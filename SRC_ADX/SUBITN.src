##########################################################################################################
Subprog C_HDTSTOFCY(VALEUR)
Variable Char    VALEUR()

Local Char SZSALFCY(GLONFCY)
Local Char SZHDTITM(GLONITM)
Local Char SZSTOFCY(GLONFCY)
Local Integer IITFOK
Local Integer ILIGNE  # FGR 09/12/2010 : X3SUIVI69775

  ILIGNE = nolign-1   # FGR 09/12/2010 : X3SUIVI69775
  SZSALFCY = [M:ITN0]SALFCY
  SZHDTITM = [M:ITN8]HDTITM(nolign-1)
  SZSTOFCY = VALEUR
  IITFOK = 1
  #Vérifie si un site de stokage est bien présent sur une consomation de type pièce
  If [M:ITN8]HDTTYP(nolign-1) = 2 Then
    #consomation de type pièce
    If VALEUR = "" Then
      GMESSAGE = mess(204,177,1) #Il faut obligatoirement saisir un site de stockage.
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
  Gosub CHECKITF From SUBSREB4
  If IITFOK = 0 Then
    End
  Endif
  Gosub CHECKFCY From SUBSREB4
  If IITFOK = 0 Then
    End
  Endif
  # FGR 09/12/2010 : X3SUIVI69775
  Call CTL_HDTDONDAT_HDTSTOFCY([M:ITN8]HDTTYP(ILIGNE), [M:ITN8]HDTSTOISS(ILIGNE), [M:ITN8]HDTDONDAT(ILIGNE), VALEUR) From SUBSREB4
  If mkstat Then
    End
  Endif
End

##########################################################################################################
Subprog AM_HDTSTOFCY(VALEUR)
Variable Char    VALEUR()

Local Integer INOL

  # FGR 15/10/2010 : X3SUIVI67190
  INOL = nolign-1
  # Sorties de stock
  Call INIZONSOR("ITN8", [M:ITN8]HDTITM(INOL), VALEUR, INOL, 24, [M:ITN0]TRSCOD , "") From STKECR
End

##########################################################################################################
Subprog IB_HDTITM

  Raz GBOUT3
  If [M:ITN8]HDTTYP(nolign-1) = 2 Then
    Call TEXTE(17614, GBOUT3) From OBJDIV      #Stocks articles
  Endif
End

##########################################################################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

Local Char SZSOC(GLONCPY)

  If VALEUR <> "" Then
    If [M:ITN0]SRVDEMNUM <> "" Then
      Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
      If !fstat Then
        If [F:SRE]SALFCY <> "" and [F:SRE]SALFCY <> VALEUR Then
          Read [FCY]FCY0=VALEUR
          If fstat Then
            GMESSAGE = mess(83,123,1) #Valeur incorrect.
            GERR = 1
            mkstat = 2
            End
          Else
            SZSOC = [F:FCY]LEGCPY
            Read [FCY]FCY0=[F:SRE]SALFCY
            If [F:FCY]LEGCPY <> SZSOC Then
              #Le site de l'intervention n'est pas sur la même société juridique que celui de la demande de service.
              GMESSAGE = mess(155,177,1)
              GERR = 1
              mkstat = 2
              End
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AS_HDTITM(VALEUR)
Variable Char    VALEUR()

  If [M:ITN8]HDTTYP(nolign-1) = 2 Then
    If VALEUR <> "" Then
      If [M:ITN8]HDTSTOISS(nolign-1) = 2 Then
        If [M:ITN8]HDTDONDAT(nolign-1) <> [00/00/00] Then
          If [M:ITN8]HDTISSISS(nolign-1) > 0 Then
            mkstat = 2
            End
          Endif
          If GITN8HDTISSISS(nolign-1) > 0 Then
            mkstat = 2
            End
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AS_HDTUOM(VALEUR)
Variable Char    VALEUR()

  If [M:ITN8]HDTTYP(nolign-1) = 2 Then
    If [M:ITN8]HDTITM(nolign-1) <> "" Then
      If [M:ITN8]HDTSTOISS(nolign-1) = 2 Then
        If [M:ITN8]HDTDONDAT(nolign-1) <> [00/00/00] Then
          If [M:ITN8]HDTISSISS(nolign-1) > 0 Then
            mkstat = 2
            End
          Endif
          If GITN8HDTISSISS(nolign-1) > 0 Then
            mkstat = 2
            End
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AS_HDTDONDAT(VALEUR)
Variable Date    VALEUR

  Gosub CHECKCANDONE From SUBITNB3
  Gosub NO_MODIF_SSTOK From SUBITNB3  # FGR 13/10/2010 : X3SUIVI68214
End

##########################################################################################################
Subprog C_HDTDONDAT(VALEUR)
Variable Date    VALEUR

Local Integer ILIGNE

  # FGR 09/12/2010 : X3SUIVI69775
  ILIGNE = nolign-1
  If VALEUR <> [0/0/0] Then
    # Je ne peux pas utiliser l'action : la date n'est pas obligatoire ici
    # FGR 20/06/2014 : X3SUIVI100319 : Seulement si article géré en stock.
    If [F:ITM]ITMREF <> [M:ITN8]HDTITM(ILIGNE) Then
      Read [F:ITM]ITM0=[M:ITN8]HDTITM(ILIGNE)
    Endif
    If [F:ITM]STOMGTCOD <> 1 Then
      Call CONTPER(VALEUR, 1, [M:ITN0]SALFCY) From CPTSUB
      If mkstat Then
        GERR = 1
        End
      Endif
    Endif
  Endif
  #
  Call CTL_HDTDONDAT_HDTSTOFCY([M:ITN8]HDTTYP(ILIGNE), [M:ITN8]HDTSTOISS(ILIGNE), VALEUR, [M:ITN8]HDTSTOFCY(ILIGNE)) From SUBSREB4
  If mkstat Then
    End
  Endif
End

