######################################################################################
## Section automatically added (Object DMWPPA) 01/12/2017 11:31:13 (ANGRE)
######################################################################################
$ACTION
#  If GUSER = "ANGRE"
#    Infbox ACTION
#  Endif
Case ACTION
    When "OUVRE"      : Gosub DECLARE From TABLEAUX
   When "FILTRE"      : Default File [F:DMWPPAH]
   When "LIENS"       : Gosub LIENS From TABLEAUX
   When "MODIF"       : Gosub MODIF From TABLEAUX
   When "ANNULE"      : Gosub ANNULE From TABLEAUX
   When "APRES_CRE"   : Gosub LIENS From TABLEAUX
   When "APRES_MOD"   : Gosub LIENS From TABLEAUX
   When "CREATION"    : Gosub CREATION From TABLEAUX
   When "DEFLIG"      : Gosub DEFLIG
   When "INICRE_LIG"  : Gosub INICRE_LIG
   When "LIENS_LIG"   : Gosub LIENS_LIG
   When "INICRE"      : Gosub INICRE
   When "ANNULE"      : Gosub ANNULE From TABLEAUX
   When "SETBOUT"     : Gosub SETBOUT
   When "SEL_LISTE"   : If LISTE = "SELID" : Gosub SELECT_ID : Endif
   When Default
Endcase
Return



$SELECT_ID
    Local Integer DIMPAORD, I
    Local Char DESCRIPTION (30)
    If !clalev([DMWPAOR]) : Local File DMWPAORD [DMWPAOR] : Endif
    Filter [F:DMWPAOR] Where COD = PARAM(1) and TYP = val(PARAM(2))
    DIMPAORD = rowcount([F:DMWPAOR])
    If DIMPAORD > 0
      Local Char TEXTE(30)(1..DIMPAORD, 1..2)                      # Array for selection rows
      Local Char TEX(30)(1..DIMPAORD)                              # Array for selection values

      # Initialize row and column counter.
      NBCOL = 0                                                     # Column counter
      NBTEX = 0                                                     # Row counter

      # Set selection title.
      Case PARAM(2)
        When "1"
          TIT(NBCOL) = "Product group"
        When "2"
          TIT(NBCOL) = "Packing material"
        When "3"
          TIT(NBCOL) = "Pack size"
        When "4"
          TIT(NBCOL) = "Tariff type"
        When "5"
          TIT(NBCOL) = "Tariff category"
        When Default
          TIT(NBCOL) = "ID"
      Endcase


      # Set column titles.
      NBCOL += 1
      TIT(NBCOL) = "ID"
      NBCOL += 1
      TIT(NBCOL) = "Description"

      For [F:DMWPAOR]

          # Add row to selection list.
          Call LECTEXTRA(DESCRIPTION,"DMWPAORD","DES",PARAM(1),num$(PARAM(2)) +"~"+ [F:DMWPAOR]TYPID) From ATEXTRA
          NBTEX += 1
          TEX( NBTEX ) = [F:DMWPAOR]TYPID
          TEXTE( NBTEX, 1 ) = [F:DMWPAOR]TYPID
          TEXTE( NBTEX, 2 ) = DESCRIPTION
      Next
      #Endif
      Filter [F:DMWPAOR]
    Else
      Infbox "No record available"
    Endif
Return

######################################################################################

#########################################################################
# Initialisation
# we have a unique counter field (PKGNUM) and a version counter field (PKGVERSION)
# the version counterfield is related to COD
#########################################################################
$INICRE
  [F:DMWPPAH]PKGNUM       = func GETNEXTNUM()
  [M:DMWPPA0]PKGNUM      = [F:DMWPPAH]PKGNUM
  [F:DMWPPAH]VER   = func GETNEXTVERSIONNUMBER([F:DMWPPAH]SCMCOD, [F:DMWPPAH]ITMREF)
  [M:DMWPPA0]VER  = [F:DMWPPAH]VER

  Affzo [M:DMWPPA0]VER

Return

#########################################################################
# Tableaux inits
#########################################################################
$DEFLIG
  #Infbox "deflig"
  Default Mask [DMWPPA1]
  Default File [DMWPPAD]
  CRIT    = 'PKGNUM='+num$([F:DMWPPAH]PKGNUM)
  FICLIG  = "DMWPRODPACKD"
  ABLIG   = "DMWPPAD"
  ZONLIG  = "LIN"
 # NBLIG = 2
Return

#########################################################################
# Initialisation detail
#########################################################################
$INICRE_LIG
  [F:DMWPPAD]PKGNUM     = [F:DMWPPAH]PKGNUM
  [F:DMWPPAD]VER = [M:DMWPPA0]VER
Return

$LIENS_LIG
  Call UPDATEIDDESCRIPTION([M:DMWPPA1]PKGMAT(nolign-1), 2)
  Call UPDATEIDDESCRIPTION([M:DMWPPA1]PKGSIZ(nolign-1), 3)
  Call UPDATEIDDESCRIPTION([M:DMWPPA1]TAFCAT (nolign-1), 5)
  Call UPDATEIDDESCRIPTION([M:DMWPPA1]ITMGRP(nolign-1), 1)
Return


Subprog UPDATEIDDESCRIPTION(TYPID, TYP)
  Variable Char TYPID
  Value Tinyint TYP
  Local Char DESCRIPTION(30)
  Call LECTEXTRA(DESCRIPTION,"DMWPAORD","DES",[M:DMWPPA0]SCMCOD,num$(TYP) +"~"+ TYPID) From ATEXTRA
  Case TYP
    When 1
      [M:DMWPPA1]ITMGRPDES(nolign-1) = DESCRIPTION
      Affzo [M:DMWPPA1]ITMGRPDES(nolign-1)
    When 2
      [M:DMWPPA1]PKGMATDES(nolign-1) = DESCRIPTION
      Affzo [M:DMWPPA1]PKGMATDES(nolign-1)
    When 3
      [M:DMWPPA1]PKGSIZDES(nolign-1) = DESCRIPTION
      Affzo [M:DMWPPA1]PKGSIZDES(nolign-1)
    When 5
      [M:DMWPPA1]TAFCATDES(nolign-1) = DESCRIPTION
      Affzo [M:DMWPPA1]TAFCATDES(nolign-1)
  Endcase

End


#########################################################################
# Button control
#########################################################################
$SETBOUT
    CHAINE += "A"
    Actzo [M:DMWPPA1]
Return



