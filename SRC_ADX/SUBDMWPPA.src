Subprog AM_SCMCOD(VALEUR)
Variable Char    VALEUR()
  Call HIDEORSHOWCOLUMNS(VALEUR,[M:DMWPPA0]SCMCOD) # hide
End



Subprog HIDEORSHOWCOLUMNS(PSCHEMEA, PSCHEMEO)
Value Char PSCHEMEA
Value Char PSCHEMEO
Local Integer CRYO : CRYO = 0
  If !clalev ([F:DMWSC])     : Local File DMWSCHEME [DMWSC]      : Endif
  If PSCHEMEO <> "" #if scheme has changed by user
    Read [F:DMWSC]DMWSC0 = PSCHEMEO   # read old scheme
    If !fstat
        CRYO = [F:DMWSC]CRY #set country of old scheme
    Endif
  Endif

  Read [F:DMWSC]DMWSC0 = PSCHEMEA # read actual scheme
  If !fstat
      If [F:DMWSC]CRY = 1                 # if Germany
        Gosub HIDECOLUMNS                 # hide obsolete columns
      Else
        Gosub SHOWCOLUMNS                 # show needed columns
      Endif
      # if country has changed empty the detail lines.
      If CRYO <> [F:DMWSC]CRY and CRYO <> 0
          Raz [M:DMWPPA1]
          Affzo [M:DMWPPA1]
      Endif
  Endif

End
# Hide columns wich are not used for the actuall scheme
$HIDECOLUMNS
  Chgfmt [M:DMWPPA1]ITMGRP With "-K:30"
  Chgfmt[M:DMWPPA1]ITMGRPDES With "-K:30"
  Chgfmt[M:DMWPPA1]PKGSIZ With "-K:30"
  Chgfmt[M:DMWPPA1]PKGSIZDES With "-K:30"
  Chgfmt[M:DMWPPA1]TAFCAT With "-K:30"
  Chgfmt[M:DMWPPA1]TAFCATDES With "-K:30"
  Affzo [M:DMWPPA1]
Return

# Hide columns wich are used for the actuall scheme
$SHOWCOLUMNS
  Chgfmt[M:DMWPPA1]ITMGRP With "K:30"
  Chgfmt[M:DMWPPA1]ITMGRPDES With "K:30"
  Chgfmt[M:DMWPPA1]PKGSIZ With "K:30"
  Chgfmt[M:DMWPPA1]PKGSIZDES With "K:30"
  Chgfmt[M:DMWPPA1]TAFCAT With "K:30"
  Chgfmt[M:DMWPPA1]TAFCATDES With "K:30"
  Affzo [M:DMWPPA1]
Return


