#########################################################################
## use this function to get a new unique number for the given parms
#########################################################################
Funprog GETNEXTNUM()
If !clalev([DMWPPAH]) : Local File DMWPRODPACKH [DMWPPAH]  Order By Key DMWPPAH0 Desc  : Endif
End uniqid([DMWPPAH])


Subprog C_ITMGRP(VALEUR)
Variable Char    VALEUR()

  If !clalev([DMWPAOR]) : Local File DMWPAORD [DMWPAOR] : Endif
  Filter [F:DMWPAOR] Where COD = [M:DMWPPA0]SCMCOD and TYP = 1 and TYPID = VALEUR
  If rowcount([F:DMWPAOR]) <= 0
    Call ERREUR (func AFNC.MES1(mess(4,7707,1),[M:DMWPPA0]SCMCOD)) From GESECRAN
    mkstat = 2
  Endif
  Filter [F:DMWPAOR]

End

Subprog AM_ITMGRP(VALEUR)
Variable Char    VALEUR()
  Call UPDATEIDDESCRIPTION(VALEUR, 1)
  [M]UPDFLG = 1
End

