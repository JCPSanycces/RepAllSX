#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
    Case ACTION
        When "INIT"     : Gosub INIT
        When "INIT_DIA" : Gosub INIT_DIA
        When "EXEC"     : Gosub EXEC
        When Default
    Endcase
Return

$INIT
    Local Char LLEG(GLONADI) : [L]LLEG = PARAM(1)
    Local Char CRITERE(250)

    If clalev([F:DTT]) = 0 Then : Local File DATEVTAX [DTT] : Endif
    If clalev([F:TVT]) = 0 Then : Local File TABVAT   [TVT] : Endif
Return

$INIT_DIA
    [M:DTC]LEG = [L]LLEG
    Gosub BUILD_CRITERIA
    Filter [F:TVT] Where evalue([L]CRITERE)
    [M:DTC]CNT = rowcount([F:TVT])
    Filter [F:TVT]
Return

$EXEC
    Local Integer I
    Local Integer FOUND

    Gosub BUILD_CRITERIA
    Filter [F:TVT] Where evalue([L]CRITERE)

    For [F:TVT]TVT0
        [L]FOUND = 0
        For [L]I = 0 To [M:DTT]NBLIG - 1
            If [M:DTT]TAX([L]I) = [F:TVT]VAT Then
                [L]FOUND = 1
                Break
            Endif
        Next [L]I
        If [L]FOUND = 1 Then
            # update
            If [M:DTC]DELASS = [V]CST_AYES Then
                # the "Remove existing assignment" flag is set
                [M:DTT]TAXDATEV([L]I) = 0
                [M:DTT]DTTISSCOD([L]I) = 0
                [M:DTT]DTTISSDES([L]I) = func SUBDTT.GET_DESCRIPTION([M:DTT]DTTISSCOD([L]I))
                Diszo [M:DTT]DTTISSCOD([L]I)
            Endif
        Else
            # insert
            [L]I = [M:DTT]NBLIG
            [M:DTT]TAX([L]I) = [F:TVT]VAT
            [M:DTT]TAXDATEV([L]I) = 0
            [M:DTT]DTTISSCOD([L]I) = 0
            [M:DTT]DTTISSDES([L]I) = func SUBDTT.GET_DESCRIPTION([M:DTT]DTTISSCOD([L]I))
            Affzo [M:DTT]DTTISSCOD([L]I)
            Diszo [M:DTT]DTTISSCOD([L]I)
            [M:DTT]NBLIG += 1
        Endif
    Next
    Affzo [M:DTT]1-99
    # FIXME cannot tell the object that the grid content is modified

    Filter [F:TVT]
Return

$BUILD_CRITERIA
    [L]CRITERE = "1=1"

    If [M:DTC]INCALL = [V]CST_AYES or [M:DTC]LEG <> "" Then
        [L]CRITERE -= "& (0=1"
        If [M:DTC]INCALL = [V]CST_AYES Then
            [L]CRITERE -= "| [F:TVT]LEG=''"
        Endif

        If [M:DTC]LEG <> "" Then
            [L]CRITERE -= "| [F:TVT]LEG='" + [M:DTC]LEG + "'"
        Endif
        [L]CRITERE += ")"
    Endif

    If [M:DTC]VATSTR <> "" Then
        [L]CRITERE -= "& [F:TVT]VAT>='" + [M:DTC]VATSTR + "'"
    Endif

    If [M:DTC]VATEND <> "" Then
        [L]CRITERE -= "& [F:TVT]VAT<='" + [M:DTC]VATEND + "'"
    Endif
Return

########################################################################################################################
## Section automatically added (screen DATEVTXOP) 08/23/2017 12:00:09 (TOGAN)
########################################################################################################################

Subprog AM_VATSTR(VALEUR)
    Variable Char VALEUR()
    [M:DTC]VATSTR = VALEUR
    Gosub UPDATE_COUNT
End

Subprog AM_VATEND(VALEUR)
    Variable Char VALEUR()
    [M:DTC]VATEND = VALEUR
    Gosub UPDATE_COUNT
End

Subprog AM_INCALL(VALEUR)
    Variable Integer VALEUR
    [M:DTC]INCALL = VALEUR
    Gosub UPDATE_COUNT
End

########################################################################################################################

$UPDATE_COUNT
    Local Char CRITERE(250)

    Gosub BUILD_CRITERIA
    Filter [F:TVT] Where evalue([L]CRITERE)
    [M:DTC]CNT = rowcount([F:TVT])
    Filter [F:TVT]
    Affzo [M:DTC]CNT
Return

########################################################################################################################

