#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank import type codes
# Supervisor
## CRUD-CLASSE ## BSIIMPTC
# 2018-08-16 22:22:47 574

Gosub TEST From WMCR_BSIIMPTC : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,BSICODTC,BAN)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# BSIIMPTC : BSIIMPTC
# BSIITCD : BSIIMPTC BSIITCD
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet BSIIMPTC._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1,A_N2,A_S2
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = BSIIMPTC.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(BSIIMPTC.ACTX.AFOLDER,nomap,"")>0
 Local File BSIIMPTC [BSITC]
 Local File BSIITCD [BSITCD]
 Local File ATEXTRA [AXX]
Else
 Local File =BSIIMPTC.ACTX.AFOLDER+".BSIIMPTC" [BSITC]
 Local File =BSIIMPTC.ACTX.AFOLDER+".BSIITCD" [BSITCD]
 Local File =BSIIMPTC.ACTX.AFOLDER+".ATEXTRA" [AXX]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [BSITC] With
& [BSITCD]BSITCD0 = [F:BSITC]BSICODTC;[F:BSITC]BAN
& As [LNK_]
Return



