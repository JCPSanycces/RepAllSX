#<AdxTL>@(#)0.0.0.0 $Revision$Class XML files
# Supervisor
## CRUD-CLASSE ## EDIXMLFIL
# 2018-11-06 07:05:17 970


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(EDIXMLFIL,ASTATUS)
Variable Instance EDIXMLFIL Using C_EDIXMLFIL
Variable Integer ASTATUS

If EDIXMLFIL = null : End : Endif

Gosub _AVARIABLES From WMC00EDIXMLFIL

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_EDIXMLFIL

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EDIXMLFIL,ASTATUS)
Variable Instance EDIXMLFIL Using C_EDIXMLFIL
Variable Integer ASTATUS

If EDIXMLFIL = null : End : Endif

Gosub AVARIABLES From WMC00EDIXMLFIL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EDIXMLFIL
Else
 Gosub ADELETE_EDIXMLFIL
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EDIXMLFIL,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EDIXMLFIL.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDIXMLFIL.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EDIXMLFIL.EXFN)
 If EDIXMLFIL.EXFN([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFN([L]A_I).ACTION("ADELETE_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXFD) : # EDIXMLFILD -- 2
 If EDIXMLFIL.EXFD(A_N2) <> null
& and EDIXMLFIL.EXFD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIXMLFIL.EXFD(A_N2).ASTALIN<>[V]CST_ANEW
   EDIXMLFIL.EXFD(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ACTION("ADELETE_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXSD) : # EDIXMLFILXSD -- 3
 If EDIXMLFIL.EXSD(A_N2) <> null
& and EDIXMLFIL.EXSD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIXMLFIL.EXSD(A_N2).ASTALIN<>[V]CST_ANEW
   EDIXMLFIL.EXSD(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ACTION("ADELETE_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXFF) : # EDIXMLFILF -- 4
 If EDIXMLFIL.EXFF(A_N2) <> null
& and EDIXMLFIL.EXFF(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIXMLFIL.EXFF(A_N2).ASTALIN<>[V]CST_ANEW
   EDIXMLFIL.EXFF(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ACTION("ADELETE_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER
For A_N2=1 To maxtab(EDIXMLFIL.EXFD) : # EDIXMLFILD -- 2
 If EDIXMLFIL.EXFD(A_N2) <> null
& and EDIXMLFIL.EXFD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXSD) : # EDIXMLFILXSD -- 3
 If EDIXMLFIL.EXSD(A_N2) <> null
& and EDIXMLFIL.EXSD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIXMLFIL.EXFF) : # EDIXMLFILF -- 4
 If EDIXMLFIL.EXFF(A_N2) <> null
& and EDIXMLFIL.EXFF(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [L]A_I=1 To maxtab(EDIXMLFIL.EXFN)
 If EDIXMLFIL.EXFN([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFN([L]A_I).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EDIXMLFIL
Trbegin [F:EXF]
 Gosub ADELETE_EDIXMLFIL
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_EDIXMLFIL
[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDIXMLFIL.EXFD)
 If EDIXMLFIL.EXFD(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ACTION("ADELETE_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDIXMLFIL.EXFD(A_N2).ASTALIN=[V]CST_ADEL
  [L]ASTATUS = func WMC00EDIXMLFIL._MAJSQL_EDIXMLFILD(EDIXMLFIL.EXFD(A_N2))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFD(A_N2).ACTION("ADELETE_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDIXMLFIL.EXSD)
 If EDIXMLFIL.EXSD(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ACTION("ADELETE_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDIXMLFIL.EXSD(A_N2).ASTALIN=[V]CST_ADEL
  [L]ASTATUS = func WMC00EDIXMLFIL._MAJSQL_EDIXMLFILXSD(EDIXMLFIL.EXSD(A_N2))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXSD(A_N2).ACTION("ADELETE_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDIXMLFIL.EXFF)
 If EDIXMLFIL.EXFF(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ACTION("ADELETE_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDIXMLFIL.EXFF(A_N2).ASTALIN=[V]CST_ADEL
  [L]ASTATUS = func WMC00EDIXMLFIL._MAJSQL_EDIXMLFILF(EDIXMLFIL.EXFF(A_N2))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  [L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.EXFF(A_N2).ACTION("ADELETE_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(EDIXMLFIL,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EDIXMLFIL._MAJSQL_EDIXMLFIL(EDIXMLFIL))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EDIXMLFIL.snapshotEnabled=1
 [L]A_RETIK = EDIXMLFIL.revertUpdTick
Endif
[L]ASTATUS = max(fmet EDIXMLFIL.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



