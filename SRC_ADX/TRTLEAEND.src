#<AdxTL>@(#)0.0.0.0 $Revision$
#
#***********************************************************************************
#
#        SAISIE FENETRE SUR CONTRAT DE LOCATION-FINANCEMENT (LEA)
#
#      LEAEND0   :  Entête  Résiliation du contrat (OAC0)
#      LEAEND    :  Résiliation du contrat (LEAE)
#      CMPEND    :  Maj des biens rattachés  (OCP)
#
#***********************************************************************************
#    Création
#    MDR - 24.10.2003
#
#**************************************************************************************
#    Modification
# Issue X3-110500 - 2018-09-27 by CBO : event lea
# MDJ   10.17.2017 X3-39795     Manage ORIGIN and ORICOD fields in GL Entry
# MDJ - 16.08.2012  (FQ 83515)  Contrôles effectués en AM_ et AP_ remplacés par C_
# MDJ - 08.10.2008  Adaptations V6
#**************************************************************************************
#
ACTION
 Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "DEBUT"         : Gosub DEBUT
  When "APRES_MODIF"   : Gosub APRES_MODIF
  When "AVANT_MODFIC"  : Gosub AVANT_MODFIC
  When "OK"            : Gosub OK
  When "ABA"           : Gosub ABA
  When "FIN"           : Gosub FIN
  When Default
 Endcase

Return
#
#---------------------------------#
# OUVRE                           #
#---------------------------------#
$OUVRE

Global  Date WDATDEBEX
Global  Date WDATFINEXS

# Récupération des informations des biens liés au contrat
 If !(clalev([F:FAS])) : Local File FXDASSETS [FAS] : Endif
 Filter [FAS] Where LEAREF=[M:LEA0]LEAREF
 Raz nolign
 For [FAS]
  nolign+=1
  [M:OCP]OBJREF(nolign-1)  = [F:FAS]AASREF
  [M:OCP]OBJDES(nolign-1)  = [F:FAS]AASDES1
 Next
 Filter [FAS]

 [M:OCP]NBOBJ=nolign

If !(clalev([F:FIS])) : Local File FISCYEAR [FIS] : Endif
# Récupération des informations exercices courantdu contexte CPFI
   Filter [FIS] Where CPY=[M:LEA0]CPY and CNX = G300CPFI and STAFIY = GVML_TECOURA
   Read [FIS]First
   Filter [FIS]
   WDATDEBEX= [F:FIS]DATSTRFIY
If !(clalev([F:FISS])) : Local File FISCYEAR [FISS] : Endif
# Récupération des informations exercice suivant du contexte CPFI
   Filter [FISS] Where CPY=[M:LEA0]CPY and CNX = G300CPFI and STAFIY = GVML_TESUIV
   Read [FISS]First
   Filter [FISS]
   WDATFINEXS = [F:FISS]DATENDFIY

Gosub ACTION From TRTOBJACT

Return
#
#====================================================
#
$DEBUT

Global Integer NUMACT

#==> Appel du traitement d'init commun à toutes les actions

 Gosub ACTION From TRTOBJACT

# Récupération des informations du contrat
  [M:LEAE]ENDLEADAT = [M:LEA1]ENDLEADAT
  Actzo [M:LEAE]
  Affzo [M:LEAE]

 Affzo [M:OCP]

If NUMACT=0
 NUMACT+=1
Endif

Return
#
#====================================================
#
$APRES_MODIF
  REP="M"
Return
#
#-------------------------------------------------------------------------------
$AVANT_MODFIC

Local  Integer LCDRET
Local  Char    LCDINT
Local  Date    WDATEFF
Local  Date    WDATCPTINT
Local Integer  L_RET
Local Date     L_CNXDAT(1..5)
Local Char     LPIECE
#------------------------------------------
 GREASON = mess(92,7771,1)
 # à confirmer  WDATEFF=min(date$, [M:LEAE]ENDLEADAT)
 WDATEFF= [M:LEAE]ENDLEADAT

 Call GET_CNX_DAT2([M:LEA0]CPY, G300CPFI, GVML_TECOURA, L_CNXDAT, L_RET) From GLOBIENS
 If L_CNXDAT(4)=[0/0/0]
   WDATFINPER = L_CNXDAT(2)
 Else
   WDATFINPER = L_CNXDAT(4)
 Endif

 # Génération d'un évènement de type "LEAEND" plan Comptable
 LCDINT= "LEAEND"+num$(G301CPT)
 LPIECE = "LCACT"
 WDATCPTINT=max([M:LEAE]ENDLEADAT,  [M:LEA0]PERENDCPT)
 #
 Call GENER_EVE (GVML_OMLOCFI,[M:LEA0]CPY,[M:LEA0]FCY,[M:LEA0]LEAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET)  From GENEVE
 If (LCDRET > 20 )
   GOK = 0
   Call FSTA("ELEAEND") From GLOCK : Return
 Endif
 # Génération d'un évènement de type "LEAEND" plan IAS
 #Gosub CPTLEA
 # Issue X3-83749
 If GCNXPROIAS = G_OUI & ([M:LEA0]LEATYP = GVML_CREBAIL or [M:LEA0]LEATYP = GVML_LOCATION )
   LCDINT= "LEAEND"+num$(G301IAS)
   LPIECE = "0LACT"
   WDATCPTINT=max([M:LEAE]ENDLEADAT, [M:LEA0]PERENDIAS)
   Call GENER_EVE (GVML_OMLOCFI,[M:LEA0]CPY,[M:LEA0]FCY,[M:LEA0]LEAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET)  From GENEVE
   If (LCDRET > 20 )
   GOK = 0
   Call FSTA("ELEAEND") From GLOCK : Return
 Endif
 #Gosub CPTLEA
 Endif
#------------------------------------------

Return
#==========================================================
# Comptabilisation actualisation du contrat

$CPTLEA
 If !clalev([F:E43]) : Local File ELEAEND [E43] : Endif
 Local Char    IDENT(20)(7)
 Local Integer STAT
 Local Char    MESSA(255)
 #*X3-39795 Local Char    TZONE(10)(1..1)   # Tableau des noms des zones à forcer
 #*X3-39795 Local Char    TVAL (10)(1..1)   # Tableau des valeurs des zones à forcer
 Local Char     TZONE(10)(1..10) : # Table des zones à forcer (Ex: type de pièce)
 Local Char     TVAL(30)(1..10)  : # Table des valeurs des zones à forcer

 IDENT(0) = [M:LEA0]CPY
 IDENT(1) = "LEAEND"
 IDENT(2) = num$(G301AUC)
 IDENT(3) = [M:LEA0]FCY
 IDENT(4) = [M:LEA0]LEAREF
 IDENT(5) = func GENEVE.BUILD_TIMSTP(date$, time)
 IDENT(6) = GUSER

 TZONE(1) = "REFINT"    : TVAL(1) = "D-"+num$(NUMACT)
 TZONE(2) = "ORIGIN"    : TVAL(2) = "2"        :#Automatic loading  #*X3-39795
 TZONE(3) = "ORICOD"    : TVAL(3) = LPIECE                          #*X3-39795
 Call VALPCE3(LPIECE,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO

 If STAT
    Infbox num$(STAT)-MESSA
 Else
   Update [E43] Where (CPY    = IDENT(0) &
&                      EVT    = IDENT(1) &
&                      PLN    = G301AUC  &
&                      FCY    = IDENT(3) &
&                      REF    = IDENT(4) &
&                      TIMSTP = IDENT(5) &
&                      CREUSR = IDENT(6)) With CPTFLG=G_OUI,UPDUSR=GUSER,UPDDAT=date$
    If fstat
       GOK=0 : Return
    Else
       #Infbox "enregistrements modifiés"-num$(adxuprec)
    Endif
 Endif


Return
#====================================================
#
$OK

  # Affectation pour mise à jour en sortie
#Fq-83515  Call AM_ENDLEADAT([M:LEA1]ENDLEADAT)
  [M:LEA0]LEASTA = GVML_STECHU  :  Affzo   [M:LEA0]LEASTA
  [M:LEA1]ENDLEADAT = [M:LEAE]ENDLEADAT   :  Affzo   [M:LEA1]ENDLEADAT
  Diszo [M:LEA0]
  Diszo [M:LEA1]
  Diszo [M:LEA2]


  # Issue X3-56289
  Diszo [M:LEA3]
  Diszo [M:LEA4]
  Diszo [M:LEA5]
  Diszo [M:LEA9]
#   Actzo [M:LEA9]EVTLIST X3-110500
   Actzo [M:LEA0]EVTLIST # X3-110500

  G_ACT_MOD=1

  mkstat = 4
  FIN=1
  Affzo   [M:LEAE]

  Global Char G_ACT
  G_ACT="LEAEND"

 If G_ACT_MOD & !([M:OCP]NBOBJ=0) # S'il y a des modifs à reporter et si il y a des objets liés
  Global Char G_ACT_NAM           # On crée la variable G_ACt_NAM
  G_ACT_NAM="LEAEND"              # On l'alimente avec le nom de l'action en cours
 Endif

 Gosub ACTION From TRTOBJACT

Return
#
#====================================================
#
$ABA

 Gosub DEBUT # Clic sur abandon, on recharge toutes les valeurs d'origine
Return
#
#====================================================
#
$FIN

 # On détruit les globales (à l'action) de gestion des habilitations en sortant
 Gosub ACTION From TRTOBJACT

Return
#
#====================================================
#
#==============================================================#
# Traitement de mise à jour et de génération d'événement       #
# des biens liés lors d'un transfert                           #
#==============================================================#
$ACTMET
 Case ACTMET
  When "CRITMEN"      : Gosub CRITMEN       # Critère d'activation du menu.
  When "FILL_HEA"     : Gosub FILL_HEA      # Alimentation zone spé à l'action de l'en-tête [OAC0]
  When "MAJ_LNK"      : Gosub MAJ_LNK       # Mise à jour et alimentation des objets liés
  When "INIT_OBJ_DIV" : Gosub INIT_OBJ_DIV  # Ouvertures tables à mettre à jour dans MAJ_LNK
  When Default
 Endcase
Return

$CRITMEN
 # Permet d'alimenter la variable CRITMEN, condition d'activation du menu
 CRITMEN='REP="" & [M:LEA0]LEASTA = GVML_STENCOU'
Return

$FILL_HEA
 # Permet d'alimenter d'autre élément de l'en-tête
 #[M:OAC0]TSTZONSUP=[M:LEA2]????? # Tests
Return

$INIT_OBJ_DIV
Return

$MAJ_LNK
 For I_OBJ=0 To [M:OCP]NBOBJ-1          # Boucle sur les biens rattachés
  Read [FASM]FAS0=[M:OCP]OBJREF(I_OBJ)
 # Maj Type date de sortie et motif de sortie du bien
  [F:FASM]ISSDAT= [M:LEA1]ENDLEADAT
  If [M:LEA0]LEATYP = GVML_CREBAIL
    [F:FASM]ISSTYP=GVML_TSFCONT
  Else
    [F:FASM]ISSTYP=GVML_TSFCLOC
  Endif
  [F:FASM]ISSDATRUL=GVML_IRJOURP

  Rewrite [FASM]
  If fstat
   GOK=0
   Break
  Endif
 Next I_OBJ
Return

$EVT_LNK

Return

