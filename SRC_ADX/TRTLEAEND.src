##########################################################################
##+Fq-83515 C_date de fin du contrat :
##########################################################################
Subprog C_ENDLEADAT(VALEUR)
Variable Date    VALEUR

Local Integer OK

#
#  la date de fin de contrat doit être >= à la date de début de l'exercice
#  courant du contexte CPF
#
If (VALEUR < WDATDEBEX)
  GERR= 1
  GMESSAGE= mess(51,7771,1)
  mkstat = 2 : End
Endif

#
#  La date de fin de contrat doit être <= à la date de fin de l'exercice
#  suivant du contexte CPF
#
If (VALEUR > WDATFINEXS  )
  GERR= 1
  GMESSAGE= mess(108,7771,1)
  mkstat = 2 : End
Endif

If VALEUR <> [M:LEA1]ENDLEADAT and (VALEUR >= WDATDEBEX and VALEUR <= WDATFINEXS )
  Call OUINON (mess(50,7771,1), OK) From GESECRAN
  If OK = 1
    mkstat=2
  Endif
Endif

End
##########################################################################

