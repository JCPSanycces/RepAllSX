###############################################################################
# PJMOPE1
###############################################################################
Subprog C_NBAFF
Local Integer IRET
Local Integer ILINE

  If status = 82 or status = 73 Then
    # Insert a line
    If [M:PJOPE1]POANUM(nolign-1) = 0 Then
      ILINE = fmet GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).ADDLINE("RAFFT", [V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
        Call SHOW_RAFFT_LINE(ILINE) From PJMACTOPE
      Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
        #[L]IRET = fmet GZINSPJM.PJM_RESET_ERRORS()        # Issue X3-96497 - 2018-06-28 by FGR
        [L]IRET = fmet GZINSPJM.RESET_ERRORS()             # Issue X3-96497 - 2018-06-28 by FGR
        GERR = 4
        mkstat = 2
        GOK = 1
        End
      Endif
      Affzo [M:PJOPE1]1-99
    Endif
  Elsif status = 65 Then
    # Delete a line
    IRET = fmet GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).ADELLINE("RAFFT", GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT([M:PJOPE1]COLLIN(nolign-1)).AORDER)
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
      #[L]IRET = fmet GZINSPJM.PJM_RESET_ERRORS()        # Issue X3-96497 - 2018-06-28 by FGR
      [L]IRET = fmet GZINSPJM.RESET_ERRORS()             # Issue X3-96497 - 2018-06-28 by FGR
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

###############################################################################
Subprog AM_POACLB(VALEUR)
Variable Char    VALEUR()

  GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT([M:PJOPE1]COLLIN(nolign-1)).POACLB = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_RAFFT_LINE([M:PJOPE1]COLLIN(nolign-1)) From PJMACTOPE
  Endif
End

###############################################################################
Subprog AM_POADES(VALEUR)
Variable Char    VALEUR()

  GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT([M:PJOPE1]COLLIN(nolign-1)).POADES = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_RAFFT_LINE([M:PJOPE1]COLLIN(nolign-1)) From PJMACTOPE
    DTOTAL = fmet GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT_SUM_POARMNQTY
    If DTOTAL > [M:PJOPE0]RMNQTY Then
      [M:PJOPE0]RMNQTY = DTOTAL
      Affzo [M:PJOPE0]RMNQTY
    Endif
  Endif
End

