###############################################################################
Subprog AM_POASTDQTY(VALEUR)
Variable Decimal VALEUR

Local Decimal DTOTAL

  GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT([M:PJOPE1]COLLIN(nolign-1)).POASTDQTY = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_RAFFT_LINE([M:PJOPE1]COLLIN(nolign-1)) From PJMACTOPE
    # -----------------------------
    DTOTAL = fmet GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE1]COLLIN).RAFFT_SUM_POASTDQTY
    If DTOTAL > [M:PJOPE0]EXTQTY Then
      [M:PJOPE0]EXTQTY = DTOTAL
      Affzo [M:PJOPE0]EXTQTY
    Endif
    # -----------------------------
    If GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT([M:PJOPE1]COLLIN(nolign-1)).POARMNQTY <>
&      GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT([M:PJOPE1]COLLIN(nolign-1)).snapshot.POARMNQTY
&   Then
      DTOTAL = fmet GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT_SUM_POARMNQTY
      If DTOTAL > [M:PJOPE0]RMNQTY Then
        [M:PJOPE0]RMNQTY = DTOTAL
        Affzo [M:PJOPE0]RMNQTY
      Endif
    Endif
  Endif
End

###############################################################################
Subprog AM_POARMNQTY(VALEUR)
Variable Decimal VALEUR

Local Decimal DTOTAL

  GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT([M:PJOPE1]COLLIN(nolign-1)).POARMNQTY = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_RAFFT_LINE([M:PJOPE1]COLLIN(nolign-1)) From PJMACTOPE
    DTOTAL = fmet GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT_SUM_POARMNQTY()
    If DTOTAL > [M:PJOPE0]RMNQTY Then
      [M:PJOPE0]RMNQTY = DTOTAL
      Affzo [M:PJOPE0]RMNQTY
    Endif
  Endif
End

