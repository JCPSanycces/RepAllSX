#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# SUBPJOPE
###############################################################################
$ACTION
  Case ACTION
    When Default
  Endcase
Return

###############################################################################
# PJMOPE0
###############################################################################
Subprog AM_RMNQTY(VALEUR)
Variable Decimal VALEUR

  GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RMNQTY = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_RTKO([M:PJOPE0]COLLIN) From PJMACTOPE
  Endif
End

