#<AdxTL>@(#)0.0.0.0 $Revision$ 
$OPERATIONS
Case [L]AOPERATION
  When "ESSWRKSIG"          : Gosub ESSWRKSIG
  When "ESSWRKSIGHYBRID"    : Gosub ESSWRKSIGHYBRID #FRLAA X3-91923 2018-05-22
Endcase
Return

#FRLAA X3-91923 2018-05-22 - START
$METHODS
#Case [L]AMETHOD
#
#Endcase
Return

$ESSWRKSIGHYBRID
$ESSWRKSIG
#Invoke the manual workflow method and pass the record and event
#The workflow actions will handle the needed record update(s)
#Keys from representation
#CHRONO
#DEST

#Parameters
#PSIG - Signature (VIS, REF etc)
#PWRKFLWEVT - Event DCG, EXS, etc..

[L]ARET_VALUE = [V]CST_AOK
#Iniate the record - instantiating the class
Local Integer READSTAT
Local Instance  I_ESSWRKHISSUI Using C_ESSWRKHISSUI
I_ESSWRKHISSUI         = NewInstance C_ESSWRKHISSUI AllocGroup null
READSTAT  = fmet I_ESSWRKHISSUI.AREAD(CHRONO,DEST)
If READSTAT > [V]CST_AWARNING
  FreeGroup I_ESSWRKHISSUI
  [L]ARET_VALUE=fmet this.ASETERROR("",mess(00060,00100,1)-CHRONO-mess(00119,07776,1),[V]CST_AERROR)
  Return
Endif


Gosub INST_WRKFLOW

Return

$INST_WRKFLOW

Gosub WORKFLOW_SIGN
Return

#-------------------------------------------
$HANDLE_EXS
Local Integer EXS_UPD, CLE_EXSNUM, TRAN_PEND
Local Char CLE_REFNUM(GLONMAT), CLE_CTRNUM(GLONCTR), CLE(255)
Local File EXPENSESHEA [F:EXSHWRK]

TRAN_PEND = adxlog
EXS_UPD   = 2

If !TRAN_PEND
  Trbegin [F:EXSHWRK]
Endif

CLE = I_ESSWRKHISSUI.CLEDEC #Original triggering key
#TODO: All the context fields are added to the class ESSWRKHISSUI - They shouldnt change and can safely be used

#Example:
#-----------------------------------#
#CLE_REFNUM = I_ESSWRKHISSUI.VALCTX1
#CLE_EXSNUM = val(I_ESSWRKHISSUI.VALCTX2)
#CLE_CTRNUM = I_ESSWRKHISSUI.VALCTX4
#-----------------------------------#

# REFNUM
CLE_REFNUM = left$(CLE, instr(1,CLE,"~")-1)
CLE        = right$(CLE,instr(1,CLE,"~")+1)

# EXSNUM
CLE_EXSNUM = val(left$(CLE,instr(1,CLE,"~")-1))
CLE        = right$(CLE,instr(1,CLE,"~")+1)

#CTRNUM
CLE_CTRNUM = left$(CLE,instr(1,CLE,"~")-1)

Read [F:EXSHWRK]EXSH0 = [L]CLE_REFNUM;[L]CLE_EXSNUM;[L]CLE_CTRNUM
If !fstat
  Case PSIG
    When "VIS"
      [F:EXSHWRK]EXSSTA = 3
    When "REF"
      [F:EXSHWRK]EXSSTA = 4
  Endcase

  Rewrite [F:EXSHWRK]
  If fstat
    EXS_UPD = 1
  Endif
Endif

If !TRAN_PEND
  If EXS_UPD = 2
    Commit
  Else
    Rollback
  Endif
Endif

LogicClose File [F:EXSHWRK]

Return


$WORKFLOW_SIGN
Gosub WORKFLOW_UPDATE_STAT
Gosub EXEC_WORKFLOW
Return

$WORKFLOW_UPDATE_STAT
Local Integer TYPEVT,STAT
Local Char    CODE(20)
Local Char    MESSAGE(250),FILTRE(250)
Local Integer REQUEST

#Check the parameter to determine the workflow code
CODE = "ESS"+PWRKFLWEVT+PSIG
FILTRE = "[F:AWS]CHRONO = '"+I_ESSWRKHISSUI.CHRONO+"' and [F:AWS]DEST = '" + I_ESSWRKHISSUI.DEST+"'"
SIMUL = 1
Return

$EXEC_WORKFLOW
[L]ARET_VALUE=fmet this.ASETERROR("",mess(11,10727,1)+":"+num$(I_ESSWRKHISSUI.CHRONO)+"-"+I_ESSWRKHISSUI.DEST,[V]CST_AINFO)
STAT =  func ASYRWRKCLASSIC.WORKMANUAL(I_ESSWRKHISSUI.ACTX,CODE,FILTRE,SIMUL,REQUEST,MESSAGE)
If STAT = [V]CST_AOK
  [L]ARET_VALUE=fmet this.ASETERROR("",MESSAGE,[V]CST_AINFO)
Else
  [L]ARET_VALUE=fmet this.ASETERROR("",MESSAGE,[V]CST_AERROR)
Endif

FreeGroup I_ESSWRKHISSUI
Return

