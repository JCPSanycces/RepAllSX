####################################################################################
# Sage Sales Tax Generic Library - can be used by both SSTTAXLIB and SSTADRLIB
#
# Process:    SSTLIB
#             Common code to read SST parameters and send requests to Syracuse
#             framework interface with SST REST API.
#
####################################################################################

#**
#* SST_PARAM - Set SST connection parameters
#*
#* @param X3_CPY - X3 company, normally from GSOCIETE or GDEFSOC
#* @param SST_CPY - SST company. X3 company can be C01 and SST company could be SST, for example
#* @param SST_ACCOUNT - SST (Avatax account) - required to connect to avatax
#* @param SST_LICENSE - SST license to be used (Avatax license) - required to connect to Avatax
#* @param SST_URL - Development(testing) or production url
#* @param ERR - Error (0=no error, otherwise  error)
#* @param ERRMSG - Error message
#*!
Subprog SST_PARAM(X3_CPY,SST_CPY,SST_ACCOUNT,SST_LICENSE,SST_URL,ERR,ERRMSG)
Value Char       X3_CPY
Variable Char    SST_CPY(),SST_ACCOUNT(),SST_LICENSE(),SST_URL(),ERRMSG()
Variable Integer ERR

Local Integer I : I=1
Raz ERR,ERRMSG

If !clalev([F:LTP]) :  Local File LTAPAR [LTP] : Endif
If !clalev([F:CPY]) :  Local File COMPANY [CPY] : Endif   # 106867.n

If [F:LTP]DOSSIER <> nomap
    Read [F:LTP]LTP0=nomap
    If fstat
        ERR=1
        ERRMSG=mess(141,105,1)- "[LTAPAR-"+nomap+"]"
        End
    Endif

Endif

If X3_CPY <> ""
    # Look for SST Company based on X3 Company
    # I=find(X3_CPY,[F:LTP]CPY)   # 106867.o
    # If  I=0   # 106867.o
    # 106867.sn
    # SST Company is now stored in the X3 Company table
    Read [F:CPY]CPY0 = X3_CPY
    If fstat | [F:CPY]SSTCPY=""
        ERR=1
        # ERRMSG="Unable to find Sage Sales Tax Company for X3 Company ["+X3_CPY+"]"   # 106867.o
        ERRMSG=mess(170,104,1)- "["+X3_CPY+"]"   # 106867.n
        End
    Endif
Endif

# SST_CPY     = [F:LTP]SSTCPY(I-1)                      # SST Company   # 106867.o
SST_CPY     = [F:CPY]SSTCPY                             # SST Company   # 106867.n
SST_ACCOUNT = [F:LTP]ACCTID                             # Sage Sales Tax Account assigned by Avalara
SST_LICENSE = [F:LTP]LICKEY                             # Sage Sales Tax license assigned by Avalara

If  [F:LTP]USEPRDURL = 2                                # Production or Development Sage Sales Tax URL to be used
    SST_URL=[F:LTP]PRDURL
Else
    SST_URL=[F:LTP]DEVURL
Endif

End

####################################################################################################
Subprog SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)
  Value    Char    FUNCTION
  Value    Clbfile ARGUMENTS
  Variable Clbfile RESHEAD
  Variable Clbfile RESBODY
  Variable Integer ERR
  Variable Char    ERRMSG

  Local Integer STATUSCODE
  Local Char    MODULE(100)   : MODULE = 'bundles/sage-salestax'
  Local Char    MODE(10)      : MODE   = 'wait'
  Local Char    ENCODINGS(40)
  Local Integer CALLBACKINDEX
  Local Char    RETURNS(50)
  Local Char    RETURNS_ENC(3)

  STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE,FUNCTION,MODE,ARGUMENTS,ENCODINGS,CALLBACKINDEX,RETURNS,RETURNS_ENC,RESHEAD,RESBODY)
  If STATUSCODE<>200
    ERR = 1
    ERRMSG = FUNCTION+":"-num$(STATUSCODE)
  Endif
  RESBODY=unescJson(RESBODY)
End

#* Ping Avatax to determine if connection is possible
#*
#* @PARAM X3_CPY - PASSED - X3 COMPANY USED To DETERMINE AVATAX COMPANY
#* @param TEST_RESULT - Success or Message from Avatax
#* @param ERR - Returned - 0 if no error otherwise error
#* @param ERRMSG - Returned - Failed + Error Message
#*!
Subprog SST_PING(TEST_RESULT,ERR,ERRMSG)
Variable Clbfile  TEST_RESULT()
Variable Char     ERRMSG()
Variable Integer  ERR

Local Char SST_URL(250),SST_ACCOUNT(200),SST_LICENSE(200),SST_JAVBRG(250),SST_CPY(25)

Local Char    AUTH(50),FUNCTION(30)
Local Clbfile ARGUMENTS(0),RESHEAD(0),RESBODY(6)
Local Char    RESULTCODE(15)

  Raz TEST_RESULT,ERRMSG,ERR

  Call SST_PARAM("",SST_CPY,SST_ACCOUNT,SST_LICENSE,SST_URL,ERR,ERRMSG)
  If  ERR
    Goto PING_CLEAN
  Endif


  #Syracuse Estimat tax to test connection
  AUTH = SST_ACCOUNT + ":" + SST_LICENSE
  #Adding test coordinates to URL
  SST_URL += "/1.0/tax/47.627935,-122.51702/get"

  FUNCTION = 'sstEstimateTax'

  # Just using $10 sale amount for testing
  Append ARGUMENTS, '"'  + AUTH     + '"'
  Append ARGUMENTS, ',"' + SST_URL  + '"'
  Append ARGUMENTS, ',"  + 10     + "'

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)
  If  ERR
    TEST_RESULT = mess(00194,00133,1) + ": " + ERRMSG
    ERRMSG = TEST_RESULT
    Goto PING_CLEAN
  Endif

  RESULTCODE = func FINDVAL(RESBODY,"ResultCode")

  If toupper(RESULTCODE) = "SUCCESS"
    TEST_RESULT = mess(40,9900,1)
  Else
    ERR = 1
    TEST_RESULT = mess(00194,00133,1) + ": " + func FINDVAL(RESBODY,"Summary")
    ERRMSG = TEST_RESULT
  Endif

  $PING_CLEAN
End

####################################################################################################
Funprog FINDVAL(RESP,K)
  Value    Clbfile  RESP
  Value    Char     K

  Local Integer X

  X = instr(1,RESP, '"' + K + '":')
  If !X : End "" : Endif
  X += len(K)+5

End seg$(RESP,X,instr(X,RESP,'"')-1)

