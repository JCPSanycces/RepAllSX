#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du fichier PARTRZL
################################################################################
#    PARAMETRAGE transit zones
#    FGR
#    Création le : 28/03/2003
#    Modification le : 17/08/2004
#-------------------------------------------------------------------------------
# PROGRAMMES ACTIONS :
################################################################################
# MODIFICATIONS :
################################################################################
# - USR - dd.mm.yyyy - FQ nnnnn - Commentaire
# MDJ 19.09.2014 FQ99561_b    : Add free field loading management
################################################################################
Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("TZL",GBIDC1,GBIDC2) From GOBJET
End

################################################################################
$ACTION
  #Infbox "ACTION="-num$(ACTION)
  Case ACTION
    When "OUVRE"            : Gosub OUVRE
    When "LIENS"            : Gosub LIENS
    When "CREATION"         : Gosub CREATION
    When "MODIF"            : Gosub MODIF
    When "ANNULE"           : Gosub ANNULE
    When "RAZCRE"           : Gosub RAZCRE
    When "RAZDUP"           : Gosub RAZDUP
    When "APRES_MODIF"      : Gosub APRES_MODIF
    When "SETBOUT"          : Gosub SETBOUT
    When Default
  Endcase
Return
################################################################################

#-------------------------------------------------------------------------------
$OUVRE
  #-------------------------
  If clalev([F:TZL])=0  : Local File PARTRZL    [TZL]  : Endif : # Paramétrage transit zones
  If clalev([F:TZLC])=0 : Local File PARTRZL    [TZLC] : Endif : # Paramétrage transit zones
  If clalev([F:TZD])=0  : Local File PARTRZLDET [TZD]  : Endif : # Paramétrage transit zones détail
  If clalev([F:AMZB])=0 : Local File AMSKZON    [AMZB] : Endif : # Dictionnaire des champs écran
  If clalev([F:ATY])=0  : Local File ATYPE      [ATY]  : Endif : # Types de données
Return

#-------------------------------------------------------------------------------
$LIENS
Local Char CHAINE, CHECRANS(250), CHECRAND(250), LCODZON(20)

  Call GET_LISTE_ECRAN ([M:TZL0]WINSRC, CHECRANS) From GLOBIENS
  If CHECRANS = "" Then
    CHECRANS = "1=1"
  Endif
  Call GET_LISTE_ECRAN ([M:TZL0]WINDES, CHECRAND) From GLOBIENS
  If CHECRAND = "" Then
    CHECRAND = "1=1"
  Endif
  #----------------------------
  # Lecture des champs paramétrés
  nolign = 1
  For [TZD] Where KEYTZL=[M:TZL0]KEYTZL
    [M:TZL1] = [F:TZD]
    #----------------------------
    LCODZON =  func GLOBIENS.VIRE_INDICE_CODZON ([M:TZL1]CODZONSRC(nolign-1))
    #----------------------------
    Filter [AMZB] Where CODZON=LCODZON and evalue(CHECRANS)
    Read [AMZB]CODE Last
    Filter [AMZB]
    #----------------------------
    [M:TZL1]ZINTITSRC(nolign-1) = func GLOBIENS.GET_LIBELLE_CHAMP ([M:TZL0]CPY, [F:AMZB]CODMSK, [M:TZL1]CODZONSRC(nolign-1), [M:TZL0]OBJSRC)
    #----------------------------
    Filter [ATY] Where CODTYP=[F:AMZB]CODTYP
    Read [ATY]CODTYP Last
    Filter [ATY]
    [M:TZL1]TYPDTABAS(nolign-1) = [F:ATY]TYPTYP
    [M:TZL1]TYPDTA(nolign-1)    = [F:AMZB]CODTYP
    #----------------------------
    Affzo [M:TZL1]ZINTITSRC(nolign-1)
    Affzo [M:TZL1]TYPDTABAS(nolign-1)
    Affzo [M:TZL1]TYPDTA(nolign-1)
    #--------------------------------------------------------
    LCODZON =  func GLOBIENS.VIRE_INDICE_CODZON ([M:TZL1]CODZONDES(nolign-1))
    #----------------------------
    Filter [AMZB] Where CODZON=LCODZON and evalue(CHECRAND)
    Read [AMZB]CODE Last
    Filter [AMZB]
    #----------------------------
    [M:TZL1]ZINTITDES(nolign-1) = func GLOBIENS.GET_LIBELLE_CHAMP ([M:TZL0]CPY, [F:AMZB]CODMSK, [M:TZL1]CODZONDES(nolign-1), [M:TZL0]OBJDES)
    #----------------------------
    Affzo [M:TZL1]ZINTITDES(nolign-1)
    #----------------------------
    nolign += 1
  Next
  #----------------------------
  [M:TZL1]NBTZLDET = nolign-1
  #----------------------------
Return

#-------------------------------------------------------------------------------
$CREATION
  # Gbn-020206-Fq 34151-Si la clé est vide, on appelle le sous-pro d'alimentation de la clé.
  If [M:TZL0]KEYTZL=""
   Call ALIMENTE_CLE ([M:TZL0]CPY, [M:TZL0]OBJSRC, [M:TZL0]OBJDES)
  Endif

  # Enregistrement des champs paramétrés
  For nolign=1 To [M:TZL1]NBTZLDET
    Raz [F:TZD]
    [F:TZD] = [M:TZL1]
    [F:TZD] = [M:TZL0] : # faut bien faire en transclasse de l'entête en dernier pour les valeur clé de l'entête
    Write [TZD]
    If fstat Then
      GOK=0
      Call FSTA("TZD") From GLOCK
      Break
    Endif
  Next nolign
  If OK=0 : Return : Endif
Return

#-------------------------------------------------------------------------------
$MODIF
  # on détruit tout et on recrée
  Gosub ANNULE

  # Pour tous les tabulaires
  Gosub CREATION
Return

#-------------------------------------------------------------------------------
$ANNULE
  # Modification des champs paramétrés
  Delete [TZD] Where KEYTZL=[M:TZL0]KEYTZL
  If fstat=1 Then
    GOK = 0
    Call RSTA("TZD",CLECUR1) From GLOCK
    Return
  Endif
Return

#-------------------------------------------------------------------------------
$APRES_MODIF

  If [M:TZL0]KEYTZL <> "" and (COUZON = "CPY" or COUZON = "OBJSRC" or COUZON = "OBJDES") Then
    Read [TZLC]TZL0=[M:TZL0]KEYTZL
    If fstat Then
      COUZON = CLEPRIM
      CZ = [M:TZL0]KEYTZL
    Else
      CLECUR1 = num$([M:TZL0]KEYTZL)
      Gosub RELIT From GOBJSUB
    Endif
  Endif
Return

#-------------------------------------------------------------------------------
$RAZCRE
  Call ACTION_BLOCK (ACB_EFFZO, "PARTRZL1", "CODZONSRC") From GLOBIENS
Return

#-------------------------------------------------------------------------------
$RAZDUP
  # FGR03082004 : X3Suivi:23978 On laisse le contenu du tableau en duplication
  #Call ACTION_BLOCK (ACB_EFFZO, "PARTRZL1", "CODZONSRC") From GLOBIENS
Return

#-------------------------------------------------------------------------------
$SETBOUT
Local Integer LSTAT : # réponse call VERFALLCPY

  # Pas de suppression du paramétrage par défaut en dehors des environnements de développement
  If GADONIX=G_NON & [M]CPY="" Then
   Call VIREBOUT(CHAINE,"A") From GOBJET
  Else
    # Pas de suppression du paramétrage par défaut si pas d'habilitation "tous sites du dossier"
    If [M]CPY="" & GNBAUZ <> GNBSITE Then
      Call VIREBOUT(CHAINE,"A") From GOBJET
    Else
      # Pas de suppression du paramétrage d'1 société si pas d'habilitation "tous sites de la société"
      Call VERFALLFCY([M]CPY,[L]LSTAT) From SUPCPT
      If [L]LSTAT < 1 Then
        Call VIREBOUT(CHAINE,"A") From GOBJET
      Endif
    Endif
  Endif
Return

################################################################################
#
################################################################################
################################################################################
########################################
Subprog GET_IDENT_TZL (PCPY, POBJSRC, POBJDES, RIDENT)
Value Char PCPY
Value Integer POBJSRC
Value Integer POBJDES
Variable Char RIDENT

  RIDENT = PCPY+'-'+num$(POBJSRC)+'-'+num$(POBJDES)
End

########################################
Subprog ALIMENTE_CLE (PCPY, POBJSRC, POBJDES)
Value Char PCPY
Value Integer POBJSRC
Value Integer POBJDES

Local Char LIDENT

# Gbn-020206-Fq 34151-La société peut être vide : cas du paramétrage par défaut.
#If PCPY <> "" and POBJSRC <> 0 and POBJDES <> 0 Then
 If POBJSRC <> 0 and POBJDES <> 0 Then
    Call GET_IDENT_TZL (PCPY, POBJSRC, POBJDES, LIDENT)
    [M:TZL0]KEYTZL = LIDENT
    Affzo [M:TZL0]KEYTZL
  Endif
End

################################################################################
# ECRAN : PARTZL0
################################################################################
########################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

  Call ALIMENTE_CLE (VALEUR, [M:TZL0]OBJSRC, [M:TZL0]OBJDES)
End

########################################
Subprog AS_OBJSRC(VALEUR)
Variable Integer VALEUR

  GMENLOC(GVML_OMBIEN)  = 1
  GMENLOC(GVML_OMSUBV)  = 1
  GMENLOC(GVML_OMLOCFI) = 1
  # Seule la dépense peut être source
  GMENLOC(GVML_OMINVEN) = 1
  GMENLOC(GVMLOMPHY)    = 1

  If [M:TZL1]NBTZLDET > 0 Then
    # Si le tableau a déjà des ligne, on ne peut plus changer l'objet destination
    mkstat = 2
  Endif
End

########################################
Subprog AM_OBJSRC(VALEUR)
Variable Integer VALEUR

  Call GET_WIN_ON_341 (VALEUR, [M:TZL0]WINSRC) From GLOBIENS
  Affzo [M:TZL0]WINSRC
  Call ALIMENTE_CLE ([M:TZL0]CPY, VALEUR, [M:TZL0]OBJDES)
End

########################################
Subprog AS_OBJDES(VALEUR)
Variable Integer VALEUR

 ## On ne peut pas choisir le même objet destination que la source
  GMENLOC([M:TZL0]OBJSRC) = 1
  If [M:TZL0]OBJSRC = GVML_OMDEPEN Then
    GMENLOC(GVML_OMSUBV)  = 1
    GMENLOC(GVML_OMLOCFI) = 1
    # Seul le bien comptable peut être cible
    GMENLOC(GVML_OMINVEN) = 1
    GMENLOC(GVMLOMPHY)    = 1
  Endif

  If [M:TZL1]NBTZLDET > 0 Then
    # Si le tableau a déjà des ligne, on ne peut plus changer l'objet destination
    mkstat = 2
  Endif
End

########################################
Subprog AM_OBJDES(VALEUR)
Variable Integer VALEUR

  Call GET_WIN_ON_341 (VALEUR, [M:TZL0]WINDES) From GLOBIENS
  Affzo [M:TZL0]WINDES
  Call ALIMENTE_CLE ([M:TZL0]CPY, [M:TZL0]OBJSRC, VALEUR)
End

################################################################################
# ECRAN : PARTZL1
################################################################################
########################################
Subprog AM_CODZONSRC(VALEUR)
Variable Char    VALEUR()

Local Char CHAINE, CHECRAN(250), LCODZON(20)
Local Integer N_I

  #----------------------------
  Call GET_LISTE_ECRAN ([M:TZL0]WINSRC, CHECRAN) From GLOBIENS
  If CHECRAN = "" Then
    CHECRAN = "1=1"
  Endif

  LCODZON =  func GLOBIENS.VIRE_INDICE_CODZON (VALEUR)
  Filter [AMZB] Where CODZON=LCODZON and evalue(CHECRAN)
  Read [AMZB]CODE Last
  Filter [AMZB]
  If fstat>2 Then
    # Erreur : code inexistant
    GMESSAGE = mess(25,7770,1) : # Champ inexistant
    GERR     = 1
    mkstat   = 2
    End
  Else
    #----------------------------
    If [F:AMZB]SAIAFF=2 or [F:AMZB]SAIAFF=3 Then
      # Erreur : Champ invisible en standard. Choix interdit
      GMESSAGE = mess(26,7770,1) : # Champ invisible en standard. Il ne peut être choisi
      GERR     = 1
      mkstat   = 2
      End
    Elsif [F:AMZB]CODTYP='W' &[F:AMZB]CODTYP='ABS' Then
      # Erreur : Champ interdit
      GMESSAGE = mess(26,7770,1) : # Champ invisible en standard. Il ne peut être choisi
      GERR     = 1
      mkstat   = 2
      End
    Else
      #----------------------------
      Filter [ATY] Where CODTYP=[F:AMZB]CODTYP
      Read [ATY]CODTYP Last
      Filter [ATY]
      If [F:ATY]TYPTYP=7 and [F:AMZB]CODTYP<>'ADI' Then
        # Erreur : Champ interdit
        GMESSAGE = mess(137,7770,1) : # Ce champ ne peut être choisi. Aucune zone libre ne peut être destinatrice de ce type d'information.
        GERR     = 1
        mkstat   = 2
        End
      Else
        #----------------------------
        Local Integer SV_TYPTYP
        Local Char    SV_CODTYP
        [L]SV_TYPTYP = [F:ATY]TYPTYP
        [L]SV_CODTYP = [F:AMZB]CODTYP
        #----------------------------
        If [M:TZL1]CODZONDES(nolign-1)<>""
          # Lecture du type de la zone de destination
          Filter [AMZB] Where CODZON=[M:TZL1]CODZONDES(nolign-1) and evalue(CHECRAN)
          Read [AMZB]CODE Last
          Filter [AMZB]
          If fstat>2 Then
            # Code inexistant. On met le champ à vide
            [M:TZL1]CODZONDES(nolign-1)=""
          Else
            Filter [ATY] Where CODTYP=[F:AMZB]CODTYP
            Read [ATY]CODTYP Last
            Filter [ATY]
            If [L]SV_TYPTYP <> [F:ATY]TYPTYP Then
              # Erreur : Les types de données sont différents
              GMESSAGE = mess(32,7770,1) : # Les types des données doivent être identiques
              GERR     = 1
              mkstat   = 2
              End
            Endif
          Endif
        Endif
        #----------------------------
        [M:TZL1]CODZONSRC(nolign-1) = VALEUR
        [M:TZL1]ZINTITSRC(nolign-1) = func GLOBIENS.GET_LIBELLE_CHAMP ([M:TZL0]CPY, [F:AMZB]CODMSK, VALEUR, [M:TZL0]OBJSRC)
        #----------------------------
        [M:TZL1]TYPDTABAS(nolign-1) = [L]SV_TYPTYP : # FQ40917
        [M:TZL1]TYPDTA(nolign-1)    = [L]SV_CODTYP : # FQ40917
        #----------------------------
        Affzo [M:TZL1]CODZONSRC(nolign-1)
        Affzo [M:TZL1]ZINTITSRC(nolign-1)
        Affzo [M:TZL1]TYPDTABAS(nolign-1)
        Affzo [M:TZL1]TYPDTA(nolign-1)
        #----------------------------
      Endif
    Endif
  Endif
End

########################################
Subprog AM_CODZONDES(VALEUR)
Variable Char    VALEUR()

Local Char CHAINE, CHECRAN(250), LCODZON(20)
Local Integer N_I

  #----------------------------
  If left$(VALEUR,4) <> "USRF" Then
    # Erreur : code interdit, seules les ZL sont autorisées
    GMESSAGE = mess(31,7770,1) : # Seules les zones libres peuvent être en destination
    GERR     = 1
    mkstat   = 2
    End
  Else
    Call GET_LISTE_ECRAN ([M:TZL0]WINDES, CHECRAN) From GLOBIENS
    If CHECRAN = "" Then
      CHECRAN = "1=1"
    Endif
    #----------------------------
    LCODZON =  func GLOBIENS.VIRE_INDICE_CODZON (VALEUR)
    Filter [AMZB] Where CODZON=LCODZON and evalue(CHECRAN)
    Read [AMZB]CODE Last
    Filter [AMZB]
    If fstat>2 Then
      # Erreur : code inexistant
      GMESSAGE = mess(25,7770,1) : # Champ inexistant
      GERR     = 1
      mkstat   = 2
      End
    Else
      #----------------------------
      If [F:AMZB]SAIAFF = 3 Then
        # Erreur : Champ invisible en standard. Choix interdit
        GMESSAGE = mess(26,7770,1) : # Champ invisible en standard. Il ne peut être choisi
        GERR     = 1
        mkstat   = 2
        End
      Else
        #----------------------------
        For N_I = 1 To [M:TZL1]NBTZLDET
          If N_I <> nolign Then
            If [M:TZL1]CODZONDES(N_I-1) = VALEUR Then
              # Erreur : Un champ ne peut être destination plusieurs fois
              GMESSAGE = mess(27,7770,1)-num$(N_I) : # Ce champ a déjà été saisi à la ligne
              GERR     = 1
              mkstat   = 2
              End
            Endif
          Endif
          #------------------------------
          # Suite de la boucle
        Next N_I
        #----------------------------
        Filter [ATY] Where CODTYP=[F:AMZB]CODTYP
        Read [ATY]CODTYP Last
        Filter [ATY]
        If [M:TZL1]TYPDTABAS(nolign-1) <> [F:ATY]TYPTYP Then
          # Erreur : Les types de données sont différents
          GMESSAGE = mess(32,7770,1) : # Les types des données doivent être identiques
          GERR     = 1
          mkstat   = 2
          End
        Endif
        #----------------------------
        [M:TZL1]CODZONDES(nolign-1) = VALEUR
        [M:TZL1]ZINTITDES(nolign-1) = func GLOBIENS.GET_LIBELLE_CHAMP ([M:TZL0]CPY, [F:AMZB]CODMSK, VALEUR, [M:TZL0]OBJDES)
        #----------------------------
        Affzo [M:TZL1]CODZONDES(nolign-1)
        Affzo [M:TZL1]ZINTITDES(nolign-1)
        #----------------------------
      Endif
    Endif
  Endif
End

########################################
Subprog AV_CUM(VALEUR)
Variable Integer VALEUR

  If [M:TZL1]TYPDTABAS(nolign-1) < 2 or [M:TZL1]TYPDTABAS(nolign-1) > 6 Then
    # si non numérique : on ne peut pas cumuler
    mkstat = 2
  Endif
End

########################################
Subprog AM_CUM(VALEUR)
Variable Integer VALEUR

  If VALEUR = G_OUI Then
    [M:TZL1]ALLVALEQU(nolign-1) = 0
    [M:TZL1]FREMAI(nolign-1)    = 0
    [M:TZL1]ORNUL(nolign-1)    = 0
    [M:TZL1]CNSVAL(nolign-1)    = ""
    Affzo [M:TZL1]ALLVALEQU(nolign-1)
    Affzo [M:TZL1]FREMAI(nolign-1)
    Affzo [M:TZL1]ORNUL(nolign-1)
    Affzo [M:TZL1]CNSVAL(nolign-1)
  Elsif VALEUR = G_NON Then
    [M:TZL1]ORNUL(nolign-1) = 0
    Affzo [M:TZL1]ORNUL(nolign-1)
  Endif
End

########################################
Subprog AV_ALLVALEQU(VALEUR)
Variable Integer VALEUR

  If [M:TZL1]TYPDTABAS(nolign-1) < 2 or [M:TZL1]TYPDTABAS(nolign-1) > 6 Then
    # si non numérique : on peut vérifier si valeur unique
  Elsif [M:TZL1]TYPDTABAS(nolign-1) >= 2 and [M:TZL1]TYPDTABAS(nolign-1) <= 6 and [M:TZL1]CUM(nolign-1) = G_NON Then
    # si numérique non cumulé : on peut vérifier si valeur unique
  Else
    # sinon : impossible de saisir cette rubrique
    mkstat = 2
  Endif
End

########################################
Subprog AM_ALLVALEQU(VALEUR)
Variable Integer  VALEUR

  If VALEUR = G_NON Then
    [M:TZL1]ORNUL(nolign-1)  = 0
    [M:TZL1]FREMAI(nolign-1) = 0
    Affzo [M:TZL1]ORNUL(nolign-1)
    Affzo [M:TZL1]FREMAI(nolign-1)
  Endif
End

########################################
Subprog AV_ORNUL(VALEUR)
Variable Integer  VALEUR

  If [M:TZL1]CUM(nolign-1) = G_OUI Then
    # Sur une zone cumulées on ne peut pas choisir cette rubrique
    mkstat = 2
  Elsif [M:TZL1]ALLVALEQU(nolign-1) = G_NON Then
    mkstat = 2
  Endif
End

########################################
Subprog AM_ORNUL(VALEUR)
Variable Integer VALEUR

  If VALEUR = G_OUI Then
    [M:TZL1]FREMAI(nolign-1) = 0
    Affzo [M:TZL1]FREMAI(nolign-1)
  Endif
End

########################################
Subprog AV_FREMAI(VALEUR)
Variable Integer VALEUR

  If [M:TZL1]CUM(nolign-1) = G_OUI Then
    # Sur une zone cumulées on ne peut pas choisir cette rubrique
    mkstat = 2
  Elsif [M:TZL1]ALLVALEQU(nolign-1) = G_NON Then
    # Si toutes les valeurs doivent être égales on ne peut pas choisir cette rubrique
    mkstat = 2
  Endif
End

########################################
Subprog AM_FREMAI(VALEUR)
Variable Integer VALEUR
End

########################################
Subprog AV_CNSVAL(VALEUR)
Variable Char    VALEUR()

  If [M:TZL1]CUM(nolign-1) = G_OUI Then
    # Sur une zone cumulées on ne peut pas choisir cette rubrique
    mkstat = 2
  Elsif [M:TZL1]ALLVALEQU(nolign-1) = G_OUI Then
    # Si toutes les valeurs doivent être égales on ne peut pas choisir cette rubrique
    mkstat = 2
  Endif
End

########################################
Subprog AM_CNSVAL(VALEUR)
Variable Char    VALEUR()

Local Char LVALEUR(20), LCHAINE(20)
Local Date LDATE

If 0=1 Then
  LVALEUR = VALEUR
  If [M:TZL1]TYPDTABAS(nolign-1)=1 or [M:TZL1]TYPDTABAS(nolign-1)=2 or [M:TZL1]TYPDTABAS(nolign-1)=3 Then
    # Ca doit être un entier
  Elsif [M:TZL1]TYPDTABAS(nolign-1)=4 or [M:TZL1]TYPDTABAS(nolign-1)=5 or [M:TZL1]TYPDTABAS(nolign-1)=6 Then
    # Ca doit être un nombre éventuellement avec des décimales
  Elsif [M:TZL1]TYPDTABAS(nolign-1)=7 Then
    # Ca doit être une chaine, on controle rien
  Elsif [M:TZL1]TYPDTABAS(nolign-1)=8 Then
    # Ca doit être une date au format [jj/mm/aaaa]
    If left$(VALEUR,1)<>'[' and func GLOBIENS.AX3_RIGHT(VALEUR, 1)<>']' or len(VALEUR)<>12 Then
      GMESSAGE = mess(140,7770,1) : # Format date invalide : [99/99/9999]
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Endif
Endif

#FQ99561_b Remplacement d'un séparateur de décimal incorrect par un '.'
If [M:TZL1]TYPDTABAS(nolign-1)=4
  Local Integer K
  K = instr(1,VALEUR,mid$(adxsca,4,1))
  If K
    VALEUR = left$(VALEUR,K-1)+"."+right$(VALEUR,K+1)
  Endif
Endif

End
########################################
Subprog AS_CNSVAL(VALEUR)
Variable Char    VALEUR()

Local Char    CHAMP(10), TABLE(10), FORMA(30), CAR(1), OPTION(10)
Local Integer NOLIB , LONG , TABDIV, LINDICE

  Local File ATABZON [ATZ], ATYPE [ATY], FREFLD [FRF]

  CHAMP = [M]CODZONDES(nolign-1)
  If [M]OBJDES = GVML_OMDEPEN Then
    TABLE = "LAYOUTFAS"
  Elsif [M]OBJDES = GVML_OMBIEN Then
    TABLE = "FXDASSETS"
  Elsif [M]OBJDES = GVML_OMSUBV Then
    TABLE = "GRANTS"
  Elsif [M]OBJDES = GVML_OMLOCFI Then
    TABLE = "LEASE"
  Endif

  If CHAMP="" Then
    FORMA = "Kf:15X"
  Else
    Read [ATZ]CODZONE = TABLE;CHAMP
    Read [ATY]CODTYP = [F:ATZ]CODTYP
    NOLIB  = 0
    TABDIV = 0
    Case [F:ATY]TYPTYP
      When 1
        If [F:ATY]NOLIB<>0 Then
          NOLIB = [F:ATY]NOLIB
        Else
          NOLIB = [F:ATZ]NOLIB
        Endif
        FORMA = "Nf:2#"
      When 7
        If [F:ATY]LNGTYP<>0 Then
          LONG = [F:ATY]LNGTYP
        Else
          LONG = [F:ATZ]LONG
        Endif
        If LONG>20 : LONG = 20 : Endif
        OPTION = [F:ATY]OPTION+[F:ATZ]OPTION
        If instr(1,OPTION,"C") Then
          CAR = "d"
        Elsif instr(1,OPTION,"A")
          CAR = "d"
        Else
          CAR = "X"
        Endif
        FORMA = "Kf:"+num$(LONG)+CAR
        If [F:ATY]OBJLIEN="ADI" Then
          If left$(CHAMP, 7) = 'USRFLDA' Then
            LINDICE = -1
            Raz [FRF]
            Read [FRF]FRF0=[M]OBJDES;[M]CPY
            If fstat Then
              Read [FRF]FRF0=[M]OBJDES;""
              If fstat=0 Then
                LINDICE = val(func GLOBIENS.AX3_RIGHT(CHAMP, len(CHAMP)-7))-1
              Endif
            Else
              LINDICE = val(func GLOBIENS.AX3_RIGHT(CHAMP, len(CHAMP)-7))-1
            Endif

            If LINDICE < 0 Then
              TABDIV = val([F:ATZ]EXPLIEN)
            Else
              TABDIV = [F:FRF]ALPREF(LINDICE)
            Endif
          Else
            TABDIV = val([F:ATZ]EXPLIEN)
          Endif
        Endif
      When 8
        FORMA = "Df:"+GFMDAT
      When 2,3
        If [F:ATY]LNGTYP<>0 Then
          LONG = [F:ATY]LNGTYP
        Else
          LONG = [F:ATZ]LONG
        Endif
        FORMA = "Nf:"+num$(LONG)+"#"
      When 4
        If [F:ATY]LNGTYP<>0 Then
          LONG = [F:ATY]LNGTYP
        Else
          LONG = [F:ATZ]LONG
        Endif
        FORMA = "Nf:15F"
    Endcase
  Endif

  [M]TYPDTA(nolign-1)  = [F:ATY]CODTYP
  [M]NOLIB(nolign-1)   = NOLIB
  If TABDIV <> 0 Then
    [M]SUPP(nolign-1) = '"'+num$(TABDIV)+'"'
  Else
    [M]SUPP(nolign-1) = ""
  Endif
End
