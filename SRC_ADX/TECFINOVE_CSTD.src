###################################################################################################
# Classe TECFINOVE
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return [L]ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return [L]ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "CHECK_INPUT_DATA"              : Gosub CHECK_INPUT_DATA                From TECFINOVE_CSTD_METHODS
    When "DATA_EXTRACT"                  : Gosub DATA_EXTRACT                    From TECFINOVE_CSTD_METHODS
    #
    When "_DATA_EXTRACT_PIMPLSEL"        : Gosub _DATA_EXTRACT_PIMPLSEL          From TECFINOVE_CSTD_METHODS
    #
    When "_DATA_EXTRACT_PJMDE"           : Gosub _DATA_EXTRACT_PJMDE             From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMDE_EXECUTE"   : Gosub _DATA_EXTRACT_PJMDE_EXECUTE     From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMDE_PROV"      : Gosub _DATA_EXTRACT_PJMDE_PROV        From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMDE_PROV_SQL"  : Gosub _DATA_EXTRACT_PJMDE_PROV_SQL    From TECFINOVE_CSTD_METHODS
    #
    When "_DATA_EXTRACT_PJMSC"           : Gosub _DATA_EXTRACT_PJMSC             From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMSC_GET_SQL"   : Gosub _DATA_EXTRACT_PJMSC_GET_SQL     From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMSC_EXECUTE"   : Gosub _DATA_EXTRACT_PJMSC_EXECUTE     From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMSC_PROV"      : Gosub _DATA_EXTRACT_PJMSC_PROV        From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMSC_PROV_SQL"  : Gosub _DATA_EXTRACT_PJMSC_PROV_SQL    From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMSC_QTYAMT"    : Gosub _DATA_EXTRACT_PJMSC_QTYAMT      From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMSC_QTYAMT_SQL": Gosub _DATA_EXTRACT_PJMSC_QTYAMT_SQL  From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMSC_SUM_TOTAUX": Gosub _DATA_EXTRACT_PJMSC_SUM_TOTAUX  From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMSC_CONSOLIDAT": Gosub _DATA_EXTRACT_PJMSC_CONSOLIDAT  From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMSC_RATIO"     : Gosub _DATA_EXTRACT_PJMSC_RATIO       From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMSC_MULPRJ"    : Gosub _DATA_EXTRACT_PJMSC_MULPRJ      From TECFINOVE_CSTD_METHODS           # Issue X3-46735 - 2017-06-28 by FGR
    #
    When "_DATA_EXTRACT_PJMSCCT"         : Gosub _DATA_EXTRACT_PJMSCCT           From TECFINOVE_CSTD_METHODS
    When "_DATA_EXTRACT_PJMSCCT_MULPRJ"  : Gosub _DATA_EXTRACT_PJMSCCT_MULPRJ    From TECFINOVE_CSTD_METHODS           # Issue X3-46735 - 2017-06-28 by FGR
    #
    When "_EXIST_PCCCOD"                 : Gosub _EXIST_PCCCOD                   From TECFINOVE_CSTD_METHODS
    #
    When "TITLE_EXTRACT"                 : Gosub TITLE_EXTRACT                   From TECFINOVE_CSTD_METHODS
    When "EXTRACT_ALL"                   : Gosub EXTRACT_ALL                     From TECFINOVE_CSTD_METHODS
    When "DELETE_PIMPLSEL"               : Gosub DELETE_PIMPLSEL                 From TECFINOVE_CSTD_METHODS
    When "DELETE_PJMDE"                  : Gosub DELETE_PJMDE                    From TECFINOVE_CSTD_METHODS
    When "DELETE_PJMSC"                  : Gosub DELETE_PJMSC                    From TECFINOVE_CSTD_METHODS
    When "DELETE_PJMSCCT"                : Gosub DELETE_PJMSCCT                  From TECFINOVE_CSTD_METHODS
    When "DELETE_ALL"                    : Gosub DELETE_ALL                      From TECFINOVE_CSTD_METHODS
    When "LOAD_PRJLST"                   : Gosub LOAD_PRJLST                     From TECFINOVE_CSTD_METHODS           # Issue X3-46735 - 2017-06-28 by FGR
    #
    When "SQL_CLEAN_COMMENTS"            : Gosub SQL_CLEAN_COMMENTS              From TECFINOVE_CSTD_METHODS
    When "SQL_REPLACE_WORD_CLOB"         : Gosub SQL_REPLACE_WORD_CLOB           From TECFINOVE_CSTD_METHODS
    When "SQL_RECURSIVITE_WORD_CLOB"     : Gosub SQL_RECURSIVITE_WORD_CLOB       From TECFINOVE_CSTD_METHODS
    When "SQL_READ_CLOB"                 : Gosub SQL_READ_CLOB                   From TECFINOVE_CSTD_METHODS
    When "SQL_GET_TYPDBA"                : Gosub SQL_GET_TYPDBA                  From TECFINOVE_CSTD_METHODS
    #
    When "GET_SUM_PSCQTYX"               : Gosub GET_SUM_PSCQTYX                 From TECFINOVE_CSTD_METHODS
    When "GET_SUM_PSCAMTX"               : Gosub GET_SUM_PSCAMTX                 From TECFINOVE_CSTD_METHODS
    #
    When "GET_PCCCOD"                    : Gosub GET_PCCCOD                      From TECFINOVE_CSTD_METHODS
    When "_GET_ITM_PCCCOD"               : Gosub _GET_ITM_PCCCOD                 From TECFINOVE_CSTD_METHODS
    When "_GET_MWS_PCCCOD"               : Gosub _GET_MWS_PCCCOD                 From TECFINOVE_CSTD_METHODS
    When "_GET_TES_PCCCOD"               : Gosub _GET_TES_PCCCOD                 From TECFINOVE_CSTD_METHODS
    When "_GET_PCCCOD_GRP"               : Gosub _GET_PCCCOD_GRP                 From TECFINOVE_CSTD_METHODS
    When "_GET_DEFAULT_GRP"              : Gosub _GET_DEFAULT_GRP                From TECFINOVE_CSTD_METHODS
    When "_GET_SELECTED_GRP"             : Gosub _GET_SELECTED_GRP               From TECFINOVE_CSTD_METHODS
    #When "_LOAD_PROJECT"                 : Gosub _LOAD_PROJECT                   From TECFINOVE_CSTD_METHODS          # Issue X3-82778 - 2018-06-18 by FGR : BEGIN not necessary
    When "_GET_BUDLIG_PLBU"              : Gosub _GET_BUDLIG_PLBU                From TECFINOVE_CSTD_METHODS
    When "_GET_EMPTY_STRING"             : Gosub _GET_EMPTY_STRING               From TECFINOVE_CSTD_METHODS
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return [L]ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return [L]ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

