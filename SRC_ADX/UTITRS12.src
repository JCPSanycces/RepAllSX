#<AdxTL>@(#)7.0.0.0 $Revision$
###########################################################################
# UTITRS12   Initialisation of field BANLEG in table TABFILBAN            #
###########################################################################

If clalev([F:ADS])=0
    Local File ADOSSIER [ADS]
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER
  If fstat <> 0
        Raz [F:ADS]
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITRS12") From LECFIC
  Call MAJ_UTITRS12(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTITRS12(DOSSIER)
Value Char    DOSSIER
Local Integer WCOMPTEUR, OK

Call ECR_TRACE("UTITRS12 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:TFB])  =0  Local File =DOSSIER+".TABFILBAN"   [TFB] : Endif

Trbegin [TFB] : GOK=1
For [TFB]
 Readlock [TFB] Curr    
 If fstat = 0
  [F:TFB]BANLEG = [F:TFB]BAN+"~"+[F:TFB]LEG
  Rewrite [TFB]
  If !fstat WCOMPTEUR += 1 Endif
 Endif
Next
Commit

Close Local File [TFB]

Call ECR_TRACE("UTITRS12 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTITRS12 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI 
If fstat : Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif

If filinfo(filpath("FIL","TABFILBAN","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTITRS12(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif
If filinfo(filpath("FIL","TABFILBAN","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTITRS12(APPLI)
End

