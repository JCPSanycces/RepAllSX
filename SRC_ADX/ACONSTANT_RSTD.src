#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure ACONSTANT

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When "ACST"
    Case [L]AEVENT
      When "AREAD_AFTER" : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "ACST.CODVAR" : Gosub CODVAR
  When "ACST.TYPVAR" : Gosub TYPVAR
  When "CURFLD"      : Gosub CURFLD
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


##############################################################################

$AREAD_AFTER
  Gosub TYPVAR_DISPLAY
  Gosub CODVAR_DISPLAY
  Gosub ACONST_DISPLAY
Return

###############################################################################

$TYPVAR_DISPLAY
  # Set attributes
  Case this.TYPVAR
   When 1
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALCHAR", "$isDisabled", "false")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALINT",  "$isDisabled", "true")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALDEC",  "$isDisabled", "true")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALDAT",  "$isDisabled", "true")
   When 2
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALCHAR", "$isDisabled", "true")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALINT",  "$isDisabled", "false")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALDEC",  "$isDisabled", "true")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALDAT",  "$isDisabled", "true")
   When 3
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALCHAR", "$isDisabled", "true")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALINT",  "$isDisabled", "true")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALDEC",  "$isDisabled", "false")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALDAT",  "$isDisabled", "true")
   When 4
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALCHAR", "$isDisabled", "true")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALINT",  "$isDisabled", "true")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALDEC",  "$isDisabled", "true")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VALDAT",  "$isDisabled", "false")
  Endcase
Return

$CODVAR_DISPLAY
  # Only allow an Activity Code for Add-on, Vertical or Specific constants.
  If this.CODVAR<>AVOID.ACHAR & find(left$(this.CODVAR,1),"X","Y","Z")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("CODACT", "$isDisabled", "false")
  Else
    [L]ASTATUS = fmet this.ASETATTRIBUTE("CODACT", "$isDisabled", "true")
  Endif
Return

$ACONST_DISPLAY
[L]ASTATUS = fmet this.ASETATTRIBUTE("ACONST", "$isDisabled", "true")
Return


###############################################################################

$CODVAR
  Case [L]ARULE
    When "CONTROL"   : Gosub CODVAR_CONTROL
    When "PROPAGATE" : Gosub CODVAR_PROPAGATE
  Endcase
Return

$CODVAR_CONTROL
  # Display warning to notify the user if constant falls into any Reserved bracket.
  # This was done by calling the CONTROL method from CONTOBJ.
  # That logic will need to be rewritten for Syracuse.
Return

$CODVAR_PROPAGATE
Gosub CODVAR_DISPLAY
Gosub ACONST_DISPLAY
Return

##############################################################################
# CURFLD is a representation property needed for the Validation record link

$CURFLD
  Case [L]ARULE
    When "GET" : Gosub GET_CURFLD
  Endcase
Return

$GET_CURFLD
  this.CURFLD = this.ACTX.AFOLDER
Return

##############################################################################

$TYPVAR
  Case [L]ARULE
    When "PROPAGATE" : Gosub TYPVAR_DISPLAY
  Endcase
Return

