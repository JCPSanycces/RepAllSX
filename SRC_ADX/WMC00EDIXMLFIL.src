#<AdxTL>@(#)0.0.0.0 $Revision$Class XML files
# Supervisor
## CRUD-CLASSE ## EDIXMLFIL
# 2018-11-06 07:05:18 379

Gosub TEST From WMCR_EDIXMLFIL : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,MSGCOD,MSGREL,MSGFILNOR)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# EDIXMLFIL : EDIXMLFIL
# EDIXMLFILD : EDIXMLFIL EDIXMLFILD
# EDIXMLFILXSD : EDIXMLFIL EDIXMLFILXSD
# EDIXMLFILF : EDIXMLFIL EDIXMLFILF
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet EDIXMLFIL._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1,A_N2,A_S2,A_N3,A_S3,A_N4,A_S4
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = EDIXMLFIL.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(EDIXMLFIL.ACTX.AFOLDER,nomap,"")>0
 Local File EDIXMLFIL [EXF]
 Local File EDIXMLFILD [EXFD]
 Local File EDIXMLFILXSD [EXSD]
 Local File EDIXMLFILF [EXFF]
Else
 Local File =EDIXMLFIL.ACTX.AFOLDER+".EDIXMLFIL" [EXF]
 Local File =EDIXMLFIL.ACTX.AFOLDER+".EDIXMLFILD" [EXFD]
 Local File =EDIXMLFIL.ACTX.AFOLDER+".EDIXMLFILXSD" [EXSD]
 Local File =EDIXMLFIL.ACTX.AFOLDER+".EDIXMLFILF" [EXFF]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet EDIXMLFIL.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [EXF] With
& [EXFD]EXFD0 = [F:EXF]MSGCOD;[F:EXF]MSGREL;[F:EXF]MSGFILNOR,
& [EXSD]EXSD0 = [F:EXF]MSGCOD;[F:EXF]MSGREL;[F:EXF]MSGFILNOR,
& [EXFF]EXFF0 = [F:EXF]MSGCOD;[F:EXF]MSGREL;[F:EXF]MSGFILNOR
& As [LNK_]
Return

############################################################################################
### EDIXMLFIL(WEXF)
############################################################################################
Funprog  _MAJSQL_EDIXMLFIL(WEXF)
Variable Instance WEXF Using C_EDIXMLFIL
Local Integer ASTATUS,A_I,A_J
Default File [F:EXF]
If WEXF.ASTALIN=[V]CST_ANEW
 Call INICRE(WEXF) From ASYRSUB
 SetInstance [F:EXF] With WEXF
 For [L]A_J=1 to 20
  For [L]A_I=1 To maxtab(WEXF.EXFN)
   If WEXF.EXFN([L]A_I)<>null & !find(WEXF.EXFN([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WEXF.EXFN([L]A_I).AORDER=[L]A_J
    [F:EXF]COMTYP([L]A_J-1) = WEXF.EXFN([L]A_I).COMTYP
    [F:EXF]COMVAL([L]A_J-1) = WEXF.EXFN([L]A_I).COMVAL
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 Write [F:EXF]
 If fstat
  Call FSTA("EXF",WEXF,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEXF.updTick = [F:EXF]updTick
Elsif WEXF.ASTALIN=[V]CST_ALL or WEXF.ASTALIN=[V]CST_AUPD
 Call INIUPD(WEXF) From ASYRSUB
 SetInstance [F:EXF] With WEXF
 For [L]A_J=1 to 20
  For [L]A_I=1 To maxtab(WEXF.EXFN)
   If WEXF.EXFN([L]A_I)<>null & !find(WEXF.EXFN([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WEXF.EXFN([L]A_I).AORDER=[L]A_J
    [F:EXF]COMTYP([L]A_J-1) = WEXF.EXFN([L]A_I).COMTYP
    [F:EXF]COMVAL([L]A_J-1) = WEXF.EXFN([L]A_I).COMVAL
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEXF,"EDIXMLFIL")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:EXF]EXF0 = [F:EXF]MSGCOD;[F:EXF]MSGREL;[F:EXF]MSGFILNOR
 If fstat
  Call FSTA("EXF",WEXF,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEXF.updTick = [F:EXF]updTick
Elsif WEXF.ASTALIN=[V]CST_ADEL
 SetInstance [F:EXF] With WEXF
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEXF,"EDIXMLFIL")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:EXF]EXF0 = [F:EXF]MSGCOD;[F:EXF]MSGREL;[F:EXF]MSGFILNOR
 If fstat
  Call FSTA("EXF",WEXF,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK

############################################################################################
### EDIXMLFILD(WEXFD)
############################################################################################
Funprog  _MAJSQL_EDIXMLFILD(WEXFD)
Variable Instance WEXFD Using C_EDIXMLFILD
Local Integer ASTATUS,A_I,A_J
Default File [F:EXFD]
If WEXFD.ASTALIN=[V]CST_ANEW
