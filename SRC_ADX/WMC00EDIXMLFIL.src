 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEXFD,"EDIXMLFILD")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:EXFD]EXFD0 = [F:EXFD]MSGCOD;[F:EXFD]MSGREL;[F:EXFD]MSGFILNOR;[F:EXFD]NUMLIN
 If fstat
  Call FSTA("EXFD",WEXFD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEXFD.updTick = [F:EXFD]updTick
Elsif WEXFD.ASTALIN=[V]CST_ADEL
 SetInstance [F:EXFD] With WEXFD
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEXFD,"EDIXMLFILD")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:EXFD]EXFD0 = [F:EXFD]MSGCOD;[F:EXFD]MSGREL;[F:EXFD]MSGFILNOR;[F:EXFD]NUMLIN
 If fstat
  Call FSTA("EXFD",WEXFD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK

