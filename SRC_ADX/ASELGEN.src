$ACTION
Case GACTION
 When "GSELECT"   : Gosub ACT
 When "GSELLIS"   : Gosub ACT
 When "GSELTRACE" : Gosub ACT : ## GEODE
Endcase
Return

$ACT
Local Char TRAITEMENT(GLONADC) , COUZON(80)
COUZON     = PARAM(1)
TRAITEMENT = PARAM(2)
Gosub ACTION From =TRAITEMENT
Return

