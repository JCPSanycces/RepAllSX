#<AdxTL>@(#)0.0.0.0 $Revision$Class Budget type
# Supervisor
## ATY-ATYPE ## BUT
# 2018-11-09 07:13:50 190

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,BUDCOD,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char BUDCOD
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File BUDTYP [BUT]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".BUDTYP" [BUT]
Endif

Default File [F:BUT]
Read [F:BUT]BUT0 = [L]BUDCOD
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]BUDCOD)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]BUDCOD)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


