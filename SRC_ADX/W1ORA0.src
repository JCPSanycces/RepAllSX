Subprog D_LEVPAY(VALEUR)
Variable Integer VALEUR
If varinit([M]LEVPAY,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_LEVPAY(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10506) From COMBOS
## Action STD
Call AS_LEVPAY(VALEUR) From SUBORA
If mkstat=2
 [M]LEVPAY(INDIC) = VALEUR
 Affzo LEVPAY(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10506,1))))
Endif
If !mkstat
 Discombo 0 From LEVPAY(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From LEVPAY(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_LEVPAY(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
## Action STD
Call C_LEVPAY(VALEUR) From SUBORA
If mkstat : GERR = 1 : GZONE = "LEVPAY" : GZNUM = 5230 : Endif
Gosub _AFF
End

