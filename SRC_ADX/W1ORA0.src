$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1ORA0
Return

Subprog IB_NBLIG
Local Decimal BASPAG
## Action STD
Call IB_NBLIG From SUBORA
Gosub _AFF
End

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45066,GBOUT1) From OBJDIV
Call IB_NBLIG
## Action STD
Call AS_NBLIG From SUBORA
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1ORA0
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action TRTPCACTR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "TRTPCACTR"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_NBLIG" : PROGSUB = "SUBORA" : PROGSPE = "SPEORA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = [M:ORA0]POP(nolign-1)
 PARMSK(2) = [M:ORA0]COD
 PARMSK(3) = "2"
 PARMSK(4) = GCURLEG
 Call SAISIE_NUM(BASPAG,PARMSK,"TRTPCACTR","TRTPCACTR","XYTRTPCACTR") From GSAISIE
 ACTION = "BB1_NBLIG" : PROGSUB = "SUBORA" : PROGSPE = "SPEORA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_LEV
Onevent BEFORE_INPUT Call AS_LEV(zc) From W1ORA0
Onevent CONTROL Call C_LEV(zc) From W1ORA0
Onevent INIT_AREA Call D_LEV(zc) From W1ORA0
Return

Subprog D_LEV(VALEUR)
Variable Integer VALEUR
If varinit([M]LEV,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_LEV(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10506) From COMBOS
## Action STD
Call AS_LEV(VALEUR) From SUBORA
If mkstat=2
 [M]LEV(INDIC) = VALEUR
 Affzo LEV(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10506,1))))
Endif
If !mkstat
 Discombo 0 From LEV(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From LEV(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_LEV(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
## Action STD
Call C_LEV(VALEUR) From SUBORA
If mkstat : GERR = 1 : GZONE = "LEV" : GZNUM = 5230 : Endif
Gosub _AFF
End

