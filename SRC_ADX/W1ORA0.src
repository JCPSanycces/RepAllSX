#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ORA0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:34"
A_USER  = "DOC"
A_STAMP = "20181109230534"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
 When "NBLIG2"
  If [M]NBLIG2=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ORA0 [ORA0]
Gosub HORODAT
Local Inpbox "ORA0" From GFONCTION At A_STAMP With A_WINDPREV Mask [ORA0] As [SIM_]
Grizo [ORA0]5
Grizo [ORA0]10
Grizo [ORA0]15
Grizo [ORA0]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ORA0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=81 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=81 : Y1(1)=4 : Y2(1)=15
X1(2)=1 : X2(2)=81 : Y1(2)=16 : Y2(2)=17
X1(3)=1 : X2(3)=81 : Y1(3)=18 : Y2(3)=28
Return

$ON_COD
Onevent CONTROL Call C_COD(zc) From W1ORA0
Onevent BEFORE_INPUT Call AS_COD(zc) From W1ORA0
Onevent AFTER_CHANGE Gosub AMM_COD From W1ORA0
Return

Subprog AS_COD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(46228,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_COD(zc) From W1ORA0
Onkey   2 Titled GBOUTS Call S_COD(zc) From W1ORA0
Onkey 144 Titled GBOUTP Call P_COD(zc) From W1ORA0
Onkey 146 Titled GBOUTA Call SA_COD(zc) From W1ORA0
Gosub _AFF
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 35085 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 35085 : Endif
 If !mkstat
  ## Action CONTORG
  Call CONTORG(VALEUR) From SUBORG
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 35085 : Endif
  If !mkstat
   ## Action CONTOBJW
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   SAVACT = GACTION : GACTION = "CONTOBJW"
   PARMSK(1) = "ORG"
   Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 35085 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_COD
Call AM_COD(zc)
If !mkstat & GOBJET
 zoncou = "COD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCOD)")>indice
 [M]COD(indice) = VALEUR
 Affzo ZCOD(indice)
Endif
Gosub _AFF
End

Subprog S_COD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJ1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJ1"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_COD" : PROGSUB = "SUBORA" : PROGSPE = "SPEORA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "ORG"
 PARMSK(2) = "D"
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 ACTION = "BS_COD" : PROGSUB = "SUBORA" : PROGSPE = "SPEORA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_COD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNORG
 Call TUNORG(VALEUR) From SUBORG
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_COD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ORG"
PARMSK(2) = num$(GCURLEG)
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_COD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("ORG",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCOD
Onevent BEFORE_AREA Gosub AV_ZCOD From W1ORA0
Return

$AV_ZCOD
Call LECTEXTRA(zc,"ORGANISME","DES",num$(GCURLEG),num$([M]COD(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1ORA0
