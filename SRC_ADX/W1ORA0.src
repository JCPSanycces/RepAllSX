Subprog C_POP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
If !mkstat
 ## Action CONTPOP
 Call CONTPOP(VALEUR,GCURLEG) From SUBPOP
 If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("POP","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
  If !mkstat
   ## Action STD
   Call C_POP(VALEUR) From SUBORA
   If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

