Onevent BEFORE_INPUT Call AS_REFNUM(zc) From W1ORA0
Onevent AFTER_CHANGE Gosub AMM_REFNUM From W1ORA0
Return

Subprog AS_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44843,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_REFNUM(VALEUR) From SUBORA
If mkstat=2
 [M]REFNUM(INDIC) = VALEUR
 Affzo REFNUM(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_REFNUM(zc) From W1ORA0
Onkey   2 Titled GBOUTS Call S_REFNUM(zc) From W1ORA0
Onkey 144 Titled GBOUTP Call P_REFNUM(zc) From W1ORA0
Onkey 146 Titled GBOUTA Call SA_REFNUM(zc) From W1ORA0
Gosub _AFF
End

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
If !GWEBSERV
 If !mkstat
  ## Action CONTEMP
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTEMP"
  PARMSK(1) = ""
  PARMSK(2) = ""
  PARMSK(3) = ""
  PARMSK(4) = ""
  PARMSK(5) = ""
  PARMSK(6) = GCURLEG
  Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 Endif
Endif
If !mkstat
 ## Action DROITEMP
 Call DROIT(VALEUR,"","","") From DIVPAYE
 If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("EML","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
  If !mkstat
   ## Action STD
   Call C_REFNUM(VALEUR) From SUBORA
   If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
  Endif
 Endif
Endif
