##############################################################################
#GCURFLG
##############################################################################
Subprog GCURFLG(DEV,DAT,RETVAL)
Value Char DEV
Value Date DAT
Variable Libelle RETVAL

Local Integer SOA_GDIMDEV                          : Call GDIMDEV(SOA_GDIMDEV)
Local Integer SOA_GNBDEV
Local Date    SOA_GDEVDAT(1..SOA_GDIMDEV)
Local Char    SOA_GDEVISE(GLONCUR)(1..SOA_GDIMDEV) : Call GDEVISE(SOA_GNBDEV,SOA_GDEVDAT,SOA_GDEVISE)

RETVAL = 1
I = find(DEV, SOA_GDEVISE(1..SOA_GNBDEV))
If !I : RETVAL = 0 : End RETVAL : Endif
If SOA_GDEVDAT(I)<=DAT : RETVAL = 2 : Endif

End
##############################################################################
#GDEVISE
##############################################################################
Subprog GDEVISE(SOA_GNBDEV,SOA_GDEVDAT,RETVAL)
Variable Integer SOA_GNBDEV
Variable Date SOA_GDEVDAT
Variable Char RETVAL

Local Char SOA_GSYSCUR(30) : Call GSYSCUR(SOA_GSYSCUR)
Local Char SOA_GCURSHR(30) : Call GCURSHR(SOA_GCURSHR)

Local File TABCUR  [F:TCU]
Local File COMPANY [F:CPY]

SOA_GNBDEV = 0
If dim(SOA_GSYSCUR)>0
 If dim(SOA_GCURSHR)>0
  If SOA_GCURSHR=AVOID.ACHAR
   SOA_GCURSHR = SOA_GSYSCUR
  Else
   SOA_GSYSCUR = SOA_GCURSHR
  Endif
 Endif
Endif
If dim(SOA_GCURSHR)>0 & SOA_GCURSHR<>AVOID.ACHAR & !find(SOA_GCURSHR,RETVAL(1..SOA_GNBDEV))
 SOA_GNBDEV += 1
 RETVAL(SOA_GNBDEV) = SOA_GCURSHR
 Read [TCU]TCU0 = SOA_GCURSHR
 SOA_GDEVDAT(SOA_GNBDEV)  = [F:TCU]EURDAT
 If [F:TCU]EURFLG<>2 : SOA_GDEVDAT(SOA_GNBDEV) = [31/12/2999] : Endif
Endif
For [CPY]CPY0 Where CPYLEGFLG=2
 If dim([F:CPY]ACCCUR)>0 & !find([F:CPY]ACCCUR,RETVAL(1..SOA_GNBDEV))
  SOA_GNBDEV += 1
  RETVAL(SOA_GNBDEV) = [F:CPY]ACCCUR
  Read [TCU]TCU0 = [F:CPY]ACCCUR
  SOA_GDEVDAT(SOA_GNBDEV)  = [F:TCU]EURDAT
  If [F:TCU]EURFLG<>2 : SOA_GDEVDAT(SOA_GNBDEV) = [31/12/2999] : Endif
 Endif
Next
For [TCU]TCU0
 If !find([F:TCU]CUR,RETVAL(1..SOA_GNBDEV))
  SOA_GNBDEV += 1
  RETVAL(SOA_GNBDEV)  = [F:TCU]CUR
  SOA_GDEVDAT(SOA_GNBDEV)  = [F:TCU]EURDAT
  If [F:TCU]EURFLG<>2 : SOA_GDEVDAT(SOA_GNBDEV) = [31/12/2999] : Endif
 Endif
Next

LogicClose File [TCU]

End
##############################################################################
#GSYSCUR
##############################################################################
Subprog GSYSCUR(RETVAL)
Variable Char RETVAL

RETVAL = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 1, "", "SYSCUR")

End
##############################################################################
#GDIMDEV
##############################################################################
Subprog GDIMDEV(RETVAL)
Variable Integer RETVAL

Local File TABCUR [F:TCU]

If RETVAL<nbrecord([TCU])+10
  RETVAL = max(nbrecord([TCU])+20,100)
Endif

LogicClose File [TCU]

End
##############################################################################
#GCPYFLG
##############################################################################
Subprog GCPYFLG(SOC,DAT,RETVAL)
Value Char SOC
Value Date DAT
Variable Libelle RETVAL

Local Integer NI
Local Integer SOA_GDIMDEV                          : Call GDIMDEV(SOA_GDIMDEV)
Local Integer SOA_GNBDEV
Local Date    SOA_GDEVDAT(1..SOA_GDIMDEV)
Local Char    SOA_GDEVISE(GLONCUR)(1..SOA_GDIMDEV) : Call GDEVISE(SOA_GNBDEV,SOA_GDEVDAT,SOA_GDEVISE)

RETVAL = 1

Local File COMPANY [CPY]
Read [F:CPY]CPY0 = SOC
If !fstat
  NI = find([F:CPY]ACCCUR, SOA_GDEVISE(1..SOA_GNBDEV))
  If !NI
    RETVAL = 0
    End
  Endif

  If SOA_GDEVDAT(NI)<=DAT
    RETVAL = 2
  Endif
Else
  RETVAL = 0
Endif

End
##############################################################################
#GRPTFLG
##############################################################################
Subprog GRPTFLG(DAT,RETVAL)
Value Date DAT
Variable Libelle RETVAL

Local Integer NI
Local Char    SOA_GSYSCUR(30)                      : Call GSYSCUR(SOA_GSYSCUR)
Local Integer SOA_GDIMDEV                          : Call GDIMDEV(SOA_GDIMDEV)
Local Integer SOA_GNBDEV
Local Date    SOA_GDEVDAT(1..SOA_GDIMDEV)
Local Char    SOA_GDEVISE(GLONCUR)(1..SOA_GDIMDEV) : Call GDEVISE(SOA_GNBDEV,SOA_GDEVDAT,SOA_GDEVISE)

RETVAL = 1

NI = find(SOA_GSYSCUR, SOA_GDEVISE(1..SOA_GNBDEV))
If !NI
  RETVAL = 0
  End
Endif

If SOA_GDEVDAT(NI)<=DAT
  RETVAL = 2
Endif

End
