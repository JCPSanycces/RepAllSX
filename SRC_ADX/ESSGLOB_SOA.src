##############################################################################
Subprog GDEVSOC(RETVAL)
Variable Char RETVAL

Local Integer SOA_GNBSOC

Local File COMPANY [F:CPY]

For [CPY]
  SOA_GNBSOC += 1
  If dim([F:CPY]ACCCUR)>0
    RETVAL(SOA_GNBSOC) = [F:CPY]ACCCUR
  Else
    RETVAL(SOA_GNBSOC) = AVOID.ACHAR
  Endif
Next

End
