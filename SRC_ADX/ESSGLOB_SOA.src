##############################################################################
#GNBHOR
##############################################################################
Subprog GNBHOR(RETVAL)
Variable Integer RETVAL

Local Integer  SOA_GTPS :  Call GTPS(SOA_GTPS)

Local File ACTIV[ACV]
Read [ACV]CODACT = "HOR"
If !fstat & [F:ACV]FLACT=2
 RETVAL = max(0,min([F:ACV]DIME ,9))
Else
 RETVAL=0
Endif

If SOA_GTPS=0
 RETVAL = 0
Endif

End
