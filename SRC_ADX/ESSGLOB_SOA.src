##############################################################################
#GTABCPT
##############################################################################
Subprog GTABCPT(RETVAL)
Variable Char RETVAL

Local Char SOA_GMACCPT(50)      : Call GMACCPT(SOA_GMACCPT)
Local Char SOA_GPORTCPT(6)      : Call GPORTCPT(SOA_GPORTCPT)
Local Char SOA_GDOSCPT(GLONADS) : Call GDOSCPT(SOA_GDOSCPT)

If SOA_GMACCPT <> AVOID.ACHAR & SOA_GPORTCPT <> AVOID.ACHAR
  RETVAL = SOA_GMACCPT+":"+SOA_GPORTCPT+"@"+SOA_GDOSCPT
Else
  RETVAL = SOA_GDOSCPT
Endif

If RETVAL <> AVOID.ACHAR
  RETVAL+="."
Endif

End
##############################################################################
#GPORTCPT
##############################################################################
Subprog GPORTCPT(RETVAL)
Variable Char RETVAL

Local File ADOSSIER [ADSW]
Local File ADOSSOL  [ADDW]
Read [ADSW]DOSSIER = nomap
If fstat
  End RETVAL
Endif

For [ADDW] Where DOSSIER=[F:ADSW]DOSSIER
  If [F:ADDW]LTYPLIEN = 2
    RETVAL = num$([F:ADDW]LSERV)
    Break 1
  Endif
Next

LogicClose File [ADSW]
LogicClose File [ADDW]

End
##############################################################################
#GMACCPT
##############################################################################
Subprog GMACCPT(RETVAL)
Variable Char RETVAL

Local File ADOSSIER [ADSW]
Local File ADOSSOL  [ADDW]
Read [ADSW]DOSSIER = nomap
If fstat
  End RETVAL
Endif

For [ADDW] Where DOSSIER=[F:ADSW]DOSSIER
  If [F:ADDW]LTYPLIEN = 2
    RETVAL = [F:ADDW]LMAC
    Break 1
  Endif
Next

LogicClose File [ADSW]
LogicClose File [ADDW]

End
##############################################################################
#GCOMPTA
##############################################################################
Subprog GCOMPTA(RETVAL)
Variable Integer RETVAL

Local Char SOA_GDOSCPT(GLONADS) : Call GDOSCPT(SOA_GDOSCPT)

If SOA_GDOSCPT=AVOID.ACHAR
  RETVAL = 3
Else
  RETVAL = 2
Endif

End
##############################################################################
#GDOSCPT
##############################################################################
Subprog GDOSCPT(RETVAL)
Variable Char RETVAL

Local File ADOSSIER [ADSW]
Local File ADOSSOL  [ADDW]
Read [ADSW]DOSSIER = nomap
If fstat
  End RETVAL
Endif

For [ADDW] Where DOSSIER=[F:ADSW]DOSSIER
  If [F:ADDW]LTYPLIEN = 2
    RETVAL = [F:ADDW]LDOSTARG
    Break 1
  Endif
Next

LogicClose File [ADSW]
LogicClose File [ADDW]

End
##############################################################################
#GSOCIETE
##############################################################################
Subprog GSOCIETE(ETRFCY,RETVAL)
Value Char ETRFCY
Variable Char RETVAL

RETVAL = func DIVPAYE_SOA.GETSOC(ETRFCY)

End
##############################################################################
#GOPTCANA
##############################################################################
Subprog GOPTCANA(RETVAL)
Variable Integer RETVAL

Local Integer RESULT
Local Instance ACTIV Using C_ACTIV
ACTIV=NewInstance C_ACTIV AllocGroup null

RESULT = fmet ACTIV.AREAD("ANA")
If RESULT = [V]CST_AOK
  RETVAL = max(0, ACTIV.DIME)
Endif

FreeInstance ACTIV

End
