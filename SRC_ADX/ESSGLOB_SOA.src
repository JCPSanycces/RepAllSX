##############################################################################
#GHIDATE
##############################################################################
Subprog GHIDATE(RETVAL)
Variable Date RETVAL

RETVAL = gdat$(31,12,adxdcs+99)

End
##############################################################################
#GEURODEV
##############################################################################
Subprog GEURODEV(RETVAL)
Variable Decimal RETVAL

Local Char SOA_GEURO(30) : Call GEURO(SOA_GEURO)

Local File TABCUR [F:TCU]

If SOA_GEURO = AVOID.ACHAR
 SOA_GEURO = "EUR"
Endif
Read [TCU]TCU0 = SOA_GEURO
If !fstat
  RETVAL = [F:TCU]CURRND
Else
  RETVAL = 0
Endif

LogicClose File [TCU]

End
##############################################################################
#GLOCALDEV
##############################################################################
Subprog GLOCALDEV(RETVAL)
Variable Char RETVAL

Local Char SOA_GPAYS(30) : Call GPAYS(SOA_GPAYS)

RETVAL = 'FRF'

If filinfo(filpath("FIL","TABCOUNTRY","fde",0),0)>0
  Local File TABCOUNTRY [TCY]
  Read [TCY]TCY0 = SOA_GPAYS
  If fstat
    Read [TCY]TCY0 = AVOID.ACHAR
  Endif
  If fstat=0
    RETVAL = [F:TCY]CUR
  Endif
Endif

End
