##############################################################################
#GMODU
##############################################################################
Subprog GMODU(RETVAL)
Variable Libelle RETVAL(1..20)

Local Char PARAM(250)
Local Integer NI

PARAM = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 1, "", "MODULE1")
If PARAM = AVOID.ACHAR
  PARAM = "2222222222"
Endif
For NI=1 To 10
 RETVAL(NI) = val(mid$(PARAM,NI,1))
Next

PARAM = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 1, "", "MODULE2")
If PARAM =AVOID.ACHAR
  PARAM = "2222222222"
Endif
For NI=1 To 10
 RETVAL(NI+10) = val(mid$(PARAM,NI,1))
Next

End
##############################################################################
#GPAYE
##############################################################################
Subprog GPAYE(RETVAL)
Variable Integer RETVAL

Local File ACTIV [ACV]
Read [ACV]CODACT="HRPAY"
If !fstat & [F:ACV]FLACT=2
  RETVAL = 1
Endif

#LogicClose File [ACV]
End
