#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################
#GUSRAUZ
##############################################################################
Subprog GUSRAUZ(SOA_GFONCTION, RETVAL)
Value Char SOA_GFONCTION
Variable Char RETVAL

Local Integer I, ISITE, ISOC
Local File AFONCTION [AFC]
Local File AFCTFCY   [AFF]
Local File AFCTPRF   [AFP]
Local File AFCTFCT   [AFT]

Local Char SOA_GPROFIL(5) : Call GPROFIL(SOA_GPROFIL)
Local Integer SOA_GNBAUZ
Local Integer SOA_GNBSITE                        : Call GNBSITE(SOA_GNBSITE)
Local Integer SOA_GDIMSIT                        : Call GDIMSIT(SOA_GDIMSIT)
Local Char    SOA_GSITE(GLONFCY)(1..SOA_GDIMSIT) : Call GSITE(SOA_GSITE)

#Call  LECTURE("AFC",SOA_GFONCTION,"") From CONTOBJ

Read [F:AFC]CODINT = SOA_GFONCTION
If fstat
 Raz [F:AFC]
Else
 I = find("GFONCTION",[F:AFC]VARIA(0..[F:AFC]NBVAR-1))
 If I
  SOA_GFONCTION = [F:AFC]VALEUR(I-1)
  If find(left$(SOA_GFONCTION,1),"'",'"') : SOA_GFONCTION = right$(SOA_GFONCTION,2) : Endif
  I = len(SOA_GFONCTION)
  If find(right$(SOA_GFONCTION,I),"'",'"') : SOA_GFONCTION = left$(SOA_GFONCTION,I-1) : Endif
 Endif
Endif

Read [AFT]AFT0 = SOA_GPROFIL
If [F:AFT]ALLFCT=2
 If [F:AFC]FCYAUZ<>2 or SOA_GFONCTION="GESFCY"
  If [F:AFC]TYP=2 or ([F:AFC]TYP=0 & left$(SOA_GFONCTION,3)="GES")
   RETVAL(1) = "CMNS"
  Endif
  RETVAL(1) += sum([F:AFC]FLAG)
  SOA_GNBAUZ      = 1
 Else
  For I=1 To SOA_GNBSITE
   If [F:AFC]TYP=2 : # Objet
    RETVAL(I) = "CMNS"
   Endif
   RETVAL(I) += sum([F:AFC]FLAG)
  Next I
  SOA_GNBAUZ = SOA_GNBSITE
 Endif
Else
 If [F:AFC]FCYAUZ<>2
  Read [AFP]AFP0 = SOA_GPROFIL ; SOA_GFONCTION ; ""
  If !fstat & [F:AFP]ACS=2
   RETVAL(1) = [F:AFP]OPT
   SOA_GNBAUZ     = 1
  Endif
 Else
  For [AFF]AFF1 Where PRFCOD=SOA_GPROFIL & FNC=SOA_GFONCTION & FCY<>""
   ISITE = find([F:AFF]FCY,SOA_GSITE(1..SOA_GNBSITE))
   If ISITE
    SOA_GNBAUZ += 1
    RETVAL(SOA_GNBAUZ) = [F:AFF]OPT
   Endif
  Next
  #117035 cas ADMCA sur GESFCY
  If SOA_GNBAUZ=0 & SOA_GFONCTION="GESFCY"
   Read [AFP]AFP0 = SOA_GPROFIL ; SOA_GFONCTION ; ""
   If !fstat & [F:AFP]ACS=2
    RETVAL(1) = [F:AFP]OPT
    SOA_GNBAUZ     = 1
   Endif
  Endif
 Endif
Endif

#GPOINT = "AUTORIS" : Gosub ENTREE From EXEFNC2

#87108
If dim(GACTX)>0
 If fmet GACTX.AGETLIC_EXPIRED(func ASYRLIC.GET_CHPRODUCTSTDCODE)=[V]CST_ATRUE | fmet GACTX.AGETLICFCT(SOA_GFONCTION)<>[V]CST_ATRUE
  Raz RETVAL(1)
  End
 Endif
Endif

# Infos pour psadx
Call SET_CURFCT(SOA_GFONCTION,[F:AFC]MODULE,"") From PSADX

End
##############################################################################
#GHISTO
##############################################################################
Subprog GHISTO(RETVAL)
Variable Integer RETVAL

RETVAL = (filinfo(filpath("","histo","",0),0)>=0)

End
##############################################################################
#GLANGUE
##############################################################################
Subprog GLANGUE(RETVAL)
Variable Char RETVAL

RETVAL = GACTX.LAN

End
##############################################################################
#GUSRACS
##############################################################################
Subprog GUSRACS(RETVAL)
Variable Integer RETVAL

Local Integer ASTATUS
Local Char SOA_GUSER(5) : Call GUSER(SOA_GUSER)

RETVAL = [V]CST_ANO : #Default value to no

Local Instance AUS Using C_AUTILIS
AUS = NewInstance C_AUTILIS AllocGroup null
ASTATUS = fmet AUS.AREAD(SOA_GUSER)

If ASTATUS = [V]CST_AOK
  RETVAL = AUS.ALLACS
Endif

FreeInstance AUS

End
##############################################################################
#GNBSERV
##############################################################################
Subprog GNBSERV(RETVAL)
Variable Integer RETVAL

Local Integer OK
Local Char SOA_GUSER(5) : Call GUSER(SOA_GUSER)

RETVAL = 0

Local File SERVICE [SRV]
Local File ACCES   [ACC]

For [SRV]SRV0
  OK = 1
  If [F:SRV]CODACC<>AVOID.ACHAR
    Read [ACC]CODACC = SOA_GUSER;[F:SRV]CODACC
    If fstat or [F:ACC]EXEC<>2
      OK = 0
    Endif
  Endif
  If OK
    RETVAL += 1
  Endif
Next

RETVAL += 1

LogicClose File [SRV]
LogicClose File [ACC]

End
##############################################################################
#GAUTSRV
##############################################################################
Subprog GAUTSRV(RETVAL)
Variable Char RETVAL

Local Integer OK, SOA_GNBSERV
Local Char SOA_GUSER(5) : Call GUSER(SOA_GUSER)
SOA_GNBSERV = 0

Local File SERVICE [SRV]
Local File ACCES   [ACC]

For [SRV]SRV0
  OK = 1
  If [F:SRV]CODACC<>AVOID.ACHAR
    Read [ACC]CODACC = SOA_GUSER;[F:SRV]CODACC
    If fstat or [F:ACC]EXEC<>2
      OK = 0
    Endif
  Endif
  If OK
    SOA_GNBSERV += 1
    RETVAL(SOA_GNBSERV) = [F:SRV]COD
  Endif
Next

SOA_GNBSERV += 1
RETVAL(SOA_GNBSERV) = AVOID.ACHAR

LogicClose File [SRV]
LogicClose File [ACC]

End
##############################################################################
#GNBAUZ
##############################################################################
Subprog GNBAUZ(SOA_GFONCTION, RETVAL)
Value Char SOA_GFONCTION
Variable Integer RETVAL

Local Char    SOA_GPROFIL(5)                     : Call GPROFIL(SOA_GPROFIL)
Local Integer SOA_GNBSITE                        : Call GNBSITE(SOA_GNBSITE)
Local Integer SOA_GDIMSIT                        : Call GDIMSIT(SOA_GDIMSIT)
Local Char    SOA_GSITE(GLONFCY)(1..SOA_GDIMSIT) : Call GSITE(SOA_GSITE)

Local Integer I, ISITE, ISOC
Local File AFONCTION [AFC]
Local File AFCTFCY   [AFF]
Local File AFCTPRF   [AFP]
Local File AFCTFCT   [AFT]
#Call LECTURE("AFC",SOA_GFONCTION,"") From CONTOBJ

Read [F:AFC]CODINT = SOA_GFONCTION
If fstat
 Raz [F:AFC]
Else
 # gh 02/12/98 pour gérer les fonctions TRTGAS, TRTGASA, GESGAUT
 I = find("GFONCTION",[F:AFC]VARIA(0..[F:AFC]NBVAR-1))
 If I
  SOA_GFONCTION = [F:AFC]VALEUR(I-1)
  If find(left$(SOA_GFONCTION,1),"'",'"') : SOA_GFONCTION = right$(SOA_GFONCTION,2) : Endif
  I = len(SOA_GFONCTION)
  If find(right$(SOA_GFONCTION,I),"'",'"') : SOA_GFONCTION = left$(SOA_GFONCTION,I-1) : Endif
  # Ne pas faire Call LECTURE("AFC",SOA_GFONCTION,"") From CONTOBJ pour les GBID...
 Endif
Endif

#Raz GUSRAUZ, GUSRFCY, GNBAUZ

Read [AFT]AFT0 = SOA_GPROFIL
If [F:AFT]ALLFCT=2   : # Toutes fonctions autorisées pour le profil
 If [F:AFC]FCYAUZ<>2 or SOA_GFONCTION="GESFCY" : # Fonctions sans sites
  RETVAL      = 1
 Else
  RETVAL = SOA_GNBSITE
 Endif
Else
 If [F:AFC]FCYAUZ<>2 : # Fonctions sans sites
  Read [AFP]AFP0 = SOA_GPROFIL ; SOA_GFONCTION ; ""
  If !fstat & [F:AFP]ACS=2
   RETVAL     = 1
  Endif
 Else
  For [AFF]AFF1 Where PRFCOD=SOA_GPROFIL & FNC=SOA_GFONCTION & FCY<>""
   ISITE = find([F:AFF]FCY,SOA_GSITE(1..SOA_GNBSITE))
   If ISITE
    RETVAL += 1
   Endif
  Next
  #117035 cas ADMCA sur GESFCY
  If RETVAL=0 & SOA_GFONCTION="GESFCY"
   Read [AFP]AFP0 = SOA_GPROFIL ; SOA_GFONCTION ; ""
   If !fstat & [F:AFP]ACS=2
    RETVAL     = 1
   Endif
  Endif
 Endif
Endif

#############################################################################

End
##############################################################################
#GPROFIL
##############################################################################
Subprog GPROFIL(RETVAL)
Variable Char RETVAL

Local Char SOA_GUSER(5) : Call GUSER(SOA_GUSER)
Local File AUTILIS [AUS]

Read [AUS]CODUSR = SOA_GUSER
If [F:AUS]PRFFCT=AVOID.ACHAR
  Local File AMETUTI [AME]
  Read [AME]AME0 = [F:AUS]CODMET
  RETVAL = [F:AME]PRFFCT
Else
  RETVAL = [F:AUS]PRFFCT
Endif

#LogicClose File [AUS]
#LogicClose File [AME]

End
##############################################################################
#GUSER
##############################################################################
Subprog GUSER(RETVAL)
Variable Char RETVAL

RETVAL = func AXDTMAIN.FIXUSER

End
##############################################################################
#GUSRFCY
##############################################################################
Subprog GUSRFCY(SOA_GFONCTION, RETVAL)
Value Char SOA_GFONCTION
Variable Char RETVAL

Local Char    SOA_GPROFIL(5)                     : Call GPROFIL(SOA_GPROFIL)
Local Integer SOA_GNBSITE                        : Call GNBSITE(SOA_GNBSITE)
Local Integer SOA_GDIMSIT                        : Call GDIMSIT(SOA_GDIMSIT)
Local Char    SOA_GSITE(GLONFCY)(1..SOA_GDIMSIT) : Call GSITE(SOA_GSITE)

Local Integer I, ISITE, ISOC, SOA_GNBAUZ
Local File AFONCTION [AFC]
Local File AFCTFCY   [AFF]
Local File AFCTPRF   [AFP]
Local File AFCTFCT   [AFT]
#Call LECTURE("AFC",SOA_GFONCTION,"") From CONTOBJ

Read [F:AFC]CODINT = SOA_GFONCTION
If fstat
 Raz [F:AFC]
Else
 # gh 02/12/98 pour gérer les fonctions TRTGAS, TRTGASA, GESGAUT
 I = find("GFONCTION",[F:AFC]VARIA(0..[F:AFC]NBVAR-1))
 If I
  SOA_GFONCTION = [F:AFC]VALEUR(I-1)
  If find(left$(SOA_GFONCTION,1),"'",'"') : SOA_GFONCTION = right$(SOA_GFONCTION,2) : Endif
  I = len(SOA_GFONCTION)
  If find(right$(SOA_GFONCTION,I),"'",'"') : SOA_GFONCTION = left$(SOA_GFONCTION,I-1) : Endif
  # Ne pas faire Call LECTURE("AFC",SOA_GFONCTION,"") From CONTOBJ pour les GBID...
 Endif
Endif

Read [AFT]AFT0 = SOA_GPROFIL
If [F:AFT]ALLFCT=2   : # Toutes fonctions autorisées pour le profil
 If [F:AFC]FCYAUZ<>2 or SOA_GFONCTION="GESFCY" : # Fonctions sans sites
  RETVAL(1)  = "\"
  SOA_GNBAUZ      = 1
 Else
  For I=1 To SOA_GNBSITE
   RETVAL(I)  = SOA_GSITE(I)
  Next I
  SOA_GNBAUZ = SOA_GNBSITE
 Endif
Else
 If [F:AFC]FCYAUZ<>2 : # Fonctions sans sites
  Read [AFP]AFP0 = SOA_GPROFIL ; SOA_GFONCTION ; ""
  If !fstat & [F:AFP]ACS=2
   RETVAL(1) = "\"
   SOA_GNBAUZ     = 1
  Endif
 Else
  For [AFF]AFF1 Where PRFCOD=SOA_GPROFIL & FNC=SOA_GFONCTION & FCY<>""
   ISITE = find([F:AFF]FCY,SOA_GSITE(1..SOA_GNBSITE))
   If ISITE
    SOA_GNBAUZ += 1
    RETVAL(SOA_GNBAUZ) = [F:AFF]FCY
   Endif
  Next
  #117035 cas ADMCA sur GESFCY
  If SOA_GNBAUZ=0 & SOA_GFONCTION="GESFCY"
   Read [AFP]AFP0 = SOA_GPROFIL ; SOA_GFONCTION ; ""
   If !fstat & [F:AFP]ACS=2
    RETVAL(1) = "\"
   Endif
  Endif
 Endif
Endif
End
##############################################################################
#GDIMSIT
##############################################################################
Subprog GDIMSIT(RETVAL)
Variable Integer RETVAL

Local File FACILITY [F:FCY]

RETVAL = max(nbrecord([FCY])+20,100)

End
##############################################################################
#GMOIPAY
##############################################################################
Subprog GMOIPAY(ETRFCY,RETVAL)
Value Char ETRFCY
Variable Date RETVAL

RETVAL=gdat$(func DIVPAYE_SOA.INIPARUSR("MOIPAY","",ETRFCY))

If RETVAL = AVOID.ADATE
  RETVAL = gdat$(01,month(date$),year(date$))
Endif

End
