#<AdxTL>@(#)9.0.0.0 $Revision$
################################################################################
## Etat MOBILITE
#################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char    CPYDEB(GLONCPY), CPYFIN(GLONCPY), FCYDEB(GLONFCY), FCYFIN(GLONFCY)
Local Char    MATDEB(GLONEML), MATFIN(GLONEML), POPULATION(GLONPOP), EMPLOI(GLONJOT)
Local Char    PARAM(20) , PRFDEB(GLONPRF), PRFFIN(GLONPRF), SRVDEB(GLONSRV), SRVFIN(GLONSRV)
Local Integer NUMREQ, WNUMLIG, VACANCE, I, J
Local Char    CRIT0(250), CRIT1(250), CRIT2(250)
Local Date    DATANC
# SYMEU - EXI 66105 LOT 8 - V6.1 : ajout de paramètres - début
Local Char    CTRDEB(GLONHRCTR), CTRFIN(GLONHRCTR), EVATYPDEB, EVATYPFIN, POSTE(GLONPOT)
Local Date    DATDEB, DATFIN, DATMETDEB, DATMETFIN
Local Integer EVAANN
Local Char    CRIT3(250)
# SYMEU - EXI 66105 LOT 8 - V6.1 : ajout de paramètres - fin

If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif
If clalev([F:ECT])=0    : Local File EMPCTR     [ECT]   : Endif
If clalev([F:EVE])=0    : Local File EVAEMP     [EVE]   : Endif
If clalev([F:HRPOA])=0  : Local File POPULA     [HRPOA] : Endif
If clalev([F:FGR])=0    : Local File FACGROUP   [FGR]   : Endif
If clalev([F:EPO])=0    : Local File EMPLOPOT   [EPO]   : Endif
If clalev([F:CPE])=0    : Local File CPCEMP     [CPE]   : Endif
If clalev([F:HRSCA])=0  : Local File SCALE      [HRSCA] : Endif
If clalev([F:CPC])=0    : Local File COMPETENCE [CPC]   : Endif
If clalev([F:POT])=0    : Local File POSTE      [POT]   : Endif
If clalev([F:TMO])=0    : Local File TMPMOB     [TMO]   : Endif
# SYMEU - EXI 66105 LOT 8 - V6.1 : ajout de paramètres
If clalev([F:JOT])=0    : Local File JOBTYP     [JOT]   : Endif

Call GETPARAM("cpydeb",NBPAR,PARAMETRE,CPYDEB) From ETAT
Call GETPARAM("cpyfin",NBPAR,PARAMETRE,CPYFIN) From ETAT
Call GETPARAM("fcydeb",NBPAR,PARAMETRE,FCYDEB) From ETAT
Call GETPARAM("fcyfin",NBPAR,PARAMETRE,FCYFIN) From ETAT
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB) From ETAT
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN) From ETAT
Call GETPARAM("prfdeb",NBPAR,PARAMETRE,PRFDEB) From ETAT
Call GETPARAM("prffin",NBPAR,PARAMETRE,PRFFIN) From ETAT
Call GETPARAM("srvdeb",NBPAR,PARAMETRE,SRVDEB) From ETAT
Call GETPARAM("srvfin",NBPAR,PARAMETRE,SRVFIN) From ETAT
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION) From ETAT
Call GETPARAM("emploi",NBPAR,PARAMETRE,EMPLOI) From ETAT
# SYMEU - EXI 66105 LOT 8 - V6.1 : ajout de paramètres - début
Call GETPARAM("ctrdeb",NBPAR,PARAMETRE,CTRDEB) From ETAT                      # Contrat début
Call GETPARAM("ctrfin",NBPAR,PARAMETRE,CTRFIN) From ETAT                      # Contrat fin
Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM) From ETAT : DATDEB=PARAM        # Date entretien début
Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM) From ETAT : DATFIN=PARAM        # Date entretien fin
Call GETPARAM("datmetdeb",NBPAR,PARAMETRE,PARAM) From ETAT : DATMETDEB=PARAM  # Date métier début
Call GETPARAM("datmetfin",NBPAR,PARAMETRE,PARAM) From ETAT : DATMETFIN=PARAM  # Date métier fin
Call GETPARAM("evatypdeb",NBPAR,PARAMETRE,EVATYPDEB) From ETAT                # Type évaluation début
Call GETPARAM("evatypfin",NBPAR,PARAMETRE,EVATYPFIN) From ETAT                # Type évaluation fin
Call GETPARAM("flgeva",NBPAR,PARAMETRE,PARAM) From ETAT : EVAANU=val(PARAM)   # Entretien annuel
Call GETPARAM("pot",NBPAR,PARAMETRE,POSTE) From ETAT                          # Poste
# SYMEU - EXI 66105 LOT 8 - V6.1 : ajout de paramètres - fin
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT
[L]NUMREQ = val(PARAM)
PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

CRIT0 = "[F:ID]ENAFLG=2"
CRIT1 = "1=1"
If CPYDEB<>"" : CRIT0 -= "& [F:FGR]CPY>='"+CPYDEB+"'"     : Endif
If CPYFIN<>"" : CRIT0 -= "& [F:FGR]CPY<='"+CPYFIN+"'"     : Endif
If MATDEB<>"" : CRIT0 -= '& [F:ID]REFNUM>="'+MATDEB+'"'   : Endif
If MATFIN<>"" : CRIT0 -= '& [F:ID]REFNUM<="'+MATFIN+'"'   : Endif
If FCYDEB<>"" : CRIT1 -= '& [F:ECT]FCY>="'+FCYDEB+'"'     : Endif
If FCYFIN<>"" : CRIT1 -= '& [F:ECT]FCY<="'+FCYFIN+'"'     : Endif
# SYMEU - EXI 66105 LOT 8 - V6.1 : profil pas obligatoire (PRFDEB contient ' ')
#If PRFDEB<>"" : CRIT1 -= '& [F:ECT]PRF>="'+PRFDEB+'"'    : Endif
If PRFDEB<>" " : CRIT1 -= '& [F:ECT]PRF>="'+PRFDEB+'"'    : Endif
If PRFFIN<>"" : CRIT1 -= '& [F:ECT]PRF<="'+PRFFIN+'"'     : Endif
# SYMEU - EXI 66105 LOT 8 - V6.1 : service pas obligatoire (SRVDEB contient ' ')
#If SRVDEB<>"" : CRIT1 -= '& [F:ECT]SRV>="'+SRVDEB+'"'    : Endif
If SRVDEB<>" " : CRIT1 -= '& [F:ECT]SRV>="'+SRVDEB+'"'    : Endif
If SRVFIN<>"" : CRIT1 -= '& [F:ECT]SRV<="'+SRVFIN+'"'     : Endif
# SYMEU - EXI 66105 LOT 8 - V6.1 : ajout de paramètres - début
If CTRDEB<>"" : CRIT1 -= '& [F:ECT]CTRNUM>="'+CTRDEB+'"'  : Endif
If CTRFIN<>"" : CRIT1 -= '& [F:ECT]CTRNUM<="'+CTRFIN+'"'  : Endif
# SYMEU - EXI 66105 LOT 8 - V6.1 : ajout de paramètres - fin

If [L]POPULATION<>""
 Link [ECT] With
&   [ID]ID0=[F:ECT]REFNUM
& , [FGR]FGR1(1)=[F:ECT]FCY
& , [HRPOA]POA0=[L]POPULATION;[F:ID]REFNUM
& As [LID]
& Where evalue(CRIT0) & evalue(CRIT1) & [F:HRPOA]REFNUM<>""
Else
 Link [ECT] With
&   [ID]ID0=[F:ECT]REFNUM
& , [FGR]FGR1(1)=[F:ECT]FCY
& As [LID]
& Where evalue(CRIT0) & evalue(CRIT1)
Endif

# SYMEU - EXI 66105 LOT 8 - V6.1 : critères supplémentaires sur EVAEMP - début
CRIT3 = "1=1"
# Entretien annuel (Non, Oui, Tous)
If EVAANU=2 : CRIT3 -= "& [F:EVE]FLGYEA=2" : Endif
If EVAANU=1 : CRIT3 -= "& [F:EVE]FLGYEA=1" : Endif
# Type évaluation
If EVATYPDEB<>" " : CRIT3 -= "& [F:EVE]EVATYP>='"+EVATYPDEB+"'" : Endif
If EVATYPFIN<>" " : CRIT3 -= "& [F:EVE]EVATYP<='"+EVATYPFIN+"'" : Endif
# Date d'entretien
CRIT3 -= "& [F:EVE]EVADAT>=["+format$(GFMD,DATDEB)+"]"
CRIT3 -= "& [F:EVE]EVADAT<=["+format$(GFMD,DATFIN)+"]"
# Date métier : particulier car la date métier n'est pas obligatoire
If DATMETDEB > gdat$(01,01,1800) Then
  CRIT3 -= "& [F:EVE]EVAJOBGRPDAT>=["+format$(GFMD,DATMETDEB)+"]"
Endif
CRIT3 -= "& [F:EVE]EVAJOBGRPDAT<=["+format$(GFMD,DATMETFIN)+"]"
# SYMEU - EXI 66105 LOT 8 - V6.1 : critères supplémentaires sur EVAEMP - fin

# SYMEU - EXI 66105 LOT 8 - V6.1 : critères supplémentaires sur EVAEMP - début
#CRIT2 = '[F:EVE]EVAJOB<>""'
#If EMPLOI<>""  : CRIT2 -= '& [F:EVE]EVAJOB="'+EMPLOI+'"'  : Endif
# On prend les évaluations dont seul le métier est renseigné
CRIT2 ='([F:EVE]EVAJOBGRP<>"" & [F:EVE]EVAPOT="" & [F:EVE]EVAJOB="")'
# Rappel : on peut saisir soit l'emploi type, soit le poste
If EMPLOI<>"" Then
  # + les évaluations dont l'emploi type correspond à celui saisi
  CRIT2-='| [F:EVE]EVAJOB="'+EMPLOI+'"'
  # + les évaluations dont seul le poste est renseigné et dont l'emploi type du poste est égal
  # à celui saisi
  CRIT2-='| ([F:EVE]EVAPOT<>"" & [F:EVE]EVAJOB="")'
Elsif POSTE<>"" Then
  # + les évaluations dont l'emploi type est renseigné
  CRIT2-='| [F:EVE]EVAJOB<>""'
  # + les évaluations dont le poste correspond à celui saisi
  CRIT2-='| ([F:EVE]EVAJOB="" & [F:EVE]EVAPOT="'+POSTE+'")'
Else
  # + les évaluations dont l'emploi type est renseigné
  CRIT2-='| [F:EVE]EVAJOB<>""'
  # + les évaluations dont seul le poste est renseigné
  CRIT2-='| ([F:EVE]EVAPOT<>"" & [F:EVE]EVAJOB="")'
Endif
# SYMEU - EXI 66105 LOT 8 - V6.1 : critères supplémentaires sur EVAEMP - fin

Call DEBTRANS From GLOCK
Gosub TR1
Raz WNUMLIG
Gosub TR2
End

$TR1
GOK = 1
Trbegin [TMO]
 Delete [TMO] Where USR=GUSER & CREDAT<date$
 If fstat=1
  GOK = -1 : GLOCK = "TMPMOB"-GUSER : Goto ROLL_TR1
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TR2
GOK=1
Trbegin [TMO]
# SYMEU - EXI 66105 LOT 8 - V6.1 : procédure différente
# For [LID]ECT0(2)
#  # Recherche du dernier entretien d'évaluation du salarié
#  Filter [EVE] Where REFNUM=[F:ECT]REFNUM & CTRNUM=[F:ECT]CTRNUM
#  Read [EVE]EVE0 Last
#  Filter [EVE]
#  If !fstat & evalue(CRIT2)=1
#   # Recherche des postes liés à l'emploi type
#   Filter [POT] Where JOBPOT=[F:EVE]EVAJOB & (DATENDVLY=[0/0/0] | DATENDVLY>date$)
#   For [POT]POT1
#    # Recherche du dernier titulaire du poste
#    VACANCE = 1 : Raz DATANC
#    Filter [EPO] Where POT=[F:POT]COD
#    Read [EPO]EPO2 Last
#    Filter [EPO]
#    If !fstat
#     DATANC=[F:EPO]DATPOT
#     Filter [HRCTR] Where REFNUM=[F:EPO]REFNUM & CTRNUM=[F:EPO]CTRNUM
#     Read [HRCTR]CTR0 Last
#     Filter [HRCTR]
#     If !fstat & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>date$)
#      # Le salarié est toujours là mais occupe-t-il un autre poste
#      Filter [EPO] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & DATPOT>DATANC & DATPOT<date$
#      Read [EPO]EPO2 First
#      Filter [EPO]
#      If fstat
#       VACANCE = 0
#      Endif
#     Endif
#    Endif
#    # Recherche des compétences requises pour le poste
#    For I=0 To dim([F:POT]CPC)-1
#     If [F:POT]CPC(I)="" : Break : Endif
#     Call LECTURE("CPC",[F:POT]CPC(I),"") From CONTOBJ
#     Call LECTURE("SCA",[F:CPC]CODSCA,"") From CONTOBJ
#     Raz [F:TMO]
#     [L]WNUMLIG   +=1
#     [F:TMO]NUMREQ = [L]NUMREQ
#     [F:TMO]USR    = GUSER
#     [F:TMO]NUMLIG = [L]WNUMLIG
#     [F:TMO]CREDAT = date$
#     [F:TMO]REFNUM = [F:EVE]REFNUM
#     [F:TMO]CTRNUM = [F:EVE]CTRNUM
#     [F:TMO]JOBPOT = [F:EVE]EVAJOB
#     [F:TMO]EVADAT = [F:EVE]EVADAT
#     [F:TMO]POT    = [F:POT]COD
#     If VACANCE=0
#      [F:TMO]EMPPOT = [F:EPO]REFNUM
#      [F:TMO]DATANC = [L]DATANC
#     Endif
#     [F:TMO]CPC    = [F:POT]CPC(I)
#     [F:TMO]CPCLEV = [F:POT]NIV(I)
#     J = find([F:POT]NIV(I),[F:SCA]LEV)
#     If J
#      [F:TMO]CPCSCA = [F:SCA]LEVREF(J-1)*[F:POT]WEI(I)
#     Endif
#     # Recherche du niveau de compétence le plus récent du salarié
#     Filter [CPE] Where REFNUM=[F:ID]REFNUM & CPC=[F:POT]CPC(I)
#     Read [CPE]CPE1 Last
#     Filter [CPE]
#     If !fstat
#      [F:TMO]CPCDAT = [F:CPE]CPCDAT
#      [F:TMO]MATLEV = [F:CPE]LEVCPC
#      J = find([F:CPE]LEVCPC,[F:SCA]LEV)
#      If J
#       [F:TMO]MATSCA = [F:SCA]LEVREF(J-1)*[F:POT]WEI(I)
#      Endif
#     Endif
#     Write [F:TMO]
#     If fstat : GOK = 0 : Call FSTA("TMO") From GLOCK : Break 3 : Endif
#    Next
#   Next
#   Filter [POT]
#  Endif
# Next

# SYMEU - EXI 66105 LOT 8 - V6.1 : Nouvelle procédure
Local Char L_EMPLOI(GLONJOT), L_POSTE(GLONPOT)
Local Integer L_TRAITE
For [LID]ECT0(2)
  # Recherche du dernier entretien d'évaluation du salarié
  Filter [EVE] Where REFNUM=[F:ECT]REFNUM & CTRNUM=[F:ECT]CTRNUM
  Read [EVE]EVE0 Last
  Filter [EVE]
  If !fstat & evalue(CRIT2)=1 & evalue(CRIT3)=1
    L_TRAITE = 2
    # Dans le cas où l'emploi type des critères est saisi et où seul le poste de l'évaluation
    # est renseigné, il faut vérifier que l'emploi type du poste est égal à celui des critères
    If EMPLOI <> "" and [F:EVE]EVAPOT<>"" and [F:EVE]EVAJOB="" Then
      Read [F:POT]POT0=[F:EVE]EVAPOT
      If fstat or [F:POT]JOBPOT <> EMPLOI Then
        L_TRAITE = 1
      Endif
    Endif
    # Dans le cas où le poste des critères est saisi et où l'emploi type est renseigné, il
    # faut vérifier que l'emploi type de l'évaluation est égal à l'emploi type du poste des
    # critères
    If POSTE <> "" and [F:EVE]EVAJOB<>"" Then
      Read [F:POT]POT0=POSTE
      If fstat or [F:POT]JOBPOT <> [F:EVE]EVAJOB Then
        L_TRAITE = 1
      Endif
    Endif
    If L_TRAITE = 2 Then
      Raz L_EMPLOI, L_POSTE
      # On va renseigner les deux variables qui vont permettre de savoir ce qu'il faut éditer
      If [F:EVE]EVAJOB<>"" Then
        # 1er cas : l'emploi type est renseigné.
        L_EMPLOI = [F:EVE]EVAJOB
        If [F:EVE]EVAPOT<>"" Then
          # Le poste est renseigné : on le lit.
          Read [F:POT]POT0=[F:EVE]EVAPOT
          If !fstat and [F:POT]JOBPOT = [F:EVE]EVAJOB Then
            L_POSTE = [F:POT]COD
          Endif
        Endif
      Elsif [F:EVE]EVAPOT<>"" and [F:EVE]EVAJOBGRP="" Then
        # 2ème cas : seul le poste est renseigné.
        # On lit le poste pour voir s'il est rattaché à un emploi type. S'il n'est pas
        # rattaché à un emploi type, on n'édite rien.
        Read [F:POT]POT0=[F:EVE]EVAPOT
        If !fstat and [F:POT]JOBPOT <> "" Then
          L_EMPLOI = [F:POT]JOBPOT
          L_POSTE = [F:POT]COD
        Endif
      Endif

      # L'emploi type est renseigné
      If L_EMPLOI <> "" Then
        # Lecture de l'emploi type
        Read [F:JOT]JOT0 = L_EMPLOI
        If !fstat Then
          # Compétences de l'emploi type
          Gosub CPC_EMPLOI_TYPE
          If GOK=0 : Break : Endif
          If L_POSTE = "" Then
            # Le poste n'est pas renseigné : on récupère les compétences de tous les postes
            # rattachés à l'emploi type
            Gosub CPC_POSTE_EMPLOI
          Else
            # Le poste est renseigné : on récupère les compétences du poste
            Gosub CPC_POSTE
          Endif
        Endif
      Elsif L_POSTE="" and [F:EVE]EVAJOBGRP<>"" Then
        # 3ème cas : seul le métier est renseigné.
        Gosub CPC_METIER
      Endif
      If GOK=0 : Break : Endif
    Endif
  Endif
Next

If GOK=0 : Goto AB_TR2 : Endif
Commit
Return

#--------------------------------------------------------------------------
# On récupère les compétences de l'emploi type
#--------------------------------------------------------------------------
$CPC_EMPLOI_TYPE
  # Parcours des compétences requises
  For I=0 To dim([F:JOT]CPC)-1
    If [F:JOT]CPC(I)="" : Break : Endif
    Call LECTURE("CPC",[F:JOT]CPC(I),"") From CONTOBJ
    Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
    Raz [F:TMO]
    Gosub PARTIE_COMMUNE
    [F:TMO]JOBPOT = [F:JOT]COD
    # [F:TMO]POT : non renseigné
    [F:TMO]CPC    = [F:JOT]CPC(I)
    [F:TMO]CPCLEV = [F:JOT]NIV(I)
    J = find([F:JOT]NIV(I),[F:HRSCA]LEV)
    If J
      [F:TMO]CPCSCA = [F:HRSCA]LEVREF(J-1)*[F:JOT]WEI(I)
    Endif
    # Recherche du niveau de compétence le plus récent du salarié, validé
    Filter [CPE] Where REFNUM=[F:ID]REFNUM & CPC=[F:JOT]CPC(I) & CPCDAT <> [00/00/00]
    Read [CPE]CPE1 Last
    Filter [CPE]
    If !fstat
      [F:TMO]CPCDAT = [F:CPE]CPCDAT
      [F:TMO]MATLEV = [F:CPE]LEVCPC
      J = find([F:CPE]LEVCPC,[F:HRSCA]LEV)
      If J
        [F:TMO]MATSCA = [F:HRSCA]LEVREF(J-1)*[F:JOT]WEI(I)
      Endif
    Endif
    [F:TMO]ORI = [F:JOT]ORI(I)
    Write [F:TMO]
    If fstat : GOK = 0 : Call FSTA("TMO") From GLOCK : Break : Endif
  Next

Return

#------------------------------------------------------------------------------------
# On récupère les compétences de tous les postes valides rattachés à l'emploi type
#------------------------------------------------------------------------------------
$CPC_POSTE_EMPLOI
  # Recherche des postes valides rattachés à l'emploi type
  Filter [POT] Where JOBPOT=[F:JOT]COD & (DATENDVLY=[0/0/0] | DATENDVLY>date$)
  For [POT]POT1
    # Recherche des compétences requises pour le poste
    For I=0 To dim([F:POT]CPC)-1
      If [F:POT]CPC(I)="" : Break : Endif
      Call LECTURE("CPC",[F:POT]CPC(I),"") From CONTOBJ
      Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
      Raz [F:TMO]
      Gosub PARTIE_COMMUNE
      [F:TMO]JOBPOT = [F:POT]JOBPOT
      [F:TMO]POT    = [F:POT]COD
      [F:TMO]CPC    = [F:POT]CPC(I)
      [F:TMO]CPCLEV = [F:POT]NIV(I)
      J = find([F:POT]NIV(I),[F:HRSCA]LEV)
      If J
        [F:TMO]CPCSCA = [F:HRSCA]LEVREF(J-1)*[F:POT]WEI(I)
      Endif
      # Recherche du niveau de compétence le plus récent du salarié, validé
      Filter [CPE] Where REFNUM=[F:ID]REFNUM & CPC=[F:POT]CPC(I) & CPCDAT <> [00/00/00]
      Read [CPE]CPE1 Last
      Filter [CPE]
      If !fstat
        [F:TMO]CPCDAT = [F:CPE]CPCDAT
        [F:TMO]MATLEV = [F:CPE]LEVCPC
        J = find([F:CPE]LEVCPC,[F:HRSCA]LEV)
        If J
          [F:TMO]MATSCA = [F:HRSCA]LEVREF(J-1)*[F:POT]WEI(I)
        Endif
      Endif
      [F:TMO]ORI = [F:POT]ORI(I)
      Write [F:TMO]
      If fstat : GOK = 0 : Call FSTA("TMO") From GLOCK : Break 2 : Endif
    Next
  Next
  Filter [POT]

Return

#-----------------------------------------------------------------------------------
# On récupère les compétences du poste s'il est valide
#-----------------------------------------------------------------------------------
$CPC_POSTE
  # Lecture du poste
  Filter [POT] Where COD=L_POSTE & (DATENDVLY=[0/0/0] | DATENDVLY>date$)
  For [POT]POT1
    # Recherche des compétences requises pour le poste
    For I=0 To dim([F:POT]CPC)-1
      If [F:POT]CPC(I)="" : Break : Endif
      Call LECTURE("CPC",[F:POT]CPC(I),"") From CONTOBJ
      Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
      Raz [F:TMO]
      Gosub PARTIE_COMMUNE
      [F:TMO]JOBPOT = [F:JOT]COD
      [F:TMO]POT    = [F:POT]COD
      [F:TMO]CPC    = [F:POT]CPC(I)
      [F:TMO]CPCLEV = [F:POT]NIV(I)
      J = find([F:POT]NIV(I),[F:HRSCA]LEV)
      If J
        [F:TMO]CPCSCA = [F:HRSCA]LEVREF(J-1)*[F:POT]WEI(I)
      Endif
      # Recherche du niveau de compétence le plus récent du salarié, validé
      Filter [CPE] Where REFNUM=[F:ID]REFNUM & CPC=[F:POT]CPC(I) & CPCDAT <> [00/00/00]
      Read [CPE]CPE1 Last
      Filter [CPE]
      If !fstat
        [F:TMO]CPCDAT = [F:CPE]CPCDAT
        [F:TMO]MATLEV = [F:CPE]LEVCPC
        J = find([F:CPE]LEVCPC,[F:HRSCA]LEV)
        If J
          [F:TMO]MATSCA = [F:HRSCA]LEVREF(J-1)*[F:POT]WEI(I)
        Endif
      Endif
      [F:TMO]ORI = [F:POT]ORI(I)
      Write [F:TMO]
      If fstat : GOK = 0 : Call FSTA("TMO") From GLOCK : Break 2 : Endif
    Next
  Next
  Filter [POT]

Return

#--------------------------------------------------------------------------------------
# On récupère les compétences de tous les emplois type en cours de validité
# rattachés au métier
#--------------------------------------------------------------------------------------
$CPC_METIER
  Filter [F:JOT] Where JOBGRP = [F:EVE]EVAJOBGRP & (DATENDVLY=[0/0/0] | DATENDVLY>date$)
  For [F:JOT]JOT0
    Gosub CPC_EMPLOI_TYPE
    If GOK=0 : Break : Endif
  Next
  Filter [F:JOT]
Return

#--------------------------------------------------------------------------
# Partie commune aux différents cas
#--------------------------------------------------------------------------
$PARTIE_COMMUNE
  [L]WNUMLIG   +=1
  [F:TMO]NUMREQ = [L]NUMREQ
  [F:TMO]USR    = GUSER
  [F:TMO]NUMLIG = [L]WNUMLIG
  [F:TMO]CREDAT = date$
  [F:TMO]REFNUM = [F:EVE]REFNUM
  [F:TMO]CTRNUM = [F:EVE]CTRNUM
  [F:TMO]EVADAT = [F:EVE]EVADAT
  [F:TMO]EVAJOBGRP = [F:EVE]EVAJOBGRP
  [F:TMO]EVAJOBGRPDAT = [F:EVE]EVAJOBGRPDAT
Return

$AB_TR2
Rollback
Return

#------------------------------------------------------------------------------
# SYMEU - EXI 66105 LOT 8 - V6.1 : pour contrôle sur l'emploi type et le poste
#------------------------------------------------------------------------------
$ACTION
Case ACTION
 When "CONT1" Gosub CONT1
Endcase
Return

#--------------------------------------------------------------------------
# SYMEU - EXI 66105 LOT 8 - V6.1 : contrôle sur l'emploi type et le poste.
# Si l'emploi type est renseigné, on initialise le poste et inversement.
#--------------------------------------------------------------------------
$CONT1
If [M]PARCOD(nolign-1)="emploi" and VALEUR<>"" Then
  # recherche de l'indice du paramètre du poste
  I = find("pot",[M:RPT]PARCOD)
  If I Then
    Raz [M:RPT]VALEUR1(I-1), [M:RPT]VALINT1(I-1)
    Affzo [RPT]VALEUR1(I-1)
  Endif
Elsif [M]PARCOD(nolign-1)="pot" and VALEUR<>"" Then
  # recherche de l'indice du paramètre de l'emploi type
  I = find("emploi",[M:RPT]PARCOD)
  If I Then
    Raz [M:RPT]VALEUR1(I-1), [M:RPT]VALINT1(I-1)
    Affzo [RPT]VALEUR1(I-1)
  Endif
Endif
Return
