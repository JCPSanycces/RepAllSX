#<AdxTL>@(#)9.0.0.0 $Revision$
##################################################################################
# Cette action INSMAJ2 sert uniquement à passer les flags "cloturé" des inscriptions
# et de la session à 'Oui'. + Passer le flag suivi des demandes à "Réalisée"
#
#     MABOS - 11/03/13 - FQ 87514-US1406- From GESHRSES, Do not come back to the last selection box
#                                         & Correct Init selection VALCPC & VALHAB
##################################################################################
Raz GPILOBJ
Call OBJET("SE2",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "INIT" : TIT = mess(58,10717,1) : Gosub DEBUT : # Validation des inscriptions :#MABOS-FQ87514-From GESSES, Correct Init selection VALCPC & VALHAB
  When "CONTROLE" : Gosub CONTROLE
 When "EXEC" : Gosub EXEC
 When "SORTIE" : Gosub SORTIE: #MABOS-FQ87514-From GESSES, Correct Init selection VALCPC & VALHAB
Endcase
Return

$DEBUT
#MABOS-FQ87514-From GESSES, Correct Init selection VALCPC & VALHAB
If ([M:HRSES1]ENDDAT>datesyst)
  If clalev([M:INM2]) = 0 : Local Mask INSMAJ2 [M:INM2]  : Endif
  [M:INM2]INSCPC=1
  [M:INM2]INSHAB=1
  BCRIT="" :# on ne veut pas la fenêtre de critère
Endif
Return


# Avant exécution de la clôture, on demande confirmation
$CONTROLE
Local Integer RET

  Call OUINON(mess(208,10717,1)+chr$(10)+mess(169,10717,1),RET) From GESECRAN : # Les inscriptions clôturées ne seront plus modifiables. Confirmez-vous ?
  If RET=1 Then
    FIN=1
  Endif
Return

#####################################
$EXEC
Gosub OUVRE From SUBHRSES
If clalev([F:SES2])=0 : Local File SESSIONS [SES2] : Endif
If clalev([F:DML])=0  : Local File DEMLIG   [DML]  : Endif
Local Integer NBENREG

TIT=mess(58,10717,1)    #Validation des inscriptions
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT-mess(34,10717,1)-":"-[F:HRSES]COD,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

SYMBOLE = "MAJINS2"
Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 Unlock =SYMBOLE
 GERR = 1 : SAI = 1 : Return
Endif

Call DEBTRANS From GLOCK
Gosub TR1

Unlock =SYMBOLE

Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
If NBENREG>0
 #Nombre d'inscriptions mises à jour
 Call ECR_TRACE(mess(54,10717,1)-":"-num$(NBENREG),0) From GESECRAN
Else
 #Aucune inscription à traiter
 Call ECR_TRACE(mess(55,10717,1),0) From GESECRAN
Endif
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

  # Si la case "Validation des compétences" est cochée, on doit mettre à jour les compétences pour la session
  If [M:INM2]INSCPC=2 Then
    Local Char VALBOUT(250) , PARBOUT(250)(1..20)
    If GFONCTION ="GESHRSES" Then :#MABOS-FQ87514-From GESHRSES, Correct Init selection VALCPC & VALHAB
      PARBOUT(1) = [M:HRSES0]STG
      PARBOUT(2) = [M:HRSES0]COD
    Else
      PARBOUT(1) = [F:INS]STG
      PARBOUT(2) = [F:INS]SES
    Endif
    FLGEXE = 1
    GACTION = "VALCPC"
    Call TRAITE_CHAR(VALBOUT,PARBOUT,"VALCPC2","VALCPC","VALCPC",4,"XYVALCPC") From GTRAITE
  Endif
  # Si la case "Validation des habilitations" est cochée, on doit mettre à jour les habilitations pour la session
  If [M:INM2]INSHAB=2 Then
    Local Char VALBOUT(250) , PARBOUT(250)(1..20)
    If GFONCTION ="GESHRSES" Then :#MABOS-FQ87514-From GESHRSES, Correct Init selection VALCPC & VALHAB
      PARBOUT(1) = [M:HRSES0]STG
      PARBOUT(2) = [M:HRSES0]COD
    Else
      PARBOUT(1) = [F:INS]STG
      PARBOUT(2) = [F:INS]SES
    Endif
    FLGEXE = 1
    GACTION = "VALHAB"
    Call TRAITE_CHAR(VALBOUT,PARBOUT,"VALHAB2","VALHAB","VALHAB",4,"XYVALHAB") From GTRAITE
  Endif
Return

$TR1
Trbegin [INS],[SES2],[DML]
NBENREG=0
For [F:INS]INS0 Where SES=[F:HRSES]COD & STA<>3
 Read [F:ID]ID0=[F:INS]REFNUM
 If fstat : GOK=0 : Break : Endif
 # MABON 03/09/10 - La clôture ne tient plus compte du statut initial de l'inscription, et de son lien avec le FLGTPS du salarié
# If ([F:ID]FLGTPS=2 & [F:INS]STA=2) | ([F:ID]FLGTPS<>2 & [F:INS]STA=1)
  #DBA le 22/03/06
  #Mise à jour du flag suivi des demandes
  If [F:INS]DEM<>""
   Filter [DML] Where DEMNUM=[F:INS]DEM & EMP=[F:INS]REFNUM & CTRNUM=[F:INS]CTRNUM
   Readlock [DML]DML0 First
   Filter [DML]
   If !fstat & [F:DML]FLGINS<4  :#Demandes non réalisées
    [F:DML]OLDFLGINS=[F:DML]FLGINS
    [F:DML]FLGINS=4             :#Demandes -> réalisées
    Rewrite [F:DML]
    If fstat
     GOK = 0 : Call FSTA("DML") From GLOCK : Break
    Endif
   Endif
  Endif
  # FQ66191 - MABON 29/10/10 - Ajout d'un état donc décalage pour le clôturé
#  [F:INS]STA=3     :#Inscriptions -> "Clôturée"
  # FQ80921 - MABON 22/03/12 - Le menu local 459 a évolué
#  [F:INS]STA=4     :#Inscriptions -> "Clôturée"
  [F:INS]STA=6     :#Inscriptions -> "Clôturée"
  # Fin MABON
  Rewrite [F:INS]
  If fstat
   GOK = 0 : Call FSTA("INS") From GLOCK : Break
  Endif
  # MABON 27/09/10 - Mise à jour parcours
  Call LECTURE("DEM", [F:INS]DEM, "") From CONTOBJ
  If [F:DEM]ORIDEM=2 : # Origine demande = Parcours
    Call UPDATE_CSI([F:DEM]CODCSI, [F:HRSES]COD, [F:INS]STG, [F:INS]REFNUM, "INS", 3, GOK) From SUBINS
    If GOK=0 Then Break 2 : Endif
  Endif
  # Fin MABON
  NBENREG+=1
# Endif
Next
If GOK & NBENREG>0
 Update [F:SES2] Where COD=[F:HRSES]COD With FLGCLO=2
Endif
If   GOK<0 : Goto ROLL_TR1
Elsif !GOK : Goto AB_TR1
Endif
Commit
Return

#####################################
$AB_TR1
Rollback
Return

#####################################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return :#MABOS-FQ87514-


$SORTIE
#MABOS-FQ87514-From GESSES, Correct Init selection VALCPC & VALHAB
  If clalev([M:INM2]) : Close Mask [M:INM2]  : Endif
Return
