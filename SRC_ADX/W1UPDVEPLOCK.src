#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque UPDVEPLOCK 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:59"
A_USER  = "DOC"
A_STAMP = "20181109230659"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask UPDVEPLOCK [UPVL]
Gosub HORODAT
Local Inpbox "UPDVEPLOCK" From GFONCTION At A_STAMP With A_WINDPREV Mask [UPVL] As [SIM_]
Grizo [UPVL]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [UPVL]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=1 : Y2(0)=22
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1UPDVEPLOCK
Return

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(47557,GBOUT1) From OBJDIV
Call TEXTE(44843,GBOUT2) From OBJDIV
Call TEXTE(5481,GBOUT3) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1UPDVEPLOCK
Onkey 130 Titled GBOUT2 Call B2_NBLIG From W1UPDVEPLOCK
Onkey 131 Titled GBOUT3 Call B3_NBLIG From W1UPDVEPLOCK
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B1_NBLIG From UPDVEPLOCK
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC1"
 Call OBJET_CHAR([M]REFNUM(nolign-1),"EML","") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC2"
 Call OBJET_CHAR([M]CTRNUM(nolign-1),"CTR",[M]REFNUM(nolign-1)+"~"+[M]CTRDAT(nolign-1)) From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_FLGLOCK
Onevent INIT_AREA Call D_FLGLOCK(zc) From W1UPDVEPLOCK
Onevent BEFORE_INPUT Call AS_FLGLOCK(zc) From W1UPDVEPLOCK
Onevent CONTROL Call C_FLGLOCK(zc) From W1UPDVEPLOCK
Return

Subprog D_FLGLOCK(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGLOCK,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLGLOCK(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_FLGLOCK(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "FLGLOCK" : GZNUM = 51786 : Endif
Gosub _AFF
End

$ON_REFNUM
Return

$ON_CTRNUM
Return

$ON_CTRDAT
Onevent BEFORE_AREA Gosub AV_CTRDAT From W1UPDVEPLOCK
Return

$AV_CTRDAT
Chgfmt [M]CTRDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

