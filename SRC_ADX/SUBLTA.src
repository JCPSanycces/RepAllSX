#<AdxTL>@(#)0.0.0.0 $Revision$
#**
# Display SST detail records
#   if GREP = "", then display from local tax table LTA
#     otherwise recalculate tax by calling SST.
#   Invoked by action VISULTA
#
#*!

$ACTION

Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "DEBUT"        : Gosub DEBUT
  When Default        :
Endcase
Return

###################################################################################
$OUVRE
Local Integer ERR : ERR=0

# 106867.sn
If [F:CPY]CPY <> GSOCIETE
  Read [F:CPY]CPY0=GSOCIETE
Endif
# 106867.en

# If  !GLOCUSATAX   # 106867.o
If !(func AFNC.ACTIV("LTA")) | [F:CPY]SSTTAXACT <> 2   # 106867.n
  ERR=1
Elsif [F:LTP]CLCALL <> 2                               # Flag set to not send all docs to SST
  If dim([M]SSTENTCOD)>0 and [M]SSTENTCOD <> ""        # SST entitty code is set (standard means tax exempt)
    ERR=1
  Elsif dim([M:SQH1]SSTENTCOD)>0 and [M:SQH1]SSTENTCOD <> ""          # Quote Tax Code
    ERR=1
  Elsif dim([M:SOH1]SSTENTCOD)>0 and [M:SOH1]SSTENTCOD <> ""          # Order Tax Code
    ERR=1
  Elsif dim([M:SDH2]SSTENTCOD)>0 and [M:SDH2]SSTENTCOD <> ""          # Shipment Tax Code
    ERR=1
  Elsif dim([M:SIH1]SSTENTCOD)>0 and [M:SIH1]SSTENTCOD <> ""          # Invoice Tax Code
    ERR=1
  Elsif dim([M:BIC1]SSTENTCOD)>0 and [M:BIC1]SSTENTCOD <> ""          # AR Invoice Tax Code
    ERR=1
  Endif
Endif
If ERR
  # ERRMSG = "SST not used in tax calc"   # 106867.o
  ERRMSG = mess(169,104,1)   # 106867.n
  Call MESSAGE(ERRMSG) From GESECRAN
  FIN=1
  Return
Endif
Return

If !clalev([F:LTV])  Local File LTAVCR [LTV] : Endif
If !clalev([M:LTA1]) Local Mask LTA1 [LTA1]  : Endif
If !clalev([F:LTP])  Local File LTAPAR [LTP] : Endif

Read [F:LTP]LTP0=nomap                                            # Lookup to find 'send all documents flag'
If  fstat
    GERR=1
    GMESSAGE=mess(141,105,1)- "[LTAPAR-"+nomap+"]"
Endif

Return


#**
#* DEBUT - If the docoument is not in the process of being changed then display from table.
#   PARAM(1): Document Type: VCRTYP
#   PARAM(2): Document Number: VCRNUM
#*!
$DEBUT

Local Integer ERR
Local Char ERRMSG(250)
If dim(GLTAGREP)<1
  Global Char GLTAGREP(1)
Endif
GLTAGREP=GREP
If  GLTAGREP=""
  # Line summary valuation
  Filter [F:LTV] Where VCRTYP= val(PARAM(1)) and VCRNUM = PARAM(2) and DTA=0 Order By Key LTV0
  nolign = 0
  For [F:LTV]
    [M:LTA1]TAXNAM(nolign) = [F:LTV]TAXNAM
    [M:LTA1]AMTATI(nolign) = [F:LTV]AMTNOT+[F:LTV]AMTTAX
    [M:LTA1]AMTNOT(nolign) = [F:LTV]AMTNOT
    [M:LTA1]AMTTAX(nolign) = [F:LTV]AMTTAX
    [M:LTA1]BASTAX(nolign) = [F:LTV]BASTAX
    [M:LTA1]CUR(nolign)    = [F:LTV]CUR
    [M:LTA1]JURNAM(nolign) = [F:LTV]JURNAM
    [M:LTA1]JURTYP(nolign) = [F:LTV]JURTYP
    [M:LTA1]PAYS(nolign)   = [F:LTV]PAYS
    [M:LTA1]SAT(nolign)    = [F:LTV]SAT
    [M:LTA1]TAXDAT(nolign) = [F:LTV]TAXDAT
    [M:LTA1]TAXNAM(nolign) = [F:LTV]TAXNAM
    [M:LTA1]TAXRAT(nolign) = [F:LTV]TAXRAT
    nolign += 1
    If nolign>=dim(TAXNAM)-1 : Break : Endif
  Next
  Filter [F:LTV]
  [M:LTA1]NBVAT = nolign

  # Invoice element summary valuation
  Filter [F:LTV] Where VCRTYP= val(PARAM(1)) and VCRNUM = PARAM(2) and DTA<>0 Order By Key LTV0
  nolign = 0
  For [F:LTV]
    [M:LTA1]DTATAXNAM(nolign) = [F:LTV]TAXNAM
    [M:LTA1]DTAAMTATI(nolign) = [F:LTV]AMTNOT+[F:LTV]AMTTAX
    [M:LTA1]DTAAMTNOT(nolign) = [F:LTV]AMTNOT
    [M:LTA1]DTAAMTTAX(nolign) = [F:LTV]AMTTAX
    [M:LTA1]DTABASTAX(nolign) = [F:LTV]BASTAX
    [M:LTA1]DTACUR(nolign)    = [F:LTV]CUR
    [M:LTA1]DTAJURNAM(nolign) = [F:LTV]JURNAM
    [M:LTA1]DTAJURTYP(nolign) = [F:LTV]JURTYP
    [M:LTA1]DTAPAYS(nolign)   = [F:LTV]PAYS
    [M:LTA1]DTASAT(nolign)    = [F:LTV]SAT
    [M:LTA1]DTATAXDAT(nolign) = [F:LTV]TAXDAT
    [M:LTA1]DTATAXNAM(nolign) = [F:LTV]TAXNAM
    [M:LTA1]DTATAXRAT(nolign) = [F:LTV]TAXRAT
    [M:LTA1]DTA(nolign)       = [F:LTV]DTA
    nolign += 1
    If nolign>=dim(DTATAXNAM)-1 : Break : Endif
  Next
  Filter [F:LTV]
  [M:LTA1]NBFOOT = nolign
Else
  GTAXBYDOC  = 1
  Case GFONCTION
    When "GESSQH", "GESSOH", "GESSDH"    :
        # 101874 : V9 : Tax code control
        #---- Supplementary sets valorisation call
        # PARAM_T(0) : Control taxes flag             (1=No/2=Yes)
        # PARAM_T(1) : Trace readling by the sub prog (1=No with msg/2=Yes with msg/3=No without msg/4=Yes without msg)
        # PARAM_T(2) : Flag back                      (1=KO/2=OK)
        Local    Char     PARAM_T (25) (0..10)
        PARAM_T(0)=num$(1)      : # No tax control
        PARAM_T(1)=num$(1)      : # No trace reading
        PARAM_T(2)=num$(0)
        Call VALTTC (GFONCTION, PARAM_T) From TRTVENFACR
        #Call VALTTC(GFONCTION) From TRTVENFACR
        # 101874
#   When "GESSIH"                        : Call CALCTAX("SIH4",ERR,ERRMSG) From TRTTAXUSA   # 106867.o
    When "GESSIH"                        : Call CALCTAX("SIH4",ERR,ERRMSG) From TRTTAXSST   # 106867.n
    When "GESBIC"                        : Call CALCTAX("BIC3",ERR,ERRMSG) From TRTTAXSST   # 106867.n
#   When "GESBIC"                        : Call CALCTAX("BIC3",ERR,ERRMSG) From TRTTAXUSA   # 106867.o
    When Default :
  Endcase
Endif

Case GFONCTION
  When "GESSQH" : [M:LTA1]TOTINVNOT = [M:SQH2]QUOINVNOT : [M:LTA1]TOTINVATI = [M:SQH2]QUOINVATI
  When "GESSOH" : [M:LTA1]TOTINVNOT = [M:SOH4]ORDINVNOT : [M:LTA1]TOTINVATI = [M:SOH4]ORDINVATI
  When "GESSDH" : [M:LTA1]TOTINVNOT = [M:SDH1]DLVINVNOT : [M:LTA1]TOTINVATI = [M:SDH1]DLVINVATI
  When "GESSIH" : [M:LTA1]TOTINVNOT = [M:SIH4]INVNOT    : [M:LTA1]TOTINVATI = [M:SIH4]INVATI
  When "GESBIC" : [M:LTA1]TOTINVNOT = [M:BIC3]TOTNOT    : [M:LTA1]TOTINVATI = [M:BIC3]TOTATI
  When Default  : [M:LTA1]TOTINVNOT = 0 : [M:LTA1]TOTINVATI = 0
Endcase

Affzo[M:LTA1]

Return

