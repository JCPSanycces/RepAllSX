#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque EDIIMP 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:07"
A_USER  = "DOC"
A_STAMP = "20181109230407"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask EDIIMP [DIA]
Gosub HORODAT
Local Inpbox "EDIIMP" From GFONCTION At A_STAMP With A_WINDPREV Mask [DIA] As [SIM_]
Grizo [DIA]10
Grizo [DIA]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DIA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=32 : X2(0)=80 : Y1(0)=9 : Y2(0)=12
X1(1)=32 : X2(1)=80 : Y1(1)=13 : Y2(1)=19
Return

$ON_FIL
Onevent CONTROL Call C_FIL(zc) From W1EDIIMP
Return

Subprog C_FIL(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "FIL" : GZNUM = 830 : Endif
Gosub _AFF
End

$ON_NUMBATCH
Onevent CONTROL Call C_NUMBATCH(zc) From W1EDIIMP
Return

Subprog C_NUMBATCH(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "NUMBATCH" : GZNUM = 52047 : Endif
Gosub _AFF
End

$ON_CATTYP
Onevent INIT_AREA Call D_CATTYP(zc) From W1EDIIMP
Onevent BEFORE_INPUT Call AS_CATTYP(zc) From W1EDIIMP
Onevent CONTROL Call C_CATTYP(zc) From W1EDIIMP
Return

Subprog D_CATTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]CATTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CATTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_CATTYP(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CATTYP" : GZNUM = 14951 : Endif
Gosub _AFF
End

$ON_PATH
Onevent CONTROL Call C_PATH(zc) From W1EDIIMP
Return

Subprog C_PATH(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PATH" : GZNUM = 15179 : Endif
Gosub _AFF
End

$ON_EXT
Onevent INIT_AREA Call D_EXT(zc) From W1EDIIMP
Onevent CONTROL Call C_EXT(zc) From W1EDIIMP
Onevent BEFORE_INPUT Call AS_EXT(zc) From W1EDIIMP
Return

Subprog D_EXT(VALEUR)
Variable Char    VALEUR()
If varinit([M]EXT,indice)=0
 If  GWEBSERV
  ## Action ACVLIBBUT
  Call ACVLIBBUT(VALEUR,"","") From SUBACV
 Endif
Endif
Gosub _AFF
End

Subprog AS_EXT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_EXT(zc) From W1EDIIMP
Onkey 144 Titled GBOUTP Call P_EXT(zc) From W1EDIIMP
Onkey 146 Titled GBOUTA Call SA_EXT(zc) From W1EDIIMP
Gosub _AFF
End

Subprog C_EXT(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "EXT" : GZNUM = 615 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("AOE","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "EXT" : GZNUM = 615 : Endif
Endif
Gosub _AFF
End

Subprog S_EXT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "AOE"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_EXT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "AOE"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_EXT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("AOE",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_TEST
Onevent INIT_AREA Call D_TEST(zc) From W1EDIIMP
Onevent BEFORE_INPUT Call AS_TEST(zc) From W1EDIIMP
Return

Subprog D_TEST(VALEUR)
Variable Integer VALEUR
If varinit([M]TEST,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TEST(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


