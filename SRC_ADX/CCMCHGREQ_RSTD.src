#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation script: CCMCHGREQ_RSTD, Change Request - Header

#####################
# METHODS           #
#####################
$METHODS

  Case CURPTH
    When ""
      Case ACTION
        When "IS_ADMIN_USER"          : Gosub IS_ADMIN_USER
        When "IS_USER_PLANNER"        : Gosub IS_USER_PLANNER
        When "AREAD_AFTER"            : Gosub ACTIVATE_FIELDS
        When "AQUERY_TRANS_AFTER"     : Gosub HIDE_CLOSEDSTATE
      Endcase
    When "CCMCR"
      Case ACTION
        When "AINIT"        : Gosub ACTIVATE_MAJOR_VERSION : Gosub ACTIVATE_MINOR_VERSION
        When "AREAD_AFTER"  : Gosub ACTIVATE_MAJOR_VERSION : Gosub ACTIVATE_MINOR_VERSION : Gosub DEACTIVATE_CRID
      Endcase
  Endcase

Return
# --------------------------------------------------
# Custom Method
#
# Is the logged-in user an X3 administrator ?
# Return true or false.
$IS_ADMIN_USER
  Local Integer LOCSTATUS
  Local Instance AUTILIS Using C_AUTILIS

  AUTILIS = NewInstance C_AUTILIS AllocGroup null
  LOCSTATUS = fmet AUTILIS.AREAD(this.ACTX.USER)
  If (AUTILIS.PRFFCT = "ADMIN")
    ARET_VALUE = CST_ATRUE
  Else
    ARET_VALUE = CST_AFALSE
  Endif
  FreeGroup AUTILIS

Return

# --------------------------------------------------
# Custom Method
#
# Is the logged-in user a CCM PLANNER ?
# Return true or false.

$IS_USER_PLANNER
  Local Char CCMPLANNER(30)

  Call PARAMUTIL("CCMPLANNER", CCMPLANNER, this.ACTX.USER, "") From SUBAUS
  If (CCMPLANNER = "2")
    ARET_VALUE = CST_ATRUE
  Else
    ARET_VALUE = CST_AFALSE
  Endif

Return

#--------------------------------------------------
#To hide the default value '-Select-' in the query facet.
$HIDE_CLOSEDSTATE

If this.CCMCR.CRSTATUS <> 7
   this.CCMCR.CLOSEDST = AVOID.ALIB
Endif

Return

# --------------------------------------------------
# Enable / disable fields at a class level.
$ACTIVATE_FIELDS
  Local Integer I
  Local Integer LOCSTATUS

  LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("CRID", "$isDisabled", "true")

  # Change manager (CCMUSRID)
  If ((this.CCMCR.CRSTATUS <> 7) and (this.CCMCR.CCMUSRID = this.ACTX.USER or fmet this.IS_ADMIN_USER()))
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("CCMUSRID", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("CCMUSRID", "$isDisabled", "true")
  Endif

  # disable or enable fields depending on who can amend

  If (this.CCMCR.CRSTATUS = 7 or (this.ACTX.USER <> this.CCMCR.CCMUSRID and this.ACTX.USER <> this.CCMCR.CREUSR))
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("TITLE",    "$isDisabled", "true")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("CRDESC",   "$isDisabled", "true")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("SEVERITY", "$isDisabled", "true")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("IMPACT",   "$isDisabled", "true")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("REASON",   "$isDisabled", "true")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("DATEREQ",  "$isDisabled", "true")
  Else
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("TITLE",    "$isDisabled", "false")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("CRDESC",   "$isDisabled", "false")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("SEVERITY", "$isDisabled", "false")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("IMPACT",   "$isDisabled", "false")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("REASON",   "$isDisabled", "false")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("DATEREQ",  "$isDisabled", "false")
  Endif

  # Unknown product (PRODDESC)
  If (this.CCMCR.PRODUCT = "")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("PRODDESC", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("PRODDESC", "$isDisabled", "true")
  Endif

  # Reason for rejection (REJECTCOD)
  # Further information (REJDESC)
  If this.CCMCR.CRSTATUS = 3  # 3 = Rejected
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("REJECTCOD", "$isDisabled", "false")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("REJECTCOD", "$isMandatory", "true")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("REJDESC", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("REJECTCOD", "$isDisabled", "true")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("REJECTCOD", "$isMandatory", "false")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("REJDESC", "$isDisabled", "true")
  Endif

  # Change status (CRSTATUS)
  If (this.CCMCR.CCMUSRID <> this.ACTX.USER)
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("CRSTATUS", "$isDisabled", "true")
  Else
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("CRSTATUS", "$isDisabled", "false")
  Endif

  # Product (PRODUCT)

  #If the status is in [new] then the product is enabled or otherwise it is disabled.
  If (this.CCMCR.CRSTATUS = 1 and (this.ACTX.USER = this.CCMCR.CCMUSRID or this.ACTX.USER = this.CCMCR.CREUSR))
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("PRODUCT", "$isDisabled", "false")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("SITE",     "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("PRODUCT", "$isDisabled", "true")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("SITE",     "$isDisabled", "true")
  Endif

  # CLOSEDSTATE flag (CLOSEDSTATE)
  If this.CCMCR.CRSTATUS = 7  # 7 = Closed
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("CLOSEDST", "$isHidden", "false")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("CLOSEDATE","$isHidden", "false")
  Else
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("CLOSEDST", "$isHidden", "true")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("CLOSEDATE","$isHidden", "true")
  Endif

  # Planner (PLANNER)
  If ((this.CCMCR.CRSTATUS = 1 or this.CCMCR.CRSTATUS = 2) and (this.CCMCR.CCMUSRID = this.ACTX.USER or fmet this.IS_USER_PLANNER()))
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("PLANNER", "$isMandatory", "false")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("PLANNER", "$isDisabled", "false")
  Elsif ((this.CCMCR.CRSTATUS = 4 or this.CCMCR.CRSTATUS = 5) and (this.CCMCR.CCMUSRID = this.ACTX.USER or fmet this.IS_USER_PLANNER()))
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("PLANNER", "$isMandatory", "true")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("PLANNER", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("PLANNER", "$isMandatory", "false")
    LOCSTATUS = fmet this.CCMCR.ASETATTRIBUTE("PLANNER", "$isDisabled", "true")
  Endif

  # if change request New, disable impact analysis link
  If (this.CCMCR.CRSTATUS = 1 or this.CCMCR.IMPACTANAL <> 2)
    LOCSTATUS = fmet this.ASETLINKDISABLE("CCMIMPACT",[V]CST_AFFLNKREC)
  Endif

  # if change request New or In-review, disable Plan link
  If (this.CCMCR.CRSTATUS < 3 or this.CCMCR.IMPACTANAL <> 2)
    LOCSTATUS = fmet this.ASETLINKDISABLE("CCMPLAN",[V]CST_AFFLNKREC)
  Else
    # check Plan exists, if not then disable link
    Local Instance PLAN_HEADER Using C_CCMPLANH
    PLAN_HEADER = NewInstance C_CCMPLANH AllocGroup null
    LOCSTATUS = fmet PLAN_HEADER.AREAD(this.CCMCR.CRID)
    If (LOCSTATUS <> CST_AOK) # if the Plan does not exist then create the Plan ...
      LOCSTATUS = fmet this.ASETLINKDISABLE("CCMPLAN",[V]CST_AFFLNKREC)
    Endif
    FreeGroup PLAN_HEADER
  Endif

  # if Change request Closed, then disable edit link
  If (this.CCMCR.CRSTATUS = 7)
    LOCSTATUS = fmet this.ASETLINKDISABLE("AEDIT",[V]CST_AFFLNKREC)
  Endif

  # Enable / disable version creation links, depending on product
  # Manufactured or Subcontracted or creating product version

  LOCSTATUS = fmet this.ASETLINKDISABLE("PRODBOMS",[V]CST_AFFLNKPAG)
  LOCSTATUS = fmet this.ASETLINKDISABLE("SUBBOMS",[V]CST_AFFLNKPAG)
  LOCSTATUS = fmet this.ASETLINKDISABLE("PRODUCT",[V]CST_AFFLNKPAG)

  If ((this.CCMCR.CRSTATUS = 4 or this.CCMCR.CRSTATUS = 5) and (this.ACTX.USER = this.CCMCR.CCMUSRID) and
&      fmet this.CCMCR.IS_PRODUCT_VERSION_MANAGED(this.CCMCR.PRODUCT) > 1)

    Local File ITMMASTER [ITM]
    Local File ITMCATEG [ITG]
    # get product and product category
    Read [ITM]ITM0 = this.CCMCR.PRODUCT
    If (fstat = 0)
      Read [ITG]ITG1 = [F:ITM]TCLCOD; ""
      If (fstat = 0)
        # if manufactured product
        If ([F:ITG]MFGFLG = 2)
          LOCSTATUS = fmet this.ASETLINKENABLE("PRODBOMS",[V]CST_AFFLNKPAG)
        Endif
        # if subcontracted product
        If ([F:ITG]SCPFLG = 2)
          LOCSTATUS = fmet this.ASETLINKENABLE("SUBBOMS",[V]CST_AFFLNKPAG)
        Endif
        # if changing product version
        If ([F:ITG]MFGFLG <> 2 and [F:ITG]SCPFLG <> 2)
          LOCSTATUS = fmet this.ASETLINKENABLE("PRODUCT",[V]CST_AFFLNKPAG)
        Endif
      Endif
    Endif

    Close Local File [ITM]
    Close Local File [ITG]
  Endif

  If (this.CCMCR.CRSTATUS = 2 and this.CCMCR.IMPACTANAL = 1)
    LOCSTATUS = fmet this.CCMCR.ASETERROR("", mess(68,2038,1), CST_AWARNING)
  Endif

Return

#####################
# PROPERTIES        #
#####################
$PROPERTIES

  Case CURPRO
    When "CCMCR.CRID"
      Case ACTION
        When "INIT"
          Gosub DEACTIVATE_CRID
      Endcase
    When "CCMCR.CRSTATUS"
      Case ACTION
        When "INIT"
          Gosub INITIALISE_CHANGE_STATUS
          Gosub ACTIVATE_CHANGE_STATUS
        When "PROPAGATE"
          Gosub ACTIVATE_REJECTION
          Gosub ACTIVATE_PLANNER
          Gosub ACTIVATE_PRODUCT
      Endcase
    When "CCMCR.CCMUSRID"
      Case ACTION
        When "INIT"
          Gosub INITIALISE_CHANGE_MANAGER
          Gosub ACTIVATE_CHANGE_MANAGER
          Gosub ACTIVATE_APPROVER
      Endcase
    When "CCMCR.PLANNER"
      Case ACTION
        When "INIT"
          Gosub INITIALISE_PLANNER
          Gosub ACTIVATE_PLANNER
      Endcase
    When "CCMCR.PRODUCT"
      Case ACTION
        When "PROPAGATE"
          Gosub RESET_VERSION
          Gosub ACTIVATE_UNKNOWN_PRODUCT
          Gosub ACTIVATE_MAJOR_VERSION
          Gosub VALIDATE_ECCVALMAJ
          Gosub VALIDATE_ECCVALMIN
      Endcase
    When "CCMCR.REJECTCOD"
      Case ACTION
        When "INIT"
          Gosub ACTIVATE_REJECTION
      Endcase
    When "CCMCR.ECCVALMAJ"
      Case ACTION
        When "PROPAGATE"
          Gosub VALIDATE_ECCVALMAJ
          Gosub ACTIVATE_MINOR_VERSION
      Endcase
    When "CCMCR.ECCVALMIN"
      Case ACTION
        When "PROPAGATE"
          Gosub VALIDATE_ECCVALMIN
      Endcase
  Endcase

Return

# --------------------------------------------------
#
$VALIDATE_ECCVALMAJ

  Local Integer R_V

  Local Char AVALUE(30) : AVALUE = ""

  If (fmet this.IS_PRODUCT_VERSION_MANAGED(this.PRODUCT) > 1  and this.ECCVALMAJ <> "")
    ASTATUS = func WMTYPCCMECS.ACTRLREF(this, "ECCVALMAJ", AVALUE, this.PRODUCT, this.ECCVALMAJ, "")
  Endif

Return

# --------------------------------------------------
#
$VALIDATE_ECCVALMIN

  Local Integer R_V

  Local Char AVALUE(30) : AVALUE = ""

  If (fmet this.IS_PRODUCT_VERSION_MANAGED(this.PRODUCT) = 3  and this.ECCVALMAJ <> "" and this.ECCVALMIN <> "")
    ASTATUS = func WMTYPCCMEVL.ACTRLREF(this, "ECCVALMIN", AVALUE, this.PRODUCT, this.ECCVALMAJ, this.ECCVALMIN, 4, "")
  Endif

Return

# ------------------------------------------------------------
# Subroutine: RESET_VERSION
#
# If the Product property value changes and then blank the Major/Minor Version.
$RESET_VERSION

    this.ECCVALMAJ = ""
    this.ECCVALMIN = ""

Return

# --------------------------------------------------
# Initialise change request status (CRSTATUS),
# Set to new and disable.
$INITIALISE_CHANGE_STATUS

  this.CRSTATUS = 1   # 1 = New

Return

# --------------------------------------------------
# Initialise change request change manager (CCMUSRID),
# Set to default change manager (error if Default CHANGE MANAGER DOES not EXIST).
$INITIALISE_CHANGE_MANAGER

  Local Char CCMCMDEF(30)

  CCMCMDEF = fmet this.ACTX.APARAM.AGETVALCHAR(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMCMDEF")
  If (CCMCMDEF <> "")
    this.CCMUSRID = CCMCMDEF
  Else
     ASTATUS = fmet  this.ASETERROR ("", mess(5,2038,1), CST_AERROR)
  Endif

Return

# --------------------------------------------------
# Initialise change request Planner (PLANNER),
# Set to default Planner
$INITIALISE_PLANNER

  Local Char CCMPLADEF(30)

  CCMPLADEF = fmet this.ACTX.APARAM.AGETVALCHAR(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMPLADEF")
  If (CCMPLADEF <> "")
    this.PLANNER = CCMPLADEF
  Endif

Return

# --------------------------------------------------
# Disable Request ID (CRID).
$DEACTIVATE_CRID

  Local Integer LOCSTATUS
  LOCSTATUS = fmet this.ASETATTRIBUTE("CRID", "$isDisabled", "true")
Return

# --------------------------------------------------
# Enable / disable change status (CRSTATUS).
$ACTIVATE_CHANGE_STATUS
  Local Integer LOCSTATUS

  If (this.CCMUSRID <> this.ACTX.USER)
      LOCSTATUS = fmet this.ASETATTRIBUTE("CRSTATUS", "$isDisabled", "true")
    Else
      LOCSTATUS = fmet this.ASETATTRIBUTE("CRSTATUS", "$isDisabled", "false")
    Endif

Return

# --------------------------------------------------
# Enable / disable change manager (CCMUSRID).
$ACTIVATE_CHANGE_MANAGER
  Local Integer LOCSTATUS

  If (this.CCMUSRID = this.ACTX.USER or fmet this.APARENT.IS_ADMIN_USER())
    LOCSTATUS = fmet this.ASETATTRIBUTE("CCMUSRID", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.ASETATTRIBUTE("CCMUSRID", "$isDisabled", "true")
  Endif

Return

# --------------------------------------------------
# Enable / disable unknown product (PRODDESC).
$ACTIVATE_UNKNOWN_PRODUCT
  Local Integer LOCSTATUS

  If (this.PRODUCT = "")
    LOCSTATUS = fmet this.ASETATTRIBUTE("PRODDESC", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.ASETATTRIBUTE("PRODDESC", "$isDisabled", "true")
  Endif

Return

# --------------------------------------------------
# Enable / disable reason for rejection (REJECTCOD) and
# further information (REJDESC).
$ACTIVATE_REJECTION
  Local Integer LOCSTATUS

  If (this.CRSTATUS = 3)  # 3 = Rejected
    LOCSTATUS = fmet this.ASETATTRIBUTE("REJECTCOD", "$isDisabled", "false")
    LOCSTATUS = fmet this.ASETATTRIBUTE("REJECTCOD", "$isMandatory", "true")
    LOCSTATUS = fmet this.ASETATTRIBUTE("REJDESC", "$isDisabled", "false")
    this.REJECTCOD = this.snapshot.REJECTCOD
  Else
    LOCSTATUS = fmet this.ASETATTRIBUTE("REJECTCOD", "$isDisabled", "true")
    LOCSTATUS = fmet this.ASETATTRIBUTE("REJECTCOD", "$isMandatory", "false")
    LOCSTATUS = fmet this.ASETATTRIBUTE("REJDESC", "$isDisabled", "true")
  Endif

Return

#--------------------------------------------------------
# Enable / disable Approver code (APPRUSER),
# Approver name(USERNAM),
# Approver status (APPRSTAT) and
# Approver reason(APPRREASON)
$ACTIVATE_APPROVER
  Local Integer LOCSTATUS
  Local Integer I

    If (this.CCMUSRID = this.ACTX.USER)
      For I = 1 To maxtab(this.CCMAPPROVER)
        LOCSTATUS = fmet this.CCMAPPROVER(I).ASETATTRIBUTE("APPRUSER", "$isDisabled", "false")
        LOCSTATUS = fmet this.CCMAPPROVER(I).ASETATTRIBUTE("APPRUSER", "$isMandatory", "true")
        LOCSTATUS = fmet this.CCMAPPROVER(I).ASETATTRIBUTE("USERNAM", "$isDisabled", "false")
        LOCSTATUS = fmet this.CCMAPPROVER(I).ASETATTRIBUTE("APPRSTAT", "$isDisabled", "false")
        LOCSTATUS = fmet this.CCMAPPROVER(I).ASETATTRIBUTE("APPRREASON", "$isDisabled", "false")
      Next I
    Else
      For I = 1 To maxtab(this.CCMAPPROVER)
        LOCSTATUS = fmet this.CCMAPPROVER(I).ASETATTRIBUTE("APPRUSER", "$isDisabled", "true")
        LOCSTATUS = fmet this.CCMAPPROVER(I).ASETATTRIBUTE("APPRUSER", "$isMandatory", "false")
        LOCSTATUS = fmet this.CCMAPPROVER(I).ASETATTRIBUTE("USERNAM", "$isDisabled", "true")

        # Enable the status and reason for logged-in approvers
        If(this.ACTX.USER <> this.CCMAPPROVER(I).APPRUSER)
          LOCSTATUS = fmet this.CCMAPPROVER(I).ASETATTRIBUTE("APPRSTAT", "$isDisabled", "true")
          LOCSTATUS = fmet this.CCMAPPROVER(I).ASETATTRIBUTE("APPRREASON", "$isDisabled", "true")
        Endif
      Next I
    Endif

Return

#--------------------------------------------------------
# Enable / disable Planner (PLANNER).
$ACTIVATE_PLANNER
  Local Integer LOCSTATUS

  If ((this.CRSTATUS = 1 or this.CRSTATUS = 2) and (this.CCMUSRID = this.ACTX.USER or fmet this.APARENT.IS_USER_PLANNER()))
    LOCSTATUS = fmet this.ASETATTRIBUTE("PLANNER", "$isMandatory", "false")
    LOCSTATUS = fmet this.ASETATTRIBUTE("PLANNER", "$isDisabled", "false")
  Elsif ((this.CRSTATUS = 4 or this.CRSTATUS = 5) and (this.CCMUSRID = this.ACTX.USER or fmet this.APARENT.IS_USER_PLANNER()))
    LOCSTATUS = fmet this.ASETATTRIBUTE("PLANNER", "$isMandatory", "true")
    LOCSTATUS = fmet this.ASETATTRIBUTE("PLANNER", "$isDisabled", "false")
  Else
    LOCSTATUS = fmet this.ASETATTRIBUTE("PLANNER", "$isMandatory", "false")
    LOCSTATUS = fmet this.ASETATTRIBUTE("PLANNER", "$isDisabled", "true")
  Endif

Return

#-----------------------------------------------------------
# Activate the product field based on CR status
$ACTIVATE_PRODUCT
  Local Integer LOCSTATUS

  If this.CRSTATUS = 1
     LOCSTATUS = fmet this.ASETATTRIBUTE("PRODUCT", "$isDisabled", "false")
  Elsif this.CRSTATUS = 2 and this.CCMUSRID = this.ACTX.USER and this.PRODUCT = ""
     LOCSTATUS = fmet this.ASETATTRIBUTE("PRODUCT", "$isDisabled", "false")
  Else
     LOCSTATUS = fmet this.ASETATTRIBUTE("PRODUCT", "$isDisabled", "true")
  Endif
Return

#-----------------------------------------------------------
# Activate Major Version (ECCVALMAJ) dependant on Product (PRODUCT) ...
$ACTIVATE_MAJOR_VERSION

  Local Integer LOCSTATUS

  LOCSTATUS = fmet this.ASETATTRIBUTE("ECCVALMAJ", "$isDisabled", "true")
  LOCSTATUS = fmet this.ASETATTRIBUTE("ECCVALMAJ", "$isMandatory", "false")
  If (this.CRSTATUS = 1 and
&     fmet this.IS_PRODUCT_VERSION_MANAGED(this.PRODUCT) > 1)
    LOCSTATUS = fmet this.ASETATTRIBUTE("ECCVALMAJ", "$isDisabled", "false")
  Endif

Return

#-----------------------------------------------------------
# Activate Minor Version (ECCVALMIN) dependant on Product (PRODUCT) ...
$ACTIVATE_MINOR_VERSION

  Local Integer LOCSTATUS

  LOCSTATUS = fmet this.ASETATTRIBUTE("ECCVALMIN", "$isDisabled", "true")
  LOCSTATUS = fmet this.ASETATTRIBUTE("ECCVALMIN", "$isMandatory", "false")
  If (this.CRSTATUS = 1 and
&     fmet this.IS_PRODUCT_VERSION_MANAGED(this.PRODUCT) = 3)
    LOCSTATUS = fmet this.ASETATTRIBUTE("ECCVALMIN", "$isDisabled", "false")
  Endif

Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

