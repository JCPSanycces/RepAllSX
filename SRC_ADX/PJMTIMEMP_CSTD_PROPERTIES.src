#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMTIMEMP properties
###################################################################################################
# PROPERTIES
###################################################################################################
$PTEDAT
  Case [L]ARULE
    When "INIT"       : Gosub PTEDAT_INIT
    When "CONTROL"    : Gosub PTEDAT_CONTROL
  Endcase
Return

$PTEDAT_INIT
  this.PTEDAT = date$
Return

# Issue X3-69372 - 2018-04-03 by SNGC : BEGIN
$PTEDAT_CONTROL
  If this.PTEDAT > date$ Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTEDAT", mess(354,2260,1), [V]CST_AWARNING))
  Endif
  # -----------------------------
  # Issue X3-66487 - 2018-05-04 by SINGC : START
  If this.ASTALIN = [V]CST_AUPD Then
    If this.PTESTA > 1 Then
      If this.PTEDAT <> this.snapshot.PTEDAT Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(339,2260,1), mess(this.PTESTA,2074,1)), [V]CST_AERROR))
      Endif
    Endif
  Endif
  # Issue X3-66487 - 2018-05-04 by SINGC : END
Return

#$PTEDAT_CONTROL
#  If this.ASTALIN = [V]CST_AUPD and this.PTEDAT <> this.snapshot.PTEDAT Then
#    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTEDAT", mess(18,9804,1), [V]CST_AERROR))
#  Endif
#  # -----------------------------
#  If this.PTEDAT > date$ and this.ASTALIN = [V]CST_ANEW Then
#    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTEDAT", mess(354,2260,1), [V]CST_AWARNING))
#  Endif
#Return
# Issue X3-69372 - 2018-04-03 by SNGC : END

###################################################################################################
$PTEQTY
  Case [L]ARULE
    When "CONTROL"    : Gosub PTEQTY_CONTROL
  Endcase
Return

$PTEQTY_CONTROL
  If this.PTEQTY < 0 Then
    [L]ASTATUS = fmet this.SETERROR("PTEQTY", mess(232,2260,1), [V]CST_AERROR)
  Endif
  # -----------------------------
  #If this.ASTALIN = [V]CST_AUPD and this.PTESTA <> 1 Then # Issue X3-66487 - 2018-05-04 by SINGC
  If this.ASTALIN = [V]CST_AUPD Then                       # Issue X3-66487 - 2018-05-04 by SINGC
    If this.PTESTA > 1 Then                                # Issue X3-66487 - 2018-05-04 by SINGC
      If this.PTEQTY <> this.snapshot.PTEQTY Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTEQTY", func AFNC.MES1(mess(339,2260,1), mess(this.PTESTA,2074,1)), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

###################################################################################################
$OPPNUM
  Case [L]ARULE
    When "CONTROL"   : Gosub OPPNUM_CONTROL
  Endcase
Return

$OPPNUM_CONTROL
  #If this.OPPNUM <> AVOID.ACHAR Then                                          # Issue X3-6217/119727 - 2016-11-14 by FGR
  If this.OPPNUM <> AVOID.ACHAR and this.snapshot.OPPNUM <> this.OPPNUM Then   # Issue X3-6217/119727 - 2016-11-14 by FGR
    Local File OPPORPJM [OPPPJM]
    # -----------------------------
    Read [OPPPJM]OPPPJM0=this.OPPNUM
    If [F:OPPPJM]OPPSTATE <> 2 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPNUM", func AFNC.MES1(mess(38,2260,1), this.OPPNUM), [V]CST_AERROR))
    Endif
  Endif
  # -----------------------------
  # Issue X3-66487 - 2018-05-04 by SINGC : START
  If this.ASTALIN = [V]CST_AUPD Then
    If this.PTESTA > 1 Then
      If this.OPPNUM <> this.snapshot.OPPNUM Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPNUM", func AFNC.MES1(mess(339,2260,1), mess(this.PTESTA,2074,1)), [V]CST_AERROR))
      Endif
    Endif
  Endif
  # Issue X3-66487 - 2018-05-04 by SINGC : END
Return

###################################################################################################
$PIMTASCOD
  Case [L]ARULE
    When "CONTROL"   : Gosub PIMTASCOD_CONTROL
    When "PROPAGATE" : Gosub PIMTASCOD_PROPAGATE
  Endcase
Return

$PIMTASCOD_CONTROL
Local File PIMPL [PIM]
Local File PJMTSK [PTA]

  #If this.ASTALIN = [V]CST_AUPD and this.PTESTA <> 1 Then # Issue X3-66487 - 2018-05-04 by SINGC
  If this.ASTALIN = [V]CST_AUPD Then                       # Issue X3-66487 - 2018-05-04 by SINGC
    If this.PTESTA > 1 Then                                # Issue X3-66487 - 2018-05-04 by SINGC
      If this.snapshot.PIMTASCOD <> this.PIMTASCOD Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMTASCOD", func AFNC.MES1(mess(339,2260,1), mess(this.PTESTA,2074,1)), [V]CST_AERROR))
      Endif
    Endif
  Endif
  #If this.PIMTASCOD <> AVOID.ACHAR Then                                                 # Issue X3-6217/119727 - 2016-11-14 by FGR
  If this.PIMTASCOD <> AVOID.ACHAR and this.snapshot.PIMTASCOD <> this.PIMTASCOD Then    # Issue X3-6217/119727 - 2016-11-14 by FGR
    Read [PIM]PIM0=this.PIMTASCOD
    If [F:PIM]PBUCOD = AVOID.ACHAR Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMTASCOD", func AFNC.MES1(mess(220,2260,1), [F:PIM]TASCOD), [V]CST_AERROR))
    Endif
    If [F:PIM]PIMTYP = 6 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMTASCOD", func AFNC.MES1(mess(424,2260,1), [F:PIM]TASCOD), [V]CST_AERROR))
    Endif
    If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.PIMTASCOD <> this.snapshot.PIMTASCOD) Then
      If [F:PIM]PIMSTA = [V]CST_ANO Then
        Read [PTA]PTA0=[PIM]OPPNUM;[PIM]TASCOD
        If [F:PTA]TASSTATE <> 2 Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMTASCOD", func AFNC.MES1(mess(428,2260,1), mess([F:PTA]TASSTATE,2250,1)), [V]CST_AERROR))
        Endif
        If [F:PTA]TASTYP = 1 Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMTASCOD", func AFNC.MES1(mess(427,2260,1), [F:PIM]TASCOD), [V]CST_AERROR))
        Endif
      Endif
    Endif
  Endif
Return

$PIMTASCOD_PROPAGATE
Local Char SOPPNUM(GLONPIM)
Local Char SPBUCOD(GLONPBU)

  # Issue X3-81871 - 2018-04-13 by FGR : BEGIN
  Raz this.OPENUM
  Raz this.OPESPLNUM
  Raz this.PIMPBUCOD
  # Issue X3-81871 - 2018-04-13 by FGR : END
  If this.PIMTASCOD <> AVOID.ACHAR Then
    Raz this.OPENUM
    # -----------------------------
    Local File PIMPL [PIM]
    Local File OPPOR [OPP]
    # -----------------------------
    Read [PIM]PIM0=this.PIMTASCOD
    Read [OPP]OPP0=[F:PIM]OPPNUM
    # -----------------------------
    this.FCY    = [F:PIM]FCY
    this.CUR    = [F:OPP]CUR
    this.CHGTYP = [F:OPP]CHGTYP
    # -----------------------------
    SOPPNUM = [F:PIM]OPPNUM
    SPBUCOD = [F:PIM]PBUCOD
    Filter [PIM] Where [F:PIM]OPPNUM = SOPPNUM and [F:PIM]PBUCOD = SPBUCOD and [F:PIM]PIMTYP = 4
    For [PIM]
      this.PIMPBUCOD = [F:PIM]PIMNUM
      Break
    Next
    Filter [PIM]
  Else
    # Issue X3-81871 - 2018-04-13 by FGR : BEGIN
    Raz this.OPENUM
    Raz this.OPESPLNUM
    Raz this.PIMPBUCOD
    Raz this.FCY
    Raz this.CUR
    Raz this.CHGTYP
    # Issue X3-81871 - 2018-04-13 by FGR : END
  Endif
Return

###################################################################################################
$PIMPBUCOD
  Case [L]ARULE
    When "CONTROL"   : Gosub PIMPBUCOD_CONTROL
    When "PROPAGATE" : Gosub PIMPBUCOD_PROPAGATE
  Endcase
Return

$PIMPBUCOD_CONTROL
Local File PIMPL [PIM]
Local File PJMBUD [PJBU]

  #If this.ASTALIN = [V]CST_AUPD and this.PTESTA <> 1 Then # Issue X3-66487 - 2018-05-04 by SINGC
  If this.ASTALIN = [V]CST_AUPD Then                       # Issue X3-66487 - 2018-05-04 by SINGC
    If this.PTESTA > 1 Then                                # Issue X3-66487 - 2018-05-04 by SINGC
      If this.snapshot.PIMPBUCOD <> this.PIMPBUCOD Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMPBUCOD", func AFNC.MES1(mess(339,2260,1), mess(this.PTESTA,2074,1)), [V]CST_AERROR))
      Endif
    Endif
  Endif
  # -----------------------------
  If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.PIMPBUCOD <> this.snapshot.PIMPBUCOD) Then
    Read [PIM]PIM0=this.PIMPBUCOD
    If [F:PIM]PIMSTA = [V]CST_ANO Then
      Read [PJBU]PJBU0=[PIM]OPPNUM;[PIM]PBUCOD
      If [F:PJBU]PBUSTATE <> 2 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMPBUCOD", func AFNC.MES1(mess(429,2260,1), mess([F:PJBU]PBUSTATE,2251,1)), [V]CST_AERROR))
      Endif
      If [F:PJBU]PBUIMP <> [V]CST_AYES Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMPBUCOD", func AFNC.MES1(mess(33,2260,1), [F:PIM]PBUCOD), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

$PIMPBUCOD_PROPAGATE
  #If this.PIMTASCOD = AVOID.ACHAR Then     # Issue X3-81871 - 2018-04-13 by FGR
  If this.PIMPBUCOD <> AVOID.ACHAR Then     # Issue X3-81871 - 2018-04-13 by FGR
    Local File PIMPL [PIM]
    Local File OPPOR [OPP]
    # -----------------------------
    Read [PIM]PIM0=this.PIMPBUCOD
    Read [OPP]OPP0=[F:PIM]OPPNUM
    # -----------------------------
    this.FCY = [F:PIM]FINRSPFCY
    this.CUR = [F:OPP]CUR
    this.CHGTYP = [F:OPP]CHGTYP
    [L]ASTATUS = max([L]ASTATUS, func OPPORPJM_CSTD_PROGS.GET_ANALYTICAL([F:OPP]OPPNUM, this)) # Issue X3-66474 - 2018-02-08 by SINGC
  Else
    # Issue X3-81871 - 2018-04-13 by FGR : BEGIN
    Raz this.FCY
    Raz this.CUR
    Raz this.CHGTYP
    # Issue X3-81871 - 2018-04-13 by FGR : END
  Endif
Return

###################################################################################################
$OPENUM
  Case [L]ARULE
    When "CONTROL"   : Gosub OPENUM_CONTROL
    When "PROPAGATE" : Gosub OPENUM_PROPAGATE
  Endcase
Return

$OPENUM_CONTROL
  #If this.ASTALIN = [V]CST_AUPD and this.PTESTA <> 1 Then # Issue X3-66487 - 2018-05-04 by SINGC
  If this.ASTALIN = [V]CST_AUPD Then                       # Issue X3-66487 - 2018-05-04 by SINGC
    If this.PTESTA > 1 Then                                # Issue X3-66487 - 2018-05-04 by SINGC
      If this.snapshot.OPENUM <> this.OPENUM Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPENUM", func AFNC.MES1(mess(339,2260,1), mess(this.PTESTA,2074,1)), [V]CST_AERROR))
      Endif
    Endif
  Endif
  # -----------------------------
  If this.OPENUM > 0 Then
    If this.PIMTASCOD = AVOID.ACHAR Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPENUM", mess(267,2260,1), [V]CST_AERROR))
    Endif
  Elsif this.OPENUM < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPENUM", mess(126,143,1), [V]CST_AERROR))
  Endif
Return

$OPENUM_PROPAGATE
  If this.OPENUM > 0 Then
    this.OPESPLNUM = 1
    Raz this.POANUM
  Else
    Raz this.OPESPLNUM
    Raz this.POANUM
  Endif
Return

###################################################################################################
$CUR
  Case [L]ARULE
    When "CONTROL"   : Gosub CUR_CONTROL
  Endcase
Return

$CUR_CONTROL
  #If this.ASTALIN = [V]CST_AUPD and this.PTESTA <> 1 Then # Issue X3-66487 - 2018-05-04 by SINGC
  If this.ASTALIN = [V]CST_AUPD Then                       # Issue X3-66487 - 2018-05-04 by SINGC
    If this.PTESTA > 1 Then                                # Issue X3-66487 - 2018-05-04 by SINGC
      If this.snapshot.CUR <> this.CUR Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CUR", func AFNC.MES1(mess(339,2260,1), mess(this.PTESTA,2074,1)), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

###################################################################################################
$PTEUOM
  Case [L]ARULE
    When "CONTROL"   : Gosub PTEUOM_CONTROL
    When "PROPAGATE" : Gosub PTEUOM_PROPAGATE # Issue X3-6208/119577 - 2016-11-07 by SINGC
  Endcase
Return

$PTEUOM_CONTROL
Local Integer IUOMTYP

  #If this.ASTALIN = [V]CST_AUPD and this.PTESTA <> 1 Then # Issue X3-66487 - 2018-05-04 by SINGC
  If this.ASTALIN = [V]CST_AUPD Then                       # Issue X3-66487 - 2018-05-04 by SINGC
    If this.PTESTA > 1 Then                                # Issue X3-66487 - 2018-05-04 by SINGC
      If this.snapshot.PTEUOM <> this.PTEUOM Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTEUOM", func AFNC.MES1(mess(339,2260,1), mess(this.PTESTA,2074,1)), [V]CST_AERROR))
      Endif
    Endif
  Endif
  # -----------------------------
  IUOMTYP = fmet this.ACTX.ACACHE.ATUN.AGETVALNUM(this.PTEUOM, "UOMTYP")
  If IUOMTYP <> 5 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTEUOM", mess(190,2260,1), [V]CST_AERROR))
  Endif
Return

$PTEUOM_PROPAGATE
  # Issue X3-6208/119577 - 2016-11-07 by SINGC : START
  # -----------------------------
  If this.ASTALIN = [V]CST_AUPD and this.PTEUOM <> this.snapshot.PTEUOM Then
    If this.PTEQTY <> 0 Then
      Call CONVERT_QTY(this.ACTX, this.snapshot.PTEUOM, this.PTEUOM, this.PTEQTY) From TRTX3_SYRA
    Endif
    If this.PJMCST <> 0 Then
      Call CONVERT_QTY(this.ACTX, this.PTEUOM, this.snapshot.PTEUOM, this.PJMCST) From TRTX3_SYRA
    Endif
    If this.CLBCST <> 0 Then
      Call CONVERT_QTY(this.ACTX, this.PTEUOM, this.snapshot.PTEUOM, this.CLBCST) From TRTX3_SYRA
    Endif
  Endif
Return

###################################################################################################
$PTEINV
  Case [L]ARULE
    When "INIT"     : Gosub PTEINV_INIT
    When "CONTROL"  : Gosub PTEINV_CONTROL
  Endcase
Return

$PTEINV_INIT
  this.PTEINV = [V]CST_ANO
Return

# Issue X3-66487 - 2018-05-04 by SINGC : START
$PTEINV_CONTROL
  If this.TCHACTION = AVOID.ACHAR Then
    If this.PTESTA > 2 Then
      If this.PTEINV <> [V]CST_ANO Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTEINV", func AFNC.MES1(mess(339,2260,1), mess(this.PTESTA,2074,1)), [V]CST_AERROR))
      Endif
    Endif
  Elsif this.TCHACTION = "TIMENTINV" Then
  Endif
Return

