###################################################################################################
$PTEVAL
  Case [L]ARULE
    When "INIT"      : Gosub PTEVAL_INIT
    When "CONTROL"   : Gosub PTEVAL_CONTROL
    When "PROPAGATE" : Gosub PTEVAL_PROPAGATE
  Endcase
Return

# Issue X3-66487 - 2018-05-04 by SINGC : START
$PTEVAL_INIT
  this.PTEVAL = fmet this.ACTX.APARAM.AGETUSERVALNUM("PJMTIMAUTO")
Return

$PTEVAL_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.PTESTA > 2 Then
      If this.PTEVAL <> [V]CST_AYES Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTEVAL", func AFNC.MES1(mess(339,2260,1), mess(this.PTESTA,2074,1)), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

