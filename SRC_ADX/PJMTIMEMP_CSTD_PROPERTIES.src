###################################################################################################
$PTEORI
  Case [L]ARULE
    When "INIT"      : Gosub PTEORI_INIT
    When "CONTROL"   : Gosub PTEORI_CONTROL
  Endcase
Return

$PTEORI_INIT
  this.PTEORI = 1
Return

$PTEORI_CONTROL
  #If this.ASTALIN = [V]CST_AUPD and this.PTESTA <> 1 Then # Issue X3-66487 - 2018-05-04 by SINGC
  If this.ASTALIN = [V]CST_AUPD Then                       # Issue X3-66487 - 2018-05-04 by SINGC
    If this.PTESTA > 1 Then                                # Issue X3-66487 - 2018-05-04 by SINGC
      If this.snapshot.PTEORI <> this.PTEORI Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTEORI", func AFNC.MES1(mess(339,2260,1), mess(this.PTESTA,2074,1)), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

###################################################################################################
$KEYCONCAT
  Case [L]ARULE
    When "GET"      : Gosub KEYCONCAT_GET
  Endcase
Return

$KEYCONCAT_GET
  #this.KEYCONCAT = this.CLB + "~" + this.OPPNUM + "~" + format$("YYYYMMDD",this.PTEDAT) + "~" + num$(this.PTESEQ) # Issue X3-69372 - 2018-04-18 by SINGC
  this.KEYCONCAT = this.CLB + "~" + num$(this.PTESEQ)                                                              # Issue X3-69372 - 2018-04-18 by SINGC
Return

###################################################################################################
# Linked to CDIE collection
###################################################################################################
$CDIE_CCE
  # Issue X3-66474 - 2018-02-02 by SINGC
  Case [L]ARULE
    When "CONTROL"   : Gosub CDIE_CCE_CONTROL
  Endcase
Return

$CDIE_CCE_CONTROL
Local Char SMESSAGE(250)
Local Char SCPY(GLONCPY)
Local Integer IRET

  # Issue X3-66474 - 2018-02-02 by SINGC
  [L]ASTATUS = [V]CST_AOK
  # -----------------------------
  SCPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.APARENT.FCY, "LEGCPY")
  IRET = func FINCCE_SYRA.CTL_CCE(this.ACTX, this.CCE, this.DIE, SCPY, [0/0/0], SMESSAGE)
  If IRET <> [V]CST_AOK Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.APARENT.SETERROR("CCE", SMESSAGE, IRET))
  Endif
  # -----------------------------
  # Issue X3-66487 - 2018-05-04 by SINGC : START
  If this.ASTALIN = [V]CST_AUPD Then
    If this.APARENT.PTESTA > 1 Then
      If this.CCE <> this.snapshot.CCE Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.APARENT.SETERROR("CCE", func AFNC.MES1(mess(339,2260,1), mess(this.APARENT.PTESTA,2074,1)), [V]CST_AERROR))
      Endif
    Endif
  Endif
  # Issue X3-66487 - 2018-05-04 by SINGC : END
Return

