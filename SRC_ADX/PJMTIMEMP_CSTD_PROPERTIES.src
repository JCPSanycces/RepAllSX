$PTEVAL_PROPAGATE
  If this.TCHACTION = AVOID.ACHAR Then # Issue X3-66487 - 2018-05-04 by SINGC
    If this.PTEVAL = [V]CST_ANO Then
      this.PTESTA = 1
    Else
      this.PTESTA = 2
    Endif
  Endif
Return

###################################################################################################
$PTESTA
  #When "INIT"      : Gosub PTESTA_INIT       # Issue X3-66487 - 2018-05-04 by SINGC
  Case [L]ARULE
    When "CONTROL"   : Gosub PTESTA_CONTROL
  Endcase
Return

# Issue X3-66487 - 2018-05-04 by SINGC : START
$PTESTA_CONTROL
  If this.TCHACTION = AVOID.ACHAR Then
    If this.ASTALIN = [V]CST_AUPD Then
      If this.PTESTA > 2 Then
        If this.snapshot.PTESTA <> this.PTESTA Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTESTA", func AFNC.MES1(mess(339,2260,1), mess(this.PTESTA,2074,1)), [V]CST_AERROR))
        Endif
      Endif
    Endif
  Elsif this.TCHACTION = "TIMENTVAL" Then
    If this.ASTALIN = [V]CST_AUPD Then
      If this.snapshot.PTESTA = 2 and this.PTESTA = 4 Then
        If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.FCY, "PJMTIMENT") = 1 Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PTESTA", func AFNC.MES1(mess(1075,2260,1), mess(3,2074,1)), [V]CST_AERROR))
        Endif
      Endif
    Endif
  Endif
Return

