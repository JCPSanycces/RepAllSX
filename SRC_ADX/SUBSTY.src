#  GMESSAGE = NATCOD-":"-mess(62,127,1)-":"-[F:NAT]LEG
#  mkstat=2 : End
# Endif
#Endif

If NATCOD<>""  #GCURLEG <>""
 Filter [F:NAT2]
 #ADNGO - 2016-11-28 - START
 #Read [F:NAT2]NAT0 = NATCOD
 Read [F:NAT2]NAT0 = GCURLEG;NATCOD
 #If [F:NAT2]LEG <> GCURLEG | [F:NAT2]LEG = ""
 If [F:NAT2]LEG <> GCURLEG
 #ADNGO - 2016-11-28 - END
