#############################
Subprog C_ENDTIM1(VALEUR)
Variable Char    VALEUR()

Call CTRL_TIM(VALEUR,[M]STRTIM0(nolign-1),[M]ENDTIM0(nolign-1),"1","2",[M]STRTIM1(nolign-1))
If mkstat : End : Endif
If GNBHOR>2
 Call CTRL_TIM(VALEUR,[M]STRTIM2(nolign-1),[M]ENDTIM2(nolign-1),"3","2",[M]STRTIM1(nolign-1))
 If mkstat : End : Endif
Endif
#62143
#SEGAY BUG 70862 20/01/10
#If VALEUR>=[M]STRTIM1(nolign-1) & [M]ENDTIM0(nolign-1)>=[M]STRTIM0(nolign-1)
#&                               & [M]STRTIM0(nolign-1)>[M]STRTIM1(nolign-1)
If VALEUR>[M]STRTIM1(nolign-1) & [M]ENDTIM0(nolign-1)>=[M]STRTIM0(nolign-1)
&                               & [M]STRTIM0(nolign-1)>[M]STRTIM1(nolign-1)
#END_BUG 70862
 GMESSAGE = mess(122,10709,1)-num$(2)-"<"-mess(122,10709,1)-num$(1)
 mkstat=2 : End
Endif
# fin 62143
End

