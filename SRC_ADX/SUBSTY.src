Subprog B1_STRTIM0(VALEUR)
Variable Char    VALEUR()
#If VALEUR<>""
 Local Integer ZONE
 Call APPLY_BEL_HR
 ZONE = 2
 Goto B1_NBR
#Endif

End # SEGAY 70862 20/01/10

