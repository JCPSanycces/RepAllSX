#############################
Subprog AS_NBRDAY1(VALEUR)
Variable Decimal VALEUR
#FQ78367 - FRRIC - 12/01/2012
#If [M]TYPDAY(nolign-1)=3 | [M]NBRHRS1(nolign-1)=0 : # Jour chômé ou nb heures=0
# mkstat = 1 : End
#Endif
If [M]TYPDAY(nolign-1)=3 | ([M]TYPDAY(nolign-1)=2 & [M]NBRHRS1(nolign-1)=0) :  # Jour chômé ou (ouvré et nb heures=0)
 mkstat = 1 : End
Endif
#END 78367
#62143
#If !VALEUR & [M]NBRHRS1(nolign-1)<>0 : VALEUR = 1 : Endif
If !VALEUR & [M]NBRHRS1(nolign-1)<>0
 If nolign-1>0
  VALEUR = [M:STY1]NBRDAY1(nolign-2)
 Else
  VALEUR = 1
 Endif
Endif
# fin 62143
End

#############################
Subprog C_NBRDAY1(VALEUR)
Variable Decimal VALEUR
If VALEUR>1
 # Le nombre de jours ne doit pas dépasser 1
 GMESSAGE = mess(110,10702,1)
 mkstat   = 2 : End
Endif
End

#############################
Subprog AS_NBRHRS1(VALEUR)
Variable Decimal VALEUR
If [M]TYPDAY(nolign-1)=3 : # Jour chômé
 mkstat = 1 : End
Endif
Gosub SUMHRS
#62143
#If !VALEUR
# VALEUR = SUMHRS
#Endif
If !VALEUR | [M]UPDHRS = 1
 VALEUR = SUMHRS
 Raz [M]UPDHRS
Endif
# fin 62143
End

#############################
Subprog C_NBRHRS1(VALEUR)
Variable Decimal VALEUR
Local Integer OK
Gosub SUMHRS
If VALEUR<>SUMHRS & SUMHRS
   #FQ78367 - FRRIC - 12/01/2012
   #Permet de saisir un nombre d'heures à zéro et jour = 1
   If [M]TYPDAY(nolign-1)<>1 : # <> Jour ouvrable
      # Nombre d'heures incorrect
      Call AVERTIR(mess(117,10709,1),OK) From GESECRAN
      OK = 1
   Endif
   #END 78367
   If OK=1
      mkstat = 2 : End
   Endif
Endif
End

#############################
$SUMHRS
Local Decimal SUMHRS, VALHMDEB, VALHMFIN

If GNBHOR>0
 Call CONVERTHM([M:STY1]STRTIM0(nolign-1),VALHMDEB)
 Call CONVERTHM([M:STY1]ENDTIM0(nolign-1),VALHMFIN)

 If VALHMDEB<=VALHMFIN
  SUMHRS = VALHMFIN-VALHMDEB
 Else
  SUMHRS = 24-VALHMDEB+VALHMFIN
 Endif
 #62143
 #If dim([F:STY1]BRKTIM0)>0 : SUMHRS -= [M:STY1]BRKTIM0(nolign-1) : Endif
 SUMHRS -= [M:STY1]BRKTIM0(nolign-1)
 If GNBHOR>1

  Call CONVERTHM([M:STY1]STRTIM1(nolign-1),VALHMDEB)
  Call CONVERTHM([M:STY1]ENDTIM1(nolign-1),VALHMFIN)

  If VALHMDEB<=VALHMFIN
   SUMHRS += VALHMFIN-VALHMDEB
  Else
   SUMHRS += 24-VALHMDEB+VALHMFIN
  Endif
  #62143
  #If dim([F:STY1]BRKTIM1)>0 : SUMHRS -= [M:STY1]BRKTIM1(nolign-1) : Endif
  SUMHRS -= [M:STY1]BRKTIM1(nolign-1)
  If GNBHOR>2
   Call CONVERTHM([M:STY1]STRTIM2(nolign-1),VALHMDEB)
   Call CONVERTHM([M:STY1]ENDTIM2(nolign-1),VALHMFIN)

   If VALHMDEB<=VALHMFIN
    SUMHRS += VALHMFIN-VALHMDEB
   Else
    SUMHRS += 24-VALHMDEB+VALHMFIN
   Endif
   #62143
   #If dim([F:STY1]BRKTIM2)>0 : SUMHRS -= [M:STY1]BRKTIM2(nolign-1) : Endif
   SUMHRS -= [M:STY1]BRKTIM2(nolign-1)
  Endif
 Endif
Endif
SUMHRS = ar2(SUMHRS)
Return

#############################
Subprog CTRL_TIM(VALEUR,DEBTIM,FINTIM,I,J,STRTIM)
Variable Char    VALEUR
Value    Char    DEBTIM, FINTIM, STRTIM
#61591: Ajout de J
Value    Char    I, J  # I=numéro plage J:1=heure début 2=heure fin

Local Decimal VDEBTIM, VFINTIM, VSTRTIM

If VALEUR="" : End : Endif

VDEBTIM = val(DEBTIM)
VFINTIM = val(FINTIM)
VSTRTIM = val(STRTIM) : #62144

If (VDEBTIM<=VFINTIM & val(VALEUR)>VDEBTIM & val(VALEUR)<VFINTIM)
&| (VDEBTIM>VFINTIM & (val(VALEUR)>VDEBTIM | val(VALEUR)<VFINTIM))
 GMESSAGE = mess(126,10709,1)-I : # Infos déjà saisie pour cette date dans la plage X
 mkstat = 2 : End
Endif
#61591
If (J="1" & VDEBTIM=val(VALEUR) & DEBTIM<>"") | (J="2" & VFINTIM=val(VALEUR) & FINTIM<>"")
 GMESSAGE = mess(126,10709,1)-I : # Infos déjà saisie pour cette date dans la plage X
 mkstat = 2 : End
Endif
# fin 61591
#62144
# En contrôle de l'heure de fin, pour que la plage (9h13h) n'englobe pas une autre plage (10h12h)
If J="2" & val(VALEUR)>VSTRTIM & VFINTIM>VDEBTIM & val(VALEUR)>VFINTIM & VSTRTIM<VDEBTIM
 GMESSAGE = mess(126,10709,1)-I : # Infos déjà saisie pour cette date dans la plage X
 mkstat = 2 : End
Endif
# fin 62144
End

#############################
$C_BRKTIM
If (VALHMFIN>=VALHMDEB & VALEUR>VALHMFIN-VALHMDEB)|(VALHMFIN<VALHMDEB & VALEUR>=24-VALHMDEB+VALHMFIN)
 # Temps de pause incorrect
 GMESSAGE = mess(115,10709,1)
 mkstat = 2 : Return
Endif
Return

#############################
$B1_NBR
NOL = nolign-1
For I=NOL To [M:STY1]NBRDAY-1
 If [M:STY1]TYPDAY(I)<3 & ([M:STY1]NBRDAY1(I)>0 | [M:STY1]NBRHRS1(I)>0)
  Case ZONE
   When 1  : [M:STY1]NATCOD0(I) = VALEUR
   When 2  : Call CONTHM(VALEUR)From OBJDIV
             [M:STY1]STRTIM0(I) = VALEUR
   When 3  : Call CONTHM(VALEUR)From OBJDIV
             [M:STY1]ENDTIM0(I) = VALEUR
   When 4  : [M:STY1]BRKTIM0(I) = VALEUR
   When 5  : [M:STY1]NATCOD1(I) = VALEUR
   When 6  : Call CONTHM(VALEUR)From OBJDIV
             [M:STY1]STRTIM1(I) = VALEUR
   When 7  : Call CONTHM(VALEUR)From OBJDIV
             [M:STY1]ENDTIM1(I) = VALEUR
   When 8  : [M:STY1]BRKTIM1(I) = VALEUR
   When 9  : [M:STY1]NATCOD2(I) = VALEUR
   When 10 : Call CONTHM(VALEUR)From OBJDIV
             [M:STY1]STRTIM2(I) = VALEUR
   When 11 : Call CONTHM(VALEUR)From OBJDIV
             [M:STY1]ENDTIM2(I) = VALEUR
   When 12 : [M:STY1]BRKTIM2(I) = VALEUR
  Endcase
 Endif
Next
Affzo [M:STY1]
End

#############################
Subprog CONVERTHM(VALEUR,NBHEURE)
Value Char VALEUR ()
Variable Decimal NBHEURE
Local Integer HH, MM
Call CONTHM(VALEUR) From OBJDIV
HH = val(left$(VALEUR,2))
MM = val(right$(VALEUR,3))
NBHEURE = ((HH*60)+MM)/60
End

