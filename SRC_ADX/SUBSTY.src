##################################################
#LIPET - 2016-11-04 - START
Subprog CONTSTY(COD)
Variable Char    COD()

  If GFONCTION = "GESSTY" | COD="" : End : Endif

  If clalev([F:WTY])=0 : Local File TYPWEEK [WTY] : Endif

  If COD <> ""
    Filter [F:WTY] Where COD=[L]COD
    Read [F:WTY] First
    Filter [F:WTY]
    If fstat
        GMESSAGE = COD-":"-mess(23,100,1)
        mkstat = 2 : End
    Else
        Filter [F:WTY]
        Read [F:WTY]WTY0 = GCURLEG;[L]COD
        If fstat
        Filter [F:WTY] Where COD=[L]COD
          Read [F:WTY] First
          If [F:WTY]LEG<>""
            GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:WTY]LEG
            mkstat = 2 : End
          Endif
        Endif
    Endif
  Endif
  Filter [F:WTY]
End



##################################################
Subprog TUNSTY(COD)
Variable Char    COD()
Local Integer TOKILL

  TOKILL = 0
  If dim(VCOD)<1
   Global Char VCOD(GLONSTY)
   TOKILL = 1
  Endif

  If clalev([F:WTY])=0 : Local File TYPWEEK [WTY] : Endif

  VCOD = COD
  Call OBJET("STY",VCOD,GCURLEG) From GOBJET
  COD = VCOD
  If TOKILL : Kill VCOD : Endif
End
#LIPET - 2016-11-04 - END

