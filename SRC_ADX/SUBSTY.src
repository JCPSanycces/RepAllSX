Subprog CHECKLEG(NATCOD)
Variable Char NATCOD

If clalev ([F:NAT2])=0 : Local File NATACTIV [NAT2] : Endif

#If NATCOD<>"" & [M:STY1]LEG <>""
# Filter [F:NAT]
