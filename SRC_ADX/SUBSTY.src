#<AdxTL>@(#)0.0.0.0 $Revision$
## Gestion des semaines types
######################################################################################
# Modifications :
#     SEGAY - 20/01/11 - BUG 70862
#              - Suppression d'une plage > 1 impossible si plage 1 renseignée
##################################################################################

Raz GPILOBJ
GFIRDAY=1
Call OBJET("STY",GBIDC1,GBIDC2) From GOBJET
End
#############################
$FERME
 If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
 #LIPET 10-11-2016 - START
 If TUNNEL<>1 : Return : Endif
 If dim(VCOD)<1 : Global Char VCOD(GLONSTY) : Endif
 VCOD = CLE1
 #LIPET 10-11-2016 - END
Return
#############################
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "RAZCRE"   : Gosub RAZCRE
 When "LIENS"    : Gosub LIENS
 When "OUVRE_BOITE" : Gosub LIENS : #64676
 When "FERME"     : Gosub FERME
 When "SEL_TABLE" : Gosub SEL_TABLE
#MIPEA - 2018-01-19- US X3-71867- START
 When "CREATION"  : Gosub CREATION
#MIPEA - 2018-01-19- US X3-71867- END
Endcase
Return

#############################
$OUVRE
If clalev([F:WTY])=0 : Local File TYPWEEK   [WTY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV     [ACV] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

#############################
#MIPEA - 2018-01-19- US X3-71867- START
$CREATION
If [M:STY1]COD="" Then
   GERR  = 1
   GMESSAGE = mess(10,123,1)
   zonsui = "[M:STY1]COD" #Put the focus on the field.
   FIN = 0 # Instruct the supervisor to keep the window open
   GOK = 0
   Return
Endif
Return
#MIPEA - 2018-01-19- US X3-71867- END
#############################
$RAZCRE
#MIPEA - 2017-11-30- US X3-63170- START
If GREP = "C"
  Local Char TEMPGFIRDAY(1)
#MIPEA - 2018-01-17- US X3-67274- START
  Call PARAM("", "FIRDAY", TEMPGFIRDAY) From ADOVAL
#  Call PARAM(GCURLEG, "FIRDAY", TEMPGFIRDAY) From ADOVAL
#MIPEA - 2018-01-17- US X3-67274- END
  GFIRDAY = val(TEMPGFIRDAY)
  [M:STY1]FIRDAY = GFIRDAY
  Affzo [M:STY1]FIRDAY
Endif
#MIPEA - 2017-11-30- US X3-63170- END
  GCURLEG = ""
  Gosub LIENS
  Affzo 20
Return

#############################
$LIENS
#JASMI - 2017-12-06 - X3-67453 - START
##MIPEA - 2017-11-23- US X3-63170- START
#If [M:STY1]FIRDAY>0 & GREP<>"C" & GREP<>"D"
#  GFIRDAY = [M:STY1]FIRDAY
#  Affzo [M:STY1]FIRDAY : Grizo [M:STY1]FIRDAY
#Endif
##MIPEA - 2017-11-23- US X3-63170- END
If GFIRDAY>7
  GFIRDAY-=7
Else
  If [F:WTY]FIRDAY>0
    Grizo [M:STY1]FIRDAY
    GFIRDAY=[F:WTY]FIRDAY
  Else
    Actzo [M:STY1]FIRDAY
    Local Char TEMPGFIRDAY(1)
#MIPEA - 2018-01-17- US X3-67274- START
    Call PARAM("", "FIRDAY", TEMPGFIRDAY) From ADOVAL
#    Call PARAM(GCURLEG, "FIRDAY", TEMPGFIRDAY) From ADOVAL
#MIPEA - 2018-01-17- US X3-67274- END
    GFIRDAY = val(TEMPGFIRDAY)
  Endif
Endif
#JASMI - 2017-12-06 - X3-67453 - END
Gosub SETDAY
For I=0 To 2
 [M]FRMTIM(I)="-Kz:##[:]##"
 [M]FRMBRK(I)="-Nz+:2.2#"
 If I<2 : [M]FRMNAT(I)="-Kz:5X" : Endif
Next
If GNBHOR>0
 [M]FRMTIM(0)="Kz:##[:]##"
 [M]FRMBRK(0)="Nz+:2.2#"
 If GNBHOR>1
  [M]FRMTIM(1)="Kz:##[:]##"
  [M]FRMBRK(1)="Nz+:2.2#"
  #62143
  #[M]FRMNAT(0)="Kz:5X"
  [M]FRMNAT(0)="K:5B"
  If GNBHOR>2
   [M]FRMTIM(2)="Kz:##[:]##"
   [M]FRMBRK(2)="Nz+:2.2#"
   #62143
   #[M]FRMNAT(1)="Kz:5X"
   [M]FRMNAT(1)="K:5B"
  Endif
 Endif
Endif

GCURLEG = [M:STY1]LEG

Return

#############################
$SEL_TABLE
Case TABLE
  When "SELSTY"
    If clalev([F:WTY])=0 : Local File TYPWEEK [WTY] : Endif

     OBJET="STY"
    START="[F:WTY]COD"
  #Filter based on code legislation

    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:WTY]LEG="'+GCURLEG+'" | [F:WTY]LEG="")',"&") From GOBJSUB

#JASMI - 2016-11-03 - END
  Endcase

Return

$SETDAY
[M]NBRDAY = 7
For I=1 To 7
 [M]DAY1(I-1) = day$(mod(GFIRDAY+I-1,7))
 If [M]TYPDAY(I-1)=0
  Case mod(GFIRDAY+I-1,7)
   When 6       : [M]TYPDAY(I-1) = 1
   When 0       : [M]TYPDAY(I-1) = 3
   When Default : [M]TYPDAY(I-1) = 2
  Endcase
 Endif
Next I
Return

######################################################################################
## Etiquettes Ecran STY1
######################################################################################
Subprog AS_STRTIM0(VALEUR)
Variable Char    VALEUR()
If [M]TYPDAY(nolign-1)=3 : # Jour chômé
 mkstat = 1 : End
Endif
If VALEUR="" & nolign-1>0
 VALEUR = [M:STY1]STRTIM0(nolign-2)
Endif
End

#############################
Subprog C_STRTIM0(VALEUR)
Variable Char    VALEUR()
If GNBHOR>1
 Call CTRL_TIM(VALEUR,[M]STRTIM1(nolign-1),[M]ENDTIM1(nolign-1),"2","1","")
 If mkstat : End : Endif
Endif
If GNBHOR>2
 Call CTRL_TIM(VALEUR,[M]STRTIM2(nolign-1),[M]ENDTIM2(nolign-1),"3","1","")
 If mkstat : End : Endif
Endif
End

