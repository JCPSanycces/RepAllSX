#<AdxTL>@(#)7.0.0.0 $Revision$
########################################################################################################################
#
# INTERFACE COMPTABLE ABELX3 : Traitement principal
# ==========================
#
#
# TRTCPTINT            Traitement principal
# TRTCPTINT1           Sous-programme de génération de pièce comptable
# TRTCPTINT2           Gestion de la trace
# TRTCPTINT3           Utilitaires et gestion du fichier log technique
# TRTCPTINT4           Outil de gestion de la comptabilisation provisoire
# TRTCPTINT9           Alimentation de la table temporaire
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Liste des sous-programmes :
# -------------------------
#
# COMPTA_DIRECTE(PCPY, PFCY, PREF, PLIN, PACTION, CDRET)
#
# AM_CPY(VALEUR)
# AS_FIY(VALEUR)
#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $ACTION
# $INIT
# $OUVRE
# $DEBUT
# $CONTROLE
# $EXEC
# $TERMINE
# $TRT_UN_SITE
# $TRT_TPE
#
########################################################################################################################
# Modifications :
# -------------
#
# MDJ - 18.08.2016  118072    Comptabilisation directe et alimentation type de pièce
# CBO - 06.07.2015  FQ109364  erreur sur TPE non ouvert en AM_TPE
# CBO - 23.10.2013  FQ 93731  ajout d'1 fct de contrôle des contextes
# MDJ - 07.08.2013  FQ 91253  Anomalie d'affichage du paramètre "Détail analytique"
# MDJ - 17.07.2013  FQ 91142  Table 952 "en dur" dans les traitements au lieu de 962 (GTD_EVENT)
# GLE - 17.06.2013  FQ 90388  Ajout d'un lock sur la société
# MDJ   14.11.2012  Fq 85066  Simplified setup for FA posting types (new table TYPACELEG)
# CBO - 12.03.2012  FQ 80246  GFMDAT4 au lieu de DD[/]MM[/]YYYY
# CBO - 2012.03.08  FQ 80212  find d'1 tableau trop grand dans un filter
# CBO - 2012.02.23  FQ 79814  pb affichage message écran
# GBO - 25.02.2011  FQ 70465  Cohérence exercices/périodes avec CPTA (certification NC25)
# GBO - 10.12.2010  FQ 69824  Interface comptable multi référentiel
# GBO - 28.07.2010  FQ 66210  Code activité CCN à non : on ne doit pas pouvoir utiliser les types d'écritures basés sur CCNRPR
# GBO - 05.07.2010  FQ 65873  Utilisation des globales GML_MSGxxx
# GBO - 05.05.2010  FQ 64544  Comptabilisation des écarts entre plans
# GBO - 13.01.2010  Fq 54343  Gestion des concessions
# GLE - 16.11.2009  FQ 59900  Gestion des codes activités dans la table diverse des tables d'événements 952
# GBO - 24.02.2010  FQ 62622  Ecritures : non suppression des pièces de simulation
# GBO - 16.11.2009  Fq 59875  Site erroné dans la trace et en sélection.
# GBO - 24.09.2009  Fq 56791  Problème de traduction des noms de champs dans le tableau tri / regroupement
# GBO - 06.07.2009  Fq 56159  Comptabilisation immédiate et date comptable
# GBO - 29.05.2009  Fq 55519  Pertes des paramètres de l'interface comptable en batch (abonnement ou lancement de requête)
# GBO - 07.05.2009  Fq 54522  Boutons Tous et Aucun sur la colonne de sélection des sites de la société.
# GBO - 21.04.2009  Fq 54597  On ne doit afficher que la liste des sites financiers de la société choisie
#
########################################################################################################################
 Local Char VALBOUT(30)
 Local Char PARBOUT(250)(1..10)
 Call TRAITE_CHAR(VALBOUT,PARBOUT,"","TRTCPTINT","TRTCPTINT",4,"") From GTRAITE
End

#============================================================================
$ACTION
 #Call ECR_TRACE(ACTION,0) From GESECRAN
 Case ACTION
  When "INIT"        : Gosub INIT
  When "AVANT_PAR"   : Gosub AVANT_PAR
  When "OUVRE_BATCH" : Gosub OUVRE_BATCH
  When "DEBUT"       : Gosub DEBUT
  When "CONT_BATCH"  : Gosub CONTROLE
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "END"         : ABANDON=G_OUI
  When "TERMINE"     : Gosub TERMINE
  When Default
 Endcase
Return

#============================================================================
$INIT
 If !clalev([F:ACM])  : Local File APLCOM     [ACM]  : Endif
 If !clalev([F:TPE])  : Local File TYPACE     [TPE]  : Endif
 If !clalev([F:TPL])  : Local File TYPACELEG  [TPL]  : Endif  #*Fq-85066
 If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
 If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
 If !clalev([F:CNX])  : Local File CONTEXT    [CNX]  : Endif
 If !clalev([F:FSY])  : Local File FISCYEAR   [FSY]  : Endif
 If !clalev([F:LCA])  : Local File LNKCPTABX3 [LCA]  : Endif
 If !clalev([F:LCD])  : Local File LNKCPTABD  [LCD]  : Endif
 If !clalev([M:TPE])  : Local Mask TYPACE     [TPE]  : Endif
 If !clalev([M:DIA])  : Local Mask TRTCPTINT  [DIA]  : Endif
 If !clalev([M:FPC])  : Local Mask FASPARCPY  [FPC]  : Endif

 Global Integer GNUMTRT
 Global Integer GABNUMPCE
 Global Integer GTECTRC
 Global Integer ALL_LEG #Fq-85066

 If dim(PARAM)<0 : Local Char PARAM : Endif

 If GNUMTRT=0
  Trbegin [ACM]
  [C]TRTACTMET+=1 : GNUMTRT=[C]TRTACTMET
  Commit
 Endif

 GTECTRC = G_NON

 If GTABCPT<>""
  Gosub CREEX3VAR # Création des variables nécessaire à la suppression des pièces provisoires dans X3.
 Endif

 If !(dim([M:DIA]FLGSIM)<0)
   [M:DIA]FLGSIM=G_OUI : Affzo [M:DIA]FLGSIM
   [M:DIA]FLGDETANA=G_OUI
 Endif

 If dim(ABANDON)<0 : Global Integer   ABANDON : Endif

Return

#============================================================================
$AVANT_PAR
 If dim(ABANDON)<0 : Global Integer   ABANDON : Endif
Return

#============================================================================
$OUVRE_BATCH
 If dim(ABANDON)<0 : Global Integer   ABANDON : Endif
Return

#============================================================================
$DEBUT

 If !GBATCH
   Raz [M:DIA]
   If dim([M:TPE0]CPY)>0
    [M:DIA]FIY=GVML_TECOURA
    If [M:TPE0]CPY<>""
     [M:DIA]CPY=[M:TPE0]CPY
     Grizo [M:DIA]CPY
     Affzo [M:DIA]CPY
    Else
     Actzo [M:DIA]CPY
    Endif
    If [M:DIA]CPY<>"" : Call AM_CPY([M:DIA]CPY) : Endif
    [M:DIA]TPE(0) = [M:TPE0]ACETYP
    [M:DIA]ZTPE(0)= [M:TPE0]DESTRA
    [M:DIA]NBTPE  = 1
    Grizo [M:DIA]20
    Affzo [M:DIA]20
   Endif
   Affzo [M:DIA]FLGDETANA
 Endif

Return

#============================================================================
$CONT_BATCH
Return

#============================================================================
$CONTROLE

 If ABANDON = G_OUI : Return : Endif

 Local Integer WCNXERR # FQ93731
 Local Char WSOCERR(30), WMESS(250) # FQ93731

#FQ 70465
 #> La société ne doit pas être désynchronisée avec la comptabilité.

 If func GLOBIENS.IS_DESYNC_CNX([M:DIA]CPY, 0)=G_OUI
  SAI      = 1
  GMESSAGE = func GLOFUNC.SUBSTIT1(mess(272,GML_MSGFASPR,1), [M:DIA]CPY) #"Société"-[M:DIA]CPY-":"-"Au moins un contexte est désynchronisé avec la comptabilité."
  GERR     = 1
  Return
 Endif

 #> Au moins un site doit être sélectionné

 If !find(G_OUI,[M:DIA]FLGFCY)
  SAI      = 1
  GMESSAGE = mess(76,GML_MSGCPT,1) #"Au moins un site doit être sélectionné"
  GERR     = 1
  Return
 Endif

 #> Au moins un type d'écriture doit être renseigné

 If ![M:DIA]NBTPE
  SAI      = 1
  GMESSAGE = mess(77,GML_MSGCPT,1) #"Au moins un type d'écriture doit être sélectionné"
  GERR     = 1
  Return
 Endif

 #> Au moins une période doit être ouverte sur l'exercice suivant

 If (!GSERVEUR & !GBATCH) | GSERVEUR
  If [M:DIA]FIY=GVML_TESUIV
   GERR = 1
   If !clalev([F:FSY]) : Local File FISCYEAR [F:FSY] : Endif
   Filter [F:FSY] Where CPY=[M:DIA]CPY & STAFIY=[M:DIA]FIY
   For [F:FSY]
    If find(GVML_SPOUVER,[F:FSY]STAPER)
     GERR=0
     Break
    Endif
   Next
   Filter [F:FSY]
   If GERR = 1
    SAI =1
    GMESSAGE = mess(78,GML_MSGCPT,1)-[M:DIA]CPY  #"Aucune période ouverte sur l'exercice suivant pour la société"
    Return
   Endif
  Endif


  # FQ93731
  If  func SUBCNX2.CTRL_CNX ([M:DIA]CPY, 0, 0, WSOCERR, WCNXERR, WMESS) > 0
    GERR = 1
    SAI = 1
    GMESSAGE =  mess(90, 7770, 1)  -mess(WCNXERR, 3100, 1) - ":" - WMESS
    Return
  Endif

 Endif

Return

#============================================================================
$EXEC
  If ABANDON = G_OUI : Return : Endif
  Local Integer LCNX
  If !GSERVEUR : Call OUVRE_TRACE (mess(1,GML_MSGCPT,1)) From LECFIC : Endif   # "Interface comptable"
  # MHB 01/07/08 : on passe par une variable temporaire, car il peut arriver que des écrans d'abréviation DIA n'aient
  # pas le champ FLGSIM
  If dim([M:DIA]FLGSIM)>0 Then
    TEMP=[M:DIA]FLGSIM
  Else
    TEMP=G_NON
  Endif

  # FQ90388 Lock de la société et point d'entrée pour l'inhiber
  Local Shortint LOCK_OK : LOCK_OK = G_NON
  #CHECK IGNORE_BEGIN
  # Pour inhiber le lock il faut positionner LOCK_OK à G_OUI dans le point d'entrée SOCLCKCPT. Dans ce cas c'est au client
  # de gérer les conflits de sélection qui risquent d'entrainer des erreurs de comptabilisation
  GPOINT = "SOCLCKCPT"
  Gosub ENTREE From EXEFNC
  #CHECK IGNORE_END
  If LOCK_OK = G_NON
    # Le lock société n'a pas été inhibé par le point d'entrée. On va essayer de locker les contextes et les biens
    # de la société à traiter.
    LOCK_OK = G_OUI
    If func GLOBIENS.LOCK_SYMBOLE ("CNX", [M:DIA]CPY, "", 0) = 0 Then
      LOCK_OK = G_NON
    Elsif func GLOBIENS.LOCK_SYMBOLE ("FAS", [M:DIA]CPY, "", 0) = 0 Then
      LOCK_OK = G_NON
    Endif
  Endif

  If LOCK_OK = G_OUI : # FQ90388
    Call LOAD_FASPARCPY([M:DIA]CPY,"FPC",G_NON,GOK) From GLOFCYCPY
    # If !GSERVEUR : Call OUVRE_VLC(mess(1,GML_MSGCPT,1)-mess(22,GML_MSGCPT,1)-[M:DIA]CPY-string$([M:DIA]FLGSIM=G_OUI,mess(19,GML_MSGCPT,1)),
    If !GSERVEUR : Call OUVRE_VLC(mess(1,GML_MSGCPT,1)-mess(22,GML_MSGCPT,1)-[M:DIA]CPY-string$(TEMP=G_OUI,mess(19,GML_MSGCPT,1)),
&                                 mess(24,GML_MSGCPT,1)-"/"-mess(31,GML_MSGCPT,1),
&                                 mess(11,GML_MSGCPT,1)) From GESECRAN : Endif
    Read [F:CPY]CPY0=[M:DIA]CPY
    Gosub TRC_PARAMETRES From TRTCPTINT2
    For I_FCY=1 To [M:DIA]NBFCY
     If [M:DIA]FLGFCY(I_FCY-1)=G_OUI
      Read [F:FCY]FCY0=[M:DIA]FCY(I_FCY-1)
      If !fstat
       Gosub TRT_UN_SITE
      Else
       LIGNE = "TRTCPTINT-$EXEC-Read [F:FCY]"-[M:DIA]FCY(I_FCY-1)-num$(fstat)
       Call ECR_TRACE(LIGNE,1) From GESECRAN
       Goto NEXT_FCY
      Endif
     Endif
    $NEXT_FCY
    Next I_FCY
  Endif

  # FQ90388 Délockage société
  Call UNLOCK_SYMBOLE ("CNX", [M:DIA]CPY, "") From GLOBIENS
  Call UNLOCK_SYMBOLE ("FAS", [M:DIA]CPY, "") From GLOBIENS

  Call ECR_TRACE("\"+mess(44,126,1)-format$("D:" + GFMDAT4,date$)-func TRTEVTLIST.TIME_NUM_TO_STRING(time),0) From GESECRAN
  If !GSERVEUR : Call FERME_VLC From GESECRAN : Endif
  If !GSERVEUR : Call LEC_TRACE() From LECFIC : Endif
Return

#============================================================================
$TERMINE
 # MHB 01/07/08 : on passe par une variable temporaire, car il peut arriver que des écrans d'abréviation DIA n'aient
 # pas le champ FLGSIM
 If dim([M:DIA]FLGSIM)>0 Then
   TEMP=[M:DIA]FLGSIM
 Else
   TEMP=G_NON
 Endif
 If GTECTRC = G_OUI
  Openo Using [XLOG]
 Endif
 If dim(GNUMTRT)>0    : Kill GNUMTRT    : Endif
 If dim(GABNUMPCE)>0  : Kill GABNUMPCE  : Endif
 If dim(ABANDON)>0    : Kill ABANDON    : Endif
 If dim(GTECTRC)>0    : Kill GTECTRC    : Endif
 If dim(GFICTECTRC)>0 : Kill GFICTECTRC : Endif
 If dim(ALL_LEG)>0    : Kill ALL_LEG    : Endif  #Fq-85066
Return

######################################################################################
# Appelé dans $TERMINE pour émission des états
$ETAT

 If [M:DIA]FLGETA=2

  Local Integer NBPAR_MAX : NBPAR_MAX=11
  Local Char TBPAR(20)(1..NBPAR_MAX)
  Local Char TBVAL(250)(1..NBPAR_MAX)

  Raz TBPAR
  Raz TBVAL

  TBPAR(1) ="cpydeb"   : TBVAL(1)  = ""
  TBPAR(2) ="cpyfin"   : TBVAL(2)  = ""
  TBPAR(3) ="fcydeb"   : TBVAL(3)  = ""
  TBPAR(4) ="fcyfin"   : TBVAL(4)  = ""
  TBPAR(5) ="datdeb"   : TBVAL(5)  = ""
  TBPAR(6) ="datfin"   : TBVAL(6)  = ""
  TBPAR(7) ="joudeb"   : TBVAL(7)  = ""
  TBPAR(8) ="joufin"   : TBVAL(8)  = ""
  TBPAR(9) ="stotal"   : TBVAL(9)  = "Oui"
  TBPAR(10)="numtrt"   : TBVAL(10) = num$(GNUMTRT)
  TBPAR(11)="exe"      : TBVAL(11) = num$([M:DIA]FIY)

  If GTABCPT=""
   Call ETATN("JOUGENSOC","EVECPT",TBPAR,TBVAL) From ETAT
   If GIAS
    Call ETATN("JOUGENGRP","EVECPT",TBPAR,TBVAL) From ETAT
   Endif
  Endif

 Endif

Return

######################################################################################
$TRT_UN_SITE

 Local Char    LTPE
 Local Char    LLEG, WLEG #Fq-85066
 Local Char    LCPY, WCPY
 Local Char    LFCY
 Local Integer LFIY

 LFIY=[M:DIA]FIY
 LCPY=[M:DIA]CPY
 Read[CPY]CPY0= LCPY #Fq-85066
 LLEG = [F:CPY]LEG   #Fq-85066 Législation de la société
 LFCY=[M:DIA]FCY(I_FCY-1)
 Local Mask TRTCPTINT1 [M:TC1P] : Raz [M:TC1P]             # Masque pour les totaux par compte pour une période
 Local Mask TRTCPTINT1 [M:TC2P] : Raz [M:TC2P]             # Masque pour les totaux par compte pour une site (ttes périodes)
 [M:TC2P]CPY    = LCPY
 [M:TC2P]FCY    = [M:DIA]FCY(I_FCY-1)
 [M:TC2P]TYPTOT = 2
 [M:TC2P]STAFIY = LFIY
 For I_TPE=1 To [M:DIA]NBTPE
  LTPE = [M:DIA]TPE(I_TPE-1)
  WLEG = [M:DIA]LEGTPE(I_TPE-1)  #Fq-85066 législation de l'entête type d'écriture
  WCPY = [M:DIA]CPYTPE(I_TPE-1)  #Fq-85066 société de l'entête type d'écriture
  #*Fq-85066 Read [F:TPE]TPE0=LTPE
  Read [F:TPE]TPE0=LTPE;WLEG;WCPY
  If fstat
     Read [F:TPE]TPE0=LTPE;WLEG;""
     If fstat
        Read [F:TPE]TPE0=LTPE;"";""
     Endif
  Endif
  Gosub TRCTEC_OUVRE From TRTCPTINT5
  #FQ54343
  If [F:TPE]DPRPLN=0 | [F:TPE]DPRPLN=G301AUC
   LCNX=G300CPFI
  Else
  Call GET_CNX_FROM_PLAN (LCPY, [F:TPE]DPRPLN, LCNX) From GLOBIENS
  Endif
  If LCNX<>-1
   Read [F:CNX]CNX0=LCPY;LCNX
   If fstat
    LIGNE = "TRTCPTINT-$TRT_UN_SITE-Read [F:CNX]"-LCPY+num$(LCNX)-num$(fstat)
    Call ECR_TRACE(LIGNE,1) From GESECRAN
    Goto $NEXT_TPE
   Endif
   Read [F:FSY]FIY1=LCPY;LCNX;LFIY
   If fstat
    LIGNE = "TRTCPTINT-$TRT_UN_SITE-Read [F:FSY]"-LCPY+num$(LCNX)-num$(LFIY)-num$(fstat)
    Call ECR_TRACE(LIGNE,1) From GESECRAN
    Goto $NEXT_TPE
   Endif
   [M:TPE]=[F:TPE]
   Read [TPL]TPL0=LTPE; [F:TPE]LEG;[F:TPE]CPY;LLEG
   If fstat=0
      [M:TPE]GTE     =  [F:TPL]GTE
      [M:TPE]GTEPRO  =  [F:TPL]GTEPRO
      [M:TPE]JOU     =  [F:TPL]JOU
      [M:TPE]JOUPRO  =  [F:TPL]JOUPRO
   Endif
   #FQ56791-Alimentation de SORTFLDDES
   #> Chargement des intitulés des champs du tableau tri/regroupement
   Local Integer I
   For I=1 To [M:TPE]NBCRIT
    [M:TPE]SORTFLDDES(I-1)=func SUBTPE.GET_FLD_DES([M:TPE]SORTFLDTAB(I-1),[M:TPE]SORTFLD(I-1))
   Next I
   Gosub TRT_TPE
  Endif
 $NEXT_TPE
 Next I_TPE

 #Fq69824
 #Gosub TRC_TOT_GAC_FCY From TRTCPTINT2
 Gosub TRC_LINE From TRTCPTINT2

Return

######################################################################################
$TRT_TPE
 Local  Integer RETOUR
 Local  Char    MSGRETOUR(80)(1..10)
 Local  Integer I_PER


 Gosub TRCTEC_DEBTPE From TRTCPTINT5
 Gosub TRC_TPE From TRTCPTINT2
 # Contrôle module actif
 If [F:TPE]SRCTYP=GVML_SRCEVT
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  #*Fq-91142 Read [F:ADI]CODE=952;[F:TPE]EVTTYP
  Read [F:ADI]CODE=GTD_EVENT;[F:TPE]EVTTYP
  # FQ59900
  #If ([F:ADI]N2=GVML_OMSUBV & G_ACTGRT<>G_OUI)
  # Local Integer I_MES : I_MES=115 : Gosub TRC_TPE_MODULE_DISABLE From TRTCPTINT2 : Goto $FIN_TRT_TPE
  #Endif
  #If ([F:ADI]N2=GVML_OMLOCFI & G_ACTLEA<>G_OUI)
  # Local Integer I_MES : I_MES=116 : Gosub TRC_TPE_MODULE_DISABLE From TRTCPTINT2 : Goto $FIN_TRT_TPE
  #Endif
  If !find([F:ADI]A2,GTABEVT)
   Local Integer I_MES
   Case [F:ADI]N2
     When GVML_OMSUBV  : I_MES=115
     When GVML_OMLOCFI : I_MES=116
     When Default      : I_MES=115 : # A COMPLETER
   Endcase
   Gosub TRC_TPE_MODULE_DISABLE From TRTCPTINT2 : Goto $FIN_TRT_TPE
  Endif
 Endif

 For I_PER=1 To [F:FSY]NBRPER
  Raz [M:TC1P]
  If    ([M:TPE]PERCLOFLG=G_OUI & [F:FSY]STAPER(I_PER-1)=GVML_SPCLOSE) |
&       ([M:TPE]PERCOUFLG=G_OUI & [F:FSY]STAPER(I_PER-1)=GVML_SPCOURA) |
&       ([M:TPE]PEROPEFLG=G_OUI & [F:FSY]STAPER(I_PER-1)=GVML_SPOUVER)
   [M:TC1P]CPY       = LCPY
   [M:TC1P]FCY       = [M:DIA]FCY(I_FCY-1)
   [M:TC1P]TYPTOT    = 1
   [M:TC1P]STAFIY    = LFIY
   [M:TC1P]PERSTRDAT = [F:FSY]DATSTRPER(I_PER-1)
   [M:TC1P]PERENDDAT = [F:FSY]DATENDPER(I_PER-1)
   [M:TC1P]STAPER    = [F:FSY]STAPER(I_PER-1)
   #FQ54343-Gestion des concessions : extension de la comtpa provisoire aux PPR
   #FQ64544-Gestion des concessions : extension de la comtpa provisoire aux écarts entre plans
   If ([M:TPE]SRCTYP=GVML_SRCDEP | [M:TPE]SRCTYP=GVML_SRCRPR | [M:TPE]SRCTYP=GVML_SRCLNK)
    [M:TC1P]TYPPST    = [F:FSY]TYPPST(I_PER-1)
   Else
    [M:TC1P]TYPPST    = GVML_TPSTDEF
   Endif
   #Gosub TRC_PER From TRTCPTINT2 #Fq69824
   If !GSERVEUR
    Call AFF_VLC(mess(24,GML_MSGCPT,1)-"/"-mess(31,GML_MSGCPT,1)-":"-LFCY-"/"-[F:TPE]ACETYP,
&                mess(11,GML_MSGCPT,1)-":"-format$("D:" + GFMDAT4,[M:TC1P]PERSTRDAT)-"au"-format$("D:" + GFMDAT4,[M:TC1P]PERENDDAT)) From GESECRAN
   Endif
   # MHB 01/07/08 : on passe par une variable temporaire, car il peut arriver que des écrans d'abréviation DIA n'aient
   # pas le champ FLGSIM
   If dim([M:DIA]FLGSIM)>0 Then
     TEMP=[M:DIA]FLGSIM
   Else
     TEMP=G_NON
   Endif
   # Alimentation des informations de date
   [M:TPE]DATSTRFIY=[F:FSY]DATSTRFIY
   [M:TPE]DATENDFIY=[F:FSY]DATENDFIY
   [M:TPE]DATSTRPER=[F:FSY]DATSTRPER([F:FSY]INDCURPER-1)
   [M:TPE]DATENDPER=[F:FSY]DATENDPER([F:FSY]INDCURPER-1)
   [M:TPE]TRTSTRPER=[F:FSY]DATSTRPER(I_PER-1)
   [M:TPE]TRTENDPER=[F:FSY]DATENDPER(I_PER-1)
#    Call GENERE_CPT(LCPY,
# &                  [F:FCY]FCY,
# &                  "",
# &                  0,
# &                  [F:FSY]DATSTRPER(I_PER-1),
# &                  [F:FSY]DATENDPER(I_PER-1),
# &                  "",
# &                  [M:TC1P]TYPPST,
# &                  [F:FSY]LSTTYPPRO(I_PER-1),
# &                  LFIY,
# &                  I_PER,
# &                  [M:DIA]FLGSIM,
# &                  G_NON,
# &                  RETOUR,
# &                  MSGRETOUR) From TRTCPTINT1
   Call GENERE_CPT(LCPY,
&                  LFCY,
&                  "",
&                  0,
&                  [F:FSY]DATSTRPER(I_PER-1),
&                  [F:FSY]DATENDPER(I_PER-1),
&                  "",
&                  [M:TC1P]TYPPST,
&                  [F:FSY]LSTTYPPRO(I_PER-1),
&                  LFIY,
&                  I_PER,
&                  TEMP,
&                  [M:DIA]FLGDETANA,
&                  G_NON,
&                  RETOUR,
&                  MSGRETOUR) From TRTCPTINT1

   # Type d'écriture sur DEPREC, type de compta = Définitive et type précédent Provisoire, on réinitialise le flag
   # LSTTYPPRO

   # If [M:DIA]FLGSIM<>G_OUI & !RETOUR & [M:TPE]SRCTYP=2 & [F:FSY]TYPPST(I_PER-1)=GVML_TPSTDEF & [F:FSY]LSTTYPPRO(I_PER-1)=G_OUI
   #Fq62622-Pas de mise à jour de LSTTYPPRO
   #If TEMP<>G_OUI & !RETOUR & ([M:TPE]SRCTYP=GVML_SRCDEP | [M:TPE]SRCTYP=GVML_SRCRPR) & [F:FSY]TYPPST(I_PER-1)=GVML_TPSTDEF & [F:FSY]LSTTYPPRO(I_PER-1)=G_OUI
   # Trbegin [M:FSY]
   # [F:FSY]LSTTYPPRO(I_PER-1)=G_NON : Rewrite [F:FSY]
   # If !fstat
   #  Commit
   # Else
   #  Rollback
   # Endif
   #Endif
   #Fq62622-Fin

   #Fq69824
   #Gosub TRC_TOT_GAC_PER From TRTCPTINT2
   If dim(LTRCINFOPER)>0 : Kill LTRCINFOPER : Endif

  Endif
 Next I_PER
 $FIN_TRT_TPE
 Gosub TRCTEC_FINTPE From TRTCPTINT5
 If GTECTRC = G_OUI
  Openo Using [XLOG]
 Endif
Return

######################################################################################
# Sous-programme et routines communes
######################################################################################

#============================================================================
# Sous-pro appelé en gestion objet pour déclencher une comptabilisation
# à la volée des dotations ou des événements générés par une action
# métier
# Le s/p boucle sur les types d'écritures "comptabilisable directement"
# définis pour la société fournie en paramètre.
# Le paramètrage du type d'écriture est chargé dans le masque TPE
# Pour le premier type d'écriture nécessitant une trace, un fichier
# trace est ouvert.
# Il est alimenté uniquement pour les types d'écritures paramétrés avec trace
# Le fichier trace est refermé à la fin du s/p
#============================================================================
Subprog COMPTA_DIRECTE(PCPY, PFCY, PREF, PLIN, PACTION, CDRET)
Value    Char    PCPY
Value    Char    PFCY
Value    Char    PREF
Value    Integer PLIN
Value    Char    PACTION
Variable Integer CDRET

 If !clalev([M:TPE])  : Local Mask TYPACE    [TPE]  : Endif

 If !clalev([F:ADI])  : Local File ATABDIV   [ADI]    : Endif
 If !clalev([F:TPE])  : Local File TYPACE    [TPE]    : Endif
 If !clalev([F:TPL])  : Local File TYPACELEG [TPL]    : Endif  #*Fq-85066
 If !clalev([F:CNX])  : Local File CONTEXT   [CNX]    : Endif
 If !clalev([F:FSY])  : Local File FISCYEAR  [FSY]    : Endif

 Local Integer LCPTDIR

 Gosub INIT

 Local  Char    LCRITTPE(255)
 Local  Integer RETOUR
 Local  Integer LCNX
 Local  Char    MSGRETOUR(80)(1..10)

 Local  Integer LFIY

 LCRITTPE = "(CPY=PCPY | CPY='') & ENAFLG=G_OUI & DIRCPTFLG=G_OUI"
 If PACTION = ""
 Elsif PACTION="DOTATION"
  LCRITTPE += "&SRCTYP=GVML_SRCDEP"
 Elsif PACTION="ECARTPLAN"
  LCRITTPE += "&SRCTYP=GVML_SRCLNK" #@fq64544
 Elsif PACTION = "AUTRE"
  LCRITTPE += "&SRCTYP=GVML_SRCOTH"
 Elsif PACTION = "RENOUV"
  LCRITTPE += "&SRCTYP=GVML_SRCRPR"
 Else
  LCRITTPE += "&SRCTYP=GVML_SRCEVT & EVTTYP=PACTION"
 Endif
 Filter [F:TPE] Where evalue(LCRITTPE)
 For [F:TPE]
  [M:TPE]=[F:TPE]

  #YYFIN_118072
  Read[CPY]CPY0= PCPY
  Read [TPL]TPL0=[M:TPE]ACETYP;[F:TPE]LEG;PCPY;[F:CPY]LEG
  If fstat
    Read [TPL]TPL0=[M:TPE]ACETYP;"";PCPY;[F:CPY]LEG
    If fstat
     Read [TPL]TPL0=[M:TPE]ACETYP;[F:TPE]LEG;"";[F:CPY]LEG
    Endif
    If fstat
     Read [TPL]TPL0=[M:TPE]ACETYP;"";"";[F:CPY]LEG
    Endif
  Endif
  If fstat=0
    [M:TPE]GTE     =  [F:TPL]GTE
    [M:TPE]GTEPRO  =  [F:TPL]GTEPRO
    [M:TPE]JOU     =  [F:TPL]JOU
    [M:TPE]JOUPRO  =  [F:TPL]JOUPRO
  Endif
  #End YYFIN_118072

  # FQ79814
#  If [F:TPE]DIRCPTTRA=G_OUI : Call TEMPOFF From GESECRAN : Endif
#  If [F:TPE]DIRCPTTRA=G_OUI : Call TEMPON("Comptabilisation en cours ...") From GESECRAN : Endif
  If [F:TPE]DIRCPTTRA=G_OUI : Call TEMPON(mess(19, 129, 1)) From GESECRAN : Endif

  #FQ56791-Alimentation de SORTFLDDES
  #> Chargement des intitulés des champs du tableau tri/regroupement
  #  ---------------------------------------------------------------
  Local Integer I
  For I=1 To [M:TPE]NBCRIT
   [M:TPE]SORTFLDDES(I-1)=func SUBTPE.GET_FLD_DES([M:TPE]SORTFLDTAB(I-1),[M:TPE]SORTFLD(I-1))
  Next I
  If GTRACE="" & [M:TPE]DIRCPTTRA=G_OUI
   Global Integer LTRCOPE
  Endif
  Call GET_CNX_FROM_PLAN (PCPY, [F:TPE]DPRPLN, LCNX) From GLOBIENS
  If !(LCNX>0) : Goto NEXT_TPE_DIR : Endif
  Read [F:CNX]CNX0=PCPY;LCNX
  If fstat
   LIGNE = "TRTCPTINT-$TRT_UN_SITE-Read [F:CNX]"-PCPY+num$(LCNX)-num$(fstat)
   Call ECR_TRACE(LIGNE,1) From GESECRAN
   Goto $NEXT_TPE_DIR
  Endif
  LFIY = GVML_TECOURA : Gosub CPT_DIR_TRT_EXE From TRTCPTINT
  LFIY=GVML_TESUIV : Gosub CPT_DIR_TRT_EXE From TRTCPTINT
 $NEXT_TPE_DIR
 Next
 Filter [F:TPE]
 If GTRACE<>"" & dim(LTRCOPE)>0
   Call LEC_TRACE From LECFIC
   Kill LTRCOPE
 Endif
# FQ79814
# If [F:TPE]DIRCPTTRA=G_OUI : Call TEMPON("Comptabilisation en cours ...") From GESECRAN : Endif
 Call TEMPOFF From GESECRAN
 Gosub TERMINE
End

#============================================================================
# Comptabilisation directe pour un type d'écriture et un exercice
# donné.
#============================================================================
$CPT_DIR_TRT_EXE
  Read [F:FSY]FIY1=PCPY;LCNX;LFIY
  If fstat
   LIGNE = "TRTCPTINT-$TRT_UN_SITE-Read [F:FSY]"-PCPY+num$(LCNX)-num$(LFIY)-num$(fstat)
   Call ECR_TRACE(LIGNE,1) From GESECRAN
   Goto $NEXT_TPE_DIR
  Endif

  For I_PER=1 To [F:FSY]NBRPER
   If    ([M:TPE]PERCLOFLG=G_OUI & [F:FSY]STAPER(I_PER-1)=GVML_SPCLOSE) |
&        ([M:TPE]PERCOUFLG=G_OUI & [F:FSY]STAPER(I_PER-1)=GVML_SPCOURA) |
&        ([M:TPE]PEROPEFLG=G_OUI & [F:FSY]STAPER(I_PER-1)=GVML_SPOUVER)
    # Alimentation des informations de date
    [M:TPE]DATSTRFIY=[F:FSY]DATSTRFIY
    [M:TPE]DATENDFIY=[F:FSY]DATENDFIY
    [M:TPE]DATSTRPER=[F:FSY]DATSTRPER([F:FSY]INDCURPER-1)
    [M:TPE]DATENDPER=[F:FSY]DATENDPER([F:FSY]INDCURPER-1)
    [M:TPE]TRTSTRPER=[F:FSY]DATSTRPER(I_PER-1)
    [M:TPE]TRTENDPER=[F:FSY]DATENDPER(I_PER-1)
    Call GENERE_CPT(PCPY,
&                   PFCY,
&                   PREF,
&                   PLIN,
&                   [F:FSY]DATSTRPER(I_PER-1),
&                   [F:FSY]DATENDPER(I_PER-1),
&                   "",
&                   [F:FSY]TYPPST(I_PER-1),
&                   [F:FSY]LSTTYPPRO(I_PER-1),
&                   LFIY,
&                   I_PER,
&                   G_NON,
&                   G_NON,
&                   G_OUI,
&                   RETOUR,
&                   MSGRETOUR) From TRTCPTINT1
   Endif
  Next I_PER
Return

#===============================================================================
# Crée les globales nécessaires au traitement (voir si possibilité report dans
# GLOBIMM)
$CREE_VARIABLES

 #> Constantes

 Global Integer GRP_OMLEA  : GRP_OMLEA  = 1
 Global Integer GRP_OMGRT  : GRP_OMGRT  = 2
 Global Integer GRP_OMLOF  : GRP_OMLOF  = 3
 Global Integer GRP_OMFAS  : GRP_OMFAS  = 4
 Global Integer GRP_FCY    : GRP_FCY    = 5
 Global Integer GRP_CPY    : GRP_CPY    = 6
 Global Integer GRP_ACCCOD : GRP_ACCCOD = 7

 #> Globales

 Global Integer GNUMTRT
 Global Integer GHEATABACE : Raz GHEATABACE   # Indicateur d'émission de l'en-tête du tableau d'écritures
 Global Char    NUMPCGACE                     # Numéro de la pièce de compta légale si pièce auto IAS associée.
 Global Char    TYPPCGACE                     # type de la pièce de compta légale si pièce auto IAS associée.
 Global Integer GPARANNUL                     # Annulation ou suppression des pièces provisoires

 #> Spécifiques si lien avec X3.

 If GCOMPTA<>3 & GTABCPT<>""
  Gosub CREEX3VAR # Création des variables nécessaire à la suppression des pièces provisoires dans X3.
 Endif

 #> Initilisations

Return

#===============================================================================
# Crée les globales nécessaires au traitement dans le cas d'un lien avec X3
# Variables pour la suppression des pièces provisoires.
$CREEX3VAR

 If 1=1

  #> Paramètres récupérés dans X3.

  Global Libelle GBALGACRPT : # Balance géné devise reporting
  Call PARAM_CPTX3DOS("","BALGACRPT",PARAM)
  GBALGACRPT = val(PARAM)
  Global Libelle GBALANARPT : # Balance ana devise reporting
  Call PARAM_CPTX3DOS("","BALANARPT",PARAM)
  GBALANARPT = val(PARAM)
  Global Libelle GRAN : # Report à nouveau général
  Call PARAM_CPTX3DOS("","FRWGAC",PARAM)
  GRAN = val(PARAM)
  Global Libelle GRANA : # Report à nouveau analytique
  Call PARAM_CPTX3DOS("","FRWANA",PARAM)
  GRANA = val(PARAM)
  Global Libelle GRANA1 : # Report à nouveau axe 1
  Call PARAM_CPTX3DOS("","FRWAXI1",PARAM)
  GRANA1 = val(PARAM)
  Global Libelle GRANA2 : # Report à nouveau axe 2
  Call PARAM_CPTX3DOS("","FRWAXI2",PARAM)
  GRANA2 = val(PARAM)
  Global Libelle GRANA3 : # Report à nouveau axe 3
  Call PARAM_CPTX3DOS("","FRWAXI3",PARAM)
  GRANA3 = val(PARAM)
  Global Libelle GRANA4 : # Report à nouveau axe 4
  Call PARAM_CPTX3DOS("","FRWAXI4",PARAM)
  GRANA4 = val(PARAM)
  Global Libelle GRANA5 : # Report à nouveau axe 5
  Call PARAM_CPTX3DOS("","FRWAXI5",PARAM)
  GRANA5 = val(PARAM)
  Global Libelle GRANA6 : # Report à nouveau axe 6
  Call PARAM_CPTX3DOS("","FRWAXI6",PARAM)
  GRANA6 = val(PARAM)
  Global Libelle GRANA7 : # Report à nouveau axe 7
  Call PARAM_CPTX3DOS("","FRWAXI7",PARAM)
  GRANA7 = val(PARAM)
  Global Libelle GRANA8 : # Report à nouveau axe 8
  Call PARAM_CPTX3DOS("","FRWAXI8",PARAM)
  GRANA8 = val(PARAM)
  Global Libelle GRANA9 : # Report à nouveau axe 9
  Call PARAM_CPTX3DOS("","FRWAXI9",PARAM)
  GRANA9 = val(PARAM)
  Global Char   GCPTRES : # Compte de résultat
  Call PARAM_CPTX3DOS("","CPTRES",PARAM)
  GCPTRES = PARAM

  #> Constantes définies dans X3

  Global Integer GDIMCRX  : GDIMCRX=99
  Global Integer GLONBPX  : GLONBPX=3

  #> Variables définies dans X3.

  Global Integer GNBCROIS                      : # Nb croisement d'axes
  Global Char    GCROIS(GLONBPX)(1..GDIMCRX)   : # Codes croisements
  Global Integer GCROISNB(1..GDIMCRX)          : # Nb axes par croisement
  Global Integer GCRAXE(1..GDIMCRX,1..3)       : # Axes croisés
  Global Integer GEXEAN(1..GDIMSOC)            : # Exercice de report à nouveau général
  Global Integer GEXEANA(1..GDIMSOC)           : # Exercice de report à nouveau ana

  #> Sous-programmes d'initialisation des variables à partir des tables d'X3.

  Call VARCROISE
  Call EXEAN
  Call EXEANA

 Endif

Return

########################################
# Origine ADOVAL : accès à la valeur
# d'un paramètre dans le dossier compta
########################################
Subprog PARAM_CPTX3DOS(SITE,PARAM,VALEUR)
Value Char    SITE
Value Char    PARAM
Variable Char VALEUR()
Local Integer PARAML

$PARAM_
If clalev([F:ADW])=0 : Local File =GTABCPT+"ADOVAL" [ADW] : Endif
VALEUR = ""
If SITE=""
 Read [ADW]ADW0 = "";"";PARAM
Elsif find(SITE,GSOC(1..GNBSOC)) : # C'est une société
 Read [ADW]ADW0 = SITE;"";PARAM
 If fstat
  Read [ADW]ADW0 = "";"";PARAM
 Endif
Else : # C'est un site
 Read [ADW]ADW0 = "";SITE;PARAM
 If fstat
  ISITE = find(SITE,GSITE(1..GNBSITE))
  If ISITE
   Read [ADW]ADW0 = GSOCSITE(ISITE);"";PARAM
  Endif
  If fstat
   Read [ADW]ADW0 = "";"";PARAM
  Endif
 Endif
Endif
If !fstat
 VALEUR = [F:ADW]VALEUR
Else
 VALEUR = ""
Endif
If PARAML
 [V]GNUPARAM = mod([V]GNUPARAM,dim([V]GSIPARAM))+1
 [V]GSIPARAM([V]GNUPARAM) = SITE+"~"+PARAM
 [V]GVAPARAM([V]GNUPARAM) = VALEUR
Endif
End

#############################################################
# Origine GLOBCPT
# Table des croisements : Chargée à partir des tables du
# dossier lié X3.
#############################################################
Subprog VARCROISE
If clalev([F:BPX])=0 : Local File =GTABCPT+"BUDPARAXI" [BPX] : Endif
Local Integer I
GNBCROIS = 0
For [BPX]BPX0 Where ENAFLG=2
 GNBCROIS += 1
 GCROIS(GNBCROIS) = [F:BPX]PARAXI
 GCROISNB(GNBCROIS) = [F:BPX]NBRAXI
 For I=1 To [F:BPX]NBRAXI
  Case I
   When 1 : GCRAXE(GNBCROIS,1) = [F:BPX]AXI1
   When 2 : GCRAXE(GNBCROIS,2) = [F:BPX]AXI2
   When 3 : GCRAXE(GNBCROIS,3) = [F:BPX]AXI3
  Endcase
 Next I
Next
End

#################################################
# Origine GLOBCPT
# Exercices de report à nouveau général :
# Chargés à partir des tables du dossier lié
# X3.
#################################################
Subprog EXEAN
Local Integer I , EXE
Raz GEXEAN
If GRAN=2 | GRANA=2 : # Report à nouveau général ou ana
#If clalev([F:FIY])=0 : Local File =GTABCPT+"FISCALYEAR" [FIY] : Endif
 Local File =GTABCPT+"FISCALYEAR" [FIY]
 For I=1 To GNBSOC
  Filter [FIY] Where CPY=GSOC(I) & FIYSTA=2 : # 1er exercice ouvert
  Read [FIY]FIY0 First
  Filter [FIY]
  If !fstat
   EXE = [F:FIY]FIYNUM
   Read [FIY]FIY0 = GSOC(I);EXE+1
   If !fstat & [F:FIY]FIYSTA=2
    GEXEAN(I) = EXE
   Endif
  Endif
 Next I
Endif
End

#################################################
# Origine GLOBCPT
# Exercices de report à nouveau :
# Chargé à partir des tables du dossier de compta
# lié X3.
#################################################
Subprog EXEANA
Local Integer I , EXE
Raz GEXEANA
If GRANA=2 # Report à nouveau ana
#If clalev([F:FIY])=0 : Local File =GTABCPT+"FISCALYEAR" [FIY] : Endif
 Local File =GTABCPT+"FISCALYEAR" [FIY]
 For I=1 To GNBSOC
  Filter [FIY] Where CPY=GSOC(I) & (FIYSTA=2 | FIYSTA=3) : # 1er exercice ouvert
  Read [FIY]FIY0 First
  Filter [FIY]
  If !fstat
   EXE = [F:FIY]FIYNUM
   Read [FIY]FIY0 = GSOC(I);EXE+1
   If !fstat & ([F:FIY]FIYSTA=2 | [F:FIY]FIYSTA=3)
    GEXEANA(I) = EXE
   Endif
  Endif
 Next I
Endif
End

#===============================================================================
# détruit les variables globales créées pour le traitement
$KILL_VARIABLES
 If dim(GNUMTRT)>0    : Kill GNUMTRT    : Endif
 If dim(GHEATABACE)>0 : Kill GHEATABACE : Endif
 If dim(GRP_OMLEA)>0  : Kill GRP_OMLEA  : Endif
 If dim(GRP_OMGRT)>0  : Kill GRP_OMGRT  : Endif
 If dim(GRP_OMLOF)>0  : Kill GRP_OMLOF  : Endif
 If dim(GRP_OMFAS)>0  : Kill GRP_OMFAS  : Endif
 If dim(GRP_FCY)>0    : Kill GRP_FCY    : Endif
 If dim(GRP_CPY)>0    : Kill GRP_CPY    : Endif
 If dim(L_LEA_ACTIF)>0: Kill L_LEA_ACTIF: Endif
 If dim(L_IAS_ACTIF)>0: Kill L_IAS_ACTIF: Endif
 If dim(L_PAC_ACTIF)>0: Kill L_PAC_ACTIF: Endif

 #> Variables X3.

 If GCOMPTA<>3 & GTABCPT<>""
  If dim(GBALGACRPT)>0    : Kill GBALGACRPT    : Endif
  If dim(GBALANARPT)>0    : Kill GBALANARPT    : Endif
  If dim(GRAN)>0          : Kill GRAN          : Endif
  If dim(GRANA)>0         : Kill GRANA         : Endif
  If dim(GRANA1)>0        : Kill GRANA1        : Endif
  If dim(GRANA2)>0        : Kill GRANA2        : Endif
  If dim(GRANA3)>0        : Kill GRANA3        : Endif
  If dim(GRANA4)>0        : Kill GRANA4        : Endif
  If dim(GRANA5)>0        : Kill GRANA5        : Endif
  If dim(GRANA6)>0        : Kill GRANA6        : Endif
  If dim(GRANA7)>0        : Kill GRANA7        : Endif
  If dim(GRANA8)>0        : Kill GRANA8        : Endif
  If dim(GRANA9)>0        : Kill GRANA9        : Endif
  If dim(GDIMCRX)>0       : Kill GDIMCRX       : Endif
  If dim(GLONBPX)>0       : Kill GLONBPX       : Endif
  If dim(GNBCROIS)>0      : Kill GNBCROIS      : Endif
  If dim(GCRAXE)>0        : Kill GCRAXE        : Endif
  If dim(GEXEAN)>0        : Kill GEXEAN        : Endif
  If dim(GEXEANA)>0       : Kill GEXEANA       : Endif
 Endif

Return

######################################################################################
# Actions sur champ du masque TRTCPTINT [DIA]
######################################################################################

#============================================================================
Subprog AM_FLGSIM(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_NON
  #Fq-91253 [M:DIA]FLGDETANA=0
  [M:DIA]FLGDETANA=G_NON
  Grizo [M:DIA]FLGDETANA
 Else
  [M:DIA]FLGDETANA=G_OUI
  Actzo [M:DIA]FLGDETANA
 Endif
 Affzo [M:DIA]FLGDETANA
End

#Fq69824
#============================================================================
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
 If GDEBUG<>G_OUI | VALEUR="" : GBOUT2 = "" : Endif
End

#============================================================================
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
 #Fq70465
 If func GLOBIENS.IS_DESYNC_CNX(VALEUR, 0)=G_OUI
  GERR     = 1
  GMESSAGE = func GLOFUNC.SUBSTIT1(mess(272,GML_MSGFASPR,1), VALEUR) #"Société"-[M:DIA]CPY-":"-"Au moins un contexte est désynchronisé avec la comptabilité."
  mkstat   = 2
 Endif
End

#============================================================================
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

 If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
 If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif
 Effzo [M:DIA]15

# FQ80212 : find sorti du Filter
# If GUSRFCY(1)="\"
#   Filter [F:FCY] Where LEGCPY = VALEUR & FINFLG=G_OUI
# Else
#   Filter [F:FCY] Where LEGCPY = VALEUR & find(FCY,GUSRFCY(1..GNBAUZ)) & FINFLG=G_OUI
# Endif
#* Fq-85066 : récupération de la législation de la société
Read[CPY]CPY0=VALEUR
If fstat=0
   [M:DIA]LEG = [F:CPY]LEG
   Affzo [M:DIA]LEG
Endif

 Filter [F:FCY] Where LEGCPY = VALEUR & FINFLG=G_OUI

 For [F:FCY]
  If GUSRFCY(1) = "\" | find([F:FCY]FCY, GUSRFCY(1..GNBAUZ))
    [M:DIA]NBFCY+=1
    [M:DIA]FCY([M:DIA]NBFCY-1)=[F:FCY]FCY
    [M:DIA]FLGFCY([M:DIA]NBFCY-1)=G_OUI
  Endif
 Next
 Affzo [M:DIA]15
 Filter [F:FCY]
 If dim([M:TPE0]CPY)<0
  Effzo [M:DIA]20
 Endif

 If VALEUR<>""
  Call LOAD_FASPARCPY(VALEUR,"FPC",G_NON,GOK) From GLOFCYCPY
 Endif

End

#============================================================================
# Tous
#============================================================================
Subprog B1_NBFCY
 Local Integer I_FCY
 For I_FCY=1 To [M:DIA]NBFCY
  [M:DIA]FLGFCY(I_FCY-1)=G_OUI
 Next I_FCY
 Affzo [M:DIA]15
End

#============================================================================
# Aucun
#============================================================================
Subprog B2_NBFCY
 Local Integer I_FCY
 For I_FCY=1 To [M:DIA]NBFCY
  [M:DIA]FLGFCY(I_FCY-1)=G_NON
 Next I_FCY
 Affzo [M:DIA]15
End

#============================================================================
Subprog AS_FIY(VALEUR)
Variable Integer VALEUR
 GMENLOC(1)=1
 GMENLOC(4)=1
End
#============================================================================
Subprog C_TPE(VALEUR)
Variable Char    VALEUR()

 # Contrôle d'unicité
 Local Integer I_OCC
 I_OCC=find(VALEUR,[M:DIA]TPE)
 If I_OCC & I_OCC<>nolign
  GERR     = 1
  GMESSAGE = mess(80,GML_MSGCPT,1)-num$(I_OCC) #"Code déjà utilisé ligne" #mess
  mkstat   = 2
  End
 Endif

 # Contrôle de restriction société
 If !clalev([F:TPE]) : Local File TYPACE     [TPE]  : Endif
 If !clalev([F:TPL]) : Local File TYPACELEG  [TPL]  : Endif  #*Fq-85066
 #Fq-85066 Read [F:TPE]TPE0=VALEUR
 Read [F:TPE]TPE0=VALEUR;[M:DIA]CPY;[M:DIA]LEG
 If !fstat & [F:TPE]CPY<>"" & [F:TPE]CPY<>[M:DIA]CPY
  GERR     = 1
  GMESSAGE = mess(81,GML_MSGCPT,1)-[F:TPE]CPY #"Type d'écriture défini uniquement pour la société"
  mkstat   = 2
  End
 Endif

 # Contrôle de législation

 If [F:TPE]LEG<>""
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  Read [F:CPY]CPY0=[M:DIA]CPY
  If [F:CPY]LEG<>[F:TPE]LEG
   GERR     = 1
    #"Le code législation du type d'écriture est incompatible avec celui de la société"
   GMESSAGE = mess(126,GML_MSGCPT,1)-[F:TPE]CPY-"/"-[F:CPY]LEG
   mkstat   = 2
   End
  Endif
 Endif

 # Contrôle module actif / inactif

 If [F:TPE]SRCTYP=GVML_SRCEVT
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  Read [F:ADI]CODE=GTD_EVENT;[F:TPE]EVTTYP # Table diverse 962
  If !fstat
   # FQ59900
   #If [F:ADI]N2=GVML_OMSUBV & G_ACTGRT<>G_OUI
   # GERR     = 1
   # GMESSAGE = mess(115,GML_MSGCPT,1)
   # mkstat   = 2
   # End
   #Endif
   #If [F:ADI]N2=GVML_OMLOCFI & G_ACTLEA<>G_OUI
   # GERR     = 1
   # GMESSAGE = mess(116,GML_MSGCPT,1)
   # mkstat   = 2
   # End
   #Endif
   If !find([F:ADI]A2,GTABEVT)
    Case [F:ADI]N2
     When GVML_OMSUBV  : GMESSAGE = mess(115,GML_MSGCPT,1)
     When GVML_OMLOCFI : GMESSAGE = mess(116,GML_MSGCPT,1)
     When Default      : GMESSAGE = mess(115,GML_MSGCPT,1) : # A COMPLETER
    Endcase
    GERR     = 1
    mkstat   = 2
    End
   Endif
  Endif
 Endif

 #@fq66210
 If [F:TPE]SRCTYP=GVML_SRCRPR & G_ACTCCN<>G_OUI
  GERR     = 1
  mkstat   = 2
  GMESSAGE = mess(131,GML_MSGCPT,1)
 Endif

End
#============================================================================
# Tous
#============================================================================
Subprog B1_NBTPE

 If !clalev([F:TPE]) : Local File TYPACE      [TPE]  : Endif
 If !clalev([F:TPL]) : Local File TYPACELEG   [TPL]  : Endif  #*Fq-85066
 If !clalev([F:CPY]) : Local File COMPANY     [CPY] : Endif

 Read [F:CPY]CPY0=[M:DIA]CPY

 Local Char LREQ(255)

 LREQ='ENAFLG=G_OUI & (CPY=[M:DIA]CPY | CPY="") & !find(ACETYP,[M:DIA]TPE)<>0'

 If [F:CPY]LEG<>""
  LREQ+='&(LEG="" | LEG=[F:CPY]LEG)'
 Endif


 Filter [F:TPE] Where evalue(LREQ)
 For [F:TPE]
   #<<< Fq-85066 Si le type d'écriture est paramétré "Toutes législations"  on va vérifier qu'il a bien une ligne pour
   # la législation de la société traitée et on ne le présentera que dans ce cas là
   If [F:TPE]LEG = ""
     For[TPL]TPL0 Where (ACETYP=[F:TPE]ACETYP and LEG="" and LEGLIN=[F:CPY]LEG)
        Read [TPL]First
        If fstat
          Goto $NEXT_B1_TPE
        Else
          [M:DIA]TPE([M:DIA]NBTPE)=[F:TPL]ACETYP
          [M:DIA]NBTPE+=1
          ALL_LEG=G_OUI
          Break
        Endif
     Next #>>>Fq-85066
  Endif

  If [F:TPE]SRCTYP=GVML_SRCEVT
   If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
   Read [F:ADI]CODE=GTD_EVENT;[F:TPE]EVTTYP
   If !find([F:ADI]A2,GTABEVT)
    Goto $NEXT_B1_TPE
   Endif
  Endif
  If [F:TPE]SRCTYP=GVML_SRCRPR & G_ACTCCN<>G_OUI
     Goto NEXT_B1_TPE
  Endif
  If ALL_LEG=G_OUI
    ALL_LEG=G_NON
    Goto NEXT_B1_TPE
  Endif
  [M:DIA]TPE([M:DIA]NBTPE)=[F:TPE]ACETYP
  [M:DIA]LEGTPE([M:DIA]NBTPE)=[F:TPE]LEG  #Fq-85066
  [M:DIA]CPYTPE([M:DIA]NBTPE)=[F:TPE]CPY  #Fq-85066
  [M:DIA]NBTPE+=1
  $NEXT_B1_TPE
 Next
 Filter [F:TPE]

 Affzo [M:DIA]TPE
 Affzo [M:DIA]ZTPE
 Affzo [M:DIA]LEGTPE #Fq-85066
 Affzo [M:DIA]CPYTPE #Fq-85066
 Affzo [M:DIA]NBTPE #Fq-85066


End

#============================================================================
# Aucun
#============================================================================
Subprog B2_NBTPE
 Effzo [M:DIA]20 : Affzo [M:DIA]20
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran TRTCPTINT) 08/11/2012 15:46:27 (MDJ)
######################################################################################
Subprog AM_TPE(VALEUR)
Variable Char    VALEUR()

   If !clalev([F:TPE])  : Local File TYPACE    [TPE]    : Endif # FQ109364
   Read[TPE]TPE0=VALEUR;[M:DIA]LEG; [M:DIA]CPY
   If fstat
      Read[TPE]TPE0=VALEUR;[M:DIA]LEG;""
      If fstat
         Read[TPE]TPE0=VALEUR;"";""
      Endif
   Endif
   [M:DIA]LEGTPE(nolign-1) = [F:TPE]LEG
   [M:DIA]CPYTPE(nolign-1) = [F:TPE]CPY
   Affzo [M:DIA]LEGTPE(nolign-1)
   Affzo [M:DIA]CPYTPE(nolign-1)

End

