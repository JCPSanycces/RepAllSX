#<AdxTL>@(#)0.0.0.0 $Revision$ 
################################################################################
# UTIADMCA 
# Utility program for patches for Customer Administrator
#
################################################################################

End
#######################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(FOLDERNAME)
Value Char FOLDERNAME
  Call ECR_TRACE("UTIADMCA : Update profil for customer administrator for Folder "+FOLDERNAME,0) From GESECRAN
# ici il faut ouvrir les tables dans le dossier à patcher sinon ne marche pas
# on les ouvre toujours (oct 2017) car on ne sait pas si elles sont ouvertes au bon endroit
#If clalev([F:AFT])   = 0 : Local File =FOLDERNAME+".AFCTFCT"   [AFT]  : Endif
#If clalev([F:AFF])   = 0 : Local File =FOLDERNAME+".AFCTFCY"   [AFF]  : Endif
#If clalev([F:AFC])   = 0 : Local File =FOLDERNAME+".AFONCTION" [AFC]  : Endif
#If clalev([F:AFP1])  = 0 : Local File =FOLDERNAME+".AFCTPRF"   [AFP1] : Endif
#If clalev([F:FCY])   = 0 : Local File =FOLDERNAME+".FACILITY"  [FCY]  : Endif
#If clalev([F:FGRA])  = 0 : Local File =FOLDERNAME+".FACGROUP"  [FGRA] : Endif


Local File =FOLDERNAME+".AFCTFCT"   [AFT] 
Local File =FOLDERNAME+".AFCTFCY"   [AFF] 
Local File =FOLDERNAME+".AFONCTION" [AFC] 
Local File =FOLDERNAME+".AFCTPRF"   [AFP1]
Local File =FOLDERNAME+".FACILITY"  [FCY] 
Local File =FOLDERNAME+".FACGROUP"  [FGRA]


  # Update AFCTFCY (AFF) records for ADMCA based on AFCTPRF (AFP) records
  # prob sur instruction Lock quand utilisation du easypatching.
  # la table APLLCK est tjs ouverte dans le dossier courant et donc dans ce cas X3
  # on ne peut pas use la fct risque de Call MAJAFF("ADMCA") From SUBAFP1
  # on reecrit un bout
  Call MAJAFF("ADMCA",FOLDERNAME)

  Call  UPDATE_RIGHTSETAG(FOLDERNAME) From ASYRFNC

  Call ECR_TRACE("UTIADMCA : end process ",0) From GESECRAN

Close Local File

End

##############################################################
Subprog MAJAFF(PRFCOD,RDOSSIER)
Value Char PRFCOD
Value Char RDOSSIER

Local Char LOK(30)
Local Integer OK_LOK

# Mise à jour des fonctions ; Profil fonction ; Fonction
Call ECR_TRACE(mess(87,115,1)-mess(20,130,1)-mess(14,7,1),0) From GESECRAN


Call DEBTRANS From GLOCK
For [AFT] Where [F:AFT]ALLFCT <> 2 and ([L]PRFCOD = "" or [L]PRFCOD = [F:AFT]PRFCOD)
 LOK = "AFP"+[F:AFT]PRFCOD+RDOSSIER
 Gosub LOK
 If OK_LOK
      Gosub TR_MAJAFF From SUBAFP1
      Unlock =LOK
      If GOK<1 : Break : Endif
 Endif
Next AFT
End

$LOK
OK_LOK = 0
Lock =LOK With lockwait=0
If fstat
     GLOCK = "%"+LOK
     Call ROLL From GLOCK
     If GROLL : Return : Else : Goto LOK : Endif
Endif
OK_LOK = 1
Return






