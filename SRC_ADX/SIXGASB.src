#<AdxTL>@(#)9.0.0.0 $Revision$

End

################################################################################
#  SIXGASB : pour traitements de bascule Integrale --> X3                      #
################################################################################
#                                                                              #
# Subprog SIXGASB                                                              #
#     Reprise du brouillard général et analytique                              #
#  => Création de pièces comptables X3 en état provisoire                      #
#                                                                              #
# PREREQUIS :                                                                  #
# ***********                                                                  #
#   - Les tables de base et de paramétrage ont dues être intégrées             #
#     et contrôlées (sociétés, sites, devises, clients, fournisseurs,          #
#     tiers, journaux comptables, modes de règlement, comptes, natures,        #
#     axes analytiques, sections analytiques)                                  #
#   - Les types de pièces et les compteurs de numérotation ont dues être       #
#     définis (on livre des types de pièces associées à des codes              #
#     compteurs documents mais le paramétrage doit être accepté ou             #
#     modifié en fonction des besoins                                          #
#   - Les échéances non encore arrivées à l'étape "RA" ont dues être           #
#     repassées à l'étape "SA" (saisie) dans l'Intégrale                       #
#                                                                              #
#                                                                              #
# OPTIONS (à définir dans l'écran de lancement)                                #
# *******                                                                      #
#   - [F:SPX]OPTDEV  : 1:Reprendre les montants en devise de société           #
#                      2:Reprendre les montants en devise de transaction       #
#   - [F:SPX]OPTMULTIDEV : Si [F]OPTDEV=2, l'option [F]OPTMULTIDEV permet de   #
#                     définir ce qu'on va faire dans le cas d'écritures        #
#                     multi-devises (=dans le cas où le groupe d'écritures     #
#                     Intégrale comporte plus d'une devise autre que la        #
#                     devise de société)                                       #
#   - [F:SPX]ACCRNDDEB,[F:SPX]ACCRNDCDT: Compte d'arrondi créditeur et débiteur#
################################################################################

Gosub SI_CONTEXT From SIXFONCTION
Local File SIPARX3  [SPX]
Read [SPX] First

Call EXEC From SIXGASB
End

#########################################################################
Subprog EXEC

Local Integer OPTDEV      : OPTDEV = 1
Local Integer OPTMULTIDEV

If !clalev([F:XGAS])  : Local File =SI_DOSSIER+".XIBROCBGNR"  [XGAS]  : Endif  # Brouillard général
If !clalev([F:XGAA])  : Local File =SI_DOSSIER+".XIBROCBANA"  [XGAA]  : Endif  # Brouillard analytique

Filter [XGAS] Where FLGREP<>2
Read [XGAS]IND0 First
Filter [XGAS]
If fstat : End : Endif

Local Integer WOUV_TRACE
If GTRACE = ""
 # Brouillard général
 Call OUVRE_TRACE("SIXGASB : "+SI_MES(137)) From LECFIC
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#---- Brouillard général => Création écritures provisoires------#
Call ECR_TIME(SI_MES(137)-"=>"-SI_MES(138)) From DOSSUB

Call SI_GASB([F:SPX]OPTDEV,[F:SPX]OPTMULDEV,[F:SPX]AMTDIF,[F:SPX]OPTDIF,[F:SPX]ACCRNDDEB,[F:SPX]ACCRNDCDT,[F:SPX]OPTANA,[F:SPX]CCEDEF,[F:SPX]ACCTMP,[F:SPX]DACDIAGEN)

If GOK<>1 : Goto FIN_GAS : Endif


$FIN_GAS
Onerrgo
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
Resume


######################################################################################
## Traitement brouillard général et analytique
######################################################################################
Subprog SI_GASB(OPTDEV,OPTMULTIDEV,ECART,OPTDIF,CPTECARD,CPTECARC,OPTANA,CCEDEF,CPTATT,SCHEMA)
Value Integer OPTDEV       : # Option reprise écritures => 1:en devise locale 2:en devise mouvement
Value Integer OPTMULTIDEV  : # Option multi-devises => 1:reprise en devise locale 2:reprise sur la 1ère devise trouvée
Value Decimal ECART        : # Montant écart autorisé
Value Integer OPTDIF       : # Si 2:Reprise en devise locale si montant écart dépassé
Value Char    CPTECARD()   : # Compte écart d'arrondi en devise si débiteur
Value Char    CPTECARC()   : # Compte écart d'arrondi en devise si créditeur
Value Integer OPTANA       : # Si 2:Reprise analytique de l'Intégrale ; Si 1:Initialisation ana via section/défaut
Value Char    CCEDEF()     : # Section par défaut pour initialisation analytique lorsque OPTANA<>2
Value Char    CPTATT()     : # Compte d'attente (temporaire) : utile en cas de dépassement de pièce
Value Char    SCHEMA()     : # Transaction de saisie comptable

If !clalev([F:XGAS]) : Local File =SI_DOSSIER+".XIBROCBGNR"   [XGAS]  : Endif  # Brouillard général
If !clalev([F:XGA2]) : Local File =SI_DOSSIER+".XIBROCBGNR"   [XGA2]  : Endif  # Brouillard général
If !clalev([F:XGA3]) : Local File =SI_DOSSIER+".XIBROCBGNR"   [XGA3]  : Endif  # Brouillard général
If !clalev([F:XGAA]) : Local File =SI_DOSSIER+".XIBROCBANA"   [XGAA]  : Endif  # Brouillard analytique
If !clalev([F:XAA2]) : Local File =SI_DOSSIER+".XIBROCBANA"   [XAA2]  : Endif  # Brouillard analytique

#Infbox num$(OPTDEV)-num$(OPTMULTIDEV)-num$(ECART)
Gosub OUVFIC From SIXGAS

Gosub DECLARE From SIXGAS
If STAT : End : Endif

SI_SUBPRG = "SIXGASB"
SI_TABLE  = "XIBROCBGNR"
Gosub SI_CRITSUP From SIXFONCTION

CRITERE="1=1"

Call VARGLOBANA(MESSA,STAT) From SIXGAS
If STAT
 ## Nb d'axes définis dans l'Intégrale pas cohérent avec le dimensionnement du code activité ANA => On arrête
 Call ECR_TRACE(MESSA,1) From GESECRAN : End
Endif

Read [SPX] First

## Qu'une société forcément...
Read [CPY]CPY0 First
If !fstat
 [L]SOCIETE   = [F:CPY]CPY
 [L]SITE      = [F:CPY]MAIFCY
 [L]ORIGINE   = "B"
 [L]DATPREMEX = [F:CPY]STRPER
 If [L]DATPREMEX = [0/0/0]
  # Date début premier exercice non définie
  Call ECR_TRACE(SI_MES(132),1) From GESECRAN : End
 Endif
 Call GETSOC([L]SITE) From DEVSUB
 Call LEC_COA(1,[F:SPX]CPY,[L]COAGEN) From SIXCPY
 Call LEC_COA(2,[F:SPX]CPY,[L]COAANA) From SIXCPY
Endif
## Juste pour tester une prise d'AN... normalement c'est l'AN du 01/01/2002 qu'il faudrait reprendre mais
## il n'y en a pas !!!

#--- Code taxe obligatoire
If dim(GSAITAX)>0
 Call PARAM([L]SOCIETE,"SAITAX",PARAMETRE) From ADOVAL
 GSAITAX  = val(PARAMETRE)
Endif
#--- Code taxe exonéré
If dim(GEXETAX)>0
 Call PARAM([L]SOCIETE,"EXETAX",PARAMETRE) From ADOVAL
 GEXETAX  = PARAMETRE
Endif


Read [XSOC]  First
If !fstat
 [L]DEVLOC = [F:XSOC]DVSIPC
Endif
Read [XSO1]  First

Filter [XGAS] Where evalue(CRITERE) & FLGREP<>2 & X3DAT>=[L]DATPREMEX & NATMVT<>"I"
&                   Order By Key CLE = NUMLOT ; DATSAILOT ; NUMPIEDEB ; NUMPIEFIN ; NUMORDLOT
Filter [XGA2] Where evalue(CRITERE) & FLGREP<>2 & X3DAT>=[L]DATPREMEX & NATMVT<>"I"
&                   Order By Key CLE = NUMLOT ; DATSAILOT ; NUMPIEDEB ; NUMPIEFIN ; NUMORDLOT
Filter [XGAA] Where evalue(CRITERE) & FLGREP<>2 & X3DAT>=[L]DATPREMEX & NATMVT<>"I"
&                   Order By Key CLE = NUMLOT ; DATSAILOT ; NUMPIEDEB ; NUMPIEFIN ; NUMORDLOT ; NUMVTLLOT

## Parcours des écritures du brouillard général par N° lot/date saisie lot/numéro pièce :
## une transaction par couple N° lot/date saisie lot

Call ECR_TRACE("",0) From GESECRAN

For [XGA2]CLE(2)
 Call DEBTRANS From GLOCK
 # Reprise Lot... Date
 Call ECR_TRACE(SI_MES(135)-mess(23,107,1)-num$([F:XGA2]NUMLOT)-";"-mess(88,100,1)-format$(GFMDAT,[F:XGA2]DATSAILOT),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Gosub TR_PCE
 Call ECR_TRACE("",0) From GESECRAN
Next
End


$TR_PCE

Trbegin [HAE], [DAE], [DAA], [DUD], [XGAS], [XGA2], [XGA3], [XGAA], [XDUD], [PER]

 Gosub OUV_PER From SIXGAS

 ## Parcours des pièces associées au même numéro de lot et date saisie lot

 ## 1ère passe : on traite les écritures Intégrale ayant un numéro de pièce renseigné
 ## (champs NUMPIEDEB et NUMPIEFIN<>"")
 ## Si ces écritures rattachées à un même numéro de pièce Intégrale sont équilibrées en devise
 ## société, on crée une pièce X3.
 ## Si on a décidé de reprendre les écritures en devise et que ces écritures sont multi-devises,
 ## deux possibilités :
 ## - L'option "Première devise trouvée" n'a pas été cochée" => On reprend la pièce en devise de société
 ## - L'option "Première devise trouvée" a été cochée" => on reprend la pièce sur la première devise trouvée
 ##   différente de la devise de société
 ## On créera une pièce X3 par numéro de pièce Intégrale ssi il n'y a pas d'écritures de centralisation
 PASSE = 1
 Gosub PASSE1
 If GOK<1
  Rollback
  # Lot.. Date... Reprise non faite => à relancer
  Call ECR_TRACE(mess(23,107,1)-num$([F:XGA2]NUMLOT)-";"-mess(3,11,1)-format$(GFMDAT,[F:XGA2]DATSAILOT)-":"-SI_MES(139),0) From GESECRAN
  Return
 Endif

 ## 2ième passe : on va traiter toutes les écritures non traitées dans la 1ère passe, c'est-à-dire
 #     * toutes les écritures rattachées à un numéro de pièce Intégrale (champs NUMPIEDEB et NUMPIEFIN <>"")
 #       et sont équilibrées en devise société
 #     * toutes les écritures qui ne sont pas rattachées à un numéro de pièce Intégrale (champs NUMPIEDEB
 #       et NUMPIEFIN vides)
 PASSE = 2
 Gosub PASSE2

 Gosub CLO_PER From SIXGAS

 If GOK>0 & SI_SIMU<>2
  Commit
 Else
  Rollback
  If STAT | GOK<1
   # Lot.. Date... Reprise non faite => à relancer
   Call ECR_TRACE(mess(23,107,1)-num$([F:XGA2]NUMLOT)-";"-mess(3,11,1)-format$(GFMDAT,[F:XGA2]DATSAILOT)-":"-SI_MES(139),0) From GESECRAN
   Return
  Endif
 Endif
Return

$PASSE1
For [XGAS]CLE(4) Where NUMLOT=[F:XGA2]NUMLOT & DATSAILOT=[F:XGA2]DATSAILOT & NUMPIEDEB<>"" & NUMPIEFIN<>""
 LOT      = [F:XGAS]NUMLOT
 DATCPT   = [F:XGAS]DATSAILOT
 TYPPIECE = [F:XGAS]NUMPIEDEB
 NUMPIECE = [F:XGAS]NUMPIEFIN
 ## 1ère chose à vérifier : le groupe d'écritures associées au même n° de pièce doit être équilibré
 ## en devise société. D'autre part, le nombre d'écritures de ce groupe ne doit pas dépasser
 ## le nb d'écritures maximum d'une pièce X3
 Gosub VERF_EQUI_LOC
 If EQUILIBRE & NBECT<MAXECT
  Gosub DEV_PIECE : # Reprise de la pièce en quelle devise ?
  Gosub PIECE
  If GOK<1 : Break : Endif
 Endif
Next
If GOK<1 : Return : Endif
Return


$PASSE2
For [XGAS]CLE(2) Where NUMLOT=[XGA2]NUMLOT & DATSAILOT=[XGA2]DATSAILOT & FLGREP<>2
 LOT  = [F:XGAS]NUMLOT
 Gosub DEV_PIECE  : # Reprise de la pièce en quelle devise ?
 Gosub PIECE
 If  GOK<1 : Break : Endif
Next
If  GOK<1 : Return : Endif
Return


$DEV_PIECE
If [L]OPTDEV=1
 ## option 1 : on a demandé la reprise des pièces en devise société => pièce tjs créée en devise société
 OKDEV = 0 : [L]DEVPCE=[L]DEVLOC
Else
 ## option 2 : on a demandé la reprise des pièces en devise. Plusieurs possibilités :
 ## 1/ La pièce ne comporte que des mouvements en devise société (=toutes les écritures ont le
 ##    champ CODDVS vide) => On reprend la pièce en devise société
 ## 2/ La pièce ne comporte que des mouvements autre que la devise société (=toutes les écritures ont le
 ##    champs CODDVS non vide et avec la même valeur) => On reprend la pièce en devise de transaction
 ##    (à condition que le groupe d'écritures soit équilibré en devise (théoriquement oui, mais si
 ##    ce n'est pas le cas, on reprendra la pièce en devise de société)
 ## 3/ La pièce comporte des écritures en devise société et des écritures dans UNE autre devise (une seule
 ##    autre) => On reprend la pièce en devise de transaction. La contre-valeur en devise de transaction
 ##    des écritures rattachées à la devise société dans l'Intégrale sera calculée en prenant le cours
 ##    de la 1ère écriture rattachée à la devise de transaction trouvée
 ## 4/ La pièce comporte plusieurs devises autre que la devise de société et on a demandé
 ##    l'option de reprise en devise société dans le cas d'écritures multi-devises => On reprend
 ##    la pièce en devise société
 ## 5/ La pièce comporte plusieurs devises autre que la devise de société et
 ##    on a demandé l'option de reprise sur la 1ère devise trouvée dans le cas d'écritures
 ##    multi-devises => On reprend la pièce dans la 1ère devise trouvée autre que la devise de société
 ##    La contre-valeur en devise de transaction des écritures rattachées à d'autres devises (société
 ##    ou autres) sera calculée en prenant le cours de la 1ère écriture rattachée à la devise
 ##    transaction trouvée
 Gosub CAS
 Case CAS
  When 1, 4
   OKDEV = 0 : [L]DEVPCE = [L]DEVLOC
  When 2, 3, 5
   For I=1 To NBDEV
    If TDEVISE(I)<>[L]DEVLOC
     OKDEV = 1 : [L]DEVPCE = TDEVISE(I) : Break
    Endif
   Next
   #   If CAS = 3 | CAS = 5 # Ajout du CAS = 2 car le cours est utilisé pour les montants analytiques (en rapport avec la demande 46730)
   If CAS = 3 | CAS = 5 | CAS = 2
    Filter [XGA3] Where NUMLOT=[F:XGAS]NUMLOT & DATSAILOT=[F:XGAS]DATSAILOT & NUMPIEDEB=[F:XGAS]NUMPIEDEB
&                     & NUMPIEFIN=[F:XGAS]NUMPIEFIN & CODDVS=[L]DEVPCE
&                 Order By Key CLE = NUMLOT ; DATSAILOT ; NUMPIEDEB ; NUMPIEFIN ; NUMORDLOT
    Read [XGA3]CLE First
    Filter [XGA3]
    COURDEV = [F:XGA3]TAUDVS1
   Endif
  When Default
   OKDEV = 0 : [L]DEVPCE = [L]DEVLOC
 Endcase
Endif
Call LECTURE("TCU",func SIXFONCTION.SI_COR("XIDVS",[L]DEVPCE,"TABCUR",""),"") From CONTOBJ
ARRONDI = [F:TCU]CURRND
Return


$PIECE
STAT = 0 : SPSTAT = 0
Gosub RAZPCE From SIXGAS
Gosub LIGNE
If GOK<1 : Return : Endif
Return

$LIGNE
For [XGAS]CLE

 Call AFFBOITE(num$([F:XGAS]NUMLOT)-format$("D:"+GFMDAT4,[F:XGAS]DATSAILOT)-[F:XGAS]NUMPIEDEB-[F:XGAS]NUMPIEFIN) From SUBSIM

 If PASSE = 2
  DATCPT   = [F:XGAS]DATSAILOT
  TYPPIECE = [F:XGAS]NUMPIEDEB
  NUMPIECE = [F:XGAS]NUMPIEFIN
 Endif
 NOL = [M:HAE2]NBLIG
 If [F:XGAS]CLF<>""
  # C'est un collectif
  #[M:HAE2]ACC(NOL) = [F:XGAS]CLF
  [M:HAE2]ACC1(NOL) = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XGAS]CLF,"GACCOUNT","")
  Call LECTURE("GAC",[M:HAE2]ACC1(NOL),[L]COAGEN) From CONTOBJ
  [M:HAE2]SAC1(NOL) = [F:GAC]ACCSHO
  ## Dans le cas d'un collectif, on a le compte auxiliaire dans [F:XGAS]CPT.
  ## On alimente le tiers [M:HAE2]BPR(NOL) par le code client/fournisseur qui est associé au
  ## compte auxiliarisé contenu dans [F:XGAS]CPT (sachant que théoriquement, la fiche tiers (BPARTNER) a été
  ## créé avec comme code tiers le code client ou le code fournisseur
  ## => alimentation tiers à revoir...
  Read [XGAC]IND0 = [F:XGAS]CLF
  If !fstat
   Case [F:XGAC]TYPCLF
    When "C" : # Clients
     Filter [XBPC] Where CPTAUX = [F:XGAS]CPT
     Read [XBPC] First
     Filter [XBPC]
     If !fstat
      [M:HAE2]BPR(NOL) = func SIXFONCTION.SI_COR("XICLT",[F:XBPC]CODCLT,"BPCUSTOMER","")
     Else
      # Erreur en lecture
      GOK = 0 : Call ECR_TRACE("BPCUSTOMER"-mess(49,125,1)-[F:XGAS]CPT,1) From GESECRAN : Break
     Endif
    When "F" : # Fournisseurs
     Filter [XBPS] Where CPTAUX = [F:XGAS]CPT
     Read [XBPS] First
     Filter [XBPS]
     If !fstat
      [M:HAE2]BPR(NOL) = func SIXFONCTION.SI_COR("XIFOU",[F:XBPS]CODFOU,"BPSUPPLIER","")
     Else
      # Erreur en lecture
      GOK = 0 : Call ECR_TRACE("BPSUPPLIER"-mess(49,125,1)-[F:XGAS]CPT,1) From GESECRAN : Break
     Endif
    When "O" : # Tiers divers
     ## La fiche tiers (BPARTNER) a théoriquement été créée lors de la reprise des comptes (création dans
     ## BPARTNER des tiers à partir de la table Intégrale PLA_CTB_AUX (XIPLACBGNR). Ces tiers ont été créés
     ## en tant que tiers divers
     [M:HAE2]BPR(NOL) = func SIXFONCTION.SI_COR("XIPLACBAUX",[F:XGAS]CPT,"GACCOUNT","")
     Gosub VERIF_AUZBPR From SIXGAS
     If !GOK : Return : Endif
   Endcase
  Else
   # Erreur en lecture
   GOK = 0 : Call ECR_TRACE("GACCOUNT"-mess(49,125,1)-[F:XGAS]CLF,1) From GESECRAN : Break
  Endif
 Else
  [M:HAE2]ACC1(NOL) = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XGAS]CPT,"GACCOUNT","")
  Call LECTURE("GAC",[M:HAE2]ACC1(NOL),[L]COAGEN) From CONTOBJ
  [M:HAE2]SAC1(NOL) = ""
  [M:HAE2]BPR(NOL) = ""
 Endif
 Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
 [M:HAE2]FCYLIN(NOL) = [F:CPY]MAIFCY
 [M:HAE2]DES(NOL) = [F:XGAS]LIBECR
 If [F:XGAS]CODLTR<>""
  ## Référence libre : si l'écriture a été lettrée dans l'Intégrale, on met dans la référence libre :
  ## [Code lettrage Intégrale]+[Compte]+[Tiers]. Ceci permettra de relancer un lettrage automatique dans X3
  ## pour relettrer les écritures
  If [F:XGAS]CLF<>""
   [M:HAE2]FREREF(NOL) = [F:XGAS]CODLTR+" "+[F:XGAS]CLF+" "+[F:XGAS]CPT+string$(len([F:XGAS]CODLTR+" "+[F:XGAS]CLF+" "+[F:XGAS]CPT),"*")
  Else
   [M:HAE2]FREREF(NOL) = [F:XGAS]CODLTR+" "+[F:XGAS]CPT
  Endif
 Else
  ## Référence libre : Si l'écriture n'a pas été lettrée dans l'Intégrale, on met dans la référence libre :
  ## Le numéro de pièce, s'il y en a une. Le libellé de l'écriture dans le cas contraire. Ceci permettra
  ## de lettrer par exemple des factures dont le règlement est saisi directement en compta dans X3
  #If [F:XGAS]NUMPIEFIN<>""
  # [M:HAE2]FREREF(NOL) = [F:XGAS]NUMPIEDEB+" "+[F:XGAS]NUMPIEFIN
  #Else
  # [M:HAE2]FREREF(NOL) = [F:XGAS]LIBECR
  #Endif
 Endif
 ## On initialise le code taxe de la même manière qu'en saisie de pièce comptable. Après reprise des comptes,
 ## il sera recommandé de renseigner le codes taxes par défaut sur les comptes pour que les écritures reprises
 ## soient rattachées au bon code taxe. En outre, on laissera la possibilité de prendre la main dans le
 ## traitement de reprise des écritures pour changer l'initialisation de certaines données
 If [F:GAC]COA=[L]COAGEN & [F:GAC]FLGVAT=1
  [M:HAE2]TAX(NOL) = ""
 Else
  # Paramètre EXETAX (Tronc commun)
  If dim(GEXETAX)>0 : [M:HAE2]TAX(NOL) = GEXETAX : Endif
  # Code taxe renseigné au niveau du compte général
  If [F:GAC]VAT(0)<>"" : [M:HAE2]TAX(NOL) = [F:GAC]VAT(0) : Endif
  # Code taxe pas obligatoire au niveau du compte
  If dim(GSAITAX)>0 & GSAITAX=1 & [F:GAC]VAT(0)=""
   TIERS=""
   For I=0 To nolign-1
    If [M:HAE2]BPR(I)<>"" : TIERS=[M]BPR(I) : Break : Endif
   Next I
   If TIERS<>""
    TYPTIERS = " "
    Read [BPR]BPR0 = TIERS
    If !fstat
     If [F:BPR]BPCFLG=2 : TYPTIERS="C"
     Elsif [F:BPR]BPSFLG=2 : TYPTIERS="F"
     Endif
    Endif
    Call INIT_REGIME(TIERS,[M]FCYLIN(I),TYPTIERS,[L]VAC) From CPTSUB
    Call LEC_TVB(GCURLEG,[L]VAC) From CPTLEC
    If !fstat & [F:TVB]ENAFLG=2
     CODTAX = [F:TVB]VAT   # Code taxe associé au régime tiers
     If CODTAX<>""
      Look [TVT]TVT0 = CODTAX;GCURLEG
      If !fstat
       [M:HAE2]TAX(NOL) = CODTAX
      Else
       Look [TVT]TVT0 = CODTAX;""
       If !fstat
        [M:HAE2]TAX(NOL) = CODTAX
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
  If [M:HAE2]TAX(NOL) = ""
   [M:HAE2]TAX(NOL) = GEXETAX
  Endif
 Endif

 If [F:XGAS]SENECR = "C"
  If OKDEV
   If [F:XGAS]CODDVS = [L]DEVPCE
    [M:HAE2]CDT(NOL)  = [F:XGAS]MNTDBTDVS
   Elsif [F:XGAS]CODDVS = "" | [F:XGAS]CODDVS<>[L]DEVPCE
    ## La contre-valeur en devise de transaction des écritures rattachées à d'autres devises (société
    ## ou autres) sera calculée en prenant le cours de la 1ère écriture rattachée à la devise de reprise
    [M:HAE2]CDT(NOL)  = arr([F:XGAS]MNTDBTFRS*COURDEV, ARRONDI)
   Endif
  Else
   [M:HAE2]CDT(NOL)  = [F:XGAS]MNTDBTFRS
  Endif
  [L]TOTCDT    += [M:HAE2]CDT(NOL)
  [L]TOTCDTLOC += [F:XGAS]MNTDBTFRS
  Assign "[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
  Assign "[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
  Assign "[M]AMT"+num$(GTYPANA)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
  Assign "[M]AMTFRC"+num$(GTYPANA)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
 Elsif [F:XGAS]SENECR = "D"
  If OKDEV
   If [F:XGAS]CODDVS = [L]DEVPCE
    [M:HAE2]DEB(NOL) = [F:XGAS]MNTDBTDVS
   Elsif [F:XGAS]CODDVS = "" | [F:XGAS]CODDVS<>[L]DEVPCE
    ## La contre-valeur en devise de transaction des écritures rattachées à d'autres devises (société
    ## ou autres) sera calculée en prenant le cours de la 1ère écriture rattachée à la devise de reprise
    [M:HAE2]DEB(NOL)  = arr([F:XGAS]MNTDBTFRS*COURDEV,ARRONDI)
   Endif
  Else
   [M:HAE2]DEB(NOL) = [F:XGAS]MNTDBTFRS
  Endif
  [L]TOTDEB += [M:HAE2]DEB(NOL)
  [L]TOTDEBLOC += [F:XGAS]MNTDBTFRS
  Assign "[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
  Assign "[M]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
  Assign "[M]AMT"+num$(GTYPANA)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
  Assign "[M]AMTFRC"+num$(GTYPANA)+"("+num$(NOL)+")" With [F:XGAS]MNTDBTFRS
 Endif
 [M:HAE2]CHK(NOL) = [F:XGAS]CODDVS  # Zone renseignée temporairement (utile dans le cas du saupoudrage).

 Assign "[M]AMTFLG"+num$(GTYPGEN)+"("+num$(NOL)+")" With 1
 Assign "[M]AMTFLG"+num$(GTYPANA)+"("+num$(NOL)+")" With 1

 ## MAJ du montant de TVA déclarée (champ AMTVAT) pour les comptes soumis et les comptes de TVA
 If [M:HAE2]TAX(NOL)<>""
  Call LEC_TVT_LEG(GCURLEG,[M:HAE2]TAX(NOL)) From CPTLEC
  Gosub SENS_ECR From SIXGAS
  Call LECTURE("GAC",[M:HAE2]ACC1(NOL),[L]COAGEN) From CONTOBJ
  If [F:GAC]VATIPT <= 2 : # TVA collectée ventes ou collectée immos
   SIGN=-1
  Else
   SIGN=1 : # TVA déductible sur achats ou immos
  Endif
  [M:HAE2]AMTVAT(NOL) = [L]SIGN*[L]SNSECR*evalue("[M:HAE2]AMTFRC"+num$(GTYPGEN)+"("+num$(NOL)+")")
 Endif

 If [M:HAE2]SAC1(NOL)<>""
  ## On va se servir de la zone REFINTLIN pour stocker l'"adresse" des échéances et pour l'exploiter au
  ## moment où on récupèrera le (ou les) échéance(s)
  Raz COMP0, COMP1
  For I=1 To 4-len(num$([F:XGAS]NUMLOT))
   COMP0 += "0"
  Next
  For I=1 To 4-len(num$([F:XGAS]NUMORDLOT))
   COMP1 += "0"
  Next
  [M:HAE2]REFINTLIN(NOL) = COMP0+num$([F:XGAS]NUMLOT)+[F:XGAS]DATSAILOT+COMP1+num$([F:XGAS]NUMORDLOT)
 Endif

 Gosub INICNACCE
 [F:XGAS]FLGREP = 2
 Rewrite [F:XGAS]
 If fstat
  # Erreur d'écriture
  Call ECR_TRACE("XIBROCBGNR"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat)-num$([L]LOT)-[L]DATCPT-[L]TYPPIECE-[L]NUMPIECE-num$([F:XGAS]NUMORDLOT),1) From GESECRAN
  GOK = 0 : Break
 Endif

 [M:HAE2]NBLIG += 1

 ## Trop de lignes => On crée la pièce et on passe par un compte d'attente
 If (!OKDEV & [M:HAE2]NBLIG+1>=MAXECT) | (OKDEV & [M:HAE2]NBLIG+2>=MAXECT)
  If TOTDEB<>TOTCDT
   Gosub SOLDE From SIXGAS

    ## Rajout d'une ligne pour l'écart d'arrondi en devise : dans le cas où les écritures ont été reprises
    ## en devise, la contre-valeur en devise de transaction des écritures rattachées à d'autres devises (société
    ## ou autres) a été calculée en prenant le cours de la 1ère écriture rattachée à la devise de reprise.
    ## Si un écart est constaté, on l'enregistrera sur le compte GACRNDLOCC/GACCRNDLOCD (ou un paramètre au niveau
    ## de l'écran de lancement ?)
    ## Dans le cas où l'écart dépasse le montant d'écart paramétré, on reprendra la pièce en devise société

   If OKDEV
    Gosub GENECART From SIXGAS
   Endif

   Gosub VALPCE From SIXGAS
   If GOK<1 : Break : Endif

   STAT = 0 : SPSTAT = 0
   Raz [M:HAE0], [M:HAE1], [M:HAE2], [M:VTL], [M:VT2]
   Raz [M:HAE2]NBLIG
   NOL = [M:HAE2]NBLIG
   Gosub SOLDE_CPTATT From SIXGAS

  Else

   Gosub VALPCE From SIXGAS
   If GOK<1 : Break : Endif
   STAT = 0 : SPSTAT = 0
   Raz [M:HAE0], [M:HAE1], [M:HAE2], [M:VTL], [M:VT2]
   Raz [M:HAE2]NBLIG
   NOL = [M:HAE2]NBLIG

  Endif

 Endif

Next : # For [XGAS]CLE (parcours des écritures d'un même numéro de lot/date saisie lot

If GOK<1 : Return : Endif

## Création de la pièce (forcément la dernière du groupe)
If [M:HAE2]NBLIG>0
 Gosub VALPCE From SIXGAS
 If GOK<1 : Return: Endif
Endif
If GOK<1 : Return: Endif
Return


$INICNACCE
If OPTANA = 2 : # Reprise analytique de l'Intégrale
 REPART_ANA = 0
 Filter [XAA2] Where NUMLOT=[L]LOT & DATSAILOT=[L]DATCPT & NUMORDLOT=[F:XGAS]NUMORDLOT & NUMPIEDEB=[L]TYPPIECE & NUMPIEFIN=[L]NUMPIECE
 Read [XAA2] Last
 Filter [XAA2]
 If !fstat & [F:XAA2]NUMVTLLOT>1
  REPART_ANA = 1
 Endif

 FIRSTVENT = 1
 For [XGAA]CLE(5) Where NUMLOT=[L]LOT & DATSAILOT=[L]DATCPT & NUMPIEDEB=[L]TYPPIECE & NUMPIEFIN=[L]NUMPIECE
&                     & NUMORDLOT=[F:XGAS]NUMORDLOT
  If !REPART_ANA
   Gosub INICNA From SIXGAS
   If [M:HAE2]ACC2(NOL)<>""
    [M:HAE2]QTY(NOL) = [F:XGAA]QTE
    ## Le sous-programme INICCE va initialiser [M:HAE2]CCE1, [M:HAE2]CCE2,...
    Call INICCE([F:XGAA]SECANA,"[M:HAE2]CCE",NOL) From SIXGAS
   Endif
   [F:XGAA]FLGREP = 2
   Rewrite [F:XGAA]
   If fstat
    Call ECR_TRACE("Erreur d'écriture sur fichier XGAA"-func SIXFONCTION.FSTATMSG(fstat)-num$([L]LOT)-[L]DATCPT-[L]TYPPIECE-[L]NUMPIECE-num$([F:XGAA]NUMORDLOT),1) From GESECRAN
    GOK = 0 : Break
   Endif
  Else
   Gosub INICNA From SIXGAS
   If [M:HAE2]ACC2(NOL)<>""
    ## Parcours de toutes les répartitions analytiques
    For [XGAA]CLE
     Gosub VENTILE From SIXGAS
     If GOK<1 : Break 2 : Endif
    Next
   Endif
  Endif
 Next
 If GOK<1 : Return : Endif
 # Equilibrage de la ventilation (en rapport avec la demande 46730)
 If [M:HAE2]DEB(NOL)+[M:HAE2]CDT(NOL)<>sum([M:VT2]TBAMT([M:HAE2]PTV(NOL)..[M:HAE2]PTF(NOL)))
  [M:VT2]TBAMT([M:HAE2]PTF(NOL)) = [M:HAE2]DEB(NOL)+[M:HAE2]CDT(NOL)-sum([M:VT2]TBAMT([M:HAE2]PTV(NOL)..[M:HAE2]PTF(NOL)-1))
 Endif
Else : # Initialisation analytique via une section par défaut définie dans l'écran de paramétrage
 FIRSTVENT = 0
 Gosub INICNA From SIXGAS
 For AXE=1 To GOPTCANA
  [M:HAE0]CPY    = [L]SOCIETE
  [M:HAE0]FCY    = [L]SITE
  [M:HAE0]JOU = func SIXFONCTION.SI_COR("XIJRN",[F:XGAS]CODJRN,"GJOURNAL","")
  Call INISEC(SECTION,[L]CCEDEF,"AX"+num$(AXE)) From SUBCDE
  Assign "[M:HAE2]CCE"+num$(AXE)+"("+num$(NOL)+")" With SECTION
 Next AXE
Endif
If GOK<1 : Return : Endif
Return

$CAS
## option 2 : on a demandé la reprise des pièces en devise. Plusieurs possibilités :
## 1/ La pièce ne comporte que des mouvements en devise société (=toutes les écritures ont le
##    champ CODDVS vide) => On reprend la pièce en devise société
## 2/ La pièce ne comporte que des mouvements autre que la devise société (=toutes les écritures ont le
##    champs CODDVS non vide et avec la même valeur) => On reprend la pièce en devise de transaction
##    (à condition que le groupe d'écritures est équilibrées en devise (théoriquement oui, mais on fera le
##    contrôle ($VERF_EQUI_DEV) et ce n'est pas le cas, on reprendra la pièce en devise de société)
## 3/ La pièce comporte des écritures en devise société et des écritures dans UNE autre devise (une seule
##    autre) => On reprend la pièce en devise de transaction
## 4/ La pièce comporte plusieurs devises autre que la devise de société et on a demandé
##    l'option de reprise en devise société dans le cas d'écritures multi-devises => On reprend
##    la pièce en devise société
## 5/ La pièce comporte plusieurs devises autre que la devise de société et
##    on a demandé l'option de reprise en sur la 1ère devise trouvée dans le cas d'écritures
##    multi-devises => On reprend la pièce dans la 1ère devise trouvée
NBDEV = 0
Raz TDEVISE
For [XGA3] Where NUMLOT=[F:XGAS]NUMLOT & DATSAILOT=[F:XGAS]DATSAILOT & NUMPIEDEB=[F:XGAS]NUMPIEDEB
&              & NUMPIEFIN=[F:XGAS]NUMPIEFIN
 If !find([F:XGA3]CODDVS,TDEVISE(1..NBDEV))
#  NBDEV+=1
  If [F:XGA3]CODDVS <> ""
   NBDEV+=1
   [L]TDEVISE(NBDEV) = [F:XGA3]CODDVS
#  Elsif [F:XGA3]CODDVS <> ""
#   [L]TDEVISE(NBDEV) = [L]CODDVS : # Si vide, =devise société
  Else
   If !find([L]DEVLOC,TDEVISE(1..NBDEV))
    NBDEV+=1
    [L]TDEVISE(NBDEV) = [L]DEVLOC : # Si vide, =devise société
   Endif
  Endif
 Endif
Next
If NBDEV=1 & TDEVISE(1)=[L]DEVLOC
 CAS = 1
Elsif NBDEV=1 & TDEVISE(1)<>[L]DEVLOC
 CAS = 2
 [L]DEVISE = TDEVISE(1) : Gosub VERF_EQUI_DEV
 If !EQUIDEV : CAS = 1 : Endif
Elsif NBDEV=2 & find([L]DEVLOC,TDEVISE(1..2))
 CAS = 3
Elsif [L]OPTMULTIDEV=1 & (NBDEV=2 & !find([L]DEVLOC,TDEVISE(1..2))) | NBDEV>2
 CAS = 4
Elsif [L]OPTMULTIDEV=2 & (NBDEV=2 & !find([L]DEVLOC,TDEVISE(1..2))) | NBDEV>2
 CAS = 5
Endif
Return


$VERF_EQUI_LOC
TOTDEB = 0 : TOTCDT = 0 : NBECT = 0 : EQUILIBRE = 0
For [XGA3] Where NUMLOT=[F:XGAS]NUMLOT & DATSAILOT=[F:XGAS]DATSAILOT & NUMPIEDEB=[F:XGAS]NUMPIEDEB & NUMPIEFIN=[F:XGAS]NUMPIEFIN
 If [F:XGA3]SENECR = "C"
  TOTCDT += [F:XGA3]MNTDBTFRS
 Elsif [F:XGA3]SENECR = "D"
  TOTDEB += [F:XGA3]MNTDBTFRS
 Endif
 NBECT += 1
Next
If TOTCDT = TOTDEB
 [L]DEVPCE = [L]DEVLOC
 EQUILIBRE = 1
Endif
Return


$VERF_EQUI_DEV
TOTDEB = 0 : TOTCDT = 0 : EQUIDEV = 0
## Les écritures en devise sont-elles équilibrées ???
For [XGA3] Where NUMLOT=[F:XGAS]NUMLOT & DATSAILOT=[F:XGAS]DATSAILOT & NUMPIEDEB=[F:XGAS]NUMPIEDEB
&              & NUMPIEFIN=[F:XGAS]NUMPIEFIN & CODDVS=[L]DEVISE
 If [F:XGA3]SENECR = "C"
  TOTCDT    += [F:XGA2]MNTDBTDVS
 Elsif [F:XGA3]SENECR = "D"
  TOTDEB += [F:XGA3]MNTDBTDVS
 Endif
Next
If TOTCDT = TOTDEB
 EQUIDEV = 1
Else
 EQUIDEV = 0
Endif
Return
