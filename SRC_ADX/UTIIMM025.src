#<AdxTL>@(#)5.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : MDJ
# LE          : 14 Février   2011 09:03:06
# Moulinette pour suppression  données de la table DIV 591 (utilisée par ailleurs par le traitement de migration FASMAJ30)
# FQ70746
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM025: Raz table diverse 591") From LECFIC
  Call EXE_UTIIMM025(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTIIMM025(APPLI)
 Value Char APPLI
  If clalev([F:ADI]) : Close Local File [ADI] : Endif
  Local File =APPLI+".ATABDIV" [ADI]
  Call ECR_TRACE("UTIIMM025: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM025
  Call ECR_TRACE("UTIIMM025: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM025
  ########################################
  # AJOUTER ICI LE CODE DE LA MOULINETTE #
  ########################################

  #----- Variables locales -----#
Local Char     WMSG(80)
Local Integer OK, GOK

 GOK = 1
 #-----
#-------------------------------#
#   mise a jour table ATABDIV   #
#-------------------------------#
Trbegin [ADI]
Delete[ADI] Where NUMTAB=591
If fstat : GOK=0 : Endif

If !GOK Then
  Goto AB_UTIIMM025
Else
  Commit
  Call ECR_TRACE("UTIIMM025 : Update ADI table 591 : lines deleted  "+APPLI,0) From GESECRAN
Endif

Return

$AB_UTIIMM025
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  #If APPLI<>GDOSX3 : End : Endif
  If filinfo(filpath("FIL","ATABDIV","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM025(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  #If APPLI<>GDOSX3 : End : Endif
  If filinfo(filpath("FIL","ATABDIV","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM025(APPLI)
End
