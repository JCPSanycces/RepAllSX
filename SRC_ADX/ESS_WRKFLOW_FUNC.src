$ADDLINE_ESSWRKEMP
Local Integer L
#Intiate workflow class
Local Instance  I_ESSWRKEMP  Using C_ESSWRKEMP
I_ESSWRKEMP         = NewInstance C_ESSWRKEMP AllocGroup null
CLASS_INIT_WRKFLOW  = fmet I_ESSWRKEMP.AINIT()

If CLASS_INIT_WRKFLOW = [V]CST_AOK
  Local File ESSWRKEMP [EWID1]
  #Class transfer
  Raz [EWID1]
#  SetInstanceNoSys [F:EWID1] With STRUCTURE
#  SetInstanceNoSys I_ESSWRKEMP With [F:EWID1]
  SetInstance [F:EWID1] With STRUCTURE
  SetInstance I_ESSWRKEMP With [F:EWID1]
  I_ESSWRKEMP.UID        = WRKFLW_UID       #Generated from the Workflow table (WRKFLW_UID)
  I_ESSWRKEMP.CHRONO     = num$(CHRONO)     #Generated from the Workflow table (CHRONO)
  I_ESSWRKEMP.CHRONO2    = num$(CHRONO)     #Generated from the Workflow table (CHRONO)
  I_ESSWRKEMP.REFNUM     = VALPKEY(0)
  I_ESSWRKEMP.WRK        = V_WRK

  #Write the class
  WRITE_WRKFLOW_CLASS = fmet I_ESSWRKEMP.AINSERT()
  If ([L]WRITE_WRKFLOW_CLASS >= [V]CST_AERROR)
    #Handle Error
    Gosub SET_RETVAL
    VCLASS_ERROR = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE_INST(I_ESSWRKEMP)
  Endif
  LogicClose File [EWID1]
  FreeGroup I_ESSWRKEMP
Else
  #TODO: JOJAC Apply to all
  Gosub HANDLE_VCLASS_ERROR_INIT
Endif
Return

