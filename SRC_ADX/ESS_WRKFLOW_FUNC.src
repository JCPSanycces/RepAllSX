$DECLARE_LOCAL_GENESSWRKFLOW
#Local variables
Local Char PROG(100), PROGTYP(100)
Local Integer K, I, RETVAL
Local Clbfile OLDVAL,NEWVAL
Local Integer COLIND
Local Integer WRKFLW_UID
Local Integer RETVALTYP, CHRONO
Local Char SYSPROP(GLONAVA)(1..)
Local Char CLS_TABLE(GLONATB)
Local Char TABLE_ABR(GLONABR)
Local Char FUNC_OBJVAR(100),FUNC_OBJVAR_SNAP(100)
Local Char TEST(50)
Local Integer CLASS_INIT_WRKFLOW, WRITE_WRKFLOW_CLASS,STAT
Local Integer MAINRECORD,CHANGEFOUND
Local Char WRKMSG(250)
COLIND = 1
MAINRECORD  = [V]CST_AYES
Return

$SET_PROG_SYS
PROG="func"-seg$(adxpno(0),instr(1,adxpno(0),"/")+1,instr(1,adxpno(0),"$")-1)+ ".PARSE_CLASS_VAL"
PROGTYP="func"-seg$(adxpno(0),instr(1,adxpno(0),"/")+1,instr(1,adxpno(0),"$")-1)+ ".GETFIELD_TYP"
#Set system properties
RETVAL = func SET_SYPROP(VSYSPROP)
Return

$PASS_CLASSES_WORKFLOW_VARIABLES
Local Integer CLASS_WRKFLOW, COLLECTION_IND, CLASSPARAMFNC
Local Integer CLASS_INIT_WRKFLOW
Local Integer FUNC_RETVAL, WRITE_WRKFLOW_CLASS
Local Char MAIN_CLASSCOD(GLONACLA),CLASSCOD(GLONACLA)
Local Char CTABLE(GLONATB)
Local Char CABR(GLONABR)
Local Char CLASS_ERROR(250)
Local Char SYSPROP(GLONAVA)(1..)
Local Char ALPKEY(250)(3)
Local Integer INTKEY(3)
Local Date DATKEY(3)
Local Char THISUSR(GLONAUS)
Local Integer TRANSACTION_PENDING
Local Char  CLEOBJ(250)
Local Char WRK(1) #C,M,D
Local Integer TRG_WRKFLW

Local Integer SET_SYSPROP
Local Integer COLCOUNT
Local Char LINSTAT(1)

#FRLAA X3-91918 2018-05-29 - START
#Assign values
[L]THISUSR              = this.ACTX.USER
[L]COLLECTION_IND       = 1
[L]CLASS_WRKFLOW        = [V]CST_AOK
[L]CLASSPARAMFNC        = [V]CST_AOK
[L]TRG_WRKFLW           = [V]CST_ANO
[L]SET_SYSPROP          = func SET_SYPROP(SYSPROP)

#FRLAA X3-91918 2018-05-29 - END

Return

$HANDLE_CLASS_WRKFLOW
If RETVAL >= [V]CST_AERROR
  If TRANSACTION_PENDING=0 : Rollback : Endif
Endif
If RETVAL = [V]CST_AOK
  If TRANSACTION_PENDING=0 : Commit : Endif
  STAT = func EMPLOIDESS_CSTD_EVT.EMPLOYEE_WORKFLOW(V_EMPLOIDESS,VCLEOBJ)
Endif

Return

$HANDLE_ESS_WRKFLOW_TRN
If TRANSACTION_PENDING<>0 : Return : Endif
If RETVAL = [V]CST_AOK
  Commit
Else
  Rollback
Endif
Return


#All functions for People ESS to create staging classes for worklow
#Some ESS Classes can not be allowed to write to the actual record with a status change



#**
#* Check all the properties in the class - write any changes to worklow staging class
#* @param STRUCTURE , Class - no internal declaration
#* @param VTABLE Value Char, Main table linked to the class
#* @param VABR Value Char, Main table abbr. linked to the class
#* @param VCLASS_ERROR Value Char, Returns the error on the class
#* @param VSYSPROP Value Char, An array indicating properties to exclude - -system properties will be excluded in this function
#* @return RETVAL Local Integer
#*!
Funprog GENESSWRKFLOW_DETAIL(STRUCTURE,VTABLE,VABR,VCLASS_ERROR,VSYSPROP)
Value Char VTABLE,VABR,VSYSPROP
Variable Char VCLASS_ERROR
#Local variables
Local Char PROG(100)
Local Integer K, I, RETVAL
Local Clbfile OLDVAL,NEWVAL
Local Integer COLIND
Local Integer RETVALTYP
Local Char SYSPROP(GLONAVA)(1..)
Local Char CLS_TABLE(GLONATB)
Local Char TABLE_ABR(GLONABR)
Local Char FUNC_OBJVAR(100),FUNC_OBJVAR_SNAP(100)
Local Char TEST(50)
Local Integer CLASS_INIT_WRKFLOW, WRITE_WRKFLOW_CLASS
COLIND = 1


#Set the calling function to parse values
PROG="func"-seg$(adxpno(0),instr(1,adxpno(0),"/")+1,instr(1,adxpno(0),"$")-1)+ ".PARSE_CLASS_VAL"
PROGTYP="func"-seg$(adxpno(0),instr(1,adxpno(0),"/")+1,instr(1,adxpno(0),"$")-1)+ ".GETFIELD_TYP"
#Set system properties
RETVAL = func SET_SYPROP(VSYSPROP)
RETVAL = [V]CST_AWARNING

K = STRUCTURE.ObjectNbs
For I = 1 To K
  If find(STRUCTURE.ObjectVar(I),VSYSPROP)=0
    FUNC_OBJVAR = "(STRUCTURE."+STRUCTURE.ObjectVar(I)+")"
    FUNC_OBJVAR_SNAP = "(STRUCTURE.snapshot."+STRUCTURE.ObjectVar(I)+")"
    OLDVAL = evalue(PROG+FUNC_OBJVAR_SNAP)
    NEWVAL = evalue(PROG+FUNC_OBJVAR)
    If (NEWVAL<>OLDVAL)
      RETVAL = [V]CST_AOK
      RETVALTYP = evalue(PROGTYP+FUNC_OBJVAR)
      #Change found - Create record in worklfow
      Gosub ADDLINE_ESSWRKFLWDET
      If (WRITE_WRKFLOW_CLASS >= [V]CST_AERROR)
        RETVAL = [V]CST_AERROR
        Break
      Endif
    Endif
  Endif
Next I
End RETVAL


$ADDLINE_ESSWRKFLWDET
Local Integer L
#Intiate workflow class
Gosub INIT_WORKFLOW_CLASS

If CLASS_INIT_WRKFLOW = [V]CST_AOK
  Local File EMPLOID [ID]

  I_ESSWRKFLWDET.USR          = V_THISUSR
  I_ESSWRKFLWDET.REFNUM       = fmet I_ESSWRKFLWDET.ACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
  #The workflow will update the CHEF field from DEST field in AWRKHISS
  #I_ESSWRKFLWDET.CHEF         = fmet I_ESSWRKFLWDET.ACTX.ACACHE.CHEFESS.AGETVALCHAR(GACTX.USER,"CHEF")
  If V_WRK = "C"
    I_ESSWRKFLWDET.FLDTYP       = 99
    I_ESSWRKFLWDET.FLDNAM       = "NEW"
  Elsif V_WRK = "D"
    I_ESSWRKFLWDET.FLDTYP       = 99
    I_ESSWRKFLWDET.FLDNAM       = "DEL"
  Else
    If MAINRECORD = [V]CST_AYES
      I_ESSWRKFLWDET.FLDTYP       = 99
      I_ESSWRKFLWDET.FLDNAM       = "MAIN"
    Else
      I_ESSWRKFLWDET.FLDTYP       = RETVALTYP
      I_ESSWRKFLWDET.FLDNAM       = num$(STRUCTURE.ObjectVar(I))
    Endif
  Endif
  I_ESSWRKFLWDET.CTRNUM       = func GETACTCONTRACT(I_ESSWRKFLWDET.REFNUM)
  I_ESSWRKFLWDET.NEWVAL       = NEWVAL
  I_ESSWRKFLWDET.OLDVAL       = OLDVAL
  I_ESSWRKFLWDET.CODFIC       = VTABLE
  I_ESSWRKFLWDET.ABRFIC       = VABR
  I_ESSWRKFLWDET.CLA          = VCLASSCOD
  #Keys
  I_ESSWRKFLWDET.ALPKEY1     = VALPKEY(0)
  I_ESSWRKFLWDET.ALPKEY2     = VALPKEY(1)
  I_ESSWRKFLWDET.ALPKEY3     = VALPKEY(2)
  I_ESSWRKFLWDET.INTKEY1     = VINTKEY(0)
  I_ESSWRKFLWDET.INTKEY2     = VINTKEY(1)
  I_ESSWRKFLWDET.INTKEY3     = VINTKEY(2)
  I_ESSWRKFLWDET.DATKEY1     = VDATKEY(0)
  I_ESSWRKFLWDET.DATKEY2     = VDATKEY(1)
  I_ESSWRKFLWDET.DATKEY3     = VDATKEY(2)
  #Technical properties and Key fields
  If CHANGEFOUND = [V]CST_AYES
     WRKFLW_UID                = uniqid([ID])
  Endif

  I_ESSWRKFLWDET.UID        = WRKFLW_UID
  VCLEOBJ                   = num$(WRKFLW_UID)+"~"+VCLASSCOD+"~"+num$(I_ESSWRKFLWDET.REFNUM)+"~"+num$(MAINRECORD)+"~"+I_ESSWRKFLWDET.FLDNAM
  CHRONO                    =-adxuid(2)
  I_ESSWRKFLWDET.CHRONO     = num$(CHRONO)
  I_ESSWRKFLWDET.CHRONO2    = num$(CHRONO)
  I_ESSWRKFLWDET.STA        = 2 #Request
  I_ESSWRKFLWDET.FLGSIG     = 3 #To be signed
  I_ESSWRKFLWDET.WRK        = V_WRK
  I_ESSWRKFLWDET.MAIREC     = MAINRECORD
  If MAINRECORD = [V]CST_AYES
    I_ESSWRKFLWDET.MSG      = WRKMSG
  Else
    WRKMSG+=VTABLE+"("+num$(STRUCTURE.ObjectVar(I))+":"-OLDVAL+"-"+NEWVAL+"),"
  Endif
  #Write the class
  WRITE_WRKFLOW_CLASS = fmet I_ESSWRKFLWDET.AINSERT()
  If ([L]WRITE_WRKFLOW_CLASS >= [V]CST_AERROR)
    #Handle Error
    Gosub SET_RETVAL
    VCLASS_ERROR = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE_INST(I_ESSWRKFLWDET)
  Endif
  LogicClose File [ID]
  FreeGroup I_ESSWRKFLWDET
Else
  VCLASSCOD = "ESSWRKFLWDET"
  Gosub HANDLE_VCLASS_ERROR_INIT
Endif

Return



#**
#* Evaluate a property in a class - used to compare values for any class
#* @param SYPROP Char array, array to be populated with system properties
#* @return RETVAL Local Integer
#*!
Funprog SET_SYPROP(VSYSPROP)
Variable Char VSYSPROP
Local Integer RETVAL
RETVAL = [V]CST_AOK

VSYSPROP(1)="AATTRIBUTES"
VSYSPROP(2)="ACTX"
VSYSPROP(3)="AERROR"
VSYSPROP(4)="AINF"
VSYSPROP(5)="AKEYS"
VSYSPROP(6)="AORDER"
VSYSPROP(7)="APARENT"
VSYSPROP(8)="ASTALIN"
VSYSPROP(9)="AUUID"
VSYSPROP(10)="CREDATTIM"
VSYSPROP(11)="UPDDATTIM"
VSYSPROP(12)="CREUSR"
VSYSPROP(13)="UPDUSR"
VSYSPROP(14)="CRETIM"
VSYSPROP(15)="CREDATTIM"
VSYSPROP(16)="CREDAT"
VSYSPROP(17)="UPDDAT"
VSYSPROP(18)="UPDDATTIM"
VSYSPROP(19)="UPDTIM"

End RETVAL

#**
#* Evaluate a property in a class - used to compare values for any class
#* @param EVAL_VAL, contains the property MYCLASS.PRO - No type can be assigned
#* @return RETVAL Local Integer
#*!
Funprog PARSE_CLASS_VAL(EVAL_VAL)
Local Clbfile S_VAL
VRETVALTYP =  type(EVAL_VAL)
If VRETVALTYP < 200
  S_VAL+=num$(EVAL_VAL)
Endif
End S_VAL

Funprog GETFIELD_TYP(EVAL_VAL)
Local Clbfile S_VAL
VRETVALTYP =  type(EVAL_VAL)

End VRETVALTYP

$INIT_WORKFLOW_CLASS
Local Instance  I_ESSWRKFLWDET  Using C_ESSWRKFLWDET
I_ESSWRKFLWDET         = NewInstance C_ESSWRKFLWDET AllocGroup null
CLASS_INIT_WRKFLOW  = fmet I_ESSWRKFLWDET.AINIT()
Return

$FREE_WORKFLOW_CLASS
FreeGroup I_ESSWRKFLWDET
Return


#**
#* Check all the properties in the class - write any changes to worklow staging class
#* Get the main table details for the class passed
#* @param VCLASS Value Char(GONACLA), Class code
#* @param VTABLE Variable Char, Main table linked to the class
#* @param VABR Variable Char, Main table abbr. linked to the class
#* @return RETVAL Local Integer
#*!
Funprog GET_CLASS_PARAMETERS(VCLASS,VTABLE,VABR)
Value Char VCLASS
Variable Char VTABLE,VABR
Local Integer RETVAL
RETVAL = [V]CST_AERROR

#Manage the values for VTABLE, VABR in function - no need to duplicate check in calling procedure
Raz VTABLE
Raz VABR

Local File ACLASSE [ACLA]
Read [ACLA]ACLA0 = VCLASS
If fstat = [V]CST_AOK
  VTABLE  = [F:ACLA]TABREF
  If VTABLE <>AVOID.ACHAR
    Local File ATABLE [ATB]
    Read [ATB]CODFIC = VTABLE
    If fstat = [V]CST_AOK
      #Only set RETVAL here, we need all parameter data
      RETVAL  = [V]CST_AOK
      VABR = ABRFIC
    Endif
  Endif
Endif
End RETVAL


Funprog CHECK_CLASS_PROP(STRUCTURE,VFLDNAM)
Value Char VFLDNAM

#Local variables
Local Integer K, I, RETVAL
Local Char SYSPROP(GLONAVA)(1..)

#Set system properties
RETVAL = func SET_SYPROP(SYSPROP)
RETVAL = [V]CST_AWARNING

K = STRUCTURE.ObjectNbs
For I = 1 To K
  If find(STRUCTURE.ObjectVar(I),SYSPROP)=0
    If STRUCTURE.ObjectVar(I) = VFLDNAM
     RETVAL = [V]CST_AOK
     Break
    Endif
  Endif
Next I
End RETVAL


$OPEN_FILE_ESSWRKEMP
#Open EMPLORIB file to start transaction - This will only be used to rollback in the case of an error.
#Important to note that we need to test if there is already a transaction open
Local File EMPLOID [ID4]
TRANSACTION_PENDING = adxlog
If TRANSACTION_PENDING=0
 Trbegin [ID4]
Endif
Return

$CLOSE_FILE_ESSWRKEMP
LogicClose File [ID4]
Return

