#<AdxTL>@(#)0.0.0.0 $Revision$ 
#<AdxTL>@(#)0.0.0.0 $Revision$
#ESS_WRKFLOW_FUNC - Handle all workflow rules for employee records
#**
#* Check all the properties in the class - write any changes to worklow staging class
#* @param V_THISUSR , Current context user
#* @param V_EMPLORIBESS , Class - EMPLORIBESS - Banking information
#* @param STRUCTURE , Class - EMPLORIBESS - Banking information ( Used to keep function generic)
#* @param VCLASSCOD Value Char, The ESS Class where the change occurred
#* @param VTABLE Value Char, Main table linked to the class
#* @param VABR Value Char, Main table abbr. linked to the class
#* @param VCLASS_ERROR Value Char, Returns the error on the class
#* @param VSYSPROP Value Char, An array indicating properties to exclude  -system properties will be excluded in this function
#* @param VALPKEY Value Char, Char array containing fields in the key of the main table
#* @param VINTKEY Value Integer, Integer array containing fields in the key of the main table
#* @param VDATKEY Value Date, Date array containing fields in the key of the main table
#* @return RETVAL Local Integer
#*!

#ESSWRKEMP
Funprog GENESSWRKFLOW_ESSWRKEMP(V_WRK,V_EMPLOIDESS, V_THISUSR,V_EMPESS,STRUCTURE,VCLASSCOD,VTABLE,VABR,VCLASS_ERROR,VSYSPROP,VALPKEY,VINTKEY,VDATKEY,VCLEOBJ)
Variable Instance V_EMPLOIDESS Using C_EMPLOIDESS
Value Char VALPKEY,V_WRK
Value Date VDATKEY
Value Integer VINTKEY
Variable Instance V_EMPESS Using C_EMPESS
Value Char VTABLE,VABR,VSYSPROP,VCLASSCOD,V_THISUSR
Variable Char VCLASS_ERROR,VCLEOBJ
Local Char TEXTABLE(GLONATB) :  TEXTABLE = VTABLE

#Set return value - All functions
RETVAL = [V]CST_AOK

#Declare variables - All functions
Gosub DECLARE_LOCAL_GENESSWRKFLOW

#Open file and begin transaction
Gosub OPEN_FILE_EMPLOID #Open own file

#Check the workflow code and manage
If V_WRK = "C"
  Gosub CREATION_ESSWRKFLWDET
  If RETVAL = [V]CST_AOK
    Gosub ADDLINE_ESSWRKEMP #Add own sub for class
  Endif
  Gosub HANDLE_CLASS_WRKFLOW From ESS_WRKFLOW_FUNC
  End RETVAL #Always return
Elsif V_WRK = "D"
  Gosub DELETE_ESSWRKFLWDET
  If RETVAL = [V]CST_AOK
    Gosub ADDLINE_ESSWRKEMP #Add own sub for class
  Endif
  Gosub HANDLE_CLASS_WRKFLOW From ESS_WRKFLOW_FUNC
  End RETVAL #Always return
Endif

#-----------------The following procedure will be used for modified records only------------------------------#

#Set the calling function to parse values and setting system properties - Generic for all functions
#These properties will be additional to the manual properties before the call
Gosub SET_PROG_SYS

K = STRUCTURE.ObjectNbs
For I = 1 To K
  If find(STRUCTURE.ObjectVar(I),VSYSPROP)=0
    FUNC_OBJVAR = "(STRUCTURE."+STRUCTURE.ObjectVar(I)+")"
    FUNC_OBJVAR_SNAP = "(STRUCTURE.snapshot."+STRUCTURE.ObjectVar(I)+")"
    OLDVAL = evalue(PROG+FUNC_OBJVAR_SNAP)
    NEWVAL = evalue(PROG+FUNC_OBJVAR)
    If (NEWVAL<>OLDVAL)
      If CHANGEFOUND = [V]CST_AYES
        CHANGEFOUND = [V]CST_ANO
      Elsif CHANGEFOUND = [V]CST_ANO
        #Keep value
      Else
        CHANGEFOUND = [V]CST_AYES
      Endif

      MAINRECORD  = [V]CST_ANO
      RETVALTYP = evalue(PROGTYP+FUNC_OBJVAR)
      #Change found - Create record in EMPLORIB Workflow table
      Gosub ADDLINE_ESSWRKFLWDET

      If (RETVAL >= [V]CST_AERROR)
        Break
      Endif
    Endif
  Endif
Next I

If (CHANGEFOUND = [V]CST_AYES or CHANGEFOUND = [V]CST_ANO)  and RETVAL = [V]CST_AOK
  MAINRECORD  = [V]CST_AYES
  CHANGEFOUND = [V]CST_ANO

  Gosub ADDLINE_ESSWRKFLWDET
  #Change found - Create record in worklfow
  Gosub ADDLINE_ESSWRKEMP #Add own sub for class

#ASTATUS=fmet V_EMPLOIDESS.ASETERROR("",num$(RETVAL),[V]CST_AINFO)

  Gosub HANDLE_CLASS_WRKFLOW From ESS_WRKFLOW_FUNC
Endif
End RETVAL

