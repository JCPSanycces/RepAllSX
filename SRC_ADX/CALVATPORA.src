#<AdxTL>@(#)3.0.0.0 $Revision$
####################################################################################
####################################################################################
### DVPB0 = DCLNUM+RECTYP+NUM+LIN+DCLFLD+DCLPAG
### DCLTYP, DCLNUM feeded on CALVATPOR
### DCLFLD feeded on label PROCESS_DAE
### DCLPAG feeded on label MAIN
####################################################################################
####################################################################################
$MAIN

GPOINT = "SET_TAXIGNORE" : Gosub ENTREE From EXEFNC

Call DEBTRANS From GLOCK
Trbegin [F:DVPB], [F:DVPF], [F:DVPL]
Delete [F:DVPB] Where [F:DVPB]DCLNUM=[L]DCLNUM
If fstat = 1 : GOK=0 : Call RSTA("DVPB",[L]DCLNUM) From GLOCK : Rollback : Return : Endif
Delete [F:DVPF] Where [F:DVPF]DCLNUM=[L]DCLNUM
If fstat = 1 : GOK=0 : Call RSTA("DVPF",[L]DCLNUM) From GLOCK : Rollback : Return : Endif
Delete [F:DVPL] Where [F:DVPL]DCLNUM=[L]DCLNUM
If fstat = 1 : GOK=0 : Call RSTA("DVPL",[L]DCLNUM) From GLOCK : Rollback : Return : Endif

Link [F:DAEP] With [F:GACP]GAC0=[L]COA;[F:DAEP]ACC As [LDAEP]
& Where [F:DAEP]LEDTYP= [F:DVPP]LEDTYP & [F:GACP]FLGVAT>1

Filter [F:HAE] Where [F:HAE]CPY=[L]CPY & [F:HAE]ACCDAT>=[L]STRDAT & [F:HAE]ACCDAT<=[L]ENDDAT
[L]RMAX = rowcount([F:HAE])
Filter [F:HAE]

Call OUVRE_BOITE(mess(1,3614,1) - [L]DCLNUM,[L]RMAX) From GESECRAN

[L]RCOUNT = 0

For [F:HAE] Where [F:HAE]CPY=[L]CPY & [F:HAE]ACCDAT>=[L]STRDAT & [F:HAE]ACCDAT<=[L]ENDDAT
#If [F:HAE]NUM = 'FCL-POR0213/00000008' | [F:HAE]NUM = "AVNPOR1_030300000001" : Dbgaff : Endif
  Gosub GETGTE From CALVATPOR
  Gosub GETJOU From CALVATPOR
  Raz [L]EXCACCFLG

  If [F:GTE]VAT=2

    For [F:LDAEP] Where [F:DAEP]TYP=[F:HAE]TYP & [F:DAEP]NUM=[F:HAE]NUM
      If pat([F:DAEP]ACC,[F:DVPP]RCAEXNROT1+string$(len([F:DVPP]RCAEXNROT1)=0,"\")+"*") | pat([F:DAEP]ACC,[F:DVPP]RCAEXNROT2+string$(len([F:DVPP]RCAEXNROT2)=0,"\")+"*") |
&        pat([F:DAEP]ACC,[F:DVPP]RCAEXNROT3+string$(len([F:DVPP]RCAEXNROT3)=0,"\")+"*") | pat([F:DAEP]ACC,[F:DVPP]RCAEXNROT4+string$(len([F:DVPP]RCAEXNROT4)=0,"\")+"*")
        [L]EXCACCFLG = 1
      Else
        # Issue  X3-101932 - 2018-08-29 by VAVIL - Customers / Recap – Suppliers detail and EENCUM group in main declaration
        Gosub GET_EECNUM From CALVATPOR
        If [L]EECNUM = "" | (len([L]EECNUM)>2 & left$([L]EECNUM, 2) <> "PT") | [F:BPR]LEGETT = 2 : [F:DVPB]EECNUM = "" : Endif
        # Issue end
        [L]DCLPAG = 1
        Gosub PROCESS_DAE
        If GOK=0 : Break 2 : Endif
        If [F:DVPH]AN1LOC > 0 & [F:DVPH]AN1LOC < 4
          [L]DCLPAG = 2
          Gosub PROCESS_DAE
          If GOK=0 : Break 2 : Endif
        Endif
        If [F:DVPH]AN2LOC > 0 & [F:DVPH]AN2LOC < 4
          [L]DCLPAG = 3
          Gosub PROCESS_DAE
          If GOK=0 : Break 2 : Endif
        Endif
      Endif
    Next

    If [F:DVPH]BPCFLG = 2 & [F:LDAEP]TAX <> ""
      [L]RECTYP = 2
      [L]DCLPAG = 0
      Gosub MAIN From CALVATPORAR
      If GOK=0 : Break : Endif
    Endif

    If [F:DVPH]BPSFLG = 2 & [F:LDAEP]TAX <> ""
      [L]RECTYP = 3
      [L]DCLPAG = 0
      Gosub MAIN From CALVATPORAR
      If GOK=0 : Break : Endif
    Endif

  Endif

  [L]RCOUNT += 1
  If mod([L]RCOUNT,1000) = 2
    Call AFF_BOITE(mess(1,20,1),[L]RCOUNT,I) From GESECRAN
  Endif

Next

If clalev([F:LDAEP]) : Close File [LDAEP] : Endif

Call FERME_BOITE From GESECRAN
If GOK=0 : Rollback : Return : Endif
Commit

GOK = 1
Trbegin  [F:DVPF], [F:DVPL]

Gosub PROC_FIELDS
If GOK=0 : Rollback : Return : Endif

If [F:DVPH]BPCFLG = 2 | [F:DVPH]BPSFLG = 2
  Gosub PROC_LISTS  From CALVATPORAR
Endif

If GOK=0 : Rollback : Return : Endif
Commit

Return
######################################################################################
######################################################################################
$PROCESS_DAE
[L]RECTYP = 0

#-------------------------------------------------------------------------------------
#------------------- Bloc 3 - (Sales) ----------------
#-------------------------------------------------------------------------------------
If ([F:GACP]FLGVAT=2 or [F:GACP]FLGVAT=5) # VAT Submited (VAT base) or prepayment

  If [F:GACP]VATIPT=1 | ([F:GACP]VATIPT=7 & pat([F:DAEP]ACC, [F:DVPP]SALGOOROT+"*"))                           :#Conta de liquidação de bens ou (regularizações a favor da empresa e 71)

    If find([F:DAEP]TAX, VAT001([L]DCLPAG,1..dim(VAT001,2))) & [F:DAEP]TAX <> ""                                               :#CAMPO 1 tx reduzida
       [L]SNS = -1 : [L]DCLFLD = "01" : Gosub WRITE_DVPB : Return
    Endif
    If find([F:DAEP]TAX, VAT002([L]DCLPAG,1..dim(VAT002,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 2 tx intermédia
       [L]SNS = -1 : [L]DCLFLD = "02" : Gosub WRITE_DVPB : Return
    Endif
    If find([F:DAEP]TAX, VAT003([L]DCLPAG,1..dim(VAT003,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 3 tx normal
       [L]SNS = -1 : [L]DCLFLD = "03" : Gosub WRITE_DVPB : Return
    Endif
    If find([F:DAEP]TAX, VAT004([L]DCLPAG,1..dim(VAT004,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 4 isentas
       [L]SNS = -1 : [L]DCLFLD = "04" : Gosub WRITE_DVPB : Return
    Endif
    If find([F:DAEP]TAX, VAT005([L]DCLPAG,1..dim(VAT005,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 5 isentas
       [L]SNS = -1 : [L]DCLFLD = "05" : Gosub WRITE_DVPB : Return
    Endif
    If find([F:DAEP]TAX, VAT064([L]DCLPAG,1..dim(VAT064,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 64 Desp/residuos
       [L]SNS = -1 : [L]DCLFLD = "64" : Gosub WRITE_DVPB : Return
    Endif
    If find([F:DAEP]TAX, VAT065([L]DCLPAG,1..dim(VAT065,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 65 inversão SP
       [L]SNS = -1 : [L]DCLFLD = "65" : Gosub WRITE_DVPB : Return
    Endif
    ############# Bloc 05 Operações with exterior
    If find([F:DAEP]TAX, VAT041([L]DCLPAG,1..dim(VAT041,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 41 transmissões intracomunitárias
       [L]SNS = -1 : [L]DCLFLD = "41" : Gosub WRITE_DVPB : Return
    Endif
    If find([F:DAEP]TAX, VAT044([L]DCLPAG,1..dim(VAT044,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 44 exportações
       [L]SNS = -1 : [L]DCLFLD = "44" : Gosub WRITE_DVPB : Return
    Endif

    Elsif [F:GACP]VATIPT=8 | ([F:GACP]VATIPT=7 & pat([F:DAEP]ACC, [F:DVPP]SALSRVROT+"*"))   :# Venda serviços

        If find([F:DAEP]TAX, VAT007([L]DCLPAG,1..dim(VAT007,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 07 tx reduzida
           [L]SNS = -1 : [L]DCLFLD = "07" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT008([L]DCLPAG,1..dim(VAT008,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 08 tx interm
           [L]SNS = -1 : [L]DCLFLD = "08" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT009([L]DCLPAG,1..dim(VAT009,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 09 tx normal
           [L]SNS = -1 : [L]DCLFLD = "09" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT010([L]DCLPAG,1..dim(VAT010,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 10 tx isenta
           [L]SNS = -1 : [L]DCLFLD = "10" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT011([L]DCLPAG,1..dim(VAT011,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 11 tx isenta
           [L]SNS = -1 : [L]DCLFLD = "11" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT066([L]DCLPAG,1..dim(VAT066,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 66 sucatas
           [L]SNS = -1 : [L]DCLFLD = "66" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT067([L]DCLPAG,1..dim(VAT067,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 67 tx inv SP
           [L]SNS = -1 : [L]DCLFLD = "67" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT012([L]DCLPAG,1..dim(VAT012,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 12 transp.Intrac.
           [L]SNS = -1 : [L]DCLFLD = "12" : Gosub WRITE_DVPB : Return
        Endif

        ############# Quadro 05 Operações com o exterior
        If find([F:DAEP]TAX, VAT041([L]DCLPAG,1..dim(VAT041,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 41 transmissões intracomunitárias
           [L]SNS = -1 : [L]DCLFLD = "41" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT044([L]DCLPAG,1..dim(VAT044,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 44 exportações
           [L]SNS = -1 : [L]DCLFLD = "44" : Gosub WRITE_DVPB : Return
        Endif

    Elsif [F:GACP]VATIPT=2 | ([F:GACP]VATIPT=7 & (pat([F:DAEP]ACC, [F:DVPP]SALIMOLESROT+"*") | pat([F:DAEP]ACC, [F:DVPP]SALIMOPLUROT+"*")))   :# Venda imobilizado
        If find([F:DAEP]TAX, VAT014([L]DCLPAG,1..dim(VAT014,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 14 tx reduzida
           [L]SNS = -1 : [L]DCLFLD = "14" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT015([L]DCLPAG,1..dim(VAT015,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 15 tx int
           [L]SNS = -1 : [L]DCLFLD = "15" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT016([L]DCLPAG,1..dim(VAT016,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 16 tx nor
           [L]SNS = -1 : [L]DCLFLD = "16" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT068([L]DCLPAG,1..dim(VAT068,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 68 tx sucatas
           [L]SNS = -1 : [L]DCLFLD = "68" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT017([L]DCLPAG,1..dim(VAT017,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 17 tx viaturas turismo
           [L]SNS = -1 : [L]DCLFLD = "17" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT018([L]DCLPAG,1..dim(VAT018,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 18 tx Transmissões isentas
           [L]SNS = -1 : [L]DCLFLD = "18" : Gosub WRITE_DVPB : Return
        Endif

        ########## quadro 05 - operações com o exterior
        If find([F:DAEP]TAX, VAT037([L]DCLPAG,1..dim(VAT037,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 37 tx Transmissões intracomunitária
           [L]SNS = -1 : [L]DCLFLD = "37" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT040([L]DCLPAG,1..dim(VAT040,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 40 tx exportações
           [L]SNS = -1 : [L]DCLFLD = "40" : Gosub WRITE_DVPB : Return
        Endif

    #-------------------------------------------------------------------------------------
    #------------------- QUADRO 4 - TRANSMISSõES INTERNAS PASSIVAS (Compras)--------------
    #-------------------------------------------------------------------------------------
    Elsif [F:GACP]VATIPT=3 | ([F:GACP]VATIPT=6 & [F:GACP]CLSCOD = "3")   :#aquisição de existências
        If find([F:DAEP]TAX, VAT020([L]DCLPAG,1..dim(VAT020,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 20 tx viaturas de turismo
           [L]SNS = 1 : [L]DCLFLD = "20" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT069([L]DCLPAG,1..dim(VAT069,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 69 tx Transmissões isentas
           [L]SNS = 1 : [L]DCLFLD = "69" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT070([L]DCLPAG,1..dim(VAT070,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 70 tx locações
           [L]SNS = 1 : [L]DCLFLD = "70" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT021([L]DCLPAG,1..dim(VAT021,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 21 tx bens e serviços isentas
           [L]SNS = 1 : [L]DCLFLD = "21" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT022([L]DCLPAG,1..dim(VAT022,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 22 tx REI
           [L]SNS = 1 : [L]DCLFLD = "22" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT071([L]DCLPAG,1..dim(VAT071,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 71 tx aquisições isentas
           [L]SNS = 1 : [L]DCLFLD = "71" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT072([L]DCLPAG,1..dim(VAT072,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 72 tx Transmissões isentas
           [L]SNS = 1 : [L]DCLFLD = "72" : Gosub WRITE_DVPB : Return
        Endif

        ############ Quadro 05 - operações com o exterior
        If find([F:DAEP]TAX, VAT042([L]DCLPAG,1..dim(VAT042,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 42 tx aquisições intracomunitárias
           [L]SNS = 1 : [L]DCLFLD = "42" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT043([L]DCLPAG,1..dim(VAT043,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 43 tx importações
           [L]SNS = 1 : [L]DCLFLD = "43" : Gosub WRITE_DVPB : Return
        Endif

    Elsif [F:GACP]VATIPT=5 | ([F:GACP]VATIPT=6 & [F:GACP]CLSCOD = "6")   :#aquisição de existências
        If find([F:DAEP]TAX, VAT024([L]DCLPAG,1..dim(VAT024,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 24 tx viaturas turismo
           [L]SNS = 1 : [L]DCLFLD = "24" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT073([L]DCLPAG,1..dim(VAT073,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 73 tx outros
           [L]SNS = 1 : [L]DCLFLD = "73" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT025([L]DCLPAG,1..dim(VAT025,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 25 tx parcial/ dedutivel
           [L]SNS = 1 : [L]DCLFLD = "25" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT026([L]DCLPAG,1..dim(VAT026,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 26 tx gasolina
           [L]SNS = 1 : [L]DCLFLD = "26" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT027([L]DCLPAG,1..dim(VAT027,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 27 tx viaturas turismo
           [L]SNS = 1 : [L]DCLFLD = "27" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT074([L]DCLPAG,1..dim(VAT074,2))) & [F:DAEP]TAX <> ""                                                :#CAMPO 74 tx locações
           [L]SNS = 1 : [L]DCLFLD = "74" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT028([L]DCLPAG,1..dim(VAT028,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 28 tx outros
           [L]SNS = 1 : [L]DCLFLD = "28" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT029([L]DCLPAG,1..dim(VAT029,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 29 tx aquisição de bens / serviços
           [L]SNS = 1 : [L]DCLFLD = "29" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT030([L]DCLPAG,1..dim(VAT030,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 30 tx viaturas turismo
           [L]SNS = 1 : [L]DCLFLD = "30" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT075([L]DCLPAG,1..dim(VAT075,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 75 sucatas
           [L]SNS = 1 : [L]DCLFLD = "75" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT076([L]DCLPAG,1..dim(VAT076,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 76 tx viaturas turismo
           [L]SNS = 1 : [L]DCLFLD = "76" : Gosub WRITE_DVPB : Return
        Endif

        ############ Quadro 05 - operações com o exterior
        If find([F:DAEP]TAX, VAT042([L]DCLPAG,1..dim(VAT042,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 42 tx aquisições intracomunitárias
           [L]SNS = 1 : [L]DCLFLD = "42" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT043([L]DCLPAG,1..dim(VAT043,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 43 tx importações
           [L]SNS = 1 : [L]DCLFLD = "43" : Gosub WRITE_DVPB : Return
        Endif

    Elsif [F:GACP]VATIPT=4 | ([F:GACP]VATIPT=6 &
&    (pat([F:DAEP]ACC, [F:DVPP]SALIMOLESROT+"*") | pat([F:DAEP]ACC, [F:DVPP]SALIMOPLUROT+"*") | pat([F:DAEP]ACC, [F:DVPP]BPCDISROT+"*") | pat([F:DAEP]ACC, [F:DVPP]BPSDISROT+"*")))
        If find([F:DAEP]TAX, VAT032([L]DCLPAG,1..dim(VAT032,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 32 tx red
           [L]SNS = 1 : [L]DCLFLD = "32" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT077([L]DCLPAG,1..dim(VAT077,2))) & [F:DAEP]TAX <> "" :#CAMPO 77 tx outros
           [L]SNS = 1 : [L]DCLFLD = "77" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT033([L]DCLPAG,1..dim(VAT033,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 33 tx aqyisição
           [L]SNS = 1 : [L]DCLFLD = "33" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT034([L]DCLPAG,1..dim(VAT034,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 34 tx outros
           [L]SNS = 1 : [L]DCLFLD = "34" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT035([L]DCLPAG,1..dim(VAT035,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 35 tx red
           [L]SNS = 1 : [L]DCLFLD = "35" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT078([L]DCLPAG,1..dim(VAT078,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 78 tx red
           [L]SNS = 1 : [L]DCLFLD = "78" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT079([L]DCLPAG,1..dim(VAT079,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 79 tx red
           [L]SNS = 1 :  [L]DCLFLD = "79" : Gosub WRITE_DVPB : Return
        Endif

        ############ Quadro 05 - operações com o exterior
        If find([F:DAEP]TAX, VAT038([L]DCLPAG,1..dim(VAT038,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 38 aquisições intracomunitárias
           [L]SNS = 1 : [L]DCLFLD = "38" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT039([L]DCLPAG,1..dim(VAT039,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 39 importações
           [L]SNS = 1 : [L]DCLFLD = "39" : Gosub WRITE_DVPB : Return
        Endif

    Endif

################### quadro 06 - bases do iva dedutivel
Elsif ([F:GACP]FLGVAT=3 or [F:GACP]FLGVAT=4)     :#BASES de IVA
   If [F:GACP]VATIPT=3

        If find([F:DAEP]TAX, VAT045([L]DCLPAG,1..dim(VAT045,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 45 IVA Exist. red
           [L]SNS = 1 : [L]DCLFLD = "45" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT046([L]DCLPAG,1..dim(VAT046,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 45 IVA Exist. int
           [L]SNS = 1 : [L]DCLFLD = "46" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT047([L]DCLPAG,1..dim(VAT047,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 47 IVA Exist. nor
           [L]SNS = 1 : [L]DCLFLD = "47" : Gosub WRITE_DVPB : Return
        Endif

   Elsif [F:GACP]VATIPT=4

        If find([F:DAEP]TAX, VAT048([L]DCLPAG,1..dim(VAT048,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 48 IVA Exist. red
           [L]SNS = 1 : [L]DCLFLD = "48" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT049([L]DCLPAG,1..dim(VAT049,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 49 IVA Exist. int
           [L]SNS = 1 : [L]DCLFLD = "49" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT050([L]DCLPAG,1..dim(VAT050,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 50 IVA Exist. nor
           [L]SNS = 1 : [L]DCLFLD = "50" : Gosub WRITE_DVPB : Return
        Endif

   Elsif [F:GACP]VATIPT=5

        If find([F:DAEP]TAX, VAT051([L]DCLPAG,1..dim(VAT051,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 51 IVA Exist. red
           [L]SNS = 1 : [L]DCLFLD = "51" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT052([L]DCLPAG,1..dim(VAT052,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 52 IVA Exist. int
           [L]SNS = 1 : [L]DCLFLD = "52" : Gosub WRITE_DVPB : Return
        Endif
        If find([F:DAEP]TAX, VAT053([L]DCLPAG,1..dim(VAT053,2))) & [F:DAEP]TAX <> ""                                                 :#CAMPO 53 IVA Exist. nor
           [L]SNS = 1 : [L]DCLFLD = "53" : Gosub WRITE_DVPB : Return
        Endif

  Endif
Endif

Return
######################################################################################
######################################################################################
$WRITE_DVPB

Raz [F:DVPB]

[F:DVPB]DCLTYP    = [L]DCLTYP
[F:DVPB]DCLPAG    = [L]DCLPAG
[F:DVPB]DCLNUM    = [L]DCLNUM
[F:DVPB]NUM       = [F:DAEP]NUM
[F:DVPB]LIN       = [F:DAEP]LIN
[F:DVPB]DCLFLD    = format$("N0:3",[L]DCLFLD)
[F:DVPB]ACC       = [F:DAEP]ACC
[F:DVPB]AMTVAT    = [F:DAEP]AMTLED*[F:DAEP]SNS*[L]SNS
[F:DVPB]ACCDAT    = [F:DAEP]ACCDAT
[F:DVPB]VAT       = [F:DAEP]TAX
[F:DVPB]DCLFLDTYP = 1
[F:DVPB]EECNUM    = [L]EECNUM # Issue  X3-101932 - 2018-08-29 by VAVIL - Customers / Recap – Suppliers detail and EENCUM group in main declaration

Write [F:DVPB]
If fstat : GOK = 0 : Call FSTA("DVPB") From GLOCK : Return : Endif

Return
######################################################################################
######################################################################################
$PROC_FIELDS

Raz FLDARR

For [F:DVPB] Where [F:DVPB]DCLNUM = [L]DCLNUM & [F:DVPB]RECTYP = 0 #[L]RECTYP = 0
  FLDARR([F:DVPB]DCLPAG, val([F:DVPB]DCLFLD)) += [F:DVPB]AMTVAT
Next

Gosub BUILD_FIELD_ARRAY

For I = 1 To dim (FLDARR, 1)
  For II = 1 To dim (FLDARR, 2)
    If find(II,FLDLST(I, 1..105))
      [F:DVPF]DCLNUM = [L]DCLNUM
      [F:DVPF]DCLPAG = I
      [F:DVPF]DCLFLD = format$("N0:3",II)
      [F:DVPF]AMT    = FLDARR(I,II)
      Write [F:DVPF]
      If fstat : GOK=0 : Call FSTA("DVPF") From GLOCK : Break 2 : Endif
    Endif
  Next
Next

If GOK
  Gosub FIELD_TOTALS
Endif

Return
######################################################################################
######################################################################################
$FIELD_TOTALS

Raz FLDARR

For [F:DVPF] Where [F:DVPF]DCLNUM = [L]DCLNUM
  Case [F:DVPF]DCLPAG
    When 1
      Case [F:DVPF]DCLFLD
        When "001", "002", "003", "004", "005", "064", "065"
          FLDARR(1, 6) += [F:DVPF]AMT
        When "007", "008", "009", "010", "011", "066", "067", "012"
          FLDARR(1, 13) += [F:DVPF]AMT
        When "014", "015", "016", "068", "017", "018"
          FLDARR(1, 19) += [F:DVPF]AMT
        When "020", "069", "070", "021", "022", "071", "072"
          FLDARR(1, 23) += [F:DVPF]AMT
        When "024", "073", "025", "026", "027", "074", "028", "029", "030", "075", "076"
          FLDARR(1, 31) += [F:DVPF]AMT
        When "032", "077", "033", "034", "035", "078", "079"
          FLDARR(1, 36) += [F:DVPF]AMT
        When "045", "048", "051"
          FLDARR(1, 54) += [F:DVPF]AMT
        When "046", "049", "052"
          FLDARR(1, 55) += [F:DVPF]AMT
        When "047", "050", "053"
          FLDARR(1, 56) += [F:DVPF]AMT
      Endcase
    When 2, 3
      Case [F:DVPF]DCLFLD
        When "001", "002", "003", "004", "005", "060", "061"
          FLDARR([F:DVPF]DCLPAG, 6) += [F:DVPF]AMT
        When "007", "008", "009", "010", "011", "062", "063", "012"
          FLDARR([F:DVPF]DCLPAG, 13) += [F:DVPF]AMT
        When "014", "015", "016", "064", "017", "018"
          FLDARR([F:DVPF]DCLPAG, 19) += [F:DVPF]AMT
        When "020", "065", "066", "021", "022", "067", "068"
          FLDARR([F:DVPF]DCLPAG, 23) += [F:DVPF]AMT
        When "024", "069", "025", "026", "027", "070", "028", "029", "030", "071", "072"
          FLDARR([F:DVPF]DCLPAG, 31) += [F:DVPF]AMT
        When "032", "073", "033", "034", "035", "074", "075"
          FLDARR(1, 36) += [F:DVPF]AMT
        When "045", "048", "051"
          FLDARR([F:DVPF]DCLPAG, 54) += [F:DVPF]AMT
        When "046", "049", "052"
          FLDARR([F:DVPF]DCLPAG, 55) += [F:DVPF]AMT
        When "047", "050", "053"
          FLDARR([F:DVPF]DCLPAG, 56) += [F:DVPF]AMT
      Endcase
  Endcase
Next

For I = 1 To 3
  #total field 6
  Read [F:DVPF]DVPF0 = [L]DCLNUM;I;format$("N0:3",6)
  If fstat
    [F:DVPF]DCLNUM = [L]DCLNUM
    [F:DVPF]DCLPAG = I
    [F:DVPF]DCLFLD = format$("N0:3",6)
    [F:DVPF]AMT    = FLDARR(I,6)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT    = FLDARR(I,6)
    Rewrite [F:DVPF]
  Endif

  If fstat
    GOK       = 0
    Call FSTA("DVPF") From GLOCK
    #GMESSAGE  = func AFNC.MES2(mess(230,111,1), num$(fstat), "6") #Error while writing field total (fstat = ?).
    Break
  Endif

  #total field 13
  Read [F:DVPF]DVPF0 = [L]DCLNUM;I;format$("N0:3",13)
  If fstat
    [F:DVPF]DCLNUM = [L]DCLNUM
    [F:DVPF]DCLPAG = I
    [F:DVPF]DCLFLD = format$("N0:3",13)
    [F:DVPF]AMT    = FLDARR(I,13)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT    = FLDARR(I,13)
    Rewrite [F:DVPF]
  Endif

  If fstat
    GOK       = 0
    Call FSTA("DVPF") From GLOCK
    #GMESSAGE  = func AFNC.MES2(mess(230,111,1), num$(fstat), "13") #Error while writing field total (fstat = ?).
    Break
  Endif

  #total field 19
  Read [F:DVPF]DVPF0 = [L]DCLNUM;I;format$("N0:3",19)
  If fstat
    [F:DVPF]DCLNUM = [L]DCLNUM
    [F:DVPF]DCLPAG = I
    [F:DVPF]DCLFLD = format$("N0:3",19)
    [F:DVPF]AMT    = FLDARR(I,19)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT    = FLDARR(I,19)
    Rewrite [F:DVPF]
  Endif

  If fstat
    GOK       = 0
    Call FSTA("DVPF") From GLOCK
    #GMESSAGE  = func AFNC.MES2(mess(230,111,1), num$(fstat), "19") #Error while writing field total (fstat = ?).
    Break
  Endif

  #total field 23
  Read [F:DVPF]DVPF0 = [L]DCLNUM;I;format$("N0:3",23)
  If fstat
    [F:DVPF]DCLNUM = [L]DCLNUM
    [F:DVPF]DCLPAG = I
    [F:DVPF]DCLFLD = format$("N0:3",23)
    [F:DVPF]AMT    = FLDARR(I,23)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT    = FLDARR(I,23)
    Rewrite [F:DVPF]
  Endif

  If fstat
    GOK       = 0
    Call FSTA("DVPF") From GLOCK
    #GMESSAGE  = func AFNC.MES2(mess(230,111,1), num$(fstat), "23") #Error while writing field total (fstat = ?).
    Break
  Endif

  #total field 31
  Read [F:DVPF]DVPF0 = [L]DCLNUM;I;format$("N0:3",31)
  If fstat
    [F:DVPF]DCLNUM = [L]DCLNUM
    [F:DVPF]DCLPAG = I
    [F:DVPF]DCLFLD = format$("N0:3",31)
    [F:DVPF]AMT    = FLDARR(I,31)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT    = FLDARR(I,31)
    Rewrite [F:DVPF]
  Endif

  If fstat
    GOK       = 0
    Call FSTA("DVPF") From GLOCK
    #GMESSAGE  = func AFNC.MES2(mess(230,111,1), num$(fstat), "31") #Error while writing field total (fstat = ?).
    Break
  Endif

  #total field 36
  Read [F:DVPF]DVPF0 = [L]DCLNUM;I;format$("N0:3",36)
  If fstat
    [F:DVPF]DCLNUM = [L]DCLNUM
    [F:DVPF]DCLPAG = I
    [F:DVPF]DCLFLD = format$("N0:3",36)
    [F:DVPF]AMT    = FLDARR(I,36)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT    = FLDARR(I,36)
    Rewrite [F:DVPF]
  Endif

  If fstat
    GOK       = 0
    Call FSTA("DVPF") From GLOCK
    #GMESSAGE  = func AFNC.MES2(mess(230,111,1), num$(fstat), "36") #Error while writing field total (fstat = ?).
    Break
  Endif

  #total field 54
  Read [F:DVPF]DVPF0 = [L]DCLNUM;I;format$("N0:3",54)
  If fstat
    [F:DVPF]DCLNUM = [L]DCLNUM
    [F:DVPF]DCLPAG = I
    [F:DVPF]DCLFLD = format$("N0:3",54)
    [F:DVPF]AMT    = FLDARR(I,54)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT    = FLDARR(I,54)
    Rewrite [F:DVPF]
  Endif

  If fstat
    GOK       = 0
    Call FSTA("DVPF") From GLOCK
    #GMESSAGE  = func AFNC.MES2(mess(230,111,1), num$(fstat), "54") #Error while writing field total (fstat = ?).
    Break
  Endif

  #total field 55
  Read [F:DVPF]DVPF0 = [L]DCLNUM;I;format$("N0:3",55)
  If fstat
    [F:DVPF]DCLNUM = [L]DCLNUM
    [F:DVPF]DCLPAG = I
    [F:DVPF]DCLFLD = format$("N0:3",55)
    [F:DVPF]AMT    = FLDARR(I,55)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT    = FLDARR(I,55)
    Rewrite [F:DVPF]
  Endif

  If fstat
    GOK       = 0
    Call FSTA("DVPF") From GLOCK
    #GMESSAGE  = func AFNC.MES2(mess(230,111,1), num$(fstat), "55") #Error while writing field total (fstat = ?).
    Break
  Endif

  #total field 56
  Read [F:DVPF]DVPF0 = [L]DCLNUM;I;format$("N0:3",56)
  If fstat
    [F:DVPF]DCLNUM = [L]DCLNUM
    [F:DVPF]DCLPAG = I
    [F:DVPF]DCLFLD = format$("N0:3",56)
    [F:DVPF]AMT    = FLDARR(I,56)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT    = FLDARR(I,56)
    Rewrite [F:DVPF]
  Endif

  If fstat
    GOK       = 0
    Call FSTA("DVPF") From GLOCK
    #GMESSAGE  = func AFNC.MES2(mess(230,111,1), num$(fstat), "56") #Error while writing field total (fstat = ?).
    Break
  Endif

Next

Return
#################################################################################################
#################################################################################################
$BUILD_FIELD_ARRAY

Raz FLDLST

For II = 1 To 3
  For I = 1 To 5
    FLDLST(II, I) = I
  Next
  For I = 7 To 12
    FLDLST(II, I) = I
  Next
  For I = 14 To 18
    FLDLST(II, I) = I
  Next
  For I = 20 To 22
    FLDLST(II, I) = I
  Next
  For I = 24 To 30
    FLDLST(II, I) = I
  Next
  For I = 32 To 35
    FLDLST(II, I) = I
  Next
  For I = 37 To 56
    FLDLST(II, I) = I
  Next
  For I = 64 To 79
    FLDLST(II, I) = I
  Next
Next

Return
