#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPCHIS 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRHIS
mkstat = 0
zoncou = "NBRHIS"
indice = 0
status = 1
zoncou = "NBRHIS"
If varmode([M]NBRHIS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRHIS" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRHIS
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRHIS = nolign
   status = 75
   Call SAI_NBRHIS(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBRHIS From SUBECP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBRHIS" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRHIS(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRHIS
mkstat = 0
zoncou = "NBRHIS"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBRHIS From SUBECP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBRHIS" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone ORICPCHIS
mkstat = 0
zoncou = "ORICPCHIS"
IMPENT = [M]ORICPCHIS(indice)
If varinit([M]ORICPCHIS,indice)=0
 IMPENT = 1
Endif
[M]ORICPCHIS(indice) = IMPENT

## Zone NBRHIS
mkstat = 0
zoncou = "NBRHIS"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CPCHIS"
Return

