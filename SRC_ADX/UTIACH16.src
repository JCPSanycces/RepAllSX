#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIACH16   Utilitaire de vérification de la chronologie   Module ACHAT #
#            des séquences et dates pour les demandes de livraison       #
# ---------------------------------------------------------------------- #
##########################################################################


Call MAJ_UTIACH16
End


Subprog MAJ_UTIACH16
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH16 - Vérif séquence DL") From SAIDOS
If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH16 : Utilitaire vérification séquencement DL") From LECFIC
  Call EXE_UTIACH16(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIACH16(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Integer WNBR,   WERR
Local Date    WDATE
Local Integer WLIGNE, WSEQUENCE
Local Char    WMSG(100)
#-----
Call ECR_TIME("UTIACH16 : Début traitement du dossier "+DOSSIER) From DOSSUB
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
#----- Ouverture des fichiers -----#
If !clalev([F:POH])  Local File =DOSSIER+".PORDER"    [POH] : Endif
If !clalev([F:POQ])  Local File =DOSSIER+".PORDERQ"   [POQ] : Endif
#----- Début du traitement -----#
For [POH] POH0 Where POHTYP=2
  Raz WDATE, WSEQUENCE, WLIGNE
  For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM
    If WLIGNE<>0 & [F:POQ]POPLIN<>WLIGNE
      Raz WSEQUENCE, WDATE
    Endif
    WLIGNE=[F:POQ]POPLIN
    If WSEQUENCE<>0
      If [F:POQ]POQSEQ<WSEQUENCE
        WMSG =[F:POH]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)-num$([F:POQ]EXTRCPDAT)
        WMSG-="Chronologie non respectée :"-num$(WSEQUENCE)-num$(WDATE)
        Call ECR_TRACE(WMSG,0) From GESECRAN
        WERR+=1
      Endif
      If [F:POQ]EXTRCPDAT<WDATE
        WMSG =[F:POH]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)-num$([F:POQ]EXTRCPDAT)
        WMSG-="Chronologie non respectée :"-num$(WSEQUENCE)-num$(WDATE)
        Call ECR_TRACE(WMSG,0) From GESECRAN
        WERR+=1
      Endif
      WSEQUENCE=[F:POQ]POQSEQ
      WDATE    =[F:POQ]EXTRCPDAT
    Else
      WSEQUENCE=[F:POQ]POQSEQ
      WDATE    =[F:POQ]EXTRCPDAT
    Endif
    WNBR+=1
  Next
Next
#----- Fin du traitement -----#
$FIN_UTIACH16
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
WMSG ="UTIACH16 : Nbre de DL erronées :"-num$(WERR)-" sur un total DL de"-num$(WNBR)
Call ECR_TIME(WMSG) From DOSSUB
Close Local File [POH], [POQ]
End
