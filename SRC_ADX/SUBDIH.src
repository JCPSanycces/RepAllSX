#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion objet DIH
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "FERME"      : Gosub FERME
 When "SETBOUT"    : Gosub SETBOUT
 When "RAZCRE"     : Gosub RAZCRE
 When "LIENS"      : Gosub LIENS
 When "FILTRE"     : Gosub FILTRE
 When "FILGAUCHE"  : Gosub FILGAUCHE
 When "INICRE"     : Gosub INICRE
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "APRES_CRE"  : Gosub APRES_CRE
 When "APRES_MOD"  : Gosub APRES_MOD
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "ANNULE"     : Gosub ANNULE
 When "CHANGE"     : Call CHANGE_AXX ("DIAHOU", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase
Return

$OUVRE
Return

$FERME
Return

$SETBOUT
Return

$RAZCRE
Return

$FILTRE
Return

$FILGAUCHE
Return

$INICRE
Return

$VERIF_CRE
Return

$VERIF_MOD
Return

$APRES_CRE
Return

$APRES_MOD
Return

$CREATION
Call MAJTEXTRA([M]DIANAMAXX,"DIAHOU","DIANAMAXX",[M]NUM,"") From ATEXTRA
Call MAJTEXTRA([M]DIASHOAXX,"DIAHOU","DIASHOAXX",[M]NUM,"") From ATEXTRA

Return

$MODIF
Call MAJTEXTRA([M]DIANAMAXX,"DIAHOU","DIANAMAXX",[M]NUM,"") From ATEXTRA
Call MAJTEXTRA([M]DIASHOAXX,"DIAHOU","DIASHOAXX",[M]NUM,"") From ATEXTRA

Return

$ANNULE
Delete [AXX] Where CODFIC="DIAHOU" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 #GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return  # FGR 17/12/2009 : X3SUIVI60986
Endif

Return

$LIENS
# Chargement du tableau des jours travaillés
Local Integer ITERNBLIG
[M:DIH1]NBLIG = 0
For ITERNBLIG = 0 To dim([M:DIH1]STRHOU) - 1
    If [M:DIH1]STRHOU(ITERNBLIG) = ""
        If [M:DIH1]ENDHOU(ITERNBLIG) = ""
            Break
        Endif
    Endif
    [M:DIH1]NBLIG += 1
Next
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran DIH1) 29/06/2005 15:55:23 (LSE)
######################################################################################
Subprog C_ENDHOU(VALEUR)
Variable Char    VALEUR()

Local Integer IUPPER
Local Integer OK

OK = 1
IUPPER = 0
Call ISHOURUPPER([M:DIH1]STRHOU(nolign - 1), VALEUR, IUPPER) From CRMUTIL140
If IUPPER Then
    If IUPPER = 2 Then # start- and end time equal
        # Issue X3-7931 - 2017-01-17 by ALSHE : Don't allow user to accept invalid data.
        GMESSAGE=mess(343,182,1)
        mkstat = 2
        # L'heure de fin est égale à l'heure de début. SAM 30458
        # Call OUINON( mess(343,182,1), OK ) From GESECRAN
        # If OK = 2 Then
        #     mkstat = 2
        #     End
        # Endif
        # Call ERREUR( mess(343,182,1) ) From GESECRAN
    Endif
Else # end time less than start time
    # Issue X3-7931 - 2017-01-17 by ALSHE : Don't allow user to accept invalid data.
    GMESSAGE=mess(342,182,1)
    mkstat = 2
    # L'heure de fin est inférieure à l'heure de début. Saisie refusée. SAM 30458
    # Call OUINON( mess(342,182,1), OK ) From GESECRAN
    # If OK = 2 Then
    #     mkstat = 2
    #     End
    # Endif
Endif
# Issue X3-7931 - 2017-01-17 by ALSHE : Don't allow user to accept invalid data.
# Issue X3-27146 - 2017-03-01 by ALSHE : Fix index error
# Issue X3-48565 - 2017-07-13 by ALSHE : Fix index error
If (nolign < dim([M:DIH1]STRHOU) & [M:DIH1]STRHOU(nolign)<>"")
    Call ISHOURUPPER([M:DIH1]STRHOU(nolign), VALEUR, IUPPER) From CRMUTIL140
    If IUPPER=1 Then # end time greater than following start time
        GMESSAGE=mess(1024,182,1)
        mkstat = 2
    Endif
Endif

End

######################################################################################
## Section automatically added (screen DIH1) 01/18/2017 09:16:06 (ALSHE)
## Issue X3-7931 - 2017-01-17 by ALSHE : Don't allow user to accept invalid data.
######################################################################################
Subprog C_STRHOU(VALEUR)
Variable Char    VALEUR()

Local Integer IUPPER
Local Integer OK

OK = 1
IUPPER = 0
If (nolign-2) >= 0
    Call ISHOURUPPER([M:DIH1]ENDHOU(nolign - 2), VALEUR, IUPPER) From CRMUTIL140
    If IUPPER=0 Then # start time is less then previous end time
        GMESSAGE=mess(1023,182,1)
        mkstat = 2
    Endif
Endif
# Issue X3-27146 - 2017-03-01 by ALSHE : Fix index error
# Issue X3-48565 - 2017-07-13 by ALSHE : Fix index error
If (nolign < dim([M:DIH1]STRHOU) & [M:DIH1]STRHOU(nolign)<>"")
    Call ISHOURUPPER([M:DIH1]STRHOU(nolign), VALEUR, IUPPER) From CRMUTIL140
    If IUPPER>0 Then # start time is greater then following start time
        GMESSAGE=mess(1024,182,1)
        mkstat = 2
    Endif
Endif

End
######################################################################################

