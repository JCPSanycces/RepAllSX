#<AdxTL>@(#)3.0.0.0 $Revision$
#** #############################################################################################
#*Handler for the report preprocess.
#*
#* @param     NBPAR       Variable Integer      Number of parameters
#* @param     PARAMETRE   Variable Char()(1..)  Report parameters as strings.
#*
#*! #############################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local Char PARAMR(30), REPCODE(30)
Local Integer NUMREQ , K

# Get the report code from report name.
Call GETPARAM("__REPORT",NBPAR,PARAMETRE,PARAMR) From ETAT
K = instr(1,PARAMR,".")
If K : REPCODE = left$(PARAMR,K-1)  : Endif

If REPCODE = "SWIVAT"
    Gosub INS_ARM
Endif
End


##** ########################################################################
##*INS_ARM
##** ########################################################################
$INS_ARM
Local Integer J1
Local Char TCPY(10)
Local Char TFCY(10)


J1 = 0
If !clalev([F:ARM])  : Local File AREPORTM [ARM]  :  Endif
GOK = 1
Call DEBTRANS From GLOCK
If clalev([F:DLV])=0 : Local File DCLVAT [DLV] : Endif : # Tax declaration on the debits
#Infbox [M:DIA]NUMRPT
Filter [F:DLV] Where [F:DLV]NUMRPT = [M:DIA]NUMRPT

#JOJAC - 2018-08-08 - X3-103256 - START
Delete [ARM] Where RPTCOD = REPCODE and NUMREQ=[M:DIA]NUMRPT
#JOJAC - 2018-08-08 - X3-103256 - START

Trbegin [ARM]
For [F:DLV]

  If ([F:DLV]FCY <> TFCY) or ([F:DLV]CPY <> TCPY)

    J1 +=1
    Raz [F:ARM]
    [F:ARM]RPTCOD = REPCODE
    [F:ARM]USR    = GUSER
    [F:ARM]NUMREQ = [M:DIA]NUMRPT
    [F:ARM]NUMLIG = J1

    [F:ARM]CLEA1  = [F:DLV]CPY
    [F:ARM]CLEA2 = [F:DLV]FCY
    [F:ARM]CLEA3 = func GETSWICNRNUM([F:DLV]CPY)
    [F:ARM]CLEA4 = func GETSWICNRNUM([F:DLV]FCY )
    [F:ARM]CREDAT = date$
      Write [ARM]
    TFCY = [F:DLV]FCY
    TCPY = [F:DLV]CPY
    If fstat
     GOK = 0
    Endif
  Endif

Next
If GOK<1 : Rollback  : Endif
Commit
Return

#** #####################################################################################################
#* Get the tax number for a facility or a company
#*
#* @param COMPFACY Variable Char:           Company or facility
#* @return  Local Char Result:  tax number
#*! #####################################################################################################
Funprog GETSWICNRNUM(COMPFACY)
Variable Char COMPFACY
Local Char RESULT(25)
  Call PARAM(COMPFACY,"SWICNRCPY",RESULT) From ADOVAL
End RESULT

