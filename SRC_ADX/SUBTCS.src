#<AdxTL>@(#)0.0.0.0 $Revision$ Object Management TCS
######################################################################################
# Gestion du masque TCS1 (Parcours type de formation)
# Gestion de fiche Parcours type (table TYPCOURSE)
#
#
# Creation :
#     SEGAY - 03/08/10 - EXI 66191 LOT 1
#     SYMEU - 04/10/10 - EXI 66191 LOT 10 - V6.1 : stage non défini
#
# Modification :
#     SEGAY - 12/04/11 - FQ72136 - Génération parcours
#     SEGAY - 07/09/11 - 75372
#         UOMTIM= jour/semaine/mois/année ML 313
#     PCA -   14/06/12 - Added COMPANY (STORY 440)
#     PCA -   24/08/12 - Added control on Position/Std Job selection options (STORY 670)
#     SBA :   07/08/2013 US 1840-81085 : réinitialisation des champs sur changement de législation
######################################################################################
Raz GPILOBJ
Call OBJET("TCS",GBIDC1,"") From GOBJET
End


$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "MODIF"       : Gosub MODIF
 When "VERIF_CRE"   : Gosub VERIF_CRE #SEGAY-10/12/2012 US 1045 81085
 When "VERIF_MOD"   : Gosub VERIF_MOD #SEGAY-10/12/2012 US 1045 81085
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Gosub CHANGE
 When "LIENS"       : Gosub LIENS
 When "INIMOD"      : Gosub INIMOD
 When "INICRE"      : Gosub INICRE
 When "SETBOUT"     : Gosub SETBOUT  #72136
 When "EXEBOUT"     : Gosub EXEBOUT  #72136
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "FERME"       : Gosub FERME
 When "ABANDON"     : Gosub ABANDON
 When "RAZCRE"      : Gosub RAZCRE
Endcase
#ADNGO - 2017-04-19 - X3-29542 - START
#FRLAA -2015-08-17 - Requirement 110204 - US 3850 - START
If func AFNC.ACTIV("FKSSD")>0
  If func DIVPAYE.EXISTE_KXX("SUBTCSSA") Then
    Gosub ACTION From SUBTCSSA
  Endif
Endif
#FRLAA -2015-08-17 - Requirement 110204 - US 3850 - END
#ADNGO - 2017-04-19 - X3-29542 - END
Return

$OUVRE
If clalev([F:TCL])=0 : Local File TCOURLIG  [TCL] : Endif
If clalev([F:STG])=0 : Local File STAGE     [STG] : Endif
If clalev([F:COU])=0 : Local File COUT      [COU] : Endif
If clalev([F:POT])=0 : Local File POSTE     [POT] : Endif
If clalev([F:CPY])=0  : Local File COMPANY       [CPY]  : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Local Char CRITTCS(250)
Global Char LEGTCS #DKA
Return

