$CREATION
$MODIF
Call MAJTEXTRA([M]DESAXX,"TYPCOURSE","DESAXX",[M]COD,"") From ATEXTRA
Call MAJTEXTRA([M]SHOAXX,"TYPCOURSE","SHOAXX",[M]COD,"") From ATEXTRA

Return

$ANNULE
Delete [AXX] Where CODFIC="TYPCOURSE" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="TYPCOURSE" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA TYPCOURSE"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

$INICRE
Gosub SAUVE_STGL
Return
$INIMOD
Gosub SAUVE_STGL
Return


$FILGAUCHE
#PCA - 14/06/2012 - Filter left list based on legislation
#ADNGO - 2017-11-16 - START
#FILGAUCHE = "(([F:CPY]LEG<>'' & (find([F:CPY]LEG,'"+GLEGFIL+"','')>0)) | [F:TCS]CPY='' | GLEGFIL='')"
If GLEGFIL <> ""
  FILGAUCHE = "[F:TCS]LEG='"+GLEGFIL+"'|[F:TCS]LEG=''"
Else
  FILGAUCHE = ""
Endif
#ADNGO - 2017-11-16 - END
Return

# FQ81085 - MABON 22/06/12 - Navigate in the records, taking into account GLEGFIL
$FILTCS

  CRITTCS="1=1"
  If GLEGFIL<>""
    If CRITTCS<>"" Then CRITTCS-="&" : Endif
#    CRITTCS -= "(find([F:CPY]LEG,'"+GLEGFIL+"','')>0)"
    CRITTCS -= "(([F:CPY]LEG<>'' & (find([F:CPY]LEG,'"+GLEGFIL+"','')>0)) | [F:TCS]CPY='' | GLEGFIL='')"
  Endif
  Filter [TCS_] Where evalue(CRITTCS)
Return

$APRES_CHOI

  Case REPONSE
    When GSTASUI, GSTAPRE, GSTAFIR,GSTALAS
      Gosub FILTCS
      If REPONSE=GSTASUI Then Read [TCS_]TCS0 > [M:TCS1]COD  : Endif
      If REPONSE=GSTAPRE Then Read [TCS_]TCS0 < [M:TCS1]COD  : Endif
      If REPONSE=GSTAFIR Then Read [TCS_]TCS0 First          : Endif
      If REPONSE=GSTALAS Then Read [TCS_]TCS0 Last           : Endif
      Filter [TCS_]
      Gosub SUIVPREC From TOOLSHRLEG
  Endcase
Return
# End MABON

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return


$ABANDON
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#####################################
$SETBOUT
# FQ72136 - SEGAY 12/04/11
CHMEN += "A"
# On ne peut pas généré les parcours si on est en création ou en train de modifier le parcours ou si la parcours type n'est pas actif
If GREP<>"" |  [M:TCS1]ENAFLG <> 2
  CHMEN = ""
Endif
Return

$EXEBOUT
Return
#**#####################################################################################
#* Pour Sauvegarder ligne de stage dans l'ordre de la clé TCL0 COD,NUMLIG
#* SEGAY
#* @since 03/07/10
#*!
$SAUVE_STGL
Delete [F:TCL] Where COD=[M:TCS1]COD
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("TCL",[F:TCL]COD-num$([F:TCL]NUMLIG)) From GLOCK : Return
Else
 For nolign=1 To [M:TCS1]NUMLIG
  [F:TCL]   =[M:TCS1]
  [F:TCL]COD=[M:TCS1]COD
  [F:TCL]NUMLIG = nolign
  [F:TCL]CREDAT =[F:TCS]CREDAT
  [F:TCL]CREUSR =[F:TCS]CREUSR
  [F:TCL]UPDDAT =[F:TCS]UPDDAT
  [F:TCL]UPDUSR =[F:TCS]UPDUSR
  [F:TCL]CRETIM =[F:TCS]CRETIM
  [F:TCL]UPDTIM =[F:TCS]UPDTIM
  Write [F:TCL]
  If fstat
   GOK = 0 : Call FSTA("TCL") From GLOCK : Break
  Endif
 Next
 If GOK=0 : Return : Endif
Endif
Return

$LIENS
#If GUSER='DKA' Dbgaff Endif
#If GNBLEG=1 : GCURLEG = GDOSLEG : Endif
If [M:TCS1]LEG <> "" : GCURLEG=[M:TCS1]LEG : Endif
Call LECTURE("CPY",[F:TCS]CPY,"") From CONTOBJ
GSOCIETE=[F:CPY]CPY : [M:TCS1]CPY=GSOCIETE
#ADNGO - 2017-11-16 - START
If [M:TCS1]CPY = ""
 GCURLEG = [M:TCS1]LEG
Else
 If dim([F:CPY]LEG)>0
    GCURLEG=[F:CPY]LEG
 Endif
Endif
#ADNGO - 2017-11-16 - END
Gosub CHARGE_STGL

Return

#**#####################################################################################
#* Pour Charger ligne de stage dans l'ordre de la clé TCL0 COD,NUMLIG
#* SEGAY
#* @since 03/07/10
#*!
$CHARGE_STGL
nolign=1
Filter [F:TCL] Where COD=[M:TCS1]COD Order By Key TCL0
Raz [M:TCS1]CSTPED
For [F:TCL]
 [M:TCS1]=[F:TCL]
 Call CHARGE_INFO_STG(nolign-1,[F:TCL]STG)
 nolign+=1
Next
Filter [F:TCL]
[M:TCS1]NUMLIG=nolign-1
Call AFF_AFFTOT
Affzo [M:TCS1]
Return


#22/06/12 - DKA - Reset GCURLEG to current LEGFIL when creating a new record
$RAZCRE
  GCURLEG = ""
Return

#####################################
$VERIF_CRE
$VERIF_MOD
#SEGAY-10/12/2012 US 1045 81085-Add LEG
# Control same LEG between Poste, Emploi Type
Local Integer WOK,WOK1
Local Char WECR(50)
Local Char WLIBCOUR(50)
Local Char WMESSAGE(250)
Local Char WFIELD(30) (1..4)
Local Char WLEG(GLONADI) (1..4)
Local Char WLEGCOUR(GLONADI)
Local Char WLEGSOC(GLONADI)
Raz WLEGSOC
Call GET_LEGCPY([M]CPY,WOK1,WLEGSOC,0) From TOOLSHRLEG
#  If WLEGSOC ="" Then
    WOK=0
    Call GET_LEGPOT([M]POT,WOK, WLEG(1), 0)  From TOOLSHRLEG         :# Poste
    Call GET_LEGJOBPOT([M]JOBPOT,WOK, WLEG(2), 0)  From TOOLSHRLEG   :# Emploi type
    WECR="TCS1"
    WFIELD(1)="POT"
    WFIELD(2)="JOBPOT"
    For I =1 To 2
       WFIELD(I)=func TOOLSHRLEG.LIB_FIELD(WECR,WFIELD(I))
    Next

    If  WOK Then

      For I =1 To 2
        Call LEGOK(WLIBCOUR,WLEGCOUR,WFIELD(I),WLEG(I) , WOK,WMESSAGE,0) From TOOLSHRLEG
        If !WOK Then
          mkstat = 2
          zonsui="POT"
          Break
        Endif
      Next

      If !WOK
        GMESSAGE = WMESSAGE:  GERR=1 : Return
      Endif
    Endif
#  Endif
Return


#**#####################################################################################
#* Chargement à l'écran des infos du stage
#* SEGAY
#* @since 03/07/10
#*!
Subprog CHARGE_INFO_STG(PNBLIG,PSTG)
Value Integer PNBLIG
Value Char PSTG
Local Char WCOUPED

Call PARAM("","COUPED",WCOUPED) From ADOVAL
Call LECTURE("STG",PSTG,"") From CONTOBJ
[M:TCS1]DOM(PNBLIG)=[F:STG]DOM
[M:TCS1]THM(PNBLIG)=[F:STG]THM
[M:TCS1]NBRDAY(PNBLIG)=[F:STG]NBRDAY
[M:TCS1]NBRHOUIPT(PNBLIG)=[F:STG]NBRHOUIPT
Raz [M:TCS1]CSTPED(PNBLIG)
For [F:COU] Where STG = PSTG & TYPCOU = 1 & TYPCRG = WCOUPED
   [M:TCS1]CSTPED(PNBLIG)+=[F:COU]CSTTOTIDV
#  [M:TCS1]CSTPED(PNBLIG)+=[F:COU]CSTIPTIDV
Next
End
#**#####################################################################################
#* Après modification poste
#* Alimentation de l'emploi-type
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : du poste
#*!
Subprog AM_POT(VALEUR)
Variable Char    VALEUR()

Call LECTURE("POT",VALEUR,"") From CONTOBJ
If [F:POT]JOBPOT<>""
 [M:TCS1]JOBPOT = [F:POT]JOBPOT
 Affzo [M:TCS1]JOBPOT,ZJOBPOT
Endif
End

#**#####################################################################################
#* Bouton MAJ Champs du poste
#* Alimentation de l'emploi-type
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : du poste
#*!
Subprog B2_POT(VALEUR)
Variable Char    VALEUR()
Call AM_POT(VALEUR) From SUBTCS
mkstat = 4
End


#**#####################################################################################
#* Sélection poste
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : du poste
#*!
Subprog B2_DESJOB(VALEUR)
Variable Char    VALEUR()
Local Char  PARMSK(250)(1..20) , SAVACT(20), SAVVALEUR(30)
Local Char  ZONE(10)
If !clalev([F:POT]) : Local File POSTE     [POT] : Endif
SAVACT = GACTION : GACTION = "SELOBJSTD"
SAVVALEUR = VALEUR
PARMSK(1) = "POT"
PARMSK(2) = ""
PARMSK(3) = ""
#PARMSK(4) = "([F:POT]DATENDVLY=[0/0/0] | [F:POT]DATENDVLY>=[M]CTRDAT)"
#PARMSK(5) = "([M]XITDAT=[0/0/0] | [F:POT]DATSTRVLY<=[M]XITDAT)"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJCRIT","SELOBJ","") From GACTION
GACTION = SAVACT
Read [POT]POT0=VALEUR
If !fstat
# VALEUR = [F:POT]DES
 Local Char DES
 Call LECTEXTRA(DES,"POSTE","DES",VALEUR,"") From ATEXTRA
 VALEUR=DES
Else
 VALEUR = SAVVALEUR
Endif
End
#**#####################################################################################
#* Initilisation Bouton Sélection emploi-type
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : de emploi-type
#*!
Subprog B3_DESJOB(VALEUR)
Variable Char    VALEUR()
Local Char    PARMSK(250)(1..20) , SAVACT(20), SAVVALEUR(30)
Local Char  ZONE(10)
If !clalev([F:JOT]) : Local File JOBTYP    [JOT] : Endif
SAVACT = GACTION : GACTION = "SELOBJSTD"
SAVVALEUR = VALEUR
PARMSK(1) = "JOT"
PARMSK(2) = ""
PARMSK(3) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJSTD","SELOBJ","") From GACTION
GACTION = SAVACT
Read [JOT]JOT0=VALEUR
If !fstat
 #SBA 04/07/2012 mod leg GESJOT
 #VALEUR = [F:JOT]DES
 Call LECTEXTRA(VALEUR,"JOBTYP","DES",VALEUR,"") From ATEXTRA
  #SBA end
Else
 VALEUR = SAVVALEUR
Endif
End

