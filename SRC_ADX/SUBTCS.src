# FQ81085 - MABON 09/10/12 - Controls that if it is not a grouping company
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local    Integer I, K, DIFF_LEG
Local    Char    LIS_CPY(GLONCPY)(0..100), LEG(5), LEGS(5)

  If VALEUR="" Then End : Endif

#ADNGO - 2017-11-16 - START
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Filter [CPY] Where [F:CPY]CPY=VALEUR
Read [CPY] First
If !fstat
  If [F:CPY]LEG <> "" & GCURLEG <> "" & GCURLEG <> [F:CPY]LEG Then
     mkstat=2
     GMESSAGE=VALEUR-mess(170,187,1)-'"'+GCURLEG-'"'
   Endif
Endif
Filter [CPY]
#ADNGO - 2017-11-16 - END



  I=0 : Call CALC_GRPCPY(VALEUR, LIS_CPY, I) From TOOLSVAR
  If I>1 Then : # C'est un groupe de sociétés
#    [L]LEG="" : DIFF_LEG=1
#    For K=0 To I-1
#      Call LECTURE("CPY", LIS_CPY(K), "") From CONTOBJ
#      If [L]LEG="" Then LEG=[F:CPY]LEG : Endif
#      If [L]LEG<>[F:CPY]LEG Then
#        DIFF_LEG=2 : Break
#      Endif
#    Next
#    If DIFF_LEG=2 Then
#      GMESSAGE=mess(289,10717,1) : # Toutes les sociétés du groupe doivent avoir la même législation
#      mkstat=2 : End
#    Endif
    GMESSAGE=VALEUR-mess(292,10717,1) : # est un groupe de sociétés
    mkstat=2 : End
  Else
    If clalev([F:AGF])=0  : Local File AGRPFCY       [AGF]  : Endif
    If clalev([F:AGC])=0  : Local File AGRPCPY       [AGC]  : Endif
    Read [F:AGF]AGF0=VALEUR
    If !fstat & [F:AGF]FLGCPY=1 Then : # Ce n'est pas un groupe de sociétés
      Filter [F:AGC] Where GRP=VALEUR
      If rowcount([F:AGC])=0 Then : # Groupe de sites
        GMESSAGE=VALEUR-mess(216,10717,1) : # est un groupe de sites
        mkstat=2
      Endif
      Filter [F:AGC]
    Endif
  Endif

#  If !mkstat Then
#    If [L]LEG="" Then
#      Read [F:CPY]CPY0=VALEUR
#      If !fstat Then [L]LEG=[F:CPY]LEG : Endif
#    Endif
#    If [L]LEG<>"" Then
#      [L]LEGS="" : DIFF_LEG=1
#      For I=0 To [M:TCS1]NUMLIG-1
#        Read [F:STG]STG0=[M:TCS1]STG(I)
#        If !fstat & [F:STG]LEG<>"" Then
#          If [L]LEGS="" Then [L]LEGS=[F:STG]LEG : Endif
#          If [L]LEGS<>[F:STG]LEG Then
#            DIFF_LEG=2 : Break
#          Endif
#        Endif
#      Next
#
#      If DIFF_LEG=2 Then
#        GMESSAGE=mess(290,10717,1) : # Vous ne pouvez pas ajouter de société sur un parcours type possédant des stages dans des législations différentes
#        mkstat=2
#      Else
#        If [L]LEGS<>"" & [L]LEGS<>[L]LEG Then
#          GMESSAGE=mess(269,10717,1)-[L]LEGS : # La législation de la société doit être
#          mkstat=2
#        Endif
#      Endif
#    Endif
#  Endif
End


######################################################################################
#SBA : US 1840-81085
Subprog REINI_FLDSLEG(VALEUR)
Value Char VALEUR()
Local Integer WI
Local Integer WOK
Local Char RESULT(10)
For WI=[M:TCS1]NUMLIG-1 To 0 Step -1
  WOK=0
  RESULT=""
  Call GET_LEGSTG([M:TCS1]STG(WI),WOK,RESULT,WOK) From TOOLSHRLEG
  # condition : gcurleg="" => stage avec leg "" sinon stage avec leg="" ou gcurleg)
  If(WOK and((VALEUR="" and RESULT<>"" ) or (VALEUR<>"" and RESULT <>"" and VALEUR <>RESULT)))
     Supli [M:TCS1]NUMLIG(WI+1)
    #Dela WI,1,[M]NUMLIG [M]NUMLIG
    #[M]NUMLIG-=1
  Endif
Next
Affzo [M:TCS1]NUMLIG
# on verifie poste et emploi type

If([M:TCS1]POT<>"")
  Call  GET_LEGPOT([M:TCS1]POT,WOK,RESULT,WOK)From TOOLSHRLEG
  If(WOK and RESULT<>"" and RESULT<>VALEUR)
      Effzo [M:TCS1]POT #,ZPOT
  Endif
Endif
WOK=0
If([M:TCS1]JOBPOT<>"")
  Call  GET_LEGJOBPOT([M:TCS1]JOBPOT,WOK,RESULT,WOK)From TOOLSHRLEG
  If(WOK and RESULT<>"" and RESULT<>VALEUR)
      Effzo [M:TCS1]JOBPOT #,ZJOBPOT
  Endif
Endif
Affzo  [M:TCS1]POT,ZPOT,JOBPOT,ZJOBPOT
End

