#**#####################################################################################
#* Subprog affichage du total
#* SEGAY
#* @since 03/08/10
#*!
Subprog AFF_AFFTOT
[M:TCS1]NBRDAYT = sum([M:TCS1]NBRDAY(0..[M:TCS1]NUMLIG))
[M:TCS1]CSTPEDT = sum([M:TCS1]CSTPED(0..[M:TCS1]NUMLIG))
[M:TCS1]NBRHOUIPTT = sum([M:TCS1]NBRHOUIPT(0..[M:TCS1]NUMLIG))
Affzo [M:TCS1]NBRDAYT
Affzo [M:TCS1]CSTPEDT
Affzo [M:TCS1]NBRHOUIPTT
End


#**#####################################################################################
#* Après NUMLIG affichage du total
#* SEGAY
#* @since 03/07/10
#*!
Subprog APRES_NUMLIG
Call AFF_AFFTOT
End


#**#####################################################################################
#* Controle de l'unicité du stage
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : Valeur du stage
#*!
Subprog C_STG(VALEUR)
Variable Char    VALEUR()
Local Char WFIELD(30) #SEGAY-10/12/2012 US 1045 81085
Local Char ZFIELD(30) #SEGAY-10/12/2012 US 1045 81085
Local Char WECR #SEGAY-10/12/2012 US 1045 81085
Local Char WLEG(GLONADI) #SEGAY-10/12/2012 US 1045 81085
Local Integer WOK #SEGAY-10/12/2012 US 1045 81085

# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini
Call CTL_STG_NON_DEF(VALEUR) From DIVFOR
If mkstat Then End Endif

Call UNICITE(VALEUR,[M:TCS1]STG) From OBJDIV
If mkstat : End : Endif # SEGAY 10/12/2012 US 1045 81085
#SEGAY-10/12/2012 US 1045 81085
If VALEUR<>""
# Call CONTSEL("STG","",VALEUR,"",mkstat) From CONTOBJ
 If clalev([F:STG])=0 : Local File STAGE     [STG] : Endif
 Raz WLEG
 Call GET_LEGCPY([M]CPY,WOK,WLEG,0) From TOOLSHRLEG
 Read [F:STG]STG0=VALEUR
 If !fstat
  #LIPET - 2017-12-07 - X3-67519 - START
  #ADNGO - 2017-11-14 - START
  #If WLEG = "" & [F:STG]LEG <> WLEG
  #If WLEG <> "" & [F:STG]LEG <> WLEG
  If WLEG <> "" & [F:STG]LEG <> WLEG & [F:STG]LEG <> "" Then
  #ADNGO - 2017-11-14 - END
  #LIPET - 2017-12-07 - X3-67519 - END
    WECR="TCS1"
    ZFIELD="STG"
    WFIELD=func TOOLSHRLEG.LIB_FIELD(WECR,ZFIELD)

    GMESSAGE = WFIELD-":"-VALEUR+chr$(10)+chr$(13)+mess(62,127,1)-":"-[F:STG]LEG : # Réservé à la législation
    mkstat = 2
    GERR=1
    End
  Else
    Call CONTROLE("STG","",VALEUR,"",mkstat) From CONTOBJ
    If mkstat : GERR = 1  : End Endif
   Endif
 Else
   If dim(GAUTOSEL)>0 & GAUTOSEL=2 & GWEBSERV<>1
     Local Char    CRITERE_STG(250)
     Call CRIT_LEG_HLEG ([L]VALEUR,"","[F:STG]COD","","STG","[F:STG]LEG",WLEG,CRITERE_STG) From TOOLSHRLEG

     Filter [F:STG] Where  evalue(CRITERE_STG)
     If rowcount([F:STG]) > 1
# ## Action SELJOTH
      Filter [F:STG]
      If !GWEBSERV
        Local Char    PARMSK(250)(1..20) , SAVACT(20)
        SAVACT = GACTION : GACTION = "SELSTGLEGH"
        PARMSK(1) = WLEG
        Call S_TAB_CHAR(VALEUR,PARMSK,"SELSTGLEGH","TOOLSHRLEG","") From GACTION
        GACTION = SAVACT
      Endif
      Gosub AFF From GSAISIE
     Endif
     If rowcount([F:STG])=  1
       Read [F:STG]JOT0 First
       If !fstat
         [L]VALEUR = num$([F:STG]COD)
       Endif
       Filter [F:STG]
     Endif
     If !rowcount([F:STG])
        Filter [F:STG]
        Call CONTROLE("STG","",VALEUR,"",mkstat) From CONTOBJ
        If mkstat : GERR = 1  : End Endif
     Endif
     Filter [F:STG]
   Else
     Call CONTROLE("STG","",VALEUR,"",mkstat) From CONTOBJ
     If mkstat : GERR = 1  : End Endif
   Endif
 Endif
Endif
End

#**#####################################################################################
#* Aprés sasie du stage, récupération des données
#* Le aprés modif faisait que l'enregistrement se trouvait sur la 1er ligne ???
#* SEGAY
#* @since 03/07/10
#* @param VALEUR : Valeur du stage
#*!
Subprog AP_STG(VALEUR)
Variable Char    VALEUR()
Local Integer NBRLIG

NBRLIG=nolign-1
Call CHARGE_INFO_STG(NBRLIG,VALEUR())

Affzo [M:TCS1]DOM(NBRLIG)
Affzo [M:TCS1]THM(NBRLIG)
Affzo [M:TCS1]NBRDAY(NBRLIG)
Affzo [M:TCS1]NBRHOUIPT(NBRLIG)
Affzo [M:TCS1]CSTPED(NBRLIG)
End



######################################################################################
#changes so that Std Job respects curleg/legfil on selection but is not validated
#on save - for example BRI = only BRI or blank on F12, but GER can be typed and saved
#LEGTCS is Param for screen JOT field instead of GCURLEG
#There are issues at the moment because GCURLEG is onlyreset when the screen is tabbed out of
######################################################################################


Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

#If VALEUR = ""
 #GCURLEG = GLEGFIL
#Else
  If dim([F:CPY]LEG)>0
    GCURLEG=[F:CPY]LEG
    #LIPET - 2017-05-19 - X3-29542 - START
    [M:TCS1]LEG = GCURLEG
    Affzo [M:TCS1]LEG
    #LIPET - 2017-05-19 - X3-29542 - END
  Endif
#Endif
# US 1840-81085
Call REINI_FLDSLEG(GCURLEG)
End

