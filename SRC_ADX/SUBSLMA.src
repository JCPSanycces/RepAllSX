#<AdxTL>@(#)0.0.0.0 $Revision$

#---------------------------------------------------------------------------#
# Actions de l'objet SLM > Modification des lots                            #
#---------------------------------------------------------------------------#

######################################################################
$DEFTRANS
Local Shortint OUVFICFLG

If GFONC1 <> "GESSLM"  : Raz GFLAG  : Endif
If GFLAG  <> ""
    If clalev([F:SRT])=0 : Local File STKTRS [SRT] : Endif
    Read [F:SRT]SRT0=4;GFLAG
    If fstat | [F:SRT]ENAFLG = 1 | [F:SRT]CHANGECOD = 1  : Raz GFLAG : Goto FIN_DEFTRANS : Endif
    If [F:SRT]ACSCOD <> "" & GPROFIL <> GSUPER
        If clalev([F:ACC])=0
            Local File ACCES  [ACC]
            OUVFICFLG = 1
        Endif
        Read [ACC]CODACC=GUSER;[F:SRT]ACSCOD
        If fstat | [F:ACC]EXEC <> 2 : Raz GFLAG : Goto FIN_DEFTRANS : Endif
    Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG = 1 : Close File [ACC] : Raz OUVFICFLG : Endif
Return

######################################################################
$VARIANTE
If clalev([F:SRT])=0  : Local File STKTRS [SRT] : Endif
Read [SRT]SRT0=4;[F:AWI]TRN
If fstat | [F:SRT]ENAFLG <> 2 | [F:SRT]CHANGECOD = 1
    OK = 0
Endif
Return

######################################################################
$SETTRANS
If clalev([F:SRT])=0  : Local File STKTRS [SRT] : Endif
Read [SRT]SRT0=4;GFLAG

#MAE, le 29/01/08, GRP_SITE
GGRPFCY = [F:SRT]GFY
GSLMNUM = [F:SRT]SRTNUM               # hcb 50197
Return

######################################################################
$OUVRE_BOITE
# récupération des noms de currbox des tiroirs
Global Char     GBOXSTO(10)
GBOXSTO = "GAU_CHE"+num$(find("STO",OBJLIS(1..8)))

Return

######################################################################
$OUVRE
Local Integer  LRET
Local Integer  WRET
Local Integer  WAFFPICK : WAFFPICK = 0        : # 0=pas d'alimentation picking
Local Char     WCRITSTA(90)   : # Critère statuts
# Issue 118525 - 2016-09-16 by MAE : Passage de 30 à 90
#Local Char     WCRITLOC(30)   : # Critère catégorie emplacements
Local Char     WCRITLOC(90)   : # Critère catégorie emplacements
Local Char     WCRIT(200)
Local Char     WCRITSTOA(30)  :  WCRITSTOA = 'pat([F:STO]STA,"A*")<>0'
Local Char     WCRITSTOQ(30)  :  WCRITSTOQ = 'pat([F:STO]STA,"Q*")<>0'
Local Char     WCRITSTOR(30)  :  WCRITSTOR = 'pat([F:STO]STA,"R*")<>0'
Local Integer  WA, WQ, WR
Local Char     WLOTCOU(GLONANM)
#--- Bug 62346
Local Integer  WTRBEGIN
Local Decimal  LQTYSTU, LQTYSTUACT

If clalev([M:STW]) = 0 : Local Mask STOWORK   [STW] : Endif
If clalev([M:STWX])= 0 : Local Mask STOWORK   [STWX]: Endif
If !clalev([M:SVW])  : Local Mask STOVALWORK [SVW]  : Endif
If !clalev([M:VALW]) : Local Mask STOVALW    [VALW]  : Endif
If !clalev([M:SDP])  : Local Mask SAIDECPRI  [SDP]  : Endif
If !clalev([M:SDPA]) : Local Mask SAIDECPRI  [SDPA] : Endif

If !clalev([F:ITFD]) : Local File ITMFACILIT [ITFD] : Endif
If !clalev([F:TCA])  : Local File TABCOUAFF  [TCA]  : Endif
If !clalev([F:SLF1]) : Local File STOLOTFCY  [SLF1] : Endif
If !clalev([F:STO])  : Local File STOCK      [STO]  : Endif
If !clalev([F:STO1]) : Local File STOCK      [STO1] : Endif
If !clalev([F:STO2]) : Local File STOCK      [STO2] : Endif   # hcb 110327
#--- Bug 62346
If !clalev([F:SWW])  : Local File STOWIPW    [SWW]  : Endif

Raz [M:SVW], [M:VALW], [M:SDP], [M:SDPA]

# type de modif en cours (1 = renum, 2 = mélange)
Global Integer GMODCOD : GMODCOD = 0
Gosub CHECK_MODCOD

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB

If dim(GRAFFRAICHISLM) < 0 : Global Libelle GRAFFRAICHISLM : Endif
Raz GRAFFRAICHISLM

Global Integer GSLMTRACE
Raz GSLMTRACE
GSLMTRACE = 4

Global Char GFILLOCENT(250)
GFILLOCENT = "LOCCAT<=2"

GSRTNUM = GFLAG

GFCY=GFCYDEF(7)                                                # Ana
Gosub CHARG_PARAM                                              # Ana

Gosub DECLARE From TABLEAUX

Return

######################################################################
$FILTRE
Default File [SLH]
FILTSUP = "CHANGECOD=2"
Return

######################################################################
$LIENS
Local Integer I
Local Integer LRET

[M:SLM1]VCRTYP = 35
[M:SLM1]MODMESS = mess([M:SLM1]MODCOD,2745,1)

Diszo [M:SLM1]5
Actzo [M:SLM1]VCRNUM
Diszo [M:SLM1]10
Diszo [M:SLM1]15
Gosub LIENS From TABLEAUX

# force l'affichage afin que les Diszo
# appelés ensuite fonctionnent
Affzo [M:SLM1]

If GFCY<>[M:SLM1]STOFCY GFCY=[M:SLM1]STOFCY: Gosub CHARG_PARAM : Endif    # Ana

Call STKCTRIPT( [M:SLM1]IPTDAT, [M:SLM1]STOFCY, "1") From STKLIB
If GERR=1
    Call ERREUR(GMESSAGE) From GESECRAN
    Raz GERR
    Raz GMESSAGE
    Grizo [M:SLM1]5
Elsif GERR=2
    Call MESSAGE(GMESSAGE) From GESECRAN
    Raz GERR
    Raz GMESSAGE
    Grizo [M:SLM1]5
Else
    # rend insaisissables toutes les colonnes, puis...
    # ( Diszo du tableau empêche la réactivation)
    # ...rend saisissable la dernière ligne (la ligne vide)
    # Car celle-ci peut avoir été rendue inactive
    # par le chargement précédent d'un document (comportant plus de lignes)
    Call STKDISCOL("SLM1",[M]NBLIG) From STKECR
    If dim([M]QTYPCU)>0
        Diszo [M]QTYPCU
        Actzo [M]QTYPCU([M]NBLIG)
    Endif
Endif
Raz [M:SLM1]WFEALOTLEV                                                   # hcb unicite deb
If [F:ITM]ITMREF <> [M:SLM1]ITMREF
   Read [ITM]ITM0=[M:SLM1]ITMREF
   If fstat
      Raz [ITM]
   Endif
Endif
If [F:ITM]LOTMGTCOD=4
   [M:SLM1]WFEALOTLEV = mess(90,187,1) + " : " + mess(GFEALOTLEV,2773,1)
Endif                                                                    # hcb unicite fin
#                                                           # Hcb 71276 deb
If dim([M:SLM1]ECCVALMAJ)>0
   Local Char WINVECC
   Case [F:ITM]ECCSTO
        When 0,1
           WINVECC="-K:"+num$(GLONECS)+"X"
           Chgfmt [M:SLM1]ECCVALMAJ  With WINVECC
           Chgfmt [M:SLM1]ECCVALMIN  With WINVECC
        When 2
           WINVECC="-K:"+num$(GLONECS)+"X"
           Chgfmt [M:SLM1]ECCVALMIN  With WINVECC
           WINVECC="K:"+num$(GLONECS)+"X"
           Chgfmt [M:SLM1]ECCVALMAJ  With WINVECC
           Diszo  [M:SLM1]ECCVALMAJ
        When 3
           WINVECC="K:"+num$(GLONECS)+"X"
           Chgfmt [M:SLM1]ECCVALMAJ  With WINVECC
           Chgfmt [M:SLM1]ECCVALMIN  With WINVECC
           Diszo  [M:SLM1]ECCVALMAJ
           Diszo  [M:SLM1]ECCVALMIN
        When Default
   Endcase
Endif
#                                                           # Hcb 71276 fin

Return

######################################################################
$DEFLIG
Default Mask [SLM1]
Default File [SLD]
CRIT = 'VCRNUM="'+[M:SLM1]VCRNUM+'"'
FICLIG="SLMD"
ABLIG="SLD"
ZONLIG="VCRLIN"
Return

######################################################################
$RAZCRE

If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 4 | [F:SRT]SRTNUM <> GSLMNUM                   # hcb 50197
   Read [SRT]SRT0=4;GSLMNUM : If fstat Raz [F:SRT] : Endif
Endif

If GFCY <> GFCYDEF(7)                               # Ana
   GFCY =  GFCYDEF(7) : Gosub CHARG_PARAM           # Ana
Endif                                               # Ana


Actzo [M:SLM1]5
If GSTKCPTMAN(5) <> 2
    Effzo [M:SLM1]VCRNUM
    Diszo [M:SLM1]VCRNUM
Endif
[M:SLM1]VCRTYP=35
[M:SLM1]TRSFAM =        [F:SRT]TRSFAMDEF
Affzo [M:SLM1]TRSFAM
Actzo [M:SLM1]10
Actzo [M:SLM1]15
If [F:SRT]LOTCOD = 2 : [M:SLM1]LOTDES = mess(62,193,1) : Affzo [M:SLM1]LOTDES : Endif

# Alimentation des zones de la fenêtre critère et du filtre
# pour contrôle ligne stock pickée
[M:SLM1]AUZSST = [F:SRT]AUZSST
[M:SLM1]AUZSTA = [F:SRT]AUZSTA
[M:SLM1]FORSTA = [F:SRT]FORSTA
[M:SLM1]AAASTA = 1
[M:SLM1]QQQSTA = 1
[M:SLM1]RRRSTA = 1
[M:SLM1]XSTA   = ""
Raz WA,WQ,WR,WCRIT,WCRITSTA
# Statuts autorisés
If find([F:SRT]AUZSTA,1,3,5,7) : WA = 1 : Endif
If find([F:SRT]AUZSTA,2,3,6,7) : WQ = 1 : Endif
If find([F:SRT]AUZSTA,4,5,6,7) : WR = 1 : Endif


Raz WCRIT
If WA = 1 : [M:SLM1]AAASTA = 2 : Endif
If WQ = 1 : [M:SLM1]QQQSTA = 2 : Endif
If WR = 1 : [M:SLM1]RRRSTA = 2 : Endif

[M:SLM1]XSTA=vireblc([M:SLM1]XSTA,4)
If !find([M:SLM1]AUZSST,"","*")
    # Décodage de la liste de statuts --> transformation en
    # une formule contenant des 'pat(%,statut)'
    Call DECODE_STAT([M:SLM1]AUZSST,WCRIT) From TRTCATEG
    # Remplacement des '%' par la variable à tester
    Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTA) From TRTCATEG
Endif
[M:SLM1]CHANGECOD = 2
Return


######################################################################
$SETBOUT
Call VIREBOUT(CHAINE,"A") From GOBJET
Call VIREBOUT(CHAINE,"D") From GOBJET
# Menu Options / Visu transaction
CHMEN += "t"

# boutons bas d'écran
If GREP <> "C"
    Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
If GREP = "C" :     Call VIREBOUT(CHAINE,"2") From GOBJET : Endif

#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
Return

######################################################################
$EXEBOUT
Case BOUT
 When "1"     : Raz WCRITSTA, WCRITLOC, WCRIT
                [M:SLM1]XSTA=vireblc([M:SLM1]XSTA,4)
                # Si statuts renseignés dans filtre
                If !find([M:SLM1]XSTA,"","*")
                   # Décodage de la liste de statuts --> transformation en
                   # une formule contenant des 'pat(%,statut)'
                   Call DECODE_STAT([M:SLM1]XSTA,WCRIT) From TRTCATEG
                   # Remplacement des '%' par la variable à tester
                   Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTA) From TRTCATEG
                # Sinon prise en compte des sous-statuts autorisés
                Elsif !find([M:SLM1]AUZSST,"","*")
                   # Décodage de la liste de statuts --> transformation en
                   # une formule contenant des 'pat(%,statut)'
                   Call DECODE_STAT([M:SLM1]AUZSST,WCRIT) From TRTCATEG
                   # Remplacement des '%' par la variable à tester
                   Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTA) From TRTCATEG
                Endif
                WCRITLOC = 'find([F:STO]LOCCAT,1,2,4)<>0'
                # Issue 118525 - 2016-09-16 by MAE : prise en compte du filtre sur les emplacements
                If [M:SLM1]XLOC <> ""
                    WCRITLOC += "& [F:STO]LOC ='"+[M:SLM1]XLOC+"'"
                Endif
                WAFFPICK = 1
                Gosub TIROIR From SUBSLMP
Endcase
Return
######################################################################
$VERIF_CRE
#                                                                      # hcb 110327 deb
Local Integer I
For I=0 To [M:SLM1]NBLIG-1
   If [F:ITM]SERMGTCOD = 4 & [M:SLM1]SERNUM(I) = ""
      # Le nb de no série ne correspond pas à la qté à traiter
      Call ECR_TRACE(mess(246,199,1)+"  "+ mess(93,100,1)+" : "+num$(I+1),1) From GESECRAN
      Raz GOK,OK
      Break
   Endif
Next I
#                                                                      # hcb 110327 end
Return

######################################################################
$VERIF_MOD
Return

######################################################################
$INICRE
Local Integer LSTAT
Local Char    LNUM
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 4 | [F:SRT]SRTNUM <> GSLMNUM                   # hcb 50197
   Read [SRT]SRT0=4;GSLMNUM : If fstat Raz [F:SRT] : Endif
Endif

# Création du numéro de document si nécessaire
If GSTKCPTMAN(5) <> 2 | [M:SLM1]VCRNUM = ""
    Call NUMERO(GSTKCPT(5), [M:SLM1]STOFCY, [M:SLM1]IPTDAT, "", LNUM, LSTAT) From SUBANM
        If GOK<0 Return Endif
        If LSTAT=0
           [M:SLM1]VCRNUM = LNUM
           [F:SLH]VCRNUM  = LNUM
        Else
            GERR=1:GMESSAGE = mess(60,199,1)
            GOK=0
        Endif
Endif

# récupération compteur lot
If [F:SRT]LOTCOD = 2
    Case [M:SLM1]GESLOTD
        When "C" : If [F:ITM]ITMREF <> [M:SLM1]ITMREF
                       Read [ITM]ITM0=[M:SLM1]ITMREF
                       If fstat : Raz [ITM] : Endif
                   Endif
                   If [F:ITM]LOTCOU <> "" : WLOTCOU = [F:ITM]LOTCOU : Else : WLOTCOU = GLOT : Endif
                   Call NUMERO(WLOTCOU,[M:SLM1]STOFCY,[M:SLM1]IPTDAT, [F:ITM]ITMREF, [M:SLM1]LOTDES, WRET) From SUBANM
                   If WRET
                       Case WRET
                           When 1  : GMESSAGE = WLOTCOU-":"-mess(12,114,1)  : # Compteur inexistant
                           When 2  : GMESSAGE = WLOTCOU-":"-mess(13,114,1)  : # Dépassement de compteur
                           When 3  : GMESSAGE = WLOTCOU-":"-mess(20,101,1)  : # Exercice non ouvert
                           When 4  : GMESSAGE = WLOTCOU-":"-mess(111,123,1) : # Longueur incorrecte
                           When 99 : GMESSAGE = WLOTCOU-":"-mess(135,133,1) : # Compteur verrouillé
                       Endcase
                       GERR=1 : GOK=0 : Return
                   Endif
                   [F:SLH]LOTDES = [M:SLM1]LOTDES
    Endcase
Endif
[F:SLH]MODCOD = GMODCOD

Return

######################################################################
$CREATION

Gosub ALISTW From SUBSLMB
If !GOK : Return : Endif
Gosub CREATION From TABLEAUX

Return

######################################################################
$MODIF
Gosub MODIF From TABLEAUX
Return

######################################################################
$ANNULE
Gosub ANNULE From TABLEAUX
Return

######################################################################
$INICRE_LIG
[F:SLD]VCRNUM = [F:SLH]VCRNUM
Return

######################################################################
$VALLIG
Return

######################################################################
$APRES_CRE
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 4 | [F:SRT]SRTNUM <> GSLMNUM                   # hcb 50197
   Read [SRT]SRT0=4;GSLMNUM : If fstat Raz [F:SRT] : Endif
Endif

If dim(GSLMTRACE)>0 & GSLMTRACE
    Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
Endif

If [F:SRT]PRNCOD1 > 1
    Local Char WPARAM(GLONVCR)(1..3) , WVALEUR(10)
    WPARAM(1) = [M:SLM1]STOFCY
    WPARAM(2) = num$([M:SLM1]VCRTYP)
    WPARAM(3) = [M:SLM1]VCRNUM
    Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
Endif

If GFONCTION = "GESSLM"
     Gosub RELIT From GOBJSUB
     WAFFPICK = 0
     Gosub TIROIR From SUBSLMP
Endif
Return

######################################################################
$APRES_MOD
Gosub APRES_CRE
Return

######################################################################
$APRES_MODIF
Local Integer DP_LRET

If GRAFFRAICHISLM
    Gosub TIROIR From SUBSLMP
    Raz GRAFFRAICHISLM
Endif

Case COUZON
    When "ITMREF":     Gosub TIROIR From SUBSLMP
    When "LOT" :       If !find(currbox,"GAU_CHE1") : currbox = "GAU_CHE1" : Endif
                       WAFFPICK = 1 : Gosub TIROIR From SUBSLMP
    When "SLO" :       If !find(currbox,"GAU_CHE1") : currbox = "GAU_CHE1" : Endif
                       WAFFPICK = 1 : Gosub TIROIR From SUBSLMP
    When "NBLIG"  :    If find(status,65,83)
                           Read [STO]STO0=[M:SLM1]STOFCY;[M:SLM1]WSTOCOU(nolign-1)
                           If !fstat
                               If evalue(FILGAUSUP) : Gosub DEPICK From GOBJSUB : Endif
                           Endif
                       Endif
Endcase
Return

######################################################################
$ABANDON
Local Integer LRET

# déverrouillage du lot
If [M:SLM1]LOT <> "" : Gosub DEVERROU From SUBSLMB : Endif

Actzo [M:SLM1]VCRNUM
WPICK = 1
Raz [M:SLM1]ITMREF
Raz GMODCOD
Raz [M:SLM1]MODMESS
Gosub TIROIR From SUBSLMP

#--- Bug 62346
#--- Maj des cumuls quantité en cours de traitement
If adxlog<>1
  GOK=1
  Trbegin [STO]
  WTRBEGIN=1
Endif
For I=0 To [M:SLM1]NBLIG-1
  If [M:SLM1]WSTOCOU(I) <> 0                                                   # hcb  110327
      Readlock [STO]STO0=[M:SLM1]STOFCY;[M:SLM1]WSTOCOU(I)
      If !fstat
         [F:STO]CUMWIPQTY = max(0,[F:STO]CUMWIPQTY-[M:SLM1]QTYSTU(I))
         [F:STO]CUMWIPQTA = max(0,[F:STO]CUMWIPQTA-([M:SLM1]QTYSTU(I)*[M:SLM1]POT/100))
         Call DEL_STOWIPW([F:STO]STOCOU,[M:SLM1]QTYSTU(I)) From STKLIB
         Rewrite [STO]
         If fstat
            GOK=0 : Call FSTA("STO") From GLOCK : Break
#                                                                               # hcb 110327 deb
         Else
# Suppression no série en cours de traitement
            If [F:ITM]SERMGTCOD=4 & [M:SLM1]SERNUM(I)<>""
                Call DEL_STOSERW([F:ITM]ITMREF,[M:SLM1]SERNUM(I),[M:SLM1]QTYSTU(I),LRET) From STKLIB
            Endif
         Endif
#                                                                               # hcb 110327 end
      Else
        GOK=0 : Break
      Endif
   Endif                                                                        # hcb 110327
Next I
If WTRBEGIN=1
  If GOK : Commit : Else : Rollback : Endif
  Raz WTRBEGIN
Endif
#--- Fin bug 62346
Return

######################################################################
$FERME
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
Return

######################################################################
$CHECK_MODCOD
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 4 | [F:SRT]SRTNUM <> GSLMNUM                   # hcb 50197
   Read [SRT]SRT0=4;GSLMNUM : If fstat Raz [F:SRT] : Endif
Endif

If [F:SRT]RENUMCOD = 2 & [F:SRT]MIXCOD = 1 : GMODCOD = 1 : Endif
If [F:SRT]RENUMCOD = 1 & [F:SRT]MIXCOD = 2 : GMODCOD = 2 : Endif
Return

###############################                         # Ana   deb
$CHARG_PARAM
#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
# récupération des codes compteur et effacement fichier de travail
Local Integer LRET
# compteur module stock
Call LECTCA(7,LRET) From SUBTCA
If !LRET
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1
   Return
Endif
GSTKCPTMAN(5) = [F:TCA]MANCOU(5) # compteur modif lot
GSTKCPT   (5) =[F:TCA]CODNUM(5)
# controle compteur pièce modif lot
Call CTRCPT(GSTKCPT(5),type([M:SLM1]VCRNUM), LRET) From STKLIB
If LRET <> 0
    GMESSAGE = mess(242,199,1)
    GERR = 1
    GOK  = 0
    Return
Endif

GSTKCPTMAN(0) = [F:TCA]MANCOU(0)
GSTKCPT   (0) = [F:TCA]CODNUM(0)

GSTKCPTMAN(2) = [F:TCA]MANCOU(2)
GSTKCPT   (2) = [F:TCA]CODNUM(2)

Return

