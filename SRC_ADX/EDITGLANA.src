#<AdxTL>@(#)10.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(10)
PARAM(1) = "GLANA1"
Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,"") From GTRAITE
End

######################################################################
$ACTION
Gosub ACTION From CPTRPT
Return

######################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char    PARAM(30) , SOCIETE(GLONCPY) , SOC(GLONCPY)
Local Integer NBAXE , REFERENTIEL
Local Char    AXE(GLONDIE)(1..3)
Local Integer IAXE
Local Char    VALDEB(30) , VALFIN(30)

Local File       GDIE [DIE] , COMPANY [CPY] , FACILITY [FCY] , FACGROUP [FGR] , GACM [GCM] , GLED [LED]

Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT
Call GETPARAM("referentiel",NBPAR,PARAMETRE,PARAM) From ETAT : REFERENTIEL = val(PARAM)
Read [CPY]CPY0 = SOCIETE
If [F:CPY]CPYLEGFLG=2 : # Juridique
 SOC = SOCIETE
Else
 Read [FGR]FGR0(1) = SOCIETE
 Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
 SOC = [F:FCY]LEGCPY
 Call LECTURE("CPY",SOC,"") From CONTOBJ
Endif
Read [GCM]GCM0 = [F:CPY]ACM
Read [LED]LED0 = [F:GCM]LED(REFERENTIEL-1)

For IAXE=1 To 3
 Call GETPARAM("axe"+num$(IAXE),NBPAR,PARAMETRE,AXE(IAXE)) From ETAT
 If AXE(IAXE)<>""
  If !find(AXE(IAXE),[F:LED]DIE(0..[F:LED]DIENBR-1))
   GMESSAGE = AXE(IAXE)-":"-mess(40,103,1) : # Axe incorrect
   Goto ERREUR
  Else
   NBAXE = IAXE
   Call LECTEXTRA(PARAM,"GDIE","COLHEA",AXE(IAXE),"") From ATEXTRA
   Call SETPARAM("libana"+num$(IAXE),NBPAR,PARAMETRE,PARAM) From ETAT
  Endif
 Endif
Next IAXE
PARAM = num$(NBAXE)
Call SETPARAM("nbaxe",NBPAR,PARAMETRE,PARAM) From ETAT

For IAXE=1 To 9
 If IAXE<=[F:LED]DIENBR
  Case [F:LED]DIE(IAXE-1)
   When AXE(1)
    Call GETPARAM("sec1deb",NBPAR,PARAMETRE,PARAM) From ETAT : VALDEB = PARAM
    Call GETPARAM("sec1fin",NBPAR,PARAMETRE,PARAM) From ETAT : VALFIN = PARAM
   When AXE(2)
    Call GETPARAM("sec2deb",NBPAR,PARAMETRE,PARAM) From ETAT : VALDEB = PARAM
    Call GETPARAM("sec2fin",NBPAR,PARAMETRE,PARAM) From ETAT : VALFIN = PARAM
   When AXE(3)
    Call GETPARAM("sec3deb",NBPAR,PARAMETRE,PARAM) From ETAT : VALDEB = PARAM
    Call GETPARAM("sec3fin",NBPAR,PARAMETRE,PARAM) From ETAT : VALFIN = PARAM
   When Default
    VALDEB = ' '
    VALFIN = 'zzzzzzzzzz'
  Endcase
 Else
  VALDEB = ' '
  VALFIN = 'zzzzzzzzzz'
 Endif
 If vireblc(VALDEB,2)='' : VALDEB = ' ' : Endif
 Call SETPARAM("s"+num$(IAXE)+"deb",NBPAR,PARAMETRE,VALDEB) From ETAT
 Call SETPARAM("s"+num$(IAXE)+"fin",NBPAR,PARAMETRE,VALFIN) From ETAT
Next IAXE

End

$ERREUR
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GOK = 0
End

