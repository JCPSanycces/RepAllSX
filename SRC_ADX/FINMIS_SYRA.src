#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################################
# MISCELLANEOUS ROUTINES
##############################################################################################################
# GET_DEFCPY : Returns the default company
# CTL_ACS    : Checks that the access code ACCESS is authorized
# CTL_EXE    : Checks execution rights
# CTL_VLYDAT : Checks if a given date is with a given range
#
##############################################################################################################

########################################################################################################
## GET_DEFCPY
########################################################################################################
#**
#* Returns the default company
#*
#* @param ACTX     Context
#* @param FUNCTION Function code
#* @param MODULE   Module
#* @param ERRMES   Error message
#*!
Funprog GET_DEFCPY(ACTX, FUNCTION, MODULE, ERRMES)
Variable Instance ACTX Using OBJECT
Value    Char     FUNCTION() : # Function code
Value    Integer  MODULE     : # Module
Variable Char     ERRMES()   : # Error message

Local Char     COMPANY(GLONCPY), DEFSIT(GLONFCY), PROFILE(GLONAFT)
Local Integer  ISITE,  I
Local Integer  ASTATUS : [L]ASTATUS = [V]CST_AOK

If adxtyp=33 | !clalev([F:AFC]) : Local File AFONCTION [AFC] : Endif
If adxtyp=33 | !clalev([F:AFT]) : Local File AFCTFCT   [AFT] : Endif
If adxtyp=33 | !clalev([F:AME]) : Local File AMETUTI   [AME] : Endif
If adxtyp=33 | !clalev([F:AFF]) : Local File AFCTFCY   [AFF] : Endif
If adxtyp=33 | !clalev([F:AFP]) : Local File AFCTPRF   [AFP] : Endif
If adxtyp=33 | !clalev([F:AUS]) : Local File AUTILIS   [AUS] : Endif
If adxtyp=33 | !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif

Read [F:AFC]CODINT = [L]FUNCTION
If fstat<>[V]CST_AOK : End [L]COMPANY : Endif

Read [F:AUS]= ACTX.USER
If [F:AUS]PRFFCT=""
 Read [AME]AME0 = [F:AUS]CODMET
 If fstat=[V]CST_AOK
  Read [AFT]AFT0 = [F:AME]PRFFCT
 Endif
Else
 Read [AFT]AFT0 = [F:AUS]PRFFCT
Endif
If fstat=[V]CST_AOK
 [L]PROFILE = [F:AFT]PRFCOD
Endif

#  All authorized functions (by profile)
If [F:AFT]ALLFCT=2

 # Functions without Authorization site => First site by default (Profile/Module) + Legal company of site
 If [F:AFC]FCYAUZ<>2
  [L]ASTATUS = fmet ACTX.AGETPRFFCYDEF(ACTX,[L]MODULE,[L]DEFSIT)
  If [L]ASTATUS=[V]CST_AOK
   ISITE = fmet ACTX.ACACHE.AFCY.AGETINDEX([L]DEFSIT)
   If ISITE = [V]CST_ANOTDEFINED :  End [L]COMPANY : Endif
   End fmet ACTX.ACACHE.AFCY.AGETVALCHAR([L]DEFSIT, "LEGCPY")
  Endif
 # Functions with Authorization site => First site
 Else
  For [FCY]
   [L]COMPANY = [F:FCY]LEGCPY
   If [L]COMPANY<>"" : Break : Endif
  Next
  End [L]COMPANY
 Endif

# Not all authorized functions (by profile)
Else

 # Functions without Authorization site => Authorization function, Site by default (Profile/Module)
 If [F:AFC]FCYAUZ<>2
  Read [AFP]AFP0 = [L]PROFILE ; [L]FUNCTION ; ""
  If fstat=[V]CST_AOK & [F:AFP]ACS=2
   [L]ASTATUS = fmet ACTX.AGETPRFFCYDEF(ACTX,[L]MODULE,[L]DEFSIT)
   If [L]ASTATUS=[V]CST_AOK
    ISITE = fmet ACTX.ACACHE.AFCY.AGETINDEX([L]DEFSIT)
    If ISITE = [V]CST_ANOTDEFINED :  End [L]COMPANY : Endif
    End fmet ACTX.ACACHE.AFCY.AGETVALCHAR([L]DEFSIT, "LEGCPY")
   Endif
  Endif
 Else
  # Functions with Authorization site => First authorization site
  For [AFF]AFF1 Where PRFCOD=[L]PROFILE & FNC=[L]FUNCTION & FCY<>""
   ISITE = fmet ACTX.ACACHE.AFCY.AGETINDEX([F:AFF]FCY)
   If ISITE <> [V]CST_ANOTDEFINED
    [L]COMPANY = fmet ACTX.ACACHE.AFCY.AGETVALCHAR([F:AFF]FCY, "LEGCPY")
    If [L]COMPANY<>"" : Break : Endif
   Endif
  Next
  End [L]COMPANY
 Endif
Endif
End [L]COMPANY

########################################################################################################
## CTL_ACS
########################################################################################################
# /!\ Code to be deleted when CONTACC From SUBACS is Syracuse-compliant
#**
#* Checks that the access code ACCESS is authorized
#*
#* @param ACTX   Context
#* @param ACCESS Access code
#* @param ERRMES Error message
#*!
Funprog CTL_ACS(ACTX, ACCESS, ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char  ACCESS()
Variable Char  ERRMES()

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

If ACCESS="" : End [L]ASTATUS : Endif

If adxtyp=33 | !clalev([F:ACC]) : Local File ACCES [ACC] : Endif

Read [ACC]CODACC = ACTX.USER;ACCESS
If ACTX.ALLACS=[V]CST_AYES
 If fstat<>[V]CST_AOK
  ERRMES = ACCESS-":"-mess(56,133,1) : [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS
 Endif
Else
 If fstat<>[V]CST_AOK
  ERRMES = ACCESS-":"-mess(3,104,1) : [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS
 Endif
 If [F:ACC]MODIF<>2
  ERRMES = ACCESS-":"-mess(4,104,1) : [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS
 Endif
Endif
End [L]ASTATUS

########################################################################################################
## CTL_EXE
########################################################################################################
# /!\ Code to be deleted when CONTEXE From SUBACS is Syracuse-compliant
#**
#* Checks execution rights. Returns ATRUE if OK to execute ACCESS access code
#*
#* @param ACTX   Context
#* @param ACCESS Access code
#* @param ERRMES Error message
#*!
Funprog CTL_EXE(ACTX, ACCESS, ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char  ACCESS
Variable Char  ERRMES()

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

If ACCESS="" or ACTX.ALLACS=[V]CST_AYES
 End [L]ASTATUS
Endif

If adxtyp=33 | !clalev([F:ACC]) : Local File ACCES [ACC] : Endif

Read [ACC]CODACC = ACTX.USER;ACCESS
If fstat<>[V]CST_AOK | [F:ACC]EXEC<>2
 ERRMES = mess(7,104,1)
 [L]ASTATUS = [V]CST_AERROR
Endif
End [L]ASTATUS

########################################################################################################
## CTL_VLYDAT
########################################################################################################
#**
#* Checks that the date DAT is in the range STRDAT..ENDDAT
#*
#* @param ACTX   Context
#* @param DAT    Date
#* @param STRDAT Start date
#* @param ENDDAT End date
#* @param ERRMES Error message
#*!
Funprog CTL_VLYDAT(ACTX, DAT, STRDAT, ENDDAT, ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Date     DAT
Value    Date     STRDAT
Value    Date     ENDDAT
Variable Char     ERRMES()

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

If !(DAT>=STRDAT & (ENDDAT=AVOID.ADATE | DAT<=ENDDAT))
 ERRMES = mess(13,104,1)
 [L]ASTATUS = [V]CST_AERROR
Endif
End [L]ASTATUS
