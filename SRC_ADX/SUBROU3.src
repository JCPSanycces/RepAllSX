#<AdxTL>@(#)12.0.0.0 $Revision$
#########################################################################
## Programme de traitement des jalonnements entre opérations de gamme  ##
#########################################################################
## écrit en novembre 1997 par Adeline Lenoir                           ##
#########################################################################
## revu et adapté par LLC 1998 
###########################################################################
## Initialisation des lignes du tableau avec les enreg. opérations
#########################################################################
$INISCD
Local Integer I
Local Integer XOPE

If GREP = "D" : Return : Endif
I=0 : XOPE=0
For nolign=1 To [M:ROU1]NBLIG
  If [M:ROU0]DATREF=[0/0/0]
    If [M:ROU1]OPENUM(nolign-1)<>XOPE
       [M:ROU3]OPENUM(I)=[M:ROU1]OPENUM(nolign-1) 
       [M:ROU3]DACMST(I)=2
       [M:ROU3]MFGMST(I)=1
       [M:ROU3]SCDCOD(I)=1
       [M:ROU3]SCDTIM(I)=0 : # GH 03/11/2014 bug 102304
       [M:ROU3]SCDQTY(I)=0 : # GH 03/11/2014 bug 102304
       [M:ROU3]SCDLOT(I)=0
       XOPE=[M:ROU3]OPENUM(I)
       I+=1
    Endif
  Else
    [M:ROU3]OPENUM(I)=[M:ROU1]OPENUM(nolign-1) 
    [M:ROU3]DACMST(I)=2
    [M:ROU3]MFGMST(I)=1
    [M:ROU3]SCDCOD(I)=1
    [M:ROU3]SCDTIM(I)=0 : # GH 03/11/2014 bug 102304
    [M:ROU3]SCDQTY(I)=0 : # GH 03/11/2014 bug 102304
    [M:ROU3]SCDLOT(I)=0
    I+=1
  Endif
Next nolign
[M:ROU3]BASTAB=I
For I=0 To [M:ROU3]BASTAB-1
    If I = [M:ROU3]BASTAB-1
        [M:ROU3]NEXOPENUM(I) = 0 
    Else
        [M:ROU3]NEXOPENUM(I)=[M:ROU3]OPENUM(I+1)
    Endif
Next I
If !GIMPORT : Affzo [ROU3]1-99 : Endif
Return

###########################################################################
## Action technique de définition du filtre de lecture
#########################################################################
$DEFLIG
# le fichier des jalonnements doit être par défaut
#Default File [ROS]
# Critère de lecture
# le critère suivant ne fonctionne pas !!!!!!!!!
# CRIT = 'ITMREF="'+[M:ROU0]ITMREF+'" & ROUALT='+[M:ROU0]ROUALT+''
# Nom et abréviation du fichier lignes
FICLIG = "ROUSCD" : ABLIG = "ROS"
Return

###########################################################################
## Lecture des lignes
#########################################################################
$LIENS
Local Integer I,J
Local Integer XOPE
I=0 : XOPE=0
For nolign=1 To [M:ROU1]NBLIG
 If [M:ROU0]DATREF=[0/0/0]
  # tester <>0 car en suppression NBLIG n'est pas encore diminué (08/02/00 TB)
  # (cas de suppression de ligne > 1 en mode Duplic)
  If [M:ROU1]OPENUM(nolign-1)<>XOPE & [M:ROU1]OPENUM(nolign-1)<> 0
    Read [ROS]ROS0=[M:ROU0]FCY;[M:ROU0]ITMREF;[M:ROU0]ROUALT;[M:ROU1]OPENUM(nolign-1)
    If !fstat
        [M:ROU3]=[F:ROS]
        [M:ROU3]OPENUM(I)=[F:ROS]OPENUM 
        [M:ROU3]NEXOPENUM(I)=[F:ROS]NEXOPENUM
        [M:ROU3]DACMST(I)=[F:ROS]DACMST
        [M:ROU3]MFGMST(I)=[F:ROS]MFGMST
        [M:ROU3]SCDCOD(I)=[F:ROS]SCDCOD
        [M:ROU3]SCDTIM(I)=[F:ROS]SCDTIM
        [M:ROU3]SCDQTY(I)=[F:ROS]SCDQTY
        [M:ROU3]SCDLOT(I)=[F:ROS]SCDLOT
        XOPE=[M:ROU3]OPENUM(I)
        I+=1
    Else
        # llc 01.02 12260 #
        # sr 06.02 demande 14664 suppression de !GIMPORT et ajout test égalité sur n° opé
        If  [M:ROU3]OPENUM(I) = 0  | [M:ROU3]OPENUM(I) <> [M:ROU1]OPENUM(nolign-1)
            [M:ROU3]OPENUM(I)=[M:ROU1]OPENUM(nolign-1) 
            [M:ROU3]DACMST(I)=2
            [M:ROU3]MFGMST(I)=1
            [M:ROU3]NEXOPENUM(I)=0
            [M:ROU3]SCDCOD(I)=1
            [M:ROU3]SCDTIM(I)=0 : # GH 03/11/2014 bug 102304
            [M:ROU3]SCDQTY(I)=0 : # GH 03/11/2014 bug 102304
            [M:ROU3]SCDLOT(I)=0
        Endif
        XOPE=[M:ROU3]OPENUM(I)
        I+=1
    Endif
  Endif
 Else
  Read [ROS]ROS0=[M:ROU0]FCY;[M:ROU0]ITMREF;[M:ROU0]ROUALT;[M:ROU1]OPENUM(nolign-1)
  If ! fstat
      [M:ROU3]=[F:ROS]
      [M:ROU3]OPENUM(I)=[F:ROS]OPENUM 
      [M:ROU3]NEXOPENUM(I)=[F:ROS]NEXOPENUM
      [M:ROU3]DACMST(I)=[F:ROS]DACMST
      [M:ROU3]MFGMST(I)=[F:ROS]MFGMST
      [M:ROU3]SCDCOD(I)=[F:ROS]SCDCOD
      [M:ROU3]SCDTIM(I)=[F:ROS]SCDTIM
      [M:ROU3]SCDQTY(I)=[F:ROS]SCDQTY
      [M:ROU3]SCDLOT(I)=[F:ROS]SCDLOT
      I+=1
  Else     
      # llc 01.02 12260 
      # sr 06.02 demande 14664 suppression de !GIMPORT et ajout test égalité sur n° opé
      If  [M:ROU3]OPENUM(I) = 0  | [M:ROU3]OPENUM(I) <> [M:ROU1]OPENUM(nolign-1)
          [M:ROU3]OPENUM(I)=[M:ROU1]OPENUM(nolign-1) 
          [M:ROU3]DACMST(I)=2
          [M:ROU3]MFGMST(I)=1
          [M:ROU3]NEXOPENUM(I)=0
          [M:ROU3]SCDCOD(I)=1
          [M:ROU3]SCDTIM(I)=0 : # GH 03/11/2014 bug 102304
          [M:ROU3]SCDQTY(I)=0 : # GH 03/11/2014 bug 102304
          [M:ROU3]SCDLOT(I)=0
      Endif
      I+=1
  Endif
 Endif
Next nolign
[M:ROU3]BASTAB=I


For I = 0 To [M:ROU3]BASTAB-1
    If I = [M:ROU3]BASTAB-1
        [M:ROU3]NEXOPENUM(I) = 0 
    Else
        [M:ROU3]NEXOPENUM(I) = [M:ROU3]OPENUM(I+1)
    Endif
Next I

Return

###########################################################################
## Modification des lignes
#########################################################################
$MODIF
If GIMPORT & [M:ROU1]NBLIG = 0 : [M:ROU3]BASTAB = 0 : Return : Endif
Gosub DEFLIG
For nolign=1 To [M:ROU3]BASTAB
    Readlock [ROS]ROS0=[M:ROU0]FCY;[M:ROU0]ITMREF;[M:ROU0]ROUALT;[M:ROU3]OPENUM(nolign-1)
    If fstat=1 : GOK=-1 : GLOCK="$"+FICLIG-num$(nolign) : Break : Endif
    If fstat=5
       [F:ROS]=[M:ROU3]
       [F:ROS]ITMREF=[M:ROU0]ITMREF
       [F:ROS]ROUALT=[M:ROU0]ROUALT
       [F:ROS]FCY   =[M:ROU0]FCY
       [F:ROS]CREDAT=date$   :# date et utilisateur rajoutés le 08/02/00 TB
       [F:ROS]CREUSR=GUSER
       Write [ROS]
    Elsif fstat=0
       [F:ROS]=[M:ROU3]
       [F:ROS]UPDDAT=date$
       [F:ROS]UPDUSR=GUSER
       Rewrite [ROS]
    Endif
Next nolign
Return

###########################################################################
## Création des lignes
#########################################################################
$CREATION
For nolign=1 To [M:ROU3]BASTAB
    [F:ROS]=[M:ROU3]
    [F:ROS]ITMREF=[M:ROU0]ITMREF
    [F:ROS]ROUALT=[M:ROU0]ROUALT
    [F:ROS]FCY   =[M:ROU0]FCY
    [F:ROS]CREDAT=date$
    [F:ROS]CREUSR=GUSER
    Write [ROS]
    If fstat : GOK=0 : Call FSTA("ROS") From GLOCK : Break : Endif
Next nolign
Return


###########################################################################
## Etiquettes de l'écran
###########################################################################

Subprog AV_WCR(VALEUR)
Variable Char     VALEUR
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif  

If [M:ROU3]WST(nolign-1) <> ""
    Read [MWS]WST0=[M:ROU3]WST(nolign-1);[M:ROU0]FCY
    If ! fstat : VALEUR=[F:MWS]WCR : Endif
Endif
End

########################################################################
Subprog AV_WSTTYP(VALEUR)
Variable Integer  VALEUR
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif  
If [M:ROU3]WST(nolign-1) <> ""
   Read [MWS]WST0=[M:ROU3]WST(nolign-1);[M:ROU0]FCY
   If !fstat
      VALEUR=[F:MWS]WSTTYP
      # GH 07/01/2015 bug 104615
      If (!find([M:ROU3]WSTTYP(nolign-1),0,3) | GIMPORT) & VALEUR=3
          Gosub PE_SCOSCDCOD  From JALLIB
          If !GPE
             [M:ROU3]SCDCOD(nolign-1)=1
             If !GIMPORT : Affzo [ROU3]SCDCOD(nolign-1) : Endif
          Endif
      Endif
      [M:ROU3]WSTTYP(nolign-1)=VALEUR : # GH 03/11/2014 bug 102304
   Endif
Endif
End

########################################################################
Subprog AV_WSTDES(VALEUR)
Variable Char     VALEUR
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif  
If [M:ROU3]WST(nolign-1) <> ""
   Read [MWS]WST0=[M:ROU3]WST(nolign-1);[M:ROU0]FCY
   If ! fstat 
#    VALEUR=[F:MWS]WSTDES
    #LECTURE du libellé traduisible
    Call LECTEXTRA(VALEUR,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
   Endif
Endif
End

########################################################################
Subprog AV_OPENUM(VALEUR)
Variable Decimal  VALEUR

If VALEUR <> 0
   Local Integer     I, VOPE
   If [M:ROU0]DATREF=[0/0/0]
      VOPE=0
      For I=0 To [M:ROU1]NBLIG-1
          If [M:ROU1]OPENUM(I)=VALEUR & [M:ROU1]OPENUM(I)<>VOPE
             VOPE=[M:ROU1]OPENUM(I)
             [M:ROU3]WST(nolign-1)=[M:ROU1]WST(I)
          Endif
      Next I
   Else
      For I=0 To [M:ROU1]NBLIG-1
          If [M:ROU1]OPENUM(I)=VALEUR
              [M:ROU3]WST(nolign-1)=[M:ROU1]WST(I)
          Endif
      Next I
   Endif
Endif
End

########################################################################
Subprog C_BASTAB
Call C_BASTAB From ECCROU # Issue 104937 - 2015-11 by GH : versioning
End 
 
########################################################################
Subprog C_NEXOPENUM(VALEUR)
Variable Decimal  VALEUR
Local Integer     I
Local Integer     OPEOK

If GIMPORT : End : Endif            # correction import 09.04
If instr(1,dbgstr(1),"ROU3") 
    If VALEUR <> 0 & VALEUR = [M:ROU3]OPENUM(nolign-1)
        mkstat=2 : GMESSAGE=mess(18,193,1) : End
    Endif
    If VALEUR <> 0
        OPEOK=0
        For I=0 To [M:ROU3]BASTAB-1
            If VALEUR=[M:ROU3]OPENUM(I) : OPEOK=1 : Break : Endif
        Next I
        If OPEOK<>1 : mkstat=2 : GMESSAGE=mess(19,193,1) : Endif
     Endif
Endif
If instr(1,dbgstr(1),"ROF4")
    If VALEUR <> 0 & VALEUR = [M:ROF4]OPENUM
        mkstat=2 : GMESSAGE=mess(18,193,1) : End
    Endif
    If VALEUR <> 0
        OPEOK=0
        For I=0 To [M:ROU3]BASTAB-1
            If VALEUR=[M:ROU3]OPENUM(I) : OPEOK=1 : Break : Endif
        Next I
        If OPEOK<>1 : mkstat=2 : GMESSAGE=mess(19,193,1) : End :Endif
    Endif
Endif
End

########################################################################
Subprog AV_SCDCOD(VALEUR)
Variable Integer  VALEUR
# FQ 76114 GA 01/2012
#If [M:ROU3]WSTTYP(nolign-1) = 3            # llc 12.01 11907
#    VALEUR = 1
#Endif
Case VALEUR
     When 1, 5, 6, 7
          [M:ROU3]SCDTIM(nolign-1)=0
          [M:ROU3]SCDQTY(nolign-1)=0
          [M:ROU3]OPEUOM(nolign-1)=""
          [M:ROU3]SCDLOT(nolign-1)=0
          If !GIMPORT
              Affzo [ROU3]SCDTIM(nolign-1)
              Affzo [ROU3]SCDQTY(nolign-1),OPEUOM(nolign-1),SCDLOT(nolign-1)
          Endif
     When 2
          [M:ROU3]SCDTIM(nolign-1)=0
          [M:ROU3]SCDQTY(nolign-1)=0
          [M:ROU3]OPEUOM(nolign-1)=""
          If !GIMPORT
              Affzo [ROU3]SCDTIM(nolign-1)
              Affzo [ROU3]SCDQTY(nolign-1),OPEUOM(nolign-1)
          Endif
     When 3
          [M:ROU3]SCDQTY(nolign-1)=0
          [M:ROU3]OPEUOM(nolign-1)=""
          [M:ROU3]SCDLOT(nolign-1)=0
          If !GIMPORT : Affzo [ROU3]SCDQTY(nolign-1),OPEUOM(nolign-1),SCDLOT(nolign-1) : Endif
     When 4
          [M:ROU3]SCDTIM(nolign-1)=0
          [M:ROU3]SCDLOT(nolign-1)=0
          [M:ROU3]OPEUOM(nolign-1)=[M:ROU1]OPEUOM(nolign-1)
          If !GIMPORT
              Affzo [ROU3]SCDTIM(nolign-1),SCDLOT(nolign-1)
              Affzo [ROU3]OPEUOM(nolign-1)
          Endif
Endcase
End

########################################################################
Subprog AM_SCDCOD(VALEUR)
Variable Integer  VALEUR
Local    Integer  I
If instr(1,dbgstr(1),"ROU3")
    # FQ 76114 GA 01/2012 soumis à PE SCOSCDCOD dans JALLIB
    If [M:ROU3]WSTTYP(nolign-1) = 3 & !find(VALEUR,1,8) 
       Gosub PE_SCOSCDCOD  From JALLIB
       If !GPE : VALEUR = 1 : Endif
    Endif
    Case VALEUR
        When 1, 5, 6, 7:      [M:ROU3]SCDTIM(nolign-1)=0
                              [M:ROU3]SCDQTY(nolign-1)=0
                              [M:ROU3]OPEUOM(nolign-1)=""
                              [M:ROU3]SCDLOT(nolign-1)=0
                              If !GIMPORT
                                  Affzo [ROU3]SCDTIM(nolign-1)
                                  Affzo [ROU3]SCDQTY(nolign-1),OPEUOM(nolign-1),SCDLOT(nolign-1)
                              Endif
        When 2:               [M:ROU3]SCDTIM(nolign-1)=0
                              [M:ROU3]SCDQTY(nolign-1)=0
                              [M:ROU3]OPEUOM(nolign-1)=""
                              [M:ROU3]SCDLOT(nolign-1)=1
                              If !GIMPORT
                                  Affzo [ROU3]SCDTIM(nolign-1)
                                  Affzo [ROU3]SCDQTY(nolign-1),OPEUOM(nolign-1)
                              Endif
        When 3:               [M:ROU3]SCDQTY(nolign-1)=0
                              [M:ROU3]OPEUOM(nolign-1)=""
                              [M:ROU3]SCDLOT(nolign-1)=0
                              If !GIMPORT : Affzo [ROU3]SCDQTY(nolign-1),OPEUOM(nolign-1),SCDLOT(nolign-1) : Endif
        When 4:               [M:ROU3]SCDTIM(nolign-1)=0
                              [M:ROU3]SCDLOT(nolign-1)=0
                              For I=0 To [M:ROU1]NBLIG - 1    
                                  If [M:ROU1]OPENUM(I) = [M:ROU3]OPENUM(nolign-1) : Break : Endif
                              Next I
                              [M:ROU3]OPEUOM(nolign-1)=[M:ROU1]OPEUOM(I)
                              If !GIMPORT
                                  Affzo [ROU3]SCDTIM(nolign-1),SCDLOT(nolign-1)
                                  Affzo [ROU3]OPEUOM(nolign-1)
                              Endif
    Endcase
Endif
If instr(1,dbgstr(1),"ROF4")
    # FQ 76114 GA 01/2012 soumis à PE SCOSCDCOD dans JALLIB
    If [M:ROF4]WSTTYP = 3 & !find(VALEUR,1,8) 
       Gosub PE_SCOSCDCOD  From JALLIB
       If !GPE  : VALEUR = 1 : Endif
    Endif
    Case VALEUR
        When 1, 5, 6, 7:      [M:ROF4]SCDTIM=0
                              [M:ROF4]SCDQTY=0
                              [M:ROF4]OPEUOM=""
                              [M:ROF4]SCDLOT=0
                              If !GIMPORT
                                  Affzo [ROF4]SCDTIM
                                  Affzo [ROF4]SCDQTY,OPEUOM,SCDLOT
                              Endif
                        
        When 2:               [M:ROF4]SCDTIM=0
                              [M:ROF4]SCDQTY=0
                              [M:ROF4]OPEUOM=""
                              [M:ROF4]SCDLOT=1
                              If !GIMPORT
                                  Affzo [ROF4]SCDTIM
                                  Affzo [ROF4]SCDQTY,OPEUOM
                              Endif
        When 3:               [M:ROF4]SCDQTY=0
                              [M:ROF4]OPEUOM=""
                              [M:ROF4]SCDLOT=0
                              If !GIMPORT : Affzo [ROF4]SCDQTY,OPEUOM,SCDLOT : Endif
        When 4:               [M:ROF4]SCDTIM=0
                              [M:ROF4]SCDLOT=0
                              For I=0 To [M:ROU1]NBLIG - 1    
                                  If [M:ROU1]OPENUM(I) = [M:ROF4]OPENUM : Break : Endif
                              Next I
                              [M:ROF4]OPEUOM=[M:ROU1]OPEUOM(I)
                              If !GIMPORT
                                  Affzo [ROF4]SCDTIM,SCDLOT
                                  Affzo [ROF4]OPEUOM
                              Endif
    Endcase
    OMODIF = 1
Endif
End


########################################
Subprog C_SCDCOD(VALEUR)
Variable Integer VALEUR
If VALEUR = 8 : mkstat = 2 : Endif
End

########################################
Subprog C_SCDTIM(VALEUR)
Variable Decimal VALEUR
If instr(1,dbgstr(1),"ROU3")
    If [M:ROU3]SCDCOD(nolign-1) = 3 & VALEUR = 0
        GMESSAGE = mess(147,193,1)
        mkstat = 2
    Endif
Endif
If instr(1,dbgstr(1),"ROF4")
    If [M:ROF4]SCDCOD = 3 & VALEUR = 0
        GMESSAGE = mess(147,193,1)
        mkstat = 2
    Endif
Endif
End

########################################
Subprog C_SCDQTY(VALEUR)
Variable Decimal VALEUR
If instr(1,dbgstr(1),"ROU3")
    If [M:ROU3]SCDCOD(nolign-1) = 4 & VALEUR = 0
        GMESSAGE = mess(147,193,1)
        mkstat = 2    
    Endif
Endif
If instr(1,dbgstr(1),"ROF4")
    If [M:ROF4]SCDCOD = 4 & VALEUR = 0
        GMESSAGE = mess(147,193,1)
        mkstat = 2    
    Endif
Endif
End

########################################
Subprog C_SCDLOT(VALEUR)
Variable Decimal VALEUR
If instr(1,dbgstr(1),"ROU3")
    If [M:ROU3]SCDCOD(nolign-1) = 2 & VALEUR = 0
        GMESSAGE = mess(147,193,1)
        mkstat = 2
    Endif
Endif
If instr(1,dbgstr(1),"ROF4")
    If [M:ROU3]SCDCOD(nolign-1) = 2 & VALEUR = 0
        GMESSAGE = mess(147,193,1)
        mkstat = 2
    Endif
Endif
End

########################################
Subprog AS_BASTAB
If [M:ROU3]OPENUM(nolign-1) = 0 : GBOUT1="" : Endif
End

