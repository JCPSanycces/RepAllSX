#<AdxTL>@(#)10.0.0.0 $Revision$
############################################################
# FUNPURWIP : Purge des encours
############################################################
$ACTION
Case ACTION
  When "EXEC"         : Gosub EXEC_PURWIP
  When "TERMINE"      : Gosub TERMINE_PURWIP
  When "INIT_DIA"     : Gosub INIT_DIA_PURWIP
  When "OK"           : Gosub OK_PURWIP
  When "END"          : Gosub END_PURWIP
Endcase 
Return

#############################################################
$EXEC_PURWIP
If [M:PUW]STOFCY <> ""
  Gosub TRAITEMENT
Endif
Return
#############################################################
$TERMINE_PURWIP
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
Return
#############################################################
$INIT_DIA_PURWIP
Raz [M:PUW]
[M:PUW]STOFCY = GFCYDEF(0)
[M:PUW]SIM    = 2

Return
#############################################################
$OK_PURWIP
FIN  = 1
Return
#############################################################
$END_PURWIP
Raz [M:PUW]
FIN = 1
Return
############################################################
$TRAITEMENT
Local Integer   WCOM
Local Integer   WFIN
Local Char      WMSG(120)
Local Char      WITM(GLONITM)
Local Integer   I, J, K, L
Local Char      WFIL(80)
Local Char      WPIE(60)(300)
If GSERVEUR
  Onerrgo ERRBATCH
Endif
Local File WIPCOST [MWI]
Local File MFGHEAD [MFG]
Local File SCOHEAD [SCO]

If [M:PUW]SIM=1
     Call TEMPON (mess(722,197,1)) From GESECRAN
     If !GSERVEUR
        Call OUVRE_TRACE(mess(722,197,1)) From LECFIC
     Endif
Else Call TEMPON (mess(885,196,1)) From GESECRAN
     If !GSERVEUR
        Call OUVRE_TRACE(mess(885,196,1)-":"-mess(722,197,1)) From LECFIC
     Endif
Endif

If [M:PUW]VCRTYPORI1=2
    Link [MWI] With [MFG]MFG0=[F:MWI]VCRNUM
&              As [LNK]
&              Where [F:MWI]VCRTYP=10
&                  & [F:MFG]CLODAT<[M:PUW]DATREF
    Default File [LNK]
    Gosub PURMWI
    Close Local File [LNK]
Endif

If [M:PUW]VCRTYPORI2=2
    Link [MWI] With [SCO]SCO0=[F:MWI]VCRNUM
&              As [LNK]
&              Where [F:MWI]VCRTYP=36
&                  & [F:SCO]CLODAT<[M:PUW]DATREF
    Default File [LNK]
    Gosub PURMWI
    Close Local File [LNK]
Endif
#
WMSG = mess(107,184,1)+" ("+format$("D:",[M:PUW]DATREF)+")"
Call ECR_TRACE(WMSG,0) From GESECRAN

Call TEMPOFF From GESECRAN

Close Local File [MWI]
Close Local File [MFG]
Close Local File [SCO]

Return
############################################################
$PURMWI
Trbegin [MWI]
Call DEBTRANS From GLOCK
$PURMWI1
GOK = 1
For [LNK]
  J += 1
  Readlock [MWI]MWI5=[F:MWI]VCRTYP;[F:MWI]VCRNUM;[F:MWI]WIPSEQ;[F:MWI]TXNTYP
  Case fstat
      When 0 :
        If [M:PUW]SIM=1  
           Delete [MWI]
           If fstat
              GOK = 0
              Call FSTA("MWI") From GLOCK
              Break   
           Endif
        Endif
        K += 1
      When 1 :
        GOK = -1
        Break
      When Default :
        GOK = 0
        Call FSTA("MWI") From GLOCK
        Break   
  Endcase
Next
 
Case GOK
  When -1 :
    Rollback
    Call ROLL From GLOCK
    If GROLL 
      Return 
    Else 
      Goto PURMWI1
    Endif
  When 1 : 
    Commit
  When Default :
    Rollback
Endcase
Return
############################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
############################################################
# Actions écran STOCKPUM
############################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
Local Char WPAR(05)
Call PARAM(VALEUR,"MARPURMWI",WPAR) From ADOVAL
If val(WPAR) = 0
  WPAR = "12"
Endif
[M:PUW]DATREF    =addmonth(date$,val(WPAR)*-1)
[M:PUW]DATREFMAX =addmonth(date$,val(WPAR)*-1)
End
############################################################
Subprog C_DATREF(VALEUR)
Variable Date    VALEUR
If VALEUR > [M:PUW]DATREFMAX
  mkstat = 2
  GMESSAGE = mess(308,199,1)-num$([M:PUW]DATREFMAX)
Endif
End
############################################################
Subprog AM_SELFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  [M:PUW]VCRTYPORI1 = 2
  [M:PUW]VCRTYPORI2 = 2

  Affzo [M:PUW]VCRTYPORI1
  Affzo [M:PUW]VCRTYPORI2
  Grizo [M:PUW]15
Else 
  Actzo [M:PUW]15
Endif
End


