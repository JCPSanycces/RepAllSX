#<AdxTL>@(#)8.0.0.0 $Revision$
##############################################################
# DOSDICTAB Remplissage du dico des tables
##############################################################
$DICTAB
Call ECR_TIME(mess(15,125,1)-mess(16,125,1)) From DOSSUB
# MAJ dictionnaire - Tables

Local File =GDOSREF+".ATABLE"  [ATB]
&         ,=GDOSREF+".ATABIND" [ATI]
&         ,=GDOSREF+".ATABZON" [ATZ]
&         ,=GDOSREF+".AMSKPAR" [AMP]
&         ,=GDOSREF+".AINDEX"  [ANX]
If !GCRE
 Local File =GDOSREF+".ATEXTRA" [AXX1]
Endif
If AUDIT
 Local File =GDOSREF+".ATABAUD" [ATA]
Endif

Local File =GDOSX3+".AFORDIM" [AFO]
&         ,=GDOSX3+".ADOSDIM" [ADE]
&         ,=GDOSX3+".ATYPE"   [ATY]

Local File =[F:ADS]DOSSIER+".ATABLE"  [DATB]
&         ,=[F:ADS]DOSSIER+".ATABIND" [DATI]
&         ,=[F:ADS]DOSSIER+".AINDEX"  [DANX]
&         ,=[F:ADS]DOSSIER+".ATABZON" [DATZ]
&         ,=[F:ADS]DOSSIER+".ACTIV"   [DACV]
&         ,=[F:ADS]DOSSIER+".AMSKPAR" [DAMP]
If !GCRE
 Local File =[F:ADS]DOSSIER+".ATEXTRA" [AXX2]
Endif
If AUDIT
 Local File =[F:ADS]DOSSIER+".ATABAUD" [DATA]
Endif

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(16,125,1),"") From GESECRAN
Endif
GNBTBL = 0

## Effacement des anciennes tables qui ne sont plus présentes

If !GCRE
 Trbegin [DATB] , [DATI] , [DATZ] , [DAMP]
  For [DATB]CODFIC Where CODFIC<GXX
   SPEC = 0
   If GPRODUIT=1 & left$([F:DATB]CODFIC,2)="WI" & [F:DATB]MODULE>1 : ## GEODE
    SPEC=1
   Endif
   # Issue 80305 - 2012-02-28 by VPO : ne pas verifier les tables avec CODACT="MIG"
   If [F:DATB]CODACT="MIG"
    SPEC=1
   Endif
   If !SPEC
    Call SPEC([F:DATB]CODACT,SPEC) From DOSSUB
   Endif
   If !SPEC
    Read [ATB]CODFIC = [F:DATB]CODFIC
    If fstat
     Call EFFACE([F:DATB]CODFIC)
    Endif
   Endif
  Next DATB
 Commit
Endif

## Création ou mise à jour des tables

For [ATB] Where CODFIC<GXX & TYPFIC<5 & CODACT<>"MIG"
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(16,125,1),[F:ATB]CODFIC) From GESECRAN
 Endif
 ACTIV = 0
 Trbegin [DATB] , [DATZ] , [DATI] , [DAMP]
  OLD   = 0
  SPEC  = 0
  RWO   = 0
  Read [DATB]CODFIC = [F:ATB]CODFIC
  If !fstat
   OLD = 1
   Call SPEC([F:DATB]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ATB]CODACT,[F:ATB]MODULE,NEWREC) From DOSSUB
  If !SPEC & GPRODUIT=1 & left$([F:ATB]CODFIC,2)="WI" & [F:ATB]MODULE>1 : ## GEODE
   SPEC=1
  Endif
  If !SPEC

   If OLD & !NEWREC : # On la vire
    Call EFFACE([F:ATB]CODFIC)

   Elsif NEWREC & !OLD : # On la créé tel quel

    Raz [F:DATB]
    [F:DATB] = [F:ATB]
    Gosub TAILLE
    If [F:ATB]TYPFIC<3 : GNBTBL += 1 : Endif
    RWO = 1
    If !AUDIT
     If dim([F:DATB]AUDCRE)>0 : [F:DATB]AUDCRE = 1 : Endif
     If dim([F:DATB]AUDUPD)>0 : [F:DATB]AUDUPD = 1 : Endif
     If dim([F:DATB]AUDDEL)>0 : [F:DATB]AUDDEL = 1 : Endif
     If dim([F:DATB]AUDWRK)>0 : [F:DATB]AUDWRK = 1 : Endif
     If dim([F:DATB]AUDBI)>0  : [F:DATB]AUDBI  = 1 : Endif
     If dim([F:DATB]AUDSDA)>0 : [F:DATB]AUDSDA = 1 : Endif
    Endif
    [F:DATB]NBENREG = NEWENREG
    [F:DATB]UPDFLG = 1
    [F:DATB]CREDAT = date$
    [F:DATB]CREUSR = GUSER
    If dim([F:DATB]CRETIM)>0 : [F:DATB]CRETIM = time : Endif
    Write [DATB]
    If fstat : Call ERREUR("ATABLE"-[F:DATB]CODFIC,1) From DOSDIC : Endif
    For [ATZ] Where CODFIC=[F:ATB]CODFIC
     [F:DATZ] = [F:ATZ]
     If [F:DATZ]CODACT<>""
      Gosub RAZNONACTIF
     Endif
     Write [DATZ]
     If fstat : Call ERREUR("ATABZON"-[F:DATZ]CODFIC-[F:DATZ]CODZONE,1) From DOSDIC : Endif
    Next ATZ
    For [ATI] Where CODFIC=[F:ATB]CODFIC
     [F:DATI] = [F:ATI]
     Write [DATI]
     If fstat : Call ERREUR("ATABIND"-[F:DATI]CODFIC-[F:DATI]CODIND,1) From DOSDIC : Endif
    Next ATI
    For [AMP] Where TYPAFF=2 & CODAFF=[F:ATB]CODFIC
     [F:DAMP] = [F:AMP]
     Write [DAMP]
     If fstat : Call ERREUR("AMSKPAR"-[F:DAMP]CODAFF-[F:DAMP]CODZON,1) From DOSDIC : Endif
    Next AMP
    If AUDIT
     For [ATA] Where CODFIC=[F:ATB]CODFIC
      [F:DATA] = [F:ATA]
      Write [DATA]
      If fstat : Call ERREUR("ATABAUD"-[F:DATA]CODFIC-[F:DATA]FLD,1) From DOSDIC : Endif
     Next ATA
    Endif

    ## Vérification des champs désactivés dans les index

    Call VIRE_INDEX(DIFF)

   Elsif NEWREC & OLD : # On respecte les lignes spécifiques

    Raz DIFF , AUD1 , AUD2 , AUD3 , AUD4 , GEN

    ## Comparaison de l'en-tête

    If [F:DATB]ABRFIC     <>  [F:ATB]ABRFIC    : DIFF = 1 : Endif
    If [F:DATB]CODACT     <>  [F:ATB]CODACT    : DIFF = 1 : Endif
    If [F:DATB]CRE        <>  [F:ATB]CRE       : DIFF = 1 : Endif
    If [F:DATB]INTIT      <>  [F:ATB]INTIT     : DIFF = 1 : Endif
    If [F:DATB]INTITC     <>  [F:ATB]INTITC    : DIFF = 1 : Endif
    If [F:DATB]INTITFIC   <>  [F:ATB]INTITFIC  : DIFF = 1 : Endif
    If [F:DATB]SYMBOL     <>  [F:ATB]SYMBOL    : DIFF = 1 : Endif
    If [F:DATB]COLFMT     <>  [F:ATB]COLFMT    : DIFF = 1 : Endif
    If [F:DATB]COLLNG     <>  [F:ATB]COLLNG    : DIFF = 1 : Endif
    If [F:DATB]COLDEC     <>  [F:ATB]COLDEC    : DIFF = 1 : Endif
    If [F:DATB]MODULE     <>  [F:ATB]MODULE    : DIFF = 1 : Endif
    If [F:DATB]OPT        <>  [F:ATB]OPT       : DIFF = 1 : Endif
    If [F:DATB]STA        <>  [F:ATB]STA       : DIFF = 1 : Endif
    If [F:DATB]TYPDLV     <>  [F:ATB]TYPDLV    : DIFF = 1 : Endif
    If [F:DATB]TYPDBA     <>  [F:ATB]TYPDBA    : DIFF = 1 : Endif
    If [F:DATB]TYPFIC     <>  [F:ATB]TYPFIC    : DIFF = 1 : Endif
    If [F:DATB]ZERO       <>  [F:ATB]ZERO      : DIFF = 1 : Endif
    If [F:DATB]FLG130     <>  [F:ATB]FLG130    : DIFF = 1 : Endif
    If [F:DATB]SECURE     <>  [F:ATB]SECURE    : DIFF = 1 : Endif
    If [F:DATB]FLGLEG     <>  [F:ATB]FLGLEG    : DIFF = 1 : Endif
    If dim([F:DATB]GENTRA)<=0 or ([F:ATB]GENTRA=2 & [F:DATB]GENTRA<>2) : DIFF = 1 : Endif

    GEN = [F:DATB]GENTRA
    OLDENREG = [F:DATB]NBENREG
    Gosub TAILLE
    If NEWENREG>OLDENREG : DIFF = 1 : Endif : # Seulement si c'est plus grand

    ## Comparaison et mise à jour des zones

    For [ATZ]CODZONE Where CODFIC=[F:ATB]CODFIC
     Read [DATZ]CODZONE = [F:ATB]CODFIC;[F:ATZ]CODZONE
     If fstat

      # Nouvelle zone

      DIFF = 1
      [F:DATZ] = [F:ATZ]
      If [F:DATZ]CODACT<>""
       Gosub RAZNONACTIF
      Endif
      Write [DATZ]
      If fstat : Call ERREUR("ATABZON"-[F:DATZ]CODFIC-[F:DATZ]CODZONE,1) From DOSDIC : Endif
      Delete [DAMP] Where TYPAFF=2 & CODAFF=[F:ATZ]CODFIC & CODZON=[F:ATZ]CODZONE
      If fstat=1 : Call ERREUR("AMSKPAR"-[F:ATZ]CODFIC-[F:ATZ]CODZONE,3) From DOSDIC : Endif
      For [AMP] Where TYPAFF=2 & CODAFF=[F:ATZ]CODFIC & CODZON=[F:ATZ]CODZONE
       [F:DAMP] = [F:AMP]
       Write [DAMP]
       If fstat : Call ERREUR("AMSKPAR"-[F:ATZ]CODFIC-[F:ATZ]CODZONE,1) From DOSDIC : Endif
      Next

     Elsif !find([F:DATZ]CODACT,GSPE(1..GNBSPE))

      # Ancienne zone non spécifique

      RW = 0
      Call DIFFACT([F:ADS]DOSSIER,[F:ATZ]CODACT,ACTIV) From DOSSUB
      If [F:ATZ]CODACT<>""
       Call NEWREC([F:ADS]DOSSIER,[F:ATZ]CODACT,0,K) From DOSSUB
      Else
       K = 1
      Endif
      If !K
       If [F:DATZ]CODTYP   <>  "A"    : RW = 1 : Endif
       If [F:DATZ]LONG     <>  1      : RW = 1 : Endif
       If [F:DATZ]DIME     <>  1      : RW = 1 : Endif
       If [F:DATZ]NOLIB    <>  0      : RW = 1 : Endif
       If [F:DATZ]OPTION   <>  ""     : RW = 1 : Endif
       If [F:DATZ]LIEN     <>  ""     : RW = 1 : Endif
       If [F:DATZ]EXPLIEN  <>  ""     : RW = 1 : Endif
       If [F:DATZ]ANNUL    <>  0      : RW = 1 : Endif
       If [F:DATZ]VERIF    <>  0      : RW = 1 : Endif
       If [F:DATZ]CHPLEG   <>  0      : RW = 1 : Endif
       If [F:DATZ]OBLIG    <>  1      : RW = 1 : Endif
       If [F:DATZ]ZERO     <>  1      : RW = 1 : Endif
      Else
       If [F:DATZ]CODTYP   <>  [F:ATZ]CODTYP    : RW = 1 : Endif
       If [F:DATZ]LONG     <>  [F:ATZ]LONG      : RW = 1 : Endif
       If [F:DATZ]DIME     <>  [F:ATZ]DIME      : RW = 1 : Endif
       If [F:DATZ]NOLIB    <>  [F:ATZ]NOLIB     : RW = 1 : Endif
       If [F:DATZ]OPTION   <>  [F:ATZ]OPTION    : RW = 1 : Endif
       If [F:DATZ]LIEN     <>  [F:ATZ]LIEN      : RW = 1 : Endif
       If [F:DATZ]EXPLIEN  <>  [F:ATZ]EXPLIEN   : RW = 1 : Endif
       If [F:DATZ]ANNUL    <>  [F:ATZ]ANNUL     : RW = 1 : Endif
       If [F:DATZ]VERIF    <>  [F:ATZ]VERIF     : RW = 1 : Endif
       If [F:DATZ]CHPLEG   <>  [F:ATZ]CHPLEG    : RW = 1 : Endif
       If [F:DATZ]OBLIG    <>  [F:ATZ]OBLIG     : RW = 1 : Endif
       If [F:DATZ]ZERO     <>  [F:ATZ]ZERO      : RW = 1 : Endif
      Endif
      If [F:DATZ]CODACT   <>  [F:ATZ]CODACT    : RW = 1 : Endif
      If [F:DATZ]CODZONE  <>  [F:ATZ]CODZONE   : RW = 1 : Endif
      If [F:DATZ]NOABREG  <>  [F:ATZ]NOABREG   : RW = 1 : Endif
      If [F:DATZ]NOCOURT  <>  [F:ATZ]NOCOURT   : RW = 1 : Endif
      If [F:DATZ]NOLONG   <>  [F:ATZ]NOLONG    : RW = 1 : Endif
      If [F:DATZ]NUMLIG   <>  [F:ATZ]NUMLIG    : RW = 1 : Endif
      If RW
       DIFF = RW
       [F:DATZ] = [F:ATZ]
       If [F:DATZ]CODACT<>""
        Gosub RAZNONACTIF
       Endif
       Rewrite [DATZ]
       If fstat : Call ERREUR("ATABZON"-[F:DATZ]CODFIC-[F:DATZ]CODZONE,2) From DOSDIC : Endif
      Endif
      Delete [DAMP] Where TYPAFF=2 & CODAFF=[F:ATZ]CODFIC & CODZON=[F:ATZ]CODZONE
      If fstat=1 : Call ERREUR("AMSKPAR"-[F:ATZ]CODFIC-[F:ATZ]CODZONE,3) From DOSDIC : Endif
      For [AMP] Where TYPAFF=2 & CODAFF=[F:ATZ]CODFIC & CODZON=[F:ATZ]CODZONE
       [F:DAMP] = [F:AMP]
       Write [DAMP]
       If fstat : Call ERREUR("AMSKPAR"-[F:ATZ]CODFIC-[F:ATZ]CODZONE,1) From DOSDIC : Endif
      Next
     Endif
    Next ATZ

    ## Suppression des anciennes zones non reconduites

    For [DATZ]CODZONE Where CODFIC=[F:ATB]CODFIC
     If !find([F:DATZ]CODACT,GSPE(1..GNBSPE))
      Read [ATZ]CODZONE = [F:ATB]CODFIC;[F:DATZ]CODZONE
      If fstat
       DIFF = 1
       Delete [DAMP] Where TYPAFF=2 & CODAFF=[F:DATZ]CODFIC & CODZON=[F:DATZ]CODZONE
       If fstat=1 : Call ERREUR("AMSKPAR"-[F:DATZ]CODFIC-[F:DATZ]CODZONE,3) From DOSDIC : Endif
       Delete [DATZ]
       If fstat=1 : Call ERREUR("ATABZON"-[F:DATZ]CODFIC-[F:DATZ]CODZONE,3) From DOSDIC : Endif
      Endif
     Endif
    Next DATZ

    ## Suppression des audits sur champs supprimés

    If AUDIT
     For [DATA]ATA0 Where CODFIC=[F:ATB]CODFIC
      Read [DATZ]CODZONE = [F:DATA]CODFIC;[F:DATA]FLD
      If fstat
       Delete [DATA]
       If fstat=1 : Call ERREUR("ATABAUD"-[F:DATA]CODFIC-[F:DATA]FLD,3) From DOSDIC : Endif
      Endif
     Next
    Endif

    ## Comparaison et mise à jour des index

    For [ATI]CODIND Where CODFIC=[F:ATB]CODFIC
     Read [DATI]CODIND = [F:ATB]CODFIC;[F:ATI]CODIND
     If fstat

      # Nouvel index

      DIFF = 1
      [F:DATI] = [F:ATI]
      Write [DATI]
      If fstat : Call ERREUR("ATABIND"-[F:DATI]CODFIC-[F:DATI]CODIND,1) From DOSDIC : Endif

     Elsif !find([F:DATI]CODACT,GSPE(1..GNBSPE))

      # Ancien index non spécifique

      RW = 0
      Call DIFFACT([F:ADS]DOSSIER,[F:ATI]CODACT,ACTIV) From DOSSUB
      If [F:DATI]CODACT    <>  [F:ATI]CODACT    : RW = 1 : Endif
      If [F:DATI]DESCRIPT  <>  [F:ATI]DESCRIPT  : RW = 1 : Endif
      If [F:DATI]HOMONYM   <>  [F:ATI]HOMONYM   : RW = 1 : Endif
      If [F:DATI]NUMLIG    <>  [F:ATI]NUMLIG    : RW = 1 : Endif
      If [F:DATI]NIVDEC    <>  [F:ATI]NIVDEC    : RW = 1 : Endif

      If RW
       DIFF = RW
       [F:DATI] = [F:ATI]
       Rewrite [DATI]
       If fstat : Call ERREUR("ATABIND"-[F:DATI]CODFIC-[F:DATI]CODIND,2) From DOSDIC : Endif
      Endif
     Endif
    Next ATI

    ## Suppression des anciens index non reconduits

    For [DATI]CODIND Where CODFIC=[F:ATB]CODFIC
     If !find([F:DATI]CODACT,GSPE(1..GNBSPE))
      Read [ATI]CODIND = [F:ATB]CODFIC;[F:DATI]CODIND
      If fstat
       DIFF = 1
       Delete [DATI]
       If fstat=1 : Call ERREUR("ATABIND"-[F:DATI]CODFIC-[F:DATI]CODIND,3) From DOSDIC : Endif
      Endif
     Endif
    Next DATI

    ## Vérification des champs désactivés dans les index

    Call VIRE_INDEX(DIFF)

    ## Réécriture de l'en_tête

    If dim([F:DATB]AUDCRE)>0 : AUD1 = [F:DATB]AUDCRE : Endif
    If dim([F:DATB]AUDUPD)>0 : AUD2 = [F:DATB]AUDUPD : Endif
    If dim([F:DATB]AUDDEL)>0 : AUD3 = [F:DATB]AUDDEL : Endif
    If dim([F:DATB]AUDWRK)>0 : AUD4 = [F:DATB]AUDWRK : Endif
    If dim([F:DATB]AUDBI)>0  : AUD5 = [F:DATB]AUDBI  : Endif
    If dim([F:DATB]AUDSDA)>0 : AUD6 = [F:DATB]AUDSDA : Endif
    If dim([F:DATB]ASDCLE)>0 : AUDC = [F:DATB]ASDCLE : Endif
    If dim([F:DATB]GENTRA)<=0 or [F:ATB]GENTRA=2
     GEN = [F:ATB]GENTRA
    Else
     GEN = [F:DATB]GENTRA
    Endif

    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff table"-[F:ATB]CODFIC-num$(DIFF),0) From GESECRAN
     Endif
     If [F:ATB]TYPFIC<3 : GNBTBL += 1 : Endif
     RWO = 1
     [F:DATB] = [F:ATB]
     [F:DATB]NBENREG = max(NEWENREG,OLDENREG) : # On ne diminue pas la taille
     [F:DATB]UPDDAT = date$
     [F:DATB]UPDUSR = GUSER
     If dim([F:DATB]UPDTIM)>0 : [F:DATB]UPDTIM = time : Endif
     [F:DATB]UPDFLG = 1
     If dim([F:DATB]AUDCRE)>0 : [F:DATB]AUDCRE = max(1,AUD1) : Endif
     If dim([F:DATB]AUDUPD)>0 : [F:DATB]AUDUPD = max(1,AUD2) : Endif
     If dim([F:DATB]AUDDEL)>0 : [F:DATB]AUDDEL = max(1,AUD3) : Endif
     If dim([F:DATB]AUDWRK)>0 : [F:DATB]AUDWRK = max(1,AUD4) : Endif
     If dim([F:DATB]AUDBI)>0  : [F:DATB]AUDBI  = max(1,AUD5) : Endif
     If dim([F:DATB]AUDSDA)>0 : [F:DATB]AUDSDA = max(1,AUD6) : Endif
     If dim([F:DATB]ASDCLE)>0 : [F:DATB]ASDCLE = AUDC        : Endif
     If dim([F:DATB]GENTRA)>0 : [F:DATB]GENTRA = GEN : Endif
     Rewrite [DATB]
     If fstat : Call ERREUR("ATABLE"-[F:DATB]CODFIC,2) From DOSDIC : Endif
    #104160 pb si S-data désactivé , idem si BI
    #Elsif ACTIV or (!AUDIT & (AUD1=2 | AUD2=2 | AUD3=2))
    Elsif ACTIV or (!AUDIT & (AUD1=2 | AUD2=2 | AUD3=2 | AUD5=2 | AUD6=2))
&               or (!ABI & AUD5=2)
&               or (!ASD & AUD6=2)
     # Changement d'un code activité ou code activité AUDIT désactivité (et trigger)
     # code activité ABI désactivité et trigger BI
     # code activité ASD désactivité et trigger SDATA
     RWO = 1
     [F:DATB]UPDFLG = 1
     [F:DATB]UPDDAT = date$
     If dim([F:DATB]UPDTIM)>0 : [F:DATB]UPDTIM = time : Endif
     [F:DATB]UPDUSR = GUSER
     If [F:ATB]TYPFIC<3 : GNBTBL += 1 : Endif
     Rewrite [DATB]
     If fstat : Call ERREUR("ATABLE"-[F:DATB]CODFIC,2) From DOSDIC : Endif
    Endif
   Endif
  Endif

 Commit
Next ATB

# Création des index spécifiques

K = 0
For [DANX]
 K = max(K,[F:DANX]LIG)
Next DANX
Trbegin [ANX]
 For [ANX]ANX2
  Read [DATB]CODFIC=[F:ANX]TABLE
  If !fstat
   Read [DANX]ANX2=[F:ANX]TABLE;[F:ANX]CODIND
   If fstat
    K += 1
    [F:DANX] = [F:ANX]
    [F:DANX]LIG   = K
    [F:DANX]FLACT = 1
    Write [DANX]
    If fstat : Call ERREUR("AINDEX"-[F:DANX]TABLE-[F:DANX]CODIND,1) From DOSDIC : Endif
    If !GCRE
     Call COPTEXTRA("AINDEX","COMDES",[F:ANX]TABLE,[F:ANX]CODIND) From ATEXTRA
    Endif
   Endif
  Endif
 Next ANX
Commit

Close Local File [ATB] , [ATZ] , [ATI] , [AMP]
Close Local File [AFO] , [ADE] , [DACV] , [ATY]
Close Local File [DATB] , [DATZ] , [DATI] , [DAMP]
Close Local File [DANX] , [ANX]
If !GCRE
 Close Local File [AXX1] , [AXX2]
Endif
If AUDIT
 Close Local File [DATA] , [ATA]
Endif

Return

###################################################################################
$RAZNONACTIF
Call NEWREC([F:ADS]DOSSIER,[F:DATZ]CODACT,0,K) From DOSSUB
If !K
 Read [ATY]CODTYP=[F:ATZ]CODTYP
 If !fstat
  Call CHANGE_CODTYP(1,[F:ATY]TYPTYP,[F:DATZ]CODTYP,[F:DATZ]LONG) From DOSDICDIV
 Else
  [F:DATZ]CODTYP  = "A"
  [F:DATZ]LONG    = 1
 Endif
 [F:DATZ]DIME    = 1
 [F:DATZ]NOLIB   = 0
 [F:DATZ]OPTION  = ""
 [F:DATZ]LIEN    = ""
 [F:DATZ]EXPLIEN = ""
 [F:DATZ]ANNUL   = 0
 [F:DATZ]VERIF   = 0
 [F:DATZ]CHPLEG  = 0
 [F:DATZ]OBLIG   = 1
 [F:DATZ]ZERO    = 1
Endif
Return

###################################################################################
Subprog VIRE_INDEX(DIFF)
Variable Integer DIFF
Local Integer I , J , K , L
Local Char    CAR(1), NEWIND(250), ZONE(20)(1..16), SENS(1)(1..16)
Local Integer NBCLE1 , NBCLE2
Local Char    CLE1(20)(1..16) , CLE2(20)(1..16) , CHAINE(250)
For [DATI]CODIND Where CODFIC=[F:ATB]CODFIC
 Raz SENS, ZONE, NEWIND
 J = 1
 For I=1 To len([F:DATI]DESCRIPT)
  CAR = mid$([F:DATI]DESCRIPT,I,1)
  If find(CAR,"-","+")
   J += 1
   SENS(J) = CAR
  Else
   ZONE(J) += CAR
  Endif
 Next I
 For I=1 To J
  Read [DATZ]CODZONE = [F:ATB]CODFIC;ZONE(I)
  If !fstat
   K = 1
   If [F:DATZ]CODACT<>""
    Read [ADA]ADA0 = [F:ADS]DOSSIER;[F:DATZ]CODACT
    If fstat or [F:ADA]FLACT<>2
     K = 0
    Endif
   Endif
   If K
    If NEWIND<>""
     NEWIND += SENS(I)
    Endif
    NEWIND += ZONE(I)
   Endif
  Endif
 Next I
 If NEWIND=""
  DIFF = 1
  Delete [DATI]
  If fstat=1 : Call ERREUR("ATABIND"-[F:DATI]CODFIC-[F:DATI]CODIND,3) From DOSDIC : Endif
 Elsif NEWIND<>[F:DATI]DESCRIPT
  DIFF = 1
  [F:DATI]DESCRIPT=NEWIND
  Rewrite [DATI]
  If fstat : Call ERREUR("ATABIND"-[F:DATI]CODFIC-[F:DATI]CODIND,2) From DOSDIC : Endif
 Endif
Next DATI
# Pour virer les doublons en cas de zone désactivée
Filter [DATI] Where CODFIC=[F:ATB]CODFIC
Read [DATI]CODIND First
CLE1   = [F:DATI]CODIND
CHAINE = [F:DATI]DESCRIPT
While 1=1
 For [DATI]CODIND Where CODFIC=[F:ATB]CODFIC & CODIND>CLE1
  If [F:DATI]DESCRIPT=CHAINE
   DIFF = 1
   Delete [DATI]
   If fstat=1 : Call ERREUR("ATABIND"-[F:DATI]CODFIC-[F:DATI]CODIND,3) From DOSDIC : Endif
  Endif
 Next DATI
 Filter [DATI] Where CODFIC=[F:ATB]CODFIC & CODIND>CLE1
 Read [DATI]CODIND First
 If fstat : Break : Endif
 CLE1   = [F:DATI]CODIND
 CHAINE = [F:DATI]DESCRIPT
Wend
Filter [DATI]
# Désactivation des index d'optimisation en cas de doublon
For [DANX] Where TABLE=[F:ATB]CODFIC & FLACT=2
 CHAINE = [F:DANX]DESCRIPT
 Raz CLE1, NBCLE1
 While CHAINE<>""
  I = instr(1,CHAINE,"+")
  J = instr(1,CHAINE,"-")
  If I & J
   I = min(I,J)
  Elsif J & !I
   I = J
  Endif
  NBCLE1 += 1
  If I
   CLE1(NBCLE1) = left$(CHAINE,I-1)
   CHAINE = right$(CHAINE,I+1)
  Else
   CLE1(NBCLE1) = CHAINE
   CHAINE = ""
  Endif
 Wend
 For [DATI] Where CODFIC=[F:ATB]CODFIC
  CHAINE = [F:DATI]DESCRIPT
  Raz CLE2, NBCLE2
  While CHAINE<>""
   I = instr(1,CHAINE,"+")
   J = instr(1,CHAINE,"-")
   If I & J
    I = min(I,J)
   Elsif J & !I
    I = J
   Endif
   NBCLE2 += 1
   If I
    CLE2(NBCLE2) = left$(CHAINE,I-1)
    CHAINE = right$(CHAINE,I+1)
   Else
    CLE2(NBCLE2) = CHAINE
    CHAINE = ""
   Endif
  Wend
  K = 0
  For I=1 To max(NBCLE1,NBCLE2)
   If CLE2(I)<>CLE1(I)
    K = 1 : Break
   Endif
  Next I
  If !K
   DIFF = 1
   [F:DANX]FLACT=1
   Rewrite [DANX]
   If fstat : Call ERREUR("AINDEX"-[F:DANX]TABLE-[F:DANX]CODIND,2) From DOSDIC : Endif
   Call ECR_TRACE([F:DANX]CODIND-mess(166,139,1),-1) From GESECRAN : # Index optimisation désactivé
  Endif
 Next DATI
Next DANX
End

##################################
$TAILLE
V = 1
NEWENREG = 0
Read [AFO]AFO0 = [F:ATB]CODFIC
If !fstat
 FORMULE = vireblc(format$("KT:80X",[F:AFO]FORDIM),2)
 If FORMULE<>""
  K = 1
  While K<len(FORMULE)
   If mid$(FORMULE,K,1)>="A" & mid$(FORMULE,K,1)<="Z"
    J = K
    VARIA = ""
    Repeat
     VARIA += mid$(FORMULE,K,1)
     K += 1
    Until K>len(FORMULE) | mid$(FORMULE,K,1)<"A" | mid$(FORMULE,K,1)>"Z"
    NEWVAR = "VV("+num$(V)+")"
    FORMULE = left$(FORMULE,J-1)+NEWVAR+right$(FORMULE,K)
    K += len(NEWVAR)-len(VARIA)
    Read [ADE]ADE0 = [F:ADS]DOSSIER;VARIA
    If !fstat
     VV(V) = [F:ADE]NBR
    Endif
    V += 1
   Else
    K += 1
   Endif
  Wend
  ERR = 0
  Onerrgo RIEN
  NEWENREG = evalue(FORMULE)
  If ERR : NEWENREG = 0 : Endif
  Onerrgo ERRDIC From DOSDIC
 Endif
Endif
If NEWENREG=0
 If [F:ATB]NBENREG<>0
  NEWENREG = [F:ATB]NBENREG
 Else
  NEWENREG = 1000 : # mb 21.3.3 bug 13546
 Endif
Endif
Return

$RIEN
ERR = errn
Resume

#################################################################
## Effacement d'une table
#################################################################

Subprog EFFACE(TABLE)
Value Char TABLE
Local Integer STAT
Local Char    SUF(10) , FICTRT(GDIMFIC) , HISAPL(GLONADS) , APPLI(GLONADS)
APPLI = [F:ADS]DOSSIER
HISAPL = [F:ADS]DOSHIS
Call ECR_TRACE(mess(53,125,1)-TABLE,0) From GESECRAN
Call SUPP_TRT("ZZINI"+TABLE) From DOSSUB
Delete [DATI] Where CODFIC=TABLE
If fstat=1 : Call ERREUR("ATABIND"-TABLE,3) From DOSDIC : Endif
Delete [DATZ] Where CODFIC=TABLE
If fstat=1 : Call ERREUR("ATABZON"-TABLE,3) From DOSDIC : Endif
Delete [DAMP] Where TYPAFF=2 & CODAFF=TABLE
If fstat=1 : Call ERREUR("AMSKPAR"-TABLE,3) From DOSDIC : Endif
If clalev([F:DATA])>0
 Delete [DATA] Where CODFIC=TABLE
 If fstat=1 : Call ERREUR("ATABAUD"-TABLE,3) From DOSDIC : Endif
Endif
Delete [DATB] Where CODFIC=TABLE
If fstat=1 : Call ERREUR("ATABLE"-TABLE,3)  From DOSDIC : Endif
If filinfo(filpath("FIL",TABLE,"fde",APPLI),0)>0
 Call SYSTEME(adxmac(0),"valfil -n"-APPLI-TABLE,"",STAT) From ORDSYS
 Call SYSTEME(adxmac(0),"valfil -d"-APPLI-TABLE,"",STAT) From ORDSYS
 For SUF = "srf", "fde", "dat", "idx" , "cfg"
  FICTRT = filpath("FIL",TABLE,SUF,APPLI)
  If filinfo(FICTRT,0)>=0
   Call EFFACE(FICTRT,STAT) From ORDSYS
  Endif
 Next SUF
 If HISAPL<>"" & filinfo(filpath("FIL",TABLE,"fde",HISAPL),0)>0
  Call SYSTEME(adxmac(0),"valfil -n"-HISAPL-TABLE,"",STAT) From ORDSYS
  Call SYSTEME(adxmac(0),"valfil -d"-HISAPL-TABLE,"",STAT) From ORDSYS
  For SUF = "srf", "fde", "viw" , "dat" , "idx" , "cfg"
   FICTRT = filpath("FIL",TABLE,SUF,HISAPL)
   If filinfo(FICTRT,0)>=0
    Call EFFACE(FICTRT,STAT) From ORDSYS
   Endif
  Next SUF
 Endif
Endif
End

