###################
# CLASS GRANTS
###################


$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
       When "AREAD_AFTER"       : Gosub AREAD_AFTER
    Endcase
Endcase
Return

$METHODS

  If (dim(CURPTH) > 0) Then
  Case CURPTH
    When ""
      Case AMETHOD
        When "CONSTRUCTOR"       : Gosub CONSTRUCTOR
        When "TRANS_QUERY"       : Gosub TRANS_QUERY
        When "CLOSE_QUERY"       : Gosub CLOSE_QUERY
        When "PROPERTIES_QUERY"  : Gosub PROPERTIES_QUERY
        When "LOAD"              : Gosub LOAD
        When Default
      Endcase
    When "LINE"
    When "SUBLINE"
    When Default
  Endcase
  Endif
Return

###################################################################
#            METHODES DE LA CLASSE  -  LAYOUTFAS
###################################################################

$CONSTRUCTOR
Return

$TRANS_QUERY
Return


$CLOSE_QUERY
Return

$PROPERTIES_QUERY
Return


$AREAD_AFTER


  If ( CURPTH = "" ) Then
#    Local Integer I_ENC : I_ENC = 1
#    While this.GRT.CASHING(I_ENC) <> null
#     this.CASHTOT += this.GRT.CASHING(I_ENC).CASHAMT
#     I_ENC += 1
#    Wend
  Endif
Return

$LOAD
Return



