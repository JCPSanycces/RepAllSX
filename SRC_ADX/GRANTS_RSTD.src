###################################################################
$XXXX
Case ARULE
   When "INIT"      : Gosub INIT_XXXX      : # Init method attached to XXXX
   When "CONTROL"   : Gosub CONTROL_XXXX   : # Control method attached to XXXX
   When "PROPAGATE" : Gosub PROPAGATE_XXXX : # Propagate method attached to XXXX
   When "GET"       : Gosub GET_XXXX       : # Get method attached to XXXX
Endcase
Return
