Call PATCH(nomap)

End

#**
#* Publication of web services
#*
#*    -AOWSBATGET Get Batch
#*    -AOWSEXPORT Export web service
#*    -AOWSIMPORT Import
#*
#* @param APPLI
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

#Call PUBLIALLWS(APPLI,1) From SUBAWE
Call PUBLIWS(APPLI,"AOWSBATGET") From SUBAWE
Call PUBLIWS(APPLI,"AOWSEXPORT") From SUBAWE
Call PUBLIWS(APPLI,"AOWSIMPORT") From SUBAWE

End

