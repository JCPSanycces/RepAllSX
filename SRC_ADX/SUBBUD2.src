Local Integer IND
IND = 9 : Gosub AV_CCE
End

$AV_CCE
If !clalev([F:BUP])
 GFMT = "10c" : Return
Endif
Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
If [F:BUP]PYMCCE(IND-1)=""
 Gosub AXI
 Call INICCEFMT(AXI) From SETGLBDIE
 GFMT = GCCEFMT
Else
 GFMT = "10c"
Endif
Return

$AXI
Local Char AXI(GLONDIE)

Case IND
 When 1 : AXI = [M]DIE1
 When 2 : AXI = [M]DIE2
 When 3 : AXI = [M]DIE3
 When 4 : AXI = [M]DIE4
 When 5 : AXI = [M]DIE5
 When 6 : AXI = [M]DIE6
 When 7 : AXI = [M]DIE7
 When 8 : AXI = [M]DIE8
 When 9 : AXI = [M]DIE9
Endcase
Return

