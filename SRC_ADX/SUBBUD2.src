Subprog AP_CCE1(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 1 : Gosub AP_CCE
End

Subprog AP_CCE2(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 2 : Gosub AP_CCE
End

Subprog AP_CCE3(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 3 : Gosub AP_CCE
End

