## C_CCExx

Subprog C_CCE1(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 1 : Gosub C_CCE
End

Subprog C_CCE2(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 2 : Gosub C_CCE
End

Subprog C_CCE3(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 3 : Gosub C_CCE
End

Subprog C_CCE4(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 4 : Gosub C_CCE
End

Subprog C_CCE5(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 5 : Gosub C_CCE
End

Subprog C_CCE6(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 6 : Gosub C_CCE
End

Subprog C_CCE7(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 7 : Gosub C_CCE
End

Subprog C_CCE8(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 8 : Gosub C_CCE
End

Subprog C_CCE9(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 9 : Gosub C_CCE
End

$C_CCE
Local Char    CCEACC(max(GLONGAC,GLONCCE)) : # Valeur de la section (ou compte)
Local Integer OK

Gosub AXI
Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ

If [F:BUP]PYMCCE(IND-1)=""
 ## Existence
 Call CONTROLE("CCE","",VALEUR,AXI,mkstat) From CONTOBJ
 If mkstat : End : Endif
 ## Code d'accès
 Call CONTEXE([F:CCE]ACS) From CPTSUB
 If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
 ## Section non budgétisable
 If [F:CCE]BUDTRK = 1 : GMESSAGE = mess(5,103,1) : mkstat=2 : End : Endif
 ## Vérif site/société et Dates de validités
 ## La section doit être valide et autorisée sur toutes les lignes critères
 For I=0 To [M:BCR]NBRBUD-1
  # NBRBUD et non NBRCRI pour ne prendre que les lignes des budgets qui seront affichées
  # dans le tableau.
  If [M:BCR]BUD(I)<>""
   Call BUDSITE([F:CCE]FCY,[F:BUP]LEV,[M:BCR]FCY(I),[M:BCR]CPY(0),VALEUR) From CFYSUB
   If mkstat=2 : Break : Endif
   If [CCE]VLYEND<>[0/0/0] & [CCE]VLYEND<[M:BCR]DATDEB(I)
&   | [CCE]VLYSTR<>[0/0/0] & [CCE]VLYSTR>[M:BCR]DATFIN(I)
    # Section inactive
    GMESSAGE = mess(7,103,1)
    mkstat = 2 : Break
   Endif
  Endif
 Next
 If mkstat : End : Endif
 ## Autorisations nature
 CCEACC = VALEUR
 Gosub AUTCCEACC From BUDGET3
 If !OK : mkstat = 2 : End : Endif
 ## Autorisations sections
 CCEACC = VALEUR
 Gosub AUTSECSEC From BUDGET3
 If !OK : mkstat = 2 : End : Endif
Else
 Filter [CRY]
 Call CONTROLE("CRY","",VALEUR,[F:BUP]PYMCCE(IND-1),mkstat) From CONTOBJ
 If mkstat : End : Endif
 If [F:CRY]LEV<>[F:BUP]PYMCCELEV(IND-1)
  # Groupe de section incorrect
  GMESSAGE = mess(32,103,1)
  mkstat=2 : End
 Endif
 If [F:CRY]BUDTRK<>2
  GMESSAGE = mess(27,103,1)
  mkstat = 2 :End
 Endif
Endif
# Zoom depuis la gestion des sections analytiques qui alimente automatiquement la section.
# Pour passer dans l'aprés modif (qui charge les natures), on positionne mkstat à 4.
If GFONCTION="GESCCE" and [F:BUP]DIENBR=1
 mkstat = 4
Endif
Return

