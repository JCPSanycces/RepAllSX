######################################################################################
## Obsolète ????

$S_VER
Filter [BUD] Where LEDTYP=[M]LEDTYP and BUD=[M:BCR]BUD and CPY=[M:BCR]CPY and FCY=[M:BCR]FCY
If nbrecord([BUD])=0
 VALEUR = 1
 Return
Endif
## Choix du numéro de version
TIT(0) = mess(100,103,1)
NBTEX = 0
For [F:BUD]
 If find([F:BUD]VER, TEX(1..NBTEX))=0
  NBTEX += 1
  TEX(NBTEX) = [F:BUD]VER
  TEXTE(NBTEX) = TEX(NBTEX)
 Endif
Next
Filter [BUD]
Return

