Local Integer IND
IND = 6 : Gosub AP_CCE
End

Subprog AP_CCE7(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 7 : Gosub AP_CCE
End

Subprog AP_CCE8(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 8 : Gosub AP_CCE
End

Subprog AP_CCE9(VALEUR)
Variable Char     VALEUR
Local Integer IND
IND = 9 : Gosub AP_CCE
End

$AP_CCE
Local Char    DESIG(50)
Gosub AXI
Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
If [F:BUP]PYMCCE(IND-1)=""
 Call LECTEXTRA(DESIG,"CACCE","DESTRA",AXI,VALEUR) From ATEXTRA
Else
 Filter [CRY] Where PYM=[F:BUP]PYMCCE(IND-1) and GRU=VALEUR and LIN=1
 Read [CRY] First
 Call LECTEXTRA(DESIG,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Filter [CRY]
Endif
If !GIMPORT
 Case IND
  When 1 : [M]DESCCE1 = DESIG : Affzo DESCCE1
  When 2 : [M]DESCCE2 = DESIG : Affzo DESCCE2
  When 3 : [M]DESCCE3 = DESIG : Affzo DESCCE3
  When 4 : [M]DESCCE4 = DESIG : Affzo DESCCE4
  When 5 : [M]DESCCE5 = DESIG : Affzo DESCCE5
  When 6 : [M]DESCCE6 = DESIG : Affzo DESCCE6
  When 7 : [M]DESCCE7 = DESIG : Affzo DESCCE7
  When 8 : [M]DESCCE8 = DESIG : Affzo DESCCE8
  When 9 : [M]DESCCE9 = DESIG : Affzo DESCCE9
 Endcase
Endif
Return

Subprog AS_QTE(VALEUR,COL)
Variable Decimal VALEUR
Value    Integer COL
Local    Char    NAT(GLONCNA)
Local    Decimal VALNAT

Gosub AFFICHE From BUDGET

Call LECTURE("TBU",[M:BCR]BUDTYP,num$(COL)) From CONTOBJ
# Critère budget non saisi pour la colonne qte
If [M:BCR]BUD([F:TBU]LINSELCRI-1)="" : mkstat=2 : End : Endif
Call LECTURE("BUP",[M:BCR]BUD([F:TBU]LINSELCRI-1),"") From CONTOBJ
If [M:BCR]BUDCAT = 3
 NAT = [M:BUD]CODACC(nolign-1)
Else
 NAT = [M:BUD]ACC
Endif
If [F:BUP]PYMACC=""
 Call LECTURE("GAC",NAT,[F:BUP]COA) From CONTOBJ
 If [F:GAC]UOM="" : mkstat=1 : End : Endif
 VALNAT = [F:GAC]VALUOM
Else
 Filter [GRY] Where PYM = [F:BUP]PYMACC and GRU = NAT and LIN=1
 Read [GRY] First
 Filter [GRY]
 If [F:GRY]UOMDAC<>2 : mkstat=1 : End : Endif
 VALNAT = [F:GRY]DEFVAL
Endif
If [F:BUP]QTY = 1
 mkstat=1 : End
Endif
# Pré calcul de la quantité budgétée par rapport au montant budgété
If VALEUR=0 & VALNAT<>0
 If clalev ([F:TBU2])=0 : Local File TABBUDTYP  [TBU2] : Endif
 Filter [TBU2] Where BUDTYP=[F:TBU]BUDTYP & LINSELCRI=[F:TBU]LINSELCRI & COLTYP=2
 Read [TBU2]TBU1 First
 If !fstat & evalue("[M:BUD]AMT"+num$([F:TBU2]COLNUM)+"(nolign-1)")<>0
  VALEUR = evalue("[M:BUD]AMT"+num$([F:TBU2]COLNUM)+"(nolign-1)") / VALNAT
 Endif
Endif
End


Subprog B2_AMONT(VALEUR,COL)
Variable Decimal VALEUR
Value Integer COL
Local Integer ETABOU(1..GNBBOU)
Call REPARTITION(COL)
ETABOU(GENRE) = 1   : # Enregistrer
ETABOU(GABAN) = 1   : # Abandon
Call SETBOUT(ETABOU) From GESECRAN
VALEUR = evalue("[M:BUD]AMT"+num$(COL)+"("+num$(nolign-1)+")")
End

Subprog REPARTITION(COL)
Value Integer COL
##Local Decimal TABQTEUOM(0..[M:BUD]NBLIG-1)
Local Decimal TABQTEUOM(0..max(0,[M:BUD]NBLIG-1)) : # <PP 17/09/04>
Local Decimal TOTQTEUOM
Local Integer I, J, OK
Local Char DIECOL(GLONDIE)
Local Mask BUNDSPUOM [BUND]

Effzo [BUD] ="AMT"+num$(COL)
Effzo [BUD] 30-35

OK=2
#Call DIALO(OK,mess(16,108,1)) From GESECRAN
Call DIALWIN(OK,mess(16,108,1),"DBUNDSPUOM") From GESECRAN : # <PP 17/09/04> Bug 25014
If OK<>2 : End : Endif

Call TEMPON("C") From GESECRAN

Raz TABQTEUOM, TOTQTEUOM

Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
DIECOL = evalue("[F:BUP]DIE("+num$([F:BUP]DIENBR-1)+")")

For I=0 To [M:BUD]NBLIG-1
 Read [CCE]CCE0 = DIECOL ; [M:BUD]CODCCE3(I)
 J = find([M:BUND]UOM,[F:CCE]UOM(0..dim([F:CCE]UOM)-1))
 If J
  TABQTEUOM(I) = [F:CCE]QTY(J-1)
  TOTQTEUOM   += TABQTEUOM(I)
 Else
  TABQTEUOM(I)  = 0
  Assign "[M:BUD]AMT"+num$(COL)+"("+num$(I)+")" With 0
  If [M:BCR]BUDCAT<>1 : [M:BUD]FLGMOD(I) = 2 : Endif
 Endif
Next
Default Mask [BUD]
If TOTQTEUOM>0
 For I=0 To [M:BUD]NBLIG-1
  Assign "[M:BUD]AMT"+num$(COL)+"("+num$(I)+")" With arr([M:BUND]AMTDSP*TABQTEUOM(I)/TOTQTEUOM,1)
  If [M:BCR]BUDCAT<>1 : [M:BUD]FLGMOD(I) = 2 : Endif
 Next
Endif

Call TEMPOFF From GESECRAN

Affzo [BUD] ="AMT"+num$(COL)
Affzo [BUD] 30-40
End

Subprog AS_AMONT(COL)
Value Integer COL

Gosub AFFICHE From BUDGET

Call LECTURE("TBU",[M:BCR]BUDTYP,num$(COL)) From CONTOBJ
# Critère budget non saisi pour la colonne montant
If [M:BCR]BUD([F:TBU]LINSELCRI-1)="" : mkstat=2 : End : Endif
Call LECTURE("BUP",[M:BCR]BUD([F:TBU]LINSELCRI-1),"") From CONTOBJ
#If [F:BUP]BUDREF<>""
# mkstat = 2 : End
#Endif
If [M:BCR]BUDCAT<>2
 GBOUT2 = ""
Endif
End

Subprog AS_NBLIG
Local Integer LINPRP, LINCMM
## On a le tunnel sur les engagements uniquement si les colonnes engagements portent sur
## un seul budget/date/site/société. La ou les colonnes "Engagements" doivent être associées
## à une seule ligne de critère. Si on a 2 colonnes "engagements" qui portent sur des
## lignes de critères différentes (pas les mêmes dates ou sites), on a pas le bouton.
## Si on a qu'une colonne, on aura forcément le bouton.
Raz GBOUT2,GBOUT3
For [TBU]TBU0 Where BUDTYP=[M:BCR]BUDTYP
 Case [F:TBU]COLTYP
  When 5 : # Quantité engagée
   If evalue("[M:BUD]QTYCMM"+num$([F:TBU]COLNUM)+"(nolign-1)")<>0
    If LINCMM<>0 & LINCMM<>[F:TBU]LINSELCRI
     LINCMM = 999
    Else
     LINCMM = [F:TBU]LINSELCRI
    Endif
   Endif
  When 6 : # Montant engagé
   If evalue("[M:BUD]AMTCMM"+num$([F:TBU]COLNUM)+"(nolign-1)")<>0
    If LINCMM<>0 & LINCMM<>[F:TBU]LINSELCRI
     LINCMM = 999
    Else
     LINCMM = [F:TBU]LINSELCRI
    Endif
   Endif
  When 7 : # Quantité pré engagée
   If evalue("[M:BUD]QTYPRP"+num$([F:TBU]COLNUM)+"(nolign-1)")<>0
    If LINPRP<>0 & LINPRP<>[F:TBU]LINSELCRI
     LINPRP = 999
    Else
     LINPRP = [F:TBU]LINSELCRI
    Endif
   Endif
  When 8 : # Montant pré engagé
   If evalue("[M:BUD]AMTPRP"+num$([F:TBU]COLNUM)+"(nolign-1)")<>0
    If LINPRP<>0 & LINPRP<>[F:TBU]LINSELCRI
     LINPRP = 999
    Else
     LINPRP = [F:TBU]LINSELCRI
    Endif
   Endif
 Endcase
Next

## LINCMM = 0   => Pas de colonne engagement
## LINCMM = 999 => Plusieurs colonnes engagements définis sur des lignes critères différentes

If LINCMM<>0 & LINCMM<>999
 GBOUT3 = mess(2,631,1) : # Engagement
Endif
If LINPRP<>0 & LINPRP<>999
 GBOUT2 = mess(1,631,1) : # Pré engagement
Endif
End

Subprog C_NBLIG
# Les lignes pré chargées ne sont pas supprimables
# Les lignes ajoutées en saisie sont supprimables tant qu'elles ne sont pas enregistrées
# qu'il y ait pré chargement ou non
If (status=65 | status=83 | status=68) & nolign<=[M:BUD]NBRLIN : mkstat=2 : Endif
End

Subprog B1_NBLIG
Local Integer CAS
CAS = 1 : Gosub COPIE
End

$COPIE
Local Integer I,J,IND
IND = nolign-1
Case CAS
 When 1 : #NBLIG
   For [TBU]TBU0 Where BUDTYP=[M:BCR]BUDTYP & (NOMZON="AMT" | NOMZON="QTY")
    Call LECTURE("BUP",[M:BCR]BUD([F:TBU]LINSELCRI-1),"") From CONTOBJ
    OK = 1
    If [F:TBU]NOMZON="QTY"
     If [F:BUP]QTY =1 : OK = 0 : Endif
     If [M:BCR]BUDCAT <> 3
#???????????? On the account definition (GAC) there isn't the flag that enable uom input
       If [F:BUP]PYMACC<>""
          Filter [GRY] Where PYM = [F:BUP]PYMACC and GRU = [M:BUD]ACC and LIN=1
          Read [GRY] First
          Filter [GRY]
        If [F:GRY]UOMDAC<>2 : OK = 0 : Endif
       Endif
      Endif
     Endif
     For I=IND+1 To [M:BUD]NBLIG-1
      OK = 1
      If [M:BCR]BUDCAT = 3
       If [F:BUP]PYMACC<>""
          Filter [GRY] Where PYM = [F:BUP]PYMACC and GRU = [M:BUD]CODACC(I) and LIN=1
          Read [GRY] First
          Filter [GRY]
        If [F:GRY]UOMDAC<>2 : OK = 0 : Endif
       Endif
      Endif
      If OK
       Assign("[M:BUD]"+[F:TBU]NOMZON+num$([F:TBU]COLNUM)+"("+num$(I)+")") With
&           evalue("[M:BUD]"+[F:TBU]NOMZON+num$([F:TBU]COLNUM)+"("+num$(IND)+")")
       If [M:BCR]BUDCAT<>1 : [M:BUD]FLGMOD(I) = 2 : Endif
      Endif
     Next I
     Affzo [BUD] =[F:TBU]NOMZON+num$([F:TBU]COLNUM)
   Next
 When 2 : #AMT
   For I=IND To [M:BUD]NBLIG-1
    Assign("[M:BUD]"+zoncou+"("+num$(I)+")") With VALEUR
    If [M:BCR]BUDCAT<>1 : [M:BUD]FLGMOD(I) = 2 : Endif
   Next I
   Affzo [BUD] =zoncou
 When 3 : #QTY
   OK = 1
   Call LECTURE("TBU",[M:BCR]BUDTYP,num$(right$(zoncou,4))) From CONTOBJ
   Call LECTURE("BUP",[M:BCR]BUD([F:TBU]LINSELCRI-1),"") From CONTOBJ
   If [F:BUP]QTY = 1 : OK = 0 : Endif
   If [M:BCR]BUDCAT <> 3
#???????????? On the account definition (GAC) there isn't the flag that enable uom input
    If [F:BUP]PYMACC<>""
        Filter [GRY] Where PYM = [F:BUP]PYMACC and GRU = [M:BUD]ACC and LIN=1
        Read [GRY] First
        Filter [GRY]
        If [F:GRY]UOMDAC<>2 : OK = 0 : Endif
    Endif
   Endif
   If OK
    For I=IND To [M:BUD]NBLIG-1
     OK = 1
     If [M:BCR]BUDCAT = 3
      #If [F:BUP]PYMACC=""
      ##  Call LECTURE("GAC",[M:BUD]COCNA(I),[F:BUP]COA) From CONTOBJ
      #  If [F:GAC]FLGUOM<>2 : OK=0 : Endif
      #Else
      If [F:BUP]PYMACC<>""
        Filter [GRY] Where PYM = [F:BUP]PYMACC and GRU = [M:BUD]CODACC(I) and LIN=1
        Read [GRY] First
        Filter [GRY]
        If [F:GRY]UOMDAC<>2 : OK = 0 : Endif
      Endif
     Endif
     If OK
       Assign("[M:BUD]"+zoncou+"("+num$(I)+")") With VALEUR
       If [M:BCR]BUDCAT<>1 : [M:BUD]FLGMOD(I) = 2 : Endif
     Endif
    Next
   Endif
   Affzo [BUD] =zoncou : # déclenche l'avant zone
Endcase
Affzo [BUD]25-40
mkstat=2
Return

