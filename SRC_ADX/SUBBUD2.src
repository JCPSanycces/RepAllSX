#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"FBUD","BUDGET","DBUDCRI",4,"") From GTRAITE
End

##########################################################################
# Etiquettes du masque BUD
##########################################################################

Subprog AS_DEFIL(VALEUR)
Variable Integer VALEUR()
Local Integer K
Local Integer Y
Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
If !GMODIF
 K = indice : Effzo DEFIL : indice = K
 GMODIF = 1
 VALEUR = 2
 [M]DEFIL(indice) = VALEUR
Endif
Y=0

If    [M:BCR]BUDCAT=1 & [F:BUP]DIE(8)<>"" : Y=9
Elsif [M:BCR]BUDCAT=1 & [F:BUP]DIE(7)<>"" | [F:BUP]DIE(8)<>"" : Y=8
Elsif [M:BCR]BUDCAT=1 & [F:BUP]DIE(6)<>"" | [F:BUP]DIE(7)<>"" : Y=7
Elsif [M:BCR]BUDCAT=1 & [F:BUP]DIE(5)<>"" | [F:BUP]DIE(6)<>"" : Y=6
Elsif [M:BCR]BUDCAT=1 & [F:BUP]DIE(4)<>"" | [F:BUP]DIE(5)<>"" : Y=5
Elsif [M:BCR]BUDCAT=1 & [F:BUP]DIE(3)<>"" | [F:BUP]DIE(4)<>"" : Y=4
Elsif [M:BCR]BUDCAT=1 & [F:BUP]DIE(2)<>"" | [F:BUP]DIE(3)<>"" : Y=3
Elsif [M:BCR]BUDCAT=1 & [F:BUP]DIE(1)<>"" | [F:BUP]DIE(2)<>"" : Y=2
Elsif [M:BCR]BUDCAT=1 & [F:BUP]DIE(0)<>"" | [F:BUP]DIE(1)<>"" : Y=1
Elsif [M:BCR]BUDCAT=1 & [F:BUP]PYMACC<>"" | [F:BUP]DIE(0)<>"" : Y=0
Endif

If indice = Y : GMODIF=0 : Endif
mkstat = 2
End

Subprog IB_ACC
Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
If [F:BUP]PYMACC=""
 GBOUT1 = mess(35,103,1) : # Comptes analytiques
 GBIDC3 = "GAC"
Else
 GBOUT1 = mess(24,103,1) : # Groupe compte
 GBIDC3 = "GRY"
Endif
End

Subprog C_ACC(VALEUR)
Variable Char     VALEUR
Local Char    CCEACC(max(GLONGAC,GLONCCE)) : # Valeur de la nature ou section
Local Integer OK , IND, I, J

If clalev([F:GAC])=0  : Local File  GACCOUNT   [GAC]  : Endif

Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
If [F:BUP]PYMACC=""
 Filter [GAC] Where COA=[M:BUD]COA
 Call CONTROLE("GAC","",VALEUR,[F:BUP]COA,mkstat) From CONTOBJ
 If mkstat : End : Endif
 Filter [GAC]
 ## Vérif code d'accès
 Call CONTEXE([F:GAC]ACS) From CPTSUB : # Vérif code d'accèssub
 If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
 ## Vérif budgétisable
 If [F:GAC]BUDTRK<> 2 : GMESSAGE = mess(4,103,1) : mkstat = 2 : End : Endif : # Compte non budgétisable

 For I=0 To [M:BCR]NBRBUD-1
  # NBRBUD et non NBRCRI pour ne prendre que les lignes des budgets qui seront affichées
  # dans le tableau.
  Call BUDSITE([F:GAC]FCY,[F:BUP]LEV,[M:BCR]FCY(I),[M:BCR]CPY(0),VALEUR) From CFYSUB
  If mkstat=2 : Break : Endif
  If [GAC]VLYEND<>[0/0/0] & [GAC]VLYEND<[M:BCR]DATDEB(I)
&  | [GAC]VLYSTR<>[0/0/0] & [GAC]VLYSTR>[M:BCR]DATFIN(I)
   # Il faut au moins qu'un jour d'activité du compte se chevauche sur l'exercice pour que le compte soit actif
   # Compte inactif
   GMESSAGE = mess(6,103,1)
   mkstat = 2 : Break
  Endif
 Next
 If mkstat : End : Endif

 ## Autorisations avec les sections
 IND = 0
 CCEACC = VALEUR
 Gosub AUTCCEACC From BUDGET3
 If !OK : mkstat = 2 : End : Endif
Else
 Filter [GRY] Where PYM = [F:BUP]PYMACC
 Call CONTROLE("GRY","",VALEUR,[F:BUP]PYMACC,mkstat) From CONTOBJ
 If mkstat : End : Endif
 Filter [GRY]
 ## Vérif budgétisable
 If [F:GRY]BUDTRK<> 2 : GMESSAGE = mess(26,103,1) : mkstat = 2 : End : Endif : # Groupe de compte non budgétisable
 If [F:GRY]LEV<>[F:BUP]PYMACCLEV
  # Groupe de compte incorrect
  GMESSAGE = mess(31,103,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AP_ACC(VALEUR)
Variable Char     VALEUR
Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
If [F:BUP]PYMACC=""
 Read [GAC]GAC0 = [M:BUD]COA;VALEUR
 Call LECTEXTRA([M]DESACC,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 [M]DTP    = [F:GAC]TIMDSP
 [M]UOMACC = [F:GAC]UOM
 Affzo DESACC, DTP, UOMACC
Else
 Filter [GRY] Where PYM = [F:BUP]PYMACC and GRU = VALEUR and LIN=1
 Read [GRY] First
 Filter [GRY]
 Call LECTEXTRA([M]DESACC,"GACCGRUPYM","DESTRA",[F:GRY]PYM,[F:GRY]GRU) From ATEXTRA
 [M]DTP    = [F:GRY]TIMDSP
 [M]UOMACC = [F:GRY]UOM
 Affzo DESACC, DTP, UOMACC
Endif
End

############################## CODCNA pour les budgets par section ############################
Subprog IB_CODACC
Call IB_ACC
End

Subprog AS_CODACC(VALEUR)
Variable Char    VALEUR()
Gosub AFFICHE From BUDGET
If nolign<=[M]NBRLIN :  mkstat=2 : Endif
End

Subprog C_CODACC(VALEUR)
Variable Char    VALEUR()
If clalev([F:CLS])=0  : Local File GACCCLS [CLS] : Endif
If clalev([F:GCOA])=0 : Local File GCOA [COA]    : Endif
Call UNICITE(VALEUR,[M:BUD]CODACC) From OBJDIV
If mkstat : End : Endif
Call C_ACC(VALEUR)
If mkstat : End : Endif
Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
If [F:BUP]PYMACC=""
 Call LECTURE("GAC",VALEUR,[M:BUD]COA) From CONTOBJ
 #If [F:GAC]FLGUOM=2 & dim([M:BUD]UOM)>0
 If dim([M:BUD]UOM)>0
  [M:BUD]UOM(nolign-1) = [F:GAC]UOM
  Affzo [M:BUD]UOM(nolign-1)
 Endif
 If dim([M:BUD]CODDTP)>0
  [M:BUD]CODDTP(nolign-1) = [F:GAC]TIMDSP
  Affzo [M:BUD]CODDTP(nolign-1)
 Endif
 If dim([M:BUD]SENS)>0
  Call LEC_COA([F:GAC]COA) From CPTLEC
  Call LEC_CLS([F:COA]LEG,[F:GAC]CLSCOD) From CPTLEC
  If !fstat
   # Charge/Produit
   [M:BUD]SENS(nolign-1) = [F:CLS]SNSANA
  Endif
 Endif
Else
 Call LECTURE("GRY",VALEUR,[F:BUP]PYMACC) From CONTOBJ
 If [F:GRY]UOMDAC=2 & dim([M:BUD]UOM)>0
  [M:BUD]UOM(nolign-1) = [F:GRY]UOM
  Affzo [M:BUD]UOM(nolign-1)
 Endif
 If dim([M:BUD]CODDTP)>0
  [M:BUD]CODDTP(nolign-1) = [F:GRY]TIMDSP
  Affzo [M:BUD]CODDTP(nolign-1)
 Endif
Endif
End

Subprog AM_CODACC(VALEUR)
Variable Char     VALEUR
Local Integer     I, J, PDEB, PFIN, AFFIC
Local Char    NOMCOL(20), CLECUR2(30)(1..12), CLECUR1(10), NEWCLE2(30)(1..12)
Local Integer DIMPER
DIMPER = dim([M:BUD]NUMLIG)
Local Decimal AMTREA(1..DIMPER)      : # Montant réel
Local Decimal QTYREA(1..DIMPER)      : # Quantité réelle
Local Decimal AMTCMM(1..DIMPER)      : # Montant engagé
Local Decimal QTYCMM(1..DIMPER)      : # Quantité engagée
Local Decimal AMTPRP(1..DIMPER)      : # Montant pré-engagé
Local Decimal QTYPRP(1..DIMPER)      : # Quantité pré-engagé
Local Decimal CONVMT                 : # Permet la conversion en devise budget des montants
Local Integer L
Local Char    CODLED(GLONLED), DEVLED(GLONCUR)       : # Ledger code, currency of the ledger
Local Char    BUDDIE(GLONDIE)(9), BUDCCE(GLONCCE)(9) : # To relate dimension of the budget to dimension of the ledger

# A la saisie d'un compte, recherche des quantités et montants à afficher
If nolign>[M]NBRLIN
 AFFIC = 1 : # Pour afficher les valeurs des colonnes
 For I=0 To [M:BCR]NBCRI-1
  Call LECTURE("BUP",[M:BCR]BUD(I),"") From CONTOBJ
  CLECUR1     = [M:BCR]CPY(I)
  CLECUR2(12) = [M:BCR]FCY(I)
  CLECUR2(2)  = VALEUR
  Raz CLECUR2(3), CLECUR2(4), CLECUR2(5)
  Raz CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
  If [F:BUP]DIE(0) <> "" : CLECUR2(3) = [M:BUD]CCE1 : Endif
  If [F:BUP]DIE(1) <> "" : CLECUR2(4) = [M:BUD]CCE2 : Endif
  If [F:BUP]DIE(2) <> "" : CLECUR2(5) = [M:BUD]CCE3 : Endif
  If [F:BUP]DIE(3) <> "" : CLECUR2(6) = [M:BUD]CCE4 : Endif
  If [F:BUP]DIE(4) <> "" : CLECUR2(7) = [M:BUD]CCE5 : Endif
  If [F:BUP]DIE(5) <> "" : CLECUR2(8) = [M:BUD]CCE6 : Endif
  If [F:BUP]DIE(6) <> "" : CLECUR2(9) = [M:BUD]CCE7 : Endif
  If [F:BUP]DIE(7) <> "" : CLECUR2(10) = [M:BUD]CCE8 : Endif
  If [F:BUP]DIE(8) <> "" : CLECUR2(11) = [M:BUD]CCE9 : Endif
  Gosub READ_AMT_QTY From BUDGET2
 Next
 [M:BUD]CODACC(nolign-1) = VALEUR
 Affzo [M:BUD]20-40
Endif
End

############################## CODCCE3 pour les budgets par nature ############################

Subprog IB_CODCCE3
Local Integer IND
Local Char DIE(GLONDIE)

Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
IND = [F:BUP]DIENBR

If [F:BUP]PYMCCE(IND-1)=""
 GBOUT1 = mess(36,103,1) : # Sections analytiques
 GBIDC3 = "CCE"
 Gosub AXI From BUDGET3
 GBIDC2 = DIE
Else
 GBOUT1 = mess(25,103,1) : # Groupe section
 GBIDC3 = "CRY"
 If clalev([F:CRY])=0 : Local File GCCEGRUPYM [CRY] : Endif
 Filter [CRY] Where PYM=[F:BUP]PYMCCE(IND-1) & LEV=[F:BUP]PYMCCELEV(IND-1)
 Read [F:CRY]CRY0 First
 Filter [CRY]
 If fstat=0
  ### ???
  GBIDC2 = num$([F:CRY]LIN)
 Else
  GBIDC2 = num$(0)
 Endif
Endif
End


Subprog AS_CODCCE3(VALEUR)
Variable Char    VALEUR()
Gosub AFFICHE From BUDGET
If nolign<=[M]NBRLIN : mkstat=2 : Endif
End

Subprog C_CODCCE3(VALEUR)
Variable Char     VALEUR
Local    Char     CCEACC(max(GLONGAC,GLONCCE)) : # Valeur de la section (ou nature)
Local    Integer  OK, I, J, IND
Local    Char DIE(GLONDIE)

Call UNICITE(VALEUR,[M:BUD]CODCCE3) From OBJDIV
If mkstat : End : Endif
Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
IND = [F:BUP]DIENBR
Gosub AXI From BUDGET3

If [F:BUP]PYMCCE(IND-1)=""
 ## Existence
 Call CONTROLE("CCE","",VALEUR,DIE,mkstat) From CONTOBJ
 If mkstat : End : Endif
 ## Code d'accès
 Call CONTEXE([F:CCE]ACS) From CPTSUB
 If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
 ## Section non budgétisable
 If [F:CCE]BUDTRK = 1 : GMESSAGE = mess(5,103,1) : mkstat=2 : End : Endif
  ## Société / site
  Call BUDSITE([F:CCE]FCY,[F:BUP]LEV,[M:BCR]FCY(I),[M:BCR]CPY(I),[F:CCE]CCE) From CFYSUB
  If mkstat : OK = 0 : End : Endif
  ## Dates de validité
  If [F:CCE]VLYEND<>[0/0/0] & [F:CCE]VLYEND<[M:BCR]DATDEB(I)
&  | [F:CCE]VLYSTR<>[0/0/0] & [F:CCE]VLYSTR>[M:BCR]DATFIN(I)
   mkstat = 2 : OK = 0 : GMESSAGE = mess(280,108,1) : End
  Endif
 ## Autorisations compte
 CCEACC = VALEUR
 Gosub AUTCCEACC From BUDGET3
 If !OK : mkstat = 2 : End : Endif
 ## Autorisations sections
 CCEACC = VALEUR
 Gosub AUTSECSEC From BUDGET3
 If !OK : mkstat = 2 : End : Endif
Else
 Call CONTROLE("CRY","",[F:BUP]PYMCCE(IND-1),VALEUR,mkstat) From CONTOBJ
 If [F:CRY]LEV<>[F:BUP]PYMCCELEV(IND-1)
  # Groupe de section incorrect
  GMESSAGE = mess(32,103,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AM_CODCCE3(VALEUR)
Variable Char      VALEUR
Local    Integer INDDIE
Local    Integer   I, J, PDEB, PFIN, AFFIC
Local    Char      NOMCOL(20), CLECUR2(30)(1..12), CLECUR1(10), NEWCLE2(30)(1..12)
Local    Integer   DIMPER
DIMPER = dim([M:BUD]NUMLIG)

Local Integer L
Local Char    CODLED(GLONLED), DEVLED(GLONCUR)       : # Ledger code, currency of the ledger
Local Char    BUDDIE(GLONDIE)(9), BUDCCE(GLONCCE)(9) : # To relate dimension of the budget to dimension of the ledger

Local    Decimal   AMTREA(1..DIMPER)    : # Montant réel
Local    Decimal   QTYREA(1..DIMPER)    : # Quantité réelle
Local    Decimal   AMTCMM(1..DIMPER)    : # Montant engagé
Local    Decimal   QTYCMM(1..DIMPER)    : # Quantité engagée
Local    Decimal   AMTPRP(1..DIMPER)    : # Montant pré-engagé
Local    Decimal   QTYPRP(1..DIMPER)    : # Quantité pré-engagé
Local    Decimal   CONVMT               : # Permet la conversion en devise budget des montants

# A la saisie d'une section, recherche des quantités et montants à afficher
If nolign>[M]NBRLIN
 AFFIC = 1 : # Pour afficher les valeurs des colonnes
 For I=0 To [M:BCR]NBCRI-1
  Call LECTURE("BUP",[M:BCR]BUD(I),"") From CONTOBJ
  CLECUR1 = [M:BCR]CPY(I)
  CLECUR2(6) = [M:BCR]FCY(I)
  CLECUR2(2) = [M:BUD]ACC
  Raz CLECUR2(3), CLECUR2(4), CLECUR2(5)
  Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
  INDDIE = [F:BUP]DIENBR
  If INDDIE>=1 : CLECUR2(INDDIE+2) = VALEUR : Endif : # Dimension displayed in column = last dimension
  If INDDIE>=2 : CLECUR2(3) = [M:BUD]CCE1 : Endif
  If INDDIE>=3 : CLECUR2(4) = [M:BUD]CCE2 : Endif
  If INDDIE>=4 : CLECUR2(5) = [M:BUD]CCE3 : Endif
  If INDDIE>=5 : CLECUR2(6) = [M:BUD]CCE4 : Endif
  If INDDIE>=6 : CLECUR2(7) = [M:BUD]CCE5 : Endif
  If INDDIE>=7 : CLECUR2(8) = [M:BUD]CCE6 : Endif
  If INDDIE>=8 : CLECUR2(9) = [M:BUD]CCE7 : Endif
  If INDDIE>=9 : CLECUR2(10) = [M:BUD]CCE8 : Endif
  Gosub READ_AMT_QTY From BUDGET2
 Next
 [M:BUD]CODCCE3(nolign-1) = VALEUR
 Affzo [M:BUD]20-40
Endif
End

