$AS_CCE
Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
If [M:BCR]BUDCAT=1 or [M:BCR]BUDCAT=3  : # Budget par période ou budget par section
 If [F:BUP]DIENBR<IND : mkstat=1 : End : Endif
Else                                   : # Budget par compte
 If [F:BUP]DIENBR<=IND : mkstat=1 : End : Endif
Endif
Return

