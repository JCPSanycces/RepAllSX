Subprog AMTFOR(AMTFOR,NOCOL)
Variable Decimal AMTFOR
Value    Integer NOCOL
Read [TBU]TBU0=[M:BCR]BUDTYP;NOCOL
Onerrgo RIEN
AMTFOR = evalue([F:TBU]COLEXP2)
Onerrgo
End

$RIEN
Resume
Return

$BUPAXE
Local Integer NAX
Local Char    AXETR(GLONDIE)
NAX=0 : AXETR =""
Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
If [F:BUP]DIE(0) <> "" : AXETR = [F:BUP]DIE(0) : NAX=1 : Endif
If [F:BUP]DIE(1) <> "" : AXETR = [F:BUP]DIE(1) : NAX=2 : Endif
If [F:BUP]DIE(2) <> "" : AXETR = [F:BUP]DIE(2) : NAX=3 : Endif
If [F:BUP]DIE(3) <> "" : AXETR = [F:BUP]DIE(3) : NAX=4 : Endif
If [F:BUP]DIE(4) <> "" : AXETR = [F:BUP]DIE(4) : NAX=5 : Endif
If [F:BUP]DIE(5) <> "" : AXETR = [F:BUP]DIE(5) : NAX=6 : Endif
If [F:BUP]DIE(6) <> "" : AXETR = [F:BUP]DIE(6) : NAX=7 : Endif
If [F:BUP]DIE(7) <> "" : AXETR = [F:BUP]DIE(7) : NAX=8 : Endif
If [F:BUP]DIE(8) <> "" : AXETR = [F:BUP]DIE(8) : NAX=9 : Endif
Return

