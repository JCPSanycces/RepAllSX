#<AdxTL>@(#)1.0.0.0 $Revision$
#*********************************************************************
#
#                FIN DE CONCESSION
#
#*********************************************************************
#    Création
#    MWA - 15.09.2009 (V5)
#
#*********************************************************************
#    Modification
#    MWA - 16.05.2018  X3-89794 Wrong definition of the site length
#    MWA - 12.04.2013  FQ88613  Forcer le recalcul des amortissements
#    CBO - 12.03.2012  FQ80246  GFMDAT4 au lieu de DD[/]MM[/]YYYY
#    MWA ../../.. (FQ....) : ........................................
#    GBO 15/02/10 (FQ62307) : Ajout "Fin normale sur trace"
#
#*********************************************************************
#

Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Local Char VALBOUT(30)
Local Char PARBOUT(250)(1..10)
VALBOUT = "12"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","TRTCCNEND","CCNEND",3,"") From GTRAITE
End

#=================================================================================
$ACTION

 #  Infbox 'ACTION='-num$(ACTION)

Case ACTION

  When "INIT"        : Gosub INIT
  When "INIT_DIA"    : Gosub INIT_DIA
  When "AVANT_PAR"   : Gosub AVANT_PAR
  When "OUVRE_BATCH" : Gosub OUVRE_BATCH
  When "DEBUT"       : Gosub DEBUT
  When "CONT_BATCH"  : Gosub CONTROLE
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "END"         : ABANDON= G_OUI
  When "SORTIE"      : Gosub SORTIE
  When "TERMINE"     : Gosub TERMINE

  When "APRES_MODIF" : Gosub APRES_MODIF
  When "SETBOUT"     : Gosub SETBOUT

  When "OK"          : Gosub OK

Endcase

Return

#=============================
$INIT
 If dim(ABANDON)<0 : Global Integer   ABANDON : Endif

 If !clalev([F:CCN])   : Local File CONCESSION  [CCN]  : Endif
 If !clalev([F:FAS])   : Local File FXDASSETS   [FAS]  : Endif
 If !clalev([F:DEP])   : Local File DEPREC      [DEP]  : Endif
 If !clalev([F:CNX])   : Local File CONTEXT     [CNX]  : Endif
 If !clalev([F:ACM])   : Local File APLCOM      [ACM]  : Endif

 If !clalev([M:DIA])   : Local Mask CCNEND  [DIA]      : Endif
 If !clalev([M:DIA2])  : Local Mask CCNEND  [DIA2]     : Endif
 Raz [M:DIA]
 Raz [M:DIA2]
 # Valeurs par défaut
 [M:DIA2]FLGCNL=G_NON
 [M:DIA2]FLGSIM=G_OUI
 [M:DIA2]FLGCAL=G_NON

 Global Integer G_ACTION
 Global Integer G_ONEBYONE  : G_ONEBYONE = 0
 Global Char    G_REFIMMO(GLONAAS)
 Global Integer GACTSILENCE
 Global Char    GTRTFILMSK
 # Récupération des paramètres de l'action
 Gosub GET_PARAMETRES From TRTCCNEND

Return

#=============================
$INIT_DIA
 If dim(ABANDON)<0 : Global Integer   ABANDON : Endif

 If !clalev([F:CCN])   : Local File CONCESSION  [CCN]  : Endif
 If !clalev([F:FAS])   : Local File FXDASSETS   [FAS]  : Endif
 If !clalev([F:DEP])   : Local File DEPREC      [DEP]  : Endif
 If !clalev([F:CNX])   : Local File CONTEXT     [CNX]  : Endif

 If !clalev([M:DIA])   : Local Mask CCNEND  [DIA]      : Endif
 If !clalev([M:DIA2])  : Local Mask CCNEND  [DIA2]     : Endif
 Raz [M:DIA]
 Raz [M:DIA2]
 # Valeurs par défaut
 [M:DIA2]FLGCNL=G_NON
 [M:DIA2]FLGSIM=G_OUI
 [M:DIA2]FLGCAL=G_NON

 Global Integer G_ACTION
 Global Integer G_ONEBYONE  : G_ONEBYONE = 0
 Global Char    G_REFIMMO(GLONAAS)
 Global Integer GACTSILENCE
 Global Char    GTRTFILMSK
 # Récupération des paramètres de l'action
 Gosub GET_PARAMETRES From TRTCCNEND

Return

#=============================
$AVANT_PAR
 If dim(ABANDON)<0 : Global Integer   ABANDON : Endif

 If ( GACTSILENCE = G_OUI and GTRTFILMSK <> "" ) Then
  # Pas d'affiage du masque en silencieux
  TYPPRG=0
  # Chargement du masque
  Gosub ALIM_MASK From =GTRTFILMSK
 Endif

Return

#=============================
$OUVRE_BATCH
 If dim(ABANDON)<0 : Global Integer   ABANDON : Endif
Return

#=============================
$DEBUT
 If !GBATCH
   # Restauration avant affichage fenêtre
   Transmask [M:DIA2] To [M:DIA]
   # Conditionnement
   If ( [M:DIA]FLGCAL=G_NON ) Then : Grizo [M:DIA]FLGCAL : Affzo [M:DIA]FLGCAL : Endif
   Affzo [M:DIA]
 Endif
Return

#=============================
$OK
 # Sauveagarde écran suite à OK
 If !GBATCH  :  Transmask [M:DIA] To [M:DIA2] :  Endif
Return

#=============================
$CONTROLE

#
#                   GSERVEUR  GBATCH
# Interactif           0        0
# Saisie param.        0        1
# Lancement trt        1        0

  #-------------
  If ABANDON = G_OUI : Return : Endif

  # Exécution silencieuse : Création des variables globales pour intercepter les erreurs suite à contrôle
  #                         Dimensionnement à 1 une seule erreur possible
  If ( GACTSILENCE = G_OUI ) Then
    If dim(G_MAJOK)>0      : Kill G_MAJOK    : Endif
    Global Integer G_MAJOK : G_MAJOK=G_OUI

    # Contrat de contession sur lequel porte l'avenant
    If dim(GT_OBJ_REF)>0      : Kill GT_OBJ_REF : Endif
    Global Char  GT_OBJ_REF(20)(1) : GT_OBJ_REF (0) = [M:DIA]CCNREF
    If dim(GT_OBJ_DES)>0 :      Kill GT_OBJ_DES : Endif
    Global Char  GT_OBJ_DES(20)(1) : GT_OBJ_DES (0) = [M:DIA]CCNDES1
    # Liste erreur ( un seul poste)
    Global Char  GT_LIS_ERR(100)(1)
  Endif

  #-1 ------------
  If (GSERVEUR or GACTSILENCE = G_OUI) Then
    If !clalev([F:CCN]) : Local File CONCESSION [CCN] : Endif
    Read [F:CCN]CCN0=[M:DIA]CCNREF
    #-2 ------------
    If (!fstat) Then
      #-3 ------------
      If ( [F:CCN]CCNSTA = GVML_CSACTI ) Then
        #==
        If ( func GLOCCN.IS_RNWOP_NOT_DONE_FOR_CCN([M:DIA]CCNREF) = G_OUI ) Then
          # Fin de concession impossible : Au moins un bien de la concession est référencé dans une préparation de renouvellement
          If (GACTSILENCE = G_OUI) Then
            ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(731,7773,1)
          Else
            GERR= 1 : GMESSAGE = mess(731,7773,1)
          Endif
          Return
        Endif
        #==
        #If ( func GLOCCN.IS_CCNFAS_TO_RNW([M:DIA]CCNREF) = G_OUI ) Then
        #  # Fin de concession impossible : Au moins un bien de la concession reste à renouveler.
        #  If (GACTSILENCE = G_OUI) Then
        #    ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(732,7773,1)
        #  Else
        #    GERR= 1 : GMESSAGE = mess(nnn,7773,1)
        #  Endif
        #  Return
        #Endif
        #==
        If ( func GLOCCN.IS_CCNFAS_NOT_RNW([M:DIA]CCNREF) = G_OUI ) Then
          # Au moins un bien de la concession de Type Apport "Renouvellement" n'a pas été effectivement renouvelé.
          If (GACTSILENCE = G_OUI) Then
            ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(733,7773,1)
          Else
            GERR= 1 : GMESSAGE = mess(733,7773,1)
          Endif
          Return
        Endif
      #-3 ------------
      Elsif ( [F:CCN]CCNSTA = GVML_CSTERM ) Then
        If ( [F:CCN]REAENDCCN < GDEBEXECPF ) Then
          # Annulation de la fin de concession impossible : Elle est antérieure au début de l'exercice courant.
          If (GACTSILENCE = G_OUI) Then
            ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(734,7773,1)
          Else
            GERR= 1 : GMESSAGE = mess(734,7773,1)
          Endif
          Return
        Endif
        # Annulation de la fin de concession impossible en mode silencieux.
        If (GACTSILENCE = G_OUI) Then
          ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(736,7773,1)
        Endif
      #-3 ------------
      Else
        # Référence concession invalide
        If (GACTSILENCE = G_OUI) Then
            ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(271,7773,1)
        Else
          GERR= 1 : GMESSAGE = mess(271,7773,1)
        Endif
        Return
      Endif
      #-3 ------------
    #-2 ------------
    Else
      # Référence concession invalide
      If (GACTSILENCE = G_OUI) Then
          ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(271,7773,1)
      Else
        GERR= 1 : GMESSAGE = mess(271,7773,1)
      Endif
      Return
    Endif
    #-2 ------------
  Endif
  #-1 ------------

  # Récupération date exercice courant et suivant du contexte fiscale & comptable
  Local Date    RDATEC(1..5)
  Local Date    RDATES(1..5)
  Local Integer RRET
  Call GET_CNX_DAT_CS([M:DIA]CPY, G300CPFI, RDATEC, RDATES, RRET) From GLOBIENS
  If ( [M:DIA]FLGCNL <> G_OUI and [M:DIA]ENDCCNDAT > RDATES(2)) Then
    # La date de fin de la concession doit être <= à la date de fin de l'exercice suivant
    If (GACTSILENCE = G_OUI) Then
      ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(742,7773,1)
    Else
      If (!GSERVEUR and GACTSILENCE <> G_OUI) Then : SAI = 1 : Endif
      GERR= 1 : GMESSAGE = mess(742,7773,1)
    Endif
    Return
  Endif

  If ( RDATEC(1) > [M:DIA]ENDCCNDAT ) Then
    # La date de fin de la concession doit être > à la date de début de l'exercice courant
    If (GACTSILENCE = G_OUI) Then
      ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(735,7773,1)
    Else
      If (!GSERVEUR and GACTSILENCE <> G_OUI) Then : SAI = 1 : Endif
      GERR= 1 : GMESSAGE = mess(735,7773,1)
    Endif
    Return
  Endif

  If ( func TRTCCNEND.IS_FAS_OUTSIDE_CCN ([M:DIA]CCNREF, [M:DIA]ENDCCNDAT) = G_OUI ) Then
    # Opération interdite : Au moins un bien en concession en dehors des nouvelles limites de la concession
    If (GACTSILENCE = G_OUI) Then
      ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(746,7773,1)
    Else
      GERR= 1 : GMESSAGE = mess(746,7773,1)
    Endif
    Return
  Endif

  If ( func TRTCCNEND.IS_ISSDAT_OUTSIDE_CCN ([M:DIA]CCNREF, [M:DIA]ENDCCNDAT) = G_OUI ) Then
    # Opération interdite : Au moins un bien en concession ayant une date de sortie au delà des nouvelles limites de la concession
    If (GACTSILENCE = G_OUI) Then
      ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(748,7773,1)
    Else
      GERR= 1 : GMESSAGE = mess(748,7773,1)
    Endif
    Return
  Endif

  If ( GACTSILENCE = G_OUI ) Then
    # Contrôle de l'interactif à effectuer en mode silencieux
    If ( [M:DIA]ENDCCNDAT <= [M:DIA]STRCCNDAT) Then
      # La date de fin doit être > à la date de début de la concession
      ABANDON = G_OUI : G_MAJOK = G_NON : GT_LIS_ERR(0) = mess(253,7773,1)
      Return
    Endif
  Endif

Return
#=============================
$EXEC

  Local Integer LNBTOT
  Local Integer LNBTRT


  If ABANDON = G_OUI : Return : Endif

  If dim(G_REAENDCCN)>0   : Kill G_REAENDCCN : Endif  : Global Date G_REAENDCCN


  # Chargement de l'environnement global de la société
  If !clalev([M:FPC]) : Local Mask FASPARCPY [FPC] : Endif
  GSOCIETE=[M:DIA]CPY
  Call CHARGE_ENVIRONNEMENT () From GLOFCYCPY

  # Ouverture de la trace
  If (GACTSILENCE <> G_OUI ) Then
    If !GSERVEUR : Call OUVRE_TRACE (mess(738,7773,1)) From LECFIC : Endif :   # "FIN DE CONCESSION"
  Endif

  If ( GACTSILENCE = G_OUI ) Then
    # Auto correction pour traitement silencieux
    # En silence : Pas de trace détaillée pas de calcul
    [M:DIA]FLGDET    = G_NON
    [M:DIA]FLGCAL    = G_NON
  Endif

  # Evaluation G_ONEBYONE
  If ( [M:DIA]FLGDET = G_OUI ) Then : G_ONEBYONE = 1 : Else : G_ONEBYONE = 0 :  Endif


  Gosub ECR_PARM From TRTCCNEND

  # Exécution silencieuse : Création des variables globales : pour intercepter les erreurs dans le traitement.
  If ( GACTSILENCE = G_OUI ) Then
    If dim(G_MAJOK)>0      : Kill G_MAJOK    : Endif
    Global Integer G_MAJOK : G_MAJOK=G_OUI
    # Contrat de contession sur lequel porte l'avenant
    If dim(GT_OBJ_REF)>0 : Kill GT_OBJ_REF : Endif
    If dim(GT_OBJ_DES)>0 : Kill GT_OBJ_DES : Endif
    Global Char    GT_OBJ_REF(20)(1) : GT_OBJ_REF (0) = [M:DIA]CCNREF
    Global Char    GT_OBJ_DES(20)(1) : GT_OBJ_DES (0) = [M:DIA]CCNDES1
  Endif

  # Verrouillage Contrat
  If ( func GLOBIENS.LOCK_SYMBOLE ("CCN", [M:DIA]CPY, [M:DIA]CCNREF, 0) = 0 ) Then
      # "Le contrat de concession n'a pas pu être verrouillé"
    If (GACTSILENCE <> G_OUI) Then
      Call ECR_TRACE(mess(790,7773,1),1) From GESECRAN
      If !GSERVEUR : Call LEC_TRACE() From LECFIC : Endif
      Return
    Else
      ABANDON = G_OUI
      If dim(I_OBJ)>0        : Kill I_OBJ      : Endif
      Global Integer I_OBJ   : I_OBJ=0
      Global Char    GT_LIS_ERR(100)(1)
      GT_LIS_ERR(I_OBJ) = mess(790,7773,1)
      G_MAJOK    = G_NON
      Return
    Endif
  Endif
  # Verrouillage Biens
  Local Integer LERR
  Call CCN_LOCK_FAS ([M:DIA]CCNREF, "", LERR) From GLOCCN
  If (LERR) Then
    # Déverrouillage Contrat
    Call UNLOCK_SYMBOLE ("CCN", [M:DIA]CPY, [M:DIA]CCNREF) From GLOBIENS
    # "Les biens n'ont pas pu être verrouillés"
    If (GACTSILENCE <> G_OUI) Then
      Call ECR_TRACE(mess(728,7773,1),1) From GESECRAN
      If !GSERVEUR : Call LEC_TRACE() From LECFIC : Endif
      Return
    Else
      ABANDON = G_OUI
      If dim(I_OBJ)>0        : Kill I_OBJ      : Endif
      Global Integer I_OBJ   : I_OBJ=0
      Global Char    GT_LIS_ERR(100)(1)
      GT_LIS_ERR(I_OBJ) = mess(728,7773,1)
      G_MAJOK    = G_NON
      Return
    Endif
  Endif

  #========================
  # Incrément du compteur
  # d'action métier :
  # sauf si mode silencieux
  # Incrément à faire par le
  # traitement appelant
  #========================
  If GACTSILENCE<>G_OUI
   Trbegin [ACM]
   [C]TRTACTMET+=1
   Commit
  Endif

  #========================
  # Début Commitment control
  #========================
  If ( [M:DIA]FLGSIM <> G_OUI ) Then
    # Traitement en réel
    Local Integer BCMTEXT
    If ( GACTSILENCE = G_OUI ) Then
      # Traitement silencieux
      BCMTEXT = adxlog
    Else
      BCMTEXT = 0
    Endif
    If ( !BCMTEXT) Then
      GTRANS = 1 : # Pour signaler que c'est ce traitement qui gère le commitment et non pas la transaction objet métier
      GOK    = 1
      Trbegin [CCN], [FAS]
    Else
      # Si un commitment control a été initialisé on considère que c'est l'appelant qui le gère
    Endif
  Endif

  #=====================================
  # Mise à jour des biens de la concession
  #=====================================

  Gosub ECR_ENTETE From TRTCCNEND

  Local Char LREQUETE(50) : Raz LREQUETE : Raz GBIDI1
  If ( [M:DIA]FLGCNL = G_OUI ) Then
    # Requete : Prise en compte uniquement des biens dont le type de sortie est "Remis au concédant"
    LREQUETE = "ISSTYP= GVML_TSFCONC"
  Else
    # Requete : Prise en compte uniquement des biens qui ne sont pas encore sortis.
    LREQUETE = "ISSDAT= [0/0/0]"
  Endif

  # Nombre de biens  à traiter
  Filter [FAS] Where CCNREF= [M:DIA]CCNREF and evalue(LREQUETE)
  LNBTOT = rowcount([FAS])
  Filter [FAS]

  # Exécution silencieuse : Création des variables globales
  #                         Dimensionnement selon le nombre de biens concernés
  If ( GACTSILENCE = G_OUI ) Then
    If ( !G_ONEBYONE ) Then : LNBTOT = 1 : Endif
    # Dimensionnement de GT_LIS_ERR
    If ( LNBTOT > 0 ) Then
      If dim(I_OBJ)>0      : Kill I_OBJ      : Endif
      Global Integer I_OBJ   : I_OBJ=0
      If dim(GT_LIS_ERR)>0  : Kill GT_LIS_ERR  : Endif
      Global Char    GT_LIS_ERR(100)(LNBTOT + 10)
    Endif
  Endif

  #> Exécution interactive : jauge - barre de progression
  If ( G_ONEBYONE and !GSERVEUR and GACTSILENCE <> G_OUI ) Then
    Call OUVRE_BOITE(mess(738,7773,1),LNBTOT) From GESECRAN
    Call SET_BOITE(mess(738,7773,1),LNBTOT) From GESECRAN
  Endif

  #>>>>>>>>>>>>>>>>>>>>>>>>>>
  For [FAS] Where CCNREF= [M:DIA]CCNREF and evalue(LREQUETE)

    NB_LUS +=1

    #> Exécution interactive : jauge - barre de progression
    If (  G_ONEBYONE and !GSERVEUR and GACTSILENCE <> G_OUI ) Then
      LNBTRT+=1
      Call AFF_BOITE([F:FAS]AASREF-+"("+num$(LNBTRT)+"/"+num$(LNBTOT)+")",LNBTRT,GOK) From GESECRAN
    Endif

    #-1 ---------------
    If ( [M:DIA]FLGSIM <> G_OUI ) Then
      # ( sortie unitaire) Mise au rebut : Remis au concédant
      If (G_ONEBYONE) Then

        # Référence du bien à sortir
        G_REFIMMO = [F:FAS]AASREF

        Local Integer RETOUR
        Call LAUNCH_SILTRT("FASISS","TRTCCNEND",RETOUR) From TRCPROCOM
        If (RETOUR) Then
          NB_ERR +=1
          GOK = 0
          If ( GACTSILENCE <> G_OUI ) Then
            Call ECR_TRACE(mess(776,7773,1)-[F:FAS]AASREF,1) From GESECRAN
            Break 1
          Else
            ABANDON    = G_OUI
            G_MAJOK    = G_NON
            GT_LIS_ERR(I_OBJ) = mess(776,7773,1)-[M:FAS]AASREF
            I_OBJ += 1
            Break 1
          Endif
        Endif
      Endif
      NB_MAJ +=1
    Endif
    #-1 ---------------
    # Ecriture trace
    Gosub ECR_LIGNE From TRTCCNEND
  Next
  #<<<<<<<<<<<<<<<<<<<<<<<<

  #> Exécution interactive : jauge - barre de progression
  If ( G_ONEBYONE and !GSERVEUR and GACTSILENCE <> G_OUI ) Then
    Call FERME_BOITE From GESECRAN
  Endif


  # ( sortie globale ) Mise au rebut : Remis au concédant
  If not (G_ONEBYONE) Then
    Call TEMPON(mess(774,7773,1)) From GESECRAN
    Local Integer RETOUR
    Call LAUNCH_SILTRT("FASISS","TRTCCNEND",RETOUR) From TRCPROCOM
    Call TEMPOFF() From GESECRAN
    If (RETOUR) Then
      NB_ERR +=1
      GOK = 0
      If ( GACTSILENCE <> G_OUI ) Then
        Call ECR_TRACE(mess(775,7773,1),1) From GESECRAN
      Else
        ABANDON    = G_OUI
        G_MAJOK    = G_NON
        GT_LIS_ERR(I_OBJ) = mess(775,7773,1)
        I_OBJ += 1
      Endif
    Endif
  Endif


  #=====================================
  # Mise à jour du contrat de concession
  #=====================================
  #-1 -----------------
  If (GOK) Then
    Read [F:CCN]CCN0=[M:DIA]CCNREF
    #-2 -----------------
    If (fstat) Then
      GOK = 0
      If ( GACTSILENCE <> G_OUI ) Then
        Call ECR_TRACE(mess(728,7773,1)-" CONCESSION " - num$([M:DIA]CCNREF),1) From GESECRAN
      Else
        ABANDON  = G_OUI
        G_MAJOK  = G_NON
        GT_LIS_ERR(I_OBJ) = mess(728,7773,1)-" CONCESSION " - num$([M:DIA]CCNREF)
        I_OBJ += 1
      Endif
    #-2 -----------------
    Else
      If ( [M:DIA]FLGSIM <> G_OUI ) Then
        If ( [M:DIA]FLGCNL = G_OUI ) Then
          G_REAENDCCN       = [F:CCN]REAENDCCN
          [F:CCN]REAENDCCN  = [0/0/0]
          [F:CCN]CCNSTA     = GVML_CSACTI
        Else
          G_REAENDCCN       = [M:DIA]ENDCCNDAT
          [F:CCN]REAENDCCN  = [M:DIA]ENDCCNDAT
          [F:CCN]CCNSTA     = GVML_CSTERM
          [F:CCN]DFTCCNFLG  = G_NON
        Endif
        Rewrite [CCN]
        If (fstat) Then
          GOK = 0
          If ( GACTSILENCE <> G_OUI ) Then
            Call ECR_TRACE(mess(728,7773,1)-" CONCESSION " - num$([M:DIA]CCNREF),1) From GESECRAN
          Else
            ABANDON    = G_OUI
            G_MAJOK    = G_NON
            GT_LIS_ERR(I_OBJ) = mess(728,7773,1)-" CONCESSION " - num$([M:DIA]CCNREF)
            I_OBJ += 1
          Endif
        Endif
      Endif
    Endif
    #-2 -----------------
  Endif
  #-1 -----------------

  #=====================================
  # Génération d'un événement CCNEND
  #=====================================
  Local Char    LCDINT :  LCDINT= "CCNEND"
  Local Integer LCDRET

  If (GOK) Then
    If ( [M:DIA]FLGSIM <> G_OUI ) Then
      If ( [M:DIA]FLGCNL = G_OUI ) Then
        If !clalev([F:EVT0]) : Local File ECCNEND [EVT0] : Endif
        If !clalev([F:EVT1]) : Local File ECCNEND [EVT1] : Endif
        # Extourne
        Filter [F:EVT0] Where CPY=[M:DIA]CPY and REF=[M:DIA]CCNREF and REAENDCCN=G_REAENDCCN and SNSEVE<>GVML_TEAACT
        Read [F:EVT0]EVE0 Last
        If !fstat
          If func GENEVE.EXISTE_EXTOURNE_EVE(LCDRET)=G_NON
            Call EXTOURNE_EVE(GVML_OMCCN,[M:DIA]CPY,[M:DIA]FCY,[M:DIA]CCNREF, 0,LCDINT, G_REAENDCCN, LCDRET) From GENEVE
          Endif
        Endif
        Filter [F:EVT0]
      Else
        #-----
        Call GENER_EVE ( GVML_OMCCN, [M:DIA]CPY, [M:DIA]FCY, [M:DIA]CCNREF, 0, LCDINT, G_REAENDCCN, [0/0/0], LCDRET ) From GENEVE
        If (LCDRET > 20) Then
          GOK = 0
          If ( GACTSILENCE <> G_OUI ) Then
            Call ECR_TRACE(mess(104,7773,1)-" ECCNEND "  - num$([M:DIA]CCNREF),1) From GESECRAN
          Else
            ABANDON = G_OUI
            G_MAJOK    = G_NON
            GT_LIS_ERR(I_OBJ) = mess(104,7773,1)-" ECCNEND "  - num$([M:DIA]CCNREF)
            I_OBJ += 1
          Endif
        Endif
      Endif
    Endif
  Endif

  #========================
  # Fin Commitment control
  #========================
  If ( [M:DIA]FLGSIM <> G_OUI and !BCMTEXT ) Then
    # Si traitement en réel et commitment control à gérer
    If (GOK) Then
      Commit
    Else
      Rollback
    Endif
  Endif

  # Déverrouillage Contrat
  Call UNLOCK_SYMBOLE ("CCN", [M:DIA]CPY, [M:DIA]CCNREF) From GLOBIENS
  # Déverrouillage Biens
  Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS

  # Ecriture statistiques
  Gosub ECR_STAT From TRTCCNEND

  #=====================================
  # Calcul des biens de la société
  #=====================================
  If ( GOK = 1 and [M:DIA]FLGSIM <> G_OUI and [M:DIA]FLGCAL = G_OUI and GACTSILENCE <> G_OUI ) Then
    # Si traitement en réel et pas en mode silencieux
    Local Integer TBCNX(1..GMAXCNXC)
    # Local Char    TBFCY(GLONCPY)(1..func AFNC.ACTIV("SIT")) : # X3-89794
    Local Char    TBFCY(GLONFCY)(1..func AFNC.ACTIV("SIT"))
    Local Decimal RERROR
    # Site à calculer
    TBFCY(1) = [M:DIA]FCY
    # Contextes à calculer
    Local Integer I_CNX : I_CNX = 0
    For [CNX]CNX0 Where CPY=[M:DIA]CPY
      I_CNX+=1
      TBCNX(I_CNX) = [F:CNX]CNX
    Next CNX0

    # Calcul FQ88613
    Global Integer G_CLCTRC : G_CLCTRC = 1   # 0 : pas de trace/1 : trace
    Gosub AVANT_CALCULER_SOCIETE From GLOBB0
    Call  CALCULER_SOCIETE([M:DIA]CPY, TBFCY, TBCNX, G_NON, RERROR) From GLOBB
    Gosub APRES_CALCULER_SOCIETE  From GLOBB0
  Endif

  # Fermeture de la trace
  #If !GSERVEUR and GACTSILENCE <> G_OUI : Call LEC_TRACE() From LECFIC : Endif #fq62307
  If !GSERVEUR and GACTSILENCE <> G_OUI : Call FERME_TRACE From LECFIC : TRA=1 : Endif



Return

#=============================
$TERMINE
  If dim(ABANDON)>0    : Kill ABANDON    : Endif
Return

#=============================
$SORTIE
  If dim(G_ONEBYONE)>0      : Kill G_ONEBYONE     : Endif
  If dim(G_REFIMMO)>0       : Kill G_REFIMMO      : Endif
  If dim(GACTSILENCE)>0     : Kill GACTSILENCE     : Endif
  If dim(GTRTFILMSK)>0      : Kill GTRTFILMSK      : Endif
Return


#=============================
$APRES_MODIF
Return

#=============================
$SETBOUT
  If ( [M:DIA]CCNREF = "" or [M:DIA]ENDCCNDAT = [0/0/0] ) Then
    Call VIREBOUT (CHBOU,"O") From GOBJET
  Endif

Return




######################################################################################
#    ECRAN   : CCNEND   [M:DIA]
######################################################################################

#=============================
Subprog AM_FLGSIM(VALEUR)
Variable Integer VALEUR

 If ( VALEUR = G_OUI ) Then
   # Par défaut traitement simulé => pas de calcul
   [M:DIA]FLGCAL = G_NON
   Affzo [M:DIA]FLGCAL
   Diszo [M:DIA]FLGCAL
 Else
   Actzo [M:DIA]FLGCAL
 Endif

End


#=============================
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
 If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
 Read [F:FCY]FCY0=VALEUR
 If (!fstat) Then
   [M:DIA]CPY = [F:FCY]LEGCPY
 Else
   [M:DIA]CPY = ""
 Endif
 [M:DIA]FLGCNL     = G_NON
 [M:DIA]CCNREF     = ""
 [M:DIA]CCNDES1    = ""
 [M:DIA]CCNDES2    = ""
 [M:DIA]STRCCNDAT  = [0/0/0]
 [M:DIA]ENDCCNDAT  = [0/0/0]
 [M:DIA]ENDCCNDATO = [0/0/0]
 Affzo [M:DIA]FLGCNL
 Affzo [M:DIA]CPY
 Affzo [M:DIA]ZCPY
 Affzo [M:DIA]CCNREF
 Affzo [M:DIA]CCNDES1
 Affzo [M:DIA]CCNDES2
 Affzo [M:DIA]STRCCNDAT
 Affzo [M:DIA]ENDCCNDAT

End


#=============================
Subprog AM_CCNUSR(VALEUR)
Variable Char    VALEUR()
 [M:DIA]FLGCNL     = G_NON
 [M:DIA]CCNREF     = ""
 [M:DIA]CCNDES1    = ""
 [M:DIA]CCNDES2    = ""
 [M:DIA]STRCCNDAT  = [0/0/0]
 [M:DIA]ENDCCNDAT  = [0/0/0]
 [M:DIA]ENDCCNDATO = [0/0/0]
 Affzo [M:DIA]FLGCNL
 Affzo [M:DIA]CCNREF
 Affzo [M:DIA]CCNDES1
 Affzo [M:DIA]CCNDES2
 Affzo [M:DIA]STRCCNDAT
 Affzo [M:DIA]ENDCCNDAT
End

#=============================
Subprog AM_CCNREF(VALEUR)
Variable Char    VALEUR()

 If !clalev([F:CCN]) : Local File CONCESSION [CCN] : Endif
 Read [F:CCN]CCN0=VALEUR
 If (!fstat) Then
   If ([F:CCN]CCNSTA = GVML_CSACTI ) Then
     #==
     If ( func GLOCCN.IS_RNWOP_NOT_DONE_FOR_CCN(VALEUR) = G_OUI ) Then
       # Fin de concession impossible : Au moins un bien de la concession est référencé dans une préparation de renouvellement
       GERR= 1: GMESSAGE = mess(731,7773,1)
       mkstat = 2 : End
     Endif
     #==
     # If ( func GLOCCN.IS_CCNFAS_TO_RNW(VALEUR) = G_OUI ) Then
     #   # Fin de concession impossible : Au moins un bien de la concession reste à renouveler.
     #   GERR= 1: GMESSAGE = mess(nnn,7773,1)
     #   mkstat = 2 : End
     # Endif
     #==
     If ( func GLOCCN.IS_CCNFAS_NOT_RNW(VALEUR) = G_OUI ) Then
       # Au moins un bien de la concession de Type Apport "Renouvellement" n'a pas été effectivement renouvelé. Confirmez-vous ?
       Local Integer LOK
       Call OUINON(mess(733,7773,1)-mess(277,7773,1), LOK) From GESECRAN
       If ( LOK = 1) Then : mkstat = 2 : End : Endif
     Endif
   Elsif ([F:CCN]CCNSTA = GVML_CSTERM ) Then
     If ( [F:CCN]REAENDCCN < GDEBEXECPF ) Then
       # Annulation de la fin de concession impossible : Elle est antérieure au début de l'exercice courant.
       GERR= 1: GMESSAGE = mess(734,7773,1)
       mkstat = 2 : End
     Endif
   Else
     # Référence concession invalide
     GERR= 1: GMESSAGE = mess(271,7773,1)
     mkstat = 2 : End
   Endif

   [M:DIA]CPY        = [F:CCN]CPY
   [M:DIA]FCY        = [F:CCN]FCY
   [M:DIA]CCNDES1    = [F:CCN]CCNDES1
   [M:DIA]CCNDES2    = [F:CCN]CCNDES2
   [M:DIA]CCNUSR     = [F:CCN]CCNUSR
   [M:DIA]STRCCNDAT  = [F:CCN]STRCCNDAT
   If ( [F:CCN]REAENDCCN = [0/0/0] ) Then
     [M:DIA]ENDCCNDAT  = [F:CCN]ENDCCNDAT
   Else
     [M:DIA]ENDCCNDAT  = [F:CCN]REAENDCCN
   Endif
   [M:DIA]ENDCCNDATO = [F:CCN]ENDCCNDAT
    Affzo [M:DIA]CPY
    Affzo [M:DIA]ZCPY
    Affzo [M:DIA]FCY
    Affzo [M:DIA]ZFCY
    Affzo [M:DIA]CCNDES1
    Affzo [M:DIA]CCNDES2
    Affzo [M:DIA]CCNUSR
    Affzo [M:DIA]ZCCNUSR
    Affzo [M:DIA]STRCCNDAT
    Affzo [M:DIA]ENDCCNDAT
 Endif

 If ( [F:CCN]CCNSTA = GVML_CSTERM ) Then
   [M:DIA]FLGCNL = G_OUI : Affzo [M:DIA]FLGCNL
   Diszo [M:DIA]ENDCCNDAT : Affzo [M:DIA]ENDCCNDAT
 Else
   [M:DIA]FLGCNL = G_NON : Affzo [M:DIA]FLGCNL
   Actzo [M:DIA]ENDCCNDAT : Affzo [M:DIA]ENDCCNDAT
 Endif

 [M:DIA]CCNREF = VALEUR

End


#=============================
Subprog AM_ENDCCNDAT(VALEUR)
Variable Date    VALEUR()

  If ( VALEUR < GDEBEXECPF) Then
    # La date de fin de la concession doit être > à la date de début de l'exercice courant
    GERR= 1 : GMESSAGE= mess(735,7773,1)
    mkstat = 2 : End
  Endif

  [M:DIA]ENDCCNDAT = VALEUR
End

#------------------------------------------------------
# Fonction permettant de savoir si un bien est en dehors
# de l'intervalle de définition de la concession.
#    1    - Non
#    2    - Oui
#    RNBE - nombre de biens
#------------------------------------------------------
Funprog IS_FAS_OUTSIDE_CCN (PCCNREF, PFINCCN)
Value   Char PCCNREF
Value   Date PFINCCN

  Local Shortint RETOUR
  Local Integer  RNBE

  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif

  Filter [WFAS] Where CCNREF = PCCNREF  and PURDAT > PFINCCN
  RNBE = rowcount([WFAS])
  Filter [WFAS]

  If RNBE > 0
    RETOUR = G_OUI
  Else
    RETOUR = G_NON
  Endif
End RETOUR

#------------------------------------------------------
# Fonction permettant de savoir si la date de sortie d'un bien est en dehors
# est au delà de la fin de concession.
#    1    - Non
#    2    - Oui
#    RNBE - nombre de biens
#------------------------------------------------------
Funprog IS_ISSDAT_OUTSIDE_CCN (PCCNREF, PFINCCN)
Value   Char PCCNREF
Value   Date PFINCCN

  Local Shortint RETOUR
  Local Integer  RNBE

  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif

  Filter [WFAS] Where CCNREF = PCCNREF  and ISSDAT <> [0/0/0] and ISSDAT > PFINCCN
  RNBE = rowcount([WFAS])
  Filter [WFAS]

  If RNBE > 0
    RETOUR = G_OUI
  Else
    RETOUR = G_NON
  Endif
End RETOUR

######################################################################################


#======================
$GET_PARAMETRES

 #-> PARAM(1) - Mode silencieux oui / non
 #-> PARAM(2) - En silencieux : Traitement de remplissage du masque de saisie


 If ( PARAM(1)<>"" and PARAM(2)<>"" ) Then
   GACTSILENCE = val(PARAM(1))
   GTRTFILMSK  = PARAM(2)
 Else
   GACTSILENCE = G_NON
   GTRTFILMSK  = "....."
 Endif

Return

################################################################################
# Traitement de gestion de la trace - informations particulières à l'action    #
################################################################################
#==============================
$ECR_PARM

  Local Integer NB_LUS  : NB_LUS=0
  Local Integer NB_MAJ  : NB_MAJ=0
  Local Integer NB_ERR  : NB_ERR=0

  If ( GACTSILENCE = G_OUI      ) Then : Return : Endif

  Call ECR_TRACE("", 0,"",0,1) From TRACEABX3
  # "Options"
  Call ECR_TRACE("", 0,mess(705,7773,1),0,1)    From TRACEABX3
  Call ECR_TRACE("", 0,"=====================",0,1) From TRACEABX3
  # "Traitement simulé    :"
  Call ECR_TRACE("", 0,mess(706,7773,1)-mess([M:DIA]FLGSIM,1,1),0,1) From TRACEABX3
  # "Trace détaillée      :"
  Call ECR_TRACE("", 0,mess(707,7773,1)-mess([M:DIA]FLGDET,1,1),0,1) From TRACEABX3
  # "Calcul amortissement :"
  Call ECR_TRACE("", 0,mess(708,7773,1)-mess([M:DIA]FLGCAL,1,1),0,1) From TRACEABX3

  Call ECR_TRACE("", 0,"",0,1) From TRACEABX3
  # "Critères de sélection"
  Call ECR_TRACE("", 0,mess(709,7773,1),0,1)    From TRACEABX3
  Call ECR_TRACE("", 0,"=====================",0,1) From TRACEABX3
  # "Société              :"
  Call ECR_TRACE("", 0,mess(710,7773,1)-[M:DIA]CPY-[M:DIA]ZCPY,0,1) From TRACEABX3
  # "Site                 :"
  Call ECR_TRACE("", 0,mess(711,7773,1)-[M:DIA]FCY-[M:DIA]ZFCY,0,1) From TRACEABX3
  # "Concédant            :"
  Call ECR_TRACE("", 0,mess(712,7773,1)-[M:DIA]CCNUSR-[M:DIA]ZCCNUSR,0,1) From TRACEABX3
  # "Contrat concession   :"
  Call ECR_TRACE("", 0,mess(713,7773,1)-[M:DIA]CCNREF-[M:DIA]CCNDES1,0,1) From TRACEABX3

  Call ECR_TRACE("", 0,"",0,1) From TRACEABX3
  # "Paramètres"
  Call ECR_TRACE("", 0,mess(714,7773,1),0,1)    From TRACEABX3
  Call ECR_TRACE("", 0,"=====================",0,1) From TRACEABX3
  # "Date fin concession  :"
  Call ECR_TRACE("", 0,mess(715,7773,1)-format$("D:" + GFMDAT4,[M:DIA]ENDCCNDAT),0,1) From TRACEABX3

Return

#===============================
$ECR_ENTETE
Local    Char    LINE(115)

  If ( GACTSILENCE = G_OUI     ) Then : Return : Endif

  # Entête
  LINE = ""
  Call ECR_TRACE("", 0, LINE, 0,1)                  From TRACEABX3
  If ( [M:DIA]FLGCNL = G_OUI ) Then
    # "ANNULATION DE LA  FIN DE CONCESSION SUR LES BIENS"
    LINE = mess(737,7773,1)
  Else
    # "PRISE EN COMPTE DE LA FIN DE CONCESSION SUR LES BIENS"
    LINE = mess(732,7773,1)
  Endif
  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3

  If ( [M:DIA]FLGDET <> G_OUI ) Then : Return : Endif

  # "Trace détaillée"
  Call ECR_TRACE("", 0,mess(717,7773,1),0,1)       From TRACEABX3
  Call ECR_TRACE("", 0,"=====================",0,1) From TRACEABX3
  LINE = ""
  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3
  LINE = string$(115,"*")
  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3
  # "Réf. Bien"
  LINE =      left$( mess(719,7773,1)  + string$(20,' '), 20)+"!"
  # "Désignation"
  LINE +=     left$( mess(720,7773,1)  + string$(55,' '), 55)+"!"

  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3
  LINE = string$(115,"*")
  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3

Return

#===============================
$ECR_LIGNE
Local    Char    LINE(115)

  If ( [M:DIA]FLGDET <> G_OUI ) Then : Return : Endif
  If ( GACTSILENCE = G_OUI     ) Then : Return : Endif

  LINE =  left$( [F:FAS]AASREF                          + string$(20,' '), 20)+"!"
  LINE += left$( [F:FAS]AASDES1                         + string$(55,' '), 55)+"!"

  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3

Return

#==============================
$ECR_STAT

  If GACTSILENCE=G_OUI : Return : Endif

  Call ECR_TRACE("", 0,"",0,1) From TRACEABX3
  # "Statistiques"
  Call ECR_TRACE("", 0,mess(724,7773,1),0,1)    From TRACEABX3
  Call ECR_TRACE("", 0,"=====================",0,1) From TRACEABX3
  # "Biens"
  Call ECR_TRACE("", 0,mess(725,7773,1),0,1) From TRACEABX3
  Call ECR_TRACE("", 0,"==========================================",0,1) From TRACEABX3
  # "Sélectionnés     Mis à jour      En erreur"
  Call ECR_TRACE("", 0,mess(726,7773,1),0,1) From TRACEABX3
  Call ECR_TRACE("", 0,"==========================================",0,1) From TRACEABX3
  LINE  = left$( ""                                   + string$( 5,' '),  5)
  LINE += left$( num$(NB_LUS)                         + string$(10,' '), 10)+"!"
  LINE += left$( ""                                   + string$( 5,' '),  5)
  LINE += left$( num$(NB_MAJ)                         + string$(10,' '), 10)+"!"
  LINE += left$( ""                                   + string$( 5,' '),  5)
  LINE += left$( num$(NB_ERR)                         + string$(10,' '), 10)
  Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3

Return

#==============================
$ALIM_MASK
  Raz [M:ASL]
  # Flag de simulation
  FLGSIM          =  [M:DIA]FLGSIM
  [M:MHC]FLGSIM   =  [M:DIA]FLGSIM
  # Alimentation de l'en-tête
  [M:MHC]FLGCPY(find([M:DIA]CPY,[M:MHC]CPY)-1)  = G_OUI
  [M:MHC]FLGFCY(find([M:DIA]FCY,[M:MHC]FCY)-1)  = G_OUI
  # Alimentation des paramètres de l'action étendue
  If (G_ONEBYONE) Then
    # Bien par bien
    [M:ASL]EXP1 = "AASREF = G_REFIMMO"
  Else
    # Tous les biens en une fois
    If ( [M:DIA]FLGCNL = G_OUI ) Then
      # Requete : Prise en compte uniquement des biens dont le type de sortie est "Remis au concédant"
      [M:ASL]EXP1 = "CCNREF = [M:DIA]CCNREF and ISSTYP= GVML_TSFCONC"
    Else
      # Requete : Prise en compte uniquement des biens qui ne sont pas encore sortis.
      [M:ASL]EXP1 = "CCNREF = [M:DIA]CCNREF and ISSDAT = [0/0/0]"
    Endif
  Endif

  # Type de sortie
  Local Char TYPSOR
  If ( [M:DIA]FLGCNL = G_OUI ) Then
    TYPSOR="ANN"
  Else
    TYPSOR="SOR"
  Endif

  Case TYPSOR
    When "ANN"
     [M:FASS]CCLISSFLG = G_OUI
    When "SOR"
     [M:FASS]CCLISSFLG = G_NON
     [M:FASS]EXTISSFLG = G_NON
     [M:FASS]ISSCMPFLG = G_OUI
     [M:FASS]IMLFLG    = G_OUI
     If (GPHY = G_OUI) Then : [M:FASS]ECRPHYATT = G_OUI : Endif
     [M:FASS]ISSDAT    = [M:DIA]ENDCCNDAT
     [M:FASS]ISSTYP    = GVML_TSFCONC
     [M:FASS]ISSDATRUL = 1
     [M:FASS]ISSAMTTYP = GVML_TVAUCUN
     [M:FASS]ISSAMT    = 0
     [M:FASS]PYBVATTYP = GVML_SNSREGU
     [M:FASS]ISSAMTTYP = 1
 Endcase

Return

