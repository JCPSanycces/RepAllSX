#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du masque CONSCPI1
#########################################################################
# CNSCPISTD : Consultation des factures d'achat            HN  12/05/00 #
# ECRAN 1   : CONSCPI1                                                  #
# ECRAN 2   : CONSCPI2                                                  #
# ECRAN CRIT: CRITCPI                                                   #
#########################################################################
Local Char PARAM(20)(1..2)
PARAM(1) = "2204"
PARAM(2) = "GAL"
GFINRSP  = "HN"
Call GCONSULT("CPI","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AB1_NBLIG"  : Gosub AB1_NBLIG
  When Default
Endcase
Return

############################################################
$AUTORIS
Return

############################################################
$SETBOUT
CHMEN+="BCDE"
Return

###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
NAVIG="CONSCPI"
Local Char    WFIL(250),WFIL1(250),WFIL2(250),WFIL3(250)
Local Char    DEBNUM(GLONPIH), FINNUM(GLONPIH)
Local Date    DEBDAT, FINDAT
# Issue 84130 - 2013-01-31 by MAE : Déclaration des variables pour les requetes
Local Char REQUETE(255)(3)
Local Char REQUETEPID(255)(2)
Local Char REQUETECPR(255)(3)
Local Integer BASE
Local Decimal WDISCGRAMTMAX, WDISCGRAMTMIN, WAMTNOTLIN
Local Char WCUR
Local Integer WCURTYP
Local Decimal WCOURS : WCOURS=1
Local Integer LRET  # Issue 84130 - 2013-04-08 by MAE :

# Issue 84130 - 2013-04-08 by MAE : ouverture de l'écran [CTS2]
If !clalev([M:CST2]) Local Mask CSTLIN2 [CST2]  : Endif
If !clalev([F:PID])  Local File PINVOICED [PID]  : Endif


If !clalev([F:PFI])  Local File PFOOTINV [PFI]  : Endif
If !clalev([F:PVF])  Local File PVCRFOOT [PVF]  : Endif

Case GTYPDBA
    When 1 : BASE=3 : # Oracle
    When 2 : BASE=5 : # Sql
    When 3 : BASE=2 : # Cisam
    When 4 : BASE=4 : # DB2
  Endcase
#fin MAE 84130

#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
Call GETDEV(GSOCIETE) From DEVSUB
Gosub DEFCRIT
Return

# --------------------------------------------------------------------------#
# Analyse paramères, initialisations                                        #
# --------------------------------------------------------------------------#
$DEFCRIT
If GNBAUZ=1 : PARAM(2) = GUSRFCY(1) : Endif
For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre tiers
      If PARAM(I) <> ""
        If [F:BPR]BPRNUM <> PARAM(I) Read [BPR] BPR0 = PARAM(I)
                                     If fstat  Raz [F:BPR], PARAM(I) : Endif
        Endif
#US 71069/138  by RBA
#        [M:CPI1]BPR = PARAM(I)
        [M:CPI1]BPSNUMDEB = PARAM(I)
        [M:CPI1]BPSNUMFIN = PARAM(I)
#/US 71069/138  by RBA
      Endif
    When 2 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [FCY] FCY0 = PARAM(I)
                                     If fstat  Raz [F:FCY], PARAM(I) : Endif
        Endif
        If (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
          [M:CPI1]FCY = PARAM(I)
          Call GETDEV([M:CPI1]FCY) From DEVSUB
          [M:CPI1]FCY = GFINRSP
          [M:CPI1]CPY = GSOCIETE
          [M:CPI1]CUR = GLOCALDEV
        Endif
      Endif
    When 3 :    : # Nom du champ
      If PARAM(I) <> ""
        Case PARAM(I)
          When "NPTINV" : [M:CCPI]MODT=2 : [M:CPI1]STAO=1 : [M:CPI1]STAN=2
          When "INV"    : [M:CCPI]MODT=2 : [M:CPI1]STAO=2 : [M:CPI1]STAN=1
                                           [M:CCPI]BAPO=2 : [M:CCPI]BAPN=1
          When "INVNBP" : [M:CCPI]MODT=2 : [M:CPI1]STAO=2 : [M:CPI1]STAN=1
                                           [M:CCPI]BAPO=1 : [M:CCPI]BAPN=2
        Endcase
      Endif
    # Issue 84130 - 2013-02-28 by MAE : Ajout des charges achat
    When 4 :    : # Parametre piéce
      If PARAM(I) <> ""
        [M:CPI1]NUMDEB = PARAM(I)
        [M:CPI1]NUMFIN = PARAM(I)
      Endif
  Endcase
Next I
[M:CPI1]CURD=GSYSCUR
If [M:CPI1]CUR=""  [M:CPI1]CUR=GSYSCUR : Endif
# type facture
If !find([M:CPI1]PIHTYP1,1,2) : [M:CPI1]PIHTYP1= 2 : Endif
# type facture complé.
If !find([M:CCPI]PIHTYP2,1,2) : [M:CCPI]PIHTYP2= 2 : Endif
# type avoir
If !find([M:CPI1]PIHTYP3,1,2) : [M:CPI1]PIHTYP3= 2 : Endif
# type avoir/retour
If !find([M:CCPI]PIHTYP4,1,2) : [M:CCPI]PIHTYP4= 2 : Endif

# validée
If !find([M:CPI1]STAO,1,2)    : [M:CPI1]STAO= 2    : Endif
# non validée
If !find([M:CPI1]STAN,1,2)    : [M:CPI1]STAN= 2    : Endif
If !find([M:CCPI]TRI,1,2)     : [M:CCPI]TRI = 1    : Endif

# Module achat
If !find([M:CCPI]MODA,1,2)    : [M:CCPI]MODA= 2    : Endif
# Module tiers (activé si appel depuis les tiers fournisseurs)
If !find([M:CCPI]MODT,1,2)
  GBIDC3=adxpno(3)
  If pat(GBIDC3,"*WGOBPS*")
  ## If GBIDC3="WGOBPS"
    [M:CCPI]MODT = 2
  Else
    [M:CCPI]MODT = 1
  Endif
Endif

# Niveau BAP oui
If !find([M:CCPI]BAPO,1,2)    : [M:CCPI]BAPO= 2    : Endif
# Niveau BAP non
If !find([M:CCPI]BAPN,1,2)    : [M:CCPI]BAPN= 2    : Endif

#----- Initialisation dates début et fin -----#
#MAE, 84130, si on vient d'une réception, on n'initialise pas les dates et on initialise le code regroupement
If GPILNAV>1
  If ! find(GNAVIG(GPILNAV-1),"GESPIH")
    Gosub INIT_DATES From TRTACHGRH1
    [M:CPI1]BPRDATDEB=WDATDEB
    [M:CPI1]BPRDATFIN=WDATFIN
  Endif
Else
  Gosub INIT_DATES From TRTACHGRH1
  [M:CPI1]BPRDATDEB=WDATDEB
  [M:CPI1]BPRDATFIN=WDATFIN
Endif
#Fin MAE

#----- Copie du masque 1 (CPI1) vers l'écran critères (CCPI) -----#
Gosub CRITENT From =PROGCNS
Return

############################################################
$LECTURE
Local   Decimal  WMNTORG(0..1), WMNTDES(0..1)
Local   Integer  SPSTAT
Local   Integer  NUMECH
Local   Integer  WFLGPAZ
Local   Decimal  WRATCUR, WRATRPT
Local   Shortint WI
#----- Grisage du champ fournisseur si consultation depuis celui-ci -----#
If GPILNAV>1
  If find(GNAVIG(GPILNAV-1),"GESBPS")
  #Diszo [CPI1]BPR :
    Diszo [M:CPI1]BPSNUMDEB : Diszo [M:CPI1]BPSNUMFIN
  Endif
Endif
#-----
Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCPI]TRI
      When 1 : # tri par numéro
        Filter [PIH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By Key PIH0
      When 2 : # tri par date
        Filter [PIH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By Key CLE=[F:PIH]BPRDAT;[F:PIH]NUM
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCPI]TRI
      When 2 : # tri par date
        Filter [PIH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By Key CLE=[F:PIH]BPRDAT Desc ; [F:PIH]NUM Desc
      When 1 : # tri par numéro
        Filter [PIH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By Key PIH0 Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CPI2] : Endif

#-- lecture
$BOUCLE
For [PIH]
  #----- Filtre sur la société -----#
  If [M:CPI1]CPY<>""
    If [F:FCY]FCY<>[F:PIH]FCY
      Read [FCY] FCY0=[F:PIH]FCY : If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY<>[M:CPI1]CPY  Goto SUIV : Endif
  Else  #MAE, 84130, si la société est vide, on réaffecte les variables globales
    GLOCALDEV=[F:PIH]CUR
    GSOCIETE = [F:PIH]CPY
  Endif
  #----- Filtre sur le bon à payer -----#
  For [DUD] DUD1 Where ACCNUM=[F:PIH]ACCNUM
    [F:PIH]PAZ=[F:DUD]FLGPAZ
    Break
  Next
  If !evalue(WFIL2)  Goto SUIV : Endif
  #-----
  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CPI2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         DEBNUM = [F:PIH]NUM
         DEBDAT = [F:PIH]BPRDAT
     Endif
     FINNUM = [F:PIH]NUM
     FINDAT = [F:PIH]BPRDAT
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         FINNUM = [F:PIH]NUM
         FINDAT = [F:PIH]BPRDAT
     Endif
     DEBNUM = [F:PIH]NUM
     DEBDAT = [F:PIH]BPRDAT
  Endif

  nolign = NOL+1
  [M:CPI2] = [F:PIH]
# Lecture de la devise pour récupérer le format
  If clalev([F:TCU])= 0 : Local File TABCUR [TCU] : Endif
  If [F:TCU]CUR <> [F:PIH]CUR
     Read [TCU] TCU0 = [F:PIH]CUR
     If fstat Raz [F:TCU] : Endif
  Endif
# Total TTC
  [M:CPI2]AMTATI(nolign-1)     = [F:PIH]AMTATI
# Devise
  [M:CPI2]CUR(nolign-1)        = [F:PIH]CUR
  If [F:PIH]CUR <> [M:CPI1]CUR
    # Calcul du montant en devise société
    WMNTORG (0) = [F:PIH]AMTATI
    # Issue 91193 - 2013-08-09 by MUARN : ajout HT document
    WMNTORG(1) = [F:PIH]AMTNOT
    WI=find(GLOCALDEV,[F:PIH]CURLED)
    If WI & [F:PIH]RATDIV(WI-1)<>0
      WRATCUR=[F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1)
    Else
      WRATCUR=0
    Endif
    If WRATCUR=0
      Call CONVERT2([F:PIH]CUR,[M:CPI1]CUR,[M:CPI1]CUR,[F:PIH]CURTYP,datesyst,
&                   WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
      # Issue 91193 - 2013-08-09 by MUARN : ajout HT document
      Call CONVERT2([F:PIH]CUR,[M:CPI1]CUR,[M:CPI1]CUR,[F:PIH]CURTYP,datesyst,
&                   WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
    Else
      WMNTDES(0) = WMNTORG(0) * WRATCUR
      # Issue 91193 - 2013-08-09 by MUARN : ajout HT document
      WMNTDES(1) = WMNTORG(1) * WRATCUR
    Endif
    If [F:TCU]CUR <> [M:CPI1]CUR
      Read [TCU] TCU0 = [M:CPI1]CUR
      If fstat Raz [F:TCU] : Endif
    Endif
    # Montant TTC société
    [M:CPI2]AMTATILOC(nolign-1)  = arr(WMNTDES(0),[F:TCU]CURRND)
    # Issue 91193 - 2013-08-09 by MUARN : ajout HT document
    [M:CPI2]AMTNOTSOC(nolign-1)  = arr(WMNTDES(1),[F:TCU]CURRND)
  Else
    [M:CPI2]AMTATILOC(nolign-1)  = [M:CPI2]AMTATI(nolign-1)
    [M:CPI2]AMTNOTSOC(nolign-1)  = [M:CPI2]AMTNOT(nolign-1)
  Endif
  If [F:PIH]CUR <> [M:CPI1]CURD
  # Calcul du montant en devise dossier
    WMNTORG (0) = [F:PIH]AMTATI
    # Issue 91193 - 2013-08-09 by MUARN : ajout HT document
    WMNTORG(1) = [F:PIH]AMTNOT
    WI=find(GSYSCUR,[F:PIH]CURLED)
    If WI & [F:PIH]RATDIV(WI-1)<>0
      WRATRPT=[F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1)
    Else
      WRATRPT=0
    Endif
    If WRATRPT=0
      Call CONVERT2([F:PIH]CUR,[M:CPI1]CURD,[M:CPI1]CURD,[F:PIH]CURTYP,datesyst,
&                   WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
      # Issue 91193 - 2013-08-09 by MUARN : ajout HT document
      Call CONVERT2([F:PIH]CUR,[M:CPI1]CUR,[M:CPI1]CUR,[F:PIH]CURTYP,datesyst,
&                   WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
    Else
      WMNTDES(0) = WMNTORG(0) * WRATRPT
    Endif
    If [F:TCU]CUR <> [M:CPI1]CURD
      Read [TCU] TCU0 = [M:CPI1]CURD
      If fstat Raz [F:TCU] : Endif
    Endif
  # Montant TTC dossier
    [M:CPI2]AMTATIDOS(nolign-1)  = arr(WMNTDES(0),[F:TCU]CURRND)
    # Issue 91193 - 2013-08-09 by MUARN : ajout HT document
    [M:CPI2]AMTNOTDOS(nolign-1)  = arr(WMNTDES(1),[F:TCU]CURRND)
  Else
    [M:CPI2]AMTATIDOS(nolign-1)  = [M:CPI2]AMTATI(nolign-1)
    [M:CPI2]AMTNOTDOS(nolign-1)  = [M:CPI2]AMTNOT(nolign-1)
  Endif

  #US 71069/16  PJT by RBA
  [M:CPI2]PJTH(nolign-1)       = [F:PIH]PJTH
  #/US 71069/16  PJT by RBA

# Site de facturation
  [M:CPI2]FCY(nolign-1)        = [F:PIH]FCY
# Départ échéance
  [M:CPI2]STRDUDDAT(nolign-1)  = [F:PIH]STRDUDDAT
# Numéro interne
  NUMECH   = [F:PIH]ACCNUM
# Recherche du montant réglé
  Raz [M:CPI2]PAYTOT(nolign-1), [M:CPI2]PAYTOTLOC(nolign-1), [M:CPI2]PAYTOTDOS(nolign-1)
  #-----
  Raz [L]WFLGPAZ
  #-----
  For [DUD]DUD1 Where ACCNUM=NUMECH
     [M:CPI2]PAYTOT(nolign-1)    += [F:DUD]PAYCUR+[F:DUD]TMPCUR : # Total règlements
     [M:CPI2]PAYTOTLOC(nolign-1) += [F:DUD]PAYLOC+[F:DUD]TMPLOC : # en devise société
    #[M:CPI2]PAYTOTDOS(nolign-1) += [F:DUD]PAYRPT+[F:DUD]TMPRPT : # en devise dossier (supprimé en v6!)
     #-----
     If [L]WFLGPAZ=0
       [L]WFLGPAZ=[F:DUD]FLGPAZ
     Elsif [L]WFLGPAZ<>[F:DUD]FLGPAZ
       [L]WFLGPAZ=9
     Endif
     #-----
  Next
  #-----
  If [L]WFLGPAZ<>0
    [F:PIH]PAZ=[L]WFLGPAZ
  Endif
  #-----
  If [F:PIH]CUR=[M:CPI1]CUR
    [M:CPI2]PAYTOTLOC(nolign-1) = [M:CPI2]PAYTOT(nolign-1) : # Par sécurité
  Endif
  If [F:PIH]CUR=[M:CPI1]CURD
    [M:CPI2]PAYTOTDOS(nolign-1) = [M:CPI2]PAYTOT(nolign-1) : # Par sécurité
  # Issue X3-88040 - 2018-04-24 by SR : Convertir de devise document vers devise dossier
  Else
    Call CONVERT2([F:PIH]CUR,[M:CPI1]CURD,[M:CPI1]CUR,[F:PIH]CURTYP,datesyst,
&        [M:CPI2]PAYTOT(nolign-1),[M:CPI2]PAYTOTDOS(nolign-1),SPSTAT) From TRTDEV
  Endif
# Condition de paiement
  [M:CPI2]PTE(nolign-1)        = [F:PIH]PTE
# Document d'origine
  [M:CPI2]BPRVCR(nolign-1)     = [F:PIH]BPRVCR
# Statut
  [M:CPI2]STA(nolign-1)        = [F:PIH]STA
# Bon à payer
  [M:CPI2]PAZ(nolign-1)        = [F:PIH]PAZ

# Issue 84130 - 2013-01-31 by MAE : Lecture les lignes de commande pour récupérer les montants
#calcul du cours de change si devise différente

If [F:PIH]CUR <> [M:CPI1]CUR
    If [F:PIH]RATDIV(0)<>0  WCOURS=[F:PIH]RATMLT(0)/[F:PIH]RATDIV(0) : Endif
Endif

#Calcul sur la somme des lignes de commande
#Charges directes, montant ligne hors taxes,coût achat,
REQUETE(0) = "SELECT SUM(FCSCSTPUR_0),SUM(AMTNOTLIN_0),SUM(LINCSTPUR_0)"
#taxes non déductibles
REQUETE(1)=
&
&
&
&
&
&
&
&
&
&
&
&
&
&
&
&
&
&
& 
& ",SUM((AMTTAXLIN1_0-DEDTAXLIN1_0)+(AMTTAXLIN2_0-DEDTAXLIN2_0)+(AMTTAXLIN3_0-DEDTAXLIN3_0)+(AMTTAXRCP_0-DEDTAXRCP_0)+(AMTTAXISS_0-DEDTAXISS_0)+(AMTTAXOTH1_0-DEDTAXOTH1_0)+(AMTTAXOTH2_0-DEDTAXOTH2_0))"
REQUETE(2)=" from PINVOICED WHERE NUM_0='"+[M:CPI2]NUM(nolign-1)+"'"

  For (Decimal WFCSCSTPUR,Decimal WLINAMT,Decimal WLINCSTPUR,Decimal WNONDEDTAX) From num$(BASE) Sql REQUETE As [SPOQ]
  [M:CPI2]FCSCSTPURD(nolign-1)= arr([SPOQ]WFCSCSTPUR/WCOURS,[F:TCU]CURRND)
  [M:CPI2]LINCSTPUR(nolign-1)=  arr([SPOQ]WLINCSTPUR/WCOURS,10^-GDECPRI)
  [M:CPI2]LINAMT(nolign-1)=  arr([SPOQ]WLINAMT,[F:TCU]CURRND)
  [M:CPI2]NONDEDTAXD(nolign-1)=  arr([SPOQ]WNONDEDTAX,[F:TCU]CURRND)
   Next

#Calcul total coefficient d'approche sur les lignes en coeff d'approche
REQUETECPR(0)="select SUM(LINCSTPUR_0), SUM(AMTNOTLIN_0), SUM(DISCRGAMT1_0+DISCRGAMT2_0+DISCRGAMT3_0+DISCRGAMT4_0+DISCRGAMT5_0+DISCRGAMT6_0+DISCRGAMT7_0+DISCRGAMT8_0+DISCRGAMT9_0)"
REQUETECPR(1)=
&
&
&
&
&
&
&
&
&
&
&
&
&
&
&
&
&
&
& 
& ",SUM((AMTTAXLIN1_0-DEDTAXLIN1_0)+(AMTTAXLIN2_0-DEDTAXLIN2_0)+(AMTTAXLIN3_0-DEDTAXLIN3_0)+(AMTTAXRCP_0-DEDTAXRCP_0)+(AMTTAXISS_0-DEDTAXISS_0)+(AMTTAXOTH1_0-DEDTAXOTH1_0)+(AMTTAXOTH2_0-DEDTAXOTH2_0))"
REQUETECPR(2)=" from PINVOICED WHERE NUM_0='"+[M:CPI2]NUM(nolign-1)+"' and (CPRCOE_0<>1 or CPRAMT_0<>0)"

  For (Decimal WLINCSTPUR,Decimal WAMTNOTLIN,Decimal WDISCGRAMT,Decimal WTAXNONDED) From num$(BASE) Sql REQUETECPR As [SPCP]
  [M:CPI2]TOTCOEFFAPPD(nolign-1) =  arr(([SPCP]WLINCSTPUR/WCOURS)-[SPCP]WAMTNOTLIN-[SPCP]WDISCGRAMT-[SPCP]WTAXNONDED ,[F:TCU]CURRND)
  Next

#Lecture des factures complémentaires

For [PID] Where NUM = [F:PIH]NUM
  Call COST_ADDINV(4,[F:PID]NUM,[F:PID]PIDLIN,0,[F:PID]FCY,[F:PID]ITMREF,LRET) From STCLIB
  If LRET
    GMESSAGE = mess(44,199,1)
    mkstat = 2
  Endif
  For J=0 To [M:CST2]NBNONDET-1
    If [M:CST2]CURCPY3(J) <> [F:PIH]CUR
      [M:CPI2]AMTNOTLIND(nolign-1) += arr([M:CST2]AMTNDTCPY(J)/WCOURS,[F:TCU]CURRND)
    Else
      [M:CPI2]AMTNOTLIND(nolign-1) += [M:CST2]AMTNDTCPY(J)
    Endif
  Next
Next




Raz WDISCGRAMTMAX, WDISCGRAMTMIN
#Total éléments de facturation :Lecture de PVCRFOOT pour sommer les éléments de facturation
Filter [PVF] Where [F:PVF]VCRNUM = [F:PIH]NUM & [F:PVF]VCRTYP=8
  For [PVF]
    Read [PFI] PFI0=[F:PVF]INVDTA : If fstat Raz [F:PFI] : Endif
    If [F:PFI]INCDCR=1
      WDISCGRAMTMAX +=[F:PVF]INVDTAAMT
    Else
      WDISCGRAMTMIN +=[F:PVF]INVDTAAMT
    Endif
 Next
Filter[PVF]

[M:CPI2]DISCGRAMTMID(nolign-1) = WDISCGRAMTMIN
[M:CPI2]DISCGRAMTMAD(nolign-1) = WDISCGRAMTMAX

#Total des charges : charges directes + Elts fact maj + taxes non ded + fac compl
#                    + frais approche
[M:CPI2]TOTCHARGESD(nolign-1) = [M:CPI2]FCSCSTPURD(nolign-1) + [M:CPI2]DISCGRAMTMAD(nolign-1) +
&                              [M:CPI2]NONDEDTAXD(nolign-1) + [M:CPI2]AMTNOTLIND(nolign-1) +
&                              [M:CPI2]TOTCOEFFAPPD(nolign-1)

#Total cout achat = mtt HT+charges directes +Elt fact majo+Elt facto min + Taxes non ded
#                  +FCC + frais d'approche
[M:CPI2]TOTCOUTACHD(nolign-1) = [M:CPI2]LINAMT(nolign-1)+[M:CPI2]FCSCSTPURD(nolign-1)+
&                              [M:CPI2]DISCGRAMTMAD(nolign-1)+[M:CPI2]DISCGRAMTMID(nolign-1)+
&                              [M:CPI2]NONDEDTAXD(nolign-1)+ [M:CPI2]AMTNOTLIND(nolign-1) +
&                              [M:CPI2]TOTCOEFFAPPD(nolign-1)

#MAE, exi 91193
#conversion en devise société
If [M:CPI1]CUR <> [F:PIH]CUR
  [M:CPI2]LINAMTSOC(nolign-1) = arr([M:CPI2]LINAMT(nolign-1)*WCOURS,[F:TCU]CURRND)
  [M:CPI2]DISCGRAMTMIS(nolign-1) = arr([M:CPI2]DISCGRAMTMID(nolign-1)*WCOURS,[F:TCU]CURRND)
  [M:CPI2]TOTCHARGESS(nolign-1) = arr([M:CPI2]TOTCHARGESD(nolign-1)*WCOURS,[F:TCU]CURRND)
  [M:CPI2]TOTCOUTACHS(nolign-1) = arr([M:CPI2]TOTCOUTACHD(nolign-1)*WCOURS,[F:TCU]CURRND)
  # MUARN, exi 91193
  [M:CPI2]DISCGRAMTMAS(nolign-1) = arr([M:CPI2]DISCGRAMTMAD(nolign-1)*WCOURS,[F:TCU]CURRND)
  [M:CPI2]NONDEDTAXS(nolign-1) = arr([M:CPI2]NONDEDTAXD(nolign-1)*WCOURS,[F:TCU]CURRND)
  [M:CPI2]FCSCSTPURS(nolign-1) = arr([M:CPI2]FCSCSTPURD(nolign-1)*WCOURS,[F:TCU]CURRND)
  [M:CPI2]AMTNOTLINS(nolign-1) = arr([M:CPI2]AMTNOTLIND(nolign-1)*WCOURS,[F:TCU]CURRND)
  [M:CPI2]TOTCOEFFAPPS(nolign-1) = arr([M:CPI2]TOTCOEFFAPPD(nolign-1)*WCOURS,[F:TCU]CURRND)
Else
  [M:CPI2]LINAMTSOC(nolign-1) = [M:CPI2]LINAMT(nolign-1)
  [M:CPI2]DISCGRAMTMIS(nolign-1) = [M:CPI2]DISCGRAMTMID(nolign-1)
  [M:CPI2]TOTCHARGESS(nolign-1) = [M:CPI2]TOTCHARGESD(nolign-1)
  [M:CPI2]TOTCOUTACHS(nolign-1) = [M:CPI2]TOTCOUTACHD(nolign-1)
  # MUARN, exi 91193
  [M:CPI2]DISCGRAMTMAS(nolign-1) = [M:CPI2]DISCGRAMTMAD(nolign-1)
  [M:CPI2]NONDEDTAXS(nolign-1) = [M:CPI2]NONDEDTAXD(nolign-1)
  [M:CPI2]FCSCSTPURS(nolign-1) = [M:CPI2]FCSCSTPURD(nolign-1)
  [M:CPI2]AMTNOTLINS(nolign-1) = [M:CPI2]AMTNOTLIND(nolign-1)
  [M:CPI2]TOTCOEFFAPPS(nolign-1) = [M:CPI2]TOTCOEFFAPPD(nolign-1)
Endif
#fin MAE 91193

  $SUIV
Next
Filter [PIH]

Return

############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
#Filtre sur l'origine
#WFIL  = "[F:PIH]ORIMOD=6"
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"
WFIL3 = "1=1"

# Site de facturation
If [M:CPI1]FCY <> ""
   WFIL += "&[F:PIH]FCY=[M:CPI1]FCY"
Endif
# Autorisation site
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
   WFIL += "& find([F:PIH]FCY,GUSRFCY(1..GNBAUZ))"
Endif
## Numéro de tiers
#If [M:CPI1]BPR <> ""
#   WFIL += "&[F:PIH]BPR =[M:CPI1]BPR"
#Endif


# Numéro de fournisseur
If [M:CPI1]BPSNUMDEB <> ""
   WFIL += "&[F:PIH]BPR >=[M:CPI1]BPSNUMDEB"
Endif
If [M:CPI1]BPSNUMFIN <> ""
   WFIL += "&[F:PIH]BPR <=[M:CPI1]BPSNUMFIN"
Endif


#    Prise en compte des factures
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPI1]PIHTYP1= 1
   WFIL1 += "&[F:PIH]PIHTYP<>1"
Endif

#    Prise en compte des factures complémentaires
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPI]PIHTYP2= 1
   WFIL1 += "&[F:PIH]PIHTYP<>2"
Endif

#    Prise en compte des avoirs
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPI1]PIHTYP3= 1
   WFIL1 += "&[F:PIH]PIHTYP<>3"
Endif

#    Prise en compte des avoir sur facture
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPI]PIHTYP4= 1
   WFIL1 += "&[F:PIH]PIHTYP<>4"
Endif

#    Prise en compte facture/débit pour module tiers
#    Prise en compte avoir/crédit  pour module tiers
If [M:CCPI]MODT=2
  If [M:CCPI]PIHTYP1=1 & [M:CCPI]PIHTYP2=1
    WFIL1 -= "& [F:PIH]INVTYP<>1 & [F:PIH]INVTYP<>3"
  Elsif [M:CCPI]PIHTYP3=1 & [M:CCPI]PIHTYP4=1
    WFIL1 -= "& [F:PIH]INVTYP<>2 & [F:PIH]INVTYP<>4"
  Endif
Endif

#    Prise en compte des factures validées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPI1]STAO= 1
   WFIL1 += "&[F:PIH]STA<>3"
Endif

#    Prise en compte des factures non validées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPI1]STAN= 1
   WFIL1 += "&[F:PIH]STA=3"
Endif

#    Prise en compte des factures module achats/tiers
#    --> Si 1 : Non
#    --> Si 2 : Oui
If [M:CCPI]MODA<2 & [M:CCPI]MODT<2
   WFIL1 -= "& [F:PIH]ORIMOD<>6 & [F:PIH]ORIMOD<>3"
Elsif [M:CCPI]MODA<2 & [M:CCPI]MODT=2
   WFIL1 -= "& [F:PIH]ORIMOD=3"
Elsif [M:CCPI]MODA=2 & [M:CCPI]MODT<2
   WFIL1 -= "& [F:PIH]ORIMOD=6"
Elsif [M:CCPI]MODA=2 & [M:CCPI]MODT=2
   WFIL1 -= "& ([F:PIH]ORIMOD=6 | [F:PIH]ORIMOD=3)"
Endif

#    Prise en compte des factures avec niveau BAP
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPI]BAPO= 1
   WFIL2 += "&[F:PIH]PAZ<>len(mess(0,510,1))"
Endif

#    Prise en compte des factures avec niveau non BAP
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPI]BAPN= 1
   WFIL2 += "&[F:PIH]PAZ=len(mess(0,510,1))"
Endif

If [M:CCPI]NUMDEB <> ""
   WFIL3 += "&[F:PIH]NUM>=[M:CPI1]NUMDEB"
Endif
If [M:CCPI]NUMFIN <> ""
   WFIL3 += "&[F:PIH]NUM<=[M:CPI1]NUMFIN"
Endif

If [M:CCPI]BPRDATDEB <> [0/0/0]
   WFIL += "&[F:PIH]BPRDAT>=[M:CCPI]BPRDATDEB"
Endif
If [M:CCPI]BPRDATFIN <> [0/0/0]
   WFIL += "&[F:PIH]BPRDAT<=[M:CCPI]BPRDATFIN"
Endif

# Three way matching - GRNA
If [M:CCPI]TWMSTAW = 1
   WFIL += "&[F:PIH]TWMSTA<>3"  # Warning
Endif
If [M:CCPI]TWMSTAB = 1
   WFIL += "&[F:PIH]TWMSTA<>4"  # Blocked
Endif
If [M:CCPI]TWMSTAU = 1
   WFIL += "&[F:PIH]TWMSTA<>5"  # Unblocked
Endif
If [M:CCPI]TWMSTAS = 1
   WFIL += "&[F:PIH]TWMSTA<>2"  # Successful
Endif
If [M:CCPI]TWMSTAN = 1
   WFIL += "&[F:PIH]TWMSTA<>1 & [F:PIH]TWMSTA<>0"  # No match
Endif

#US 71069/16  PJT by RBA
If [M:CCPI]PJTHDEB <> ""
   WFIL3 += "&[F:PIH]PJTH>=[M:CCPI]PJTHDEB"
Endif
If [M:CCPI]PJTHFIN <> ""
   WFIL3 += "&[F:PIH]PJTH<=[M:CCPI]PJTHFIN"
Endif
#/US 71069/16  PJT by RBA

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCPI]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:PIH]NUM>=DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:PIH]BPRDAT>DEBDAT | ([F:PIH]BPRDAT=DEBDAT & [F:PIH]NUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCPI]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:PIH]NUM>FINNUM"
       When 2 : # tri par date
           WFIL += "&([F:PIH]BPRDAT>FINDAT | ([F:PIH]BPRDAT=FINDAT & [F:PIH]NUM>FINNUM))"
     Endcase
   When -2 : # retour
     Case [M:CCPI]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:PIH]NUM<DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:PIH]BPRDAT<DEBDAT | ([F:PIH]BPRDAT=DEBDAT & [F:PIH]NUM<DEBNUM))"
     Endcase
Endcase
Return

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT

Return


#############################################################
##     Etiquettes masques CONSPOH1 & CONSPOH2 & CRITPOH    ##
#############################################################
Subprog AV_CPY(VALEUR)
#-------------------------------#
# Avant zone de la société      #
#-------------------------------#
Variable Char     VALEUR
If GNBAUZ = 1 : Diszo [M]CPY,FCY : Endif
End

Subprog C_CPY(VALEUR)
#-------------------------------#
# Contrôle de la société        #
#-------------------------------#
Variable Char     VALEUR
If VALEUR <> ""
  [M]CUR = [F:CPY]ACCCUR : GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]FCY = ""
  # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
  # mkstat = 2
  # Raz [M]CUR
  [M]CUR=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Endif
End

Subprog AM_CPY(VALEUR)
#-------------------------------#
# Après modif de la société     #
#-------------------------------#
Variable Char     VALEUR
Affzo CUR, ZCPY : # On ne présise pas la classe car utilisé par 2 écrans
Raz   [M]FCY, [M]ZFCY
Affzo FCY, ZFCY
If VALEUR<>""  GSOCIETE=VALEUR : Endif
End

Subprog AS_FCY(VALEUR)
#----------------------#
# Avant saisie du site #
#----------------------#
Variable Char    VALEUR()
If GFCYDEF(6) <> ""
   GFCY = GFCYDEF(6)
Else
   GFCY = GUSRFCY(1)
Endif
Call GETDEV(GFCY) From DEVSUB
If GFINRSP<>"" GFCY=GFINRSP Else GFINRSP=GFCY : Endif
VALEUR = GFINRSP
End

Subprog C_FCY(VALEUR)
#------------------------------------------------#
# Chargement de la devise
#------------------------------------------------#
Variable Char    VALEUR()
If VALEUR <> ""
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    [M]CUR = GLOCALDEV
    [M]FCY = GFINRSP
Elsif [M]CPY = ""
    # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    # mkstat = 2
    [M]CUR=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

#-------------------------------#
# Après modif du site           #
#-------------------------------#
Subprog AM_FCY(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
  Affzo CUR, CPY, ZCPY
Endif
End

#-------------------------------#
# Avant saisie de la ligne      #
#-------------------------------#
Subprog IB_NBLIG
Raz GBOUT1
If [M:CPI2]NBLIG<>0
   If clalev([M:PIH0])=0
     GBOUT1=mess(12,107,1) : # Pièce
   Endif
Endif
End

#-------------------------------------#
# Après modification de la date début #
#-------------------------------------#
Subprog AM_BPRDATDEB(VALEUR)
Variable Date     VALEUR
#----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
If dim([M]PERCOD)>0
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]BPRDATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]BPRDATFIN=WDATE : Affzo BPRDATFIN
  Endif
Elsif VALEUR>[M]BPRDATFIN
  [M]BPRDATFIN=VALEUR
Endif
End

#-----------------------------------#
# Après modification de la date fin #
#-----------------------------------#
Subprog AM_BPRDATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)<1  End : Endif
#----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
Local Date WDATE
Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]BPRDATFIN,VALEUR,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]BPRDATDEB=WDATE : Affzo BPRDATDEB
Endif
#-----
End

#---------------------------------------------------#
#      Controle du numéro de facture fin            #
# ------------------------------------------------- #
Subprog C_NUMFIN(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]NUMDEB
   GMESSAGE = mess(44,199,1)
   mkstat = 2
Endif
End

Subprog AM_PIHTYP1(VALEUR)
#---------------------------#
# Apres-modif type facture  #
#---------------------------#
Variable Integer  VALEUR
If VALEUR=1
   [M:CCPI]PIHTYP2=1
Else
  [M:CCPI]PIHTYP2=2
Endif
End


Subprog AM_PIHTYP3(VALEUR)
#-------------------------#
# Apres-modif type avoir  #
#-------------------------#
Variable Integer  VALEUR
If VALEUR=1
  [M:CCPI]PIHTYP4=1
Else
  [M:CCPI]PIHTYP4=2
Endif
End

$AB1_NBLIG
#-----------------------------------------------#
# Avant exécution du bouton Tunnel sur factures #
#-----------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1(GLONPIH) : WCLE1=[M:CPI2]NUM(NOL)
Local Char     WCLE2(GLONPIH) : WCLE2=""
If [M:CPI2]ORIMOD(NOL)=6
  WOBJET="PIH"
Else
  WOBJET="BIS"
Endif
Return

#--------------------------#
# Avant saisie périodicité #
#--------------------------#
Subprog AS_PERCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=0 : # Jour      Ok
GMENLOC(2)=0 : # Semaine   Ok
GMENLOC(3)=1 : # Quinzaine
GMENLOC(4)=0 : # Mois      Ok
GMENLOC(5)=0 : # Trimestre Ok
GMENLOC(6)=0 : # Semestre  Ok
GMENLOC(7)=0 : # Année     Ok
GMENLOC(8)=1 : # décade
End

#-------------------------#
# Après modif périodicité #
#-------------------------#
Subprog AM_PERCOD(VALEUR)
Variable Integer VALEUR
#----- Recalcul du nbre de périodes -----#
Call CALPERNBR([M]PERCOD,VALEUR,[M]PERNBR) From TRTX3DAT
Affzo PERNBR
[M]PERCOD=VALEUR
Call AM_PERNBR([M]PERNBR)
#-----
End

#------------------------------#
# Après modif nbre de périodes #
#------------------------------#
Subprog AM_PERNBR(VALEUR)
Variable Decimal VALEUR
#----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
Local Date WDATE
Call CALDATPER([M]PERCOD,VALEUR,"+",[0/0/0],[M]BPRDATDEB,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]BPRDATFIN=WDATE : Affzo BPRDATFIN
Endif
#-----
End


#########################################################################
# Pour exécution de la validation des consultations en gestion de patch #
#########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2 End : Endif
Call VALGTC(APPLI,"CPI") From SUBGTC
End
