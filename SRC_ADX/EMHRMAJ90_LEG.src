#Test
#=>func UTI_114309_LEG.GET_LEG("PAYINDAMBA")
Funprog GET_LEG(DOSSIER)
Value Char DOSSIER
Local Char RET_LEG(5)
Local Integer COMPTEUR

#Check all active activity codes.
#Loop through the list and match with the list populated.
#There shouldnt be conflicting activity codes.

# SBA : it is better with a . ".ACTIV"
#If clalev([F:ACV])=0 : Local File =DOSSIER+".ACTIV" [ACV] : Endif
#Filter [ACV] Where FLACT = 2 and MODULE = 9 # All existing in common data - localisation activity codes
#For [ACV]ACV1
#Case [F:ACV]CODACT
#  When "KAE"    : RET_LEG = "ARE" : COMPTEUR +=1 : Call ECR_TRACE("EMHRMAJ90_LEG: KAE Active",0) From GESECRAN
#  When "KAO"    : RET_LEG = "ANG" : COMPTEUR +=1 : Call ECR_TRACE("EMHRMAJ90_LEG: KAO Active",0) From GESECRAN
#  When "KAU"    : RET_LEG = "AUS" : COMPTEUR +=1 : Call ECR_TRACE("EMHRMAJ90_LEG: KAU Active",0) From GESECRAN
#  When "KPO"    : RET_LEG = "POR" : COMPTEUR +=1 : Call ECR_TRACE("EMHRMAJ90_LEG: KPO Active",0) From GESECRAN
#  When "KFR"    : RET_LEG = "FRA" : COMPTEUR +=1 : Call ECR_TRACE("EMHRMAJ90_LEG: KFR Active",0) From GESECRAN
#  When "KZA"    : RET_LEG = "ZAF" : COMPTEUR +=1 : Call ECR_TRACE("EMHRMAJ90_LEG: KZA Active",0) From GESECRAN
#  When "KNG"    : RET_LEG = "NGA" : COMPTEUR +=1 : Call ECR_TRACE("EMHRMAJ90_LEG: KNG Active",0) From GESECRAN
#  When "KUK"    : RET_LEG = "BRI" : COMPTEUR +=1 : Call ECR_TRACE("EMHRMAJ90_LEG: KUK Active",0) From GESECRAN
#Endcase
#Next
#
#If COMPTEUR = 0# or COMPTEUR > 1
#  RET_LEG = GDOSLEG
#Endif

#Open activity code table first...
#FRLAA to do...

If clalev([F:WADV])=0 : Local File =DOSSIER+".ADOVAL" [WADV] : Endif
Read [F:WADV]ADW0 = "";"";"DOSLEG"
If !fstat
  Call ECR_TRACE("EMHRMAJ90_LEG: DOSLEG Found" - [F:WADV]VALEUR,0) From GESECRAN
  If len([F:WADV]VALEUR) >= 3
    RET_LEG = left$([F:WADV]VALEUR,3)
  Else
    RET_LEG = GDOSLEG
  Endif
Else
  Call ECR_TRACE("EMHRMAJ90_LEG: DOSLEG not found in ADOVAL",0) From GESECRAN
  RET_LEG = GDOSLEG
Endif
Close File [F:WADV]

End RET_LEG

# Another fonction to get all legislation from a folder :
#
# Call SETLEG(DOSSRC,LDOSLEG,LNBLEG) From DOSCONT

Funprog GET_LANFOLDER(DOSSIER,TLAN)
Variable Char DOSSIER
Variable Char TLAN()()
Local Integer RES
Local Integer I,NBMAX
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif

Read [ADS] DOSSIER=[L]DOSSIER
If !fstat
    NBMAX=dim([F:ADS]LAN)
    While(RES<NBMAX and [F:ADS]LAN(RES)<>"")
      TLAN(RES)=[F:ADS]LAN(RES)
      RES+=1
    Wend
Endif

End RES

