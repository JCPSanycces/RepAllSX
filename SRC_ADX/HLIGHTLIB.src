#<AdxTL>@(#)0.0.0.0 $Revision$
#-------------------------------------------------------------------------
# stylisation partielle/complète ligne
# sur 1 ou 2 tableaux d'un même écran
#-------------------------------------------------------------------------
# Paramètres HLIK:
# ABB                   # abbréviation masque
# VARABS                # bas de tableau
# STYLE                 # style à appliquer
# LIN                   # numéro de ligne à styliser
# EXCLUDE               # champs à exclure de la stylisation
# NBREX                 # nombre de champs à exclure
# VARABS2               # bas de tableau 2
# EXCLUDE2              # champs à exclure de la stylisation 2
# NBREX2                # nombre de champs à exclure 2
#-------------------------------------------------------------------------
$OPEN_HL_TABLIN
If clalev ([M:HLIK]) <= 0 : Local Mask HLIK     [HLIK] : Endif
Return

#-------------------------------------------------------------------------
# stylisation de la ligne
# toute la ligne ou champ par champ si des exclusions existent
#-------------------------------------------------------------------------
$STYLE_HL_TABLIN
If dim(GMTOSTYLEOFF) > 0
    If GMTOSTYLEOFF = 1 : Return : Endif
Endif
Chgstl ="[M:"+[M:HLIK]ABB+"]"+[M:HLIK]VARABS+"([M:HLIK]LINNUM)" With [M:HLIK]STYLE
If [M:HLIK]NBREX <> 0
    For HL = 0 To [M:HLIK]NBREX-1
        Chgstl ="[M:"+[M:HLIK]ABB+"]"+[M:HLIK]EXCLUDE(HL)+"([M:HLIK]LINNUM)" With ""
    Next HL
Endif 
Return

$STYLE_HL_TABLIN2
If dim(GMTOSTYLEOFF) > 0
    If GMTOSTYLEOFF = 1 : Return : Endif
Endif
Chgstl ="[M:"+[M:HLIK]ABB+"]"+[M:HLIK]VARABS2+"([M:HLIK]LINNUM)" With [M:HLIK]STYLE
If [M:HLIK]NBREX2 <> 0
    For HL = 0 To [M:HLIK]NBREX2-1
        Chgstl ="[M:"+[M:HLIK]ABB+"]"+[M:HLIK]EXCLUDE2(HL)+"([M:HLIK]LINNUM)" With [M:HLIK]STYLE
    Next HL
Endif 
Return
