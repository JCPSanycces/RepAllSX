#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(30)(1..5) , VALEUR(10)
PARAM(1) = nomap
PARAM(2) = ""
PARAM(3) = ""
PARAM(4) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","ARQTPAB","",3,"XYARQTPAB") From GTRAITE
End 
 
############################################################ 
# Saisie des paramètres d'un abonnement batch
############################################################ 

$ACTION
Case ACTION
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "FIN_LISTE"  : Gosub FIN_LISTE
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "AVANT_PAR"  : Gosub AVANT_PAR
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "TERMINE"    : FIN = 1
 When "SORTIE"     : Gosub SORTIE
 When Default      : # Actions de GSAISIE
  GPE = 0
  Local Integer K
  If dim([V]GSPEBATCH)>0 & GSPEBATCH<>""
   Call EXISTE_ADX("","",GSPEBATCH,K) From ORDSYS
   If K>0 : Gosub ACTION From =GSPEBATCH : Endif
  Endif
  If !GPE & dim([V]GPROBATCH)>0 & GPROBATCH<>""
   Gosub ACTION From =GPROBATCH
  Endif
Endcase
Return

$SEL_LISTE
Local Char    GROUPE(GLONABG) , DOSSIER(GLONADS) , USER(GLONAUS)
Local Char    ABONNE(GLONABA) , DES(50) , DESOK(50)
Local Integer I , OKPAR
If dim([V]GSPEBATCH)>0 : GSPEBATCH = "" : Endif
If dim([V]GPROBATCH)>0 : GPROBATCH = "" : Endif
ABONNE = PARAM(2)
If clalev([F:ABA])=0 : Local File ABATABT [ABA] : Endif
If clalev([F:ABG])=0 : Local File ABATGRP [ABG] : Endif
If clalev([F:ABT])=0 : Local File ABATTAC [ABT] : Endif
If clalev([F:ABR])=0 : Local File ABATRQT [ABR] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
Read [ABA]CODABT = ABONNE
If [F:ABA]GRP<>""
 DOSSIER = [F:ABA]DOSSIER
 USER    = [F:ABA]USER
 Gosub SETUSR From ARQTSUB
 GROUPE = [F:ABA]GRP
 Gosub VERFGRP From ARQTSUB
 Gosub RESTUSR From ARQTSUB
 If GERR : NBTEX = 0 : Return : Endif
 Read [ABG]ABG0 = [F:ABA]GRP
 NBTEX = [F:ABG]NBTAC
 For I=1 To NBTEX
  TEX(I) = [F:ABG]CODTAC(I-1)
  Read [ABT]CODTAC = TEX(I)
  Call TEXTE([F:ABT]DES,DES) From OBJDIV
  Call VERFPAR(DOSSIER,ABONNE,I,OKPAR) From SUBABA
  DESOK = string$(OKPAR=0,"("+mess(180,126,1)+")") : # Paramètres non saisis
  TEXTE(I) = num$(I)-TEX(I)-DES-DESOK
 Next I
Else
 NBTEX = 1
 TEX(1) = [F:ABA]TACHE
Endif
Return

$FIN_LISTE
[M]TACGRP = VALEUR
[M]NUMLIG = CHOIX
Return

$INIT
# On définit la boîte de critère à saisir
Local Char    DOSSIER(GLONADS) , TACHE(GLONABT) , ABONNE(GLONABA) , USER(GLONAUS)
Local Char    BPROG(GLONADC) , SPROG(GLONADC)
Local Integer K , NUMLIG , CHGUSR , KK , OKTR
Local Char    ABCRIT(GLONABR)(0..15)
DOSSIER = PARAM(1)
If DOSSIER="" : DOSSIER = nomap : Endif
ABONNE  = PARAM(2)
TACHE   = PARAM(3)
NUMLIG  = val(PARAM(4))
USER    = PARAM(5)
Raz BCRIT , BPROG , SPROG , CHGUSR
If clalev([F:AXX])>0 : Close Local File [AXX] : Endif
If clalev([F:ABT])=0 : Local File ABATTAC  [ABT] : Endif
If clalev([F:ABR])=0 : Local File ABATRQT  [ABR] : Endif
If clalev([F:ABP])=0 : Local File ABATPAR  [ABP] : Endif
If clalev([F:ABA])=0 : Local File ABATABT  [ABA] : Endif
If clalev([F:ABD])=0 : Local File ABATABTD [ABD] : Endif
Local File =DOSSIER+".ATEXTE"
Local Char    SAVPAR(250)(1..dim(PARAM))
For I=1 To dim(PARAM)
 SAVPAR(I) = PARAM(I)
Next I
Read [ABT]CODTAC = TACHE
If !fstat & [F:ABT]FONCTION<>""
 CHGUSR = 1
 Gosub SETUSR From ARQTSUB
 Gosub VERFTAC From ARQTSUB
 If GERR : Return : Endif
 Read [AFC]CODINT = [F:ABT]FONCTION
 If !fstat
  If dim([V]GCHGENV)>0
   If dim([F:AFC]DEPENV)>0 & [F:AFC]DEPENV=2 : # Chgt environnement
    GCHGENV=2 
   Elsif dim([F:AFC]FCYENV)>0 & [F:AFC]FCYENV=2
    GCHGENV=1
   Else
    GCHGENV=0
   Endif
  Endif
  For I=0 To [F:AFC]NBVAR-1
   If [F:AFC]VALEUR(I)<>"#"
    Assign [F:AFC]VARIA(I) With evalue([F:AFC]VALEUR(I))
   Else
    Assign [F:AFC]VARIA(I) With [F:ABT]PARAM
   Endif
  Next I
  Raz PARAM
  For I=1 To dim([F:AFC]VALPAR)
   If [F:AFC]VALPAR(I-1)<>""
    PARAM(I) = num$(evalue([F:AFC]VALPAR(I-1)))
   Endif
  Next I
  If [F:AFC]ACTION<>""
   Read [ACT]ACTION = [F:AFC]ACTION
   If !fstat
    BCRIT = [F:ACT]PARAM4
    BPROG = [F:ACT]CODTRT
    SPROG = [F:ACT]SPETRT
    Case [F:ACT]PARAM3
     When 3,4 : TYPPRG = [F:ACT]PARAM3
    Endcase
   Endif
  Endif
 Endif
Endif
GBATCH = 1
If BCRIT<>"" & (BPROG<>"" | SPROG<>"")
 Call SETMASK(BCRIT,ABCRIT) From ARQTPAR
 ACTION = "OUVRE_BATCH" : Gosub ACTIONB
Else
 ABCRIT = ""
Endif
GPROBATCH = BPROG
GSPEBATCH = SPROG
GSTATUT = GSTAOK : # Au cas où pas de paramètres à saisir
Return

$ERR
If errn<>39 : # Etiquette inexistante
 GMESSAGE = num$(errn)-":"-errmes$(errn)-errm-errp+"("+num$(errl)+")"
 Call ERREUR(GMESSAGE) From GESECRAN
 GMESSAGE = ""
Endif
Resume

$SORTIE
If CHGUSR
 Gosub RESTUSR From ARQTSUB
Endif
If dim([V]GCHGENV)>0 : GCHGENV=0 : Endif
GPROBATCH = ""
GSPEBATCH = ""
Return

$AVANT_PAR
If sum(ABCRIT)<>""
 K = 0
 For I=0 To dim(ABCRIT)-1
  If ABCRIT(I)<>"" & evalue("clalev([M:"+ABCRIT(I)+"])")>0
   K = 1 : Break
  Endif
 Next I
 If K
  If clalev([F:ABD])=0 : Local File ABATABTD [ABD] : Endif
  Default File [F:ABD]
  Filter [F:ABD] Where CODABT=[L]ABONNE & CODTAC=[L]TACHE & LIG=[L]NUMLIG
  Read [ABD]ABD0 First
  If !fstat : GCONSDIA = -1 : Endif
  Call GETPAR(ABCRIT) From REQUETES
  Filter [F:ABD]
 Endif
Endif
Return

$INIT_DIA
ACTION = "INIT_DIA" : Gosub ACTIONB
# Chargement de la boite
If sum(ABCRIT)<>""
 If clalev([F:ABD])=0 : Local File ABATABTD [ABD] : Endif
 Default File [F:ABD]
 Filter [F:ABD] Where CODABT=[L]ABONNE & CODTAC=[L]TACHE & LIG=[L]NUMLIG
 Read [ABD]ABD0 First
 If !fstat : GCONSDIA = -1 : Endif
 Call GETPAR(ABCRIT) From REQUETES
 Filter [F:ABD]
Endif
Return

$ACTIONB
GPE = 0
If dim(SPROG)>0 & SPROG<>""
 Call EXISTE_ADX("","",SPROG,K) From ORDSYS
 If K>0 : Gosub ACTION From =SPROG : Endif
Endif
If !GPE & dim(BPROG)>0 & BPROG<>""
 Gosub ACTION From =BPROG
Endif
Return    

$CONTROLE
ACTION = "CONT_BATCH" : Gosub ACTIONB
For I=1 To dim(PARAM)
 PARAM(I) = SAVPAR(I)
Next I
Return

$EXEC
If GSTATUT=GSTAOK
 OKTR = 0
 For I=0 To dim(ABCRIT)-1
  If ABCRIT(I)<>""
   OKTR = 1
   Break
  Endif
 Next
 If OKTR
  Default File [ABD]
  Call DEBTRANS From GLOCK
  Gosub TR1
 Endif
Endif
Return

$TR1
GOK = 1
Trbegin [ABD]
 Delete [F:ABD] Where  CODABT=ABONNE & CODTAC=TACHE & LIG=NUMLIG
 If fstat
  GOK = 0 : Call RSTA("ABD",ABONNE-TACHE-num$(NUMLIG)) From GLOCK : Goto AB_TR1
 Endif
 Call ECRIT(ABCRIT,ABONNE,TACHE,NUMLIG,0) From REQUETES
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
