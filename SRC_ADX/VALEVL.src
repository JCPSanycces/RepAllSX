#<AdxTL>@(#)1.0.0.0 $Revision$
If 1
  Local Char PARAM(10)(1..3) , VALEUR(10)
  PARAM(1) = "CYCLO2"
  PARAM(2) = "2"
  Call TRAITE_CHAR(VALEUR,PARAM,"","VALEVL","",2,"") From GTRAITE
  Infbox "PARAM(3)="+PARAM(3)
Else
  Call TR_EXEC2("CYCLO2",2)
  If GERR
     If GMESSAGE<>""
        Call ERREUR(GMESSAGE) From GESECRAN
        GMESSAGE=""
     Endif
     GERR=0
  Else
     Infbox "GOK="+num$(GOK)
  Endif
Endif
End

$ACTION
Case ACTION
  When "INIT"        : Gosub INIT
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "SORTIE"      : Gosub SORTIE

  When "BOITE"       : Gosub BOITE
Endcase
Return

############################################################################################
## Validate a BOM version in development to change it to a BOM version available to use
## GH 03/2015
############################################################################################

$INIT
Local Char    ITM([V]GLONITM)
Local Integer TYPALT
Local Integer TRC

ITM    = [L]PARAM(1)
TYPALT = val([L]PARAM(2))
[L]PARAM(3)="0"

Gosub VERIF
If GERR=-1
   GMESSAGE=mess(14,195,1)-[L]ITM+"\"+GMESSAGE : # Item
   GERR=1
Endif
If GERR : FIN=1 : Return : Endif

Call TITFNC("VALEVL",TIT) From CONTOBJ
TIT = mess(153,198,1)-[L]ITM-"\"+TIT-[F:EVL]ECCVALMAJ-[F:EVL]ECCVALMIN : # BOM
Return

$VERIF
If !clalev([F:EVL])  : Local File ECCVAL    [EVL]  : Endif
If !clalev([F:ECS])  : Local File ECCSTA    [ECS]  : Endif
If !clalev([F:ITM])  : Local File ITMMASTER [ITM]  : Endif
If !clalev([F:TBO])  : Local File TABBOMALT [TBO]  : Endif
If !clalev([F:EVL2]) : Local File ECCVAL    [EVL2] : Endif
If !clalev([F:BOD])  : Local File BOMD      [BOD]  : Endif

Local Integer SEQ, ALT1, ALT2, NIV
Local Char    FCY1(GLONFCY)
Local Date    STRDAT1
Local Char    SAVFONCION([V]GLONAFC)

SAVFONCTION = GFONCTION

Read [ITM]ITM0 = [L]ITM
If !fstat
   NIV = func ECCLIB.NBRCPN([L]ITM)
Endif
If NIV<1
   GERR=1 : GMESSAGE = mess(153,187,1)-[L]ITM : # Versions not managed on this product
   Return
Endif

Filter [EVL] Where ITMREF=[L]ITM & ECCTYP=[L]TYPALT & USESTA=2
Read [EVL]EVL0 Last
Filter [EVL]
If !fstat : ALT2 = [F:EVL]BOMALT
Else      : ALT2 = evalue("[F:ITM]ECCBOMALT"+num$([L]TYPALT)+"(1)")
Endif
If ALT2=0
   GERR=-1 : GMESSAGE = mess(309,193,1)-"("+mess(2,240,1)+")" : # BOM code not defined
   Return
Endif

Filter [EVL] Where ITMREF=[L]ITM & ECCTYP=[L]TYPALT
Read [EVL]EVL0 Last
Filter [EVL]
If fstat>2
   GERR=-1 : GMESSAGE = mess(308,193,1) : # Non existing version
   Return
Elsif [F:EVL]USESTA=2
   # Last version ... Available to use
   GERR=-1 : GMESSAGE = mess(311,193,1)-[F:EVL]ECCVALMAJ-[F:EVL]ECCVALMIN-":"-mess(2,240,1)
   Return
Endif
[L]SEQ  = [F:EVL]ECCSEQ
[L]ALT1 = [F:EVL]BOMALT
[L]STRDAT1 = [F:EVL]STRDAT

If [L]ALT1=[L]ALT2
   GERR=-1 : GMESSAGE = mess(314,193,1)-"("+num$([L]ALT1)+")"-":"-mess(1,240,1)-","-mess(2,240,1) :  # Same BOM codes
   Return
Endif

# BOM lines of the version to be validated
For [BOD] Where ITMREF=[L]ITM & ECCVALMAJ<>""
&             & (BOMSTRDAT <= [F:EVL]STRDAT)
&             & (BOMENDDAT >= [F:EVL]STRDAT | BOMENDDAT = [0/0/0])
    If dim([F:BOD]UPDBOMNUM)=1 & [F:BOD]UPDBOMNUM<>""
       Read [EVL2]EVL1=[F:BOD]CPNITMREF;[F:BOD]ECCVALMAJ;[F:BOD]ECCVALMIN;[F:BOD]BOMALTTYP
       If !fstat & [F:EVL2]USESTA=1
          # Validate first BOM
          GERR=1 : GMESSAGE=mess(321,193,1)-[F:BOD]CPNITMREF
          Break
       Endif
    Else
      Look [EVL2]EVL1 =[F:BOD]CPNITMREF;[F:BOD]ECCVALMAJ;[F:BOD]ECCVALMIN;4
      If fstat>2
        Filter [EVL2] Where ECCTYP>1
        Look [EVL2]EVL1(3) =[F:BOD]CPNITMREF;[F:BOD]ECCVALMAJ;[F:BOD]ECCVALMIN
        Filter [EVL2]
        If fstat<=2
           # Validate first BOM
           GERR=1 : GMESSAGE=mess(321,193,1)-[F:BOD]CPNITMREF
           Break
        Endif
      Endif
    Endif
Next
If GERR : Return : Endif

Read [TBO]TBO0 = [L]TYPALT;[L]ALT1
If fstat
   GERR=1 : GMESSAGE = num$([L]ALT1)-":"-mess(154,193,1) : # Non existing BOM code
   Return
Endif
[L]FCY1 =[F:TBO]FCY

Read [TBO]TBO0 = [L]TYPALT;[L]ALT2
If fstat
   GERR=1 : GMESSAGE = num$([L]ALT2)-":"-mess(154,193,1) : # Non existing BOM code
   Return
Endif
If [L]FCY1<>[F:TBO]FCY
   GERR=-1 : GMESSAGE = mess(310,193,1) : # Incompatible sites between BOM codes for versioning
   Return
Endif

#GPROFIL="GL"
GFONCTION="VALEVL"
Call AUTORIS From EXEFNC
If GNBAUZ=0
  GERR=1
Elsif GUSRFCY(1)<>"\"
  If [L]FCY1<>""
     If !find([L]FCY1,GUSRFCY(1..GNBAUZ)) : GERR=1 : Endif
  Else
     # At least one authorized site (for sales, production, stock) according to the BOM type (commercial, production, SST)
     Case [L]TYPALT
       When 1 : CRITFCY = "SALFLG=2"
       When 2 : CRITFCY = "MFGFLG=2"
       When 3 : CRITFCY = "WRHFLG=2"
     Endcase
     GERR=1
     Local File FACILITY [FCY]
     For [FCY]FCY0 Where evalue(CRITFCY)
         If find([F:FCY]FCY,GUSRFCY(1..GNBAUZ)) : GERR=0 : Break : Endif
     Next
  Endif
Endif
If GERR
   GMESSAGE=mess(1,123,1) : # Unauthorized function
   Return
Endif

# lock management
If !func ECCLIB.LCKBOH([L]ITM,[L]ALT1,[L]TYPALT)
   GERR=1 : GMESSAGE=mess([L]TYPALT,2059,1)-[L]ITM-num$([L]ALT1)+"\"+mess(10,100,1) : Return
Elsif !func ECCLIB.LCKBOH([L]ITM,[L]ALT2,[L]TYPALT)
   GERR=1 : GMESSAGE=mess([L]TYPALT,2059,1)-[L]ITM-num$([L]ALT2)+"\"+mess(10,100,1) : Return
Endif
Return

#############################################################

$SORTIE
#GPROFIL="ADMIN"
GFONCTION=SAVFONCTION
Call AUTORIS From EXEFNC

Call DELOCK("BOH") From GLOCK : # Call DELOCK("BOH\") From GLOCK # Issue 118592 GH 20/09/2016
Return

#############################################################

$CONTROLE
Filter [BOD] Where BOMSTRDAT=[L]STRDAT1 | BOMENDDAT=[L]STRDAT1-1
Look [BOD]BOD4(3) = [L]ALT1;[L]ITM;[L]TYPALT
Filter [BOD]
If fstat>2
   OK=1 : Call OUINON(mess(322,193,1)+"\"+mess(172,100,1),OK) From GESECRAN : #  Version in development with no revised line
   If OK<>2 : FIN=1 : Return : Endif
Endif
Return

#############################################################

$EXEC
GOK=1
If ![V]GSERVEUR & GTRACE=""
   Local Char TITTRC(200)
   Call TITFNC("VALEVL",TITTRC) From CONTOBJ
   TITTRC = mess(153,198,1)-[L]ITM-":"-TITTRC-[F:EVL]ECCVALMAJ-[F:EVL]ECCVALMIN : # Nomenclature
   Call OUVRE_TRACE(TITTRC) From LECFIC
   TRC=1
Endif
Call TR_EXEC1([L]ITM,[L]TYPALT,[L]ALT1,[L]ALT2,[L]SEQ)
If GOK<1 or GERR=1 : SAI=1 : Endif
If TRC
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
Endif
If SAI=1 : SAI=0 : Return : Endif

[L]PARAM(3) = num$([L]SEQ)
Return

#############################################################
## Transaction
#############################################################

Subprog TR_EXEC1(ITM,TYPALT,ALT1,ALT2,SEQ)
Value Char    ITM()
Value Integer TYPALT
Value Integer ALT1, ALT2
Value Integer SEQ

Local Char ABREV(GLONAOB), TRTGBM(GLONADC)

[L]TRTGBM="VALEVL"
[L]ABREV="BOD"
Case [L]TYPALT
 When 1 : GFONBOD="BOMC"
 When 2 : GFONBOD="BOMP"
 When 3 : GFONBOD="BOMS" : [L]ABREV="BOS"
Endcase

If dim([V]GDATEREF)=1
   Local Date SAVDATEREF
   [L]SAVDATEREF = [V]GDATEREF
Endif

Gosub DEFVAR From OBJSIM

Call DEBTRANS From GLOCK
Gosub TR

Gosub RESTGLO From OBJSIM

If dim([V]GDATEREF)=1 & dim([L]SAVDATEREF)=1
   [V]GDATEREF=[L]SAVDATEREF
Endif
End

$TR
GOK=1
Trbegin [BOH], [BOD], [EVL]

  If [L]SEQ=1
     Gosub TR1
  Else
     Gosub TR2
  Endif
  If GOK>0
     Gosub ANNULE
  Endif

If GOK<1
  Rollback
  If GOK<0
   Call ROLL From GLOCK
   If !GROLL : Goto TR : Endif
  Endif
  Return
Endif
Commit
Return

#############################################################
## validation of the first version
#############################################################
## Duplication (header + lines + text) of the first BOM in development
## to a new one available to use with change of BOM code
## + Deletion of the BOM in development
$TR1
Read [BOH]BOH0 = [L]ITM;[L]ALT1;[L]TYPALT
If fstat
   GOK=0 : Call RSTA("BOH",[L]ITM-num$([L]ALT1)-num$([L]TYPALT)) From GLOCK : Return
Endif
#
GDATEREF=[0/0/0]
Gosub CHARGE From OBJSIM
#
[M:BOH0]BOMALT = [L]ALT2
[M:BOH0]USESTA = 2
[M:BOH0]NEWALT = [L]ALT2
#
Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
[V]GREP="D"
[L]ACTION="RAZDUP" : Gosub ACTION From GOBJSUB
If [V]GOK>0
   Gosub CREATION From OBJSIM
Endif
Setmode
If GOK<0 : Return : Endif

Gosub CHANGE
If GOK<0 : Return : Endif
Return

#############################################################
## validation of the other versions
#############################################################
## Deletion of all lines of the BOM available to use
## + Values transfer (header + lines + texts) from the BOM in development to the BOM available to use
## + Deletion of the BOM in development

$TR2
Read [BOH]BOH0 = [L]ITM;[L]ALT2;[L]TYPALT
If fstat
   GOK=0 : Call RSTA("BOH",[L]ITM-num$([L]ALT2)-num$([L]TYPALT)) From GLOCK : Return
Endif

## BOM available to use : loading and deletion of all lines
GDATEREF=[0/0/0]
Gosub CHARGE From OBJSIM
#
[V]GREP="M"
[M:BOD1]NBLIG=0 : # all lines are deleted
If ABREV="BOS"
    [M:BOS2]NBLIG=0
Endif
Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
Gosub MODIF From OBJSIM
Setmode
If GOK<1 : Return : Endif

## BOM available to use : values transfer from the BOM in development
Gosub CHANGE
If GOK<0 : Return : Endif

Read [BOH]BOH0 = [L]ITM;[L]ALT1;[L]TYPALT
If fstat
   GOK=0 : Call RSTA("BOH",[L]ITM-num$([L]ALT1)-num$([L]TYPALT)) From GLOCK : Return
Endif
GDATEREF=[0/0/0]
Gosub CHARGE From OBJSIM
#
CLECUR1 = num$([L]ALT2)
[M:BOH0]BOMALT = [L]ALT2
[M:BOH0]USESTA = 2
[M:BOH0]NEWALT = [L]ALT2
#
# all lines are supposed to be new lines
Raz [M:BOD1]CREFLG, [L]MAXLIG
If ABREV="BOS"
   Raz [M:BOS2]CREFLG, [L]MAXLIG2
Endif
#
[V]GREP="M"
Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
Gosub MODIF From OBJSIM
Setmode
Return

#############################################################

$CHANGE
Local Date    DATF
Local Char    VMAJ(GLONICVVAL), VMIN(GLONICVVAL)
Local Integer I

# Version : change of routing and use status
Readlock [EVL]EVL0 = [L]ITM;[L]SEQ;[L]TYPALT
If fstat=1
     GOK=-1 : GLOCK="$ECCVAL"-[L]ITM-num$([L]SEQ)-num$([L]TYPALT) : Return
Elsif fstat
   GOK=0 : Call RSTA("EVL",[L]ITM-num$([L]SEQ)-num$([L]TYPALT)) From GLOCK : Return
Endif
[F:EVL]BOMALT = [L]ALT2
[F:EVL]USESTA = 2 : # available to use
Rewrite [EVL]
If fstat
   GOK=0 : Call FSTA("EVL") From GLOCK : Return
Endif

VMAJ = [F:EVL]ECCVALMAJ
VMIN = [F:EVL]ECCVALMIN
DATF = [F:EVL]STRDAT
If [L]SEQ>1
   # change end date of the last version to the day before the starting of the new version
   Readlock [EVL]EVL0 = [L]ITM;[L]SEQ-1;[L]TYPALT
   If fstat=1
      GOK=-1 : GLOCK="$ECCVAL"-[L]ITM-num$([L]SEQ-1)-num$([L]TYPALT) : Return
   Elsif fstat
      GOK=0 : Call RSTA("EVL",[L]ITM-num$([L]SEQ-1)-num$([L]TYPALT)) From GLOCK : Return
   Endif
   [F:EVL]ENDDAT = [L]DATF-1

   # derogation calculation according to WO/EO orders with starting date >= revision date
   [F:EVL]EXNDAT = [0/0/0] : [F:EVL]EXNFLG=1 : # par sécurité
   If [L]TYPALT=2 : I=10  : # Production     => WO
   Else           : I=36  : # Subcontracting => EO
   Endif
   If !clalev([F:ORD]) : Local File ORDERS [ORD] : Endif
   Columns [ORD] (STRDAT)
   For [ORD] Where ITMREF=[L]ITM & ECCVALMAJ=[F:EVL]ECCVALMAJ & ECCVALMIN=[F:EVL]ECCVALMIN & VCRTYP=I
&                & WIPSTA<>3 & STRDAT>[F:EVL]ENDDAT
       If [F:ORD]STRDAT>[F:EVL]EXNDAT
          [F:EVL]EXNDAT=[F:ORD]STRDAT
      Endif
   Next
   Columns [ORD]
   If [F:EVL]EXNDAT<>[0/0/0] : [F:EVL]EXNFLG=2 : Endif

   Rewrite [EVL]
   If fstat
     GOK=0 : Call FSTA("EVL") From GLOCK : Return
   Endif
Endif

# Stock : creation of the new version available to use in tables ECCSTA & ECCVAL
If DATF > date$
   I = 4 : # to active
Else
   I = 2 : # active
Endif
Call CREEVL4([L]ITM, [L]VMAJ, [L]VMIN, I) From ECCLIB
If GOK<1 : Return : Endif

Return

$ANNULE
## Text transfer
Call SUPTEXTRA("BOM","BOMDESAXX",[L]ITM+"~"+num$([L]ALT2),num$([L]TYPALT)) From ATEXTRA
If GOK<1 : Return : Endif
Call  CHGTEXTRA("BOM","BOMDESAXX",[L]ITM+"~"+num$([L]ALT1),num$([L]TYPALT)
&                                ,[L]ITM+"~"+num$([L]ALT2),num$([L]TYPALT)) From ATEXTRA
If GOK<1 : Return : Endif

##  Deletion of the BOM in developement
Read [BOH]BOH0 = [L]ITM;[L]ALT1;[L]TYPALT
If !fstat
   GDATEREF=[0/0/0]
   Gosub CHARGE From OBJSIM
   #
   [V]GREP="A" : [M:BOH0]NEWALT=[L]ALT2
   Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
   Call ANUCOD([L]ABREV,[L]CLECUR1,[L]CLECUR2,[L]OK) From GOBJACT
   If ![L]OK & GOK>0 : GOK=0 : Endif
   If GOK>0
      Call ANNULE([L]ABREV,[L]CLECUR1,[L]CLECUR2) From GOBJTXT
   Endif
   Setmode
Endif
Return

$BOITE
Case [L]TYPALT
 When 1 : GBOITE="OBOD"
 When 2 : GBOITE="OBODP"
 When 3 : GBOITE="OBODS"
Endcase
Return

#**----------------------------------------------------------------<br/>
#* Validate a BOM version in development to change it to a BOM version available to use
#**<br/>----------------------------------------------------------------<br/>
#* @param ITM    = Product
#* @param TYPALT = Alternative type (menu 224)
#**<br/>----------------------------------------------------------------
#*!

Subprog TR_EXEC2(ITM,TYPALT)
Value Char    ITM()
Value Integer TYPALT

Local Integer TRC

# INIT
GERR=0 : GMESSAGE="" : GOK=1
Gosub VERIF
If GERR=-1
   GMESSAGE=mess(14,195,1)-[L]ITM+"\"+GMESSAGE : # Article
   GERR=1
Endif
If GERR : Goto FIN2 : Endif

If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif

If ![V]GSERVEUR & GTRACE=""
   Local Char TITTRC(200)
   Call TITFNC("VALEVL",TITTRC) From CONTOBJ
   TITTRC = mess(153,198,1)-[L]ITM-":"-TITTRC-[F:EVL]ECCVALMAJ-[F:EVL]ECCVALMIN : # Nomenclature
   Call OUVRE_TRACE(TITTRC) From LECFIC
   TRC=1
Endif
Call TR_EXEC1([L]ITM,[L]TYPALT,[L]ALT1,[L]ALT2,[L]SEQ)
If TRC
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
Endif

$FIN2
Gosub SORTIE
End

