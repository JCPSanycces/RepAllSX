#<AdxTL>@(#)0.0.0.0 $Revision$
$GENLEDGENT
Wrseq '<GeneralLedgerEntries xmlns="urn:OECD:StandardAuditFile-Tax:PT_'+[L]SAFTVER+'">' Using [SAFT]

Link [F:HAE] With [F:DAE]DAE0(2)=[F:HAE]TYP;[F:HAE]NUM,[F:GAC]GAC0=[L]COA;[F:DAE]ACC, [F:CLS]CLS0=[L]LEG;[F:GAC]CLSCOD  As [CTB]
&  Where  [F:HAE]CAT = 1 & [F:HAE]ACCDAT >= [L]STRDATE & [F:HAE]ACCDAT  <= [L]ENDDATE &
&  [F:DAE]LEDTYP=[L]LEDT & [F:HAE]CPY=[L]SOC & [F:CLS]TYP=1 & [F:HAE]STA=2
&  Order By Key SKEY = [F:HAE]JOU;[F:HAE]TYP;[F:HAE]NUM;[F:DAE]LIN Asc
[L]GLENUMOFENTRI = 0
[L]GLETOTDEBIT = 0
[L]GLETOTCREDIT = 0
[L]GLNUM     = "XXXX"
[L]GLTYP     = "XXXX"

Gosub RAZ_GLEH From SAFTGENPOR
For [F:CTB]
  Call LEC_JOU_LEG([L]LEG,[F:HAE]JOU,STAT) From TRTLECLEG
  Call LEC_GTE_LEG([L]LEG,[F:HAE]TYP,STAT) From TRTLECLEG

  If [F:GTE]PER = 2 : Goto  NEXTGLE1 : Endif

  If [F:DAE]SNS = 1
    If [F:DAE]AMTLED > 0
      [L]GLETOTDEBIT += abs([F:DAE]AMTLED)
    Else
      [L]GLETOTCREDIT += abs([F:DAE]AMTLED)
    Endif
  Else
    If [F:DAE]AMTLED > 0
      [L]GLETOTCREDIT += abs([F:DAE]AMTLED)
    Else
      [L]GLETOTDEBIT += abs([F:DAE]AMTLED)
    Endif
  Endif
  If [F:HAE]NUM <> [L]GLNUM | [F:HAE]TYP <> [L]GLTYP
    [L]GLENUMOFENTRI += 1
  Endif

  [L]GLNUM     = [F:HAE]NUM
  [L]GLTYP     = [F:HAE]TYP

  $NEXTGLE1
Next
#WRITE_GLE_HEADER
AUXTAGNAM = 'NumberOfEntries'            : AUXTAGVAL = num$([L]GLENUMOFENTRI)    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'TotalDebit'                 : AUXTAGVAL = ctrans(vireblc(format$("N20.2",ar2([L]GLETOTDEBIT)),4),",",".")    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'TotalCredit'                : AUXTAGVAL = ctrans(vireblc(format$("N20.2",ar2([L]GLETOTCREDIT)),4),",",".")    : Gosub WRITETAG From SAFTGENPORTG

[L]GLJOURN = "XXXX"
[L]GLNUM   = "XXXX"
[L]GLTYP   = "XXXX"

For [F:CTB]
  Call LEC_JOU_LEG([L]LEG,[F:HAE]JOU,STAT) From TRTLECLEG
  Call LEC_GTE_LEG([L]LEG,[F:HAE]TYP,STAT) From TRTLECLEG

  [L]GLE = 0
  GPOINT  = "SAFTPTGLE" : Gosub ENTREE From EXEFNC
  If [L]GLE = 1 : Goto NEXTGLE2 : Endif

  If [F:GTE]PER = 2 : Goto  NEXTGLE2 : Endif

  # Issue X3-27059 - 2017-04-04 by MANOW/MRDAB - small refactoring
  Local Integer NOTBAL : [L]NOTBAL = 0
  Link [F:HA2] With [F:DA2]DAE0(2)=[F:HA2]TYP;[F:HA2]NUM,[F:GA2]GAC0=[L]COA;[F:DA2]ACC, [F:CL2]CLS0=[L]LEG;[F:GA2]CLSCOD As [CT2]
& Where [F:CL2]TYP=1 & [F:HA2]NUM=[F:HAE]NUM
  For [F:CT2]
   [L]NOTBAL = 1
   Break
  Next
  Close File [F:CT2]
  If [L]NOTBAL = 0 : Goto NEXTGLE2 : Endif
  # End Issue X3-27059

  If [F:HAE]JOU <> [L]GLJOURN
    If [L]GLJOURN <> "XXXX"
      # Issue X3-31864 - 2017-04-06 by MRDAB: end Lines section with Transaction section
      Gosub CLOSE_TRANSACTION
      # End issue X3-31864

      Wrseq '</Journal>' Using [SAFT]
    Endif

    #ALIM_GLE_JOURNAL
    Gosub RAZ_GLEJ From SAFTGENPOR
    [L]GLEJOURNALID = [F:HAE]JOU
    [L]GLEJDESCRIPT = [F:JOU]DES
    If [L]GLEJDESCRIPT = "" : [L]GLEJDESCRIPT = "Diário " + [F:HAE]JOU : Endif

    #WRITE_GLE_JOURNAL
    Wrseq '<Journal>' Using [SAFT]
    AUXTAGNAM = 'JournalID'            : AUXTAGVAL = [L]GLEJOURNALID    : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = 'Description'          : AUXTAGVAL = [L]GLEJDESCRIPT    : Gosub WRITETAG From SAFTGENPORTG
    [L]RECSWRI += 1
  Endif

  If ([F:HAE]NUM <> [L]GLNUM | [F:HAE]TYP <> [L]GLTYP)
    If [L]GLNUM <> "XXXX" & [L]GLTYP <> "XXXX" & [F:HAE]JOU = [L]GLJOURN
      # Issue X3-31864 - 2017-04-06 by MRDAB: end Lines section with Transaction section
      Gosub CLOSE_TRANSACTION
      # End issue X3-31864

    Endif

    #ALIM_GLE_TRANSID
    Gosub RAZ_GLEL From SAFTGENPOR
    Case [F:GTE]PER
      When 3       : [L]GLEPERIOD = 16         : [L]GLETRANSTYPE = "A"
      When Default
        #Issue 86039 – 2018-04-17  by MADOR - PT certification - SAF-T Period tag needs to match with the fiscal period
        [L]GLEPERIOD = func SAFTGENPOR.GET_PERIOD_NUMBER([F:HAE]CPY, [F:HAE]ACCDAT)
        [L]GLETRANSTYPE = "N"
        #Isssue end
    Endcase
    [L]GLETRANSACDT = format$("D:YYYY[-]MM[-]DD",[F:HAE]ACCDAT)
    [L]GLESOURCEID  = [F:HAE]CREUSR
    If [F:HAE]TYP = 'STK'
      [L]GLEMDESCRIPT = 'Apuramento de Resultados'
    Else
      [L]GLEMDESCRIPT = [F:HAE]DESVCR
    Endif
    If [L]GLEMDESCRIPT = "" : [L]GLEMDESCRIPT = "Documento " + [F:HAE]NUM : Endif

    If [L]TYPONDAN = "2"
      If len([F:HAE]TYP+ctrans([F:HAE]NUM,"_-.\/",""))>20
        [L]GLEDOCARCNUM = ctrans([F:HAE]NUM,"_-.\/","")
      Else
        [L]GLEDOCARCNUM = [F:HAE]TYP+ctrans([F:HAE]NUM,"_-.\/","")
      Endif
    Else
      [L]GLEDOCARCNUM = ctrans([F:HAE]NUM,"_-.\/","")
    Endif
    #Issue X3-31864 - 2017-05-05 by VAVIL: na V04 o formato é [YYYY/MM/DD]
    If [L]ISSAFTVERCURRENT
      [L]GLEGLPOSTDAT = format$("D:YYYY[-]MM[-]DD",[F:HAE]ACCDAT)
    Else
      [L]GLEGLPOSTDAT = format$("D:YYYY[-]MM[-]DD",[F:HAE]ACCDAT)+"T00:00:00"
    Endif
    #Issue end

    #[L]GLEGLPOSTDAT = format$("D:YYYY[-]MM[-]DD",[F:HAE]ACCDAT)+"T00:00:00"
    [L]GLETRANSACID = [L]GLETRANSACDT + " " + [L]GLEJOURNALID + " " + [L]GLEDOCARCNUM
    Read [F:SIH]SIH0 = [F:HAE]NUM
    If !fstat
      [L]GLEGLCUSTOID = [F:SIH]BPR
      Read [F:SIV]SIV0 = [F:HAE]NUM
      If !fstat
        If [F:SIV]BPIEECNUM <> ""
          Read [F:BPR]BPR0 = [F:SIV]BPCINV
          If !fstat
            If [F:SIV]BPIEECNUM <> [F:BPR]EECNUM & [F:SIV]BPIEECNUM <> ""
              [L]GLEGLCUSTOID = "D"+toupper([F:SIV]BPIEECNUM)
            Endif
          Endif
        Endif
      Endif
      Read [F:BPC]BPC0 = [F:SIH]BPR
      If ([F:BPR]LEGETT = 2 & [F:BPR]CRY = "PT" & [F:BPC]BPCTYP =2) & ([F:SIV]BPIEECNUM="" |[F:SIV]BPIEECNUM="PT999999990")  : [L]GLEGLCUSTOID = "Consumidor final" : Endif
    Elsif [F:HAE]TYPDUD <> 3
      Read [F:PIH]PIH0 = [F:HAE]NUM
      If !fstat
        [L]GLEGLSUPPLID = [F:PIH]BPR
      Endif
    Else
      If find(left$([F:HAE]REFINT,3),"FRM")
        Filter [F:PYH] Where [F:PYH]FRMNUM = [F:HAE]BPRVCR
        For [F:PYH]
          If !fstat and [F:PYH]SNS = 2
           [L]GLEGLCUSTOID = [F:PYH]BPR
          Endif
          Read [F:BPC]BPC0 = [F:PYH]BPR
          If ([F:BPR]LEGETT = 2 & [F:BPR]CRY = "PT" & [F:BPC]BPCTYP =2) & ([F:SIV]BPIEECNUM="" |[F:SIV]BPIEECNUM="PT999999990")  : [L]GLEGLCUSTOID = "Consumidor final" : Endif
        Next
        Filter [F:PYH]
      Else
        Read [F:PYH]PYH0 = vireblc(right$([F:HAE]REFINT,4),2)
        If !fstat and [F:PYH]SNS = 2
          [L]GLEGLCUSTOID = [F:PYH]BPR
        Endif
        Read [F:BPC]BPC0 = [F:PYH]BPR
        If ([F:BPR]LEGETT = 2 & [F:BPR]CRY = "PT" & [F:BPC]BPCTYP =2) & ([F:SIV]BPIEECNUM="" |[F:SIV]BPIEECNUM="PT999999990")  : [L]GLEGLCUSTOID = "Consumidor final" : Endif
      Endif
    Endif

    # Issue X3-31864 - 2017-04-06 by MRDAB: start Transaction section with new Lines section
    Gosub OPEN_TRANSACTION
    # End issue X3-31864
  Endif

  Gosub RAZ_GLED From SAFTGENPOR

  [L]GLEGLRECORDI = [F:DAE]LIN
  # Issue X3-27059 - 2017-04-04 by MANOW/MRDAB
  If [L]SAFTDET = 2
    [L]GLEGLACCOUNT = [F:DAE]ACC + [F:DAE]BPR
  Else
    [L]GLEGLACCOUNT = [F:DAE]ACC
  Endif
  # End Issue X3-27059
  [L]GLEGLSODOCID = [F:DAE]TYP + " " + [F:DAE]NUM
  # issue X3-90535 - 2018-05-29 by MANOW
  Read [F:DKD]DKD0="SAFT-PT";[F:DAE]TYP;[F:DAE]NUM
  If !fstat & [F:DKD]VALIDDAT<>[0/0/0]
    [L]GLEGLSYSENTD = format$("D:YYYY[-]MM[-]DD",[F:DKD]VALIDDAT)+"T"+[F:DKD]VALIDTIM
  Else
    # Issue X3-101174 by MRDAB
    [L]GLEGLSYSENTD = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss", func PORLEGLIB.TRANSFORM_TO_LOCAL_TIME([F:HAE]CREDATTIM))
#    [L]GLEGLSYSENTD = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss",[F:HAE]CREDATTIM)
    # Issue end X3-101174
  Endif
  # issue end
  [L]GLEGLLDESCRI = [F:DAE]DES
  If [L]GLEGLLDESCRI = "" : [L]GLEGLLDESCRI = "Documento " + [F:HAE]NUM : Endif
  If [F:DAE]SNS = 1
    [L]GLEGLLDEBAMO = [F:DAE]AMTLED
  Else
    [L]GLEGLLCREAMO = [F:DAE]AMTLED
  Endif

  #WRITE_GLE_RECORD
  # Issue X3-31864 - 2017-04-06 by MRDAB: xml file structure main change
  Gosub WRITE_GLE
  # End issue X3-31864

  $NEXT_RECORD
  [L]GLJOURN = [F:HAE]JOU
  [L]GLNUM   = [F:HAE]NUM
  [L]GLTYP   = [F:HAE]TYP

  $NEXTGLE2
Next

If [L]GLJOURN <> "XXXX"
  # Issue X3-31864 - 2017-04-06 by MRDAB: end Lines section with Transaction section
  Gosub CLOSE_TRANSACTION
  # End issue X3-31864

  Wrseq '</Journal>' Using [SAFT]
Endif

Wrseq '</GeneralLedgerEntries>' Using [SAFT]

Return
#######################################################################################
#######################################################################################
# Issue X3-31864 - 2017-04-06 by MRDAB: subroutines for transaction and GLE entries with version management
$WRITE_GLE_COMMON
  AUXTAGNAM = 'RecordID'         : AUXTAGVAL = num$([L]GLEGLRECORDI)  : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = 'AccountID'        : AUXTAGVAL = [L]GLEGLACCOUNT        : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = 'SourceDocumentID' : AUXTAGVAL = [L]GLEGLSODOCID        : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = 'SystemEntryDate'  : AUXTAGVAL = [L]GLEGLSYSENTD        : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = 'Description'      : AUXTAGVAL = [L]GLEGLLDESCRI        : Gosub WRITETAG From SAFTGENPORTG

Return
#######################################################################################
#######################################################################################
$WRITE_GLE
If [L]ISSAFTVERCURRENT
  Gosub WRITE_GLE_CUR
Else
  Gosub WRITE_GLE_PREV
Endif

Return
#######################################################################################
#######################################################################################
$WRITE_GLE_CUR
If [F:DAE]SNS = 1
  If [L]GLEGLLDEBAMO > 0
    Wrseq '<DebitLine>' Using [SAFT]
    Gosub WRITE_GLE_COMMON
    AUXTAGNAM = 'DebitAmount'      : AUXTAGVAL = ctrans(vireblc(format$("N20.4",arr(abs([L]GLEGLLDEBAMO),0.0001)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
    Wrseq '</DebitLine>' Using [SAFT]
  Else
    Wrseq '<CreditLine>' Using [SAFT]
    Gosub WRITE_GLE_COMMON
    AUXTAGNAM = 'CreditAmount'     : AUXTAGVAL = ctrans(vireblc(format$("N20.4",arr(abs([L]GLEGLLDEBAMO),0.0001)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
    Wrseq '</CreditLine>' Using [SAFT]
  Endif
Else
  If [L]GLEGLLCREAMO > 0
    Wrseq '<CreditLine>' Using [SAFT]
    Gosub WRITE_GLE_COMMON
    AUXTAGNAM = 'CreditAmount'     : AUXTAGVAL = ctrans(vireblc(format$("N20.4",arr(abs([L]GLEGLLCREAMO),0.0001)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
    Wrseq '</CreditLine>' Using [SAFT]
  Else
    Wrseq '<DebitLine>' Using [SAFT]
    Gosub WRITE_GLE_COMMON
    AUXTAGNAM = 'DebitAmount'      : AUXTAGVAL = ctrans(vireblc(format$("N20.4",arr(abs([L]GLEGLLCREAMO),0.0001)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
    Wrseq '</DebitLine>' Using [SAFT]
  Endif
Endif

Return
#######################################################################################
#######################################################################################
$WRITE_GLE_PREV
Wrseq '<Line>' Using [SAFT]

If [F:DAE]SNS = 1
  If [L]GLEGLLDEBAMO > 0
    Gosub WRITE_GLE_COMMON
    AUXTAGNAM = 'DebitAmount'      : AUXTAGVAL = ctrans(vireblc(format$("N20.4",arr(abs([L]GLEGLLDEBAMO),0.0001)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
  Else
    Gosub WRITE_GLE_COMMON
    AUXTAGNAM = 'CreditAmount'     : AUXTAGVAL = ctrans(vireblc(format$("N20.4",arr(abs([L]GLEGLLDEBAMO),0.0001)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
  Endif
Else
  If [L]GLEGLLCREAMO > 0
    Gosub WRITE_GLE_COMMON
    AUXTAGNAM = 'CreditAmount'     : AUXTAGVAL = ctrans(vireblc(format$("N20.4",arr(abs([L]GLEGLLCREAMO),0.0001)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
  Else
    Gosub WRITE_GLE_COMMON
    AUXTAGNAM = 'DebitAmount'      : AUXTAGVAL = ctrans(vireblc(format$("N20.4",arr(abs([L]GLEGLLCREAMO),0.0001)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
  Endif
Endif

Wrseq '</Line>' Using [SAFT]

Return
#######################################################################################
#######################################################################################
$OPEN_TRANSACTION
If [L]ISSAFTVERCURRENT
  Gosub OPEN_TRANSACTION_CUR
Else
  Gosub OPEN_TRANSACTION_PREV
Endif

Return
#######################################################################################
#######################################################################################
$OPEN_TRANSACTION_CUR
Gosub OPEN_TRANSACTION_COMMON
Wrseq '<Lines>' Using [SAFT]

Return
#######################################################################################
#######################################################################################
$OPEN_TRANSACTION_PREV
Gosub OPEN_TRANSACTION_COMMON

Return
#######################################################################################
#######################################################################################
$OPEN_TRANSACTION_COMMON
Wrseq '<Transaction>' Using [SAFT]
AUXTAGNAM = 'TransactionID'        : AUXTAGVAL = [L]GLETRANSACID                         : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'Period'               : AUXTAGVAL = num$([L]GLEPERIOD)                      : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'TransactionDate'      : AUXTAGVAL = [L]GLETRANSACDT                         : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'SourceID'             : AUXTAGVAL = [L]GLESOURCEID                          : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'Description'          : AUXTAGVAL = [L]GLEMDESCRIPT                         : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'DocArchivalNumber'    : AUXTAGVAL = [L]GLEDOCARCNUM                         : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'TransactionType'      : AUXTAGVAL = [L]GLETRANSTYPE                         : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'GLPostingDate'        : AUXTAGVAL = [L]GLEGLPOSTDAT                         : Gosub WRITETAG From SAFTGENPORTG
If [L]GLEGLCUSTOID <> "" : AUXTAGNAM = 'CustomerID' : AUXTAGVAL = [L]GLEGLCUSTOID             : Gosub WRITETAG From SAFTGENPORTG : Endif
If [L]GLEGLSUPPLID <> "" : AUXTAGNAM = 'SupplierID' : AUXTAGVAL = [L]GLEGLSUPPLID             : Gosub WRITETAG From SAFTGENPORTG : Endif

Return
#######################################################################################
#######################################################################################
$CLOSE_TRANSACTION
If [L]ISSAFTVERCURRENT
  Gosub CLOSE_TRANSACTION_CUR
Else
  Gosub CLOSE_TRANSACTION_PREV
Endif

Return
#######################################################################################
#######################################################################################
$CLOSE_TRANSACTION_CUR
Wrseq '</Lines>' Using [SAFT]
Wrseq '</Transaction>' Using [SAFT]

Return
#######################################################################################
#######################################################################################
$CLOSE_TRANSACTION_PREV
Wrseq '</Transaction>' Using [SAFT]

Return
# End issue X3-31864
#######################################################################################
#######################################################################################

