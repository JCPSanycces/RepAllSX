#<AdxTL>@(#)0.0.0.0 $Revision$

#**
#* Web service import
#*
#* @param I_MODIMP    : X3 template import
#* @param I_AOWSTA    : Tempory storage space = YES or NO
#* @param I_EXEC      :  Type of execution = BATCH or REALTIME
#* @param I_RECORDSEP : Separator of records for the import file
#* @param I_FILE      : It is the imput file
#* @param O_REQNUM    : If the type is BATCH the number of batch request
#* @param O_STATUS    : Status of Web service : 0=OK else >0 ERROR
#* @param O_MESSA     : Error if status>0
#*!
Subprog IMPORT(I_MODIMP, I_AOWSTA, I_EXEC,I_RECORDSEP,I_FILE,O_REQNUM,O_STATUS,O_MESSA)
Value     Char      I_MODIMP()
Value     Char      I_AOWSTA
Value     Char      I_EXEC()
Value     Char      I_RECORDSEP()
Variable  Clbfile   I_FILE()
Variable  Integer   O_REQNUM
Variable  Integer   O_STATUS
Variable  Char      O_MESSA()


Local Char     FIL1(GDIMFIC) : # name of the csv.file : ex : ol.csv
Local Char     FIL1FULL(GDIMFIC) : # Fullname of the csv file : ex c:/../tmp/ol.csv
Local Char     SEPENR(5)

Local Integer I,J
Local Clbfile LEC(6), TMP_FILE(6)
Local Char YEND(3) : YEND="END"
If clalev([F:AOE])=0 : Local File AOBJEXT [AOE] : Endif


If clalev([M:IMP2])=0 : Local Mask IMPOBJ2 [IMP2] : Endif
Raz O_REQNUM, O_STATUS,O_MESSA

If I_MODIMP=""
 O_STATUS = 1 : O_MESSA=func AFNC.MES1(mess(181,141,1),"I_MODIMP") : End : #"The value I_MODIMP should not be empty" : End
Endif
Read [AOE]AOE0 = I_MODIMP
If fstat
 O_STATUS = 2 : O_MESSA=mess(182,141,1) : End :#"Template X3 not found"
Endif
If find(I_AOWSTA,"YES","NO")=0
 O_STATUS = 3 : O_MESSA=func AFNC.MES3(mess(183,141,1),"I_AOWSTA","YES","NO") : End : #"The value of I_AOWSTA must be YES or NO" : End
Endif

If find(I_EXEC,"BATCH","REALTIME")=0
 O_STATUS = 4 : O_MESSA=func AFNC.MES3(mess(183,141,1),"I_EXEC","BATCH","REALTIME") : End : #"The value of I_EXEC must be BATCH or REALTIME" : End
Endif
If I_RECORDSEP=""
 O_STATUS = 5 : O_MESSA=func AFNC.MES1(mess(181,141,1),"I_RECORDSEP") : End : #"The value of I_RECORDSEP should not be empty"
Endif
If I_FILE=""
 O_STATUS = 6 : O_MESSA=func AFNC.MES1(mess(181,141,1),"I_FILE") : End  : #The value of I_FILE should not be empty" : End
Endif

If right$(I_FILE,len(I_FILE)-2)<>[L]YEND
 O_STATUS = 20 : O_MESSA=func AFNC.MES2(mess(187,141,1),"I_FILE",YEND) : End : #"The value of I_FILE should finished by the word"-YEND : End
Endif

FIL1 = func APREFIXTRT.GET_PREFIX_AOWS()+"_IMPORT"+"_"+I_MODIMP+"_"+GUSER+"_"+num$(adxuid(1))+num$(time)

FIL1FULL = filpath("tmp",FIL1,"csv",nomap)

I=0
J=1
TMP_FILE=""
SEPENR = func GET_SEPENR([F:AOE]SEPREC)
Repeat
 I = instr(J,I_FILE,I_RECORDSEP)
 If I>0
  Append TMP_FILE ,seg$(I_FILE,J,I-1)
  Append TMP_FILE,SEPENR
  J=I+1
 Endif
Until I=0

Openo FIL1FULL,0 Using [CSV]

Iomode adxirs "" Using [CSV]
Iomode adxifs "" Using [CSV]

Case [F:AOE]CODDBA
 When 1 : #ASCII
  Iomode adxium GASCII Using [CSV]
 When 2 : #UTF-8
  Iomode adxium GUTF8 Using [CSV]
Endcase

Wrseq TMP_FILE Using [CSV]

Openo Using [CSV]
Raz [M:IMP2]
Case I_AOWSTA
  When "YES" : [M:IMP2]AOWSTA = 2
  When "NO" : [M:IMP2]AOWSTA = 1
Endcase
If I_EXEC="REALTIME"
 Gosub IMPORT_REALTIME
Elsif I_EXEC="BATCH"
 Gosub IMPORT_BATCH
Endif

Raz I_FILE

End

$IMPORT_BATCH

Local Char TACHE(GLONABT) : TACHE = "IMPORT"
Local Char ABRMSKBATCH(5) : ABRMSKBATCH = "IMP2"
Gosub BATCH_START

If GERR : Return : Endif

[M:IMP2]MODIMP = I_MODIMP
[M:IMP2]NOMIMP = [L]FIL1FULL
[M:IMP2]VOLFIL = "[TMP]/"+[L]FIL1+".csv"
[M:IMP2]TYPEXP = 2

Gosub BATCH_END


Return

$IMPORT_REALTIME

Call IMPORTSIL(I_MODIMP,FIL1FULL) From GIMPOBJ


Return

Funprog GET_SEPENR(SEPREC)
Value Char SEPREC()

Local Char SEPENR(10)
Local Integer I
SEPENR = SEPREC

I = 1

$SEP1
I = instr(1,SEPENR,"\")
If I
 SEPENR = left$(SEPENR,I-1)+chr$(val(mid$(SEPENR,I+1,3)))+right$(SEPENR,I+4)
 I += 1
 Goto SEP1
Endif

End SEPENR

$BATCH_START

If clalev([F:ABR])=0  : Local File ABATRQT  [ABR]  : Endif
If clalev([F:ABP])=0  : Local File ABATPAR  [ABP]  : Endif
If clalev([F:ABL])=0 : Local File ABATRQTL [ABL] : Endif

Gosub OUVRE_TABLE From ARQTSUB
Local Char    DOSSIER(GLONADS) , USER(GLONAUS) , GROUPE(GLONABG)
Local Char ZTIM(20)
#$AVANT_BOUTON
DOSSIER = nomap
USER    = GUSER
Gosub SETUSR From ARQTSUB

GERR=0
Gosub VERFTAC  From ARQTSUB
If GERR
    Gosub RESTUSR  From ARQTSUB
Endif

Gosub FERME_ATEXTE From ARQTSUB
If GERR : Return : Endif
###
Return

$BATCH_END

ZTIM = time$

Call CRERQT(nomap,GUSER,"",0,TACHE,1,date$,seg$(ZTIM,1,2)+seg$(ZTIM,4,5),"",ABRMSKBATCH,O_REQNUM) From REQUETES



#BOUTON
Gosub RESTUSR From ARQTSUB
Gosub OUVRE_ATEXTE  From ARQTSUB
Return

