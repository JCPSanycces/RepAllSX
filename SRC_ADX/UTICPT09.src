#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################
# UTICPT09   Mise à jour de la formule                      Module CPT   #
#            liée au code activité CASIN                                 #                     
##########################################################################
Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTICPT09(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT09(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTICPT09 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
#Local File =GDOSX3+".ACTIV"  [ACV_] #F58879
Local File =DOSSIER+".ACTIV" [ACV]

Call DEBTRANS From GLOCK

Trbegin [ACV]

#F58879
#Read [ACV_]CODACT = "CASIN"
#If !fstat
# Readlock [ACV]CODACT ="CASIN"
# If !fstat
#  [F:ACV]ACTFOR =  [F:ACV_]ACTFOR
#  Rewrite [F:ACV]
# Endif
#Endif
#Commit
#Close Local File [ACV], [ACV_]

#F58879
Readlock [ACV]CODACT ="CASIN"
If !fstat
 [F:ACV]ACTFOR =  "T1000<>0  or SCTE<>0 or SFRPT<>0"
 Rewrite [F:ACV]
Endif

Commit
Close Local File [ACV]

Call ECR_TRACE("UTICPT09 : record processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
#If APPLI=GDOSX3: End : Endif #F58879
Call MAJ_UTICPT09(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#If APPLI=GDOSX3 :  End : Endif #F58879
Call MAJ_UTICPT09(APPLI)
End

