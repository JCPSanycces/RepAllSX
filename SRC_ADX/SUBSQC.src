#                                                                        # hcb X3-77043 deb
Subprog AM_LPNFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
   [M:SQC]LOCFLG = 2
Else
   [M:SQC]LOCFLG = 1
Endif
Affzo [M:SQC]LOCFLG
If [M:SQC]PCUFLG=2 | [M:SQC]STAFLG=2 | [M:SQC]CRDFLG=2 | [M:SQC]LOCFLG=2 | [M:SQC]CPTFLG=2 | [M:SQC]VALEUR=2
   If dim([M:SQC]LOT)>0
      If [M:SQC]LOT<>""
         Actzo [M:SQC]LOTSTR,LOTEND
         Affzo [M:SQC]LOTSTR,LOTEND
      Else
         Effzo [M:SQC]LOTSTR,LOTEND
         Grizo [M:SQC]LOTSTR,LOTEND
      Endif
   Endif
   If dim([M:SQC]SLO)>0
      If [M:SQC]SLO<>""
         Actzo [M:SQC]SLOSTR,SLOEND
         Affzo [M:SQC]LOTSTR,LOTEND
      Else
         Effzo [M:SQC]SLOSTR,SLOEND
         Grizo [M:SQC]SLOSTR,SLOEND
      Endif
   Endif
Else
   If dim([M:SQC]LOTSTR)>0
      Effzo [M:SQC]LOTSTR,LOTEND
      Grizo [M:SQC]LOTSTR,LOTEND
   Endif
   If dim([M:SQC]SLOSTR)>0
      Effzo [M:SQC]SLOSTR,SLOEND
      Grizo [M:SQC]SLOSTR,SLOEND
   Endif
Endif
End
#                                                                        # hcb X3-77043 fin

