#<AdxTL>@(#)10.0.0.0 $Revision$
#####################################################################
# Gestion du masque STKCOP (Copies dans le contrôle qualité)        #
#             interdit en echantillonnage                           #
# Fenêtre    : ISTKCOP                                              #
# Ecran      : STKCOP [SQC]                                         #
# Traitement : SUBSQC                                               #
#####################################################################
$ACTION
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
 When Default
Endcase
Return

$DEBUT
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
Raz [M:SQC]
Local Integer LNOLIG    # Indice de la ligne à copier
Local Integer WTRA, LNBDET, I,J,K

WTRA= find([M:STQ1]WSTOSEQ(LNOLIG),[M:SGW]WSTOSEQ)
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
If [F:SRT]SRTTYP<>8 | [F:SRT]SRTNUM<>GSTQNUM                    # hcb 50197
   Read [SRT]SRT0=8;GSTQNUM : If fstat  Raz [F:SRT] : Endif
Endif
LNOLIG = val(PARAM(1))
nolign=LNOLIG+1
[M:SQC] = [M:STQ1]
If dim([M:STQ1]LOT)>0 & dim([M:SQC]LOT)>0
    [M:SQC]LOT =[M:STQ1]LOT(LNOLIG)
Endif
If dim([M:SQC]SERNUM)>0
    [M:SQC]SERNUM =[M:STQ1]SERNUMDEP(LNOLIG)
    [M:SQC]SERNUMF=[M:STQ1]SERNUMFDEP(LNOLIG)
Endif
Diszo [M:SQC]5

If dim([M:SQC]SERNUM)>0
    If (val(PARAM(2))<>1 | [M:SQC]SERNUM="")
        Effzo [M:SQC]SERNUMSTR,SERNUMEND
        Grizo [M:SQC]SERNUMSTR,SERNUMEND
    Else
        Actzo [M:SQC]SERNUMSTR,SERNUMEND
    Endif
Endif
#-- L'unité ne peut être copier que si renseigné mais pas multiples
If [M:SQC]PCUDES="$" | [F:SRT]CHGPCUCOD<>2 |  [M:SQC]PCUDES="" | [M:STQ1]STADES(LNOLIG)=""
  [M:SQC]PCUFLG=1
  Grizo [M:SQC]PCUFLG
Elsif [M:SQC]PCUFLG=0
  [M:SQC]PCUFLG=2
Endif
#-- Le statut ne peut être copié que si
If [M:SQC]STADES="" | [M:SQC]STADES="$"
    Grizo [M:SQC]STAFLG
    [M:SQC]STAFLG=1
Elsif [M:SQC]STAFLG=0
    [M:SQC]STAFLG=2
Endif
#                                                                  # hcb 55412 deb
If [M:SQC]STAFLG=2
   Call STKCTRSTA([M:SQC]STADES,[F:SRU]AUZSST,val(string$(GBLOSTA=1,'4')+string$(GBLOSTA<>1,'1')),1,0,mkstat) From STKACT
   If mkstat
      [M:SQC]STAFLG=1
      Grizo [M:SQC]STAFLG
      Raz GMESSAGE
   Endif
Endif

#                                                                  # hcb 55412 end

#-- La fiche qualité ne peut être copiée
If [M:SQC]QLYCRD="" | [M:STQ1]CRDSEQ(LNOLIG)=0
    Grizo [M:SQC]CRDFLG
    [M:SQC]CRDFLG=1
Else
    Actzo [M:SQC]CRDFLG
    If [M:SQC]CRDFLG=0
        [M:SQC]CRDFLG=2
    Endif
Endif
#-- Complément lot ne peut être copié


If dim([M:SQC]LOT)<=0 | (dim([M:SQC]LOT)>0 & [M:SQC]LOT="")
&                     | (WTRA=0 & [M:STQ1]MVTFLG(LNOLIG)=1)
&                     | [M:STQ1]STADES(LNOLIG)=""
   Grizo [M:SQC]CPTFLG
   [M:SQC]CPTFLG=1
Else
    Actzo [M:SQC]LOTSTR,LOTEND,CPTFLG
    [M:SQC]CPTFLG=2
Endif
# hcb unicite deb
# controle qu'une ligne n a pas deja ete qualifiée
If GFEALOTLEV = 2 & [F:ITM]LOTMGTCOD = 4
 #  Local Integer LRET
 #  LRET = sigma(0,[M:STQ1]NBLIG-1,(indcum+1)*([M:STQ1]LOT(indcum) = [M:STQ1]LOT(LNOLIG) & [M:STQ1]WSTJQTY(indcum) <> 0 &
#                       LRET=0 & sigma(LRET=1,1,1)))
#   If LRET <> 0
#      Grizo [M:SQC]CPTFLG
#      [M:SQC]CPTFLG=1
#   Endif
# pour le moment je bloque car cela genere trop de pb .........  il faudrait inhiber le controle sur le slo pour le
# complement lot , faire aussi des controle sur le titre , sur le nombre de detail etc etc
   Grizo [M:SQC]CPTFLG
   [M:SQC]CPTFLG=1

Endif
# hcb unicite fin

#---- Lot ----#
If dim([M:SQC]LOT)>0
    Diszo [M:SQC]10    # Bloc lot
Endif

#                                                                               # hcb X3-77043 deb
If [F:ITF]ITMREF<>[M:STQ1]ITMREF | [F:ITF]STOFCY<>[M:STQ1]STOFCY
   Read [ITF]ITF0 = [M:STQ1]ITMREF; [M:STQ1]STOFCY
   If fstat : Raz [F:ITF] : Endif
Endif
If dim([M:SQC]LPNNUMDES)>0
#----- Contenant -------#
   If [F:ITF]LPNMGTCOD <>2 | [M:SQC]LPNNUMDES="$"
      [M:SQC]LPNFLG = 1
      Grizo [M:SQC]LPNFLG
   Else
      Actzo [M:SQC]LPNFLG
   Endif
   If [M:SQC]LPNFLG=0
      [M:SQC]LPNFLG=2
   Endif
Endif
#                                                                               # hcb X3-77043 fin

#----- Emplacement -------#
#                                      rajout [F:ITF]LPNMGTCOD = 2              # hcb X3-77043
If dim([M:SQC]LOCDES)<=0 | (dim([M:SQC]LOCDES)>0 & ([M:SQC]LOCDES="" | [M:SQC]LOCDES="$"))
&      | [M:STQ1]STADES(LNOLIG)="" | [F:ITF]LPNMGTCOD = 2
    [M:SQC]LOCFLG = 1
    Grizo [M:SQC]LOCFLG
Else
    Actzo [M:SQC]LOCFLG
Endif
If dim([M:SQC]LPNFLG) >0
  If [M:SQC]LPNFLG=2                                                     # hcb X3-77043
   [M:SQC]LOCFLG=2                                                     # hcb X3-77043
  Endif
Endif                                                                  # hcb X3-77043

If [M:SQC]LOCFLG=0
    [M:SQC]LOCFLG=2
Endif
If dim([M:SQC]LOT)>0
  If dim([M:SQC]SLO)>0
    Read [STL]STL0=[M:STQ1]ITMREF;[M:SQC]LOT;[M:SQC]SLO
  Else
    Read [STL]STL0=[M:STQ1]ITMREF;[M:SQC]LOT;""
  Endif
  If fstat Raz [STL]
  Else
    [M:SQC]=[F:STL]
  Endif
  Raz K
  K=find([M]WSTOSEQ(LNOLIG),[M:SGW]WSTOSEQ)-1
  If K>=0
     [M:SQC]REFPER    = [M:SGW]REFPER   (K)
     [M:SQC]SHL       = [M:SGW]SHL      (K)
     [M:SQC]SHLDAT    = [M:SGW]SHLDAT   (K)
     [M:SQC]POT       = [M:SGW]POT      (K)
     [M:SQC]ACT       = [M:SGW]ACT      (K)
     [M:SQC]USRFLD1   = [M:SGW]USRFLD1  (K)
     [M:SQC]USRFLD2   = [M:SGW]USRFLD2  (K)
     [M:SQC]USRFLD3   = [M:SGW]USRFLD3  (K)
     [M:SQC]USRFLD4   = [M:SGW]USRFLD4  (K)
     [M:SQC]SHLUOM    = [M:SGW]SHLUOM   (K)               # V6per
     [M:SQC]SHLLTI    = [M:SGW]SHLLTI   (K)               # V6per
     [M:SQC]SHLLTIUOM = [M:SGW]SHLLTIUOM(K)               # V6per
     [M:SQC]NEWLTIDAT = [M:SGW]NEWLTIDAT(K)               # V6per
     [M:SQC]DLU       = [M:SGW]DLU      (K)               # V6per
     [M:SQC]DLUDAT    = [M:SGW]DLUDAT   (K)               # V6per

  Endif
Endif
#-- Si on ne souhaite copier que le sous-lot
If [M:SQC]PCUFLG=2 | [M:SQC]STAFLG=2 | [M:SQC]CRDFLG=2 | [M:SQC]LOCFLG=2 | [M:SQC]CPTFLG=2
  If dim([M:SQC]LOT)>0
    If [M:SQC]LOT<>""
      Actzo [M:SQC]LOTSTR,LOTEND
    Else
      Effzo [M:SQC]LOTSTR,LOTEND
      Grizo [M:SQC]LOTSTR,LOTEND
    Endif
  Endif
  If dim([M:SQC]SLO)>0
    If [M:SQC]SLO<>""
      Actzo [M:SQC]SLOSTR,SLOEND
    Else
      Effzo [M:SQC]SLOSTR,SLOEND
      Grizo [M:SQC]SLOSTR,SLOEND
    Endif
  Endif
Else
  If dim([M:SQC]LOTSTR)>0
    Effzo [M:SQC]LOTSTR,LOTEND
    Grizo [M:SQC]LOTSTR,LOTEND
  Endif
  If dim([M:SQC]SLOSTR)>0
    Effzo [M:SQC]SLOSTR,SLOEND
    Grizo [M:SQC]SLOSTR,SLOEND
  Endif
Endif
Affzo [M:SQC]
Return

$OK
#-----------------------#
# Après exécution de OK #
#-----------------------#
Local Integer I,J,K, MAJ
Local Integer LSEQ, LIRET
Local Char MSKCOU(10) : MSKCOU="[STQ1]"
Local Char LABR(5) : LABR="STQ1"
Local Shortint LSRET
Local Integer  LRET
Local Decimal LQTYSTU, LSAVQTYSTU, LCOE, LQTY, LSAVQTYPCU
Local Char PCU(GLONUOM), LSTA(GLONSTA), LLOC(GLONLOC), LLOCTYP(GLONTLO), LWRH(GLONWRH), LLPN(GLONLPN)           # hcb X3-77043
Default Mask MSKCOU
If !clalev([QLA])  : Local File QLYCRDASW [QLA]  : Endif
If !clalev([QLA1]) : Local File QLYCRDASW [QLA1] : Endif
#-- Si fiche qualité à oui
If [M:SQC]CRDFLG=2
    LIRET=2
    # On demande confirmation car il n'y a plus possibilité de revenir en arrière.
#   Call AVERTIR(mess(65,184,1),LIRET) From GESECRAN                                   # hcb X3-48567
    Call AVERTIR(mess(503,184,1)-" "-[M:STQ1]QLYCRD(LNOLIG)-"?",LIRET) From GESECRAN    # hcb X3-48567

    If LIRET<>2
        [M:SQC]CRDFLG=1
    Endif
Endif
#-- Pour chacune des lignes
For I=0 To [M:STQ1]NBLIG-1
    #-- Raz indicateur de mise à jour
    Raz MAJ
    #-- Si la ligne est celle de la copie
    If I=LNOLIG Goto NEXTI : Endif
    #-- Si lot départ renseigné et > que le lot de la ligne
    If dim([M:STQ1]LOT)>0 & ([M:SQC]LOTSTR<>"" & [M:SQC]LOTSTR>[M:STQ1]LOT(I)) : Goto NEXTI : Endif
    #-- Si lot fin renseigné et < que le lot de la ligne
    If dim([M:STQ1]LOT)>0 & ([M:SQC]LOTEND<>"" & [M:SQC]LOTEND<[M:STQ1]LOT(I)) : Goto NEXTI : Endif
    #-- Si sous-lot départ renseigné et > que le sous-lot de la ligne
    If dim([M:STQ1]SLO)>0 & ([M:SQC]SLOSTR<>"" & [M:SQC]SLOSTR>[M:STQ1]SLO(I)) : Goto NEXTI : Endif
    #-- Si sous-lot départ renseigné et < que le sous-lot de la ligne
    If dim([M:STQ1]SLO)>0 & ([M:SQC]SLOEND<>"" & [M:SQC]SLOEND<[M:STQ1]SLO(I)) : Goto NEXTI : Endif
    #-- Si numéro serie départ renseigné et > que le numéro de serie de la  ligne
    If dim([M:STQ1]SERNUM)>0 &([M:SQC]SERNUMSTR<>"" & [M:SQC]SERNUMSTR>[M:STQ1]SERNUMDEP(I)) : Goto NEXTI : Endif
    #-- Si numéro serie fin renseigné et < que le numéro de serie de la  ligne
    If dim([M:STQ1]SERNUM)>0 &([M:SQC]SERNUMEND<>"" & [M:SQC]SERNUMEND<[M:STQ1]SERNUMFDEP(I)) : Goto NEXTI : Endif
    #-- Si ligne déjà validée on ne fait plus rien
    If [M:STQ1]SAICOD(I)="*" & [M:STQ1]WSTJQTY(I)=[M:STQ1]QTYSTU(I) & [M:STQ1]UPDFLG(I)=0 : Goto NEXTI : Endif
#                                                             # hcb x3-48567  deb

# si copie fiche qualité cochée
#     si fiche qualite de la ligne receptrice est  <> on copie les qualifications si les réponses sont renseignées
If [M:SQC]CRDFLG=2 & [M:STQ1]QLYCRD(LNOLIG) <>  [M:STQ1]QLYCRD(I) & [M:STQ1]SAICOD(I)="F" : Goto NEXTI : Endif
# si copie fiche qualité décochée
#     on copie les qualifications si les réponses sont renseignées
If [M:SQC]CRDFLG <> 2 & [M:STQ1]SAICOD(I)="F" : Goto NEXTI : Endif

#                                                             # hcb x3-48567  end

    nolign = I+1
    Raz mkstat
    Call C_NBLIG From SUBSTQ
    #-- Calcul du nombre de détail
    LNBDET = func SUBSCSB.CALCNBDET([M]WSTOSEQ(I))
    If ([M:SQC]PCUFLG=2 | [M:SQC]STAFLG=2 | [M:SQC]LOCFLG=2) & [M]STADES(LNOLIG)<>""
        #-- On ne fait la copie que sur des lignes à 1 seul détail ---#
        If !mkstat & LNBDET<=1
            If [M]WSTJQTY(I)<>0 & [M]QTYSTUDES(I)=[M]WSTJQTY(I)
              LQTYSTU=[M]QTYSTU(I)-[M:STQ1]WSTJQTY(I)
            Else
              LQTYSTU = [M]QTYSTUDES(I)+([M]QTYSTUDES(I)=0)*[M]QTYSTU(I)
            Endif
            LPCU    = [M]PCUDES(I)
            LCOE    = [M]COEDES(I)+([M]COEDES(I)=0)
            LSTA    = [M]STADES(I)
            If evalue("dim("+MSKCOU+"LOCDES)")>0
              LLOC    = [M]LOCDES(I)
              If evalue("dim("+MSKCOU+"LOCTYPDES)")>0
                         LLOCTYP = [M]LOCTYPDES(I)
              Endif
            Endif
            If evalue("dim("+MSKCOU+"WRHDES)")>0
              LWRH    = [M]WRHDES(I)
            Endif
            #-- Si case unité de destination cochée
            If [M:SQC]PCUFLG=2
               LPCU = [M]PCUDES(LNOLIG)
               LCOE = [M]COEDES(LNOLIG)+([M]COEDES(LNOLIG)=0)
            Endif
            #-- Si case à cocher statut
            If [M:SQC]STAFLG=2 : LSTA = [M]STADES(LNOLIG) : Endif
            If LSTA="" & [F:SRU]DEFSTA<>"" : LSTA=[F:SRU]DEFSTA : Endif : # dde 27199
#                                                                               # hcb X3-77043 deb

            #-- Si case à cocher contenant non cochée on prend le contenant d'origine
            #-- Si case à cocher contenant     cochée on prend le contenant à copier
            If evalue("dim("+MSKCOU+"LPNNUMDES)")>0
               If [M:SQC]LPNFLG=2
                  LLPN = [M]LPNNUMDES(LNOLIG)
               Else
                  LLPN=[M]LPNNUM(I)
               Endif
            Endif
#                                                                               # hcb X3-77043 fin

            #-- Si case à cocher emplacement non cochée on prend l'emplacement d'origine
            #-- Si case à cocher emplacement cochée, on prend l'emplacement à copier
            If evalue("dim("+MSKCOU+"LOCDES)")>0
                If [M:SQC]LOCFLG=2
                    LLOCTYP=[M]LOCTYPDES(LNOLIG) : LLOC = [M]LOCDES(LNOLIG)
                Else
                   If LSTA<>""
                       LLOCTYP=[M]LOCTYP(I)      : LLOC = [M]LOC(I)
                   Endif
                Endif
            Endif
            LQTY = LQTYSTU/LCOE
            #-- Copie
            [M:SQC]LOC = [M]LOC(I)                                              # hcb X3-77043
            Gosub COP_CHP
        Endif
    Endif
    #----- Copie du complément lot -----------#
    If [M:SQC]CPTFLG=2 & LNBDET<=1
        J=find([M]WSTOSEQ(I),[M:SGW]WSTOSEQ)-1
        K=find([M]WSTOSEQ(LNOLIG),[M:SGW]WSTOSEQ)-1
        If J>=0 & K>=0
            J=[M:SGW]NUMLIGLOT(J)
            K=[M:SGW]NUMLIGLOT(K)
        Endif
        If J>=0 & K>=0
            [M:SGW]REFPER    (J) = [M:SGW]REFPER   (K)
            [M:SGW]SHL       (J) = [M:SGW]SHL      (K)
            [M:SGW]SHLDAT    (J) = [M:SGW]SHLDAT   (K)
            [M:SGW]POT       (J) = [M:SGW]POT      (K)
            [M:SGW]ACT       (J) = [M:SGW]ACT      (K)
            [M:SGW]USRFLD1   (J) = [M:SGW]USRFLD1  (K)
            [M:SGW]USRFLD2   (J) = [M:SGW]USRFLD2  (K)
            [M:SGW]USRFLD3   (J) = [M:SGW]USRFLD3  (K)
            [M:SGW]USRFLD4   (J) = [M:SGW]USRFLD4  (K)
            [M:SGW]SHLUOM    (J) = [M:SGW]SHLUOM   (K)               # V6per
            [M:SGW]SHLLTI    (J) = [M:SGW]SHLLTI   (K)               # V6per
            [M:SGW]SHLLTIUOM (J) = [M:SGW]SHLLTIUOM(K)               # V6per
            [M:SGW]NEWLTIDAT (J) = [M:SGW]NEWLTIDAT(K)               # V6per
            [M:SGW]DLU       (J) = [M:SGW]DLU      (K)               # V6per
            [M:SGW]DLUDAT    (J) = [M:SGW]DLUDAT   (K)               # V6per
            MAJ=1
         Elsif J>=0 & K = -1
            If dim([M:STQ1]SLO)>0                                                     # hcb 84902
               Read [STL] STL0=[M:STQ1]ITMREF;[M:STQ1]LOT(LNOLIG);[M:STQ1]SLO(LNOLIG)
            Else
               Read [STL]STL0=[M:STQ1]ITMREF;[M:STQ1]LOT(LNOLIG);""
            Endif
            If !fstat
               [M:SGW]REFPER    (J) = [F:STL]REFPER
               [M:SGW]SHL       (J) = [F:STL]SHL
               [M:SGW]SHLDAT    (J) = [F:STL]SHLDAT
               [M:SGW]POT       (J) = [F:STL]POT
               [M:SGW]ACT       (J) = [F:STL]ACT
               [M:SGW]USRFLD1   (J) = [F:STL]USRFLD1
               [M:SGW]USRFLD2   (J) = [F:STL]USRFLD2
               [M:SGW]USRFLD3   (J) = [F:STL]USRFLD3
               [M:SGW]USRFLD4   (J) = [F:STL]USRFLD4
               [M:SGW]SHLUOM    (J) = [F:STL]SHLUOM                  # V6per
               [M:SGW]SHLLTI    (J) = [F:STL]SHLLTI                  # V6per
               [M:SGW]SHLLTIUOM (J) = [F:STL]SHLLTIUOM               # V6per
               [M:SGW]NEWLTIDAT (J) = [F:STL]NEWLTIDAT               # V6per
               [M:SGW]DLU       (J) = [F:STL]DLU                     # V6per
               [M:SGW]DLUDAT    (J) = [F:STL]DLUDAT                  # V6per
               MAJ=1
            Endif
        Endif
    Endif
    #----- Copie de la fiche qualité ---------#
    If [M:SQC]CRDFLG=2
#                                                             # hcb x3-48567  deb
    #-- la fiche qualité de la ligne doit etre la meme que la ligne copiée
       If [M:STQ1]QLYCRD(LNOLIG) <>  [M:STQ1]QLYCRD(I): Goto NEXTI : Endif
    #-- pas de copie si des reponses sont  deja saisies
       If [M:STQ1]SAICOD(I)<> "F" : Goto NEXTI : Endif


#                                                             # hcb x3-48567  end
        Trbegin [QLA1]    # On fait un Trbegin ici car il y a aussi une transaction ouverte dans STKCTREMP
        LSEQ = [M:STQ1]CRDSEQ(I)
        If LSEQ > 0
            #--- S'il existe déjà une réponse hors standard nécessitant une nouvelle séquence de réponse ---#
            #--- on change le n° de séquence, sinon on efface les réponses précédentes ----#
            If func SUBSTQB.SEARCHOSDASW4([M:STQ1]QLYCRD,[M:STQ1]VCRNUM,[M:STQ1]VCRLIN(I),[M:STQ1]CRDSEQ(I))
                    LSEQ -= 1
            Else
               Delete [QLA1] Where QLYCTLDEM = [M:STQ1]VCRNUM
&                                & VCRLIN    = [M:STQ1]VCRLIN(I)
&                                & CRDSEQ    = LSEQ
            Endif
        Else
           # Si le n° de séquence=0 cela veut dire qu'il n'y a jamais eu de réponse pour cette ligne => lseq=9999
            LSEQ = 9999
        Endif
        #----- Boucle sur toutes les questions ----#
        For [QLA] Where QLYCTLDEM = [M:STQ1]VCRNUM
&                     & VCRLIN    = [M:STQ1]VCRLIN(LNOLIG)
&                     & CRDSEQ    = [M:STQ1]CRDSEQ(LNOLIG)
           [F:QLA1]       = [F:QLA]
           [F:QLA1]CRDSEQ = LSEQ
           [F:QLA1]VCRLIN = [M:STQ1]VCRLIN(I)
           Write [QLA1]
           If fstat GOK=0 : Call FSTA("QLA1") From GLOCK : Goto AB_QLA1 : Endif
        Next
        [M:STQ1]CRDSEQ(I) = LSEQ
        [M:STQ1]CRDFLG(I) = [M:STQ1]CRDFLG(LNOLIG)
        #-- si numéro de série
        Gosub MAJ_SERQLA
        If GOK=0 : Goto AB_QLA1 : Endif
        #--
        Gosub MAJ_CRDQLD From SUBSTQB
        If mkstat=4 : MAJ=1 : Endif

       $AB_QLA1
        If GOK=1
          Commit
        Else
          Rollback
          MAJ=0
        Endif
    Endif

    $NEXTI
    If MAJ=1
        #--- Raffraichissement de l'indicateur de saisie
        Call MAJSAICOD(I) From SUBSTQB

    Endif
Next




$FINF
nolign = LNOLIG+1

Return

#####################################################################################
#
#            Actions champs
#
#####################################################################################
Subprog AM_LOTSTR(VALEUR)
Variable Char    VALEUR()
    If VALEUR<>"" & ( LOTEND="" | LOTEND=LOTSTR )
        LOTEND=VALEUR
    Endif
End

Subprog AM_LOTEND(VALEUR)
Variable Char    VALEUR()
    If VALEUR<>"" & VALEUR<LOTSTR
        GMESSAGE = mess(44, 199, 1)
        mkstat=2
    Endif
End

Subprog AM_SLOSTR(VALEUR)
Variable Char    VALEUR()
    If VALEUR<>"" & ( SLOEND="" | SLOEND=SLOSTR)
        SLOEND=VALEUR
    Endif
End

Subprog AM_SLOEND(VALEUR)
Variable Char    VALEUR()
    If VALEUR<>"" & VALEUR<SLOSTR
        GMESSAGE = mess(44, 199, 1)
        mkstat=2
    Endif
End

Subprog AM_SERNUMSTR(VALEUR)
Variable Char    VALEUR()
    If VALEUR<>"" & ( SERNUMEND="" | SERNUMEND=SERNUMSTR)
        SERNUMEND=VALEUR
    Endif
End

Subprog AM_SERNUMEND(VALEUR)
Variable Char    VALEUR()
    If VALEUR<>"" & VALEUR<SERNUMSTR
        GMESSAGE = mess(44, 199, 1)
        mkstat=2
    Endif
End


##########################################################################
$COP_CHP
Local Char WOPT(3)
#-- Si statut non renseigné on quitte
If LSTA="" : Return : Endif
Call AM_QTYSTUDES(LQTYSTU) From SUBSTQ
#-- Si emplacement-statut-et unité renseigné, contrôle de l'emplacement
If LLOC<>"" & LSTA<>"" & LPCU<>""
    Raz WOPT
    If LLOC=[M]LOC(I) WOPT="QU" Endif
    Call STKCTREMP([M]WLOCSEQ(I),[M]TRSTYP,[M]TRSCOD,[M]STOFCY,[M]ITMREF,
&                  LPCU, LQTY,
&                  LSTA,
&                  LLOCTYP,
&                  LLOC,
&                  "",0,LSRET,GBIDD1,WOPT,"","") From STKLOC
Endif
#                                                                     # hcb X3-77043 deb
If dim([M:SQC]LPNFLG)>0
  If LLPN <> "" & [M:SQC]LPNFLG=2 & !LSRET
   Call CONTROL_LPN(LLPN,"",[M]ITMREF,[M:SQC]LOT,[M]STOFCY,"","SQC") From STKLPN
   LSRET = mkstat
  Endif
Endif
#                                                                     # hcb X3-77043 deb
#--- Copie de l'UC, du coef UC/US ou du statut                ---#
#--- Vérifie que la ligne est complète pour alimenter STOCHGW ---#
If !LSRET
    LSAVQTYSTU = [M]QTYSTUDES(I)    # On sauvegarde la quantité préc. au cas où le ctrl serie échouerait
    LSAVQTYPCU = [M]QTYPCUDES(I)    # On sauvegarde la quantité préc. au cas où le ctrl serie échouerait
    [M]QTYSTUDES(I) = LQTYSTU
    If LABR="STQ1"
        Call AVANT_NBLIG From SUBSTQ
        If dim([M:STQ1]SERNUM)>0 & [M:STQ1]SERNUM(nolign-1)<>""
            Call C_SERNUM([M:STQ1]SERNUM(nolign-1)) From SUBSTQ
            LSRET = mkstat
        Endif
    Endif
    If LSRET
        [M]QTYSTUDES(I) = LSAVQTYSTU
    Endif
Endif
If !LSRET
    [M]PCUDES(I)    = LPCU
    [M]COEDES(I)    = LCOE
    [M]STADES(I)    = LSTA
    If evalue("dim("+MSKCOU+"WRHDES)")>0
       [M]WRHDES(I)    = LWRH
    Endif
    If evalue("dim("+MSKCOU+"LOCDES)")>0
       [M]LOCDES(I)    = LLOC
       [M]LOCTYPDES(I) = LLOCTYP
       Affzo [M]LOCDES(I),LOCTYPDES(I)
    Endif
    If evalue("dim("+MSKCOU+"LPNNUMDES)")>0                                 # hcb X3-77043
       [M]LPNNUMDES(I)    = LLPN                                            # hcb X3-77043
        Affzo [M]LPNNUMDES(I)                                               # hcb X3-77043
    Endif                                                                   # hcb X3-77043
    If [M:SQC]STAFLG=2 | [M:SQC]LOCFLG=2 | [M:SQC]PCUFLG=2
       [M]QTYPCUDES(I) = LQTY
       Call OUVCHG(LABR,I,[M]STOFCY) From SUBSCSB
       If mkstat
          [M]QTYSTUDES(I)=LSAVQTYSTU
          [M]QTYPCUDES(I)=LSAVQTYPCU
          Call DELSTOCHGW("STQ1",[M:STQ1]STOFCY, I, I, 1, LRET) From SUBSCSB
       Else
          MAJ=1
       Endif
    Else
        [M]QTYSTUDES(I)=LSAVQTYSTU
        [M]QTYPCUDES(I)=LSAVQTYPCU
    Endif
    Affzo [M]QTYSTUDES(I),PCUDES(I),QTYPCUDES(I),COEDES(I),STADES(I)
Endif
Return

$MAJ_SERQLA
If dim([M:STQ1]SERNUMDEP(I))>0 & [M:STQ1]SERNUMDEP(I)<>""
   Read [QLD]QLD0 = [M:STQ1]VCRTYP;[M:STQ1]VCRNUM;[M:STQ1]VCRLIN(I)
        Filter [QLD] Where VCRTYP = [M:STQ1]VCRTYP
&                                & VCRNUM = [M:STQ1]VCRNUM
&                                & SERNUM >= [M:STQ1]SERNUMDEP(I)
&                                & SERNUM <= [M:STQ1]SERNUMFDEP(I)
&                                & len(SERNUM) = len([M:STQ1]SERNUMDEP(I))
        For [QLD]
            For  [QLA]QLA0 Where QLYCTLDEM=[F:QLD]VCRNUM & VCRLIN=[M:STQ1]VCRLIN(I) & CRDSEQ=[M:STQ1]CRDSEQ(I)
              Look [QLA1]QLA0=[M:STQ1]VCRNUM;[F:QLD]VCRLIN;[F:QLA]CRDSEQ;[F:QLA]QSTNUM
              If fstat
                [F:QLA1]      =[F:QLA]
                [F:QLA1]VCRLIN=[F:QLD]VCRLIN
                Write [QLA1]
                If fstat GOK=0 : Call FSTA("QLA1") From GLOCK : Goto FIN_MAJSERQLA : Endif
              Else
                [F:QLA1]      =[F:QLA]
                [F:QLA1]VCRLIN=[F:QLD]VCRLIN
                Rewrite [QLA1]
                If fstat GOK=0 : Call FSTA("QLA1") From GLOCK : Goto FIN_MAJSERQLA : Endif
              Endif
            Next
        Next
        Filter [QLD]
Endif
$FIN_MAJSERQLA
Return

Subprog AM_PCUFLG(VALEUR)
Variable Integer VALEUR
Local Integer LLPN
If dim([M:SQC]LPNFLG)>0
  If  [M:SQC]LPNFLG = 2
    LLPN = 1
  Endif
Else
  LLPN = 0
Endif
If VALEUR=2 | [M:SQC]STAFLG=2 | [M:SQC]CRDFLG=2 | [M:SQC]LOCFLG=2 | [M:SQC]CPTFLG=2 | (dim([M:SQC]LPNFLG)>0 &[M:SQC]LPNFLG=2)   # hcb X3-77043
  If dim([M:SQC]LOT)>0
    If [M:SQC]LOT<>""
      Actzo [M:SQC]LOTSTR,LOTEND
      Affzo [M:SQC]LOTSTR,LOTEND
    Else
      Effzo [M:SQC]LOTSTR,LOTEND
      Grizo [M:SQC]LOTSTR,LOTEND
    Endif
  Endif
  If dim([M:SQC]SLO)>0
    If [M:SQC]SLO<>""
      Actzo [M:SQC]SLOSTR,SLOEND
      Affzo [M:SQC]LOTSTR,LOTEND
    Else
      Effzo [M:SQC]SLOSTR,SLOEND
      Grizo [M:SQC]SLOSTR,SLOEND
    Endif
  Endif
Else
  If dim([M:SQC]LOTSTR)>0
    Effzo [M:SQC]LOTSTR,LOTEND
    Grizo [M:SQC]LOTSTR,LOTEND
  Endif
  If dim([M:SQC]SLOSTR)>0
    Effzo [M:SQC]SLOSTR,SLOEND
    Grizo [M:SQC]SLOSTR,SLOEND
  Endif
Endif
End

Subprog AM_CPTFLG(VALEUR)
Variable Integer VALEUR
If [M:SQC]PCUFLG=2 | [M:SQC]STAFLG=2 | [M:SQC]CRDFLG=2 | [M:SQC]LOCFLG=2 | VALEUR=2 | (dim([M:SQC]LPNFLG)>0 &[M:SQC]LPNFLG=2)     # hcb X3-77043
  If dim([M:SQC]LOT)>0
    If [M:SQC]LOT<>""
      Actzo [M:SQC]LOTSTR,LOTEND
      Affzo [M:SQC]LOTSTR,LOTEND
    Else
      Effzo [M:SQC]LOTSTR,LOTEND
      Grizo [M:SQC]LOTSTR,LOTEND
    Endif
  Endif
  If dim([M:SQC]SLO)>0
    If [M:SQC]SLO<>""
      Actzo [M:SQC]SLOSTR,SLOEND
      Affzo [M:SQC]LOTSTR,LOTEND
    Else
      Effzo [M:SQC]SLOSTR,SLOEND
      Grizo [M:SQC]SLOSTR,SLOEND
    Endif
  Endif
Else
  If dim([M:SQC]LOTSTR)>0
    Effzo [M:SQC]LOTSTR,LOTEND
    Grizo [M:SQC]LOTSTR,LOTEND
  Endif
  If dim([M:SQC]SLOSTR)>0
    Effzo [M:SQC]SLOSTR,SLOEND
    Grizo [M:SQC]SLOSTR,SLOEND
  Endif
Endif
End

