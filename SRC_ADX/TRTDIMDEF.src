#<AdxTL>@(#)3.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("COA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "EXEC"     : Gosub EXEC
 When "CONTROLE" : Gosub CONTROLE
 When "TERMINE"  : Gosub FIN
Endcase
Return

$CONTROLE
TMP = 1 : # Pour afficher des tempon/tempoff
Return

$FIN
TRA = 1 : # Pour lire la trace
Return

$EXEC
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:GCD])=0 : Local File GACCDIM  [GCD] : Endif
If clalev([F:DIE])=0 : Local File GDIE     [DIE] : Endif
If clalev([F:COA])=0 : Local File GCOA     [COA] : Endif
Local Integer K , NBAXE
Local Integer MAXAXE
MAXAXE = nbrecord([F:DIE])
Local Char    DESIG(GLONAX3)
Local Char    AXE(GLONDIE)(1..MAXAXE)
Local Char    CCE(GLONCCE)(1..MAXAXE)
Local Char    ADDAXE(250), SUPAXE(250), MODSEC(250), MESSA(250)
Local Integer FLA(1..MAXAXE)

Call OUVRE_VLC(mess(91,103,1),"","") From GESECRAN : # Axes par défaut
Call OUVRE_TRACE(mess(91,103,1)) From LECFIC
Gosub STR_TRA
Call DEBTRANS From GLOCK
Gosub TR_EXEC
Call FERME_TRACE From LECFIC
Call FERME_VLC From GESECRAN
Return

$TR_EXEC
GOK = 1
Trbegin [GAC]
 For [GAC]GAC0 Where COA=[M:COA0]COA
  Readlock [GAC] Curr
  If fstat=1
   GOK = -1 : GLOCK = "$GACCOUNT"-[F:GAC]COA-[F:GAC]ACC : Break
  Endif
  Call AFF_VLC(mess(8,104,1),[F:GAC]ACC) From GESECRAN : # Compte
  NBAXE = [F:GAC]DACDIENBR
  For K=1 To NBAXE
   AXE(K) = [F:GAC]DIE(K-1)
   CCE(K) = [F:GAC]CCEDEF(K-1)
   FLA(K) = 0
  Next K
  ADDAXE = ""
  SUPAXE = ""
  For [GCD]GCD0 Where COA=[M:COA0]COA
   If left$([F:GAC]ACC,len([F:GCD]ACCSTR))=[F:GCD]ACCSTR or [F:GCD]ACCSTR="*"
    K = find([F:GCD]DIE,AXE(1..NBAXE))
    If K>0
     # Axes déjà présents
     FLA(K) = 1
     If[M:DIA]AFFECT=2  
      If CCE(K)<>[F:GCD]CCE
       CCE(K) = [F:GCD]CCE
       MODSEC -= [F:GCD]DIE
       If CCE(K)<>""
        MODSEC += "("+CCE(K)+")"
       Endif
      Endif
     Endif
    Else 
     NBAXE += 1
     AXE(NBAXE) = [F:GCD]DIE
     CCE(NBAXE) = [F:GCD]CCE
     FLA(NBAXE) = 1
     ADDAXE -= [F:GCD]DIE
     If CCE(NBAXE)<>""
      ADDAXE += "("+CCE(NBAXE)+")"
     Endif
    Endif
   Endif
  Next
  If [M:DIA]RAZACC=2
   K = 1
   While K<=NBAXE
    If FLA(K)=0
     SUPAXE -= AXE(K)
     Dela K,1 AXE,CCE,FLA
     NBAXE -= 1
    Else
     K += 1
    Endif
   Wend
  Endif
  If SUPAXE<>"" or ADDAXE<>"" or MODSEC<>""
   Call LECTEXTRA([L]DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
   MESSA = [F:GAC]ACC-"'"+[L]DESIG+"' : "
   If ADDAXE<>""
    MESSA -= "\ "-mess(92,103,1)-":"-ADDAXE : # Axes ajoutés
   Endif
   If MODSEC<>""
    MESSA -= "\ "-mess(99,103,1)-":"-MODSEC : # Sections modifiées
   Endif
   If SUPAXE<>""
    MESSA -= "\ "-mess(93,103,1)-":"-SUPAXE : # Axes supprimés
   Endif
   Call ECR_TRACE(MESSA,0) From GESECRAN
   If [M:DIA]SIMUL<>2
    For K=1 To NBAXE
     [F:GAC]DIE(K-1)    = AXE(K)
     [F:GAC]CCEDEF(K-1) = CCE(K)
    Next K
    If NBAXE<[F:GAC]DACDIENBR
     For K=NBAXE+1 To [F:GAC]DACDIENBR
      [F:GAC]DIE(K-1) = ""
      [F:GAC]CCEDEF(K-1) = ""
     Next
    Endif
    [F:GAC]DACDIENBR = min(NBAXE,dim([F:GAC]DIE))
    Rewrite [GAC]
    If fstat
     GOK = 0 : Call FSTA("GAC") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
 If    GOK<0 : Goto ROLL_EXEC
 Elsif !GOK  : Goto AB_EXEC
 Endif
Commit
Return

$AB_EXEC
Rollback
Return

$ROLL_EXEC
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_EXEC : Endif
Return

$STR_TRA
Local Char DESIG(GLONAX3)
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call LECTEXTRA([L]DESIG,"GCOA","DESTRA",[M:COA0]COA,"") From ATEXTRA
Call ECR_TRACE(mess(36,113,1)-[M:COA0]COA-[L]DESIG,0) From GESECRAN # plan de compte
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Onerrgo ERREUR From CONTROLE
 If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
Onerrgo
If GERREUR : GERREUR=0
Else
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Local Char    LIBZON(80)
 Read [AMZ]CODE = "DIMDEF";"AFFECT"
 If fstat=0
  Call TEXTE([F:AMZ]INTIT,LIBZON) From OBJDIV
  If LIBZON<>""
   LIBZON-=":"-mess([M]AFFECT,1,1)
   Call ECR_TRACE(LIBZON,0) From GESECRAN
  Endif
 Endif
 Read [AMZ]CODE = "DIMDEF";"RAZACC"
 If fstat=0
  Call TEXTE([F:AMZ]INTIT,LIBZON) From OBJDIV
  If LIBZON<>""
   LIBZON-=":"-mess([M]RAZACC,1,1)
   Call ECR_TRACE(LIBZON,0) From GESECRAN
  Endif
 Endif
 Call ECR_TRACE(mess(27,107,1)-":"-mess([M]SIMUL,1,1),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif
Return
