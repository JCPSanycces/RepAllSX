#<AdxTL>@(#)2.0.0.0 $Revision$
####################################################################################
# Program Name: MANHLDLIB
####################################################################################

####################################################################################
# Subprogram : ORDERHOLD
####################################################################################
Subprog ORDERHOLD(ISOHNUM,IHLDCOD,ORET,OMESSAGE)
Value    Char    ISOHNUM
Value    Char    IHLDCOD
Variable Integer ORET
Variable Char    OMESSAGE

Local Integer I,POK,FOK

Raz ORET
Raz POK,FOK

# open the SOH screens
If !clalev([M:SOH0]) : Local Mask SOH0       [SOH0] : Endif
If !clalev([M:SOH1]) : Local Mask SOH1       [SOH1] : Endif
If !clalev([M:SOH2]) : Local Mask SOH2       [SOH2] : Endif
If !clalev([M:SOH3]) : Local Mask SOH3       [SOH3] : Endif
If !clalev([M:SOH4]) : Local Mask SOH4       [SOH4] : Endif

If !clalev([F:SOH])  : Local File SORDER     [SOH]  : Endif
If !clalev([F:SOQ])  : Local File SORDERQ    [SOQ]  : Endif
If !clalev([F:SOP])  : Local File SORDERP    [SOP]  : Endif
If !clalev([F:BPC])  : Local File BPCUSTOMER [BPC]  : Endif
If !clalev([F:ADI])  : Local File ATABDIV    [ADI]  : Endif

# load the SOH screens
Read [F:SOH]SOH0=ISOHNUM
If fstat
  OMESSAGE = mess(8,492,1)  # "Unable to read SOH"
  ORET = 1 : End
Endif

# check if the order is already on hold
If [F:SOH]HLDCOD=IHLDCOD : End : Endif

# Make any modification here, if changing a line, be sure to set UPDFLG to 1 on the line

# check if any line is being shipped, shipped, or invoiced. If so, warn user
# but only for a manual hold
For I=0 To [M:SOH4]NBLIG-1
  If [M:SOH4]ODLQTY(I)<>0 | [M:SOH4]DLVQTY(I)<>0 | [M:SOH4]INVQTY(I)<>0
    POK = 2  # some lines cannot be placed on hold
  Else
    FOK = 2  # some lines can be placed on hold
  Endif
Next

If POK & FOK                      # manual hold
  Call OUINON(mess(5,492,1),POK) From GESECRAN
  If POK<>2
    OMESSAGE = mess(6,492,1)  # Hold cancelled by user
    ORET = 2 : End
  Endif
Endif

# if any allocation exists, deallocate the order if the hold code does not allow allocations
Read [ADI]CODE=204;IHLDCOD
If !fstat & (sum([M:SOH4]ALLQTY(0..[M:SOH4]NBLIG-1)) | [M:SOH1]ALLSTA>1 | [M:SOH4]DALLTYP=1) & [F:ADI]N1<>2 & !adxlog
  Call OUVRE_TRACE(mess(7,492,1) - [M:SOH0]SOHNUM) From LECFIC
  Gosub INI_TRTORDALL From TRTVENFEN     # defined variables used in TR_ALLOC
  WTRTALL = 2                            # deallocate
  WSHTFLG = 1                            # default value
  WALLCTM = 1
  WALLPAR = 1
  Default Mask [M:SOH0]
  Default Mask [M:SOH1]
  Default Mask [M:SOH2]
  Default Mask [M:SOH3]
  Default Mask [M:SOH4]
  Gosub TR_ALLOC From SUBSOHB            # allocaton routine, updates SOQ, etc.
  Call FERME_TRACE From LECFIC
  Raz GTRACE
Endif

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [SOH] : Endif

Read [SOH]SOH0=ISOHNUM
If fstat
  OMESSAGE = mess(8,492,1) - ISOHNUM # Error reading SOH
  ORET = 2 : Goto OFIN
Endif

[F:SOH]HLDSTA = 2  # order placed on hold
[F:SOH]HLDCOD = IHLDCOD
[F:SOH]HLDUSR = GUSER
[F:SOH]HLDDAT = date$
[F:SOH]HLDTIM = time$

Rewrite [SOH]
If fstat
  OMESSAGE = mess(9,492,1) - ISOHNUM # Error rewriting SOH
  ORET = 2 : Goto OFIN
Endif

$OFIN
If !TMP_ADXLOG
  If ORET
    Rollback
    GOK = 0
    End
  Else
    Commit
  Endif
Endif

If dim([M:SOH1]HLDSTA)>0
  [M:SOH1]HLDSTA = [F:SOH]HLDSTA
  [M:SOH1]HLDCOD = [F:SOH]HLDCOD
  Affzo [M:SOH1]: Affzo [M:SOH4]
Endif

End

####################################################################################
Subprog IMPHLD(IHLDCOD)
Value    Char    IHLDCOD

If IHLDCOD="" | dim([M:SOH1]HLDSTA)<=0 : End : Endif

If !clalev([F:ADI])  : Local File ATABDIV    [ADI]  : Endif

# if any allocation exists, deallocate the order if the hold code does not allow allocations
Read [ADI]CODE=204;IHLDCOD
If fstat
  Call RSTA("ADI","204"-IHLDCOD) From GLOCK
  Raz [F:SOH]HLDCOD : End
Endif
[M:SOH1]HLDSTA = 2
[M:SOH1]HLDCOD = IHLDCOD

End

####################################################################################
# Subprogram : GET_USER_LOGIN
#
# Description : Retrieves the users login from user code.
####################################################################################
Funprog GET_USER_LOGIN(USER)
Value    Char USER

If !clalev([F:AUS])  : Local File AUTILIS     [AUS]  : Endif

Read [AUS]CODUSR=USER
If fstat : End USER : Endif

End [F:AUS]LOGIN


#####################################################################################
$HLD_PROP    # File > properties from GESSOH
Local Integer HLD

If ABFIC<>"SOH" : Return : Endif # Sales Orders only

HLD = 0
 If dim([F:SOH]HLDCOD)>0 | dim([F:SOH]HLDCODP)>0
   If [F:SOH]HLDCOD="" & [F:SOH]HLDCODP<>""  # Held and released
    HLD = 1
    VISNBR += 1
    VISDES(VISNBR) = mess(10,492,1) : # Held on
    VISVAL(VISNBR) = format$("D:"+GFMDAT,[F:SOH]HLDDATP)
    VISVAL(VISNBR) -= [F:SOH]HLDTIMP
    NOMUSER = func SUBAOP.NOMUSER([F:SOH]HLDUSRP)
    If NOMUSER<>""
     VISVAL(VISNBR) -= mess(161,124,1)-NOMUSER-"("+evalue("[F:SOH]HLDUSRP")+")" : # user
    Else
     VISVAL(VISNBR) -= mess(161,124,1)-"("+evalue("[F:SOH]HLDUSRP")+")" : # user
    Endif
   Elsif [F:SOH]HLDCOD<>"" & [F:SOH]HLDCODP<>""  # Held and released and held again
    HLD = 1
    VISNBR += 1
    VISDES(VISNBR) = mess(10,492,1) : # Held on
    VISVAL(VISNBR) = format$("D:"+GFMDAT,[F:SOH]HLDDAT)
    VISVAL(VISNBR) -= [F:SOH]HLDTIM
    NOMUSER = func SUBAOP.NOMUSER([F:SOH]HLDUSR)
    If NOMUSER<>""
     VISVAL(VISNBR) -= mess(161,124,1)-NOMUSER-"("+evalue("[F:SOH]HLDUSR")+")" : # user
    Else
     VISVAL(VISNBR) -= mess(161,124,1)-"("+evalue("[F:SOH]HLDUSR")+")" : # user
    Endif
   Endif
   If [F:SOH]HLDCOD<>"" & [F:SOH]HLDCODP=""  # Held
    HLD = 1
    VISNBR += 1
    VISDES(VISNBR) = mess(10,492,1) : # Held on
    VISVAL(VISNBR) = format$("D:"+GFMDAT,[F:SOH]HLDDAT)
    VISVAL(VISNBR) -= [F:SOH]HLDTIM
    NOMUSER = func SUBAOP.NOMUSER([F:SOH]HLDUSR)
    If NOMUSER<>""
     VISVAL(VISNBR) -= mess(161,124,1)-NOMUSER-"("+evalue("[F:SOH]HLDUSR")+")" : # user
    Else
     VISVAL(VISNBR) -= mess(161,124,1)-"("+evalue("[F:SOH]HLDUSR")+")" : # user
    Endif
   Endif
 Endif
 If HLD
   If dim([F:SOH]HLDCODP)>0 & [F:SOH]HLDCODP<>"" & [F:SOH]HLDCOD="" # released order
    VISNBR += 1
    VISDES(VISNBR) = mess(11,492,1) : # Released on
    VISVAL(VISNBR) = format$("D:"+GFMDAT,[F:SOH]HLDDAT)
    VISVAL(VISNBR) -= [F:SOH]HLDTIM
    NOMUSER = func SUBAOP.NOMUSER([F:SOH]HLDUSR)
    If NOMUSER<>""
     VISVAL(VISNBR) -= mess(161,124,1)-NOMUSER-"("+evalue("[F:SOH]HLDUSR")+")" : # user
    Else
     VISVAL(VISNBR) -= mess(161,124,1)-"("+evalue("[F:SOH]HLDUSR")+")" : # user
    Endif
   Endif
 Endif
Return


####################################################################################
$MANHLD_LIENS

If dim([M:SOH1]HLDSTA)<=0 : Return : Endif

If [M:SOH1]HLDSTA<1 : [M:SOH1]HLDSTA=1 : Endif

# parameter allows manual order holds
Local Integer WCDTUNL, WHLDREL        # 104899.o - Add new WHLDREL variable.
Local Char    WPARAM(10), WPARAM1(10) # 104899.o - Add new WPARAM1(10) array.

Call PARAMUTIL("SCDTUNL",WPARAM,"",[M:SOH0]SALFCY) From SUBAUS
WCDTUNL=val(WPARAM)
If WCDTUNL=0 WCDTUNL=1 Endif

If GREP="" & WCDTUNL=2
  # parameter allows credit hold release
  If find([M:SOH1]CDTSTA,2,3) | (GLOKORD=2 & [M:SOH1]CDTSTA=4)
    Actzo [M:SOH1]CDTBTN
  Else
    Grizo [M:SOH1]CDTBTN
  Endif
Else
  Grizo [M:SOH1]CDTBTN              # 104899.o - Remove the HLDBTN.
Endif

# 104899.sn - Manual order hold parameter.
Call PARAMUTIL("HLDREL",WPARAM1,GUSER,"") From SUBAUS
WHLDREL=val(WPARAM1)
If WHLDREL=0 WHLDREL=1 Endif

# Process only when the standard action is not in progress.
If GREP=""
  If WHLDREL=2  # Authorize manual order hold is Yes
    Actzo [M:SOH1]HLDBTN    # Enable the Order hold button
  Else
    # Enable the order hold button when the order is not on hold or
    # when the hold was put in place by the same user. Else, disable the Order hold button.
    If [M:SOH1]HLDSTA = 2 & GUSER <> [F:SOH]HLDUSR
      Grizo [M:SOH1]HLDBTN    # Disable the order hold button
    Else
      Actzo [M:SOH1]HLDBTN    # Enable the order hold button
    Endif
  Endif
Else
  Grizo [M:SOH1]HLDBTN
Endif
# 104899.en

Affzo [M:SOH1]HLDCOD,HLDSTA,CDTSTA

# hide icon if order closed
If [M:SOH1]ORDSTA>1
 Chgfmt [M:SOH1]HLDBTN With "-K:3X"
 Chgfmt [M:SOH1]CDTBTN With "-K:3X"
Else
 Chgfmt [M:SOH1]HLDBTN With "K:3X"
 Chgfmt [M:SOH1]CDTBTN With "K:3X"
Endif
Return

#################################################################################################
Funprog BLK_ALLOC(HLDSTA,HLDCOD)
Value Integer HLDSTA
Value Char    HLDCOD
If !clalev([F:ADI])  : Local File ATABDIV    [ADI]  : Endif
If [L]HLDSTA>1  # Manual hold
  Read [ADI]CODE=204;[L]HLDCOD
  If !fstat & [F:ADI]N1<>2  # disallow allocation
    End 1
  Endif
Endif
End 0
#################################################################################################
# TODAN-X3-25070 119459 Manual order hold control on blocking the back to back orders.
#################################################################################################
Funprog BLK_BACK_TO_BACK(HLDSTA,HLDCOD)
Value Integer HLDSTA
Value Char    HLDCOD

Local Integer BLOCK_BTB

  BLOCK_BTB = [V]CST_ANO

  If !clalev([F:ADI])  : Local File ATABDIV    [ADI]  : Endif
  If [L]HLDSTA > 1  # Manual hold
    Read [ADI]CODE = 204;[L]HLDCOD
    If !fstat & [F:ADI]N2 = [V]CST_AYES  # Found and block back-to-back orders
      BLOCK_BTB =  [V]CST_AYES
    Endif
  Endif
End BLOCK_BTB
#################################################################################################

