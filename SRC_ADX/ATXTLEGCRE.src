#<AdxTL>@(#)0.0.0.0 $Revision$
# Create legacy text - X3PLAT-418

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"ATXTLEGCRE","ATXTLEGCRE","",1,"XYATXTLEGCRE") From GTRAITE
End

$ACTION
Case ACTION
  When "INIT"       : Gosub INIT
  When "OK"         : Gosub ATXTLEGSEL
Endcase
Return

$INIT
If func AFNC.PARAMDOS(nomap,"ATXTSRV")<>"2"
  GMESSAGE = mess(74,100,1)
  GERR=1
  Return
Endif

If GLANGUE<>"FRA" & GLANGUE<>"ENG"
  GMESSAGE = func AFNC.MES2(mess(325,123,1), "FRA", "ENG")
  GERR=1
  Return
Endif

Local Integer OK , NUM
If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
Local Mask ATXTLEGCRE [DIA]
Raz [M:DIA]
Return

$ATXTLEGSEL
Local Char TEXT(80),MESSAGE(250)
Local Integer ASTATUS,NUM
# Determine if text exists
Filter [F:ATX] Where LAN=GLANGUE & TEXTE=[M:DIA]TEXTE & COMMENT=[M:DIA]COMMENT & [F:ATX]NUMERO < GMAXTXTSTD
Read [F:ATX]First
Filter [F:ATX]
If fstat=[V]CST_AOK
  # If text defined issue message and done
  [L]MESSAGE = mess(29,123,1)-num$([F:ATX]NUMERO)
  #TODO: remove next line - for deleting text added by RBU
Else
  # If new text to be created
  Call OUINON(mess(326,123,1),OK) From GESECRAN
  If OK = [V]CST_AYES
    # create new text in text server
    Gosub INIT_LANGS
    [L]ASTATUS = func ATXTSVC.CREATE_TEXT_LEGACY_CHAR(GPRODUIT, GLANGUE, [L]LANGS, [M:DIA]TEXTE, [M:DIA]COMMENT, [L]NUM, [L]MESSAGE)
    If [L]ASTATUS<>[V]CST_AOK | [L]NUM<=0
      # Text creation failed on text server
      [L]MESSAGE=mess(327,123,1)-[L]MESSAGE
      GOK = 0
    Else
      # Text creation successful on text server-create ATEXTE rows
      [L]ASTATUS = func ATXTSVC.GET_TEXT(GPRODUIT, [L]NUM, GLANGUE, TEXT, MESSAGE)
      If [L]ASTATUS = [V]CST_AOK
        # Insert ATEXTE rows using CHECK_TEX
        Gosub CHECK_TEX From OBJDIV
        If GOK=[V]CST_ATRUE
          # ATEXTE creation successful
          [L]MESSAGE = func AFNC.MES1(mess(328,123,1),num$([L]NUM))
        Else
          # If ATEXTE insert fails then remove text from text server
          [L]ASTATUS = func ATXTSVC.DELETE_TEXT(GPRODUIT, [L]NUM, MESSAGE)
          If [L]ASTATUS = [V]CST_AOK
            [L]MESSAGE = mess(327,123,1)
          Else
            [L]MESSAGE = mess(327,123,1)-[L]MESSAGE
          Endif
        Endif
      Else
        # Text server create text failed
        [L]MESSAGE = mess(327,123,1)-[L]MESSAGE
      Endif
    Endif
  Endif
Endif
# Print message - either successful or fail
Call MESSAGE([L]MESSAGE) From GESECRAN

Return

# Return list of languages in LANGS(0..(
$INIT_LANGS
Local Char LANGS(3)(0..)
Local Integer NBLANGS
Local File ADOSSIER [ADS]
Local Integer AI
If func DOSSUB.FILL_ADS(nomap)
 For AI=0 To [F:ADS]NBRLAN-1
  LANGS(AI) = [F:ADS]LAN(AI)
  NBLANGS+=1
 Next AI
Endif
Return

