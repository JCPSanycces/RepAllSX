#<AdxTL>@(#)9.0.0.0 $Revision$
##################################################### 
# DOSDICOBJ Remplissage du dico des objets 
##################################################### 
$DICOBJ 
Call ECR_TIME(mess(15,125,1)-mess(18,125,1)) From DOSSUB
# MAJ dictionnaire - Objets 
Local File =GDOSREF+".AOBJET"  [AOB]
&         ,=GDOSREF+".AOBJET"  [AOB2]
&         ,=GDOSREF+".AOBJTAB" [AOT]
&         ,=GDOSREF+".AOBJLST" [AOL]
Local File =GDOSX3+".AOBJLST"  [AOLX]
Local File =[F:ADS]DOSSIER+".AOBJET"    [DAOB] 
&        , =[F:ADS]DOSSIER+".AOBJET"    [DAO2] 
&        , =[F:ADS]DOSSIER+".AWINBRO"   [DAWB] 
&        , =[F:ADS]DOSSIER+".AOBJTAB"   [DAOT] 
&        , =[F:ADS]DOSSIER+".AOBJTAB"   [DAT2] 
&        , =[F:ADS]DOSSIER+".AOBJLST"   [DAOL] 
&        , =[F:ADS]DOSSIER+".AOBJLNK"   [DAOK] 
&        , =[F:ADS]DOSSIER+".AOBJLNK"   [DAK2] 
&        , =[F:ADS]DOSSIER+".ACTIV"     [DACV]
&        , =[F:ADS]DOSSIER+".ATABLE"    [DATB]
&        , =[F:ADS]DOSSIER+".ATABZON"   [DATZ]
&        , =[F:ADS]DOSSIER+".ATABIND"   [DATI]
&        , =[F:ADS]DOSSIER+".AVIEW"     [DAVW]

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(18,125,1),"") From GESECRAN
Endif
GNBAOB = 0 

## Effacement anciens objets

If !GCRE   
 Trbegin [DAOB], [DAOT], [DAOL]   
  For [DAOB]ABREV Where ABREV<GXX
   Call SPEC([F:DAOB]CODACT,SPEC) From DOSSUB   
   If !SPEC   
    Read [AOB]ABREV = [F:DAOB]ABREV   
    If fstat 
     Call EFFACE([F:DAOB]ABREV)
    Endif   
   Endif   
  Next   
 Commit   
Endif  

## Mise à jour

For [AOB]ABREV Where ABREV<GXX
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(18,125,1),[F:AOB]ABREV) From GESECRAN
 Endif
 ACTIV = 0
 Read [AOL]AOL0  = [F:AOB]ABREV 
 Trbegin [DAOB] 
  OLD  = 0 
  SPEC = 0 
  RWO  = 0
  Read [DAOB]ABREV = [F:AOB]ABREV 
  If !fstat 
   OLD = 1 
   Call SPEC([F:DAOB]CODACT,SPEC) From DOSSUB 
  Endif 
  Call NEWREC([F:ADS]DOSSIER,[F:AOB]CODACT,[F:AOB]MODULE,NEWREC) From DOSSUB 
  If !SPEC 
   If OLD & !NEWREC : # On le vire 

    Call EFFACE([F:AOB]ABREV)

   Elsif NEWREC & !OLD  

    GNBAOB += 1 : RWO = 1
    Raz [F:DAOB] 
    [F:DAOB] = [F:AOB] 
    [F:DAOB]UPDFLG = 1 
    [F:DAOB]CREDAT = date$ 
    [F:DAOB]CREUSR = GUSER
    If dim([F:DAOB]CRETIM)>0 : [F:DAOB]CRETIM = time : Endif
    Write [DAOB] 
    If fstat : Call ERREUR("AOBJET"-[F:DAOB]ABREV,1) From DOSDIC : Endif 
    For [AOT]ABREV Where ABREV=[F:AOB]ABREV
     Call NEWREC([F:ADS]DOSSIER,[F:AOT]TABACT,0,NEWREC2) From DOSSUB   
     If NEWREC2  
     [F:DAOT] = [F:AOT]
      Write [DAOT]
      If fstat : Call ERREUR("AOBJTAB"-[F:DAOB]ABREV,1) From DOSDIC : Endif 
     Endif
    Next
    [F:DAOL] = [F:AOL]
    Write [DAOL]
    If fstat : Call ERREUR("AOBJLST"-[F:DAOB]ABREV,1) From DOSDIC : Endif 

   Elsif NEWREC & OLD  

    Read [DAOL]AOL0 = [F:AOB]ABREV
    DIFF = 0  

    ## Comparaison de l'en-tête

    If [F:AOB]CODACT    <> [F:DAOB]CODACT     : DIFF = 1 : Endif  
    If [F:AOB]LIBEL     <> [F:DAOB]LIBEL      : DIFF = 1 : Endif  
    If [F:AOB]LIBSHO    <> [F:DAOB]LIBSHO     : DIFF = 1 : Endif  
    If [F:AOB]LIBPAR    <> [F:DAOB]LIBPAR     : DIFF = 1 : Endif  
    If [F:AOB]MODULE    <> [F:DAOB]MODULE     : DIFF = 1 : Endif  
    If [F:AOB]MENU      <> [F:DAOB]MENU       : DIFF = 1 : Endif  
    If [F:AOB]RANG      <> [F:DAOB]RANG       : DIFF = 1 : Endif  
    If [F:AOB]NBOPT     <> [F:DAOB]NBOPT      : DIFF = 1 : Endif  
    If [F:AOB]NBRIMP    <> [F:DAOB]NBRIMP     : DIFF = 1 : Endif  
    If [F:AOB]NOMFIC    <> [F:DAOB]NOMFIC     : DIFF = 1 : Endif  
    If [F:AOB]TYPGES    <> [F:DAOB]TYPGES     : DIFF = 1 : Endif  
    If [F:AOB]ZSITE     <> [F:DAOB]ZSITE      : DIFF = 1 : Endif 
    If [F:AOB]ZACC      <> [F:DAOB]ZACC       : DIFF = 1 : Endif 
    If [F:AOB]IMPORT    <> [F:DAOB]IMPORT     : DIFF = 1 : Endif 
    If dim([F:AOB]ABRFIC)>0 & dim([F:DAOB]ABRFIC)>0
     If [F:AOB]ABRFIC    <> [F:DAOB]ABRFIC     : DIFF = 1 : Endif 
    Endif
    If dim([F:AOB]FCYDEP)>0 & dim([F:DAOB]FCYDEP)>0
     If [F:AOB]FCYDEP    <> [F:DAOB]FCYDEP     : DIFF = 1 : Endif 
    Endif
    If !DIFF : Call TXT([F:AOB]LIBEL,DIFF)  From DOSSUB : Endif
    If !DIFF : Call TXT([F:AOB]LIBPAR,DIFF) From DOSSUB : Endif
    # mb 9.4.14 bug 98467 
    # Pour permettre la validation d'un objet combiné/tableau lié à un code activité qui dimensionne le tableau dans l'écran associé
    If !DIFF : Call DIFFACT([F:ADS]DOSSIER,[F:AOB]CODACT,ACTIV) From DOSSUB : Endif

    # Comparaison des vues
  
    For I=0 To [F:AOB]NBVUE-1
     If !find([F:DAOB]VUEACT,GSPE(1..GNBSPE))
      If [F:AOB]VUECOD(I)  <> [F:DAOB]VUECOD(I)  : DIFF = 1 : Break : Endif 
      If [F:AOB]VUEABR(I)  <> [F:DAOB]VUEABR(I)  : DIFF = 1 : Break : Endif 
     Endif
    Next I

    ## Comparaison des tables  

    If !DIFF
     For [AOT]ABREV Where ABREV=[F:AOB]ABREV
      Read [DAOT]TABFIC = [F:AOT]ABREV;[F:AOT]TABFIC;[F:AOT]TABABR
      If fstat
       DIFF = 1 : Break
      Elsif !find([F:DAOT]TABACT,GSPE(1..GNBSPE))
       If [F:AOT]TABFIC  <> [F:DAOT]TABFIC   : DIFF = 1 : Endif  
       If [F:AOT]TABLIEN <> [F:DAOT]TABLIEN  : DIFF = 1 : Endif  
       If [F:AOT]TABABR  <> [F:DAOT]TABABR   : DIFF = 1 : Endif  
       If [F:AOT]TABACT  <> [F:DAOT]TABACT   : DIFF = 1 : Endif  
       If DIFF : Break : Endif
      Endif
      Call DIFFACT([F:ADS]DOSSIER,[F:AOT]TABACT,ACTIV) From DOSSUB
     Next
    Endif 
    If !DIFF
     For [DAOT]ABREV Where ABREV=[F:AOB]ABREV
      If !find([F:DAOT]TABACT,GSPE(1..GNBSPE))
       Read [AOT]TABFIC = [F:DAOT]ABREV;[F:DAOT]TABFIC;[F:DAOT]TABABR
       If fstat
        DIFF = 1 : Break
       Endif
      Endif
      Call DIFFACT([F:ADS]DOSSIER,[F:DAOT]TABACT,ACTIV) From DOSSUB
     Next
    Endif 

    ## Comparaison des écrans supp
 
    If !DIFF
     For B=0 To [F:AOB]NBSCR-1
      If [F:AOB]SCRNAM(B)    <> [F:DAOB]SCRNAM(B)     : DIFF = 1 : Endif  
      If [F:AOB]SCRABR(B)    <> [F:DAOB]SCRABR(B)     : DIFF = 1 : Endif  
     Next B
    Endif

    ## Comparaison des options de sélection

    If !DIFF  
     For B=0 To [F:AOB]NBOPT-1  
      If [F:AOB]OPTCND(B)    <> [F:DAOB]OPTCND(B)     : DIFF = 1 : Endif  
      If [F:AOB]OPTCOD(B)    <> [F:DAOB]OPTCOD(B)     : DIFF = 1 : Endif  
      If [F:AOB]OPTERR(B)    <> [F:DAOB]OPTERR(B)     : DIFF = 1 : Endif  
      If [F:AOB]OPTLIB(B)    <> [F:DAOB]OPTLIB(B)     : DIFF = 1 : Endif  
     Next  
    Endif  

    ## Comparaison des masques d'import-export

    If !DIFF
     For B=0 To [F:AOB]NBRIMP-1
      If [F:AOB]IMPTBL(B)    <> [F:DAOB]IMPTBL(B)     : DIFF = 1 : Endif
      If [F:AOB]IMPMSK(B)    <> [F:DAOB]IMPMSK(B)     : DIFF = 1 : Endif
      If [F:AOB]IMPTAB(B)    <> [F:DAOB]IMPTAB(B)     : DIFF = 1 : Endif
     Next B
    Endif

    ## Comparaison de [AOL] + vérif si les zones existent toujours

    If !DIFF
     If [F:AOL]DELDEF <> [F:DAOL]DELDEF    : DIFF = 1 : Endif
     For B=0 To [F:DAOL]NBSEL-1
      If [F:DAOL]SELFIC(B)<>""
       Look [DATZ]CODZONE = [F:DAOL]SELFIC(B) ; [F:DAOL]SELZON(B)
       If fstat :  DIFF = 1 : Break : Endif
      Endif
     Next B
    Endif

    # Comparaison champs impression et liste

     If !DIFF & [F:DAOB]RPT1="" & [F:AOB]RPT1<>""
      DIFF = 1
     Endif
     If !DIFF & [F:DAOB]RPT2="" & [F:AOB]RPT2<>""
      DIFF = 1
     Endif

    ## Réécriture si modifié

    If DIFF 
     If GTSTDOS
      Call ECR_TRACE("Diff objet"-[F:AOB]ABREV-num$(DIFF),0) From GESECRAN
     Endif
     GNBAOB += 1 : RWO = 1
     [F:DAO2] = [F:DAOB]
     [F:DAOB] = [F:AOB]

     # Vues

     For I=0 To [F:DAOB]NBVUE-1
      If !find([F:DAOB]VUEACT(I),GSPE(1..GNBSPE)) & [F:DAOB]VUECOD(I)<>""
       K = 0
       For J=0 To [F:AOB]NBVUE-1
        If [F:AOB]VUECOD(J)=[F:DAOB]VUECOD(I) & [F:AOB]VUEABR(J)=[F:DAOB]VUEABR(I)
         K = 1 : Break
        Endif
       Next J
       If !K
        Dela I,1 [F:DAOB]VUECOD,[F:DAOB]VUEABR,[F:DAOB]VUEACT
        [F:DAOB]NBVUE -= 1
       Endif
      Endif
     Next I
     For I=0 To [F:AOB]NBVUE-1
      K = 0
      For J=0 To [F:DAOB]NBVUE-1
       If [F:DAOB]VUECOD(J)=[F:AOB]VUECOD(I) & [F:DAOB]VUEABR(J)=[F:AOB]VUEABR(I)
        K = 1 : Break
       Endif
      Next J
      If !K
       [F:DAOB]VUECOD([F:DAOB]NBVUE) = [F:AOB]VUECOD(I)
       [F:DAOB]VUEABR([F:DAOB]NBVUE) = [F:AOB]VUEABR(I)
       [F:DAOB]VUEACT([F:DAOB]NBVUE) = [F:AOB]VUEACT(I)
       [F:DAOB]NBVUE += 1
      Endif
     Next I
     For I=0 To [F:DAOB]NBVUE-1
      If [F:DAOB]VUECOD(I)<>"" & left$([F:DAOB]VUECOD(I),1)<>"W"
       Look [DAVW]AVW0 = [F:DAOB]VUECOD(I)
       If fstat
        Dela I,1 [F:DAOB]VUECOD,[F:DAOB]VUEABR,[F:DAOB]VUEACT
        [F:DAOB]NBVUE -= 1
       Endif
      Endif
     Next I

     # Zones protégées par code activité

     LIGNUM = 0
     For [DAOT]ABREV Where ABREV=[F:AOB]ABREV
      If find([F:DAOT]TABACT,GSPE(1..GNBSPE))
       LIGNUM += 1
       [F:DAOT]NUMLIG = LIGNUM
       Rewrite [DAOT]
       If fstat : Call ERREUR("AOBJTAB"-[F:AOB]ABREV,2) From DOSDIC : Endif 
      Else
       Delete [DAOT]
       If fstat : Call ERREUR("AOBJTAB"-[F:AOB]ABREV,3) From DOSDIC : Endif 
     Endif
     Next B
     For [AOT]ABREV Where ABREV=[F:AOB]ABREV
      Call NEWREC([F:ADS]DOSSIER,[F:AOT]TABACT,0,K) From DOSSUB
      If K
       Read [DAOT]TABFIC = [F:AOT]ABREV;[F:AOT]TABFIC;[F:AOT]TABABR
       If fstat
        [F:DAOT] = [F:AOT]
        LIGNUM += 1
        [F:DAOT]NUMLIG = LIGNUM
        Write [DAOT]
        If fstat : Call ERREUR("AOBJTAB"-[F:AOB]ABREV,1) From DOSDIC : Endif 
       Endif
      Endif
     Next

     # Zones attribuées à l'utilisateur (+ toute la table AOBJLST)

     [F:DAOB]SELCLE  = [F:DAO2]SELCLE
     [F:DAOB]SELORD  = [F:DAO2]SELORD
     [F:DAOB]SELTREE = [F:DAO2]SELTREE
     [F:DAOB]SELCAR  = [F:DAO2]SELCAR
     [F:DAOB]SELOPT  = [F:DAO2]SELOPT
     If [F:DAO2]RPT1<>""
      [F:DAOB]RPT1    = [F:DAO2]RPT1
     Endif
     If [F:DAO2]RPT2<>""
      [F:DAOB]RPT2    = [F:DAO2]RPT2
     Endif
     [F:DAOB]LIBSHO  = [F:DAO2]LIBSHO
     [F:DAOB]STA     = [F:DAO2]STA
     If dim([F:DAOB]MLOCK)>0 & dim([F:DAO2]MLOCK)>0
      [F:DAOB]MLOCK   = [F:DAO2]MLOCK
     Endif
     If dim([F:DAOB]ARCURL)>0 & dim([F:DAO2]ARCURL)>0
      [F:DAOB]ARCURL   = [F:DAO2]ARCURL
     Endif
     For B=0 To [F:DAO2]NBOPT-1
      If [F:DAO2]OPTCOD(B)>"W" & !find([F:DAO2]OPTCOD(B),[F:DAOB]OPTCOD(0..[F:DAOB]NBOPT-1))
       [F:DAOB]OPTCOD([F:DAOB]NBOPT) = [F:DAO2]OPTCOD(B)
       [F:DAOB]OPTCND([F:DAOB]NBOPT) = [F:DAO2]OPTCND(B)
       [F:DAOB]OPTERR([F:DAOB]NBOPT) = [F:DAO2]OPTERR(B)
       [F:DAOB]OPTLIB([F:DAOB]NBOPT) = [F:DAO2]OPTLIB(B)
       [F:DAOB]NBOPT += 1
      Endif
     Next B

     [F:DAOB]UPDFLG = 1  
     [F:DAOB]UPDDAT = date$ 
     [F:DAOB]UPDUSR = GUSER 
     If dim([F:DAOB]UPDTIM)>0 : [F:DAOB]UPDTIM = time : Endif
     [F:DAOL]DELDEF = [F:AOL]DELDEF
     Rewrite [DAOL]
     If fstat : Call ERREUR("AOBJLST"-[F:DAOL]ABREV,2) From DOSDIC : Endif 
     Rewrite [DAOB] 
     If fstat : Call ERREUR("AOBJET"-[F:DAOB]ABREV,2) From DOSDIC : Endif 

    Elsif ACTIV

     [F:DAOB]UPDFLG = 1  
     [F:DAOB]UPDDAT = date$ 
     [F:DAOB]UPDUSR = GUSER 
     If dim([F:DAOB]UPDTIM)>0 : [F:DAOB]UPDTIM = time : Endif
     GNBAOB += 1 : RWO = 1
     Rewrite [DAOB] 
     If fstat : Call ERREUR("AOBJET"-[F:DAOB]ABREV,2) From DOSDIC : Endif 

    Endif
   Endif 
  Endif 

 Commit 

Next  

# Passe pour virer les liaisons inexistantes

Trbegin [DAOK]
 For [DAK2]AOK0
  K = 1
  Look [DAO2]ABREV = [F:DAK2]SRCOBJ
  If fstat : K = 0 : Endif
  If K
   Look [DAO2]ABREV = [F:DAK2]DSTOBJ
   If fstat : K = 0 : Endif
  Endif
  If !K
   Delete [DAOK] Where SRCOBJ=[F:DAK2]SRCOBJ & DSTOBJ=[F:DAK2]DSTOBJ
   If fstat=1 : Call ERREUR("AOBJLNK"-[F:DAK2]SRCOBJ-[F:DAK2]DSTOBJ,3) From DOSDIC : Endif 
  Endif
 Next
Commit

# Passe pour virer les tables inexistantes

Trbegin [DAOT]
 For [DAOT]ABREV Where left$([DAOT]TABFIC,1)<>"W"
  Look [DATB]CODFIC = [F:DAOT]TABFIC
  If fstat
   Delete [DAOT]
   If fstat : Call ERREUR("AOBJTAB"-[F:DAOT]ABREV,3) From DOSDIC : Endif 
   Update [DAOB] Where ABREV=[F:DAOT]ABREV With UPDFLG=1
   If fstat : Call ERREUR("AOBJET"-[F:DAOT]ABREV,2) From DOSDIC : Endif 
  Endif
 Next
Commit

# Passe pour virer les tables/zones inexistantes

Trbegin [DAOL]
 For [DAOL]AOL0
  I = 0
  K = 0
  While I<=[F:DAOL]NBSEL-1 & I<=dim([F:DAOL]SELFIC)-1
   If [F:DAOL]SELFIC(I)<>"" & left$([DAOL]SELFIC(I),1)<>"W"
    Look [DATB]CODFIC = [F:DAOL]SELFIC(I)
    If fstat
     If dim([F:DAOL]SELPCK)>1
      Dela I,1 [F:DAOL]SELFIC,[F:DAOL]SELZON,[F:DAOL]SELEXP,[F:DAOL]SELINT,[F:DAOL]SELTYP,[F:DAOL]SELPCK
&             ,[F:DAOL]SELLNG,[F:DAOL]SELSAI
     Else
      Dela I,1 [F:DAOL]SELFIC,[F:DAOL]SELZON,[F:DAOL]SELEXP,[F:DAOL]SELINT,[F:DAOL]SELTYP
&             ,[F:DAOL]SELLNG,[F:DAOL]SELSAI
     Endif
     [F:DAOL]NBSEL -= 1
     K = 1
    Else
     Look [DATZ]CODZONE = [F:DAOL]SELFIC(I) ; [F:DAOL]SELZON(I)
     If fstat
      If dim([F:DAOL]SELPCK)>1
       Dela I,1 [F:DAOL]SELFIC,[F:DAOL]SELZON,[F:DAOL]SELEXP,[F:DAOL]SELINT,[F:DAOL]SELTYP,[F:DAOL]SELPCK
&              ,[F:DAOL]SELLNG,[F:DAOL]SELSAI
      Else
       Dela I,1 [F:DAOL]SELFIC,[F:DAOL]SELZON,[F:DAOL]SELEXP,[F:DAOL]SELINT,[F:DAOL]SELTYP
&              ,[F:DAOL]SELLNG,[F:DAOL]SELSAI
      Endif
      [F:DAOL]NBSEL -= 1
      K = 1
     Else
      I += 1
     Endif
    Endif
   Else
    I += 1 
   Endif
  Wend
  If K
   Rewrite [DAOL]
   If fstat : Call ERREUR("AOBJLST"-[F:DAOL]ABREV,2) From DOSDIC : Endif 
   Update [DAOB] Where ABREV=[F:DAOL]ABREV With UPDFLG=1
   If fstat : Call ERREUR("AOBJET"-[F:DAOL]ABREV,2) From DOSDIC : Endif 
  Endif
 Next DAOL
Commit

# Pour les listes de gauche hiérarchisée, le nb de champs de sélection >= nb parties de clé de la table

Trbegin [DAOL]
 For [DAOB]
  If [F:DAOB]NOMFIC<>"" & [F:DAOB]SELTREE=2
   CHAINE = [F:DAOB]SELCLE
   Gosub MAJSEL
  Endif
 Next DAOB
 For [DAWB]
  For L=1 To [F:DAWB]NBLIS
   If [F:DAWB]OBJLIS(L-1)<>"" & find([F:DAWB]TRELIS(L-1),2,3)
    Read [DAOB]ABREV=[F:DAWB]OBJLIS(L-1)
    If !fstat & [F:DAOB]NOMFIC<>""
     CHAINE = [F:DAWB]CLELIS(L-1)
     Gosub MAJSEL
    Endif
   Endif
  Next L
 Next DAWB
Commit

Close Local File [AOB] , [AOT] , [AOL] , [DAOB] , [DAOT] , [DAOL] , [DAO2] , [AOLX] , [DAWB]
&              , [DAT2] , [DATZ] , [DACV] , [DATB] , [DAOK] , [DAK2] , [DATI] , [DAVW]
Return 
 
$MAJSEL
Read [DAOL]AOL0=[F:DAOB]ABREV
If !fstat
 If CHAINE<>""
  Read [DATI]CODIND=[F:DAOB]NOMFIC;CHAINE
 Else
  Read [DATI]NUMLIG(2)=[F:DAOB]NOMFIC;1
 Endif
 If !fstat
  K = 0
  CHAINE = [F:DATI]DESCRIPT
  While CHAINE<>""
   I = instr(1,CHAINE,"+")
   J = instr(1,CHAINE,"-")
   If I & J
    I = min(I,J)
   Elsif J & !I
    I = J
   Endif
   K += 1
   If I
    CHAINE = right$(CHAINE,I+1)
   Else
    CHAINE = ""
   Endif
  Wend
  If [F:DAOL]NBSEL<K
   Read [AOLX]AOL0=[F:DAOL]ABREV
   If !fstat & [F:AOLX]NBSEL>=K
    [F:DAOL] = [F:AOLX]
    Rewrite [DAOL]
    If fstat : Call ERREUR("AOBJLST"-[F:DAOL]ABREV,2) From DOSDIC : Endif 
    Update [DAOB] Where ABREV=[F:DAOL]ABREV With UPDFLG=1
    If fstat : Call ERREUR("AOBJET"-[F:DAOL]ABREV,2) From DOSDIC : Endif 
   Endif
  Endif
 Endif
Endif
Return

## Effacement d'un objet

Subprog EFFACE(OBJET)
Value Char OBJET
Call ECR_TRACE(mess(55,125,1)-OBJET,0) From GESECRAN   
Call SUPP_TRT("GES"+OBJET) From DOSSUB
Call SUPP_TRT("WO"+OBJET) From DOSSUB
Delete [DAOT] Where ABREV=OBJET
If fstat=1 : Call ERREUR("AOBJTAB"-OBJET,3) From DOSDIC : Endif   
Delete [DAOL] Where ABREV=OBJET
If fstat=1 : Call ERREUR("AOBJLST"-OBJET,3) From DOSDIC : Endif   
Delete [DAOB] Where ABREV=OBJET
If fstat=1 : Call ERREUR("AOBJET"-OBJET,3) From DOSDIC : Endif   
End

