#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"TRTMHC","TRTMHC","TRTMHC",4,"") From GTRAITE
End

####################################################################################
$ACTION
Case ACTION
 When "INIT"         : Gosub INIT
 When "CONTROLE"     : Gosub CONTROLE
 When "DEBUT"        : Gosub DEBUT
 When "SORTIE"       : Gosub SORTIE
 When "EXEC"         : Gosub EXEC
 When "OK"           : FIN = 1 : GOK = 1
 When "END"          : FIN = 1
Endcase
Return

####################################################################################
$INIT
  Local Char CRITFCY(250), CRITOTHERS(250)
  Local Char FCYGRP(GLONFCY)(1..999)
  Local Integer OK, NOLIG, I, J
  Local Char ZONE1
  Local Char SAVCTRNUM(GLONHRCTR), SAVREFNUM(GLONEML)

  Gosub OUVREFIC

  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

  Case PARAM(1)
    When "MHE"
      Local Mask TRTMHC [DIA], MHE0 [MHS0]
      [M:MHS0] = [M:MHE0]
    When "MHX"
      Local Mask TRTMHC [DIA], MHX0 [MHS0]
      [M:MHS0] = [M:MHX0]
    When "MHC"
      Local Mask TRTMHC [DIA], MHC0 [MHS0]
      [M:MHS0] = [M:MHC0]
  Endcase

  Raz [M:DIA]
  Call LECMEMO("STD","[M:DIA]","mas") From GMEMO
  [M:DIA]ALLCPY = 2
  [M:DIA]ALLFCY = 2
  [M:DIA]ALLPRF = 2
  [M:DIA]ALLSRV = 2
  [M:DIA]ALLPOT = 2
  [M:DIA]ALLJOBPOT = 2
  Effzo [M:DIA]INI
Return

################################################
$DEBUT
  Affzo [DIA]
  Setmok [DIA] With 0
Return

################################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

################################################
$OUVREFIC
  Gosub OUVRE From WPDEFTABLE
  If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
  If !clalev([F:CPY])   : Local File COMPANY  [CPY]   : Endif
  If !clalev([F:FCY])   : Local File FACILITY [FCY]   : Endif
  If !clalev([F:SRV])   : Local File SERVICE  [SRV]   : Endif
  If !clalev([F:PRF])   : Local File PROFIL   [PRF]   : Endif
  If !clalev([F:HRPOP])   : Local File POPUL    [HRPOP]   : Endif
  If !clalev([F:HRPOA])   : Local File POPULA   [HRPOA]   : Endif
  If !clalev([F:FGR])   : Local File FACGROUP [FGR]   : Endif
  If !clalev([F:DIC])   : Local File DICOEMP  [DIC]   : Endif
  If !clalev([F:VRA])   : Local File VARIA    [VRA]   : Endif
  If !clalev([F:CPY2])  : Local File COMPANY  [CPY2]  : Endif
  If !clalev([F:FCY2])  : Local File FACILITY [FCY2]  : Endif

  If clalev([F:MHS])=0
    Case PARAM(1)
      When "MHE"    : Local File MSENTEML [MHS]
      When "MHX"    : Local File MSXITEML [MHS]
      When "MHC"    : Local File MSMODCTR [MHS]
      When Default  : GERR=1 : GMESSAGE = mess(00061,00139,1) : FIN=1
    Endcase
  Endif
Return

$CONTROLE
  If GSTATUT<>GSTAOK
   FIN = 1
  Else
   TMP = 1
   TRA = 1
  Endif
Return

$EXEC
  SYMBOLE = "MAS"+num$(date$)
  Lock =SYMBOLE
  If fstat
   GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
   GERR = 1 : SAI = 1
   Return
  Endif

  Gosub FILTRE

  NOLIG=0
  Gosub FILL_HEADER
  For [FCTR]CTR0
    If ([F:HRCTR]REFNUM<>SAVREFNUM | [F:HRCTR]CTRNUM<>SAVCTRNUM)
      # Multi_leg & multi_société
      Call LECTURE("FCY2",[F:HRCTR]ETRFCY,"") From CONTOBJ
      Call LECTURE("CPY2",[F:FCY2]LEGCPY,"") From CONTOBJ
      GSOCIETE=[F:CPY2]CPY
      GCURLEG=[F:CPY2]LEG

      SAVREFNUM = [F:HRCTR]REFNUM
      SAVCTRNUM = [F:HRCTR]CTRNUM
      OK=1
      MATRI   = [F:HRCTR]REFNUM
      DATMAT  = [F:HRCTR]CTRDAT
      CTR     = [F:HRCTR]CTRNUM
      Gosub LECEMP From WPDEFTABLE
      Call CONTROLE([F:HRCTR]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[M:DIA]CRI,OK,1) From DIVPAYE
      If OK
        Gosub FILL_TABLE
        NOLIG+=1
      Endif
    Endif
  Next

  Case PARAM(1)
    When "MHE"
      [M:MHS0]NBENT = NOLIG
      [M:MHE0] = [M:MHS0]
    When "MHX"
      [M:MHS0]NBXIT = NOLIG
      [M:MHX0] = [M:MHS0]
    When "MHC"
      [M:MHS0]NBMOD = NOLIG
      [M:MHC0] = [M:MHS0]
  Endcase

  Unlock=SYMBOLE
Return

$FILTRE
  #critère société (en tenant compte des non juridiques)
  CRITFCY="1=1"
  If [M:DIA]FCY<>""
   CRITFCY-= '& [F:FCY]FCY="'+[M:DIA]FCY+'"'
  Elsif [M:DIA]CPY<>""
   Read [CPY]CPY0=[M:DIA]CPY
   If !fstat & [F:CPY]CPYLEGFLG=2    : # Société juridique
    CRITFCY-= '& [F:FCY]LEGCPY="'+[M:DIA]CPY+'"'
   Elsif !fstat & [F:CPY]CPYLEGFLG=1 : # Société non juridique
    I=1
    Raz FCYGRP()
    For [FGR]FGR0 Where CPY=[M:DIA]CPY
      If !find([F:FGR]FCY, FCYGRP(1..I))
        FCYGRP(I) = [F:FGR]FCY
        I += 1
      Endif
    Next
    If I>1
      CRITFCY -= '& find([F:FCY]FCY, FCYGRP(1..'+num$(I-1)+'))'
    Endif
   Endif
  Endif

  #Autres critères
  CRITOTHERS="1=1"
  If [M:DIA]SRV<>""
    CRITOTHERS-='& [F:HRCTR]ETRSRV="'+[M:DIA]SRV+'"'
  Endif
  If [M:DIA]PRF<>""
    CRITOTHERS-='& [F:HRCTR]PROPRF="'+[M:DIA]PRF+'"'
  Endif
  If [M:DIA]JOBPOT<>""
    CRITOTHERS-='& [F:HRCTR]JOBPOT="'+[M:DIA]JOBPOT+'"'
  Endif
  If [M:DIA]POT<>""
    CRITOTHERS-='& [F:HRCTR]POT="'+[M:DIA]POT+'"'
  Endif

  If [M:DIA]POP<>""
    Link[HRCTR] With
&     [FCY]FCY0=[F:HRCTR]ETRFCY,
&     [HRPOA]POA0=[M:DIA]POP;[F:HRCTR]REFNUM
&     As [FCTR]
&     Where evalue(CRITFCY) & [F:HRPOA]REFNUM<>"" & evalue(CRITOTHERS)
  Else
    Link[HRCTR] With
&     [FCY]FCY0=[F:HRCTR]ETRFCY
&     As [FCTR]
&     Where evalue(CRITFCY) & evalue(CRITOTHERS)
  Endif
Return

$FILL_HEADER
  [M:MHS0]COD = [M:DIA]COD
  [M:MHS0]DES = [M:DIA]DES
  [M:MHS0]SHO = [M:DIA]SHO
  [M:MHS0]BUD = [M:DIA]BUD
  [M:MHS0]TRN = GFLAG
Return

$FILL_TABLE
  I=NOLIG
  [M:MHS0]ORD(I) = NOLIG+1
  [M:MHS0]ENAFLG1(I) = 2
  [M:MHS0]CTRNUM(I) = [F:HRCTR]CTRNUM
  [M:MHS0]REFNUM(I) = [F:HRCTR]REFNUM
  [M:MHS0]CMTLIG(I) = ""

  #Fill name and firstname
  Read [F:ID]ID0 = [M:MHS0]REFNUM(I)
  If !fstat
   [M:MHS0]NAMSRN(I) = [F:ID]NAM+"-"+[F:ID]SRN
  Endif

  #Set employee fields value
  For J=0 To dim([M:MHS0]FLDEML)-1
    If [M:MHS0]FLDEML(J)<>""
      Read [DIC]DIC0 = [M:MHS0]FLDEML(J)
      If !fstat
        TABLE = [DIC]TBL
        Gosub DEFAUT From WPDEFTABLE
      Endif
      ZONE1 = "[F]"+[M:MHS0]FLDEML(J)

      Case [M:MHS0]TYP(J)
        When 1 #menu local
          If([M:MHS0]NOLIBFLD(J)>0)
            Assign "[M:MHS0]FLDVAL"+num$(J)+"("+num$(I)+")" With mess(evalue(ZONE1),[M:MHS0]NOLIBFLD(J),1)
            Assign "[M:MHS0]VALINT"+num$(J)+"("+num$(I)+")" With mess(evalue(ZONE1),[M:MHS0]NOLIBFLD(J),1)
          Endif
        When 2,3,4,5,6,8 #numérique ou date
          Assign "[M:MHS0]FLDVAL"+num$(J)+"("+num$(I)+")" With num$(evalue(ZONE1))
          Assign "[M:MHS0]VALINT"+num$(J)+"("+num$(I)+")" With num$(evalue(ZONE1))
        When  Default #alphanumérique
          Assign "[M:MHS0]FLDVAL"+num$(J)+"("+num$(I)+")" With evalue(ZONE1)
          Assign "[M:MHS0]VALINT"+num$(J)+"("+num$(I)+")" With evalue(ZONE1)
      Endcase
    Endif
  Next

  ##Get employee variables
#  For J=0 To dim([M:MHS0]VRAEML)-1
#    Assign "[M:MHS0]VRAVAL"+num$(J)+"("+num$(I)+")" With 0
#  Next
#
  ##Specific fields
  Case PARAM(1)
    When "MHE"
      [M:MHS0]NBR(I) = 1
      [M:MHS0]XITDAT(I) = [0/0/0]
      [M:MHS0]ENTDAT(I) = date$
    When "MHX"
      [M:MHS0]XITDAT(I) = date$
      [M:MHS0]DATRPL(I) = [0/0/0]
      [M:MHS0]ENDRPL(I) = [0/0/0]
      [M:MHS0]REFRPL(I) = ""
      [M:MHS0]CTRRPL(I) = ""
    When "MHC"
      [M:MHS0]MODDAT(I) = [0/0/0]
  Endcase
Return

####################################################################################
#                                Etiquettes [M:DIA]
####################################################################################

Subprog C_COD(VALEUR)
  Variable Char    VALEUR()
  Local Char VCRIT
  
  Filter [F:MHS] Where COD=VALEUR
  Look [MHS] First  
  If fstat<=2 #Code existant
    GMESSAGE = mess(33,137,1)
    mkstat=2
  Endif
End

######################################################################################
######################################################################################
## Section automatically added (screen TRTMHC) 25/05/2012 17:32:31 (ADW)
######################################################################################
Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 :  GCURLEG = "" : Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
If dim([F:CPY]LEG)>0
  Call LECTURE("CPY",VALEUR,"") From CONTOBJ
  GCURLEG = [F:CPY]LEG
Endif
End
