#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################################
# UTIGPA201808001   Initialize new weighing parameters: WEICOMSEQC and USRWEI           #
#                   Initialize values to new weighing fields: ITMFACILIT.COMSEQCON,     #
#                   CONTAINERS.CTNMST, STATIONBOX.STAAUZ, and STATIONBOX.MATAUZ         #
#########################################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI Testing") From LECFIC
  Call PATCH([L]WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File

End

#################################################################################
Subprog MAJ_UTIGPA201808001(DOSSIER)
Value Char DOSSIER()

  Local Integer WOUV_TRACE

  If GTRACE = "" Then
    Call OUVRE_TRACE("UTIGPA201808001 : Process for manufacturing") From LECFIC
    WOUV_TRACE = 1
  Endif

  Call ECR_TIME("UTIGPA201808001 Manufacturing Process. Insert into ADOVAL table and initialize WEICOMSEQC & USRWEI parameters") From DOSSUB
  Call INS_WEIPARAM(DOSSIER)

  Call ECR_TIME("UTIGPA201808001 Manufacturing Process. Update ITMFACILIT table and initialize COMSEQCON field") From DOSSUB
  Call UPD_COMSEQFLD(DOSSIER)

  Call ECR_TIME("UTIGPA201808001 Manufacturing Process. Update CONTAINERS table and initialize CTNMST field") From DOSSUB
  Call UPD_CTNMSTFLD(DOSSIER)

  Call ECR_TIME("UTIGPA201808001 Manufacturing Process. Update STATIONBOX table and initialize STAAUZ, MATAUZ fields") From DOSSUB
  Call UPD_AUZFLD(DOSSIER)

  #--------------------------------
  #--------------------------------
  If WOUV_TRACE = 1 Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif

End

##########################################################################
Subprog INS_WEIPARAM(DOSSIER)
Value Char DOSSIER

  If clalev([F:ADW])=0 : Local File =DOSSIER+".ADOVAL"  [ADW]  : Endif

  # -----------------------------------------------------
  Trbegin [ADW]
  Look [F:ADW]ADW0="";"";"WEICOMSEQC"
  If fstat
      Raz [F:ADW]
      [F:ADW]PARAM = "WEICOMSEQC"
      [F:ADW]CREDAT = date$
      [F:ADW]CREUSR = GUSER
      [F:ADW]VALEUR = "1"
      Write [F:ADW]
      If fstat
        Call ECR_TRACE("WEICOMSEQC parameter was not initialized, insert failed",1) From GESECRAN
      Endif
  Endif

  Look [F:ADW]ADW0="";"";"USRWEI"
  If fstat
      Raz [F:ADW]
      [F:ADW]PARAM = "USRWEI"
      [F:ADW]CREDAT = date$
      [F:ADW]CREUSR = GUSER
      [F:ADW]VALEUR = "1"
      Write [F:ADW]
      If fstat
        Call ECR_TRACE("USRWEI parameter was not initialized, insert failed",1) From GESECRAN
      Endif
  Endif

  Commit
  Close Local File [ADW]
  Call ECR_TRACE("Insert ADOVAL for WEICOMSEQC & USERWEI parameters completed",0) From GESECRAN
End

##########################################################################
Subprog UPD_COMSEQFLD(DOSSIER)
Value Char DOSSIER

  Local Integer COMPTEUR

  If clalev([F:ITF])=0 : Local File =DOSSIER+".ITMFACILIT" [ITF] : Endif

  # -----------------------------------------------------
  Trbegin [ITF]
  Update [ITF] Where [F:ITF]COMSEQCON=0 With COMSEQCON=1
  COMPTEUR = adxuprec
  Commit
  # -----------------------------------------------------

  Close Local File [ITF]
  Call ECR_TRACE("Update ITMFACILIT :" - num$(COMPTEUR) - "records updated",0) From GESECRAN

End

##########################################################################
Subprog UPD_CTNMSTFLD(DOSSIER)
Value Char DOSSIER

  Local Integer COMPTEUR

  If clalev([F:CTN])=0 : Local File =DOSSIER+".CONTAINERS" [CTN] : Endif

  # -----------------------------------------------------
  Trbegin [CTN]
  Update [CTN] Where [F:CTN]CTNMST=0 With CTNMST=1
  COMPTEUR = adxuprec
  Commit
  # -----------------------------------------------------

  Close Local File [CTN]
  Call ECR_TRACE("Update CONTAINERS :" - num$(COMPTEUR) - "records updated",0) From GESECRAN

End

##########################################################################
Subprog UPD_AUZFLD(DOSSIER)
Value Char DOSSIER

  Local Integer COMPTEUR

  If clalev([F:SBX])=0 : Local File =DOSSIER+".STATIONBOX" [SBX] : Endif

  # -----------------------------------------------------
  Trbegin [SBX]
  Update [SBX] Where [F:SBX]STAAUZ=0 & [F:SBX]MATAUZ=0 With STAAUZ=1, MATAUZ=1
  COMPTEUR = adxuprec
  Commit
  # -----------------------------------------------------

  Close Local File [SBX]
  Call ECR_TRACE("Update STATIONBOX :" - num$(COMPTEUR) - "records updated",0) From GESECRAN

End

########################################################################
# Executed during integration of patches from EXE patch element type
########################################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER

  If [L]DOSSIER = GDOSX3 and GADONIX <> 2 Then
    End
  Endif

  If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If [F:ADS]MODULE(7) <> 2 : End : Endif

  If !func TABLE_CHECK([L]DOSSIER) Then
    End
  Endif

  Call MAJ_UTIGPA201808001([L]DOSSIER)

End

#######################################################################
# Executed during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER

  If [L]DOSSIER = GDOSX3 and GADONIX <> 2 Then
    End
  Endif

  If [F:ADS]MODULE(7) <> 2 : End : Endif

  If !func TABLE_CHECK([L]DOSSIER) Then
    End
  Endif

  Call MAJ_UTIGPA201808001([L]DOSSIER)

End

########################################################################
# Check for the existence of every table needed
# Verify that the tables are not a view - indicates historic folder
# If any fail this check, do not run the script
########################################################################

Funprog TABLE_CHECK(DOSSIER)
Value Char DOSSIER

  If filinfo(filpath("FIL","ADOVAL","fde",DOSSIER),0)<=0 : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER,"ADOVAL") : End 0 : Endif
  If filinfo(filpath("FIL","ITMFACILIT","fde",DOSSIER),0)<=0 : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "ITMFACILIT") : End 0 : Endif
  If filinfo(filpath("FIL","CONTAINERS","fde",DOSSIER),0)<=0 : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "CONTAINERS") : End 0 : Endif
  If filinfo(filpath("FIL","STATIONBOX","fde",DOSSIER),0)<=0 : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "STATIONBOX") : End 0 : Endif

End 1

