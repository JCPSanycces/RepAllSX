#<AdxTL>@(#)0.0.0.0 $Revision$ 
#Class ESSEMPPERCNT
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES

Case [L]CURPRO
  When "PERCNT.SRNCNT"              : Gosub EMPESS_PERCNT_SRNCNT From EMPESS_CSTD_PRO
  When "PERCNT.NAMCNT"              : Gosub EMPESS_PERCNT_NAMCNT From EMPESS_CSTD_PRO
  When "PERCNT.CNTTYP"              : Gosub EMPESS_PERCNT_CNTTYP From EMPESS_CSTD_PRO
Endcase

Return

