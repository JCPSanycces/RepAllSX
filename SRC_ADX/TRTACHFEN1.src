#<AdxTL>@(#)9.0.0.0 $Revision$
##################################################################################
# TRTACHFEN1          Traitements des fenêtres (Visu)          Module ACHAT      #
# ------------------------------------------------------------------------------ #
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                           #
#   - VISUDETPOH : Visualisation des commandes d'un article                      #
#   - VISUPOHPSH : Visualisation des commandes d'une DA                          #
#   - VISUPWS    : Visualisation des signataires d'une DA ou commande            #
#   - VISUPLP1   : Visualisation des derniers prix de cde d'un fournisseur       #
#   - VISUPLP2   : Visualisation des derniers prix de cde                        #
#   - VISUPOCR   : Visualisation des dernières réceptions d'un contrat           #
#   - VISUETAPOH : Fenêtre de visu de la situation d'une commande                #
#   - VISUVALPOQ : Fenêtre de visu détail valorisation ligne cde ou récept.      #
#                : Fenêtre de visu détail valorisation fact. ajout 29/05/12 muarn#
#   - SAICRITPNH : Fenêtre de saisie de critères en retour                       #
#   - SAIREP1    : Fenêtre de saisie répartition journalière  des qtés           #
#   - SAIREP2    : Fenêtre de saisie répartition hebdomadaire des qtés           #
#   - SAIPCEE    : Saisie des informations douanières                            #
##################################################################################


$ACTION
Case ACTION
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Case GACTION
   When "VISUDETPOH" : Gosub OUV_VISUDETPOH
   When "VISUPOHPSH" : Gosub OUV_VISUPOHPSH
   When "VISUPWS"    : Gosub OUV_VISUPWS
   When "VISUPLP1"   : Gosub OUV_VISUPLP1
   When "VISUPLP2"   : Gosub OUV_VISUPLP2
   When "VISUPOCR"   : Gosub OUV_VISUPOCR
   When "VISUETAPOH" : Gosub OUV_VISUETAPOH
   When "VISUVALPOQ" : Gosub OUV_VISUVALPOQ
   When "SAIPCEE"    : Gosub OUV_SAIPCEE
  Endcase
 When "TITRE"
  #-------------------------------------------#
  # Titre juste avant ouverture de la fenêtre #
  #-------------------------------------------#
  Case GACTION
   When "VISUDETPOH" : TIT=mess(21,195,1)
   When "VISUPWS"    : TIT=mess(22,195,1)-mess(REGLE,512,1)-NUMERO
   When "VISUPLP1"   : TIT=mess(24,195,1)
   When "VISUPLP2"   : TIT=mess(24,195,1)
   When "VISUPOCR"   : TIT=mess(181,195,1)
   When "VISUETAPOH" : TIT=mess(237,198,1)-WNUMCDE
   When "VISUVALPOQ" : Gosub TIT_VISUVALPOQ
   When "SAIREP1"    : TIT=mess(18,195,1)
   When "SAIREP2"    : TIT=mess(32,195,1)
   When "SAICRITPNH" : TIT=mess(367,198,1)
   When "SAIPCEE"
     If PARAM(1)="2" & clalev([M:POC2])
       TIT=mess(247,195,1)-"-"-mess(569,197,1)-":"-[M:POC2]ITMREF
     Endif
  Endcase
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  Case GACTION
   When "VISUDETPOH" : Gosub DEB_VISUDETPOH
   When "VISUPOHPSH" : Gosub DEB_VISUPOHPSH
   When "VISUPWS"    : Gosub DEB_VISUPWS
   When "VISUPLP1"   : Gosub DEB_VISUPLP1
   When "VISUPLP2"   : Gosub DEB_VISUPLP2
   When "VISUPOCR"   : Gosub DEB_VISUPOCR
   When "VISUETAPOH" : Gosub DEB_VISUETAPOH
   When "VISUVALPOQ" : Gosub DEB_VISUVALPOQ
   When "SAICRITPNH" : Gosub DEB_CRITPNH
   When "SAIREP1"    : Gosub DEB_SAIREP1
   When "SAIREP2"    : Gosub DEB_SAIREP2
   When "SAIPCEE"    : Gosub DEB_SAIPCEE
  Endcase
 When "OK"
  #--------------------------------#
  # Après l'exécution du bouton OK #
  #--------------------------------#
  Case GACTION
   When "SAICRITPNH" : Gosub OK_CRITPNH
   When "SAIREP1"    : Gosub OK_SAIREP1
   When "SAIREP2"    : Gosub OK_SAIREP2
   When "SAIPCEE"    : Gosub OK_SAIPCEE
  Endcase
 When "ABA"
  #-------------------------------------#
  # Après l'exécution du bouton ABANDON #
  #-------------------------------------#
  Case GACTION
   When "SAICRITPNH" : Gosub ABA_CRITPNH
   When "SAIREP1"    : Gosub ABA_SAIREP1
   When "SAIREP2"    : Gosub ABA_SAIREP2
   When "SAIPCEE"    : Gosub ABA_SAIPCEE
  Endcase
 When "APRES_MODIF"
  #------------------------------------#
  # Après chaque modification de champ #
  #------------------------------------#
  Case GACTION
   When "SAICRITPNH" : REP="M"
   When "SAIREP1"    : REP="M"
   When "SAIREP2"    : REP="M"
   When "SAIPCEE"    : REP="M"
  Endcase
 When "FINSAI"
  #------------------------------------------#
  # Avant de revenir à la fenêtre précédente #
  #------------------------------------------#
  Case GACTION
   When "VISUDETPOH" : Gosub FINSAI_VISUDETPOH
   When "VISUPOHPSH" : Gosub FINSAI_VISUPOHPSH
   When "VISUPWS"    : Gosub FINSAI_VISUPWS
   When "VISUPLP1"   : Gosub FINSAI_VISUPLP1
   When "VISUPLP2"   : Gosub FINSAI_VISUPLP2
   When "VISUPOCR"   : Gosub FINSAI_VISUPOCR
   When "VISUETAPOH" : Gosub FINSAI_VISUETAPOH
   When "VISUVALPOQ" : Gosub FINSAI_VISUVALPOQ
   When "SAIPCEE"    : Gosub FINSAI_SAIPCEE
   When "SAIREP1"    : Gosub FINSAI_SAIREP1 : #VPO 11/01/11 70581
   When "SAIREP2"    : Gosub FINSAI_SAIREP2 : #VPO 11/01/11 70581
  Endcase
Endcase
Return


#############################################################################
# POPW : Visualisation des commandes d'un article          CG décembre 1997 #
#   WITMREF  : Référence article dont les commandes sont à visualiser       #
# ------------------------------------------------------------------------- #
# Remplacé par l'action VISUDETPOH avec paramètre :                         #
#   VALEUR = zone courante : Référence article                              #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUDETPOH
Local Char     WITMREF(GLONITM) : WITMREF = VALEUR
Local Integer  SAVNOLIGN   : SAVNOLIGN=nolign
If clalev ([F:POH]) = 0  Local File PORDER  [POH] : Endif
If clalev ([F:POP]) = 0  Local File PORDERP [POP] : Endif
If clalev ([F:POQ]) = 0  Local File PORDERQ [POQ] : Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUDETPOH
Raz [M:POPW]
#----- Lecture des commandes par article -----#
If WITMREF <> ""
  Filter [POQ] Where ITMREF=WITMREF & LINCLEFLG<2 Order By ORDDAT Desc
Else
  Filter [POQ] Where LINCLEFLG<2 Order By ORDDAT Desc
Endif
#----- Charger le tableau à partir de POQ car date commande dans POQ -----#
nolign =1
For [POQ] Hint Key POQ2
  [M:POPW] = [F:POQ]
  Read [POP]POP0 = [F:POQ]POHNUM; [F:POQ]POPLIN;1
  If fstat = 0
    [M:POPW] = [F:POP]
  Endif
  If [F:POH]POHNUM<>[F:POQ]POHNUM
    Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
  Endif
  [M:POPW]CUR(nolign-1) = [F:POH]CUR
  nolign += 1
  If nolign = dim([M:POPW]POHNUM) : Break: Endif
Next
Filter [POQ]
[M:POPW]NBCDE = nolign-1
If [M:POPW]NBCDE = 0
  FIN = 1 : GERR = 2 : GMESSAGE =mess(40,194,1) : Return
Endif
Affzo [POPW]1-99
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUDETPOH
nolign=SAVNOLIGN
Return


#############################################################################
# PSOW : Visualisation des commandes d'une DA              CG décembre 1997 #
#   WNUM     : Numéro de la DA dont les commandes sont à visualiser         #
# ------------------------------------------------------------------------- #
# Remplacé par l'action VISUPOHPSH avec paramètre :                MBT 2003 #
#   PARAM(1) = WNUM   : Numéro de la DA                                     #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUPOHPSH
Local Char     WNUM(GLONVCR) : WNUM =PARAM(1)
Local Integer  SAVNOLIGN     : SAVNOLIGN=nolign
If !clalev([F:PSO])  Local File PREQUISO [PSO] : Endif
If !clalev([F:POQ])  Local File PORDERQ  [POQ] : Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUPOHPSH
Raz [M:PSOW]
#----- Chargement du tableaux -----#
nolign=1
For [PSO] PSO0 Where PSHNUM=WNUM
  [M:PSOW]=[F:PSO]
  #-- lecture detail commande
  Read [POQ] POQ0=[F:PSO]POHNUM;[F:PSO]POPLIN;[F:PSO]POQSEQ
  If fstat : Raz [F:POQ] : Endif
  [M:PSOW]ITMREF   (nolign-1)=[F:POQ]ITMREF
  [M:PSOW]RCPDAT   (nolign-1)=[F:POQ]EXTRCPDAT
  [M:PSOW]RCPQTYPUU(nolign-1)=[F:POQ]RCPQTYPUU
  [M:PSOW]POHTYP   (nolign-1)=[F:POQ]POHTYP
  nolign+=1
  If nolign>dim([M:PSOW]PSDLIN)-1 : Break : Endif
Next
[M:PSOW]NBCDE=nolign-1
If [M:PSOW]NBCDE=0
   GERR=2 : FIN=1 : GMESSAGE=mess(40,194,1) : Return
Endif
Affzo [PSOW]1-99
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUPOHPSH
nolign=SAVNOLIGN
Return


########################################################################
# Action VISUPWS Visualisation des signataires d'une DA ou commande    #
# -------------------------------------------------------------------- #
#   PARAM(1) = REGLE  : Type de règle (1=DA, 2=Commande, 3=Contrat)    #
#   PARAM(2) = NUMERO : Numéro de la DA, de la commande ou du contrat  #
#   PARAM(3) = SITE   : Site de la DA, de la commande ou du contrat    #
########################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUPWS
#----- Variables locales -----#
Local Integer  REGLE           : REGLE  = val(PARAM(1))
Local Char     NUMERO(GLONVCR) : NUMERO = PARAM(2)
Local Char     SITE  (GLONFCY) : SITE   = PARAM(3)
Local Integer  SAVNOLIGN       : SAVNOLIGN=nolign
Local Char     FICHIER(GLONATB)
#----- Si paramètres non renseignés alors c'est fini -----#
If REGLE<1 | REGLE>3 | NUMERO="" | SITE=""
   GERR = 1 : FIN = 1 : GMESSAGE = mess(41,194,1) : Return : Endif
#----- Ouverture du fichier si nécessaire -----#
If !clalev ([F:AWS])  Local File AWRKHISSUI  [AWS] : Endif
#-----
Case REGLE
  When 1 : FICHIER="PREQUIS"
  When 2 : FICHIER="PORDER"
  When 3 : FICHIER="PORDER"
Endcase
FIN=1
For [AWS] AWS0 Where instr(1,IDENTGRP,FICHIER)<>0 & instr(1,IDENTGRP,NUMERO)<>0
  FIN=0 : Break
Next
If FIN=1 GERR=2 : GMESSAGE=mess(41,194,1) : Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUPWS
Raz [M:PWS]
nolign=1
#----- Chargement du tableau des signataires -----#
For [AWS] AWS0 Where instr(1,IDENTGRP,FICHIER)<>0 & instr(1,IDENTGRP,NUMERO)<>0
  [M:PWS]=[F:AWS]
  nolign+=1
  If nolign>dim([M:PWS]CHRONO)
    GMESSAGE=mess(26,100,1) : GERR=2 : Break
  Endif
Next
If nolign=1
  GERR=2 : FIN=1 : GMESSAGE=mess(41,194,1) : Return
Endif
[M:PWS]NBLIG=nolign-1
Sorta [M:PWS]NBLIG [M:PWS]NBLIG Order By [M:PWS]IDENTGRP(indice),
&                                        [M:PWS]CHRONO(indice),
&                                        [M:PWS]DATSIG(indice),
&                                        [M:PWS]TIMSIG(indice)
Affzo [PWS]1-99
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUPWS
nolign=SAVNOLIGN
Return


################################################################################
# PLPW : S/P de visualisation des derniers prix commandes         MBT 18/12/97 #
#   FOURN    : Numéro du fournisseur à rechercher  ("" = Tous)                 #
#   REFART   : Référence de l'article à rechercher (Obligatoire)               #
# ---------------------------------------------------------------------------- #
# Remplacé par l'action VISUPLP1 avec paramètres :                MBT 08/12/00 #
#   PARAM(1) = BPSNUM : Numéro du fournisseur à rechercher  (Obligatoire)      #
#   PARAM(2) = ITMREF : Référence de l'article à rechercher (Obligatoire)      #
#       et par l'action VISUPLP2 avec paramètre  :                 HN 23/10/00 #
#   PARAM(1) = BPSNUM : Numéro du fournisseur à rechercher  (Facultatif)       #
#   PARAM(2) = ITMREF : Référence de l'article à rechercher (Obligatoire)      #
################################################################################
#---------------------------------------------------------------------------------#
# Avant l'ouverture de la fenêtre dernières cdes d'un fournisseur et d'un article #
#---------------------------------------------------------------------------------#
$OUV_VISUPLP1
#----- Variables locales -----#
Local Char     FOURN (GLONBPS) : FOURN =PARAM(1)
Local Char     REFART(GLONITM) : REFART=PARAM(2)
Local Integer  SAVNOLIGN       : SAVNOLIGN=nolign
Local Shortint I
#-----
If FOURN="" | REFART="" FIN=1 : Return : Endif
If clalev([F:POH])<=0 Local File PORDER     [POH] : Endif
If clalev([F:POP])<=0 Local File PORDERP    [POP] : Endif
If clalev([F:POQ])<=0 Local File PORDERQ    [POQ] : Endif
If clalev([F:BPS])<=0 Local File BPSUPPLIER [BPS] : Endif
If clalev([F:ITM])<=0 Local File ITMMASTER  [ITM] : Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUPLP1
Raz [M:PLP1] : I=1
If [F:BPS]BPSNUM<>FOURN
  Read [BPS] BPS0=FOURN : If fstat Raz [F:BPS] : Endif
Endif
[M:PLP1]BPSNUM=FOURN
Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
Call FMTREM("PLP1",GCUR)         From TRTPRICE
If [F:ITM]ITMREF<>REFART
  Read [ITM] ITM0=REFART : If fstat Raz [F:ITM] : Endif
Endif
[M:PLP1]ITMREF=REFART
#[M:PLP1]ITMDES=[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PLP1]ITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
Filter [POQ] Where ITMREF=REFART & BPSNUM=FOURN & POHTYP=1 Order By ORDDAT Desc
nolign=1
For [POQ] With Nohint : # Clé spécifique possible
  Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
  If [F:POH]BPSNUM=FOURN
    Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN
    Read [POP] POP0 First : If fstat Raz [F:POP] : Endif
    [M:PLP1]=[F:POP] : [M:PLP1]=[F:POH] : [M:PLP1]=[F:POQ]
    [M:PLP1]PORTYP(nolign-1)=[F:POH]POHTYP
    nolign+=1
    If nolign>99 Break : Endif
  Endif
Next
Filter [POP] : Filter [POQ]
[M:PLP1]NBLIG=nolign-1
[M:PLP1]BPRNAM=[F:BPS]BPSNAM
Affzo [PLP1]1-99
If [M:PLP1]NBLIG=0 GMESSAGE=mess(40,194,1) : GERR=2 : FIN=1 : Endif
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUPLP1
nolign=SAVNOLIGN
Return

#-------------------------------------------------------------#
# Avant l'ouverture de la fenêtre dernières cdes d'un article #
#-------------------------------------------------------------#
$OUV_VISUPLP2
#----- Variables locales -----#
Local Char     FOURN (GLONBPS) : FOURN=PARAM(1)
Local Char     REFART(GLONITM) : REFART=PARAM(2)
Local Integer  SAVNOLIGN       : SAVNOLIGN=nolign
Local Shortint I
Local Decimal  WMNTORG(0..1), WMNTDES(0..1)
Local Integer  SPSTAT
#-----
If REFART="" FIN=1 : Return : Endif
If clalev([F:POH])<=0 Local File PORDER     [POH] : Endif
If clalev([F:POP])<=0 Local File PORDERP    [POP] : Endif
If clalev([F:POQ])<=0 Local File PORDERQ    [POQ] : Endif
If clalev([F:BPS])<=0 Local File BPSUPPLIER [BPS] : Endif
If clalev([F:ITM])<=0 Local File ITMMASTER  [ITM] : Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUPLP2
Raz [M:PLP2]
[M:PLP2]DEVISE=GLOCALDEV
If [F:ITM]ITMREF<>REFART
  Read [ITM] ITM0=REFART : If fstat Raz [F:ITM] : Endif
Endif
[M:PLP2]ITMREF=REFART
#[M:PLP2]ITMDES=[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PLP2]ITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
#----- Filtre sur commande/article -----#
Filter [POQ] Where ITMREF=REFART & POHTYP=1 Order By ORDDAT Desc
#----- Chargement du tableau -----#
nolign=1
For [POQ] With Nohint : # Clé spécifique possible
  Read [POH] POH0=[F:POQ]POHNUM
  If fstat Raz [F:POH] : Endif
  If FOURN="" | [F:POH]BPSNUM=FOURN
    Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN
    Read [POP] POP0 First
    If fstat Raz [F:POP] : Endif
      [M:PLP2]=[F:POP] : [M:PLP2]=[F:POH] : [M:PLP2]=[F:POQ]
      [M:PLP2]PORTYP(nolign-1)=[F:POH]POHTYP
      If [M:PLP2]CUR(nolign-1) <> [M:PLP2]DEVISE
        # Calcul des montants en devise société
        WMNTORG (0) = [M:PLP2]GROPRI(nolign-1)
        WMNTORG (1) = [M:PLP2]NETPRI(nolign-1)
        Call CONVERT_TAB([M:PLP2]CUR(nolign-1),[M:PLP2]DEVISE,[M:PLP2]DEVISE,1,date$,
&                        WMNTORG,WMNTDES,SPSTAT) From TRTDEV
        # Prix brut société
        [M:PLP2]GROPRILOC(nolign-1)  = WMNTDES (0)
        # Prix net société
        [M:PLP2]NETPRILOC(nolign-1)  = WMNTDES (1)
      Else
        # Prix brut société
        [M:PLP2]GROPRILOC(nolign-1)  = [M:PLP2]GROPRI(nolign-1)
        # Prix net société
        [M:PLP2]NETPRILOC(nolign-1)  = [M:PLP2]NETPRI(nolign-1)
      Endif
      nolign+=1
      If nolign>dim([M:PLP2]POHNUM)-1 : Break: Endif
    Endif
Next
Filter [POP] : Filter [POQ]
[M:PLP2]NBLIG=nolign-1
Affzo [PLP2]1-99
If [M:PLP2]NBLIG=0 GMESSAGE=mess(40,194,1) : GERR=2 : FIN=1 : Endif
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUPLP2
nolign=SAVNOLIGN
Return


################################################################################
# POCR : Visualisation des dernières réceptions d'un contrat       CG 10/12/98 #
#   WNUM    : Numéro du contrat                                                #
#   WLIN    : Numéro de ligne de l'article-contrat                             #
# ---------------------------------------------------------------------------- #
# Remplacé par l'action VISUPOCR avec paramètres :                MBT 26/12/00 #
#   PARAM(1) = NUM :  Numéro du contrat                                        #
#   PARAM(2) = LIN :  Numéro de ligne de l'article-contrat                     #
################################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUPOCR
#----- Variables locales -----#
Local Char     WNUM(GLONPOC) : WNUM=PARAM(1)
Local Integer  WLIN          : WLIN=val(PARAM(2))
Local Integer  SAVNOLIGN     : SAVNOLIGN=nolign
If WNUM="" GMESSAGE=mess(161,194,1) : GERR=1 : FIN=1 : Return : Endif
If clalev ([F:PTH])=0  Local File PRECEIPT  [PTH] : Endif
If clalev ([F:PTD])=0  Local File PRECEIPTD [PTD] : Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUPOCR
Raz [M:POCR]
Filter [PTD] Where POHNUM=WNUM & POPLIN=WLIN Order By RCPDAT Desc
#----- chargement du tableau -----#
nolign=1
For [PTD] Hint Key PTD2
  [M:POCR]=[F:PTD]
  nolign+=1
  If nolign>dim([M:POCR]PTHNUM)-1 : Break : Endif
Next
[M:POCR]NBPTD=nolign-1
If [M:POCR]NBPTD=0
  GMESSAGE=mess(161,194,1) : GERR=1 : FIN=1 : Return
Endif
Affzo [POCR]
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUPOCR
Filter [PTD]
nolign=SAVNOLIGN
Return


#############################################################################
# SITUATION_CDE : S/P de visualisation de la situation cde     MBT 22/12/98 #
#   NUMCDE   : Numéro de la commande à traiter                              #
#   ABMSK    : Abréviation du masque écran contenant les lignes             #
# ------------------------------------------------------------------------- #
# Remplacé par l'action VISUETAPOH avec paramètres :           MBT 29/11/00 #
#   PARAM(1) = NUM    : Numéro de la commande à traiter                     #
#   PARAM(2) = WABMSK : Abréviation du masque écran contenant les lignes    #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUETAPOH
#----- Variables locales -----#
Local Char     WNUMCDE(GLONPOH) : WNUMCDE=PARAM(1)
Local Char     WABMSK(4)        : WABMSK =PARAM(2)
Local Shortint SAVGNOLIGN, I
SAVNOLIGN=nolign
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUETAPOH
Raz [M:PDQ3]
Call TEMPON("O") From GESECRAN
#----- Lecture entête commande à traiter si nécessaire -----#
If [F:POH]POHNUM<>WNUMCDE
  Read [POH] POH0=WNUMCDE : If fstat Raz [F:POH] : Endif
Endif
#----- Ouverture des fichiers si nécessaire ----#
If clalev([F:PTD]) <=0 Local File PRECEIPTD [PTD]  : Endif
If clalev([F:PID]) <=0 Local File PINVOICED [PID]  : Endif
If clalev([F:PIDB])<=0 Local File PINVOICED [PIDB] : Endif
#----- Chargement des zones dans le masque -----#
[M:PDQ3]LINNBR   =[F:POH]LINNBR
[M:PDQ3]RCPLINNBR=[F:POH]RCPLINNBR
[M:PDQ3]CLELINNBR=[F:POH]CLELINNBR
[M:PDQ3]INVLINNBR=[F:POH]INVLINNBR
[M:PDQ3]RCPNBR   =[F:POH]RCPNBR
[M:PDQ3]APPFLG   =[F:POH]APPFLG
[M:PDQ3]INVNBR   =[F:POH]INVNBR
[M:PDQ3]PRNFLG   =[F:POH]PRNFLG
Raz I
#----- Chargement du détail lignes commande standard -----#
If WABMSK="POH2"
  Filter [POQ] Where POHNUM=WNUMCDE
  For [POQ]
    [M:PDQ3]ITMREF(I)=[F:POQ]ITMREF
    [M:PDQ3]QTYPUU(I)=[F:POQ]QTYPUU
    [M:PDQ3]INVQTY(I)=[F:POQ]INVQTYPUU
    [M:PDQ3]PUU(I)   =[F:POQ]PUU
    #----- Chargement des réceptions effectuées sur la ligne de commande -----#
    Filter [PTD] Where POHNUM=WNUMCDE & POPLIN=[F:POQ]POPLIN & POQSEQ=[F:POQ]POQSEQ
&                Order By Key PTD2
    For [PTD]
      [M:PDQ3]PUU(I)      =[F:PTD]PUU
      [M:PDQ3]PTHNUM(I)   =[F:PTD]PTHNUM
      [M:PDQ3]PTDLIN(I)   =[F:PTD]PTDLIN
      [M:PDQ3]RCPDAT(I)   =[F:PTD]RCPDAT
      [M:PDQ3]RCPQTYPUU(I)=[F:PTD]QTYPUU
      [M:PDQ3]INVQTYPUU(I)=[F:PTD]INVQTYPUU
      [M:PDQ3]INVNUM(I)   =""
      #-----
      Raz GBIDD3
      For [PID] PID1 Where TYPORI=2
&                        & NUMORI=[F:PTD]PTHNUM
&                        & LINORI=[F:PTD]PTDLIN
        Gosub CHARG_NUMFAC
        GBIDD3+=[F:PID]QTYPUU
        #----- Tenir compte d'éventuels avoirs sur facture -----#
        For [PIDB] PID1 Where TYPORI=4
&                           & NUMORI=[F:PID]NUM
&                           & LINORI=[F:PID]PIDLIN
          If [F:PID]NETPRI=[F:PIDB]NETPRI  GBIDD3-=[F:PIDB]QTYPUU : Endif
          If [M:PDQ3]INVNUM(I)=""
            [M:PDQ3]INVNUM(I)=[F:PIDB]NUM
          Elsif len([M:PDQ3]INVNUM(I))<163
            [M:PDQ3]INVNUM(I)-="_ "+[F:PIDB]NUM
          Endif
        Next
        #-----
        [M:PDQ3]INVQTYPUU(I)=GBIDD3
      Next
      #-----
      If [F:PTD]LININVFLG<>2 | [M:PDQ3]INVNUM(I)="" |
&        [F:POQ]RCPQTYPUU<=sum([M:PDQ3]RCPQTYPUU(0..I))
        For [PID] PID1 Where TYPORI=1
&                          & NUMORI=[F:PTD]POHNUM
&                          & LINORI=[F:PTD]POPLIN
&                          & SEQORI=[F:PTD]POQSEQ
          Gosub CHARG_NUMFAC
        Next
      Endif
      #-----
      I+=1 : [M:PDQ3]NBLIG=I
      If I>dim([M:PDQ3]ITMREF)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break 2 : Endif
    Next
    If [M:PDQ3]ITMREF(I)<>""
     #[M:PDQ3]INVQTYPUU(I)=[F:POQ]INVQTYPUU
      I+=1 : [M:PDQ3]NBLIG=I
    Endif
    If I>dim([M:PDQ3]ITMREF)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
    If I>0 & [M:PDQ3]INVQTY(I-1)<>0 & [M:PDQ3]INVNUM(I-1)=""
      I-=1
      For [PID] PID1 Where TYPORI=1
&                        & NUMORI=[F:POQ]POHNUM
&                        & LINORI=[F:POQ]POPLIN
&                        & SEQORI=[F:POQ]POQSEQ
        Gosub CHARG_NUMFAC
      Next
      I+=1
    Endif
  Next
#----- Chargement du détail lignes commande ouverte -----#
Else
  #----- Rendre invisible les champs non significatifs pour les commandes ouvertes -----#
  Chgtzn [M:PDQ3]LINNBR    With ""
  Chgtzn [M:PDQ3]RCPLINNBR With ""
  Chgtzn [M:PDQ3]CLELINNBR With ""
  Chgtzn [M:PDQ3]INVLINNBR With ""
  #-----
  Chgfmt [M:PDQ3]LINNBR    With "-NZP:4.0#"
  Chgfmt [M:PDQ3]RCPLINNBR With "-NZP:4.0#"
  Chgfmt [M:PDQ3]CLELINNBR With "-NZP:4.0#"
  Chgfmt [M:PDQ3]INVLINNBR With "-NZP:4.0#"
  #-----
  Filter [POC] Where POHNUM=WNUMCDE
  For [POC]
    [M:PDQ3]ITMREF(I)="("+num$([F:POC]POPLIN)+")"-[F:POC]ITMREF
    Filter [POQ] Where POHNUM=[F:POC]POHNUM & POPLIN=[F:POC]POPLIN & WIPSTA=1
    For [POQ]
      If [M:PDQ3]ITMREF(I)="" [M:PDQ3]ITMREF(I)=+"     "+[F:POQ]ITMREF : Endif
      [M:PDQ3]QTYPUU(I)=[F:POQ]QTYPUU
      [M:PDQ3]INVQTY(I)=[F:POQ]INVQTYPUU
      [M:PDQ3]PUU(I)   =[F:POQ]PUU
      #----- Chargement des réceptions effectuées sur la ligne de commande -----#
      Filter [PTD] Where POHNUM=WNUMCDE & POPLIN=[F:POQ]POPLIN & POQSEQ=[F:POQ]POQSEQ
&                  Order By Key PTD2
      For [PTD]
        [M:PDQ3]PTHNUM(I)   =[F:PTD]PTHNUM
        [M:PDQ3]PTDLIN(I)   =[F:PTD]PTDLIN
        [M:PDQ3]RCPDAT(I)   =[F:PTD]RCPDAT
        [M:PDQ3]RCPQTYPUU(I)=[F:PTD]QTYPUU
        [M:PDQ3]INVQTYPUU(I)=[F:PTD]INVQTYPUU
        [M:PDQ3]INVNUM(I)   =""
        For [PID] PID1 Where TYPORI=1
&                          & NUMORI=[F:PTD]POHNUM
&                          & LINORI=[F:PTD]POPLIN
&                          & SEQORI=[F:PTD]POQSEQ
          Gosub CHARG_NUMFAC
        Next
        If [M:PDQ3]INVNUM(I)=""
          For [PID] PID1 Where TYPORI=2
&                            & NUMORI=[F:PTD]PTHNUM
&                            & LINORI=[F:PTD]PTDLIN
            Gosub CHARG_NUMFAC
          Next
        Endif
        I+=1 : [M:PDQ3]NBLIG=I
        If I>dim([M:PDQ3]ITMREF)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break 3 : Endif
      Next
      If [M:PDQ3]ITMREF(I)<>""
       #[M:PDQ3]INVQTYPUU(I)=[F:POQ]INVQTYPUU
        I+=1 : [M:PDQ3]NBLIG=I
      Endif
      If I>dim([M:PDQ3]ITMREF)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break 2 : Endif
      # Issue 113514 - 2016-01-27 by MUARN : A faire sur POQ et non POC sinon pas la bonne ligne DL
      If I>0 & [M:PDQ3]INVQTY(I-1)<>0 & [M:PDQ3]INVNUM(I-1)=""
        I-=1
        For [PID] PID1 Where TYPORI=1
&                        & NUMORI=[F:POQ]POHNUM
&                        & LINORI=[F:POQ]POPLIN
&                        & SEQORI=[F:POQ]POQSEQ
          Gosub CHARG_NUMFAC
        Next
        I+=1
      Endif
    Next
    If [M:PDQ3]ITMREF(I)<>""
      I+=1 : [M:PDQ3]NBLIG=I
    Endif
    If I>dim([M:PDQ3]ITMREF)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
    # Issue 113514 - 2016-01-27 by MUARN : A faire sur POQ et non POC sinon pas la bonne ligne DL
#    If I>0 & [M:PDQ3]INVQTY(I-1)<>0 & [M:PDQ3]INVNUM(I-1)=""
#      I-=1
#      For [PID] PID1 Where TYPORI=1
#&                        & NUMORI=[F:POC]POHNUM
#&                        & LINORI=[F:POC]POPLIN
#        Gosub CHARG_NUMFAC
#      Next
#      I+=1
#    Endif
  Next
Endif
#----- Affichage foreground -----#
Filter [POQ] : Filter [PTD]
Affzo [PDQ3]
Call TEMPOFF From GESECRAN
Return
#----- Chargement des numéros de facture (10 maxi) -----#
$CHARG_NUMFAC
If [M:PDQ3]INVNUM(I)=""
  [M:PDQ3]INVNUM(I)=[F:PID]NUM
Elsif len([M:PDQ3]INVNUM(I))<163 & instr(1,[M:PDQ3]INVNUM(I),[F:PID]NUM)<1
  [M:PDQ3]INVNUM(I)-="_ "+[F:PID]NUM
Endif
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUETAPOH
nolign=SAVNOLIGN
Return


##############################################################################
#  Visualisation de la valorisation d'une ligne de commande ou de réception  #
# -------------------------------------------------------------------------- #
# Action VISUVALPOQ avec paramètres :                           MBT 05/03/08 #
#   PARAM(1) = NUM    : Numéro de la commande/réception                      #
#   PARAM(2) = LIN    : Numéro de la ligne de commande/réception             #
#   PARAM(3) = SEQ    : Séquence de la ligne de commande                     #
#   PARAM(4) = WABMSK : Abréviation du masque écran contenant les lignes     #
#   PARAM(5) = NOLIG  : Indice de la ligne en cours                          #
##############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUVALPOQ
#-----
Local Char     NUM(GLONPOH) : NUM      =PARAM(1)
Local Integer  LIN          : LIN      =val(PARAM(2))
Local Integer  SEQ          : SEQ      =val(PARAM(3))
Local Char     WABMSK(4)    : WABMSK   =PARAM(4)
Local Shortint NOL          : NOL      =val(PARAM(5))
Local Shortint SAVNOLIGN    : SAVNOLIGN=nolign
Local Integer  I, J
Local Char     WTAX(GLONVAT)
Local Char     WLIBTAX(GLONSHO)
Local Decimal  WAMTTAX, WDEDTAX
Local Char     DESIGN(20)
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
#-----
If evalue("[M:"+WABMSK+"]ITMREF(NOL)=''")  FIN=1 : Return : Endif
#----- Mise à jour des répartitions si nécessaire -----#
If evalue("[M:"+WABMSK+"]CLCFLG=2")
  Case WABMSK
    When "POH2" : #----- Commandes -----#
      Gosub CALCUL_MT_ELEMENT From SUBPOHC
      If !GIMPORT  Affzo [POH3]1-99 : Endif
    When "PTH1" : #----- Réceptions -----#
      Gosub TEST_VALID From SUBPTH
    # Issue 70985 - 2012-05-29 by MUARN : landed cost ajout factures
    When "PIH3" : #----- Factures -------#
      #----- Chargement prix unitaire brut si nécessaire -----#
      If [M:PIH3]GROPRI(NOL)=0 [M:PIH3]GROPRI(NOL)=[M:PIH3]NETPRI(NOL) : Endif
      #----- Réajustement des montants de taxe sur éléments et lignes facture -----#
      Call MAJ_TAXE (NOL) From SUBPIHB : If !GIMPORT Affzo [PIH4]10 : Endif
      If [M:PIH1]NBFAC1>0 & [M:PIH4]NBFAC=0
        [M:PIH4]NBFAC=[M:PIH1]NBFAC1
        For I=0 To [M:PIH1]NBFAC1-1
          Call MAJ_ELEMENT (I,1,+1) From SUBPIHB
        Next I
      Endif
  Endcase
Endif
#-----
If !clalev([F:PFI])  Local File PFOOTINV [PFI] : Endif
If !clalev([F:TVT])  Local File TABVAT   [TVT] : Endif
If !clalev([F:PPR])  Local File PPREASON [PPR] : Endif
#-----
Return
#-----------------------------------------------------------------------#
# Après ouverture de l'écran mais avant ouverture de la fenêtre : Titre #
#-----------------------------------------------------------------------#
$TIT_VISUVALPOQ
#-----
TIT=mess(486,198,1)
Case WABMSK
  When "POH2" : TIT-=mess(191,198,1)
  When "PTH1" : TIT-=mess(117,198,1)
  When "PIH3" : TIT-=mess(193,198,1) # Issue 70985 - 2012-05-29 by MUARN : landed cost ajout factures
Endcase
TIT-=NUM-mess(18,197,1)-num$(LIN)
Raz [M:PVQ1]
[M:PVQ1]WABMSK=WABMSK
#----- Chargement des libellés des montants répartis -----#
For I=0 To 8
  If evalue("[M:"+WABMSK+"]INVDTALIN2(I)")<>0
    Read [PFI] PFI0=evalue("[M:"+WABMSK+"]INVDTALIN2(I)")
    If fstat Raz [F:PFI] : Endif
    If [F:PFI]PFINUM<>0
      Call LECTEXTRA(DESIGN,"PFOOTINV","SHOAXX",num$([F:PFI]PFINUM),"") From ATEXTRA
      Assign "[M:PVQ1]LIB"+num$(I+1) With DESIGN+"  ("+format$("N0:3",[F:PFI]PFINUM)+")"
    Else
      Assign "[M:PVQ1]LIB"+num$(I+1) With ""
    Endif
  Endif
Next I
#-----
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUVALPOQ
#----- Chargement formats colonnes tarif -----#
[M:PVQ1]CUR =GCUR
[M:PVQ1]CUR2=GCUR
[M:PVQ1]CUR3=GCUR
# Issue 70985 - 2012-04-04 by MUARN : landed cost
[M:PVQ1]CURSOC=GLOCALDEV
[M:PVQ1]CURSOC1=GLOCALDEV
[M:PVQ1]CUR1=GCUR
Call FMTREM("PVQ1",[M:PVQ1]CUR)  From TRTPRICE
#----- Chargement des zones dans le masque -----#
[M:PVQ1]ITMREF    =evalue("[M:"+WABMSK+"]ITMREF(NOL)")
[M:PVQ1]ITMDES    =evalue("[M:"+WABMSK+"]ITMDES(NOL)")
[M:PVQ1]QTYUOM    =evalue("[M:"+WABMSK+"]QTYUOM(NOL)")
[M:PVQ1]UOM       =evalue("[M:"+WABMSK+"]UOM(NOL)")
[M:PVQ1]NETPRI    =evalue("[M:"+WABMSK+"]NETPRI(NOL)")
# Issue 70985 - 2012-04-04 by MUARN : landed cost
If WABMSK <> "PIH3"
[M:PVQ1]LINAMT    =evalue("[M:"+WABMSK+"]LINAMT(NOL)")
[M:PVQ1]LINATIAMT =evalue("[M:"+WABMSK+"]LINATIAMT(NOL)")
Else
[M:PVQ1]LINAMT    =evalue("[M:"+WABMSK+"]AMTNOTLIN(NOL)")
[M:PVQ1]LINATIAMT =evalue("[M:"+WABMSK+"]AMTATILIN(NOL)")
Endif

# Issue 70985 - 2012-04-04 by MUARN : landed cost
[M:PVQ1]CPR       =evalue("[M:"+WABMSK+"]CPR(NOL)")
[M:PVQ1]LINAMTCPR =evalue("[M:"+WABMSK+"]LINAMTCPR(NOL)")
[M:PVQ1]GROPRI    =evalue("[M:"+WABMSK+"]GROPRI(NOL)")
Raz [M:PVQ1]TYPORIMSK
If WABMSK = "PIH3"
  [M:PVQ1]TYPORI    =evalue("[M:"+WABMSK+"]TYPORI(NOL)")
  [M:PVQ1]TYPORIMSK = mess([M:PVQ1]TYPORI,511,1)
  [M:PVQ1]NUMORI    =evalue("[M:"+WABMSK+"]NUMORI(NOL)")
  [M:PVQ1]LINORI    =evalue("[M:"+WABMSK+"]LINORI(NOL)")
Elsif WABMSK ="PTH1"
  [M:PVQ1]NUMORI = evalue("[M:"+WABMSK+"]POHNUM(NOL)")
  [M:PVQ1]LINORI = evalue("[M:"+WABMSK+"]POPLIN(NOL)")
  If [M:PVQ1]NUMORI <> ""  [M:PVQ1]TYPORIMSK = mess(1,511,1) Endif
Endif

#----- Chargement des frais, remises et motifs tarif -----#
For I=0 To dim(GCOLREM)-1
  If GCOLREM(I)<>""
    If GDISCRGTYP(I)=1
      [M:PVQ1]DISCRGTYP([M:PVQ1]NBREM)=GCUR
    Else
      [M:PVQ1]DISCRGTYP([M:PVQ1]NBREM)="%"
    Endif
    If evalue("dim([M:"+WABMSK+"]DISCRGREN"+num$(I+1)+"(NOL))")>0
      [M:PVQ1]DISCRGVAL([M:PVQ1]NBREM)=evalue("[M:"+WABMSK+"]DISCRGVAL"+num$(I+1)+"(NOL)")
      [M:PVQ1]DISCRGREN([M:PVQ1]NBREM)=evalue("[M:"+WABMSK+"]DISCRGREN"+num$(I+1)+"(NOL)")
    Endif
    #----- Mettre les formats colonnes tarif en affiché -----#
    J=instr(1,[M:PVQ1]FMTREM([M:PVQ1]NBREM),":")
    If J
      [M:PVQ1]FMTREM([M:PVQ1]NBREM)=left$([M:PVQ1]FMTREM([M:PVQ1]NBREM),J-1)
&                             +"P"+right$([M:PVQ1]FMTREM([M:PVQ1]NBREM),J)
    Endif
     #-----
    [M:PVQ1]NBREM+=1
  Endif
Next I

#-----
[M:PVQ1]DISCRGAMT1=evalue("[M:"+WABMSK+"]DISCRGAMT1(NOL)")
[M:PVQ1]DISCRGAMT2=evalue("[M:"+WABMSK+"]DISCRGAMT2(NOL)")
[M:PVQ1]DISCRGAMT3=evalue("[M:"+WABMSK+"]DISCRGAMT3(NOL)")
[M:PVQ1]DISCRGAMT4=evalue("[M:"+WABMSK+"]DISCRGAMT4(NOL)")
[M:PVQ1]DISCRGAMT5=evalue("[M:"+WABMSK+"]DISCRGAMT5(NOL)")
[M:PVQ1]DISCRGAMT6=evalue("[M:"+WABMSK+"]DISCRGAMT6(NOL)")
[M:PVQ1]DISCRGAMT7=evalue("[M:"+WABMSK+"]DISCRGAMT7(NOL)")
[M:PVQ1]DISCRGAMT8=evalue("[M:"+WABMSK+"]DISCRGAMT8(NOL)")
[M:PVQ1]DISCRGAMT9=evalue("[M:"+WABMSK+"]DISCRGAMT9(NOL)")
#-----
[M:PVQ1]CLCAMT1   =evalue("[M:"+WABMSK+"]CLCAMT1(NOL)")
[M:PVQ1]CLCAMT2   =evalue("[M:"+WABMSK+"]CLCAMT2(NOL)")
[M:PVQ1]CLCAMT3   =evalue("[M:"+WABMSK+"]CLCAMT3(NOL)")
# Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
#If func AFNC.ACTIV("PTX") & dim([M:PVQ1]CLCAMT4)>0
If func TRTX3.ACTIV_PTX & dim([M:PVQ1]CLCAMT4)>0
  [M:PVQ1]CLCAMT4 =evalue("[M:"+WABMSK+"]CLCAMT4(NOL)")
  [M:PVQ1]CLCAMT5 =evalue("[M:"+WABMSK+"]CLCAMT5(NOL)")
  [M:PVQ1]CLCAMT6 =evalue("[M:"+WABMSK+"]CLCAMT6(NOL)")
  [M:PVQ1]CLCAMT7 =evalue("[M:"+WABMSK+"]CLCAMT7(NOL)")
Endif
[M:PVQ1]BASTAXLIN1=evalue("[M:"+WABMSK+"]BASTAXLIN1(NOL)")
If dim([M:PVQ1]DISBASLIN1)>0
  [M:PVQ1]DISBASLIN1=evalue("[M:"+WABMSK+"]DISBASLIN1(NOL)")
Endif
#-----
# Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
#For I=1 To 3+4*(func AFNC.ACTIV("PTX") & evalue("dim([M:"+WABMSK+"]TAXRCP)")>0)
For I=1 To 3+4*(func TRTX3.ACTIV_PTX & evalue("dim([M:"+WABMSK+"]TAXRCP)")>0)
  Case I
    When 1
      WTAX   =evalue("[M:"+WABMSK+"]VAT1(NOL)")
      WAMTTAX=evalue("[M:"+WABMSK+"]AMTTAXLIN1(NOL)")
      WDEDTAX=evalue("[M:"+WABMSK+"]DEDTAXLIN1(NOL)")
    When 2
      WTAX   =evalue("[M:"+WABMSK+"]VAT2(NOL)")
      WAMTTAX=evalue("[M:"+WABMSK+"]AMTTAXLIN2(NOL)")
      WDEDTAX=evalue("[M:"+WABMSK+"]DEDTAXLIN2(NOL)")
    When 3
      WTAX   =evalue("[M:"+WABMSK+"]VAT3(NOL)")
      WAMTTAX=evalue("[M:"+WABMSK+"]AMTTAXLIN3(NOL)")
      WDEDTAX=evalue("[M:"+WABMSK+"]DEDTAXLIN3(NOL)")
    When 4
      WTAX   =evalue("[M:"+WABMSK+"]TAXRCP(NOL)")
      WAMTTAX=evalue("[M:"+WABMSK+"]AMTTAXRCP(NOL)")
      WDEDTAX=evalue("[M:"+WABMSK+"]DEDTAXRCP(NOL)")
    When 5
      WTAX   =evalue("[M:"+WABMSK+"]TAXISS(NOL)")
      WAMTTAX=evalue("[M:"+WABMSK+"]AMTTAXISS(NOL)")
      WDEDTAX=evalue("[M:"+WABMSK+"]DEDTAXISS(NOL)")
    When 6
      WTAX   =evalue("[M:"+WABMSK+"]TAXOTH1(NOL)")
      WAMTTAX=evalue("[M:"+WABMSK+"]AMTTAXOTH1(NOL)")
      WDEDTAX=evalue("[M:"+WABMSK+"]DEDTAXOTH1(NOL)")
    When 7
      WTAX=evalue("[M:"+WABMSK+"]TAXOTH2(NOL)")
      WAMTTAX=evalue("[M:"+WABMSK+"]AMTTAXOTH2(NOL)")
      WDEDTAX=evalue("[M:"+WABMSK+"]DEDTAXOTH2(NOL)")
  Endcase
  If WTAX<>""
    # Issue 71937 - 2012-03-27 by SR : comment
    Call LEC_TVT_LEG(GCURLEG,WTAX,WRET) From TRTLECLEG
    If WRET : Raz [F:TVT] : Endif
    #Read [TVT] TVT0=WTAX : If fstat  Raz [F:TVT] : Endif
    #-----
    If [F:TVT]VATTYP>1
      If [F:TVT]VATBAS>1
        [M:PVQ1]BASTAX([M:PVQ1]NBTAX)=evalue("[M:"+WABMSK+"]CLCAMT"+num$(I)+"(NOL)")
      Else
        [M:PVQ1]BASTAX([M:PVQ1]NBTAX)=evalue("[M:"+WABMSK+"]LINAMT(NOL)")
      Endif
    Else
      [M:PVQ1]BASTAX([M:PVQ1]NBTAX)=evalue("[M:"+WABMSK+"]BASTAXLIN1(NOL)")
    Endif
    #-----
    Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,WLIBTAX) From TRTX3TEX
    [M:PVQ1]TAX      ([M:PVQ1]NBTAX)=WTAX
    [M:PVQ1]LIBTAX   ([M:PVQ1]NBTAX)=WLIBTAX
    [M:PVQ1]AMTTAX   ([M:PVQ1]NBTAX)=WAMTTAX
    [M:PVQ1]DEDTAX   ([M:PVQ1]NBTAX)=WDEDTAX
    [M:PVQ1]NONDEDTAX([M:PVQ1]NBTAX)=WAMTTAX-WDEDTAX
    [M:PVQ1]LINPURTYP([M:PVQ1]NBTAX)=evalue("[M:"+WABMSK+"]LINPURTYP(NOL)")
    [M:PVQ1]NBTAX+=1
  Endif
Next I
#----- Affichage foreground -----#
Affzo [PVQ1]1-99
#-----
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUVALPOQ
nolign=SAVNOLIGN
Return


#############################################################################
# SAICRITPNH : Saisie des critères de sélection en retour       HN 20/10/00 #
#############################################################################
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_CRITPNH
Raz [M:PCR1]
If [M:PCRW]WBPSNUM<>"" [M:PCR1]WBPSNUM=[M:PCRW]WBPSNUM : Affzo [PCR1]WBPSNUM
  Diszo [PCR1]WBPSNUM
Endif
If [M:PCRW]WNUMCDE<>"" [M:PCR1]WNUMCDE=[M:PCRW]WNUMCDE : Endif
If [M:PCRW]WBPSNDE<>"" [M:PCR1]WBPSNDE=[M:PCRW]WBPSNDE : Endif
If [M:PCRW]WITMREF<>"" [M:PCR1]WITMREF=[M:PCRW]WITMREF : Endif
If [M:PCRW]WNUMRCP<>"" [M:PCR1]WNUMRCP=[M:PCRW]WNUMRCP : Endif
If [M:PCRW]WLOT   <>"" [M:PCR1]WLOT   =[M:PCRW]WLOT    : Endif
Affzo [PCR1]1-99
Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_CRITPNH
[M:PCRW]=[M:PCR1]
Affzo [PCR1]1-99
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA_CRITPNH
[M:PCR1]=[M:PCRW]
REP=""
Affzo [PCR1]1-99
Return


#############################################################################
# REPART_QTY : S/P de répartition des quantités horizon contrat cde ouverte #
#   TYP      : "PF" Horizon ferme    répartition journalière                #
#              "PP" Horizon planifié répartition hebdomadaire               #
# ------------------------------------------------------------------------- #
# Remplacé par les actions SAIREP1 et SAIREP2 sans paramètre   MBT 29/11/00 #
#   SAIREP1 pour répartition journalière  d'un horizon ferme                #
#   SAIREP2 pour répartition hebdomadaire d'un horizon planifié             #
#############################################################################
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_SAIREP1
Local Integer WRET
Local Char SYMBOL2(30) : Raz SYMBOL2

Raz [M:PRP1]
[M:PRP1]XREP1=[M:POC2]DAYDSP(0)
[M:PRP1]XREP2=[M:POC2]DAYDSP(1)
[M:PRP1]XREP3=[M:POC2]DAYDSP(2)
[M:PRP1]XREP4=[M:POC2]DAYDSP(3)
[M:PRP1]XREP5=[M:POC2]DAYDSP(4)
[M:PRP1]XREP6=[M:POC2]DAYDSP(5)
[M:PRP1]XREP7=[M:POC2]DAYDSP(6)

#VPO 11/01/11 70581
If GREP<>"C" & GREP<>"D"
    # on doit locker la commande ouverte
    #----- Contrôle lock logique -----#
    Call JELOCKE("POH"+[M:POC0]POHNUM,WRET) From OBJDIV
    If [L]WRET=0
        SYMBOL2="POH"+[M:POC0]POHNUM : Lock=SYMBOL2
        If fstat
            Raz SYMBOL2
            Diszo [PRP1]1-99
        Endif
    Endif
Endif

Affzo [PRP1]1-99
Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAIREP1
#VPO 11/01/11 70581
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
#VPO 10/01/11 pour provoquer bouton enregistrer
If [M:POC2]DAYDSP(0)<>[M:PRP1]XREP1 |
&    [M:POC2]DAYDSP(1)<>[M:PRP1]XREP2 |
&    [M:POC2]DAYDSP(2)<>[M:PRP1]XREP3 |
&    [M:POC2]DAYDSP(3)<>[M:PRP1]XREP4 |
&    [M:POC2]DAYDSP(4)<>[M:PRP1]XREP5 |
&    [M:POC2]DAYDSP(5)<>[M:PRP1]XREP6 |
&    [M:POC2]DAYDSP(6)<>[M:PRP1]XREP7
mkstat=4
Endif

[M:POC2]DAYDSP(0)=[M:PRP1]XREP1
[M:POC2]DAYDSP(1)=[M:PRP1]XREP2
[M:POC2]DAYDSP(2)=[M:PRP1]XREP3
[M:POC2]DAYDSP(3)=[M:PRP1]XREP4
[M:POC2]DAYDSP(4)=[M:PRP1]XREP5
[M:POC2]DAYDSP(5)=[M:PRP1]XREP6
[M:POC2]DAYDSP(6)=[M:PRP1]XREP7
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
ABA_SAIREP1
#VPO 11/01/11 70581
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Raz REP
Gosub DEB_SAIREP1
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SAIREP1
#VPO 11/01/11 70581
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_SAIREP2
Local Integer WRET
Local Char SYMBOL2(30) : Raz SYMBOL2

Raz [M:PRP2]
[M:PRP2]XREP1=[M:POC2]WEEDSP(0)
[M:PRP2]XREP2=[M:POC2]WEEDSP(1)
[M:PRP2]XREP3=[M:POC2]WEEDSP(2)
[M:PRP2]XREP4=[M:POC2]WEEDSP(3)
[M:PRP2]XREP5=[M:POC2]WEEDSP(4)

#VPO 11/01/11 70581
If GREP<>"C" & GREP<>"D"
    # on doit locker la commande ouverte
    #----- Contrôle lock logique -----#
    Call JELOCKE("POH"+[M:POC0]POHNUM,WRET) From OBJDIV
    If [L]WRET=0
        SYMBOL2="POH"+[M:POC0]POHNUM : Lock=SYMBOL2
        If fstat
            Raz SYMBOL2
            Diszo [PRP2]1-99
        Endif
    Endif
Endif

Affzo [PRP2]1-99
Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAIREP2
#VPO 11/01/11 70581
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
#VPO 10/01/11 pour provoquer bouton enregistrer
If [M:POC2]WEEDSP(0)<>[M:PRP2]XREP1 |
&    [M:POC2]WEEDSP(1)<>[M:PRP2]XREP2 |
&    [M:POC2]WEEDSP(2)<>[M:PRP2]XREP3 |
&    [M:POC2]WEEDSP(3)<>[M:PRP2]XREP4 |
&    [M:POC2]WEEDSP(4)<>[M:PRP2]XREP5
mkstat=4
Endif

[M:POC2]WEEDSP(0)=[M:PRP2]XREP1
[M:POC2]WEEDSP(1)=[M:PRP2]XREP2
[M:POC2]WEEDSP(2)=[M:PRP2]XREP3
[M:POC2]WEEDSP(3)=[M:PRP2]XREP4
[M:POC2]WEEDSP(4)=[M:PRP2]XREP5
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
ABA_SAIREP2
#VPO 11/01/11 70581
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Raz REP
Gosub DEB_SAIREP2
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SAIREP2
#VPO 11/01/11 70581
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Return


#########################################################################
# SAI_INFOCEE : S/P de saisie des informations douanières               #
#    INDIC : Indicateur d'appel  1 = depuis les commandes  (écran PCEV) #
#                                2 = depuis les contrats   (écran PCEW) #
#                                3 = depuis les réceptions (écran PCEX) #
#                                4 = depuis les retours    (écran PCEY) #
#                                5 = depuis les factures   (écran PCEZ) #
#                                                                       #
#        à la sortie du S/P -->  9 = pour activation touche enregistrer #
# --------------------------------------------------------------------- #
# Remplacé par l'action SAIPCEE avec paramètre             MBT 06/11/00 #
#    PARAM(1) = EXEFLG : Indicateur d'exécution (9=OK)                  #
#########################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_SAIPCEE
Local Char    SAV_DEFMSK(255) : SAV_DEFMSK=dbgstr(1)
Local Libelle FLGSAI : FLGSAI=1
Local Char    WABREV(5)
# Issue 84130 - 2013-02-21 by MUARN : landed cost
Local    Integer  I,J
#-----
If !clalev([F:BPR2]) Local File BPARTNER  [BPR2] : Endif
If !clalev([F:BPT])  Local File BPCARRIER [BPT]  : Endif
If !clalev([F:BPA])  Local File BPADDRESS [BPA]  : Endif
If !clalev([M:WCEE]) Local Mask PCEE      [WCEE] : Endif
#-----
Case PARAM(1)
  When "1" : WABREV="PCEV"
  When "2" : WABREV="PCEW"
  When "3" : WABREV="PCEX"
  When "4" : WABREV="PCEY"
  When "5" : WABREV="PCEZ"
Endcase
Return
#-------------------------------------------------------------#
# Après l'ouverture de la fenêtre des informations douanières #
#-------------------------------------------------------------#
$DEB_SAIPCEE
#----- Si appel depuis la gestion contrats (les infos sont sur la ligne article) -----#
If PARAM(1)="2" & clalev([M:POC2])
  If !clalev([M:PCEW])  Local Mask PCEE [PCEW] : Endif
  [M:PCEW]EECICT =[M:POC2]EECICT2
  [M:PCEW]ICTCTY =[M:POC2]ICTCTY2
  [M:PCEW]FFWNUM =[M:POC2]FFWNUM2
  [M:PCEW]FFWADD =[M:POC2]FFWADD2
  # Issue 117876 - 2016-08-03 by MUARN : code activité DEB inactif
  If GACTDEB=2
    [M:PCEW]EECLOC =[M:POC2]EECLOC2
    [M:PCEW]EECNUM =[M:POC2]EECNUM2
  Endif
  [M:PCEW]WPOSCOD=[M:AD63]POSCOD
  [M:PCEW]WBPSNUM=[M:POC0]BPSNUM
  [M:PCEW]WBPAADD=[M:AD63]BPAADD
  [M:PCEW]WCRY   =[M:AD63]CRY
Endif
#-----
Default Mask "["+WABREV+"]"
[M:PCEE]=[M]
[M:WCEE]=[M]
#-----
If [M:PCEE]WCRY=""
  If !clalev([F:BPA])  Local File BPADDRESS [BPA] : Endif
  Read [BPA] BPA0=1;[M:PCEE]WBPSNUM;[M:PCEE]WBPAADD
  If fstat  Raz [F:BPA] : Endif
  [M:PCEE]WCRY   =[F:BPA]CRY
  [M:PCEE]WPOSCOD=[F:BPA]POSCOD
Endif
#-----
If [M:PCEE]FFWNUM<>""
  If [F:BPR2]BPRNUM<>[M:PCEE]FFWNUM
    Read [BPR2] BPR0=[M:PCEE]FFWNUM : If fstat Raz [F:BPR2] : Endif
  Endif
  [M:PCEE]FFWNAM(0)=[F:BPR2]BPRNAM(0)
  [M:PCEE]FFWNAM(1)=[F:BPR2]BPRNAM(1)
  Actzo [PCEE]FFWADD
Else
  Diszo [PCEE]FFWADD
Endif
Affzo [PCEE]1-99

# Issue 84130 - 2013-02-21 by MUARN : landed cost
Case PARAM(1)
  When "1"
    If clalev([M:POH2])
      If [M:POH2]NBLIG>0
        J = sigma(I=0,[M:POH2]NBLIG-1,1*([M:POH2]STCNUM(I)<>""))
        If J
          Diszo [M:PCEE]EECICT
        Else
          Actzo [M:PCEE]EECICT
        Endif
      Endif
    Endif
  When "3"
    If clalev([M:PTH1])
      If [M:PTH1]NBLIG>0
        J = sigma(I=0,[M:PTH1]NBLIG-1,1*([M:PTH1]STCNUM(I)<>""))
        If J
          Diszo [M:PCEE]EECICT
        Else
          Actzo [M:PCEE]EECICT
        Endif
      Endif
    Endif
  When "5"
    If clalev([M:PIH3])
      If [M:PIH3]NBLIG>0
        J = sigma(I=0,[M:PIH3]NBLIG-1,1*([M:PIH3]STCNUM(I)<>""))
        If J
          Diszo [M:PCEE]EECICT
        Else
          Actzo [M:PCEE]EECICT
        Endif
      Endif
    Endif
Endcase

#----- Si modif non autorisée, désactivation de la saisie par grisage -----#
If GREP<>"C"
  GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2  Diszo [PCEE]1-99 : Raz FLGSAI : Return : Endif
  Case PARAM(1)
    When "1"
      If clalev([M:POH1]) & [M:POH1]CLEFLG=2
        Diszo [PCEE]1-99 : Raz FLGSAI
      Endif
    When "2"
      If clalev([M:POC0]) & [M:POC0]XVERROU=0
        Diszo [PCEE]1-99 : Raz FLGSAI
      Endif
    When "3"
      If clalev([M:PTH1]) &  !GPTH_VERROU
        Diszo [PCEE]1-99 : Raz FLGSAI
      Endif
    When "4"
      If clalev([M:PNH1]) & (!GPNH_VERROU | [M:PNH1]CFMFLG=2)
        Diszo [PCEE]1-99 : Raz FLGSAI
      Endif
    When "5"
      If clalev([M:PIH1]) & (!GPIH_VERROU | [M:PIH1]STA=3)
        Diszo [PCEE]1-99 : Raz FLGSAI
      Endif
  Endcase
Endif
#-- CPO 04/08/2008 - Comportement identique Ventes
#-- Pour les commandes, contrats :
#   Suppression du bloc "Flux physique"
#   Suppression du champs Mode transport CEE du bloc Informations CEE
If find(PARAM(1),"1","2")
   Chgtbk [PCEE]15 With ""
   If dim([PCEE]EECNAT)>0  : Chgfmt [PCEE]EECNAT  With "-K:1X" : Endif
   If dim([PCEE]ZEECNAT)>0 : Chgfmt [PCEE]ZEECNAT With "-K:1X" : Endif
   If dim([PCEE]EECSCH)>0  : Chgfmt [PCEE]EECSCH  With "-K:1X" : Endif
   If dim([PCEE]ZEECSCH)>0 : Chgfmt [PCEE]ZEECSCH With "-K:1X" : Endif

   If dim([PCEE]EECTRN)>0  : Chgfmt [PCEE]EECTRN  With "-K:1X" : Endif
Endif
#-- fin CPO

#-----
# Bug 64917
#If GACTDEB<>2
#  Grizo [PCEE]EECNUM, EECNAT, EECSCH, EECTRN, EECLOC
#Elsif PARAM(1)="1" | PARAM(1)="2"
If GACTDEB=2 & (PARAM(1)="1" | PARAM(1)="2")
  Grizo [PCEE]EECNAT, EECSCH, EECTRN
Endif

Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAIPCEE
If ([M:PCEE]EECICT<>[M:WCEE]EECICT |
&   [M:PCEE]ICTCTY<>[M:WCEE]ICTCTY |
&   [M:PCEE]FFWNUM<>[M:WCEE]FFWNUM |
&   [M:PCEE]FFWADD<>[M:WCEE]FFWADD |
&   (GACTDEB=2 & ([M:PCEE]EECNAT<>[M:WCEE]EECNAT |
&   [M:PCEE]EECSCH<>[M:WCEE]EECSCH |
&   [M:PCEE]EECTRN<>[M:WCEE]EECTRN |
&   [M:PCEE]EECLOC<>[M:WCEE]EECLOC |
&   [M:PCEE]EECNUM<>[M:WCEE]EECNUM))) & FLGSAI<>0
  Default Mask "["+WABREV+"]"
  [M]=[M:PCEE]
  #----- Si appel depuis la gestion oommandes -----#
  If PARAM(1)="1" & clalev([M:POH1])
    [M:POH1]EECICT2=[M:PCEE]EECICT
    [M:POH1]ICTCTY2=[M:PCEE]ICTCTY
    If dim([M:POH1]ZEECICT2)>0
      Affzo [POH1]EECICT2, ZEECICT2, ICTCTY2
    Else
      Affzo [POH1]EECICT2, ICTCTY2
    Endif
  Endif
  #----- Si appel depuis la gestion contrats -----#
  If PARAM(1)="2" & clalev([M:POC2])
    [M:POC2]EECICT2=[M:PCEE]EECICT
    [M:POC2]ICTCTY2=[M:PCEE]ICTCTY
    [M:POC2]FFWNUM2=[M:PCEE]FFWNUM
    [M:POC2]FFWADD2=[M:PCEE]FFWADD
    If GACTDEB=2
      [M:POC2]EECLOC2=[M:PCEE]EECLOC
      [M:POC2]EECNUM2=[M:PCEE]EECNUM
    Endif
  Endif
  #----- Si appel depuis le contrôle factures -----#
  If PARAM(1)="5" & clalev([M:PIH1])
    [M:PIH1]EECICT2=[M:PCEE]EECICT
    [M:PIH1]ICTCTY2=[M:PCEE]ICTCTY
    If dim([M:PIH1]ZEECICT2)>0
      Affzo [PIH1]EECICT2, ZEECICT2, ICTCTY2
    Else
      Affzo [PIH1]EECICT2, ICTCTY2
    Endif
  Endif
  #-----
  PARAM(1)="9"
Endif
FIN=1
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
ABA_SAIPCEE
[M:PCEE]=[M:WCEE] : Raz REP
If [M:PCEE]FFWNUM<>""
  If [F:BPR2]BPRNUM<>[M:PCEE]FFWNUM
    Read [BPR2] BPR0=[M:PCEE]FFWNUM : If fstat Raz [F:BPR2] : Endif
  Endif
  [M:PCEE]FFWNAM(0)=[F:BPR2]BPRNAM(0)
  [M:PCEE]FFWNAM(1)=[F:BPR2]BPRNAM(1)
  Actzo [PCEE]FFWADD
Else
  Diszo [PCEE]FFWADD
Endif
Affzo [PCEE]1-99
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SAIPCEE
If clalev([M:WCEE])  Close Local Mask [WCEE] : Endif
Default Mask SAV_DEFMSK
Return

