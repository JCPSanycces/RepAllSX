#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
# SUBVISTIM : visualisation des articles commandés         MAE 04/04/08 #
# --------------------------------------------------------------------- #

$ACTION
#---------------------------------------------------------------------#
# Actions sur la saisie de fenêtre (GSAISIE)                          #
# VISUITM : Affichage des articles commandés d'un client donné        #
#---------------------------------------------------------------------#
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "FIN"         : Gosub FIN
 When "FINSAI"      : Gosub FINSAI
 When "BOUTON"      : Gosub BOUTON_SEL
 When "SETBOUT"     : Gosub SETBOUT
Endcase
Return
 


#############################################################################
# VISUITM : Derniers articles commandés    MAE, 15/04/08                    #
#   BPRNUM   : Numéro tiers                                                 #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE
Global Integer SVNOLIGN
Global Char WITMREF
Global Char WABREV


If clalev([F:SOH]) = 0 Local File SORDER      [SOH]: Endif 
If clalev([F:SOQ]) = 0 Local File SORDERQ     [SOQ]: Endif 
If clalev([F:SOP]) = 0 Local File SORDERP     [SOP]: Endif 
#MAE, on ajoute la consultation dans la pile de la navigation
NAVIG= "VISUITM"
#sauvegarde du numéro de ligne du tableau des lignes de commandes
SVNOLIGN = nolign
If GPILNAV > 0
    If find (GNAVIG(GPILNAV), "GESSQH")
       WABREV = "SQH2"
    Else If find (GNAVIG(GPILNAV), "GESSOH")
       WABREV="SOH4"    
    Endif
    Endif
Endif
Return
#############################################################################
#--------------------------------------------------------------#
# Définition des boutons                                       #
#--------------------------------------------------------------#
$SETBOUT
If evalue("[M:"+WABREV+"]ITMREF(SVNOLIGN-1)") <> ""
    Call VIREBOUT(CHMEN, "1") From GOBJET
Endif
Return
#############################################################################
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEBUT
Raz [M:SITM]
Link [SOQ] With [SOH]SOH0=[SOQ]SOHNUM,
&               [SOP]SOP0=[SOQ]SOHNUM;[SOQ]SOPLIN;[SOQ]SOQSEQ
&          As [LNK] Order By Key CLE = [F:SOH]ORDDAT Desc
nolign = 0
For [LNK] Where BPCORD=PARAM(1)
    If nolign < dim([M:SITM]SOHNUM)-1
        nolign += 1
        [M:SITM]SOHNUM(nolign-1)=[F:SOH]SOHNUM
        [M:SITM]SALFCY(nolign-1)=[F:SOH]SALFCY
        [M:SITM]ITMREF(nolign-1)=[F:SOQ]ITMREF
        [M:SITM]QTY(nolign-1)=[F:SOQ]QTY
        [M:SITM]ORDDAT(nolign-1)=[F:SOQ]ORDDAT  
        [M:SITM]CUR(nolign-1)=[F:SOH]CUR
        [M:SITM]GROPRI(nolign-1)=[F:SOP]GROPRI
        [M:SITM]CPRPRI(nolign-1)=[F:SOP]CPRPRI
        [M:SITM]NETPRI(nolign-1)=[F:SOP]NETPRI
        [M:SITM]NBLIG+=1
        If dim([M:SITM]DISCRGVAL1(nolign-1))>0 [M:SITM]DISCRGVAL1(nolign-1)=[F:SOP]DISCRGVAL1 Endif
        If dim([M:SITM]DISCRGVAL2(nolign-1))>0 [M:SITM]DISCRGVAL2(nolign-1)=[F:SOP]DISCRGVAL2 Endif
        If dim([M:SITM]DISCRGVAL3(nolign-1))>0 [M:SITM]DISCRGVAL3(nolign-1)=[F:SOP]DISCRGVAL3 Endif
        If dim([M:SITM]DISCRGVAL4(nolign-1))>0 [M:SITM]DISCRGVAL4(nolign-1)=[F:SOP]DISCRGVAL4 Endif
        If dim([M:SITM]DISCRGVAL5(nolign-1))>0 [M:SITM]DISCRGVAL5(nolign-1)=[F:SOP]DISCRGVAL5 Endif
        If dim([M:SITM]DISCRGVAL6(nolign-1))>0 [M:SITM]DISCRGVAL6(nolign-1)=[F:SOP]DISCRGVAL6 Endif
        If dim([M:SITM]DISCRGVAL7(nolign-1))>0 [M:SITM]DISCRGVAL7(nolign-1)=[F:SOP]DISCRGVAL7 Endif
        If dim([M:SITM]DISCRGVAL8(nolign-1))>0 [M:SITM]DISCRGVAL8(nolign-1)=[F:SOP]DISCRGVAL8 Endif
        If dim([M:SITM]DISCRGVAL9(nolign-1))>0 [M:SITM]DISCRGVAL9(nolign-1)=[F:SOP]DISCRGVAL9 Endif
    Endif
Next    
Affzo[M]1-99
Return
#############################################################################
#---------------------------------#
# Selection                       #
#---------------------------------#
$BOUTON_SEL
Case BOUT 
  When "1" :
    If nolign > 0
      Assign("[M:"+WABREV+"]QTY(SVNOLIGN-1)") With [M:SITM]QTY (nolign-1)
      WITMREF = [M:SITM]ITMREF(nolign-1)
      If dim([M:SITM]DISCRGVAL1(nolign-1))>0 Assign("[M:"+WABREV+"]DISCRGVAL1(SVNOLIGN-1)") With [M:SITM]DISCRGVAL1(nolign-1) Endif
      If dim([M:SITM]DISCRGVAL2(nolign-1))>0 Assign("[M:"+WABREV+"]DISCRGVAL2(SVNOLIGN-1)") With [M:SITM]DISCRGVAL2(nolign-1) Endif
      If dim([M:SITM]DISCRGVAL3(nolign-1))>0 Assign("[M:"+WABREV+"]DISCRGVAL3(SVNOLIGN-1)") With [M:SITM]DISCRGVAL3(nolign-1) Endif
      If dim([M:SITM]DISCRGVAL4(nolign-1))>0 Assign("[M:"+WABREV+"]DISCRGVAL4(SVNOLIGN-1)") With [M:SITM]DISCRGVAL4(nolign-1) Endif
      If dim([M:SITM]DISCRGVAL5(nolign-1))>0 Assign("[M:"+WABREV+"]DISCRGVAL5(SVNOLIGN-1)") With [M:SITM]DISCRGVAL5(nolign-1) Endif
      If dim([M:SITM]DISCRGVAL6(nolign-1))>0 Assign("[M:"+WABREV+"]DISCRGVAL6(SVNOLIGN-1)") With [M:SITM]DISCRGVAL6(nolign-1) Endif
      If dim([M:SITM]DISCRGVAL7(nolign-1))>0 Assign("[M:"+WABREV+"]DISCRGVAL7(SVNOLIGN-1)") With [M:SITM]DISCRGVAL7(nolign-1) Endif
      If dim([M:SITM]DISCRGVAL8(nolign-1))>0 Assign("[M:"+WABREV+"]DISCRGVAL8(SVNOLIGN-1)") With [M:SITM]DISCRGVAL8(nolign-1) Endif
      If dim([M:SITM]DISCRGVAL9(nolign-1))>0 Assign("[M:"+WABREV+"]DISCRGVAL9(SVNOLIGN-1)") With [M:SITM]DISCRGVAL9(nolign-1) Endif
      Assign("[M:"+WABREV+"]GROPRI(SVNOLIGN-1)") With [M:SITM]GROPRI(nolign-1)
      Assign("[M:"+WABREV+"]CPRPRI(SVNOLIGN-1)") With [M:SITM]CPRPRI(nolign-1)
      Assign("[M:"+WABREV+"]NETPRI(SVNOLIGN-1)") With [M:SITM]NETPRI(nolign-1)
    Endif
    FIN=1
Endcase
Return
#############################################################################
#--------------------------------------------------------------#
# Après la fermeture de la fenêtre                             #
#--------------------------------------------------------------#
$FIN
nolign = SVNOLIGN
If  evalue("dim([M:"+WABREV+"]ITMREF(SVNOLIGN-1))") > 0 & evalue("[M:"+WABREV+"]ITMREF(SVNOLIGN-1)") = ""
    VALEUR = WITMREF
Endif
If evalue("dim([M:"+WABREV+"]DISCRGVAL1(SVNOLIGN-1))")>0 Affzo = "[M:"+WABREV+"]DISCRGVAL1(SVNOLIGN-1)" Endif
If evalue("dim([M:"+WABREV+"]DISCRGVAL2(SVNOLIGN-1))")>0 Affzo = "[M:"+WABREV+"]DISCRGVAL2(SVNOLIGN-1)" Endif
If evalue("dim([M:"+WABREV+"]DISCRGVAL3(SVNOLIGN-1))")>0 Affzo = "[M:"+WABREV+"]DISCRGVAL3(SVNOLIGN-1)" Endif
If evalue("dim([M:"+WABREV+"]DISCRGVAL4(SVNOLIGN-1))")>0 Affzo = "[M:"+WABREV+"]DISCRGVAL4(SVNOLIGN-1)" Endif
If evalue("dim([M:"+WABREV+"]DISCRGVAL5(SVNOLIGN-1))")>0 Affzo = "[M:"+WABREV+"]DISCRGVAL5(SVNOLIGN-1)" Endif
If evalue("dim([M:"+WABREV+"]DISCRGVAL6(SVNOLIGN-1))")>0 Affzo = "[M:"+WABREV+"]DISCRGVAL6(SVNOLIGN-1)" Endif
If evalue("dim([M:"+WABREV+"]DISCRGVAL7(SVNOLIGN-1))")>0 Affzo = "[M:"+WABREV+"]DISCRGVAL7(SVNOLIGN-1)" Endif
If evalue("dim([M:"+WABREV+"]DISCRGVAL8(SVNOLIGN-1))")>0 Affzo = "[M:"+WABREV+"]DISCRGVAL8(SVNOLIGN-1)" Endif
If evalue("dim([M:"+WABREV+"]DISCRGVAL9(SVNOLIGN-1))")>0 Affzo = "[M:"+WABREV+"]DISCRGVAL9(SVNOLIGN-1)" Endif
Affzo = "[M:"+WABREV+"]GROPRI(SVNOLIGN-1)"
Affzo = "[M:"+WABREV+"]CPRPRI(SVNOLIGN-1)"
Affzo = "[M:"+WABREV+"]NETPRI(SVNOLIGN-1)"
Return
#############################################################################
#--------------------------------------------------------------#
# Fermeture de la fenêtre                                      #
#--------------------------------------------------------------#
$FINSAI

# 87294 : Pb init. des sections analytiques sur le document d'origine
# Si NBAFF=1, Raffraichissement de la fenêtre du dessous, on ne passe plus dans les actions d'init des sections
#NBAFF=1
# 87294
    
Return


###################################################################################


