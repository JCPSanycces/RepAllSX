#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End

########################################################################################################
##                                                                                                     #
## Historisation / Epuration pièces comptables  V140    -   Module TIERS                               #
##                                                                                                     #
########################################################################################################
#   - SINVOICE  : Historisation / Epuration des factures client                                        #
#   - PINVOICE  : Historisation / Epuration des factures fournisseur                                   #
#   - PAYMENTH  : Historisation / Epuration des règlements                                             #
#   - HISTODUD  : Historisation / Epuration de l'historisation des échéances                           #
#   - RELBANK   : Historisation / Epuration des relevés bancaires                                      #
########################################################################################################
# HISTO = 1 => Historisation
#
#              Les données passent d'APPLI vers HISAPL
#              Les données historisées sont supprimées d'APPLI
#              Uniquement des contrôles liés au dossier APPLI
#
#
# EPUR  = 1 => Epuration
#
#    Soit Epuration seule (EPUR=1 et HISTO=0)
#         Les données sont supprimées d'APPLI
#         Uniquement des contrôles liés au dossier APPLI.
#
#    Soit Epuration suite à l'historisation (EPUR=1 et HISTO=1)
#                    L'historisation a fait les vérifications nécessaires (cf HISTO=1)
#                    L'épuration concerne donc le dossier HISAPL mais aucun contrôle sur ce dossier.
#
########################################################################################################

$ACTION
Case ACTION
  When "OUVRE"
            Case [F:AHI]COD
                When "SINVOICE" : Gosub OUVRE_INVOICE
                When "PINVOICE" : Gosub OUVRE_INVOICE
                When "PAYMENTH" : Gosub OUVRE_PAYMENTH
                When "HISTODUD" : Gosub OUVRE_DUD
                When "RELBANK"  : Gosub OUVRE_RELBANK
            Endcase

  When "FILTRE"

            Case [F:AHI]COD
                When "HISTODUD" : If FLGHDUD : Gosub FILTRE_DUD : Endif
            Endcase

  When "FILSOC"
            Case [F:AHI]COD
                When "RELBANK"  : Gosub FILTRE_RELBANK
            Endcase

  When "HISTO"
            Case [F:AHI]COD
                 When "SINVOICE"   : Gosub HISEPU_INVOICE
                 When "PINVOICE"   : Gosub HISEPU_INVOICE
                 When "PAYMENTH"   : Gosub HISTO_PAYMENTH
                 When "HISTODUD"   : If FLGHDUD : Gosub HISTO_DUD : Endif
                 When "RELBANK"    : Gosub HISEPU_RELBANK
            Endcase

  When "EPURE"

            Case [F:AHI]COD
                 When "SINVOICE"  : Gosub HISEPU_INVOICE
                 When "PINVOICE"  : Gosub HISEPU_INVOICE
                 When "PAYMENTH"  : Gosub EPURE_PAYMENTH
                 When "HISTODUD"  : If FLGHDUD : Gosub EPURE_DUD : Endif
                 When "RELBANK"   : Gosub HISEPU_RELBANK
            Endcase

  When "FERME"

            Case [F:AHI]COD
                 When "SINVOICE"  : Gosub FERME_INVOICE
                 When "PINVOICE"  : Gosub FERME_INVOICE
                 When "PAYMENTH"  : Gosub FERME_PAYMENTH
                 When "HISTODUD"  : If FLGHDUD : Gosub FERME_DUD : Endif
                 When "RELBANK"   : Gosub FERME_RELBANK
            Endcase

Endcase
Return


#####################################################################################################
# Historation / Epuration des factures tiers                                                        #
# Formule d'épuration :   ORIMOD=6 & STA=3                                                          #
#####################################################################################################
#
#     Historisation/Epuration d'une facture s'effectue si :
#        la pièce comptable associée a déjà été historisée/épurée
#        toutes ses échéances sont soldées (réglés)
#
#    Si facture historisée/épurée, il faut faire de même avec ces propres échéances.
#
#######################################################################################

$OUVRE_INVOICE
If [L]HISTO
   If !OKEPU
        # Historisation sans épuration.
        # Contrôle sur APPLI
        If clalev([F:P1])=0 : Local File =[L]APPLI+".GACCDUDATE" [P1] : Endif
        If clalev([F:P2])=0 : Local File =[L]APPLI+".GACCENTRY"  [P2] : Endif

        # Données à historiser
        # ... les échéances (GACCDUDATE)
        #     09/05 => Pas d'historisation des échéances
        # ... l'historique des échéances (HISTODUD) : Code activité HDU
        #     09/05 Fonction à part => Epuration/Historisation avec le code HISTODUD.

   #Else
        # Epuration suite à l'Historisation.
        # Données HISAPL à supprimer... aucun contrôle
   Endif

Else
    # Epuration seule.
    # Contrôle sur APPLI
    # Données APPLI à supprimer
    If clalev([F:P1])=0 : Local File =[L]APPLI+".GACCDUDATE" [P1] : Endif
    If clalev([F:P2])=0 : Local File =[L]APPLI+".GACCENTRY"  [P2] : Endif
Endif

Return

###################
$HISEPU_INVOICE
Case TABLE
 When "SINVOICE" :
    If [L]TRACEDET :  Call ECR_TRACE(mess(43,109,1)-[F:F1]GTE-[F:F1]NUM,0) From GESECRAN : Endif
 When "PINVOICE" :
    If [L]TRACEDET :  Call ECR_TRACE(mess(44,109,1)-[F:F1]GTE-[F:F1]NUM,0) From GESECRAN : Endif
 When Default    :
    OKHIS=0 : OKEPU=0 : Return
Endcase

# Contrôle si
#    - Historisation sans épuration (HISAPL)
#   OU
#    - Epuration seule (APPLI)

If ([L]HISTO & !OKEPU) or ![L]HISTO
    Read [P2]HAE0 =[F1]GTE;[F1]NUM
    If !fstat
        If [L]TRACEDET
            Call ECR_TRACE(mess(635,197,1)-[F:P2]TYP-[F:P2]NUM,0) From GESECRAN
            # La pièce comptable est toujours présente
        Endif
        OKHIS=0 : OKEPU=0 : Return
    Endif
    For [P1]DUD6 Where FLGCLE<>2 & ACCNUM=[F1]ACCNUM
      OKHIS=0 : OKEPU=0 : Break
    Next
    If !OKHIS
        If [L]TRACEDET
            Call ECR_TRACE(mess(430,197,1)-"(ACCNUM="+num$([F:P1]ACCNUM)+")",0) From GESECRAN
            # Il reste des échéances non réglées
        Endif
        Return
    Endif

    # Si Contrôle OK, il faut épurer l'échéance
    If [L]TRACEDET
     Call ECR_TRACE("GACCDUDATE : "-"(ACCNUM="+num$([F:F1]ACCNUM)+")",0) From GESECRAN
    Endif
    If ![L]SIMUL
      Delete [P1] Where FLGCLE<>2 & ACCNUM=[F1]ACCNUM
      If fstat=1
       [V]GOK = -1 : Call ECR_TRACE("$GACCDUDATE"-num$([F1]ACCNUM)-mess(10,100,1),1) From GESECRAN
      Endif
    Endif
    If GOK<1 : OKHIS=0 : OKEPU=0 : Endif
Endif
Return


##############
$FERME_INVOICE
If clalev([F:P1])  Close Local File [P1] : Endif
If clalev([F:P2])  Close Local File [P2] : Endif
Return


#######################################################################################
# Historation / Epuration des règlements                                              #
# Formule d'épuration :   STA>=9                                                      #
#######################################################################################

$OUVRE_PAYMENTH
If clalev([F:P1])=0 : Local File =[L]APPLI+".PAYLOT" [P1] : Endif
If clalev([F:P2])=0 : Local File =[L]APPLI+".PAYFRM" [P2] : Endif
Local Integer NBFRM : Raz NBFRM
Local Integer NBLOT : Raz NBLOT
Return

$HISTO_PAYMENTH
Case TABLE
   When "PAYACCNUM" : If [P1]TYPNUM<>3 : OKHIS =0 : Endif
   When "PAYLOT"    : OKHIS = 0
   When "PAYFRM"    : OKHIS = 0
   When "PAYMENTH"  : Gosub EPUR_LOTFRM
Endcase
Return

$EPURE_PAYMENTH
# Même contrôle que l'historisation
Local Integer SVG_OKHIS
SVG_OKHIS = OKHIS
OKHIS = OKEPU
Gosub HISTO_PAYMENTH
OKEPU = OKHIS
OKHIS = SVG_OKHIS

Gosub EPUR_LOTFRM
Return

$EPUR_LOTFRM
If [L]SIMUL : Return : Endif

# Epuration des bordereaux et des lots vides
If OKEPU or ([L]HISTO & !OKEPU)
    Case TABLE
       When "PAYMENTH"
          If [F1]FRMNUM<>""
              Filter [P2]  Where FRMFLG=[F1]FRMFLG & FRMNUM=[F1]FRMNUM
              NBFRM = rowcount([P2])
              If ![L]SIMUL & NBFRM=1
               Delete [P2] Where FRMFLG=[F1]FRMFLG & FRMNUM=[F1]FRMNUM
               If fstat=1 : [V]GOK = -1 : [V]GLOCK = "$PAYFRM"-[F1]FRMNUM : Return : Endif
              Endif
           Endif
           # Si épuration des bordereaux => PAN & BES reste AF
           If [F1]PAYLOT<>""
              Filter [P1]  Where COD=[F1]PAYLOT
              NBLOT = rowcount([P1])
              If ![L]SIMUL & NBLOT=1
               Delete [P1] Where COD=[F1]PAYLOT
               If fstat=1 : [V]GOK = -1 : [V]GLOCK = "$PAYLOT"-[F1]PAYLOT : Return : Endif
              Endif
           Endif
    Endcase
Endif
Return

$FERME_PAYMENTH
If clalev([F:P1])  Close Local File [P1] : Endif
If clalev([F:P2])  Close Local File [P2] : Endif
If [L]TRACEDET
 If NBFRM : Call ECR_TRACE("---- PAYFRM (1) ",0) From GESECRAN : Endif
 If NBLOT : Call ECR_TRACE("---- PAYLOT (1) ",0) From GESECRAN : Endif
Endif
Return

#######################################################################################
# Historisation / Epuration de l'historisation des échéances                          #
#                                                                                     #
#######################################################################################
###DBA le 22/01/03 : Epuration de l'historique des échéances
# On garde dans l'historique :
# 1)les enreg créés aprés la date d'épuration
# 2)les enreg représentant la "dernière image" d'une échéance même créés avant la date
# d'épuration.
#######################################################################################

$OUVRE_DUD
If func AFNC.ACTIV("HDU") <> 0
 Local Char HCRIT(50)
 Local Integer OLDCLE, OLDNUM, OLDLIG, FLGHDUD
 Raz OLDCLE,OLDNUM,OLDLIG,FLGHDUD
 If clalev([F:P1])=0 :
    Local File =[L]APPLI+".HISTODUD"  [P1] Order By Key CLE=ACCNUM;DUDLIG;CREDAT;NUMHDU
 Endif
 If clalev([F:P2])=0 :
    Local File =[L]APPLI+".HISTODUD"  [P2] Order By Key CLE=ACCNUM;DUDLIG;CREDAT;NUMHDU
 Endif
 If clalev([F:P3])=0 : Local File =[L]APPLI+".HISTODUD"  [P3] : Endif
 FLGHDUD=1
Endif
If [L]HISTO
 If clalev([F:O9])=0 : Local File =[L]HISAPL+".ACTIV" [O9] : Endif
 Read [O9]CODACT="HDU"
 If !fstat & [O9]FLACT=2 & FLGHDUD=1
    If clalev([F:O1])=0 :
        Local File =[L]HISAPL+".HISTODUD"  [O1] Order By Key CLE=ACCNUM;DUDLIG;CREDAT;NUMHDU
    Endif
    If clalev([F:O2])=0 :
        Local File =[L]HISAPL+".HISTODUD"  [O2] Order By Key CLE=ACCNUM;DUDLIG;CREDAT;NUMHDU
    Endif
    If clalev([F:O3])=0 : Local File =[L]HISAPL+".HISTODUD"  [O3] : Endif

    If dim([F:O1]CREHISDAT)>0
       HCRIT = "CREHISDAT<=["+format$(GFMD,date$-TEMPS)+"]"
    Else
       HCRIT = "1=1"
    Endif
 Else
    FLGHDUD=0
 Endif
Endif
Return

$FILTRE_DUD
Case TABLE
     When "HISTODUD"   : FILTSUP ="TYP='ZZZ'"
Endcase
Return

$HISTO_DUD
Case TABLE
     When "HISTODUD"   : OKHIS = 0
Endcase
Return

$EPURE_DUD
Case TABLE
     When "HISTODUD"   : OKEPU = 0
Endcase
Return

$FERME_DUD
Call DEBTRANS From GLOCK
#JOJAC - 2018-09-13 - X3-80722 - START #Test if archive option is TRUE
If [M:DIA]HISTO = 2
  Gosub H_DUD
Endif
#Gosub H_DUD
#JOJAC - 2018-09-13 - X3-80722 - END
Call DEBTRANS From GLOCK
Gosub E_DUD
If clalev([F:P1])  Close Local File [P1] : Endif
If clalev([F:P2])  Close Local File [P2] : Endif
If clalev([F:P3])  Close Local File [P3] : Endif
If clalev([F:O1])  Close Local File [O1] : Endif
If clalev([F:O2])  Close Local File [O2] : Endif
If clalev([F:O3])  Close Local File [O3] : Endif
Return

$H_DUD
GOK = 1
Trbegin [O2]
If clalev([F:P1])=0 | clalev([F:P3])=0 | clalev([F:O2])=0 : Return  : Endif
If func AFNC.ACTIV("HDU") <> 0
 If OLDCLE=0
  For [F:P1]CLE Where evalue(FILTRE)
   If OLDCLE<>0
    If [F:P1]ACCNUM=OLDNUM & [F:P1]DUDLIG=OLDLIG
     Read[F:P3]HDU0=OLDCLE
     If !fstat
      [F:O2] = [F:P1]
      If dim([F:O2]CREHISDAT)>0 : [F:O2]CREHISDAT = date$    : Endif
      If dim([F:O2]CREHISUSR)>0 : [F:O2]CREHISUSR = [V]GUSER : Endif
      If ![L]SIMUL
       Write [O2]
       If fstat
        [V]GOK = 0 : Call FSTA("O2") From GLOCK : Break
       Endif
       Delete [P1]
       If fstat=1
        [V]GOK = -1 : [V]GLOCK = "$HISTODUD"-[P1]NUMHDU : Break
       Endif
      Endif
      NRDEL += 1
     Endif
    Endif
   Endif
   OLDCLE=[F:P1]NUMHDU
   OLDNUM=[F:P1]ACCNUM
   OLDLIG=[F:P1]DUDLIG
  Next
 Endif
Endif
If   GOK<0 : Goto ROLL_H_DUD
Elsif !GOK : Goto AB_H_DUD
Endif
Commit
Return

$AB_H_DUD
Rollback
Return

$ROLL_H_DUD
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto H_DUD : Endif

$E_DUD
GOK = 1
Trbegin [P3]
If clalev([F:P1])=0 | clalev([F:P3])=0 : Return  : Endif
If OLDCLE=0
 For [F:P1]CLE Where evalue(FILTRE)
  If OLDCLE<>0
   If [F:P1]ACCNUM=OLDNUM & [F:P1]DUDLIG=OLDLIG
    Read[F:P3]HDU0=OLDCLE
    If !fstat
     If ![L]SIMUL
      Delete [P3]
      If fstat=1
       [V]GOK = -1 : [V]GLOCK = "$HISTODUD"-[P3]NUMHDU : Break
      Endif
     Endif
     NRDEL += 1
    Endif
   Endif
  Endif
  OLDCLE=[F:P1]NUMHDU
  OLDNUM=[F:P1]ACCNUM
  OLDLIG=[F:P1]DUDLIG
 Next
Endif

If OLDCLE=0 & [V]GOK>0
 For [F:O1]CLE Where evalue(FILTRE) and evalue(HCRIT)
  If OLDCLE<>0
   If [F:O1]ACCNUM=OLDNUM & [F:O1]DUDLIG=OLDLIG
    Read[F:O3]HDU0=OLDCLE
    If !fstat
     If ![L]SIMUL
      Delete [O3]
      If fstat=1
       [V]GOK = -1 : [V]GLOCK = "$HISTODUD"-[O3]NUMHDU : Break
      Endif
     Endif
     NRDEL += 1
    Endif
   Endif
  Endif
  OLDCLE=[F:O1]NUMHDU
  OLDNUM=[F:O1]ACCNUM
  OLDLIG=[F:O1]DUDLIG
 Next
Endif

If   GOK<0 : Goto ROLL_E_DUD
Elsif !GOK : Goto AB_E_DUD
Endif
Commit
Return

$AB_E_DUD
Rollback
Return

$ROLL_E_DUD
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto E_DUD : Endif


#######################################################################################
# Historisation / Epuration des relevés bancaires                                     #
#                                                                                     #
#######################################################################################
$OUVRE_RELBANK
If clalev([F:R0])=0  : Local File =[L]APPLI+".RELBANK"     [R0]  : Endif
If clalev([F:R1])=0  : Local File =[L]APPLI+".RELBANK"     [R1]  : Endif
If clalev([F:RR1])=0 : Local File =[L]APPLI+".RELBANKREM"  [RR1] : Endif
If HISTO=1
 If clalev([F:R2])=0  : Local File =[L]HISAPL+".RELBANK"    [R2]  : Endif
 If clalev([F:R3])=0  : Local File =[L]HISAPL+".RELBANK"    [R3]  : Endif
 If clalev([F:RR2])=0 : Local File =[L]HISAPL+".RELBANKREM" [RR2] : Endif
 Call VUE_OK("RELBANKREM",[L]HISAPL,"FIL",VUE) From DOSVUE
 If VUE
  Call CRETABLE([L]APPLI,[L]HISAPL,TYPDBA,"RELBANKREM",COEFF,0) From CREHISTO
 Endif
Else
 If clalev([F:R2])=0  : Local File =[L]APPLI+".RELBANK"     [R2]  : Endif
 If clalev([F:R3])=0  : Local File =[L]APPLI+".RELBANK"     [R3]  : Endif
 If clalev([F:RR2])=0 : Local File =[L]APPLI+".RELBANKREM"  [RR2] : Endif
Endif
If clalev([F:BAN])=0 : Local File =[L]APPLI+".BANK"    [BAN] : Endif
If clalev([F:PER])=0 : Local File =[L]APPLI+".PERIOD"  [PER] : Endif
If clalev([F:GCM])=0 : Local File =[L]APPLI+".GACM"    [GCM] : Endif

Local Char BANCPYCUR(GLONCPY)
Local Integer RLKOK        : # RLKOK=0 if the bank statement must not be archived or purged
Local Decimal EXE          : # Fiscal year
Local Decimal PER          : # Period
Local Integer TYPLED       : # ledger type
Local Integer CTRL         : # No check if purge in HISAPL
# Histo/Archive   : FLGRECTYP=1 If [RELBANK]RECTYP=1 / FLGRECTYP=2 If [F:RELBANK]RECTYP=2 or 3
# Epuration/Purge : FLGRECTYP=3 If [RELBANK]RECTYP=1 / FLGRECTYP=4 If [F:RELBANK]RECTYP=2 or 3
Local Integer FLGRECTYP    : # Record type
Return

#######################################################################################
# To not run the loop For[F1] in AHISTO
$FILTRE_RELBANK
Case TABLE
  When "RELBANK"   : FILTSUP ="NUMRBK='ZZZ'"
Endcase
Return

#######################################################################################
$HISEPU_RELBANK
OKHIS = 0
OKEPU = 0
Return

#######################################################################################
# This label is called both from the archive and purge
# Check the purge date to prevent the archive when the purge is running or to prevent the purge when the archive is running
$FERME_RELBANK
CTRL = 1
If [M:DIA]HISTO=2 & EPUDAT=[0/0/0]
 Gosub HIS_RELBANK
Endif

If [M:DIA]EPUR=2 & EPUDAT<>[0/0/0]
 If HISTO=1 : CTRL = 0 :Endif
 Gosub EPU_RELBANK
Endif

If clalev([F:R0])  : Close Local File [R0]  : Endif
If clalev([F:R1])  : Close Local File [R1]  : Endif
If clalev([F:R2])  : Close Local File [R2]  : Endif
If clalev([F:R3])  : Close Local File [R3]  : Endif
If clalev([F:BAN]) : Close Local File [BAN] : Endif
If clalev([F:PER]) : Close Local File [PER] : Endif
If clalev([F:RR1]) : Close Local File [RR1] : Endif
If clalev([F:RR2]) : Close Local File [RR2] : Endif
Return


#######################################################################################
# L'épuration/historisation ne se fait que pour un relevé dans son intégralité. Il faut donc regarder toutes les lignes du relevé
# The purge/archive is done only for a bank statement in its entirety. All bank statement lines have to be checked
$HIS_RELBANK
FILTSUP = "1=1"
If SOCIETE<>""
 FILTSUP -= "& [F:BAN]CPY = '"+SOCIETE+"'"
Endif

Link [R0] With [F:BAN]BAN0=[F:R0]BAN
& As [LNK]
& Where evalue(FILTRE) & evalue(FORMU) & evalue(FILTSUP) & RECTYP = 1

Call DEBTRANS From GLOCK
Gosub TR1
NRDEL += NBDEL
NBRES = nbrecord([R1])
If SIMUL : NBRES -= NPDEL : Endif
Return

#######################################################################################
$TR1
GOK = 1
Trbegin [R2]
 Raz BANCPYCUR
 # Iterate by bank, all the header records whose opedat is ok.
 For [LNK]RBK1(1) : # BAN
  If BANCPYCUR<>[F:BAN]CPY
   BANCPYCUR = [F:BAN]CPY
   Call LECLEDMAIN(1,[F:BAN]CPY,TYPLED) From CPTDIV
  Endif

  For [LNK]RBK1(4) : # BAN / RECTYP / OPEDAT / RBKNUM
   # Check that the bank statement is OK
   FLGRECTYP = 1
   Gosub CHK_RECTYP
   If RLKOK=0 : Break : Endif

   For [R1]RBK1 Where BAN=[F:R0]BAN & RBKNUM=[F:R0]RBKNUM & RECTYP<>1
    FLGRECTYP = 2
    Gosub CHK_RECTYP
    If RLKOK=0 : Break 2 : Endif
   Next

   # The bank statement is Ok => archive
   For [R1]RBK1 Where BAN=[F:R0]BAN & RBKNUM=[F:R0]RBKNUM
    [F:R2] = [F:R1]
    If dim([F:R2]CREHISDAT)>0 : [F:R2]CREHISDAT = HISDAT   : Endif
    If dim([F:R2]CREHISUSR)>0 : [F:R2]CREHISUSR = [V]GUSER : Endif
    If ![L]SIMUL
     Write [R2]
     If fstat
      [V]GOK = 0 : Call FSTA("R2") From GLOCK : Break 3
     Endif
    Endif
    [V]GCLE = [F:R1]BAN-[F:R1]RBKNUM-num$([F:R1]RECTYP)-num$([F:R1]RBKLIN)
    If ![L]SIMUL
     Delete [R1]
     If fstat=1
      [V]GOK = -1 : [V]GLOCK = "$RELBANK"-[V]GCLE : Break 3
     Endif
    Endif
    [L]NBDEL += 1
    [L]NPDEL += 1
    [L]NBEPU += 1
   Next

   # RELBANKREM
   For [RR1] Where BAN=[F:R0]BAN & RBKNUM=[F:R0]RBKNUM
    [F:RR2] = [F:RR1]
    If dim([F:RR2]CREHISDAT)>0 : [F:RR2]CREHISDAT = HISDAT   : Endif
    If dim([F:RR2]CREHISUSR)>0 : [F:RR2]CREHISUSR = [V]GUSER : Endif
    If ![L]SIMUL
     Write [RR2]
     If fstat
      [V]GOK = 0 : Call FSTA("RR2") From GLOCK : Break 3
     Endif
    Endif
    [V]GCLE = [F:RR1]BAN-[F:RR1]RBKNUM-num$([F:RR1]RBKLIN)-num$([F:RR1]REMNUM)
    If ![L]SIMUL
     Delete [RR1]
     If fstat=1
      [V]GOK = -1 : [V]GLOCK = "$RELBANKRREM"-[V]GCLE : Break 3
     Endif
    Endif
   Next

   If [L]TRACEDET
    Call ECR_TRACE("--"-mess(22,133,1)-[F:R0]BAN-[F:R0]RBKNUM,0) From GESECRAN : # Archive
   Endif
   If [L]NBDEL>=[L]MAXDEL
    Commit
    [L]NRDEL += [L]NBDEL
    [L]NBDEL  = 0
    Trbegin [R2]
   Endif
  Next

 Next

 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#######################################################################################
$CHK_RECTYP
# A bank statement can be purged/archived only if
# - all the lines are reconcilied
# - values of the OPEDAT field is <= the pivot date
# - OPEDAT belongs to a closed period

# Un relevé ne peut être épuré que si :
# - toutes ses lignes sont pointées
# - OPEDAT est antèrieur à la date pivot
# - OPEDAT appartient à une période close : pour la CPY de la BAN et son réf géné principal
RLKOK = 1
If !CTRL : Return : Endif
Case FLGRECTYP
  When 1 : Call GETPERSOC([F:BAN]CPY,TYPLED,[F:R0]OPEDAT,EXE,PER) From CPTSUB
  When 2 : If [F:R1]RECTYP=2 & [F:R1]CHK=""
            If [L]TRACEDET
             # Ecriture non pointée dans le relevé
             Call ECR_TRACE([F:R1]BAN-mess(91,120,1)-[F:R1]RBKNUM-mess(61,100,1)-num$([F:R1]RBKLIN-1),-1) From GESECRAN
            Endif
            RLKOK = 0 : Return
           Endif
           If [F:R1]OPEDAT>REFDAT : RLKOK = 0 : Return : Endif
           Call GETPERSOC([F:BAN]CPY,TYPLED,[F:R1]OPEDAT,EXE,PER) From CPTSUB
  When 3 : Call GETPERSOC([F:BAN]CPY,TYPLED,[F:R2]OPEDAT,EXE,PER) From CPTSUB
  When 4 : If [F:R3]RECTYP=2 & [F:R3]CHK=""
            If [L]TRACEDET
             # Ecriture non pointée dans le relevé
             Call ECR_TRACE([F:R3]BAN-mess(91,120,1)-[F:R3]RBKNUM-mess(61,100,1)-num$([F:R3]RBKLIN-1),-1) From GESECRAN
            Endif
            RLKOK = 0 : Return
           Endif
           If [F:R3]OPEDAT>REFDAT : RLKOK = 0 : Return : Endif
           Call GETPERSOC([F:BAN]CPY,TYPLED,[F:R3]OPEDAT,EXE,PER) From CPTSUB
Endcase
If EXE=0 | PER=0    : RLKOK = 0 : Return : Endif
If [F:PER]PERSTA<>3 : RLKOK = 0 : Return : Endif
Return


#######################################################################################
$EPU_RELBANK
FILTSUP = "1=1"
If SOCIETE<>""
 FILTSUP -= "& [F:BAN]CPY = '"+SOCIETE+"'"
Endif
# The Link is declared with R2
Link [R2] With [F:BAN]BAN0=[F:R2]BAN
& As [LNK]
& Where evalue(FILTRE) & evalue(FORMU) & evalue(FILTSUP) & RECTYP = 1

Call DEBTRANS From GLOCK
Gosub TR2
NRDEL += NBDEL
NBRES = nbrecord([R2])
If SIMUL : NBRES -= NPDEL : Endif
Return

#######################################################################################
$TR2
GOK = 1
Trbegin [R3]
 Raz BANCPYCUR
 # Iterate by bank, all the header records whose opedat is ok.
 For [LNK]RBK1(1) : # BAN
  If BANCPYCUR<>[F:BAN]CPY
   BANCPYCUR = [F:BAN]CPY
   Call LECLEDMAIN(1,[F:BAN]CPY,TYPLED) From CPTDIV
  Endif

  For [LNK]RBK1(4) : # BAN / RECTYP / OPEDAT / RBKNUM
   # Check that the bank statement is OK
   FLGRECTYP = 3
   Gosub CHK_RECTYP
   If RLKOK=0 : Break : Endif

   For [R3]RBK1 Where BAN=[F:R2]BAN & RBKNUM=[F:R2]RBKNUM & RECTYP<>1
    FLGRECTYP = 4
    Gosub CHK_RECTYP
    If RLKOK=0 : Break 2 : Endif
   Next

   # The bank statement is Ok => purge
   For [R3]RBK1 Where BAN=[F:R2]BAN & RBKNUM=[F:R2]RBKNUM
    [V]GCLE = [F:R3]BAN-[F:R3]RBKNUM-num$([F:R3]RECTYP)-num$([F:R3]RBKLIN)
    If ![L]SIMUL
     Delete [R3]
     If fstat=1
      [V]GOK = -1 : [V]GLOCK = "$RELBANK"-[V]GCLE : Break 3
     Endif
    Endif
    [L]NBDEL += 1
    [L]NPDEL += 1
   Next

   # RELBANKREM
   For [RR2] Where BAN=[F:R2]BAN & RBKNUM=[F:R2]RBKNUM
    [V]GCLE = [F:RR2]BAN-[F:RR2]RBKNUM-num$([F:RR2]RBKLIN)-num$([F:RR2]REMNUM)
    If ![L]SIMUL
     Delete [RR2]
     If fstat=1
      [V]GOK = -1 : [V]GLOCK = "$RELBANKREM"-[V]GCLE : Break 3
     Endif
    Endif
   Next

   If [L]TRACEDET
    Call ECR_TRACE("--"-mess(29,133,1)-[F:R2]BAN-[F:R2]RBKNUM,0) From GESECRAN : # Purge
   Endif
   If [L]NBDEL>=[L]MAXDEL
    Commit
    [L]NRDEL += [L]NBDEL
    [L]NBDEL  = 0
    Trbegin [R3]
   Endif
  Next

 Next

 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif

Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

