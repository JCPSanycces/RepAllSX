#<AdxTL>@(#)0.0.0.0 $Revision$
Local Integer SAVING

$ACTION
Case ACTION
 When "OUVRE"           : Gosub OUVRE
 When "LIENS"           : Gosub LIENS
 When "CREATION"        : Gosub CREATION
 When "MODIF"           : Gosub MODIF
 When "RAZCRE"          : Gosub RAZCRE
 When "APRES_CRE"       : Gosub APRES_CRE
 When "APRES_MOD"       : Gosub APRES_MOD
 When "DEGRISE"         : Gosub DEGRISE
 When Default
  #If GUSER = 'PITRU': Infbox ACTION : Endif
Endcase
Return

$OUVRE
  SAVING = 1
  If clalev([F:HRAEH])    = 0 : Local File HRAEHEADER       [HRAEH]           : Endif
  If clalev([F:HRAEH2])   = 0 : Local File HRAEHEADER       [HRAEH2]          : Endif
  If clalev([F:HRAED])    = 0 : Local File HRAEDETAIL       [HRAED]           : Endif
  If clalev([F:HRAES])    = 0 : Local File HRAESUSPEND      [HRAES]           : Endif
  If clalev([F:ID])       = 0 : Local File EMPLOID          [ID]              : Endif
  If clalev([F:HRCTR])    = 0 : Local File EMPLOCTR         [HRCTR]           : Endif
  If clalev([F:HRAET])    = 0 : Local File HRATTEARTYP      [HRAET]           : Endif
Return

$LIENS
  Read[F:ID]ID0=[M:HRAE0]REFNUM
  If !fstat Then
    [M:HRAE0]NAM = [F:ID]NAM
    [M:HRAE0]SRN = [F:ID]SRN
  Endif

  Read [HRAED]HRAED0 = [M:HRAE0]AEHCOD
  If !fstat
    [M:HRAE1] = [F:HRAED]

    Read [HRAET]HRAET0 = [M:HRAE1]TYPCOD
    If !fstat
      [M:HRAE1]CODAET = [F:HRAET]CODAET
      [M:HRAE1]PAYFRQ = [F:HRAET]PAYFRQ
      [M:HRAE1]EFFDAT = [F:HRAET]EFFDAT
      Call INSTALLMENTACTIVE([F:HRAET]FIXEDAMT)
    Endif
  Endif

  Filter [F:HRAES] Where AEHCOD = [M:HRAE0]AEHCOD
  nolign = 0
  For [HRAES]HRAES0
    nolign += 1
    [M:HRAE2] = [F:HRAES]
  Next
  Assign "[M:HRAE2]SUPNBR" With nolign
  Filter [HRAES]

  Call TOGGLE_READONLY(1)
Return

$CREATION
$MODIF
  SAVING = 2
  Read [HRAEH]HRAEH0 = [M:HRAE0]AEHCOD

  Filter [F:HRAED]
  Delete [F:HRAED] Where [F:HRAED]AEHCOD=[M:HRAE0]AEHCOD
  If fstat=1 | fstat>5
    GOK=0 : Call RSTA("AEDR",[F:HRAED]AUUID) From GLOCK : Return
  Endif

  Raz [F:HRAED]
  [F:HRAED] = [M:HRAE1]
  [F:HRAED]AEHCOD = [M:HRAE0]AEHCOD
  Write [F:HRAED]
  If fstat
    GOK=0 : Call FSTA("HRAED") From GLOCK
  Endif

  Filter [F:HRAES]
  Delete [F:HRAES] Where [F:HRAES]AEHCOD=[M:HRAE0]AEHCOD
  If fstat=1 | fstat>5
    GOK=0 : Call RSTA("AEDR",[F:HRAES]AUUID) From GLOCK : Return
  Endif

  For nolign = 1 To [M:HRAE2]SUPNBR
    Raz [F:HRAES]
    [F:HRAES] = [M:HRAE2]
    [F:HRAES]AEHCOD = [M:HRAE0]AEHCOD
    [F:HRAES]LIGNBR = nolign
    Write [F:HRAES]
    If fstat
      GOK=0 : Call FSTA("HRAES") From GLOCK : Break
    Endif
  Next
Return

$RAZCRE
  Call TOGGLE_READONLY(2)
Return

$APRES_CRE
$APRES_MOD
  Call TOGGLE_READONLY(1)
Return

$DEGRISE
  If SAVING = 2
    Grizo [M:HRAE0]AEHCOD
  Endif
  SAVING = 1
Return

Subprog TOGGLE_READONLY(ACTIVE)
Value Integer ACTIVE

  If ACTIVE = 2
    Actzo [M:HRAE0]REFNUM
    Actzo [M:HRAE0]CTRNUM
    Actzo [M:HRAE0]AEHCOD
    Actzo [M:HRAE1]TYPCOD
    Actzo [M:HRAE1]STRDAT
    Actzo [M:HRAE1]AEBAL
    Actzo [M:HRAE1]MTHINS
  Else
    Grizo [M:HRAE0]REFNUM
    Grizo [M:HRAE0]CTRNUM
    Grizo [M:HRAE0]AEHCOD
    Grizo [M:HRAE1]TYPCOD
    Grizo [M:HRAE1]STRDAT
    Grizo [M:HRAE1]AEBAL
    Grizo [M:HRAE1]MTHINS
  Endif

End

Subprog INSTALLMENTACTIVE(VFIXEDAMT)
Value Integer VFIXEDAMT

  If VFIXEDAMT = 1
    Grizo [M:HRAE1]MTHINS
  Else
    Actzo [M:HRAE1]MTHINS
  Endif
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
  Read[F:ID]ID0=VALEUR
  If !fstat Then
    [M:HRAE0]NAM = [F:ID]NAM
    [M:HRAE0]SRN = [F:ID]SRN
  Endif
  Affzo [M:HRAE0]
End


Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()

  Local Char COUNTER(30)
  Local Integer STAT

  [M:HRAE0]CTRDAT = [F:HRCTR]CTRDAT
  Affzo [M:HRAE0]CTRDAT

  Call NUMERO("AEHEA", [F:HRCTR]ETRFCY, date$, "", COUNTER, STAT) From SUBANM
  If STAT
    GMESSAGE = mess(104,117,1) - "AEHEA"
    GOK = 0 : End
  Endif
  [M:HRAE0]AEHCOD = COUNTER
  Affzo [M:HRAE0]AEHCOD
End

Subprog C_TYPCOD(VALEUR)
Variable Char    VALEUR()
  [M:HRAE1]TYPCOD = [F:HRAET]TYPCOD
  [M:HRAE1]CODAET = [F:HRAET]CODAET
  [M:HRAE1]PAYFRQ = [F:HRAET]PAYFRQ
  [M:HRAE1]EFFDAT = [F:HRAET]EFFDAT
  Call INSTALLMENTACTIVE([F:HRAET]FIXEDAMT)
  Affzo [M:HRAE1]
End

Subprog AM_DEDPRI(VALEUR)
Variable Decimal VALEUR

  If VALEUR <= 0
    GMESSAGE = mess(25,11800,1)
    mkstat = 2 : GERR=1
  Endif

  Local Integer I

  Filter [HRAEH2] Where AEHCOD <> [M:HRAE0]AEHCOD & REFNUM = [M:HRAE0]REFNUM & CTRNUM = [M:HRAE0]CTRNUM & CTRDAT = [M:HRAE0]CTRDAT
  For [HRAEH2]
    I += 1
    If [F:HRAEH2]DEDPRI = VALEUR
      GMESSAGE = mess(23,11800,1)
      mkstat = 2 : GERR=1
    Endif
  Next
  Filter [HRAEH2]
End

Subprog AM_ADMCOST(VALEUR)
Variable Decimal VALEUR
  If VALEUR > 2
    GMESSAGE = mess(27,11800,1)
    mkstat = 2 : GERR=1
  Endif
End

Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR < [M:HRAE0]CTRDAT
    GMESSAGE = mess(28,11800,1)
    mkstat = 2 : GERR=1
  Endif

End

Subprog AM_STADAT(VALEUR)
Variable Date    VALEUR
End

Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR

#  If VALEUR <> [0/0/0]
