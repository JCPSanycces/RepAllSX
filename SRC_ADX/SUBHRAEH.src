End

Subprog AM_PROTEARNAMT(VALEUR)
Variable Decimal VALEUR
  If VALEUR > 0 & [M:HRAE1]PROTEARNPCT > 0
    GMESSAGE = mess(26,11800,1)
    mkstat = 2 : GERR=1
  Endif
End

Subprog AM_PROTEARNPCT(VALEUR)
Variable Decimal VALEUR
  If VALEUR > 0 & [M:HRAE1]PROTEARNAMT > 0
    GMESSAGE = mess(26,11800,1)
    mkstat = 2 : GERR=1
  Endif
End

