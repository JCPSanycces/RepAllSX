##########################################################################################################
# Description transfert information tache  synchronisation Adonix-Outlook     Module CRM     Dûˋcembre 2005
##########################################################################################################
# TSK_INISETDSC : Initialisation variables description Outlook Adonix
# TSK_LD_SETDESC : Dûˋfinition description Outlook Adonix
#
# TSK_INIGETDSC  : Initialisation variables description Adonix Outlook
# TSK_LD_GETDESC : Dûˋfinition description Adonix Outlook
##########################################################################################################
##########################################################################################################
# paramûˋtrage description
# - - - - - - - - -
# Nota:
#  <Line  Multi="N" Id="IdentKey">'
#   <X3 Cat="S"  />'
#   <OL Name="OlName" Cat="S" />'
#  </Line>'
#
#  *  <X3 Cat="S"  />'
#         Cette info n'est pas exploitûˋe
#         Cat: Standard - User (perso)
#  * <OL Name="Subject" Cat="S" />
#         Cat: Standard - User (perso)
#  * <Line  Multi="N" ... >
#        Multi: Yes - No  -> Ligne pouvant gûˋnûˋrûˋ plusieurs clûˋs sous la forme: IdentKey_1 û  IdentKey_n
#        L'Add-In standard a une gestion propre basûˋ sur OlName pour traiter un Multi (ex: Contacts des taches)
#        - Pour l'instant, il n'est pas utilisable avec une categorie U <OL Name="OlName" Cat="U" />
#        - <Line Multi="N" ... > est ûˋgal û  <Line   ... >
#  * <OL Name="OlName" Cat="U" UserType="xxx" />'
#        UserType va de pair avec Cat='U'
#        Pour l'instant, il est utilisûˋ avec TbInt
#            - MC_TU_NB (dûˋfaut):    nombre  ("olNumber")
#            - MC_TU_YESNO:          oui/non ("olYesNo")

# Cas non gûˋrûˋs:
#  - multi='Y'
##########################################################################################################
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
# SENS OUTLOOK ADONIX
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
##########################################################################################################
# Dûˋclaration variables  Outlook Adonix
# ------------------------------------------------------------
$TSK_INISETDSC
Local Char VERSION(GLONDES)

  VERSION="V00002"
Return

##########################################################################################################
# Pgrm TSK_LD_SETDESC : Dûˋfinition description Outlook Adonix
$TSK_LD_SETDESC
  WI += 1 : WDSC(WI) = '<Description Trt="SUBSYDTSK" Subprog="TSK_SET" Version="' +VERSION+ '" AdxIdLib='+ GLIBCHRONOTSK + '>'
  # - - - -tableau de Char
  WI += 1 : WDSC(WI) = ' <TbChr Size="200" Dim="10">'
  WI += 1 : WDSC(WI) = '  <Line Id="Subject">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Subject" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line Id="Companies">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Companies" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbChr>'
  # - - - -Tableau d'entiers
  WI += 1 : WDSC(WI) = ' <TbInt Dim="10">'
  WI += 1 : WDSC(WI) = '  <Line  Id="ActualWork">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="ActualWork" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="Complete">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Complete" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="Status">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Status" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbInt >'
  # - - - -Tableau de dûˋcimal
  WI += 1 : WDSC(WI) = ' <TbDec Dim="0">'
  WI += 1 : WDSC(WI) = ' </TbDec>'
  # - - - -Tableau de date
  WI += 1 : WDSC(WI) = ' <TbDate Dim="4">'
  WI += 1 : WDSC(WI) = '  <Line  Id="StartDate">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="StartDate" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="DueDate">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="DueDate" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="LastModificationTime">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="LastModificationTime" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbDate >'
  # - - - -Tableau de clob
  WI += 1 : WDSC(WI) = ' <TbCClob Dim="2" Size="3">'
  WI += 1 : WDSC(WI) = '  <Line Id="Subject">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Subject" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="Body">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Body" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbCClob>'
  # - - - -Tableau de spûˋcial
  WI += 1 : WDSC(WI) = ' <Special>'
  If GIBSYNCTSKGERECOR = MC_TRUE Then
    WI += 1 : WDSC(WI) = '   <Link Id="Lk">'
    WI += 1 : WDSC(WI) = '     <TbChr>'
    WI += 1 : WDSC(WI) = '       <Line Id="Name">'
    WI += 1 : WDSC(WI) = '         <X3 Cat="S" />'
    WI += 1 : WDSC(WI) = '         <OL Name="FullName" Cat="S" />'
    WI += 1 : WDSC(WI) = '       </Line>'
    WI += 1 : WDSC(WI) = '       <Line Id="CtAdxId">'
    WI += 1 : WDSC(WI) = '         <X3 Cat="S" />'
    WI += 1 : WDSC(WI) = '         <OL Name="AdxId" Cat="S" />'
    WI += 1 : WDSC(WI) = '       </Line>'
    WI += 1 : WDSC(WI) = '     </TbChr>'
    WI += 1 : WDSC(WI) = '     <TbInt>'
    WI += 1 : WDSC(WI) = '       <Line Id="HasContact">'
    WI += 1 : WDSC(WI) = '         <X3 Cat="S" />'
    WI += 1 : WDSC(WI) = '         <OL Name="" Cat="S" />'
    WI += 1 : WDSC(WI) = '       </Line>'
    WI += 1 : WDSC(WI) = '     </TbInt>'
    WI += 1 : WDSC(WI) = '   </Link>'
  Endif
  WI += 1 : WDSC(WI) = ' </Special>'
  WI += 1 : WDSC(WI) = '</Description>'
Return

#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
# SENS ADONIX OUTLOOK
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
##########################################################################################################
# Dûˋclaration variables  Adonix Outlook
# ------------------------------------------------------------
$TSK_INIGETDSC
Local Char VERSION(GLONDES)

  VERSION="V00005"
Return

##########################################################################################################
# Dûˋfinition description Adonix Outlook
# Structure LD
# ------------------------------------------------------------
$TSK_LD_GETDESC
  WI += 1 : WDSC(WI) = '<Description Trt="SUBSYDTSK" Subprog="TSK_GET" Version="' +VERSION+ '" AdxIdLib='+ GLIBCHRONOTSK + '>'
  # - - - -Tableau de char
  WI += 1 : WDSC(WI) = ' <TbChr Size="200" Dim="10">'
  WI += 1 : WDSC(WI) = '  <Line Id="Companies">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Companies" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbChr>'
  # - - - -Tableau d'entiers
  WI += 1 : WDSC(WI) = ' <TbInt Dim="10">'
  WI += 1 : WDSC(WI) = '  <Line  Id="ActualWork">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="ActualWork" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="Status" >'                     # OK Int  0 û  4 olTaskInProgress=1
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Status" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbInt >'
  # - - - -tableau de dûˋcimal
  WI += 1 : WDSC(WI) = ' <TbDec Dim="0">'
  WI += 1 : WDSC(WI) = ' </TbDec>'
  # - - - -Tableau de date
  WI += 1 : WDSC(WI) = ' <TbDate Dim="3">'
  WI += 1 : WDSC(WI) = '  <Line  Id="AdxTaskDateTime">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="AdxTaskDateTime" Cat="U" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="StartDate">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="StartDate" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="DueDate">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="DueDate" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbDate >'
  # - - - -
  WI += 1 : WDSC(WI) = ' <TbCClob Dim="2" Size="6">'
  WI += 1 : WDSC(WI) = '  <Line  Id="Subject">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Subject" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = '  <Line  Id="Body">'
  WI += 1 : WDSC(WI) = '   <X3 Cat="S"  />'
  WI += 1 : WDSC(WI) = '   <OL Name="Body" Cat="S" />'
  WI += 1 : WDSC(WI) = '  </Line>'
  WI += 1 : WDSC(WI) = ' </TbCClob>'
  # - - - -
  WI += 1 : WDSC(WI) = ' <Special>'
  If GIBSYNCTSKGERECOR = MC_TRUE Then
    WI += 1 : WDSC(WI) = '   <Link Id="Lk">'
    WI += 1 : WDSC(WI) = '     <TbChr>'
    WI += 1 : WDSC(WI) = '       <Line Id="Name">'
    WI += 1 : WDSC(WI) = '         <X3 Cat="S" />'
    WI += 1 : WDSC(WI) = '         <OL Name="FullName" Cat="S" />'
    WI += 1 : WDSC(WI) = '       </Line>'
    WI += 1 : WDSC(WI) = '       <Line Id="CtAdxId">'
    WI += 1 : WDSC(WI) = '         <X3 Cat="S" />'
    WI += 1 : WDSC(WI) = '         <OL Name="AdxId" Cat="S" />'
    WI += 1 : WDSC(WI) = '       </Line>'
    WI += 1 : WDSC(WI) = '     </TbChr>'
    WI += 1 : WDSC(WI) = '   </Link>'
  Endif
  WI += 1 : WDSC(WI) = ' </Special>'
  WI += 1 : WDSC(WI) = '</Description>'
Return
