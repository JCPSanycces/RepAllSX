#<AdxTL>@(#)0.0.0.0 $Revision$Class Default dimensions
# Supervisor
## ACLA-CLASSE ## CACCEDEF_IDENT
# 2018-11-06 07:04:05 376


####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : FLD Identifiers ( Field AFR 128)
####################################################################

$SET_FLD
If [L]_AOLDVAL<>this.FLD
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_FLD
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.FLD
 Gosub PROPAGATE_FLD
Endif
Return

$INIT_FLD
Gosub DECLARE_VAR From WMC0CACCEDEF_IDENT
[L]CURPRO = "FLD"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_FLD
Gosub DECLARE_VAR From WMC0CACCEDEF_IDENT
[L]CURPRO = "FLD"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_FLD                   : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_FLD                   : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_FLD
[L]CURPRO = "FLD"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.FLD,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_FLD
[L]CURPRO = "FLD"
Return

$_AOTHERS_FLD
[L]CURPRO = "FLD"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_FLD
[L]CURPRO = "FLD"
Return

$PROPAGATE_FLD
this.isReadonly = 0
[L]CURPRO = "FLD"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_FLD
Gosub DECLARE_VAR From WMC0CACCEDEF_IDENT
[L]CURPRO = "FLD"
$_LNKPRO_FLD
Return




