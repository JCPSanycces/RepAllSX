#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SOPENORDER
#######################################################################################
End

#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER                     From SOPENORDER_CSTD_METHODS
        When "AINIT"                   : Gosub AINIT                           From SOPENORDER_CSTD_METHODS
      Endcase
    When "SVV"
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER_SVV                 From SOPENORDER_CSTD_METHODS
        When Default
      Endcase
    When "SVF"
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER_SVF                 From SOPENORDER_CSTD_METHODS
        When Default
      Endcase
    When "SVF.C_DTAVAT"
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER_SVF_C_DTAVAT        From SOPENORDER_CSTD_METHODS
        When Default
      Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "INIT_TSCCODADI"              : Gosub INIT_TSCCODADI                  From SOPENORDER_CSTD_METHODS # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - moved from
# $EVENT
  Endcase
Return
#--------------------------------------
#######################################################################################
$PROPERTIES
  Case CURPTH
    When ""
      Case CURPRO
        When "CPYCUR"                   :  Gosub CPYCUR         From SOPENORDER_PROPERTIES
        # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - deleted all _LEG properties call
        When "INVCDTA"                  :  Gosub INVCDTA        From SOPENORDER_PROPERTIES
        When Default
      Endcase
  Endcase
Return

