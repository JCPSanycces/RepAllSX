#<AdxTL>@(#)2.0.0.0 $Revision$ Consultation AUD
Local Char PARAM(10)(1..8)
PARAM(1)= "120101"
PARAM(2)= "120131"
PARAM(3) = "APRINTER"
PARAM(4) =""
PARAM(5) ="2"
PARAM(6) =""
PARAM(7) =""
PARAM(8) =""
GCONSULT = 0
Raz GNBMASKOUV
Call GCONSULT("AUD","",PARAM) From GCONSULT
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "DEB_CRIT"   : Gosub SET_ECRAN
Endcase
Return

$OUVRE
If clalev([F:AUD])=0 : Local File AUDITH   [AUD] : Endif
If clalev([F:AUL])=0 : Local File AUDITL   [AUL] : Endif
If clalev([F:ATB])=0 : Local File ATABLE   [ATB] : Endif
If clalev([F:AOB])=0 : Local File AOBJET   [AOB] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif
If clalev([F:ACN])=0 : Local File ACONSULT [ACN] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON  [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE    [ATY] : Endif

Local Char    CRITENT(250) , CRITSUI(250)
Local Integer SEQUENCE , MAXLIG , DET , O , N
Local Char    CHAMP(20)
Local Char    TBFLD(GLONAVA+GLONATB+1)(1..99) , FLD(GLONAVA) , TAB(GLONATB)
Local Integer TBLIB(1..99) , NBTB , O , N

MAXLIG = dim([M:CAU2]SEQ)

Gosub DEFCRIT

If [M:CAU1]STRDAT=[0/0/0] & [M:CAU1]ENDDAT=[0/0/0] 
 [M:CAU1]STRDAT = GDATEDEB
 [M:CAU1]ENDDAT = GDATEFIN
Endif

Return

$DEFCRIT
For I=1 To dim(PARAM)
 Case I
   When 1 : # STRDAT
    If instr(1,PARAM(I),"/")
     [M:CAU1]STRDAT= "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:CAU1]STRDAT= PARAM(I)
    Endif
   When 2 : # ENDDAT
    If instr(1,PARAM(I),"/")
     [M:CAU1]ENDDAT= "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:CAU1]ENDDAT= PARAM(I)
    Endif
   When 3 : # TABLE
    If PARAM(I)<>""
     Call LECTURE("ATB",PARAM(I),"") From CONTOBJ
     If !fstat
      [M:CAU1]TABLE= PARAM(I)
     Endif
    Endif
   When 4 : # CHAMP
    [M:CAU1]USER = PARAM(I)
   When 5 : # DETAIL
    Onerrgo
    [M:CAU1]DETAIL= val(PARAM(I))
    Onerrgo
   When 6 : # USER
    If PARAM(I)<>""
     Call LECTURE("AUS",PARAM(I),"") From CONTOBJ
     If !fstat
      [M:CAU1]USER = PARAM(I)
     Endif
    Endif
   When 7 : # LOGIN
    [M:CAU1]LOGIN= PARAM(I)
   When 8 : # EVENEMENT
    If PARAM(I) <> ""
     For II=6 To 1 Step-1
      For ACT="INSERT","UPDATE","DELETE"
       If left$(PARAM(I),II)=left$(ACT,II)
        [M:CAU1]EVENEMENT= ACT : Break 2
       Endif
      Next ACT
     Next I
   Endif
  Endcase
Next I
Return

$LECTURE
Gosub CRITENT
Gosub CRITSUI
If [M:CAU1]DETAIL=2
 DET = 2
Else
 DET = 1
Endif
NOL = 0
SUITE  = 1
RETOUR = 1
Link [AUL] With [AUD]AUD0=[F:AUL]SEQ As [LAUL]
If CHGPAG>0
 Filter [LAUL] Where evalue(CRITENT) & evalue(CRITSUI)
&              Order By Key CLE=[F:AUL]SEQ;[F:AUL]COL
 NOL = 0
 For [LAUL]CLE(DET)
  If NOL>=MAXLIG
   SUITE = 2 : Break
  Else
   If CHGPAG=2 : RETOUR = 2 : Endif
   NOL += 1
   Gosub CHARGE
  Endif
 Next
 [M:CAU2]NBLIG = NOL
Else
 Filter [LAUL] Where evalue(CRITENT) & evalue(CRITSUI)
&              Order By Key CLE=[F:AUL]SEQ Desc;[F:AUL]COL Desc
 NOL = MAXLIG+1
 For [LAUL]CLE(DET)
  If NOL<=1
   RETOUR = 2 : Break
  Else
   If CHGPAG=-2 : SUITE = 2 : Endif
   NOL -= 1
   Gosub CHARGE
  Endif
 Next
 [M:CAU2]NBLIG = MAXLIG
Endif
NOL -= 1
Return

$CHARGE
If NBLU=1
 NBLU = 2
 If CHGPAG=2 or CHGPAG=-2 : Raz [M:CAU2] : Endif
Endif
nolign = NOL
If DET<>2
 Raz [F:AUL]
Endif
[M:CAU2] = [F:AUL]
[M:CAU2] = [F:AUD]
Gosub SET_COL
Return

$SET_COL
If [F:AUL]COL<>""
 LIB = 0
 FLD = [F:AUL]COL
 K = instr(1,FLD,"(")
 If K
  FLD = left$(FLD,K-1)
 Endif
 TAB = [F:AUD]TBL
 If TAB<>""
  K = find(TAB+"~"+FLD,TBFLD)
  If K
   LIB = TBLIB(K)
  Else
   Read [ATZ]CODZONE=TAB;FLD
   If !fstat
    If [F:ATZ]NOLIB<>0
     LIB = [F:ATZ]NOLIB
    Else
     Read [ATY]CODTYP=[F:ATZ]CODTYP
     If !fstat & [F:ATY]TYPTYP=1 & [F:ATY]NOLIB<>0
      LIB = [F:ATY]NOLIB
     Endif
    Endif
    If LIB & NBTB<dim(TBFLD)
     NBTB += 1
     TBFLD(NBTB) = TAB+"~"+FLD
     TBLIB(NBTB) = [F:ATZ]NOLIB
    Endif
   Endif
  Endif 
 Endif
 If LIB
  Onerrgo RIEN
  O = val([F:AUL]OVAL)
  N = val([F:AUL]NVAL)
  If O>0
   [M:CAU2]OVAL(nolign-1) = mess(O,LIB,1)
  Else
   [M:CAU2]OVAL(nolign-1) = ""
  Endif
  If N>0
   [M:CAU2]NVAL(nolign-1) = mess(N,LIB,1)
  ELSe
   [M:CAU2]NVAL(nolign-1) = ""
  Endif
  Onerrgo
 Endif
Endif
Return

$RIEN
Resume

$SET_ECRAN
If [M:CAUD]ECRAN = "" 
 Call LECTURE("ACN","AUD","") From CONTOBJ
 If !fstat & [ACN]SCRCOD <> ""
  [M:CAUD]ECRAN = [ACN]SCRCOD
 Endif
Endif
Return

$CRITENT
CRITENT = ""
If [M:CAU1]STRDAT<>[0/0/0]
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= "[AUD]DAT>=["+format$(GFMD,[M:CAU1]STRDAT)+"]"
Endif
If [M:CAU1]ENDDAT<>[0/0/0]
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= "[AUD]DAT<=["+format$(GFMD,[M:CAU1]ENDDAT)+"]"
Endif
If [M:CAU1]TABLE<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AUD]TBL="'+[M:CAU1]TABLE+'"'
Endif
If [M:CAU1]CHAMP<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= 'pat([AUL]COL,"'+[M:CAU1]CHAMP+'") = 1'
Endif
If [M:CAU1]USER<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AUD]ADOUSR="'+[M:CAU1]USER+'"'
Endif
If [M:CAU1]LOGIN<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AUD]SYSUSR="'+[M:CAU1]LOGIN+'"'
Endif
If [M:CAU1]EVENEMENT<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AUD]EVT="'+[M:CAU1]EVENEMENT+'"'
Endif
If CRITENT=""
 CRITENT = "1=1"
Endif
Return

$CRITSUI
CRITSUI = ""
Case CHGPAG
 When 2
  If [M:CAU2]NBLIG>0
   SEQUENCE = [M:CAU2]SEQ([M:CAU2]NBLIG-1)
   CHAMP    = [M:CAU2]COL([M:CAU2]NBLIG-1)
   CRITSUI = '([AUL]SEQ>'+num$(SEQUENCE)-'or ([AUL]SEQ='+num$(SEQUENCE)
&             -'and [AUL]COL>"'+CHAMP+'"))'
  Endif
 When -2
  If [M:CAU2]NBLIG>0
   SEQUENCE = [M:CAU2]SEQ(0)
   CHAMP    = [M:CAU2]COL(0)
   CRITSUI = '([AUL]SEQ<'+num$(SEQUENCE)-'or ([AUL]SEQ='+num$(SEQUENCE)
&             -'and [AUL]COL<"'+CHAMP+'"))'
  Endif
Endcase
If CRITSUI=""
 CRITSUI = "1=1"
Endif
Return
  
######################################################################################
$SEL_LISTE
Case LISTE
 When "ASELAUDLOG" : Gosub SELAUDLOG
 When "ASELAUDEVT" : Gosub SELAUDEVT
Endcase
Return

$SELAUDLOG
Local Char TEXTE(GLONDES)(1..200,1..2)
NBTEX = 1 : TEX(NBTEX) = "External" : TEXTE(NBTEX,2) = mess(10,233,1) : # Intervenant externe
Call TITACTION(LISTE,TIT(0)) From CONTOBJ
TIT(1) = mess(6,83,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
FORCE = 1
Return

$SELAUDEVT
Local Char TEXTE(GLONDES)(1..200,1..2)
NBTEX = 1  : TEX(NBTEX) = "INSERT" : TEXTE(NBTEX,2) = mess(59,123,1) : # Création
NBTEX += 1 : TEX(NBTEX) = "UPDATE" : TEXTE(NBTEX,2) = mess(60,123,1) : # Modification
NBTEX += 1 : TEX(NBTEX) = "DELETE" : TEXTE(NBTEX,2) = mess(53,123,1) : # Suppression
Call TITACTION(LISTE,TIT(0)) From CONTOBJ
TIT(1) = mess(6,83,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
Return

######################################################################################
## Ecran CAU1
######################################################################################
Subprog C_CHAMP(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
End

Subprog C_EVENEMENT(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char    ACT(10)
If VALEUR<>""
 mkstat = 2
 For I=6 To 1 Step-1
  For ACT="INSERT","UPDATE","DELETE"
   If left$(VALEUR,I)=left$(ACT,I)
    VALEUR = ACT : mkstat = 0 : Break 2
   Endif
  Next ACT
 Next I
Endif
End

Subprog B1_NBLIG
Local Integer NOL , I , J , K , NBTEX
Local Char    CLE1(GLONID1) , CLE2(GLONID2)(16)
Local Char    CHAINE(250) , CLE(GLONID1)
Local Char    OBJET(GLONAOB) , TEXTE(GLONDES)(0..30)
NOL = nolign-1
Filter [AOB] Where NOMFIC=[M]TBL(NOL)
Case rowcount([F:AOB])
 When 0
  Call MESSAGE(mess(19,137,1)-[M]TBL(NOL)) From GESECRAN : # Objet non trouvé
 When 1
  Read [AOB]NOMFIC(1) = [M]TBL(NOL)
  OBJET = [F:AOB]ABREV
 When Default
  NBTEX = 0
  For [AOB]
   If NBTEX<dim(TEXTE)
    NBTEX += 1
    Call TEXTE([F:AOB]LIBEL,TEXTE(NBTEX)) From OBJDIV
    TEXTE(NBTEX) = [F:AOB]ABREV-TEXTE(NBTEX)
   Endif
  Next AOB
  Call SAITEX(NBTEX,TEXTE,K,mess(4,42,1)) From GESECRAN : # Objets
  If K=0 : End : Endif
  OBJET = TEXTE(K)
Endcase
Filter [AOB]
If [M]ID2(NOL)=""
 CLE1    = [M]ID1(NOL)
Else
 CLE2(0) = [M]ID1(NOL)
 CHAINE  = [M]ID2(NOL)
 K = 0
 While CHAINE<>""
  I = instr(1,CHAINE,"~")
  If I
   CLE    = left$(CHAINE,I-1)
   CHAINE = right$(CHAINE,I+1)
  Else
   CLE    = CHAINE
   CHAINE = ""
  Endif
  If K=0
   CLE1 = CLE
  Else
   CLE2(K) = CLE
  Endif
  K += 1
 Wend
Endif
Call OBJET(OBJET,CLE1,CLE2) From GOBJET
End

Subprog AS_DETAIL(VALEUR)
Variable Integer VALEUR
If [M]CHAMP<>""
 VALEUR = 2
 mkstat = 2 : End
Endif
End

