Subprog SAI_NBRCHEF(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRCHEF
mkstat = 0
zoncou = "NBRCHEF"

## Zone RESPO
mkstat = 0
zoncou = "RESPO"
IMPENT = [M]RESPO(indice)
If varinit([M]RESPO,indice)=0
 IMPENT = nolign
Endif
[M]RESPO(indice) = IMPENT

## Zone CHEF
mkstat = 0
zoncou = "CHEF"
If varmode([M]CHEF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CHEF" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_CHEF([M]CHEF(indice)) From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CHEF" : GZNUM = 10793 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "DROITEMP"
  Call DROIT([M]CHEF(indice),"","",[M:EMP0]REFNUM) From DIVPAYE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CHEF" : GZNUM = 10793 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CHEFNAM
mkstat = 0
zoncou = "CHEFNAM"
SAVACT = GACTION : GACTION = "STD"
Call AV_CHEFNAM([M]CHEFNAM(indice)) From SUBEML2
GACTION = SAVACT
If mkstat=1 : Raz [M]CHEFNAM(indice) : Endif

## Zone NBRCHEF
mkstat = 0
zoncou = "NBRCHEF"

End

