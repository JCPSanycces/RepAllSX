####################################
IMPTBL = 0

## Zone FLGHDC
mkstat = 0
zoncou = "FLGHDC"
indice = 0
IMPENT = [M]FLGHDC
WNUM = IMPENT
If varinit([M]FLGHDC,indice)=0
 IMPENT = 1
 SAVACT = GACTION : GACTION = "STD"
 Call D_FLGHDC(IMPENT) From SUBEML2
 GACTION = SAVACT
Endif
If !mkstat
