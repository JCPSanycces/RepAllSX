  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>IMPENT or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_FLGHDC(IMPENT) From SUBEML2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "FLGHDC" : GZNUM = 48533 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif
[M]FLGHDC = IMPENT

## Zone DISRSN
mkstat = 0
zoncou = "DISRSN"
indice = 0
If varinit([M]DISRSN,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]DISRSN,"11670","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DISRSN,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DISRSN" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]DISRSN,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DISRSN" : GZNUM = 55142 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]DISRSN,"11670","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DISRSN" : GZNUM = 55142 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]DISRSN,"11670",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "DISRSN" : GZNUM = 55142 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone HDCNTE
mkstat = 0
zoncou = "HDCNTE"
indice = 0
If varmode([M]HDCNTE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "HDCNTE" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone HDCTYP
