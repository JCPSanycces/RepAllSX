mkstat = 0
zoncou = "EXPDAT"
If varmode([M]EXPDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXPDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ETRPITTYP
mkstat = 0
zoncou = "ETRPITTYP"
If varmode([M]ETRPITTYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETRPITTYP" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ETRPITDAT
mkstat = 0
zoncou = "ETRPITDAT"
If varmode([M]ETRPITDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETRPITDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ETRPITEXPDAT
mkstat = 0
zoncou = "ETRPITEXPDAT"
If varmode([M]ETRPITEXPDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETRPITEXPDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PASAMD
mkstat = 0
zoncou = "PASAMD"
IMPENT = [M]PASAMD(indice)
If varinit([M]PASAMD,indice)=0
