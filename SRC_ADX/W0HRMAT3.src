Subprog SAI_ITMNBR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone ITMNBR
mkstat = 0
zoncou = "ITMNBR"

## Zone ITMTYP
mkstat = 0
zoncou = "ITMTYP"
If varinit([M]ITMTYP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]ITMTYP(indice),"11732","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]ITMTYP,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ITMTYP" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]ITMTYP(indice),"11732","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ITMTYP" : GZNUM = 22928 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]ITMTYP(indice),"11732",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "ITMTYP" : GZNUM = 22928 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone ITMMDLNUM
mkstat = 0
zoncou = "ITMMDLNUM"
If varmode([M]ITMMDLNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ITMMDLNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DATISS
mkstat = 0
zoncou = "DATISS"
SAVACT = GACTION : GACTION = "STD"
Call AV_DATISS([M]DATISS(indice)) From SUBEML2
GACTION = SAVACT
If mkstat=1 : Raz [M]DATISS(indice) : Endif
If !mkstat
 If varmode([M]DATISS,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DATISS" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone DATRTR
mkstat = 0
zoncou = "DATRTR"
SAVACT = GACTION : GACTION = "STD"
Call AV_DATRTR([M]DATRTR(indice)) From SUBEML2
GACTION = SAVACT
If mkstat=1 : Raz [M]DATRTR(indice) : Endif
If !mkstat
 If varmode([M]DATRTR,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DATRTR" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone ITMNBR
mkstat = 0
zoncou = "ITMNBR"

End

