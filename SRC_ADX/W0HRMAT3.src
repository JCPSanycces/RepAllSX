# Superviseur
# Gestion du masque HRMAT3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone PFLTEL
mkstat = 0
zoncou = "PFLTEL"
indice = 0
WCHAR = [M]PFLTEL
SAVACT = GACTION : GACTION = "FMTTELPAY"
Call FMTTELPAY([M:EMP1]CRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]PFLTEL : Endif
If !mkstat
 If varmode([M]PFLTEL,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PFLTEL" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "ACNTTEL"
  Call CONTTEL([M]PFLTEL,[M:EMP1]CRY) From CONTNUM
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PFLTEL" : GZNUM = 289 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]PFLTEL or IMPMOD
    SAVACT = GACTION : GACTION = "ACNTTELMOD"
    Call CONTTELMOD([M]PFLTEL,[M:EMP1]CRY) From CONTNUM
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PFLTEL" : GZNUM = 289 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone PFLMOB
mkstat = 0
zoncou = "PFLMOB"
indice = 0
