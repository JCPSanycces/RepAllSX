 Endif
Endif

## Zone BORWRK
mkstat = 0
zoncou = "BORWRK"
indice = 0
IMPENT = [M]BORWRK
WNUM = IMPENT
If varinit([M]BORWRK,indice)=0
 IMPENT = 1
Endif
If varmode([M]BORWRK,indice)=0
 [M]BORWRK(indice) = IMPENT
