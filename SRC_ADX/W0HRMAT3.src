 If !mkstat
  IMPMOD = 0 : IMPZON = "SRCRET" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  Call CONTROLE("GRI","!",[M]SRCRET,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "SRCRET" : GZNUM = 14077 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone EXOATTNUM
mkstat = 0
zoncou = "EXOATTNUM"
indice = 0
If varmode([M]EXOATTNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXOATTNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc tableau 4
####################################
IMPTBL = 1

## Zone NBHDC
mkstat = 0
zoncou = "NBHDC"
indice = 0
status = 1
zoncou = "NBHDC"
If varmode([M]NBHDC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBHDC" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBHDC
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBHDC = nolign
   status = 75
   Call SAI_NBHDC(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBHDC From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBHDC" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc tableau 5
####################################
IMPTBL = 1

## Zone NBRPAS
mkstat = 0
zoncou = "NBRPAS"
indice = 0
status = 1
zoncou = "NBRPAS"
