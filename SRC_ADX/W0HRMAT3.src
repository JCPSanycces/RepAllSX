 If !mkstat
  IMPMOD = 0 : IMPZON = "STYCRD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DATSTY
mkstat = 0
zoncou = "DATSTY"
indice = 0
WDATE = [M]DATSTY
If varmode([M]DATSTY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATSTY" : Gosub ACTION From =IMPTRT
 Endif
 If WDATE<>[M]DATSTY or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_DATSTY([M]DATSTY) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DATSTY" : GZNUM = 5463 : Endif
