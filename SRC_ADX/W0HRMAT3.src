####################################
## Bloc tableau 4
####################################
Subprog SAI_NBHDC(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBHDC
mkstat = 0
zoncou = "NBHDC"
SAVACT = GACTION : GACTION = "STD"
Call C_NBHDC From SUBEML2
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "NBHDC" : GZNUM = 0 : Endif
Gosub AFF From GSAISIE
If mkstat : End : Endif

## Zone CATHDC
mkstat = 0
zoncou = "CATHDC"
IMPENT = [M]CATHDC(indice)
If varinit([M]CATHDC,indice)=0
 IMPENT = 1
Endif
[M]CATHDC(indice) = IMPENT

## Zone HDC
mkstat = 0
zoncou = "HDC"
WNUM = [M]HDC(indice)
If varmode([M]HDC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "HDC" : Gosub ACTION From =IMPTRT
 Endif
 If [M]HDC(indice)<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "HDC" : GZNUM = 48540 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_HDC([M]HDC(indice)) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "HDC" : GZNUM = 48540 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>[M]HDC(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_HDC([M]HDC(indice)) From SUBEML2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "HDC" : GZNUM = 48540 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone DATSTRHDC
mkstat = 0
zoncou = "DATSTRHDC"
WDATE = [M]DATSTRHDC(indice)
If varmode([M]DATSTRHDC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATSTRHDC" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_DATSTRHDC([M]DATSTRHDC(indice)) From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "DATSTRHDC" : GZNUM = 1805 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WDATE<>[M]DATSTRHDC(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_DATSTRHDC([M]DATSTRHDC(indice)) From SUBEML2
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DATSTRHDC" : GZNUM = 1805 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone DATENDHDC
mkstat = 0
zoncou = "DATENDHDC"
WDATE = [M]DATENDHDC(indice)
If varmode([M]DATENDHDC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATENDHDC" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_DATENDHDC([M]DATENDHDC(indice)) From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "DATENDHDC" : GZNUM = 1806 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WDATE<>[M]DATENDHDC(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_DATENDHDC([M]DATENDHDC(indice)) From SUBEML2
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DATENDHDC" : GZNUM = 1806 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBHDC
mkstat = 0
zoncou = "NBHDC"
status = 71
SAVACT = GACTION : GACTION = "STD"
Call APRES_NBHDC From SUBEML2
GACTION = SAVACT

End

