  Call AM_BORWRK(IMPENT) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "BORWRK" : GZNUM = 55329 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
