 If !mkstat
  IMPMOD = 0 : IMPZON = "WRKCRD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DATWRK
mkstat = 0
zoncou = "DATWRK"
indice = 0
WDATE = [M]DATWRK
If varmode([M]DATWRK,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATWRK" : Gosub ACTION From =IMPTRT
 Endif
 If WDATE<>[M]DATWRK or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_DATWRK([M]DATWRK) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DATWRK" : GZNUM = 5463 : Endif
  Gosub AFF From GSAISIE
