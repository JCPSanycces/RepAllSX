  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PFLMOB" : GZNUM = 9564 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]PFLMOB or IMPMOD
    SAVACT = GACTION : GACTION = "ACNTTELMOD"
    Call CONTTELMOD([M]PFLMOB,[M:EMP1]CRY) From CONTNUM
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PFLMOB" : GZNUM = 9564 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

