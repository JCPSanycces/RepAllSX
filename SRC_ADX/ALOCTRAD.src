##########################################################################
##########################################################################

##########################################################################
# LISTE DES FONCTIONS UTILES                                             #
##########################################################################
# IS_TRADUISIBLE : Un message est il traductible ?                       #
##########################################################################
##########################################################################
# ATTENTION : Funprog IS_TRADUISIBLE utilisé par 2 Traitements :
#           - ALOCTRAD   : Fonction de Traduction des Menus Locaux
#           - ASELOCTRAD : Action de Sélection des Menu à Traduire
##########################################################################
Funprog IS_TRADUISIBLE(W_LANMES, W_LANREFMES, W_LANORI, W_NONTRA)
Value    Char  W_LANMES(), W_LANREFMES(), W_LANORI()
Value Integer  W_NONTRA

  Local Integer RET_CODE

  [L]RET_CODE=0
  # Un message est à Traduire si :
  #   - Le texte de la LAN est = au texte de la LANREF
  #   - La langue Origine est renseignée pour le texte de la LAN
  #   - Le flag de NON traduction du Message n'est pas positionné
  # Ou
  #   - Le texte de la LAN est vide et celui de la LANREF est non vide
  #   - Le flag de NON traduction du Message n'est pas positionné --> cg faux
#  If (W_LANMES=W_LANREFMES & W_LANORI<>"" & W_NONTRA<>2) or (W_LANMES="" & W_LANREFMES<>"" & W_NONTRA<>2)
# If (W_LANMES=W_LANREFMES & W_LANORI<>"" & W_NONTRA<>2) or (W_LANMES="" & W_LANREFMES<>"")
  If (W_LANORI<>"" & W_NONTRA<>2) or (W_LANMES="" & W_LANREFMES<>"")
    [L]RET_CODE=1
  Endif
End [L]RET_CODE
##########################################################################

