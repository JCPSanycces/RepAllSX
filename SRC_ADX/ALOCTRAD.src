######################################################################################
## Etiquette ajoutée par le superviseur (écran ALOCTRAD) 07/07/2009 17:30:10 (CG)
######################################################################################
Subprog AS_ICO(VALEUR)
Variable Char    VALEUR()

If [M]LANCHP =0
    mkstat = 2
Endif

End

######################################################################################

##########################################################################
# LISTE DES ETIQUETTES UTILES                                            #
##########################################################################
# AFF_CRITERES           : Gestion Ecran : Affichage du module et de l'opérateur
# RECHARGEMENT_MASQUE    : Gestion Ecran : Rechargement complet du tableau du masque
# CHARGE_FILTRES         : Chargement du Filtre de critères de sélection
# INITIALISATION_FILTRES : Initialisation des critères de sélection du masque
# TRAITE_MENUS_0   : Selection en Liste : Boucle sur les EN-TETE des Menus locaux du Chapitre 0
# TRAITE_MENUS_200 : Selection en Liste : Boucle sur les EN-TETE des Menus locaux du Chapitre 200
# TRAITE_MESSAGES  : Selection en Liste : Boucle sur les EN-TETE des Messages
# CHARGE_MENUSLOCAUX   : Selection en Liste : Chargement de toutes les lignes de Chapitre
# CHARGE_TITRECOLONNES : Selection en Liste : Chargement du Titre des colonnes
# CHARGE_COLONNES  : Selection en Liste : Chargement d'une ligne de sélection
# CHARGE_SPE       : Chargement de la liste des plages réservées en tableau
##########################################################################
$AFF_CRITERES
  If dim([L]OPECRE)<=0 : Local Char       OPECRE(GLONAUS) : Endif

  # Affichage du Module du Menu local (Au niveau AMENLOC)
  [M:ALT]CHPMOD=[F:AML1]MODULE

  # Affichage de l'opérateur Modificateur de l'intitulé du chapitre de Menu local (Au niveau APLSTD)
  [L]OPECRE=string$([F:AST1]UPDUSR<>"",[F:AST1]UPDUSR)+string$([F:AST1]UPDUSR="",[F:AST1]CREUSR)
  [M:ALT]CHPUSR=[L]OPECRE

  Affzo [M:ALT]CHPMOD, CHPUSR
Return

$RECHARGEMENT_MASQUE
  Raz   [M:ALT]BASPAG
  Effzo [M:ALT]20

  # Chargement des zones du masque à partir des zones saisies : LAN, LANREF, LANCHP
  Call CHARGE_MESSAGES_PAR_CHP([M:ALT]LANCHP)
Return

$CHARGE_MENUSLOCAUX
  # Mise en place des Filtres pour : MODULE et OPERATEUR
  Gosub CHARGE_FILTRES

  If [L]PARAM_LAN = GFRA
    [L]FILTRE_PLAGE=' 1=2 '
    # on charge ici le tableau
    Gosub CHARGE_SPE From ALOCTRAD
    # on boucle sur toutes les tranches autre que std
    If WNBR_PLG <> 0
      I=1  :  WIND_PLG=0
      While I = 1
        WIND_PLG+=1
        If WIND_PLG > WNBR_PLG
          I=2
        Else
          [L]FILTRE_PLAGE=' LANNUM>='      +num$(WDEB_PLG(WIND_PLG))+" & "+ ' LANNUM<='      +num$(WFIN_PLG(WIND_PLG))+' '
          Gosub TRAITE_MENUS_0
          [L]FILTRE_PLAGE=' (LANNUM+200)>='+num$(WDEB_PLG(WIND_PLG))+" & "+ ' (LANNUM+200)<='+num$(WFIN_PLG(WIND_PLG))+' '
          Gosub TRAITE_MENUS_200
          [L]FILTRE_PLAGE=' LANCHP>='      +num$(WDEB_PLG(WIND_PLG))+" & "+ ' LANCHP<='      +num$(WFIN_PLG(WIND_PLG))+' '
          Gosub TRAITE_MESSAGES
        Endif
      Wend
    Endif
  Else
    # Si la Langue de TRAD n'est pas le FRA
    [L]FILTRE_PLAGE=' 1=1 '
    Gosub TRAITE_MENUS_0
    Gosub TRAITE_MENUS_200
    Gosub TRAITE_MESSAGES
  Endif
Return

$CHARGE_FILTRES
  If dim([L]FILTRE_CRITERES)<=0
    Local Char FILTRE_CRITERES(250)
  Endif

  # Chargement du Filtre des critères
  Raz [L]FILTRE_CRITERES
  Gosub INITIALISATION_FILTRES
  [L]FILTRE_CRITERES+=string$([L]FILTRE_CRITERES=""," 1=1 ")
Return

$INITIALISATION_FILTRES
Return

$TRAITE_MENUS_0
    ### ----------------------------------------###
    ### on charge les Menus locaux : Chapitre 0 ###
    ### ----------------------------------------###
    Filter [AST1] Where LAN=[L]PARAM_LANREF and LANCHP=0   and LANNUM>0 and evalue([L]FILTRE_PLAGE)
    Link   [AST1] With  [AML1]MENLOC=[AST1]LANNUM           As [ASTZ] Where [AML1]MENLOCAL=2 and evalue([L]FILTRE_CRITERES)
    For [ASTZ]
      [L]CHAPITRE_ENTETE = [F:ASTZ]LANNUM
      Gosub CHARGE_COLONNES          # Traitement de l'intitulé du Menu local/Message : EN-TETE
    Next ASTZ
    Filter [F:AST1]
Return

$TRAITE_MENUS_200
    ### ------------------------------------------###
    ### on charge les Menus locaux : Chapitre 200 ###
    ### ------------------------------------------###
    Filter [AST1] Where LAN=[L]PARAM_LANREF and LANCHP=200 and evalue([L]FILTRE_PLAGE)
    Link   [AST1] With  [AML1]MENLOC=[AST1]LANNUM+200       As [ASTZ] Where [AML1]MENLOCAL=2 and evalue([L]FILTRE_CRITERES)
    For [ASTZ]
      [L]CHAPITRE_ENTETE = [F:ASTZ]LANNUM+200
      Gosub CHARGE_COLONNES          # Traitement de l'intitulé du Menu local/Message : EN-TETE
    Next ASTZ
    Filter [F:AST1]
Return

$TRAITE_MESSAGES
    ### -----------------------------------------------###
    ### on charge les Messages : Chapitre 8900 à 30000 ###
    ### -----------------------------------------------###
    Filter [AST1] Where LAN=[L]PARAM_LANREF and LANNUM=0   and evalue([L]FILTRE_PLAGE)
    Link   [AST1] With  [AML1]MENLOC=[AST1]LANCHP           As [ASTZ] Where [AML1]MENLOCAL<>2 and evalue([L]FILTRE_CRITERES)
    For [ASTZ]
      [L]CHAPITRE_ENTETE = [F:ASTZ]LANCHP
      Gosub CHARGE_COLONNES          # Traitement de l'intitulé du Menu local/Message : EN-TETE
    Next ASTZ
    Filter [F:AST1]
Return

##########################################################################
# ETIQUETTES de chargement de la Fenêtre Sélection : Titres des colonnes et Contenus et Valeurs Résultat
##########################################################################
$CHARGE_TITRECOLONNES
  # Initialisation du Titre de la Fenêtre de sélection ainsi que du nom des Colonnes
  For I = 0 To [L]NB_TEXTE
    Case I
      When 0 : TIT(I) = mess(30,123,1)                # Titre de la liste : Choix message
      When 1 : TIT(I) = mess(80,123,1)                # Titre de la colonne 1 : Chapitre          : 1
      When 2 : TIT(I) = mess(82,123,1)-mess(80,123,1) # Titre de la colonne 2 : Intitulé Chapitre : Oui/Non
      When 3 : TIT(I) = mess(10,144,1)                # Titre de la colonne 3 : Module            : 0
      When 4 : TIT(I) = mess(1,30,1)                  # Titre de la colonne 4 : Menu local        : Oui/Non
      When Default : Raz TIT(I)
    Endcase
  Next I
Return

$CHARGE_COLONNES
  NBTEX += 1

  # Valeur du Champs de SORTIE : n° de Chapitre
  TEX(NBTEX) = format$("N:5#[ ]",[L]CHAPITRE_ENTETE)

  # Listes des valeurs des colonnes de la fenêtre de sélection
  #TEXTE(NBTEX,1) = num$([L]CHAPITRE_ENTETE)
  TEXTE(NBTEX,1) = format$("N0:5",[L]CHAPITRE_ENTETE)
  TEXTE(NBTEX,2) =  [F:AST1]LANMES
  Read [AST2]CLE=14;[F:AML1]MODULE;[V]GLANGUE
  If fstat : Raz TEXTE(NBTEX,3) : Else : TEXTE(NBTEX,3) = [AST2]LANMES : Endif
  Read [AST2]CLE=1;[F:AML1]MENLOCAL;[V]GLANGUE
  If fstat : Raz TEXTE(NBTEX,4) : Else : TEXTE(NBTEX,4) = [AST2]LANMES : Endif
Return
##########################################################################

##########################################################################
# ATTENTION : Etiquette CHARGE_SPE utilisée par 2 Traitements :
#           - ALOCTRAD   : Fonction de Traduction des Menus Locaux
#           - ASELOCTRAD : Action de Sélection des Menu à Traduire
##########################################################################
$CHARGE_SPE
  # chargement des tranches non std.. pour filtre sur code langue a traduire lorsque gfra
  Raz WDEB_PLG
  Raz WFIN_PLG
  WNBR_PLG = 0

  Filter [ACD] Where DEV <> 1 and (PRO = 1 or PRO= 2 or PRO=GPRODUIT+3)
  For [ACD]
      For I=1 To [F:ACD]NBLIG
          If [F:ACD]TYP(I-1)=2
               K = instr(1,[F:ACD]RAN(I-1),"-")
               If K
                    If WNBR_PLG < 100
                        WNBR_PLG +=1
                        WDEB_PLG(WNBR_PLG) = val(left$([F:ACD]RAN(I-1),K-1))
                        WFIN_PLG(WNBR_PLG) = val(right$([F:ACD]RAN(I-1),K+1))
                    Endif
               Endif
          Endif
     Next I
  Next ACB
  Filter [ACD]

  # ici il faut trier le tableau
  Sorta WNBR_PLG  WDEB_PLG,WFIN_PLG
Return

######################################################################################
$SYNCCHAPITRE_SCREEN

Local Integer LASTATUS
Local Char    ERRMSG(250)
Local Integer WCONTINUE

  # We suppose VALEUR comes from AM_LANCHP and contain value of [M]LANCHP field
  # 2017-06-01 TEXT SERVER : Synchronisation of One Chapter for LANREF.
  Call TEMPON("Synchronisation"-[M:ALT]LANREF) From GESECRAN
  [L]WCONTINUE = 0
  LASTATUS= func APLSTD.SYNCCHAPITRE (PNUMCHP, [M:ALT]LANREF, [L]WCONTINUE, ERRMSG)
  Call TEMPOFF From GESECRAN
  If LASTATUS<>CST_AOK
    Call ERREUR (ERRMSG) From GESECRAN
  Endif

  # 2017-06-01 TEXT SERVER : Synchronisation of One Chapter for LAN.
  Call TEMPON("Synchronisation"-[M:ALT]LAN) From GESECRAN
  [L]WCONTINUE = 1   # Head message or message may not be translated yet ... We must synchronize.
  LASTATUS= func APLSTD.SYNCCHAPITRE (PNUMCHP, [M:ALT]LAN, [L]WCONTINUE, ERRMSG)
  Call TEMPOFF From GESECRAN
  If LASTATUS<>CST_AOK
    Call ERREUR (ERRMSG) From GESECRAN
  Endif
Return
##########################################################################


##########################################################################
# LISTE DES SOUS-PROGRAMMES UTILES                                       #
##########################################################################
