#<AdxTL>@(#)0.0.0.0 $Revision$ Traduction menus locaux
##########################################################################################################
#      Indus team (INDUS)
##########################################################################################################
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"ALOCTRAD","ALOCTRAD","",3,"") From GTRAITE
End

#########################################################################################################
#               Menus locaux a TRADUIRE
# fonction webisée (cg)
# modifs pour mettre a jour environnement indus (cg) abelx3 superv et x3
#########################################################################################################
$ACTION

#--- Actions liées au traitement standard

Case ACTION
 When "EXEC" : Gosub EXEC
Endcase

#--- Actions liées à la fenêtre de saisie

Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "BOUTON"     : Gosub EXEBOUT
 When "SETBOUT"    : Gosub SETBOUT
 When "DEBUT"      : Gosub DEBUT
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "SUI"        : Gosub SUIVANT
 When "PRE"        : Gosub PRECEDENT
 When "FIR"        : Gosub PREMIER
 When "LAS"        : Gosub DERNIER
 When "APRES_MODIF": Gosub APRES_MODIF
 When "ENR"        : Gosub MODIF
 When "ABA"        : Gosub ABANDON
 When "END"        : Gosub ABORT
 When "FIN"        : Gosub FIN
Endcase
Return

############################################################
$EXEC
TRA = 1
Return

############################################################
$OUVRE
Local Decimal WCCHR, WCSEQ
Local Integer I, J, K, NB
Local Integer ISEL, WLEC
Local Char    WMSG(100), WABR(255)

Local Integer WDEB_PLG (1..100), WFIN_PLG (1..100), WNBR_PLG, WIND_PLG
Local Char    WANC_TRAD(250)

# 2017-06-01 TEXT SERVER : Variables necessary to call Text server API.
Local Integer LSTATUS
Local Char    LERRMSG (250)

Gosub DEFVAR From ATRANSLATION

If clalev([F:AST])  = 0 Local File APLSTD [AST]  : Endif
If clalev([F:AST1]) = 0 Local File APLSTD [AST1] : Endif
If clalev([F:AST2]) = 0 Local File APLSTD [AST2] : Endif
If clalev([F:AST3]) = 0 Local File APLSTD [AST3] : Endif
If clalev([F:AST4]) = 0 Local File APLSTD [AST4] : Endif
If clalev([F:AST5]) = 0 Local File APLSTD [AST5] : Endif
If clalev([F:AST6]) = 0 Local File APLSTD [AST6] : Endif

If clalev([F:AML])  = 0 Local File AMENLOC [AML]  : Endif
If clalev([F:AML1]) = 0 Local File AMENLOC [AML1] : Endif
If clalev([F:ACD])  = 0 Local File ACTLDEV [ACD] : Endif

#-----------------------------
# prog spe a chaque produit opdadx sur indusprd.....
# test si ca marche ou pas la remontée ..
#-----------------------------
Local Integer WOK
WOK = 0

Call EXISTE_ADX ("","","ATRANSLATIONB",WOK) From ORDSYS
If WOK = 1
   WOK =0
   WNBRFOLDER= 0
   Call OUVRE_FIC (GFOLDER_INDUS,GFOLDER_VERSION,GFOLDER_PRODUIT,WNBRFOLDER,WOK) From ATRANSLATIONB
Endif
Gosub CHARGE_SPE
Call OUVRE_TRACE("") From LECFIC
Return


############################################################
$EXEBOUT
Local Char WAPPLI(30)
Case BOUT
 When "I" :
  # affichage du nombre d'enreg dans toutes les langues du dossier
  Call AFF_NBELEMENTS
Endcase
Return
############################################################

$SETBOUT
#-- Pas de recherche texte si modif
If REP = "M"
      Call VIREBOUT(CHMEN,"RI") From GOBJET
Endif
Return


############################################################
$SEL_LISTE
Case LISTE
 When "ASELOCTRA" : Gosub SEL_ASELOCTRA
Endcase
Return

##########################################################################
# ACTIONS DU MODELE : SELECTION DANS LISTE                               #
##########################################################################
$SEL_ASELOCTRA
  Local Integer NB_TEXTE : [L]NB_TEXTE=4  # ATTENTION : Saisir ici le nombre de colonnes à afficher dans la fenêtre de Sélection
  Local Char    TEX(10)(0..9999), TEXTE(100)(1..9999,1..[L]NB_TEXTE)
  Local Integer NBTEX , NUM, CHAPITRE_ENTETE
  Local Integer WDEB_PLG (1..100), WFIN_PLG (1..100), WNBR_PLG, WIND_PLG
  Local Char    FILTRE_PLAGE(250), PARAM_LAN(GLONLAN), PARAM_LANREF(GLONLAN)

  [L]PARAM_LAN   =[M]LAN
  [L]PARAM_LANREF=[M]LANREF
  NBTEX = 0

  # Boucle de remplissage de la fenêtre de sélection
  Gosub CHARGE_MENUSLOCAUX

  # Boucle de remplissage du Titre des colonnes de la fenêtre de sélection
  Gosub CHARGE_TITRECOLONNES

  #Sorta NBTEX TEX,TEXTE
  mkstat = 2
Return
##########################################################################

############################################################
$APRES_MODIF
### Ig le 26/06 : En attendant de régler le problème de la touche 'TAB'
If COUZON="CODE" or COUZON="LANMES"
 REP = "M"
### VPO 10/04/07 on passe en modif si saisie du titre
Elsif COUZON="LANCHPTRAD"
 REP = "M"
Endif
Return

############################################################
$MODIF
K = 0
NB = 0
For I=[M]BASPAG To 2 Step -2
 If [M]LANMES(I-1)<>""
  NB = I : Break
 Endif
Next I

# on en profite pour forcer le record 0 si necessaire
# au cas ou ?
If NB>0
 For I= 0 To [M]BASPAG-2 Step 2
  If  [M]CODE(I)<>""
      If [M]CODE(I+1)=""  or [M]CODE (I+1) = " "
        [M]CODE(I+1)=[M]CODE(I)
      Endif
  Endif
 Next I
Endif

If NB>0
 For I= 2 To NB Step 2
  If [M]LANMES(I-1)="" & [M]LANMES(I-2)<>""
   K = I : Break
  Endif
 Next I
Endif

# demande 56200
# enlever ce controle car c'est tres lourd
# si on a beaucoup de ligne a traduire
If K
 # Traduction incomplète\Ligne # non saisie
 #Call ERREUR(mess(231,139,1)+"\"+func AFNC.MES(mess(232,139,1),num$(K))) From GESECRAN
 #FIN = 0 : Return
Endif
Gosub LOC_MAJ
REP= ""
Return

############################################################
$ABANDON
REP = ""
Gosub RECHARGEMENT_MASQUE
Return

############################################################
$ABORT
REP = ""
Return

############################################################
$DEBUT
Raz [M:ALT]
# Langue de traduction (dans laquelle on va enregistrer les textes)
[M:ALT]LAN    = GLANTRAD
# Langue de référence la langue de connexion
[M:ALT]LANREF = GLANREF
Return

############################################################
$FIN
Close Local File [AST1]
Close Local File [AST2]
Close Local File [AST3]
Close Local File [AST4]
Close Local File [AST5]
Close Local File [AST6]

Call FERME_TRACE From LECFIC
Call IMPSCR From ATRTX3
Return

############################################################
$COP_ECRAN
Call PRTSCR("ALOCTRAD","","",0,0) From ATRTX3
Return

###########################################################
$PREMIER
If [M:ALT]LANREF = "" : Return : Endif
# Mise en place des Filtres pour : MODULE et OPERATEUR
Gosub CHARGE_FILTRES

If [M]LAN = GFRA
    If WNBR_PLG <> 0
        I = 1
        WIND_PLG = 0
        While I = 1
            WIND_PLG +=1
            If WIND_PLG > WNBR_PLG
                   Raz [F:AST1]
                   I = 2
            Else
                Filter [AST1] Where LANCHP <> 0 & LANCHP <>200 & LANCHP >= WDEB_PLG (WIND_PLG) & LANCHP <= WFIN_PLG (WIND_PLG) & LAN = [M:ALT]LANREF
                Link   [AST1] With  [AML1]MENLOC=[AST1]LANCHP As [ASTZ] Where evalue([L]FILTRE_CRITERES)
                Read [ASTZ]CLE(1) First
                If fstat = 0
                    I = 0
                Else
                    Raz [F:AST1]
                Endif
                Filter [AST1]
            Endif
        Wend
        # ici soit on a trouvé le premier et alors i  = 0
        # soit pas du tout et alors i = 2
        If I = 2
            #Infbox "Rien trouvé"
            Raz [F:AST1]
        Endif
    Else
        #Infbox "Rien trouvé"
        Raz [F:AST1]
    Endif
Else
    Filter [AST1] Where LANCHP <> 0 & LANCHP <>200 & LANCHP < 30000 & LAN = [M:ALT]LANREF
    Link   [AST1] With  [AML1]MENLOC=[AST1]LANCHP As [ASTZ] Where evalue([L]FILTRE_CRITERES)
    Read [ASTZ]CLE(1) First
    Filter [AST1]
    If fstat
      Raz [F:AST1]
    Endif
Endif

[M:ALT]LANCHP = [F:AST1]LANCHP
[M:ALT]LANCHPREF= [F:AST1]LANMES
Affzo [M:ALT]LANCHP
Affzo [M:ALT]LANCHPREF
Gosub AFF_CRITERES

# X3-9046 : resync from text server before loading
If [F:AST1]LANCHP<>0
    Call RESYNC([M:ALT]LANCHP, [M:ALT]LANREF, [M:ALT]LAN)
Endif

Call AFF_TAB([M:ALT]LANCHP)
Return

############################################################
$DERNIER
If [M:ALT]LANREF = "" : Return : Endif
# Mise en place des Filtres pour : MODULE et OPERATEUR
Gosub CHARGE_FILTRES

If [M]LAN = GFRA
    If WNBR_PLG <> 0
        I = 1
        WIND_PLG = WNBR_PLG
        While I = 1
            WIND_PLG -=1
            If WIND_PLG = 0
                   Raz [F:AST1]
                   I = 2
            Else
                Filter [AST1] Where LANCHP <> 0 & LANCHP <>200 & LANCHP >= WDEB_PLG (WIND_PLG) & LANCHP <= WFIN_PLG (WIND_PLG) & LAN = [M:ALT]LANREF
                Link   [AST1] With  [AML1]MENLOC=[AST1]LANCHP As [ASTZ] Where evalue([L]FILTRE_CRITERES)
                Read [ASTZ]CLE(1) Last
                If fstat = 0
                    I = 0
                Else
                    Raz [F:AST1]
                Endif
                Filter [AST1]
            Endif
        Wend
        # ici soit on a trouvé le premier et alors i  = 0
        # soit pas du tout et alors i = 2
        If I = 2
            #Infbox "Rien trouvé"
            Raz [F:AST1]
        Endif
    Else
        #Infbox "Rien trouvé"
        Raz [F:AST1]
    Endif
Else
    Filter [AST1] Where LANCHP <> 0 & LANCHP <>200 & LANCHP < 30000  & LAN = [M:ALT]LANREF
    Link   [AST1] With  [AML1]MENLOC=[AST1]LANCHP As [ASTZ] Where evalue([L]FILTRE_CRITERES)
    Read [ASTZ]CLE(1) Last
    Filter [AST1]
    If fstat
        Raz [F:AST1]
    Endif
Endif

[M:ALT]LANCHP = [F:AST1]LANCHP
[M:ALT]LANCHPREF= [F:AST1]LANMES
Affzo [M:ALT]LANCHP
Affzo [M:ALT]LANCHPREF
Gosub AFF_CRITERES

# X3-9046 : resync from text server before loading
If [F:AST1]LANCHP<>0
    Call RESYNC([M:ALT]LANCHP, [M:ALT]LANREF, [M:ALT]LAN)
Endif

Call AFF_TAB([M:ALT]LANCHP)
Return

############################################################
$SUIVANT
If [M:ALT]LANREF = "" : Return : Endif
# Mise en place des Filtres pour : MODULE et OPERATEUR
Gosub CHARGE_FILTRES

If [M]LAN = GFRA
    If WNBR_PLG <> 0
        # tranche interdite aussi 200 et 0
        Filter [AST1] Where LANCHP > [M:ALT]LANCHP and LAN = [M:ALT]LANREF and LANNUM = 0 and LANCHP <> 0 and LANCHP <> 200
        Link   [AST1] With  [AML1]MENLOC=[AST1]LANCHP As [ASTZ] Where evalue([L]FILTRE_CRITERES)
        Read [ASTZ] First
        If fstat = 0
            # il faut vérifier que appartient aux tranches non std.
            GMESSAGE =""
            Call TRAD_ACTLDEV (num$([F:AST1]LANCHP),2,1,0) From ALOCTRAD : # Contrôle plages messages std
            Repeat
               # il faut prendre le suivant
               Read [ASTZ] Next
               If fstat <> 0
                    Raz [F:AST1]
                    GMESSAGE = ""
               Else
                    GMESSAGE = ""
                    Call TRAD_ACTLDEV (num$([F:AST1]LANCHP),2,1,0) From ALOCTRAD : # Contrôle plages messages std
                    # si renvoie un message c'est que le chapitre est dnas la tranche std
               Endif
            Until GMESSAGE = ""
        Else
            #Infbox "Rien trouvé on est à la fin"
            Raz [F:AST1]
        Endif
        Filter [AST1]
    Else
        #Infbox "Rien trouvé"
        Raz [F:AST1]
    Endif
Else
    Filter [AST1] Where LANCHP > [M:ALT]LANCHP and LAN = [M:ALT]LANREF and LANNUM = 0 & LANCHP < 30000 and LANCHP<>200 and LANCHP<>0
    Link   [AST1] With  [AML1]MENLOC=[AST1]LANCHP As [ASTZ] Where evalue([L]FILTRE_CRITERES)
    Read [ASTZ] First
    If fstat
        Raz [F:AST1]
    Endif
    Filter [AST1]
Endif

[M:ALT]LANCHP = [F:AST1]LANCHP
Affzo [M:ALT]LANCHP
Gosub AFF_CRITERES

# X3-9046 : resync from text server before loading
If [F:AST1]LANCHP<>0
    Call RESYNC([M:ALT]LANCHP, [M:ALT]LANREF, [M:ALT]LAN)
Endif

Call AFF_TAB([M:ALT]LANCHP)
Return

############################################################
$PRECEDENT
If [M:ALT]LANREF = "" : Return : Endif
# Mise en place des Filtres pour : MODULE et OPERATEUR
Gosub CHARGE_FILTRES

If [M]LAN = GFRA
    If WNBR_PLG <> 0
        # tranche interdite aussi 200 et 0
        Filter [AST1] Where LANCHP < [M:ALT]LANCHP and LAN = [M:ALT]LANREF and LANNUM = 0 and LANCHP <> 0 and LANCHP <> 200
        Link   [AST1] With  [AML1]MENLOC=[AST1]LANCHP As [ASTZ] Where evalue([L]FILTRE_CRITERES)
        Read [ASTZ] Last
        If fstat = 0
            # il faut vérifier que appartient aux tranches non std.
            GMESSAGE =""
            Call TRAD_ACTLDEV (num$([F:AST1]LANCHP),2,1,0) From ALOCTRAD : # Contrôle plages messages std
            Repeat
               # il faut prendre le suivant
               Read [ASTZ] Prev
               If fstat <> 0
                    Raz [F:AST1]
                    GMESSAGE = ""
               Else
                    GMESSAGE = ""
                    Call TRAD_ACTLDEV (num$([F:AST1]LANCHP),2,1,0) From ALOCTRAD : # Contrôle plages messages std
                    # si renvoie un message c'est que le chapitre est dnas la tranche std
               Endif
            Until GMESSAGE = ""
        Else
            #Infbox "Rien trouvé on est à la fin"
            Raz [F:AST1]
        Endif
        Filter [AST1]
    Else
        #Infbox "Rien trouvé"
        Raz [F:AST1]
    Endif
Else
    Filter [AST1] Where LANCHP < [M:ALT]LANCHP and LAN = [M:ALT]LANREF and LANNUM = 0 & LANCHP < 30000
    Link   [AST1] With  [AML1]MENLOC=[AST1]LANCHP As [ASTZ] Where evalue([L]FILTRE_CRITERES)
    Read [ASTZ] Last
    If fstat
        Raz [F:AST1]
    Else
        If [F:AST1]LANCHP = 200
            Read [ASTZ] Prev
        Elsif [F:AST1]LANCHP = 0
            Read [ASTZ] Next
        Endif
        If fstat
            Raz [F:AST1]
        Endif
    Endif
    Filter [AST1]
Endif

[M:ALT]LANCHP = [F:AST1]LANCHP
Affzo [M:ALT]LANCHP
Gosub AFF_CRITERES

# X3-9046 : resync from text server before loading
If [F:AST1]LANCHP<>0
    Call RESYNC([M:ALT]LANCHP, [M:ALT]LANREF, [M:ALT]LAN)
Endif

Call AFF_TAB([M:ALT]LANCHP)
Return


############################################################
$LOC_MAJ

If [M]LAN = GFRA
    # ici on refait le controle mais bon c'est vraiment pas necessaire
    # cg fev 2015 , on ajout la mise a jour de [m]syracuse a ce niveau
    GMESSAGE = ""
    Call TRAD_ACTLDEV (num$([M:ALT]LANCHP),2,1,2) From ALOCTRAD : # Contrôle plages messages std
    # si renvoie un message c'est que le chapitre est dnas la tranche std
    If GMESSAGE <> ""
        Call ECR_TRACE(GMESSAGE,0) From GESECRAN
        Return
    Endif
Endif


Trbegin [AST1]
GOK = 1

# Rewrite new local menu title

Readlock [AST2]CLE=[F:AST2]LANCHP;[F:AST2]LANNUM;[F:AST2]LAN
  Case fstat
    When 0 :
       WMSG = format$("N>:5",[M:ALT]LANCHP)-"___"-format$("K:30X",[F:AST2]LANMES)
       # ancienne valeur - aout 2012
       WANC_TRAD =  [F:AST2]LANMES
       #
       Call ECR_TRACE(WMSG,0) From GESECRAN
       [F:AST2]LANMES = [M:ALT]LANCHPTRAD
       WMSG = "_________"-
&      format$("K:30X",[F:AST2]LANMES)
       Call ECR_TRACE(WMSG,0) From GESECRAN
       # si modif que valuer init alors lanori =""
       # aout 2012
       If  [F:AST2]LANMES <> WANC_TRAD
           [F:AST2]LANORI= ""
       Endif
       Call FLDUPD("AST2") From OBJDIV
       Rewrite [AST2]
         If fstat
           Call FSTA("AST") From GLOCK
           Goto LOC_MAJ_FIN
         Endif
         # 2017-06-01 TEXT SERVER : AST2 : Head record : Description of chapters to be translated
         If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
           LSTATUS = func  APLSTD.UPDATE_MESSAGE([M:ALT]LANCHP,0,[F:AST2]LAN, "", [F:AST2]LANMES, [F:AST2]LANORI, LERRMSG)
           If LSTATUS<> CST_AOK
             GOK=0
             Goto LOC_MAJ_FIN
           Endif
         Endif
     When 4,5 :
       WMSG = format$("N>:5",[M:ALT]LANCHP)-"____"
       Call ECR_TRACE(WMSG,0) From GESECRAN
       [F:AST2]       = [F:AST1]
       [F:AST2]LAN    = [M:ALT]LAN
       [F:AST2]LANMES = [M:ALT]LANCHPTRAD
       WMSG = "________"-format$("K:30X",[F:AST2]LANMES)
       Call ECR_TRACE(WMSG,0) From GESECRAN
       # en creation si valeur diff de blanc alors lanori = vide
       # aout 2012
       If  [F:AST2]LANMES <> ""
           [F:AST2]LANORI= ""
       Endif
        Call FLDCRE("AST2") From OBJDIV
       Write [AST2]
         If fstat
           Call FSTA("AST") From GLOCK
           Goto LOC_MAJ_FIN
         Endif
         # 2017-06-01 TEXT SERVER : AST2 : Head record : Description of chapters to be translated
         If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
           LSTATUS = func  APLSTD.UPDATE_MESSAGE([M:ALT]LANCHP,[F:AST2]LANNUM,[F:AST2]LAN, "", [F:AST2]LANMES, [F:AST2]LANORI, LERRMSG)
           If LSTATUS<> CST_AOK
             GOK=0
             Goto LOC_MAJ_FIN
           Endif
         Endif
    When Default :
       GOK = 0
       Call FSTA("AST2") From GLOCK
       Goto LOC_MAJ_FIN
  Endcase
#
If [F:AST3]LANMES <> ""
  WABR = ""
  For J = 1 To [M:ALT]BASPAG-1 Step 2
    If [M:ALT]CODE(J) = ""
      [M:ALT]CODE(J) = " "
    Endif
    WABR += [M:ALT]CODE(J)
  Next J
  Readlock [AST4]CLE=[F:AST3]LANCHP;[F:AST3]LANNUM;[M:ALT]LAN
    Case fstat
      When 0 :
       [F:AST4]LANMES = WABR
       [F:AST4]LANORI= ""
       Call FLDUPD("AST4") From OBJDIV
       Rewrite [AST4]
          If fstat
            Call FSTA("AST4") From GLOCK
            Goto LOC_MAJ_FIN
          Endif
          # 2017-06-01 TEXT SERVER : AST3 : Head record : List of Codes for Local menus
          # Nothing to do : Not existent in TEXT server
      When 4,5 :
        [F:AST4]       = [F:AST3]
        [F:AST4]LAN    = [M:ALT]LAN
        [F:AST4]LANMES = WABR
        [F:AST4]LANORI = ""
        Call FLDCRE("AST4") From OBJDIV
        Write [AST4]
          If fstat
            Call FSTA("AST4") From GLOCK
            Goto LOC_MAJ_FIN
          Endif
      When Default :
         GOK = 0
         Call FSTA("AST4") From GLOCK
         Goto LOC_MAJ_FIN
    Endcase
Endif
#
Filter [AST5] Where LANCHP = [M:ALT]LANCHP & LANNUM > 0 & LAN = [M:ALT]LANREF
For [AST5]
  I = ([F:AST5]LANNUM*2)-2
  If I < dim([M:ALT]LANMES)-1
    Readlock [AST6]CLE=[F:AST5]LANCHP;[F:AST5]LANNUM;[M:ALT]LAN
    Case fstat
      When 0 :
        WMSG = "_________"-format$("N>:5",[F:AST5]LANNUM)-mid$([F:AST3]LANMES,[F:AST5]LANNUM,1)-
&       format$("K:30X",[F:AST5]LANMES)
        WANC_TRAD = [F:AST6]LANMES
        Call ECR_TRACE(WMSG,0) From GESECRAN
        [F:AST6]LANMES = [M:ALT]LANMES(I+1)
        WMSG = "___________"-mid$([F:AST4]LANMES,[F:AST5]LANNUM,1)-
&       format$("K:30X",[F:AST6]LANMES)
        Call ECR_TRACE(WMSG,0) From GESECRAN
       # si modif que valuer init alors lanori =""
       # aout 2012
       If  [F:AST6]LANMES <> WANC_TRAD
           [F:AST6]LANORI= ""
       Endif
       Call FLDUPD("AST6") From OBJDIV
       Rewrite [AST6]
          If fstat
            Call FSTA("AST6") From GLOCK
            Goto LOC_MAJ_FIN
          Endif
          # 2017-06-01 TEXT SERVER : AST6 : Line record : text of chapter to be translated
          If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
            LSTATUS= func APLSTD.UPDATE_MESSAGE([F:AST6]LANCHP,[F:AST6]LANNUM,[F:AST6]LAN, [M:ALT]CODE(I), [F:AST6]LANMES, [F:AST6]LANORI, LERRMSG)
            If LSTATUS<> CST_AOK
              GOK=0
              Goto LOC_MAJ_FIN
            Endif
          Endif
       When 4, 5 :
         WMSG = "_________"-format$("N>:5",[F:AST5]LANNUM)-mid$([F:AST3]LANMES,[F:AST5]LANNUM,1)-
&        format$("K:30X",[F:AST5]LANMES)
         Call ECR_TRACE(WMSG,0) From GESECRAN
         [F:AST6]       = [F:AST5]
         [F:AST6]LAN    = [M:ALT]LAN
         [F:AST6]LANMES = [M:ALT]LANMES(I+1)
         WMSG = "___________"-mid$([F:AST4]LANMES,[F:AST6]LANNUM,1)-
&        format$("K:30X",[F:AST6]LANMES)
         Call ECR_TRACE(WMSG,0) From GESECRAN
## cn 20.11.01  creer l'enre uniquement si la traduction est saisie
        If  [F:AST6]LANMES <>""
           [F:AST6]LANORI= ""
           Call FLDCRE("AST6") From OBJDIV
           Write [AST6]
           If fstat
             Call FSTA("AST6") From GLOCK
             Goto LOC_MAJ_FIN
           Endif
           # 2017-06-01 TEXT SERVER : AST6 : Line record : text of chapter to be translated
           If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
             LSTATUS= func APLSTD.UPDATE_MESSAGE([F:AST6]LANCHP,[F:AST6]LANNUM,[F:AST6]LAN, [M:ALT]CODE(I), [F:AST6]LANMES, [F:AST6]LANORI, LERRMSG)
             If LSTATUS<> CST_AOK
               GOK=0
               Goto LOC_MAJ_FIN
             Endif
           Endif
        Endif
      When Default :
        GOK = 0
        Call FSTA("AST2") From GLOCK
        Goto LOC_MAJ_FIN
    Endcase
  Else
    Break
  Endif
Next
Filter [AST5]

#
$LOC_MAJ_FIN
If GOK = 1
  Commit
  # cg may 2017
  # add the marking of the change
   If GADONIX=2 : Call TRACE_COR("AML",num$([M]LANCHP),"","M") From GOBJET : Endif
Else
  Rollback
Endif

#----------------------------
#----------------------------
# mise a jour des envir indus en interne
# apres le commit dans le dossier en cours car cette partie se lance depusi indusprd

If WNBRFOLDER <> 0
    Local Integer WOK
    Local Char WTRACE
    Raz WTRACE
    WOK = 0
    Call EXISTE_ADX ("","","ATRANSLATIONB",WOK) From ORDSYS
    If WOK = 1
       # si tout est ok alors là on met a jour les autres envri..
        # a faire apres le commit.... sur indusprd
        WOK = 0
        Call MAJ_TRAD([M:ALT]LANCHP,[M]LAN,[M]SYRACUSE,GFOLDER_INDUS,GFOLDER_VERSION,GFOLDER_PRODUIT,WNBRFOLDER,WTRACE,WOK) From ATRANSLATIONB
     Endif
Endif

Return

############################################################
Subprog AFF_TAB(LCHA)
Variable Decimal LCHA
Local Integer I
Local Integer LCHAREL, TRADUISIBLE, RET_CODE

# Cas de Chapitre à 0 : Non trouvé (initialisé par la recherche à 0) donc on efface le tableau qui n'a pas lieu d'être
If LCHA = 0
  Raz   [M:ALT]BASPAG  :  Effzo [M:ALT]20  :  End
Endif

[M:ALT]FLG  = LCHA

Effzo [M:ALT]20
Raz [F:AST1]
Raz [F:AST2]
Raz [F:AST3]
Raz [F:AST4]
Raz [F:AML1]
Read [AML1]MENLOC=LCHA
If fstat
  End
Endif

If [F:AML1]MENLOCAL=2
    If LCHA < 100
        Read [AST1]CLE=0;LCHA;[M:ALT]LANREF
        If fstat
          End
        Endif
    Else
        LCHAREL=LCHA-200
        Read [AST1]CLE=200;LCHAREL;[M:ALT]LANREF
        If fstat
          End
        Endif
    Endif
Else
    Read [AST1]CLE=LCHA;0;[M:ALT]LANREF
    If fstat
      End
    Endif
Endif
[M:ALT]LANCHPREF  = [F:AST1]LANMES
Affzo [M:ALT]LANCHPREF

#
If [F:AML1]MENLOCAL=2
    If LCHA < 100
        Read [AST2]CLE=0;LCHA;[M:ALT]LAN
    Else
        LCHAREL=LCHA-200
        Read [AST2]CLE=200;LCHAREL;[M:ALT]LAN
    Endif
Else
    Read [AST2]CLE=LCHA;0;[M:ALT]LAN
Endif
[M:ALT]LANCHPTRAD  = [F:AST2]LANMES
Affzo [M:ALT]LANCHPTRAD

# affichage info sur alm tradusible et modifiable
If [F:AML1]NONTRA=2
    [M:ALT]WINFMES= mess (310,123,1)
Elsif [F:AML1]AUZMOD = 2
    [M:ALT]WINFMES= mess (309,123,1)
Else
    [M:ALT]WINFMES= ""
Endif
Affzo [M:ALT]WINFMES

#
If [F:AML1]MENLOCAL=2
    Read [AST3]CLE=LCHA;0;[M:ALT]LANREF
Endif
#
If [F:AML1]MENLOCAL=2
    Read [AST4]CLE=LCHA;0;[M:ALT]LAN
Endif
#
Filter [AST5] Where LANCHP = LCHA & LANNUM > 0 & LAN = [M:ALT]LANREF
For [AST5]
  I = ([F:AST5]LANNUM*2)-2
  If I < dim([M:ALT]LANMES)-2
    [M:ALT]LANNUM(I) = [F:AST5]LANNUM
    [M:ALT]CODE(I)   = mid$([F:AST3]LANMES,[F:AST5]LANNUM,1)
    [M:ALT]LANMES(I) = [F:AST5]LANMES
    If dim([F:AST5]UPDUSR)>0
       If [F:AST5]UPDUSR <> ""
          [M:ALT]USR(I)    = [F:AST5]UPDUSR
       Elsif dim([F:AST5]CREUSR)>0
          [M:ALT]USR(I)    = [F:AST5]CREUSR
       Endif
    Endif
    If dim([F:AST5]UPDDAT)>0
       If [F:AST5]UPDDAT <> [0/0/0]
          [M:ALT]USRDAT(I) = [F:AST5]UPDDAT
       Elsif dim([F:AST5]CREDAT)>0
          [M:ALT]USRDAT(I) = [F:AST5]CREDAT
       Endif
    Endif
    #
    I += 1
    Read [AST6]CLE=[F:AST5]LANCHP;[F:AST5]LANNUM;[M:ALT]LAN
      If fstat
        Raz [F:AST6]
      Endif
    [M:ALT]CODE(I)   = mid$([F:AST4]LANMES,[F:AST6]LANNUM,1)
    [M:ALT]LANMES(I) = [F:AST6]LANMES
    #JPGA 06/02/2013 EXI-87047-1 : Affichage du Flag Traduisible sur les Messages correspondants
    [L]TRADUISIBLE=func ALOCTRAD.IS_TRADUISIBLE([AST6]LANMES, [AST5]LANMES, [AST6]LANORI, [AML1]NONTRA)
    If [L]TRADUISIBLE
      [M:ALT]TRA(I)=2
    Else
      [M:ALT]TRA(I)=1
    Endif
    #
    [M:ALT]BASPAG = I+1
  Else
    Break
  Endif
Next
Filter [AST5]
Affzo [M:ALT]20
End


#####################################################################################################
Subprog AFF_NBELEMENTS

Local File APLSTD [ZZC]
Local File ADOSSIER [ZZA]

# recherche du nbre de lignes en fra
Local Integer WNBR_TRANSLATE (0..15)
Local Char WLAN (3)(0..dim([F:ZZA]LAN))
Local Integer WNBR_LAN, WINDICE
Local Integer WIND_FRA

Local Clbfile WCLOB (4)

Local Integer WRESTANT
Raz WCLOB

Read [ZZA]DOSSIER =nomap
If fstat <> 0
    WCLOB = "No Texts"
    Goto FIN_AFF_TEXT
Endif


# lecture fiche dossier pour recup table des langue
For WINDICE=0 To [F:ZZA]NBRLAN-1
     WLAN (WINDICE) = [F:ZZA]LAN (WINDICE)
Next WINDICE
WNBR_LAN = [F:ZZA]NBRLAN
# recherche du poste fra
WIND_FRA = find ("FRA",WLAN(0..))
Raz WNBR_TRANSLATE

WCLOB = " ------ Number of messages which exist in APLSTD "+chr$(13)

#   remplissage de la table des langues
For WINDICE = 0 To WNBR_LAN-1
    If WLAN (WINDICE) <> ""
        Filter [ZZC] Where LAN =  WLAN (WINDICE) and LANMES <> "" and LANORI = ""
        WNBR_TRANSLATE (WINDICE) = rowcount ([F:ZZC])
        Filter [ZZC]
        If WLAN (WINDICE) <> "FRA"
                WRESTANT = WNBR_TRANSLATE(0) - WNBR_TRANSLATE(WINDICE)
                WCLOB += " in "+WLAN (WINDICE)+ ": "+num$(WNBR_TRANSLATE(WINDICE))
                WCLOB += "     To translate : "+num$(WRESTANT)+chr$(13)
        Else
                WCLOB += " in "+WLAN (WINDICE)+ ": "+num$(WNBR_TRANSLATE(WINDICE))+chr$(13)
        Endif
    Endif
Next WINDICE

$FIN_AFF_TEXT

Call AFFMES(WCLOB) From GESECRAN
Close Local File
End

########################################################################
Subprog TRAD_ACTLDEV (CODE, TYP, NIVEAU,INDMAJ)
Value Char CODE
Value Integer TYP
Value Integer NIVEAU
Value Integer INDMAJ

# type = 2 pour les menus locaux
If TYP <> 2 : End : Endif
# INDMAJ = 0 pas de mise a jour de [m]syracuse
# INDMAJ = 2 on met à jour le champ de la classe M
[M]SYRACUSE= 1

Local Integer OKPLG , K, I
Local Char    DEB(30) , FIN(30)


OKPLG= 0
GMESSAGE =""
# niveau 1 = standard
# niveau  2 : addon
# niveau  3 : vertical
# niveau  4 : specifique
Filter [ACD] Where DEV = NIVEAU and (PRO = 1 or PRO= 2 or PRO=GPRODUIT+3)
For [ACD]
      For I=1 To [F:ACD]NBLIG
          If [F:ACD]TYP(I-1)=[L]TYP
               K = instr(1,[F:ACD]RAN(I-1),"-")
               If K
                    DEB = left$([F:ACD]RAN(I-1),K-1)
                    FIN = right$([F:ACD]RAN(I-1),K+1)
                    OKPLG = (val(CODE)>=val(DEB) & val(CODE)<=val(FIN))
                    If OKPLG <> 0
                           # là ce n'est bon  on est dans la tranche où il ne faut pas
                           # cg fev 2015 on autorise les tranches de syracuse pour trad du eng vers fra
                           # ce sont les seules... autorisées de eng vers fra
                           If [F:ACD]COD <> "SYRACUSE"
                               # renvoie un message c'est que le chapitre est dans la tranche std
                               GMESSAGE = "Code réservé, saisie impossible"
                               Break 2
                           Else
                               [M]SYRACUSE= 2
                           Endif
                    Endif
               Endif
          Endif
     Next I
Next ACB
Filter [ACD]
End

############################################################
Subprog CHARGE_MESSAGES_PAR_CHP(W_LANCHP)
Variable Decimal W_LANCHP

  Local Integer LCHAREL

  Read [AML1]MENLOC=W_LANCHP
  If [M]LAN = GFRA
    # cg mars 2012
    # controle avec nouvelle table actldev
    # ici on veut traduire en fra donc toutes les transches non std sont autorisées
    GMESSAGE = ""
    Call TRAD_ACTLDEV (num$(W_LANCHP),2,1,0) From ALOCTRAD : # Contrôle plages messages std
    # si renvoie un message c'est que le chapitre est dnas la tranche std
    If GMESSAGE <> ""
        mkstat =2
        End
    Endif
    # lecture dans langue de ref si n existe pas on ne fait rien
    Read [AST1]CLE=W_LANCHP;0;[M:ALT]LANREF
    If fstat = 0
       Gosub AFF_CRITERES
       Call AFF_TAB(W_LANCHP)
    Else
        mkstat = 2
        GMESSAGE = mess(83,123,1)
    Endif
  Else
    Raz [F:AML1]
    Read [AML1]MENLOC=W_LANCHP
    If fstat=0
        If [F:AML1]MENLOCAL=2
            If W_LANCHP< 100
                Read [AST1]CLE=0;W_LANCHP;[M:ALT]LANREF
                If fstat=0
                    Gosub AFF_CRITERES
                    Call AFF_TAB(W_LANCHP)
                    End
                Endif
            Else
                LCHAREL=W_LANCHP-200
                Read [AST1]CLE=200;LCHAREL;[M:ALT]LANREF
                If fstat=0
                    Gosub AFF_CRITERES
                    Call AFF_TAB(W_LANCHP)
                    End
                Endif
            Endif
        Else
            Read [AST1]CLE=W_LANCHP;0;[M:ALT]LANREF
            If fstat=0
                Gosub AFF_CRITERES
                Call AFF_TAB(W_LANCHP)
                End
            Endif
        Endif
    Endif
    mkstat = 2
    GMESSAGE = mess(83,123,1)
  Endif
End


