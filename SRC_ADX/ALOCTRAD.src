Subprog AS_CODE(VALEUR)
Variable Char    VALEUR()
If mod(nolign,2) = 1
     mkstat = 2
     End
Endif
If nolign >= 2
    If [M:ALT]CODE(nolign-2) = ""
         mkstat = 2
    Endif
Endif
End

############################################################
Subprog AS_LANMES(VALEUR)
Variable Char    VALEUR()

If nolign > 2
    If [M:ALT]LANMES(nolign-2) = ""
      mkstat = 2
    Endif
Endif
End

############################################################
Subprog C_LANCHP(VALEUR)
Variable Decimal VALEUR
Local Integer    RET_CODE

If VALEUR < 1 | VALEUR > 30000
   GMESSAGE = mess(83,123,1)
   mkstat = 2
   End
Endif

# X3-9046 : resync from text server before loading
If VALEUR<>0
    If func RESYNC(VALEUR,[M]LANREF,[M]LAN)<>[V]CST_AOK
        mkstat=2
        End
    Endif
Endif

# Chargement des zones du masque à partir des zones saisies : LAN, LANREF, LANCHP
Call CHARGE_MESSAGES_PAR_CHP(VALEUR)
End

############################################################
Funprog RESYNC(PNUMCHP,PLANREF,PLAN)
Value Decimal PNUMCHP
Value Char    PLANREF
Value Char    PLAN

Local Integer LASTATUS
LASTATUS = [V]CST_AOK
# 2017-06-01 TEXT SERVER : Chapter synchronisation with text server at user input.
If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
    Local Integer LCODPRODUCT

    [L]LCODPRODUCT=func APLSTD.GET_CODE_PRODUCT(PNUMCHP, PLANREF, GMESSAGE)
    If GMESSAGE<>""
        mkstat=2
        End [V]CST_AERROR
    Endif

    # 1/ Looking for Product code. We test with -2 : PRODUCT = ""
    If dim([M]FLGPRO)>0
        If [L]LCODPRODUCT = -2
            [M]FLGPRO = 1
        Else
            [M]FLGPRO = 2
        Endif
    Endif

    LASTATUS = func APLSTD.SYNCCHAPITRE_SCREEN(PNUMCHP, PLANREF)
    If LASTATUS = [V]CST_AOK
        LASTATUS = func APLSTD.SYNCCHAPITRE_SCREEN(PNUMCHP, PLAN)
    Endif
Endif
End LASTATUS

############################################################
Subprog C_CODE(VALEUR)
Variable Char    VALEUR()

# test de la ligne a traduire
# on oblige la saisie cg 12/01/09

If VALEUR = "" or VALEUR = " "
    # on est sur une ligne paire
    If mod(nolign,2) = 0
        If [M:ALT]CODE(nolign-2) <> "" and [M:ALT]CODE(nolign-2) <> " "
            GMESSAGE="You must enter code"
            mkstat = 2
        Endif
    Endif
Endif
End

############################################################
Subprog C_LANMES(VALEUR)
Variable Char    VALEUR()

If nolign > 2
    If VALEUR = "" & [M:ALT]CODE(nolign-2) <> ""
      mkstat = 2
    Endif
Endif

# TCH 05/09/14 - SAM 102133
If mod(nolign,2) = 0
  If [M:ALT]CODE(nolign-2) <> "" and [M:ALT]CODE(nolign-2) <> " " and ([M:ALT]CODE(nolign-1) = "" or [M:ALT]CODE(nolign-1) = " ")
    zonsui = "[M:ALT]CODE(nolign-1)"
  Endif
Endif

End

