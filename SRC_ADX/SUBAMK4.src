#<AdxTL>@(#)7.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("AMK",GBIDC1,GBIDC2) From GOBJET
End

###############################################################
## SUBAMK4    Saisie des caractéristiques graphiques d'un bloc
###############################################################

$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "DEBUT"       : Gosub DEBUT
  When "SETBOUT"     : Gosub SETBOUT
  When "FIN"         : Gosub FIN
  When "OK"          : Gosub OK
  When "ABANDON"     : Gosub ABANDON
  When "APRES_MODIF" : Gosub APRES_MODIF
Endcase
Return

$APRES_MODIF
REP = "M"
Return

$OUVRE
If VALEUR<=1 : FIN=1 : Return : Endif
Return

$DEBUT
[M:AMK4]NOLTBL=val(PARAM(1))
[M:AMK4]TABTYP=zc

$RECHARG
Local Integer NLI : NLI=[M:AMK4]NOLTBL
# Charge les champs stockés dans AMK1
# BLOCTYPT 2930    
# BLOCTYPG 2932     TYPEG
# BLOCPOSG 2931     POSITION
# BLOCGDEF 2933     AFFDEF
# BLOCAFFD 2936     POSDEF
# BLOCLIEN1         CODURL1
# BLOCLIEN2         CODURL2
Raz [M:AMK4]CHPAR1,CODURL1,URL1,INTURL1,CHPAR2,CODURL2,URL2,INTURL2
# Charge les champs stockés dans AMK1
If clalev([F:AUR])=0 : Local File AURL [AUR]     : Endif
If clalev([F:ASU])=0 : Local File ASUBPROG [ASU] : Endif
If clalev([F:ASB])=0 : Local File ABLBSYS [ASB]  : Endif
[M:AMK4]TYPEG=[M:AMK1]BLOCTYPG(NLI)
[M:AMK4]POSITION=[M:AMK1]BLOCPOSG(NLI)
[M:AMK4]AFFDEF=[M:AMK1]BLOCGDEF(NLI)
[M:AMK4]POSDEF=[M:AMK1]BLOCAFFD(NLI)
[M:AMK4]REPD=[M:AMK1]BLOCREPD(NLI)
[M:AMK4]CHPAR1=[M:AMK1]BLOCPAR1(NLI)
[M:AMK4]CODURL1=[M:AMK1]BLOCLIEN1(NLI)
If [M:AMK4]CODURL1<>""
  Read [AUR]AUR0=[M:AMK4]CODURL1
  If fstat=0
    Call TEXTE([F:AUR]INTIT,[M]INTURL1) From OBJDIV
    [M]URL1=[F:AUR]URL
  Endif
  If [F:AUR]TYPURL=2
    For I=0 To 4
      [M]UPARCOD(I)=[F:AUR]UPARCOD(I) : [M]UPARLIB(I)=[F:AUR]UPARLIB(I) 
      [M]UPARDEF(I)=[F:AUR]UPARDEF(I) : # [M]UPARMEN(I)=[F:AUR]UPARMEN(I) 
      Raz [M]UPARVAL(I)
    Next I
  Endif
Endif
[M:AMK4]CHPAR2=[M:AMK1]BLOCPAR2(NLI)
[M:AMK4]CODURL2=[M:AMK1]BLOCLIEN2(NLI)
If [M:AMK4]CODURL2<>""
  Read [AUR]AUR0=[M:AMK4]CODURL2
  If fstat=0
    Call TEXTE([F:AUR]INTIT,[M]INTURL2) From OBJDIV
    [M]URL2=[F:AUR]URL
  Endif
  Local Integer I,J
  If [F:AUR]TYPURL=2
    For J=0 To 4
      If [M]UPARCOD(I)="" : Break 1 : Endif
    Next J
    For I=J+1 To 4
      [M]UPARCOD(I)=[F:AUR]UPARCOD(I) : [M]UPARLIB(I)=[F:AUR]UPARLIB(I) 
      [M]UPARDEF(I)=[F:AUR]UPARDEF(I) : # [M]UPARMEN(I)=[F:AUR]UPARMEN(I)
      Raz [M]UPARVAL(I)
    Next I
  Endif
Endif
Local Integer IP,DEB,NBV
If [M:AMK1]BLOCACT1(NLI)<>""
  DEB=1
  NBV=-1
  IP=1
  While IP<>0
    IP=instr(DEB+1,[M:AMK1]BLOCACT1(NLI),"?")
    If IP<>0
      NBV+=1
      [M]UPARVAL(NBV)=mid$([M:AMK1]BLOCACT1(NLI),DEB+1,IP-DEB-1)
      If [M]UPARVAL(NBV)="?" : [M]UPARVAL(NBV)="" : Endif
      DEB=IP
    Endif
  Wend
Endif
Local Integer ATYPEG
ATYPEG=[M:AMK4]TYPEG
Gosub SETSCRN
Return

$SETIMAG
Local Char NOMIMAG(200),IMAG1(20)
Case ATYPEG
 When 1,2
   Case AAFFDEF
     When 1 : IMAG1="xbar"
     When 2 : IMAG1="xline"
     When 3 : IMAG1="xarea"
     When 4 : IMAG1="xpie"
     When 5 : IMAG1="xradar"
   Endcase
   If IMAG1<>""
     Case AREPD
       When 1 : IMAG1+="m"
       When 2 : IMAG1+="cu"
       When 3 : IMAG1+="co"
     Endcase
   Endif
 When 3
   Case AREPD
     When 4 : IMAG1="calmonth"
     When 5 : IMAG1="calweek"
     When 6 : IMAG1="calday"
   Endcase
 When 5
   IMAG1="gantt"
Endcase
Read [ASB]ASB0="SCR";toupper(IMAG1)
If fstat=0
  [M:AMK4]IMAG=[F:ASB]BLOB
Else
  Raz [M:AMK4]IMAG
Endif
Return

$OK
#   On recharge les valeurs dans AMK1
Local Integer NLI : NLI=[M:AMK4]NOLTBL
[M:AMK1]BLOCTYPG(NLI)=[M:AMK4]TYPEG
[M:AMK1]BLOCPOSG(NLI)=[M:AMK4]POSITION
[M:AMK1]BLOCGDEF(NLI)=[M:AMK4]AFFDEF
[M:AMK1]BLOCAFFD(NLI)=[M:AMK4]POSDEF
[M:AMK1]BLOCLIEN1(NLI)=[M:AMK4]CODURL1
[M:AMK1]BLOCLIEN2(NLI)=[M:AMK4]CODURL2
[M:AMK1]BLOCPAR1(NLI)=[M:AMK4]CHPAR1
[M:AMK1]BLOCPAR2(NLI)=[M:AMK4]CHPAR2
[M:AMK1]BLOCREPD(NLI)=[M:AMK4]REPD
Raz [M:AMK1]BLOCACT1(NLI)
# CCCCCC   charge BLOCACT1
[M:AMK1]BLOCACT1(NLI)="?"
For I=0 To dim([M]UPARVAL)-1
  [M:AMK1]BLOCACT1(NLI)+=[M:AMK4]UPARVAL(I)+"?"
Next I
Return

$SETBOUT
Return

$ABANDON
#  On restaure les anciennes valeurs
REP = ""
Gosub RECHARG
FIN = 1
Return

$FIN
# Recharge les champs en invisible de AMK1
If GSTATUT=7
 mkstat = 1
Endif
Return

######################################################################################
Subprog AP_TYPEG(VALEUR)
Variable Integer VALEUR
Local Integer ATYPEG
ATYPEG=VALEUR
Gosub SETSCRN
End

$SETSCRN
Case ATYPEG
  When 1  : Actzo AFFDEF : [M]REPD=0 : Diszo REPD : Gosub RAZURL      : # Graphe Flash
  When 2  : Actzo AFFDEF,REPD : Gosub RAZURL      : # Graphe multi Flash
  When 3  : Diszo AFFDEF : Actzo REPD : [M]AFFDEF=0 : Gosub RAZURL      : # Calendrier Flash
  When 4  : Diszo AFFDEF,REPD : [M]AFFDEF=0 : [M]REPD=0 : Gosub ACTURL   : # XSL
  When 5  : Diszo AFFDEF,REPD : Gosub RAZURL      : # Gantt
Endcase
Local Integer AREPD,AAFFDEF
AREPD=[M:AMK4]REPD
AAFFDEF=[M:AMK4]AFFDEF

Gosub SETIMAG
Affzo [M:AMK4]
Return

$RAZURL
Raz   [M]CHPAR1,CODURL1,INTURL1,URL1,CHPAR2,CODURL2,INTURL2,URL2
Diszo CHPAR1,CODURL1,INTURL1,URL1,CHPAR2,CODURL2,INTURL2,URL2
Raz [M]UPARCOD , UPARLIB, UPARDEF, UPARVAL
Affzo [M]UPARCOD , UPARLIB, UPARDEF, UPARVAL
Return

$ACTURL
Actzo CHPAR1,CODURL1,INTURL1,URL1,CHPAR2,CODURL2,INTURL2,URL2
Return

Subprog AS_AFFDEF(VALEUR)
Variable Integer VALEUR
If [M:AMK4]TYPEG<>1 and [M:AMK4]TYPEG<>2 : mkstat=1 : Endif
End


Subprog AV_POSITION(VALEUR)
Variable Integer VALEUR
If [M:AMK4]TABTYP<>3 : mkstat=1 : Endif
End

Subprog AS_REPD(VALEUR)
Variable Integer VALEUR
Case [M:AMK4]TYPEG
 When 2
  GMENLOC(1)=0 : GMENLOC(2)=0 : GMENLOC(3)=0
  GMENLOC(4)=1 : GMENLOC(5)=1 : GMENLOC(6)=1
  If [M:AMK4]AFFDEF=4 or  [M:AMK4]AFFDEF=5
    GMENLOC(2)=1 : GMENLOC(3)=1
  Endif
 When 3
  GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1
  GMENLOC(4)=0 : GMENLOC(5)=0 : GMENLOC(6)=0
 When Default  : mkstat=1
Endcase
End

Subprog AP_AFFDEF(VALEUR)
Variable Integer VALEUR
Local Integer ATYPEG,AREPD,AAFFDEF
ATYPEG=[M:AMK4]TYPEG
AREPD=[M:AMK4]REPD
AAFFDEF=VALEUR
Gosub SETIMAG
Affzo [M:AMK4]IMAG
End

Subprog AP_REPD(VALEUR)
Variable Integer VALEUR
Local Integer ATYPEG,AREPD,AAFFDEF
ATYPEG=[M:AMK4]TYPEG
AREPD=VALEUR
AAFFDEF=[M:AMK4]AFFDEF
Gosub SETIMAG
Affzo [M:AMK4]IMAG
End

Subprog AS_TYPEG(VALEUR)
Variable Integer VALEUR
#GMENLOC(3)=1
End

Subprog AV_POSDEF(VALEUR)
Variable Integer VALEUR
If [M:AMK4]TABTYP<>2 : mkstat=1 : Endif
End

Subprog AM_CODURL1(VALEUR)
Variable Char    VALEUR()
If clalev([F:AUR])=0 : Local File AURL [AUR] : Endif
Raz [M]URL1,INTURL1
Read [AUR]AUR0=VALEUR
If fstat=0
  Call TEXTE([F:AUR]INTIT,[M]INTURL1) From OBJDIV
  [M]URL1=[F:AUR]URL
Endif
Affzo [M]URL1,INTURL1
Local Integer I
If [F:AUR]TYPURL=2
  For I=0 To 4
    [M]UPARCOD(I)=[F:AUR]UPARCOD(I) : [M]UPARLIB(I)=[F:AUR]UPARLIB(I) 
    [M]UPARDEF(I)=[F:AUR]UPARDEF(I) : # [M]UPARMEN(I)=[F:AUR]UPARMEN(I) 
    Raz [M]UPARVAL(I)
  Next I
  Affzo [M:AMK4]55
Endif
End

Subprog AS_CODURL2(VALEUR)
Variable Char    VALEUR()
If [M]CODURL1="" 
  Raz [M]URL2,INTURL2
  Affzo [M]URL2,INTURL2
  mkstat=1 
Endif
End

Subprog AM_CODURL2(VALEUR)
Variable Char    VALEUR()
If clalev([F:AUR])=0 : Local File AURL [AUR] : Endif
Raz [M]URL2,INTURL2
Read [AUR]AUR0=VALEUR
If fstat=0
  Call TEXTE([F:AUR]INTIT,[M]INTURL2) From OBJDIV
  [M]URL2=[F:AUR]URL
Endif
Affzo [M]URL2,INTURL2
Local Integer I,J
If [F:AUR]TYPURL=2
  For J=0 To 4
    If [M]UPARCOD(I)="" : Break 1 : Endif
  Next J

  For I=J+1 To 4
    [M]UPARCOD(I)=[F:AUR]UPARCOD(I) : [M]UPARLIB(I)=[F:AUR]UPARLIB(I) 
    [M]UPARDEF(I)=[F:AUR]UPARDEF(I) : # [M]UPARMEN(I)=[F:AUR]UPARMEN(I)
    Raz [M]UPARVAL(I)
  Next I
  Affzo [M:AMK4]55
Endif

End

Subprog AM_CHPAR1(VALEUR)
Variable Char    VALEUR()
End

Subprog AS_CHPAR2(VALEUR)
Variable Char    VALEUR()
If [M]CHPAR1="" 
  Raz [M]CODURL2,URL2,INTURL2
  Affzo [M]CODURL2,URL2,INTURL2
  mkstat=1 
Endif
End

Subprog AM_CHPAR2(VALEUR)
Variable Char    VALEUR()
End

Subprog AV_UPARVAL(VALEUR)
Variable Char    VALEUR()
If [M:AMK4]UPARCOD(indice)="" : mkstat=1 : Endif
End

Subprog C_UPARVAL(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,"?")<>0
  GMESSAGE=mess(94,123,1)-"?"
  mkstat=2
  End
Endif
End
