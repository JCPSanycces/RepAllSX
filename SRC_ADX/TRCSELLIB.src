#<AdxTL>@(#)3.0.0.0 $Revision$
#                                                                 #
#        traitement de sélection tronc commun                     #
###################################################################
# Actions :                                                       #
#                                                                 #
#  SELORD     : sélection d'OS ou d'OF dont la situation          #
#               est au - en cours                                 #
###################################################################


$ACTION
Case ACTION
    When "SEL_TABLE"    : Gosub SEL_TABLE
    When "FIN_TABLE"    : Gosub FIN_TABLE
    When "SEL_LISTE"    : Gosub SEL_LISTE
    When Default
Endcase
Return

###################################################################
#    Choix dans les tables                                        #
###################################################################

$SEL_TABLE
Case TABLE
    When "SELORD"     : Gosub S_ORD
Endcase
Return

$FIN_TABLE
Case TABLE
Endcase
Return

$SEL_LISTE
Case LISTE
Endcase
Return


###################################################################
$S_ORD
Case val(PARAM(3))
    When 10 : Gosub S_OF From MFGSELLIB
    When 36 : Gosub S_EO From SCOSELLIB
Endcase
Return
