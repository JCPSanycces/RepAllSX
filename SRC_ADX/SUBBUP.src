#<AdxTL>@(#)8.0.0.0 $Revision$
Raz GBIDC1, GBIDC2
Call OBJET("BUP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"          : Gosub OUVRE
 When "LIENS"          : Gosub LIENS
 When "RAZDUP"         : Gosub RAZDUP
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "CREATION"       : Gosub CREATION
 When "MODIF"          : Gosub MODIF
 When "VERIF_MOD"      : Gosub VERIF_MOD
 When "AP_CHANGE"      : Gosub AP_CHANGE
 When "ANNULE"         : Gosub ANNULE
 When "SEL_LISTE"      : Gosub SEL_LISTE
Endcase
Return

$OUVRE
If clalev([F:GYM])=0 : Local File GACCPYM    [GYM] : Endif : # Pyramides de comptes
If clalev([F:CYM])=0 : Local File GCCEPYM    [CYM] : Endif : # Pyramides de sections
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:CRY])=0 : Local File GCCEGRUPYM [CRY] : Endif
If clalev([F:BUV])=0 : Local File BUDVER     [BUV] : Endif
If clalev([F:BUD])=0 : Local File BUD        [BUD] : Endif
If clalev([F:DIE])=0 : Local File GDIE       [DIE] : Endif
Return

$LIENS
Actzo [M:BUP1]
Affzo [M:BUP1]
Call LECTEXTRA([M:BUP1]DESTRA,"BUDPAR","DESTRA",[M:BUP1]BUD,"") From ATEXTRA
Call LECTEXTRA([M:BUP1]SHOTRA,"BUDPAR","SHOTRA",[M:BUP1]BUD,"") From ATEXTRA
# the transatable headed of budget versions
nolign = 0
For [BUV] Where BUD=[M:BUP1]BUD
 nolign += 1
 [M] = [F:BUV]
 Call LECTEXTRA([M]VERDES(nolign-1),"BUDVER","DESTRA",[M]BUD,[M]VER(nolign-1)) From ATEXTRA
 Call LECTEXTRA([M]VERSHO(nolign-1),"BUDVER","SHOTRA",[M]BUD,[M]VER(nolign-1)) From ATEXTRA
Next
[M]NBVER = nolign
Affzo [M:BUP1]

If func AFNC.ACTIV("GDD")
 If [F:BUP]GDDFLG<>2
  Actzo [M]
  If [F:BUP]PYMACC=""
   Grizo PYMACCLEV
  Else
   Actzo PYMACCLEV
  Endif
  For I=0 To dim([F:BUP]DIE)-1
   If [F:BUP]DIE(I)=""
    Grizo PYMCCE(I),PYMCCELEV(I)
    For J=I+1 To dim([F:BUP]DIE)-1
     Grizo DIE(J),PYMCCE(J),PYMCCELEV(J)
    Next J
   Else
    Actzo PYMCCE(I)
    If I<dim([F:BUP]DIE)-1
     Actzo DIE(I+1)
    Endif
    If [F:BUP]PYMCCE(I)=""
     Grizo PYMCCELEV(I)
    Else
    Actzo PYMCCELEV(I)
    Endif
   Endif
  Next I
 Else
  #If operating buget
  Grizo [M]DIE(3), DIE(4), DIE(5), DIE(6), DIE(7), DIE(8)
  Grizo [M]PYMCCE(3), PYMCCE(4), PYMCCE(5), PYMCCE(6), PYMCCE(7), PYMCCE(8)
  Grizo [M]PYMCCELEV(3), PYMCCELEV(4), PYMCCELEV(5), PYMCCELEV(6), PYMCCELEV(7), PYMCCELEV(8)
  If !clalev([F:ENV]) : Local File ENVELOPPE [ENV] : Endif
  Filter [ENV] Where BUD=[M:BUP1]BUD
  Look [ENV]ENV0 First
  If !fstat
   Diszo [M]BUDCTL,QTY,BUPODS,NBVER,PYMACC,PYMACCLEV,PYMCCE,PYMCCELEV,DIE(0),DIE(1),COA
   Filter [BUD] Where DIE1=[M]DIE(0) & DIE2=[M]DIE(1) & DIE3<>""
   Look [BUD]BUD0 First
   If !fstat
    Diszo [M]DIE(2)
   Endif
   Filter [BUD]
  Else
   Diszo [M]BUDCTL,QTY,BUPODS,NBVER,PYMACC,PYMACCLEV,PYMCCE,PYMCCELEV
  Endif
 Endif
Endif
Affzo [M:BUP1]
Return

$RAZDUP
If func AFNC.ACTIV("GDD")
 If [M]GDDFLG<>2
  Actzo [M]1-99
 Else
  Actzo [M]COA,DIE(0),DIE(1),DIE(2)
 Endif
Else
 Actzo [M]1-99
Endif
Return

$INICRE
$INIMOD
If dim([F:BUP]DES)>0
 [F:BUP]DES = [M:BUP1]DESTRA
Endif
[F:BUP]DIENBR = 0
For I=0 To dim([M:BUP1]DIE)-1
 If [M:BUP1]DIE(I)<>"" : [F:BUP]DIENBR = [F:BUP]DIENBR+1 : Endif
Next
Return

$MODIF
Gosub MTEXTRA
Call MAJTEXTRA([M:BUP1]DESTRA,"BUDPAR","DESTRA",[M:BUP1]BUD,"") From ATEXTRA
If GOK<1 : Return : Endif
Call MAJTEXTRA([M:BUP1]SHOTRA,"BUDPAR","SHOTRA",[M:BUP1]BUD,"") From ATEXTRA
If GOK<1 : Return : Endif
Return

$VERIF_MOD
For [BUV] Where BUD=CLECUR1
 If !find([F:BUV]VER,[M]VER(0..[M]NBVER-1)) : # Version supprimée
  Filter [BUD] Where BUD=CLECUR1 & VER=[F:BUV]VER
  Read [BUD] First
  Filter [BUD]
  If fstat<=2
   GMESSAGE = [F:BUV]VER-":"-mess(148,108,1) : # Non supprimable
   OK = 0 : Break
  Endif
 Endif
Next
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## When duplication, we duplicate also the transatable headed.
 Call DUPTEXTRA("BUDPAR","DESTRA",CLECUR1,"","BUDPAR","DESTRA",[M:BUP1]BUD,"")  From ATEXTRA
 Call DUPTEXTRA("BUDPAR","SHOTRA",CLECUR1,"","BUDPAR","SHOTRA",[M:BUP1]BUD,"")  From ATEXTRA
 For nolign=1 To [M]NBVER
  Call DUPTEXTRA("BUDVER","DESTRA",CLECUR1,num$([M:BUP1]VER(nolign-1)),"BUDVER","DESTRA",[M:BUP1]BUD,[M:BUP1]VER(nolign-1)) From ATEXTRA
  Call DUPTEXTRA("BUDVER","SHOTRA",CLECUR1,num$([M:BUP1]VER(nolign-1)),"BUDVER","SHOTRA",[M:BUP1]BUD,[M:BUP1]VER(nolign-1)) From ATEXTRA
 Next
Endif

If GREP="C" | GREP="D"
 Call MAJTEXTRA([M:BUP1]DESTRA,"BUDPAR","DESTRA",[M:BUP1]BUD,"") From ATEXTRA
 Call MAJTEXTRA([M:BUP1]SHOTRA,"BUDPAR","SHOTRA",[M:BUP1]BUD,"") From ATEXTRA
 For nolign=1 To [M]NBVER
  Call MAJTEXTRA([M]VERDES(nolign-1),"BUDVER","DESTRA",[M]BUD,[M]VER(nolign-1)) From ATEXTRA
  Call MAJTEXTRA([M]VERSHO(nolign-1),"BUDVER","SHOTRA",[M]BUD,[M]VER(nolign-1)) From ATEXTRA
  If [F:BUV]CTL<>[M]CTL(nolign-1) & dim([V]GBUDSITE)>0 & [V]GBUDSITE<>""
   Raz [V]GBUDSITE
  Endif
  [F:BUV]BUD = [M]BUD
  [F:BUV]VER = [M]VER(nolign-1)
  [F:BUV]STA = [M]STA(nolign-1)
  [F:BUV]DEF = [M]DEF(nolign-1)
  [F:BUV]CTL = [M]CTL(nolign-1)
  Write [BUV]
  If fstat
   GOK = 0 : Call FSTA("BUV") From GLOCK : Break
  Endif
 Next nolign
Endif
Return

$MTEXTRA
# Update of the TEXTRA of the version table
If GREP="M"
 # Save the textra of version as we see it (the mask [m:bup1])
 For I=0 To [M:BUP1]NBVER-1
#  Call DUPTEXTRA("BUDVER","DESTRA",[M:BUP1]BUD,[M:BUP1]VER(I),"BUDVER","DESTRA",[M:BUP1]BUD,chr$(255)+num$(I+1)) From ATEXTRA
#  Call DUPTEXTRA("BUDVER","SHOTRA",[M:BUP1]BUD,[M:BUP1]VER(I),"BUDVER","SHOTRA",[M:BUP1]BUD,chr$(255)+num$(I+1)) From ATEXTRA
  Call DUPTEXTRA("BUDVER","DESTRA",[M:BUP1]BUD,[M:BUP1]VER(I),"BUDVER","DESTRA",[M:BUP1]BUD,chr$(255)+[M:BUP1]VER(I)) From ATEXTRA
  Call DUPTEXTRA("BUDVER","SHOTRA",[M:BUP1]BUD,[M:BUP1]VER(I),"BUDVER","SHOTRA",[M:BUP1]BUD,chr$(255)+[M:BUP1]VER(I)) From ATEXTRA
 Next I

 # Delete all the textra of BUDVER exisiting
 Delete [AXX] Where CODFIC = "BUDVER" & ZONE = "DESTRA" & IDENT1 = [M:BUP1]BUD & left$(IDENT2,1) <> chr$(255)
 If fstat=1
  GOK=-1 : Call RSTA("AXX","BUDVER"-[M:BUP1]BUD) From GLOCK : Return
 Endif
 Delete [AXX] Where CODFIC = "BUDVER" & ZONE = "SHOTRA" & IDENT1 = [M:BUP1]BUD & left$(IDENT2,1) <> chr$(255)
 If fstat=1
  GOK=-1 : Call RSTA("AXX","BUDVER"-[M:BUP1]BUD) From GLOCK : Return
 Endif
 # At the same time delete the version of the BUDVER table
 Delete [BUV] Where BUD=CLECUR1
 If fstat
  GOK = 0 : Call FSTA("BUV") From GLOCK
 Endif

 # Update with the version value of the mask in Textra
 Update [AXX] Where CODFIC = "BUDVER" & ZONE = "DESTRA" & IDENT1 = [M:BUP1]BUD & left$(IDENT2,1) = chr$(255)
&             With [AXX]IDENT2 = right$([AXX]IDENT2,2)
 If fstat=1
  GOK=-1 : Call RSTA("AXX","BUDVER"-[M:BUP1]BUD) From GLOCK : Return
 Endif
 Update [AXX] Where CODFIC = "BUDVER" & ZONE = "SHOTRA" & IDENT1 = [M:BUP1]BUD & left$(IDENT2,1) = chr$(255)
&             With [AXX]IDENT2 = right$([AXX]IDENT2,2)
 If fstat=1
  GOK=-1 : Call RSTA("AXX","BUDVER"-[M:BUP1]BUD) From GLOCK : Return
 Endif

 # MAJTEXTRA of these versions and at the same time update the version of the BUDVER table with the mask values
 For I=0 To [M:BUP1]NBVER-1
  Call MAJTEXTRA([M:BUP1]VERDES(I),"BUDVER","DESTRA",[M:BUP1]BUD,[M]VER(I)) From ATEXTRA
  Call MAJTEXTRA([M:BUP1]VERSHO(I),"BUDVER","SHOTRA",[M:BUP1]BUD,[M]VER(I)) From ATEXTRA
  [F:BUV]BUD = [M]BUD
  [F:BUV]VER = [M]VER(I)
  [F:BUV]STA = [M]STA(I)
  [F:BUV]DEF = [M]DEF(I)
  [F:BUV]CTL = [M]CTL(I)
  Write [BUV]
  If fstat
   GOK = 0 : Call FSTA("BUV") From GLOCK : Break
  Endif
 Next

Endif
Return

$AP_CHANGE
Call CHGTEXTRA("BUDPAR","DESTRA",[M:BUP1]BUD,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("BUDPAR","SHOTRA",[M:BUP1]BUD,"",NCODE,"") From ATEXTRA
Return

$ANNULE
Call SUPTEXTRA("BUDPAR","DESTRA",[M:BUP1]BUD,"") From ATEXTRA
Call SUPTEXTRA("BUDPAR","SHOTRA",[M:BUP1]BUD,"") From ATEXTRA
Return

##########################################################################
# Labels of the mask [BUP1]
##########################################################################
Subprog AV_DESTRA(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("GDD")
 If GREP="D" & [M]GDDFLG=2
  [M]VERDES(0) ="V1"-[M]BUD
  Affzo [M]VERDES(0)
 Endif
Endif
End

Subprog C_BUDCTL(VALEUR)
Variable Integer VALEUR
If VALEUR=1 & [M:BUP1]BUD<>""
 If !clalev([F:ADW]) : Local File ADOVAL [ADW] : Endif
 Filter [ADW] Where VALEUR=[M:BUP1]BUD & left$(PARAM,3)="BUP" & find(right$(PARAM,4),"1","2","3","4","5","6","7","8","9")
 Look [ADW]ADW0 First
 If !fstat
  # Budget utilisé dans les paramètres budgets à contrôler
  GMESSAGE=mess(266,108,1)
  mkstat=2
 Endif
 Filter [ADW]
Endif
End

Subprog C_LEV(VALEUR)
Variable Integer VALEUR
If VALEUR<>[M]LEV
 Gosub VERFBUD
 If mkstat : End : Endif
Endif
End

$VERFBUD
Filter [BUD] Where BUD = [M]BUD
Read [BUD]First
Filter [BUD]
If !fstat
 ## Budget used in the budget parameters to be controlled
 GMESSAGE = mess(17,108,1)
 mkstat = 2 : End
Endif
Return

Subprog C_CUR(VALEUR)
Variable Char     VALEUR
If VALEUR<>[M]CUR
 Gosub VERFBUD
 If mkstat : End : Endif
Endif
End

Subprog C_DIVAMT(VALEUR)
Variable Decimal VALEUR
If VALEUR<1
 mkstat = 1 : End
Endif
End

Subprog C_VLYSTR(VALEUR)
Variable Date    VALEUR
If ([M]BUDCTL=4 | [M]BUDCTL=5) & VALEUR=[0/0/0]
 # Start date mandatory for sliding budget control + contrôle budgétaire cumulé
 GMESSAGE = mess(60,108,1)
 mkstat = 2 : End
Endif
End

Subprog C_PYMACC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If clalev([F:GYM])=0 : Local File GACCPYM [GYM] : Endif
 Read [GYM]GYM0 = VALEUR
 If [M:BUP1]COA <> [F:GYM]COA
  # Pyramid associated with the chart of accounts
  GMESSAGE = mess(93,108,1)-[F:GYM]COA
  mkstat = 2 : End
 Endif
 Call CONTEXE([F:GYM]ACS) From CPTSUB
 If mkstat : GMESSAGE = VALEUR-GMESSAGE : Endif
Endif
If VALEUR<>[M]PYMACC
 Gosub VERFBUD
 If mkstat : End : Endif
Endif
End

Subprog AP_PYMACC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & [M]PYMACCLEV=0
 Actzo PYMACCLEV
 [M]PYMACCLEV = 1 : Affzo PYMACCLEV
Elsif VALEUR = ""
 Effzo PYMACCLEV
 Grizo PYMACCLEV
Endif
End

Subprog AS_PYMACCLEV(VALEUR)
Variable Decimal  VALEUR
If [M]PYMACC = ""
 mkstat = 1 : End
Endif
End

Subprog C_PYMACCLEV(VALEUR)
Variable Decimal  VALEUR
Local Integer NIVEAU
If VALEUR=0
 mkstat = 2 : End
Elsif VALEUR>=99
 mkstat = 1 : End
Endif
NIVEAU = 0
If [M]PYMACC<>"" & VALEUR<>1
 If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY]:  Endif
 For [GRY]GRY1 Where PYM=[M]PYMACC & LEV=VALEUR
  NIVEAU = 1 : Break
 Next
 If NIVEAU = 0
  ## Non-existent definition level
  GMESSAGE = mess(51,108,1)
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_PYMCCE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If clalev([F:CYM])=0 : Local File GCCEPYM [CYM] : Endif
 Read [CYM]CYM0 = VALEUR
 ## The pyramid should be associated to the same dimension.
 If [M:BUP1]DIE(indice)<>[F:CYM]DIE
  # Pyramid associated with the dimension type
  GMESSAGE = mess(94,108,1)-[F:CYM]DIE
  mkstat = 2 : End
 Endif
 Call CONTEXE([F:CYM]ACS) From CPTSUB
 If mkstat : GMESSAGE = VALEUR-GMESSAGE : Endif
Endif
If VALEUR<>[M]PYMCCE(indice)
 Gosub VERFBUD
 If mkstat : End : Endif
Endif
End

Subprog AP_PYMCCE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & [M]PYMCCELEV(indice)=0
 Actzo PYMCCELEV(indice)
 [M]PYMCCELEV(indice) = 1 : Affzo PYMACCLEV
Elsif VALEUR = ""
 Effzo PYMCCELEV(indice)
 Grizo PYMCCELEV(indice)
Endif
End

Subprog AS_PYMCCELEV(VALEUR)
Variable Decimal  VALEUR
If [M]PYMCCE(indice) = ""
 mkstat = 1 : End
Endif
End

Subprog C_PYMCCELEV(VALEUR)
Variable Decimal  VALEUR
Local Integer NIVEAU
If VALEUR=0
 mkstat = 2 : End
Elsif VALEUR>=99
 mkstat = 1 : End
Endif
NIVEAU = 0
If [M]PYMCCE(indice)<>"" & VALEUR<>1
 If clalev([F:CRY])=0 : Local File GCCEGRUPYM [CRY]:  Endif
 For [CRY]CRY1 Where PYM=[M]PYMCCE(indice) & LEV=VALEUR
  NIVEAU = 1 : Break
 Next
 If NIVEAU = 0
  ## Non-existent definition level
  GMESSAGE = mess(51,108,1)
  mkstat = 2 : End
 Endif
Endif
End


Subprog C_COA(VALEUR)
Variable Char    VALEUR()
Call LECTURE("COA",VALEUR,"") From CONTOBJ
#If dim([M]GDDFLG)>0 & [M]GDDFLG=2 & [F:COA]ANATRK<>2
If [F:COA]ANATRK<>2
 ## The chart of accounts must be tracked analytically
 GMESSAGE=mess(152,108,1)
 mkstat=2
Endif
End


Subprog AS_DIE(VALEUR)
Variable Char    VALEUR()
#08/10/09 JHA
#If indice>1 & [M]DIE(indice-1)=""
# mkstat = 1 : End
#Endif
End

Subprog C_DIE(VALEUR)
Variable Char    VALEUR()
Local Integer I
If find(VALEUR,[M]DIE(0..indice-1))
 ## Dimension type already defined
 GMESSAGE = mess(80,105,1)
 mkstat = 2 : End
Endif
If VALEUR = ""
# If indice=0
#  # At least one dimension type must be entered
#  GMESSAGE = mess(98,106,1)
#  mkstat = 2 : End
# Else
#  Effzo PYMCCE(indice),PYMCCELEV(indice)
#  Grizo PYMCCE(indice),PYMCCELEV(indice)
#  For I=indice+1 To dim([M]DIE)-1
#   Effzo DIE(I),PYMCCE(I),PYMCCELEV(I)
#   Grizo DIE(I),PYMCCE(I),PYMCCELEV(I)
#  Next I
# Endif
 Case indice
  When 0
   # At least one dimension type must be entered
   GMESSAGE = mess(98,106,1)
   mkstat = 2 : End
  When 1
   If func AFNC.ACTIV("GDD")
    If [M]GDDFLG=2
     # The envelop dimension is requiered in operating budget
     # L'axe enveloppe est obligatoire pour un budget opérationnel
     GMESSAGE = mess(270,108,1)
     mkstat = 2 : End
    Endif
   Endif
 Endcase

 Effzo PYMCCE(indice),PYMCCELEV(indice)
 Grizo PYMCCE(indice),PYMCCELEV(indice)
 For I=indice+1 To dim([M]DIE)-1
  Effzo DIE(I),PYMCCE(I),PYMCCELEV(I)
  Grizo DIE(I),PYMCCE(I),PYMCCELEV(I)
 Next I

Else
 If func AFNC.ACTIV("GDD")
  If [M]GDDFLG=1
   Call LECTURE("DIE",VALEUR,"") From CONTOBJ
   If [F:DIE]ENT=2 | [F:DIE]ENV=2
    ## The balance of the fiscal year budget available for allocation has been exceeded
    GMESSAGE=mess(143,108,1)
    mkstat=2 : End
   Endif
   Actzo PYMCCE(indice)
   If indice<dim([M]DIE)-1
    Actzo DIE(indice+1)
   Endif
  Else
  #GDD
   Call LECTURE("DIE",VALEUR,"") From CONTOBJ
   Case indice
    When 0 :
     If [F:DIE]ENT<>2
      #Si le budget est flagué Budget opérationnel, le premier axe renseigné doit être flagué entité
      GMESSAGE=mess(150,108,1)
      mkstat=2 : End
     Endif
    When 1 :
     If [F:DIE]ENV<>2
      ## If the budget is flagged "Operarting budgets", the dimension type first entered must be flagged "Entity"
      GMESSAGE=mess(151,108,1)
      mkstat=2 : End
     Endif
   Endcase
   If indice<2
    Actzo DIE(indice+1)
   Endif
  Endif
  #JHA:ARV 110411 : Ajouter un contrôle que les plan de compte et axe(s) existent dans un référentiels

 Else
  Actzo PYMCCE(indice)
  If I<dim([M]DIE)-1
   Actzo DIE(indice+1)
  Endif
 Endif
Endif
End

Subprog AS_PYMCCE(VALEUR)
Variable Char    VALEUR()
If [M]DIE(indice)="" : mkstat = 1 : End : Endif
End

Subprog C_VER(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]VER) From OBJDIV
If mkstat : End : Endif
End

Subprog C_DEF(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 For NOL=0 To [M]NBVER
  If NOL<>nolign-1 & [M]DEF(NOL)=2
   [M]DEF(NOL) = 1
   Affzo DEF(NOL)
  Endif
 Next NOL
Endif
End

Subprog C_CTL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 For NOL=0 To [M]NBVER
  If NOL<>nolign-1 & [M]CTL(NOL)=2
   [M]CTL(NOL) = 1
   Affzo CTL(NOL)
  Endif
 Next NOL
Endif
End

#Subprog B1_VER(VALEUR)
#Variable Char    VALEUR()
#Call OBJET("BUV",VALEUR,[M]BUD) From GOBJET
#End

######################################################################################
## Ecran BUP1 18/02/2008 12:08:27 JHA Gestion des dépenses
## Ajoût d'une case à cocher "Gestion des dépenses" GDDFLG à la table BUDPAR
######################################################################################

Subprog C_GDDFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 If !clalev([ENV]) : Local File ENVELOPPE [ENV] : Endif
 Filter [ENV] Where BUD=[M:BUP1]BUD
 Look [ENV]ENV0 First
 If !fstat
  ## There is no approved budget line that matches the selection (Analytical account/Entity/Envelope)
  GMESSAGE=mess(239,108,1)
  [M]GDDFLG=2 : Affzo [M]GDDFLG
  mkstat=2 : End
 Endif
 Filter [ENV]
 Actzo [M]BUDCTL,QTY,BUPODS,NBVER,PYMACC,PYMACCLEV,PYMCCE,PYMCCELEV,DIE,COA
Endif
End

Subprog AM_GDDFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Local Integer OK
 If GREP<>"C" & GREP <>"D"
  ## Some of the following zones will be reinitialized. Do you want to continue?
  Call OUINONT(mess(153,108,1),OK) From GESECRAN
  If OK=1
   VALEUR=[M]GDDFLG : mkstat=0 : End
  Endif
 Endif
 #-------------------------
 Raz [M]BUDCTL,QTY,BUPODS,NBVER
 Raz PYMACC,PYMACCLEV,PYMCCE,PYMCCELEV
 #Raz COA,DIE
 Actzo [M]COA,DIE
 Affzo [M]
 # - le type de contrôle est forcé à aucun
 [M]BUDCTL=1 :  Grizo [M]BUDCTL
 # - la saisie des quantités est désactivée
 [M]QTY=1 :  Diszo [M]QTY
 # - la case "OD Budgétaire" est désactivée
 [M]BUPODS=1 : Diszo [M]BUPODS
 # - le tableau des version est desactivé
 [M]VER(0)    ="1"
 [M]VERDES(0) ="V1"-[M]BUD
 [M]STA(0)    =2 :#Fermée
 [M]CTL(0)    =2 :#Définitif Oui
 [M]DEF(0)    =2 :#Par défaut Oui
 [M]NBVER=1
 Affzo [M]VER,VERDES,STA,CTL,DEF
 Diszo [M]NBVER
 # - la gestion des pyramides est desactivée
 Diszo [M]PYMACC,PYMACCLEV,PYMCCE,PYMCCELEV
 #-------------------------
 Effzo [M]DIE(3), DIE(4), DIE(5), DIE(6), DIE(7), DIE(8)
 Effzo [M]ZDIE(3), ZDIE(4), ZDIE(5), ZDIE(6), ZDIE(7), ZDIE(8)
 Grizo [M]DIE(3), DIE(4), DIE(5), DIE(6), DIE(7), DIE(8)
 Affzo [M]DIE
Else
 Actzo [M]DIE(3), DIE(4), DIE(5), DIE(6), DIE(7), DIE(8)
 Actzo [M]PYMCCE(3), PYMCCE(4), PYMCCE(5), PYMCCE(6), PYMCCE(7), PYMCCE(8)
 Actzo [M]PYMCCELEV(3), PYMCCELEV(4), PYMCCELEV(5), PYMCCELEV(6), PYMCCELEV(7), PYMCCELEV(8)
Endif
End


######################################################################################
## Sélections
######################################################################################
$SEL_LISTE
Local Char DESIG(GLONAX3)
Local Char TEXTE(30)(1..200,1..2) , TIT(30)(0..2)
# Niveau
TIT(0) = mess(46,104,1)
Case PARAM(1)
 When "NIVCPT"
  # Code
  TIT(1) = mess(37,100,1)
  # Intitulé
  TIT(2) = mess(3,113,1)
  For [GRY]GRY1(2) Where PYM=[M]PYMACC
   NBTEX += 1
   TEX(NBTEX)   = num$([F:GRY]LEV)
   Call LECTEXTRA(DESIG,"GACCGRUPYM","DESTRA",[M]PYMACC,[F:GRY]GRU) From ATEXTRA
   TEXTE(NBTEX, 1) = TEX(NBTEX)
   TEXTE(NBTEX, 2) = [F:GRY]GRU-DESIG
  Next
 When "NIVSEC"
  # Code
  TIT(1) = mess(37,100,1)
  # Intitulé
  TIT(2) = mess(3,113,1)
  For [CRY]CRY1(2) Where PYM=[M]PYMCCE(indice)
   NBTEX += 1
   TEX(NBTEX)   = num$([F:CRY]LEV)
   Call LECTEXTRA(DESIG,"GCCEGRUPYM","DESTRA",[M]PYMCCE(indice),[F:CRY]GRU) From ATEXTRA
   TEXTE(NBTEX, 1) = TEX(NBTEX)
   TEXTE(NBTEX, 2) = [F:CRY]GRU-DESIG
  Next
Endcase
Return


