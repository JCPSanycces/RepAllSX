#<AdxTL>@(#)124.0.0.0 $Revision$
Subprog SAISI(NBMASK,MASQUE,TIT,CHAINE,NBTEX,TEXTE,TRAITEMENT)
Value   Integer NBMASK
Value   Char    MASQUE()(1..)
Value   Char    TIT
Value   Char    CHAINE
Value   Integer NBTEX
Value   Char    TEXTE()()
Value   Char    TRAITEMENT

Local Integer I , OK , PAG , J , SAVOBJ, BOX
Local Integer ETABOU(1..GNBBOU) , ETATEX(1..GNBBOU)
Local Integer REPONSE , NBBOUT , CODBOUT(1..30)
Local Char    REP(1) , ACT(15) , CBOUT(1)(30) , SAVPROG(10)
Local Char    LISBOUT(30)(1..30) , ABRBOUT(1)(1..30)
Local Char    REPORT1(20), REPORT2(20)

Call SAVBOUT From GESECRAN
SAVOBJ  = GOBJET
SAVPROG = GPROGRAMME
GOBJET = 1
GPROGRAMME = "SAIECRAN"

# Définition initiale des boutons
Raz NBBOUT , LISBOUT
If instr(1,CHAINE,"M")
 NBBOUT += 1 : LISBOUT(NBBOUT) = mess(2,123,1)
 ABRBOUT(NBBOUT) = left$(mess(2,123,1),1) : CODBOUT(NBBOUT) = GSTAENR
#                               Enregistrer
Endif
If instr(1,CHAINE,"C")
 NBBOUT += 1 : LISBOUT(NBBOUT) = mess(3,123,1)
 ABRBOUT(NBBOUT) = left$(mess(3,123,1),1) : CODBOUT(NBBOUT) = GSTACRE
#                               Créer
Endif
If instr(1,CHAINE,"A")
 NBBOUT += 1 : LISBOUT(NBBOUT) = mess(4,123,1) : CODBOUT(NBBOUT) = GSTAANU
 ABRBOUT(NBBOUT) = left$(mess(4,123,1),1) : CODBOUT(NBBOUT) = GSTAANU
#                               Supprimer
Endif
If instr(1,CHAINE,"F") | instr(1,CHAINE,"C")
 NBBOUT += 1 : LISBOUT(NBBOUT) = mess(5,123,1) : CODBOUT(NBBOUT) = GSTAFIN
 ABRBOUT(NBBOUT) = left$(mess(5,123,1),1) : CODBOUT(NBBOUT) = GSTAFIN
#                               Abandon
Endif
STDBOUT = NBBOUT
For I=1 To NBTEX
 NBBOUT +=1
 LISBOUT(NBBOUT) = TEXTE(I)
 CODBOUT(NBBOUT) = GSTABOU+I
 ABRBOUT(NBBOUT) = left$(TEXTE(I),1) 
 CBOUT(NBBOUT)   = mid$("abcdefghijkmn",I,1) 
 CODBOUT(nbbout) = GSTABOU2+I 
 GSTASPE(i) = CODBOUT(nbbout)
Next I
NBBOUT += 1 : LISBOUT(NBBOUT) = mess(65,123,1) : CODBOUT(NBBOUT) = GSTAEND
ABRBOUT(NBBOUT) = left$(LISBOUT(NBBOUT),1)

REPORT1=GREPORT1
REPORT2=GREPORT2

# Ouverture des masques
For I=1 To NBMASK
 Case I
  When 1 : Local Mask =MASQUE(I) [SAI1]
  When 2 : Local Mask =MASQUE(I) [SAI2]
  When 3 : Local Mask =MASQUE(I) [SAI3]
  When 4 : Local Mask =MASQUE(I) [SAI4]
  When 5 : Local Mask =MASQUE(I) [SAI5]
  When 6 : Local Mask =MASQUE(I) [SAI6]
  When 7 : Local Mask =MASQUE(I) [SAI7]
  When 8 : Local Mask =MASQUE(I) [SAI8]
 Endcase
Next I

# Constitution inpbox
OK=1
ACT="OUVRE_BOITE" : Gosub ACTION
If OK<0 : Goto FIN
Elsif OK
 Case NBMASK
  When 1
   Local inpbox Mask [SAI1]
&   Button LISBOUT(1..NBBOUT) With ABRBOUT(1..NBBOUT) Coded CODBOUT(1..NBBOUT)
&   Titled TIT
&   As [SAI]
    Setmok [SAI1] With 0
  When 2
   Local Inpbox Mask [SAI1]
&  Button LISBOUT(1..NBBOUT) With ABRBOUT(1..NBBOUT) Coded CODBOUT(1..NBBOUT)
&  Titled TIT
&   Folder Mask [SAI2] Titled mess(16,100,1)-"1"
&  As [SAI]
   Setmok [SAI1] With 0
   Setmok [SAI2] With 0
  When 3
   Local Inpbox Mask [SAI1]
&  Button LISBOUT(1..NBBOUT) With ABRBOUT(1..NBBOUT) Coded CODBOUT(1..NBBOUT)
&  Titled TIT
&   Folder Mask [SAI2] Titled mess(16,100,1)-"1"
&  ,Folder Mask [SAI3] Titled mess(16,100,1)-"2"
&  As [SAI]
   Setmok [SAI1] With 0
   Setmok [SAI2] With 0
   Setmok [SAI3] With 0
 Endcase
Endif
Boxact [SAI] : BOX=1
Onevent

ACT="DEBUT" : Gosub ACTION
REP = ""

$CHOI
OK=1
Gosub SETBOUT
If !OK : Goto FIN : Endif
Onevent AFTER_CHANGE Gosub APRES_MODIF
ACT="AV_CHOIX" : Gosub ACTION
Boxinp [SAI] Using REPONSE
Onevent AFTER_CHANGE
ACT="AP_CHOIX" : Gosub ACTION
Case REPONSE
 When GSTAESC, GSTAEND : Gosub ABORT
                         If OK : Goto FIN : endif   
 When GSTAENR : Gosub MODIF
 When GSTACRE : Gosub CREATION
 When GSTAFIN : Gosub ABANDON
 When GSTARET : If REP="M"
                 Gosub MODIF
                Else
                 Gosub CREATION
                Endif
 When GSTAANU : Gosub ANNUL
 When GSTACHG : ACT = "CHG"   : Gosub ACTION
 When GSTASUI : Gosub ABORT 
                If OK : ACT = "SUIV"  : Gosub ACTION : Endif
 When GSTAPRE : Gosub ABORT 
                If OK : ACT = "PREC"  : Gosub ACTION : Endif
 When GSTAFIR : Gosub ABORT 
                If OK : ACT = "PREM"  : Gosub ACTION : Endif
 When GSTALAS : Gosub ABORT 
                If OK : ACT = "DERN"  : Gosub ACTION : Endif
 When GSTALFT : Gosub ABORT 
                If OK : ACT = "GAU1"  : Gosub ACTION : Endif
 When GSTALF2 : Gosub ABORT 
                If OK : ACT = "GAU2"  : Gosub ACTION : Endif
 When GSTALF3 : Gosub ABORT 
                If OK : ACT = "GAU3"  : Gosub ACTION : Endif
 When GSTALF4 : Gosub ABORT 
                If OK : ACT = "GAU4"  : Gosub ACTION : Endif
 When GSTANEW : Gosub ABORT 
                If OK : ACT = "NOUV"  : Gosub ACTION : Endif
 When GSTARAF : Gosub ABORT 
                If OK : ACT = "RAF"   : Gosub ACTION : Endif
 When GSTASEL : ACT = "SELE"  : Gosub ACTION
 When GSTAEDI : ACT="EDI" : Gosub ACTION
                If REPORT1<>"" : Call IMPRIME(REPORT1,GFONCTION) From ETAT : Endif
 When GSTALIS : ACT="LIS" : Gosub ACTION
                If REPORT2<>"" : Call IMPRIME(REPORT2,GFONCTION) From ETAT : Endif
 When GSTAJOI : ACT = "JOI" : Gosub ACTION
 When GSTACOM : ACT = "COM" : Gosub ACTION
 When Default 
  If REPONSE>GSTABOU2   : I=REPONSE-GSTABOU2 
  Elsif REPONSE>GSTABOU : I=REPONSE-GSTABOU 
  Else I=0 
  Endif 
  If I
   SAVREP = REP
   If I>=1 & I<=NBTEX
    REP = CBOUT(I+STDBOUT)
    ACT = "BOUTON" : Gosub ACTION
   Else
    ACT = "STATUT" : Gosub ACTION
   Endif
   REP = SAVREP
  Endif
Endcase
Goto CHOI

$FIN
ACT="FIN" : Gosub ACTION
If BOX : Boxclr [SAI] : Endif
Call RESTBOUT From GESECRAN
GOBJET     = SAVOBJ
GPROGRAMME = SAVPROG
End

$SETBOUT
Raz ETABOU
Case REP
 When ""
  ETABOU(GSUPP) = 1
 When "M"
  ETABOU(GENRE) = 1
  ETABOU(GABAN) = 1
 When "C"
  ETABOU(GCREE) = 1
  ETABOU(GABAN) = 1
Endcase
For I=1 To NBTEX
 ETATEX(I) = 1
Next I
If instr(1,CHAINE,"E") : ETABOU(GEDIT)=1 : Endif
If instr(1,CHAINE,"L") : ETABOU(GLIST)=1 : Endif
ETABOU(GBFIN) = 1
ACT = "SETBOUT" : Gosub ACTION
Call SETBOUT(ETABOU) From GESECRAN
For I=1 To NBTEX
 If ETATEX(I)=1
  Enable GSTABOU2+I
 Else
  Disable GSTABOU2+I
 Endif
Next I
Return

$APRES_MODIF
Case REP
 When ""
  ACT="AV_MODIFICATION" : Gosub ACTION
  If !OK : Return : Endif
  Gosub SETBOUT
Endcase
Return

$ABANDON
ACT = "ABANDON" : Gosub ACTION
REP = ""
Return

$MODIF
ACT="AP_MODIFICATION" : Gosub ACTION
If OK
 REP = ""
Endif
Return

$CREATION
ACT="AP_CREATION" : Gosub ACTION
If OK
 REP = ""
Endif
Return

$ANNUL
ACT="ANNUL" : Gosub ACTION
If OK
 REP = ""
Endif
Return
 
$ABORT 
OK=2  
If find(REP,"C","D","M")  
 Call ABANDON(OK) From GESECRAN  
 If OK<>2 
  OK = 0 
 Endif 
Endif 
Return 

$ACTION
Gosub ACT From =TRAITEMENT
Return
