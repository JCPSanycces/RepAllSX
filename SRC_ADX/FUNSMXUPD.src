######################################################################################
## Etiquette ajoutée par le superviseur (écran SMXUPD1) 13/12/2012 10:28:59 (HCB)
######################################################################################
Subprog AM_BPSLOT(VALEUR)
Variable Char    VALEUR()
End


#                                                                                             # hcb 71276 deb
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Char    WECCVALMAJ(GLONECS)
Local Char    WECCVALMIN(GLONEVL)
Local Char    PITM(GLONITM)
Raz WECCVALMAJ
Raz WECCVALMIN
Raz PITM

# si version majeure trouvée et si article gere la version mineure : recherche derniere version mineure
If VALEUR  <> "" & [F:ITM]ECCSTO = 3
   WECCVALMAJ = VALEUR
   PITM = [F:ITM]ITMREF
   Gosub READECCMIN From STKACT
   [M:SUD1]ECCVALMIN = WECCVALMIN
   Affzo [M:SUD1]ECCVALMIN
Elsif VALEUR = "" & [M:SUD1]ECCVALMIN <> ""
      Raz   [M:SUD1]ECCVALMIN
      Affzo [M:SUD1]ECCVALMIN
Endif
[M:SUD1]ECCSTA = [F:ECS]ECCSTA
Affzo [M:SUD1]ECCSTA

End


I
######################################################################################
## Etiquette ajoutée par le superviseur (écran SMXUPD1) 23/06/2015 14:38:29 (HCB)
######################################################################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
If [F:ITM]ECCSTO < 2
   mkstat = 2
Endif
End


Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
If [F:ITM]ECCSTO <> 3
   mkstat = 2
Endif
If [M:SUD1]ECCVALMAJ = ""
   mkstat = 2
Endif
End


