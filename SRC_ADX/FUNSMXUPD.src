#<AdxTL>@(#)10.0.0.0 $Revision$
#########################################################################
#                                                                       #
# ACTION  : TRTSMXUPD  : Action traitement de modif caract. lot         #
#                                                                       #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"       : Gosub INIT
 When "TITRE"      : Gosub TIT_TRT
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "FIN_LISTE"  : Gosub FIN_LISTE
 When "CONTROLE"   : Gosub CONTROLE
 When "TERMINE"    : Gosub TERMINE
 When "SETBOUT"    : Gosub SETBOUT
 When "OUVRE"      : Gosub OUVRE
 When "AVANT_OK"   : Gosub AVANT_OK
 When "DEBUT"      : Gosub DEBUT
 When "APRES_MODIF": Gosub APRES_MODIF
 When "ENR"        : Gosub ENREGISTRE
 When "ABA"        : Gosub ABORT
 When "FIN"        : Gosub FIN
 When Default
Endcase
Return

#########################################################################
$TIT_TRT
    Call LECTEXTRA(TIT,"STKTRS","DESAXX","4",GSMXNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-GSMXNUM-":"-TIT
Return

#########################################################################
$SEL_LISTE
Local Char    TABACS(10)(100)
Local Integer NBACS
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX
Local Char    CRITERE(250)

If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif
If clalev([F:SRT])=0 : Local File STKTRS [SRT] : Endif

CRITERE = "SRTTYP=4 & CHANGECOD=1&ENAFLG=2"

If GPROFIL<>GSUPER
  For [ACC]CODACC Where USR=GUSER
    If [F:ACC]EXEC=2
      [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1)
      NBACS +=1
    Endif
    If NBACS>99 Break Endif
  Next
  CRITERE += "&(ACSCOD=''|find(ACSCOD,TABACS(0..99)))"
Endif

If GFLAG=""
    Filter [SRT] Where evalue(CRITERE)
    If rowcount([SRT])=1
        Read [SRT] First
        If !fstat
            GFLAG=[F:SRT]SRTNUM
        Endif
    Endif
    Filter [SRT]
Endif
If GFLAG<>""
    Filter [SRT] Where evalue(CRITERE)
    Read [SRT]SRT0=4;GFLAG
    Filter [SRT]
    If !fstat
        If dim(GSMXNUM)<=0
            Global Char    GSMXNUM(GLONTRS)
        Endif
        GSMXNUM= [F:SRT]SRTNUM
        OK=0
    Endif
Endif
If GSMXNUM=""
    For [F:SRT] Where evalue(CRITERE)
        NBTEX+= 1
        TEX(NBTEX)   =[F:SRT]SRTNUM
        Call LECTEXTRA(TEXTE(NBTEX),"STKTRS","DESAXX",num$([F:SRT]SRTTYP),[F:SRT]SRTNUM) From ATEXTRA
        TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
    Next
    TIT(0) = mess(3,126,1) # Choix transactions
Endif
Return

$FIN_LISTE
GSMXNUM = VALEUR
Return

#########################################################################
$CONTROLE
Case GACTION
 When "TRTSMXUPD"   : Gosub CONTROLE_TRTSMXUPD
 When "SAISMXUPD"   : # pas d'action
Endcase
Return

#########################################################################
$INIT
Case GACTION
 When "TRTSMXUPD"   : Gosub INI_TRTSMXUPD
 When "SAISMXUPD"   : Gosub INI_SAISMXUPD
Endcase
Return

#########################################################################
$OUVRE
Case GACTION
 When "TRTSMXUPD"   : Gosub OUVRE_TRTSMXUPD
 When "SAISMXUPD"   : Gosub OUVRE_SAISMXUPD
Endcase
Return

#########################################################################
$SETBOUT
Case GACTION
 When "TRTSMXUPD"   : # pas d'action
 When "SAISMXUPD"   : Gosub SETBOUT_SAISMXUPD
Endcase
Return

#########################################################################
$DEBUT
Case GACTION
 When "TRTSMXUPD"   : Gosub DEBUT_TRTSMXUPD
 When "SAISMXUPD"   : Gosub DEBUT_SAISMXUPD
Endcase
Return

#########################################################################
$AVANT_OK
Case GACTION
 When "TRTSMXUPD"  : Gosub AVANT_OK_TRTSMXUPD
Endcase
Return

#########################################################################
$APRES_MODIF
Case GACTION
 When "SAISMXUPD"   : Gosub AM_SAISMXUPD
Endcase
Return

#########################################################################
$ENREGISTRE
Case GACTION
 When "SAISMXUPD"   : Gosub ENR_SAISMXUPD
Endcase
Return

#########################################################################
$ABORT
Case GACTION
 When "SAISMXUPD"   : Gosub ABORT_SAISMXUPD
Endcase
Return

#########################################################################
$TERMINE
Case GACTION
 When "SAISMXUPD"   : Gosub TERMINE_SAISMXUPD
Endcase
Return

#########################################################################
$FIN
Case GACTION
 When "TRTSMXUPD"   : Gosub FIN_TRTSMXUPD
 When "SAISMXUPD"   : Gosub FIN_SAISMXUPD
Endcase
GFEALOTLEV  = GWFEALOTLEV                           # hcb 71276

Return

#------------------------------------------------------------------------
# Action TRTSMXUPD (critères modif série)
#------------------------------------------------------------------------
#########################################################################
$INI_TRTSMXUPD
Global Char    GSMXNUM(GLONTRS)
Global Integer GSHLUOM
Global Integer GSHLLTIUOM
Raz GSHLUOM
Raz GSHLLTIUOM
GSMXNUM = ""
Return

#########################################################################
$CONTROLE_TRTSMXUPD
If GSMXNUM = "" : FIN = 1 : Endif
Return

#########################################################################
$OUVRE_TRTSMXUPD
#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:STL]) = 0 : Local File STOLOT     [STL]      : Endif
If clalev([F:SLF]) = 0 : Local File STOLOTFCY  [SLF]      : Endif   # Pour calcul qté lot sur site
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM]      : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF]      : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY]      : Endif
If clalev([F:SRT]) = 0 : Local File STKTRS     [SRT]      : Endif
If !clalev([ECS])      : Local File ECCSTA     [ECS]      : Endif   # hcb 71276
If !clalev([EVL])      : Local File ECCVAL     [EVL]      : Endif   # hcb 71276


# substitution fenêtre
BOITE     = "WDSMX"+GSMXNUM
WMASQUE   = "WT4"+GSMXNUM+"D"
Gosub CHANGE_AWI

#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 4 | [F:SRT]SRTNUM <> GSMXNUM
    Read [SRT]SRT0=4;GSMXNUM : If fstat Raz [F:SRT] : Endif
Endif
Return

#########################################################################
$DEBUT_TRTSMXUPD
Raz [M:SUD1]
[M:SUD1]STOFCY    = GFCYDEF(7)
GFCY              = GFCYDEF(7)
Gosub CHARG_PARAM

[M:SUD1]TRSFAM    = [F:SRT]TRSFAMDEF
[M:SUD1]SHLUOM    = 1
[M:SUD1]SHLLTIUOM = 1
# [M:SUD1]DLU       = 1  # hcb 75934
Global Integer GWFEALOTLEV                          # hcb 71276
GWFEALOTLEV  = GFEALOTLEV                           # hcb 71276

Affzo [M:SUD1]1-99
If dim([M:SUD1]SLOSTR)>0                                                 # hcb unicite
   If GFEALOTLEV = 2                                                     # hcb unicite
      Local Char WINVSLO                                                 # hcb unicite
      WINVSLO="-K:"+num$(GLONSLO)+"X"                                    # hcb unicite
      Chgfmt [M:SUD1]SLOSTR  With WINVSLO                                # hcb unicite
      Chgfmt [M:SUD1]SLOEND  With WINVSLO                                # hcb unicite
   Endif                                                                 # hcb unicite
Endif                                                                    # hcb unicite

Return

#########################################################################
$AVANT_OK_TRTSMXUPD
FIN = 0
If [M:SUD1]ITMREFSTR = "" &
&  [M:SUD1]ITMREFEND = "" &
&  [M:SUD1]LOTSTR    = "" &
&  [M:SUD1]LOTEND    = "" &
&  [M:SUD1]SLOSTR    = "" &
&  [M:SUD1]SLOEND    = ""
   GERR = 3
   GMESSAGE = mess(64,190,1)
   Return
Endif

Return

#########################################################################
$FIN_TRTSMXUPD
Return

#------------------------------------------------------------------------
# Action SAISMXUPD (modif série)
#------------------------------------------------------------------------
#########################################################################
$INI_SAISMXUPD
#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:STL]) = 0 : Local File STOLOT     [STL]      : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM]      : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF]      : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV]      : Endif
If clalev([F:ITG]) = 0 : Local File ITMCATEG   [ITG]      : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY]      : Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO]      : Endif
If !clalev([ECS])      : Local File ECCSTA     [ECS]      : Endif   # hcb 71276
If !clalev([EVL])      : Local File ECCVAL     [EVL]      : Endif   # hcb 71276
Return

#########################################################################
$TERMINE_SAISMXUPD

TRA=1
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

Return


#########################################################################
$SETBOUT_SAISMXUPD

Raz ETABOU
ETABOU(GENRE) = 1
ETABOU(GABAN) = 1
ETABOU(GBFIN) = 1
Return


#########################################################################
$OUVRE_SAISMXUPD
Local Char     LITMSTR    : LITMSTR = PARAM      (1)
Local Char     LITMEND    : LITMEND = PARAM      (2)
Local Char     LLOTSTR    : LLOTSTR = PARAM      (3)
Local Char     LLOTEND    : LLOTEND = PARAM      (4)
Local Char     LSLOSTR    : LSLOSTR = PARAM      (5)
Local Char     LLSLOEND   : LSLOEND = PARAM      (6)
Local Decimal  LPOT       : LPOT    = val(PARAM  (7))
Local Char     CREFPER    : CREFPER = PARAM      (8)
Local Date     LREFPER
Local Integer  LSHL       : LSHL    = val(PARAM  (9))
Local Char     CSHLDAT    : CSHLDAT = PARAM      (10)
Local Date     LSHLDAT
Local Char     LUSRFLD1   : LUSRFLD1 = PARAM     (11)
Local Char     LUSRFLD2   : LUSRFLD2 = PARAM     (12)
Local Decimal  LUSRFLD3   : LUSRFLD3 = val(PARAM (13))
Local Char     CUSRFLD4   : CUSRFLD4 = PARAM     (14)
Local Date     LUSRFLD
Local Char     CIPTDAT    : CIPTDAT  = PARAM     (15)
Local Date     LIPTDAT
Local Char     LMVTDES    : LMVTDES  = PARAM     (16)
Local Char     LPJT       : LPJT     = PARAM     (17)
Local Char     LTRSFAM    : LTRSFAM  = PARAM     (18)
Local Char     LFCY       : LFCY     = PARAM     (19)
Local Char     LSMXNUM    : LSMXNUM  = PARAM     (20)

Local Char     LBPSLOT
Raz LBPSLOT
If dim([M:SUD1]BPSLOT) > 0
   LBPSLOT  = [M:SUD1]BPSLOT
Endif
#                                                      # hcb 71276 deb
Local Char    LMAJ(GLONECS)
Local Char    LMIN(GLONEVL)
Raz LMAJ
Raz LMIN
If dim([M:SUD1]ECCVALMAJ) > 0
   LMAJ  = [M:SUD1]ECCVALMAJ
Endif
If dim([M:SUD1]ECCVALMIN) > 0
   LMIN  = [M:SUD1]ECCVALMIN
Endif
#                                                      # hcb 71276 fin

Local Char     FILSTL(250)(3)
Local Char     WMESS(80), WMESS1(80), WCLE(80)
Local Integer  I , J, LRET
Local Integer  NBMODIF, OK, WIND

If clalev([F:SLH]) <= 0 : Local File SLOTMH     [SLH]  : Endif
If clalev([M:STW]) <= 0 : Local Mask STOWORK    [STW]  : Endif
If clalev([M:STWX])<= 0 : Local Mask STOWORK    [STWX] : Endif
If clalev([F:STOL])<= 0 : Local File STOCK      [STOL] : Endif
If !clalev([M:SVW])     : Local Mask STOVALWORK [SVW]  : Endif
If !clalev([M:SDPA])    : Local Mask SAIDECPRI  [SDPA] : Endif
#--- Bug 77900
If !clalev([F:STA])     : Local File STOALL     [STA]  : Endif
If !clalev([ECS])      : Local File ECCSTA     [ECS]   : Endif   # hcb 71276
If !clalev([EVL])      : Local File ECCVAL     [EVL]   : Endif   # hcb 71276

# hcb 75934 deb
Local Decimal  LDLU
Local Char     CDLUDAT
Local Date     LDLUDAT
Local Integer  LSHLLTI
Local Char     CNEWLTIDAT
Local Date     LNEWLTIDAT
If !clalev([M:SUD1])
   Raz LDLU
   Raz CDLUDAT
   Raz LDLUDAT
   Raz CSHLLTI
   Raz LNEWLTIDAT
Else
   LDLU       = [M:SUD1]DLU
   CDLUDAT    = [M:SUD1]DLUDAT
   LSHLLTI    = [M:SUD1]SHLLTI
   CNEWLTIDAT = [M:SUD1]NEWLTIDAT
Endif
# hcb 75934 fin


# substitution fenêtre
BOITE     = "WFSMX"+GSMXNUM
WMASQUE   = "WT4"+GSMXNUM+"F"
Gosub CHANGE_AWI

# hcb 75934 deb
If CDLUDAT <> ""
    If instr(1,CDLUDAT,"/")
        LDLUDAT = "["+CDLUDAT+"]"
    Else
        LDLUDAT = CDLUDAT
    Endif
Endif
If CNEWLTIDAT <> ""
    If instr(1,CNEWLTIDAT,"/")
        LNEWLTIDAT = "["+CNEWLTIDAT+"]"
    Else
        LNEWLTIDAT = CNEWLTIDAT
    Endif
Endif
# hcb 75934 fin



If CREFPER <> ""
    If instr(1,CREFPER,"/")
        LREFPER = "["+CREFPER+"]"
    Else
        LREFPER = CREFPER
    Endif
Endif
If CSHLDAT <> ""
    If instr(1,CSHLDAT,"/")
        LSHLDAT = "["+CSHLDAT+"]"
    Else
        LSHLDAT = CSHLDAT
    Endif
Endif
If CUSRFLD4 <> ""
    If instr(1,CUSRFLD4,"/")
        LUSRFLD4 = "["+CUSRFLD4+"]"
    Else
        LUSRFLD4 = CUSRFLD4
    Endif
Endif
If CIPTDAT <> ""
    If instr(1,CIPTDAT,"/")
        LIPTDAT = "["+CIPTDAT+"]"
    Else
        LIPTDAT = CIPTDAT
    Endif
Endif
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 4 | [F:SRT]SRTNUM <> LSMXNUM
    Read [SRT]SRT0=4;LSMXNUM : If fstat Raz [F:SRT] : Endif
Endif

# récupération des codes compteur et effacement fichier de travail
If clalev ([F:TCA]) <= 0 : Local File TABCOUAFF [TCA] : Endif
If clalev ([F:ANM]) <= 0 : Local File ACODNUM   [ANM] : Endif


# compteur module stock
Call LECTCA(7,OK) From SUBTCA
If !OK
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1 : FIN = 1
   Return
Endif
GSTKCPTMAN(5)=[F:TCA]MANCOU(5) # compteur modif lot
GSTKCPT(5)   =[F:TCA]CODNUM(5)

Read [ANM]ANM0 = GSTKCPT(5)
If fstat
    GMESSAGE = mess(242,199,1)
    GERR = 1
    FIN = 1
    Return
Endif
# controle compteur pièce modif lot
Call CTRCPT(GSTKCPT(5), [F:ANM]LNG+10, LRET) From STKLIB
If LRET <> 0
    GMESSAGE = mess(242,199,1)
    GERR = 1
    FIN = 1
    Return
Endif



Gosub SEL_LOT
Return


#########################################################################
$SEL_LOT
#--> critères de saisie
Raz FILSTL, I
FILSTL = "1=1"

# article
If LITMSTR <> ""
   Call ADDCRIT(FILSTL,I,"",'[F:STL]ITMREF>="'+LITMSTR+'"',"&") From GOBJSUB
Endif
If LITMEND <> ""
   Call ADDCRIT(FILSTL,I,"",'[F:STL]ITMREF<="'+LITMEND+'"',"&") From GOBJSUB
Endif

# lot
If LLOTSTR <> ""
   Call ADDCRIT(FILSTL,I,"",'[F:STL]LOT>="'+LLOTSTR+'"',"&") From GOBJSUB
Endif
If LLOTEND <> ""
   Call ADDCRIT(FILSTL,I,"",'[F:STL]LOT<="'+LLOTEND+'"',"&") From GOBJSUB
Endif

# sous-lot
If LSLOSTR <> ""
   Call ADDCRIT(FILSTL,I,"",'[F:STL]SLO>="'+LSLOSTR+'"',"&") From GOBJSUB
Endif
If LSLOEND <> ""
   Call ADDCRIT(FILSTL,I,"",'[F:STL]SLO<="'+LSLOEND+'"',"&") From GOBJSUB
Endif

Return


#########################################################################
$DEBUT_SAISMXUPD

Local Char    TIT(50) :  TIT =  mess(241,195,1)
Local Integer WTSTFCY

Default File [STL]
Default Mask [SUD2]

Local Integer WMAX : WMAX = dim([M:SUD2]ITMREF)
Gosub LIRE
If [M:SUD2]NBLIG=0
    GERR=2 : GMESSAGE=mess(587,197,1)
    FIN=1
Endif



Return

#########################################################################
$LIRE
REP="" : GREP=""
Raz [M:SUD2]
nolign=0
Local Char WRUPTST(GLONITM+GLONLOT)    # hcb unicite
Local Char WRUPLEC(GLONITM+GLONLOT)    # hcb unicite
Local Char WFILTRE(250)                # hcb unicite
If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif

If LFCY=""
    [M]ALLSTOFCY=2
Else
    [M]ALLSTOFCY=1
    [M]STOFCY = LFCY
    Call LECTURE("FCY",[M:SUD2]STOFCY,"") From CONTOBJ
    [M]FCYDES = [F:FCY]FCYNAM
Endif

WTSTFCY=1
For [STL]STL0  Where evalue(FILSTL)
#                                                    # hcb unicite deb
    WFILTRE = "LOT = [F:STL]LOT & SLO = [F:STL]SLO"
    If GFEALOTLEV = 2
       If [F:ITM]ITMREF   <> [F:STL]ITMREF
          Read [F:ITM]ITM0=  [F:STL]ITMREF
          If fstat
             Raz [F:ITM]
          Endif
       Endif
       If [F:ITM]LOTMGTCOD=4
          WRUPLEC =  [F:STL]ITMREF+[F:STL]LOT
          If WRUPTST <> WRUPLEC
             WRUPTST = WRUPLEC
             WFILTRE = "LOT = [F:STL]LOT"
          Else
             Goto NXT_STL
          Endif
       Endif
    Endif
#                                                    # hcb unicite fin

    Gosub CHECK_STO
    If WIND : Goto NXT_STL : Endif
    nolign += 1
    If nolign = WMAX : Break : Endif
    [M:SUD2] = [F:STL]
    Gosub FILL_LINE
$NXT_STL
Next

If GFEALOTLEV = 2                                                        # hcb unicite
   Local Char WINVSLO                                                    # hcb unicite
   WINVSLO="-K:"+num$(GLONSLO)+"X"                                       # hcb unicite
   Chgfmt [M:SUD2]SLO  With WINVSLO                                      # hcb unicite
Endif                                                                    # hcb unicite


If nolign = WMAX : Call MESSAGE(mess(168,190,1)) From GESECRAN: Endif

[M:SUD2]NBLIG = nolign
Diszo [M:SUD2]5
Affzo [M:SUD2]1-99

Return

#########################################################################
$CHECK_STO
WIND = 0
# exclusion lots blancs (?)
If [F:STL]LOT = ""
    WIND = 1 : Return
Endif
If GFEALOTLEV = 2 & [F:ITM]LOTMGTCOD=4                                         # hcb unicite
   If func STKLIB.QTYLOT([F:STL]ITMREF,[F:STL]LOT,"",[M:SUD2]STOFCY)=0         # hcb unicite
      WIND = 1 : Return                                                        # hcb unicite
   Endif                                                                       # hcb unicite
Else                                                                           # hcb unicite
   If func STKLIB.QTYLOT([F:STL]ITMREF,[F:STL]LOT,[F:STL]SLO,[M:SUD2]STOFCY)=0
      WIND = 1 : Return
   Endif
Endif                                                                          # hcb unicite
# ces 2 lignes remplacées par evalue(wfiltre)                                  # hcb unicite
#                         LOT    = [F:STL]LOT     &
#                         SLO    = [F:STL]SLO

# vérification stock
If [M:SUD2]STOFCY<>""
    For [F:STO]STO3 Where ITMREF = [F:STL]ITMREF  &
&                         STOFCY = [M:SUD2]STOFCY &
&                         evalue(WFILTRE)
        If [F:STO]CUMALLQTY <> 0  : WIND = 1 : Break : Endif
        If [F:STO]QLYCTLDEM <> "" : WIND = 2 : Break : Endif
        If [F:STO]CUMWIPQTY <> 0  : WIND = 3 : Break : Endif
        #                                                 # hcb 110327 deb
        If [F:ITM]SERMGTCOD = 4
           Call VERIF_DESYNCHRO_SERIE([F:STO]ITMREF,[F:STO]STOCOU,[F:STO]QTYSTU,WIND) From STKLIB
           If WIND = 2
              WIND = 5
              Break
           Endif
        Endif
 #                                                 # hcb 110327 fin
    Next
    If WIND=0 & WTSTFCY=1
        # Ce lot a t-il du stock sur d'autres sites ?
        For [F:STO]STO3 Where ITMREF = [F:STL]ITMREF  &
&                             STOFCY <>[M:SUD2]STOFCY &
&                             evalue(WFILTRE)
            WIND = 4 : Break
        Next
    Endif
Else
    For [F:STO]STO3 Where ITMREF = [F:STL]ITMREF  &
&                         evalue(WFILTRE)
        If [F:STO]CUMALLQTY <> 0  : WIND = 1 : Break : Endif
        If [F:STO]QLYCTLDEM <> "" : WIND = 2 : Break : Endif
        If [F:STO]CUMWIPQTY <> 0  : WIND = 3 : Break : Endif
    Next
Endif

#--- Dem 77583
#--- Pour modifier la valeur de WIND
GPOINT="CTL_LOT" : Gosub ENTREE From EXEFNC

Return

#########################################################################
$FILL_LINE
Local Integer WSTOMGTCOD
Local    Integer  WLTI


If [F:ITM]ITMREF   <> [F:STL]ITMREF
    Read [ITM]ITM0 =  [F:STL]ITMREF
    If fstat : Raz [ITM] : Endif
Endif
WSTOMGTCOD = [F:ITM]STOMGTCOD

# vérification stock
If [M:SUD2]STOFCY<>"" & [F:ITM]STOMGTCOD > 1
#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
   If [F:ITF]STOFCY <> [M:SUD2]STOFCY | [F:ITF]ITMREF <> [F:ITM]ITMREF
      Read [ITF]ITF0 = [F:ITM]ITMREF;[M:SUD2]STOFCY
      If fstat
         Raz [F:ITF]
      Endif
   Endif
   WSTOMGTCOD = [F:ITF]STOMGTCOD
Endif

#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 4 | [F:SRT]SRTNUM <> GSMXNUM                   # hcb 50197
    Read [SRT]SRT0=4;GSMXNUM : If fstat Raz [F:SRT] : Endif
Endif

# si titre saisi et article géré avec titre
If dim([M:SUD2]POT) > 0 & [F:SRT]POTCOD = 1 & LPOT <> 0 & WSTOMGTCOD = 3
    [M:SUD2]POT(nolign-1) = LPOT
Endif

# si péremption saisie et article géré avec péremption
# hcb v6per deb
# hcb 75934
If [F:ITM]EXYMGTCOD > 1 & dim([M:SUD2]REFPER)>0
    If [F:SRT]PERCOD = 1 & LREFPER           <> [0/0/0]    : [M:SUD2]REFPER    (nolign-1) = LREFPER            : Endif
    If [F:SRT]PERCOD = 1 & LSHL              <> 0          : [M:SUD2]SHL       (nolign-1) = LSHL               : Endif
    If [F:SRT]PERCOD = 1 & LSHLDAT           <> [0/0/0]    : [M:SUD2]SHLDAT    (nolign-1) = LSHLDAT            : Endif
    If [F:SRT]PERCOD = 1 & [M:SUD1]SHLDAT    <> [0/0/0]    : [M:SUD2]SHLDAT    (nolign-1) = [M:SUD1]SHLDAT     : Endif
    If [F:SRT]PERCOD = 1 & GSHLUOM           <> 0          : [M:SUD2]SHLUOM    (nolign-1) = GSHLUOM            : Endif
    If [F:SRT]PERCOD = 1 & LDLU              <> 0          : [M:SUD2]DLU       (nolign-1) = LDLU               : Endif
    If [F:SRT]PERCOD = 1 & LDLUDAT           <> [0/0/0]    : [M:SUD2]DLUDAT    (nolign-1) = LDLUDAT            : Endif
    If [F:SRT]PERCOD = 1 & LSHLLTI           <> 0          : [M:SUD2]SHLLTI    (nolign-1) = LSHLLTI            : Endif
    If [F:SRT]PERCOD = 1 & GSHLLTIUOM        <> 0          : [M:SUD2]SHLLTIUOM (nolign-1) = GSHLLTIUOM         : Endif
    If [F:SRT]PERCOD = 1 & LNEWLTIDAT        <> [0/0/0]    : [M:SUD2]NEWLTIDAT (nolign-1) = LNEWLTIDAT        : Endif
    If LSHLDAT       = [0/0/0] & (LREFPER <> [0/0/0] | LSHL <> 0 | GSHLUOM <> 0)
        Call CALPER([F:ITM]EXYMGTCOD, [M:SUD2]REFPER(nolign-1), [M:SUD2]SHL(nolign-1) ,[M:SUD2]SHLUOM(nolign-1),"", [M:SUD2]SHLDAT(nolign-1)) From STKLIB
    Endif
    If LNEWLTIDAT  = [0/0/0] & (LREFPER <> [0/0/0] | LSHLLTI   <> 0 |  GSHLLTIUOM  <> 0)
        Call CALLTI([F:ITM]EXYMGTCOD, [M:SUD2]REFPER(nolign-1), [M:SUD2]SHLLTI(nolign-1) ,[M:SUD2]SHLLTIUOM(nolign-1),"", [M:SUD2]NEWLTIDAT (nolign-1)) From STKLIB
    Endif
#                                                                                           # hcb dlu deb
    If [F:ITM]EXYMGTCOD = 1 | [F:ITM]EXYMGTCOD= 3 | [F:ITM]EXYMGTCOD= 4
       [M:SUD2]DLU       (nolign-1)   = 1
       [M:SUD2]DLUDAT    (nolign-1)   = LSHLDAT
       Raz [M:SUD2]DLULTI(nolign-1)
    Else
#                                                                                           # hcb dlu fin
       If LDLUDAT = [0/0/0] & (LREFPER <> [0/0/0] | LDLU <> 0 | GSHLUOM <> 0)
          Call CALDLU([F:ITM]EXYMGTCOD, [M:SUD2]REFPER(nolign-1), [M:SUD2]SHLDAT(nolign-1) ,[M:SUD2]DLU(nolign-1),"", [M:SUD2]DLUDAT(nolign-1) ,WLTI) From STKLIB
          [M:SUD2]DLULTI(nolign-1) = WLTI
       Else
          [M:SUD2]DLULTI(nolign-1) = nday([M:SUD2]DLUDAT(nolign-1)) -nday([M:SUD2]REFPER(nolign-1))
       Endif
    Endif                                                                                   # hcb dlu
# hcb v6per deb

Endif

# zones utilisateur
If [F:SRT]SRUB1FLG  = 2 & LUSRFLD1 <> ""      : [M:SUD2]USRFLD1(nolign-1) = LUSRFLD1  : Endif
If [F:SRT]SRUB2FLG  = 2 & LUSRFLD2 <> ""      : [M:SUD2]USRFLD2(nolign-1) = LUSRFLD2  : Endif
If [F:SRT]SRUB3FLG  = 2 & LUSRFLD3 <>  0      : [M:SUD2]USRFLD3(nolign-1) = LUSRFLD3  : Endif
If [F:SRT]SRUB4FLG  = 2 & LUSRFLD4 <> [0/0/0] : [M:SUD2]USRFLD4(nolign-1) = LUSRFLD4  : Endif

If LIPTDAT          <>    [0/0/0]             : [M:SUD2]IPTDAT (nolign-1) = LIPTDAT   : Endif
If [F:SRT]PJTCOD    = 1 & LPJT    <> ""       : [M:SUD2]PJT    (nolign-1) = LPJT      : Endif
If [F:SRT]TRSFAMCOD = 1 & LTRSFAM <> ""       : [M:SUD2]TRSFAM (nolign-1) = LTRSFAM   : Endif
If [F:SRT]MVTDESCOD = 1 & LMVTDES <> ""       : [M:SUD2]MVTDES (nolign-1) = LMVTDES   : Endif

If [F:ITM]LOTMGTCOD=4 & GFEALOTLEV = 2           # hcb unicite
   [M:SUD2]WFEA (nolign-1)         = 2           # hcb unicite
Endif                                            # hcb unicite

# si lot fournisseur saisi
If dim([M:SUD2]BPSLOT) > 0 & [F:SRT]BPSLOTCOD = 1 & LBPSLOT    <> ""
   [M:SUD2]BPSLOT    (nolign-1) = LBPSLOT
Endif
#                                                           # hcb 71276 deb
# si versions saisies
If dim([M:SUD2]ECCVALMAJ) > 0 & [F:SRT]ECCCOD = 2 & LMAJ    <> ""
   [M:SUD2]ECCVALMAJ    (nolign-1) = LMAJ
Endif
If dim([M:SUD2]ECCVALMIN) > 0 & [F:SRT]ECCCOD = 2 & LMIN    <> ""
   [M:SUD2]ECCVALMIN    (nolign-1) = LMIN
Endif
#                                                           # hcb 71276 fin

Return

#########################################################################
$AM_SAISMXUPD

# Pour interdire la navigation
GREP="M"
REP ="M"
Gosub SETBOUT

Return

#########################################################################
$ENR_SAISMXUPD
OK =1
Call OUINON(mess(20,196,1), OK) From GESECRAN
If OK<> 2  : FIN = 0 :  GERR = 2 : Return : Endif

Gosub MODIF
FIN=1
GERR=2
GMESSAGE=mess(363,197,1)

Return

#########################################################################
$MODIF
# Enregistrement des modifications

Call TEMPON("V") From GESECRAN
If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif
Gosub MODLOT
If !NBMODIF
    WMESS1=mess(371,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Endif

Call TEMPOFF From GESECRAN
Return

#########################################################################
$MODLOT

Gosub MAJLOT
If NBMODIF
    Call ECR_TRACE(" ",0) From GESECRAN
    WMESS1=num$(NBMODIF)-mess(362,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Endif
Return

#########################################################################
$MAJLOT
Local Integer I,J, LRET
Local Integer LSTAT, WMAJLOT_FCY
Local Char    LNUM
Local Char    LUSCAV
Local Char    LFMT
Local Integer LMODIF
Local Decimal LCOE
Local Char    LSTOFCY(GLONFCY)
Local Char    WFILTRE(250)   # hcb unicite
#--- Bug 77900
Local Decimal WCUM(300,5)

NBMODIF=0

# chargement des lignes à sortir
Raz [STW]
Raz [M:STW]NBLIG
Raz [STWX]
Raz [M:STWX]NBLIG
GOK = 1
Call DEBTRANS From GLOCK    # hcb 69317
Trbegin [STL]               # hcb 69317

For J=0 To [M:SUD2]NBLIG - 1

    Raz WMAJLOT_FCY
    # Tous les sites
    If [M:SUD2]ALLSTOFCY=2
        Raz LSTOFCY
        If [M:SUD2]WFEA(J) = 2                                               # hcb unicite
           WFILTRE = "LOT    = [M:SUD2]LOT(J)"                               # hcb unicite
        Else                                                                 # hcb unicite
           WFILTRE = "LOT    = [M:SUD2]LOT(J) & SLO    = [M:SUD2]SLO(J)"     # hcb unicite
        Endif                                                                # hcb unicite
        For [F:STOL]STO3 Where ITMREF = [M:SUD2]ITMREF(J)  &
&                              evalue(WFILTRE)
            If [F:STOL]STOFCY<>LSTOFCY
                LSTOFCY = [F:STOL]STOFCY
                WMAJLOT_FCY +=1
                Gosub MAJLOT_FCY
                If GERR | !GOK Break 2 Endif
                If WIND Break Endif
            Endif
        Next
        If WIND Goto NXT_LINE Endif
    # Le site saisi
    Else
        LSTOFCY = [M:SUD2]STOFCY
        WMAJLOT_FCY +=1
        Gosub MAJLOT_FCY
        If GERR | !GOK Break Endif
        If WIND Goto NXT_LINE Endif
    Endif

# controle que tous les lot/souslot soient correctes dans le cas "niveaux lot"                         # hcb unicite
    If [F:ITM]LOTMGTCOD = 4 & GFEALOTLEV = 2  & GOK                                                  # hcb unicite  deb

       Update [STL] Where ITMREF = [F:SLH]ITMREF & LOT = [F:SLH]LOT  &
&          (POT     <> [F:SLH]POT     | REFPER    <> [F:SLH]REFPER    | SHL       <> [F:SLH]SHL       | SHLDAT  <> [F:SLH]SHLDAT |
&           SHLUOM  <> [F:SLH]SHLUOM  | DLU       <> [F:SLH]DLU       | DLUDAT    <> [F:SLH]DLUDAT    | BPSLOT  <> [F:SLH]BPSLOT |
&           SHLLTI  <> [F:SLH]SHLLTI  | SHLLTIUOM <> [F:SLH]SHLLTIUOM | NEWLTIDAT <> [F:SLH]NEWLTIDAT |
&           USRFLD1 <> [F:SLH]USRFLD1 | USRFLD2   <> [F:SLH]USRFLD2   | USRFLD3   <> [F:SLH]USRFLD3   | USRFLD4 <>[F:SLH]USRFLD4)
&      With USRFLD1   = [F:SLH]USRFLD1,   USRFLD2 = [F:SLH]USRFLD2, USRFLD3 = [F:SLH]USRFLD3, USRFLD4   = [F:SLH]USRFLD4,
&           REFPER    = [F:SLH]REFPER,    SHL     = [F:SLH]SHL,     SHLDAT  = [F:SLH]SHLDAT,  SHLUOM    = [F:SLH]SHLUOM,
&           DLU       = [F:SLH]DLU,       DLUDAT  = [F:SLH]DLUDAT,  SHLLTI  = [F:SLH]SHLLTI,  SHLLTIUOM = [F:SLH]SHLLTIUOM,
&           NEWLTIDAT = [F:SLH]NEWLTIDAT, POT     = [F:SLH]POT , BPSLOT = [F:SLH]BPSLOT
          If fstat
             GMESSAGE-=mess(50,176,1)
             Raz GOK
          Break
       Endif
    Endif
#                                                                                                  # hcb unicite fin
$NXT_LINE
Next J

#              hcb 69317  deb
If GERR | !GOK
   Raz NBMODIF
   Rollback
Else
   Commit
Endif
#              hcb 69317  fin


Return

#########################################################################
$MAJLOT_FCY
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 4 | [F:SRT]SRTNUM <> GSMXNUM                   # hcb 50197
    Read [SRT]SRT0=4;GSMXNUM : If fstat Raz [F:SRT] : Endif
Endif

If [F:ITM]ITMREF <> [M:SUD2]ITMREF(J) | [F:ITF]STOFCY <> LSTOFCY
   Call LECITM2( LSTOFCY, [M:SUD2]ITMREF(J), "", LRET ) From STKLIB
Endif

# génération du document
Gosub GEN_SLM
If GERR=1  FIN=1 : Return Endif
If WIND    Return  Endif

# lecture du stock
XCRITERE  = "STOFCY=LSTOFCY"
XCRITERE += "&ITMREF=[M:SUD2]ITMREF(J)"
XCRITERE += "&LOT=[M:SUD2]LOT(J)"

# si article géré avec s/lot
If [F:ITM]LOTMGTCOD=4 & dim([M:SUD2]SLO)>0 & GFEALOTLEV = 1 : XCRITERE += "&SLO=[M:SUD2]SLO(J)" : Endif   # hcb unicite

For [F:STO]STO3 Where evalue(XCRITERE)

   #--- Bug 77900
   WCUM(I,0) = [F:STO]CUMALLQTY
   WCUM(I,1) = [F:STO]CUMALLQTA
   WCUM(I,2) = [F:STO]CUMWIPQTY
   WCUM(I,3) = [F:STO]CUMWIPQTA
   WCUM(I,4) = [F:STO]STOCOU
   I+=1
   If I>299 : Raz GOK : Break : Endif
   #---
#                                              # hcb 110327 deb

  If [F:ITM]SERMGTCOD = 4
      Gosub  RECH_SERIES_GLOBALE From SUBSMXA
   Else
   #                                              # hcb 110327 fin
      Call ADDSTOWORKLIN("C", "S", [F:STO]STOFCY, [F:STO]STOCOU, [F:STO]QTYPCU, [F:STO]QTYSTU,"","", LRET) From STKINT  # hcb 110327
      If LRET <> 0 : Raz GOK : Break : Endif
   Endif                                          # hcb 110327
Next
If !GOK Return Endif

[M:STW]STOFCY     = [F:SLH]STOFCY      # Site
[M:STW]TRSTYP     = 2                  # Type mouvement (M.704)
[M:STW]VCRTYP     = 35                 # Type pièce (M.701)
[M:STW]VCRNUM     = [F:SLH]VCRNUM      # Numéro pièce
[M:STW]VCRLIN     = 0                  # Numero ligne pièce
[M:STW]ITMREF     = [F:SLH]ITMREF      # Article
[M:STW]MVTDES     = [F:SLH]MVTDES      # Désignation mouvement
[M:STW]PJT        = [F:SLH]PJT         # Affaire
[M:STW]TRSFAM     = [F:SLH]TRSFAM      # Famille mouvement
[M:STW]IPTDAT     = [F:SLH]IPTDAT      # Date imputation
[M:STW]TRAFLG     = 0
Gosub ALIVALWORK From STKVALMAJ
# sauvegarde STOWORK (on va repartir du même modèle pour les entrées)
Transmask [M:STW] To [M:STWX] # Issue 25606_Transmask [M:STWX] = [M:STW]

# mise à jour des sorties
Call MAJ_STOCK From STKMAJ
If GOK = 0 : Return : Endif

# CCC (29/03/07) Bug 40553 (suite du 30922)
[M:STWX]PRIORDH = [M:STW]ISSAMTVAL/sum([M:STWX]QTYSTU)

# chargement des lignes à entrer, on repart du modèle sauvegardé
Raz [STW]
Raz [M:STW]NBLIG
Transmask [M:STWX] To [M:STW]  # Issue 25606_Transmask [M:STW] = [M:STWX]

# seul le type de mouvement change dans l'entête
[M:STW]TRSTYP     = 1                   # Type mouvement (M.704)

# on applique les nouvelles caractéristiques
For I = 0 To [M:STWX]NBLIG - 1
    [M:STW]MAJTYP(I)       = "E"
    If dim([M:SUD2]POT) > 0
        [M:STW]POT(I)        = [F:SLH]POT
        [M:STW]QTYSTUACT(I)  = [M:STW]QTYSTU(I) * [M:STW]POT(I)/100
    Else
        [M:STW]QTYSTUACT(I)  = [M:STW]QTYSTU(I)
    Endif
    [M:STW]ECCVALMAJ(I)      = [F:SLH]ECCVALMAJ       # hcb 71276
    [M:STW]ECCVALMIN(I)      = [F:SLH]ECCVALMIN       # hcb 71276
    [M:STW]REFPER   (I)      = [F:SLH]REFPER
    [M:STW]BPSLOT   (I)      = [F:SLH]BPSLOT
    [M:STW]SHL      (I)      = [F:SLH]SHL
    [M:STW]SHLDAT   (I)      = [F:SLH]SHLDAT
    [M:STW]SHLUOM   (I)      = [F:SLH]SHLUOM     # v6per
    [M:STW]DLU      (I)      = [F:SLH]DLU        # v6per
    [M:STW]DLUDAT   (I)      = [F:SLH]DLUDAT     # v6per
    [M:STW]SHLLTI   (I)      = [F:SLH]SHLLTI     # v6per
    [M:STW]SHLLTIUOM(I)      = [F:SLH]SHLLTIUOM  # v6per
    [M:STW]NEWLTIDAT(I)      = [F:SLH]NEWLTIDAT  # v6per
    [M:STW]USRFLD1  (I)      = [F:SLH]USRFLD1
    [M:STW]USRFLD2  (I)      = [F:SLH]USRFLD2
    [M:STW]USRFLD3  (I)      = [F:SLH]USRFLD3
    [M:STW]USRFLD4  (I)      = [F:SLH]USRFLD4
    If [F:SRT]PRNCOD1 = 2
        If [M:STW]PCU(I) = [F:ITM]STU
            Call CTLUOM ([F:SLH]ITMREF, 3, "", [M:STW]STU(I), LCOE, LUSCAV, LFMT, LMODIF) From STKACT
        Else
            Call CTLUOM ([F:SLH]ITMREF, 3, "", [M:STW]PCU(I), LCOE, LUSCAV, LFMT, LMODIF) From STKACT
        Endif
        #--- Bug 59444
        #[M:STW]LBENBR(I) = int([M:STW]QTYPCU(I))
        If int([M:STW]QTYPCU(I))=[M:STW]QTYPCU(I)
           [M:STW]LBENBR(I) = [M:STW]QTYPCU(I)
        Else
           [M:STW]LBENBR(I) = int([M:STW]QTYPCU(I))+1
        Endif
        #---
        [M:STW]LBEFMT(I) = LFMT
    Endif
Next I

Gosub ALIVALWORK From STKVALMAJ

# mise à jour des entrées
Call MAJ_STOCK From STKMAJ

#--- Bug 77900
For I=0 To dim([M:STW]STOCOU)-1
   If [M:STW]STOCOU(I)=0 : Break : Endif

   If WCUM(I,0)<>0 | WCUM(I,2)<>0
      Readlock [STO]STO0=[M:STW]STOFCY;[M:STW]STOCOU(I)
      If !fstat
         [F:STO]CUMALLQTY += WCUM(I,0)
         [F:STO]CUMALLQTA += WCUM(I,1)
         [F:STO]CUMWIPQTY += WCUM(I,2)
         [F:STO]CUMWIPQTA += WCUM(I,3)
         Rewrite [STO]
         If fstat
            GMESSAGE-=mess(50,176,1): GOK=0 : Break
         Elsif WCUM(I,0)<>0
            Update [STA] Where STOCOU=WCUM(I,4) With STOCOU=[F:STO]STOCOU
            If fstat
               GMESSAGE-=mess(50,176,1): GOK=0 : Break
            Endif
         Endif
      Endif
   Endif
Next I
Raz [M:STW]
#---

# mise à jour document
Gosub MAJ_SLM

NBMODIF += 1

Return

#########################################################################
$GEN_SLM
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 4 | [F:SRT]SRTNUM <> GSMXNUM                   # hcb 50197
    Read [SRT]SRT0=4;GSMXNUM : If fstat Raz [F:SRT] : Endif
Endif

# génération du document
Call NUMERO(GSTKCPT(5), LSTOFCY, [M:SUD2]IPTDAT(J), "", LNUM, LSTAT) From SUBANM
If LSTAT = 2
    GERR = 1 : GMESSAGE= GSTKCPT(5)-":"-mess(30,196,1) : Return
Endif
Local Char WFILTRE(250)                                         # hcb unicite

# Initialisation de l'en-tête (apres l'ajout de ligne car le transclasse de STL vers STW surcharge la pièce)
Raz [F:SLH]
[F:SLH]VCRNUM = LNUM
[F:SLH]STOFCY = LSTOFCY
[F:SLH]PJT    = [M:SUD2]PJT    (J)
[F:SLH]ITMREF = [M:SUD2]ITMREF (J)
[F:SLH]LOT    = [M:SUD2]LOT    (J)
If [F:ITM]LOTMGTCOD = 4 & dim([M:SUD2]SLO) > 0 & GFEALOTLEV = 1 : [F:SLH]SLO = [M:SUD2]SLO(J) : Endif   # hcb unicite
[F:SLH]IPTDAT = [M:SUD2]IPTDAT (J)
[F:SLH]VCRDES = [M:SUD2]MVTDES (J)                                 # pas de saisie VCRDES ici, on reprend MVTDES
[F:SLH]TRSFAM = [M:SUD2]TRSFAM (J)
[F:SLH]MVTDES = [M:SUD2]MVTDES (J)
If dim([M:SUD2]BPSLOT) > 0
   [F:SLH]BPSLOT = [M:SUD2]BPSLOT (J)
Endif

[F:SLH]CHANGECOD = 1

If [F:ITM]LOTMGTCOD = 4 & GFEALOTLEV = 2                                 # hcb unicite deb
    Filter [F:STL] Where ITMREF = [M:SUD2]ITMREF (J) & LOT = [M:SUD2]LOT    (J)
&                    Order By Key STL0
    Read [STL] First
    If fstat
       Raz [STL]
    Endif
    Filter [F:STL]
    WFILTRE = "LOT = [F:SLH]LOT"                      # hcb unicite
Else                                                                     # hcb unicite fin
# lecture lot pour récupérer ancienne valeur titre, péremption ...
    Read [F:STL]STL0=[F:SLH]ITMREF;[F:SLH]LOT;[F:SLH]SLO
    If fstat
       Raz [STL]
    Endif
    WFILTRE = "LOT = [F:SLH]LOT & SLO = [F:SLH]SLO"                      # hcb unicite
Endif                                                                    # hcb unicite
# on relance une petite vérif pour être sur que le lot est modifiable
# c'est redondant mais c'est fait exprès (on peut difficilement bloquer complétement
# les lots dans un traitement en série ...)
Raz WTSTFCY
Gosub CHECK_STO
If WIND > 0
    WMESS  = mess(80,197,1)-":"-[F:SLH]ITMREF
    WMESS -= mess(43,197,1)-":"-[F:SLH]LOT
    If [F:ITM]LOTMGTCOD = 4 & GFEALOTLEV <> 2                           # hcb unicite
       WMESS -= mess(456,197,1)-":"-[F:SLH]SLO : Endif
    Case WIND
        When 1: WMESS1 = mess(482,199,1)
        When 2: WMESS1 = mess(460,199,1)
        When 3: WMESS1 = mess(488,199,1)
    Endcase
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(WMESS,0)  From GESECRAN
    Call ECR_TRACE(WMESS1,0)  From GESECRAN
    Return
Endif
[F:SLH]BPSLOTOLD  = [F:STL]BPSLOT
[F:SLH]POTOLD     = [F:STL]POT
[F:SLH]REFPEROLD  = [F:STL]REFPER
[F:SLH]SHLOLD     = [F:STL]SHL
[F:SLH]SHLDATOLD  = [F:STL]SHLDAT
[F:SLH]SHLUOMOLD  = [F:STL]SHLUOM             # hcb v6per
[F:SLH]DLUOLD     = [F:STL]DLU                # hcb v6per
[F:SLH]DLUDATOLD  = [F:STL]DLUDAT             # hcb v6per
[F:SLH]SHLLTIOLD  = [F:STL]SHLLTI             # hcb v6per
[F:SLH]SHLLTIUOMO = [F:STL]SHLLTIUOM          # hcb v6per
[F:SLH]NEWLTIDATO = [F:STL]NEWLTIDAT          # hcb v6per

[F:SLH]USRFLD1OLD = [F:STL]USRFLD1
[F:SLH]USRFLD2OLD = [F:STL]USRFLD2
[F:SLH]USRFLD3OLD = [F:STL]USRFLD3
[F:SLH]USRFLD4OLD = [F:STL]USRFLD4

# nouvelles valeurs initialisées
[F:SLH]BPSLOT     = [F:STL]BPSLOT
[F:SLH]POT        = [F:STL]POT
[F:SLH]REFPER     = [F:STL]REFPER
[F:SLH]SHL        = [F:STL]SHL
[F:SLH]SHLDAT     = [F:STL]SHLDAT
[F:SLH]SHLUOM     = [F:STL]SHLUOM             # hcb v6per
[F:SLH]DLU        = [F:STL]DLU                # hcb v6per
[F:SLH]DLUDAT     = [F:STL]DLUDAT             # hcb v6per
[F:SLH]SHLLTI     = [F:STL]SHLLTI             # hcb v6per
[F:SLH]SHLLTIUOM  = [F:STL]SHLLTIUOM          # hcb v6per
[F:SLH]NEWLTIDAT  = [F:STL]NEWLTIDAT          # hcb v6per

[F:SLH]USRFLD1    = [F:STL]USRFLD1
[F:SLH]USRFLD2    = [F:STL]USRFLD2
[F:SLH]USRFLD3    = [F:STL]USRFLD3
[F:SLH]USRFLD4    = [F:STL]USRFLD4
#                                                     # hcb 71276 deb
[F:SLH]ECCVALMAJ    = [F:STL]ECCVALMAJ
[F:SLH]ECCVALMAJOLD = [F:STL]ECCVALMAJ
[F:SLH]ECCVALMIN    = [F:STL]ECCVALMIN
[F:SLH]ECCVALMINOLD = [F:STL]ECCVALMIN
#                                                     # hcb 71276 fin
#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:SLH]STOFCY | [F:ITF]ITMREF <> [F:SLH]ITMREF
   Read [ITF]ITF0 = [F:SLH]ITMREF;[F:SLH]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif


# surcharge par valeurs saisies

GPOINT = "GENSLM_BSLH"
Gosub ENTREE From EXEFNC

If dim([M:SUD2]POT) > 0 & [F:SRT]POTCOD = 1 & [F:ITF]STOMGTCOD = 3
    [F:SLH]POT = [M:SUD2]POT(J)
Endif
# hcb v6per
If dim([M:SUD2]REFPER)>0 & [F:ITM]EXYMGTCOD > 1 & [F:SRT]PERCOD = 1
    [F:SLH]REFPER       = [M:SUD2]REFPER    (J)
    [F:SLH]SHL          = [M:SUD2]SHL       (J)
    [F:SLH]SHLDAT       = [M:SUD2]SHLDAT    (J)
    [F:SLH]SHLUOM       = [M:SUD2]SHLUOM    (J)
    [F:SLH]DLU          = [M:SUD2]DLU       (J)
    [F:SLH]DLUDAT       = [M:SUD2]DLUDAT    (J)
    [F:SLH]SHLLTI       = [M:SUD2]SHLLTI    (J)
    [F:SLH]SHLLTIUOM    = [M:SUD2]SHLLTIUOM (J)
    [F:SLH]NEWLTIDAT    = [M:SUD2]NEWLTIDAT (J)
Endif
If [F:SRT]SRUB1FLG = 2 : [F:SLH]USRFLD1 = [M:SUD2]USRFLD1(J) : Endif
If [F:SRT]SRUB2FLG = 2 : [F:SLH]USRFLD2 = [M:SUD2]USRFLD2(J) : Endif
If [F:SRT]SRUB3FLG = 2 : [F:SLH]USRFLD3 = [M:SUD2]USRFLD3(J) : Endif
If [F:SRT]SRUB4FLG = 2 : [F:SLH]USRFLD4 = [M:SUD2]USRFLD4(J) : Endif
If dim([M:SUD2]BPSLOT) > 0 & [F:SRT]BPSLOTCOD = 1
   [F:SLH]BPSLOT       = [M:SUD2]BPSLOT      (J)
Endif
#                                                     # hcb 71276 deb
If dim([M:SUD2]ECCVALMAJ) > 0 & [F:SRT]ECCCOD = 2
   [F:SLH]ECCVALMAJ       = [M:SUD2]ECCVALMAJ      (J)
Endif
If dim([M:SUD2]ECCVALMIN) > 0 & [F:SRT]ECCCOD = 2
   [F:SLH]ECCVALMIN       = [M:SUD2]ECCVALMIN      (J)
Endif
#                                                     # hcb 71276 fin


GPOINT = "GENSLM_ASLH"
Gosub ENTREE From EXEFNC

# Si on a pas déjà fait le test (pour les lots multi-sites)
# hcb  v6per
If WMAJLOT_FCY < 2
    # on vérifie si quelque chose à été modifié
    If [F:SLH]POT       = [F:SLH]POTOLD     &
&      [F:SLH]ECCVALMAJ = [F:SLH]ECCVALMAJOLD &
&      [F:SLH]ECCVALMIN = [F:SLH]ECCVALMINOLD &
&      [F:SLH]BPSLOT    = [F:SLH]BPSLOTOLD  &
&      [F:SLH]REFPER    = [F:SLH]REFPEROLD  &
&      [F:SLH]SHL       = [F:SLH]SHLOLD     &
&      [F:SLH]SHLDAT    = [F:SLH]SHLDATOLD  &
&      [F:SLH]SHLUOM    = [F:SLH]SHLUOMOLD  &
&      [F:SLH]DLU       = [F:SLH]DLUOLD     &
&      [F:SLH]DLUDAT    = [F:SLH]DLUDATOLD  &
&      [F:SLH]SHLLTI    = [F:SLH]SHLLTIOLD  &
&      [F:SLH]SHLLTIUOM = [F:SLH]SHLLTIUOMO &
&      [F:SLH]NEWLTIDAT = [F:SLH]NEWLTIDATO &
&      [F:SLH]USRFLD1   = [F:SLH]USRFLD1OLD &
&      [F:SLH]USRFLD2   = [F:SLH]USRFLD2OLD &
&      [F:SLH]USRFLD3   = [F:SLH]USRFLD3OLD &
&      [F:SLH]USRFLD4   = [F:SLH]USRFLD4OLD
        WIND = 9
    Endif
Endif
Return

#########################################################################
$MAJ_SLM
[F:SLH]CREDAT = date$
[F:SLH]CREUSR = GUSER
Write [SLH]
If fstat : GERR=1 : Call FSTA("SLM") From GLOCK : Return : Endif

Call ECR_TRACE(" ",0) From GESECRAN
WMESS   = mess(589,197,1)
WMESS  -= [F:SLH]VCRNUM
WMESS1  = mess(80,197,1)-":"-[F:SLH]ITMREF
WMESS1 -= mess(43,197,1)-":"-[F:SLH]LOT
If [F:ITM]LOTMGTCOD = 4 : WMESS1 -= mess(456,197,1)-":"-[F:SLH]SLO : Endif
Call ECR_TRACE(WMESS,0)  From GESECRAN
Call ECR_TRACE(WMESS1,0)  From GESECRAN

#                                                  # hcb 71276 deb
If [F:SLH]ECCVALMAJ <> [F:SLH]ECCVALMAJOLD
    WMESS  = mess(852,197,1)+":"
    WMESS -= [F:SLH]ECCVALMAJOLD-"-->"-[F:SLH]ECCVALMAJ
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
If [F:SLH]ECCVALMIN <> [F:SLH]ECCVALMINOLD
    WMESS  = mess(853,197,1)+":"
    WMESS -= [F:SLH]ECCVALMINOLD-"-->"-[F:SLH]ECCVALMIN
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
#                                                  # hcb 71276 fin

If [F:SLH]BPSLOT <> [F:SLH]BPSLOTOLD
    WMESS  = mess(3,706,1)+":"
    WMESS -= [F:SLH]BPSLOTOLD-"-->"-[F:SLH]BPSLOT
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif

If [F:SLH]POT <> [F:SLH]POTOLD
    WMESS  = mess(590,197,1)
    WMESS -= num$([F:SLH]POTOLD)-"-->"-num$([F:SLH]POT)
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
If [F:SLH]REFPER <> [F:SLH]REFPEROLD
    WMESS  = mess(591,197,1)
    If [F:SLH]REFPEROLD <> [0/0/0]
        WMESS -= format$(GFMD,[F:SLH]REFPEROLD)-"-->"-format$(GFMD,[F:SLH]REFPER)
    Else
        WMESS -= "[0/0/0]"-"-->"+format$(GFMD,[F:SLH]REFPER)
    Endif
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
If [F:SLH]SHL <> [F:SLH]SHLOLD
    WMESS  = mess(592,197,1)
    WMESS -= num$([F:SLH]SHLOLD)-"-->"-num$([F:SLH]SHL)
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
If [F:SLH]SHLDAT <> [F:SLH]SHLDATOLD
    WMESS  = mess(593,197,1)
    If [F:SLH]SHLDATOLD <> [0/0/0]
        WMESS -= format$(GFMD,[F:SLH]SHLDATOLD)-"-->"+format$(GFMD,[F:SLH]SHLDAT)
    Else
        WMESS -= "[0/0/0]"-"-->"-format$(GFMD,[F:SLH]SHLDAT)
    Endif
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
If [F:SLH]USRFLD1 <> [F:SLH]USRFLD1OLD
    WMESS  = mess(1,726,1)+":"
    WMESS -= [F:SLH]USRFLD1OLD-"-->"-[F:SLH]USRFLD1
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
If [F:SLH]USRFLD2 <> [F:SLH]USRFLD2OLD
    WMESS  = mess(2,726,1)+":"
    WMESS -= [F:SLH]USRFLD2OLD-"-->"-[F:SLH]USRFLD2
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
If [F:SLH]USRFLD3 <> [F:SLH]USRFLD3OLD
    WMESS  = mess(3,726,1)+":"
    WMESS -= num$([F:SLH]USRFLD3OLD)-"-->"-num$([F:SLH]USRFLD3)
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
If [F:SLH]USRFLD4 <> [F:SLH]USRFLD4OLD
    WMESS  = mess(4,726,1)+":"
    If [F:SLH]USRFLD4OLD <> [0/0/0]
        WMESS -= format$(GFMD,[F:SLH]USRFLD4OLD)-"-->"-format$(GFMD,[F:SLH]USRFLD4)
    Else
        WMESS -= "[0/0/0]"-"-->"-format$(GFMD,[F:SLH]USRFLD4)
    Endif
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif

#                                      hcb v6per deb
If [F:SLH]DLUDAT <> [F:SLH]DLUDATOLD
    WMESS  = mess(591,197,1)
    If [F:SLH]DLUDATOLD <> [0/0/0]
        WMESS -= format$(GFMD,[F:SLH]DLUDATOLD)-"-->"-format$(GFMD,[F:SLH]DLUDAT)
    Else
        WMESS -= "[0/0/0]"-"-->"+format$(GFMD,[F:SLH]DLUDAT)
    Endif
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
If [F:SLH]NEWLTIDAT <> [F:SLH]NEWLTIDATO
    WMESS  = mess(591,197,1)
    If [F:SLH]NEWLTIDATO <> [0/0/0]
        WMESS -= format$(GFMD,[F:SLH]NEWLTIDATO)-"-->"-format$(GFMD,[F:SLH]NEWLTIDAT)
    Else
        WMESS -= "[0/0/0]"-"-->"+format$(GFMD,[F:SLH]NEWLTIDAT)
    Endif
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
If [F:SLH]SHLLTI <> [F:SLH]SHLLTIOLD
    WMESS  = mess(592,197,1)
    WMESS -= num$([F:SLH]SHLLTIOLD)-"-->"-num$([F:SLH]SHLLTI)
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
If [F:SLH]DLU <> [F:SLH]DLUOLD
    WMESS  = mess(592,197,1)
    WMESS -= num$([F:SLH]DLUOLD)-"-->"-num$([F:SLH]DLU)
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
If [F:SLH]SHLUOM <> [F:SLH]SHLUOMOLD
    WMESS  = mess(592,197,1)
    WMESS -= num$([F:SLH]SHLUOMOLD)-"-->"-num$([F:SLH]SHLUOM)
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
If [F:SLH]SHLLTIUOM <> [F:SLH]SHLLTIUOMO
    WMESS  = mess(592,197,1)
    WMESS -= num$([F:SLH]SHLLTIUOMO)-"-->"-num$([F:SLH]SHLLTIUOM)
    Call ECR_TRACE(WMESS,0)  From GESECRAN
Endif
#                                      hcb v6per fin

Return

#########################################################################
$ABORT_SAISMXUPD
Raz [M:SUD2]
Diszo [M:SUD2]5
Affzo [M:SUD2]1-99
Gosub LIRE
Return

#########################################################################
$FIN_SAISMXUPD
Raz GSHLUOM
Raz GSHLLTIUOM
Return


#########################################################################
$ROLL_MODLOT
Rollback
Call ROLL From GLOCK
If GROLL
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN : End
Else Goto MAJLOT : Endif

#########################################################################
$AB_MOD
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

########################################################################
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
Call GETCPY(GFCY,"",0,"") From TRTX3CPT

Return

########################################################################
$CHANGE_AWI
Local Integer OK
If clalev([F:AWI])=0  : Local File AWINDOW [AWI] : Endif
Read [AWI]AWI0=BOITE
If fstat
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenêtre inexistante
    GERR = 1
    FIN = 1
    Return
Endif
GBOITE     = BOITE
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG

#If filinfo(filpath("TRT",WINPROG,"adx"),0)<0
Call EXISTE_ADX("","",WINPROG,OK) From ORDSYS
If OK=0
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenêtre inexistante
    GERR = 1
    FIN = 1
Endif
Return

#######################################################################
#                     ACTIONS CHAMPS                                  #
#######################################################################

Subprog AM_ALLSTOFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    Raz   [M]STOFCY
    Diszo [M]STOFCY
Else
    [M]STOFCY=GFCYDEF(7)
    Actzo [M]STOFCY
Endif
End

Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
If [M]ALLSTOFCY<>2 & VALEUR=""
    mkstat=2
    GMESSAGE=mess(215,193,1)
Endif
GFCY   = VALEUR
Gosub CHARG_PARAM

End

Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFEND = ""     : [M]ITMREFEND = VALEUR : Endif
If [M]ITMREFEND < VALEUR : [M]ITMREFEND = VALEUR : Endif
GFEALOTLEV = GWFEALOTLEV                          # hcb 71276

End

Subprog AM_LOTSTR(VALEUR)
Variable Char    VALEUR()
If [M]LOTEND = ""     : [M]LOTEND = VALEUR : Endif
If [M]LOTEND < VALEUR : [M]LOTEND = VALEUR : Endif
End

Subprog AM_SLOSTR(VALEUR)
Variable Char    VALEUR()
If [M]SLOEND = ""     : [M]SLOEND = VALEUR : Endif
If [M]SLOEND < VALEUR : [M]SLOEND = VALEUR : Endif
End

Subprog C_ITMREFSTR(VALEUR)
Variable Char    VALEUR()

If VALEUR = "" : End : Endif
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat : Raz [ITM] : Endif
Endif
# article doit être géré avec lot
If !find([F:ITM]LOTMGTCOD,2,3,4) : mkstat = 2 : GMESSAGE = mess(480,199,1) : Endif

End

Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
Actzo  [M:SUD1]BPSLOT
GFEALOTLEV = GWFEALOTLEV                          # hcb 71276

If (VALEUR <> [M:SUD1]ITMREFSTR ) | ([M:SUD1]LOTSTR <> [M:SUD1]LOTEND ) | ([M:SUD1]ITMREFSTR = "") | ([M:SUD1]LOTSTR =  "")
   Raz    [M:SUD1]BPSLOT
   Affzo  [M:SUD1]BPSLOT
   Diszo  [M:SUD1]BPSLOT
Endif
#                                                           # Hcb 71276 deb
If (VALEUR <> [M:SUD1]ITMREFSTR ) |([M:SUD1]ITMREFSTR = "")
   If [M:SUD1]ITMREFSTR =  VALEUR
      If [F:ITM]LOTMGTCOD = 4
         Actzo [M:SUD1]SLOSTR
         Actzo [M:SUD1]SLOEND
      Else
         Diszo [M:SUD1]SLOSTR
         Diszo [M:SUD1]SLOEND
      Endif
   Else
      Actzo [M:SUD1]SLOSTR
      Actzo [M:SUD1]SLOEND
   Endif

   If dim([M:SUD1]ECCVALMAJ)>0
      Raz    [M:SUD1]ECCVALMAJ
      Raz    [M:SUD1]ECCVALMIN
      Raz    [M:SUD1]ECCSTA
      Affzo  [M:SUD1]ECCVALMAJ
      Affzo  [M:SUD1]ECCVALMIN
      Affzo  [M:SUD1]ECCSTA
      Diszo  [M:SUD1]ECCVALMAJ
      Diszo  [M:SUD1]ECCVALMIN
    Endif
Else
   If [F:ITM]LOTMGTCOD <> 4
      Diszo [M:SUD1]SLOSTR
      Diszo [M:SUD1]SLOEND
   Else
      Actzo [M:SUD1]SLOSTR
      Actzo [M:SUD1]SLOEND
   Endif
   If dim([M:SUD1]ECCVALMAJ)>0
      If [F:ITM]ECCSTO > 2
         Actzo  [M:SUD1]ECCVALMAJ
         Actzo  [M:SUD1]ECCVALMIN
         Diszo [M:SUD1]SLOSTR
         Diszo [M:SUD1]SLOEND
      Endif
      If [F:ITM]ECCSTO = 2
         Actzo  [M:SUD1]ECCVALMAJ
         Diszo [M:SUD1]SLOSTR
         Diszo [M:SUD1]SLOEND
      Endif
   Endif
   If dim([F:ITM]ECCSTO) > 0 & [F:ITM]ECCSTO >1      # hcb 71276
      GFEALOTLEV = 2                                 # hcb 71276
   Endif                                             # hcb 71276

#                                                           # Hcb 71276 fin
Endif

If VALEUR = "" : End : Endif
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat : Raz [ITM] : Endif
Endif
# article doit être géré avec lot
If !find([F:ITM]LOTMGTCOD,2,3,4) : mkstat = 2 : GMESSAGE = mess(480,199,1) : Endif
If [M:SUD1]ITMREFSTR = "" | [M:SUD1]LOTSTR =  ""
   Raz    [M:SUD1]BPSLOT
   Affzo  [M:SUD1]BPSLOT
   Diszo  [M:SUD1]BPSLOT
Endif
If (VALEUR <> [M:SUD1]ITMREFSTR ) | ([M:SUD1]LOTSTR <> [M:SUD1]LOTEND )
   Raz    [M:SUD1]BPSLOT
   Affzo  [M:SUD1]BPSLOT
   Diszo  [M:SUD1]BPSLOT
Endif

End

Subprog C_REFPER(VALEUR)
Variable Date    VALEUR
If VALEUR > [31/12/2999] : mkstat = 2 : Endif
End

Subprog C_SHLDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [31/12/2999] : mkstat = 2 : Endif

End

Subprog C_IPTDAT(VALEUR)
Variable Date    VALEUR
If [M:SUD1]STOFCY<>""
    Call STKCTRIPT(VALEUR,[M:SUD1]STOFCY,"1") From STKLIB
Endif
End


#                                          hcb v6per deb

########################################
Subprog AM_REFPER(VALEUR)
Variable Date    VALEUR
Local    Integer  WCOD
Local    Date     WREF
Local    Integer  WSHL
Local    Date     WPER
Local    Integer  WUOM
Local    Decimal  WDLU
Local    Date     WEXY
Local    Integer  WLTI

If [M:SUD1]ITMREFSTR = [M:SUD1]ITMREFEND & [M:SUD1]ITMREFSTR <> ""
    WCOD = [F:ITM]EXYMGTCOD
    WUOM = [M:SUD1]SHLUOM
    WREF = VALEUR
    WSHL = [M:SUD1]SHL
    WDLU = [M:SUD1]DLU

    Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
    [M:SUD1]SHLDAT = WPER
    Affzo [M:SUD1]SHLDAT
    WEXY = WPER
    Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB

    [M:SUD1]DLUDAT = WPER
    Affzo [M:SUD1]DLUDAT
    [M:SUD1]DLULTI = WLTI
    Affzo [M:SUD1]DLULTI


    WSHL = [M:SUD1]SHLLTI
    WUOM = [M:SUD1]SHLLTIUOM
    Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
    [M:SUD1]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
    If [M:SUD1]NEWLTIDAT <> [31/12/2999]
        If [M:SUD1]NEWLTIDAT  > [M:SUD1]DLUDAT
           [M:SUD1]NEWLTIDAT  = [M:SUD1]DLUDAT
        Endif
    Endif

    Affzo [M:SUD1]NEWLTIDAT

Endif


End



########################################
Subprog AM_SHL(VALEUR)
Variable Decimal VALEUR
Local    Integer  WCOD
Local    Date     WREF
Local    Integer  WSHL
Local    Date     WPER
Local    Integer  WUOM
Local    Date     WEXY
Local    Integer  WLTI


If [M:SUD1]ITMREFSTR = [M:SUD1]ITMREFEND & [M:SUD1]ITMREFSTR <> ""
    WCOD = [F:ITM]EXYMGTCOD
    WREF = [M:SUD1]REFPER
    WUOM = [M:SUD1]SHLUOM
    WDLU = [M:SUD1]DLU
    WSHL = VALEUR
    Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
    [M:SUD1]SHLDAT = WPER
    Affzo [M:SUD1]SHLDAT
    WEXY = WPER
    Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
    [M:SUD1]DLUDAT = WPER
    Affzo [M:SUD1]DLUDAT
    [M:SUD1]DLULTI = WLTI
    Affzo [M:SUD1]DLULTI

    WSHL = [M:SUD1]SHLLTI
    WUOM = [M:SUD1]SHLLTIUOM
    Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
    [M:SUD1]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
    If [M:SUD1]NEWLTIDAT <> [31/12/2999]
       If [M:SUD1]NEWLTIDAT  > [M:SUD1]DLUDAT
          [M:SUD1]NEWLTIDAT  = [M:SUD1]DLUDAT
       Endif
    Endif
    Affzo [M:SUD1]NEWLTIDAT

Endif

End


Subprog AM_SHLUOM(VALEUR)
Variable Integer VALEUR
Local    Integer  WCOD
Local    Date     WREF
Local    Integer  WSHL
Local    Date     WPER
Local    Integer  WUOM
Local    Date     WEXY
Local    Integer  WLTI

GSHLUOM = VALEUR

If [M:SUD1]ITMREFSTR = [M:SUD1]ITMREFEND & [M:SUD1]ITMREFSTR <> ""
    WCOD = [F:ITM]EXYMGTCOD
    WREF = [M:SUD1]REFPER
    WUOM = VALEUR
    WDLU = [M:SUD1]DLU
    WSHL = [M:SUD1]SHL
    Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
    [M:SUD1]SHLDAT = WPER
    Affzo [M:SUD1]SHLDAT
    WEXY = WPER
    Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
    [M:SUD1]DLUDAT = WPER
    Affzo [M:SUD1]DLUDAT
    [M:SUD1]DLULTI = WLTI
    Affzo [M:SUD1]DLULTI

    WSHL = [M:SUD1]SHLLTI
    WUOM = [M:SUD1]SHLLTIUOM
    Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
    [M:SUD1]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
    If [M:SUD1]NEWLTIDAT <> [31/12/2999]
       If [M:SUD1]NEWLTIDAT  > [M:SUD1]DLUDAT
          [M:SUD1]NEWLTIDAT  = [M:SUD1]DLUDAT
       Endif
    Endif
    Affzo [M:SUD1]NEWLTIDAT

Endif

End

Subprog AM_DLU(VALEUR)
Variable Decimal VALEUR
Local    Integer  WCOD
Local    Date     WREF
Local    Integer  WSHL
Local    Date     WPER
Local    Integer  WUOM
Local    Date     WEXY
Local    Integer  WLTI

If [M:SUD1]ITMREFSTR = [M:SUD1]ITMREFEND & [M:SUD1]ITMREFSTR <> ""
    WCOD = [F:ITM]EXYMGTCOD
    WREF = [M:SUD1]REFPER
    WUOM = [M:SUD1]SHLUOM
    WDLU = VALEUR
    WEXY = [M:SUD1]SHLDAT
    Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
    [M:SUD1]DLUDAT = WPER
    Affzo [M:SUD1]DLUDAT
    [M:SUD1]DLULTI = WLTI
    Affzo [M:SUD1]DLULTI

Endif

End


Subprog AM_DLUDAT(VALEUR)
Variable Date    VALEUR
If [M:SUD1]NEWLTIDAT <> [31/12/2999]
   If [M:SUD1]NEWLTIDAT  > VALEUR
      [M:SUD1]NEWLTIDAT  = VALEUR
      Affzo [M:SUD1]NEWLTIDAT
   Endif
Endif
[M:SUD1]DLULTI     =  nday(VALEUR) -nday([M:SUD1]REFPER)
Affzo [M:SUD1]DLULTI

End



Subprog AM_SHLLTI(VALEUR)
Variable Decimal VALEUR
Local    Integer  WCOD
Local    Date     WREF
Local    Integer  WSHL
Local    Date     WPER
Local    Integer  WUOM

If [M:SUD1]ITMREFSTR = [M:SUD1]ITMREFEND & [M:SUD1]ITMREFSTR <> ""
    WCOD = [F:ITM]EXYMGTCOD
    WREF = [M:SUD1]REFPER
    WSHL = VALEUR
    WUOM = [M:SUD1]SHLLTIUOM
    Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
    [M:SUD1]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
    If [M:SUD1]NEWLTIDAT <> [31/12/2999]
       If [M:SUD1]NEWLTIDAT  > [M:SUD1]DLUDAT
          [M:SUD1]NEWLTIDAT  = [M:SUD1]DLUDAT
       Endif
    Endif
    Affzo [M:SUD1]NEWLTIDAT

Endif

End

Subprog AM_SHLLTIUOM(VALEUR)
Variable Integer VALEUR
Local    Integer  WCOD
Local    Date     WREF
Local    Integer  WSHL
Local    Date     WPER
Local    Integer  WUOM

GSHLLTIUOM = VALEUR

If [M:SUD1]ITMREFSTR = [M:SUD1]ITMREFEND & [M:SUD1]ITMREFSTR <> ""
    WCOD = [F:ITM]EXYMGTCOD
    WREF = [M:SUD1]REFPER
    WSHL = [M:SUD1]SHLLTI
    WUOM = VALEUR
    Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
    [M:SUD1]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
    If [M:SUD1]NEWLTIDAT <> [31/12/2999]
        If [M:SUD1]NEWLTIDAT  > [M:SUD1]DLUDAT
           [M:SUD1]NEWLTIDAT  = [M:SUD1]DLUDAT
        Endif
    Endif
    Affzo [M:SUD1]NEWLTIDAT

Endif

End

Subprog C_NEWLTIDAT(VALEUR)
Variable Date    VALEUR
If VALEUR <> [31/12/2999]
   If VALEUR > [M:SUD1]DLUDAT
      GMESSAGE=mess(309,184,1)  # Date re-contrôle  > date limite utilisation !
      mkstat = 2
   Endif
Endif
End

Subprog C_DLU(VALEUR)
Variable Decimal VALEUR
If VALEUR > 1 | VALEUR < 0               # hcb 75934
   GMESSAGE = mess(83,123,1) #"valeur incorrecte"
   mkstat = 2
   End
Endif
End
Subprog C_DLUDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [M:SUD1]SHLDAT
   GMESSAGE=mess(313,184,1)  # Date re-contrôle  > date limite utilisation !
   mkstat = 2
Endif

End


Subprog AM_SHLDAT(VALEUR)
Variable Date    VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Decimal  WDLU : WDLU = [M:SUD1]DLU
Local    Date     WREF : WREF = [M:SUD1]REFPER
Local    Date     WPER
Local    Date     WEXY : WEXY = VALEUR
Local    Integer  WLTI


Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB

[M:SUD1]DLUDAT = WPER
Affzo [M:SUD1]DLUDAT
[M:SUD1]DLULTI = WLTI
Affzo [M:SUD1]DLULTI

End

#                                          hcb v6per fin
Subprog C_LOTEND(VALEUR)
Variable Char    VALEUR()
Actzo  [M:SUD1]BPSLOT
If (VALEUR <> [M:SUD1]LOTSTR ) | ([M:SUD1]ITMREFSTR <> [M:SUD1]ITMREFEND ) | ([M:SUD1]ITMREFSTR = "") | ([M:SUD1]LOTSTR =  "")
   Raz    [M:SUD1]BPSLOT
   Affzo  [M:SUD1]BPSLOT
   Diszo  [M:SUD1]BPSLOT
Endif
#                                                           # Hcb 71276 deb
If ([M:SUD1]ITMREFSTR <> [M:SUD1]ITMREFEND ) | ([M:SUD1]ITMREFSTR = "")

   If [M:SUD1]ITMREFSTR =  [M:SUD1]ITMREFEND
      If [F:ITM]LOTMGTCOD = 4
         Actzo [M:SUD1]SLOSTR
         Actzo [M:SUD1]SLOEND
      Else
         Diszo [M:SUD1]SLOSTR
         Diszo [M:SUD1]SLOEND
      Endif
   Else
      Actzo [M:SUD1]SLOSTR
      Actzo [M:SUD1]SLOEND
   Endif
   If dim([M:SUD1]ECCVALMAJ)>0
      Raz    [M:SUD1]ECCVALMAJ
      Raz    [M:SUD1]ECCVALMIN
      Raz    [M:SUD1]ECCSTA
      Affzo  [M:SUD1]ECCVALMAJ
      Affzo  [M:SUD1]ECCVALMIN
      Affzo  [M:SUD1]ECCSTA
      Diszo  [M:SUD1]ECCVALMAJ
      Diszo  [M:SUD1]ECCVALMIN
      Diszo  [M:SUD1]ECCSTA
    Endif
Else
   If dim([M:SUD1]ECCVALMAJ)>0
      If [F:ITM]ECCSTO > 2
         Actzo  [M:SUD1]ECCVALMAJ
         Actzo  [M:SUD1]ECCVALMIN
      Endif
      If [F:ITM]ECCSTO = 2
         Actzo  [M:SUD1]ECCVALMAJ
      Endif
   Endif
#                                                           # Hcb 71276 fin
Endif

End


