Local Mask DEBUGGER2 [DBG2]
Local Mask DEBUGGER3 [DBG3]
Local Mask DEBUGGER4 [DBG4]
Local Mask DEBUGGER5 [DBG5]
Local Mask DEBUGGER6 [DBG6]
Local Mask DEBUGGER7 [DBG7]
Local Mask DEBUGGER8 [DBG8]



Local Integer DBG_ERR, DBG_I
Local Integer DBG_K

Gosub INIT_MSK From DEBUGGERSUB

MAVARIABLEDL = "azerty"

Infbox MAVARIABLEDL + [M:DBG2]MEM1(3) +":"+ num$([M:DBG2]MEM2(3)) +","+ num$([M:DBG2]MEM3(3)) +","+ num$([M:DBG2]MEM4(3)) +","+ num$([M:DBG2]MEM5(3))


End

#**
#* Return folder info (displayed in About dialog) 
#* @param FLDER folder
#* @return info values
#*!
Funprog GET_PROJECT_INFO(FLDER)
Value Char FLDER

Local Char NEWLINE_SEP(4) : NEWLINE_SEP = "#NL#"
Local Char VALUE_SEP(4)   : VALUE_SEP   = "#SP#"

Local Char VERSION, RELEASE, NOPATCH
Local Char PROCESS_SVR(255)
Local Char RESULT(255)

Call VERSX3(FLDER, VERSION, RELEASE, NOPATCH) From INTRUTILA

# Process server
PROCESS_SVR = ""
Local Char CHAINE
Local Integer I
CHAINE = ver$(0)
I = instr(1,CHAINE," ")
If I
 CHAINE = right$(ver$(0),I+1)
 I = instr(1, CHAINE," ")
 PROCESS_SVR = left$(CHAINE,I)
Endif

RESULT = "VER" + VALUE_SEP + VERSION + NEWLINE_SEP + 
&        "REL" + VALUE_SEP + RELEASE + NEWLINE_SEP +
&        "PCH" + VALUE_SEP + NOPATCH + NEWLINE_SEP +
&        "PROSVR" + VALUE_SEP + vireblc(PROCESS_SVR,1) + NEWLINE_SEP + 
&        "SOL" + VALUE_SEP + GINSTID + NEWLINE_SEP +
&        "SOLVER" + VALUE_SEP + GVERSOL + NEWLINE_SEP +
&        "SOLADR" + VALUE_SEP + "http://"+GVIRTDIR+"/" + NEWLINE_SEP 

End RESULT




Funprog GETFILES(DOSSIER, START, FILTERS, NBMAX, FILEEXT, FILEDIR)
Value Char    DOSSIER()
Value Char    START()
Value Char    FILTERS()
Value Char    NBMAX()
Value Char    FILEEXT()
Value Char    FILEDIR()

Local Char    FILTRE(250), REPERT(GDIMFIC)
Local Char    MACHINE(250), APPLI(GLONADS), ORDSYS(250)
Local Char    CODTRT(GLONADC)
Local Integer NB_TRT, K
Local Integer NB_MAX

Local Clbfile FILES(10)

Local Char VALUE_SEP(4)   : VALUE_SEP   = "#SP#"

# Default values initialization
If NBMAX = "-1" : NB_MAX = GNBSEL : Else : NB_MAX = val(NBMAX) : Endif
If DOSSIER="" : DOSSIER = nomap : Endif

Call MACHINE(DOSSIER, MACHINE, APPLI) From ORDSYS
REPERT = filpath(FILEDIR, "", "", APPLI, "", MACHINE)

# Insert start filter (is present)
If START="" 
  FILTRE = ""
Else
  FILTRE = 'TRT>="'+START+'"'
Endif

# Exclude empty named files
If FILTRE<>"" : FILTRE += "&" : Endif
FILTRE += 'TRT<>""'

# insert caller filters
If FILTERS<>"" 
  If FILTRE<>"" : FILTRE += "&" : Endif
  FILTRE += FILTERS
Endif

If clalev([F:TRT_])>0 : Close Local File [TRT_] : Endif
Case FILEEXT
 When "src"
  ORDSYS = MACHINE+"@"+'lsadx -a'-toupper(APPLI)-REPERT-FILEEXT
 When "stc"
  ORDSYS = MACHINE+"@"+'lsadx -a'-toupper(APPLI)-REPERT-FILEEXT
 When Default
  ORDSYS = MACHINE+"@"+'archive -d '+DOSSIER-' -t "src" -l "*"'
Endcase
Local File (TRT(30)) From System ORDSYS As [TRT_]

NB_TRT =0

For [TRT_] Where evalue(FILTRE)
 NB_TRT += 1
 If NB_TRT > NB_MAX
   Break
 Endif
 FILES+=[F:TRT_]TRT+VALUE_SEP
Next TRT_

End FILES

$KEEP_ERROR
ER = errn
Resume

#################################################################
#                       Test lsadx function                     #
#################################################################
Subprog TEST_LSADX
Local Clbfile LIST(10)
Local Char    DATE_START
Local Char    DATE_END

DATE_START = format$(GFMD,date$)-"-"-time$
LIST = func GETFILES("SUPERV", "", "", "50000", "SRC", "TRT")
DATE_END = format$(GFMD,date$)-"-"-time$

Infbox "Début: "-DATE_START-"  Fin :"-DATE_END

End
