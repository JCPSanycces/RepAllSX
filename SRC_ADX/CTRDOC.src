#Global Integer ACTSELECT

Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("CTR",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "OK"        : Gosub OK
 When "DEBUT"     : Gosub DEBUT
 When "FINSAI"    : If FLGOK : mkstat = 4 : Endif
Endcase
Return

$OUVRE
Local Integer FLGOK
FLGOK = 0
If clalev([F:HRDOC])=0  : Local File HRCTRDOC   [HRDOC] : Endif
If clalev([F:HRCLC])=0  : Local File CLACTR     [HRCLC] : Endif
If clalev([F:HRTXC])=0  : Local File TXTCTR     [HRTXC] : Endif

Return

## Chargement du tableau "Documents" avec les doc de l'écran


$DEBUT
Local Char NUMLIB(10)
Local Integer PNOLIB
Local Shortint WOKLEG
Local Integer NBDOC, I, J, NBMAX
Local Integer ONLEG #MABOS - 08/01/13-FQ81085-US1126- 1 = Parameter TYPDOC on the leg
Raz [M:CDOC]
[M:CDOC]REFNUM=PARAM(1)
Read [F:ID]ID0=[M:CDOC]REFNUM
[M:CDOC]NAM =[F:ID]NAM - [F:ID]SRN
[M:CDOC]CTRNUM=PARAM(2)
[M:CDOC]CTRDAT=PARAM(3)
#[M:CDOC]LEG=PARAM(4)
Affzo [M:CDOC]

#MABOS - 08/01/13-FQ81085-US1126- 1 = Parameter TYPDOC on the leg
[M:CDOC]ONLEG=0
Call PARAM(PARAM(4),"TYPDOC",[L]NUMLIB,ONLEG) From SUBHRCLC

 If val([L]NUMLIB) = 0 Then
    GERR=1 : FIN=1
    GMESSAGE=mess(157,10701,1) :# Le paramètre TYPDOC n'est pas correctement renseigné
    Return
 Endif
If [L]NUMLIB<>"0" & [L]NUMLIB<>"" Then
    [L]PNOLIB=val([L]NUMLIB)
    [M:CDOC]NOLIB=[L]PNOLIB
    [M:CDOC]ONLEG=[L]ONLEG
    Affzo [M:CDOC]NOLIB
Endif

I=0
#For nolign=1 To dim(NBDOC)
#For [HRDOC] Where REFNUM=[M:CDOC]REFNUM & CTRNUM=[M:CDOC]CTRNUM & CTRDAT=[M:CDOC]CTRDAT
#
#  [M:CDOC]DOCGEN(I)=[F:HRDOC]COD
#  [M:CDOC]DOCGENA(I)=mess([M:CDOC]DOCGEN(I),[M:CDOC]NOLIB,1)
#  [M:CDOC]SELFLG(I)=1
# I+=1
#[M:CDOC]DOCGEN = [F]
# If GNAVIG(GPILNAV)="GESHRENT"
#  If evalue(PARAM(2)+num$(nolign-1)+"("+PARAM(1)+")")<>""
#   [M:MCL]CLASPE(nolign-1) = evalue(PARAM(2)+num$(nolign-1)+"("+PARAM(1)+")")
#  Else
#   Break
#  Endif
# Else
#  If evalue(PARAM(2)+"("+num$(nolign-1)+")")<>""
#   [M:MCL]CLASPE(nolign-1) = evalue(PARAM(2)+"("+num$(nolign-1)+")")
#   If dim([M:MCL]LEG) > 0 Then
#   [M:MCL]LEG(nolign-1) = evalue(PARAM(4)+"("+num$(nolign-1)+")")
#   Endif


##Translatable description
# If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
# If dim([M:MCL]LEG(nolign-1))>0
#     Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANGUE;[M:MCL]CLASPE(nolign-1);[M:MCL]LEG(nolign-1)
# Else
#     Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANGUE;[M:MCL]CLASPE(nolign-1);GCURLEG
# Endif
#      If fstat=0
#      [M:MCL]DESCLA(nolign-1) = [F:AXX]TEXTE
#      Else
#      If dim([M:MCL]LEG(nolign-1))>0
#       Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANDEF;[M:MCL]CLASPE(nolign-1);[M:MCL]LEG(nolign-1)
#      Else
#       Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANDEF;[M:MCL]CLASPE(nolign-1);GCURLEG
#      Endif
#If fstat=0
#        [M:MCL]DESCLA(nolign-1) = [F:AXX]TEXTE
#       Else
#        [M:MCL]DESCLA(nolign-1) = ""
#       Endif
#      Endif
#  Else
#   Break
#  Endif
# Endif
#Next
NBDOC = len(mess(0,[M:CDOC]NOLIB,1))
nolign=0
For I=1 To NBDOC
  [M:CDOC]DOCGEN(I-1)=I
  [M:CDOC]DOCGENA(I-1)=mess([M:CDOC]DOCGEN(I-1),[M:CDOC]NOLIB,1)
  [M:CDOC]SELFLG(I-1)=1
Next

[M:CDOC]NBDOCGEN = I-1

I=1
J=1
NBMAX=min(dim([F:HRDOC]CLAUSESPE), dim([M:CDOC]CLASPE))

#For nolign=1 To dim(NBDOC)
For [HRDOC] Where REFNUM=[M:CDOC]REFNUM & CTRNUM=[M:CDOC]CTRNUM & CTRDAT=[M:CDOC]CTRDAT
  I=find ([F:HRDOC]COD,[M:CDOC]DOCGEN)
  If I > 0
    [M:CDOC]SELFLG(I-1)=[F:HRDOC]FLGCRE
    For J=1 To NBMAX
      ZONE="[M:CDOC]CLASPE"+num$(J)+"(I-1)"
      Assign ZONE With [F:HRDOC]CLAUSESPE(J-1)
      ZONE="[M:CDOC]LEG"+num$(J)+"(I-1)"
      Assign ZONE With [F:HRDOC]CLAUSESPELEG(J-1)
    Next J

  Endif
Next
If [M:CDOC]NBDOCGEN
  NOL=0 : Gosub CHARGE_CLC
Endif

Affzo [M:CDOC]
Return




$CHARGE_CLC
Effzo [M:CDOC]15
For I=0 To dim([M:CDOC]CLASPE)-1
 If evalue("[M:CDOC]CLASPE"+num$(I+1)+"("+num$(NOL)+")")="" : Break : Endif
 [M:CDOC]CLASPE(I)=evalue("[M:CDOC]CLASPE"+num$(I+1)+"("+num$(NOL)+")")
 [M:CDOC]LEG(I)=evalue("[M:CDOC]LEG"+num$(I+1)+"("+num$(NOL)+")")
Next
[M:CDOC]NBCLC=I
[M:CDOC]WLIG=NOL
[M:CDOC]DOCCLA=[M:CDOC]DOCGEN(NOL)


Return

$DECHARGE_CLC
Local Integer I
Local Integer NOL
Local Char    CLASSE(10) , NAMFLD(GLONAVA)
CLASSE = clanam([M])
NOL=[M:CDOC]WLIG


For I=0 To dim([M:CDOC]CLASPE)-1
 For NAMFLD="CLASPE","LEG"
   Assign CLASSE+NAMFLD+num$(I+1)+"("+num$(NOL)+")" With evalue(CLASSE+NAMFLD+"("+num$(I)+")")
 Next
Next I

Return

$SETNOL
Local Integer NOL
NOL=nolign-1
Return

Subprog AS_NBDOCGEN
Gosub SETNOL
If NOL>=0 & [M]NBDOCGEN>0
 If NOL<=[M]NBDOCGEN
  Chgstl [M]NBDOCGEN With ""
#  Chgstl [M]NBDOCGEN(NOL) With "AMKCUR":# on ne fait pas toute la ligne car le champ du flag n'est pas beau
  Chgstl [M]DOCGENA(NOL) With "SELLIG":# "AMKCUR"
  Chgstl [M]ICODOC2(NOL) With "SELLIG":#"AMKCUR"
  Affzo [M]NBDOCGEN(nolign)
  Gosub CHARGE_CLC
  Actzo [M:CDOC]NBCLC
  Affzo 15
 Else
  Effzo 15
  Diszo [M:CDOC]NBCLC
 Endif
Endif
End


## Affectation des zones invisibles de l'écran par le tableau "clauses"
#
$OK
#For I=1 To dim([M:MCL]CLASPE)
#
# If GNAVIG(GPILNAV)="GESHRENT"
#  Assign PARAM(2)+num$(I-1)+"("+PARAM(1)+")" With [M:MCL]CLASPE(I-1)
# Else
#  Assign PARAM(2)+"("+num$(I-1)+")" With [M:MCL]CLASPE(I-1)
#  If dim([M:MCL]LEG(nolign-1))>0
#  Assign PARAM(4)+"("+num$(I-1)+")" With [M:MCL]LEG(I-1)
#  Endif
# Endif
#Next
#FLGOK = 1
GOK = 1
Local Char    CLASSE(10) , NAMFLD(GLONAVA)
Local Integer I,K,NBMAX
CLASSE = clanam([M])
NBMAX=min(dim([F:HRDOC]CLAUSESPE), dim([M:CDOC]CLASPE1))

Trbegin [HRDOC]
Delete [HRDOC] Where REFNUM=[M:CDOC]REFNUM & CTRNUM=[M:CDOC]CTRNUM & CTRDAT=[M:CDOC]CTRDAT
If fstat=1
   GOK = -1 : GLOCK = "$HRDOC"-num$([F:HRDOC]COD)-[M:CDOC]REFNUM-[M:CDOC]CTRNUM-[M:CDOC]CTRDAT
Endif

If !GOK  Goto AB_TR1 : Endif
If !GOK : Return : Endif
For K=0 To [M:CDOC]NBDOCGEN-1
  If [M:CDOC]SELFLG(K) = 2
     Raz [F:HRDOC]
     [F:HRDOC]REFNUM=[M:CDOC]REFNUM
     [F:HRDOC]CTRNUM=[M:CDOC]CTRNUM
     [F:HRDOC]CTRDAT=[M:CDOC]CTRDAT
     [F:HRDOC]COD=[M:CDOC]DOCGEN(K)
     [F:HRDOC]FLGCRE=[M:CDOC]SELFLG(K)
     For I=1 To NBMAX
       For NAMFLD="CLASPE","LEG"
          Case NAMFLD
            When "CLASPE"
              If evalue(CLASSE+NAMFLD+num$(I)+"("+num$(K)+")") <> ""
                 [F:HRDOC]CLAUSESPE(I-1)=evalue(CLASSE+NAMFLD+num$(I)+"("+num$(K)+")")
              Endif
            When "LEG"
              If evalue(CLASSE+NAMFLD+num$(I)+"("+num$(K)+")") <> ""
                [F:HRDOC]CLAUSESPELEG(I-1)=evalue(CLASSE+NAMFLD+num$(I)+"("+num$(K)+")")
              Endif
          Endcase
       Next
     Next
     Gosub CREUSR
     Write
     If fstat
        GOK = 0 : Call FSTA("HRDOC") From GLOCK : Break
    Endif
  Else
    Gosub SUPP_TXTCTR
    If !GOK : Break : Endif
  Endif
Next
If !GOK  Goto AB_TR1 : Endif
If !GOK : Return : Endif


If find (2,[M:CDOC]SELFLG) > 0
  PARAM(5)="2"
  PARAM(6)="2"
Else
  PARAM(5)="1"
  PARAM(6)="1"
Endif

Commit

Return

$AB_TR1
Rollback
Return

$SUPP_TXTCTR
 Delete [HRTXC]TXC2(4)=[M:CDOC]REFNUM;[M:CDOC]CTRNUM;[M:CDOC]CTRDAT;[M:CDOC]DOCGEN(K)
 ###
 If fstat=1
  GOK = -1 : GLOCK = "$TXTCTR"-[M:CDOC]REFNUM-[M:CDOC]CTRNUM-[M:CDOC]CTRDAT-num$([M:CDOC]DOCGEN(K))
 Endif
Return

$CREUSR
If dim([F]CREDAT)>0 : [F]CREDAT = date$     : Endif
If dim([F]CRETIM)>0 : [F]CRETIM = time      : Endif
If dim([F]CREUSR)>0 : [F]CREUSR = GUSER     : Endif
If dim([F]EXPNUM)>0 : [F]EXPNUM = [C]EXPORT : Endif
Return

$MODUSR
If dim([F]UPDDAT)>0 : [F]UPDDAT = date$     : Endif
If dim([F]UPDTIM)>0 : [F]UPDTIM = time      : Endif
If dim([F]UPDUSR)>0 : [F]UPDUSR = GUSER     : Endif
If dim([F]EXPNUM)>0 : [F]EXPNUM = [C]EXPORT : Endif
Return

