## Etiquette ajoutée par le superviseur (écran CTRDOC) 14/01/2013 15:58:48 (SEGAY)
######################################################################################
Subprog AS_NBCLC
If [M:CDOC]SELFLG([M:CDOC]WLIG)=1
  Diszo [M:CDOC]NBCLC
Else
  Actzo [M:CDOC]NBCLC
Endif
End

Subprog C_NBCLC

# 21=clique vers un tableau, 1029 = bouton OK
If status=21 or status=1029 Then
  Gosub DECHARGE_CLC
Endif
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran CTRDOC) 18/01/2013 14:51:26 (SEGAY)
######################################################################################
Subprog AS_ICODOC2(VALEUR)
Variable Char    VALEUR()
If [M]SELFLG(nolign-1)<>2
 mkstat=2 : End
Endif
End

Subprog CL_ICODOC2(VALEUR)
Variable Char    VALEUR()
Local Char CRITERE(250)
CRITERE = "REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT=[M]CTRDAT & DOCCLA=[M]DOCGEN(nolign-1)"
Call LECTXC(CRITERE)

End


Subprog LECTXC(CRITERE)
Value Char CRITERE
Local Char TABCLE (20)(0..3)
#Local Char DAT
Local Char CTR (GLONHRCTR)
If clalev([F:HRTXC])=0 : Local File TXTCTR [HRTXC] : Endif
Filter [HRTXC] Where evalue(CRITERE)
Read[HRTXC]TXC0 First
Filter [HRTXC]
If ! fstat
# DAT       = num$([HRTXC]CTRDAT)
# TABCLE(0) = [HRTXC]REFNUM
# TABCLE(1) = num$([HRTXC]DOCCLA)
# TABCLE(2) = [HRTXC]CODCLA
# Call OBJET ("TXC",DAT,TABCLE) From GOBJET

 CTR       = [HRTXC]CTRNUM
 TABCLE(0) = [HRTXC]REFNUM
 TABCLE(1) = num$([HRTXC]CTRDAT)
 TABCLE(2) = num$([HRTXC]DOCCLA)
 TABCLE(3) = [HRTXC]CODCLA

 Call OBJET ("TXC",CTR,TABCLE) From GOBJET

Else
 Raz [F:HRTXC]
 GMESSAGE = mess(7,10715,1)
 mkstat = 2 : End
Endif
End


