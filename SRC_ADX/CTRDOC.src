######################################################################################
## Etiquette ajoutée par le superviseur (écran CTRDOC) 04/01/2013 17:38:35 (MABOS)
######################################################################################
Subprog AS_ICODOC(VALEUR)
Variable Char    VALEUR()
End


######################################################################################
Subprog AS_CLASPE(VALEUR)
Variable Char    VALEUR()
If VALEUR =""
   Raz [F:HRCLC]
Endif
End



Subprog C_CLASPE(VALEUR)
Variable Char    VALEUR()
#Call UNICITE(VALEUR,[M:CDOC]CLASPE(0..[M:CDOC]NBCLC-1)) From OBJDIV

Local Integer I, NOL
NOL = nolign-1
For I=0 To [M]NBCLC-1
  If I<>NOL Then
    If VALEUR=[M:CDOC]CLASPE(I)    Then
     GERR=1
     GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
     mkstat=2 : End
   Endif
  Endif
Next
End

######################################################################################
## Default to LEG when typed in, if appropriate - SPE and matching DOCCLA type
######################################################################################
Subprog AM_CLASPE(VALEUR)
Variable Char    VALEUR()
Local Integer DOCNUM


If [M:CDOC]ACTSELECT(nolign-1)<>2

DOCNUM=DOCCLA


Filter [F:HRCLC] Where [F:HRCLC]TYPCLA=2 and [F:HRCLC]LEG=GCURLEG and [F:HRCLC]CODCLA=VALEUR and find(DOCNUM, [F:HRCLC]DOCCLA(0..9))>0
Look [HRCLC]CLC0 First

 If  fstat =4
[M:CDOC]LEG(nolign-1) = ""
Else
[M:CDOC]LEG(nolign-1) = GCURLEG
Endif


Endif


 ##Translatable description
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
 If dim([M:CDOC]LEG(nolign-1))>0
    Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANGUE; VALEUR;[M:CDOC]LEG(nolign-1)
 Else
     Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANGUE; VALEUR;GCURLEG
 Endif
      If fstat=0
      [M:CDOC]DESCLA(nolign-1) = [F:AXX]TEXTE

      Else

 If dim([M:CDOC]LEG(nolign-1))>0
       Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANDEF; VALEUR;[M:CDOC]LEG(nolign-1)
      Else
        Read [AXX]AXX0 = "CLACTR";"DESCLA";GLANDEF; VALEUR;GCURLEG
      Endif
       If fstat=0
        [M:CDOC]DESCLA(nolign-1) = [F:AXX]TEXTE
       Else
        [M:CDOC]DESCLA(nolign-1) = ""
       Endif
      Endif
 [M:CDOC]ACTSELECT(nolign-1)=0

End


