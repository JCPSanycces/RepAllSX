#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
##########################################################################################################
# FLORENT ICI : multisoc retiré pour le moment. Je laisse tout ça en commentaire comme ça quand ça
#               reviendra, tout sera prévu
##########################################################################################################
$CRM_OPEN_BPR_VENTE
If 0=1 Then
  If dim(GCRM_BPR_BEFORE) <= 0 Then
    Global Integer GCRM_BPR_BEFORE
  Endif
  # 0 BPR N'existe pas 
  # 1 BPR sur table BPARTNER
  # 2 BPR sur vue
  If clalev([F:BPR]) = 0 Then
    GCRM_BPR_BEFORE = 0
    Local File WVCPYBR1 [BPR]        
  Else
    If dim([F:BPR]WCPY) <= 0 Then
      GCRM_BPR_BEFORE = 1
      Close Local File [BPR]
      Local File WVCPYBR1 [BPR]
    Else
      GCRM_BPR_BEFORE = 2
    Endif   
  Endif
Endif
Return

##########################################################################################################
$CRM_CLOSE_BPR_VENTE
If 0=1 Then
  Case GCRM_BPR_BEFORE
    When 0
      Close Local File [BPR]
    When 1
      Close Local File [BPR]    
      Local File BPARTNER [BPR]
  Endcase
Endif
Return

##########################################################################################################
$CRM_OPEN_BPC_VENTE
If 0=1 Then
  If dim(GCRM_BPC_BEFORE) <= 0 Then
    Global Integer GCRM_BPC_BEFORE
  Endif
  # 0 BPR N'existe pas 
  # 1 BPR sur table BPCUSTOMER
  # 2 BPR sur vue
  If clalev([F:BPC]) = 0 Then
    GCRM_BPR_BEFORE = 0
    Local File WVCPYBR1 [BPR]        
  Else
    If dim([F:BPC]WCPY) <= 0 Then
      GCRM_BPC_BEFORE = 1
      Close Local File [BPC]
      Local File WVCPYBC1 [BPC]
    Else
      GCRM_BPC_BEFORE = 2
    Endif   
  Endif
Endif
Return

##########################################################################################################
$CRM_CLOSE_BPC_VENTE
If 0=1 Then
  Case GCRM_BPC_BEFORE
    When 0
      Close Local File [BPC]
    When 1
      Close Local File [BPC]    
      Local File BPCUSTOMER [BPC]
  Endcase
Endif
Return
