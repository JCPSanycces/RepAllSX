#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe FREFLD

# *************
#  METHODS
# *************

$EVENTS
  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE
        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE
      Endcase
  Endcase
Return

$METHODS
  Gosub METHODS From FREFLD_C_MPR
Return

# *************
#  PROPERTIES
# *************

$PROPERTIES
   Gosub PROPERTIES From FREFLD_C_PRO
Return


# -------------------------------------
# FREFLD standard data class methods
# -------------------------------------
$AREAD_AFTER


  Local Integer LNB : # Line number
  Local Integer N_I : # free fields number
  Local Char XDES(30), XALPDES(30), XAMTDES(30), XRATDES(30), XDATDES(30)

 # loading ADI table designation and free fields designations
 LNB = 1
 For N_I = 1 To maxtab(this.FRFALP)
    If this.FRFALP(LNB).ALPREF <> AVOID.AINT
       Call LECTEXTRA(XDES,"ATABTAB","LNGDES", num$(this.FRFALP(LNB).ALPREF),"") From FREFLD_C_MPR
       this.FRFALP(LNB).INTITADI = XDES
    Endif
    LNB += 1
 Next

Return


$AINSERT_CONTROL_BEFORE
  Local File FREFLD [FRF]
  Read [F:FRF]FRF0=this.OBJ;this.CPY
  If fstat = [V]CST_AOK
     # FRF005 This setting already exists
     [L]ASTATUS = fmet this.ASETERROR("FRF", mess(54,[V]CST_MSGMIS, 1), [V]CST_AFATAL)
    Return
  Endif
  Gosub CONTROL_BEFORE
Return

$AUPDATE_CONTROL_BEFORE
Local Char  ERRMSG(100)
#
Local Integer NCHGPRO : # Number of changed properties
Local Char    CHGPRO(12)(1..)
Local Char    PRO(12)

  # Get changed properties
  [L]NCHGPRO=this.getModified([L]CHGPRO)

  # Check if hereunder properties have been changed
  For [L]PRO = "OBJ", "CPY"
    If find([L]PRO, [L]CHGPRO) > 0
      # Modification is impossible : $1$ property must not be modified
      [L]ERRMSG = func AFNC.MES1(mess(56,[V]CST_MSGMIS, 1), [L]PRO)
      [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    Endif
  Next [L]PRO

  Gosub CONTROL_BEFORE
Return

$ADELETE_CONTROL_BEFORE

  #  Development environnement
  Local Integer PADONIX
  [L]PADONIX = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,"","ADONIX")

  If not ([L]PADONIX = CST_AYES)
    # Deletion impossible
    [L]ASTATUS = fmet this.ASETERROR("FRF",  "Deletion forbidden", [V]CST_AERROR)
  Endif

Return

$CONTROL_BEFORE

# At this level you can write control for insert or update.
# You can differenciate those two situations with the values
# [V]CST_ANEW, [V]CST_AUPD of this.ASTALIN class property

Local Char  MSG(100)
Local Char  ERRMSG(100)
Local Integer RET
Local Integer STA


#- OBJ -------


#- CPY --------

#
#- Collections FRFALP, FRFAMT,  FRFDAT, FRFRAT-----

Return

