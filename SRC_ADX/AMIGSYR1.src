#<AdxTL>@(#)5.0.0.0 $Revision$

  Call OUVRE_TRACE("Syracuse transition phase 1") From LECFIC
  Call GENE("","",chr$(255),1,1)
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC

End
Subprog GENE(DOSSIER,FIRST_OBJ,LAST_OBJ,GENE,SUPP)
Value Char FIRST_OBJ,LAST_OBJ
Value Char DOSSIER
Value Libelle GENE,SUPP

Local Integer OK
Local Char OBJECT(10)
Local Char CHAINE(255)

If DOSSIER="" : DOSSIER=nomap : Endif

If !clalev([AOB2]) : Local File =DOSSIER+".AOBJET" [AOB2] : Endif
  For [AOB2] Where [AOB2]TYPGES<=2 and [AOB2]ABREV>=FIRST_OBJ and [AOB2]ABREV<=LAST_OBJ
    Call ANALYZE(DOSSIER,[AOB2]ABREV,GENE,SUPP)
  Next
End

# Program analyzing an object
# Fills the following variables :
# TABLES, ABREV, TABABREV : table names, abbreviations, name/abbreviation concatenation
# LEVEL=link level : 0=undefined, 1=main table, 2=1-1 links, 3=1-N links, -1=link found only on references
# CLELNK=link key if not the first one and if LEVEL>=1, EXPLNK=link expression

Subprog CLOSE_FILE : # In order to manage call for several folders
  If clalev([AOB]) : Close Local File [AOB] : Endif
  If clalev([AOB1]) : Close Local File [AOB1] : Endif
  If clalev([AOB2]) : Close Local File [AOB2] : Endif
  If clalev([ATB]) : Close Local File [ATB] : Endif
  If clalev([ATX]) : Close Local File [ATX] : Endif
  If clalev([ATB1]) : Close Local File [ATB1] : Endif
  If clalev([ATZ]) : Close Local File [ATZ] : Endif
  If clalev([ATZ1]) : Close Local File [ATZ1]: Endif
  If clalev([ATI]) : Close Local File [ATI] : Endif
  If clalev([AMK]) : Close Local File [AMK] : Endif
  If clalev([AMK1]) : Close Local File [AMK1]: Endif
  If clalev([AMZ]) : Close Local File [AMZ] : Endif
  If clalev([ATY]) : Close Local File [ATY] : Endif
  If clalev([ACV]) : Close Local File [ACV] : Endif
  If clalev([AOT]) : Close Local File [AOT] : Endif
  If clalev([AWI]) : Close Local File [AWI] : Endif
  If clalev([AWM]) : Close Local File [AWM] : Endif
  If clalev([AWK]) : Close Local File [AWK] : Endif
  If clalev([AHD]) : Close Local File [AHD] : Endif
End

Subprog ANALYZE(DOSSIER,OBJECT,GENE,SUPP)
Value Char OBJECT
Value Char DOSSIER
Value Libelle GENE,SUPP

# Miscellaneous variables
Local Integer I,J,K,L,M,N,P,Q,ITB,MAXT, MAXR
Local Char TEXTLEVEL(10)(1..4)
Local Integer OLDVER

OLDVER=pat(GVERSION,"1.6*")

# Constants
  MAXT=100
  TEXTLEVEL(1)="(0,1)" : TEXTLEVEL(2)="(1,1)" :   TEXTLEVEL(3)="(0,N)" :   TEXTLEVEL(4)="(1,N)" :

# Open the tables
  If !clalev([AOB]) : Local File =DOSSIER+".AOBJET" : Endif
  If !clalev([AOB1]) : Local File =DOSSIER+".AOBJET" [AOB1] : Endif
  If !clalev([ATB]) : Local File =DOSSIER+".ATABLE" : Endif
  If !clalev([ATX]) : Local File =DOSSIER+".ATEXTE" : Endif
  If !clalev([ATB1]) : Local File =DOSSIER+".ATABLE" [ATB1] : Endif
  If !clalev([ATZ]) : Local File =DOSSIER+".ATABZON" : Endif
  If !clalev([ATZ1]) : Local File =DOSSIER+".ATABZON" [ATZ1]: Endif
  If !clalev([ATI]) : Local File =DOSSIER+".ATABIND" : Endif
  If !clalev([AMK]) : Local File =DOSSIER+".AMSK" : Endif
  If !clalev([AMK1]) : Local File =DOSSIER+".AMSK" [AMK1]: Endif
  If !clalev([AMZ]) : Local File =DOSSIER+".AMSKZON" : Endif
  If !clalev([ATY]) : Local File =DOSSIER+".ATYPE" : Endif
  If !clalev([ACV]) : Local File =DOSSIER+".ACTIV" : Endif
  If !clalev([AOT]) : Local File =DOSSIER+".AOBJTAB" : Endif
  If !clalev([AWI]) : Local File =DOSSIER+".AWINDOW" : Endif
  If !clalev([AWM]) : Local File =DOSSIER+".AWRKLNK" : Endif
  If !clalev([AHD]) : Local File =DOSSIER+".AHISTOD" : Endif
  If OLDVER=0 : If !clalev([AWK]) : Local File =DOSSIER+".AWRKTAB" : Endif : Endif
# If !clalev([]) : Local File : Endif

# Buffers for analyzing
# Tables found (a table may be repeated if the abbreviation is different)
Local Integer NB_TABLES
Local Char TABLES(GLONATB)(1..MAXT), ABREV(GLONABR)(1..MAXT),TABABREV(GLONATB+GLONABR+1)(1..MAXT), FIRSTKEYS(GLONANX)(1..MAXT)
Local Char TABANA(GLONATB+GLONABR+5)
Local Char ELTCLES(20)(1..MAXT,1..16)
Local Integer NB_ELT(1..MAXT)
Local Libelle PERSISTENT(1..MAXT)
Local Char ADD_TABLES(GLONATB)(1..MAXT),LNK_ADDTABLES(GLONATB)(1..MAXT)
Local Integer NB_ADDTABLES

# Link characteristics
Local Char CLELNK(GLONANX)(1..MAXT), TBLLNK(100)(1..MAXT), ORILINK(GLONATB)(1..MAXT), ORIABREV(GLONABR)(1..MAXT)
Local Char EXPLNK(100)(1..MAXT)
Local Integer DEPTHLNK(1..MAXT)
Local Integer LEVEL(1..MAXT)

# For some exceptions
Local Char LINKEXPR1(100),LINKEXPR2(100)

# Miscallaneous
Local Char CHAINE(250), CHAINE1(250)
Local Integer TLINK(1..MAXT,1..16)
Local Integer NEK(1..MAXT)

# Read the main object record, verify it exists with the right type
  Read [AOB]ABREV=OBJECT
  If fstat<>0 or [AOB]TYPGES>2 : End : Endif

# Read and analyze the main tables
  Read [ATB]CODFIC=[AOB]NOMFIC
  TABANA=[AOB]NOMFIC : Gosub ANA_TBL

# Read and analyse the linked tables
  For [AOT]ABREV Where [AOT]ABREV=OBJECT and [AOT]TABLIEN<>"" and find([AOT]TABFIC,'ATEXTRA','ATEXTE')=0
    TABANA=vireblc([AOT]TABFIC-[AOT]TABABR,2) : Gosub ANA_TBL
    If CLELNK(ITB)="" and EXPLNK(ITB)=""
      CLELNK(ITB)=[AOT]TABCLE
      EXPLNK(ITB)=[AOT]TABLIEN

      LEVEL(ITB)=1 : # link is (0,1) for the moment

      # Let's try to figure out the characteristics of the field on which the link is based
     # if this field is unique (in order to know if it is mandatory (link will become (1,1)) and to add (indice) if multi-dimensioned
      If EXPLNK(ITB)<>"" and instr(1,EXPLNK(ITB),";")=0 and (instr(1,EXPLNK(ITB),"]")=0 or pat(EXPLNK(ITB),"[??*]*")=1)
        I=instr(1,EXPLNK(ITB),"]")
        If I
          CHAINE=right$(EXPLNK(ITB),I+1)
          CHAINE1=vireblc(ctrans(left$(EXPLNK(ITB),I-1),"[]","  "),2)
        Else
          CHAINE=EXPLNK(ITB)
          CHAINE1=""
        Endif

      # Search if the field exists in the right table, or in a table located prior the current one (I will be not null, and [ATZ] on line)
        If CHAINE1<>""
          If left$(CHAINE1,2)="F:" : CHAINE1=right$(CHAINE1,3) : Endif
          I=find(CHAINE1,ABREV(1..NB_TABLES))
          If I
            Read [ATZ]CODZONE=TABLES(I);CHAINE
            If fstat<>0 : I=0 : Endif
          Endif
        Else
          For I=1 To ITB-1
            Read [ATZ]CODZONE=TABLES(I);CHAINE
            Break (fstat=0)
          Next I
          I*=(I<>ITB+1)
        Endif
        If I
          LEVEL(ITB)+=[ATZ]OBLIG=2 : # (0,1) will become (1,1) if the field is mandatory
          If [ATZ]DIME>1
            EXPLNK(ITB)+="(indice)"
          Elsif [ATZ]DIME=0
            Read [ACV]CODACT=[ATZ]CODACT
            If [ACV]TYP=2
              EXPLNK(ITB)+="(indice)"
            Endif
          Endif
        Endif
      Endif
      If CLELNK(ITB)=""
        CLELNK(ITB)=FIRSTKEYS(ITB)
      Endif
    Endif
  Next

# Prepare a list of additional tables to analyze
# This includes the grids declared for import and the tables found in a purge formula if one exists
  For I=0 To [AOB]NBRIMP-1
    NB_ADDTABLES+=1 : ADD_TABLES(NB_ADDTABLES)=[AOB]IMPTBL(I) : LNK_ADDTABLES(NB_ADDTABLES)=""
  Next I
  CHAINE=""
  For [AHD] Where LIG=1 and TBL=TABLES(1)
    CHAINE=[AHD]COD
    Break
  Next
  If CHAINE<>""
    For [AHD]Where COD=CHAINE and I>1
      I=find([AHD]TBL,ADD_TABLES(1..NB_ADDTABLES))
      If I=0
        NB_ADDTABLES+=1 : ADD_TABLES(NB_ADDTABLES)=[AHD]TBL : LNK_ADDTABLES(NB_ADDTABLES)=[AHD]LNKTBL
      Else
        LNK_ADDTABLES(I)=[AHD]LNKTBL
      Endif
    Next
  Endif

# Add also the tables declared in the mask of the main window (23th of May addition)
  For [AWI]AWI2 Where OBJ=OBJECT and TRN=""
    I=1
    Break
  Next I
  If I=0
    For [AWI]AWI2 Where OBJ=OBJECT
      I+=1
    Next I
    If I<>1
      Call ECR_TRACE("The object"-[AOB]ABREV-"does not have a main windows suitable for generation",2) From GESECRAN
      End
    Endif
  Endif
  For I=1 To [AWI]NBMSK+([AWI]MSKENT<>"")+[AOB]NBSCR
    If I=1 and [AWI]MSKENT<>""
      Read [AMK]CODMSK=[AWI]MSKENT
    Elsif I<=[AWI]NBMSK+([AWI]MSKENT<>"")
      Read [AMK]CODMSK=[AWI]NOMMSK(I-1-([AWI]MSKENT<>""))
    Endif
    For J=0 To dim ([AMK]FICREF)-1
      If [AMK]FICREF(J)<>"" and [AMK]FICREF(J)<>TABLES(1) and find([AMK]FICREF(J),ADD_TABLES(1..NB_ADDTABLES))=0
        NB_ADDTABLES+=1 : ADD_TABLES(NB_ADDTABLES)=[AMK]FICREF(J)
      Endif
    Next J
  Next I

# analyze the grids declared for import : only on these tables, perform an multi-level analysis
  For I=1 To NB_ADDTABLES
    TABANA=ADD_TABLES(I) : Gosub ANA_TBL
    If ITB>1 and EXPLNK(ITB)=""
      J=0
      If LNK_ADDTABLES(I)<>""
        J=find(LNK_ADDTABLES(I),TABLES(1..ITB))
      Endif
      J=max(J,1)
      TBLLNK(ITB)=TABLES(J)
      CLELNK(ITB)=FIRSTKEYS(ITB)

      # Find how the link can be done
      # If an unique link of the right table exists, get it
      Filter [ATZ1] Where [ATZ1]CODFIC=TABLES(1) and [ATZ1]LIEN=TABLES(ITB)
      If rowcount([ATZ1])=1
        For [ATZ1]
          EXPLNK(ITB)="["+ABREV(1)+"]"+[ATZ1]CODZONE
          CLELNK(ITB)+="(1)"
        Next
      Else

        # Loop on the different key elements : L is the number of key elements found
        L=0
        For J=1 To ITB-1
          For K=1 To NB_ELT(ITB)

          # If an unique field with the same type exists (not a generic one), and if this field is not reset to zero when cancel, get it
            Read [ATZ]CODZONE=TABLES(ITB);ELTCLES(ITB,K)
            Filter [ATZ1] Where [ATZ1]CODFIC=TABLES(J) and [ATZ1]CODTYP=[ATZ]CODTYP and [ATZ1]LONG=[ATZ]LONG
            If rowcount([ATZ1])=1 and pat([ATZ]CODTYP,"?")=0 and [ATZ1]ANNUL<>2
              For [ATZ1]
                EXPLNK(ITB)+=string$(EXPLNK(ITB)<>"",";")+"["+ABREV(J)+"]"+[ATZ1]CODZONE : L+=1
              Next
            Else

            # If an unique field with the same name exists, get it
              Filter [ATZ1]
              Read [ATZ1]CODZONE=TABLES(J);ELTCLES(ITB,L+1)
              If fstat=0
                EXPLNK(ITB)+=string$(EXPLNK(ITB)<>"",";")+"["+ABREV(J)+"]"+[ATZ1]CODZONE : L+=1
              Else
                Break
              Endif
            Endif
          Next K
          If L=NB_ELT(ITB)
            Break
          Endif
        Next J
        If L=0
          Call LINK_EXCEPTIONS(TABLES,ABREV,ITB,TBLLNK(ITB),CLELNK(ITB),EXPLNK(ITB),L)
          CLELNK(ITB)+=string$(L<NB_ELT(ITB),"("+num$(L)+")")
          LEVEL(ITB)=3
        Elsif L<NB_ELT(ITB)
          CLELNK(ITB)+="("+num$(L)+")"
          LEVEL(ITB)=3
        Else
          # All the elements have been found, it is a (0,1) or (1,1) link
          LEVEL(ITB)=1
          # On a 1 element key, we can be sure that it is a (0,1) link if ANNUL=2, and also that it is a (1,1) link if OBLIG=2
          # Otherwise, (0,1) will be proposed
          If L=2
            Filter [ATZ1]
            Read [ATZ1]CODZONE=TABLES(1);ELTCLES(ITB,1)
            LEVEL(ITB)+=[ATZ1]OBLIG=2
          Endif
        Endif
      Endif

    Elsif ITB>1
      LEVEL(ITB)=1+2*([AOB]IMPTAB(I)<>"")
    Endif
  Next I

# Add a link on CPTANALIG if any exist
  For I=1 To NB_TABLES
    Call LINK_ANA(ABREV(I),LINKEXPR1,LINKEXPR2)
    If LINKEXPR1<>""
      TABANA="CPTANALIN" : Gosub ANA_TBL
      CLELNK(ITB)="CAL0"
      EXPLNK(ITB)=LINKEXPR1
      LEVEL(ITB)=1
      If LINKEXPR2<>""
        TABANA="CPTANALIN/CAL1" : Gosub ANA_TBL
        CLELNK(ITB)="CAL0"
        EXPLNK(ITB)=LINKEXPR2
        LEVEL(ITB)=1
      Endif
      Break
    Endif
  Next I

# Analyze the dependencies in order to find the origin table for the link
  For I=2 To NB_TABLES
    NEK(I)=0
    CHAINE=vireblc(EXPLNK(I),2)
    Repeat
      K=instr(1,CHAINE,';')
      If K
        CHAINE1=vireblc(left$(CHAINE,K-1),2)
        CHAINE=right$(CHAINE,K+1)
      Else
        CHAINE1=vireblc(CHAINE,2)
        CHAINE=""
      Endif
      If pat(CHAINE1,"[??*]?*")
        CHAINE1=vireblc( mid$(CHAINE1,2, instr(1,CHAINE1,"]")-2),2)
        If left$(CHAINE1,2)="F:" : CHAINE1=right$(CHAINE1,3) : Endif
      Else
        CHAINE1=""
      Endif
      J=find(CHAINE1,ABREV(1..NB_TABLES))
      If CHAINE1<>"" and J<>0
        If NEK(I)=0 or find(J,TLINK(I,1..NEK(I)))=0
          NEK(I)+=1
          TLINK(I,NEK(I))=J
        Endif
      Endif
    Until K=0
  Next I

  # TLINK contains the list of index on tables on which a dependency exists
  DEPTHLNK(1)=1
  For M=1 To NB_TABLES-1 : # Max loop
    For I=2 To NB_TABLES
      If NEK(I)=0 and DEPTHLNK(I)=0
        ORILINK(I)=TABLES(1) : ORIABREV(I)=ABREV(1) : DEPTHLNK(I)=2
      Elsif DEPTHLNK(I)=0
        L=0
        For J=1 To NEK(I)
          If DEPTHLNK(TLINK(I,J))=0
            Break 2
          Else
            L=max(L,DEPTHLNK(TLINK(I,J)))
          Endif
        Next J
        For J=1 To NEK(I) : If L=DEPTHLNK(TLINK(I,J)) : Break : Endif : Next J
        ORILINK(I)=TABLES(TLINK(I,J))
        ORIABREV(I)=ABREV(TLINK(I,J))
        DEPTHLNK(I)=min(L+1,2)
      Endif
    Next I
  Next M

# Trace
  adxium=GASCII
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE("*** Object : "+OBJECT+"     --"+format$("D:DD[/]MM[/]YYYY[ ]hh[:]mm[:]ss",date$),0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  J=1
  Read [ATX]NUMERO=GLANGUE;[AOB]LIBEL
  J=1 : Gosub PRINT_MODEL

# Let's start the real job
  If GENE=1 : End : Endif

  Read [AWM]AWM0="SY_"+[AOB]ABREV
  If fstat=0 & SUPP=1
    Call ECR_TRACE("Data model SY_"+[AOB]ABREV-"not replaced",-2) From GESECRAN
    End
  Endif

  Raz [AWM]
  If OLDVER
    Trbegin [AWM]
  Else
    Trbegin [AWM],[AWK]
  Endif

  Read [AWM]AWM0="SY_"+[AOB]ABREV
  If fstat=0
    Delete [AWM]
    If OLDVER=0
      Delete [AWK] Where [AWK]MODELE="SY_"+[AOB]ABREV
    Endif
  Endif

  [AWM]MODELE="SY_"+[AOB]ABREV
  [AWM]INTITMOD=[AOB]LIBEL
  [AWM]ENAFLG=1 : # Pour l'instant
  [AWM]MODULE=[AOB]MODULE
  [AWM]FLGSTR=1
  [AWM]CODSTR=""
  [AWM]CODACT=[AOB]CODACT
  [AWM]TABREF=[AOB]NOMFIC
  [AWM]FLDCPY="" : # To be improved ?
  [AWM]FLDFCY=[AOB]ZSITE
  [AWM]FCT="GES"+[AOB]ABREV : # Not sure it is relevant
  [AWM]FCYSTR=[AOB]ZSITE    : # Not sure it is relevant
  [AWM]ACCSTR=[AOB]ZACC
  [AWM]FLGEXA=1
  [AWM]FLGAPH=1
  [AWM]FLGADLV=1
  [AWM]FLGWRK=2
  [AWM]CREUSR=GUSER
  If dim([AWM]CREDAT)>0 : [AWM]CREDAT=date$ : Endif
  If OLDVER=0
    [AWM]NBROPT=0
    Write [AWM]
    If fstat
      Rollback
      Call ECR_TRACE("The model was not created, error while writing the header",2) From GESECRAN
      End
    Endif
  Endif

  J=1
  For I=1 To NB_TABLES
    For K=1 To NB_TABLES
      If DEPTHLNK(K)=I and LEVEL(K)<>0
        If OLDVER=0
          Raz [AWK]
          [AWK]MODELE="SY_"+[AOB]ABREV
          [AWK]NUMLIG=J : J+=1
          [AWK]TABORI=ORILINK(K)
          Read [ATB1]CODFIC=ORILINK(K)
          If fstat
            Rollback
            Call ECR_TRACE("The model was not created, error on table that doesn't exist ("+ORILINK(K)+")",2) From GESECRAN
            End
          Endif
          If [ATB1]ABRFIC=ORIABREV(K)
            [AWK]ABRORI=""
          Else
            [AWK]ABRORI=ORIABREV(K)
          Endif
          [AWK]TABLNK=TABLES(K)
          Read [ATB1]CODFIC=TABLES(K)
          If fstat
            Rollback
            Call ECR_TRACE("The model was not created, error on table that doesn't exist ("+ORILINK(K)+")",2) From GESECRAN
            End
          Endif
          If [ATB1]ABRFIC=ABREV(K)
            [AWK]ABRLNK=""
          Else
            [AWK]ABRLNK=ABREV(K)
          Endif
          If pat(EXPLNK(K),"*not*found*")
            [AWK]EXPLNK="999"
          Else
            [AWK]EXPLNK=EXPLNK(K)
          Endif
          CHAINE=CLELNK(K)
          L=instr(1,CHAINE,"]") : If L : CHAINE=right$(CHAINE,L+1) : Endif
          L=instr(1,CHAINE,"(") : If L : CHAINE=left$(CHAINE,L-1) : Endif
          [AWK]CLELNK=CHAINE
          If find(LEVEL(K),2,3) : [AWK]TYPLNK=5-LEVEL(K) : Else [AWK]TYPLNK=LEVEL(K) : Endif
          [AWK]EXPSEL=""
          [AWK]STRLNK=""
          [AWK]CREUSR=GUSER
          Write [AWK]
          If fstat
            Rollback
            Call ECR_TRACE("The model was not created, error when writing line ("+ABREV(K)+")",2) From GESECRAN
            End
          Endif
        Else
          J+=1
          [AWM]TABORI(J-2)=ORILINK(K)
          Read [ATB1]CODFIC=ORILINK(K)
          If fstat
            Call ECR_TRACE("The model was not created, error on table that doesn't exist ("+ORILINK(K)+")",2) From GESECRAN
            End
          Endif
          If [ATB1]ABRFIC=ORIABREV(K)
            [AWM]ABRORI(J-2)=""
          Else
            [AWM]ABRORI(J-2)=ORIABREV(K)
          Endif
          [AWM]TABLNK(J-2)=TABLES(K)
          Read [ATB1]CODFIC=TABLES(K)
          If fstat
            Call ECR_TRACE("The model was not created, error on table that doesn't exist ("+ORILINK(K)+")",2) From GESECRAN
            End
          Endif
          If [ATB1]ABRFIC=ABREV(K)
            [AWM]ABRLNK(J-2)=""
          Else
            [AWM]ABRLNK(J-2)=ABREV(K)
          Endif
          If pat(EXPLNK(K),"*not*found*")
            [AWM]EXPLNK(J-2)="999"
          Else
            [AWM]EXPLNK(J-2)=EXPLNK(K)
          Endif
          CHAINE=CLELNK(K)
          L=instr(1,CHAINE,"]") : If L : CHAINE=right$(CHAINE,L+1) : Endif
          L=instr(1,CHAINE,"(") : If L : CHAINE=left$(CHAINE,L-1) : Endif
          [AWM]CLELNK(J-2)=CHAINE
          If find(LEVEL(K),2,3) : [AWM]TYPLNK(J-2)=5-LEVEL(K) : Else [AWM]TYPLNK(J-2)=LEVEL(K) : Endif
          [AWM]EXPSEL(J-2)=""
          [AWM]STRLNK(J-2)=""
        Endif
      Endif
    Next K
  Next I
  If OLDVER
    [AWM]NBRLNK=J-1
    Write [AWM]
    If fstat
        Call ECR_TRACE("The model was not created, error at creation fstat="+num$(fstat),2) From GESECRAN
        Rollback
        End
    Endif
  Endif
  Commit
End

$PRINT_MODEL
  Call ECR_TRACE( "Data model "+ABREV(J)+" associated to : "+[ATX]TEXTE-"("+string$(PERSISTENT(J)=1,"not ")+"persistent)",0) From GESECRAN
  Call ECR_TRACE( "  Main table="+TABLES(J),0) From GESECRAN
  If J=1
    For I=1 To NB_TABLES
      For K=1 To NB_TABLES
        If DEPTHLNK(K)=I and LEVEL(K)<>0
          Call ECR_TRACE( "     "+ORILINK(K)+" ["+ORIABREV(K)+"] +--"+TEXTLEVEL(LEVEL(K))+"--> "+format$("K:12X",TABLES(K))+"["+ABREV(K)+"]"+CLELNK(K)+"="+EXPLNK(K),(GENE=2)*pat(EXPLNK(K),
& "*not*found*")) From GESECRAN
        Endif
      Next K
    Next I
  Endif
  Call ECR_TRACE("",0) From GESECRAN
Return

# Table analysis
# Returns ITB as table number
$ANA_TBL
  CHAINE1=vireblc(TABANA,3)
  If CHAINE1<>TABANA
    CHAINE=right$(TABANA,len(CHAINE1)+2)
    TABANA=CHAINE1
  Else CHAINE=""
  Endif

  If NB_TABLES>0
    If CHAINE=""
      ITB=find(TABANA,TABLES(1..NB_TABLES))
    Else
      ITB=find(TABANA-CHAINE,TABABREV(1..NB_TABLES))
    Endif
  Else
    ITB=0
  Endif

  If ITB
    Return
  Else
    NB_TABLES+=1 : ITB=NB_TABLES
  Endif

  Read [ATB1]CODFIC=TABANA
  TABLES(ITB)=TABANA : ABREV(ITB)=string$(CHAINE<>"",CHAINE)+string$(CHAINE="",[ATB1]ABRFIC)
  TABABREV(ITB)=TABLES(ITB)-ABREV(ITB)

# The table is persistent if it is the main table, or if an object (browser excluded) exists for it
  PERSISTENT(ITB)=2-(ITB>1)
  If ITB>1
    Filter [AOB1] Where NOMFIC=TABANA and TYPGES<>4
    For [AOB1]
      PERSISTENT(ITB)=2
      Break
    Next
  Endif

# First, get the key elements (whithout dimensions)
  Read [ATI]NUMLIG>=TABANA;1;""
  If [ATI]NUMLIG=1 : # & [ATI]HOMONYM=1  # ACCES for instance is not a table with an unique key
    FIRSTKEYS(ITB)=[ATI]CODIND
    CHAINE=vireblc(vireblc(ctrans([ATI]DESCRIPT,"+-","  "),5),2)
    NB_ELT(ITB)=1
    While vireblc(CHAINE,3)<>CHAINE
        ELTCLES(ITB,NB_ELT(ITB))=vireblc(CHAINE,3)
        CHAINE=right$(CHAINE,len(ELTCLES(ITB,NB_ELT(ITB)))+2)
        NB_ELT(ITB)+=1
    Wend
    ELTCLES(ITB,NB_ELT(ITB))=CHAINE
    For P=1 To NB_ELT(ITB)
      Q=instr(1,ELTCLES(ITB,P),"(") : If Q : ELTCLES(ITB,P)=left$(ELTCLES(ITB,P),Q-1) : Endif
    Next P
  Endif
Return

# Exception management for useful links
 Subprog LINK_EXCEPTIONS(TABLES,ABREV,ITB,TABLE_ORI,CLE_ORI,EXPRESSION_LIEN,NB_ELEM)
 Value Char TABLE_LIEE(),TABLE_ORI(),CLE_ORI(), TABLES()(1..), ABREV()(1..)
 Value Integer ITB
 Variable Char EXPRESSION_LIEN()
 Variable Integer NB_ELEM

 Local Char TABLE_LIEE(GLONATB)
 Local Integer I

 TABLE_LIEE=TABLES(ITB)

 Case TABLE_LIEE+"/"+TABLE_ORI+"/"+CLE_ORI
  When "BID/BPCUSTOMER/BID0" : EXPRESSION_LIEN="1;[BPC]BPC0" : NB_ELEM=2
  When Default :
    Case TABLE_LIEE
      When Default
    Endcase
 Endcase
 EXPRESSION_LIEN+=string$(EXPRESSION_LIEN="","  (not found)  ")
End

# Analyse des liens sur CPTANALIG
Subprog LINK_ANA(ABRFIC,LIEN,LIEN2)
Value Char ABRFIC()
Variable Char LIEN(),LIEN2()
LIEN1="" : LIEN2=""
Case ABRFIC
  When "PQD" : LIEN="'"+ABRFIC+"';0;[F:PQD]PQHNUM;[F:PQD]PQDLIN;0;'';1"
  When "PSD" : LIEN="'"+ABRFIC+"';0;[F:PSD]PSHNUM;[F:PSD]PSDLIN;0;'';1"
  When "POP" : LIEN="'"+ABRFIC+"';0;[F:POP]POHNUM;[F:POP]POPLIN;[F:POP]POPSEQ;'';1"
  When "UOP" : LIEN="'"+ABRFIC+"';0;[F:UOP]POHNUM;[F:UOP]POPLIN;[F:UOP]POPSEQ;num$([F:UOP]LINREVNUM);1"
  When "PTD" : LIEN="'"+ABRFIC+"';0;[F:PTD]PTHNUM;[F:PTD]PTDLIN;0;'';1"
  When "PND" : LIEN="'"+ABRFIC+"';0;[F:PND]PNHNUM;[F:PND]PNDLIN;0;'';1"
  When "PID" : LIEN="'"+ABRFIC+"';0;[F:PID]NUM;[F:PID]PIDLIN;0;'';1"
  When "PVF" : LIEN="'"+ABRFIC+"';[F:PVF]VCRTYP;[F:PVF]VCRNUM;0;[F:PVF]IND;'';1"
  When "SQD" : LIEN="'"+ABRFIC+"';0;[F:SQD]SQDNUM;[F:SQD]SQDLIN;0;'';1"
  When "SOP" : LIEN="'"+ABRFIC+"';0;[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ;'';1"
  When "VOP" : LIEN="'"+ABRFIC+"';0;[F:VOP]SOHNUM;[F:VOP]SOPLIN;[F:VOP]SOPSEQ;num$([F:VOP]LINREVNUM);'';1"
  When "SDD" : LIEN="'"+ABRFIC+"';0;[F:SDD]SDHNUM;[F:SDD]SDDLIN;0;'';1"
  When "SRD" : LIEN="'"+ABRFIC+"';0;[F:SRD]SRHNUM;[F:SRD]SRDLIN;0;'';1"
  When "SID" : LIEN="'"+ABRFIC+"';0;[F:SID]NUM;[F:SID]SIDLIN;0;'';1"
  When "SVF" : LIEN="'"+ABRFIC+"';[F:SVF]VCRTYP;[F:SVF]VCRNUM;0;[F:SVF]DTA;'';1"
  When "MFI" : LIEN="'"+ABRFIC+"';0;[F:MFI]MFGNUM;[F:MFI]MFGLIN;0;'';1"
  When "MFO" : LIEN="'"+ABRFIC+"';0;[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM;'EXTWST';1"

              LIEN2="'"+ABRFIC+"';0;[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM;'EXTLAB';1"

  When "MFM" : LIEN="'"+ABRFIC+"';0;[F:MFM]MFGNUM;[F:MFM]MFGLIN;[F:MFM]BOMSEQ;[F:MFM]ITMREF;1"

  When "MKI" : LIEN="'"+ABRFIC+"';0;[F:MKI]MFGTRKNUM;[F:MKI]ITMTRKLIN;0;'';1"

  When "MKO" : LIEN="'"+ABRFIC+"';0;[F:MKO]MFGTRKNUM;[F:MKO]OPETRKLIN;0;[F:MKO]CPLWST;1"
              LIEN2="'"+ABRFIC+"';0;[F:MKO]MFGTRKNUM;[F:MKO]OPETRKLIN;0;[F:MKO]CPLLAB;1"
  When "MKM" : LIEN="'"+ABRFIC+"';0;[F:MKM]MFGTRKNUM;[F:MKM]MATTRKLIN;0;'';1"
  When "SCI" : LIEN="'"+ABRFIC+"';36;[F:SCI]SCONIUM;[F:SCI]SCILIN;0;'';1"
  When "SCM" : LIEN="'"+ABRFIC+"';36;[F:SCM]SCONUM;[F:SCM]SCILIN;[F:SCM]SCMLIN;'';1"
  When "SCS" : LIEN="'"+ABRFIC+"';36;[F:SCS]SCONUM;[F:SCS]SCILIN;[F:SCS]SCSLIN;'';1"
  When "MWI" : LIEN="'"+ABRFIC+"';0;[F:MWI]MFGTRKNUM;[F:MWI]MFGTRKLIN;0;[F:MWI]OVENAT+'~'+[F:MWI]ITMREF;1"
              LIEN2="'"+ABRFIC+"';0;[F:MWI]MFGTRKNUM;[F:MWI]MFGTRKLIN;0;[F:MWI]ITMREF;1"
  When "HDT" : LIEN="'"+ABRFIC+"';0;[F:HDT]HDTNUM;0;0;'';1"
  When "HDI" : LIEN="'"+ABRFIC+"';0;[F:HDI]SRENUM;[F:HDI]HDTORD;0;'';1"
  When "SMD" : LIEN="'"+ABRFIC+"';[F:SMD]VCRTYP;[F:SMD]VCRNUM;[F:SMD]VCRLIN;0;'';1"
  When "SGD" : LIEN="'"+ABRFIC+"';29;[F:SGD]VCRNUM;[F:SGD]VCRLIN;0;'';1"
Endcase
End
