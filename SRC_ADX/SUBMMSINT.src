Subprog C_ID(VALEUR)
Variable Char    VALEUR()
Read [MMS]MMS0=VALEUR
If fstat
    GERR=1
    GMESSAGE=mess(13,7710,1)-"("+VALEUR+")"
    mkstat=2
Endif
End

