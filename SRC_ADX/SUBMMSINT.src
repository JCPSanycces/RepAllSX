Subprog C_STJENDDAT(VALEUR)
Variable Date    VALEUR
If [M:DIA]STJSTRDAT>VALEUR & VALEUR<>[0/0/0]
    GERR=1
    GMESSAGE=mess(67,7710,1)
    mkstat=2
Endif
End

######################################################################################
Subprog AM_STJENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0]
    [M]STJEDTFLG=1 : Affzo [M]STJEDTFLG
    Grizo [M]STJEDTFLG
Else
    [M]STJEDTFLG=2 : Affzo [M]STJEDTFLG
    Actzo [M]STJEDTFLG
    Grizo [M]STJENDDAT
Endif
End


######################################################################################
Subprog AM_STJEDTFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    [M]STJENDDAT=[0/0/0] : Affzo [M]STJENDDAT
    Grizo [M]STJENDDAT
Else
    If [M]STJENDDAT=[0/0/0] : [M]STJENDDAT=date$ : Endif
    Affzo [M]STJENDDAT
    Actzo [M]STJENDDAT
Endif
End


######################################################################################
Subprog AM_STJSTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0]
    Raz [M]STJNDSTR: Affzo [M]STJNDSTR
    Grizo [M]STJNDSTR
Else
    Actzo [M]STJNDSTR
Endif
End

Subprog AM_STJNDSTR(VALEUR)
Variable Decimal VALEUR
If VALEUR>0
    [M]STJSTRDAT=[0/0/0] : Affzo [M]STJSTRDAT
    Grizo [M]STJSTRDAT
Else
    Actzo [M]STJSTRDAT
Endif
End


