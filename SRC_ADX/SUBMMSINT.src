##########################################################################
######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
# Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
#If GBATCH & VALEUR=1
# GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
# mkstat = 2 : End
#Endif
If VALEUR=1
 If GBATCH : GMESSAGE = mess(163,141,1) : mkstat = 2 : End
 Else
   Raz [M]VOLFILWRK : Grizo [M]VOLFILWRK
   Raz [M]VOLFILSTO : Grizo [M]VOLFILSTO
 Endif
Endif
#/ Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
# Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
#  Call SET_NOMFIC("DRTWRK",[M:DIA]DRTWRK,VALEUR)
#  Call SET_NOMFIC("DRTSTO",[M:DIA]DRTSTO,VALEUR)
#  Affzo [M:DIA]DRTWRK
#  Affzo [M:DIA]DRTSTO
#  If VALEUR=1
#     Grizo [M:DIA]DRTWRK
#     Grizo [M:DIA]DRTSTO
#  Else
#     Actzo [M:DIA]DRTWRK
#     Actzo [M:DIA]DRTSTO
#  Endif
If VALEUR=1
 Raz [M:DIA]VOLFILWRK
 Grizo [M:DIA]VOLFILWRK
 Raz [M:DIA]VOLFILSTO
 Grizo [M:DIA]VOLFILSTO
Else
 Actzo [M:DIA]VOLFILWRK
 Actzo [M:DIA]VOLFILSTO
Endif
Affzo [M:DIA]VOLFILWRK
Affzo [M:DIA]VOLFILSTO
#/ Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
End

######################################################################################




Subprog SET_NOMFIC(COLREP,NOMIMP,TYPEXP)
Value Char COLREP()
Variable Char NOMIMP()
Value Integer TYPEXP
Local Char    FICSRV(GDIMFIC) , URL(GDIMFIC)
Local Char    REPERT(GDIMFIC) , MACHINE(GDIMFIC)

Read [MMS]MMS0=[M:DIA]ID
If !fstat
    If (GOS(1)="unix" & pat(left$([F:MMS]DRTWRK,3),"!:\")) or left$([F:MMS]DRTWRK,1)="#"
     If TYPEXP=1
        NOMIMP=evalue("[F:MMS]"+COLREP)
     Endif
    Elsif GOS(1)<>"unix" & pat(left$([F:MMS]DRTWRK,3),"!:\") & filinfo([F:MMS]DRTWRK,0)<=0
     If TYPEXP=1
        NOMIMP=evalue("[F:MMS]"+COLREP)
     Endif
    Else
     If TYPEXP=2
        NOMIMP=evalue("[F:MMS]"+COLREP)
     Else
        Call SET_NAMCLI(NOMIMP) From ORDSYS
     Endif
    Endif
Else
  If TYPEXP=1
    Call SET_NAMCLI(NOMIMP) From ORDSYS
  Endif
Endif

End


Subprog AS_DRTWRK(VALEUR)
Variable Char    VALEUR()
If [M:DIA]TYPEXP = 1
    Grizo [M:DIA]DRTWRK
    [S]mkstat=2
Endif
End

Subprog C_DRTWRK(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
# contrôle du répertoire
Call CONTREP(VALEUR)
If mkstat : End : Endif
End

Subprog AS_DRTSTO(VALEUR)
