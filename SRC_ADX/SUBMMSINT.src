#<AdxTL>@(#)4.0.0.0 $Revision$
# FQ 64855 GA 05/2010 champs trop longs pour la V5 (tronqués à 10c) renommés en V6
# FLGCNTBPSPIT devient FLGCNTBPSP
# FLGCLSBPSPIT devient FLGCLSBPSP
# FLGITMBPSPIT devient FLGITMBPSP
# FLGSTAPSHPIT devient FLGSTAPSHP

Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBMMSINT","MMSINT",4,"SPEMMSINT") From GTRAITE
End

# Gestion du masque MMSINT
######################################################################################
$ACTION
  #Infbox "ACTION="+ACTION
  Case ACTION
    When "OUVRE_BATCH"  : Gosub OUVRE : #entrée en Batch
    When "INIT"         : Gosub OUVRE : #entrée en Interactif
    When "DEBUT"        : Gosub DEBUT
    When "CONTROLE"     : Gosub CONTROLE
    When "EXEC"         : Gosub EXEC
    When "TERMINE"      : Gosub TERMINE
    When Default
  Endcase
Return

######################################################################################
$OUVRE
  Local Integer NBERR : NBERR=0
  Local Integer OK , STAT
  Local Char   FICREF(GDIMFIC),FICREJ(GDIMFIC), WFICHIER (GDIMFIC) , WFICCLI(GDIMFIC) , URL(GDIMFIC)

  Local Mask MMSINT [DIA] : # Saisie paramètres
  Raz [M:DIA]
  If clalev ([F:MMS]) = 0 : Local File MMSPAR [MMS] : Endif
  If clalev ([F:TFO]) = 0 : Local File TABFOR [TFO] : Endif   # FQ 65180 GA 06/2010
  Call GET_DERLU([M:DIA]ID,"MMS","")
  If [M:DIA]ID<>""
      Call AP_ID([M:DIA]ID)
  Endif
  [M:DIA]TRACE=2
Return

$DEBUT
  # Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
  If [M:DIA]ID<>""
   Call AM_TYPEXP([M:DIA]TYPEXP)
  Endif
  #/ Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
  Affzo [M:DIA]
  Call AM_STJENDDAT([M:DIA]STJENDDAT)
  Call AM_STJSTRDAT([M:DIA]STJSTRDAT)
Return

#######################################################
$CONTROLE
If GSTATUT=7
 FIN = 1 : # Sortie du GSAISIE par la touche FIN
 Return
Endif
If !GSERVEUR
 TMP = 1
Endif
If [M:DIA]TYPEXP=2 & [M:DIA]DRTWRK=[M:DIA]DRTSTO
    ##Les répertoires indiqués doivent être différents
    GERR=1
    SAI=1
    GMESSAGE=mess(44,7710,1)
    Return
Endif

# FQ 64855 GA 05/2010 champs trop longs pour la V5 (tronqués à 10c) renommés en V6
If [M:DIA]FLGITMPIT=1 &
&     [M:DIA]FLGCCEPIT=1 &
&     [M:DIA]FLGFCYPIT=1 &
&     [M:DIA]FLGITVPIT=1 &
&     [M:DIA]FLGBPSPIT=1 &
&     [M:DIA]FLGCNTBPSP=1 &
&     [M:DIA]FLGCLSBPSP=1 &
&     [M:DIA]FLGITMBPSP=1 &
&     [M:DIA]FLGPJTPIT=1 &
&     [M:DIA]FLGSTUPIT=1 &
&     [M:DIA]FLGTCOPIT=1 &
&     [M:DIA]FLGSTJPIT=1 &
&     [M:DIA]FLGMVTPIT=1 &
&     [M:DIA]FLGUSRPIT=1 &
&     [M:DIA]FLGSTAPSHP=1 &
&     [M:DIA]FLGPSHPIT=1
    ##Il faut demander au moins le traitement d'un fichier
    GERR=1
    SAI=1
    GMESSAGE=mess(36,7710,1)
    Return
Endif

If [M:DIA]FLGSTJPIT=2
    If ([M:DIA]STJSTRDAT=[0/0/0] & [M:DIA]STJNDSTR=0) | ([M:DIA]STJENDDAT=[0/0/0] & [M:DIA]STJEDTFLG=1)
        GERR=1
        SAI=1
        GMESSAGE=mess(66,7710,1)
        Return
    Endif
    If [M:DIA]STJENDDAT<>[0/0/0] & [M:DIA]STJSTRDAT>[M:DIA]STJENDDAT& [M:DIA]STJSTRDAT<>[0/0/0]
        GERR=1
        SAI=1
        GMESSAGE=mess(67,7710,1)
        Return
    Endif
    If [M:DIA]STJEDTFLG=2 & [M:DIA]STJENDDAT>date$ & [M:DIA]STJENDDAT<>[0/0/0]
        GERR=1
        SAI=1
        GMESSAGE=mess(67,7710,1)
        Return
    Endif
Endif

Return

###############################################################
$TERMINE
  If !GSERVEUR & ( [M:DIA]TRACE=2 | NBERR>0)
    TRA = 1
  Else
    TRA = 0
  Endif
  Gosub SUP_VAR
Return

######################################################################################
$EXEC
Local Char     WMESS(150)
Local Char     CRITERE(255),WCRITSTJ(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)

TIT  = mess(61,7710,1) # interface MMS

If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
##Call PRTSCR("MMSINT","DIA","",0,1) From ATRTX3
Call TRACE_MASQUE("MMSINT","DIA",nomap) From GTRAITE
Call ECR_TRACE(string$(100,"="),0) From GESECRAN


# lecture en cours
Call TEMPON(mess(3,100,1)) From GESECRAN
##
If [M:DIA]FLGCCEPIT=2
    If pat(GVERSION,"1.5.*")
    #CHECK IGNORE_BEGIN  # Analyse des sources, ne pas planter sur ce code V5
    Call TRT_CCE('MMS',[M:DIA]ID,[M:DIA]AXI,"",[M:DIA]CCEPIT,1,"WRHFLG=2",OK) From PITCCE
    #CHECK IGNORE_END # Analyse des sources, ne pas planter sur ce code V5
    Else
    Call TRT_CCE('MMS',[M:DIA]ID,0,[M:DIA]DIE,[M:DIA]CCEPIT,1,"WRHFLG=2",OK) From PITCCE
    Endif
Endif
If [M:DIA]FLGFCYPIT=2
    Call TRT_FCY('MMS',[M:DIA]ID,[M:DIA]FCYPIT,"WRHFLG=2","",OK) From PITFCY
Endif
# FQ 64855 GA 05/2010 champs trop longs pour la V5 (tronqués à 10c) renommés en V6
If [M:DIA]FLGITMPIT=2 | [M:DIA]FLGITVPIT=2| [M:DIA]FLGITMBPSP=2| [M:DIA]FLGSTJPIT=2
    WITMPIT=""
    If [M:DIA]FLGITMPIT=2
        WITMPIT=[M:DIA]ITMPIT
    Endif
    WITVPIT=""
    If [M:DIA]FLGITVPIT=2
        WITVPIT=[M:DIA]ITVPIT
    Endif
    WITMBPSPIT=""
    If [M:DIA]FLGITMBPSP=2
        WITMBPSPIT=[M:DIA]ITMBPSPIT
    Endif
    WSTJPIT=""
    If [M:DIA]FLGSTJPIT=2
        WSTJPIT=[M:DIA]STJPIT
    Endif
    WDEBUT=[M:DIA]STJSTRDAT
    WNBJOUR=[M:DIA]STJNDSTR
    If [M:DIA]STJEDTFLG=2
        WFIN=date$
    Else
        WFIN=[M:DIA]STJENDDAT
    Endif
    If [M:DIA]STJMMSFLG=1
        WCRITSTJ="USRFLD1<>'MMS'"
    Else
        WCRITSTJ="1=1"
    Endif
    Call TRT_ITM('MMS',[M:DIA]ID,WITMPIT,[M:DIA]ITMFOR,WITVPIT,WITMBPSPIT,WSTJPIT,WCRITSTJ,WDEBUT,WNBJOUR,WFIN,OK) From PITMMS
Endif
# FQ 64855 GA 05/2010 champs trop longs pour la V5 (tronqués à 10c) renommés en V6
If [M:DIA]FLGBPSPIT=2 | [M:DIA]FLGCNTBPSP=2 | [M:DIA]FLGCLSBPSP=2
    WBPSPIT=""
    If [M:DIA]FLGBPSPIT=2
        WBPSPIT=[M:DIA]BPSPIT
    Endif
    WCNTBPSPIT=""
    If [M:DIA]FLGCNTBPSP=2
        WCNTBPSPIT=[M:DIA]CNTBPSPIT
    Endif
    WCLSBPSPIT=""
    If [M:DIA]FLGCLSBPSP=2
        WCLSBPSPIT=[M:DIA]CLSBPSPIT
    Endif
   # FQ 65180 GA 06/2010 ajout [M:DIA]BPSFOR (avant "1=1")
    WBPSFOR="1=1"
    If [M:DIA]BPSFOR <> ""
        Read [F:TFO]TFO0=50;[M:DIA]BPSFOR
        If !fstat
            WBPSFOR=[F:TFO]FORFOR
        Endif
    Endif
    Call TRT_BPS('MMS',[M:DIA]ID,WBPSPIT,WBPSFOR,WCNTBPSPIT,WCLSBPSPIT,OK) From PITBPS
Endif
###
If [M:DIA]FLGPJTPIT=2
    Call TRT_PJT('MMS',[M:DIA]ID,[M:DIA]PJTPIT,"1=1",OK) From PITPJT
Endif
If [M:DIA]FLGSTUPIT=2
    Call TRT_TUN('MMS',[M:DIA]ID,[M:DIA]STUPIT,"1=1",OK) From PITTUN
Endif
If [M:DIA]FLGTCOPIT=2
    Call TRT_TCO('MMS',[M:DIA]ID,[M:DIA]TCOPIT,"1=1",OK) From PITTCO
Endif
If [M:DIA]FLGUSRPIT=2
    Call TRT_USR('MMS',[M:DIA]ID,[M:DIA]USRPIT,"1=1",OK) From PITUSR
Endif
# FQ 64855 GA 05/2010 champs trop longs pour la V5 (tronqués à 10c) renommés en V6
If [M:DIA]FLGSTAPSHP=2
    Call TRT_PSH('MMS',[M:DIA]ID,"",'[F:PSH]PSHNUMMMS<>""',[M:DIA]STAPSHPIT,OK) From PITPSH
Endif
#

Gosub TRF_FILES
Call TEMPOFF From GESECRAN

# Ecriture en cours
Call TEMPON(mess(4,100,1)) From GESECRAN
Gosub INI_VAR
If [M:DIA]FLGPSHPIT=2
    Gosub TRAIT_PSH
Endif
If [M:DIA]FLGMVTPIT=2
    Gosub TRAIT_SMVT
Endif
Gosub FIN_CPTRENDU

Call TEMPOFF From GESECRAN

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

$TRAIT_PSH
If [M:DIA]TYPEXP=1
    WFICCLI = "mmspsh.csv"
    FICREJ = "mmspsh_rej.csv"
    FICREF = "mmsrefpsh.csv"
    Call SET_FICNAM(WFICCLI,WFICHIER,URL) From ORDSYS
    Call COPSRV(WFICCLI,WFICHIER,STAT) From ORDSYS
    If STAT : Return : Endif
    Call IMPORT("MMSPSH",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
Else
    WFICCLI = ""
    FICREJ = ""
    FICREF = ""
    WFICHIER=[M:DIA]DRTWRK
    Call IMPORT("MMSPSH",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
    Call IMPORT("mmspsh",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
Endif
Return

$TRAIT_SMVT
If [M:DIA]TYPEXP=1
    WFICCLI = "mmsmvt.csv"
    FICREJ = "mmsmvt_rej.csv"
    FICREF = "mmsrefmvt.csv"
    Call SET_FICNAM(WFICCLI,WFICHIER,URL) From ORDSYS
    Call COPSRV(WFICCLI,WFICHIER,STAT) From ORDSYS
    If STAT : Return : Endif
    Call IMPORT("MMSMVT",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
Else
    WFICCLI = ""
    FICREJ = ""
    FICREF = ""
    WFICHIER=[M:DIA]DRTWRK
    Call IMPORT("MMSMVT",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
    Call IMPORT("mmsmvt",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
Endif
Return


######################################################################################
Subprog IMPORT(NOMBASE,FICBASE,FICCLI,FICREJ,FICREF,NBERR)
Value    Char    NOMBASE(),FICBASE(),FICCLI(),FICREJ(),FICREF()
Variable Integer NBERR
#----------------------#
Local Char     MACHINE(GDIMFIC) , MACFIC(GDIMFIC),WFICREF(GDIMFIC),WFICREJ(GDIMFIC),WFICTMP(GDIMFIC)
Local Char     OS(20)(1..2)
Local Integer  TYPFIC,NBTRAIT
Local Shortint MAXFIL : MAXFIL = 1000
Local Char     TRAIT(200)(1..MAXFIL), EXT(30)

WDATBAS=format$("D:YYYYMMDDhhmmss",date$)

If toupper(NOMBASE)="MMSPSH"
    CONPROG="CONNECTPSH"
    CONPIT=[M:DIA]PSHPIT
    REJ=1
    REF=0
Else
    CONPROG="CONNECTSMVT"
    CONPIT=[M:DIA]MVTPIT
    REJ=1
    REF=0
Endif

If find(right$(FICBASE,len(FICBASE)),"\","/")
 FICBASE= left$(FICBASE,len(FICBASE)-1)
Endif

Call MACHINE(FICBASE,MACHINE,MACFIC) From ORDSYS
Call EXISTE(FICBASE,TYPFIC) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
Case TYPFIC
 When 2 : # C'est un répertoire
  EXT = "csv"
  Call SYSTEME2(MACHINE,'lsadx "'+MACFIC+'" "'+NOMBASE+"*."+EXT+'"','',NBTRAIT,TRAIT) From ORDSYS
  If NBTRAIT>dim(TRAIT)
   Call ECR_TRACE(mess(29,139,1)-"."+EXT-"("+num$(NBTRAIT)+"/"+num$(dim(TRAIT))+")",1) From GESECRAN : # Trop de fichiers
   NBERR+=1
   End
  Endif
 When 1 : # C'est un fichier normal
  NBTRAIT  = 1
  If FICCLI<>""
   Call SETNAM(FICCLI,TRAIT(1),EXT) From GOBJTXT
  Else
      #Call REPERT(FICBASE,FICBASE,TRAIT(1),EXT)
      Call ECR_TRACE("|"+FICBASE-":"-mess(159,141,1),-1) From GESECRAN : # Fichier ou répertoire inexistant
      NBERR+=1
      End
  Endif
 When Default : # Ca n'existe pas
      Call ECR_TRACE("|"+FICBASE-":"-mess(159,141,1),-1) From GESECRAN : # Fichier ou répertoire inexistant
      NBERR+=1
      End
Endcase

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium

For P=1 To NBTRAIT
 If FICCLI<>""
      FICCSV = FICBASE
      WFICREF= FICBASE+"_ref"
      WFICREJ= FICBASE+"_rej"
 Else
    J=instr(1,TRAIT(P),EXT)
    If J>2
        TRAIT(P)=left$(TRAIT(P),J-2)
    Endif
    FICCSV = filpath(FICBASE,TRAIT(P),EXT,"","",MACHINE)
    Call MACHINE([M:DIA]DRTWRK,MACHINE,MACFIC) From ORDSYS
    WFICREF= filpath([M:DIA]DRTWRK,"REF"+TRAIT(P)+WDATBAS,EXT,"","",MACHINE)
    Call MACHINE([M:DIA]DRTSTO,MACHINE,MACFIC) From ORDSYS
    WFICREJ= filpath([M:DIA]DRTSTO,TRAIT(P)+WDATBAS+"_rej",EXT,"","",MACHINE)
 Endif
 TAILFIC = filinfo(FICCSV,7)
 If TAILFIC<0 : # Il aurait pu disparaître!!
  Call ECR_TRACE("|"+FICCSV-":"-mess(101,100,1),-1) From GESECRAN : # Fichier inexistant
  NBERR+=1
 Else
  Gosub INTEGRE
 Endif

Next P
Openi

adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
End

######################################################################################
$INTEGRE
Local Integer ERR : ERR=0
Local Integer ERRNOFIC : ERRNOFIC=0
Local Integer OK , STAT

 Raz ERR,ERRNOFIC
 Call TRAITE('MMS',OS(1),FICCSV,FICCLI,CONPIT,[M:DIA]ID,REJ,WFICREJ,REF,WFICREF,ERR,ERRNOFIC) From=CONPROG
 If ERR
    #erreur sur un des fichiers
    NBERR+=1
 Endif
 #on doit basculer le fichier dans le repertoire des fichiers traites ssi sur serveur
 If FICCLI="" & !ERRNOFIC
    WFICTMP= filpath([M:DIA]DRTSTO,TRAIT(P)+WDATBAS,EXT,"","",MACHINE)
    Call MOVE_EMPTY(FICCSV,WFICTMP,STAT) From ORDSYS
 Endif
 #si fichier des rejets, on doit le recuperer
 If FICCLI<>"" & REJ=1
# Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
#      Call MOVCLI(WFICREJ,FICREJ,STAT) From ORDSYS
  Call COPCLI(WFICREJ,FICREJ,STAT) From ORDSYS
#/ Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
 Endif
 #si fichier des references, on doit le récuperer
 If FICCLI<>"" & REF=1
# Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
#      Call MOVCLI(WFICREF,FICREF,STAT) From ORDSYS
  Call COPCLI(WFICREF,FICREF,STAT) From ORDSYS
#/ Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
 Endif
Return



######################################################################################
$INI_VAR
# Déclaration des variables globales
Gosub INIVARNB From CONNECTPSH
Gosub INIVARNB From CONNECTSMVT
Return

$SUP_VAR
# Désallocation des variables globales
Gosub SUPVARNB From CONNECTPSH
Gosub SUPVARNB From CONNECTSMVT
Return

#######################################################
$FIN_CPTRENDU
Local Char WCLIGNE (100)
WCLIGNE="======================================================================"

Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN

#########"
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
############
# Import des demandes d'achat
Call ECR_TRACE("=========="-mess(63,7710,1),0) From GESECRAN
# nombre de fichiers traités
Call ECR_TRACE(mess(2,7710,1)-':'-num$(GCONPSH_NBF),0) From GESECRAN
For I=1 To GCONPSH_NBF
    Call ECR_TRACE('          '+ctrans(GCONPSH_FIC(I),"\","/"),0) From GESECRAN
Next I
Call ECR_TRACE("",0) From GESECRAN

# nombre d'enreg lus
Call ECR_TRACE(mess(3,7710,1)-':'-num$(GCONPSH_ENR),0) From GESECRAN
# Nombre de demandes d'achat lues
Call ECR_TRACE(mess(75,7710,1)-':'-num$(GCONPSH_LUS),0) From GESECRAN
# Nombre de demandes d'achat importées en insertion
Call ECR_TRACE('     '+mess(76,7710,1)-':'-num$(GCONPSH_NEW),0) From GESECRAN
# Nombre de demandes d'achat importées en mise à jour
##Call ECR_TRACE('     '+mess(77,7710,1)-':'-num$(GCONPSH_MAJ),0) From GESECRAN
# Nombre de demandes d'achat rejetées
If GCONPSH_REJ > 0
Call ECR_TRACE('     '+mess(78,7710,1)-':'-num$(GCONPSH_REJ),-1) From GESECRAN
Else
Call ECR_TRACE('     '+mess(78,7710,1)-':'-num$(GCONPSH_REJ),0) From GESECRAN
Endif
Call ECR_TRACE("",0) From GESECRAN

############
# Import des mouvements
Call ECR_TRACE("=========="-mess(69,7710,1),0) From GESECRAN
# nombre de fichiers traités
Call ECR_TRACE(mess(2,7710,1)-':'-num$(GCONSMVT_NBF),0) From GESECRAN
For I=1 To GCONSMVT_NBF
    Call ECR_TRACE('          '+ctrans(GCONSMVT_FIC(I),"\","/"),0) From GESECRAN
Next I
Call ECR_TRACE("",0) From GESECRAN

# nombre d'enreg lus
Call ECR_TRACE(mess(3,7710,1)-':'-num$(GCONSMVT_ENR),0) From GESECRAN
# nombre d'enreg importés en insertion
Call ECR_TRACE('     '+mess(4,7710,1)-':'-num$(GCONSMVT_NEW),0) From GESECRAN
# nombre d'entrées
Call ECR_TRACE('     '+'     '+mess(70,7710,1)-':'-num$(GCONSMVTR_NEW),0) From GESECRAN
# nombre de sorties
Call ECR_TRACE('     '+'     '+mess(71,7710,1)-':'-num$(GCONSMVTO_NEW),0) From GESECRAN
# nombre d'enreg importés en maj
##Call ECR_TRACE('     '+mess(5,7710,1)-':'-num$(GCONSMVT_MAJ),0) From GESECRAN
# nombre d'enreg rejetés
If GCONSMVT_REJ > 0
Call ECR_TRACE('     '+mess(6,7710,1)-':'-num$(GCONSMVT_REJ),-1) From GESECRAN
Else
Call ECR_TRACE('     '+mess(6,7710,1)-':'-num$(GCONSMVT_REJ),0) From GESECRAN
Endif
Call ECR_TRACE("",0) From GESECRAN

#########"
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
#Call ECR_TRACE(WCLIGNE,0) From GESECRAN
Return


########################################################################
# transfert fichiers serveur vers client
$TRF_FILES
Local Char PATH (GDIMFIC)
Local Char WFICHIER (GDIMFIC)
Local Integer STAT

Local Char MACHINE(GDIMFIC) , MACFIC(GDIMFIC)
Call MACHINE([M:DIA]DRTWRK,MACHINE,MACFIC) From ORDSYS

#on doit basculer le fichier dans le repertoire des fichiers destination

# sections analytiques
PATH = filpath("tmp",tolower([M:DIA]ID)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitcce")
WFICHIER = filpath([M:DIA]DRTWRK,"MMSCCE","csv","","",MACHINE)
If [M:DIA]TYPEXP=1
# Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
#    Call MOVCLI(PATH ,WFICHIER ,STAT) From ORDSYS
    Call COPCLI(PATH,WFICHIER,STAT) From ORDSYS
#/ Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
Elsif [M:DIA]TYPEXP=2
    Call MOVE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
Endif

# sites de stockage
PATH = filpath("tmp",tolower([M:DIA]ID)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitfcy")
WFICHIER = filpath([M:DIA]DRTWRK,"MMSFCY","csv","","",MACHINE)
If [M:DIA]TYPEXP=1
# Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
#    Call MOVCLI(PATH ,WFICHIER ,STAT) From ORDSYS
    Call COPCLI(PATH,WFICHIER,STAT) From ORDSYS
#/ Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
Elsif [M:DIA]TYPEXP=2
    Call MOVE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
Endif

# articles
PATH = filpath("tmp",tolower([M:DIA]ID)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pititm")
WFICHIER = filpath([M:DIA]DRTWRK,"MMSITM","csv","","",MACHINE)
If [M:DIA]TYPEXP=1
# Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
#    Call MOVCLI(PATH ,WFICHIER ,STAT) From ORDSYS
    Call COPCLI(PATH,WFICHIER,STAT) From ORDSYS
#/ Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
Elsif [M:DIA]TYPEXP=2
    Call MOVE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
Endif

# stock articles-sites
PATH = filpath("tmp",tolower([M:DIA]ID)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pititv")
WFICHIER = filpath([M:DIA]DRTWRK,"MMSITV","csv","","",MACHINE)
If [M:DIA]TYPEXP=1
