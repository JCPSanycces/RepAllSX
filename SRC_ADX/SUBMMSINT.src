Subprog AP_ID(VALEUR)
Variable Char    VALEUR()
Read [MMS]MMS0=VALEUR
If !fstat
    [M:DIA]=[F:MMS]

# Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
#    If [M:DIA]DRTWRK<>""
#        If (GOS(1)="unix" & pat(left$([M:DIA]DRTWRK,3),"!:\")) or left$([M:DIA]DRTWRK,1)="#"
#         [M:DIA]TYPEXP = 1
#        Elsif GOS(1)<>"unix" & pat(left$([M:DIA]DRTWRK,3),"!:\") & filinfo([M:DIA]DRTWRK,0)<=0
#         [M:DIA]TYPEXP = 1
#        Else
#         [M:DIA]TYPEXP = 2
#        Endif
#    Elsif [M:DIA]DRTSTO<>""
#        If (GOS(1)="unix" & pat(left$([M:DIA]DRTSTO,3),"!:\")) or left$([M:DIA]DRTSTO,1)="#"
#         [M:DIA]TYPEXP = 1
#        Elsif GOS(1)<>"unix" & pat(left$([M:DIA]DRTSTO,3),"!:\") & filinfo([M:DIA]DRTSTO,0)<=0
#         [M:DIA]TYPEXP = 1
#        Else
#         [M:DIA]TYPEXP = 2
#        Endif
#    Else
#        [M:DIA]TYPEXP = 1
#    Endif
  If [M:DIA]VOLFILWRK<>"" & left$([M:DIA]VOLFILWRK,1)="["
    [M:DIA]TYPEXP = 2 : # Server
  Else
    If GBATCH
      [M:DIA]TYPEXP = 2
    Else
      [M:DIA]TYPEXP = 1
    Endif
  Endif
#/ Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution

    Call AM_TYPEXP([M:DIA]TYPEXP)
    Affzo [M:DIA]
    Call SET_DERLU("MMS",VALEUR)
Endif
End


#----------------------------------------------#
Subprog GET_DERLU(VALEUR,ABREV,CRITERE)
Variable Char VALEUR
Value Char ABREV,CRITERE
Onerrgo RIEN
Local File ALSTRD [ALS]
Local Char CLE(GLONID1) , PROGOBJ(GLONADC)
PROGOBJ = "WO"+ABREV
Gosub NOMFIC From =PROGOBJ
Local File =NOMFIC [A__]
If CRITERE="" : CRITERE = "1=1" : Endif
Filter [ALS] Where USR=GUSER & OBJ=ABREV Order By Key ALS0 Desc
For [ALS]ALS0
 CLE = [F:ALS]CLES
 K = instr(1,CLE,"~")
 If K
  CLE = left$(CLE,K-1)
 Endif
 Read [A__] = CLE
 If !fstat & evalue(CRITERE)
  VALEUR = CLE : Break
 Endif
Next ALS
Close Local File [ALS] , [A__]
End

#----------------------------------------------#
Subprog SET_DERLU(ABREV,CLE)
Value Char ABREV,CLE
Local File ALSTRD [ALS]
Local Integer I , K , OK
Trbegin [ALS]
 Gosub ECR_DERLU
Commit
Close Local File [ALS]
End


#----------------------------------------------#
$ECR_DERLU
Filter [ALS] Where USR=GUSER & OBJ=ABREV
Read [ALS]ALS0 Last
If fstat<=2
 If [F:ALS]LIG>=32000
  Delete [ALS] Where USR=GUSER & OBJ=ABREV
  K = 1
 Else
  K = [F:ALS]LIG+1
 Endif
Else
 K = 1
Endif
Raz I, OK
For [ALS]ALS0
 If [F:ALS]CLES=CLE : OK = 1 : Break : Endif
 If dim(CLEVALEUR)<0
  I+=1
 Else : ## GEODE
  OK=1
  Local Integer I1, I2, I3
  If CLEFCY<>""
   I2=0
   J=find(CLEFCY,CLEPRIM,CLESEC)
   For I3=1 To J
    I1 = I2+1
    I2 = instr(I1,[F:ALS]CLES,"~")
   Next I3
   If I2 & GFCY<>seg$([F:ALS]CLES,I1,I2-1) : OK=0 : Endif
  Endif
  If CLEDEP<>""
   I2=0
   J=find(CLEDEP,CLEPRIM,CLESEC)
   For I3=1 To J
    I1 = I2+1
    I2 = instr(I1,[F:ALS]CLES,"~")
   Next I3
   If GDEP<>seg$([F:ALS]CLES,I1,I2-1) : OK=0 : Endif
  Endif
  If OK : I+=1 : OK=0 : Endif
 Endif
Next
Filter [ALS]
If OK
 [F:ALS]LIG = K
 Rewrite [ALS]
Else
 If I>=GNBDERNIER
  Read [ALS]ALS0(2) = GUSER ; ABREV
  If fstat<=2 : OK = 1 : Endif
 Endif
 Raz [F:ALS]
 [F:ALS]USR  = GUSER
 [F:ALS]OBJ  = ABREV
 [F:ALS]LIG  = K
 [F:ALS]CLES = CLE
 If !OK
  Write [ALS]
 Else
  Rewrite [ALS]
 Endif
Endif
Return

$RIEN
Resume

