    Affzo [M:PJTA2]30
  Endif
End

###################################################################################################
# PJTA3
###################################################################################################
Subprog C_NBLNK

Local Integer IRET
Local Integer ILINE

  If status = 82 or status = 73 Then
    # Insert line
    If [M:PJTA3]SEQNUM(nolign-1) = 0 Then
      ILINE = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).ADDLINE("PTLNK", [V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
        Call SHOW_TASK_HEADER([M:PJTA0]LINTAS) From PJMACTTAS
        Call SHOW_PTLNK_LINE(ILINE) From PJMACTTAS
      Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
        GERR = 4
        mkstat = 2
        GOK = 1
        #IRET = fmet GZINSPJM.PJM_RESET_ERRORS() # Issue X3-96497 - 2018-06-28 by FGR
        IRET = fmet GZINSPJM.RESET_ERRORS()      # Issue X3-96497 - 2018-06-28 by FGR
        End
      Endif
      [M:PJTA3]OPPNUMLNK(nolign-1) = [M:PJTA0]OPPNUM
      Affzo [M:PJTA3]5
    Endif
  Elsif status = 65 Then
    # Delete a line
    If [M:PJTA3]COLLIN(nolign-1) > 0 Then
      IRET = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).ADELLINE("PTLNK", GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK([M:PJTA3]COLLIN(nolign-1)).AORDER)
      If IRET = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
        GOK = 0
        GERR = 1
        mkstat = 2
      Endif
    Else
      GMESSAGE = mess(375,2260,1)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

###################################################################################################
Subprog AM_OPPNUMLNK(VALEUR)
Variable Char    VALEUR()

  Raz [M:PJTA3]TASCODLNK(nolign-1)
End

###################################################################################################
Subprog AM_TASCODLNK(VALEUR)
Variable Char    VALEUR()

Local Char KEYCONCAT(250)

  KEYCONCAT = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GZINSPJM.ACTX, [M:PJTA3]OPPNUMLNK(nolign-1), VALEUR)
  GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK([M:PJTA3]COLLIN(nolign-1)).PIMOPPTASLNK = KEYCONCAT
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK([M:PJTA3]COLLIN(nolign-1)).PIMOPPTASLNK = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PTLNK([M:PJTA3]COLLIN(nolign-1)).snapshot.PIMOPPTASLNK
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_PTLNK_LINE([M:PJTA3]COLLIN(nolign-1)) From PJMACTTAS
    Affzo [M:PJTA3]5
  Endif
  # -----------------------------------
  Call AM_TASLNKTYP([M:PJTA3]TASLNKTYP(nolign-1))
  # -----------------------------------
End

