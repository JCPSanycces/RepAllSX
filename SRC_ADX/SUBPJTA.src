###################################################################################################
Subprog AS_TASSTARTDT(VALEUR)
Variable Date    VALEUR

  # Issue X3-107733 - 2018-10-09 by FGR : Moved from PJTA0B screen
  If VALEUR = AVOID.ADATE and [M:PJTA0A]TASENDDT <> AVOID.ADATE Then
    VALEUR = [M:PJTA0A]TASENDDT
  Endif
End

###################################################################################################
Subprog AM_TASSTARTDT(VALEUR)
Variable Date    VALEUR

  # Issue X3-107733 - 2018-10-09 by FGR : Moved from PJTA0B screen
  GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASSTARTDT = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASSTARTDT = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).snapshot.TASSTARTDT
    GERR = 1
    mkstat = 2
    End
  Else
    VALEUR = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASSTARTDT
    Call SHOW_TASK_HEADER([M:PJTA0]LINTAS) From PJMACTTAS
  Endif
End

###################################################################################################
Subprog AS_TASENDDT(VALEUR)
Variable Date    VALEUR

  # Issue X3-107733 - 2018-10-09 by FGR : Moved from PJTA0B screen
  If VALEUR = AVOID.ADATE and [M:PJTA0A]TASSTARTDT <> AVOID.ADATE Then
    VALEUR = [M:PJTA0A]TASSTARTDT
  Endif
End

###################################################################################################
Subprog AM_TASENDDT(VALEUR)
Variable Date    VALEUR

Local Integer IRET

  # Issue X3-107733 - 2018-10-09 by FGR : Moved from PJTA0B screen
  GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASENDDT = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASENDDT = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).snapshot.TASENDDT
    GERR = 1
    mkstat = 2
    End
  Else
    VALEUR = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASENDDT
    Call SHOW_TASK_HEADER([M:PJTA0]LINTAS) From PJMACTTAS
    If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).ASTALIN = [V]CST_AUPD and fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT_EXISTING() = [V]CST_AYES Then
      If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASENDDT <> GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).snapshot.TASENDDT Then
        GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TCHANSREQDAT = func TRTPJMREP.ASK_QUESTION_MESSAGE(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TCHANSREQDAT, mess(543,2260,1))
        IRET = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT_REPEAT_TASENDDT()
        If IRET <> [V]CST_AOK Then
          Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
          If GERR = 1 Then
            GERR = 1
            mkstat = 2
            End
          Endif
        Endif
        GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TCHANSREQDAT = 2
        Call SHOW_TASK([M:PJTA0]LINTAS) From PJMACTTAS
      Endif
    Endif
  Endif
End

###################################################################################################
Subprog AM_DUEDAT(VALEUR)
Variable Date    VALEUR

  # Issue X3-107733 - 2018-10-09 by FGR : Moved from PJTA0B screen
  GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).DUEDAT = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).DUEDAT = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).snapshot.DUEDAT
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_TASK_HEADER([M:PJTA0]LINTAS) From PJMACTTAS
  Endif
End

