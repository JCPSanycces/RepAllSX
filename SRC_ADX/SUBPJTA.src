###################################################################################################
Funprog MANAGE_DATE_VALIDITY(SFIELD, DDATE, RDATE)
Value Char SFIELD
Value Date DDATE
Variable Date RDATE

Local Integer IARENDRE
Local Integer IRETURN_VALUE
Local Integer ITYP
Local Char STYP(GLONWST)(1..)
Local Char WST(GLONWST)(1..)

  IRETURN_VALUE = [V]CST_AOK
  # -----------------------------
  If DDATE <> [0/0/0] Then
    ITYP = 0
    ITYP += 1
    STYP(ITYP) = "WST"
    WST(ITYP) = [M:PJTA2]EXTWST(nolign-1)
    If [M:PJTA2]EXTLAB(nolign-1) <> AVOID.ACHAR Then
      ITYP += 1
      STYP(ITYP) = "WST"
      WST(ITYP) = [M:PJTA2]EXTLAB(nolign-1)
    Endif
    IRETURN_VALUE = func OPPORPJM_CSTD_PROGS.CHECK_DATE_VALIDITY(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)),
&                        SFIELD, [M:PJTA2]TASFCY(nolign-1), STYP, WST, DDATE, AVOID.ACHAR, 1, RDATE, AVOID.ACHAR)
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GERR = 1 Then
      GERR = 1
      mkstat = 2
      End IRETURN_VALUE
    Endif
  Endif
End IRETURN_VALUE

###################################################################################################
# ON GBOUT6 : Stock manual allocation labels parameters loading
###################################################################################################
$CHARGE_STOALL
  #---------------------------------------------------------------------- #
  # Chargement des paramètres dans masque STOALL                          #
  # Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOALLA       #
  #---------------------------------------------------------------------- #
  # Issue X3-65941 - 2018-01-12 by FGR
  # Chargement du masque [M:ALL]
  Raz [M:ALL]
  [M:ALL]VCRTYP        = 40
  [M:ALL]VCRNUM        = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASNUM
  [M:ALL]VCRLIN        = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).ITTSEQ
  [M:ALL]VCRSEQ        = 0
  [M:ALL]PCU           = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).UOM
  [M:ALL]STU           = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).UOM
  [M:ALL]PCUSTUCOE     = 1
  [M:ALL]BPCORD        = AVOID.ACHAR
  [M:ALL]BPAADD        = AVOID.ACHAR
  # Quantité besoin en allocation
  If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).ITTQTY >= GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).SOQQTY Then
    [M:ALL]RETQTY        = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).ITTQTY -
&                          GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).SOQQTY
  Else
    [M:ALL]RETQTY        = 0
  Endif
  [M:ALL]OLDALLQTY     = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).ALLQTY
  [M:ALL]SHTQTY        = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).SHTQTY
  # Alimentation de la qté à allouer
  [M:ALL]QTYTOALL      = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).ITTQTY -
&                        GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).SOQQTY # Quantity to allocate
  # Alimentation de la qté déjà allouée en global
  Raz [M:ALL]GLOALLQTY
  If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).ALLTYP = 1 Then
    [M:ALL]GLOALLQTY   = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).ALLQTY
  Endif
  [M:ALL]ALLTYP        = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).ALLTYP
  # La date besoin doit tjs être alimentée avec la date d'expédition pour respecter l'ordre chronologique des ddes d'allocation
  [M:ALL]RETDAT        = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).REQDAT
  [M:ALL]DLVDAT        = max(date$, GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).REQDAT)
  [M:ALL]PECINTLOC     = 2
  [M:ALL]PECPLFLOC     = 1
  [M:ALL]XLOT          = AVOID.ACHAR
  [M:ALL]XLOC          = AVOID.ACHAR
  [M:ALL]XSTA          = AVOID.ACHAR
  If dim(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).ECCVALMAJ) >= 0 Then
    [M:ALL]WECCVALMAJ  = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).ECCVALMAJ
  Endif
  GTYPLIG              = 0
  # Récupération du paramêtre stock : Génération de ruptures
  GGENSHT              = fmet GZINSPJM.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).STOFCY, "GENSHT")
  GPRET                = 0
Return

###################################################################################################
$AVANT_STOALL
  #---------------------------------------------------------------------- #
  # Contrôle avant enregistrement                                         #
  # Si contrôle non OK, mettre FOK=0 pour ne pas enregister               #
  # Cette étiquette est appelée depuis AVANT_ENR From TRTSTOALLA          #
  #---------------------------------------------------------------------- #
  # Issue X3-65941 - 2018-01-12 by FGR
  # Quantité totale < quantité to allocate
  If [M:ALL]PECQTY < [M:ALL]QTYTOALL Then
    GMESSAGE = mess(1029,2260,1)
    FOK = 0
  Endif
Return

###################################################################################################
$APRES_STOALL
Local Instance ZTECALLITM Using C_TECALLITM
Local Integer IRET

  #---------------------------------------------------------------------- #
  # Mise à jour complémentaires après enregistrement                      #
  # Si problème mettre GOK=0 pour annuler l'enregistrement                #
  # Cette étiquette est appelée depuis APRES_ENR From TRTSTOALLA          #
  #---------------------------------------------------------------------- #
  # WALLQTY contient la quantité allouée                                  #
  # WSHTQTY contient la quantité en rupture                               #
  # WCSOQTY contient la quantité consommée sur les réservations clients   #
  #---------------------------------------------------------------------- #
  # Issue X3-65941 - 2018-01-12 by FGR
  ZTECALLITM = NewInstance C_TECALLITM AllocGroup null
  IRET = fmet ZTECALLITM.MANUAL_ADD_LINE(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).KEYCONCAT,
&                                        GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).ITMREF,
&                                        GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(LNOL)).UOM,
&                                        WALLQTY,
&                                        WSHTQTY
&                                       )
  If IRET < [V]CST_AERROR Then
    IPJMRET = fmet GZINSPJM.PJM_TASK_RITT_ALLOCATION("", ZTECALLITM)
    If IPJMRET >= [V]CST_AERROR Then
      GOK = 0
      If func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(GZINSPJM, GMESSAGE) = [V]CST_AWARNING Then
        GERR = 2
      Else
        GOK = 0
        GERR = 1
      Endif
    Endif
  Else
    IRET = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(ZTECALLITM, GMESSAGE)
    GOK = 0
  Endif
  FreeGroup ZTECALLITM
Return

###################################################################################################
$CHARGE_STOALL_FUNGBENCH
Local Instance ZINSPJM Using C_OPPOR
Local Integer MY_STATUS
Local Integer IRET
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Char SKEYCONCAT(GLONVPJ)
Local Char SPROJECT(GLONPIM)
Local Char SBUDGET(GLONTAC)
Local Char STASK(GLONPBU)
Local Integer ILINTAS
Local Integer ILINITM

  # Issue X3-31898/X3-59500 - 2018-02-08 by FGR
  #---------------------------------------------------------------------- #
  # Chargement des paramètres dans masque STOALL                          #
  # Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOALLA       #
  #---------------------------------------------------------------------- #
  # Chargement du masque [M:ALL]
  Raz [M:ALL]
  ZINSPJM = NewInstance C_OPPOR AllocGroup null
  IRET = func PJMTSK_CSTD_PROGS.GET_KEYCONCAT_FROM_TASNUM(ZINSPJM.ACTX, [M:MGB]VCRNUM(LNOL), SKEYCONCAT, SMESSAGE)
  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(ZINSPJM.ACTX, SKEYCONCAT, SPROJECT, SBUDGET, STASK)
  ZINSPJM.TCHTOREAD = "PJM"
  [L]MY_STATUS = fmet ZINSPJM.AREAD(SPROJECT)
  If [L]MY_STATUS > [V]CST_AWARNING Then
    Call RECOVERS_ERROR_IN_CLASSIC(ZINSPJM) From SUBPJMA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(163,2260,1)
    Endif
    Return
  Endif
  ILINTAS = fmet ZINSPJM.PJM(1).TAS_GET_INDEX(STASK)
  ILINITM = fmet ZINSPJM.PJM(1).TAS(ILINTAS).RITT_GET_INDEX_ITMREF([M:MGB]ITMREF(LNOL))
  # Chargement du masque [M:ALL]
  [M:ALL]VCRTYP        = 40
  [M:ALL]VCRNUM        = ZINSPJM.PJM(1).TAS(ILINTAS).TASNUM
  [M:ALL]VCRLIN        = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).ITTSEQ
  [M:ALL]VCRSEQ        = 0
  [M:ALL]PCU           = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).UOM
  [M:ALL]STU           = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).UOM
  [M:ALL]PCUSTUCOE     = 1
  [M:ALL]BPCORD        = AVOID.ACHAR
  [M:ALL]BPAADD        = AVOID.ACHAR
  # Quantité besoin en allocation
  If ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).ITTQTY >= ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).SOQQTY Then
    [M:ALL]RETQTY      = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).ITTQTY -
&                        ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).SOQQTY
  Else
    [M:ALL]RETQTY      = 0
  Endif
  [M:ALL]OLDALLQTY     = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).ALLQTY
  [M:ALL]SHTQTY        = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).SHTQTY
  # Alimentation de la qté à allouer
  [M:ALL]QTYTOALL      = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).ITTQTY -
&                        ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).SOQQTY # Quantity to allocate
  # Alimentation de la qté déjà allouée en global
  Raz [M:ALL]GLOALLQTY
  If ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).ALLTYP = 1 Then
    [M:ALL]GLOALLQTY   = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).ALLQTY
  Endif
  [M:ALL]ALLTYP        = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).ALLTYP
  # La date besoin doit tjs être alimentée avec la date d'expédition pour respecter l'ordre chronologique des ddes d'allocation
  [M:ALL]RETDAT        = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).REQDAT
  [M:ALL]DLVDAT        = max(date$, ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).REQDAT)
  [M:ALL]PECINTLOC     = 2
  [M:ALL]PECPLFLOC     = 1
  [M:ALL]XLOT          = AVOID.ACHAR
  [M:ALL]XLOC          = AVOID.ACHAR
  [M:ALL]XSTA          = AVOID.ACHAR
  If dim(ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).ECCVALMAJ) >= 0 Then
    [M:ALL]WECCVALMAJ  = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).ECCVALMAJ
  Endif
  GTYPLIG              = 0
  # Récupération du paramêtre stock : Génération de ruptures
  GGENSHT              = fmet ZINSPJM.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).STOFCY, "GENSHT")
  GPRET                = 0
Return

###################################################################################################
$AVANT_STOALL_FUNGBENCH
  # Issue X3-31898/X3-59500 - 2018-02-08 by FGR
  # Quantité totale < quantité to allocate
  If [M:ALL]PECQTY < [M:ALL]QTYTOALL Then
    GMESSAGE = mess(1029,2260,1)
    FOK = 0
  Endif
Return

###################################################################################################
$APRES_STOALL_FUNGBENCH
Local Instance ZTECALLITM Using C_TECALLITM
Local Integer IRET

  # Issue X3-31898/X3-59500 - 2018-02-08 by FGR
  #---------------------------------------------------------------------- #
  # Mise à jour complémentaires après enregistrement                      #
  # Si problème mettre GOK=0 pour annuler l'enregistrement                #
  # Cette étiquette est appelée depuis APRES_ENR From TRTSTOALLA          #
  #---------------------------------------------------------------------- #
  # WALLQTY contient la quantité allouée                                  #
  # WSHTQTY contient la quantité en rupture                               #
  # WCSOQTY contient la quantité consommée sur les réservations clients   #
  #---------------------------------------------------------------------- #
  # Issue X3-65941 - 2018-01-12 by FGR
  ZTECALLITM = NewInstance C_TECALLITM AllocGroup null
  IRET = fmet ZTECALLITM.MANUAL_ADD_LINE(ZINSPJM.PJM(1).TAS(ILINTAS).KEYCONCAT,
&                                        ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).ITMREF,
&                                        ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINITM).UOM,
&                                        WALLQTY,
&                                        WSHTQTY
&                                       )
  If IRET < [V]CST_AERROR Then
    IPJMRET = fmet ZINSPJM.PJM_TASK_RITT_ALLOCATION("", ZTECALLITM)
    If IPJMRET >= [V]CST_AERROR Then
      GOK = 0
      If func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(ZINSPJM, GMESSAGE) = [V]CST_AWARNING Then
        GERR = 2
      Else
        GOK = 0
        GERR = 1
      Endif
    Endif
  Else
    IRET = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(ZTECALLITM, GMESSAGE)
    GOK = 0
  Endif
  FreeGroup ZTECALLITM
  FreeGroup ZINSPJM
Return

