Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR

  # --------------------------------------------------------------
  # CAREFUL START DATE IS THE START DATE OF THE LINKED TASK.
  # IT CAN BE UPDATED ONLY WHEN THE LINK IS ON THE CURRENT PROJECT
  # --------------------------------------------------------------
  GZINSPJM.PJM(1).TAS([M:PJTA3]COLLINLNK(nolign-1)).TASSTARTDT = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
