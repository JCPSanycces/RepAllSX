#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Gestion du masque PJMTAS0
###################################################################################################
$ACTION
  Case ACTION
    When "BCL_BTNTAC"                : Gosub BCL_BTNTAC
    When "BCL_BTITT"                 : Gosub BCL_BTITT
    When "BCL_BTCLB"                 : Gosub BCL_BTCLB
    When "BCL_BTNAFFECT"             : Gosub BCL_BTNAFFECT
    When "BB1_NBLIG"                 : Gosub BB1_NBLIG
    When "BB2_NBLIG"                 : Gosub BB2_NBLIG
    When "BB3_NBLIG"                 : Gosub BB3_NBLIG
    When "BB1_NBOPE"                 : Gosub BB1_NBOPE
    When "BB1_EXTWST"                : Gosub BB1_EXTWST
    When "BB1_EXTLAB"                : Gosub BB1_EXTLAB
    When "AB1_NBART"                 : Gosub AB1_NBART
    When "BB1_NBART"                 : Gosub BB1_NBART
    When "AB2_NBART"                 : Gosub AB2_NBART
    When "BB2_NBART"                 : Gosub BB2_NBART
    When "AB3_NBART"                 : Gosub AB3_NBART
    When "BB3_NBART"                 : Gosub BB3_NBART
    When "BB6_NBART"                 : Gosub BB6_NBART               # Issue X3-65941 - 2018-01-12 by FGR
    When "AB7_NBART"                 : Gosub AB7_NBART               # Issue X3-65941 - 2018-01-12 by FGR
    When "BB7_NBART"                 : Gosub BB7_NBART               # Issue X3-65941 - 2018-01-12 by FGR
    When Default
  Endcase
Return

###################################################################################################
$BCL_BTNTAC
#  If   GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASDESTEX <> GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).snapshot.TASDESTEX
#&  or  GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TASCOMTEX <> GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).snapshot.TASCOMTEX
    If REP = "" Then
      mkstat = 4
      REP = "M"
      [M:PJTA0]REP = REP
    Endif
#  Endif
Return

###################################################################################################
$BCL_BTITT
Local Integer ILINE

  ILINE = [M:PJTA1]COLLIN(nolign-1)
#  If   GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(ICOLLIN).ITTDESTEX <> GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(ICOLLIN).snapshot.ITTDESTEX
#&  or  GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(ICOLLIN).ITTCOMTEX <> GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT(ICOLLIN).snapshot.ITTCOMTEX
    If REP = "" Then
      mkstat = 4
      REP = "M"
      [M:PJTA0]REP = REP
    Endif
#  Endif
Return

###################################################################################################
$BCL_BTCLB
Local Integer ILINE

  ILINE = [M:PJTA1]COLLIN(nolign-1)
#  If   GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(ICOLLIN).OPEDESTEX <> GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(ICOLLIN).snapshot.OPEDESTEX
#&  or  GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(ICOLLIN).OPECOMTEX <> GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO(ICOLLIN).snapshot.OPECOMTEX
    If REP = "" Then
      mkstat = 4
      REP = "M"
      [M:PJTA0]REP = REP
    Endif
#  Endif
Return

###################################################################################################
$BCL_BTNAFFECT
  REP = ""
  [M:PJTA0]REP = REP
  Diszo [M:PJTA2]NBOPE
  zonsui = "[M:PJTA0A]TCACOD"
  Global Integer PJM_BTNAFFECT2
Return

###################################################################################################
$BB1_NBLIG
Local Char STUNTAS(GLONTAC)

  Gosub LOAD_PAGE From PJMACTTAS
Return

###################################################################################################
$BB2_NBLIG
Local Char STUNTAS(GLONTAC)

  Gosub LOAD_PAGE From PJMACTTAS
Return

###################################################################################################
$BB3_NBLIG
Local Char STUNTAS(GLONTAC)

  Gosub LOAD_PAGE From PJMACTTAS
Return

###################################################################################################
$BB1_NBOPE
  Call SHOW_TASK([M:PJTA0]LINTAS) From PJMACTTAS
Return

###################################################################################################
$BB1_EXTWST
  If [F:MWS]WST <> "" Then
    VALEUR = [F:MWS]WST
  Endif
Return

###################################################################################################
$BB1_EXTLAB
  If [F:MWS]WST <> "" Then
    VALEUR = [F:MWS]WST
  Endif
Return

###################################################################################################
$AB1_NBART
Local Integer IANSWER

  If func MFGLIB.VALIDWIP([M:PJTA1]ITMREF(nolign-1), [M:PJTA1]TASFCY, [M:PJTA0]KEYCONCAT) = [V]CST_ATRUE Then
    IANSWER = [V]CST_AYES
    Call YESNO(mess(551,2260,1), IANSWER) From GESECRAN
    If IANSWER = [V]CST_ANO Then
      Global Integer GVALIDWIP

      GVALIDWIP = IANSWER
    Endif
  Endif
Return

###################################################################################################
$BB1_NBART
  If dim(GVALIDWIP) >= 0 Then
    Kill GVALIDWIP
  Endif
Return

###################################################################################################
$AB2_NBART
Local Integer IANSWER

  If func MFGLIB.VALIDWIP([M:PJTA1]ITMREF(nolign-1), [M:PJTA1]TASFCY, [M:PJTA0]KEYCONCAT) = [V]CST_ATRUE Then
    IANSWER = [V]CST_AYES
    Call YESNO(mess(551,2260,1), IANSWER) From GESECRAN
    If IANSWER = [V]CST_ANO Then
      Global Integer GVALIDWIP

      GVALIDWIP = IANSWER
    Endif
  Endif
Return

###################################################################################################
$BB2_NBART
  If dim(GVALIDWIP) >= 0 Then
    Kill GVALIDWIP
  Endif
Return

###################################################################################################
$AB3_NBART
Local Integer IANSWER

  If func MFGLIB.VALIDWIP([M:PJTA1]ITMREF(nolign-1), [M:PJTA1]TASFCY, [M:PJTA0]KEYCONCAT) = [V]CST_ATRUE Then
    IANSWER = [V]CST_AYES
    Call YESNO(mess(551,2260,1), IANSWER) From GESECRAN
    If IANSWER = [V]CST_ANO Then
      Global Integer GVALIDWIP

      GVALIDWIP = IANSWER
    Endif
  Endif
Return

###################################################################################################
$BB3_NBART
  If dim(GVALIDWIP) >= 0 Then
    Kill GVALIDWIP
  Endif
Return

###################################################################################################
$BB6_NBART
  # Issue X3-65941 - 2018-01-12 by FGR
  Gosub RELIT_GZINSPJM From SUBPJMA
  Call SHOW_RITT_LINE([M:PJTA1]COLLIN(nolign-1)) From PJMACTTAS
  Affzo [M:PJTA1]35
Return

###################################################################################################
$AB7_NBART
Global Char GVCR(GLONVCR)
Global Integer GLIN
Global Integer GSEQ

  # Issue X3-65941 - 2018-01-12 by FGR
  GVCR = [M:PJTA0B]TASNUM    # Issue X3-101833 - 2018-07-30 by FGR : moved from [M:PJTA0]
  GLIN = [M:PJTA1]ITTSEQ(nolign-1)
  GSEQ = 0
Return

###################################################################################################
$BB7_NBART
  # Issue X3-65941 - 2018-01-12 by FGR
  If dim(GVCR) >= 0 Then
    Kill GVCR
    Kill GLIN
    Kill GSEQ
  Endif
Return

###################################################################################################
# PJTA0
###################################################################################################
Subprog AS_NBLIG

  If nolign <= [M:PJTA0]NBLIG and [M:PJTA0]CLAROW(nolign-1) > 0 Then
    [M:PJTA0]LINTAS = [M:PJTA0]CLAROW(nolign-1)
    [M:PJTA0]LINTASTBL = nolign
    Call SHOW_TASK([M:PJTA0]LINTAS) From PJMACTTAS
  Endif
End

###################################################################################################
Subprog IB_NBLIG

  If nolign-1 = 0 Then
    # The first line is the project
    Raz GBOUT1
  Endif
  If [M:PJTA0]REP <> AVOID.ACHAR Then
    Raz GBOUT1
    Raz GBOUT3
  Endif
  # -------------------------
  # Issue X3-99928 - 2018-07-19 by FGR : BEGIN
  If GBOUT1 <> AVOID.ACHAR Then
    # Change status
    If func SUBPJMA.GET_AUTHORIZATION("1") = [V]CST_ANO Then
      Raz GBOUT1
    Endif
  Endif
  If GBOUT3 <> AVOID.ACHAR Then
    # "Saleable products"
    If func SUBPJMA.GET_AUTHORIZATION_GESPJM("6") = [V]CST_ANO Then
      Raz GBOUT3
    Endif
  Endif
  # Issue X3-99928 - 2018-07-19 by FGR : END
End

###################################################################################################
# PJTA0A
###################################################################################################
Subprog AV_TCACOD(VALEUR)
Variable Char    VALEUR()

  If dim(PJM_BTNAFFECT2) >= 0 Then
    Kill PJM_BTNAFFECT2
    Effzo [M:PJTA2]30
    Call SHOW_TASK([M:PJTA0]LINTAS) From PJMACTTAS
    Affzo [M:PJTA2]30
    Call MANAGE_TAB_ACCESS() From PJMACTTAS
  Endif
End

###################################################################################################
Subprog AM_TCACOD(VALEUR)
Variable Char    VALEUR()

  GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TCACOD = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TCACOD = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).snapshot.TCACOD
    VALEUR = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).TCACOD
    [M:PJTA0A]TCACOD = VALEUR                                                  # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
    Affzo [M:PJTA0A]TCACOD                                                     # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
    GERR = 1
    mkstat = 2
    End
  Else
    [M:PJTA0A]TASPIMTYP = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PIMPL.PIMTYP    # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
    Call SHOW_TASPIMTYP_FIELD([V]CST_AYES) From PJMACTTAS
    Call MANAGE_TAB_ACCESS() From PJMACTTAS
    Affzo [M:PJTA0A]TASPIMTYP                                                  # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
    Call SHOW_TASK_HEADER([M:PJTA0]LINTAS) From PJMACTTAS
  Endif
End

