    GZINSPJM.PJM(1).TAS([M:PJTA3]COLLINLNK(nolign-1)).TASSTARTDT = GZINSPJM.PJM(1).TAS([M:PJTA3]COLLINLNK(nolign-1)).snapshot.TASSTARTDT
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_PTLNK_LINE([M:PJTA3]COLLIN(nolign-1)) From PJMACTTAS
    Affzo [M:PJTA3]5
  Endif
End

###################################################################################################
