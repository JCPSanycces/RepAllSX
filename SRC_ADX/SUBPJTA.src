Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

  # Issue X3-65941 - 2018-01-12 by FGR
  GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(nolign-1)).STOFCY = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(nolign-1)).STOFCY = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(nolign-1)).snapshot.STOFCY
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_RITT_LINE([M:PJTA1]COLLIN(nolign-1)) From PJMACTTAS
    Affzo [M:PJTA1]35
  Endif
End

###################################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

  GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(nolign-1)).ITMREF = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(nolign-1)).ITMREF = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(nolign-1)).snapshot.ITMREF
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_RITT_LINE([M:PJTA1]COLLIN(nolign-1)) From PJMACTTAS
    Affzo [M:PJTA1]35
  Endif
  # -------------------------
  If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(nolign-1)).TCHPURFLG = [V]CST_ANO Then
    Grizo [M:PJTA1]MANUALBUD(nolign-1)
  Else
    Actzo [M:PJTA1]MANUALBUD(nolign-1)
  Endif
End

