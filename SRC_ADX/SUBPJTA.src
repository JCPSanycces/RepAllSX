    VALEUR = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PBUCOD
    # Issue X3-110851 - 2018-10-11 by FGR : BEGIN
    #[M:PJTA0]PBUCOD = VALEUR
