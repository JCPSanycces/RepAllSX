    GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).EXTLAB = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).snapshot.EXTLAB
    GERR = 1
    mkstat = 2
    End
  Else
    # -----------------------------
    [M:PJTA2]EXTLAB(nolign-1) = VALEUR
    IRETURN_VALUE = func MANAGE_DATE_VALIDITY("OPESTR", [M:PJTA2]OPESTR(nolign-1), RDATE)
    If IRETURN_VALUE < [V]CST_AERROR Then
      GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).OPESTR = RDATE
