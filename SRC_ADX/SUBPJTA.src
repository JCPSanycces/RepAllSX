Local Integer IREP
Local Integer IAFF
Local Integer IRETURN_VALUE
Local Date RDATE

  GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).OPESTR = VALEUR
