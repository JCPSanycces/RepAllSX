##########################################################################################################
# PJTA2
###################################################################################################
Subprog C_NBOPE

Local Integer IRET
Local Integer ILINE

  If status = 82 or status = 73 Then
    # Insert line
    If [M:PJTA2]OPENUM(nolign-1) = 0 Then
      ILINE = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).ADDLINE("RTKO", [V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
        Call SHOW_TASK_HEADER([M:PJTA0]LINTAS) From PJMACTTAS
        Call SHOW_RTKO_LINE(ILINE) From PJMACTTAS
      Else
        Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
        GERR = 4
        mkstat = 2
        GOK = 1
        #IRET = fmet GZINSPJM.PJM_RESET_ERRORS() # Issue X3-96497 - 2018-06-28 by FGR : not necessary already done in RECOVERS_ERROR_IN_CLASSIC
        End
      Endif
      #Affzo [M:PJTA0]1-99   # Issue X3-99916 - 2018-07-11 by FGR
      Affzo [M:PJTA0A]1-99   # Issue X3-99916 - 2018-07-11 by FGR
      Affzo [M:PJTA0B]1-99   # Issue X3-99916 - 2018-07-11 by FGR
      Affzo [M:PJTA2]30
      Grizo [M:PJTA2]BTNAFFECT(nolign-1)
    Endif
  Elsif status = 65 Then
    # Delete a line
    If [M:PJTA2]COLLIN(nolign-1) > 0 Then
      IRET = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).ADELLINE("RTKO", GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).AORDER)
      If IRET = [V]CST_ANOTDEFINED Then
        Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
        GOK = 0
        GERR = 1
        mkstat = 2
      Else
        Call SHOW_TASK_HEADER([M:PJTA0]LINTAS) From PJMACTTAS
        #Affzo [M:PJTA0]1-99   # Issue X3-99916 - 2018-07-11 by FGR
        Affzo [M:PJTA0A]1-99   # Issue X3-99916 - 2018-07-11 by FGR
        Affzo [M:PJTA0B]1-99   # Issue X3-99916 - 2018-07-11 by FGR
      Endif
    Else
      GMESSAGE = mess(375,2260,1)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

###################################################################################################
Subprog IB_NBOPE
  # Issue X3-77556 - 2018-03-06 by FGR : BEGIN
  If (nolign-1) >= [M:PJTA2]NBOPE Then
    Raz GBOUT1
    Raz GBOUT2
    End
  Endif
  # Issue X3-77556 - 2018-03-06 by FGR : END
  If [M:PJTA0]REP <> AVOID.ACHAR Then
    Raz GBOUT1
  Endif
  # Issue X3-99928 - 2018-07-19 by FGR : BEGIN
  If GBOUT1 <> AVOID.ACHAR Then
    # Change status
    If func SUBPJMA.GET_AUTHORIZATION("O") = [V]CST_ANO Then
      Raz GBOUT1
    Endif
  Endif
  # Issue X3-99928 - 2018-07-19 by FGR : END
End

###################################################################################################
Subprog AM_EXTWST(VALEUR)
Variable Char    VALEUR()

Local Integer IREP
Local Integer IAFF
Local Integer IRETURN_VALUE
Local Date RDATE

  GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).EXTWST = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).EXTWST = GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).snapshot.EXTWST
    GERR = 1
    mkstat = 2
    End
  Else
    [M:PJTA2]EXTWST(nolign-1) = VALEUR
    IRETURN_VALUE = func MANAGE_DATE_VALIDITY("OPESTR", [M:PJTA2]OPESTR(nolign-1), RDATE)
    If IRETURN_VALUE < [V]CST_AERROR Then
      GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).OPESTR = RDATE
    Else
      End
    Endif
    # -----------------------------
    IRETURN_VALUE = func MANAGE_DATE_VALIDITY("OPEEND", [M:PJTA2]OPEEND(nolign-1), RDATE)
    If IRETURN_VALUE < [V]CST_AERROR Then
      GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).OPEEND = RDATE
    Else
      End
    Endif
    # -----------------------------
    If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).ASTALIN = [V]CST_AUPD Then
      If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).OPESTR <> GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).snapshot.OPESTR Then
        IAFF = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).RAFFT_COUNT()
        If IAFF > 0 Then
          IREP = func TRTPJMREP.ASK_THE_QUESTION(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).TCHOPESTRAN)
          GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).TCHOPESTRAN = IREP
          IREP = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).RAFFT_REPEAT_OPESTR()
          If IREP <> [V]CST_AOK Then
            Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
            If GERR = 1 Then
              GERR = 1
              mkstat = 2
              End
            Endif
          Endif
          GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).TCHOPESTRAN = 2
        Endif
      Endif
    Endif
    # -----------------------------
    If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).ASTALIN = [V]CST_AUPD Then
      If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).OPEEND <> GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).snapshot.OPEEND Then
        IAFF = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).RAFFT_COUNT()
        If IAFF > 0 Then
          IREP = func TRTPJMREP.ASK_THE_QUESTION(GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).TCHOPESTRAN)
          GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).TCHOPESTRAN = IREP
          IREP = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).RAFFT_REPEAT_OPEEND()
          If IREP <> [V]CST_AOK Then
            Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
            If GERR = 1 Then
              GERR = 1
              mkstat = 2
              End
            Endif
          Endif
          GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RTKO([M:PJTA2]COLLIN(nolign-1)).TCHOPESTRAN = 2
        Endif
      Endif
    Endif
    # -----------------------------
    Call SHOW_RTKO_LINE([M:PJTA2]COLLIN(nolign-1)) From PJMACTTAS
    Affzo [M:PJTA2]30
  Endif
End

###################################################################################################
Subprog AS_OPESTR(VALEUR)
Variable Date    VALEUR

  # Issue X3-101322 - 2018-08-09 by FGR
  If VALEUR = AVOID.ADATE and [M:PJTA2]OPEEND(nolign-1) <> AVOID.ADATE Then
    VALEUR = [M:PJTA2]OPEEND(nolign-1)
  Endif
End

###################################################################################################
Subprog AM_OPESTR(VALEUR)
