###################################################################################################
# PJTA1
###################################################################################################
Subprog C_NBART

Local Integer IRET
Local Integer ILINE

  If status = 82 or status = 73 Then
    # Insert line
    If [M:PJTA1]ITTSEQ(nolign-1) = 0 Then
      ILINE = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).ADDLINE("RITT", [V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
        Call SHOW_TASK_HEADER([M:PJTA0]LINTAS) From PJMACTTAS
        Call SHOW_RITT_LINE(ILINE) From PJMACTTAS
      Else
        Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
        GERR = 4
        mkstat = 2
        GOK = 1
        #IRET = fmet GZINSPJM.PJM_RESET_ERRORS() # Issue X3-96497 - 2018-06-28 by FGR : not necessary already done in RECOVERS_ERROR_IN_CLASSIC
        End
      Endif
      #Affzo [M:PJTA0]1-99   # Issue X3-99916 - 2018-07-11 by FGR
      Affzo [M:PJTA0A]1-99   # Issue X3-99916 - 2018-07-11 by FGR
      Affzo [M:PJTA0B]1-99   # Issue X3-99916 - 2018-07-11 by FGR
      Affzo [M:PJTA1]35
    Endif
  Elsif status = 65 Then
    # Delete a line
    If [M:PJTA1]COLLIN(nolign-1) > 0 Then
      IRET = fmet GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).ADELLINE("RITT", GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(nolign-1)).AORDER)
      If IRET = [V]CST_ANOTDEFINED Then
        Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
        GOK = 0
        GERR = 1
        mkstat = 2
      Else
        Call SHOW_TASK_HEADER([M:PJTA0]LINTAS) From PJMACTTAS
        #Affzo [M:PJTA0]1-99   # Issue X3-99916 - 2018-07-11 by FGR
        Affzo [M:PJTA0A]1-99   # Issue X3-99916 - 2018-07-11 by FGR
        Affzo [M:PJTA0B]1-99   # Issue X3-99916 - 2018-07-11 by FGR
      Endif
    Else
      GMESSAGE = mess(375,2260,1)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

###################################################################################################
Subprog IB_NBART

  # Issue X3-77556 - 2018-03-06 by FGR : BEGIN
  If (nolign-1) >= [M:PJTA1]NBART Then
    Raz GBOUT1
    Raz GBOUT2
    Raz GBOUT3
    Raz GBOUT4
    Raz GBOUT5
    Raz GBOUT6
    Raz GBOUT7
    End
  Endif
  # Issue X3-77556 - 2018-03-06 by FGR : END
  # Issue X3-65941 - 2018-01-12 by FGR : BEGIN
  If [M:PJTA0]REP <> AVOID.ACHAR Then
    Raz GBOUT6
    Raz GBOUT7
  Endif
  # Issue X3-65941 - 2018-01-12 by FGR : END
  If [M:PJTA0C]TASSTATE = 1 or ([M:PJTA0C]TASSTATE <> 1 and GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).PIMPL.PIMSTA = [V]CST_ANO) Then  # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
    Raz GBOUT1
    Raz GBOUT2
    Raz GBOUT3
    Raz GBOUT4
    Raz GBOUT5     # Issue X3-65941 - 2018-01-12 by FGR
    Raz GBOUT6     # Issue X3-65941 - 2018-01-12 by FGR
    Raz GBOUT7     # Issue X3-65941 - 2018-01-12 by FGR
  Else
    If [M:PJTA1]ITMREF(nolign-1) <> AVOID.ACHAR Then
      # Eneble/disable Buttons depending on the flow type
      Local File ITMMASTER [ITM]
      Read [ITM]ITM0=[M:PJTA1]ITMREF(nolign-1)
      If GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(nolign-1)).TCHPURFLG <> [V]CST_AYES Then
        Raz GBOUT1
      Endif
      If [F:ITM]MFGFLG <> [V]CST_AYES Then
        Raz GBOUT2
      Endif
      If [F:ITM]SCPFLG <> [V]CST_AYES Then
        Raz GBOUT3
      Endif
      # Issue X3-65941 - 2018-01-12 by FGR : BEGIN
      If [F:ITM]STOMGTCOD <> 2 Then
        Raz GBOUT6
        Raz GBOUT7
      Elsif GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(nolign-1)).ITTQTY < GZINSPJM.PJM(1).TAS([M:PJTA0]LINTAS).RITT([M:PJTA1]COLLIN(nolign-1)).ALLQTY Then
        # If "Required quantity" < "Allocated qty." : not possible to allocate another time
        Raz GBOUT6
      Endif
      # Issue X3-65941 - 2018-01-12 by FGR : END
    Endif
  Endif
  If [M:PJTA1]AVADAT(nolign-1) = [0/0/0] Then
    Raz GBOUT5
  Endif
End

