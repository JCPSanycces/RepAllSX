#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMTSK
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param [L]CURPTH Local Char(250), contains the class path
#* @param [L]AEVENT Local Char(20), contains the event code
#* @return [L]ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ACONTROL"                : Gosub ACONTROL                        From PJMTSK_CSTD_EVENTS
        When "AREAD_AFTER"             : Gosub AREAD_AFTER                     From PJMTSK_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE          From PJMTSK_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE          From PJMTSK_CSTD_EVENTS
        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE          From PJMTSK_CSTD_EVENTS
      Endcase
    When "RITT"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub RITT_ACONTROL                   From PJMTSK_CSTD_EVENTS
        When "ADDLINE_BEFORE"          : Gosub RITT_ADDLINE_BEFORE             From PJMTSK_CSTD_EVENTS
        When "ADDLINE_AFTER"           : Gosub RITT_ADDLINE_AFTER              From PJMTSK_CSTD_EVENTS
        When "ADELLINE_BEFORE"         : Gosub RITT_ADELLINE_BEFORE            From PJMTSK_CSTD_EVENTS
        When "ADELLINE_AFTER"          : Gosub RITT_ADELLINE_AFTER             From PJMTSK_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub RITT_AUPDATE_CONTROL_BEFORE     From PJMTSK_CSTD_EVENTS
        When "AUPDATE_CONTROL_AFTER"   : Gosub RITT_AUPDATE_CONTROL_AFTER      From PJMTSK_CSTD_EVENTS
        When "AINSERT_BEFORE"          : Gosub RITT_AINSERT_BEFORE             From PJMTSK_CSTD_EVENTS
        When "AUPDATE_BEFORE"          : Gosub RITT_AUPDATE_BEFORE             From PJMTSK_CSTD_EVENTS
        When "ADELETE_AFTER"           : Gosub RITT_ADELETE_AFTER              From PJMTSK_CSTD_EVENTS
      Endcase
    When "RTKO"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub RTKO_ACONTROL                   From PJMTSK_CSTD_EVENTS
        When "ADDLINE_BEFORE"          : Gosub RTKO_ADDLINE_BEFORE             From PJMTSK_CSTD_EVENTS
        When "ADDLINE_AFTER"           : Gosub RTKO_ADDLINE_AFTER              From PJMTSK_CSTD_EVENTS
        When "ADELLINE_BEFORE"         : Gosub RTKO_ADELLINE_BEFORE            From PJMTSK_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"  : Gosub RTKO_AINSERT_CONTROL_BEFORE     From PJMTSK_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub RTKO_AUPDATE_CONTROL_BEFORE     From PJMTSK_CSTD_EVENTS
      Endcase
    When "RTKO.OPLNK"
      # Issue X3-28737/X3-26991 - 2017-07-31 by TEJAC
      Case [L]ACTION
        When "ACONTROL"                : Gosub RTKO_OPLNK_ACONTROL             From PJMTSK_CSTD_EVENTS
      Endcase
    When "PIMPL"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub PIMPL_ACONTROL                  From PJMTSK_CSTD_EVENTS
      Endcase
    When "SPLD"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub SPLD_ACONTROL                   From PJMTSK_CSTD_EVENTS
        When "ADDLINE_BEFORE"          : Gosub SPLD_ADDLINE_BEFORE             From PJMTSK_CSTD_EVENTS
        When "ADDLINE_AFTER"           : Gosub SPLD_ADDLINE_AFTER              From PJMTSK_CSTD_EVENTS
        When "ADELLINE_BEFORE"         : Gosub SPLD_ADELLINE_BEFORE            From PJMTSK_CSTD_EVENTS
      Endcase
    When "PTLNK"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub PTLNK_ACONTROL                   From PJMTSK_CSTD_EVENTS
        When "ADDLINE_BEFORE"          : Gosub PTLNK_ADDLINE_BEFORE             From PJMTSK_CSTD_EVENTS
        When "ADELLINE_BEFORE"         : Gosub PTLNK_ADELLINE_BEFORE            From PJMTSK_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub PTLNK_AUPDATE_CONTROL_BEFORE     From PJMTSK_CSTD_EVENTS
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param [L]AMETHOD Local Char(20), contains the method code
#* @return [L]ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SETERROR"                    : Gosub SETERROR                        From PJMTSK_CSTD_METHODS
    #
    When "RITT_INIT_TECH_PROP"         : Gosub RITT_INIT_TECH_PROP             From PJMTSK_CSTD_METHODS
    When "RITT_COUNT"                  : Gosub RITT_COUNT                      From PJMTSK_CSTD_METHODS
    When "RITT_GET_INDEX"              : Gosub RITT_GET_INDEX                  From PJMTSK_CSTD_METHODS
    When "RITT_GET_INDEX_ITMREF"       : Gosub RITT_GET_INDEX_ITMREF           From PJMTSK_CSTD_METHODS
    When "RITT_EXISTING"               : Gosub RITT_EXISTING                   From PJMTSK_CSTD_METHODS
    When "RITT_REPEAT_TASENDDT"        : Gosub RITT_REPEAT_TASENDDT            From PJMTSK_CSTD_METHODS
    When "RITT_CHECK_MANUF_INVENTORY"  : Gosub RITT_CHECK_MANUF_INVENTORY      From PJMTSK_CSTD_METHODS  # Issue X3-101833 - 2018-07-30 by FGR
    #
    When "RTKO_INIT_TECH_PROP"         : Gosub RTKO_INIT_TECH_PROP             From PJMTSK_CSTD_METHODS
    When "RTKO_COUNT"                  : Gosub RTKO_COUNT                      From PJMTSK_CSTD_METHODS
    When "RTKO_GET_INDEX"              : Gosub RTKO_GET_INDEX                  From PJMTSK_CSTD_METHODS
    When "RTKO_CLOSING"                : Gosub RTKO_CLOSING                    From PJMTSK_CSTD_METHODS
    When "RTKO_SUSPENSION"             : Gosub RTKO_SUSPENSION                 From PJMTSK_CSTD_METHODS
    When "RTKO_REACTIVATE"             : Gosub RTKO_REACTIVATE                 From PJMTSK_CSTD_METHODS
    When "RTKO_GET_EFFECTIVE_DATE"     : Gosub RTKO_GET_EFFECTIVE_DATE         From PJMTSK_CSTD_METHODS
    When "RTKO_GET_COST_EFFECTIVE_RATE": Gosub RTKO_GET_COST_EFFECTIVE_RATE    From PJMTSK_CSTD_METHODS
    When "RTKO_GET_COST_TYPE"          : Gosub RTKO_GET_COST_TYPE              From PJMTSK_CSTD_METHODS
    When "RTKO_EXISTING"               : Gosub RTKO_EXISTING                   From PJMTSK_CSTD_METHODS
    When "RTKO_GET_PROGRESS"           : Gosub RTKO_GET_PROGRESS               From PJMTSK_CSTD_METHODS
    When "RTKO_COMPUTE_EXTQTY"         : Gosub RTKO_COMPUTE_EXTQTY             From PJMTSK_CSTD_METHODS
    When "RTKO_COMPUTE_CSMQTY"         : Gosub RTKO_COMPUTE_CSMQTY             From PJMTSK_CSTD_METHODS
    When "RTKO_COMPUTE_RMNQTY"         : Gosub RTKO_COMPUTE_RMNQTY             From PJMTSK_CSTD_METHODS
    When "RTKO_COMPUTE_EXTAMT"         : Gosub RTKO_COMPUTE_EXTAMT             From PJMTSK_CSTD_METHODS
    #
    When "SPLD_INIT_TECH_PROP"         : Gosub SPLD_INIT_TECH_PROP             From PJMTSK_CSTD_METHODS
    When "SPLD_DEL_ALL_LINES"          : Gosub SPLD_DEL_ALL_LINES              From PJMTSK_CSTD_METHODS
    When "SPLD_GET_INDEX"              : Gosub SPLD_GET_INDEX                  From PJMTSK_CSTD_METHODS
    When "SPLD_EXISTING"               : Gosub SPLD_EXISTING                   From PJMTSK_CSTD_METHODS
    #
    When "PTLNK_INIT_TECH_PROP"        : Gosub PTLNK_INIT_TECH_PROP            From PJMTSK_CSTD_METHODS
    When "PTLNK_EXISTING"              : Gosub PTLNK_EXISTING                  From PJMTSK_CSTD_METHODS
    #
    When "GET_PIMTYP_FROM_TCACOD"      : Gosub GET_PIMTYP_FROM_TCACOD          From PJMTSK_CSTD_METHODS
    When "CONV_ML2252_TO_ML2254"       : Gosub CONV_ML2252_TO_ML2254           From PJMTSK_CSTD_METHODS
    When "COPY"                        : Gosub COPY                            From PJMTSK_CSTD_METHODS
    When "COPY_LOAD_PROPERTIES"        : Gosub COPY_LOAD_PROPERTIES            From PJMTSK_CSTD_METHODS
    When "TIMEENTRY"                   : Gosub TIMEENTRY                       From PJMTSK_CSTD_METHODS
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param [L]AOPERATION Local Char(20), contains the operation code
#* @return [L]ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param [L]CURPRO Local Char(50), contains the property code
#* @param [L]ARULE Local Char(20), contains the action code requested
#* @return [L]ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "TASCOD"                          : Gosub TASCOD                          From PJMTSK_CSTD_PROPERTIES
    When "TASFCY"                          : Gosub TASFCY                          From PJMTSK_CSTD_PROPERTIES
    When "TCACOD"                          : Gosub TCACOD                          From PJMTSK_CSTD_PROPERTIES
    When "TASSTATE"                        : Gosub TASSTATE                        From PJMTSK_CSTD_PROPERTIES
    When "TASSTARTDT"                      : Gosub TASSTARTDT                      From PJMTSK_CSTD_PROPERTIES
    When "TASENDDT"                        : Gosub TASENDDT                        From PJMTSK_CSTD_PROPERTIES
    When "PBUCOD"                          : Gosub PBUCOD                          From PJMTSK_CSTD_PROPERTIES
    When "TASTYP"                          : Gosub TASTYP                          From PJMTSK_CSTD_PROPERTIES
    When "TASTLA"                          : Gosub TASTLA                          From PJMTSK_CSTD_PROPERTIES
    When "TASDATL"                         : Gosub TASDATL                         From PJMTSK_CSTD_PROPERTIES
    When "TASDATH"                         : Gosub TASDATH                         From PJMTSK_CSTD_PROPERTIES
    When "TASDATS"                         : Gosub TASDATS                         From PJMTSK_CSTD_PROPERTIES
    When "TASDATB"                         : Gosub TASDATB                         From PJMTSK_CSTD_PROPERTIES
    When "TCHANSREQDAT"                    : Gosub TCHANSREQDAT                    From PJMTSK_CSTD_PROPERTIES
    When "KEYCONCAT"                       : Gosub KEYCONCAT                       From PJMTSK_CSTD_PROPERTIES
    When "ORITAS"                          : Gosub ORITAS                          From PJMTSK_CSTD_PROPERTIES
    When "PRCCPL"                          : Gosub PRCCPL                          From PJMTSK_CSTD_PROPERTIES
    #
    #When "RTKO.OPESTR"                     : Gosub RTKO_OPESTR                     From PJMTSK_CSTD_PROPERTIES   # Issue X3-101322 - 2018-08-09 by FGR
    #When "RTKO.OPEEND"                     : Gosub RTKO_OPEEND                     From PJMTSK_CSTD_PROPERTIES   # Issue X3-101322 - 2018-08-09 by FGR
    #
    When "RTKO.RAFFT.POASTR"               : Gosub RTKO_RAFFT_POASTR               From PJMTSK_CSTD_PROPERTIES
    When "RTKO.RAFFT.POAEND"               : Gosub RTKO_RAFFT_POAEND               From PJMTSK_CSTD_PROPERTIES
    #
    When "RTKO.OPLNK.OPENUMLNK"            : Gosub RTKO_OPLNK_OPENUMLNK            From PJMTSK_CSTD_PROPERTIES
    #
    When "RITT.ITMREF"                     : Gosub RITT_ITMREF                     From PJMTSK_CSTD_PROPERTIES
    When "RITT.FRCDLTALLFLG"               : Gosub RITT_FRCDLTALLFLG               From PJMTSK_CSTD_PROPERTIES  # Issue X3-101833 - 2018-07-30 by FGR
  Endcase
Return

