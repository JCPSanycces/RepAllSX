#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TVBLEGSPA 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone SPAJOUDCL
mkstat = 0
zoncou = "SPAJOUDCL"
indice = 0
IMPENT = [M]SPAJOUDCL
If varinit([M]SPAJOUDCL,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPAJOUDCL,indice)=0
 [M]SPAJOUDCL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPAJOUDCL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPAJOUDCL(indice)
 Endif
Endif
[M]SPAJOUDCL = IMPENT

## Zone SPAISP
mkstat = 0
zoncou = "SPAISP"
indice = 0
IMPENT = [M]SPAISP
If varinit([M]SPAISP,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPAISP,indice)=0
 [M]SPAISP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPAISP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPAISP(indice)
 Endif
Endif
[M]SPAISP = IMPENT

## Zone SPAIGIC
mkstat = 0
zoncou = "SPAIGIC"
indice = 0
IMPENT = [M]SPAIGIC
If varinit([M]SPAIGIC,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPAIGIC,indice)=0
 [M]SPAIGIC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPAIGIC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPAIGIC(indice)
 Endif
Endif
[M]SPAIGIC = IMPENT

## Zone SPADCL347
mkstat = 0
zoncou = "SPADCL347"
indice = 0
IMPENT = [M]SPADCL347
If varinit([M]SPADCL347,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPADCL347,indice)=0
 [M]SPADCL347(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPADCL347" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPADCL347(indice)
 Endif
Endif
[M]SPADCL347 = IMPENT

## Zone SPADCL349
mkstat = 0
zoncou = "SPADCL349"
indice = 0
IMPENT = [M]SPADCL349
If varinit([M]SPADCL349,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPADCL349,indice)=0
 [M]SPADCL349(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPADCL349" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPADCL349(indice)
 Endif
Endif
[M]SPADCL349 = IMPENT

## Zone SPAEXEOPE
mkstat = 0
zoncou = "SPAEXEOPE"
indice = 0
IMPENT = [M]SPAEXEOPE
If varinit([M]SPAEXEOPE,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPAEXEOPE,indice)=0
 [M]SPAEXEOPE(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPAEXEOPE" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPAEXEOPE(indice)
 Endif
Endif
[M]SPAEXEOPE = IMPENT

## Zone SPAEURSRV
mkstat = 0
zoncou = "SPAEURSRV"
indice = 0
IMPENT = [M]SPAEURSRV
If varinit([M]SPAEURSRV,indice)=0
 IMPENT = 1
Endif
If varmode([M]SPAEURSRV,indice)=0
 [M]SPAEURSRV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SPAEURSRV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SPAEURSRV(indice)
 Endif
Endif
[M]SPAEURSRV = IMPENT

## Zone SPAOPE340
mkstat = 0
zoncou = "SPAOPE340"
indice = 0
If varinit([M]SPAOPE340,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]SPAOPE340,"393","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SPAOPE340,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SPAOPE340" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]SPAOPE340,"393","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SPAOPE340" : GZNUM = 48685 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]SPAOPE340,"393",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "SPAOPE340" : GZNUM = 48685 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "TVBLEGSPA"
Return

