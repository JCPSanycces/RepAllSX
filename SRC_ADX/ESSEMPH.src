$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase

Return


$OUVRE

Return

$DEBUT
Local Char EMPCODE(GLONEML)
[L]EMPCODE=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")

#Update header icon
#[M:ESSEV]WSTA3 = "246"
#[M:ESSEV]WSTADES3 = 3
#[M:ESSEV]WSTA4 = "248"
#[M:ESSEV]WSTADES4 = 4

#Update mask
Call UPDATE_ESSEV([L]EMPCODE,0) From ESSEMPR

Return

