#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTITC41  Table TABDEPAGIO Initialization of DEPTYP to "Tax included" (2)
#          Table PFOOTINV   Initialization of DEPFLG to "Yes" (2)
#          Table SFOOTINV   Initialization of DEPFLG to "Yes" (2)
##########################################################################
# MAF 05/31/2012 : 81683
##########################################################################
Local Integer TEST : TEST=0
If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Local Char DOSSIER(30)
If !TEST
  DOSSIER = nomap
  Call SAIDOS(DOSSIER,"") From SAIDOS
  If DOSSIER="" : End : Endif
Endif

Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("Correction") From LECFIC
If TEST
  For [ADS]DOSSIER
    If !find([F:ADS]DOSSIER,"X3INDV6","X3TESTV6")
      DOSSIER = [F:ADS]DOSSIER
      Call MAJ_UTITC41(DOSSIER)
    Endif
  Next
Else
  Read [ADS]DOSSIER=[L]DOSSIER
  If fstat : Raz [F:ADS] : Endif
Endif
Call MAJ_UTITC41(DOSSIER)
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End

##########################################################################
Subprog MAJ_UTITC41(DOSSIER)
Value Char DOSSIER

Local Integer T,P,S

Call ECR_TRACE("UTITC41: Process Start on : "+DOSSIER,0) From GESECRAN

# TABDEPAGIO
If filinfo(filpath("FIL","TABDEPAGIO","fde",DOSSIER), 0)>0
  If !clalev([F:TDA]) : Local File =DOSSIER + ".TABDEPAGIO"  [TDA] : Endif
  If dim([F:TDA]DEPTYP)>=0
    Trbegin [TDA]
    For [TDA] Where DEPTYP=0 With Lock
      [F:TDA]DEPTYP = 2
      Rewrite [TDA]
      If !fstat : T+= 1 : Endif
    Next
    Commit
  Endif
Endif

# PFOOTINV
If filinfo(filpath("FIL","PFOOTINV","fde",DOSSIER), 0)>0
  If !clalev([F:PFI]) : Local File =DOSSIER + ".PFOOTINV"  [PFI] : Endif
  If dim([F:PFI]DEPFLG)>=0
    Trbegin [PFI]
    For [PFI] Where DEPFLG=0 & DISVATFLG<2 With Lock
      [F:PFI]DEPFLG = 2
      Rewrite [PFI]
      If !fstat : P+= 1 : Endif
    Next
    Commit
  Endif
Endif

# SFOOTINV
If filinfo(filpath("FIL","SFOOTINV","fde",DOSSIER), 0)>0
  If !clalev([F:SFI]) : Local File =DOSSIER + ".SFOOTINV"  [SFI] : Endif
  If dim([F:SFI]DEPFLG)>=0
    Trbegin [SFI]
    For [SFI] Where DEPFLG=0 & MISRULSTD<2 With Lock
      [F:SFI]DEPFLG = 2
      Rewrite [SFI]
      If !fstat : S+= 1 : Endif
    Next
    Commit
  Endif
Endif

Call ECR_TRACE("UTITC41 :" - num$(T) - "TDA records processed",0) From GESECRAN
Call ECR_TRACE("UTITC41 :" - num$(P) - "PFI records processed",0) From GESECRAN
Call ECR_TRACE("UTITC41 :" - num$(S) - "SFI records processed",0) From GESECRAN
End

########################################################################
# For automatic execution during patch integration
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
Call MAJ_UTITC41(APPLI)
End

########################################################################
# For execution during folder validation
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
Call MAJ_UTITC41(APPLI)
End
