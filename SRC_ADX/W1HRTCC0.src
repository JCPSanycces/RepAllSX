#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRTCC0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:46"
A_USER  = "DOC"
A_STAMP = "20181109230446"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRTCC0 [HRTCC0]
Gosub HORODAT
Local Inpbox "HRTCC0" From GFONCTION At A_STAMP With A_WINDPREV Mask [HRTCC0] As [SIM_]
Grizo [HRTCC0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HRTCC0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=3
Return

$ON_TCCCOD
Onevent CONTROL Call C_TCCCOD(zc) From W1HRTCC0
Onevent BEFORE_INPUT Call AS_TCCCOD(zc) From W1HRTCC0
Return

Subprog AS_TCCCOD(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Onkey   2 Titled GBOUTS Call S_TCCCOD(zc) From W1HRTCC0
Onkey 144 Titled GBOUTP Call P_TCCCOD(zc) From W1HRTCC0
Gosub _AFF
End

Subprog C_TCCCOD(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TCCCOD" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJW"
 PARMSK(1) = "HRTCC"
 Call S_AFF_NUM(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "TCCCOD" : GZNUM = 5296 : Endif
Endif
Gosub _AFF
End

Subprog S_TCCCOD(VALEUR)
Variable Decimal VALEUR
If !GWEBSERV
 ## Action SELOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJW"
 PARMSK(1) = "HRTCC"
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_TAB_NUM(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog P_TCCCOD(VALEUR)
Variable Decimal VALEUR
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRTCC",num$(VALEUR),PAROBJ) From SUBAOP
Gosub _AFF
End

$CHG_STY
Return


