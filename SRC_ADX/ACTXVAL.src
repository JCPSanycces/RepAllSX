# Public functions:
# Subprog VALIDATION(DOSSIER,TRAITEMENT,SILENCE)
#
#----------------------------------------------------------------------------#
$TEST
Call OUVRE_TRACE(mess(1,140,1)-"CONTEXT") From LECFIC
Call VALIDATION("TEST2","",1)
#Call VALIDATION_TECH("TEST2","",1)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

#---------------------------------------------------------------------------------------------------#
## VALIDATION of context
#---------------------------------------------------------------------------------------------------#
Subprog VALIDATION(DOSSIER,CHAPTER,SILENCE)
Value Char    DOSSIER
Value Char    CHAPTER
Value Integer SILENCE

Gosub DEFVAR

# retrieve chapters:
Call LOAD_CHAPTERS(DOSSIER,CHAPTERS)

# retrieve CACHEs
Call LOAD_CACHECLASS(DOSSIER,CACHES)

Local Instance ACLA Using C_ACLA

If CHAPTER <> ""
 # case 1 : validation of a given chapter
 Gosub VALID_ONE_CHAPTER
Else
 # case 2 : an overall validation
 # Load/validate children class for each chapter: "WMACONTEXTxxx"
 Gosub VALID_ALL_CHAPTERS

 # load/validate Children of ACACHE
 Gosub VALID_CHILDREN_CACHE

 # Load/validate mother cache "WMACACHEMAIN"
 Gosub VALID_MOTHER_CACHE

 # validate other classes used by the context: ACTXPARAM, AISNULL, etc
 Gosub VALID_CLASS_ACTX

 # Load/validate "WMACONTEXT"
 Gosub VALID_MAIN_CONTEXT

Endif

End

#---------------------------------------------------------------------------------------------------#
## VALIDATION of context
#---------------------------------------------------------------------------------------------------#
Subprog VALIDATION_TECH(DOSSIER,CHAPTER,SILENCE)
Value Char    DOSSIER
Value Char    CHAPTER
Value Integer SILENCE

Gosub DEFVAR

Local Integer WLOCKSTC
#----- Contrôle lock logique -----#
Call JELOCKEDOS([L]DOSSIER,"AVALSUPSTC",WLOCKSTC) From OBJDIV
If WLOCKSTC=0
 WLOCKSTC=1
 Lock ="AVALSUPSTC" From =[L]DOSSIER With lockwait=-1
Else
 WLOCKSTC=0
Endif

# retrieve chapters:
Call LOAD_CHAPTERS(DOSSIER,CHAPTERS)

# retrieve CACHEs
Call LOAD_CACHECLASS(DOSSIER,CACHES)

Local Instance ACLA Using C_ACLA

# Load/validate children class for each chapter: "WMACONTEXTxxx"
Gosub VALID_ALL_CHAPTERS

# load/validate Children of ACACHE
Gosub VALID_CHILDREN_CACHE

# Load/validate motehr cache "WMACACHEMAIN"
Gosub VALID_MOTHER_CACHE

# Load/validate "WMACONTEXT"
Gosub VALID_MAIN_CONTEXT

If WLOCKSTC
 Unlock ="AVALSUPSTC" From =[L]DOSSIER
Endif
End

#----------------------------------------------------------------------------#

Funprog GET_CTX_NAME()
End [V]CST_NAME_CLASS_CONTEXT

Funprog GET_CTX_SUFFIX_TRT()
End "_CSTD"

Funprog GET_CTX_NAME_TRTMET()
End "ACONTEXT_CMET"

Funprog GET_CODE_PARAM()
End "APARAM"

Funprog GET_NAME_PARAM()
End "ACTXPARAM"

Funprog GET_CODE_CACHE()
End "ACACHE"

Funprog GET_NAME_CACHE()
End "WMACACHEMAIN"

Funprog GET_PREFIX_CACHE()
End "WMACE"

Funprog GET_NAME_COL
End "ACOL"

Funprog GET_NAME_CODPRO
End "ACODPRO"

Funprog GET_CODE_PROFIL()
End "_APROFIL"

Funprog GET_NAME_PROFIL()
End "ACTXFCTPRF"

Funprog GET_CODE_LICENSE()
End "_ASYRLIC"

Funprog GET_NAME_LICENSE()
End "ASYRLIC"

$DECLARE_CLOB
Local Char  LIGNE(250)
Local Clbfile  CLOB(1)
Local Integer DIF
Return

$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

$WRITE_CLOB
Wrseq CLOB Using [FIC]
Return

#----------------------------------------------------------------------------#
$DEFVAR
Local Char CHAPTERS(GLONADC)(1..)
Local Char CACHES(GLONACLA)(1..)
Local Instance AERR(1..)    Using C_AERROR
Local Char CHILD(GLONACLA)
Local Char FICLCK(GDIMFIC)
Local Char NAME_CLA(60) # class name
Local Char NAME_TRT(GLONADC), NAME_TRTMET(GLONADC)  # std treatment name
Local Char NAME_CONTEXT(GLONACLA) # fix string used as prefix or suffix in class/trt name
NAME_CONTEXT = func GET_CTX_NAME
Local Char SUFFIX_TRT(10)
SUFFIX_TRT = func GET_CTX_SUFFIX_TRT
NAME_TRTMET = func GET_CTX_NAME_TRTMET
Local Integer FOUND,LOADTYPCLA,FLAG_ERROR,I_CHP,I_BUF,TEST

TEST = 0
Return

#----------------------------------------------------------------------------#
$VALID_ONE_CHAPTER
FOUND = find(CHAPTER,CHAPTERS)
If FOUND
 LOADTYPCLA = 2
 CHILD = CHAPTER
 NAME_CLA = NAME_CONTEXT+CHILD
 NAME_TRT = NAME_CONTEXT+CHILD+SUFFIX_TRT
 Gosub L_VALIDATE_ONE
 FreeGroup  ACLA
 ACLA= null
Endif
Return

$VALID_ALL_CHAPTERS
For I_CHP=1 To maxtab(CHAPTERS)
 LOADTYPCLA = 2
 CHILD = CHAPTERS(I_CHP)
 NAME_CLA = NAME_CONTEXT+CHILD
 NAME_TRT = NAME_CONTEXT+CHILD+SUFFIX_TRT
 Gosub L_VALIDATE_ONE
 FreeGroup  ACLA
 ACLA= null
Next I_CHP
Return

$VALID_CHILDREN_CACHE
For I_BUF=1 To maxtab(CACHES)
 LOADTYPCLA = 3
 CHILD = CACHES(I_BUF)
 NAME_CLA = func GET_PREFIX_CACHE+CHILD
 NAME_TRT = func GET_PREFIX_CACHE+CHILD+SUFFIX_TRT
 Gosub L_VALIDATE_ONE
 FreeGroup  ACLA
 ACLA= null
Next
Return

$VALID_MOTHER_CACHE
LOADTYPCLA = 4
CHILD = ""
NAME_CLA = func GET_NAME_CACHE
NAME_TRT = func GET_NAME_CACHE+SUFFIX_TRT
Gosub L_VALIDATE_ONE
FreeGroup  ACLA
ACLA= null
Return

$VALID_MAIN_CONTEXT
LOADTYPCLA = 1
CHILD = ""
NAME_CLA = NAME_CONTEXT
NAME_TRT = NAME_CONTEXT+SUFFIX_TRT
Gosub L_VALIDATE_ONE
FreeGroup  ACLA
ACLA= null
Return

$VALID_CLASS_ACTX
Local Integer OK, TYPAGE
Local File =DOSSIER+".ACLASSE" [ACLA]
For [ACLA] Where FLGACTX = 2 or CODCLA="AISNULL"
 If !SILENCE : Call AFF_VLC(mess(1,140,1)-[F:ACLA]CODCLA,"") From GESECRAN : Endif
  If [ACLA]TYPCLA<>4
   Call VALIDATION(0,[F:ACLA]CODCLA,DOSSIER,1,0,0,TYPAGE,OK) From ACLAVAL
  Else
   Call VALIDATION(0,[F:ACLA]CODCLA,[L]DOSSIER,1,0,[L]TYPAGE,[L]OK) From ACLAVALTECH
  Endif
 Next
Close Local File [ACLA]
Return


#---------------------------------------------------------------------------------------------------#
$ERROR
FLAG_ERROR = 1
Local Integer I_AERR
If GTRACE<>""
 For I_AERR=1 To maxtab(AERR)
  If AERR(I_AERR)<>null
   Call ECR_TRACE(AERR(I_AERR).MES,1) From GESECRAN
  Endif
 Next
Endif
Raz AERR
Return



#---------------------------------------------------------------------------------------------------#
# $L_VALIDATE_ONE for local use only
#---------------------------------------------------------------------------------------------------#
$L_VALIDATE_ONE

If !SILENCE : Call AFF_VLC(mess(1,140,1)-NAME_CLA-CHILD,"") From GESECRAN : Endif

# Open trt WMCONTEXT_CSTD or WMCONTEXTxxxx_CSTD
If NAME_TRT<>""
 Call OPENTRT(DOSSIER,NAME_TRT,CHILD,FICLCK,AERR,[L]LOADTYPCLA)
 If maxtab(AERR)>0 : Gosub ERROR :  Return : Endif
Endif

# write into trt WMCONTEXT_CSTD or WMCONTEXTxxxx_CSTD
If LOADTYPCLA=1 : # load Context main
 Call LOAD_ACONTEXT(DOSSIER,NAME_CLA,NAME_TRT,NAME_TRTMET,ACLA,CHAPTERS,CACHES)
Elsif LOADTYPCLA = 2 : # Load  context child chapter
 Call LOAD_CHILDCLASS(DOSSIER,NAME_CLA,NAME_TRT,ACLA,CHILD)
Elsif LOADTYPCLA = 3 : # Load  class CACHE collection
 Call LOAD_CHILDCACHE(DOSSIER,NAME_CLA,NAME_TRT,ACLA,CHILD)
Elsif LOADTYPCLA = 4 : # Load  class CACHE
 Call LOAD_CACHE(DOSSIER,NAME_CLA,NAME_TRT,ACLA,CACHES)
Endif

If NAME_TRT<>""
 Call CLOSETRT(DOSSIER,NAME_TRT,FICLCK,AERR)
 If maxtab(AERR)>0  & !TEST
  Call RESTORE_CSTD(DOSSIER,NAME_TRT)
  Gosub ERROR
  Return
 Endif
Endif

# Generate class WMCONTEXT or WMCONTEXTxxxx
Local Integer WTYPAGE
Call VALSTR_CLASSE(DOSSIER,NAME_CLA,0,0,WTYPAGE,ACLA,AERR) From ACLAVALTRT
If maxtab(AERR)>0 & !TEST
 Call RESTORE_CSTD(DOSSIER,NAME_TRT)
 Call RESTORE_STC(DOSSIER,[L]NAME_CLA) From ACLAVALSUB
 Gosub ERROR
 Return
Endif

If GTRACE<>"" : Call ECR_TRACE(mess(1,140,1)-NAME_CLA,0) From GESECRAN : Endif : # Validation de la classe
Call CLEAN_CSTDOLD(DOSSIER,NAME_TRT)
Call DELETE_STCOLD(DOSSIER,NAME_CLA) From ACLAVALSUB
Return

#---------------------------------------------------------------------------------------------------#
## Load the class CACHE collection : C_WMABUFZZFCY
#---------------------------------------------------------------------------------------------------#
Subprog LOAD_CACHE(DOSSIER,CODCLA,CODTRT,ACLA,CACHES)
Value Char DOSSIER,CODCLA,CODTRT
Variable  Instance  ACLA Using C_ACLA
Value Char CACHES()(1..)

Local File =DOSSIER+".ACLASSE"    [ACLA]
Local Integer ACLAF_NBR
Local Instance AERR(1..)    Using C_AERROR

Gosub DECLARE_CLOB

ACLA = NewInstance C_ACLA AllocGroup null
Call INI_ACLAVARDEF(CODCLA,DOSSIER,ACLA,AERR) From ACLAVALLEC

ACLA.CODCLA = CODCLA
ACLA.TYPCLA = 3
ACLA.FLGACTX = 2
ACLA.CODECLA =  ACLA.CODCLA

#For initialization treaments:
ACLA.NBRTRT +=1
ACLA.ACLATRT(ACLA.NBRTRT) = NewInstance  C_ACLATRT AllocGroup ACLA
ACLA.ACLATRT(ACLA.NBRTRT).CODTRT = CODTRT # treatement automatically generated!
ACLA.ACLATRT(ACLA.NBRTRT).RANTRT = 1000
ACLA.ACLATRT(ACLA.NBRTRT).TYPTRT = 1 # Standard Type
ACLA.ACLATRT(ACLA.NBRTRT).ACTTRT = ""

For I=1 To maxtab(CACHES)
 Read [ACLA]ACLA0 = CACHES(I)
 If !fstat
  ACLAF_NBR += 1
  ACLA.ACLAF(ACLAF_NBR) = NewInstance C_ACLAFLD  AllocGroup ACLA
  ACLA.ACLAF(ACLAF_NBR).INTFLD = [F:ACLA]INTCLA
  ACLA.ACLAF(ACLAF_NBR).INTITFLD =func ASYRFNC.TEXTE(ACLA.ACLAF(ACLAF_NBR).INTFLD)
  ACLA.ACLAF(ACLAF_NBR).FLDCLA   = CACHES(I)   # Field name
  ACLA.ACLAF(ACLAF_NBR).ACLA     = ACLA     # Link to the parent
  ACLA.ACLAF(ACLAF_NBR).LNKCLA = func GET_PREFIX_CACHE+CACHES(I)
 Endif
Next

# add method ACLEAN
ACLAM_NBR = maxtab(ACLA.ACLAM)
ACLAM_NBR += 1
ACLA.ACLAM(ACLAM_NBR) = NewInstance C_ACLAMET AllocGroup ACLA
ACLA.ACLAM(ACLAM_NBR).CODMET = "ACLEAN"
ACLA.ACLAM(ACLAM_NBR).DONMET = 3

DIF = 0
LIGNE = "" : Gosub ADDCLB
LIGNE = "#"+string$(78,'-')+"#"
LIGNE = "$ACLEAN" : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "$ACLEAN_OLD" : Gosub ADDCLB
LIGNE = "Local Instance WOBJ Using OBJECT" : Gosub ADDCLB
LIGNE = "this.isReadonly = 0" : Gosub ADDCLB
For I=1 To maxtab(CACHES)
 LIGNE = "WOBJ = this."+CACHES(I)  : Gosub ADDCLB
 LIGNE = "this."+CACHES(I)-"= null"  : Gosub ADDCLB
 LIGNE = "FreeInstance WOBJ" : Gosub ADDCLB
 LIGNE = "this."+CACHES(I)+" = NewInstance C_"+func GET_PREFIX_CACHE+CACHES(I)-[V]CST_ALLOCGROUP-"this" : Gosub ADDCLB
 LIGNE = "this."+CACHES(I)+".APARENT = this.APARENT" : Gosub ADDCLB
 LIGNE = "this."+CACHES(I)+".isReadonly = 1" : Gosub ADDCLB
Next
LIGNE = "this.isReadonly = 1" : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB

Gosub WRITE_CLOB

Close Local File [ACLA]
End

#---------------------------------------------------------------------------------------------------#
## Load the class CACHE collection : C_WMABUFZZFCY
#---------------------------------------------------------------------------------------------------#
Subprog LOAD_CHILDCACHE(DOSSIER,CODCLA,CODTRT,ACLA,CACHE)
Value Char DOSSIER,CODCLA,CODTRT
Variable  Instance  ACLA Using C_ACLA
Value Char CACHE

Local File =DOSSIER+".ACLASSE"    [ACLA]
Local File =DOSSIER+".ATABIND"    [ATI]
Local File =DOSSIER+".ACLAFLD"    [ACLAF]
Local File =DOSSIER+".ATYPE"       [ATY]

Local Integer ACLAF_NBR,ACLAK_NBR,I,ACLAMP_NBR ,ACLAM_NBR

Local Char    CHAINE(250),AMETHOD(GLONASM)

Gosub DECLARE_CLOB

Read [ACLA]ACLA0 = CACHE
If fstat : End : Endif

ACLA = NewInstance  C_ACLA AllocGroup null
Local Instance AERR(1..)    Using C_AERROR
Call INI_ACLAVARDEF(CODCLA,DOSSIER,ACLA,AERR) From ACLAVALLEC
ACLA.CODCLA = CODCLA
ACLA.TYPCLA = 3
ACLA.FLGACTX = 2
ACLA.CODECLA =  ACLA.CODCLA

#For initialization treaments:
ACLA.NBRTRT +=1
ACLA.ACLATRT(ACLA.NBRTRT) = NewInstance C_ACLATRT AllocGroup ACLA
ACLA.ACLATRT(ACLA.NBRTRT).CODTRT = CODTRT # treatement automatically generated!
ACLA.ACLATRT(ACLA.NBRTRT).RANTRT = 1000
ACLA.ACLATRT(ACLA.NBRTRT).TYPTRT = 1 # Standard Type
ACLA.ACLATRT(ACLA.NBRTRT).ACTTRT = ""

# Add collection
ACLA.NBRGRP +=1
ACLA.CODGRP(ACLA.NBRGRP)   = func GET_NAME_COL
ACLA.MINGRP(ACLA.NBRGRP)   = 1
ACLA.PROGRP(ACLA.NBRGRP)   = ""
ACLA.INTGRP(ACLA.NBRGRP)   = [F:ACLA]INTCLA
ACLA.INTITGRP(ACLA.NBRGRP) = func ASYRFNC.TEXTE(ACLA.INTGRP(ACLA.NBRGRP))
ACLA.ACTGRP(ACLA.NBRGRP)   =  ""
ACLA.FLGTRIGRP(ACLA.NBRGRP)   = 2
ACLA.FLGAPDGRP(ACLA.NBRGRP)   = 2
ACLA.FLGINSGRP(ACLA.NBRGRP)   = 2
ACLA.FLGSUPGRP(ACLA.NBRGRP)   =2
ACLA.MAXGRP(ACLA.NBRGRP)   = 0
ACLA.PROUID(ACLA.NBRGRP) = func GET_NAME_COL
ACLA.TYPUID(ACLA.NBRGRP) = 2
ACLA.CLAUID(ACLA.NBRGRP) = CACHE

# add field
ACLAF_NBR += 1
ACLA.ACLAF(ACLAF_NBR) = NewInstance C_ACLAFLD AllocGroup ACLA
ACLA.ACLAF(ACLAF_NBR).INTFLD = [F:ACLA]INTCLA
ACLA.ACLAF(ACLAF_NBR).INTITFLD =func ASYRFNC.TEXTE(ACLA.ACLAF(ACLAF_NBR).INTFLD)
ACLA.ACLAF(ACLAF_NBR).FLDCLA   = func GET_NAME_COL # Field name
ACLA.ACLAF(ACLAF_NBR).ACLA     = ACLA     # Link to the parent
ACLA.ACLAF(ACLAF_NBR).LNKCLA = "OBJECT"  : # CACHE
ACLA.ACLAF(ACLAF_NBR).FLDGRP = func GET_NAME_COL

ACLAK_NBR += 1
ACLA.ACLAK(ACLAK_NBR) = NewInstance C_ACLALNK AllocGroup ACLA
If [F:ACLA]TYPCLA=2
 Read [ATI]CODIND =  [ACLA]TABREF; [ACLA]INDREF
 If !fstat & [F:ATI]HOMONYM<2
  ACLA.ACLAK(ACLAK_NBR).EXPLNK = [F:ATI]DESCRIPT
  CHAINE = [F:ATI]DESCRIPT
 Endif
Else
 ACLA.ACLAK(ACLAK_NBR).EXPLNK = [F:ACLA]KEYINT
 CHAINE = [F:ACLA]KEYINT
Endif
I = instr(0,CHAINE,"+")
While I
 ACLA.ACLAK(ACLAK_NBR).NBRIND+=1
 ACLA.ACLAK(ACLAK_NBR).INDEX(ACLA.ACLAK(ACLAK_NBR).NBRIND) = left$(CHAINE,I-1)
 CHAINE       = right$(CHAINE,I+1)
 I = instr(0,CHAINE,"+")
Wend
ACLA.ACLAK(ACLAK_NBR).NBRIND += 1
ACLA.ACLAK(ACLAK_NBR).INDEX(ACLA.ACLAK(ACLAK_NBR).NBRIND) = CHAINE
For I=1 To ACLA.ACLAK(1).NBRIND
 Read [ACLAF]ACLAF0 = CACHE;ACLA.ACLAK(ACLAK_NBR).INDEX(I)
  If !fstat
  ACLA.ACLAK(ACLAK_NBR).CODTYPIND(I) = [F:ACLAF]CODTYP
  Read [ATY]CODTYP=ACLA.ACLAK(ACLAK_NBR).CODTYPIND(I)
  If !fstat
   ACLA.ACLAK(ACLAK_NBR).TYPIND(I)  = [F:ATY]TYPTYP
   If find([F:ATY]TYPTYP,7,9,10) & [F:ATY]LNGTYP<>0
    ACLA.ACLAK(ACLAK_NBR).LNGIND(I)  = [F:ATY]LNGTYP
   Else
    ACLA.ACLAK(ACLAK_NBR).LNGIND(I)  =  [F:ACLAF]LONG
   Endif
  Endif
 Endif
Next

# add method AREAD
ACLAM_NBR = maxtab(ACLA.ACLAM)
ACLAM_NBR += 1
ACLA.ACLAM(ACLAM_NBR) = NewInstance C_ACLAMET AllocGroup ACLA
ACLA.ACLAM(ACLAM_NBR).CODMET = "AREAD"
ACLA.ACLAM(ACLAM_NBR).DONMET = 3

# add param
Raz ACLAMP_NBR
For I=1 To ACLA.ACLAK(1).NBRIND
 ACLAMP_NBR += 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR)  = NewInstance C_ACLAPARDEF AllocGroup ACLA
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODPAR    = ACLA.ACLAK(ACLAK_NBR).INDEX(I)
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).NOPAR     = ACLAMP_NBR
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).DIMPAR    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).MODPAR    = 2
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPINTPAR = ACLA.ACLAK(ACLAK_NBR).TYPIND(I)
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPKEY    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODE      = ACLA.ACLAM(ACLAM_NBR).CODMET
Next

# add method AGETINDEX
ACLAM_NBR = maxtab(ACLA.ACLAM)
ACLAM_NBR += 1
ACLA.ACLAM(ACLAM_NBR) = NewInstance C_ACLAMET AllocGroup ACLA
ACLA.ACLAM(ACLAM_NBR).CODMET = "AGETINDEX"
ACLA.ACLAM(ACLAM_NBR).DONMET = 3

# add param
Raz ACLAMP_NBR
For I=1 To ACLA.ACLAK(1).NBRIND
 ACLAMP_NBR += 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR)  = NewInstance C_ACLAPARDEF AllocGroup ACLA
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODPAR    = ACLA.ACLAK(ACLAK_NBR).INDEX(I)
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).NOPAR     = ACLAMP_NBR
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).DIMPAR    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).MODPAR    = 2
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPINTPAR = ACLA.ACLAK(ACLAK_NBR).TYPIND(I)
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPKEY    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODE      = ACLA.ACLAM(ACLAM_NBR).CODMET
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CLAPAR   = ""
Next

For AMETHOD="AGETVALCHAR","AGETVALNUM","AGETVALDAT","AGETVALDEC"

 # add method AGETVALCHAR
 ACLAM_NBR = maxtab(ACLA.ACLAM)
 ACLAM_NBR += 1
 ACLA.ACLAM(ACLAM_NBR) = NewInstance C_ACLAMET AllocGroup ACLA
 ACLA.ACLAM(ACLAM_NBR).CODMET = [L]AMETHOD
 Case [L]AMETHOD
  When "AGETVALCHAR" : ACLA.ACLAM(ACLAM_NBR).DONMET = 2
  When "AGETVALNUM"  : ACLA.ACLAM(ACLAM_NBR).DONMET = 3
  When "AGETVALDAT"  : ACLA.ACLAM(ACLAM_NBR).DONMET = 1
  When "AGETVALDEC"  : ACLA.ACLAM(ACLAM_NBR).DONMET = 4
 Endcase

 # add param
 Raz ACLAMP_NBR
 For I=1 To ACLA.ACLAK(1).NBRIND
  ACLAMP_NBR += 1
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR)  = NewInstance C_ACLAPARDEF AllocGroup ACLA
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODPAR    = ACLA.ACLAK(ACLAK_NBR).INDEX(I)
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).NOPAR     = ACLAMP_NBR
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).DIMPAR    = 1
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).MODPAR    = 2
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPINTPAR = ACLA.ACLAK(ACLAK_NBR).TYPIND(I)
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPKEY    = 1
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODE      = ACLA.ACLAM(ACLAM_NBR).CODMET
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CLAPAR   = ""
 Next
 ACLAMP_NBR += 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR)  = NewInstance C_ACLAPARDEF AllocGroup ACLA
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODPAR    = func GET_NAME_CODPRO
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).NOPAR     = ACLAMP_NBR
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).DIMPAR    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).MODPAR    = 2
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPINTPAR = 7
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPKEY    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODE      = ACLA.ACLAM(ACLAM_NBR).CODMET
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CLAPAR   = ""
Next

DIF = 0
LIGNE = "" : Gosub ADDCLB
LIGNE = "#"+string$(78,'-')+"#"
LIGNE = "$AREAD" : Gosub ADDCLB
LIGNE = 'If [L]CURPTH<>"" : Return : Endif' : Gosub ADDCLB
LIGNE = "Local Integer A_I" : Gosub ADDCLB
LIGNE = "Local Instance _WACTX Using C_WMACONTEXT" : Gosub ADDCLB
LIGNE = "_WACTX = cast(this.APARENT,C_WMACONTEXT)" : Gosub ADDCLB
LIGNE = "A_I = maxtab(this.ACOL)+1" : Gosub ADDCLB
LIGNE = "this.isReadonly = 0" : Gosub ADDCLB
LIGNE = 'this.ACOL(A_I) = NewInstance  C_'+CACHE+' (_WACTX,NullUuid,[L]A_I,this,"ACOL")'-[V]CST_ALLOCGROUP-"this" : Gosub ADDCLB
LIGNE = '[L]ASTATUS = fmet this.ACOL(A_I).AREAD([L]'+ACLA.ACLAK(ACLAK_NBR).INDEX(1)
For I=2 To ACLA.ACLAK(1).NBRIND
 LIGNE += ',[L]'+ACLA.ACLAK(ACLAK_NBR).INDEX(I)
Next
LIGNE += ')'  : Gosub ADDCLB
LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR'  : Gosub ADDCLB
DIF += 1
LIGNE = '[L]ARET_VALUE = -1'  : Gosub ADDCLB
For I=1 To ACLA.ACLAK(1).NBRIND
 LIGNE = 'this.ACOL(A_I).'+ACLA.ACLAK(ACLAK_NBR).INDEX(I)+'=[L]'+ACLA.ACLAK(ACLAK_NBR).INDEX(I)   : Gosub ADDCLB
Next
DIF -= 1
LIGNE = "Else"  : Gosub ADDCLB
DIF += 1
LIGNE = "[L]ARET_VALUE = [L]A_I" : Gosub ADDCLB
LIGNE = 'this.ACOL(A_I).APARENT = this'   : Gosub ADDCLB
DIF -= 1
LIGNE = "Endif" : Gosub ADDCLB
LIGNE = "this.ACOL(A_I).isReadonly = 1" : Gosub ADDCLB
LIGNE = "this.isReadonly = 1" : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB

LIGNE = "#"+string$(78,'-')+"#" : Gosub ADDCLB
LIGNE = "$AGETINDEX" : Gosub ADDCLB
LIGNE = "Local Integer A_I"  : Gosub ADDCLB
LIGNE = "[L]ARET_VALUE = -1" : Gosub ADDCLB
LIGNE = "For A_I=1 To maxtab(this.ACOL)"  : Gosub ADDCLB
LIGNE = ' If this.ACOL(A_I)<>null & this.ACOL(A_I).'+ACLA.ACLAK(ACLAK_NBR).INDEX(1)+'=[L]'+ACLA.ACLAK(ACLAK_NBR).INDEX(1)   : Gosub ADDCLB
For I=2 To ACLA.ACLAK(1).NBRIND
 LIGNE = '&   & this.ACOL(A_I).'+ACLA.ACLAK(ACLAK_NBR).INDEX(I)+'=[L]'+ACLA.ACLAK(ACLAK_NBR).INDEX(I)   : Gosub ADDCLB
Next
DIF += 1
LIGNE = '[L]ARET_VALUE= [L]A_I : Break' : Gosub ADDCLB
DIF -=1
LIGNE = ' Endif' : Gosub ADDCLB
LIGNE = 'Next' : Gosub ADDCLB
LIGNE = 'If [L]ARET_VALUE = -1' : Gosub ADDCLB
DIF +=1
LIGNE = '[L]ASTATUS = fmet this.AREAD([L]'+ACLA.ACLAK(ACLAK_NBR).INDEX(1)
For I=2 To ACLA.ACLAK(1).NBRIND
 LIGNE += ',[L]'+ACLA.ACLAK(ACLAK_NBR).INDEX(I)
Next
LIGNE += ")" : Gosub ADDCLB
LIGNE = "If [L]ASTATUS<[V]CST_AOK : Return : Endif"  : Gosub ADDCLB
LIGNE = '[L]ARET_VALUE = [L]ASTATUS' : Gosub ADDCLB
DIF-=1
LIGNE = ' Endif' : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB

LIGNE = "#"+string$(78,'-')+"#" : Gosub ADDCLB
LIGNE = "$AGETVAL" : Gosub ADDCLB
LIGNE = "Local Integer ASTATUS,A_I,A_J" : Gosub ADDCLB
LIGNE = '[L]ASTATUS = fmet this.AGETINDEX([L]'+ACLA.ACLAK(ACLAK_NBR).INDEX(1)
For I=2 To ACLA.ACLAK(1).NBRIND
 LIGNE += ',[L]'+ACLA.ACLAK(ACLAK_NBR).INDEX(I)
Next
LIGNE += ')'  : Gosub ADDCLB
LIGNE = "If [L]ASTATUS<[V]CST_AOK" : Gosub ADDCLB
DIF += 1
LIGNE = '[L]ASTATUS = fmet this.AREAD([L]'+ACLA.ACLAK(ACLAK_NBR).INDEX(1)
For I=2 To ACLA.ACLAK(1).NBRIND
 LIGNE += ',[L]'+ACLA.ACLAK(ACLAK_NBR).INDEX(I)
Next
LIGNE += ")" : Gosub ADDCLB
LIGNE = "If [L]ASTATUS<[V]CST_AOK : Return : Endif"  : Gosub ADDCLB
DIF -=1
LIGNE = 'Endif' : Gosub ADDCLB
LIGNE = 'If this.ACOL([L]ASTATUS)<>null' : Gosub ADDCLB
DIF += 1
LIGNE =  'If evalue("dim(this.ACOL([L]ASTATUS)."+[L]ACODPRO+")")>0'  : Gosub ADDCLB
DIF += 1
LIGNE =  'Assign "[L]ARET_VALUE" With evalue("this.ACOL([L]ASTATUS)."+[L]ACODPRO)'  : Gosub ADDCLB
LIGNE = "[L]A_J = 1" : Gosub ADDCLB
DIF -=1
LIGNE = 'Endif' : Gosub ADDCLB

LIGNE = "If [L]A_J=0" : Gosub ADDCLB
DIF += 1
LIGNE = '[L]ASTATUS = fmet this.ACOL([L]ASTATUS).ASETERROR("",[L]ACODPRO-":"-mess(38,140,1),[V]CST_AERROR) : # Propriété inexistante dans la classe' : Gosub ADDCLB
DIF -=1
LIGNE = 'Endif' : Gosub ADDCLB

DIF -=1
LIGNE = 'Endif' : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB

Gosub WRITE_CLOB

Close Local File [ACLA],[ATI],[ACLAF],[ATY]

End

#---------------------------------------------------------------------------------------------------#
## Load the class WMCONTEXTxxx in memory
#---------------------------------------------------------------------------------------------------#
Subprog LOAD_CHILDCLASS(DOSSIER,CODCLA,CODTRT,ACLA,CHAPTER)
Value Char DOSSIER,CODCLA,CODTRT
Variable  Instance  ACLA Using C_ACLA
Value Char CHAPTER

ACLA = NewInstance C_ACLA AllocGroup null
Local Instance AERR(1..)    Using C_AERROR
Call INI_ACLAVARDEF(CODCLA,DOSSIER,ACLA,AERR) From ACLAVALLEC
ACLA.CODCLA = CODCLA
ACLA.TYPCLA = 3
ACLA.FLGACTX = 2
ACLA.CODECLA =  ACLA.CODCLA

#For initialization treaments:
ACLA.NBRTRT +=1
ACLA.ACLATRT(ACLA.NBRTRT) = NewInstance C_ACLATRT AllocGroup ACLA
ACLA.ACLATRT(ACLA.NBRTRT).CODTRT = CODTRT # treatement automatically generated!
ACLA.ACLATRT(ACLA.NBRTRT).RANTRT = 1000
ACLA.ACLATRT(ACLA.NBRTRT).TYPTRT = 1 # Standard Type
ACLA.ACLATRT(ACLA.NBRTRT).ACTTRT = ""

Call LOAD_CTXTVAR(DOSSIER,CODCLA,CODTRT,ACLA,CHAPTER,1)

End


#---------------------------------------------------------------------------------------------------#
## Load Context Variables
#---------------------------------------------------------------------------------------------------#
Subprog LOAD_CTXTVAR(DOSSIER,CODCLA,CODTRT,ACLA,CHP,IS_CHILD)
Value Char DOSSIER,CODCLA,CODTRT
Variable  Instance  ACLA Using C_ACLA
Value Char CHP
Value Integer IS_CHILD

Local Integer ACLAF_NBR
Local Char    INTITFLD(255)
Local Integer ERROR
Local Char    EXPRESSION(80)
Local Char    LINE(250)(1..200)
Local Integer STAT
Local Char    HEADER(80)
Local Integer FWRITEINT

Gosub DECLARE_CLOB

Local File =DOSSIER+".ATYPE"    [ATY]
Local File =DOSSIER+".ACONTEXT" [ACTX]
Local File =DOSSIER+".ADOPAR"   [ADP]

### Step 1: build an instance of C_ACLA : ACLA ###
For [ACTX]ACTX1 Where CHAPTER=CHP

 ACLAF_NBR += 1
 ACLA.ACLAF(ACLAF_NBR) = NewInstance C_ACLAFLD AllocGroup ACLA

 ACLA.ACLAF(ACLAF_NBR).FLDCLA   = [F:ACTX]CODCTX   # Field name
 ACLA.ACLAF(ACLAF_NBR).ACLA     = ACLA     # Link to the parent
 ACLA.ACLAF(ACLAF_NBR).MENU     = 0

 ACLA.ACLAF(ACLAF_NBR).INTFLD =  [F:ACTX]INTIT
 ACLA.ACLAF(ACLAF_NBR).INTITFLD =func ASYRFNC.TEXTE(ACLA.ACLAF(ACLAF_NBR).INTFLD)

 If [F:ACTX]CHGMOD <> 2
  ACLA.ACLAF(ACLAF_NBR).FLGACCGET = 1
 Else
  ACLA.ACLAF(ACLAF_NBR).FLGACCGET = 2
 Endif

 #Type
 Read [ATY]CODTYP=[F:ACTX]CODTYP
 ACLA.ACLAF(ACLAF_NBR).ATY = NewInstance C_ACLATYPE AllocGroup ACLA
 SetInstance ACLA.ACLAF(ACLAF_NBR).ATY With [F:ATY]
 ACLA.ACLAF(ACLAF_NBR).CODTYP = [F:ACTX]CODTYP
 ACLA.ACLAF(ACLAF_NBR).LON    = 0

 If find([F:ATY]TYPTYP,7,9,10) & [F:ATY]LNGTYP<>0
  ACLA.ACLAF(ACLAF_NBR).LON = [F:ATY]LNGTYP
 Else
  If [F:ACTX]LNGTYP <> ""
   ACLA.ACLAF(ACLAF_NBR).LON =  evalue([F:ACTX]LNGTYP)
  Endif
 Endif

 If [F:ACTX]FORDIM(0) <> ""
  ACLA.ACLAF(ACLAF_NBR).FLDGRP = "TOTO"+num$(ACLAF_NBR)
  ACLA.ACLAF(ACLAF_NBR).DIME = val([F:ACTX]FORDIM(0))
 Else
  ACLA.ACLAF(ACLAF_NBR).DIME = 1
 Endif
Next ACTX0


### Step 2: write into treatment WMCONTEXT_CSTD, or WMCONTEXTxxx_CSTD ###

# $INIT
LIGNE = ""  : Gosub ADDCLB
LIGNE = "#"+string$(78,'-')+"#"  : Gosub ADDCLB
LIGNE = "$AINIT"  : Gosub ADDCLB
LIGNE = "Local Char    PARAM(250)"  : Gosub ADDCLB
LIGNE = "Local Integer RES"  : Gosub ADDCLB
If !IS_CHILD
 LIGNE = "Gosub ADD_INSTANCE"  : Gosub ADDCLB
Endif
LIGNE = "this.isReadonly = 0"  : Gosub ADDCLB
For I = 1 To ACLAF_NBR
 Call WRITETRT_INIT(DOSSIER,ACLA.ACLAF(I),LIGNE ,DIF,CLOB)
Next
LIGNE = "this.isReadonly = 1"  : Gosub ADDCLB
LIGNE = "Return"  : Gosub ADDCLB

# $GET
LIGNE = "" : Gosub ADDCLB
LIGNE = "#"+string$(78,'-')+"#"  : Gosub ADDCLB
LIGNE = "$GET"  : Gosub ADDCLB
LIGNE = "Local Char    PARAM(250)"  : Gosub ADDCLB
LIGNE = "Case CURPRO"  : Gosub ADDCLB
For I = 1 To ACLAF_NBR
 Call WRITETRT_GET(ACLA.ACLAF(I),LIGNE ,DIF,CLOB)
Next
LIGNE = "Endcase"  : Gosub ADDCLB
LIGNE = "Return"  : Gosub ADDCLB


# $GET_xxx
LIGNE = "" : Gosub ADDCLB
LIGNE = string$(78,'#')  : Gosub ADDCLB
LIGNE = "# GET for different properties"  : Gosub ADDCLB
LIGNE = string$(78,'#')  : Gosub ADDCLB
For I = 1 To ACLAF_NBR
 Call WRITETRT_GET_FLD(DOSSIER, ACLA.ACLAF(I),LIGNE ,DIF,CLOB)
Next


# $INIT_xxx
LIGNE = "" : Gosub ADDCLB
LIGNE = string$(78,'#')  : Gosub ADDCLB
LIGNE = "# INIT for different properties"  : Gosub ADDCLB
LIGNE =  string$(78,'#') : Gosub ADDCLB
For I = 1 To ACLAF_NBR
  Call WRITETRT_INIT_FLD(DOSSIER, ACLA.ACLAF(I), IS_CHILD,LIGNE ,DIF,CLOB)
Next

Gosub WRITE_CLOB

$FIN_L_CTXTVAR
Close Local File [ATY]
Close Local File [ACTX]
Close Local File [ADP]

End


#---------------------------------------------------------------------------------------------------#
## Load the class WMCONTEXT in memory
#---------------------------------------------------------------------------------------------------#
Subprog LOAD_ACONTEXT(DOSSIER,CODCLA,TRTSTD,TRTMET,ACLA,CHAPTERS,CACHES)
Value Char DOSSIER , CODCLA, TRTSTD, TRTMET
Variable  Instance  ACLA Using C_ACLA
Value Char CHAPTERS()(1..)
Value Char CACHES()(1..)

 Local File =DOSSIER+".ATYPE"    [ATY]

 Local Integer ACLAF_NBR, ACLAM_NBR, ACLAMP_NBR
 Local Integer I
 Local Char T_LINE(250)(1..200)
 Local Char CHP_OK(GLONADC)(1..)
 Local Char BUF_OK(GLONACLA)(1..)

 Gosub DECLARE_CLOB

 If maxtab(CHAPTERS)>0 : Call GET_VALID_CHP(DOSSIER, CHAPTERS, CHP_OK)     : Endif
 If maxtab(CACHES)>0   : Call GET_VALID_CACHES(DOSSIER, CACHES, BUF_OK) : Endif

 # Constructure
 LIGNE = ""  : Gosub ADDCLB
 LIGNE = "$ADD_INSTANCE"  : Gosub ADDCLB

 For I=1 To maxtab(CHP_OK)
  T_LINE = "this."+CHP_OK(I)-"= NewInstance C_"+CODCLA+CHP_OK(I)-[V]CST_ALLOCGROUP-"this"
  LIGNE = T_LINE  : Gosub ADDCLB
  LIGNE = "this."+CHP_OK(I)+".APARENT = this"  : Gosub ADDCLB
  LIGNE = "[L]ASTATUS = fmet this."+CHP_OK(I)+".AINIT"  : Gosub ADDCLB
  LIGNE = "this."+CHP_OK(I)+".isReadonly = 1"  : Gosub ADDCLB
 Next I

 LIGNE = "this."+func GET_CODE_PARAM+" = NewInstance C_"+func GET_NAME_PARAM-[V]CST_ALLOCGROUP-"this"  : Gosub ADDCLB
 LIGNE = "this."+func GET_CODE_PARAM+".APARENT = this"  : Gosub ADDCLB
 LIGNE = "this."+func GET_CODE_PARAM+".isReadonly = 1"  : Gosub ADDCLB

 LIGNE = "this."+func GET_CODE_CACHE+" = NewInstance C_"+func GET_NAME_CACHE-[V]CST_ALLOCGROUP-"this"  : Gosub ADDCLB
 LIGNE = "this."+func GET_CODE_CACHE+".APARENT = this"  : Gosub ADDCLB
 For I=1 To maxtab(BUF_OK)
  LIGNE = "this."+func GET_CODE_CACHE+"."+BUF_OK(I)-"= NewInstance C_"+func GET_PREFIX_CACHE+BUF_OK(I)-[V]CST_ALLOCGROUP-"this"  : Gosub ADDCLB
  LIGNE = "this."+func GET_CODE_CACHE+"."+BUF_OK(I)+".APARENT = this"  : Gosub ADDCLB
  LIGNE = "this."+func GET_CODE_CACHE+"."+BUF_OK(I)+".isReadonly = 1"  : Gosub ADDCLB
 Next
 LIGNE = "this."+func GET_CODE_CACHE+".isReadonly = 1"  : Gosub ADDCLB

 LIGNE = "this.isReadonly = 1"  : Gosub ADDCLB
 LIGNE = "this.getAccessorEnabled = 1"  : Gosub ADDCLB
 LIGNE = "Return"  : Gosub ADDCLB

 Gosub WRITE_CLOB

 ACLA = NewInstance  C_ACLA AllocGroup null
 Local Instance AERR(1..)    Using C_AERROR
 Call INI_ACLAVARDEF(CODCLA,DOSSIER,ACLA,AERR) From ACLAVALLEC
 ACLA.CODCLA = CODCLA
 ACLA.TYPCLA = 3
 ACLA.FLGACTX = 2
 ACLA.CODECLA =  ACLA.CODCLA

 #load context variables which doesn't belong to a category
 Call LOAD_CTXTVAR(DOSSIER,CODCLA,TRTSTD,ACLA,"",0)
 ACLAF_NBR = maxtab(ACLA.ACLAF)

 #For initialization treaments:
 ACLA.NBRTRT +=1
 ACLA.ACLATRT(ACLA.NBRTRT) = NewInstance C_ACLATRT AllocGroup ACLA
 ACLA.ACLATRT(ACLA.NBRTRT).CODTRT = TRTSTD# treatement automatically generated!
 ACLA.ACLATRT(ACLA.NBRTRT).RANTRT = 1000
 ACLA.ACLATRT(ACLA.NBRTRT).TYPTRT = 1 # Standard Type
 ACLA.ACLATRT(ACLA.NBRTRT).ACTTRT = ""

 ACLA.NBRTRT +=1
 ACLA.ACLATRT(ACLA.NBRTRT) = NewInstance C_ACLATRT AllocGroup ACLA
 ACLA.ACLATRT(ACLA.NBRTRT).CODTRT = TRTMET
 ACLA.ACLATRT(ACLA.NBRTRT).RANTRT = 1010
 ACLA.ACLATRT(ACLA.NBRTRT).TYPTRT = 1 # Standard Type
 ACLA.ACLATRT(ACLA.NBRTRT).ACTTRT = ""

 # add child class into class WMCONTEXT for each chapter in use
 For I=1 To maxtab(CHP_OK)
  ACLAF_NBR += 1
  ACLA.ACLAF(ACLAF_NBR) = NewInstance C_ACLAFLD AllocGroup ACLA
  ACLA.ACLAF(ACLAF_NBR).FLDCLA = CHP_OK(I)
  ACLA.ACLAF(ACLAF_NBR).LNKCLA = CODCLA + CHP_OK(I)
  ACLA.ACLAF(ACLAF_NBR).DIME   = 1
 Next I

 # add the param as child class into WMCONTEXT
 ACLAF_NBR += 1
 ACLA.ACLAF(ACLAF_NBR) = NewInstance C_ACLAFLD AllocGroup ACLA
 ACLA.ACLAF(ACLAF_NBR).FLDCLA = func GET_CODE_PARAM
 ACLA.ACLAF(ACLAF_NBR).LNKCLA = func GET_NAME_PARAM
 ACLA.ACLAF(ACLAF_NBR).DIME   = 1

 #add the bufffer as child class into WMCONTEXT
 ACLAF_NBR += 1
 ACLA.ACLAF(ACLAF_NBR) = NewInstance C_ACLAFLD AllocGroup ACLA
 ACLA.ACLAF(ACLAF_NBR).FLDCLA = func GET_CODE_CACHE
 ACLA.ACLAF(ACLAF_NBR).LNKCLA = func GET_NAME_CACHE
 ACLA.ACLAF(ACLAF_NBR).DIME   = 1

 #add the profil as child class into WMCONTEXT
 ACLAF_NBR += 1
 ACLA.ACLAF(ACLAF_NBR) = NewInstance C_ACLAFLD AllocGroup ACLA
 ACLA.ACLAF(ACLAF_NBR).FLDCLA = func GET_CODE_PROFIL
 ACLA.ACLAF(ACLAF_NBR).LNKCLA = func GET_NAME_PROFIL
 ACLA.ACLAF(ACLAF_NBR).LNKCLATYP = 4
 ACLA.ACLAF(ACLAF_NBR).DIME   = 1

#add the license as child class into WMCONTEXT
 ACLAF_NBR += 1
 ACLA.ACLAF(ACLAF_NBR) = NewInstance C_ACLAFLD AllocGroup ACLA
 ACLA.ACLAF(ACLAF_NBR).FLDCLA = func GET_CODE_LICENSE
 ACLA.ACLAF(ACLAF_NBR).LNKCLA = func GET_NAME_LICENSE
 ACLA.ACLAF(ACLAF_NBR).LNKCLATYP = 4
 ACLA.ACLAF(ACLAF_NBR).DIME   = 1

 # add methodes
 Gosub ADDACTXMET From ACTXVALMET

Close Local File [ATY]

End


#----------------------------------------------------------------------------#
# open/create trt WMCONTEXTxxx_CSTD and write the begining part $ACTION
#----------------------------------------------------------------------------#
Subprog OPENTRT(DOSSIER,TRTSTD,CHP,FICLCK,AERR,LOADTYPCLA)
Value Char DOSSIER,TRTSTD,CHP
Variable Char FICLCK
Variable  Instance  AERR(1..) Using C_AERROR
Value Integer LOADTYPCLA

 Local Char    FICTRT(GDIMFIC),FICTRTPAR(GDIMFIC), MACHINE(GDIMFIC), APPLI(GDIMFIC)
 Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

 # save a copy into CONTEXTxxx_CSTD.srcold
 Call SAVE_CSTD(DOSSIER,TRTSTD)

 # Open trt WMCONTEXTxxx_CSTD
 FICTRT = filpath("TRT",TRTSTD,"src",APPLI,"",MACHINE)
 Openo FICTRT,0 Using [FIC]
 Iomode adxifs "" Using [FIC]
 Iomode adxirs chr$(10) Using [FIC]
 Iomode adxium GUTF8 Using [FIC]

 Gosub DECLARE_CLOB

 ### WMCONTEXTxxx_CSTD : write the beginning part ###
 LIGNE = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"  : Gosub ADDCLB
 LIGNE = "#"-TRTSTD  : Gosub ADDCLB
 LIGNE = "#"-func SUBADC.CNVMIL(timestamp$)  : Gosub ADDCLB
 LIGNE = ""  : Gosub ADDCLB

 # $ACTION

 #LIGNE = "$ACTION"  : Gosub ADDCLB
 #LIGNE = "Return"  : Gosub ADDCLB
 #LIGNE = ""  : Gosub ADDCLB

 LIGNE = "$PROPERTIES"  : Gosub ADDCLB
 LIGNE = "Case ACTION"  : Gosub ADDCLB
 If LOADTYPCLA=1 : # Context main
  LIGNE = ' When "GET" : Gosub GET'  : Gosub ADDCLB
 Elsif LOADTYPCLA=2 : # chapter context
  LIGNE = ' When "GET" : Gosub GET'  : Gosub ADDCLB
 Endif
 LIGNE = " When Default"  : Gosub ADDCLB
 LIGNE = "Endcase"  : Gosub ADDCLB
 LIGNE = "Return"  : Gosub ADDCLB
 LIGNE = ""  : Gosub ADDCLB

 LIGNE = "$EVENTS"  : Gosub ADDCLB
 LIGNE = "Case AEVENT"  : Gosub ADDCLB
 If LOADTYPCLA=1 : # Context main
  LIGNE = ' When "AINIT" : Gosub AINIT'  : Gosub ADDCLB
 Elsif LOADTYPCLA=2 : # chapter context
  LIGNE = ' When "AINIT" : Gosub AINIT'  : Gosub ADDCLB
 Endif
 LIGNE = " When Default"  : Gosub ADDCLB
 LIGNE = "Endcase"  : Gosub ADDCLB
 LIGNE = "Return"  : Gosub ADDCLB
 LIGNE = ""  : Gosub ADDCLB

 LIGNE = "$METHODS"  : Gosub ADDCLB
 LIGNE = "Case [L]AMETHOD"  : Gosub ADDCLB
 If LOADTYPCLA=3
  LIGNE = ' When "AREAD" : Gosub AREAD'  : Gosub ADDCLB
  LIGNE = ' When "AGETINDEX" : Gosub AGETINDEX'  : Gosub ADDCLB
  LIGNE = ' When "AGETVALCHAR" : Gosub AGETVAL'  : Gosub ADDCLB
  LIGNE = ' When "AGETVALNUM" : Gosub AGETVAL'  : Gosub ADDCLB
  LIGNE = ' When "AGETVALDAT" : Gosub AGETVAL'  : Gosub ADDCLB
  LIGNE = ' When "AGETVALDEC" : Gosub AGETVAL'  : Gosub ADDCLB
 Elsif LOADTYPCLA=4
  LIGNE = ' When "ACLEAN" : Gosub ACLEAN'  : Gosub ADDCLB
 Endif
 LIGNE = " When Default"  : Gosub ADDCLB
 LIGNE = "Endcase"  : Gosub ADDCLB
 LIGNE = "Return"  : Gosub ADDCLB
 Gosub WRITE_CLOB
End


#----------------------------------------------------------------------------#
Subprog CLOSETRT(DOSSIER,TRTSTD,FICLCK,AERR)
Value Char DOSSIER,TRTSTD,FICLCK
Variable Instance AERR(1..) Using C_AERROR
 Local Integer SUCCESS,TYPAGE
 Openo Using [FIC]
 Openo Using [FICPAR]
 #Validate the treatment
 Call VALID("TRT",TRTSTD,2,DOSSIER,0,TYPAGE,SUCCESS,AERR) From ACLAVALSUB
End



#-----------------------------------------------------------------------------#
# write $INIT into trt WMCONTEXTxxx_CSTD
#-----------------------------------------------------------------------------#
Subprog WRITETRT_INIT(DOSSIER,ACLAF,LIGNE,DIF,CLOB)
Value Char DOSSIER
Variable  Instance  ACLAF Using C_ACLAFLD
Variable Char LIGNE
Variable Integer DIF
Variable Clbfile CLOB

Local File =DOSSIER+".ATYPE"    [ATY]
Local File =DOSSIER+".ACONTEXT" [ACTX]
Local File =DOSSIER+".ADOPAR"   [ADP]

Read[ACTX]ACTX0 = ACLAF.FLDCLA
If fstat : Goto FIN_WRITETRT : Endif
If ACLAF.FLGACCGET<>2
 # Paramètre/Formule/TRT init
 If [F:ACTX]PARAM <> "" or [F:ACTX]FORINI <> "" or len([F:ACTX]TRTINI) > 0
  LIGNE = "Gosub INIT_"+ACLAF.FLDCLA : Gosub ADDCLB
 Endif
Else
 LIGNE = 'RES = fmet this.ASETATTRIBUTE("'+ACLAF.FLDCLA+'","STA","0")' : Gosub ADDCLB
Endif

$FIN_WRITETRT
Close Local File [ATY]
Close Local File [ACTX]
Close Local File [ADP]
End



#-----------------------------------------------------------------------------#
# write $INIT_xxx into trt WMCONTEXTxxx_CSTD
#-----------------------------------------------------------------------------#
Subprog WRITETRT_INIT_FLD(DOSSIER, ACLAF, IS_CHILD,LIGNE,DIF,CLOB)
Value Char DOSSIER
Variable  Instance  ACLAF Using C_ACLAFLD
Value Integer IS_CHILD
Variable Char LIGNE
Variable Integer DIF
Variable Clbfile CLOB

 Local Integer FWRITE_RM
 Local Char    INTITFLD(255)
 Local File =DOSSIER+".ATYPE"    [ATY]
 Local File =DOSSIER+".ACONTEXT" [ACTX]
 Local File =DOSSIER+".ADOPAR"   [ADP]

  Read[ACTX]ACTX0 = ACLAF.FLDCLA
  If fstat : Goto FIN_WRITETRT_INIT_FLD : Endif


  FWRITE_RM = 1
  # Paramètre
  If [F:ACTX]PARAM <> ""
   If FWRITE_RM
    LIGNE = "" : Gosub ADDCLB
    #LIGNE = "#"+string$(78,'-')+"#"  : Gosub ADDCLB
    LIGNE = "#"+ACLAF.FLDCLA-":"-func ASYRFNC.TEXTE([F:ACTX]INTIT)  : Gosub ADDCLB
    LIGNE = "$INIT_"+ACLAF.FLDCLA  : Gosub ADDCLB
    FWRITE_RM=0
   Endif
   Read [ADP]ADP1 = [F:ACTX]PARAM
   If [F:ADP]NIVDEF<>4
    #LIGNE = 'Call PARAM("","'+[F:ACTX]PARAM+'",PARAM) From ADOVAL'  : Gosub ADDCLB
    If IS_CHILD
     LIGNE = 'PARAM = func ADP_TOOL.GET_PARAM(this.APARENT.AFOLDER,1,"","'+[F:ACTX]PARAM+'")'  : Gosub ADDCLB
    Else
     LIGNE = 'PARAM = func ADP_TOOL.GET_PARAM(this.AFOLDER,1,"","'+[F:ACTX]PARAM+'")'  : Gosub ADDCLB
    Endif
   Else
    #LIGNE = 'Call PARAMUTIL("'+[F:ACTX]PARAM+'",PARAM,"","") From SUBAUS'  : Gosub ADDCLB
    If IS_CHILD
     LIGNE = 'PARAM = func ADP_TOOL.GET_PARAM_USER(this.APARENT.AFOLDER,this.APARENT.USER, "'+[F:ACTX]PARAM+'")'  : Gosub ADDCLB
    Else
     LIGNE = 'PARAM = func ADP_TOOL.GET_PARAM_USER(this.AFOLDER,this.USER, "'+[F:ACTX]PARAM+'")'  : Gosub ADDCLB
    Endif
   Endif
   Read [ATY]CODTYP = [F:ACTX]CODTYP
   If [F:ATY]TYPTYP=7 : # Char
    LIGNE = "this."+[F:ACTX]CODCTX+" = PARAM"  : Gosub ADDCLB
   Elsif [F:ATY]TYPTYP=8 : # Date
    LIGNE = "If len(PARAM)=6 | len(PARAM)=8 : "  : Gosub ADDCLB
    LIGNE = " this."+[F:ACTX]CODCTX+" = PARAM"  : Gosub ADDCLB
    LIGNE = "Endif"  : Gosub ADDCLB
   Else
    LIGNE = "this."+[F:ACTX]CODCTX+" = val(PARAM)"  : Gosub ADDCLB
   Endif
  Endif

  # Formule
  If [F:ACTX]FORINI <> ""
   If FWRITE_RM
    LIGNE = "" : Gosub ADDCLB
    LIGNE = "#"+ACLAF.FLDCLA-":"-INTITFLD  : Gosub ADDCLB
    LIGNE = "$INIT_"+ACLAF.FLDCLA  : Gosub ADDCLB
    FWRITE_RM=0
   Endif
   LIGNE = "   this."+[F:ACTX]CODCTX+" = "+[F:ACTX]FORINI  : Gosub ADDCLB
  Endif

  # TRT init
  If len([F:ACTX]TRTINI) > 0
   Local Char    TRTLIGNE(250)(1..200)
   Local Integer I,K
   If FWRITE_RM
    LIGNE = "" : Gosub ADDCLB
    LIGNE = "#"+ACLAF.FLDCLA-":"-INTITFLD  : Gosub ADDCLB
    LIGNE = "$INIT_"+ACLAF.FLDCLA  : Gosub ADDCLB
    FWRITE_RM=0
   Endif
   #Be careful of End Of Line characters!
   Setlob TRTLIGNE With [F:ACTX]TRTINI
   K = dim(TRTLIGNE)
   While K & TRTLIGNE(K)=""
   K -= 1
   Wend
   For I=1 To K
    K = instr(1,TRTLIGNE(I),chr$(13))
    While K
     TRTLIGNE(I) = left$(TRTLIGNE(I),K-1)+right$(TRTLIGNE(I),K+1)
     K = instr(K,TRTLIGNE(I),chr$(13))
    Wend
    LIGNE = TRTLIGNE(I)  : Gosub ADDCLB
   Next I
  Endif

 If FWRITE_RM = 0
  LIGNE = "Return"  : Gosub ADDCLB
 Endif

$FIN_WRITETRT_INIT_FLD
 Close Local File [ATY]
 Close Local File [ACTX]
 Close Local File [ADP]
End


#-----------------------------------------------------------------------------#
# write $GET into trt WMCONTEXTxxx_CSTD
#-----------------------------------------------------------------------------#
Subprog WRITETRT_GET(ACLAF,LIGNE,DIF,CLOB)
Variable  Instance  ACLAF Using C_ACLAFLD
Variable Char LIGNE
Variable Integer DIF
Variable Clbfile CLOB
If ACLAF.FLGACCGET=2
 LIGNE = 'When "'+ACLAF.FLDCLA+'" : Gosub '+"GET_"+ACLAF.FLDCLA : Gosub ADDCLB
Endif
End


#-----------------------------------------------------------------------------#
# write $GET_(field) into trt WMCONTEXTxxx_CSTD
#-----------------------------------------------------------------------------#
Subprog WRITETRT_GET_FLD(DOSSIER,ACLAF,LIGNE,DIF,CLOB)
Value Char DOSSIER
Variable  Instance  ACLAF Using C_ACLAFLD
Variable Char LIGNE
Variable Integer DIF
Variable Clbfile CLOB

 Local Char    INTITFLD(255)
 Local File =DOSSIER+".ATYPE"    [ATY]
 Local File =DOSSIER+".ACONTEXT" [ACTX]
 Local File =DOSSIER+".ADOPAR"   [ADP]

 FWRITE_LOC = 1

 If ACLAF.FLGACCGET = 2
  Read[ACTX]ACTX0 = ACLAF.FLDCLA
  If fstat : Goto FIN_WRITETRT_GET_FLD : Endif

  LIGNE = "" : Gosub ADDCLB
  #LIGNE = "#"+string$(78,'-')+"#"  : Gosub ADDCLB
  LIGNE = "#"+ACLAF.FLDCLA-":"-func ASYRFNC.TEXTE([F:ACTX]INTIT)  : Gosub ADDCLB
  LIGNE = "$GET_"+ACLAF.FLDCLA  : Gosub ADDCLB
  LIGNE = "Local Char    PARAM(250)"  : Gosub ADDCLB
  LIGNE = 'If Fmet THIS.AGETATTRIBUTE("'+ACLAF.FLDCLA+'","STA")<>"1"'  : Gosub ADDCLB

  # Paramètre/Formule/TRT init
  If [F:ACTX]PARAM <> "" or [F:ACTX]FORINI <> "" or len([F:ACTX]TRTINI) > 0
   LIGNE = " this.isReadonly = 0"  : Gosub ADDCLB
   LIGNE = " Gosub INIT_"+ACLAF.FLDCLA  : Gosub ADDCLB
   LIGNE = " this.isReadonly = 1"  : Gosub ADDCLB
  Endif
  LIGNE = ' Local Integer RES : RES = Fmet THIS.ASETATTRIBUTE("'+ACLAF.FLDCLA+'","STA","1")'   : Gosub ADDCLB

  LIGNE = "Endif"  : Gosub ADDCLB
  LIGNE = "Return"  : Gosub ADDCLB
 Endif
$FIN_WRITETRT_GET_FLD
 Close Local File [ATY]
 Close Local File [ACTX]
 Close Local File [ADP]
End



#--------------------------------------------------------------------------------------#
# Remove the child class and the trt associated for a CHAPTER that is no longer in use.
#--------------------------------------------------------------------------------------#
Subprog REMOVE(DOSSIER, CODCHP)
Value Char DOSSIER
Value Char CODCHP

 Local Integer FOUND,STAT
 Local Char CHAPTERS(GLONADC)(1..)
 Local Char NAME_CONTEXT(GLONACLA)
 NAME_CONTEXT = func GET_CTX_NAME
 Local Char SUFFIX_TRT(10)
 SUFFIX_TRT = func GET_CTX_SUFFIX_TRT

 Local Char FICHIER(GDIMFIC),MACHINE(GDIMFIC), APPLI(GDIMFIC)
 Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

 Call LOAD_CHAPTERS(DOSSIER,CHAPTERS)
 FOUND = find(CODCHP,CHAPTERS)

 If !FOUND
  # 1: remove C_WMCONTEXTxxx, and WMCLAnC_WMCONTEXTxxx
  Call DELETE_STC(DOSSIER,NAME_CONTEXT+CODCHP) From ACLAVALSUB
  # 2: remove trt WMCONTEXTxxx_CSTD
  FICHIER = filpath("TRT",NAME_CONTEXT+CODCHP+SUFFIX_TRT,"src",APPLI,"",MACHINE)
  If filinfo(FICHIER,0)>=0
   Call _EFFACE(FICHIER,STAT) From ASYRSYS
  Endif
  Call EXISTE_ADX("",APPLI,NAME_CONTEXT+CODCHP+SUFFIX_TRT,FOUND) From ASYRSYS
  If FOUND>0
   Call _EFFACE_ADX("",APPLI,NAME_CONTEXT+CODCHP+SUFFIX_TRT,STAT) From ASYRSYS
  Endif

 Endif

End


#----------------------------------------------------------------------------#
# Retrieve the list of chapters
#----------------------------------------------------------------------------#
Subprog LOAD_CHAPTERS(DOSSIER,CHAPTERS)
Value Char    DOSSIER
Variable Char CHAPTERS()(1..)

 Local Integer NB_CHAPTERS
 Local File =DOSSIER+".ATABDIV"         [ADI]
 Local File =DOSSIER+".ACONTEXT"       [ACTX]

 Raz CHAPTERS
 For [ACTX]ACTX1(1)
  If [F:ACTX]CHAPTER <> ""
   NB_CHAPTERS += 1
   CHAPTERS(NB_CHAPTERS) = [F:ACTX]CHAPTER
  Endif
 Next
 Close Local File [ADI]
 Close Local File [ACTX]

End

#----------------------------------------------------------------------------#
# Retrieve the list of CACHE class
#----------------------------------------------------------------------------#
Subprog LOAD_CACHECLASS(DOSSIER,TBCACHE)
Value Char    DOSSIER
Variable Char TBCACHE()(1..)

Local Integer NB_CACHES
Local File =DOSSIER+".ACLASSE"         [ACLA]

Raz TBCACHE
For [F:ACLA]ACLA0
 If [F:ACLA]FLGBUFFER=2
  NB_CACHES += 1
  TBCACHE(NB_CACHES) = [F:ACLA]CODCLA
 Endif
Next

Close Local File [ACLA]
End


#-------------------------------------------------------#
Subprog SAVE_CSTD(DOSSIER,TRTSTD)
Value Char DOSSIER, TRTSTD

 Local Integer STAT
 Local Char    FICSAV(GDIMFIC)
 Local Char    FICHIER(GDIMFIC)
 Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)

 Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS
 FICSAV  = filpath("TRT",TRTSTD,"srcold",APPLI,"",MACHINE)
 FICHIER = filpath("TRT",TRTSTD,"src",APPLI,"",MACHINE)
 If filinfo(FICHIER,0)>=0
  Call _COPIE(FICHIER,FICSAV,STAT) From ASYRSYS
 Endif

End


#-------------------------------------------------------#
Subprog RESTORE_CSTD(DOSSIER,TRTSTD)
Value Char DOSSIER, TRTSTD

 Local Integer STAT,SUCCESS,TYPAGE
 Local Char    FICSAV(GDIMFIC)
 Local Char    FICHIER(GDIMFIC)
 Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)
 Local Instance AERR(1..) Using C_AERROR

 Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS
 FICSAV  = filpath("TRT",TRTSTD,"srcold",APPLI,"",MACHINE)
 FICHIER = filpath("TRT",TRTSTD,"src",APPLI,"",MACHINE)
 If filinfo(FICSAV,0)>=0
  Call _COPIE(FICSAV,FICHIER,STAT) From ASYRSYS
  Call _EFFACE(FICSAV,STAT) From ASYRSYS
  Call VALID("TRT",TRTSTD,2,APPLI,0,TYPAGE,SUCCESS,AERR) From ACLAVALSUB
 Endif

End

#-------------------------------------------------------#
Subprog CLEAN_CSTDOLD(DOSSIER,TRTSTD)
Value Char DOSSIER, TRTSTD

 Local Integer STAT
 Local Char    FICANU(GDIMFIC)
 Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)

 Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS
 FICANU =  filpath("TRT",TRTSTD,"srcold",APPLI,"",MACHINE)
 If filinfo(FICANU,0)>=0
  Call _EFFACE(FICANU,STAT) From ASYRSYS
 Endif

End

#-------------------------------------------------------#
# extract only the already validated chapters
#-------------------------------------------------------#
Subprog GET_VALID_CHP(DOSSIER, CHAPTERS, CHP_OK)
Value Char DOSSIER
Variable Char CHAPTERS()(1..)
Variable Char CHP_OK()(1..)
 Local Char    FICHIER(GDIMFIC)
 Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)
 Local Char    NAME_CONTEXT(GLONACLA)
 Local Integer I, J

 Raz CHP_OK
 NAME_CONTEXT = func GET_CTX_NAME
 Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS
 For I = 1 To maxtab(CHAPTERS)
  NM_STC = func SUBACLA.PREFIX_CLA+NAME_CONTEXT+CHAPTERS(I)
  FICHIER = filpath("STC",NM_STC,"stc",APPLI,"",MACHINE)
  If filinfo(FICHIER,0)>=0
   J+=1
   CHP_OK(J) = CHAPTERS(I)
  Endif
 Next
End

#-------------------------------------------------------#
# extract only the already validated chapters
#-------------------------------------------------------#
Subprog GET_VALID_CACHES(DOSSIER, CACHES, BUF_OK)
Value Char DOSSIER
Variable Char CACHES()(1..)
Variable Char BUF_OK()(1..)
 Local Char    FICHIER(GDIMFIC)
 Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)
 Local Integer I, J

 Raz BUF_OK
 Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS
 For I = 1 To maxtab(CACHES)
  NM_STC = func SUBACLA.PREFIX_CLA+func GET_PREFIX_CACHE+CACHES(I)
  FICHIER = filpath("STC",NM_STC,"stc",APPLI,"",MACHINE)
  If filinfo(FICHIER,0)>=0
   J+=1
   BUF_OK(J) = CACHES(I)
  Endif
 Next
End

