#<AdxTL>@(#)1.0.0.0 $Revision$
#############################################################################
# TRTSYNBICPT  -   Fonctions pour la Business Intelligence  -  Comptabilité #
#############################################################################

###################################################################
## ACTION Mise à jour des tables de faits X3                      #
###################################################################
$ACTION
Case ACTION
 When "DEBUT_FAT"  : Gosub DEBUT_FAT
 When "FIN_FAT"    : Gosub FIN_FAT
#
 When "B_BREAK"   : Gosub B_BREAK
 When "B_CRITERE" : Gosub B_CRITERE
 When "B_LOOP"    : Gosub B_LOOP
#
Endcase
Return

$DEBUT_FAT
If [F:ABV]TABORG="GACCENTRYA"
 #-- Pour règle synchro ACC3 Lignes analytiques comptables
 # Globales pour l'alimentation des champs Axes dans les lignes de la tables de faits 
 # puisque partout les mêmes  puisque dépendant des paramètres BIDIE01 à 20
 Global Char   GBICPTDIE(GLONDIE)(1..20)
 For I=1 To 20
  If I<10
   Call PARAM("","BIDIE0"+num$(I),GBICPTDIE(I)) From ADOVAL
  Else
   Call PARAM("","BIDIE"+num$(I),GBICPTDIE(I)) From ADOVAL
  Endif 
 Next
Endif 
Return

#############################################################################
$FIN_FAT
If [F:ABV]TABORG="GACCENTRYA"
 If dim([V]GBICPTDIE)>0
  Kill [V]GBICPTDIE
 Endif
Endif
Return


############################## Perf Resynchro ################################
$B_BREAK
If dim(GMAXUPDTRS)>0
 B_BREAK = max(GMAXUPDTRS,50000)
Else
 B_BREAK = 50000
Endif
Local Char    B_CLE1(250),B_CLE2(250)
Local Integer B_CLE3, B_CLE4, B_CLE5
Return

$B_CRITERE
Case [F:ABV]TABORG
 When "GACCENTRYD" :# Lignes comptables
  B_CLE1 = [F:DAE]TYP
  B_CLE2 = [F:DAE]NUM
  B_CLE3 = [F:DAE]LIN
  B_CLE4 = [F:DAE]LEDTYP
 When "GACCDUDATE" :# Echéances
  B_CLE1 = [F:DUD]TYP
  B_CLE2 = [F:DUD]NUM
  B_CLE3 = [F:DUD]LIG
  B_CLE4 = [F:DUD]DUDLIG  
 When "GACCENTRYA" :# Lignes analytiques
  B_CLE1 = [F:DAA]TYP
  B_CLE2 = [F:DAA]NUM
  B_CLE3 = [F:DAA]LIN
  B_CLE4 = [F:DAA]LEDTYP
  B_CLE5 = [F:DAA]ANALIN 
Endcase
B_STOP = 1
Return


$B_LOOP
 Case [F:ABV]TABORG
  When "GACCENTRYD" :# Lignes comptables
   Gosub CRI_DAE
  When "GACCDUDATE" :# Echéances
   Gosub CRI_DUD 
  When "GACCENTRYA" :# Lignes analytiques
   Gosub CRI_DAA
 Endcase
Return

$CRI_DAE
If B_STOP=1
  B_CRITERE = 'TYP="'+B_CLE1+'" & NUM="'+B_CLE2+'" & LIN='+num$(B_CLE3)+' & LEDTYP>'+num$(B_CLE4)
  B_STOP=2
Elsif B_STOP=2
  B_CRITERE = 'TYP="'+B_CLE1+'" & NUM="'+B_CLE2+'" & LIN>'+num$(B_CLE3)
  B_STOP=3
Elsif B_STOP=3
  B_CRITERE = 'TYP="'+B_CLE1+'" & NUM>"'+B_CLE2+'"'
  B_STOP=4 
Elsif B_STOP=4
  B_CRITERE = 'TYP>"'+B_CLE1+'"'
  B_STOP=0
Else
  B_CRITERE="1=1"
Endif
Return

$CRI_DUD
If B_STOP=1
  B_CRITERE = 'TYP="'+B_CLE1+'" & NUM="'+B_CLE2+'" & LIG='+num$(B_CLE3)+' & DUDLIG>'+num$(B_CLE4)
  B_STOP=2
Elsif B_STOP=2
  B_CRITERE = 'TYP="'+B_CLE1+'" & NUM="'+B_CLE2+'" & LIG>'+num$(B_CLE3)
  B_STOP=3
Elsif B_STOP=3
  B_CRITERE = 'TYP="'+B_CLE1+'" & NUM>"'+B_CLE2+'"'
  B_STOP=4 
Elsif B_STOP=4
  B_CRITERE = 'TYP>"'+B_CLE1+'"'
  B_STOP=0
Else
  B_CRITERE="1=1"
Endif
Return

$CRI_DAA
If B_STOP=1
  B_CRITERE = 'TYP="'+B_CLE1+'" & NUM="'+B_CLE2+'" & LIN='+num$(B_CLE3)+' & LEDTYP='+num$(B_CLE4)+' & ANALIN>'+num$(B_CLE5)
  B_STOP=2
Elsif B_STOP=2
  B_CRITERE = 'TYP="'+B_CLE1+'" & NUM="'+B_CLE2+'" & LIN='+num$(B_CLE3)+' & LEDTYP>'+num$(B_CLE4)
  B_STOP=3
Elsif B_STOP=3
  B_CRITERE = 'TYP="'+B_CLE1+'" & NUM="'+B_CLE2+'" & LIN>'+num$(B_CLE3)
  B_STOP=4
Elsif B_STOP=4
  B_CRITERE = 'TYP="'+B_CLE1+'" & NUM>"'+B_CLE2+'"'
  B_STOP=5 
Elsif B_STOP=5
  B_CRITERE = 'TYP>"'+B_CLE1+'"'
  B_STOP=0
Else
  B_CRITERE="1=1"
Endif
Return
