#<AdxTL>@(#)0.0.0.0 $Revision$
Call PASSWD("database.software.sqlsystempwd",GBIDC1,GBIDI1)
Infbox GBIDC1
End

Subprog CREBASE

Onerrgo ERREUR

Local Char    ORDSYS(250)(1..2)
Local Integer STAT , I
Local Char    MESSAGE(255)(1..2) , FICHIERLOG(GDIMFIC) , LIGNE(255)
# jira X3-86047 86048 86049
Local Char    AUTHEN_LOGIN (100)
Local Char    AUTHEN_PWD (100)
Local Char    X3_PWD (100)

##############################################################################################
#----- Pour NT
# les quatre variables suivantes devront être fournies par le programme de valid de dossier
# ces paramètres sont utilisés lors de l'appel de adcrapora.bat et adcrapdb2.bat
# et adcrapss7 lors de groupe de fichier
##############################################################################################

Local Integer INITINCDAT : # taille initiale DAT
Local Integer INITNXTDAT : # taille next     DAT
Local Integer INITINCIDX : # taille initiale IDX
Local Integer INITNXTIDX : # taille initiale IDX

##############################################################################################
#----- Pour Db2
# PC 16/12/99
# les variables suivantes seront renseignees afin de définir les chemins d'installations des conteneurs
# Pour l'instant ils sont definis par defaut
# mais on peut tres bien concevoir qu'un jour ils soient differents ! ! !
##############################################################################################

Local Char    CHMCONTDAT(100) : # chemin d'acces au conteneur de donnees
Local Char    CHMCONTIDX(100) : # chemin d'acces au conteneur des index

If !GCRE : End : Endif

Case [F:ADS]TYPDBA
 When 1 : Gosub ORACLE
 When 2 : Gosub SQLS7
 When 3 : Gosub CISAM
 When 4 : Gosub DB2
Endcase

MESSAGE(1) = "SPACE FOR STORAGE NOT FOUND"
MESSAGE(2) = "USER NOT FOUND"
FICHIERLOG = filpath(adxdir+"/tmp","show_user_"+[F:ADS]DOSSIER,"log")
If filinfo(FICHIERLOG,0)>0
 Openi FICHIERLOG Using [LOG_]
 Iomode adxifs ""       Using [LOG_]
 Iomode adxirs chr$(10) Using [LOG_]
 Iomode adxium GASCII   Using [LOG_]
 Rdseq LIGNE Using [LOG_]
 While !fstat
  For I=1 To 2
   If instr(1,LIGNE,MESSAGE(I))<>0
    Call ECR_TRACE(MESSAGE(I),1) From GESECRAN
    GERRDOS = 1 : Break
   Endif
  Next I
  Rdseq LIGNE Using [LOG_]
 Wend
 Openi Using [LOG_]
Endif

Onerrgo

End

##############################################################################################
#----- Pour Cisam
##############################################################################################

$CISAM
# X3BY Pour les test en C-ISAM avec X3 Sous Oracle
ORDSYS(1) = "adxora -b"-getenv$("ORACLE_SID")-"-u"-GDOSX3-"-p tiger"-[F:ADS]DOSSIER
Call ECR_TRACE(ORDSYS(1),0) From GESECRAN
Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
ORDSYS(2) = filpath("TRA",GTRACE,"tra")
Return

##############################################################################################
#----- Pour Sql server
##############################################################################################

$SQLS7
If GOS(1)= "" : Return :  Endif

If GINFO
   Call AFF_VLC(mess(80,125,1),"") From GESECRAN : # Création user Sql-server
Endif
Call ECR_TIME(mess(80,125,1)) From DOSSUB : # Création user Sql-server

# Modifier les lignes suivantes :
INITINCDAT = 100
INITNXTDAT = 100
INITINCIDX = 100
INITNXTIDX = 100

# jira X3-86047 86048 86049
# recuperation du compte sa....AUTHEN_LOGIN
# si on trouve rien sa par défaut.....
Call PASSWD("database.software.sqlinternallogin",AUTHEN_LOGIN,GERRDOS)
If GERRDOS : Return : Endif

# Récupération du passwd authenfication login
Call PASSWD("database.software.sqlinternalpwd",AUTHEN_PWD,GERRDOS)
If GERRDOS : Return : Endif

#recuperation du password pour X3 tiger par example X3_PWD
# si on trouve rien tiger par defaut......
Call PASSWD("database.software.sqlfolderpwd",X3_PWD,GERRDOS)
If GERRDOS : Return : Endif


Case GOS(1)

 When "unix"
  #################################################################################################################################
  # usage : $1 -o folder-name -s db-name -p sa-password -r parent-folder [-x repartition-in-file-groups -d data-size -i index-size]
  #################################################################################################################################

  ORDSYS(1) = 'adcrapss7'
  ORDSYS(1) -= '-o'-[F:ADS]DOSSIER
  ORDSYS(1) -= '-s'-right$(getenv$("CONNECTSTR"),instr(0,getenv$("CONNECTSTR"),"#")+1)
  ORDSYS(1) -= '-p'-AUTHEN_PWD
  ORDSYS(1) -= '-r'-[F:ADS]DOSSIER
  If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
     ORDSYS(1) -= '-u'-AUTHEN_LOGIN
     ORDSYS(1) -= '-P'-X3_PWD
  Endif
  If dim([F:ADS]GRPFIL)<=0 or [F:ADS]GRPFIL=1
   ORDSYS(1) -= '-x NO'
  Elsif [F:ADS]GRPFIL=2
   ORDSYS(1) -= '-x YES'
   ORDSYS(1) -= '-d'-num$(INITINCDAT)
   ORDSYS(1) -= '-i'-num$(INITINCIDX)
  Endif
  ORDSYS(2) = filpath("TRA",GTRACE,"tra")
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

 When "dos"
    #---- suite normale
    CHEMINWRK = adxdir + "\tmp"
    # test version du runtime ...... à partir du R091 adcrap a changer 10 parametres....2018R05
    # ver$(0) instruction runtime pour connaitre version
    ORDSYS(1) = adxdir+"\ebin\adcrapss7.bat"-[F:ADS]DOSSIER-getenv$("SQLS7_SID")-CHEMINWRK
    If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
    #################################################################################
    # p1 = Folder name (ex. DEMO)
    # p2 = Database name (ex. Adonix)
    # p3 = Working path (ADXDIR\tmp)
    # p4 = Parent Folder (parent folder for archive folder or folder name)
    # p5 = AUTHENTIFICATION LOGIN (EXAMPLE SA )
    # p6 = AUTHENTIFICATION password
    # p7 = X3 password For Folder 'ex. tiger'
    # p8 = Repartition in file groups YES/NO
    # p9 = Data file size if file groups
    # p10 = Index file size if file groups
    #################################################################################
    # password doit etre passé avec des " pour prendre en compter les blancs
    # voir a faire de même sur linux ????
        ORDSYS(1) -= [F:ADS]DOSSIER-'"'+num$(AUTHEN_LOGIN)+'"'-'"'+num$(AUTHEN_PWD)+'"'-'"'+num$(X3_PWD)+'"'
        If dim([F:ADS]GRPFIL)<=0 or [F:ADS]GRPFIL=1
             ORDSYS(1) -= "NO"-num$(INITINCDAT)-num$(INITINCIDX)
        Elsif [F:ADS]GRPFIL=2
             ORDSYS(1) -= "YES"-num$(INITINCDAT)-num$(INITINCIDX)
        Endif
    Else
    #################################################################################
    # p1 = Folder name (ex. DEMO)
    # p2 = Database name (ex. Adonix)
    # p3 = Working path (ADXDIR\tmp)
    # p4 = Parent Folder (parent folder for archive folder or folder name)
    # p5 = sa password
    # p6 = Repartition in file groups YES/NO
    # p7 = Data file size if file groups
    # p8 = Index file size if file groups
    #################################################################################
        ORDSYS(1) -= [F:ADS]DOSSIER-'"'+num$(AUTHEN_PWD)+'"'
        If dim([F:ADS]GRPFIL)<=0 or [F:ADS]GRPFIL=1
             ORDSYS(1) -= "NO"-num$(INITINCDAT)-num$(INITINCIDX)
        Elsif [F:ADS]GRPFIL=2
             ORDSYS(1) -= "YES"-num$(INITINCDAT)-num$(INITINCIDX)
        Endif
    Endif
    ORDSYS(2) = filpath("TRA",GTRACE,"tra")
    Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
Endcase
Return

##############################################################################################
#---- pour Oracle
##############################################################################################

$ORACLE

  If GINFO
   Call AFF_VLC(mess(13,125,1),"") From GESECRAN :  # Création user Oracle
  Endif
  Call ECR_TIME(mess(13,125,1)) From DOSSUB : # Création user Oracle

  # recuperation du compte sa....AUTHEN_LOGIN
  # si on trouve rien system par défaut.....
  Call PASSWD("database.software.sqlsystemlogin",AUTHEN_LOGIN,GERRDOS)
  If GERRDOS : Return : Endif

  # Récupération du passwd system
  Call PASSWD("database.software.sqlsystempwd",AUTHEN_PWD,GERRDOS)
  If GERRDOS : Return : Endif
  #recuperation du password pour X3 tiger par example X3_PWD
  # si on trouve rien tiger par defaut......
  Call PASSWD("database.software.sqlfolderpwd",X3_PWD,GERRDOS)
  If GERRDOS : Return : Endif


Case GOS(1)

 When "unix"

  #####################################################################################################
  # usage : $1 [-v] [-p syspas] -d sizdat -i sizidx -r appliref [-o dossier_origine] nomap idapl
  # usage en R091 : $1 [-v] [-u syslogin] [-p syspas][-P x3pas]  -d sizdat -i sizidx -r appliref [-o dossier_origine] nomap idapl
  #####################################################################################################

  ORDSYS(1) = 'adcrap'
  If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        # password a passer
        ORDSYS(1) -= '-u'-num$(AUTHEN_LOGIN)
  Endif
  ORDSYS(1) -= '-p "'-num$(AUTHEN_PWD)+'"'
  If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        # password a passer
        ORDSYS(1) -= '-P'-num$(X3_PWD)
  Endif
  ORDSYS(1) -= '-d'-num$([F:ADS]SIZDAT)-'-i'-num$([F:ADS]SIZIDX)
  ORDSYS(1) -= '-r'-GDOSX3
  ORDSYS(1) -= [F:ADS]DOSSIER-[F:ADS]DOSSIER
  ORDSYS(2) = filpath("TRA",GTRACE,"tra")
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

  ############################################################
  # Windows NT (identifié comme Dos ! )
  # Attention : On utilise les variables ORACLE_SID et ORACLE_BASE
  # qui doivent donc être définies dans la base de registre ...
  ############################################################

 When "dos"

  # Modifier les lignes suivantes :
  INITINCDAT = 100
  INITNXTDAT = 100
  INITINCIDX = 100
  INITNXTIDX = 100

  # suite normale
  CHEMINWRK = adxdir + "\tmp"
  ORDSYS(1) = adxdir+"\ebin\adcrapora.bat"-num$([F:ADS]SIZDAT)-num$([F:ADS]SIZIDX)
  ORDSYS(1) -= [F:ADS]DOSSIER-[F:ADS]DOSSIER
  If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
    ###########################################################################################
    # Usage :
    # -------
    #   adcrapora p1 p2 p3 p4 p5 p6 p7
    #
    #   p1  = Data tablespace size
    #   p2  = Index tablespace size
    #   p3  = Folder name
    #   p4  = Parent Folder (parent folder for archive folder or folder name)
    #   p5  = system login like system
    #   p6  = system password
    #   p7  = Oracle file identifier
    #   p8  = Oracle SID
    #   p9  = working path : adxdir + tmp (ex. d:\x3\adox3\tmp) (%ADXDIR%\tmp)
    #   p10 = password x3 folder like tiger
    # sur oracle login sans les guillements sinon prob sur le connect system/cccc
    # voir pour mot de passe tiger si on met "
    ###########################################################################################
    ORDSYS(1) -= num$(AUTHEN_LOGIN)-'"'+num$(AUTHEN_PWD)+'"'
    ORDSYS(1) -=[F:ADS]DOSSIER-getenv$("ORACLE_SID")-'"'+CHEMINWRK+'"'
    ORDSYS(1) -= num$(X3_PWD)
  Else
    ###########################################################################################
    # Usage :
    # -------
    #   adcrapora p1 p2 p3 p4 p5 p6 p7
    #
    #   p1  = Data tablespace size
    #   p2  = Index tablespace size
    #   p3  = Folder name
    #   p4  = Parent Folder (parent folder for archive folder or folder name)
    #   p5  = system password
    #   p6  = Oracle file identifier
    #   p7  = Oracle SID
    #   p8  = working path : adxdir + tmp (ex. d:\x3\adox3\tmp) (%ADXDIR%\tmp)
    ###########################################################################################
    ORDSYS(1) -= '"'+num$(AUTHEN_PWD)+'"'
    ORDSYS(1) -=[F:ADS]DOSSIER-getenv$("ORACLE_SID")-'"'+CHEMINWRK+'"'
  Endif
  ORDSYS(2) = filpath("TRA",GTRACE,"tra")
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
Endcase
# X3BY pas de user sous NT
Return

##############################################################################################
#---- pour DB2
##############################################################################################

## PC 16/12/99
## Modifications :
## PC 11/05/00 prise en compte de DB2/unix

$DB2

If GINFO
  Call AFF_VLC(mess(59,123,1)-":"-mess(114,124,1),[F:ADS]DOSSIER+"_DAT"-"    &    "-[F:ADS]DOSSIER+"_IDX")
& From GESECRAN : # Création tablespaces
Endif

Call ECR_TRACE("Création des tablespaces",0) From GESECRAN

# on recupere les tailles renseignees par l'utilisateur (en Mo), donnees et index,
# que l'on ramene en page de 4KB

INITINCDAT = int([F:ADS]SIZDAT *1000 / 4)
INITINCIDX = int([F:ADS]SIZIDX *1000 / 4)

Case GOS(1)

 When "unix"

  # preparation de l'ordre systeme pour la creation du dossier
  ORDSYS(1) = "adcrapdb2 -d" -num$(INITINCDAT) - "-x" -num$(INITINCIDX) - [F:ADS]DOSSIER
  ORDSYS(2) = filpath("TRA",GTRACE,"tra")
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

  # adxdb2 est cree dans le adcrapdb2

 When "dos"

  # on defini le chemin ou sera cree le script DB2
  CHEMINWRK  = adxdir + "\tmp"
  CHMCONTDAT = getenv$("DB2_BASE") + "\data"
  CHMCONTIDX = getenv$("DB2_BASE") + "\Index"

  # p1 = Nom de la base de donnee          getenv$("DB2_SID") -- recupere dans l'editeur de registre
  # p2 = Nom du dossier                    [F:ADS] DOSSIER
  # p3 = Chemin conteneur de donnees       CHMCONTDAT
  # p4 = Chemin conteneur des index        CHMCONTIDX
  # p5 = Taille des donnees                INITINCDAT
  # p6 = Taille des index                  INITINCIDX
  # p7 = Chemin du script genere           CHEMINWRK
  # p8 = dossier/application de reference(racine) (obligatoire: toujours renseigné)
  # p9 = dossier origine pour creation dossier histo (facultatif:renseigné uniquement sur creation dos hist)

  # preparation de l'ordre systeme pour la creation du dossier
  ORDSYS(1) = adxdir + "\ebin\adcrapdb2.bat" - getenv$("DB2_SID")
  ORDSYS(1) -= [F:ADS]DOSSIER - CHMCONTDAT - CHMCONTIDX
  ORDSYS(1) -= num$(INITINCDAT) -num$(INITINCIDX) - CHEMINWRK
  ORDSYS(1) -=  GDOSX3
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

  # On execute adxdb2 pour creer le fichier adxdb2 qui va bien ...
  ORDSYS(1) = adxdir + "\bin\adxdb2.exe -u" - [F:ADS]DOSSIER - "-p tiger -d"
  ORDSYS(1) -= getenv$("DB2_SID") - "-t" - [F:ADS]DOSSIER + "_DAT"
  ORDSYS(1) -= "-i" - [F:ADS]DOSSIER + "_IDX" - [F:ADS]DOSSIER
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

Endcase

# Tempo necessaire à l'allocation et au catalogage des tablespaces dans DB2

Sleep(10)

Return

###########################################################################################################
$ERREUR
Call ECR_TRACE(mess(6,123,1)-num$(errn)-errmes$(errn)-errm-errp-mess(61,100,1)-num$(errl),1) From GESECRAN
# Erreur...ligne no...
Resume
###########################################################################################################
Subprog RECH_PROPERTY(PROPERTY,PROPERTY_VALUE,ERR)
Value    Char PROPERTY
Variable Char PROPERTY_VALUE
Variable Integer ERR
#
ERR = 0
Call RECHPROP(PROPERTY,PROPERTY_VALUE,ERR) From INTRUTILA
If ERR <> 0
    # Erreur lors de la recherche de l'élément
    # Vérifier le paramétrage de la solution depuis la console (fichier solution.xml).
    Call ECR_TRACE(mess(228,100,1)-"<"+PROPERTY+">"+"\"+mess(227,100,1),1) From GESECRAN
Endif
End
###########################################################################################################
Subprog PASSWD(PROPERTY,PROPERTY_VALUE,ERR)
Value    Char PROPERTY
Variable Char PROPERTY_VALUE
Variable Integer ERR

Local Char    VPROP(200)
ERR = 0

Call RECHPROP(PROPERTY,VPROP,ERR) From INTRUTILA
# Quand le fichier solution.xml sera mis à jour, on pourra virer les tests
# err 1 = propriété non trouvée
# err= 2 ou 3 : erreur sur fichier solution
#
If PROPERTY = "database.software.sqlinternallogin"
    If ERR = 1
       PROPERTY_VALUE = "sa"
       ERR= 0
    Elsif ERR = 0
       # test du vide quand mme
       If vireblc (VPROP,4) = ""
                 PROPERTY_VALUE = "sa"
       Else
            If pat(VPROP,"CRYPT:*") > 0
                 Call DECRYPTO(VPROP,PROPERTY_VALUE) From GESUSER
            Else
                 PROPERTY_VALUE = VPROP
            Endif
       Endif
    Else
       # Erreur lors de la recherche de l'élément
       # Vérifier le paramétrage de la solution depuis la console (fichier solution.xml).
       Call ECR_TRACE(mess(228,100,1)-"<"+PROPERTY+">"+"\"+mess(227,100,1),1) From GESECRAN
    Endif
Elsif PROPERTY = "database.software.sqlfolderpwd"
    If ERR = 1
        PROPERTY_VALUE = "tiger"
        ERR= 0
    Elsif ERR = 0
      # test du vide quand mme
      If vireblc (VPROP,4) = ""
                  PROPERTY_VALUE = "tiger"
      Else
            If pat(VPROP,"CRYPT:*") > 0
                 Call DECRYPTO(VPROP,PROPERTY_VALUE) From GESUSER
            Else
                 PROPERTY_VALUE = VPROP
            Endif

      Endif
    Else
       # Erreur lors de la recherche de l'élément
       # Vérifier le paramétrage de la solution depuis la console (fichier solution.xml).
       Call ECR_TRACE(mess(228,100,1)-"<"+PROPERTY+">"+"\"+mess(227,100,1),1) From GESECRAN
    Endif
Elsif PROPERTY = "database.software.sqlsystemlogin"
    If ERR = 1
        PROPERTY_VALUE = "system"
        ERR= 0
    Elsif ERR = 0
      # test du vide quand mme
      If vireblc (VPROP,4) = ""
                PROPERTY_VALUE = "system"
      Else
            If pat(VPROP,"CRYPT:*") > 0
                 Call DECRYPTO(VPROP,PROPERTY_VALUE) From GESUSER
            Else
                 PROPERTY_VALUE = VPROP
            Endif
      Endif
    Else
       # Erreur lors de la recherche de l'élément
       # Vérifier le paramétrage de la solution depuis la console (fichier solution.xml).
       Call ECR_TRACE(mess(228,100,1)-"<"+PROPERTY+">"+"\"+mess(227,100,1),1) From GESECRAN
    Endif
Else
   If ERR <>0
       # Erreur lors de la recherche de l'élément
       # Vérifier le paramétrage de la solution depuis la console (fichier solution.xml).
       Call ECR_TRACE(mess(228,100,1)-"<"+PROPERTY+">"+"\"+mess(227,100,1),1) From GESECRAN
   Else
       If pat(VPROP,"CRYPT:*") > 0
                Call DECRYPTO(VPROP,PROPERTY_VALUE) From GESUSER
       Else
                PROPERTY_VALUE = VPROP
       Endif
   Endif
Endif

End


Funprog ISBASE_RESERVED_WORDS(NAME)
Value Char NAME
Gosub DEF_ODBC_RESERVED
Gosub DEF_SQL_RESERVED
Gosub DEF_ORA_RESERVED

If find(NAME,ODBCWORDS(1..ODBCNB))>0
End 1
Elsif find(NAME,SQLWORDS(1..SQLNB))>0
End 1
Elsif find(NAME,ORAWORDS(1..ORANB))>0
End 1
Endif
End 0


$DEF_ODBC_RESERVED
Local Integer ODBCNB
Local Char ODBCWORDS(50) (1..300)

ODBCNB+=1 : ODBCWORDS(ODBCNB)="ABSOLUTE"
#ODBCNB+=1 : ODBCWORDS(ODBCNB)="ACTION"
