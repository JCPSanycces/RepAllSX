#<AdxTL>@(#)1.0.0.0 $Revision$

$ACTION
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "FERME"        : Gosub FERME
  When "FILTRE"       : Gosub FILTRE
  When "SETBOUT"      : Gosub SETBOUT
  When "RAZCRE"       : Gosub RAZCRE
  When "RAZDUP"       : Gosub RAZDUP
  When "LIENS"        : Gosub LIENS
  When "VERIF_MOD"    : Gosub VERIF_MOD
  When "AVANT_MODFIC" : Gosub AVANT_MODFIC
  When "VERF_ANU"     : Gosub VERF_ANU
  When "AV_ANNULE"    : Gosub AV_ANNULE
  When Default
Endcase
Return
###########################################################
$OUVRE
If clalev([F:REO])=0 Local File STOREO     [REO]  Endif
If clalev([F:STA])=0 Local File STOALL     [STA]  Endif      # hcb 58967

Local Integer WI
Return
###########################################################
$FERME
Call IMPSCR        From ATRTX3
Return
###########################################################
$FILTRE
Return
###########################################################
$LIENS
Read [TLO]TLO0=[M:LOC0]STOFCY;[M:LOC1]LOCTYP
If fstat
  Raz [F:TLO]
Endif
#
[M:LOC0]LOCTYPSEL = [M:LOC1]LOCTYP
[M:LOC0]STOEXI = 0
#
Filter [STO] Where STOFCY = [M:LOC0]STOFCY &
&                  LOC    = [M:LOC0]LOC    &
&                  QTYSTU <> 0
&            Order By Key STO3
Effzo [M:LOC2]
Effzo [M:LOC3]
For [STO] Hint Key STO4
  [M:LOC0]STOEXI = 2
  If [M:LOC2]NBLIG < dim([M:LOC2]ITMREF)-1
    Read [ITM]ITM0=[F:STO]ITMREF
    If fstat = 0 
      [M:LOC2]ITMREF([M:LOC2]NBLIG)    = [F:ITM]ITMREF
      #[M:LOC2]ITMDES1([M:LOC2]NBLIG)   = [F:ITM]ITMDES1
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:LOC2]ITMDES1([M:LOC2]NBLIG), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
      [M:LOC2]STU([M:LOC2]NBLIG)       = [F:ITM]STU
      If dim([M:LOC2]LOT) > 0 
        [M:LOC2]LOT([M:LOC2]NBLIG)     = [F:STO]LOT 
      Endif
      [M:LOC2]PCU([M:LOC2]NBLIG)       = [F:STO]PCU
      [M:LOC2]QTYPCU([M:LOC2]NBLIG)    = [F:STO]QTYPCU
      [M:LOC2]QTYSTU([M:LOC2]NBLIG)    = [F:STO]QTYSTU
      [M:LOC2]STA([M:LOC2]NBLIG)       = [F:STO]STA 
      If dim([M:LOC2]PALNUM) > 0 
        [M:LOC2]PALNUM([M:LOC2]NBLIG)  = [F:STO]PALNUM
      Endif 
      If dim([M:LOC2]CTRNUM) > 0 
        [M:LOC2]CTRNUM([M:LOC2]NBLIG)  = [F:STO]CTRNUM
      Endif 
      If dim([M:LOC2]SLO) > 0 
        [M:LOC2]SLO([M:LOC2]NBLIG)     = [F:STO]SLO
      Endif 
      If dim([M:LOC2]SERNUM) > 0 
        [M:LOC2]SERNUM([M:LOC2]NBLIG)  = [F:STO]SERNUM
      Endif 


      [M:LOC2]NBLIG += 1
    Endif
  Else 
    Break
  Endif
Next
#
If [M:LOC1]DEDFLG = 2 | [M:LOC1]REAFLG = 2
  Filter [STF] Where STOFCY = [M:LOC0]STOFCY &
&                    LOC    = [M:LOC0]LOC    
&              Order By Key STF0
  For [STF]
    If [M:LOC3]NBLIG < dim([M:LOC3]ITMREF)-1
      Read[ITM]ITM0=[F:STF]ITMREF
      If fstat = 0
        [M:LOC3]ITMREF    ([M:LOC3]NBLIG) = [F:ITM]ITMREF
        [M:LOC3]STU       ([M:LOC3]NBLIG) = [F:ITM]STU
        [M:LOC3]REOTSD    ([M:LOC3]NBLIG) = [F:STF]REOTSD
        [M:LOC3]MAXSTO    ([M:LOC3]NBLIG) = [F:STF]MAXSTO
        [M:LOC3]PCU       ([M:LOC3]NBLIG) = [F:STF]PCU   
        [M:LOC3]QTYPCU    ([M:LOC3]NBLIG) = [F:STF]QTYPCU
        [M:LOC3]PCUSTUCOE ([M:LOC3]NBLIG) = [F:STF]PCUSTUCOE
        [M:LOC3]NBLIG += 1
      Endif
    Else
      Call ERREUR(mess(217,184,1)) From GESECRAN                  # hcb 280405 29872

      Break
    Endif
  Next
  Filter [STF]
Endif
[M:LOC1]HOU = mess(29,197,1)
Filter [STO]
If !GIMPORT
  Affzo [M:LOC2]
  Affzo [M:LOC3]
  Gosub GRISAGE_LOC
Endif
Return
###########################################################
$GRISAGE_LOC
Diszo [M:LOC0]LOCTYPSEL
If dim([M:LOC0]WRH)>0 Diszo [M:LOC0]WRH Endif
Grizo [M:LOC1]5
Grizo [M:LOC1]15
Case [M:LOC1]LOCCAT
  When 4 :
    Actzo [M:LOC1]20
    GBPRSEL = "BPSFLG=2"
#Les clients ont déjà un lien vers 1 seul emplacement
#  When 3 :
#    Actzo [M:LOC1]20
#    GBPRSEL = "BPCFLG=2"
  When Default :
    Grizo [M:LOC1]20
Endcase
#
#If [M:LOC0]STOEXI = 0
#  Actzo [M:LOC1]MONITMFLG
#  Actzo [M:LOC1]DEDFLG
#  Actzo [M:LOC1]REAFLG
#Endif
#If [M:LOC1]FILMGTFLG = 2
#  Actzo [M:LOC1]OCPCOD
#Else 
#  Grizo [M:LOC1]OCPCOD
#Endif
#
#MAE, bg 75966, pour que l'export Excel fonctionne: remplacement des Grizo par Diszo
#Grizo [M:LOC2]
Diszo [M:LOC2]
#
If [M:LOC1]DEDFLG = 2 | [M:LOC1]REAFLG = 2
  Affzo [M:LOC3]
  Actzo [M:LOC3]
Else
  Effzo [M:LOC3]
  #MAE, bg 75966
  #Grizo [M:LOC3]
  Diszo [M:LOC3]
Endif
If [M:LOC1]FRGMGTMOD<>2
    Diszo [M:LOC1]AVADAT,AVAHOU
Else
    Actzo [M:LOC1]AVADAT,AVAHOU
Endif
Return
###########################################################
$RAZCRE
Diszo [M:LOC0]LOCTYPSEL
If dim([M:LOC0]WRH)>0 Diszo [M:LOC0]WRH Endif
[M:LOC1]HOU = mess(29,197,1)
Return
###########################################################
$RAZDUP
Diszo [M:LOC0]LOCTYPSEL
If dim([M:LOC0]WRH)>0 Diszo [M:LOC0]WRH Endif
[M:LOC1]HOU = mess(29,197,1)
Effzo [M:LOC2]
Effzo [M:LOC3]
Return
###########################################################
$VERIF_MOD
# Vérification des affectations
If [M:LOC3]NBLIG > 0
  For WI = 0 To [M:LOC3]NBLIG-1
    If [M:LOC1]REAFLG <> 2
# modif suite demande Gilles lefevbre 090104
#      If [M:LOC3]REOTSD(WI) = 0
#        GMESSAGE = mess(369,199,1)
#        OK = 0
#        Break
#      Endif
#    Else
      [M:LOC3]REOTSD    (WI) = 0
      [M:LOC3]MAXSTO    (WI) = 0   
      [M:LOC3]PCU       (WI) = ""  
      [M:LOC3]QTYPCU    (WI) = 0   
      [M:LOC3]PCUSTUCOE (WI) = 0   
    Endif
  Next WI
Endif
Return
###########################################################
$AVANT_MODFIC


# Modification affectations / Effacement affectations supprimées
Filter [STF] Where STOFCY = [M:LOC0]STOFCY &
&                  LOC    = [M:LOC0]LOC
&            Order By Key STF0
For [STF]
  Readlock [STF] Curr
  Case fstat
    When 0 :
      WJ = 0
      For WI = 0 To [M:LOC3]NBLIG -1
        If [M:LOC3]ITMREF(WI) = [F:STF]ITMREF
          WJ = 1
          Break
        Endif
      Next WI
      If WI = 0 | ([M:LOC1]DEDFLG = 1 & [M:LOC1]REAFLG = 1)
        Delete [STF]
        If fstat
          GOK = 0
          Call FSTA("STF") From GLOCK
          Break
        Endif
      Else
        If [M:LOC3]REOTSD    (WI) <> [F:STF]REOTSD | 
&          [M:LOC3]MAXSTO    (WI) <> [F:STF]MAXSTO |
&          [M:LOC3]PCU       (WI) <> [F:STF]PCU    |
&          [M:LOC3]QTYPCU    (WI) <> [F:STF]QTYPCU |
&          [M:LOC3]PCUSTUCOE (WI) <> [F:STF]PCUSTUCOE

          [F:STF]REOTSD    = [M:LOC3]REOTSD    (WI)
          [F:STF]MAXSTO    = [M:LOC3]MAXSTO    (WI)
          [F:STF]PCU       = [M:LOC3]PCU       (WI)
          [F:STF]QTYPCU    = [M:LOC3]QTYPCU    (WI)
          [F:STF]PCUSTUCOE = [M:LOC3]PCUSTUCOE (WI)
          [F:STF]EXPNUM    = [C]EXPORT
          [F:STF]UPDUSR    = GUSER
          [F:STF]UPDDAT    = date$
          Rewrite [STF]
          If fstat
            GOK = 0
            Call FSTA("STF") From GLOCK
            Break
          Endif
        Endif
       Endif
    When 1 :
      GOK = -1
      Break
    When Default :
      GOK = 0
      Call FSTA("STF") From GLOCK
      Break
  Endcase
Next 
Filter [STF]
If GOK = 1
  If [M:LOC1]DEDFLG = 2 | [M:LOC1]REAFLG = 2 & [M:LOC3]NBLIG > 0
    For nolign = 1 To [M:LOC3]NBLIG
      Read [STF]STF0=[M:LOC0]STOFCY;[M:LOC0]LOC;[M:LOC3]ITMREF(nolign-1)
      Case fstat
        When 0 :
        When 4, 5 : 
          Raz [F:STF]
          [F:STF] = [M:LOC3]
          [F:STF]STOFCY = [M:LOC0]STOFCY
          [F:STF]LOC    = [M:LOC0]LOC 
          [F:STF]CREUSR = GUSER
          [F:STF]CREDAT = date$
          Write [STF]
          If fstat
            GOK = 0
            Call FSTA("STF") From GLOCK
            Break
          Endif  
      Endcase  
    Next nolign
  Endif
Endif
Filter [STF] Where STOFCY = [M:LOC0]STOFCY
&                & LOC    = [M:LOC0]LOC
&            Order By Key STF0
For [STF]
    If !find([F:STF]ITMREF,[M:LOC3]ITMREF(0..[M:LOC3]NBLIG-1))
        Delete [STF] Curr
    Endif 
Next
Filter [STF]

Filter [REO] Where STOFCY = [M:LOC0]STOFCY
&                & LOC    = [M:LOC0]LOC
&            Order By Key REO0
For [REO]
    If !find([F:REO]ITMREF,[M:LOC3]ITMREF(0..[M:LOC3]NBLIG-1))
        Filter [STA] Where STOFCY = [F:REO]STOFCY                        
&                        & ITMREF = [F:REO]ITMREF
&                        & SRGNUM = [F:REO]VCRNUM
&                        & SRGLIN = [F:REO]VCRLIN
&                        & VCRTYP = 34
&                        & ALLTYP = 2
&       Order By Key STA0
        For [STA]
            Delete [STA] Curr
        Next
        Filter [STA]                                                     
#                                                                   # hcb 59967 fin
        Delete [REO] Curr
    Endif 
Next
Filter [REO]



#----- Calcul du nb d'emplacement bloqués -----#
Readlock [TLO]TLO0=[M:LOC0]STOFCY;[M:LOC1]LOCTYP
If [F:STC]LOKSTA<>[M:LOC1]LOKSTA
    If [M:LOC1]LOKSTA=2
        [F:TLO]LOKLOC += 1
    Else
        [F:TLO]LOKLOC -= 1
    Endif
Endif
Rewrite [TLO]
Return
###########################################################
$VERF_ANU
    If [M:LOC0]STOEXI <> 0
  GMESSAGE = mess(8,196,1) 
  OK = 0
Endif
Return
###########################################################
$AV_ANNULE
Delete [STF] Where STOFCY = [M:LOC0]STOFCY &
&                  LOC    = [M:LOC0]LOC    
Case fstat
  When 1 : GOK = -1
Endcase
Return
###########################################################
$SETBOUT
Call VIREBOUT(CHAINE,"CDHS") From GOBJET
Return
