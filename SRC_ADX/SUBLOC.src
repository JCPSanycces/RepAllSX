############################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer WI
#
Read [ITM]ITM0=VALEUR
If fstat 
  mkstat = 2
  GMESSAGE = mess(212,199,1)
Else
  If [F:ITM]STOMGTCOD = 1
     mkstat = 2
     GMESSAGE = mess(147,199,1)
  Else 
     Read [ITF]ITF0=VALEUR;[M:LOC0]STOFCY
     If fstat
        mkstat = 2
        GMESSAGE = mess(2,196,1)
     Else 
        If [F:ITF]STOMGTCOD = 1
           mkstat = 2
           GMESSAGE = mess(147,199,1)
        Else
           If [F:ITF]LOCMGTCOD <> 2
              mkstat = 2
              GMESSAGE = mess(149,199,1)
           Endif
        Endif
     Endif 
  Endif
Endif
# Contrôle unicité
For WI = 0 To [M:LOC3]NBLIG -1
  If WI <> nolign -1
    If [M:LOC3]ITMREF(WI) = VALEUR
      mkstat = 2
      GMESSAGE = mess(176,193,1)-num$(WI+1)
      Break
    Endif
  Endif
Next WI
#
If !mkstat
  [M:LOC3]STU(nolign-1) = [F:ITM]STU
  Affzo [M:LOC3]STU(nolign-1)
  If [M:LOC3]PCU(nolign-1) = ""
     [M:LOC3]PCU(nolign-1) = [F:ITM]STU
     Affzo [M:LOC3]PCU(nolign-1)
  Endif
  If [M:LOC3]QTYPCU(nolign-1) = 0
     [M:LOC3]QTYPCU(nolign-1) = 1
     Affzo [M:LOC3]QTYPCU(nolign-1)
  Endif
  If [M:LOC3]PCUSTUCOE(nolign-1) = 0
     [M:LOC3]PCUSTUCOE(nolign-1) = 1
     Affzo [M:LOC3]PCUSTUCOE(nolign-1)
  Endif
Endif
End
###########################################################
Subprog AS_REOTSD(VALEUR)
Variable Decimal VALEUR
If [M:LOC1]REAFLG <> 2
  VALEUR = 0
  mkstat = 2
Endif
End
###########################################################
Subprog AS_MAXSTO(VALEUR)
Variable Decimal VALEUR
If [M:LOC1]REAFLG <> 2
  VALEUR = 0
  mkstat = 2
Endif
End
###########################################################
Subprog C_MAXSTO(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 & VALEUR < [M:LOC3]REOTSD(nolign-1)
  mkstat = 2
Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 27/11/2003 11:30:27 (HCB)
##########################################################################
Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()
Local Char    LUSCAV(5)
Local Integer LMODIF
Local Char    PLBEFMT(GLONARP)
Local Decimal LCOEF

If VALEUR = ""
   [M:LOC3]QTYPCU          (nolign-1) = 0
   [M:LOC3]PCUSTUCOE       (nolign-1) = 0
   Affzo [M:LOC3]QTYPCU    (nolign-1)
   Affzo [M:LOC3]PCUSTUCOE (nolign-1)
   End
Endif   


Call CTLUOM ([M:LOC3]ITMREF(nolign-1),3,"", VALEUR, LCOEF, LUSCAV, PLBEFMT, LMODIF) From STKACT

If LUSCAV <> "S" 
   If LUSCAV <> "C"
      mkstat = 2 
      End
   Endif
Endif

[M:LOC3]PCUSTUCOE(nolign-1) =  LCOEF
Affzo [M:LOC3]PCUSTUCOE(nolign-1)
End

Subprog C_QTYPCU(VALEUR)
Variable Decimal VALEUR
Local Decimal LQTYSTU

If VALEUR = 0 & [M:LOC3]PCU (nolign-1) <> ""
  mkstat = 2
Endif

LQTYSTU = VALEUR * [M:LOC3]PCUSTUCOE(nolign-1)
# si le seuil et la quantite maxi sont à zero  alors pas de test sur la quantite economique
If [M:LOC3]MAXSTO(nolign-1) = 0 & [M:LOC3]REOTSD(nolign-1) = 0
   End
Else
   If LQTYSTU >  [M:LOC3]MAXSTO(nolign-1)
      mkstat = 2
      GMESSAGE = mess(73,184,1)    # Quantite superieure à la quantite maximum
      End
   Endif
Endif


End

Subprog AS_PCU(VALEUR)
Variable Char    VALEUR()
If [M:LOC1]REAFLG <> 2
  VALEUR = ""
  mkstat = 2
Endif

End

Subprog AS_QTYPCU(VALEUR)
Variable Decimal VALEUR
If [M:LOC1]REAFLG <> 2
  VALEUR = 0
  mkstat = 2
Endif
If [M:LOC3]PCU (nolign-1) = ""
   mkstat = 2
Endif 

End


##########################################################################
## Etiquette ajoutée par le superviseur 15/12/2003 16:18:14 (CCC)
##########################################################################
Subprog C_AUZSST(VALEUR)
Variable Char    VALEUR()
Local Shortint WRET
Columns [STO] (STA)
Filter [STO] Where STOFCY = [M:LOC0]STOFCY &
&                  LOC    = [M:LOC0]LOC    &
&                  QTYSTU <> 0
&            Order By Key STO4
Raz WRET
For [STO]
    Call STKCTRSTA([F:STO]STA, VALEUR, 0, 0,0, WRET) From STKACT
    If WRET
        mkstat=2
        GMESSAGE=mess(75,184,1)-[F:STO]STA
        Break
    Endif
Next
Filter [STO]
Columns [STO]
End

Subprog IB_LOC
GBOUT3 = mess(567,197,1)     # Type emplacement
If [M:LOC0]LOCTYPSEL = ""
   GBOUT3 = ""
Endif

End

Subprog B3_LOC(VALEUR)
Variable Char    VALEUR()

GCONSULT = 2
Call OBJET("TLO",[M:LOC0]LOCTYPSEL,[M:LOC0]STOFCY) From GOBJET   
GCONSULT = 0

End


######################################################################################

