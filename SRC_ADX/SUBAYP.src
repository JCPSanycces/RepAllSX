#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion objet AYP
Raz GPILOBJ
Call OBJET("AYP",GBIDC1,GBIDC2) From GOBJET
End

##########################################################################
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "SETBOUT"   : Gosub SETBOUT
 When "RAZCRE"    : Gosub RAZCRE
 When "LIENS2"    : Gosub LIENS2
 When "INICRE"    : Gosub INICRE
 When "MODIF"     : Gosub MODIF
 When "AP_ANNULE" : Gosub AP_ANNULE
 When "FERME"     : Gosub FERME
Endcase
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

$OUVRE
Local Char PARSTY(GLONASY) , RETOUR(20)
Return

$RAZCRE
nolign = 0
For [ASY]
 nolign += 1
 [M] = [F:ASY]
Next ASY
[M]NBLIG = nolign
PARSTY = "DEFAULT"
Gosub AFFICHE
Affzo
Return
 
$LIENS2
nolign = 0
For [ASY]
 nolign += 1
 [M] = [F:ASY]
 Read [AYP]AYP1 = [M]CAT;[F:ASY]COD
 If !fstat
  [M]STY(nolign-1) = [F:AYP]STY
 Endif
Next ASY
[M]NBLIG = nolign
PARSTY = [M]CAT
Gosub AFFICHE
Return

$AFFICHE
Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings", "ADXStyleFile="+chr$(1)+"STX_"+PARSTY
Sorta [M]NBLIG [M]NBLIG Order By [M]LIG(indice)
Chgstl [M]ADES With ""
For I=0 To [M]NBLIG-1
 Read [ASY]ASY0 = [M]COD(I)
 If !fstat
  [M]DES(I) = [F:ASY]DES
  Call TEXTE([M]DES(I),[M]ADES(I)) From OBJDIV
  Chgstl [M]ADES(I) With [M]COD(I)
  Affzo ADES(I)
 Endif
Next I
Return

$INICRE
[F:ASY]LIG = nolign
Return

$MODIF
Call GENSTYLE(nomap,[M]CAT) From SUBASY
PARSTY = [M]CAT
Gosub AFFICHE
Return

$AP_ANNULE
Call ANUSTYLE(APPLI,[L]CODE) From SUBASY
Return

$FERME
## On restaure les styles de l'utilisateur
Call PARAMUTIL("STYLE",PARSTY,"","") From SUBAUS
If PARSTY<>""
 Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings", "ADXStyleFile="+chr$(1)+"STX_"+PARSTY
Else
 Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings", "ADXStyleFile="+chr$(1)+"STX_DEFAULT"
Endif
Return

#########################################################
$TRTCOP
If [M]DOSORG=nomap 
 Local File ASTYLEP [AYP1] 
Else 
 Local File =[M]DOSORG+".ASTYLEP" [AYP1]
Endif 
If [M]DOSDES=nomap 
 Local File ASTYLEP [AYP2] 
 Local File ASTYLE  [ASY2] 
Else 
 Local File =[M]DOSDES+".ASTYLEP" [AYP2]
 Local File =[M]DOSDES+".ASTYLE"  [ASY2]
Endif 
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AYP1], [AYP2], [ASY2]
Call GENSTYLE([M]DOSDES,TABLE) From SUBASY
Return

$TR_COP
GOK = 1
Trbegin [AYP2]
 Delete [AYP2] Where CAT=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASTYLEP" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYP2","") From GLOCK : Goto AB_TR_COP
 Endif
 Local Char ZINTIT(GLONDES)
 For [AYP1]AYP0 Where CAT=TABLE
  If ZINTIT=""
   ZINTIT = [F:AYP1]INTIT
  Endif
  Read [ASY2]ASY0 = [F:AYP1]COD
  If !fstat
   [F:AYP2] = [F:AYP1]
   [F:AYP2]LIG = [F:ASY2]LIG
   If dim([F:AYP2]UPDUSR)>0 : [F:AYP2]UPDUSR = GUSER : Endif
   If dim([F:AYP2]UPDDAT)>0 : [F:AYP2]UPDDAT = date$ : Endif
   If dim([F:AYP2]UPDTIM)>0 : [F:AYP2]UPDTIM = time : Endif
   Write [AYP2]
   If fstat
    GOK=0 : Call FSTA("AYP2") From GLOCK : Break
   Endif
  Endif
 Next AYP1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ASY2]ASY0
  Look [AYP2]AYP1 = TABLE;[F:ASY2]COD
  If fstat
   [F:AYP2] = [F:ASY2]
   [F:AYP2]CAT   = TABLE
   [F:AYP2]INTIT = ZINTIT
   Write [AYP2]
   If fstat
    GOK=0 : Call FSTA("AYP2") From GLOCK : Break
   Endif
  Endif
 Next ASY2
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

