#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################################################
## Xtend: Gestion archives du design Xtend
######################################################################################
##  Gestion Ecran
#    AYTFCYTAR
#
##  Actions
#    AYTFCYTAR    Compression/Décompression du design Xtend; Suppression Tar
#        Param(1)      Dossier 
#        Param(2)      Site Xtend 
#
##  Gosub
#
##  Subprog
######################################################################################
$ACTION
  #Infbox "Action:"-ACTION
  #
  If dim([L]PTRTB)<=0        # Perso par produit
    Local Integer PTRTB
    Call EXISTE_ADX("","","AYTFCYDELB",PTRTB) From ORDSYS
  Endif
  #
  Case ACTION
    When "INIT"     : Gosub FCYTAR_INI
    When "INIT_DIA" : Gosub FCYTAR_DIA
    When "EXEC"     : Gosub FCYTAR_EXEC
  Endcase
  If PTRTB: Gosub ACTION From AYTFCYDELB : Endif           # Perso par produit
Return

$FCYTAR_INI
#-----------------------------
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Local Char FCYORG(GLONAYS), DOSORG(GDIMFIC)
Local Char WSTR1(200)
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)
Local Integer WI, RET 

[L]DOSORG=PARAM(1) 
[L]FCYORG=PARAM(2) 
Return

$FCYTAR_DIA
#-----------------------------
[M:DIA]DOSORG=DOSORG
[M:DIA]FCYORG=FCYORG
[M:DIA]TARNAM=FCYORG+".tar"
Return

$FCYTAR_EXEC
#-----------------------------
WMSG="-"-mess(1,7900,1)-[M]FCYORG-"("-[M:DIA]DOSORG-")"
Case [M]ARCHACT
When 3
    WMSG=mess(161,7900,1)-[M]TARNAM
When 2
    WMSG=mess(34,7900,1)-[M]TARNAM-WMSG
When 1
    WMSG=mess(30,7900,1)-[M]TARNAM-WMSG
Endcase
If !GSERVEUR
    TRA=1
    Call TEMPON(WMSG) From GESECRAN 
    Call OUVRE_TRACE(WMSG) From LECFIC
Endif
#
Call FCYGESTAR([M:DIA]DOSORG, [M:DIA]FCYORG, [M:DIA]TARNAM, ARCHACT, RET) 
If RET=0 : FIN=1 : Goto FCYTAR_FIN: Endif

$FCYTAR_FIN
If !GSERVEUR
 Call TEMPOFF() From GESECRAN 
Endif
Return

######################################################################################
###     Utilitaires générations subprog et funprog 
######################################################################################
# Gestiohn archive Xtend
# $$$$
#------------------------------------------------------------#
Subprog  FCYGESTAR(DOSORG, FCYORG, TARNAM, ARCHACT, RET)       
Value Char DOSORG              # sodaix01:5000@XTEND
Value Char FCYORG              # Site Xtend
Value Char TARNAM              # Nom du tar
Value Integer ARCHACT          # Action sur archives (Menu 7923) 1:Compression, 2:Décop, 3:Sup
Variable Integer RET : RET=1   # 1: Ok
#
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        #  sodaix01:5000 ; XTEND
Local Char WMSG(250), WTARNAM(50)
Local Char WFILTARFULL(250)
Local Integer WI, STAT
#
#
Case [L]ARCHACT
When 3    # Sup tar
    Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS
    Call DIRFCYSUPTAR(MACORG, DOSNAMORG, FCYORG, TARNAM, RET) From AYTGESFILE

When 2    # Detar
    Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS
    Call DIRFCYDETAR(MACORG,DOSNAMORG,FCYORG,TARNAM,RET) From AYTGESFILE

When 1    # Tar
    Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS
    Call DIRFCYTAR(MACORG,DOSNAMORG,FCYORG,TARNAM,RET) From AYTGESFILE

Endcase
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran AYTFCYTAR) 19/07/2007 10:26:07 (JPJ)
######################################################################################
Subprog C_TARNAM(VALEUR)
Variable Char    VALEUR()
Local Char FILEPATH(250), WTARNAM(20)
Local Integer WI
#
WTARNAM=VALEUR
Call TARNAMFMT(WTARNAM,VALEUR) From AYTGESFILE  # mise en forme

#
FILEPATH= func AYTGESFILE.GETPATH("",nomap,"FILTAR","",[M]FCYORG,VALEUR)
Call EXISTE(FILEPATH, WI) From ORDSYS
Case [M]ARCHACT
When 2,3
    If WI<>1     # pas un fichier
        GERR=2 : GMESSAGE=mess(35,7900,1)-VALEUR        # GERR=3: avertissement GERR=2: message
    Endif
When 1
    If WI<>0
        GERR=3 : GMESSAGE=mess(156,7900,1)                  # GERR=3: avertissement GERR=2: message
    Endif
Endcase
End

Subprog S_TARNAM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 Local Char RACINE(200),WVAL(250)
 Local Char LANDEF(GLONLAN)
 Local Integer WI
 
 RACINE= func AYTGESFILE.GETPATH("",nomap,"DIRTAR","",[M]FCYORG,"")+
&        func AYTGESFILE.GETPATH("",nomap,"DIRSEP","","","")
 WVAL=RACINE+VALEUR
 ## Action SELFICREP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 Call SAISIE_CHAR(WVAL,PARMSK,"DFICREP","SELFICREP","XWDFICREP") From GSAISIE
 WI=instr(0,WVAL,RACINE)
 If WI
    VALEUR=right$(WVAL,len(RACINE)+1)
 Else
    mkstat=2
    GERR=1 : GMESSAGE=mess(159,7900,1)-WVAL
 Endif 
 WI=instr(0,VALEUR,".tar")
 If !WI
    mkstat=2
    GERR=1 : GMESSAGE=mess(160,7900,1)-VALEUR
 Endif 
Endif
End


Subprog AM_ARCHACT(VALEUR)
Variable Integer VALEUR
If VALEUR=3    # Suppression
    Grizo [DIA]DOSORG,FCYORG
    [M]TARNAM=""
Else
    Actzo [DIA]DOSORG,FCYORG
    [M]TARNAM=FCYORG+".tar"
Endif
End


Subprog AM_FCYORG(VALEUR)
Variable Char    VALEUR()
Call TARNAMFMT(VALEUR,[M]TARNAM) From AYTGESFILE  # mise en forme
End

