#<AdxTL>@(#)11.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Copie des paramètres législations dans niveau dossier sur un dossier mono-lég
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update file ADOVAL legislation") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub LEG
End

#-------------------#
$LEG

If DOSSIER=GDOSX3
 Return
#117111
#Elsif func AFNC.ACTIVDOS(DOSSIER,"LEG")=2
Elsif func AFNC.ACTIVDOS(DOSSIER,"LEG")
 Call ECR_TRACE("folder"-DOSSIER-"in multi-legislation",0) From GESECRAN
 Return
Else
 Local Char    TBLEG(GLONADI)(1..dim(GDOSLEG))
 Local Integer NBLEG
 Call SETLEG(DOSSIER,TBLEG,NBLEG) From DOSCONT
 If NBLEG>1
  Call ECR_TRACE("folder"-DOSSIER-"in multi-legislation ("+num$(NBLEG)+")",0) From GESECRAN
  Return
 Endif
Endif

Local File =DOSSIER+".ADOVAL" [DADW] 
Local File =DOSSIER+".ADOVAL" [DAW2]  

Trbegin [DADW]  
 For [DADW] Where CMP="*"
  Call ECR_TRACE([F:DADW]PARAM-": Legislation value"-[F:DADW]VALEUR-"-> folder value",0) From GESECRAN
  Read [DAW2]ADW0="";"";[F:DADW]PARAM
  If !fstat
   [F:DAW2] = [F:DADW]
   [F:DAW2]CMP = ""
   [F:DAW2]FCY = ""
   Rewrite [DAW2]
   If fstat : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,2) From DOSDIC : Endif
  Else
   [F:DAW2] = [F:DADW]
   [F:DAW2]CMP = ""
   [F:DAW2]FCY = ""
   Write [DAW2]
   If fstat : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,1) From DOSDIC : Endif
  Endif
  Call ECR_TRACE("Legislation value parameter"-[F:DADW]PARAM-"deleted",0) From GESECRAN
  Delete [DAW2] Where CMP="*" & PARAM=[F:DADW]PARAM
  If fstat=1 : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,3) From DOSDIC : Endif
 Next DADW
Commit

Close Local File

Return
