###################################################################################################
# Class PJMTSKOPE   (Task - Operations)
###################################################################################################
# METHODS
###################################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  SLEVEL = func AFNC.MES3(mess(945,2260,1), this.OPPNUM, this.TASCOD, num$(this.OPENUM))  # + "/" + num$(this.OPESPLNUM) this part of the PK is still =1 not visible to the end user
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

###################################################################################################
$GET_RESOURCE_RATE
#Value Char COD ()
#Value Date DAT
#Value Char UOM ()
#Value Char CUR ()
#Value Char FCY ()
#Value Char WST ()
#Variable Decimal RATE
#Local Integer ARET_VALUE

Local Char SFCY(GLONFCY)
Local Char SCPY(GLONCPY)
Local Char SDIMUOM(GLONUOM)
Local Char SUOM(GLONUOM)
Local Char SCURORI(GLONCUR)  #Work center cur
Local Decimal DRATE
Local Integer ISTAT

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  Local File WORKSTATIO [MWS]
  Local File WORKCOST [MWC]
  # -----------------------------
  DRATE = 0
  # -------------------------------------------
  For SFCY = FCY, ""
    Read [F:MWS]WST0=WST;SFCY
    # -------------------------------------------
    If !fstat Then
      Read [F:MWC]WCT0 = [F:MWS]VLTCCE; [F:MWS]WCRFCY
      If !fstat Then
        # -------------------------------------------
        If [F:MWC]STDSETCST > 0 or [F:MWC]STDOPECST > 0 Then
          DRATE = [F:MWC]STDSETCST + [F:MWC]STDOPECST
          RATE = DRATE
          IOPECST = DRATE
          # -----------------------------
          If RATE = 0 Then
            Read [F:MWC]WCT0 = [F:MWS]VLTCCE; [F:MWS]WCRFCY
            # -------------------------------------------
            If !fstat and ([F:MWC]STDSETCST > 0 or [F:MWC]STDOPECST > 0) Then
              RATE = [F:MWC]STDSETCST + [F:MWC]STDOPECST
              IOPECST = [F:MWC]STDSETCST + [F:MWC]STDOPECST
            Endif
          Endif
          # -----------------------------
          # Hour unit given by a folder parameter
          If [F:MWC]CSTTYP <> 1 Then
            SDIMUOM = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "HOURLYUNIT")
          Endif
          # Unit of measure check
          If UOM <> AVOID.ACHAR Then
            If SDIMUOM <> UOM Then
              Call CONVERT_QTY(this.ACTX, SDIMUOM, UOM, DRATE) From TRTX3_SYRA
            Endif
          Endif
          # Get origional currency before convert
          SCPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR([F:MWS]WCRFCY, "LEGCPY")
          SCURORI = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(SCPY, "ACCCUR")
          If this.CUR <> AVOID.ACHAR and this.CUR <> SCURORI Then
            Call CONVERT(this.ACTX, SCURORI, CUR, CUR, this.TCHCHGTYP, DAT, DRATE, DRATE, ISTAT) From TRTDEV_SYRA
          Endif
          If ISTAT <> 0 Then
            [L]ARET_VALUE = fmet this.SETERROR("", mess(236,2260,1), [V]CST_AERROR)
          Endif
        Endif
        # -------------------------------------------
        If ISTAT = 0 Then
          RATE = DRATE
        Endif
      Endif
      Break
    Endif
  Next SFCY
  If DRATE = 0
    # Apply Price from cost type only when the valuation based on costing dimensions (DRATE) returns 0.
    Call GETRATE_FROMDATE(COD, DAT, SUOM, SCURORI, DRATE) From PJMCOSTCTR_CSTD_PROGS
    If SUOM <> AVOID.ACHAR Then
      If UOM <> SUOM Then
          Call CONVERT_QTY(this.ACTX, SUOM, UOM, DRATE) From TRTX3_SYRA
      Endif
      ISTAT = 0
      If this.CUR <> SCURORI Then
        Call CONVERT(this.ACTX, SCURORI, CUR, CUR, this.TCHCHGTYP, DAT, DRATE, DRATE, ISTAT) From TRTDEV_SYRA
        If ISTAT <> 0 Then
          [L]ARET_VALUE = fmet this.SETERROR("", mess(236,2260,1), [V]CST_AERROR)
        Endif
      Endif
      # -----------------------------
      If ISTAT = 0 Then
        RATE = DRATE
      Endif
    Else
      RATE = 0
    Endif
  Endif
Return

###################################################################################################
$GET_RES_RATE_DIM
#Value Date DAT
#Value Char UOM ()
#Value Char CUR ()
#Value Char FCY ()
#Value Char WST ()
#Variable Decimal RATE
#Local Integer ARET_VALUE

Local Char SFCY(GLONFCY)
Local Char SCPY(GLONCPY)
Local Char SDIMUOM(GLONUOM)
Local Char SCURORI(GLONCUR)  #Work center cur
Local Decimal DRATE
Local Integer ISTAT

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  Local File WORKSTATIO [MWS]
  Local File WORKCOST [MWC]
  # -----------------------------
  DRATE = 0
  # -------------------------------------------
  For SFCY = FCY, ""
    Read [F:MWS]WST0=WST;SFCY
    # -------------------------------------------
    If !fstat Then
      Read [F:MWC]WCT0=[F:MWS]VLTCCE;[F:MWS]WCRFCY
      If !fstat Then
        # -------------------------------------------
        If [F:MWC]STDSETCST > 0 or [F:MWC]STDOPECST > 0 Then
          DRATE = [F:MWC]STDSETCST + [F:MWC]STDOPECST
          RATE = DRATE
          IOPECST = DRATE
          # -----------------------------
          If RATE = 0
            Read [F:MWC]WCT0=[F:MWS]VLTCCE;[F:MWS]WCRFCY
            # -------------------------------------------
            If !fstat and ([F:MWC]STDSETCST > 0 or [F:MWC]STDOPECST > 0) Then
              RATE = [F:MWC]STDSETCST + [F:MWC]STDOPECST
              IOPECST = [F:MWC]STDSETCST + [F:MWC]STDOPECST
            Endif
          Endif
          # -----------------------------
          # Hour unit given by a folder parameter
          If [F:MWC]CSTTYP <> 1 Then
            SDIMUOM = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "HOURLYUNIT")
          Endif
          # Unit of measure check
          #If UOM <> AVOID.ACHAR Then                                # Issue X3-52568 - 2017-08-11 by FGR
          If UOM <> AVOID.ACHAR and SDIMUOM <> AVOID.ACHAR Then      # Issue X3-52568 - 2017-08-11 by FGR
            If SDIMUOM <> UOM Then
              Call CONVERT_QTY(this.ACTX, UOM, SDIMUOM, DRATE) From TRTX3_SYRA
            Endif
          Endif
          # Get origional currency before convert
          SCPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR([F:MWS]WCRFCY, "LEGCPY")
          SCURORI = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(SCPY, "ACCCUR")
          If CUR <> AVOID.ACHAR and CUR <> SCURORI Then
            Call CONVERT(this.ACTX, SCURORI, CUR, CUR, this.TCHCHGTYP, DAT, DRATE, DRATE, ISTAT) From TRTDEV_SYRA
          Endif
          If ISTAT <> 0 Then
            [L]ARET_VALUE = fmet this.SETERROR("", mess(236,2260,1), [V]CST_AERROR)
          Endif
        Endif
        # -------------------------------------------
        If ISTAT = 0 Then
          RATE = DRATE
        Endif
      Endif
      Break
    Endif
  Next SFCY
Return

###################################################################################################
$GET_RES_RATE_CSTYP
#Value Char COD ()
#Value Date DAT
#Value Char UOM ()
#Value Char CUR ()
#Variable Decimal RATE
#Local Integer ARET_VALUE

Local Char SUOM(GLONUOM)
Local Char SCURORI(GLONCUR)  #Work center cur
Local Decimal DRATE
Local Integer ISTAT

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  RATE = 0
  DRATE = 0
  If COD <> AVOID.ACHAR Then
    Call GETRATE_FROMDATE(COD, DAT, SUOM, SCURORI, DRATE) From PJMCOSTCTR_CSTD_PROGS
    If SUOM <> AVOID.ACHAR Then
      If UOM <> SUOM Then
        Call CONVERT_QTY(this.ACTX, UOM, SUOM, DRATE) From TRTX3_SYRA
      Endif
      ISTAT = 0
      If CUR <> SCURORI Then
        Call CONVERT(this.ACTX, SCURORI, CUR, CUR, this.TCHCHGTYP, DAT, DRATE, DRATE, ISTAT) From TRTDEV_SYRA
        If ISTAT <> 0 Then
          [L]ARET_VALUE = fmet this.SETERROR("", mess(236,2260,1), [V]CST_AERROR)
        Endif
      Endif
      If ISTAT = 0 Then
        RATE = DRATE
      Endif
    Else
      RATE = 0
    Endif
  Endif
Return

###################################################################################################
$GET_OPEUOM
#Variable Char SOPEUOM
#Value Integer ARET_VALUE

  If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.snapshot.CSMQTY = 0) Then
    [L]ARET_VALUE = fmet this.GET_OPEUOM_RES1(SOPEUOM)
  Elsif this.TASCOD <> AVOID.ACHAR Then
    [L]ARET_VALUE = fmet this.GET_OPEUOM_TASK(SOPEUOM)
  Endif
Return

###################################################################################################
$GET_OPEUOM_RES1
#Variable Char SOPEUOM
#Value Integer ARET_VALUE

Local Char SFCY(GLONFCY)

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------------
  Local File WORKSTATIO [MWS]
  Local File PJMCOSTCTR [PCC]
  # -------------------------
  For SFCY = this.TASFCY, ""
    Read [F:MWS]WST0=this.EXTWST;SFCY
    # -----------------------------
    If !fstat Then
      If [F:MWS]PCCCOD <> AVOID.ACHAR Then
        Read [PCC]PCC0 = [F:MWS]PCCCOD
        SOPEUOM = [F:PCC]PCCU
      Endif
      Break
    Endif
  Next SFCY
Return

###################################################################################################
$GET_OPEUOM_TASK
#Variable Char SOPEUOM
#Value Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  Local File PJMTSKCAT [CTA]
  Local File PJMCOSTCTR [PCC]
  # -----------------------------
  Read [F:CTA]CTA0=this.TCHTCACOD
  # -----------------------------
  If [F:CTA]PCCCOD <> AVOID.ACHAR Then
    Read [PCC]PCC0 = [F:CTA]PCCCOD
    SOPEUOM = [F:PCC]PCCU
  Else
    [L]ARET_VALUE = fmet this.GET_OPEUOM_DEFAULT(SOPEUOM)
  Endif
  # -----------------------------
Return

###################################################################################################
$GET_OPEUOM_DEFAULT
#Variable Char SOPEUOM
#Value Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  SOPEUOM = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, this.ACTX.AFOLDER, "HOURLYUNIT")
Return

###################################################################################################
$GET_STDOPENUM_DES
  [L]ARET_VALUE = [V]CST_AOK
  Call LECTEXTRA(this, AVOID.ACHAR, this.ROODESAXX, "ROUOPESTD", "STDOPEDESAXX", num$(this.STDOPENUM), this.TASFCY) From ASYRFNC
Return

###################################################################################################
$RAFFT_INIT_TECH_PROP
#Value Integer LIN

  [L]ARET_VALUE = [V]CST_AOK
  this.RAFFT(LIN).TASFCY = this.TASFCY
  this.RAFFT(LIN).TCHOPESTA = this.OPESTA        # Issue X3-17075/120484 - 2016-12-19 by FGR
  this.RAFFT(LIN).TCHCHGTYP = this.TCHCHGTYP     # Issue X3-17556/120812 - 2017-01-10 by FGR
  this.RAFFT(LIN).TCHOPECST = this.OPECST        # Issue X3-28427/122128 - 2017-03-21 by FGR
  this.RAFFT(LIN).TCHOPECST2 = this.OPECST2      # Issue X3-28427/122128 - 2017-03-21 by FGR
Return

###################################################################################################
$RAFFT_COUNT
Local Integer NI

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.RAFFT)
    If this.RAFFT(NI) <> null and find(this.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE += 1
    Endif
  Next NI
Return

###################################################################################################
# Issue X3-29639/122209 - 2017-03-24 by FGR : BEGIN
$RAFFT_GET_INDEX
#Value Char USR ()
#Local Integer ARET_VALUE

Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = 0
  NI = find(USR,this.RAFFT(1..maxtab(this.RAFFT)).POACLB)
  While NI > 0
    If this.RAFFT(NI) <> null and find(this.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = NI
      Break
    Else
      NI1 = NI
      NI = find(USR,this.RAFFT(NI+1..maxtab(this.RAFFT)).POACLB)
      If NI > 0 Then
        NI += NI1
      Endif
    Endif
  Wend
Return

