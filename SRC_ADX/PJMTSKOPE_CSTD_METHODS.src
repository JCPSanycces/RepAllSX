###################################################################################################
$RAFFT_REPEAT_OPESTR
#Local Integer ARET_VALUE
Local Integer NI

  [L]ARET_VALUE = [V]CST_AOK
  If (this.ASTALIN = [V]CST_AUPD and this.OPESTR <> this.snapshot.OPESTR) Then
    Case this.TCHOPESTRAN
      When 1
        # Yes
        For NI = 1 To maxtab(this.RAFFT)
          If this.RAFFT(NI) <> null and find(this.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            this.RAFFT(NI).POASTR = this.OPESTR
          Endif
        Next NI
      When 2
        # No
        # Nothing to do
      When 3
        # Yes if same value
        For NI = 1 To maxtab(this.RAFFT)
          If this.RAFFT(NI) <> null and find(this.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If this.RAFFT(NI).POASTR = this.snapshot.OPESTR Then
              this.RAFFT(NI).POASTR = this.OPESTR
            Endif
          Endif
        Next NI
      When Default
        [L]ARET_VALUE = fmet this.SETERROR("TCHOPESTRAN", func AFNC.MES1(mess(349,2260,1), this.TCHOPESTRAN), [V]CST_AERROR)
    Endcase
  Endif
Return

###################################################################################################
$RAFFT_REPEAT_OPEEND
