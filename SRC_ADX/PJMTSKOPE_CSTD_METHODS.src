Local Integer NI

  [L]ARET_VALUE = [V]CST_AOK
  If (this.ASTALIN = [V]CST_AUPD and this.OPEEND <> this.snapshot.OPEEND) Then
    Case this.TCHOPEENDAN
      When 1
        # Yes
        For NI = 1 To maxtab(this.RAFFT)
          If this.RAFFT(NI) <> null and find(this.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            this.RAFFT(NI).POAEND = this.OPEEND
          Endif
        Next NI
      When 2
        # No
        # Nothing to do
      When 3
        # Yes if same value
        For NI = 1 To maxtab(this.RAFFT)
          If this.RAFFT(NI) <> null and find(this.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If this.RAFFT(NI).POAEND = this.snapshot.OPEEND Then
              this.RAFFT(NI).POAEND = this.OPEEND
            Endif
          Endif
        Next NI
      When Default
        [L]ARET_VALUE = fmet this.SETERROR("TCHOPEENDAN", func AFNC.MES1(mess(349,2260,1), this.TCHOPEENDAN), [V]CST_AERROR)
    Endcase
  Endif
Return

###################################################################################################
# Issue X3-24095/121425 - 2017-02-14 by EUHAV/FGR : BEGIN
$COPY
#Variable Instance TARGET Using C_PJMTSKOPE
#Variable Instance TECCLA Using C_PJMACOPY
#Value Integer TECIDX
#Local Integer ARET_VALUE

Local Instance TECPJMCOPY Using C_TECPJMCOPY     # Issue X3-29531 - 2017-04-21 by FGR
Local Integer NI
Local Integer ILINE

  # Issue X3-29531 - 2017-04-21 by FGR : BEGIN
  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  TECPJMCOPY = NewInstance C_TECPJMCOPY AllocGroup null
  [L]ARET_VALUE = fmet this.COPY_LOAD_PROPERTIES(TECPJMCOPY, TECCLA, TECIDX)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # --------------------
  # 1°) copy properties and translated texts
  [L]ARET_VALUE = func TECPJMCOPY_CSTD.DO_COPY_CHAIN(TECPJMCOPY, TECCLA, this, TARGET)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # --------------------
  If TECCLA.TASASSL = [V]CST_AYES Then
    For NI = 1 To maxtab(this.RAFFT)
      If this.RAFFT(NI) <> null and find(this.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        ILINE = fmet TARGET.ADDLINE("RAFFT",[V]CST_ALASTPOS)
        If ILINE = [V]CST_ANOTDEFINED Then
          [L]ARET_VALUE = fmet this.SETERROR("", mess(184,2260,1), [V]CST_AERROR)
          Break
        Endif
        [L]ARET_VALUE = fmet this.RAFFT(NI).COPY(TARGET.RAFFT(ILINE), TECCLA, TECIDX)
      Endif
    Next NI
  Endif
  # --------------------
$COPY_END
  If TECPJMCOPY <> null Then
    FreeGroup TECPJMCOPY
  Endif
Return

###################################################################################################
$COPY_LOAD_PROPERTIES
#Variable Instance TECPJMCOPY Using C_TECPJMCOPY : #
#Variable Instance TECCLA Using C_PJMACOPY : #
#Value Integer TECIDX
#Local Integer ARET_VALUE

  # Issue X3-29531 - 2017-04-21 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("EXTWST", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("EXTLAB", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD_AXX("ROODESAXX", AVOID.ACHAR, "PJMTSKOPE", "ROODESAXX", "KEYCONCAT", AVOID.ACHAR))
  If TECCLA.TASOPDAT = [V]CST_ANO Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("OPESTR", AVOID.ACHAR))
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("OPEEND", AVOID.ACHAR))
  Endif
  # Copy all descriptions (CLOB)
  If TECCLA.TASOPDES = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("OPEDESTEX", AVOID.ACHAR))
  Endif
  #Copy all comments (CLOB)
  If TECCLA.TASOPCOM = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("OPECOMTEX", AVOID.ACHAR))
  Endif
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("OPEUOM2", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("EXTQTY", AVOID.ACHAR))
Return

###################################################################################################
# Issue X3-29779/122141 - 2017-03-22 by FGR : BEGIN
$COMPUTE_OPECST_OPECTS2
Local Char SFCY(GLONFCY)
Local Decimal DTOTRATE
Local Decimal DRATE1
Local Decimal DRATE2
Local Decimal DRATEUOM
Local Decimal DRATEUOM2
Local Char STIMUOM(GLONUOM)
Local Integer IOPECOST
Local Date DOPESTR
Local Integer IRET

  # Issue X3-17377/120529 - 2016-12-21 by FGR : Created a method to rewrite all of that and to have AINSERT_AUPDATE_CONTROL_BEFORE more readable
  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------------------
  STIMUOM = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "HOURLYUNIT")
  # ---------------------------------------
  If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and (this.EXTWST <> this.snapshot.EXTWST or this.EXTLAB <> this.snapshot.EXTLAB)) Then
    Local File WORKSTATIO [WST]
    # ---------------------------------------
    # 1ST resouce is filled \ UPDATE and 1ST resource has been changed
    # ---------------------------------------
    IOPECOST = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.TASFCY, "PJMOPECST")
    # ---------------------------------------
    If IOPECOST <> 1 and IOPECOST <> 2 Then
      [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES2(mess(478,2260,1), "PJMOPECST", this.TASFCY), [V]CST_AERROR)            # Issue X3-27073/121779 - 2017-03-01 by TEJAC
      Return
    Endif
    # ---------------------------------------
    If this.OPESTR = [0/0/0] Then
      DOPESTR = date$
    Else
      DOPESTR = this.OPESTR
    Endif
    # ---------------------------------------
    DRATE1 = 0
    DRATE2 = 0
    DRATEUOM = 0
    # ---------------------------------------
    If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and (this.EXTWST <> this.snapshot.EXTWST or this.EXTLAB <> this.snapshot.EXTLAB)) Then
      For SFCY = this.TASFCY, ""
        Read [F:WST]WST0=this.EXTWST;SFCY
        If !fstat Then
          If IOPECOST = 1 Then
            # --- Get rate BY Costing dimension first
            IRET = fmet this.GET_RES_RATE_DIM(DOPESTR, STIMUOM, this.CUR, this.TASFCY, this.EXTWST, DRATE1)
            [L]ARET_VALUE = max([L]ARET_VALUE,IRET)
            # ---------------------------------------
            If DRATE1 = 0 Then
              IRET = fmet this.GET_RES_RATE_CSTYP([F:WST]PCCCOD, DOPESTR, STIMUOM, this.CUR, DRATE1)
              [L]ARET_VALUE = max([L]ARET_VALUE,IRET)
            Endif
          Else
            # ----- Get rate BY Cost type first -----
            IRET = fmet this.GET_RES_RATE_CSTYP([F:WST]PCCCOD, DOPESTR, STIMUOM, this.CUR, DRATE1)
            [L]ARET_VALUE = max([L]ARET_VALUE,IRET)
            # ---------------------------------------
            If DRATE1 = 0 Then
              IRET = fmet this.GET_RES_RATE_DIM(DOPESTR, STIMUOM, this.CUR, this.TASFCY, this.EXTWST, DRATE1)
              [L]ARET_VALUE = max([L]ARET_VALUE,IRET)
            Endif
          Endif
          Break
        Endif
      Next SFCY
    Endif
    # ---------------------------------------
    # 2nd resouce is filled OR on UPDATE and 2nd resource has been changed
    If (this.ASTALIN = [V]CST_ANEW and this.EXTLAB <> AVOID.ACHAR) or (this.ASTALIN = [V]CST_AUPD and (this.EXTWST <> this.snapshot.EXTWST or this.EXTLAB <> this.snapshot.EXTLAB)) Then
      For SFCY = this.TASFCY, ""
        Read [F:WST]WST0=this.EXTLAB;SFCY
        If !fstat Then
          If IOPECOST = 1 Then
            # --- Get rate BY Costing dimension first
            IRET = fmet this.GET_RES_RATE_DIM(DOPESTR, STIMUOM, this.CUR, this.TASFCY, this.EXTLAB, DRATE2)
            [L]ARET_VALUE = max([L]ARET_VALUE,IRET)
            # ---------------------------------------
            If DRATE2 = 0 Then
              IRET = fmet this.GET_RES_RATE_CSTYP([F:WST]PCCCOD, DOPESTR, STIMUOM, this.CUR, DRATE2)
              [L]ARET_VALUE = max([L]ARET_VALUE,IRET)
            Endif
          Else
            # ----- Get rate BY Cost type first -----
            IRET = fmet this.GET_RES_RATE_CSTYP([F:WST]PCCCOD, DOPESTR, STIMUOM, this.CUR, DRATE2)
            [L]ARET_VALUE = max([L]ARET_VALUE,IRET)
            # ---------------------------------------
            If DRATE2 = 0 Then
              IRET = fmet this.GET_RES_RATE_DIM(DOPESTR, STIMUOM, this.CUR, this.TASFCY, this.EXTLAB, DRATE2)
              [L]ARET_VALUE = max([L]ARET_VALUE,IRET)
            Endif
          Endif
          Break
        Endif
      Next SFCY
    Endif
    # ---------------------------------------
    If [L]ARET_VALUE < [V]CST_AERROR Then
      DRATEUOM = DRATE1 + DRATE2
      DRATEUOM2 =  DRATE1 + DRATE2
      # ---------------------------------------
      If STIMUOM <> this.OPEUOM2 Then
        Call CONVERT_QTY(this.ACTX, this.OPEUOM2, STIMUOM, DRATEUOM2) From TRTX3_SYRA
      Endif
      this.OPECST = DRATEUOM       # OPECST in STIMUOM Unit
      this.OPECST2 = DRATEUOM2     # OPECST2 in OPEUOM2 converted unit if necessary
      # ---------------------------------------
    Endif
  Else
    If this.OPEUOM2 <> this.snapshot.OPEUOM2 Then
      DRATEUOM = this.OPECST
      Call CONVERT_QTY(this.ACTX, this.OPEUOM2, STIMUOM, DRATEUOM) From TRTX3_SYRA
      this.OPECST2 = DRATEUOM
    Endif
  Endif
  # ---------------------------------------
Return

###################################################################################################
$COMPUTE_EXTAMT
#Value Decimal PLNQTY
#Value Decimal LABCST
#Local Decimal ARET_VALUE
# Issue X3-26843 - 2017-02-27 by SINGC

  [L]ARET_VALUE = PLNQTY * LABCST
Return

###################################################################################################
$PROGRESS
# Issue X3-29489 - 2017-04-04 by SINGC
#Value Decimal CSMQTY
#Value Decimal RMNQTY
#Local Decimal ARET_VALUE

  [L]ARET_VALUE = 0
  If CSMQTY <> 0 Then
    [L]ARET_VALUE = ar2(CSMQTY / (CSMQTY + RMNQTY) * 100)
  Endif
Return

###################################################################################################
$OPLNK_COUNT
#Local Decimal ARET_VALUE

Local Integer NI

  # Issue X3-28535/X3-28737 - 2017-08-21 by TEJAC
  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.OPLNK)
    If this.OPLNK(NI) <> null and find(this.OPLNK(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE += 1
    Endif
  Next NI
Return

###################################################################################################
$OPLNK_USED
#Value Integer COD ()
#Value Integer SPLIT ()
#Local Decimal ARET_VALUE

Local Integer NI
Local Integer NI1

  # Issue X3-28535/X3-28737 - 2017-08-21 by TEJAC
  [L]ARET_VALUE = [V]CST_ANO
  If COD > 0 Then
    For NI = 1 To maxtab(this.OPLNK)
      If this.OPLNK(NI) <> null and find(this.OPLNK(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.OPLNK(NI).OPENUMLNK = COD and this.OPLNK(NI).OPESPNUMLNK = SPLIT Then
          [L]ARET_VALUE = [V]CST_AYES
          Break
        Endif
      Endif
    Next NI
  Endif
Return

