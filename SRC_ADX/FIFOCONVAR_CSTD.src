#<AdxTL>@(#)0.0.0.0 $Revision$
# Class FIFOCONVAR
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ACONTROL"                : Gosub ACONTROL                    From FIFOCONVAR_CSTD
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE      From FIFOCONVAR_CSTD
        When "AINSERT_BEFORE"          : Gosub AINSERT_BEFORE              From FIFOCONVAR_CSTD
        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE      From FIFOCONVAR_CSTD
      Endcase
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
     When "FCY"
     Case [L]ARULE
      When "CONTROL"    : Gosub FCY_CONTROL
      When "PROPAGATE"  : Gosub FCY_PROPAGATE
     Endcase
     When "FIFCOD"
     Case [L]ARULE
      When "PROPAGATE"  : Gosub FIFCOD_PROPAGATE
     Endcase
  Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
      When "FIFCOD_VALIDATE"                 : Gosub FIFCOD_VALIDATE
      When "STARTDAT_INITIALIZE"             : Gosub STARTDAT_INITIALIZE
      When "STARTDAT_VALIDATE"               : Gosub STARTDAT_VALIDATE
      When "FINDAT_INITIALIZE"               : Gosub FINDAT_INITIALIZE
      When "FINDAT_VALIDATE"                 : Gosub FINDAT_VALIDATE
      When "PAYMENTS_VALIDATE"               : Gosub PAYMENTS_VALIDATE
      When "COMPUTE_FIFO"                    : Gosub COMPUTE_FIFO
      When "DIMENSION_INITIALIZE"            : Gosub DIMENSION_INITIALIZE
      When "POST_FIFO"                       : Gosub POST_FIFO
      When "DOCUMENT_REVERSAL"               : Gosub DOCUMENT_REVERSAL
      When "IS_LAST_FIFO"                    : Gosub IS_LAST_FIFO
  Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return
######################################################################################
######################################################################################
######################################################################################
######################################################################################
#
#                                     CLASS EVENTS
#
######################################################################################
######################################################################################
######################################################################################
######################################################################################
$ACONTROL

    [L]ASTATUS = fmet this.FIFCOD_VALIDATE(this.FIFONO, this.FIFCOD, this.CPY, this.FCY)
    If [L]ASTATUS < [V]CST_AERROR
        [L]ASTATUS = fmet this.STARTDAT_VALIDATE(this.STARTDAT, this.FIFCOD)
    Endif
    If [L]ASTATUS < [V]CST_AERROR
        [L]ASTATUS = fmet this.FINDAT_VALIDATE(this.FINDAT, this.CPY)
    Endif

Return
######################################################################################
######################################################################################
$AUPDATE_CONTROL_BEFORE

  #-- 1) Can't modify a site on already created FIFO conversion variance
  If this.snapshot.FCY <> AVOID.ACHAR & this.snapshot.FCY <> this.FCY
    [L]ASTATUS = fmet this.ASETERROR("", mess(1,7708,1), [V]CST_AERROR)
  Endif

  #-- 2) Can't modify the type on already created FIFO conversion variance
  If this.snapshot.FIFTYP <> AVOID.AINT & this.snapshot.FIFTYP <> this.FIFTYP
    [L]ASTATUS = fmet this.ASETERROR("", mess(2,7708,1), [V]CST_AERROR)
  Endif

  #-- 3) Can't modify the code on already created FIFO conversion variance
  If this.snapshot.FIFCOD <> AVOID.ACHAR & this.snapshot.FIFCOD <> this.FIFCOD
    [L]ASTATUS = fmet this.ASETERROR("", mess(3,7708,1), [V]CST_AERROR)
  Endif

  #-- 4) Can't modify the start date on already posted FIFO conversion variance
  If this.snapshot.STARTDAT <> AVOID.ADATE & this.snapshot.STARTDAT <> this.STARTDAT & this.FLDPOS = 2
    [L]ASTATUS = fmet this.ASETERROR("", mess(6,7708,1), [V]CST_AERROR)
  Endif

  #-- 5) Can't modify the end date on already posted FIFO conversion variance
  If this.snapshot.FINDAT <> AVOID.ADATE & this.snapshot.FINDAT <> this.FINDAT & this.FLDPOS = 2
    [L]ASTATUS = fmet this.ASETERROR("", mess(7,7708,1), [V]CST_AERROR)
  Endif

Return
######################################################################################
######################################################################################
#
# 1) Get the FIFO conversion record sequence number
#
######################################################################################
$AINSERT_BEFORE

  Local Char WSEQ_CODE(20)
  Local Integer WMANUAL
  Local Char WMESSAGE(250)
  Local Char WCOMP(250)
  WCOMP = ""

  If this.FIFONO = AVOID.ACHAR
    #-- 1) Get sequence number code to use
    If func TCA_TOOL.LECTCA(this.ACTX,2,fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"LEGCPY"),
&      fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY, "LEG"),21,WSEQ_CODE,WMANUAL,WMESSAGE) = [V]CST_AFALSE
      [L]ASTATUS = fmet this.ASETERROR("",mess(64,199,1),[V]CST_AERROR)
      Return
    Endif
    WCOMP = this.FIFCOD

    #-- 2) Get sequence number
    [L]ASTATUS = func ANM_TOOL.NUMERO(this.ACTX,WSEQ_CODE,this.FCY,date$,WCOMP,this.FIFONO,WMESSAGE)
    If [L]ASTATUS = [V]CST_AERROR
      [L]ASTATUS = fmet this.ASETERROR("",WMESSAGE,[V]CST_AERROR)
    Endif

  Endif

Return
######################################################################################
$ADELETE_CONTROL_BEFORE

  If (this.FLDPOS = 2)
    [L]ASTATUS = fmet this.ASETERROR("", mess(21,7708,1), [V]CST_AERROR)
  Endif

Return
######################################################################################
######################################################################################
######################################################################################
######################################################################################
#
#                                   PROPERTY EVENTS
#
######################################################################################
######################################################################################
######################################################################################
######################################################################################
$FCY_CONTROL

  #-- 1) Site must have the FIFRC parameter active
  Local Char ERROR_MESSAGE(100)

  If func AFNC.PARAM("FIFRC", this.FCY) <> "2"
      ERROR_MESSAGE = func AFNC.MES2(mess(218,125,1), "FIFRC", mess(1,1,1))
      [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, ERROR_MESSAGE, [V]CST_AERROR)
  Endif

Return
######################################################################################

######################################################################################
$FCY_PROPAGATE

  #-- 1) Get the site Company
  this.CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"LEGCPY")

Return
######################################################################################
######################################################################################
$FIFCOD_PROPAGATE
  Local File BANK [BAN]

  Read [F:BAN]BAN0 = this.FIFCOD
  If !fstat
      this.FLDBIN = [F:BAN]BIDNUM
      this.FLDACC = [F:BAN]BANACC
      this.FLDCUR = [F:BAN]CUR
  Endif

  LogicClose File [BAN]

Return
######################################################################################
######################################################################################
######################################################################################
######################################################################################
#
#                                     METHODS
#
######################################################################################
######################################################################################
######################################################################################
######################################################################################
$FIFCOD_VALIDATE
  #P_ variables are method parameters
  Local File BANK         [BAN]

  If [L]P_FIFCOD <> AVOID.ACHAR
    #-- 1) Check if Fifo conversion variance exists
    Read [F:BAN]BAN0 = [L]P_FIFCOD
    If !fstat
      #-- 2) Check not belongs to the current site or company
      If (([F:BAN]FCY = "" and [F:BAN]CPY <> [L]P_CPY) or ([F:BAN]FCY <> [L]P_FCY and [F:BAN]FCY <> "") or
&          [F:BAN]FLDFIFCP=1 or [F:BAN]FLDSDA=AVOID.ADATE)
        [L]ARET_VALUE = fmet this.ASETERROR("FIFCOD", mess(6,83,1) - mess(368,177,1), [V]CST_AERROR)
      #-- 4) We can only have one not posted Fifo conversion variance
      Elsif func OPENED_FIF_CONVAR([L]P_FIFONO, [L]P_FIFCOD, this.STARTDAT) = 1
        [L]ARET_VALUE = fmet this.ASETERROR("FIFCOD", mess(5,7708,1), [V]CST_AERROR)
      Endif
    Else
      [L]ARET_VALUE = fmet this.ASETERROR("FIFCOD", mess(6,83,1) - mess(368,177,1), [V]CST_AERROR)
    Endif

  Else
      [L]ARET_VALUE = [V]CST_AERROR
  Endif

  LogicClose File [BAN]

Return
######################################################################################
######################################################################################
$STARTDAT_INITIALIZE
  #P_ variables are method parameters
  Local File    FIFOCONVAR  [FIFCV2]
  Local File    BANK        [BAN]

  Local Char FIFCOD(5)      : [L]FIFCOD      = [L]P_FIFCOD
  Local Char FIFONO(25)     : [L]FIFONO      = [L]P_FIFONO
  Local Date CURSTARTDAT


  Gosub GET_LAST_FIFO
  If [L]LASTFIFO = 1
    [L]ARET_VALUE = [F:FIFCV2]FINDAT + 1
    this.SDADIS = 2
  Else
    Read [F:BAN]BAN0 = [L]FIFCOD
    If !fstat
      [L]ARET_VALUE = [F:BAN]FLDSDA
      If this.SDADIS <> 2
        this.SDADIS = 1
      Else
        this.SDADIS = 2
      Endif

    Else
      this.SDADIS = 1
    Endif
  Endif
  Filter [F:FIFCV2]

  LogicClose File  [BAN]
  LogicClose File  [FIFCV2]


Return
######################################################################################
######################################################################################
$STARTDAT_VALIDATE
  #P_ variables are method parameters
  Local File    BANK                  [BAN]
  Local File    FIFOCONVAR            [FIFCV2]

  Local Char ERROR_MESSAGE(100)
  Local Char FIFCOD(5)      : [L]FIFCOD      = this.FIFCOD
  Local Char FIFONO(25)     : [L]FIFONO      = this.FIFONO
  Local Date PERSTRDAT, PERENDDAT
  Local Date CURSTARTDAT    : [L]CURSTARTDAT = [L]P_STARTDAT

  [L]ARET_VALUE = [V]CST_AOK
  #-- 1) FIFO conversion variance Start date cannot be less then cash/bank account start date
  Read [F:BAN]BAN0 = [L]P_FIFCOD
  If !fstat
      If [L]P_STARTDAT = AVOID.ADATE
          [L]ARET_VALUE = fmet this.ASETERROR("STARTDAT", mess(197,193,1), [V]CST_AERROR)
      Elsif [F:BAN]FLDSDA = AVOID.ADATE
          [L]ARET_VALUE = fmet this.ASETERROR("STARTDAT", mess(45,102,1) + " " + tolower(mess(197,193,1)), [V]CST_AERROR)
      Elsif [F:BAN]FLDSDA > [L]P_STARTDAT
          ERROR_MESSAGE = mess(1,104,1) - num$([L]P_STARTDAT) + ' < ' + num$([F:BAN]FLDSDA)
          [L]ARET_VALUE = fmet this.ASETERROR("STARTDAT", ERROR_MESSAGE, [V]CST_AERROR)
      Else
          Call GET_PERIOD_DATES(this.CPY, [L]P_STARTDAT, [L]PERSTRDAT, [L]PERENDDAT)
          If [L]PERSTRDAT <> [L]P_STARTDAT
              [L]ARET_VALUE = fmet this.ASETERROR("STARTDAT", mess(49,108,1), [V]CST_AERROR)
          Else
              Gosub GET_LAST_FIFO
              If [L]LASTFIFO = 1
                  If this.STARTDAT <> [F:FIFCV2]FINDAT + 1
                      [L]ARET_VALUE = fmet this.ASETERROR("STARTDAT", mess(13,7708,1), [V]CST_AERROR)
                  Endif
              Endif
          Endif
      Endif
  Endif

  Filter [F:FIFCV2]

  LogicClose File  [FIFCV2]
  LogicClose File  [BAN]
Return
######################################################################################
######################################################################################
$FINDAT_INITIALIZE
  Local Date PERSTRDAT, PERENDDAT

  Call GET_PERIOD_DATES([L]P_CPY, [L]P_ENDDAT, [L]PERSTRDAT, [L]PERENDDAT)
  [L]ARET_VALUE = [L]PERENDDAT

Return
######################################################################################
######################################################################################
$FINDAT_VALIDATE
  Local Char    ERROR_MESSAGE(100)
  Local Date    CURFINDAT

  [L]ARET_VALUE = [V]CST_AOK
  If this.STARTDAT = AVOID.ADATE
      [L]ARET_VALUE = fmet this.ASETERROR("STARTDAT", mess(197,193,1), [V]CST_AERROR)
  Elsif this.STARTDAT >= [L]P_FINDAT
      ERROR_MESSAGE = mess(1,104,1) - num$([L]P_FINDAT) + ' < ' + num$(this.STARTDAT)
      [L]ARET_VALUE = fmet this.ASETERROR("FINDAT", ERROR_MESSAGE, [V]CST_AERROR)
  Elsif func FINPER_SYRA.CTRL_DATE_PER([L]P_FINDAT,0,[L]P_CPY,ERROR_MESSAGE) = [V]CST_AERROR
      [L]ARET_VALUE = fmet this.ASETERROR("FINDAT", ERROR_MESSAGE, [V]CST_AERROR)
  Else
      CURFINDAT = fmet this.FINDAT_INITIALIZE([L]P_FINDAT, this.CPY)
      If CURFINDAT <> [L]P_FINDAT
          [L]ARET_VALUE = fmet this.ASETERROR("FINDAT", mess(50,108,1), [V]CST_AERROR)
      Endif
  Endif

Return
######################################################################################
######################################################################################
$PAYMENTS_VALIDATE
  Local Integer S_IN_THE_BAN: S_IN_THE_BAN = 9

  Local File PAYMENTH [PYH]

  [L]ARET_VALUE = [V]CST_AOK

  ### need to check if FYc emtyy etc
  If ([V]COMPUTING = 0)
    #-- 4) Get all unposted payments related to this FIFO conversion variance
    Filter [F:PYH] Where [F:PYH]BAN = this.FIFCOD and this.STARTDAT <= [F:PYH]ACCDAT and
&                        [F:PYH]ACCDAT <= this.FINDAT and [F:PYH]STA < [L]S_IN_THE_BAN
    Read [F:PYH] First

    If !fstat
        [L]ARET_VALUE = fmet this.ASETERROR("", mess(4,7708,1), [V]CST_AERROR)
    Endif
  Endif
  LogicClose File [PYH]
Return
######################################################################################
### Gets the previous FIFO record for the site\bank code. Returns empty if it's the
### first FIFO record
######################################################################################
Funprog GET_PREVIOUS_FIFONO(FIFONO, FIFCOD, CURSTARTDAT)
  Value    Char FIFONO
  Value    Char FIFCOD
  Value    Date CURSTARTDAT

  Local Char RET_VAL (GLONVCR)
  Local Char FIFONO(1)

  Local File FIFOCONVAR  [FIFCV2]
  Gosub GET_LAST_FIFO
  If [L]LASTFIFO = 1
    [L]RET_VAL = [F:FIFCV2]FIFONO
  Endif
  Filter [F:FIFCV2]

  LogicClose File [FIFCV2]

End [L]RET_VAL
######################################################################################
### Checks if there's any open FIFO conversion variance for the given Bank/Cash.
### If a date is supplied, search will be done only on records previous to that date
######################################################################################
Funprog OPENED_FIF_CONVAR(FIFONO, FIFCOD, CURSTARTDAT)
  Value Char    FIFONO, FIFCOD
  Value Date    CURSTARTDAT

  #-- 1) Checks if there's any open FIFO conversion variance for the given Bank/Cash.
  Local Integer RET_VAL     : [L]RET_VAL = 0
  Local Integer NOT_POSTED  : [L]NOT_POSTED = 1

  Local File FIFOCONVAR  [FIFCV2]
  Gosub GET_LAST_FIFO

  If [L]LASTFIFO = 1 and [F:FIFCV2]FLDPOS = [L]NOT_POSTED: [L]RET_VAL = 1 : Endif
  Filter [F:FIFCV2]

  LogicClose File [FIFCV2]

End [L]RET_VAL
######################################################################################
######################################################################################
Subprog GET_PERIOD_DATES(CPY, DATUSR, PERSTRDAT, PERENDDAT)
  Value    Char CPY
  Value    Date DATUSR
  Variable Date PERSTRDAT
  Variable Date PERENDDAT

  Local Tinyint LEDT
  Local Decimal FISCALYEAR, PERIOD

  Local File COMPANY      [CPY]
  Local File GACM         [GCM]

  Read [F:CPY]CPY0 = [L]CPY
  If fstat > 1 : Raz [F:CPY] : Endif
  Read [F:GCM]GCM0 = [F:CPY]ACM
  If fstat > 1 : Raz [F:GCM] : Endif
  [L]LEDT = [F:GCM]GENLEDTYP

  # get fiscal year and period for the start date of FIFO conversion variance
  Call GETPERSOC([L]CPY, [L]LEDT, [L]DATUSR, [L]FISCALYEAR, [L]PERIOD) From CPTSUB
  # get start date and end date for the fiscal year and period of FIFO conversion variance
  Call DATPERIOD([L]CPY, [L]LEDT, [L]FISCALYEAR, [L]PERIOD, [L]PERSTRDAT, [L]PERENDDAT) From CPTSUB

  LogicClose File  [CPY]
  LogicClose File  [GCM]

End
######################################################################################
######################################################################################
Funprog VARIANCE_EXCLUDED(TYP, NUM, ACC)
  Value Char    TYP, NUM, ACC

  Local Integer RET_VAL     : [L]RET_VAL = 0

  Local File GACCENTRYD   [DAE2]
  Local File GACCOUNT     [GAC]

  Link [F:DAE2] With [F:GAC]GAC0 ~= [F:DAE2]COA;ACC
&               As [ENTJOU2]
&               Where [F:DAE2]TYP = [L]TYP and [F:DAE2]NUM = [L]NUM and
&                     [F:DAE2]ACC <> [L]ACC and [F:GAC]FIFOVARPRO = 2
  Look [ENTJOU2] First
  If !fstat
    [L]RET_VAL = 1
  Endif

  LogicClose File [DAE2]
  LogicClose File [GAC]

End [L]RET_VAL
######################################################################################
######################################################################################
$COMPUTE_FIFO
  Local Integer LINE_NUM, ROWTMP, ISCURSTO
  Local Decimal TMPTOTAKE # tmp amount still needed to be taken
  Local Decimal LASTBALSH # previous BALSH
  Local Integer ROWFORSET # First not empty row for settlement and tmp interator in nested for

  Local Date    FILTER_STD
  Local Date    FILTER_FID

  Local File BANK         [BAN]
  Local File GACCENTRY    [HAE]
  Local File GACCENTRYD   [DAE]
  Local File GTYPACCENT   [GTE]
  Local File FIFOCONVARD  [FIFCVD2]
  Local File PAYACCNUM    [PAN]

  [L]ROWFORSET = 1
  [L]LASTBALSH = 0
  [L]ARET_VALUE = [V]CST_AOK
  If (fmet this.PAYMENTS_VALIDATE() = [V]CST_AOK)
    If this.FLDPOS <> 2
      #1 - Clean child collection and database records on detail table
      Gosub CLEAN_LINE_COLLECTION

      [L]ARET_VALUE = fmet this.ACONTROL()
      If [L]ARET_VALUE < [V]CST_AERROR
        #2 - Get currency stock
        [L]ISCURSTO = 1
        Gosub GET_CURRENCY_STOCK
        #3 - Get period entries
        If([V]COMPUTING <> 1) # if 1 we are computing FIFO, if <> 1 we are not loading data from current period.
          [L]ISCURSTO = 0
          Gosub GET_PERIOD_ENTRIES
        Endif
      Endif
    Else
      [L]ARET_VALUE = fmet this.ASETERROR("", mess(9,7708,1), [V]CST_AERROR)
    Endif
  Else
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(4,7708,1), [V]CST_AERROR)
  Endif

  LogicClose File [BAN]
  LogicClose File [HAE]
  LogicClose File [DAE]
  LogicClose File [GTE]
  LogicClose File [FIFCVD2]
  LogicClose File [PAN]

Return
######################################################################################
######################################################################################
$GET_CURRENCY_STOCK

  Local Char PREVIOUS_FIFONO(GLONVCR)

  PREVIOUS_FIFONO = func GET_PREVIOUS_FIFONO(this.FIFONO, this.FIFCOD, this.STARTDAT)

  If PREVIOUS_FIFONO = ""
    Gosub GET_PERIOD_ENTRIES
  Else
    Gosub GET_CURRENCY_STOCK_FROM_PREVIOUS
  Endif

Return
######################################################################################
######################################################################################
$GET_PERIOD_ENTRIES

  Local Decimal  RATECALC  # Rate Calculated
  Local Decimal  EXRATDIF  # Exchange rate difference (RATECAL)
  Local Decimal  SUMTOTAMO # Total amount

  Local Char CURLEG(5) : [L]CURLEG = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.CPY,"LEG")
  Local Char LSPECRITFIFO(250)

  If [L]ISCURSTO = 1
      Read [F:BAN]BAN0 = this.FIFCOD
      If !fstat
          [L]FILTER_STD = [F:BAN]FLDSDA
      Endif
      [L]FILTER_FID = this.STARTDAT - 1
  Else
      [L]FILTER_STD = this.STARTDAT
      [L]FILTER_FID = this.FINDAT
  Endif

  Gosub LINK_ENTJOU

  Look [F:ENTJOU] First
  If !fstat
    this.SDADIS = 2
  Endif

  For [ENTJOU]
      [L]LSPECRITFIFO = '1=1'
      GPOINT = "FIFOJOUFILTER" : Gosub ENTREE From EXEFNC

      Read [F:GTE]GTE0=[F:DAE]TYP;[L]CURLEG
      If fstat
          Read [F:GTE]GTE0=[F:DAE]TYP;""
      Endif

      If (!fstat and [F:HAE]REFINT <> AVOID.ACHAR)
          Filter [F:PAN] Where [F:PAN]ACCNUM = [F:DAE]ACCNUM and [F:PAN]RVSACCNUM = 0
          Look [F:PAN] First
      Endif

      If (!fstat and [F:GTE]PER <> 2 and evalue([L]LSPECRITFIFO) and
&         func VARIANCE_EXCLUDED([F:DAE]TYP, [F:DAE]NUM, this.FLDACC) = 0)

          If [L]ISCURSTO = 0
              Gosub CREATE_LINE_AND_COMMON_VALUES
              this.FIFCVD([L]LINE_NUM).ISCURSTO = 0
          Endif
          If [F:DAE]SNS = 1
              If [L]ISCURSTO = 1
                  Gosub CREATE_LINE_AND_COMMON_VALUES
                  this.FIFCVD([L]LINE_NUM).ISCURSTO = 1
              Endif
              this.FIFCVD([L]LINE_NUM).AMTLED = [F:DAE]AMTLED
              this.FIFCVD([L]LINE_NUM).AMTCUR = [F:DAE]AMTCUR
              this.FIFCVD([L]LINE_NUM).EXRATDIF = 0
              this.FIFCVD([L]LINE_NUM).TOTAMO = 0
              this.FIFCVD([L]LINE_NUM).FORSETTL = [F:DAE]AMTCUR
              this.FIFCVD([L]LINE_NUM).RATECALC = 0
              this.FIFCVD([L]LINE_NUM).SNS = [F:DAE]SNS
              this.FIFCVD([L]LINE_NUM).RATECALC = 0
              If [L]LASTBALSH < 0 : [L]LASTBALSH = 0 : Endif
              [L]LASTBALSH = [L]LASTBALSH + [F:DAE]AMTCUR
              this.FIFCVD([L]LINE_NUM).BALSH = [L]LASTBALSH
          Elsif [F:DAE]SNS = -1
              If [L]ISCURSTO = 0
                  this.FIFCVD([L]LINE_NUM).SNS = [F:DAE]SNS
                  this.FIFCVD([L]LINE_NUM).AMTLED = (-1) * [F:DAE]AMTLED
                  this.FIFCVD([L]LINE_NUM).AMTCUR = (-1) * [F:DAE]AMTCUR
              Endif
              [L]TMPTOTAKE = [F:DAE]AMTCUR
              [L]RATECALC = 0
              For [L]ROWTMP = [L]ROWFORSET To maxtab(this.FIFCVD)
                If find(this.FIFCVD([L]ROWTMP).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
                  If this.FIFCVD([L]ROWTMP).SNS = 1
                    If [L]TMPTOTAKE <= this.FIFCVD([L]ROWTMP).FORSETTL
                      this.FIFCVD([L]ROWTMP).FORSETTL = this.FIFCVD([L]ROWTMP).FORSETTL - [L]TMPTOTAKE
                      [L]RATECALC = [L]RATECALC + ([L]TMPTOTAKE * this.FIFCVD([L]ROWTMP).AMTLED /
&                                                 this.FIFCVD([L]ROWTMP).AMTCUR)
                      [L]TMPTOTAKE = 0
                      [L]ROWFORSET = [L]ROWTMP
                      Break
                    Else
                      [L]RATECALC = [L]RATECALC + (this.FIFCVD([L]ROWTMP).FORSETTL *
&                                                 this.FIFCVD([L]ROWTMP).AMTLED / this.FIFCVD([L]ROWTMP).AMTCUR)
                      [L]TMPTOTAKE = [L]TMPTOTAKE - this.FIFCVD([L]ROWTMP).FORSETTL
                      this.FIFCVD([L]ROWTMP).FORSETTL = 0
                      If [L]ISCURSTO = 1 and find(this.FIFCVD([L]ROWTMP).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
                        [L]ARET_VALUE = fmet this.ADELLINE("FIFCVD", this.FIFCVD([L]ROWTMP).AORDER)
                      Endif
                    Endif
                  Endif
                Endif
              Next [L]ROWTMP
              [L]LASTBALSH -= [F:DAE]AMTCUR
              If [L]ISCURSTO = 0 and [L]LASTBALSH >= 0
                  this.FIFCVD([L]LINE_NUM).BALSH = [L]LASTBALSH
                  this.FIFCVD([L]LINE_NUM).RATECALC = arr([L]RATECALC / [F:DAE]AMTCUR, 0.0001)
                  this.FIFCVD([L]LINE_NUM).EXRATDIF = arr([F:DAE]AMTLED - ([L]RATECALC), 0.01)
                  this.FIFCVD([L]LINE_NUM).TOTAMO = [L]SUMTOTAMO + this.FIFCVD([L]LINE_NUM).EXRATDIF
                  [L]SUMTOTAMO = this.FIFCVD([L]LINE_NUM).TOTAMO
              Endif
          Endif
          this.TOTAMOH = [L]SUMTOTAMO
      Endif
  Next

  If [L]ISCURSTO = 1
    [L]LASTBALSH = 0
    For [L]ROWTMP = [L]ROWFORSET To maxtab(this.FIFCVD)
      If find(this.FIFCVD([L]ROWTMP).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        [L]LASTBALSH += this.FIFCVD([L]ROWTMP).FORSETTL
        If [L]LASTBALSH = 0
          [L]ARET_VALUE = fmet this.ADELLINE("FIFCVD", this.FIFCVD([L]ROWTMP).AORDER)
        Endif
        this.FIFCVD([L]ROWTMP).BALSH = [L]LASTBALSH
      Endif
    Next [L]ROWTMP
  Endif

Return
######################################################################################
######################################################################################
$CREATE_LINE_AND_COMMON_VALUES
  [L]LINE_NUM=fmet this.ADDLINE("FIFCVD",[V]CST_ALASTPOS)
  If [L]LINE_NUM=[V]CST_ANOTDEFINED # check status after creating line
      [L]ARET_VALUE = [L]CST_AFALSE
  Endif

  this.FIFCVD([L]LINE_NUM).FIFONO = this.FIFONO
  this.FIFCVD([L]LINE_NUM).LIN = [L]LINE_NUM
  this.FIFCVD([L]LINE_NUM).BPRVCR = [F:HAE]BPRVCR
  this.FIFCVD([L]LINE_NUM).NUM = [F:DAE]NUM
  this.FIFCVD([L]LINE_NUM).LEG = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.CPY,"LEG")
  this.FIFCVD([L]LINE_NUM).TYP = [F:DAE]TYP
  this.FIFCVD([L]LINE_NUM).ACCDAT = [F:HAE]ACCDAT
  this.FIFCVD([L]LINE_NUM).MULRATE = arr([F:DAE]AMTLED / [F:DAE]AMTCUR, 0.0001)

Return
######################################################################################
######################################################################################
$GET_CURRENCY_STOCK_FROM_PREVIOUS

  [L]LASTBALSH = 0
  Filter [F:FIFCVD2] Where [F:FIFCVD2]FIFONO = PREVIOUS_FIFONO and [F:FIFCVD2]FORSETTL > 0
  For [F:FIFCVD2]

    LINE_NUM=fmet this.ADDLINE("FIFCVD",[V]CST_ALASTPOS)
    If [L]LINE_NUM=[V]CST_ANOTDEFINED # check status after creating line
      ARET_VALUE = CST_AFALSE
    Endif

    SetInstance this.FIFCVD([L]LINE_NUM) With [F:FIFCVD2]

    [L]LASTBALSH += this.FIFCVD([L]LINE_NUM).FORSETTL
    this.FIFCVD([L]LINE_NUM).BALSH = [L]LASTBALSH
    this.FIFCVD([L]LINE_NUM).FIFONO = this.FIFONO
    this.FIFCVD([L]LINE_NUM).LIN = [L]LINE_NUM
    this.FIFCVD([L]LINE_NUM).ISCURSTO = 1

    this.TOTAMOH = this.FIFCVD([L]LINE_NUM).TOTAMO

  Next
  Filter [F:FIFCVD2]

Return
######################################################################################
######################################################################################
$GET_LAST_FIFO

  Local Integer LASTFIFO : [L]LASTFIFO = 0
  Local Char SEARCH_CRITERIA(250)
  SEARCH_CRITERIA = "[F:FIFCV2]FIFCOD = '" + [L]FIFCOD + "' and " +
&                   "[F:FIFCV2]FIFONO <> '" + [L]FIFONO + "'"

  If [L]CURSTARTDAT <> AVOID.ADATE
    SEARCH_CRITERIA += " and [F:FIFCV2]FINDAT <= [L]CURSTARTDAT"
  Endif

  Filter [F:FIFCV2] Where evalue(SEARCH_CRITERIA)
&                   Order By [F:FIFCV2]FINDAT Desc
  Read [F:FIFCV2] First
  If !fstat
    [L]LASTFIFO = 1
  Endif
Return
######################################################################################
######################################################################################
$LINK_ENTJOU

  Call SETMAINREF(this.CPY, GTYPGEN, GTYPANA) From CPTDIV

  Link [F:DAE] With [F:HAE]HAE0 ~= [F:DAE]TYP;NUM
&              As [ENTJOU]
&              Where [F:DAE]ACC = this.FLDACC and [F:DAE]CPY = this.CPY and [F:DAE]LEDTYP = GTYPGEN and
&                    [F:DAE]ACCDAT >= [L]FILTER_STD and [F:DAE]ACCDAT <= [L]FILTER_FID and
&                    [F:DAE]CUR = this.FLDCUR and [F:DAE]AMTCUR <> 0 and [F:HAE]CAT = 1 and
&                    [F:HAE]RVS <> 3 and [F:DAE]MTC = AVOID.ACHAR and [F:HAE]RVSORINUM = AVOID.ACHAR
&              Order By [F:DAE]ACCDAT Asc; [F:DAE]SNS Desc; [F:DAE]NUM Asc; [F:DAE]LIN Asc
Return
######################################################################################
######################################################################################
$DIMENSION_INITIALIZE

  Local Char LSEC(GLONCCE)
  Local Tinyint I, LINE_NUM

  Call GETCPY(this.FCY,"",0,"") From TRTX3CPT
  For I=1 To GNBDIE
    Call INISEC (LSEC, "FIFCV", I) From TRTX3CPT
    [L]LINE_NUM = fmet this.ADDLINE("C_DIECCE", [V]CST_ALASTPOS)
    If [L]LINE_NUM = [V]CST_ANOTDEFINED
      [L]ARET_VALUE = [V]CST_ANOTDEFINED
      Break
    Else
      this.C_DIECCE([L]LINE_NUM).DIE = GDIE([L]LINE_NUM)
      this.C_DIECCE([L]LINE_NUM).CCE = LSEC
    Endif
  Next

  [L]ARET_VALUE = GNBDIE

Return
######################################################################################
######################################################################################
$POST_FIFO
  Local Char    MESSA(250)
  Local Char    TZONE(10)(1..3)
  Local Char    TVALEUR(50)(1..3)
  Local Char    PCEAUTO(GLONGAU)
  Local Integer STAT

  If this.FIFONO <> "" and this.FLDPOS <> 2
    [L]STAT = 0
    [L]ARET_VALUE = [V]CST_AOK
    If this.TOTAMOH <> 0
      Raz GNUMPCE, GTYPPCE

      Call PARAM(this.FCY, "GAUFIFRC", [L]PCEAUTO) From ADOVAL
      If [L]PCEAUTO = ""
        [L]PCEAUTO = "FIFRC"
      Endif

      [L]TZONE(1) = 'REFINT'
      [L]TZONE(2) = 'ORIGIN'
      [L]TZONE(3) = 'ORICOD'
      [L]TVALEUR(1) = 'FIFO' - this.FIFONO
      [L]TVALEUR(2) = '2'
      [L]TVALEUR(3) = [L]PCEAUTO
      Call VALGRPPCE3([L]PCEAUTO, this.FIFONO, [L]STAT, [L]MESSA, [L]TZONE, [L]TVALEUR) From CPTAUTO
      If [L]STAT
        [L]ARET_VALUE = fmet this.ASETERROR("", [L]MESSA, [V]CST_AERROR)
      Else
        If [V]GNUMPCE <> AVOID.ACHAR & [V]GTYPPCE <> AVOID.ACHAR
          this.FLDPOS = 2
          this.FLDJOE = [V]GNUMPCE
          this.FLDJOETYP = [V]GTYPPCE
          [L]ARET_VALUE = fmet this.AUPDATE()
        Endif
      Endif
    Else
      this.FLDPOS = 2
      [L]ARET_VALUE = fmet this.AUPDATE()
    Endif
  Else
    If this.FLDPOS = 2
      [L]MESSA = mess(16,7708,1)
    Else
      [L]MESSA = mess(94,116,1)
    Endif
    [L]ARET_VALUE = fmet this.ASETERROR("", [L]MESSA, [V]CST_AERROR)
  Endif

Return
######################################################################################
######################################################################################
$DOCUMENT_REVERSAL

Local Integer WRET, STATCODE
Local Char    STATMES(255)

If (this.FIFONO = "")
  [L]ARET_VALUE = fmet this.ASETERROR("", mess(94,116,1), [V]CST_AERROR)
  Return
Endif

If (this.FLDPOS <> 2)
  [L]ARET_VALUE = fmet this.ASETERROR("", mess(20,7708,1), [V]CST_AERROR)
  Return
Endif

[L]WRET = fmet this.IS_LAST_FIFO()
If [L]WRET <> 1
  [L]ARET_VALUE = fmet this.ASETERROR("", mess(27,7708,1), [V]CST_AERROR)
  Return
Endif

[L]STATCODE = 0

If (this.FLDJOE <> AVOID.ACHAR & this.FLDJOETYP <> AVOID.ACHAR)
  Call REVERSE_DOC(this.FLDJOE, this.FLDJOETYP, [L]EXTSNS, [L]ACCDAT, [L]DESVCR, STATCODE, STATMES) From TRTDOCRVS
Endif

If STATCODE <> 0
  [L]ARET_VALUE = fmet this.ASETERROR("", STATMES, [V]CST_AERROR)
Else
  this.FLDPOS = 1
  this.FLDJOE = AVOID.ACHAR
  this.FLDJOETYP = AVOID.ACHAR
  [L]ARET_VALUE = fmet this.AUPDATE()
Endif

Return
######################################################################################
######################################################################################
$CLEAN_LINE_COLLECTION
Local Integer FIFCVD_SIZE : FIFCVD_SIZE = maxtab(this.FIFCVD)

If FIFCVD_SIZE > 0
    If dim(this.FIFCVD(1).AORDER) > 0
        For LINE_NUM = 1 To FIFCVD_SIZE
            [L]ARET_VALUE = fmet this.ADELLINE("FIFCVD", this.FIFCVD(LINE_NUM).AORDER)
        Next
    Else
        Raz this.FIFCVD
    Endif
Endif

this.TOTAMOH = 0

Return
######################################################################################
### check if FIFO for given BANK and DATE exists
######################################################################################
Funprog IS_FIFO_EXIST(PAYBAN, PAYDAT)
Value    Char PAYBAN
Value    Date PAYDAT
If clalev([F:FIFCV2])=0 : Local File FIFOCONVAR [FIFCV2] : Endif

Local Integer RET_VAL : [L]RET_VAL = 0 # 0 - not exists, 1 - exists

Filter [F:FIFCV2] Where [F:FIFCV2]FIFCOD = [L]PAYBAN and [F:FIFCV2]STARTDAT <= [L]PAYDAT and
&                       [F:FIFCV2]FINDAT >= [L]PAYDAT
Look [F:FIFCV2] First
If !fstat
  [L]RET_VAL = 1
Endif

Filter [F:FIFCV2]
LogicClose File  [FIFCV2]

End [L]RET_VAL
######################################################################################
### check if FIFO for given BANK and DATE is enabled to be used
######################################################################################
Funprog FLDFIFCP_CTL(PAYBAN, PAYDAT)
Value    Char PAYBAN
Value    Date PAYDAT

If !clalev([F:BANAF]) : Local File BANK       [BANAF] : Endif

Local Char CRITFIFO(250)
Local Integer RET_VAL

[L]RET_VAL = 0 # 0 - not enabled, 1 - enabled

Read [F:BANAF]BAN0 = PAYBAN
If !fstat & [F:BANAF]FLDFIFCP = 2 & [F:BANAF]FLDSDA <= PAYDAT
  [L]RET_VAL = 1
Else
  [L]RET_VAL = 0
Endif

LogicClose File  [F:BANAF]
End [L]RET_VAL
######################################################################################
### checks if the FIFO record is the last one for the bank and site given
### returns 0 if not and 1 if yes
######################################################################################
$IS_LAST_FIFO

If clalev([F:FIFCV2])=0 : Local File FIFOCONVAR [FIFCV2] : Endif

[L]ARET_VALUE = 0

Filter [F:FIFCV2] Where [F:FIFCV2]FIFCOD = this.FIFCOD
&              Order By [F:FIFCV2]FINDAT Desc
Read [F:FIFCV2] First
If !fstat
  If ([F:FIFCV2]FIFONO = this.FIFONO)
    [L]ARET_VALUE = 1
  Endif
Endif
Filter [F:FIFCV2]

LogicClose File  [FIFCV2]
Return
######################################################################################
### check if FIFO with ACC (account), CPY (company) and DATE exists
### return 0 if yes 1 if not
######################################################################################
Funprog DOES_FIFO_EXIST_FOR_ACC_CPY_DATE(L_ACC, L_CPY, L_DAT)
Value   Char    L_ACC
Value   Char    L_CPY
Value   Date    L_DAT

If clalev([F:FIFCV2])=0 : Local File FIFOCONVAR [FIFCV2] : Endif
Local Integer RET_VAL

Filter [F:FIFCV2] Where [F:FIFCV2]FLDACC = [L]L_ACC and [F:FIFCV2]STARTDAT <= [L]L_DAT and
&                       [F:FIFCV2]FINDAT >= [L]L_DAT and [L]L_CPY = [F:FIFCV2]CPY
Read [F:FIFCV2] First
If !fstat
  [L]RET_VAL = 0 # found
Else
  [L]RET_VAL = 1 # not found
Endif
Filter [F:FIFCV2]

LogicClose File  [F:FIFCV2]
End [L]RET_VAL
######################################################################################
### check if ACC number is assigned to BANK
### return 0 if yes 1 if not
######################################################################################
Funprog IS_ACC_ASSIGNED_TO_FIFO_BANK(ACC)
Value   Char    ACC

If clalev([F:BAN2])=0 : Local File BANK [BAN2] : Endif
Local Integer RET_VAL

Filter [F:BAN2] Where [F:BAN2]BANACC=[L]ACC and [F:BAN2]FLDFIFCP = 2
Read [F:BAN2]BAN0 First
If !fstat
  [L]RET_VAL = 0
Else
  [L]RET_VAL = 1
Endif
Filter [F:BAN2]

LogicClose File [F:BAN2]
End [L]RET_VAL
######################################################################################
### check if FIFO for [HAE]NUM exists
### return 0 if yes 1 if not
######################################################################################
Funprog DOES_FIFO_EXIST_FOR_HAE(L_NUM, L_CPY)
Value   Char    L_NUM
Value   Char    L_CPY

If clalev([F:DAE2])=0 : Local File GACCENTRYD [DAE2] : Endif
Local Integer RET_VAL : [L]RET_VAL = 1
Local Tinyint LTYPGEN, LTYPANA

Call SETMAINREF(L_CPY, [L]LTYPGEN, [L]LTYPANA) From CPTDIV

Filter [F:DAE2] Where [F:DAE2]NUM=[L]L_NUM and [F:DAE2]LEDTYP = [L]LTYPGEN
For [F:DAE2]
 If (func FIFOCONVAR_CSTD.IS_ACC_ASSIGNED_TO_FIFO_BANK([F:DAE2]ACC) = 0 and
&   func FIFOCONVAR_CSTD.DOES_FIFO_EXIST_FOR_ACC_CPY_DATE([F:DAE2]ACC, [F:DAE2]CPY, [F:DAE2]ACCDAT) = 0)
  [L]RET_VAL = 0
 Endif
Next
Filter [F:DAE2]

LogicClose File [DAE2]
End [L]RET_VAL
######################################################################################

