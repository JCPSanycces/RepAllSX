#<AdxTL>@(#)1.0.0.0 $Revision$
End

#---------------------------------------------------#
# Search errors in class
#---------------------------------------------------#

Subprog FIND_ERROR_CLASS(WREP,REP,UPD)
Variable Instance WREP Using OBJECT
Variable Instance REP       Using C_AREPENT
Variable Instance UPD(1..)  Using C_ADELTA
Local Uuident UIF , UID
Local Char    CHAINE(250)
UIF = NullUuid
CHAINE = "WREP."+REP.ICL+".AUUID"
If evalue("dim("+CHAINE+")")>0
 UID = evalue(CHAINE)
Else
 UID = evalue("WREP.AUUID")
Endif
INS = "WREP"
Gosub SYSTEM_INSTANCES From ASYRUID
Call FIND_ERROR_COLLECTION(WREP,REP,UPD,UIF,UID,INS,NAMSYS,NBRSYS)
End

#--------------------------------------------------------------------------#
Subprog FIND_ERROR_COLLECTION(WREP,REP,UPD,UIF,UID,INS,NAMSYS,NBRSYS)
Variable Instance WREP Using OBJECT
Variable Instance REP       Using C_AREPENT
Variable Instance UPD(1..)  Using C_ADELTA
Value Uuident UIF , UID
Value Char    INS
Value Char    NAMSYS()(1..)
Value Integer NBRSYS
Local Integer I , J , K , E , M , N , NBRINS
Local Integer TBORD(1..) , TBPOS(1..) , NBPOS , ONE
Local Char    PRO(30)
Local Char WINS(250)

M = evalue('maxtab('+INS+')')
If M>0
 Call TYPSYR(REP,INS,ONE,PRO) From ASYRDELSRV
 If ONE : # instance 1,1
  If evalue(INS)<>null & !find(evalue(INS+".ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL)
   Call INSTANCE_FIND_ERROR(WREP,REP,UPD,UIF,UID,INS,NBRINS,NAMSYS,NBRSYS)
  Endif
 Else
  NBRINS = 0
  For N=1 To M
   WINS = INS+'('+num$(N)+')'
   If !find(evalue(WINS+".ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL)
    Gosub INSTANCE_ERROR
   Endif
  Next N
  If NBRINS=1 & PRO<>""
   NBRINS += 1
  Endif
  If NBRINS>1
   # Send all instances in order
   Sorta NBPOS TBORD,TBPOS Order By TBORD(indice+1),TBPOS(indice+1)
   UIF = UID
   For N=1 To NBPOS
    WINS = INS+'('+num$(TBPOS(N))+')'
    UID = evalue(WINS+".AUUID")
    Call INSTANCE_FIND_ERROR(WREP,REP,UPD,UIF,UID,WINS,NBRINS,NAMSYS,NBRSYS)
   Next N
  Elsif NBRINS=1
   UIF = UID
   For N=1 To M
    WINS = INS+'('+num$(N)+')'
    If !find(evalue(WINS+".ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL)
     UID = evalue(WINS+".AUUID")
     Call INSTANCE_FIND_ERROR(WREP,REP,UPD,UIF,UID,WINS,NBRINS,NAMSYS,NBRSYS)
    Endif
   Next N
  Endif
 Endif
Endif
End

#-----------------------------------------------------------#
# How many instances in error in this collection
#-----------------------------------------------------------#

$INSTANCE_ERROR
NBPOS += 1
TBPOS(NBPOS) = N
TBORD(NBPOS) = evalue(WINS+".AORDER")
For E=1 To evalue("maxtab("+WINS+".AERROR)")
 If evalue(WINS+".AERROR")<>null
  NBRINS += 1 : Break
 Endif
Next E
Return

#------------------------------------------------------------------------------#
Subprog INSTANCE_FIND_ERROR(WREP,REP,UPD,UIF,UID,INS,NBRINS,NAMSYS,NBRSYS)
Variable Instance WREP Using OBJECT
Variable Instance REP       Using C_AREPENT
Variable Instance UPD(1..)  Using C_ADELTA
Value Uuident UIF , UID
Value Char    INS
Value Integer NBRINS
Value Char    NAMSYS()(1..)
Value Integer NBRSYS
Local Integer I , P , K
Local Char    WPRO(30)
If evalue(INS)=null
 End
Endif
Call SET_ERROR(WREP,REP,UPD,UIF,UID,INS,NBRINS,NAMSYS,NBRSYS)
For P=1 To evalue(INS+'.Objectnbs')
 WPRO = evalue(INS+'.Objectvar('+num$(P)+')')
 K = evalue('type('+INS+'.'+WPRO+')')
 If K=524 & !find(WPRO,NAMSYS(1..NBRSYS))
  Call FIND_ERROR_COLLECTION(WREP,REP,UPD,UIF,UID,INS+'.'+WPRO,NAMSYS,NBRSYS)
 Endif
Next P
End

#------------------------------------------------------------------------------#
Subprog SET_ERROR(WREP,REP,UPD,UIF,UID,INS,NBRINS,NAMSYS,NBRSYS)
Variable Instance WREP Using OBJECT
Variable Instance REP       Using C_AREPENT
Variable Instance UPD(1..)  Using C_ADELTA
Value Uuident UIF , UID
Value Char    INS
Value Integer NBRINS
Value Char    NAMSYS()(1..)
Value Integer NBRSYS
Local Integer I , J , K , ONE
Local Integer CATCOL , WORD , NBRERR , WORD , CATPRO
Local Char    CHAINE(250) , COLSYR(30) , WINS(250) , WMES(250) , WPRO(50) :#SAM 119601
Local Clbfile CLOB
NBRERR = 0
If NBRINS>1
 WORD = -1
Else
 WORD = evalue(INS+".AORDER")
Endif
If evalue("maxtab("+INS+".AERROR)")>0
 For I=1 To evalue("maxtab("+INS+".AERROR)")
  WINS = INS+".AERROR("+num$(I)+")"
  If evalue(WINS)<>null
   NBRERR += 1
   Call COLSYR(REP,INS,COLSYR,ONE) From ASYRDELSRV
   Call CATPRO(REP,WINS,evalue(WINS+".PRO"),WPRO,CATPRO) From ASYRDELSRV
   If WPRO=""
    WPRO = evalue(WINS+".PRO")
    CATPRO = 1
   Endif
   If evalue(WINS+".DEL")=2
    WMES = ""
   Else
    WMES = evalue(WINS+".MES")
   Endif
   If GTRASYR : Call TRACE("error="+num$(evalue(WINS+".STA"))-"pro="+WPRO-"mes="+WMES) From ASYRCOM : Endif
   Call MAJ_ERROR(UPD,CATPRO,0,UIF,UID,WORD,COLSYR,WPRO,WMES,evalue(WINS+".CREDATTIM"),evalue(WINS+".STA"),evalue(WINS+".NUM"))
&  From  ASYRDELSYS
  Endif
 Next I
Endif
If NBRINS>1 & NBRERR=0
 Call COLSYR(REP,INS,COLSYR,ONE) From ASYRDELSRV
 Call CATCOL(REP,COLSYR,CATCOL) From ASYRDELSRV
 Call MAJ_FIELD(UPD,CATCOL,0,UIF,UID,WORD,COLSYR,"",7,CLOB) From  ASYRDELSYS
Endif
If NBRERR>0 or NBRINS>1
 Call UPDATE_PARENT(WREP,REP,UPD,UIF) From ASYRDELSRV
Endif
End

#---------------------------------------------------------------------------------#
$TRACE_ERREUR
Local Char    WCHAINE(250)
Local Integer I , J
Call TRACE("asyredt-send-errors"-"MAXTAB(upd)="+num$(maxtab(UPD))) From ASYRCOM
For I=1 To maxtab(UPD)
 WCHAINE = "col="+UPD(I).COL-"pro="+UPD(I).PRO-"ind="+num$(UPD(I).IND)-"uuid="+num$(UPD(I).UID)-"uuif="+num$(UPD(I).UIDPAR)
 WCHAINE -= "cat="+num$(UPD(I).CAT)
 If UPD(I).CHR<>null : WCHAINE -= "value="+func ASYRSUB.AGETCHR(UPD(I).CHR) : Endif
 Call TRACE(WCHAINE) From ASYRCOM
 For J=1 To maxtab(UPD(I).ATT)
  Call TRACE("att"-UPD(I).ATT(J).COD-"value="+UPD(I).ATT(J).ATT) From ASYRCOM
 Next J
 For J=1 To maxtab(UPD(I).ERR)
  Call TRACE("err"-UPD(I).ERR(J).MES-"sta="+num$(UPD(I).ERR(J).STA)-"num="+num$(UPD(I).ERR(J).NUM)) From ASYRCOM
 Next J
Next I
Call TRACE("end errors") From ASYRCOM
Return

