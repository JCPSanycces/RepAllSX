#<AdxTL>@(#)0.0.0.0 $Revision$

#Handling all events for EMPLOJNT_CSTD

$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AINIT"                        : Gosub AINIT
      When "AINSERT_CONTROL_BEFORE"       : Gosub AINSERT_CONTROL_BEFORE
    Endcase
Endcase
Return


$AINIT
Return

$AINSERT_CONTROL_BEFORE
#Set the line number
Gosub SET_LIGNUM
Return

$SET_LIGNUM
If this.NUMLIG <> 0 : Return: Endif
Local Integer MAXLIGNUM
Local File EMPLOJNT [JNT2]
Filter [JNT2] Where REFNUM = this.REFNUM
For [JNT2]
  If [F:JNT2]NUMLIG > MAXLIGNUM
    MAXLIGNUM = [F:JNT2]NUMLIG
  Endif
Next

MAXLIGNUM+=1
this.NUMLIG = MAXLIGNUM
LogicClose File [JNT2]
Return

