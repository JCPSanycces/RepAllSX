#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque BOD1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_CTNWEU
Return

$ON_LEVSET
Onevent BEFORE_INPUT Call AS_LEVSET(zc) From W2BOD1
Onevent CONTROL Call C_LEVSET(zc) From W2BOD1
Onevent INIT_AREA Call D_LEVSET(zc) From W2BOD1
Return

Subprog D_LEVSET(VALEUR)
Variable Integer VALEUR
If varinit([M]LEVSET,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_LEVSET(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(2394) From COMBOS
## Action PASECCUSE2
Call PASECCUSE2 From ECCLIB
If mkstat=2
 [M]LEVSET(INDIC) = VALEUR
 Affzo LEVSET(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action STD
 Call AS_LEVSET(VALEUR) From SUBBOD
 If mkstat=2
  [M]LEVSET(INDIC) = VALEUR
  Affzo LEVSET(INDIC) : mkstat = 2
 Endif
 If VALEUR<1 | GMENLOC(VALEUR)=1
  VALEUR = find(0,GMENLOC(1..len(mess(0,2394,1))))
 Endif
 If !mkstat
  Discombo 0 From LEVSET(INDIC)
  If sum(GMENLOC)<>0
   Gosub COMBOS From COMBOS
   For WI=1 to WN : Discombo WCOMBO(WI) From LEVSET(INDIC) : Next WI
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog C_LEVSET(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
## Action STD
Call C_LEVSET(VALEUR) From SUBBOD
If mkstat : GERR = 1 : GZONE = "LEVSET" : GZNUM = 42168 : Endif
Gosub _AFF
End

$ON_ITMTOLPOS
Onevent BEFORE_INPUT Call AS_ITMTOLPOS(zc) From W2BOD1
Return

Subprog AS_ITMTOLPOS(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action PASECCUSE2
Call PASECCUSE2 From ECCLIB
If mkstat=2
 [M]ITMTOLPOS(INDIC) = VALEUR
 Affzo ITMTOLPOS(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action STD
 Call AS_ITMTOLPOS(VALEUR) From SUBBOD
 If mkstat=2
  [M]ITMTOLPOS(INDIC) = VALEUR
  Affzo ITMTOLPOS(INDIC) : mkstat = 2
 Endif
Endif
Gosub _AFF
End

$ON_ITMTOLNEG
Onevent BEFORE_INPUT Call AS_ITMTOLNEG(zc) From W2BOD1
Return

Subprog AS_ITMTOLNEG(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action PASECCUSE2
Call PASECCUSE2 From ECCLIB
If mkstat=2
 [M]ITMTOLNEG(INDIC) = VALEUR
 Affzo ITMTOLNEG(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action STD
 Call AS_ITMTOLNEG(VALEUR) From SUBBOD
 If mkstat=2
  [M]ITMTOLNEG(INDIC) = VALEUR
  Affzo ITMTOLNEG(INDIC) : mkstat = 2
 Endif
Endif
Gosub _AFF
End

$CHG_STY
Return


