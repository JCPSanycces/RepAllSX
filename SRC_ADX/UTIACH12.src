#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################
# UTIACH12      Utilitaire de récupération du bug 36643     Module ACHAT #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Vérifier et remettre si nécessaire le bon coefficient de conversion  #
#   entre l'unité de réception et l'unité d'achat [F:PTD]UOMPUUCOE puis  #
#   recalculer le prix unitaire net en UA [F:PTD]NETPRIPUU sur les       #
#   lignes de réception non facturées.                                   #
##########################################################################

Call MAJ_UTIACH12
End

Subprog MAJ_UTIACH12
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH12 - Récup. Bug 36643") From SAIDOS
If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH12 : Utilitaire de resynchro des coef UC-UA et prix UA sur lignes RCP") From LECFIC
  Call EXE_UTIACH12(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End

Subprog EXE_UTIACH12(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Char     WMSG(90), CRITERE(150)
Local Char     CLE2(GLONBPS), CLE3(GLONITM), CLE4(GLONPTH)
Local Integer COMPTEUR, STOP
Local Integer  NBENR, NBCOR, CLE1, CLE5
Local Decimal  WUOMPUUCOE, WNETPRIPUU
#-----
Call ECR_TRACE("UTIACH12 : Début traitement du dossier "+DOSSIER,0) From GESECRAN
#----- Ouverture du fichier des lignes de réception -----#
If !clalev([F:PTD])  Local File =DOSSIER+".PRECEIPTD"  [PTD] : Endif
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, CLE2, CLE3, CLE4, CLE5, NBENR, NBCOR, STOP
#-----
$BOUCLE_PTD
If STOP=1
  STOP=2 : CRITERE ='LININVFLG='+num$(CLE1)+' & BPSINV="'+CLE2+'"'+' & ITMREF="'+CLE3+'"'
           CRITERE-='& PTHNUM="'+CLE4+'"'+' & PTDLIN>'+num$(CLE5)
Elsif STOP=2
  STOP=3 : CRITERE ='LININVFLG='+num$(CLE1)+' & BPSINV="'+CLE2+'"'+' & ITMREF="'+CLE3+'"'
           CRITERE-='& PTHNUM>"'+CLE4+'"'
Elsif STOP=3
  STOP=4 : CRITERE ='LININVFLG='+num$(CLE1)+' & BPSINV="'+CLE2+'"'+' & ITMREF>"'+CLE3+'"'
Elsif STOP=4
  STOP=5 : CRITERE ='LININVFLG='+num$(CLE1)+' & BPSINV>"'+CLE2+'"'
Elsif STOP=5
  STOP=0 : CRITERE ='LININVFLG>'+num$(CLE1)
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [PTD]
  For [PTD] PTD1 Where evalue(CRITERE) & LININVFLG<2
    COMPTEUR+=1
    NBENR+=1
    Call PCAL_QTY([F:PTD]QTYUOM,[F:PTD]UOM,GBIDD1,[F:PTD]PUU,
&                 [F:PTD]ITMREF,[F:PTD]BPSNUM,1,[L]WUOMPUUCOE) From TRTACHQTE1
    If [F:PTD]UOMPUUCOE<>[L]WUOMPUUCOE  Gosub MAJ_PTD : Endif
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:PTD]LININVFLG : CLE2=[F:PTD]BPSINV : CLE3=[F:PTD]ITMREF
      CLE4=[F:PTD]PTHNUM    : CLE5=[F:PTD]PTDLIN
      STOP=1 : Break
    Endif
  Next
Commit
If STOP  Goto BOUCLE_PTD : Endif
#----- Fin du traitement -----#
$FIN_UTIACH12
WMSG ="UTIACH12 : Nbre d'enregistrements traités :"-num$(NBENR)
WMSG+=" dont corrigés :"-num$(NBCOR)
Call ECR_TRACE(WMSG,0) From GESECRAN
Close Local File [PTD]
End

$MAJ_PTD
Readlock [PTD] Curr
If fstat
  Call ECR_TRACE("File PRECEIPTD"-[F:PTD]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
Else
  [L]WNETPRIPUU=arr([F:PTD]NETPRI/[L]WUOMPUUCOE,10^-GDECPRI)
  WMSG ="Ligne RCP"-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)-"(Coef"-[F:PTD]UOM+"-"+[F:PTD]PUU-":"
  WMSG-=num$([F:PTD]UOMPUUCOE)-"-->"-num$([L]WUOMPUUCOE)+","
  WMSG-="Prix UA :"-num$([F:PTD]NETPRIPUU)-"-->"-num$([L]WNETPRIPUU)
  [F:PTD]UOMPUUCOE=[L]WUOMPUUCOE
  [F:PTD]NETPRIPUU=[L]WNETPRIPUU
  Rewrite [PTD]
  If fstat
    Call ECR_TRACE("Erreur réécriture"-[F:PTD]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
  Else
    Call ECR_TRACE(WMSG,0) From GESECRAN
    NBCOR+=1
  Endif
Endif
Return
