#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
######################################################################################
$ACTION

Case ACTION
  When "OUVRE"  : Gosub OUVRE
  When "LIENS"  : Gosub LIENS
Endcase

Return
######################################################################################
######################################################################################
$OUVRE

If !clalev ([F:DVPP]) : Local File DCLVATPORP [DVPP] : Endif
If !clalev ([F:CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev ([F:GCM])  : Local File GACM       [GCM]  : Endif

Local Integer I

Return
######################################################################################
######################################################################################
$LIENS

If [F:CPY]CPY <> [F:DVPP]CPY
  Read [F:CPY]CPY0 = [F:DVPP]CPY
  If fstat : Raz [F:CPY] : Endif
Endif

[M:DVPP0]CUR          = [F:CPY]ACCCUR

Affzo [M:DVPP0]CUR

Return
######################################################################################
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

If [F:CPY]CPY <> VALEUR
  Read [F:CPY]CPY0 = VALEUR
  If fstat : Raz [F:CPY] : Endif
Endif

[M:DVPP1]HQRLOC       = [F:CPY]PORHQR
[M:DVPP0]CUR          = [F:CPY]ACCCUR

Affzo [M:DVPP0]CUR
Affzo [M:DVPP1]

End
######################################################################################
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

If func AFNC.PARAM("PORVAT",VALEUR)<>"2"
  mkstat = 2
  GMESSAGE = func AFNC.MES2(mess(00218,00125,1), "PORVAT", mess(00001,00001,1))
Endif

End
######################################################################################
######################################################################################
Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR

If [F:CPY]CPY <> [M:DVPP0]CPY
  Read [F:CPY]CPY0 = [M:DVPP0]CPY
  If fstat : Raz [F:CPY] : Endif
Endif

If [F:GCM]GCM <> [F:CPY]ACM
  Read [F:GCM]GCM0 = [F:CPY]ACM
  If fstat : Raz [F:GCM] : Endif
Endif

If [F:GCM]CUR(VALEUR-1) <> "EUR"
  mkstat = 2
  GMESSAGE = [F:GCM]CUR(VALEUR-1) - mess(90,103,1)
Endif

End
######################################################################################
######################################################################################
Subprog AS_AN1LOC(VALEUR)
Variable Integer VALEUR

For I = 1 To 3
  If I = [M:DVPP1]HQRLOC | I = [M:DVPP1]AN2LOC
    GMENLOC(I) = 1
  Else
    GMENLOC(I) = 0
  Endif
Next

GMENLOC(4) = 0 : # Non applicable OK

End
######################################################################################
######################################################################################
Subprog AS_AN2LOC(VALEUR)
Variable Integer VALEUR

For I = 1 To 3
  If I = [M:DVPP1]HQRLOC | I = [M:DVPP1]AN1LOC
    GMENLOC(I) = 1
  Else
    GMENLOC(I) = 0
  Endif
Next

GMENLOC(4) = 0 : # Non applicable OK

End
######################################################################################
######################################################################################
Subprog C_YEA(VALEUR)
Variable Decimal VALEUR

If VALEUR<1600 : mkstat = 1 : End : Endif

End
######################################################################################
######################################################################################
