#<AdxTL>@(#)6.0.0.0 $Revision$
######################################################################################
## Xtend: Génération fiche Messages Xtend
#  Version 0001
######################################################################################
#    XMLGEN 
######################################################################################
Subprog XMLGEN(DOSORG, FCYORG, TIMSTP, OPTION, ELTCOD,RET)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char FCYORG        #     Code site Xtend
Value Char TIMSTP        #     Référence time stamp 20061012093014
Value Char OPTION()(1..) #     Option 
                         #       'TRADET'=Trace détaillée
Value Char ELTCOD        #     Code élément
Variable Integer RET     #     1 Ok; 0: Ko ; 2: avertissementLocal Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Integer WI, WNBLANFCY, WNBREC
Local Integer TRADETFLG   : TRADETFLG   = find("TRADET",OPTION)
Local Char WSTR1(250), WMSG(250)
Local Char U_TXTTOHEX(255),U_HEXTOTXT(255)

RET=1

Call TITOBJ("AYM","", WSTR1) From CONTOBJ
Call ECR_TRACE(mess(38,7900,1)-WSTR1,0) From GESECRAN : # Validation de l'écran

Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS

If DOSORG=nomap 
 Local File AYTMES    [AYM1] 
 Local File ATEXTE    [ATX1] 
 Local File APLSTD    [AST1] 
 Local File AYTFCY    [AYS1] 
 Local File ATEXTRA   [AXX1]
Else 
 Local File =[L]DOSORG+".AYTMES"     [AYM1] 
 Local File =[L]DOSORG+".ATEXTE"     [ATX1] 
 Local File =[L]DOSORG+".APLSTD"     [AST1] 
 Local File =[L]DOSORG+".AYTFCY"     [AYS1] 
 Local File =[L]DOSORG+".ATEXTRA"    [AXX1] 
Endif 
If adxmother=nomap
 Local File APLSTD    [ASTM] 
Else
 Local File =adxmother+".APLSTD"     [ASTM] 
Endif

Default File "[AYM1],[ATX1]"

#
Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_FCYCOD=FCYORG : XT_TIMSTP=TIMSTP
XT_XMLID="MES"
Gosub XMLF_INI2 From AYTGEN : If XT_RET=0 : RET=0 : Goto FFINALLY : Endif 

#   Recherche des langues
Read [AYS1]AYS0 = [L]FCYORG
If fstat<>0     # <=> non trouvé
  Call ECR_TRACE(mess(19,7900,1)-[L]FCYORG,1) From GESECRAN
  RET=0
  Goto FFINALLY
Endif
#
Local Char WTABLAN(GLONLAN) (1..dim([F:AYS1]LANADS))    # Tableau des langues Xtend
Local Char WLANDEF(GLONLAN) : WLANDEF=GLANDEF           # Langue par défaut
For WI=0 To [F:AYS1]LANNBR-1
 If !find([F:AYS1]LANCOD(WI),WTABLAN)
    WNBLANFCY+=1
    WTABLAN(WNBLANFCY) = [F:AYS1]LANCOD(WI)
    If [F:AYS1]LANDEF=2 : WLANDEF=[F:AYS1]LANADS : Endif
 Endif
Next
#
XT_TY="ELMTS"  : XT_ID=XT_XMLID                                            : Gosub XMLF_ADD From AYTGEN
#
For [AYM1]AYM0 Where FCYCOD=FCYORG
 WNBREC+=1
 If TRADETFLG : Call ECR_TRACE(mess(12,7910,1)-":"-[F]MESCOD,0) From GESECRAN : Endif
 #
 XT_TY="ELMT"  : XT_ID=[F]MESCOD    
 Call LECTEXTRA(XT_VAL,"AYTMES","INTIT",[F]FCYCOD,[F]MESCOD) From AYTUTIA  : Gosub XMLF_ADD From AYTGEN 
 
 # Recherche message dans le dossier en-cours puis si besoin le dossier mère puis la langue par défaut
 XT_TY="TAB"   : XT_ID="LANNBR"                                         : Gosub XMLF_ADD From AYTGEN
 For WI=1 To WNBLANFCY
    WMSG="???"
    If [F:AYM1]LANNUM(0)<> 0
        Read [AST1]CLE=[F:AYM1]LANCHP;[F:AYM1]LANNUM(0);WTABLAN(WI)      # Dossier en-cours
        If fstat=0
             WMSG=[F:AST1]LANMES
             If [F:AYM1]LANNUM(1)<> 0         # suite
                 Read [AST1]CLE=[F:AYM1]LANCHP;[F:AYM1]LANNUM(1);WTABLAN(WI) 
                 If fstat=0 : WMSG+=[F:AST1]LANMES : Endif
             Endif
        Else
            Read [ASTM]CLE=[F:AYM1]LANCHP;[F:AYM1]LANNUM(0);WTABLAN(WI)       # Dossier mère
            If fstat=0
                 WMSG=[F:ASTM]LANMES
                 If [F:AYM1]LANNUM(1)<> 0         # suite
                     Read [ASTM]CLE=[F:AYM1]LANCHP;[F:AYM1]LANNUM(1);WTABLAN(WI) 
                     If fstat=0 : WMSG+=[F:ASTM]LANMES : Endif
                 Endif
            Else
                Read [AST1]CLE=[F:AYM1]LANCHP;[F:AYM1]LANNUM(0);WLANDEF            # Dossier en-cours - WLANDEF
                If fstat=0
                     WMSG=[F:AST1]LANMES
                     If [F:AYM1]LANNUM(1)<> 0         # suite
                         Read [AST1]CLE=[F:AYM1]LANCHP;[F:AYM1]LANNUM(1);WLANDEF    
                         If fstat=0 : WMSG+=[F:AST1]LANMES : Endif
                     Endif
                Else
                    Read [ASTM]CLE=[F:AYM1]LANCHP;[F:AYM1]LANNUM(0);WLANDEF      # Dossier mère - WLANDEF            
                    If fstat=0
                         WMSG=[F:ASTM]LANMES
                         If [F:AYM1]LANNUM(1)<> 0         # suite
                             Read [ASTM]CLE=[F:AYM1]LANCHP;[F:AYM1]LANNUM(1);WLANDEF      
                             If fstat=0 : WMSG+=[F:ASTM]LANMES : Endif
                         Endif
                    Else
                        WSTR=mess(153,7900,1)-[F]MESCOD-"("-[F:AYM1]LANCHP-"/"-[F:AYM1]LANNUM(0)-"/"-WTABLAN(WI)-")"
                        Call ECR_TRACE(WSTR,1) From GESECRAN : RET=2
                    Endif            
                Endif
            Endif        
        Endif
    Else
        WSTR=mess(152,7900,1)-[F]MESCOD-"("-[F:AYM1]LANCHP-")"
        Call ECR_TRACE(WSTR,1) From GESECRAN : RET=2
    Endif
    #
   XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="LANCOD"     : XT_VAL=WTABLAN(WI)                    : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="LANFMT" 
        u_HEXTOTXT=WMSG : Gosub U_TXTTOHEX From SUBAPSUTI
                                                    XT_VAL=U_TXTTOHEX        : Gosub XMLF_ADD From AYTGEN    
 Next    # Langue
Next
#

$FFINALLY
Gosub XMLF_CL  From AYTGEN
Close Local File [AYM1],[ATX1],[AYS1],[AST1],[AXX1]
Call ECR_TRACE(mess(146,7900,1)-num$(WNBREC),0) From GESECRAN
End

