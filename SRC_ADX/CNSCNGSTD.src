######################################################################################

Raz GTUNCPT
Local Char PARAM(10)(1..7)

Call GCONSULT("CNG","",PARAM) From GCONSULT
End
#######################################
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "AV_AFFICHE" : Gosub AV_AFFICHE
 When "AV_MAGNETO" : Gosub AV_MAGNETO
 When "AP_MAGNETO" : Gosub AP_MAGNETO
 When "EXEBOUT"    : Gosub EXEBOUT
 When Default
Endcase

Return
#######################################
$AV_MAGNETO
#Filter [F] Where REFNUM=[M:CNG1]REFNUM
#NBCMP = 2
Return
#######################################
$AP_MAGNETO
#Filter [F] Where REFNUM=[M:CNG1]REFNUM
Call AM_REFNUM([M:CNG1]REFNUM)
Call AS_DATPYR([M:CNG1]DATPYR)
Return
#######################################
$OUVRE

If !clalev([F:CNG])  : Local File CNGCPY    [CNG]  : Endif
If !clalev([F:DCG])  : Local File DEMCONGE  [DCG]  : Endif
#MIPEA - 2016-12-21 - X3-11945- START
#If !clalev([F:CTR])  : Local File EMPLOCTR  [CTR]  : Endif
If !clalev([F:HRCTR])  : Local File EMPLOCTR  [HRCTR]  : Endif
#MIPEA - 2016-12-21 - X3-11945- END
If !clalev([F:TIM])  : Local File TIMCOD    [TIM]  : Endif
#MIPEA - 2016-12-21 - X3-11945- START
If !clalev([F:HRPEOD])  : Local File HRPEODET    [HRPEOD]  : Endif
#If !clalev([F:PEO])  : Local File PERIOD    [PEO]  : Endif
#MIPEA - 2016-12-21 - X3-11945- END
If !clalev([F:FCY])  : Local File FACILITY  [FCY]  : Endif
If !clalev([F:HSP])  : Local File HISTOPAYE [HSP]  : Endif
If !clalev([F:TIP])  : Local File TIMEMP    [TIP]  : Endif
If !clalev([F:TIG])  : Local File TIMREGUL  [TIG]  : Endif
If !clalev([F:VEP])  : Local File VALEMP    [VEP]  : Endif
# FQ88082 - SEGAY 23/04/13 test ACS de TIM
If !clalev([F:ACC1]) : Local File ACCES     [ACC1] :Endif
# END FQ88082

#JASMI - 2014-09-22 - US2983 - START
#MIPEA - 2016-12-21 - X3-11945- START
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-21 - X3-11945- END
  If !clalev([F:CNE])  : Local File CNGEMP    [CNE]  : Endif
Endif
#JASMI - 2014-09-22 - US2983 - END

Global Char    SAVCRIT   (20)(1..7)
Global Char    SAVCRIT1  (250)

Local Char     FINTIM (GLONTPS)
Local Shortint FINYEA
#MIPEA - 2016-12-21 - X3-11945- START
Local Char     FINCTR (GLONHRCTR)
#Local Char     FINCTR (GLONCTR)
#MIPEA - 2016-12-21 - X3-11945- END
Local Char CRITEREX  (250)
Local Char CRITEREY  (250)

#####
Local Char CRITERE   (250)
Local Char CRITERE0  (250)
Local Char CRITERE1  (250)
Local Char CRITERE2  (250)
Local Char CRITEREN  (250)
Local Char CRITEREN0 (250)
Local Char CRITEREN1 (250)
Local Char OLDCRIT   (250)
Local Char OLDCRIT0  (250)
Local Char OLDCRIT1  (250)
Local Char OLDCRIT2  (250)

#57273
Local Date     CRITDAT
Local Date     OLDDAT
#MIPEA - 2016-12-21 - X3-11945- START
Local Char     SAVCTR(GLONHRCTR) , SAVTIM(GLONTPS)
#Local Char     SAVCTR(GLONCTR) , SAVTIM(GLONTPS)
#MIPEA - 2016-12-21 - X3-11945- END
Local Integer  SAVYEA
Local Date     SAVDTC
#
Local  Shortint I , IND1 , IND2 , IND3 , IND4

#
Local Integer  NBCUM , NBPRJ , INTE , ENR , STEP_NOL
Local Shortint RUPT , TFULL , EXEFULL
Local Char     FRUPT (GLONAVA) , FRUPT2 (GLONAVA)

Local Integer WYEA(0..10)
Local Decimal WACQ(0..10), WPRI(0..10), WVLD(0..10), WATT(0..10), WSLD(0..10)
Local Decimal WSLDMIN

# FQ76178 US1931 - SEGAY 18/09/13
Local Char WCPA(GLONTPS),WCPE(GLONTPS)
Local Integer WOK
Call PARAM("","CPA",WCPA) From ADOVAL
Call PARAM("","CPE",WCPE) From ADOVAL
# END FQ76178
#MIPEA - 2016-12-23 - X3-11945- START
If dim(GCURLEG)>0 :  Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif
#MIPEA - 2016-12-23 - X3-11945- END
Return
#######################################
$LECTURE

If [M:CNG1]REFNUM = "" | [M:CNG1]DATPYR = [00/00/0000] : NBLU=0 : Return : Endif

Gosub CREATE_FILTER
Gosub CHG_PAGE

If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CNG2] : Endif
Gosub TABLE_LINK

Gosub SORT_FILTER

nolign = 0

Raz IND1 , IND2 , IND3 , IND4 , SAVCTR , SAVDTC , SAVYEA , SAVTIM
[M:CNG1]DATSEL = [M:CNG1]DATPYR

For [LNK]
 # FQ76178 US1931 - SEGAY 18/09/13 - On fait le test sur TYPCP pour CPE et CPA idem dans CNSCNGSTD, CNSCCSTD et GETLSTCCG de PORTPS
  [L]WOK = 1
#MIPEA - 2016-12-22 - X3-11945- START
  Call VERIF_TYPCP([F:HRCTR]ETRFCY,[L]WCPA,[L]WCPE,[F:CNG]TIM,[L]WOK) From CNSCNGSTD
#  Call VERIF_TYPCP([F:CTR]ETRFCY,[L]WCPA,[L]WCPE,[F:CNG]TIM,[L]WOK) From CNSCNGSTD
#MIPEA - 2016-12-22 - X3-11945- END
  If [L]WOK
# END FQ76178
    TFULL  = 1

    #On ne garde que les années concernée par la date de sélection
    If !evalue(CRITERE0):  TFULL=2 : Endif

    If TFULL <> 2

       # saut de ligne à chaque contrat
     STEP_NOL = 1
#MIPEA - 2016-12-22 - X3-11945- START
     If ( [F:HRCTR]CTRNUM <> SAVCTR & SAVCTR <> "" )
&     | ( [F:HRCTR]CTRNUM =  SAVCTR & [F:HRCTR]CTRDAT <> SAVDTC )
#     If ( [F:CTR]CTRNUM <> SAVCTR & SAVCTR <> "" )
#&     | ( [F:CTR]CTRNUM =  SAVCTR & [F:CTR]CTRDAT <> SAVDTC )
#MIPEA - 2016-12-22 - X3-11945- END
        STEP_NOL = 2
     Endif

     SAVNOL = NOL
     If CHGPAG > 0                                   : # Recherche(1),Suite(2),Raffraichissement(3)
      If NOL >= MAXLIG-2 : SUITE=2 : TFULL = 2 : Endif
      NOL    += STEP_NOL
#MIPEA - 2016-12-22 - X3-11945- START
      If NOL=0
       DEBCTR = [F:HRCTR]CTRNUM
       DEBYEA = [F:CNG]YEA
       DEBTIM = [F:CNG]TIM
      Endif
      FINCTR = [F:HRCTR]CTRNUM
      FINYEA = [F:CNG]YEA
      FINTIM = [F:CNG]TIM
     Else
      If NOL <= 0 : RETOUR=2 : TFULL = 2 : Endif
      NOL    -= STEP_NOL
      If NOL=MAXLIG-1
       FINCTR = [F:HRCTR]CTRNUM
       FINYEA = [F:CNG]YEA
       FINTIM = [F:CNG]TIM
      Endif
      DEBCTR = [F:HRCTR]CTRNUM
      DEBYEA = [F:CNG]YEA
      DEBTIM = [F:CNG]TIM
     Endif
#      If NOL=0
#       DEBCTR = [F:CTR]CTRNUM
#       DEBYEA = [F:CNG]YEA
#       DEBTIM = [F:CNG]TIM
#      Endif
#      FINCTR = [F:CTR]CTRNUM
#      FINYEA = [F:CNG]YEA
#      FINTIM = [F:CNG]TIM
#     Else
#      If NOL <= 0 : RETOUR=2 : TFULL = 2 : Endif
#      NOL    -= STEP_NOL
#      If NOL=MAXLIG-1
#       FINCTR = [F:CTR]CTRNUM
#       FINYEA = [F:CNG]YEA
#       FINTIM = [F:CNG]TIM
#      Endif
#      DEBCTR = [F:CTR]CTRNUM
#      DEBYEA = [F:CNG]YEA
#      DEBTIM = [F:CNG]TIM
#     Endif
#MIPEA - 2016-12-22 - X3-11945- END
     nolign=NOL+1

     If TFULL <> 2
      Gosub LINEFEED
     Endif
     # SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
     If [M:CNG2]CTRNUM(nolign-1) <> ""
       [M:CNG2]WSLD(nolign-1)=format$("N:3.2",([M:CNG2]SLD(nolign-1)))
     Endif
    #zones pour les ruptures
#MIPEA - 2016-12-22 - X3-11945- START
     SAVCTR = [F:HRCTR]CTRNUM
     SAVDTC = [F:HRCTR]CTRDAT
#     SAVCTR = [F:CTR]CTRNUM
#     SAVDTC = [F:CTR]CTRDAT
#MIPEA - 2016-12-22 - X3-11945- END
     SAVYEA = [F:CNG]YEA
     SAVTIM = [F:CNG]TIM

    Endif
  Endif : # FQ76178
Next

Filter [F:LNK]

[M:CNG2]NBLIG = NOL+1

# On essaye d'afficher le même évènement dans les détails si il y en avait un
[M:CNG3]LIN = 0

If [M:CNG3]TIM <> "" & [M:CNG3]YEA <> 0
 #trouve-t-on la même combinaison évènement/année dans le masque
 [M:CNG3]LIN = find([M:CNG3]TIM,[M:CNG2]TIM)
 If [M:CNG3]LIN > 0
  [M:CNG3]LIN -= 1
  [M:CNG3]LIN = [M:CNG3]LIN+(find([M:CNG3]YEA,[M:CNG2]CNGYEA([M:CNG3]LIN..NOL)))
  #nb:si on ne trouve pas la même année ici, on aura au moins le même évènement
  If [M:CNG3]LIN > 0
   [M:CNG3]LIN -= 1
   Endif
 Endif
Endif

Call DETAILFEED([M:CNG3]LIN)

OLDDAT   = CRITDAT
OLDCRIT  = CRITERE
OLDCRIT0 = CRITERE0
OLDCRIT1 = CRITERE1
OLDCRIT2 = CRITERE2
Return
#######################################
$AV_AFFICHE
#Supression des colonnes hors contexte et alimentation des titres
Return
#######################################
$EXEBOUT

#Gosub PAG_PREM From GCONSULT
Return

######################################################################################
######################################################################################
$LINEFEED
#MIPEA - 2016-12-22 - X3-11945- START
[M:CNG2]CTRNUM(nolign-1) = [F:HRCTR]CTRNUM
#[M:CNG2]CTRNUM(nolign-1) = [F:CTR]CTRNUM
#MIPEA - 2016-12-22 - X3-11945- END
[M:CNG2]CNGYEA(nolign-1) = [F:CNG]YEA
[M:CNG2]TIM   (nolign-1) = [F:CNG]TIM
#JASMI - 2014-09-22 - US2983 - START
#[M:CNG2]DEBDAT(nolign-1) = [F:CNG]DEBDAT
#[M:CNG2]FINDAT(nolign-1) = [F:CNG]FINDAT
#MIPEA - 2016-12-22 - X3-11945- START
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
  [M:CNG2]DEBDAT(nolign-1) = [F:CNE]EMPLEASTR
  [M:CNG2]FINDAT(nolign-1) = [F:CNE]EMPLEAEND
Else
  [M:CNG2]DEBDAT(nolign-1) = [F:CNG]DEBDAT
  [M:CNG2]FINDAT(nolign-1) = [F:CNG]FINDAT
Endif
#JASMI - 2014-09-22 - US2983 - END
#MIPEA - 2016-12-22 - X3-11945- START
[M:CNG2]CTRDAT(nolign-1) = [F:HRCTR]CTRDAT
#[M:CNG2]CTRDAT(nolign-1) = [F:CTR]CTRDAT
#MIPEA - 2016-12-22 - X3-11945- END

#MIPEA - 2016-01-04- X3-11945- START
#MIPEA - 2016-12-22 - X3-11945- START
Call CNG_ACCOUNT([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[F:CNG]TIM,[F:HRCTR]ETRFCY,[M:CNG1]DATSEL,[F:HRCTR]PERCOD
&               ,WYEA,WACQ,WPRI,WVLD,WATT,WSLD,WSLDMIN) From CNSCNGSTD
#Call CNG_ACCOUNT([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[F:CNG]TIM,[F:HRCTR]ETRFCY,[M:CNG1]DATSEL
#&               ,WYEA,WACQ,WPRI,WVLD,WATT,WSLD,WSLDMIN)
#Call CNG_ACCOUNT([F:CTR]REFNUM,[F:CTR]CTRNUM,[F:CTR]CTRDAT,[F:CNG]TIM,[F:CTR]ETRFCY,[M:CNG1]DATSEL
#&               ,WYEA,WACQ,WPRI,WVLD,WATT,WSLD,WSLDMIN)
#MIPEA - 2016-12-22 - X3-11945- END
#MIPEA - 2016-01-04- X3-11945- END
# On recupère un tableau des années concernées par DATSEL, on ne garde que celle courante
I=0
While I<dim(WYEA)-1 & WYEA(I) <> [F:CNG]YEA
 I+=1
Wend
If WYEA(I) = [F:CNG]YEA
 [M:CNG2]ACQ(nolign-1)   = WACQ(I)
 [M:CNG2]PRI(nolign-1)   = WPRI(I)
 [M:CNG2]VLD(nolign-1)   = WVLD(I)
 [M:CNG2]ATT(nolign-1)   = WATT(I)
 [M:CNG2]SLD(nolign-1)   = WSLD(I)
Endif

Return
######################################################################################
#**
#*  FQ76178 US1931 - SEGAY 18/09/13 -
#* Test parameter TYPCP for site, evenement CPA, evenement CPE and evement of CNG
#*
#* @param PETRFCY
#* @param PCPA
#* @param PCPE
#* @param PTIM
#* @param POK return 1 if OK
#*!
Subprog VERIF_TYPCP(PETRFCY,PCPA,PCPE,PTIM,POK)
Value Char PETRFCY
Value Char PCPA
Value Char PCPE
Value Char PTIM
Variable Integer POK
Local Char WEVT(GLONTPS)

POK =1
If (PTIM = PCPA | PTIM = PCPE)
  If func AFNC.PARAM("TYPCP",[L]PETRFCY) = "2"
     [L]WEVT=PCPA
  Else
     [L]WEVT=PCPE
  Endif
  If [L]WEVT <> "" & [L]WEVT <> PTIM
     POK = 0
  Endif
Endif
End

#MIPEA - 2016-01-05- X3-11418- START
Subprog CNG_ACCOUNT (REFN,CTRN,CTRD,TIM,FCY,DATSEL,CTRPERCOD,YEA,ACQ,PRI,VLD,ATT,SLD,SLDMIN)
#Subprog CNG_ACCOUNT (REFN,CTRN,CTRD,TIM,FCY,DATSEL,YEA,ACQ,PRI,VLD,ATT,SLD,SLDMIN)
#MIPEA - 2016-01-05- X3-11418- END
######################################################################################
# Décomptes des soldes pour un code évènement
# Paramètres attendus :
#  - Matricule
#  - Contrat
#  - Date du contrat
#  - Site du contrat
#  - code évènement
#  - Date de paie courante
#
# On restitue les valeurs
#  - Année de la période de congé (une occurence des valeurs retournées par année -période de congés-
#                                  concernée par la date de paie courante)
#  - Acquis     1 = issu de l'historique de paye
#  - Pris       2 = issu de l'historique de paye (à la date de paie des Acquis), ou Temps pour le détail
#  - Validés    3 = Présent dans les temps mais postérieurs à la date de paie des Acquis
#  - En attente 4 = Demande d'absence en attente à partir date du jour moins DCGJOUANT ou date paie courante
#  - Solde      5 =  reste à prendre
#  - Solde minimum évènement
#
# Il est possible d'avoir Solde <> 1-(2+3+4) car on tient compte du solde minimum toléré
# sur la fiche évènement
#
#######################################################################################
Value    Char    REFN(), CTRN()
Value    Date    CTRD
Value    Char    TIM(),FCY(),CTRPERCOD()
Variable Date    DATSEL
Variable Integer YEA(0..)
Variable Decimal ACQ(0..), PRI(0..), VLD(0..), ATT(0..), SLD(0..)
Variable Decimal SLDMIN

Local    Date    DT
Local    Date    DATACQ          : # 70417
Local    Char    BULACQ(GLONVCR) : # 70417
Local    Decimal ATT_EXCED(0..dim([L]ATT)) , VLD_EXCED(0..dim([L]ATT))
Local    Decimal ATT_TOLER(0..dim([L]ATT)) , VLD_TOLER(0..dim([L]ATT))
Local    Decimal SLD_TMP , RND_SLD
Local    Char    CODCUM(GLONCUM)

Local    Integer I,N,XD

If !clalev([F:CNGC]) : Local File CNGCPY    [CNGC] : Endif
If !clalev([F:TIM])  : Local File TIMCOD    [TIM]  : Endif
If !clalev([F:HSP])  : Local File HISTOPAYE [HSP]  : Endif
If !clalev([F:TIP])  : Local File TIMEMP    [TIP]  : Endif
If !clalev([F:TIG])  : Local File TIMREGUL  [TIG]  : Endif
If !clalev([F:FCY])  : Local File FACILITY  [FCY]  : Endif
If !clalev([F:VEP])  : Local File VALEMP    [VEP]  : Endif
If !clalev([F:CTRC]) : Local File EMPLOCTR  [CTRC] : Endif

#JASMI - 2014-09-25 - US2983 - START
#MIPEA - 2016-12-22 - X3-11945- START
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
  If !clalev([F:CNEC]) : Local File CNGEMP  [CNEC]  : Endif
Endif
#JASMI - 2014-09-25 - US2983 - END

Raz [L]ACQ,[L]PRI,[L]VLD,[L]ATT,[L]SLD,[L]YEA
Raz [L]ATT_EXCED,[L]VLD_EXCED,[L]ATT_TOLER,[L]VLD_TOLER,[L]SLD_TMP,[L]SLDMIN,I

#webservice : choix 'Affichage solde' sur evt est nécessaire
#MIPEA - 2016-12-22 - X3-11945- START
Read [F:TIM]TIM0 = GCURLEG;[L]TIM
#Read [F:TIM]TIM0 = [L]TIM
#MIPEA - 2016-12-22 - X3-11945- END
If fstat | (GWEBSERV & [F:TIM]DSPSLD <> 2): End : Endif

If [F:TIM]FLGBLC = 2
 [L]SLDMIN  = [F:TIM]BLCMIN  : # 66076
Endif
mkstat = 0
DT=DATSEL
#MIPEA - 2016-01-05- X3-11418- START
Call CADRE_PYRDAT([L]DATSEL,[L]CTRPERCOD) From TPSSUB
#Call CADRE_PYRDAT([L]DATSEL,[L]FCY) From TPSSUB
#MIPEA - 2016-01-05- X3-11418- END
While DATSEL > DT & !mkstat
 # On cherche la plus proche date de paie antérieure à la date sélectionnée
 I+=1
 DATSEL = DT - I
#MIPEA - 2016-01-05- X3-11418- START
Call CADRE_PYRDAT([L]DATSEL,[L]CTRPERCOD) From TPSSUB
#Call CADRE_PYRDAT([L]DATSEL,[L]FCY) From TPSSUB
#MIPEA - 2016-01-05- X3-11418- END
Wend
# FQ77390 - MABON 25/10/11 - Ajout test sur mkstat<>3, qui peut maintenant être égal à 3 après CADRE_PYRDAT
If mkstat & mkstat<>3
 GERR = 1    : # 67776
 End
Endif
# FQ77390 - MABON 25/10/11 - Il faut réinitialiser mkstat
Raz mkstat

Call LECTURE("FCY",[L]FCY,"") From CONTOBJ : # recherche société

#
If [L]CTRD = [0/0/0]
 Filter [CTRC] Where REFNUM=[L]REFN & CTRNUM=[L]CTRN
 Read [CTRC]CTR0 Last
 Filter [CTRC]
Else
 Read [CTRC]CTR0 = [L]REFN;[L]CTRN;[L]CTRD
Endif
#

#Périodes congés évt dont la date reçue en critère est
# dans la période d'acquisition (N-1) ou de tolérance (N)
# FQ76186 - MABON 19/09/11 - Ajout test sur XITFNL
Filter[F:CNGC] Where   [F:CNGC]CPY = [F:FCY]LEGCPY
&                 &    [F:CNGC]TIM = [L]TIM
&                 & (( [F:CNGC]STRPER <= DATSEL & DATSEL <= [F:CNGC]ENDPER )
&                  | ( [F:CNGC]DEBDAT <= DATSEL & DATSEL <= [F:CNGC]FINDAT ))
&                 &  ( [F:CTRC]XITDAT  = [0/0/0] | [F:CTRC]XITDAT  >= [F:CNGC]STRPER | [F:CTRC]XITFNL<>2)
#JASMI - 2014-09-25 - US2983 - START
#MIPEA - 2016-12-22 - X3-11945- START
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
  Filter[F:CNEC] Where   [F:CNEC]TIM = [L]TIM
&                      & [F:CNEC]REFNUM=[L]REFN
&                      & [F:CNEC]CTRNUM=[L]CTRN
&                     & ([F:CNEC]EMPLEASTR <= DATSEL & DATSEL <= [F:CNEC]EMPLEAEND)
&                     & ([F:CTRC]XITDAT  = [0/0/0] | [F:CTRC]XITDAT  >= [F:CNEC]EMPLEASTR | [F:CTRC]XITFNL<>2)
  Read [F:CNEC]CNE0 Last
  Filter [F:CNEC]
  If !fstat
    Filter [F:CNGC] Where CPY=[F:FCY]LEGCPY & TIM=[L]TIM & YEA=[F:CNEC]YEA
  Endif
Endif
#JASMI - 2014-09-25 - US2983 - END

N=0

For [F:CNGC]

  If N>=dim([L]ACQ)
   Break
  Endif

#JASMI - 2014-09-25 - US2983 - START
#MIPEA - 2016-12-22 - X3-11945- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
    Read [F:CNEC]CNE0 = [F:CNGC]YEA;[L]REFN;[L]CTRN;[F:CNGC]TIM
    If fstat : End : Endif
  Endif
#JASMI - 2014-09-25 - US2983 - END

  YEA   (N) = [F:CNGC]YEA

 #-- Droits              => récupérés dans histopaye --------------------------------------
#JASMI - 2014-09-25 - US2983 - START
#  If DATSEL > [F:CNGC]ENDPER
#   [L]CODCUM = [F:CNGC]CUMACQ(1)     : # Acquis N-1 si on est après la période d'acquisition
#  Else
#   [L]CODCUM = [F:CNGC]CUMACQ(0)     : # Acquis N
#  Endif
#MIPEA - 2016-12-22 - X3-11945- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
    If DATSEL > [F:CNEC]EMPLEAEND
     [L]CODCUM = [F:CNGC]CUMACQ(1)     : # Acquis N-1 si on est après la période d'acquisition
    Else
     [L]CODCUM = [F:CNGC]CUMACQ(0)     : # Acquis N
    Endif
  Else
    If DATSEL > [F:CNGC]ENDPER
     # FQ109019 - 22/06/15 - Si le bulletin du mois de bascule n'a pas été calculé, alors qu'on demande le mois de bascule, il faut
     # échanger les cumuls à récupérer
#     [L]CODCUM = [F:CNGC]CUMACQ(1)     : # Acquis N-1 si on est après la période d'acquisition
      If year(DATSEL)=year([F:CNGC]STRDAT) & month(DATSEL)=month([F:CNGC]STRDAT) Then
        Filter [HSP] Where [HSP]EMP    =  [L]REFN
&                        & [HSP]DAT    <= DATSEL
&                        & [HSP]DAT    >= CTRD
&                        & [HSP]CTRNUM =  [L]CTRN
&                   Order By Key HSP1
        Read [HSP] Last
        If year([F:HSP]DAT)=year(DATSEL) & month([F:HSP]DAT)=month(DATSEL)-1 Then
         [L]CODCUM = [F:CNGC]CUMACQ(0)     : # Acquis N
        Else
         [L]CODCUM = [F:CNGC]CUMACQ(1)     : # Acquis N-1 si on est après la période d'acquisition
        Endif
        Filter [HSP]
      Else
        [L]CODCUM = [F:CNGC]CUMACQ(1)     : # Acquis N-1 si on est après la période d'acquisition
      Endif
    Else
     [L]CODCUM = [F:CNGC]CUMACQ(0)     : # Acquis N
    Endif
  Endif
#JASMI - 2014-09-25 - US2983 - END
  Raz [HSP]
  Filter [HSP] Where [HSP]EMP    =  [L]REFN
&                  & [HSP]DAT    <= DATSEL
&                  & [HSP]DAT    >= CTRD
&                  & [HSP]RUB    =  [L]CODCUM
&                  & [HSP]TYP    =  6
&                  & [HSP]CTRNUM =  [L]CTRN
&              Order By Key HSP1
  Read [HSP] Last

# recherche du bon bulletin sur le bon contrat (cas des salariés sortis & entrés dans le même mois sur le même n° contrat)
  If CTRD <> [0/0/0]
   Read [F:VEP]VEP5 = [HSP]BUL
   While !fstat & [F:VEP]CTRDAT <> [0/0/0] & [F:VEP]CTRDAT <> [L]CTRD
    Read [F:HSP] Prev
    If !fstat
     Read [F:VEP]VEP5 = [HSP]BUL
    Endif
   Wend
  Endif
#
  Filter [HSP]
  [L]ACQ(N) = [HSP]AMT
  BULACQ    = [HSP]BUL
  DATACQ    = max([HSP]DAT,CTRD)

 #On arrondit à l'entier supérieur le reste à prendre
  [L]SLD(N)  = fix([L]ACQ(N)+0.999)
  RND_SLD    = [L]SLD(N) - [L]ACQ(N)

#-- Pris                => récupérés dans histopaye --------------------------------------
#JASMI - 2014-09-25 - US2983 - START
#  If DATSEL > [F:CNGC]ENDPER
#   [L]CODCUM = [F:CNGC]CUMPRI(1)     : # Pris N-1 si on est après la période de d'acquisition
#  Else
#   [L]CODCUM = [F:CNGC]CUMPRI(0)     : # Pris N
#  Endif
#MIPEA - 2016-12-22 - X3-11945- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
    If DATSEL > [F:CNEC]EMPLEAEND
     [L]CODCUM = [F:CNGC]CUMPRI(1)     : # Pris N-1 si on est après la période de d'acquisition
    Else
     [L]CODCUM = [F:CNGC]CUMPRI(0)     : # Pris N
    Endif
  Else
    If DATSEL > [F:CNGC]ENDPER
     # FQ109019 - 22/06/15 - Si le bulletin du mois de bascule n'a pas été calculé, alors qu'on demande le mois de bascule, il faut
     # échanger les cumuls à récupérer
#     [L]CODCUM = [F:CNGC]CUMPRI(1)     : # Pris N-1 si on est après la période de d'acquisition
      If year(DATSEL)=year([F:CNGC]STRDAT) & month(DATSEL)=month([F:CNGC]STRDAT) Then
        Filter [HSP] Where [HSP]EMP    =  [L]REFN
&                        & [HSP]DAT    <= DATSEL
&                        & [HSP]DAT    >= CTRD
&                        & [HSP]CTRNUM =  [L]CTRN
&                   Order By Key HSP1
        Read [HSP] Last
        If year([F:HSP]DAT)=year(DATSEL) & month([F:HSP]DAT)=month(DATSEL)-1 Then
         [L]CODCUM = [F:CNGC]CUMPRI(0)     : # Pris N
        Else
         [L]CODCUM = [F:CNGC]CUMPRI(1)     : # Pris N-1 si on est après la période d'acquisition
        Endif
        Filter [HSP]
      Else
        [L]CODCUM = [F:CNGC]CUMPRI(1)     : # Pris N-1 si on est après la période de d'acquisition
      Endif
    Else
     [L]CODCUM = [F:CNGC]CUMPRI(0)     : # Pris N
    Endif
  Endif
#JASMI - 2014-09-25 - US2983 - END
  Raz [HSP]
# / 70417
#  Filter [HSP] Where [HSP]EMP    =  [L]REFN
#&                  & [HSP]DAT    <= DATSEL
#&                  & [HSP]RUB    =  [L]CODCUM
#&                  & [HSP]TYP    =  6
#&                  & [HSP]CTRNUM = [L]CTRN
#&              Order By Key HSP1
  Read [HSP]HSP3 = BULACQ;[L]CODCUM;6 : # on lit la même date que celle trouvé pour les acquis
                                        # car on peut avoir 0 pris > soit pas d'enreg
  [L]PRI(N) = [HSP]AMT

# 70417 /

#-- On cherche l'occ de N-1 pour récupérer l'éventuel excédent de jours
  I=0 : XD = -1
  While I < N & XD < 0
   If YEA(I) = YEA(N)-1
    XD = I
   Endif
   I+=1
  Wend

  [L]SLD(N)  = [L]SLD(N)-[L]PRI(N)
  [L]SLD_TMP = [L]SLD(N)

#-- Validés > date sélectionnée ----------------------------------------------------------
  [L]VLD(N)=0
  # TIP TIR d'abord dans la période de conso puis dans la période de tolérance
  # déduire ceux pris dans la tolérance N-1([L]VLD_EXCED(XD))
  # & relever les pris dans la période de tolérance ([L]VLD_EXCED)

  #[L]DT = max([F:CNGC]DEBDAT-1,DATSEL)
#JASMI - 2014-09-25 - US2983 - START
#  [L]DT = max([F:CNGC]DEBDAT-1,DATACQ) : # 70385 On prend au delà de date des "Droits" trouvée plutôt que date sélection
#  Filter [TIP] Where [TIP]REFNUM =  [L]REFN
#&                  & [TIP]CTRNUM =  [L]CTRN
#&                  & [TIP]DATPYR >  [L]DT
#&                  & [TIP]DATPYR <= [F:CNGC]ENDDAT
#&                  & [TIP]TIM    =  [L]TIM
#&              Order By Key TIP1
#MIPEA - 2016-12-22 - X3-11945- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
    [L]DT = max([F:CNEC]EMPLEASTR-1,DATACQ) : # 70385 On prend au delà de date des "Droits" trouvée plutôt que date sélection
    Filter [TIP]  Where [TIP]REFNUM =  [L]REFN
&                     & [TIP]CTRNUM =  [L]CTRN
&                     & [TIP]DATPYR >  [L]DT
&                     & [TIP]DATPYR <= [F:CNEC]EMPLEAEND
&                     & [TIP]TIM    =  [L]TIM
&                 Order By Key TIP1
  Else
    [L]DT = max([F:CNGC]DEBDAT-1,DATACQ) : # 70385 On prend au delà de date des "Droits" trouvée plutôt que date sélection
    Filter [TIP] Where [TIP]REFNUM =  [L]REFN
&                    & [TIP]CTRNUM =  [L]CTRN
&                    & [TIP]DATPYR >  [L]DT
&                    & [TIP]DATPYR <= [F:CNGC]ENDDAT
&                    & [TIP]TIM    =  [L]TIM
&                Order By Key TIP1
  Endif
#JASMI - 2014-09-25 - US2983 - END
  For [TIP]
   [L]VLD(N) += [F:TIP]NBRDAY
  Next
  Filter [TIP]

#JASMI - 2014-09-25 - US2983 - START
#  Filter [TIG] Where [TIG]REFNUM =  [L]REFN
#&                  & [TIG]CTRNUM =  [L]CTRN
#&                  & [TIG]DATPYR >  [L]DT
#&                  & [TIG]DATPYR <= [F:CNGC]ENDDAT
#&                  & [TIG]TIM    =  [L]TIM
#&              Order By Key TIG1
#MIPEA - 2016-12-22 - X3-11945- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
    Filter [TIG] Where [TIG]REFNUM =  [L]REFN
&                    & [TIG]CTRNUM =  [L]CTRN
&                    & [TIG]DATPYR >  [L]DT
&                    & [TIG]DATPYR <= [F:CNEC]EMPLEAEND
&                    & [TIG]TIM    =  [L]TIM
&                Order By Key TIG1
  Else
    Filter [TIG] Where [TIG]REFNUM =  [L]REFN
&                    & [TIG]CTRNUM =  [L]CTRN
&                    & [TIG]DATPYR >  [L]DT
&                    & [TIG]DATPYR <= [F:CNGC]ENDDAT
&                    & [TIG]TIM    =  [L]TIM
&                Order By Key TIG1
  Endif
#JASMI - 2014-09-25 - US2983 - END
  For [TIG]
   [L]VLD(N) += [F:TIG]NBRDAY
  Next
  Filter [TIG]

  # Y a t-il des jours dans la Période de tolérance ?
#  [L]DT = max([F:CNGC]ENDDAT,DATSEL)

#JASMI - 2014-09-25 - US2983 - START
#  [L]DT = max([F:CNGC]ENDDAT,DATACQ)
#
#  Filter [TIP] Where [TIP]REFNUM =  [L]REFN
#&                  & [TIP]CTRNUM =  [L]CTRN
#&                  & [TIP]DATPYR >  [L]DT
#&                  & [TIP]DATPYR <= [F:CNGC]FINDAT
#&                  & [TIP]TIM    =  [L]TIM
#&              Order By Key TIP1
#MIPEA - 2016-12-22 - X3-11945- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
    [L]DT = max([F:CNEC]EMPLEAEND,DATACQ)

    Filter [TIP] Where [TIP]REFNUM =  [L]REFN
&                    & [TIP]CTRNUM =  [L]CTRN
&                    & [TIP]DATPYR >  [L]DT
&                    & [TIP]DATPYR <= [F:CNEC]EMPLEAEND
&                    & [TIP]TIM    =  [L]TIM
&                Order By Key TIP1
  Else
    [L]DT = max([F:CNGC]ENDDAT,DATACQ)

    Filter [TIP] Where [TIP]REFNUM =  [L]REFN
&                    & [TIP]CTRNUM =  [L]CTRN
&                    & [TIP]DATPYR >  [L]DT
&                    & [TIP]DATPYR <= [F:CNGC]FINDAT
&                    & [TIP]TIM    =  [L]TIM
&                Order By Key TIP1
  Endif
#JASMI - 2014-09-25 - US2983 - END

  For [TIP]
   [L]VLD_TOLER(N) += [F:TIP]NBRDAY :# 112624
  Next
  Filter [TIP]

#JASMI - 2014-09-25 - US2983 - START
#  Filter [TIG] Where [TIG]REFNUM =  [L]REFN
#&                  & [TIG]CTRNUM =  [L]CTRN
#&                  & [TIG]DATPYR >  [L]DT
#&                  & [TIG]DATPYR <= [F:CNGC]FINDAT
#&                  & [TIG]TIM    =  [L]TIM
#&              Order By Key TIG1
#MIPEA - 2016-12-22 - X3-11945- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
    Filter [TIG] Where [TIG]REFNUM =  [L]REFN
&                    & [TIG]CTRNUM =  [L]CTRN
&                    & [TIG]DATPYR >  [L]DT
&                    & [TIG]DATPYR <= [F:CNEC]EMPLEAEND
&                    & [TIG]TIM    =  [L]TIM
&                Order By Key TIG1
  Else
    Filter [TIG] Where [TIG]REFNUM =  [L]REFN
&                    & [TIG]CTRNUM =  [L]CTRN
&                    & [TIG]DATPYR >  [L]DT
&                    & [TIG]DATPYR <= [F:CNGC]FINDAT
&                    & [TIG]TIM    =  [L]TIM
&                Order By Key TIG1
  Endif
#JASMI - 2014-09-25 - US2983 - END

  For [TIG]
   [L]VLD_TOLER(N) += [F:TIG]NBRDAY : # 112624
  Next
  Filter [TIG]

  # Calcul excédent de jours pour N et jours dans la période de tolérence pour N
  If [L]SLD_TMP <= [L]SLDMIN                     : # 66076

    [L]VLD_EXCED(N)= [L]VLD(N)                   : # Excédent de l'année parcourue
    [L]VLD(N)      = 0

  Else

    If XD < 0                                      : # pas d'occurence N-1
     [L]SLD(N) = [L]SLD_TMP - [L]VLD(N)
    Else
   # [L]VLD(N) = [L]VLD(N) + [L]VLD_EXCED(XD) - [L]VLD_TOLER(XD)
   #71325 les exédents de N-1 ont dû passés dans les pris.
   # On enlève donc la part des pris de l'année aux exécedents
   # On ne le fait pas si c'est la totalité de N-1 qui est en excédent.
   # Parce que dans ce cas on ne sait pas si les pris N-1 ont de l'excédent
     If VLD(XD) = 0 & PRI(XD) <> 0
      [L]VLD(N) = [L]VLD(N) + [L]VLD_EXCED(XD) - [L]VLD_TOLER(XD)
     Else
      [L]VLD(N) = [L]VLD(N) + max(0,[L]VLD_EXCED(XD)-PRI(N)) - [L]VLD_TOLER(XD)
     Endif

     [L]SLD(N) = [L]SLD_TMP - [L]VLD(N)            : # avec reprise excédent N-1
    Endif

    If [L]SLD(N) >= [L]SLDMIN                      : # 66076
     # 112624
     [L]VLD_TOLER(N) = min([L]VLD_TOLER(N),[L]SLD(N))    : # Jours période de tolérance année parcourue
     [L]VLD_TOLER(N) = max(0,[L]VLD_TOLER(N))            : # 66076 tenir compte que [L]SLDMIN peut < 0
     [L]VLD(N)    = [L]VLD(N) + [L]VLD_TOLER(N)       : # Nb renvoyé inclue les j pér. de tolérance
     [L]SLD(N)    = [L]SLD(N) - [L]VLD_TOLER(N)
    Else
     [L]VLD_EXCED(N)= [L]SLDMIN  - [L]SLD(N)       : # 66076 # Excédent de l'année parcourue
     [L]VLD(N)      = [L]SLD_TMP - [L]SLDMIN
     [L]SLD(N)      = [L]SLDMIN                    : # 66076
    Endif

  Endif

  [L]SLD_TMP = [L]SLD(N)

  #-- En [L]ATT(N)ente > date sélectionnée ---------------------------------------------------------
  [L]ATT(N) = 0

#  [L]DT = min(DATSEL,date$-val(func AFNC.PARAM("DCGJOUANT",""))) : # 66457 inclure 'en attente'
  [L]DT = min(DATSEL,date$-val(func AFNC.PARAM("DCGJOUANT",[L]FCY)))

#JASMI - 2014-09-25 - US2983 - START
#  [L]DT = max([F:CNGC]DEBDAT,[L]DT,[L]CTRD)                       : # de moins de DCGJOUANT jours
#
#  If [L]DT <= [F:CNGC]ENDDAT
#   Call CNGREQUEST([L]REFN,[L]CTRN,[L]TIM,[L]DT,[F:CNGC]ENDDAT,[L]ATT(N))
#  Endif
#
#    # Y a t-il des jours dans la Période de tolérance ?
#  [L]DT = max([F:CNGC]ENDDAT+1,DATSEL,[L]CTRD)
#  If [L]DT <= [F:CNGC]FINDAT
#   Call CNGREQUEST([L]REFN,[L]CTRN,[L]TIM,[L]DT,[F:CNGC]FINDAT,[L]ATT_TOLER)
#  Endif
#MIPEA - 2016-12-22 - X3-11945- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
    [L]DT = max([F:CNEC]EMPLEASTR,[L]DT,[L]CTRD)                       : # de moins de DCGJOUANT jours

    If [L]DT <= [F:CNEC]EMPLEAEND
     Call CNGREQUEST([L]REFN,[L]CTRN,[L]TIM,[L]DT,[F:CNEC]EMPLEAEND,[L]ATT(N))
    Endif

      # Y a t-il des jours dans la Période de tolérance ?
    [L]DT = max([F:CNEC]EMPLEAEND+1,DATSEL,[L]CTRD)
    If [L]DT <= [F:CNEC]EMPLEAEND
     Call CNGREQUEST([L]REFN,[L]CTRN,[L]TIM,[L]DT,[F:CNEC]EMPLEAEND,[L]ATT_TOLER(N)) : # 112624
    Endif
  Else
    [L]DT = max([F:CNGC]DEBDAT,[L]DT,[L]CTRD)                       : # de moins de DCGJOUANT jours

    If [L]DT <= [F:CNGC]ENDDAT
     Call CNGREQUEST([L]REFN,[L]CTRN,[L]TIM,[L]DT,[F:CNGC]ENDDAT,[L]ATT(N))
    Endif

      # Y a t-il des jours dans la Période de tolérance ?
    [L]DT = max([F:CNGC]ENDDAT+1,DATSEL,[L]CTRD)
    If [L]DT <= [F:CNGC]FINDAT
     Call CNGREQUEST([L]REFN,[L]CTRN,[L]TIM,[L]DT,[F:CNGC]FINDAT,[L]ATT_TOLER(N)) : # 112624
    Endif
  Endif
#JASMI - 2014-09-25 - US2983 - END

    # Calcul excédent de jours pour N et jours dans la période de tolérence pour N
  If [L]SLD_TMP <= [L]SLDMIN                     : # 66076

   [L]ATT_EXCED(N) = [L]ATT(N)                   : # Excédent de l'année parcourue
   [L]ATT(N)       = 0

  Else

   If XD < 0                                     : # pas d'occurence N-1
    [L]SLD(N)    = [L]SLD_TMP - [L]ATT(N)
   Else                                          : # avec reprise excédent & tolérance N-1
    [L]ATT(N)    = [L]ATT(N) + [L]ATT_EXCED(XD) - [L]ATT_TOLER(XD)
    [L]SLD(N)    = [L]SLD_TMP - [L]ATT(N)
   Endif

     # Y a t-il des jours dans la Période de tolérance de l'année parcourue à intégrer ?
   If [L]SLD(N) >= [L]SLDMIN                     : # 66076
    #112624
    [L]ATT_TOLER(N) = min([L]ATT_TOLER(N),[L]SLD(N))   : # Jours période de tolérance année parcourue
    [L]ATT_TOLER(N) = max(0,[L]ATT_TOLER(N))           : # 66076 tenir compte que [L]SLDMIN peut < 0
    [L]ATT(N)    = [L]ATT(N) + [L]ATT_TOLER(N)      : # Nb renvoyé , inclue les j pér. de tolérance
    [L]SLD(N)    = [L]SLD(N) - [L]ATT_TOLER(N)
   Else
    [L]ATT_EXCED(N)= [L]SLDMIN  - [L]SLD(N)      : # 66076
    [L]ATT(N)      = [L]SLD_TMP - [L]SLDMIN
    [L]SLD(N)      = [L]SLDMIN                   : # 66076
   Endif

  Endif

  [L]SLD_TMP = [L]SLD(N)

 #-- SOLDE           ----------------------------------------------------------------------
  #On soustrait l'arrondi appliqué sur le cumul acquis
  [L]SLD(N)    -= RND_SLD

 #-- Reste à prendre ----------------------------------------------------------------------
  #[L]SLD(N)     = [L]SLD_TMP - [L]SLDMIN       : # 66076
  # 66076 si on veut que le solde n'inclut pas le solde minimum (2 lignes ci-dessous)
  #[L]SLD_TMP = min([L]SLD_TMP,[L]SLD(N),[L]ACQ(N))
  #[L]SLD(N)  = max(0,[L]SLD_TMP)
  #

  N+=1

Next

Filter[F:CNGC]
#JASMI - 2014-09-25 - US2983 - START
#MIPEA - 2016-12-22 - X3-11945- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
  Filter[F:CNEC]
Endif
#JASMI - 2014-09-25 - US2983 - END

End

######################################################################################
# demande d'absence en cours de validation
Subprog CNGREQUEST(REFNUM,CTRNUM,TIMCOD,DDEB,DFIN,TPRV)
Value    Char    REFNUM, CTRNUM,TIMCOD
Value    Date    DDEB,DFIN
Variable Decimal TPRV

Local Decimal JOUR(1..400), HEURE(1..400)
Local Date    DATD, DATF
Local Integer I

If !clalev([F:CTRC]) : Local File EMPLOCTR [CTRC] : Endif
If !clalev([F:DCG])  : Local File DEMCONGE [DCG]  : Endif

[L]TPRV=0
For [DCG]DCG0 Where REFNUM=[L]REFNUM & find(CTRNUM,"",[L]CTRNUM)<>0 & STA=2 & UID>0
&                 & TIM=[L]TIMCOD & STRDAT<=[L]DFIN & ENDDAT>=[L]DDEB
 If [F:DCG]STRDAT>=[L]DDEB & [F:DCG]ENDDAT<=[L]DFIN

  [L]TPRV+=[F:DCG]NBRDAY

 Else

  # FQ76186 - MABON 19/09/11 - Ajout test sur XITFNL
  For [CTRC]CTR0 Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM & CTRDAT<=[F:DCG]ENDDAT
&                   & (XITDAT=[0/0/0] | XITDAT>=[F:DCG]STRDAT | XITFNL<>2)
   [L]DATD=max([L]DDEB,[F:DCG]STRDAT,[F:CTRC]CTRDAT)
   If [F:CTRC]XITDAT=[0/0/0] : [L]DATF=min([L]DFIN,[F:DCG]ENDDAT)
   Else                        [L]DATF=min([L]DFIN,[F:DCG]ENDDAT,[F:CTRC]XITDAT)
   Endif
   Call VALORDET( [L]DATD,[L]DATF,[F:DCG]REFNUM,[F:DCG]TIM,[L]JOUR,[L]HEURE,[F:CTRC]ETRFCY
&               , [F:CTRC]CTRNUM
&               ) From SUBPLN
#73242   If [L]DATD=[F:DCG]STRDAT & [F:DCG]STRDAY=2 : [L]JOUR(1)-=min(0.5,[L]JOUR(1)) : Endif
#73242   If [L]DATF=[F:DCG]ENDDAT & [F:DCG]ENDDAY=2
   If [L]DATD=[F:DCG]STRDAT & [F:DCG]ENDDAY=2 : [L]JOUR(1)-=min(0.5,[L]JOUR(1)) : Endif
   If [L]DATF=[F:DCG]ENDDAT & [F:DCG]STRDAY=2
    I=[L]DATF-[L]DATD+1
    [L]JOUR(I)-=min(0.5,[L]JOUR(I))
   Endif
   [L]TPRV+=sum([L]JOUR)
  Next

 Endif
Next

End
######################################################################################
Subprog DETAILFEED(L)
Value Integer L

Raz [M:CNG3] , [M:CNG4] , [M:CNG5]

[M:CNG3]TIM  = [M:CNG2]TIM(L)
[M:CNG3]YEA  = [M:CNG2]CNGYEA(L)
[M:CNG3]STA  = 1
[M:CNG3]LIN  = L

[M:CNG4]TIM  = [M:CNG2]TIM(L)
[M:CNG4]YEA  = [M:CNG2]CNGYEA(L)
[M:CNG4]STA  = 2
[M:CNG4]LIN  = L

[M:CNG5]TIM  = [M:CNG2]TIM(L)
[M:CNG5]YEA  = [M:CNG2]CNGYEA(L)
[M:CNG5]STA  = 3
[M:CNG5]LIN  = L

If [M:CNG3]TIM <> "" & [M:CNG3]YEA  <> 0

 D=dim([M:CNG3]STRCNG)-1
 Call CNG_DETAIL([M:CNG1]REFNUM,[M:CNG2]CTRNUM(L),[M:CNG2]CTRDAT(L),[M:CNG1]DATPYR,[M:CNG2]CNGYEA(L)
&               ,[M:CNG2]TIM(L),[M:CNG3]STA
&               ,[M:CNG3]STRCNG,[M:CNG3]ENDCNG,[M:CNG3]CMT
&               ,[M:CNG3]NBRDAY,[M:CNG3]SUMDAY
&               ,[M:CNG3]TOTDAY)

 While D > 0 & [M:CNG3]STRCNG(D) = [00/00/0000]
  D-=1
 Wend
 If [M:CNG3]STRCNG(D) <> [00/00/0000]
  [M:CNG3]NBDET = D+1
 Endif

  D=dim([M:CNG4]STRCNG)-1

 Call CNG_DETAIL([M:CNG1]REFNUM,[M:CNG2]CTRNUM(L),[M:CNG2]CTRDAT(L),[M:CNG1]DATPYR,[M:CNG2]CNGYEA(L)
&               ,[M:CNG2]TIM(L),[M:CNG4]STA
&               ,[M:CNG4]STRCNG,[M:CNG4]ENDCNG,[M:CNG4]CMT
&               ,[M:CNG4]NBRDAY,[M:CNG4]SUMDAY
&               ,[M:CNG4]TOTDAY)

 While D > 0 & [M:CNG4]STRCNG(D) = [00/00/0000]
  D-=1
 Wend
 If [M:CNG4]STRCNG(D) <> [00/00/0000]
  [M:CNG4]NBDET = D+1
 Endif

  D=dim([M:CNG5]STRCNG)-1

 Call CNG_DETAIL([M:CNG1]REFNUM,[M:CNG2]CTRNUM(L),[M:CNG2]CTRDAT(L),[M:CNG1]DATPYR,[M:CNG2]CNGYEA(L)
&               ,[M:CNG2]TIM(L),[M:CNG5]STA
&               ,[M:CNG5]STRCNG,[M:CNG5]ENDCNG,[M:CNG5]CMT
&               ,[M:CNG5]NBRDAY,[M:CNG5]SUMDAY
&               ,[M:CNG5]TOTDAY)

 While D > 0 & [M:CNG5]STRCNG(D) = [00/00/0000]
  D-=1
 Wend
 If [M:CNG5]STRCNG(D) <> [00/00/0000]
  [M:CNG5]NBDET = D+1
 Endif


Endif

Affzo [M:CNG3]
Affzo [M:CNG4]
Affzo [M:CNG5]

End
######################################################################################
Subprog CNG_DETAIL(REFN,CTRN,CTRD,DATSEL,YEA,TIM,TYP,STRDAT,ENDDAT,CMT,NBRDAY,CUMDAY,TOTDAY)
Value    Char    REFN(), CTRN()
Value    Date    CTRD, DATSEL
Value    Integer YEA
Value    Char    TIM()
Value    Integer TYP
Variable Decimal NBRDAY(0..), CUMDAY(0..),TOTDAY
Variable Date    STRDAT(0..), ENDDAT(0..)
Variable Char    CMT()(0..)

If !clalev([F:CNGC]) : Local File CNGCPY    [CNGC] : Endif
If !clalev([F:CTRC]) : Local File EMPLOCTR  [CTRC] : Endif
If !clalev([F:FCY])  : Local File FACILITY  [FCY]  : Endif
If !clalev([F:TIP])  : Local File TIMEMP    [TIP]  : Endif
If !clalev([F:TIG])  : Local File TIMREGUL  [TIG]  : Endif
If !clalev([F:HSP])  : Local File HISTOPAYE [HSP]  : Endif
If !clalev([F:DCG])  : Local File DEMCONGE  [DCG]  : Endif
If !clalev([F:VEP])  : Local File VALEMP    [VEP]  : Endif

#JASMI - 2014-09-25 - US2983 - START
#MIPEA - 2016-12-22 - X3-11945- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
  If !clalev([F:CNEC]) : Local File CNGEMP  [CNEC]  : Endif
Endif
#JASMI - 2014-09-25 - US2983 - END

Local    Integer DIMTAB , MAXJOUR , MAXANNEE

DIMTAB = dim(NBRDAY)-1
MAXJOUR  = DIMTAB
MAXANNEE = DIMTAB

Local    Integer IFILLER (0..DIMTAB), JFILLER (0..DIMTAB)
Local    Char    CODCUM(GLONCUM)

Local    Integer I , N
Local    Char    CRITERE(200)

Local    Integer NBDROIT
Local    Decimal JOUR(1..MAXJOUR) , HEURE(1..MAXJOUR)
Local    Integer TBANNEE(1..MAXANNEE)
Local    Date    TBDEB(1..MAXANNEE) , TBFIN(1..MAXANNEE)
Local    Decimal TBJOURS(1..MAXANNEE)
Local    Date    DAT,SAVDAT
Local    Date    DATACQ : # 70385
Local    Decimal JRESTE , JIMPUT , TOTIMPUT

Local Integer WYEA(1..10)
Local Decimal WACQ(1..10), WPRI(1..10), WVLD(1..10), WATT(1..10), WSLD(1..10)
Local Decimal WSLDMIN

If [L]CTRD = [0/0/0]
 Filter [CTRC] Where REFNUM=[L]REFN & CTRNUM=[L]CTRN
 Read [CTRC]CTR0 Last
 Filter [CTRC]
Else
 Read [CTRC]CTR0 = [L]REFN;[L]CTRN;[L]CTRD
Endif

Call LECTURE("FCY",[F:CTRC]ETRFCY,"") From CONTOBJ

# 1 - Y a il un reste à prendre sur l'année choisie (=RAPn) > sinon sortie
# 2 - Y a t'il un reste à prendre sur l'année précédente (RAPp)
# 3 - Chercher jour en excédent sur N-1 (maxi RAPn) > à restituer
# 4 - maj RAPn
# 5 - Chercher jours sur N inclus période de tolérance de N-1 (maxi RAPp)> à ne pas restituer
# 6 - Chercher jour sur N inclus période de tolérance de N (maxi RAPn) > à restituer
#MIPEA - 2016-01-04- X3-11945- START
Call CNG_ACCOUNT([L]REFN,[L]CTRN,[L]CTRD,[L]TIM,[F:CTRC]ETRFCY,[L]DATSEL,[F:CTRC]PERCOD
&               ,WYEA,WACQ,WPRI,WVLD,WATT,WSLD,WSLDMIN)
#Call CNG_ACCOUNT([L]REFN,[L]CTRN,[L]CTRD,[L]TIM,[F:CTRC]ETRFCY,[L]DATSEL
#&               ,WYEA,WACQ,WPRI,WVLD,WATT,WSLD,WSLDMIN)
#MIPEA - 2016-01-04- X3-11945- END

If GERR : # 67776
 End
Endif

#Indice année précédente, année courante
Local Shortint PREVYEA, CURRYEA
PREVYEA = find([L]YEA-1,[L]WYEA)
CURRYEA = find([L]YEA,[L]WYEA)

#Pas de droits
If !CURRYEA | (CURRYEA & [L]WACQ(CURRYEA) = 0) : End : Endif

NBDROIT = 0
# Pour l'année recherchée
Read [F:CNGC]CNG0 = [F:FCY]LEGCPY;[L]YEA;[L]TIM
If fstat : End : Endif

#JASMI - 2014-09-25 - US2983 - START
#MIPEA - 2016-12-22 - X3-11945- START
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
  Read [F:CNEC]CNE0 = [F:CNGC]YEA;[L]REFN;[L]CTRN;[F:CNGC]TIM
  If fstat : End : Endif
Endif
#JASMI - 2014-09-25 - US2983 - END

#70385 On veut retrouver la date de paie ayant servie pour les "Pris" (Acquis N)
Raz [HSP]
Filter [HSP] Where [HSP]EMP    =  [L]REFN
&                & [HSP]DAT    <= DATSEL
&                & [HSP]DAT    >= CTRD
&                & [HSP]RUB    =  [F:CNGC]CUMACQ(0)
&                & [HSP]TYP    =  6
&                & [HSP]CTRNUM =  [L]CTRN
&            Order By Key HSP1
Read [HSP] Last
# recherche du bon bulletin sur le bon contrat (cas des salariés sortis & entrés dans le même mois sur le même n° contrat)
If CTRD <> [0/0/0]
 Read [F:VEP]VEP5 = [HSP]BUL
 While !fstat & [F:VEP]CTRDAT <> [0/0/0] & [F:VEP]CTRDAT <> [L]CTRD
  Read [F:HSP] Prev
  If !fstat
   Read [F:VEP]VEP5 = [HSP]BUL
  Endif
 Wend
Endif
#
Filter [HSP]
DATACQ    = max([HSP]DAT,CTRD)                   : # Si HSP est vide on cale sur date contrat


[L]WACQ(CURRYEA)  = fix([L]WACQ(CURRYEA)+0.999)  : # Arrondi à l'entier supérieur
[L]WACQ(CURRYEA) -= WSLDMIN                      : # on intègre le solde minimum

NBDROIT += 1
TBANNEE(NBDROIT) = [L]YEA
#JASMI - 2014-09-25 - US2983 - START
#TBDEB(NBDROIT)   = [F:CNGC]DEBDAT : # dates tolérées
#TBFIN(NBDROIT)   = [F:CNGC]FINDAT
#MIPEA - 2016-12-22 - X3-11945- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
  TBDEB(NBDROIT)   = [F:CNEC]EMPLEASTR : # dates tolérées
  TBFIN(NBDROIT)   = [F:CNEC]EMPLEAEND
Else
  TBDEB(NBDROIT)   = [F:CNGC]DEBDAT : # dates tolérées
  TBFIN(NBDROIT)   = [F:CNGC]FINDAT
Endif
#JASMI - 2014-09-25 - US2983 - END

#71489- si le salarié est entrée dans les périodes on scrute depuis sa date d'entrée
#JASMI - 2014-09-25 - US2983 - START
#If  ( [F:CTRC]CTRDAT > [F:CNGC]STRPER & [F:CTRC]CTRDAT < [F:CNGC]ENDPER )
#& | ( [F:CTRC]CTRDAT > [F:CNGC]STRDAT & [F:CTRC]CTRDAT < [F:CNGC]ENDDAT )
# TBDEB(NBDROIT) = [F:CTRC]CTRDAT
#Endif
#MIPEA - 2016-12-22 - X3-11945- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
  If  ( [F:CTRC]CTRDAT > [F:CNEC]EMPLEASTR & [F:CTRC]CTRDAT < [F:CNEC]EMPLEAEND )
   TBDEB(NBDROIT) = [F:CTRC]CTRDAT
  Endif
Else
  If  ( [F:CTRC]CTRDAT > [F:CNGC]STRPER & [F:CTRC]CTRDAT < [F:CNGC]ENDPER )
&   | ( [F:CTRC]CTRDAT > [F:CNGC]STRDAT & [F:CTRC]CTRDAT < [F:CNGC]ENDDAT )
   TBDEB(NBDROIT) = [F:CTRC]CTRDAT
  Endif
Endif
#JASMI - 2014-09-25 - US2983 - END

If PREVYEA
 [L]WACQ(PREVYEA)  = fix([L]WACQ(PREVYEA)+0.999)  : # Arrondi à l'entier supérieur
 [L]WACQ(PREVYEA) -= WSLDMIN                      : # on intègre le solde minimum
 [L]YEA -=1
 Read [F:CNGC]CNG0 = [F:FCY]LEGCPY;[L]YEA;[L]TIM
 If !fstat
#JASMI - 2014-09-25 - US2983 - START
#  NBDROIT +=1
#  TBANNEE(NBDROIT) = [L]YEA
#  TBDEB(NBDROIT)   = [F:CNGC]DEBDAT
#  #71489- si le salarié est entrée dans les périodes on scrute depuis sa date d'entrée
#  If  ( [F:CTRC]CTRDAT > [F:CNGC]STRPER & [F:CTRC]CTRDAT < [F:CNGC]ENDPER )
#&   | ( [F:CTRC]CTRDAT > [F:CNGC]STRDAT & [F:CTRC]CTRDAT < [F:CNGC]ENDDAT )
#   TBDEB(NBDROIT) = [F:CTRC]CTRDAT
#  Endif
#  TBFIN(NBDROIT)   = [F:CNGC]FINDAT
#MIPEA - 2016-12-22 - X3-11945- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
    Read [F:CNEC]CNE0 = [F:CNGC]YEA;[L]REFN;[L]CTRN;[F:CNGC]TIM
    If !fstat
      NBDROIT +=1
      TBANNEE(NBDROIT) = [L]YEA
      TBDEB(NBDROIT)   = [F:CNEC]EMPLEASTR
      #71489- si le salarié est entrée dans les périodes on scrute depuis sa date d'entrée
      If  ( [F:CTRC]CTRDAT > [F:CNEC]EMPLEASTR & [F:CTRC]CTRDAT < [F:CNEC]EMPLEAEND )
       TBDEB(NBDROIT) = [F:CTRC]CTRDAT
      Endif
      TBFIN(NBDROIT)   = [F:CNEC]EMPLEAEND
    Endif
  Else
    NBDROIT +=1
    TBANNEE(NBDROIT) = [L]YEA
    TBDEB(NBDROIT)   = [F:CNGC]DEBDAT
    #71489- si le salarié est entrée dans les périodes on scrute depuis sa date d'entrée
    If  ( [F:CTRC]CTRDAT > [F:CNGC]STRPER & [F:CTRC]CTRDAT < [F:CNGC]ENDPER )
&   | ( [F:CTRC]CTRDAT > [F:CNGC]STRDAT & [F:CTRC]CTRDAT < [F:CNGC]ENDDAT )
     TBDEB(NBDROIT) = [F:CTRC]CTRDAT
    Endif
    TBFIN(NBDROIT)   = [F:CNGC]FINDAT
  Endif
#JASMI - 2014-09-25 - US2983 - END
 Endif
 [L]YEA +=1
Endif

Case TYP
 When 1 :
#          If [L]WPRI(CURRYEA)
#           #CRITERE = "REFNUM=REFN & CTRNUM=CTRN & TIM=[L]TIM & DATPYR <= DATSEL"
#           CRITERE = "REFNUM=REFN & CTRNUM=CTRN & TIM=[L]TIM & DATPYR <= DATACQ" : #70385
#           TBJOURS(1) = [L]WACQ(CURRYEA)
#           Gosub SLDPRI
#          Endif

# / 70674
           CRITERE  = "REFNUM=REFN & CTRNUM=CTRN & TIM=[L]TIM"
           CRITERE -= "& DATPYR <= DATACQ & STRDAT > CTRD"      : #70385

           If NBDROIT > 1 & ([L]WACQ(PREVYEA)-[L]WPRI(PREVYEA)-WSLDMIN) <= 0
            # On cherche l'excédent sur N-1
            # si on soupçonne un excédent => Droits soldés apres Pris de n-1
            [L]YEA -=1
            TBJOURS(2) = [L]WACQ(PREVYEA) - WSLDMIN
            Gosub SLDPRI
            [L]YEA +=1
            # On modifie les critères de l'année courante
            If N >= 0
&            & [L]STRDAT(N) > [00/00/0000]
             DATSEL   = [L]STRDAT(N)
             TBDEB(1) = [L]SAVDAT+1
            Else
             TBDEB(1) = TBDEB(2) : # On a utilisé aucune date sur N-1, donc la période scrutée commence début n-1
            Endif

            # FQ109025 - Déplacé en dehors du If sinon il manque des jours dans le détail
#            #Pour ne pas avoir de jour non restitué dans le détail, on s'accorde un solde garni pour l'année 1
#            [L]WACQ(CURRYEA) = 999

           Endif

           # FQ109025 - Déplacé en dehors du If sinon il manque des jours dans le détail
           [L]WACQ(CURRYEA) = 999

           TBJOURS(1) = [L]WACQ(CURRYEA)
           Gosub SLDPRI
# 70674 /

 When 2 :
          #If [L]WVLD(CURRYEA) : 70674

           #CRITERE = "REFNUM=REFN & CTRNUM=CTRN & TIM=[L]TIM & DATPYR >  DATSEL"
           CRITERE = "REFNUM=REFN & CTRNUM=CTRN & TIM=[L]TIM & DATPYR >  DATACQ" : #70385

           If NBDROIT > 1 & ([L]WACQ(PREVYEA)-[L]WPRI(PREVYEA)-[L]WVLD(PREVYEA)-WSLDMIN) <= 0
            # On cherche l'excédent sur N-1
            # si on soupçonne un excédent => Droits soldés apres Validés de n-1
            [L]YEA -=1
            TBJOURS(2) = [L]WACQ(PREVYEA) - [L]WPRI(PREVYEA) - WSLDMIN
            Gosub SLDVLD
            [L]YEA +=1
            # On modifie les critères de l'année courante
            If N >= 0
&            & [L]STRDAT(N) > [00/00/0000]
             DATSEL   = [L]STRDAT(N)
             TBDEB(1) = [L]SAVDAT+1  : # 70674
            Else
             TBDEB(1) = TBDEB(2) : # On a utilisé aucune date sur N-1, donc la période scrutée commence début n-1
            Endif

            # FQ109025 - Déplacé en dehors du If sinon il manque des jours dans le détail
#            #70674 Pour ne pas avoir de jour non restitués dans le détail, on s'accorde un solde garni pour l'année 1
#            [L]WACQ(CURRYEA) = 999

           Endif

           # FQ109025 - Déplacé en dehors du If sinon il manque des jours dans le détail
           [L]WACQ(CURRYEA) = 999

           # jours de N
           TBJOURS(1) = [L]WACQ(CURRYEA) - [L]WPRI(CURRYEA) - WSLDMIN
           Gosub SLDVLD

          #Endif
 When 3 :
          #If [L]WATT(CURRYEA) : 70674

           If NBDROIT > 1 & ([L]WACQ(PREVYEA)-[L]WPRI(PREVYEA)-[L]WVLD(PREVYEA)-[L]WATT(PREVYEA)-WSLDMIN) <= 0
            # On cherche l'excédent sur N-1
            # si on soupçonne un excédent => Droits soldés apres En attente de n-1
            TBJOURS(1) = [L]WACQ(PREVYEA) - [L]WPRI(PREVYEA) - [L]WVLD(PREVYEA) - WSLDMIN
            SAVDAT   = TBDEB(1)
            TBDEB(1) = TBDEB(2)
            Gosub SLDATT
            # On modifie les critères de l'année courante
            If N>= 0
&            & [L]STRDAT(N) > [00/00/0000] : # On a utilisé au moins une date sur N-1 ,
             TBDEB(1) = [L]STRDAT(N)+1     : # donc la période scrutée commence à dernière date utilisée sur n-1
            Endif
            # FQ109025 - Déplacé en dehors du If sinon il manque des jours dans le détail
#            #70674 Pour ne pas avoir de jour non restitués dans le détail, on s'accorde un solde garni pour l'année 1
#            [L]WACQ(CURRYEA) = 999

           Endif

           # FQ109025 - Déplacé en dehors du If sinon il manque des jours dans le détail
           [L]WACQ(CURRYEA) = 999

           # jours de N
           TBJOURS(1) = [L]WACQ(CURRYEA) - [L]WPRI(CURRYEA) - [L]WVLD(CURRYEA) - WSLDMIN
           Gosub SLDATT
          #Endif
Endcase

End
#----------------------------#
$SLDPRI
$SLDVLD
#On ne sait pas précisément ce qui a alimenté la paye [HSP] alors on renvoie tous ce qui est
#dans les temps à une date donnée

# Parcours des temps (inspiré de TPSCP)

Raz [L]STRDAT,[L]ENDDAT,[L]NBRDAY,[L]CMT,[L]CUMDAY,[L]TOTDAY
Raz [L]SAVDAT

N=-1

For [TIP]TIP1 Where evalue(CRITERE)

 If [F:TIP]STRDAT=[F:TIP]ENDDAT
  JOUR(1) = [F:TIP]NBRDAY
 Else
  Call VALORDET([F:TIP]STRDAT,[F:TIP]ENDDAT,REFN,[L]TIM,JOUR,HEURE,[F:TIP]FCY,[F:TIP]CTRNUM) From SUBPLN
 Endif

 TOTIMPUT = 0
 For K=1 To [F:TIP]ENDDAT-[F:TIP]STRDAT+1
  DAT = [F:TIP]STRDAT+K-1
  If JOUR(K)
   JRESTE = JOUR(K)
   For I=1 To NBDROIT
    If DAT>=TBDEB(I) & DAT<=TBFIN(I) & TBJOURS(I)>0
     If TBJOURS(I)>JOUR(K)
      JIMPUT = JRESTE
     Else
      JIMPUT = TBJOURS(I)
     Endif


     TBJOURS(I) -= JIMPUT
     JRESTE     -= JIMPUT
     If TBANNEE(I)= [L]YEA
      TOTIMPUT  += JIMPUT
      [L]SAVDAT  = DAT  : # sauvegarde de la dernière date imputée pour gérér les excédents sur n+1
     Endif
     If JRESTE<=0 : Break : Endif
    Endif
   Next I
  Endif
 Next K
 If TOTIMPUT
  N+=1
  [L]STRDAT(N) = [F:TIP]STRDAT
  [L]ENDDAT(N) = [F:TIP]ENDDAT
  [L]CMT(N)    = [F:TIP]CMT
  [L]NBRDAY(N) = TOTIMPUT
 Endif
Next
For [TIG] Where evalue(CRITERE)
 DAT = [F:TIG]STRDAT
 TOTIMPUT = 0
 If [F:TIG]NBRDAY
  JRESTE = [F:TIG]NBRDAY
  For I=1 To NBDROIT
   If DAT>=TBDEB(I) & DAT<=TBFIN(I) & TBJOURS(I)>0
    If TBJOURS(I)>JRESTE
     JIMPUT = JRESTE
    Else
     JIMPUT = TBJOURS(I)
    Endif
    TBJOURS(I) -= JIMPUT
    JRESTE     -= JIMPUT
    If TBANNEE(I)=[L]YEA
     TOTIMPUT += JIMPUT
     [L]SAVDAT = max(DAT,SAVDAT)  : # sauvegarde de la dernière date imputée pour gérér les excédents sur n+1
    Endif
    If JRESTE<=0 : Break : Endif
   Endif
  Next I
 Endif
 If TOTIMPUT
  N+=1
  [L]STRDAT(N) = [F:TIG]STRDAT
  [L]ENDDAT(N) = [F:TIG]ENDDAT
  [L]NBRDAY(N) = TOTIMPUT
  [L]CMT(N)    = [F:TIG]CMT

 Endif
Next

N=max(0,N)
Sorta N   [L]STRDAT,[L]ENDDAT,[L]NBRDAY,[L]CMT Order By [L]STRDAT(indice)

[L]CUMDAY(0) = [L]NBRDAY(0)

TOTDAY = [L]NBRDAY(0)
For I=1 To N
 If N>=DIMTAB
  GERR=1
  Break
 Endif
 [L]CUMDAY(I) = [L]CUMDAY(I-1)+[L]NBRDAY(I)
 TOTDAY      += [L]NBRDAY(I)
Next I

If GERR & GMESSAGE = ""
#MIPEA - 2016-12-22 - X3-11945- START
 GMESSAGE="SLDVLD :"-func AFNC.MES1(mess(80,10701,1),num$(N))
# GMESSAGE="SLDVLD :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2016-12-22 - X3-11945- END
 #           Dimension des variables inférieure à $1$
Endif

Return
#----------------------------#
$SLDATT
# TBJOURS(1) = nombre de jours restant à prendre
N=0
Raz [L]STRDAT,[L]ENDDAT,[L]NBRDAY,[L]CMT,[L]CUMDAY,[L]TOTDAY

#DAT    = min(DATSEL,date$-val(func AFNC.PARAM("DCGJOUANT",""))) : # 66457 inclure 'en attente'
DAT    = min(DATSEL,date$-val(func AFNC.PARAM("DCGJOUANT",[F:CTRC]ETRFCY))) : # 66457 inclure 'en attente'
DATSEL = max(TBDEB(1),DAT,CTRD)                                             : # de moins de DCGJOUANT jours

For [DCG]DCG0 Where REFNUM=[L]REFN & (CTRNUM=[L]CTRN | CTRNUM="")
&                 & TIM = [L]TIM
&                 & UID > 0 & STA = 2
&                 & STRDAT<=TBFIN(1) & ENDDAT>=[L]DATSEL

 If N>=DIMTAB
  GERR=1
  Break
 Endif

 [L]STRDAT(N) = [F:DCG]STRDAT
 [L]ENDDAT(N) = [F:DCG]ENDDAT
 [L]NBRDAY(N) = [F:DCG]NBRDAY
 [L]CMT(N)    = [F:DCG]CMT

 If [F:DCG]STRDAT < DATSEL | [F:DCG]ENDDAT > TBFIN(1)
 # Cette absence est à cheval sur une borne de la période date sélectionnée à fin tolérance
 # on découpe j/j pour ensuite ne prendre que ce qui est dans cette période
  IFILLER(N) = [F:DCG]STRDAY
  JFILLER(N) = [F:DCG]ENDDAY
  Call CUTBYDAY(REFN,CTRN,[F:CTRC]ETRFCY
&            , [L]TIM
&            , [L]STRDAT(N..DIMTAB),IFILLER(N..DIMTAB)
&            , [L]ENDDAT(N..DIMTAB),JFILLER(N..DIMTAB)
&            , [L]NBRDAY(N..DIMTAB))
  If GERR : Break : Endif
  I  = N
  N -=1
  While I < DIMTAB & [L]NBRDAY(I) > 0       : # on parcourt les occurences créées pour enlever les hors période
   If [L]STRDAT(I) >= DATSEL & [L]ENDDAT(I) <= TBFIN(1)
    N+=1
    [L]STRDAT(N) = [L]STRDAT(I)
    [L]ENDDAT(N) = [L]ENDDAT(I)
    [L]NBRDAY(N) = [L]NBRDAY(I)
    [L]CMT(N)    = [F:DCG]CMT
   Endif
   I+=1
  Wend
  I=N+1
  While [L]NBRDAY(I) <> 0  : # On efface l'excédent
   Raz [L]STRDAT(I) , IFILLER(I) , [L]ENDDAT(I), JFILLER(I) , [L]NBRDAY(I)
   I+=1
  Wend

 Endif

 N+=1

Next

If GERR
#MIPEA - 2016-12-22 - X3-11945- START
 GMESSAGE="SLDATT :"-func AFNC.MES1(mess(80,10701,1),num$(N))
# GMESSAGE="SLDATT :"-func AFNC.MES1(mess(80,701,1),num$(N))
#MIPEA - 2016-12-22 - X3-11945- END
 #           Dimension des variables inférieure à $1$
Else
 N=max(0,N)
 Sorta N
&      [L]STRDAT
&     ,[L]ENDDAT
&     ,[L]NBRDAY
&     ,[L]CMT
&      Order By [L]STRDAT(indice)

 # On a pas encore éliminé ce qui est dans la période mais dépasse le reste à prendre
 # > Suppression de l'excédent et alim du cumul
 I=0
 While I < DIMTAB

  If I > N
   Break
  Endif

  If [L]NBRDAY(I) > TBJOURS(1)   : # Si excédent provoqué par cette occurence, on la découpe
   N += int([L]NBRDAY(I))-1

   IFILLER(I) = [F:DCG]STRDAY
   JFILLER(I) = [F:DCG]ENDDAY
   Call CUTBYDAY(REFN,CTRN,[F:CTRC]ETRFCY
&            , [L]TIM
&            , [L]STRDAT(I..DIMTAB),IFILLER(I..DIMTAB)
&            , [L]ENDDAT(I..DIMTAB),JFILLER(I..DIMTAB)
&            , [L]NBRDAY(I..DIMTAB))
   If GERR : Break : Endif
  Endif

  If TBJOURS(1) >= [L]NBRDAY(I)  : # Alimentation du cumul pour les occurences concernées
   [L]CUMDAY(I) = [L]NBRDAY(I)
   If I > 0  : [L]CUMDAY(I) += [L]CUMDAY(I-1) : Endif
   TBJOURS(1)-= [L]NBRDAY(I)
  Else                           : # Si on a atteint le max de jours, on efface l'excédent
   N=I
   For I=I To DIMTAB
    Raz [L]STRDAT(I),[L]ENDDAT(I),[L]NBRDAY(I),[L]CMT(I),[L]CUMDAY(I)
   Next I
  Endif
  I+=1
Wend
N-=1
If N >= 0
 [L]TOTDAY = [L]CUMDAY(N)
Endif
Endif

Return
######################################################################################

Subprog CUTBYDAY(DREF,DCTR,DFCY,DTIM,DSTRDAT,DSTRDAY,DENDDAT,DENDDAY,DNBRDAY)
###########################################################################################
# Découpage d'une période en jour par jour
#
# Param en entrée :
# - 1 occ de DREFNUM,DCTRNUM,DFCY,DTIM,DSTRDAT,DSTRDAY,DENDDAT,DENDDAY,DNBRDAY
#
#   => 1 seule ligne d'absence qui peut concerner plusieurs jours
#
#
# Rendu en sorti :
# - n occurences du param entrée avec valeurs recalculées DSTRDAT,DSTRDAY,DENDDAT,DENDDAY,DNBRDAY
#   les autres valeurs de champs des occurences rendues sont identiques aux valeurs reçu
#
#   => plusieurs lignes d'absence qui concernent chacune 1 seul jour
#      chaque jour en sorti est un jour effectivement décompté dans les temps
#
#
###########################################################################################
Value    Char    DREF() , DCTR() , DTIM() , DFCY()
Variable Date    DSTRDAT(0..) , DENDDAT(0..)
Variable Decimal DNBRDAY(0..)
Variable Integer DSTRDAY(0..) , DENDDAY(0..)

Local    Decimal DJOUR(0..dim(DSTRDAT)) , DHEURE(0..dim(DSTRDAT))
Local    Integer DN,DJ
Local    Date    END0
Local    Integer DAY0

END0 = DENDDAT(0)
DAY0 = DENDDAY(0)

#Alimentation de la liste des jours: DJOUR(n)=1 signifie jour décompté ---------------
Call VALORDET(DSTRDAT(0),DENDDAT(0),DREF,DTIM,DJOUR,DHEURE,DFCY,DCTR) From SUBPLN

#Eclatement période d'absence en 1 occ par jour
DN = 0
DJ = 0
While DSTRDAT(DN) <= DENDDAT(DN)

 If DJOUR(DJ) > 0 : # on ne renvoie que les jours décomptés - 64045

  # 5 champs varient sur chaque occurence : STRDAT,STRDAY,ENDDAT,ENDDAY,NBRDAY
# 73242  If DN = 0 & DSTRDAY(DN) = 2
#   DENDDAY(DN) = 1
  If DN = 0 & DENDDAY(DN) = 2                       : # début un ap.midi?
   DSTRDAY(DN) = 1
   DNBRDAY(DN) = 0.5
# 73242  Elsif DSTRDAT(DN) = DENDDAT(DN) & DENDDAY(DN) = 2
#   DSTRDAY(DN) = 1
  Elsif DSTRDAT(DN) = DENDDAT(DN) & DSTRDAY(DN) = 2 : # fin un matin?
   DENDDAY(DN) = 1
   DNBRDAY(DN) = 0.5
  Else                                              : # Au milieu de la période >jours complets
   DSTRDAY(DN) = 1   :#  73242 ligne non modifiée
   DENDDAY(DN) = 1   :#  73242 ligne non modifiée
   DNBRDAY(DN) = 1
  Endif

  DENDDAT(DN) = DSTRDAT(DN)
  DN+=1
  If DN >= dim(DSTRDAT)
   GERR=1
   Break
  Endif
  DSTRDAT(DN)  = DSTRDAT(DN-1)
  DENDDAT(DN)  = END0
  DENDDAY(DN)  = DAY0

 Endif

 DSTRDAT(DN) +=1

 DJ+=1
 If DJ >= dim(DJOUR)
  GERR=1
  Break
 Endif
Wend

If DN < dim(DSTRDAT)
 Raz DSTRDAT(DN) , DENDDAT(DN) , DNBRDAY(DN) , DSTRDAY(DN) , DENDDAY(DN)
Endif

End


######################################################################################
$CREATE_FILTER

#Période de congés à parcourir
CRITERE  = "1=1"
CRITERE0 = "1=1"
CRITERE1 = "1=1"
CRITERE2 = "1=1"

#Contrats
#MIPEA - 2016-12-22 - X3-11945- START
CRITERE   = '[F:HRCTR]REFNUM="'+[M:CNG1]REFNUM+'"'
If [M:CNG1]CTRNUM <> ""
 CRITERE -= '& [F:HRCTR]CTRNUM="'+[M:CNG1]CTRNUM+'"'
Endif
#CRITERE   = '[F:CTR]REFNUM="'+[M:CNG1]REFNUM+'"'
#If [M:CNG1]CTRNUM <> ""
# CRITERE -= '& [F:CTR]CTRNUM="'+[M:CNG1]CTRNUM+'"'
#Endif
#MIPEA - 2016-12-22 - X3-11945- END

#CRITERE  -= '& ([F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>= ['+num$([M:CNG1]DATSEL)+'])'
# FQ76186 - MABON 19/09/11 - Ajout test sur XITFNL
#CRITERE  -= '& [F:CTR]CTRDAT<= ['+num$([M:CNG1]DATSEL)+']'
#CRITERE  -= '& ([F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>= ['+num$([M:CNG1]DEBREG)+'] | [F:CTR]XITFNL<>2)'          : # 70676
#     SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
#MIPEA - 2016-12-22 - X3-11945- START
CRITERE  -= '& ([F:HRCTR]CTRDAT<=['+num$([M:CNG1]DATSEL)+'] | ([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<=['+num$([M:CNG1]DATSEL)+']))'
CRITERE  -= '& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>= ['+num$([M:CNG1]WDATDEB)+'] )'
#CRITERE  -= '& ([F:CTR]CTRDAT<=['+num$([M:CNG1]DATSEL)+'] | ([F:CTR]FLGRET=2 & [F:CTR]RETDATEFF<=['+num$([M:CNG1]DATSEL)+']))'
#CRITERE  -= '& ([F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>= ['+num$([M:CNG1]WDATDEB)+'] )'
#MIPEA - 2016-12-22 - X3-11945- END

If [M:CNG1]CTRDAT <> [0/0/0]
#MIPEA - 2016-12-22 - X3-11945- START
 CRITERE  -= '& [F:HRCTR]CTRDAT = ['+num$([M:CNG1]CTRDAT)+']'
# CRITERE  -= '& [F:CTR]CTRDAT = ['+num$([M:CNG1]CTRDAT)+']'
#MIPEA - 2016-12-22 - X3-11945- END
Endif
If GUSRACS<>2
   CRITERE2 -= '& ([F:TIM]ACS="" | [F:ACC1]CONSUL=2 | [F:ACC1]EXEC=2)' # FQ88082 - SEGAY 23/04/13 test ACS de TIM
Endif

#Périodes de congés
#JASMI - 2014-09-22 - US2983 - START
#CRITERE0  = '([F:CNG]STRPER <=[M:CNG1]DATSEL & [M:CNG1]DATSEL <= [F:CNG]ENDPER)'
#CRITERE0 -= '| ([F:CNG]DEBDAT <= [M:CNG1]DATSEL & [M:CNG1]DATSEL <= [F:CNG]FINDAT )'
#MIPEA - 2016-12-22 - X3-11945- START
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-22 - X3-11945- END
  CRITERE0  = '([F:CNE]EMPLEASTR <=[M:CNG1]DATSEL & [M:CNG1]DATSEL <= [F:CNE]EMPLEAEND)'
Else
  CRITERE0  = '([F:CNG]STRPER <=[M:CNG1]DATSEL & [M:CNG1]DATSEL <= [F:CNG]ENDPER)'
  CRITERE0 -= '| ([F:CNG]DEBDAT <= [M:CNG1]DATSEL & [M:CNG1]DATSEL <= [F:CNG]FINDAT )'
Endif
#JASMI - 2014-09-22 - US2983 - END

#Gestion de la pagination
If CRITERE=OLDCRIT & CRITERE0=OLDCRIT0
 Gosub NAV_FILTER
Endif

Return

######################################################################################
$SORT_FILTER
#Clé de tri des données parcourues en fonction du détail demandé
# FQ88082 - SEGAY 23/04/13 test ACS de TIM
#If CHGPAG>0
#  Filter [F:LNK] Where evalue (CRITERE)
#&                Order By Key CLE = [F:CTR]REFNUM;[F:CTR]CTRNUM;[F:CTR]CTRDAT;[F:CNG]YEA Desc;[F:CNG]TIM
#Else
#  Filter [F:LNK] Where evalue (CRITERE)
#&                Order By Key CLE = [F:CTR]REFNUM;[F:CTR]CTRNUM;[F:CTR]CTRDAT;[F:CNG]YEA Asc;[F:CNG]TIM Desc
#Endif
If CHGPAG>0
#MIPEA - 2016-12-22 - X3-11945- START
  Filter [F:LNK] Where evalue (CRITERE) & evalue(CRITERE2)
&                Order By Key CLE = [F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT;[F:CNG]YEA Desc;[F:CNG]TIM
Else
  Filter [F:LNK] Where evalue (CRITERE) & evalue(CRITERE2)
&                Order By Key CLE = [F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT;[F:CNG]YEA Asc;[F:CNG]TIM Desc
Endif
#  Filter [F:LNK] Where evalue (CRITERE) & evalue(CRITERE2)
#&                Order By Key CLE = [F:CTR]REFNUM;[F:CTR]CTRNUM;[F:CTR]CTRDAT;[F:CNG]YEA Desc;[F:CNG]TIM
#Else
#  Filter [F:LNK] Where evalue (CRITERE) & evalue(CRITERE2)
#&                Order By Key CLE = [F:CTR]REFNUM;[F:CTR]CTRNUM;[F:CTR]CTRDAT;[F:CNG]YEA Asc;[F:CNG]TIM Desc
#Endif
#MIPEA - 2016-12-22 - X3-11945- END

Return

######################################################################################
$CHG_PAGE
If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif
Return

######################################################################################
$TABLE_LINK
# FQ88082 - SEGAY 23/04/13 test ACS de TIM
#Link [F:CTR] With
#&    [F:FCY]FCY0     = [F:CTR]ETRFCY
#&  , [F:CNG]CNG0(1)  = [F:FCY]LEGCPY
#& As [LNK]
#JASMI - 2014-09-22 - US2983 - START
#Link [F:CTR] With
#&    [F:FCY]FCY0     = [F:CTR]ETRFCY
#&  , [F:CNG]CNG0(1)  = [F:FCY]LEGCPY
#&  , [F:TIM]TIM0     = [F:CNG]TIM
#&  , [F:ACC1]CODACC  = GUSER;[F:TIM]ACS
#& As [LNK]
#MIPEA - 2016-12-22 - X3-11945- START
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
  Link [F:HRCTR]   With  [F:FCY]FCY0     =  [F:HRCTR]ETRFCY
&                      , [F:CNG]CNG0(1)  =  [F:FCY]LEGCPY
&                      , [F:TIM]TIM0     =  [F:CNG]TIM
&                      , [F:ACC1]CODACC  =  GUSER;[F:TIM]ACS
&                      , [F:CNE]CNE0     ~= [F:CNG]YEA; [F:HRCTR]REFNUM; [F:HRCTR]CTRNUM; [F:CNG]TIM
&                  As    [LNK]
Else
  Link [F:HRCTR] With
&      [F:FCY]FCY0     = [F:HRCTR]ETRFCY
&    , [F:CNG]CNG0(1)  = [F:FCY]LEGCPY
&    , [F:TIM]TIM0     = [F:CNG]TIM
&    , [F:ACC1]CODACC  = GUSER;[F:TIM]ACS
&   As [LNK]
Endif
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#  Link [F:CTR]   With  [F:FCY]FCY0     =  [F:CTR]ETRFCY
#&                    , [F:CNG]CNG0(1)  =  [F:FCY]LEGCPY
#&                    , [F:TIM]TIM0     =  [F:CNG]TIM
#&                    , [F:ACC1]CODACC  =  GUSER;[F:TIM]ACS
#&                    , [F:CNE]CNE0     ~= [F:CNG]YEA; [F:CTR]REFNUM; [F:CTR]CTRNUM; [F:CNG]TIM
#&                As    [LNK]
#Else
#  Link [F:CTR] With
#&      [F:FCY]FCY0     = [F:CTR]ETRFCY
#&    , [F:CNG]CNG0(1)  = [F:FCY]LEGCPY
#&    , [F:TIM]TIM0     = [F:CNG]TIM
#&    , [F:ACC1]CODACC  = GUSER;[F:TIM]ACS
#&   As [LNK]
#Endif
#JASMI - 2014-09-22 - US2983 - END
#MIPEA - 2016-12-22 - X3-11945- END

Return


######################################################################################
$NAV_FILTER
#Verrai plus tard si possible de dépasser 200 lignes sur cette consultation,
#soient 200 contrats à une date de sélection...
Case CHGPAG

 When  2 :#suite
  CRITERE1  = '[F:CNG]TIM >"'+FINTIM+'"'-'& [F:CNG]YEA >='+FINYEA
  CRITERE1 -= 'CTRNUM >="'+FINCTR+'"'

 When -2 :#retour
  CRITERE1  = '[F:CNG]TIM <"'+DEBTIM+'"'-'& [F:CNG]YEA <='+DEBYEA
  CRITERE1 -= 'CTRNUM <="'+DEBCTR+'"'

Endcase

Return


