######################################################################################
##         Etiquette masque CONSCNG2             00/00/0000 00:00:00 (WGA)          ##
######################################################################################
Subprog AS_NBLIG
NOL = nolign-1
If [M:CNG2]TIM(NOL) <> ""

 [M:CNG2]SLDMIN = ""

 #If sigma(1,[M:CNG2]NBLIG-1,[M:CNG2]CTRDAT(indcum)<>[0/0/0] & [M:CNG2]CTRDAT(indcum)<>[M:CNG2]CTRDAT(indcum-1))
 #si plusieurs dates contrats différentes
#MIPEA - 2016-12-22 - X3-11945- START
  [M:CNG2]SLDMIN -= mess(6,10506,1)-num$([M:CNG2]CTRDAT(NOL))-"-" : # date contrat
#  [M:CNG2]SLDMIN -= mess(6,506,1)-num$([M:CNG2]CTRDAT(NOL))-"-" : # date contrat
#MIPEA - 2016-12-22 - X3-11945- END
 #Endif
#ADNGO - 2017-02-20 - X3-11945 - START
 #Read [F:TIM]TIM0 =[M:CNG2]TIM(NOL)
 Read [F:TIM]TIM0 = GCURLEG;[M:CNG2]TIM(NOL)
#ADNGO - 2017-02-20 - X3-11945 - END
 # Evénement xxx aaaa Solde minimum de nn jour(s)
 [M:CNG2]SLDMIN -= mess(204,100,1)
 [M:CNG2]SLDMIN -= [M:CNG2]TIM(NOL)-num$([M:CNG2]CNGYEA(NOL))
 [M:CNG2]SLDMIN -= mess(1,106,1)-mess(1,147,1)
 [M:CNG2]SLDMIN -= num$([F:TIM]BLCMIN)
 [M:CNG2]SLDMIN -= mess(28,197,1)
 Affzo [M:CNG2]SLDMIN
 Call DETAILFEED(NOL)
Endif
End

