######################################################################################
Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR

If VALEUR = ""
#MIPEA - 2016-12-22 - X3-11945- START
 Raz [F:HRCTR]
# Raz [F:CTR]
#MIPEA - 2016-12-22 - X3-11945- END
 Raz [M:CNG1]CTRDAT
Endif

#MIPEA - 2016-12-23 - X3-11945- START
  If !clalev([F:HRCTR2]) : Local File EMPLOCTR [HRCTR2] : Endif
  If !clalev([F:FCY2]) : Local File FACILITY [FCY2]  : Endif
    Filter  [HRCTR2] Where CTRNUM=VALEUR
    Read [HRCTR2] First
    Filter [HRCTR2]
#    [M:CNG1]REFNUM = [F:HRCTR2]REFNUM
    Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
    If !fstat
    GCURLEG = [F:FCY2]LEG
    [M:CNG1]LEG = GCURLEG
    Affzo [M:CNG1]LEG
    Endif
#MIPEA - 2016-12-23 - X3-11945- END


End
######################################################################################
Subprog AS_DATPYR(VALEUR)
Variable Date    VALEUR
If VALEUR = [00/00/0000] or VALEUR > eomonth(GMOIPAY)  : # pas le futur
# VALEUR = GMOIPAY
 VALEUR = eomonth(GMOIPAY) #SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
Endif
 #SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
Gosub RECH_DAT_PAI
GMESSAGE ="" : # Pour ne pas bloquer la saisie
mkstat = 0

#Sauvegarde de la date du contrat sélectionné
If [M]CTRNUM <> ""
#MIPEA - 2016-12-22 - X3-11945- START
 [M:CNG1]CTRDAT = [F:HRCTR]CTRDAT
# [M:CNG1]CTRDAT = [F:CTR]CTRDAT
#MIPEA - 2016-12-22 - X3-11945- END
Endif

End
######################################################################################
Subprog C_DATPYR(VALEUR)
Variable Date    VALEUR
If VALEUR = [00/00/0000] or VALEUR > eomonth(GMOIPAY)  : # pas le futur
 VALEUR = eomonth(GMOIPAY)
Endif

#/70374
Filter [VEP] Where [VEP]EMP     =  [M]REFNUM
&                & [VEP]PYRDAT <=  VALEUR
Read   [VEP] First
Filter [VEP]
If fstat
 mkstat = 1
#MIPEA - 2016-12-22 - X3-11945- START
 GMESSAGE =mess(24,10702,1)-num$(VALEUR)
# GMESSAGE =mess(24,702,1)-num$(VALEUR) : # Paie non calculée au
#MIPEA - 2016-12-22 - X3-11945- END
 End
Endif
#70374/

#CRITDAT = VALEUR
#Call CADRE_PYRDAT(VALEUR,[F:CTR]ETRFCY) From TPSSUB
#I=0
#While VALEUR > CRITDAT & !mkstat
# # On cherche la plus proche date de paie antérieure à la date sélectionnée
# I+=1
# VALEUR = CRITDAT - I
# Call CADRE_PYRDAT(VALEUR,[F:CTR]ETRFCY) From TPSSUB
#Wend
#SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
Gosub RECH_DAT_PAI
If mkstat : End : Endif

[M:CNG1]DATSEL = VALEUR

#MIPEA - 2016-12-22 - X3-11945- START
[M:CNG1]DEBREG = [F:HRPEOD]PERSTR(2) : # 70676 date debut de régularisation. A utiliser dans criteres de sélection des contrats
[M:CNG1]WDATDEB = [F:HRPEOD]PERSTR(0) : #SEGAY - 23/05/13 - FQ89905  date debut de période. A utiliser dans criteres de sélection des contrats
#[M:CNG1]DEBREG = [F:PEO]PERSTR(2) : # 70676 date debut de régularisation. A utiliser dans criteres de sélection des contrats
#[M:CNG1]WDATDEB = [F:PEO]PERSTR(0) : #SEGAY - 23/05/13 - FQ89905  date debut de période. A utiliser dans criteres de sélection des contrats
#MIPEA - 2016-12-22 - X3-11945- END
End

#SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
$RECH_DAT_PAI
Local Date    CRITDAT
CRITDAT = VALEUR
#MIPEA - 2016-12-22 - X3-11945- START
Call CADRE_PYRDAT(VALEUR,[F:HRCTR]PERCOD) From TPSSUB
#Call CADRE_PYRDAT(VALEUR,[F:CTR]ETRFCY) From TPSSUB
#MIPEA - 2016-12-22 - X3-11945- END
I=0
While VALEUR > CRITDAT & !mkstat
 # On cherche la plus proche date de paie antérieure à la date sélectionnée
 I+=1
 VALEUR = CRITDAT - I
#MIPEA - 2016-12-22 - X3-11945- START
 Call CADRE_PYRDAT(VALEUR,[F:HRCTR]PERCOD) From TPSSUB
# Call CADRE_PYRDAT(VALEUR,[F:CTR]ETRFCY) From TPSSUB
#MIPEA - 2016-12-22 - X3-11945- END
Wend
Return

######################################################################################
Subprog AM_DATPYR(VALEUR)
Variable Date    VALEUR
#     SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
#Call SELCTR([M]REFNUM,VALEUR,VALEUR,[M]CTRNUM) From DIVPAYE
Call SELCTR([M]REFNUM,VALEUR,[M:CNG1]WDATDEB,[M]CTRNUM) From DIVPAYE
# On ne sélectionne que les contrat actif
# Le code contrat peut-être vide pour avoir tous les contrats
#If [M]CTRNUM = ""
# If [M]DATPYR<>[0/0/0]
#  Call SELCTR([M]REFNUM,[M]DATPYR,gdat$(0,0,0),[M]CTRNUM) From DIVPAYE
# Endif
#Endif
#If [M]CTRNUM = ""
# GOK=0 : GMESSAGE =mess(150,702,1) : #Pas de contrat de travail pour ce salarié
# mkstat = 2
# End
#Endif

If [M]CTRNUM <> ""
#MIPEA - 2016-12-22 - X3-11945- START
 [M:CNG1]CTRDAT = [F:HRCTR]CTRDAT
Else
 Raz [F:HRCTR] #SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
# [M:CNG1]CTRDAT = [F:CTR]CTRDAT
#Else
# Raz [F:CTR] #SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
#MIPEA - 2016-12-22 - X3-11945- END
 Raz [M:CNG1]CTRDAT
Endif
Affzo [M]CTRNUM #SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
End

