Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
 #maj nom-prénom
 Read [F:ID]ID0 = VALEUR
 If !fstat
  [M:CNG1]NAMSRN = [F:ID]NAM-[F:ID]SRN
 Endif
 Affzo [M:CNG1]NAMSRN
 #contrat du salarié
 Raz [M]CTRNUM
#     SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
# If [M]DATPYR<>[0/0/0]
#  Call SELCTR(VALEUR,[M]DATPYR,[M]DATPYR,[M]CTRNUM) From DIVPAYE
# Else
#  Call SELCTR(VALEUR,datesyst,datesyst,[M]CTRNUM) From DIVPAYE
# Endif
 If [M]WDATDEB=[0/0/0] and [M]CTRNUM = ""
  Call AS_DATPYR([M]DATPYR)
#MIPEA - 2016-12-22 - X3-11945- START
  [M:CNG1]WDATDEB = [F:HRPEOD]PERSTR(0)
#  [M:CNG1]WDATDEB = [F:PEO]PERSTR(0) : #SEGAY - 23/05/13 - FQ89905  date debut de période. A utiliser dans criteres de sélection des contrats
#MIPEA - 2016-12-22 - X3-11945- END
 Endif
 If [M]DATPYR<>[0/0/0]
  Call SELCTR(VALEUR,[M]DATPYR,[M:CNG1]WDATDEB,[M]CTRNUM) From DIVPAYE
 Else
  Call SELCTR(VALEUR,datesyst,[M:CNG1]WDATDEB,[M]CTRNUM) From DIVPAYE
 Endif

#     SEGAY - 23/05/13 - FQ89905 - Test sur date contrat
# On ne sélectionne que les contrat actif
# Le code contrat peut-être vide pour avoir tous les contrats
# If [M]CTRNUM = ""
#
#  If [M]DATPYR<>[0/0/0]
#   Call SELCTR(VALEUR,[M]DATPYR,gdat$(0,0,0),[M]CTRNUM) From DIVPAYE
#  Else
#   Call SELCTR(VALEUR,gdat$(31,12,9999),gdat$(0,0,0),[M]CTRNUM) From DIVPAYE
#  Endif
#
# Endif
# If [M]CTRNUM = ""
#  GOK=0 : GMESSAGE =mess(150,702,1) : #Pas de contrat de travail pour ce salarié
#  mkstat = 2
#  End
# Endif
 Affzo [M]CTRNUM

#MIPEA - 2016-12-22 - X3-11945- START
 If [F:FCY]FCY <> [F:HRCTR]ETRFCY
 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ : # recherche société
 Endif
# If [F:FCY]FCY <> [F:CTR]ETRFCY
# Call LECTURE("FCY",[F:CTR]ETRFCY,"") From CONTOBJ : # recherche société
# Endif
#MIPEA - 2016-12-22 - X3-11945- END
Endif

End
