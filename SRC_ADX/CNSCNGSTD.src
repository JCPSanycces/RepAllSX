  [M:CNG1]WDATDEB = [F:HRPEOD]PERSTR(0)
#  [M:CNG1]WDATDEB = [F:PEO]PERSTR(0) : #SEGAY - 23/05/13 - FQ89905  date debut de période. A utiliser dans criteres de sélection des contrats
#MIPEA - 2016-12-22 - X3-11945- END
