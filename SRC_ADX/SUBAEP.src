#<AdxTL>@(#)2.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
Call OBJET("AEP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "DEFBOUT"     : Gosub DEFBOUT
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub LIENS
Endcase
Return

$DEFBOUT
NBTEX += 1 : CBOUT(NBTEX) = "1" : TEX(NBTEX) = mess(19,123,1) : # Traitement
NBTEX += 1 : CBOUT(NBTEX) = "2" : TEX(NBTEX) = mess(91,123,1) : # Copie
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU | [M:AEP1]TRAIT=""
 Call VIREBOUT(CHAINE,"12") From GOBJET
Endif
Return

$EXEBOUT
Case REP
 When "1" : Edi =[M:AEP1]TRAIT
 When "2" : Call COPIE(CLECUR1)
Endcase
Return

$LIENS
Call TEXTE([F:AEP]INTIT,[M]ZINTIT) From OBJDIV
Return

#########################################################
Subprog COPIE(TABLE)
Value Char TABLE
Local Integer OK , I
If clalev([M:DIA2])=0
 Local Mask ACOPIE [DIA2]
 Raz [M:DIA2]
 [M]OBJET = mess(76,125,1)-TABLE : # Paramétre
 OK = 2 : Call DIALO(OK,mess(76,125,1)) From GOBJTXT
 If OK<>2 : End : Endif
Endif
Call TEMPON("T") From GESECRAN
If [M]DOSORG=nomap 
 Local File AEPUR   [AEP1] 
 Local File ATEXTE  [ATX1] 
Else 
 Local File =[M]DOSORG+".AEPUR"   [AEP1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1] 
Endif 
If [M]DOSDES=nomap 
 Local File AEPUR   [AEP2] 
 Local File ATEXTE  [ATX2] 
Else 
 Local File =[M]DOSDES+".AEPUR"   [AEP2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
Endif 
Call DEBTRANS From GLOCK
Gosub TR_COP
Call TEMPOFF From GESECRAN
End

$TR_COP
GOK = 1
Trbegin [AEP2] , [ATX2]
 Delete [AEP2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AEPUR" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AEP2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AEP1]AEP0 Where COD=TABLE
  [F:AEP2] = [F:AEP1]
  Call COPTEXTE([F:AEP1]INTIT,[F:AEP2]INTIT) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:AEP2]UPDUSR)>0 : [F:AEP2]UPDUSR = GUSER : Endif
  If dim([F:AEP2]UPDDAT)>0 : [F:AEP2]UPDDAT = date$ : Endif
  If dim([F:AEP2]UPDTIM)>0 : [F:AEP2]UPDTIM = time : Endif
  Write [AEP2]
  If fstat
   GOK=0 : Call FSTA("AEP2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

########################################
Subprog C_COD(VALEUR)
Variable Char    VALEUR()
End

Subprog C_OBJET(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call CONTROLE("AOB","",VALEUR,"",mkstat) From CONTOBJ
Endif
End

Subprog S_OBJET(VALEUR)
Variable Char    VALEUR()
Call SELECT("AOB","",VALEUR,"") From SELOBJ
End

Subprog AS_CODFIC(VALEUR)
Variable Char    VALEUR()
If [M]OBJET<>""
 Call LECTURE("AOB",[M]OBJET,"") From CONTOBJ
 VALEUR = [F:AOB]NOMFIC : mkstat = 2 : End
Endif
End

Subprog C_CODFIC(VALEUR)
Variable Char    VALEUR()
End

Subprog C_DAT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [ATZ]CODZONE = [M]CODFIC;VALEUR
 If fstat
  GMESSAGE = mess(8,124,1) : # Zone inexistante
  mkstat = 2 : End
 Else
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  If [F:ATY]TYPTYP<>8
   GMESSAGE = mess(10,124,1) : # Type de zone incorrect
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog S_DAT(VALEUR)
Variable Char VALEUR()
Local Integer NBTEX , CHOI
Local Char    TEXTE(50) , TEX(50)(50)
NBTEX = 0
If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
For [ATZ]CODZONE Where CODFIC=[M]CODFIC
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 If [F:ATY]TYPTYP=8
  NBTEX += 1
  Call TEXTE([F:ATZ]NOCOURT,TEXTE) From OBJDIV
  TEX(NBTEX) = format$("K:12X",[F:ATZ]CODZONE)+TEXTE
 Endif
Next
If NBTEX>0
 Call SAITEX(NBTEX,TEX,CHOI,"") From GESECRAN
 If CHOI<>0 & status<>7
  VALEUR = vireblc(left$(TEX(CHOI),10),2)
 Endif
Endif
End

Subprog C_FIY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]DAT=""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Elsif VALEUR<>"" 
 Read [ATZ]CODZONE = [M]CODFIC;VALEUR
 If fstat
  GMESSAGE = mess(8,124,1) : # Zone inexistante
  mkstat = 2 : End
 Else
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  If [F:ATY]TYPTYP<>2
   GMESSAGE = mess(10,124,1) : # Type de zone incorrect
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog S_FIY(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEX , CHOI
Local Char    TEXTE(50) , TEX(50)(50)
NBTEX = 0
If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
For [ATZ]CODZONE Where CODFIC=[M]CODFIC
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 If [F:ATY]TYPTYP=2
  NBTEX += 1
  Call TEXTE([F:ATZ]NOCOURT,TEXTE) From OBJDIV
  TEX(NBTEX) = format$("K:12X",[F:ATZ]CODZONE)+TEXTE
 Endif
Next
If NBTEX>0
 Call SAITEX(NBTEX,TEX,CHOI,"") From GESECRAN
 If CHOI<>0 & status<>7
  VALEUR = vireblc(left$(TEX(CHOI),10),2)
 Endif
Endif
End

Subprog C_TRAIT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & filinfo(filpath("TRT",VALEUR,"adx"),0)<0
 GMESSAGE = mess(90,123,1) : # Traitement inexistant
 mkstat = 2 : End
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [ATZ]CODZONE = [M]CODFIC;VALEUR
 If fstat
  GMESSAGE = mess(8,124,1) : # Zone inexistante
  mkstat = 2 : End
 Elsif [F:ATZ]CODTYP<>"CPY" & [F:ATZ]CODTYP<>"FCY"
  GMESSAGE = mess(10,124,1) : # Type de zone incorrect
  mkstat = 2 : End
 Endif
Endif
End

Subprog S_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEX , CHOI
Local Char    TEXTE(50) , TEX(50)(50)
NBTEX = 0
For [ATZ]CODZONE Where CODFIC=[M]CODFIC & CODTYP="CPY"
 NBTEX += 1
 Call TEXTE([F:ATZ]NOCOURT,TEXTE) From OBJDIV
 TEX(NBTEX) = format$("K:12X",[F:ATZ]CODZONE)+TEXTE
Next
If NBTEX>0
 Call SAITEX(NBTEX,TEX,CHOI,"") From GESECRAN
 If CHOI<>0 & status<>7
  VALEUR = vireblc(left$(TEX(CHOI),10),2)
 Endif
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [ATZ]CODZONE = [M]CODFIC;VALEUR
 If fstat
  GMESSAGE = mess(8,124,1) : # Zone inexistante
  mkstat = 2 : End
 Elsif [F:ATZ]CODTYP<>"FCY" & [F:ATZ]CODTYP<>"CPY"
  GMESSAGE = mess(10,124,1) : # Type de zone incorrect
  mkstat = 2 : End
 Endif
Endif
End

Subprog S_FCY(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEX , CHOI
Local Char    TEXTE(50) , TEX(50)(50)
NBTEX = 0
For [ATZ]CODZONE Where CODFIC=[M]CODFIC & CODTYP="FCY"
 NBTEX += 1
 Call TEXTE([F:ATZ]NOCOURT,TEXTE) From OBJDIV
 TEX(NBTEX) = format$("K:12X",[F:ATZ]CODZONE)+TEXTE
Next
If NBTEX>0
 Call SAITEX(NBTEX,TEX,CHOI,"") From GESECRAN
 If CHOI<>0 & status<>7
  VALEUR = vireblc(left$(TEX(CHOI),10),2)
 Endif
Endif
End

