#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "AP_IMPORT"   : Gosub AP_IMPORT
  Endcase
Return


####################################################################
# Après l'import d'une ligne du fichier en entrée
#
$AP_IMPORT
  Case SEPNUM
    When 2 : 
      Gosub ALI_PBS
      OK = 0
    When Default
  Endcase
Return


$ALI_PBS
Local Integer I

  If [F:PBS]NUMCOD<>[M:COA4]NUM Then
    If !clalev([F:PBS2]) Then Local File GAPARBSE [PBS2] Endif
    Filter [PBS2] Where COA = [M:COA0]COA and NUMCOD = [F:PBS]NUMCOD
    [M:COA4]NUM  = [F:PBS]NUMCOD
    [M:COA4]NBLIG= rowcount([F:PBS2])
    Raz [M:COA4]ACCSTR, CODCDT, CODDEB
    I=0
    For [PBS2]PBS0
      [M:COA4]ACCSTR(I) = [F:PBS2]ACCSTR
      [M:COA4]CODCDT(I) = [F:PBS2]CODCDT
      [M:COA4]CODDEB(I) = [F:PBS2]CODDEB
      I+=1
    Next
    Filter [PBS2]
    If clalev([F:PBS2]) Then Close Local File [PBS2] Endif
  Endif

  nolign = [M:COA4]NBLIG+1

  If find( [F:PBS]ACCSTR, [M:COA4]ACCSTR) Then
  Else
    [M:COA4]NUM = [F:PBS]NUMCOD
    [M:COA4]ACCSTR(nolign-1) = [F:PBS]ACCSTR
    [M:COA4]CODCDT(nolign-1) = [F:PBS]CODCDT 
    [M:COA4]CODDEB(nolign-1) = [F:PBS]CODDEB 

    [M:COA4]NBLIG +=1
  Endif
Return


