Call TEXTE(5169,TIT) From OBJDIV
Return

$SETCLE
Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..3) , CLELIG(GLONAVA)
CLEPRIM = 'CTRNUM'
CLESEC(0) = 'REFNUM'
CLESEC(1) = 'CTRDAT'
CLESEC(2) = 'DOCCLA'
CLESEC(3) = 'CODCLA'
Return

$OPTIONS
Local Integer  NBCOND
Local Char     CONDIT(50)(1..20)
Local Char     OPT(1)(1..20) , OPTSEL(20)
Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
OPTSEL = ''
Return

$LIBPAR
Local Char LIBPAR(30)
Call TEXTE(0,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(30)(0..GNBDERNIER)
Local Char     A_BUF2(10)(0..GNBDERNIER)
Local Date     A_BUF3(0..GNBDERNIER)
Local Char     A_BUF4(20)(0..GNBDERNIER)
Local Char     A_BUF5(10)(0..GNBDERNIER)
If clalev([F:HRTXC9])>0 : Close Local File [HRTXC9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(30),
& Char     A_TAB2(10),
& Date     A_TAB3,
& Char     A_TAB4(20),
& Char     A_TAB5(10)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5
& As [HRTXC9]
Return

$LEC_DERLU
Read [AFF]AFF0 = [F:HRTXC]ETRFCY;GPROFIL;GUSRFCT
If fstat : Raz [F:AFF] : Endif
Read [ID]ID0=[F:HRTXC]REFNUM
If fstat : Raz [F:ID] : Endif
Read [ACC]CODACC=GUSER;[F:ID]CODACS
If fstat : Raz [F:ACC] : Endif
Read [ECT]ECT0=[F:HRTXC]REFNUM;[F:HRTXC]CTRNUM
If fstat : Raz [F:ECT] : Endif
Read [FCY]FCY0=[F:HRTXC]ETRFCY
If fstat : Raz [F:FCY] : Endif
Read [AD1]ADW0='*';[F:FCY]LEG;'TYPDOC'
If fstat : Raz [F:AD1] : Endif
Read [AD2]ADW0='';'';'TYPDOC'
If fstat : Raz [F:AD2] : Endif
Return

$CHARGE_DERLU
If clalev([F:HRTXC9])>0
 Read [HRTXC9] = [F:HRTXC9]A_TABI
 [L]CLE = [F:HRTXC9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:HRTXC9])>0
 Filter [HRTXC9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [TXC0] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:HRTXC9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:HRTXC]CTRNUM+"~"
 A_CLEDERLU += [F:HRTXC]REFNUM+"~"
 A_CLEDERLU += [F:HRTXC]CTRDAT+"~"
 A_CLEDERLU += num$([F:HRTXC]DOCCLA)+"~"
 A_CLEDERLU += [F:HRTXC]CODCLA+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:HRTXC9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:HRTXC9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 2
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(1)"
SELEXP(NBSEL) = "[F:HRTXC]REFNUM-[F:ID]NAM-[F:ID]SRN"
Call TEXTE(44921,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(2)"
SELEXP(NBSEL) = "string$(val([F:AD1]VALEUR)<>0,mess([F:HRTXC]DOCCLA,val([F:AD1]VALEUR),1))+ string$(val([F:AD1]VALEUR)=0 & val([F:AD2]VALEUR)<>0,mess([F:HRTXC]DOCCLA,val([F:AD2]VALEUR),1))"
Call TEXTE(5169,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[F:HRTXC]CTRDAT"
Call TEXTE(212,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 8
SELFMT(NBSEL) = ""
SELFOR(NBSEL) = "DZz:"+GFMDAT4
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:HRTXC]CTRDAT"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:HRTXC]CTRNUM"
Call TEXTE(5481,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:HRTXC]CTRNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:HRTXC]CODCLA"
Call TEXTE(5296,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10B"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:HRTXC]CODCLA"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:HRTXC_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
If clalev([F:ACC])=0 : Local file ACCES [ACC] : Endif
If clalev([F:ECT])=0 : Local file EMPCTR [ECT] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:AD1])=0 : Local file ADOVAL [AD1] : Endif
If clalev([F:AD2])=0 : Local file ADOVAL [AD2] : Endif
Link [HRTXC] With
& [AFF]AFF0~=[F:HRTXC]ETRFCY;GPROFIL;GUSRFCT,
& [ID]ID0=[F:HRTXC]REFNUM,
& [ACC]CODACC=GUSER;[F:ID]CODACS,
& [ECT]ECT0=[F:HRTXC]REFNUM;[F:HRTXC]CTRNUM,
& [FCY]FCY0=[F:HRTXC]ETRFCY,
& [AD1]ADW0='*';[F:FCY]LEG;'TYPDOC',
& [AD2]ADW0='';'';'TYPDOC'
& As [HRTXC_]
[G:HRTXC_]currind = 2
Return

$DEFAUT_LISTE
Default file [HRTXC_]
Return

$OUVRE_JOIN
Local Char    ORDRE_JOI(250)
ORDRE_JOI = "A_TABJ1;A_TABJ2;A_TABJ3;A_TABJ4;A_TABJ5"
Local Char     A_BUFJ1(15)(1..GNBSEL)
Local Char     A_BUFJ2(20)(1..GNBSEL)
Local Date     A_BUFJ3(1..GNBSEL)
Local Shortint A_BUFJ4(1..GNBSEL)
Local Char     A_BUFJ5(10)(1..GNBSEL)
Local Char     A_BUFJ6(15)(1..GNBSEL)
Local Char     A_BUFJ7(80)(1..GNBSEL)
Local File(
& Char     A_TABJ1(15),
& Char     A_TABJ2(20),
& Date     A_TABJ3,
& Shortint A_TABJ4,
& Char     A_TABJ5(10),
& Char     A_TABJ6(15),
& Char     A_TABJ7(80)
& ) From Variable A_BUFJ1, A_BUFJ2, A_BUFJ3, A_BUFJ4, A_BUFJ5, A_BUFJ6, A_BUFJ7
& As [PCEJ]
Return

$TIT_JOIN
Local Char TITJOI(30)(1..7)
Call TEXTE(10793,TITJOI(1)) From OBJDIV
Call TEXTE(5481,TITJOI(2)) From OBJDIV
Call TEXTE(212,TITJOI(3)) From OBJDIV
Call TEXTE(5169,TITJOI(4)) From OBJDIV
Call TEXTE(5296,TITJOI(5)) From OBJDIV
TITJOI(6) = mess(59,100,1) : # Type
TITJOI(7) = mess(38,100,1) : # Nom
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Kf:20c"
LG = 0
TIT = ""
End

Subprog FORMCLE2(FMT)
Variable Char    FMT()
FMT = "Kf:15c"
End

$LIENS
Read [ID]ID0 = [F:HRTXC]REFNUM
If fstat : Raz [F:ID] : Endif
Read [ACC]CODACC = GUSER;[F:ID]CODACS
If fstat : Raz [F:ACC] : Endif
Read [ECT]ECT0 = [F:HRTXC]REFNUM;[F:HRTXC]CTRNUM
If fstat : Raz [F:ECT] : Endif
Read [FCY]FCY0 = [F:HRTXC]ETRFCY
If fstat : Raz [F:FCY] : Endif
Read [AD1]ADW0 = '*';[F:FCY]LEG;'TYPDOC'
If fstat : Raz [F:AD1] : Endif
Read [AD2]ADW0 = '';'';'TYPDOC'
If fstat : Raz [F:AD2] : Endif
Return

