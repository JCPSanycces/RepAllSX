#<AdxTL>@(#)6.0.0.0 $Revision$
########################################################################
##  Subprog SERVEUR(DOSSIER,PID)
##  Subprog PROCESS(PROCESS,STAT)
##  Subprog KILLP(PROCESS)
##  Subprog REQUETE(PID)
##  Subprog SERV_PID
##  Subprog RQT_PID
########################################################################

Subprog SERVEUR(DOSSIER,PID)
Value    Char DOSSIER
Variable Char PID
Gosub DCL_SERV
Call EFFACE(FICPID,STAT) From ORDSYS
Case GOS(1)
 When "unix"
  Gosub SET_FICENT
  Gosub SERV_UNIX
 When "dos"
  If adxmac(0)<>""
   Call ERREUR(mess(41,134,1)) From GESECRAN : # Cette fonction doit être effectuée sur le serveur
   End
  Endif
  Gosub SERV_DOS
Endcase
Gosub LEC_PID
End

########################################################################
$SERV_UNIX
Local Char MACENT(30) , MACOUT(30) , FICENT2(250) , FICOUT2(250)
Call MACHINE(FICENT,MACENT,FICENT2) From ORDSYS
Call MACHINE(FICOUT,MACOUT,FICOUT2) From ORDSYS
ORDRE = 'USER_ENTREP="'+GUSER+'~'+GLOGIN+'"'
If [F:ABP]RQTLOG>=2
 ORDRE -= 'TRA_ENTREP="'+num$([F:ABP]RQTLOG)+'"' : # Trace déclenchement requête (.log)
Endif
ORDRE -= 'adonix -a -s'-num$(adxtcp)
If [F:ABP]RQTLOG=-1
 ORDRE -= '-w 0*' : # Trace ligne à ligne de tous les traitements dans $ADXDIR/tmp/adotra_XXXXX_0.tra
Endif
If dim([S]secmod)>0 & dim([S]adxcpw)>0
 If [S]adxcpw<>'' : # Passwd passé par le serveur batch
  ORDRE -= '-y'-[S]adxcpw
  If [S]secmod=2 : # Kerberos
   ORDRE -= '-k'
  Endif
 Endif
Endif
ORDRE -= '-l'-GLANGUE-DOSSIER
ORDRE -= '<'+FICENT2-'>'+FICOUT2-'2>&1'
If len(ORDRE)>=250
 # Ligne de commande trop longue pour exécution en arrière plan
 Call ERREUR(mess(195,139,1)-GOS(1)) From GESECRAN
Else
 If [F:ABP]RQTLOG=2
  Call TRACE_LOG(ORDRE,0,0) From SERVEUR
 Endif
 Call SYSTEME(adxmac(0),ORDRE,"&",STAT) From ORDSYS
Endif
Return

########################################################################
$SERV_DOS
Openo FICBAT , 0 Using [CMD]
Iomode adxifs "" Using [CMD]
Iomode adxirs GIRS(1) Using [CMD]
Iomode adxium GASCII Using [CMD]
Wrseq "@echo off" Using [CMD]
If adxmac(0)=""
 #102739
 #Wrseq "SET ADXDIR="+adxdir Using [CMD]
 #Wrseq "SET TMPDIR="+adxdir+"\tmp" Using [CMD]
 #Wrseq "SET PATH=%ADXDIR%\ebin;%ADXDIR%\bin;%ADXDIR%\lib;%PATH%" Using [CMD]
Endif
Wrseq "SET USER_ENTREP="+GUSER+"~"+GLOGIN Using [CMD]
If [F:ABP]RQTLOG>=2
 Wrseq "SET TRA_ENTREP="+num$([F:ABP]RQTLOG) Using [CMD]
Endif
ORDRE = "start adonix"
If GTEST : # JML 20/11/98 Mode spéciale sleep 30s pour debug adonix
 ORDRE -= "-# 30"
Endif
ORDRE -= "-a -s"-num$(adxtcp)
If [F:ABP]RQTLOG=-1
 ORDRE -= '-w 0*' : # Trace ligne à ligne de tous les traitements dans $ADXDIR/tmp/adotra_XXXXX_0.tra
Endif
If dim([S]secmod)>0 & dim([S]adxcpw)>0
 If [S]adxcpw<>"" : # Passwd passé par le serveur batch
  ORDRE -= "-y"-[S]adxcpw
  If [S]secmod=2 : # Kerberos
   ORDRE -= "-k"
  Endif
 Endif
Endif
ORDRE -= "-l"-GLANGUE-DOSSIER
Wrseq ORDRE Using [CMD]
Wrseq "exit" Using [CMD]
Openo Using [CMD]
Local Char MACBAT(30),FICBAT2(250)
Call MACHINE(FICBAT,MACBAT,FICBAT2) From ORDSYS
ORDRE = 'start "Serveur Batch '+DOSSIER+'" /MIN'-FICBAT2
If [F:ABP]RQTLOG=2
 Call TRACE_LOG(ORDRE,0,0) From SERVEUR
Endif
Call SYSTEME(adxmac(0),ORDRE,"b",STAT) From ORDSYS
Return

########################################################################
$SET_FICENT
Openo FICENT , 0 Using [CMD]
Iomode adxifs "" Using [CMD]
Iomode adxirs chr$(10) Using [CMD]
Iomode adxium GASCII Using [CMD]
Wrseq string$(255,10) Using [CMD]
Wrseq string$(255,10) Using [CMD]
Wrseq string$(255,10) Using [CMD]
Wrseq string$(255,10) Using [CMD]
Openo Using [CMD]
Return

##########################################################################################
##  Test d'existence d'un processus sur une machine sur laquelle tourne un moteur Adonix ##
##########################################################################################
Subprog SRVPROCESS(MACHINE,PORT,PROCESS,MORT)
Value    Char    MACHINE
Value    Integer PORT
Value    Char    PROCESS
Variable Integer MORT

If adxmac(0)="" & MACHINE=adxmac(-1)
 MACHINE=""
Endif
Goto SEARCH_PROCESS

###########################################################
##  Test d'existence d'un processus sur l'appli courante ##
###########################################################
Subprog PROCESS(PROCESS,MORT)
Value    Char    PROCESS
Variable Integer MORT
Local Char MACHINE(250) : MACHINE=adxmac(0)
Local Integer PORT : PORT=adxtcp

$SEARCH_PROCESS
Local Integer STAT
If vireblc(PROCESS,2)="" : MORT = 1 : End : Endif

Local Char MACFULL(250)
MACFULL=MACHINE+":"+num$(PORT)

Local Char OS(10)
If MACHINE="" | MACHINE=adxmac(0)
 [L]OS=GOS(1)
Else
 Call GET_OS(MACFULL,[L]OS) From ORDSYS
Endif

Local Char    ORDRE(250)
Local Char    RESULT(250)
Local Integer IJ
Local Char    FICBAT(GDIMFIC) , SYSBAT(GDIMFIC) , FICRES(GDIMFIC) , SYSRES(GDIMFIC)
Case [L]OS
 When "unix"
  ORDRE = "ent_ps" - PROCESS - ">/dev/null ; echo $?"
  If MACHINE=""
   Call SYSTEME2(MACHINE,ORDRE,"",STAT,RESULT) From ORDSYS
  Else
   Call SYSTEME2(MACFULL,ORDRE,"",STAT,RESULT) From ORDSYS
  Endif
  MORT = val(RESULT)
 When "dos"
  If MACHINE=""
   FICBAT = func SERVSYS.GET_ONEFILE_BATCH("tmp","psadx"+[L]PROCESS,"bat")
  Else
   FICBAT = filpath("!tmp","psadx"+[L]PROCESS,"bat","","",MACFULL)
  Endif
  SYSBAT = FICBAT
  IJ = instr(1,FICBAT,"@")
  If IJ
   SYSBAT = right$(SYSBAT,IJ+1)
  Endif
  If MACHINE=""
  FICRES = func SERVSYS.GET_ONEFILE_BATCH("tmp","psadx"+[L]PROCESS,"res")
  Else
  FICRES = filpath("!tmp","psadx"+[L]PROCESS,"res","","",MACFULL)
  Endif
  SYSRES = FICRES
  IJ = instr(1,SYSRES,"@")
  If IJ
   SYSRES = right$(SYSRES,IJ+1)
  Endif
  Openo FICBAT , 0 Using [CMD]
  Iomode adxifs "" Using [CMD]
  Iomode adxirs GIRS(1) Using [CMD]
  Iomode adxium GASCII Using [CMD]
  Wrseq "@ECHO off" Using [CMD]
  # PC 13/12/99 changement de la syntaxe des Wrseq. Les '"' ne sont plus generes dans "psadxXXX.bat".
  # JML 20/11/98 -e permet de tester l'existence, renvoi STILL ALIVE ou rien
  #     Marche désormais avec no process système
  If MACHINE=""
   #102739
   #Wrseq "SET ADXDIR="+adxdir Using [CMD]
   #Wrseq "SET TMPDIR="+adxdir+"\tmp" Using [CMD]
   #Wrseq "SET PATH=%ADXDIR%\ebin;%ADXDIR%\bin;%PATH%" Using [CMD]
   Wrseq "%ADXDIR%\bin\killadx.exe -e"-num$(val([L]PROCESS))-">"-SYSRES Using [CMD]
  Else
   Wrseq "killadx.exe -e"-num$(val([L]PROCESS))-">"-SYSRES Using [CMD]
  Endif
  Wrseq "exit" Using [CMD]
  Openo Using [CMD]
  ORDRE = '"'+SYSBAT+'"'
  If MACHINE=""
  Call SYSTEME(MACHINE,ORDRE,"",STAT) From ORDSYS
  Else
  Call SYSTEME(MACFULL,ORDRE,"",STAT) From ORDSYS
  Endif
  Openi FICRES Using [CMD]
  Iomode adxifs "" Using [CMD]
  Iomode adxirs GIRS(1) Using [CMD]
  Iomode adxium GASCII Using [CMD]
  MORT = 1
  Rdseq RESULT Using [CMD]
  While !fstat
   If pat(RESULT,"*STILL ALIVE*")>0 : MORT = 0 : Endif
   Rdseq RESULT Using [CMD]
  Wend
  Openi Using [CMD]
  Call EFFACE(FICBAT,STAT) From ORDSYS
  Call EFFACE(FICRES,STAT) From ORDSYS
Endcase
End

##########################################################################################
##  Destruction d'un processus sur une machine sur laquelle tourne un moteur Adonix ##
##########################################################################################
Subprog SRVKILLP(MACHINE,PORT,PROCESS)
Value    Char    MACHINE
Value    Integer PORT
Value Char PROCESS
#MACHINE is always filled
If adxmac(0)="" & MACHINE=adxmac(-1)
 MACHINE=""
Endif
Goto KILL_PROCESS
###########################################################
##  Destruction d'un processus sur l'appli courante ##
###########################################################
Subprog KILLP(PROCESS)
Value Char PROCESS
Local Char MACHINE(250) : MACHINE=adxmac(0)
Local Integer PORT : PORT=adxtcp

$KILL_PROCESS
If vireblc(PROCESS,2)="" : End : Endif

Local Char MACFULL(250)
MACFULL=MACHINE+":"+num$(PORT)

Local Char OS(10)
If MACHINE="" | MACHINE=adxmac(0)
 [L]OS=GOS(1)
Else
 Call GET_OS(MACFULL,[L]OS) From ORDSYS
Endif

Local Integer MORT, STAT
Local Char    ORDRE(250)
Local Char    RESULT(250)
Local Integer IJ
Local Char    FICBAT(GDIMFIC) , SYSBAT(GDIMFIC) , FICRES(GDIMFIC) , SYSRES(GDIMFIC)

Case [L]OS
 When "unix"
  ORDRE = "kill -1"-PROCESS
  If MACHINE=""
   Call SYSTEME(MACHINE,ORDRE,"",STAT) From ORDSYS
  Else
   Call SYSTEME(MACFULL,ORDRE,"",STAT) From ORDSYS
  Endif
  For IJ=1 To 5
   Sleep 1
   Call SRVPROCESS(MACHINE,PORT,PROCESS,MORT)
   If MORT : Break : Endif
  Next IJ
  If !MORT
   ORDRE = "kill -9"-PROCESS
   If MACHINE=""
    Call SYSTEME(MACHINE,ORDRE,"",STAT) From ORDSYS
   Else
    Call SYSTEME(MACFULL,ORDRE,"",STAT) From ORDSYS
   Endif
  Endif
 When "dos"
  If MACHINE=""
   FICBAT = func SERVSYS.GET_ONEFILE_BATCH("tmp","killadx"+[L]PROCESS,"bat")
  Else
   FICBAT = filpath("!tmp","killadx"+[L]PROCESS,"bat","","",MACFULL)
  Endif
  SYSBAT = FICBAT
  IJ = instr(1,FICBAT,"@")
  If IJ
   SYSBAT = right$(SYSBAT,IJ+1)
  Endif
  If MACHINE=""
   FICRES = func SERVSYS.GET_ONEFILE_BATCH("tmp","killadx"+[L]PROCESS,"res")
  Else
   FICRES = filpath("!tmp","killadx"+[L]PROCESS,"res","","",MACFULL)
  Endif
  SYSRES = FICRES
  IJ = instr(1,SYSRES,"@")
  If IJ
   SYSRES = right$(SYSRES,IJ+1)
  Endif
  Openo FICBAT , 0 Using [CMD]
  Iomode adxifs "" Using [CMD]
  Iomode adxirs GIRS(1) Using [CMD]
  Iomode adxium GASCII Using [CMD]
  Wrseq "@echo off" Using [CMD]
  If adxmac(0)=""
   #102739
   #Wrseq 'SET ADXDIR='+adxdir Using [CMD]
   #Wrseq 'SET TMPDIR='+adxdir+'\tmp' Using [CMD]
   #Wrseq "SET PATH=%ADXDIR%\ebin;%ADXDIR%\bin;%PATH%" Using [CMD]
   Wrseq "%ADXDIR%\bin\killadx.exe"-num$(val([L]PROCESS))-">"-SYSRES Using [CMD]
  Else
   Wrseq "killadx.exe"-num$(val([L]PROCESS))-">"-SYSRES Using [CMD]
  Endif
  Wrseq "exit" Using [CMD]
  Openo Using [CMD]
  ORDRE = '"'+SYSBAT+'"'
  If MACHINE=""
   Call SYSTEME(MACHINE,ORDRE,"",STAT) From ORDSYS
  Else
   Call SYSTEME(MACFULL,ORDRE,"",STAT) From ORDSYS
  Endif
  Openi FICRES Using [CMD]
  Iomode adxifs "" Using [CMD]
  Iomode adxirs GIRS(1) Using [CMD]
  Iomode adxium GASCII Using [CMD]
  Rdseq RESULT Using [CMD]
  If !fstat & RESULT<>""
   Call ECR_TRACE(RESULT,1) From GESECRAN
  Endif
  Openi Using [CMD]
  Call EFFACE(FICBAT,STAT) From ORDSYS
  Call EFFACE(FICRES,STAT) From ORDSYS
Endcase
End

###############################
##  Exécution d'une requête  ##
###############################
Subprog REQUETE(PID)
Variable Char PID
Local Char LANGUE(5)
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER = [F:ABR]DOSSIER
GPE = 0
GPOINT = "LANRUN" : Gosub ENTREE From EXEFNC
If !GPE
 #109897
 #If find(GLANGUE,[F:ADS]LAN(0..[F:ADS]NBRLAN-1))
 # LANGUE = GLANGUE
 #Else
 # LANGUE = [F:ADS]LAN(0)
 #Endif
 If dim([F:ABR]LAN)>0 & [F:ABR]LAN<>""
  LANGUE = [F:ABR]LAN
 Elsif [F:ADS]DOSREF=[F:ABR]DOSSIER
  LANGUE = GLANGUE
 Else
  LANGUE = [F:ADS]LANDEF
 Endif
 If find(LANGUE,[F:ADS]LAN(0..[F:ADS]NBRLAN-1))=0
  LANGUE = [F:ADS]LAN(0)
 Endif
Endif
Gosub DCL_RQT
Call EFFACE(FICPID,STAT) From ORDSYS
Case GOS(1)
 When "unix"
  Gosub RQT_UNIX
 When "dos"
  Gosub RQT_DOS
Endcase
## Trace
If getenv$("TRA_ENTREP")<>""
 Call TRACE_LOG(ORDRE,[L]NUMREQ,0) From SERVEUR
Endif
##  Exécution
Call SYSTEME(adxmac(0),ORDRE,OPT,STAT) From ORDSYS
Gosub LEC_PID
##  Trace du serveur, activation requête
Call STRACE(FICTRA,51000,[F:ABR]NUMREQ,mess(15,134,1)-"("+RQTID-PID+")") From SERVEUR
End

########################################################################
$RQT_UNIX
ORDRE  = 'EXEC_ENTREP="BATCH"'
ORDRE -= 'USER_ENTREP="'+[F:ABR]USER+'"'
ORDRE -= 'TRA_ENTREP="'+getenv$("TRA_ENTREP")+'"'
ORDRE -= 'RQT_ENTREP="'+num$([F:ABR]NUMREQ)+'"'
If [F:ABR]PRIO<>0
 ORDRE -= 'nice -'+num$([F:ABR]PRIO)
Endif
ORDRE -= "adonix -a"-SERVICE
If [F:ABP]RQTLOG=-1
 ORDRE -= '-w 0*' : # Trace ligne à ligne de tous les traitements dans $ADXDIR/tmp/adotra_XXXXX_0.tra
Endif
If dim([S]secmod)>0 & dim([S]adxcpw)>0
 If [S]adxcpw<>"" : # Passwd passé par le serveur batch
  ORDRE -= "-y"-[S]adxcpw
  If [S]secmod=2 : # Kerberos
   ORDRE -= "-k"
  Endif
 Endif
Endif
ORDRE -= "-l"-LANGUE-[F:ABR]DOSSIER
ORDRE -= "<"+FICENT
If getenv$("TRA_ENTREP")<>"" & len(ORDRE)+len(FICOUT)+7<type(ORDRE)-10
 ORDRE -= ">>"+FICOUT-"2>&1"
Else
 ORDRE -= ">/dev/null 2>&1"
Endif
OPT = "&"
Return

########################################################################
$RQT_DOS
Openo FICBAT , 0 Using [CMD]
Iomode adxifs "" Using [CMD]
Iomode adxirs GIRS(1) Using [CMD]
Iomode adxium GASCII Using [CMD]
Wrseq "@echo off" Using [CMD]
If adxmac(0)=""
 #102739
 #Wrseq "SET ADXDIR="+adxdir Using [CMD]
 #Wrseq "SET TMPDIR="+adxdir+"\tmp" Using [CMD]
 #Wrseq "SET PATH=%ADXDIR%\ebin;%ADXDIR%\bin;%ADXDIR%\lib;%PATH%" Using [CMD]
Endif
Wrseq "set EXEC_ENTREP=BATCH" Using [CMD]
Wrseq "set USER_ENTREP="+[F:ABR]USER Using [CMD]
Wrseq "set TRA_ENTREP="+getenv$("TRA_ENTREP") Using [CMD]
Wrseq "set RQT_ENTREP="+num$([F:ABR]NUMREQ) Using [CMD]
ORDRE = "start adonix -a"-SERVICE
If [F:ABP]RQTLOG=-1
 ORDRE -= '-w 0*' : # Trace ligne à ligne de tous les traitements dans $ADXDIR/tmp/adotra_XXXXX_0.tra
Endif
If dim([S]secmod)>0 & dim([S]adxcpw)>0
 If [S]adxcpw<>"" : # Passwd passé par le serveur batch
  ORDRE -= "-y"-[S]adxcpw
  If [S]secmod=2 : # Kerberos
   ORDRE -= "-k"
  Endif
 Endif
Endif
ORDRE -= "-l"-LANGUE-[F:ABR]DOSSIER
Wrseq ORDRE Using [CMD]
Wrseq "exit" Using [CMD]
Openo Using [CMD]
##  Exécution
Local Char SYSBAT(GDIMFIC)
SYSBAT = FICBAT
IJ = instr(1,FICBAT,"@")
If IJ
 SYSBAT = right$(SYSBAT,IJ+1)
Endif
ORDRE  = 'start "ADONIX'-RQTID-'('+num$([F:ABR]NUMREQ)+')" /MIN'-SYSBAT
OPT = "b"
Return

###########################################
##  Déclaration lancement serveur batch  ##
###########################################
$DCL_SERV
Local Char    FICENT(GDIMFIC)
Local Char    FICOUT(GDIMFIC)
Local Char    FICTRA(GDIMFIC)
Local Char    FICTRQ(GDIMFIC)
Local Char    FICBAT(GDIMFIC)
Local Char    FICPID(GDIMFIC)
Local Char    ORDRE(GDIMFIC)
Local Char    RQTID(50)
Local Integer NUMREQ
Local Integer STAT
FICENT = filpath("tmp","serveur","ent",DOSSIER,"",adxmac(0))
FICOUT = filpath("tmp","serveur","out",DOSSIER,"",adxmac(0))
FICTRA = func SERVSYS.GET_FILE_SERVEUR("tra")        # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
FICBAT = filpath("tmp","serveur","bat",DOSSIER,"",adxmac(0))
FICPID = filpath("tmp","serveur","pid",DOSSIER,"",adxmac(0))
Return

##########################################################
##  Déclaration exécution requête par le serveur batch  ##
##########################################################
$DCL_RQT
Local Char    FICENT(GDIMFIC)
Local Char    FICOUT(GDIMFIC)
Local Char    FICTRA(GDIMFIC)
Local Char    FICTRQ(GDIMFIC)
Local Char    FICBAT(GDIMFIC)
Local Char    FICPID(GDIMFIC)
Local Char    ORDRE(250)
Local Char    OPT(10)
Local Char    RQTID(50)
Local Char    SERVICE(30)
Local Integer NUMREQ
Local Integer STAT
[L]NUMREQ = [F:ABR]NUMREQ
FICENT = filpath("tmp","serveur","ent",0)
FICTRA = func SERVSYS.GET_FILE_SERVEUR("tra")        # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
FICOUT = func SERVSYS.GET_ONEFILE_BATCH("tmp","RQT"+format$("N0:8#",[L]NUMREQ),"log")
FICTRQ = func SERVSYS.GET_ONEFILE_BATCH("TRA","RQT"+format$("N0:8#",[L]NUMREQ),"tra")
FICBAT = func SERVSYS.GET_ONEFILE_BATCH("tmp","RQT"+format$("N0:8#",[L]NUMREQ),"bat")
FICPID = func SERVSYS.GET_ONEFILE_BATCH("tmp","RQT"+format$("N0:8#",[L]NUMREQ),"pid")
RQTID  = [F:ABR]DOSSIER - [F:ABR]TACHE
RQTID -= left$(mess([F:ABR]TYPTAC,20,1),1) - [F:ABR]ETAT
#109897
#If dim([F:ABR]SERVICE)>0 & [F:ABR]SERVICE<>""
# SERVICE = "-s"-[F:ABR]SERVICE
#Else
 SERVICE = "-s"-num$(adxtcp)
#Endif
Return

##############################################
##  Ecriture no processus du serveur batch  ##
##############################################
Subprog SERV_PID
Local Char FICPID(GDIMFIC)
FICPID = filpath("tmp","serveur","pid",0)
Gosub ECR_PID
End

###########################################
##  Ecriture no processus de la requête  ##
###########################################
Subprog RQT_PID(CODE)
Value Char CODE
Local Char FICPID(GDIMFIC)
FICPID = func SERVSYS.GET_ONEFILE_BATCH("tmp",CODE,"pid")
Gosub ECR_PID
End

#############################
##  Ecriture no processus  ##
#############################
$ECR_PID
Openo FICPID Using [CMD]
Iomode adxifs "" Using [CMD]
Iomode adxirs GIRS(1) Using [CMD]
Iomode adxium GASCII Using [CMD]
Wrseq num$(adxpid) Using [CMD]
Openo Using [CMD]
Return

############################
##  Lecture no processus  ##
############################
$LEC_PID
Local Integer NBLEC , MAXLEC , TEMPO
Local Char    MESSA(250)
If clalev([F:ABP])>0 & dim([F:ABP]LECPID)>0
 TEMPO = [F:ABP]LECPID
Endif
If TEMPO=0 : TEMPO = 6 : Endif
MAXLEC = val(getenv$("PID_ENTREP"))
If MAXLEC <= 0
 MAXLEC = 20
Endif
PID = ""
NBLEC = 0

$PID0
If filinfo(FICPID,0) > 0
 Openi FICPID Using [CMD]
 Iomode adxifs "" Using [CMD]
 Iomode adxirs GIRS(1) Using [CMD]
 Iomode adxium GASCII Using [CMD]
 Rdseq PID Using [CMD]
 Openi Using [CMD]
 If PID<>""
  PID = num$(val(PID))
 Endif
Else
 NBLEC += 1
 If NBLEC>MAXLEC
  MESSA = mess(84,134,1)-":"-num$(TEMPO*MAXLEC) : # Délai d'attente
  MESSA -= mess(16,134,1)-"("+RQTID+")" : # Récupération no processus impossible
  ##  Trace du serveur
  If [L]NUMREQ=0
   Call STRACE(FICTRA,53000,[L]NUMREQ,MESSA) From SERVEUR
  Else
   Call STRACE(FICTRA,41000,[L]NUMREQ,MESSA) From SERVEUR
  Endif
  GOK = 0
  Return
 Endif
 Sleep TEMPO
 Goto PID0
Endif
Return

###########################
#109897 function to get file names
$DEF_DOSSIER
If dim(GBATCHDIR)<0
 Gosub SETBATCHDIRECTORY From GLOBVAR
Endif
Local Char NOMDOSX3(50)
If adxtyp<>35
 If dim(GDOSX3)<0
  Global Char GDOSX3(50)
 Endif
 If GDOSX3=""
  Call PARAM("","SUPDOS",GDOSX3) From ADOVAL
 Endif
 NOMDOSX3=GDOSX3
Else
 NOMDOSX3=fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,"","SUPDOS")
Endif
Return

#**
#* Return the path for batch server log
#*
#* @param PFIL : "" to get only the directory or the file name to get the full path
#* @param PEXT : "" or file extension
#*!
Funprog GET_BATCH_TRA_DIRECTORY(PFIL, PEXT)
Value Char PFIL
Value Char PEXT

Gosub DEF_DOSSIER

End filpath("",GBATCHDIR+"/TRA"+string$(PFIL<>"","/"+PFIL),string$(PFIL<>"",PEXT),NOMDOSX3,"",adxmac(0))

#**
#* Return path of bach server log
#*
#* @param PEXT : file extension ("" or "tra")
#*!
Funprog GET_FILE_SERVEUR(PEXT)
Value Char PEXT

If filinfo(func GET_BATCH_TRA_DIRECTORY("",""),0)>=0
    End func GET_BATCH_TRA_DIRECTORY("serveur",PEXT)
Endif
End ""

#**
#* Return path of bach server technical log (with ".tra")
#*
#* @param PEXT : file extension ("" or "tra")
#*!
Funprog GET_FILE_SERVEUR_TECH(PEXT)
Value Char PEXT
If filinfo(func GET_BATCH_TRA_DIRECTORY("",""),0)>=0
    End func GET_BATCH_TRA_DIRECTORY("serveur-tech",PEXT)
Endif
End ""

#**
#* return path of request log file
#*
#* @param COD : Request number
#* @param PEXT : file extension ("" or "tra")
#*!
Funprog GET_FILE_RQT(COD,PEXT)
Value Char COD
Value Char PEXT
If filinfo(func GET_BATCH_TRA_DIRECTORY("",""),0)>=0
    End func GET_BATCH_TRA_DIRECTORY("RQT"+COD,PEXT)
Endif
End ""

