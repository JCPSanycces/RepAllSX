Funprog GET_ONEFILE_BATCH(REP,COD,SUFF)
Value Char REP,COD,SUFF
Gosub DEF_DOSSIER
If filinfo(filpath("",GBATCHDIR+"/"+REP,"",NOMDOSX3,"",adxmac(0)),0)>=0
 End filpath("",GBATCHDIR+"/"+REP+"/"+COD,SUFF,NOMDOSX3,"",adxmac(0))
Else
 Local File ABATPAR [ABP]
 Read [ABP]SPOOL First
 APPLI = [F:ABP]APPLI
 End filpath(REP,COD,SUFF,[F:ABP]APPLI,"",adxmac(0))
Endif
End ""

