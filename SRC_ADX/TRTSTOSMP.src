#<AdxTL>@(#)6.0.0.0 $Revision$
# Action     SAISTOSMP : Saisie échantillonnage                     #
# Fenêtre    ISTOSMP                                                #
# Ecran      STOSMP                                                 #
# Traitement supplémentaire : TRTSTO                                #
#####################################################################
$ACTION
Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "TITRE"       : Gosub TIT_TRT
    When "OUVRE_BOITE" : Gosub OUVRE_BOITE
    When "DEBUT"       : Gosub DEBUT
    When "AVANT_BOUTON":
        Case BOUT
            When "E"   : Gosub AVANT_ENR
        Endcase
    When "BOUTON" :
        Case BOUT
            When "E"   : Gosub ENR
            When "A"   : Gosub ABANDON
        Endcase
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "END"         : Gosub ACTEND
    When "FINSAI"      : Gosub FINSAI
    When "SETBOUT"     : Gosub SETBOUT
    When "OK"          : Gosub OK
    When Default       :
Endcase

Return

$OK
#------------------------------#
# Apres exécution du bouton OK #
#------------------------------#
mkstat=4
Return

$TIT_TRT
    Call LECTEXTRA(TIT,"STKTRS","DESAXX","8",GSTQNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-GSTQNUM-":"-TIT
Return




$APRES_MODIF
#-------------#
# Après modif #
#-------------#
REP="M"
Return

$SET_NOL
Local Integer NOL
NOL = nolign-1
Return

##################################################
$OUVRE

Local Integer SAVCONS : SAVCONS=GCONSULT
If !GOUVENT
  FIN = 1
  Return
Endif
If dim(GMAJLIGDOC)<=0
  Global Integer GMAJLIGDOC
Endif
Raz GMAJLIGDOC
Local Integer LLIGDOC   : LLIGDOC = val(PARAM(1))
Local Decimal W_QTE
Local Integer J

# LECSMPCOD  = Lecture et stockage taille echantillon                   #
Call LECSMPCOD From CRDLIB

GOUVENT = 1    # Pour pouvoir ouvrir le complément lot
# Initialisation de GOUVLOT (valable pour tout le document)
GOUVLOT = 30    # Modif des rubriques utilisateur
If [F:ITM]EXYMGTCOD>1
  GOUVLOT += 128
Endif
Return

##################################################
$OUVRE_BOITE

If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif

# ouverture et lecture du dictionnaire des fenetres pour recuperer l ecran generé
If clalev([F:AWI])=0 Local File AWINDOW [AWI] : Endif
Local Char WNOMMSK(GLONAMK)
BOITE = "WQSMP"+GSTQNUM+"E"
GBOITE = BOITE
Call NOMTRTWIN(BOITE,WINPROG) From MSKDIV

Global Char GWSSMPLOT(20)
GWSSMPLOT
If [F:ITM]LOTMGTCOD = 1 | [F:ITF]SMPMOD = 1
   GWSSMPLOT   = "-"+GSINVLOT
Else
   If [F:ITF]SMPMOD = 2
      GWSSMPLOT   = GSINVLOT
   Endif
Endif

Gosub FORMAT_INV From STKLIB
Gosub FORMAT_INV_CHG From STKLIB                               # hcb 110327
If [F:ITM]SERMGTCOD=2 & evalue("dim("+LMABR+"SERNUMDEP)")>0 & evalue(LMABR+"SERNUMDEP(LLIGDOC)")=""
    GWSINVSER = "-"+GSINVSER
    GWSINVSERF= "-"+GSINVSERF
    GWSINTSER = ""
    GWSINTSERF= ""
Endif
If [F:ITF]SMPMOD = 2
   GWSINVLOT   = "-"+GSINVLOT
   GWSINVLOS   = "-"+GSINVLOS
   GWSINTLOT   = ""
Endif


Return

##################################################
$SETBOUT

If [M:STQ1]QLYCRD =""
  Call VIREBOUT(CHMEN,"Of") From GOBJET
Endif
If REP<>"M"
  Call VIREBOUT(CHMEN,"E,A") From GOBJET
Endif
If [M:STQ1]VALFLG=2
  Call VIREBOUT(CHMEN,"E,A") From GOBJET
Endif
Return

##################################################
$DEBUT
Local Integer I
Local Integer LRET
Local Char    WLOT(GLONLOT)
Local Char    WSLO(GLONSLO)
Local Decimal LQTY
Local Decimal LSMP
Local Decimal LACP

Raz [M:SMP]
# Ne pas déplacer le Diszo (fait avant l'actzo de iptdat)
# diszo [M:SQD]5-15

#------ bloc 1
[M:SMP]STOFCY     = [M:STQ1]STOFCY
[M:SMP]VCRNUM     = [M:STQ1]VCRNUM
[M:SMP]IPTDAT     = [M:STQ1]IPTDAT(LLIGDOC)
[M:SMP]VCRTYP     = [M:STQ1]VCRTYP
[M:SMP]TRSTYP     = [M:STQ1]TRSTYP
[M:SMP]TRSCOD     = [M:STQ1]TRSCOD
[M:SMP]OWNER      = [M:STQ1]OWNER (LLIGDOC)
[M:SMP]LLIGDOC    = LLIGDOC

#------ bloc 2
[M:SMP]ITMREF     = [M:STQ1]ITMREF
[M:SMP]STU        = [M:STQ1]STU
[M:SMP]QLYCRD     = [M:STQ1]QLYCRD
[M:SMP]SMPMOD     = [F:ITF]SMPMOD
If [F:ITF]SMPMOD  = 2
   If dim([M:STQ1]LOT) > 0
      [M:SMP]SMPLOT  = [M:STQ1]LOT(LLIGDOC)
   Endif
Else
   If dim([M:SMP]LOT) > 0                  # hcb 67198
      Raz [M:SMP]SMPLOT
   Endif
Endif
[M:SMP]NQA        = [F:ITF]NQA
[M:SMP]GENLEVINS  = [F:ITF]GENLEVINS
#------ bloc 3 / 4
[M:SMP]QTYINISTU  = [M:STQ1]QTYSTU    (LLIGDOC)
[M:SMP]QTYSMPACP  = [M:STQ1]QTYSMPACP (LLIGDOC)
[M:SMP]QTYSMPREF  = [M:STQ1]QTYSMPREF (LLIGDOC)
[M:SMP]STASMP     = [M:STQ1]STASMP    (LLIGDOC)
[M:SMP]STASMPCAL  = [M:STQ1]STASMPCAL (LLIGDOC)
[M:SMP]RENSMP     = [M:STQ1]RENSMP    (LLIGDOC)
[M:SMP]QTYACP     = [M:STQ1]QTYACP    (LLIGDOC)
[M:SMP]CODSMP     = [M:STQ1]CODSMP    (LLIGDOC)
[M:SMP]QTYSMP     = [M:STQ1]QTYSMP    (LLIGDOC)
[M:SMP]QTYSMPLIM  = [M:SMP]QTYSMP - [M:SMP]QTYACP
[M:SMP]LOTACT     = [M:STQ1]LOTACT                  # hcb X3-77043
If [M:SMP]QTYSMP  = 0
# calcul code et taille
   LQTY = [M:SMP]QTYINISTU
   Call CALSMPCOD(1,LQTY,[M:SMP]CODSMP,LSMP) From CRDLIB
   [M:SMP]QTYSMP    = LSMP
   # calcul taille rejet
   Call CALACPPRM([M:SMP]NQA,[M:SMP]CODSMP,LACP) From CRDLIB
   [M:SMP]QTYACP = LACP
   [M:SMP]QTYSMPLIM = [M:SMP]QTYSMP - [M:SMP]QTYACP
Endif

If [M:SMP]QTYSMPREF > [M:SMP]QTYACP
   [M:SMP]WAUZSST = "R*"
Else
   [M:SMP]WAUZSST = "A*"
Endif

#------ chargement tableau
Local Integer WMAX
WMAX = dim([M:SMP]STA)     # mémorisation nombre de ligne maxi
Local Char WLOT(GLONLOT)                # hcb 67198
Raz        WLOT                         # hcb 67198
If dim([M:SMP]LOT) > 0                  # hcb 67198
   WLOT = [M:SMP]SMPLOT                 # hcb 67198
Endif                                   # hcb 67198

If [F:ITF]SMPMOD = 2
   Filter [QLD] Where VCRTYP    = [M:SMP]VCRTYP
&                   & VCRNUM    = [M:SMP]VCRNUM
&                   & LOT       = WLOT
&               Order By Key QLD2
Else
   Filter [QLD] Where VCRTYP    = [M:SMP]VCRTYP
&                   & VCRNUM    = [M:SMP]VCRNUM
&               Order By Key QLD0
Endif

Local Integer WI
Raz WI
Raz nolign
nolign + =1
For [QLD]
    If nolign > WMAX -1
       Call ERREUR(mess(70,184,1)) From GESECRAN
       Raz [M:SMP]
       Break
    Else
       [M:SMP] = [F:QLD]
       [M:SMP]PCUDES      (nolign-1) = [M:SMP]PCU       (nolign-1)
       [M:SMP]QTYPCUDES   (nolign-1) = [M:SMP]QTYPCU    (nolign-1)
       [M:SMP]QTYSTUDES   (nolign-1) = [M:SMP]QTYSTU    (nolign-1)
       [M:SMP]COEDES      (nolign-1) = [M:SMP]PCUSTUCOE (nolign-1)
       If dim([M:SMP]PALNUM) > 0
          [M:SMP]PALNUMDES   (nolign-1) = [M:SMP]PALNUM    (nolign-1)
       Endif
       If dim([M:SMP]CTRNUM) > 0
          [M:SMP]CTRNUMDES   (nolign-1) = [M:SMP]CTRNUM    (nolign-1)
       Endif
       Columns [STO] (STOCOU)
       Raz [STO]
       Filter [STO] Where ITMREF   = [M:SMP]ITMREF
&                       & STOFCY   = [M:SMP]STOFCY
&                       & LOT      = [F:QLD]LOT
&                       & SLO      = [F:QLD]SLO
&                       & PALNUM   = [F:QLD]PALNUM
&                       & CTRNUM   = [F:QLD]CTRNUM
&                       & STA      = [F:QLD]STA
&                       & LOC      = [F:QLD]LOC
&                       & PCU      = [F:QLD]PCU
&                       & PCUSTUCOE= [F:QLD]PCUSTUCOE
&                       & SERNUM   = [F:QLD]SERNUM
&                       & OWNER    = [F:QLD]OWNER
&                       & QLYCTLDEM= [F:QLD]VCRNUM
&                       & STOFLD1  = [F:QLD]STOFLD1
&                       & STOFLD2  = [F:QLD]STOFLD2
       For [STO]STO3
           Break
       Next
       [M:SMP]WSTOCOU(nolign-1) = [F:STO]STOCOU
       Filter [STO]
       Columns [STO]
       nolign += 1
      [M:SMP]NBLIG += 1
    Endif
Next
Filter [QLD]

Local Integer I
For I=0 To [M:SMP]NBLIG-1
    #-- Recherche des différents mouvements déjà effectués pour ce contrôle qualité
    Call RECSTJ_SMP_SMP ([M:SMP]ITMREF,[M:SMP]STOFCY,[M:SMP]VCRTYP,[M:SMP]VCRNUM,[M:SMP]VCRLIN(I),I,"") From TRTSTOSMPB
Next I

Gosub LOAD_FROM_SGW From TRTSTOSMPB


[M:SMP]QTYSMPREFS = sum([M:SMP]QTYSMPREFLIG)   # affichage qty R saisie



Local Integer WDISZO
Raz WDISZO
Read [ACC]CODACC=GUSER;[F:ITF]QUAACS
If fstat | [F:ACC]MODIF<>2
    WDISZO = 2
Endif

# pas de modifications si :
#      - Controle validé
#      - pas acces utilisateur
#      - échantillonnage deja effectué
#      - Gconsult = 2 "Bouton 8 -Infos échantillonage-"
If [M:STQ1]VALFLG=2 | WDISZO = 2 | [M:SMP]WSTJFLG(0)  <> 0 | GCONSULT
   Diszo [M:SMP]
Else
   If dim([M:SMP]LOT) > 0
      Diszo [M:SMP]LOT
   Endif
   If dim([M:SMP]WRH) > 0
      Diszo [M:SMP]WRH
   Endif
   If dim([M:SMP]SLO) > 0
      Diszo [M:SMP]SLO
   Endif
   If dim([M:SMP]LOCTYP) > 0
      Diszo [M:SMP]LOCTYP
   Endif
   If dim([M:SMP]LOC) > 0
      Diszo [M:SMP]LOC
   Endif
   If dim([M:SMP]SERNUM) > 0
      Diszo [M:SMP]SERNUM
   Endif
   If [M:SMP]LBENBRNEW = 0
      Diszo [M:SMP]LBEFMTNEW
      Raz   [M:SMP]LBEFMTNEW
   Endif

   If [M:SMP]QTYSMPACP = 0 & [M:SMP]QTYSMPREF = 0
      Diszo [M:SMP]STASMP
      Diszo [M:SMP]RENSMP
   Endif
Endif
If dim([M:SMP]SMPLOT) > 0
   Diszo [M:SMP]SMPLOT
Endif

#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
If GWRHACT = 2
   If [M]STOFCY<>[F:FCY]FCY
      Read [FCY]FCY0=[M]STOFCY
   Endif
   If [F:FCY]WRHGES <> 2
      Grizo [M:SMP]WRHDES
   Endif
Endif
#------ affichage
Affzo [M:SMP]1-99
Return


#############################################################
$AVANT_ENR

Local Integer  LRET
Local Shortint WRET
Local Integer  LLIG
Local Integer  J
Local Char     MES(255)
Local Integer  LNBNEWLIG

# si LNBNEWLIG = 0 cela veux dire que toutes les lignes sont deja echantillonnées  (wstjflg = 1)

LNBNEWLIG = sigma(0,[M:SMP]NBLIG-1,[M:SMP]WSTJFLG(indcum)<>1)
If LNBNEWLIG=0
   Return
Endif
#------------------------------------------------------------------------------#
# Vérification que toutes les lignes saisies peuvent être entrées dans STOCHGW #
#------------------------------------------------------------------------------#
If [M:SGW]NBLIG+[M:SMP]NBLIG > dim([M:SGW]WSTOSEQ)
    Call ERREUR(mess(36,184,1)+"\"+mess(353,199,1)) From GESECRAN
    Return
Endif

LRET = 0
For LLIG = 0 To [M:SMP]NBLIG-1
    Call CTRLIG("SMP",LLIG, LRET) From SUBSCSB
    If LRET > 0
        MES  = mess(93,100,1)+":"+num$(LLIG+1)+"\"
        If LRET=256
            MES += mess(67,184,1)+"\"        # Ligne stock en inventaire
        Else
            MES += mess(7,111,1) +":\"
            If mod(LRET ,2)>=1
                MES += mess(23,197,1)+"\"    # Unités
            Endif
            If mod(LRET ,4)>=2
                MES += mess(9,184,1)+"\"     # Quantité doit être >0
            Endif
            If mod(LRET ,8)>=4
                MES += mess(398,198,1)+"\"   # Coeff
            Endif
            If mod(LRET ,16)>=8
                MES += mess(24,197,1)+"\"    # Statut
            Endif
            If mod(LRET ,32)>=16 | mod(LRET ,64)>=32
                MES += mess(2,181,1)+"\"     # Emplacement / Type Emplacement
            Endif
            If mod(LRET ,128)>=64
                MES += mess(47,197,1)        # N° de série non saisi
            Endif
#                                                                                       # hcb 110327 deb
            If mod(LRET ,1024)>=512
                MES += mess(246,199,1)        # # Le nb de no série ne correspond pas à la qté à traiter
            Endif
#                                                                                       # hcb 110327 end
        Endif
    Endif
    If LRET : Break : Endif
#                                                             # hcb X3-77043 deb
# controle meme emplacement pour chaque contenant
    If [F:ITF]LPNMGTCOD = 2 & [F:SRT]CHGEMPCOD = 2 & [M:SMP]LPNNUMDES(LLIG) <> ""
#--- Contrôle du mono-emplacement par LPN
       K=sigma(LLIG+1,[M:SMP]NBLIG-1,1*([M:SMP]LPNNUMDES(indcum)=[M:SMP]LPNNUMDES(LLIG) & [M:SMP]WSTJFLG(indcum)=0))
       L=sigma(LLIG+1,[M:SMP]NBLIG-1,1*([M:SMP]LPNNUMDES(indcum)=[M:SMP]LPNNUMDES(LLIG) & [M:SMP]WSTJFLG(indcum)=0
&                & [M:SMP]LOCDES(indcum)=[M:SMP]LOCDES(LLIG)))
       If K<>L
          Call ERREUR(func AFNC.MES2(mess(521,184,1),[M:SMP]LPNNUMDES(LLIG),[M:SMP]LOCDES(LLIG))) From GESECRAN
          GERR=1
          Break
       Endif
    Endif
#                                                             # hcb X3-77043 fin

Next
If GERR = 1                                                   # hcb X3-77043
   Return                                                     # hcb X3-77043
Endif                                                         # hcb X3-77043
If LRET
    Call ERREUR(MES) From GESECRAN  # Ligne incomplete
    FOK = 0
    GERR = 2
    Return
Endif


# controle de la quantite refusée saisie (desactivable par PE)
Raz GPE
GPOINT = "CTRQTYREFS"
Gosub  ENTREE From EXEFNC
If GPE =  0
   If [M:SMP]QTYSMPREFS < [M:SMP]QTYSMPREF
      Call ERREUR(mess(371,184,1)) From GESECRAN   # La quantité refusée est inferieure à la quantité refusée saisie
      FOK = 0
      GERR = 2
      Return
   Endif
Endif

FOK=1

Return

##################################################
$ENR
Local Integer LRET
Local Integer LSEQ
Local Decimal LQTYSTU
Local Integer LERR    # hcb 67159
# si LNBNEWLIG <> 0 signifie que des lignes n ont pas de stojou donc pas d echantillonnage de fait

If LNBNEWLIG <> 0
  # si  l article est géré en serie global STOCHGW est deja rempli                             # hcb 110327
   If [F:ITM]SERMGTCOD <> 4                                                                     # hcb 110327
   # si une saisie detail existe il ne faut pas supprimer stochgw
   If !find(2,[M:SMP]MODFLG(0..[M:SMP]NBLIG-1))
       Call DELSTOCHGW("STQ1", [M:SMP]STOFCY, LLIGDOC, LLIGDOC, 0, LRET) From SUBSCSB
   Endif
   LSEQ = [M:SMP]WSTOSEQ
   I = find(0,[M:SMP]WSTJFLG(0..[M:SMP]NBLIG-1))-1
   If I>=0
      Call FILLCHGW("SMP", I, [M:SMP]NBLIG-I, LSEQ, [M:SMP]STOFCY, LRET, LQTYSTU) From SUBSCSB
      # La ligne chargée n'est pas correcte
      If LRET<>0 | GERR=2
         LRET=99
         Return
      Else
         If LQTYSTU = 0
            If !find(2,[M:SMP]MODFLG(0..[M:SMP]NBLIG-1))    # si pas de saisie détail et lqtystu = 0 : erreur
               Call ERREUR(mess(367,199,1)) From GESECRAN   # pas de stock disponible
               GERR=2
               LRET=99
               Return
            Endif
         Endif
      Endif
   Endif
    Endif                                                                                        # hcb 110327
#  si l echantillon est en  statut "R" et que des details existent il faut verifier
#     que tout les statut soient en "R" . Cela peut arriver dans le cas d une modification
#     du statut de l echantillon  apres saisie d un detail
   If left$([M:SMP]STASMP,1) = "R"   &  find(2,[M:SMP]MODFLG(0..[M:SMP]NBLIG-1))
      Gosub CTR_SGW From TRTSTOSMPB
      If LERR = 1
         Call ERREUR(mess(368,184,1)) From GESECRAN   # Des détails ne sont pas en statut "R"
         GERR=2
         LRET=99
         Return
      Endif
   Endif
   Call RECSGW_STQ ([M:STQ1]ITMREF,[M:STQ1]STOFCY,(LLIGDOC),[M:SMP]WSTOSEQ,"") From TRTSTOSMPB
   [M:STQ1]IPTDAT(LLIGDOC)      =  [M:SMP]IPTDAT
   If LRET=99
      [M:STQ1]WSTOFLG(LLIGDOC)  =  0
   Else
      [M:STQ1]WSTOFLG(LLIGDOC)  =  1
   Endif

   [M:STQ1]QTYSMPACP (LLIGDOC)  = [M:SMP]QTYSMPACP
   [M:STQ1]QTYSMPREF (LLIGDOC)  = [M:SMP]QTYSMPREF
   [M:STQ1]STASMP    (LLIGDOC)  = [M:SMP]STASMP
   [M:STQ1]STASMPCAL (LLIGDOC)  = [M:SMP]STASMPCAL
   [M:STQ1]RENSMP    (LLIGDOC)  = [M:SMP]RENSMP
   [M:STQ1]QTYACP    (LLIGDOC)  = [M:SMP]QTYACP
   [M:STQ1]CODSMP    (LLIGDOC)  = [M:SMP]CODSMP
   [M:STQ1]QTYSMP    (LLIGDOC)  = [M:SMP]QTYSMP
Endif

FIN=1
If LNBNEWLIG>0
    GMAJLIGDOC     = 1
    GRAFFRAICHISCS = 1
    mkstat=4
Endif

Return


##################################################
$ABANDON
    Gosub ANNULE
    Raz [M:SMP]
    Raz REP
    Gosub DEBUT
Return

##########################################################################
$ANNULE
Local Integer  I
Local Integer  LRET
Local Shortint WRET

Call DELSTOCHGW("STQ1", [M:SMP]STOFCY, LLIGDOC, LLIGDOC, 0, LRET) From SUBSCSB

# Suppression de reservation
For I=0 To [M:SMP]NBLIG-1
    If [M:SMP]WLOCSEQ(I)<>0 & dim([M:SMP]LOCDES)>0
       Call STKDELRES([M:SMP]WLOCSEQ(I), [M:SMP]STOFCY, [M:SMP]LOCDES(I), LRET) From STKLOC
    Endif
Next
Return

##########################################################################
$ACTEND
# Meme si les détails sont enregistrés il faut tout de meme faire l action "enregistrement" pour :
#             enregistrer le resultat de l echantillonnage
#             Controler l enregistrement du resultat de l echantillonnage  :
#                   SI l echantillon est en  statut "R" tout les statut doivent etre "R"

Local Integer WOK
WOK = 0
For I = 0 To [M:SMP]NBLIG-1
    If [M:SMP]MODFLG (I) <> 0 & [M:SMP]WSTJFLG (I) = 0   & GREP = "M"
       WOK = 9
       Break
    Endif
Next I
If WOK = 9
   WOK = 0
# Vous n'avez pas enregistré votre saisie. Confirmez vous ?
   Call OUINON(mess(369,184,1), WOK) From GESECRAN
   If WOK <> 2
      FIN = 0
      Return
   Endif
Endif

Gosub ANNULE
Return

##########################################################################
$FINSAI
GCONSULT=SAVCONS
Return


###########################################################################
# repercution nouveau statut sur les lignes de détails
# initialisation de la rubriqie MODFLG avec valeur 1
#                   MODFLG = 0 si echantillonnage non saisie
#                   MODFLG = 1 si echantillonnage saisie et saisie par STOSMP  (échantillonnage)
#                   MODFLG = 2 si echantillonnage saisie et saisie par STOSMP1 (détail échantillonnage)
# initialisation avec l'emplacement origine si emplacement destination non saisissable
###########################################################################
TAB_STADES
Local Integer WI
Local Char    WWRH(GLONWRH)
Raz [M:SMP]QTYSMPREFS

If find(2,[M:SMP]MODFLG(0..[M:SMP]NBLIG-1))
   Call MESSAGE(mess(366,184,1)) From GESECRAN    # Attention des détails ont deja ete saisis
Endif

# si pas de saisie detail et que le statut de la ligne est different de celui de l echantillon : mise à jour
For WI = 0 To [M:SMP]NBLIG-1
    If [M:SMP]MODFLG (WI) <> 2 & [M:SMP]STADES (WI) <> [M:SMP]STASMP
       [M:SMP]STADES (WI) = [M:SMP]STASMP
       If left$([M:SMP]STASMP,1) = "R"
          [M:SMP]QTYSMPREFLIG (WI) = [M:SMP]QTYSTU (WI)
       Endif
#      [M:SMP]MODFLG (WI) = 1                                                 # 110327
       If dim([M:SMP]WRHDES) > 0
          [M:SMP]WRHDES (WI) = [M:SMP]WRH(WI)
       Endif
# Si emplacement destination non saisissable
       If GTRSCHGEMP <> 2
          If dim([M:SMP]WRH) > 0
             WWRH=[M:SMP]WRH(WI)
          Else
             WWRH=""
          Endif
          If dim([M:SMP]LPNNUMDES) > 0                                 # hcb X3-77043
             [M:SMP]LPNNUMDES (WI) = [M:SMP]LPNNUM(WI)                 # hcb X3-77043
          Endif                                                        # hcb X3-77043
          #-- Si article géré en emplacement , on essaie
          #-- d'initialiser avec l'emplacement d'origine, on fait les contrôles
          #-- Si contrôle non ok on raz
          If [F:ITF]ITMREF<>[M:SMP]ITMREF | [F:ITF]STOFCY<>[M:SMP]STOFCY
             Read [ITF]ITF0 = [M:SMP]ITMREF;[M:SMP]STOFCY
             If fstat : Raz [F:ITF] : Endif
          Endif
          If [F:ITF]LOCMGTCOD=2
             Call STKCTRTLO([M:SMP]WLOCSEQ(WI),[M:SMP]TRSTYP,[M:SMP]TRSCOD,[M:SMP]STOFCY,[M:SMP]ITMREF
&                          ,[M:SMP]PCU(WI),[M:SMP]QTYPCU(WI),[M:SMP]STADES (WI)
&                          ,0,[M:SMP]LOCTYP(WI),mkstat,"QU","","") From STKLOC
             If mkstat
                # statut non autorisé pour l emplacement
                GMESSAGE =num$(VALEUR)-":"-mess(213,184,1)-[M:SMP]LOCTYP(WI)-[M:SMP]LOC(WI)      # hcb 88732
                # veuillez utiliser une transaction permettant la saisie de l emplacement
#                GMESSAGE+="\"+mess(214,184,1)
                [M:SMP]MODFLG (WI) = 1                                           # hcb 110327
                Break
             Elsif [M:SMP]LOC(WI)<>""
                Call STKCTREMP([M:SMP]WLOCSEQ(WI),[M:SMP]TRSTYP,[M:SMP]TRSCOD,[M:SMP]STOFCY
&                 ,[M:SMP]ITMREF,[M:SMP]PCU(WI),[M:SMP]QTYPCU(WI),[M:SMP]STADES (WI)
&                 ,[M:SMP]LOCTYP(WI),[M:SMP]LOC(WI),"",0,mkstat,GBIDD1,"QU","",WWRH) From STKLOC
                If !mkstat
                   [M:SMP]LOCTYPDES(WI)=[M:SMP]LOCTYP(WI)
                   [M:SMP]LOCDES(WI)   =[M:SMP]LOC(WI)
                   If dim([M:SMP]WRHDES) > 0
                      [M:SMP]WRHDES(WI)=[M:SMP]WRH(WI)
                   Endif
                Else
                   # statut non autorisé pour l emplacement
                   GMESSAGE =num$(VALEUR)-":"-mess(213,184,1)-[M:SMP]LOCTYP(WI)-[M:SMP]LOC(WI)         # hcb 88732
                   # veuillez utiliser une transaction permettant la saisie de l emplacement
#                   GMESSAGE+="\"+mess(214,184,1)
                   [M:SMP]MODFLG (WI) = 1                                           # hcb 110327
                   Break
                Endif
             Endif
          Endif
       Endif
    Endif
#                                                                 # hcb 110327 deb
    Local Integer WOUI
    WOUI = 2
    If [F:ITF]LOCMGTCOD = 2
       If  [M:SMP]LOCTYPDES(WI) <> "" & [M:SMP]LOCDES(WI) <> ""
           WOUI = 2
       Else
           Raz WOUI
       Endif
    Endif
    If [F:ITM]SERMGTCOD = 4 & [M:SMP]MODFLG (WI) = 0 & WOUI = 2
       Local Char    PABR
       Local Integer LRET
       Local Integer LSEQIND
       Local Integer MODFLG

       PNOL = WI
       PABR = "SMP"
       Gosub CTR_SERIES_GLOBALE From SUBSCSB
       Call WSTOSEQIND ("",WI+1, LSEQIND, LRET) From SUBSCSB
       If LRET
          [M:SMP]MODFLG (WI) = 1
          Break
       Endif
       [M:SMP]WSTOSEQIND(WI) = LSEQIND
    Endif
    [M:SMP]MODFLG (WI) = 1
#                                                                 # hcb 110327 end
Next WI

[M:SMP]QTYSMPREFS = sum([M:SMP]QTYSMPREFLIG)
Affzo [M:SMP]STADES
Affzo [M:SMP]QTYSMPREFS
Return
###########################################################################
# repercution nbre etiquette
###########################################################################
TAB_LBENBR
Local Integer WI
For WI = 0 To [M:SMP]NBLIG-1
    [M:SMP]LBENBR (WI) = [M:SMP]LBENBRNEW
Next WI
Affzo [M:SMP]LBENBR
Return
###########################################################################
# repercution etiquette
###########################################################################
TAB_LBEFMT
Local Integer WI
For WI = 0 To [M:SMP]NBLIG-1
    [M:SMP]LBEFMT (WI) = [M:SMP]LBEFMTNEW
Next WI
Affzo [M:SMP]LBEFMT
Return

##########################################################################
Subprog AVANT_NBLIG
Local Integer LRET

If [F:ITF]LOCMGTCOD=2
   If [M:SMP]LOCDES(nolign-1) = ""
      Call STKWLOCSEQ("SMP", nolign-1, LRET) From STKECR
   Endif
Endif
#                                                                                         # hcb x3-77043 deb
 If dim([M:SMP]LPNNUMDES) > 0
    If [M:SMP]LPNNUMDES               (nolign-1)<>""
       Read [LPN]LPN0=[M:SMP]LPNNUMDES(nolign-1)
       If !fstat & [F:LPN]LOC<>""
           Diszo [M:SMP]LOCDES         (nolign-1)
           Diszo [M:SMP]LOCTYPDES      (nolign-1)
       Endif
    Endif
Endif
#                                                                                         # hcb x3-77043 fin

End

##########################################################################
Subprog APRES_NBLIG
Local Integer     LRET
Local Shortint    WRET
Local Char        LSLO(GLONSLO)
Local Decimal     WOVF
Local Libelle LNOTPCU
Local Libelle LNOTCOE
Local Libelle LNOTSTA
Local Libelle LNOTLOC
Local Libelle LNOTLOF
Local Libelle LNOTLOT
Local Libelle LNOTSLO
Local Libelle LNOTSER
Local Libelle LNOTPAL
Local Libelle LNOTCTR
Local Integer LDUP
Local Integer I


Gosub SET_NOL

If [M:SMP]WLOCSEQ(NOL)=0 | [M:SMP]WLOCSEQ(NOL)=100000
    Call STKDELRES(100000,"","",LRET) From STKLOC
    [M:SMP]WLOCSEQ(NOL)=0
Endif

If [F:ITM]SERMGTCOD = 4 & [M:SMP]MODFLG (NOL) = 1 & [M:SMP]LOCTYPDES(NOL) <> "" & [M:SMP]LOCDES(NOL) <> ""
&  & [M:SMP]WSTOSEQIND(NOL) = 0
   Local Char    PABR
   Local Integer LRET
   Local Integer LSEQIND
   Local Integer PNOL
   PABR = "SMP"
   PNOL = NOL
   Gosub CTR_SERIES_GLOBALE From SUBSCSB
   Call WSTOSEQIND ("",[M:SMP]NBLIG, LSEQIND, LRET) From SUBSCSB
   If LRET
      End
   Endif
   [M:SMP]WSTOSEQIND(NOL) = LSEQIND
Endif
#                                                                       # hcb 110327 end
End

Subprog C_QTYSMPACP(VALEUR)
Variable Decimal VALEUR
If VALEUR > [M:SMP]QTYSMP
   GMESSAGE=mess(294,184,1)   # Quantité supérieure à la taille de l échantillon !
   mkstat = 2
Endif
End

Subprog AM_QTYSMPACP(VALEUR)
Variable Decimal VALEUR
[M:SMP]QTYSMPREF = [M:SMP]QTYSMP - VALEUR
If [M:SMP]QTYSMPREF > [M:SMP]QTYACP
   [M:SMP]WAUZSST = "R*"
   [M:SMP]STASMP  = "R"
Else
   [M:SMP]WAUZSST = "A*"
   If left$([M:STQ1]DEFSTA,1) = "A"
      [M:SMP]STASMP  = [M:STQ1]DEFSTA
   Else
      [M:SMP]STASMP  = "A"
   Endif
Endif
Affzo [M:SMP]QTYSMPREF
Affzo [M:SMP]STASMP
Actzo [M:SMP]STASMP
Actzo [M:SMP]RENSMP
Gosub TAB_STADES
End

Subprog C_QTYSMPREF(VALEUR)
Variable Decimal VALEUR
If VALEUR > [M:SMP]QTYSMP
   GMESSAGE=mess(294,184,1)  # Quantité supérieure à la taille de l échantillon !
   mkstat = 2
Endif
End

Subprog AM_QTYSMPREF(VALEUR)
Variable Decimal VALEUR
[M:SMP]QTYSMPACP     = [M:SMP]QTYSMP - VALEUR
If VALEUR            > [M:SMP]QTYACP
   [M:SMP]WAUZSST    = "R*"
   [M:SMP]STASMP     = "R"
   [M:SMP]STASMPCAL  = "R"
Else
   [M:SMP]WAUZSST    = "A*"
   [M:SMP]STASMP     = [F:SRU]DEFSTA
   [M:SMP]STASMPCAL  = [F:SRU]DEFSTA
Endif

Affzo [M:SMP]QTYSMPACP
Affzo [M:SMP]STASMP
Actzo [M:SMP]STASMP
Gosub TAB_STADES
End

Subprog C_STASMP(VALEUR)
Variable Char    VALEUR
If left$(VALEUR,1) = "Q"
   GMESSAGE=mess(127,184,1)   # Statut non autorisé
   mkstat = 2
Endif
End

Subprog AM_STASMP(VALEUR)
Variable Char    VALEUR()
[M:SMP]STASMP = VALEUR
Gosub TAB_STADES
End


Subprog AM_LBENBRNEW(VALEUR)
Variable Decimal VALEUR
[M:SMP]LBENBRNEW = VALEUR
Gosub TAB_LBENBR
End

Subprog C_LBENBRNEW(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0
   Diszo [M:SMP]LBEFMTNEW
   Raz   [M:SMP]LBEFMTNEW
   Affzo [M:SMP]LBEFMTNEW
Else
   Actzo [M:SMP]LBEFMTNEW
Endif
End

Subprog AS_LBEFMTNEW(VALEUR)
Variable Char    VALEUR()
If [M:SMP]STASMP = ""
   mkstat = 2
Endif
If [M:SMP]LBENBRNEW = 0
   mkstat = 2
Endif
End

Subprog AM_LBEFMTNEW(VALEUR)
Variable Char    VALEUR()
[M:SMP]LBEFMTNEW = VALEUR
Gosub TAB_LBEFMT
End


Subprog AS_LOCTYPDES(VALEUR)
Variable Char    VALEUR()
If [M:SMP]STADES = ""
   mkstat = 2
Endif
If VALEUR = ""
   VALEUR                      = [M:SMP]LOCTYP(nolign-1)
   [M:SMP]LOCDES   (nolign-1) = [M:SMP]LOC(nolign-1)
Endif
End


Subprog AS_LOCDES(VALEUR)
Variable Char    VALEUR()
If [M:SMP]STADES = ""
   mkstat = 2
Endif

End

Subprog AS_WRHDES(VALEUR)
Variable Char    VALEUR()
If [M:SMP]STADES = ""
   mkstat = 2
   End
Endif
If GWRHACT = 2
   If [M]STOFCY<>[F:FCY]FCY
      Read [FCY]FCY0=[M]STOFCY
   Endif
   If [F:FCY]WRHGES <> 2
      mkstat = 2
   Endif
Endif


End

Subprog C_WRHDES(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF;VALEUR
  If fstat
     GMESSAGE=[M]ITMREF-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

Subprog AM_WRHDES(VALEUR)
Variable Char    VALEUR()
If [M:SMP]WRHDES(nolign-1)<>""
   Raz [M:SMP]LOCDES(nolign-1)
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran STOSMP) 27/04/2010 15:26:13 (HCB)
######################################################################################
Subprog IB_NBLIG
If  [M:SMP]QTYSMPACP = 0 & [M:SMP]QTYSMPREF = 0
    Raz GBOUT1
Endif
#                                                                       # hcb 110327 deb

# No séries concernés
GBOUT2 = mess(655,199,1)
# pas de saisie des series concernés si :
# saisie détail impossible
# l article ne gère pas les series globales
# pas de STOCOU
# pas de quantité qualifiée
Local Integer WOUI
WOUI = 2
If [F:ITF]LOCMGTCOD = 2
   If  [M:SMP]LOCTYPDES(nolign-1) <> "" & [M:SMP]LOCDES(nolign-1) <> ""
       WOUI = 2
   Else
       Raz WOUI
   Endif
Endif
If [F:ITM]SERMGTCOD <> 4 | [M:SMP]WSTOCOU(nolign-1) = 0 | [M:SMP]QTYPCUDES (nolign-1)= 0 | [M:SMP]MODFLG (nolign-1)= 0 | WOUI = 0
   Raz GBOUT2
Endif
#                                                                       # hcb 110327 fin

End


