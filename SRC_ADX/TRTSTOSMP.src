Subprog C_LOCTYPDES(VALEUR)
Variable Char    VALEUR()
If [M:SMP]LOCTYPDES(nolign-1)<>VALEUR
   Call RAZLOC([M:SMP]LOCDES(nolign-1),[M:SMP]WLOCSEQ(nolign-1)) From STKACT
Endif
#                                                                                         # hcb X3-77043 deb
If [F:ITF]LPNMGTCOD = 2 &  dim([M:SMP]LPNNUMDES) > 0 & [M:SMP]LPNNUMDES(nolign-1) <> ""
   If find([F:TLO]LOCCAT,3,4)
      GMESSAGE = mess(241,184,1)  # Emplacement non autorise
      mkstat = 2
      End
   Endif
Endif
#                                                                                         # hcb X3-77043 fin

End
