Subprog B2_NBLIG
# depuis STOSMP la fenetre est toujours en consultation car la qty n est pas modifiable
If [M:SMP]MODFLG(nolign-1) = 1
   GOUVCHGS = 2
Else
   GOUVCHGS = 9
Endif
End

#                                                                       # hcb 110327 fin
#                                                                       # hcb X3-77043 deb

Subprog AS_LPNNUMDES(VALEUR)
Variable Char    VALEUR()
If [M:SMP]STADES = ""
   mkstat = 2
Else
   If VALEUR = "" & [M:SMP]LPNNUM(nolign-1) <> ""
      VALEUR = [M:SMP]LPNNUM(nolign-1)
   Endif
Endif
End

Subprog C_LPNNUMDES(VALEUR)
Variable Char    VALEUR()
Local Shortint W_K
#If  [M:SMP]LPNNUM(nolign-1) <> "" & VALEUR = ""
#    GMESSAGE=mess(513,184,1)
#    mkstat=2
#Endif
If VALEUR <> "" & [F:LPN]LOC <> ""
   Read  [STC]STC0=[M:SMP]STOFCY;[F:LPN]LOC
   If !fstat
      Call STKCTRSTA([M:SMP]STADES(nolign-1),[F:STC]AUZSST,0,1,0,W_K) From STKACT
      If W_K <> 0
         GMESSAGE += [F:LPN]LOC-mess(832,196,1)-"("+[M:SMP]STADES(nolign-1)+")"
         mkstat=2
      Endif
  Endif
Endif
End
Subprog C_LOCDES(VALEUR)
Variable Char    VALEUR()
If [F:ITF]LPNMGTCOD = 2 & dim([M:SMP]LPNNUMDES) > 0 & [M:SMP]LPNNUMDES(nolign-1) <> ""
   If find([F:STC]LOCCAT,3,4)
      GMESSAGE = mess(241,184,1)  # Emplacement non autorise
      mkstat = 2
      End
   Endif
Endif
End
#                                                                                         # hcb X3-77043 fin

