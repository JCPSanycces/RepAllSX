#<AdxTL>@(#)2.0.0.0 $Revision$
################################################################################
#    EXPORT SIMULATION SOUS EXCEL
#    Création le : 02/04/2012
#    Modification le :
#
#
################################################################################

#--------------------------------------------------------------#
# AEXPSIMU  Simulation : Export au format CSV
#--------------------------------------------------------------#
$ACTION
  Case ACTION
    When "INIT"     : Gosub INIT
    When "INIT_DIA" : Gosub INIT_DIA
    When "EXEC"     : Gosub EXEC
  Endcase
Return

#---------------------------------------------#
$INIT
  If clalev([F:DPS_])=0   : Local File DEPSIMU    [DPS_]  : Endif
  If clalev([F:FAS_])=0   : Local File FXDASSETS  [FAS_]  : Endif
  If clalev([F:ACN_])=0   : Local File ACONSULT   [ACN_]  : Endif
  If clalev([F:GTC_])=0   : Local File GTABACC    [GTC_]  : Endif
  If clalev([F:AMZ_])=0   : Local File AMSKZON    [AMZ_] : Endif

  Local Char    CRITFIL1(250), CRITSUP1(250)
  Local Char ECRAN, CHAMP

  Local Char    LISTE(GLONPS2)
  Local Char    FICCLI(GDIMFIC) , FICSRV(GDIMFIC) , URL(GDIMFIC)
  Local Integer I , J , ER
  LISTE   = PARAM(1)
  TMP = 1
  Gosub SET_INIVAR From ALHE
Return

#---------------------------------------------#
$INIT_DIA
  [M:ALE]EXC = 2
Return

#---------------------------------------------#
$EXEC
  FICCLI = [L]LISTE+"."+[L]EXT
  Call SET_FICNAM(FICCLI,FICSRV,URL) From ORDSYS
  Gosub ECR_EXLSRV
  Case [M:ALE]EXC
    When 1 : # Enregistrer sur le poste client
        Call COPCLI(FICSRV,FICCLI,ER) From ORDSYS
    When 2 : # Activer Excel
        Call OPEN_HTTP(URL) From ORDSYS
  Endcase
Return

#---------------------------------------------#
$ECR_EXLSRV
  If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
    Local Char LFCY(GLONFCY), LDEP(GLONDEP)
    LFCY = GFCY : LDEP = GDEP
  Endif
  Onerrgo ERREUR
  Openo FICSRV,0 Using [ST_]
  Iomode adxifs IFS Using [ST_]
  Iomode adxirs IRS Using [ST_]
  Iomode adxium IUM Using [ST_]
  Gosub SIMU
  Openo Using [ST_]
  Onerrgo
Return

#---------------------------------------------#
#-----------------------------
#--- Préparation du filtre #
#-----------------------------
$LOAD_FILTER
  Raz CRITFIL1
  Raz CRITSUP1

  CRITFIL1 = "1=1"
  CRITSUP1 = "1=1"

  # Société
  CRITFIL1 = "[F:DPS_]CPY='"+[M:SIM1]CPY+"'"

  # Site
  If [M:SIM1]FCY <> ""
    CRITFIL1 += " & [F:DPS_]FCY='"+[M:SIM1]FCY+"'"
  Endif

  # Bien
  If [M:SIM1]AASREF <> ""
    CRITFIL1 += " & [F:DPS_]AASREF='"+[M:SIM1]AASREF+"'"
  Endif

  # Contexte et plan
  CRITFIL1 += " & [F:DPS_]CNX="+num$([M:SIM1]CNX)+" & [F:DPS_]DPRPLN="+num$([M:SIM1]DPRPLN)

  # Date début/fin exercice
  If [M:SIM1]FIYSTRDAT <> [0/0/0]
    CRITFIL1 += " & [F:DPS_]FIYSTRDAT=["+format$(GFMD,[M:SIM1]FIYSTRDAT)+"] & [F:DPS_]FIYENDDAT=["+format$(GFMD,[M:SIM1]FIYENDDAT)+"]"
  Endif

  # Date début/fin période
  If [M:SIM1]PERSTRDAT <> [0/0/0]
    CRITFIL1 += " & [F:DPS_]PERSTRDAT=["+format$(GFMD,[M:SIM1]PERSTRDAT)+"] & [F:DPS_]PERENDDAT=["+format$(GFMD,[M:SIM1]PERENDDAT)+"]"
  Endif

  #---------------------------------------------------
  # Autres filtres à partir de l'écran des critères
  #---------------------------------------------------
  # Famille
  If [M:CSIM]ACGGRP <> ""
    CRITSUP1 += " & [F:FAS_]ACGGRP='"+[M:CSIM]ACGGRP+"'"
  Endif

  # Code comptable
  If [M:CSIM]ACCCOD <> ""
    CRITSUP1 += " & [F:FAS_]ACCCOD='"+[M:CSIM]ACCCOD+"'"
  Endif

  # Compte PCG
  If [M:CSIM]GAC <> ""
    CRITSUP1 += " & [F:FAS_]GAC='"+[M:CSIM]GAC+"'"
  Endif

  # Compte IAS
  If [M:CSIM]IASACC <> ""
    CRITSUP1 += " & [F:FAS_]IASACC='"+[M:CSIM]IASACC+"'"
  Endif

  # UGT
  If [M:CSIM]IASCGU <> ""
    CRITSUP1 += " & [F:FAS_]IASCGU='"+[M:CSIM]IASCGU+"'"
  Endif

  # Axe analytique
  Local Integer N_CCE
  For N_CCE = 0 To [M:CSIM]NBRCCE-1
    If [M:CSIM]CCE(N_CCE) <> ""
      CRITSUP1 += " & [F:FAS]CCE("-num$(find([M:CSIM]DIE(N_CCE),[F:FAS]DIE)-1)-")='"+[M:CSIM]CCE(N_CCE)+"'"
    Endif
  Next

Return


#---------------------------------------------#
$SIMU
  Gosub LOAD_FILTER

  [L]ECRAN="WMSIM"+[V]CODECR
  Filter [DPS_] Where evalue(CRITFIL1) Order By Key CLE=FCY;AASREF;DPRPLN;FIYENDDAT;PERSTRDAT

  Filter [AMZ_] Where CODMSK=[L]ECRAN and NOZONE>1 Order By Key CLE=NOZONE

  # Ecriture ligne en-tête
  For [AMZ_]
    Wrseq '"'+func AFNC.TEXTE([F:AMZ_]INTIT)+'"'; Using [ST_]
  Next

  For [DPS_]
    For [FAS_] Where [F:FAS_]CPY=[F:DPS_]CPY and [F:FAS_]FCY=[F:DPS_]FCY and [F:FAS_]AASREF=[F:DPS_]AASREF and evalue(CRITSUP1)
      # Remplissage du tableau
      Wrseq '""'; Using [ST_]
      Wrseq Using [ST_]

      For [AMZ_]
        [L]CHAMP = "[F:DPS_]"+[F:AMZ_]CODZON

        Case [F:AMZ_]CODTYP
            When "MD1","RCU" :
                Wrseq num$(evalue([L]CHAMP)); Using [ST_]
            When "M" :
                If [F:AMZ_]NOLIB>0
                  Wrseq '"'+mess(evalue([L]CHAMP),[F:AMZ_]NOLIB,1)+'"'; Using [ST_]
                Else
                  Wrseq '""'; Using [RQ_]
                Endif
            When "D4" :
                Wrseq '"'+format$("D:"+GFMDAT4,evalue([L]CHAMP))+'"'; Using [ST_]
            When Default :
                Wrseq '"'+evalue([L]CHAMP)+'"'; Using [ST_]
        Endcase
      Next
    Next
  Next

  Filter [AMZ_]
  Filter [DPS_]
Return

#---------------------------------------------#
$ERREUR
ER = errn
Resume

