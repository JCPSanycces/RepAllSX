#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
GACTION = "SAIVALPAY"
GFONC1 = "GESVFC"
GLEGFIL=""
Call TRAITE_CHAR(VALEUR,PARAM,"","SAIVALPAY","SAIVALPAY",3,"") From GTRAITE
End

$ACTION
#MIPEA - 2016-07-12 - REQ 114309 US274 - START
Case ACTION
 When "INIT_DIA": Gosub INIT_DIA
 When "EXEC" :
  IF GFONC1 = "GESVEPZAF" | GFONC1 = "GESVEPZMB" :GCURLEG=PARAM(1) : GDIV=GCURLEG :#Use GDIV because the supervisor erase GCURLEG if the main table of the object hasn't LEG field !
    Else
     GCURLEG=[M:DIA0]LEG : GDIV=GCURLEG
  Endif
  Raz GBIDC2


  Case GFONC1
   When "GESVFD"     :  Call OBJET("VFD",GBIDC1,GBIDC2) From GOBJET
   When "GESVCP"     :  Call OBJET("VCP",GBIDC1,GBIDC2) From GOBJET
   When "GESVFC"     :  Call OBJET("VFC",GBIDC1,GBIDC2) From GOBJET
   When "GESVEP"     :  Call OBJET("VEP",GBIDC1,GBIDC2) From GOBJET
   When "GESVEPZAF"  :  Call OBJET("VEP",GBIDC1,GBIDC2) From GOBJET
   When "GESVEPZMB"  :  Call OBJET("VEP",GBIDC1,GBIDC2) From GOBJET
   When "PRNBUL"     :  Gosub PRNBUL
  Endcase
   When "SORTIE"       : Gosub SORTIE
Endcase
#Case ACTION
# When "INIT_DIA": Gosub INIT_DIA
# When "EXEC" :
#  GCURLEG=[M:DIA0]LEG : GDIV=GCURLEG :#Use GDIV because the supervisor erase GCURLEG if the main table of the object hasn't LEG field !
#  Raz GBIDC2
#  Case GFONC1
#   When "GESVFD" :  Call OBJET("VFD",GBIDC1,GBIDC2) From GOBJET
#   When "GESVCP" :  Call OBJET("VCP",GBIDC1,GBIDC2) From GOBJET
#   When "GESVFC" :  Call OBJET("VFC",GBIDC1,GBIDC2) From GOBJET
#   When "GESVEP" :  Call OBJET("VEP",GBIDC1,GBIDC2) From GOBJET
#   When "PRNBUL" :  Gosub PRNBUL
# Endcase
# When "SORTIE"  : Gosub SORTIE
#Endcase
#MIPEA - 2016-07-12 - REQ 114309 US274 - END
Return

$INIT_DIA
Raz [M:DIA0]
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If dim(GLEGFIL)>0 : Local Char SAV_GLEGFIL(GLONADI) : SAV_GLEGFIL = GLEGFIL   : Endif
GCURLEG = GLEGFIL
Return

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
If dim(SAV_GLEGFIL)>0 : GLEGFIL = SAV_GLEGFIL : Endif
Return

#81084
#Call to PRNBUL action using legislation
$PRNBUL
  PARAM(1)=func PRNBUL.RPTBUL()
  GBIDI1=0
  Call S_LIS_CHAR(VALEUR,PARAM,"SEL_LISTE","PRNBUL","") From GACTION
  If GBIDI1<>1
    PARAM(1) = GBIDC1
    Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,"") From GTRAITE
  Endif
Return
#end 81084

Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()
If GNBLEG = 1 : VALEUR = GDOSLEG : mkstat=2 : End : Endif
End

