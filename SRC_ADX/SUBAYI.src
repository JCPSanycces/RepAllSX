#<AdxTL>@(#)1.0.0.0 $Revision$   Gestion objet AYI
Raz GPILOBJ,GNBMASKOUV

Call OBJET("AYI",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
## Xtend:  Gestion des Interfaces Xtend 
#  Version 0002
#    Ex test: AWEB / LISTWS -> JPJTST (WRJPJTST)
#
#   Fichier AYTLINES  (AYN)
#        Interface  LINCODTYP = 6
#        LINTYP
#                 = 40    Paramètres
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "AVANT_OUVRE"    : Gosub AVANT_OUVRE
 When "ANNULE"         : Gosub ANNULE
 When "CREATION"       : Gosub CREATION
 When "EXEACT"         : Gosub EXEACT
 When "FERME"          : Gosub FERME
 When "FILTRE"         : Gosub FILTRE
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "LIENS"          : Gosub LIENS
 When "MODIF"          : Gosub MODIF
 When "OUVRE"          : Gosub OUVRE
 When "RAZCRE"         : Gosub RAZCRE 
 When "RAZDUP"         : Gosub RAZDUP
 When "SETBOUT"        : Gosub SETBOUT
Endcase
Return

$AVANT_OUVRE
#---------------------------------------------------------------#
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Gosub INICTLFCY From SUBAYS
Return

#---------------------------------------------------------------#
$EXEACT
Case BOUT
When "S"
    Call USG_SUPP([M]FCYCOD, GABREV, [M:AYI0]INTCOD, WI) From CNSAYUSTD
    If WI : OK=0 : Endif
Endcase
Return

#---------------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, copie
Else
 CHMEN+="13"    # Gestion Web service, aide création champs
Endif
If find(REP,"C","D","M")  Diszo [M:AYI1]IGEN : Else : Actzo [M:AYI1]IGEN : Endif
Return

#---------------------------------------------------------------#
$INICRE    
$INIMOD
# Clé browser X3
[F]BRWX3=[F]FCYCOD+"_"+[F]INTCOD
Return

$OUVRE
#---------------------------------------------------------------#
Local Char WSTR1 (250), WTRT(12)
Local Integer WI, WJ, RET
Gosub DSYFCY From SUBAYS       # Infos site
Local Integer WS_RET           # WS - Code retour
Local Char    WS_MES(80)       # WS - message associé
Return

#---------------------------------------------------------------#
$FERME
Gosub DSYCLRFCY From SUBAYS    # Clear affichage site
Return

#---------------------------------------------------------------#
$LIENS
Gosub DSYFCY From SUBAYS                     # Infos site
Call SETDATA(0, [M]WEBSRCCOD, [M]TYP, WS_RET, WS_MES)      # Données interface
Call TYPUPD(0, 0, [M]TYP)                                  # Accès zones en fct du type
If find([M]TYP,3,21)
 Call SETAOB([M]WEBSRCCOD)                                  # Gestion ecran pour les objets
Endif
#
Call SETLNKADS([F:AYI]LNKADSDEF)             # Lien Xtend-Progiciel
#
# Paramétres
Raz [F:AYN]
WI=0
For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = 6
&                     and LINCOD = toupper([M]INTCOD) and  LINTYP = 40
 [M:AYI3]PARCOD40(WI) = [F:AYN]PARCOD
 [M:AYI3]VALTYP40(WI) = [F:AYN]VALTYP
 [M:AYI3]VALEUR40(WI) = [F:AYN]VALEUR
  WI+=1
Next
[M:AYI3]NUM40=WI

Return

#---------------------------------------------------------------#
$FILTRE
FILTSUP+=func SUBAYS.FILTFCY
Return

#---------------------------------------------------------------#
$RAZCRE
Gosub DSYFCY From SUBAYS     # Infos site
#[M]CODACT=WFCY_CODACT        # Code activité site
#
[M]LNKADSDEF=2
Call SETLNKADS([M]LNKADSDEF)
Return

#---------------------------------------------------------------#
$RAZDUP
Return

#---------------------------------------------------------------#
$CREATION
$MODIF
# 
# Sup. avant recréation par. Action 
Gosub ANNULE2 : If GOK<>1 : Return : Endif

# Paramétres
For WI=0 To [M:AYI3]NUM40-1
 Raz [F:AYN]
 [F:AYN]FCYCOD    = [M]FCYCOD
 [F:AYN]LINCODTYP = 6
 [F:AYN]LINCODSTD = [M]INTCOD
 [F:AYN]LINCOD    = toupper([M]INTCOD)
 [F:AYN]LINTYP    = 40
 [F:AYN]PARCOD    = [M:AYI3]PARCOD40(WI)
 [F:AYN]VALTYP    = [M:AYI3]VALTYP40(WI)
 [F:AYN]VALEUR    = [M:AYI3]VALEUR40(WI)
 [F:AYN]LINNUM    = WI
 Write [AYN]
 If fstat
  GOK=0 : Call FSTA("AYN") From GLOCK : Break
 Endif
Next

#  textes AXX
Call MAJTEXTRA([M]INTIT,"AYTINT","INTIT",[M]FCYCOD,[M]INTCOD) From  ATEXTRA

Return

#---------------------------------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="AYTELTBLC" & ZONE = "INTIT"   & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
$ANNULE2
Delete [AYN]AYN0=[M]FCYCOD;6;toupper([M]INTCOD)
If fstat=1 : GOK=-1 : GLOCK="$AYTLINES ("-[M]FCYCOD-"3"-[M]INTCOD+")" : Return : Endif
Return

######################################################################################
### Utilitaires
######################################################################################

# Lien Xtend-Progiciel
#------------------------------------------------------------#
Subprog SETLNKADS(LNKDEF)
If LNKDEF=2
  Effzo [AYI3]LNKADS : Grizo [AYI3]LNKADS 
Else
  Actzo [AYI3]LNKADS
Endif
End

Subprog SETAOB(PUBLICATION)
Value Char PUBLICATION
If !clalev([F:AWE]) : Local File AWEBSERVIC [F:AWE] : Endif
Read [F:AWE]AWE1 = PUBLICATION
If !fstat
 [M]OBJET     = [F:AWE]OBJET
 [M]VARIANTE  = [F:AWE]VARIANTE
 [M]INVISIBLE = [F:AWE]INVISIBLE
 Grizo [M:AYI1]OBJET
 Grizo [M:AYI1]VARIANTE
 Grizo [M:AYI1]INVISIBLE 
Else
 Actzo [M:AYI1]OBJET
 Actzo [M:AYI1]VARIANTE
 Actzo [M:AYI1]INVISIBLE 
Endif
End

# Remplissage du tableau des champs accessibles par l'interface
#------------------------------------------------------------#
# 
#
Subprog SETDATA(AFFZO_FLG, WEBSRCCOD, TYP, WSRET, WSMES)   
Value Integer AFFZO_FLG
Value Char    WEBSRCCOD      # Code web service
Value Integer TYP            # Type interface
Variable Integer WSRET       # WS - Code retour
Variable Char    WSMES       # WS - message associé
Raz WSRET, WSMES

Effzo [AYI2]15,16,20
#Diszo [AYI1]PRG,SUBPRG # Menu contextuel
Raz   [M]WWSLIB, [M]WEBSRCSEL : #  [M]PRG, [M]SUBPRG
# Maj [M]WEBSRCSEL en fonction du type Xtend
Case [L]TYP
When 1,2,4,20    # Accès via WS sous-programme
    [M]WEBSRCSEL="S"
When 3,21
    [M]WEBSRCSEL="O"
Endcase
#
If [L]WEBSRCCOD = "" : End : Endif
#
Gosub GETWS_VAR From SUBAYIACT      # Variables pour GETWS_INF

WS_INTTYP=[L]TYP : WS_WSRCOD=[L]WEBSRCCOD 

Gosub GETWS_INF  From SUBAYIACT 

If WS_RET    #  Traitement si Anomalie dans GETWS_INF
    WWSLIB=WS_MES
    Case [L]TYP
    When 1,4          # Accès sous-programme généré table et vue 
                      # Accès sous-programme utilisateur, Action sous-programme utilisateur
        If [M]PRG="" : [M]PRG=WS_ASUTRT : [M]SUBPRG=WS_ASUSPG : Endif
    When 3, 21     # Accès liste gauche, Action objet
        [M]PRG=WS_WXTRT : [M]SUBPRG=WS_WXSPG  
    Endcase
    If AFFZO_FLG : Affzo [M:AYI1]PRG,SUBPRG,WWSLIB : Endif
    WSRET=WS_RET : WSMES=WS_MES : End
Endif

Case [L]TYP
When 1,4,2     # Accès sous-programme généré table et vue 
               # Accès sous-programme utilisateur
    [M]DSCNBR = 0
    [M]PRG=WS_ASUTRT : [M]SUBPRG=WS_ASUSPG 
    For WI=0 To RUBNBR-1
        Gosub LOADDSC
        [M]DSCOCC(WI)=0      # utile sur action
    Next 
    #
    [M]RESMAX=RUBRESMAX
    #
When 3     # Accès liste gauche
    [M]DSCNBR = 0
    [M]PRG=WS_WXTRT : [M]SUBPRG=WS_WXSPG     # Nota: provient de la description générée dans le wrapper WS
    For WI=0 To RUBNBR-1
        Gosub LOADDSC
        [M]DSCOCC(WI)=0    
    Next 
    [M]RESMAX=RUBRESMAX
    #
When 20    # Action sous-programme utilisateur
    [M]DSCNBR = 0
    [M]PRG=WS_ASUTRT : [M]SUBPRG=WS_ASUSPG : 
    For WI=0 To RUBNBR-1
        Gosub LOADDSC
    Next 
    #
When 21     # Action objet
    [M]DSCNBR = 0
    [M]PRG=WS_WXTRT : [M]SUBPRG=WS_WXSPG     # Nota: provient de la description générée dans le wrapper WS
    For WI=0 To RUBNBR-1
        Gosub LOADDSC
    Next 
    #
    For WI=0 To dim(RUBKEYIND)-1        # Clé objet
        [M]DSCKEY(WI)=RUBCOD(RUBKEYIND(WI))
        Call TEXTE(RUBINTIT(RUBKEYIND(WI)), [M]DSCKEYDES(WI)) From OBJDIV
        #
        [M]DSCKEYNB+=1
    Next 
    #
When Default
    If GERR : WSRET=WS_RET : WSMES=WS_MES : End : Endif     # Anomalie GETWS_INF
    GERR=1 : GMESSAGE="Xtend - Interface type unknown:"-num$([F:AYI]TYP)-mess([F:AYI]TYP,7912,1)
Endcase
If AFFZO_FLG
    Affzo [M:AYI1]PRG,SUBPRG,WWSLIB,RESMAX
    Affzo [M:AYI2]
Endif
End

$LOADDSC
 [M]DSCCOD(WI)=RUBCOD(WI)
 [M]DSCGRP(WI)=RUBGRP(WI)
 Call TEXTE(RUBINTIT(WI), [M]DSCDES(WI)) From OBJDIV
 [M]DSCOCC(WI)=RUBDIM(WI)      
 [M]DSCADR(WI)=RUBADR(WI)
 #
 [M]DSCNBR+=1
Return

# Diszo champs en fct du type - menu 7912
#------------------------------------------------------------#
Subprog TYPUPD(AFFZO_FLG, MOD_FLG, TYP)   
Value Integer AFFZO_FLG
Value Integer MOD_FLG
Value Integer TYP            # Type interface

# gestion icone génération
#   TYP        Adresse       Type interface
Case [L]TYP         
When 1                
    Chgfmt [M:AYI1]IGEN With "KIB:3X"
    [M:AYI1]IGEN="258"
    Actzo [AYI1]CODFIC
    Effzo [AYI1]CODVUE : Diszo [AYI1]CODVUE
    Effzo [AYI1]16     : Diszo [AYI1]16
    Diszo [AYI1]17

When 2,20
    Chgfmt [M:AYI1]IGEN With "KIB:3X"
    [M:AYI1]IGEN="258"
    Effzo [AYI1]CODFIC, CODVUE
    Diszo [AYI1]CODFIC, CODVUE
    Effzo [AYI1]16  : Diszo [AYI1]16
    Actzo [AYI1]PRG,SUBPRG

When 3,21
    Chgfmt [M:AYI1]IGEN With "KIB:3X"
    [M:AYI1]IGEN="258"
    Effzo [AYI1]CODVUE : Diszo [AYI1]CODVUE
    Effzo [AYI1]CODFIC : Diszo [AYI1]CODFIC
    Actzo [AYI1]OBJET,VARIANTE,INVISIBLE,LIBVAR
    Diszo [AYI1]17

When 4                
    Chgfmt [M:AYI1]IGEN With "KIB:3X"
    [M:AYI1]IGEN="258"
    Actzo [AYI1]CODVUE
    Effzo [AYI1]CODFIC : Diszo [AYI1]CODFIC
    Effzo [AYI1]OBJET  : Diszo [AYI1]OBJET
    Effzo [AYI1]16     : Diszo [AYI1]16
    Diszo [AYI1]17

When Default
     Chgfmt [M:AYI1]IGEN With "-KIB:3X"
    [M:AYI1]IGEN=""
    Effzo [AYI1]CODFIC, CODVUE
    Diszo [AYI1]CODFIC, CODVUE
    Effzo [AYI1]16  : Diszo [AYI1]16

Endcase

# Gestion optimisation
Case [L]TYP 
When 1,4
    #    
    Effzo [AYI3]20
    [M:AYI3]OPTIMI(0)=1
    [M:AYI3]OPTIMI(1)=2
    [M:AYI3]OPTIMI(2)=3
    [M:AYI3]OPTIMI(3)=4
    [M:AYI3]OPTIMINBR=4
    Diszo [AYI3]20
When 2
    #    
    Actzo [AYI3]20
When Default
    Effzo [AYI3]20
    Grizo [AYI3]20
Endcase

# Gestion paramètres interface
Case [L]TYP 
When 2
    Actzo [AYI3]30
When Default
    Effzo [AYI3]30
    Grizo [AYI3]30
Endcase

# Modif valeur
If MOD_FLG
    Effzo 10,15,20,30
    [M:AYI1]IGEN="258"
    [M:AYI1]TYP=[L]TYP
    Diszo [M:AYI1]IGEN
    If AFFZO_FLG : Affzo [M:AYI1]TYP : Endif
Endif
End   


#    AYIDIM     Dimension d'un champ interface
######################################################################################
# PARAM(1..4)   Site Xtend            A
#               Code interface        A
#               Groupe du champ       A
#               Code champ interface  A

Funprog DSCDIM(FCY, INTERF, GRP, FLD)
Local Char FCYWRK(GLONAYG), INTCOD(GLONAYI), WEBSRCCOD(GLONAWE), DSCCOD(12), DSCGRP(GLONAPU)
Local Integer WI, WJ, ERRPRG
Local Integer DIMVAL : DIMVAL=1

If clalev([F:AYI])=0 : Local File AYTINT [AYI] : Endif

[L]FCYWRK= FCY         # site de travail
[L]INTCOD= INTERF      # interface
[L]DSCGRP= GRP         # Groupe du champ
[L]DSCCOD= FLD         # Code champ interface

Read [AYI]AYI0 = [L]FCYWRK;[L]INTCOD
If fstat
    Call RSTA("AYI",[L]FCYWRK+"~"+[L]INTCOD) From GLOCK 
    Goto DSCDIM_END
Endif

WEBSRCCOD=[F:AYI]WEBSRCCOD
Case [F:AYI]TYP
When 1,2    # Accès (dim = 1)
    Goto DSCDIM_END
When 20     # Action sous-prgrm personnalisé
    Gosub GETWS_VAR From SUBAYIACT      # Variables pour GETWS_INF
    WS_INTTYP=[F:AYI]TYP : WS_WSRCOD=[L]WEBSRCCOD
    Gosub GETWS_INF  From SUBAYIACT
    If WS_RET and !(WS_RET=2) : GERR=1 : GMESSAGE=WS_MES : Goto DSCDIM_END : Endif
    For WI=0 To RUBNBR-1
         If [L]FLD=RUBCOD(WI) and [L]GRP=RUBGRP(WI)
            DIMVAL = RUBDIM(WI)
            Break
         Endif
    Next 
    
When 3,21   # Liste gauche, Objet
    Gosub GETWS_VAR From SUBAYIACT      # Variables pour GETWS_INF
    WS_INTTYP=[F:AYI]TYP : WS_WSRCOD=[L]WEBSRCCOD 
    Gosub GETWS_INF  From SUBAYIACT : If WS_RET : GERR=1 : GMESSAGE=WS_MES : Goto DSCDIM_END : Endif

    For WI=0 To RUBNBR-1
         If [L]FLD=RUBCOD(WI) and [L]GRP=RUBGRP(WI)
            DIMVAL = RUBDIM(WI)
            Break
         Endif
    Next 

When Default
    Call ERREUR("Xtend DSCDIM/SUBAYI - Interface type unknown:"-num$([F:AYI]TYP)-mess([F:AYI]TYP,7912,1)
&        -"Interface:"-[L]INTCOD)From GESECRAN
    Goto DSCDIM_END
Endcase

#
$DSCDIM_END
End DIMVAL

$DSCDIM_E
ERRPRG=1
Resume

######################################################################################
## Ecran AYI0
######################################################################################

######################################################################################
## Ecran AYI1
######################################################################################
Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
Local Integer WS_RET
Local Char    WS_MES(80)
[M:AYI1]WEBSRCCOD="" : Affzo [M:AYI1]WEBSRCCOD
Call TYPUPD(1, 1, VALEUR)                                         # Accès zones en fct du type
Call SETDATA(1, [M:AYI1]WEBSRCCOD, VALEUR, WS_RET, WS_MES)      # Données interface

End

# - - - -
Subprog AV_WEBSRCCOD(VALEUR)
Variable Char     VALEUR
If VALEUR=""
    Case [M]TYP
    When 1
        VALEUR=[M]CODFIC
    When 4
        VALEUR=[M]CODVUE
    Endcase
Endif
End

Subprog AM_WEBSRCCOD(VALEUR)
Variable Char    VALEUR()
Local Integer WS_RET
Local Char    WS_MES(80)
Call SETDATA(1, VALEUR, [M:AYI1]TYP, WS_RET, WS_MES)      # Données interface
If WS_RET=4    # Incohérence entre le WS et le type Xtend
    mkstat=2 : GMESSAGE=WS_MES : End
Endif
End

Subprog C_WEBSRCCOD(VALEUR)        
Variable Char    VALEUR()
Local Integer OTHFCY

If !clalev([F:AWE]) : Local File AWEBSERVIC [AWE] : Endif

Read [F:AWE]AWE1 = VALEUR
If fstat
 # : Traitement ou sous-programme non renseigné
 If [M]PRG=""  & find([M]TYP,2,20) : GMESSAGE = mess(220,07900,1) : mkstat= 2  : End :  Endif
Else
 If ([F:AWE]PRG<>[M]PRG)  or ([F:AWE]SUBPRG <> [M]SUBPRG)
  Call OUINON(mess(224,7900,1),GBIDI1) From GESECRAN
  If GBIDI1 <> 2
   GMESSAGE = ""
   mkstat = 2 : End
  Endif
 Endif
 [M]PRG    = [F:AWE]PRG
 [M]SUBPRG = [F:AWE]SUBPRG
 Affzo [M]PRG,SUBPRG
Endif

## Action %CNTOBJ
Call CONTSEL("AWE","",VALEUR,"",mkstat) From CONTOBJ
If mkstat
  If !find([M:AYI1]TYP,1,4,3,21,2,20)     # Ne concernent pas les trt générés (message dans l'écran)
      GERR=1 
      End
  Else 
      mkstat=0 : End            # Pas de msg
  Endif
Endif

# Verif du type de WS
Call CONTSEL("AWE",[M]WEBSRCSEL,VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif

If find([M:AYI1]TYP,1,4)    # Type interface généré
    # Test si existe déjà dans le même site
    For [AYI]AYI1 Where WEBSRCCOD=VALEUR and FCYCOD=[M]FCYCOD
      If [AYI]INTCOD<>[M]INTCOD
       mkstat=2
       GMESSAGE=mess(73,7900,1)-[AYI]INTCOD
      Break
     Endif
    Next
    If mkstat : End : Endif

    # Test si existe dans un autre site 
    For [AYI]AYI1 Where WEBSRCCOD=VALEUR and FCYCOD<>[M]FCYCOD
       GMESSAGE=mess(73,7900,1)-[AYI]INTCOD-mess(1,7900,1)-[AYI]FCYCOD
       GERR=3
    Next
Endif

End


# - - - -


 
Subprog CL_IGEN(VALEUR)
Variable Char    VALEUR()
If [M:AYI1]WRETGEN=1
    Local Integer WS_RET
    Local Char    WS_MES(80)
    Call SETDATA(1, [M:AYI1]WEBSRCCOD, [M:AYI1]TYP, WS_RET, WS_MES)      # Données interface
Endif
End

Subprog AS_TYP(VALEUR)
Variable Integer VALEUR
For WI=5 To 19 : GMENLOC(WI)=1 : Next
End

Subprog IB_PRG
If find([M]TYP, 3, 21)    # objet
    Raz GBOUT3
Endif
End

Subprog B3_PRG(VALEUR)
Variable Char    VALEUR()
Call OBJET("ASU",[M]SUBPRG,VALEUR) From GOBJET
# Mise à jour (suite suppresion fiche ss-prgm par ex.)
Local Integer WS_RET
Local Char    WS_MES(80)
Call SETDATA(1, [M:AYI1]WEBSRCCOD, [M:AYI1]TYP, WS_RET, WS_MES)      # Données interface
End


Subprog AM_LNKADSDEF(VALEUR)
Variable Integer VALEUR
Variable Integer VALEUR
Call SETLNKADS(VALEUR)
End

Subprog AS_OPTIMI(VALEUR)
Variable Integer VALEUR
For WI=7 To 19 : GMENLOC(WI)=1 : Next # réservé dév. std
End

Subprog C_OPTIMI(VALEUR)
Variable Integer VALEUR
Call UNICITE(VALEUR,[M]OPTIMI) From OBJDIV
End

Subprog AS_VALTYP40(VALEUR)
Variable Integer VALEUR
Local Integer LST(len(mess(0,GCOMBO,1))),WI
LST(WI)=1 : WI+=1    # Cst
LST(WI)=6 : WI+=1    # Saisie
Call MNLCHX(GCOMBO,LST) From AYTUTIA
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran AYI1) 22/06/2009 09:57:51 (CCL)
######################################################################################
Subprog AS_VARIANTE(VALEUR)
Variable Char    VALEUR()
Call AS_VARIANTE(VALEUR) From SUBAWE
End

Subprog C_VARIANTE(VALEUR)
Variable Char    VALEUR()
End

Subprog C_SUBPRG(VALEUR)
Variable Char    VALEUR()
If [M]PRG<> "" & VALEUR= ""
 GMESSAGE = mess(10,123,1) : # Zone OBLIGATOIRE
 mkstat =2
Endif
End


Subprog C_PRG(VALEUR)
Variable Char    VALEUR()

End

