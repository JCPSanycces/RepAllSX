#<AdxTL>@(#)0.0.0.0 $Revision$
#------------------------------------------------------------------#
Funprog CONTROLE_ABR(TAB,ABR,ORI,TABLE,IND,OPT,EXPR,MESSAGE)
Value    Char    TAB()   : # Tables liÃĐes utilisÃĐes dans l'expression
Value    Char    ABR()   : # AbrÃĐviATIon des tables liÃĐes utilisÃĐes dans l'expression
Value    Char    ORI     : # Table des champs utilisÃĐe dans l'expression
Value    Char    TABLE   : # Table lue
Value    Char    IND     : # Index de la table lue
Value    Integer OPT     : # 1->0,1 2->0,n 3->1,1 4->1,n
Variable Char    EXPR()
Variable Char MESSAGE

#------------#
$CONTROL
If filinfo(filpath("FIL","AVIEWTAB","fde",nomap),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde",nomap),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde",nomap),0)<0
 Local File ATABLE [ATB]
 Local File ATABZON [ATZ]
 Local File ATABIND [ATI]
Else
 Local File AVIEWTAB [ATB]
 Local File AVIEWFLD [ATZ]
 Local File AVIEWIND [ATI]
Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
EXPR = toupper(EXPR)
Local Char    CHAINE(250) , CHAMP(30) , ABREV(10)
Local Integer NBCLE , NBCMP
Local Integer I , J , K , OK
OK = 1
NBCLE = 0
If IND<>""
 Read [ATI]CODIND = TABLE;IND
Else
 Read [ATI]NUMLIG(2) = TABLE;1
Endif
CHAINE = [F:ATI]DESCRIPT
Repeat
 NBCLE += 1
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If    I & J  : I = min(I,J)
 Elsif J & !I : I = J
 Endif
 If I : CHAINE = right$(CHAINE,I+1) : Else : CHAINE = "" : Endif
Until CHAINE = ""
NBCMP = 0
CHAINE = EXPR
Repeat
 NBCMP += 1
 I = instr(1,CHAINE,";")
 If I
  CHAMP  = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CHAMP  = CHAINE
  CHAINE = ""
 Endif
 If left$(CHAMP,3)<>"[F]" & left$(CHAMP,1)="[" & !instr(1,CHAMP,"/")
  I = instr(1,CHAMP,"]")
  If I=0 : OK = 0 : Break : Endif
  ABREV = seg$(CHAMP,2,I-1)
  CHAMP = right$(CHAMP,I+1)
  If left$(ABREV,2) = "F:"
   ABREV = right$(ABREV,3)
  Endif
  If !find(ABREV,"L","V")
   If dim([L]ABR)>0
    I = find(ABREV,[L]ABR)
    If I
     Read [ATB]CODFIC = [L]TAB(I-1)
    Else
     MESSAGE = ABREV-":"-mess(124,124,1) : # Table inexistante
     OK = 0 : Break
    Endif
   Else
    Read [ATB]ABRFIC = ABREV
   Endif
   If fstat
    MESSAGE = ABREV-":"-mess(124,124,1) : # Table inexistante
    OK = 0 : Break
   Endif
   I = instr(1,CHAMP,"(")
   If I : CHAMP = left$(CHAMP,I-1) : Endif
   Read [ATZ]CODZONE = [F:ATB]CODFIC;CHAMP
   If fstat
    MESSAGE = "[F:"+ABREV+"]"+CHAMP-":"-mess(41,100,1) : # Champ inexistant
    OK = 0 : Break
   Else
    K = 1
    If [F:ATZ]CODACT<>""
     Read [ACV]CODACT=[F:ATZ]CODACT
     If fstat | [F:ACV]FLACT<>2
      K = 0
     Endif
    Endif
    If !K
     MESSAGE = "[F:"+ABREV+"]"+CHAMP-":"-[F:ATZ]CODACT-mess(24,176,1) : # Code activitÃĐ inactif
     OK = 0 : Break
    Endif
   Endif
  Endif
 Elsif dim([L]TAB)>0 | (dim([L]ORI)>0 & ORI<>"")
  I = instr(1,CHAMP,"]")
  If I : CHAMP = right$(CHAMP,I+1) : Endif
  I = instr(1,CHAMP,"(")
  If I : CHAMP = right$(CHAMP,I-1) : Endif
  If format$("KTv2:A9u",CHAMP)=CHAMP & evalue("dim([V]"+CHAMP+")")<0
   K = 0
   If ORI<>""
    Read [ATB]CODFIC = ORI
    Read [ATZ]CODZONE = ORI;CHAMP
    If !fstat
     K = 1
     If [F:ATZ]CODACT<>""
      Read [ACV]CODACT=[F:ATZ]CODACT
      If fstat | [F:ACV]FLACT<>2
       K = 0
      Endif
     Endif
    Endif
    If !K
     MESSAGE = "[F:"+ORI+"]"+CHAMP-":"-mess(41,100,1) : # Champ inexistant
     OK = 0 : Break
    Endif
   Else
    For I=0 To dim([L]TAB)-1
     If [L]TAB(I)<>""
      Read [ATB]CODFIC = [L]TAB(I)
      Read [ATZ]CODZONE = [L]TAB(I);CHAMP
      If !fstat
       K = 1
       If [F:ATZ]CODACT<>""
        Read [ACV]CODACT=[F:ATZ]CODACT
        If fstat | [F:ACV]FLACT<>2
         K = 0
        Endif
       Endif
      Endif
     Endif
    Next I
    If !K
     MESSAGE = CHAMP-":"-mess(41,100,1) : # Champ inexistant
     OK = 0 : Break
    Endif
   Endif
  Endif
 Endif
Until CHAINE=""
If !OK
 If MESSAGE = "" : MESSAGE = mess(101,123,1) : Endif : # Expression de lien incorrecte
 End OK
Endif
If (find(OPT,1,3) & NBCMP<>NBCLE) | (find(OPT,2,4) & NBCMP>NBCLE)
 OK = 0
 MESSAGE = mess(101,123,1) : # Expression de lien incorrecte
 End OK
Endif
End OK
