###########################################################################
# Lecture de l'unite et arrondi
Subprog QTEARR(QTY,UOM)
Variable Decimal QTY
Value Char UOM

If QTY=0 | UOM="" End Endif     : # Bug 73721
# lecture de l'unité
Local File TABUNIT [TUN]
If UOM <> "" & UOM<>[F:TUN]UOM   # FQ 70409 GA 01/2011 PERFORMANCES ne pas relire si unité déjà lue
 Read [TUN]TUN0 = UOM : If fstat Raz [F:TUN] Endif
Endif
# le format est determiné par la variable globale GF..(7)
# Arrondi de la quantité selon nb de décimales :
#If QTY <> 0 & fstat = 0        : # Bug 73721
If QTY <> 0                     : # Bug 73721
 Case [F:TUN]UOMDEC
  When 0 : QTY = arr(QTY,1)
  When 1 : QTY = arr(QTY,0.1)
  When 2 : QTY = arr(QTY,0.01)
  When 3 : QTY = arr(QTY,0.001)
  When 4 : QTY = arr(QTY,0.0001)
  When 5 : QTY = arr(QTY,0.00001)
  When 6 : QTY = arr(QTY,0.000001)
 Endcase
# ou mieux : arr(QTY,10^-[F:TUN]UOMDEC)
Endif
End

###########################################################################
Subprog QTEARR_CC(CTX, QTY, UOM)
Variable Instance CTX Using OBJECT
Variable Decimal QTY
Value Char UOM

Local Integer IUOMDEC

  # Issue X3-31898 - 2017-11-23 by FGR : Using cache classes (_CC)
  If QTY = 0 or UOM = AVOID.ACHAR Then
    End
  Endif
  # Arrondi de la quantité selon nb de décimales :
  If QTY <> 0 Then
    IUOMDEC = fmet CTX.ACACHE.ACUR.AGETVALDEC(UOM, "UOMDEC")
    Case IUOMDEC
      When 0 : QTY = arr(QTY,1)
      When 1 : QTY = arr(QTY,0.1)
      When 2 : QTY = arr(QTY,0.01)
      When 3 : QTY = arr(QTY,0.001)
      When 4 : QTY = arr(QTY,0.0001)
      When 5 : QTY = arr(QTY,0.00001)
      When 6 : QTY = arr(QTY,0.000001)
    Endcase
    # ou mieux : arr(QTY,10^-[F:TUN]UOMDEC)
  Endif
End

###########################################################################
# lit la devise (pour récupérer le format) puis ARRONDIT le montant
Subprog ARRDEV(MNT,DEV,CPY)
Variable Decimal MNT
Variable Char DEV
Value    Char CPY

  If DEV = "" : DEV = func SREPLACEGLOB_SYRA.GET_GLOCALDEV("", [L]CPY) : Endif #(AVOID.ACHAR, [L]CPY) : Endif

  Local File TABCUR [TCU]

  Read [TCU]TCU0 = DEV
  If fstat = 0
   MNT = arr(MNT,[F:TCU]CURRND)
  Endif

End

