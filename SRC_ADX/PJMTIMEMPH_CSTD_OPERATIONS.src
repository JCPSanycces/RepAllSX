#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMTIMEMPH
###################################################################################################
# OPERATIONS
###################################################################################################
$FROM_PJMOPEAFF
#Value Char CLB ()
#Variable Instance PJMOPEAFF Using C_PJMOPEAFF : #
#Variable Instance TECPJOAPTEH Using C_TECPJOAPTEH : #
#Local Integer ARET_VALUE
  # ------------------------------------
  Local Integer ITO_CREATE
  Local Integer ILINE
  Local Instance LOGFILE Using C_ALOG
  Local Integer IRETLOG
  # ------------------------------------
  If this.CLB <> AVOID.ACHAR and CLB <> this.CLB Then
    [L]ARET_VALUE = fmet this.SETERROR("", mess(120,7711,1), [V]CST_AERROR)
    Return
  Endif
  # ------------------------------------
  Local File PJMTIMEMPH [PTEH]
  Look [PTEH]PTEH0=CLB
  # ------------------------------------
  If fstat Then
    ITO_CREATE = [V]CST_AYES
  Else
    ITO_CREATE = [V]CST_ANO
  Endif
  # ------------------------------------
  If ITO_CREATE = [V]CST_AYES Then
    # ------------------------------------
    # This is a new user in time entries
    this.CLB = CLB
  Else
    # ------------------------------------
    # This is a new date on an existing user in time entries
    If this.CLB = "" Then
      [L]ARET_VALUE = fmet this.AREAD(CLB)
    Endif
  Endif
  # ------------------------------------
  ILINE = fmet this.ADDLINE("TIMENT",[V]CST_ALASTPOS)
  If ILINE <> [V]CST_ANOTDEFINED Then
    this.TIMENT(ILINE).PIMTASCOD = PJMOPEAFF.KEYCONCAT
    this.TIMENT(ILINE).CUR       = PJMOPEAFF.CUR
    this.TIMENT(ILINE).FCY       = PJMOPEAFF.TASFCY
    this.TIMENT(ILINE).PTEUOM    = PJMOPEAFF.POUOM
    this.TIMENT(ILINE).PTEQTY    = PJMOPEAFF.POACSMQTY
    this.TIMENT(ILINE).OPENUM    = PJMOPEAFF.OPENUM
  Endif
  # ------------------------------------
  If [L]ARET_VALUE <> [V]CST_AERROR Then
    # ------------------------------------
    If ITO_CREATE = [V]CST_AYES Then
      [L]ARET_VALUE = fmet PJMOPEAFF.AINSERT()
    Else
      [L]ARET_VALUE = fmet PJMOPEAFF.AUPDATE()
    Endif
    # ------------------------------------
  Endif
  # ------------------------------------
  If [L]ARET_VALUE <> [V]CST_AOK Then
    # ------------------------------------
    If LOGFILE = null Then
      LOGFILE = NewInstance C_ALOG AllocGroup null
      IRETLOG = fmet LOGFILE.ABEGINLOG(mess(276,2260,1))
    Endif
    # ------------------------------------
    Call MSGSTACK_DUMP_MESSAGES_INTO_LOG(this, LOGFILE) From SYRSTACKTOOLS
    # ------------------------------------
    If LOGFILE <> null Then
      IRETLOG = fmet LOGFILE.AFLUSHLOG()
      IRETLOG = fmet LOGFILE.AENDLOG()
      FreeGroup LOGFILE
    Endif
    # ------------------------------------
  Endif
  # ------------------------------------
Return

#######################################################################################
$TIMENT_VALIDATION
#Value Char CLB ()
#Variable Instance TECPTESTA Using C_TECPTESTA : #
#Local Integer ARET_VALUE

Local Instance LOGFILE Using C_ALOG
Local Instance ZINSPJMTE Using C_PJMTIMEMPH
Local Instance ZTECPTESTA Using C_TECPTESTA
Local Integer IRET
Local Integer IRETLOG

  # Issue X3-66487 - 2018-04-08 by SINGC
  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  If TECPTESTA <> null Then
    Repeat
      If ZTECPTESTA <> null Then
        FreeGroup ZTECPTESTA
        Raz ZTECPTESTA
      Endif
      ZTECPTESTA = NewInstance C_TECPTESTA AllocGroup null
      IRET = fmet ZTECPTESTA._LOAD_ONE_TIMENT(TECPTESTA)
      If IRET < [V]CST_AERROR Then
        If maxtab(ZTECPTESTA.TIMENT) > 0 Then
          # ------------------------------------
          ZINSPJMTE = NewInstance C_PJMTIMEMPH AllocGroup null
          IRET = fmet ZINSPJMTE.AREAD(ZTECPTESTA.TIMENT(1).CLB)
          If IRET < [V]CST_AERROR Then
            ZINSPJMTE.TCHACTION = "TIMENTVAL"
            IRET = fmet ZINSPJMTE._TIMENT_VALIDATION(ZTECPTESTA)
            If IRET < [V]CST_AERROR Then
              IRET = fmet ZINSPJMTE.AUPDATE()
              If IRET >= [V]CST_AERROR Then
                [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(1082,2260,1), [V]CST_AERROR))
                IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO(ZINSPJMTE, this)
              Endif
            Else
              [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(1082,2260,1), [V]CST_AERROR))
              IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO(ZINSPJMTE, this)
            Endif
          Else
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", ZTECPTESTA.TIMENT(1).CLB - ":" - mess(49,125,1), [V]CST_AERROR))
          Endif
          # ------------------------------------
          FreeGroup ZINSPJMTE
          Raz ZINSPJMTE
          # ------------------------------------
        Endif
      Endif
    Until maxtab(ZTECPTESTA.TIMENT) = 0
    # ------------------------------------
    If ZTECPTESTA <> null Then
      FreeGroup ZTECPTESTA
      Raz ZTECPTESTA
    Endif
    # ------------------------------------
    If [L]ARET_VALUE <> [V]CST_AOK Then
      If LOGFILE = null Then
        LOGFILE = NewInstance C_ALOG AllocGroup null
        IRETLOG = fmet LOGFILE.ABEGINLOG(mess(5,2269,1))
      Endif
      # ------------------------------------
      Call MSGSTACK_DUMP_MESSAGES_INTO_LOG(this, LOGFILE) From SYRSTACKTOOLS
      # ------------------------------------
    Endif
    # ------------------------------------
    If LOGFILE <> null Then
      TECPTESTA.LOGFILNAM = fmet LOGFILE.AGETNAME()          # Set in the parameter technical class the name of the log file
      IRETLOG = fmet LOGFILE.AFLUSHLOG()
      IRETLOG = fmet LOGFILE.AENDLOG()
      FreeGroup LOGFILE
    Endif
  Endif
Return

