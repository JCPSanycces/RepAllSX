#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ECP2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRCPC
mkstat = 0
zoncou = "NBRCPC"
indice = 0
status = 1
zoncou = "NBRCPC"
If varmode([M]NBRCPC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRCPC" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRCPC
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRCPC = nolign
   status = 75
   Call SAI_NBRCPC(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBRCPC From SUBECP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBRCPC" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

indice = 0
status = 1
zoncou = "NBRDLT"
If !mkstat
 NBLIG = [M]NBRDLT
 For nolign=1 To NBLIG
  indice = nolign-1
  [M]NBRDLT = nolign
  status = 75
  Call SAI_NBRDLT(IMPFIC,ACTION,IMPTRT)
  If mkstat : Break : Endif
 Next nolign
 If mkstat : End : Endif
 indice = 0
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBRVAL
mkstat = 0
zoncou = "NBRVAL"
indice = 0
status = 1
zoncou = "NBRVAL"
If varmode([M]NBRVAL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRVAL" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRVAL
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRVAL = nolign
   status = 75
   Call SAI_NBRVAL(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBRVAL From SUBECP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBRVAL" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc tableau 4
####################################
IMPTBL = 1

## Zone NBRGRA
mkstat = 0
zoncou = "NBRGRA"
indice = 0
status = 1
zoncou = "NBRGRA"
If varmode([M]NBRGRA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRGRA" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRGRA
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRGRA = nolign
   status = 75
   Call SAI_NBRGRA(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 5
####################################
IMPTBL = 1

indice = 0
status = 1
zoncou = "NBRDLTVAL"
If !mkstat
 NBLIG = [M]NBRDLTVAL
 For nolign=1 To NBLIG
  indice = nolign-1
  [M]NBRDLTVAL = nolign
  status = 75
  Call SAI_NBRDLTVAL(IMPFIC,ACTION,IMPTRT)
  If mkstat : Break : Endif
 Next nolign
 If mkstat : End : Endif
 indice = 0
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRCPC(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRCPC
mkstat = 0
zoncou = "NBRCPC"
SAVACT = GACTION : GACTION = "STD"
Call C_NBRCPC From SUBECP
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "NBRCPC" : GZNUM = 0 : Endif
Gosub AFF From GSAISIE
If mkstat : End : Endif

## Zone ORICPC
mkstat = 0
zoncou = "ORICPC"
IMPENT = [M]ORICPC(indice)
If varinit([M]ORICPC,indice)=0
 IMPENT = 9
Endif
[M]ORICPC(indice) = IMPENT

## Zone FLGMOD
mkstat = 0
zoncou = "FLGMOD"
IMPENT = [M]FLGMOD(indice)
If varinit([M]FLGMOD,indice)=0
 IMPENT = 1
Endif
[M]FLGMOD(indice) = IMPENT

## Zone FLGOLD
mkstat = 0
zoncou = "FLGOLD"
IMPENT = [M]FLGOLD(indice)
If varinit([M]FLGOLD,indice)=0
 IMPENT = 1
Endif
[M]FLGOLD(indice) = IMPENT

## Zone NBRCPC
mkstat = 0
zoncou = "NBRCPC"

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRDLT(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1



End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBRVAL(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRVAL
mkstat = 0
zoncou = "NBRVAL"
SAVACT = GACTION : GACTION = "STD"
Call C_NBRVAL From SUBECP
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "NBRVAL" : GZNUM = 0 : Endif
Gosub AFF From GSAISIE
If mkstat : End : Endif

## Zone CPCVAL
mkstat = 0
zoncou = "CPCVAL"
WCHAR = [M]CPCVAL(indice)
If varmode([M]CPCVAL,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CPCVAL([M]CPCVAL(indice)) From SUBECP
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CPCVAL(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPCVAL" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]CPCVAL(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CPCVAL" : GZNUM = 22067 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_CPCVAL([M]CPCVAL(indice)) From SUBECP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CPCVAL" : GZNUM = 22067 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJN"
    Local Char    VALEUR(250)
    VALEUR = [M]CPCVAL(indice)
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
    [M]CPCVAL(indice) = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CPCVAL" : GZNUM = 22067 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]CPCVAL(indice) or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_CPCVAL([M]CPCVAL(indice)) From SUBECP
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "CPCVAL" : GZNUM = 22067 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone LEVCPCVAL
mkstat = 0
zoncou = "LEVCPCVAL"
WCHAR = [M]LEVCPCVAL(indice)
If varmode([M]LEVCPCVAL,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_LEVCPCVAL([M]LEVCPCVAL(indice)) From SUBECP
 GACTION = SAVACT
 If mkstat=1 : Raz [M]LEVCPCVAL(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "LEVCPCVAL" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CTLNIV"
  Call CTLNIV([M]LEVCPCVAL(indice),[M]CPCVAL(nolign-1)) From SUBCPC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEVCPCVAL" : GZNUM = 5230 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]LEVCPCVAL(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_LEVCPCVAL([M]LEVCPCVAL(indice)) From SUBECP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "LEVCPCVAL" : GZNUM = 5230 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone ORICPCVAL
mkstat = 0
zoncou = "ORICPCVAL"
IMPENT = [M]ORICPCVAL(indice)
If varinit([M]ORICPCVAL,indice)=0
 IMPENT = 1
Endif
[M]ORICPCVAL(indice) = IMPENT

## Zone CPCDATVAL
mkstat = 0
zoncou = "CPCDATVAL"
WDATE = [M]CPCDATVAL(indice)
If varmode([M]CPCDATVAL,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CPCDATVAL([M]CPCDATVAL(indice)) From SUBECP
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CPCDATVAL(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPCDATVAL" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If WDATE<>[M]CPCDATVAL(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_CPCDATVAL([M]CPCDATVAL(indice)) From SUBECP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CPCDATVAL" : GZNUM = 45890 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone FLGMODVAL
mkstat = 0
zoncou = "FLGMODVAL"
IMPENT = [M]FLGMODVAL(indice)
If varinit([M]FLGMODVAL,indice)=0
 IMPENT = 1
Endif
[M]FLGMODVAL(indice) = IMPENT

## Zone FLGOLDVAL
mkstat = 0
zoncou = "FLGOLDVAL"
IMPENT = [M]FLGOLDVAL(indice)
If varinit([M]FLGOLDVAL,indice)=0
 IMPENT = 1
Endif
[M]FLGOLDVAL(indice) = IMPENT

## Zone NBRVAL
mkstat = 0
zoncou = "NBRVAL"

End

####################################
## Bloc tableau 4
####################################
Subprog SAI_NBRGRA(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRGRA
mkstat = 0
zoncou = "NBRGRA"

## Zone NBRGRA
mkstat = 0
zoncou = "NBRGRA"

End

####################################
## Bloc tableau 5
####################################
Subprog SAI_NBRDLTVAL(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1



End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ECP2"
Return

