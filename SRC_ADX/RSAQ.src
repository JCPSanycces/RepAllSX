#################################################################################################################
#
#   Recapitulative Statements Austria
#
#   PURPOSE :    Exports recapitulative statements as XML-, CSV- and ELMA5-files.
#   AUTHORS :    DNE
#   DATE    :    2012-07-19
#   UPDATES :    2014-05-19 DNE - Output is now volume aware and can be downloaded (US #780)
#
#################################################################################################################

# < DEBUG> ######################################################################################################
Local Char XPARAM(10)(1..10)
Call GCONSULT( "RSA", "", XPARAM ) From GCONSULT
End
# </DEBUG> ######################################################################################################


#** #############################################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #############################################################################################################

$ACTION
    Case ACTION
        When "DEBUT"   : Gosub DEBUT
        When "OK"      : Gosub OK
    Endcase
Return



#** #############################################################################################################
#*
#* Sub chunk:  DEBUT
#*
#* Purpose:    Handler before entering the window
#*             Reads data from the parent screen and prefills the property window.
#*
#*! #############################################################################################################

$DEBUT
    [M] = [M:RSG0]
    [M]CRN2 = [M]CRN
    Affzo [M] 1 - 99

# 2014-05-19 DNE INSERT BEGIN
    # Disable/enable VOLFIL field and get the output volume/storage area.
    [M]TYPEXP = 1 # Client
    Call AM_TYPEXP( [M]TYPEXP )
# 2014-05-19 DNE INSERT END
Return



#** #############################################################################################################
#*
#* Sub chunk:  OK
#*
#* Purpose:    Handler for the OK button.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param BOUT    The code of the pressed button. (Not used at the moment.)
#*
#*! #############################################################################################################

$OK
    Gosub CREATE_RSA_XML
Return



#** #############################################################################################################
#*
#* Sub chunk:  CREATE_RSA_XML
#*
#* Purpose:    Exports an Elster complient XML file which can then be uploaded by the web based
#*             Elster-Formular
#*
#*! #############################################################################################################

$CREATE_RSA_XML
    Local Integer NODECL              : NODECL = 1            # Number of declarations (<ERKLAERUNG/> tags).
    Local Char    FILEEXTENSION(255)  : FILEEXTENSION = "xml"
    Local Char    FILES(100)(50)                              # For the "system" call if a
                                                              # file preview is desired.
    Local Integer I

    If clalev([F:RSLG1])=0  : Local File RSLINESGER1 [RSLG1] : Endif

    # Create file, filename etc.
    Gosub CREATE_RS_FILE_COMMON From RSGQ
# 2014-05-19 DNE MODIF INSERT BEGIN (US #780)
    If RC : Return : Endif
# 2014-05-19 DNE MODIF INSERT END

    # Initialize XML tag stack.
    Gosub XML_INIT From CNSRSGSTDLIB

    # Open XML file.
    XMLFILENAME = FILENAMETR : Gosub XML_OPEN From CNSRSGSTDLIB

    # Create XML tree.
    XMLTAG = "ERKLAERUNGS_UEBERMITTLUNG" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    XMLTAG = "INFO_DATEN" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    XMLTAG = "ART_IDENTIFIKATIONSBEGRIFF" : XMLCONTENT = "FASTNR" : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "IDENTIFIKATIONSBEGRIFF" : XMLCONTENT = [M]CRN : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "PAKET_NR" : XMLCONTENT = [M]NOPKG : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "DATUM_ERSTELLUNG" : XMLATTR= "type='datum'" : XMLCONTENT = format$( "D:YYYY[-]MM[-]DD", date$ ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "UHRZEIT_ERSTELLUNG" : XMLATTR= "type='uhrzeit'" : XMLCONTENT = time$ : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "ANZAHL_ERKLAERUNGEN" : XMLCONTENT = num$( NODECL ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    Gosub XML_POP_TAG From CNSRSGSTDLIB # </INFO_DATEN>
    XMLTAG = "ERKLAERUNG" : XMLATTR= "art='U13'" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    XMLTAG = "SATZNR" : XMLCONTENT = [M]NOREC : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "ALLGEMEINE_DATEN" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    XMLTAG = "ANBRINGEN" : XMLCONTENT = "U13" : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "ZRVON" : XMLATTR= "type='jahrmonat'" : XMLCONTENT = format$( "D:YYYY[-]MM", [M]DATDEB ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "ZRBIS" : XMLATTR= "type='jahrmonat'" : XMLCONTENT = format$( "D:YYYY[-]MM", [M]DATFIN ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "FASTNR" : XMLCONTENT = [M]CRN2 : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "KUNDENINFO" : XMLCONTENT = [M]NOTECUST : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    Gosub XML_POP_TAG From CNSRSGSTDLIB

    # Withdrawal?
    If [M]FLGWDR = 2
        # <GESAMTRUECKZIEHUNG> tag.
        XMLTAG = "GESAMTRUECKZIEHUNG" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
        XMLTAG = "GESAMTRUECK" : XMLCONTENT = "J" : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    Else
        # <ZM> tags.
        Filter [F:RSLG1] Where USERID = func CNSRSGSTDLIB.GETUSERID Order By Key RSLG2
        For [F:RSLG1]
            # Suppress 0 totals.
            If [F:RSLG1]GEREECNUM <> "" and fix( [F:RSLG1]AMTTRN ) <> 0 Then
                XMLTAG = "ZM" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
                XMLTAG = "UID_MS" : XMLCONTENT = num$( [F:RSLG1]GEREECNUM ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
                XMLTAG = "SUM_BGL" : XMLATTR= "type='kz'" : XMLCONTENT = num$( fix( [F:RSLG1]AMTTRN ) ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
                If [F:RSLG1]TRNTYP <> "NORMAL"
                    XMLTAG = [F:RSLG1]TRNTYP : XMLCONTENT = "1" : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
                Endif
                Gosub XML_POP_TAG From CNSRSGSTDLIB # </ZM>
            Endif
            I += 1
        Next
    Endif

    # Close open tags and close the XML file.
    Gosub XML_CLOSE From CNSRSGSTDLIB

# 2014-05-19 DNE INSERT BEGIN (US #780)
    # If the file is to be downloaded to the client initiate the download.
    Gosub DOWNLOAD_FILE_COMMON From RSGQ
# 2014-05-19 DNE INSERT END
# 2014-05-19 DNE DELETE BEGIN (US #780)
#    # Open file in a program (e. g. internet explorer) if FLGPRV is set to YES (2)
#    # and the output file is a local file and parameter VATFILVIE is set properly.
#    If ( FLGPRV = 2 ) and ( left$( FILENAMETR, 2 ) = "#@" )
#        PARAMETERVALUE = func AFNC.PARAM( "VATFILVIE", CPY )
#        If PARAMETERVALUE = ""  Then
#            Call ERREURT( mess(278,107,1), 1 ) From GESECRAN  # "Parameter: VATFILVIE\Please enter a file view path."
#        Else
#            System FILES = PARAMETERVALUE - '"' + right$( FILENAMETR, 3 ) + '"'
#        Endif
#    Else
#        # Signal success.
#        Call MESSAGE( mess(257,107,1) + chr$(10) + func CNSRSGSTDLIB.REPLACE( FILENAMETR, "\", "/" ) ) From GESECRAN # "File succesfully created."
#    Endif
# 2014-05-19 DNE DELETE END
Return



# ###############################################################################################################
# ##########
# ########## Screen/Window handling
# ##########
# ##########
# ##########
# ###############################################################################################################

#################################################################################################################
#
#    Event: While changing field NOPKG
#    Does:  Make sure that the number represented by this alphanumeric field is positive (>=1).
#
#################################################################################################################

Subprog C_NOPKG(VALEUR)
Variable Char VALEUR()

    If val(VALEUR) <= 0
        mkstat = 2
    Endif
End



#################################################################################################################
#
#    Event: While changing field NOREC
#    Does:  Make sure that the number represented by this alphanumeric field is positive (>=1).
#
#################################################################################################################

Subprog C_NOREC(VALEUR)
Variable Char VALEUR()

    If val(VALEUR) <= 0
        mkstat = 2
    Endif
End



# 2014-05-19 DNE INSERT BEGIN (US #780)
#################################################################################################################
#
#    Event: While changing field VOLFIL
#    Does:  Checks if the volume/directory exists and that it is a directory.
#
#################################################################################################################

Subprog C_VOLFIL(VALEUR)
Variable Char VALEUR()

    Call C_VOLFIL( VALEUR ) From RSGQ
End



#################################################################################################################
#
#    Event: After having changed the TYPEXP field
#    Does:  Updates fields after modification of the export to client/server selection
#
#################################################################################################################

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

    Call AM_TYPEXP( VALEUR ) From RSGQ
End
# 2014-05-19 DNE INSERT END
