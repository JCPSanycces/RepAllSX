#<AdxTL>@(#)2.0.0.0 $Revision$

# Issue X3-107197 - 2018-09-14 by CBO : PARAMETER AND ACTIVITY CODE
# Issue X3-74646 - 2018-02-05 by FHA : UK VAT Vat Box management
# Issue X3-82605 - 2018-03-20 by FHA : Making DCLVATPAY Subrog independant of DIA screen
# Issue X3-63066 - 2018-04-23 by FHA : Activity code of this process in the dictionary (GASADC) is set from VATBX to DCL
$ACTION
Case ACTION
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "SORTIE"      : Gosub SORTIE
 When "DEBUT"       : Raz [M:DIA]INI : Affzo [DIA] : Setmok[DIA] With 0
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
Endcase
Return


######################################################################################
$INIT
Gosub OPEN_FIL
Gosub DECLARE
## The DCLVATBAT function runs the batch process with the legislation parameter
#If GFONCTION="DCLVATFRA" | (GSERVEUR=1 & PARAM(1)="FRA")     :# Issue X3-74646
# Local Mask DCLVATFRA [DIA]                                  :# Issue X3-74646
 Local Mask =GDCLFNCORI [DIA]                                 :# Issue X3-74646
 Raz [M:DIA]                                                  :# Issue X3-74646
 [L]DCLTRIW = tolower([L]DCLTRIGRAM)                          :# Issue X3-74646
 #Call LECMEMO("STD","[M:DIA]","dclfra") From GMEMO           :# Issue X3-74646
 Call LECMEMO("STD","[M:DIA]","dcl"+[L]DCLTRIW) From GMEMO    :# Issue X3-74646
#Endif
Return

######################################################################################
$OPEN_FIL
# Tables
If !clalev([F:DLVB])   : Local File DCLVATBOXH   [DLVB]    : Endif
If !clalev([F:DLVB1])  : Local File DCLVATBOXH   [DLVB1]   : Endif
If !clalev([F:DLVBD])  : Local File DCLVATBOXDBD [DLVBD]  : Endif
If !clalev([F:DLVBD1]) : Local File DCLVATBOXDBD [DLVBD1] : Endif
If !clalev([F:DLVBP])  : Local File DCLVATBOXPYD [DLVBP]  : Endif
If !clalev([F:DLVBP1]) : Local File DCLVATBOXPYD [DLVBP1] : Endif
If !clalev([F:VTB])    : Local File VATBOX       [VTB]      : Endif
If !clalev([F:VTD])    : Local File VATBOXD      [VTD]      : Endif
If !clalev([F:CPY])    : Local File COMPANY      [CPY]      : Endif
If !clalev([F:FCY])    : Local File FACILITY     [FCY]      : Endif
If !clalev([F:GTE])    : Local File GTYPACCENT   [GTE]      : Endif
If !clalev([F:TCU])    : Local File TABCUR       [TCU]      : Endif
If !clalev([F:TVT])    : Local File TABVAT       [TVT]      : Endif
If !clalev([F:HAE])    : Local File GACCENTRY    [HAE]      : Endif
If !clalev([F:HAE2])   : Local File GACCENTRY    [HAE2]     : Endif
If !clalev([F:DAE])    : Local File GACCENTRYD   [DAE]      : Endif
If !clalev([F:DAE2])   : Local File GACCENTRYD   [DAE2]     : Endif
If !clalev([F:TRA])    : Local File TABRATVAT    [TRA]      : Endif
If !clalev([F:GAC])    : Local File GACCOUNT     [GAC]      : Endif
# Views
If !clalev([F:TVTD])   : Local File LEGTVTDEB    [TVTD]     : Endif
If !clalev([F:TVTPAY]) : Local File LEGTVTPAY    [TVTPAY]   : Endif
# Off declaration
If !clalev([F:VTBD])   : Local File VATBOX       [VTBD]    : Endif
If !clalev([F:VTDD])   : Local File VATBOXD      [VTDD]    : Endif

Return

######################################################################################
$DECLARE
Local Integer  I, ERR_STOP, OK, NBRFCY
Local Integer  NBLOCK                     : # Number of locks
Local Char     TSYMBOLE(50)(1..GNBSOC)    : # Lock on companies
Local Char     COUNTER(GLONANM)           : # Counter that assigns the request number
Global Integer GNUMRPT, GNUMRPT2          : # Request number used to print VAT declaration
Local  Integer TYPDCL
Local Integer  INDCPY                     : # Number of companies to manage
Local Char     TABCPY(GLONCPY)(1..GNBSOC) : # List of the legal companies that belong to a group
Local Char     LCPY(GLONCPY)              : # To call lockcpy
Local Char     VALPAR(1)                  : # Indicates if the FRAVAT parameter is set to yes (=2)

Local Integer  NBTYPDEB                   : # Number of document types (GTE) defined with tax/debits
Filter [GTE] Where VAT=2
NBTYPDEB = rowcount([F:GTE])
Filter [GTE]
Local Char     TTYPDEB(GLONGTE)(1..NBTYPDEB) # List of of document types (GTE) defined with tax/debits

Local Integer  NBTYPPAY                   : # Number of document types (GTE) defined with tax/payment
Filter [GTE] Where VATPAI=2
NBTYPPAY = rowcount([F:GTE])
Filter [GTE]
Local Char     TTYPPAY(GLONGTE)(1..NBTYPPAY) # List of of document types (GTE) defined with tax/payments

Local Char     OPT(1)                     : # Take into account the value of parameter DCLVATDAT : VAT declaration date (ML687)
#                                               "1"=accounting date or "2"=source document date
Local Char     OPTPAY(1)                  : # Take into account the value of paramter DCLVATPAY : VAT options for shipments (ML688)
#                                               "1"=Tax/Charges Paid First or "2"=Pro Rata
Local Char     CRITERE(250)               : # Criteria
Local Char     COA(GLONCOA)               : # Chart of account
Local Char     DEVLED(GLONCUR)            : # Currency of the general main ledger

Local Integer  SAVGPARTRABTC              : # The value of the GPARTRABTC parameter is saved

# Issue X3-74646
Global Char    GDCLFNCORI(12)                 : # The DCLVAT function DCLVATFRA, DCLVATBRI,...
Local  Char    DCLTRIGRAM(3)                  : # 3 letter code indicating the declaration (FRA,BRI,...)
Local  Char    DCLTRIW(3)
If GFONCTION="DCLVATBAT"
  GDCLFNCORI="DCLVAT"+GBIDC1                  : # GBIDC1 contains the localisation (FRA,BRI) of the batch submitted Declaration
Else
  GDCLFNCORI=GFONCTION
Endif
[L]DCLTRIGRAM=right$(GDCLFNCORI,7)
# End issue X3-74646

# This global variable tells us if the DCLVAT's entry points are used
Global Integer CALL_PT : Raz CALL_PT

If dim(GNBENTREE)>0 & GNBENTREE>0 & find("DCLVATBOX",GENTSTD(1..GNBENTREE))
 CALL_PT=1
Endif
Return

######################################################################################
$CONTROLE

If GOK<1 : FIN = 1 : Return : Endif

# Lock Symbol
Gosub LOCKSYMB
If FIN=1 : Return : Endif
If [M:DIA]ALLCPY=2
 LCPY = ""
Else
 LCPY = [M:DIA]CPY
Endif
Call LOCKCPY(LCPY, OK) From AX3MONO
If !OK : FIN = 1 : Return : Endif

If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif
If dim([M:DIA]LEG)>0 & [M:DIA]LEG<>GCURLEG : GCURLEG=[M:DIA]LEG : Endif

# VAT on debit
If [M:DIA]VAT=2
 # Sequence number assignment to the request
 Call REQUESTNUM(1,COUNTER,FIN)
 If FIN=1 : Return : Endif
 # Document types(GTE) defined with tax on debit
 Call LECPARAM_GTE(1,GCURLEG,NBTYPDEB,TTYPDEB)
Endif

# VAT on payment
If [M:DIA]VATPAY=2
 # Sequence number assignment to the request
 Call REQUESTNUM(2,COUNTER,FIN)
 If FIN=1 : Return : Endif
 # Document types(GTE) defined with tax on payment
 Call LECPARAM_GTE(2,GCURLEG,NBTYPPAY,TTYPPAY)
Endif

Gosub TRABTC

TMP = 1
Return

$TRABTC
# To not display the log file "MASQUE_TRACE" managed by the supervisor in GTRAITE
If GSERVEUR=1 & dim(GPARTRABTC)>0
 SAVGPARTRABTC = GPARTRABTC
 GPARTRABTC = 1
Endif
Return

######################################################################################
$EXEC
If GSERVEUR
 [M:DIA]TRCFLG = 2
 If dim(GPARTRABTC)>0
  GPARTRABTC = SAVGPARTRABTC
 Endif
Endif

If !GSERVEUR & [M:DIA]TRCFLG=2
 Call OUVRE_TRACE(mess(71,107,1)-GDCLFNCORI) From LECFIC                :# Issue X3-74646
Endif

If [M:DIA]TRCFLG=2
 Call ECR_TRACE(mess(00071,00107,1)-":"-GDCLFNCORI,0) From GESECRAN     :# Issue X3-74646
 #Call TRACE_MASQUE("DCLVATFRA","DIA",nomap) From GTRAITE               :# Issue X3-74646
 Call TRACE_MASQUE(GDCLFNCORI,"DIA",nomap) From GTRAITE                 :# Issue X3-74646
 If [M:DIA]VAT=2 : Call ECR_TRACE(mess(400,107,1)-"-"-mess(38,114,1)-":"-num$(GNUMRPT),0) From GESECRAN : Endif
 If [M:DIA]VATPAY=2 :  Call ECR_TRACE(mess(401,107,1)-"-"-mess(38,114,1)-":"-num$(GNUMRPT2),0) From GESECRAN : Endif
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

If [M:DIA]VAT=2
 Call DEBTRANS From GLOCK
 Gosub TR_DELDLV_VAT
 If GOK<1 : Return : Endif
Endif
If [M:DIA]VATPAY=2
 Call DEBTRANS From GLOCK
 Gosub TR_DELDLV_VATPAY
 If GOK<1 : Return : Endif
Endif

If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif
If dim([M:DIA]LEG)>0 & [M:DIA]LEG<>GCURLEG : GCURLEG=[M:DIA]LEG : Endif

# Run the declaration
If [M:DIA]VAT=2
 # Only VAT boxes created in the VATBOXD table (<=> that match TYPBOX=2 or TYPBOX=4)
 # and with a code tax = debit (view TVTD)
 # Issue X3-74646 VATFNC="DCLVATFRA" condition replaced by GDCLFNCORI
 Link [VTD] With [VTB]VTB1~=[F:VTD]VATFNC;[F:VTD]LEG;[F:VTD]VATBOX
&              , [TVTD]TVT0(2)~=[F:VTD]VAT;GCURLEG
& As [LNK_V]
& Where [F:VTD]VATFNC=GDCLFNCORI & [F:VTD]LEG=GCURLEG
  [L]TYPDCL = 1 : Gosub DECLARATION
Endif

If [M:DIA]VATPAY=2
# Issue X3-74646 VATFNC="DCLVATFRA" condition replaced by GDCLFNCORI
 Link [VTDD] With [VTBD]VTB1~=[F:VTDD]VATFNC;[F:VTDD]LEG;[F:VTDD]VATBOX
&              , [TVTD]TVT0(2)~=[F:VTDD]VAT;GCURLEG
& As [LNK_D]
& Where [F:VTDD]VATFNC=GDCLFNCORI & [F:VTDD]LEG=GCURLEG
# Issue X3-74646 VATFNC="DCLVATFRA" condition replaced by GDCLFNCORI
 Link [VTD] With [VTB]VTB1~=[F:VTD]VATFNC;[F:VTD]LEG;[F:VTD]VATBOX
&              , [TVTPAY]TVT0(2)~=[F:VTD]VAT;GCURLEG
& As [LNK_V]
& Where [F:VTD]VATFNC=GDCLFNCORI & [F:VTD]LEG=GCURLEG
 [L]TYPDCL = 2 : Gosub DECLARATION
Endif

If !GSERVEUR & [M:DIA]TRCFLG=2
 Call FERME_TRACE From LECFIC
Endif
If GOK<1 : Return : Endif
Return

######################################################################################
$DECLARATION
GOK = 1

For [CPY]CPY0 Where ([M:DIA]ALLCPY=2 | CPY=[M:DIA]CPY) & CPYLEGFLG=2 & LEG=GCURLEG

 ERR_STOP = 0
 NBRFCY = 0
 Raz VALPAR
 #Call PARAML([F:CPY]CPY,"FRAVAT",VALPAR) From ADOVAL             :# Issue X3-74646
 Call PARAML([F:CPY]CPY,[L]DCLTRIGRAM+"VAT",VALPAR) From ADOVAL   :# Issue X3-74646
 If VALPAR=num$(2)
  # Accounting date or  source document date ?
  Call PARAML([F:CPY]CPY,"DCLVATDAT",OPT) From ADOVAL

  # general ledger
  Call SETCUR(1,[F:CPY]CPY,DEVLED)From CPTDIV # Runs Call SETMAINREF([F:CPY]CPY,GTYPGEN,GTYPANA) From CPTDIV
  Call LECPLAN([F:CPY]CPY,GTYPGEN,[L]COA) From CPTDIV
  Call LEC_TCU(DEVLED) From CPTLEC
  GARODEV = [F:TCU]CURRND # used in the VAT on payment

  # Point d'entrée FCY_FILTER
  Raz [L]CRITERE
  If CALL_PT : GPOINT = "FCY_FILTER" : Gosub ENTREE From EXEFNC : Endif
  If [L]CRITERE="" : [L]CRITERE="1=1" : Endif
  If [M:DIA]FCY<>"" : [L]CRITERE-='& [F:FCY]FCY = "'+[M:DIA]FCY+'"' : Endif

  For [FCY]FCY0 Where LEGCPY=[F:CPY]CPY & FINFLG=2 & evalue(CRITERE)
   If [M:DIA]TRCFLG=2
    Call ECR_TRACE (mess(362,107,1)-[F:FCY]FCY-mess(26,113,1)-[F:CPY]CPY,0) From GESECRAN
   Endif
   If [L]TYPDCL = 1 : # VAT on debit
   # Issue number X3-82605 adding parameters [M:DIA]DETDCL,[M:DIA]TRCFLG,"",[M:DIA]CPY,[M:DIA]FCY
    Call DCLVATDEB([F:CPY]CPY,[F:FCY]FCY,[M:DIA]STRDAT,[M:DIA]ENDDAT,[M:DIA]TYPGEN,OPT,
&                  TTYPDEB,NBTYPDEB,[L]COA,DEVLED,ERR_STOP,[M:DIA]DETDCL,[M:DIA]TRCFLG,"",[M:DIA]CPY,[M:DIA]FCY) From DCLVATBOXDEB
    NBRFCY +=1
    If GOK<1 : Break 2 : Endif
   Endif
   If [L]TYPDCL = 2 : # VAT on payment
    Call PARAML([F:CPY]CPY,"DCLOPTPAY",OPTPAY) From ADOVAL
    # Issue number X3-82605 adding parameters [M:DIA]DATPCE,[M:DIA]ECRAUX,[M:DIA]DETDCL,[M:DIA]TRCFLG,[M:DIA]FCY
    Call DCLVATPAY([F:CPY]CPY,[F:FCY]FCY,[M:DIA]STRDAT2,[M:DIA]ENDDAT2,[M:DIA]TYPGEN,OPTPAY,
&                  TTYPPAY,NBTYPPAY,[L]COA,DEVLED,ERR_STOP,[M:DIA]DATPCE,[M:DIA]ECRAUX,[M:DIA]DETDCL,[M:DIA]TRCFLG,[M:DIA]FCY) From DCLVATBOXPAY
    NBRFCY +=1
    If GOK<1 : Break 2 : Endif
   Endif

   If ERR_STOP>0 & [M:DIA]TYPGEN=1 : Break : Endif

   If [M:DIA]TRCFLG=2
    Call ECR_TRACE (mess(363,107,1)-[F:FCY]FCY-mess(26,113,1)-[F:CPY]CPY,0) From GESECRAN
   Endif
  Next

  # For the french declaration, we add records to the DCLVATBOXH table company by company, for the vat report
  #If GFONCTION = "DCLVATFRA" | (GSERVEUR=1 & PARAM(1)="FRA")       :# Issue X3-74646
   If [M:DIA]TYPGEN<>1 | ERR_STOP=0 | NBRFCY>1
    If [L]TYPDCL = 1 : # VAT on debit
     Call DEBTRANS From GLOCK
     Gosub TR_UPDREPORT_FRA From DCLVATBOXDEB
     If GOK<1 : Break : Endif
    Endif

    If [L]TYPDCL = 2 : # VAT on payment
     Call DEBTRANS From GLOCK
     Gosub TR_UPDREPORT_FRA From DCLVATBOXPAY
     If GOK<1 : Break : Endif
    Endif
   Endif
  #Endif                                                            :# Issue X3-74646
 Endif
Next

If GOK<1 : Return : Endif

Return

######################################################################################
$LOCKSYMB
NBLOCK = 0
If [M:DIA]ALLCPY<>2
 NBLOCK=1
 TSYMBOLE(NBLOCK) = "DCLVATBOX\"+[L]DCLTRIGRAM+"\"+[M:DIA]CPY     :# Issue X3-74646
 Lock =TSYMBOLE(NBLOCK) With lockwait=0
 If fstat
  GERR = 2 : GMESSAGE = mess(30,100,1)
  FIN  = 1 : Return
 Endif
 INDCPY +=1
 TABCPY(INDCPY) = [M:DIA]CPY
Else
 CRITERE = "CPYLEGFLG="+num$(2)
 If dim([M:DIA]LEG)>0
  CRITERE -= "& LEG=[M:DIA]LEG"
 Endif
 If func AFNC.ACTIV("KFR")   # Issue X3-107197
 	For [CPY]CPY0 Where evalue(CRITERE)
    If func AFNC.PARAM("FRAVAT",[F:CPY]CPY)="2" #& (GFONCTION="DCLVATFRA" | (GSERVEUR=1 & PARAM(1)="FRA") )   :# Issue X3-74646
      NBLOCK +=1
      TSYMBOLE(NBLOCK) = "DCLVATBOX\"+[L]DCLTRIGRAM+"\"+[F:CPY]CPY   :# Issue X3-74646
      Lock =TSYMBOLE(NBLOCK) With lockwait=0
      If fstat
        GERR = 2 : GMESSAGE=mess(30,100,1)
        FIN  = 1 : Break
      Endif
      INDCPY +=1
      TABCPY(INDCPY) = [F:CPY]CPY
    Endif
  Next
 Endif   # Issue X3-107197
 If FIN=1 : Return : Endif
Endif
Return

######################################################################################
# Sequence number assign at a folder level
Subprog REQUESTNUM(TYP,COUNTER,FIN)
Value    Integer TYP
Variable Char    COUNTER
Variable Integer FIN

Local Char     NUMIMP(8) : # Request number
Local Integer  STAT      : #Status
If !clalev([F:TCA]) : Local File TABCOUAFF  [TCA] : Endif

Raz COUNTER
Read [TCA]TCA0=2;"";""
If !fstat
 Case TYP
  When 1 : COUNTER = [F:TCA]CODNUM(3) : # VAT on debit
  When 2 : COUNTER = [F:TCA]CODNUM(4) : # VAT on payment
 Endcase
Endif
If COUNTER=""
 Case TYP
  When 1 : COUNTER = "DLV" : # VAT on debit
  When 2 : COUNTER = "DVP" : # VAT on payment
 Endcase
Endif

Call NUMERO(COUNTER,"",[0/0/0],"",NUMIMP,STAT) From SUBANM
If STAT
 Gosub MESSAGE From SUBANM
 Call ERREUR(mess(60,199,1)-"("+COUNTER+") : "-MESSA) From GESECRAN
 FIN = 1 : End
Endif
Case TYP
  When 1 : GNUMRPT   = val(NUMIMP)
  When 2 : GNUMRPT2  = val(NUMIMP)
 Endcase
End


######################################################################################
# We begin to delete the simulations that matches the execution criteria
$TR_DELDLV_VAT
GOK = 1
Trbegin [DLVB],[DLVBD]

If [M:DIA]CPY<>"" & [M:DIA]FCY<>""
 # Obviously the declaration is run in simulation when FCY<>"".
 # When the actual declaration will be run for the company, all the simulations will be removed

 Filter [DLVBD1] Where CPY=[M:DIA]CPY & FCY=[M:DIA]FCY & SIM=2
 For [DLVBD1]DLVBD0(2)
  #Delete [DLVB] Where NUMRPT=[F:DLVBD1]NUMRPT & VATFNC="DCLVATFRA" & DCLVATTYP=1     :# Issue X3-74646
  Delete [DLVB] Where NUMRPT=[F:DLVBD1]NUMRPT & VATFNC=GDCLFNCORI & DCLVATTYP=1       :# Issue X3-74646
  If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVB",[M:DIA]CPY-[M:DIA]FCY-num$([F:DLVBD1]NUMRPT)) From GLOCK : Break : Endif
  If adxdlrec>0
   Delete [DLVBD] Where NUMRPT=[F:DLVBD1]NUMRPT
   If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVBD",[M:DIA]CPY-[M:DIA]FCY-num$([F:DLVBD1]NUMRPT)) From GLOCK : Break : Endif
  Endif
 Next
 Filter [DLVBD1]
 If GOK<1 : Goto AB_TR_DELDLV : Endif

 # If DCLVATDEBD is empty but not DCLVATDEB
 #Delete [DLVB] Where CPY=[M:DIA]CPY & FCY=[M:DIA]FCY & SIM=2 & VATFNC="DCLVATFRA" & DCLVATTYP=1  :# Issue X3-74646
 Delete [DLVB] Where CPY=[M:DIA]CPY & FCY=[M:DIA]FCY & SIM=2 & VATFNC=GDCLFNCORI & DCLVATTYP=1    :# Issue X3-74646
 If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVB",[M:DIA]CPY-[M:DIA]FCY) From GLOCK : Goto AB_TR_DELDLV : Endif

 Elsif [M:DIA]CPY<>""
  # Delete the company
  #Filter [DLVB1] Where CPY=[M:DIA]CPY & SIM=2 & VATFNC="DCLVATFRA" & DCLVATTYP=1                 :# Issue X3-74646
  Filter [DLVB1] Where CPY=[M:DIA]CPY & SIM=2 & VATFNC=GDCLFNCORI & DCLVATTYP=1                   :# Issue X3-74646
  For [DLVB1]DLVB0(4)
   Delete [DLVBD] Where NUMRPT=[F:DLVB1]NUMRPT
   If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVBD",[M:DIA]CPY-num$([F:DLVB1]NUMRPT)) From GLOCK : Break : Endif
   #Delete [DLVB] Where NUMRPT=[F:DLVB1]NUMRPT & VATFNC="DCLVATFRA" & DCLVATTYP=1                 :# Issue X3-74646
   Delete [DLVB] Where NUMRPT=[F:DLVB1]NUMRPT & VATFNC=GDCLFNCORI & DCLVATTYP=1                   :# Issue X3-74646
   If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVB",[M:DIA]CPY-num$([F:DLVB1]NUMRPT)) From GLOCK : Break : Endif
  Next
  Filter [DLVB1]
  If GOK<1 : Goto AB_TR_DELDLV : Endif

 Elsif [M:DIA]ALLCPY=2
  # Delete all the companies
  If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif
  If dim([M:DIA]LEG)>0 & [M:DIA]LEG<>GCURLEG : GCURLEG=[M:DIA]LEG : Endif
  #Filter [DLVB1] Where SIM=2 & VATFNC="DCLVATFRA" & DCLVATTYP=1                                  :# Issue X3-74646
  Filter [DLVB1] Where SIM=2 & VATFNC=GDCLFNCORI & DCLVATTYP=1                                    :# Issue X3-74646
  Link [DLVB1] With [CPY]CPY0=[F:DLVB1]CPY As [LNK] Where [F:CPY]LEG=GCURLEG
  For [LNK]DLVB0(4)
   Delete [DLVBD] Where NUMRPT=[F:DLVB1]NUMRPT
   If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVBD",[M:DIA]CPY-num$([F:DLVB1]NUMRPT)) From GLOCK : Break : Endif
   #Delete [DLVB] Where NUMRPT=[F:DLVB1]NUMRPT & VATFNC="DCLVATFRA" & DCLVATTYP=1                 :# Issue X3-74646
   Delete [DLVB] Where NUMRPT=[F:DLVB1]NUMRPT & VATFNC=GDCLFNCORI & DCLVATTYP=1                   :# Issue X3-74646
   If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVB",[M:DIA]CPY-num$([F:DLVB1]NUMRPT)) From GLOCK : Break : Endif
  Next
  Filter [DLVB1]
  If GOK<1 : Goto AB_TR_DELDLV : Endif
 Endif
Commit
Return

######################################################################################
# We begin to delete the simulations that matches the execution criteria
$TR_DELDLV_VATPAY
GOK = 1

Trbegin [DLVB],[DLVBP]

 If [M:DIA]CPY<>"" & [M:DIA]FCY<>""
  # Obviously the declaration is run in simulation when FCY<>"".
  # When the actual declaration will be run for the company, all the simulations will be removed
  Filter [DLVBP1] Where CPY=[M:DIA]CPY & FCY=[M:DIA]FCY & SIM=2
  For [DLVBP1]DLVBP0(2)
   #Delete [DLVB] Where NUMRPT=[F:DLVBP1]NUMRPT & VATFNC="DCLVATFRA" & DCLVATTYP=2                :# Issue X3-74646
   Delete [DLVB] Where NUMRPT=[F:DLVBP1]NUMRPT & VATFNC=GDCLFNCORI & DCLVATTYP=2                  :# Issue X3-74646
   If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVB",[M:DIA]CPY-[M:DIA]FCY-num$([F:DLVBP1]NUMRPT)) From GLOCK : Break : Endif
   Delete [DLVBP] Where NUMRPT=[F:DLVBP1]NUMRPT
   If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVBP",[M:DIA]CPY-[M:DIA]FCY-num$([F:DLVBP1]NUMRPT)) From GLOCK : Break : Endif
  Next
  Filter [DLVBP1]
  If GOK<1 : Goto AB_TR_DELDLV : Endif

  # If DCLVATDEBD is empty but not DCLVATDEB
  #Delete [DLVB] Where CPY=[M:DIA]CPY & FCY=[M:DIA]FCY & SIM=2 & VATFNC="DCLVATFRA" & DCLVATTYP=2 :# Issue X3-74646
  Delete [DLVB] Where CPY=[M:DIA]CPY & FCY=[M:DIA]FCY & SIM=2 & VATFNC=GDCLFNCORI & DCLVATTYP=2   :# Issue X3-74646
  If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVB",[M:DIA]CPY-[M:DIA]FCY) From GLOCK : Goto AB_TR_DELDLV : Endif

 Elsif [M:DIA]CPY<>""
  # Delete the company
  #Filter [DLVB1] Where CPY=[M:DIA]CPY & SIM=2 & VATFNC="DCLVATFRA" & DCLVATTYP=2                 :# Issue X3-74646
  Filter [DLVB1] Where CPY=[M:DIA]CPY & SIM=2 & VATFNC=GDCLFNCORI & DCLVATTYP=2                   :# Issue X3-74646
  For [DLVB1]DLVB0(4)
   Delete [DLVBP] Where NUMRPT=[F:DLVB1]NUMRPT
   If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVBD",[M:DIA]CPY-num$([F:DLVB1]NUMRPT)) From GLOCK : Break : Endif
   #Delete [DLVB] Where NUMRPT=[F:DLVB1]NUMRPT & VATFNC="DCLVATFRA" & DCLVATTYP=2                 :# Issue X3-74646
   Delete [DLVB] Where NUMRPT=[F:DLVB1]NUMRPT & VATFNC=GDCLFNCORI & DCLVATTYP=2                   :# Issue X3-74646
   If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVB",[M:DIA]CPY-num$([F:DLVB1]NUMRPT)) From GLOCK : Break : Endif
  Next
  Filter [DLVB1]
  If GOK<1 : Goto AB_TR_DELDLV : Endif

 Elsif [M:DIA]ALLCPY=2
  # Delete all the companies
  If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif
  If dim([M:DIA]LEG)>0 & [M:DIA]LEG<>GCURLEG : GCURLEG=[M:DIA]LEG : Endif
  #Filter [DLVB1] Where SIM=2 & VATFNC="DCLVATFRA" & DCLVATTYP=2                                  :# Issue X3-74646
  Filter [DLVB1] Where SIM=2 & VATFNC=GDCLFNCORI & DCLVATTYP=2                                    :# Issue X3-74646
  Link [DLVB1] With [CPY]CPY0=[F:DLVB1]CPY As [LNK] Where [F:CPY]LEG=GCURLEG
  For [LNK]DLVB0(4)
   Delete [DLVBP] Where NUMRPT=[F:DLVB1]NUMRPT
   If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVBP",[M:DIA]CPY-num$([F:DLVB1]NUMRPT)) From GLOCK : Break : Endif
   #Delete [DLVB] Where NUMRPT=[F:DLVB1]NUMRPT & VATFNC="DCLVATFRA" & DCLVATTYP=2                 :# Issue X3-74646
   Delete [DLVB] Where NUMRPT=[F:DLVB1]NUMRPT & VATFNC=GDCLFNCORI & DCLVATTYP=2                   :# Issue X3-74646
   If fstat=1 | fstat>5 : GOK = 0 : Call RSTA("DLVB",[M:DIA]CPY-num$([F:DLVB1]NUMRPT)) From GLOCK : Break : Endif
  Next
  Filter [DLVB1]
  If GOK<1 : Goto AB_TR_DELDLV : Endif
 Endif

Commit
Return

$AB_TR_DELDLV
Rollback
Return

######################################################################################
# Load the list of the  document types (GTE) defined with tax on issue
Subprog LECPARAM_GTE(TYP,WLEG,NBTYP,TTYP)
Value    Integer TYP
Value    Char    WLEG
Variable Integer NBTYP
Variable Char    TTYP()(1..)

If !clalev([F:GTE]) : Local File GTYPACCENT [GTE] : Endif

Filter [GTE] Where LEG=[L]WLEG | LEG="" Order By Key CLE=TYP Asc ; LEG Desc
Raz NBTYP, TTYP
For [GTE]CLE(1)
 If TYP=1 & [F:GTE]VAT = 2
  NBTYP += 1
  TTYP(NBTYP) = [F:GTE]TYP
 Endif
 If TYP=2 & [F:GTE]VATPAI = 2
  NBTYP += 1
  TTYP(NBTYP) = [F:GTE]TYP
 Endif
Next
Filter [GTE]
End

######################################################################################
$TERMINE
Local Integer NBPAR1, NBPAR2
Local Char    TBPAR1(20)(1..10) , TBVAL1(50)(1..10)
Local Char    TBPAR2(20)(1..10) , TBVAL2(50)(1..10)
Local Char    NAM_PRT(GLONADP)

# Print the report if the declaration is run in simulation mode or in actual mode and no error occurs
If ([M:DIA]TYPGEN=2 | ([M:DIA]TYPGEN=1 & GOK=1))
 If GSERVEUR=1
  # Batch
  NBPAR1 = 0
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "numrpt"        : TBVAL1(NBPAR1) = num$(GNUMRPT)
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "detail_piece"  : TBVAL1(NBPAR1) = num$(2)
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "impselections" : TBVAL1(NBPAR1) = num$(1)
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "societe"       : TBVAL1(NBPAR1) = [M:DIA]CPY
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "dclfncori"     : TBVAL1(NBPAR1) = [V]GDCLFNCORI          :# Issue X3-74646

  NBPAR2 = 0
  NBPAR2 +=1 : TBPAR2(NBPAR2) = "numrpt"        : TBVAL2(NBPAR2) = num$(GNUMRPT2)
  NBPAR2 +=1 : TBPAR2(NBPAR2) = "detail"        : TBVAL2(NBPAR2) = num$([M:DIA]DETAIL)
  NBPAR2 +=1 : TBPAR2(NBPAR2) = "impselections" : TBVAL2(NBPAR2) = num$(1)
  NBPAR2 +=1 : TBPAR2(NBPAR2) = "societe"       : TBVAL2(NBPAR2) = [M:DIA]CPY
  NBPAR2 +=1 : TBPAR1(NBPAR2) = "dclfncori"     : TBVAL2(NBPAR2) = [V]GDCLFNCORI          :# Issue X3-74646

  If [M:DIA]FCY<>""
   Call PARAML([M:DIA]FCY,"VATRPTBAT",NAM_PRT) From ADOVAL
  Elsif [M:DIA]CPY<>""
   Call PARAML([M:DIA]CPY,"VATRPTBAT",NAM_PRT) From ADOVAL
  Else
   Call PARAML("","VATRPTBAT",NAM_PRT) From ADOVAL
  Endif

  If [M:DIA]VAT=2
   [M:DIA]NUMRPT = GNUMRPT
   Call ETAT("DCLVATBOXDEB1",NAM_PRT,"",0,"",TBPAR1,TBVAL1) From AIMP3
  Endif
  If [M:DIA]VATPAY=2
   [M:DIA]NUMRPT2 = GNUMRPT2
   Call ETAT("DCLVATBOXPAY1",NAM_PRT,"",0,"",TBPAR2,TBVAL2) From AIMP3
  Endif

 Else

  If [M:DIA]VAT = 2
   [M:DIA]NUMRPT = GNUMRPT
   Call IMPRIME("DCLVATBOXDEB1","DCLVATBOX") From ETAT
  Endif
  If [M:DIA]VATPAY = 2
   [M:DIA]NUMRPT2 = GNUMRPT2
   Call IMPRIME("DCLVATBOXPAY1","DCLVATBOX") From ETAT
  Endif
 Endif
Endif

# Logfile
If !GSERVEUR & [M:DIA]TRCFLG=2
 TRA = 1
Else
 TRA = 0
Endif
Return

######################################################################################
$SORTIE
If dim(GNUMRPT)>0  : Kill GNUMRPT : Endif
If dim(GNUMRPT2)>0 : Kill GNUMRPT2 : Endif
If dim(GDCLFNCORI)>0 : Kill GDCLFNCORI : Endif    :# Issue X3-74646

# Unlock
For I=1 To NBLOCK
 Unlock =TSYMBOLE(I)
Next
Return

#############################################################################
## BATCH
#############################################################################
$OUVRE_BATCH
# Initializes the right window in a batch process
BCRIT = "DCLVAT"+PARAM(1)
Gosub OPEN_FIL
Gosub DECLARE
Return


#############################################################################
## Etiquettes du masque DCLVATFRA et Autres
#############################################################################
Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 Grizo ALLCPY
 Actzo CPY
 mkstat = 1 : End
Endif
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From CPTTRT
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Call AS_CPY(VALEUR) From CPTTRT
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Char VALPAR(1)
If VALEUR="" & [M]ALLCPY= [V]CST_ANO
 GMESSAGE =  mess(10,123,1)
 mkstat = 2 : End
Endif
#If GFONCTION="DCLVATFRA" | (GFONCTION="DCLVATBAT" & GBIDC1="FRA")    :# Issue X3-74646
# Check that the FRAVAT parameter is set to Yes
 Raz VALPAR
 Local Char DCLTRIGRAM(3)                                             :# Issue X3-74646
 [L]DCLTRIGRAM=right$(GDCLFNCORI,7)                                   :# Issue X3-74646
 #Call PARAML(VALEUR,"FRAVAT",VALPAR) From ADOVAL                     :# Issue X3-74646
 Call PARAML(VALEUR,[L]DCLTRIGRAM+"VAT",VALPAR) From ADOVAL           :# Issue X3-74646
 If VALPAR <> num$([V]CST_AYES)
  GMESSAGE = mess(231,107,1)
  mkstat = 2 : End
 Endif
 Call LEC_CPY(VALEUR) From CPTLEC
 GCURLEG = [F:CPY]LEG
 If dim([M:DIA]LEG)>0
  [M:DIA]LEG =[F:CPY]LEG
  Affzo [M:DIA]LEG
 Endif
 # Check that the VATBOX table contains a record for the legislation (of the company)
 # If the declaration is run for a group, either a company of a group has a BEL legislation
 #Look [VTB]VTB0(2)="DCLVATFRA"; GCURLEG                              :# Issue X3-74646
 Look [VTB]VTB0(2)=GDCLFNCORI; GCURLEG                                :# Issue X3-74646
 If fstat
  GMESSAGE = mess(218,107,1) - GCURLEG - "-" - mess(366,107,1)
  mkstat = 2 : End
 Endif
#Endif                                                                :# Issue X3-74646
End

Subprog C_LEG(VALEUR)
Variable Char VALEUR()
Call C_LEG(VALEUR) From CPTTRT
# Check that the VATBOX table contains a record for the legislation (of the company)
# If the declaration is run for a group, either a company of a group has a BEL legislation
#If (GFONCTION = "DCLVATFRA" | (GFONCTION="DCLVATBAT" & GBIDC1="FRA") ) and VALEUR <> AVOID.ACHAR :# Issue X3-74646
If VALEUR <> AVOID.ACHAR                                                                          :# Issue X3-74646
 #Look [VTB]VTB0(2)="DCLVATFRA"; VALEUR                                                           :# Issue X3-74646
 Look [VTB]VTB0(2)=GDCLFNCORI; VALEUR                                                             :# Issue X3-74646
 If fstat
  GMESSAGE = mess(218,107,1) - VALEUR - "-" - mess(366,107,1)
  mkstat = 2 : End
 Endif
Endif
End


## Suggestion 10822
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Local Char  PARAM(10)
Call PARAM(VALEUR,"DCLVATPAY",PARAM) From ADOVAL
If dim([M]VATPAY)>0
 If PARAM="2" : [M]VATPAY=2 : Else [M]VATPAY=1 : Endif
 Affzo [M]VATPAY
Endif
If dim([M]VATPAY)>0
 Call AP_VATPAY([M]VATPAY)
Endif
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
If [M]ALLCPY=2 : VALEUR = 2 : End : Endif
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Effzo FCY : Diszo FCY :  Actzo [M]TYPGEN : Else : Actzo FCY : [M]TYPGEN=2 : Diszo [M]TYPGEN : Affzo [M]TYPGEN : Endif

End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR
If [M]ALLFCY=2 : mkstat = 1 : End : Endif
End

## Si on choisit un site en particulier c'est forcement une simulation !
Subprog AS_TYPGEN(VALEUR)
Variable Integer VALEUR
If [M]ALLFCY<>2 : VALEUR=2 : mkstat = 2 : End : Endif
End

## Etiquettes pour le bloc TVA sur débits
Subprog AP_VAT(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
 Grizo STRDAT, ENDDAT, DETVCR
Else
 Actzo STRDAT, ENDDAT, DETVCR
Endif
End

Subprog D_STRDAT(VALEUR)
Variable Date    VALEUR
VALEUR = gdat$(1,month(date$)-1,year(date$))
End

Subprog D_ENDDAT(VALEUR)
Variable Date    VALEUR
VALEUR = eomonth([M]STRDAT)
End

## Etiquettes pour le bloc TVA sur encaissements
Subprog D_VATPAY(VALEUR)
Variable Integer VALEUR
Local Char  PARAM(10)
Call PARAM([M]CPY,"DCLVATPAY",PARAM) From ADOVAL
If PARAM="2" : VALEUR=2 : Else VALEUR=1 : Endif
Call AP_VATPAY(VALEUR)
End

Subprog AP_VATPAY(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
 Grizo STRDAT2, ENDDAT2, DATPCE, DETAIL, ECRAUX
Else
 Actzo STRDAT2, ENDDAT2, DATPCE, DETAIL, ECRAUX
Endif
End

Subprog D_STRDAT2(VALEUR)
Variable Date    VALEUR
VALEUR = gdat$(1,month(date$)-1,year(date$))
End

Subprog D_ENDDAT2(VALEUR)
Variable Date    VALEUR
VALEUR = eomonth([M]STRDAT)
End

Subprog D_DATPCE(VALEUR)
Variable Date     VALEUR
VALEUR = [M]ENDDAT2
End

Subprog AV_INI(VALEUR)
Variable Char    VALEUR()
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 [M]ALLCPY = 1 : Affzo ALLCPY
Endif
If [M]ALLCPY=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY : Grizo ALLFCY
Else
 Actzo CPY,ALLFCY
Endif
If [M]VAT=1
 Grizo STRDAT, ENDDAT, DETVCR
Else
 Actzo STRDAT, ENDDAT, DETVCR
Endif
If dim([M]VATPAY)>0
 If [M]VATPAY = 1
  Grizo STRDAT2, ENDDAT2, DATPCE, DETAIL, ECRAUX
 Else
  Actzo STRDAT2, ENDDAT2, DATPCE, DETAIL, ECRAUX
 Endif
Endif
If [M]TRCFLG = 2
 Actzo DETDCL
Else
 Effzo DETDCL
 Grizo DETDCL
Endif
End

Subprog C_TRCFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
 DETDCL = 1
 Grizo DETDCL
Else
 Actzo DETDCL
Endif
Affzo DETDCL
End

#############################################################################
## This sub-program controls the parameters capture.
## The batch process needs these parameters
#############################################################################

Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK

If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif

Case PARAM
 When "VATRPTBAT"
  If VALEUR="" : End : Endif
  Read [AIM]AIM0=VALEUR
  If [F:AIM]PRT<>2 & [F:AIM]PRT<>4
   # La destination renseignée dans le paramètre '$1' doit être de type 'Fichier' ou 'Imprimante'.
   GMESSAGE = mess(327,117,1)
   Call DYNAMIC(GMESSAGE,"$1", PARAM) From TEXTE
   OK = 0 : End
  Endif
  If [AIM]PRTSRV=""
   # La destination renseignée dans le paramètre '$1' doit être associée à un serveur d'impression.
   GMESSAGE = mess(254,117,1)
   Call DYNAMIC(GMESSAGE,"$1", PARAM) From TEXTE
   OK = 0 : End
  Endif
 When "VATRPTDIR"
  If VALEUR<>"" & (right$(VALEUR, len(VALEUR))<>"/" and right$(VALEUR, len(VALEUR))<>"\")
   # La valeur doit finir par le caractère / ou |\
   GMESSAGE = mess(256,117,1)
   OK = 0
   End
  Endif
Endcase
End

