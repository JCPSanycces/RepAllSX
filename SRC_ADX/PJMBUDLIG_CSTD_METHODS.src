#######################################################################################
# Classe PJMBUDLIG
#######################################################################################
# METHODS                                                                             #
#######################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  # Issue X3-51863 - 2017-08-07 by FGR
  SLEVEL = func AFNC.MES3(mess(950,2260,1), this.OPPNUM, this.PBUCOD, num$(this.PLBSEQ))
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

#######################################################################################
$COPY
#Variable Instance TARGET Using C_PJMBUDLIG : #
#Variable Instance TECCLA Using C_PJMACOPY : #
#Value Integer TECIDX
#Local Integer ARET_VALUE

Local Instance TECPJMCOPY Using C_TECPJMCOPY     # Issue X3-29531 - 2017-04-21 by FGR

  # Issue X3-29531 - 2017-04-21 by FGR : BEGIN
  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  TECPJMCOPY = NewInstance C_TECPJMCOPY AllocGroup null
  [L]ARET_VALUE = fmet this.COPY_LOAD_PROPERTIES(TECPJMCOPY, TECCLA, TECIDX)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # --------------------
  # 1°) copy properties and translated texts
  [L]ARET_VALUE = func TECPJMCOPY_CSTD.DO_COPY_CHAIN(TECPJMCOPY, TECCLA, this, TARGET)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # --------------------
$COPY_END
  If TECPJMCOPY <> null Then
    FreeGroup TECPJMCOPY
  Endif
Return

#$COPY
##Variable Instance TARGET Using C_PJMBUDLIG : #
##Variable Instance TECCLA Using C_PJMACOPY : #
##Value Integer TECIDX
##Local Integer ARET_VALUE
#
#Local Integer IRET
#
#  Local File PJMBUDLIG[PJLB]
#  # -----------------------------------------------------------------
#  SetInstance [F:PJLB] With this
#  #Set the [F] instance to the CRM project if CRMFLG is flagged       # Issue X3-15584/121450 - 2017-04-10 by EUHAV : BEGIN
#  If TECCLA.CRMFLG = [V]CST_AYES and TECCLA.DESTAFF <> AVOID.ACHAR
#    [F:PJLB]OPPNUM = TECCLA.DESTAFF
#  Endif                                                               # Issue X3-15584/121450 - 2017-04-10 by EUHAV : END
#  SetInstanceNoSys TARGET With [F:PJLB] # Issue X3-6717/119894 - 2016-11-22 by EUHAV
#  # -----------------------------------------------------------------
#  # Translated Texts management
#  TARGET.PLBDESAXX = this.PLBDESAXX
#  # ---------------------------
#  # Header clob management (will have to be there) - depending of a setup value
#  #Copy all descriptions
#  If TECCLA.BUDLDES = [V]CST_AYES Then
#    TARGET.PLBDESTEX = this.PLBDESTEX
#  Endif
#  #Copy all comments (CLOB)
#  If TECCLA.BUDLCOM = [V]CST_AYES Then
#    TARGET.PLBCOMTEX = this.PLBCOMTEX
#  Endif
#  # ---------------------------
#  # Special Management for some properties which should not been copied from the source
#  Raz TARGET.PLBDATBUD
#  Raz TARGET.PLBPRIREM
#  Raz TARGET.PLBDATREM
#  Raz TARGET.PLBQTYREM
#  Raz TARGET.PLBAMTREM
#  TARGET.PLBFLGREM = [V]CST_ANO
#  IRET = fmet TARGET.ORI.INIT()
#  # -----------------------------------------------------------------
#  Raz TARGET.OPPNUM
#  TARGET.OPPNUM = TECCLA.DESTAFF        #Eugene.H added for testing purposes.
#  # -----------------------------------------------------------------
#Return

#######################################################################################
$COPY_LOAD_PROPERTIES
#Variable Instance TECPJMCOPY Using C_TECPJMCOPY : #
#Variable Instance TECCLA Using C_PJMACOPY : #
#Value Integer TECIDX
#Local Integer ARET_VALUE

  # Issue X3-29531 - 2017-04-21 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD_AXX("PLBDESAXX", AVOID.ACHAR, "PJMBUDLIG", "PLBDESAXX", "KEYCONCAT", "PLBSEQ"))
  #  #Copy all descriptions
  If TECCLA.BUDLDES = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PLBDESTEX", AVOID.ACHAR))
  Endif
  #Copy all comments (CLOB)
  If TECCLA.BUDLCOM = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PLBCOMTEX", AVOID.ACHAR))
  Endif
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PCCCOD", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PLBU", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PLBQTY", AVOID.ACHAR))
  #
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD_CUR("PLBPRI", AVOID.ACHAR, this.CUR, TECCLA.CHGTYP, TECCLA.DATECUR, "CUR"))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD_CUR("PLBAMT", AVOID.ACHAR, this.CUR, TECCLA.CHGTYP, TECCLA.DATECUR, "CUR"))
Return

