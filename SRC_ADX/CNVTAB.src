#<AdxTL>@(#)1.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
Call CNVTAB    
End

##############################################################
Subprog CNVTAB
Local Integer OK, ERR

Raz ERR
Onerrgo ERR From CNVEURO
Gosub OUVRE
If ERR : End : Endif

Read [TCY]TCY0 = GPAYS
If fstat
 Read [TCY]TCY0 = ""
Endif
If fstat=0
 GLOCALDEV = [F:TCY]CUR
Else
 GLOCALDEV = "FRF"
Endif

Local Mask CNVTAB [DIA]

Raz [M]

###DBA le 01/08/04 : Passage V140
###OK = 2 : Call DIALOD(OK,mess(66,115,1)) From GESECRAN
Local Char WIN (GLONFEN)
WIN="DCNVTAB"
OK=2 : Call DIALWIN(OK,mess(66,115,1),WIN) From GESECRAN
###

# Conversion des tableaux de bord
If OK<>2 : Goto FIN : Endif

Local Mask CNVTAB [DIAX]
[M:DIAX] = [M:DIA]
Close Local Mask [DIA]

If [M]TRACE=2
 Call OUVRE_TRACE(mess(66,115,1)) From LECFIC
Endif
Call TEMPON("V") From GESECRAN

If [M]TOUTAB=2
 For [TXA2]
  Call CNVTAB2([F:TXA2]GRUCPY,[F:TXA2]YEAPAR,[F:TXA2]TXSARRCOD,[M]RECUP,[M]DATPAS,[M]DEVCUR,[M]DEVDES)
  If GOK<1 : Break : Endif
 Next
Else
 For I=0 To [M]NBLIG-1
  If [M]CNV(I)=2
   Call CNVTAB2([M]GRUCPY(I),[M]YEAPAR(I),[M]TXSARRCOD(I),[M]RECUP,[M]DATPAS,[M]DEVCUR,[M]DEVDES)
   If GOK<1 : Break : Endif
  Endif
 Next 
Endif

Call TEMPOFF From GESECRAN 
If [M]TRACE=2
 Call FERME_TRACE From LECFIC 
 Call LEC_TRACE From LECFIC
Endif

$FIN
End

##############################################################
$OUVRE
If clalev([F:TCY])=0  : Local File TABCOUNTRY [TCY]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:TCH])=0  : Local File TABCHANGE  [TCH]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
#If clalev([F:TXV])=0  : Local File GACTXSVAL  [TXV]  : Endif
#If clalev([F:TVP])=0  : Local File GACTXSVALP [TVP]  : Endif
#If clalev([F:TVP2])=0 : Local File GACTXSVALP [TVP2] : Endif
#If clalev([F:TXF])=0  : Local File GACTXSFIE  [TXF]  : Endif
#If clalev([F:TXA])=0  : Local File GACTXSARR  [TXA]  : Endif
#If clalev([F:TAD])=0  : Local File GACTXSARRD [TAD]  : Endif
#If clalev([F:CYD])=0  : Local File GRUCPYD    [CYD]  : Endif
#If clalev([F:TXA2])=0 : Local File GACTXSARR  [TXA2] : Endif
Return

###############################################################
Subprog CNVTAB2(GROSOC,ANN,CODE,RECUP,DATPAS,DEVCUR,DEVDES)
Value Char    GROSOC
Value Integer ANN
Value Char    CODE
Value Integer RECUP
Value Date    DATPAS
Value Char    DEVCUR
Value Char    DEVDES

Gosub OUVRE

Local Integer  OK, ANOM
Local Integer  TYPCUR, SPSTAT
Local Char     VALPAR(20), SYMBOLE(80)

Call PARAM("","CHGTYP",VALPAR) From ADOVAL
TYPCUR = val(VALPAR)
If TYPCUR=0 : TYPCUR = 1 : Endif

Read [TXA2]TXA0 = GROSOC ; ANN ; CODE
If !find([L]DEVCUR,[F:TXA2]CURAFF(0..dim([F:TXA2]CURAFF)-1))
 End
Endif

Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1 : Return : Endif

If [L]RECUP=2
 # Recalcul tableaux de bord
 For [TVP2]TVP0 Where GRUCPY=GROSOC & YEAPAR=ANN & TXSARRCOD=CODE
  If GTRACE<>""
   Call ECR_TRACE(mess(74,111,1)-GROSOC-num$(ANN)-CODE-num$([F:TVP2]FIYNUM),0) From GESECRAN
  Endif
  Call CPTLIA([F:TVP2]GRUCPY,[F:TVP2]YEAPAR,[F:TVP2]TXSARRCOD
&            ,[F:TVP2]CPY,[F:TVP2]FIYNUM,1,"122112223",ANOM) From CPTLIA
 Next
Endif

If GTRACE<>""
 Call ECR_TRACE(GROSOC-num$(ANN)-CODE-[L]DEVCUR-"->"-[L]DEVDES,0) From GESECRAN
Endif
End

$TR1
GOK = 1
Trbegin [TXA], [TXV], [TVP]

 SYMBOLE = format$("K:3X","BUP")+num$(ANN)+GROSOC+CODE
 Lock =SYMBOLE With lockwait=0
 If fstat
  Call ECR_TRACE(GROSOC-num$(ANN)-CODE-mess(39,107,1),1) From GESECRAN
  GOK=0 : Goto AB_TR1
 Endif
 Readlock [TXA]TXA0 = GROSOC ; ANN ; CODE
 If fstat=1
  GOK=-1 : GLOCK="$GACTXSARR"-GROSOC-num$(ANN)-CODE : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("TXA",GROSOC-num$(ANN)-CODE) From GLOCK : Goto AB_TR1
 Endif
 For I=0 To dim([F:TXA]CURAFF)-1
  If [F:TXA]CURAFF(I) = [L]DEVCUR
   [F:TXA]CURAFF(I) = [L]DEVDES
  Endif
 Next I
 Rewrite [TXA]
 If fstat
  GOK=0 : Call FSTA("TXA") From GLOCK : Goto AB_TR1
 Endif

 If [L]RECUP<>2
  For [TVP]TVP0 Where GRUCPY=GROSOC & YEAPAR=ANN & TXSARRCOD=CODE
   For I=0 To dim([F:TVP]CURAFF)-1
    If [F:TVP]CURAFF(I)=[L]DEVCUR
     For [TAD]TAD0 Where GRUCPY=GROSOC & YEAPAR=ANN & TXSARRCOD=CODE & COLNUM=I+1
      For [TXV]TXV0 Where GRUCPY=GROSOC & YEAPAR=ANN & TXSARRCOD=CODE & TXSCOD=[F:TAD]TXSCOD
&                       & FIYNUM=[F:TVP]FIYNUM
       Call CONVERT([L]DEVCUR,[L]DEVDES,[L]DEVDES,TYPCUR,DATPAS,[F:TXV]AMTDEB,[TXV]AMTDEB,SPSTAT) From TRTDEV
       Call CONVERT([L]DEVCUR,[L]DEVDES,[L]DEVDES,TYPCUR,DATPAS,[F:TXV]AMTCDT,[TXV]AMTCDT,SPSTAT) From TRTDEV
       Call CONVERT([L]DEVCUR,[L]DEVDES,[L]DEVDES,TYPCUR,DATPAS,[F:TXV]VALCOD,[TXV]VALCOD,SPSTAT) From TRTDEV
       Rewrite [TXV]
       If fstat=1
        GOK=-1 : GLOCK = "$GACTXSVAL" : Break 4
       Elsif fstat
        GOK=0 : Call FSTA("TXV") From GLOCK : Break 4
       Endif
      Next
     Next  
    Endif
   Next I
  Next
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
 Endif
 
 For [TVP]TVP0 Where GRUCPY=GROSOC & YEAPAR=ANN & TXSARRCOD=CODE
  For I=0 To dim([F:TVP]CURAFF)-1
   If [F:TVP]CURAFF(I) = [L]DEVCUR
    [F:TVP]CURAFF(I) = [L]DEVDES
   Endif
  Next I
  Rewrite [TVP]
  If fstat=1
   GOK=-1 : GLOCK = "$GACTXSVALP" : Break
  Elsif fstat
   GOK=0 : Call FSTA("TVP") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#########################################################################
Subprog C_DEVDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]DEVCUR
 mkstat = 2 : End
Endif
End

$CHARGE
Effzo 10
If [M]TOUTAB=2 : mkstat = 1 : End : Endif
Local Integer J
Raz J
For [TXA2]
 If find([M]DEVCUR,[F:TXA2]CURAFF(0..dim([F:TXA2]CURAFF)-1))
  [M]GRUCPY(J)    = [F:TXA2]GRUCPY
  [M]YEAPAR(J)    = [F:TXA2]YEAPAR
  [M]TXSARRCOD(J) = [F:TXA2]TXSARRCOD
  If J>=dim([M]GRUCPY)-1
   Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
   Break
  Endif
  J +=1
 Endif
Next
[M]NBLIG = J
Affzo 10
Return

Subprog AS_NBLIG
GBOUT1 = mess(2,1,1)
GBOUT2 = mess(1,1,1)
If adxgtb : Gosub CHARGE : Endif
End

Subprog B1_NBLIG
Local Integer I
For I=0 To [M]NBLIG-1
 [M]CNV(I) = 2 : # Oui
Next I
Affzo
End

Subprog B2_NBLIG
Local Integer I
For I=0 To [M]NBLIG-1
 [M]CNV(I) = 1 : # Non
Next I
Affzo
End

Subprog AM_TOUTAB(VALEUR)
Variable Integer  VALEUR
End

