#<AdxTL>@(#)1.0.0.0 $Revision$
# Generation of a prototype associated to a report
# This prototype contains the description of the parameters
Local Char CODREP(20),DOSSIER(20)
Local Integer OKTRT

CODREP="ZZMB"
Call GENETRT(DOSSIER,CODREP,OKTRT)
If OKTRT=0 : Errbox "error" : End : Endif


Local Instance PSYR Using C_ASYR
Local Clbfile   WCLOB(7)
Local Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT


  PSYR= NewInstance With C_ASYR
  PSYR.PREFIX="http://ici_url_test"
  ACTX = NewInstance With =[V]CST_C_NAME_CLASS_CONTEXT
  # nouveau moyen d'init context
  Local Integer ASTATUS
  [L]ASTATUS = fmet ACTX.ACTX_INIT_LAN(nomap,"FRA",adxusr)
#  ACTX.USER = GUSER
#  ACTX.LAN = "FRA"
#  ACTX.LANDEF = "FRA"
  NOMTRT="WMRPT"+CODREP
  Call PROTO_JSON(ACTX,PSYR,WCLOB) From =NOMTRT
  Openo "#@D:\temp\proto.json",0
  Wrseq WCLOB
  Openo
End

Subprog GENETRT(DOSSIER,CODREP,OKTRT)
Value Char DOSSIER()
Value Char CODREP()
Variable Integer OKTRT

Local Integer NUM_PAR
Local Char REFCLA(20)

# Default folder by default
  If DOSSIER="" : DOSSIER=nomap : Endif

# Opens AREPORT and AREPORTD tables and some others
  If !clalev([ARP]) : Local File AREPORT : Endif
  If !clalev([ARD]) : Local File AREPORTD : Endif
  If !clalev([ATY]) : Local File ATYPE : Endif
  If !clalev([AOB]) : Local File AOBJET : Endif
  If !clalev([ATI]) : Local File ATABIND : Endif
  If !clalev([ATB]) : Local File ATABLE : Endif

  Read [ARP]ARP0=CODREP : If fstat : OKTRT=0 : End : Endif

# Generation variable declaration
  Gosub DECL_GEN From AJSONLIB

# Let's start the generation with the header
  NOMTRT = "WMRPT"+CODREP
  COMMENT="Reports parameters for report " -CODREP-format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss",date$)
  Gosub DEB_GEN From AJSONLIB

# PROTO JSON subprog generation
  Gosub JPRO_HEAD_GEN From AJSONLIB

# Miscellaneous declaration if needed
  Wrseq Using [SSS_]
  Wrseq "# Miscellaneous declarations" Using [SSS_]

  Wrseq "Local Char L(10) : L=ACTX.LAN" Using [SSS_]
  Wrseq "Local Char DOL_KEY(10) : DOL_KEY="+'"'+"'{$key}'"+'"' Using [SSS_]
  Wrseq "Local Char RES_RPT(20) : RES_RPT="+'"'+[ARP]RPTCOD+'"' Using [SSS_]
  Wrseq "Local Char RES_RPT1(20) : RES_RPT1="+'"'+"'"+[ARP]RPTCOD+"'"+'"' Using [SSS_]
  Wrseq "Local Integer IML" Using [SSS_]
  Wrseq Using [SSS_]

# Init
  NBP=-1 : Gosub PRO_GEN From AJSONLIB

# Base URL and computed formula because simple quotes are nested in double quotes
  PRF="{"
  NBP+=1 : PRO(NBP)="$baseUrl" : TYP(NBP)=4 : VLE(NBP)="PSYR.PREFIX"
  NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4 : VLE(NBP)='"{$baseUrl}/reports("+tolower(RES_RPT1)+")?representation=REPORT_"+RES_RPT+".$edit&role={$role}"'
  POF=","
  Gosub PRO_GEN From AJSONLIB

# Title and type
  NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)='func A(L,'+num$([ARP]RPTDES)+')'
  POF=","
  Gosub PRO_GEN From AJSONLIB

  NBP+=1 : PRO(NBP)="$type" : TYP(NBP)=4
  VLE(NBP)='"application/json; vnd.sage=syracuse.presentation=x3.erp.superv/report("+tolower(RES_RPT)+")"'
  POF=","
  Gosub PRO_GEN From AJSONLIB

  NBP+=1 : PRO(NBP)="$methods" : TYP(NBP)=3 : VLE(NBP)="GET"
  NBP+=1 : PRO(NBP)="codeReport" : VLE(NBP)=[ARP]RPTCOD
  NBP+=1 : PRO(NBP)="$" : TYP(NBP)=5
  Gosub PRO_GEN From AJSONLIB

# Loop on the reports parameters
  NUM_PAR=0
  For [ARD]ARD0 Where RPTCOD=[ARP]RPTCOD
    # Manage ',' if not all parameters have been listed
    NUM_PAR+=1
    PRF=string$(NUM_PAR>1,",")

    # Field, title ans read-only values
    NBP+=1 : PRO(NBP)=[ARD]PARCOD : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)="func A(L,"+num$([ARD]PARNAM)+")"
    If [ARD]PARSAI=1
      NBP+=1 : PRO(NBP)="$isReadOnly" : TYP(NBP)=1 : VLE(NBP)="1"
    Endif

    # If a range or a collection is expected, add two nested levels
    If [ARD]PARSTREND>=2
      Funprog TYPZON(TYP,MENL)
      NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=string$([ARD]PARSTREND=2,"application/x-range")+string$([ARD]PARSTREND=3,"application/x-collection")
      NBP+=1 : PRO(NBP)="$item" : TYP(NBP)=5
      Gosub PRO_GEN From AJSONLIB
    Endif
    Read [ATY]CODTYP=[ARD]PARTYP

    If fstat=0

      # Check if the field is a reference : Check with the new Syracuse features (CODCLA), but check also with object
      # For an object, check if the main key is a single component key
      REFCLA=""
      If dim([ATY]CODCLA)>0 and [ATY]CODCLA<>""
        REFCLA=[ATY]CODCLA
      Elsif [ATY]OBJLIEN<>""
        Read [AOB]ABREV=[ATY]OBJLIEN
        Read [ATI]NUMLIG(2)=[AOB]NOMFIC;1
        If max(instr(1,[ATI]DESCRIPT,"+"),instr(1,[ATI]DESCRIPT,"-"))=0
          REFCLA=[AOB]NOMFIC
        Endif
      Endif

      # If reference
      If REFCLA<>""
        NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-reference"
        NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4
        VLE(NBP)='"{$baseUrl}/'+REFCLA+'("+DOL_KEY+")?representation='+REFCLA+'.$thumb&role={$role}"'
        POF=","
        Gosub PRO_GEN From AJSONLIB

        NBP+=1 : PRO(NBP)="$links" : TYP(NBP)=5
        NBP+=1 : PRO(NBP)="$details" : TYP(NBP)=5
        NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/json;vnd.sage=syracuse"
        POF=","
        Gosub PRO_GEN From AJSONLIB

        NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4
        VLE(NBP)='"{$baseUrl}/'+REFCLA+'("+DOL_KEY+")?representation='+REFCLA+'.$details&role={$role}"'
        POF="}}}" : # Closes "$links" : { "$details" : { and field
        Gosub PRO_GEN From AJSONLIB
      Else

        NBP+=1 : PRO(NBP)="$type" : VLE(NBP)=func AJSONLIB.ATYPEZON([ARD]PARTYP,[ARD]PARNOLIB)

        # Check if a constraint section exists
        If [ATY]TYPTYP=7 or ([ATY]TYPTYP=1 and [ARD]PARNOLIB>1)
          NBP+=1 : PRO(NBP)="$constraints" : TYP(NBP)=5
          If [ATY]TYPTYP=7
            NBP+=1 : PRO(NBP)="$maxLength" : TYP(NBP)=2 : VLE(NBP)=num$([ARD]PARLNG+([ARD]PARLNG=0)*[ATY]LNGTYP)
            POF="}"
          Else
            NUMLOC=[ARD]PARNOLIB
            Gosub MEN_GEN From AJSONLIB
            POF="}"
          Endif
        Elsif [ATY]TYPTYP=4
          NBP+=1 : PRO(NBP)="$format" : VLE(NBP)=string$(10*([ARD]PARLNG-int([ARD]PARLNG)),"0") : VLE(NBP)="#"+string$(VLE(NBP)<>"",".")+VLE(NBP)
        Endif

        # Close the section
        POF+="}"
        Gosub PRO_GEN From AJSONLIB
      Endif
    Endif

    # Close the additional x-range or x-collection section
    If [ARD]PARSTREND>=2
      POF="}"
      Gosub PRO_GEN From AJSONLIB
    Endif

  Next I

  # Close the prototype
  POF="}}"
  Gosub PRO_GEN From AJSONLIB
  Wrseq Using [SSS_]
  Wrseq "End" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# " Using [SSS_]
  Wrseq "# Void call" Using [SSS_]
  Wrseq "$GET" Using [SSS_]
  Wrseq "Return" Using [SSS_]

  Openo Using [SSS_]
  Call VALID("TRT",NOMTRT,DOSSIER,OKTRT) From VALMSKSUB
End
