#<AdxTL>@(#)8.0.0.0 $Revision$
###########################################################################
# Descente de nomenclature récursive  GNIV doit être déclarée Globale avant
###########################################################################
Subprog DESCLIEN(LITM,ALT,ALTTYP,NIVMAX,CURNIV)  : # Utilisé en Ctrl de niveau max
Value Char LITM
Value Integer ALT
Value Integer ALTTYP
Variable Integer NIVMAX
Variable Integer CURNIV

Local Integer WLLCTYP : WLLCTYP = func LLCLIB.LLCTYP(ALTTYP)
If !find(WLLCTYP,1,2) : End : Endif     # CCC : if the returned value is not 1 or 2, reading of [F:BOD] will be incorrect => it's better to go out

Local Integer MAXNIVCHILD : MAXNIVCHILD = 0
Local Integer NIVCHILD : NIVCHILD = 0
# 03.09 bug 53989 On parcoure l'arborescence dans sa totalité ce que est trop long
# Désormais on enregistre temporairement dans la table CTRLNIVW le niveau max
# d'une nomenclature afin de directement retrouver l'information au prochain passage

# lecture de la table de travail CTRLNIVW
Read [CNW]CNW0 = LITM;ALT;ALTTYP
If fstat = 0
  CURNIV= [F:CNW]NIV
#  GNIV += [F:CNW]NIV -1
#  If (GNIV + [F:CNW]NIV -1) > NIVMAX : NIVMAX = GNIV : Endif
  NIVMAX = max(NIVMAX,GNIV + [F:CNW]NIV -1)
Else

# FQ 67302 #If GUSER="ADMIN"
  Call ECR_DEBUG("LLCLIB/DESCLIEN:"-LITM-num$(ALT)-num$(ALTTYP)-"MaxLev="-num$(NIVMAX)-"CurLev="-num$(CURNIV))

  # 06.06 demande 21581
  # UN NIVEAU DE LOCALITÉ à CHAQUE APPEL
  # FQ 64407 GA 04/2010 traiter aussi les sous-produits CPNTYP=4: suppression de "& !find(CPNTYP,4,5)"
  Case WLLCTYP
      When 1: Local File BOMD [BOD] Where ITMREF = LITM & BOMALT = ALT & BOMALTTYP = ALTTYP
&                                       & find(CPNTYP,4,5)=0    # Issue 117054 - 2016-06-13 by GH : Change <> by =
#&                                       & find(CPNTYP,4,5)<>0    # Issue 104223 - 2015-03-26 by CCC : Don't take into account by-product

      When 2: Local File BOMD [BOD] Where ITMREF = LITM & BOMALT = ALT & find(BOMALTTYP,2,3)<>0
&                                       & find(CPNTYP,4,5)=0    # Issue 117054 - 2016-06-13 by GH : Change <> by =
#&                                       & find(CPNTYP,4,5)<>0    # Issue 104223 - 2015-03-26 by CCC : Don't take into account by-product
  Endcase

  Read [BOD] First
  # Si l'on trouve un composant, on incrémente le niveau
  If !fstat
    GNIV += 1
  Else
    Close Local File [BOD]
    End
  Endif
  If GNIV > NIVMAX : NIVMAX = GNIV : Endif
  # 06.06 demande 21581
  While !fstat
      Read [F:ITB]ITB0= [F:BOD]CPNITMREF;[F:BOD]BOMALT;WLLCTYP
 #     If !fstat & [F:ITB]BOMEXIFLG = 2
      If !fstat
          Call DESCLIEN ([F:BOD]CPNITMREF,ALT,ALTTYP,NIVMAX,NIVCHILD)
         If NIVCHILD>MAXNIVCHILD
            MAXNIVCHILD = NIVCHILD
         Endif
      Endif
      Read [BOD] Next
  Wend
  MAXNIVCHILD += 1
  Raz [F:CNW]
  [F:CNW]ITMREF = LITM
  [F:CNW]BOMALT = ALT
  [F:CNW]BOMALTTYP = ALTTYP
  [F:CNW]NIV = MAXNIVCHILD
  CURNIV = MAXNIVCHILD
  Write [CNW]
  # retour du sous-pro = remontée d'un niveau
  GNIV -= 1
  Close Local File [BOD] # pour libérer la mémoire (bug 12546) 25/01/02
Endif
End

###########################################################################
# Remontée de nomenclature récursive (à partir du composant)
# pour détecter une boucle lors de la saisie.
###########################################################################
Subprog MONTLIEN(LITM,CPN,ALT,ALTTYP,OK)
Value Char LITM : # le composant qui a été saisi
Value Char CPN
Value Integer ALT
Value Integer ALTTYP
Variable Integer OK

Local Integer WLLCTYP : WLLCTYP = func LLCLIB.LLCTYP(ALTTYP)
If !find(WLLCTYP,1,2) : End : Endif     # CCC : if the returned value is not 1 or 2, reading of [F:BOD] will be incorrect => it's better to go out

# FQ 67302 #If GUSER="ADMIN"
  Call ECR_DEBUG("LLCLIB/MONTLIEN:"-LITM-num$(ALT)-num$(ALTTYP)-"Cpn="-CPN)

# 06.06 demande 21581
# UN NIVEAU DE LOCALITÉ à CHAQUE APPEL
# FQ 64407 GA 04/2010 traiter aussi les sous-produits CPNTYP=4: suppression de "& !find(CPNTYP,4,5)"
Case WLLCTYP
    When 1: Local File BOMD [BOD] Where CPNITMREF = CPN & BOMALT = ALT  & BOMALTTYP = ALTTYP
&                                       & find(CPNTYP,4,5)=0    # Issue 117054 - 2016-06-13 by GH : Change <> by =
#&                                       & find(CPNTYP,4,5)<>0   # Issue 104223 - 2015-03-26 by CCC : Don't take into account by-product

    When 2: Local File BOMD [BOD] Where CPNITMREF = CPN & BOMALT = ALT  & find(BOMALTTYP,2,3)<>0
&                                       & find(CPNTYP,4,5)=0    # Issue 117054 - 2016-06-13 by GH : Change <> by =
#&                                       & find(CPNTYP,4,5)<>0   # Issue 104223 - 2015-03-26 by CCC : Don't take into account by-product
Endcase
# Controler si composant=composé en création lien ou Fusion
If LITM = CPN : Goto ERREUR : Endif

Read [BOD]BOD3 First
# s'arreter si l'on trouve l'article en cours
If !fstat & [F:BOD]ITMREF = LITM
   Goto ERREUR
Endif
# 06.06 demande 21581
While !fstat
    If [F:BOD]ITMREF = LITM : OK = 0 : Break : Endif
    Read [F:ITB]ITB0= [F:BOD]ITMREF;[F:BOD]BOMALT;WLLCTYP
    If !fstat & [F:ITB]WUSEXIFLG = 2
       Call MONTLIEN (LITM,[F:BOD]ITMREF,ALT,ALTTYP,OK)
       If OK = 0 : Break : Endif
    Endif
    Read [BOD]BOD3 Next
Wend
If OK = 1 : Goto FIN : Endif

$ERREUR
OK = 0

$FIN
Close Local File [BOD] # pour libérer la mémoire (bug 12546) 25/01/02
End

#######################################################################
# RECALCUL du LLC des sous niveaux (récursif) (DANS UNE TRANSACTION)
# utilisé dans SUBBODA (gestion), SUBBOC (copie) et SYNCLLC (resynchro)
#######################################################################
Subprog CALCLLC(LITM,ALT,ALTTYP,SENS)
Value Char LITM           : # composant considéré comme article maître
Value Integer ALT
Value Integer ALTTYP
Value Char SENS        : # "+" en création de lien ; "-" en annulation

Local Integer TROUVE   : # pour eviter de décrementer GNIV à tort
Local Integer MAX_LLC  : # le niveau le + bas ailleurs (après annul)
Local Integer WFSTAT   : WFSTAT = fstat
Local Integer WLLCTYP  : WLLCTYP = func LLCLIB.LLCTYP(ALTTYP)
Local Char    FLTBOM_0(50)
Local Char    FLTBOM(50)
Local Char    LBOHITM(GLONITM)
Local Integer OLDLCC
Local Integer I

Case WLLCTYP
    When 1 : FLTBOM_0 =  " AND B.BOMALTTYP_0=1"
             FLTBOM   =  "BOMALTTYP=1"
    When 2 : FLTBOM_0 =  " AND B.BOMALTTYP_0>="+num$(WLLCTYP)
             FLTBOM   =  "BOMALTTYP>="+num$(WLLCTYP)
Endcase

# FQ 69008 #If GUSER="ADMIN"
  Call ECR_DEBUG("LLCLIB/CALCLLC:"-LITM-num$(ALT)-num$(ALTTYP)-"Sens="-SENS)

# UN NIVEAU DE LOCALITÉ (classe BOD) à CHAQUE APPEL
# GNIV + GBOHLLC correspond au niv que l'on mettra si ITB doit changer

# Débranchement erreur à cause des risques en copie multi-niveaux
Onerrgo ERREUR From CONTROLE
If SENS="-" & clalev([F:ITB2])=0 : Local File ITMBOM [ITB2] : Endif # Issue 118021 GH 07/09/2016 - optimization
If clalev([F:BOD2])=0 : Local File BOMD   [BOD2] : Endif
If GERREUR : End : Endif
Onerrgo
#Call ECR_TRACE(num$(GNIV)-LITM,0) From GESECRAN
Local Integer NBCPN
Local Char    LTABCPN(GLONITM)(100)
Local Integer LTABCPNBYP(100)       # Issue 104223 - 2015-04-02 by CCC : is the component a pure by-product in the bom ?
Local Char    REQ(250)(3)

# 1- Mémorisation des composants de l'article (nécessaire pour l'appel récursif)
Raz NBCPN, REQ
# Issue 104223 - 2015-04-13 by CCC : If MIN=MAX=4 => component is only a by-product in this BOM
REQ(0) ="Select /*+ Index(B BOMD_BOD4)*/ B.CPNITMREF_0, MIN(B.CPNTYP_0), MAX(B.CPNTYP_0) From BOMD B"
REQ(1) =" Where B.ITMREF_0 = '"+LITM+"'"
REQ(1)+=  " and B.BOMALT_0 = "+num$(ALT)
# FQ 64407 GA 04/2010 traiter aussi les sous-produits CPNTYP=4
#REQ(1)+=  " and B.CPNTYP_0<>4 and B.CPNTYP_0<>5"
REQ(1)+=    FLTBOM_0
REQ(2) =" Group By B.CPNITMREF_0"
For (Char CPNITMREF, Integer MINCPNTYP, Integer MAXCPNTYP) From num$(GTYPDBA*2+1) Sql REQ As [XXX]
  If [F:XXX]CPNITMREF<>"" : # Issue 118298 GH 05/09/2016 - don't generate ITMBOM records with no ITMREF
    If NBCPN>=dim(LTABCPN)
        Local Char LTABTMP(GLONITM)(dim(LTABCPN))
        For I=0 To dim(LTABCPN)-1
            LTABTMP(I)=LTABCPN(I)
        Next
        Kill LTABCPN
        Local Char LTABCPN(GLONITM)(dim(LTABTMP)+100)
        For I=0 To dim(LTABTMP)-1
            LTABCPN(I)=LTABTMP(I)
        Next
        Kill LTABTMP
        Local Integer LTABTMP(dim(LTABCPNBYP))
        For I=0 To dim(LTABCPNBYP)-1
            LTABTMP(I)=LTABCPNBYP(I)
        Next
        Kill LTABCPNBYP
        # Local Char LTABCPNBYP(dim(LTABTMP)+100)  : # Issue 109423 - 2015-07-09 by GH
        Local Integer LTABCPNBYP(dim(LTABTMP)+100)
        For I=0 To dim(LTABTMP)-1
            LTABCPNBYP(I)=LTABTMP(I)
        Next
        Kill LTABTMP
    Endif
    LTABCPN(NBCPN)=[F:XXX]CPNITMREF
    # Issue 104223 - 2015-04-02 by CCC : if this item is only a by-product, remember to avoid going down the BOM
    If [F:XXX]MINCPNTYP=4 & [F:XXX]MAXCPNTYP=4
        LTABCPNBYP(NBCPN)=1
    Endif
    NBCPN+=1
  Endif
Next

# 2- Traitement de chaque composant
For I=0 To NBCPN-1
    If !TROUVE  : GNIV += 1 : TROUVE = 1 : Endif
    Read [ITB]ITB0=LTABCPN(I);ALT;WLLCTYP
    If !fstat
      [F:ITB]WUSEXIFLG=2
      If SENS = "+" & [F:ITB]LLC < GNIV + GBOHLLC
         OLDLLC=[F:ITB]LLC
         # Issue 104223 - 2015-03-31 by CCC : set llc=0 if only by-product in this BOM
         If LTABCPNBYP(I)<>1
            [F:ITB]LLC    = GNIV + GBOHLLC
         Elsif  [F:ITB]LLC<0
            # Leave old value if >0. LLC can change because of by-product only on deletion
            # LLC can be negative during resynchronization
            [F:ITB]LLC = 0
         Endif
         If [F:ITB]LLC <> OLDLLC # Issue 118021 GH 07/09/2016 - reset BOHITM only if LLC is changed
            [F:ITB]BOHITM = LITM
         Endif
         Filter [BOD2] Where BOMALT=ALT
&                          & ITMREF=LTABCPN(I)
&                          & evalue(FLTBOM) # Issue 118021 GH 07/09/2016 - consider the right BOM type
         If rowcount([BOD2])>0
            [F:ITB]BOMEXIFLG = 2
         Else
            [F:ITB]BOMEXIFLG    = 0
         Endif
         Filter [BOD2]
         Rewrite [ITB]
         If fstat=1
          GOK=-1 : GLOCK="$ITMBOM"-LTABCPN(I)-num$(ALT)-num$(WLLCTYP)
         Elsif [F:ITB]BOMEXIFLG = 2
&         & LTABCPNBYP(I)<>1       # Issue 104223 - 2015-03-31 by CCC
            Call CALCLLC (LTABCPN(I),ALT,ALTTYP,SENS)
         Endif
      Elsif SENS = "+" & [F:ITB]LLC = GNIV+GBOHLLC & !find([ITB]BOHITM,LITM,"") # Issue 118021 GH 07/09/2016 - optimization : # [F:ITB]BOHITM<>LITM
         [F:ITB]BOHITM = "" : # il en existe au moins 2 (normalement inutile en sous-niv!)
         Rewrite [ITB]
         If fstat=1
          GOK=-1 : GLOCK="$ITMBOM"-LTABCPN(I)-num$(ALT)-num$(WLLCTYP)
         Endif
      Elsif SENS = "-"
&         & LTABCPNBYP(I)<>1       # Issue 104223 - 2015-03-31 by CCC
        # Issue 118021 GH 07/09/2016 - subprog RECHLLC is not used anymore because it doesn't return LBOHITM
        # Call RECHLLC(LTABCPN(I),ALT,ALTTYP,MAX_LLC,LITM)
        MAX_LLC = 0 : LBOHITM =""
        For [BOD2] Where CPNITMREF=LTABCPN(I) & BOMALT=ALT & evalue(FLTBOM) & CPNTYP<>5
             Read [ITB2]ITB0=[F:BOD2]ITMREF;[F:BOD2]BOMALT;WLLCTYP : # LLC du composé
             If !fstat & [F:BOD2]CPNTYP<>4 & 1+[F:ITB2]LLC > MAX_LLC
                 MAX_LLC = 1+[F:ITB2]LLC
                 LBOHITM = [F:ITB2]ITMREF
             Elsif !fstat & 1+[F:ITB2]LLC = MAX_LLC
                 LBOHITM = ""
             Endif
        Next
        #
        If MAX_LLC <= GNIV+GBOHLLC : # test (le cpn est ailleurs + haut)
         [F:ITB]LLC = GNIV + GBOHLLC
         # If MAX_LLC= GNIV+GBOHLLC : [F:ITB]BOHITM = ""
         # Else                     : [F:ITB]BOHITM = LITM
         # Endif
         [F:ITB]BOHITM = LBOHITM
         Rewrite [ITB]
         If fstat=1
            GOK=-1 : GLOCK="$ITMBOM"-LTABCPN(I)-num$(ALT)-num$(WLLCTYP)
         Elsif [F:ITB]BOMEXIFLG = 2
            Call CALCLLC (LTABCPN(I),ALT,ALTTYP,SENS)
         Endif
        Endif
      Endif
    Elsif fstat = 5 & SENS = "+"
        Raz [F:ITB]
        [F:ITB]ITMREF    = LTABCPN(I)
        [F:ITB]BOMALT    = ALT
        [F:ITB]LLCTYP    = WLLCTYP
        [F:ITB]WUSEXIFLG = 2
        [F:ITB]BOHITM    = LITM
        If LTABCPNBYP(I)<>1 : # Issue 118021 GH 07/09/2016 - set LLC=0 if the component is a by-product
           [F:ITB]LLC= GBOHLLC + GNIV
        Endif
        [F:ITB]CREDAT    = date$
        [F:ITB]CREUSR    = GUSER
        [F:ITB]EXPNUM    = [C]EXPORT
        Filter [BOD2] Where BOMALT=[F:TBO]BOMALT
&                         & ITMREF=LTABCPN(I)
&                         & evalue(FLTBOM) # Issue 118021 GH 07/09/2016 - consider the right BOM type
        If rowcount([BOD2])>0
            [F:ITB]BOMEXIFLG = 2
        Else
            [F:ITB]BOMEXIFLG = 0
        Endif
        Filter [BOD2]
        Write [ITB]
        If [F:ITB]BOMEXIFLG = 2
&        & LTABCPNBYP(I)<>1       # Issue 104223 - 2015-03-31 by CCC
            Call CALCLLC (LTABCPN(I),ALT,ALTTYP,SENS)
        Endif
    Endif
    If GOK=-1 : Break : Endif
Next

# retour du sous-pro = remontée d'un niveau
If TROUVE
   GNIV -= 1
Endif
fstat = WFSTAT
If SENS="-"
   Close Local File [ITB2] # FQ 64407 GA 07/2010
Endif
Close Local File [BOD2] # FQ 64407 GA 07/2010
End

###########################################################################
# Remontée de nomenclature récursive (à partir du composant)
# pour déterminer les cas d'emploi Dernier niveau
###########################################################################
Subprog EMPDERNIV(LITM,CPN,ALT,ALTTYP,OK)
Value Char LITM : # le composant
Value Char CPN
Value Integer ALT
Value Integer ALTTYP
Variable Integer OK

Local Integer WLLCTYP : WLLCTYP = func LLCLIB.LLCTYP(ALTTYP)

# 06.06 demande 21581
# UN NIVEAU DE LOCALITÉ à CHAQUE APPEL !
# FQ 64407 GA 04/2010 traiter aussi les sous-produits CPNTYP=4: suppression de "& !find(CPNTYP,4,5)"
Local File BOMD [BOD] Where CPNITMREF = CPN & BOMALT = ALT
&                         & find(CPNTYP,4,5)=0    # Issue 117054 - 2016-06-13 by GH : Change <> by =
#&                         & find(CPNTYP,4,5)<>0   # Issue 104223 - 2015-03-26 by CCC : Don't take into account by-product

Read [BOD]BOD3 First
# s'arreter si l'on trouve l'article en cours
If !fstat & [F:BOD]ITMREF = LITM
   Goto ERR1
Endif
While !fstat
    If [F:BOD]ITMREF = LITM : OK = 0 : Break : Endif
#   QTE *= QTE
    Read [F:ITB]ITB0= [F:BOD]ITMREF;[F:BOD]BOMALT;WLLCTYP
    If !fstat & [F:ITB]WUSEXIFLG = 2
       Call EMPDERNIV(LITM,[F:BOD]ITMREF,ALT,ALTTYP,OK)
       If OK = 0 : Break : Endif
    Endif
#   sinon ecrire dans le fichier de sortie
    Read [BOD]BOD3 Next
Wend
If OK = 1 : Goto FIN1 : Endif

$ERR1
OK = 0

$FIN1
Close Local File [BOD] # pour libérer la mémoire (bug 12546) 25/01/02
End

############################################################
# Issue 118021 GH 07/09/2016 - not used anymore
############################################################
# Sous- programme pour rechercher tous les cas d'emploi du composant
# et ramener le LLC maximum.  TEST avec méthode lecture des cas d'emplois
Subprog RECHLLC(ITM,ALT,ALTTYP,MAX_LLC,COMPOSE)
Value Char ITM
Value Integer ALT
Value Integer ALTTYP
Variable Integer MAX_LLC
Value Char COMPOSE

Local Integer WLLCTYP : # WLLCTYP = func LLCLIB.LLCTYP(ALTTYP)
WLLCTYP = func LLCLIB.LLCTYP([F:BOD]BOMALTTYP) : # Issue 117054 - 2016-06-13 by GH : optimisation

If clalev([F:WBO])=0 : Local File BOMD [WBO] : Endif
Filter [WBO] Where CPNITMREF=ITM & BOMALT=ALT & ITMREF <> COMPOSE
&               & find(CPNTYP,4,5)=0    # Issue 117054 - 2016-06-13 by GH : Change <> by =
#&               & find(CPNTYP,4,5)<>0   # Issue 104223 - 2015-03-31 by CCC

MAX_LLC = 0
For [WBO]
    # WLLCTYP = func LLCLIB.LLCTYP([F:BOD]BOMALTTYP) : # Issue 117054 - 2016-06-13 by GH : optimisation
    Read [ITB2]ITB0=[F:WBO]ITMREF;[F:WBO]BOMALT;WLLCTYP : # LLC du composé
    If !fstat & [F:ITB2]LLC > MAX_LLC # Issue 117054 - 2016-06-13 by GH : fstat tested
        MAX_LLC = [F:ITB2]LLC
    Endif
Next
Filter [WBO]
MAX_LLC += 1 : # niveau du composant trouvé ailleurs
Close Local File [WBO] # FQ 64407 GA 07/2010
End

#######################################################################
# CALCUL du LLC généralisé à partir d'un article maître (entête)
# utilisé dans le configurateur
# appelé dans une transaction
#######################################################################
Subprog LLCUPD(ITMM,ALT,ALTTYP,SENS)
Value Char ITMM        : # article maître
Value Integer ALT
Value Integer ALTTYP
Value Char SENS        : # "+" en création de lien ; "-" en annulation
If !clalev([F:BOD]) : Local File BOMD   [BOD] Endif
If !clalev([F:ITB]) : Local File ITMBOM [ITB] Endif

Local Integer WLLCTYP : WLLCTYP = func LLCLIB.LLCTYP(ALTTYP)

Local Char    ERR_TRA(132)
Local Integer MAJ_OK
Local Integer NB_OLD, NB_NEW : # nb enreg effacés, recréés

Global   Integer GNIV, GBOHLLC : # pour le sous-pro de màj des LLC

MAJ_OK = 1
If SENS = "-" Goto FIN_MAJ Endif :# pas encore fait !

# Premier passage pour l'entête de nomenclature
Read [ITB]ITB0=ITMM;ALT;WLLCTYP
If fstat
    Raz [F:ITB]
    [F:ITB]ITMREF    = ITMM
    [F:ITB]BOMALT    = ALT
    [F:ITB]LLCTYP    = WLLCTYP
    [F:ITB]BOMEXIFLG = 2
    [F:ITB]CREDAT    = date$
    [F:ITB]CREUSR    = GUSER
    [F:ITB]EXPNUM    = [C]EXPORT
    Write [ITB]
    If fstat
        MAJ_OK = 0 : Goto FIN_MAJ
    Endif
Else
    [F:ITB]BOMEXIFLG = 2
    Rewrite [ITB]
    If fstat
        MAJ_OK = 0 : Goto FIN_MAJ
    Endif
Endif
# garder le LLC de l'entête
GBOHLLC = [F:ITB]LLC

# traitement des liens de nomenclatures
# 06.06 demande 21581
# FQ 64407 GA 04/2010 traiter aussi les sous-produits CPNTYP=4: suppression de "& !find(CPNTYP,4,5)"
For [BOD]BOD0 Where ITMREF = ITMM & BOMALT=ALT
&                 & find(CPNTYP,4,5)=0   # Issue 104223 - 2015-03-26 by CCC : Don't take into account by-product \ Issue 114190 - 27-05-2016 by STLIG : = not <>
    WLLCTYP = func LLCLIB.LLCTYP([F:BOD]BOMALTTYP)
    Read [ITB]ITB0 = [F:BOD]CPNITMREF;[F:BOD]BOMALT;WLLCTYP
    If fstat = 5
        Raz [F:ITB]
        [F:ITB]ITMREF    = [F:BOD]CPNITMREF
        [F:ITB]BOMALT    = [F:BOD]BOMALT
        [F:ITB]LLCTYP    = WLLCTYP
        [F:ITB]WUSEXIFLG = 2
        [F:ITB]LLC       = GBOHLLC + 1
        [F:ITB]BOHITM    = [F:BOD]ITMREF
        [F:ITB]CREDAT    = date$
        [F:ITB]CREUSR    = GUSER
        [F:ITB]EXPNUM    = [C]EXPORT
        Write [ITB]
        If fstat
            MAJ_OK = 0
            Break
        Endif
    Elsif fstat = 1  : # enreg déjà locké
        GOK = -1 : GLOCK = "$ITMBOM"-[F:ITB]ITMREF-num$([F:ITB]BOMALT)-num$([F:ITB]LLCTYP) : Break
    Elsif !fstat & ([F:ITB]LLC < (GBOHLLC + 1))
       [F:ITB]WUSEXIFLG = 2
       [F:ITB]LLC       = GBOHLLC + 1
       [F:ITB]BOHITM    = [F:BOD]ITMREF
       Rewrite [ITB]
       GNIV = 1 : # car on part du composant en lançant le sous-pro
       # appel du prog récursif qui met à jour les sous-niveaux
       Call CALCLLC([F:BOD]CPNITMREF,[F:BOD]BOMALT,[F:BOD]BOMALTTYP,"+")
    Elsif !fstat & ([F:ITB]LLC = (GBOHLLC + 1)) & [F:ITB]BOHITM <> [F:BOD]ITMREF
        [F:ITB]BOHITM = "" : # plusieurs liens au même LLC
        Rewrite [ITB]
        If fstat
            MAJ_OK = 0
            Break
        Endif
    Endif
Next

$FIN_MAJ
If GOK = 0 | MAJ_OK = 0
    # tracer le problème sur ITB à partir des liens
    ERR_TRA = mess(13,100,1) - mess(192,197,1)-" (ITMBOM)"
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
Endif
Close Local File [ITB] # FQ 64407 GA 07/2010
Close Local File [BOD] # FQ 64407 GA 07/2010

End

########################################################################
# A partir du type d'encours, renvoit si il s'agit d'une demande
Funprog LLCTYP( LBOMALTTYP)
Value    Integer LBOMALTTYP
Local    Integer LLLCTYP
Case LBOMALTTYP
    When 1:             # commerce
                        LLLCTYP = 1
    When 2,3:           # production/sous-traitance
                        LLLCTYP = 2
    When Default:       # Erreur
       # FQ 64407 GA 07/2010
         If dim([F:BOD]CPNITMREF)>0 & [F:BOD]CPNITMREF<>""
         Call ECR_TRACE("Funprog LLCTYP: error"-num$(LBOMALTTYP)-"Bod"-[F:BOD]ITMREF-[F:BOD]CPNITMREF-num$([F:BOD]BOMALT),1) From GESECRAN
         Else
         Call ECR_TRACE("Funprog LLCTYP: error"-num$(LBOMALTTYP),1) From GESECRAN
         Endif
                        LLLCTYP = 0 : GOK=0
Endcase
End LLLCTYP

#######################################################################
# Mise à jour table ITB (Article-Nomenclature)     FQ 73741 GA 05/2011
# [F:BOH] doit être chargée avec une entête de nomenclature valide
# [F:ITM], [F:ITB] doivent être ouverts
#######################################################################
$WRITE_ITB
Local Shortint W_ERR : W_ERR=0

# "Calcul des codes de plus bas niveau"
GMESSAGE=mess(177,188,1)-[F:BOH]ITMREF+"/"+num$([F:BOH]BOMALT)+"/"+num$([F:BOH]BOMALTTYP)
Call ECR_TRACE(GMESSAGE,0) From GESECRAN

Local File BOMD [BODA]
Local File BOMD [BODB]
GOK=1

Gosub MAJ_ALLITB # préparation ITB
If GOK = 1
    GNIV=0    # niveau de départ
    Call LLCUPD([F:BOH]ITMREF,[F:BOH]BOMALT,[F:BOH]BOMALTTYP,"+") From LLCLIB
    If GOK=-1
        Gosub WRITE_ITB_FIN
    Elsif GOK=0
        GMESSAGE=mess(178,188,1)
        Call ECR_TRACE(GMESSAGE,1) From GESECRAN
        GERR=1 : Gosub WRITE_ITB_FIN
    Endif
Elsif GOK=-1
    Gosub WRITE_ITB_FIN
Else
    GMESSAGE="Error"-num$(W_ERR)
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    GERR=1 : Gosub WRITE_ITB_FIN
Endif

$WRITE_ITB_FIN
 If clalev([F:BODA]) # FQ GA 08/2011
    Close File [BODA]
    Close File [BODB]
 Endif
Return

$MAJ_ALLITB
Local Char     WW_CURITM(GLONITM)
Local Integer  WW_BOMALT
Local Shortint WW_BOMALTTYP,WW_LLCTYP

# Composé
WW_CURITM   =[F:BOH]ITMREF
WW_BOMALT   =[F:BOH]BOMALT
WW_BOMALTTYP=[F:BOH]BOMALTTYP
WW_LLCTYP = func LLCLIB.LLCTYP(WW_BOMALTTYP)
Gosub MAJ_ITB
If W_ERR : Goto FIN_MAJ_ALLITB : Endif
# composants
For [BODA] Where ITMREF=[F:BOH]ITMREF & BOMALT=[F:BOH]BOMALT & BOMALTTYP=[F:BOH]BOMALTTYP & CPNTYP<>5
    WW_CURITM=[F:BODA]CPNITMREF
    If WW_CURITM<>""
       Gosub MAJ_ITB
    Endif
    If W_ERR : Goto FIN_MAJ_ALLITB : Endif
Next

$FIN_MAJ_ALLITB
If GOK=0  # tracer le probleme
  GMESSAGE = mess(137,123,1)-"$MAJ_ALLITB"
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Endif
Return
############################################################
$MAJ_ITB
Read [ITM]ITM0=WW_CURITM
If !fstat    # protection
  # Maj ITB
  Readlock [ITB]ITB0=WW_CURITM;WW_BOMALT;WW_LLCTYP
  Case fstat
  When 1    # enreg. déjà vérouillé
    GOK = -1
    GLOCK = "$ITMBOM"-WW_CURITM-num$(WW_BOMALT)-num$(WW_LLCTYP)  # Issue 116136 - 2016-06-15 by STLIG : Replace LLCTYP with WW_LLCTYP
    W_ERR=2
  When 0    # existe
    [F:ITB]LLC=0    # le calcul std LLC le met à jour
    Gosub MAJ_ITBRUB
    Rewrite [ITB]
    If fstat
        Call FSTA("ITB") From GLOCK
        W_ERR=2 : GOK=0
    Endif
  When 5    # n'existe pas
    Raz [F:ITB]
    [F:ITB]ITMREF    = WW_CURITM
    [F:ITB]BOMALT    = WW_BOMALT
    [F:ITB]LLCTYP    = WW_LLCTYP
    [F:ITB]CREDAT    = date$
    [F:ITB]CREUSR    = GUSER
    [F:ITB]EXPNUM    = [C]EXPORT
    Gosub MAJ_ITBRUB
    Write [ITB]
    If fstat
      Call FSTA("ITB") From GLOCK
      W_ERR=2 : GOK=0
    Endif
  When Default
    Call FSTA("ITB") From GLOCK
    W_ERR=2 : GOK=0
  Endcase
Else
  Call FSTA("ITM") From GLOCK
  W_ERR=1 : GOK=0
Endif

$FIN_MAJ_ITB
Return

############################################################
$MAJ_ITBRUB
[F:ITB]BOMEXIFLG = 0# composé
[F:ITB]WUSEXIFLG = 0# where used
[F:ITB]BOHITM=""# entete
# composé
Filter [BODB] Where ITMREF = [F:ITB]ITMREF &
&                   BOMALT = [F:ITB]BOMALT
&             Order By Key BOD0
For [BODB]
  [F:ITB]BOMEXIFLG = 2
  Break
Next
Filter [BODB]

# composant
Filter [BODB] Where CPNITMREF = [F:ITB]ITMREF &
&                   BOMALT    = [F:ITB]BOMALT
&             Order By Key BOD1
For [BODB]
  [F:ITB]WUSEXIFLG = 2
  # entete si unique
  If [F:ITB]BOHITM="" # 1er fois
    [F:ITB]BOHITM=[BODB]ITMREF
  Elsif [F:ITB]BOHITM <> [BODB]ITMREF
    [F:ITB]BOHITM=""
    Break
  Endif
Next
Filter [BODB]
Return


########################################################################
Subprog ECR_DEBUG(LMESS)                         # FQ 69008 GA 11/2010 #
Value Char LMESS
If LMESS<>"" & GUSER="xADMINx"
   Call ECR_TRACE(LMESS,0) From GESECRAN
Endif
End

