#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("VEF",GBIDC1,GBIDC2) From GOBJET
End

# Issue X3-93502 - 2018-06-27 by CBO : Enhancements of VAT form
# Issue X3-98320 - 2018-06-26 by CBO : Refactoring
# Issue EPIC_X3-74826 (X3-98320) - 2018-06-26 by FHA : Refactoring SUBVEF
# Issue X3-85098 - 2018-05-30 by CBO : add a tunnel
# Issue EPIC_X3-63065 (X3-91052) - 2018-05-30 by MWA : Advanced formula setup
# Issue EPIC_X3-63065 (X3-71891) - 2018-02-06 by MDJ : MTD_Form_Setup

####################################################################################################
# Tables
#   VATENTFRM  [VEF]   (Key : VATFRM+VATFNC+LEG+LIN)
###########F################################################################################################
# Masks           Windows   Function    Programs    Object/action
# -----          --------   -------   --------     --------
# VATFRM0 [VEF0]  |
# VATFRM1 [VEF1]  |  OVEF    GESVEF      SUBVEF      VEF ( Objet simply)|
###########################################################################################################
$ACTION

  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "AFFMASK"     : Gosub AFFMASK
    When "SETBOUT"     : Gosub SETBOUT
    When "LIENS"       : Gosub LIENS
    When "FILTRE"      : Gosub FILTRE
    When "FILGAUCHE"   : Gosub FILGAUCHE
    When "RAZCRE"      : Gosub RAZCRE
    When "INICRE"      : Gosub INICRE
    When "VERIF_CRE"   : Gosub VERIF_CRE
    When "CREATION"    : Gosub CREATION
    When "APRES_CRE"   : Gosub APRES_CRE
    When "INIMOD"      : Gosub INIMOD
    When "VERIF_MOD"   : Gosub VERIF_MOD
    When "MODIF"       : Gosub MODIF
    When "APRES_MOD"   : Gosub APRES_MOD
    When "AV_ANNULE"   : Gosub AV_ANNULE
    When "ANNULE"      : Gosub ANNULE
    When "FERME"       : Gosub FERME
    When "SEL_LISTE"   : Gosub SEL_LISTE
    When Default
  Endcase

Return
###################################################
$OUVRE

If clalev([F:VEF])  = 0   : Local File VATENTFRM    [VEF]   : Endif
If clalev([F:VEF2]) = 0   : Local File VATENTFRM    [VEF2]  : Endif
If clalev([F:VEFD]) = 0   : Local File VATENTFRMD   [VEFD]  : Endif

If clalev([F:VFE])  = 0   : Local File VATFRMENT    [VFE]   : Endif
If clalev([F:AXX])  = 0   : Local File ATEXTRA      [AXX]   : Endif
If clalev([F:TCU])  = 0   : Local File TABCUR       [TCU]   : Endif

Global Integer GMAXLINTXT              # Manage the translatable titles while inserting a line(s)
Global Char    GVATFNC(GLONAFC)        # Manage the translatable titles while inserting a line(s)
Global Char    TDELVATBOX(10)(1..)     # Vat box deleted (for deleting ATEXTRA records)
Global Integer I_DEL                   # Index for Vat box lines deleted (for deleting ATEXTRA records)
Global Integer G_VFE_STATUS
Raz TDELVATBOX, I_DEL

  G_VFE_STATUS = 0
  If dim(GCURLEG)>0
    Local Char SAV_GCURLEG(GLONADI)
    SAV_GCURLEG = GCURLEG
  Endif

Return
###################################################
$AFFMASK

  # If TUNNEL and dim ([M:VFE0]VATFRM) > 0
  If TUNNEL and dim ([M:VFE0]VATFRM) > 0 and  (GNAVIG(max(GPILNAV-1,1)) = "GESVFE")
    [M:VEF0]VATFRM = [M:VFE0]VATFRM
    [M:VEF0]VATFNC = [M:VFE1]VATFNC
    [M:VEF0]LEG = [M:VFE1]LEG

    CLE1 = ""   # Remise à vide, pour ne rien perturber

  Endif

  # Hide the leg if mono-leg folder
  Call FMTLEG From TRTX3
  Gosub GRILEG

Return
###################################################
$GRILEG

  # if folder mono-legislation
  If func AFNC.ACTIV("LEG")=[V]CST_AFALSE
    Diszo [M:VEF0]LEG
    [M:VEF0]LEG=GDOSLEG(1)
    Affzo [M:VEF0]LEG
  Endif

Return
###################################################
$SETBOUT

  If CLECUR = 0
    Call VIREBOUT(CHAINE,"A") From GOBJET
  Else
    If instr(1, CHAINE, 'A') = 0
      CHAINE += 'A'
    Endif
  Endif

  # It's not possible to delete a VAT form setting if the VAT form is already used
  Filter[VFE] Where
&             ( VATFRM = [M:VEF0]VATFRM and
&               VATFNC = [M:VEF0]VATFNC and
&               LEG    = [M:VEF0]LEG )

  Look [VFE]VFE0 First
  If fstat = 0
    Call VIREBOUT(CHAINE,"A") From GOBJET
  Endif
  Filter[VFE]

Return
###################################################
$LIENS

 # Simply object => Supervisor manage VATFRM+VATFNC+LEG+LIN=0
  Local Char LVATBOX(10)
 #  If TUNNEL and [M:VEF0]VATFRM <> ""
  If TUNNEL and dim ([M:VFE0]VATFRM) > 0 and  (GNAVIG(max(GPILNAV-1,1)) = "GESVFE")
    Read [VEF]VEF0 = [M:VEF0]VATFRM; [M:VEF0]VATFNC; [M:VEF0]LEG
  Endif
  If dim([M:VEF0]LEG)>0
    Affzo [M:VEF0]LEG
  Endif

  GCURLEG = [F:VEF]LEG
  If GNBLEG = 1
    GCURLEG = GDOSLEG
  Endif
  Raz TDELVATBOX, I_DEL

  # reading translatable texts for DESTRA and SHOTRA fields
  Call LECTEXTRA([M:VEF0]DESTRA,"VATENTFRM","DESTRA",[M:VEF0]VATFRM,[M:VEF0]VATFNC+"~"+GCURLEG) From ATEXTRA
  Call LECTEXTRA([M:VEF0]SHOTRA,"VATENTFRM","SHOTRA",[M:VEF0]VATFRM,[M:VEF0]VATFNC+"~"+GCURLEG) From ATEXTRA

  # We read the records that have a line number > 0 (key=VATFRM+VATFNC+LEG+LIN > 0) to fill the VATBOX tab
  nolign = 0
  For [VEFD]VEFD0 Where VATFRM = [F:VEF]VATFRM &
&                       VATFNC = [F:VEF]VATFNC &
&                       LEG    = [F:VEF]LEG
    If nolign >= dim ([M:VEF1]VATBOX)
      Break
    Endif

    nolign += 1
    [M:VEF1] = [F:VEFD]
    LVATBOX=[M:VEF1]VATBOX(nolign-1)
    Call LECTEXTRA([M:VEF1]DESLIN([F:VEFD]LIN-1),"VATENTFRMD","DESLIN",[M:VEF0]VATFRM,[M:VEF0]VATFNC+"~"+GCURLEG+"~"+num$(LVATBOX)) From ATEXTRA
    [M:VEF1]LIGTXT([F:VEFD]LIN-1) = [F:VEFD]LIN

  Next

  [M:VEF1]NBBOX = nolign
  Affzo [M:VEF1]

  # If the type of the box is not "Total", the formula condition is disable
  For I=1 To [M:VEF1]NBBOX
    If  [M:VEF1]TYPBOX(I-1) <> 3
      Raz [M:VEF1]CNDFOR(I-1)
      Diszo [M:VEF1]CNDFOR(I-1)
    Else
      Actzo [M:VEF1]CNDFOR(I-1)
    Endif
  Next

  GMAXLINTXT = max([M:VEF1]NBBOX)

  Filter  [VFE] Where VATFRM = [M:VEF0]VATFRM and
&                     VATFNC =  [M:VEF0]VATFNC and
&                     LEG    =  [M:VEF0]LEG

  Look [VFE]VFE0 First
  If fstat
    G_VFE_STATUS = 0

    Actzo [M:VEF0]5
    Actzo [M:VEF0]ENAFLG
    Actzo [M:VEF1]NBBOX
    [M:VEF0]ICOINFO = "128"
    Enable GSTAANU
  Else

    Grizo [M:VEF0]5
    Diszo [M:VEF1]1-99
    Diszo [M:VEF1]NBBOX
    [M:VEF0]ICOINFO = "127"
    Disable GSTAANU

    Filter  [VFE] Where VATFRM = [M:VEF0]VATFRM and
&                     VATFNC =  [M:VEF0]VATFNC and
&                     LEG    =  [M:VEF0]LEG and
&                     STA    = 1
    Look [VFE]VFE0 First
    If fstat
      G_VFE_STATUS = 2
      Actzo [M:VEF0]ENAFLG
    Else
      G_VFE_STATUS = 1
      Diszo [M:VEF0]ENAFLG

    Endif
  Endif
  Filter  [VFE]

Return
###################################################
$FILGAUCHE

  If GLEGFIL<>""
    If FILGAUCHE <> ""
      FILGAUCHE -= "&"
    Endif
    FILGAUCHE -= "(find([F:VEF]LEG, '" + GLEGFIL + "','') > 0)"
    If FILGAUSUP <> ""
      FILGAUSUP += " & "
    Endif
    FILGAUSUP += "(find([F:VEF]LEG, '" + GLEGFIL + "','') > 0)"
  Endif

Return
###################################################
$FILTRE

  #If dim(TUNNEL) > 0 and TUNNEL and [M:VEF0]VATFRM <> ""
  If dim(TUNNEL) > 0 and  TUNNEL and dim ([M:VFE0]VATFRM) > 0 and  (GNAVIG(max(GPILNAV-1,1)) = "GESVFE")
    If FILTSUP <> ""
      FILTSUP -= "and"
    Endif
    FILTSUP -= "VATFRM = '" + [M:VEF0]VATFRM + "' and"
    FILTSUP -= "VATFNC = '" + [M:VEF0]VATFNC + "' and"
    FILTSUP -= "LEG = '" + [M:VEF0]LEG + "'"
  Endif

Return
###################################################
$RAZCRE

  [M:VEF0]VATFNC = "DCLVATBRI"
  Affzo [M:VEF0]VATFNC
  Gosub GRILEG

  Raz TDELVATBOX, I_DEL

Return
###################################################
$INICRE
$INIMOD

  # when mono-leg folder
  If func AFNC.ACTIV("LEG") = [V]CST_AFALSE
    [F:VEF]LEG = GDOSLEG(1)
  Endif

Return
###################################################
$VERIF_CRE
$VERIF_MOD

  # The end date can only be empty or greater than the start date
  If [M:VEF0]VLYENDDAT<>[0/0/0] & [M:VEF0]VLYENDDAT<=[M:VEF0]VLYSTRDAT
    GMESSAGE = mess(1,104,1) - ":" - format$("D:" + GFMDAT4, [M:VEF0]VLYSTRDAT) - ">" - format$("D:" + GFMDAT4, [M:VEF0]VLYENDDAT)

    GERR = 1
    OK = 0
    Return
  Endif

  If ( GREP = "C" or GREP = "D" ) and [M:VEF0]ENAFLG = [V]CST_AYES

    Filter [VEFD] Where VATFRM <> [M:VEF0]VATFRM and VATFNC = [M:VEF0]VATFNC and LEG = [M:VEF0]LEG and ENAFLG = [V]CST_AYES
    Look[VEFD]VEFD0 First
    Filter [VEFD]
    If fstat=0
      GERR=1
      # Only "One active setting for one declaration and one legislation"
      GMESSAGE = mess(209,104,1)
      OK=0
      Return
    Endif
  Endif

  If GREP="D" or  ( [M:VEF0]VLYSTRDAT <> [F:VEF]VLYSTRDAT ) or
&                 ( [M:VEF0]VLYENDDAT <> [F:VEF]VLYENDDAT )

    # Check that the validity dates do not overlap for the same Declaration (VATFNC) and the same legislation (LEG)

    Filter  [VEF2] Where (VATFRM <> [M:VEF0]VATFRM and
&                         VATFNC =  [M:VEF0]VATFNC and
&                         LEG    =  [M:VEF0]LEG )
&                         Order By VLYSTRDAT
    For [VEF2]
      If  ( [M:VEF0]VLYSTRDAT >= [F:VEF2]VLYSTRDAT and  [M:VEF0]VLYSTRDAT <= [F:VEF2]VLYENDDAT ) or
&         ( [M:VEF0]VLYSTRDAT <= [F:VEF2]VLYSTRDAT and  [M:VEF0]VLYENDDAT >= [F:VEF2]VLYSTRDAT ) or
&         ( [M:VEF0]VLYENDDAT >= [F:VEF2]VLYSTRDAT and  [M:VEF0]VLYENDDAT <= [F:VEF2]VLYENDDAT)
        GERR=1
        # "Validity dates cannot overlap for the same 'Declaration' and 'Legislation'"
        GMESSAGE = mess(210,104,1)
        OK=0
        Break
      Endif
    Next
    Filter [VEF2]

  Endif
  If OK=0 : Return : Endif

Return
###################################################
$CREATION

  # Create records in the VATENTFRM table (LIN > 0)
  For NOL=0 To [M:VEF1]NBBOX-1
    nolign = NOL+1
    [F:VEFD]          = [M:VEF0]
    [F:VEFD]          = [M:VEF1]
    [F:VEFD]LIN = nolign
    Write [VEFD]
    If fstat
      GOK = 0
      Call FSTA("VEFD") From GLOCK
      Break
    Endif
  Next
  If GOK < 1
    Return
  Endif

  Gosub TEXTRA
  If GOK < 1
    Return
  Endif

Return
###################################################
$MODIF

  # First, We delete... then we create
  Delete [VEFD] Where [F:VEFD]VATFRM      = [F:VEF]VATFRM &
&                     [F:VEFD]VATFNC      = [F:VEF]VATFNC &
&                     [F:VEFD]LEG         = [F:VEF]LEG
  If fstat = 1
    GOK = -1
    Call RSTA("VEFD",[F:VEF]VATFRM-"/"-[F:VEF]VATFNC-"/"-[F:VEF]LEG) From GLOCK
    Return
  Endif
  If GOK < 1
    Return
  Endif

  Gosub CREATION

Return
###################################################
$APRES_CRE

  CLECUR1    =  [M]VATFNC
  CLECUR2(0) =  [M]VATFRM
  CLECUR2(1) =  GCURLEG

  Gosub SUP_TEXTRA

  Gosub RELIT From GOBJET
  zoncou     = ""
  Gosub RAFFRAICHIR From GOBJSUB

Return
###################################################
$APRES_MOD

  CLECUR1    =  [M]VATFNC
  CLECUR2(0) =  [M]VATFRM
  CLECUR2(1) =  GCURLEG

  Gosub SUP_TEXTRA

  Gosub RELIT From GOBJET
  zoncou  = ""
  Gosub RAFFRAICHIR From GOBJSUB

Return

$SUP_TEXTRA

Local Integer J

  For J = 1 To I_DEL
    If TDELVATBOX(J) <> ""
      Call SUPTEXTRA("VATENTFRMD", "DESLIN", [F:VEF]VATFRM,
&                    [F:VEF]VATFNC + "~" + [F:VEF]LEG +"~" + TDELVATBOX(J)) From ATEXTRA
    Endif
  Next I

Return

###################################################
$TEXTRA
# 3 translates texts :
#  DESTRA     (Key :  VATFRM + VATFNC~LEG)
#  SHOTRA     (key :  VATFRM + VATFNC~LEG)
#  DESLIN     (key :  VATFRM+VATFNC~LEG~VATBOX)

  If GREP="D" # Duplication
    Call DUPTEXTRA("VATENTFRM","DESTRA",[F:VEF]VATFRM,[F:VEF]VATFNC+"~"+[F:VEF]LEG,"VATENTFRM","DESTRA",[M:VEF0]VATFRM,[M:VEF0]VATFNC+"~"+[M:VEF0]LEG)  From ATEXTRA
    Call DUPTEXTRA("VATENTFRM","SHOTRA",[F:VEF]VATFRM,[F:VEF]VATFNC+"~"+[F:VEF]LEG,"VATENTFRM","SHOTRA",[M:VEF0]VATFRM,[M:VEF0]VATFNC+"~"+[M:VEF0]LEG)  From ATEXTRA
    For I=0 To [M:VEF1]NBBOX-1
      Call DUPTEXTRA("VATENTFRMD","DESLIN",[F:VEFD]VATFRM,[F:VEFD]VATFNC+"~"+[F:VEFD]LEG+"~"+num$([M:VEF1]VATBOX(I)),
&                    "VATENTFRMD","DESLIN",[F:VEF]VATFRM,[F:VEF]VATFNC+"~"+[F:VEF]LEG+"~"+num$([M:VEF1]VATBOX(I)))
&          From ATEXTRA

     If GOK < 1
      Break
    Endif
    Next
    If GOK < 1
      Return
    Endif
  Endif

  Call MAJTEXTRA([M:VEF0]DESTRA,"VATENTFRM","DESTRA",[F:VEF]VATFRM,[F:VEF]VATFNC+"~"+[F:VEF]LEG) From ATEXTRA
  Call MAJTEXTRA([M:VEF0]SHOTRA,"VATENTFRM","SHOTRA",[F:VEF]VATFRM,[F:VEF]VATFNC+"~"+[F:VEF]LEG) From ATEXTRA

  If GREP = "M" # Modification
    For I=0 To [M:VEF1]NBBOX-1
      Call MAJTEXTRA([M:VEF1]DESLIN(I),"VATENTFRMD","DESLIN",[M:VEF0]VATFRM,[F:VEFD]VATFNC+"~"+[F:VEFD]LEG+"~"+num$([M:VEF1]VATBOX(I))) From ATEXTRA
      If GOK < 1
        Break
      Endif
      [M:VEF1]LIGTXT(I) = I + 1
    Next
    If GOK < 1
      Return
    Endif
  Else
    If GREP = "C" or GREP = "D" # Creation or Duplication
      For I=0 To [M:VEF1]NBBOX-1
        Call MAJTEXTRA([M:VEF1]DESLIN(I),"VATENTFRMD","DESLIN",[M:VEF0]VATFRM,[M:VEF0]VATFNC+"~"+GCURLEG+"~"+num$([M:VEF1]VATBOX(I))) From ATEXTRA
        If GOK < 1
          Break
        Endif
      Next
      If GOK < 1
        Return
      Endif
    Endif
  Endif

Return
###################################################
$AV_ANNULE

Local Integer I
Local Char    LACTION(1), LVATBOX(10)

  For I=1 To [M:VEF1]NBBOX
    LACTION="A" : # Delete all
    LVATBOX=[M:VEF1]VATBOX(I-1)
  Next I

Return
###################################################
$ANNULE

  Delete [VEFD] Where [F:VEFD]VATFRM      = [F:VEF]VATFRM    and
&                     [F:VEFD]VATFNC      = [F:VEF]VATFNC    and
&                     [F:VEFD]LEG         = [F:VEF]LEG

  If fstat = 1
    GOK = -1
    Call RSTA("VEFD",[F:VEF]VATFRM-"/"-[F:VEF]VATFNC-"/"-[F:VEF]LEG) From GLOCK
    Return
  Endif
  If GOK < 1
    Return
  Endif

  Call SUPTEXTRA("VATENTFRM","DESTRA",[F:VEF]VATFRM,[F:VEF]VATFNC+"~"+[F:VEF]LEG) From ATEXTRA
  If GOK < 1
    Return
  Endif
  Call SUPTEXTRA("VATENTFRM","SHOTRA",[F:VEF]VATFRM,[F:VEF]VATFNC+"~"+[F:VEF]LEG) From ATEXTRA
  If GOK < 1
    Return
  Endif

  For I=0 To [M:VEF1]NBBOX-1
    Call SUPTEXTRA("VATENTFRMD","DESLIN",[F:VEF]VATFRM,[F:VEF]VATFNC+"~"+[F:VEF]LEG+"~"+num$([M:VEF1]VATBOX(I))) From ATEXTRA
    If GOK < 1
      Break
    Endif
  Next

  If GOK < 1
    Return
  Endif

Return
###################################################
$FERME

  If dim(SAV_GCURLEG)>0
    GCURLEG = SAV_GCURLEG
  Endif

  If dim(GMAXLINTXT)
    Kill GMAXLINTXT
  Endif

Return

###############################################################################
##  Copie  Issue X3-97936
###############################################################################
$TRTCOP

If [M]DOSORG=nomap
 Local File VATENTFRM   [VEF1]
 Local File VATENTFRMD  [VED1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".VATENTFRM"      [VEF1]
 Local File =[M]DOSORG+".VATENTFRMD"     [VED1]
 Local File =[M]DOSORG+".ATEXTRA"     [AXX1]
Endif
If [M]DOSDES=nomap
 Local File VATENTFRM   [VEF2]
 Local File VATENTFRMD  [VED2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".VATENTFRM"   [VEF2]
 Local File =[M]DOSDES+".VATENTFRMD"  [VED2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA

If TABLE3<>"" & clalev([F:ADS2])>0 & !find(TABLE3,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1))
 Call MESSAGE(TABLE3-":"-mess(249,133,1) ) From GESECRAN
 Return
Endif

Call DEBTRANS From GLOCK
Gosub TR_COP

Close Local File [VEF1], [VEF2], [VED1], [VED2], [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif

Return

$TR_COP

Read [VEF2]VEF0=TABLE; TABLE2; TABLE3
If !fstat
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
Endif

GOK = 1
Trbegin [VEF2]
 Delete [VEF2] Where VATFRM=TABLE & VATFNC=TABLE2 & LEG=TABLE3
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".VATENTFRM" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("VEF2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [VED2] Where VATFRM=TABLE & VATFNC=TABLE2 & LEG=TABLE3
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".VATENTFRM" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("VEF2","") From GLOCK : Goto AB_TR_COP
 Endif

 For [VEF1] Where VATFRM=TABLE & VATFNC=TABLE2 & LEG=TABLE3
  [F:VEF2] = [F:VEF1]
  Call COPTEXTRA("VATENTFRM","DESTRA",TABLE,TABLE2+"~"+TABLE3) From ATEXTRA
  Call COPTEXTRA("VATENTFRM","SHOTRA",TABLE,TABLE2+"~"+TABLE3) From ATEXTRA
  Call FLDUPD("VEF2") From OBJDIV
  Write [VEF2]
  If fstat
   GOK = 0 : Call FSTA("VEF2") From GLOCK : Break
  Endif
 Next
 For [VED1] Where VATFRM=TABLE & VATFNC=TABLE2 & LEG=TABLE3
  [F:VED2] = [F:VED1]
  Call COPTEXTRA("VATENTFRMD","DESLIN",TABLE,TABLE2+"~"+TABLE3+"~"+num$([F:VED1]VATBOX)) From ATEXTRA
  Call FLDUPD("VED2") From OBJDIV
  Write [VED2]
  If fstat
   GOK = 0 : Call FSTA("VED2") From GLOCK : Break
  Endif
 Next

 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Commit

Return

$AB_TR_COP

Rollback

Return

$ROLL_TR_COP

Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

Return


###################################################
$SEL_LISTE

  Case LISTE
    When "SELAFCVAT" : Gosub SELAFCVAT
    When Default
  Endcase

Return
###################################################
$SELAFCVAT

Local Char    TEXTE(80)(1..dim(TEX),1..2)

  # Selection of functions linked with the action code DCLVATSTD
  TIT(0) = mess(10, 16,1)-mess(20,110,1)
  TIT(1) = mess(20,110,1)
  TIT(2) = mess(38,100,1)

  If clalev([F:WAFC])=0  : Local File AFONCTION   [WAFC]  : Endif

  NBTEX = 0
  For [WAFC] Where ACTION="DCLVATSTD"
    If NBTEX>=dim(TEXTE)
      Break
    Endif
    NBTEX += 1
    TEX(NBTEX)     = [F:WAFC]CODINT
    TEXTE(NBTEX,1) = [F:WAFC]CODINT
    Call TEXTE([F:WAFC]NOM,TEXTE(NBTEX,2)) From OBJDIV
  Next

  If NBTEX=0
    Call MESSAGE(mess(99,100,1)) From GESECRAN
    GERR=2 : mkstat=2
    Return
  Endif

Return

######################################################################################
## Labels of VATFRM0 screen
######################################################################################
#=====================================
Subprog AM_VATFNC(VALEUR)
Variable Char    VALEUR()

 GVATFNC=VALEUR

End
#=====================================
Subprog C_VATFNC(VALEUR)
Variable Char    VALEUR()

If clalev([F:WAFC])=0  : Local File AFONCTION   [WAFC]  : Endif

  # The VAT function must have an action code "DCLVATSTD"
  fstat=0
  If [F:WAFC]CODINT<>VALEUR
    Read [F:WAFC]CODINT = VALEUR
  Endif
  If fstat | [F:WAFC]ACTION<>"DCLVATSTD"
    GMESSAGE=mess(83,123,1)
    mkstat=2
    End
  Endif

End
#=====================================
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

  GCURLEG = VALEUR

End
#=====================================
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()

  GCURLEG = VALEUR

End
#=====================================
Subprog AM_AMTVATCUR(VALEUR)
Variable Char    VALEUR()

  # Research of the number of decimals for the currency
  Call LEC_TCU(VALEUR) From CPTLEC
  [M:VEF0]DEC = [F:TCU]DECNBR
  Affzo [M:VEF0]DEC

End
#=====================================
Subprog C_DEC(VALEUR)
Variable Decimal VALEUR

 # Initialized with the number of decimals of the currency
 # must be <= 3
 If VALEUR > 3
   # "Maximum number of decimals: 3"
   GMESSAGE=mess(211,104,1)
   mkstat=2
   End
 Endif

End
#=====================================
Subprog AS_ENAFLG(VALEUR)
Variable Integer VALEUR

Local Integer ENT_COUNT :   ENT_COUNT=0

  If G_VFE_STATUS = 1
    mkstat=2
    Grizo [M:VEF0]ENAFLG
  Else
    Actzo [M:VEF0]ENAFLG
  Endif

End
#=====================================
Subprog AM_ENAFLG(VALEUR)
Variable Integer VALEUR

 Local Integer FRM_COUNT :  FRM_COUNT=0

  If ( VALEUR <> [M:VEF0]ENAFLG ) and ( VALEUR =  [V]CST_AYES ) # Active

    Filter [VEF]  Where ( VATFNC =  [M:VEF0]VATFNC  and
&                         LEG    =  [M:VEF0]LEG     and
&                         ENAFLG =  [V]CST_AYES  )
    FRM_COUNT= rowcount([VEF])
    Filter [VEF]

    If   FRM_COUNT > 0
      GERR=1
      #"Only one active setting for a 'Declaration' and a 'Legislation'
      GMESSAGE = mess(209,104,1)
      mkstat = 2
      End
    Endif
  Endif

End
######################################################################################
## Labels of VATFRM1 screen
######################################################################################
Subprog C_NBBOX

Local Integer I

  Case status
    When 65 : # Cancellation 1 line
      Gosub SETNOL

      # the TDELVATBOX table contains the VATBOX whose lines have been removed
      I_DEL += 1
      TDELVATBOX(I_DEL) = [M:VEF1]VATBOX(nolign - 1)
    When 68 : # Cancellation ??? line
      If status=65 : nolign1 = nolign : Endif
      Gosub SETNOL

      # the TDELVATBOX table contains the VATBOX whose lines have been removed
      For I=nolign To nolign1
        I_DEL += 1
        TDELVATBOX(I_DEL)=[M:VEF1]VATBOX(I-1)
      Next I
    When 83 : # Cancellation all lines
      Gosub SETNOL
      For I = 0 To [M:VEF1]NBBOX - 1
        I_DEL += 1
        TDELVATBOX(I_DEL) = [M:VEF1]VATBOX(I)
      Next I
  Endcase

  If mkstat
    End
  Endif

End
#=====================================
$SETNOL
Local Integer NOL

  NOL = nolign-1

Return
#=====================================
Subprog AS_VATBOX(VALEUR)
Variable Char    VALEUR()

  If [M]LIGTXT(nolign-1)=0
    GMAXLINTXT +=1
    [M]LIGTXT(nolign-1) = GMAXLINTXT
  Endif

End
#=====================================
Subprog C_VATBOX(VALEUR)
Variable Char    VALEUR()

  Call UNICITE(VALEUR,[M]VATBOX(0..[M]NBBOX-1)) From OBJDIV

End
#=====================================
Subprog AM_VATBOX(VALEUR)
Variable Char    VALEUR()
End
#=====================================
Subprog AS_TYPBOX(VALEUR)
Variable Integer VALEUR

   # The box type can't be "1 - Title"
   # The box type can't be "4 - Off Declaration"
   GMENLOC(1)=1
   GMENLOC(4)=1

End
#=====================================
Subprog AM_TYPBOX(VALEUR)
Variable Integer VALEUR

  # If box type ="Total" there is not Formula condition
  If VALEUR=3
    [M:VEF1]CNDFOR(nolign-1) = 1 # "None"
    Actzo [M:VEF1]CNDFOR(nolign-1)
  Else
    Raz[M:VEF1]CNDFOR(nolign-1)
    Diszo [M:VEF1]CNDFOR(nolign-1)
  Endif

End
#=====================================
Subprog AS_FLDTYP(VALEUR)
Variable Integer VALEUR

  GMENLOC(3)=1  # No choice for format="Date"
  # CBO if we keep value our sum, we can add GMENLOC(1)=1   # Box type = Numeric or Total ==> FLDTYP not Alphanumeric
  # and delete the case :

  Case [M:VEF1]TYPBOX(nolign-1)
    When 1    : GMENLOC(2)=1   # Box type = Title ==> FLDTYP not Numeric
    When 2, 3 : GMENLOC(1)=1   # Box type = Numeric or Total ==> FLDTYP not Alphanumeric
  Endcase

End
#=====================================
Subprog AS_CLCFOR(VALEUR)
Variable Char    VALEUR()

  # If box type <> "Total"
  If [M:VEF1]TYPBOX(nolign-1)<>3
    mkstat=1
  Endif

End

#=====================================
Subprog C_CLCFOR(VALEUR)
Variable Char    VALEUR()

  Local Integer B_ERR : B_ERR = 0

  If VALEUR = ""
    End
  Endif
  LIGNE = VALEUR

  # Interpretation and control of the formula
  While LIGNE<>""
    K = instr(1,LIGNE,"'")
    If K
      L = instr(K+1,LIGNE,"'")
      If (!L)
        B_ERR= 2
        Break
      Endif
      ZONE = mid$(LIGNE,K+1,L-1-K) : LIGNE = vireblc(right$(LIGNE,L+1),2)
    Else
      Break
    Endif

    # We search into the previous lines if the line number (Zone) in the formula exists (has not been deleted)
    B_ERR = 1
    For I=0 To nolign-2
      If [M:VEF1]VATBOX(I)=ZONE & ([M:VEF1]TYPBOX(I)=2 | [M:VEF1]TYPBOX(I)=3)
        B_ERR=0
        Break
      Endif
    Next I

    If B_ERR
      Break
    Endif
  Wend

  If B_ERR
    If ( B_ERR = 1 )
      GMESSAGE = mess(83,123,1)-ZONE
    Else
      GMESSAGE = mess(9,108,1)
    Endif
    mkstat = 2
    End
  Endif

  If !B_ERR
    Local Decimal RESULT
    Call EVALUE_FORMULA ("S", VALEUR, RESULT, B_ERR) From SUBVFE
    ZONE = ""
  Endif

  If B_ERR
    GMESSAGE = mess(9,108,1)
    mkstat = 2
    End
  Endif
End
#=====================================
Subprog AS_CNDFOR(VALEUR)
Variable Integer VALEUR

  # If box type <> "Total"
  If [M:VEF1]TYPBOX(nolign-1)<>3
    mkstat=1
  Endif

End

