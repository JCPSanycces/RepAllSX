#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe PHYELTCNLTRF

$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER
        When "AUPDATE_CONTROL_AFTER"   : Gosub AUPDATE_CONTROL_AFTER
      Endcase
  Endcase
Return

$METHODS
Return

$PROPERTIES
Case [L]CURPRO
Endcase
Return


# -------------------------------------
# PHYELTCNLTRF standard representation methods
# -------------------------------------

#------------------------
$AREAD_AFTER

  # 1°, we want to cancel the transfer movement
  # 2°, we want to cancel the last transfer (if not 1°)
#  If maxtab(this.CNLTRF.PHYMVT)> 0
#    If this.CNLTRF.PHYMVT(maxtab(this.CNLTRF.PHYMVT)).MVT = [V]CST_PMVGEO or
#&      this.CNLTRF.PHYMVT(maxtab(this.CNLTRF.PHYMVT)).MVT = [V]CST_PMVAGEO
#
#    this.CNLTRF.TRFDAT = this.CNLTRF.PHYMVT(maxtab(this.CNLTRF.PHYMVT)).MVTDAT
#    Endif
#  Endif

Return

#------------------------
$AUPDATE_CONTROL_AFTER
Local Char  ERRMSG(140)

  Local Instance PARAM Using C_PHYELTTRF
  PARAM = NewInstance C_PHYELTTRF AllocGroup null
  PARAM.FASFLG = [V]CST_ANO

  If fmet this.CNLTRF._PHYELT_CNL_TRANSFER(PARAM) >= [V]CST_AERROR
    [L]ASTATUS = fmet this.CNLTRF.AGETMAXERROR("")
  Endif

  FreeGroup PARAM

Return

