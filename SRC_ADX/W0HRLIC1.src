#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRLIC1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone COD
mkstat = 0
zoncou = "COD"
indice = 0
If varmode([M]COD,indice)=0
 SAVACT = GACTION : GACTION = "DEFHRLIC"
 Call DEFHRLIC([M]COD,GCURLEG,GSOCIETE) From SUBHRLIC
 GACTION = SAVACT
 If mkstat=1 : Raz [M]COD : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "COD" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]COD,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 47613 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTHRLIC"
   Call CONTHRLIC([M]COD,GCURLEG,GSOCIETE) From SUBHRLIC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 47613 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJN"
    Local Char    VALEUR(250)
    VALEUR = [M]COD
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
    [M]COD = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 47613 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "CONTOBJW"
     PARAM(1) = "HRLIC"
     Local Char    VALEUR(250)
     VALEUR = [M]COD
     Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
     [M]COD = VALEUR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 47613 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]LEG,"909","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]LEG,"909",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "ACONTLEG"
    Call CONTLEG([M]LEG) From SUBADI
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]LEG or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_LEG([M]LEG) From SUBHRLIC
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DESAXX
mkstat = 0
zoncou = "DESAXX"
indice = 0
If varinit([M]DESAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESAXX,"HRLICAUT","DESAXX",[M]COD,[M]LEG) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESAXX" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]DESAXX,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DESAXX" : GZNUM = 282 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone SHOAXX
mkstat = 0
zoncou = "SHOAXX"
indice = 0
If varinit([M]SHOAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]SHOAXX,"HRLICAUT","SHOAXX",[M]COD,[M]LEG) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SHOAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SHOAXX" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone ENAFLG
mkstat = 0
zoncou = "ENAFLG"
indice = 0
IMPENT = [M]ENAFLG
If varinit([M]ENAFLG,indice)=0
 IMPENT = 2
Endif
If varmode([M]ENAFLG,indice)=0
 [M]ENAFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENAFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENAFLG(indice)
 Endif
Endif
[M]ENAFLG = IMPENT

## Zone GRP
mkstat = 0
zoncou = "GRP"
indice = 0
If varmode([M]GRP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRP" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("AGF","!C",[M]GRP,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "GRP" : GZNUM = 28843 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CGRPCPYLEG"
  Call C_GRPCPYLEG([M]GRP,GCURLEG) From DIVPAYE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GRP" : GZNUM = 28843 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CODACT
mkstat = 0
zoncou = "CODACT"
indice = 0
If varmode([M]CODACT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACV","!",[M]CODACT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 4 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone CODACS
mkstat = 0
zoncou = "CODACS"
indice = 0
If varmode([M]CODACS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACS" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACS","!",[M]CODACS,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACS" : GZNUM = 729 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone DEFVAL
mkstat = 0
zoncou = "DEFVAL"
indice = 0
IMPENT = [M]DEFVAL
If varinit([M]DEFVAL,indice)=0
 IMPENT = 1
Endif
If varmode([M]DEFVAL,indice)=0
 [M]DEFVAL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DEFVAL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DEFVAL(indice)
 Endif
Endif
[M]DEFVAL = IMPENT

## Zone VLY
mkstat = 0
zoncou = "VLY"
indice = 0
If varmode([M]VLY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VLY" : Gosub ACTION From =IMPTRT
 Endif
 If [M]VLY<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "VLY" : GZNUM = 4038 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRLIC1"
Return

