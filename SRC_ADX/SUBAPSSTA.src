Local Char DDCHAR(50), DDCHAR2(50)
Local Date DAT
#Dbgaff
DDCHAR="" #format$("D:YYYYMMDD",addmonth(date$,15))
DDCHAR="addmonth(date$,15)"
DDCHAR2="type("-DDCHAR-")"
#Dbgaff
Infbox("Type: "-num$( type(DDCHAR2) ))

#Call MESSAGE("DDCHAR"-DDCHAR) From GESECRAN
#DAT=[24/11/2004]  #DDCHAR
#DAT=DDCHAR
#Call MESSAGE("DAT"-DAT) From GESECRAN

End
# ------------------------------------------------------------
# SUBAPSSTA
# Version 0002
#    Serveur de statistiques
#        U_VIEWCODE        Code de la vue portail
#        [F:APV]           Enreg. en ligne de la table Vue portail (APTLVW)
#        M_ACTION          Code de l'action à traiter soumis par le provider Htc
# ------------------------------------------------------------
$S_EXECUTE                         # Init + type de dialogue
    # Trace
    U_TRAMES="--> Debut: " + "Serveur de statistiques du portail": Gosub U_TRAPUT From SUBAPSUTI 

    # init
    Gosub S_INIT

    # Existence du code statistique
    S_STACOD=[F:APV]SRCCOD
    If clalev([F:PS2])=0 : Local File PARSTA2 [PS2] : Endif
    Call LECTURE(SC_STAOBJ, S_STACOD ,"")From CONTOBJ
    If fstat <> 0
       U_MESCODE="X3STAUNKNOWN" : U_MESP1=S_STACOD : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
    Endif
    # Verif du code d'accès eventuel
    If [F:PS2]ACS<>""
        Raz mkstat
        Call ACCES2([F:PS2]ACS) From OBJDIV 
        If mkstat
           U_MESCODE="X3CODACCNOTAUTHORIZE" : U_MESP1=S_STACOD : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
        Endif
    Endif

    #-- XML
    U_SEQPUT=' <Data>' : Gosub U_PUT From SUBAPSUTI         

    ### Gestion Action titres ou données
    Case M_ACTION
        When SQ_ACTTITLE                                                ## Demande de titres
            U_TRAMES="Titres seuls": Gosub U_TRAPUT From SUBAPSUTI 
            Gosub S_GENETIT From SUBAPSSTAA : If U_ERR=UC_ERRG : Goto ERRXMLCLOSE : Endif
        When SQ_ACTFIRST,  SQ_ACTLOAD, SQ_ACTINIT, SQ_ACTREFRESH                    ## Demande de données
            U_TRAMES="Demande de données initiale.": Gosub U_TRAPUT From SUBAPSUTI 
            Gosub S_GENEINIT From SUBAPSSTAA : If U_ERR=UC_ERRG : Goto ERRXMLCLOSE : Endif
            # données
            Gosub S_GENE From SUBAPSSTAA : If U_ERR=UC_ERRG : Goto ERRXMLCLOSE : Endif
            # Titre
            U_QSCODE=SQ_TITLEOPT : Gosub U_QSREAD_UC From SUBAPSUTI
            If (!U_QSEXIST or (U_QSEXIST and  U_QSVAL<>UC_NO))
                    Gosub S_GENETIT From SUBAPSSTAA : If U_ERR=UC_ERRG : Goto ERRXMLCLOSE : Endif
            Endif      
        When Default
            U_MESCODE="X3ACTUNKNOWN" : U_MESP1=M_ACTION : U_MESP2= [F:APV]SRCCODTYP : U_ERR=UC_ERRG 
            Gosub U_MESPUT From SUBAPSUTI : Goto ERRXMLCLOSE
    Endcase     ### fin gestion Action titres ou données

    $ERRXMLCLOSE    # fermeture XML listes
    #-- XML 
    U_SEQPUT=' </Data>' : Gosub U_PUT From SUBAPSUTI
    # Trace
    U_TRAMES="--> Fin: " + "Serveur statistique du portail": Gosub U_TRAPUT From SUBAPSUTI 

Return

  
# ------------------------------------------------------------
#     G O S U B
# ------------------------------------------------------------
# ------------------------------------------------------------
#  Commun
# ------------------------------------------------------------
# Variables
# - - - - - - - - - - - - - - - - - -
$S_INIT
# Objet X3 Standard Statistique
Local Char SC_STAOBJ : SC_STAOBJ="PS2"                             # Objet X3
Local Char S_STACOD(10)


# Actions
Local Char SQ_ACTTITLE(10) : SQ_ACTTITLE='TITLE'            # Titres seuls
Local Char SQ_ACTLOAD(10)  : SQ_ACTLOAD='LOAD'              # Demande avec niveau et critère
Local Char SQ_ACTFIRST(10) : SQ_ACTFIRST='FIRST'            # Demande initiale
#        Pour compatibilité tableau
Local Char SQ_ACTINIT(10) : SQ_ACTINIT='INIT'                # Ces 2 actions sont équivalentes à first
Local Char SQ_ACTREFRESH(10) : SQ_ACTREFRESH='REFRESH'           


# Option 
Local Char SQ_TITLEOPT(5) : SQ_TITLEOPT='TITLE'               # Option titres (UC_YES ou UC_NO)
Local Char SQ_NIVEAU(6) : SQ_NIVEAU='NIVEAU'                  # niveau demandé 
Local Char SQ_CRIT(6) : SQ_CRIT='CRIT'                      # prefixe critère 

# Divers
Local Integer SC_NBMAXCOL : SC_NBMAXCOL=20    # nb maxi de colonnes du prgrm
Local Integer S_NBCOL                         # nb de colonnes de la requête
#Local Integer S_COLNOMENU (SC_NBMAXCOL)       # Pour des colonnes avec menu: Numéro de menu associé
#Local Integer S_COLCUMUL (SC_NBMAXCOL)        # Pour des colonnes avec cumul: vrai
#Local Integer S_COLGROUP (SC_NBMAXCOL)        # Pour des colonnes groupe: vrai
Local Char    S_COLLINK(3)(SC_NBMAXCOL)        # Pour des colonnes liées à un objet: code objet X3 (ABREV)
#Local Char    S_COLTITLE (20)(1..SC_NBMAXCOL) # Titre

#Paramètres sources de données
Local Char SC_CPY(GLONATY)     : SC_CPY="CPY"    # Société
Local Char SC_FCY(GLONATY)     : SC_FCY="FCY"    # Site
Local Char SC_DATDEB1(7) : SC_DATDEB1="DATDEB1"
Local Char SC_DATFIN1(7) : SC_DATFIN1="DATFIN1"
Local Char SC_DATDEB2(7) : SC_DATDEB2="DATDEB2"
Local Char SC_DATFIN2(7) : SC_DATFIN2="DATFIN2"
Local Char SC_LEVEL(5)   : SC_LEVEL="LEVEL"
Local Char SC_CRIT(5)(1..8)
SC_CRIT(1)="CRIT1" : SC_CRIT(2)="CRIT2" : SC_CRIT(3)="CRIT3" : SC_CRIT(4)="CRIT4"
SC_CRIT(5)="CRIT5" : SC_CRIT(6)="CRIT6" : SC_CRIT(7)="CRIT7" : SC_CRIT(8)="CRIT8"

# Travail
Local Integer SW_I, SW_T1, SW_T2
Local Char SW_URL(100)
Local Char SW_FILTER(100)(1..2)            # filtres
Local Char SW_CTXFOR (150)                 # contexte
Local Char SW_PARCOD(20)                      # code parametre

Local Integer SW_LIG, SW_NEWLIG, SW_LINEOPEN   # ligne de données
Local Integer SW_COL                           # colonne
Local Integer SW_NBREC
Local Char SW_STR1(100), SW_STRINTVAL(200), SW_STRVAL(200)
Local Decimal SW_DEC1
Local Date SW_DATE
Return

#-- Ecriture output avec decalage
$S_SEQPUTDEC
  U_SEQPUT=space$(4)+U_SEQPUT :  Gosub U_PUT From SUBAPSUTI
Return

