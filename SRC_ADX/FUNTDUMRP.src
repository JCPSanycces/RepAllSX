    Else
         WMESS1 =mess(367,197,1)-[M:TMP4]VCRNUM(NOL)-num$([M:TMP4]VCRLIN(NOL))-num$([M:TMP4]VCRSEQ(NOL))
         Call ECR_TRACE(WMESS1,0) From GESECRAN
