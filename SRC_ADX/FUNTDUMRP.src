######################################################################################
Subprog IB_NBLIG
Local Integer WRET
GBOUT1 = ""
GBOUT2 = ""
GBOUT3 = ""
GBOUT4 = ""
GBOUT5 = ""
GBOUT6 = ""
GBOUT7 = ""
GBOUT8 = ""
GBOUT9 = ""

If [M:TMP4]NBLIG = 0 : End : Endif

GBOUT1 = mess(261,198,1)    # plan de travail
Case [M:TMP4]WIPTYP(nolign-1)
    When 2,7 :  If find ([M:TMP4]WIPSTA(nolign-1),1,2)
                    GBOUT2 = mess(332,198,1)             # Gestion D.A./commande
                Endif
                If [M:TMP4]MRPMES(nolign-1)<>6
                    GBOUT8 = mess(464,198,1)         # marquer l'ordre "inutile"
                Endif
    When 5   :  # ordre en attente ou édité
                If find([M:TMP4]MFGTRKFLG(nolign-1),1,3)
                    GBOUT8 = mess(464,198,1)         # marquer l'ordre "inutile"
                Endif
                Case [M:TMP4]WIPSTA(nolign-1)
                    When 1 :
                        GBOUT5 = mess(282,198,1)     # Disponibilité composants
                        GBOUT6 = mess(423,198,1)     # Disponibilité composants à date
                        GBOUT9 = mess(336,198,1)     # Ordre de fabrication
                        Call HAB_ACT([M:TMP4]STOFCY(nolign-1), "J", WRET) From BENCHLIB
                        If WRET  : GBOUT7 = mess(158,198,1): Endif    # jalonnement
                    When 2 :
                        GBOUT5 = mess(282,198,1)     # Disponibilité composants
                        GBOUT6 = mess(423,198,1)     # Disponibilité composants à date
                        GBOUT9 = mess(336,198,1)     # Ordre de fabrication
                Endcase
    When 13   :  # ordre en attente ou édité
                If find([M:TMP4]MFGTRKFLG(nolign-1),1,3)
                    GBOUT8 = mess(464,198,1)         # marquer l'ordre "inutile"
                Endif
                Case [M:TMP4]WIPSTA(nolign-1)
                    When 1 :
                        GBOUT5 = mess(282,198,1)     # Disponibilité composants
                        GBOUT6 = mess(423,198,1)     # Disponibilité composants à date
                        GBOUT9 = mess(473,198,1)     # Ordre de sous-traitance
                        Call HAB_ACT([M:TMP4]STOFCY(nolign-1), "J", WRET) From BENCHLIB
                        If WRET  : GBOUT7 = mess(158,198,1): Endif    # jalonnement
                    When 2 :
                        GBOUT5 = mess(282,198,1)     # Disponibilité composants
                        GBOUT6 = mess(423,198,1)     # Disponibilité composants à date
                        GBOUT9 = mess(473,198,1)     # Ordre de sous-traitance
                Endcase
Endcase
If [M:TMP4]SCSFLG(nolign-1) <> 2
    GBOUT3 = mess(102,198,1)    # interro stock
Endif
GBOUT4 = mess(456,198,1)        # données de gestion

End

######################################################################################
Subprog AS_MRPDAT(VALEUR)
Variable Date    VALEUR

If [M:TMP4]WIPTYP(nolign-1)=5
    # WOS inutile : affichée, mais on ne peut rien saisir
    If [M:TMP4]WIPSTA(nolign-1)=3  : mkstat=2 : Endif
    # WOP saisissable si la situation est en attente
    If [F:MFG]MFGSTA = 2
        If !find([M:TMP4]MFGTRKFLG(nolign-1),1) mkstat = 2  Endif
    Endif
    # WOF saisissable si la situation est en attente ou édité
    If [F:MFG]MFGSTA = 3
        If !find([M:TMP4]MFGTRKFLG(nolign-1),1,3) mkstat = 2  Endif
    Endif
Endif

Case [M:TMP4]WIPTYP(nolign-1)
    When 2  : # POS inutile : affichée, mais on ne peut rien saisir
              If [M:TMP4]WIPSTA(nolign-1)=3  : mkstat=2 : Endif
    When 7  : # TRS inutile : affichée, mais on ne peut rien saisir
              If [M:TMP4]WIPSTA(nolign-1)=3  : mkstat=2 : Endif
    When 13 : # EOS inutile : affichée, mais on ne peut rien saisir
              If [M:TMP4]WIPSTA(nolign-1)=3  : mkstat=2 : Endif
Endcase

End

######################################################################################
Subprog C_MRPDAT(VALEUR)
Variable Date    VALEUR

Read [ORD]ORD0=[M:TMP4]WIPTYP(nolign-1);[M:TMP4]WIPNUM(nolign-1);[M:TMP4]ITMREF(nolign-1)
If !fstat
    If VALEUR <> [M:TMP4]MRPDAT(nolign-1)
        If VALEUR<>[0/0/0] & VALEUR < date$
            GERR=1 : GMESSAGE= mess(239,193,1) : mkstat=2
            If  [F:ORD]MRPDAT<> [0/0/0]
                VALEUR = [F:ORD]MRPDAT
            Else
                VALEUR = date$
            Endif
        Endif

        If VALEUR = [0/0/0]
            VALEUR = [F:ORD]MRPDAT
            If [F:ORD]MRPDAT=[0/0/0]
                Raz [M:TMP4]MRPQTY(nolign-1)
                [M:TMP4]MRPMES(nolign-1)=6
                [M:TMP4]XMRPMES(nolign-1)    = mess([M:TMP4]MRPMES(nolign-1),318,1)
                Call AP_MRPDAT(VALEUR)
            Endif
        Endif
    Endif
Endif
End

######################################################################################
Subprog AP_MRPDAT(VALEUR)
Variable Date    VALEUR
zonsui = [M:TMP4]XMRPMES(nolign-1)
Affzo [M:TMP4]XMRPMES(nolign-1),MRPQTY(nolign-1)
End

######################################################################################
Subprog AS_MRPQTY(VALEUR)
Variable Decimal VALEUR
If [M:TMP4]WIPTYP(nolign-1)=5
    # WOS inutiles : affichée, mais on ne peut rien saisir
    If [M:TMP4]WIPSTA(nolign-1)=3  : mkstat=2 : Endif
    # WOP saisissable si la situation est en attente
    If [F:MFG]MFGSTA = 2
        If !find([M:TMP4]MFGTRKFLG(nolign-1),1) mkstat = 2  Endif
    Endif
    # WOF saisissable si la situation est en attente ou édité
    If [F:MFG]MFGSTA = 3
        If !find([M:TMP4]MFGTRKFLG(nolign-1),1,3) mkstat = 2  Endif
    Endif
Endif

Case [M:TMP4]WIPTYP(nolign-1)
    When 2  : # POS inutile : affichée, mais on ne peut rien saisir
              If [M:TMP4]WIPSTA(nolign-1)=3  : mkstat=2 : Endif
    When 7  : # TRS inutile : affichée, mais on ne peut rien saisir
              If [M:TMP4]WIPSTA(nolign-1)=3  : mkstat=2 : Endif
    When 13 : # EOS inutile : affichée, mais on ne peut rien saisir
              If [M:TMP4]WIPSTA(nolign-1)=3  : mkstat=2 : Endif
Endcase
End

######################################################################################
Subprog C_MRPQTY(VALEUR)
Variable Decimal VALEUR

If [M:TMP4]MRPMES(nolign-1) = 6 # inutile
    VALEUR  = 0
Else
    If VALEUR = 0
        Read [ORD]ORD0=[M:TMP4]WIPTYP(nolign-1);[M:TMP4]WIPNUM(nolign-1);[M:TMP4]ITMREF(nolign-1)
        If !fstat
            If [F:ORD]MRPQTY <>0
                VALEUR = [F:ORD]MRPQTY
            Else
                VALEUR = [F:ORD]RMNEXTQTY
            Endif
        Endif
    Endif
Endif


End
######################################################################################
Subprog AM_MRPDAT(VALEUR)
Variable Date    VALEUR

# Cas des ordres dont le message MRP= "inutile"
If  [M:TMP4]MRPMES(nolign-1)= 6
    If VALEUR <>[0/0/0]
        [M:TMP4]MRPQTY(nolign-1) = [M:TMP4]RMNEXTQTY(nolign-1)
    Else
        End
    Endif
Endif


If [M:TMP4]ENDDAT(nolign-1)< date$    # on est dans le passé
    If [M:TMP4]RMNEXTQTY(nolign-1) =  [M:TMP4]MRPQTY(nolign-1)
        # pas de message
        [M:TMP4]MRPMES(nolign-1) =1                                             # ----- pas de message
    Else
        # Augmenter ou diminuer la quantité
        If [M:TMP4]RMNEXTQTY(nolign-1) <  [M:TMP4]MRPQTY(nolign-1)
           [M:TMP4]MRPMES(nolign-1) = 4                                         # ----- augmenter
        Else
           [M:TMP4]MRPMES(nolign-1) = 5                                         # ----- diminuer
        Endif
    Endif
Else    # on est dans le présent
    If [M:TMP4]ENDDAT(nolign-1) = VALEUR
        If [M:TMP4]RMNEXTQTY(nolign-1) =  [M:TMP4]MRPQTY(nolign-1)
            # pas de message
            [M:TMP4]MRPMES(nolign-1) =1                                         # ----- pas de message
        Else
            # Augmenter ou diminuer la quantité
            If [M:TMP4]RMNEXTQTY(nolign-1) <  [M:TMP4]MRPQTY(nolign-1)
               [M:TMP4]MRPMES(nolign-1) = 4                                     # ----- augmenter
            Else
               [M:TMP4]MRPMES(nolign-1) = 5                                     # ----- diminuer
            Endif
        Endif
    Elsif [M:TMP4]ENDDAT(nolign-1)> VALEUR
        # avancer
        If [M:TMP4]RMNEXTQTY(nolign-1) =  [M:TMP4]MRPQTY(nolign-1)
            [M:TMP4]MRPMES(nolign-1) = 2                                         # ----- avancer
        Elsif [M:TMP4]RMNEXTQTY(nolign-1) <  [M:TMP4]MRPQTY(nolign-1)
            [M:TMP4]MRPMES(nolign-1) = 7                                         # ----- avancer/augmenter
        Else
            [M:TMP4]MRPMES(nolign-1) = 8                                         # ----- avancer/ diminuer
        Endif
    Else
        # retarder
        If [M:TMP4]RMNEXTQTY(nolign-1) =  [M:TMP4]MRPQTY(nolign-1)
            [M:TMP4]MRPMES(nolign-1) = 3                                         # ----- retarder
        Elsif [M:TMP4]RMNEXTQTY(nolign-1) <  [M:TMP4]MRPQTY(nolign-1)
            [M:TMP4]MRPMES(nolign-1) = 9                                         # ----- retarder/augmenter
        Else
            [M:TMP4]MRPMES(nolign-1) = 10                                        # ----- retarder/ diminuer
        Endif
    Endif
Endif

[M:TMP4]XMRPMES(nolign-1)    = mess([M:TMP4]MRPMES(nolign-1),318,1)
Affzo [M:TMP4]XMRPMES(nolign-1)

End


######################################################################################
Subprog AM_MRPQTY(VALEUR)
Variable Decimal VALEUR


If [M:TMP4]ENDDAT(nolign-1)< date$    # on est dans le passé
    If [M:TMP4]RMNEXTQTY(nolign-1) =  VALEUR
        # pas de message
        [M:TMP4]MRPMES(nolign-1) =1                                             # ----- pas de message
    Else
        # Augmenter ou diminuer la quantité
        If [M:TMP4]RMNEXTQTY(nolign-1) < VALEUR
           [M:TMP4]MRPMES(nolign-1) = 4                                         # ----- augmenter
        Else
           [M:TMP4]MRPMES(nolign-1) = 5                                         # ----- diminuer
        Endif
    Endif
Else    # on est dans le présent
    If [M:TMP4]ENDDAT(nolign-1) = [M:TMP4]MRPDAT(nolign-1)
        If [M:TMP4]RMNEXTQTY(nolign-1) =  VALEUR
            # pas de message
            [M:TMP4]MRPMES(nolign-1) =1                                         # ----- pas de message
        Else
            # Augmenter ou diminuer la quantité
            If [M:TMP4]RMNEXTQTY(nolign-1) <  VALEUR
               [M:TMP4]MRPMES(nolign-1) = 4                                     # ----- augmenter
            Else
               [M:TMP4]MRPMES(nolign-1) = 5                                     # ----- diminuer
            Endif
        Endif
    Elsif [M:TMP4]ENDDAT(nolign-1)>  [M:TMP4]MRPDAT(nolign-1)
        # avancer
        If [M:TMP4]RMNEXTQTY(nolign-1) =  VALEUR
            [M:TMP4]MRPMES(nolign-1) = 2                                         # ----- avancer
        Elsif [M:TMP4]RMNEXTQTY(nolign-1) < VALEUR
            [M:TMP4]MRPMES(nolign-1) = 7                                         # ----- avancer/augmenter
        Else
            [M:TMP4]MRPMES(nolign-1) = 8                                         # ----- avancer/ diminuer
        Endif
    Else
        # retarder
        If [M:TMP4]RMNEXTQTY(nolign-1) =  VALEUR
            [M:TMP4]MRPMES(nolign-1) = 3                                         # ----- retarder
        Elsif [M:TMP4]RMNEXTQTY(nolign-1) <  VALEUR
            [M:TMP4]MRPMES(nolign-1) = 9                                         # ----- retarder/augmenter
        Else
            [M:TMP4]MRPMES(nolign-1) = 10                                        # ----- retarder/ diminuer
        Endif
    Endif
Endif

[M:TMP4]XMRPMES(nolign-1)    = mess([M:TMP4]MRPMES(nolign-1),318,1)
Affzo [M:TMP4]XMRPMES(nolign-1)

End


######################################################################################
Subprog B8_NBLIG
If [M:TMP4]MRPMES(nolign-1)<>6
    [M:TMP4]MRPMES(nolign-1)  = 6
    [M:TMP4]XMRPMES(nolign-1) = mess(6,318,1)
    [M:TMP4]MRPQTY(nolign-1)  = 0
    [M:TMP4]MRPDAT(nolign-1)  = [0/0/0]
Affzo [M:TMP4]XMRPMES(nolign-1),MRPQTY(nolign-1),MRPDAT(nolign-1)
Endif
End

