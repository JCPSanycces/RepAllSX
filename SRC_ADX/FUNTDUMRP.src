$LOAD_CRITERE

If len(XCRITERE)+len(XCRITERE1)+1 < 250
  If XCRITERE1 <> ""
      XCRITERE1 += "|"
  Endif
  XCRITERE1 += XCRITERE
Else
  If XCRITERE2 <> ""
     XCRITERE2 += "|"
  Endif
  XCRITERE2 += XCRITERE
Endif

Return
