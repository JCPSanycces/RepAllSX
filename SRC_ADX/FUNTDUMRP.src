        #---- Message : Ligne commande XXXXXXXXXXXXXXX 9999999 9999999 supprimée ! ----#
        WMESS =[M:TMP4]VCRNUM(NOL)-num$([M:TMP4]VCRLIN(NOL))-num$([M:TMP4]VCRSEQ(NOL))
        WMESS1=mess(367,197,1)-WMESS-mess(170,197,1)
        Call ECR_TRACE(WMESS1,0) From GESECRAN
    Endif
    NBMRP += 1
Else
    If [M:TMP4]POHNUM(NOL) <> ""
         WMESS1 =mess(244,197,1)-[M:TMP4]VCRNUM(NOL)-num$([M:TMP4]VCRLIN(NOL))-num$([M:TMP4]VCRSEQ(NOL))
