########################################################################
$SUPPOS

Raz [M:MFGK]
[M:MFGK]CODMAJ = "A"
[M:MFGK]CODTRS = 2
[M:MFGK]MFGNUM = [M:TMP4]VCRNUM(NOL)
[M:MFGK]MFGFCY = [M:TMP4]STOFCY(NOL)
[M:MFGK]MFGSTA = [M:TMP4]WIPSTA(NOL)
[M:MFGK]ITMREF = [M:TMP4]ITMREF(NOL)
[M:MFGK]WIPTYP = [M:TMP4]WIPTYP(NOL)
Call MAJ_OF From MFGAUTLIB
If [M:MFGK]CODRET = 0
    WMESS1 = mess(236,197,1)-[M:MFGK]MFGNUM-mess(234,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    NBMRP += 1
Else
    WMESS1 =mess(236,197,1)-[M:MFGK]MFGNUM-mess(27,133,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN      # Transaction interrompue
    GOK = 0
Endif

Return

########################################################################
Subprog CHARGE_WRCPDAT (WRCPDAT, STRRCPDAT, EXTRCPDAT, WEE, YEA)
Variable Char       WRCPDAT
Variable Date       STRRCPDAT
Const    Date       EXTRCPDAT
Value    Shortint   WEE
Value    Shortint   YEA
Local    Shortint   WJOUR ,WMOIS ,WANNEE
Local    Char       WDATE(10)
# chargement zone wrcpdat
WANNEE = val(left$(EXTRCPDAT,4))
WMOIS  = val(mid$(EXTRCPDAT,5,2))
WJOUR  = val(right$(EXTRCPDAT,7))

If [M]CAD = 1           : # cadencement jour
    Gosub DAT8 From BENCHLIBP
    WRCPDAT        = WDATE
    STRRCPDAT      = EXTRCPDAT
Elsif [M]CAD = 3        : # cadencement mois
    STRRCPDAT  = aweek(WEE,YEA)
    Local Char WWMOIS
    If len(num$(WMOIS))= 1
        WWMOIS = "0"+num$(WMOIS)
    Else  WWMOIS = num$(WMOIS)
    Endif
    WDATE= format$("K:2#[-]4#",WWMOIS+num$(WANNEE))
    WRCPDAT = WDATE
Else                    : # cadencement semaine
    STRRCPDAT = aweek(WEE,YEA)
    Local Char WSEM
    If len(num$(WEE))= 1
          WSEM = "00"+num$(WEE)
    Elsif len(num$(WEE))= 2
          WSEM = "0"+num$(WEE)
    Else  WSEM = num$(WEE)
    Endif
    WDATE= format$("K:3#[-]4#",WSEM+num$(YEA))
    WRCPDAT = WDATE
Endif

End

########################################################################
$MODWOX
Local Integer  WALT

# recherche alternatives utilisées
Read [SCH]SCH0 = [F:ORD]VCRNUM
If !fstat
    [M:TMP4]ROUNUM(NOL) = [F:SCH]ROUNUM
    [M:TMP4]ROUALT(NOL) = [F:SCH]ROUALT
Endif


Read [MFI]MFI0 = [F:ORD]VCRNUM;[F:ORD]VCRLIN
If !fstat
    If find([F:ORD]WIPSTA,1,2) [M:TMP4]LOT(NOL) = [F:MFI]LOT Endif
Else
    # Lot obligatoire non renseigné
    WMESS1 = mess(69,151,1)-[M:TMP4]VCRNUM(NOL)-":"-mess(141,184,1) -":"-mess(1,455,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    Return
Endif

WENDDAT = [M:TMP4]ENDDAT(NOL)
If  [M:TMP4]MRPDAT(NOL) <> [0/0/0]
    [M:TMP4]ENDDAT(NOL)  = [M:TMP4]MRPDAT(NOL)
    Call CAL_DATDEB([M:TMP4]STOFCY(NOL), [M:TMP4]ENDDAT(NOL),
&       [M:TMP4]EXTQTY(NOL),[M:TMP4]STRDAT(NOL))From BENCHLIB
Endif
If [M:TMP4]MRPQTY(NOL)<>0 : [M:TMP4]EXTQTY(NOL) = [M:TMP4]MRPQTY(NOL) : Endif

# contrôle nomenclature
If find([M:TMP4]WIPSTA(NOL),1,2) & find([F:MFG]MFGMOD,1,2)
    WALT = [M:TMP4]BOMALT(NOL)
    Call CONT_BOMALT([M:TMP4]STOFCY(NOL), WALT,2,
&                    [M:TMP4]ITMREF(NOL), [M:TMP4]STRDAT(NOL))
&   From BENCHLIB
    If GMESSAGE <> ""
        WMESS1= mess(156,197,1)-[M:TMP4]VCRNUM(NOL)-":"-GMESSAGE
        Call ECR_TRACE(WMESS1,0) From GESECRAN : Return
    Endif
Endif

# contrôle gamme
If find([M:TMP4]WIPSTA(NOL),1,2) & find([F:MFG]MFGMOD,1,3)
    WALT = [M:TMP4]ROUALT(NOL)
    Call CONT_ROUALT([M:TMP4]STOFCY(NOL), WALT,
&                    [M:TMP4]ROUNUM(NOL), [M:TMP4]STRDAT(NOL),
&                    [M:TMP4]EXTQTY(NOL), [M:TMP4]STU(NOL),
&                    [M:TMP4]BOMALT(NOL))
&   From BENCHLIB
    If GMESSAGE <> ""
        WMESS1= mess(156,197,1)-[M:TMP4]VCRNUM(NOL)-":"-GMESSAGE
        Call ECR_TRACE(WMESS1,0) From GESECRAN : Return
    Endif
Endif

Call DEBTRANS From GLOCK
Trbegin [ORD]
Raz [M:MFGK]
[M:MFGK]CODMAJ = "M"
[M:MFGK]CODTRS = 0
[M:MFGK]CALCST  = 1                     # GH 09/04/2014 bug 99047
[M:MFGK]MFGNUM = [M:TMP4]VCRNUM(NOL)
[M:MFGK]MFGLIN = [M:TMP4]VCRLIN(NOL)
[M:MFGK]MFGFCY = [M:TMP4]STOFCY(NOL)
[M:MFGK]MFGSTA = [M:TMP4]WIPSTA(NOL)
[M:MFGK]ITMREF = [M:TMP4]ITMREF(NOL)
[M:MFGK]PRVQTY = [M:TMP4]EXTQTY1(NOL)
[M:MFGK]EXTQTY = [M:TMP4]EXTQTY(NOL)
[M:MFGK]STRDAT = [M:TMP4]STRDAT(NOL)
[M:MFGK]ENDDAT = [M:TMP4]ENDDAT(NOL)
[M:MFGK]BOMALT = [M:TMP4]BOMALT(NOL)
[M:MFGK]ROUNUM = [M:TMP4]ROUNUM(NOL)
[M:MFGK]ROUALT = [M:TMP4]ROUALT(NOL)
[M:MFGK]PJT    = [M:TMP4]PJT(NOL)
If dim([M:TMP4]MFGDES)>0
 [M:MFGK]MFGDES = [M:TMP4]MFGDES(NOL)    # GH 09/01/12 bug 78926
Endif
[M:MFGK]LOT    = [M:TMP4]LOT(NOL)
[M:MFGK]OBJDAT = [M:TMP4]OBJDAT(NOL)
Call MAJ_OF From MFGAUTLIB
If [M:MFGK]CODRET = 0
    Case [M:MFGK]MFGSTA
            When 1:        WMESS1 = mess(231,197,1)-[M:MFGK]MFGNUM-mess(232,197,1)
            When 2:        WMESS1 = mess(230,197,1)-[M:MFGK]MFGNUM-mess(232,197,1)
    Endcase
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    # Un composant fantôme est présent. Une intervention manuelle est nécessaire.
    If GVISUGHOST
        Call ECR_TRACE(mess(214,190,1),0) From GESECRAN
    Endif
    # xxx : Attention, des matières liées à cet article ont été cumulées et
    # devront faire l'objet d'un ajustement manuel...
    If GCUMFLG = 2 & [M:MFGK]AUTOTRT <> 2 & !GIMPORT & [M:MFGK]SYNCHRO <> 2
        WMESS1 = [M:MFGK]ITMREF -":"-mess(55,190,1)
        Call ECR_TRACE(WMESS1,0) From GESECRAN
    Endif
    Gosub MORE_DET
    NBMRP += 1
Elsif [M:MFGK]CODRET=1
    Case [M:MFGK]MFGSTA
        When 1 :     WMESS1 = mess(231,197,1)-[M:MFGK]MFGNUM-mess(27,133,1)
        When 2 :     WMESS1 = mess(230,197,1)-[M:MFGK]MFGNUM-mess(27,133,1)
    Endcase
    Call ECR_TRACE(WMESS1,1) From GESECRAN      # Transaction interrompue
    GOK = 0
Endif
Commit

Return

##########################################################################
$SUPWOX

Call DEBTRANS From GLOCK
Trbegin [ORD]
Raz [M:MFGK]

[M:MFGK]CODMAJ = "A"
[M:MFGK]CODTRS = 0
[M:MFGK]MFGNUM = [M:TMP4]VCRNUM(NOL)
[M:MFGK]MFGFCY = [M:TMP4]STOFCY(NOL)
[M:MFGK]MFGSTA = [M:TMP4]WIPSTA(NOL)
[M:MFGK]MFGLIN = [M:TMP4]VCRLIN(NOL)
Call MAJ_OF From MFGAUTLIB
If [M:MFGK]CODRET = 0
    Case [M:MFGK]MFGSTA
        When 1 : WMESS1 = mess(231,197,1)-[M:MFGK]MFGNUM-mess(234,197,1)
        When 2 : WMESS1 = mess(230,197,1)-[M:MFGK]MFGNUM-mess(234,197,1)
        When 3 : WMESS1 = mess(235,197,1)-[M:MFGK]MFGNUM-mess(234,197,1)
    Endcase
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    NBMRP += 1
Elsif [M:MFGK]CODRET=1
    Case [M:MFGK]MFGSTA
        When 1 : WMESS1 = mess(231,197,1)-[M:MFGK]MFGNUM-mess(27,133,1)
        When 2 : WMESS1 = mess(230,197,1)-[M:MFGK]MFGNUM-mess(27,133,1)
        When 3 : WMESS1 = mess(235,197,1)-[M:MFGK]MFGNUM-mess(27,133,1)
    Endcase
    Call ECR_TRACE(WMESS1,1) From GESECRAN      # Transaction interrompue
    GOK = 0
Endif
Commit

Return

########################################################################
$MODEOX
Local Integer  WALT

Read [SCI]SCI0 = [F:ORD]VCRNUM;[F:ORD]VCRLIN
If !fstat
    If find([F:ORD]WIPSTA,1,2) [M:TMP4]LOT(NOL) = [F:SCI]LOT Endif
Else
    # Lot obligatoire non renseigné
    WMESS1 = mess(69,151,1)-[M:TMP4]VCRNUM(NOL)-":"-mess(141,184,1) -":"-mess(1,455,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    Return
Endif

WENDDAT = [M:TMP4]ENDDAT(NOL)
If  [M:TMP4]MRPDAT(NOL) <> [0/0/0]
    [M:TMP4]ENDDAT(NOL)  = [M:TMP4]MRPDAT(NOL)
    Call CAL_DATDEB([M:TMP4]STOFCY(NOL), [M:TMP4]ENDDAT(NOL),
&       [M:TMP4]EXTQTY(NOL),[M:TMP4]STRDAT(NOL))From BENCHLIB
Endif
If [M:TMP4]MRPQTY(NOL)<>0 : [M:TMP4]EXTQTY(NOL) = [M:TMP4]MRPQTY(NOL) : Endif

# contrôle nomenclature
### FQ 65591 ctrl des sources: variable inexistante & find([F:SCO]SCOMOD,1,2)
If find([M:TMP4]WIPSTA(NOL),1,2)
    WALT = [M:TMP4]BOMALT(NOL)
    Call CONT_BOMALT([M:TMP4]STOFCY(NOL), WALT, 3,
&                    [M:TMP4]ITMREF(NOL), [M:TMP4]STRDAT(NOL))
&   From BENCHLIB
    If GMESSAGE <> ""
        WMESS1= mess(156,197,1)-[M:TMP4]VCRNUM(NOL)-":"-GMESSAGE
        Call ECR_TRACE(WMESS1,0) From GESECRAN : Return
    Endif
Endif

Call DEBTRANS From GLOCK
Trbegin [ORD]
Raz [M:SCOK]
[M:SCOK]CODMAJ = "M"
[M:SCOK]CODTRS = 0
[M:SCOK]SCONUM = [M:TMP4]VCRNUM(NOL)
[M:SCOK]SCILIN = [M:TMP4]VCRLIN(NOL)
[M:SCOK]POHFCY = [M:TMP4]STOFCY(NOL)
[M:SCOK]SCOSTA = [M:TMP4]WIPSTA(NOL)
[M:SCOK]ITMREF = [M:TMP4]ITMREF(NOL)
[M:SCOK]PRVQTY = [M:TMP4]EXTQTY1(NOL)
[M:SCOK]EXTQTY = [M:TMP4]EXTQTY(NOL)
[M:SCOK]STRDAT = [M:TMP4]STRDAT(NOL)
[M:SCOK]ENDDAT = [M:TMP4]ENDDAT(NOL)
[M:SCOK]BOMALT = [M:TMP4]BOMALT(NOL)
#[M:SCOK]ROUNUM = [M:TMP4]ROUNUM(NOL) # FGR 14/01/2010 : X3SUIVI60986
#[M:SCOK]ROUALT = [M:TMP4]ROUALT(NOL) # FGR 14/01/2010 : X3SUIVI60986
[M:SCOK]PJT    = [M:TMP4]PJT(NOL)
If dim([M:TMP4]MFGDES)>0
 [M:SCOK]SCODES    = [M:TMP4]MFGDES(NOL)    : # GH 09/01/12 bug 78926
Endif
[M:SCOK]LOT    = [M:TMP4]LOT(NOL)
[M:SCOK]OBJDAT = [M:TMP4]OBJDAT(NOL)
Call MAJ_SCO From SCOAUTLIB      # FGR 13/01/2010 : X3SUIVI60986 avant MAJ_EO
If [M:SCOK]CODRET = 0
    WMESS1 = mess(473,198,1)-mess([M:SCOK]SCOSTA,317,1)-[M:SCOK]SCONUM-mess(232,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    Gosub MORE_DET
    NBMRP += 1
Elsif [M:SCOK]CODRET=1
    WMESS1 = mess(473,198,1)-mess([M:SCOK]SCOSTA,317,1)-[M:SCOK]SCONUM-mess(27,133,1)
    Call ECR_TRACE(WMESS1,1) From GESECRAN      # Transaction interrompue
    GOK = 0
Endif
Commit

Return

##########################################################################
$SUPEOX

Call DEBTRANS From GLOCK
Trbegin [ORD]
Raz [M:SCOK]

[M:SCOK]CODMAJ = "A"
[M:SCOK]CODTRS = 0
[M:SCOK]SCONUM = [M:TMP4]VCRNUM(NOL)
[M:SCOK]POHFCY = [M:TMP4]STOFCY(NOL)
[M:SCOK]SCOSTA = [M:TMP4]WIPSTA(NOL)
[M:SCOK]SCILIN = [M:TMP4]VCRLIN(NOL)
Call MAJ_SCO From SCOAUTLIB       # FGR 13/01/2010 : X3SUIVI60986 avant MAJ_EO
If [M:SCOK]CODRET = 0
    WMESS1 = mess(473,198,1)-mess([M:SCOK]SCOSTA,317,1)-[M:SCOK]SCONUM-mess(234,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    NBMRP += 1
Elsif [M:SCOK]CODRET=1
    WMESS1 = mess(473,198,1)-mess([M:SCOK]SCOSTA,317,1)-[M:SCOK]SCONUM-mess(27,133,1)
    Call ECR_TRACE(WMESS1,1) From GESECRAN      # Transaction interrompue
    GOK = 0
Endif
Commit

Return

##########################################################################
# FGR 13/01/2010 : X3SUIVI60986
#Subprog MORE_DET
$MORE_DET
# ancienne qté / nouvelle quantité
WMESS1 = mess(153,184,1)-":"-num$([M:TMP4]RMNEXTQTY(NOL))-[M:TMP4]STU(NOL)-"/"-
&        mess(220,190,1)-mess(33,105,1)-":"-num$([M:TMP4]MRPQTY(NOL))-[M:TMP4]STU(NOL)
Call ECR_TRACE(WMESS1,0) From GESECRAN

# ancienne date / nouvelle date
WMESS1 = mess(219,190,1)-mess(88,100,1)-":"-format$("D:", WENDDAT)-"/"-
&        mess(220,190,1)-mess(88,100,1)-":"-format$("D:",[M:TMP4]MRPDAT(NOL))
Call ECR_TRACE(WMESS1,0) From GESECRAN

Return
