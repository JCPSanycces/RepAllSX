#<AdxTL>@(#)5.0.0.0 $Revision$
#################################################################################
#                                                                               #
#    MODELISATION E-COMMERCE                                                    #
#                                                                               #
# ACTION  : SAITDUMRP  : Action traitement replanification en série             #
#                                                                               #
#################################################################################
# Etiquettes ACTION                                                             #
#################################################################################

########################################################################
#    Détail des actions                                                #
########################################################################
$ACTION
# actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"        : Case GACTION
                           When "SAITDUMRP" : Gosub OUVRE
                       Endcase
 When "DEBUT"        : Case GACTION
                           When "SAITDUMRP" : Gosub S_DEBUT
                       Endcase
 When "ENR"          : Gosub ENREGISTRE
 When "ABA"          : Gosub ABORT
 When "SETBOUT"      : Case GACTION
                           When "TRTTDUMRP" : Gosub SETBOUT
                       Endcase
 When "FIN"          : Gosub FIN
 When Default
Endcase

# actions liées au traitement standard
Case ACTION
 When "DEBUT"      : Case GACTION
                           When "TRTTDUMRP" : Gosub DEBUT
                     Endcase
 When "EDI"       : Case GACTION
                           When "TRTTDUMRP" : Gosub EDITION
                     Endcase
 When "TERMINE"    : Case GACTION
                           When "TRTTDUMRP" : Gosub TERMINE
                     Endcase
 When Default
Endcase

Return

#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################
#########################################################################
$OUVRE
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER   [ITM] : Endif
If clalev ([F:ORD]) <= 0 : Local File ORDERS      [ORD] : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT  [ITF] : Endif
If clalev ([F:TRP]) <= 0 : Local File TABREOPOL   [TRP] : Endif
If clalev ([F:PCB]) <= 0 : Local File PARMRP      [PCB] : Endif
If clalev ([F:PSD]) <= 0 : Local File PREQUISD    [PSD] : Endif
If clalev ([F:SOH]) <= 0 : Local File SORDER      [SOH] : Endif
If clalev ([F:SOP]) <= 0 : Local File SORDERP     [SOP] : Endif
If clalev ([F:SOQ]) <= 0 : Local File SORDERQ     [SOQ] : Endif
If clalev ([F:SCH]) <= 0 : Local File SCHEDULING  [SCH] : Endif
If clalev ([F:ITP]) <= 0 : Local File ITMBPS      [ITP] : Endif
If clalev ([F:TBO]) <= 0 : Local File TABBOMALT   [TBO] : Endif
If clalev ([F:BOH]) <= 0 : Local File BOM         [BOH] : Endif
If clalev ([F:BPR]) <= 0 : Local File BPARTNER    [BPR] : Endif
If clalev ([F:TFO]) <= 0 : Local File TABFOR      [TFO] : Endif : # GH 30/07/2014 bug 101806

If clalev ([M:ORDK]) <=0 : Local Mask ORDK        [ORDK]: Endif

If GMODU(8)=2
   If clalev ([M:MFGK]) <=0 : Local Mask MFGK        [MFGK]: Endif
   If clalev ([F:MFG]) <= 0 : Local File MFGHEAD     [MFG] : Endif
   If clalev ([F:MFM]) <= 0 : Local File MFGMAT      [MFM] : Endif
   If clalev ([F:MFI]) <= 0 : Local File MFGITM      [MFI] : Endif
   If clalev ([F:TRO]) <= 0 : Local File TABROUALT   [TRO] : Endif
   If clalev ([F:ROH]) <= 0 : Local File ROUTING     [ROH] : Endif
Endif

If GMODU(6)=2
   If clalev ([M:PMG]) <= 0 : Local Mask PURMGT      [PMG] : Endif
   If clalev ([F:POP]) <= 0 : Local File PORDERP     [POP] : Endif
   If clalev ([F:POH]) <= 0 : Local File PORDER      [POH] : Endif
   If clalev ([F:POQ]) <= 0 : Local File PORDERQ     [POQ] : Endif

   If clalev ([M:SCOK]) <=0 : Local Mask SCOK        [SCOK]: Endif
   If clalev ([F:SCO]) <= 0 : Local File SCOHEAD     [SCO] : Endif
   If clalev ([F:SCM]) <= 0 : Local File SCOMAT      [SCM] : Endif
   If clalev ([F:SCI]) <= 0 : Local File SCOITM      [SCI] : Endif
Endif

# Pour éviter que la trace ne soit fermée par TRTACHPOH1
If clalev ([M:MGP])  <=0 : Local Mask MFGPICK     [MGP] : Endif
If clalev ([M:MUX1]) <=0 : Local Mask MULTIWOX1   [MUX1]: Endif
#

Local Integer  I
Local Char     TIT(50) : TIT = mess(243,195,1)
Local Integer  NBMRP
Local Char     WMESS(80), WMESS1(80)
Local Date     WENDDAT
Global Integer GCUMFLG  : GCUMFLG =0   # En cas de cumul matière
Global Integer GVISUGHOST  : GVISUGHOST  =0   # En cas de matière fantôme

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub CHARG_PARAM

Return

#########################################################################
$S_DEBUT
Raz [M:TMP1]
Raz [M:TMP2]
Raz [M:TMP3]

[M:TMP1]STOFCY = GFCY
[M:TMP3]FLGWOS =2

Affzo [M:TMP1]1-99
Affzo [M:TMP2]1-99
Affzo [M:TMP3]1-99

Return
#########################################################################
$DEBUT
Default File [ORD]
Default Mask [M:TMP4]
[M:TMP4]FCY        = [M:TMP1]STOFCY
Gosub LIRE
Return

#########################################################################
$SETBOUT
Raz ETABOU
ETABOU(GENRE) = 1
ETABOU(GABAN) = 1
ETABOU(GBFIN) = 1
ETABOU(GEDIT) = 1

Return

#########################################################################
$LIRE
Local Char    XCRITERE(255)
Local Char    XCRITERE1(255)
Local Char    XCRITERE2(255)
Local Char    XCRITERE3(255)

Local Char    XCRITERE11(255)
Local Char    XCRITERE12(255)
Local Char    XCRITERE13(255)
Local Char    XCRITERE14(255)
Local Char    XCRITERE15(255)
Local Integer WMAX
Local Char    FORMULE1(255)

WMAX = dim([M:TMP4]WIPTYP)     # mémorisation nombre de ligne maxi

Dela 0,[M:TMP4]NBLIG+1,[M:TMP4]NBLIG [M:TMP4]NBLIG
Gosub LOAD_FILTER
Gosub LOAD_FILTER2

# analyse présence formule de sélection
If [M:TMP2]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [TFO]TFO0=10;[M:TMP2]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

If XCRITERE1  = "" : XCRITERE1  = "1=2" : Endif
If XCRITERE2  = "" : XCRITERE2  = "1=2" : Endif
If XCRITERE3  = "" : XCRITERE3  = "1=2" : Endif
If XCRITERE11 = "" : XCRITERE11 = "1=1" : Endif
If XCRITERE12 = "" : XCRITERE12 = "1=1" : Endif
If XCRITERE13 = "" : XCRITERE13 = "1=1" : Endif
If XCRITERE14 = "" : XCRITERE14 = "1=1" : Endif
If XCRITERE15 = "" : XCRITERE15 = "1=1" : Endif


Link [ORD] With [ITF]ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY, [ITM]ITM0=[F:ORD]ITMREF As [ORDX]
&          Where (evalue(XCRITERE1)|evalue(XCRITERE2)|evalue(XCRITERE3))&
&                 evalue(XCRITERE11)&evalue(XCRITERE12)&evalue(XCRITERE13)&evalue(XCRITERE14)&
&                 evalue(XCRITERE15)&evalue(FORMULE1)

nolign=1
For [ORDX]
    If nolign = WMAX  : Break : Endif

    If find ([F:ORD]WIPSTA,1,2)
        Case [F:ORD]MRPMES
            When 2 : If [M:TMP3]FLGBEF    <>2 : Goto NXT1 : Endif
            When 3 : If [M:TMP3]FLGLAT    <>2 : Goto NXT1 : Endif
            When 4 : If [M:TMP3]FLGUP     <>2 : Goto NXT1 : Endif
            When 5 : If [M:TMP3]FLGDOW    <>2 : Goto NXT1 : Endif
            When 6 : If [M:TMP3]FLGNOTUSE <>2 : Goto NXT1 : Endif
            When 7 : If [M:TMP3]FLGA_A    <>2 : Goto NXT1 : Endif
            When 8 : If [M:TMP3]FLGA_D    <>2 : Goto NXT1 : Endif
            When 9 : If [M:TMP3]FLGR_A    <>2 : Goto NXT1 : Endif
            When 10: If [M:TMP3]FLGR_D    <>2 : Goto NXT1 : Endif
        Endcase
    Endif

    Case WIPTYP
        When 2 : If [F:ORD]WIPSTA = 3     # POS
                     If [M:TMP3]FLGPOS <> 2  : Goto NXT1 : Endif
                 Endif
        When 5 : If [F:ORD]WIPSTA = 3     # WOS
                     If [M:TMP3]FLGWOS <> 2  : Goto NXT1 : Endif
                 Endif
        When 7 : If [F:ORD]WIPSTA = 3     # TRS
                     If [M:TMP3]FLGTRS <> 2  : Goto NXT1 : Endif
                 Endif
        When 13: If [F:ORD]WIPSTA = 3     # EOS
                     If [M:TMP3]FLGEOS <> 2  : Goto NXT1 : Endif
                 Endif
    Endcase


    [M:TMP4] = [F:ORD]
    [M:TMP4]EXTQTY1(nolign-1)    = [F:ORD]EXTQTY
    [M:TMP4]WIPTYPSTA(nolign-1)  = mess([F:ORD]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)
    [M:TMP4]PLANNER2(nolign-1)   = [F:ITF]PLANNER
    [M:TMP4]BUY(nolign-1)        = [F:ITF]BUY
    If [F:ITM]ITMREF <> [F:ORD]ITMREF : Read [ITM]ITM0=[F:ORD]ITMREF : Endif
    If dim([M:TMP4]ITMDES1(nolign-1)) > 0
        #[M:TMP4]ITMDES1(nolign-1) = [F:ITM]ITMDES1
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:TMP4]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Endif

    If [M:TMP4]MRPMES(nolign-1)  = 6
        [M:TMP4]MRPQTY(nolign-1)  = 0
    Endif

    [M:TMP4]XMRPMES(nolign-1)    = mess([M:TMP4]MRPMES(nolign-1),318,1)
    If dim([M:TMP4]ITMDES1(nolign-1)) > 0
        #[M:TMP4]ITMDES1(nolign-1) = [F:ITM]ITMDES1
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:TMP4]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Endif
    [M:TMP4]PURFLG(nolign-1)  = [F:ITM]PURFLG
    [M:TMP4]MFGFLG(nolign-1)  = [F:ITM]MFGFLG
    [M:TMP4]SCPFLG(nolign-1)  = [F:ITM]SCPFLG
    [M:TMP4]SCSFLG(nolign-1)  = [F:ITM]SCSFLG
    [M:TMP4]PHAFLG(nolign-1)  = [F:ITM]PHAFLG
    [M:TMP4]GENFLG(nolign-1)  = [F:ITM]GENFLG
    [M:TMP4]TOOFLG(nolign-1)  = [F:ITM]TOOFLG
    [M:TMP4]DLVFLG(nolign-1)  = [F:ITM]DLVFLG
    [M:TMP4]SALFLG(nolign-1)  = [F:ITM]SALFLG
    [M:TMP4]INTFLG(nolign-1)  = [F:ITM]INTFLG
    [M:TMP4]STU(nolign-1)     = [F:ITM]STU        # US

    # analyse mises en relief (en cours, inter-société ...)
    ISINTERCPY = 0
    If [F:ORD]WIPTYP = 2
        If [F:ORD]BPRNUM <> ""
            Read [BPR]BPR0=[F:ORD]BPRNUM
            If fstat : Raz [F:BPR] : Endif

            # Inter-société ?
            If [F:BPR]FCY <> ""
                ISINTERCPY = func BENCHLIBP.ISINTERCPY([F:BPR]FCY, [F:ORD]STOFCY)
            Endif

            # PO inter-sociétés
            If ISINTERCPY
                If ISINTERCPY : [M:TMP4]WIPTYPSTA(nolign-1) +=  chr$(126) : Endif
            Endif
        Endif

        # en cours
        If [F:ORD]WIPSTA = 1
            Read [POH]POH0=[F:ORD]VCRNUM
            If fstat : Raz [F:POH] : Endif
            If [F:POH]RCPFLG = 2 : [M:TMP4]WIPTYPSTA(nolign-1) += ">" : Endif
        Endif
    Endif

    If [F:ORD]WIPTYP = 5 & find([F:ORD]WIPSTA, 1, 2)  # WOP, WOF
        Read [MFG]MFG0=[F:ORD]VCRNUM
        If fstat : Raz [F:MFG]
        Else
            If [F:MFG]OBJDAT <> [0/0/0]
                [M:TMP4]OBJDAT(nolign-1)  = [F:MFG]OBJDAT
                [M:TMP4]ELFLG(nolign-1)   = [F:MFG]OBJDAT - [F:ORD]ENDDAT
            Else
                [M:TMP4]OBJDAT(nolign-1)  = [F:ORD]ENDDAT
                [M:TMP4]ELFLG(nolign-1)   = 0
            Endif
            If [F:MFG]MFGSTA = 1 & [F:MFG]MFGTRKFLG = 4 : [M:TMP4]WIPTYPSTA(nolign-1) += ">" : Endif
            [M:TMP4]MFGTRKFLG(nolign-1) = [F:MFG]MFGTRKFLG
        Endif
        If dim([M:TMP4]MFGDES(nolign-1)) > 0
            Read [MFI]MFI0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
            If fstat : Raz [F:MFI]
            Else
                [M:TMP4]MFGDES(nolign-1) = [F:MFI]MFGDES
            Endif
        Endif
    Endif

    If [F:ORD]WIPTYP = 13 & find([F:ORD]WIPSTA, 1, 2)   # EOP, EOF
        Read [SCO]SCO0=[F:ORD]VCRNUM
        If fstat : Raz [F:SCO]
        Else
            If [F:SCO]RETDAT <> [0/0/0]
                [M:TMP4]OBJDAT(nolign-1)  = [F:SCO]RETDAT
                [M:TMP4]ELFLG(nolign-1)   = [F:SCO]RETDAT - [F:ORD]ENDDAT
            Else
                [M:TMP4]OBJDAT(nolign-1)  = [F:ORD]ENDDAT
                [M:TMP4]ELFLG(nolign-1)   = 0
            Endif
            If [F:SCO]SCOSTA = 1 & [F:SCO]SCOTRKFLG = 4 : [M:TMP4]WIPTYPSTA(nolign-1) += ">" : Endif
            [M:TMP4]MFGTRKFLG(nolign-1) = [F:SCO]SCOTRKFLG
        Endif
        If dim([M:TMP4]MFGDES(nolign-1)) > 0
            [M:TMP4]MFGDES(nolign-1) = [F:SCO]SCODES
        Endif
        If [F:SCO]BPRNUM <> ""
            Read [BPR]BPR0=[F:ORD]BPRNUM
            If fstat : Raz [F:BPR] : Endif

            # Inter-société ?
            If [F:BPR]FCY <> ""
                ISINTERCPY = func BENCHLIBP.ISINTERCPY([F:BPR]FCY, [F:ORD]STOFCY)
            Endif

            # EO inter-sociétés
            If ISINTERCPY
                If ISINTERCPY : [M:TMP4]WIPTYPSTA(nolign-1) +=  chr$(126) : Endif
            Endif
        Endif
    Endif

    # si prix ou devise renseigné , récupération
    If (dim([M:TMP4]NETPRI(nolign-1)) > 0 | dim([M:TMP4]CUR(nolign-1)) > 0)
        #If ([F:ORD]WIPTYP = 2 & GMODU(6) = 2) | ([F:ORD]WIPTYP = 1 & GMODU(5) = 2)
            Gosub GET_DOCUMENT_DATA
        #Endif
    Endif

    # mémorisation code objet (pour action tunnel)
    Case [M:TMP4]WIPTYP(nolign-1)
        When 2,7:       Case [M:TMP4]WIPSTA(nolign-1)
                            When 1 : Case [M:TMP4]ABBFIL(nolign-1)
                                         When "POQ" : [M:TMP4]CODOBJ(nolign-1)  = "POH"
                                                      [M:TMP4]CODCLE(nolign-1)  = [M:TMP4]VCRNUM(nolign-1)
                                                      [M:TMP4]CODCLE2(nolign-1) = num$([M:TMP4]VCRLIN(nolign-1))
                                         When "POC" : [M:TMP4]CODOBJ(nolign-1) = "POD"
                                                      [M:TMP4]CODCLE(nolign-1)  = num$([M:TMP4]VCRLIN(nolign-1))
                                                      [M:TMP4]CODCLE2(nolign-1) = [M:TMP4]VCRNUM(nolign-1)
                                     Endcase
                            When 2 : Case [M:TMP4]ABBFIL(nolign-1)
                                         When "PSD" : [M:TMP4]CODOBJ(nolign-1) = "PSH"
                                                      [M:TMP4]CODCLE(nolign-1)  = [M:TMP4]VCRNUM(nolign-1)
                                                      [M:TMP4]CODCLE2(nolign-1) = num$([M:TMP4]VCRLIN(nolign-1))
                                         When "POC" : [M:TMP4]CODOBJ(nolign-1) = "POD"
                                                      [M:TMP4]CODCLE(nolign-1)  = num$([M:TMP4]VCRLIN(nolign-1))
                                                      [M:TMP4]CODCLE2(nolign-1) = [M:TMP4]VCRNUM(nolign-1)
                                     Endcase
                        Endcase
        When 5,6,9:     [M:TMP4]CODOBJ(nolign-1)  = "MFG"
                        [M:TMP4]CODCLE(nolign-1)  = [M:TMP4]VCRNUM(nolign-1)
                        [M:TMP4]CODCLE2(nolign-1) = num$([M:TMP4]VCRLIN(nolign-1))
        When 3,13:      [M:TMP4]CODOBJ(nolign-1)  = "SCO"
                        [M:TMP4]CODCLE(nolign-1)  = [M:TMP4]VCRNUM(nolign-1)
                        [M:TMP4]CODCLE2(nolign-1) = num$([M:TMP4]VCRLIN(nolign-1))
        When 4:
                        Case [M:TMP4]ABBFIL(nolign-1)
                            When "MFO" :   [M:TMP4]CODOBJ(nolign-1)  = "MFG"
                            When "SCS" :   [M:TMP4]CODOBJ(nolign-1)  = "SCO"
                        Endcase
                        [M:TMP4]CODCLE(nolign-1)  = [M:TMP4]VCRNUM(nolign-1)
                        [M:TMP4]CODCLE2(nolign-1) = num$([M:TMP4]VCRLIN(nolign-1))
     Endcase

    # date besoin
    If find([F:ORD]WIPTYP,2,5,7,13) & find ([F:ORD]WIPSTA,1,2)    # POP,POF,WOP,WOF,TRP,TRF,EOF,EOP
        Read [ITF]ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY
        If fstat : Raz [F:ITF]
        Else
            If find([F:ITF]REOMGTCOD,2,3)    # réappro PDP/CBN
                Read [TRP]TRP0=[F:ITF]REOPOL
                If fstat : Raz [F:TRP]
                Else
                    If [F:TRP]PLNANYCOD=2 & [F:ITF]REOCOD<>1    # replanification + Type suggestion<>pas de suggestion
                        Read [PCB]PCB0=[F:ORD]STOFCY
                        If fstat : Raz [F:PCB]
                        Else
                           Local Integer IRPL                   # GA code simplifié 12/2008
                           IRPL= func CBNLIB.MAPRPL([F:ORD]WIPTYP, [F:ORD]WIPSTA)
                           Case [F:ITF]REOMGTCOD
                                When 2 :  # CBN
                                     If [F:PCB]RPLMOD(IRPL)=3 & [F:PCB]MRPANYLTI<>0
                                        [M:TMP4]REQDAT(nolign-1) = [M:TMP4]MRPDAT(nolign-1)
                                     Endif
                                When 3 :  # PDP
                                     If [F:PCB]RPLMODS(IRPL)=3 & [F:PCB]MPSANYLTI<>0
                                        [M:TMP4]REQDAT(nolign-1) = [M:TMP4]MRPDAT(nolign-1) Endif
                           Endcase
                        Endif
                    Endif
                Endif
            Endif
        Endif
    Endif
    If [M:TMP4]REQDAT(nolign-1)=[0/0/0] [M:TMP4]REQDAT(nolign-1)=[M:TMP4]ENDDAT(nolign-1) Endif

nolign += 1
$NXT1
Next

[M:TMP4]NBLIG  = nolign-1

Sorta [M:TMP4]NBLIG [M:TMP4]NBLIG Order By [M:TMP4]REQDAT(indice)
Affzo [M:TMP4]
Return

###########################################################################
$GET_DOCUMENT_DATA
Case [F:ORD]WIPTYP
    When 1:    If GMODU(5)<>2 Return Endif
               Case [F:ORD]WIPSTA
                   When 1:     Case [F:ORD]ABBFIL
                                   When "SOQ":    If dim([M:TMP4]NETPRI(nolign-1)) > 0
                                                      Read [SOP]SOP0=[F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
                                                      If fstat : Raz [F:SOP] : Endif
                                                      [M:TMP4]NETPRI(nolign-1) = [F:SOP]NETPRI
                                                  Endif
                                                  If dim([M:TMP4]CUR(nolign-1)) > 0
                                                      Read [SOH]SOH0=[F:ORD]VCRNUM
                                                      If fstat : Raz [F:SOH] : Endif
                                                      [M:TMP4]CUR(nolign-1) = [F:SOH]CUR
                                                  Endif
                                   When "SOC":    If dim([M:TMP4]NETPRI(nolign-1)) > 0
                                                      Read [SOQ]SOQ0=[F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
                                                      If !fstat
                                                          Filter [SOP] Where SOHNUM=[F:ORD]VCRNUM & SOPLIN=[F:ORD]VCRLIN &
&                                                                            ENDDAT>=[F:SOQ]DEMDLVDAT Order By Key SOP0
                                                          Read [SOP] First
                                                          If fstat : Raz [F:SOP] : Endif
                                                          Filter [SOP]
                                                          [M:TMP4]NETPRI(nolign-1) = [F:SOP]NETPRI
                                                      Endif
                                                  Endif
                                                  If dim([M:TMP4]CUR(nolign-1)) > 0
                                                      Read [SOH]SOH0=[F:ORD]VCRNUM
                                                      If fstat : Raz [F:SOH] : Endif
                                                      [M:TMP4]CUR(nolign-1) = [F:SOH]CUR
                                                  Endif
                               Endcase
                   When 2:     If dim([M:TMP4]NETPRI(nolign-1)) > 0
                                   Read [SOQ]SOQ0=[F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
                                   If !fstat
                                       Filter [SOP] Where SOHNUM=[F:ORD]VCRNUM & SOPLIN=[F:ORD]VCRLIN &
&                                                         ENDDAT>=[F:SOQ]DEMDLVDAT Order By Key SOP0
                                       Read [SOP] First
                                       If fstat : Raz [F:SOP] : Endif
                                       Filter [SOP]
                                       [M:TMP4]NETPRI(nolign-1) = [F:SOP]NETPRI
                                   Endif
                               Endif
                               If dim([M:TMP4]CUR(nolign-1)) > 0
                                   Read [SOH]SOH0=[F:ORD]VCRNUM
                                   If fstat : Raz [F:SOH] : Endif
                                   [M:TMP4]CUR(nolign-1) = [F:SOH]CUR
                               Endif
               Endcase
    When 2:    If GMODU(6)<>2 Return Endif
               Case [F:ORD]WIPSTA
                   When 1:     Case [F:ORD]ABBFIL
                                   When "POQ":    If dim([M:TMP4]NETPRI(nolign-1)) > 0
                                                      Read [POP]POP0=[F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
                                                      If fstat : Raz [F:POP] : Endif
                                                      [M:TMP4]NETPRI(nolign-1) = [F:POP]NETPRI
                                                  Endif
                                                  If dim([M:TMP4]CUR(nolign-1)) > 0
                                                      Read [POH]POH0=[F:ORD]VCRNUM
                                                      If fstat : Raz [F:POH] : Endif
                                                      [M:TMP4]CUR(nolign-1) = [F:POH]CUR
                                                  Endif
                                   When "POC":    If dim([M:TMP4]NETPRI(nolign-1)) > 0
                                                      Read [POQ]POQ0=[F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
                                                      If !fstat
                                                          Filter [POP] Where POHNUM=[F:ORD]VCRNUM & POPLIN=[F:ORD]VCRLIN &
&                                                                            POPDAT>=[F:POQ]DEMRCPDAT Order By Key POP1
                                                          Read [POP] First
                                                          If fstat : Raz [F:POP] : Endif
                                                          Filter [POP]
                                                          [M:TMP4]NETPRI(nolign-1) = [F:POP]NETPRI
                                                      Endif
                                                  Endif
                                                  If dim([M:TMP4]CUR(nolign-1)) > 0
                                                      Read [POH]POH0=[F:ORD]VCRNUM
                                                      If fstat : Raz [F:POH] : Endif
                                                      [M:TMP4]CUR(nolign-1) = [F:POH]CUR
                                                  Endif
                               Endcase
                   When 2:     Case [F:ORD]ABBFIL
                                   When "PSD":    Read [PSD]PSD0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
                                                  If fstat : Raz [F:PSD] : Endif
                                                  If dim([M:TMP4]NETPRI(nolign-1)) > 0
                                                      [M:TMP4]NETPRI(nolign-1) = [F:PSD]NETPRI
                                                  Endif
                                                  If dim([M:TMP4]CUR(nolign-1)) > 0
                                                      [M:TMP4]CUR(nolign-1) = [F:PSD]CUR
                                                  Endif
                                   When "POC":    If dim([M:TMP4]NETPRI(nolign-1)) > 0
                                                      Read [POQ]POQ0=[F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
                                                      If !fstat
                                                          Filter [POP] Where POHNUM=[F:ORD]VCRNUM & POPLIN=[F:ORD]VCRLIN &
&                                                                            POPDAT>=[F:POQ]DEMRCPDAT Order By Key POP1
                                                          Read [POP] First
                                                          If fstat : Raz [F:POP] : Endif
                                                          Filter [POP]
                                                          [M:TMP4]NETPRI(nolign-1) = [F:POP]NETPRI
                                                      Endif
                                                  Endif
                                                  If dim([M:TMP4]CUR(nolign-1)) > 0
                                                      Read [POH]POH0=[F:ORD]VCRNUM
                                                      If fstat : Raz [F:POH] : Endif
                                                      [M:TMP4]CUR(nolign-1) = [F:POH]CUR
                                                  Endif
                                   Endcase
               Endcase
     When 3:    If GMODU(6)<>2 Return Endif           # MS Prix matière (si fournie par le sous-traitant)
               If dim([M:TMP4]NETPRI(nolign-1)) > 0
                  Read [SCM]SCM0=[F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
                  If fstat : Raz [F:SCM] : Endif
                  [M:TMP4]NETPRI(nolign-1) = [F:SCM]NETPRI
               Endif
               If dim([M:TMP4]CUR(nolign-1)) > 0
                  If [F:SCO]SCONUM<>[F:ORD]VCRNUM
                     Read [SCO]SCO0=[F:ORD]VCRNUM
                     If fstat : Raz [F:SCO] : Endif
                  Endif
                  [M:TMP4]CUR(nolign-1) = [F:SCO]CUR
               Endif
   When 4:    Case [F:ORD]ABBFIL
                    When "SCS": If GMODU(6)<>2 Return Endif           # Prix du service
                                If dim([M:TMP4]NETPRI(nolign-1)) > 0
                                   Read [SCS]SCS0=[F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
                                   If fstat : Raz [F:SCS] : Endif
                                   [M:TMP4]NETPRI(nolign-1) = [F:SCS]NETPRI
                                Endif
                                If dim([M:TMP4]CUR(nolign-1)) > 0
                                   If [F:SCO]SCONUM<>[F:ORD]VCRNUM
                                      Read [SCO]SCO0=[F:ORD]VCRNUM
                                      If fstat : Raz [F:SCO] : Endif
                                   Endif
                                   [M:TMP4]CUR(nolign-1) = [F:SCO]CUR
                                Endif
                    When "MFO": If GMODU(8)<>2 Return Endif
                                # pas de prix ?
               Endcase
    When 13:   If GMODU(6)<>2 Return Endif           # EO Prix article sous-traité
               If dim([M:TMP4]NETPRI(nolign-1)) > 0
                  Read [SCI]SCI0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
                  If fstat : Raz [F:SCI] : Endif
                  [M:TMP4]NETPRI(nolign-1) = [F:SCI]NETPRI
               Endif
               If dim([M:TMP4]CUR(nolign-1)) > 0
                  If [F:SCO]SCONUM<>[F:ORD]VCRNUM
                     Read [SCO]SCO0=[F:ORD]VCRNUM
                     If fstat : Raz [F:SCO] : Endif
                  Endif
                  [M:TMP4]CUR(nolign-1) = [F:SCO]CUR
               Endif
Endcase
Return


########################################################################
# Préparation du filtre sur la table encours                           #
########################################################################
$LOAD_FILTER
Raz XCRITERE
Raz XCRITERE1
Raz XCRITERE2
Raz XCRITERE3

# ordres de type WOF
If [M:TMP3]FLGWOF= 2
    XCRITERE  = "(WIPTYP=5&WIPSTA=1&MRPMES>=2&MRPMES<=10)"
    Gosub LOAD_CRITERE
Endif
# ordres de type WOP
If [M:TMP3]FLGWOP= 2
    XCRITERE  = "(WIPTYP=5&WIPSTA=2&MRPMES>=2&MRPMES<=10)"
    Gosub LOAD_CRITERE
Endif
# ordres de type POF
If [M:TMP3]FLGPOF= 2
    XCRITERE  = "(WIPTYP=2&WIPSTA=1&MRPMES>=2&MRPMES<=10)"
    Gosub LOAD_CRITERE
Endif
# ordres de type POP
If [M:TMP3]FLGPOP= 2
    XCRITERE  = "(WIPTYP=2&WIPSTA=2&MRPMES>=2&MRPMES<=10)"
    Gosub LOAD_CRITERE
Endif
# ordres de type TRF
If [M:TMP3]FLGTRF= 2
    XCRITERE  = "(WIPTYP=7&WIPSTA=1&MRPMES>=2&MRPMES<=10)"
    Gosub LOAD_CRITERE
Endif
# ordres de type TRP
If [M:TMP3]FLGTRP= 2
    XCRITERE  = "(WIPTYP=7&WIPSTA=2&MRPMES>=2&MRPMES<=10)"
    Gosub LOAD_CRITERE
Endif
# V6 Beryl ordres de type EOF
If [M:TMP3]FLGEOF= 2
    XCRITERE  = "(WIPTYP=13&WIPSTA=1&MRPMES>=2&MRPMES<=10)"
    Gosub LOAD_CRITERE
Endif
# V6 Beryl ordres de type EOP
If [M:TMP3]FLGEOP= 2
    XCRITERE  = "(WIPTYP=13&WIPSTA=2&MRPMES>=2&MRPMES<=10)"
    Gosub LOAD_CRITERE
Endif


# ordres de type WOS inutile
If [M:TMP3]FLGWOS= 2
    XCRITERE  = "(WIPTYP=5&WIPSTA=3&MRPMES=6)"
    Gosub LOAD_CRITERE1
Endif

# ordres de type POS inutile
If [M:TMP3]FLGPOS= 2
    XCRITERE  = "(WIPTYP=2&WIPSTA=3&MRPMES=6)"
    Gosub LOAD_CRITERE1
Endif

# ordres de type TRS inutile
If [M:TMP3]FLGTRS= 2
    XCRITERE  = "(WIPTYP=7&WIPSTA=3&MRPMES=6)"
    Gosub LOAD_CRITERE1
Endif

# ordres de type EOS inutile
If [M:TMP3]FLGEOS= 2
    XCRITERE  = "(WIPTYP=13&WIPSTA=3&MRPMES=6)"
    Gosub LOAD_CRITERE1
Endif

Return
#########################################################################
$LOAD_FILTER2
Raz XCRITERE
Raz XCRITERE11
Raz XCRITERE12
Raz XCRITERE13
Raz XCRITERE14
Raz XCRITERE15

# critères dynamiques, dépendant des paramètres
# site
If [M:TMP1]STOFCY <> ""
   XCRITERE = "STOFCY=[M:TMP1]STOFCY"                # filtre site
   Gosub LOAD_CRITERE11
Endif

# article
If [M:TMP2]ITMREFSTR <> ""
    XCRITERE = "ITMREF>=[M:TMP2]ITMREFSTR"      # borne début article
    Gosub LOAD_CRITERE11
Endif
If [M:TMP2]ITMREFEND<>""
    XCRITERE = "ITMREF<=[M:TMP2]ITMREFEND"      # borne fin   article
    Gosub LOAD_CRITERE11
Endif

# tiers
If [M:TMP2]BPRNUMSTR <> ""
   XCRITERE = "BPRNUM>=[M:TMP2]BPRNUMSTR"         # borne début tiers
   Gosub LOAD_CRITERE11
Endif
If [M:TMP2]BPRNUMEND <> ""
   XCRITERE = "BPRNUM<=[M:TMP2]BPRNUMEND"         # borne fin   tiers
   Gosub LOAD_CRITERE11
Endif

# date fin
If [M:TMP2]ENDDATSTR <> [0/0/0]
   XCRITERE = "ENDDAT>=[M:TMP2]ENDDATSTR"         # borne date fin
   Gosub LOAD_CRITERE11
Endif
If [M:TMP2]ENDDATEND <> [0/0/0]
   XCRITERE = "ENDDAT<=[M:TMP2]ENDDATEND"         # borne date fin
   Gosub LOAD_CRITERE11
Endif

# affaire
If [M:TMP2]PJTSTR <> ""
   XCRITERE = "PJT>=[M:TMP2]PJTSTR"               # borne début affaire
   Gosub LOAD_CRITERE11
Endif
If [M:TMP2]PJTEND <> ""
   XCRITERE = "PJT<=[M:TMP2]PJTEND"               # borne fin   affaire
   Gosub LOAD_CRITERE11
Endif

# pièce
If [M:TMP2]VCRNUMSTR <> ""
   XCRITERE = "VCRNUM>=[M:TMP2]VCRNUMSTR"         # borne début pièce
   Gosub LOAD_CRITERE11
Endif
If [M:TMP2] VCRNUMEND <> ""
   XCRITERE = "VCRNUM<=[M:TMP2]VCRNUMEND"         # borne fin   pièce
   Gosub LOAD_CRITERE11
Endif

# Pièce origine
If [M:TMP2]VCRORISTR <> ""
   XCRITERE ="VCRNUMORI>=[M:TMP2]VCRORISTR"       # borne début pièce origine
   Gosub LOAD_CRITERE11
Endif
If [M:TMP2]VCRORIEND <>""
   XCRITERE = "VCRNUMORI <=[M:TMP2]VCRORIEND"     # borne fin pièce origine
   Gosub LOAD_CRITERE11
Endif

# date début
If [M:TMP2]STRDATSTR <> [0/0/0]
   XCRITERE = "STRDAT>=[M:TMP2]STRDATSTR"         # borne date début
   Gosub LOAD_CRITERE11
Endif
If [M:TMP2]STRDATEND <> [0/0/0]
   XCRITERE = "STRDAT<=[M:TMP2]STRDATEND"         # borne date début
   Gosub LOAD_CRITERE11
Endif

# catégorie
If [M:TMP2]TCLCODSTR <> ""
   XCRITERE = "[F:ITM]TCLCOD>=[M:TMP2]TCLCODSTR"         # borne catégorie
   Gosub LOAD_CRITERE11
Endif
If [M:TMP2]TCLCODEND <> ""
   XCRITERE = "[F:ITM]TCLCOD<=[M:TMP2]TCLCODEND"         # borne catégorie
   Gosub LOAD_CRITERE12
Endif

If dim([M:TMP2]TSICODSTR) > 0                # familles statistiques
    For I = 0 To dim([M:TMP2]TSICODSTR)-1
        If [M:TMP2]TSICODSTR(I) <> ""
            XCRITERE = "[F:ITM]TSICOD("+num$(I)+")>=[M:TMP2]TSICODSTR("+num$(I)+")"
            Gosub LOAD_CRITERE12
        Endif
        If [M:TMP2]TSICODEND(I) <> ""
            XCRITERE = "[F:ITM]TSICOD("+num$(I)+")<=[M:TMP2]TSICODEND("+num$(I)+")"
            Gosub LOAD_CRITERE15
        Endif
    Next I
Endif


Return

