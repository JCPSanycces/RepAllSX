########################################################################
$ENREGISTRE
Gosub MODIF
FIN=1
GERR=2
GMESSAGE=mess(363,197,1)
Return

########################################################################
$MODIF
Call TEMPON("V") From GESECRAN

If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif
Gosub MODORD
If !NBMRP
    WMESS1=mess(371,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Endif

Call TEMPOFF From GESECRAN

Return
########################################################################
# Mise à jour des ordres
$MODORD
Gosub MAJORD
If NBMRP
    WMESS1=num$(NBMRP)-mess(362,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Endif
Return
########################################################################
$MAJORD
NBMRP = 0

For I=1 To [M:TMP4]NBLIG
    NOL = I-1
    Read [ORD]ORD0=[M:TMP4]WIPTYP(NOL);[M:TMP4]WIPNUM(NOL);[M:TMP4]ITMREF(NOL)
    If !fstat
        Case [M:TMP4]WIPTYP(NOL)
        When 2,7 :    # PO,TR
            Case [M:TMP4]WIPSTA(NOL)
                When 1 :     # POF,TRF
                    If [M:TMP4]MRPMES(NOL) = 6 : Gosub SUPPOF
                    Else                       : Gosub MODPOF : Endif
                When 2 :     # POP,TRP
                    If [M:TMP4]MRPMES(NOL) = 6 : Gosub SUPPOP
                    Else                       : Gosub MODPOP : Endif
                When 3 :     # POS,TRS
                    If [M:TMP4]MRPMES(NOL) = 6 : Gosub SUPPOS : Endif
            Endcase
        When 5 :    # WO
            Read [MFG]MFG0=[M:TMP4]VCRNUM(NOL)
            # WOF à l'étude ou en cours  : non modifiable
            If [F:MFG]MFGSTA = 1  & find([F:MFG]MFGTRKFLG,2,4)
                WMESS1 =  mess(231,197,1)-[M:TMP4]VCRNUM(NOL)-mess(215,190,1)
                Call ECR_TRACE(WMESS1,0) From GESECRAN : Goto NXTORD1
            Endif
            # WOP à l'étude : non modifiable
            If [F:MFG]MFGSTA = 2 & [F:MFG]MFGTRKFLG= 2
                WMESS1 =  mess(230,197,1)-[M:TMP4]VCRNUM(NOL)-mess(216,190,1)
                Call ECR_TRACE(WMESS1,0) From GESECRAN : Goto NXTORD1
            Endif
            # WOx inutile
            If [M]MRPMES(NOL) = 6                 Gosub SUPWOX
            Else
                If find ([M:TMP4]WIPSTA(NOL),1,2) Gosub MODWOX  Endif
            Endif
        When 13 :     # EO
            If [M:TMP4]MRPMES(NOL) = 6            Gosub SUPEOX
            Else
                If find ([M:TMP4]WIPSTA(NOL),1,2) Gosub MODEOX  Endif
            Endif
        Endcase
    Else
        WMESS1=mess(69,151,1)-num$([M]WIPTYP(NOL))-"/"-num$([M]WIPNUM(NOL))-"/"-[M]ITMREF(NOL)-
&        mess(42,9003,1)
        Call ECR_TRACE(WMESS1,0) From GESECRAN
        Goto NXTORD1
    Endif
$NXTORD1
Next I

Return

########################################################################
$MODPOF
Local Integer WOK

Read [POH]POH0 = [F:ORD]VCRNUM
If fstat : Return
Else
    If [F:POH]POHTYP =2
        [M:TMP4]POHNUM(NOL)     = [F:POH]POHNUM
        [M:TMP4]LINAPPFLG(NOL)  = 4
    Else
        [M:TMP4]LINAPPFLG(NOL)  = [F:POH]APPFLG
        If [M:TMP4]LINAPPFLG(NOL) = 0 : [M:TMP4]LINAPPFLG(NOL) = 4 : Endif
    Endif
Endif

Read [POQ]POQ0 = [F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
If fstat : Return
Else
    [M:TMP4]STU(NOL)    = [F:POQ]STU
    [M:TMP4]PUU(NOL)    = [F:POQ]PUU
    [M:TMP4]USEPLC(NOL) = [F:POQ]USEPLC
    [M:TMP4]BPSNUM(NOL) = [F:POQ]BPSNUM
    Call PCAL_QTY([M:TMP4]MRPQTY(NOL),[M:TMP4]STU(NOL),[M:TMP4]QTYPUU(NOL), [M:TMP4]PUU(NOL),
&       [M:TMP4]ITMREF(NOL),[M:TMP4]BPSNUM(NOL),1,GBIDD1 ) From TRTACHQTE1
Endif

If [M:TMP4]POHNUM(NOL) = ""
    #----- Contrôle article-fournisseur -----#
    If [F:ITP]ITMREF <> [M:TMP4]ITMREF(NOL) | [F:ITP]BPSNUM <> [M:TMP4]BPSNUM(NOL)
        Read [ITP]ITP0=[M:TMP4]ITMREF(NOL);[M:TMP4]BPSNUM(NOL)
    Else
        fstat = 0
    Endif
    If !fstat
        Call PCAL_QTY ([F:ITP]PURMINQTY,[F:ITP]PUU,GBIDD1,[M:TMP4]PUU(NOL),
&                      [M:TMP4]ITMREF(NOL),[M:TMP4]BPSNUM(NOL),1,GBIDD2) From TRTACHQTE1
        #----- Test qté inférieure à qté minimum d'achat -----#
        #VPO 15/10/10 17730/59532 contrôle selon paramètre
        If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
        #If [M:TMP4]QTYPUU(NOL) < GBIDD1
        If [M:TMP4]QTYPUU(NOL) < GBIDD1 & GPOHMINQTY<3
            WMESS1 =[M:TMP4]ITMREF(NOL)-mid$(mess(14,194,1),1,instr(1,mess(14,194,1),"\")-1)
            WMESS1-=right$(mess(14,194,1),instr(1,mess(14,194,1),"\")+1)
            WMESS1-=num$(GBIDD1)-[M:TMP4]PUU(NOL)
            If GPOHMINQTY=1
                Call ECR_TRACE(WMESS1,0) From GESECRAN
                Return
            Else : #GPOHMINQTY=2
                WOK=2
                Call AVERTIR (WMESS1, WOK)From GESECRAN
                If WOK=1
                    Return
                Endif
                Raz WMESS1
            Endif
        Endif
    Endif
Endif

[M:TMP4]EXTRCPDAT(NOL) = [M:TMP4]MRPDAT(NOL)
[M:TMP4]CAD(NOL)       = 1
Call CHARGE_WRCPDAT([M:TMP4]WRCPDAT(NOL),[M:TMP4]STRRCPDAT(NOL),[M:TMP4]EXTRCPDAT(NOL),[M:TMP4]WEE(NOL),
&    [M:TMP4]YEA(NOL))

WENDDAT = [M:TMP4]ENDDAT(NOL)

Raz [M:PMG]
[M:PMG]MAJCOD          = "M"
[M:PMG]MAJTYP          = "F"
[M:PMG]MSGFLG          = 1
[M:PMG]USEPLC          = [M:TMP4]USEPLC(NOL)
[M:PMG]REVFLG          = 1
[M:PMG]TRAFLG          = 1

#----- Modification avec avenant ?
# on répond oui systématiquement à la place de l'utilisateur
# puisque pas d'interactivité dans traitement en série
If GPURREV > 1 & [M:TMP4]LINAPPFLG(NOL) > 1 # Issue X3-71652 - 2018-01-28 by SDEM
    If [F:POH]RCPFLG > 1 | [F:POH]INVFLG > 1
        [M:PMG]REVFLG = 2
    Endif
    If [F:POH]PRNFLG = 2 & [F:POH]APPFLG > 2
        [M:PMG]REVFLG = 2
    Endif
    If [F:POH]APPFLG = 3 [M:PMG]REVFLG = 2 Endif
Endif
#
If [M:TMP4]POHNUM(NOL) <> ""
    [M:PMG]WRCPDAT        = [M:TMP4]WRCPDAT(NOL)
Endif
[M:PMG]POCNUM          = [M:TMP4]POHNUM(NOL)
[M:PMG]NBLIG           = 1
[M:PMG]STOFCY(0)       = [M:TMP4]STOFCY(NOL)
[M:PMG]PJT(0)          = [M:TMP4]PJT(NOL)
[M:PMG]BPRNUM(0)       = [M:TMP4]BPSNUM(NOL)
[M:PMG]VCRNUM(0)       = [M:TMP4]VCRNUM(NOL)
[M:PMG]VCRLIN(0)       = [M:TMP4]VCRLIN(NOL)
[M:PMG]VCRSEQ(0)       = [M:TMP4]VCRSEQ(NOL)
[M:PMG]ENDDAT(0)       = [M:TMP4]EXTRCPDAT(NOL)
[M:PMG]STU(0)          = [M:TMP4]STU(NOL)
[M:PMG]EXTSTUQTY(0)    = [M:TMP4]MRPQTY(NOL)
[M:PMG]PUU(0)          = [M:TMP4]PUU(NOL)
[M:PMG]EXTPUUQTY(0)    = [M:TMP4]QTYPUU(NOL)
If [M:PMG]EXTPUUQTY(0) = 0 : Return : Endif
Raz [M:ORDK]
Call MGT_PURCHASE From TRTACHMGT1
If [M:PMG]ERRCOD = 0
    # raz des zones MRPDAT et MRPQTY de la table ORDERS
    GOK = 1
    Trbegin [ORD]
    Readlock [ORD] ORD0=[F:POQ]WIPTYP;[F:POQ]WIPNUM;[F:POQ]ITMREF
    [F:ORD]MRPDAT = [0/0/0]
    [F:ORD]MRPQTY = 0
    Rewrite [ORD]
    If fstat
        GOK=0 : Call FSTA("ORD") From GLOCK
        Goto AB_MOD
    Endif
    If GOK = 1 : Commit : Endif
    Unlock [ORD]
    #
    If [M:TMP4]POHNUM(NOL) <> ""
        # Message : Ligne contrat XXXXXXXXXXXXXXX 99999999 modifiée !
        WMESS=[M:TMP4]VCRNUM(NOL)-num$([M:TMP4]VCRLIN(NOL))-num$([M:TMP4]VCRSEQ(NOL))
        WMESS1=mess(243,197,1)-WMESS-mess(223,197,1)
        Call ECR_TRACE(WMESS1,0) From GESECRAN
    Else
          # Message : Ligne commande XXXXXXXXXXXXXXX 999999 999999 modifiée !
        WMESS=[M:TMP4]VCRNUM(NOL)-num$([M:TMP4]VCRLIN(NOL))-num$([M:TMP4]VCRSEQ(NOL))
        WMESS1=mess(367,197,1)-WMESS-mess(223,197,1)
        Call ECR_TRACE(WMESS1,0) From GESECRAN
    Endif
    Gosub MORE_DET
    NBMRP += 1
Else
    If [M:TMP4]POHNUM(NOL) <> ""
        WMESS1 = mess(243,197,1)-[M:TMP4]VCRNUM(NOL)-num$([M:TMP4]VCRLIN(NOL))-num$([M:TMP4]VCRSEQ(NOL))
        Call ECR_TRACE(WMESS1,0) From GESECRAN
    Else
        WMESS1 = mess(367,197,1)-[M:TMP4]VCRNUM(NOL)-num$([M:TMP4]VCRLIN(NOL))-num$([M:TMP4]VCRSEQ(NOL))
        Call ECR_TRACE(WMESS1,0) From GESECRAN
    Endif
    If GMESSAGE<>"" Call ECR_TRACE(GMESSAGE,1) From GESECRAN Endif
    If GOK=0 Call ECR_TRACE(mess(157,199,1),0) From GESECRAN Endif    #"Transaction abandonnée"
Endif


Return

########################################################################
$MODPOP

# test origine POP
Case [F:ORD]ABBFIL
    When "PSD" :
        # lecture ligne DA
        Read [PSD]PSD0 = [F:ORD]VCRNUM;[F:ORD]VCRLIN
        If fstat : Return : Endif
        [M:TMP4]BPSNUM(NOL) = [F:PSD]BPSNUM
        [M:TMP4]PUU(NOL)    = [F:PSD]PUU
        [M:TMP4]STU(NOL)    = [F:PSD]STU
        Call PCAL_QTY([M:TMP4]MRPQTY(NOL),[M:TMP4]STU(NOL),[M:TMP4]QTYPUU(NOL),
&           [M:TMP4]PUU(NOL),[M:TMP4]ITMREF(NOL),[M:TMP4]BPSNUM(NOL),1,GBIDD1 ) From TRTACHQTE1
    When "POC" :
        # lecture entête DL
        Read [POH]POH0 = [F:ORD]VCRNUM
        If fstat : Return : Endif
        # lecture ligne DL
        Read [POQ]POQ0 = [F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
        If fstat : Return : Endif
        [M:TMP4]POHNUM(NOL) = [F:POH]POHNUM
        [M:TMP4]BPSNUM(NOL) = [F:POQ]BPSNUM
        [M:TMP4]PUU(NOL)    = [F:POQ]PUU
        [M:TMP4]STU(NOL)    = [F:POQ]STU
        [M:TMP4]USEPLC(NOL) = [F:POQ]USEPLC
        Call PCAL_QTY([M:TMP4]MRPQTY(NOL),[M:TMP4]STU(NOL),[M:TMP4]QTYPUU(NOL),
&           [M:TMP4]PUU(NOL),[M:TMP4]ITMREF(NOL),[M:TMP4]BPSNUM(NOL),1,GBIDD1 ) From TRTACHQTE1
Endcase
[M:TMP4]EXTRCPDAT(NOL) = [M:TMP4]MRPDAT(NOL)
[M:TMP4]CAD(NOL)       = 1
Call CHARGE_WRCPDAT([M:TMP4]WRCPDAT(NOL),[M:TMP4]STRRCPDAT(NOL),[M:TMP4]EXTRCPDAT(NOL),[M:TMP4]WEE(NOL),
&    [M:TMP4]YEA(NOL))

WENDDAT = [M:TMP4]ENDDAT(NOL)

Raz [M:PMG]
[M:PMG]MAJCOD = "M"
[M:PMG]MAJTYP = "P"
[M:PMG]MSGFLG = 1
[M:PMG]TRAFLG = 1

If [M:TMP4]POHNUM(NOL) <> ""
    # contrat
    [M:PMG]WRCPDAT        = [M:TMP4]WRCPDAT(NOL)
    [M:PMG]USEPLC         = [M:TMP4]USEPLC(NOL)
    [M:PMG]NBLIG          = 1
    [M:PMG]POCNUM(0)      = [M:TMP4]POHNUM(NOL)
    [M:PMG]WIPTYP(0)      = [M:TMP4]WIPTYP(NOL)
    [M:PMG]WIPSTA(0)      = [M:TMP4]WIPSTA(NOL)
    [M:PMG]WIPNUM(0)      = [M:TMP4]WIPNUM(NOL)
    [M:PMG]VCRNUM(0)      = [M:TMP4]VCRNUM(NOL)
    [M:PMG]VCRLIN(0)      = [M:TMP4]VCRLIN(NOL)
    [M:PMG]VCRSEQ(0)      = [M:TMP4]VCRSEQ(NOL)
    [M:PMG]ITMREF(0)      = [M:TMP4]ITMREF(NOL)
    [M:PMG]ORIFCY(0)      = [M:TMP4]ORIFCY(NOL)
    [M:PMG]STOFCY(0)      = [M:TMP4]STOFCY(NOL)
    [M:PMG]ENDDAT(0)      = [M:TMP4]EXTRCPDAT(NOL)
    [M:PMG]STU(0)         = [M:TMP4]STU(NOL)
    [M:PMG]EXTSTUQTY(0)   = [M:TMP4]MRPQTY(NOL)
    [M:PMG]PUU(0)         = [M:TMP4]PUU(NOL)
    [M:PMG]EXTPUUQTY(0)   = [M:TMP4]QTYPUU(NOL)
Else
    [M:PMG]REQUSR         = GUSER
    [M:PMG]PSHFCY         = [M:TMP4]ORIFCY(NOL)
    [M:PMG]USEPLC         = [M:TMP4]USEPLC(NOL)
    [M:PMG]NBLIG          = 1
    [M:PMG]WIPTYP(0)      = [M:TMP4]WIPTYP(NOL)
    [M:PMG]WIPSTA(0)      = [M:TMP4]WIPSTA(NOL)
    [M:PMG]WIPNUM(0)      = [M:TMP4]WIPNUM(NOL)
    [M:PMG]VCRNUM(0)      = [M:TMP4]VCRNUM(NOL)
    [M:PMG]VCRLIN(0)      = [M:TMP4]VCRLIN(NOL)
    [M:PMG]VCRSEQ(0)      = [M:TMP4]VCRSEQ(NOL)
    [M:PMG]STOFCY(0)      = [M:TMP4]STOFCY(NOL)
    [M:PMG]PJT(0)         = [M:TMP4]PJT(NOL)
    [M:PMG]BPRNUM(0)      = [M:TMP4]BPSNUM(NOL)
    [M:PMG]ENDDAT(0)      = [M:TMP4]EXTRCPDAT(NOL)
    [M:PMG]STU(0)         = [M:TMP4]STU(NOL)
    [M:PMG]EXTSTUQTY(0)   = [M:TMP4]MRPQTY(NOL)
    [M:PMG]PUU(0)         = [M:TMP4]PUU(NOL)
    [M:PMG]EXTPUUQTY(0)   = [M:TMP4]QTYPUU(NOL)
Endif

Raz [M:ORDK]
Call MGT_PURCHASE From TRTACHMGT1
If [M:PMG]ERRCOD = 0
    # raz des zones MRPDAT et MRPQTY de la table ORDERS
    GOK = 1
    Trbegin [ORD]
    Readlock [ORD] ORD0=[M:TMP4]WIPTYP(NOL);[M:TMP4]WIPNUM(NOL);[M:TMP4]ITMREF(NOL)
    [F:ORD]MRPDAT = [0/0/0]
    [F:ORD]MRPQTY = 0
    Rewrite [ORD]
    If fstat
        GOK=0 : Call FSTA("ORD") From GLOCK
        Goto AB_MOD
    Endif
    If GOK = 1 : Commit : Endif
    Unlock [ORD]
    #
    If [M:TMP4]POHNUM(NOL) <> ""
        # Message : Ligne contrat XXXXXXXXXXXXXXX 99999999 modifiée !
        WMESS=[M:TMP4]VCRNUM(NOL)-num$([M:TMP4]VCRLIN(NOL))-num$([M:TMP4]VCRSEQ(NOL))
        WMESS1=mess(243,197,1)-WMESS-mess(223,197,1)
        Call ECR_TRACE(WMESS1,0) From GESECRAN
    Else
        # MESSAGE : Demande d'achat XXXXXXXXXXXXXXX 9999999 modifiée!
        WMESS1 = mess(222,197,1)-[M:TMP4]VCRNUM(NOL)-num$([M:TMP4]VCRLIN(NOL))-mess(223,197,1)
        Call ECR_TRACE(WMESS1,0) From GESECRAN
    Endif
    Gosub MORE_DET
    NBMRP += 1
Else
    If [M:TMP4]POHNUM(NOL) <> ""
        WMESS1 = mess(243,197,1)-[M:TMP4]VCRNUM(NOL)-num$([M:TMP4]VCRLIN(NOL))-num$([M:TMP4]VCRSEQ(NOL))
        Call ECR_TRACE(WMESS1,0) From GESECRAN
    Else
        WMESS1 = mess(222,197,1)-[M:TMP4]VCRNUM(NOL)-num$([M:TMP4]VCRLIN(NOL))
        Call ECR_TRACE(WMESS1,0) From GESECRAN
    Endif
    If GMESSAGE<>"" Call ECR_TRACE(GMESSAGE,1) From GESECRAN Endif
    If GOK=0 Call ECR_TRACE(mess(157,199,1),0) From GESECRAN Endif
Endif

Return

