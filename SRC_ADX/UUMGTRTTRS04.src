#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRS04                              Module   A/P-A/R Accounting  #
#                                                                        #
#                    Migration Process                                   #
#                                                                        #
#     Flow for Expenses                                                  #
#                                                                        #
#            EXPENSES                                                    #
#                                                                        #
##########################################################################
#                                                                        #
#  Optimized Index for Migration                                         #
#                                                                        #
#   EXPENSES : CPY;ACCNUM                                                #
#                                                                        #
#  Index to keep for Migration                                           #
#                                                                        #
#   EXPENSES : CLB;DATEXS;NBREXS                                         #
#                                                                        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRS04 ") From LECFIC
  Endif

  #Call RAZ_UUMGTRTTRS04 (DOSSIER)
  Call MAJ_UUMGTRTTRS04 (DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

########################################################################
Subprog RAZ_UUMGTRTTRS04(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(2)<>2 : End : Endif

#----- File naming...  -----#
Local Char WNAMEXSM
Call MIGTABNAME (DOSSIER,"EXPENSES",WNAMEXSM,ERR) From TRTMIG : If ERR : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMEXSM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif

#----- Deleting of records...  -----#
Call MIGTABRAZ (DOSSIER,"EXPENSES",ERR) From TRTMIG
Call MIGRAZKEY (DOSSIER,"UUMGTRTTRS04",ERR) From TRTMIG

End

########################################################################
Subprog MAJ_UUMGTRTTRS04(DOSSIER)
Value Char DOSSIER
Local Integer ERR

If [F:ADS]MODULE(2)<>2
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS04",3,ERR) From TRTMIG : End
Endif

#----- File naming...  -----#
Local Char WNAMEXSM
Call MIGTABNAME (DOSSIER,"EXPENSES",WNAMEXSM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS04",7,ERR) From TRTMIG : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMEXSM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS04",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS04",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS04",7,ERR) From TRTMIG : End : Endif

Call ECR_TIME("UUMGTRTTRS04 Expenses Process : Update EXPENSES") From DOSSUB
Call ECR_TRACE("UUMGTRTTRS04 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Files Updating where we will insert -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"EXPENSES",ERR) From TRTMIG

#--------------- Opening of files  -----#
# X3 Files
If clalev([F:EXS]) = 0 :  Local File =DOSSIER+".EXPENSES"    [EXS]   : Endif     # Cost

# X3 Renamed File
If clalev([F:EXSM]) = 0 :  Local File =DOSSIER+"."+WNAMEXSM   [EXSM]  : Endif    # Cost

# X3 Commun File
Gosub OPEN_FILE From UUMGTRTCPT00

#-----  Declaration of Variables
Gosub DECLARE From UUMGTRTCPT00

# Variables to manage Flush instruction
Local Char WTAB_EXS (100) (adxwrb)
Local Shortint WCPT_EXS

# Variables to Handle Loops Ruptures
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

#-----  Keys's reading  -----#
# Table's AMIGKEY reading to initialize ACLEx/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTTRS04",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

Filter [EXSM] Order By Key CLE = [F:EXSM]CPY;[F:EXSM]ACCNUM

# EP to add a criteria in the "where"
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRS04" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_TRS04
Raz NB

If STOP = 1
 STOP = 2
 CRITERE = "[F:EXSM]CPY='"+TABMIGKEY(1)+"' & [F:EXSM]ACCNUM>"+TABMIGKEY(2)
Elsif STOP = 2
 STOP = 0
 CRITERE = "[F:EXSM]CPY>'"+TABMIGKEY(1)+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [EXS]
GOK = 1

For [EXSM]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

 # By company - Initialization of Variables linked to the Account Core Model
 [L]COMPANY = [F:EXSM]CPY
 Gosub INI_CPY From UUMGTRTCPT00
 If !GOK : Break : Endif

 For [EXSM]CLE

  NBLUS+=1

  # EP to delete line
  If FILTRELIN
   FLUX="UUMGTRTTRS04" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
   If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  # To Update EXPENSES table
  Gosub MAJ30_EXS
  If GOK<1 : Break 2 : Endif

  NB+=1
  If NB>GMAXUPDTRS
   TABMIGKEY(1) = [F:EXSM]CPY
   TABMIGKEY(2) = num$([F:EXSM]ACCNUM)
   STOP=1
   Break 2
  Endif
 $SUITE_BOUCLE
 Next
Next

$FIN_BOUCLE
If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS04",7,ERR) From TRTMIG
Else
 Flush [F:EXS]
 If fstat
  Call ECR_TRACE("File EXPENSES, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub EXS_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 # To Save values of key ACLEx/STOP in AMIGKEY table
 If STOP
  TABMIGKEY(3)=num$(STOP)
 Else
  Raz TABMIGKEY
 Endif
 Call MIGSTKKEY (DOSSIER,"UUMGTRTTRS04",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
 If ERR
  GOK=-1 : Goto FIN_BOUCLE
 Endif
 Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTTRS04",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_TRS04
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [EXS]
Close Local File [EXSM]
Close Local File [GCM], [LED], [CPY]

#----- To Re-Update files where we will insert
Call MIGTABEND (DOSSIER,"EXPENSES",ERR) From TRTMIG

$FIN
Call MIGTRTEND (DOSSIER,"UUMGTRTTRS04") From TRTMIG
Call ECR_TIME("UUMGTRTTRS04 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

#############################################################################################################
$MAJ30_EXS
#--- Transclass
#Raz [EXS]  # expensive... must RAZ new V6 fields
[EXS] = [EXSM]

#--- New fields's assignation
For IREF=1 To dim([F:GCM]LED)
 If [F:GCM]LED(IREF-1)<>""
  [F:EXS]LED(IREF-1) = [F:GCM]LED(IREF-1)
  [F:EXS]CURLED(IREF-1) = [F:GCM]CUR(IREF-1)
  [F:EXS]RATDIV(IREF-1) = 1
  If find(IREF,1,2,3)
   [F:EXS]RATMLT(IREF-1) = [F:EXSM]RATCUR
  Else
   [F:EXS]RATMLT(IREF-1) = [F:EXSM]RATRPT
  Endif
 Else # useful to delete intruction RAZ
  [F:EXS]LED(IREF-1)    = ""
  [F:EXS]CURLED(IREF-1) = ""
  [F:EXS]RATDIV(IREF-1) = 0
  [F:EXS]RATMLT(IREF-1) = 0
 Endif
Next

For AXE=1 To min([L]NBRAXE,dim([F:EXS]DIE))
 If [L]AXEA(AXE)<>""
  [F:EXS]DIE(AXE-1) = [L]AXEI(AXE)
 Else
  Break
 Endif
Next

Gosub WRI_EXS
Return

# Write Instruction
$WRI_EXS
# To Save reference
Gosub EXS_STK
WriteB [F:EXS]
If fstat
 Call ECR_TRACE("File EXPENSES, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub EXS_ERRTRA
 GOK=0 : Return
Endif
Return

################################################
$EXS_STK
Call STK (WTAB_EXS,WCPT_EXS,num$([F:EXS]ACCNUM)) From TRTMIG
Return

#################################################
$EXS_ERRTRA
Call ERRTRA (WTAB_EXS,WCPT_EXS,"File EXPENSES(ACCNUM)=") From TRTMIG
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTTRS04(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGTRTTRS04(APPLI)
End

