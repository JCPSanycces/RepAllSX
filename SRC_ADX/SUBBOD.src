# Issue 110957 - 2015-09-21 by GH
If !mkstat & !GIMPORT &  dim([M:BOH0]CRID)=1 & func ECCLIB.NBRCPN([M:BOH0]ITMREF)=2
    [M:BOH0]CRID = func TRTX3FNC.CCMID([M:BOH0]ITMREF,[M:BOH0]BOHECCMAJ,VALEUR)
    Affzo [BOH0]CRID
    If dim([M:BOH0]CRFLG)>0
       [M:BOH0]CRFLG = string$([M:BOH0]CRID<>"","151") : Affzo [BOH0]CRFLG
