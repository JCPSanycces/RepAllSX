######################################################################################
Subprog B1_BOMALT(VALEUR)
Variable Decimal VALEUR
Local Char     WCLE1(15)
Local Char     WCLE2(15)
#
Case GFONBOD
    When "BOMC" :  WCLE2= num$(1)
    When "BOMP" :  WCLE2= num$(2)
    When "BOMS" :  WCLE2= num$(3)
Endcase
Local File TABBOMALT [TBO] Where BOMALTTYP = val(WCLE2)
WCLE1 = num$(VALEUR)
Call OBJET("TBO",WCLE1,WCLE2) From GOBJET
VALEUR = [F:TBO]BOMALT

End

