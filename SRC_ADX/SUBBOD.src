##########################################################################
## Etiquette ajoutée par le superviseur 11/03/2004 14:15:35 (MM)
##########################################################################
# Process : Rendre possible la saisie de la quantité de lien en US- 03.04 MM
Subprog AM_LIKQTY(VALEUR)
Variable Decimal VALEUR

# Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
If [M:BOH0]BOMALTTYP=1
  # Saisie exclusive entre Qté lien et formule qté
  If instr(1,dbgstr(1),"BOD1")
    If VALEUR<>0 Raz [M:BOD1]FORQTY(nolign-1) Endif
  Elsif instr(1,dbgstr(1),"BOM2")
    If VALEUR<>0 Raz [M:BOM2]FORQTY Endif
  Endif
Endif

If instr(1,dbgstr(1),"BOD1")
    If [M]CPNTYP(nolign-1) = 5 : mkstat = 1 : End : Endif
    If dim([M]WBOMSTUCOE(nolign-1))>0
      If dim([M]BOMSTUCOE(nolign-1))>0
          [M]WBOMSTUCOE(nolign-1) = [M]BOMSTUCOE(nolign-1)
      Else
          [M]WBOMSTUCOE(nolign-1) = 0
      Endif
    Endif
Elsif instr(1,dbgstr(1),"BOM1")
    If dim([M]BOMSTUCOE)>0
        [M]WBOMSTUCOE = [M]BOMSTUCOE
    Else
        [M]WBOMSTUCOE =0
    Endif
Endif
End

Subprog AS_SCOFLG(VALEUR)
Variable Integer VALEUR
#-X3Suivi 71277)
# If find([M]CPNTYP(nolign-1),2,3,4,6,7,8,9) mkstat = 2 Endif
# Type =1 "Interne" inutilisable sur nomenclature de sous-traitance
# Type =2 "A envoyer au SST" inutilisable sur nomenclature de SST si article géré en E/S globale  : # Issue 110327
Case GFONBOD
   When "BOMS" :
       GMENLOC(1)=1
       #--- Issue 110327
       If [F:ITM]ITMREF<>[M:BOD1]CPNITMREF(nolign-1)
         Read [ITM]ITM0=[M:BOD1]CPNITMREF(nolign-1)
       Endif
       If [F:ITM]SERMGTCOD=4
         GMENLOC(2)=1
       Else
         GMENLOC(2)=0
       Endif
       #---
Endcase
End

