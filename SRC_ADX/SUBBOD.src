        GMESSAGE = mess(41,2324,1)
        mkstat = 2
        End
   Endif
Elsif  instr(1,dbgstr(1),"BOM1")
   If [M:BOM1]CPNOPE = 900 & !find(VALEUR,1,8,9)
        GMESSAGE = mess(41,2324,1)
        mkstat = 2
        End
   Endif
Endif
End

