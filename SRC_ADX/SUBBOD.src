Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Call AS_ECCVALMAJ(VALEUR) From ECCBOM
End

Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Call C_ECCVALMAJ(VALEUR) From ECCBOM
# Issue 110957 - 2015-09-21 by GH
If !mkstat & !GIMPORT
   If dim([M]CRID)=1 & func ECCLIB.NBRCPN([M]CPNITMREF)=1
      [M]CRID = func TRTX3FNC.CCMID([M]CPNITMREF,VALEUR,"")
      Affzo CRID
      If dim([M]CRFLG)=1
         [M]CRFLG = string$([M]CRID<>"","151") : Affzo CRFLG
      Endif
   Elsif dim([M]CRID)>1 & func ECCLIB.NBRCPN([M]CPNITMREF(nolign-1))=1
      [M]CRID(nolign-1) = func TRTX3FNC.CCMID([M]CPNITMREF(nolign-1),VALEUR,"")
      Affzo CRID(nolign-1)
      If dim([M]CRFLG)=dim([M]CRID)
         [M]CRFLG(nolign-1) = string$([M]CRID(nolign-1)<>"","151") : Affzo CRFLG(nolign-1)
      Endif
   Endif
Endif
End

