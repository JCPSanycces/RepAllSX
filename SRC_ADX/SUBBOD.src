#CATUA X3-30162.sn
#Manage container fields in BOM
Subprog AV_CTN(VALEUR)
Variable Char VALEUR()
  If dim([M:BOD1]CTN(nolign-1))>0 & dim([M:BOD1]PKC(nolign-1))>0
    If find([M:BOD1]PKC(nolign-1),2,4,6)
      Actzo [M:BOD1]CTN(nolign-1)
    Else
      Grizo [M:BOD1]CTN(nolign-1)
    Endif
    Call DISP_CTN_FLDS(VALEUR)
  Endif
End

Subprog AM_CTN(VALEUR)
Variable Char VALEUR()
  If dim([M:BOD1]CTN(nolign-1))>0 & dim([M:BOD1]PKC(nolign-1))>0
    Call DISP_CTN_FLDS(VALEUR)
  Endif
End

#Show display only fields 'container weight unit' and 'container capacity'
Subprog DISP_CTN_FLDS(CTNCODE)
Value Char CTNCODE
  Local Integer ISEMPTY

  ISEMPTY=1
  If clalev ([F:CTN])=0  Local File CONTAINERS [CTN] Endif
  If CTNCODE<>""
    Read [CTN]CTN0=CTNCODE
    If !fstat
      ISEMPTY=0
      [M:BOD1]CTNWEU(nolign-1) = [CTN]CTNWEU
      [M:BOD1]CTNCAP(nolign-1) = [CTN]CTNCAP
    Endif
  Endif

  If ISEMPTY
    Raz [M:BOD1]CTNWEU(nolign-1)
    Raz [M:BOD1]CTNCAP(nolign-1)
  Endif

  Affzo [M:BOD1]CTNWEU(nolign-1)
  Affzo [M:BOD1]CTNCAP(nolign-1)
End
#CATUA X3-30162.en

