######################################################################################
## Etiquette ajoutée par le superviseur (écran BOD2) 10/08/2012 16:19:52 (LD)
######################################################################################
Subprog AS_FORSEL(VALEUR)
Variable Char    VALEUR()

# Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales

# Clé non modifiable
#If (GREP = "M" | GREP = "") & (VALEUR <> "" | [M:BOD1]CPNITMREF(nolign-1)<>"") & [M:BOD1]CREFLG(nolign-1) > 0
#   mkstat = 2 : End
#Endif

If [M:BOH0]BOMALTTYP = 1
    # Saisie exclusive entre Référence composant et formule sélection
    If instr(1,dbgstr(1),"BOD1")
      If [M:BOD1]CPNITMREF(nolign-1)<>"" mkstat=2 : End : Endif
    Elsif instr(1,dbgstr(1),"BOM2")
      If [M:BOM2]CPNITMREF<>"" mkstat=2 : End : Endif
    Endif
    # Une seule formule sélection possible par n° de séquence
    If VALEUR =""
      If instr(1,dbgstr(1),"BOD1")
        If sigma(0,[M:BOD1]NBLIG-1,[M:BOD1]BOMSEQ(indcum)=[M:BOD1]BOMSEQ(nolign-1)& [M:BOD1]FORSEL(indcum)<>"")
          mkstat=2
        Endif
      Elsif instr(1,dbgstr(1),"BOM2")
        If sigma(0,[M:BOD1]NBLIG-1,[M:BOD1]BOMSEQ(indcum)=[M:BOM2]BOMSEQ & [M:BOD1]FORSEL(indcum)<>"")
          mkstat=2
        Endif
      Endif
    Endif
Endif
End
######################################################################################
Subprog C_FORSEL(VALEUR)
Variable Char    VALEUR()
# Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
# Référence composant ou formule sélection sont obligatoires
If [M:BOH0]BOMALTTYP = 1
  If instr(1,dbgstr(1),"BOD1")
    If VALEUR="" & [M:BOD1]CPNITMREF(nolign-1) ="" mkstat = 1 : GMESSAGE = mess(577,199,1) : End : Endif
  Elsif instr(1,dbgstr(1),"BOM2")
    If VALEUR="" & [M:BOM2]CPNITMREF ="" mkstat = 1 : GMESSAGE = mess(577,199,1) : End : Endif
  Endif
Endif
End
######################################################################################
Subprog AM_FORSEL(VALEUR)
Variable Char    VALEUR()
# Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
If [M:BOH0]BOMALTTYP = 1
  # Saisie exclusive entre formule de sélection et composant
  If instr(1,dbgstr(1),"BOD1")
    If VALEUR<>"" Raz [M]CPNITMREF(nolign-1) Endif
  Elsif instr(1,dbgstr(1),"BOM2")
    If VALEUR<>""
        Raz [M:BOM2]CPNITMREF
        If [M:BOM2]CPNTYP < 2 [M:BOM2]CPNTYP = 9 : Affzo [M:BOM2]CPNTYP : Endif
    Endif
  Endif
Endif
End
######################################################################################
Subprog AS_FORQTY(VALEUR)
Variable Char    VALEUR()
# Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
If [M:BOH0]BOMALTTYP = 1
  # Saisie exclusive entre formule qté et qté lien
  # Saisie formule qté ssi formule sélection
  If instr(1,dbgstr(1),"BOD1")
    If [M:BOD1]LIKQTY(nolign-1)<>0 mkstat=2 Endif
    If [M:BOD1]FORSEL(nolign-1)="" mkstat=2 Endif
  Elsif instr(1,dbgstr(1),"BOM2")
    If [M:BOM2]LIKQTY<>0 mkstat=2 Endif
    If [M:BOM2]FORSEL="" mkstat=2 Endif
  Endif
Endif
End
######################################################################################
Subprog C_FORQTY(VALEUR)
Variable Char    VALEUR()
# Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
If [M:BOH0]BOMALTTYP = 1
  # Formule qté ou qté lien sont obligatoires
  If instr(1,dbgstr(1),"BOD1")
    If VALEUR="" & [M]LIKQTY(nolign-1) =0 mkstat = 1 : GMESSAGE = mess(578,199,1) Endif
  Elsif instr(1,dbgstr(1),"BOM2")
    If VALEUR="" & [M]LIKQTY =0 mkstat = 1 : GMESSAGE = mess(578,199,1) Endif
  Endif
Endif

End
######################################################################################
Subprog AM_FORQTY(VALEUR)
Variable Char    VALEUR()
# Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
If [M:BOH0]BOMALTTYP = 1
  # Saisie exclusive entre formule qté et qté lien
  If instr(1,dbgstr(1),"BOD1")
    If VALEUR<>"" Raz [M]LIKQTY(nolign-1) Endif
  Elsif instr(1,dbgstr(1),"BOM2")
    If VALEUR<>"" Raz [M]LIKQTY Endif
  Endif
Endif
End

######################################################################################
Subprog AV_LSTFLD(VALEUR)
Variable Char    VALEUR()

# 98144 - Food allergens - hide fields when not production BOM
If GFONBOD <> "BOMP" & func AFNC.ACTIV("FOA")
  Chgfmt [M:BOH0]ALG    With "-K:1B"
  Chgfmt [M:BOH0]ALGDAT With "-D:"+GFMDAT4
  Chgfmt [M:BOH0]ALGBOM With "-K:1B"
Endif

If GFONBOD = "BOMC" & dim([M:BOH0]ECCSTRDAT)=1 # GH 12/10/2015 bug 111671
   Chgfmt [M:BOH0]ECCSTRDAT  With "-"+GFMD
   Chgfmt [M:BOH0]ECCENDDAT  With "-"+GFMD
Endif
End

######################################################################################
## Section automatically added (screen BOH0) 01/12/2015 16:09:05 (FRHOL)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

# Issue 104494 - 2014-12-23 by FRHOL : Title must be initialized with product description
# If item changed then read description
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:BOH0]BOMDESAXX, "[F:ITM]") From TRTX3
Affzo [BOH0]BOMDESAXX
# End issue 104494

Call AM_ITMREF(VALEUR) From ECCBOM

# Issue 110957 - 2015-09-21 by GH and SLL
# Check for Change Request if Parent Product is not version managed OR if Commercial BOM
If !mkstat & !GIMPORT & dim([M]CRID)=1 & varmode([M]CRID)<>3 &
& (GFONBOD = "BOMC" | func ECCLIB.NBRCPN(VALEUR)<1)
    [M:BOH0]CRID = func TRTX3FNC.CCMID(VALEUR,"","")
    Affzo [BOH0]CRID
    If dim([M:BOH0]CRFLG)>0
       [M:BOH0]CRFLG = string$([M:BOH0]CRID<>"","151") : Affzo [BOH0]CRFLG
    Endif
Endif

# Issue 112881 - 2016-04-15 by BEEBE : Check for Subcontracting BOM that Product is received Product
If GFONBOD="BOMS" & [F:ITM]RCPFLG<>2
    mkstat=2
    GMESSAGE=mess(230,187,1)
Endif
# End issue 112881
End

