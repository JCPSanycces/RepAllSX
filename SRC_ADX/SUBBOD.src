######################################################################################
## Etiquette ajoutée par le superviseur (écran BOD1) 03/05/2010 16:18:23 (MM)
######################################################################################
Subprog AS_LEVSET(VALEUR)
Variable Integer VALEUR
Local Integer OK : OK = 1

# 119030 mm 10.2016
# matière non pesée en centrale : ça n'a pas de sens de définir l'endroit où trouver la tolérance de pesée
If instr(1,dbgstr(1),"BOD1") & [M]PKC(nolign-1)=1
    VALEUR = 1 : mkstat = 2
    If [M]ITMTOLPOS(nolign-1)<>0 : Raz [M]ITMTOLPOS(nolign-1) : Endif
    If [M]ITMTOLNEG(nolign-1)<>0 : Raz [M]ITMTOLNEG(nolign-1) : Endif
    End
Elsif  instr(1,dbgstr(1),"BOM1") & [M]PKC = 1
    VALEUR = 1 : mkstat = 2
    If [M]ITMTOLPOS<>0 : Raz [M]ITMTOLPOS : Endif
    If [M]ITMTOLNEG<>0 : Raz [M]ITMTOLNEG : Endif
    End
Endif

If find ([M]PKC(nolign-1),8,9)
    GMENLOC(1) = 0
Else
    GMENLOC(1) = 1     # 119030 mm 10.2016 -  make disappear first value of the local menu
Endif

If VALEUR=4  # ancienne valeur = nomenclature
   Call OUINON(mess(981,196,1),OK) From GESECRAN
   If OK=2
      If instr(1,dbgstr(1),"BOD1")
        [M]TOLSAISIE(nolign-1) = OK
        Raz [M]ITMTOLNEG(nolign-1),ITMTOLPOS(nolign-1)
      Elsif instr(1,dbgstr(1),"BOM1")
        [M]TOLSAISIE = OK
        Raz [M]ITMTOLNEG,ITMTOLPOS
      Endif
   Else
      If instr(1,dbgstr(1),"BOD1")
        [M]TOLSAISIE(nolign-1) = OK
      Elsif instr(1,dbgstr(1),"BOM1")
         [M]TOLSAISIE = OK
      Endif
      mkstat=2 : End
   Endif
Endif

End

######################################################################################
Subprog AS_ITMTOLPOS(VALEUR)
Variable Decimal VALEUR
If clalev ([F:HSH])=0  Local File HANDLING [HSH] Endif

If instr(1,dbgstr(1),"BOD1")
  If [M]LEVSET(nolign-1) = 4 &  [M]TOLSAISIE(nolign-1) = 1  : mkstat=2 : End : Endif
  If find([M]LEVSET(nolign-1),1,2,3) : mkstat=2 : Endif
  Case [M]LEVSET(nolign-1)
    When 1,4 : # If VALEUR : Raz VALEUR : Endif            # 77667
    When 2 : # Récupération de la tolérance >0 de la fiche ISM
        If [F:ITF]ITMREF <> [M]CPNITMREF(nolign-1)
          Read [ITF]ITF0= [M]CPNITMREF(nolign-1);[M:BOH0]STOFCY
          If fstat : Raz [F:ITF] : Endif
        Endif
        Read [HSH]HSH0 = [F:ITF]ISM
        If fstat: Raz [F:HSH] : Endif
        VALEUR = [F:HSH]ITMTOL
    When 3: # Récupération de la tolérance >0 de l'article-site
        If [F:ITF]ITMREF <> [M]CPNITMREF(nolign-1)
          Read [ITF]ITF0= [M]CPNITMREF(nolign-1);[M:BOH0]STOFCY
          If fstat : Raz [F:ITF] : Endif
        Endif
        VALEUR = [F:ITF]ITMTOLPOS
  Endcase
Elsif instr(1,dbgstr(1),"BOM1")
  If [M]LEVSET = 4 &  [M]TOLSAISIE = 1  : mkstat=2 : End : Endif
  If find([M]LEVSET,1,2,3) : mkstat=2 : Endif
  Case [M]LEVSET
    When 1,4 : # If VALEUR : Raz VALEUR : Endif        # 77667
    When 2 : # Récupération de la tolérance >0 de la fiche ISM
        If [F:ITF]ITMREF <> [M]CPNITMREF
           Read [ITF]ITF0= [M]CPNITMREF;[M:BOH0]STOFCY
           If fstat : Raz [F:ITF] : Endif
        Endif
        Read [HSH]HSH0 = [F:ITF]ISM
        If fstat: Raz [F:HSH] : Endif
        VALEUR = [F:HSH]ITMTOL
    When 3: # Récupération de la tolérance >0 de l'article-site
        If [F:ITF]ITMREF <> [M]CPNITMREF
          Read [ITF]ITF0= [M]CPNITMREF;[M:BOH0]STOFCY
          If fstat : Raz [F:ITF] : Endif
        Endif
        VALEUR = [F:ITF]ITMTOLPOS
  Endcase
Endif
End

######################################################################################
Subprog AS_ITMTOLNEG(VALEUR)
Variable Decimal VALEUR
If clalev ([F:HSH])=0  Local File HANDLING [HSH] Endif

If instr(1,dbgstr(1),"BOD1")
  If [M]LEVSET(nolign-1) = 4 & [M]TOLSAISIE(nolign-1) = 1  : mkstat=2 : End : Endif
  If find([M]LEVSET(nolign-1),1,2,3) : mkstat=2 : Endif
  Case [M]LEVSET(nolign-1)
    When 1,4 : # If VALEUR : Raz VALEUR : Endif        # 77667
    When 2 : # Récupération de la fiche ISM de l'article
        If [F:ITF]ITMREF <> [M:BOD1]CPNITMREF(nolign-1)
          Read [ITF]ITF0=[M]CPNITMREF(nolign-1);[M:BOH0]STOFCY
          If fstat : Raz [F:ITF] : Endif
        Endif
        Read [HSH]HSH0 = [F:ITF]ISM
        If fstat: Raz [F:HSH] : Endif
        VALEUR =[F:HSH]ITMTOLNEG
     When 3: # Récupération de la tolérance <0 de l'article-site
        If [F:ITF]ITMREF <> [M:BOD1]CPNITMREF(nolign-1)
         Read [ITF]ITF0= [M]CPNITMREF(nolign-1);[M:BOH0]STOFCY
         If fstat : Raz [F:ITF] : Endif
        Endif
        VALEUR = [F:ITF]ITMTOLNEG
  Endcase
Elsif instr(1,dbgstr(1),"BOM1")
  If [M]LEVSET = 4 &  [M]TOLSAISIE = 1  : mkstat=2 : End : Endif
  If find([M]LEVSET,1,2,3) : mkstat=2 : Endif
  Case [M]LEVSET
     When 1,4 : # If VALEUR : Raz VALEUR : Endif        # 77667
     When 2 : # Récupération de la fiche ISM de l'article
        If [F:ITF]ITMREF <> [M]CPNITMREF
          Read [ITF]ITF0=[M]CPNITMREF(nolign-1);[M:BOH0]STOFCY
          If fstat : Raz [F:ITF] : Endif
        Endif
        Read [HSH]HSH0 = [F:ITF]ISM
        If fstat: Raz [F:HSH] : Endif
        VALEUR =[F:HSH]ITMTOLNEG
     When 3: # Récupération de la tolérance <0 de l'article-site
       If [F:ITF]ITMREF <> [M]CPNITMREF
        Read [ITF]ITF0= [M]CPNITMREF;[M:BOH0]STOFCY
        If fstat : Raz [F:ITF] : Endif
       Endif
       VALEUR = [F:ITF]ITMTOLNEG
  Endcase
Endif
End

