#########################################################
## tableaux des nomenclatures détails          Thierry B
## Modif GA 21/06/2005 ajout BOMS
########################################################
# Ce traitement nécessite d'avoir
# GFONBOD : positionné avant son appel
#           ("BOMC":commerciale, "BOMP":production, "BOMS":sous-traitance)
########################################################
# Ce traitement nécessite d'avoir
# GFONBOD : positionné avant son appel
#           ("BOMC":commerciale, "BOMP":production, "BOMS":sous-traitance)
# GBOMALT : Tableau des alternatives acceptées (en tunnel)
# GDATEREF: déclarée et initialisée si besoin
########################################################
#Call OBJET("BOD",GBIDC1,GBIDC2) From GOBJET
#End
########################################################

$ACTION
Case ACTION
 When "VARIANTE"         : Gosub VARIANTE From SUBBODA
 When "AVANT_OUVRE"      : Gosub AVANT_OUVRE From SUBBODA
 When "OUVRE"            : Gosub OUVRE From SUBBODA
 When "OUVRE_BATCH"      : Gosub OUVRE From SUBBODA          : # GA 10/2008
 When "OUVRE_BOITE"      : Gosub OUVRE_BOITE  From SUBBODA
 When "HINTCLE"          : Gosub HINTCLE      From SUBBODA
 When "STATUT"           : Gosub STATUT From SUBBODA
 When "FERME"            : Gosub FERME From SUBBODA
 When "VERIF_CRE"        : Gosub VERIF_CRE From SUBBODA
 When "VERIF_MOD"        : Gosub VERIF_MOD From SUBBODA
 When "INICRE"           : Gosub INICRE From SUBBODA
 When "INIMOD"           : Gosub INICRE From SUBBODA
 When "CREATION"         : Gosub CREATION From SUBBODA
 When "APRES_CRE"        : Gosub APRES_CRE From SUBBODA
 When "AVANT_MODFIC"     : Gosub AVANT_MODFIC From SUBBODA
 When "APRES_MOD"        : Gosub APRES_MOD From SUBBODA
 When "APRES_MODIF"      : Gosub APRES_MODIF From SUBBODA
 When "MODIF"            : Gosub MODIF From SUBBODA
 When "FILTRE"           : Gosub FILTRE From SUBBODA
 When "LIENS"            : Gosub LIENS From SUBBODA
 When "SETBOUT"          : Gosub SETBOUT From SUBBODA
 When "AVANTBOUT"        : Gosub AVANTBOUT From SUBBODA
 When "EXEBOUT"          : Gosub EXEBOUT From SUBBODA
 When "EXEACT"           : Gosub EXEACT From SUBBODA     # 27172 12.04 MM
 When "VERF_ANU"         : Gosub VERF_ANU From SUBBODA
 When "ANNULE"           : Gosub ANNULE From SUBBODA
 When "AP_ANNULE"        : Gosub AP_ANNULE From SUBBODA
 When "RAZCRE"           : Gosub RAZCRE From SUBBODA
 When "RAZDUP"           : Gosub RAZDUP From SUBBODA
 When "ABANDON"          : Gosub SUPPRESS_TEX From SUBBODA
 When "AB_CREATION"      : Gosub SUPPRESS_TEX From SUBBODA
 When "FILGAUCHE"        : Gosub FILGAUCHE From SUBBODA
 When "TIROIR"           : Gosub TIROIR    From SUBBODA
 When "FIN_ACTION"       : Gosub FIN_ACTION  From SUBBODA   # 12.06 demande 38646
 When "SEL_TABLE"        : Gosub SEL_TABLE From SUBBODA
 When "EFFMASK"          : Gosub EFFMASK From SUBBODA
 When "AFFMASK"          : Gosub AFFMASK From SUBBODA
Endcase
Return

########################################
## Etiquettes de l'écran             ###
########################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:BOH0]OPTION_ITM = ""
[M:BOH0]FILTRE = ""
# GA 21/06/2005 option de selection pour le type d'alternative
Case GFONBOD
    When "BOMC": [M:BOH0]OPTIONA    = "A" : # Nomenclature commerciale
                 [M:BOH0]BOMALTTYP  =  1
                 [M:BOH0]OPTION_ITM = "K" : # Sélection des articles vendus FQ 48056 GA 02/2009
                 [M:BOH0]FILTRE     = "SALFLG=2" : # Article vendu

    When "BOMP": [M:BOH0]OPTIONA    = "B" : # Nomenclature production
                 [M:BOH0]BOMALTTYP  =  2
                 [M:BOH0]OPTION_ITM = "C" : # Sélection des articles fabriqués
                 [M:BOH0]FILTRE     = "MFGFLG=2" : # Article fabriqué

    When "BOMS": [M:BOH0]OPTIONA    = "D"    : # Alternative de Nomenclature sous-traitance
                 [M:BOH0]BOMALTTYP  =  3
                 [M:BOH0]OPTION_ITM = "D" : # Sélection des articles sous-traités
                 [M:BOH0]FILTRE     = "SCPFLG=2" : # Article sous-traité
Endcase
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR
If GFONBOD = "BOMC"
  [M:BOH0]BOMSTU = [F:ITM]SAU
Else
  [M:BOH0]BOMSTU = [F:ITM]STU
Endif
#[M:BOH0]BOMDES = [F:ITM]ITMDES1
#Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:BOH0]BOMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
#Affzo[M:BOH0]BOMDES
# FGR 01/10/2009 : X3SUIVI57935
End

########################################
Subprog AP_DATREF(VALEUR)
Variable Date     VALEUR
# pour rafraichir le tableau (var globale pour être utilisée dans ACTION)
# GDATEREF = VALEUR
If VALEUR<>GDATEREF
   GDATEREF = VALEUR
#   SDATEREF = VALEUR
#   Gosub LIENS From SUBBODA
#   Affzo [M:BOD1]
   # bug 17507 Date pour composants en pourcentage 03/03/03
   If VALEUR="00/00/00"
    [M:BOH0]CUMREF = datesyst
   Else
    [M:BOH0]CUMREF = VALEUR
   Endif
Endif
End

######################################################
Subprog IB_BOMALT
If GREP = "C" | GREP = "D" :# Sélect sur BOD
  GBOUT2 = ""
Endif
End

######################################################
Subprog C_BOMALT(VALEUR)
Variable Decimal  VALEUR
Local    Integer WLLCTYP :   WLLCTYP = func LLCLIB.LLCTYP([M:BOH0]BOMALTTYP)

Read [TBO]TBO0 = [M:BOH0]BOMALTTYP;VALEUR
If fstat
    GMESSAGE = mess(23,100,1)
    mkstat = 2 : End
Endif
# sr 06.06 c'est ici seulement que l'on peut contrôler la catégorie article
If [F:ITM]ITMREF <> [M:BOH0]ITMREF
    Read [ITM]ITM0 = [M:BOH0]ITMREF
    If fstat : Raz [F:ITM] : Endif
Endif
If [F:TBO]FCY <> ""
    Read [ITG]ITG0=[F:TBO]FCY;[F:ITM]TCLCOD
    If fstat
        Read [ITG]ITG0="";[F:ITM]TCLCOD
        If fstat : Raz [F:ITG] : Endif
    Endif
Else
    Read [ITG]ITG0="";[F:ITM]TCLCOD
    If fstat : Raz [F:ITG] : Endif
Endif
If GFONBOD = "BOMC"
  If [F:ITG]SALFLG <> 2
    GMESSAGE = mess(221,199,1) : # "L'article doit être de catégorie vendue"
    mkstat = 2 : End
  Endif
Endif
# Issue 72025 - 2011-03-02 by CCC
#If GFONBOD = "BOMP"
#  If [F:ITG]MFGFLG <> 2 & [F:ITG]PHAFLG <> 2
#    GMESSAGE = mess(528,199,1) : # "Article non fabriqué"
#    mkstat = 2 : End
#  Endif
#Endif
# GA 17/11/2005 article sous-traité
If GFONBOD = "BOMS"
   If [F:ITG]SCPFLG <> 2
      GMESSAGE = mess(513,199,1) : # "L'article doit être de catégorie sous-traitée"
      mkstat = 2 : End
   Endif
Endif
If GFONBOD = "BOMS" | GFONBOD = "BOMP"
  # Ajout GA 24/11/2005
  # un article sous-traitance ne peut pas etre composé (à valider LLC)
  # Issue 112531  - 2015-11-18 by MAE : type sous traitance : service + acheté
  #If [F:ITG]SCSFLG = 2
  If [F:ITG]SCSFLG = 2 & [F:ITG]PURFLG = 2
    GMESSAGE = mess(164,199,1) : # "Article de type 'service' non autorisé"
    mkstat = 2 : End
  Endif
Endif

If GREP = "C" | GREP = "D"
#  vérifier qu'on n'atteint pas le niveau maximum de nomenclature
   Read [ITB]ITB0=[M:BOH0]ITMREF;VALEUR;WLLCTYP
   If !fstat & [F:ITB]LLC >= GBOMLEV
       GMESSAGE = mess(89,199,1)
       mkstat = 2 : End
   Endif
   Read [ACC]CODACC = GUSER;[F:TBO]ACSCOD # accès par utilisateur (enreg avec code "" existe toujours)
   If fstat & GUSRACS < 2
       GMESSAGE = mess(57,133,1)-[F:TBO]ACSCOD # "code d'accès non autorisé" Corr 21936
       mkstat = 2 : End
   Endif
Endif
# 27172 12.04 MM
If GREP= "C" & !fstat & [F:ACC]MODIF=1
   GMESSAGE = mess(144,199,1) # Pas d'autorisation de modification sur cette alternative
   mkstat = 2 : End
Endif
# 150
# "Mauvais type d'alternative" (il est induit par la fonction)
# GA 21/06/2005 ajout d'un 3eme type d'alternative
#If (GFONBOD = "BOMC" & [F:TBO]BOMALTTYP = 2)
#&  | (GFONBOD = "BOMP" & [F:TBO]BOMALTTYP = 1)
#If   (GFONBOD = "BOMC" & [F:TBO]BOMALTTYP <> 1)
#&  | (GFONBOD = "BOMP" & [F:TBO]BOMALTTYP <> 2)
#&  | (GFONBOD = "BOMS" & [F:TBO]BOMALTTYP <> 3)
#   mkstat = 2 : GMESSAGE = mess(225,199,1) : End # "Mauvais type d'alternative"
#Endif

[M:BOH0]STOFCY=[F:TBO]FCY : Affzo [BOH0]STOFCY : # GH 22/02/2013 bug 88047

Call C_BOMALT(VALEUR) From ECCBOM
End

######################################################
Subprog AS_DATREF(VALEUR)
Variable Date     VALEUR
If find(GREP,"M","C","D") : mkstat = 2 : End : Endif
If VALEUR = [0/0/0] : VALEUR = date$ : Endif
End

######################################################
Subprog C_BOHSTRDAT(VALEUR)
Variable Date     VALEUR

Call C_BOHSTRDAT(VALEUR) From ECCBOM
If mkstat : End : Endif

# s'il existe des lignes hors de la fourchette, msg bloquant
If VALEUR > [F:BOH]BOHSTRDAT
   For nolign = 1 To [M:BOD1]NBLIG
     If dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]ECCSEQ=0 | [M:BOD1]CPNTYP(nolign-1)<>1 : # Versioning
#       If [M:BOD1]BOMSTRDAT(nolign-1) < VALEUR bug 75776 22/08/11
       If [M:BOD1]BOMSTRDAT(nolign-1) < VALEUR & [M:BOD1]BOMSTRDAT(nolign-1) <>[0/0/0]
          GMESSAGE = mess(70,199,1) : mkstat=2 : Break
       Endif
     Endif
   Next
# Issue 115658 - 2016-10-19 by CCC : control services too in Sub-contracting BOM
   If clalev([M:BOS2])
       For nolign = 1 To [M:BOS2]NBLIG
         If dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]ECCSEQ=0 | [M:BOS2]CPNTYP(nolign-1)<>1 : # Versioning
           If [M:BOS2]BOMSTRDAT(nolign-1) < VALEUR & [M:BOS2]BOMSTRDAT(nolign-1) <>[0/0/0]
              GMESSAGE = mess(70,199,1) : mkstat=2 : Break
           Endif
         Endif
       Next
   Endif

# regarder les éventuels enregistrements non visibles
   If [M:BOH0]DATREF <> [0/0/0] & !mkstat
      For [BOD] Where ITMREF=[M:BOH0]ITMREF & BOMALT=[M:BOH0]BOMALT & BOMALTTYP = [M:BOH0]BOMALTTYP
&                  & (BOMSTRDAT > [M:BOH0]DATREF | (BOMENDDAT < [M:BOH0]DATREF & BOMENDDAT<>[0/0/0]))
#                  & (BOMSTRDAT > [M:BOH0]DATREF | BOMENDDAT < [M:BOH0]DATREF)
#    If [F:BOD]BOMSTRDAT < VALEUR bug 75776 22/08/11
        If [F:BOD]BOMSTRDAT < VALEUR & [F:BOD]BOMSTRDAT <> [0/0/0]
          GMESSAGE = mess(70,199,1)
          GMESSAGE+="\ ("+mess(441,199,1)+")"  # + "Lignes non affichées"14/05/03
          mkstat=2 : Break
        Endif
      Next
   Endif
# "Il existe des lignes avec des dates hors de ces bornes"
Endif
End

######################################################
Subprog C_BOHENDDAT(VALEUR)
Variable Date     VALEUR
# Vérifier les dates des liens si l'on rapproche la date de fin
If VALEUR <> [0/0/0] & (VALEUR < [F:BOH]BOHENDDAT |  [F:BOH]BOHENDDAT = [0/0/0])
   For nolign = 1 To [M:BOD1]NBLIG
       # Corr 17896 (Tester aussi le cas de date vide !)     15/05/03
      #If [M:BOD1]BOMENDDAT(nolign-1)>VALEUR | [M:BOD1]BOMENDDAT=[0/0/0] bug 64194 il manquait le nolign-1
       If [M:BOD1]BOMENDDAT(nolign-1)>VALEUR | [M:BOD1]BOMENDDAT(nolign-1)=[0/0/0]
          GMESSAGE = mess(70,199,1) : mkstat = 2 : Break
       Endif
   Next
   # regarder les éventuels enregistrements non visibles
   If [M:BOH0]DATREF <> [0/0/0] & GMESSAGE = ""
     For [BOD] Where ITMREF=[M:BOH0]ITMREF & BOMALT=[M:BOH0]BOMALT & BOMALTTYP = [M:BOH0]BOMALTTYP
&            & (BOMSTRDAT > [M:BOH0]DATREF | BOMENDDAT < [M:BOH0]DATREF)
       # Corr 17896 (Tester aussi le cas de date vide !)     15/05/03
       If [F:BOD]BOMENDDAT > VALEUR | [F:BOD]BOMENDDAT=[0/0/0]
          GMESSAGE = mess(70,199,1) : mkstat = 2 : Break
       Endif
     Next
   Endif
Endif
End

######################################################
Subprog AS_BASQTY(VALEUR)
Variable Decimal  VALEUR
# initialisation de la quantité selon le code quantité
mkstat = 2 : # non saisissable sauf quand code "par lot"
Case [M:BOH0]QTYCOD
 When 1 : VALEUR = 1
 When 2 : VALEUR = 100
 When 3 : VALEUR = 1000
 When 4 : VALEUR = 100
 When 5 : # lot réappro du site de l'alternative s'il est renseigné
   mkstat = 0
   If [M:BOH0]BASQTY = 0 : # à la création
      VALEUR = 1
   # Endif # En fait une initialisation (bug 15106) 15/07/02
     If [F:TBO]FCY <> ""
       Read [ITF]ITF0 = [M:BOH0]ITMREF;[F:TBO]FCY
       If !fstat : VALEUR = [F:ITF]MFGLOTQTY : Endif
     Endif
   Endif
 When Default : VALEUR = 1
Endcase
End

######################################################
Subprog AS_QTYCOD(VALEUR)
Variable Integer  VALEUR
If [M:BOH0]BOMALTTYP = 1 : GMENLOC(4) = 1 : Endif
End

######################################################
Subprog AM_QTYCOD(VALEUR)
Variable Integer  VALEUR
If GREP <> "C" | [M:BOD1]NBLIG > 0
   GMESSAGE = mess(127,199,1) : GERR = 2
Endif
Case VALEUR
 When 1    : [M:BOH0]BASQTY = 1
 When 2, 4 : [M:BOH0]BASQTY = 100
 When 3    : [M:BOH0]BASQTY = 1000
 When 5    : # lot réappro du site de l'alternative s'il est renseigné
   If [F:TBO]FCY <> ""
      Read [ITF]ITF0 = [M:BOH0]ITMREF;[F:TBO]FCY
      If !fstat : [M:BOH0]BASQTY = [F:ITF]MFGLOTQTY : Endif
   Endif
 When Default : [M:BOH0]BASQTY = 1
Endcase
End

######################################################
# Ecrans des lignes de détails (aussi en saisie fiche)
######################################################
Subprog IB_NBLIG
If [M:BOD1]CPNITMREF(nolign-1) <> ""
    GBOUT2 = mess(385,198,1) : # chgt n° séquence

    If find("GESITM", GNAVIG(1..GPILNAV)) | find("CASNOMENS", GNAVIG(1..GPILNAV)) Then
      GBOUT6=""
    Endif
    # MHB 19/12/08 : on ne laisse le menu Cas d'emploi que si on n'a pas déjà
    # ouvert un cas d'emploi. Sinon, erreur "Fonction non appelable dans le contexte"
    Local Integer I, CAS_EMPLOI_OUV
    CAS_EMPLOI_OUV=G_NON
    For I=1 To GNBMASKOUV
      If instr(1,GMASKOUV(I),"BOWH")>0 Then
        CAS_EMPLOI_OUV=G_OUI
        Break
      Endif
    Next
    If find("CASNOMENP", GNAVIG(1..GPILNAV)) | find("CASNOMENS", GNAVIG(1..GPILNAV)) | CAS_EMPLOI_OUV=G_OUI Then
      GBOUT7=""
    Endif
Else
    # GBOUT2 = "" : # GH 20/06/2013 bug 92844
    Raz GBOUT2, GBOUT6, GBOUT7

    # Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
    If [M:BOH0]BOMALTTYP = 1
      If nolign>=1 & [M:BOD1]FORSEL(nolign-1)="" Raz GBOUT5 Endif
    Else
      GBOUT5 = "" # texte ligne  (désactivé sur ligne vide 01/10/01)
    Endif
Endif
If [M:BOH0]DATREF = [0/0/0]  GBOUT3 = mess(408,198,1) Else GBOUT3="" Endif
GBOUT4 = mess(110,198,1)  # fusion

# Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
If [M:BOH0]BOMALTTYP = 1
  If nolign>=1 & [M:BOD1]FORSEL(nolign-1)<>""
    Raz GBOUT4
  Else
    Raz GBOUT8
  Endif
Else
  Raz GBOUT8
Endif

Call IB_NOTECHECK([M:BOD1]CPNITMREF(nolign-1),"ITMREF",9)  From TRTNTSCTL # product notes

Call IB_NBLIG From ECCBOM
End

######################################################
Subprog AVANT_NBLIG
# bug 17507 Cumuler que les composants valides 03/03/03
If [M:BOH0]CUMREF>=[M:BOD1]BOMSTRDAT(nolign-1)
& & ([M:BOH0]CUMREF<=[M:BOD1]BOMENDDAT(nolign-1)|[M:BOD1]BOMENDDAT(nolign-1)=[0/0/0])
    # 30793 MM 06.05
    If dim([M:BOD1]BOMUOM(nolign-1))<0    # UML inactif
       [M:BOH0]CUMQTE -= [M:BOD1]LIKQTY(nolign-1) : # pour gestion pourcentage
    Else
       [M:BOH0]CUMQTE -= [M:BOD1]BOMQTY(nolign-1)
    Endif
Endif
End

######################################################
Subprog APRES_NBLIG
[M]CONCATKEY(nolign-1) = num$([M]BOMSEQ(nolign-1)) + [M]CPNITMREF(nolign-1)
[M:BOD1]UPDFLG(nolign-1) = 1
# bug 17507 Cumuler que les composants valides 03/03/03
If [M:BOH0]CUMREF>=[M:BOD1]BOMSTRDAT(nolign-1)
& & ([M:BOH0]CUMREF<=[M:BOD1]BOMENDDAT(nolign-1)|[M:BOD1]BOMENDDAT(nolign-1)=[0/0/0])
    # 30793 MM 06.05
    If dim([M:BOD1]BOMUOM(nolign-1))<0    # UML inactif
        [M:BOH0]CUMQTE += [M:BOD1]LIKQTY(nolign-1)
    Else
        [M:BOH0]CUMQTE += [M:BOD1]BOMQTY(nolign-1)
    Endif
Endif
End

######################################################
Subprog D_BOMSEQ(VALEUR)
Variable Decimal  VALEUR
# initialisation selon le paramètre BOMSTE
If !GIMPORT
    If nolign > 1
        VALEUR = [M:BOD1]BOMSEQ(nolign-2) + GBOMSTE
    Else
        VALEUR = GBOMSTE
    Endif
Endif
End
######################################################
Subprog AS_BOMSEQ(VALEUR)
Variable Decimal  VALEUR
If (GREP = "M" | GREP = "") & VALEUR <> 0 & [M:BOD1]CREFLG(nolign-1) > 0
   mkstat = 2
Endif
End

######################################################
Subprog C_BOMSTRDAT(VALEUR)
Variable Date     VALEUR
If (VALEUR < [M:BOH0]BOHSTRDAT)
&  | (VALEUR > [M:BOH0]BOHENDDAT & [M:BOH0]BOHENDDAT <> [0/0/0])
   mkstat = 2
   GMESSAGE = mess(51,199,1) + "\" + mess(52,199,1)
Endif
End

######################################################
Subprog D_BOMSTRDAT(VALEUR)
Variable Date     VALEUR

VALEUR = [M:BOH0]BOHSTRDAT

Call D_BOMSTRDAT(VALEUR) From ECCBOM
End

######################################################
Subprog D_BOMENDDAT(VALEUR)
Variable Date     VALEUR
VALEUR = [M:BOH0]BOHENDDAT
End

######################################################
Subprog C_BOMENDDAT(VALEUR)
Variable Date     VALEUR
If (VALEUR < [M:BOH0]BOHSTRDAT & VALEUR <> [0/0/0])
&   | (VALEUR > [M:BOH0]BOHENDDAT & [M:BOH0]BOHENDDAT <> [0/0/0])
&   | (VALEUR = [0/0/0] & [M:BOH0]BOHENDDAT <> [0/0/0])
   mkstat = 2
   GMESSAGE = mess(51,199,1) + "\" + mess(52,199,1)
Endif
End

######################################################
Subprog AS_CPNITMREF(VALEUR)
Variable Char     VALEUR
If instr(1,dbgstr(1),"BOM1")
    If [M]CPNTYP = 5 : mkstat = 2 : Endif
Endif

# clé non modifiable
If [M:BOH0]BOMALTTYP <> 1
  If (GREP = "M" | GREP = "") & VALEUR <> "" & [M:BOD1]CREFLG(nolign-1) > 0
     mkstat = 2
  Endif
Else
  # Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
  If (GREP = "M" | GREP = "") & (VALEUR <> "" | [M:BOD1]FORSEL(nolign-1)<>"") & [M:BOD1]CREFLG(nolign-1) > 0
     mkstat = 2
  Endif
Endif

End
######################################################
Subprog C_CPNITMREF(VALEUR)
Variable Char     VALEUR
Local Char CONC(50)
Local Integer OK
Local Integer WLLCTYP :   WLLCTYP = func LLCLIB.LLCTYP([M:BOH0]BOMALTTYP)
Local File CTRLNIVW [CNW]

If [M:BOH0]BOMALTTYP <> 1
  If VALEUR="" mkstat=1 : GMESSAGE = mess(10,123,1) : End : Endif
Else
  # 107888 : Scheduled invoices (LD:07/12/15)
  Local File ITMMASTER [ITM1]
  Read [ITM1]ITM0=[M:BOH0]ITMREF
  If [F:ITM1]DLVFLG=2 & [F:ITM]DLVFLG<>2
      # Parent product is deliverable : Components have to be deliverable
      mkstat=2 : GMESSAGE = mess(645,199,1) : End
  Endif
  If [F:ITM1]DLVFLG=1 & [F:ITM]DLVFLG<>1
      # Parent product is undeliverable : Components have to be undeliverable
      mkstat=2 : GMESSAGE = mess(646,199,1) : End
  Endif
  # 107888 : Scheduled invoices (LD:07/12/15)

  # Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
  ## Référence composant ou formule sélection sont obligatoires
  If VALEUR=""

    #-- JDE Sam 92818 : Nomenclature commerciale & formule de sélection --#
    # Controle d'unicité
    Gosub TEST_UNICITE
    If WUNICITE_OK<>2 : End : Endif

    If instr(1,dbgstr(1),"BOD1")
        If [M:BOD1]FORSEL(nolign-1)=""
          If sigma(0,[M:BOD1]NBLIG-1,[M:BOD1]BOMSEQ(indcum)=[M:BOD1]BOMSEQ(nolign-1)& [M:BOD1]FORSEL(indcum)<>"")
            mkstat=1 : GMESSAGE = mess(584,199,1)
          Endif
        Endif
    Elsif instr(1,dbgstr(1),"BOM2")
        If [M:BOM2]FORSEL=""
          If sigma(0,[M:BOD1]NBLIG-1,[M:BOD1]BOMSEQ(indcum)=[M:BOM2]BOMSEQ & [M:BOD1]FORSEL(indcum)<>"")
            mkstat=1 : GMESSAGE = mess(584,199,1)
          Endif
        Endif
    Endif
    End
  Endif
Endif

# CONTROLES DE CREATION DE LIEN
If GFONBOD = "BOMC"
  Read [ITG]ITG0="";[F:ITM]TCLCOD
  If [F:ITG]SALFLG <> 2
    GMESSAGE = mess(221,199,1) : # "L'article doit être de catégorie vendue"
    mkstat = 2 : End
  Endif
Endif

# If GFONBOD <> "BOMS" | !instr(1,dbgstr(1),"BOS2") : # GH 06/05/13 bug 89818
# 107888 : Scheduled invoices (LD:07/12/15)
## Issue 112531 - 2015-11-18 by MAE : type sous traitance : service + acheté
## If [F:ITM]SCSFLG = 2
#If [F:ITM]SCSFLG = 2  & [F:ITM]PURFLG=2
#      GMESSAGE = mess(164,199,1) : # "Article de type 'service' non autorisé"
#      mkstat = 2 : End
#Endif
## Endif
# 107888 : Scheduled invoices (LD:07/12/15)

#-- JDE Sam 92818 : Nomenclature commerciale & formule de sélection --#
# Controle d'unicité
Gosub TEST_UNICITE
If WUNICITE_OK<>2 : End : Endif

# Controler qu'il n'y a pas de boucle dans la nomenclature
# Lecture récursive par la clé composant (Remontant la nomencl.)
# Si le composant est de type sous-produit, pas de controle demande 21581
If instr(1,dbgstr(1),"BOM1") = 0 Then # on en passe pas dans ce test en mode fiche
  If [M:BOD1]CPNTYP(nolign-1) <> 4 & !adxlog
    Local Integer NIVMAX
    OK = 1
    Call MONTLIEN(VALEUR,[M:BOH0]ITMREF,[M:BOH0]BOMALT,[M:BOH0]BOMALTTYP,OK) From LLCLIB
    If OK = 0
      GMESSAGE = mess(67,199,1) : mkstat = 2 : End
    Endif
    # 06.06 demande 21581
    # Contrôler qu'on n'atteint pas le niveau max de nomenclature
    Local Integer CURNIV : CURNIV = 0

    # 03.09 bug 53989
    # début de la transaction base de donnée
    Trbegin [CNW]
    NIV = 1
    Call DESCLIEN(VALEUR,[M:BOH0]BOMALT,[M:BOH0]BOMALTTYP,NIVMAX,CURNIV) From LLCLIB
    # Les informations de la table CTRLNIVW ne doivent pas être conservées
    Rollback
    # Les niveaux parcourus + le LLC de l'entete ne doit pas dépasser le max
    Read [ITB]ITB0 = [M:BOH0]ITMREF;[M:BOH0]BOMALT;WLLCTYP
    If !fstat & ([F:ITB]LLC + NIVMAX + 1) > GBOMLEV
       GMESSAGE = mess(89,199,1) : mkstat=2 : End
    Endif
  Endif
Endif

# Issue 110957 - 2015-09-21 by GH and SLL
# Check for Change Request if Component is not version managed OR if Commercial BOM
If !mkstat & !GIMPORT & dim([M]CRID)>0 &
& (GFONBOD = "BOMC" | func ECCLIB.NBRCPN(VALEUR)<1)
   If dim([M]CRID)=1 & VALEUR<>[M]CPNITMREF
      [M]CRID = func TRTX3FNC.CCMID(VALEUR,"","")
      Affzo CRID
      If dim([M]CRFLG)=1
         [M]CRFLG = string$([M]CRID<>"","151") : Affzo CRFLG
      Endif
   Elsif VALEUR<>[M]CPNITMREF(nolign-1)
      [M]CRID(nolign-1) = func TRTX3FNC.CCMID(VALEUR,"","")
      Affzo CRID(nolign-1)
      If dim([M]CRFLG)=dim([M]CRID)
         [M]CRFLG(nolign-1) = string$([M]CRID(nolign-1)<>"","151") : Affzo CRFLG(nolign-1)
      Endif
   Endif
Endif

# Avertir s'il n'existe aucun enreg article-site sur le site de l'altern.
#If [F:TBO]FCY <> ""
#Issue 87125
#If [F:TBO]BOMALT=[M:BOH0]BOMALT & [F:TBO]BOMALTTYP=[M:BOH0]BOMALTTYP & [F:TBO]FCY <> ""
#   Read [ITF]ITF0 = VALEUR;[F:TBO]FCY
#   If fstat : GMESSAGE = mess(65,199,1) : GERR = 2 : Endif
#Endif
# GH 01/03/13 bug 87125
If [M:BOH0]STOFCY<>""
   Read [ITF]ITF0 = VALEUR;[M:BOH0]STOFCY
   If fstat : GMESSAGE = mess(65,199,1) : GERR = 2 : Endif
Endif

# le controle par le type de donnée a été fait et pas d'autre erreur
# Affecter la zone STU (invisible)
If instr(1,dbgstr(1),"BOD1") | instr(1,dbgstr(1),"BOD2") | instr(1,dbgstr(1),"BOD3")| GIMPORT
  If GFONBOD = "BOMC"
   [M]STU(nolign-1) = [F:ITM]SAU
  Else
   [M]STU(nolign-1) = [F:ITM]STU
  Endif
# 03.07 Demande 40156
#  [M]ITMDES1(nolign-1) = [F:ITM]ITMDES1
  ##If !GIMPORT : Affzo [M:BOD1]STU(nolign-1), ITMDES1(nolign-1) : Endif
Else
  If GFONBOD = "BOMC"
   [M]STU           = [F:ITM]SAU
  Else
   [M]STU           = [F:ITM]STU
  Endif
  ##If !GIMPORT  Affzo STU Endif
Endif
Close Local File [CNW]
End

################################
## $TEST_UNICITE
################################
$TEST_UNICITE
Local Integer WUNICITE_OK
WUNICITE_OK=2

# Distinction selon l'ecran tableau (aussi pendant Fusion) ou l'écran fiche
If instr(1,dbgstr(1),"BOD1") | instr(1,dbgstr(1),"BOD2") | instr(1,dbgstr(1),"BOD3") | GIMPORT
 CONC = num$([M:BOD1]BOMSEQ(nolign-1)) + VALEUR
 Call UNICITE(CONC,[M:BOD1]CONCATKEY(0..[M:BOD1]NBLIG-1)) From OBJDIV
 If mkstat = 2 : WUNICITE_OK=1 : Return : Endif

# comparer à un éventuel enregistrement non visible
 If [M:BOH0]DATREF <> [0/0/0]
   Read [BOD]BOD0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;[M:BOD1]BOMSEQ(nolign-1);VALEUR;[M:BOH0]BOMALTTYP
   If !fstat & ([F:BOD]BOMSTRDAT>[M:BOH0]DATREF | ([F:BOD]BOMENDDAT<[M:BOH0]DATREF & [F:BOD]BOMENDDAT<>[0/0/0])) : # If !fstat
      mkstat = 2 : GMESSAGE = mess(50,199,1) : WUNICITE_OK=1 : Return
   Endif
 Endif
Else
 CONC = num$([M]BOMSEQ) + VALEUR
 Call UNICITE(CONC,[M:BOD1]CONCATKEY(0..[M:BOD1]NBLIG-1)) From OBJDIV
 If mkstat = 2 : WUNICITE_OK=1 : Return : Endif

 If [M:BOH0]DATREF <> [0/0/0]
   Read [BOD]BOD0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;[M]BOMSEQ;VALEUR;[M:BOH0]BOMALTTYP
   If !fstat & ([F:BOD]BOMSTRDAT>[M:BOH0]DATREF | ([F:BOD]BOMENDDAT<[M:BOH0]DATREF & [F:BOD]BOMENDDAT<>[0/0/0])) : # If !fstat
      mkstat = 2 : GMESSAGE = mess(50,199,1) : WUNICITE_OK=1 : Return
   Endif
 Endif
Endif

Return

########################################
Subprog AM_CPNITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer OK

If !GIMPORT # Bug 48829 08.08
    If [F:ITM]ITMSTA > 3
        Call AVERTIR(mess(382,199,1),OK) From GESECRAN
        If OK <> 2 mkstat=2 : Endif
    Endif
Endif
If [M:BOH0]BOMALTTYP=3 & [F:ITM]PHAFLG= 2 : # Issue 98871 GA 05/2014 no ghost
    GMESSAGE = mess(92,184,1) : # Fantôme interdit !
   mkstat=2 : End
Endif
Affzo [M]STU
#-----------------------------------------------------------------------------------------------#
# Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
# Saisie exclusive entre Référence composant et formule sélection
# Saisie formule qté ssi formule sélection
#-----------------------------------------------------------------------------------------------#
If [M:BOH0]BOMALTTYP = 1 & VALEUR <> ""
    If instr(1,dbgstr(1),"BOD1")
        Raz [M:BOD1]FORSEL(nolign-1) : Affzo [M:BOD1]FORSEL(nolign-1)
        Raz [M:BOD1]FORQTY(nolign-1) : Affzo [M:BOD1]FORQTY(nolign-1)
    Elsif instr(1,dbgstr(1),"BOM2")
        Raz [M:BOM2]FORSEL : Affzo [M:BOM2]FORSEL
        Raz [M:BOM2]FORQTY : Affzo [M:BOM2]FORQTY
        If [M:BOM2]CPNTYP=9 [M:BOM2]CPNTYP=1 : Affzo [M:BOM2]CPNTYP Endif
    Endif
Endif

# 98144 - Display the allergens for normal components
If GFONBOD = "BOMP" & func AFNC.ACTIV("FOA") & [M:BOD1]CPNTYP(nolign-1) = 1
  [M:BOD1]ALG(nolign-1) = [F:ITM]ALG : Affzo [M:BOD1]ALG
Endif
End

######################################################
Subprog AS_LIKQTYCOD(VALEUR)
Variable Integer  VALEUR
# Quantité toujours proportionnelle pour une alternative commerciale
If [M:BOH0]BOMALTTYP=1 : VALEUR=1 : mkstat=2 : Endif
If instr(1,dbgstr(1),"BOD1") | instr(1,dbgstr(1),"BOD3")
   If [M]CPNTYP(nolign-1) = 5 : mkstat = 1 : End : Endif
Endif
End

######################################################
Subprog C_LIKQTY(VALEUR)
Variable Decimal  VALEUR
Local Integer I      # pour contrôle qte en %  03/03/03
#58690 10.09
Local Decimal QTYMAX # ou decimal

# Dde 71277 : Saisie formule de sélection et formule de qté ds les nomenclatures commerciales
If VALEUR=0
#Gbn-96594
#  If [M:BOH0]BOMALTTYP<>1
#    mkstat=1 : GMESSAGE = mess(10,123,1) : End
#  Else
  If [M:BOH0]BOMALTTYP=1
    # Saisie qté lien obligatoire si composant
    If instr(1,dbgstr(1),"BOD1")
      If [M:BOD1]CPNITMREF(nolign-1)<>""
        mkstat=1 : GMESSAGE = mess(10,123,1) : End
      Endif
    Elsif instr(1,dbgstr(1),"BOM2")
      If [M:BOM2]CPNITMREF<>""
        mkstat=1 : GMESSAGE = mess(10,123,1) : End
      Endif
    Endif
  Endif
Endif

#bug 67976 11/10/10 On pouvait saisir une valeur négative
If VALEUR < 0
   mkstat = 2
Endif
# 30793 MM 06.05
If dim([M:BOD1]BOMUOM)<0    # UML inactif
    # LIEN NEGATIF NON GERE POUR L'INSTANT
    If VALEUR < 0
       mkstat = 2
    Endif
    If [M:BOH0]QTYCOD = 4
        For I=0 To [M:BOD1]NBLIG-1

        # bug 17507 Cumuler que les composants valides 03/03/03
            If [M:BOH0]CUMREF>=[M:BOD1]BOMSTRDAT(I)
&  & ([M:BOH0]CUMREF<=[M:BOD1]BOMENDDAT(I)|[M:BOD1]BOMENDDAT(I)=[0/0/0])
                QTYMAX += [M:BOD1]LIKQTY(I)
           Endif
        Next
        # FQ 54951 GA 01/2010 pas de message d'erreur en import
        # modif du test pour contrôle  (03/03/03)
        If !GIMPORT & QTYMAX-[M:BOD1]LIKQTY(nolign-1)+VALEUR > 100
            mkstat = 2 : GMESSAGE = mess(4,199,1)
        Endif
    Endif
Endif
If [F:ITM]ITMREF <> [M:BOD1]CPNITMREF(nolign-1)
 Read [ITM]ITM0=[M:BOD1]CPNITMREF(nolign-1)
 If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]PHAFLG = 2
    If VALEUR <= 0 : GMESSAGE = mess(552,199,1) : mkstat = 2 : Endif
Endif

End

########################################
Subprog D_CPNTYP(VALEUR)
Variable Integer VALEUR

Raz GMENLOC
Call AS_CPNTYP(VALEUR)
VALEUR = find(0,GMENLOC(1..dim(GMENLOC)-1))
End

########################################
Subprog AS_CPNTYP(VALEUR)
Variable Integer VALEUR

Call AS_CPNTYP(VALEUR) From ECCBOM
If mkstat : End : Endif

# GA 21/06/2005
Case GFONBOD
    When "BOMC": GMENLOC(4) = 1
                 GMENLOC(5) = 1
                 GMENLOC(6) = 1
                 GMENLOC(7) = 1 : # Service
                 If [M:BOD1]FORSEL(nolign-1) <>'' & VALEUR < 2  : VALEUR = 9 : Endif

    When "BOMP": GMENLOC(2) = 1
                 GMENLOC(3) = 1
                 GMENLOC(7) = 1 : # Service
                 GMENLOC(8) = 1 : # Option multiple        (X3Suivi 71277)
                 GMENLOC(9) = 1 : # Normal (avec formule)  (X3Suivi 71277)

    When "BOMS": GMENLOC(2) = 1 : # Option
                 GMENLOC(3) = 1 : # Variante
                 GMENLOC(4) = 1 : # Sous-produit
                 GMENLOC(5) = 1
                 GMENLOC(6) = 1
                 GMENLOC(7) = 1 : # Service  (=> affiché dans l'écrans BOS2)
                 GMENLOC(8) = 1 : # Option multiple        (X3Suivi 71277)
                 GMENLOC(9) = 1 : # Normal (avec formule)  (X3Suivi 71277)
Endcase
End

######################################################
Subprog C_CPNTYP(VALEUR)
Variable Integer  VALEUR
# Controle du type par rapport au n° de séquence
# Le controle global est fait dans l'Action VERIF_CRE/MOD
Case [M:BOH0]BOMALTTYP
 When 1 : # Nomenclatures commerciales
  If nolign > 2
   If [M:BOD1]BOMSEQ(nolign-1) > [M:BOD1]BOMSEQ(nolign-2) & [M:BOD1]CPNTYP(nolign-2) = 3 &  [M:BOD1]FORSEL(nolign-2)=''
         # "Un composant de type variante ne doit pas être seul" (Sauf si formule)
         If [M:BOD1]BOMSEQ(nolign-3) <> [M:BOD1]BOMSEQ(nolign-2)    | [M:BOD1]CPNTYP(nolign-3) <> 3
               GMESSAGE = mess(84,199,1) : mkstat=2
         Endif
   Endif

  If [M:BOD1]BOMSEQ(nolign-1) > [M:BOD1]BOMSEQ(nolign-2) & [M:BOD1]CPNTYP(nolign-2) = 8 &  [M:BOD1]FORSEL(nolign-2)=''
         # "Un composant de type Option multiple ne doit pas être seul" (Sauf si formule)
         If [M:BOD1]BOMSEQ(nolign-3) <> [M:BOD1]BOMSEQ(nolign-2)  | [M:BOD1]CPNTYP(nolign-3) <> 8
               GMESSAGE = mess(576,199,1) : mkstat=2
         Endif
   Endif

   #--X3SUIVI 71277 :  --#

   # "Des composants de même séquence doivent être de même type"
   If ([M:BOD1]BOMSEQ(nolign-1) = [M:BOD1]BOMSEQ(nolign-2))
      If (VALEUR = 1 & [M:BOD1]CPNTYP(nolign-2)=9) | (VALEUR = 9 & [M:BOD1]CPNTYP(nolign-2)=1)
      Elsif  VALEUR <>[M:BOD1]CPNTYP(nolign-2)
         GMESSAGE = mess(83,199,1) : mkstat = 2
      Endif
   Endif
  Endif

 When 2 : # Nomenclatures de production : # GH 19/10/2011 bug 77164
  If VALEUR=5 : # Texte
   If instr(1,dbgstr(1),"BOM1")
    Call UNICITE(num$([M:BOM1]BOMSEQ),[M:BOD1]CONCATKEY(0..[M:BOD1]NBLIG-1)) From OBJDIV
   Else
    Call UNICITE(num$([M:BOD1]BOMSEQ(nolign-1)),[M:BOD1]CONCATKEY(0..[M:BOD1]NBLIG-1)) From OBJDIV
   Endif
   If mkstat = 2 : End : Endif
  Endif
 Endcase
End

########################################
Subprog AM_CPNTYP(VALEUR)
Variable Integer VALEUR

Call AM_CPNTYP(VALEUR) From ECCBOM

Case VALEUR
    When 4
        If instr(1,dbgstr(1),"BOD1")
          [M]CSTFLG(nolign-1) = 1
        Else
          Actzo [M]CPNITMREF
          Actzo [M]21-35
          [M]CSTFLG           = 1
#          Actzo [M]CSTFLG
          Grizo SCA,PICPRN
          Affzo [M]CSTFLG
        Endif
    When 5
        If instr(1,dbgstr(1),"BOD1") | instr(1,dbgstr(1),"BOD3")
          Raz [M]CPNITMREF(nolign-1)
          [M]CSTFLG(nolign-1) = 1
          [M]PICPRN(nolign-1) = 2
          If dim([M]PKC) > 0
              [M]PKC(nolign-1)    = 1
          Endif
          If instr(1,dbgstr(1),"BOD3") : [M]SCOFLG(nolign-1) = 1 : Endif
        Else
          Effzo [M]21-35
          [M]CSTFLG           = 1
          [M]PICPRN           = 2
          If dim([M]PKC) > 0
              [M]PKC              = 1
          Endif
          Raz   [M]CPNITMREF
          [M]BOMSTRDAT = [M:BOH0]BOHSTRDAT
          [M]BOMENDDAT = [M:BOH0]BOHENDDAT
          Grizo CPNITMREF
          Grizo [M]21-35
          Actzo BOMSTRDAT, BOMENDDAT, CPNOPE, BOMSHO
          Affzo [M]BOMSTRDAT,BOMENDDAT,CSTFLG,PICPRN
        Endif
    When 6
        If instr(1,dbgstr(1),"BOD1")
          [M]CSTFLG(nolign-1) = 2
          If dim([M]PKC) > 0
              [M]PKC(nolign-1)    = 1
          Endif
          [M]PICPRN(nolign-1) = 1
        Else
          Actzo [M]CPNITMREF
          Actzo [M]21-35
          [M]CSTFLG           = 2
          If dim([M]PKC) > 0
              [M]PKC              = 1
          Endif
          [M]PICPRN           = 1
#          Actzo [M]CSTFLG
          Grizo SCA,PICPRN
          Affzo [M]CSTFLG
          If dim([M]PKC) > 0
             Grizo PKC
          Endif
        Endif
    When 7
        If instr(1,dbgstr(1),"BOD1")
          [M]CSTFLG(nolign-1) = 2
          If dim([M]PKC) > 0
             [M]PKC(nolign-1) = 1
             Grizo PKC
          Endif
          [M]PICPRN(nolign-1) = 1
        Endif

    When Default
        If instr(1,dbgstr(1),"BOD1")
          [M]CSTFLG(nolign-1) = 2
        Elsif instr(1,dbgstr(1),"BOM1")
         Actzo [M]CPNITMREF
         Actzo [M]21-35
         [M]CSTFLG           = 2
          Grizo [M]CSTFLG
#          Actzo SCA,PICPRN
          Affzo [M]CSTFLG
        Endif
Endcase

# 98144 - Display the allergens for normal components
If GFONBOD = "BOMP" & func AFNC.ACTIV("FOA")
  If VALEUR=1
    If [F:ITM]ITMREF <> [M:BOD1]CPNITMREF(nolign-1)
      Read [ITM]ITM0=[M:BOD1]CPNITMREF(nolign-1)
      If fstat : Raz [F:ITM] : Endif
    Endif
    [M:BOD1]ALG(nolign-1) = [F:ITM]ALG
  Else
    Raz [M:BOD1]ALG(nolign-1)
  Endif
  Affzo [M:BOD1]ALG
Endif

End

########################################
Subprog AS_SCA(VALEUR)
Variable Decimal  VALEUR
# Issue 89446 GA 09/2014: 2 different screens use the same code
If    instr(1,dbgstr(1),"BOD1")
   If find([M:BOD1]CPNTYP(nolign-1),4,5,7) mkstat = 2 Endif
Elsif instr(1,dbgstr(1),"BOM1")
   If find([M:BOM1]CPNTYP,4,5,7) mkstat = 2 Endif
Endif
End

Subprog AS_CSTFLG(VALEUR)
Variable Integer  VALEUR
# Issue 89446 GA 09/2014: 2 different screens use the same code
#If !find([M]CPNTYP(nolign-1),4,6,7) mkstat = 2 Endif
If    instr(1,dbgstr(1),"BOD1")
   If !find([M:BOD1]CPNTYP(nolign-1),4,6,7) mkstat = 2 Endif
Elsif instr(1,dbgstr(1),"BOM1")
   If !find([M:BOM1]CPNTYP,4,6,7) mkstat = 2 Endif
Endif
End

Subprog AS_PICPRN(VALEUR)
Variable Integer  VALEUR
# Issue 89446 GA 09/2014: 2 different screens use the same code
If    instr(1,dbgstr(1),"BOD1")
   If find([M:BOD1]CPNTYP(nolign-1),4,5,6,7) mkstat = 2 Endif
Elsif instr(1,dbgstr(1),"BOM1")
   If find([M:BOM1]CPNTYP,4,5,6,7) mkstat = 2 Endif
Endif
End


########################################
#Si composant pesé en centrale, on contrôle qu'il y a bien un poids de l'US. FI n° 21
Subprog AM_PKC(VALEUR)
Variable Integer VALEUR
Local    Integer OK
Local Integer I    # 50271 mm 10.08

If VALEUR <> 1
   If instr(1,dbgstr(1),"BOD1")
       Read [ITM]ITM0 = [M]CPNITMREF(nolign-1)
       If !fstat & [F:ITM]ITMWEI = 0
           Call AVERTIR(mess(356,199,1),OK) From GESECRAN
           If OK <> 2 mkstat=2 : Endif
       Endif
    Elsif  instr(1,dbgstr(1),"BOM1")
       Read [ITM]ITM0 = [M]CPNITMREF
       If !fstat & [F:ITM]ITMWEI = 0
           Call AVERTIR(mess(356,199,1),OK) From GESECRAN
           If OK <> 2 mkstat=2 : Endif
       Endif
   Endif
Endif

#CATUA X3-30162.sn Blank out container code if not weighed at station
If dim([M:BOD1]CTN(nolign-1))>0
  If !find(VALEUR,2,4,6)
    [M:BOD1]CTN(nolign-1) = ""
    Affzo[M:BOD1]CTN(nolign-1)
  Endif
Endif
#CATUA X3-30162.en

End

##########################################
# process 03.03 MM
Subprog AS_BOMUOM(VALEUR)
Variable Char    VALEUR()
Local Integer    TYP
Local Char       WSTU(GLONUOM)
If clalev ([F:TUN])=0  Local File TABUNIT  [TUN] Endif

If instr(1,dbgstr(1),"BOD1")
    WSTU=[M]STU(nolign-1)
Elsif  instr(1,dbgstr(1),"BOM1")
    WSTU=[M]STU
Endif

If VALEUR = "" : VALEUR = WSTU : Endif            # llc 09.03
TYP=0
Read [TUN]TUN0=WSTU
If !fstat
    TYP = [F:TUN]UOMTYP
Endif
If (TYP <>3 & TYP <>4)
  If instr(1,dbgstr(1),"BOD1")
    VALEUR =[M]STU(nolign-1)
    [M]BOMSTUCOE(nolign-1)=1
    [M]BOMQTY(nolign-1)=[M]LIKQTY(nolign-1)
  Elsif  instr(1,dbgstr(1),"BOM1")
    VALEUR =[M]STU
    [M]BOMSTUCOE=1
    [M]BOMQTY=[M]LIKQTY
 Endif
 mkstat=2
Endif

End


########################################
# process 03.03 MM
Subprog AM_BOMUOM(VALEUR)
Variable Char    VALEUR()
If instr(1,dbgstr(1),"BOD1")
  If [M:BOD1]BOMUOM(nolign-1)<>VALEUR
    [M:BOD1]BOMQTY(nolign-1)=0 : [M:BOD1]LIKQTY(nolign-1)=0
    Affzo [M:BOD1]BOMQTY(nolign-1),LIKQTY(nolign-1)
  Endif
Elsif  instr(1,dbgstr(1),"BOM1")
  If [M:BOM1]BOMUOM<>VALEUR
    [M:BOM1]BOMQTY=0 : [M:BOM1]LIKQTY=0
    Affzo [M:BOM1]BOMQTY,LIKQTY
  Endif
Endif

End


##########################################################################
## Etiquette ajoutée par le superviseur 23/12/2003 09:54:46 (LLC)
##########################################################################
Subprog C_BOMUOM(VALEUR)
Variable Char    VALEUR()
Local Integer    TYP
Local Char       WSTU(GLONUOM)

If !GIMPORT
    If VALEUR = ""
        GMESSAGE = mess(10,123,1) : mkstat = 2 : End
    Endif
    If clalev ([F:TUN])=0  Local File TABUNIT  [TUN] Endif
    If instr(1,dbgstr(1),"BOD1")
        WSTU=[M]STU(nolign-1)
    Elsif  instr(1,dbgstr(1),"BOM1")
        WSTU=[M]STU
    Endif
    TYP=0
    Read [TUN]TUN0=WSTU
    If !fstat
        TYP = [F:TUN]UOMTYP
    Endif
    If find(TYP,3,4)
        Read [TUN]TUN0=VALEUR
        If !fstat
            TYP = [F:TUN]UOMTYP
        Endif
        If !find(TYP,3,4) : GMESSAGE = mess(471,199,1) : mkstat = 2 : Endif
    Endif
Endif
End

##########################################################################
Subprog C_BOMQTY(VALEUR)
Variable Decimal VALEUR
Local Integer I        # 30793 MM 06.05
Local Integer QTYMAX   # 30793 MM 06.05

# 08.12.05 150 autoriser la saisie à 0
#If !GIMPORT
#    If VALEUR = 0
#        GMESSAGE = mess(10,123,1) : mkstat = 2 : End
#    Endif
#Endif

# Demande 30793 MM 06.05 : contrôle que la somme des qtés de lien UOM n'excède pas 100%
# LIEN NEGATIF NON GERE POUR L'INSTANT
If VALEUR < 0
   mkstat = 2
Endif
If [M:BOH0]QTYCOD = 4
    For I=0 To [M:BOD1]NBLIG-1
        # cumul des composants valides
        If [M:BOH0]CUMREF>=[M:BOD1]BOMSTRDAT(I)
&       & ([M:BOH0]CUMREF<=[M:BOD1]BOMENDDAT(I)|[M:BOD1]BOMENDDAT(I)=[0/0/0])
             QTYMAX += [M:BOD1]BOMQTY(I)
        Endif
    Next I
    If QTYMAX-[M:BOD1]BOMQTY(nolign-1)+VALEUR > 100
        mkstat = 2 : GMESSAGE = mess(4,199,1)     # Le total ne doit pas excéder 100 %
    Endif
Endif

If [F:ITM]ITMREF <> [M:BOD1]CPNITMREF(nolign-1)
 Read [ITM]ITM0=[M:BOD1]CPNITMREF(nolign-1)
 If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]PHAFLG = 2
    If VALEUR <= 0 : GMESSAGE = mess(552,199,1) : mkstat = 2 : Endif
Endif
End

