Subprog C_NBLIG
Call C_NBLIG From ECCBOM

# Issue 115658 - 2016-11-18 by CCC
# For a new line, if varinit value has been changed wrongly because of Insa instruction (for example in line revision action)
# reset values of fields that shouldn't be seen as already initialized
If [M]CPNTYP(nolign-1)=0 & varinit([M]CPNTYP,nolign-1)<>0
    #Issue X3-58067 14/12/2017 by GEBIL : Error: PKC: variable nonexistent
    #Raz [M]BOMSEQ(nolign-1),[M]CPNTYP(nolign-1),[M]CSTFLG(nolign-1),[M]PICPRN(nolign-1),[M]PKC(nolign-1)
    Raz [M]BOMSEQ(nolign-1),[M]CPNTYP(nolign-1),[M]CSTFLG(nolign-1),[M]PICPRN(nolign-1)
    If dim([M]PKC)>0
      Raz [M]PKC(nolign-1)
    Endif
Endif
End

