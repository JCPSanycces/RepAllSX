End

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
    Endcase
Endcase
Return
#######################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]CURPTH
   When ""
      Case [L]AMETHOD
        When "INITPARAM" :
                               Gosub INITPARAM
                               Return
        When "FINDVAT"   :
                               Gosub SEARCHVAT
                               Return
        When "LOADPARAM" :
                               Gosub LOADPARAM
                               Return
        When "LOADVATRESULT" :
                               Gosub LOADVATRESULT
                               Return
        When Default
      Endcase
Endcase
Return
#######################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return
#######################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO

Endcase

Return
#######################################################################################

# ----------------------------- #
# Method that Search the VAT    #
# ----------------------------- #
$SEARCHVAT
Local Integer WRET
Local Char    WMESSA(250)

If GENERIC_OBJ = null
  [L]ASTATUS = fmet  this.ASETERROR ("", "GENERIC_OBJ :"-mess(18,9137,1), [V]CST_AERROR)
  [L]ARET_VALUE = [L]ASTATUS
  Return
Endif

#--First, we need to initialize/load the properties
#--Call to a private methode in order to instantiate all needed collection within this (if not done yet)
WRET = fmet this.INITPARAM()
If WRET >= [V]CST_AERROR
  WMESSA = mess(68,123,1)-":"-mess(1,7845,1)- "INITPARAM"
  [L]ASTATUS = fmet GENERIC_OBJ.ASETERROR ("", WMESSA, WRET)
  [L]ASTATUS = fmet        this.ASETERROR ("", WMESSA, WRET)
  [L]ARET_VALUE = [L]ASTATUS
  Return
Endif

#--It's done by calling the "private" method LOADVATPARAMFROMDOC, by passing on the MyDOC pointer
WRET = fmet this.LOADPARAM(GENERIC_OBJ)
If WRET >= [V]CST_AERROR
  WMESSA = mess(68,123,1)-":"-mess(1,7845,1)- "LOADPARAM"
  [L]ASTATUS = fmet GENERIC_OBJ.ASETERROR ("", WMESSA, WRET)
  [L]ASTATUS = fmet        this.ASETERROR ("", WMESSA, WRET)
  [L]ARET_VALUE = [L]ASTATUS
  Return
Endif

#--The black box for Vat searching ("syracusation" of the RECHVATCOD label from vintage TRTX3)
Raz WMESSA
WRET = func TRTX3_SYRA.SEARCHVAT(this,WMESSA)
If WRET >= [V]CST_AERROR | WMESSA<>""
  If WMESSA = ""
    WMESSA = mess(68,123,1)-":"-mess(2,7845,1)- "SEARCHVAT"
 	Endif
 	[L]ASTATUS = fmet GENERIC_OBJ.ASETERROR ("", WMESSA, WRET)
  [L]ASTATUS = fmet        this.ASETERROR ("", WMESSA, WRET)
  [L]ARET_VALUE = [L]ASTATUS
  Return
Endif

#--Loading the Document from the Result class (Help yourself...)
WRET = fmet this.LOADVATRESULT(GENERIC_OBJ)
If WRET >= [V]CST_AERROR
  WMESSA = mess(68,123,1)-":"-mess(1,7845,1)- "LOADVATRESULT"
  [L]ASTATUS = fmet GENERIC_OBJ.ASETERROR ("", WMESSA, WRET)
  [L]ASTATUS = fmet        this.ASETERROR ("", WMESSA, WRET)
  [L]ARET_VALUE = [L]ASTATUS
  Return
Endif

Return
#######################################################################################
# ----------------------------------------------- #
# Method that initializes properties of FINDVAT    #
# ----------------------------------------------- #
$INITPARAM

Local Integer WRET

If this.C_TLK(1) = null
  WRET = fmet this.ADDLINE("C_TLK",1)
  If WRET = [V]CST_ANOTDEFINED
    #--The insertion was not possible
    [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_TLK","FINDVAT"), [V]CST_AERROR)
    Return
  Endif
Endif

Return
#######################################################################################
# ----------------------------------------------- #
# Method that loads properties of FINDVAT         #
# ----------------------------------------------- #
#------------------------------------------------------------------------------
#--LOADVATPARAMFROMDOC => sort of "interface" method
#--We ask the calling object to fill us
#--The object must therefor implements this method in order to be able to call the FINDVAT method
$LOADPARAM
Local Integer WRET

If GENERIC_OBJ=null
  [L]ASTATUS = fmet this.ASETERROR ("", "GENERIC_OBJ :"-mess(18,9137,1), [V]CST_AERROR)
  Return
Endif

Local Instance MYDOC Using =GENERIC_OBJ.ObjectType

MYDOC = cast(GENERIC_OBJ,=GENERIC_OBJ.ObjectType)

#--We ask the calling object to fill us
#--We pass in a pointer to the current instance
WRET = fmet MYDOC.LOADVATPARAMFROMDOC(this)
If WRET >= [V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(1,7845,1)-"LOADPARAM", WRET)
    Return
Endif

$END_LOADPARAM

Return
#######################################################################################
#$ERR_LOADPARAMFROMDOC_METHNOTSUPPORTED
#
#[L]WRET = fmet this.ASETERROR ("", "Class"-MYDOC.ObjectType-" : No such method defined LOADPARAMFROMDOC", [V]CST_AERROR)
#
#Resume
#######################################################################################
# ----------------------------------------------- #
# Method that loads properties of FINDVAT         #
# ----------------------------------------------- #
#------------------------------------------------------------------------------
#--LOADVATRESULTFROMDOC => sort of "interface" method
#--We ask the calling object to get back the result
#--The object must therefor implements this method in order to be able to call the SEARCHVAT method
$LOADVATRESULT
Local Integer WRET

If GENERIC_OBJ=null
  [L]ASTATUS = fmet this.ASETERROR ("", "GENERIC_OBJ :"-mess(18,9137,1), [V]CST_AERROR)
  Return
Endif

Local Instance MYDOC Using =GENERIC_OBJ.ObjectType
MYDOC = cast(GENERIC_OBJ,=GENERIC_OBJ.ObjectType)

#--We ask the calling object to get back
#--The object must therefor implements this method in order to be able to call the SEARCHVAT method
#--We pass in a pointer to the current instance
WRET = fmet MYDOC.LOADVATRESULTFROMFINDVAT(this)
If WRET >= [V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(1,7845,1)-"LOADVATRESULT", WRET)
    Return
Endif

$END_LOADVATRESULT

Return
#######################################################################################

