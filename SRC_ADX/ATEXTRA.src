#<AdxTL>@(#)0.0.0.0 $Revision$ Saisie des textes traduisibles
Local Char VALEUR(10), PARAM(250)(1..4)
PARAM(1) = "ATABDIV"
PARAM(2) = "LNGDES"
PARAM(3) = "1"
PARAM(4) = "ALS"
Call SAISIE_CHAR(VALEUR,PARAM,"ATEXTRA","ATEXTRA","") From GSAISIE
End

#---------------------------------------------------------------------------------#
# Saisie des textes traduisibles suivant les langues du dossier
#---------------------------------------------------------------------------------#

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "TITRE"    : Gosub TIT
 When "SETBOUT"  : Gosub SETBOUT
 When "AP_CHOIX" : Gosub AP_CHOIX
 When "RAF"      : Gosub CHARGE
 When "OK"       : Gosub OK
 When "FIN"      : Gosub FIN
 When "TRT_DIV"  : Gosub TRT_DIV
Endcase
Return

#--------------------------------------------#
$ACTIONB
Local Integer PSUB
Call EXISTE_ADX("","","ATEXTRAB",PSUB) From ORDSYS
If PSUB
 Gosub ACTION From ATEXTRAB
Endif
Return

#------------------------------------#
$TRT_DIV
If find(GREP,"C","D")
 GBOUT1 = ""
Endif
Return

#------------------------------------#
$OUVRE
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If clalev([F:TLA])=0 : Local File TABLAN   [TLA] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON  [ATZ] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif
Call FORMAT(PARAM(2))
Return

Subprog FORMAT(ZONE)
Value Char ZONE
Local Integer TYP
Onerrgo ERREUR
TYP = evalue("type([M]"+ZONE+")")
If TYP<=10
 TYP = evalue("type([M]"+zoncou+")")
Endif
Onerrgo
If TYP<=10
 TYP = type([F:AXX]TEXTE)
Endif
GFMT = "K:"+num$(TYP-10)+"X"
End

$ERREUR
TYP = 0
Resume

#------------------------------------#
$TIT
Read [ATZ]CODZONE = PARAM(1);PARAM(2)
If !fstat
 Call TEXTE([F:ATZ]NOCOURT,TIT) From OBJDIV
 TIT = mess(158,123,1)-TIT : # Traduction en ligne
Endif
Return

#------------------------------------#
$DEBUT
Local Shortint MAXLAN
MAXLAN = dim([M]LANGUE)

Local Char    OGLANGUE(GLONLAN), TABLAN(GLONLAN)(1..MAXLAN)
Local Integer NBLAN , NBTEX
Local Char    SYMBOLE(80) , OVALEUR(250)
Local Integer VERROU

OVALEUR  = VALEUR
OGLANGUE = GLANGUE
Raz [M]
[M]CODFIC = PARAM(1)
[M]ZONE   = PARAM(2)
[M]IDENT1 = PARAM(3)
[M]IDENT2 = PARAM(4)
Read [ADS]DOSSIER = nomap
If OGLANGUE<>""
 NBLAN = 1
 TABLAN(NBLAN) = OGLANGUE
Endif
For I=1 To [F:ADS]NBRLAN
 If [F:ADS]LAN(I-1)<>OGLANGUE
  NBLAN += 1
  TABLAN(NBLAN) = [F:ADS]LAN(I-1)
 Endif
Next I
For [TLA]
 If !find([F:TLA]LAN,TABLAN(1..NBLAN))
  NBLAN += 1
  TABLAN(NBLAN) = [F:TLA]LAN
 Endif
Next TLA
Gosub VERROU
Gosub CHARGE
Return

#------------------------------------#
$CHARGE
J = 0
For I=1 To NBLAN
 Read [AXX]AXX0 = [M]CODFIC;[M]ZONE;TABLAN(I);[M]IDENT1;[M]IDENT2
 If !fstat
  J += 1
  [M]LANGUE(J-1) = TABLAN(I)
  If TABLAN(I)=OGLANGUE
   [M]TEXTE(J-1) = OVALEUR
  Else
   [M]TEXTE(J-1) = [F:AXX]TEXTE
  Endif
 Endif
Next I
[M]NBLIG = J
Affzo
If !VERROU
 Grizo
Else
 Actzo
Endif
Return

#------------------------------------#
$AP_CHOIX
If REPONSE=GSTACLK+3
 Gosub VERROU
 If VERROU
  REPONSE = 0
  Gosub CHARGE
 Endif
Endif
Return

#------------------------------------#
$VERROU
SYMBOLE = [M]CODFIC+"/"+[M]ZONE+"/"+[M]IDENT1+"/"+[M]IDENT2
Lock =SYMBOLE
If !fstat
 VERROU = 1
Else
 VERROU = 0
Endif
Return

#------------------------------------#
$DEVERROU
If VERROU
 Unlock =SYMBOLE
Endif
Return

#------------------------------------#
$SETBOUT
If !VERROU
 Call VIREBOUT(CHBOU,"O") From GOBJET : # Bouton Ok
 IMGFLG(3) = 1 : # Icône Cadenas
Else
 IMGFLG(3) = 0
Endif
If !instr(1,CHBOU,"=") : CHBOU += "=" : Endif
Return

#------------------------------------#
$FIN
GLANGUE = OGLANGUE
Gosub DEVERROU
Return

#------------------------------------#
$OK
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 If OGLANGUE<>""
  I = find(OGLANGUE,[M]LANGUE(0..[M]NBLIG-1))
  If I
   VALEUR = [M]TEXTE(I-1)
  Else
   VALEUR = ""
  Endif
 Endif
Endif
Return

$TR1
GOK = 1
Trbegin [AXX]
 For I=1 To NBLAN
  J = find(TABLAN(I),[M]LANGUE(0..dim([M]LANGUE)-1))
  Read [AXX]AXX0 = [M]CODFIC;[M]ZONE;TABLAN(I);[M]IDENT1;[M]IDENT2
  If !fstat & J=0
   Delete [AXX]AXX0 = [M]CODFIC;[M]ZONE;TABLAN(I);[M]IDENT1;[M]IDENT2
   If fstat=1
    GOK=-1 : Call RSTA("AXX",[M]CODFIC-[M]ZONE-TABLAN(I)-[M]IDENT1-[M]IDENT2) From GLOCK : Break
   Endif
  Elsif J<>0
   GLANGUE = [M]LANGUE(J-1)
   Call MAJTEXTRA([M]TEXTE(J-1),[M]CODFIC,[M]ZONE,[M]IDENT1,[M]IDENT2)
   If GOK<1 : Break : Endif
  Endif
 Next I
 If GOK=-1 : Goto ROLL_TR1
 Elsif GOK=0 : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#----------------------------------------------------------------------------------------------------#
# Lecture d'un texte traduisible
#----------------------------------------------------------------------------------------------------#

Subprog LECTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
Variable Char    VALEUR()
Value    Char    TABLE, CHAMP, CLE1, CLE2
Local    Char    ACTION(20)
Local Integer    OK
If GPRODUIT=1 : Gosub MODIF_CLE : Endif : # Géode
OK = 1
ACTION = "LECTEXTRA" : Gosub ACTIONB
If !OK : End : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
Read [AXX]AXX0 = TABLE;CHAMP;GLANGUE;CLE1;CLE2
If fstat=0
 VALEUR = [F:AXX]TEXTE
Else
 Read [AXX]AXX0 = TABLE;CHAMP;GLANDEF;CLE1;CLE2
 If fstat=0
  VALEUR = [F:AXX]TEXTE
 Else
  VALEUR = ""
 Endif
Endif
ACTION = "ClOSETEXTRA" : Gosub ACTIONB
End

Subprog LECTEXTRA_SYR(AINSTANCE,APRONAME, AVALUE,TABLE,CHAMP,CLE1,CLE2)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value    Char    TABLE, CHAMP, CLE1, CLE2
Call LECTEXTRA(AINSTANCE,APRONAME, AVALUE,TABLE,CHAMP,CLE1,CLE2) From ASYRFNC
End

#----------#
$MODIF_CLE
If  dim(GFCY)>0 &  dim(GDEP)>0 : ##----- GEODE
  #-Si FCY ou FCY~DEP pas ds CLE1-> On ajoute éventuellement GFCY ou GFCY+GDEP ds recherche sur IDENT1 de ATEXTRA -#
  Local Char    CLE_DECOUP(10)(10)
  #LSE 03/03/2011 FQ71991
  #Local Integer FCYDEPOK, I
  #FCYDEPOK=1
  Local Integer INBVAL
  Local Integer INBCLE
  Local Char CLETMP (type(CLE1)-10)
  Local Integer N
  Local Integer K

  #Call SUPPN(CLE1,CLE_DECOUP) From CONTOBJ
  #-- ELA 06012011-#
  #For I=0 To CLE_DECOUP(I)=""
  # If CLE_DECOUP(I)=GFCY : FCYDEPOK=2 : Break : Endif
  #Next I
  #For I=0 To dim(CLE_DECOUP)-1 : # EL 05/01/2011
  # If CLE_DECOUP(I)="" : Break : Endif : # EL 05/01/2011
  # If CLE_DECOUP(I)=GFCY : FCYDEPOK=2 : Break : Endif
  #Next I

  Raz CLE_DECOUP
  #Il faut tenir compte des valeurs vide...
  INBVAL=0
  CLETMP =CLE1
  Repeat
    K = instr(1,CLETMP ,"~")
    If !K :
      CLE_DECOUP(N)=CLETMP
      INBVAL=INBVAL+1
      N+=1
      Break
    Endif
    CLE_DECOUP(N) = left$(CLETMP ,K-1)
    N+=1
    INBVAL=INBVAL+1
    CLETMP = right$(CLETMP ,K+1)
  Until dim(CLE_DECOUP)=N

  If CLE2<>""
    INBVAL=INBVAL+1
  Endif

  #-- ELA 06012011-#
  #If FCYDEPOK<>2

  Local Integer PSUB , PSPE , PSPV , PSTD, TYPENV
  Local Char    PROGOBJ(GDIMFIC) , PROGSUB(GDIMFIC) , PROGSPE(GDIMFIC) , PROGSPV(GDIMFIC)(1..50)
  Local Char    CLEGEO1(GLONFCY+GLONDEP+2+len(CLE1)) , CLEGEO2(max(1,len(CLE2),len(CLE1)))
  Local File AOBJET [AOB]

  Read [AOB]NOMFIC(1)=[L]TABLE
  If fstat<=2
    Call SETPROG([F:AOB]ABREV,PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
    Gosub SETCLE From =PROGOBJ
    If dim([L]CLEFCY)>0 & [L]CLEFCY<>"" : TYPENV=1 : Endif
    If dim([L]CLEDEP)>0 & [L]CLEDEP<>"" : TYPENV=2 : Endif

    INBCLE=0
    If CLEPRIM<>""
      INBCLE=1
      For I=0 To dim(CLESEC)-1
        If CLESEC(I)<>""
          INBCLE=INBCLE+1
        Endif
      Next I
    Endif
    If (TYPENV =1 or TYPENV=2) and  INBVAL<INBCLE
      # on a une gestion des site ou site déposant et pas assez de valeur => on complete
      If CLE2 = ""
        If TYPENV=2
          CLEGEO1 = GFCY + '~' + GDEP
          CLEGEO2 = CLE1
        Elsif TYPENV=1
          CLEGEO1 = GFCY
          CLEGEO2 = CLE1
        Else
          CLEGEO1 = CLE1
          CLEGEO2 = ""
        Endif
      Else
        If TYPENV=2
          CLEGEO1 = GFCY + '~' + GDEP + '~' + CLE1
        Elsif TYPENV=1
          CLEGEO1 = GFCY + '~' + CLE1
        Else
          CLEGEO1 = CLE1
        Endif
        CLEGEO2 = CLE2
      Endif

      CLE1 = CLEGEO1
      CLE2 = CLEGEO2
    Endif

  Endif
Endif
Return

#----------------------------------------------------------------------------------------------------#
# Création ou modification d'un texte traduisible
#----------------------------------------------------------------------------------------------------#
Subprog MAJTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
Value    Char    VALEUR, TABLE, CHAMP, CLE1, CLE2
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR_MAJTEX
Else
 Gosub MAJTEX
Endif
End

$TR_MAJTEX
Trbegin [AXX]
 Gosub MAJTEX
 If GOK=-1 : Goto ROLL_MAJTEX
 Elsif GOK<1 : Goto AB_MAJTEX
 Endif
Commit
Return

$AB_MAJTEX
Rollback
Return

$ROLL_MAJTEX
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_MAJTEX : Endif

$MAJTEX
Readlock [AXX]AXX0 = TABLE;CHAMP;GLANGUE;CLE1;CLE2
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA"
Elsif !fstat
 [F:AXX]TEXTE = VALEUR
 Call FLDUPD("AXX") From OBJDIV
 Rewrite [AXX]
 If fstat
  GOK=0 : Call FSTA("AXX") From GLOCK
 Endif
Else
 Raz [F:AXX]
 [F:AXX]CODFIC = TABLE
 [F:AXX]ZONE   = CHAMP
 [F:AXX]LANGUE = GLANGUE
 [F:AXX]TEXTE  = VALEUR
 [F:AXX]IDENT1 = CLE1
 [F:AXX]IDENT2 = CLE2
 Call FLDCRE("AXX") From OBJDIV
 Write [AXX]
 If fstat
  GOK=0 : Call FSTA("AXX") From GLOCK
 Endif
Endif
Return

#----------------------------------------------------------------------------------------------------#
# Suppression d'un texte traduisible
#----------------------------------------------------------------------------------------------------#
Subprog SUPTEXLAN(TABLE,CHAMP,LAN,CLE1,CLE2)
Value    Char    TABLE, CHAMP, LAN, CLE1, CLE2
Goto SUP

Subprog SUPTEXTRA(TABLE,CHAMP,CLE1,CLE2)
Value    Char    TABLE, CHAMP, CLE1, CLE2
Local Char LAN(GLONLAN)
LAN = ""
Goto SUP

$SUP
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR_SUPTEX
Else
 Gosub SUPTEX
Endif
End

$TR_SUPTEX
Trbegin [AXX]
 Gosub SUPTEX
 If GOK=-1 : Goto ROLL_SUPTEX
 Elsif GOK<1 : Goto AB_SUPTEX
 Endif
Commit
Return

$AB_SUPTEX
Rollback
Return

$ROLL_SUPTEX
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_SUPTEX : Endif

$SUPTEX
If LAN=""
 Delete [AXX] Where CODFIC=TABLE & ZONE=CHAMP & IDENT1=CLE1 & IDENT2=CLE2
Else
 Delete [AXX] Where CODFIC=TABLE & ZONE=CHAMP & LANGUE=LAN & IDENT1=CLE1 & IDENT2=CLE2
Endif
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA"
Elsif fstat
 GOK=0 : Call FSTA("AXX") From GLOCK
Endif
Return

#----------------------------------------------------------------------------------------------------#
# Duplication d'un texte traduisible
#----------------------------------------------------------------------------------------------------#

Subprog DUPTEXTRA(TABORG,FLDORG,CLEORG1,CLEORG2,TABDES,FLDDES,CLEDES1,CLEDES2)
Value    Char    TABORG,FLDORG,CLEORG1,CLEORG2,TABDES,FLDDES,CLEDES1,CLEDES2
If TABORG=TABDES & FLDORG=FLDDES & CLEORG1=CLEDES1 & CLEORG2=CLEDES2
 End
Endif
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR_DUPTEX
Else
 Gosub DUPTEX
Endif
End

$TR_DUPTEX
Trbegin [AXX]
 Gosub DUPTEX
 If GOK=-1 : Goto ROLL_DUPTEX
 Elsif GOK<1 : Goto AB_DUPTEX
 Endif
Commit
Return

$AB_DUPTEX
Rollback
Return

$ROLL_DUPTEX
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_DUPTEX : Endif

$DUPTEX
Delete [AXX] Where CODFIC=TABDES & ZONE=FLDDES & IDENT1=CLEDES1 & IDENT2=CLEDES2
If fstat=1
 GOK=-1 : Call RSTA("AXX",TABDES-FLDDES-CLEDES1-CLEDES2) From GLOCK
Endif
For [AXX]AXX0 Where CODFIC=TABORG & ZONE=FLDORG & IDENT1=CLEORG1 & IDENT2=CLEORG2
 [F:AXX]CODFIC = TABDES
 [F:AXX]ZONE   = FLDDES
 [F:AXX]IDENT1 = CLEDES1
 [F:AXX]IDENT2 = CLEDES2
 Call FLDCRE("AXX") From OBJDIV
 Write [AXX]
 If fstat
  GOK=0 : Call FSTA("AXX") From GLOCK
 Endif
Next AXX
Return

#----------------------------------------------------------------------------------------------------#
# Changement de clé d'un texte traduisible
#----------------------------------------------------------------------------------------------------#

Subprog CHGTEXTRA(TABLE,CHAMP,CLE1,CLE2,NEWCLE1,NEWCLE2)
Value    Char    TABLE,CHAMP,CLE1,CLE2,NEWCLE1,NEWCLE2
If CLE1=NEWCLE1 & CLE2=NEWCLE2
 End
Endif
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR_CHGTEX
Else
 Gosub CHGTEX
Endif
End

$TR_CHGTEX
Trbegin [AXX]
 Gosub CHGTEX
 If GOK=-1 : Goto ROLL_CHGTEX
 Elsif GOK<1 : Goto AB_CHGTEX
 Endif
Commit
Return

$AB_CHGTEX
Rollback
Return

$ROLL_CHGTEX
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_CHGTEX : Endif

$CHGTEX
Update [AXX] Where CODFIC=TABLE & ZONE=CHAMP & IDENT1=CLE1 & IDENT2=CLE2 With IDENT1=NEWCLE1, IDENT2=NEWCLE2
If fstat=1
 GOK=-1 : Call RSTA("AXX",TABLE-CHAMP-CLE1-CLE2) From GLOCK
Elsif fstat
 GOK=0 : Call FSTA("AXX") From GLOCK
Endif
Return

#-------------------------------------------------------------------------------------------------------#
# Copie des textes du dossier origine sans supprimer les autres textes du dossier destination
#-------------------------------------------------------------------------------------------------------#

Subprog COPTEXTRA(TABLE,CHAMP,CLE1,CLE2)
Value    Char    TABLE, CHAMP, CLE1, CLE2
For [AXX1] Where CODFIC=TABLE & ZONE=CHAMP & IDENT1=CLE1 & IDENT2=CLE2
 Read [F:AXX2]AXX0 = TABLE;CHAMP;[F:AXX1]LANGUE;CLE1;CLE2
 If !fstat
  [F:AXX2]TEXTE = [F:AXX1]TEXTE
  Call FLDUPD("AXX2") From OBJDIV
  Rewrite [AXX2]
  If fstat
   GOK=0 : Call FSTA("AXX2") From GLOCK : Break
  Endif
 Else
  [F:AXX2] = [F:AXX1]
  Call FLDUPD("AXX2") From OBJDIV
  Write [AXX2]
  If fstat
   GOK=0 : Call FSTA("AXX2") From GLOCK : Break
  Endif
 Endif
Next
End

#----------------------------------------------------------------------------------------------------#
# Parametre d'un texte traduisible
#----------------------------------------------------------------------------------------------------#

Subprog PARAMTEXTRA(TABLE,CHAMP,CLE1,CLE2)
Value Char TABLE : # Table
Value Char CHAMP : # Champ
Value Char CLE1 : # Clé1
Value Char CLE2 : # Clé2
End


#----------------------------------------------------------------------------------------------------#
# Permet de retrouver l'application Superviseur des dossiers origine et destination
# pour la copie des textes traduisibles dans les langues communes aux deux dossiers
#----------------------------------------------------------------------------------------------------#

$OUVDOS

Gosub OUVLAN

Local Char APPLI(GDIMFIC), MERE(GDIMFIC), MACHINE(GDIMFIC)

If dim([M]DOSORG)<=0 | dim([M]DOSDES)<=0
 Return
Endif

If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif

Call MOTHER([M]DOSORG,APPLI,MERE,MACHINE)
If MERE<>""
 If MACHINE=""
  If MERE=nomap
   Local File ADOSSIER [ADS1]
  Else
   Local File =MERE+".ADOSSIER" [ADS1]
  Endif
 Else
  Local File =MACHINE+"@"+MERE+".ADOSSIER" [ADS1]
 Endif
 Read [ADS1]DOSSIER = APPLI
 If fstat : Raz [F:ADS1] : Endif
Endif

Call MOTHER([M]DOSDES,APPLI,MERE,MACHINE)
If MERE<>""
 If MACHINE=""
  If MERE=nomap
   Local File ADOSSIER [ADS2]
  Else
   Local File =MERE+".ADOSSIER" [ADS2]
  Endif
 Else
  Local File =MACHINE+"@"+MERE+".ADOSSIER" [ADS2]
 Endif
 Read [ADS2]DOSSIER = APPLI
 If fstat : Raz [F:ADS2] : Endif
Endif
Return

#------------------------------------------------------------#
# Permet de retrouver l'application Superviseur d'une appli
#------------------------------------------------------------#

Subprog MOTHER(DOSSIER,APPLI,MERE,MACHINE)
Value    Char DOSSIER
Variable Char APPLI
Variable Char MERE
Variable Char MACHINE
Local Char    CHEMIN(250) , VOLUME(80)
Local Char    LIGNE(80) , VARIA(20) , VALEUR(20)
Local Integer I , J

Raz APPLI, MERE, MACHINE

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Call VOLUME(MACHINE,APPLI,VOLUME) From ORDSYS

CHEMIN = filpath("","APL","ini",APPLI,VOLUME,MACHINE)
If filinfo(CHEMIN,0)<0 : End : Endif

Openi CHEMIN Using [INI]
Iomode adxirs chr$(10) Using [INI]
Iomode adxifs "" Using [INI]
Iomode adxium GASCII Using [INI]
Rdseq LIGNE Using [INI]
Repeat
 I = instr(1,LIGNE,"=")
 If I
  VARIA  = vireblc(left$(LIGNE,I-1),2)
  VALEUR = vireblc(right$(LIGNE,I+1),2)
  I = instr(1,VALEUR,'"')
  J = instr(I+1,VALEUR,'"')
  If I & J
   VALEUR = seg$(VALEUR,I+1,J-1)
  Else
   I = instr(1,VALEUR,"'")
   J = instr(I+1,VALEUR,"'")
   If I & J
    VALEUR = seg$(VALEUR,I+1,J-1)
   Endif
  Endif
  If left$(VARIA,10)="adxmother("
   If filinfo(filpath("FIL","ADOSSIER","fde",VALEUR,"",MACHINE),0)>0
    MERE = VALEUR : Break
   Endif
  Endif
 Endif
 Rdseq LIGNE Using [INI]
Until fstat
Openi Using [INI]
End

#---------------------------------------------#

$OUVLAN
If dim([M]DOSORG)<=0 | dim([M]DOSDES)<=0
 Return
Endif

If clalev([F:TLA1])>0 : Close Local File [TLA1] : Endif
If clalev([F:TLA2])>0 : Close Local File [TLA2] : Endif

If [M]DOSORG=nomap
 Local File TABLAN [TLA1]
Else
 Local File =[M]DOSORG+".TABLAN" [TLA1]
Endif
If [M]DOSDES=nomap
 Local File TABLAN [TLA2]
Else
 Local File =[M]DOSDES+".TABLAN" [TLA2]
Endif
Return

#----------------------------------------------------------------------------------------------------#
# Calcul de la clé secondaire
#----------------------------------------------------------------------------------------------------#

Subprog SETCLE(OBJET,ABREV,CLE2)
Value    Char OBJET : # Objet
Value    Char ABREV : # [F:abrev] ou [M:abrev]
Variable Char CLE2  : # Clesec(0) ~ clesec(n)
Local    Integer I
Gosub SETCLE From ="WO"+OBJET
CLE2 = ""
For I=0 To dim(CLESEC)-1
 If CLESEC(I)<>""
  If CLE2<>"" : CLE2 += "~" : Endif
  CLE2 += num$(evalue(ABREV+CLESEC(I)))
 Endif
Next I
End




