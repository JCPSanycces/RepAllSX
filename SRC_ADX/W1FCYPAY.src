Subprog AS_RSKWRK(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45608,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_RSKWRK(zc) From W1FCYPAY
Onkey   2 Titled GBOUTS Call S_RSKWRK(zc) From W1FCYPAY
Onkey 144 Titled GBOUTP Call P_RSKWRK(zc) From W1FCYPAY
Onkey 146 Titled GBOUTA Call SA_RSKWRK(zc) From W1FCYPAY
Gosub _AFF
End

Subprog C_RSKWRK(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("VAC","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "RSKWRK" : GZNUM = 46041 : Endif
Gosub _AFF
End

$AMM_RSKWRK
Call AM_RSKWRK(zc)
If !mkstat & GOBJET
 zoncou = "RSKWRK" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_RSKWRK(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZRSKWRK)")>indice
 [M]RSKWRK(indice) = VALEUR
 Affzo ZRSKWRK(indice)
Endif
Gosub _AFF
End

Subprog S_RSKWRK(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "VAC"
PARMSK(2) = "!"
