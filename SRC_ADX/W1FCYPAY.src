#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque FCYPAY 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:16"
A_USER  = "DOC"
A_STAMP = "20181109230416"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRCHEF"
  If [M]NBRCHEF=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask FCYPAY [FCYP]
Gosub HORODAT
Local Inpbox "FCYPAY" From GFONCTION At A_STAMP With A_WINDPREV Mask [FCYP] As [SIM_]
Grizo [FCYP]5
Grizo [FCYP]10
Grizo [FCYP]15
Grizo [FCYP]20
Grizo [FCYP]25
Grizo [FCYP]30
Grizo [FCYP]31
Grizo [FCYP]32
Grizo [FCYP]35
Grizo [FCYP]45
Grizo [FCYP]50
Grizo [FCYP]55
Grizo [FCYP]60
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [FCYP]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=55 : Y1(0)=1 : Y2(0)=4
X1(1)=56 : X2(1)=104 : Y1(1)=1 : Y2(1)=4
X1(2)=1 : X2(2)=55 : Y1(2)=5 : Y2(2)=10
X1(3)=56 : X2(3)=104 : Y1(3)=5 : Y2(3)=10
X1(4)=1 : X2(4)=104 : Y1(4)=11 : Y2(4)=12
X1(5)=1 : X2(5)=104 : Y1(5)=13 : Y2(5)=14
X1(6)=1 : X2(6)=55 : Y1(6)=15 : Y2(6)=16
X1(7)=56 : X2(7)=104 : Y1(7)=15 : Y2(7)=16
X1(8)=1 : X2(8)=104 : Y1(8)=17 : Y2(8)=16
X1(9)=1 : X2(9)=94 : Y1(9)=17 : Y2(9)=23
X1(10)=1 : X2(10)=104 : Y1(10)=24 : Y2(10)=27
X1(11)=1 : X2(11)=55 : Y1(11)=28 : Y2(11)=32
X1(12)=56 : X2(12)=94 : Y1(12)=28 : Y2(12)=32
Return

$ON_PAYFLG
Onevent INIT_AREA Call D_PAYFLG(zc) From W1FCYPAY
Onevent BEFORE_INPUT Call AS_PAYFLG(zc) From W1FCYPAY
Return

Subprog D_PAYFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]PAYFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PAYFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_HRMDADFLG
Onevent CONTROL Call C_HRMDADFLG(zc) From W1FCYPAY
Onevent AFTER_CHANGE Gosub AMM_HRMDADFLG From W1FCYPAY
Onevent INIT_AREA Call D_HRMDADFLG(zc) From W1FCYPAY
Onevent BEFORE_INPUT Call AS_HRMDADFLG(zc) From W1FCYPAY
Return

Subprog D_HRMDADFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]HRMDADFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_HRMDADFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_HRMDADFLG(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_HRMDADFLG(VALEUR) From SUBFCYB
If mkstat : GERR = 1 : GZONE = "HRMDADFLG" : GZNUM = 47537 : Endif
Gosub _AFF
End

$AMM_HRMDADFLG
Call AM_HRMDADFLG(zc)
If !mkstat & GOBJET
 zoncou = "HRMDADFLG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_HRMDADFLG(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_HRMDADFLG(VALEUR) From SUBFCYB
If mkstat : GERR = 1 : GZONE = "HRMDADFLG" : GZNUM = 47537 : Endif
Gosub _AFF
End

$ON_HRMDADFCY
Onevent CONTROL Call C_HRMDADFCY(zc) From W1FCYPAY
Onevent BEFORE_INPUT Call AS_HRMDADFCY(zc) From W1FCYPAY
Onevent AFTER_CHANGE Gosub AMM_HRMDADFCY From W1FCYPAY
Return

Subprog AS_HRMDADFCY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_HRMDADFCY(VALEUR) From SUBFCYB
If mkstat=2
 [M]HRMDADFCY(INDIC) = VALEUR
 Affzo HRMDADFCY(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_HRMDADFCY(zc) From W1FCYPAY
Onkey 144 Titled GBOUTP Call P_HRMDADFCY(zc) From W1FCYPAY
Onkey 146 Titled GBOUTA Call SA_HRMDADFCY(zc) From W1FCYPAY
Gosub _AFF
End

Subprog C_HRMDADFCY(VALEUR)
Variable Char    VALEUR()
## Action ACONTFCY
Call CONTSITE(VALEUR) From SUBAGF
If mkstat : GERR = 1 : GZONE = "HRMDADFCY" : GZNUM = 11232 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("FCY","!$H",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "HRMDADFCY" : GZNUM = 11232 : Endif
 If !mkstat
  ## Action STD
  Call C_HRMDADFCY(VALEUR) From SUBFCYB
  If mkstat : GERR = 1 : GZONE = "HRMDADFCY" : GZNUM = 11232 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_HRMDADFCY
Call AM_HRMDADFCY(zc)
If !mkstat & GOBJET
 zoncou = "HRMDADFCY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_HRMDADFCY(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_HRMDADFCY(VALEUR) From SUBFCYB
If mkstat : GERR = 1 : GZONE = "HRMDADFCY" : GZNUM = 11232 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZHRMDADFCY)")>indice
 [M]HRMDADFCY(indice) = VALEUR
 Affzo ZHRMDADFCY(indice)
Endif
Gosub _AFF
End

Subprog S_HRMDADFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "FCY"
PARMSK(2) = "!$H"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_HRMDADFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FCY"
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_HRMDADFCY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZHRMDADFCY
Onevent BEFORE_AREA Gosub AV_ZHRMDADFCY From W1FCYPAY
Return

$AV_ZHRMDADFCY
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Local File FACILITY [F_] 
[F:F_]=[F:FCY]
Call LECTURE("FCY",num$([M]HRMDADFCY(indice)),"") From CONTOBJ
zc = [F:FCY]FCYNAM
[F:FCY]=[F:F_]
Close Local File [F_]
Gosub _AFF
Return

