Subprog AS_CHEF(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CHEF(zc) From W1FCYPAY
Onkey 144 Titled GBOUTP Call P_CHEF(zc) From W1FCYPAY
Onkey 146 Titled GBOUTA Call SA_CHEF(zc) From W1FCYPAY
Gosub _AFF
End

Subprog C_CHEF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTEMP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTEMP"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 PARMSK(6) = GCURLEG
 Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CHEF" : GZNUM = 10793 : Endif
Endif
If !mkstat
 ## Action DROITEMP
 Call DROIT(VALEUR,"","","") From DIVPAYE
 If mkstat : GERR = 1 : GZONE = "CHEF" : GZNUM = 10793 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("EML","!",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CHEF" : GZNUM = 10793 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_CHEF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMLLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMLLEG"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_CHEF" : PROGSUB = "SUBFCYB" : PROGSPE = "SPEFCY" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = GCURLEG
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELEMLLEG","TOOLSHRLEG","") From GACTION
 ACTION = "BS_CHEF" : PROGSUB = "SUBFCYB" : PROGSPE = "SPEFCY" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_CHEF(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EML"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CHEF(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("EML",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

