#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
    Case [L]CURPTH
        When ""
            Case [L]AEVENT
                When "AINSERT_CONTROL_BEFORE" : Gosub EVENT_LINE_IS_MOVED
                When "AUPDATE_CONTROL_BEFORE" : Gosub EVENT_LINE_IS_MOVED
                When "ACONTROL"               : Gosub EVENT_ACONTROL
            Endcase
    Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
    Case [L]AMETHOD
        When "GETJSONTRANS"  : Gosub GETJSONTRANS
    Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


$EVENT_ACONTROL
    Local Integer I
    Local Integer COUNT : COUNT = 0
    Local Integer LEVEL : LEVEL = -1
    Local Integer TMPLEVEL
    Local Integer INDEX(maxtab(this.LINES) + 1)

    # Initialize re-indexing of lines for to work in correct order.
    For [L]I = 0 To maxtab(this.LINES)
        INDEX(I) = 0
    Next
    For [L]I = 1 To maxtab(this.LINES)
        If this.LINES([L]I) <> null
&           and this.LINES([L]I).ASTALIN <> [V]CST_ADEL
&           and this.LINES([L]I).ASTALIN <> [V]CST_ANEWDEL
            INDEX(this.LINES([L]I).LIN)  = [L]I
            COUNT += 1
        Endif
    Next

    # Check that there are lines at all.
    If COUNT <= 0
        ASTATUS = fmet this.ASETERROR("", mess(32,7703,1), [V]CST_AERROR) # 'Detail lines are required.'
        Return
    Endif

    # Loop throug all lines and perform checks
    For [L]I = 1 To maxtab(this.LINES)
        If INDEX(I) <> 0
            # Check level rules (start by 0, ascending, no gaps)
            TMPLEVEL = this.LINES(INDEX([L]I)).LEV
            If TMPLEVEL < 0 # Positive level numbers
                ASTATUS = fmet this.LINES(INDEX([L]I)).ASETERROR( "LEV", mess(204,7703,1), [V]CST_AERROR )
                # 'Level numbers have to start with 0 and continue in ascending order without gaps between level numbers.'
            Endif
            If TMPLEVEL < LEVEL # Monotonous growth
                ASTATUS = fmet this.LINES(INDEX([L]I)).ASETERROR( "LEV", mess(204,7703,1), [V]CST_AERROR )
                # 'Level numbers have to start with 0 and continue in ascending order without gaps between level numbers.'
            Endif
            If TMPLEVEL - LEVEL > 1 # Maximum growth by 1
                ASTATUS = fmet this.LINES(INDEX([L]I)).ASETERROR( "LEV", mess(204,7703,1), [V]CST_AERROR )
                # 'Level numbers have to start with 0 and continue in ascending order without gaps between level numbers.'
            Endif
            LEVEL = TMPLEVEL

            # Some minor syntax checks on elements
            If not func IS_ELEMENT(this.LINES(INDEX([L]I)).ELT)
                ASTATUS = fmet this.LINES(INDEX([L]I)).ASETERROR( "ELT", func AFNC.MES1( mess(203,7703,1), num$(this.LINES(INDEX([L]I)).LIN) ), [V]CST_AERROR ) # 'Syntax error in line $1$.'
            Endif

            # Some minor syntax checks on paths
            If not func IS_ELEMENTPATH(this.LINES(INDEX([L]I)).ELTPAH)
                ASTATUS = fmet this.LINES(INDEX([L]I)).ASETERROR( "ELTPAH", func AFNC.MES1( mess(203,7703,1), num$(this.LINES(INDEX([L]I)).LIN) ), [V]CST_AERROR ) # 'Syntax error in line $1$.'
            Endif
        Endif
    Next
Return

########################################################################################################################

Funprog IS_ELEMENTPART(ELEMPART)
Value Char ELEMPART

    If ELEMPART = ""
        End 0
    Endif
End 1

Funprog IS_ELEMENTCHAIN(ELEMENT)
Value Char ELEMENT
    Local Integer OPOS, POS
    Local Char ELEMPART(255)

    ELEMENT = vireblc(ELEMENT, 2)
    If ELEMENT = ""
        End 1
    Endif

    OPOS = instr(1, ELEMENT, "." )
    If OPOS <= 0
        End func IS_ELEMENTPART(ELEMENT)
    Else
        If OPOS > 1
            ELEMPART = left$(ELEMENT, OPOS - 1 )
            If !func IS_ELEMENTPART(ELEMPART)
                End 0
            Endif
        Endif
        OPOS += 1
        POS = instr(OPOS, ELEMENT, "." )
        While POS
            ELEMPART = mid$( ELEMENT, OPOS, POS - OPOS)
            If !func IS_ELEMENTPART(ELEMPART)
                End 0
            Endif
            OPOS = POS + 1
            POS = instr(OPOS, ELEMENT, "." )
        Wend
        ELEMPART = right$( ELEMENT, OPOS )
        If !func IS_ELEMENTPART(ELEMPART)
            End 0
        Endif
    Endif
End 1

Funprog IS_ELEMENT(ELEMENT)
Value Char ELEMENT

    ELEMENT = vireblc(ELEMENT, 2)
    If ELEMENT = ""
        End 1
    Endif
    If left$( ELEMENT, 1 ) = "."
        End 0
    Endif
End func IS_ELEMENTCHAIN(ELEMENT)

Funprog IS_ELEMENTPATH(ELEMENT)
Value Char ELEMENT
    Local Integer POS, POSR

    ELEMENT = vireblc(ELEMENT, 2)
    If ELEMENT = ""
        End 1
    Endif

    POS  = instr( 1, ELEMENT, "[" )
    POSR = instr( 1, ELEMENT, "]" )
    If POS = 0 and POSR = 0             # No [] in element path --> OK
    Else
        If POS = 0 and POSR <> 0        # Only ] in elment path --> not OK
            End 0
        Endif
        If POS = 1                      # Path cannot start with [.
            End 0
        Endif
        If POS <> len( ELEMENT ) - 1    # [] only allowed at the end.
            End 0
        Endif
        If POSR - POS <> 1              # ] must follow directly [.
            End 0
        Endif
        ELEMENT = left$( ELEMENT, len( ELEMENT ) - 2 )
    Endif

    If !func IS_ELEMENTCHAIN(ELEMENT)
        End 0
    Endif
End 1

########################################################################################################################

$EVENT_LINE_IS_MOVED
    Local Integer I, J

    # loop throug all lines
    For [L]I = 1 To maxtab(this.LINES)
        If this.LINES([L]I) <> null
&           and this.LINES([L]I).ASTALIN <> [V]CST_ADEL
&           and this.LINES([L]I).ASTALIN <> [V]CST_ANEWDEL
&           and this.LINES([L]I).AORDER  <> this.LINES([L]I).LIN
&       Then
            # delete the line
            ASTATUS = fmet this.ADELLINE("LINES", this.LINES([L]I).AORDER)
            # add new line
            [L]J = fmet this.ADDLINE("LINES", this.LINES([L]I).AORDER)
            If [L]J <> [V]CST_ANOTDEFINED Then
                # copy contents
                this.LINES([L]J).COD    = this.COD
                this.LINES([L]J).LIN    = this.LINES([L]I).AORDER
                this.LINES([L]J).DES    = this.LINES([L]I).DES
                this.LINES([L]J).LEV    = this.LINES([L]I).LEV
                this.LINES([L]J).ELTPAH = this.LINES([L]I).ELTPAH
                this.LINES([L]J).ELT    = this.LINES([L]I).ELT
            Endif
        Endif
    Next
Return

########################################################################################################################

$GETJSONTRANS
    Local Integer I, COUNT

    # Embed all JSON objects in an array.
    ARET_VALUE = '['

    # Loop throug all lines and create a JSON object for each line.
    COUNT = maxtab( this.LINES )
    For [L]I = 1 To COUNT
        # Only use lines that are not marked as deleted.
        If this.LINES([L]I) <> null
&        and this.LINES([L]I).ASTALIN <> [V]CST_ADEL
&        and this.LINES([L]I).ASTALIN <> [V]CST_ANEWDEL
            Append ARET_VALUE, '{'
            Append ARET_VALUE, '"level":' + num$( this.LINES([L]I).LEV ) + ','
            Append ARET_VALUE, '"path":' + '"' + this.LINES([L]I).ELTPAH + '",'
            Append ARET_VALUE, '"value":' + '"' + this.LINES([L]I).ELT + '"'
            Append ARET_VALUE, '}'
            If [L]I < COUNT
                Append ARET_VALUE, ',' + chr$(13) + chr$(10)
            Endif
        Endif
    Next

    # Close array.
    Append ARET_VALUE, ']'
Return

