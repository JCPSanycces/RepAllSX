#<AdxTL>@(#)2.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value Integer    NBPAR
Variable Char    PARAMETRE()()
#--- ouverture des tables
Gosub OUVRE
#--- declaration des variables
Gosub DECLARE

[L]CRITERE = "1=1"
#--- analyse des paramètres
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
   #--- alimentation des paramètres utilisateur
   When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
   When "lotcod"          : [L]PARAMETRE(I) = "lotcod="+num$([L]VALEUR)
                            [L]LOTCOD = val([L]VALEUR)
   When "slocod"          : [L]PARAMETRE(I) = "slocod="+num$([L]VALEUR)
                            [L]SLOCOD  = val([L]VALEUR)
   When "loccod"          : [L]PARAMETRE(I) = "loccod="+num$([L]VALEUR)
                            [L]LOCCOD = val([L]VALEUR)
   When "stacod"          : [L]PARAMETRE(I) = "stacod="+num$([L]VALEUR)
                            [L]STACOD = val([L]VALEUR)
   When "sercod"          : [L]PARAMETRE(I) = "sercod="+num$([L]VALEUR)
                            [L]SERCOD = val([L]VALEUR)
   When "idecod1"         : [L]PARAMETRE(I) = "idecod1="+num$([L]VALEUR)
                            [L]IDECOD1 = val([L]VALEUR)
   When "idecod2"         : [L]PARAMETRE(I) = "idecod2="+num$([L]VALEUR)
                            [L]IDECOD2 = val([L]VALEUR)
   When "ilc"             : [L]PARAMETRE(I) = "ilc="+num$([L]VALEUR)                      # hcb 71659
                            [L]ILC      = val([L]VALEUR)                                  # hcb 71659
   When "impqtytheorique" : [L]PARAMETRE(I) = "impqtytheorique="+num$([L]VALEUR)          # hcb X3-43892
                            [L]IMPQTYTHEORIQUE  = val([L]VALEUR)                          # hcb X3-43892
   #--- préparation du filtre à appliquer sur la table CUD
   When "stofcy"          : [L]CRITERE -= "& STOFCY='"+[L]VALEUR+"'"
   When "sssnum"          : [L]CRITERE -= "& CUNSSSNUM='"+[L]VALEUR+"'"
                            [L]CUNSSSNUM= [L]VALEUR
   When "lisnumdeb"       : [L]CRITERE -= "& CUNLISNUM>='"+[L]VALEUR+"'"
   When "lisnumfin"       : [L]CRITERE -= "& CUNLISNUM<='"+[L]VALEUR+"'"
 Endcase
 Endif
Next

# agrégation demandée : agrflg=1
If LOTCOD=0 & SLOCOD=0 & LOCCOD=0 & STACOD=0 & SERCOD=0 & IDECOD1=0 & IDECOD2=0
     AGRFLG=0
Else AGRFLG = 1
Endif
    #                                                                                         # hcb 71659 deb
#  Lecture de la session pour savoir si c est un inventaire en multi-comptages
Read [F:CUN]CUN0=[L]CUNSSSNUM
If fstat
   Raz [F:CUN]
Endif

# si la session ne gére pas le multi comptage valeur  6 et 6 impossible
If [F:CUN]MULCTGFLG <> 2  & [L]ILC > 4
   [L]ILC = 2
Endif

# Coomptées
If [L]ILC = 2
    CRITERE -= "& ([F:CUD]QTYSTUNEW <> 0 | [F:CUD]ZERSTOFLG = 2)"
Endif

# A compter
If [L]ILC = 3
    CRITERE -= "& [F:CUD]QTYSTUNEW = 0 & [F:CUD]ZERSTOFLG < 2"
Endif
# Comptées avec écart
If [L]ILC = 4
    CRITERE -= "& ([F:CUD]CUNLISSTA = 2 | [F:CUD]CUNLISSTA = 4) & ([F:CUD]QTYSTUNEW<>[F:CUD]QTYSTU | [F:CUD]QTYPCUNEW<>[F:CUD]QTYPCU)"
Endif

#                                                                                         # hcb 71659 fin
Gosub PUR_CUD
Filter [F:CUD] Where evalue([L]CRITERE)
Gosub TRT_CUD
Filter [F:CUD]
End

###################################################################
$TRT_CUD
Global Char GCUNLISNUM(GLONVCR)    # hcb 63615
Raz GCUNLISNUM                     # hcb 63615

Default File [CUD]
#--- lecture de la session
Read [F:CUN]CUN0=[L]CUNSSSNUM
If fstat [F:CUN]CUNSSSTYP=1 Endif
#--- creation directe ou agregation
For [F:CUD]CUD0
#                                  # hcb 63615 deb
    If GCUNLISNUM = ""
       GCUNLISNUM = [F:CUD]CUNLISNUM
    Endif
    If GCUNLISNUM <> [F:CUD]CUNLISNUM
       Gosub CRE_WCU2
       GCUNLISNUM = [F:CUD]CUNLISNUM
    Endif
    Gosub AGREGATION
Next

#--- creation suite a agregation
If [M:WCU]NBLIG <> 0
   Gosub CRE_WCU2
Endif
#                                  # hcb 63615 fin
Return

###################################################################
$AGREGATION
AGREG=0
For I =0 To [M:WCU]NBLIG-1
    If [F:CUD]CUNSSSNUM <> [M:WCU]CUNSSSNUM(I)            Goto SUIVANT Endif
    If [F:CUD]CUNLISNUM <> [M:WCU]CUNLISNUM(I)            Goto SUIVANT Endif
    If [F:CUD]ITMREF    <> [M:WCU]ITMREF(I)               Goto SUIVANT Endif
    If [F:CUD]PCU       <> [M:WCU]PCU(I)                  Goto SUIVANT Endif
    If [F:CUD]PCUSTUCOE <> [M:WCU]PCUSTUCOE (I)           Goto SUIVANT Endif
    #-- Si pas d'agreg sur lot
    If [L]LOTCOD = 1  & [F:CUD]LOT = [M:WCU]LOT(I)
       AGREG = 1
    Endif
    #-- Si pas d'agreg sur sous-lot
    If [L]SLOCOD=1 & [F:CUD]SLO = [M:WCU]SLO(I)
       AGREG = 1
    Endif
    #-- Si pas d'agreg sur le statut
    If [L]STACOD = 1 & [F:CUD]STA = [M:WCU]STA(I)
       AGREG = 1
    Endif
    #-- Si pas d'agreg sur emplacemnt
    If [L]LOCCOD = 1 & [F:CUD]LOC = [M:WCU]LOC(I)
       AGREG = 1
    Endif
    #-- Si pas d'agreg sur numéro de série
    If [L]SERCOD = 1 & [F:CUD]SERNUM = [M:WCU]SERNUM(I)
       AGREG = 1
    Endif
    #-- Si pas d'agreg sur identification 1
    If [L]IDECOD1 = 1  & [F:CUD]PALNUM = [M:WCU]PALNUM(I)
       AGREG = 1
    Endif
   #-- Si pas d'agreg sur identification 2
    If [L]IDECOD2 = 1 & [F:CUD]CTRNUM = [M:WCU]CTRNUM(I)
       AGREG = 1
    Endif
If AGREG = 1
    If [F:CUD]LOC <> [M:WCU]LOC(I) & [M:WCU]LOC(I)<>"$"
      [M:WCU]LOC(I)="$"
    Endif
    If [F:CUD]LOT <> [M:WCU]LOT(I) & [M:WCU]LOT(I)<>"$"
      [M:WCU]LOT(I)="$"
    Endif
    If [F:CUD]SLO <> [M:WCU]SLO(I) & [M:WCU]SLO(I)<>"$"
      [M:WCU]SLO(I)="$"
    Endif
    If [F:CUD]STA <> [M:WCU]STA(I) & [M:WCU]STA(I)<>"$"
      [M:WCU]STA(I)="$"
    Endif
    If [F:CUD]SERNUM <> [M:WCU]SERNUM(I) & [M:WCU]SERNUM(I)<>"$"
      [M:WCU]SERNUM(I)="$"
    Endif
    If [F:CUD]PALNUM <> [M:WCU]PALNUM(I) & [M:WCU]PALNUM(I)<>"$"
      [M:WCU]PALNUM(I)="$"
    Endif
    If [F:CUD]CTRNUM <> [M:WCU]CTRNUM(I) & [M:WCU]CTRNUM(I)<>"$"
      [M:WCU]CTRNUM(I)="$"
    Endif
    If [F:CUD]ECCVALMAJ <> [M:WCU]ECCVALMAJ(I) & [M:WCU]ECCVALMAJ(I)<>"$"
      [M:WCU]ECCVALMAJ(I)="$"
    Endif

   # --- agrégation des quantités
    [M:WCU]QTYPCU    (I) += [F:CUD]QTYPCU
    [M:WCU]QTYSTU    (I) += [F:CUD]QTYSTU
#                                                                                         # hcb 71659 deb
    Case [L]ILC
    When 1,2,3,4 :
       [M:WCU]QTYPCUNEW (I) += [F:CUD]QTYPCUNEW
       [M:WCU]QTYSTUNEW (I) += [F:CUD]QTYSTUNEW
    When 5 :
       [M:WCU]QTYPCUNEW (I) += [F:CUD]QTYPCUNEW1
       [M:WCU]QTYSTUNEW (I) += [F:CUD]QTYSTUNEW1
    When 6 :
       [M:WCU]QTYPCUNEW (I) += [F:CUD]QTYPCUNEW2
       [M:WCU]QTYSTUNEW (I) += [F:CUD]QTYSTUNEW2
    When Default
    Endcase
#                                                                                         # hcb 71659 deb
    AGREG=1
    Break
Endif
$SUIVANT
Next I

#--- insertion dans le tableau
If AGREG=0
   # --- WPLEIN=1 dernière insertion
   If I>=dim([M:WCU]CUNSSSNUM)-1 WPLEIN=1 Endif           # hcb 45652
   [M:WCU]NBLIG       += 1
   [M:WCU]CUNSSSNUM(I)  = [F:CUD]CUNSSSNUM
   [M:WCU]CUNLISNUM(I)  = [F:CUD]CUNLISNUM
   [M:WCU]ITMREF(I)     = [F:CUD]ITMREF
   [M:WCU]PCU(I)        = [F:CUD]PCU
   [M:WCU]QTYPCU(I)     = [F:CUD]QTYPCU
   [M:WCU]PCUSTUCOE(I)  = [F:CUD]PCUSTUCOE
   [M:WCU]QTYSTU(I)     = [F:CUD]QTYSTU
#   [M:WCU]QTYPCUNEW (I) = [F:CUD]QTYPCUNEW                                               # hcb 71659
#   [M:WCU]QTYSTUNEW (I) = [F:CUD]QTYSTUNEW                                               # hcb 71659
#                                                                                         # hcb 71659 deb
    Case [L]ILC
    When 1,2,3,4 :
       [M:WCU]QTYPCUNEW (I) = [F:CUD]QTYPCUNEW
       [M:WCU]QTYSTUNEW (I) = [F:CUD]QTYSTUNEW
    When 5 :
       [M:WCU]QTYPCUNEW (I) = [F:CUD]QTYPCUNEW1
       [M:WCU]QTYSTUNEW (I) = [F:CUD]QTYSTUNEW1
    When 6 :
       [M:WCU]QTYPCUNEW (I) = [F:CUD]QTYPCUNEW2
       [M:WCU]QTYSTUNEW (I) = [F:CUD]QTYSTUNEW2
    When Default
    Endcase
#                                                                                         # hcb 71659 deb
   [M:WCU]CUNCST(I)     = [F:CUD]CUNCST
   [M:WCU]CUR(I)        = [F:CUD]CUR
   [M:WCU]LOT(I)        = [F:CUD]LOT
   [M:WCU]SLO(I)        = [F:CUD]SLO
   [M:WCU]ECCVALMAJ (I) = [F:CUD]ECCVALMAJ
   [M:WCU]STA(I)        = [F:CUD]STA
   [M:WCU]LOC(I)        = [F:CUD]LOC
   # Issue 110327 - 2016-09-15 by MAE : si article série globale, récupération des nums de série
   If [F:CUD]SERSEQ <> 0
    WSERDEB = "" : WSERFIN = ""
    #lecture de la table CUNSERDET
    Filter [CSD] Where CUNSSSNUM = [F:CUD]CUNSSSNUM and CUNLISNUM = [F:CUD]CUNLISNUM and SERSEQ = [F:CUD]SERSEQ
&   Order By [F:CSD]SERDEB
    For [CSD]
      If WSERDEB = "":  WSERDEB = [F:CSD]SERDEB: Endif
      If WSERFIN <> ""
        Call PLUS_UN(WSERFIN, WSERFINP, WRET) From STKLIB
        If [F:CSD]SERDEB <> "" & (WSERFINP <>[F:CSD]SERDEB)
          [M:WCU]SERNUM(I) = "$"
          Break
        Else
          [M:WCU]SERNUM(I) = WSERDEB
        Endif
      Else
        [M:WCU]SERNUM(I) = WSERDEB
      Endif
      WSERFIN = [F:CSD]SERFIN
    Next
   Else
    [M:WCU]SERNUM    (I) = [F:CUD]SERNUM
   Endif
   # End Issue 110327 - 2016-09-16 by MAE
   #[M:WCU]SERNUM(I)     = [F:CUD]SERNUM
   [M:WCU]PALNUM(I)     = [F:CUD]PALNUM
   [M:WCU]CTRNUM(I)     = [F:CUD]CTRNUM
   [M:WCU]STOFLD1   (I) = [F:CUD]STOFLD1
   [M:WCU]STOFLD2   (I) = [F:CUD]STOFLD2
   [M:WCU]WRH   (I)     = [F:CUD]WRH
Endif
Return

##########################################################################
$CRE_WCU
# creation de l'enregistrement WCU
Trbegin [WCU]
Raz [F:WCU]
[F:WCU]       = [F:CUD]
#                                              # hcb X3-46892 deb
If IMPQTYTHEORIQUE <> 1
   Raz [F:WCU]QTYPCU
   Raz [F:WCU]QTYSTU
Endif
#                                              # hcb X3-46892 deb
[F:WCU]USR    = GUSER
[F:WCU]NUMREQ = [L]NUMREQ

Write [F:WCU]
If fstat : GOK = 0 : Call FSTA("WCU") From GLOCK : Goto AB_CRE : Endif
Commit
Return

$ROLL_CRE
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto CRE_WCU : Endif
Return

$AB_CRE
Rollback
Return

###########################################################################
$CRE_WCU2
#--- tri du tableau
I=nolign-1
#If [F:CUN]CUNSSSTYP=1 # hcb 33627
If [F:CUN]CUNSRTCOD <> 2
   Sorta [M]NBLIG [M]NBLIG
&        Order By [M]CUNSSSNUM(indice),[M]CUNLISNUM(indice),[M]ITMREF(indice),
&                 [M]LOC(indice),[M]LOT(indice),[M]SLO(indice),
&                 [M]PCU(indice),[M]PCUSTUCOE(indice),[M]STA(indice),[M]SERNUM(indice),
&                 [M]PALNUM(indice),[M]CTRNUM(indice)
Else
   Sorta [M]NBLIG [M]NBLIG
&        Order By [M]CUNSSSNUM(indice),[M]CUNLISNUM(indice),[M]LOC(indice),[M]ITMREF(indice),
&                 [M]LOT(indice),[M]SLO(indice),
&                 [M]PCU(indice),[M]PCUSTUCOE(indice),[M]STA(indice),[M]SERNUM(indice),
&                 [M]PALNUM(indice),[M]CTRNUM(indice)

Endif

#--- creation WCU suite a agregation
J=0
Trbegin [WCU]
For I=0 To [M:WCU]NBLIG-1
  J +=1000
  Raz [F:WCU]
  [F:WCU]CUNSSSNUM = [M:WCU]CUNSSSNUM (I)
  [F:WCU]CUNLISNUM = [M:WCU]CUNLISNUM (I)
  [F:WCU]ITMLISNUM = J
  [F:WCU]CUR       = [M:WCU]CUR       (I)
  [F:WCU]ITMREF    = [M:WCU]ITMREF    (I)
  [F:WCU]LOT       = [M:WCU]LOT       (I)
  [F:WCU]SLO       = [M:WCU]SLO       (I)
  [F:WCU]ECCVALMAJ = [M:WCU]ECCVALMAJ (I)
  [F:WCU]LOC       = [M:WCU]LOC       (I)
  [F:WCU]STA       = [M:WCU]STA       (I)
  [F:WCU]PCU       = [M:WCU]PCU       (I)
  [F:WCU]QTYPCU    = [M:WCU]QTYPCU    (I)
  [F:WCU]QTYPCUNEW = [M:WCU]QTYPCUNEW (I)
  [F:WCU]PCUSTUCOE = [M:WCU]PCUSTUCOE (I)
  [F:WCU]QTYSTU    = [M:WCU]QTYSTU    (I)
  [F:WCU]QTYSTUNEW = [M:WCU]QTYSTUNEW (I)
  [F:WCU]CUNCST    = [M:WCU]CUNCST    (I)
  [F:WCU]SERNUM    = [M:WCU]SERNUM    (I)
  [F:WCU]PALNUM    = [M:WCU]PALNUM    (I)
  [F:WCU]CTRNUM    = [M:WCU]CTRNUM    (I)
  [F:WCU]STOFLD1   = [M:WCU]STOFLD1   (I)
  [F:WCU]STOFLD2   = [M:WCU]STOFLD2   (I)
  [F:WCU]WRH       = [M:WCU]WRH       (I)

  [F:WCU]USR       = GUSER
  [F:WCU]NUMREQ    = [L]NUMREQ

  [F:WCU]CREUSR    = GUSER
  [F:WCU]CREDAT    = date$
  [F:WCU]UPDUSR    = GUSER
  [F:WCU]UPDDAT    = date$
 #                                              # hcb X3-46892 deb
  If IMPQTYTHEORIQUE <> 1
     Raz [F:WCU]QTYPCU
     Raz [F:WCU]QTYSTU
  Endif
#                                              # hcb X3-46892 deb
  Write [F:WCU]
  If fstat : GOK = 0 : Call FSTA("WCU") From GLOCK : Break : Goto AB_CRE2 : Endif
Next I
Commit
Raz [M:WCU]   # hcb 63615

Return

$ROLL_CRE2
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto CRE_WCU2 : Endif
Return

$AB_CRE2
Rollback
Return

###########################################################
$PUR_CUD
Trbegin [WCU]
Delete [WCU] Where CREUSR = GUSER & CREDAT < date$
fstat = 0
Delete [WCU] Where NUMREQ = [L]NUMREQ
fstat = 0
Commit
Return

###########################################################################
$OUVRE
Local File CUNLISDET [CUD], CUNSESSION [CUN], WCUNLISDET [WCU], STKTRS [SRT]
# Issue 110327 - 2016-09-16 by MAE
Local File CUNSERDET [CSD]
Local Mask TCUN [WCU]
Return

$DECLARE
Local Char    CRITERE(255), PARAM(30) , VALEUR(30) , ETAT(15), CUNSSSNUM
# Issue 110327 - 2016-09-16 by MAE
Local Char WSERDEB(GLONSER), WSERFIN(GLONSER), WSERFINP(GLONSER)
Local Integer WRET
# End issue 110327
Local Integer I, J, NUMREQ, AGREG, AGRFLG, WPLEIN, LOTCOD, SLOCOD, LOCCOD, STACOD, SERCOD, IDECOD1, IDECOD2
Local Integer ILC                                                               # hcb 71659
ILC = 1                                                                         # hcb 71659
Local Integer IMPQTYTHEORIQUE                                                   # hcb X3-46892
Raz [M:WCU]
WPLEIN=0
Return

