#<AdxTL>@(#)4.0.0.0 $Revision$
################################################################
# CBO 2016.10.05 118804  Chgt d'imputation et TRTFLG
# CBO 2015.08.06 FQxxxxxx Maj sortie par itf des mvts
# CBO 2015.04.14 FQ100398/13 : Liaison FXD PHY
# CBO 2014.02.25 FQ97148 Suppression du masque FGR9 et tjrs utilisation du FASFZ
# CBO 2013.07.17 FQ93936 cas changement de méthode interdit
# CBO 2013.07.17 FQ91070 ajout éclatement d'un bien comptable (interactif)
# CBO 2013.07.05 FQ90828 contrôle en chgt d'imput si TRTFLG Ok pour les champs du plan
# CBO 2013.02.14 FQ87753 gestion des droits par société, site
# CBO 2012.05.29 FQ82485 Elsif en trop avec [M:FASM]ISSDAT
# CBO 2012.05.02 FQ80044 gestion de CMPORI
# CBO 2012.04.20 FQ81733 pb de type des paramètres
# CBO 2012.03.06 FQ80551 ajout de PE
# CBO 2011.09.07 exigence 69691 Intégration des mouvements d'import
# CBO 2012.02.23 FQ80109
# CBO 2012.02.29 FQ80394 GHY et G_ACTCIG pour conditionner les BPH et CIG
#
#b
################################################################

Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT, PARBOUT, "", "FXDINT", "FXDINT", 3, "") From GTRAITE
End

$ACTION
Case ACTION
    When "OUVRE_BATCH" : Gosub OUVRE
    When "DEBUT"       : Gosub DEBUT
    When "INIT"        : Gosub INIT
    When "OK"          : GOK=1
    When "END"         : GOK=0
    When "CONTROLE"    : Gosub CONTROLE
    When "EXEC"        : Gosub EXEC
    When "TERMINE"     : Gosub TERMINE
    When "BOUTON"      : Gosub BOUTON # FQ91070
Endcase
Return


$OUVRE
Return

$INIT
#############################################################################################################

    Local Integer WNBTRAITES, WSVNBTRAITES, RETOUR, WNBERRPREMCT
    Local Integer WSVMVT, WNBTYPEOBJETS, WCPTRTOT, WNBTOT, WBDEJALOCK, WILOCK
    Local Integer WNDIME
    Local Char WSVREF1(30), WSVREF2(30), WFILTRE(250), WCLEFCPTR(30)

    Global Integer GFXDNBERR # Attention : cette variable est utilisée (par DIM) dans les actions pour savoir si on est en interface de mouvement
    Global Integer GBCONTROLE, GERR_CTL, GFXDINT, GFXDERRALCHP, GSVNBERREURS, GCRDET
    Global Char GCFXCLE(250), GERRALIMCHP(250), GABVMSKMAM(30), GRUBALIM(20)(200), GRUBPLN(20)(200)
    Global Integer GNBRUBALIM, GNBRUBPLN, GTYPDIMEAL

    # CBO 20120209 FQ79571 : sortie d'1 composant
    Global Integer GBCOMPOSANT, GSVSTATUT
    Global Char GSVPRINCIPAL(30), GSVORI(30)

    Local Integer LOCK_NON, WNKAS9, GDROIT_CPYFCY # FQ87753
    Global Integer G_HASELT # FQ91070
    Local Char WFCY(30) # FQ87753
    LOCK_NON = 1
    GCRDET = 2
    GBCONTROLE = 0
    Gosub GLOBFXM From SUBFXM

    If !clalev([F:AMZ])
        Local File AMSKZON [AMZ]
    Endif
    Gosub ALIMRUBPLN
    If !clalev([F:AMP]) #FQ91070
        Local File AMSKPAR [AMP]
    Endif
    If !clalev([F:FXM])
        Local File FXDMVT [FXM]
    Endif

    If !clalev([F:FXD])
        Local File FXDMVTD [FXD]
    Endif
        # Ouverture de FASS pour la gestion de la sortie par action silencieuse
    # ? utile que si on affecte des chps [F:FASS] ou à partir de champ [F:FASS]
    If !clalev([F:FASS])
        Local File FXDASSETS  [FASS]
    Endif
    If !clalev ([F:AMZ])
        Local File = "AMSKZON" [AMZ]
    Endif
    If !clalev ([F:ATX])
        Local File = "ATEXTE" [ATX]
    Endif

    If !clalev([F:AWI])
        Local File AWINDOW  [AWI]
    Endif

    If !clalev([F:AMK])
        Local File AMSK [AMK]
    Endif

    If !clalev([F:ATY])
        Local File ATYPE [ATY]
    Endif

    If !clalev([F:LOF])
        Local File LAYOUTFAS  [LOF]
    Endif
    If !clalev([F:DEP])
        Local File DEPREC  [DEP]
    Endif

    # CBO 20120227 FQ80394
    If GPHY = G_OUI
        If !clalev([F:PHY])
            Local File PHYELT  [PHY]
        Endif
    Endif
    If !clalev([F:CNX])
        Local File CONTEXT  [CNX]
    Endif
    If !clalev([F:SAC])
        Local File SECACT  [SAC]
    Endif

# V5 <> V6 _________________________________________
    # CBO 2012.02.29 FQ80394 test avec G_ACTCIG
    If G_ACTCIG = G_OUI
        If !clalev([F:CIB])
            Local File CIGFXDSOR  [CIB]
        Endif
    Endif
# fin V5 <> V6 _________________________________________

    # FQ91070
    Global Integer GNBDEPLIEES
    Global Integer G_ARECALCULER
    Global Integer DETA_LEAREF, RATT_LEAREF, MOD_LEAREF, GMODENAFAS
    Global Integer GSPLBASVFRCE
    Global Integer GTBSPLPRC(999)
    DETA_LEAREF = G_NON
    RATT_LEAREF = G_NON
    MOD_LEAREF = G_NON
    GMODENAFAS = 0
    Raz GSPLBASVFRCE, GTBSPLPRC

    If !clalev([F:ATZ])
        Local File ATABZON [ATZ]
    Endif
    If !clalev([F:FAS])
        Local File FXDASSETS  [FAS]
    Endif

    Local Mask FXDINT   [FXT]
    Read [AMZ]CODE = "FXDMVT1"; "DIME"
    If [F:AMZ]CODTYP = "A"
        GTYPDIMEAL = 1
    Else
        GTYPDIMEAL = 0
    Endif

# CBO 2012.01.30 FQ79825 : KAS9 dépent d'un code activité (KPO)
    If !clalev ([F:ACV])
        Local File ACTIV [ACV]
    Endif
    Read [ACV] CODACT="KPO"
    If fstat
        Raz [F:ACV]
    Endif
    WNKAS9 = [F:ACV]FLACT
    If WNKAS9 <> G_OUI
        WNKAS9 = G_NON
    Endif
Return

$ALIMRUBPLN

    # Ds un chgt de méthode, il faut connaître toutes les zones saisissables du tabulaire
    # pour savoir si elles sont modifiées : on affecte alors l'indice ds $IMP_MVT
    GNBRUBPLN = 0
    For [AMZ] Where CODMSK = "FASTRFCP" and SAIAFF = 1
        GNBRUBPLN += 1
        GRUBPLN(GNBRUBPLN) = [F:AMZ]CODZON

    Next

Return

$DEBUT

    # CBO 20120227 FQ80394

    # FQ100398/13
#    If GPHY <> G_OUI
        [M:FXT]TRTPHY = G_NON
#    Endif

    Affzo [M:FXT]
    Diszo [M:FXT]TRTFXD, TRTLAY, TRTPHY
    Diszo [M:FXT]CPY, FCY, FCYTOUS
    Diszo [M:FXT]MVTSORTIE, MVTTRF, MVTIMPUT, MVTMODIF, MVTSPLIT

    # FQ91070 Si provenance depuis la transaction de gestion des mvts : préaffectation de l'écran
    Local Integer ICBO
    ICBO = 1
    While adxpno(ICBO)  <> ""
        If instr(1, adxpno(ICBO), "WGOFXM")
            Gosub PREAFFECTE
    #        Infbox adxpno(ICBO) - num$(ICBO) - [M:FXM0]CPY
            Break
        Endif
        ICBO += 1
    Wend

Return

#FQ91070 préaffecte l'écran en fonction du mouvement d'où l'on vient
$PREAFFECTE

    [M:FXT]SIMULATION = G_OUI
    [M:FXT]ARCHIVE = G_OUI
    [M:FXT]TRACEDET = G_OUI

    [M:FXT]CPYTOUS = G_NON
    Call AM_CPYTOUS([M:FXT]CPYTOUS)
    [M:FXT]CPY = [M:FXM0]CPY

    [M:FXT]FCYTOUS = G_NON
    Call AM_FCYTOUS([M:FXT]FCYTOUS)
    [M:FXT]FCY = [M:FXM0]FCY

    [M:FXT]MVTTOUS = G_NON
    Call AM_MVTTOUS([M:FXT]MVTTOUS)

    [M:FXT]TRTTOUS = G_NON
    Call AM_TRTTOUS([M:FXT]TRTTOUS)

    If [M:FXM0]OBJMVT = GFXM_DEPENSE
        [M:FXT]TRTLAY    = G_OUI
    Elsif [M:FXM0]OBJMVT = GFXM_IMMOS
        [M:FXT]TRTFXD    = G_OUI
# FQ100398/13
#    Elsif [M:FXM0]OBJMVT = GFXM_PHY
#        [M:FXT]TRTPHY    = G_OUI
    Endif

    If [M:FXM0]TYPMVT = GFXM_SORTIE
        [M:FXT]MVTSORTIE = G_OUI
    Elsif [M:FXM0]TYPMVT = GFXM_TRANSFERT
        [M:FXT]MVTTRF = G_OUI
    Elsif [M:FXM0]TYPMVT = GFXM_IMPUT
        [M:FXT]MVTIMPUT = G_OUI
#    Elsif [M:FXM0]TYPMVT = GFXM_METHODE
#        [M:FXT]MVTXXX = G_OUI
    Elsif [M:FXM0]TYPMVT = GFXM_MODIF
        [M:FXT]MVTMODIF = G_OUI
    Elsif [M:FXM0]TYPMVT = GFXM_SPLIT
        [M:FXT]MVTSPLIT = G_OUI
    Endif

    [M:FXT]REF1 = [M:FXM0]REF1MVT
    [M:FXT]REF2 = [M:FXM0]REF1MVT

      Affzo [M:FXT]
Return

$CONTROLE

    If GOK < 1
#        FIN=1
        Return
    Endif
    If [M:FXT]REF1 = "CBOSUP" or [M:FXT]REF1 = "cbosup"
    Return
    Endif

    If [M:FXT]REF1 <> "" or [M:FXT]REF2 <> ""
        WNBTYPEOBJETS = 0
        If [M:FXT]TRTFXD = G_OUI
            WNBTYPEOBJETS +=1
        Endif
        If [M:FXT]TRTLAY = G_OUI
            WNBTYPEOBJETS +=1
        Endif
        If [M:FXT]TRTPHY = G_OUI
            WNBTYPEOBJETS +=1
        Endif

        If WNBTYPEOBJETS > 1
#            GMESSAGE = "Impossible de sélectionner plusieurs types d'objets avec des bornes de sélection"
            GMESSAGE = mess(4, GML_IMPFXD, 1)
            mkstat = 2
            GERR = 1
        Endif
    Endif
Return


# traitement
$EXEC

    GCRDET = [M:FXT]TRACEDET
    If GOK = 0
        Return
    Endif

    # purge
    If toupper([M:FXT]REF1) = "CBOSUP"
        Gosub SUPPR_OBJ
        Return
    Endif

    Call DEB_TRACE()

    # boucle sur FXDMVT par OBJMVT+REF1MVT+REF2MVT+SEQMVT+TYPMVT+IDMVT
    WNBTRAITES = 0
    WNBERRPREMCT = 0
    GFXDNBERR = 0
    GSVNBERREURS = 0
    WSVREF1   = ""
    WSVREF2   = ""
    WSVMVT     = 0

    WFILTRE = "(STATMVT = GFXM_ATRAITER or STATMVT = GFXM_REJET)"
    If [M:FXT]CPY <> ""
        WFILTRE -= "and [F:FXM]CPY = [M:FXT]CPY"
    Endif
    If [M:FXT]FCY <> ""
#        FQ87753 fCY -> FCY
        WFILTRE -= "and [F:FXM]FCY = [M:FXT]FCY"
    Endif
    If [M:FXT]REF1 <> ""
        WFILTRE -= "and [F:FXM]REF1MVT >= [M:FXT]REF1"
    Endif
    If [M:FXT]REF2 <> ""
        WFILTRE -= "and [F:FXM]REF1MVT <= [M:FXT]REF2"
    Endif

    Raz WCPTRTOT, WNBTOT
    Filter [FXM] Where evalue(WFILTRE)
    WNBTOT = nbrecord ([FXM])
    For [FXM]FXM1 With Stability
        GERR_CTL = 0
        GSVNBERREURS = GFXDNBERR
        WSVNBTRAITES = WNBTRAITES
        Raz GRUBALIM, GNBRUBALIM
        WCPTRTOT += 1
        WBDEJALOCK = LOCK_NON
        # FQ87753
        GDROIT_CPYFCY = 1

        GCFXCLE = [F:FXM]REF1MVT
        If [F:FXM]OBJMVT = GFXM_DEPENSE
            GCFXCLE -= "/" - [F:FXM]REF2MVT
        Endif
        GCFXCLE -= "n° seq" - num$([F:FXM]SEQMVT)
        WCLEFCPTR = GCFXCLE
        GCFXCLE -= "(" + mess([F:FXM]OBJMVT, GML_MSGOBJ, 1) - "/" - mess([F:FXM]TYPMVT, GML_MSGTYP, 1) + ")"
        GERRALIMCHP = ""

        If mod(WCPTRTOT, 2) = 0
            Call TEMPON(WCLEFCPTR - "(" - num$(WCPTRTOT) + "/" + num$(WNBTOT) + ")") From GESECRAN
        Endif

        # dépense          : qu'en modif
        # immos            : tout
        # élément physique : sortie transfert modif
        # chgt de méthode : non implémenté

        #  FQ93936 GFXM_METHODE non contrôlé
        If ([F:FXM]OBJMVT = GFXM_DEPENSE and [F:FXM]TYPMVT <> GFXM_MODIF) or
&         ([F:FXM]OBJMVT = GFXM_PHY     and [F:FXM]TYPMVT = GFXM_IMPUT) or
&         ([F:FXM]TYPMVT = GFXM_METHODE)

            [F:FXM]DESRJTMVT = func AFNC.MES5(mess(6, GML_IMPFXD, 1), GCFXCLE, "", "", "", "")
            [F:FXM]STATMVT = GFXM_REJET
            GFXDNBERR += 1
            If [M:FXT]SIMULATION = G_NON
                [F:FXM]TRACE = GTRACE
                [F:FXM]DATINTMVT = date$
                Rewrite [FXM]
            Endif
            Call ECR_TRACE([F:FXM]DESRJTMVT, 1) From GESECRAN
        Else

            Gosub TRTOBJET
        Endif

    Next
    Filter [FXM]
    GERR = 0
    GOK  = 1

Return


$TRTOBJET
    If ([F:FXM]OBJMVT = GFXM_IMMOS and [M:FXT]TRTFXD = G_OUI) and
&     (([F:FXM]TYPMVT = GFXM_SORTIE and [M:FXT]MVTSORTIE = G_OUI) or
&      ([F:FXM]TYPMVT = GFXM_TRANSFERT and [M:FXT]MVTTRF = G_OUI)    or
&      ([F:FXM]TYPMVT = GFXM_IMPUT and [M:FXT]MVTIMPUT = G_OUI))


        Gosub OBJPREMCTL
        # FQ87753 Test ajouté et trace déplacée
        If GDROIT_CPYFCY = 0
            Return
        Endif
        If GSVNBERREURS = GFXDNBERR
            Call ECR_TRACE(func AFNC.MES5(mess(5, GML_IMPFXD, 1), GCFXCLE, "", "", "", ""), 0) From GESECRAN
            Gosub OUVRE_MASK

            WNBTRAITES += 1
            Call PGM_IMMOS([F:FXM]OBJMVT, [F:FXM]TYPMVT, GFXDNBERR)
        Endif

    Elsif ([F:FXM]OBJMVT = GFXM_PHY and [M:FXT]TRTPHY = G_OUI) and
&        (([F:FXM]TYPMVT = GFXM_SORTIE and [M:FXT]MVTSORTIE = G_OUI) or
&         ([F:FXM]TYPMVT = GFXM_TRANSFERT and [M:FXT]MVTTRF = G_OUI))

        Gosub OBJPREMCTL
        # FQ87753 Test ajouté et trace déplacée
        If GDROIT_CPYFCY = 0
            Return
        Endif
        If GSVNBERREURS = GFXDNBERR
            Call ECR_TRACE(func AFNC.MES5(mess(5, GML_IMPFXD, 1), GCFXCLE, "", "", "", ""), 0) From GESECRAN
            Gosub OUVRE_MASK

            WNBTRAITES += 1
            Call PGM_PHY([F:FXM]OBJMVT, [F:FXM]TYPMVT, GFXDNBERR)
        Endif

    Elsif [F:FXM]TYPMVT = GFXM_MODIF and [M:FXT]MVTMODIF = G_OUI

        If [F:FXM]OBJMVT = GFXM_DEPENSE and [M:FXT]TRTLAY = 2 or
&          [F:FXM]OBJMVT = GFXM_IMMOS and [M:FXT]TRTFXD = 2 or
&          [F:FXM]OBJMVT = GFXM_PHY and [M:FXT]TRTPHY = 2

            Gosub OBJPREMCTL
            # FQ87753 Test ajouté et trace déplacée
            If GDROIT_CPYFCY = 0
                Return
            Endif
            If GSVNBERREURS = GFXDNBERR
                Call ECR_TRACE(func AFNC.MES5(mess(5, GML_IMPFXD, 1), GCFXCLE, "", "", "", ""), 0) From GESECRAN
                Gosub OUVRE_MASK

                WNBTRAITES += 1
                Gosub TRAITE_MODIF
            Endif
        Endif
    # FQ91070
    Elsif [F:FXM]TYPMVT = GFXM_SPLIT and [M:FXT]MVTSPLIT = G_OUI and
&         [F:FXM]OBJMVT = GFXM_IMMOS and [M:FXT]TRTFXD = G_OUI

        Gosub OBJPREMCTL
        If GDROIT_CPYFCY = 0
            Return
        Endif
        If GSVNBERREURS = GFXDNBERR
            Call ECR_TRACE(func AFNC.MES5(mess(5, GML_IMPFXD, 1), GCFXCLE, "", "", "", ""), 0) From GESECRAN
            Gosub OUVRE_MASK

# fermeture temporaire des éclatements de biens avec éléments physiques

If G_HASELT = G_OUI # and GUSER <> "CBO"
    # Eclatement impossible : bien lié à un élément physique.
    [F:FXM]DESRJTMVT = mess(46, GML_IMPFXD, 1)
    GMESSAGE =  mess(46, GML_IMPFXD, 1)
#    [F:FXM]DESRJTMVT = mess(7, GML_IMPFXD, 1)
    GERRALIMCHP = [F:FXM]DESRJTMVT
    GFXDNBERR += 1
    WNBTRAITES += 1
    GERR = 1
    Call CPTERENDU(RETOUR, GFXDNBERR)

Else
            WNBTRAITES += 1
            Gosub TRAITE_SPLIT From FXDINT2
Endif
        Endif
    Endif

    If WSVNBTRAITES <> WNBTRAITES
        Gosub FERME_MASK

        If GFXDNBERR = GSVNBERREURS
            WSVREF1 = ""
            WSVREF2 = ""
            WSVMVT = 0
            If [M:FXT]SIMULATION = G_NON
                If [M:FXT]ARCHIVE = G_NON
                    Delete [FXD] Where IDMVT = [F:FXM]IDMVT
                    Delete [FXM]
                Else
                    [F:FXM]STATMVT = GFXM_ARCHIVE
                    [F:FXM]TRACE = GTRACE
                    [F:FXM]DESRJTMVT = ""
                    [F:FXM]DATINTMVT = date$
                    Rewrite [FXM]
                Endif
            Endif
        Else
            WSVREF1 = [F:FXM]REF1MVT
            WSVREF2 = [F:FXM]REF2MVT
            WSVMVT = [F:FXM]OBJMVT
            If [M:FXT]SIMULATION = G_NON and WBDEJALOCK = LOCK_NON
                [F:FXM]STATMVT = GFXM_REJET
                [F:FXM]TRACE = GTRACE
                [F:FXM]DATINTMVT = date$
                Rewrite [FXM]
            Endif
        Endif

            # CBO 20120209 FQ79571 : sortie d'1 composant (échec)
            # remise du 'composant' à l'état de composant
            # si simu ou erreur
        If GBCOMPOSANT and
&          [F:FXM]OBJMVT = GFXM_IMMOS and [F:FXM]TYPMVT = GFXM_SORTIE

            If [M:FXT]SIMULATION = G_OUI or GFXDNBERR <> GSVNBERREURS

                [F:FASS]CMP = GSVPRINCIPAL
                [F:FASS]CMPSTA = GSVSTATUT
                # CBO 2012.05.02 FQ80044
                [F:FASS]CMPORI = GSVORI
                Rewrite [FASS]

                If fstat
                    [F:FXM]DESRJTMVT = func AFNC.MES5(mess(16, GML_IMPFXD, 1), [F:FXM]REF1MVT, "", "", "", "")
#            [F:FXM]DESRJTMVT = "Echec en Maj de" - [F:FXM]REF1MVT
                    [F:FXM]TRACE = GTRACE
                    GERR = 1
                Endif
            Endif
            GBCOMPOSANT = 0
        Endif
    Endif

    #il n'était pas locké : donc on l'a fait et il faut défaire !
    If WBDEJALOCK = LOCK_NON
        Call UNLOCK_SYMBOLE_CPY ("FXM", [F:FXM]CPY, num$([F:FXM]IDMVT)) From GLOBIENS
    Endif
Return


# contrôles préliminaires sur l'objet
$OBJPREMCTL

    # existence de l'objet métier
    If [F:FXM]OBJMVT = GFXM_DEPENSE
        Read [LOF]LOF0 = [F:FXM]REF1MVT ; val([F:FXM]REF2MVT)
        WFCY = [F:LOF]FCY # FQ87753
    Elsif [F:FXM]OBJMVT = GFXM_IMMOS
        Read [FASS]FAS0 = [F:FXM]REF1MVT
        WFCY = [F:FASS]FCY # FQ87753
    Elsif [F:FXM]OBJMVT = GFXM_PHY
        Read [PHY]PHY0 = [F:FXM]REF1MVT
        WFCY = [F:PHY]FCY # FQ87753
    Endif

    If fstat

#        [F:FXM]DESRJTMVT = "Objet inexistant"
        [F:FXM]DESRJTMVT = mess(7, GML_IMPFXD, 1)
        GERRALIMCHP = [F:FXM]DESRJTMVT
        GFXDNBERR += 1
        WNBERRPREMCT += 1
        Call ECR_TRACE(func AFNC.MES5(mess(5, GML_IMPFXD, 1), GCFXCLE, "", "", "", ""), 0) From GESECRAN
        Call CPTERENDU(RETOUR, GFXDNBERR)
        If [M:FXT]SIMULATION = G_NON
           [F:FXM]STATMVT = GFXM_REJET
            [F:FXM]TRACE = GTRACE
            [F:FXM]DATINTMVT = date$
            Rewrite [FXM]
        Endif
        Return
    Endif

    # FQ87753
    # vérifier si l'utilisateur a les droits au site
    If (GUSRFCY(1) <> "" and GUSRFCY(1) <> "\")
      If find(WFCY, GUSRFCY) = 0
        Raz GERRALIMCHP, GMESSAGE #, GT_LIS_ERR
        GDROIT_CPYFCY = 0
        WCPTRTOT -= 1
#Call ECR_TRACE("Pas le droit soc/site pour" - GCFXCLE - "1° site" - GUSRFCY(1), 0) From GESECRAN
        Return
      Endif
    Endif

    WBDEJALOCK = func GLOBIENS.IS_SYMBOLE_LOCKED ("FXM", [F:FXM]CPY, num$([F:FXM]IDMVT))
    # 0 = vérouillé
    # Test si la société est verrouillée sur cette table pour en empêcher la modification

    # sinon on gère à la main le verrou identifiant+société pour permettre le contrôle
    # de tester si le lockage de la table pour la société est possible
    If WBDEJALOCK
        WILOCK =  func GLOBIENS.LOCK_SYMBOLE_CPY ("FXM", [F:FXM]CPY, num$([F:FXM]IDMVT), 0)
    Endif

    # mouvement déjà verrouillé
    If WBDEJALOCK = 0
        GFXDNBERR += 1
        WNBERRPREMCT += 1

#        GERRALIMCHP = "Mouvement vérouillé (IDMVT =" -num$([F:FXM]IDMVT) + ")"
        GERRALIMCHP = func AFNC.MES5(mess(33, GML_IMPFXD, 1), num$([F:FXM]IDMVT), "", "", "", "")
        Call CPTERENDU(RETOUR, GFXDNBERR)
        Return
    Endif

    # mouvement précédent (sur le même objet) en erreur
    If WSVREF1 = [F:FXM]REF1MVT and
&      WSVREF2 = [F:FXM]REF2MVT and
&      WSVMVT = [F:FXM]OBJMVT
#        [F:FXM]DESRJTMVT = "Mouvement précédent en erreur : objet non traité"
        [F:FXM]DESRJTMVT = mess(8, GML_IMPFXD, 1)
        GERRALIMCHP = [F:FXM]DESRJTMVT
        GFXDNBERR += 1
        WNBERRPREMCT += 1
        Call CPTERENDU(RETOUR, GFXDNBERR)
        If [M:FXT]SIMULATION = G_NON
           [F:FXM]STATMVT = GFXM_REJET
            [F:FXM]TRACE = GTRACE
            [F:FXM]DATINTMVT = date$
            Rewrite [FXM]
        Endif
        Return
    Endif

    # objet verrouillé
    Local Char LLOCK(200), WOBJLCK(30)

    If [F:FXM]OBJMVT = GFXM_DEPENSE
        LLOCK = func GLOBIENS.GET_KEY_LAYOUTFAS ([F:FXM]REF1MVT, val([F:FXM]REF2MVT))
        WOBJLCK = "LOF"
    Elsif [F:FXM]OBJMVT = GFXM_IMMOS
        LLOCK = func GLOBIENS.GET_KEY_FXDASSETS ([F:FXM]REF1MVT)
        WOBJLCK = "FAS"
    Elsif [F:FXM]OBJMVT = GFXM_PHY
        LLOCK = func GLOBIENS.GET_KEY_PHYELT([F:FXM]REF1MVT)
        WOBJLCK = "PHY"
    Endif
    If func GLOBIENS.IS_SYMBOLE_LOCKED (WOBJLCK, [F:FXM]CPY, LLOCK) = 0
        GFXDNBERR += 1
        WNBERRPREMCT += 1
#        GERRALIMCHP = "Objet vérouillé."
        GERRALIMCHP = mess(32, GML_IMPFXD, 1)
        Call CPTERENDU(RETOUR, GFXDNBERR)
        Return
    Endif

Return

$OUVRE_MASK
    G_HASELT = G_NON # FQ91070
    If [F:FXM]OBJMVT = GFXM_DEPENSE

        Local Mask LOF0 [LOF0], LOF1 [LOF1], LOF2 [LOF2], LOFFZ9 [LOF9]

    Elsif [F:FXM]OBJMVT = GFXM_IMMOS

        Local Mask FAS0 [FAS0], FAS1 [FAS1]
        Local Mask FAS2 [FAS2], FAS3 [FAS3]

        If [F:FXM]TYPMVT = GFXM_MODIF
# CBO 2012.01.30 FQ79740 : FAS5 et FAS6 dépendent d'1 code activité
            Local Mask FAS4 [FAS4] #, FAS5 [FAS5], FAS6 [FAS6]
            If (dim(GKFR) >= 0 and GKFR = G_OUI) or dim(GKFR) < 0
                Local Mask FAS5 [FAS5]
            Endif
            If G_ACTCCN = G_OUI
                Local Mask FAS6 [FAS6]
            Endif
# CBO 2012.01.30 FQ79740 : KAS9 inutile en sortie trf, imput
            Local Mask FASFZ9 [FAS9], FAS8 [FAS8]#, KAS9 [KAS9]
        Elsif [F:FXM]TYPMVT = GFXM_IMPUT
#            If clalev([F:FASM])
#                Close Mask [FASM]
#            Endif
#            Local Mask FASTRFCP [FASM]
        Elsif [F:FXM]TYPMVT = GFXM_SORTIE
            Local Mask FAS4 [FAS4]
        # FQ91070
        Elsif [F:FXM]TYPMVT = GFXM_SPLIT

            # on a besoin de savoir si il y a des éléments physiques pour ouvrir le bon écran

            If GPHY=G_OUI
                If clalev([F:PHY]) = 0
                    Local File PHYELT  [PHY]
                Endif
                Look [PHY] PHY5(1) = [F:FXM]REF1MVT
                If fstat = 0
                    G_HASELT = G_OUI
                Endif
#                Close Local File [PHY]
            Endif

            # Si on a des éléments physiques rattachés au bien, on affiche la fenêtre FASSPE contenant
            # l'onglet supplémentaire Eléments physiques
            If clalev([M:FASE])
                Close Mask [FASE]
            Endif
            If G_HASELT = G_OUI
                Local Mask FASSPL0 [OAC0], FASSPL1B [FASE], FASSPL2 [OCP], FASSPL3 [OCP1]
                BOITE='FASSPE'
            Else
                # sinon on affiche la fenêtre "classique" FASSPL
                Local Mask FASSPL0 [OAC0], FASSPL1 [FASE], FASSPL2 [OCP]
                BOITE='FASSPL'
            Endif

        Endif
    Elsif [F:FXM]OBJMVT = GFXM_PHY
        Local Mask PHY0 [PHY0], PHY1 [PHY1]
    Endif
Return

$FERME_MASK

    If [F:FXM]OBJMVT = GFXM_DEPENSE

        Close Mask [LOF0], [LOF1], [LOF2], [LOF9]

    Elsif [F:FXM]OBJMVT = GFXM_IMMOS
        Close Mask [FAS0], [FAS1]
        Close Mask [FAS2], [FAS3]

        If [F:FXM]TYPMVT = GFXM_MODIF
# CBO 2012.01.30 FQ79740 : FAS5 et FAS6 dépendent d'1 code activité
            If (dim(GKFR) >= 0 and GKFR = G_OUI) or dim(GKFR) < 0
                Close Mask [FAS5]
            Endif
            If G_ACTCCN = G_OUI
                Close Mask [FAS6]
            Endif
            Close Mask [FAS4]#, [FAS5], [FAS6]
# CBO 2012.01.30 FQ79740 : KAS9 inutile en sortie trf, imput
            Close Mask [FAS9], [FAS8]
        Elsif [F:FXM]TYPMVT = GFXM_IMPUT
#            Close Mask [FASM]
        Elsif [F:FXM]TYPMVT = GFXM_SORTIE
            Close Mask [FAS4]
        # FQ91070
        Elsif [F:FXM]TYPMVT = GFXM_SPLIT
#            Close Mask [OAC0], [FASE], [OCP]
        Endif
    Elsif [F:FXM]OBJMVT = GFXM_PHY
        Close Mask [PHY0], [PHY1]
    Endif
Return

# FQ91070 : mis en place d'1 purge -> A voir
$BOUTON
Infbox BOUT
    If BOUT = "c"

        If [M:FXT]SIMULATION = G_OUI
            Return
        Endif

        Gosub SUPPR_OBJ
    Endif
Return

# Suppression des objets avec sélection identique à l'intégration _______________________________________________________________________
# non en service officiellement(mot clef cbosup)
$SUPPR_OBJ

    WNBTRAITES = 0
    WNBERRPREMCT = 0
    GFXDNBERR = 0
    GSVNBERREURS = 0
    WSVREF1   = ""
    WSVREF2   = ""
    WSVMVT     = 0
    Call DEB_TRACE()

    Trbegin [FXM]
    For [FXM]FXM1

        If ([F:FXM]OBJMVT = GFXM_DEPENSE and [M:FXT]TRTLAY = G_OUI) or
&          ([F:FXM]OBJMVT = GFXM_IMMOS and [M:FXT]TRTFXD = G_OUI) or
&          ([F:FXM]OBJMVT = GFXM_PHY and [M:FXT]TRTPHY = G_OUI)

            If (([F:FXM]TYPMVT = GFXM_SORTIE and [M:FXT]MVTSORTIE = G_OUI) or
&               ([F:FXM]TYPMVT = GFXM_TRANSFERT and [M:FXT]MVTTRF = G_OUI) or
&               ([F:FXM]TYPMVT = GFXM_IMPUT and [M:FXT]MVTIMPUT = G_OUI)  or
&               ([F:FXM]TYPMVT = GFXM_MODIF and [M:FXT]MVTMODIF = G_OUI) or
&               ([F:FXM]TYPMVT = GFXM_SPLIT and [M:FXT]MVTSPLIT = G_OUI)) # FQ91070

                GDROIT_CPYFCY = 1
                GCFXCLE = [F:FXM]REF1MVT
                If [F:FXM]OBJMVT = GFXM_DEPENSE
                    GCFXCLE -= "/" - [F:FXM]REF2MVT
                Endif
                GCFXCLE -= "n° seq" - num$([F:FXM]SEQMVT)

                # recherche du site
                WFCY = ""
                If [F:FXM]OBJMVT = GFXM_DEPENSE
                    Read [LOF]LOF0 = [F:FXM]REF1MVT ; val([F:FXM]REF2MVT)
                    If fstat = 0
                        WFCY = [F:LOF]FCY
                    Endif
                Elsif [F:FXM]OBJMVT = GFXM_IMMOS
                    Read [FASS]FAS0 = [F:FXM]REF1MVT
                    If fstat = 0
                        WFCY = [F:FASS]FCY
                    Endif
                Elsif [F:FXM]OBJMVT = GFXM_PHY
                    Read [PHY]PHY0 = [F:FXM]REF1MVT
                    If fstat = 0
                        WFCY = [F:PHY]FCY
                    Endif
                Endif

                # vérifier si l'utilisateur a les droits au site
                If (GUSRFCY(1) <> "" and GUSRFCY(1) <> "\") and WFCY <> ""
                    If find(WFCY, GUSRFCY) = 0
                        Raz GERRALIMCHP, GMESSAGE #, GT_LIS_ERR
                        GDROIT_CPYFCY = 0
                    Endif
                Endif

                If GDROIT_CPYFCY
                    Call ECR_TRACE(func AFNC.MES5(mess(5, GML_IMPFXD, 1), GCFXCLE, "", "", "", ""), 0) From GESECRAN
                    WNBTRAITES += 1

                    Delete [FXD] Where IDMVT = [F:FXM]IDMVT
                    Delete [FXM]
                Endif
            Endif
        Endif
    Next

    If [M:FXT]SIMULATION = G_OUI
        Rollback
    Else
        Commit
    Endif
#    Infbox num$(WNBTRAITES) - "mouvements supprimés"
Return
#_______
$TERMINE

    GERR = 0
    GMESSAGE = ""
    Call TEMPOFF From GESECRAN
    If GOK

        Call ECR_TRACE("", 0) From GESECRAN
        Call ECR_TRACE(func AFNC.MES5(mess(9, GML_IMPFXD, 1), num$(GFXDNBERR), num$(WNBTRAITES + WNBERRPREMCT), "", "", ""), 0) From GESECRAN
        Call FERME_TRACE() From LECFIC

        If GSERVEUR = 0
            Call LEC_TRACE From LECFIC
        Endif
    Endif

#   fq91070
#    Close File [FXM], [FXD], [FASS], [AMZ], [ATX], [AWI], [AMK], [ATY]
    # CBO 20120227 FQ80394
#    If GPHY = G_OUI
#        Close File [PHY]
#    Endif
#
#    # CBO 2012.02.29 FQ80394 test avec G_ACTCIG pour CIB
#    Close File [LOF], [DEP], [CNX], [SAC]
#    If G_ACTCIG = G_OUI
#        Close File [CIB]
#    Endif

    If dim(GFXALMSK) > 0
        Kill GFXALMSK
    Endif
    If dim(GFXDINT) > 0
        Kill GFXDINT
    Endif
    If dim(GFXDNBERR) > 0 # Attention : cette variable est utilisée (par DIM) dans les actions pour savoir si on est en interface de mouvement
        Kill GFXDNBERR    # il est fondamental qu'elle soit détruite en sortie d'interface
    Endif
    If dim(GFXDERRALCHP) > 0
        Kill GFXDERRALCHP
    Endif

    Close Mask [FXT]
Return

##########################################################################################################
$ALIM_MASK

    # Eviter de boucler sans fin
    If dim(GFXALMSK) > 0
        Return
    Endif
    Local Char WCODWIN(30), WTRTMAM(30), WTRTALIMMSK(30), WTRTGENERE(30)
    Call REFFXM([F:FXM]OBJMVT, [F:FXM]TYPMVT, WCODWIN, WTRTMAM, WTRTALIMMSK, GABVMSKMAM, WTRTGENERE) From SUBFXM
    Global Integer GFXALMSK
    # FQ87753
    GMESSAGE = ""
    mkstat = 0
    # immos
    If [F:FXM]OBJMVT = GFXM_IMMOS

        # paramètres généraux (globales... ?)
        Local Char WSVACTION(30)
        Local Integer SV_ERR_TRACE
        [M:MHC]FLGSIM = [M:FXT]SIMULATION

        [M:MHC]FLGCPY(find([F:FASS]CPY, [M:MHC]CPY) - 1) = G_OUI
        [M:MHC]FLGFCY(find([F:FASS]FCY, [M:MHC]FCY) - 1) = G_OUI

        Call ACTION_FCY ([F:FASS]FCY, [F:FASS]CPY) From GLOFCYCPY

        # écran de sélection
        [M:ASL]TBL1      = "FXDASSETS"
        [M:ASL]FLD1      = "AASREF"
        [M:ASL]OPE1      = 2
        [M:ASL]VAL1      = [F:FXM]REF1MVT
        [M:ASL]VALI1     = [F:FXM]REF1MVT

        If [F:FXM]TYPMVT = GFXM_SORTIE
            Gosub AL_IMM_SORTIE
        Elsif [F:FXM]TYPMVT = GFXM_TRANSFERT
            Gosub AL_IMM_TRANSFERT
        Elsif [F:FXM]TYPMVT = GFXM_IMPUT
            Gosub AL_IMM_IMPUT
        Endif

    # elts physiques
    Elsif [F:FXM]OBJMVT = GFXM_PHY

        # paramètres généraux (globales... ?)
        Local Char WSVACTION(30)
        Local Integer SV_ERR_TRACE
        [M:MHC]FLGSIM = [M:FXT]SIMULATION

        [M:MHC]FLGCPY(find([F:PHY]CPY, [M:MHC]CPY) - 1) = G_OUI
        [M:MHC]FLGFCY(find([F:PHY]FCY, [M:MHC]FCY) - 1) = G_OUI
        Call ACTION_FCY ([F:PHY]FCY, [F:PHY]CPY) From GLOFCYCPY

        # écran de sélection

        [M:ASL]TBL1      = "PHYELT"
        [M:ASL]FLD1      = "PHYREF"
        [M:ASL]OPE1      = 2
        [M:ASL]VAL1      = [F:FXM]REF1MVT
        [M:ASL]VALI1     = [F:FXM]REF1MVT

        If [F:FXM]TYPMVT = GFXM_SORTIE
            Gosub AL_PHY_SORTIE
        Elsif [F:FXM]TYPMVT = GFXM_TRANSFERT
            Gosub AL_PHY_TRANSFERT
        Endif
    Endif

    Kill GFXALMSK
    # CBO 2012.01.31 FQ79681 cas PNUMECRAN = 1
    If [F:FXM]TYPMVT = GFXM_IMPUT
        Call ALIMCHP(GFXDNBERR, 1)
    Else
        Call ALIMCHP(GFXDNBERR, 0)
    Endif
    If GFXDNBERR = GSVNBERREURS
        GFXDERRALCHP = 0
    Else
        GFXDERRALCHP = 1
    Endif

    # Point d'entrée
    # CBO 20120301 FQ80551
    GPOINT="FXD_APRES_CHP" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC

    If [F:FXM]TYPMVT = GFXM_IMPUT
        Affzo [M:FASM]
    Endif
Return


##########################################################################################################

$AL_IMM_SORTIE

    # paramètres de l'action métier

    Raz [M:FASS]
    [M:FASS] = [F:FASS]
[M:FASS]ISSCPY = [F:FASS]CPY # Fqxxxxxx
    [M:FAS0] = [F:FASS]
    [M:FAS1] = [F:FASS]
    [M:FAS2] = [F:FASS]
    [M:FAS4] = [F:FASS]
    Gosub MAJFLGSORTIE

    # Point d'entrée
    # CBO 20120301 FQ80551
    GPOINT="FXD_AVANT_CHP" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC

    Gosub VARMODEECR From FXDINT

    # dans le $DEBUT pour gérer les droits et initialisations
    Gosub DEB_ITFMVT From TRTFASISS
Return

$MAJFLGSORTIE

    If [M:FASS]CCLISSFLG <> G_OUI
        [M:FASS]CCLISSFLG = G_NON
    Endif
    If [M:FASS]EXTISSFLG <> G_OUI
        [M:FASS]EXTISSFLG = G_NON
    Endif
    If [M:FASS]ISSCMPFLG <> G_OUI
        [M:FASS]ISSCMPFLG = G_NON
    Endif
    If [M:FASS]IMLFLG <> G_OUI
        [M:FASS]IMLFLG = G_NON
    Endif
    # CBO 2012.02.29 FQ80394
    If GPHY = G_OUI
        If [M:FASS]ECRPHYATT <> G_OUI
            [M:FASS]ECRPHYATT = G_NON
        Endif
    Endif
Return

##########################################################################################################
$AL_IMM_TRANSFERT

    # paramètres de l'action métier

    Raz [M:FASM]
    [M:FASM] = [F:FASS]

#    [M:FASM] = [F:FASS]
    [M:FAS0] = [F:FASS]
    [M:FAS1] = [F:FASS]
    [M:FAS2] = [F:FASS]

    If [M:FASM]CCLTRF <> G_OUI
        [M:FASM]CCLTRF = G_NON
    Endif
    # CBO 2012.02.29 FQ80394
    If GPHY = G_OUI
        If [M:FASM]ECRPHYATT <> G_OUI
            [M:FASM]ECRPHYATT = G_NON
        Endif
    Endif

    # Point d'entrée
    # CBO 20120301 FQ80551
    GPOINT="FXD_AVANT_CHP" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC

    Gosub VARMODEECR From FXDINT
    Default Mask [M:FAS0]

    # dans le $DEBUT pour gérer les droits et initialisations
    Gosub DEB_ITFMVT From TRTFASTRF
Return
##########################################################################################################
$AL_IMM_IMPUT

    # paramètres de l'action métier


    Raz [M:FASC], [M:FASM]
    [M:MHC] = [F:FASS]
    [M:FASC] = [F:FASS]
    [M:FASM] = [F:FASS]
#    [M:FASM] = [F:DEP]

    [M:FAS0] = [F:FASS]
    [M:FAS1] = [F:FASS]

    # Point d'entrée
    # CBO 20120301 FQ80551
    GPOINT="FXD_AVANT_CHP" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC

    Gosub VARMODEECR From FXDINT
#    Default Mask [M:FASC]
#    Default Mask [M:FASM]

    # dans le $DEBUT pour gérer les droits et initialisations
    Gosub CREE_GLOBTRT From TRTFASTRFC
    Gosub DEBUT From TRTFASTRFC

    Gosub DEB_ITFMVT From TRTFASTRFC

Return


##########################################################################################################

$TRAITE_MODIF
Local Char WCODWIN(30), WTRTMAM(30), WTRTALIMMSK(30), WTRTGENERE(30)
Local Shortint WNREF2
Local Integer WTAB, WERRCHP

    GERR = 0
    Call REFFXM([F:FXM]OBJMVT, [F:FXM]TYPMVT, WCODWIN, WTRTMAM, WTRTALIMMSK, GABVMSKMAM, WTRTGENERE) From SUBFXM

    # lecture et alimentation des masques _______________________________________

    If [F:FXM]OBJMVT = GFXM_DEPENSE

        Local Mask LOF0 [LOF0], LOF1 [LOF1], LOF2 [LOF2], LOFFZ9 [LOF9]
        If [F:FXM]REF2MVT <> ""
            WNREF2 = val([F:FXM]REF2MVT)
        Endif

        Trbegin [LOF]
        Read [F:LOF]LOF0 = [F:FXM]REF1MVT ; WNREF2
        If fstat
            GERR = 1

            [F:FXM]DESRJTMVT = func AFNC.MES5(mess(10, GML_IMPFXD, 1), [F:FXM]REF1MVT, [F:FXM]REF2MVT, "", "", "")
#            [F:FXM]DESRJTMVT = "dépense non lue (" + [F:FXM]REF1MVT + "/" + [F:FXM]REF2MVT + ")"
            [F:FXM]TRACE = GTRACE
        Else
            [M:LOF0] = [F:LOF]
            [M:LOF1] = [F:LOF]
            [M:LOF2] = [F:LOF]
            [M:LOF9] = [F:LOF]
        Endif

    Elsif [F:FXM]OBJMVT = GFXM_IMMOS

        Local Mask FAS0 [FAS0], FAS1 [FAS1], FAS2 [FAS2], FAS3 [FAS3], FAS4 [FAS4]
# CBO 2012.01.30 FQ79740 : KAS9 dépend d'1 code activité
        If WNKAS9 = G_OUI
            Local Mask KAS9 [KAS9]
        Endif
# CBO 2012.01.30 FQ79740 : FAS5 et FAS6 dépendent d'1 code activité
            If (dim(GKFR) >= 0 and GKFR = G_OUI) or dim(GKFR) < 0
                Local Mask FAS5 [FAS5]
            Endif
            If G_ACTCCN = G_OUI
                Local Mask FAS6 [FAS6]
            Endif

        Local Mask FASFZ9 [FAS9], FAS8 [FAS8] #, KAS9 [KAS9]
        Trbegin [FASS]
        Read [F:FASS]FAS0 = [F:FXM]REF1MVT
        If fstat
            GERR = 1
            [F:FXM]DESRJTMVT = func AFNC.MES5(mess(11, GML_IMPFXD, 1), [F:FXM]REF1MVT, "", "", "", "")
#            [F:FXM]DESRJTMVT = "bien non lu (" + [F:FXM]REF1MVT + ")"
            [F:FXM]TRACE = GTRACE
        Elsif [F:FASS]ISSDAT <> [0/0/0]
            GERR = 1
            [F:FXM]DESRJTMVT = mess(12, GML_IMPFXD, 1)
        Else
            [M:FAS0] = [F:FASS]
            [M:FAS1] = [F:FASS]
            [M:FAS2] = [F:FASS]
            [M:FAS3] = [F:FASS]
            [M:FAS4] = [F:FASS]
# CBO 2012.01.30 FQ79740 : FAS5 et FAS6 dépendent d'1 code activité
            If (dim(GKFR) >= 0 and GKFR = G_OUI) or dim(GKFR) < 0
                [M:FAS5] = [F:FASS]
            Endif
            If G_ACTCCN = G_OUI
                [M:FAS6] = [F:FASS]
            Endif

            [M:FAS9] = [F:FASS]
            [M:FAS8] = [F:FASS]
            # CBO 2012.01.30 FQ79740 : KAS9 dépend d'1 code activité
            If WNKAS9 = G_OUI
                [M:KAS9] = [F:FASS]
            Endif
        Endif

    Elsif [F:FXM]OBJMVT = GFXM_PHY

        Local Mask PHY0 [PHY0], PHY1 [PHY1], PHY2 [PHY2], PHYFZ9 [PHY9]

        Trbegin [PHY]
        Read [F:PHY]PHY0 =  [F:FXM]REF1MVT
        If fstat
            GERR = 1
            [F:FXM]DESRJTMVT = func AFNC.MES5(mess(13, GML_IMPFXD, 1), [F:FXM]REF1MVT, "", "", "", "")
#            [F:FXM]DESRJTMVT = "élément physique non lu (" + [F:FXM]REF1MVT + ")"
            [F:FXM]TRACE = GTRACE
        Else
            [M:PHY0] = [F:PHY]
            [M:PHY1] = [F:PHY]
            [M:PHY2] = [F:PHY]
            [M:PHY9] = [F:PHY]
        Endif
    Endif

    # modification des champs _______________________________________

    If GERR = 0

        # Point d'entrée
        # CBO 20120301 FQ80551
        GPOINT="FXD_AVANT_CHP" #CHECK IGNORE_LINE
        Gosub ENTREE From EXEFNC

        WERRCHP = 0
        Call ALIMCHP(WERRCHP, 0)
        # alimchp incrémente mais refait en CPTERENDUMOD pour ts les types de contrôle
#        GFXDNBERR -= 1
        [F:FXM]TRACE = GTRACE

        # Point d'entrée
        # CBO 20120301 FQ80551
        GPOINT="FXD_APRES_CHP" #CHECK IGNORE_LINE
        Gosub ENTREE From EXEFNC

    Endif

    # contrôle _______________________________________

    If GERR = 0
        For [FXD]FXD0 Where IDMVT = [F:FXM]IDMVT
            If func SUBFXM.IS_MVT_AUTORISE([F:FXM]OBJMVT, [F:FXD]CODZONE, WTAB) = 0

                [F:FXM]DESRJTMVT = func AFNC.MES5(mess(14, GML_IMPFXD, 1), [F:FXD]CODZONE, num$(WTAB), "", "", "")
#                [F:FXM]DESRJTMVT = "Champ" - [F:FXD]CODZONE - "non autorisé en modification (voir table diverse n°" - num$(WTAB) + ")"
                [F:FXM]TRACE = GTRACE
                GERR = 1
                Break
            Else
                If func SUBFXM.IS_ZLIB_OK([F:FXM]CPY, [F:FXM]OBJMVT, [F:FXD]CODZONE, [F:FXD]VALZONE, WTAB) = 0

                [F:FXM]DESRJTMVT = func AFNC.MES5(mess(15, GML_IMPFXD, 1), [F:FXD]CODZONE, [F:FXD]VALZONE, num$(WTAB), "", "")
#                    [F:FXM]DESRJTMVT = "Valeur du champ" - [F:FXD]CODZONE - "= '" + [F:FXD]VALZONE + "' non renseignée en table diverse n°" - num$(WTAB)
                    [F:FXM]TRACE = GTRACE
                    GERR = 1
                    Break
                Endif
            Endif
        Next
    Endif

    # enregistrement _______________________________________


    If GERR = 0
        If [F:FXM]OBJMVT = GFXM_DEPENSE

            [F:LOF] = [M:LOF0]
            [F:LOF] = [M:LOF1]
            [F:LOF] = [M:LOF2]
            [F:LOF] = [M:LOF9]
            [F:FXM]TRACE = GTRACE
            Rewrite [F:LOF]

        Elsif [F:FXM]OBJMVT = GFXM_IMMOS

#            If GERR = 0
#                Gosub CONTROLE_MODIF
#            Endif
#            If GERR
#                GFXDNBERR += 1
#            Else
                [F:FASS] = [M:FAS0]
                [F:FASS] = [M:FAS1]
                [F:FASS] = [M:FAS2]
                [F:FASS] = [M:FAS3]
                [F:FASS] = [M:FAS4]
# CBO 2012.01.30 FQ79740 : FAS5 et FAS6 dépendent d'1 code activité
                If (dim(GKFR) >= 0 and GKFR = G_OUI) or dim(GKFR) < 0
                    [F:FASS] = [M:FAS5]
                Endif
                If G_ACTCCN = G_OUI
                    [F:FASS] = [M:FAS6]
                Endif

                [F:FASS] = [M:FAS9]
                [F:FASS] = [M:FAS8]
# CBO 2012.01.30 FQ79740 : KAS9 dépend d'1 code activité
                If WNKAS9 = G_OUI
                    [F:FASS] = [M:KAS9]
                Endif

                [F:FXM]TRACE = GTRACE
                Rewrite [F:FASS]
#            Endif

        Elsif [F:FXM]OBJMVT = GFXM_PHY

            [F:PHY] = [M:PHY0]
            [F:PHY] = [M:PHY1]
            [F:PHY] = [M:PHY2]
            [F:PHY] = [M:PHY9]
            [F:FXM]TRACE = GTRACE
            Rewrite [F:PHY]
        Endif

        If fstat
            [F:FXM]DESRJTMVT = func AFNC.MES5(mess(16, GML_IMPFXD, 1), [F:FXM]REF1MVT, "", "", "", "")
#            [F:FXM]DESRJTMVT = "Echec en Maj de" - [F:FXM]REF1MVT
            [F:FXM]TRACE = GTRACE
            GERR = 1
        Endif
     Endif

    If fstat = 0 and [M:FXT]SIMULATION = 1 and GERR = 0
        Commit
    Else
        Rollback
    Endif
    # FQ91070 suppression de GERR et GFXDNBERR
    Call CPTERENDUMOD()
    GERR = 0
Return


$CONTROLE_MODIF
# pour le moment réservé aux immos (INUTILISE à ce jour)
    Gosub VARMODEECR From FXDINT

    Local Integer SV_ERR_TRACE
    Default Mask [M:FAS0]

    GIMPORT = 1 # permet de ne pas afficher à l'écran les messages d'erreur
    SV_ERR_TRACE = GERRTRACE

    Gosub AVANT_MOD From SUBFAS
    If GERR
        Setmode
        [F:FXM]DESRJTMVT = GMESSAGE
        Return
    Endif

    Call SAIMSK("", "ACT_SPE", "FXDINT") From W0FAS0
    GIMPORT = 0
    # setmode final
    Setmode
    If SV_ERR_TRACE <> GERRTRACE
        GERR = 1
        Return
    Endif
Return

##########################################################################################################
$AL_PHY_SORTIE

    # paramètres de l'action métier

    Raz [M:PHYS]

    [M:PHYS] = [F:PHY]
    [M:PHY0] = [F:PHY]
    [M:PHY1] = [F:PHY]
    # CBO 20120105 exigence 69691B
    If [M:PHYS]CCLISSFLG <> G_OUI
        [M:PHYS]CCLISSFLG = G_NON
    Endif

    # Point d'entrée
    # CBO 20120301 FQ80551
    GPOINT="FXD_AVANT_CHP" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC

    Gosub VARMODEECR From FXDINT

    # dans le $DEBUT pour gérer les droits et initialisations
    Gosub DEB_ITFMVT From TRTPHYISS
Return
##########################################################################################################
$AL_PHY_TRANSFERT

    # paramètres de l'action métier

    Raz [M:PHYM]

    [M:PHYM] = [F:PHY]
    [M:PHY0] = [F:PHY]
    [M:PHY1] = [F:PHY]
    # CBO 20120105 exigence 69691B
#    If [M:PHYM]CCLTRF <> G_OUI
        [M:PHYM]CCLTRF = G_NON
#    Endif

    # Point d'entrée
    # CBO 20120301 FQ80551
    GPOINT="FXD_AVANT_CHP" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC

    Gosub VARMODEECR From FXDINT
    Default Mask [M:PHY0]

    # dans le $DEBUT pour gérer les droits et initialisations

Global Char    SAULOCO(30)
Global Char    SAULOCD(30)
Global Char    SAUFCYD(30)
Global Date    SAUTRFDAT(30)

Gosub OUVRE From TRTPHYTRF
    Gosub DEB_ITFMVT From TRTPHYTRF
Return

######################################################################################
$ACT_SPE
Return


$VARMODEECR

    # varmode ne fonctionne que quand l'écran est ouvert à partir d'1 fenêtre
    # pour une ouverture par traitement, voici un moyen de passer outre (de Marc)

    # ne pas oublier le setmode final (après les contrôles) pour désactiver...


    Local Shortint IADIME : IADIME = 30    : # Taille pour le Setmode'
    Local Integer  INBAFF                  : # Pile/Indice'
    Local Integer  IAFFCOD(0..IADIME)      : # Code instruction'
    Local Char     IAFFMASK(GLONABR)(0..IADIME)  : # Abréviation écran'
    Local Char     IAFFCHP(50)(0..IADIME)        : # Zone écran'
    Local Integer  IAFFIND(0..IADIME)            : # Indice de la zone'
    Local Char     IAFFTXT(250)(0..IADIME) : # Texte'
    Local Integer  IAFFRANG(0..IADIME)     : # Rang'
    Local Integer  IAFFOPT1(0..IADIME)     : # Option1 Ex: Status, premier rang affzo 10-20'
    Local Integer  IAFFOPT2(0..IADIME)     : # Option2 Ex: Raccourci clavier, dernier rang affzo 10-20'
    Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2

# setmode final à reporter après la partie de source
# Setmode

Return
# CBO 2012.01.20 FQ69691B ajout de pnumecran
######################################################################################
#** Alimente les champs écran de FXD
#*
#*
#* @param RNBERREURS nombre d'erreurs
#* @param PNUMECRAN  pour chgt d'imputation : 0 = tous, 1 = premier, 2 = deuxième
#*                   pour éclatement        : 0 = tous, 1 = champs de paramétrage, 2 = tableau des biens générés
#*!
Subprog ALIMCHP(RNBERREURS, PNUMECRAN)
Variable Integer RNBERREURS
Value Integer PNUMECRAN

Local Decimal WDIMEMAX, WTYPTYP, WNBMVTD, WMT
Local Char WDESI(30), WCODZONE(30), WABRMSK(30), WMSK(30)
Local Char WSUFFIXE(30), WSCODESUFF(30)
Local Date WDT
Local Integer WERR, WINDPLN, WBOK
Local Integer WNDIME, WI

    GREPART_VIA_QTY = G_NON # FQ91070
    GNBFAS_FXD = G_NON # FQ91070
    Raz GTBSPLPRC  # FQ91070
    WNBMVTD    = 0
    For [FXD]FXD0 Where IDMVT = [F:FXM]IDMVT
        WNBMVTD += 1
        If func SUBFXM.LIRTYPMSK([F:FXM]OBJMVT, [F:FXM]TYPMVT, [F:FXD]CODZONE,
&         [F:FXD]DPRPLN, WDIMEMAX, WTYPTYP, WDESI, WABRMSK, WMSK) <> ""

            WCODZONE = "[M:" + WABRMSK + "]" + [F:FXD]CODZONE
            # CBO CBO
            WBOK = 1
            If [F:FXM]OBJMVT = GFXM_IMMOS and [F:FXM]TYPMVT = GFXM_IMPUT
                # CBO 2012.01.31 FQ79681 cas PNUMECRAN = 1
                If PNUMECRAN = 1
                    If WABRMSK = "FASM"
                        WBOK = 0
                    Endif
                Elsif PNUMECRAN = 2
                    If WABRMSK <> "FASM"
                        WBOK = 0
                    Endif
                Endif
            Endif
            # FQ91070
            If [F:FXM]OBJMVT = GFXM_IMMOS and [F:FXM]TYPMVT = GFXM_SPLIT
                # CBO 2012.01.31 FQ79681 cas PNUMECRAN = 1
                If PNUMECRAN = 1 and WABRMSK = "FASE" and [F:AMK]TYPBLOC([F:AMZ]NUMBLOC - 1) = 1 # on ne veut pas les champs du tableau
                    WBOK = 0
                Elsif PNUMECRAN = 2 and WABRMSK = "FASE" and [F:AMK]TYPBLOC([F:AMZ]NUMBLOC - 1) <> 1 # on veut les champs du tableau
                    WBOK = 0
                Endif

                # FQ91070 action de répartir les montants en fonction de la quantité
                If [F:FXD]CODZONE = GCODE_REPART
                    WBOK = 0
                    If [F:FXD]VALZONE = num$(G_OUI)
                        GREPART_VIA_QTY = G_OUI
                    Endif
                Endif
                If [F:FXD]CODZONE = "NBFAS" and [F:FXD]VALZONE <> ""
                    GNBFAS_FXD = G_OUI
                Endif
                If [F:FXD]CODZONE = "SPLPRC" and [F:FXD]VALZONE <> ""
                    If [F:FXD]DIME = ""
                        GTBSPLPRC(0) = 1
                    Else
                        GTBSPLPRC(val([F:FXD]DIME)) = 1
                    Endif
                Endif

            Endif
            #blocage temporaire de la partie CM
#            If [F:FXM]OBJMVT = GFXM_IMMOS and [F:FXM]TYPMVT = GFXM_IMPUT
#                If WABRMSK = "FASM"
#                    RNBERREURS += 1
#
#                    [F:FXM]DESRJTMVT = func AFNC.MES5(mess(17, GML_IMPFXD, 1), [F:FXD]CODZONE, "", "", "", "")
##                    [F:FXM]DESRJTMVT = "Champ inexistant" - [F:FXD]CODZONE - "(valeur" - [F:FXD]VALZONE + ")"
#                    GERRALIMCHP = [F:FXM]DESRJTMVT
#                    GERR = 1
#                    Break
#                Endif
#            Endif
            # Fin blocage temporaire de la partie CM

            If WBOK
                # Gestion spécifique des flags sortie et transfert
                If [F:FXM]OBJMVT = GFXM_IMMOS and [F:FXM]TYPMVT = GFXM_SORTIE and
&                  [F:FXD]CODZONE = "CCLISSFLG"

                    If [F:FXD]VALZONE = num$(G_OUI) and [M:FASS]ISSDAT = [0/0/0]
                        RNBERREURS += 1
                        [F:FXM]DESRJTMVT = mess(18, GML_IMPFXD, 1)
#                       [F:FXM]DESRJTMVT = "Annulation de sortie impossible : bien non sorti"
                        GERRALIMCHP = [F:FXM]DESRJTMVT
                        GERR = 1
                        Break
                    Elsif [F:FXD]VALZONE <> num$(G_OUI) and [M:FASS]ISSDAT <> [0/0/0]
                        RNBERREURS += 1
                        [F:FXM]DESRJTMVT = mess(19, GML_IMPFXD, 1)
#                       [F:FXM]DESRJTMVT = "Sortie impossible : bien déjà sorti"
                        GERRALIMCHP = [F:FXM]DESRJTMVT
                        GERR = 1
                        Break
                    Else
                        Assign WCODZONE With val([F:FXD]VALZONE)
                    Endif

                Elsif [F:FXM]OBJMVT = GFXM_IMMOS and [F:FXM]TYPMVT = GFXM_TRANSFERT and
&                 [F:FXD]CODZONE = "CCLTRF"
                    If [F:FXD]VALZONE = num$(G_OUI) and [M:FASM]MVTDAT = [0/0/0]
                        RNBERREURS += 1
                        [F:FXM]DESRJTMVT = mess(20, GML_IMPFXD, 1)
#                       [F:FXM]DESRJTMVT = "Annulation de transfert impossible : bien non transféré"
                        GERRALIMCHP = [F:FXM]DESRJTMVT
                        GERR = 1
                        Break
                    Elsif [F:FXD]VALZONE = num$(G_OUI) and [F:FASS]ISSDAT <> [0/0/0]
                        RNBERREURS += 1
                        [F:FXM]DESRJTMVT = mess(21, GML_IMPFXD, 1)
#                       [F:FXM]DESRJTMVT = "Annulation de transfert impossible : bien sorti"
                        GERRALIMCHP = [F:FXM]DESRJTMVT
                        GERR = 1
                        Break
                    Elsif [F:FXD]VALZONE <> num$(G_OUI) and [F:FASS]ISSDAT <> [0/0/0]
                        RNBERREURS += 1
                        [F:FXM]DESRJTMVT = mess(22, GML_IMPFXD, 1)
#                       [F:FXM]DESRJTMVT = "Transfert impossible : bien sorti"
                        GERRALIMCHP = [F:FXM]DESRJTMVT
                        GERR = 1
                        Break
                    Else
                        Assign WCODZONE With val([F:FXD]VALZONE)
                    Endif

                # CBO 20120105 exigence 69691B
                Elsif [F:FXM]OBJMVT = GFXM_PHY and [F:FXM]TYPMVT = GFXM_SORTIE and
&                     [F:FXD]CODZONE = "CCLISSFLG"

                    If [F:FXD]VALZONE = num$(G_OUI) and [F:PHY]ISSDAT = [0/0/0]
                        RNBERREURS += 1
                        [F:FXM]DESRJTMVT = mess(18, GML_IMPFXD, 1)
#                       [F:FXM]DESRJTMVT = "Annulation de sortie impossible : bien non sorti"
                        GERRALIMCHP = [F:FXM]DESRJTMVT
                        GERR = 1
                        Break
                    Elsif [F:FXD]VALZONE <> num$(G_OUI) and [F:PHY]ISSDAT <> [0/0/0]
                        RNBERREURS += 1
                        [F:FXM]DESRJTMVT = mess(19, GML_IMPFXD, 1)
#                       [F:FXM]DESRJTMVT = "Sortie impossible : bien déjà sorti"
                        GERRALIMCHP = [F:FXM]DESRJTMVT
                        GERR = 1
                        Break
                    Else
                        Assign WCODZONE With val([F:FXD]VALZONE)
                    Endif
                Else
                    # champ saisissable
#                    If evalue("varmode(" + WCODZONE + ")") = 0
                    If WCODZONE <> ""
# V5 <> V6 _________________________________________
                        WSUFFIXE = ""
                        # FQ91070 ajout de WDIMEMAX
                        If GTYPDIMEAL
                            WI = func SUBFXM.TRTDIME(GTYPDIMEAL, [F:FXD]DIME, [F:FXD]CODZONE, WDIMEMAX, WNDIME, WSUFFIXE, WSCODESUFF)
                        Else
                            WI = func SUBFXM.TRTDIME(GTYPDIMEAL, num$([F:FXD]DIME), [F:FXD]CODZONE, WDIMEMAX, WNDIME, WSUFFIXE, WSCODESUFF)
                        Endif
                        If WNDIME
                            # CBO 2012.02.23 FQ80109
                            If WNDIME >= WDIMEMAX
                                RNBERREURS += 1
                                [F:FXM]DESRJTMVT = func AFNC.MES5(mess(1, GML_IMPFXD, 1), num$(WDIMEMAX), "", "", "", "")
                                GERRALIMCHP = [F:FXM]DESRJTMVT
                                GERR = 1
                                Break
                            Endif

                            WCODZONE += WSUFFIXE
                        Elsif WSUFFIXE <> ""

                            If [F:FXM]TYPMVT = GFXM_TRANSFERT
                                # CBO 2012.02.29 FQ80394
                                If GOPTCANA
                                    WI = find([F:FXD]DIME, [M:FASM]DIE)
                                Else
                                    WI = 0
                                Endif
                                If WI
#                                    [M:FASM]CCED(WI - 1) = [F:FXD]VALZONE
                                    WCODZONE = "[M:FASM]CCED(" + num$(WI - 1) + ")"
                                Else
                                    RNBERREURS += 1
                                    [F:FXM]DESRJTMVT = func AFNC.MES5(mess(31, GML_IMPFXD, 1), [F:FXD]DIME, "", "", "", "")
                  #                 [F:FXM]DESRJTMVT = "Axe analytique $1$ non trouvé"
                                    GERRALIMCHP = [F:FXM]DESRJTMVT
                                    GERR = 1
                                    Break
                                Endif
                            Endif
                        Endif
# V5 <> V6 _________________________________________

                        If [F:FXD]DPRPLN > 0
                            # attention : [F:FXD]DPRPLN est le n° du plan
                            # transformer en indice du tableau
                            WINDPLN = func INDUPLAN([F:FXD]DPRPLN, [M:FASM]NBLIG1)
                            If WINDPLN >= 0
                                WCODZONE += "(" + num$(WINDPLN) + ")"
                            Else
                                RNBERREURS += 1
#                               [F:FXM]DESRJTMVT = "Plan" - num$([F:FXD]DPRPLN) - "non trouvé"
                                [F:FXM]DESRJTMVT = func AFNC.MES5(mess(23, GML_IMPFXD, 1), num$([F:FXD]DPRPLN), "", "", "", "")
                                GERRALIMCHP = [F:FXM]DESRJTMVT
                                GERR = 1
                                Break
                            Endif
                        Endif

                        # stockage pour pouvoir indiquer que ce champ est modifié
                        # ds les IMP_MVT des TRTFASTRF...
                        If [F:FXD]VALZONE <> ""
                            GNBRUBALIM += 1
                            GRUBALIM(GNBRUBALIM) = [F:FXD]CODZONE
# V5 <> V6 _________________________________________
                            If WSUFFIXE <> ""
                                GRUBALIM(GNBRUBALIM) += WSUFFIXE
# V5 <> V6 _________________________________________
                            Elsif [F:FXD]DPRPLN > 0
                                GRUBALIM(GNBRUBALIM) += "(" + num$(WINDPLN) + ")"
                            Endif
                        Endif

                        If WTYPTYP = 7 or WTYPTYP = 10
                            Assign WCODZONE With vireblc([F:FXD]VALZONE, 2)
                        Elsif WTYPTYP < 7
                            WMT = func SUBFXM.CSTRMTDEC(vireblc([F:FXD]VALZONE, 4), WTYPTYP, WERR)
                            If WERR = 0
                                Assign WCODZONE With WMT
                            Else
                                RNBERREURS += 1
                                [F:FXM]DESRJTMVT = func AFNC.MES5(mess(2, GML_IMPFXD, 1), WCODZONE, [F:FXD]VALZONE, "", "", "")
#                               [F:FXM]DESRJTMVT = "Format de montant invalide (" + WCODZONE - [F:FXD]VALZONE + ")"
                                GERRALIMCHP = [F:FXM]DESRJTMVT
                                GERR = 1
                                Break
                            Endif
                        Elsif WTYPTYP = 8
                            WDT = func SUBFXM.CSTRDATE(vireblc([F:FXD]VALZONE, 4), WERR)
                            If WERR = 0
                                Assign WCODZONE With WDT
                            Else
                                RNBERREURS += 1
                                [F:FXM]DESRJTMVT = func AFNC.MES5(mess(3, GML_IMPFXD, 1), WCODZONE, [F:FXD]VALZONE, "", "", "")
#                               [F:FXM]DESRJTMVT = "Format de date invalide (" + WCODZONE - [F:FXD]VALZONE + ")"
                                GERRALIMCHP = [F:FXM]DESRJTMVT
                                GERR = 1
                                Break
                            Endif
                        Endif

                        # CBO 2012.01.17 FQ69691B
                        If [F:FXM]OBJMVT = GFXM_IMMOS and [F:FXM]TYPMVT = GFXM_SORTIE
                            If [F:FXD]CODZONE = "ISSAMT"
                                Assign "[M:" + WABRMSK + "]FGISSAMT" With G_OUI
                            Elsif [F:FXD]CODZONE = "ISSVATRAT"
                                Assign "[M:" + WABRMSK + "]FGISSVAT" With G_OUI
                            Endif
                        Endif
                    Else
                        If [F:FXD]VALZONE <> ""
                            RNBERREURS += 1
#                           [F:FXM]DESRJTMVT = "champ" - WCODZONE - "non modifiable. (valeur" - [F:FXD]VALZONE + ")"
                            [F:FXM]DESRJTMVT = func AFNC.MES5(mess(24, GML_IMPFXD, 1), WCODZONE, [F:FXD]VALZONE, "", "", "")
                            GERRALIMCHP = [F:FXM]DESRJTMVT
                            GERR = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Else
            RNBERREURS += 1
            [F:FXM]DESRJTMVT = func AFNC.MES5(mess(17, GML_IMPFXD, 1), [F:FXD]CODZONE, "", "", "", "")
#           [F:FXM]DESRJTMVT = "champ inexistant" - [F:FXD]CODZONE - "(valeur" - [F:FXD]VALZONE + ")"
            GERRALIMCHP = [F:FXM]DESRJTMVT
            GERR = 1
            Break
        Endif
    Next

    If WNBMVTD = 0
        RNBERREURS += 1
        [F:FXM]DESRJTMVT = mess(25, GML_IMPFXD, 1)
#        [F:FXM]DESRJTMVT = "aucun champ paramétré"
        GERRALIMCHP = [F:FXM]DESRJTMVT
        GERR = 1
    Endif
End

#** Vérifie si le champ est saisissable : A l'écran, on ne peut rien saisir,
#*  mais en interface, rien n'empêche d'affecter, il faut donc contrôler.
#*
#*
#* @param RNBERREURS
#*!
Subprog CTLVARMODE(RNBERREURS)
Variable Integer RNBERREURS

Local Decimal WDIMEMAX, WTYPTYP
Local Integer WNDIME
Local Char WDESI(30), WCODZONE(30), WABRMSK(30), WCODZONE2(30), WMSK(30)
Local Char WSUFFIXE(30), WSCODESUFF(30)

    GFXDERRALCHP = 0

    # FQ90828 contrôle en chgt d'imput si TRTFLG Ok pour les champs du plan
    If [F:FXM]TYPMVT = GFXM_IMPUT
        Local Integer T_TRTFLG(0..20)
        Raz T_TRTFLG

        # Recherche des plans flagués (TRTFLG = G_OUI)
        For [FXD]FXD0 Where IDMVT = [F:FXM]IDMVT and CODZONE = "TRTFLG"

            If [F:FXD]VALZONE = num$(G_OUI)
                T_TRTFLG([F:FXD]DPRPLN) = 1
            Endif
        Next

        # Recherche des champs (onglet plan) correspondant à un plan non flagué
        For [FXD]FXD0 Where IDMVT = [F:FXM]IDMVT and CODZONE <> "TRTFLG" and [F:FXD]DPRPLN > 0

            If T_TRTFLG([F:FXD]DPRPLN) = 0
                WCODZONE2 = [F:FXD]CODZONE + "(" + mess([F:FXD]DPRPLN, GML_NPLAN, 1) + ")"

                RNBERREURS += 1
                GFXDERRALCHP = 1
                [F:FXM]DESRJTMVT = func AFNC.MES5(mess(36, GML_IMPFXD, 1), WCODZONE2, [F:FXD]VALZONE, "", "", "")
                GERRALIMCHP = [F:FXM]DESRJTMVT
                GERR = 1
                Break

            Endif
        Next
        If GFXDERRALCHP
            End

        Endif
    Endif

    For [FXD]FXD0 Where IDMVT = [F:FXM]IDMVT
        If func SUBFXM.LIRTYPMSK([F:FXM]OBJMVT, [F:FXM]TYPMVT, [F:FXD]CODZONE,
&         [F:FXD]DPRPLN, WDIMEMAX, WTYPTYP, WDESI, WABRMSK, WMSK) <> ""

            WCODZONE = "[M:" + WABRMSK + "]" + [F:FXD]CODZONE

# V5 <> V6 _________________________________________
            # FQ91070 ajout de WDIMEMAX
            If GTYPDIMEAL
                I = func SUBFXM.TRTDIME(GTYPDIMEAL, [F:FXD]DIME, [F:FXD]CODZONE, WDIMEMAX, WNDIME, WSUFFIXE, WSCODESUFF)
            Else
                I = func SUBFXM.TRTDIME(GTYPDIMEAL, num$([F:FXD]DIME), [F:FXD]CODZONE, WDIMEMAX, WNDIME, WSUFFIXE, WSCODESUFF)
            Endif
            If WNDIME
               WCODZONE += WSUFFIXE
            Endif
# V5 <> V6 _________________________________________

            WCODZONE2 = WCODZONE

            # attention : [F:FXD]DPRPLN est le n° du plan
            # transformer en indice du tableau

            If [F:FXD]DPRPLN > 0
                WCODZONE += "(" + num$(func INDUPLAN([F:FXD]DPRPLN, [M:FASM]NBLIG1)) + ")"
                WCODZONE2 + = "(" + mess([F:FXD]DPRPLN, GML_NPLAN, 1) + ")"
            Endif

            # Gestion spécifique des flags sortie et transfert
            If [F:FXD]CODZONE <> "CCLISSFLG" and [F:FXD]CODZONE <> "CCLTRF"

                # FQ91070 action de répartir les montants en fonction de la quantité
                If [F:FXM]OBJMVT = GFXM_IMMOS and [F:FXM]TYPMVT = GFXM_SPLIT and [F:FXD]CODZONE = GCODE_REPART
                Else

                    If [F:FXD]VALZONE <> ""
                    # champ saisissable
                        If evalue("varmode(" + WCODZONE + ")")

                            # FQ91070 : exception : si on a alimenté SPLBAS à la bonne valeur et qu'il n'y avait que ce choix (donc champ non saisissable)
                            If [F:FXM]OBJMVT = GFXM_IMMOS and [F:FXM]TYPMVT = GFXM_SPLIT and
&                              [F:FXD]CODZONE = "SPLBAS" and [F:FXD]VALZONE = num$(GSPLBASVFRCE)
                                [M:FASE]SPLBAS = GVML_TECLAMT
# Issue 118804
                            Elsif [F:FXM]OBJMVT = GFXM_IMMOS and [F:FXM]TYPMVT = GFXM_IMPUT and
&                              [F:FXD]CODZONE = "TRTFLG"
# End Issue 118804
                            Else
                                RNBERREURS += 1
                                GFXDERRALCHP = 1
                                [F:FXM]DESRJTMVT = func AFNC.MES5(mess(24, GML_IMPFXD, 1), WCODZONE2, [F:FXD]VALZONE, "", "", "")
        #                       [F:FXM]DESRJTMVT = "champ" - WCODZONE2 - "non modifiable. (=" - [F:FXD]VALZONE + ")"
                                GERRALIMCHP = [F:FXM]DESRJTMVT
                                GERR = 1
                                Break
                            Endif
                        Endif
                    Endif
                Endif
            Endif
        Endif
    Next
End

# CBO 2012.04.20 FQ81733 pb de type des paramètres
#** recherche de l'indice du plan dans le tableau des plans [M:FASM]
#*
#*
#* @param PNUMPLAN
#* @param PNBPLAN
#*!
Funprog INDUPLAN(PNUMPLAN, PNBPLAN)
Value Shortint PNUMPLAN, PNBPLAN
#Value Integer PNUMPLAN, PNBPLAN

Local Integer RINDICE, I
    RINDICE = -1

    For I = 1 To PNBPLAN
        If PNUMPLAN = [M:FASM]DPRPLND(I - 1)
            RINDICE = I - 1
            Break
        Endif
    Next

End RINDICE


#** liste des champs paramétrés avec leur valeur
#*
#*!
Subprog CRDET()

Local Decimal WDIMEMAX, WTYPTYP
Local Integer WNDIME
Local Char WSUFFIXE(30), WSCODESUFF(30)
Local Char WDESI(30), WCODZONE(30), WABRMSK(30), WDESIVAL(50), WCODTYP(30), WMSK(30)

    For [FXD]FXD0 Where IDMVT = [F:FXM]IDMVT
        # FQ91070
        WCODTYP = func SUBFXM.LIRTYPMSK([F:FXM]OBJMVT, [F:FXM]TYPMVT, [F:FXD]CODZONE,
&         [F:FXD]DPRPLN, WDIMEMAX, WTYPTYP, WDESI, WABRMSK, WMSK)
        If WCODTYP <> ""

            WCODZONE = "[M:" + WABRMSK + "]" + [F:FXD]CODZONE
# V5 <> V6 _________________________________________
            # FQ91070
            If GTYPDIMEAL
                I = func SUBFXM.TRTDIME(GTYPDIMEAL, [F:FXD]DIME, [F:FXD]CODZONE, WDIMEMAX, WNDIME, WSUFFIXE, WSCODESUFF)
            Else
                I = func SUBFXM.TRTDIME(GTYPDIMEAL, num$([F:FXD]DIME), [F:FXD]CODZONE, WDIMEMAX, WNDIME, WSUFFIXE, WSCODESUFF)
            Endif
            If WSUFFIXE <>""
               WCODZONE += WSUFFIXE
            Endif
# V5 <> V6 _________________________________________
            If [F:FXD]DPRPLN  > 0
                WCODZONE -= "(" + num$(mess([F:FXD]DPRPLN, GML_NPLAN, 1)) + ")"
            Endif
            Call DESI_VALZONE([F:FXM]OBJMVT, [F:FXM]TYPMVT, [F:AMZ]NOLIB, WTYPTYP, WCODTYP, [F:FXD]CODZONE, [F:FXD]VALZONE, WMSK, WDESIVAL)# FQ91070
            Call ECR_TRACE(func AFNC.MES5(mess(26, GML_IMPFXD, 1), WCODZONE, [F:FXD]VALZONE, "", "", "") - WDESIVAL, 0) From GESECRAN
        Endif
    Next
End

# FQ91070
#** recherche la désignation de la valeur d'1 champ paramétré
#*
#*
#* @param POBJET
#* @param PTYPMVT
#* @param PNUMMENU    n° de menu (si...)
#* @param PTYPTYP     type de données (numérique)
#* @param PCODTYP     type de données (alpha)
#* @param PCODZONE    champ
#* @param PVALZONE    valeur
#* @param PMSK        masque
#* @param RDESI       désignation trouvée
#*!
Subprog DESI_VALZONE(POBJET, PTYPMVT, PNUMMENU, PTYPTYP, PCODTYP, PCODZONE, PVALZONE, PMSK, RDESI)
Value Integer POBJET, PTYPMVT, PNUMMENU, PTYPTYP
Value Char PCODTYP(), PCODZONE(), PVALZONE(), PMSK()

Variable Char RDESI()

Local Char WABRMSK(10), WDESI(30)
Local Decimal WTYPTYP
Local Date WDT
Local Integer WERR, WDIMEMAX

    RDESI = ""

    If POBJET = GFXM_IMMOS and PTYPMVT = GFXM_SPLIT and PCODZONE = GCODE_REPART
        PNUMMENU = 1
#    Else
#        WCODTYP= func SUBFXM.LIRTYPMSK(POBJET, PTYPMVT,
#&         PCODZONE, PDPRPLN, WDIMEMAX, WTYPTYP,
#&         WDESIZONE, WABRMSK)
    Endif

    If PNUMMENU
        RDESI  = "->" - mess(val(PVALZONE), PNUMMENU, 1)
        RDESI -= "(" + mess(15, 7, 1) - num$(PNUMMENU) + ")"
    Elsif PTYPTYP = 8
        WDT = func SUBFXM.CSTRDATE(PVALZONE, WERR)
        If WERR = 0
            RDESI = "->" - format$("D:" + GFMDAT4, WDT)
        Endif
    Elsif PCODTYP = "ADI"
        Read [AMP]CODPAR = 1; PMSK; PCODZONE; "ADI"
        If fstat = 0
            Call LECTEXTRA(WDESI, "ATABDIV", "LNGDES", [F:AMP]VALPAR, PVALZONE) From ATEXTRA
            RDESI = "->" - WDESI - "(ATABDIV =" - [F:AMP]VALPAR + ")"
        Endif
    Else
#        If [F:ATY]OBJLIEN <> ""
#            Call OBJET([F:ATY]OBJLIEN, VALEUR, "") From GOBJET
#        Endif
    Endif

End
#** trt itf pour les immos (imputation ou sortie)
#*
#*
#* @param POBJMVT
#* @param PTYPMVT
#* @param RNBERREURS
#*!
Subprog PGM_IMMOS(POBJMVT, PTYPMVT, RNBERREURS)
Value Decimal POBJMVT, PTYPMVT
Variable Integer RNBERREURS

    Local Integer RETOUR, SVERRTRACE
    Local Char WCODWIN(30), WTRTMAM(30), WTRTALIMMSK(30), WTRTGENERE(30)

    Call REFFXM(POBJMVT, PTYPMVT, WCODWIN, WTRTMAM, WTRTALIMMSK, GABVMSKMAM, WTRTGENERE) From SUBFXM
    # lire le bien
#    Read [F:FASS]FAS0 = [F:FXM]REF1MVT

    Gosub DEFVAR From =WTRTGENERE

    # appel du M A M
    # Paramètres
    # 1° : action métier demandée
    # 2° : traitement contenant l'alimentation du masque de saisie ($ALIM_MASK)
    # 3° : code retour (pb si action n'existe pas ou fct (massive))

    If [F:FXM]OBJMVT = GFXM_IMMOS and [F:FXM]TYPMVT = GFXM_IMPUT
        # var pour éviter de passer 2 fois ds ALIM_MASK (1 par TRTFASTRFC et 1 par TRTFASMTFC)
        Global Integer GFXIMPUT
        If clalev([F:CPY]) = 0
            Local File COMPANY [CPY]
        Endif
    Endif

    # CBO 20120209 FQ79571 : sortie d'1 composant
    GBCOMPOSANT = 0
    If [F:FXM]OBJMVT = GFXM_IMMOS and [F:FXM]TYPMVT = GFXM_SORTIE
        If [F:FASS]CMPSTA = GVML_SBCOMPO or [F:FASS]CMPSTA= GVML_SBCMPOA
            GBCOMPOSANT = 1

            GSVPRINCIPAL = [F:FASS]CMP
            # CBO 2012.05.02 FQ80044
            GSVORI = [F:FASS]CMPORI
            GSVSTATUT = [F:FASS]CMPSTA

            [F:FASS]CMPORI = [F:FASS]CMP
            [F:FASS]CMP = ""
            [F:FASS]CMPSTA = GVML_SBAUTON
            Rewrite [FASS]
            If fstat
                GBCOMPOSANT = 0
                [F:FXM]DESRJTMVT = func AFNC.MES5(mess(16, GML_IMPFXD, 1), [F:FXM]REF1MVT, "", "", "", "")
                GERRALIMCHP = [F:FXM]DESRJTMVT
#            [F:FXM]DESRJTMVT = "Echec en Maj de" - [F:FXM]REF1MVT
                [F:FXM]TRACE = GTRACE
                GERR = 1
                If dim(G_MAJOK) <= 0
                    Global Integer G_MAJOK
                Endif
                G_MAJOK = G_NON
                GFXDNBERR += 1
                Call CPTERENDU(RETOUR, RNBERREURS)
                Call KILL_GLO_SILTRT() From TRCPROCOM
                End
            Endif
        Endif
    Endif

    SVERRTRACE = GERRTRACE
    Call LAUNCH_SILTRT(WTRTMAM, WTRTALIMMSK, RETOUR) From TRCPROCOM

    If [F:FXM]OBJMVT = GFXM_IMMOS and [F:FXM]TYPMVT = GFXM_IMPUT
        Kill GFXIMPUT
    Endif

    If GSVNBERREURS <> GFXDNBERR
        If dim(G_MAJOK) <= 0
            Global Integer G_MAJOK
        Endif
        G_MAJOK = G_NON

    Endif
    If GERRTRACE <> SVERRTRACE
        If dim(G_MAJOK) <= 0
            Global Integer G_MAJOK
        Endif
        G_MAJOK = G_NON
        GFXDNBERR += 1

    Endif
    Call CPTERENDU(RETOUR, RNBERREURS)
    Call KILL_GLO_SILTRT() From TRCPROCOM

End

#** trt itf pour les éléments physiques (sortie)
#*
#*
#* @param POBJMVT
#* @param PTYPMVT
#* @param RNBERREURS
#*!
Subprog PGM_PHY(POBJMVT, PTYPMVT, RNBERREURS)
Value Decimal POBJMVT, PTYPMVT
Variable Integer RNBERREURS

    Local Integer RETOUR, SVERRTRACE
    Local Char WCODWIN(30), WTRTMAM(30), WTRTALIMMSK(30), WTRTGENERE(30)

    Call REFFXM(POBJMVT, PTYPMVT, WCODWIN, WTRTMAM, WTRTALIMMSK, GABVMSKMAM, WTRTGENERE) From SUBFXM
    # lire le bien
#    Read [PHY]PHY0 = [F:FXM]REF1MVT

    Gosub DEFVAR From =WTRTGENERE

    # appel du M A M
    # Paramètres
    # 1° : action métier demandée
    # 2° : traitement contenant l'alimentation du masque de saisie ($ALIM_MASK)
    # 3° : code retour (pb si action n'existe pas ou fct (massive))
    SVERRTRACE = GERRTRACE
    Call LAUNCH_SILTRT(WTRTMAM, WTRTALIMMSK, RETOUR) From TRCPROCOM
    If GSVNBERREURS <> GFXDNBERR
        If dim(G_MAJOK) <= 0
            Global Integer G_MAJOK
        Endif
        G_MAJOK = G_NON

    Endif
    If GERRTRACE <> SVERRTRACE
        If dim(G_MAJOK) <= 0
            Global Integer G_MAJOK
        Endif
        G_MAJOK = G_NON
        GFXDNBERR += 1

    Endif


    Call CPTERENDU(RETOUR, RNBERREURS)
    Call KILL_GLO_SILTRT() From TRCPROCOM

End


Subprog DEB_TRACE()

    Local Char WLIB(30)
    Call OUVRE_TRACE("Intégration de mouvements") From LECFIC

    # FQ87753
    Call ECR_TRACE("", 0) From GESECRAN
    # FQ87753
    # vérifier si l'utilisateur a les droits au site
    If (GUSRFCY(1) <> "" and GUSRFCY(1) <> "\")
    Call ECR_TRACE(mess(2, 72, 1) - ":" - GUSER - ":" - mess(34, 7786, 1), 0) From GESECRAN
    Call ECR_TRACE("->" - mess(35, 7786, 1), 0) From GESECRAN
    Else
    Call ECR_TRACE(mess(2, 72, 1) - ":" - GUSER, 0) From GESECRAN
    Endif

    Call ECR_TRACE("", 0) From GESECRAN
    Call MESSOUI_TRACE([M:FXT]SIMULATION, "SIMULATION")
    Call MESSOUI_TRACE([M:FXT]ARCHIVE, "ARCHIVE")
    Call MESSOUI_TRACE([M:FXT]TRACEDET, "TRACEDET")

    Call ECR_TRACE("", 0) From GESECRAN
    Call MESSOUI_TRACE([M:FXT]TRTFXD, "TRTFXD")
    Call MESSOUI_TRACE([M:FXT]TRTLAY, "TRTLAY")
    Call MESSOUI_TRACE([M:FXT]TRTPHY, "TRTPHY")

    Call ECR_TRACE("", 0) From GESECRAN
    If [M:FXT]CPYTOUS = G_OUI
        Call LIBCHPATZ(GLANGUE, "FXDINT", "CPYTOUS", WLIB)
        Call ECR_TRACE(WLIB - ":" - mess([M:FXT]CPYTOUS, 1, 1), 0) From GESECRAN
    Elsif [M:FXT]CPY <> ""
        Call LIBCHPATZ(GLANGUE, "FXDINT", "CPY", WLIB)
        Call ECR_TRACE(WLIB - ":" - [M:FXT]CPY, 0) From GESECRAN
    Endif

    If [M:FXT]FCYTOUS = G_OUI
        Call LIBCHPATZ(GLANGUE, "FXDINT", "FCYTOUS", WLIB)
        Call ECR_TRACE(WLIB - ":" - mess([M:FXT]FCYTOUS, 1, 1), 0) From GESECRAN
    Elsif [M:FXT]FCY <> ""
        Call LIBCHPATZ(GLANGUE, "FXDINT", "FCY", WLIB)
        Call ECR_TRACE(WLIB - ":" - [M:FXT]FCY, 0) From GESECRAN
    Endif

    Call ECR_TRACE("", 0) From GESECRAN
    Call MESSOUI_TRACE([M:FXT]MVTSORTIE, "MVTSORTIE")
    Call MESSOUI_TRACE([M:FXT]MVTTRF, "MVTTRF")
    Call MESSOUI_TRACE([M:FXT]MVTIMPUT, "MVTIMPUT")
    Call MESSOUI_TRACE([M:FXT]MVTMODIF, "MVTMODIF")
    Call MESSOUI_TRACE([M:FXT]MVTSPLIT, "MVTSPLIT") # FQ91070

    If [M:FXT]REF1 <> "" or [M:FXT]REF2 <> ""
        Call LIBCHPATZ(GLANGUE, "FXDINT", "REF1", WLIB)
        Call ECR_TRACE(WLIB - ":" - [M:FXT]REF1 - "/" - [M:FXT]REF2, 0) From GESECRAN
    Endif

    Call ECR_TRACE("", 0) From GESECRAN
    #FQ91070
#    Call LIBCHPATZ(GLANGUE, "FXDMVT3", "CH1", WLIB)
    Call ECR_TRACE(mess(42, GML_IMPFXD, 1) - ":" - GFMTDATTXT, 0) From GESECRAN
#    Call LIBCHPATZ(GLANGUE, "FXDMVT3", "CH2", WLIB)

    Call ECR_TRACE(mess(43, GML_IMPFXD, 1) - ":" - GFMTDEC, 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN

End


#** Désignation d'un champ
#*
#*
#* @param PLANGUE
#* @param PMASQUE
#* @param PCHAMP
#* @param RLIBELLE
#*!
Subprog LIBCHPATZ(PLANGUE, PMASQUE, PCHAMP, RLIBELLE)
Value Char PLANGUE, PMASQUE, PCHAMP
Variable Char RLIBELLE

    Read [AMZ]CODE = PMASQUE ; PCHAMP
    If fstat
        RLIBELLE = ""
    Else
        Read [ATX]NUMERO =PLANGUE ; [F:AMZ]INTIT
        RLIBELLE = [F:ATX]TEXTE
    Endif
End

#** Pour l'entête de CR
#*
#*
#* @param PCHAMP
#* @param PCODECHP
#*!
Subprog MESSOUI_TRACE(PCHAMP, PCODECHP)
Value Integer PCHAMP
Value Char PCODECHP

    Local Char WLIB(30)
    If PCHAMP = G_OUI
        Call LIBCHPATZ(GLANGUE, "FXDINT", PCODECHP, WLIB)
        Call ECR_TRACE(WLIB - ":" - mess(PCHAMP, 1, 1), 0) From GESECRAN
    Endif
End

#** CR d'un mouvement (hors modification et éclatement)
#*
#*
#* @param PRETOUR
#* @param RNBERREUR
#*!
Subprog CPTERENDU(PRETOUR, RNBERREUR)
Value Integer PRETOUR
Variable Integer RNBERREUR

    Local Char WRES(80)
    Local Integer I, J, DIMGTOBJ_REF, WINDERR, WDEJAERR

    DIMGTOBJREF = dim(GT_OBJ_REF)
    If dim(G_MAJOK) <= 0
        Global Integer G_MAJOK

        G_MAJOK = G_NON
        G_MAJOK = 0
    Endif
    WRES =  "-->"
    WINDERR = 0

    If G_MAJOK <> G_NON
        For  I=1 To dim(GT_LIS_ERR)
            If GT_LIS_ERR(I-1) <> ""
                G_MAJOK = G_NON
                Break
            Endif
        Next  I
    Endif

    If G_MAJOK = G_NON or GERRALIMCHP <> ""
        WRES -= mess(30, GML_IMPFXD, 1)
        WINDERR = 1
        G_MAJOK = G_NON
    Else
        WRES -= mess(29, GML_IMPFXD, 1)
    Endif

    If dim(GT_LIS_ERR) > 0
        If [F:FXM]DESRJTMVT = "" and GT_LIS_ERR(0) <> ""
            [F:FXM]DESRJTMVT = GT_LIS_ERR(0)
        Endif
    Endif

    GOK=0
    If GERRALIMCHP <> ""
        Call ECR_TRACE("   " + GERRALIMCHP, 1) From GESECRAN
    Endif

    WDEJAERR = 0
    For  I=1 To dim(GT_LIS_ERR)
        If GT_LIS_ERR(I-1) <> ""
            If WDEJAERR = 0
                RNBERREUR += 1
            Endif
            LIGNE = GT_LIS_ERR(I-1)
            If WDEJAERR
                Call  ECR_TRACE("  " + LIGNE, 0) From GESECRAN
            Else
                Call  ECR_TRACE("  " + LIGNE, 1) From GESECRAN
            Endif
            WDEJAERR = 1
        Endif
    Next  I

    If GCRDET = G_OUI
        Call CRDET()
    Endif
    Call ECR_TRACE(WRES, 0) From GESECRAN
End


#** CR d'un mouvement de modification
#*
#*
Subprog CPTERENDUMOD()
Local Integer IJK


    Local Char WRES(80)

    WRES =  "-->"
    IJK = 0
    If GERR
        WRES -= mess(30, GML_IMPFXD, 1)
        IJK = 1
    Else
        WRES -=  mess(29, GML_IMPFXD, 1)
    Endif

    If GERR
        Call ECR_TRACE([F:FXM]DESRJTMVT, 1) From GESECRAN
        GERR = 1
        GFXDNBERR += 1
    Endif
    If GCRDET = 2
        Call CRDET()
    Endif

    Call ECR_TRACE(WRES, 0) From GESECRAN
End

