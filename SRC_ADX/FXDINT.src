Subprog AM_TRTTOUS(VALEUR)
Variable Integer VALEUR
    [M:FXT]TRTFXD = VALEUR
    [M:FXT]TRTLAY = VALEUR
    # CBO 20120227 FQ80394
# FQ100398/13
#    If GPHY = G_OUI
#        [M:FXT]TRTPHY = VALEUR
#    Endif
    Affzo [M:FXT]TRTFXD, TRTLAY, TRTPHY
    If VALEUR = G_OUI
        Diszo [M:FXT]TRTFXD, TRTLAY, TRTPHY
        # FQ91070
        Raz [M:FXT]REF1, REF2
        Affzo [M:FXT]REF1, REF2
    Else
        # CBO 20120227 FQ80394
        Actzo [M:FXT]TRTFXD, TRTLAY
# FQ100398/13
#        If GPHY = G_OUI
#            Actzo [M:FXT]TRTPHY
#        Endif
    Endif

End

Subprog AM_MVTTOUS(VALEUR)
Variable Integer VALEUR
    [M:FXT]MVTSORTIE = VALEUR
    [M:FXT]MVTTRF = VALEUR
    [M:FXT]MVTIMPUT = VALEUR
    [M:FXT]MVTMODIF = VALEUR
    [M:FXT]MVTSPLIT = VALEUR # FQ91070
    Affzo [M:FXT]MVTSORTIE, MVTTRF, MVTIMPUT, MVTMODIF, MVTSPLIT# FQ91070
    If VALEUR = G_OUI
        Diszo [M:FXT]MVTSORTIE, MVTTRF, MVTIMPUT, MVTMODIF, MVTSPLIT # FQ91070
    Else
        Actzo [M:FXT]MVTSORTIE, MVTTRF, MVTIMPUT, MVTMODIF,MVTSPLIT # FQ91070
    Endif

End
