Subprog C_FCY(VALEUR)
#----------------------------------------------------------#
# Contrôle site : Obligatoire si flag tous sites non coché #
#----------------------------------------------------------#
Variable Char    VALEUR()
    If [M]FCYTOUS <> 2 & VALEUR = ""
        GMESSAGE = mess(28, GML_IMPFXD, 1)
#        GMESSAGE = "Site obligatoire"
        mkstat = 1
        End
    Endif
End

######################################################################################

Subprog AM_FCY(VALEUR)
#---------------------#
# Après modif du site #
#---------------------#
Variable Char    VALEUR()

#FQ87753
#Call CONTUSR([M]CPY,[M]FCY) From CPTSUB

    #FQ87753 : fct venant des contrôles du type de données
    If mkstat
        GMESSAGE = mess(63, 133, 1)
    Else
        Affzo [M:FXT]CPY, FCY
    Endif
End

