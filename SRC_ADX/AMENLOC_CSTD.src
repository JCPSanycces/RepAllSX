#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure AMENLOC

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD_AFTER"            : Gosub AREAD_AFTER
      When "AINSERT_AFTER"          : Gosub AINSERT_AFTER
      When "AINSERT_CONTROL_BEFORE" : Gosub AINSERT_CONTROL_BEFORE
      When "AUPDATE_AFTER"          : Gosub AUPDATE_AFTER
      When "AUPDATE_CONTROL_BEFORE" : Gosub AUPDATE_CONTROL_BEFORE
      When "ADELETE_AFTER"          : Gosub ADELETE_AFTER
    Endcase
  When "AST"
    Case [L]AEVENT
      When "ADELLINE"               : Gosub AST_ADELLINE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "MENLOC"                         : Gosub MENLOC
  When "MENLOCAL"                       : Gosub MENLOCAL
  When "MAXI"                           : Gosub MAXI
  When "NONTRA"                         : Gosub NONTRA
  When "AST.LANNUM"                     : Gosub AST_LANNUM
  When "AST.CODE"                       : Gosub AST_CODE
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



###############################################################################################
$AST_ADELLINE
Local Integer MY_STATUS
[L]MY_STATUS = fmet this.ASETATTRIBUTE("CODE","$isMandatory","false")
Return

######################################################################################################
$MENLOC
Case [L]ARULE
  When "CONTROL"                      : Gosub MENLOC_CONTROL
  When "PROPAGATE"                    : Gosub MENLOC_PROPAGATE
  When Default:
Endcase
Return

$MENLOC_CONTROL
  Local Char MESSAGE(50)
  If this.MENLOC = 200 | this.MENLOC<1 | this.MENLOC>29999
    [L]ASTATUS = fmet this.ASETERROR("MENLOC",mess(126,143,1)-num$(this.MENLOC),[V]CST_AERROR)
    Return
  Endif

  # ASTATUS returned as OK, warning or error
  [L]ASTATUS =  func ACD_TOOL.PLAGE(num$(this.MENLOC),2,MESSAGE)
  If [L]ASTATUS <> [V]CST_AOK
    [L]ASTATUS = fmet this.ASETERROR("MENLOC",MESSAGE-num$(this.MENLOC),[L]ASTATUS)
    Return
  Endif
Return


$MENLOC_PROPAGATE
Gosub MENLOC_DEPENDENCY             # MENLOCAL flat dependent on MENLOC value
Gosub MENLOCAL_DEPENDENCIES
Return

#######################################################################################################
$MENLOCAL
Case [L]ARULE
  When "PROPAGATE"                        : Gosub MENLOCAL_PROPAGATE
Endcase
Return

$MENLOCAL_PROPAGATE
Gosub MENLOCAL_DEPENDENCIES
Return

$MENLOCAL_DEPENDENCIES
Gosub MINI_DEPENDENCY
Gosub MAXI_DEPENDENCY
Gosub AUZMOD_DEPENDENCY
Gosub LONG_DEPENDENCY
Return

#####################################################################################################
$MENLOC_DEPENDENCY
If this.MENLOC>=100 & this.MENLOC<=200
  this.MENLOCAL = [V]CST_ANO
Endif
Return

#####################################################################################################
$MINI_DEPENDENCY
If this.MENLOCAL<>[V]CST_AYES
  this.MINI=AVOID.AINT
Endif
Return

#####################################################################################################
$MAXI_DEPENDENCY
If this.MENLOCAL<>[V]CST_AYES
  this.MAXI=AVOID.AINT
Endif
Return

#####################################################################################################
$AUZMOD_DEPENDENCY
If this.MENLOCAL<>[V]CST_AYES
  this.AUZMOD=[V]CST_ANO
Endif
Return

#####################################################################################################
$LONG_DEPENDENCY
If this.MENLOCAL<>[V]CST_AYES
  this.LONG=AVOID.AINT
Endif
Return

############################################################################################################
$MAXI
Case [L]ARULE
  When "CONTROL"                          : Gosub MAXI_CONTROL
  When Default:
Endcase
Return

$MAXI_CONTROL
If this.MAXI<this.MINI
  [L]ASTATUS = fmet this.ASETERROR("MAXI",mess(8,133,1)-num$(this.MAXI),[V]CST_AERROR)
Endif
Return

$AST_LANNUM
Case [L]ARULE
  When "INIT"                             : Gosub AST_LANNUM_INIT
  When "CONTROL"                          : Gosub AST_LANNUM_CONTROL
Endcase
Return

$AST_CODE
Case [L]ARULE
  When "INIT"                             : Gosub AST_CODE_INIT
Endcase
Return

#######################################################################################################
$NONTRA
Case [L]ARULE
  When "PROPAGATE"                        : Gosub NONTRA_PROPAGATE
Endcase
Return

$NONTRA_PROPAGATE
Gosub NONTRA_DEPENDENCY
Return

$NONTRA_DEPENDENCY
If this.NONTRA=[V]CST_AYES
  this.FORCE=[V]CST_ANO
Endif
Return

############################################################################################################
$AREAD_AFTER
Local Integer ILINE, MY_STATUS
Local Char TITLIB(250) : Raz [L]TITLIB
Local Instance MY_APLSTD Using C_APLSTD

# Get menu title
MY_APLSTD = NewInstance C_APLSTD AllocGroup null
If this.MENLOCAL = [V]CST_AYES
  If this.MENLOC<100
    [L]MY_STATUS = fmet MY_APLSTD.AREAD(0,this.MENLOC,this.ACTX.LAN)
  Elsif this.MENLOC>200
    [L]MY_STATUS = fmet MY_APLSTD.AREAD(200,this.MENLOC-200,this.ACTX.LAN)
  Endif
Else
  [L]MY_STATUS = fmet MY_APLSTD.AREAD(this.MENLOC,0,this.ACTX.LAN)
Endif

If [L]MY_STATUS = [V]CST_AOK
  this.TITCHP = MY_APLSTD.LANMES
Endif

# Get local menu codes
If this.MENLOCAL = [V]CST_AYES
  [L]MY_STATUS = fmet MY_APLSTD.AREAD(this.MENLOC,0,this.ACTX.LAN)
  If [L]MY_STATUS = [V]CST_AOK
    [L]TITLIB = MY_APLSTD.LANMES
  Endif
Endif

FreeGroup MY_APLSTD

# Set menu code on each detail line
For ILINE=1 To maxtab(this.AST)
  If this.MENLOCAL = [V]CST_AYES
    this.AST(ILINE).CODE = mid$([L]TITLIB,ILINE,1)
    [L]MY_STATUS = fmet this.AST(ILINE).ASETATTRIBUTE("CODE","$isMandatory","true")
  Else
    [L]MY_STATUS = fmet this.AST(ILINE).ASETATTRIBUTE("CODE","$isMandatory","false")
  Endif
  this.AST(ILINE).ASTALIN = [V]CST_ALL                 # [V]CST_ALL = Line has not been modified
Next

Return

############################################################################################################
$AINSERT_CONTROL_BEFORE
  Gosub MENLOC_DEPENDENCY
  Gosub MENLOC_CONSISTENCY
Return


############################################################################################################
$AINSERT_AFTER
Gosub AMENLOC_AUPDATE
Return

############################################################################################################
$AUPDATE_CONTROL_BEFORE
Gosub MENLOC_CONSISTENCY
Return

############################################################################################################
$AUPDATE_AFTER
Gosub AMENLOC_AUPDATE
Return

############################################################################################################
$AMENLOC_AUPDATE

Gosub SET_TBLAN                                              # Languages to be updated - menu 101

Gosub TITLE_UPDATE                                           # Update local menu/message title
If [L]ASTATUS<[V]CST_AERROR : Gosub MESSAGE_UPDATE : Endif   # Update message lines
If [L]ASTATUS<[V]CST_AERROR : Gosub CODES_UPDATE   : Endif   # Update codes lines

Return

############################################################################################################
$TITLE_UPDATE
Local Integer ILINE,MY_STATUS,CHAPTER,LANNUM
Local Char TITLIB(250) : Raz TITLIB
Local Instance MY_APLSTD Using C_APLSTD

# Main Title update or insert
If this.snapshot.TITCHP <> this.TITCHP
  If this.MENLOCAL = [V]CST_AYES
    If this.MENLOC<100
      [L]CHAPTER=0
      [L]LANNUM=this.MENLOC
    Elsif this.MENLOC>200
      [L]CHAPTER=200
      [L]LANNUM=this.MENLOC-200
    Else
      [L]CHAPTER = this.MENLOC
      [L]LANNUM = 0
    Endif
  Else
    [L]CHAPTER=this.MENLOC
    [L]LANNUM=0
  Endif

  # Update local menu title of user's language
  MY_APLSTD = NewInstance C_APLSTD AllocGroup null
  [L]MY_STATUS = fmet MY_APLSTD.AREAD([L]CHAPTER,[L]LANNUM,this.ACTX.LAN)
  If [L]MY_STATUS = [V]CST_AOK
    MY_APLSTD.LANMES = this.TITCHP
    MY_APLSTD.LANORI = AVOID.ACHAR
    [L]ASTATUS = fmet MY_APLSTD.AUPDATE()
    If [L]ASTATUS<>[V]CST_AOK
      # Error during update
      [L]ASTATUS = fmet this.ASETERROR("APLSTD",mess(50,176,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]ASTATUS)
    Endif
  Else
  # Initialize Instance
    FreeGroup MY_APLSTD                                   # Remove error on read
    MY_APLSTD = NewInstance C_APLSTD AllocGroup null      # create new instance

    [L]ASTATUS = fmet MY_APLSTD.AINIT()
    If [L]ASTATUS=[V]CST_AOK
      MY_APLSTD.LANCHP = [L]CHAPTER
      MY_APLSTD.LANNUM = [L]LANNUM
      MY_APLSTD.LAN    = this.ACTX.LAN
      MY_APLSTD.LANORI = AVOID.ACHAR
      MY_APLSTD.LANMES = this.TITCHP
      [L]ASTATUS = fmet MY_APLSTD.AINSERT()
      If [L]ASTATUS<>[V]CST_AOK
        # Error creation
        [L]ASTATUS = fmet this.ASETERROR("APLSTD",mess(100,141,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]ASTATUS)
      Endif
    Else
      # Error upon table initialization
      [L]ASTATUS = fmet this.ASETERROR("APLSTD",mess(91,143,1)-"MY_APLSTD",[L]ASTATUS)
    Endif
  Endif
  FreeGroup MY_APLSTD
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

  # Loop thru languages to update title if title changed on user's language
  For ILINE=1 To NBLAN
    MY_APLSTD = NewInstance C_APLSTD AllocGroup null
    [L]MY_STATUS = fmet MY_APLSTD.AREAD([L]CHAPTER,[L]LANNUM,TBLAN(ILINE))
    If [L]MY_STATUS<>[V]CST_AOK
      FreeGroup MY_APLSTD                     # Remove error on read
      MY_APLSTD = NewInstance C_APLSTD AllocGroup null      # create new instance

      [L]MY_STATUS = fmet MY_APLSTD.AINIT
      [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
      If [L]MY_STATUS<>[V]CST_AOK
        # Error upon table initialization
        [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(91,143,1)-"MY_APLSTD",[L]MY_STATUS)
        Break
      Endif
      MY_APLSTD.LANCHP = [L]CHAPTER
      MY_APLSTD.LANNUM = [L]LANNUM
      MY_APLSTD.LAN    = TBLAN(ILINE)
      MY_APLSTD.LANORI = this.ACTX.LAN
      MY_APLSTD.LANMES = this.TITCHP
      [L]MY_STATUS = fmet MY_APLSTD.AINSERT()
      [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
      If [L]MY_STATUS<>[V]CST_AOK
        # Insert status
        [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(100,141,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]MY_STATUS)

      Endif
    Elsif [L]MY_STATUS=[V]CST_AOK & (MY_APLSTD.LANORI<>AVOID.ACHAR | this.FORCE=[V]CST_AYES)
      # this.force = force update of translated descriptions - set force variable
      MY_APLSTD.LANMES = this.TITCHP
      If this.NONTRA=[V]CST_AYES
        MY_APLSTD.LANORI = AVOID.ACHAR
      Else
        MY_APLSTD.LANORI = this.ACTX.LAN
      Endif
      [L]MY_STATUS = fmet MY_APLSTD.AUPDATE()
      [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
      If [L]MY_STATUS <> [V]CST_AOK
        # Error during update
        [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(50,176,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]MY_STATUS)
      Endif
    Endif
    FreeGroup MY_APLSTD
  Next ILINE
Endif
Return

##############################################################################################################
#**
#* Local menu codes update
#*!
$CODES_UPDATE
Local Integer MY_STATUS,ILINE,UPD : UPD=[V]CST_AFALSE
# Set codes to each local menu; applies to local menu=yes only
If this.MENLOCAL = [V]CST_AYES
  For ILINE = 1 To maxtab(this.AST)
    If find(this.AST(ILINE).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = [V]CST_AFALSE
      [L]TITLIB += this.AST(ILINE).CODE
    Endif
  Next

  MY_APLSTD = NewInstance C_APLSTD AllocGroup null
  [L]MY_STATUS = fmet MY_APLSTD.AREAD(this.MENLOC,0,this.ACTX.LAN)
  If [L]MY_STATUS = [V]CST_AOK
    If MY_APLSTD.LANMES <> [L]TITLIB
      MY_APLSTD.LANMES = [L]TITLIB
      [L]MY_STATUS = fmet MY_APLSTD.AUPDATE()
      [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
      If [L]MY_STATUS<>[V]CST_AOK
        # Error during update
        [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(50,176,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]MY_STATUS)
      Endif
      UPD=[V]CST_ATRUE
    Endif
  Else
    FreeGroup MY_APLSTD                     # Remove error on read
    MY_APLSTD = NewInstance C_APLSTD AllocGroup null      # create new instance

    [L]MY_STATUS = fmet MY_APLSTD.AINIT()
    [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
    If [L]MY_STATUS<>[V]CST_AOK
        # Error upon table initialization
        [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(91,143,1)-"MY_APLSTD",[L]MY_STATUS)
    Else
      MY_APLSTD.LANCHP = this.MENLOC
      MY_APLSTD.LAN    = this.ACTX.LAN
      MY_APLSTD.LANNUM = 0
      MY_APLSTD.LANMES = [L]TITLIB
      MY_APLSTD.LANORI = AVOID.ACHAR
      [L]MY_STATUS = fmet MY_APLSTD.AINSERT()
      [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
      If [L]MY_STATUS<>[V]CST_AOK
        # Error creation
        [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(100,141,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]MY_STATUS)
      Endif
      UPD=[V]CST_ATRUE
    Endif
  Endif
  FreeGroup MY_APLSTD

# Update all languages
  If UPD=[V]CST_ATRUE
    For NOLAN=1 To NBLAN
      MY_APLSTD = NewInstance C_APLSTD AllocGroup null
      [L]MY_STATUS = fmet MY_APLSTD.AREAD(this.MENLOC,0,[L]TBLAN(NOLAN))
      If [L]MY_STATUS = [V]CST_AOK
        If MY_APLSTD.LANORI<>AVOID.ACHAR | this.FORCE=[V]CST_AYES # Update when non-translated or force
          MY_APLSTD.LANMES = TITLIB
          If this.NONTRA=[V]CST_AYES
            MY_APLSTDLANORI  = AVOID.ACHAR
          Else
            MY_APLSTD.LANORI = this.ACTX.LAN
          Endif
          [L]MY_STATUS = fmet MY_APLSTD.AUPDATE()
          [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
          If [L]MY_STATUS<>[V]CST_AOK
            # Error during update
            [L]MY_STATUS=fmet this.ASETERROR("APLSTD",mess(50,176,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]MY_STATUS)
          Endif
        Endif
      Else
        FreeGroup MY_APLSTD                     # Remove error on read
        MY_APLSTD = NewInstance C_APLSTD AllocGroup null      # create new instance

        [L]MY_STATUS = fmet MY_APLSTD.AINIT
        [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
        If [L]MY_STATUS<>[V]CST_AOK
          # Error upon table initialization
          [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(91,143,1)-"MY_APLSTD",[L]MY_STATUS)
        Else
          MY_APLSTD.LANCHP = this.MENLOC
          MY_APLSTD.LANNUM = 0
          MY_APLSTD.LAN    = [L]TBLAN(NOLAN)
          MY_APLSTD.LANMES = [L]TITLIB
          If this.NONTRA=[V]CST_AYES
            MY_APLSTDLANORI  = AVOID.ACHAR
          Else
            MY_APLSTD.LANORI = this.ACTX.LAN
          Endif
          [L]MY_STATUS = fmet MY_APLSTD.AINSERT()
          [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
          If [L]MY_STATUS<>[V]CST_AOK
            # Status of insert
            [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(100,141,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]MY_STATUS)
          Endif
        Endif
      Endif
      FreeGroup MY_APLSTD
    Next ILINE
  Endif
Endif
Return

#####################################################################################################
#**
#* Update Menu/Message line translations for olanguages other than user's language - ref: 88823
#*!
$MESSAGE_UPDATE
Local Integer ILINE
# loop through all lines that are new, updated, or deleted
For ILINE=1 To maxtab(this.AST)
  # Force all lines not changed to be updated if 'Force updates' is set or if 'do not translate flag' changed
  If ((this.FORCE=[V]CST_AYES) | (this.snapshot.NONTRA <> this.NONTRA)) & this.AST(ILINE).ASTALIN = [V]CST_ALL
    this.AST(ILINE).ASTALIN=[V]CST_AUPD
  Endif
  If find(this.AST(ILINE).ASTALIN,[V]CST_ANEW,[V]CST_AUPD,[V]CST_ADEL)<>[V]CST_AFALSE ##??Check for deleted are still available
    For NOLAN=1 To NBLAN
      Case this.AST(ILINE).ASTALIN
        When [V]CST_ANEW          : Gosub APLSTD_MESSAGE_UPDATE
        When [V]CST_AUPD          : Gosub APLSTD_MESSAGE_UPDATE
        When [V]CST_ADEL          : Gosub APLSTD_MESSAGE_DELETE
      Endcase
    Next
  Endif
Next ILINE
Return

#######################################################################################################
#**
#* Remove deleted message lines
#*!
$APLSTD_MESSAGE_DELETE
Local Integer MY_STATUS
Local Instance MY_APLSTD Using C_APLSTD
MY_APLSTD = NewInstance C_APLSTD AllocGroup null
[L]MY_STATUS = fmet MY_APLSTD.AREAD(this.MENLOC,this.AST(ILINE).LANNUM,TBLAN(NOLAN))
[L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
If [L]MY_STATUS = [V]CST_AOK
  [L]MY_STATUS = fmet MY_APLSTD.ADELETE()
  [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
    If [L]MY_STATUS <> [V]CST_AOK
      # Error
      [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(6,123,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]MY_STATUS)
    Endif
 Endif
FreeGroup MY_APLSTD
Return

#####################################################################################################
#**
#* Update new or changed message lines
#*!
$APLSTD_MESSAGE_UPDATE
Local Integer MY_STATUS
Local Instance MY_APLSTD Using C_APLSTD
MY_APLSTD = NewInstance C_APLSTD AllocGroup null

[L]MY_STATUS = fmet MY_APLSTD.AREAD(this.MENLOC,this.AST(ILINE).LANNUM,TBLAN(NOLAN))
If [L]MY_STATUS <> [V]CST_AOK
  FreeGroup MY_APLSTD
  MY_APLSTD = NewInstance C_APLSTD AllocGroup null

  MY_APLSTD.LANCHP = this.MENLOC
  MY_APLSTD.LANNUM = this.AST(ILINE).LANNUM
  MY_APLSTD.LAN    = TBLAN(NOLAN)
  MY_APLSTD.LANMES = this.AST(ILINE).LANMES
  # clear original language if no translation is set to yes
  If this.NONTRA=[V]CST_AYES
    MY_APLSTD.LANORI = AVOID.ACHAR
  Else
    MY_APLSTD.LANORI = this.ACTX.LAN
  Endif
  [L]MY_STATUS = fmet MY_APLSTD.AINSERT()
  [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
  If [L]MY_STATUS<>[V]CST_AOK
    # Errpr
    [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(6,123,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]MY_STATUS)
  Endif
Elsif [L]MY_STATUS=[V]CST_AOK & (MY_APLSTD.LANORI<>AVOID.ACHAR | this.FORCE=[V]CST_AYES | this.NONTRA=[V]CST_AYES)
  # Incorporate update based on force...
  MY_APLSTD.LANMES = this.AST(ILINE).LANMES
  # clear original language if no translation is set to yes
  If this.NONTRA=[V]CST_AYES
    MY_APLSTD.LANORI = AVOID.ACHAR
  Else
    MY_APLSTD.LANORI = this.ACTX.LAN
  Endif
  [L]MY_STATUS = fmet MY_APLSTD.AUPDATE()
  [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
  If [L]MY_STATUS<>[V]CST_AOK
    # Message on insert
    [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(6,123,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]MY_STATUS)
  Endif
Endif
FreeGroup MY_APLSTD
Return

############################################################################################################
#**
#* Delete entire local menu and all languages translations (APLSTD) attached to local menu
#*!

$ADELETE_AFTER
Local Integer ILINE,NOLAN,MY_STATUS
Local Instance MY_APLSTD Using C_APLSTD

Local Integer CHAPTER,LANNUM

# Main title delete
  If this.MENLOCAL = [V]CST_AYES
    If this.MENLOC<100
      [L]CHAPTER=0
      [L]LANNUM=this.MENLOC
    Elsif this.MENLOC>200
      [L]CHAPTER=200
      [L]LANNUM=this.MENLOC-200
    Else
      [L]CHAPTER = this.MENLOC
      [L]LANNUM = 0
    Endif
  Else
    [L]CHAPTER=this.MENLOC
    [L]LANNUM=0
  Endif

  Gosub SET_TBLAN             # Languages to be updated according to menu 101

  # Delete local menu titles
  MY_APLSTD = NewInstance C_APLSTD AllocGroup null
  [L]MY_STATUS = fmet MY_APLSTD.AREAD([L]CHAPTER,[L]LANNUM,this.ACTX.LAN)
  If [L]MY_STATUS = [V]CST_AOK
    [L]MY_STATUS = fmet MY_APLSTD.ADELETE()
    [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
     If [L]MY_STATUS<>[V]CST_AOK
       # Error
       [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(6,123,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]MY_STATUS)
     Endif
  Endif
  FreeGroup MY_APLSTD

  For NOLAN=1 To NBLAN
    MY_APLSTD = NewInstance C_APLSTD AllocGroup null
    [L]MY_STATUS = fmet MY_APLSTD.AREAD([L]CHAPTER,[L]LANNUM,TBLAN(NOLAN))
    If [L]MY_STATUS = [V]CST_AOK
      [L]MY_STATUS = fmet MY_APLSTD.ADELETE()
      [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
      If [L]MY_STATUS<>[V]CST_AOK
        # Message on delete
        [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(6,123,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]MY_STATUS)
      Endif
    Endif
    FreeGroup MY_APLSTD
  Next

  # Delete local menu codes storage
  If this.MENLOCAL = [V]CST_AYES
    MY_APLSTD = NewInstance C_APLSTD AllocGroup null
    [L]MY_STATUS = fmet MY_APLSTD.AREAD(this.MENLOC,0,this.ACTX.LAN)
    If [L]MY_STATUS = [V]CST_AOK
      [L]MY_STATUS = fmet MY_APLSTD.ADELETE()
      [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
      If [L]MY_STATUS<>[V]CST_AOK
        [L]MY_STATUS = fmet this.ASETERROR("APLSTD","Unable to delete APLSTD"-"0"-num$(this.MENLOC),[L]MY_STATUS)
      Endif
    Endif
    FreeGroup MY_APLSTD

    For NOLAN=1 To NBLAN
      MY_APLSTD = NewInstance C_APLSTD AllocGroup null
      [L]MY_STATUS = fmet MY_APLSTD.AREAD(this.MENLOC,0,TBLAN(NOLAN))
      If [L]MY_STATUS=[V]CST_AOK
        [L]MY_STATUS = fmet MY_APLSTD.ADELETE()
        [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
        If [L]MY_STATUS<>[V]CST_AOK
          # Error
          [L]MY_STATUS = fmet this.ASETERROR("APLSTD",mess(6,123,1)-num$(MY_APLSTD.LANCHP)-num$(MY_APLSTD.LANNUM)-MY_APLSTD.LAN,[L]MY_STATUS)
        Endif
      Endif
      FreeGroup MY_APLSTD
    Next
Endif

  # Delete message lines for all languages
  For ILINE = 1 To maxtab(this.AST)
    For NOLAN=1 To NBLAN
      Gosub APLSTD_MESSAGE_DELETE
    Next NOLAN
  Next ILINE

Return

##########################################################################################
$AST_LANNUM_INIT
  this.LANNUM = max(this.APARENT.AST(1..maxtab(this.APARENT.AST)).LANNUM)+1
Return

$AST_LANNUM_CONTROL
Local Integer MY_STATUS
  If this.LANNUM<-9999 | this.LANNUM > 9999
    # Invalid value
    [L]MY_STATUS = fmet this.ASETERROR("LANNUM",mess(126,143,1)-num$(this.LANNUM),[V]CST_AERROR)
    [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
  Endif
Return

######################################################################################################
$AST_CODE_INIT
Local Integer MY_STATUS
If this.APARENT.MENLOCAL=[V]CST_AYES
  [L]MY_STATUS = fmet this.ASETATTRIBUTE("CODE","$isMandatory","true")
Else
  [L]MY_STATUS = fmet this.ASETATTRIBUTE("CODE","$isMandatory","false")
Endif
Return

############################################################################################################
# Tests if at least one line exists & lines are between min/max
$MENLOC_CONSISTENCY
Local Integer MY_STATUS, ILINE, CNT : Raz CNT
Local Shortint LINE_FOUND : LINE_FOUND = [V]CST_AFALSE

  For ILINE = 1 To maxtab(this.AST)
    If this.AST(ILINE)<>null
      If this.AST(ILINE).LANCHP = AVOID.AINT
        this.AST(ILINE).LANCHP = this.MENLOC
      Endif
      If this.AST(ILINE).LAN = AVOID.ACHAR
        this.AST(ILINE).LAN = this.ACTX.LAN
      Endif
      If find(this.AST(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=[V]CST_AFALSE
        [L]LINE_FOUND=[V]CST_ATRUE
        CNT+=1
        # Clear code if not local menu
        If this.MENLOCAL<>[V]CST_AYES
          If this.AST(ILINE).CODE<>AVOID.ACHAR
            this.AST(ILINE).CODE=AVOID.ACHAR
          Endif
          [L]MY_STATUS=fmet this.AST(ILINE).ASETATTRIBUTE("CODE","$isMandatory","false")
        Else            # Code required if local menu
          If this.AST(ILINE).CODE=AVOID.ACHAR
            [L]MY_STATUS=fmet this.AST(ILINE).ASETATTRIBUTE("CODE","$isMandatory","true")
          Endif
        Endif
      Endif
    Endif
  Next

  If [L]LINE_FOUND = [V]CST_AFALSE
    # There must be at least one line
    [L]MY_STATUS = fmet this.ASETERROR("AST",mess(178,123,1),[V]CST_AERROR)
    [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
  Endif

  If this.MINI <> 0 and this.MINI>CNT
    # Minimum number of descriptions
    [L]MY_STATUS = fmet this.ASETERROR("AST",mess(113,100,1)-num$(this.MINI),[V]CST_AERROR)
    [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
  Endif

  If this.MAXI <> 0 and this.MAXI<CNT
  # Maximum number of descriptions
    [L]MY_STATUS = fmet this.ASETERROR("AST",mess(112,100,1)-num$(this.MAXI),[V]CST_AERROR)
    [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
  Endif

  If this.MENLOC = 97 & CNT>99
    # Maximum number of descriptions
    [L]MY_STATUS = fmet this.ASETERROR("AST",mess(134,124,1)-num$(99),[V]CST_AERROR)
    [L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)
  Endif

  Gosub MENLOC_CONTROL
Return



#####################################################################################################
$SET_TBLAN
Local File APLSTD [AST7]
Local Char    TBLAN(GLONLAN)(1..50)
Local Integer NBLAN , NOLAN
Raz NBLAN , TBLAN
For [AST7]LAN(1) Where LAN<>"XXX" & LAN<>"" & LAN<>this.ACTX.LAN & LANCHP=101
 NBLAN += 1
 TBLAN(NBLAN) = [F:AST7]LAN
Next AST7
Return

###########################################################
Funprog TITMEN(DOSSIER,CHAPITRE,LANGUE,TITMEN)
Value Char DOSSIER
Value Integer CHAPITRE
Value Char LANGUE
Variable Char TITMEN
Local Integer MY_STATUS

[L]MY_STATUS = [V]CST_AERROR              # Initialize as error

If LANGUE<>AVOID.ACHAR
  If DOSSIER="" or DOSSIER=nomap
   Local File APLSTD  [ASTX]
   Local File AMENLOC [AMLX]
  Else
   Local File =DOSSIER+".APLSTD"  [ASTX]
   Local File =DOSSIER+".AMENLOC" [AMLX]
  Endif
  Read [AMLX]MENLOC=CHAPITRE
  If !fstat
   If [F:AMLX]MENLOCAL=2
    If CHAPITRE<100
     Read [ASTX]CLE = 0;CHAPITRE;LANGUE
    Else
     Read [ASTX]CLE = 200;CHAPITRE-200;LANGUE
    Endif
   Else
    Read [ASTX]CLE = CHAPITRE;0;LANGUE
   Endif
   If !fstat
    TITMEN = [F:ASTX]LANMES
    [L]MY_STATUS = [V]CST_AOK
   Endif
  Endif
Endif
End [L]MY_STATUS

###########################################################
Funprog TEXMEN(DOSSIER,CHAPITRE,NUM,LANGUE,TEXMEN)
Value Char DOSSIER
Value Integer CHAPITRE , NUM
Value Char LANGUE
Variable Char TEXMEN
Local Integer MY_STATUS

[L]MY_STATUS = [V]CST_AERROR              # Initialize as error

If LANGUE<>AVOID.ACHAR
  If DOSSIER="" or DOSSIER=nomap
   Local File APLSTD  [ASTX]
  Else
   Local File =DOSSIER+".APLSTD"  [ASTX]
  Endif
  Read [ASTX]CLE = CHAPITRE;NUM;LANGUE
  If !fstat
    TEXMEN = [F:ASTX]LANMES
    [L]MY_STATUS = [V]CST_AOK
  Endif
Endif
End [L]MY_STATUS

