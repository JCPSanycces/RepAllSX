########################################################################
#                                                                      #
#         TRAITEMENT de M.A.J. des STOCKS dans les VENTES              #
#                                                                      #
########################################################################
#                                                                      #
# Subprog SUP_SERIE (WTYP,WITM,WNUM,WLIN)                              #
#      Suppression des no de série                                     #
#                                                                      #
########################################################################

#-----------------------------------------------------------------------# 
# Suppression des no série                                              # 
# suite à suppression d'une ligne ou modif en - de la quantité          # 
#-----------------------------------------------------------------------# 
Subprog SUP_SERIE(WTYP,WITM,WNUM,WLIN) 

Value Shortint WTYP
Value Char     WITM
Value Char     WNUM
Value Integer  WLIN
  
If clalev ([F:STS]) <= 0 Local File STOSER [STS] Endif  

If find([F:ITM]SERMGTCOD,2,3)  
   Filter [STS] Where ITMREF=WITM & SDHTYP=WTYP & SDHNUM=WNUM & SDDLIN=WLIN
&               Order By Key STS2  
   For [STS] With Lock  
      If [F:ITM]SERMGTCOD = 3  
         Raz [F:STS]SDHTYP, [F:STS]SDHNUM, [F:STS]SDDLIN, [F:STS]ISSDAT, [F:STS]GUAENDDAT  
         Raz [F:STS]BPCNUM, [F:STS]BPAADD
         Rewrite [STS]  
      Else   
         Delete  [STS]  
      Endif      
      If fstat : GOK = 0 : Break : Endif     
   Next  
   Filter [STS]
   If GOK = 0 End Endif    
Endif  
  
End 
