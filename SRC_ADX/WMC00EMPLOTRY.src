Gosub TEST From WMCR_EMPLOTRY : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,REFNUM,NUMLIG)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# EMPLOTRY : EMPLOTRY
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet EMPLOTRY._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = EMPLOTRY.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(EMPLOTRY.ACTX.AFOLDER,nomap,"")>0
 Local File EMPLOTRY [TRY]
 Local File EMPLOTRY [AAA_]
Else
 Local File =EMPLOTRY.ACTX.AFOLDER+".EMPLOTRY" [TRY]
 Local File =EMPLOTRY.ACTX.AFOLDER+".EMPLOTRY" [AAA_]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [TRY] With
& [AAA_]TRY0 = REFNUM+NUMLIG
& As [LNK_]
Return

############################################################################################
### EMPLOTRY(WTRY)
############################################################################################
Funprog  _MAJSQL_EMPLOTRY(WTRY)
Variable Instance WTRY Using C_EMPLOTRY
Local Integer ASTATUS,A_I,A_J
Default File [F:TRY]
If WTRY.ASTALIN=[V]CST_ANEW
 Call INICRE(WTRY) From ASYRSUB
 SetInstance [F:TRY] With WTRY
 Write [F:TRY]
 If fstat
  Call FSTA("TRY",WTRY,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WTRY.updTick = [F:TRY]updTick
Elsif WTRY.ASTALIN=[V]CST_ALL or WTRY.ASTALIN=[V]CST_AUPD
 Call INIUPD(WTRY) From ASYRSUB
 SetInstance [F:TRY] With WTRY
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WTRY,"EMPLOTRY")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:TRY]TRY0 = [F:TRY]REFNUM;[F:TRY]NUMLIG
 If fstat
  Call FSTA("TRY",WTRY,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WTRY.updTick = [F:TRY]updTick
Elsif WTRY.ASTALIN=[V]CST_ADEL
 SetInstance [F:TRY] With WTRY
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WTRY,"EMPLOTRY")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:TRY]TRY0 = [F:TRY]REFNUM;[F:TRY]NUMLIG
 If fstat
  Call FSTA("TRY",WTRY,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK



