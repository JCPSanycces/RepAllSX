#<AdxTL>@(#)3.0.0.0 $Revision$
########################################################################################################################
#
# CALCUL ABELX3 :
# =============
#
# Outils de diagnostic pendant le calcul. Débug et routines de contrôle de cohérence des données.
#
# @ver        1.0.0
# @date       29/11/2006
# @user       GBO
# @modif      29/11/2006
#
# Liste des sous-programmes :
# -------------------------
# 
# Liste des fonctions :
# -------------------
#
# Liste des routines :
# ------------------
#
# $DEF_BRKPTLST
# $KILL_BRKPTLIST
# $DEBUG_DEF_VAR
# $DEBUG_KILL_VAR
# $DEBUG_INIT_BRKPOINT
# $DEBUG_INIT_BY_ATB
# $DEBUG_LST_BRKPT
# $DEBUG_SET_CF
# $DEBUG_VISU_MSK
#
########################################################################################################################
# Modifications :
# -------------
# 
# - XXX - JJ.MM.AAAA - Fq nnnnn - Commentaire
########################################################################################################################
End

#=======================================
# Liste des points d'entrée utilisables
# dans les traitements de calcul :
# Cette liste sert de base à la liste
# de sélection de la fonction
# GESCDG.
#=======================================
$DEF_BRKPTLST

 Local  Integer L_NBBRKPT : L_NBBRKPT=9
 Global Char    GLSTBRKPNT(20)(1..L_NBBRKPT)
 Global Char    GLSTBRKTRT(20)(1..L_NBBRKPT)
 Global Integer GLSTBRKNUM(1..L_NBBRKPT)
 Global Char    GLSTBRKDES(200)(1..L_NBBRKPT)

 GLSTBRKNUM(1)=0
 GLSTBRKPNT(1)="NOCOMMIT"
 GLSTBRKTRT(1)=""
 GLSTBRKDES(1)="Pas de mis à jour des plans d'amortissement"

 GLSTBRKNUM(2)=1
 GLSTBRKPNT(2)="AFFTRACE1"
 GLSTBRKTRT(2)=""
 GLSTBRKDES(2)="Affichage trace du calcul"

 GLSTBRKNUM(3)=2
 GLSTBRKPNT(3)="AFFTRACE2"
 GLSTBRKTRT(3)=""
 GLSTBRKDES(3)="Affichage trace technique"

 GLSTBRKNUM(4)=3
 GLSTBRKPNT(4)="BEFCALCURPLN"
 GLSTBRKTRT(4)="GLOBI1"
 GLSTBRKDES(4)="Avant Calcul Plan Courant"

 GLSTBRKNUM(5)=4
 GLSTBRKPNT(5)="AFTCALCURPLN"
 GLSTBRKTRT(5)="GLOBI1"
 GLSTBRKDES(5)="Après calcul Plan Courant"

 GLSTBRKNUM(6)=5
 GLSTBRKPNT(6)="BEFUPDCURPLN"
 GLSTBRKTRT(6)="GLOBI0"
 GLSTBRKDES(6)="Avant mise à jour (après point d'entrée éventuel)"

 GLSTBRKNUM(7)=6
 GLSTBRKPNT(7)="AFTLEGDER"
 GLSTBRKTRT(7)="GLOBI2"
 GLSTBRKDES(7)="Après évaluation dérogatoire (Comptable)"

 GLSTBRKNUM(8)=7
 GLSTBRKPNT(8)="AFTLEGRFI"
 GLSTBRKTRT(8)="GLOBI2"
 GLSTBRKDES(8)="Après évaluation réintégration fiscale (Fiscal)"

 GLSTBRKNUM(9)=8
 GLSTBRKPNT(9)="AFTLNKPLN"
 GLSTBRKTRT(9)="GLOBI2"
 GLSTBRKDES(9)="Après évaluation lien entre plan (Maître)"

Return

#=======================================
# Suppression des globales utilisées par
# SUBCDG
#=======================================
$KILL_BRKPTLIST
 If dim(GLSTBRKPNT)>0 : Kill GLSTBRKPNT : Endif
 If dim(GLSTBRKTRT)>0 : Kill GLSTBRKTRT : Endif
 If dim(GLSTBRKNUM)>0 : Kill GLSTBRKNUM : Endif
 If dim(GLSTBRKDES)>0 : Kill GLSTBRKDES : Endif
Return

#=======================================
# Definition des variables nécessaires
# au débug du calcul
#=======================================
$DEBUG_DEF_VAR

 # Globales à positionner au début du calcul

 Global Integer PDBGPLAN 
 Global Char    PDBGMSK

 # Globales à positionner dans le traitement appelant à l'endroit du point d'arrêt

 Global Char    PBKPOINTNAM                # Nom du point d'arrêt 
#Global Char    PBKPOINTTRT                # Traitement dans lequel est positionné le point d'arrêt

 # Nombre de points d'arrêts à charger

 FICHIER=filpath("FIL","CALCDBG","fde",nomap)
 If filinfo(FICHIER,0) < 0 : Return : Endif 

 Local  Integer NBBRKPOINT
 If !clalev([F:CDG]) : Local File CALCDBG [CDG] : Endif  
 Filter [CDG] Where (USR=GUSER | USR="")
 NBBRKPOINT=rowcount([F:CDG])
 Filter [CDG]

 If !NBBRKPOINT : Return : Endif

 # Liste des points d'arrêt à gérer

 Global Char    PBKPOINTLST(20)(1..NBBRKPOINT)     # Liste des points d'arrêt
 Global Char    PBKPOINTTRT(20)(1..NBBRKPOINT)     # Traitement dans lequel se situe le point d'arrêt
 Global Char    PBKPOINTDES(80)(1..NBBRKPOINT)     # Commentaire point d'arrêt
 Global Integer PBKPOINTFLG(1..NBBRKPOINT)         # Flag activation du point d'arrêt
 Global Integer PBKPOINTPLN(1..NBBRKPOINT)         # Plan à afficher

 # Initialisation des points d'arrêts

 Gosub DEBUG_INIT_BRKPOINT

Return

#=======================================
# suppression des variables nécessaires
# au débug du calcul
#=======================================
$DEBUG_KILL_VAR
 If dim(PDBGPLAN)>0    : Kill PDBGPLAN    : Endif
 If dim(PDBGMSK)>0     : Kill PDBGMSK     : Endif
 If dim(PBKPOINTLST)>0 : Kill PBKPOINTLST : Endif
 If dim(PBKPOINTTRT)>0 : Kill PBKPOINTTRT : Endif
 If dim(PBKPOINTDES)>0 : Kill PBKPOINTDES : Endif
 If dim(PBKPOINTFLG)>0 : Kill PBKPOINTFLG : Endif
 If dim(PBKPOINTNAM)>0 : Kill PBKPOINTNAM : Endif
Return

#=======================================
# Initilisation des points d'arrêt
#=======================================
$DEBUG_INIT_BRKPOINT
 Gosub DEBUG_INIT_BY_ATB
Return

#=======================================
# Initialisation par la table CALCDBG
#=======================================
$DEBUG_INIT_BY_ATB

 If !clalev([F:CDG]) : Local File CALCDBG [CDG] : Endif
 Filter [CDG] Where USR=GUSER
 
 Local Integer I_BRKPT 
 
 For [CDG] 
  I_BRKPT+=1
  PBKPOINTLST(I_BRKPT) = [F:CDG]BRKPTNAM
  PBKPOINTTRT(I_BRKPT) = [F:CDG]BRKPTTRT
  PBKPOINTFLG(I_BRKPT) = [F:CDG]BRKPTFLG
  PBKPOINTPLN(I_BRKPT) = [F:CDG]BRKPTPLN
  PBKPOINTDES(I_BRKPT) = [F:CDG]BRKPTDES
 Next
 Filter [CDG]

Return

#=======================================
# Visualisation d'un masque calcul
#=======================================
$DEBUG_LST_BRKPT
 If !(dim(PBKPOINTLST)>0) : Return : Endif
 If GTRACE=""
  Call OUVRE_TRACE("Liste des points d'entrée du calcul") From LECFIC   
  Local Integer LOCALTRACE
 Endif
 Call ECR_TRACE("============================================",0) From GESECRAN 
 Call ECR_TRACE("LISTE DES POINTS D'ENTREE DEFINIS",0)            From GESECRAN 
 Call ECR_TRACE("============================================",0) From GESECRAN 
 Local Integer I_BKP
 Local Char    LIGNE(110)
 For I_BKP=1 To dim(PBKPOINTLST)
  LIGNE = PBKPOINTLST(I_BKP)+space$(30-len(PBKPOINTLST(I_BKP)))
  LIGNE+= mess(PBKPOINTPLN(I_BKP),301,1)+space$(30-len(left$(mess(PBKPOINTPLN(I_BKP),301,1),30)))
  LIGNE+= "Actif ?"-mess(PBKPOINTFLG(I_BKP),1,1)
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Next I_BKP
 Call ECR_TRACE("============================================",0) From GESECRAN 
 If GTRACE<>"" & dim(LOCALTRACE)>0
  Call LEC_TRACE() From LECFIC
 Endif
Return

#=======================================
# Positionnement des paramètres de DEBUG
#=======================================
$DEBUG_SET_CF
Return

#=======================================
# Visualisation d'un masque calcul
#=======================================
$DEBUG_VISU_MSK

 #> Si le paramètre DEBUG n'est pas activé pour le dossier, on sort

 If !GDEBUG=G_OUI : Return : Endif

 #> Si les globales n'existent pas (Utilisateur autre que celui ayant paramétré les points d'entrée on sort)
 If dim(PBKPOINTLST)<0 : Return : Endif

 #> Si le point d'entrée n'exsite pas ou n'est pas actif on sort

 Local Integer I_BRKPOINT : I_BRKPOINT = find(PBKPOINTNAM,PBKPOINTLST)
 If I_BRKPOINT
  If PBKPOINTFLG(I_BRKPOINT)=G_NON : Return : Endif
 Else
  Return
 Endif

 #> Si demande de debug sur un plan en particulier et que le plan en cours de traitement n'est pas le même, on sort

 If PBKPOINTPLN(I_BRKPOINT)<>G301AUC & PDBGPLAN<>PBKPOINTPLN(I_BRKPOINT) : Return : Endif

 #> Affichage de la fenêtre

 Local Integer OK
 Local Char    WINTITLE

 If !clalev([M:CAL0]) : Local Mask CAL0   [CAL0] : Endif : Raz [M:CAL0]
 If !clalev([M:PLN])  : Local Mask CALDEP [PLN]  : Endif : Raz [M:PLN]
 #Masques onglets
 

 If PDBGMSK="CURPLN"
  [M:PLN]=[M:DEP]
 Endif

 If PDBGMSK="" & PDBGPLAN<>0
  Case PDBGPLAN
    When G301CPT  : Transmask [M:PCPT] To [M:PLN]
    When G301FIS  : Transmask [M:PFIS] To [M:PLN] 
    When G301MIN  : Transmask [M:PMIN] To [M:PLN] 
    When G301ORI  : Transmask [M:PORI] To [M:PLN]              
    When G301R76  : Transmask [M:PR76] To [M:PLN]  
    When G301IAS  : Transmask [M:PIAS] To [M:PLN] 
    When G301TEC  : Transmask [M:PTEC] To [M:PLN] 
    When G301RET  : Transmask [M:PRET] To [M:PLN] 
    When G301SUB  : Transmask [M:PSUB] To [M:PLN] 
    When G301LI1  : Transmask [M:PLI1] To [M:PLN] 
    When G301LI2  : Transmask [M:PLI2] To [M:PLN]  
    When G301LI3  : Transmask [M:PLI3] To [M:PLN]  
    When G301LI4  : Transmask [M:PLI4] To [M:PLN]  
    When G301LI5  : Transmask [M:PLI5] To [M:PLN] 
    When G301LI6  : Transmask [M:PLI6] To [M:PLN]            
  Endcase
 Endif

 [M:CAL0]BRKNAM = PBKPOINTNAM
 [M:CAL0]TRT    = PBKPOINTTRT(find (PBKPOINTNAM,PBKPOINTLST))
 [M:CAL0]CPY    = [M:PLN]CPY(0) 
 [M:CAL0]AASREF = [M:PLN]AASREF(0) 
 [M:CAL0]DES(0) = "Plan"-mess([M:PLN]DPRPLN(0),301,1)
 [M:CAL0]DES(1) = PBKPOINTDES(find (PBKPOINTNAM,PBKPOINTLST))
 
 WINTITLE = PBKPOINTNAM

 Call DIALWIN(OK,WINTITLE,"CALDEP") From GESECRAN : # Contrôle calcul
 Close Local Mask [PLN]

Return




