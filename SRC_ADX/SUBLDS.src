#<AdxTL>@(#)1.0.0.0 $Revision$

Call OBJET ("LDS", GBIDC1, GBIDC2) From GOBJET
End

##########################################################################################################
# Gestion des leads                 Module CRM aout 2006
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "OUVRE"        : Gosub OUVRE
    When "FERME"        : Gosub FERME
    When "SETBOUT"      : Gosub SETBOUT
    When "AVANTBOUT"    : Gosub AVANTBOUT
    When "EXEBOUT"      : Gosub EXEBOUT        # FGR 22/10/2010 : X3SUIVI69097 : c'est mieux ici
    When "LIENS"        : Gosub LIENS
    When "RAZCRE"       : Gosub RAZCRE
    When "RAZDUP"       : Gosub RAZDUP
    When "INICRE"       : Gosub INICRE
    When "INIMOD"       : Gosub INIMOD
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "AVANT_MODFIC" : Gosub AVANT_MODFIC
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "CREATION"     : Gosub CREATION
    When "MODIF"        : Gosub MODIF
    When "ANNULE"       : Gosub ANNULE
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "AP_ANNULE"    : Gosub AP_ANNULE
    When "FILTRE"       : Gosub FILTRE
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When "STATUT"       : Gosub STATUT
    When "AVANT_CHOI"   : Gosub AVANT_CHOI
    When "AB_CREATION"  : Gosub AB_CREATION
    When "AB_MODIF"     : Gosub AB_MODIF
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
#Local Integer WLDSBPATYP  # FGR 14/05/2009 : X3SUIVI55146 : Déclaration de la variable en LOCAL pas en GLOBAL
Global Integer WLDSBPATYP  # FGR 17/08/2009 : Obligé de le mettre en Global. $ANNULE est appelé depuis un S/P

  If !clalev([F:AIN2]) : Local File CONTACTCRM [AIN2] : Endif
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  WLDSBPATYP = 6    # FGR 24/07/2008 : X3SUIVI48267 : Type Lead pour BPADDRESS
  If GCRMSYNC = 2 and GCRMSYNCCOR = 2 Then
    Local Mask LDS0 [PS0S]
    Local Mask LDS2 [PS2S]
    Local Mask BPALDS [PBPA] # FGR 24/07/2008 : X3SUIVI48267 gestion des adresses dans BPADDRESS
    Local Mask LDS3 [PS3S]
    Local Mask LDS5 [PS5S]
    Raz [PS0S]
    Raz [PS2S]
    Raz [PBPA] # FGR 24/07/2008 : X3SUIVI48267 gestion des adresses dans BPADDRESS
    Raz [PS3S]
    Raz [PS5S]
    Global Integer GIBLDSCREFROMCOR
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Local Char LTI_LEAD
Local Char LTI_DISCAL
Local Char LTI_TRANSF

  LTI_LEAD = 'GAU_CHE'+num$(find('LDS',OBJLIS(1..10)))   : # Leads "en cours"
  LTI_DISCAL = 'GAU_CHE'+num$(find('LD1',OBJLIS(1..10))) : # Leads disqualifiés
  LTI_TRANSF = 'GAU_CHE'+num$(find('LD2',OBJLIS(1..10))) : # Leads transformés (client ou prospect)
Return

##########################################################################################################
$FERME
  Kill WLDSBPATYP  # FGR 17/08/2009 : Obligé de le mettre en Global. $ANNULE est appelé depuis un S/P
  If GCRMSYNC = 2 and GCRMSYNCCOR = 2 Then
    Close Local Mask [PS0S]
    Close Local Mask [PS2S]
    Close Local Mask [PBPA] # FGR 24/07/2008 : X3SUIVI48267 gestion des adresses dans BPADDRESS
    Close Local Mask [PS3S]
    Close Local Mask [PS5S]
    If dim(GIBLDSCREFROMCOR) > 0 Then
      Kill GIBLDSCREFROMCOR
    Endif
  Endif
Return

##########################################################################################################
$FILTRE
  Default File [LDS]
  #                         Lead                 Disqualifié
  FILTSUP += "[F:LDS]PSTTYP=2 and [F:LDS]PSTSTA<>1"
Return

##########################################################################################################
$FILGAUCHE
  If dim(LTI_DISCAL) = -1 Then
    Return
  Endif
  If currbox = LTI_DISCAL Then
    # Leads disqualifiés
    #                                                               Lead                Disqualifié
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "[F:LDS]PSTTYP=2 and [F:LDS]PSTSTA=1", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "LDS") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Elsif currbox = LTI_TRANSF Then
    # Leads transformés en prospect ou client
    #                                                               Autre (plus un lead quoi)
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "[F:LDS]PSTTYP=1", "&") From GOBJSUB
    #FILGAUSUP(1) = "and [F:AIN]CNTNUM=[F:LDS]PSTNUM"
    #FILGAUSUP(2) = "and [F:CNT]CCNCRM=[F:LDS]PSTNUM and [F:CNT]BPATYP=1 and [F:BPR]BPRNUM=[F:CNT]BPANUM"
    # FLORENT ICI : afficher dans la liste si c'est un Prospect ou un Client (attention ça peut être les deux).
    #               Dans ce cas, c'est Client que j'afficherais. Plus la référence du tiers.
    #               Voir dans TRTBPCRM, étiquette $CREATE_FROM_LDS comment ça se fait
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "LDS") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Endif
Return

##########################################################################################################
$SETBOUT
  #Menu Actions   Module Action Co
  #  )    Planifier Rendez-vous
  #  (    Planifier Appel
  #  £    Planifier Tâche
  #  }    Enregistrer Rendez-vous
  #  {    Enregistrer Appel
  #  ~    Enregistrer Tâche
  #  D    Passer en interlocuteur      (FGR 10/09/2008 : Option supprimée)
  #  I    Transformer en interlocuteur (FGR 10/09/2008 : Option supprimée)
  #  P    Relier à un tiers
  #  G    Transformer en tiers
  # FGR 30/04/2008 : X3SUIVI46542
  #Bouton
  #  O    Prospect      (fonctionnement idem G)
  #  V    Client        (fonctionnement idem G) FGR 15/05/2008 : X3SUIVI46542
  #  U    Interlocuteur (fonctionnement idem I) FGR 15/05/2008 : X3SUIVI46542
  If [F:LDS]PSTTYP = 1 Then
    # S'il a été transformé en tiers on n'a plus le droit à rien (ni modification, ni suppression)
    Call VIREBOUT (CHAINE,"MAPOVU") From GOBJET
    CHMEN += ""
  Else
    # Sinon, c'est la situation qui permet de décider
    If REP = "" Then
      CHMEN += "{}~()£"
    Endif
    If REP = "" Then
      If [M:LDS0]PSTSTA = 1 or [M:LDS0]PSTSTA = 2 Then
        # FGR 27/03/2008 : X3SUIVI46543 : Toute "transformation" est interdite pour ces statuts
        # 1=Disqualifié 2=En attente
        CHMEN += ""
        Call VIREBOUT (CHAINE,"OVU") From GOBJET
      Else
        #CHMEN += "DIPG"
        CHMEN += "PG"
      Endif
    Else
      Call VIREBOUT (CHAINE,"OVU") From GOBJET
    Endif
    If REP = "" Then
      CHMEN += ""
    Endif
    #
    If func SUBLDSB.GET_IND_ADD_PRINC() = 0 Then
      Call VIREBOUT (CHAINE,"P") From GOBJET
    Endif
  Endif
  #----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
  Gosub SET_BOUT_SPE From GSAISIE
Return

##########################################################################################################
$AVANTBOUT
  [M:LDS0]NVGCOD = BOUT
  Case BOUT
    When ")"
      # Planifier Rendez-vous
      GBCRMFLGNEW = 1
    When "("
      # Planifier Appel
      GBCRMFLGNEW = 1
    When "£"
      # Planifier tache
      GBCRMFLGNEW = 1
    When "}"
      # Enregistrer Rendez-vous
      GBCRMFLGNEW = 1
    When "{"
      # Enregistrer Appel
      GBCRMFLGNEW = 1
    When "~"
      # Enregistrer tache
      GBCRMFLGNEW = 1
    #When "I"
    #  # générer interlocuteur
    #  GBCRMFLGUPD = 1
    When "P"
      # Relier à un tiers
      Local Integer IRNGADP  # FGR 15/12/2009 : X3SUIVI60908

      IRNGADP = func SUBLDSB.GET_IND_ADD_PRINC()  # FGR 15/12/2009 : X3SUIVI60908
    # FGR 22/10/2010 : X3SUIVI69097 : rien à faire ici (début)
    #When "O"
    #  # Transformer en Prospect
    #  # FGR 15/05/2008 : X3SUIVI46542
    #  ## Action GOBJETC1
    #  Local Char  PARMSK(250)(1..20), SAVACT(20)
    #  #
    #  GBCRMFLGNEW = 1
    #  SAVACT = GACTION
    #  GACTION = "GOBJETC1"
    #  Call OBJET_CHAR(GBIDC3, "BPP", "") From GOBJET
    #  GACTION = SAVACT
    #When "V"
    #  # Transformer en Client
    #  # FGR 15/05/2008 : X3SUIVI46542
    #  ## Action GOBJETC1
    #  Local Char  PARMSK(250)(1..20), SAVACT(20)
    #  #
    #  GBCRMFLGNEW = 1
    #  SAVACT = GACTION
    #  GACTION = "GOBJETC1"
    #  Call OBJET_CHAR(GBIDC3, "BPC", "") From GOBJET
    #  GACTION = SAVACT
    # FGR 22/10/2010 : X3SUIVI69097 : (fin)
  Endcase
Return

##########################################################################################################
$EXEBOUT
  # FGR 22/10/2010 : X3SUIVI69097 : c'est mieux ici
  Case BOUT
    When "O"
      # Transformer en Prospect
      # FGR 15/05/2008 : X3SUIVI46542
      ## Action GOBJETC1
      Local Char  PARMSK(250)(1..20), SAVACT(20)
      #
      GBCRMFLGNEW = 1
      SAVACT = GACTION
      GACTION = "GOBJETC1"
      Call OBJET_CHAR(GBIDC3, "BPP", "") From GOBJET
      GACTION = SAVACT
      Gosub RELIT From GOBJSUB  # FGR 22/10/2010 : X3SUIVI69097
      GBCRMFLGNEW = 0 # Issue X3-55198 - 2018-02-26 by USA : to fix the issue
    When "V"
      # Transformer en Client
      # FGR 15/05/2008 : X3SUIVI46542
      ## Action GOBJETC1
      Local Char  PARMSK(250)(1..20), SAVACT(20)
      #
      GBCRMFLGNEW = 1
      SAVACT = GACTION
      GACTION = "GOBJETC1"
      Call OBJET_CHAR(GBIDC3, "BPC", "") From GOBJET
      GACTION = SAVACT
      Gosub RELIT From GOBJSUB  # FGR 22/10/2010 : X3SUIVI69097
      GBCRMFLGNEW = 0 # Issue X3-55198 - 2018-02-26 by USA : to fix the issue
  Endcase
Return

##########################################################################################################
$STATUT
  Case BOUT
    When "P"
      # Relier à un tiers
      Gosub VERIFRETOUR From SUBLDSB
      #retour générer interlocuteur
      REPONSE = GSTARAF
      Gosub RAFFRAICHIR From GOBJSUB
      Gosub SETBOUT From GOBJSUB
    When "G", "O", 'V'
      # Transformer en Tiers, Clients ou Prospect
      # FGR 30/04/2008 : X3SUIVI46542 ajout "O : Prospect"
      # FGR 15/05/2008 : X3SUIVI46542 ajout "V : Client"
      Gosub VERIFRETOUR From SUBLDSB
      #retour générer interlocuteur
      REPONSE = GSTARAF
      Gosub RAFFRAICHIR From GOBJSUB
      Gosub SETBOUT From GOBJSUB
    #When "D"
    #  # Passer en interlocuteur
    #  Gosub TRANSAIN From SUBLDSB
    #  Gosub VERIFRETOUR From SUBLDSB
    #  #retour générer interlocuteur
    #  REPONSE = GSTARAF
    #  Gosub RAFFRAICHIR From GOBJSUB
    #  Gosub SETBOUT From GOBJSUB
    #When "I"
    #  # Transformer en interlocuteur
    #  Gosub VERIFRETOUR From SUBLDSB
    #  #retour générer interlocuteur
    #  REPONSE = GSTARAF
    #  Gosub RAFFRAICHIR From GOBJSUB
    #  Gosub SETBOUT From GOBJSUB
  Endcase
Return

##########################################################################################################
$AVANT_CHOI
  If GBCRMFLGNEW = 1 Then
    REPONSE = GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    GBCRMFLGNEW = 0
  Endif
Return

##########################################################################################################
$RAZCREDUP
# LTA.sn - 93205
If func AFNC.ACTIV("LTA")
  If dim([M:BPAL]XADRVAL)>0
    Chgfmt [M:BPAL]XADRVAL With "-LA:1"
    Chgfmt [M:BPAL]VALADR  With "-K:10X"
  Endif
Endif
# LTA.en - 93205
  # FGR 13/05/2009 : X3SUIVI551134
  #Origine
  [M:LDS5]CREDAT = date$
  [M:LDS5]CREUSR = GUSER
  Read [AUS]CODUSR=GUSER
  If fstat Then
    [M:LDS5]FULNAMUSR = GUSER
  Else
    [M:LDS5]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  [M:LDS5]PSTORIOBC = ""
  [M:LDS5]PSTORI = 1
  [M:LDS5]PSTORITXT = ""
  Diszo [M:LDS5]PSTORIVCR
  Diszo [M:LDS5]PSTORI # Issue SAM119357 - 2016-12-05 by FGR : now not [M:LDS5]PSTORITXT
  If !GIMPORT Then
    [M:LDS5]PSTORITYP = 1
  Else
    If GSYNCOUTLOOK = 0 Then
      [M:LDS5]PSTORITYP = 2
    Else
      [M:LDS5]PSTORITYP = 3
    Endif
  Endif
  [M:LDS5]PSTORILIB = mess([M:LDS5]PSTORITYP,3037,1)
  [M:LDS0]CNTTTL = 1
  [M:LDS0]PSTSTA = 2
  [M:LDS0]PSTITR = 2
  [M:LDS0]CNTTYP = 2
  [M:LDS0]PSTTYP = 2
  # FGR 11/04/2008 : X3SUIVI46506 affectation représentant par défaut
  Gosub INIT_PSTREP
  If GCRMSYNC = 2 and GCRMSYNCCOR = 2 Then
    Raz [PS0S]
    Raz [PS2S]
    Raz [PBPA]  # FGR 24/07/2008 : X3SUIVI48267 gestion des adresses dans BPADDRESS
    Raz [PS3S]
    Raz [PS5S]
  Endif
Return

##########################################################################################################
$RAZCRE
  [F:BPA]BPATYP = WLDSBPATYP # FGR 24/07/2008 : X3SUIVI48267 gestion des adresses dans BPADDRESS
  Gosub RAZCREDUP  # FGR 13/05/2009 : X3SUIVI551134
  If GCRMSYNC = 2 and GCRMSYNCCOR = 2 Then
    If !GIMPORT Then
      If GPILNAV > 1 Then
        If GNAVIG(GPILNAV-1) = "GESCOR" Then
          If GBCRMFLGNEW = 1 Then
            GIBLDSCREFROMCOR = 1
            Gosub CRELDSFROMCOR From SUBLDSB
          Endif
        Endif
      Endif
    Endif
  Endif
  Affzo [M:LDS0]1-99
Return

##########################################################################################################
$RAZDUP
  Gosub RAZCREDUP  # FGR 13/05/2009 : X3SUIVI551134
  Affzo [M:LDS5]1-99
  Diszo [M:LDS5]PSTORIVCR
  Diszo [M:LDS5]PSTORI   # Issue SAM119357 - 2016-12-05 by FGR : now not [M:LDS5]PSTORITXT
Return

##########################################################################################################
$INIT_PSTREP
  # FGR 11/04/2008 : X3SUIVI46506 affectation représentant par défaut
  If GCRMDEFREP = 2 Then
    If [M:LDS0]PSTREP = "" Then
      Read [REP]REP1=GUSER
      If !fstat Then
        [M:LDS0]PSTREP = [F:REP]REPNUM
      Endif
    Endif
  Endif
Return

##########################################################################################################
$INICRE
  Gosub INILDS  # FGR 24/07/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
  #---------------------------------------------------#
  # code SUBAIN
  If [M:LDS0]PSTNUM = "" Then
    Repeat
      [F:AIN]CNTNUM = func SUBAIN.COD([C]INTERLOC)
      [C]INTERLOC += 1
      Read [AIN2]AIN0=[F:AIN]CNTNUM
    Until fstat
    [F:LDS]PSTNUM = [F:AIN]CNTNUM
    [M:LDS0]PSTNUM = [F:LDS]PSTNUM
  Endif
  #---------------------------------------------------#
  Gosub INICLOB From SUBLDSB
Return

##########################################################################################################
$VERIF_CRE_MOD
  GOK = 1
  Gosub VERIFORI From SUBLDSB
  If GERR <> 0 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If GERR <> 0 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
  If GERR <> 0 Then
    Return
  Endif
Return

##########################################################################################################
$INIMOD
  Gosub INILDS  # FGR 24/07/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
  Gosub INICLOB From SUBLDSB
Return

##########################################################################################################
$INILDS
Local Integer WI

  # FGR 24/07/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
  # Alimentation du code adresse par défaut, du lead par défaut
  WI = find (2, [M:BPAL]BPAADDFLG (0..[M:BPAL]NBADR-1))
  If WI <> 0 Then
    [F:LDS]BPAADD = [M:BPAL]CODADR(WI-1)
  Endif
Return

##########################################################################################################
$CREMODBPA
  # FGR 24/07/2008 : X3SUIVI48267 : Adresses dans BPADDRESS
  Default Mask [BPAL]
  Call CREBPA(WLDSBPATYP, [M:LDS0]PSTNUM) From TRTBPA
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$CREATION
  Gosub CRE_AIN From SUBLDSB
  If GOK < 1 Then
    Return
  Endif
  #
  # FGR 24/07/2008 : X3SUIVI48267 : Adresses dans BPADDRESS
  Gosub CREMODBPA
  If GOK < 1 Then
    Return
  Endif
  #
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBLDSB
  If GOK < 1 Then
    Return
  Endif
  #
  If GCRMSYNC = 2 and GCRMSYNCCOR = 2 Then
    If GIBLDSCREFROMCOR = 1 Then
      Gosub UPDCORORIGINE From SUBLDSB
      GIBLDSCREFROMCOR = 0
    Endif
    If GOK < 1 Then
      Return
    Endif
    Gosub GEREAFFECTLDSCOR From SUBLDSB
    If GOK < 1 Then
      Return
    Endif
    Gosub GEREMODIFLDSCOR From SUBLDSB
    If GOK < 1 Then
      Return
    Endif
  Endif
  # Maj des statistiques
  Call VALSTA("LDS", 1) From SUBPS2
Return

##########################################################################################################
$AVANT_MODFIC
Return

##########################################################################################################
$MODIF
  Gosub MODIF_AIN From SUBLDSB
  If GOK < 1 Then
    Return
  Endif
  #
  # FGR 24/07/2008 : X3SUIVI48267 : Adresses dans BPADDRESS
  Gosub CREMODBPA
  If GOK < 1 Then
    Return
  Endif
  #
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBLDSB
  If GOK < 1 Then
    Return
  Endif
  #
  If GCRMSYNC = 2 and GCRMSYNCCOR = 2 Then
    Gosub GEREAFFECTLDSCOR From SUBLDSB
    If GOK < 1 Then
      Return
    Endif
    Gosub GEREMODIFLDSCOR From SUBLDSB
    If GOK < 1 Then
      Return
    Endif
  Endif
  # Maj des statistiques
  Call VALSTA("LDS",-1) From SUBPS2
  Call VALSTA("LDS",1) From SUBPS2
Return

##########################################################################################################
$ANNULE
  #suppression dans CONTACTCRM
  Gosub ANNULE_AIN From SUBLDSB
  If GOK < 1 Then
    Return
  Endif
  #Suppression des clobs
  Gosub DELCLOB From SUBLDSB
  If GOK < 1 Then
    Return
  Endif
  # FGR 24/07/2008 : X3SUIVI48267 : Adresses dans BPADDRESS
  Call ANNBPA(WLDSBPATYP, [M:LDS0]PSTNUM) From TRTBPA
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("LDS",-1) From SUBPS2
Return

##########################################################################################################
$APRES_CRE
  Affzo [LDS0]PSTNUM
  Diszo [M:LDS5]PSTORIVCR
  Diszo [M:LDS5]PSTORI  # Issue SAM119357 - 2016-12-05 by FGR : now not [M:LDS5]PSTORITXT
  If GCRMSYNC = 2 and GCRMSYNCCOR = 2 Then
    # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
    #[M:PS0S] = [M:LDS0]
    #[M:PS2S] = [M:LDS2]
    #[M:PBPA] = [M:BPAL]  # FGR 24/07/2008 : X3SUIVI48267 gestion des adresses dans BPADDRESS
    #[M:PS3S] = [M:LDS3]
    #[M:PS5S] = [M:LDS5]
    Raz [M:PS0S] : Transmask [M:LDS0] To [M:PS0S]
    Raz [M:PS2S] : Transmask [M:LDS2] To [M:PS2S]
    Raz [M:PBPA] : Transmask [M:BPAL] To [M:PBPA]
    Raz [M:PS3S] : Transmask [M:LDS3] To [M:PS3S]
    Raz [M:PS5S] : Transmask [M:LDS5] To [M:PS5S]
    # Issue X3-35454 - 2017-05-03 by FGR : END
  Endif
Return

##########################################################################################################
$APRES_MOD
  Diszo [M:LDS5]PSTORIVCR
  Diszo [M:LDS5]PSTORI  # Issue SAM119357 - 2016-12-05 by FGR : now not [M:LDS5]PSTORITXT
  If GCRMSYNC = 2 and GCRMSYNCCOR = 2 Then
    # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
    #[M:PS0S] = [M:LDS0]
    #[M:PS2S] = [M:LDS2]
    #[M:PBPA] = [M:BPAL]  # FGR 24/07/2008 : X3SUIVI48267 gestion des adresses dans BPADDRESS
    #[M:PS3S] = [M:LDS3]
    #[M:PS5S] = [M:LDS5]
    Raz [M:PS0S] : Transmask [M:LDS0] To [M:PS0S]
    Raz [M:PS2S] : Transmask [M:LDS2] To [M:PS2S]
    Raz [M:PBPA] : Transmask [M:BPAL] To [M:PBPA]
    Raz [M:PS3S] : Transmask [M:LDS3] To [M:PS3S]
    Raz [M:PS5S] : Transmask [M:LDS5] To [M:PS5S]
    # Issue X3-35454 - 2017-05-03 by FGR : END
  Endif
  If dim([M:BPAL]VALADR) > 0  #LTA.sn
    Actzo [M:BPAL]VALADR
  Endif                       #LTA.en
Return

##########################################################################################################
$AP_ANNULE
Return

##########################################################################################################
$LIENS
  Call AM_FNC([M:LDS2]FNC)
  Gosub LIENS_AIN From SUBLDSB
  Gosub LOADCLOB From SUBLDSB
  # FGR 24/07/2008 : X3SUIVI48267 : Gestion de l'onglet Adresses
  Default Mask [BPAL]
  Call CHARG_BPA(WLDSBPATYP, [M:LDS0]PSTNUM, [F:LDS]BPAADD) From TRTBPA
  For MA = 0 To NBMASK
    If AMA(MA) Then
      Gosub SETMASK From="WGO"+GABREV
    Endif
  Next MA
  #---------------------------------------------------#
  #  Origine
  #---------------------------------------------------#
  If [M:LDS5]CREUSR <> "" Then
    Read [AUS]CODUSR=[M:LDS5]CREUSR
    If fstat = 0 Then
      [M:LDS5]FULNAMUSR=[F:AUS]NOMUSR
    Endif
    Affzo [M:LDS5]FULNAMUSR
  Endif
  [M:LDS5]PSTORILIB = mess([M:LDS5]PSTORITYP,3037,1)
  If [M:LDS5]PSTORI = 1 Then
    [M:LDS5]PSTORITXT = ""
  Else
    #[M:LDS5]PSTORITXT = mess([M:LDS5]PSTORI,2992,1)       # FGR 18/05/2015 : X3SUIVI108178
    [M:LDS5]PSTORITXT = mess([M:LDS5]PSTORI,3042,1)        # FGR 18/05/2015 : X3SUIVI108178
  Endif
  #Définition du type de pièce
  Gosub DEFOBJORI From SUBLDSB
  Diszo [M:LDS5]PSTORIVCR
  Diszo [M:LDS5]PSTORI   # Issue SAM119357 - 2016-12-05 by FGR : now not [M:LDS5]PSTORITXT
  If GCRMSYNC = 2 and GCRMSYNCCOR = 2 Then
    # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
    #[M:PS0S] = [M:LDS0]
    #[M:PS2S] = [M:LDS2]
    #[M:PBPA] = [M:BPAL]  # FGR 24/07/2008 : X3SUIVI48267 gestion des adresses dans BPADDRESS
    #[M:PS3S] = [M:LDS3]
    #[M:PS5S] = [M:LDS5]
    Raz [M:PS0S] : Transmask [M:LDS0] To [M:PS0S]
    Raz [M:PS2S] : Transmask [M:LDS2] To [M:PS2S]
    Raz [M:PBPA] : Transmask [M:BPAL] To [M:PBPA]
    Raz [M:PS3S] : Transmask [M:LDS3] To [M:PS3S]
    Raz [M:PS5S] : Transmask [M:LDS5] To [M:PS5S]
    # Issue X3-35454 - 2017-05-03 by FGR : END
  Endif
Return

##########################################################################################################
$AB_CREATION
  If dim(GIBLDSCREFROMCOR) > 1 Then
    GIBLDSCREFROMCOR = 0
  Endif
Return

##########################################################################################################
$AB_MODIF
  If dim(GIBLDSCREFROMCOR) > 1 Then
    GIBLDSCREFROMCOR = 0
  Endif
Return

##########################################################################################################
$ABANDON
  If dim(GIBLDSCREFROMCOR) > 1 Then
    GIBLDSCREFROMCOR = 0
  Endif
Return

##########################################################################################################
$APRES_MODIF
  If dim([M:BPAL]VALADR) > 0      #LTA.sn
    Diszo [M:BPAL]VALADR
  Endif                           #LTA.en
Return

##########################################################################################################
Subprog AS_CRY(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" and [M]CRYNAM = "" Then
    VALEUR = GPAYS
  Endif
End

##########################################################################################################
Subprog C_CRY(VALEUR)
Variable Char    VALEUR()

  Call LECTURE("TCY", VALEUR, "") From CONTOBJ
  Gosub TITRES From W1LDS3
  If dim([M:LDS3]SAT) > 0 Then
    If [F:TCY]ETAT <> 2 Then
      Effzo [M:LDS3]SAT
      Grizo [M:LDS3]SAT
    Else
      Actzo [M:LDS3]SAT
    Endif
  Endif
  If VALEUR <> "" Then
    Diszo [M:LDS3]CRYNAM
  Else
    Actzo [M:LDS3]CRYNAM
  Endif
End

##########################################################################################################
Subprog AS_CNTLAN(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    Call LECTURE("TCY",[M]CRY,"") From CONTOBJ
    VALEUR = [F:TCY]LAN
  Endif
End

##########################################################################################################
Subprog C_PSTNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" and [M]PSTNUM = "" Then
    If !GIMPORT Then
      mkstat = 4
    Endif
    End
  Endif
  If num$(val(VALEUR)) = VALEUR Then
    Read [AIN2]AIN0=VALEUR
    If fstat Then
      VALEUR = func SUBAIN.COD(val(VALEUR))
    Endif
  Endif
End

##########################################################################################################
Subprog IB_PSTORITXT
  # Issue SAM119357 - 2016-12-05 by FGR : never executed now
  Raz GBOUT1
  If [M:LDS5]PSTORITYP <> 2 Then
    If varmode ([M:LDS5]PSTORITXT, 0) = 0 Then
      Raz GBOUT2
    Else
      Raz GBOUT2
      Raz GBOUTS   # FGR 18/05/2015 : X3SUIVI108178 : déplacé de GBOUT3
      GBOUT2 = mess(257,177,1)
    Endif
  Else
    Raz GBOUT2
    Raz GBOUTS     # FGR 18/05/2015 : X3SUIVI108178 : déplacé de GBOUT3
  Endif
End

##########################################################################################################
Subprog AM_PSTORITXT(VALEUR)
Variable Char    VALEUR()

  # Issue SAM119357 - 2016-12-05 by FGR : never executed now
  #Définition du type de pièce
  If VALEUR = "" Then
    [M:LDS5]PSTORI = 1
  Endif
  If [M:LDS5]PSTORI = 1 and VALEUR <> "" Then
    VALEUR = ""
  Endif
  Gosub DEFOBJORI From SUBLDSB
  Raz [M:LDS5]PSTORIVCR
End

##########################################################################################################
Subprog B2_PSTORITXT(VALEUR)
Variable Char    VALEUR()

  # Issue SAM119357 - 2016-12-05 by FGR : never executed now
  Actzo [M:LDS5]PSTORITXT
  Actzo [M:LDS5]PSTORIVCR
  mkstat = 4
  zonsui = "PSTORITXT"
End

##########################################################################################################
Subprog IB_PSTORIVCR
  Raz GBOUT1
  If [M:LDS5]PSTORITYP <> 2 Then
    If varmode( [M:LDS5]PSTORIVCR, 0) <> 0 Then
      Raz GBOUTS
      Raz GBOUT2
      GBOUT2 = mess(257,177,1)
    Else
      Raz GBOUT2
    Endif
  Else
    Raz GBOUTS
    Raz GBOUT2
  Endif
  If [M:LDS5]PSTORIOBC <> "" and [M:LDS5]PSTORIVCR <> "" Then
    #Détail pièce
    GBOUT1 = mess(103,182,1)
  Endif
End

##########################################################################################################
Subprog B2_PSTORIVCR(VALEUR)
Variable Char    VALEUR()

  Actzo [M:LDS5]PSTORI  # Issue SAM119357 - 2016-12-05 by FGR : now not [M:LDS5]PSTORITXT
  Actzo [M:LDS5]PSTORIVCR
  mkstat = 4
  zonsui = "PSTORI"  # Issue SAM119357 - 2016-12-05 by FGR : now not [M:LDS5]PSTORITXT
End

##########################################################################################################
Subprog AM_FNC(VALEUR)
Variable Decimal    VALEUR()

  If VALEUR <= 0 Then
    Raz [M:LDS2]FNCX
  Elsif VALEUR <= len(mess(0,233,1)) Then
    [M:LDS2]FNCX = mess(VALEUR,233,1)
  Else
    GMESSAGE = mess(618,177,1) - "(" + num$(VALEUR) + ")"
    mkstat = 1
    End
  Endif
End

##########################################################################################################
Subprog AM_CPYCRY(VALEUR)
Variable Char    VALEUR()

  Read [TCY]TCY0=VALEUR
  [M:LDS2]CUR = [F:TCY]CUR
  Affzo [M:LDS2]CUR
  If dim([M:LDS2]ZCUR) > 0 Then
    Affzo [M:LDS2]ZCUR
  Endif
  If [M:LDS2]CPYCAF <> 0 Then
    # Je le réaffiche parce que le format peut changer en fonction de la devise
    Affzo [M:LDS2]CPYCAF
  Endif
End

##########################################################################################################
Subprog IB_PSTORI

  # Issue SAM119357 - 2016-12-05 by FGR
  Raz GBOUT1
  If [M:LDS5]PSTORITYP <> 2 Then
    If varmode( [M:LDS5]PSTORIVCR, 0) <> 0 Then
      Raz GBOUTS
      Raz GBOUT2
      GBOUT2 = mess(257,177,1)
    Else
      Raz GBOUT2
    Endif
  Else
    Raz GBOUTS
    Raz GBOUT2
  Endif
  If [M:LDS5]PSTORIOBC <> "" and [M:LDS5]PSTORIVCR <> "" Then
    #Détail pièce
    GBOUT1 = mess(103,182,1)
  Endif
End

##########################################################################################################
Subprog AM_PSTORI(VALEUR)
Variable Integer VALEUR

  # Issue SAM119357 - 2016-12-05 by FGR
  # Définition du type de pièce
  [M:LDS5]PSTORI = VALEUR
  Gosub DEFOBJORI From SUBLDSB
  Raz [M:LDS5]PSTORIVCR
End

##########################################################################################################
Subprog B2_PSTORI(VALEUR)
Variable Integer VALEUR

  # Issue SAM119357 - 2016-12-05 by FGR
  Actzo [M:LDS5]PSTORI
  Actzo [M:LDS5]PSTORIVCR
  mkstat = 4
  zonsui = "PSTORI"
End

