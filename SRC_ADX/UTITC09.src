#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################
# UTITC09   Table TABSCA les désignations deviennent           Module TC #
#           traduisibles                                                 #
##########################################################################
# FGR 18/09/2009 : X3SUIVI57920
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  # Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-08-07 by MAE :
    #Read [ADS]DOSSIER=[L]DOSSIER
    #If fstat THEN
    #  Raz [F:ADS]
    #Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTITC09(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC09(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)

  IERR = 0
  Call ECR_TRACE("UTITC09: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table TABBOMALT
  #
  If filinfo(filpath("FIL", "ATEXTRA", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".ATEXTRA" [AXX]
  #
  If filinfo(filpath("FIL", "TABSCA", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI + ".TABSCA" [TSR]
    If dim([F:TSR]SCADES) > 0 or dim([F:TSR]SCASHO) > 0  Then
      Trbegin [TSR], [AXX]
      For [TSR]TSR0
        IUPDATE = 0
        If dim([F:TSR]SCADES) > 0 Then
          If [F:TSR]SCADES <> "" Then
            Call MAJTEXTRA([F:TSR]SCADES, "TABSCA", "SCADESAXX", num$([F:TSR]SCANUM), "") From ATEXTRA
            If GOK < 1 Then
              Call ECR_TRACE("File ATEXTRA TABSCA-SCADESAXX" - num$([F:TSR]SCANUM) + ",Error =" - num$(fstat), 1) From GESECRAN
              GOK = 1
              IERR = 1
              Break
            Endif
            IUPDATE = 1
            [F:TSR]SCADES = ""
          Else
            Call LECTEXTRA(WCHAINE, "TABSCA", "SCADESAXX", num$([F:TSR]SCANUM), "") From ATEXTRA
            If WCHAINE = "" Then
              Call MAJTEXTRA(WCHAINE, "TABSCA", "SCADESAXX", num$([F:TSR]SCANUM), "") From ATEXTRA
            Endif
          Endif
        Endif
        If dim([F:TSR]SCASHO) > 0  Then
          If [F:TSR]SCASHO <> "" Then
            Call MAJTEXTRA([F:TSR]SCASHO, "TABSCA", "SCASHOAXX", num$([F:TSR]SCANUM), "") From ATEXTRA
            If GOK < 1 Then
              Call ECR_TRACE("File ATEXTRA TABSCA-SCASHOAXX" - num$([F:TSR]SCANUM) + ",Error =" - num$(fstat), 1) From GESECRAN
              GOK = 1
              IERR = 1
              Break
            Endif
            IUPDATE = 1
            [F:TSR]SCASHO = ""
          Else
            Call LECTEXTRA(WCHAINE, "TABSCA", "SCASHOAXX", num$([F:TSR]SCANUM), "") From ATEXTRA
            If WCHAINE = "" Then
              Call MAJTEXTRA(WCHAINE, "TABSCA", "SCASHOAXX", num$([F:TSR]SCANUM), "") From ATEXTRA
            Endif
          Endif
        Endif
        If IUPDATE = 1 Then
          Rewrite [TSR]
        Endif
      Next
      If IERR = 0 Then
        Commit
      Else
        Rollback
      Endif
    Endif
    Close Local File [TSR]
  Endif
  Close Local File [AXX]
  #
  If IERR = 0 Then
    If clalev([F:AOB]) = 0 : Local File =SZAPPLI + ".AOBJET"  [AOB] : Endif
    WOBJET = "TSR"
    Read [AOB]ABREV=WOBJET
    If !fstat Then
      Call MAJ_SEL(SZAPPLI, WOBJET) From PATCHAOB
      #
      If [F:AOB]TYPGES <> 4 Then
        # Pas de fenêtre pour les browsers
        Call VALID("O" + WOBJET, SZAPPLI, 1, IERR) From VALWIN
        If IERR <> 1 Then
          Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET, 1) From GESECRAN
        Endif
      Endif
      #
      Call VALID (WOBJET, SZAPPLI, 1, IERR) From VALOBJ
      If IERR <> 1 Then
        Call ECR_TRACE("Erreur revalidation objet" - WOBJET, 1) From GESECRAN
      Endif
    Endif
  Endif
  #
  Call ECR_TRACE("UTITC09 : records processed", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat THEN
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"TABSCA") : End : Endif
  Call MAJ_UTITC09(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"TABSCA") : End : Endif
  Call MAJ_UTITC09(APPLI)
End

