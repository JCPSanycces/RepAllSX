#<AdxTL>@(#)0.0.0.0 $Revision$
#
#*********************************************************************
#
#           SYRCUSE CONTAINER IMPORT PROCESS
#
#*********************************************************************
# Creation
# MAE   12.06.2015
#
#*********************************************************************
# Updates
#
# XXXXX DD.MM.YYYY FQ000000   : XXX
#
#*********************************************************************

$ACTION
  Case ACTION
    When "IMP_OUVRE"     : Gosub IMP_OUVRE
    When "AP_IMPORT"     : Gosub AP_IMPORT
    When "IMP_FERME"     : Gosub IMP_FERME
    When Default
  Endcase
Return

####################################################################
# At the beginning of import process
####################################################################
$IMP_OUVRE
  Local Integer RET
  Local Integer NBCREA, NBMODIF
  Local Integer WPOS
  Local Integer NBLIG
  Local Char SAV_CTRNUM(GLONVCR)

  If !clalev([F:POQ]) : Local File PORDERQ [POQ] : Endif
  If !clalev([F:CTRD]) : Local File CONTAINERD [CTRD] : Endif
  If !clalev([F:CTRD1]) : Local File CONTAINERD [CTRD1] : Endif
  If !clalev([F:CTRH1]) : Local File CONTAINER [CTRH1] : Endif

  Local Instance WCONTAINER Using C_CONTAINER

  # Set ANOWRITE to 1 to avoid creation/update by the Supervisor import process
  ANOWRITE = 1
Return

####################################################################
# After each line reading
####################################################################
$AP_IMPORT
# In the TEST mode ther's nothing to do
If ([M:IMP2]TEST=[V]CST_AYES) : Return : Endif

If WCONTAINER<>null
  If IMPFIC="CTRH"
    If WCONTAINER.CTRNUM<>AVOID.ACHAR & WCONTAINER.CTRNUM<>[F:CTRH]CTRNUM
      If GREP ="C"
        Gosub INSERTION
      Elsif GREP="M"
        Gosub MODIFICATION
      Else
        Call ECR_TRACE("GREP = ''",1) From GESECRAN
        Return
      Endif
     #To manage the case of the sequence number (Wcontainer & [F:CTRH]CTRNUM are empty)
     Elsif WCONTAINER.CTRNUM=AVOID.ACHAR & [F:CTRH]TCTRNUM <> AVOID.ACHAR
       If GREP ="C"
        Gosub INSERTION
       Endif
     Endif
  Endif
Endif

# To avoid the supervisor messages in the log
GOK = 0

If IMPFIC="CTRH"
  WCONTAINER=NewInstance C_CONTAINER AllocGroup null
  [L]RET=fmet WCONTAINER.AINIT()
  If [L]RET >= [V]CST_AERROR
    Call WRITE_ERRORS(WCONTAINER)
    Return
  Endif
  # Must set GREP to have the right numbers of created and updated items in the log
  GREP="C"
Endif

# The container exist, passage in modification
If ([M:AOE1]OPTUPD=G_OUI) and ([F:CTRH]CTRNUM<>"") & IMPFIC="CTRH"
  Read[CTRH1]CTRH0=[F:CTRH]CTRNUM
  If (fstat=[V]CST_AOK)
    [L]RET=fmet WCONTAINER.AREAD([F:CTRH]CTRNUM)
    If [L]RET >= [V]CST_AERROR
      Call WRITE_ERRORS(WCONTAINER)
      Return
    Else
      GREP="M"
    Endif
  Endif
Endif

If GREP="M"
  Gosub SET_PROPERTIES_UPDATE
Elsif GREP="C"
 Gosub SET_PROPERTIES_CREATE
Else
 Call ECR_TRACE("GREP = ''",1) From GESECRAN
 Return
Endif

If IMPFIC="CTRH"
  NBLIG=AVOID.ADEC
  Call ECR_TRACE(mess(143,141,1)-[F:CTRH]CTRNUM,0) From GESECRAN
Else
  NBLIG += 1
  Call ECR_TRACE(mess(143,141,1)-WCONTAINER.CTRNUM-mess(3,40,1)-num$(NBLIG),0) From GESECRAN
Endif

Return

####################################################################
# At the end of import process
####################################################################
$IMP_FERME
# To import the last row of the file
If WCONTAINER <> null
  If GREP="C"
    Gosub INSERTION
  Elsif  GREP="M"
    Gosub MODIFICATION
  Else
    Call ECR_TRACE("GREP = ''",1) From GESECRAN
    Return
  Endif
Endif

# Write the records number
If NBCREA <> AVOID.ADEC
  Call ECR_TRACE(num$(NBCREA) +" "+ mess(103,141,1),0) From GESECRAN
Endif

If NBMODIF <> AVOID.ADEC
  Call ECR_TRACE(num$(NBMODIF) +" "+ mess(104,141,1),0) From GESECRAN
Endif

Return

####################################################################
# Record insertion
####################################################################
$INSERTION
Trbegin [F:CTRH]
# Insertion of the previous record
[L]RET=fmet WCONTAINER.AINSERT()

Call WRITE_ERRORS(WCONTAINER)

If [L]RET>=[V]CST_AERROR
  # Must set GOK to zero in case of error. If not a success message is added to the log.
  GOK=0
  Rollback
Else
  NBCREA +=1
  Commit
Endif


FreeGroup WCONTAINER
Return

####################################################################
# Record update
####################################################################
$MODIFICATION

Trbegin [F:CTRH]
# Update of the previous record

[L]RET=fmet WCONTAINER.AUPDATE()

Call WRITE_ERRORS(WCONTAINER)

If [L]RET>=[V]CST_AERROR
  # Must set GOK to zero in case of error. If not a success message is added to the log.
  GOK=0
  Rollback
Else
  NBMODIF +=1
  Commit
Endif

FreeGroup WCONTAINER
Return

####################################################################
# Assign value to the class property when creating
####################################################################
$SET_PROPERTIES_CREATE

If IMPFIC="CTRH"
  SetInstance WCONTAINER With [F:CTRH]
Else
  WPOS=fmet WCONTAINER.ADDLINE("CTRD",[V]CST_ALASTPOS)
  If WPOS=[V]CST_ANOTDEFINED
    # The insertion was not possible
    Call WRITE_ERROR_STACK_CLASSIC(WCONTAINER, [V]CST_AERROR) From LCCLIB
    GOK=0
    Return
  Endif

  # Read the order and tranclass first to keep the imported quantity
  Read [POQ] POQ0=[F:CTRD]POHNUM;[F:CTRD]POPLIN;[F:CTRD]POQSEQ
  If fstat
    Raz [F:POQ]
  Else
    SetInstance WCONTAINER.CTRD(WPOS) With [F:POQ]
  Endif
  WCONTAINER.CTRD(WPOS).CTRNUM = [F:CTRH]CTRNUM
  WCONTAINER.CTRD(WPOS).POHNUM = [F:CTRD]POHNUM
  WCONTAINER.CTRD(WPOS).POPLIN = [F:CTRD]POPLIN
  WCONTAINER.CTRD(WPOS).POQSEQ = [F:CTRD]POQSEQ
  WCONTAINER.CTRD(WPOS).QTYUOM = [F:CTRD]QTYUOM
  WCONTAINER.CTRD(WPOS).QTYWEU = [F:CTRD]QTYWEU
  WCONTAINER.CTRD(WPOS).QTYVOU = [F:CTRD]QTYVOU
Endif

Return

####################################################################
# Assign value to the class property from the F class
# according the imported fields list when updating
####################################################################
$SET_PROPERTIES_UPDATE
Local Integer N_I, IS_NULL, WIND
For N_I = 0 To [M:AOE2]NBRLIG-1
  If IMPFIC = "CTRH"
    If (left$([M:AOE2]FLD(N_I),1)<>"*") &(left$([M:AOE2]FLD(N_I),1)<>"/")
      If (evalue("dim(WCONTAINER."+[M:AOE2]FLD(N_I)+")>-1")) & (evalue("dim([F:CTRH]"+[M:AOE2]FLD(N_I)+")>-1"))
        IS_NULL = 0
        Case evalue("type([F:CTRH]"+[M:AOE2]FLD(N_I)+")")
        When 1, 2, 4, 5, 6, 7, 9
         If evalue("[F:CTRH]"+[M:AOE2]FLD(N_I)) = 0
           IS_NULL = 1
         Endif
        When 3
          If evalue("[F:CTRH]"+[M:AOE2]FLD(N_I)) = [0/0/0]
           IS_NULL = 1
          Endif
        When Default
          If evalue("[F:CTRH]"+[M:AOE2]FLD(N_I)) = ""
            IS_NULL = 1
          Endif
        Endcase
        # Filling of the header
        If !IS_NULL
          Assign "WCONTAINER."+[M:AOE2]FLD(N_I) With evalue("[F:CTRH]"+[M:AOE2]FLD(N_I))

        Endif
      Endif
     Endif
  Elsif IMPFIC = "CTRD"
    If (left$([M:AOE2]FLD(N_I),1)<>"*")&(left$([M:AOE2]FLD(N_I),1)<>"/")
      If (evalue("dim(WCONTAINER.CTRD(1)."+[M:AOE2]FLD(N_I)+")>-1"))&(evalue("dim([F:CTRD]"+[M:AOE2]FLD(N_I)+")>-1"))
        IS_NULL = 0
        Case evalue("type([F:CTRD]"+[M:AOE2]FLD(N_I)+")")
        When 1, 2, 4, 5, 6, 7, 9
          If evalue("[F:CTRD]"+[M:AOE2]FLD(N_I)) = 0
            IS_NULL = 1
          Endif
        When 3
          If evalue("[F:CTRD]"+[M:AOE2]FLD(N_I)) = [0/0/0]
            IS_NULL = 1
          Endif
        When Default
          If evalue("[F:CTRD]"+[M:AOE2]FLD(N_I)) = ""
            IS_NULL = 1
          Endif
        Endcase

        # Filling of lines
        If !IS_NULL
          # Use of CTRD1 file in order to not crush the one read on the import. CTRD1 is only use to find AAUUID
          Filter [CTRD1] Where CTRNUM = [F:CTRH]CTRNUM & POHNUM=[F:CTRD]POHNUM & POPLIN=[F:CTRD]POPLIN & POQSEQ=[F:CTRD]POQSEQ
          Read [CTRD1] First
          WIND = find([F:CTRD1]AUUID, WCONTAINER.CTRD(1..maxtab(WCONTAINER.CTRD)).AUUID)
          # If the line exist, the class is update
          If WIND <> 0
            Assign "WCONTAINER.CTRD("+num$(WIND)+")."+[M:AOE2]FLD(N_I) With evalue("[F:CTRD]"+[M:AOE2]FLD(N_I))
          # If the line don't exist, the line is create
          Else
            Gosub SET_PROPERTIES_CREATE
            Break
          Endif
        Endif
      Endif
     Endif
    Endif
  Next
Return

#------------------------------------#
#--- Write the errors                #
#------------------------------------#
Subprog WRITE_ERRORS(WCONTAINER)
Variable Instance WCONTAINER Using C_CONTAINER

Local Integer I
Local Char WMESSAGE(250)

WMESSAGE=AVOID.ACHAR

# Lines errors
For I=1 To maxtab(WCONTAINER.CTRD)
  WMESSAGE=func LCCLIB.MAXMSG(WCONTAINER.CTRD(I))
  If WMESSAGE<>AVOID.ACHAR
    Call WRITE_ERROR_STACK_CLASSIC(WCONTAINER.CTRD(I), 0) From LCCLIB
  Endif
Next I

# Head errors
WMESSAGE=func LCCLIB.MAXMSG(WCONTAINER)
If WMESSAGE<>AVOID.ACHAR
  Call WRITE_ERROR_STACK_CLASSIC(WCONTAINER, 0) From LCCLIB
Endif

End

