#<AdxTL>@(#)3.0.0.0 $Revision$
#  When "FXDOLINKTOPROC"            : Gosub LTOPROC
#  When "FXDOLINKTOFUNC"            : Gosub LTOFUNC
#  When "FXDOLINKTOREPORT"          : Gosub LTOREPORT
#  When "FXDOLINKTOCONSULT"         : Gosub LTOCONSULT


#   AINTERFL   :     Gestion des interactions avec les blocs flash

Local Char TCL(100)(1..30)
Local Integer IND
IND+=1 : TCL(IND)= "<INTERFL>"
IND+=1 : TCL(IND)= "<TYPFL>FPADP</TYPFL>"   : #           type de flash
IND+=1 : TCL(IND)= "<TYPINTER>FXSELLINKTOFIELD</TYPINTER>" : #    type d'interaction
IND+=1 : TCL(IND)= "<TRANS></TRANS> " : #                      numéro de ligne
IND+=1 : TCL(IND)= "<CODE></CODE> " : #                      numéro de ligne
IND+=1 : TCL(IND)= "</INTERFL>" 
Local Char MESSAG(100)(1..3)
Local Integer GRAV(1..3),OK
Local Clbfile CLOBD(6)
Setlob CLOBD With TCL(1..IND)
Local Mask ZZCC25 [ZC25]
Call AINTERFL(CLOBD,MESSAG,GRAV,OK)
Infbox(num$(OK)-":"-MESSAG)
Infbox CLOBD
End


# ----------------------------------------------------------------------------

Subprog AINTERFL(CLOBD,MESSAG,GRAV,OK)
Variable Clbfile CLOBD()
Variable Char MESSAG()(1..)
Variable Integer GRAV(1..)
Variable Integer OK

#   CLOBD  : contient le clob de description des paramètres (spécifique à chaque interaction flash)
#   MESSAG : contient le texte des messages à afficher (0 à 5)
#   GRAV   : contient la gravité des messages 1=info, 2=avertissement, 3=bloquant
#   OK=1 si pas de pb, 0 sinon

#Raz MESSAG,GRAV
OK=1

#   Exemple de CLOBD pour une modification de valeur d'une barre dans un graphique
#   <INTERFL>
#     <TYPFL>GRAPH</TYPFL>                               Type de flash
#     <TYPINTER>MODFIELD</TYPINTER>                      Type d'interaction
#     <NL>6</NL>                                         Numéro de ligne
#     <FIELD>QTE</FIELD>                                 Nom du champ (ou un identifiant)
#     <VAL>456.5</VAL>                                   Nouvelle valeur en alpha
#   </INTERFL>
#
Local Char ATROUV,VTROUV(100),TYPFL
Local Integer IT1,IT2,IT3

#  Recherche TYPFL
ATROUV="TYPFL" : Gosub TROUVT
VTROUV=toupper(VTROUV)
Case VTROUV
  When "FQD"              : Call AINTERFL(CLOBD,MESSAG,GRAV,OK) From SUBALT
  When "FAG"              : Gosub FAG
  When "FPADT","FPADP"    : Gosub FPADT
Endcase
End



$FAG
#  Recherche TYPINTER
Onerrgo ERRFL
ATROUV="TYPINTER" : Gosub TROUVT
VTROUV=toupper(VTROUV)
Case VTROUV
  When "MODFIELD"         : Gosub GRAPH
  When "FXCREATEAGDEVENT" : Gosub CRERDV
Endcase

Onerrgo
Return


$ERRFL
Resume



$FPADT
#  Recherche TYPINTER
ATROUV="TYPINTER" : Gosub TROUVT
Local Char TYPI1(50) : TYPI1=VTROUV
ATROUV="CODE" : Gosub TROUVT
Local Char CODF(20) : CODF=toupper(VTROUV)
ATROUV="TRANS" : Gosub TROUVT
Local Char TRANS(20) : TRANS=toupper(VTROUV)
ATROUV="KEY" : Gosub TROUVT
If VTROUV<>"" : MESSAG="KEY:"+VTROUV : Endif
Call AINTERFL(TYPI1,CODF,TRANS,CLOBD,MESSAG,GRAV,OK) From SUBAPR
Return


$TROUVT
VTROUV=""
IT1=instr(1,CLOBD,"<"+ATROUV+">")
If IT1=0 : Return : Endif
IT2=instr(IT1,CLOBD,">")
IT3=instr(IT2,CLOBD,"</")
If IT2>0 and IT3>IT2
  VTROUV=mid$(CLOBD,IT2+1,IT3-IT2-1)
#  Enleve le CDATA si il y en a un
  If left$(toupper(VTROUV),9)="<![CDATA["
    VTROUV=mid$(VTROUV,10,len(VTROUV)-12)
  Endif
Endif
Return




$GRAPH
#  Recherche TYPINTER
ATROUV="TYPINTER" : Gosub TROUVT
#If VTROUV<>"MODFIELD" : Return : Endif
#  Modification d'un champ
ATROUV="NL" : Gosub TROUVT
Local Integer NL : NL=val(VTROUV)
                                                                   If NL=0 : NL=1 : Endif
ATROUV="FIELD" : Gosub TROUVT
Local Char AFIELD : AFIELD=VTROUV : AFIELD="PRIXU"
ATROUV="VAL" : Gosub TROUVT
Local Decimal AVAL : AVAL=val(VTROUV)*1.1
                                                                   If AVAL=0 : AVAL=134.43 : Endif

Assign "[M]"+AFIELD+"("+num$(NL-1)+")" With AVAL
Affzo ="[M]"+AFIELD+"("+num$(NL-1)+")"
Return





$CRERDV
#  On passe la main au programme CRM si il existe sinon on a un traitement "superviseur" par défaut
Local Integer OKEX
Call EXISTE_ADX("","","CRMAINTERFL",OKEX) From ORDSYS
If OKEX=1
  Call AINTERFL(CLOBD,MESSAG,GRAV,OK) From CRMAINTERFL
  Return
Endif

Local Char AFIELD
Local Integer NL
NL=[M]NBLIG
#   Date de début de RDV
AFIELD="DATD"
ATROUV="DATSTART" : Gosub TROUVT
Local Date DATE1 : DATE1=VTROUV
Assign "[M]"+AFIELD+"("+num$(NL)+")" With DATE1
AFIELD="DATDI"
Local Integer ANN,MOIS,JMOIS
ANN=year(DATE1)
MOIS=month(DATE1)
JMOIS=day(DATE1)
VTROUV=num$(ANN)+format$("N0:##",MOIS)+format$("N0:##",JMOIS)
Assign "[M]"+AFIELD+"("+num$(NL)+")" With VTROUV

#   Date de fin de RDV
AFIELD="DATF"
ATROUV="DATEND" : Gosub TROUVT
Local Date DATD : DATE1=VTROUV
Assign "[M]"+AFIELD+"("+num$(NL)+")" With DATE1
#Affzo ="[M]"+AFIELD+"("+num$(NL)+")"
AFIELD="DATFI"
Local Integer ANN,MOIS,JMOIS
ANN=year(DATE1)
MOIS=month(DATE1)
JMOIS=day(DATE1)
VTROUV=num$(ANN)+format$("N0:##",MOIS)+format$("N0:##",JMOIS)
Assign "[M]"+AFIELD+"("+num$(NL)+")" With VTROUV


#   Heure de début de RDV
AFIELD="HEUD"
ATROUV="HOURSTART" : Gosub TROUVT
Local Char HEUT : HEUT=VTROUV
Assign "[M]"+AFIELD+"("+num$(NL)+")" With HEUT
#Affzo ="[M]"+AFIELD+"("+num$(NL)+")"

#   Heure de fin de RDV
AFIELD="HEUF"
ATROUV="HOUREND" : Gosub TROUVT
Local Char HEUT : HEUT=VTROUV
Assign "[M]"+AFIELD+"("+num$(NL)+")" With HEUT
#Affzo ="[M]"+AFIELD+"("+num$(NL)+")"

#   Description du RDV
AFIELD="OBJ"
ATROUV="DESCR" : Gosub TROUVT
Local Char DESRDV(60) : DESRDV=VTROUV
Assign "[M]"+AFIELD+"("+num$(NL)+")" With DESRDV
#Affzo ="[M]"+AFIELD+"("+num$(NL)+")"

[M]NBLIG+=1
Affzo [M]
Return
