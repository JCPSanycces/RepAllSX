#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : articles/fournisseurs REACH
#                             cf AML 2240 : 45/46
###################################################
######################################################################
$OUVTAB_ITM
If !clalev([F:TFO]) Local File TABFOR    [TFO] Endif
If !clalev([F:AXX]) Local File ATEXTRA   [AXX] Endif
If !clalev([F:ITM]) Local File ITMMASTER [ITM] Endif
If !clalev([F:ITG]) Local File ITMCATEG  [ITG] Endif
If !clalev([F:ITP]) Local File ITMBPS    [ITP] Endif
If !clalev([F:BPS]) Local File BPSUPPLIER[BPS] Endif
If !clalev([F:BPR]) Local File BPARTNER  [BPR] Endif
If !clalev([F:BPA]) Local File BPADDRESS [BPA] Endif   
If !clalev([F:FCY]) Local File FACILITY  [FCY] Endif
If !clalev([F:CNT]) Local File CONTACT   [CNT] Endif
If !clalev([F:AIN]) Local File CONTACTCRM[AIN] Endif
Return

######################################################################
Subprog TRT_ITM(ID,CLETRT,PITITM,P_ITMFOR,P_ITMSRT,PITBPS,P_BPSFOR,OK)
Value Char ID()
Value Char CLETRT () 
Value Char PITITM () 
Value Char P_ITMFOR() 
Value Integer P_ITMSRT
Value Char PITBPS () 
Value Char P_BPSFOR() 
Variable Integer OK

If PITITM="" & PITBPS="" : Return : Endif

Local Char     FORMULE1(255) : Raz FORMULE1   # chargement de P_ITMFOR
Local Char     FORMULE2(255) : Raz FORMULE2   # chargement de P_BPSFOR
Local Char WFIL1(255),WFIL2(255),WFIL3(255)

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GASCII
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub OUVTAB_ITM
Gosub OUVREPIVOT From CONNECTFCT


If PITITM<>""
    Local Integer WNBITM  : Raz WNBITM 
    Local Integer WPREITM : Raz WPREITM
    Local Char    OPTITM(GDIMFIC)
    OPTITM = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pititm")
    Local Integer WKNBZON        : Raz WKNBZON
    Local Char    WKNORECMES (50): Raz WKNORECMES 
    Local Integer WKHEATYP       : Raz WKHEATYP 
    Local Char    WKHEADMES (250): Raz WKHEADMES 
    
    Call READPIT(PITITM,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
    Local Char    WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
    Local Char    WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
    Local Char    WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
    Local Char    WKFRM(150)(1..WKNBZON) : Raz WKFRM
    Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
    Local Char    WKVAL(255)(1..WKNBZON) : Raz WKVAL
    Local Char    WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
    Call LOADPIVZON(PITITM,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITITM,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPREITM,OPTITM) From CONNECTFCT
Endif
If PITBPS<>""
    Local Integer WNBBPS  : Raz WNBBPS
    Local Integer WPREBPS : Raz WPREBPS
    Local Char    OPTBPS(GDIMFIC)
    OPTBPS = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitbps")
    OPTBPSTMP = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitbpstmp")
    Openo OPTBPSTMP ,0 Using [FPIV]
    Openo Using [FPIV]
    Local Integer ECRBPS
    Local Char WBPSTMP(GLONBPS)

    Local Integer BWKNBZON        : Raz BWKNBZON
    Local Char    BWKNORECMES (50): Raz BWKNORECMES 
    Local Integer BWKHEATYP       : Raz BWKHEATYP 
    Local Char    BWKHEADMES (250): Raz BWKHEADMES 
    
    Call READPIT(PITBPS,BWKNBZON,BWKNORECMES,BWKHEATYP ,BWKHEADMES ) From CONNECTFCT
    Local Char    BWKTABZON(GLONATB+GLONAVA+2)(1..BWKNBZON) : Raz BWKTABZON
    Local Char    BWKTABABR(GLONABR)(1..BWKNBZON) : Raz BWKTABABR
    Local Char    BWKZON(GLONAVA)(1..BWKNBZON) : Raz BWKTABZON
    Local Char    BWKFRM(150)(1..BWKNBZON) : Raz BWKFRM
    Local Integer BWKWRK(1..BWKNBZON) : Raz BWKWRK
    Local Char    BWKVAL(255)(1..BWKNBZON) : Raz BWKVAL
    Local Char    BWKVALFIC(GLONAVA)(1..BWKNBZON) : Raz BWKVALFIC
    Call LOADPIVZON(PITBPS,BWKNBZON,BWKTABZON,BWKTABABR,BWKZON,BWKFRM,BWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITBPS,BWKNBZON,BWKTABZON,BWKTABABR,BWKZON,BWKWRK,BWKHEATYP,BWKHEADMES,WPREBPS,OPTBPS) From CONNECTFCT
Endif
#######
Gosub TRT_FORMULE1
Gosub TRT_FORMULE2
If P_ITMSRT=1
Link [ITP] With [ITM]ITM0~=[F:ITP]ITMREF, [BPS]BPS0~=[F:ITP]BPSNUM,[BPR]BPR0~=[F:ITP]BPSNUM
& As [LNK] 
& Order By Key KEY1=[ITP]ITMREF;[ITP]BPSNUM
Else
Link [ITP] With [ITM]ITM0~=[F:ITP]ITMREF, [BPS]BPS0~=[F:ITP]BPSNUM,[BPR]BPR0~=[F:ITP]BPSNUM
& As [LNK] 
& Order By Key KEY1=[ITP]BPSNUM;[ITP]ITMREF
Endif

Filter [CNT] Where CNTFNC=12

If FORMULE1="" : FORMULE1="1=1" : Endif
If FORMULE2="" : FORMULE2="1=1" : Endif

For [LNK]KEY1 Where [F:ITM]ITMSTD='REACH' and evalue(FORMULE1) and evalue(FORMULE2)

    Gosub WR_ITM

    Gosub RECH_BPS
    If ECRBPS
        Raz [CNT]
        Raz[F:AIN]
        Raz [BPA]
        Read [BPA]BPA0=1;[F:BPS]BPSNUM;[F:BPS]BPAADD

        Read [CNT]CNT0=1;[F:BPS]BPSNUM
        If !fstat
            Read [AIN]AIN0=[F:CNT]CCNCRM
        Endif

        Gosub WR_BPS
    Endif
Next

# Issue 80230 - 2012-02-20 by RBA
Filter [CNT]


#######
If PITITM<>"" : Call WRPIVOT_END(PITITM ,WNBITM ,WKNORECMES ,WPREITM ,OPTITM) From CONNECTFCT : Endif
If PITBPS<>"" : Call WRPIVOT_END(PITBPS ,WNBBPS ,BWKNORECMES ,WPREBPS ,OPTBPS) From CONNECTFCT : Endif
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

######################################################################
$TRT_FORMULE1
If P_ITMFOR <> ""
    Read [F:TFO]TFO0=41;P_ITMFOR
    If !fstat 
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif
Return
######################################################################
$TRT_FORMULE2
If P_BPSFOR <> ""
    Read [F:TFO]TFO0=50;P_BPSFOR
    If !fstat 
        If FORMULE2 = "" 
            FORMULE2  = [F:TFO]FORFOR
        Else
            FORMULE2 += "&" 
            FORMULE2 += [F:TFO]FORFOR
        Endif
    Endif
Endif
Return

######################################################################
$WR_ITM
If PITITM<>""
    ################################
    # fichiers ITM
    ################################
    #     Ouverture du fichier OPTITM en écriture
    If WPREITM = 0
      Openo OPTITM,0 Using [FPIV]
      WPREITM = 1
    Else
      Openo OPTITM Using [FPIV]
    Endif
    WNBITM += 1
    Call RAZVALPIVOT(PITITM,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITITM,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return
######################################################################
$WR_BPS
If PITBPS<>""
    ################################
    # fichiers BPS
    ################################
    #     Ouverture du fichier OPTBPS en écriture
    If WPREBPS = 0
      Openo OPTBPS,0 Using [FPIV]
      WPREBPS = 1
    Else
      Openo OPTBPS Using [FPIV]
    Endif
    WNBBPS += 1

    Openo OPTBPSTMP Using [FTMP]
    Wrseq [F:BPS]BPSNUM Using [FTMP]
    Openo Using [FTMP]

    Call RAZVALPIVOT(PITBPS,BWKNBZON,BWKVAL,BWKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITBPS,BWKNBZON,BWKTABZON,BWKTABABR,BWKZON,BWKFRM,BWKWRK,BWKVAL,BWKVALFIC) From CONNECTFCT
    Call WRPIVOT(BWKNBZON,BWKTABZON,BWKTABABR,BWKZON,BWKFRM,BWKWRK,BWKVAL,BWKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return

######################################################################
$RECH_BPS
      ECRBPS=1
      Openi OPTBPSTMP Using [FPIV]
      Rdseq WBPSTMP Using [FPIV]
      While fstat=0
            If WBPSTMP =[F:BPS]BPSNUM
                ECRBPS=0
                Break
            Endif
            Rdseq WBPSTMP Using [FPIV]
      Wend
      Openi Using [FPIV]
Return


