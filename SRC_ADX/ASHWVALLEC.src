    LNK_ABORT.ALNK(ACT_LNK).ATBKEY(ASWK_KEY).NOLIB=LNK_D.ATBKEY(ASWK_KEY).NOLIB
    LNK_ABORT.ALNK(ACT_LNK).ATBKEY(ASWK_KEY).LNG=LNK_D.ATBKEY(ASWK_KEY).LNG
    LNK_ABORT.ALNK(ACT_LNK).ATBKEY(ASWK_KEY).LOO=LNK_D.ATBKEY(ASWK_KEY).LOO
    LNK_ABORT.ALNK(ACT_LNK).ATBKEY(ASWK_KEY).PARFIL=LNK_D.ATBKEY(ASWK_KEY).PARFIL
    LNK_ABORT.ALNK(ACT_LNK).ATBKEY(ASWK_KEY).PARENT=LNK_D.ATBKEY(ASWK_KEY).PARENT
   Next ASWK_KEY
   For ASWK_NBP=1 To maxtab(LNK_D.ATBPAR)
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP) = NewInstance C_ASWPAR AllocGroup ASHW
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).TYPPAR=LNK_D.ATBPAR(ASWK_NBP).TYPPAR
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).CODFLD=LNK_D.ATBPAR(ASWK_NBP).CODFLD
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).CODPAR=LNK_D.ATBPAR(ASWK_NBP).CODPAR
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).TYPKEY=LNK_D.ATBPAR(ASWK_NBP).TYPKEY
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).VALEUR=LNK_D.ATBPAR(ASWK_NBP).VALEUR
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).TYPINT=LNK_D.ATBPAR(ASWK_NBP).TYPINT
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).ALIAS=LNK_D.ATBPAR(ASWK_NBP).ALIAS
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).DESPAR=LNK_D.ATBPAR(ASWK_NBP).DESPAR
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).MODPAR=LNK_D.ATBPAR(ASWK_NBP).MODPAR
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).TYPAFF=LNK_D.ATBPAR(ASWK_NBP).TYPAFF
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).NOLIB=LNK_D.ATBPAR(ASWK_NBP).NOLIB
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).LNG=LNK_D.ATBPAR(ASWK_NBP).LNG
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).LOO=LNK_D.ATBPAR(ASWK_NBP).LOO
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).PARFIL=LNK_D.ATBPAR(ASWK_NBP).PARFIL
    LNK_ABORT.ALNK(ACT_LNK).ATBPAR(ASWK_NBP).PARENT=LNK_D.ATBPAR(ASWK_NBP).PARENT
   Next ASWK_NBP
  Endif
Endif
Return


#---------------------------------------------------------------------------------------------------#
# Parameters of fields
#---------------------------------------------------------------------------------------------------#
Subprog CHARGE_PARFLD(AERR,ACLAF,CODREP,TYPPAR)
Variable  Instance  AERR(1..) Using C_AERROR
Variable  Instance  ACLAF  Using C_ACLAFLD
Value Integer TYPPAR
Value Char CODREP
Local Integer NBR_NBP,NBR_NBK,NBR_NBA
NBR_NBP = maxtab(ACLAF.ATBPAR)
NBR_NBK = maxtab(ACLAF.ATBKEY)
NBR_NBA = maxtab(ACLAF.ATYPPAR)
For [ASWP]ASWP1 Where CODREP=[L]CODREP & CODFLD=ACLAF.FLDCLA & TYPPAR=[L]TYPPAR
 If [F:ASWP]TYPPAR=1 & [F:ASWP]TYPKEY=2
  NBR_NBK += 1
  ACLAF.ATBKEY(NBR_NBK) = NewInstance C_ACLAPARFLD AllocGroup ACLAF
  SetInstance ACLAF.ATBKEY(NBR_NBK) With  [F:ASWP]
 Elsif [F:ASWP]TYPPAR=1
  NBR_NBP += 1
  ACLAF.ATBPAR(NBR_NBP) = NewInstance C_ACLAPARFLD AllocGroup ACLAF
  SetInstance ACLAF.ATBPAR(NBR_NBP) With  [F:ASWP]
 Elsif [F:ASWP]TYPPAR = 2
  Read [ATYP]ATYP0=[F:ASWP]VALEUR
  If !fstat
   NBR_NBA += 1
   ACLAF.ATYPPAR(NBR_NBA) = NewInstance C_ACLAPARFLD AllocGroup ACLAF
   SetInstance ACLAF.ATYPPAR(NBR_NBA) With  [F:ASWP]
   ACLAF.ATYPPAR(NBR_NBA).CODPAR = ACLAF.ATYPPAR(NBR_NBA).VALEUR
   ACLAF.ATYPPAR(NBR_NBA).VALEUR=[F:ATYP]PROTYP
  Endif
 Endif
Next
End

#---------------------------------------------------------------------------------------------------#
# Construction of path of properties : DEMO ITM
#---------------------------------------------------------------------------------------------------#
Subprog FIND_SUBCLASS(GROUPE,DOSSIER,WPTH,WGRP,PTR,ACLASSE,NBPTH,ASHW,AERR,TBCLAFIND)
Value Char       GROUPE
Value Char       DOSSIER
Value Char       WPTH
Value Char       WGRP
Value Char       PTR
Value Char       ACLASSE
Variable Integer NBPTH
Variable Instance ASHW Using C_ASW
Variable Instance AERR(1..) Using C_AERROR
Variable Char TBCLAFIND ()(1..)

Local Integer I,M

If find(ACLASSE,[L]TBCLAFIND)>0 : End : Endif
If find([L]WPTH+"."+[L]PTR,ASHW.PTHGRI)  : End : Endif
NBPTH +=1
ASHW.PTHGRI(NBPTH) = [L]WPTH+"."+[L]PTR
ASHW.INSGRI(NBPTH) = [L]PTR
ASHW.GRPGRI(NBPTH) = [L]WPTH+"."+[L]PTR : # [L]WGRP+string$([L]GROUPE<>"",".")+[L]GROUPE
If GROUPE<>""
 ASHW.ONE(NBPTH)    = 1
Else
 ASHW.ONE(NBPTH)    = 2
Endif
ASHW.ACLAGRI(NBPTH)  = NewInstance C_ACLA AllocGroup ASHW
Call CHARGE_ACLA(ACLASSE,0,ASHW.ACLAGRI(NBPTH),AERR) From ACLAVALLEC   : # Classe
Call CHARGE_ACLAF(ACLASSE,0,"", ASHW.ACLAGRI(NBPTH),AERR) From ACLAVALLEC
If maxtab(AERR)>0 : End : Endif

M=NBPTH
For I=1 To maxtab(ASHW.ACLAGRI(NBPTH).CODGRP)
  If ASHW.ACLAGRI(M).CRECLAGRP(I)=2
   NBPTH += 1
   ASHW.PTHGRI(NBPTH) = ASHW.PTHGRI(M) +"."+ASHW.ACLAGRI(M).CODGRP(I)
   ASHW.INSGRI(NBPTH) = ASHW.ACLAGRI(M).CODGRP(I)
   ASHW.GRPGRI(NBPTH) = ASHW.GRPGRI(M) +"."+ASHW.ACLAGRI(M).CODGRP(I)
   ASHW.ONE(NBPTH)    = 1
   ASHW.ACLAGRI(NBPTH) =  NewInstance C_ACLA AllocGroup ASHW
   ASHW.ACLAGRI(NBPTH).CODCLA = ASHW.ACLAGRI(M).CODCLA+"_"+ASHW.ACLAGRI(M).CODGRP(I)
   Call CHARGE_ACLA(ASHW.ACLAGRI(M).CODCLA,0,ASHW.ACLAGRI(NBPTH),AERR) From ACLAVALLEC   : # Classe
   Call CHARGE_ACLAF(ASHW.ACLAGRI(M).CODCLA,2,ASHW.ACLAGRI(M).CODGRP(I), ASHW.ACLAGRI(NBPTH),AERR) From ACLAVALLEC
   ASHW.ACLAGRI(NBPTH).NBRTRT = ASHW.ACLAGRI(M).NBRTRT
   For J=1 To  ASHW.ACLAGRI(NBPTH).NBRTRT
    ASHW.ACLAGRI(NBPTH).ACLATRT(J) = NewInstance C_ACLATRT AllocGroup ASHW
    ASHW.ACLAGRI(NBPTH).ACLATRT(J).RANTRT = ASHW.ACLAGRI(M).ACLATRT(J).RANTRT
    ASHW.ACLAGRI(NBPTH).ACLATRT(J).TYPTRT = ASHW.ACLAGRI(M).ACLATRT(J).TYPTRT
    ASHW.ACLAGRI(NBPTH).ACLATRT(J).CODTRT = ASHW.ACLAGRI(M).ACLATRT(J).CODTRT
    ASHW.ACLAGRI(NBPTH).ACLATRT(J).ACTTRT = ASHW.ACLAGRI(M).ACLATRT(J).ACTTRT
   Next
  Endif
 Next

Local Integer NOCLAFIND
NOCLAFIND=maxtab(TBCLAFIND)+1
[L]TBCLAFIND(NOCLAFIND) = ACLASSE
Local File =DOSSIER+".ACLAFLD"    [ACLAF9]
Local Integer N_ACLAF9
Local Char ACLAF9_FLDGRP(GLONAVA) (1..)
Local Char ACLAF9_FLDCLA(GLONAVA) (1..)
Local Char ACLAF9_LNKCLA(GLONACLA) (1..)
For [ACLAF9]ACLAF1 Where CODCLA=ACLASSE & LNKCLA<>""
 N_ACLAF9+=1
 ACLAF9_FLDGRP(N_ACLAF9)=[F:ACLAF9]FLDGRP
 ACLAF9_FLDCLA(N_ACLAF9)=[F:ACLAF9]FLDCLA
 ACLAF9_LNKCLA(N_ACLAF9)=[F:ACLAF9]LNKCLA
Next
Close Local File [ACLAF9]
For I=1 To N_ACLAF9
 #Call FIND_SUBCLASS(ACLAF9_FLDGRP(I),DOSSIER,WPTH+"."+PTR,WPTH+"."+GROUPE,ACLAF9_FLDCLA(I),ACLAF9_LNKCLA(I),NBPTH,ASHW,AERR,TBCLAFIND)
 Call FIND_SUBCLASS(ACLAF9_FLDGRP(I),DOSSIER,WPTH+"."+PTR,WPTH+"."+GROUPE,ACLAF9_FLDCLA(I),ACLAF9_LNKCLA(I),NBPTH,ASHW,AERR,TBCLAFIND)
Next
#On ne doit garder que les parents
[L]TBCLAFIND(NOCLAFIND) = ""
End

#---------------------------------------------------------------------------------------------------#
# Add ATT of links
#---------------------------------------------------------------------------------------------------#

Subprog ADD_ATT_LNK(OBJ,CODATT,VALATT)
Variable Instance OBJ Using OBJECT
Value Char CODATT
Value Char VALATT

If dim(OBJ.ATT)
 OBJ.ATT(maxtab(OBJ.ATT)+1) = NewInstance C_ASWATT AllocGroup OBJ
 OBJ.ATT(maxtab(OBJ.ATT)).COD = [L]CODATT
 OBJ.ATT(maxtab(OBJ.ATT)).ATT = [L]VALATT
Endif

End

#---------------------------------------------------------------------------------------------------#
# Add alias
#---------------------------------------------------------------------------------------------------#
$ADD_ALIAS
Raz ASWK_NBR
ASWR_NBR += 1
ASHW.ASWR(ASWR_NBR) = NewInstance C_ASWEXPPRO AllocGroup ASHW
SetInstance ASHW.ASWR(ASWR_NBR) With  [F:ASWR]
ASHW.ASWR(ASWR_NBR).INTITPRO= func ASYRFNC.TEXTE([F:ASWR]INTPRO)
[L]OKALIAS = 1
If ASHW.TEST>0 : Call ECR_TRACE("Alias :"-ASHW.ASWR(ASWR_NBR).ALIAS-" CODPRO = "-ASHW.ASWR(ASWR_NBR).CODPRO,0) From GESECRAN : Endif
Return

#---------------------------------------------------------------------------------------------------#
# Add path of properties ASW
#---------------------------------------------------------------------------------------------------#
$ADD_PTRASW
ASHW.ASWR(ASWR_NBR).GRIPRO = ""
J = instr(1,ASHW.ASWR(ASWR_NBR).CODPRO,'.')
If J
 ASHW.ASWR(ASWR_NBR).GRIPRO = left$(ASHW.ASWR(ASWR_NBR).CODPRO,J-1)
Endif
Return

#---------------------------------------------------------------------------------------------------#
# Add path of properties ACLA
#---------------------------------------------------------------------------------------------------#
$ADD_PTRCLA
ASHW.ASWR(ASWR_NBR).TYPCLA = 2
CHAINE = ASHW.ASWR(ASWR_NBR).CODPRO
J = instr(1,CHAINE,'.')
If J
 NBRTABCLA = 1
 TABCODCLA(NBRTABCLA) = ASHW.CODCLA
 ASHW.ASWR(ASWR_NBR).TABCODCLA(NBRTABCLA) = ASHW.CODCLA
 ASHW.ASWR(ASWR_NBR).PTRCLA(NBRTABCLA) = ASHW.ABRCLA
 CHAINE = right$(CHAINE,J+1)
 J = instr(1,CHAINE,'.')
 M = 0

 If J
  While J
   If func ACLAVALLEC.CRECLAGRPCOL(ASHW.ASWR(ASWR_NBR).TABCODCLA(NBRTABCLA),left$(CHAINE,J-1))<>2
    For [ACLAF] Where CODCLA = ASHW.ASWR(ASWR_NBR).TABCODCLA(NBRTABCLA) & FLDCLA= left$(CHAINE,J-1)
     NBRTABCLA += 1
     ASHW.ASWR(ASWR_NBR).TABCODCLA(NBRTABCLA) = [F:ACLAF]LNKCLA
     ASHW.ASWR(ASWR_NBR).PTRCLA(NBRTABCLA) = [F:ACLAF]FLDCLA
     M = 1
     Break
    Next
    If M
     Read [ACLA]ACLA0 = [ACLAF]CODCLA
     If !fstat & [F:ACLAF]FLDGRP<>""
       If ASHW.ASWR(ASWR_NBR).GRIPRO="" & [F:ACLAF]FLDGRP<>""
        ASHW.ASWR(ASWR_NBR).GRIPRO = ASHW.ABRCLA
       Endif
       ASHW.ASWR(ASWR_NBR).GRIPRO += string$([F:ACLAF]FLDGRP<>"",".")+[F:ACLAF]FLDGRP
       If ASHW.ASWR(ASWR_NBR).GRIPRO="" & [F:ACLAF]FLDGRP=""
        ASHW.ASWR(ASWR_NBR).GRIPRO = ASHW.ABRCLA
       Endif
     Else
      If ASHW.ASWR(ASWR_NBR).GRIPRO=""
       ASHW.ASWR(ASWR_NBR).GRIPRO = ASHW.ABRCLA
      Endif
      ASHW.ASWR(ASWR_NBR).GRIPRO += "."+left$(CHAINE,J-1)
     Endif
    Else
     If ASHW.ASWR(ASWR_NBR).GRIPRO=""
      ASHW.ASWR(ASWR_NBR).GRIPRO = ASHW.ABRCLA
     Endif
    Endif
   Else
    If ASHW.ASWR(ASWR_NBR).GRIPRO=""
     ASHW.ASWR(ASWR_NBR).GRIPRO = ASHW.ABRCLA
    Endif
    ASHW.ASWR(ASWR_NBR).GRIPRO += "."+left$(CHAINE,J-1)
   Endif
   CHAINE = right$(CHAINE,J+1)
   J = instr(1,CHAINE,'.')
  Wend
 Endif
 ASHW.ASWR(ASWR_NBR).FLDCLA = CHAINE
Endif
Return



#---------------------------------------------------------------------------------------------------#
# Add links
#---------------------------------------------------------------------------------------------------#
Subprog ADD_ASWK(DOSSIER,ASHW,ASWACTIONS,ASWK,ALIAS,LNK_PAG)
Value Char DOSSIER
Variable Instance ASHW Using C_ASW
Variable Instance ASWACTIONS(1..) Using C_ASWACTION
Variable Instance ASWK Using C_ASWLNK
Value Char ALIAS
Value Integer LNK_PAG

Local Integer ASWK_NBP,ASWK_KEY
Local Char TABCLA(80)(1..50)
Local Char TABPTR(80)(1..50),OBJ(50)
Local Integer NBCLA,OKALIAS,ISACTX

  SetInstance ASWK With  [F:ASWK]
  ASWK.INTITLNK= func ASYRFNC.TEXTE(ASWK.INTLNK)
  If ASWK.ANCLNK<>""
   Case [F:ASWK]AFFLNK
    When 1 : # propriété
     ASWK.ANCLNKREP = [L]ALIAS
    When 2 : # Ligne de collection
     ASWK.ANCLNKREP = ctrans(ASWK.ANCLNK,".","")
    When 3 : # Collection
     ASWK.ANCLNKREP =  ctrans(ASWK.ANCLNK,".","")
    When 4 : # page
    When 5 : # Fiche/Enregistrement.
   Endcase
  Endif
  #---
  ASWK.ORICODLNK=num$([F:ASWK0]AFFLNK)+'/'+[F:ASWK0]CODLNK
  Gosub CHARGE_ASWK_PARAM : #using [F:ASWK0] !! si AFFLNK modifié ou CODLNK
  #---
  If ASWK.TYPLNK  = 2 : # Méthodes
   #Call ADD_ATT_LNK(ASWK,func ASYRSUB.CODATT("H"),func ASYRSUB.BOOLEAN_TO_SYR(2))
   Call ADD_ATT_LNK(ASWK,func ASYRSUB.CODATT("r"),func ASYRSUB.BOOLEAN_TO_SYR(1))
   #Call ADD_ATT_LNK(ASWK,func ASYRSUB.CODATT("G"),func ASYRSUB.BOOLEAN_TO_SYR(1))
  Endif
  #Sur les STD, on affecte le code
  If [F:ASWK]FLGSTDLNK=2
    ASWK.CODLNK=ASWACTIONS([F:ASWK]CMPLNK).PROLNK
    If [L]LNK_PAG=2
     For AFAC=1 To 5
       If ASHW.ASWFAC(AFAC).AFFLNKFAC=5 & ASHW.ASWFAC(AFAC).LNKMENFAC=[F:ASWK]CODLNK
         ASHW.ASWFAC(AFAC).LNKMENFAC = ASWK.CODLNK
         ASHW.ASWFAC(AFAC).AFFLNKFAC = 4
       Endif
     Next
    Elsif ASWK.AFFLNK=4
     For AFAC=1 To 5
       If ASHW.ASWFAC(AFAC).AFFLNKFAC = ASWK.AFFLNK & ASHW.ASWFAC(AFAC).LNKMENFAC=[F:ASWK]CODLNK
         ASHW.ASWFAC(AFAC).LNKMENFAC = ASWK.CODLNK
       Endif
     Next
    Endif
  Elsif [L]LNK_PAG=2
    ASWK.CODLNK+="_LIG"+string$(GLONAVA-len(ASWK.CODLNK),"4") : #il faut modifier le code pour garder unicité
    For AFAC=1 To 5
      If ASHW.ASWFAC(AFAC).AFFLNKFAC=5 & ASHW.ASWFAC(AFAC).LNKMENFAC=[F:ASWK]CODLNK
       ASHW.ASWFAC(AFAC).LNKMENFAC = ASWK.CODLNK
       ASHW.ASWFAC(AFAC).AFFLNKFAC = 4
      Endif
    Next
  Endif
  #le lien par défaut, ne doit pas avoir de menu
  If ASWK.AFFLNK=4 & ASWK.MENLNK<>""
    For AFAC=1 To 5
      If ASHW.ASWFAC(AFAC).AFFLNKFAC = ASWK.AFFLNK & ASHW.ASWFAC(AFAC).LNKMENFAC=ASWK.CODLNK
       ASHW.ASWFAC(AFAC).LNKMENFAC = ""
       ASHW.ASWFAC(AFAC).AFFLNKFAC = 0
      Endif
    Next
  Endif
  #Retour des methodes et opérations
  If [F:ASWK]CODMETLNK<>"" or  [F:ASWK]CODOPELNK<>""
    If [F:ASWK]CODOPELNK<>""
      Read [ACLAM]ACLAM0 = [F:ASWK]CLALNK;[F:ASWK]CODOPELNK
      If !fstat
        ASWK.TYPRETMET = [F:ACLAM]DONMET
      Endif
    Else
      If [F:ASWK]CLALNK<>""
        Read [ACLAM]ACLAM0 = [F:ASWK]CLALNK;[F:ASWK]CODMETLNK
        If !fstat
          ASWK.TYPRETMET = [F:ACLAM]DONMET
        Endif
      Else
        Read [ASWM]ASWM0 = [F:ASWK]CODREP;[F:ASWK]CODMETLNK
        If !fstat
          ASWK.TYPRETMET = [F:ASWM]DONMET
        Endif
      Endif
    Endif
  Endif
End

#------------------------------------
Funprog FVALKEY(VALEUR,TYPINT)
Value Char VALEUR
Value Integer TYPINT
Local Date VALDAT
Local Integer ERR

   If [L]VALEUR=""
     End ""
#  "AVOID.ADATE","AVOID.ADATTIM"
   Elsif find([L]VALEUR,[V]CST_INSTANCE_AISNULL_NAME+"."+[V]CST_LIST_AISNULL_PRO_NAME(5),[V]CST_INSTANCE_AISNULL_NAME+"."+[V]CST_LIST_AISNULL_PRO_NAME(11))
#     End "00000000"
     End ""
   Elsif toupper(left$([L]VALEUR,6)) = [V]CST_INSTANCE_AISNULL_NAME+"." # "AVOID."
     End num$(evalue([L]VALEUR))
   Elsif left$([L]VALEUR,1)="'" | left$([L]VALEUR,1)='"'
     End num$(evalue([L]VALEUR))
   Elsif [L]TYPINT=8 : #AML10030 : date saisie YYYYMMDD sans "
     If [L]VALEUR="000000" | [L]VALEUR="00000000"
       End ""
     Endif
     Onerrgo ERR_EVAL
     VALDAT = gdat$([L]VALEUR)
     Onerrgo
     If ERR
       End [L]VALEUR
     Elsif len([L]VALEUR)=8
       End left$([L]VALEUR,4)+"-"+mid$([L]VALEUR,5,2)+"-"+right$([L]VALEUR,7)
     Else
       End [L]VALEUR
     Endif
   Else
#     End num$(evalue([L]VALEUR))
     End [L]VALEUR
   Endif
End ""
#------------------------------------
Funprog FVALPAR(VALEUR,TYPINT)
Value Char VALEUR
Value Integer TYPINT
Local Date VALDAT
Local Integer ERR

   If [L]VALEUR=""
     End ""
#  "AVOID.ADATE","AVOID.ADATTIM"
   Elsif find([L]VALEUR,[V]CST_INSTANCE_AISNULL_NAME+"."+[V]CST_LIST_AISNULL_PRO_NAME(5),[V]CST_INSTANCE_AISNULL_NAME+"."+[V]CST_LIST_AISNULL_PRO_NAME(11))
     End '""'
   Elsif toupper(left$([L]VALEUR,6)) = [V]CST_INSTANCE_AISNULL_NAME+"." # "AVOID."
     If num$(evalue([L]VALEUR))=""
      End '""'
     Else
      End num$(evalue([L]VALEUR))
     Endif
   Elsif left$([L]VALEUR,1)="'" | left$([L]VALEUR,1)='"'
     If num$(evalue([L]VALEUR))=""
      End '""'
     Else
      End num$(evalue([L]VALEUR))
     Endif
   Elsif [L]TYPINT=8 : #AML10030 : date saisie YYYYMMDD sans "
     If [L]VALEUR="000000" | [L]VALEUR="00000000"
       End '""'
     Endif
     Onerrgo ERR_EVAL
     VALDAT = gdat$([L]VALEUR)
     Onerrgo
     If ERR
       End [L]VALEUR
     Elsif len([L]VALEUR)=8
       End left$([L]VALEUR,4)+"-"+mid$([L]VALEUR,5,2)+"-"+right$([L]VALEUR,7)
     Else
       End [L]VALEUR
     Endif
   Else
#     End num$(evalue([L]VALEUR))
     End [L]VALEUR
   Endif
End ""

$ERR_EVAL
ERR=1
Resume

#------------------------------------
$CHARGE_ASWK_PARAM
  Raz ASWK_NBP,ASWK_KEY
  For [ASWP]ASWP1 Where CODREP=ASHW.CODREP & CODFLD=[F:ASWK0]ANCLNK & CODLNK=[F:ASWK0]CODLNK & AFFLNK=[F:ASWK0]AFFLNK & [ASWP]TYPPAR=3
   If [ASWP]TYPKEY<>2
    ASWK_NBP += 1
    ASWK.ATBPAR(ASWK_NBP) = NewInstance C_ASWPAR  AllocGroup ASWK
    SetInstance ASWK.ATBPAR(ASWK_NBP) With  [ASWP]
    ASWK.ATBPAR(ASWK_NBP).MODPAR = [ASWP]ADRVAL : # ccl
    If [F:ASWP]TYPAFF=2 | [F:ASWK0]TYPLNK=1
     Case [F:ASWK0]TYPLNK
      When 1 :
       If ASWK.REPLNK<>""
        If ASWK.REPLNK=ASHW.CODREP
           Read [ASWR2]ASWR0 = ASHW.CODREP;ASWK.ATBPAR(ASWK_NBP).CODPAR
           If !fstat
            If [F:ASWP]TYPAFF=2 :ASWK.ATBPAR(ASWK_NBP).DESPAR = [F:ASWR2]INTPRO : Endif
            If [F:ASWP]PARFIL=2
             If left$([F:ASWR2]CODPRO,len(ASHW.ABRCLA+"."))=ASHW.ABRCLA+"."
              #97306 ASWK.ATBPAR(ASWK_NBP).FILCODPAR = right$([F:ASWR2]CODPRO,len(ASHW.ABRCLA+".")+1)
              ASWK.ATBPAR(ASWK_NBP).FILCODPAR = [F:ASWR2]ALIAS
             Endif
            Endif
           Endif
        Elsif ASWK.REPLNK=[F:ASW2]CODREP
           Read [ASWR2]ASWR0 = [F:ASW2]CODREP;ASWK.ATBPAR(ASWK_NBP).CODPAR
           If !fstat
            If [F:ASWP]TYPAFF=2 :ASWK.ATBPAR(ASWK_NBP).DESPAR = [F:ASWR2]INTPRO : Endif
            If [F:ASWP]PARFIL=2
             If left$([F:ASWR2]CODPRO,len([F:ASW2]ABRCLA+"."))=[F:ASW2]ABRCLA+"."
              #97306 ASWK.ATBPAR(ASWK_NBP).FILCODPAR = right$([F:ASWR2]CODPRO,len([F:ASW2]ABRCLA+".")+1)
              ASWK.ATBPAR(ASWK_NBP).FILCODPAR = [F:ASWR2]ALIAS
             Endif
            Endif
           Endif
        Else
          Read [F:ASW2]ASW0 = ASWK.REPLNK
          If fstat
            Raz [F:ASW2]
          Else
           Read [ASWR2]ASWR0 = [F:ASW2]CODREP;ASWK.ATBPAR(ASWK_NBP).CODPAR
           If !fstat
            If [F:ASWP]TYPAFF=2 :ASWK.ATBPAR(ASWK_NBP).DESPAR = [F:ASWR2]INTPRO : Endif
            If [F:ASWP]PARFIL=2
             If left$([F:ASWR2]CODPRO,len([F:ASW2]ABRCLA+"."))=[F:ASW2]ABRCLA+"."
              #97306 ASWK.ATBPAR(ASWK_NBP).FILCODPAR = right$([F:ASWR2]CODPRO,len([F:ASW2]ABRCLA+".")+1)
              ASWK.ATBPAR(ASWK_NBP).FILCODPAR = [F:ASWR2]ALIAS
             Endif
            Endif
           Endif
          Endif
        Endif
       Endif
      When 2 : # Methode
      ASWK.ATBPAR(ASWK_NBP).DESPAR = func READ_PARMET_ATX([L]DOSSIER,[F:ASWK]CLAPTRLNK,[F:ASWK]CLALNK,[F:ASWK]CODMETLNK,[F:ASWK]CODREP,[F:ASW]CODCLA,[F:ASWP]CODPAR)
      When 3 : # operation
      ASWK.ATBPAR(ASWK_NBP).DESPAR = func READ_PARMET_ATX([L]DOSSIER,[F:ASWK]CLAPTRLNK,[F:ASWK]CLALNK,[F:ASWK]CODOPELNK,[F:ASWK]CODREP,[F:ASW]CODCLA,[F:ASWP]CODPAR)
     Endcase
    Endif
    WPTHPRO = ASWK.ATBPAR(ASWK_NBP).VALEUR
    If left$(WPTHPRO,6)="=num$("
      ASWK.ATBPAR(ASWK_NBP).VALEUR = mid$(WPTHPRO,7,len(WPTHPRO)-7)
    Elsif left$(WPTHPRO,5)="=val("
      ASWK.ATBPAR(ASWK_NBP).VALEUR = mid$(WPTHPRO,6,len(WPTHPRO)-6)
    Endif
    WPTHPRO = ASWK.ATBPAR(ASWK_NBP).VALEUR
    If  (!instr(1,WPTHPRO,".") or (instr(1,WPTHPRO,".")>0  & left$(WPTHPRO,instr(1,WPTHPRO,".")-1)<>ASHW.ABRCLA)): # Propriete propre representation
     WPTHPRO = ASWK.ATBPAR(ASWK_NBP).VALEUR
    Else
     WPTHPRO = func PATHCLAPRO(ASWK.ATBPAR(ASWK_NBP).VALEUR)
     WCHAINE = ASWK.ATBPAR(ASWK_NBP).VALEUR
     K=instr(1,WCHAINE,".")
     While K>0
      WCHAINE = right$(WCHAINE,K+1)
      K=instr(1,WCHAINE,".")
     Wend
     WPTHPRO += WCHAINE
    Endif
    Read [ASWR2]ASWR3 = ASHW.CODREP;WPTHPRO
    If !fstat
     If instr(1,[F:ASWR2]CODPRO,".")  & !find(left$([F:ASWR2]CODPRO,instr(1,[F:ASWR2]CODPRO,".")-1),ASHW.CODGRP) : #  Propriété de classe
      Raz TABPTR,TABCLA,OBJ,ISACTX,NBCLA
      Call DECODE_PRO([F:ASWR2]CODPRO,0,"PRO",[L]DOSSIER,ASHW.CODREP,ASHW.ABRCLA,ASHW.CODCLA,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
      If NBCLA>=1
       Read [ACLAF]ACLAF0 = TABCLA(NBCLA);OBJ
       If !fstat
        ASWK.ATBPAR(ASWK_NBP).ALIAS = [F:ASWR2]ALIAS
       Endif
      Endif
     Else
      If instr(1,[F:ASWR2]CODPRO,".")>0
       Read [F:ASWF]ASWF0 = ASHW.CODREP;right$([F:ASWR2]CODPRO,instr(1,[F:ASWR2]CODPRO,".")+1)
      Else
       Read [F:ASWF]ASWF0 = ASHW.CODREP;[F:ASWR2]CODPRO
      Endif
      If !fstat
       ASWK.ATBPAR(ASWK_NBP).ALIAS = [F:ASWR2]ALIAS
      Endif
     Endif
    Else
      ASWK.ATBPAR(ASWK_NBP).VALEUR=func FVALPAR(ASWK.ATBPAR(ASWK_NBP).VALEUR,ASWK.ATBPAR(ASWK_NBP).TYPINT)
    Endif
   Else
    ASWK_KEY += 1
    ASWK.ATBKEY(ASWK_KEY) = NewInstance C_ASWPAR   AllocGroup ASWK
    SetInstance ASWK.ATBKEY(ASWK_KEY) With  [ASWP]
    ASWK.ATBKEY(ASWK_KEY).MODPAR = [ASWP]ADRVAL : # ccl
    If ASWK.REPLNK<>""
     If ASWK.REPLNK=ASHW.CODREP
        Read [ASWR2]ASWR3 = ASHW.CODREP;ASHW.ABRCLA+"."+ASWK.ATBKEY(ASWK_KEY).CODPAR
        If !fstat
         ASWK.ATBKEY(ASWK_KEY).LOO = [F:ASWR2]ALIAS
         If [F:ASWP]TYPAFF=2 : ASWK.ATBKEY(ASWK_KEY).DESPAR = [F:ASWR2]INTPRO : Endif
        Endif
     Elsif ASWK.REPLNK=[F:ASW2]CODREP
        Read [ASWR2]ASWR3 = [F:ASW2]CODREP;[F:ASW2]ABRCLA+"."+ASWK.ATBKEY(ASWK_KEY).CODPAR
        If !fstat
         ASWK.ATBKEY(ASWK_KEY).LOO = [F:ASWR2]ALIAS
         If [F:ASWP]TYPAFF=2 : ASWK.ATBKEY(ASWK_KEY).DESPAR = [F:ASWR2]INTPRO : Endif
        Endif
     Else
       Read [F:ASW2]ASW0 = ASWK.REPLNK
       If fstat
         Raz [F:ASW2]
       Else
        Read [ASWR2]ASWR3 = [F:ASW2]CODREP;[F:ASW2]ABRCLA+"."+ASWK.ATBKEY(ASWK_KEY).CODPAR
        If !fstat
         ASWK.ATBKEY(ASWK_KEY).LOO = [F:ASWR2]ALIAS
         If [F:ASWP]TYPAFF=2 : ASWK.ATBKEY(ASWK_KEY).DESPAR = [F:ASWR2]INTPRO : Endif
        Endif
       Endif
     Endif
    Endif
    WPTHPRO = ASWK.ATBKEY(ASWK_KEY).VALEUR
    If left$(WPTHPRO,6)="=num$("
      ASWK.ATBKEY(ASWK_KEY).VALEUR = mid$(WPTHPRO,7,len(WPTHPRO)-7)
    Elsif left$(WPTHPRO,5)="=val("
      ASWK.ATBKEY(ASWK_KEY).VALEUR = mid$(WPTHPRO,6,len(WPTHPRO)-6)
    Endif
    WPTHPRO = ASWK.ATBKEY(ASWK_KEY).VALEUR
    If  (!instr(1,WPTHPRO,".") or (instr(1,WPTHPRO,".")>0  & left$(WPTHPRO,instr(1,WPTHPRO,".")-1)<>ASHW.ABRCLA)): # Propriete propre representation
     WPTHPRO = ASWK.ATBKEY(ASWK_KEY).VALEUR
    Else
     WPTHPRO = func PATHCLAPRO(ASWK.ATBKEY(ASWK_KEY).VALEUR)
     WCHAINE = ASWK.ATBKEY(ASWK_KEY).VALEUR
     K=instr(1,WCHAINE,".")
     While K>0
      WCHAINE = right$(WCHAINE,K+1)
      K=instr(1,WCHAINE,".")
     Wend
     WPTHPRO += WCHAINE
    Endif
    Read [ASWR2]ASWR3 = ASHW.CODREP;WPTHPRO
    If !fstat
     If instr(1,[F:ASWR2]CODPRO,".")  & !find(left$([F:ASWR2]CODPRO,instr(1,[F:ASWR2]CODPRO,".")-1),ASHW.CODGRP) : #  Propriété de classe
      Call DECODE_PRO([F:ASWR2]CODPRO,0,"PRO",[L]DOSSIER,ASHW.CODREP,ASHW.ABRCLA,ASHW.CODCLA,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
      If NBCLA>=1
       Read [ACLAF]ACLAF0 = TABCLA(NBCLA);OBJ
       If !fstat
        ASWK.ATBKEY(ASWK_KEY).ALIAS = [F:ASWR2]ALIAS
       Endif
      Endif
     Else
      If instr(1,[F:ASWR2]CODPRO,".")>0
       Read [F:ASWF]ASWF0 = ASHW.CODREP;right$([F:ASWR2]CODPRO,instr(1,[F:ASWR2]CODPRO,".")+1)
      Else
       Read [F:ASWF]ASWF0 = ASHW.CODREP;[F:ASWR2]CODPRO
      Endif
      If !fstat
       ASWK.ATBKEY(ASWK_KEY).ALIAS = [F:ASWR2]ALIAS
      Endif
     Endif
    Else
      ASWK.ATBKEY(ASWK_KEY).VALEUR=func FVALKEY(ASWK.ATBKEY(ASWK_KEY).VALEUR,ASWK.ATBKEY(ASWK_KEY).TYPINT)
    Endif
   Endif
  Next
Return

#############################################################################################
Funprog READ_PARMET_ATX(DOSSIER,ACLAPTR,ALNKCLA,AMETHOD,CODREP1,CODCLA1,CODPAR)
Value Char    DOSSIER
Value Char    ACLAPTR
Value Char    ALNKCLA
Value Char    AMETHOD
Value Char    CODREP1
Value Char    CODCLA1
Value Char    CODPAR

Local Char TABCLA(80)(1..50),TABPTR(80)(1..50),OBJ(50),TABREF(GLONAVB)(1..)
Local Integer NBCLA,WNUM,ISACTX,J

If [L]ACLAPTR<>""  : #method of a class of the representation (base)
 Call DECODE_PRO([L]ACLAPTR,0,"PTR",[L]DOSSIER,[L]CODREP1,"",[L]CODCLA1,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
 If NBCLA>0
  Read [ACLPD]ACLPD0=TABCLA(NBCLA);[L]AMETHOD;[L]CODPAR
  If !fstat
   End [F:ACLPD]INTPAR
  Endif
 Endif
Elsif [L]ALNKCLA="" : #method of representation (base)
  Read [ASWMP]ASWMP0=[L]CODREP1;[L]AMETHOD;[L]CODPAR
  If !fstat
   End [F:ASWMP]INTPARMET
  Endif
Elsif [L]ALNKCLA<>"" : #Operation from another class (base)
  Read [ACLPD]ACLPD0=[L]ALNKCLA;[L]AMETHOD;[L]CODPAR
  If !fstat
   End [F:ACLPD]INTPAR
  Endif
Endif

End 0

#---------------------------------------------------------------------------------------------------#
# Funprog to find the path of propertie
#---------------------------------------------------------------------------------------------------#
Funprog PATHCLAPRO(PATH)
Value Char PATH
Local Char PTHCLA(250)
Local Integer I
I = instr(1,PATH,".")
While I
 PTHCLA += left$(PATH,I)
 PATH = right$(PATH,I+1)
 I = instr(1,PATH,".")
Wend
If right$(PTHCLA,len(PTHCLA))="."
 PTHCLA=mid$(PTHCLA,1,len(PTHCLA)-1)
Endif
If PTHCLA<>""
 PTHCLA += "."
Endif
End PTHCLA

#---------------------------------------------------------------------------------------------------#
# Charge field PTHGRP
#---------------------------------------------------------------------------------------------------#
Subprog CHARGE_PTHGRP(PTHGRP,FLDGRP,CLAFLD,CODCLA,ABRCLA,TABPTR,NBCLA)
Variable Char PTHGRP
Value Char FLDGRP
Value Char CLAFLD
Value Char CODCLA
Value Char ABRCLA
Value Char TABPTR()(1..)
Value Integer NBCLA

Local Integer I

If [L]FLDGRP<>""
 [L]PTHGRP = ABRCLA
 If [L]CODCLA<>[L]CLAFLD
  For I=1 To [L]NBCLA
   [L]PTHGRP += string$([L]TABPTR(I)<>"",".")+[L]TABPTR(I)
  Next
 Endif
 [L]PTHGRP += string$([L]FLDGRP<>"",".")+[L]FLDGRP
Endif
End

#---------------------------------------------------------------------------------------------------#
# Test if i need trt WMRS
#---------------------------------------------------------------------------------------------------#
$TESTNEEDWMRS
Local Integer TESTWMRS,TESTMETREAD
For MT=1 To maxtab(ASHW.ACLA.ACLAT)
 Case ASHW.ACLA.ACLAT(MT).CODMETSTD
  When "R" : TESTMETREAD = 1
 Endcase
Next
If TESTWMRS=0
 If ASHW.AFCRIGHT<>""
  For I=1 To maxtab(ASHW.ASWR)
   If ASHW.ASWR(I).ACLAF.ATY.CODTYP ="FCY" : TESTWMRS = 1 : Break : Endif
   If TESTWMRS=0
    If ASHW.ASWR(I).ACLAF.ATY.CODTYP ="CPY" : TESTWMRS=1 : Break : Endif
   Endif
  Next
 Endif
Endif
If TESTWMRS=0 & TESTMETREAD=1
 For MT=1 To maxtab(ASHW.ACLA.ACLAK)
  For M=1 To maxtab(ASHW.ACLA.ACLAK(MT).ACLALNK.ACLAF)
   If ASHW.ACLA.ACLAK(MT).ACLALNK.ACLAF(M).ACS<>""
    TESTWMRS=1 : Break 2
   Endif
  Next
 Next
Endif
If TESTWMRS=0
 For MT=1 To maxtab(ASHW.ACLA.ACLAF)
  If ASHW.ACLA.ACLAF(MT).FLDCLA="ENAFLG"
   TESTWMRS=1
  Endif
 Next
Endif
If TESTWMRS=1 : ASHW.ACLAV.TRTCTLSUP  = func GETPREFIXTRTCTLSUP+ASHW.CODREP : Endif
Return

