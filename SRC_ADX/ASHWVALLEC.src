    LNK_SAVE.ALNK(ACT_LNK).ATBKEY(ASWK_KEY).PARFIL=LNK_Q.ATBKEY(ASWK_KEY).PARFIL
    LNK_SAVE.ALNK(ACT_LNK).ATBKEY(ASWK_KEY).PARENT=LNK_Q.ATBKEY(ASWK_KEY).PARENT
   Next ASWK_KEY
