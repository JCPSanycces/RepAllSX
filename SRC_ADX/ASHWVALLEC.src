#<AdxTL>@(#)11.0.0.0 $Revision$
Gosub TEST From ASHWVAL
End

#---------------------------------------------------------------------------------------------------#
## Loading of the structure representation
#---------------------------------------------------------------------------------------------------#
Subprog LOAD_REP(TEST,DOSSIER,CODREP,TYPGEN,NAMCOL,ASHW,AERR)
Value Integer    TEST
Value Char DOSSIER
Value Char CODREP
Value Integer TYPGEN
Value Char NAMCOL
Variable  Instance  ASHW Using C_ASW
Variable  Instance  AERR(1..) Using C_AERROR
Local Char CODCLA(GLONACLA)
Gosub OPEN_FILE
Gosub DEFVAR
Gosub LOAD
Gosub CLOSE_FILE
End

#---------------------------------------------------------------------------------------------------#
## Class load All with sub collections
#---------------------------------------------------------------------------------------------------#
Subprog LOAD_REP_COL(TEST,DOSSIER,CODREP,ASHW,AERR)
Value Integer TEST
Value Char DOSSIER , CODREP
Variable  Instance  ASHW  Using C_ASW
Variable  Instance  AERR(1..) Using C_AERROR
Local File =DOSSIER+".ASHW"        [ASW]
Gosub DEFVAR
Read [ASW]ASW0 = [L]CODREP
If fstat
 Close Local File [ASW]
Else
 Close Local File [ASW]
 Call LOAD_REP(TEST,DOSSIER,CODREP,1,"",ASHW,AERR)
 For I=1 To ASHW.NBRGRP
  If ASHW.CRECLAGRP(I)=2
   ASHW.ASHWCOL(I)  = NewInstance C_ASW AllocGroup ASHW
   Call INI_ACLAVARDEF([L]CODREP+"_"+ASHW.ALIASGRP(I),DOSSIER,ASHW.ASHWCOL(I),AERR) From ASHWVALLEC
   Call LOAD_REP(TEST,DOSSIER,[L]CODREP+"_"+ASHW.ALIASGRP(I),2,ASHW.CODGRP(I),ASHW.ASHWCOL(I),AERR)
  Endif
 Next
Endif
End

#---------------------------------------------------------------------------------------------------#
## Lecture de la representation en mémoire
#---------------------------------------------------------------------------------------------------#

$LOAD

If TEST : Call ECR_TRACE("- Load representation :"-[L]CODREP,0) From GESECRAN : Endif

Call CHARGE_ASHW([L]DOSSIER,[L]CODREP,[L]TEST,[L]TYPGEN,ASHW,AERR) : # Representation entete
If maxtab(AERR)>0 : Return : Endif

ASHW.ACLA  = NewInstance C_ACLA  AllocGroup ASHW
If find(TYPGEN,0,1)>0
 Call LOAD_CLASSE(ASHW.TEST,DOSSIER,ASHW.CODCLA,0,"",ASHW.ACLA,AERR) From ACLAVALLEC : #
 If maxtab(AERR)>0  : Return : Endif
 Call INI_ACLAVARDEF(ASHW.CODCLA,DOSSIER,ASHW.ACLA,AERR) From ACLAVALLEC
 If maxtab(AERR)>0  : Return : Endif
Endif

Call CHARGE_ASHWF([L]CODREP,[L]TYPGEN,[L]NAMCOL,ASHW,AERR)     : # Champs
If maxtab(AERR)>0 : Return : Endif

If TYPGEN =2  : Return Endif

Gosub CHARGE_ACLAM                                  : # Methodes
If maxtab(AERR)>0 : Return : Endif

Gosub CHARGE_ASWG                                  : # Organisation
If maxtab(AERR)>0 : Return : Endif

Gosub CHARGE_ASWR                                   : # Proprités expose
If maxtab(AERR)>0 : Return : Endif

Gosub CHARGE_ASWMN                                  : # Menus (necessaires dans CHARGE_ASWK)
If maxtab(AERR)>0 : Return : Endif

Gosub CHARGE_ASWK                                   : # Liens
If maxtab(AERR)>0 : Return : Endif

Gosub CHARGE_ASWFAC                                 : # Menus/facette selon les liens
If maxtab(AERR)>0 : Return : Endif

Gosub CHARGE_KEYREP
If maxtab(AERR)>0 : Return : Endif

Call CHARGE_GRP([L]CODREP,ASHW,AERR) From ACLAVALLEC
If maxtab(AERR)>0  : Return : Endif

Return

#---------------------------------------------------------------------------------------------------#
## Open tables
#---------------------------------------------------------------------------------------------------#

$OPEN_FILE
# Tables Data
Gosub OPEN_FILE From ACLAVALLEC

If dim([L]TEST)>0 & [L]TEST : Call ECR_TRACE("- Open tables for representation",0) From GESECRAN : Endif

# Tables representation
Local File =DOSSIER+".ASHW"        [ASW]
Local File =DOSSIER+".ASHW"        [ASW2]
Local File =DOSSIER+".ASHWFLD"     [ASWF]
Local File =DOSSIER+".ASHWFLD"     [ASWF2]
Local File =DOSSIER+".ASHWFLD"     [ASWF3]
Local File =DOSSIER+".ASHWMET"     [ASWM]
Local File =DOSSIER+".ASHWPARMET"  [ASWMP]
Local File =DOSSIER+".ASHWEXPPRO"  [ASWR]
Local File =DOSSIER+".ASHWEXPPRO"  [ASWR2]
Local File =DOSSIER+".ASHWOPT"     [ASWO]
Local File =DOSSIER+".ASHWCOL"     [ASWC]
Local File =DOSSIER+".ASHWSEC"     [ASWS]
Local File =DOSSIER+".ASHWBLC"     [ASWB]
Local File =DOSSIER+".ASHWLNK"     [ASWK]
Local File =DOSSIER+".ASHWLNK"     [ASWK0]
Local File =DOSSIER+".ASHWLNK"     [ASWK2]
Local File =DOSSIER+".ASHWPAR"     [ASWP]
Local File =DOSSIER+".ASHWMENU"    [ASWMN]

Return

$CLOSE_FILE
Close Local File
Return

#---------------------------------------------------------------------------------------------------#
## Declaration of variables
#---------------------------------------------------------------------------------------------------#

$DEFVAR
If dim([L]TEST)>0 & [L]TEST : Call ECR_TRACE("- Declaration of variables : Representation",0) From GESECRAN : Endif

Gosub DEFVAR From ACLAVALLEC

Local Schar   NOMTRTREP(GLONADC),NOMTRTQRY(GLONADC)
Local Schar   IDENTTRT(30),IDENTQRY(30)
Local Integer ASWR_NBR,ASWG_NBR,ASWK_NBR,ACLAM_NBP,ASWK_NBP,ASWK_KEY
Local Integer NBRTABCLA,AFAC
Local Schar   CRITASWR(30)
Local Schar   WABRUSED(GLONABR)(1..50),WINSUSED(GLONAVA)(1..50)
Local Schar   WTBLUSED(GLONATB)(1..50)
Local Char    WPTHUSED(250)(1..50),WCLAUSED(GLONACLA)(1..50)
Local Integer WTRANSUSED(1..50),NBABRUSED
Local Char    WFLDCLB(GLONAVA)(1..10,1..10)
Local Char   TABCODCLA(GLONACLA)(1..)

Return

Subprog INI_ACLAVARDEF(CODREP,DOSSIER,ACLA,AERR)
Value Char CODREP
Value Char DOSSIER
Variable  Instance  ACLA  Using OBJECT
Variable  Instance  AERR Using C_AERROR

Call INI_ACLAVARDEF(CODREP,DOSSIER,ACLA,AERR) From ACLAVALLEC
ACLA.ACLAV.NOMSTC    = func SUBASW.PREFIX_REP+[L]CODREP

ACLA.ACLAV.TRTCRUD   = func APREFIXTRT.GET_PREFIX_REP_CRUD+[L]CODREP
ACLA.ACLAV.IDENTREP = "##"-func SUBASW.PREFIX_TRT-"REPRESENTATION ##"
ACLA.ACLAV.IDENTQRY= "##"-func SUBASW.PREFIX_TRT-"REPRESENTATION ##"
ACLA.ACLAV.VARREP     = "REP" : # Nom de l'instance representation
ACLA.ACLAV.ABRFRE     = "REP" : # Abreviation utilise pr l'instance en memoire

ACLA.ACLAV.IDENTWML  = "## CRUD-REP ##"
ACLA.ACLAV.TRTCRUD         = func APREFIXTRT.GET_PREFIX_REP_CRUD+[L]CODREP
ACLA.ACLAV.TRTCRUDREAD   = func ACLAVALCRUD.GET_PREFIX_REP_READ+[L]CODREP
ACLA.ACLAV.TRTCRUDUPD    = func ACLAVALCRUD.GET_PREFIX_REP_UPD+[L]CODREP
ACLA.ACLAV.TRTCRUDDEL    = func ACLAVALCRUD.GET_PREFIX_REP_DEL+[L]CODREP
ACLA.ACLAV.TRTCRUDCRE    = func ACLAVALCRUD.GET_PREFIX_REP_CRE+[L]CODREP

End


#---------------------------------------------------------------------------------------------------#
## Max properties in a treatment WMRS_
#---------------------------------------------------------------------------------------------------#
Funprog GETPREFIXTRTCTLSUP
End func APREFIXTRT.GET_PREFIX_REP+"S_"

#---------------------------------------------------------------------------------------------------#
# Charge representation : General
#---------------------------------------------------------------------------------------------------#
Subprog CHARGE_ASHW(DOSSIER,CODREP,TEST,TYPGEN,ASHW,AERR)
Value Char DOSSIER
Value Char CODREP
Value Integer TEST
Value Integer TYPGEN
Variable  Instance  ASHW Using C_ASW
Variable  Instance  AERR(1..) Using C_AERROR

Local Integer NBPTH,NBCLE,AFAC
Local Char    CLE(GLONAVB)(1..)

Read [F:ASW]ASW0= func ACLAVALLEC.GETNAMCLA(TYPGEN,[L]CODREP)
If !fstat
 SetInstance ASHW With [F:ASW]
 ASHW.CODREP = [L]CODREP
 ASHW.CODECLA =  ASHW.CODREP
  If instr(1,[L]CODREP,"_")>0
  ASHW.CODESUBCLA = right$( [L]CODREP,instr(1, [L]CODREP,"_")+1)
 Endif
 ASHW.INTITREP = func ASYRFNC.TEXTE(ASHW.INTREP)
 ASHW.INTITCLA = ASHW.INTITREP


If ASHW.CODIND<>""
 Read [F:ACLA]ACLA0 = ASHW.CODCLA
 If !fstat
  Read [ATI]CODIND=[F:ACLA]TABREF;ASHW.CODIND
  If !fstat
   ASHW.DESCRIPT=[ATI]DESCRIPT
  Endif
 Endif
Endif

 If ASHW.AFCRIGHT<>""
  Read [AFC]CODINT=ASHW.AFCRIGHT
  If !fstat & [F:AFC]ACTION="GOBJET"
   If [F:AFC]VALPAR(0)<>""
    Read [AOB]ABREV=evalue([F:AFC]VALPAR(0))
    If !fstat
     ASHW.AOBRIGHT = [AOB]ABREV
    Endif
   Endif
  Endif
 Endif

 For AFAC=1 To 5
  If ASHW.ENAFAC(AFAC)=0 :ASHW.ENAFAC(AFAC) += 1 : Endif
 Next

 For AFAC=1 To 5
   ASHW.ASWFAC(AFAC) = NewInstance C_ASWFAC AllocGroup ASHW
   ASHW.ASWFAC(AFAC).CODFAC = AFAC
   ASHW.ASWFAC(AFAC).ENAFAC = [F:ASW]ENAFAC(AFAC-1)
   If ASHW.ASWFAC(AFAC).ENAFAC=0 : ASHW.ASWFAC(AFAC).ENAFAC += 1 : Endif
   If func AFNC.ACTIV([F:ASW]ACTLNKFAC(AFAC-1))
    ASHW.ASWFAC(AFAC).DEFLNKFAC = [F:ASW]DEFLNKFAC(AFAC-1)
    ASHW.ASWFAC(AFAC).AFFLNKFAC = [F:ASW]AFFLNKFAC(AFAC-1)
    ASHW.ASWFAC(AFAC).LNKMENFAC = [F:ASW]LNKMENFAC(AFAC-1)
    ASHW.ASWFAC(AFAC).ACTLNKFAC = [F:ASW]ACTLNKFAC(AFAC-1)
    Call DEFLNKFAC(AFAC,ASHW,ASHW.ASWFAC(AFAC)) From SUBASW
   Endif
 Next

 # Par defaut TEST = 0 : TEST = 1 pour une trace
 ASHW.TEST = [L]TEST
 ASHW.TYPCLA = -1
 ASHW.FLGACTX = 1
 ASHW.FLGBUFFER = 1
 # Pour l'odre des trt
 Sorta [F:ASW]NBRTRT [F:ASW]RANTRT,[F:ASW]TYPTRT,[F:ASW]CODTRT,[F:ASW]ACTTRT Order By [F:ASW]RANTRT(indice)

 Raz ASHW.NBRTRT

 For I=0 To [F:ASW]NBRTRT-1
  Read [ACV]CODACT = [F:ASW]ACTTRT(I)
  If ([F:ASW]ACTTRT(I)="") or (!fstat & [F:ACV]FLACT=2)
   ASHW.NBRTRT +=1
   ASHW.ASWTRT(ASHW.NBRTRT) = NewInstance C_ACLATRT AllocGroup ASHW

   ASHW.ASWTRT(ASHW.NBRTRT).RANTRT = [F:ASW]RANTRT(I)
   ASHW.ASWTRT(ASHW.NBRTRT).TYPTRT = [F:ASW]TYPTRT(I)
   ASHW.ASWTRT(ASHW.NBRTRT).CODTRT = [F:ASW]CODTRT(I)
   ASHW.ASWTRT(ASHW.NBRTRT).ACTTRT = [F:ASW]ACTTRT(I)
  Endif
 Next

 If TYPGEN = 2
  Raz ASHW.NBRGRP,ASHW.CODGRP,ASHW.MINGRP,ASHW.MAXGRP,ASHW.INTGRP,ASHW.INTITGRP,ASHW.CRECLAGRP
  End
 Endif

 # Options/Filtres
 Raz ASHW.NBROPT
 For [ASWO] Where CODREP=[F:ASW]CODREP
  If [F:ASWO]OPTFLGCLA=2
    Read [ACLAO]ACLAO0=[F:ASW]CODCLA;[F:ASWO]OPTCOD
    If !fstat & func AFNC.ACTIV([F:ACLAO]OPTACT)
      ASHW.NBROPT += 1
      ASHW.ASWOPT(ASHW.NBROPT) = NewInstance C_ACLAOPTION  AllocGroup ASHW
      SetInstance  ASHW.ASWOPT(ASHW.NBROPT)  With [F:ACLAO]
#      ASHW.ASWOPT(ASHW.NBROPT).OPTCOD = [F:ASWO]OPTCOD
      ASHW.ASWOPT(ASHW.NBROPT).OPTOBY=[F:ASWO]OPTOBY
      ASHW.ASWOPT(ASHW.NBROPT).OPTDEF=[F:ASWO]OPTDEF
    Endif
  Elsif func AFNC.ACTIV([F:ASWO]OPTACT)
    ASHW.NBROPT += 1
    ASHW.ASWOPT(ASHW.NBROPT) = NewInstance C_ACLAOPTION  AllocGroup ASHW
    SetInstance  ASHW.ASWOPT(ASHW.NBROPT)  With [F:ASWO]
#    ASHW.ASWOPT(ASHW.NBROPT).OPTCOD = [F:ASWO]OPTCOD
    ASHW.ASWOPT(ASHW.NBROPT).OPTOBY=[F:ASWO]OPTOBY
    ASHW.ASWOPT(ASHW.NBROPT).OPTDEF=[F:ASWO]OPTDEF
  Endif
 Next

 Read [ACLA]ACLA0 = [F:ASW]CODCLA
 If !fstat
  For [ACLAT]ACLAT0 Where CODCLA=[F:ASW]CODCLA
   Case [ACLAT]CODMETSTD
    When "C"  :      If [ACLAT]ENAMETSTD<>2 : ASHW.ENACOM(1)=1 : Endif
    When "U"  :      If [ACLAT]ENAMETSTD<>2 : ASHW.ENACOM(2)=1 : Endif
    When "D"  :      If [ACLAT]ENAMETSTD<>2 : ASHW.ENACOM(3)=1 : Endif
    When "R"  :
     If [ACLAT]ENAMETSTD<>2
      ASHW.ENAFAC(1)=1 : # pas de facette detail
      ASHW.ENACOM(2)=1 : #  pas de comportement edit modification
      ASHW.ENAFAC(5)=1  : # pas de facatte summury
      If ASHW.ENACOM(2)=1 & ASHW.ENACOM(1)=1 # si pas de comportement modification et crea alors pas de facette edit
       ASHW.ENAFAC(2)=1
      Endif
     Endif
   Endcase
  Next
 Endif

 Gosub LOAD_COLLECTION

 #  ASHW.NBRGRP +=1
 #  ASHW.CODGRP(ASHW.NBRGRP)   =  ASHW.ABRCLA
 #  ASHW.ALIASGRP(ASHW.NBRGRP)   =ASHW.ABRCLA
 #  ASHW.MINGRP(ASHW.NBRGRP)   = 2
 #  ASHW.MAXGRP(ASHW.NBRGRP)   = 1

 Local Char TBCLAFIND(250)(1..)
 NBPTH += 1
 ASHW.PTHGRI(NBPTH) = ASHW.ABRCLA
 ASHW.INSGRI(NBPTH) = ASHW.ABRCLA
 ASHW.GRPGRI(NBPTH) = ""
 ASHW.ONE(NBPTH)    = 1
 ASHW.ACLAGRI(NBPTH) =  NewInstance C_ACLA AllocGroup ASHW
 Call CHARGE_ACLA(ASHW.CODCLA,0,ASHW.ACLAGRI(NBPTH) ,AERR) From ACLAVALLEC   : # Classe
 Call CHARGE_ACLAF(ASHW.CODCLA,1,"",ASHW.ACLAGRI(NBPTH),AERR) From ACLAVALLEC

 If maxtab(AERR)>0 : End : Endif
 M = NBPTH
 For I=1 To  dim(ASHW.ACLAGRI(M).CODGRP)
  If ASHW.ACLAGRI(M).CRECLAGRP(I)=2
   NBPTH += 1
   ASHW.PTHGRI(NBPTH) = ASHW.ABRCLA+"."+ASHW.ACLAGRI(M).CODGRP(I)
   ASHW.INSGRI(NBPTH) = ASHW.ACLAGRI(M).CODGRP(I)
   ASHW.GRPGRI(NBPTH) = ASHW.ABRCLA+"."+ASHW.ACLAGRI(M).CODGRP(I)
   ASHW.ONE(NBPTH)    = 1
   ASHW.ACLAGRI(NBPTH) =  NewInstance C_ACLA AllocGroup ASHW
   ASHW.ACLAGRI(NBPTH).CODCLA = ASHW.ACLAGRI(M).CODCLA+"_"+ASHW.ACLAGRI(M).CODGRP(I)
   #107283
   #Call CHARGE_ACLA(ASHW.ACLAGRI(M).CODCLA,0,ASHW.ACLAGRI(NBPTH),AERR) From ACLAVALLEC   : # Classe
   #Call CHARGE_ACLAF(ASHW.ACLAGRI(M).CODCLA,2,ASHW.ACLAGRI(M).CODGRP(I), ASHW.ACLAGRI(NBPTH),AERR) From ACLAVALLEC
   Call CHARGE_ACLA(ASHW.ACLAGRI(NBPTH).CODCLA,2,ASHW.ACLAGRI(NBPTH),AERR) From ACLAVALLEC   : # Classe
   Call CHARGE_ACLAF(ASHW.ACLAGRI(NBPTH).CODCLA,2,ASHW.ACLAGRI(M).CODGRP(I), ASHW.ACLAGRI(NBPTH),AERR) From ACLAVALLEC
   ASHW.ACLAGRI(NBPTH).NBRTRT = ASHW.ACLAGRI(M).NBRTRT
   For J=1 To  ASHW.ACLAGRI(M).NBRTRT
    ASHW.ACLAGRI(NBPTH).ACLATRT(J) = NewInstance C_ACLATRT  AllocGroup ASHW
    ASHW.ACLAGRI(NBPTH).ACLATRT(J).RANTRT = ASHW.ACLAGRI(M).ACLATRT(J).RANTRT
    ASHW.ACLAGRI(NBPTH).ACLATRT(J).TYPTRT = ASHW.ACLAGRI(M).ACLATRT(J).TYPTRT
    ASHW.ACLAGRI(NBPTH).ACLATRT(J).CODTRT = ASHW.ACLAGRI(M).ACLATRT(J).CODTRT
    ASHW.ACLAGRI(NBPTH).ACLATRT(J).ACTTRT = ASHW.ACLAGRI(M).ACLATRT(J).ACTTRT
   Next
  Endif
 Next

 For [ACLAF2]ACLAF1 Where CODCLA=ASHW.CODCLA & LNKCLA<>""
  Raz  [L]TBCLAFIND : #  [L]TBCLAFIND(maxtab([L]TBCLAFIND)+1) = ASHW.CODCLA
  Call FIND_SUBCLASS([F:ACLAF2]FLDGRP,[L]DOSSIER,ASHW.ABRCLA,ASHW.ABRCLA,[ACLAF2]FLDCLA,[ACLAF2]LNKCLA,NBPTH,ASHW,AERR,[L]TBCLAFIND)
 Next
Endif


For I=1 To  dim(ASHW.CODGRP)
 If ASHW.CRECLAGRP(I)=2
  If !instr(1,ASHW.CODGRP(I),".")
   NBPTH += 1
   ASHW.PTHGRI(NBPTH) = ASHW.CODGRP(I)
   ASHW.INSGRI(NBPTH) = ASHW.CODGRP(I)
   ASHW.GRPGRI(NBPTH) = ASHW.CODGRP(I)
   ASHW.ONE(NBPTH)    = 1
   ASHW.ACLAGRI(NBPTH) =  NewInstance C_ACLA  AllocGroup ASHW
   ASHW.ACLAGRI(NBPTH).CODCLA = ASHW.CODREP+"_"+ASHW.CODGRP(I)
   ASHW.ACLAGRI(NBPTH).TYPCLA = -1
   ASHW.ACLAGRI(NBPTH).NBRTRT = ASHW.NBRTRT
   For J=1 To  ASHW.ACLAGRI(NBPTH).NBRTRT
    ASHW.ACLAGRI(NBPTH).ACLATRT(J) = NewInstance C_ACLATRT  AllocGroup ASHW
    ASHW.ACLAGRI(NBPTH).ACLATRT(J).RANTRT = ASHW.ASWTRT(J).RANTRT
    ASHW.ACLAGRI(NBPTH).ACLATRT(J).TYPTRT = ASHW.ASWTRT(J).TYPTRT
    ASHW.ACLAGRI(NBPTH).ACLATRT(J).CODTRT = ASHW.ASWTRT(J).CODTRT
    ASHW.ACLAGRI(NBPTH).ACLATRT(J).ACTTRT = ASHW.ASWTRT(J).ACTTRT
   Next
   ASHW.ASWGRI(NBPTH) =  NewInstance C_ASW  AllocGroup ASHW
   SetInstance ASHW.ASWGRI(NBPTH) With [F:ASW]
   Gosub LOAD_COLLECTION
   Call CHARGE_ASHWF(ASHW.CODREP,2,ASHW.CODGRP(I),ASHW.ASWGRI(NBPTH),AERR)     : # Champs
  Else
   Local Char WGRP(200),WPTH(250)
   Local Char WTABGRP(200),CHAINE(250)
   CHAINE = ASHW.CODGRP(I)
   K= instr(1,CHAINE,".")
   While K>0
    If WTABGRP=""
     WTABGRP = left$(CHAINE,K-1)
    Else
     WTABGRP += "."+CHAINE
    Endif
    CHAINE = right$(CHAINE,K+1)
    K= instr(1,CHAINE,".")
   Wend
   WGRP = CHAINE
   For J=1 To NBPTH
    If ASHW.ACLAGRI(J)<>null &  WTABGRP= ASHW.PTHGRI(J)
     For K=1 To ASHW.ACLAGRI(J).NBRGRP
      If WGRP =ASHW.ACLAGRI(J).CODGRP(K)
       ASHW.ACLAGRI(J).FLGTRIGRP(K) = ASHW.FLGTRIGRP(I)
       ASHW.ACLAGRI(J).FLGAPDGRP(K) = ASHW.FLGAPDGRP(I)
       ASHW.ACLAGRI(J).FLGINSGRP(K) = ASHW.FLGINSGRP(I)
       ASHW.ACLAGRI(J).FLGSUPGRP(K) = ASHW.FLGSUPGRP(I)
       ASHW.ACLAGRI(J).MINGRP(K) = ASHW.MINGRP(I)
       ASHW.ACLAGRI(J).INTGRP(K) = ASHW.INTGRP(I)
       ASHW.ACLAGRI(J).INTITGRP(K) = ASHW.INTITGRP(I)
       ASHW.ACLAGRI(J).MAXGRP(K) = ASHW.MAXGRP(I)
       ASHW.ACLAGRI(J).ACTGRP(K) = ASHW.ACTGRP(I)
      Endif
     Next
    Endif
   Next
  Endif
 Endif
Next
End

$LOAD_COLLECTION

Raz ASHW.NBRGRP,ASHW.CODGRP,ASHW.MINGRP,ASHW.MAXGRP,ASHW.INTGRP,ASHW.INTITGRP,ASHW.NBRPROGRP

For [ASWC] Where CODREP=[F:ASW]CODREP
 Read [ACV]CODACT = [F:ASWC]ACTCOL
 If ([F:ASWC]ACTCOL="") or (!fstat & [F:ACV]FLACT=2)  or (!fstat & [F:ACV]TYP=2)
  ASHW.NBRGRP +=1
  ASHW.CODGRP(ASHW.NBRGRP)   = [F:ASWC]CODCOL
  ASHW.ALIASGRP(ASHW.NBRGRP)   = [F:ASWC]ALIASCOL
  ASHW.MINGRP(ASHW.NBRGRP)   = [F:ASWC]MINCOL
  ASHW.INTGRP(ASHW.NBRGRP)   = [F:ASWC]INTCOL
  ASHW.PROGRP(ASHW.NBRGRP)   = [F:ASWC]PROCOL
  ASHW.ACTGRP(ASHW.NBRGRP) = [F:ASWC]ACTCOL
  If ASHW.MINGRP(ASHW.NBRGRP)<>3
   ASHW.FLGTRIGRP(ASHW.NBRGRP)  = [F:ASWC]FLGTRICOL
   ASHW.FLGAPDGRP(ASHW.NBRGRP)  = [F:ASWC]FLGAPDCOL
   ASHW.FLGINSGRP(ASHW.NBRGRP)  = [F:ASWC]FLGINSCOL
   ASHW.FLGSUPGRP(ASHW.NBRGRP)  = [F:ASWC]FLGSUPCOL
  Else
   ASHW.FLGTRIGRP(ASHW.NBRGRP)  = [V]CST_ANO
   ASHW.FLGAPDGRP(ASHW.NBRGRP) = [V]CST_ANO
   ASHW.FLGINSGRP(ASHW.NBRGRP)  = [V]CST_ANO
   ASHW.FLGSUPGRP(ASHW.NBRGRP)  = [V]CST_ANO
  Endif
  ASHW.INTITGRP(ASHW.NBRGRP) = func ASYRFNC.TEXTE([F:ASWC]INTCOL)
  If  ASHW.ACTGRP(ASHW.NBRGRP)<>""
  If [F:ACV]DIMFIL>0 & [F:ACV]DIME>0 & [F:ACV]DIMMAX>0
    ASHW.MAXGRP(ASHW.NBRGRP)  = min(max([F:ACV]DIMFIL,[F:ACV]DIME),[F:ACV]DIMMAX)
   Elsif ([F:ACV]DIMFIL<>0 | [F:ACV]DIME<>0)
    ASHW.MAXGRP(ASHW.NBRGRP)  = max([F:ACV]DIMFIL,[F:ACV]DIME)
   Else
    ASHW.MAXGRP(ASHW.NBRGRP)    = -1
   Endif
  Else
   ASHW.MAXGRP(ASHW.NBRGRP)   = [F:ASWC]MAXCOL
  Endif
  ASHW.CRECLAGRP(ASHW.NBRGRP) = 2
  For [F:ASWF2]ASWF0 Where CODREP=ASHW.CODREP & FLDGRP=ASHW.CODGRP(ASHW.NBRGRP)
   K=1
   If [F:ASWF2]ACTFLD<>""
    Read [ACV]CODACT = [F:ASWF2]ACTFLD
    If fstat or [F:ACV]FLACT<>2 : K = -1 : Endif
   Endif
   If K
    ASHW.NBRPROGRP(ASHW.NBRGRP)  += 1
   Endif
  Next
 Endif
Next
Return

$CHARGE_KEYREP
Local Integer NBCLE
Local Char    CLE(GLONAVB)(1..),CHAINE(250)
Read [ACLA]ACLA0 =ASHW.CODCLA
If !fstat
 If [ACLA]TYPCLA=2 : # persistant
  Read [ATB]CODFIC = [ACLA]TABREF
  If !fstat
   ASHW.TIT    =   [F:ATB]INTIT
   ASHW.INDCLA = [F:ACLA]INDREF
   Read [F:ATI]CODIND = [ACLA]TABREF;[ACLA]INDREF
   If !fstat
    CHAINE = [F:ATI]DESCRIPT
   Endif
  Endif
 Elsif [ACLA]TYPCLA=5 : # Interface
  CHAINE = [ACLA]KEYINT
 Endif
 Call SETCLE([L]NBCLE,[L]CLE,CHAINE) From LNKSUB
 For I=1 To  [L]NBCLE
  For J=1 To maxtab(ASHW.ASWR)
   If  ASHW.ABRCLA+"."+[L]CLE(I)= ASHW.ASWR(J).CODPRO
    ASHW.NBRKEYREP += 1
    ASHW.ASWKEY(ASHW.NBRKEYREP) = NewInstance C_ASWPAR  AllocGroup ASHW
    ASHW.ASWKEY(ASHW.NBRKEYREP).CODFLD= [L]CLE(I)
    ASHW.ASWKEY(ASHW.NBRKEYREP).CODREP = ASHW
    ASHW.ASWKEY(ASHW.NBRKEYREP).VALEUR = ASHW.ASWR(J).CODPRO
    ASHW.ASWKEY(ASHW.NBRKEYREP).ALIAS= ASHW.ASWR(J).ALIAS : # [L]CLE(I) 109885 CCL
    ASHW.ASWKEY(ASHW.NBRKEYREP).DESPAR= ASHW.ASWR(J).INTPRO
    ASHW.ASWKEY(ASHW.NBRKEYREP).TYPINT = ASHW.ASWR(J).ACLAF.ATY.TYPTYP
   Endif
  Next
 Next
Endif
Return

#---------------------------------------------------------------------------------------------------#
# Charge representation : Fields
#---------------------------------------------------------------------------------------------------#
Subprog CHARGE_ASHWF(CODREP,TYPGEN,NAMCOL,ASHW,AERR)
Value Char CODREP
Value Integer TYPGEN
Value Char NAMCOL
Variable  Instance  ASHW Using C_ASW
Variable  Instance  AERR Using C_AERROR

Local Integer   ASHWF_NBR,ASHWF_NBP,NBR_ASP,I,K,F,ISACTX
Local Char TABCLA(80)(1..50),CRITERIA(250)
Local Char TABPTR(80)(1..50),GRP(GLONAVC)
Local Integer NBCLA,K

If TYPGEN=0 or TYPGEN = 1
 CRITERIA = "1=1"
Else
 CRITERIA = 'FLDGRP="'+NAMCOL+'"'
Endif

If ASHW.TEST : Call ECR_TRACE("- Load properties of representation :"-ASHW.CODREP,0) From GESECRAN : Endif

ASHWF_NBR = maxtab(ASHW.ACLAF)
For [ASWF]ASWF2 Where CODREP=func ACLAVALLEC.GETNAMCLA([L]TYPGEN,[L]CODREP) & evalue(CRITERIA)
 K=0
 If [F:ASWF]FLDGRP<>"" & [L]TYPGEN<>2
  I = find([F:ASWF]FLDGRP,ASHW.CODGRP(1..ASHW.NBRGRP))
  If I>0 & !instr(1,ASHW.CODGRP(I) ,".")
   K  = ASHW.MAXGRP(I)
   [L]GRP = ASHW.ALIASGRP(I)
  Else
   Raz TABPTR,TABCLA,NBCLA,GRP
   Call DECODE_PRO([F:ASWF]FLDGRP,0,"GRP","",[L]CODREP,ASHW.ABRCLA,ASHW.CODCLA,TABPTR,TABCLA,GRP,ISACTX,NBCLA) From SUBASW
   If (NBCLA>1 & TABCLA(NBCLA)="") or NBCLA=0
    AERR(maxtab(AERR)+1) = NewInstance C_AERROR  AllocGroup ASHW
    AERR(maxtab(AERR)).STA = [V]CST_AERROR
    AERR(maxtab(AERR)).MES = mess(34,140,1)-[ASWF]CODFLD-":"-[F:ASWF]FLDGRP-mess(144,143,1) : # Collection inexistante
    AERR(maxtab(AERR)).NUM = 9101
    Break
   Else
    Read [ACLA]ACLA0 = TABCLA(NBCLA)
    If !fstat
     Read [ACLAC]ACLAC0=[F:ACLA]CODCLA;[L]GRP
     If !fstat
      K = [F:ACLAC]MAXCOL
      If [F:ACLAC]ACTCOL<>""
       Read [ACV]CODACT = [F:ACLAC]ACTCOL
       If !fstat and ([F:ACV]TYP=2) & [F:ACV]DIME<>0
        K = [F:ACV]DIME
       Elsif fstat
        K = -1
       Endif
      Endif
     Endif
     [L]GRP = ASHW.ALIASGRP(I)
    Endif
   Endif
  Endif
 Endif
 If [F:ASWF]ACTFLD<>""
  Read [ACV]CODACT = [F:ASWF]ACTFLD
  If fstat or [F:ACV]FLACT<>2
   K = -1
  Endif
 Endif
 If K>0 & [L]GRP<>""
  If [L]TYPGEN=1
   J = find(ASHW.CODREP+"_"+[L]GRP,ASHW.ACLAF(1..ASHWF_NBR).LNKCLA)
   If J : K=-1 : Endif
  Endif
 Endif

 If K>=0
  ASHWF_NBR += 1
  ASHW.ACLAF(ASHWF_NBR) = NewInstance C_ACLAFLD  AllocGroup ASHW
  SetInstance ASHW.ACLAF(ASHWF_NBR) With [F:ASWF]
  ASHW.ACLAF(ASHWF_NBR).FLDCLA = [F:ASWF]CODFLD
  ASHW.ACLAF(ASHWF_NBR).CODCLA = [F:ASWF]CODREP
  ASHW.ACLAF(ASHWF_NBR).PTHGRP = [L]GRP
  ASHW.ACLAF(ASHWF_NBR).ACLA = ASHW
  If K>1
   If [L]TYPGEN=1 & ASHW.CRECLAGRP(I) =2
    ASHW.ACLAF(ASHWF_NBR).FLDCLA = [L]GRP
    ASHW.ACLAF(ASHWF_NBR).LNKCLA = [L]CODREP+"_"+[L]GRP
    ASHW.ACLAF(ASHWF_NBR).CODTYP = ""
    ASHW.ACLAF(ASHWF_NBR).LONG = 0
    ASHW.ACLAF(ASHWF_NBR).NOLIB = 0
   Elsif [L]TYPGEN=2
    ASHW.ACLAF(ASHWF_NBR).FLDGRP = ""
    DS = 1
   Endif
  Elsif [L]TYPGEN=2
   ASHW.ACLAF(ASHWF_NBR).FLDGRP = ""
   DS = 1
  Endif
  ASHW.ACLAF(ASHWF_NBR).FLGACCCTL = 2
  ASHW.ACLAF(ASHWF_NBR).FLGACCINI = 2
  ASHW.ACLAF(ASHWF_NBR).INTITFLD= func ASYRFNC.TEXTE([F:ASWF]INTFLD)
  Call CHARGE_FLD(AERR,ASHW.ACLAF(ASHWF_NBR),[F:ASWF]CODTYP,K,"",[F:ASWF]NOLIB,[F:ASWF]LONG,ASHW.TEST) From ACLAVALLEC
  Call CHARGE_PARFLD(AERR,ASHW.ACLAF(ASHWF_NBR),func ACLAVALLEC.GETNAMCLA([L]TYPGEN,[L]CODREP),1)
  Call CHARGE_PARFLD(AERR,ASHW.ACLAF(ASHWF_NBR),func ACLAVALLEC.GETNAMCLA([L]TYPGEN,[L]CODREP),2)
  Call CHARGE_RULES(AERR,ASHW.ACLAF(ASHWF_NBR),ASHW.TYPCLA) From ACLAVALLEC
  If find(ASHW.ACLAF(ASHWF_NBR).CODTYP,"AX1","AX2","AXX","AX3","ATX")>0 : ASHW.ACLAF(ASHWF_NBR).FLGACCGET = 2 : Endif
  If ASHW.ACLAF(ASHWF_NBR).ATY<>null & find(ASHW.ACLAF(ASHWF_NBR).ATY.TYPTYP,9,10)>0 : ASHW.ACLAF(ASHWF_NBR).FLGACCGET = 2 : Endif

  If ASHW.TEST :
   Call ECR_TRACE(" --- "
&    -ASHW.ACLAF(ASHWF_NBR).FLDCLA
&    +space$(max(0,20-len(ASHW.ACLAF(ASHWF_NBR).FLDCLA)))+ASHW.ACLAF(ASHWF_NBR).CODTYP
&    +space$(max(0,12-len(ASHW.ACLAF(ASHWF_NBR).CODTYP)))+ASHW.ACLAF(ASHWF_NBR).LNKCLA
&    +space$(max(0,12-len(ASHW.ACLAF(ASHWF_NBR).FLDGRP)))+ASHW.ACLAF(ASHWF_NBR).FLDGRP
&    +space$(max(0,20-len(ASHW.ACLAF(ASHWF_NBR).LNKCLA)))+ASHW.ACLAF(ASHWF_NBR).INTITFLD
&    +space$(max(0,20-1))+num$(ASHW.ACLAF(ASHWF_NBR).FLGACCGET)
&    ,0) From GESECRAN
  Endif
 Endif
Next
If TYPGEN<>2
 ASHWF_NBR += 1
 ASHW.ACLAF(ASHWF_NBR) = NewInstance C_ACLAFLD AllocGroup ASHW
 ASHW.ACLAF(ASHWF_NBR).FLDCLA  = ASHW.ABRCLA
 ASHW.ACLAF(ASHWF_NBR).LNKCLA  = ASHW.CODCLA
 #ASHW.ACLAF(ASHWF_NBR).FLDGRP  = ASHW.ABRCLA
 ASHW.ACLAF(ASHWF_NBR).DIME = 1
Endif
End

#---------------------------------------------------------------------------------------------------#
# Charge representation : Methods
#---------------------------------------------------------------------------------------------------#
$CHARGE_ACLAM
Raz ACLAM_NBR
For [F:ASWM]ASWM1 Where CODREP=[L]CODREP
 If  func AFNC.ACTIV([F:ASWM]ACTMET)
  ACLAM_NBR += 1
  ASHW.ACLAM(ACLAM_NBR) = NewInstance C_ACLAMET AllocGroup ASHW
  SetInstance ASHW.ACLAM(ACLAM_NBR) With  [F:ASWM]
  ASHW.ACLAM(ACLAM_NBR).INTITMET= func ASYRFNC.TEXTE([F:ASWM]INTMET)
  Raz ACLAM_NBP
  For [ASWMP]ASWMP1 Where CODREP=[L]CODREP & CODMET=[ASWM]CODMET
   ACLAM_NBP += 1
   ASHW.ACLAM(ACLAM_NBR).ACLMP(ACLAM_NBP) = NewInstance C_ACLAPARDEF AllocGroup ASHW
   SetInstance ASHW.ACLAM(ACLAM_NBR).ACLMP(ACLAM_NBP) With  [F:ASWMP]
   ASHW.ACLAM(ACLAM_NBR).ACLMP(ACLAM_NBP).CODE = [F:ASWMP]CODMET
   ASHW.ACLAM(ACLAM_NBR).ACLMP(ACLAM_NBP).CODPAR = [F:ASWMP]CODPARMET
   ASHW.ACLAM(ACLAM_NBR).ACLMP(ACLAM_NBP).NOPAR = [F:ASWMP]NOPARMET
   ASHW.ACLAM(ACLAM_NBR).ACLMP(ACLAM_NBP).TYPINTPAR = [F:ASWMP]TYPPARMET
   ASHW.ACLAM(ACLAM_NBR).ACLMP(ACLAM_NBP).TYPKEY = 1
   ASHW.ACLAM(ACLAM_NBR).ACLMP(ACLAM_NBP).INTPAR = [F:ASWMP]INTPARMET
   ASHW.ACLAM(ACLAM_NBR).ACLMP(ACLAM_NBP).CLAPAR = [F:ASWMP]CLAPARMET
   ASHW.ACLAM(ACLAM_NBR).ACLMP(ACLAM_NBP).MODPAR = [F:ASWMP]MODPARMET
   ASHW.ACLAM(ACLAM_NBR).ACLMP(ACLAM_NBP).DIMPAR = [F:ASWMP]DIMPARMET
  Next
 Endif
Next
Return

#---------------------------------------------------------------------------------------------------#
# Charge representation : Organizations
#---------------------------------------------------------------------------------------------------#
$CHARGE_ASWG
Raz ASWG_NBR
 ASWG_NBR += 1
 ASHW.ASWG(ASWG_NBR) = NewInstance C_ASWORG  AllocGroup ASHW
 For [ASWB]ASWB1 Where CODREP=[L]CODREP
  If func AFNC.ACTIV([F:ASWB]ACTBLC)
   ASHW.ASWG(ASWG_NBR).NBRBLC += 1
   ASHW.ASWG(ASWG_NBR).CODBLC(ASHW.ASWG(ASWG_NBR).NBRBLC) = [F:ASWB]CODBLC
   ASHW.ASWG(ASWG_NBR).SECBLC(ASHW.ASWG(ASWG_NBR).NBRBLC) = [F:ASWB]SECBLC
   ASHW.ASWG(ASWG_NBR).ACTBLC(ASHW.ASWG(ASWG_NBR).NBRBLC) = [F:ASWB]ACTBLC
   ASHW.ASWG(ASWG_NBR).INTBLC(ASHW.ASWG(ASWG_NBR).NBRBLC) = [F:ASWB]INTBLC
   ASHW.ASWG(ASWG_NBR).NIVBLC(ASHW.ASWG(ASWG_NBR).NBRBLC) = [F:ASWB]NIVBLC
  Endif
 Next
 For [ASWS]ASWS1 Where CODREP=[L]CODREP
  If  func AFNC.ACTIV([F:ASWS]ACTSEC)
   ASHW.ASWG(ASWG_NBR).NBRSEC += 1
   ASHW.ASWG(ASWG_NBR).CODSEC(ASHW.ASWG(ASWG_NBR).NBRSEC) = [F:ASWS]CODSEC
   ASHW.ASWG(ASWG_NBR).INTSEC(ASHW.ASWG(ASWG_NBR).NBRSEC) = [F:ASWS]INTSEC
   ASHW.ASWG(ASWG_NBR).ACTSEC(ASHW.ASWG(ASWG_NBR).NBRSEC) = [F:ASWS]ACTSEC
   ASHW.ASWG(ASWG_NBR).NIVSEC(ASHW.ASWG(ASWG_NBR).NBRSEC) = [F:ASWS]NIVSEC
  Endif
 Next
Return

$ER_LNGTYP
J =0
Resume

$CHARGE_ASWR
Local Char TABCLA(80)(1..50)
Local Char TABPTR(80)(1..50),OBJ(50)
Local Integer NBCLA,OKALIAS,ISACTX

Raz ASWR_NBR
For [F:ASWR]ASWR2 Where CODREP=[L]CODREP
 [L]OKALIAS = 0
 K=1
 If [F:ASWR]ACTPRO<>""
  Read [ACV]CODACT = [F:ASWR]ACTPRO
  If fstat or [F:ACV]FLACT<>2
   K = -1
  Endif
 Endif
 If K>=0
  Raz TABPTR,TABCLA,OBJ,ISACTX,NBCLA
  Call DECODE_PRO([F:ASWR]CODPRO,0,"PRO",[L]DOSSIER,[L]CODREP,ASHW.ABRCLA,ASHW.CODCLA,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
  If (NBCLA>1 & TABCLA(NBCLA)="") or NBCLA=0
   Gosub ERR_EXPRO
   Break
  Elsif NBCLA>=1
   If TABCLA(NBCLA)=""
    If !ISACTX
     Read [ASWF]ASWF0 = [L]CODREP;OBJ
     If !fstat
      Gosub ADD_ALIAS
      ASHW.ASWR(ASWR_NBR).ACLAF = NewInstance C_ACLAFLD   AllocGroup ASHW
      SetInstance ASHW.ASWR(ASWR_NBR).ACLAF With [F:ASWF]
      ASHW.ASWR(ASWR_NBR).ACLAF.FLDCLA = [F:ASWF]CODFLD
      ASHW.ASWR(ASWR_NBR).ACLAF.PTHGRP = [F:ASWF]FLDGRP
      ASHW.ASWR(ASWR_NBR).CLAPRO = "R_"+[F:ASWF]CODREP
      ASHW.ASWR(ASWR_NBR).ACLAF.INTITFLD= func ASYRFNC.TEXTE([F:ASWF]INTFLD)
      Call CHARGE_FLD(AERR,ASHW.ASWR(ASWR_NBR).ACLAF,[F:ASWF]CODTYP,K,"",[F:ASWF]NOLIB,[F:ASWF]LONG,ASHW.TEST) From ACLAVALLEC
      Call CHARGE_PARFLD(AERR,ASHW.ASWR(ASWR_NBR).ACLAF,[L]CODREP,1)
      Call CHARGE_PARFLD(AERR,ASHW.ASWR(ASWR_NBR).ACLAF,[L]CODREP,2)
      Call CHARGE_RULES(AERR,ASHW.ASWR(ASWR_NBR).ACLAF,ASHW.TYPCLA) From ACLAVALLEC
      ASHW.ASWR(ASWR_NBR).TYPCLA = 1
      Gosub ADD_PTRASW
      Gosub ALIAS_PARFLD
     Endif
    Else
     Read [F:ACTX]ACTX0 = OBJ
     If !fstat
      Gosub ADD_ALIAS
      ASHW.ASWR(ASWR_NBR).ACLAF = NewInstance C_ACLAFLD   AllocGroup ASHW
      ASHW.ASWR(ASWR_NBR).ACLAF.FLDCLA = OBJ
      ASHW.ASWR(ASWR_NBR).ACLAF.PTHGRP = ""
      ASHW.ASWR(ASWR_NBR).CLAPRO = ""
      ASHW.ASWR(ASWR_NBR).ACLAF.INTITFLD= func ASYRFNC.TEXTE([ACTX]INTIT)
      J=0
      If [ACTX]LNGTYP<>""
       Onerrgo ER_LNGTYP
        J = evalue([ACTX]LNGTYP)
       Onerrgo
      Endif
      Call CHARGE_FLD(AERR,ASHW.ASWR(ASWR_NBR).ACLAF,[ACTX]CODTYP,K,"",0,J,ASHW.TEST) From ACLAVALLEC
      ASHW.ASWR(ASWR_NBR).TYPCLA = 0
     Endif
    Endif
   Else
    Read [ACLA]ACLA0 = TABCLA(NBCLA)
    If !fstat & find([F:ACLA]TYPCLA,3,4)
       Gosub ERR_EXPROCLA
       Break
    Endif
    Read [ACLAF]ACLAF0 = TABCLA(NBCLA);OBJ
    If !fstat
     If [F:ACLAF]CODTYP="" : # pointeur
      Gosub ERR_EXPRO
      Break
     Endif
     Gosub ADD_ALIAS
     ASHW.ASWR(ASWR_NBR).ACLAF= NewInstance C_ACLAFLD   AllocGroup ASHW
     SetInstance ASHW.ASWR(ASWR_NBR).ACLAF With [F:ACLAF]
     ASHW.ASWR(ASWR_NBR).CLAPRO = "C_"+ [F:ACLAF]CODCLA
     Call CHARGE_FLD(AERR,ASHW.ASWR(ASWR_NBR).ACLAF,[F:ACLAF]CODTYP,K,ASHW.CODCLA,[F:ACLAF]NOLIB,[F:ACLAF]LONG,ASHW.TEST) From ACLAVALLEC
     Call CHARGE_PARFLD(AERR,ASHW.ASWR(ASWR_NBR).ACLAF) From ACLAVALLEC
     Call CHARGE_PTHGRP(ASHW.ASWR(ASWR_NBR).ACLAF.PTHGRP,ASHW.ASWR(ASWR_NBR).ACLAF.FLDGRP,[F:ACLAF]CODCLA,ASHW.CODCLA,ASHW.ABRCLA,TABPTR,NBCLA)
     Call CHARGE_RULES(AERR,ASHW.ASWR(ASWR_NBR).ACLAF,ASHW.TYPCLA) From ACLAVALLEC
     Gosub ADD_PTRCLA
     Gosub ALIAS_PARFLD
    Endif
   Endif
  Elsif NBCLA=-1
   If ASHW.TEST>0 : Call ECR_TRACE("Alias :"-[F:ASWR]ALIAS-" CODPRO = "-[F:ASWR]CODPRO-mess(24,176,1),0) From GESECRAN : Endif
  Endif
 Else
  If ASHW.TEST>0 : Call ECR_TRACE("Alias :"-[F:ASWR]ALIAS-" CODPRO = "-[F:ASWR]CODPRO-mess(24,176,1),0) From GESECRAN : Endif
 Endif
Next
If maxtab(AERR)>0 : Return : Endif

# Test to kow if i need trt WMRS_
Gosub TESTNEEDWMRS
Return

$ALIAS_PARFLD
Local Char WPTHPRO(250),WCHAINE(250)
For I=1 To maxtab(ASHW.ASWR(ASWR_NBR).ACLAF.ATBKEY)
 WPTHPRO = ASHW.ASWR(ASWR_NBR).CODPRO
 If  (!instr(1,WPTHPRO,".")
& or instr(1,ASHW.ASWR(ASWR_NBR).ACLAF.ATBKEY(I).VALEUR,"ACTX.")<>0
& or (instr(1,WPTHPRO,".")>0  & left$(WPTHPRO,instr(1,WPTHPRO,".")-1)<>ASHW.ABRCLA)): # Propriete propre representation
  WPTHPRO = ASHW.ASWR(ASWR_NBR).ACLAF.ATBKEY(I).VALEUR
 Else
  WPTHPRO = func PATHCLAPRO(ASHW.ASWR(ASWR_NBR).CODPRO)
  WCHAINE = ASHW.ASWR(ASWR_NBR).ACLAF.ATBKEY(I).VALEUR
  K=instr(1,WCHAINE,".")
  While K>0
   WCHAINE = right$(WCHAINE,K+1)
   K=instr(1,WCHAINE,".")
  Wend
  WPTHPRO += WCHAINE
 Endif
 Read [ASWR2]ASWR3 = ASHW.CODREP;WPTHPRO
 If !fstat
  ASHW.ASWR(ASWR_NBR).ACLAF.ATBKEY(I).ALIAS = [F:ASWR2]ALIAS
 Endif
Next
For I=1 To maxtab(ASHW.ASWR(ASWR_NBR).ACLAF.ATBPAR)
 WPTHPRO = ASHW.ASWR(ASWR_NBR).CODPRO
 If  (!instr(1,WPTHPRO,".")
& or instr(1,ASHW.ASWR(ASWR_NBR).ACLAF.ATBPAR(I).VALEUR,"ACTX.")<>0
& or (instr(1,WPTHPRO,".")>0  & left$(WPTHPRO,instr(1,WPTHPRO,".")-1)<>ASHW.ABRCLA)): # Propriete propre representation
  WPTHPRO = ASHW.ASWR(ASWR_NBR).ACLAF.ATBPAR(I).VALEUR
 Else
  WPTHPRO = func PATHCLAPRO(ASHW.ASWR(ASWR_NBR).CODPRO)
  WCHAINE = ASHW.ASWR(ASWR_NBR).ACLAF.ATBPAR(I).VALEUR
  K=instr(1,WCHAINE,".")
  While K>0
   WCHAINE = right$(WCHAINE,K+1)
   K=instr(1,WCHAINE,".")
  Wend
  WPTHPRO += WCHAINE
 Endif
 Read [ASWR2]ASWR3 = ASHW.CODREP;WPTHPRO
 If !fstat
  ASHW.ASWR(ASWR_NBR).ACLAF.ATBPAR(I).ALIAS = [F:ASWR2]ALIAS
 Endif
Next
Return
$ERR_EXPRO
AERR(maxtab(AERR)+1) = NewInstance C_AERROR  AllocGroup AERR
AERR(maxtab(AERR)).STA = [V]CST_AERROR
AERR(maxtab(AERR)).MES = mess(35,140,1)-[F:ASWR]CODPRO-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"-":"-mess(56,140,1) : # propriété inexistante
# +' , '+mess(23,140,1)-"="-[L]CODREP-" : "-mess(34,140,1)-"="-[F:ASWR]ALIAS
AERR(maxtab(AERR)).NUM = 9101
Return

$ERR_EXPROCLA
AERR(maxtab(AERR)+1) = NewInstance C_AERROR AllocGroup AERR
AERR(maxtab(AERR)).STA = [V]CST_AERROR
#Une propriété d'une classe technique ou système ne peut être exposée
AERR(maxtab(AERR)).MES = mess(35,140,1)-[F:ASWR]CODPRO-"("+mess(3,40,1)-num$([ASWR]NUMPRO)+")"-":"-mess(185,143,1)
AERR(maxtab(AERR)).NUM = 9101
Return

#---------------------------------------------------------------------------------------------------#
# Charge representation : Menus
#---------------------------------------------------------------------------------------------------#
$CHARGE_ASWMN
Local Integer NBMEN
Local Instance ASWMEN(1..) Using C_ASWMEN
For [ASWMN]ASWMN1 Where CODREP=ASHW.CODREP
 If func AFNC.ACTIV([F:ASWMN]ACTMENU)
  NBMEN+=1
  ASWMEN(NBMEN) = NewInstance C_ASWMEN  AllocGroup ASHW
  SetInstance ASWMEN(NBMEN) With  [F:ASWMN]
 Endif
Next
Return


#-----------------------------------------------
$CHARGE_ASWFAC
Local Integer NOMEN,HASLNK

If WNBMENDET>0
 For NOMEN=1 To NBMEN
   ASWMEN(NOMEN).FLG=1
 Next
 HASLNK=0
 Call RECH_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(1),WNBMENDET,WMENDET,"",HASLNK)
 Call INI_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(1),"")
 Call CRE_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(1),"")
Endif

If WNBMENEDI>0
 For NOMEN=1 To NBMEN
   ASWMEN(NOMEN).FLG=1
 Next
 HASLNK=0
 Call RECH_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(2),WNBMENEDI,WMENEDI,"",HASLNK)
 Call INI_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(2),"")
 Call CRE_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(2),"")
Endif

If WNBMENQRY>0
 For NOMEN=1 To NBMEN
   ASWMEN(NOMEN).FLG=1
 Next
 HASLNK=0
 Call RECH_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(3),WNBMENQRY,WMENQRY,"",HASLNK)
 Call INI_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(3),"")
 Call CRE_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(3),"")
Endif

If WNBMENLOK>0
 For NOMEN=1 To NBMEN
   ASWMEN(NOMEN).FLG=1
 Next
 HASLNK=0
 Call RECH_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(4),WNBMENLOK,WMENLOK,"",HASLNK)
 Call INI_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(4),"")
 Call CRE_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(4),"")
Endif

If WNBMENSUM>0
 For NOMEN=1 To NBMEN
   ASWMEN(NOMEN).FLG=1
 Next
 HASLNK=0
 Call RECH_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(5),WNBMENSUM,WMENSUM,"",HASLNK)
 Call INI_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(5),"")
 Call CRE_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASHW.ASWFAC(5),"")
Endif

Return

#------------------
Subprog INI_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASWFAC,PARENT)
Value Char DOSSIER
Variable Instance ASHW Using C_ASW
Value Integer NBMEN
Variable Instance ASWMEN(1..) Using C_ASWMEN
Variable Instance ASWFAC Using C_ASWFAC
Value Char PARENT

Local Integer NOMEN,NBRMEN

If ASWFAC.LNKMENFAC<>"" & ASWFAC.AFFLNKFAC=0
 For NOMEN=1 To NBMEN
  If ASWMEN(NOMEN).CODMENU=ASWFAC.LNKMENFAC & ASWMEN(NOMEN).FLG=2
    NBRMEN=maxtab(ASWFAC.ASWMN)+1
    ASWFAC.ASWMN(NBRMEN) = NewInstance C_ASWMEN  AllocGroup ASWFAC
    ASWFAC.ASWMN(NBRMEN).CODMENU=ASWMEN(NOMEN).CODMENU
    ASWFAC.ASWMN(NBRMEN).LIBMENU=ASWMEN(NOMEN).LIBMENU
    ASWFAC.ASWMN(NBRMEN).PARMENU=ASWMEN(NOMEN).PARMENU
    ASWFAC.ASWMN(NBRMEN).ORDMENU=ASWMEN(NOMEN).ORDMENU
    ASWFAC.ASWMN(NBRMEN).ACTMENU=ASWMEN(NOMEN).ACTMENU
    ASWFAC.ASWMN(NBRMEN).FLG=ASWMEN(NOMEN).FLG
    Call CRE_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASWFAC,ASWMEN(NOMEN).CODMENU)
    ASWMEN(NOMEN).FLG=1
  Endif
 Next
Endif

End

#------------------
Subprog CRE_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASWFAC,PARENT)
Value Char DOSSIER
Variable Instance ASHW Using C_ASW
Value Integer NBMEN
Variable Instance ASWMEN(1..) Using C_ASWMEN
Variable Instance ASWFAC Using C_ASWFAC
Value Char PARENT

Local Integer NOMEN,NBRMEN

For NOMEN=1 To NBMEN
 If ASWMEN(NOMEN).PARMENU=PARENT & ASWMEN(NOMEN).FLG=2
   NBRMEN=maxtab(ASWFAC.ASWMN)+1
   ASWFAC.ASWMN(NBRMEN) = NewInstance C_ASWMEN AllocGroup ASWFAC
   ASWFAC.ASWMN(NBRMEN).CODMENU=ASWMEN(NOMEN).CODMENU
   ASWFAC.ASWMN(NBRMEN).LIBMENU=ASWMEN(NOMEN).LIBMENU
   ASWFAC.ASWMN(NBRMEN).PARMENU=ASWMEN(NOMEN).PARMENU
   ASWFAC.ASWMN(NBRMEN).ORDMENU=ASWMEN(NOMEN).ORDMENU
   ASWFAC.ASWMN(NBRMEN).ACTMENU=ASWMEN(NOMEN).ACTMENU
   ASWFAC.ASWMN(NBRMEN).FLG=ASWMEN(NOMEN).FLG
   Call CRE_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASWFAC,ASWMEN(NOMEN).CODMENU)
   ASWMEN(NOMEN).FLG=1
 Endif
Next
End

#------------------
Subprog RECH_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASWFAC,NBMENFAC,LISTMENFAC,PARENT,HASLNK)
Value Char DOSSIER
Variable Instance ASHW Using C_ASW
Value Integer NBMEN
Variable Instance ASWMEN(1..) Using C_ASWMEN
Variable Instance ASWFAC Using C_ASWFAC
Value Integer NBMENFAC
Value Char LISTMENFAC()()
Value Char PARENT
Variable Integer HASLNK

Local Integer NOMEN
Local Integer SONLNK
For NOMEN=1 To NBMEN
 If ASWMEN(NOMEN).PARMENU=PARENT
   SONLNK=0
   Call RECH_MENUFAC(DOSSIER,ASHW,NBMEN,ASWMEN,ASWFAC,NBMENFAC,LISTMENFAC,ASWMEN(NOMEN).CODMENU,SONLNK)
   If !SONLNK & find(ASWMEN(NOMEN).CODMENU,LISTMENFAC) : SONLNK=1 : Endif
   If SONLNK : HASLNK=1 : ASWMEN(NOMEN).FLG=2 : Endif
 Endif
Next
End

#---------------------------------------------------------------------------------------------------#
# Charge representation : Links
#---------------------------------------------------------------------------------------------------#
$CHARGE_ASWK
Local File =DOSSIER+".ASHWLNK"     [ASWK3]
Local Integer OK_LNK,LNK_PAG
Local Integer I,J
Local File =DOSSIER+".ASHWLNK"     [ASWKQ] : Raz [ASWKQ]
Local Instance LNK_Q Using C_ASWLNK
Local File =DOSSIER+".ASHWLNK"     [ASWKE] : Raz [ASWKE]
Local Instance LNK_E Using C_ASWLNK
Local File =DOSSIER+".ASHWLNK"     [ASWKD] : Raz [ASWKD]
Local Instance LNK_D Using C_ASWLNK
Local Integer NBREMP
Local Char WCODLNKREMP(200)(1..),WCODLNKREF(20)
Local Integer WNBMENQRY,WNBMENDET,WNBMENEDI,WNBMENLOK,WNBMENSUM
Local Char WMENQRY(20)(1..),WMENDET(20)(1..),WMENEDI(20)(1..),WMENLOK(20)(1..),WMENSUM(20)(1..)
Local Char WWHERE(50),WANCLNK(GLONAVC)
#
Local Instance LNK_SAVE Using C_ASWLNK
Local Instance LNK_ABORT Using C_ASWLNK
#
Local Instance ASWACTIONS(1..) Using C_ASWACTION
Call LOAD_ACTIONS(ASWACTIONS) From SUBASW_TOOL

If ASHW.TEST : Call ECR_TRACE("--- Links :",0) From GESECRAN : Endif
Gosub LECT_TAB_ASWKREM
#--------------------
If dim(GACTION)>0 & GACTION="ASWMEN"
 WWHERE="find(AFFLNK,4,5)<>0"
Else
 WWHERE="1=1"
Endif
Raz ASWK_NBR
# ASWK1=CODREP+ANCLNK+ORDTECLNK+AFFLNK+MENLNK+CODLNK
For [F:ASWK]ASWK1(2) Where CODREP=[L]CODREP & ENALNK=2 & evalue(WWHERE)
 WANCLNK=[F:ASWK]ANCLNK
 For [F:ASWK]ASWK1
  If [F:ASWK]TARLNK=0 : [F:ASWK]TARLNK=1 : Endif
  If find(num$([F:ASWK]AFFLNK)+"~"+[F:ASWK]ANCLNK+"~"+[F:ASWK]CODLNK,WCODLNKREMP(1..NBREMP))
      Goto NEXT_ASWK
  Endif
  WCODLNKREF=[F:ASWK]CODLNK :#utilisé pour LECT_ASWKATTLNK après lecture ASWKREM
  If [F:ASWK]REMSTDLNK<>""
    Gosub LECT_ASW2KREM
    If fstat | [F:ASWK2]ENALNK<>2
      Goto NEXT_ASWK
    Endif
    #on reprend le flag std pour affecter code
    If [F:ASWK]ATTLNK<>1 & [F:ASWK2]ATTLNK=1 : [F:ASWK2]ATTLNK=[F:ASWK]ATTLNK : Endif
    If [F:ASWK]FLGSTDLNK=2 : [F:ASWK2]FLGSTDLNK=2 : Endif
    #On reprend menu et position
    [F:ASWK2]MENLNK=[F:ASWK]MENLNK : [F:ASWK2]ORDLNK=[F:ASWK]ORDLNK
    [F:ASWK]=[F:ASWK2]
  Endif
  If [F:ASWK]ATTLNK>1 & [F:ASWK]FLGSTDLNK=2
    Gosub LECT_ASWKATTLNK
  Endif
  If [F:ASWK]ATTLNK>1
    [F:ASWK]FLGSTDLNK=2
  Endif
  [F:ASWK0]=[F:ASWK] :#utilisé pour le chargement des param ....si AFFLNK ou CODLNK changent
  [L]LNK_PAG=0

$NEW_ASWK
  Gosub IS_LNK_OK
  If [L]OK_LNK=0
    Goto NEXT_ASWK
  Endif

  If ASHW.TEST & [F:ASWK]CODLNK=WCODLNKREF
    Call ECR_TRACE("  - Link :"-num$([F:ASWK]AFFLNK)+"/"+[F:ASWK]ANCLNK+"/"+[F:ASWK]CODLNK,0) From GESECRAN
  Elsif ASHW.TEST
    Call ECR_TRACE("  - Link :"-num$([F:ASWK]AFFLNK)+"/"+[F:ASWK]ANCLNK+"/"+WCODLNKREF-"->"-[F:ASWK]CODLNK,0) From GESECRAN
  Endif
  [F:ASWK]CODLNK=WCODLNKREF

  If [F:ASWK]AFFLNK=1 : # propriété
     I = find([F:ASWK]ANCLNK,ASHW.ASWR(1..maxtab(ASHW.ASWR)).CODPRO)
     While I>0
       ASWK_NBR = maxtab(ASHW.ASWR(I).ASWK)+1
       ASHW.ASWR(I).ASWK(ASWK_NBR) = NewInstance C_ASWLNK AllocGroup ASHW
       Call ADD_ASWK([L]DOSSIER,ASHW,ASWACTIONS,ASHW.ASWR(I).ASWK(ASWK_NBR),ASHW.ASWR(I).ALIAS,[L]LNK_PAG)
       If I<maxtab(ASHW.ASWR)
        J=find([F:ASWK]ANCLNK,ASHW.ASWR(I+1..maxtab(ASHW.ASWR)).CODPRO)
        If J>0
          I+=J
        Else
          I=0
        Endif
       Else
        I=0
       Endif
     Wend
  Else
    ASWK_NBR = maxtab(ASHW.ASWK)+1
    ASHW.ASWK(ASWK_NBR) = NewInstance C_ASWLNK  AllocGroup ASHW
    Call ADD_ASWK([L]DOSSIER,ASHW,ASWACTIONS,ASHW.ASWK(ASWK_NBR),"",[L]LNK_PAG)
    #Sur les STD, on doit retraiter le lien pour SAVE et ABORT
    If [F:ASWK]FLGSTDLNK=2
      Gosub ATT_ASWK_STD1718
    Endif
    #liste des menus page utilisés par facette
    Gosub LIST_MENPAGE
  Endif

  #---

$NEXT_ASWK
  If [L]LNK_PAG=1
    [L]LNK_PAG=2
    [F:ASWK]=[F:ASWK0]
    [F:ASWK]AFFLNK=4
    [F:ASWK]QRYLNK=1
    [F:ASWK]LOKLNK=1
    Goto NEW_ASWK
  Endif
 Next
Next
#---
Gosub FILL_ASWK_STD1718
If ASWACTIONS<>null
 FreeGroup ASWACTIONS
Endif
Return

#------------------------------------
$LIST_MENPAGE
  #liste des menus utilisés par facette
  If ASHW.ASWK(ASWK_NBR).AFFLNK=4 & ASHW.ASWK(ASWK_NBR).MENLNK<>""
   If ASHW.ASWK(ASWK_NBR).DETLNK=2
    If find(ASHW.ASWK(ASWK_NBR).MENLNK,WMENDET)=0
    WNBMENDET+=1 : WMENDET(WNBMENDET)=ASHW.ASWK(ASWK_NBR).MENLNK
    Endif
   Endif
   If ASHW.ASWK(ASWK_NBR).QRYLNK=2
    If find(ASHW.ASWK(ASWK_NBR).MENLNK,WMENQRY)=0
    WNBMENQRY+=1 : WMENQRY(WNBMENQRY)=ASHW.ASWK(ASWK_NBR).MENLNK
    Endif
   Endif
   If ASHW.ASWK(ASWK_NBR).EDILNK=2
    If find(ASHW.ASWK(ASWK_NBR).MENLNK,WMENEDI)=0
    WNBMENEDI+=1 : WMENEDI(WNBMENEDI)=ASHW.ASWK(ASWK_NBR).MENLNK
    Endif
   Endif
   If ASHW.ASWK(ASWK_NBR).LOKLNK=2
    If find(ASHW.ASWK(ASWK_NBR).MENLNK,WMENLOK)=0
    WNBMENLOK+=1 : WMENLOK(WNBMENLOK)=ASHW.ASWK(ASWK_NBR).MENLNK
    Endif
   Endif
   If ASHW.ASWK(ASWK_NBR).SUMLNK=2
    If find(ASHW.ASWK(ASWK_NBR).MENLNK,WMENSUM)=0
    WNBMENSUM+=1 : WMENSUM(WNBMENSUM)=ASHW.ASWK(ASWK_NBR).MENLNK
    Endif
   Endif
  Endif
Return
#------------------------------------
$LECT_ASWKATTLNK
    For [ASWK2] Where CODREP=[L]CODREP & AFFLNK=[F:ASWK]AFFLNK & ANCLNK=[F:ASWK]ANCLNK
&                & FLGSTDLNK=1 & ATTLNK=[F:ASWK]ATTLNK & ENALNK=2
&                & [F:ASWK2]CODLNK<>[F:ASWK]CODLNK
&                & [F:ASWK2]CODLNK<>WCODLNKREF
      [F:ASWK]ATTLNK=1
      [F:ASWK]FLGSTDLNK=1
      Break
    Next
Return
#------------------------------------
$LECT_ASW2KREM
 Read [ASWK2]ASWK0=[L]CODREP;[F:ASWK]AFFLNK;[F:ASWK]ANCLNK;[F:ASWK]REMSTDLNK
Return
#------------------------------------
$LECT_TAB_ASWKREM
 #on charge les remplacants
  Raz WCODLNKREMP
  NBREMP=0
  For [ASWK3] Where CODREP=[L]CODREP & FLGSTDLNK=2 & ENALNK=2 & REMSTDLNK<>""
    NBREMP+=1
    WCODLNKREMP(NBREMP)=num$([F:ASWK3]AFFLNK)+"~"+[F:ASWK3]ANCLNK+"~"+[F:ASWK3]REMSTDLNK
  Next
Return
#------------------------------------
$IS_LNK_OK
  [L]OK_LNK=1
  If !func AFNC.ACTIV([F:ASWK]ACVLNK)
    [L]OK_LNK=0
    For AFAC=1 To 5
      If ASHW.ASWFAC(AFAC).AFFLNKFAC = [F:ASWK]AFFLNK & ASHW.ASWFAC(AFAC).LNKMENFAC=[F:ASWK]CODLNK
       ASHW.ASWFAC(AFAC).LNKMENFAC = ""
       ASHW.ASWFAC(AFAC).AFFLNKFAC = 0
      Endif
    Next
    Return
  Endif
  If [F:ASWK]MENLNK<>"" & !find([F:ASWK]MENLNK,ASWMEN(1..NBMEN).CODMENU)
    [L]OK_LNK=0
    Return
  Endif
  #----
  If ASHW.ENAFAC(1)<>2 : [F:ASWK]DETLNK=1 : Endif : # Détail
  If ASHW.ENAFAC(2)<>2 : [F:ASWK]EDILNK=1 : Endif : # Edit
  If ASHW.ENAFAC(3)<>2 : [F:ASWK]QRYLNK=1 : Endif : # Query
  If ASHW.ENAFAC(4)<>2 : [F:ASWK]LOKLNK=1 : Endif : # Lookup
  If ASHW.ENAFAC(5)<>2 : [F:ASWK]SUMLNK=1 : Endif : # Summary
  #----
  If [F:ASWK]AFFLNK=5 & ([F:ASWK]DETLNK=2 | [F:ASWK]EDILNK=2 | [F:ASWK]SUMLNK=2)
    [L]LNK_PAG=1
    [F:ASWK]DETLNK=1
    [F:ASWK]EDILNK=1
    [F:ASWK]SUMLNK=1
  Endif
  #----
  If find([F:ASWK]AFFLNK,4,5)=0 & [F:ASWK]DETLNK<>2 & [F:ASWK]EDILNK<>2 & [F:ASWK]QRYLNK<>2 & [F:ASWK]LOKLNK<>2 & [F:ASWK]SUMLNK<>2
    [L]OK_LNK=0
    Return
  Endif
  Gosub IS_REPLNK_OK
Return

#------------------------------------
$IS_REPLNK_OK
If [F:ASWK]TYPLNK<>1
  Return
Endif
If [F:ASWK]REPLNK=ASHW.CODREP
  Case [F:ASWK]CMPLNK
  When 1  : # Créer une fiche
    If ASHW.ENAFAC(2)<>2 | ASHW.ENACOM(1)<>2: [L]OK_LNK=0 : Endif : # Edit
  When 2  : # Afficher détail
    If ASHW.ENAFAC(1)<>2 : [L]OK_LNK=0 : Endif : # Détail
  When 3  : # Modifier une fiche
    If ASHW.ENAFAC(2)<>2 | (ASHW.ENACOM(1)<>2 & ASHW.ENACOM(2)<>2) : [L]OK_LNK=0 : Endif : # Edit
  When 4  : # Supprimer une fiche
    If ASHW.ENACOM(3)<>2: [L]OK_LNK=0 : Endif : # Edit
  When 5  : # Afficher liste
    If ASHW.ENAFAC(3)<>2 : [L]OK_LNK=0 : Endif : # Query
  When 6  : # Dupliquer une fiche
    If ASHW.ENAFAC(2)<>2 | ASHW.ENACOM(1)<>2: [L]OK_LNK=0 : Endif : # Edit
  When 7  : # Afficher dans Excel
    If ASHW.ENACOM(5)<>2: [L]OK_LNK=0 : Endif : # Edit
  When 8  : # Lister dans Excel
    If ASHW.ENACOM(5)<>2: [L]OK_LNK=0 : Endif : # Edit
  When 9  : # Sélection
    If ASHW.ENAFAC(4)<>2 : [L]OK_LNK=0 : Endif : # Lookup
  When 10 : # Afficher résumé
    If ASHW.ENAFAC(5)<>2 : [L]OK_LNK=0 : Endif : # Summary
  When 11 : # Afficher en PDF
    If ASHW.ENACOM(4)<>2: [L]OK_LNK=0 : Endif : # Edit
  When 12 : # Lister en PDF
    If ASHW.ENACOM(4)<>2: [L]OK_LNK=0 : Endif : # Edit
  When 13 : # Afficher dans Word
    If ASHW.ENACOM(6)<>2: [L]OK_LNK=0 : Endif : # Edit
  When 14 : # Lister dans Word
    If ASHW.ENACOM(6)<>2: [L]OK_LNK=0 : Endif : # Edit
  When 15 : # Publiposter fiche
    If ASHW.ENACOM(7)<>2: [L]OK_LNK=0 : Endif : # Edit
  When 16 : # Publiposter liste
    If ASHW.ENACOM(7)<>2: [L]OK_LNK=0 : Endif : # Edit
  When 17 : # Enregistrer
    [L]OK_LNK=1
  When 18 : # Abandon
    [L]OK_LNK=1
  Endcase
  Return
Elsif [F:ASWK]REPLNK<>[F:ASW2]CODREP
  Read [ASW2]ASW0 = [F:ASWK]REPLNK
  If fstat
    Raz [F:ASW2]
    [L]OK_LNK=0
    Return
  Elsif !func AFNC.ACTIV([F:ASW2]CODACT)
    [L]OK_LNK=0
    Return
  Endif
  If [F:ASW2]CODCLA<>""
  Read [ACLA2]ACLA0 = [F:ASW2]CODCLA
  If fstat
    Raz [F:ACLA2]
    [L]OK_LNK=0
    Return
  Elsif !func AFNC.ACTIV([F:ACLA2]CODACT)
    [L]OK_LNK=0
    Return
  Endif
  Endif
Endif
Case [F:ASWK]CMPLNK
When 1  : # Créer une fiche
  If [F:ASW2]ENAFAC(1)<>2 | [F:ASW2]ENACOM(0)<>2: [L]OK_LNK=0 : Endif : # Edit
When 2  : # Afficher détail
  If [F:ASW2]ENAFAC(0)<>2 : [L]OK_LNK=0 : Endif : # Détail
When 3  : # Modifier une fiche
  If [F:ASW2]ENAFAC(1)<>2 | ([F:ASW2]ENACOM(0)<>2 & [F:ASW2]ENACOM(1)<>2) : [L]OK_LNK=0 : Endif : # Edit
When 4  : # Supprimer une fiche
  If [F:ASW2]ENACOM(2)<>2: [L]OK_LNK=0 : Endif : # Edit
When 5  : # Afficher liste
  If [F:ASW2]ENAFAC(2)<>2 : [L]OK_LNK=0 : Endif : # Query
When 6  : # Dupliquer une fiche
  If [F:ASW2]ENAFAC(1)<>2 | [F:ASW2]ENACOM(0)<>2: [L]OK_LNK=0 : Endif : # Edit
When 7  : # Afficher dans Excel
  If [F:ASW2]ENACOM(4)<>2: [L]OK_LNK=0 : Endif : # Edit
When 8  : # Lister dans Excel
  If [F:ASW2]ENACOM(4)<>2: [L]OK_LNK=0 : Endif : # Edit
When 9  : # Sélection
  If [F:ASW2]ENAFAC(3)<>2 : [L]OK_LNK=0 : Endif : # Lookup
When 10 : # Afficher résumé
  If [F:ASW2]ENAFAC(4)<>2 : [L]OK_LNK=0 : Endif : # Summary
When 11 : # Afficher en PDF
  If [F:ASW2]ENACOM(3)<>2: [L]OK_LNK=0 : Endif : # Edit
When 12 : # Lister en PDF
  If [F:ASW2]ENACOM(3)<>2: [L]OK_LNK=0 : Endif : # Edit
When 13 : # Afficher dans Word
  If [F:ASW2]ENACOM(5)<>2: [L]OK_LNK=0 : Endif : # Edit
When 14 : # Lister dans Word
  If [F:ASW2]ENACOM(5)<>2: [L]OK_LNK=0 : Endif : # Edit
When 15 : # Publiposter fiche
  If [F:ASW2]ENACOM(6)<>2: [L]OK_LNK=0 : Endif : # Edit
When 16 : # Publiposter liste
  If [F:ASW2]ENACOM(6)<>2: [L]OK_LNK=0 : Endif : # Edit
When Default : # Enregistrer # Abandon
  [L]OK_LNK=0
Endcase
Return

#------------------------------------
$ATT_ASWK_STD1718
   #Sur les STD, on doit retraiter le lien pour SAVE et ABORT
   If [F:ASWK]TYPLNK=1 & [F:ASWK]AFFLNK=4 & [F:ASWK]CMPLNK=17 : # Enregistrer
    Call ADD_ATT_LNK(ASHW.ASWK(ASWK_NBR),func ASYRSUB.CODATT("H"),func ASYRSUB.BOOLEAN_TO_SYR(2))
    #107757
    #Call ADD_ATT_LNK(ASHW.ASWK(ASWK_NBR),func ASYRSUB.CODATT("r"),func ASYRSUB.BOOLEAN_TO_SYR(1))
    Call ADD_ATT_LNK(ASHW.ASWK(ASWK_NBR),func ASYRSUB.CODATT("G"),func ASYRSUB.BOOLEAN_TO_SYR(1))
    LNK_SAVE=ASHW.ASWK(ASWK_NBR)
   Elsif [F:ASWK]TYPLNK=1 & [F:ASWK]AFFLNK=4 & [F:ASWK]CMPLNK=18 : # Abandon
   Call ADD_ATT_LNK(ASHW.ASWK(ASWK_NBR),func ASYRSUB.CODATT("H"),func ASYRSUB.BOOLEAN_TO_SYR(2))
   #107757
   #Call ADD_ATT_LNK(ASHW.ASWK(ASWK_NBR),func ASYRSUB.CODATT("r"),func ASYRSUB.BOOLEAN_TO_SYR(1))
   Call ADD_ATT_LNK(ASHW.ASWK(ASWK_NBR),func ASYRSUB.CODATT("G"),func ASYRSUB.BOOLEAN_TO_SYR(1))
    LNK_ABORT=ASHW.ASWK(ASWK_NBR)
   Elsif [F:ASWK]TYPLNK=1 & [F:ASWK]AFFLNK=4 & [F:ASWK]CMPLNK=5 : # Lister
     [F:ASWKQ]=[F:ASWK]
     LNK_Q=ASHW.ASWK(ASWK_NBR)
   Elsif [F:ASWK]TYPLNK=1 & find([F:ASWK]AFFLNK,4,5) & [F:ASWK]CMPLNK=2 & [F:ASWK]ATTLNK>1 : # Detail
     [F:ASWKD]=[F:ASWK]
     LNK_D=ASHW.ASWK(ASWK_NBR)
   Elsif [F:ASWK]TYPLNK=1 & find([F:ASWK]AFFLNK,4,5) & [F:ASWK]CMPLNK=3 : # Edit
     [F:ASWKE]=[F:ASWK]
     LNK_E=ASHW.ASWK(ASWK_NBR)
   Endif
Return
#------------------------------------
$FILL_ASWK_STD1718
Local Integer ACT_LNK

If LNK_SAVE<>null
  Raz ACT_LNK
  If [F:ASWKQ]CODLNK<>"" : #Query
   ACT_LNK += 1
   LNK_SAVE.ALNK(ACT_LNK) = NewInstance C_ASWLNK  AllocGroup ASHW
   SetInstance LNK_SAVE.ALNK(ACT_LNK) With  [F:ASWKQ]
   LNK_SAVE.ALNK(ACT_LNK).CODLNK=ASWACTIONS(LNK_SAVE.ALNK(ACT_LNK).CMPLNK).PROLNK
   LNK_SAVE.ALNK(ACT_LNK).AFFLNK=4
   LNK_SAVE.ALNK(ACT_LNK).EDILNK=2
   LNK_SAVE.ALNK(ACT_LNK).INTITLNK= func ASYRFNC.TEXTE(LNK_SAVE.ALNK(ACT_LNK).INTLNK)
   Raz ASWK_NBP,ASWK_KEY
   For ASWK_KEY=1 To maxtab(LNK_Q.ATBKEY)
    LNK_SAVE.ALNK(ACT_LNK).ATBKEY(ASWK_KEY) = NewInstance C_ASWPAR  AllocGroup ASHW
    LNK_SAVE.ALNK(ACT_LNK).ATBKEY(ASWK_KEY).TYPPAR=LNK_Q.ATBKEY(ASWK_KEY).TYPPAR
