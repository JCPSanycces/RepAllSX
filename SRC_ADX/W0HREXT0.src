mkstat = 0
zoncou = "EXRCODACC"
indice = 0
If varmode([M]EXRCODACC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRCODACC" : Gosub ACTION From =IMPTRT
