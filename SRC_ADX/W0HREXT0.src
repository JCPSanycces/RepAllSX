## Zone EXRCDTSYM
mkstat = 0
zoncou = "EXRCDTSYM"
indice = 0
If varmode([M]EXRCDTSYM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRCDTSYM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone EXRSYMPOS
mkstat = 0
zoncou = "EXRSYMPOS"
indice = 0
IMPENT = [M]EXRSYMPOS
If varinit([M]EXRSYMPOS,indice)=0
 IMPENT = 1
Endif
If varmode([M]EXRSYMPOS,indice)=0
 Call INICOMBO(425) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_EXRSYMPOS(IMPENT) From SUBHREXT
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,425,1))))
 Endif
 [M]EXRSYMPOS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRSYMPOS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EXRSYMPOS(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "EXRSYMPOS" : GZNUM = 802 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]EXRSYMPOS = IMPENT

