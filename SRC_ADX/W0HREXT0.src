 Call CONTROLE("ACS","!",[M]EXRCODACC,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "EXRCODACC" : GZNUM = 729 : Endif
 Gosub AFF From GSAISIE
