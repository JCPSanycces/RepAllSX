 Call CONTROLE("ARP","!",[M]EXRPRNRPT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "EXRPRNRPT" : GZNUM = 20400 : Endif
 Gosub AFF From GSAISIE
