IMPTBL = 0

## Zone EXRDEBSYM
mkstat = 0
zoncou = "EXRDEBSYM"
indice = 0
If varinit([M]EXRDEBSYM,indice)=0
 [M]EXRDEBSYM = '-'
Endif
If varmode([M]EXRDEBSYM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRDEBSYM" : Gosub ACTION From =IMPTRT
 Endif
