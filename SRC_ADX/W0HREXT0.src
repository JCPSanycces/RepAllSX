#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HREXT0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone EXRTEP
mkstat = 0
zoncou = "EXRTEP"
indice = 0
If varmode([M]EXRTEP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRTEP" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]EXRTEP,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "EXRTEP" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARAM(1) = "HREXT"
  Local Char    VALEUR(250)
  VALEUR = [M]EXRTEP
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
  [M]EXRTEP = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "EXRTEP" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone EXRTIT
mkstat = 0
zoncou = "EXRTIT"
indice = 0
If varmode([M]EXRTIT,indice)=0
 If !mkstat
