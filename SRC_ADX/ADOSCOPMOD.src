#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char TBLEG(10)(1..2)
Local Char TBLAN(5)(1..30)
Local Integer NBLAN , MODULE(1..30)
For I=1 To dim(MODULE) : MODULE(I) = 2 : Next I
Call OUVRE_TRACE("test ADOSCOPMOD") From LECFIC
Call COPY("TEST2","","",3,TBLEG,1,TBLAN,NBLAN,"",1,0,MODULE,"TESTMB","AUTILISDEF",1)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#-----------------------------------------------------------------------------------------------------------------#
Subprog COPY(DOSSIER,DOSCOP,DOSREF,ORIGIN,TBLEG,NBLEG,TBLAN,NBLAN,CRYDEF,LEGNUL,ONELEG,MODULE,KITLIV,MODDON,DETAIL)
Value    Char    DOSSIER , DOSCOP , DOSREF
Value    Integer ORIGIN
Value    Char    TBLEG()(1..)
Value    Integer NBLEG
Variable Char    TBLAN()(1..)
Variable Integer NBLAN
Value    Char    CRYDEF
Value    Integer LEGNUL
Value    Integer ONELEG
Value    Integer MODULE(1..)
Value    Char    KITLIV , MODDON
Value    Integer DETAIL

Local Integer STAT
Local Char    NOMPROG(250) , DOSORG(GLONADS)

Case ORIGIN
 When 1 : DOSORG = DOSCOP
 When 2 : DOSORG = DOSREF
 When 3 : DOSORG = GDOSX3
Endcase
If DOSORG=""
 DOSORG = nomap
Endif

If clalev([F:AWM])=0  : Local File =DOSORG+".AWRKLNK"   [AWM]  : Endif
If clalev([F:AWK])=0  : Local File =DOSORG+".AWRKTAB"   [AWK]  : Endif
If clalev([F:ATB])=0  : Local File =DOSORG+".ATABLE"    [ATB]  : Endif
If clalev([F:ATI])=0  : Local File =DOSORG+".ATABIND"   [ATI]  : Endif
If clalev([F:AMP])=0  : Local File =DOSORG+".AMSKPAR"   [AMP]  : Endif
If clalev([F:ATZ])=0  : Local File =DOSORG+".ATABZON"   [ATZ]  : Endif
If clalev([F:ATY])=0  : Local File =DOSORG+".ATYPE"     [ATY]  : Endif
If clalev([F:ADLO])=0 : Local File =GDOSX3+".ADELIVERO" [ADLO] : Endif

If clalev([F:ACV8])=0  : Local File =DOSSIER+".ACTIV"     [ACV8]  : Endif
If clalev([F:AXX2])=0  : Local File =DOSSIER+".ATEXTRA"   [AXX2]  : Endif

# WMVMOD*
NOMPROG = format$("KTv2:30X",func APREFIXTRT.GET_COPMOD+MODDON+num$(adxuid(2)))
Call VALID(DOSSIER,DOSORG,KITLIV,MODDON,NOMPROG,DETAIL,STAT)
If !STAT
 # Erreur dans la copie des données (modèle $1$ du kit/livrable $2$)
 Call ECR_TRACE(func AFNC.MES2(mess(265,143,1),MODDON,KITLIV),-1) From GESECRAN
 Call MOVE(filpath("TRT",NOMPROG,"src"),filpath("TRT","WWERR_"+MODDON+num$(adxuid(2)),"src"),STAT) From ORDSYS
Else
 Gosub COPY From =NOMPROG
 Call EFFACE_ADX("","",NOMPROG,STAT) From ORDSYS
 Call EFFACE(filpath("TRT",NOMPROG,"adx"),STAT) From ORDSYS
 #113657
 #Call MOVE(filpath("TRT",NOMPROG,"src"),filpath("TRT","WWOLD_"+MODDON+num$(adxuid(2)),"src"),STAT) From ORDSYS
 Call EFFACE(filpath("TRT",NOMPROG,"src"),STAT) From ORDSYS
Endif

Close Local File

End

#---------------------------------------------------------------------------------#
Subprog VALID(DOSSIER,DOSORG,KITLIV,MODDON,NOMPROG,DETAIL,OK)
Value    Char    DOSSIER
Value    Char    DOSORG
Value    Char    KITLIV
Value    Char    MODDON
Value    Char    NOMPROG
Value    Integer DETAIL
Variable Integer OK

Local Char     FICSRC(GDIMFIC) , IDENT(20) , FLDLEG(30)
Local Char     CHAINE(250) , MAGIC(80) , BUF(250) , FORMULE(255)
Local Integer  I , J , K , L , M , N , OK , SPA
Local Shortint DIME : DIME = 20
Local Char     TBORI(GLONATB+GLONABR+1)(1..DIME) , TBLNK(GLONATB+GLONABR+1)(1..DIME) , TBCLE(GLONANX)(1..DIME)
Local Char     TBEXP(80)(1..DIME) , TBSEL(80)(1..DIME)
Local Integer  NBTB , NIV , TBNIV(1..DIME)
Local Char     REFTAB(GLONATB) , ABRREF(GLONABR) , CLEREF(GLONANX) , TAB(GLONATB+GLONABR+1)(1..DIME)
Local Char     REFREF(250) , ABREV(10) , TABLE(20)

MAGIC = mess(77,133,1) : # Superviseur Adonix
IDENT = "##"-func APREFIXTRT.GET_COPMOD-"##"

OK = 1
If [L]MODDON=""
 Call ECR_TRACE(mess(134,141,1),1) From GESECRAN : # Erreur de syntaxe
 OK = 0
Endif

Read [AWM]AWM0=[L]MODDON
If fstat
 Call ECR_TRACE([L]MODDON-":"-mess(7,140,1),1) From GESECRAN : # Modèle de données inexistant
 OK = 0
Else
 Look [ATB]CODFIC=[F:AWM]TABREF
 If fstat
  Call ECR_TRACE([F:AWM]TABREF-":"-mess(124,124,1),1) From GESECRAN : # Table inexistante
  OK = 0
 Else
  For [AWK]AWK0 Where MODELE=[AWM]MODELE & TYPTAB<1
   If [F:AWK]TABLNK<>""
    Look [ATB]CODFIC=[F:AWK]TABLNK
    If fstat
     Call ECR_TRACE([F:AWK]TABLNK-":"-mess(124,124,1),1) From GESECRAN : # Table inexistante
     OK = 0 : Break
    Endif
   Endif
  Next I
 Endif
Endif

Read [ADLO]ADLO0(2)=KITLIV;[F:AWM]TABREF
If fstat
 Call ECR_TRACE([L]KITLIV-[F:AWM]TABREF-":"-'Livrable ou Kit inexistant',1) From GESECRAN
 OK = 0
Endif

If OK
 Gosub TRT_DEB
 If OK
  Gosub ETIQ
  Gosub TRT_FIN
 Endif
Endif

End

#-------------------------------------------------------#
$TRT_DEB
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
FICSRC = filpath("TRT",NOMPROG,"src")
If filinfo(FICSRC,0)>=0
 Openi FICSRC Using [SSS_]
 Raz I, OK
 Rdseq CHAINE Using [SSS_]
 While !fstat
  I += 1 : If I>5 : Break : Endif
  If left$(CHAINE,len(IDENT))=IDENT
   OK = 1 : Break
  Endif
  Rdseq CHAINE Using [SSS_]
 Wend
 Openi Using [SSS_]
 If !OK
  # Ce traitement est déjà utilisé par un autre paramétrage
  Call ECR_TRACE(NOMPROG-":"-mess(215,139,1),1) From GESECRAN
  Return
 Endif
Else
 OK = 1
Endif
Openo FICSRC , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq IDENT-mess(264,143,1)-KITLIV+"/"+MODDON-'('+num$(datetime$)+')' : # Livrable ou kit
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN
Wrseq
Openo
Call VALID("TRT",NOMPROG,nomap,OK) From VALMSKSUB
Return

#------------------------------------------------------------------------------#
$ETIQ
Wrseq "#-----------------------#"
Wrseq "$COPY"
Wrseq

# Chargement des tables liées
NBTB = 0
For [AWK]AWK0 Where MODELE=[AWM]MODELE & TYPTAB<1
 If [F:AWK]TABLNK<>""
  NBTB += 1
  TBLNK(NBTB) = [F:AWK]TABLNK
  TBORI(NBTB) = [F:AWK]TABORI
  TBCLE(NBTB) = [F:AWK]CLELNK
  TBEXP(NBTB) = [F:AWK]EXPLNK
  TBSEL(NBTB) = [F:AWK]EXPSEL
  If [F:AWK]ABRLNK<>""
   TBLNK(NBTB) += "~"+[F:AWK]ABRLNK
  Else
   Read [ATB]CODFIC=[F:AWK]TABLNK
   TBLNK(NBTB) += "~"+[F:ATB]ABRFIC
  Endif
  If [F:AWK]ABRORI<>""
   TBORI(NBTB) += "~"+[F:AWK]ABRORI
  Else
   Read [ATB]CODFIC=[F:AWK]TABORI
   TBORI(NBTB) += "~"+[F:ATB]ABRFIC
  Endif
 Endif
Next I

# Table principale
REFTAB = [F:AWM]TABREF
Read [ATB]CODFIC=[F:AWM]TABREF
ABRREF = [F:ATB]ABRFIC
CLEREF = [F:ADLO]TABKEYNAM
REFREF = REFTAB+"~"+ABRREF
FLDLEG = ""
If [F:ATB]FLGLEG=2
 For [ATZ]CODZONE Where CODFIC=REFTAB & CHPLEG=2
  FLDLEG = [F:ATZ]CODZONE
 Next ATZ_
Endif

# Open files
Wrseq 'Local File =DOSORG+".'+REFTAB+'" ['+ABRREF+']'
Wrseq 'Local File =DOSORG+".ATEXTRA" [AXX1]'
For I=1 To NBTB
 K = instr(1,TBLNK(I),"~")
 Wrseq 'Local File =DOSORG+".'+left$(TBLNK(I),K-1)+'" ['+right$(TBLNK(I),K+1)+']'
Next I
Wrseq
Wrseq 'Local File =DOSSIER+".'+REFTAB+'" [DEST_]'
For I=1 To NBTB
 K = instr(1,TBLNK(I),"~")
 Wrseq 'Local File =DOSSIER+".'+left$(TBLNK(I),K-1)+'" [DEST_'+num$(I)+']'
Next I

Wrseq
Wrseq 'Local Integer I , J , K , OK'
Wrseq 'Local Char    KEYVAL(50) , CHAINE(250)'
Wrseq

# Field 'Législation'
If [L]FLDLEG<>"" & REFTAB<>"TABFOR"
 Wrseq 'If !LEGNUL'
 Wrseq ' If ONELEG'
 Wrseq '  Filter ['+ABRREF+'] Where '+[L]FLDLEG+'=TBLEG(1)'
 Wrseq ' Else'
 Wrseq '  Filter ['+ABRREF+'] Where '+[L]FLDLEG+'<>"" & find('+[L]FLDLEG+',TBLEG(1..NBLEG))<>0'
 Wrseq ' Endif'
 Wrseq 'Else'
 Wrseq ' If ONELEG'
 Wrseq '  Filter ['+ABRREF+'] Where '+[L]FLDLEG+'=TBLEG(1) or '+[L]FLDLEG+'=""'
 Wrseq ' Else'
 Wrseq '  Filter ['+ABRREF+'] Where '+[L]FLDLEG+'="" or find('+[L]FLDLEG+',TBLEG(1..NBLEG))<>0'
 Wrseq ' Endif'
 Wrseq 'Endif'
Endif

Wrseq 'Trbegin [DEST_]'
Wrseq ' Gosub UPDATE_RECORD'
Wrseq 'Commit'
Wrseq

# Close files
Wrseq 'Close local File ['+ABRREF+']'
Wrseq 'Close local File [AXX1]'
For I=1 To NBTB
 K = instr(1,TBLNK(I),"~")
 Wrseq 'Close local File ['+right$(TBLNK(I),K+1)+']'
Next I
Wrseq
Wrseq "Close local File [DEST_]"
For I=1 To NBTB
 K = instr(1,TBLNK(I),"~")
 Wrseq "Close local File [DEST_"+num$(I)+"]"
Next I
Wrseq

Wrseq 'Return'
Wrseq

Wrseq '#------------------------------#'
Wrseq '$UPDATE_RECORD'

Wrseq 'Default File ['+ABRREF+']'
Wrseq

NIV = 1
SPA = 5
L = 0

# Loop master file
Wrseq 'For [ADLO]ADLO0 Where COD="'+KITLIV+'" & TABCOD="'+REFTAB+'"'
If [F:ATB]FLGLEG<>2 or REFTAB="TABFOR"
 Wrseq ' K = 1'
Else
 Wrseq ' K = 0'
 Wrseq ' If [F:ADLO]TABLEG=""'
 Wrseq '  K = 1'
 Wrseq ' Elsif ONELEG & [F:ADLO]TABLEG=TBLEG(1)'
 Wrseq '  K = 1'
 Wrseq ' Elsif !ONELEG & [F:ADLO]TABLEG<>"" & find([F:ADLO]TABLEG,TBLEG)'
 Wrseq '  K = 1'
 Wrseq ' Endif'
Endif
Wrseq ' If K'
Read [ATB]CODFIC=REFTAB
Read [ATI]CODIND=REFTAB;CLEREF
Gosub SETCLE
Wrseq '  CHAINE = [F:ADLO]TABKEY'
Wrseq '  I = 0'
Wrseq '  While CHAINE<>""'
Wrseq '   I += 1'
Wrseq '   K = instr(1,CHAINE,"~")'
Wrseq '   If K'
Wrseq '    KEYVAL = left$(CHAINE,K-1)'
Wrseq '    CHAINE = right$(CHAINE,K+1)'
Wrseq '   Else'
Wrseq '    KEYVAL = CHAINE'
Wrseq '    CHAINE = ""'
Wrseq '   Endif'
Wrseq '   Case I'
For I=1 To NBCLE
 Wrseq '    When '+num$(I)+' : [F:'+ABRREF+']'+CLE(I)+' = ';
 Case TYP(I)
  When 1,2,3,4,5,6 : Wrseq 'val(KEYVAL)'
  When 8           : Wrseq 'evalue("["+format$(GFMD,KEYVAL)+"]")'
  When Default     : Wrseq 'KEYVAL'
 Endcase
Next I
Wrseq '   Endcase'
Wrseq '  Wend'
Wrseq '  Read [F:'+ABRREF+']'+CLEREF+' ='
Wrseq '  If fstat'
Wrseq '   If DETAIL'
Wrseq '    # Enregistrement non trouvé'
Wrseq '    Call ECR_TRACE(mess(81,75,1)-"'+REFTAB+'"-[F:ADLO]TABKEY,-1) From GESECRAN'
Wrseq '   Endif'
Wrseq '  Else'
If REFTAB="TABFOR"
 Wrseq '   Gosub COPY_TFO From ADOSCOPDAT'
Else
 Wrseq '   OK = 1'
 Read [ATZ]CODZONE=REFTAB;"CODACT"
 If !fstat
  Wrseq '   If [F:'+ABRREF+']CODACT<>""'
  Wrseq '    Read [ACV8]CODACT = [F:'+ABRREF+']CODACT'
  Wrseq '    If fstat or [F:ACV8]FLACT<>2 : OK = 0 : Endif'
  Wrseq '   Endif'
 Endif
 Read [ATZ]CODZONE=REFTAB;"MODULE"
 If !fstat
  Wrseq '   If [F:'+ABRREF+']MODULE>0 & [L]MODULE([F:'+ABRREF+']MODULE)<>2 : OK = 0 : Endif'
 Endif
 If REFTAB="POSCOD"
  Wrseq '   If dim([F:'+ABRREF+']CRY)>0 & [F:'+ABRREF+']CRY<>[L]CRYDEF : OK = 0 : Endif'
 Endif
 Wrseq '   If OK'
 Wrseq '    [F:DEST_] = [F:'+ABRREF+']'
 If [L]FLDLEG<>"" & !instr(1,[L]FLDLEG,"[")
  Wrseq '    If ONELEG & LEGNUL & [F:DEST_]'+[L]FLDLEG+'=""'
  Wrseq '     [F:DEST_]'+[L]FLDLEG+' = TBLEG(1)'
  Wrseq '    Endif'
 Endif
 Wrseq '    look [F:DEST_] ='
 Wrseq '    If !fstat'
 If [L]FLDLEG<>"" & !instr(1,[L]FLDLEG,"[")
  Wrseq '     If ONELEG & LEGNUL & [F:'+ABRREF+']'+[L]FLDLEG+'<>""'
  Wrseq '      Read [F:DEST_] ='
  Wrseq '      [F:DEST_] = [F:'+ABRREF+']'
  Wrseq '      Rewrite [F:DEST_]'
  Wrseq '      If fstat'
  Wrseq '       Call ERREUR("'+REFTAB+'"-[F:ADLO]TABKEY,1) From DOSDIC'
  Wrseq '      Elsif DETAIL'
  Wrseq '       Call ECR_TIME(mess(104,141,1)-"'+REFTAB+'"-[F:ADLO]TABKEY) From DOSSUB : # Enregistrements modifiés'
  Wrseq '      Endif'
  Wrseq '     Elsif DETAIL'
 Else
  Wrseq '     If DETAIL'
 Endif
 Wrseq '      # Enregistrement existant'
 Wrseq '      Call ECR_TRACE(mess(224,115,1)-"'+REFTAB+'"-[F:ADLO]TABKEY,-1) From GESECRAN'
 Wrseq '     Endif'
 Wrseq '    Else'
 Gosub RAZ_ZONE
 Wrseq '     Write [F:DEST_]'
 Wrseq '     If fstat'
 Wrseq '      Call ERREUR("'+REFTAB+'"-[F:ADLO]TABKEY,1) From DOSDIC'
 Wrseq '     Else'
 Wrseq '      If DETAIL'
 Wrseq '       # Enregistrement créé'
 Wrseq '       Call ECR_TIME(mess(36,149,1)-"'+REFTAB+'"-[F:ADLO]TABKEY) From DOSSUB'
 Wrseq '      Endif'
 Gosub UPD_AXX
 Wrseq '      Gosub UPDATE_LNK_FILES'
 Wrseq '     Endif'
 Wrseq '    Endif'
 Wrseq '   Endif'
Endif
Wrseq '  Endif'
Wrseq ' Endif'
Wrseq 'Next ADLO'
Wrseq

Wrseq 'Return'
Wrseq

# Update secondary files
Wrseq '#----------------------------------#'
Wrseq '$UPDATE_LNK_FILES'

NIV = 1
SPA = 2

Call LOOP_FOR(NBTB,NIV,SPA,TBLNK,TBORI,TBCLE,TBEXP,REFREF)

Wrseq 'Return'
Return

#---------------------------------------------------------------------------#
Subprog LOOP_FOR(NB,NIV,SPA,TBLNK,TBORI,TBCLE,TBEXP,REF)
Value Integer NB , NIV
Value Char    TBLNK()(1..) , TBORI()(1..) , TBCLE()(1..) , TBEXP()(1..)
Value Char    REF
Local Integer I , J , K , SUBNIV
For L=1 To NB
 If TBORI(L)=REF
  Gosub ONE_FOR
  SUBNIV = NIV+1
  Call LOOP_FOR(NB,SUBNIV,SPA,TBLNK,TBORI,TBCLE,TBEXP,TBLNK(L))
  Wrseq space$(NIV-1)+'Next'
 Endif
Next L
End

#---------------#
$ONE_FOR
K = instr(1,TBLNK(L),"~")
Read [ATB]CODFIC=left$(TBLNK(L),K-1)
Read [ATI]CODIND=left$(TBLNK(L),K-1);TBCLE(L)
Gosub SETCLE
Wrseq space$(NIV-1)+'For ['+right$(TBLNK(L),K+1)+']'+TBCLE(L);
CHAINE = TBEXP(L)
I = 0
While CHAINE<>""
 I += 1
 J = instr(1,CHAINE,';')
 If J
  LNK = left$(CHAINE,J-1)
  CHAINE = right$(CHAINE,J+1)
 Else
  LNK = CHAINE
  CHAINE = ""
 Endif
 If I=1
  Wrseq ' Where ';
 Else
  Wrseq ' & ';
 Endif
 Wrseq CLE(I)+'='+LNK;
Wend
Wrseq
Wrseq space$(NIV-1)+' [F:DEST_'+num$(L)+']=[F:'+right$(TBLNK(L),K+1)+']'
Wrseq space$(NIV-1)+' Look [F:DEST_'+num$(L)+']'+TBCLE(L)+' ='
Wrseq space$(NIV-1)+' If !fstat'
Gosub NAMKEY
Wrseq space$(NIV-1)+'  If DETAIL'
Wrseq space$(NIV-1)+'   # Enregistrement existant'
Wrseq space$(NIV-1)+'   Call ECR_TRACE(mess(224,115,1)-'+CHAINE+',-1) From GESECRAN'
Wrseq space$(NIV-1)+'  Endif'
Wrseq space$(NIV-1)+' Else'
Wrseq space$(NIV-1)+'  [F:DEST_'+num$(L)+']=[F:'+right$(TBLNK(L),K+1)+']'
Gosub RAZ_ZONE
Wrseq space$(NIV-1)+'  Write [F:DEST_'+num$(L)+']'
Wrseq space$(NIV-1)+'  If fstat'
Gosub NAMKEY
Wrseq space$(NIV-1)+'   Call ERREUR('+CHAINE+',1) From DOSDIC'
Wrseq space$(NIV-1)+'  Else'
Wrseq space$(NIV-1)+'   If DETAIL'
Wrseq space$(NIV-1)+'  # Enregistrement créé'
Wrseq space$(NIV-1)+'    Call ECR_TIME(mess(36,149,1)-'+CHAINE+') From DOSSUB : # Enregistrement créé'
Wrseq space$(NIV-1)+'   Endif'
Gosub UPD_AXX
Wrseq space$(NIV-1)+'  Endif'
Wrseq space$(NIV-1)+' Endif'
Return

#-------------------------------------------------#
$NAMKEY
CHAINE = '"'+left$(TBLNK(L),K-1)+'"-'
For I=1 To NBCLE
 If len(CHAINE)>200
  Break
 Endif
 If I>1
  CHAINE += '+"~"+'
 Endif
 Case TYP(I)
  When 1,2,3,4,5,6 : CHAINE += 'num$([F:'+right$(TBLNK(L),K+1)+']'+CLE(I)+')'
  When 8           : CHAINE += 'num$([F:'+right$(TBLNK(L),K+1)+']'+CLE(I)+')'
  When Default     : CHAINE += '[F:'+right$(TBLNK(L),K+1)+']'+CLE(I)
 Endcase
Next I
Return

#---------------------------------------------------#
$UPD_AXX
If L=0
 TABLE = REFTAB
 ABREV = ABRREF
Else
 TABLE = left$(TBLNK(L),K-1)
 ABREV = right$(TBLNK(L),K+1)
Endif
For [ATZ]CODZONE Where CODFIC=TABLE & find(CODTYP,"AXX","AX1","AX2","AX3")
 For [AMP] Where TYPAFF=2 & CODAFF=[F:ATZ]CODFIC & CODZON=[ATZ]CODZONE
  Case [AMP]CODPAR
   When "TABLE1"   : TABLE1  = '"'+ctrans([AMP]VALPAR,'"',"¨")+'"'
   When "ZONE"     : ZONE    = '"'+ctrans([AMP]VALPAR,'"',"¨")+'"'
   When "CLECUR1"  : CLECUR1 = '"'+ctrans([AMP]VALPAR,'"',"¨")+'"'
   When "CLECUR2"  : CLECUR2 = '"'+ctrans([AMP]VALPAR,'"',"¨")+'"'
  Endcase
 Next AMP_
 If TABLE1<>"" and ZONE<>""
  Gosub SET_REPET
  Wrseq space$(SPA+NIV-1)+' Call UPDATE_TEXTRA(TBLAN,NBLAN,'+num$(REPET)+',"'+ABREV+'","'+"DEST_"+string$(L>0,num$(L))+'"';
  Wrseq ','+TABLE1+','+ZONE+','+CLECUR1+','+CLECUR2+') From ADOSCOPDAT'
 Endif
Next ATZ_
Return

#-----------------------------------------------------#
$RAZ_ZONE
If L=0
 CHAINE = REFTAB
Else
 CHAINE = left$(TBLNK(L),K-1)
Endif
For [ATZ]CODZONE Where CODFIC=CHAINE & ZERO=2
 Read [ATY]CODTYP=[F:ATZ]CODTYP
 Gosub SET_REPET
 For I=1 To REPET
  If I=1
   Wrseq space$(SPA+NIV-1)+' [F:DEST_'+string$(L>0,num$(L))+']'+[F:ATZ]CODZONE+' = ';
  Else
   Wrseq space$(SPA+NIV-1)+' [F:DEST_'+string$(L>0,num$(L))+']'+[F:ATZ]CODZONE+'('+num$(I-1)+') = ';
  Endif
  Case [F:ATY]TYPTYP
   When 1,2,3,4,5,6 : Wrseq '0'
   When 8           : Wrseq '[0/0/0]'
   When Default     : Wrseq '""'
  Endcase
 Next I
Next ATZ_
Return

#---------------------------#
$SET_REPET
Local Integer REPET
REPET = 0
If [ATZ]DIME>0
 REPET = [F:ATZ]DIME
Elsif [F:ATZ]CODACT <> ""
 Read [ACV8]CODACT = [F:ATZ]CODACT
 If !fstat
  If [F:ACV8]DIMFIL>0 & [F:ACV8]DIME>0 & [F:ACV8]DIMMAX>0
   REPET = min(max([F:ACV8]DIMFIL,[F:ACV8]DIME),[F:ACV8]DIMMAX)
  Elsif ([F:ACV8]DIMFIL<>0 | [F:ACV8]DIME<>0)
   REPET = max([F:ACV8]DIMFIL,[F:ACV8]DIME)
  Endif
 Endif
 REPET = max(REPET,1)
Endif
Return

#-----------------------#
$SETEXP
Local Char    EXPCLE(GLONID1)(1..16)
Local Integer NBEXP , POS
Raz NBEXP , EXPCLE
While CHAINE<>""
 NBEXP += 1
 POS = instr(1,CHAINE,"~")
 If POS
  EXPCLE(NBEXP) = left$(CHAINE,POS-1)
  CHAINE = right$(CHAINE,POS+1)
 Else
  EXPCLE(NBEXP) = CHAINE
  CHAINE = ""
 Endif
Wend
Return

#-----------------------#
$SETCLE
Local Char    CLE(GLONID1)(1..16)
Local Integer NBCLE , POS , TYP(1..16)
CHAINE = [F:ATI]DESCRIPT
Raz NBCLE , CLE
While CHAINE<>""
 NBCLE += 1
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
 Read [ATZ]CODZONE=[F:ATB]CODFIC;CLE(NBCLE)
 Read [ATY]CODTYP=[F:ATZ]CODTYP
 TYP(NBCLE) = [F:ATY]TYPTYP
Wend
Return

