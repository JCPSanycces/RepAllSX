#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet AGS
######################################################################################
$ACTION
Case ACTION
    When "AFFMASK"     : Gosub AFFMASK
    When "SETBOUT"   : Gosub SETBOUT
    When "RAZCRE"    : Gosub RAZCRE
    When "RAZDUP"    : Gosub RAZDUP
    When "LIENS"     : Gosub LIENS
    When "APRES_CRE" : Gosub APRES_CREMOD
    When "APRES_MOD" : Gosub APRES_CREMOD
    When "VERIF_CRE" : Gosub VERIF_CREMOD
    When "VERIF_MOD" : Gosub VERIF_CREMOD
    When Default
Endcase
Return

$AFFMASK
If GADONIX<>2
    Diszo [M:AGS1]RECSTD
Endif
Return

$RAZCRE
[M:AGS1]TYP=1   # to initialize when no last read
If GADONIX=2
    [M:AGS1]RECSTD = 2
Else
    [M:AGS1]RECSTD = 1
    Diszo [M:AGS1]RECSTD
Endif
[M:AGS1]ENAFLG = 2
Call ACTIVE_FIELDS
Return

$RAZDUP
If GADONIX<>2
    [M:AGS1]RECSTD = 1
    Diszo [M:AGS1]RECSTD
Endif
Return

$LIENS
# If the setting doesn't fit to current folder (data type or table missing) => disable it
If [M:AGS1]ENAFLG=2 & func CHKENAFLG(GMESSAGE)=[V]CST_AERROR
    Trbegin [AGS]
    [F:AGS]ENAFLG = 1
    Rewrite [AGS]
    If fstat=[V]CST_AOK
        Commit
        [M:AGS1]ENAFLG = 1
        Affzo [M:AGS1]ENAFLG
    Else
        Rollback
        Call FSTA("AGS") From GLOCK
    Endif
Endif
Call ACTIVE_FIELDS
# Linked data types are checked only for "References"
If [F:AGS]TYP = 1
    Call SEARCH_LINKS([M:AGS1]CODATY)
Endif
Return

$APRES_CREMOD
If [M:AGS1]TYP = 1
    Call SEARCH_LINKS([M:AGS1]CODATY)
Endif
Return

$VERIF_CREMOD
If [M:AGS1]ENAFLG=2 & func CHKENAFLG(GMESSAGE)=[V]CST_AERROR
    GERR=2  # Information message & disable the setting
    [M:AGS1]ENAFLG = 1
    Affzo [M:AGS1]ENAFLG
Endif
Return

$SETBOUT
# Only Sage can remove & rename Standard records
If [M:AGS1]RECSTD=2 & GADONIX<>2
    Call VIREBOUT(CHAINE,"AH")      From GOBJET
Endif
Return

######################################################################################
Subprog C_ENAFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & func CHKENAFLG(GMESSAGE)=[V]CST_AERROR
    mkstat=2
    End
Endif

End
######################################################################################
Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>1 & [M:AGS1]CODATY<>""
    # Not a reference & data type entered => enter a data type only
    Effzo [M:AGS1]CODATB, CODFLD
Endif
[M:AGS1]TYP = VALEUR
Call ACTIVE_FIELDS
End

######################################################################################
Subprog C_CODATY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M:AGS1]TYP=1
    GMESSAGE = mess(10,123,1)
    mkstat=2
    End
Endif
If VALEUR<>""
    If func CTRTYP([M:AGS1]TYP, VALEUR, GMESSAGE)<>[V]CST_AOK
        mkstat=2
        End
    Endif
Endif
End

######################################################################################
Subprog AM_CODATY(VALEUR)
Variable Char    VALEUR()
Raz [M:AGS1]CODATB, [M:AGS1]CODFLD
# For reference, Table+field are mandatory => try to initialize them
# For other types (e-mails, phone), if data type is entered, table+field are not entered
If [M:AGS1]TYP=1
    Read [ATY]CODTYP = VALEUR
    If fstat=[V]CST_AOK
        [M:AGS1]CODATB = [F:ATY]FICLIEN
        Filter [ATI] Where [F:ATI]CODFIC=[F:ATY]FICLIEN
&                    Order By NUMLIG
        Read [ATI] First
        Filter [ATI]
        # The field is initialized with the main key if the descriptor contains only 1 field
        If fstat=[V]CST_AOK
&        & instr(1,[F:ATI]DESCRIPT,"+")=0
&        & instr(1,[F:ATI]DESCRIPT,"-")=0
            [M:AGS1]CODFLD = [F:ATI]DESCRIPT
        Endif
    Endif
Endif
Affzo [M:AGS1]CODATB, CODFLD
# Reset grid with linked data types
Effzo [M:AGS1]10

[M:AGS1]CODATY = VALEUR
Call ACTIVE_FIELDS
End

######################################################################################
Subprog C_CODATB(VALEUR)
Variable Char    VALEUR()
# the table must be entered if the type is "Reference" or if data type has not been entered
If VALEUR="" & ([M:AGS1]CODATY="" | [M:AGS1]TYP=1)
    GMESSAGE = mess(10,123,1)
    mkstat=2
    End
Endif
End

######################################################################################
Subprog AS_CODFLD(VALEUR)
Variable Char    VALEUR()
If [M:AGS1]CODATB=""
    mkstat=1
Endif
End

######################################################################################
Subprog C_CODFLD(VALEUR)
Variable Char    VALEUR()
# the field code must be entered if the type is "Reference" or if data type has not been entered
If VALEUR="" & ([M:AGS1]CODATB<>"" | [M:AGS1]TYP=1)
    GMESSAGE = mess(10,123,1)
    mkstat=2
    End
Endif
If VALEUR<>""
    # Check if the field exists in the table
    Read [ATZ]CODZONE = [M:AGS1]CODATB;VALEUR
    If fstat<>[V]CST_AOK
        GMESSAGE = mess(41,100,1) : # Non-existent Field
        mkstat = 2
        End
    Endif
    # For GDPR type not a reference (e-mail, phone..) it must correspond to data type entered
    # For GDPR type = reference, the data type can be different (ex: BPA -> BPARTNER.BPRNUM
    If [M:AGS1]TYP>1
&    & [M:AGS1]CODATY<>""
&    & [F:ATZ]CODTYP<>[M:AGS1]CODATY
        GMESSAGE=mess(14,133,1)
        mkstat=2
        End
    Endif

    If func CTRTYP([M:AGS1]TYP, [F:ATZ]CODTYP, GMESSAGE)<>[V]CST_AOK
        mkstat=2
        End
    Endif
Endif
End


######################################################################################
Subprog IB_NBLIG
If GREP="" & [M:AGS1]EXIFLG(nolign-1) = 2
    Raz GBOUT1  # Don't generate if already existing
Endif
End

######################################################################################
Subprog B1_NBLIG
If func DUPLICATE_AGS([M:AGS1]CODE,[M:AGS1]CODTYP(nolign-1),[M:AGS1]CODTYP(nolign-1))=[V]CST_AOK
    [M:AGS1]EXIFLG(nolign-1)=2
    Affzo [M:AGS1]EXIFLG(nolign-1)
    Call MESSAGE(mess(36,149,1))From GESECRAN
Endif
End

######################################################################################

Subprog ACTIVE_FIELDS

If [M:AGS1]RECSTD=2 & GADONIX<>2
    # Only Activation can be modified
    Grizo [M:AGS1]TYP, CODATY, CODATB, CODFLD

Else
    Actzo [M:AGS1]TYP, CODATY

    If [M:AGS1]TYP=1
        Actzo [M:AGS1]CODATB
        Actzo [M:AGS1]CODFLD
    Else
        # E-mail or phone => everything can be entered except if a data type has been entered
        If [M:AGS1]CODATY<>""
            Grizo [M:AGS1]CODATB
            Grizo [M:AGS1]CODFLD
        Else
            Actzo [M:AGS1]CODATB
            Actzo [M:AGS1]CODFLD
        Endif
    Endif
Endif

End
#**
#* Search data types linked to the same object than a data type and fill the screen [M:AGS1] with them
#*
#* @param PTYP : reference data type
#*!
Subprog SEARCH_LINKS(PTYP)
Value Char PTYP

Local Char LTAB(GLONATB)
Local Integer I

Local File ATYPE [ATY]
Local File AOBJET [AOB]

Effzo [M:AGS1]10

# Look for the linked table
Link [ATY] With [AOB]ABREV=[ATY]OBJLIEN
&          As [LNK]
&          Where [ATY]CODTYP=[L]PTYP
Read [LNK] First
If fstat=[V]CST_AOK & [F:AOB]NOMFIC<>""
    LTAB = [F:AOB]NOMFIC

    # Look for data types linked to the same object
    Link [ATY] With [AOB]ABREV~=[ATY]OBJLIEN
&              As [LNK]
&              Where [ATY]CODTYP<>[L]PTYP
&                and [AOB]NOMFIC=LTAB
    Raz [M:AGS1]NBLIG
    For [LNK]
        # Check if a record already exists in AGDPRSETTING
        Filter [AGS] Where TYP=1
&                        & CODATY = [F:ATY]CODTYP
        Look [AGS] First
        Filter [AGS]
        If fstat=[V]CST_AOK
            [M:AGS1]EXIFLG([M:AGS1]NBLIG) = 2
        Else
            [M:AGS1]EXIFLG([M:AGS1]NBLIG) = 1
        Endif
        [M:AGS1]CODTYP([M:AGS1]NBLIG) = [F:ATY]CODTYP
        [M:AGS1]NBLIG+=1
        If [M:AGS1]NBLIG=dim([M:AGS1]CODTYP)
            Call ERREUR(mess(26,100,1)) From GESECRAN
            Break
        Endif
    Next
    Affzo [M:AGS1]10
Endif

LogicClose File [AOB], [ATY]
End

#**
#* Duplicate a record of AGDPRSETTING by changing data type
#*
#* @param PAGSCODE : Code of reference record in AGDPRSETTING
#* @param PNEWNAME : Code for new record : If the new code alredy exists, an incremental number will be added
#* @param PATY     : Data type to set in the new record. Set "" to change nothing
#*!
Funprog DUPLICATE_AGS(PAGSCODE, PNEWNAME, PATY)
Value Char PAGSCODE
Value Char PNEWNAME
Value Char PATY

Local Char LCODE(type([F:AGS]CODE)-10)
Local Integer I, TRANSAC, LRET
Local File AGDPRSETTING [AGS]

LRET = [V]CST_AOK

Read [AGS]AGS0=PAGSCODE
If fstat<>[V]CST_AOK
    # The model doesn't exist
    Call RSTA("AGS",LCODE) From GLOCK
    LRET = [V]CST_AERROR

Else
    # Look for a name that doesn't exist yet: new code or new code + number
    LCODE = PNEWNAME
    Look [AGS]AGS0=LCODE
    Raz I
    While fstat=[V]CST_AOK
        I+=1
        LCODE = left$(PNEWNAME,type([F:AGS]CODE)-10-len(num$(I)))+num$(I)
        Look [AGS]AGS0=LCODE
    Wend

    # Duplication
    If adxlog=0
        Trbegin [AGS]
        TRANSAC=1
    Endif
    [F:AGS]CODE = LCODE
    If PATY<>""
        [F:AGS]CODATY = PATY
    Endif

    # Standard setting can only be created by Sage
    If GADONIX<>2
        [F:AGS]RECSTD=1
    Endif

    Write [F:AGS]

    If fstat<>[V]CST_AOK
        If TRANSAC=1
            Rollback
        Endif
        Call RSTA("AGS",LCODE) From GLOCK
        LRET = [V]CST_AERROR
    Else
        If TRANSAC=1
            Commit
        Endif
        If GADONIX=2 : Call TRACE_COR("AGS",[F:AGS]CODE,"","C") From GOBJET : Endif
    Endif
Endif

LogicClose File [AGS]

End LRET

#**
#* Control if a data type is compatible with the type of setting (see local menu 7947)
#*
#* @param PGDPRTYP : Type of setting (value in local menu 7947)
#* @param PATY     : Data type to control
#* @param PMSG     : gets error message if an error occurs
#* @return [V]CST_AERROR if an error occured otherwise [V]CST_AOK
#*!
Funprog CTRTYP(PGDPRTYP, PATY, PMSG)
Value Integer PGDPRTYP
Value Char PATY
Variable Char PMSG

Local Integer LRET
LRET = [V]CST_AOK
Raz PMSG

Local File ATYPE [ATY]

Read [ATY]CODTYP=PATY
If fstat<>[V]CST_AOK
    PMSG = func GLOCK.GET_FSTAT_MSG(fstat)-"ATYPE : "-PATY
    LRET= [V]CST_AERROR
Else
    Case PGDPRTYP
        When 2 :    # E-mail must be Alphanumeric
            If [F:ATY]TYPTYP<>7
                PMSG = mess(14,133,1)
                LRET = [V]CST_AERROR
            Endif
    Endcase
Endif
LogicClose File [ATY]
End LRET

######################################################################################
Funprog CHKENAFLG(PMSG)
Variable Char PMSG

Local Integer LRET
LRET = [V]CST_AOK

# No control in development mode as the table could not be generated
If GADONIX=2
    End LRET
Endif

Local File ATYPE  [ATY]
Local File ATABLE [ATB]

If [M:AGS1]CODATY<>""
    # If data type doesn't exist (because of activity code) => disable the setting
    Look [ATY]CODTYP = [M:AGS1]CODATY
    If fstat<>[V]CST_AOK
        PMSG = mess(82,133,1)
        LRET=[V]CST_AERROR
    Endif
Endif
If LRET=[V]CST_AOK & [M:AGS1]CODATB<>""
    # if table doesn't exist => disable the setting
    Look [ATB]CODFIC=[M:AGS1]CODATB
    If fstat<>[V]CST_AOK | filinfo(filpath("FIL",[M:AGS1]CODATB,"fde"),0)<0
        PMSG=mess(124,124,1)
        LRET=[V]CST_AERROR
    Endif
Endif

LogicClose File [ATY], [ATB]
End LRET



######################################################################################

