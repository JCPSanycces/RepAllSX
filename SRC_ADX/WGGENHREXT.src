#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre GENHREXT

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:11:00"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"GENHREXT",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="HREXE0;HREXE1;HREXE2;HREXE3;HREXE4;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
If clalev([M:HREXE0])=0 : Local Mask GENHREXT0 [HREXE0] : Endif
If clalev([M:HREXE1])=0 : Local Mask GENHREXT1 [HREXE1] : Endif
If clalev([M:HREXE2])=0 : Local Mask GENHREXT2 [HREXE2] : Endif
If clalev([M:HREXE3])=0 : Local Mask GENHREXT3 [HREXE3] : Endif
If clalev([M:HREXE4])=0 : Local Mask GENHREXT4 [HREXE4] : Endif
Gosub TIT
nolign = 1
Return

$DEF_BOITE
Gosub HORODAT From WGGENHREXT
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "GENHREXT" From GFONCTION At A_STAMP With A_WINDPREV Mask [HREXE0]
&   Invfol Mask [HREXE1]
& , Folder Mask [HREXE2]
& , Invfol Mask [HREXE3]
& , Invfol Mask [HREXE4]
& As [HREXE1]
Titled [HREXE1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGGENHREXT
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "GENHREXT" From GFONCTION At A_STAMP With A_WINDPREV Mask [HREXE0]
&   Invfol Mask [HREXE1]
& , Folder Mask [HREXE2]
& , Invfol Mask [HREXE3]
& , Invfol Mask [HREXE4]
& As [HREXE1]
Titled [HREXE1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [HREXE1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [HREXE1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [HREXE1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TIT(60) , TITTRN(60)
Call TEXTE(1000741,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Return

$DEFAUT_BRO
Return

$SETBOX
Return

$SETORDER
Return

$ENDORDER
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "GENHREXT0"    : ABMSK(0)  = "HREXE0"   : AMA(0) = 1
NOMMSK(1) = "GENHREXT1"    : ABMSK(1)  = "HREXE1"   : AMA(1) = 0
NOMMSK(2) = "GENHREXT2"    : ABMSK(2)  = "HREXE2"   : AMA(2) = 1
NOMMSK(3) = "GENHREXT3"    : ABMSK(3)  = "HREXE3"   : AMA(3) = 0
NOMMSK(4) = "GENHREXT4"    : ABMSK(4)  = "HREXE4"   : AMA(4) = 0
NBMASK = 4
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:HREXE0])>0 : Default Mask [HREXE0] : Endif
 When 1 : If clalev([M:HREXE1])>0 : Default Mask [HREXE1] : Endif
 When 2 : If clalev([M:HREXE2])>0 : Default Mask [HREXE2] : Endif
 When 3 : If clalev([M:HREXE3])>0 : Default Mask [HREXE3] : Endif
 When 4 : If clalev([M:HREXE4])>0 : Default Mask [HREXE4] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:HREXE0])>0 : Gosub TITRES From W1GENHREXT0 : Endif
 When 1 : If clalev([M:HREXE1])>0 : Gosub TITRES From W1GENHREXT1 : Endif
 When 2 : If clalev([M:HREXE2])>0 : Gosub TITRES From W1GENHREXT2 : Endif
 When 3 : If clalev([M:HREXE3])>0 : Gosub TITRES From W1GENHREXT3 : Endif
 When 4 : If clalev([M:HREXE4])>0 : Gosub TITRES From W1GENHREXT4 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:HREXE0])>0 : Close Local Mask [HREXE0] : Endif
If clalev([M:HREXE1])>0 : Close Local Mask [HREXE1] : Endif
If clalev([M:HREXE2])>0 : Close Local Mask [HREXE2] : Endif
If clalev([M:HREXE3])>0 : Close Local Mask [HREXE3] : Endif
If clalev([M:HREXE4])>0 : Close Local Mask [HREXE4] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:HREXE0])>0 : Raz [M:HREXE0] : Endif
 When 1 : If clalev([M:HREXE1])>0 : Raz [M:HREXE1] : Endif
 When 2 : If clalev([M:HREXE2])>0 : Raz [M:HREXE2] : Endif
 When 3 : If clalev([M:HREXE3])>0 : Raz [M:HREXE3] : Endif
 When 4 : If clalev([M:HREXE4])>0 : Raz [M:HREXE4] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:HREXE0])>0 : Affzo [M:HREXE0] : Endif
 When 1 : If clalev([M:HREXE1])>0 : Affzo [M:HREXE1] : Endif
 When 2 : If clalev([M:HREXE2])>0 : Affzo [M:HREXE2] : Endif
 When 3 : If clalev([M:HREXE3])>0 : Affzo [M:HREXE3] : Endif
 When 4 : If clalev([M:HREXE4])>0 : Affzo [M:HREXE4] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Return

$CHARGEMSK
Return

$GRISE_CLE
Return

$DEGRISE_CLE
Return

$BOUTON
STDBOUT = "O"
NBTEX  = 0
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


