#<AdxTL>@(#)0.0.0.0 $Revision$
#*******************************************************************************
#
#                    GESTION DES SECTEURS D'ACTIVITE
#
#*******************************************************************************
#    Création
#    MWA : 21.10.2016  FQ119309 : Champs coefficients non modifiables à tort
#    MWA - 28.03.2008
#    MWA : 08.09.2008  FQ49103  : Révision gestion accès aux champs
#
#**********************************************************************************
#    Modification
#
#**********************************************************************************
#

Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("SEA",GBIDC1,GBIDC2) From GOBJET
End


######################################################################################
$ACTION


#Infbox ACTION
Case ACTION
 When "OUVRE"            : Gosub OUVRE
 When "VERF_ANU"         : Gosub VERF_ANU
 When "INICRE"           : Gosub INICRE
 When "APRES_CRE"        : Gosub APRES_CRE
 When "APRES_MOD"        : Gosub APRES_MOD
 When "LIENS"            : Gosub LIENS
 When "FIN"              : Gosub FIN
 When Default
Endcase
Return

#=====================================================================
#
$OUVRE


  Global Integer  G_STATUS
  Global Integer  G_DEBUG : G_DEBUG = 0
Return

#=====================================================================
#
$INICRE
  Global Integer  G_STATUS
  If !( func GLOFCYCPY.GET_SOC_PAYS([M:SEA0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:SEA0]CPY) = "FRA") Then
    [F:SEA]ASJCOE = 1.
  Endif
Return
#=====================================================================
#
$LIENS

  [M:SEA0]BCREAT(nolign-1) = G_NON

Return
#=====================================================================
#
$APRES_MOD
  Gosub RELIT From GOBJSUB
Return
#=====================================================================
#
$APRES_CRE
  Gosub RELIT From GOBJSUB
Return


#=====================================================================
$VERF_ANU

Local Integer IL
Local Integer B_ERR

  B_ERR = 0
  # >>>>>>>>>>>>>>>>
  For IL = 1 To [M:SEA0]NBLIG1
    # Secteur d'activité est-il utilisé par au moins un bien ou une dépense
    If ( func SUBSEA.IS_SECACT_USED([M:SEA0]CPY, [M:SEA0]SAC(IL-1)) ) Then
      B_ERR = 1
      Break
    Endif
  Next
  # <<<<<<<<<<<<<<<<
  If (B_ERR) Then
    # Suppression impossible : La société utilise au moins un secteur d'activité pour un bien ou une dépense
    GMESSAGE = mess(232,7770,1)
    OK       = 0
    GERR     = 1
    Return
  Endif

Return

#=====================================================================
#
$FIN
  If dim(G_STATUS) >0 : Kill G_STATUS  : Endif
  If dim(G_DEBUG)  >0 : Kill G_DEBUG   : Endif
Return



######################################
Subprog AV_NBLIG1

  If !( func GLOFCYCPY.GET_SOC_PAYS([M:SEA0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:SEA0]CPY) = "FRA" ) Then
    Chgfmt [M:SEA0]ASJCOE With "-N+:3.2#"
  Else
    Chgfmt [M:SEA0]ASJCOE With "N+:3.2#"
  Endif
End

######################################
Subprog C_NBLIG1
  G_STATUS = status
  If (G_STATUS = 68 or G_STATUS = 83  ) Then
    # La suppression des secteurs d'activité doit se faire ligne par ligne,
    # ou en totalité par le bouton supprimer
    GERR= 1 : GMESSAGE= mess(233, 7770, 1)
    mkstat = 2 : End
  Endif
  If ( G_STATUS = 65 and func SUBSEA.IS_SECACT_USED([M:SEA0]CPY, [M:SEA0]SAC(nolign-1)) ) Then
    # Opération impossible : Le secteur d'activité est utilisée par au moins un bien ou une dépense
    GERR= 1 : GMESSAGE= mess(234, 7770, 1)
    mkstat = 2 : End
  Endif


End

######################################
Subprog AM_SAC(VALEUR)
Variable Char    VALEUR()

  If ( ( G_STATUS = 82 or G_STATUS = 73 ) and find (VALEUR, [M:SEA0]SAC) > 0 ) Then
    # Secteur d'activité invalide
    GERR= 1 : GMESSAGE= mess(636, 7773, 1)
    mkstat = 2 : End
  Endif
  If ( G_STATUS <> 82 and G_STATUS <> 73 and func SUBSEA.IS_SECACT_USED([M:SEA0]CPY, [M:SEA0]SAC(nolign-1)) ) Then
    # Oération impossible : Le secteur d'activité est utilisée par au moins un bien ou une dépense
    GERR= 1 : GMESSAGE= mess(234, 7770, 1)
    mkstat = 2 : End
  Endif

  [M:SEA0]BCREAT(nolign-1) = G_OUI

  [M:SEA0]TAXCOEINI(nolign-1) = 1.
  [M:SEA0]TAXCOEDEF(nolign-1) = 1.
  [M:SEA0]TAXCOEFLG(nolign-1) = G_NON
  [M:SEA0]ASJCOE(nolign-1)    = 1.

  Actzo [M:SEA0]TAXCOEINI(nolign-1)
  Actzo [M:SEA0]TAXCOEDEF(nolign-1)
  Actzo [M:SEA0]TAXCOEFLG(nolign-1)
  Actzo [M:SEA0]ASJCOE(nolign-1)


End


######################################
Subprog AV_TAXCOEINI(VALEUR)
Variable Decimal VALEUR

  If (G_DEBUG) Then : Infbox "AV_TAXCOEINI" : Endif

  If( VALEUR = 0.) Then
    Diszo [M:SEA0]TAXCOEINI(nolign-1)
    Diszo [M:SEA0]TAXCOEDEF(nolign-1)
    Diszo [M:SEA0]TAXCOEFLG(nolign-1)
  Else
    # FQ119309
    Actzo [M:SEA0]TAXCOEINI(nolign-1)
    Actzo [M:SEA0]TAXCOEDEF(nolign-1)
    Actzo [M:SEA0]TAXCOEFLG(nolign-1)
  Endif
End

######################################
Subprog C_TAXCOEINI(VALEUR)
Variable Decimal VALEUR

  If (G_DEBUG) Then : Infbox "C_TAXCOEINI" : Endif

  If ( VALEUR < 0. or VALEUR > 1. ) Then
    # La valeur du coefficient doit être comprise entre 0. et 1.
    GERR= 1 : GMESSAGE= mess(231, 7770, 1)
    mkstat = 2 : End
  Endif

  If ( VALEUR = 0 and func SUBSEA.IS_SECACT_USED([F:CPY]CPY, [M:SEA0]SAC(nolign-1) ) ) Then
    If ( [M:SEA0]TAXCOEDEF(nolign-1) <> 0 ) Then
      # Coefficient invalide.
      GERR= 1 : GMESSAGE= mess(173, 7773, 1)
      mkstat = 2 : End
    Endif
  Endif

  If ( VALEUR = 0. ) Then
    [M:SEA0]TAXCOEFLG(nolign-1) = G_OUI : Affzo [M:SEA0]TAXCOEFLG(nolign-1)
    [M:SEA0]TAXCOEDEF(nolign-1) = 0.    : Affzo [M:SEA0]TAXCOEDEF(nolign-1)
    Diszo [M:SEA0]TAXCOEFLG(nolign-1)
    Diszo [M:SEA0]TAXCOEDEF(nolign-1)
    Diszo [M:SEA0]TAXCOEINI(nolign-1)
  Endif
End


######################################
Subprog AV_TAXCOEFLG(VALEUR)
Variable Integer VALEUR

  If (G_DEBUG) Then : Infbox "AV_TAXCOEFLG" : Endif

  If ( [M:SEA0]TAXCOEINI(nolign-1) = 0 ) Then
    Diszo [M:SEA0]TAXCOEFLG(nolign-1)
    Diszo [M:SEA0]TAXCOEDEF(nolign-1)
  Else
    # FQ119309
    Actzo [M:SEA0]TAXCOEFLG(nolign-1)
    Actzo [M:SEA0]TAXCOEDEF(nolign-1)
  Endif

End


######################################
Subprog C_TAXCOEDEF(VALEUR)
Variable Decimal VALEUR

  If (G_DEBUG) Then : Infbox "C_TAXCOEDEF" : Endif

  If ( VALEUR < 0. or VALEUR > 1. ) Then
    # La valeur du coefficient doit être comprise entre 0. et 1.
    GERR= 1 : GMESSAGE= mess(231, 7770, 1)
    mkstat = 2 : End
  Endif

  If ( VALEUR = 0 and  [M:SEA0]TAXCOEINI(nolign-1) <> 0 ) Then
    # Coefficient invalide.
    GERR= 1 : GMESSAGE= mess(173, 7773, 1)
    mkstat = 2 : End
  Endif

End

#######################################
Subprog AV_ASJCOE(VALEUR)
Variable Decimal VALEUR

  If (G_DEBUG) Then : Infbox "AV_ASJCOE" : Endif

  If ( VALEUR = 0. ) Then
    Diszo [M:SEA0]ASJCOE(nolign-1)
  Else
    Actzo [M:SEA0]ASJCOE(nolign-1)
  Endif

End

#######################################
Subprog C_ASJCOE(VALEUR)
Variable Decimal VALEUR

  If (G_DEBUG) Then : Infbox "C_ASJCOE" : Endif
  If ( VALEUR < 0. or VALEUR > 1. ) Then
    # La valeur du coefficient doit être comprise entre 0. et 1.
    GERR= 1 : GMESSAGE= mess(231, 7770, 1)
    mkstat = 2 : End
  Endif


  If ( VALEUR = 0 and func SUBSEA.IS_SECACT_USED([F:CPY]CPY, [M:SEA0]SAC(nolign-1) ) ) Then
    If ( [M:SEA0]TAXCOEDEF(nolign-1) <> 0 ) Then
      # Coefficient invalide.
      GERR= 1 : GMESSAGE= mess(173, 7773, 1)
      mkstat = 2 : End
    Endif
  Endif

  If ( VALEUR = 0. ) Then
    [M:SEA0]TAXCOEINI(nolign-1) = 0
    [M:SEA0]TAXCOEDEF(nolign-1) = 0
    [M:SEA0]TAXCOEFLG(nolign-1) = G_OUI
    Affzo [M:SEA0]TAXCOEINI(nolign-1)
    Affzo [M:SEA0]TAXCOEDEF(nolign-1)
    Affzo [M:SEA0]TAXCOEFLG(nolign-1)
    Diszo [M:SEA0]TAXCOEINI(nolign-1)
    Diszo [M:SEA0]TAXCOEDEF(nolign-1)
    Diszo [M:SEA0]TAXCOEFLG(nolign-1)

    [M:SEA0]ASJCOE(nolign-1) = VALEUR
    Affzo [M:SEA0]ASJCOE(nolign-1)
    Diszo [M:SEA0]ASJCOE(nolign-1)
  Endif
End



#==========================================
Funprog IS_SECACT_USED (PCPY, PSECACT)

Value Char PCPY
Value Char PSECACT

Local Integer B_USED

  B_USED=0
  Local File FXDASSETS   [WFAS]
  Filter [WFAS] Where CPY = PCPY and AASBUS = PSECACT
  If (rowcount([WFAS])) Then
    B_USED=1
  Endif
  Filter [WFAS]
  Close Local File [WFAS]

  If (not B_USED) Then
    Local File LAYOUTFAS   [WLOF]
    Filter [WLOF] Where CPY = PCPY and ACT = PSECACT
    If (rowcount([WLOF])) Then
      B_USED=1
    Endif
    Filter [WLOF]
    Close Local File [WLOF]
  Endif

End B_USED



#==========================================
Subprog UPGRADE_SECACT
#
#  *** A SUPPRIMER ***
#

Local Char    LDES

  Local File SECACT     [SEA]
  Local File ATABDIV    [ADI]
  Local File COMPANY    [CPY]

  Trbegin [SEA]
  # >>>>>>>>>>>>>>>>
  For [CPY]
    # >>>>>>>>>>>>>>>>
    For [ADI] Where NUMTAB=410

      If ( func SUBSEA.IS_SECACT_USED([F:CPY]CPY, [F:ADI]CODE ) ) Then
        Call LECTEXTRA (LDES, "ATABDIV", "LNGDES", num$(410), num$([F:ADI]CODE) ) From ATEXTRA
        Read [SEA] SEA0=[F:CPY]CPY;[F:ADI]CODE
        If (fstat <> 0) Then
          [F:SEA]CPY       = [F:CPY]CPY
          [F:SEA]SAC       = [F:ADI]CODE
          If (LDES = "" ) Then : LDES = "...." : Endif
          [F:SEA]SACDES    = LDES
          [F:SEA]TAXCOEINI = [F:ADI]N1/100
          [F:SEA]TAXCOEDEF = [F:ADI]N2/100
          [F:SEA]TAXCOEFLG = 1
          [F:SEA]ASJCOE    = 1.
          [F:SEA]CREUSR    = GUSER
          [F:SEA]CREDAT    = date$
          Write [SEA]
        Endif
      Endif
    Next
    # <<<<<<<<<<<<<<<<<<
  Next
  # <<<<<<<<<<<<<<<<<<

  If (adxlog) Then
    Commit
  Else
    Rollback
  Endif

End

