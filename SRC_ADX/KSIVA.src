#<AdxTL>@(#)5.0.0.0 $Revision$
#######################################################################
### PROGRAMA PARA ASEGURARNOS QUE TODAS LAS FACTURAS TENDRÁN ALIMENTADOS
### LOS CAMPOS RATRPT Y RATCUR EN LAS TABLAS SINVOICE Y PINVOICE
### TAMBIEN SE CONTROLA EL IMPORTE DE IVA DEDUCIBLE EN FACTURAS TERCEROS
#######################################################################
Subprog IMPRIME(NBPAR, PARAMETRE)
Variable Integer NBPAR
Variable Char PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)
End

#######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char PARAMETRE()()

Local File SINVOICE, PINVOICE, COMPANY, TABCUR, TABCHANGE, ADOSSIER, BPSINVLIG
Local Decimal CAMBIO, CAMBIORPT, RATRPT
Local Decimal CAMBIO, CAMBIOCUR

Local Integer I
Local Char    PARAM(30) ,VALEUR(30) ,ETAT(15) 
Local Date DATINI, DATFIN


For I=1 To NBPAR
   J=instr(1,[L]PARAMETRE(I),"=")
   If J
     [L]PARAM=left$([L]PARAMETRE(I),J-1)
     [L]VALEUR=right$([L]PARAMETRE(I),J+1)
     Case [L]PARAM
          When "X3ETA"     : [L]ETAT=[L]VALEUR
           When "datdeb"    : [L]DATINI=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
           When "datfin"    : [L]DATFIN=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
       Endcase
    Endif

Next


Case ETAT
     When "S-IVAREP" : Gosub FACVEN
     When "S-IVASOP" : Gosub FACCOM : Gosub IVADED
     When "S-AUTOFAC": Gosub FACCOM : Gosub IVADED
     When "S-RESIVA" : Gosub FACVEN : Gosub FACCOM : Gosub IVADED
Endcase

End


$FACVEN
####################################################################
### FACTURAS DE VENTAS
####################################################################

Filter [SIH] Where ACCDAT>=[L]DATINI and ACCDAT<=[L]DATFIN and (RATCUR=0 or RATRPT=0)

For [SIH]SIH0

   Read [CPY]CPY0=[SIH]CPY
   If fstat
       Infbox "ERROR EN LA FACTURA"-[SIH]NUM- "SOCIEDAD INEXISTENTE"
   Else
       Read [TCU]TCU0=[CPY]ACCCUR
       CAMBIOCUR=[TCU]EURRAT
       #------------------------
       # Lee Divisa de reporting
       #------------------------
       Read [TCU]TCU0 = GSYSCUR
       CAMBIORPT=[TCU]EURRAT
       #-------------------------
       # Lee divisa del documento
       #-------------------------
       Read [TCU]TCU0=[SIH]CUR
    
       #---------------------------------------------
       # Cambia ratio conversion divisa del reporting  Y SOCIEDAD
       #---------------------------------------------

       If [TCU]EURFLG=2
          If [SIH]CUR<>GSYSCUR
              [SIH]RATRPT=CAMBIORPT/[TCU]EURRAT
          Else
              [SIH]RATRPT=1
          Endif
          If [SIH]CUR=[CPY]ACCCUR
              [SIH]RATCUR=1
          Else 
              [SIH]RATCUR=CAMBIOCUR/[TCU]EURRAT
          Endif
       Else
          Filter [TCH] Where CHGTYP=[SIH]CURTYP and CURDEN="EUR" and CUR=[SIH]CUR and CHGSTRDAT<=[SIH]ACCDAT
          Read [TCH]TCH0 Last
          [SIH]RATCUR=([TCH]CHGRAT*CAMBIOCUR)
          [SIH]RATRPT=([TCH]CHGRAT*CAMBIORPT)
       Endif
    
    Endif

    Trbegin [SIH]
    Rewrite [SIH]
    Commit

Next

Return

#######################################################################

$FACCOM
####################################################################
### FACTURAS DE COMPRAS
####################################################################

Filter [PIH] Where ACCDAT>=[L]DATINI and ACCDAT<=[L]DATFIN and (RATCUR=0 or RATRPT=0)

For [PIH]PIH0
    Read [CPY]CPY0=[PIH]CPY
    If fstat
       Infbox "ERROR EN LA FACTURA"-[PIH]NUM- "SOCIEDAD INEXISTENTE"
    Else
       Read [TCU]TCU0=[CPY]ACCCUR
       CAMBIOCUR=[TCU]EURRAT
       #------------------------
       # Lee Divisa de reporting
       #------------------------
       Read [TCU]TCU0 = GSYSCUR
       CAMBIORPT=[TCU]EURRAT
       #-------------------------
       # Lee divisa del documento
       #-------------------------
       Read [TCU]TCU0=[PIH]CUR
       #---------------------------------------------
       # Cambia ratio conversion divisa del reporting  Y SOCIEDAD
       #---------------------------------------------
       If [TCU]EURFLG=2
          If [PIH]CUR<>GSYSCUR
              [PIH]RATRPT=CAMBIORPT/[TCU]EURRAT
          Else
              [PIH]RATRPT=1
          Endif
          If [PIH]CUR=[CPY]ACCCUR
              [PIH]RATCUR=1
          Else 
              [PIH]RATCUR=CAMBIOCUR/[TCU]EURRAT
          Endif
       Else
          Filter [TCH] Where CHGTYP=[PIH]CURTYP and CURDEN="EUR" and CUR=[PIH]CUR and CHGSTRDAT<=[PIH]ACCDAT
          Read [TCH]TCH0 Last
          [PIH]RATCUR=([TCH]CHGRAT*CAMBIOCUR)
          [PIH]RATRPT=([TCH]CHGRAT*CAMBIORPT)
       Endif
    Endif
    
    Trbegin [PIH]
    Rewrite [PIH]
    Commit

Next

Return

#####################################################################

$IVADED
Local Integer I
Filter [PIH] Where ORIMOD=3 and sum(DEDTAX(0..9))=0 

For [PIH]PIH0
    Trbegin [PIH]
    Raz [F:PIH]DEDTAX
    For [PIL] Where NUM=[F:PIH]NUM
      For I=0 To 9
          If [F:PIL]VAT=[F:PIH]TAX(I) 
             [F:PIH]DEDTAX(I)+=[F:PIL]DEDVAT
             Break
          Endif
      Next I
    Next
    Rewrite [PIH]
    Commit
Next

End
