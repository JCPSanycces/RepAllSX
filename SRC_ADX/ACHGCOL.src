End [L]NBCOLORS


#----------------------------------------------#
Subprog PATCH(PFOLDER)
Value Char PFOLDER

Local Char COLOR_ORI_H(6)(1..), COLOR_DES_H(6)(1..)
Local Integer NBCOLORS

[L]NBCOLORS = func LOAD_COLORS_HEXA(COLOR_ORI_H,COLOR_DES_H)

Call CHANGE_COLORS_APR(PFOLDER,COLOR_ORI_H, COLOR_DES_H, 0)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PFOLDER)
Value Char PFOLDER

Local Char COLOR_ORI_H(6)(1..), COLOR_DES_H(6)(1..)
Local Integer NBCOLORS

[L]NBCOLORS = func LOAD_COLORS_HEXA(COLOR_ORI_H,COLOR_DES_H)

Call CHANGE_COLORS_APR(PFOLDER,COLOR_ORI_H, COLOR_DES_H, 0)

End



################################################
# Create Styles to be able to preview color changes
################################################
Subprog CREATE_ASY(PCOLORI, PCOLDES)
Value Char PCOLORI()()
Value Char PCOLDES()()

If GADONIX<>2
    End
Endif

Local Integer I
Local File ASTYLE [ASY]

Trbegin [ASY]
# 1st : remove all existing generated styles
Delete [F:ASY] Where pat([F:ASY]COD,"WACOL*")=1

# 2nd : create styles in ASTYLE table
Raz [F:ASY]
While I<=maxtab(PCOLORI) & PCOLORI(I)<>""
    [F:ASY]COD = "WACOLORI"+num$(I)
    [F:ASY]STY = ";font-style:normal;background-color:#"+[L]PCOLORI(I)
    Write [ASY]
    [F:ASY]COD = "WACOLDES"+num$(I)
    [F:ASY]STY = ";font-style:normal;background-color:#"+[L]PCOLDES(I)
    Write [ASY]
    I+=1
Wend
Commit

# Generate files of styles
Call GENSTYLE(nomap,"DEFAULT") From SUBASY
# ... and use them
Callui CHAINE="" With "UIAction="+chr$(1)+"SessionSettings", "ADXStyleFile="+chr$(1)+"STX_DEFAULT"

End


################################################
# Remove records in ASTYLE table and restore personalized styles if defined
################################################
Subprog CLEAR_ASY()
Local Char STYDEF(20)

If GADONIX<>2
    End
Endif

Local File ASTYLE [ASY]
# Deletion of temporary styles
GOK=1
Trbegin [ASY]
Delete [F:ASY] Where pat([F:ASY]COD,"WACOL*")=1
If fstat<>[V]CST_AOK
    Call FSTA("ASY") From GLOCK
    GOK=0
Endif
If GOK=1
    Commit
Else
    Rollback
Endif
# Generate files of styles
Call GENSTYLE(nomap,"DEFAULT") From SUBASY

# restore default/personalized style
Call PARAMUTIL("STYLE",STYDEF,"","") From SUBAUS
If STYDEF<>""
    Callui CHAINE="" With "UIAction="+chr$(1)+"SessionSettings", "ADXStyleFile="+chr$(1)+"STX_"+STYDEF
Else
    Callui CHAINE="" With "UIAction="+chr$(1)+"SessionSettings", "ADXStyleFile="+chr$(1)+"STX_DEFAULT"
Endif

End

