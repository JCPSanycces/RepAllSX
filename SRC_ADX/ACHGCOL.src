#<AdxTL>@(#)0.0.0.0 $Revision$
# Recodify visual processes to comply with the new style sheet
# The color change table has been fixed to manage the color changes introduced in 2017 R3

Local Char COLOR_ORI_H(6)(1..), COLOR_DES_H(6)(1..)
Local Integer NBCOLORS
Local Integer LSIM : LSIM=0

If !GSERVEUR
    Call TEMPON("") From GESECRAN
    Call OUVRE_TRACE("Change colors of visual processes"-string$(LSIM>0,"(Simulation)")) From LECFIC
Endif

[L]NBCOLORS = func LOAD_COLORS_HEXA(COLOR_ORI_H,COLOR_DES_H)
Call CHANGE_COLORS_APR(nomap,COLOR_ORI_H, COLOR_DES_H,LSIM)

If !GSERVEUR
    Call FERME_TRACE() From LECFIC
    Call TEMPOFF From GESECRAN
    Call LEC_TRACE From LECFIC
Endif

End

###################################################
$ACTION
Case ACTION
    When "OUVRE" : Gosub OUVRE
    When "DEBUT" : Gosub DEBUT
    When "OK"    : Gosub OK
    When "FIN"   : Gosub FIN
Endcase
Return

###################################################
$OUVRE
Local Char COLOR_ORI_H(6)(1..), COLOR_DES_H(6)(1..)
Local Integer NBCOLORS
Local Integer PREVIEW : PREVIEW=0
Return

###################################################
$DEBUT
# Load default colors
[L]NBCOLORS = func LOAD_COLORS_HEXA(COLOR_ORI_H,COLOR_DES_H)

# Preview of colors in the screen
If [L]NBCOLORS>dim([M:ACOL]CODCOLORI)
    Call ERREUR("Too many colors") From GESECRAN
Endif
If PREVIEW=1
    Call CREATE_ASY([L]COLOR_ORI_H,[L]COLOR_DES_H)     # Create styles in ASTYLE table : need to logout afterwards

    Affzo [M:ACOL]
    # To be able to use Chgstl on all lines
    [M:ACOL]NBCOL=[L]NBCOLORS
    Affzo [M:ACOL]CODCOLORI(0)

    For I=0 To [L]NBCOLORS-1
        If I>=dim([M:ACOL]CODCOLORI)
            Break
        Endif

        [M:ACOL]CODCOLORI(I) = [L]COLOR_ORI_H(I+1)
        If mod(I,2)=0 |1
            Chgstl [M:ACOL]COLORI(I) With "WACOLORI"+num$(I)
        Else
            Chgstl [M:ACOL]COLORI(I) With "AERROR"
        Endif
        [M:ACOL]CODCOLDES(I) = [L]COLOR_DES_H(I+1)
        Chgstl [M:ACOL]COLDES(I) With "WACOLDES"+num$(I)
    Next
    Affzo [M:ACOL]
Endif
Return

###################################################
$OK
# Process the change of colors
Call TEMPON("") From GESECRAN
Call OUVRE_TRACE("Change colors of visual processes") From LECFIC

Call CHANGE_COLORS_APR([M:ACOL]DOSSIER,COLOR_ORI_H, COLOR_DES_H,0)

Call FERME_TRACE() From LECFIC
Call TEMPOFF From GESECRAN
Call LEC_TRACE From LECFIC

Return

###################################################
$FIN
# Clean styles
If GADONIX=2 & PREVIEW=1
    Local Integer LRET
    Call OUINON("Remove generated styles ?",LRET) From GESECRAN
    If LRET=2
        Call CLEAR_ASY
    Endif
Endif
Return

#**
#* Run the process to change colors
#*
#* @param PFOLDER      : Folder on which to apply changes
#* @param PCOLOR_ORI_H : List of colors to modify (hexa)
#* @param PCOLOR_DES_H : List of new colors       (hexa)
#*!
Subprog CHANGE_COLORS_APR(PFOLDER,PCOLOR_ORI_H, PCOLOR_DES_H, PSIM)
Value Char PFOLDER
Variable Char PCOLOR_ORI_H()()
Variable Char PCOLOR_DES_H()()
Value Integer PSIM

Call ECR_TRACE("Change colors of visual processes"-string$(PSIM>0,"(Simulation)"),0) From GESECRAN

Local Integer COUNT_COLCHANGES,COUNT_PROCHANGES, NB_COLCHANGES
Local Integer P
Local Char COLOR_ORI_D(10)(maxtab(PCOLOR_ORI_H)+1)
Local Char COLOR_DES_D(10)(maxtab(PCOLOR_ORI_H)+1)
Local Char PATTERNS(50)(2)  # Node to find
Local Char COLOR_TYPE(1)(2) # type of value (D=decimal, H=Hexadecimal)

PATTERNS(0)='color":' : COLOR_TYPE(0) = 'D'
PATTERNS(1)='OLOR=\"#': COLOR_TYPE(1) = 'H'


Local File =PFOLDER+".APROCESSUS" [APR]
Local File =PFOLDER+".ACLOB" [ACB]
Local File =PFOLDER+".APROCTEXTE" [AXP]

# Calculate values in decimal as they are needed for 2nd pattern
For I=0 To maxtab(PCOLOR_ORI_H)
    If PCOLOR_ORI_H(I)=""
        Break
    Endif
    COLOR_ORI_D(I) = num$(func AFNC.HEXA_TO_DEC(PCOLOR_ORI_H(I)))
    COLOR_DES_D(I) = num$(func AFNC.HEXA_TO_DEC(PCOLOR_DES_H(I)))
Next

Call DEBTRANS From GLOCK

Trbegin [APR]

For [APR]APR2 Where TYPEP=1

    [L]COUNT_PROCHANGES+=1
    [L]COUNT_COLCHANGES=0

    # Change color in definition of process
    Raz [L]NB_COLCHANGES
    For P=0 To 1
        If [L]COLOR_TYPE(P) = 'H'
            [L]NB_COLCHANGES += func REPLACE_COLOR([APR]CLOB, [L]PATTERNS(P), [L]PCOLOR_ORI_H, [L]PCOLOR_DES_H)
        Else
            [L]NB_COLCHANGES += func REPLACE_COLOR([APR]CLOB, [L]PATTERNS(P), [L]COLOR_ORI_D, [L]COLOR_DES_D)
        Endif
    Next
    If [L]NB_COLCHANGES>0
        [L]COUNT_COLCHANGES += [L]NB_COLCHANGES
        Rewrite [APR]
        If fstat<>[V]CST_AOK
            Call FSTA("APR") From GLOCK
            GOK=0
            Break
        Endif
    Endif

    # Change color in JSON definition of process
    For [ACB]ACB0 Where CODBLB="APRJSON"
&                   and (   find(IDENT1,[APR]CODPRO+"~"+[APR]CODLEG,[APR]CODPRO)<>0
&                        or (IDENT1=[APR]CODPRO and IDENT2=[APR]CODLEG) )
        Raz [L]NB_COLCHANGES
        For P=0 To 1
            If [L]COLOR_TYPE(P) = 'H'
                [L]NB_COLCHANGES += func REPLACE_COLOR([ACB]CLOB, [L]PATTERNS(P), [L]PCOLOR_ORI_H, [L]PCOLOR_DES_H)
            Else
                [L]NB_COLCHANGES += func REPLACE_COLOR([ACB]CLOB, [L]PATTERNS(P), [L]COLOR_ORI_D, [L]COLOR_DES_D)
            Endif
        Next
        If [L]NB_COLCHANGES>0
            [L]COUNT_COLCHANGES += [L]NB_COLCHANGES
            Rewrite [ACB]
            If fstat<>[V]CST_AOK
                Call FSTA("ACB") From GLOCK
                GOK=0
                Break 2
            Endif
        Endif
    Next

    # Change color in process texts translations
    For [AXP]AXP0 Where CODPRO=[APR]CODPRO and CODLEG=[APR]CODLEG
        Raz [L]NB_COLCHANGES
        For P=0 To 1
            If [L]COLOR_TYPE(P) = 'H'
                [L]NB_COLCHANGES += func REPLACE_COLOR([AXP]CLBTEXT, [L]PATTERNS(P), [L]PCOLOR_ORI_H, [L]PCOLOR_DES_H)
            Else
                [L]NB_COLCHANGES += func REPLACE_COLOR([AXP]CLBTEXT, [L]PATTERNS(P), [L]COLOR_ORI_D, [L]COLOR_DES_D)
            Endif
        Next
        If [L]NB_COLCHANGES>0
            [L]COUNT_COLCHANGES += [L]NB_COLCHANGES
            Rewrite [AXP]
            If fstat<>[V]CST_AOK
                Call FSTA("AXP") From GLOCK
                GOK=0
                Break 2
            Endif
        Endif
    Next

# We don't trace modifications as Graphic processes on VM are not in Github
#    If GADONIX=2 & [L]COUNT_COLCHANGES>0 & PSIM=0
#        Call TRACE_COR("APR",[APR]CODPRO,[APR]CODLEG,"M") From GOBJET
#    Endif

    Call ECR_TRACE ([APR]CODPRO-[APR]CODLEG-":"-num$(COUNT_COLCHANGES)-"color changes",0) From GESECRAN
Next

If !GOK | PSIM
    Rollback
Else
    Commit
Endif

Call ECR_TRACE ("**********"-num$(COUNT_PROCHANGES)-"visual processes recodified",0) From GESECRAN

End

#**
#* Replace color codes in a clob
#*
#* @param PTXT     : Clob to modify
#* @param PPATTERN : Pattern to find (the following number will be replaced)
#* @param PCOLORI  : color codes to replace
#* @param PCOLDES  : corresponding new color codes
#* @return number of replacements
#*!
Funprog REPLACE_COLOR(PTXT,PPATTERN,PCOLORI,PCOLDES)
Variable Clbfile PTXT
Value Char PPATTERN
Value Char PCOLORI()()
Value Char PCOLDES()()

Local Integer COUNT_COLCHANGES
Local Integer I
Local Char CARAC(1)
I=0
Repeat
    # Look for the pattern
    I=instr(I+1,[L]PTXT,PPATTERN)
    If I
        If mid$([L]PTXT,I+len(PPATTERN),4)<>"null"
            # Get the value corresponding to the pattern (only numeric and letters)
            I+=len(PPATTERN)
            J=I
            Repeat
                J+=1
                CARAC=mid$([L]PTXT,J,1)
            Until (CARAC<"0" or CARAC>"9")
&              &  (CARAC<"A" or CARAC>"F")
&              &  CARAC<>" "

            K=find(vireblc(seg$([L]PTXT,I,J-1),4),PCOLORI(1..maxtab(PCOLORI)))
            If K
                [L]PTXT=left$([L]PTXT,I-1) + PCOLDES(K) + right$([L]PTXT,J)
                #Call ECR_TRACE("From"-PCOLORI(K)-"to"-PCOLDES(K),0) From GESECRAN
                COUNT_COLCHANGES+=1
            Endif
        Endif
    Endif
Until I=0
End COUNT_COLCHANGES

#**
#* Load colors to change and the new codes to use
#*
#* @param COLOR_ORI : array of color codes to change
#* @param COLOR_DES : array of new color codes
#* @return number of colors to change
#*!
Funprog LOAD_COLORS_HEXA(COLOR_ORI, COLOR_DES)
Variable Char COLOR_ORI()()
Variable Char COLOR_DES()()

Local Integer NBCOLORS

  COLOR_ORI(NBCOLORS)="9A9B9C" : COLOR_DES(NBCOLORS)="9A9B9C" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="9EA2A2" : COLOR_DES(NBCOLORS)="9A9B9C" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="B2B4B2" : COLOR_DES(NBCOLORS)="C7C9C7" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="BAB3B3" : COLOR_DES(NBCOLORS)="C7C9C7" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="FFFCFC" : COLOR_DES(NBCOLORS)="FFFFFF" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="DBD7D7" : COLOR_DES(NBCOLORS)="DBD7D7" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="EBEAE8" : COLOR_DES(NBCOLORS)="DBD7D7" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="C7C9C7" : COLOR_DES(NBCOLORS)="C7C9C7" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="4D4F53" : COLOR_DES(NBCOLORS)="4D4F53" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="E1EBEB" : COLOR_DES(NBCOLORS)="DBD7D7" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="F0E6E6" : COLOR_DES(NBCOLORS)="DBD7D7" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="41A940" : COLOR_DES(NBCOLORS)="004089" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="34B233" : COLOR_DES(NBCOLORS)="004089" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="00DC00" : COLOR_DES(NBCOLORS)="28A3DA" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="13CF25" : COLOR_DES(NBCOLORS)="28A3DA" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="007F64" : COLOR_DES(NBCOLORS)="073460" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="156E93" : COLOR_DES(NBCOLORS)="004089" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="156E96" : COLOR_DES(NBCOLORS)="004089" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="4277A3" : COLOR_DES(NBCOLORS)="004089" : NBCOLORS+=1
  COLOR_ORI(NBCOLORS)="009FDA" : COLOR_DES(NBCOLORS)="28A3DA" : NBCOLORS+=1
