#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################
#                                                                       #
#      TRAITEMENTS de M.A.J. de TABLE dans les VENTES                   #
#                                                                       #
#########################################################################
#                                                                       #
# Etiquette APPELWIP                                                    #
#      Mise ? jour du fichier ORDERS ? partir de [F:SOQ]                #
#                                                                       #
# Etiquette APPELWIP1                                                   #
#      Mise ? jour du fichier ORDERS ? partir de [F:SOQ1]               #
#                                                                       #
# Etiquette WIP_ALLSHT                                                  #
#      Détermination des qtés allouées et ruptures pour                 #
#      les qtés en préparation, préparées                               #
#      d'une ligne de commande (pour maj correcte de l'en-cours)        #
#                                                                       #
# Subprog HISTO_REV(ABFIC, TRAIT)                                       #
#      Historisation des avenants                                       #
#                                                                       #
# Subprog MAJFMISOQ(LSOHNUM, LSOPLIN, LSOQSEQ, L, LFMILIN,              #
#                 LFMISEQ, LOPT, LRET)                                  #
#      Maj du n° de la contremarque générée dans les commandes          #
#                                                                       #
# Subprog MAJITVVEN(LITM,LFCY,LQTY,LSENS,LTYP, LRET)                    #
#     Maj des cumuls articles                                           #
#########################################################################
# Issue 116484 - 20160526 by LD : PERF FUNAUTPREP - optimisation done for MADMAN
# Issue 117950 - 20160805 by LD : Lockwait on ITMMVT update in TRTVENMAJ
# Issue X3-38651 - 20170526 by LD : SOF Project link initialized with the SO header value

$ACTION
Case ACTION
 When "TRT_DIV"     : Gosub TRT_DIV
Endcase
Return

$TRT_DIV
Case TRAIT
 When Default
Endcase
Return

#########################################################################
# Mise ? jour du fichier ORDERS (encours)                               #
#                                                                       #
#   --> Alimentation du masque [ORDK]                                   #
#   --> Appel du sous-pro TRTWIP                                        #
#                                                                       #
#       Il faut avoir la classe [SOP] en ligne si cde classique         #
#                                                                       #
# ATTENTION : Si modif de cette étiquette, penser ? modifier aussi      #
#             APPELWIP1 qui travaille avec [SOQ1]                       #
#-----------------------------------------------------------------------#
$APPELWIP
Local Decimal WEXTQTY, WALL, WSHT
Local Char    ABR(7) : ABR="[F:SOQ]"
Raz [M:ORDK]


If WTRTORD="S" | (WTRTORD="M" & find ([F:SOH]APPFLG,1,2) & GSOHAPPORD=1)
    # Solde cde ou cde non signée et pas d'encours sur les cdes non signées
    # --> La qté prévue = Qté restant ? livrer
#    WEXTQTY=[F:SOQ]ODLQTYSTU+WCPLQTY
    WEXTQTY=[F:SOQ]LPRQTYSTU+[F:SOQ]OPRQTYSTU+[F:SOQ]PREQTYSTU+[F:SOQ]ODLQTYSTU+WCPLQTY
    [M:ORDK]MAJCOD     = "M"
Else
    WEXTQTY=[F:SOQ]QTYSTU
    [M:ORDK]MAJCOD     = WTRTORD
Endif

#If [F:SOH]BETFCY=2 & [F:SOH]ORIFCY<>""
#   [M:ORDK]WIPTYP  = 8                   : # C'est une Demande inter_site : TP

If [F:SOH]BETFCY=2 & [F:SOH]BETCPY<>2
   [M:ORDK]WIPTYP  = 8                   : # C'est une Demande inter_site/intra-société : TP
   If GMODU(6)=2
       If clalev([F:POQ])=0 : Local File PORDERQ [POQ] : Endif
       If [F:POQ]POHNUM<>[F:SOQ]POHNUM | [F:POQ]POPLIN<>[F:SOQ]POPLIN | [F:POQ]POQSEQ<>[F:SOQ]POQSEQ
           Read [POQ]POQ0 = [F:SOQ]POHNUM;[F:SOQ]POPLIN;[F:SOQ]POQSEQ
           If fstat Raz [F:POQ] : Endif
       Endif
       [M:ORDK]ORIFCY    = [F:POQ]PRHFCY     : # Site de réception
   Endif
   [M:ORDK]VCRTYPORI = 14                : # Commande d'achat
   [M:ORDK]VCRNUMORI = [F:SOQ]POHNUM
   [M:ORDK]VCRLINORI = [F:SOQ]POPLIN
   [M:ORDK]VCRSEQORI = [F:SOQ]POQSEQ
Else
   [M:ORDK]WIPTYP  = 1                   : # C'est une Commande de vente  : SO
   [M:ORDK]ORIFCY  = [F:SOH]SALFCY
Endif
[M:ORDK]WIPSTA     = [F:SOQ]DEMSTA
[M:ORDK]WIPNUM     = [F:SOQ]DEMNUM
[M:ORDK]ITMREF     = [F:SOQ]ITMREF
# --------------------------------------
# FGR 13/04/2015 : X3SUIVI105605 (début)
If dim([M:ORDK]ECCVALMAJ) >= 0 Then
  [M:ORDK]ECCVALMAJ  = [F:SOQ]ECCVALMAJ
Endif
If dim([M:ORDK]ECCVALMIN) >= 0 Then
  [M:ORDK]ECCVALMIN  = [F:SOQ]ECCVALMIN
Endif
# FGR 13/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------
[M:ORDK]STOFCY     = [F:SOQ]STOFCY
[M:ORDK]BPRNUM     = [F:SOQ]BPCORD
[M:ORDK]STRDAT     = [F:SOQ]ORDDAT
If [F:SOQ]SHIDAT = [0/0/0]
    [M:ORDK]ENDDAT = [F:SOQ]DEMDLVDAT
Else
    [M:ORDK]ENDDAT = [F:SOQ]SHIDAT
Endif
If [M:ORDK]ENDDAT < [M:ORDK]STRDAT [M:ORDK]ENDDAT = [M:ORDK]STRDAT : Endif
[M:ORDK]VCRTYP     = 2
[M:ORDK]VCRNUM     = [F:SOQ]SOHNUM
[M:ORDK]VCRLIN     = [F:SOQ]SOPLIN
[M:ORDK]VCRSEQ     = [F:SOQ]SOQSEQ
[M:ORDK]EXTQTY     = WEXTQTY
[M:ORDK]CPLQTY     = WCPLQTY
# Détermination des quantités allouées et ruptures des préparations
Raz WALL, WSHT

If [F:SOQ]OPRQTYSTU+[F:SOQ]PREQTYSTU>0
   Gosub WIP_ALLSHT
Endif
[M:ORDK]ALLQTY  = [F:SOQ]ALLQTYSTU + WALL + [F:SOQ]ODLQTYSTU
[M:ORDK]SHTQTY  = [F:SOQ]SHTQTYSTU + WSHT

# Gestion des signatures : Si la cde n'est pas signée et pas d'encours sur les cdes non signées
# --> Il faut supprimer l'encours si rien n'est alloué et réalisé
If find ([F:SOH]APPFLG,1,2) & GSOHAPPORD=1 & sum([M:ORDK]ALLQTY, [M:ORDK]SHTQTY)=0 & [M:ORDK]CPLQTY=0
    [M:ORDK]MAJCOD     = "A"
Endif

If [M:ORDK]MAJCOD="M" & dim([L]WMAJMTO)=1 : WMAJMTO=func CHGALLQTY : Endif : # GH 02/07/2014 bug 93888

# Issue X3-38651
#[M:ORDK]PJT        = [F:SOH]PJT
[M:ORDK]PJT        = [F:SOQ]PJT
# End issue X3-38651
If [F:SOH]SOHCAT = 4
   [M:ORDK]ABBFIL  = "SOC"
   [M:ORDK]FMI     = 1
Else
   [M:ORDK]ABBFIL  = "SOQ"
   [M:ORDK]FMI     = [F:SOQ]FMI
Endif
[M:ORDK]MRPMES     = 1
#[M:ORDK]VCRTYPORI  = 0
#[M:ORDK]VCRNUMORI  = ""
#[M:ORDK]VCRLINORI  = 0
#[M:ORDK]VCRSEQORI  = 0
[M:ORDK]BOMALT     = 0
[M:ORDK]ORI        = 2
[M:ORDK]PIO        = [F:SOQ]DLVPIO

Call WIP From TRTWIP

Return

#####################

Funprog CHGALLQTY
Local File ORDERS [ORDW]
Read [ORDW]ORD0=[M:ORDK]WIPTYP;[M:ORDK]WIPNUM;[M:ORDK]ITMREF
If !fstat & [F:ORDW]ALLQTY<>[M:ORDK]ALLQTY : End 1
Else                                       : End 0
Endif
End

####################################################################
$APPELWIP1
Local Decimal WEXTQTY, WALL, WSHT
Local Char    ABR(8) : ABR="[F:SOQ1]"

#-----------------------------------------------------------------------#
# Mise ? jour du fichier ORDERS (encours)                               #
#                                                                       #
#   --> Alimentation du masque [ORDK]                                   #
#   --> Appel du sous-pro TRTWIP                                        #
#                                                                       #
# ATTENTION : Si modif de cette étiquette, penser ? modifier aussi      #
#             APPELWIP qui travaille avec [F:SOQ]                       #
#-----------------------------------------------------------------------#
Raz [M:ORDK]

If WTRTORD="S" | (WTRTORD="M" & find ([F:SOH]APPFLG,1,2) & GSOHAPPORD=1)
    # Solde cde ou cde non signée et pas d'encours sur les cdes non signées
    # --> La qté prévue = Qté restant ? livrer
#    WEXTQTY=[F:SOQ1]ODLQTYSTU+WCPLQTY
    WEXTQTY=[F:SOQ1]LPRQTYSTU+[F:SOQ1]OPRQTYSTU+[F:SOQ1]PREQTYSTU+[F:SOQ1]ODLQTYSTU+WCPLQTY
    [M:ORDK]MAJCOD     = "M"
Else
    WEXTQTY=[F:SOQ1]QTYSTU
    [M:ORDK]MAJCOD     = WTRTORD
Endif

#If [F:SOH]BETFCY=2 & [F:SOH]ORIFCY<>""
#   [M:ORDK]WIPTYP  = 8                  : # C'est une Demande inter_site : TP

If [F:SOH]BETFCY=2 & [F:SOH]BETCPY<>2
   [M:ORDK]WIPTYP  = 8                   : # C'est une Demande inter_site/intra-société : TP
   If GMODU(6)=2
       If clalev([F:POQ])=0 : Local File PORDERQ [POQ] : Endif
       If [F:POQ]POHNUM<>[F:SOQ1]POHNUM | [F:POQ]POPLIN<>[F:SOQ1]POPLIN | [F:POQ]POQSEQ<>[F:SOQ1]POQSEQ
           Read [POQ]POQ0 = [F:SOQ1]POHNUM;[F:SOQ1]POPLIN;[F:SOQ1]POQSEQ
           If fstat Raz [F:POQ] : Endif
       Endif
   Endif
   [M:ORDK]ORIFCY    = [F:POQ]PRHFCY    : # Site réception
   [M:ORDK]VCRTYPORI = 14               : # Commande d'achat
   [M:ORDK]VCRNUMORI = [F:SOQ1]POHNUM
   [M:ORDK]VCRLINORI = [F:SOQ1]POPLIN
   [M:ORDK]VCRSEQORI = [F:SOQ1]POQSEQ
Else
   [M:ORDK]WIPTYP  = 1                  : # C'est une Commande de vente  : SO
   [M:ORDK]ORIFCY  = [F:SOH]SALFCY
Endif
[M:ORDK]WIPSTA     = [F:SOQ1]DEMSTA
[M:ORDK]WIPNUM     = [F:SOQ1]DEMNUM
[M:ORDK]ITMREF     = [F:SOQ1]ITMREF
# --------------------------------------
# FGR 13/04/2015 : X3SUIVI105605 (début)
If dim([M:ORDK]ECCVALMAJ) >= 0 Then
  [M:ORDK]ECCVALMAJ  = [F:SOQ1]ECCVALMAJ
Endif
If dim([M:ORDK]ECCVALMIN) >= 0 Then
  [M:ORDK]ECCVALMIN  = [F:SOQ1]ECCVALMIN
Endif
# FGR 13/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------
[M:ORDK]STOFCY     = [F:SOQ1]STOFCY
# Issue X3-38651
#[M:ORDK]PJT        = [F:SOH]PJT
[M:ORDK]PJT        = [F:SOQ1]PJT
# End issue X3-38651
[M:ORDK]BPRNUM     = [F:SOH]BPCORD
[M:ORDK]STRDAT     = [F:SOQ1]ORDDAT
If [F:SOQ1]SHIDAT = [0/0/0]
    [M:ORDK]ENDDAT = [F:SOQ1]DEMDLVDAT
Else
    [M:ORDK]ENDDAT = [F:SOQ1]SHIDAT
Endif
If [M:ORDK]ENDDAT < [M:ORDK]STRDAT [M:ORDK]ENDDAT = [M:ORDK]STRDAT : Endif
[M:ORDK]VCRTYP     = 2
[M:ORDK]VCRNUM     = [F:SOQ1]SOHNUM
[M:ORDK]VCRLIN     = [F:SOQ1]SOPLIN
[M:ORDK]VCRSEQ     = [F:SOQ1]SOQSEQ
[M:ORDK]EXTQTY     = WEXTQTY
[M:ORDK]CPLQTY     = WCPLQTY
# Détermination des quantités allouées et ruptures des préparations
Raz WALL, WSHT
If [F:SOQ1]OPRQTYSTU+[F:SOQ1]PREQTYSTU>0
   Gosub WIP_ALLSHT
Endif
[M:ORDK]ALLQTY  = [F:SOQ1]ALLQTYSTU + WALL + [F:SOQ1]ODLQTYSTU
[M:ORDK]SHTQTY  = [F:SOQ1]SHTQTYSTU + WSHT

# Gestion des signatures : Si la cde n'est pas signée et pas d'encours sur les cdes non signées
# --> Il faut supprimer l'encours si rien n'est alloué et réalisé
If [F:SOH]APPFLG<3 & GSOHAPPORD=1 & sum([M:ORDK]ALLQTY, [M:ORDK]SHTQTY)=0 & [M:ORDK]CPLQTY=0
    [M:ORDK]MAJCOD     = "A"
Endif

If [F:SOH]SOHCAT = 4
   [M:ORDK]ABBFIL  = "SOC"
   [M:ORDK]FMI     = 1
Else
   [M:ORDK]ABBFIL  = "SOQ"
   [M:ORDK]FMI     = [F:SOQ1]FMI
Endif
[M:ORDK]MRPMES     = 1
#[M:ORDK]VCRTYPORI  = 0
#[M:ORDK]VCRNUMORI  = ""
#[M:ORDK]VCRLINORI  = 0
#[M:ORDK]VCRSEQORI  = 0
[M:ORDK]BOMALT     = 0
[M:ORDK]ORI        = 2
[M:ORDK]PIO        = [F:SOQ1]DLVPIO

Call WIP From TRTWIP

Return

#-----------------------------------------------------------------------#
# Détermination des quantités allouées et ruptures                      #
# pour les quantités en préparation, préparées                          #
# d'une ligne de commande (pour maj correcte de l'en-cours)             #
#-----------------------------------------------------------------------#
$WIP_ALLSHT

# Lecture des lignes de BP concernant la ligne de commande
If evalue(ABR+"OPRQTYSTU")>0 | evalue(ABR+"PREQTYSTU")>0
   If instr(1,dbgstr(2),",")
      WFILEDEF = vireblc(left$(dbgstr(2),instr(1,dbgstr(2),",")-1),4)
   Else
      WFILEDEF = vireblc(dbgstr(2),4)
   Endif

# Issue 116484
#   If !clalev([F:PRE1]) Local File STOPRED    [PRE1] Endif
#   If !clalev([F:PRH1]) Local File STOPREH    [PRH1] Endif
#
#   Filter [PRE1] Where ORINUM=[M:ORDK]VCRNUM & ORILIN=[M:ORDK]VCRLIN &
#&                      ORISEQ=[M:ORDK]VCRSEQ
#&                Order By Key CLE=ORINUM;ORILIN;ORISEQ
#   For [PRE1]
#      # Lecture de l'ent?te de préparation
#      Read [PRH1]PRH0=[F:PRE1]PRHNUM
#      # Elle n'existe pas encore ou la prépa n'est pas livrée
#      If fstat | [F:PRH1]SDHNUM=""
#         WALL += [F:PRE1]ALLQTY
#         WSHT += [F:PRE1]SHTQTY
#      Endif
#   Next
#   Filter [PRE1]

   If !clalev([F:PREW]) Local File STOPRED    [PREW] Endif

   Filter [PREW] Where ORINUM=[M:ORDK]VCRNUM & ORILIN=[M:ORDK]VCRLIN &
&                      ORISEQ=[M:ORDK]VCRSEQ
   For [PREW]PRE1
      WALL += [F:PREW]ALLQTY
      WSHT += [F:PREW]SHTQTY
   Next
   Filter [PREW]
# End issue 116484

Endif

Default File WFILEDEF

Return

#-----------------------------------------------------------------------#
# Mise ? jour du fichier ORDERS (encours) pour les réservations clients #
#                                                                       #
#   --> Alimentation du masque [ORDK]                                   #
#   --> Appel du sous-pro TRTWIP                                        #
#                                                                       #
#-----------------------------------------------------------------------#
$APPELWIP_BPCALL

Raz [M:ORDK]

[M:ORDK]MAJCOD     = WTRTORD
[M:ORDK]WIPTYP     = 12                       : # Réservation client: CR
[M:ORDK]WIPSTA     = 1                        : # Statut encours    : Ferme
[M:ORDK]WIPNUM     = WWIPNUM                  : # Numero ordre
[M:ORDK]ITMREF     = WITMREF
# --------------------------------------
# FGR 13/04/2015 : X3SUIVI105605 (début)
If dim(WECCVALMAJ) >= 0 Then
  [M:ORDK]ECCVALMAJ  = WECCVALMAJ
Endif
If dim(WECCVALMIN) >= 0 Then
  [M:ORDK]ECCVALMIN  = WECCVALMIN
Endif
# FGR 13/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------
[M:ORDK]ORIFCY     = WORIFCY                  : # Site origine/emetteur
[M:ORDK]STOFCY     = WSTOFCY
[M:ORDK]BPRNUM     = vireblc(left$(LNUM,10),2)
[M:ORDK]STRDAT     = date$                    : # Date debut
[M:ORDK]ENDDAT     = WALLDAT                  : # Date fin
[M:ORDK]VCRTYP     = 1
[M:ORDK]VCRNUM     = LNUM
[M:ORDK]VCRLIN     = WLIN
[M:ORDK]VCRSEQ     = 0
[M:ORDK]EXTQTY     = LQTY
[M:ORDK]CPLQTY     = 0                        : # Qte réalisée
[M:ORDK]ALLQTY     = LQTY
[M:ORDK]SHTQTY     = 0
[M:ORDK]PJT        = ""
[M:ORDK]ABBFIL     = "BPC"
[M:ORDK]FMI        = 1
[M:ORDK]MRPMES     = 1
[M:ORDK]VCRTYPORI  = 0
[M:ORDK]VCRNUMORI  = ""
[M:ORDK]VCRLINORI  = 0
[M:ORDK]VCRSEQORI  = 0
[M:ORDK]BOMALT     = 0
[M:ORDK]ORI        = 2                        : # Origine : Ventes
[M:ORDK]PIO        = 1

Call WIP From TRTWIP

Return
####################################################################

#----------------------------------------------------------------#
# Historisation des avenants                                     #
#----------------------------------------------------------------#
# Entrée  ABFIC    : Abréviation du fichier ? historiser         #
#                    "SOH" = Ent?te commande                     #
#                    "SOC" = Cumul A/R        SOC                #
#                    "SOP" = Détail commande  SOP                #
#                    "SOQ" = Détail commande  SOP et SOQ         #
#         TRAIT    : Code traitement                             #
#                    "M"   = Modification                        #
#                    "A"   = Annulation                          #
#----------------------------------------------------------------#
Subprog HISTO_REV(ABFIC, TRAIT)
Value Char ABFIC
Value Char TRAIT

Case ABFIC
    When "SOH" : Gosub HISTO_SOH
    When "SOC" : Gosub HISTO_SOC
    When "SOP" : Gosub HISTO_SOP
    When "SOQ" : Gosub HISTO_SOQ
    When "SQH" : Gosub HISTO_SQH #For header modification Issue X3-57674 : X3-71864 - 2018-01-18 by APL
    When "SQD" : Gosub HISTO_SQD #For detail modification Issue X3-57674 : X3-71864 - 2018-01-18 by APL
    When Default
Endcase
End
#----------------------------------------------------#
# Historisation ent?te commande SORDER  --> VSORDER  #
#----------------------------------------------------#
$HISTO_SOH
  If clalev ([F:VOH]) = 0 Local File VSORDER [VOH] : Endif
  [F:VOH] = [F:SOH]     : [F:VOH]REVCOD = TRAIT
  [F:VOH]CREDAT = date$ : [F:VOH]CREUSR = GUSER
  Write [VOH] : If fstat : GOK = 0 : Call FSTA("VOH") From GLOCK : Endif
Return

#----------------------------------------------------#
# Historisation ent?te commande SQUOTE  --> VSQUTED  #
#----------------------------------------------------#
$HISTO_SQH
# Issue X3-57674 : X3-71864 - 2018-01-18 by APL
If clalev ([F:VQH]) = 0 Local File VSQUOTE[VQH] : Endif
[F:VQH] = [F:SQH]
[F:VQH]REVCOD = TRAIT
Write [VQH] : If fstat : GOK = 0 : Call FSTA("VQH") From GLOCK : Endif
Return

$HISTO_SQD
# Issue X3-57674 : X3-71864 - 2018-01-18 by APL
If clalev ([F:VQD]) = 0 Local File VSQUOTED [VOQ] : Endif
[F:VQD] = [F:SQD]     : [F:VQD]REVCOD    = TRAIT
                        [F:VQD]LINREVNUM = [F:SQD]LINREVNUM
[F:VQD]CREDAT = date$ : [F:VQD]CREUSR    = GUSER
Write [VQD] : If fstat : GOK = 0 : Call FSTA("VQD") From GLOCK : Endif

Return

#----------------------------------------------------#
# Historisation ent?te commande SORDERC --> VSORDERC #
#----------------------------------------------------#
$HISTO_SOC
If clalev ([F:VOC]) = 0 Local File VSORDERC [VOC] : Endif
[F:VOC] = [F:SOC] : [F:VOC]REVCOD = TRAIT
[F:VOC]CREDAT = date$ : [F:VOC]CREUSR = GUSER
Write [VOC] : If fstat : GOK = 0 : Call FSTA("VOC") From GLOCK : Endif
Return

#----------------------------------------------------#
# Historisation détail commande SORDERP --> VSORDERP #
#                               SORDERQ --> VSORDERQ #
#----------------------------------------------------#
$HISTO_SOQ

Gosub HISTO_SOP
If clalev ([F:VOQ]) = 0 Local File VSORDERQ [VOQ] : Endif

[F:VOQ] = [F:SOQ]     : [F:VOQ]REVCOD    = TRAIT
                        [F:VOQ]LINREVNUM = [F:VOP]LINREVNUM
[F:VOQ]CREDAT = date$ : [F:VOQ]CREUSR    = GUSER
#Infbox "Write " + num$([F:VOP]LINREVNUM)
Write [VOQ] : If fstat : GOK = 0 : Call FSTA("VOQ") From GLOCK : Endif
Return

#----------------------------------------------------#
# Historisation détail commande SORDERP --> VSORDERP #
#----------------------------------------------------#
$HISTO_SOP
If clalev ([F:VOP]) = 0 Local File VSORDERP [VOP] : Endif
Look [VOP] VOP0=[F:SOP]SOHNUM;[F:SOP]LINREVNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ

If fstat
    [F:VOP] = [F:SOP]     : [F:VOP]REVCOD = TRAIT
    [F:VOP]CREDAT = date$ : [F:VOP]CREUSR = GUSER
    Write [VOP] : If fstat : GOK = 0 : Call FSTA("VOP") From GLOCK : Endif
    If TRAIT<>"A"
      Read [CAL] CAL0="SOP";0;[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ;"";1
      If !fstat
        [F:CAL]ABRFIC="VOP"
        [F:CAL]CPLCLE=num$([F:VOP]LINREVNUM)
        Write [CAL] : If fstat GOK=0 : Call FSTA("CAL") From GLOCK : Endif
      Endif
    Endif
Endif
Return

#-----------------------------------------------------------------#
# Maj du n° de la contremarque générée dans les commandes         #
#-----------------------------------------------------------------#
# Entrée  LSOHNUM     : N° de la commande                         #
#         LSOPLIN     : N° ligne                                  #
#         LSOQSEQ     : N° séquence                               #
#         LFMINUM     : N° de la contremarque générée             #
#         LFMILIN     : N° ligne                                  #
#         LFMISEQ     : N° séquence                               #
#         LOPT        : 1 : Maj du n°contremarque (creation)      #
#                       2 : Raz du n°contremarque (suppression)   #
# Sortie  LRET        : 0 Ok ; 1 Pb                               #
#-----------------------------------------------------------------#
Subprog MAJFMISOQ(LSOHNUM, LSOPLIN, LSOQSEQ, LFMINUM, LFMILIN, LFMISEQ, LOPT, LRET)
Value    Char    LSOHNUM
Value    Integer LSOPLIN
Value    Integer LSOQSEQ
Value    Char    LFMINUM
Value    Integer LFMILIN
Value    Integer LFMISEQ
Value    Integer LOPT
Variable Integer LRET    : LRET=0

If clalev ([F:SOQ]) = 0 Local File SORDERQ [SOQ] : Endif

Readlock [SOQ]SOQ0 = LSOHNUM;LSOPLIN;LSOQSEQ
If fstat
    LRET=1 : Call RSTA("SOQ", LSOHNUM-num$(LSOPLIN)-num$(LSOQSEQ)) From GLOCK : End
Endif

If LOPT = 1
#   Création de l'OF    : Maj du n°contremarque dans la ligne de commande
    [F:SOQ]FMINUM = LFMINUM : [F:SOQ]FMILIN = LFMILIN
    [F:SOQ]FMISEQ = LFMISEQ
Elsif LOPT=2
#   Suppression de l'OF : Remise ? blc du n° contremarque dans la ligne de commande
    Raz [F:SOQ]FMINUM, [F:SOQ]FMILIN, [F:SOQ]FMISEQ
Endif

Rewrite [F:SOQ]
If fstat LRET=1 : Call FSTA("SOQ") From GLOCK : Endif

End


#---------------------------------------------------------#
# Maj des cumuls articles                                 #
#---------------------------------------------------------#
# Entrée  LITM        : Article                           #
#         LFCY        : Site                              #
#         LQTY        : Quantité                          #
#         LSENS       : En + ou en -                      #
#         LTYP        : Type quantité                     #
#                        "S" : SALSTO                     #
# Sortie  LRET        : 0 Ok ; 1 Pb                       #
#---------------------------------------------------------#
Subprog MAJITVVEN(LITM,LFCY,LQTY,LSENS,LTYP, LRET)
Value   Char     LITM
Value   Char     LFCY
Value   Decimal  LQTY
Value   Char     LSENS
Value   Char     LTYP
Value   Integer  LRET

LRET=0

If clalev([F:ITV])  = 0 Local File ITMMVT     [ITV]  : Endif
If clalev([F:ITF1]) = 0 Local File ITMFACILIT [ITF1] : Endif      # hcb  86563
If [F:ITF1]ITMREF<>LITM | [F:ITF1]STOFCY<>LFCY                    # hcb  86563
    Read [ITF1]ITF0=LITM;LFCY                                     # hcb  86563
    # 92719 : ITF is not mandatory if the item is not managed in stock
    #If fstat                                                      # hcb  86563
       #Call RSTA("ITF1",LITM-LFCY) From GLOCK                     # hcb  86563
       #GOK=0 : LRET=1 : End                                       # hcb  86563
    #Endif                                                         # hcb  86563
    If fstat Raz [ITF1] Endif
    # 92719
Endif                                                             # hcb  86563

# Issue 117950
#Readlock [ITV]ITV0=LITM;LFCY
Readlock [ITV]ITV0=LITM;LFCY With lockwait=3
# End 117950
If fstat=1
   GOK=-1 : GLOCK = "$ITMMVT"-LITM-LFCY
   LRET=1
Elsif fstat
   # Création ITV
   Raz [F:ITV]
   [F:ITV]ITMREF=LITM
   [F:ITV]STOFCY=LFCY
   Gosub MAJQTY
   Call ECRITV From STKLIB
   If fstat
      GOK=0 : Call FSTA("ITV") From GLOCK
      LRET=1
   Endif
Else
   # Mise ? jour ITV
   Gosub MAJQTY
   Call REWITV From STKLIB
   If fstat
      GOK=0 : Call FSTA("ITV") From GLOCK
      LRET=1
   Endif
Endif
End

$MAJQTY
Case LTYP
    When "S" : Gosub MAJQTYSAL
    When "TRF" : # Bug 81935: Stock transit   (pour retour intersite ss mvt stock)
                 If [F:ITF1]STOMGTCOD > 1                         # hcb  86563
                    Gosub MAJQTYTRF                               # hcb  86563
                 Endif                                            # hcb  86563
    When "TRA" : # Bug 81935: Stock transféré (pour retour intersite ss mvt stock)
                 If [F:ITF1]STOMGTCOD > 1                         # hcb  86563
                    Gosub MAJQTYTRA                               # hcb  86563
                 Endif                                            # hcb  86563
Endcase
Return

#----------------------------#
# Mise ? jour En cde client  #
#----------------------------#
$MAJQTYSAL
If LSENS = "="
   #-- X3Suivi 85514 : Cas de Resynchronisation ITMMVT (SALSTO) si retour réactive la commande ---#
   [F:ITV]SALSTO = LQTY
Elsif LSENS = "+"
   [F:ITV]SALSTO += LQTY
Else
   [F:ITV]SALSTO -= LQTY
Endif
If [F:ITV]SALSTO<0 [F:ITV]SALSTO=0 Endif     : # 106012 : On order desynchronized on product site

Return

# Bug 81935 : Maj stock en transit si retour intersite sans mvt de stock
#------------------------------#
# Mise ? jour Stock en transit #
#------------------------------#
$MAJQTYTRF
If LSENS = "+"
   [F:ITV]TRFSTO += LQTY
Else
   [F:ITV]TRFSTO -= LQTY
Endif
If [F:ITV]TRFSTO<0 [F:ITV]TRFSTO=0 Endif     # hcb 86563

Return
# Bug 81935

# Bug 81935 : Maj stock transféré si retour intersite sans mvt de stock
#------------------------------#
# Mise ? jour Stock en transit #
#------------------------------#
$MAJQTYTRA
If LSENS = "+"
   [F:ITV]TRASTO += LQTY
Else
   [F:ITV]TRASTO -= LQTY
Endif
If [F:ITV]TRASTO<0 [F:ITV]TRASTO=0 Endif     # hcb 86563

Return
# Bug 81935

