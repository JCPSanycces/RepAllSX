#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
#  Sous programmes pour la gestion des contrats de service              Module CRM     Aout 2006
##########################################################################################################
#  GERE_LCM_CREATION  : gere les données  pour la gestion des en cours en creation
#  GERE_LCM_MODIF     : gere les données  pour la gestion des en cours en modification
#  GERE_LCM_ANNULE    : gere les données  pour la gestion des en cours en annulation
##########################################################################################################
##########################################################################################################
# gere les données  pour la gestion des en cours en creation
$GERE_LCM_CREATION
  # FGR 12/08/2009 : X3SUIVI57005 : Revu toute cette partie pour laisser faire S/P qui vont bien
  If [M:CON0]CONBPC <> "" Then
    Read [BPR]BPR0=[M:CON0]CONBPC
    If fstat <> 0 Then
      #Erreur lors de la lecture du tiers + " : " +[M:CON0]CONBPC
      GMESSAGE = mess(445,177,1) - ":" - [M:CON0]CONBPC
      GERR = 2
      OK = 0
      GOK = 0
      Return
    Endif
    If [F:BPR]BPCFLG <> 2 and [F:BPR]PPTFLG <> 2 Then
      Return
    Endif
    #Gestion Dernier contrat de service
    Call LCM_BPRLASTCON ([M:CON0]CONBPC, [M:CON0]CPY, [M:CON0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 2
      OK = 0
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
# gere les données  pour la gestion des en cours en modification
$GERE_LCM_MODIF    
Local Integer IBTRAITBPR
Local Integer IBTRAITBPRINI
Local Char SZSOCINI
Local Integer IBCHANGE_LCMKEY

  # FGR 12/08/2009 : X3SUIVI57005 : Revu toute cette partie pour laisser faire S/P qui vont bien
  IBTRAITBPR = 0
  IBTRAITBPRINI = 0
  Raz SZSOCINI
  IBCHANGE_LCMKEY = 0
  If [M:CON0]CPYINI = [M:CON0]CPY and [M:CON0]SALFCYINI = [M:CON0]SALFCY and [M:CON0]CONBPCINI = [M:CON0]CONBPC and [M:CON4]CONSTRDATI = [M:CON4]CONSTRDAT Then
    #Rien n'a été changé sur les données encours, on sort
    Return
  Endif
  If [M:CON0]CONBPC <> "" Then
    Read [BPR]BPR0=[M:CON0]CONBPC
    If fstat <> 0 Then
      #Erreur lors de la lecture du tiers + " : " +[M:CON0]CONBPC
      GMESSAGE = mess(445,177,1) - ":" - [M:CON0]CONBPC
      GERR = 2
      OK = 0
      GOK = 0
      Return
    Endif
    If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
      IBTRAITBPR = 1
    Endif
  Endif
  If [M:CON0]CPYINI <> [M:CON0]CPY Then
    IBCHANGE_LCMKEY = 1
  Endif
  If [M:CON0]CONBPCINI <> [M:CON0]CONBPC Then
    If [M:CON0]CONBPCINI <> "" Then
      IBCHANGE_LCMKEY = 1
      Read [BPR]BPR0=[M:CON0]CONBPCINI
      If fstat <> 0 Then
        #Erreur lors de la lecture du tiers + " : " +[M:CON0]CONBPCINI
        GMESSAGE = mess(445,177,1) - ":" - [M:CON0]CONBPCINI
        GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
        IBTRAITBPRINI = 1
      Endif
    Endif
  Else
    IBTRAITBPRINI = IBTRAITBPR
  Endif    
  If IBCHANGE_LCMKEY = 1 and IBTRAITBPRINI = 1 Then
    # On a changé de société. On remet à jour les infos pour l'ancienne société
    Call LCM_BPRLASTCON ([M:CON0]CONBPCINI, [M:CON0]CPYINI, [M:CON0]SALFCYINI, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 2
      OK = 0
      GOK = 0
      Return
    Endif
  Endif
  #
  If IBTRAITBPR = 1 Then
    # C'est un client ou un prospect
    # GERE_LCM_CREATION fait tout ce qu'il faut.
    Gosub GERE_LCM_CREATION
  Endif
Return

##########################################################################################################
# gere les données  pour la gestion des en cours en annulation
$GERE_LCM_ANNULE
Local Integer IBSUPR

  # FGR 12/08/2009 : X3SUIVI57005 : Revu toute cette partie pour laisser faire S/P qui vont bien
  IBSUPR = 0
  Read [BPR]BPR0=[M:CON0]CONBPC
  If fstat <> 0 Then
    #Erreur lors de la lecture du tiers + " : " +[M:CON0]CONBPC
    GMESSAGE = mess(445,177,1) - ":" - [M:CON0]CONBPC
    GERR = 2
    OK = 0
    GOK = 0
    Return
  Endif
  If [F:BPR]BPCFLG <> 2 and [F:BPR]PPTFLG <> 2 Then
    Return
  Endif
  #If faut supprimer les anciennes données
  Call LCM_DELKEY(6, [M:CON0]CONNUM, IBSUPR, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 2
    OK = 0
    GOK = 0
    Return
  Endif
  If IBSUPR = 1 Then
    # on a supprimé quelque chose : donc on refait la recherche
    # GERE_LCM_CREATION fait tout ce qu'il faut.
    Gosub GERE_LCM_CREATION
  Endif
Return
