#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-78905 - 2018-04-13 by BAKHA : Selections for linking documents from Non-conformance
#                                        which includes linking to either document header or document lines

$ACTION
Case ACTION
    When "SEL_TABLE"    : Gosub SEL_TABLE
    When "FIN_TABLE"    : Gosub FIN_TABLE

Endcase
Return

$SEL_TABLE
Case TABLE
    When "SELNCSDOC"  : Gosub S_SELNCSDOC  # Document selection for header and details # Issue X3-100238 - 2018-08-20 by JUSYN: Only for header
    When "SELNCSDOCD" : Gosub S_SELNCSDOCD # Document selection for details # Issue X3-100238 - 2018-08-20 by JUSYN: Only for detail
Endcase
Return

# Document selection, which allows either document header or lines to be selected

$S_SELNCSDOC
Local Integer  DOCTYP         : DOCTYP    = val(PARAM(1))
Local Char     WFCY(GLONFCY)   : WFCY       = PARAM(3)
Local Char     WBPCNUM(GLONBPC): WBPCNUM    = PARAM(4)
Local Char     WBPSNUM(GLONBPS): WBPSNUM    = PARAM(5)
Local Char     WITMREF(GLONITM): WITMREF    = PARAM(6)
# Issue X3-100238 - 2018-08-23 by JUSYN : New Parameter for version; Check ECC activity code
Local Char     WECCVALMAJ(GLONEVL): WECCVALMAJ    = PARAM(7)
Local Char     WECCVALMIN(GLONEVL): WECCVALMIN    = PARAM(8)
Local Integer  WECCFLG            : WECCFLG       = 0
If func AFNC.ACTIV("ECC")
    WECCFLG = 1
Endif
# End issue X3-100238
Local Char   CODFIC (30)

Case DOCTYP
    When 1 : # Purchase receipts selection
        # Issue X3-100229 - 2018-09-03 by JUSYN : New title for selection list. Separation between header and detail line selection.
        #                                        Allow header and detail line selection if product is empty.
        TIT(0) = mess(10,16,1) - mess(11,2088,1)- "-" - mess(5,159,1) # "Selection Purchase receipts - Number"
        NBCOL = 0

        START='PTHNUM'
        ORDRE='PTHNUM Desc'
        CRITERE = 'PRHFCY = "'+WFCY+'"'

        CODFIC ="PRECEIPT"
        NBCOL +=1  : COL(NBCOL)="PTHNUM" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="PRHFCY" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="RCPDAT" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="BPSNUM" : Gosub TEXTE

        # receipt header selection
        If (WITMREF = "")
          If clalev([F:PTH]) = 0 : Local File PRECEIPT   [PTH] : Endif
          Default File [PTH]

          If (WBPSNUM <> "")
            CRITERE += ' & BPSNUM ="'+WBPSNUM+'"'
          Endif

          NBCOL +=1  : COL(NBCOL)="PJTH"   : Gosub TEXTE
        Else
          # Receipt line selection with version
          If WECCFLG > 0 and WECCVALMAJ <> ""
            If clalev([F:NCSPTHS]) = 0 : Local File NCSPTHPTDSTJ  [NCSPTHS] : Endif
            Default File [NCSPTHS]
          Else # receipt line without version
            If clalev([F:NCSPTH]) = 0 : Local File NCSPTHPTD  [NCSPTH] : Endif
            Default File [NCSPTH]
          Endif


          ORDRE += ';PTDLIN'
          CRITERE += ' & ITMREF ="'+WITMREF+'"'

          If (WBPSNUM <> "")
            CRITERE += '& BPSNUM ="'+WBPSNUM+'"'
          Endif

          If WECCFLG > 0 and WECCVALMAJ <> ""
            CRITERE += ' & ECCVALMAJ ="'+WECCVALMAJ+'"'
            If (WECCVALMIN <> "")
              CRITERE += ' & ECCVALMIN ="'+WECCVALMIN+'"'
            Endif
          Endif

          CODFIC ="PRECEIPTD"
          NBCOL +=1  : COL(NBCOL)="PJT"   : Gosub TEXTE
        Endif
# End issue X3-100229
    When 2 : # Customer return selection
        # Issue X3-88164 - 2018-08-29 by JUSYN : New title for selection list. Separation between header and detail line selection.
        #                                        Allow header and detail line selection if product is empty.
        TIT(0) = mess(10,16,1) - mess(624,197,1) - "-" - mess(5,159,1) # "Selection Production tracking - Number"
        NBCOL = 0

        START='SRHNUM'
        ORDRE='SRHNUM Desc'  # Newest return first
        CRITERE = 'STOFCY = "'+WFCY+'"'

        CODFIC ="SRETURN"
        NBCOL +=1  : COL(NBCOL)="SRHNUM" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="STOFCY" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="RTNDAT" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="BPCORD" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="PJT" : Gosub TEXTE

        # Customer return header selection
        If (WITMREF = "")
          If clalev([F:SRH]) = 0 : Local File SRETURN [SRH] : Endif
          Default File [SRH]

          If (WBPCNUM <> "")
            CRITERE += ' & BPCORD ="'+WBPCNUM+'"'
          Endif
        Else
          If WECCFLG > 0 and WECCVALMAJ <> ""
            If clalev([F:NCSSRHS]) = 0 : Local File NCSSRHSRDSTJ  [NCSSRHS] : Endif
            Default File [NCSSRHS]
          Else # Customer return header line without version
            If clalev([F:NCSSRH]) = 0 : Local File NCSSRHSRD [NCSSRH] : Endif
            Default File [NCSSRH]
          Endif

          ORDRE +=';SRDLIN'
          CRITERE += ' & ITMREF ="'+WITMREF+'"'

          If (WBPCNUM <> "")
            CRITERE += ' & BPCORD ="'+WBPCNUM+'"'
          Endif

          If WECCFLG > 0 and WECCVALMAJ <> ""
            CRITERE += ' & ECCVALMAJ ="'+WECCVALMAJ+'"'
            If (WECCVALMIN <> "")
              CRITERE += ' & ECCVALMIN ="'+WECCVALMIN+'"'
            Endif
          Endif
        Endif
# End issue X3-88164
    When 3 : # Production tracking selection
# Issue X3-100238 - 2018-08-14 by JUSYN : Allow selection from tracking header and detail
        # Title change header and detail specific. Header with "- Number"
        TIT(0) = mess(10,16,1) - mess(214,195,1) - "-" - mess(5,159,1) # "Selection Production tracking - Number"
        NBCOL = 0

        START='MFGTRKNUM'
        ORDRE='MFGTRKNUM Desc'     # Issue X3-100238 - 2018-08-23 by JUSYN : Sort descending by tracking number. Newest first.
        CODFIC ="MFGHEADTRK"
        # Issue X3-100238 - 2018-08-23 by JUSYN : code improvements
        CRITERE = ' MFGFCY = "'+WFCY+'"'
        # Issue X3-104609 - 2018-09-06 by JUSYN : Include first links WO as criteria
        If (CMFGNUM <> "")
          CRITERE += ' & MFGNUM ="'+CMFGNUM+'"'
        Endif
        # End issue X3-104609

        # Production tracking header selection
        If (WITMREF = "")
            If clalev([F:MTK]) = 0 : Local File MFGHEADTRK [MTK] : Endif
            Default File [MTK]

            NBCOL +=1  : COL(NBCOL)="MFGTRKNUM"   : Gosub TEXTE
            NBCOL +=1  : COL(NBCOL)="MFGFCY"      : Gosub TEXTE
            NBCOL +=1  : COL(NBCOL)="MFGTRKDAT"   : Gosub TEXTE
            NBCOL +=1  : COL(NBCOL)="MFGNUM"      : Gosub TEXTE
        Else
            CRITERE += ' & ITMREF ="'+WITMREF+'"'

            # Production tracking header selection with version
            If WECCFLG > 0 and WECCVALMAJ <> ""
                If clalev([F:NCSMTKS]) = 0 : Local File NCSMTKMKISTJ [NCSMTKS] : Endif
                Default File [NCSMTKS]

                CRITERE += ' & ECCVALMAJ ="'+WECCVALMAJ+'"'
                If (WECCVALMIN <> "")
                  CRITERE += ' & ECCVALMIN ="'+WECCVALMIN+'"'
                Endif
            Else # Production tracking header without version
              If clalev([F:NCSMTK]) = 0 : Local File NCSMTKMKI  [NCSMTK] : Endif
              Default File [NCSMTK]
            Endif
        # End ISSUE X3-100238

            NBCOL +=1  : COL(NBCOL)="MFGTRKNUM"   : Gosub TEXTE
            NBCOL +=1  : COL(NBCOL)="MFGFCY"      : Gosub TEXTE
            NBCOL +=1  : COL(NBCOL)="MFGTRKDAT"   : Gosub TEXTE
            NBCOL +=1  : COL(NBCOL)="MFGNUM"      : Gosub TEXTE
        Endif

# End issue X3-100238
    When 4 : # Quality control selection

        TIT(0) = mess(10,16,1) - mess(28,701,1)
        NBCOL = 0

        # Quality control header selection
        If (WITMREF = "")
          If clalev([F:QLH]) = 0 : Local File STOQLYH [QLH] : Endif
          Default File [QLH]
          CODFIC ="STOQLYH"
          START='VCRNUM'
          ORDRE='VCRNUM'
          CRITERE = 'STOFCY = "'+WFCY+'"'

          NBCOL +=1  : COL(NBCOL)="VCRNUM" : Gosub TEXTE
          NBCOL +=1  : COL(NBCOL)="STOFCY" : Gosub TEXTE
          NBCOL +=1  : COL(NBCOL)="ITMREF" : Gosub TEXTE
          NBCOL +=1  : COL(NBCOL)="ENDCTLDAT" : Gosub TEXTE
          NBCOL +=1  : COL(NBCOL)="PJT" : Gosub TEXTE
        Else
          # Quality control line selection

          If clalev([F:QLD]) = 0 : Local File STOQLYD  [QLD] : Endif
          Default File [QLD]

          START='VCRNUM'
          ORDRE='VCRNUM;VCRLIN'
          CRITERE = 'STOFCY = "'+WFCY+'"'
          CRITERE += ' & ITMREF ="'+WITMREF+'"'

          If dim([M]ECCVALMAJ)>0 and [M]ECCVALMAJ <> ""
            CRITERE += ' & ECCVALMAJ ="'+[M]ECCVALMAJ+'"'
            If ([M]ECCVALMIN <> "")
              CRITERE += ' & ECCVALMIN ="'+[M]ECCVALMIN+'"'
            Endif
          Endif

          CODFIC ="STOQLYD"
          NBCOL +=1  : COL(NBCOL)="VCRNUM" : Gosub TEXTE
          NBCOL +=1  : COL(NBCOL)="VCRLIN" : Gosub TEXTE
          NBCOL +=1  : COL(NBCOL)="ITMREF" : Gosub TEXTE
          If dim([M]ECCVALMAJ)>0 and [M]ECCVALMAJ <> ""
            NBCOL +=1  : COL(NBCOL)="ECCVALMAJ" : Gosub TEXTE
            NBCOL +=1  : COL(NBCOL)="ECCVALMIN" : Gosub TEXTE
          Endif
          NBCOL +=1  : COL(NBCOL)="QTYSTU"    : Gosub TEXTE
          NBCOL +=1  : COL(NBCOL)="STOFCY" : Gosub TEXTE
          NBCOL +=1  : COL(NBCOL)="PJT" : Gosub TEXTE

        Endif

Endcase
DEFPAG = 1
Return

###################################################################
$TEXTE
Call TEXTFIC(CODFIC ,  COL(NBCOL), 1, TIT(NBCOL) ) From OBJDIV
Return

$FIN_TABLE
Case TABLE
   When "SELNCSDOC" : Gosub FIN_SELNCSDOC
Endcase
Return

# If needed, set Line number after selecting line

$FIN_SELNCSDOC

If VALEUR <> ""
  # Issue X3-100229 - 2018-09-04 by JUSYN : SELNCSDOC for header selection only. Header means detail line = 0; so to set for all documents
  #                                         Erased all former statements.
  PARAM(2) = num$(0)
  # End issue X3-100229
Endif

Return

# End issue X3-100238
# Issue X3-100238 - 2018-08-20 by JUSYN: Selection for detail lines
$S_SELNCSDOCD
Local Integer  DOCTYP         : DOCTYP      = val(PARAM(1))
Local Char     WFCY(GLONFCY)   : WFCY       = PARAM(2)
Local Char     WBPCNUM(GLONBPC): WBPCNUM    = PARAM(3)
Local Char     WBPSNUM(GLONBPS): WBPSNUM    = PARAM(4)
Local Char     WITMREF(GLONITM): WITMREF    = PARAM(5)
Local Char     WVCRNUM(GLONVCR): WVCRNUM    = PARAM(6)
# Issue X3-100238 - 2018-08-23 by JUSYN : New Parameter for version
Local Char     WECCVALMAJ(GLONEVL): WECCVALMAJ    = PARAM(7)
Local Char     WECCVALMIN(GLONEVL): WECCVALMIN    = PARAM(8)
Local Integer  WECCFLG            : WECCFLG       = 0
If func AFNC.ACTIV("ECC")
    WECCFLG = 1
Endif
# End issue X3-100238

Local Char   CODFIC (30)

     # ISSUE X3-100229 - 2018-09-03 By JUSYN : PURCHASE RECEIPT DETAIL LINE TREATMENT
Case DOCTYP
    When 1 : # Purchase receipt detail line selection
        TIT(0) = mess(10,16,1) - mess(11,2088,1) - "-" - mess(176,133,1) # "Selection Customer returns - Lines"
        NBCOL = 0

        START = 'PTDLIN'
        ORDRE = 'PTHNUM; PTDLIN'
        CRITERE = 'PRHFCY = "'+WFCY+'"'
        CRITERE += ' & PTHNUM ="'+WVCRNUM+'"'

        # Purchase receipts header selection
        If (WITMREF = "")
            If clalev([F:NCSPTD]) = 0 : Local File NCSPTDSTJ [NCSPTD] : Endif
            Default File [NCSPTD]
        Else
            CRITERE += ' & ITMREF ="'+WITMREF+'"'

            # Purchase receipts line selection with version
            If WECCFLG > 0 and WECCVALMAJ <> ""
                If clalev([F:NCSPTHS]) = 0 : Local File NCSPTHPTDSTJ [NCSPTHS] : Endif
                Default File [NCSPTHS]

                CRITERE += ' & ECCVALMAJ ="'+WECCVALMAJ+'"'
                If (WECCVALMIN <> "")
                  CRITERE += ' & ECCVALMIN ="'+WECCVALMIN+'"'
                Endif
            Else # Customer returns line without version
                If clalev([F:NCSPTH]) = 0 : Local File NCSPTHPTD  [NCSPTH] : Endif
                Default File [NCSPTH]
            Endif
        Endif

        CODFIC ="PRECEIPTD"
        NBCOL +=1  : COL(NBCOL)="PTHNUM" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="PTDLIN" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="ITMREF" : Gosub TEXTE
        If WECCFLG > 0 and WECCVALMAJ <> ""
          CODFIC ="STOJOU"
          NBCOL +=1  : COL(NBCOL)="ECCVALMAJ" : Gosub TEXTE
          NBCOL +=1  : COL(NBCOL)="ECCVALMIN" : Gosub TEXTE
          CODFIC ="PRECEIPTD"
        Endif
        NBCOL +=1  : COL(NBCOL)="QTYSTU" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="STU"    : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="PRHFCY" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="RCPDAT" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="BPSNUM" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="PJT"    : Gosub TEXTE
    # End issue X3-100229
    # Issue X3-88164 - 2018-08-30 by JUSYN : Customer returns detail line treatment

    When 2 : # Customer return detail line selection
        TIT(0) = mess(10,16,1) - mess(624,197,1) - "-" - mess(176,133,1) # "Selection Customer returns - Lines"
        NBCOL = 0

        START='SRDLIN'
        ORDRE='SRHNUM; SRDLIN'
        CRITERE = 'STOFCY = "'+WFCY+'"'
        CRITERE += ' & SRHNUM ="'+WVCRNUM+'"'

        # Customer returns header selection
        If (WITMREF = "")
            If clalev([F:NCSSRD]) = 0 : Local File NCSSRDSTJ [NCSSRD] : Endif
            Default File [NCSSRD]

        Else
            CRITERE += ' & ITMREF ="'+WITMREF+'"'

            # Customer returns line selection with version
            If WECCFLG > 0 and WECCVALMAJ <> ""
                If clalev([F:NCSSRHS]) = 0 : Local File NCSSRHSRDSTJ [NCSSRHS] : Endif
                Default File [NCSSRHS]

                CRITERE += ' & ECCVALMAJ ="'+WECCVALMAJ+'"'
                If (WECCVALMIN <> "")
                  CRITERE += ' & ECCVALMIN ="'+WECCVALMIN+'"'
                Endif
            Else # Customer returns line without version
                If clalev([F:NCSSRH]) = 0 : Local File NCSSRHSRD  [NCSSRH] : Endif
                Default File [NCSSRH]
            Endif
        Endif

        CODFIC ="SRETURND"
        NBCOL +=1  : COL(NBCOL)="SRHNUM" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="SRDLIN" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="ITMREF" : Gosub TEXTE
        If WECCFLG > 0 & WECCVALMAJ <> "" | WITMREF = ""
          CODFIC ="STOJOU"
          NBCOL +=1  : COL(NBCOL)="ECCVALMAJ" : Gosub TEXTE
          NBCOL +=1  : COL(NBCOL)="ECCVALMIN" : Gosub TEXTE
          CODFIC ="SRETURND"
        Endif
        NBCOL +=1  : COL(NBCOL)="QTYSTU" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="STU"    : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="STOFCY" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="RTNDAT" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="PJT"    : Gosub TEXTE
        # End issue X3-88164
    When 3 : # Production tracking line selection
        TIT(0) = mess(10,16,1) - mess(214,195,1) - "-" - mess(176,133,1) # "Selection Production tracking - Lines"
        NBCOL = 0

        START='ITMTRKLIN'
        ORDRE='MFGTRKNUM; ITMTRKLIN'
        # Issue X3-100238 - 2018-08-23 by JUSYN : code improvements
        CRITERE = 'MFGFCY = "'+WFCY+'"'
        CRITERE += ' & MFGTRKNUM ="'+WVCRNUM+'"'

        # Production tracking header selection
        If (WITMREF = "")
            If clalev([F:NCSMKI]) = 0 : Local File NCSMKISTJ [NCSMKI] : Endif
            Default File [NCSMKI]

        Else
            CRITERE += ' & ITMREF ="'+WITMREF+'"'

            # Production tracking line selection with version
            If WECCFLG > 0 and WECCVALMAJ <> ""
                If clalev([F:NCSMTKS]) = 0 : Local File NCSMTKMKISTJ [NCSMTKS] : Endif
                Default File [NCSMTKS]

                CRITERE += ' & ECCVALMAJ ="'+WECCVALMAJ+'"'
                If (WECCVALMIN <> "")
                  CRITERE += ' & ECCVALMIN ="'+WECCVALMIN+'"'
                Endif
            Else # Production tracking line without version
                If clalev([F:NCSMTK]) = 0 : Local File NCSMTKMKI  [NCSMTK] : Endif
                Default File [NCSMTK]
            Endif
        Endif
        # End Issue X3-100238

        CODFIC ="MFGITMTRK"
        NBCOL +=1  : COL(NBCOL)="MFGTRKNUM"    : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="ITMTRKLIN"    : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="ITMREF"       : Gosub TEXTE
        If WECCFLG > 0 and WECCVALMAJ <> "" | WITMREF = ""
          CODFIC ="STOJOU"
          NBCOL +=1  : COL(NBCOL)="ECCVALMAJ"    : Gosub TEXTE
          NBCOL +=1  : COL(NBCOL)="ECCVALMIN"    : Gosub TEXTE
          CODFIC = "MFGITMTRK"
        Endif
        NBCOL +=1  : COL(NBCOL)="CPLQTY"       : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="STU"          : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="MFGFCY"       : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="PJT"          : Gosub TEXTE
Endcase
Return
# End issue X3-100238

