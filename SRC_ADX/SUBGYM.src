#<AdxTL>@(#)3.0.0.0 $Revision$
Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("GYM",GBIDC1,GBIDC2) From  GOBJET
End

$ACTION
Case GACTION
 When "GYMCPT" : Gosub GYMCPT
 When "GYMGRP" : Gosub GYMGRP
 When "GYMMOD" : Gosub GYMMOD
 When Default
  Case ACTION
   When "OUVRE"        : Gosub OUVRE
   When "LIENS"        : Gosub LIENS
   When "EXEACT"       : Gosub EXEACT
   When "CREATION"     : Gosub CREATION
   When "MODIF"        : Gosub MODIF
   When "APRES_CRE"    : Gosub APRES_CRE
   When "APRES_MOD"    : Gosub APRES_MOD
   When "RAZCRE"       : Gosub RAZCRE
   When "RAZDUP"       : Gosub RAZDUP
   When "INICRE"       : Gosub INICRE
   When "INIMOD"       : Gosub INIMOD
   When "SETBOUT"      : Gosub SETBOUT
   When "AVANTBOUT"    : Gosub AVANTBOUT
   When "STATUT"       : Gosub STATUT
   When "DEGRISE"      : Gosub DEGRISE
   When "STYLE"        : Gosub STYLE
   When "AP_CHANGE"    : Gosub AP_CHANGE
   When "ANNULE"       : Gosub ANNULE
  Endcase
Endcase
Return

$GYMCPT
# Boite de création de compte
Case ACTION
 When "DEBUT" : Gosub DEBUT_GYMCPT
Endcase
Return

$GYMGRP
# Boite de création de groupe
Case ACTION
 When "DEBUT" : Gosub DEBUT_GYMGRP
Endcase
Return

$GYMMOD
# Boite de modification de groupe
Case ACTION
 When "DEBUT" : Gosub DEBUT_GYMMOD
Endcase
Return

$OUVRE
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
If clalev([F:CLS])=0 : Local File GACCCLS    [CLS] : Endif
If clalev([F:ASB])=0 : Local File ABLBSYS    [ASB] : Endif
Local Integer FLMOD
Local Integer PYRREF
Local Mask GYMCPT [GYMC]
Local Mask GYMGRP [GYMR]
For I=1 To 4
 Call CHARGE_IMAGE(func DEFIMG(I))
Next IMG
Return

Funprog CATIMG
End "MIS"

Funprog DEFIMG(I)
Value Integer I
Case I
 When 1 : End "PYRHEAD"
 When 2 : End "PYRGRP"
 When 3 : End "PYRELT"
 When 4 : End "PYRJOK"
Endcase
End

Subprog CHARGE_IMAGE(IMG)
Value Char IMG
Local Integer K
Local Char    IMGFIC(30) , IMGEXT(10) , PHOTO(250)
Read [ASB]ASB0 = func CATIMG;IMG
K = instr(1,[F:ASB]NAMFIC,".")
If K
 IMGFIC = left$([F:ASB]NAMFIC,K-1)
 IMGEXT = right$([F:ASB]NAMFIC,K+1)
Else
 IMGFIC = [F:ASB]NAMFIC
 IMGEXT = ""
Endif
PHOTO = filpath(nomap+"\RES",IMGFIC,IMGEXT,"X3_PUB")
If filinfo(PHOTO,0)<0
 Openo PHOTO,0
 Putseq 1,[F:ASB]BLOB
 Openo
Endif
End

$EXEACT
If BOUT="S"
 Gosub RELIT From GOBJSUB
 OK = 0
Endif
Return

$LIENS
Call LECTEXTRA([M]DESTRA,"GACCPYM","DESTRA",[M]PYM,"") From ATEXTRA
Call LECTEXTRA([M]SHOTRA,"GACCPYM","SHOTRA",[M]PYM,"") From ATEXTRA
Actzo 30
Diszo COA
Read [COA]COA0 = [F:GYM]COA
Call CHARGE_PYR([F:GYM]COA,[F:GYM]PYM)
[M]LEGCLSINV = [F:COA]LEGCLS
Filter [COA] Where PYRREF=[F:GYM]PYM
Read [COA] First
Filter [COA]
If fstat<=2
 PYRREF = 1
Else
 PYRREF = 0
Endif
[M]PYRREF = PYRREF
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Call TEMPON("V") From GESECRAN
Call VALPYR
FLMOD = 1
Call TEMPOFF From GESECRAN
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
If [M]FLMOD
 Call TEMPON("V") From GESECRAN
 Call VALPYR
 FLMOD = 1
 Call TEMPOFF From GESECRAN
Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GACCPYM","DESTRA",CLECUR1,"","GACCPYM","DESTRA",[M]PYM,"")  From ATEXTRA
 Call DUPTEXTRA("GACCPYM","SHOTRA",CLECUR1,"","GACCPYM","SHOTRA",[M]PYM,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GACCPYM","DESTRA",[M]PYM,"") From ATEXTRA
Call MAJTEXTRA([M]SHOTRA,"GACCPYM","SHOTRA",[M]PYM,"") From ATEXTRA
Return

$INICRE
$INIMOD
If dim([F:GYM]DES)>0
 [F:GYM]DES = [M]DESTRA
Endif
Return

$APRES_CRE
Actzo 30

$APRES_MOD
If FLMOD
 Call TEMPON("V") From GESECRAN
 Call PYRAMPRT([M]PYM,[M]COA,nomap) From LIENPYRACC
 Call PYRAMLIK([M]PYM,[M]COA,nomap) From LIENPYRACC
 Call TEMPOFF From GESECRAN
Endif
Call CHARGE_PYR([F:GYM]COA,[F:GYM]PYM)
Affzo 30
Return

$RAZCRE
Local Char XFLGCLS(20)
Actzo COA
Effzo 30
Gosub DEFVAR
[M]NBGRU     = 1
[M]GRU(0)    = mess(115,102,1) : # TOTAL
[M]DES(0)    = mess(116,102,1) : # Groupe racine
[M]SHO(0)    = ""
[M]LEV(0)    = 10
[M]PRNROW(0) = 10
[M]CLSCOD(0) = ""
[M]UOMDAC(0) = 1
[M]UOM(0)    = ""
[M]BUDTRK(0) = 1
[M]DEFVAL(0) = 0
[M]TIMDSP(0) = ""
[M]NBLNK     = 1
[M]GROUPE(0) = [M]GRU(0)
[M]SBBGRU(0) = ""
[M]ACC(0)    = ""
[M]NBCMP     = 1
[M]PARENT(0)   = ""
[M]KEYC(0)     = PFIXG+[M]GRU(0)
[M]LIBSHORT(0) = [M]GRU(0)
[M]LIBL(0)     = [M]DES(0)
[M]IMG(0)      = IMGDEP
Affzo 30
Return

$RAZDUP
[M]FLMOD = 1
Return

$SETBOUT
CHMEN = ""
If REP=""
 If instr(1,GUSRAUZ(1),"2")
  CHMEN += "2"
 Endif
 If instr(1,GUSRAUZ(1),"3") & !PYRREF : # Pas de génération pour pyramide de référence
  CHMEN += "3"
 Endif
 CHMEN += "4"
 If PYRREF
  CHMEN += "5" : # Réorganisation
 Endif
Endif
If BOUT="N"
 Call INIXSL([M]XSL1,"ANOMH") From INTRUTILA
 Affzo [M]XSL1
Endif
Return

$AVANTBOUT
If BOUT = "3" : # Génération auto
 Filter [GRY] Where PYM=[M]PYM
 Read [GRY]GRY0 First
 Filter [GRY]
 If !fstat
  # Groupes existants  pour cette pyramide
  OK = 2 : Call AVERTIR(mess(97,102,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
Return

$STATUT
Case BOUT
 When "2" : # Duplication
  If GBIDC3<>""
   CLECUR1 = GBIDC3
   Gosub RELIT From GOBJSUB
  Endif
 When "3" : # Génération
  Gosub RELIT From GOBJSUB
 When "5" : # Réorg
  Call REORG(CLECUR1)
  Gosub RELIT From GOBJSUB
Endcase
Return

$DEGRISE
$STYLE
Setmok [GYM] With 0
Return

$ANNULE
Call SUPTEXTRA("GACCPYM","DESTRA",[M]PYM,"") From ATEXTRA
Call SUPTEXTRA("GACCPYM","SHOTRA",[M]PYM,"") From ATEXTRA
Return

$AP_CHANGE
#Class[M] à éviter car $AP_CHANGE peut être appelé d'un utilitaire externe ACHANGE
#Call CHGTEXTRA("GACCPYM","DESTRA",[M]PYM,"",NCODE,"") From ATEXTRA
#Call CHGTEXTRA("GACCPYM","SHOTRA",[M]PYM,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GACCPYM","DESTRA",OCODE,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GACCPYM","SHOTRA",OCODE,"",NCODE,"") From ATEXTRA

#chgmt de cle PYRAMIDE alors MAJ des textes traduisibles pour les groupes associés à nouvel PYRAMIDE
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
Filter [GRY] Where PYM=NCODE
For [GRY]
  #Call CHGTEXTRA("GACCGRUPYM","DESTRA",[M]PYM,[F:GRY]GRU,NCODE,[F:GRY]GRU) From ATEXTRA
 #Call CHGTEXTRA("GACCGRUPYM","SHOTRA",[M]PYM,[F:GRY]GRU,NCODE,[F:GRY]GRU) From ATEXTRA
 Call CHGTEXTRA("GACCGRUPYM","DESTRA",OCODE,[F:GRY]GRU,NCODE,[F:GRY]GRU) From ATEXTRA
 Call CHGTEXTRA("GACCGRUPYM","SHOTRA",OCODE,[F:GRY]GRU,NCODE,[F:GRY]GRU) From ATEXTRA
Next
Filter [GRY]

Return

#################################################################################
## Variables diverses
#################################################################################
$DEFVAR
Local Char    PFIXG(1) , PFIXC(1)
Local Char    IMGDEP(15) , IMGGRP(15) , IMGCPT(15) , IMGJOK(15)
PFIXG  = "G"            : # Préfixe des groupes
PFIXC  = "C"            : # Préfixe des comptes
Read [ASB]ASB0 = func CATIMG;func DEFIMG(1)
IMGDEP = [F:ASB]NAMFIC : # Image groupe de départ
Read [ASB]ASB0 = func CATIMG;func DEFIMG(2)
IMGGRP = [F:ASB]NAMFIC : # Image groupes
Read [ASB]ASB0 = func CATIMG;func DEFIMG(3)
IMGCPT = [F:ASB]NAMFIC : # Image comptes
Read [ASB]ASB0 = func CATIMG;func DEFIMG(4)
IMGJOK = [F:ASB]NAMFIC : # Image avec jokers
Return

#################################################################################
## Chargement de la pyramide
#################################################################################
Subprog CHARGE_PYR(PLAN,PYRAM)
Value Char    PLAN
Value Char    PYRAM

Local Integer IGRP , RABG , OKPYR
Local Char    COMPTE(GLONGAC)
Local Char    GRPDEP(GLONGRY)

Gosub DEFVAR

If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
Effzo 15-30

OKPYR  = 1
nolign = 0

#
# Chargement de 2 tableaux:
# NBGRU : Liste des groupes et de leurs caractéristiques
# NBLNK : Liste des liens
#
# On force le niveau (LEV) et les rangs (PRNROW) de 10 en 10
#

Filter [GRY] Where PYM=PYRAM Order By Key CLE=LEV;PRNROW;GRU;LIN
[M]NBGRU = 0
[M]NBLNK = 0
NIV = 0
For [GRY]CLE(1)
 RANG = 0
 NIV += 10
 For [GRY]CLE(3)
  RANG += 10
  If [M]NBGRU>=dim([M]GRU)
   OKPYR = 0 : Break 2
  Endif
  [M]NBGRU += 1
  nolign = [M]NBGRU
  [M]GRU(nolign-1) = [F:GRY]GRU
  Call LECTEXTRA([M]DES(nolign-1),"GACCGRUPYM","DESTRA",PYRAM,[F:GRY]GRU) From ATEXTRA
  Call LECTEXTRA([M]SHO(nolign-1),"GACCGRUPYM","SHOTRA",PYRAM,[F:GRY]GRU) From ATEXTRA
  [M]LEV(nolign-1)    = NIV
  [M]PRNROW(nolign-1) = RANG
  [M]CLSCOD(nolign-1) = [F:GRY]CLSCOD
  [M]UOMDAC(nolign-1) = [F:GRY]UOMDAC
  [M]UOM(nolign-1)    = [F:GRY]UOM
  [M]BUDTRK(nolign-1) = [F:GRY]BUDTRK
  [M]DEFVAL(nolign-1) = [F:GRY]DEFVAL
  [M]TIMDSP(nolign-1) = [F:GRY]TIMDSP
  For [GRY]CLE
   If [M]NBLNK>=dim([M]GROUPE)
    OKPYR = 0 : Break 3
   Endif
   [M]NBLNK += 1
   nolign = [M]NBLNK
   [M]GROUPE(nolign-1) = [F:GRY]GRU
   [M]SBBGRU(nolign-1) = [F:GRY]SBBGRU
   [M]ACC(nolign-1)    = [F:GRY]ACC
  Next
 Next
Next
Filter [GRY]

#
# Premier groupe
#

If OKPYR
 Filter [GRY] Where PYM=PYRAM Order By Key CLE=LEV;GRU;LIN
 Read [GRY]CLE First
 Filter [GRY]
 If fstat<=2
  GRPDEP = [F:GRY]GRU
 Else
  End
 Endif
 Call CHARGE_GROUPE(GRPDEP)
Else
 Call MESSAGE(mess(124,102,1)) From GESECRAN : # Trop de groupes
 Effzo 30
 Grizo [M]DEPART
Endif
End

#################################################################################
## Chargement du groupe de départ
#################################################################################
Subprog CHARGE_GROUPE(GRPDEP)
Value Char GRPDEP

Local Integer IGRP , IGRU , IPAPA , NPAPA
Local Char    MESSA(250)
Local Char    PAPA(15)(1..2000)
Gosub DEFVAR

IGRU = find(GRPDEP,[M]GRU(0..[M]NBGRU-1))
If !IGRU : End : Endif

#
# Partie "visible" de la pyramide : Tableau NBCMP
#

Effzo 30
[M]DEPART = GRPDEP
[M]LIBDEP = [M]DES(IGRU-1)
[M]PARENT(0)   = ""
[M]KEYC(0)     = PFIXG+GRPDEP
[M]LIBSHORT(0) = GRPDEP
[M]LIBL(0)     = [M]DES(IGRU-1)
If IGRU=1
 [M]IMG(0)     = IMGDEP
Else
 [M]IMG(0)     = IMGGRP
Endif

NPAPA   = 1
PAPA(1) = GRPDEP
IPAPA   = 1
nolign  = 1

While IPAPA<=NPAPA
 For IGRP=0 To [M]NBLNK-1
  If [M]GROUPE(IGRP)=PAPA(IPAPA)
   If [M]SBBGRU(IGRP)<>""
    nolign += 1
    [M]PARENT(nolign-1)   = PFIXG+PAPA(IPAPA)
    [M]KEYC(nolign-1)     = PFIXG+[M]SBBGRU(IGRP)
    [M]LIBSHORT(nolign-1) = [M]SBBGRU(IGRP)
    [M]IMG(nolign-1)      = IMGGRP
    [M]LINLNK(nolign-1)   = IGRP
    IGRU = find([M]SBBGRU(IGRP),[M]GRU(0..[M]NBGRU-1))
    If IGRU
     [M]LINGRU(nolign-1) = IGRU-1
     [M]LIBL(nolign-1)   = [M]DES(IGRU-1)
     [M]ROW(nolign-1)    = [M]PRNROW(IGRU-1)
    Endif
    NPAPA += 1
    PAPA(NPAPA) = [M]SBBGRU(IGRP)
   Elsif [M]ACC(IGRP)<>""
    nolign += 1
    [M]PARENT(nolign-1)   = PFIXG+PAPA(IPAPA)
    [M]KEYC(nolign-1)     = PFIXC+func COMPTE([M]ACC(IGRP))
    [M]LIBSHORT(nolign-1) = [M]ACC(IGRP)
    If func JOKER([M]ACC(IGRP))
     [M]IMG(nolign-1)     = IMGJOK
    Else
     [M]IMG(nolign-1)     = IMGCPT
    Endif
    [M]LINLNK(nolign-1)   = IGRP
    [M]LINGRU(nolign-1)   = -1
    [M]ROW(nolign-1)      = 0
    If !func JOKER([M]ACC(IGRP))
     Call LECTEXTRA([M]LIBL(nolign-1),"GACCOUNT","DESTRA",[M]COA,[M]ACC(IGRP)) From ATEXTRA
    Endif
   Endif
   #CP
   If nolign>=dim([M]PARENT) : Break 2 : Endif
  Endif
 Next IGRP
 IPAPA += 1
Wend
[M]NBCMP = nolign
# Pyramide
MESSA = mess(50,103,1)-[M]PYM-":"-[M]DESTRA : # Pyramide
IGRU = find(GRPDEP,[M]GRU(0..[M]NBGRU-1))
If IGRU>1
 MESSA -= "("+mess(96,103,1)-[M]GRU(IGRU-1)-":"-[M]DES(IGRU-1)+")" : # Zoom à partir du groupe
Else
 MESSA -= "("+mess(95,103,1)+")" : # Complète
Endif
Chgtbk 30 With MESSA
Gosub AFFPYR
End

$AFFPYR
Sorta [M]NBCMP [M]NBCMP Order By [M]PARENT(indice),[M]ROW(indice),[M]KEYC(indice)
Affzo 30
Return

######################################################################################
## Changement de groupe de départ
######################################################################################
Subprog AM_DEPART(VALEUR)
Variable Char    VALEUR()
Local Integer K
If VALEUR=""
 VALEUR = [M]GRU(0)
Endif
K = find(VALEUR,[M]GRU(0..[M]NBGRU-1))
If !K
 GMESSAGE = mess(113,102,1) : # Groupe inexistant
 mkstat = 2 : End
Else
 [M]LIBDEP = [M]DES(K-1)
Endif
Call CHARGE_GROUPE(VALEUR)
End

Subprog AP_DEPART(VALEUR)
Variable Char    VALEUR()
mkstat=4
End

######################################################################################
## Initialisation de la classification CLSCOD pour le grp DEPART (=TOTAl par déf)   ##
######################################################################################
# 1ère classification du plan COA de la pyramide = 1ère valeur du tab des classes par
# défaut et si tab vide 1ère classification de législation classes du plan de la pym

Subprog AM_COA(VALEUR)
Variable Char    VALEUR()
#Initialisation de la classification
Filter [COA] Where COA=VALEUR
Read [COA] First
If !fstat
[M]LEGCLSINV = [F:COA]LEGCLS
If [F:COA]PFXNBR <> 0
 [M]CLSCOD=[F:COA]CLSCOD(0)
Else
 Filter [CLS] Where LEG=[M]LEGCLSINV
 Read [CLS] First
 If !fstat
  [M]CLSCOD=[F:CLS]CLSCOD(0)
 Endif
Endif
Endif
Filter [COA]
Filter [CLS]
End


##################################################################
## Traitement des modifications
##################################################################
Subprog MAJHIER(CODACT,NLIG,LIGFAT,RANGNIV,MESSAGE,CODRET)
Value    Char    CODACT
Value    Integer NLIG
Value    Integer LIGFAT
Value    Integer RANGNIV
Variable Char    MESSAGE
Variable Integer CODRET

Local Integer I , J , K , NB
Local Integer RANG , RG , NIV
Local Integer NPERE , NPAPA
Local Char    PERE(20)(1..100) , PAPA(20)(1..100)
Local Char    CLE(20)
Local Char    FATHER(20)

Gosub DEFVAR
Case CODACT
 When "M"
  If NLIG=1 : # On ne peut pas déplacer la racine!!
   Call MESSAGE(mess(104,102,1)) From GESECRAN : # Déplacement impossible
   End
  Endif

  If RANGNIV=0
   FATHER = [M]KEYC(LIGFAT-1)
   RANG   = 10
  Elsif RANGNIV>0
   FATHER = [M]PARENT(LIGFAT-1)
   RANG   = [M]ROW(LIGFAT-1)+10
  Else
   FATHER = [M]PARENT(LIGFAT-1)
   RANG   = [M]ROW(LIGFAT-1)
  Endif

  If left$(FATHER,len(PFIXG))=PFIXC : # Un papa ne pas être un compte
   Call MESSAGE(mess(105,102,1)) From GESECRAN : # Un compte ne peut pas en regrouper d'autres
   End
  Endif

  If [M]PYRREF<>0
   If right$(FATHER,2)<>[M]DEPART & left$(right$([M]KEYC(NLIG-1),2),len(FATHER)-1)<>right$(FATHER,2)
    Call MESSAGE(mess(42,113,1)-right$(FATHER,2)) From GESECRAN : # Le groupe doit commencer par
    End
   Endif
  Endif

  K = find(FATHER,[M]PARENT(0..[M]NBCMP-1))
  If K
   RG   = 0
   J    = 0
   While [M]PARENT(K-1)=FATHER
    RG += 10
    If RANG=RG
     RG += 10
    Endif
    J += 1
    If [M]LINGRU(K-1)>=0
     [M]ROW(K-1)               = RG
     [M]PRNROW([M]LINGRU(K-1)) = RG
    Else
     [M]ROW(K-1) = 0
    Endif
    K += 1
   Wend
  Endif
  IGRU = find(right$(FATHER,len(PFIXG)+1),[M]GRU(0..[M]NBGRU-1))
  NIV = [M]LEV(IGRU-1)+10 : # Niveau du papa + 10
  CLE = [M]KEYC(NLIG-1)
  [M]PARENT(NLIG-1) = FATHER
  [M]GROUPE([M]LINLNK(NLIG-1))  = right$(FATHER,len(PFIXG)+1)
  If [M]LINGRU(NLIG-1)>=0
   [M]ROW(NLIG-1)               = RANG
   [M]PRNROW([M]LINGRU(NLIG-1)) = RANG
   [M]LEV([M]LINGRU(NLIG-1))    = NIV
   #
   # Propagation du nouveau niveau vers les fistons...
   #
   NPAPA = 1
   PAPA(NPAPA) = [M]KEYC(NLIG-1)
   Repeat
    NIV += 10
    NPERE = 0
    For I=0 To [M]NBCMP-1
     If find([M]PARENT(I),PAPA(1..NPAPA))
      If [M]LINGRU(I)>=0
       [M]LEV([M]LINGRU(I)) = NIV
       NPERE += 1
       PERE(NPERE) = [M]KEYC(I)
      Endif
     Endif
    Next I
    NPAPA = NPERE
    For I=1 To NPAPA
     PAPA(I) = PERE(I)
    Next I
   Until NPAPA=0
  Else
   [M]ROW(NLIG-1) = 0
  Endif
  zonsui = "KEYC("+num$(NLIG-1)+")"
  Gosub AFFPYR
  [M]FLMOD = 1
  NLIG = find(CLE,[M]KEYC)
  Affzo KEYC(NLIG-1)
#  zonsui = "KEYC("+num$(NLIG-1)+")"
#  mkstat = 4
Endcase
End

######################################################################################
## Enregistrement de la pyramide
######################################################################################
Subprog VALPYR
Local Integer ILNK , IGRP , NB
Local Char    SOUGROUPE(GLONGRY) , COMPTE(GLONGAC)

Default Mask [GYM]
Call TEMPON("V") From GESECRAN
Sorta [M]NBLNK [M]NBLNK Order By [M]GROUPE(indice),[M]ACC(indice),[M]SBBGRU(indice)
Gosub MAJPYR
Call TEMPOFF From GESECRAN
End

$MAJPYR
#
# On efface tout et on récréé...
#
Delete [GRY] Where PYM=[M]PYM
If fstat=1
 GOK = -1 : GLOCK = "$GACCGRUPYM"-[M]PYM: Return
Endif
ILNK = 0
Raz [M]FLGRP
While ILNK<=[M]NBLNK-1
 IGRP = find([M]GROUPE(ILNK),[M]GRU(0..[M]NBGRU-1))-1
 If IGRP<0
  Call ERREUR(mess(114,102,1)-[M]GROUPE(ILNK)) From GESECRAN : # malaise dans la pyramide
  GOK = 0 : Break
 Endif
 NB = 0
 While ILNK<=[M]NBLNK-1 & [M]GROUPE(ILNK)=[M]GRU(IGRP)
  SOUGROUPE = [M]SBBGRU(ILNK)
  COMPTE    = [M]ACC(ILNK)
  If SOUGROUPE<>"" or COMPTE<>""
   [M]FLGRP(IGRP) = 1
   Gosub CRE_GROUPE
   If GOK<1 : Break 2 : Endif
  Endif
  ILNK += 1
 Wend
Wend
If GOK<1 : Return : Endif
# Texte et groupes sans liens
For IGRP=0 To [M]NBGRU-1
 Call MAJTEXTRA([M]DES(IGRP),"GACCGRUPYM","DESTRA",[M]PYM,[M]GRU(IGRP)) From ATEXTRA
 Call MAJTEXTRA([M]SHO(IGRP),"GACCGRUPYM","SHOTRA",[M]PYM,[M]GRU(IGRP)) From ATEXTRA
 If ![M]FLGRP(IGRP)
  NB = 0
  SOUGROUPE = ""
  COMPTE    = ""
  Gosub CRE_GROUPE
  If GOK<1 : Break : Endif
 Endif
Next IGRP

# Vérification de l'initialisation de la classification de DEPART
# si on a ajoute des grps ou cptes
# on a associé la classe au groupe TOTAL selon l'algo suivant :
# 1- la classe du 1er compte si n'existe pas,
# 2- la classe du 1er groupe, et si le groupe TOTAL est vide,
# 3- alors 1ère classe définie dans le plan de compte associé à la pyramide, ou à défaut
# 4- la 1ère classe liée à la législation (3 et 4 initialiser en amont ds $AM_COA

If GREP="C"
 If [M]ACC(1)<>""
  Filter [GAC] Where COA=[M]COA & ACC=[M]ACC(1)
  Read [GAC]GAC0 First
  [M]CLSCOD(0) = [F:GAC]CLSCOD
    Filter [GAC]
 Elsif [M]GRU(1)<>""
  [M]CLSCOD(0) = [M]CLSCOD(1)
 Endif
 Filter [GRY] Where PYM=[M]PYM & GRU=[M]GRU(0)
 Read [GRY]GRY4 First
 [F:GRY]CLSCOD = [M]CLSCOD(0)
 Rewrite[GRY]
 Filter [GRY]
Endif
Return

$CRE_GROUPE
NB += 1
Raz [F:GRY]
[F:GRY]PYM    = [M]PYM
[F:GRY]COA    = [M]COA
[F:GRY]GRU    = [M]GRU(IGRP)
[F:GRY]LEV    = [M]LEV(IGRP)
[F:GRY]PRNROW = [M]PRNROW(IGRP)
[F:GRY]UOMDAC = [M]UOMDAC(IGRP)
[F:GRY]UOM    = [M]UOM(IGRP)
[F:GRY]CLSCOD = [M]CLSCOD(IGRP)
[F:GRY]DEFVAL = [M]DEFVAL(IGRP)
[F:GRY]BUDTRK = [M]BUDTRK(IGRP)
[F:GRY]TIMDSP = [M]TIMDSP(IGRP)
[F:GRY]LIN    = NB
[F:GRY]SBBGRU = SOUGROUPE
[F:GRY]ACC    = COMPTE
Write [GRY]
If fstat
 GOK = 0 : Call FSTA("GRY") From GLOCK
Endif
Return

######################################################################################
## Etiquettes gestion pyramide
######################################################################################
Subprog IB_NBCMP
Gosub DEFVAR
If left$([M]KEYC(nolign-1),len(PFIXG))=PFIXC
 Raz GBOUT1,GBOUT2,GBOUT4,GBOUT5
 If func JOKER(ctrans(right$([M]KEYC(nolign-1),len(PFIXG)+1),"xyzw","*?!#"))
  Raz GBOUT6
 Else
  GBOUT6 = mess(35,102,1) : # Gestion des comptes
 Endif
Else
 If GREP="C"
  Raz GBOUT6 #pas de Groupes car en création de pyramides donc 1er groupe n'existe pas encore
 Else
  GBOUT6 = mess(28,135,1) : # Groupes
 Endif
Endif
If nolign=1
 Raz GBOUT3
Endif
[M]FLNOL = nolign
End

#
# Ajout d'un groupe
#

$DEBUT_GYMGRP
If [M:GYM]NBGRU>=dim([M:GYM]GRU) or [M:GYM]NBLNK>=dim([M:GYM]GROUPE)
 Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
 SAI = 0 : FIN = 1 : GSTATUT = GSTAFIN
Endif
[M:GYMR]GRPPERE = right$([M:GYM]KEYC(nolign-1),2)
Return

Subprog B1_NBCMP
If GSTATUT=GSTAOK
 Gosub DEFVAR
 Local Integer NOL , RANG , NIV , OKMES
 Local Char    GROUPE(GLONGRY) , MESSA(80)

 RANG = 10
 For NOL=0 To [M]NBCMP-1
  If [M]PARENT(NOL)=[M]KEYC(nolign-1)
   RANG = max(RANG,[M]ROW(NOL)+10)
  Endif
 Next NOL
 NOL = find(right$([M]KEYC(nolign-1),len(PFIXG)+1),[M]GRU(0..[M]NBGRU-1))-1
 NIV = [M]LEV(NOL)+10

 NOL = [M]NBGRU
 [M]NBGRU += 1
 [M]GRU(NOL)    = [M:GYMR]GROUPE
 [M]DES(NOL)    = [M:GYMR]DESTRA
 [M]SHO(NOL)    = [M:GYMR]SHOTRA
 [M]LEV(NOL)    = NIV
 [M]PRNROW(NOL) = RANG
 [M]CLSCOD(NOL) = [M:GYMR]CLSCOD
 [M]UOMDAC(NOL) = [M:GYMR]UOMDAC
 [M]UOM(NOL)    = [M:GYMR]UOM
 [M]DEFVAL(NOL) = [M:GYMR]DEFVAL
 [M]BUDTRK(NOL) = [M:GYMR]BUDTRK
 [M]TIMDSP(NOL) = [M:GYMR]TIMDSP

 NOL = [M]NBCMP
 [M]NBCMP += 1
 [M]PARENT(NOL)   = [M]KEYC(nolign-1)
 [M]KEYC(NOL)     = PFIXG+[M:GYMR]GROUPE
 [M]LIBSHORT(NOL) = [M:GYMR]GROUPE
 [M]IMG(NOL)      = IMGGRP
 [M]ROW(NOL)      = RANG
 [M]LINGRU(NOL)   = [M]NBGRU-1
 [M]LINLNK(NOL)   = [M]NBLNK
 [M]LIBL(NOL)     = [M:GYMR]DESTRA

 NOL = [M]NBLNK
 [M]NBLNK += 1
 [M]GROUPE(NOL) = right$([M]KEYC(nolign-1),len(PFIXG)+1)
 [M]SBBGRU(NOL) = [M:GYMR]GROUPE
 [M]ACC(NOL)    = ""

  #
  # Rattachement des comptes pour le portugal
  #

 If [M]PYRREF<>0
  OKMES = 0
  For NOL=0 To [M]NBLNK-1
   If left$([M]ACC(NOL),len([M:GYMR]GROUPE))=[M:GYMR]GROUPE
    [M]GROUPE(NOL) = [M:GYMR]GROUPE
    OKMES = 1 : #MESSA -= [M]ACC(NOL)
   Endif
  Next NOL
  For NOL=0 To [M]NBCMP-2
   If mid$([M]KEYC(NOL),2,len([M:GYMR]GROUPE))=[M:GYMR]GROUPE
    [M]PARENT(NOL) = PFIXG+[M:GYMR]GROUPE
    OKMES = 1 : MESSA -= right$([M]KEYC(NOL),2)
   Endif
  Next NOL
  If OKMES
   Call MESSAGE([M:GYMR]GROUPE-":"-mess(109,103,1)+"\"+MESSA) From GESECRAN : # Des comptes ont été ajouté sur ce groupe
  Endif
 Endif


 Gosub AFFPYR
 [M]FLMOD = 1
 mkstat = 4
Endif
End

#
# Ajout d'un compte
#

$DEBUT_GYMCPT
If [M:GYM]NBLNK>=dim([M:GYM]GROUPE)
 Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
 SAI = 0 : FIN = 1 : GSTATUT = GSTAFIN
Endif
[M:GYMC]GROUPE = right$([M:GYM]KEYC(nolign-1),2)
Return

Subprog B2_NBCMP
If GSTATUT=GSTAOK
 Gosub DEFVAR
 Local Integer NOL

 NOL = [M]NBCMP
 [M]NBCMP += 1
 [M]PARENT(NOL)   = [M]KEYC(nolign-1)
 [M]KEYC(NOL)     = PFIXC+func COMPTE([M:GYMC]COMPTE)
 [M]LIBSHORT(NOL) = [M:GYMC]COMPTE
 If func JOKER([M:GYMC]COMPTE)
  [M]IMG(NOL)     = IMGJOK
 Else
  [M]IMG(NOL)     = IMGCPT
 Endif
 [M]ROW(NOL)      = 0
 [M]LINGRU(NOL)   = -1
 [M]LINLNK(NOL)   = [M]NBLNK
 If !func JOKER([M:GYMC]COMPTE)
  Call LECTEXTRA([M]LIBL(NOL),"GACCOUNT","DESTRA",[M]COA,[M:GYMC]COMPTE) From ATEXTRA
 Endif

 NOL = [M]NBLNK
 [M]NBLNK += 1
 [M]GROUPE(NOL) = right$([M]KEYC(nolign-1),len(PFIXG)+1)
 [M]SBBGRU(NOL) = ""
 [M]ACC(NOL)    = [M:GYMC]COMPTE

 Gosub AFFPYR
 [M]FLMOD = 1
 mkstat = 4
Endif
End

#
# Suppression d'une branche
#

Subprog B3_NBCMP
Gosub DEFVAR
Local Integer IPAPA , NPAPA , IGRU , ILNK , OKREA , OKMES
Local Char    PAPA(20)(1..300) , CPTSUP(20)
Local Char    GRPERE(GLONGRY)(1..300)
Local Char    MESSA(80)
#
# 1) On vire du tableau d'affichage (en pointant les pères)
#
OKMES = 0
If left$([M]KEYC(nolign-1),len(PFIXG))=PFIXG
 NPAPA = 1
 PAPA(NPAPA) = [M]KEYC(nolign-1)
Else
 CPTSUP = right$([M]KEYC(nolign-1),len(PFIXG)+1)
Endif
Dela nolign-1,1,[M]NBCMP [M]NBCMP
[M]NBCMP -= 1
IPAPA = 1
While IPAPA<=NPAPA
 I = 0
 While I<=[M]NBCMP-1
  If [M]PARENT(I)=PAPA(IPAPA)
   If left$([M]KEYC(I),len(PFIXG))=PFIXG
    NPAPA += 1
    PAPA(NPAPA) = [M]KEYC(I)
   Endif
   If [M]PYRREF<>0 & left$([M]KEYC(I),len(PFIXG))=PFIXC
    OKREA = 0
    For L=len(PAPA(1))-2 To 1 Step -1
     K = find(seg$([M]KEYC(I),2,L+1),[M]GRU(0..[M]NBGRU-1))
     If K
      [M]PARENT(I) = PFIXG+[M]GRU(K-1)
      OKREA = 1 : OKMES = 1 : MESSA -= right$([M]KEYC(I),2)
     Endif
    Next L
    If OKREA
     I += 1
    Else
     Dela I,1,[M]NBCMP [M]NBCMP
     [M]NBCMP -= 1
    Endif
   Else
    Dela I,1,[M]NBCMP [M]NBCMP
    [M]NBCMP -= 1
   Endif
  Else
   I += 1
  Endif
 Wend
 IPAPA += 1
Wend
#
# 2) On vire les groupes
#
For IPAPA=1 To NPAPA
 GRPERE(IPAPA) = right$(PAPA(IPAPA),len(PFIXG)+1)
 IGRU = find(GRPERE(IPAPA),[M]GRU(0..[M]NBGRU-1))-1
 If IGRU>=0
  Dela IGRU,1,[M]NBGRU [M]NBGRU
  [M]NBGRU -= 1
  For I=0 To [M]NBCMP-1
   If [M]LINGRU(I)>=IGRU
    [M]LINGRU(I) -= 1
   Endif
  Next I
 Endif
Next IPAPA
#
# 3) On vire les liens obsolètes
#
ILNK = 0
While ILNK<=[M]NBLNK-1
 If find([M]SBBGRU(ILNK),GRPERE(1..NPAPA)) or find([M]GROUPE(ILNK),GRPERE(1..NPAPA))
&   or (CPTSUP<>"" & func COMPTE([M]ACC(ILNK))=CPTSUP)
  Dela ILNK,1,[M]NBLNK [M]NBLNK
  [M]NBLNK -= 1
  For I=0 To [M]NBCMP-1
   If [M]LINLNK(I)>=ILNK
    [M]LINLNK(I) -= 1
   Endif
  Next I
 Else
  ILNK += 1
 Endif
Wend
#
# 4) On réaffiche le tout
#
Gosub AFFPYR
If OKMES
 Call MESSAGE(right$(PAPA(1),2)-":"-mess(110,103,1)+"\"+MESSA) From GESECRAN : # Des comptes ont été réaffectés
Endif
[M]FLMOD = 1
mkstat = 4
End

#
# Modification groupe
#

$DEBUT_GYMMOD : # (Action GYMMOD)
Local Char    GROUPE(GLONGRY)
Local Integer IGRU
Gosub DEFVAR
GROUPE = right$([M:GYM]KEYC([M:GYM]FLNOL-1),len(PFIXG)+1)
IGRU = find(GROUPE,[M:GYM]GRU(0..[M:GYM]NBGRU-1))-1
[M:GYMR]GROUPE = GROUPE
[M:GYMR]DESTRA = [M:GYM]DES(IGRU)
[M:GYMR]SHOTRA = [M:GYM]SHO(IGRU)
[M:GYMR]CLSCOD = [M:GYM]CLSCOD(IGRU)
[M:GYMR]UOMDAC = [M:GYM]UOMDAC(IGRU)
[M:GYMR]UOM    = [M:GYM]UOM(IGRU)
[M:GYMR]DEFVAL = [M:GYM]DEFVAL(IGRU)
[M:GYMR]BUDTRK = [M:GYM]BUDTRK(IGRU)
[M:GYMR]TIMDSP = [M:GYM]TIMDSP(IGRU)
Grizo GROUPE
Affzo
Return

Subprog B4_NBCMP
If GSTATUT=GSTAOK : # (Le bouton)
 Local Integer I , IGRU
 Gosub DEFVAR
 IGRU = find([M:GYMR]GROUPE,[M]GRU(0..[M]NBGRU-1))-1
 [M:GYM]DES(IGRU)    = [M:GYMR]DESTRA
 [M:GYM]SHO(IGRU)    = [M:GYMR]SHOTRA
 [M:GYM]CLSCOD(IGRU) = [M:GYMR]CLSCOD
 [M:GYM]UOMDAC(IGRU) = [M:GYMR]UOMDAC
 [M:GYM]UOM(IGRU)    = [M:GYMR]UOM
 [M:GYM]DEFVAL(IGRU) = [M:GYMR]DEFVAL
 [M:GYM]BUDTRK(IGRU) = [M:GYMR]BUDTRK
 [M:GYM]TIMDSP(IGRU) = [M:GYMR]TIMDSP
 I = find(PFIXG+[M:GYMR]GROUPE,[M]KEYC(0..[M]NBCMP-1))
 If I
  [M]LIBL(I-1) = [M:GYMR]DESTRA
  Affzo LIBL(I-1)
 Endif
Endif
End

#
# Zoom
#

Subprog B5_NBCMP
Gosub DEFVAR
Local Integer ILNK
Local Char    GROUPE(20)
If nolign=1
 ILNK = find(right$([M]KEYC(nolign-1),len(PFIXG)+1),[M]SBBGRU(0..[M]NBLNK))-1
 If ILNK>=0
  GROUPE = [M]GROUPE(ILNK)
 Endif
Else
 GROUPE = right$([M]KEYC(nolign-1),len(PFIXG)+1)
Endif
Call CHARGE_GROUPE(GROUPE)
End

#
# Tunnel
#

Subprog B6_NBCMP
Local Char OBJET(GLONAOB) , CLE1(30) , CLE2(30)
Gosub DEFVAR
If left$([M]KEYC(nolign-1),len(PFIXG))=PFIXC
 OBJET = "GAC"
 CLE1  = right$([M]KEYC(nolign-1),len(PFIXG)+1)
 CLE2  = [M]COA
Else
 OBJET = "GRY"
 CLE1  = right$([M]KEYC(nolign-1),len(PFIXG)+1)
 CLE2  = [M]PYM
Endif
Call OBJET(OBJET,CLE1,CLE2) From GOBJET
End


######################################################################################
## Ecrans divers
######################################################################################
#
# Contrôle création d'un compte (GYMCPT)
#

Subprog C_COMPTE(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
If find(VALEUR,[M:GYM]ACC(0..[M]NBLNK-1))
 #...-: - déjà présent dans la pyramide
 GMESSAGE = VALEUR-":"- mess(101,103,1)
 mkstat = 2 : End
Endif
If !func JOKER(VALEUR)
 Read [GAC]GAC0 = [M]COA;VALEUR
 If fstat
  GMESSAGE = mess(44,102,1) : # Compte inexistant
  mkstat = 2 : End
 Endif
Endif
If [M:GYM]PYRREF<>0 & left$(VALEUR,len([M:GYMC]GROUPE))<>[M:GYMC]GROUPE
 GMESSAGE = mess(41,113,1)-[M:GYMC]GROUPE : # Le compte doit commencer par
 mkstat = 2
 End
Endif
End

#
# Contrôle création d'un groupe (GYMGRP)
#

Subprog AV_GROUPE(VALEUR)
Variable Char VALEUR()
Call LECTURE("COA",[M]COA,"") From CONTOBJ
If [F:COA]ANATRK<>2
 Effzo UOMDAC,UOM,DEFVAL,BUDTRK,TIMDSP
 Grizo UOMDAC,UOM,DEFVAL,BUDTRK,TIMDSP
Else
 Actzo UOMDAC,UOM,DEFVAL,BUDTRK,TIMDSP
Endif
End

Subprog C_GROUPE(VALEUR)
Variable Char VALEUR()
VALEUR = toupper(VALEUR)
If find(VALEUR,[M:GYM]GRU(0..[M:GYM]NBGRU-1))
 #...-: - déjà présent dans la pyramide
 GMESSAGE = VALEUR-":"- mess(101,103,1)
 mkstat = 2 : End
Endif
If [M:GYM]PYRREF<>0 & left$(VALEUR,len([M:GYMR]GRPPERE))<>[M:GYMR]GRPPERE
 GMESSAGE = mess(42,113,1)-[M:GYMR]GRPPERE : # Le groupe doit commencer par
 mkstat = 2
 End
Endif
End

Subprog C_CLSCOD(VALEUR)
Variable Char VALEUR
Call LECTURE("COA",[M]COA,"") From CONTOBJ
Read [CLS]CLS0 = [F:COA]LEGCLS;VALEUR
If [F:CLS]TYP=3
 GMESSAGE = mess(5,113,1) : # Classe inutilisée
 mkstat = 2 : End
Endif
End

Subprog C_UOMDAC(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 Effzo UOM,DEFVAL
 Grizo UOM,DEFVAL
Else
 Actzo UOM,DEFVAL
Endif
End

Subprog C_BUDTRK(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 Effzo TIMDSP
 Grizo TIMDSP
Else
 Actzo TIMDSP
Endif
End

######################################################################################
## Fonctions
######################################################################################
Funprog COMPTE(CHAINE)
Value Char CHAINE
End ctrans(CHAINE,"*?!#","xyzw")

Funprog JOKER(CHAINE)
Value Char CHAINE
End instr(1,CHAINE,"*") or instr(1,CHAINE,"?") or instr(1,CHAINE,"!") or instr(1,CHAINE,"#")


######################################################################################
## Réorg pyramide Portugal
######################################################################################
Subprog REORG(PYRAM)
Value Char PYRAM

If clalev([F:GYM])=0 : Local File GACCPYM    [GYM] : Endif
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif

Local Integer MAXGROU : MAXGROU = 5000
Local Integer NBGROUPE
Local Char    TBGROUPE(GLONGRY)(1..MAXGROU)
Local Integer LINGROUPE(1..MAXGROU)
Local Integer K , L , G , RACINE , NIVEAU , OKGRP

Read [GYM]GYM0 = PYRAM
If fstat : End : Endif
Call TEMPON("O") From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR1
Call TEMPOFF From GESECRAN
End

$TR1
GOK = 1
Trbegin [GRY]
 #
 # Chargement
 #
 NBGROUPE = 0
 RACINE   = 0
 NIVEAU   = 9999
 For [GRY]GRY0(2) Where PYM=PYRAM
  NBGROUPE += 1
  TBGROUPE(NBGROUPE)  = [F:GRY]GRU
  LINGROUPE(NBGROUPE) = 0
  If [F:GRY]LEV<NIVEAU
   NIVEAU = [F:GRY]LEV
   RACINE = NBGROUPE
  Endif
 Next
 #
 # Ménage
 #
 For K=1 To NBGROUPE
  Filter [GRY] Where PYM=PYRAM & GRU=TBGROUPE(K)
  Read [GRY]GRY0 First
  Filter [GRY]
  [F:GRY]LIN = 1
  [F:GRY]SBBGRU = ""
  [F:GRY]ACC    = ""
  Rewrite [GRY]
  If fstat
   GOK = 0 : Call FSTA("GRY") From GLOCK : Break
  Endif
  Delete [GRY] Where PYM=PYRAM & GRU=TBGROUPE(K) & LIN>1
 Next K
 If GOK<1 : Goto ROLL_TR1 : Endif
 #
 # Reconstruction des groupes
 #
 For G=1 To NBGROUPE
  If G<>RACINE
   OKGRP = 0
   For L=len(TBGROUPE(G))-1 To 1 Step -1
    K = find(left$(TBGROUPE(G),L),TBGROUPE(1..NBGROUPE))
    If K
     Gosub SET_GRP
     If GOK<1 : Break 2 : Endif
     OKGRP = 1 : Break
    Endif
   Next L
   If !OKGRP
    K = RACINE : Gosub SET_GRP
    If GOK<1 : Break : Endif
   Endif
  Endif
 Next G
 If GOK<1 : Goto ROLL_TR1 : Endif
 #
 # Recalcul des niveaux
 #
 For G=1 To NBGROUPE
  NIVEAU = 10
  If G<>RACINE
   Read [GRY]GRY0 = PYRAM;TBGROUPE(G);1
   Repeat
    NIVEAU += 10
    Read [GRY]GRY2 = PYRAM;[F:GRY]GRU
   Until fstat>2 or NIVEAU>1000 or [F:GRY]GRU=TBGROUPE(RACINE)
  Endif
  Read [GRY]GRY0 = PYRAM;TBGROUPE(G);1
  [F:GRY]LEV = NIVEAU
  Rewrite [GRY]
  If fstat
   GOK = 0 : Call FSTA("GRY") From GLOCK : Break
  Endif
 Next G
 If GOK<1 : Goto ROLL_TR1 : Endif
 #
 # Reconstruction des comptes
 #
 For [GAC]GAC0 Where COA=[F:GYM]COA
  OKGRP = 0
  For L=len([F:GAC]ACC) To 1 Step -1
   K = find(left$([F:GAC]ACC,L),TBGROUPE(1..NBGROUPE))
   If K
    Gosub SET_ACC
    If GOK<1 : Break 2 : Endif
    OKGRP = 1 : Break
   Endif
  Next L
  If !OKGRP
   K = RACINE : Gosub SET_ACC
   If GOK<1 : Break : Endif
  Endif
 Next
 If GOK<1 : Goto ROLL_TR1 : Endif
 #
 # Liens
 #
Commit
If GOK=1
 Call PYRAMPRT(PYRAM,[F:GYM]COA,nomap) From LIENPYRACC
 Call PYRAMLIK(PYRAM,[F:GYM]COA,nomap) From LIENPYRACC
Endif
Return

$ROLL_TR1
Rollback
Return

$SET_GRP
Read [GRY]GRY0 = PYRAM;TBGROUPE(K);1
If LINGROUPE(K)=0
 [F:GRY]SBBGRU = TBGROUPE(G)
 Rewrite [GRY]
Else
 [F:GRY]LIN    = LINGROUPE(K)+1
 [F:GRY]SBBGRU = TBGROUPE(G)
 [F:GRY]ACC    = ""
 Write [GRY]
Endif
If fstat
 GOK = 0 : Call FSTA("GRY") From GLOCK : Return
Endif
LINGROUPE(K) += 1
Return

$SET_ACC
Read [GRY]GRY0 = PYRAM;TBGROUPE(K);1
If LINGROUPE(K)=0
 [F:GRY]ACC = [F:GAC]ACC
 Rewrite [GRY]
Else
 [F:GRY]LIN    = LINGROUPE(K)+1
 [F:GRY]SBBGRU = ""
 [F:GRY]ACC    = [F:GAC]ACC
 Write [GRY]
Endif
If fstat
 GOK = 0 : Call FSTA("GRY") From GLOCK : Return
Endif
LINGROUPE(K) += 1
Return
