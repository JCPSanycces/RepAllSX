#<AdxTL>@(#)12.0.0.0 $Revision$
#############################################################################################################
#    Selection des livrables 
#    Appel depuis la gestion des livrables ou des kits
#
#    en paramètre le livrable a ne pas afficher  --- Param (1)
#                 et l option 1 : pour les codes act fonctionnel ---- param (2)
#                             2: pour les codes de dimension
#                             3: pour les paramètres
#                 et le type produit ---- param (3)
#    si OK, on recupere les valeurs des codes act de ce livrable selectionné pour re init screen ADLV2 ou ADLV5
#    si OK, on recupere les valeurs des param de ce livrable selectionné pour re init screen ADLV3
#
#
# Selection des paramètres dans ADOPAR on ne peut utiliser le trt ADOVAL  
# car le superviseur teste des valeurs dans ecran notamment chapitre ET NOUs C'est à la ligne
#############################################################################################################
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "OK"         : Gosub OK
 When "FIN"        : Gosub FIN
 When "SEL_TABLE"  : Gosub SEL_TABLE
 When "TITRE"      : Gosub INTIT

Endcase
Return

#############################################################################################################
#
#############################################################################################################
$OUVRE
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
# on ouvre adelver pour ne pas casser les boucles dans SUBADLV
#--------------------------------------------------------------#
Local File ADELIVER  [ADLVB]
Local File ADELIVERD [ADLDB]
Local File ADELIVERP [ADLPB]

If clalev([F:ACV])=0 :  Local File ACTIV   [ACV] : Endif
If clalev([F:ADA])=0 :  Local File ADOSACT [ADA] : Endif

If clalev([F:ADP])=0  : Local File ADOPAR   [ADP] : Endif
If clalev([F:ADW])=0  : Local File ADOVAL   [ADW]  : Endif



Local Mask ASELADLV [ASADLV]
#----- variables globales -----#
Global Shortint GSAVNOLIGN : GSAVNOLIGN=nolign
Global Integer GMAXLIG
GMAXLIG = 200

If PARAM (2) = "K"
    If PARAM (3) <> ""
        #'fct impossible'
        GMESSAGE = mess(127,100,1)
        FIN  = 1
    Endif
Else
    If PARAM (1)= "" 
        #'fct impossible'
        GMESSAGE = mess(127,100,1)
        FIN  = 1
    Elsif PARAM (2) <> "1" and PARAM (2) <> "2" and PARAM (2) <> "3" and PARAM (2) <> "11" and PARAM (2) <> "22" and PARAM (2) <> "33" 
        #'fct impossible'
        GMESSAGE = mess(127,100,1)
        FIN  = 1
    Elsif PARAM (3) = ""
        #'fct impossible'
        GMESSAGE = mess(127,100,1)
        FIN  = 1
    Endif
Endif

# si ecran adlv2 adlv3 adlv5 ne sont pas en ligne on bloque
# sinon plantage.
If clalev([M:ADLV2])=0
    #'fct impossible'
    GMESSAGE = mess(127,100,1)
    FIN  = 1
Elsif clalev([M:ADLV3])=0
    #'fct impossible'
    GMESSAGE = mess(127,100,1)
    FIN  = 1
Elsif clalev([M:ADLV5])=0
    #'fct impossible'
    GMESSAGE = mess(127,100,1)
    FIN  = 1
Endif

Return

#############################################################################################################
$INTIT

If PARAM (2) = "K"
    TIT = mess (71,7999,1)
Elsif PARAM (2) <> "1" and PARAM (2) <> "2" and PARAM (2) <> "3" 
    TIT = mess (73,7999,1)
Else
    TIT = mess (72,7999,1)
Endif
Return

#############################################################################################################
$DEBUT
#--------------------------------------------------------------#
# debut affichage fenetre                                      #
#--------------------------------------------------------------#
Raz [M:ASADLV]
[M:ASADLV]NBLIG = 0
WIND = 0

Local Integer WTYP
If PARAM (2) = "1" or PARAM (2) = "2" or PARAM (2) = "3"
    # typ = 1 2 et 3  pour livrable
    WTYP = 1
Else
    # typ = 11 22 et 33 pour les kits
    # param = k juste pour affichage des kits depuis les livrables
    WTYP = 2
Endif

If PARAM (2) = "K"
    Filter [ADLVB] Where ADLVTYP = WTYP and !pat (COD,"*~*")
Else
    Filter [ADLVB] Where COD <> PARAM (1) and PDT = val (PARAM (3)) and ADLVTYP = WTYP and !pat (COD,"*~*")
Endif

For [ADLVB]
    [M:ASADLV]COD(WIND)     = [F:ADLVB]COD
    [M:ASADLV]ADLVTYP(WIND) = [F:ADLVB]ADLVTYP
    Call LECTEXTRA([M:ASADLV]DLVDES(WIND),"ADELIVER","DLVDES",[F:ADLVB]COD,"") From ATEXTRA
    [M:ASADLV]PDT (WIND)    = [F:ADLVB]PDT
    [M:ASADLV]COMMENT(WIND) = [F:ADLVB]COMMENT
    [M:ASADLV]RPBUSR(WIND)  = [F:ADLVB]RPBUSR

    [M:ASADLV]NBLIG += 1
    WIND +=1
    If [M:ASADLV]NBLIG = GMAXLIG
       # 'tableau plein'
        GMESSAGE=mess (26,100,1)
        Call MESSAGE(GMESSAGE) From GESECRAN
        Raz GMESSAGE
        Break 
    Endif
Next
Filter [ADLVB]
    

Affzo [M:ASADLV]
Return

#############################################################################################################
$OK
Local Integer WINDICE
WINDICE = find(2,[M:ASADLV]FLGSEL(0..[M:ASADLV]NBLIG-1))
If WINDICE = 0
    Goto FIN_OK
Endif

Local Integer WIND
WIND  = 0
Local Integer WRETOUR
Local Char WVALPARAM(250)
Local Char WLEGPARAM (250)


# là il faut donc charge en fct option les valeurs des codes act 
# ou les param
If PARAM (2) = "1" or PARAM (2) = "11"
    If [M:ADLV2]NBRACT<>0
        #------------------------------------------------------------------------#
        # on recharge  les valeurs à partir du livrable ou kit selectionné
        #------------------------------------------------------------------------#
        # lecture dans livrable pris en compte
        Read [ADLVB]ADLV0 = [M:ASADLV]COD (WINDICE-1)
        If fstat = 0
            For WIND = 0 To [M:ADLV2]NBRACT
                  Read [ADLDB]ADLD0 = [M:ASADLV]COD (WINDICE-1);[M:ADLV2]CODACT (WIND)
                  If fstat = 0
                     If [F:ADLDB]TYPACV <> 2
                         # on relit le code activité au cas ou aurait changé de def
                         # dans ce cas on ne change pas la valeur init
                         WRETOUR = 0
                         Call READ_ACTIV ([F:ADLDB]CODACT,"F",WRETOUR) From SUBADLV
                         If WRETOUR = 0
                                 [M:ADLV2]FLGACT(WIND)   = [F:ADLDB]FLGACT
                                 [M:ADLV2]LICACT(WIND)   = [F:ADLDB]LICACT
                                 [M:ADLV2]NOTAVAACT(WIND)= [F:ADLDB]NOTAVAACT
                         Endif
                     Endif
                  Endif
            Next WIND
        Else
            Goto FIN_OK
        Endif
    Endif
Elsif PARAM (2) = "2" or PARAM (2) = "22"
        #------------------------------------------------------------------------#
        # on recharge  les valeurs à partir du livrable selectionné
        #------------------------------------------------------------------------#
        # lecture dans livrable pris en compte sur les mêmes codes
        # si code existe on ecrase valeur et on ajoute si n existe pas dans adlv5
        Read [ADLVB]ADLV0 = [M:ASADLV]COD (WINDICE-1)
        If fstat = 0
            Raz GMESSAGE
            Filter [ADLDB] Where COD = [M:ASADLV]COD (WINDICE-1) and TYPACV = 2
            For [ADLDB]
                    WIND = find([F:ADLDB]CODACT,[M:ADLV5]CODDIM(0..[M:ADLV5]NBRDIM-1))
                    If WIND <> 0
                        # on verif existe tjs et correct
                        # sinon on ne change pas la valuer
                         WRETOUR = 0
                         Call READ_ACTIV ([F:ADLDB]CODACT,"D",WRETOUR) From SUBADLV
                         If WRETOUR = 0
                                [M:ADLV5]DIMACT(WIND-1)= [F:ADLDB]DIMACT
                         Endif
                     Else
                        # on ajoute le code mais avant on doit verifier que le code n est pas dans ADLV2 
                        # au cas ou
                        WIND = find([F:ADLDB]CODACT,[M:ADLV2]CODACT(0..[M:ADLV2]NBRACT-1))
                        If WIND  = 0
                               If [M:ADLV5]NBRDIM = GMAXDIMACT
                                   # 'tableau plein'
                                    GMESSAGE=mess (26,100,1)+"\[M:ADLV5]NBRDIM"
                                Else
                                   # on doit aussi verif que le typ et la dep sont corrects
                                    WRETOUR = 0
                                    Call READ_ACTIV ([F:ADLDB]CODACT,"D",WRETOUR) From SUBADLV
                                    If WRETOUR = 0
                                            WIND = [M:ADLV5]NBRDIM
                                            # ok on ajoute dans le tableau adlv5
                                            [M:ADLV5]CODDIM(WIND)     = [F:ADLDB]CODACT
                                            [M:ADLV5]DIMACT(WIND)     = [F:ADLDB]DIMACT
                                            #
                                            Call CHARGE_DEFAULT_DIM ([F:ADLDB]CODACT,WIND) From SUBADLV
                                            [M:ADLV5]NBRDIM += 1
                                    Endif
                                Endif
                        Endif
                    Endif
            Next
            Filter [ADLDB]
            If GMESSAGE <> ""
                Call MESSAGE(GMESSAGE) From GESECRAN
            Endif
            Raz GMESSAGE
        Else
            Goto FIN_OK
        Endif
Elsif PARAM (2) = "3" or PARAM (2) = "33"
        #------------------------------------------------------------------------#
        # on recharge  les valeurs à partir du livrable selectionné
        #------------------------------------------------------------------------#
        # lecture dans livrable pris en compte sur les mêmes codes
        # si code existe on ecrase valeur et on ajoute si n existe pas dans adlv3
        Read [ADLVB]ADLV0 = [M:ASADLV]COD (WINDICE-1)
        If fstat = 0
            Raz GMESSAGE
            Filter [ADLPB] Where COD = [M:ASADLV]COD (WINDICE-1) 
            For [ADLPB]
                    WLEGPARAM= [F:ADLPB]PARAM+"~"+[F:ADLPB]CLEPARAM
                    WIND = find(WLEGPARAM,[M:ADLV3]LEGPARAM(0..[M:ADLV3]NBRSET-1))
                    If WIND <> 0
                        # on verif existe tjs et correct
                        # sinon on ne change pas la valeur
                         WRETOUR = 0
                         Call READ_ADOPAR ([F:ADLPB]PARAM,[F:ADLPB]TYPPARAM,WRETOUR) From SUBADLV
                         If WRETOUR = 0
                                [M:ADLV3]VALPARAM (WIND-1)= [F:ADLPB]VALPARAM
                                [M:ADLV3]VALSAI   (WIND-1)= [F:ADLPB]VALPARAM
                                Call CHARGE([M:ADLV3]VALSAI(WIND-1),[M:ADLV3]TYP(WIND-1),[M:ADLV3]NOLIB(WIND-1),[M:ADLV3]LONG(WIND-1),[M:ADLV3]VALPARAM(WIND-1)) From FMTVAR
                         Endif
                     Else
                        # on ajoute le code mais avant on doit verifier sur la leg
                        # la leg doit etre defini dans le livrable 
                        If [F:ADLPB]CLEPARAM = ""
                            WIND = 1
                        Else
                            WIND = find([F:ADLPB]CLEPARAM,[M:ADLV4]DOSLEG(0..[M:ADLV4]NBRLEG-1))
                        Endif
                        If WIND  <> 0
                                If [M:ADLV3]NBRSET = GMAXPARAM
                                    # 'tableau plein'
                                    GMESSAGE=mess (26,100,1)+"\[M:ADLV3]NBRSET"
                                Else
                                    # on doit aussi verif que le typ est tjs correct
                                    WRETOUR = 0
                                    Call READ_ADOPAR ([F:ADLPB]PARAM,[F:ADLPB]TYPPARAM,WRETOUR) From SUBADLV
                                    If WRETOUR = 0
                                            # attention on doit verifier que le niveau de def est correct
                                            # si pas le cas on ne prend pas
                                            If [F:ADP]NIVDEF = 1 and [F:ADLPB]CLEPARAM <> ""

                                            Else
                                                # on peut alors prendre la valeur
                                                WIND = [M:ADLV3]NBRSET
                                                # ok on ajoute dans le tableau adlv3
                                                [M:ADLV3]PARAM(WIND) = [F:ADLPB]PARAM
                                                Call CHARGE_DEFAULT_PARAM ([F:ADLPB]PARAM,[F:ADLPB]VALPARAM,[F:ADLPB]CLEPARAM,WIND) From SUBADLV
                                                [M:ADLV3]NBRSET += 1
                                            Endif
                                    Endif
                                Endif
                        Endif
                    Endif
            Next
            Filter [ADLPB]
            If GMESSAGE <> ""
                Call MESSAGE(GMESSAGE) From GESECRAN
            Endif
            Raz GMESSAGE
        Else
            Goto FIN_OK
        Endif
Elsif PARAM (2) = "K" 
        #----------------------------#
        # on charge  la valeur du kit
        #----------------------------#
        Read [ADLVB]ADLV0 = [M:ASADLV]COD (WINDICE-1)
        If fstat = 0
                If [F:ADLVB]ADLVTYP = 2
                    PARAM (1) = [M:ASADLV]COD (WINDICE-1) 
                Endif
        Endif
Else
    Goto FIN_OK
Endif

nolign=GSAVNOLIGN
status=0
If PARAM (2) = "1" or PARAM (2) = "11"
    If [M:ADLV2]NBRACT<>0
        Affzo [M:ADLV2]5
    Endif
Elsif PARAM (2) = "2" or PARAM (2) = "22"
    If [M:ADLV5]NBRDIM <> 0
        Affzo [M:ADLV5]5
    Endif
Elsif PARAM (2) = "3" or PARAM (2) = "33"
    If [M:ADLV3]NBRSET <> 0
        Affzo [M:ADLV3]5
    Endif
Endif

# pour degriser bouton enreg
# a avoir a faire uniquement si on a changé quelquechose
mkstat=4 


$FIN_OK
nolign=GSAVNOLIGN
FIN=1
Return

#############################################################################################################
$FIN
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
nolign=GSAVNOLIGN
#-----------#
# Globales   #
#-----------#
If dim(GSAVNOLIGN)>0
    Kill GSAVNOLIGN
Endif
Close Local File
Return



#############################################################################################################
$SEL_TABLE
Case TABLE
 When "SELPARADLV"
  OBJET = "ADP"
  ORDRE = "PARAM"
  CRITERE = "MODIF=2"
Endcase
Return

$RIEN
Resume
#############################################################################################################
##     Etiquette écran ASELADLV
#############################################################################################################
Subprog AM_FLGSEL(VALEUR)
Variable Integer VALEUR

# une seule selection à la fois
Local Integer WINDICE
If VALEUR = 2
    WINDICE = find(2,[M:ASADLV]FLGSEL(0..[M:ASADLV]NBLIG-1))
    If WINDICE  <> 0 
        [M:ASADLV]FLGSEL (WINDICE-1) = 1
        Affzo [M:ASADLV]FLGSEL (WINDICE-1)
    Endif
Endif

End


