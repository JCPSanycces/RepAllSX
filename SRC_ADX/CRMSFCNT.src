#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################################
# Subprogram for Salesforce to create a new customer with contacts in X3
####################################################################################################

Subprog READCONTACT(CONTACTNUMBER,
&                  CONTACTFIRSTNAME,
&                  CONTACTLASTNAME,
&                  CONTACTPHONE,
&                  CONTACTFAX,
&                  CONTACTEMAIL,
&                  CONTACTCOUNTRYCODE,
&                  CONTACTMAILINGADDRESSNUMBER,
&                  CONTACTMAILINGADDRESS,
&                  CONTACTMAILINGCITY,
&                  CONTACTMAILINGPROVINCECODE,
&                  CONTACTMAILINGPOSTALCODE,
&                  CONTACTMAILINGCOUNTRYCODE,
&                  CUSTOMERNUMBER,
&                  CUSTOMERNAME,
&                  RESPONSESTATUS,
&                  RESPONSEMESSAGES,
&                  LBLCONTACTNUMBER,
&                  LBLCONTACTFIRSTNAME,
&                  LBLCONTACTLASTNAME,
&                  LBLCONTACTPHONE,
&                  LBLCONTACTFAX,
&                  LBLCONTACTEMAIL,
&                  LBLCONTACTCOUNTRYCODE,
&                  LBLCONTACTMAILINGADDRESSNUMBER,
&                  LBLCONTACTMAILINGADDRESS,
&                  LBLCONTACTMAILINGCITY,
&                  LBLCONTACTMAILINGPROVINCECODE,
&                  LBLCONTACTMAILINGPOSTALCODE,
&                  LBLCONTACTMAILINGCOUNTRYCODE,
&                  LBLCUSTOMERNUMBER,
&                  LBLCUSTOMERNAME)

  Variable Char CONTACTNUMBER
  Variable Char CONTACTFIRSTNAME
  Variable Char CONTACTLASTNAME
  Variable Char CONTACTPHONE
  Variable Char CONTACTFAX
  Variable Char CONTACTEMAIL
  Variable Char CONTACTCOUNTRYCODE

  Variable Char CONTACTMAILINGADDRESSNUMBER
  Variable Char CONTACTMAILINGADDRESS
  Variable Char CONTACTMAILINGCITY
  Variable Char CONTACTMAILINGPROVINCECODE
  Variable Char CONTACTMAILINGPOSTALCODE
  Variable Char CONTACTMAILINGCOUNTRYCODE

  Variable Char CUSTOMERNUMBER
  Variable Char CUSTOMERNAME

  Variable Integer RESPONSESTATUS
  Variable Char    RESPONSEMESSAGES()(1..)

  Variable Char LBLCONTACTNUMBER
  Variable Char LBLCONTACTFIRSTNAME
  Variable Char LBLCONTACTLASTNAME
  Variable Char LBLCONTACTPHONE
  Variable Char LBLCONTACTFAX
  Variable Char LBLCONTACTEMAIL
  Variable Char LBLCONTACTCOUNTRYCODE

  Variable Char LBLCONTACTMAILINGADDRESSNUMBER
  Variable Char LBLCONTACTMAILINGADDRESS
  Variable Char LBLCONTACTMAILINGCITY
  Variable Char LBLCONTACTMAILINGPROVINCECODE
  Variable Char LBLCONTACTMAILINGPOSTALCODE
  Variable Char LBLCONTACTMAILINGCOUNTRYCODE

  Variable Char LBLCUSTOMERNUMBER
  Variable Char LBLCUSTOMERNAME

  # Environment
  Local Char    WEBSERVICELANGUAGE(GLONLAN) : WEBSERVICELANGUAGE = GLANGUE
  Local Char    ERRMSG(255)

  # Used across gosubs
  Local Char    FUNCTION(30) : FUNCTION = "soapRead"
  Local Clbfile ARGUMENTS
  Local Clbfile RESBODY

  # Contact
  Local Char CONTACTFUNCTION(123)
  Local Char CONTACTMAILINGADDRESS1(GLONADL)(dim(CONTACTMAILINGADDRESS))
  Local Char CONTACTMAILINGADDRESS2(GLONADL)(dim(CONTACTMAILINGADDRESS))
  Local Char CONTACTMAILINGADDRESS3(GLONADL)(dim(CONTACTMAILINGADDRESS))

  # Logging across gosubs
  Local Instance MYLOG Using C_ALOG
  MYLOG=NewInstance C_ALOG AllocGroup null
  OK=fmet MYLOG.ABEGINLOG("CRMSFCNTR"-mess(3,7845,1))
  OK=fmet MYLOG.APUTLINE("Reading contact"-CONTACTNUMBER-"for customer"-CUSTOMERNUMBER,OK)   # TODO translation
  OK=fmet MYLOG.AFLUSHLOG

  # Verify correct arguments were supplied
  If CONTACTNUMBER = ""
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000106", mess(10,123,1), "", func CRMSF.GETLABEL("CNTBPC", "CCNCRM"))
    Goto READWRAPUP
  Endif
  If CUSTOMERNUMBER = ""
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000106", mess(10,123,1), "", func CRMSF.GETLABEL("BPC0", "BPCNUM"))
    Goto READWRAPUP
  Endif
  CONTACTMAILINGADDRESSNUMBER = ""

  # Build call to BPC web service
  ARGUMENTS = '"'
  Append ARGUMENTS, WEBSERVICELANGUAGE    # <codeLang> from ws call to this subprogram
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'SFCRMPOOL'            # TODO can this come from call?  <poolAlias>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'CRMSFBPC'                 # <publicName>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'BPCNUM'              # <objectKeys.key>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, CUSTOMERNUMBER        # <objectKeys.value>
  Append ARGUMENTS, '"'

#-------------------------------------------------------------------------------------------------#
# Unremark below line to log contents of ARGUMENTS
#OK = fmet MYLOG.APUTLINE("ARGUMENTS ="-ARGUMENTS, OK) : OK = fmet MYLOG.AFLUSHLOG
#-------------------------------------------------------------------------------------------------#

  If ERRMSG = ""
    Gosub CLEARRETURNVALUES
    Gosub CALLBUNDLE From CRMSF
    If ERRMSG = ""
      RESPONSESTATUS = func CRMSF.GETRESPONSESTATUS(RESBODY)
      If RESPONSESTATUS=0
        Gosub LOADRESPONSES From CRMSF
      Else
        Gosub PROCESSRETURNEDXML
        If ERRMSG=""
          OK=fmet MYLOG.APUTLINE("Read contact"-CONTACTNUMBER-CONTACTFIRSTNAME-CONTACTLASTNAME-"for customer"-CUSTOMERNUMBER-CUSTOMERNAME,OK)    # TODO translation
        Endif
      Endif
    Endif
  Endif

$READWRAPUP
  If ERRMSG <> ""
    RESPONSESTATUS = 0
    RESPONSEMESSAGES(1) = ERRMSG
    OK = fmet MYLOG.APUTLINE(func AFNC.TEXTE(141)+":"-ERRMSG, OK) : OK = fmet MYLOG.AFLUSHLOG
  Endif

  # End logging
  OK = fmet MYLOG.AENDLOG
  FreeGroup MYLOG

End

####################################################################################################

$PROCESSRETURNEDXML

  OK = fmet MYLOG.APUTLINE(mess(RESPONSESTATUS,189,1), OK) : OK = fmet MYLOG.AFLUSHLOG

  # Populate return variables
  Gosub LOADRETURNVALUES
  If ERRMSG = ""
    # Get field labels
    Gosub LOADLABELS
  Endif

Return

####################################################################################################

$LOADRETURNVALUES

  Local Integer LOOP
  Local Clbfile CUSTOMERNAMELIST

  CUSTOMERNAMELIST = func CRMSF.GETXMLVALUE(RESBODY, "BPRC_1", 0, "BPRNAM")
  CUSTOMERNAME     = func CRMSF.GETLISTVALUE(CUSTOMERNAMELIST, 1)

  For LOOP = 1 To int(val(func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", 0, "SIZE")))
    If func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CCNCRM")=CONTACTNUMBER
      CONTACTLASTNAME = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTLNA")
      Break
    Endif
  Next LOOP

  If CONTACTLASTNAME=""
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000102", mess(23,100,1), CONTACTNUMBER, func CRMSF.GETLABEL("CNTBPC", "CCNCRM"))
  Else
    CONTACTFIRSTNAME            = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTFNA")
  #  CONTACTFUNCTION             = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTFNC")
    CONTACTPHONE                = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTTEL")
    CONTACTFAX                  = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTFAX")
    CONTACTEMAIL                = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTWEB")
    CONTACTCOUNTRYCODE          = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTCRY")
    CONTACTMAILINGADDRESSNUMBER = func CRMSF.GETXMLVALUE(RESBODY, "CNTC_1", LOOP, "CNTADD")

    If CONTACTMAILINGADDRESSNUMBER <> ""
      For LOOP = 1 To int(val(func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", 0, "SIZE")))
        If func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP, "CODADR")=CONTACTMAILINGADDRESSNUMBER
          CONTACTMAILINGADDRESS1      = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP, "ADDLIG1")
          CONTACTMAILINGADDRESS2      = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP, "ADDLIG2")
          CONTACTMAILINGADDRESS3      = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP, "ADDLIG3")
          Call COMBINEADDRESSES(CONTACTMAILINGADDRESS1, CONTACTMAILINGADDRESS2, CONTACTMAILINGADDRESS3, CONTACTMAILINGADDRESS) From CRMSF
          CONTACTMAILINGCITY          = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP, "CTY")
          CONTACTMAILINGPROVINCECODE  = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP, "SAT")
          CONTACTMAILINGPOSTALCODE    = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP, "POSCOD")
          CONTACTMAILINGCOUNTRYCODE   = func CRMSF.GETXMLVALUE(RESBODY, "BPAC_1", LOOP, "BPACRY")
          Break
        Endif
      Next LOOP

      If CONTACTMAILINGCITY=""
        ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000102", mess(23,100,1), CONTACTMAILINGADDRESSNUMBER, func CRMSF.GETLABEL("CNTBPC", "CNTADD"))
      Endif
    Endif
  Endif

  OK=fmet MYLOG.APUTLINE("Contact return values loaded",OK) : OK=fmet MYLOG.AFLUSHLOG     # TODO translate

  # Decode any XML escaped characters in the returned values
  If CONTACTFIRSTNAME            <> "" : CONTACTFIRSTNAME           = func CRMSF.ESCAPECHARS(CONTACTFIRSTNAME          , "OUT") : Endif
  If CONTACTLASTNAME             <> "" : CONTACTLASTNAME            = func CRMSF.ESCAPECHARS(CONTACTLASTNAME           , "OUT") : Endif
  If CONTACTPHONE                <> "" : CONTACTPHONE               = func CRMSF.ESCAPECHARS(CONTACTPHONE              , "OUT") : Endif
  If CONTACTFAX                  <> "" : CONTACTFAX                 = func CRMSF.ESCAPECHARS(CONTACTFAX                , "OUT") : Endif
  If CONTACTEMAIL                <> "" : CONTACTEMAIL               = func CRMSF.ESCAPECHARS(CONTACTEMAIL              , "OUT") : Endif
  If CONTACTMAILINGADDRESS       <> "" : CONTACTMAILINGADDRESS      = func CRMSF.ESCAPECHARS(CONTACTMAILINGADDRESS     , "OUT") : Endif
  If CONTACTMAILINGCITY          <> "" : CONTACTMAILINGCITY         = func CRMSF.ESCAPECHARS(CONTACTMAILINGCITY        , "OUT") : Endif
  If CONTACTMAILINGPROVINCECODE  <> "" : CONTACTMAILINGPROVINCECODE = func CRMSF.ESCAPECHARS(CONTACTMAILINGPROVINCECODE, "OUT") : Endif
  If CONTACTMAILINGPOSTALCODE    <> "" : CONTACTMAILINGPOSTALCODE   = func CRMSF.ESCAPECHARS(CONTACTMAILINGPOSTALCODE  , "OUT") : Endif
  If CUSTOMERNAME                <> "" : CUSTOMERNAME               = func CRMSF.ESCAPECHARS(CUSTOMERNAME              , "OUT") : Endif

  OK=fmet MYLOG.APUTLINE("Character conversion completed for contacts",OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

Return

####################################################################################################

$LOADLABELS

  LBLCONTACTNUMBER      = func CRMSF.GETLABEL("CNTBPC", "CCNCRM")
  LBLCONTACTFIRSTNAME   = func CRMSF.GETLABEL("CNTBPC", "CNTFNA")
  LBLCONTACTLASTNAME    = func CRMSF.GETLABEL("CNTBPC", "CNTLNA")
  LBLCONTACTPHONE       = func CRMSF.GETLABEL("CNTBPC", "CNTTEL")
  LBLCONTACTFAX         = func CRMSF.GETLABEL("CNTBPC", "CNTFAX")
  LBLCONTACTEMAIL       = func CRMSF.GETLABEL("CNTBPC", "CNTWEB")
  LBLCONTACTCOUNTRYCODE = func CRMSF.GETLABEL("BPRBPC", "BPRNAM")

  LBLCONTACTMAILINGADDRESSNUMBER = func CRMSF.GETLABEL("CNTBPC", "CNTADD" )
  LBLCONTACTMAILINGADDRESS       = func CRMSF.GETLABEL("BPABPC", "ADDLIG")
  LBLCONTACTMAILINGCITY          = func CRMSF.GETLABEL("BPABPC", "CTY"    )
  LBLCONTACTMAILINGPROVINCECODE  = func CRMSF.GETPROVINCELABEL(CONTACTMAILINGCOUNTRYCODE, WEBSERVICELANGUAGE)
  LBLCONTACTMAILINGPOSTALCODE    = func CRMSF.GETLABEL("BPABPC", "POSCOD" )
  LBLCONTACTMAILINGCOUNTRYCODE   = func CRMSF.GETLABEL("BPABPC", "BPACRY" )

  LBLCUSTOMERNUMBER = func CRMSF.GETLABEL("BPC0",   "BPCNUM")
  LBLCUSTOMERNAME   = func CRMSF.GETLABEL("BPRBPC", "BPRNAM" )

Return

####################################################################################################

Subprog SAVECONTACT(CONTACTNUMBER,
&                   CONTACTFIRSTNAME,
&                   CONTACTLASTNAME,
&                   CONTACTPHONE,
&                   CONTACTFAX,
&                   CONTACTEMAIL,
&                   CONTACTCOUNTRYCODE,
&                   CONTACTMAILINGADDRESSNUMBER,
&                   CONTACTMAILINGADDRESS,
&                   CONTACTMAILINGCITY,
&                   CONTACTMAILINGPROVINCECODE,
&                   CONTACTMAILINGPOSTALCODE,
&                   CONTACTMAILINGCOUNTRYCODE,
&                   CUSTOMERNUMBER,
&                   CUSTOMERNAME,
&                   RESPONSESTATUS,
&                   RESPONSEMESSAGES,
&                   LBLCONTACTNUMBER,
&                   LBLCONTACTFIRSTNAME,
&                   LBLCONTACTLASTNAME,
&                   LBLCONTACTPHONE,
&                   LBLCONTACTFAX,
&                   LBLCONTACTEMAIL,
&                   LBLCONTACTCOUNTRYCODE,
&                   LBLCONTACTMAILINGADDRESSNUMBER,
&                   LBLCONTACTMAILINGADDRESS,
&                   LBLCONTACTMAILINGCITY,
&                   LBLCONTACTMAILINGPROVINCECODE,
&                   LBLCONTACTMAILINGPOSTALCODE,
&                   LBLCONTACTMAILINGCOUNTRYCODE,
&                   LBLCUSTOMERNUMBER,
&                   LBLCUSTOMERNAME)

  Variable Char CONTACTNUMBER
  Variable Char CONTACTFIRSTNAME
  Variable Char CONTACTLASTNAME
  Variable Char CONTACTPHONE
  Variable Char CONTACTFAX
  Variable Char CONTACTEMAIL
  Variable Char CONTACTCOUNTRYCODE

  Variable Char CONTACTMAILINGADDRESSNUMBER
  Variable Char CONTACTMAILINGADDRESS
  Variable Char CONTACTMAILINGCITY
  Variable Char CONTACTMAILINGPROVINCECODE
  Variable Char CONTACTMAILINGPOSTALCODE
  Variable Char CONTACTMAILINGCOUNTRYCODE

  Variable Char CUSTOMERNUMBER
  Variable Char CUSTOMERNAME

  Variable Integer RESPONSESTATUS
  Variable Char    RESPONSEMESSAGES()(1..)

  Variable Char LBLCONTACTNUMBER
  Variable Char LBLCONTACTFIRSTNAME
  Variable Char LBLCONTACTLASTNAME
  Variable Char LBLCONTACTPHONE
  Variable Char LBLCONTACTFAX
  Variable Char LBLCONTACTEMAIL
  Variable Char LBLCONTACTCOUNTRYCODE

  Variable Char LBLCONTACTMAILINGADDRESSNUMBER
  Variable Char LBLCONTACTMAILINGADDRESS
  Variable Char LBLCONTACTMAILINGCITY
  Variable Char LBLCONTACTMAILINGPROVINCECODE
  Variable Char LBLCONTACTMAILINGPOSTALCODE
  Variable Char LBLCONTACTMAILINGCOUNTRYCODE

  Variable Char LBLCUSTOMERNUMBER
  Variable Char LBLCUSTOMERNAME

  # Environment
  Local Char    WEBSERVICELANGUAGE(GLONLAN) : WEBSERVICELANGUAGE = GLANGUE
  Local Char    ERRMSG(255)

  # Addresses
  Local Char CONTACTMAILINGADDRESS1(GLONADL)(dim(CONTACTMAILINGADDRESS))
  Local Char CONTACTMAILINGADDRESS2(GLONADL)(dim(CONTACTMAILINGADDRESS))
  Local Char CONTACTMAILINGADDRESS3(GLONADL)(dim(CONTACTMAILINGADDRESS))

  # Used across gosubs
  Local Char    FUNCTION(30) : FUNCTION = "soapModify"
  Local Clbfile ARGUMENTS
  Local Clbfile RESBODY

  # XML building
  Local Char    CUSTOMERCOUNTRYCODE(GLONCRY)
  Local Char    BILLTOADDRESSNUMBER(GLONADR)
  Local Clbfile CONTACTSXML
  Local Clbfile CURRENTCONTACTXML
  Local Integer CONTACTSCOUNT
  Local Clbfile ADDRESSESXML
  Local Integer ADDRESSESCOUNT


  # Logging across gosubs
  Local Instance MYLOG Using C_ALOG
  MYLOG=NewInstance C_ALOG AllocGroup null
  OK=fmet MYLOG.ABEGINLOG("CRMSFCNTS"-mess(3,7845,1))
  OK=fmet MYLOG.APUTLINE("Saving contact for customer"-CUSTOMERNUMBER,OK)   # TODO translation
  OK=fmet MYLOG.AFLUSHLOG

  Gosub DATARECEIVED

  # Verify correct arguments were supplied
  CONTACTNUMBER = ""
  If CUSTOMERNUMBER = ""
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000106", mess(10,123,1), "", func CRMSF.GETLABEL("BPC0", "BPCNUM"))
    Goto SAVEWRAPUP
  Endif
  CONTACTMAILINGADDRESSNUMBER = ""

  # Get contact number
  CONTACTNUMBER = func CRMSF.GETNEXTCONTACTNUMBER(ERRMSG)
  If ERRMSG <> ""
    Goto SAVEWRAPUP
  Endif

  # Get customer category from customer
  Call GETCUSTOMERDATA(CUSTOMERNUMBER, CUSTOMERCOUNTRYCODE, BILLTOADDRESSNUMBER, ERRMSG)
  If ERRMSG <> ""
    Goto SAVEWRAPUP
  Endif

  Gosub BUILDSAVEXML

  If ERRMSG = ""
    Gosub CLEARRETURNVALUES
    Gosub CALLBUNDLE From CRMSF
    If ERRMSG = ""
      RESPONSESTATUS = func CRMSF.GETRESPONSESTATUS(RESBODY)
      If RESPONSESTATUS=0
        Gosub LOADRESPONSES From CRMSF
      Else
        Gosub PROCESSRETURNEDXML
        If ERRMSG=""
          OK=fmet MYLOG.APUTLINE("Saved contact"-CONTACTNUMBER-CONTACTFIRSTNAME-CONTACTLASTNAME-"for customer"-CUSTOMERNUMBER-CUSTOMERNAME,OK)    # TODO translation
        Endif
      Endif
    Endif
  Endif

$SAVEWRAPUP
  If ERRMSG <> ""
    RESPONSESTATUS = 0
    RESPONSEMESSAGES(1) = ERRMSG
    OK = fmet MYLOG.APUTLINE("Wrapup"-func AFNC.TEXTE(141)+":"-ERRMSG, OK) : OK = fmet MYLOG.AFLUSHLOG   # TODO translation
  Endif

  # End logging
  OK = fmet MYLOG.AENDLOG
  FreeGroup MYLOG

  End

####################################################################################################

$ BUILDSAVEXML
  # All contact codes for the customer must be submitted,
  # otherwise missing codes will be removed from the customer.
  Call GETCONTACTSXML(CUSTOMERNUMBER, CONTACTSXML, CONTACTSCOUNT)

  # Like the contacts all address codes must be submitted if an address is being added.
  If CONTACTMAILINGCITY <> ""
    Call GETNEXTCONTACTADDR(CUSTOMERNUMBER, CONTACTMAILINGADDRESSNUMBER, ERRMSG)
    If ERRMSG <> ""
      Goto SAVEWRAPUP
    Endif
    Call GETADRESSESXML(CUSTOMERNUMBER, ADDRESSESXML, "", ADDRESSESCOUNT)
  Endif

  Call PARSEADDRESS(CONTACTMAILINGADDRESS, CONTACTMAILINGADDRESS1, CONTACTMAILINGADDRESS2, CONTACTMAILINGADDRESS3) From CRMSF

  # Build call to BPC web service
  ARGUMENTS = '"'
  Append ARGUMENTS, WEBSERVICELANGUAGE   # <codeLang> from ws call to this subprogram
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'SFCRMPOOL'  # TODO can this come from call?  <poolAlias>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'CRMSFBPC'       # <publicName>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'BPCNUM'              # <objectKeys.key>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, CUSTOMERNUMBER        # <objectKeys.value>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, '<PARAM>'   # <requestXml>
  Append ARGUMENTS,   '<GRP ID=\"BPC0_1\">'
  Append ARGUMENTS,     '<FLD NAME=\"BPCNUM\" TYPE=\"Char\">' + CUSTOMERNUMBER + '</FLD>'
  Append ARGUMENTS,   '</GRP>'
  Append ARGUMENTS,   '<GRP ID=\"BPRC_1\">'
  Append ARGUMENTS,     '<FLD NAME=\"CRY\" TYPE=\"Char\">' + CUSTOMERCOUNTRYCODE + '</FLD>'
  Append ARGUMENTS,   '</GRP>'
  Append ARGUMENTS,   '<GRP ID=\"BPC3_1\">'
  Append ARGUMENTS,    '<FLD NAME=\"BPAINV\" TYPE=\"Char\">' + BILLTOADDRESSNUMBER + '</FLD>'
  Append ARGUMENTS,   '</GRP>'
  Append ARGUMENTS,   '<TAB DIM=\"' + num$(func AFNC.ACTIV("NBCNT")) + '\" ID=\"CNTC_1\" SIZE=\"' + num$(CONTACTSCOUNT+1) + '\">'
  Append ARGUMENTS,     CONTACTSXML
  Append ARGUMENTS,     '<LIN NUM=\"' + num$(CONTACTSCOUNT+1) + '\">'
  Append ARGUMENTS,       '<FLD NAME=\"CCNCRM\" TYPE=\"Char\">' + CONTACTNUMBER + '</FLD>'
  Append ARGUMENTS,       '<FLD NAME=\"CNTFNA\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTFIRSTNAME, "IN") + '</FLD>'
  Append ARGUMENTS,       '<FLD NAME=\"CNTLNA\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTLASTNAME, "IN") + '</FLD>'   # See SPEBPC for logic that allows this
  Append ARGUMENTS,       '<FLD NAME=\"CNTTEL\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTPHONE, "IN") + '</FLD>'
  Append ARGUMENTS,       '<FLD NAME=\"CNTFAX\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTFAX, "IN") + '</FLD>'
  Append ARGUMENTS,       '<FLD NAME=\"CNTWEB\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTEMAIL, "IN") + '</FLD>'
  Append ARGUMENTS,       '<FLD NAME=\"CNTADD\" TYPE=\"Char\">' + CONTACTMAILINGADDRESSNUMBER + '</FLD>'
  Append ARGUMENTS,       '<FLD MENULAB=\"Other\" MENULOCAL=\"233\" NAME=\"CNTFNC\" TYPE=\"Integer\">11</FLD>'    # Function = Other
  Append ARGUMENTS,     '</LIN>'
  Append ARGUMENTS,   '</TAB>'
  If ADDRESSESCOUNT
    Append ARGUMENTS,   '<TAB DIM=\"' + num$(func AFNC.ACTIV("BPA")) + '\" ID=\"BPAC_1\" SIZE=\"' + num$(ADDRESSESCOUNT+1) + '\">'
    Append ARGUMENTS,     ADDRESSESXML
    Append ARGUMENTS,       '<LIN NUM=\"' + num$(ADDRESSESCOUNT+1) + '\">'
    Append ARGUMENTS,         '<FLD NAME=\"CODADR\" TYPE=\"Char\">' + CONTACTMAILINGADDRESSNUMBER + '</FLD>'
    Append ARGUMENTS,         '<FLD NAME=\"BPACRY\" TYPE=\"Char\">' + CONTACTMAILINGCOUNTRYCODE + '</FLD>'
    Append ARGUMENTS,         '<FLD NAME=\"ADDLIG1\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTMAILINGADDRESS1, "IN") + '</FLD>'
    Append ARGUMENTS,         '<FLD NAME=\"ADDLIG2\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTMAILINGADDRESS2, "IN") + '</FLD>'
    Append ARGUMENTS,         '<FLD NAME=\"ADDLIG3\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTMAILINGADDRESS3, "IN") + '</FLD>'
    Append ARGUMENTS,         '<FLD NAME=\"POSCOD\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTMAILINGPOSTALCODE, "IN") + '</FLD>'
    Append ARGUMENTS,         '<FLD NAME=\"CTY\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTMAILINGCITY, "IN") + '</FLD>'
    Append ARGUMENTS,         '<FLD NAME=\"SAT\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTMAILINGPROVINCECODE, "IN") + '</FLD>'
    Append ARGUMENTS,         '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"BPAADDFLG\" TYPE=\"Integer\">1</FLD>'
    Append ARGUMENTS,       '</LIN>'
    Append ARGUMENTS,   '</TAB>'
  Endif
  Append ARGUMENTS, '</PARAM>'
  Append ARGUMENTS, '"'

#-------------------------------------------------------------------------------------------------#
# Unremark below line to log contents of ARGUMENTS
 Local Char     CLOBNAME(30)
 Local Clbfile  CLOBDATA
 CLOBNAME = "ARGUMENTS" : CLOBDATA = ARGUMENTS : Gosub LOGCLOB From CRMSF
#-------------------------------------------------------------------------------------------------#

Return

####################################################################################################

Subprog MODIFYCONTACT(CONTACTNUMBER,
&                     CONTACTFIRSTNAME,
&                     CONTACTLASTNAME,
&                     CONTACTPHONE,
&                     CONTACTFAX,
&                     CONTACTEMAIL,
&                     CONTACTCOUNTRYCODE,
&                     CONTACTMAILINGADDRESSNUMBER,
&                     CONTACTMAILINGADDRESS,
&                     CONTACTMAILINGCITY,
&                     CONTACTMAILINGPROVINCECODE,
&                     CONTACTMAILINGPOSTALCODE,
&                     CONTACTMAILINGCOUNTRYCODE,
&                     CUSTOMERNUMBER,
&                     CUSTOMERNAME,
&                     RESPONSESTATUS,
&                     RESPONSEMESSAGES,
&                     LBLCONTACTNUMBER,
&                     LBLCONTACTFIRSTNAME,
&                     LBLCONTACTLASTNAME,
&                     LBLCONTACTPHONE,
&                     LBLCONTACTFAX,
&                     LBLCONTACTEMAIL,
&                     LBLCONTACTCOUNTRYCODE,
&                     LBLCONTACTMAILINGADDRESSNUMBER,
&                     LBLCONTACTMAILINGADDRESS,
&                     LBLCONTACTMAILINGCITY,
&                     LBLCONTACTMAILINGPROVINCECODE,
&                     LBLCONTACTMAILINGPOSTALCODE,
&                     LBLCONTACTMAILINGCOUNTRYCODE,
&                     LBLCUSTOMERNUMBER,
&                     LBLCUSTOMERNAME)

  Variable Char CONTACTNUMBER
  Variable Char CONTACTFIRSTNAME
  Variable Char CONTACTLASTNAME
  Variable Char CONTACTPHONE
  Variable Char CONTACTFAX
  Variable Char CONTACTEMAIL
  Variable Char CONTACTCOUNTRYCODE

  Variable Char CONTACTMAILINGADDRESSNUMBER
  Variable Char CONTACTMAILINGADDRESS
  Variable Char CONTACTMAILINGCITY
  Variable Char CONTACTMAILINGPROVINCECODE
  Variable Char CONTACTMAILINGPOSTALCODE
  Variable Char CONTACTMAILINGCOUNTRYCODE

  Variable Char CUSTOMERNUMBER
  Variable Char CUSTOMERNAME

  Variable Integer RESPONSESTATUS
  Variable Char    RESPONSEMESSAGES()(1..)

  Variable Char LBLCONTACTNUMBER
  Variable Char LBLCONTACTFIRSTNAME
  Variable Char LBLCONTACTLASTNAME
  Variable Char LBLCONTACTPHONE
  Variable Char LBLCONTACTFAX
  Variable Char LBLCONTACTEMAIL
  Variable Char LBLCONTACTCOUNTRYCODE

  Variable Char LBLCONTACTMAILINGADDRESSNUMBER
  Variable Char LBLCONTACTMAILINGADDRESS
  Variable Char LBLCONTACTMAILINGCITY
  Variable Char LBLCONTACTMAILINGPROVINCECODE
  Variable Char LBLCONTACTMAILINGPOSTALCODE
  Variable Char LBLCONTACTMAILINGCOUNTRYCODE

  Variable Char LBLCUSTOMERNUMBER
  Variable Char LBLCUSTOMERNAME

# Environment
  Local Char    WEBSERVICELANGUAGE(GLONLAN) : WEBSERVICELANGUAGE = GLANGUE
  Local Char    ERRMSG(255)

  # Addresses
  Local Char CONTACTMAILINGADDRESS1(GLONADL)(dim(CONTACTMAILINGADDRESS))
  Local Char CONTACTMAILINGADDRESS2(GLONADL)(dim(CONTACTMAILINGADDRESS))
  Local Char CONTACTMAILINGADDRESS3(GLONADL)(dim(CONTACTMAILINGADDRESS))

  # Used across gosubs
  Local Char    FUNCTION(30) : FUNCTION = "soapModify"
  Local Clbfile ARGUMENTS
  Local Clbfile RESBODY

  # XML building
  Local Char    CUSTOMERCOUNTRYCODE(GLONCRY)
  Local Char    BILLTOADDRESSNUMBER(GLONADR)
  Local Clbfile CONTACTSXML
  Local Clbfile CURRENTCONTACTXML
  Local Integer CONTACTSCOUNT
  Local Clbfile ADDRESSESXML
  Local Clbfile CURRENTADDRESSXML
  Local Integer ADDRESSESCOUNT
  Local Tinyint CONTACTHASADDRESS
  Local Tinyint ADDRESSCODESUBMITTED
  Local Tinyint ADDRESSDATASUBMITTED


  # Logging across gosubs
  Local Instance MYLOG Using C_ALOG
  MYLOG=NewInstance C_ALOG AllocGroup null
  OK=fmet MYLOG.ABEGINLOG("CRMSFCNTM"-mess(3,7845,1))
  OK=fmet MYLOG.APUTLINE("Modifying contact"-CONTACTNUMBER-"for customer"-CUSTOMERNUMBER,OK)   # TODO translation
  OK=fmet MYLOG.AFLUSHLOG

  Gosub DATARECEIVED

  # Verify correct arguments were supplied
  If CONTACTNUMBER = ""
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000106", mess(10,123,1), "", func CRMSF.GETLABEL("CNTBPC", "CCNCRM"))
    Goto MODIFYWRAPUP
  Endif
  If CUSTOMERNUMBER = ""
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000106", mess(10,123,1), "", func CRMSF.GETLABEL("BPC0", "BPCNUM"))
    Goto MODIFYWRAPUP
  Endif

  If CONTACTMAILINGADDRESSNUMBER <> ""
    ADDRESSCODESUBMITTED = 1
  Endif
  If (CONTACTMAILINGADDRESS+CONTACTMAILINGCITY+CONTACTMAILINGPROVINCECODE+CONTACTMAILINGPOSTALCODE+CONTACTMAILINGCOUNTRYCODE) <> ""
    ADDRESSDATASUBMITTED = 1
  Endif

  # Get customer settings
  Call GETCUSTOMERDATA(CUSTOMERNUMBER, CUSTOMERCOUNTRYCODE, BILLTOADDRESSNUMBER, ERRMSG)
  If ERRMSG <> ""
    Goto MODIFYWRAPUP
  Endif

  # Determine if contact is associated with this customer. If not then call save logic.
  If func CONTACTBELONGSTOCUSTOMER(CONTACTNUMBER, CUSTOMERNUMBER)
    Gosub BUILDMODIFYXML
  Else
    Gosub BUILDSAVEXML
  Endif

  If ERRMSG = ""
    Gosub CLEARRETURNVALUES
    Gosub CALLBUNDLE From CRMSF
    If ERRMSG = ""
      RESPONSESTATUS = func CRMSF.GETRESPONSESTATUS(RESBODY)
      If RESPONSESTATUS=0
        Gosub LOADRESPONSES From CRMSF
      Else
        Gosub PROCESSRETURNEDXML
        If ERRMSG=""
          OK=fmet MYLOG.APUTLINE("Modified contact"-CONTACTNUMBER-CONTACTFIRSTNAME-CONTACTLASTNAME-"for customer"-CUSTOMERNUMBER-CUSTOMERNAME,OK)    # TODO translation
        Endif
      Endif
    Endif
  Endif

$MODIFYWRAPUP
  If ERRMSG <> ""
    RESPONSESTATUS = 0
    RESPONSEMESSAGES(1) = ERRMSG
    OK = fmet MYLOG.APUTLINE("Wrapup"-func AFNC.TEXTE(141)+":"-ERRMSG, OK) : OK = fmet MYLOG.AFLUSHLOG   # TODO translation
  Endif

  # End logging
  OK = fmet MYLOG.AENDLOG
  FreeGroup MYLOG

  End

####################################################################################################

$BUILDMODIFYXML

  Local Char CUSTOMERBILLINGADDRESSNUMBER(GLONADR)
  Local Char CUSTOMERSHIPPINGADDRESSNUMBER(GLONADR)

  # All contacts for the customer must be submitted, otherwise missing codes will be removed from the customer
  Call GETCONTACTSXML(CUSTOMERNUMBER, CONTACTSXML, CONTACTSCOUNT)

  # Get current address numbers
  If clalev([F:BPC]) = 0 : Local File BPCUSTOMER [BPC] : Endif
  Read [F:BPC]BPC0=CUSTOMERNUMBER

  CUSTOMERBILLINGADDRESSNUMBER  = [F:BPC]BPAINV
  CUSTOMERSHIPPINGADDRESSNUMBER = [F:BPC]BPDADD

  # Compare address numbers to determine if a new one is needed
  If ([F:BPC]BPCINV = [F:BPC]BPCNUM & CONTACTMAILINGADDRESSNUMBER = [F:BPC]BPAINV) | (CONTACTMAILINGADDRESSNUMBER = [F:BPC]BPDADD)
    Call GETNEXTCONTACTADDR(CUSTOMERNUMBER, CONTACTMAILINGADDRESSNUMBER, ERRMSG)
    If ERRMSG <> "" : Goto MODIFYWRAPUP : Endif
  Endif

  # Get XML for this contact
  CURRENTCONTACTXML = func GETCONTACTXML(CUSTOMERNUMBER, CONTACTNUMBER, CONTACTSCOUNT+1, CONTACTFIRSTNAME, CONTACTLASTNAME, CONTACTPHONE, CONTACTFAX, CONTACTEMAIL, CONTACTMAILINGADDRESSNUMBER)
  If func CONTACTHASADDRESS(CUSTOMERNUMBER, CONTACTNUMBER)
    If ADDRESSCODESUBMITTED
      If ADDRESSDATASUBMITTED
        # Modify address
        Call GETADRESSESXML(CUSTOMERNUMBER, ADDRESSESXML, "", ADDRESSESCOUNT)
        Call PARSEADDRESS(CONTACTMAILINGADDRESS, CONTACTMAILINGADDRESS1, CONTACTMAILINGADDRESS2, CONTACTMAILINGADDRESS3) From CRMSF
        CURRENTADDRESSXML = func GETADDRESSXML(CUSTOMERNUMBER, CONTACTMAILINGADDRESSNUMBER, CONTACTMAILINGADDRESS1, CONTACTMAILINGADDRESS2, CONTACTMAILINGADDRESS3,
&                                        CONTACTMAILINGCITY, CONTACTMAILINGPROVINCECODE, CONTACTMAILINGPOSTALCODE, CONTACTMAILINGCOUNTRYCODE, ADDRESSESCOUNT, ERRMSG)
      If ERRMSG <> "" : Goto MODIFYWRAPUP : Endif
      Endif
    Else
      If ADDRESSDATASUBMITTED
        ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000106", mess(10,123,1), "", func CRMSF.GETLABEL("CNTBPC", "CNTADD")) : Goto MODIFYWRAPUP
      Endif
    Endif
  Else
    If ADDRESSCODESUBMITTED or ADDRESSDATASUBMITTED
      # Add address
      Call GETNEXTCONTACTADDR(CUSTOMERNUMBER, CONTACTMAILINGADDRESSNUMBER, ERRMSG) : If ERRMSG <> "" : End "" : Endif
      CURRENTCONTACTXML = func GETCONTACTXML(CUSTOMERNUMBER, CONTACTNUMBER, CONTACTSCOUNT+1, CONTACTFIRSTNAME, CONTACTLASTNAME, CONTACTPHONE, CONTACTFAX, CONTACTEMAIL, CONTACTMAILINGADDRESSNUMBER)
      Call GETADRESSESXML(CUSTOMERNUMBER, ADDRESSESXML, "", ADDRESSESCOUNT)
      Call PARSEADDRESS(CONTACTMAILINGADDRESS, CONTACTMAILINGADDRESS1, CONTACTMAILINGADDRESS2, CONTACTMAILINGADDRESS3) From CRMSF
      ADDRESSESCOUNT += 1
      Append CURRENTADDRESSXML, '<LIN NUM=\"' + num$(ADDRESSESCOUNT) + '\">'
      Append CURRENTADDRESSXML,   '<FLD NAME=\"CODADR\" TYPE=\"Char\">' + CONTACTMAILINGADDRESSNUMBER + '</FLD>'
      Append CURRENTADDRESSXML,   '<FLD NAME=\"BPACRY\" TYPE=\"Char\">' + CONTACTMAILINGCOUNTRYCODE + '</FLD>'
      Append CURRENTADDRESSXML,   '<FLD NAME=\"ADDLIG1\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTMAILINGADDRESS1, "IN") + '</FLD>'
      Append CURRENTADDRESSXML,   '<FLD NAME=\"ADDLIG2\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTMAILINGADDRESS2, "IN") + '</FLD>'
      Append CURRENTADDRESSXML,   '<FLD NAME=\"ADDLIG3\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTMAILINGADDRESS3, "IN") + '</FLD>'
      Append CURRENTADDRESSXML,   '<FLD NAME=\"POSCOD\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTMAILINGPOSTALCODE, "IN") + '</FLD>'
      Append CURRENTADDRESSXML,   '<FLD NAME=\"CTY\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTMAILINGCITY, "IN") + '</FLD>'
      Append CURRENTADDRESSXML,   '<FLD NAME=\"SAT\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTMAILINGPROVINCECODE, "IN") + '</FLD>'
      Append CURRENTADDRESSXML,   '<FLD MENULAB=\"Yes\" MENULOCAL=\"1\" NAME=\"BPAADDFLG\" TYPE=\"Integer\">1</FLD>'
      Append CURRENTADDRESSXML, '</LIN>'
    Endif
  Endif

  # Build call to BPC web service
  ARGUMENTS = '"'
  Append ARGUMENTS, WEBSERVICELANGUAGE   # <codeLang> from ws call to this subprogram
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'SFCRMPOOL'  # TODO can this come from call?  <poolAlias>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'CRMSFBPC'       # <publicName>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, 'BPCNUM'              # <objectKeys.key>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, CUSTOMERNUMBER        # <objectKeys.value>
  Append ARGUMENTS, '","'
  Append ARGUMENTS, '<PARAM>'   # <requestXml>
  Append ARGUMENTS,   '<GRP ID=\"BPC0_1\">'
  Append ARGUMENTS,     '<FLD NAME=\"BPCNUM\" TYPE=\"Char\">' + CUSTOMERNUMBER + '</FLD>'
  Append ARGUMENTS,   '</GRP>'
  Append ARGUMENTS,   '<GRP ID=\"BPRC_1\">'
  Append ARGUMENTS,     '<FLD NAME=\"CRY\" TYPE=\"Char\">' + CUSTOMERCOUNTRYCODE + '</FLD>'
  Append ARGUMENTS,   '</GRP>'
  Append ARGUMENTS,   '<GRP ID=\"BPC3_1\">'
  Append ARGUMENTS,    '<FLD NAME=\"BPAINV\" TYPE=\"Char\">' + BILLTOADDRESSNUMBER + '</FLD>'
  Append ARGUMENTS,   '</GRP>'
  Append ARGUMENTS,   '<TAB DIM=\"' + num$(func AFNC.ACTIV("NBCNT")) + '\" ID=\"CNTC_1\" SIZE=\"' + num$(CONTACTSCOUNT+1) + '\">'
  Append ARGUMENTS,     CONTACTSXML
  Append ARGUMENTS,     CURRENTCONTACTXML
  Append ARGUMENTS,   '</TAB>'
  If ADDRESSESCOUNT
    Append ARGUMENTS,   '<TAB DIM=\"' + num$(func AFNC.ACTIV("BPA")) + '\" ID=\"BPAC_1\" SIZE=\"' + num$(ADDRESSESCOUNT) + '\">'
    Append ARGUMENTS,     ADDRESSESXML
    Append ARGUMENTS,     CURRENTADDRESSXML
    Append ARGUMENTS,   '</TAB>'
  Endif
  Append ARGUMENTS, '</PARAM>'
  Append ARGUMENTS, '"'

#-------------------------------------------------------------------------------------------------#
# Unremark below line to log contents of ARGUMENTS
 Local Char     CLOBNAME(30)
 Local Clbfile  CLOBDATA
 CLOBNAME = "ARGUMENTS" : CLOBDATA = ARGUMENTS : Gosub LOGCLOB From CRMSF
#-------------------------------------------------------------------------------------------------#

Return

####################################################################################################

Funprog CONTACTBELONGSTOCUSTOMER(CONTACTNUMBER, CUSTOMERNUMBER)

  Value Char CONTACTNUMBER
  Value Char CUSTOMERNUMBER

  Local Tinyint MATCH

  If clalev([F:CNT]) = 0 : Local File CONTACT [CNT] : Endif
  Read [F:CNT]CNT0 = 1;CUSTOMERNUMBER;CONTACTNUMBER
  MATCH = (fstat=0)

End MATCH

####################################################################################################

Subprog GETCUSTOMERDATA(CUSTOMERNUMBER, COUNTRY, BILLTOADDRESSNUMBER, ERRMSG)

  Value    Char CUSTOMERNUMBER
  Variable Char CATEGORY
  Variable Char COUNTRY
  Variable Char BILLTOADDRESSNUMBER
  Variable Char ERRMSG

  If clalev([F:BPC]) = 0 : Local File BPCUSTOMER [BPC] : Endif
  Read [F:BPC]BPC0=CUSTOMERNUMBER
  If !fstat
    BILLTOADDRESSNUMBER = [F:BPC]BPAINV
  Else
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000102", mess(23,100,1), CUSTOMERNUMBER, func CRMSF.GETLABEL("BPC0", "BPCNUM"))
  Endif

  If clalev([F:BPR]) = 0 : Local File BPARTNER [BPR] : Endif
  Read [F:BPR]BPR0=CUSTOMERNUMBER
  If !fstat
    COUNTRY = [F:BPR]CRY
  Else
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000102", mess(23,100,1), CUSTOMERNUMBER, func CRMSF.GETLABEL("BPC0", "BPCNUM"))
  Endif

End

####################################################################################################

Subprog GETCONTACTSXML(CUSTOMERNUMBER, CONTACTSXML, CONTACTSCOUNT)

  Value    Char    CUSTOMERNUMBER
  Variable Clbfile CONTACTSXML
  Variable Integer CONTACTSCOUNT

  Local Char    CCNCRM(GLONCNT)
  Local Integer CHARPOS
  Local Char    CNTFULNAM(GLONFNA+2+GLONNAM)

  If clalev([F:CNT]) = 0 : Local File CONTACT [CNT] : Endif
  If clalev([F:AIN]) = 0 : Local File CONTACTCRM [AIN] : Endif
  If clalev([F:BPC]) = 0 : Local File BPCUSTOMER [BPC] : Endif

  CONTACTSXML   = ""
  CONTACTSCOUNT = 0

  Read [F:BPC]BPC0=CUSTOMERNUMBER

  For [CNT] Where BPANUM=CUSTOMERNUMBER
    CCNCRM = [F:CNT]CCNCRM
    Read [F:AIN]AIN0=CCNCRM
      CONTACTSCOUNT += 1
      Append CONTACTSXML, '<LIN NUM=\"' + num$(CONTACTSCOUNT) + '\">'
      Append CONTACTSXML,   '<FLD NAME=\"CCNCRM\" TYPE=\"Char\">' + [F:CNT]CCNCRM + '</FLD>'
      Append CONTACTSXML,   '<FLD NAME=\"CNTLNA\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS([F:AIN]CNTLNA, "IN") + '</FLD>'
      Append CONTACTSXML,   '<FLD NAME=\"CNTFNA\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS([F:AIN]CNTFNA, "IN") + '</FLD>'
      Append CONTACTSXML,   '<FLD MENULOCAL=\"941\" NAME=\"CNTTTL\" TYPE=\"Integer\">' + num$([F:AIN]CNTTTL) + '</FLD>'
      Append CONTACTSXML,   '<FLD MENULOCAL=\"233\" NAME=\"CNTFNC\" TYPE=\"Integer\">' + num$([F:CNT]CNTFNC) + '</FLD>'
      Append CONTACTSXML,   '<FLD NAME=\"CNTSRV\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS([F:CNT]CNTSRV, "IN") + '</FLD>'
      Append CONTACTSXML,   '<FLD NAME=\"CNTADD\" TYPE=\"Char\">' + [F:CNT]BPAADD + '</FLD>'
      Append CONTACTSXML,   '<FLD NAME=\"CNTTEL\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS([F:CNT]TEL, "IN") + '</FLD>'
      Append CONTACTSXML,   '<FLD NAME=\"CNTFAX\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS([F:CNT]FAX, "IN") + '</FLD>'
      Append CONTACTSXML,   '<FLD NAME=\"CNTMOB\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS([F:CNT]MOB, "IN") + '</FLD>'
      Append CONTACTSXML,   '<FLD NAME=\"CNTWEB\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS([F:CNT]WEB, "IN") + '</FLD>'
      Append CONTACTSXML,   '<FLD NAME=\"CNTMSS\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS([F:CNT]CNTMSS, "IN") + '</FLD>'
      If [F:AIN]CNTBIR=[00/00/00]
        Append CONTACTSXML,   '<FLD NAME=\"CNTBIR\" TYPE=\"Date\"> </FLD>'
      Else
        Append CONTACTSXML,   '<FLD NAME=\"CNTBIR\" TYPE=\"Date\">' + [F:AIN]CNTBIR + '</FLD>'
      Endif
      CHARPOS = instr(1, [F:AIN]CNTFULNAM, "\")
      CNTFULNAM = func CRMSF.ESCAPECHARS(left$([F:AIN]CNTFULNAM, CHARPOS), "IN") + "\" + func CRMSF.ESCAPECHARS(right$([F:AIN]CNTFULNAM, CHARPOS+1), "IN")
      Append CONTACTSXML,   '<FLD NAME=\"CNTFULNAM\" TYPE=\"Char\">' + CNTFULNAM + '</FLD>'
      Append CONTACTSXML,   '<FLD MENULOCAL=\"1\" NAME=\"CNTFBDMAG\" TYPE=\"Integer\">' + num$([F:AIN]CNTFBDMAG) + '</FLD>'
      Append CONTACTSXML,   '<FLD NAME=\"CNTLAN\" TYPE=\"Char\">' + [F:AIN]CNTLAN + '</FLD>'
      Append CONTACTSXML,   '<FLD NAME=\"CNTCSP\" TYPE=\"Char\">' + [F:AIN]CNTCSP + '</FLD>'
      If [F:CNT]CCNCRM = [F:BPC]CNTNAM
        Append CONTACTSXML,   '<FLD MENULOCAL=\"1\" NAME=\"CNTFLG\" TYPE=\"Integer\">2</FLD>'
      Else
        Append CONTACTSXML,   '<FLD MENULOCAL=\"1\" NAME=\"CNTFLG\" TYPE=\"Integer\">1</FLD>'
      Endif
      Append CONTACTSXML, '</LIN>'
  Next

End

####################################################################################################

Subprog GETADRESSESXML(CUSTOMERNUMBER, ADDRESSESXML, ADDRESSCODE, ADDRESSESCOUNT)

  Value    Char    CUSTOMERNUMBER
  Variable Clbfile ADDRESSESXML
  Value    Char    ADDRESSCODE        # to be excluded
  Variable Integer ADDRESSESCOUNT

  If clalev([F:BPA]) = 0 : Local File BPADDRESS [BPA] : Endif

  ADDRESSESXML   = ""
  ADDRESSESCOUNT = 0

  For [BPA] Where [BPA]BPANUM=CUSTOMERNUMBER & [BPA]BPAADD <> ADDRESSCODE
    ADDRESSESCOUNT += 1
    Append ADDRESSESXML, '<LIN NUM=\"' + num$(ADDRESSESCOUNT) + '\">'
    Append ADDRESSESXML,   '<FLD NAME=\"CODADR\" TYPE=\"Char\">' + [F:BPA]BPAADD + '</FLD>'
    Append ADDRESSESXML, '</LIN>'
  Next

End

####################################################################################################

Subprog GETNEXTCONTACTADDR(CUSTOMERNUMBER, ADDRESSNUMBER, ERRMSG)

  Value    Char CUSTOMERNUMBER
  Variable Char ADDRESSNUMBER
  Variable Char ERRMSG

  Local Integer CURRENT
  Local Integer HIGHEST

  If clalev([F:BPA]) = 0 : Local File BPADDRESS [BPA] : Endif

  For [BPA] Where [BPA]BPANUM=CUSTOMERNUMBER
    If left$([F:BPA]BPAADD,3)="CNT"
      CURRENT = val(right$([F:BPA]BPAADD,4))
      If CURRENT > HIGHEST
        HIGHEST = CURRENT
      Endif
    Endif
  Next

  If HIGHEST = 99
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000104", mess(83,134,1), "CNT**", func CRMSF.GETLABEL("BPABPC", "CODADR"))
  Else
    ADDRESSNUMBER = "CNT" + format$("N0:2",num$(HIGHEST+1))
  Endif

End

####################################################################################################

Funprog GETCONTACTXML(CUSTOMERNUMBER, CONTACTNUMBER, LINENUMBER, CONTACTFIRSTNAME, CONTACTLASTNAME, CONTACTPHONE, CONTACTFAX, CONTACTEMAIL, CONTACTADDRESSCODE)

  Value Char    CUSTOMERNUMBER
  Value Char    CONTACTNUMBER
  Value Integer LINENUMBER
  Value Char    CONTACTFIRSTNAME
  Value Char    CONTACTLASTNAME
  Value Char    CONTACTPHONE
  Value Char    CONTACTFAX
  Value Char    CONTACTEMAIL
  Value Char    CONTACTADDRESSCODE

  Local Clbfile CONTACTXML
  Local Integer CHARPOS
  Local Char    CNTFULNAM(GLONFNA+2+GLONNAM)

  If clalev([F:CNT]) = 0 : Local File CONTACT [CNT]    : Endif
  If clalev([F:AIN]) = 0 : Local File CONTACTCRM [AIN] : Endif
  If clalev([F:BPC]) = 0 : Local File BPCUSTOMER [BPC] : Endif

  Read [CNT]CNT0=1;CUSTOMERNUMBER;CONTACTNUMBER
  Read [F:AIN]AIN0=CONTACTNUMBER
  Read [F:BPC]BPC0=CUSTOMERNUMBER

  If CONTACTFIRSTNAME = ""   : CONTACTFIRSTNAME = [F:AIN]CNTFNA   : Endif
  If CONTACTLASTNAME = ""    : CONTACTLASTNAME = [F:AIN]CNTLNA    : Endif
  If CONTACTPHONE = ""       : CONTACTPHONE = [F:CNT]TEL          : Endif
  If CONTACTFAX = ""         : CONTACTFAX = [F:CNT]FAX            : Endif
  If CONTACTEMAIL = ""       : CONTACTEMAIL = [F:CNT]WEB          : Endif
  If CONTACTADDRESSCODE = "" : CONTACTADDRESSCODE = [F:CNT]BPAADD : Endif

  Append CONTACTXML, '<LIN NUM=\"' + num$(LINENUMBER) + '\">'
  Append CONTACTXML,   '<FLD NAME=\"CCNCRM\" TYPE=\"Char\">' + CONTACTNUMBER + '</FLD>'
  Append CONTACTXML,   '<FLD NAME=\"CNTLNA\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTLASTNAME, "IN") + '</FLD>'
  Append CONTACTXML,   '<FLD NAME=\"CNTFNA\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTFIRSTNAME, "IN") + '</FLD>'
  Append CONTACTXML,   '<FLD MENULOCAL=\"941\" NAME=\"CNTTTL\" TYPE=\"Integer\">' + num$([F:AIN]CNTTTL) + '</FLD>'
  Append CONTACTXML,   '<FLD MENULOCAL=\"233\" NAME=\"CNTFNC\" TYPE=\"Integer\">' + num$([F:CNT]CNTFNC) + '</FLD>'
  Append CONTACTXML,   '<FLD NAME=\"CNTSRV\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS([F:CNT]CNTSRV, "IN") + '</FLD>'
  Append CONTACTXML,   '<FLD NAME=\"CNTADD\" TYPE=\"Char\">' + CONTACTADDRESSCODE + '</FLD>'
  Append CONTACTXML,   '<FLD NAME=\"CNTTEL\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTPHONE, "IN") + '</FLD>'
  Append CONTACTXML,   '<FLD NAME=\"CNTFAX\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTFAX, "IN") + '</FLD>'
  Append CONTACTXML,   '<FLD NAME=\"CNTMOB\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS([F:CNT]MOB, "IN") + '</FLD>'
  Append CONTACTXML,   '<FLD NAME=\"CNTWEB\" TYPE=\"Char\">' + func CRMSF.ESCAPECHARS(CONTACTEMAIL, "IN") + '</FLD>'
  Append CONTACTXML,   '<FLD NAME=\"CNTMSS\" TYPE=\"Char\">' + [F:CNT]CNTMSS + '</FLD>'
  If [F:AIN]CNTBIR=[00/00/00]
    Append CONTACTXML,   '<FLD NAME=\"CNTBIR\" TYPE=\"Date\"> </FLD>'
  Else
    Append CONTACTXML,   '<FLD NAME=\"CNTBIR\" TYPE=\"Date\">' + [F:AIN]CNTBIR + '</FLD>'
  Endif
  CHARPOS = instr(1, [F:AIN]CNTFULNAM, "\")
  CNTFULNAM = func CRMSF.ESCAPECHARS(left$([F:AIN]CNTFULNAM, CHARPOS), "IN") + "\" + func CRMSF.ESCAPECHARS(right$([F:AIN]CNTFULNAM, CHARPOS+1), "IN")
  Append CONTACTXML,   '<FLD NAME=\"CNTFULNAM\" TYPE=\"Char\">' + CNTFULNAM + '</FLD>'
  Append CONTACTXML,   '<FLD MENULOCAL=\"1\" NAME=\"CNTFBDMAG\" TYPE=\"Integer\">' + num$([F:AIN]CNTFBDMAG) + '</FLD>'
  Append CONTACTXML,   '<FLD NAME=\"CNTLAN\" TYPE=\"Char\">' + [F:AIN]CNTLAN + '</FLD>'
  Append CONTACTXML,   '<FLD NAME=\"CNTCSP\" TYPE=\"Char\">' + [F:AIN]CNTCSP + '</FLD>'
  If CONTACTNUMBER = [F:BPC]CNTNAM
    Append CONTACTXML,   '<FLD MENULOCAL=\"1\" NAME=\"CNTFLG\" TYPE=\"Integer\">2</FLD>'
  Else
    Append CONTACTXML,   '<FLD MENULOCAL=\"1\" NAME=\"CNTFLG\" TYPE=\"Integer\">1</FLD>'
  Endif
  Append CONTACTXML, '</LIN>'

End CONTACTXML

####################################################################################################

Funprog CONTACTHASADDRESS(CUSTOMERNUMBER, CONTACTNUMBER)

  Value Char CUSTOMERNUMBER
  Value Char CONTACTNUMBER

  Local Integer HASADDRESS

  If clalev([F:CNT]) = 0 : Local File CONTACT [CNT] : Endif

  Read [CNT]CNT0=1;CUSTOMERNUMBER;CONTACTNUMBER
  If !fstat
    HASADDRESS = [F:CNT]BPAADD<>""
  Else
    HASADDRESS = -1
  Endif

End HASADDRESS

####################################################################################################

Funprog GETADDRESSXML(CUSTOMERNUMBER, ADDRESSNUMBER, ADDRESS1, ADDRESS2, ADDRESS3, CITY, PROVINCECODE, POSTALCODE, COUNTRYCODE, LINENUMBER, ERRMSG)

  Value    Char    CUSTOMERNUMBER
  Value    Char    ADDRESSNUMBER
  Value    Char    ADDRESS1
  Value    Char    ADDRESS2
  Value    Char    ADDRESS3
  Value    Char    CITY
  Value    Char    PROVINCECODE
  Value    Char    POSTALCODE
  Value    Char    COUNTRYCODE
  Variable Integer LINENUMBER
  Variable Char    ERRMSG

  Local Clbfile ADDRESSXML

  LINENUMBER += 1

  # Get existing address data
  If clalev([F:BPA]) = 0 : Local File BPADDRESS [BPA] : Endif
  Read [F:BPA]BPA0=1;CUSTOMERNUMBER;ADDRESSNUMBER

  If ADDRESS1 = ""     : ADDRESS1     = [F:BPA]BPAADDLIG(0) : Endif
  If ADDRESS2 = ""     : ADDRESS2     = [F:BPA]BPAADDLIG(1) : Endif
  If ADDRESS3 = ""     : ADDRESS3     = [F:BPA]BPAADDLIG(2) : Endif
  If CITY = ""         : CITY         = [F:BPA]CTY          : Endif
  If PROVINCECODE = "" : PROVINCECODE = [F:BPA]SAT          : Endif
  If POSTALCODE = ""   : POSTALCODE   = [F:BPA]POSCOD       : Endif
  If COUNTRYCODE = ""  : COUNTRYCODE  = [F:BPA]CRY          : Endif

  Append ADDRESSXML, '<LIN NUM=\"' + num$(LINENUMBER) + '\">'
  Append ADDRESSXML,   '<FLD NAME=\"CODADR\" type=\"Char\">' + ADDRESSNUMBER + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"BPADES\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]BPADES, "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"BPACRY\" type=\"Char\">' + COUNTRYCODE + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"CRYNAM\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]CRYNAM, "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"ADDLIG1\" type=\"Char\">' + func CRMSF.ESCAPECHARS(ADDRESS1, "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"ADDLIG2\" type=\"Char\">' + func CRMSF.ESCAPECHARS(ADDRESS2, "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"ADDLIG3\" type=\"Char\">' + func CRMSF.ESCAPECHARS(ADDRESS3, "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"POSCOD\" type=\"Char\">' + func CRMSF.ESCAPECHARS(POSTALCODE, "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"CTY\" type=\"Char\">' + func CRMSF.ESCAPECHARS(CITY, "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"SAT\" type=\"Char\">' + func CRMSF.ESCAPECHARS(PROVINCECODE, "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"TEL1\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]TEL(0), "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"TEL2\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]TEL(1), "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"TEL3\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]TEL(2), "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"TEL4\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]TEL(3), "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"TEL5\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]TEL(4), "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"WEB1\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]WEB(0), "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"WEB2\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]WEB(1), "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"WEB3\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]WEB(2), "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"WEB4\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]WEB(3), "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"WEB5\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]WEB(4), "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"FCYWEB\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]FCYWEB, "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD NAME=\"EXTNUM\" type=\"Char\">' + func CRMSF.ESCAPECHARS([F:BPA]EXTNUM, "IN") + '</FLD>'
  Append ADDRESSXML,   '<FLD MENULAB=\"No\" MENULOCAL=\"1\" NAME=\"BPAADDFLG\" type=\"Integer\">1</FLD>'
  Append ADDRESSXML,   '<FLD MENULAB=\"No\" MENULOCAL=\"1\" NAME=\"ADRVAL\" type=\"Integer\">1</FLD>'
  Append ADDRESSXML, '</LIN>'

End ADDRESSXML

####################################################################################################

$CLEARRETURNVALUES

   # Don't use RAZ here because it will initialize all the dims of the variables
  # which causes a lot of extra fields in the returned XML

  CUSTOMERNUMBER                 = ""
  CUSTOMERNAME                   = ""

#  CONTACTNUMBER                  = ""
  CONTACTFIRSTNAME               = ""
  CONTACTLASTNAME                = ""
  CONTACTPHONE                   = ""
  CONTACTFAX                     = ""
  CONTACTEMAIL                   = ""

  CONTACTMAILINGADDRESSNUMBER    = ""
  CONTACTMAILINGADDRESS          = ""
  CONTACTMAILINGCITY             = ""
  CONTACTMAILINGPROVINCECODE     = ""
  CONTACTMAILINGPOSTALCODE       = ""
  CONTACTMAILINGCOUNTRYCODE      = ""

  LBLCUSTOMERNUMBER              = ""
  LBLCUSTOMERNAME                = ""

  LBLCONTACTNUMBER               = ""
  LBLCONTACTFIRSTNAME            = ""
  LBLCONTACTLASTNAME             = ""
  LBLCONTACTPHONE                = ""
  LBLCONTACTFAX                  = ""
  LBLCONTACTEMAIL                = ""

  LBLCONTACTMAILINGADDRESSNUMBER = ""
  LBLCONTACTMAILINGADDRESS       = ""
  LBLCONTACTMAILINGCITY          = ""
  LBLCONTACTMAILINGPROVINCECODE  = ""
  LBLCONTACTMAILINGPOSTALCODE    = ""
  LBLCONTACTMAILINGCOUNTRYCODE   = ""

Return

####################################################################################################

$ DATARECEIVED

  OK=fmet MYLOG.APUTLINE("\Dump of data in\",OK) : OK=fmet MYLOG.AFLUSHLOG   # TODO translation

  OK=fmet MYLOG.APUTLINE("CUSTOMERNUMBER ="-CUSTOMERNUMBER,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("CUSTOMERNAME ="-CUSTOMERNAME,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("",OK) : OK=fmet MYLOG.AFLUSHLOG

  OK=fmet MYLOG.APUTLINE("    CONTACTNUMBER ="-CONTACTNUMBER,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("    CONTACTFIRSTNAME ="-CONTACTFIRSTNAME,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("    CONTACTLASTNAME ="-CONTACTLASTNAME,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("    CONTACTPHONE ="-CONTACTPHONE,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("    CONTACTFAX ="-CONTACTFAX,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("    CONTACTEMAIL ="-CONTACTEMAIL,OK) : OK=fmet MYLOG.AFLUSHLOG

  OK=fmet MYLOG.APUTLINE("    CONTACTMAILINGADDRESSNUMBER ="-CONTACTMAILINGADDRESSNUMBER,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("    CONTACTMAILINGADDRESS ="-CONTACTMAILINGADDRESS,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("    CONTACTMAILINGCITY ="-CONTACTMAILINGCITY,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("    CONTACTMAILINGPROVINCECODE ="-CONTACTMAILINGPROVINCECODE,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("    CONTACTMAILINGPOSTALCODE ="-CONTACTMAILINGPOSTALCODE,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("    CONTACTMAILINGCOUNTRYCODE ="-CONTACTMAILINGCOUNTRYCODE,OK) : OK=fmet MYLOG.AFLUSHLOG
  OK=fmet MYLOG.APUTLINE("",OK) : OK=fmet MYLOG.AFLUSHLOG

Return

