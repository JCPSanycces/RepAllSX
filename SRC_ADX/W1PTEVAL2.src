#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PTEVAL2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:10"
A_USER  = "DOC"
A_STAMP = "20181109230610"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PTEVAL2 [PJT2]
Gosub HORODAT
Local Inpbox "PTEVAL2" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJT2] As [SIM_]
Grizo [PJT2]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJT2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=25
Return

$ON_CLB
Return

$ON_ZCLB
Onevent BEFORE_AREA Gosub AV_ZCLB From W1PTEVAL2
Return

$AV_ZCLB
Call LECTEXTRA(zc,"AUTILIS","INTUSR",num$([M]CLB(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_PTEDAT
Onevent BEFORE_AREA Gosub AV_PTEDAT From W1PTEVAL2
Return

$AV_PTEDAT
Chgfmt [M]PTEDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_OPPNUM
Return

$ON_ZOPPNUM
Onevent BEFORE_AREA Gosub AV_ZOPPNUM From W1PTEVAL2
Return

$AV_ZOPPNUM
Call LECTEXTRA(zc,"PIMPL","PIMDESAXX",num$([M]OPPNUM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_TASCOD
Return

$ON_PIMTASCOD
Return

$ON_OPENUM
Return

$ON_PBUCOD
Return

$ON_PIMPBUCOD
Return

$ON_PTEDESAXX
Onevent INIT_AREA Call D_PTEDESAXX(zc) From W1PTEVAL2
Return

Subprog D_PTEDESAXX(VALEUR)
Variable Char    VALEUR()
If varinit([M]PTEDESAXX,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"PJMTIMEMP","PTEDESAXX",func SUBPTEVAL.GET_KEYCONCAT_PJT2(),AVOID.ACHAR) From ATEXTRA
Endif
Gosub _AFF
End

$ON_PTEUOM
Return

$ON_PTEQTY
Onevent BEFORE_AREA Gosub AV_PTEQTY From W1PTEVAL2
Return

$AV_PTEQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find([M:PJT1]PTEUOM(nolign-1),GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]PTEQTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_PTESTA
Onevent INIT_AREA Call D_PTESTA(zc) From W1PTEVAL2
Return

Subprog D_PTESTA(VALEUR)
Variable Integer VALEUR
If varinit([M]PTESTA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


