#<AdxTL>@(#)12.0.0.0 $Revision$
###############################################################################################################
#
#   Génération XML d'une Affaire                                                        Version 140
#   Module CRM                             
#
#   XXXINXML    : Objet unique avec ses tables liées en multi-niveaux.
#   XXXLISTXML  : Liste filtrée de la table objet.
#   
###############################################################################################################

Subprog OPPINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF
ICHAPTER = 0
IERRINF = 0
SZFULLRETFILE = ""
SZRETFILENAME = ""

If SZRECNUM = "" : End : Endif

Gosub XMLPART1 From CRMXML140

Call TEXTE(18260, SZHTMLTITLE) From OBJDIV      #Affaire
SZSUBPROG = "OPPINXML"
SZAOBABREV = "OPP"

Gosub XMLPART2 From CRMXML140
If IERRINF : End : Endif

Gosub DOCOREXML

Gosub XMLPART3 From CRMXML140

End

#########################################################################################################################
Subprog OPPLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZCUSTFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFILTER
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF
ICHAPTER = 0
IERRINF = 0
SZFULLRETFILE = ""
SZRETFILENAME = ""

If SZFILTER = ""
    SZFILTER = "1=1"
Endif

Gosub XMLPART1 From CRMXML140

Call TEXTE(14667, SZHTMLTITLE) From OBJDIV      #Affaires
SZSUBPROG = "OPPLISTXML"
SZAOBABREV = "OPP"

Gosub XMLPART2B From CRMXML140
If IERRINF : End : Endif

Gosub DOLISTXML

Gosub XMLPART3 From CRMXML140

End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOLISTXML

Gosub SETOPPEXCEPT From CRMEXCEPT

#On extrait
Filter [OPP] Where evalue(SZFILTER)

For [OPP]
    SZCTAOB = "OPP"
    SZCTAOBNUM = [F:OPP]OPPNUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLOPP From CRMEXCEPT
Next

Filter [OPP]
Return

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREXML

Gosub SETOPPEXCEPT From CRMEXCEPT

########################################################
#Variable particulière pour affaire associée
Local Integer IDIMCODSOL
IDIMCODSOL = dim([F:OPP]SBBPJT)
Local Char SZCODSOL(30)(IDIMCODSOL)
Local Integer ITERCODSOL
ITERCODSOL = 0
Raz SZCODSOL
########################################################

#On extrait
Filter [OPP] Where [F:OPP]OPPNUM = SZRECNUM

For [OPP]
    SZCTAOB = "OPP"
    SZCTAOBNUM = [F:OPP]OPPNUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLOPP From CRMEXCEPT

    ITERCODSOL = 0
    For ITERCODSOL = 0 To dim([F:OPP]SBBPJT) - 1
        SZCODSOL(ITERCODSOL) = [F:OPP]SBBPJT(ITERCODSOL)
    Next
Next

Filter [OPP]

If IDISPLAYOPP
    ITERCODSOL = 0
    For ITERCODSOL = 0 To dim(SZCODSOL) - 1
        If SZCODSOL(ITERCODSOL) <> ""
            Read [OPP] OPP0 = SZCODSOL(ITERCODSOL)
            If !fstat
                SZCTAOB = "OPP"
                SZCTAOBNUM = [F:OPP]OPPNUM
                SZCTLEVEL = "1"
                SZCTPARENTAOB = "OPP"
                SZCTPARENTNUM = SZRECNUM
                Gosub XMLOPP2 From CRMEXCEPT
            Endif
        Endif
    Next
Endif

Return



