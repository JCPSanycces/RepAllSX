#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
# Controle des flux autorises en inter-sites et inter-sociétés
################################################################################
########################################################################################
# Test suite Process FUNBCH_SYRA : QLFSA_FUNBCH_SYRA
# CPO 02/01/2014
# launch with : func qlfsa_funbch_syra.testsuite in the Eclipse console
########################################################################################
Subprog IS_FLUX (VCRTYP,FCYORI,FCYDES,PTRFPRI,STAT)
Value    Integer VCRTYP       : # document (2=cde vente / 5=fac vente / 14=cde achat)
Value    Char    FCYORI ()    : # site origine
Value    Char    FCYDES ()    : # site destinataire
Variable Integer PTRFPRI      : # 1-Non/2-Oui     : # Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
Variable Integer STAT         : # 0=interdit / 1=autorise

Local    Integer TYPBET       : # type de flux (1=intra-societe / 2=inter-societes)
Local    Char    CPYORI(GLONCPY)       : # societe origine
Local    Char    CPYDES(GLONCPY)       : # societe destinataire
Local    Integer IJL

Local File BETCPYL  [BCL]
Local File AGRPCPY  [AGC]
Local File FACGROUP [FGR]

Local File FACILITY [FCY]
Local File COMPANY  [CPY]

STAT=0

If FCYORI ="" or FCYDES = "" : Goto FIN0   Endif
#--- recherche societe origine
Read [F:FCY]FCY0=FCYORI
If fstat Raz [F:FCY] : Goto FIN0   Endif
CPYORI=[F:FCY]LEGCPY

#--- recherche societe destinataire
Read [F:FCY]FCY0=FCYDES
If fstat Raz [F:FCY] : Goto FIN0   Endif
CPYDES=[F:FCY]LEGCPY

#--- determination du flux ( 1=intra-société / 2=inter-sociétés )
If CPYORI=CPYDES   TYPBET=1   Else   TYPBET=2   Endif

# Il faut lire selon l'index BCL1(FLG1234+NUMERO)
For [BCL]BCL1 Where TYPBET=[L]TYPBET & VCRTYP=[L]VCRTYP
    #---  societe origine
    If [F:BCL]FLG1CPYORI=1 & CPYORI<>[F:BCL]GRPCPYORI : Goto NOK0 : Endif
    If [F:BCL]FLG1CPYORI=2
       Look [AGC]AGC0=[F:BCL]GRPCPYORI;CPYORI
       If fstat : Goto NOK0 : Endif
    Endif
    #---  site origine
    If [F:BCL]FLG2FCYORI=1 & FCYORI<>[F:BCL]GRPFCYORI : Goto NOK0 : Endif
    If [F:BCL]FLG2FCYORI=2
       Look [FGR]FGR0=[F:BCL]GRPFCYORI;FCYORI
       If fstat : Goto NOK0 : Endif
    Endif
    #---  societe destination
    If [F:BCL]FLG3CPYDES=1 & CPYDES<>[F:BCL]GRPCPYDES : Goto NOK0 : Endif
    If [F:BCL]FLG3CPYDES=2
       Look [AGC]AGC0=[F:BCL]GRPCPYDES;CPYDES
       If fstat : Goto NOK0 : Endif
    Endif
    #---  site destination
    If [F:BCL]FLG4FCYDES=1 & FCYDES<>[F:BCL]GRPFCYDES : Goto NOK0 : Endif
    If [F:BCL]FLG4FCYDES=2
       Look [FGR]FGR0=[F:BCL]GRPFCYDES;FCYDES
       If fstat : Goto NOK0 : Endif
    Endif

    #--- autorisation flux
    If [F:BCL]AUZBETFLG=1 : STAT=0 : Endif
    If [F:BCL]AUZBETFLG=2 : STAT=1 : Endif

    PTRFPRI = [F:BCL]TRFPRI : # Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
    Break

$NOK0
Next

$FIN0

End

