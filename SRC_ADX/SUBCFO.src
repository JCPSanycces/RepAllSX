Local Integer INCRE
If VALEUR = [0/0/0] and [M:CFO1]ACCDAT=[0/0/0]
#   #GMESSAGE=mess(503,177,1): mkstat=2: End
   zonsui="ACCDAT"
   End
Endif

If [M:CFO0]RCR<>2 and VALEUR<date$
   mkstat=2
Endif
End
######################### PAM ###############################################################
Subprog AM_PAM(VALEUR)
Variable Char    VALEUR()
If GREP<>"C"
  [M:CFO0]CFOSTA=1
  Affzo [M:CFO0]CFOSTA
Endif
End
####################### typper ##############################################################
Subprog AM_TYPPER(VALEUR)
Variable Integer VALEUR
Local Integer N1, X
Raz N1
If VALEUR=2
   Raz [M:CFO1]DAYS:  Affzo [M:CFO1]DAYS
Endif
If VALEUR=3

   For X=1 To 7
     If [M:CFO1]DAYS(X-1)=2 and N1=1
        Raz [M:CFO1]DAYS(X-1)
     Endif
     If [M:CFO1]DAYS(X-1)=2 and N1=0
        N1=1
     Endif
   Next
   Affzo [M:CFO1]DAYS
Endif

If VALEUR=4
   For X=7 To 1 Step -1
     If [M:CFO1]DAYS(X-1)=2 and N1=1
        Raz [M:CFO1]DAYS(X-1)
     Endif
     If [M:CFO1]DAYS(X-1)=2 and N1=0
        N1=1
     Endif
   Next
   Affzo [M:CFO1]DAYS
Endif

If GREP<>"C"
  [M:CFO0]CFOSTA=1
  Affzo [M:CFO0]CFOSTA
Endif
End

############################## PERIOD ##################################################
Subprog AM_RCR(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
   Raz [M:CFO1]TYPPER,[M:CFO1]IRT,[M:CFO1]ENDDAT,[M:CFO1]DAYS
   Affzo [M:CFO1]TYPPER: Grizo [M:CFO1]TYPPER
   Affzo [M:CFO1]IRT: Grizo [M:CFO1]IRT
   Affzo [M:CFO1]ENDDAT: Grizo [M:CFO1]ENDDAT
   Affzo [M:CFO1]DAYS: Grizo [M:CFO1]DAYS
Else
   Actzo [M:CFO1]TYPPER
   Actzo [M:CFO1]IRT
   Actzo [M:CFO1]ENDDAT
   Actzo [M:CFO1]DAYS
Endif
If GREP<>"C"
  [M:CFO0]CFOSTA=1
  Affzo [M:CFO0]CFOSTA
Endif
End
