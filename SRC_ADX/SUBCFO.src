Endif
End

######################################################################################
## Calculation of the open items in the [M:CFO2] screen
#####################################################################################
$CALC_OPEN_ITEM

Local Char    MODECHE(5)(1..)      : # Mode règlement / échéance
Local Integer TYPECHE  (1..)       : # Type règlement / échéance
Local Decimal MNTECHE(1..)         : # Montant        / échéance
Local Date    DATECHE(1..)         : # Date           / échéance
Local Integer RELEVE(1..)          : # =2 si relevé à faire
Local Shortint NECHE               : # Nb échéance
Local Integer X

## Calculation of the delay in function of the behavior of payments customer
Local Integer DELAY_DAY
Raz DELAY_DAY
If val(CFOPAYSTT)<>0 and [M:CFO0]SNS=2 : Gosub CALC_DELAY: Endif

Raz [M:CFO2]NBLIG, [M:CFO2]DAT, [M:CFO2]AMTCUR, [M:CFO2]PAMDET
Affzo [M:CFO2]NBLIG
Affzo [M:CFO2]DAT
Affzo [M:CFO2]AMTCUR
Affzo [M:CFO2]PAMDET

If [M:CFO0]CFOSTA>2: Return: Endif ## Only for active or inactive documents
If [M:CFO0]RCR<>2 ## Non-periodic document
  If [M:CFO1]CFODAT<>[0/0/0] and [M:CFO1]CFODAT>=date$-HORPAST
     [M:CFO2]NBLIG=1
     [M:CFO2]DAT(0)=[M:CFO1]CFODAT+DELAY_DAY
     [M:CFO2]PAMDET(0)=[M:CFO1]PAM
     [M:CFO2]AMTCUR(0)=[M:CFO1]AMTATI
     Affzo [M:CFO2]
  Else
    Call LEC_TCU([M:CFO1]CUR) From CPTLEC
    Call DATECHE([M:CFO1]PTE,[M:CFO1]ACCDAT,[M:CFO1]AMTATI,[F:TCU]CURRND,MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE,NECHE,[M:CFO0]FCY) From SUBTPT
    For X=1 To NECHE
      If DATECHE(X)>=date$-HORPAST and X<20
       [M:CFO2]DAT(X-1)=DATECHE(X)+DELAY_DAY
       [M:CFO2]AMTCUR(X-1)=MNTECHE(X)
       [M:CFO2]PAMDET(X-1)=MODECHE(X)
       [M:CFO2]NBLIG+=1
      Endif
    Next
  Endif
Else ## Periodic document
  Case [M:CFO1]TYPPER
    When 1: Gosub CALC_OPEN_ITEM_WEEK  ### Weekly
    When 2: Gosub CALC_OPEN_ITEM_MONTH ### Monthly
    When 3: Gosub CALC_OPEN_ITEM_FIRST ### fist xx of the month
    When 4: Gosub CALC_OPEN_ITEM_LAST  ### last xx of the month
  Endcase
Endif
 Sorta [M:CFO2]NBLIG [M:CFO2]DAT,[M:CFO2]AMTCUR,[M:CFO2]PAMDET
 Affzo [M:CFO2]
Return

$CALC_OPEN_ITEM_WEEK
## Calculation of the open items in the [M:CFO2] screen (Peridicity weekly)
Local Integer NUMOT, X,Y
Local Date DATOPE
Local Date DATINIWEEK

Raz NUMOT
If !find(2,[M:CFO1]DAYS)
   If [M:CFO1]CFODAT<>[0/0/0]
      [M:CFO1]DAYS(dayn([M:CFO1]CFODAT)-1)=2
   Else
      [M:CFO1]DAYS(dayn([M:CFO1]ACCDAT)-1)=2
   Endif
Endif

If [M:CFO1]CFODAT<>[0/0/0]
   If [M:CFO1]CFODAT>=date$-HORPAST
      DATINIWEEK=[M:CFO1]CFODAT-dayn([M:CFO1]CFODAT)+1
   Else
      DATINIWEEK=date$-HORPAST-dayn(date$-HORPAST)+1
   Endif
   While DATINIWEEK <= [M:CFO1]ENDDAT and NUMOT<20
   For X=1 To 7
      If [M:CFO1]DAYS(X-1)=2
        DATOPE = DATINIWEEK+(X-1)
        If DATOPE>= [M:CFO1]CFODAT and DATOPE<=[M:CFO1]ENDDAT and DATOPE>=date$-HORPAST and NUMOT<20
           NUMOT+=1
           [M:CFO2]DAT(NUMOT-1)=DATOPE+DELAY_DAY
           [M:CFO2]PAMDET(NUMOT-1)=[M:CFO1]PAM
           [M:CFO2]AMTCUR(NUMOT-1)=[M:CFO1]AMTATI
           [M:CFO2]NBLIG=NUMOT
        Endif
      Endif
   Next
   DATINIWEEK+=7*[M:CFO1]IRT
   Wend
Else
  Call LEC_TCU([M:CFO1]CUR) From CPTLEC ## we need the [F:TCU]CURRND
  If [M:CFO1]ACCDAT>date$-HORPAST
     DATINIWEEK=[M:CFO1]ACCDAT-dayn([M:CFO1]ACCDAT)+1
  Else
      DATINIWEEK=date$-HORPAST-dayn(date$-HORPAST)+1
  Endif
  While DATINIWEEK <= [M:CFO1]ENDDAT and NUMOT<20
  For X=1 To 7
    If [M:CFO1]DAYS(X-1)=2
      DATOPE = DATINIWEEK + (X-1)
       If DATOPE>= [M:CFO1]CFODAT and DATOPE<=[M:CFO1]ENDDAT and DATOPE>=date$-HORPAST
        Call DATECHE([M:CFO1]PTE,DATOPE,[M:CFO1]AMTATI,[F:TCU]CURRND,MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE,NECHE,[M:CFO0]FCY) From SUBTPT
        For Y=1 To NECHE
         If DATECHE(Y)>=date$-HORPAST and NUMOT<20
           NUMOT+=1
           [M:CFO2]DAT(NUMOT-1)=DATECHE(Y)+DELAY_DAY
           [M:CFO2]AMTCUR(NUMOT-1)=MNTECHE(Y)
           [M:CFO2]PAMDET(NUMOT-1)=MODECHE(Y)
           [M:CFO2]NBLIG+=1
         Endif
        Next
       Endif
    Endif
  Next
  DATINIWEEK+=7*[M:CFO1]IRT
  Wend
Endif
Return

## Calculation of the open items in the [M:CFO2] screen (Peridicity monthly)
$CALC_OPEN_ITEM_MONTH
Local Integer NUMOT, X
Local Date DATOPE


Raz NUMOT
If [M:CFO1]CFODAT<>[0/0/0]
   If [M:CFO1]CFODAT>=date$-HORPAST
      DATOPE = [M:CFO1]CFODAT
   Else
      DATOPE = gdat$(day([M:CFO1]CFODAT),month(date$-HORPAST), year(date$-HORPAST))
   Endif
   While DATOPE <= [M:CFO1]ENDDAT and NUMOT<20
    If DATOPE>= [M:CFO1]CFODAT and DATOPE<=[M:CFO1]ENDDAT and DATOPE>=date$-HORPAST and NUMOT<20
       NUMOT+=1
       [M:CFO2]DAT(NUMOT-1)=DATOPE+DELAY_DAY
       [M:CFO2]PAMDET(NUMOT-1)=[M:CFO1]PAM
       [M:CFO2]AMTCUR(NUMOT-1)=[M:CFO1]AMTATI
       [M:CFO2]NBLIG=NUMOT
     Endif
    DATOPE = gdat$(day(DATOPE),month(DATOPE)+[M:CFO1]IRT,year(DATOPE))
   Wend
Else
   Call LEC_TCU([M:CFO1]CUR) From CPTLEC
   If [M:CFO1]ACCDAT>=date$-HORPAST
      DATOPE = [M:CFO1]ACCDAT
   Else
      DATOPE = gdat$(day([M:CFO1]ACCDAT),month(date$-HORPAST), year(date$-HORPAST))
   Endif
   While DATOPE <= [M:CFO1]ENDDAT and NUMOT<20
    If DATOPE>= [M:CFO1]ACCDAT and DATOPE<=[M:CFO1]ENDDAT and DATOPE>=date$-HORPAST and NUMOT<20
      Call DATECHE([M:CFO1]PTE,DATOPE,[M:CFO1]AMTATI,[F:TCU]CURRND,MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE,NECHE,[M:CFO0]FCY) From SUBTPT
        For Y=1 To NECHE
         If DATECHE(Y)>=date$-HORPAST and NUMOT<20
           NUMOT+=1
           [M:CFO2]DAT(NUMOT-1)=DATECHE(Y)+DELAY_DAY
           [M:CFO2]AMTCUR(NUMOT-1)=MNTECHE(Y)
           [M:CFO2]PAMDET(NUMOT-1)=MODECHE(Y)
           [M:CFO2]NBLIG+=1
         Endif
        Next
     Endif
   DATOPE = gdat$(day(DATOPE),month(DATOPE)+[M:CFO1]IRT,year(DATOPE))
   Wend

Endif
Return

## Calculation of the open items in the [M:CFO2] screen (Peridicity first XX of each month)
$CALC_OPEN_ITEM_FIRST
Local Integer NUMOT, X
Local Date DATOPE
Local Date DATINIMONTH

If [M:CFO1]CFODAT<>[0/0/0]
   If [M:CFO1]CFODAT>=date$-HORPAST
      DATINIMONTH = gdat$(1,month([M:CFO1]CFODAT), year([M:CFO1]CFODAT))
   Else
      DATINIMONTH = gdat$(1,month(date$-HORPAST), year(date$-HORPAST))
   Endif
   While DATINIMONTH <= [M:CFO1]ENDDAT and NUMOT<20
      X=find(2,[M:CFO1]DAYS())
      If X
        If dayn(DATINIMONTH) = X : DATOPE=DATINIMONTH: Endif
        If dayn(DATINIMONTH) < X : DATOPE=DATINIMONTH+X-dayn(DATINIMONTH): Endif
        If dayn(DATINIMONTH) > X : DATOPE=DATINIMONTH+7+X-dayn(DATINIMONTH): Endif
      Else
        DATOPE=DATINIMONTH
      Endif

      If DATOPE>= [M:CFO1]CFODAT and DATOPE<=[M:CFO1]ENDDAT and DATOPE>=date$-HORPAST and NUMOT<20
        NUMOT+=1
        [M:CFO2]DAT(NUMOT-1)=DATOPE+DELAY_DAY
        [M:CFO2]PAMDET(NUMOT-1)=[M:CFO1]PAM
        [M:CFO2]AMTCUR(NUMOT-1)=[M:CFO1]AMTATI
        [M:CFO2]NBLIG=NUMOT
      Endif
      DATINIMONTH = gdat$(1,month(DATINIMONTH)+[M:CFO1]IRT,year(DATINIMONTH))
   Wend
Else
   Call LEC_TCU([M:CFO1]CUR) From CPTLEC
   If [M:CFO1]ACCDAT>=date$-HORPAST
      DATINIMONTH = gdat$(1,month([M:CFO1]ACCDAT), year([M:CFO1]ACCDAT))
   Else
      DATINIMONTH = gdat$(1,month(date$-HORPAST), year(date$-HORPAST))
   Endif
   While DATINIMONTH <= [M:CFO1]ENDDAT and NUMOT<20
      X=find(2,[M:CFO1]DAYS())
      If X
        If dayn(DATINIMONTH) = X : DATOPE=DATINIMONTH: Endif
        If dayn(DATINIMONTH) < X : DATOPE=DATINIMONTH+X-dayn(DATINIMONTH): Endif
        If dayn(DATINIMONTH) > X : DATOPE=DATINIMONTH+7+X-dayn(DATINIMONTH): Endif
      Else
        DATOPE=DATINIMONTH
      Endif

      If DATOPE>= [M:CFO1]CFODAT and DATOPE<=[M:CFO1]ENDDAT and DATOPE>=date$-HORPAST and NUMOT<20
        Call DATECHE([M:CFO1]PTE,DATOPE,[M:CFO1]AMTATI,[F:TCU]CURRND,MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE,NECHE,[M:CFO0]FCY) From SUBTPT
        For Y=1 To NECHE
         If DATECHE(Y)>=date$-HORPAST and NUMOT<20
           NUMOT+=1
           [M:CFO2]DAT(NUMOT-1)=DATECHE(Y)+DELAY_DAY
           [M:CFO2]AMTCUR(NUMOT-1)=MNTECHE(Y)
           [M:CFO2]PAMDET(NUMOT-1)=MODECHE(Y)
           [M:CFO2]NBLIG+=1
         Endif
        Next
      Endif
      DATINIMONTH = gdat$(1,month(DATINIMONTH)+[M:CFO1]IRT,year(DATINIMONTH))
   Wend

Endif
Return

## Calculation of the open items in the [M:CFO2] screen (Peridicity last XX of each month)
$CALC_OPEN_ITEM_LAST
Local Integer NUMOT, X
Local Date DATOPE
Local Date DATENDMONTH

If [M:CFO1]CFODAT<>[0/0/0]
   If [M:CFO1]CFODAT>=date$-HORPAST
      DATENDMONTH = eomonth([M:CFO1]CFODAT)
   Else
      DATENDMONTH = eomonth(date$-HORPAST)
   Endif
   While DATENDMONTH <= eomonth([M:CFO1]ENDDAT) and NUMOT<20
      X=find(2,[M:CFO1]DAYS())
      If X
        If dayn(DATENDMONTH) = X : DATOPE=DATENDMONTH: Endif
        If dayn(DATENDMONTH) > X : DATOPE=DATENDMONTH+X-dayn(DATENDMONTH): Endif
        If dayn(DATENDMONTH) < X : DATOPE=DATENDMONTH-7+X-dayn(DATENDMONTH): Endif
      Else
        DATOPE=DATENDMONTH
      Endif

      If DATOPE>= [M:CFO1]CFODAT and DATOPE<=[M:CFO1]ENDDAT and DATOPE>=date$-HORPAST and NUMOT<20
        NUMOT+=1
        [M:CFO2]DAT(NUMOT-1)=DATOPE+DELAY_DAY
        [M:CFO2]PAMDET(NUMOT-1)=[M:CFO1]PAM
        [M:CFO2]AMTCUR(NUMOT-1)=[M:CFO1]AMTATI
        [M:CFO2]NBLIG=NUMOT
      Endif
      DATENDMONTH = eomonth(gdat$(1,month(DATENDMONTH)+[M:CFO1]IRT,year(DATENDMONTH)))
   Wend
Else
   Call LEC_TCU([M:CFO1]CUR) From CPTLEC
   If [M:CFO1]ACCDAT>=date$-HORPAST
      DATENDMONTH = eomonth([M:CFO1]ACCDAT)
   Else
      DATENDMONTH = eomonth(date$-HORPAST)
   Endif
   While DATENDMONTH <= eomonth([M:CFO1]ENDDAT) and NUMOT<20
      X=find(2,[M:CFO1]DAYS())
      If X
        If dayn(DATENDMONTH) = X : DATOPE=DATENDMONTH: Endif
        If dayn(DATENDMONTH) > X : DATOPE=DATENDMONTH+X-dayn(DATENDMONTH): Endif
        If dayn(DATENDMONTH) < X : DATOPE=DATENDMONTH-7+X-dayn(DATENDMONTH): Endif
      Else
        DATOPE=DATENDMONTH
      Endif

      If DATOPE>= [M:CFO1]CFODAT and DATOPE<=[M:CFO1]ENDDAT and DATOPE>=date$-HORPAST and NUMOT<20
       Call DATECHE([M:CFO1]PTE,DATOPE,[M:CFO1]AMTATI,[F:TCU]CURRND,MODECHE,TYPECHE,MNTECHE,DATECHE,RELEVE,NECHE,[M:CFO0]FCY) From SUBTPT
        For Y=1 To NECHE
         If DATECHE(Y)>=date$-HORPAST and NUMOT<20
           NUMOT+=1
           [M:CFO2]DAT(NUMOT-1)=DATECHE(Y)+DELAY_DAY
           [M:CFO2]AMTCUR(NUMOT-1)=MNTECHE(Y)
           [M:CFO2]PAMDET(NUMOT-1)=MODECHE(Y)
           [M:CFO2]NBLIG+=1
         Endif
        Next
      Endif
      DATENDMONTH = eomonth(gdat$(1,month(DATENDMONTH)+[M:CFO1]IRT,year(DATENDMONTH)))
   Wend


Endif
Return

### Reading of the setup of CFO type by company
Subprog CALC_CFOTYP(CPY,FCY,CFOTYP,HORPAST,SNS,FLG, TYPRAT, TDAYS, INCRE)
Value Char CPY
Value Char FCY
Value Integer CFOTYP
Variable Integer HORPAST
Variable Integer SNS
Variable Integer FLG
Variable Integer TYPRAT
Variable Integer TDAYS()
Variable Integer INCRE

SNS=0: FLG=1: HORPAST=0
If !clalev([CFOT]): Local File CFOTYP [CFOT]: Endif
Raz [F:CFOT]
Read [CFOT]CFOT1=CPY;FCY;CFOTYP
If fstat
   Read [CFOT]CFOT1=CPY;"";CFOTYP
Endif
HORPAST=[F:CFOT]PASHOR
SNS=[F:CFOT]SNS
FLG=[F:CFOT]FLG
TYPRAT=[F:CFOT]TYPRAT
TDAYS(0)=[F:CFOT]DAY1: TDAYS(1)=[F:CFOT]DAY2: TDAYS(2)=[F:CFOT]DAY3
INCRE=[F:CFOT]DAYINC
End


######################################################################################
## Creation of the record in the [F:CFDD] table from [F:CFOMM] open items
$CRE_CFODUD
Local Integer STAT
Local Decimal EXE, PER


If [F:CFOMM]CFOSTA=1 or [F:CFOMM]CFOSTA=3  ## Only when the status is Active or modified (not Inative or Obsolete)
 For X=0 To 19
  If [F:CFOMM]DAT(X)=[0/0/0]: Break : Endif
  Raz [F:CFODD]
  [F:CFODD]=[F:CFOMM]
  [F:CFODD]TYP="*CM"+format$("N0:2#",[F:CFOMM]CFOTYP)
  [F:CFODD]LIG=[F:CFOMM]CFOLIN
  [F:CFODD]DUDLIG=X+1
  [F:CFODD]BPR=[F:CFOMM]BPRNUM
  [F:CFODD]BPRPAY=[F:CFOMM]BPRNUM
  [F:CFODD]CFODAT=[F:CFOMM]DAT(X)
  [F:CFODD]PAM=[F:CFOMM]PAMDET(X)
  [F:CFODD]AMTCUR=[F:CFOMM]AMTCUR(X)
  [F:CFODD]CFOBAN=[F:CFOMM]BAN
  [F:CFODD]PAMTYP=1
  [F:CFODD]DUDSTA=2
  [F:CFODD]FLGCLE=1

  [F:CFODD]SNS=1
  If [F:CFOMM]SNS=1
     [F:CFODD]SNS=-1
  Endif


  # BPRTYP field #################################
  Call LEC_BPR([F:CFODD]BPR) From CPTLEC
  If    [F:BPR]BPCFLG=2  & [F:BPR]BPSFLG<>2 : [F:CFODD]BPRTYP = 1 : # Client
  Elsif [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG=2  : [F:CFODD]BPRTYP = 2 : # Fourn
  Endif
  If [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG<>2
   If [F:BPR]BPTFLG=2                        : [F:CFODD]BPRTYP = 3 : # Transporteur
   Elsif [F:BPR]FCTFLG=2                     : [F:CFODD]BPRTYP = 4 : # Factor
   Elsif [F:BPR]REPFLG=2                     : [F:CFODD]BPRTYP = 5 : # Représentant
   Elsif [F:BPR]BPRACC=2                     : [F:CFODD]BPRTYP = 6 : # Tiers divers
   Endif
  Endif

  If [F:CFODD]BPRTYP=0
       If !clalev([GAC]): Local File GACCOUNT [GAC]: Endif
       Read [GAC]GAC1=[F:CFOMM]COA;[F:CFODD]SAC
       If !fstat
         Call LECTURE("GAC",[F:GAC]ACC,[F:CFOMM]COA) From CONTOBJ
         If    [F:GAC]AUZBPR(0)=2  & [F:GAC]AUZBPR(1)<>2 : [F:CFODD]BPRTYP = 1 : # Client
         Elsif [F:GAC]AUZBPR(0)<>2 & [F:GAC]AUZBPR(1)=2  : [F:CFODD]BPRTYP = 2 : # Fourn
         Elsif [F:GAC]UPDBLC=2                           : [F:CFODD]BPRTYP = 1 : # Client
         Elsif [F:GAC]UPDBLC=3                           : [F:CFODD]BPRTYP = 2 : # Fournisseur
         Endif
       Endif

       If [F:CFODD]BPRTYP=0
        If [F:CFODD]SNS=1 : [F:CFODD]BPRTYP = 2 : Else : [F:CFODD]BPRTYP = 1 : Endif
      Endif
  Endif

     If [F:CFODD]BPRTYP=1:  [F:CFODD]FLGPAZ= len(mess(0,510,1))
     Else [F:CFODD]FLGPAZ= 1: Endif

  ## BPRPAY #########################################################
   If [F:CFODD]BPRTYP=1
     If clalev([F:BPC]) = 0 : Local File BPCUSTOMER [BPC] : Endif
     Read [BPC]BPC0=[F:CFODD]BPRPAY
     If !fstat
       [F:CFODD]BPAPAY = [F:BPC]BPAPYR
     Endif
   Elsif [F:CFODD]BPRTYP = 2
     If clalev([F:BPS]) = 0 : Local File BPSUPPLIER [BPS] : Endif
     Read [BPS]BPS0=[F:CFODD]BPRPAY
     If !fstat
      [F:CFODD]BPAPAY = [F:BPS]BPAPAY
     Endif
   Else
     If clalev([F:BPR]) = 0 : Local File BPARTNER [BPR] : Endif
     Read [BPR]BPR0=[F:CFODD]BPRPAY
     If !fstat
      [F:CFODD]BPAPAY = [F:BPR]BPAADD
     Endif
   Endif

  ### EXE and PER
  Call GETPERSOC([F:CFODD]CPY,1,[F:CFODD]CFODAT,EXE, PER) From CPTSUB
  [F:CFODD]FIY=EXE
  [F:CFODD]PER=PER

  ### Currency
  Call LEC_CPY([F:CFODD]CPY) From CPTLEC
  Call CONVERT([F:CFODD]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[F:CFOMM]TYPRAT,[F:CFODD]CFODAT,[F:CFODD]AMTCUR,[F:CFODD]AMTLOC,STAT) From TRTDEV
  If STAT
  Call ECR_TRACE(mess(16,114,1)-[F:CFODD]CUR-"->"-[F:CPY]ACCCUR-"("+format$("D:"+GFMDAT,[F:CFODD]CFODAT)
&       -")",[L]STAT) From GESECRAN
   GOK=0 : Break
Endif
  Write [F:CFODD]
  If fstat
     GOK=0
     STAT=1
     Call FSTA("CFODD") From GLOCK
  Endif
 Next
Endif
Return

#####################################################################################
## Calculation of the delay in function of the behavior of payments customer
$CALC_DELAY
Return
If !clalev([F:DUD]): Local File GACCDUDATE [DUD]: Endif
Local Decimal TOT_DUD
Local Decimal TOT_DUDDAY
Raz TOT_DUD, TOT_DUDDAY

If val(CFOPAYSTT)<>999
   Filter [DUD] Where DUDDAT<date$ and DUDDAT>=date$-val(CFOPAYSTT) and BPRPAY=[M:CFO1]BPRNUM and CPY=[M:CFO0]CPY and TYPDUD<3
Else
   Filter [DUD] Where DUDDAT<date$ and BPRPAY=[M:CFO1]BPRNUM and CPY=[M:CFO0]CPY and TYPDUD<3
Endif
For [DUD]DUD0

    If [F:DUD]AMTCUR-[F:DUD]PAYCUR=0
       TOT_DUD+=[F:DUD]AMTCUR
       TOT_DUDDAY+=[F:DUD]AMTCUR*((date$-[F:DUD]DUDDAT)-(date$-[F:DUD]PAYDAT)*([F:DUD]PAYDAT<>[0/0/0]))
    Else
       TOT_DUD+=[F:DUD]AMTCUR-[F:DUD]PAYCUR
       TOT_DUDDAY+=([F:DUD]AMTCUR-[F:DUD]PAYCUR)*((date$-[F:DUD]DUDDAT)-(date$-[F:DUD]PAYDAT)*([F:DUD]PAYDAT<>[0/0/0]))
    Endif
Next
    If TOT_DUD<>0
       DELAY_DAY=arr(TOT_DUDDAY/TOT_DUD,1)
    Endif
    Filter [DUD]
Return
############################################################################################################
## Deletion of the record in CFODD before to create the new ones
############################################################################################################
$ANNULE
   Delete [F:CFODD] Where NUM=[F:CFOMM]NUM and TYP="*CM"+format$("N0:2#",[F:CFOMM]CFOTYP)
Return

############################################################################################################
## Control of the General parmaters
#############################################################################################################
Subprog VERF_PARAM(PPARAM,PVALEUR,POK)
Value Char PPARAM     # Nom du paramètre en cours de saisie
Value Char PVALEUR    # Valeur saisie à contrôler
Variable Integer POK  # 1 si contrôle satisfait, 0 si saisie incorrecte

If PVALEUR="" End :Endif

If !clalev([BAN]): Local File BANK [BAN]: Endif
If !clalev([BAN]): Local File FACILITY [FCY]: Endif
Local Char    FCY(GLONFCY)
Local Char    CPY(GLONCPY)

If GFONCTION="ADPVAL" and PPARAM="CFOBANDEF"
  FCY  = [M:ADWP]FCY
  CPY  = [M:ADWP]CMP
  Read [BAN]BAN0=PVALEUR
  If !fstat
     If FCY<>"" and FCY<>[F:BAN]FCY and [F:BAN]FCY<>""
        POK=0
        GMESSAGE = mess(43,121,1)-[F:BAN]FCY
     Endif
     If FCY<>"" and [F:BAN]FCY=""
        Read [FCY]FCY0=FCY
        If !fstat and [F:BAN]CPY<>[F:FCY]LEGCPY
           POK=0
           GMESSAGE = mess(42,121,1)-[F:BAN]CPY
         Endif
     Endif
     If CPY<>"" and CPY<>[F:BAN]CPY
        POK=0
        GMESSAGE = mess(42,121,1)-[F:BAN]CPY
     Endif
     If [F:BAN]CFOEXD=2
        POK=0
        GMESSAGE = mess(192,187,1)-[F:BAN]CPY
     Endif
  Endif
Endif

If GFONCTION="ADPVAL" and PPARAM="CFOPBYRAT"
  If val(PVALEUR)<0 or val(PVALEUR)>100
    POK=0
    GMESSAGE = mess(12,146,1)
  Endif
Endif
If GFONCTION="ADPVAL" and PPARAM="CFOPAYSTT"
  If val(PVALEUR)<0 or val(PVALEUR)>999
    POK=0
    GMESSAGE = mess(12,146,1)
  Endif
Endif
End POK
############################################# SEL TABLES ########################################
$SEL_TABLE
Case COUZON
 When "BAN"    : Gosub S_BAN    : # Banque
 When "NUM"    : Gosub S_NUM    : # Banque
Endcase
Return

$S_BAN
OBJET="BAN"
If [M:CFO0]CPY<>"" : CRITERE = "CPY='"+[M:CFO0]CPY+"'" : Endif
Return


$S_NUM
OBJET="CFO"
If [M:CFO0]CPY<>"" : CRITERE = "CPY='"+[M:CFO0]CPY+"'" : Endif
If [M:CFO0]FCY<>"" : CRITERE = "FCY='"+[M:CFO0]FCY+"'" : Endif
#If [M:CFO0]CFOTYP<>0 : CRITERE = "CFOTYP="+num$([M:CFO0]CFOTYP) : Endif
Return
