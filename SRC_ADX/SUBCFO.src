Endif
End
########################  ACCDAT ########################################################
Subprog AM_ACCDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
   Raz [M:CFO1]PTE
   Affzo [M:CFO1]PTE
Endif
If GREP<>"C"
  [M:CFO0]CFOSTA=1
  Affzo [M:CFO0]CFOSTA
Endif
End

Subprog C_ACCDAT(VALEUR)
Variable Date    VALEUR
Local Integer FLG
Local Integer HORPAST
Local Integer SNS
Local Integer TYPRAT
Local Integer TDAYS(3)
Local Integer INCRE

If VALEUR = [0/0/0]: End: Endif
Call CALC_CFOTYP([M:CFO0]CPY,[M:CFO0]FCY,[M:CFO0]CFOTYP,HORPAST,SNS, FLG, TYPRAT, TDAYS, INCRE) From SUBCFO
If [M:CFO0]RCR<>2 and VALEUR<date$-HORPAST
   GMESSAGE = mess(190,187,1)-num$(date$-HORPAST): mkstat=2
Endif
End
