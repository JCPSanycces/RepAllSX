#<AdxTL>@(#)0.0.0.0 $Revision$ Object Management CFO
######################################################################################
## Section automatically added (Object CFO) 09/19/2013 13:28:16 (LUCUE)
######################################################################################
$ACTION

Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "RAZCRE"   : Gosub RAZCRE
 When "LIENS"    : Gosub LIENS
 When "SEL_TABLE": Gosub SEL_TABLE
 When "INICRE"   : Gosub INICRE
 When "CREATION" : Gosub CREATION
 When "INIMOD"   : Gosub INIMOD
 When "MODIF"    : Gosub MODIF
 When "ANNULE"   : Gosub ANNULE
 When "SETBOUT"  : Gosub SETBOUT

 When Default
Endcase
Return

######################################################################################
$SETBOUT
  If GREP = "" and ([M:CFO0]CFOSTA=4 or [M:CFO0]CFOSTA=2) Then
    CHAINE += "A"
  Endif
  If [M:CFO0]CFOTYP>19
    Call VIREBOUT(CHAINE,"z") From GOBJET
  Endif
Return
######################################################################################
$OUVRE

If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif

Return
#######################################################################################
$RAZCRE
   Diszo [M:CFO0]NUM
   [M:CFO0]CFOLIN=1 : Affzo [M:CFO0]CFOLIN: Diszo [M:CFO0]CFOLIN
   [M:CFO0]CFOSTA=1 : Affzo [M:CFO0]CFOSTA
Return

#######################################################################################
$LIENS
Local Integer X

For X=0 To 19
  If [F:CFOMM]AMTCUR(X)=0: Break: Endif
  [M:CFO2]DAT(X)    = [F:CFOMM]DAT(X)
  [M:CFO2]PAMDET(X) = [F:CFOMM]PAMDET(X)
  [M:CFO2]AMTCUR(X) = [F:CFOMM]AMTCUR(X)
  [M:CFO2]NBLIG=X+1
Next

Case [M:CFO0]CFOTYP  ## [M:CFO0]OBJ is used for the ZOOM
   When 1: [M:CFO0]OBJ="PSH"
   When 2: [M:CFO0]OBJ="POC"
   When 3: [M:CFO0]OBJ="POH"
   When 4: [M:CFO0]OBJ="PTH"
   When 5: [M:CFO0]OBJ="SQH"
   When 6: [M:CFO0]OBJ="SOH"
   When 7: [M:CFO0]OBJ="SOR"
   When 8: [M:CFO0]OBJ="CON"
   When 9: [M:CFO0]OBJ="SDH"
   When 10: [M:CFO0]OBJ="LEA"
   When Default [M:CFO0]OBJ=""
Endcase

If [M:CFO0]CFOTYP<20
   Diszo [M:CFO0]1-99
   Diszo [M:CFO1]1-99
Else
   Actzo [M:CFO0]1-99
   Actzo [M:CFO1]1-99
Endif
Return

##########################################################################
$INICRE
Local Integer STAT, X, SNS
Local Integer FLG
Local Integer HORPAST
Local Integer TYPRAT
Local Integer TDAYS(3)
Local Integer INCRE
Local Integer OK
Local Char    CFOPAYSTT(10)

GSOCIETE=[M:CFO0]CPY
Call LECTCA(3,OK) From SUBTCA
If fstat | !OK | [F:TCA]CODNUM(17)=""
   GERR=1 : GMESSAGE=mess(58,105,1)-mess(3,14,1)-mess(250,199,1) : GOK=0 : Return
Endif
GCPT=[F:TCA]CODNUM(17)

Call NUMERO (GCPT,[M:CFO0]FCY,[M:CFO0]DOCDAT,"",[M:CFO0]NUM,STAT) From SUBANM
Call PARAM([M:CFO0]CPY,"CFOPAYSTT",CFOPAYSTT) From ADOVAL

If GOK<0 Return Endif
If STAT = 0
   [F:CFOMM]NUM= [M:CFO0]NUM
   Affzo [M:CFO0]NUM
Else
# problème lors de la récupération du compteur
   GERR=1:GMESSAGE = mess(60,199,1)
   GOK = 0
   GERR = 1
   Return
Endif

##### Reading the parameterization of types of Cash Forecasts ##############################################
Call CALC_CFOTYP([M:CFO0]CPY,[M:CFO0]FCY,[M:CFO0]CFOTYP,HORPAST, SNS, FLG, TYPRAT, TDAYS, INCRE) From SUBCFO

##### Calculation od the open items ([M:CFO2]) #############################################################
Gosub CALC_OPEN_ITEM

##### We feed the fields in the table [F:CFOMM] ############################################################
Raz [F:CFOMM]DAT, [F:CFOMM]AMTCUR, [F:CFOMM]PAMDET
For X=0 To [M:CFO2]NBLIG-1
  [F:CFOMM]DAT(X)    =[M:CFO2]DAT(X)
  [F:CFOMM]PAMDET(X) =[M:CFO2]PAMDET(X)
  [F:CFOMM]AMTCUR(X) =[M:CFO2]AMTCUR(X)
Next X

Return

#############################################################################################################
$CREATION

Gosub ANNULE       ## Deletion of the records in the table [F:CFODD]
Gosub CRE_CFODUD   ## Creation of the records in the table [F:CFODD]

Return

#############################################################################################################
$MODIF
Gosub ANNULE       ## Deletion of the records in the table [F:CFODD]
Gosub CRE_CFODUD   ## Creation of the records in the table [F:CFODD]

Return

#############################################################################################################
$INIMOD
Local Integer X, SNS
Local Integer FLG
Local Integer HORPAST
Local Integer TYPRAT
Local Integer TDAYS(3)
Local Integer INCRE
Local Char    CFOPAYSTT(10)

If [M:CFO0]CFOSTA=3: Return: Endif  ## If the CFO is from a X3 document and its status="Modified", the CFO is not modified again

##### Reading the parameterization of types of Cash Forecasts ##############################################
Call CALC_CFOTYP([M:CFO0]CPY,[M:CFO0]FCY,[M:CFO0]CFOTYP,HORPAST,SNS,FLG, TYPRAT, TDAYS, INCRE) From SUBCFO
Call PARAM([M:CFO0]CPY,"CFOPAYSTT",CFOPAYSTT) From ADOVAL

##### Calculation od the open items ([M:CFO2]) #############################################################
Gosub CALC_OPEN_ITEM

##### We feed the fields in the table [F:CFOMM] ############################################################
Raz [F:CFOMM]DAT, [F:CFOMM]AMTCUR, [F:CFOMM]PAMDET
For X=0 To [M:CFO2]NBLIG-1
    [F:CFOMM]DAT(X)    =[M:CFO2]DAT(X)
    [F:CFOMM]PAMDET(X)   =[M:CFO2]PAMDET(X)
    [F:CFOMM]AMTCUR(X)=[M:CFO2]AMTCUR(X)
Next X
Return

######################################################################################
## Field Actions  [M:CFO0]
######################################################################################
########################### CPY  ########################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

Call LEC_CPY(VALEUR) From CPTLEC
[M:CFO0]LEG=[F:CPY]LEG: Affzo [M:CFO0]LEG
Call LEC_GCM([F:CPY]ACM) From CPTLEC
[M:CFO0]LED=[F:GCM]LED(0): Affzo [M:CFO0]LED
Call LEC_LED([F:GCM]LED(0)) From CPTLEC
[M:CFO0]COA=[F:LED]COA: Affzo [M:CFO0]COA
End
########################  FCY ########################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CONSSUB
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CONSSUB
End

######################## CFOSTA #######################################################
Subprog AS_CFOSTA(VALEUR)
Variable Integer VALEUR
If GREP="C"
   GMENLOC(3)=1
   GMENLOC(4)=1
Else
   GMENLOC(3)=0
   GMENLOC(4)=0
Endif
End

######################## CFOTYP ######################################################
Subprog AS_CFOTYP(VALEUR)
Variable Integer VALEUR

#### Manually, it is only possible the values >=20
If GREP="C" or VALEUR>19
  For X=1 To 19
     GMENLOC(X)=1
  Next
Else
  For X=1 To 19
     GMENLOC(X)=0
  Next
Endif
End

Subprog C_CFOTYP(VALEUR)
Variable Integer VALEUR

Local Integer FLG
Local Integer HORPAST
Local Integer SNS
Local Integer TYPRAT
Local Integer TDAYS(3)
Local Integer INCRE
Call CALC_CFOTYP([M:CFO0]CPY,[M:CFO0]FCY,VALEUR,HORPAST,SNS, FLG, TYPRAT, TDAYS, INCRE) From SUBCFO
If FLG <> 2
   GMESSAGE = mess(189,187,1)
   mkstat=2
Endif
End

Subprog AM_CFOTYP(VALEUR)
Variable Integer VALEUR
Local Integer FLG
Local Integer HORPAST
Local Integer SNS
Local Integer TYPRAT
Local Integer TDAYS(3)
Local Integer INCRE
Call CALC_CFOTYP([M:CFO0]CPY,[M:CFO0]FCY,VALEUR,HORPAST,SNS, FLG, TYPRAT, TDAYS, INCRE) From SUBCFO
If SNS<>0
   [M:CFO0]SNS=SNS
   Affzo [M:CFO0]SNS
Endif
[M:CFO1]TYPRAT=TYPRAT
Affzo [M:CFO1]TYPRAT
End
######################################################################################
## Field Actions  [M:CFO1]
######################################################################################
######################## BPRNUM ########################################################
Subprog C_BPRNUM(VALEUR)
Variable Char    VALEUR()

### The partner has to be valid for the company and is not excluded form CFO management
Read [BPE]BPE0=VALEUR;[M:CFO0]CPY
If !fstat
   If [F:BPE]ACEAUZ<>2
      GMESSAGE=mess(29,104,1) : mkstat=2 : End
   Endif
   If [F:BPE]CFOEXDCPY=2
      GMESSAGE=mess(188,187,1) : mkstat=2 : End
   Endif
Endif
Read [BPR]BPR0=VALEUR
If !fstat and [F:BPR]CFOEXD=2
   GMESSAGE=mess(188,187,1) : mkstat=2 : End
Endif
End

Subprog AM_BPRNUM(VALEUR)
Variable Char    VALEUR()
If !clalev([CAC]): Local File GACCCODE   [CAC] : Endif
If !clalev([BPS]): Local File BPSUPPLIER [BPS]: Endif
If !clalev([BPC]): Local File BPCUSTOMER [BPC]: Endif
If !clalev([GAC]): Local File GACCOUNT   [GAC]: Endif
Raz [F:CAC], [F:GAC]
Read [BPE]BPE0=VALEUR;[M:CFO0]CPY
If !fstat
   Case [M:CFO0]SNS
     When 1: If [F:BPE]VACBPS<>"": Read [CAC]CAC0=3;[F:BPE]VACBPS;[M:CFO0]COA : Endif
     When 2: If [F:BPE]VACBPC<>"": Read [CAC]CAC0=2;[F:BPE]VACBPC;[M:CFO0]COA : Endif
   Endcase
Endif
If [F:CAC]ACCCOD=""
   Case [M:CFO0]SNS
     When 1: Read [BPS]BPS0=VALEUR
             If !fstat
                [M:CFO1]BAN=[F:BPS]PAYBAN
                Read [CAC]CAC0=3;[F:BPS]ACCCOD;[M:CFO0]COA
             Endif
     When 2: Read [BPC]BPC0=VALEUR
             If !fstat
                [M:CFO1]BAN=[F:BPC]PAYBAN
                Read [CAC]CAC0=2;[F:BPC]ACCCOD;[M:CFO0]COA
             Endif
   Endcase
Endif
If [F:CAC]ACCCOD<>""
    Call LEC_GAC([F:CAC]ACC(0),[M:CFO0]COA) From CPTLEC
    [M:CFO1]SAC=[F:GAC]ACCSHO
    Affzo [M:CFO1]SAC
Endif
If [M:CFO1]BAN=""
   Call PARAM([M:CFO0]FCY,"CFOBANDEF", [M:CFO1]BAN) From ADOVAL
Endif
Affzo [M:CFO1]BAN
End
######################### BAN ########################################################
Subprog C_BAN(VALEUR)
Variable Char    VALEUR()

## The Bank has to be valid for the company/site
If [F:BAN]CPY<>[M:CFO0]CPY
   GMESSAGE=mess(318,107,1): mkstat=2
   End
Endif
## The bank is nos excluded form the CFO management
If [F:BAN]CFOEXD=2
   GMESSAGE=mess(192,187,1): mkstat=2
Endif
End

Subprog AM_BAN(VALEUR)
Variable Char    VALEUR()
  [M:CFO1]CUR=[F:BAN]CUR
  Affzo [M:CFO1]CUR
End
