#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet AYF
Raz GNBMASKOUV, GPILOBJ
Call OBJET("AYF",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
## Xtend:  Gestion des Elements champs 
#  Version 0001
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "AVANT_OUVRE"    : Gosub AVANT_OUVRE
 When "EXEBOUT"        : Gosub EXEBOUT
 When "EXEACT"         : Gosub EXEACT
 When "FERME"          : Gosub FERME
 When "FILTRE"         : Gosub FILTRE
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "LIENS"          : Gosub LIENS
 When "OUVRE"          : Gosub OUVRE
 When "RAZCRE"         : Gosub RAZCRE
 When "STATUT"         : Gosub STATUT
 When "SETBOUT"        : Gosub SETBOUT
 When "TITRE"          : Gosub TITRES 
 When "CREATION"       : Gosub CREATION
 When "MODIF"          : Gosub MODIF
 When "ANNULE"         : Gosub ANNULE
 When "FILGAUCHE"      : Gosub FILGAUCHE
 When default
Endcase
Return

#---------------------------------------------------------------#
$FILGAUCHE
Case currbox
 When "GAU_CHE"
  FILGAUCHE = 'left$(FIECOD,2)<>"AX" & '-func SUBAYS.FILTFCY
 When "GAU_CHE1"
  FILGAUSUP = '[F:AYF]ENASPE <> 2 & '-func SUBAYS.FILTFCY
 When "GAU_CHE2"
  FILGAUSUP = '[F:AYF]ENASPE = 2 & '-func SUBAYS.FILTFCY
Endcase
Return

#---------------------------------------------------------------#
$MODIF
$CREATION
Call MAJTEXTRA([M]INTIT,"AYTELTFLD","INTIT",[M]FCYCOD,[M]FIECOD) From  ATEXTRA
Return

#---------------------------------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="AYTELTFLD" & ZONE = "INTIT"   & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
Return

#---------------------------------------------------------------#
$AVANT_OUVRE
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Gosub INICTLFCY From SUBAYS
Return

#---------------------------------------------------------------#
$OUVRE
Local Char WSTR1 (250)
Local Integer WI, TYP_
Gosub DSYFCY From SUBAYS     # Infos site
#  Format par langue
If clalev([F:AYS])=0 : Local File AYTFCY [AYS] : Endif
Read [F:AYS]AYS0 = GAYTFCYWRK 
#
If clalev([F:APV1])=0 : Local File APTLVW [APV1] : Endif
Return

#---------------------------------------------------------------#
$FERME
Gosub DSYCLRFCY From SUBAYS # Clear affichage site
Return

#---------------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, copie
Else
 CHMEN+="3"    # Validation avec vérification interface
Endif

CHMEN+="1"    # Menu
Return

#---------------------------------------------------------------#
$EXEBOUT
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$EXEACT
Case BOUT
When "S"
    # on n'a pas de notion de site... 1er paramètre à vide
    Call USG_SUPP("", GABREV, [M]FIECOD, WI) From CNSAYUSTD
    If WI : OK=0 : Endif
Endcase
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$TITRES
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$INICRE
$INIMOD
# Clé browser X3
[F]BRWX3=[F]FCYCOD+"_"+[F]FIECOD 
#
Raz [F:AYF]LANNBR, [F:AYF]LANCOD, [F:AYF]LANFMT
For WI=0 To [M]FCYLANNBR-1
    If [M]FIELANFMT(WI)<>""
        [F:AYF]LANCOD([F:AYF]LANNBR)=[M]FCYLANCOD(WI)
        [F:AYF]LANFMT([F:AYF]LANNBR)=[M]FIELANFMT(WI)
        [F:AYF]LANNBR+=1
    Endif
Next
Return

#---------------------------------------------------------------#
$LIENS
Actzo [M:AYF1]
Actzo [M:AYF2]
Affzo [M:AYF1]
Affzo [M:AYF2]

Call GES_NOLIB   (0,[M]TYP)
Call GES_NOLIBTIT(0,[M]NOLIB)
Call GES_FCYLAN  (0,[M]TYP)
Call GES_RESRAC  (0,[M]TYP)
Call GES_LSTMEN  (0,[M]TYP)

# modif sb pour flash
Call GES_FLASH   (0,[M]TYP)
Call GES_VALDEF([M]TYP)
Call GES_TYPEDONNEE([M]TYP)
Gosub DSYFCY From SUBAYS     # Infos site
[M:AYF1]valsai = [M:AYF1]valVAL
Call CHARGE([M:AYF1]valsai,[M]VALTYP,[M]NOLIB,[M]VALLNG,[M:AYF1]valVAL) From FMTVAR
# fin modif sb

## ccl ajout champ speciaux
If [M]ENASPE=2
 Gosub GRISE_SPE
 [M]OBJ = "AYX"
Else
 [M]OBJ = "AYF"
Endif
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$FILTRE
FILTSUP+=func SUBAYS.FILTFCY
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$RAZCRE
Gosub DSYFCY From SUBAYS     # Infos site
#[M]CODACT=WFCY_CODACT     # Code activité site
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$STATUT
Return
#---------------------------------------------------------------#


######################################################################################
## Utilitaires
######################################################################################
#    Analyse Champ Clé composite
Subprog FIEKEY_ANA(FIEKEY, FIELNKENT, FIECOD)
Value Char    FIEKEY ()
Variable Char FIELNKENT(), FIECOD ()
Local Integer WI
WI = instr(1,FIEKEY,"_")
If WI
    FIECOD    =right$(FIEKEY, WI+1)
    FIELNKENT =left$(FIEKEY, WI-1)
Else
    FIECOD    =FIEKEY
Endif
#
End

#    Code Clé composite
Subprog FIEKEY_COD(FIELNKENT, FIECOD, FIEKEY)
Value Char FIELNKENT(), FIECOD ()
Variable Char    FIEKEY ()
If FIELNKENT <> ""
    FIEKEY    =FIELNKENT+"_"+FIECOD
Else
    FIEKEY    =FIECOD
Endif
End

# Obtenir des infos sur un champ 
Subprog  AYF_INFOS(FCYCOD,FIECOD,FIEXTTYP, FIEX3TYP, FIELON, FIENOLIB, FIEFMT )
Value Char FCYCOD
Value Char FIECOD
Variable Integer  FIEXTTYP     # Type Xtend de variable (mnl7931)
Variable Char     FIEX3TYP     # Type X3
Variable Decimal  FIELON       # 
Variable Decimal  FIENOLIB     # Numéro de numéro local attaché (le cas échéant)
Variable Char     FIEFMT       # Format X3 (futur)

If !clalev([AYF]) : Local File AYTELTFLD [AYF] : Endif

Raz FIEXTTYP, FIEX3TYP, FIELON, FIENOLIB
Read [AYF]AYF0=FCYCOD;FIECOD
If !fstat
    FIEXTTYP   =[F:AYF]TYP
    Case FIEXTTYP   
    When 2    # entier
        FIEX3TYP="L"
    When 3    # decimal
        FIEX3TYP="DCB"        
    When 4    # devise
        FIEX3TYP="DCB"        
    When 5    # date
        FIEX3TYP="D"        
    When 8    # mnl
        FIEX3TYP="M"
        FIENOLIB =[F:AYF]NOLIB
    When Default   #  1 texte, 6 accès image, 7 accès PJ
        FIEX3TYP="A"
    Endcase
Else
    FIETYP   =0
    FIENOLIB =0
    Call ECR_TRACE("XT_TYP/SUBAYF"-mess(88,7900,1)-FIECOD,1) From gesecran
Endif
End 

#-- Gestion tableau langue 
Subprog GES_FCYLAN(AFFZO_FLG, FIETYP)
Value Integer AFFZO_FLG
Value Integer FIETYP
Raz [M]FCYLANCOD, [M]FCYLANFMT, [M]FCYLANNBR, [M]FIELANFMT
# modif sb pour flash
# If !find(FIETYP,6,7,8)
If !find(FIETYP,6,7,8,9)
# Fin modif sb
    [M]FCYLANNBR=[F:AYS]LANNBR
    For WI=0 To [F:AYS]LANNBR-1
        [M]FCYLANCOD(WI)=[F:AYS]LANCOD(WI)
        Case FIETYP
        When 2
            [M]FCYLANFMT(WI)=[F:AYS]LANFMTINT(WI)
        When 3
            [M]FCYLANFMT(WI)=[F:AYS]LANFMTDEC(WI)
        When 4
            [M]FCYLANFMT(WI)=[F:AYS]LANFMTCUR(WI)
        When 5
            [M]FCYLANFMT(WI)=[F:AYS]LANFMTDAT(WI)
        Endcase
        WJ=find([M]FCYLANCOD(WI), [F:AYF]LANCOD)
        If WJ : [M]FIELANFMT(WI)=[F:AYF]LANFMT(WJ-1) : Endif
    Next
Endif
#
If AFFZO_FLG : Affzo [M]15 : Endif
End

#-- Gestion numéro menu local
Subprog GES_NOLIB(AFFZO_FLG, FIETYP)
Value Integer AFFZO_FLG
Value Integer FIETYP
If FIETYP=8
    Actzo [M:AYF1]NOLIB
Else
    [M:AYF1]NOLIB=0 : Grizo [M:AYF1]NOLIB
Endif
#
If AFFZO_FLG : Affzo [M]NOLIB : Endif
End

#-- Gestion libellé menu local (issu trt APLSTD)
Subprog GES_NOLIBTIT(AFFZO_FLG, NOLIB)
Value Integer AFFZO_FLG
Value Integer    NOLIB()
[M]NOLIBTIT=""
If NOLIB=0 : End : Endif
If NOLIB <100 
  Read [AST]CLE = 0;NOLIB;GLANGUE 
Else
  Read [AST]CLE = 200;NOLIB-200;GLANGUE 
Endif
If !fstat
 [M]NOLIBTIT= [F:AST]LANMES
Endif
#
If AFFZO_FLG : Affzo [M]NOLIBTIT : Endif
End

# -- Gestion racine chemin relatif ressources (Image et PJ)
Subprog GES_RESRAC(AFFZO_FLG, TYP)
Value Integer AFFZO_FLG
Value Integer TYP
Case TYP
When 6,7
    Actzo [M:AYF2]RESRAC
    Actzo [M:AYF2]EXTFCYOPT
When Default
    Effzo [M:AYF2]RESRAC
    [M:AYF2]EXTFCYOPT=2 
    Grizo [M:AYF2]RESRAC
    Grizo [M:AYF2]EXTFCYOPT 
Endcase
Call GES_RESSUBREP(AFFZO_FLG, TYP, [M:AYF2]RESRAC)
Call GES_EXT      (AFFZO_FLG, TYP, [M:AYF2]EXTFCYOPT)
#
If AFFZO_FLG : Affzo [M:AYF2]RESSUBREP : Endif
End

Subprog GES_RESSUBREP(AFFZO_FLG, TYP,RESRAC)
Value Integer AFFZO_FLG
Value Integer TYP
Value Integer RESRAC
Case TYP
When 6,7
  If RESRAC<>1
    Actzo [M:AYF2]RESSUBREP
  Else
    Effzo [M:AYF2]RESSUBREP : Grizo [M:AYF2]RESSUBREP
  Endif
When Default
    Effzo [M:AYF2]RESSUBREP : Grizo [M:AYF2]RESSUBREP
Endcase

Subprog GES_EXT(AFFZO_FLG, TYP, EXTFCYOPT)
Value Integer AFFZO_FLG
Value Integer TYP
Value Integer EXTFCYOPT
If EXTFCYOPT=1
    Actzo [M:AYF2]ext
Else
    If TYP=6
       [M:AYF2]ext=[F:AYS]EXTDEFIMG
    Elsif TYP=7
       [M:AYF2]ext=[F:AYS]EXTDEFPJ
    Else
       [M:AYF2]ext=""
    Endif
    Diszo [M:AYF2]ext
Endif
#
If AFFZO_FLG : Affzo [M:AYF2]ext: Endif
End

#-- Gestion Liste de valeurs
Subprog GES_LSTMEN(AFFZO_FLG, FIETYP)
Value Integer FIETYP
If find(FIETYP,1,2)        # FD: pas de menu local car double indication
    Actzo [M:AYF1]LSTMEN
Else
    Effzo [M:AYF1]LSTMEN 
    Grizo [M:AYF1]LSTMEN
Endif
#
If AFFZO_FLG : Affzo [M:AYF1]LSTMEN : Endif
End

# modif sb pour flash
#-- Gestion Flash
Subprog GES_FLASH(AFFZO_FLG, FIETYP)
Value Integer FIETYP
If find(FIETYP,9)        # FD: pas de menu local car double indication
    Actzo [M:AYF2]15
    Call INFOVUEFLASH([M]FLAVUE, [M:AYF2]flatypvueO) 
    Call GES_FLATYPVUE([M:AYF2]flatypvueO)
Else
    Effzo [M:AYF2]15 : Grizo [M:AYF2]15
Endif
#
If AFFZO_FLG : Affzo [M:AYF2]15 : Endif
End
# fin modif sb


Subprog INFOVUEFLASH(VUE, TYPVUE)    # Exist 1:Oui
Variable Char TYPVUE
If VUE <> [F:APV1]APVCOD
    Read [F:APV1] APV0=VUE
    If fstat : Raz [F:APV1] : Endif
Endif
TYPVUE=[F:APV1]SRCCODTYP
End


# ValTypvue = type de vue dans le dossier courant si vue trouvée
Subprog GES_FLATYPVUE(VALTYPVUE)
Value Char VALTYPVUE()
If VALTYPVUE=""    
    Affzo [M:AYF2]flatypvue
    Actzo [M:AYF2]flatypvue   
Else
    [M:AYF2]flatypvue=VALTYPVUE
    Affzo [M:AYF2]flatypvue
    Grizo [M:AYF2]flatypvue
Endif
End

# Affiche la valeur si valdef est à Oui
Subprog GES_VALPARDEF(VALTYP)
Value Integer VALTYP()
If VALTYP<>1 
    Affzo [M:AYF1]valsai
    Actzo [M:AYF1]valsai   
Else
    Effzo [M:AYF1]valsai
    Effzo [M:AYF1]valVAL
    Grizo [M:AYF1]valsai
Endif
End

# Réinitialisation de VALDEF sur changement de VALTYP
Subprog GES_REINIVALDEF()
 Effzo [M:AYF1]valdef
 [M:AYF1]valdef=1
 Affzo [M:AYF1]valdef
End


Subprog GES_VALDEF(VALTYP)
Value Integer VALTYP() 
If VALTYP<6 or VALTYP= 8
    # on affiche val par défaut
    Actzo [M:AYF1]valdef 
Else
    Grizo [M:AYF1]valdef
Endif
Call  GES_VALPARDEF([M:AYF1]valdef)
End

Subprog GES_TYPEDONNEE(VALTYP)
Value Integer VALTYP
Case VALTYP   
    When 2    # entier
        [M]VALTYP="L"
    When 3    # decimal
        [M]VALTYP="DCB"        
    When 4    # devise
        [M]VALTYP="DCB"        
    When 5    # date
        [M]VALTYP="D"        
    When 8    # mnl
        [M]VALTYP="M"
    When Default   #  1 texte, 6 accès image, 7 accès PJ
        [M]VALTYP="A"
    Endcase
End

######################################################################################
## Ecran AYF0
######################################################################################

######################################################################################
## Ecran AYF1
######################################################################################
$GRISE_SPE
Effzo [M:AYF1]
Effzo [M:AYF2]
[M]TYP=0
[M:AYF2]RESRAC=0
[M:AYF2]EXTFCYOPT=0
[M:AYF1]valdef =0
[M]FLATIT=0
Grizo [M:AYF1]
Grizo [M:AYF2]
Return

Subprog AM_ENASPE(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Gosub GRISE_SPE
 [M]OBJ = "AYX"
Else
 [M]OBJ = "AYF"
 Actzo [M:AYF1]
 Actzo [M:AYF2]
 Affzo [M:AYF1]
 Affzo [M:AYF2]
 Call GES_NOLIB   (0,[M]TYP)
 Call GES_NOLIBTIT(0,[M]NOLIB)
 Call GES_FCYLAN  (0,[M]TYP)
 Call GES_RESRAC  (0,[M]TYP)
 Call GES_LSTMEN  (0,[M]TYP)
 # modif sb pour flash
 Call GES_FLASH   (0,[M]TYP)
 Call GES_VALDEF([M]TYP)
 Call GES_TYPEDONNEE([M]TYP)
Endif
End


Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
Call GES_NOLIB  (1, VALEUR)
Call GES_FCYLAN (1, VALEUR)
Call GES_RESRAC (1, VALEUR) 
Call GES_LSTMEN (1, VALEUR)
Call GES_FLASH (1, VALEUR)
Call GES_REINIVALDEF()
Call GES_VALDEF(VALEUR)
Call GES_TYPEDONNEE(VALEUR)
Case  VALEUR
 When 6,7 : zonsui = "[M:AYF2]RESRAC"
 When 9   : zonsui = "[M:AYF2]FLAINT"
Endcase
End

Subprog AM_NOLIB(VALEUR)
Variable Decimal VALEUR
Call GES_NOLIBTIT(1, VALEUR)
End

Subprog AS_FIELANFMT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif
Case [M]TYP
When 1
    VALEUR="K:40X"
When Default
    VALEUR=[M]FCYLANFMT(nolign-1)
Endcase
End

Subprog C_FIELANFMT(VALEUR)
Variable Char    VALEUR()
Call FORMA(VALEUR,[M]TYP) From SUBAYS
End

Subprog S_RESSUBREP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 Local Char RACINE(200),WVAL(250)
 Local Integer WI
 Local Char WLAN(GLONLAN) : WLAN= func SUBAYS.LANDEF([M]FCYCOD)
    
 RACINE = func AYTUTIA.MNL7937REP([M]FCYCOD, WLAN, [M:AYF2]RESRAC) :  WVAL=RACINE+VALEUR

 #
 # <=> Action SELFICREP  (TRT SELFICREP)
 Call SELREPREP(WVAL) From SELFICREP
 #
 WI=instr(0,WVAL,RACINE)
 If WI
    # Remove eventuel du dirsep en dernière position
    If right$(WVAL,len(WVAL))= func AYTGESFILE.GETPATH("","","DIRSEP","","","") : WVAL=left$(WVAL,len(WVAL)-1) : Endif
    VALEUR=right$(WVAL,len(RACINE)+1)
 Else
    mkstat=2
    GERR=1 : GMESSAGE=mess(16,7900,1)-WVAL
 Endif 
Endif
End

Subprog C_RESSUBREP(VALEUR)
Variable Char    VALEUR()
Local Char RACINE(200),FILEPATH(250)
Local Integer WI
Local Char WLAN(GLONLAN) : WLAN= func SUBAYS.LANDEF([M]FCYCOD)

RACINE = func AYTUTIA.MNL7937REP([M]FCYCOD, WLAN, [M:AYF2]RESRAC) 
FILEPATH=RACINE+VALEUR
Call EXISTE(FILEPATH, WI) From ORDSYS
If WI<>2     # pas un répertoire
    GERR=3 : GMESSAGE=mess(203,7900,1)-VALEUR        # GERR=3: avertissement GERR=2: message
Endif
End



Subprog AM_RESRAC(VALEUR)
Variable Integer VALEUR
Call GES_RESSUBREP(1, [M]TYP,VALEUR)
End

Subprog AM_EXTFCYOPT(VALEUR)
Variable Integer VALEUR
Call GES_EXT(1, [M]TYP, VALEUR)
End

Subprog C_FLAVUE(VALEUR)
Variable Char    VALEUR()
Call INFOVUEFLASH(VALEUR, [M:AYF2]flatypvueO)
If [M:AYF2]flatypvueO<>""
     Call CONTSEL("APV","B",VALEUR,"",mkstat) From CONTOBJ
Endif
End 

Subprog AM_FLAVUE(VALEUR)
Variable Char    VALEUR()
Call GES_FLATYPVUE([M:AYF2]flatypvueO)
End

Subprog AM_VALDEF(VALEUR)
Variable Integer  VALEUR
Call GES_VALPARDEF(VALEUR)
End
