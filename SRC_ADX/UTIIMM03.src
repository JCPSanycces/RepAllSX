#<AdxTL>@(#)2.0.0.0 $Revision$
##############################################################################
# Initialisation à "2" du flag FLGEXPCRE de la table GTYPACCENT
# GLE 15/07/2010
##############################################################################
Call MAJ_UTIIMM03
End

Subprog MAJ_UTIIMM03
Local Char DOSSIER(30) : DOSSIER=nomap
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIIMM03:"-toupper(mess(70,117,1))-tolower(mess(1,89,1))-"FLGEXPCRE") From LECFIC
Call SAIDOS(DOSSIER,"UTIIMM03") From SAIDOS
If DOSSIER<>"" Call EXE_UTIIMM03(DOSSIER) : Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End

Subprog EXE_UTIIMM03(APPLI)
Value Char APPLI
Local Integer OK
If filinfo(filpath("FIL","GTYPACCENT","fde",APPLI),0) < 0 : End : Endif
If !clalev([F:GTE]) : Local File =APPLI+".GTYPACCENT" [GTE] : Endif
If dim([F:GTE]FLGEXPCRE)<0 : End : Endif

Call ECR_TRACE("UTIIMM03: Process Start on : "+APPLI,0) From GESECRAN

Call DEBTRANS From GLOCK
Gosub TR_UTIIMM03
Call ECR_TRACE("UTIIMM03: Process End on : "+APPLI,0) From GESECRAN

End

#### Corps de la moulinette - début

$TR_UTIIMM03
Trbegin [GTE]
Update [GTE] Where FLGEXPCRE<>2 With FLGEXPCRE=2
Call ECR_TRACE("UTIIMM03: records updated : "+num$(adxuprec),0) From GESECRAN
Commit
Return

#### Corps de la moulinette - fin 

Subprog PATCH(APPLI)
Value Char    APPLI
Call EXE_UTIIMM03(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj7 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call EXE_UTIIMM03(APPLI)
End


