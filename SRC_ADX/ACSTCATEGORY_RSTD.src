#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure ACATEG_RSTD

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
       When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
       When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
       When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
       When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
       When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return



##########################################################################################################
# METHODS
##########################################################################################################

$AQUERY_DECODE_CRITERIA_AFTER
  Raz NBPRO
  NBPRO += 1
  TBPRO(NBPRO) = "CATEG" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ACATEG.CATEG" : TBFIL(NBPRO) = "[LNK_]CATEG"
  NBPRO += 1
  TBPRO(NBPRO) = "CODVAR" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ACATEG.CODVAR"    : TBFIL(NBPRO) = "[LNK_]CODVAR"
Return

$AQUERY_PRIMARYKEYS_AFTER
  ASTDKEY = "[LNK_]CATEG;[LNK_]CODVAR"
Return

$AQUERY_OPEN_AFTER
  Local File    ACONSTANT [QRY_ACST]
  Local Integer I : I=0
  Local Char    TCATEG(12)(1..)
  Local Char    TCODVAR(GLONACST)(1..), CUR_CATEG(12)

Filter [QRY_ACST] Where [QRY_ACST]CATEG<>AVOID.ACHAR Order By Key ACST1
  For [QRY_ACST]ACST1 Where XCAT <> [F:QRY_ACST]CATEG  # TEST
    If CUR_CATEG = [F:QRY_ACST]CATEG :
      I += 1
      [L]TCATEG(I)   = [F:QRY_ACST]CATEG
      [L]CUR_CATEG   = [F:QRY_ACST]CATEG
      [L]TCODVAR(I)  = [F:QRY_ACST]CODVAR
    Endif
  Next
Filter [QRY_ACST]

Local File (Char CATEG(12),Char CODVAR(GLONACST)) From Variable TCATEG,TCODVAR As [LNK_]
Return

$AQUERY_TRANS_AFTER
  this.ACATEG.CATEG   = [LNK_]CATEG
  this.ACATEG.CODVAR  = [LNK_]CODVAR
Return

$AQUERY_CLOSE_AFTER
  Close Local File [LNK_]
Return

