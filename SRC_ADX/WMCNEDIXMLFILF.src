# Supervisor
## ACLA-CLASSE ## EDIXMLFILF
# 2018-11-06 07:05:23 256

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EDIXMLFILF
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_MSGCOD From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub INIT_MSGREL From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub INIT_MSGFILNOR From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub INIT_NUMLIN From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub INIT_SORT From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub INIT_FILNAM From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub INIT_MANDATORY From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub INIT_DESCRIPTION From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub AINIT From WMC0EDIXMLFILF : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EDIXMLFILF
Gosub _ALOADATTRIBUTE_MSGCOD From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGREL From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGFILNOR From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_NUMLIN From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_SORT From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_FILNAM From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MANDATORY From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EDIXMLFILF
Gosub LNKPRO_MSGCOD From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub LNKPRO_MSGREL From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub LNKPRO_MSGFILNOR From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1EDIXMLFILF : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



