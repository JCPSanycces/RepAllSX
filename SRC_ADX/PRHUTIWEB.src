######################################################################################
## Xtend -      
#    Login portail RH
#
#      Subprog-Funprog
#            PRHLOGIN   
# Version  : 20111010
#  
# 20110525 : Ajout accès kil : bug 69135 
# 20110401 : suppression subordonnee niveau et GETLSTTYPCNG
# 2010117    : Ajout de la langue   
# 201110614  : Suppression de la langue car mis à jour par client via setUserVar de la session 
######################################################################################
# Gestion d'un login en prenant pour exemple: Code profil X3 = Code profil Xtend
Subprog PRHLOGSIMPLE(AXPARCOD,AXPARVAL,AXUSERCODE,AXPWD,AXUSERPROF,AX3SOL,AX3FLDR,AX3LANG,AX3USER,AX3PWD
&       ,AXLOGCOD,AXLOGVAL,CNGPARAM,USRPARAM,COLPARAM)
    # Paramètres contextuels valorisés par le serveur XTEND - Contient le code site 'SITCOD'
    # Contextual parameters settled by XTEND server - Contains Xtend site's code 'SITCOD'
    Variable Char     AXPARCOD()()
    Variable Char     AXPARVAL()()
    # Paramètres obligatoires de login saisis par l'utilisateur 
    # Input parameters (HTML FORM)
    Variable Char     AXUSERCODE()
    Value    Char     AXPWD()
    # Paramètres obligatoires valorisés par le sous-programme
    # Mandatory parameters that must be returned to XTEND server
    Variable Char     AXUSERPROF()    
    #Tableau des login X3 utilisé pour l'appel des web services    
    #Array of X3 logins per SOLUTION/FOLDER - Used to cal web services
    Variable Char     AX3SOL()()
    Variable Char     AX3FLDR()() 
    Variable Char     AX3LANG()()   
    Variable Char     AX3USER()()
    Variable Char     AX3PWD()()
    # Paramètres optionnels valorisés par le sous-programme
    # --> Informations complementaires (CODE/VALEUR) sur l'utilisateur (tel, email, nom...) qui seront copiés dasn la sessions XTEND (ASESSION)
    # --> Evite de créer autant de paramètres que de champs et facilite l'ajout de nouveaux champs 
    # Optional parameters returned to XTEND server
    # --> Additional user information (KEY/VALUE) (phone, email, name...) that will be mapped to XTEND session(ASESSION)
    # --> Avoid to create as many parameters as user information fields and facilitate addition of new parameters
    Variable Char     AXLOGCOD()()   
    Variable Char     AXLOGVAL()()
    Variable Clbfile  CNGPARAM()
    Variable Clbfile  USRPARAM()
    Variable Clbfile  COLPARAM()
    
    # Informations complementaires traitées par mapping dans l'action de login
    Local Integer WOK:WOK=1
    
    AXUSERCODE=toupper(vireblc(AXUSERCODE,0))
    If len(AXUSERCODE)=0
        Call ADDMESSERR(mess(14,751,1)) From AWEB
        # 751,14 : "Code utilisateur vide"
        WOK=0
    Else
        AXPWD=vireblc(AXPWD,0)
        If AXUSERCODE="SAGE" and toupper(AXPWD)="SAGE"
            WOK=1
        Else
            If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
            Read [AUS]LOGIN=AXUSERCODE
            If fstat
                 #Call ADDMESSERR("Code utilisateur ["+ AXUSERCODE +"] non trouvé") From AWEB
                  Call ADDMESSERR(AXUSERCODE-":"-mess(17,751,1)) From AWEB
                  # 751,17 :Code utilisateur non trouvé
                WOK=0
            Else
                Local Char WSITEXTEND(30) : WSITEXTEND="" 
                Local Integer WIDX:WIDX=find("SITCOD",AXPARCOD)
                If WIDX<>0
                    WSITEXTEND=AXPARVAL(WIDX-1)
                    Call USERX3(WSITEXTEND,AXUSERCODE,AXUSERPROF,WOK) From SUBAUS  
                    If WOK=1
                        If [AUS]ENAFLG = 2
                            If [AUS]USRCONXTD= 2 
                                # Vérifie le mot de passe
                                Call CTLPAS(AXPWD, WOK) From GESUSER
                                If WOK=0
                                    Call ADDMESSERR(mess(16,751,1)) From AWEB
                                   #751,16:"Mot de passe erroné"
                                Else
                                    WOK=1
                                Endif
                                If clalev([F:ADW])=0 : Local File ADOVAL    [ADW] : Endif 
                                Local Char PASSVIDE(50)
                                Local Integer VIDE
                                Call CTLPAS(PASSVIDE,VIDE)From GESUSER
                                If VIDE
                                  Read [ADW]ADW0 = "";"";"PASSWD"
                                  If !fstat & val([F:ADW]VALEUR)=2
                                    Call ADDMESSERR(AXUSERCODE-":"-mess(100,100,1)) From AWEB : # Vous devez saisir un mot de passe
                                    WOK=0
                                  Endif
                                Endif
                            Else
                                Call ADDMESSERR(AXUSERCODE-":"-+mess(19,751,1)) From AWEB
                                # 19: Connexion site Web non autorisée pour l'utilisateur
                                WOK=0 
                            Endif
                        Else
                            Call ADDMESSERR(AXUSERCODE-":"-mess(17,751,1)) From AWEB
                            # 751,17 : Utilisateur X3 désactivé
                            WOK=0 
                        Endif
                    Else
                      Call ADDMESSERR( WSITEXTEND - ":" - mess(18,751,1) - "[" + AXUSERCODE +"]") From AWEB
                        # 751, 18 : Code site Web non autorisé pour l'utilisateur
                        WOK=0 
                    Endif
                Else    
                    Call ADDMESSERR(mess(15,751,1)) From AWEB
                    #751,15:"Code site XTEND non défini dans les paramètres"
                    
                    WOK=0
                Endif
            Endif
        Endif
    Endif    
    If WOK
        AX3SOL(0)=GINSTID
        AX3FLDR(0)= nomap(0)
        #FDB 28/06/11 - Check folder lang
        Local Char FLDR_DEFLANG(10), LOGIN_LANG(10)
        Local Char FLDR_LANGS(10)(100)
        Call  FOLDERINFO(FLDR_LANGS,FLDR_DEFLANG)
        Local Integer IRES
        IRES=find("USRLANG",AXPARCOD)
        If IRES
            LOGIN_LANG=AXPARVAL(IRES-1)
            IRES=find(LOGIN_LANG,FLDR_LANGS)
            If IRES<=0
                LOGIN_LANG=FLDR_DEFLANG
            Endif
        Else  
            LOGIN_LANG=FLDR_DEFLANG
        Endif        
        AX3LANG(0)= LOGIN_LANG
        AX3USER(0)=toupper(vireblc(AXUSERCODE,0))
        AX3PWD(0)=vireblc(AXPWD,0)
        Local Char TMPMAT (50) 
        Local Char TMPUSER (50)
        TMPUSER= toupper(vireblc([AUS]USR,0))
        TMPMAT=func AFNC.PARAMUTIL('REFNUM',TMPUSER,'')
        If TMPMAT=""
          Call ADDMESSERR([AUS]USR  - ":" - mess(20,751,1)) From AWEB
        # 751,14 : "Cet utilisateur n'est pas rattaché à un matricule"
        WOK=0
        End
        Endif
       
        
        AXLOGCOD(0)="NOMUSR" : AXLOGVAL(0)=func GETNOMEML(TMPMAT,1)     # Prévu de charger dans AUSLOGINF
        AXLOGCOD(1)="REFNUM"  : AXLOGVAL(1)=TMPMAT        # Idem
        AXLOGCOD(2)="PRFMEN"  : AXLOGVAL(2)=[AUS]PRFMEN      # Prévu de charger dans ASESSION
        # Info Manager       
        AXLOGCOD(3)="MATMANA1"  : AXLOGVAL(3)=func PRHUTIWEB.GETCHEFEML(TMPMAT,1)
        AXLOGCOD(4)="MATMANA2"  : AXLOGVAL(4)=func PRHUTIWEB.GETCHEFEML(TMPMAT,2)
        AXLOGCOD(5)="MATMANA3"  : AXLOGVAL(5)=func PRHUTIWEB.GETCHEFEML(TMPMAT,3)
        AXLOGCOD(6)="NOMMANA1"  : AXLOGVAL(6)=func PRHUTIWEB.GETNOMEML(AXLOGVAL(3),1)
        AXLOGCOD(7)="NOMMANA2"  : AXLOGVAL(7)=func PRHUTIWEB.GETNOMEML(AXLOGVAL(4),2)
        AXLOGCOD(8)="NOMMANA3"  : AXLOGVAL(8)=func PRHUTIWEB.GETNOMEML(AXLOGVAL(5),2)
        AXLOGCOD(15)="LOGINX3"  : AXLOGVAL(15)=toupper(vireblc(AXUSERCODE,0))
        AXLOGCOD(16)="USERX3"  : AXLOGVAL(16)=[AUS]USR
        GUSER=[AUS]USR
        If clalev([F:AD])=0 : Local File EMPLOAD [AD] : Endif
        If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
        If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
        If clalev([F:SRV])=0 : Local File SERVICE [SRV] : Endif
        If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
        If clalev([F:POP])=0 : Local File POPUL [POP] : Endif
        If !clalev([F:CTR])  : Local File EMPLOCTR [CTR]  : Endif
        # on récupère les infos de la personne qui se connecte
        # la societe (9,10), le site (11,12) et le service (13,14)
        #64942 : Avant appel func AFNC.PARAM#
        # 69710
        Local Date WMOISPAIE 
        Call GETDATPAY(TMPMAT,"",WMOISPAIE)From PORDCG
        WMOISPAIE=GMOIPAY
        Read [ID]ID0=TMPMAT
        #on vérifie date sortie et définitive
        
        
        
        AXLOGCOD(11)="SITECOD"  : AXLOGVAL(11)=[ID]FCY
        AXLOGCOD(12)="SITENOM"  : AXLOGVAL(12)=""
        AXLOGCOD(9)="SOCIETECOD"
        AXLOGVAL(9)= ""
        AXLOGCOD(17)="NAMUSR"  : AXLOGVAL(17)=[ID]NAM
        AXLOGCOD(18)="SRNUSR"  : AXLOGVAL(18)=[ID]SRN
        AXLOGCOD(19)="URLDOC"
        AXLOGVAL(19)=func AXDTMAIN.GET_HELP_PATH()
        AXLOGCOD(20)="MOISPAYE"
        AXLOGVAL(20)=""+WMOISPAIE
        Read [FCY]FCY0=[ID]FCY
        If !fstat
            AXLOGVAL(9)= [F:FCY]LEGCPY
            AXLOGVAL(12)= [F:FCY]FCYNAM
        Endif    
        AXLOGCOD(13)="SERVICECOD"  : AXLOGVAL(13)=[ID]SRV
        Read [SRV]SRV0=[ID]SRV
        AXLOGCOD(14)="SERVICENOM"  : AXLOGVAL(14)=[ID]SRV
        If !fstat
          Call LECTEXTRA(AXLOGVAL(14),"SERVICE","DES",[ID]SRV,"") From ATEXTRA
        Endif
        AXLOGCOD(10)="SOCIETENOM"  : AXLOGVAL(10)=AXLOGVAL(9)
        If AXLOGVAL(9)<>"" Then
            Read [CPY]CPY0=AXLOGVAL(9)
            If !fstat
                AXLOGVAL(10)= [F:CPY]CPYNAM
            Endif
        Endif
        # on ajoute la liste des types de congés
        Local Char     LSTTYPCNGLIB(60)(0..50)
        Local Char     LSTTYPCNGVAL(20)(0..50)
      #  Call GETLSTTYPCNG(LSTTYPCNGVAL,LSTTYPCNGLIB) From PORDCG
        Raz CNGPARAM
        Append CNGPARAM,"{"
        Local Integer WI : WI=0
        Local Char SEP :SEP=""
        While(LSTTYPCNGVAL(WI)<>"")
          Call REPLACECHARSPE(LSTTYPCNGLIB(WI))From PRHUTIFCTPRH
          Append CNGPARAM ,SEP+'"'+LSTTYPCNGVAL(WI)+'":"'+LSTTYPCNGLIB(WI)+'"'
          SEP=","
          WI+=1
       Wend           
           Append CNGPARAM,"}"
        SEP=""   
        Raz USRPARAM
        Append USRPARAM,"{CONTRATS:["
           # LSTCONTRAT
        WI=0
        
        Local Char TMPCONTRAT(30) : TMPCONTRAT=""
        Local Integer LOGOK : LOGOK=0
        # on vérifie que la personne peut se connecter
        For [CTR]CTR1 Where REFNUM=TMPMAT 
          If [CTR]CTRDAT<=date$ & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=date$)
            If(WI=0)
              TMPCONTRAT=[CTR]CTRNUM
              WI+=1
            Endif
            Append USRPARAM,SEP+'"'+[CTR]CTRNUM+'"'
            SEP=","
            LOGOK=1
         Else
          If[CTR]XITFNL<>2 : LOGOK=1 : Endif
         Endif
        Next
        If LOGOK=0
          # 76129
          Call ADDMESSERR(AXUSERCODE-":"-+mess(27,751,1)) From AWEB
          WOK=0
          End
        Endif
        
#         For [CTR]CTR1 Where REFNUM=TMPMAT & CTRDAT<=date$ & (XITDAT=[0/0/0] | XITDAT>=date$)
#         If(WI=0)
#          TMPCONTRAT=[CTR]CTRNUM
#          WI+=1
#         Endif
#          Append USRPARAM,SEP+'"'+[CTR]CTRNUM+'"'
#          SEP=","
#        Next


         Append USRPARAM,"]"
         Append USRPARAM,',REFNUM:"'+TMPMAT+'"'
         Append USRPARAM,',USER:"'+TMPUSER+'"'
         Append USRPARAM,',LOGINX3:"'+AXUSERCODE+'"'
         Append USRPARAM,',CONTRAT:"'+TMPCONTRAT+'"'
         Call REPLACECHARSPE(AXLOGVAL(14))From PRHUTIFCTPRH
         Append USRPARAM,',SERVICE:{CODE:"'+AXLOGVAL(13)+'",LABEL:"'+AXLOGVAL(14)+'"}'  
         Call REPLACECHARSPE(AXLOGVAL(10))From PRHUTIFCTPRH
         Append USRPARAM,',SOCIETE:{CODE:"'+AXLOGVAL(9)+'",LABEL:"'+AXLOGVAL(10)+'"}' 
         Call REPLACECHARSPE(AXLOGVAL(12))From PRHUTIFCTPRH
         Append USRPARAM,',SITE:{CODE:"'+AXLOGVAL(11)+'",LABEL:"'+AXLOGVAL(12)+'"}'
         Call REPLACECHARSPE(AXLOGVAL(17))From PRHUTIFCTPRH
         Append USRPARAM,',NAME:"'+AXLOGVAL(17)+'"'
         Call REPLACECHARSPE(AXLOGVAL(18))From PRHUTIFCTPRH
         Append USRPARAM,',FIRSTNAME:"'+AXLOGVAL(18)+'"'
         Append USRPARAM,',XTDPROFIL:"'+AXUSERPROF+'"'
         #Vérification de l'acessibilité des pages
         Local Char X3PAG(10)(0..30),PRHPAG(20)(0..30)
         Local Char TMP_CODFNC
         Local Char TMP_COD(15)(0..100),TMP_LIBCOD(15)(0..100)
         WI=0
         X3PAG(WI)="EXS"
         PRHPAG(WI)="NDF"
         WI+=1
         X3PAG(WI)="DPI"
         PRHPAG(WI)="DPE"
         WI+=1
         X3PAG(WI)="DCG"
         PRHPAG(WI)="CNG"
         WI+=1
         X3PAG(WI)="DCG"
         PRHPAG(WI)="CNGANN"
         WI+=1
         X3PAG(WI)="EXS"
         PRHPAG(WI)="KIL"
         WI+=1
         WI=0
         Append USRPARAM,',ACCPAG:{'
         SEP=""  
         While(X3PAG(WI)<>"")
         Raz TMP_COD,TMP_LIBCOD
         Call GETLSTSOC (TMPUSER,X3PAG(WI),0,TMP_COD,TMP_LIBCOD) From PORSUP
         If(TMP_COD(0)<>"")
            Append USRPARAM,SEP+PRHPAG(WI)+":"+"true"
         Else
            Append USRPARAM,SEP+PRHPAG(WI)+":"+"false"
         Endif
         SEP=","
         WI+=1
         Wend
         Append USRPARAM,'}'
         Append USRPARAM,'}'
         #on ajoute les collaborateur
        Local Char TMPREFNUM(30)(0..200)
        Local Char TMPCTRNUM(30)(0..200)
         Local Char TMPTABCOL(30)(0..1)
        Local Char TMPNOM(50)
        Raz TMPREFNUM,TMPCTRNUM
      #  Call GETMYSUBORDONNESNIVEAU(TMPMAT,TMPREFNUM,TMPCTRNUM,TMPTABCOL)
         SEP=""
         Raz COLPARAM
         Append COLPARAM,"{"
           # LSTCONTRAT
          WI=0
          While (TMPREFNUM(WI)<>"" and WI<=200)
          If(TMPREFNUM(WI)<>TMPMAT)
          TMPNOM=func GETNOMEML(TMPREFNUM(WI),1)
           Call REPLACECHARSPE(TMPNOM)From PRHUTIFCTPRH
           Append COLPARAM,SEP+'"'+TMPREFNUM(WI)+'":"'+TMPNOM+'"'
            SEP=","
            Endif
          WI+=1
          Wend
          Append COLPARAM,'}'
        
        If (WOK=1)    
            Call ADDMESSINF(mess(21,751,1)- ":" -AXUSERCODE) From AWEB
        Endif
    Endif
End
######################################################################################
#
# Changement de login utilisateur
#
######################################################################################
Subprog PRHCHGLOGIN(AXPARCOD,AXPARVAL,AXUSERCODE,AXUSERX3,AXPWD,NEWLOGIN)

Variable Char     AXPARCOD()()
Variable Char     AXPARVAL()()
Value    Char     AXUSERCODE()
Value    Char     AXPWD()
Value    Char     NEWLOGIN()
Value    Char     AXUSERX3()
Local Integer VOK
Call CTLPAS(vireblc(AXPWD,0), VOK) From GESUSER
If VOK=0 : Call ADDMESSERR(GMESSAGE)From AWEB : GMESSAGE="" 
Else
# On vérifie l'unicité du nouveau login :
Call CONTLOG(NEWLOGIN,AXUSERX3,OK) From SUBAUS
Endif
End

######################################################################################
#
# Changement de mot de passe
#
######################################################################################
Subprog PRHCHGMDP(AXPARCOD,AXPARVAL,AXUSERCODE,PWDOLDPWD,NEWPWD)

Variable Char     AXPARCOD()()
Variable Char     AXPARVAL()()
Value    Char     AXUSERCODE()
Value    Char     PWDOLDPWD()
Value    Char     NEWPWD()
Call NEWPASS(PWDOLDPWD,NEWPWD,NEWPWD)From PORSUP

End
######################################################################################
#
# Oubli du mot de passe
#
######################################################################################
Subprog PRHFORGETPWD(AXPARCOD,AXPARVAL,USRCOD)

Variable Char     AXPARCOD()()
Variable Char     AXPARVAL()()
Value    Char     USRCOD()

# Correction CC 04/08/2010  : Bug 65355 -   c'est un login qui arrive dans cette routine
Local Char  TMPUSR(30)
USRCOD=toupper(USRCOD)
If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif 
Read [AUS]LOGIN = USRCOD
If !fstat
  TMPUSR=[F:AUS]USR
Endif

# on passe le code salarié...
#TMPUSR=func PORSUP.EMPUSR(USRCOD,"")
If TMPUSR=""
  Call ADDMESSERR(mess(24,100,1))From AWEB
Else
Call GENPASS(TMPUSR) From PORSUP 
Endif
End



######################################################################################
## Xtend - 
#    Récupération matricule hierarchie dans la fiche employé
#
######################################################################################

Funprog GETCHEFEML(MATRICULE,N)
Value Char MATRICULE
Value Integer N

Local Char MATCHEF(30)

If clalev([F:AD])=0 : Local File EMPLOAD [AD] : Endif

Read [AD]AD0=MATRICULE

 If fstat<>0 or N<=0 or N>dim([F:AD]CHEF) or [F:AD]CHEF(N-1)=""
    #on ne fait rien pour l'instant mais on pourra renvoyer une valeur par defaut...
 Else
   MATCHEF=[F:AD]CHEF(N-1)
 Endif
End MATCHEF

################################################################################
#
#    Renvoi un nom en fonction d'un matricule. inverse : 1= nom prenom sinon prenom nom
#
################################################################################
Funprog GETNOMEML(MATRICULE,INVERSE)
Value Char MATRICULE
Value Integer INVERSE     
Local Char NOMCHEF

If MATRICULE="" : End "": Endif
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif

Read [ID]ID0=MATRICULE
Local Integer K
If fstat
 NOMCHEF = mess(54,134,1) : # Utilisateur inconnu
 K = instr(1,NOMCHEF,"#")
 If K
  NOMCHEF = left$(NOMCHEF,K-1)+right$(NOMCHEF,K+1)
 Endif
Else
    If INVERSE=1 Then
 NOMCHEF = [F:ID]NAM-[F:ID]SRN
    Else
NOMCHEF = [F:ID]SRN-[F:ID]NAM
Endif
Endif
End  NOMCHEF

Funprog GETNOMPAIEX3(CODE,INVERSE)
Value Char CODE
Value Integer INVERSE     
Local Char MATRICULE(50)
Local Char RES(50)
MATRICULE=func AFNC.PARAMUTIL('REFNUM',CODE,'')
If MATRICULE<>"" Then
    RES=func GETNOMEML(MATRICULE,1)
Else
    RES=func AFNC.NOMUSER(CODE)
Endif
End RES

################################################################################
#
#  Gestion de la délégation pour les workflows ()
#    2 actions : get pour récupérer les infos sinon maj
################################################################################

Subprog ACTDELEGATION(AXPARCOD,AXPARVAL,AACTION,MATRICULE,LINEACTION,NODEL,DELEGUE,DELNAM,STRDAT,ENDDAT,NATWRK,TYPDEL,DELEML)
Variable Char     AXPARCOD()()
Variable Char     AXPARVAL()()
Value     Char    AACTION()
Value     Char    MATRICULE()
Variable Char LINEACTION()()
Variable Char DELEGUE()() , DELNAM()() , NATWRK()()
Variable Date STRDAT() , ENDDAT()
Variable Integer TYPDEL(),NODEL()
Variable Char DELEML()()

If AACTION="GET"
Call GETLSTDELWRK(MATRICULE,NODEL,DELEGUE,DELNAM,STRDAT,ENDDAT,NATWRK,TYPDEL,DELEML) From PORSUP
Else
Local Integer WI : WI=0
Local Char TMP_LINEACTION(10)
Local Char TMP_DELEGUE(30) , TMP_DELNAM(30) , TMP_NATWRK(20),TMP_DELEML(80)
Local Date TMP_STRDAT , TMP_ENDDAT
Local Integer TMP_TYPDEL,TMP_NODEL
While(LINEACTION(WI)<>"")
TMP_LINEACTION=LINEACTION(WI)
TMP_NODEL=NODEL(WI)
TMP_DELEGUE=DELEGUE(WI)
TMP_DELNAM=DELNAM(WI)
TMP_STRDAT=STRDAT(WI)
TMP_ENDDAT=ENDDAT(WI)
TMP_NATWRK=NATWRK(WI)
TMP_TYPDEL=TYPDEL(WI)
TMP_DELEML=DELEML(WI)
Call SETDELEGWRK(TMP_LINEACTION,MATRICULE,TMP_NODEL,TMP_DELEGUE,TMP_DELNAM,TMP_STRDAT
& ,TMP_ENDDAT,TMP_NATWRK,TMP_TYPDEL,TMP_DELEML) From PORSUP
WI+=1
Wend
Endif
End


################################################################################
#
#  renvoi les subordonnées d'un niveau n pour un matricule donné
#    2 actions : get pour récupérer les infos sinon maj
################################################################################

Subprog GETMYSUBORDONNESNIVEAU(MATRICULE,REFNUM,CTRNUM,COLTAB)
Value    Char    MATRICULE
Variable Char    REFNUM()(0..), CTRNUM()(0..)
Value Char    COLTAB()(0..)
Call GETSUBORDONNESNIVEAU(MATRICULE,COLTAB,REFNUM,CTRNUM)From PORMAT
End
################################################################################
#
#  Vérifie qu'il existe un utilisateur x3 rattaché au matricule saisi
#    
################################################################################
Subprog CHECKCODEDELEG(AXPARCOD,AXPARVAL,MATRICULE)
Variable Char     AXPARCOD()()
Variable Char     AXPARVAL()()
Value     Char    MATRICULE()
Local Char DELEGUE(30)
DELEGUE=func PORSUP.EMPUSR(MATRICULE,"")
If(DELEGUE="")
 # mess(99,709,1)   Le salarié n'est pas rattaché à un utilisateur
 Call ADDMESSERR(mess(99,709,1))From AWEB
Endif
End


################################################################################
#
#  Renvoi des informations sur le dossier courant
#   - ALANGS      Liste des langues actives pour le dossier
#   - ADEFLANG    Langue par défaut
#
################################################################################
Subprog FOLDERINFO(ALANGS,ADEFLANG)
    Variable Char ALANGS()()
    Variable Char ADEFLANG()

    Local Char FLDR
    FLDR=nomap
    If clalev([F:ADS])<>0 and [F:ADS]DOSSIER=FLDR
        For I=0 To [F:ADS]NBRLAN-1
            ALANGS(I)=[F:ADS]LAN(I)
        Next I
        ADEFLANG=[F:ADS]LANDEF
    Else 
        If clalev([F:ADSW])=0 : Local File ADOSSIER [ADSW] : Endif
        If GHISTO=1 : FLDR=adxmother(0) : Endif
        Read [ADSW]DOSSIER=FLDR
        If fstat<>0 : Call ECR_TRACE(mess(52,150,1)-FLDR,1) From GESECRAN : End : Endif 
        For I=0 To [F:ADSW]NBRLAN-1
            ALANGS(I)=[F:ADSW]LAN(I)
        Next I
        ADEFLANG=[F:ADSW]LANDEF
    Endif
End
################################################################################
#  75612 Web service updtate free fields
################################################################################
Subprog PRHSETCONFIG(AXPARCOD, AXPARVAL, MAILACCOUNT, REFMOISPAYE)   
    Value     Char     AXPARCOD()()
    Value     Char     AXPARVAL()()   
    Variable  Char     MAILACCOUNT()
    Variable  Integer  REFMOISPAYE
    Local Char SITE(20)
    SITE=func PRHUTIFILES.PARAMXTD_GET(AXPARCOD, AXPARVAL, "SITCOD")
    Call FREEFLDS_WRITE (SITE, MAILACCOUNT, REFMOISPAYE)
End
################################################################################
#  75612 Lecture des free fields
################################################################################
Subprog FREEFLDS_READ(ASITE, AWRKFLW, AURLDOC, AMAIL, AREFMOISPAYE)   
    Value     Char     ASITE()       
    Variable  Char     AWRKFLW()    
    Variable  Char     AURLDOC()
    Variable  Char     AMAIL()
    Variable  Integer  AREFMOISPAYE

    Raz AWRKFLW,AURLDOC,AMAIL,AREFMOISPAYE
    If clalev([F:XZY])=0 : Local File AYTFCY[XZY] : Endif 
    Local Integer I, NBPARAMS
    Local  Char STRMOISPAYE(200)
    Read [XZY]AYS0=ASITE
    If fstat=0
        NBPARAMS= [F:XZY]PARNBR-1      
        For I=0 To NBPARAMS
            Case [F:XZY]PAR(I)
               When "WORKFLOW" : 
                    AWRKFLW=[F:XZY]PARVAL(I)                                   
               When "DEFURLDOC" :                                      
                    AURLDOC=[F:XZY]PARVAL(I)                    
               When "MAILACCOUNT" :
                    AMAIL=[F:XZY]PARVAL(I)                  
               When "REFMOISPAYE" :
                    # "2" pour true
                    STRMOISPAYE=[F:XZY]PARVAL(I)
                    If STRMOISPAYE="2" Then AREFMOISPAYE=2 Else AREFMOISPAYE=1 Endif
            Endcase
        Next
        Close Local File [XZY]
    Else
        Call ADDMESSERR("Error updating site[" + ASITE + "] - Site not found") From AWEB
    Endif
End
################################################################################
#  75612 Ecriture des free fields
################################################################################
Subprog FREEFLDS_WRITE(ASITE, AMAIL, AREFMOISPAYE)   
    Value     Char     ASITE()    
    Value     Char     AMAIL()
    Value     Integer  AREFMOISPAYE

    If ASITE=""
        Call ADDMESSERR("Error updating site's free field. Empty site code")From AWEB
    Endif

    If clalev([F:XZY])=0 : Local File AYTFCY[XZY] : Endif 
    Local Integer I, NBPARAMS
    Local Char PARCOD(255)
    Read [XZY]AYS0=ASITE
    If fstat=0
        NBPARAMS= [F:XZY]PARNBR-1      
        For I=0 To NBPARAMS
            PARCOD=[F:XZY]PAR(I)
            If  PARCOD = "MAILACCOUNT" Then
                    Update [XZY] Where FCYCOD=ASITE With PARVAL(I)=AMAIL                            
            Elsif PARCOD = "REFMOISPAYE" Then
                    # "2" pour true
                    If AREFMOISPAYE<>2 Then AREFMOISPAYE=1 Endif 
                    Update [XZY] Where FCYCOD=ASITE  With PARVAL(I)=num$(AREFMOISPAYE)               
            Endif
            If fstat<>0
              Call ADDMESSERR("Error updating site[" + ASITE + "] free field[" + PARCOD + "]")From AWEB
            Endif 
        Next
    Else
        Call ADDMESSERR("Error updating site[" + ASITE + "] - Site not found")From AWEB
    Endif
    Close Local File [XZY]
    Call  XTDSITE_VALIDATE(ASITE)
End
################################################################################
#  75612 Test des free fields
################################################################################
Subprog FREEFLDS_TEST()
    Call INITABMES()From AWEB
    Local Char     AWRKFLW(255)    
    Local Char     AURLDOC(255)
    Local Char     AMAIL(255)
    Local Integer  AREFMOISPAYE

    Local Char PARCOD(50)(1),PARVAL(50)(2)
    PARCOD(0)="SITCOD"
    PARVAL(0)="RHDEV"

    Call  FREEFLDS_READ(PARVAL(0), AWRKFLW, AURLDOC, AMAIL, AREFMOISPAYE)   
    #Infbox  AWRKFLW + chr$(13) + AURLDOC+ chr$(13) +AMAIL+ chr$(13) + num$(AREFMOISPAYE)
    If AMAIL = "" : AMAIL="test@sage.com" : Endif
    AMAIL += ".updt"
    AREFMOISPAYE += 1
    Call  PRHSETCONFIG(PARCOD, PARVAL, AMAIL,  AREFMOISPAYE)
    Call  FREEFLDS_READ(PARVAL(0), AWRKFLW, AURLDOC, AMAIL, AREFMOISPAYE)       
    #Infbox  AWRKFLW + chr$(13) + AURLDOC+ chr$(13) +AMAIL+ chr$(13) + num$(AREFMOISPAYE)
    Call VISUALLMES()From AWEB
End

################################################################################
#  75612 Validation du site XTEND pour que les freeFields soient pris en compte par la session XTEND
################################################################################
Subprog XTDSITE_VALIDATE(ASITE)
    Value Char    ASITE()    
    Local Char    SAVACT(GLONACT),VALBOUT(250) , PARBOUT(250)(1..20)
    Local Integer FLGEXE  
    SAVACT = GACTION
    PARBOUT(1) = nomap
    PARBOUT(2) = ASITE
    PARBOUT(3) = "AYS"
    PARBOUT(4) = ""
    PARBOUT(5) = num$("0")
    GACTION = "AYTGEN"
    Call TRAITE_CHAR(VALBOUT,PARBOUT,"","AYTGEN","",1,"") From GTRAITE
    GACTION = SAVACT
End
#*********************************************************************
# SAGE HRM PORTAL
#  Check if HTML Version number is compliant with web services interfaces
#  This process is called by login page
#  Parameters set by JS function with HTML version number (Ex 2.1.1)
#    VERSMAIN    First  version number - New functions
#    VERSWSVC    Second version number - New/Modfied Web services
#    VERSBUILD   Third  version number - Build increment
#    VERSDATE    Version date
#    DEBUG       true/false - No message if debug mode
#  Returned value
#    MSG : Message - Empty if OK
#*********************************************************************
Subprog PRHCHECKVERS(AXPARCOD, AXPARVAL, VERSMAIN, VERSWSVC, VERSBUILD, VERSDATE, DEBUG, MSG1,MSG2,MSG3,EMAIL)  
    Value     Char     AXPARCOD()()
    Value     Char     AXPARVAL()()  
    Value     Char     VERSMAIN()
    Value     Char     VERSWSVC()
    Value     Char     VERSBUILD()
    Value     Char     VERSDATE()
    Value     Char     DEBUG()
    Variable  Char     MSG1()
    Variable  Char     MSG2()
    Variable  Char     MSG3()
    Variable  Char     EMAIL()

    Raz MSG1,MSG2,MSG3,EMAIL
    If tolower(DEBUG)<>"true"        
        Local Char SITE(20)
        SITE=func PRHUTIFILES.PARAMXTD_GET(AXPARCOD, AXPARVAL, "SITCOD")   
        # Expected version numbers
        # ->- Third version number is not significant
        Local Char NUM_MAIN(10), NUM_WSVC(10)
        # 2.1 version 11/09/16 - 2 for PPH new function - 1 First version
        # 
        NUM_MAIN= "2"
        NUM_WSVC= "1"        
        # Messages
        #REFMSG="Sage HRM Portal HTML client version[VERSMAIN.VERSWSVC] Date[VERSDATE] is not compliant with RH back office [NUM_MAIN.NUM_WSVC].\n"
        #REFMSG+= "Please call site administrator.\nCheck if AHRPORTAL website have been actually copied into current X3 folder."
        If VERSMAIN<>NUM_MAIN or VERSWSVC<>NUM_WSVC Then
            MSG1=mess(28,751,1)
            MSG2=mess(29,751,1)
            MSG3=mess(30,751,1)
            MSG1=func PRHUTIFILES.STR_REPLACE(MSG1,"%S","[" + VERSMAIN + "." + VERSWSVC + "]")             
            MSG1=func PRHUTIFILES.STR_REPLACE(MSG1,"%R","[" + NUM_MAIN + "." + NUM_WSVC + "]") 
            Local Char XWRKFLW(255), XURLDOC(255)
            Local Integer XREFMOISPAYE            
            Call FREEFLDS_READ(SITE, XWRKFLW, XURLDOC, EMAIL, XREFMOISPAYE) 
        Endif
    Endif
    
End
