Onevent BEFORE_INPUT Call AS_PRF(zc) From W1ODPAY
Onevent AFTER_CHANGE Gosub AMM_PRF From W1ODPAY
Return

Subprog AS_PRF(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(8750,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_PRF(VALEUR) From ODPAY
If mkstat=2
 [M]PRF(INDIC) = VALEUR
 Affzo PRF(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_PRF(zc) From W1ODPAY
Onkey   2 Titled GBOUTS Call S_PRF(zc) From W1ODPAY
Onkey 144 Titled GBOUTP Call P_PRF(zc) From W1ODPAY
Onkey 146 Titled GBOUTA Call SA_PRF(zc) From W1ODPAY
Gosub _AFF
End

Subprog C_PRF(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PRF" : GZNUM = 8750 : Endif
If !mkstat
 ## Action CONTPRF
 Call CONTPRF(VALEUR) From SUBPRF
 If mkstat : GERR = 1 : GZONE = "PRF" : GZNUM = 8750 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PRF" : GZNUM = 8750 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_PRF
Call AM_PRF(zc)
If !mkstat & GOBJET
