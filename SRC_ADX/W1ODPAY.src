 SAVACT = GACTION : GACTION = "SELHRPEO"
 PARMSK(1) = [M]LEG
 PARMSK(2) = [M]CPY
 PARMSK(3) = [M]FCY
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRPEO","SUBHRPEO","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

