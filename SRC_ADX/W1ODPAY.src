Subprog AS_POP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_POP(zc) From W1ODPAY
Onkey 144 Titled GBOUTP Call P_POP(zc) From W1ODPAY
Onkey 146 Titled GBOUTA Call SA_POP(zc) From W1ODPAY
Gosub _AFF
End

Subprog C_POP(VALEUR)
Variable Char    VALEUR()
## Action CONTPOP
Call CONTPOP(VALEUR,GCURLEG) From SUBPOP
If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("POP","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
Endif
Gosub _AFF
End

$AMM_POP
Call AM_POP(zc)
If !mkstat & GOBJET
 zoncou = "POP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_POP(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZPOP)")>indice
 [M]POP(indice) = VALEUR
 Affzo ZPOP(indice)
Endif
Gosub _AFF
End

Subprog S_POP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOP"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOP","SUBPOP","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_POP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "POP"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_POP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("POP",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

