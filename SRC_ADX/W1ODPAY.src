Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_PERCOD(zc) From W1ODPAY
Gosub _AFF
End

Subprog C_PERCOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PERCOD" : GZNUM = 1355 : Endif
If !mkstat
 ## Action CONTHRPEO
 Call CONTHRPEO(VALEUR) From SUBHRPEO
 If mkstat : GERR = 1 : GZONE = "PERCOD" : GZNUM = 1355 : Endif
Endif
Gosub _AFF
End

$AMM_PERCOD
Call AM_PERCOD(zc)
If !mkstat & GOBJET
 zoncou = "PERCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PERCOD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_PERCOD(VALEUR) From ODPAY
If mkstat : GERR = 1 : GZONE = "PERCOD" : GZNUM = 1355 : Endif
Gosub _AFF
End

Subprog S_PERCOD(VALEUR)
