$PROPAGATE_TELCNT
this.isReadonly = 0
[L]CURPRO = "TELCNT"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_TELCNT
Gosub DECLARE_VAR From WMC0EMPLOID_PERCNT
[L]CURPRO = "TELCNT"
$_LNKPRO_TELCNT
Local Char AFORMAT(50)
[L]ASTATUS =  func ASYRTRTATY.GETFORMATTEL(this,"TELCNT",this.TELCNT,[L]AFORMAT,this.APARENT.CRY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]AFORMAT<>''
[L]AFORMAT='"'+[L]AFORMAT+'"'
[L]ASTATUS = fmet this.ASETATTRIBUTE("TELCNT","$x3Format",[L]AFORMAT)
Endif
Return


