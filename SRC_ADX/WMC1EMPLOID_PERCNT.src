####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : NAMCNT Contact name ( Field NAM 35)
####################################################################

$SET_NAMCNT
If [L]_AOLDVAL<>this.NAMCNT
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_NAMCNT
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.NAMCNT
 Gosub PROPAGATE_NAMCNT
Endif
Return

$INIT_NAMCNT
Gosub DECLARE_VAR From WMC0EMPLOID_PERCNT
[L]CURPRO = "NAMCNT"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_NAMCNT
Gosub DECLARE_VAR From WMC0EMPLOID_PERCNT
[L]CURPRO = "NAMCNT"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_NAMCNT                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_NAMCNT                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_NAMCNT
[L]CURPRO = "NAMCNT"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.NAMCNT,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_NAMCNT
[L]CURPRO = "NAMCNT"
If vireblc(this.NAMCNT,2)<>vireblc(format$("K:35X",this.NAMCNT),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_NAMCNT
[L]CURPRO = "NAMCNT"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_NAMCNT
[L]CURPRO = "NAMCNT"
Return

$PROPAGATE_NAMCNT
this.isReadonly = 0
[L]CURPRO = "NAMCNT"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_NAMCNT
Gosub DECLARE_VAR From WMC0EMPLOID_PERCNT
[L]CURPRO = "NAMCNT"
$_LNKPRO_NAMCNT
Return


