#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################
Subprog AM_BPC(VALEUR)
Variable Char    VALEUR()

  [M:LKP5]NUM = ""
  If VALEUR = "" Then
    Grizo [M:LKP5]NUM
  Else
    Actzo [M:LKP5]NUM
  Endif
  [M:LKP5]BPC = VALEUR
  If [M:LKP5]BPC <> "" Then
    Gosub LOADLKP5 From TRTLKP5
  Endif
  Affzo [M:LKP5]
End

##########################################################################
Subprog AM_NUM(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR

  SZVALEUR = VALEUR
  Gosub LOOKUPSRE
  [M:LKP5]NUM = VALEUR
  Affzo [M:LKP5]
End

##########################################################################
Subprog AM_CLOFLG(VALEUR)
Variable Integer VALEUR

Local Char SZVALEUR

  [M:LKP5]CLOFLG = VALEUR
  If [M:LKP5]BPC <> "" Then
    If [M:LKP5]NUM = "" Then
      Gosub LOADLKP5 From TRTLKP5
    Else
      SZVALEUR = [M:LKP5]NUM
      Gosub LOOKUPSRE
    Endif
  Endif
  Affzo [M:LKP5]
End

##########################################################################
$LOOKUPSRE
Local Char SZFILTER(250)
Local Integer ITER

  Raz [M:LKP5]NBLIG
  Raz [M:LKP5]SRENUM
  Raz [M:LKP5]SRENUMBPC
  Raz [M:LKP5]SRETTR
  Raz [M:LKP5]SREASS
  Raz [M:LKP5]SREDET
  Raz [M:LKP5]SREDETCLA
  Raz [M:LKP5]CREDAT
  Raz [M:LKP5]SRERESDAT
  Raz [M:LKP5]SRERESHOU
  If [M:LKP5]CLOFLG = 2 Then
    SZFILTER = '[F:SRE]SREBPC = ' + '"' + [M:LKP5]BPC + '" and pat([F:SRE]SRENUMBPC, ' + '"' + SZVALEUR + '*") = 1' 
  Else
    SZFILTER = '[F:SRE]SREBPC = ' + '"' + [M:LKP5]BPC + '" and pat([F:SRE]SRENUMBPC, ' + '"' + SZVALEUR + '*") = 1' +  ' and [F:SRE]SREASS <> 5'
  Endif
  Filter [SRE] Where evalue(SZFILTER) Order By [F:SRE]SREINUMBPC Desc
  ITER = 0
  nolign = 0
  For [SRE] Hint Key SRE5
    If ITER >= dim([M:LKP5]SRENUM) Then
      Break
    Endif
    #Transclass
    nolign += 1
    [M:LKP5] = [F:SRE]
    [M:LKP5]SREDETCLA(ITER) = ""
    Case [M:LKP5]SREASS(ITER)
      When 1 
        If [M:LKP5]SREDET(ITER) <> "" Then
          Read [FCY]FCY0=[M:LKP5]SREDET(ITER)
          If !fstat Then
            [M:LKP5]SREDETCLA = [F:FCY]FCYNAM
          Endif
        Endif
      When 2
        If [M:LKP5]SREDET(ITER) <> "" Then
          Read [AUS]CODUSR=[M:LKP5]SREDET(ITER)
          If !fstat Then
            [M:LKP5]SREDETCLA = [F:AUS]NOMUSR
          Endif
        Endif
      When 3
        If [M:LKP5]SREDET(ITER) <> "" Then
          Read [QUE]QUE0=[M:LKP5]SREDET(ITER)
          If !fstat Then
            # FGR 23/09/2009 : X3SUIVI58037
            #[M:LKP5]SREDETCLA = [F:QUE]TTR
            Call LECTEXTRA([M:LKP5]SREDETCLA,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
          Endif
        Endif
      When Default
    Endcase
    ITER += 1
  Next
  Filter [SRE]
  [M:LKP5]NBLIG = ITER
  Affzo [M:LKP5]
Return
