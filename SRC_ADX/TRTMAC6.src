##########################################################################################################
$BOUTON
#Case BOUT
#    When "A"
#        VALEUR = [M:MAC6]BPRNUM(GMAC6NOL)
#        If type(GSZCUTBPCTYP) > 0
#            GSZCUTBPCTYP = "BPR"
#        Endif
#        FIN = 1
#    When Default
#Endcase
Case BOUT
    When "A"
        If (nolign-1)>=0
            If [M:MAC6]BPRNUM(nolign-1)<>""
                VALEUR = [M:MAC6]BPRNUM(nolign-1)
                FIN = 1
            Endif
        Endif
    When "C"
        Gosub ONLOAD
    When Default
Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONLOAD

Local Char SZWHERE (250)(20)
Raz SZWHERE
Local Integer ILIGNEWHERE
ILIGNEWHERE=0
Local Char SZAND
Raz SZAND
Local Char SZVALEUR (100)
Raz SZVALEUR
Local Char SZRECHERCHE (100)
Raz SZRECHERCHE

Local Integer IBNONVIDE
IBNONVIDE=0
Local Integer ILIGNE
ILIGNE = 0

Local Integer INBLIGNETOTAL
INBLIGNETOTAL=0

#Raz [M:MAC6]NBREC
#Raz [M:MAC6]NAM
#Raz [M:MAC6]ZIP
#Raz [M:MAC6]CTY
#Raz [M:MAC6]TEL
#Raz [M:MAC6]CRY
#Raz [M:MAC6]BPRNUM

Effzo [M:MAC6]15
[M:MAC6]NBREC=0


If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif

#Il faut créer le link
Link [BPA] With [BPR] BPR0=[F:BPA]BPANUM  As [BPRA] Where [F:BPR]BPRNUM<>"" and [F:BPA]BPATYP=1

If [M:MAC6]BPRNAM<>""
    SZVALEUR=[M:MAC6]BPRNAM
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE='"'+toupper(SZVALEUR)+'*"'
    SZWHERE(ILIGNEWHERE)=SZAND+ " pat ( toupper([F:BPR]BPRNAM)," +SZRECHERCHE+" )<>0 "
    ILIGNEWHERE=ILIGNEWHERE+1
    SZAND=" AND "
Endif

If [M:MAC6]BPRZIP<>""
    SZVALEUR=[M:MAC6]BPRZIP
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE='"'+toupper(SZVALEUR)+'*"'
    SZWHERE(ILIGNEWHERE)=SZAND+ " pat ( toupper([F:BPA]POSCOD)," +SZRECHERCHE+" )<>0 "
    ILIGNEWHERE=ILIGNEWHERE+1
    SZAND=" AND "
Endif

If [M:MAC6]BPRCTY<>""
    SZVALEUR=[M:MAC6]BPRCTY
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE='"'+toupper(SZVALEUR)+'*"'
    SZWHERE(ILIGNEWHERE)=SZAND+ " pat ( toupper([F:BPA]CTY)," +SZRECHERCHE+" )<>0 "
    ILIGNEWHERE=ILIGNEWHERE+1
    SZAND=" AND "
Endif

If [M:MAC6]BPRADEDEF=2
    SZWHERE(ILIGNEWHERE)= SZAND+ " [F:BPA]BPAADDFLG=2 "
    ILIGNEWHERE=ILIGNEWHERE+1
    SZAND=" AND "
Endif

ILIGNE=0
While ILIGNE< ILIGNEWHERE
    If SZWHERE <>""
        IBNONVIDE=1
    Endif
    ILIGNE=ILIGNE+1
Wend

If IBNONVIDE=1
    Filter  [BPRA] Where evalue (SZWHERE ) Order By [F:BPR]BPRNAM Desc; [F:BPA]CTY Desc
Else
    Filter  [BPRA] Order By [F:BPR]BPRNAM Desc; [F:BPA]CTY Desc
Endif

INBLIGNETOTAL=rowcount([BPRA])
ILIGNE=0
For [BPRA]
    If ILIGNE >= dim([M:MAC6]NAM) - 1 : Break : Endif
    If [F:BPA]BPANUM<>""

        [M:MAC6]BPRNUM(ILIGNE) = [F:BPR]BPRNUM

        [M:MAC6]NAM(ILIGNE) = [F:BPR]BPRNAM
        [M:MAC6]ZIP(ILIGNE) = [F:BPA]POSCOD
        [M:MAC6]CTY(ILIGNE) = [F:BPA]CTY
        [M:MAC6]TEL(ILIGNE) = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
        [M:MAC6]CRY(ILIGNE) = [F:BPA]CRY

        [M:MAC6]BPAADDFLG(ILIGNE) = [F:BPA]BPAADDFLG
        [M:MAC6]BPADES(ILIGNE) = [F:BPA]BPADES

        ILIGNE += 1
    Endif
Next

Filter [BPRA]

[M:MAC6]NBREC = ILIGNE

Affzo [M:MAC6]1-99

If ILIGNE<INBLIGNETOTAL
    #Tous les enregistrements n'ont pas pu être affichés, un critère plus discriminant doit être saisi.
    GMESSAGE = mess(963, 182, 2)
    GERR = 2
Endif


Return

