#<AdxTL>@(#)0.0.0.0 $Revision$
Call MANAGE_LOCALISATION_HIDE("OCTR")
End
Subprog MANAGE_LOCALISATION_HIDE(THIS_WINDOW)
Value Char THIS_WINDOW()

Call HIDE_FIELDS_AUTO(THIS_WINDOW)

End

#########################################################################################

Subprog HIDE_FIELDS_AUTO(THIS_WINDOW)
#Local Shortint I
Value Char THIS_WINDOW()
Local Char THIS_SCREEN(12)
Local Char THIS_ACT(GLONACV)
Local Char DATA_TYPE(GLONATY)
Local Decimal TYP_LEN()
Local Integer INT_TYP()
Local Decimal SCR_LEN()
Local Char ADO_TYP(50)
Local Shortint LOM_NUM()
Local Char THIS_SCREENABR(GLONABR)
Local Integer FIRSTCHAR
Local Integer LOOPNUMBER
Local Integer CALLCOUNTER
Local Char BLOCACTARRAY(GLONACV)(1..)
Local Integer BLOC_NUM()
Local Char THIS_FIELD(GLONAVA)
Local Char THIS_SCREENACTCOD(GLONACV)
#MIPEA - 2016-11-02 - REQ 114309 - START
Local Integer BLOCTYPARRAY(1..)
Local Integer BLOC_TYPE
Local Integer FIELD_DIM
#MIPEA - 2016-11-02 - REQ 114309 - END

#Opening required tables
If !clalev([F:ACVZZ])  : Local File ACTIV [ACVZZ]      : Endif
If !clalev([F:ACVZZ3]) : Local File ACTIV [ACVZZ3]     : Endif     #Third Instance
If !clalev([F:ADIZZ])  : Local File ATABDIV [ADIZZ]    : Endif
If !clalev([F:AMZZZ])  : Local File AMSKZON [AMZZZ]    : Endif
If !clalev([F:AMKZZ])  : Local File AMSK [AMKZZ]       : Endif
If !clalev([F:ADATYP]) : Local File ATYPE [ADATYP]     : Endif
If !clalev([F:ADIZZ])  : Local File ATABDIV [ADIZZ]    : Endif
If !clalev([F:AWIZZ])  : Local File AWINDOW [AWIZZ]    : Endif

Read [F:AWIZZ]AWI0 = THIS_WINDOW
If !fstat
#JASMI - START
  Gosub GET_LOCALIZATIONS
#JASMI - END

#Checking header screens
  If [F:AWIZZ]MSKENT<>""
  #fields
    THIS_SCREEN=[F:AWIZZ]MSKENT
    Gosub CHECK_FIELDS_FOR_SCREEN
  Endif

  #Checking tab screens
  For I = 0 To [F:AWIZZ]NBMSK-1
    #fields
    THIS_SCREEN=[F:AWIZZ]NOMMSK(I)
    Gosub CHECK_FIELDS_FOR_SCREEN
  Next
Endif

Wrseq ''
Wrseq "End"

#close file
Openo

If GOK<>0
  Gosub COMPILE_HIDE_SCRIPT
Endif

End

#########################################################################################

#JASMI - START
$GET_LOCALIZATIONS
Local Char LOC_ACT(GLONACV)(1..)
Local Integer ACT_COUNT : ACT_COUNT=0

  If !clalev([F:ACVZ4])  : Local File ACTIV [ACVZ4]      : Endif
  If !clalev([F:ACVZ5])  : Local File ACTIV [ACVZ5]      : Endif
  If !clalev([F:ACVZ6])  : Local File ACTIV [ACVZ6]      : Endif

  For [ACVZ4] Where [ACVZ4]TYP=3 & [ACVZ4]FLACT=2
    [L]ACT_COUNT+=1
    [L]LOC_ACT([L]ACT_COUNT)=[ACVZ4]CODACT
    For [ACVZ5] Where [ACVZ5]DEP=4 & [ACVZ5]FLACT=2
      If instr(1, [ACVZ5]ACTFOR, [ACVZ4]CODACT)>0
        [L]ACT_COUNT+=1
        [L]LOC_ACT([L]ACT_COUNT)=[ACVZ5]CODACT
        For [ACVZ6] Where [ACVZ6]DEP=4 & [ACVZ6]FLACT=2
          If instr(1, [ACVZ6]ACTFOR, [ACVZ5]CODACT)>0
            [L]ACT_COUNT+=1
            [L]LOC_ACT([L]ACT_COUNT)=[ACVZ6]CODACT
          Endif
        Next
      Endif
    Next
  Next

Return
#JASMI - END

$CHECK_FIELDS_FOR_SCREEN

GOK=1
Filter [F:AMZZZ]
Filter [F:AMKZZ]
Filter [F:ADIZZ]
Filter [F:AMKZZ] Where [F:AMKZZ]CODMSK  = THIS_SCREEN #& [F:AMKZZ]NBBLOC=[F:AMZZZ]NUMBLOC
Filter [F:ADIZZ] Where [F:ADIZZ]NUMTAB  = 10302

Read [F:AMKZZ]First
THIS_SCREENABR=[F:AMKZZ]ABRMSK
THIS_SCREENACTCOD=[F:AMKZZ]CODACT

Raz BLOCACTARRAY

#CREATING BLOCK ACTIVITY CODE ARRAY
For X = 0 To [F:AMKZZ]NBBLOC-1
  BLOCACTARRAY(X+1)=[F:AMKZZ]ACTBLOC(X)
#MIPEA - 2016-11-02 - REQ 114309 - START
  BLOCTYPARRAY(X+1)=[F:AMKZZ]TYPBLOC(X)
  #MIPEA - 2016-11-02 - REQ 114309 - END
Next

#POPULATE SUBPROGS FOR ALL LOCALISATION ACTIVITY CODES
#write call subprog with activity code calls per Legislation
LOOPNUMBER=1
Gosub CREATE_HIDE_SCRIPT

#########################################################################################

For [AMZZZ] Where CODMSK = THIS_SCREEN
LOOPNUMBER=2
DATA_TYPE =[F:AMZZZ]CODTYP
SCR_LEN =[F:AMZZZ]LONG
LOM_NUM =[F:AMZZZ]NOLIB
BLOC_NUM =[F:AMZZZ]NUMBLOC
#MIPEA - 2016-11-02 - REQ 114309 - START
#THIS_FIELD=[F:AMZZZ]CODZON
FIELD_DIM=[F:AMZZZ]DIME
#MIPEA - 2016-11-02 - REQ 114309 - END

#JASMI - START
#If [F:AMZZZ]CODACT<>"" THIS_ACT=[F:AMZZZ]CODACT : Endif
#If [F:AMZZZ]CODACT="" and BLOCACTARRAY(BLOC_NUM)<>"" THIS_ACT=BLOCACTARRAY(BLOC_NUM) : Endif
#If [F:AMZZZ]CODACT="" and BLOCACTARRAY(BLOC_NUM) ="" THIS_ACT=THIS_SCREENACTCOD      : Endif
THIS_ACT=""
If [F:AMZZZ]CODACT<>"" & find([F:AMZZZ]CODACT,[L]LOC_ACT(1..[L]ACT_COUNT))>0
  THIS_ACT=[F:AMZZZ]CODACT
Endif
If THIS_ACT=""
  If BLOCACTARRAY(BLOC_NUM)<>"" & find(BLOCACTARRAY(BLOC_NUM),[L]LOC_ACT(1..[L]ACT_COUNT))>0
    THIS_ACT=BLOCACTARRAY(BLOC_NUM)
  Endif
Endif
If THIS_ACT=""
  If THIS_SCREENACTCOD<>"" & find(THIS_SCREENACTCOD,[L]LOC_ACT(1..[L]ACT_COUNT))>0
    THIS_ACT=THIS_SCREENACTCOD
  Endif
Endif
#JASMI - END

#MIPEA - 2016-11-02 - REQ 114309 - START
  BLOC_TYPE = BLOCTYPARRAY(BLOC_NUM)
#MIPEA - 2016-11-02 - REQ 114309 - END

  If THIS_ACT<>""
#JASMI - START
#    Read [F:ACVZZ3]CODACT = THIS_ACT
#      If [F:ACVZZ3]FLACT=2
#          If (left$(THIS_ACT,1)="K"|left$(THIS_ACT,2)="FK") | [F:ACVZZ3]DEP=4
#JASMI - END
            Read [F:ADATYP]CODTYP = DATA_TYPE
            INT_TYP=[F:ADATYP]TYPTYP
            TYP_LEN =[F:ADATYP]LNGTYP
            ADO_TYP =[F:ADATYP]FORTYP
#MIPEA - 2016-11-02 - REQ 114309 - START
  If BLOC_TYPE <> 1 & FIELD_DIM > 1
    For BT = 0 To FIELD_DIM-1
      THIS_FIELD = [F:AMZZZ]CODZON+"("+num$(BT)+")"
      Gosub CREATE_HIDE_SCRIPT
    Next
  Else
    THIS_FIELD=[F:AMZZZ]CODZON
    Gosub CREATE_HIDE_SCRIPT
  Endif
  #Gosub CREATE_SHOW_SCRIPT
#MIPEA - 2016-11-02 - REQ 114309 - END
  Endif
Next

Return

#########################################################################################

$CREATE_HIDE_SCRIPT
Local Char RET_ACTCODE(GLONACV)(1..)
Local Char SEND_ACTCODE(GLONACV)(1..)
Local Char COMBINED_ACTCODE(GLONACV)(1..)
Local Integer ISFOUND()
Local Char MISCACT(5)
Local Char MISCLEG(GLONADI)


CALLCOUNTER+=1
If CALLCOUNTER=1 & LOOPNUMBER=1
#get filename
  SCRISRC = filpath("TRT","W"+THIS_WINDOW+"HIDE","src",nomap)

#open source file
  Openo SCRISRC,0
  adxifs = ""
  adxirs = chr$(10)

#write creation details
  Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
  Wrseq '# User :'-GUSER
  Wrseq '# Date :'-format$("DD4",date$)
  Wrseq ''
  Wrseq "Subprog HIDE_ACTIVITYFIELDS"
  Wrseq ''

Endif

#########################################################################################

If LOOPNUMBER=2
#write write change formats to show fields for each activity code
Case INT_TYP
  When 1
    #"LA" (Local MENU)
    LAVAL = "-LA:"+num$(LOM_NUM)
          Wrseq "If dim([M:"+THIS_SCREENABR+"]"+THIS_FIELD+")>0 : "+"Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
&         " With "+"'"+LAVAL+"'"+" : Endif"
  When 2,3,4,5,6
    #"NZ" (Number)
    If DATA_TYPE <> "ABS"
      If SCR_LEN<>0
        NZVAL ="-Nz:"+num$(SCR_LEN)
          Wrseq "If dim([M:"+THIS_SCREENABR+"]"+THIS_FIELD+")>0 : "+"Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
&         " With "+"'"+NZVAL+"'"+" : Endif"
      Endif
      If SCR_LEN=0 & TYP_LEN<>0
        NZVAL ="-Nz:"+num$(TYP_LEN)
          Wrseq "If dim([M:"+THIS_SCREENABR+"]"+THIS_FIELD+")>0 : "+"Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
&         " With "+"'"+NZVAL+"'"+" : Endif"
      Endif
      If SCR_LEN=0 & TYP_LEN=0
        NZVAL ="-Nz:"+ADO_TYP
        Wrseq "If dim([M:"+THIS_SCREENABR+"]"+THIS_FIELD+")>0 : "+"Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
&         " With "+"'"+NZVAL+"'"+" : Endif"
     Endif
    Else
     If SCR_LEN<>0
        NZVAL ="-Nz:"+num$(SCR_LEN)
        NZVAL2="+Nz:"+num$(SCR_LEN)
          Wrseq "If dim([M:"+THIS_SCREENABR+"]"+THIS_FIELD+")>0 : "+"Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
&         " With "+"'"+NZVAL2+"'"+" : Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
&         " With "+"'"+NZVAL+"'"+" : Endif"
     Endif
     If SCR_LEN=0 & TYP_LEN<>0
        NZVAL ="-Nz:"+num$(TYP_LEN)
        NZVAL2="+Nz:"+num$(TYP_LEN)
          Wrseq "If dim([M:"+THIS_SCREENABR+"]"+THIS_FIELD+")>0 : "+"Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
&         " With "+"'"+NZVAL2+"'"+" : Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
&         " With "+"'"+NZVAL+"'"+" : Endif"
     Endif
     If SCR_LEN=0 & TYP_LEN=0
        NZVAL ="-Nz:"+ADO_TYP
        NZVAL2="+Nz:"+ADO_TYP
        Wrseq "If dim([M:"+THIS_SCREENABR+"]"+THIS_FIELD+")>0 : "+"Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
&         " With "+"'"+NZVAL2+"'"+" : Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
&       " With "+"'"+NZVAL+"'"+" : Endif"
     Endif
   Endif
  When 7
    #"K" (ALPHA)
    If SCR_LEN<>0
      KVAL="-K:"+num$(SCR_LEN)
      Wrseq "If dim([M:"+THIS_SCREENABR+"]"+THIS_FIELD+")>0 : "+"Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
& " With "+"'"+KVAL+"'"+" : Endif"
    Else
      KVAL="-K:"+num$(TYP_LEN)
      Wrseq "If dim([M:"+THIS_SCREENABR+"]"+THIS_FIELD+")>0 : "+"Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
& " With "+"'"+KVAL+"'"+" : Endif"
    Endif
  When 8, 12
    #"D" (Date)
    DVAL="-D:"+GFMDAT4
    Wrseq "If dim([M:"+THIS_SCREENABR+"]"+THIS_FIELD+")>0 : "+"Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
& " With "+"'"+DVAL+"'"+" : Endif"
#JASMI - 2016-11-02 - START
  When 10
    #CLOB
    Wrseq "If dim([M:"+THIS_SCREENABR+"]"+THIS_FIELD+")>0 : "+"Chgfmt [M:"+THIS_SCREENABR+"]"+THIS_FIELD+
& " With "+"'-"+DATA_TYPE+"'"+" : Endif"
#JASMI - 2016-11-02 - END
Endcase

Endif

Return

#########################################################################################

$COMPILE_HIDE_SCRIPT

If dim(OK)<0 : Local Integer OK : Endif

Call VALID("TRT","W"+THIS_WINDOW+"HIDE",nomap,OK) From VALMSKSUB
If OK=0
  GOK=0
  GMESSAGE = mess(35, 11662, 1)
Endif

Return

#########################################################################################

