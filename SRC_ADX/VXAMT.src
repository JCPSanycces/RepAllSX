#<AdxTL>@(#)2.0.0.0 $Revision$
####################################################################################
# Program Name: XAMT
# Description : ADC ADC Material Issue
# Date        : Mar 1, 2007
# Type        :
####################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)

Call SAISIE_CHAR(VALEUR,PARAM,"VXAMT","VXAMT","XVWXAMT") From GSAISIE
End

########################################################
# Material consumption
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# FCY, MFGNUM, ITMREF, USEQTY, STU,  CLEFLG, BOMSEQ, MFGLIN,
# STA, LOC, LOT, SLO, PALNUM, CTRNUM, SERNUM, SERNUMF
# WSTOSEQ
#
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Automatic determination' --> No
#
########################################################

########################################################
$ACTION
#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "AVANT_OK"      : Gosub AVANT_OK
 When "OK"            : Gosub OK
 When "BOUTON"        : Gosub BOUTON
 When "END"           : Gosub CHECK
 When "FIN"           : Gosub FIN
Endcase

Return

########################################################
# Actions liées à la fenètre de saisie
########################################################

########################################################
$OUVRE
Global Char    GMMLNUM(GLONTRS)
Local Char CRIT1
Local Integer  VALOK


If clalev([F:BTS]) =0 : Local File BENCHTRS [BTS]  : Endif


GVTMOD=1

# Initialisation du site de stock
Gosub INIT_STOFCY From ENVADC

Raz GMMLNUM

#Filter [F:BTS] Where BTSTYP = 61 and STKFLG <> 2

#Read [F:BTS] First
#If fstat = 0
#    GMMLNUM = [F:BTS]BTSNUM
#Endif

#"Filter [F:BTS]

#GMMLNUM contains the consumption transaction
GMMLNUM = func ENVADC.SETMFGTRANS(61)

Gosub OUVRE_MBM From ENVADC
Return

########################################################
$DEBUT
Local Integer WOK, WCPT
Global Char GTRAVT(250)
Gosub DEBUT_MBM From ENVADC
# verify that the ADC site is set
If GXAFCY=""
   Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN = 2 : Return
Endif

Gosub INIT_SCREEN

Return

########################################################
$SETBOUT

If !find("1",CHMEN) CHMEN+="1" Endif
Return

########################################################
$AVANT_OK

If [M]MFGNUM="" | [M]ITMREF="" | [M]USEQTY <=0
   GERR=1 : GMESSAGE=mess(17,7750,1)
   zonsui="[M:XAMT]MFGNUM"
   Return
Endif
Return

########################################################
$OK
Gosub OK_MBM From ENVADC
If GERR = 1  :    zonsui="[M:XAMT]MFGNUM" : Return : Endif

If GOUVSOR>=1
   GERR=1 : GMESSAGE=mess(12,7750,1)
   zonsui="[M:XAMT]MFGNUM" : Return
Endif
[L]WCPT = [M:XAMT]WCPT
Effzo [M:XAMT]1-99
[M:XAMT]WCPT   = [L]WCPT+1

[M]MMLNUM  = GMMLNUM

[M]FCY     = GXAFCY
[M]IPTDAT  = date$
Affzo [M:XAMT]1-99
Grizo [M:XAMT]MMLNUM

Return

########################################################
$BOUTON

# Création
If BOUT="1" Gosub CRE : Endif
# Abandon
If BOUT="2" Gosub ABA Endif

Return

########################################################
$ABA

If [M:MBM]NBLIG > 0
    Call DELSTOSORW(-1,0,"MBM",[M:MBM]FCY,WRET) From STKSOR
Else
    Call RAZSTOSORW From STKSOR
Endif

Gosub INIT_SCREEN
Return

########################################################
$CRE
# Si article renseigné, enregistrement de la saisie (bouton OK)
If [M]ITMREF<>""
   Gosub AVANT_OK
   If GERR=1 Return Endif
   Gosub OK
   If GERR=1 Return Endif
Endif

If [M:MBM]NBLIG=0
    GERR=1
    # CCC (2010-03-09) Bug 63134
    #GMESSAGE=mess(52,8016,1)
    GMESSAGE=mess(17,7750,1)
    FIN = 0
    Return
Endif

Gosub CRE_MBM From ENVADC
If [M:MBM]NBLIG<>0 : # GH 02/2016 bug 108954 if the validation transaction failed, give the opportunity to make a new try
   [M:XAMT]WCPT = [M:MBM]NBLIG : Affzo [XAMT]WCPT
   WOK=2
   # Tracking creation failed. New try ?
   Call OUINON(mess(254,193,1)+"\"+mess(182,188,1)-"?",WOK) From GESECRAN
   If WOK=2 : GNOLIG=[M:MBM]NBLIG : Goto CRE : Endif
Endif

Gosub INIT_SCREEN
Return

########################################################
$CHECK
Local Integer WOK
If [M:MBM]NBLIG<>0
   WOK=1
   # Pièce en cours de saisie non enregistrée
   Call OUINON(mess(38,7750,1),WOK) From GESECRAN
   If WOK<>2
      FIN=0 : zonsui="[M:XAMT]MFGNUM" : Return
   Endif
Endif

Return

########################################################
$FIN

Gosub FIN_MBM From ENVADC

GVTMOD=0
Kill GTRAVT

Return

########################################################
$INIT_SCREEN

Gosub RAZ_MBM From ENVADC
Raz [M:XAMT]

[M:XAMT]MMLNUM  = GMMLNUM
[M:XAMT]TRSCODS = [F:BTS]TRSCODS
[M:XAMT]TRSTYP  = 6
[M:XAMT]FCY     = GXAFCY
[M:XAMT]IPTDAT  = date$
Actzo [XAMT]1-99
Affzo [XAMT]1-99
nolign=0
Default Mask [XAMT]
GREP="" : REP=""

Return



######################################################################################
## Etiquette ajoutée par le superviseur (écran VXAMT) 27/02/2007 11:26:31 (SR)
######################################################################################
Subprog AM_MMLNUM(VALEUR)
Variable Char    VALEUR()
GMMLNUM = VALEUR
[M:XAMT]TRSCODS = [F:BTS]TRSCODS
End

########################################################
Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   mkstat=2 : End
Endif
Gosub C_MFGNUM_MBM From ENVADC
End

########################################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
Gosub AS_ITMREF_MBM From ENVADC
End

########################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   mkstat=2 : End
Endif
End

########################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer WRET
Gosub AM_ITMREF_MBM From ENVADC
If GMESSAGE <> ""  : mkstat = 1 : End : Endif
[M:XAMT]STU=[F:MFM]STU
Affzo [M:XAMT]USEQTY, STU, STA, LOC, LOT, SLO, CLEFLG
End

########################################################
Subprog AM_USEQTY(VALEUR)
Variable Decimal VALEUR
Local Integer LRET
Call CONT_SOLDE_MAT([M]FCY,[M]ITMREF,VALEUR,[M]WQTY,LRET) From MFGLIBM
If LRET = 1 : [M]CLEFLG = 2
Else          [M]CLEFLG = 1
Endif
Affzo [M]CLEFLG
End

########################################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
# Issue 110327
If [F:ITM]SERMGTCOD <> 4
  If [M:XAMT]USEQTY=1
    Read [STO]STO5=[M:XAMT]ITMREF;VALEUR
    If fstat
      mkstat=2 : End
    Else
      If dim([M:XAMT]LOT)>0  [M:XAMT]LOT=[F:STO]LOT  Endif
      If dim([M:XAMT]SLO)>0  [M:XAMT]SLO=[F:STO]SLO  Endif
      If dim([M:XAMT]LOC)>0  [M:XAMT]LOC=[F:STO]LOC  Endif
      [M:XAMT]STA = [F:STO]STA
      Affzo [M:XAMT]1-99
    Endif
  Endif
Endif

Gosub AM_SERNUM_MBM From ENVADC
End

########################################################
Subprog AM_MFGNUM(VALEUR)
Variable Char    VALEUR()
Raz [M]MFGLIN
Raz [M]BOMSEQ
Raz [M]ITMREF
End

