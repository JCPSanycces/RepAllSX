#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du masque TRTDAT
####################################################################################################################
# HCM V8 :
# To manage the filter by GCURLEG on the main process    : Already done by DBA
# To manage the filter on new concept of population      : Already done by DBA
###################################################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTDAT","TRTDAT",4,"") From GTRAITE
End

#########################################
## Traitement des actions : TRTAUT
#########################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE From TRTAUT  :#86255
 When "EXEC"        : Gosub EXEC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1
 When "DEBUT"       : Gosub DEBUT From TRTAUT     :#86255
 When "BOUTON"      : Gosub BOUTON From TRTAUT    :#86255
 When "SORTIE"      : Gosub SORTIE From TRTAUT    :#86255
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

#######################################################
## (Actions nécessaires à la saisie des paramètres)
#######################################################
$OUVRE
Gosub OUVFIC

Local Integer NBPCE
Local Char    CRITERE(250)
Local Char    CRITERE1(250)
Local Char    TIT(50)
Local Char    MESSA(50)
Local Char    SYMBOLE(80)
Local Char    VALPAR(10)
Local Date    DATDEB , DATFIN
Local Integer I , J , K , OK , OPT

#Modification de la date de paye
TIT = mess(51,10703,1)
NBPCE=0

#86255
If dim(GCURLEG)>0 :  Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif

Local Mask TRTDAT [DIA]
Raz [M:DIA]
[M:DIA]DATDEB = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
[M:DIA]DATFIN = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
[M:DIA]DATPAI = gdat$(func DIVPAYE.INIPARUSR("DATREG","",""))
[M:DIA]OLDDAT = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
Call LECMEMO("STD","[M:DIA]","dat") From GMEMO
#86255
Call AFF_MEMO From DIVPAYE
Return

######################################################
$OUVFIC
Gosub OUVRE From WPDEFTABLE
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:SRV])=0 : Local File SERVICE    [SRV] : Endif
If clalev([F:PRF])=0 : Local File PROFIL     [PRF] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA] : Endif
If clalev([F:VEP])=0 : Local File VALEMP     [VEP] : Endif
If clalev([F:VP2])=0 : Local File VALEMP     [VP2] : Endif
If clalev([F:HSP])=0 : Local File HISTOPAYE  [HSP] : Endif
If clalev([F:VLA])=0 : Local File VALEUR     [VLA] : Endif
If clalev([F:VAN])=0 : Local File VALANA     [VAN] : Endif
If clalev([F:VPR])=0 : Local File VALPRV     [VPR] : Endif
# DBA le 02/08/04 : Gestion commentaire variables par un CLOB
If clalev([F:BCB])=0 : Local File BCLOB      [BCB] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif
##64942
If clalev([F:ADU])=0 : Local File ADOVALAUS [ADU] : Endif
Return

#FRLAA - 2016-04-01 - REQUIREMENT 114309 US 135 - START
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return
#FRLAA - 2016-04-01 - REQUIREMENT 114309 US 135 - END

$EXEC
Local Date    DATFINPAY , DATPAY , DATMAT
Local Integer RETOUR , NOK , OKC, NBFCY
#FRLAA - 2016-04-01 - REQUIREMENT 114309 US 135 - START
Local Char    MATCUR(GLONMAT) , MATREF(GLONMAT) , MATRI(GLONMAT) , SYMBOLE(80), TABFCY(GLONFCY)(1..900)
#Local Char    MATCUR(GLONEML) , MATREF(GLONEML) , MATRI(GLONEML) , SYMBOLE(80), TABFCY(GLONFCY)(1..900)
#FRLAA - 2016-04-01 - REQUIREMENT 114309 US 135 - END

#ouverture de la trace et écriture de l'en-tête
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

#86255
CRITERE = '[F:CPY]LEG="'+GCURLEG+'"'

# mise en place du filtre sur la table des salariés
CRITERE -= "& [F:ID]FLGPAY=2"

If [M:DIA]ALLCPY<>2  #société
 CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif
If [M:DIA]ALLFCY<>2
 CRITERE -= '& [F:HRCTR]ETRFCY="'+[M:DIA]FCY+'"' :# site
Endif
If [M:DIA]ALLSRV<>2
 CRITERE -= '& [F:HRCTR]ETRSRV="'+[M:DIA]SRV+'"' :# service
Endif
If [M:DIA]ALLPRF<>2
 CRITERE -= '& [F:HRCTR]PROPRF="'+[M:DIA]PRF+'"' :# profil
Endif

If [M:DIA]POP<>""
#86255
 Link [HRCTR] With
&    [ID]ID0=[F:HRCTR]REFNUM,
&    [FCY]FCY0=[F:HRCTR]ETRFCY,
&    [CPY]CPY0=[F:FCY]LEGCPY,
&    [HRPOA]POA0= [M:DIA]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&   As [LNK]
&   Where evalue(CRITERE) & [F:HRPOA]REFNUM<>""
Else
 Link [HRCTR] With
&   [ID]ID0 = [F:HRCTR]REFNUM,
&   [FCY]FCY0=[F:HRCTR]ETRFCY,
&   [CPY]CPY0=[F:FCY]LEGCPY
&   As [LNK]
&   Where evalue(CRITERE)
Endif

For [LNK]
#86255
 For [VEP] Where EMP=[F:ID]REFNUM & PYRDAT=[M:DIA]OLDDAT & CTRNUM=[HRCTR]CTRNUM & CTRDAT=[HRCTR]CTRDAT
  Readlock [VEP]VEP0 Curr
  If fstat=0
   Gosub VERIF_PAYE
   If GOK=1
    Call DEBTRANS From GLOCK
    NBPCE = NBPCE+1
    Gosub TR1
    If GOK=1
     # Modification de la date de paye
     Call ECR_TRACE([F:ID]REFNUM-":"-mess(51,10703,1)-num$([M:DIA]OLDDAT)-"->"-num$([M:DIA]DAT)-"("+[F:VEP]BUL+")",0) From GESECRAN
    Endif
   Endif
   Unlock =SYMBOLE
  Endif
 Next
Next

If !NBPCE
 Call ECR_TRACE(mess(50,10703,1),0) From GESECRAN : # Aucune paye à traiter
Else
 Call ECR_TRACE(num$(NBPCE)-mess(49,10703,1),0) From GESECRAN : # payes modifiées
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

#######################################################
$VERIF_PAYE
GOK=0
#FRLAA - 2016-04-01 - REQUIREMENT 114309 US 135 - START
# Critère sur site
If [M:DIA]ALLFCY<>2 & [F:VEP]FCY <> [M:DIA]FCY  :# site
 Return
Endif

# Critère sur service
If [M:DIA]ALLSRV<>2 & [F:VEP]SRV <> [M:DIA]SRV  :# service
 Return
Endif

# Critère sur profil
If [M:DIA]ALLPRF<>2 & [F:VEP]PRF <> [M:DIA]PRF  :# profil
 Return
Endif

# Critère sur société
If [M:DIA]ALLCPY<>2 & !find([F:VEP]FCY,TABFCY(1..NBFCY))  :#société
 Return
Endif
#FRLAA - 2016-04-01 - REQUIREMENT 114309 US 135 - END

#Verif si c'est pas une extourne (#78800) alors on verif que bien la dernière
If [F:VEP]ORIDAT=[0/0/0]
 Filter [VP2] Where EMP=[F:ID]REFNUM & CTRNUM=[F:VEP]CTRNUM & CTRDAT=[F:VEP]CTRDAT
 Read [VP2]VEP0 Last
 Filter[VP2]
 If fstat=0
  If [F:VEP]PYRDAT<[F:VP2]PYRDAT : Return : Endif
 Else
  Return
 Endif
Endif

# Verrou
Call VEPSYMBOLE (SYMBOLE, "VEP") From DIVPAYE
Lock =SYMBOLE
If fstat
 Call ECR_TRACE([F:ID]REFNUM-":"-mess(10,100,1),1) From GESECRAN
 Return
Endif

# Non comptabilisé
If [F:VEP]PST>1 : Return : Endif     :# Déjà comptabilisé
GOK=1
Return

#######################################################
$TR1
Trbegin [VEP], [HSP], [VLA], [VAN], [VPR], [BCB]
 Gosub MAJ_HSP
 Gosub MAJ_VLA
 Gosub MAJ_VAN
 Gosub MAJ_VPR
 Gosub MAJ_BCB
 Gosub MAJ_PARAM
 #FRLAA - 2016-04-01 - REQUIREMENT 114309 US 135 - START
 #107614 : Ajout PE
 [V]GPE = 0
 GPOINT = "CHGDATPAI" : Gosub ENTREE From EXEFNC
 If GPE=1 : GOK=0 : Endif
 If GOK
  [F:VEP]PYRDAT=[M:DIA]DAT
  Rewrite [VEP]
  If fstat
   GOK = 0 : Call FSTA("VEP") From GLOCK
  Endif
  #[F:VEP]PYRDAT=[M:DIA]DAT
  #Rewrite [VEP]
  #If fstat
  #GOK = 0 : Call FSTA("VEP") From GLOCK
 Endif
 If GOK<1 : Gosub AB_TR1 : Return : Endif
Commit
#FRLAA - 2016-04-01 - REQUIREMENT 114309 US 135 - END
Return

#######################################################
$MAJ_HSP
For [HSP] Where BUL=[F:VEP]BUL
 Readlock [F:HSP]Curr
 If !fstat
  [F:HSP]DAT=[M:DIA]DAT
  Rewrite [HSP]
  If fstat
   GOK = 0 : Call FSTA("HSP") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Gosub AB_TR1 : Return : Endif
Return

#######################################################
$MAJ_VLA
For [VLA] Where TYP=4 & CPY="" & FCY="" & EMP=[F:ID]REFNUM & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL
 Readlock [F:VLA]Curr
 If !fstat
  [F:VLA]DAT=[M:DIA]DAT
  Rewrite [VLA]
  If fstat
   GOK = 0 : Call FSTA("VLA") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Gosub AB_TR1 : Return : Endif
Return

#######################################################
$MAJ_VAN
For [VAN] Where EMP=[F:ID]REFNUM & PYRDAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL
 Readlock [F:VAN]Curr
 If !fstat
  [F:VAN]PYRDAT=[M:DIA]DAT
  Rewrite [VAN]
  If fstat
   GOK = 0 : Call FSTA("VAN") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Gosub AB_TR1 : Return : Endif
Return

#######################################################
$MAJ_VPR
For [VPR] Where EMP=[F:ID]REFNUM & CTRNUM=[F:VEP]CTRNUM & DAT=[F:VEP]PYRDAT
 Readlock [F:VPR]Curr
 If !fstat
  [F:VPR]DAT=[M:DIA]DAT
  Rewrite [VPR]
  If fstat
   GOK = 0 : Call FSTA("VPR") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Gosub AB_TR1 : Return : Endif
Return

#######################################################
#######################################################
# Ca sert plus à rien
$MAJ_BCB
Return

For [BCB] Where find(CODBLB,"VARTXT","VEPTXT")<>0 & IDENT2=[F:VEP]BUL
 Readlock [F:BCB]Curr
 If !fstat
  Rewrite [BCB]
  If fstat
   GOK = 0 : Call FSTA("BCB") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Gosub AB_TR1 : Return : Endif
Return


#64942 : Nouveau $MAJ_PARAM
#######################################################
$MAJ_PARAM
VALPAR = format$("YYYYMMDD",[M:DIA]DAT)
Readlock [ADU]ADU0 = GUSER;"DATPAY"
If !fstat
 [F:ADU]VALEUR = VALPAR
 Rewrite [ADU]
Else
 GOK = -1 : GLOCK = "$ADOVALAUS" : Return
Endif
If fstat
 GOK = 0 : Call FSTA("ADU") From GLOCK : Return
Endif
If GOK<1 : Gosub AB_TR1 : Return : Endif
Return

#64942 : Ancien $MAJ_PARAM
#######################################################
$OLDMAJ_PARAM
VALPAR = format$("YYYYMMDD",[M:DIA]DAT)
Readlock [ADW]ADW0 = "";"";"DATPAY"
If fstat=0
 [F:ADW]VALEUR = VALPAR
 Rewrite [ADW]
Else
 GOK = -1 : GLOCK = "$ADOVAL" : Return
Endif
If fstat
 GOK = 0 : Call FSTA("ADW") From GLOCK : Return
Endif
 If GOK<1 : Gosub AB_TR1 : Return : Endif
Return

#######################################################
$AB_TR1
Rollback
Return


