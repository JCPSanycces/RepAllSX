#FRLAA - 2016-04-01 - REQUIREMENT 114309 US 135 - END

## Sélection matricule
$SEL_TABLE
Case TABLE
 When "SELEMP"
  OBJET   = "EML"
Endcase
Return

#############################################################
## Contrôles sur la date de paye
#############################################################
## La date de paye doit être comprise entre
## Le premier jour du mois de paye (GMOIPAY) et
## la fin du mois + un nb jour de "décalage" (GJMAX)
## Entre le 1 et GJMAX on avertit seulement
#############################################################

Subprog C_OLDDAT(VALEUR)
Variable Date    VALEUR
Local Integer OK
If VALEUR<GMOIPAY or VALEUR>eomonth(GMOIPAY)+GJMAX
 GBIDI1=1
 OK = 2 : Call AVERTIR(mess(21,10702,1)-"("+format$("D:"+GFMMOI,GMOIPAY)+")",OK) From GESECRAN
 # Date incompatible avec le mois de paye
 If OK<>2 : GBIDI1=0 : mkstat = 2 : End : Endif
Elsif VALEUR<GMOIPAY+GJMAX
 OK = 2 : Call AVERTIR(mess(22,10702,1)-"("+format$("D:"+GFMDAT4,GMOIPAY+GJMAX)
&  +"-"+format$("D:"+GFMDAT4,eomonth(GMOIPAY)+GJMAX)+")",OK) From GESECRAN
 # Date en dehors de la période de paye
 If OK<>2 : mkstat = 2 : End : Endif
Endif
End

Subprog C_DAT(VALEUR)
Variable Date    VALEUR
Local Integer OK
If VALEUR<GMOIPAY or VALEUR>eomonth(GMOIPAY)+GJMAX
 GMESSAGE = mess(21,10702,1)-"("+format$("D:"+GFMMOI,GMOIPAY)+")"
 #Date incompatible avec le mois de paye
 mkstat = 2 : End
Endif
If VALEUR<GMOIPAY+GJMAX
 OK = 2 : Call AVERTIR(mess(22,10702,1)-"("+format$("D:"+GFMDAT4,GMOIPAY+GJMAX)
&  +"-"+format$("D:"+GFMDAT4,eomonth(GMOIPAY)+GJMAX)+")",OK) From GESECRAN
 #Date en dehors de la période de paye
 If OK<>2 : mkstat = 2 : End : Endif
Endif
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Local Integer OK
If VALEUR > [M:DIA]DAT or (VALEUR > [M:DIA]OLDDAT & !GBIDI1)
 #Date de paye en dehors de la période
 Call AVERTIR(mess(22,10702,1),OK) From GESECRAN
 If OK=1 : mkstat=2 : Endif
Endif
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Local Integer OK
#FRLAA - 2016-04-01 - REQUIREMENT 114309 US 135 - START
If VALEUR<[M:DIA]DATDEB
#Période incorrecte
 GMESSAGE = mess(25,702,1)
 mkstat = 2 : End
Endif
#FRLAA - 2016-04-01 - REQUIREMENT 114309 US 135 - END

If [M:DIA]DAT>VALEUR+GJMAX or ([M:DIA]OLDDAT>VALEUR+GJMAX & !GBIDI1)
 #Date de paye en dehors de la période
 Call AVERTIR(mess(22,10702,1),OK) From GESECRAN
 If OK=1 : mkstat=2 : Endif
Endif
End

