########################################################################
# Traitement STKENTA - Librairie de composants communs entrées         #
########################################################################
# Sous-programmes
#-----------------------------------------------------------------------
# CUTLIGSLO         Découpe une quantité en tenant compte des arrondis
# COPYENTWLIG       Copie une ligne de ENTW sur une autre
# ADDLOTBLANC       Ajoute le complément lot correspondant au lot blanc
#                   dans le masque passé en paramètre
# ADDLOTENTW
# SEARCHLOTENTW
# SEARCHGESLOT
# SEARCHLOTENT
# SEARCHGESLOT
# SEARCHLOTENTM
########################################################################

################################################################################
# CUTLIGSLO      Découpe une quantité en tenant compte des arrondis
################################################################################
# Paramètres E : LABR    = Abréviation du masque écran de saisie
#                LLIG    = Numéro de la ligne (nolign-1) de l'écran de saisie
#                PQTY    = Quantité UC à répartir
#                PNBSLO  = Nombre de sous-lot
#                PUOM    = UC
# Paramètre  S : PTABQTY = Tableau des quantités réparties
################################################################################
Subprog CUTLIGSLO(LABR,LLIG,PQTY,PNBSLO,PUOM,PTABQTY)
Value    Char    LABR
Value    Integer LLIG
Value    Decimal PQTY
Variable Integer PNBSLO                             # hcb X3-94838
Value    Char    PUOM
Variable Decimal PTABQTY(0..)

Local Decimal LQTY
Local Decimal LQTYTOT
Local Integer I

LQTYTOT =  PQTY
# hcb 36778 deb

GPOINT = "QTYSLO_ENTW"
GPE    = 0
Gosub  ENTREE From EXEFNC
If GPE = 0
# hcb 36778 fin
   LQTY=PQTY/PNBSLO
   Call QTEARR2(LQTY, PUOM, 1) From TRTDIV
   For I=0 To PNBSLO-2
       If PQTY < LQTY
          PTABQTY(I) = PQTY
          PNBSLO = I+1                                         # hcb X3-94838
          Break
       Else
          PTABQTY(I) = LQTY
          PQTY = PQTY-LQTY
       Endif
   Next
   If LQTYTOT-(PNBSLO-1)*LQTY > 0                              # hcb X3-94838
      PTABQTY(PNBSLO-1)= LQTYTOT-(PNBSLO-1)*LQTY
   Else
      If PTABQTY(PNBSLO-1) = 0
         PNBSLO -= 1
      Endif
   Endif                                                       # hcb X3-94838
Endif
End

###############################################################################
# COPYENTWLIG : Copie une ligne de ENTW sur une autre
###############################################################################
# Paramètres E : PFROM   = indice de la ligne à copier
#                PTO     = Indice de la ligne sur laquelle on effectue la copie
#                PFIELDEX= Nom(s) de champ(s) à exclure de la copie
#                           QPCU: pour la quantité en UC (La quantité US est calculée
#                                 avec la valeur de [M:ENTW]QTYPCU(LTO) )
#                           EMP : pour l'emplacement
#                PTRS    = Type de transaction (m. 704) (nécessaire si g° d'emplacement)
#                PTRSCOD = Code mouvement               (nécessaire si g° d'emplacement)
#                PFCY    = Site                         (nécessaire si g° d'emplacement)
#                PBPS    = Tiers                        (nécessaire si g° d'emplacement)
#
# Pré-requis : Table ITMFACILIT [ITF] positionnée
###############################################################################
Subprog COPYENTWLIG( PFROM, PTO, PFIELDEX, PTRS, PTRSCOD, PFCY, PBPS)
Value Integer PFROM
Value Integer PTO
Value Char    PFIELDEX # FGR 18/01/2010 : X3SUIVI60986
Value Integer PTRS
Value Char    PTRSCOD
Value Char    PFCY
Value Char    PBPS

Local Integer  LRET
Local Shortint WRET
Local Decimal  WOVF

    [M:ENTW]ORILIG    (PTO) = [M:ENTW]ORILIG   (PFROM)
    [M:ENTW]WSTOSEQ   (PTO) = [M:ENTW]WSTOSEQ  (PFROM)
    [M:ENTW]ITMREF    (PTO) = [M:ENTW]ITMREF   (PFROM)
    [M:ENTW]PCU       (PTO) = [M:ENTW]PCU      (PFROM)
    If !instr(1,PFIELDEX,"QPCU")
        [M:ENTW]QTYPCU(PTO) = [M:ENTW]QTYPCU   (PFROM)
    Endif
    [M:ENTW]PCUSTUCOE (PTO) = [M:ENTW]PCUSTUCOE(PFROM)
    [M:ENTW]QTYSTU    (PTO) = [M:ENTW]QTYPCU   (PFROM)*[M:ENTW]PCUSTUCOE(PFROM)
    [M:ENTW]STOCOU    (PTO) = [M:ENTW]STOCOU   (PFROM)
    [M:ENTW]SERNUM    (PTO) = [M:ENTW]SERNUM   (PFROM)
    [M:ENTW]SERNUMF   (PTO) = [M:ENTW]SERNUMF  (PFROM)
    [M:ENTW]STA       (PTO) = [M:ENTW]STA      (PFROM)
    [M:ENTW]LBEFMT    (PTO) = [M:ENTW]LBEFMT   (PFROM)
    [M:ENTW]LBENBR    (PTO) = [M:ENTW]LBENBR   (PFROM)
    [M:ENTW]PALNUM    (PTO) = [M:ENTW]PALNUM   (PFROM)
    [M:ENTW]CTRNUM    (PTO) = [M:ENTW]CTRNUM   (PFROM)
    [M:ENTW]QLYCTLFLG (PTO) = [M:ENTW]QLYCTLFLG(PFROM)
    [M:ENTW]NUMLIGLOT (PTO) = [M:ENTW]NUMLIGLOT(PFROM)
    [M:ENTW]SAIACTFLG (PTO) = [M:ENTW]SAIACTFLG(PFROM)

    [M:ENTW]STOFLD1   (PTO) = [M:ENTW]STOFLD1  (PFROM)
    [M:ENTW]STOFLD2   (PTO) = [M:ENTW]STOFLD2  (PFROM)

    [M:ENTW]LOCTYP    (PTO) = [M:ENTW]LOCTYP   (PFROM)
    [M:ENTW]WRH       (PTO) = [M:ENTW]WRH      (PFROM)
    If !instr(1,PFIELDEX,"EMP")
        [M:ENTW]LOC   (PTO) = [M:ENTW]LOC      (PFROM)
    Endif

    If [F:ITF]LOCMGTCOD=2
        # Réservation de l'emplacement
        Call STKWLOCSEQ("ENTW", PTO, LRET) From STKECR

        Call STKCTRTLO([M:ENTW]WLOCSEQ(PTO),PTRS,PTRSCOD,PFCY,[M:ENTW]ITMREF(PTO),
&                      [M:ENTW]PCU(PTO),[M:ENTW]QTYPCU(PTO),[M:ENTW]STA(PTO),
&                      0,[M:ENTW]LOCTYP(PTO),WRET,"","",[M:ENTW]WRH(PTO))
&                      From STKLOC

        Call STKCTREMP([M:ENTW]WLOCSEQ(PTO),PTRS,PTRSCOD,PFCY,[M:ENTW]ITMREF(PTO),
&                      [M:ENTW]PCU(PTO),[M:ENTW]QTYPCU(PTO),[M:ENTW]STA(PTO),
&                      [M:ENTW]LOCTYP(PTO),[M:ENTW]LOC(PTO),PBPS,0,WRET,
&                      WOVF,"","",[M:ENTW]WRH(PTO)) From STKLOC
    Endif
End

###############################################################################
# ADDLOTBLANC : Ajoute le complément lot correspondant au lot blanc dans le
#               masque passé en paramètre
###############################################################################
Subprog ADDLOTBLANC( PABR )
Value Char PABR

    Assign "[M:"+PABR+"]LOT(0)"     With ""
    If evalue("dim([M:"+PABR+"]SLO)")>0
        Assign "[M:"+PABR+"]SLO(0)" With ""
    Endif
#                                                      # hcb 71276 deb

    If evalue("dim([M:"+PABR+"]ECCVALMAJ)")>0
        Assign "[M:"+PABR+"]ECCVALMAJ(0)" With ""
    Endif
    If evalue("dim([M:"+PABR+"]ECCVALMIN)")>0
        Assign "[M:"+PABR+"]ECCVALMIN(0)" With ""
    Endif
#                                                      # hcb 71276 deb

    Assign "[M:"+PABR+"]BPSLOT   (0)"  With ""
    Assign "[M:"+PABR+"]GESLOT   (0)"  With "B"
    Assign "[M:"+PABR+"]REFPER   (0)"  With "000000"
    Assign "[M:"+PABR+"]SHL      (0)"  With 0
    Assign "[M:"+PABR+"]SHLDAT   (0)"  With "000000"
    Assign "[M:"+PABR+"]SHLUOM   (0)"  With 1        # hcb V6per
    Assign "[M:"+PABR+"]SHLLTI   (0)"  With 0        # hcb V6per
    Assign "[M:"+PABR+"]SHLLTIUOM(0)"  With 1        # hcb V6per
    Assign "[M:"+PABR+"]NEWLTIDAT(0)"  With "000000" # hcb V6per
    Assign "[M:"+PABR+"]DLU      (0)"  With 0        # hcb V6per
    Assign "[M:"+PABR+"]DLUDAT   (0)"  With "000000" # hcb V6per
    Assign "[M:"+PABR+"]POT      (0)"  With 100
    Assign "[M:"+PABR+"]ACT      (0)"  With 1
    Assign "[M:"+PABR+"]USRFLD1  (0)"  With ""
    Assign "[M:"+PABR+"]USRFLD2  (0)"  With ""
    Assign "[M:"+PABR+"]USRFLD3  (0)"  With 0
    Assign "[M:"+PABR+"]USRFLD4  (0)"  With "000000"
    Assign "[M:"+PABR+"]MODIF    (0)"  With 1
    Assign "[M:"+PABR+"]VALIDE   (0)"  With 2
    Assign "[M:"+PABR+"]NBLIGLOT"      With 1
End

###############################################################################
# ADDLOTENTW : Trouve ou ajoute un lot dans STOENTW
#              et renvoie l'indice de la ligne
###############################################################################
# Paramètres E : PITM = Article
#                PLOT = Numéro de lot
#                PSLO = Numéro de sous lot
#                PLOF = Numéro de lot fournisseur
#                PGES = Type de n° de lot: ""  -> N° lot saisi
#                                          "B" -> N° lot = Blanc
#                                          "C" -> N° lot = N° de compteur
#                                          "V" -> N° lot = N° de pièce
#
#            S : PLIG = indice de la ligne dans le tableau
#                       complément lot de STOENTW
###############################################################################
Subprog ADDLOTENTW( PITM, PLOT, PSLO, PLOF, PGES, PLIG)
Value    Char    PITM
Value    Char    PLOT
Value    Char    PSLO
Value    Char    PLOF
Value    Char    PGES
Variable Integer PLIG

If PGES="" | PGES="V"
    Call SEARCHLOTENTW( PITM, PLOT, PSLO, -1, PLIG ) From STKENTA
Else
    If PGES="B"
#        PSLO="00001"
        Raz PSLO
    Endif
    PLIG =-1
Endif

If PLIG = -1
    [M:ENTW]LOT   ([M:ENTW]NBLIGLOT) = PLOT
    [M:ENTW]SLO   ([M:ENTW]NBLIGLOT) = PSLO
    [M:ENTW]BPSLOT([M:ENTW]NBLIGLOT) = PLOF
    [M:ENTW]GESLOT([M:ENTW]NBLIGLOT) = PGES
    PLIG = [M:ENTW]NBLIGLOT

    [M:ENTW]NBLIGLOT += 1
Endif

End

###############################################################################
# SEARCHLOTENTW : Trouve un lot dans STOENTW
#                 et renvoie l'indice de la ligne (-1 si non trouvé)
#
# ATTENTION :  Si aucun lot n'est passé en paramètre cela veut dire
#              qu'on recherche un lot qui a pour n° la pièce courante
###############################################################################
# Paramètres E : PITM = Article
#                PLOT = Numéro de lot
#                PSLO = Numéro de sous lot
#                PWSTOSEQEX = Numéro de séquence à supprimer de la recherche
#                             ( Utile en particulier dans le contrôle de lot
#                               et de sous lot )
#
#            S : PLIG = indice de la ligne dans le tableau
#                       complément lot de STOENTW
###############################################################################
Subprog SEARCHLOTENTW( PITM, PLOT, PSLO, PWSTOSEQEX, PLIG)
Value    Char    PITM
Value    Char    PLOT
Value    Char    PSLO
Value    Integer PWSTOSEQEX # FGR 18/01/2010 : X3SUIVI60986
Variable Integer PLIG
#--- L'utilisation de la formule sigma(...) ci-dessous, utilisée dans SEARCHLOTENTW et SEARCHLOTENT
#--- a permis de passer le temps d'ouverture de la fenêtre détail, lors de la création d'une ligne de document avec 200 sous-lots
#--- de plus de 55s à 6s
#---
#--- structure du sigma:  sigma(0, nblig-1, indcum*( condition(indcum) & sigma(nblig,nblig,0)=0 )
#---         où : condition(indcum) = condition à vérifier, lot(indcum)=PLOT
#---                                                       &slo(indcum)=PSLO si PSLO<>""
#---                                                       &article utilsant le lot&slo = PITM & dont wstoseq<>PWSTOSEQEX
#--- !!!!!NON!!!!!sigma(nblig,nblig,0)=0 permet d'arrêter en cours de route le calcul de sigma !!! -> interdit, génère des erreurs imprévisibles
#---                => remplacé par " & I=0 & sigma(I=1,1,1)" qui ne peut êtr vrai qu'une seule fois
#---              indcum* => le résultat correspond à l'indice de la ligne recherchée
#---
    Local Integer I,J
    PLIG =sigma(1, [M:ENTW]NBLIGLOT-1,indcum*( ([M:ENTW]LOT(indcum)=PLOT | (PLOT="" & [M:ENTW]GESLOT(indcum)="V")) & ( PSLO="" | ([M:ENTW]SLO(indcum)=PSLO) )
&                                  & I=0 & sigma(J=0,[M:ENTW]NBLIG-1, ([M:ENTW]NUMLIGLOT(J)=indcum) &
&                                                                ([M:ENTW]ITMREF(J)=PITM) &
&                                                                (PWSTOSEQEX<>[M:ENTW]WSTOSEQ(J)) &
&                                                                ([M:ENTW]WSTOSEQ(J)<>0)) & I=0 & sigma(I=1,1,1) ))
    If PLIG<=0
        PLIG = -1
    Endif
# suppression du dim([M:ENTW]SLO)>0                  # 66114  gain 18  secondes sur 950 slo  (HCB)
# ajout : & I=0  en début 2 eme ligne du sigma       # 66114  gain 850 secondes sur 950 slo  (CCC)

End

###############################################################################
# SEARCHGESLOTW : Trouve l'indice de la ligne complément lot correspondant à
#                un GESLOT passé en paramètre
###############################################################################
# Paramètres E : PGESLOT = "C"
#                PSLO    = Numéro de sous lot
#                PWSTOSEQ= Numéro de séquence à respecter
#
#            S : PLIG = indice de la ligne dans le tableau
#                       complément lot de STOENT
###############################################################################
Subprog SEARCHGESLOTW ( PGESLOT, PLOF, PSLO, PWSTOSEQ, PLIG)
Value    Char    PGESLOT
Value    Char    PLOF
Value    Char    PSLO
Value    Integer PWSTOSEQ
Variable Integer PLIG

    #------ Voir explications dans SEARCHLOTENTW  --------#
    Local Integer I,J
# Attention : (indcum+1)*... ==> il faut enlever 1 ensuite à PLIG
  PLIG =sigma(0, [M:ENTW]NBLIG-1,(indcum+1)*( PWSTOSEQ=[M:ENTW]WSTOSEQ(indcum) & [M:ENTW]NUMLIGLOT(indcum)<>-1
&                            & ([M:ENTW]GESLOT([M:ENTW]NUMLIGLOT(indcum))=PGESLOT)
&                            & ([M:ENTW]BPSLOT([M:ENTW]NUMLIGLOT(indcum))=PLOF)
&                            & ( PSLO="" | (dim([M:ENTW]SLO)>0 & [M:ENTW]SLO([M:ENTW]NUMLIGLOT(indcum))=PSLO) ) & I=0 & sigma(I=1,1,1) ))
    If PLIG<=0
        PLIG = -1
    Else
        PLIG = [M:ENTW]NUMLIGLOT(PLIG-1)
    Endif

End

###############################################################################
# SEARCHLOTENT : Trouve un lot dans STOENT
#              et renvoie l'indice de la ligne (-1 si non trouvé)
###############################################################################
# Paramètres E : PLOT = Numéro de lot
#                PSLO = Numéro de sous lot
#                PLIGEX = Indice de ligne à exclure de la recherche
#                         (=-1 si aucune ligne à exclure)
#
#            S : PLIG = indice de la ligne dans le tableau
#                       complément lot de STOENT
###############################################################################
Subprog SEARCHLOTENT( PLOT, PSLO, PLIGEX, PLIG)
Value    Char    PLOT
Value    Char    PSLO
Value    Integer PLIGEX
Variable Integer PLIG

    #------ Voir explications dans SEARCHLOTENTW  --------#
    Local Integer I,J
    PLIG =sigma(0, [M:ENT]NBLIGLOT-1,indcum*( ([M:ENT]LOT(indcum)=PLOT | (PLOT="" & [M:ENT]GESLOT(indcum)="V"))
&                                           & ( PSLO="" | (dim([M:ENT]SLO)>0 & [M:ENT]SLO(indcum)=PSLO) )
&                                           & sigma(J=0,[M:ENT]NBLIG-1, ([M:ENT]NUMLIGLOT(J)=indcum)
&                                                                      &(PLIGEX<>J) ) & I=0 & sigma(I=1,1,1) ))
    If PLIG<=0
        PLIG = -1
    Endif

End

###############################################################################
# SEARCHGESLOT : Trouve l'indice de la ligne complément lot correspondant à
#                un GESLOT passé en paramètre
###############################################################################
# Paramètres E : PGESLOT = "C"
#                PSLO = Numéro de sous lot
#                PLIGEX = Indice de ligne à exclure de la recherche
#                         (=-1 si aucune ligne à exclure)
#
#            S : PLIG = indice de la ligne dans le tableau
#                       complément lot de STOENT
###############################################################################
Subprog SEARCHGESLOT ( PABR, PGESLOT, PLOF, PSLO, PLIGEX, PLIG)
Value    Char    PABR
Value    Char    PGESLOT
Value    Char    PLOF
Value    Char    PSLO
Value    Integer PLIGEX
Variable Integer PLIG

Local Integer LSLO : Raz LSLO
If evalue("dim([M:"+PABR+"]SLO)")>0
    LSLO = 1
Endif

    #------ Voir explications dans SEARCHLOTENTW  --------#
    Local Integer I,J
    PLIG =sigma(0, [M]NBLIGLOT-1,indcum*( ([M]GESLOT(indcum)=PGESLOT)
&                                       & ([M]BPSLOT(indcum)=PLOF)
&                                       & ( PSLO="" | (LSLO>0 & [M]SLO(indcum)=PSLO) )
&                                       & sigma(J=0,[M]NBLIG-1, ([M]NUMLIGLOT(J)=indcum)
&                                                             & (PLIGEX<>J) )
&                                       & I=0 & sigma(I=1,1,1) ))
    If PLIG<=0
        PLIG = -1
    Endif

End

