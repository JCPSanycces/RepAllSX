#<AdxTL>@(#)12.0.0.0 $Revision$
#########################################################################
# CNSCSOSTD : Consultation des commandes ventes                         #
# ECRAN 1   : CONSCSO1                                                  #
# ECRAN 2   : CONSCSO2                                                  #
# ECRAN CRIT: CRITCSO                                                   #
#########################################################################

$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When Default
Endcase
Return

############################################################
$AUTORIS
Return
############################################################
$SETBOUT
# ------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                    #
# ------------------------------------------------------------------------------------- #
# B : HT/Catégorie          : Actif                                                     #
# C : HT/Statut             : Actif                                                     #
# D : Palmarès Client       : Actif                                                     #
# E : Palmarès Représentant : Actif si représentant présent                             #
# ------------------------------------------------------------------------------------- #

If [F:AMZ]CODMSK<>GBOITE | [F:AMZ]CODZON<>"REP1"
    Read [F:AMZ]CODE = GBOITE;"REP1"
    If fstat Raz [F:AMZ] : Endif
Endif
If [M:CSO2]NBLIG>0 CHMEN += "BCD" Endif
#If [M:CSO2]NBLIG>0 & [M:CSO1]BPCORD=""  CHMEN += "D" Endif
#If [M:CSO2]NBLIG>0 & [M:CSO1]BPCORD="" & [F:AMZ]SAIAFF= 2 CHMEN += "E" Endif
If [M:CSO2]NBLIG>0 & [F:AMZ]SAIAFF= 2 CHMEN += "E" Endif

Return
###########################################################################################
#    Après execution des menus                                                            #
###########################################################################################
$EXEBOUT

Case BOUT
    When "B", "C", "D", "E" :
#        OK=1 : CHANGE=1 : # Pour déclencher un réaffichage de la consultation
        [M:CSO1]ORDDATDEB=[M:CCSO]ORDDATDEB : # Pour restituer les critères de date de départ
        [M:CSO1]ORDDATFIN=[M:CCSO]ORDDATFIN
Endcase

Return
###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
Local Char    WFIL(250),WFIL1(250),WFIL2(250)
Local Char    DEBNUM, FINNUM, WSOHNUM
Local Date    DEBDAT, FINDAT

If clalev([F:DUD])=0 Local File GACCDUDATE [DUD] : Endif
If clalev([F:SOQ])=0 Local File SORDERQ [SOQ] : Endif
If clalev([F:TCU])=0 Local File TABCUR [TCU]  : Endif
If clalev([F:AMZ])=0 Local File AMSKZON [AMZ]  : Endif

NAVIG="CONSCSO"

Gosub DEFCRIT
[M:CSO1]CURD=GSYSCUR
Return

# --------------------------------------------------------------------------#
# Analyse paramères, initialisations                                        #
# --------------------------------------------------------------------------#
$DEFCRIT
If [M:CSO1]SALFCY<>"" & GUSRFCY(1)<>"\" & !find([M:CSO1]SALFCY,GUSRFCY(1..GNBAUZ))
 [M:CSO1]SALFCY=""
Endif

For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre Client
      If PARAM(I) <> ""
        If [F:BPC]BPCNUM<>PARAM(I) Read [F:BPC]BPC0 = PARAM(I)
                                     If fstat
                                       Raz [F:BPC], PARAM(I)
                                     Endif
        Endif
        [M:CSO1]BPCORD = PARAM(I)
      Endif
    When 2 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [F:FCY]FCY0 = PARAM(I)
                                     If fstat
                                       Raz [F:FCY], PARAM(I)
                                     Endif
        Endif
        If GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ))
           [M:CSO1]SALFCY = PARAM(I)
           If [M:CSO1]SALFCY <> ""
             Call GETDEV([M:CSO1]SALFCY) From DEVSUB
             [M:CSO1]CPY  = GSOCIETE
             [M:CSO1]CURS = GLOCALDEV
           Endif
        Endif
      Endif
  Endcase
Next I

If !find([M:CSO1]SOHCATNOR,1,2) : [M:CSO1]SOHCATNOR = 2 : Endif
If !find([M:CSO1]SOHCATLND,1,2) : [M:CSO1]SOHCATLND = 2 : Endif
If !find([M:CSO1]SOHCATFAC,1,2) : [M:CSO1]SOHCATFAC = 2 : Endif
If !find([M:CSO1]ORDSTAO,1,2)   : [M:CSO1]ORDSTAO = 2 : Endif
If !find([M:CSO1]ORDSTAN,1,2)   : [M:CSO1]ORDSTAN = 2 : Endif
If !find([M:CSO1]APPFLGO,1,2)   : [M:CSO1]APPFLGO = 2 : Endif
If !find([M:CSO1]APPFLGN,1,2)   : [M:CSO1]APPFLGN = 2 : Endif
If !find([M:CCSO]TRI,1,2)       : [M:CCSO]TRI = 1   : Endif
If !find([M:CCSO]FMI,11,15)     : [M:CCSO]FMI = 11  : Endif

[M:CSO1]ORDDATFIN=eomonth(date$)
[M:CSO1]ORDDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))

# -- copie de l'écran critères (CCSO) vers le masque 1 (CSO1)
Gosub CRITENT From =PROGCNS

Return

############################################################
$LECTURE
Local   Decimal  WMNTORG(0..5), WMNTDES(0..5)
Local   Integer  SPSTAT, WFIC_FIL

# Mail CH : 03/03/04
#If [M:CSO1]CPY="" & [M:CSO1]SALFCY=""
# NBLU=0 : Return
#Endif

  # FGR 21/10/2009 : X3SUIVI56101
  If GPILNAV > 1 Then
    #acces depuis clients ou tiers
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC") Then
      Diszo [M:CSO1]BPCORD
    Endif

    # GRNA 16/05/2011
    Local Char CUSSEAORI : CUSSEAORI = "CSO1"
    Gosub LECTURE From CUSSEALIB
  Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCSO]TRI
      When 1 : # tri par numéro
        If WFIC_FIL = 0
            Filter [SOH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SOH0
        Else
            Filter [SOQ] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SOQ0
        Endif
      When 2 : # tri par date
        If WFIC_FIL = 0
            Filter [SOH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                        Order By Key CLE=[F:SOH]ORDDAT;[F:SOH]SOHNUM
        Else
            Filter [SOQ] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                        Order By Key CLE=[F:SOQ]ORDDAT;[F:SOQ]SOHNUM
        Endif
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCSO]TRI
      When 1 : # tri par numéro
        If WFIC_FIL = 0
            Filter [SOH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SOH0 Desc
        Else
            Filter [SOQ] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SOQ0 Desc
        Endif
      When 2 : # tri par date
        If WFIC_FIL = 0
            Filter [SOH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                        Order By [F:SOH]ORDDAT Desc ;[F:SOH]SOHNUM Desc
        Else
            Filter [SOQ] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                        Order By [F:SOQ]ORDDAT Desc ;[F:SOQ]SOHNUM Desc
        Endif
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CSO2] : Endif

#-- lecture
$BOUCLE
If WFIC_FIL=0
    For [SOH] With Nohint
      # Filtre sur la société
      If [M:CSO1]CPY <> ""
          If [F:FCY]FCY <> [F:SOH]SALFCY Read [F:FCY]FCY0 = [F:SOH]SALFCY
                                         If fstat  Raz [F:FCY] : Endif
                                         Endif
          If [F:FCY]LEGCPY <> [M:CSO1]CPY Goto SUIV : Endif
      Endif
      Gosub CHARGE_CNS
      If CHGPAG > 0 & NOL >= MAXLIG-1 & SUITE=2
          Break
      Elsif CHGPAG <= 0 & NOL <= 0 & RETOUR=2
          Break
      Endif
      $SUIV
    Next
Else
    WSOHNUM=""
    For [SOQ] With Nohint
      # Filtre sur la société
      If [M:CSO1]CPY <> ""
          If [F:FCY]FCY <> [F:SOQ]SALFCY Read [F:FCY]FCY0 = [F:SOQ]SALFCY
                                         If fstat  Raz [F:FCY] : Endif
                                         Endif
          If [F:FCY]LEGCPY <> [M:CSO1]CPY Goto SUIV1 : Endif
      Endif
      If WSOHNUM <> [F:SOQ]SOHNUM
          Read [F:SOH]SOH0 = [F:SOQ]SOHNUM
          If fstat  Raz [F:SOH] : Endif
          # Prise en compte des commandes soldées
          # --> Si 1 (Non) On exclut les commandes soldées
          If [M:CSO1]ORDSTAO = 1
              If [F:SOH]ORDSTA = 2 Goto SUIV1 Endif
          Endif
          # Prise en compte des commandes non soldées
          # --> Si 1 (Non) On exclut les commandes non soldées
          If [M:CSO1]ORDSTAN = 1
              If [F:SOH]ORDSTA = 1 Goto SUIV1 Endif
          Endif
          # Prise en compte des commandes signés
          # --> Si 1 (Non) On exclut les cdes totalement signées (val.3), pas de gestion (val.4), oui automatique (val.5)
          If [M:CSO1]APPFLGO = 1
             WFIL += "&[F:SOH]APPFLG<3"
          Endif
          # Prise en compte ou pas des commandes non signés
          # --> Si 1 (Non) On exclut les cdes non signées (valeur 1)
          If [M:CSO1]APPFLGN = 1
             WFIL += "&[F:SOH]APPFLG<>1"
          Endif
          Gosub CHARGE_CNS
          WSOHNUM=[F:SOQ]SOHNUM
          If CHGPAG > 0 & NOL >= MAXLIG-1 & SUITE=2
              Break
          Elsif CHGPAG <= 0 & NOL <= 0 & RETOUR=2
              Break
          Endif
      Endif
      $SUIV1
    Next
Endif

If WFIC_FIL=0 Filter [SOH] Else Filter [SOQ] : Endif

Return


############################################################
#    Chargement de l'écran de consultation                 #
############################################################
$CHARGE_CNS

If NBLU = 1
    If CHGPAG=2 | CHGPAG=-2 : Raz [M:CSO2] : Endif
    NBLU = 2
Endif
If CHGPAG > 0
#     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
    If NOL >= MAXLIG-1 : SUITE=2 : Return : Endif
    NOL    += 1
    If NOL=0
        DEBNUM = [F:SOH]SOHNUM
        DEBDAT = [F:SOH]ORDDAT
    Endif
    FINNUM = [F:SOH]SOHNUM
    FINDAT = [F:SOH]ORDDAT
Else
#     If NOL <= 0 : RETOUR=2 : Break : Endif
    If NOL <= 0 : RETOUR=2 : Return : Endif
    NOL    -= 1
    If NOL=MAXLIG-1
        FINNUM = [F:SOH]SOHNUM
        FINDAT = [F:SOH]ORDDAT
    Endif
    DEBNUM = [F:SOH]SOHNUM
    DEBDAT = [F:SOH]ORDDAT
Endif

# Modifié par Dominique BOPP après discussion avec Jacky LESAGE
# Objectif : disposer d'un maximum de rubriques possibles dans l'écran de consultation des devis
  nolign = NOL+1
  [M:CSO2]=[F:SOH] : # Un trans-classe pour commencer

# Ne subsistent ici que des champs dimensionnés de part et d'autre, pour lesquels un renommage
# est nécessaire dans les écrans
  If dim([M:CSO2]REP1)>=nolign
      [M:CSO2]REP1(nolign-1)       = [F:SOH]REP(0)
      If dim([M:CSO2]REP2)>=nolign : # L'un ne va pas sans l'autre
          [M:CSO2]REP2(nolign-1)       = [F:SOH]REP(1)
      Endif
  Endif
  [M:CSO2]BPCNAM1(nolign-1)    = [F:SOH]BPCNAM(0)

Raz WMNTORG
#    Calcul des montants en devise société
If [F:SOH]CUR <> [M:CSO1]CURS
    WMNTORG (0) = [F:SOH]ORDINVNOT : # Montants les plus complets (D BOPP pour 140)
    WMNTORG (1) = [F:SOH]ORDINVATI : # Montants les plus complets (D BOPP pour 140)
    Call CONVERT2([F:SOH]CUR, [M:CSO1]CURS, [M:CSO1]CURS, [F:SOH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
    Call CONVERT2([F:SOH]CUR, [M:CSO1]CURS, [M:CSO1]CURS, [F:SOH]CHGTYP, datesyst, WMNTORG(1), WMNTDES(1),SPSTAT) From TRTDEV
    If [F:TCU]CUR <> [M:CSO1]CURS
       Read [F:TCU]TCU0 = [M:CSO1]CURS
       If fstat Raz [F:TCU] : Endif
    Endif
    [M:CSO2]ORDNOTSOC(nolign-1)  = arr(WMNTDES(0),[F:TCU]CURRND)
    [M:CSO2]ORDATISOC(nolign-1)  = arr(WMNTDES(1),[F:TCU]CURRND)
Else
    [M:CSO2]ORDNOTSOC(nolign-1)  = [F:SOH]ORDINVNOT : # Montants les plus complets (D BOPP pour 140)
    [M:CSO2]ORDATISOC(nolign-1)  = [F:SOH]ORDINVATI : # Montants les plus complets (D BOPP pour 140)
Endif
#    Calcul des montants en devise dossier
If [F:SOH]CUR <> [M:CSO1]CURD
    WMNTORG (0) = [F:SOH]ORDINVNOT : # Montants les plus complets (D BOPP pour 140)
    WMNTORG (1) = [F:SOH]ORDINVATI : # Montants les plus complets (D BOPP pour 140)
#    Call CONVERT2_TAB([F:SOH]CUR, [M:CSO1]CURD, [M:CSO1]CURS, [F:SOH]CHGTYP, date$, WMNTORG, WMNTDES,SPSTAT) From TRTDEV
    Call CONVERT2([F:SOH]CUR, [M:CSO1]CURD, [M:CSO1]CURS, [F:SOH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
    Call CONVERT2([F:SOH]CUR, [M:CSO1]CURD, [M:CSO1]CURS, [F:SOH]CHGTYP, datesyst, WMNTORG(1), WMNTDES(1),SPSTAT) From TRTDEV
    If [F:TCU]CUR <> [M:CSO1]CURD
       Read [F:TCU]TCU0 = [M:CSO1]CURD
       If fstat Raz [F:TCU] : Endif
    Endif
    [M:CSO2]ORDNOTDOS(nolign-1)  = arr(WMNTDES(0),[F:TCU]CURRND)
    [M:CSO2]ORDATIDOS(nolign-1)  = arr(WMNTDES(1),[F:TCU]CURRND)
Else
    [M:CSO2]ORDNOTDOS(nolign-1)  = [F:SOH]ORDINVNOT : # Montants les plus complets (D BOPP pour 140)
    [M:CSO2]ORDATIDOS(nolign-1)  = [F:SOH]ORDINVATI : # Montants les plus complets (D BOPP pour 140)
Endif

#    Calcul du montant acomptes demandés
#    Calcul du montant acomptes reçus
Raz WMNTORG
For [DUD]DUD0 Where TYP="*SO" & NUM=[F:SOH]SOHNUM
    WMNTORG(0) += [F:DUD]AMTCUR
    WMNTORG(1) += [F:DUD]PAYCUR
    WMNTORG(2) += [F:DUD]AMTLOC
    WMNTORG(3) += [F:DUD]PAYLOC
#    WMNTORG(4) += [F:DUD]AMTRPT
#    WMNTORG(5) += [F:DUD]PAYRPT
Next
[M:CSO2]INSAMT(nolign-1)     = WMNTORG(0)
[M:CSO2]INSPAY(nolign-1)     = WMNTORG(1)
[M:CSO2]CURA(nolign-1)       = [F:SOH]CUR
[M:CSO2]INSAMTSOC(nolign-1)  = WMNTORG(2)
[M:CSO2]INSPAYSOC(nolign-1)  = WMNTORG(3)
[M:CSO2]INSAMTDOS(nolign-1)  = WMNTORG(4)
[M:CSO2]INSPAYDOS(nolign-1)  = WMNTORG(5)

Return

############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL    = "1=1"
WFIL1   = "1=1"
WFIL2   = "1=1"

WFIC_FIL=0
# filtre sur le n° de contremarque : il faut partir du fichier SOQ
If [M:CCSO]FMINUMDEB <> "" | [M:CCSO]FMINUMFIN <> ""
    WFIC_FIL=1 : Gosub LOAD_FILTER_SOQ : Return
Endif

If [M:CSO1]SALFCY <> ""
    WFIL += "&[F:SOH]SALFCY=[M:CSO1]SALFCY"
Endif
#    Autorisation site
# 86749 : Ctrl Autorisation site ssi aucun site saisi (si site saisi, le ctrl a été fait à la saisie)
#If GUSRFCY(1)<>"\" & [M:CSO1]SALFCY <> "" & GNBAUZ<>GNBSITE
If GUSRFCY(1)<>"\" & [M:CSO1]SALFCY = "" & GNBAUZ<>GNBSITE
# 86749
 WFIL += "& find([F:SOH]SALFCY,GUSRFCY(1..GNBAUZ))"
Endif

If [M:CSO1]BPCORD <> ""
   WFIL += "&[F:SOH]BPCORD =[M:CSO1]BPCORD"
Endif
WFIL += "&[F:SOH]SOHCAT<>4"
# Prise en compte des commandes normales
# --> Si 1 (Non) On exclut les commandes normales
If [M:CSO1]SOHCATNOR = 1
   WFIL += "&[F:SOH]SOHCAT<>1"
Endif
# Prise en compte des commandes de pret
# --> Si 1 (Non) On exclut les commandes de pret
If [M:CSO1]SOHCATLND = 1
   WFIL += "&[F:SOH]SOHCAT<>2"
Endif
# Prise en compte des commandes à facturation directe
# --> Si 1 (Non) On exclut les commandes de pret
If [M:CSO1]SOHCATFAC = 1
   WFIL += "&[F:SOH]SOHCAT<>3"
Endif

# Prise en compte des commandes soldées
# --> Si 1 (Non) On exclut les commandes soldées
If [M:CSO1]ORDSTAO = 1
   WFIL += "&[F:SOH]ORDSTA<>2"
Endif
# Prise en compte des commandes non soldées
# --> Si 1 (Non) On exclut les commandes non soldées
If [M:CSO1]ORDSTAN = 1
   WFIL += "&[F:SOH]ORDSTA<>1"
Endif

# Prise en compte des commandes signées
# --> Si 1 (Non) On exclut les cdes totalement signées (valeur 3), pas de gestion (valeur 4), oui automatique (valeur 5)
If [M:CSO1]APPFLGO = 1
   WFIL += "&[F:SOH]APPFLG<3"
Endif
# Prise en compte ou pas des commandes non signées
# --> Si 1 (Non) On exclut les cdes non signées (valeur 1)
If [M:CSO1]APPFLGN = 1
   WFIL += "&[F:SOH]APPFLG<>1"
Endif

If [M:CCSO]SOHNUMDEB <> ""
   WFIL += "&[F:SOH]SOHNUM>=[M:CCSO]SOHNUMDEB"
Endif
If [M:CCSO]SOHNUMFIN <> ""
   WFIL += "&[F:SOH]SOHNUM<=[M:CCSO]SOHNUMFIN"
Endif

If [M:CCSO]ORDDATDEB <> [0/0/0]
   WFIL += "&[F:SOH]ORDDAT>=[M:CCSO]ORDDATDEB"
Endif
If [M:CCSO]ORDDATFIN <> [0/0/0]
   WFIL += "&[F:SOH]ORDDAT<=[M:CCSO]ORDDATFIN"
Endif

# FGR 23/02/2015 : X3SUIVI104383 (début)
If [M:CCSO]SOHTYP <> "" Then
  WFIL1 += "&[F:SOH]SOHTYP=[M:CCSO]SOHTYP"
Endif
# FGR 23/02/2015 : X3SUIVI104383 (fin)

# 71065 : PJT
If [M:CCSO]PJTDEB <> ""
   WFIL1 += "&[F:SOH]PJT>=[M:CCSO]PJTDEB"
Endif
If [M:CCSO]PJTFIN <> ""
   WFIL1 += "&[F:SOH]PJT<=[M:CCSO]PJTFIN"
Endif
# 71065 : PJT

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCSO]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SOH]SOHNUM>=DEBNUM"
       When 2 : # tri par date
           WFIL1 += "&([F:SOH]ORDDAT>DEBDAT | ([F:SOH]ORDDAT=DEBDAT & [F:SOH]SOHNUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCSO]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SOH]SOHNUM>FINNUM"
       When 2 : # tri par date
           WFIL1 += "&([F:SOH]ORDDAT>FINDAT | ([F:SOH]ORDDAT=FINDAT & [F:SOH]SOHNUM>FINNUM))"
     Endcase
   When -2 : # retour
     Case [M:CCSO]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SOH]SOHNUM<DEBNUM"
       When 2 : # tri par date
           WFIL1 += "& ([F:SOH]ORDDAT<DEBDAT | ([F:SOH]ORDDAT=DEBDAT & [F:SOH]SOHNUM<DEBNUM))"
     Endcase
Endcase

Return

############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER_SOQ
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"

If [M:CSO1]SALFCY <> ""
   WFIL += "&[F:SOQ]SALFCY=[M:CSO1]SALFCY"
Endif
#    Autorisation site
If GUSRFCY(1)<>"\" & [M:CSO1]SALFCY <> "" & GNBAUZ<>GNBSITE
   WFIL += "& find([F:SOQ]SALFCY,GUSRFCY(1..GNBAUZ))"
Endif

If [M:CSO1]BPCORD <> ""
   WFIL += "&[F:SOQ]BPCORD =[M:CSO1]BPCORD"
Endif
WFIL += "&[F:SOQ]SOHCAT<>4"
# Prise en compte des commandes normales
# --> Si 1 (Non) On exclut les commandes normales
If [M:CSO1]SOHCATNOR = 1
   WFIL += "&[F:SOQ]SOHCAT<>1"
Endif
# Prise en compte des commandes de pret
# --> Si 1 (Non) On exclut les commandes de pret
If [M:CSO1]SOHCATLND = 1
   WFIL += "&[F:SOQ]SOHCAT<>2"
Endif
# Prise en compte des commandes à facturation directe
# --> Si 1 (Non) On exclut les commandes de pret
If [M:CSO1]SOHCATFAC = 1
   WFIL += "&[F:SOQ]SOHCAT<>3"
Endif

If [M:CCSO]SOHNUMDEB <> ""
   WFIL += "&[F:SOQ]SOHNUM>=[M:CCSO]SOHNUMDEB"
Endif
If [M:CCSO]SOHNUMFIN <> ""
   WFIL += "&[F:SOQ]SOHNUM<=[M:CCSO]SOHNUMFIN"
Endif

If [M:CCSO]ORDDATDEB <> [0/0/0]
   WFIL += "&[F:SOQ]ORDDAT>=[M:CCSO]ORDDATDEB"
Endif
If [M:CCSO]ORDDATFIN <> [0/0/0]
   WFIL += "&[F:SOQ]ORDDAT<=[M:CCSO]ORDDATFIN"
Endif

If [M:CCSO]FMINUMDEB <> "" | [M:CCSO]FMINUMFIN <> ""
   If [M:CCSO]FMI=11
       WFIL += "&([F:SOQ]FMI=5)"
   Else
       WFIL += "&([F:SOQ]FMI=2 | [F:SOQ]FMI=3)"
   Endif
   If [M:CCSO]FMINUMDEB <> ""
       WFIL += "&[F:SOQ]FMINUM>=[M:CCSO]FMINUMDEB"
   Endif
   If [M:CCSO]FMINUMFIN <> ""
       WFIL += "&[F:SOQ]FMINUM<=[M:CCSO]FMINUMFIN"
   Endif
Endif
Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCSO]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SOQ]SOHNUM>=DEBNUM"
       When 2 : # tri par date
           WFIL1 += "&([F:SOQ]ORDDAT>DEBDAT | ([F:SOQ]ORDDAT=DEBDAT & [F:SOQ]SOHNUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCSO]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SOQ]SOHNUM>FINNUM"
       When 2 : # tri par date
           WFIL1 += "&([F:SOQ]ORDDAT>FINDAT | ([F:SOQ]ORDDAT=FINDAT & [F:SOQ]SOHNUM>FINNUM))"
     Endcase
   When -2 : # retour
     Case [M:CCSO]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SOQ]SOHNUM<DEBNUM"
       When 2 : # tri par date
           WFIL1 += "& ([F:SOQ]ORDDAT<DEBDAT | ([F:SOQ]ORDDAT=DEBDAT & [F:SOQ]SOHNUM<DEBNUM))"
     Endcase
Endcase

Return

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT


Return

#############################################################################
##     Etiquettes masques CONSCSO1 & CONSCSO2 & CRITCSO                    ##
#############################################################################
############################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  [M]CURS = [F:CPY]ACCCUR : GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]SALFCY = ""
# Mail CH : 03/03/04
#  GERR=2 : GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
#  Raz [M]CURS
  [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Endif
Affzo [M]CURS
End
############################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
# -- Controle autorisation sur le site
    If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
        GMESSAGE=VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        mkstat=2 : End
    Endif
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    [M]CURS = GLOCALDEV
    Affzo [M]CPY, ZCPY, CURS
Elsif [M]CPY = ""
    # Mail CH : 03/03/04
    #    GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    #    mkstat = 2
    [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif

End
########################################
Subprog IB_NBLIG

GBOUT1 = mess(191, 198,1)-[M]SOHNUM(nolign-1)
End
########################################
Subprog AM_SOHNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]SOHNUMFIN= VALEUR : Endif
End

########################################
Subprog AM_ORDDATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M]ORDDATFIN= VALEUR : Endif
End
# 71065 : PJT
######################################################################################
Subprog AM_PJTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]PJTFIN= VALEUR : Affzo [M]PJTFIN Endif
End
# 71065 : PJT
########################################
Subprog AS_FMI(VALEUR)
Variable Integer VALEUR
Local Integer JL
For JL=1 To len(mess(0,725,1))
    GMENLOC(JL)=1
Next
GMENLOC(11)=0
GMENLOC(15)=0
End
########################################
Subprog AM_FMINUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]FMINUMFIN= VALEUR : Endif
End
########################################
Subprog IB_FMINUMDEB
Case [M]FMI
    When 11 : Raz GBOUT2
    When 15 : Raz GBOUT1
Endcase
End
########################################
Subprog IB_FMINUMFIN
Case [M]FMI
    When 11 : Raz GBOUT2
    When 15 : Raz GBOUT1
Endcase
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSCSO1) 19/04/2006 10:45:23 (JL)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Affzo CURS, ZCPY
Raz [M]SALFCY, ZSALFCY
Affzo SALFCY,ZSALFCY
If VALEUR<>"" : GSOCIETE=VALEUR : Endif
End

Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   Affzo CURS, CPY, ZCPY
Endif
End



#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif

Call VALGTC(APPLI,"CSO") From SUBGTC

End
######################################################################################

