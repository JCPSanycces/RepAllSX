#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################################
#
# TRTPHYELTISSM - Sortie massive des éléments physiques
#
######################################################################
# MODIF :
#
######################################################################


$ACTION

  #Infbox num$(ACTION)
  Case ACTION
    When "INIT"             : Gosub INIT
    When "AVANT_PAR"        : Gosub AVANT_PAR
    When "INIT_DIA"         : Gosub INIT_DIA
#
    When "OUVRE"            : Gosub OUVRE
    When "OUVRE_BATCH"      : Gosub OUVRE_BATCH
#
    When "DEBUT"            : Gosub DEBUT
    When "AP_CHOIX"         : Gosub AP_CHOIX
    When "APRES_MODIF"      : Gosub APRES_MODIF
    When "SETBOUT"          : Gosub SETBOUT
#
    When "CONTROLE"         : Gosub CONTROLE
    When "CONT_BATCH"       : Gosub CONT_BATCH

    When "EXEC"             : Gosub EXEC
    When "TERMINE"          : Gosub TERMINE

    When "OK"               : Gosub OK

    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$INIT_DIA
  # Action - Traitement ( Standard & Saisie et Execution - Batch)

  Global Integer ABANDON_TRT        : # -- Flag alimenté à 1 quand on clique sur le bouton FIN

  GOK=1

  # Chargement & affichage de la fenêtre de dialogue
  Gosub INIT_WIN_PHYELTISSM

  #=> On rend le masque en-tête invalide pour faire tous les contrôles
  Setmok [M:PHYM] With 0

  #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
  If clalev([M:ASL]) = 0 : Local Mask ASELOBJ [ASL] : Endif
  Default Mask [ASL]
  Gosub DEBUT From ASELOBJ
Return

#-------------------------------------------------------------------------------
$INIT
  # Action - ( Standard & Execution - Batch)

  Global Integer ABANDON_TRT   : # Flag alimenté à 1 quand on clique sur le bouton FIN

  # -- Ouverture des fichiers
  If clalev([F:CPY]) = 0 : Local File COMPANY     [CPY]  : Endif
  If clalev([F:FCY]) = 0 : Local File FACILITY    [FCY]  : Endif

  If clalev([F:PHY]) = 0 : Local File PHYELT    [PHY]  : Endif # Open for Memo

  Local Char DBGSTR_SAV(255)
  If clalev([M:PHYM])=0
    DBGSTR_SAV=dbgstr(1)         : # sauvegarde de la liste des masques par défaut
    Local Mask PHYELTISSM [PHYM] : # ouverture de [PHYM]
    Default Mask DBGSTR_SAV      : # restauration de la liste des masques
  Endif
  If clalev([M:PHYM1])=0
    DBGSTR_SAV=dbgstr(1)            : # sauvegarde de la liste des masques par défaut
    Local Mask PHYELTISSM1 [PHYM1]  : # ouverture de [PHYM1]
    Default Mask DBGSTR_SAV    : # restauration de la liste des masques
  Endif

  If GSERVEUR=1
    Gosub OUVRE From ASELOBJ
  Endif

Return


#-------------------------------------------------------------------------------
$OUVRE
 # Action  ( Saisie - Batch )
  # -- Ouverture des fichiers
  If clalev([F:CPY]) = 0 : Local File COMPANY     [CPY]  : Endif
  If clalev([F:FCY]) = 0 : Local File FACILITY    [FCY]  : Endif

  If GBATCH=0
      # Ouverture de l'écran de sélection étendue
      PARAM(1) = "PHY"
      #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
      Gosub OUVRE From ASELOBJ
      If clalev([M:ASL]) = 0 : Local Mask ASELOBJ [ASL] : Endif
      Default Mask [ASL]
      Gosub DEBUT From ASELOBJ
  Endif
Return


#-------------------------------------------------------------------------------
$OUVRE_BATCH
 # Action  ( Saisie - Batch )
  # -- Ouverture des fichiers
  If clalev([F:CPY]) = 0 : Local File COMPANY     [CPY]  : Endif
  If clalev([F:FCY]) = 0 : Local File FACILITY    [FCY]  : Endif


  # Ouverture de l'écran de sélection étendue
  PARAM(1) = "PHY"
  #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
  Gosub OUVRE From ASELOBJ

Return


#-------------------------------------------------------------------------------
$AVANT_PAR
 # Action  (Massif uniquement - Interactif et soumission batch)

Return


#-------------------------------------------------------------------------------
$DEBUT
  # Action - Traitement ( Standard & Saisie et Execution - Batch)
  GOK=1

  # Chargement & affichage de la fenêtre de dialogue
  Gosub INIT_WIN_PHYELTISSM

  #=> On rend le masque en-tête invalide pour faire tous les contrôles
  Setmok [M:PHYM] With 0

  #=> Raz de l'onglet supplémentaire
  Raz [M:ASL]FLD1, [M:ASL]VAL1
  Raz [M:ASL]FLD2, [M:ASL]VAL2
  Raz [M:ASL]FLD3, [M:ASL]VAL3
  Raz [M:ASL]FLD4, [M:ASL]VAL4
  Raz [M:ASL]FLD5, [M:ASL]VAL5

Return


#-------------------------------------------------------------------------------
$AP_CHOIX
  Case REPONSE
    When GSTAOK   : ABANDON_TRT = 0
    When GSTAEND  : ABANDON_TRT = 1
  Endcase

Return

#-------------------------------------------------------------------------------
$SETBOUT
  Grizo [M:ASL]TBL1
  Grizo [M:ASL]TBL2
  Grizo [M:ASL]TBL3
  Grizo [M:ASL]TBL4
  Grizo [M:ASL]TBL5
  Affzo [M:ASL]
Return


#-------------------------------------------------------------------------------
$APRES_MODIF
Return


#-------------------------------------------------------------------------------
$OK
Return

#-------------------------------------------------------------------------------
$CONTROLE
  # Action - Traitement ( Standard & Execution - Batch)
  If GSERVEUR = 0
    If ABANDON_TRT=1 : Return : Endif

    # Contrôle
    Gosub CTRL_SORTIE
  Endif
Return

#-------------------------------------------------------------------------------
$CONT_BATCH

  # Action - Traitement ( Standard & Execution - Batch)
  If ABANDON_TRT=1 : Return : Endif

    # Contrôle
    Gosub CTRL_SORTIE
Return

$CTRL_SORTIE

  If [M:PHYM1]FLGSIM = [V]CST_AYES and [M:PHYM1]FLGTRC <> [V]CST_AYES
    [M:PHYM1]FLGTRC = [V]CST_AYES
    Affzo [M:PHYM1]FLGTRC
  Endif

  #------------------------------
  #------------------------------
Return

#-------------------------------------------------------------------------------
$EXEC
  If ABANDON_TRT=1 : Return : Endif

  Local Integer RET

  If GBATCH=0 and GSERVEUR=0
    Gosub OUVRE From ASELOBJ
  Endif

  # Construction de la clause WHERE
  Gosub BUILD_WHERE_FILTER

  # Ouverture du Compte-rendu
  If [M:PHYM1]FLGTRC= G_OUI Then
    Global Instance CLOG Using C_FXDLOG

    Gosub ECR_TRACE_INIT
    Gosub ECR_TRACE_HEADER
  Endif

  # Traitement de transfert
  Call TEMPON('C') From GESECRAN
  If [M:PHYM1]ISSACT = [V]CST_IAISS
    Gosub SORTIE
  Elsif [M:PHYM1]ISSACT = [V]CST_IACNLISS
    Gosub ANNULATION_SORTIE
  Else
    Gosub ABANDON_ANNULATION_SORTIE
  Endif
  Call TEMPOFF() From GESECRAN

  If [M:PHYM1]FLGTRC= G_OUI  Then
    Gosub ECR_TRACE_FOOTER
  Endif

# CFF  If !(GSERVEUR) and [M:PHYM1]FLGTRC= G_OUI Then
  If [M:PHYM1]FLGTRC= G_OUI Then
    # Fermeture du Compte-rendu
    [L]RET = fmet CLOG.LOG_CLOSE()

    # Visualisation du Compte-rendu (code CLASSIC)
    Local Char STRACE(GLONTRA)
    STRACE = GTRACE
    GTRACE = CLOG.LOG_NAME
    Call LEC_TRACE From LECFIC
    GTRACE = STRACE

    # Free class
    FreeGroup CLOG
    # Kill the global declaration
    If (dim(CLOG)>0) : Kill CLOG : Endif

  Endif

  FIN = 1
Return

#-------------------------------------------------------------------------------
$TERMINE

  # Action - Traitement ( Standard & Execution - Batch)
  Call TEMPOFF() From GESECRAN

  # -- Interactif
  If (dim(ABANDON_TRT)>0)  : Kill ABANDON_TRT       : Endif

  If (clalev([M:PHYM])) Then
    Close Mask [PHYM]
  Endif

  If (clalev([M:PHYM1])) Then
    Close Mask [PHYM1]
  Endif

  If (clalev([M:ASL])) Then
    Close Mask [ASL]
  Endif
Return

#-------------------------------------------------------------------------------
$SORTIE
  #==================================
  # Sortie des éléments physiques
  #==================================
  Global Integer NBPHY_INF : Raz NBPHY_INF
  Global Integer NBPHY_TRT : Raz NBPHY_TRT
  Global Integer NBPHY_WAR : Raz NBPHY_WAR
  Global Integer NBPHY_ERR : Raz NBPHY_ERR
  Local Integer LOK

  Trbegin [CPY]
  # Warning: use [CPY] file because the [PHY] file will be open later

  # -- Progress bar declaration : Title
  Global Char TXTPROG(40) : TXTPROG = mess(214, GML_MSGPHY, 1)
  Call TEMPOFF() From GESECRAN
  Call OUVRE_BOITE(TXTPROG, 0) From GESECRAN

  # -- Call the class transfer function
  Local Instance ISS_PARAM Using C_PHYELTISS
  ISS_PARAM = NewInstance C_PHYELTISS AllocGroup null
  # Set parameter class properties
  ISS_PARAM.ISSDAT     = [M:PHYM1]ISSDAT
  ISS_PARAM.ISSTYP     = [M:PHYM1]ISSTYP
  ISS_PARAM.PHY_FILTER = LFILTER
  If (CRITSUP <> "") Then
    # Ctitère supplémentaire de la Selection étendue
    ISS_PARAM.PHY_FILTER += " and " + CRITSUP
  Endif
  If [M:PHYM1]FLGTRC= G_OUI
    ISS_PARAM.TRT_CALLBACK = "TRTPHYELTISSM"
  Else
    ISS_PARAM.TRT_CALLBACK = AVOID.ACHAR
  Endif
  # Call the class transfer function with link option
  [L]LOK = func PHYELT_C_MPR._ISSUE_PHYELT_POPULATION(ISS_PARAM)
  # Free parameter class
  FreeGroup ISS_PARAM

  # -- Close progress bar
  Call FERME_BOITE From GESECRAN

  If ([M:PHYM1]FLGSIM = G_OUI) Then
    Rollback
  Else
    Commit
  Endif

Return

#-------------------------------------------------------------------------------
$ANNULATION_SORTIE
  #==================================
  # Annulation sortie des éléments physiques
  #==================================
  Global Integer NBPHY_INF : Raz NBPHY_INF
  Global Integer NBPHY_TRT : Raz NBPHY_TRT
  Global Integer NBPHY_WAR : Raz NBPHY_WAR
  Global Integer NBPHY_ERR : Raz NBPHY_ERR
  Local Integer LOK

  Trbegin [CPY]
  # Warning: use [CPY] file because the [PHY] file will be open later

  # -- Progress bar declaration : Title
  Global Char TXTPROG(40) : TXTPROG = mess(215, GML_MSGPHY, 1)
  Call TEMPOFF() From GESECRAN
  Call OUVRE_BOITE(TXTPROG, 0) From GESECRAN

  # -- Call the class transfer function
  Local Instance ISS_PARAM Using C_PHYELTISS
  ISS_PARAM = NewInstance C_PHYELTISS AllocGroup null
  # Set parameter class properties
  ISS_PARAM.ISSDAT     = [M:PHYM1]ISSDAT
  ISS_PARAM.PHY_FILTER = LFILTER
  If (CRITSUP <> "") Then
    # Ctitère supplémentaire de la Selection étendue
    ISS_PARAM.PHY_FILTER += " and " + CRITSUP
  Endif
  If [M:PHYM1]FLGTRC= G_OUI
    ISS_PARAM.TRT_CALLBACK = "TRTPHYELTISSM"
  Else
    ISS_PARAM.TRT_CALLBACK = AVOID.ACHAR
  Endif
  # Call the class transfer function with link option
  [L]LOK = func PHYELT_C_MPR._CNL_ISSUE_PHYELT_POPULATION(ISS_PARAM)
  # Free parameter class
  FreeGroup ISS_PARAM

  # -- Close progress bar
  Call FERME_BOITE From GESECRAN

  If ([M:PHYM1]FLGSIM = G_OUI) Then
    Rollback
  Else
    Commit
  Endif
Return

#-------------------------------------------------------------------------------
$ABANDON_ANNULATION_SORTIE
  #==================================
  # Abandon annulation sortie des éléments physiques
  #==================================
  Global Integer NBPHY_INF : Raz NBPHY_INF
  Global Integer NBPHY_TRT : Raz NBPHY_TRT
  Global Integer NBPHY_WAR : Raz NBPHY_WAR
  Global Integer NBPHY_ERR : Raz NBPHY_ERR
  Local Integer LOK

  Trbegin [CPY]
  # Warning: use [CPY] file because the [PHY] file will be open later

  # -- Progress bar declaration : Title
  Global Char TXTPROG(40) : TXTPROG = mess(225, GML_MSGPHY, 1)
  Call TEMPOFF() From GESECRAN
  Call OUVRE_BOITE(TXTPROG, 0) From GESECRAN

  # -- Call the class transfer function
  Local Instance ISS_PARAM Using C_PHYELTISS
  ISS_PARAM = NewInstance C_PHYELTISS AllocGroup null
  # Set parameter class properties
  ISS_PARAM.PHY_FILTER = LFILTER
  If (CRITSUP <> "") Then
    # Ctitère supplémentaire de la Selection étendue
    ISS_PARAM.PHY_FILTER += " and " + CRITSUP
  Endif
  If [M:PHYM1]FLGTRC= G_OUI
    ISS_PARAM.TRT_CALLBACK = "TRTPHYELTISSM"
  Else
    ISS_PARAM.TRT_CALLBACK = AVOID.ACHAR
  Endif
  # Call the class transfer function with link option
  [L]LOK = func PHYELT_C_MPR._ISSUE_CNL_LST_MVT_PHYELT_POPULATION(ISS_PARAM)
  # Free parameter class
  FreeGroup ISS_PARAM

  # -- Close progress bar
  Call FERME_BOITE From GESECRAN

  If ([M:PHYM1]FLGSIM = G_OUI) Then
    Rollback
  Else
    Commit
  Endif
Return

#-------------------------------------------------------------------------------
$INIT_WIN_PHYELTISSM

  Effzo [M:PHYM]
  Effzo [M:PHYM1]

  Diszo [M:PHYM]FCY
  Diszo [M:PHYM]BUICOD
  Diszo [M:PHYM]LCTCODO

  #--> Réaffichage du masque paramètre et positionnement à non valide pour forcer tous les contrôles
  Affzo  [M:PHYM]
  Affzo  [M:PHYM1]
  Setmok [M:PHYM] With 0
Return

#-------------------------------------------------------------------------------
$BUILD_WHERE_FILTER
  # Construction critère principal
  # Warning : Use this syntax "LCTCOD <> '"+[M:PHYM1]LCTCODD+"'"
  Local Char LFILTER(250)
  LFILTER = " CPY='"+[M:PHYM]CPY+"'"
  If ([M:PHYM]FCY <> "") Then
    LFILTER += " and FCY='"+[M:PHYM]FCY+"'"
  Endif
  If ([M:PHYM]BUICOD <> "") Then
    # Warning: [F:LCT] is mandatory on the second table if use link option
    LFILTER += " and [F:LCT]BUICOD='"+[M:PHYM]BUICOD+"'"
  Endif
  If ([M:PHYM]LCTCODO <> "") Then
    LFILTER += " and LCTCOD='"+[M:PHYM]LCTCODO+"'"
  Endif

  # Cas de l'Annulation de sortie ou de l'Abandon annulation
  If (find([M:PHYM1]ISSACT, [V]CST_IACNLISS, [V]CST_IADELMVT) > 0) Then
    # Prise en compte paramètre Date de sortie
    If ([M:PHYM1]ISSDAT <> [0/0/0]) Then
      LFILTER += " and (ISSDAT=" + "[" + format$(GFMD, gdat$([M:PHYM1]ISSDAT)) +
&        "] or (ISSDAT=[0/0/0] and [F:PMVT]MVTDAT=" + "["+ format$(GFMD, gdat$([M:PHYM1]ISSDAT))+"]"+
&        " and [F:PMVT]MVTISSTYP=" +num$([M:PHYM1]ISSTYP) +"))"
    Endif
    # Prise en compte paramètre Type de sortie
    If ([M:PHYM1]ISSTYP <> [V]CST_PDNOTISS) Then
      LFILTER += " and (ISSTYP="+num$([M:PHYM1]ISSTYP) +
&      " or (ISSTYP="+ num$([V]CST_PDNOTISS) + " and [F:PMVT]MVTISSTYP=" +num$([M:PHYM1]ISSTYP) +"))"
    Endif
  Endif

  # Construction critère supplémentaire (onglet ASELOBJ)
  Local Char CRITSUP(255)
  [M]NBTBL = 0
  Raz CRITSUP
  Gosub EXPRESSION From ASELOBJ
  If (EXPRESSION <> "") Then
   CRITSUP=EXPRESSION
  Else
   CRITSUP=" 1=1"
  Endif
Return

#-------------------------------------------------------------------------------
$ECR_TRACE_INIT

  CLOG = NewInstance  C_FXDLOG AllocGroup null

  # Class init
  [L]RET = fmet CLOG.LOG_INIT()

  # Separator character, Underlining character, Space character, Length line
  [L]RET = fmet CLOG.LOG_SET_PARAMS(" ", "=", "", 80)

  # Columns(s) definition
  # Number
  [L]RET = fmet CLOG.LOG_ADD_COLUMN("I", [V]CST_ANO, 5, [V]CST_AYES, 0, "", [V]CST_ANO, mess(208, GML_MSGPHY, 1))
  # Reference
  [L]RET = fmet CLOG.LOG_ADD_COLUMN("A", [V]CST_AYES, GLONPHY, [V]CST_AYES, 0, "", [V]CST_ANO, mess(209, GML_MSGPHY, 1))
  # Description
  [L]RET = fmet CLOG.LOG_ADD_COLUMN("A", [V]CST_AYES, 50, [V]CST_AYES, 0, "", [V]CST_ANO, mess(210, GML_MSGPHY, 1))
  # Issue date only if cancel disposal
  If [M:PHYM1]ISSACT = [V]CST_IACNLISS
    [L]RET = fmet CLOG.LOG_ADD_COLUMN("D", 0, 15, [V]CST_AYES, 0, "D:DD[/]MM[/]YYYY", [V]CST_AYES, mess(217, GML_MSGPHY, 1))
  Endif

  # Open trace file of log
  # si GSERVEUR c'est le traitement batch lui-même qui ouvre la trace
  If !(GSERVEUR) Then
    If [M:PHYM1]ISSACT = [V]CST_IAISS
      [L]RET = fmet CLOG.LOG_CREATE(mess(214, GML_MSGPHY, 1))
    Elsif [M:PHYM1]ISSACT = [V]CST_IACNLISS
      [L]RET = fmet CLOG.LOG_CREATE(mess(214, GML_MSGPHY, 1))
    Else
      [L]RET = fmet CLOG.LOG_CREATE(mess(225, GML_MSGPHY, 1))
    Endif
  Endif

  # Standard Parameters of header
  [L]RET = fmet CLOG.LOG_SET_H_USR(GACTX.USER)
  [L]RET = fmet CLOG.LOG_SET_H_CPY([M:PHYM]CPY)
  [L]RET = fmet CLOG.LOG_SET_H_FCY([M:PHYM]FCY)
  [L]RET = fmet CLOG.LOG_SET_H_SIM([M:PHYM1]FLGSIM)

Return

$ECR_TRACE_HEADER
  #Call OUVRE_TRACE(mess(1,GML_MSGCAL,1))  From LECFIC

  # Header XXXX
  [L]RET = fmet CLOG.LOG_WRITE_HEADER()

  [L]RET = fmet CLOG.LOG_WRITE_STRING_SEPARATOR()
  # Critères
  [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(195, GML_MSGPHY, 1))
  If ( [M:PHYM]BUICOD <> "")
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(196, GML_MSGPHY, 1)-[M:PHYM]BUICOD-"/"-[M:PHYM]ZBUICOD)
  Endif
  If ( [M:PHYM]LCTCODO <> "")
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(197, GML_MSGPHY, 1)-[M:PHYM]LCTCODO-"/"-[M:PHYM]ZLCTCODO)
  Endif
  # Sélection étendue
  If ( EXPRESSION <> "" ) Then
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(198, GML_MSGPHY, 1))
    [L]RET = fmet CLOG.LOG_WRITE_STRING(EXPRESSION)
  Endif
  # Destination
  [L]RET = fmet CLOG.LOG_WRITE_LINEFEED(1)

  # Disposal
  If [M:PHYM1]ISSACT = [V]CST_IAISS
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(214, GML_MSGPHY, 1))
  Elsif [M:PHYM1]ISSACT = [V]CST_IACNLISS
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(215, GML_MSGPHY, 1))
  Else
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(225, GML_MSGPHY, 1))
  Endif
  If ([M:PHYM1]ISSACT <> [V]CST_IACNLISS or [M:PHYM1]ISSDAT <> AVOID.ADATE ) Then
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(217, GML_MSGPHY, 1)-num$([M:PHYM1]ISSDAT))
  Endif
  If ([M:PHYM1]ISSACT <> [V]CST_IACNLISS or [M:PHYM1]ISSTYP <> [V]CST_PDNOTISS ) Then
    [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(220, GML_MSGPHY, 1)-num$([M:PHYM1]ISSTYP)-"/"-mess([M:PHYM1]ISSTYP, [V]CST_ML_PHYISSTYP, 1))
  Endif
  # Options
  [L]RET = fmet CLOG.LOG_WRITE_LINEFEED(1)

  [L]RET = fmet CLOG.LOG_WRITE_STRING_SEPARATOR()
  [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(203, GML_MSGPHY, 1) - num$(date$) - time$)

  [L]RET = fmet CLOG.LOG_WRITE_LINEFEED(1)
  [L]RET = fmet CLOG.LOG_WRITE_TITLES()
  [L]RET = fmet CLOG.LOG_WRITE_STRING_SEPARATOR()
Return

#-------------------------------------------------------------------------------
$ECR_TRACE_DET_LIN
  [L]RET  = fmet CLOG.LOG_INIT_LINE()
  [L]RET += fmet CLOG.LOG_PUT_INT_COLUMN(1, NBPHY_TRT)
  [L]RET += fmet CLOG.LOG_PUT_COLUMN(2, [F:PHY]PHYREF)
  [L]RET += fmet CLOG.LOG_PUT_COLUMN(3, [F:PHY]PHYDES1)
  [L]RET += fmet CLOG.LOG_WRITE([V]CST_AOK)
Return

#-------------------------------------------------------------------------------
$ECR_TRACE_FOOTER
  # Footer
  [L]RET = fmet CLOG.LOG_WRITE_LINEFEED(1)
  [L]RET = fmet CLOG.LOG_WRITE_STRING(mess(204, GML_MSGPHY, 1) - num$(date$) - time$)
  [L]RET = fmet CLOG.LOG_WRITE_STRING_SEPARATOR()
  [L]RET = fmet CLOG.LOG_WRITE_LINEFEED(1)

  [L]RET = fmet CLOG.LOG_WRITE_STRING(num$(NBPHY_TRT) - mess(205, GML_MSGPHY, 1))
  If (NBPHY_TRT - NBPHY_ERR) > 0
    [L]RET = fmet CLOG.LOG_WRITE_STRING(num$(NBPHY_TRT - NBPHY_ERR) - mess(218, GML_MSGPHY, 1))
  Endif
  If NBPHY_ERR > 0
    [L]RET = fmet CLOG.LOG_WRITE_STRING(num$(NBPHY_ERR) - mess(219, GML_MSGPHY, 1))
  Endif

  #[L]RET = fmet CLOG.LOG_NB_OK(NBPHY_TRT, NBPHY_TRT-NBPHY_ERR, NBPHY_ERR)
Return


######################################################################################
#                                                                                    #
#         GESTION DU MASQUE DE CONTROLE MPHYELTM [M:PHYM]                            #
#                                                                                    #
######################################################################################

#-------------------------------------------------------------------------------
Subprog AM_CPY(VALEUR)
Variable Char VALEUR()

  # [M:PHYM]
  [M:PHYM]ALLFCY = G_OUI
  [M:PHYM]ALLBUI = G_OUI
  [M:PHYM]ALLLCT = G_OUI
  Raz [M:PHYM]FCY
  Raz [M:PHYM]BUICOD
  Raz [M:PHYM]LCTCODO
  Diszo [M:PHYM]FCY
  Diszo [M:PHYM]BUICOD
  Diszo [M:PHYM]LCTCODO

  # [M:PHYM1]
  Raz [M:PHYM1]ISSDAT
  Raz [M:PHYM1]ISSTYP

  #--> Réaffichage du masque paramètre et positionnement à non valide pour forcer tous les contrôles
  Affzo  [M:PHYM]
  Affzo  [M:PHYM1]
  Setmok [M:PHYM] With 0
End

#-------------------------------------------------------------------------------
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  #--> Réaffichage du masque paramètre et positionnement à non valide pour forcer tous les contrôles
  Affzo  [M:PHYM1]
  Setmok [M:PHYM] With 0
End

#-------------------------------------------------------------------------------
Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR

  If (VALEUR = G_OUI) Then
    Raz [M:PHYM]FCY
    Diszo [M:PHYM]FCY
  Else
    Actzo [M:PHYM]FCY
  Endif

End

#-------------------------------------------------------------------------------
Subprog AM_ALLBUI(VALEUR)
Variable Integer VALEUR
  If (VALEUR = G_OUI) Then
    Raz [M:PHYM]BUICOD
    Diszo [M:PHYM]BUICOD
  Else
    Actzo [M:PHYM]BUICOD
  Endif
End

#-------------------------------------------------------------------------------
Subprog AM_ALLLCT(VALEUR)
Variable Integer VALEUR
  If (VALEUR = G_OUI) Then
    Raz [M:PHYM]LCTCODO
    Diszo [M:PHYM]LCTCODO
  Else
    Actzo [M:PHYM]LCTCODO
  Endif
End


######################################################################################
#                                                                                    #
#         GESTION DU MASQUE DE CONTROLE PHYELTM1 [M:PHYM1]                          #
#                                                                                    #
######################################################################################

#-------------------------------------------------------------------------------
#**
#* Callback function
#*
#* @param PHY
#* @param PCASE
#* @param PVALUE
#* @param PPHYREF
#* @param PPHYDES1
#* @return CST_ATRUE or CST_AFALSE to stop disposal process
#*!
Funprog  CALLBACK_ISS(PARAM, PCASE, PVALUE, PPHYREF, PPHYDES1)
Variable Instance PARAM Using C_PHYELTISS
Value Integer PCASE
Value Integer PVALUE
Value Char PPHYREF()
Value Char PPHYDES1()

  Local Integer LOK

  Case PCASE
    When 1:
      # Set progress bar
      Call SET_BOITE(TXTPROG, PVALUE) From GESECRAN
    When 2:
      # Increase issued physical asset number
      NBPHY_TRT += 1

      # Update progress bar
      Local Char MSGPROG(40)

      MSGPROG = PPHYREF + '['+num$(NBPHY_TRT) + ']'
      Call AFF_BOITE(MSGPROG, NBPHY_TRT, LOK) From GESECRAN

      # Set log value columns
      [L]LOK  = fmet CLOG.LOG_INIT_LINE()
      [L]LOK += fmet CLOG.LOG_PUT_INT_COLUMN(1, NBPHY_TRT)
      [L]LOK += fmet CLOG.LOG_PUT_COLUMN(2, PPHYREF)
      [L]LOK += fmet CLOG.LOG_PUT_COLUMN(3, PPHYDES1)
      [L]LOK += fmet CLOG.LOG_WRITE([V]CST_AOK)

      # Write error messages (CLOG is global variable)
      Call LOG_WRITE_AERROR_STACK_COUNT(PARAM, CLOG, [V]NBPHY_INF, NBPHY_WAR, NBPHY_ERR, NBPHY_ERR) From FXDLOG_CSTD
    When 3:
    When Default:
  Endcase

End [V]CST_ATRUE

#**
#* Callback function of disposal cancellation
#*
#* @param PARAM
#* @param PCASE
#* @param PVALUE
#* @param PPHYREF
#* @param PPHYDES1
#* @param PDATEISS
#* @return CST_ATRUE or CST_AFALSE to stop disposal process
#*!
Funprog  CALLBACK_CNL_ISS(PARAM_PHY, PCASE, PVALUE, PPHYREF, PPHYDES1, PDATEISS)
Variable Instance PARAM_PHY Using C_PHYELTISS
Value Integer PCASE
Value Integer PVALUE
Value Char PPHYREF()
Value Char PPHYDES1()
Value Date PDATEISS

  Local Integer LOK

  Case PCASE
    When 1:
      # Set progress bar
      Call SET_BOITE(TXTPROG, PVALUE) From GESECRAN
    When 2:
      # Increase issued physical asset number
      NBPHY_TRT += 1

      # Update progress bar
      Local Char MSGPROG(40)
      MSGPROG = PPHYREF + '['+num$(NBPHY_TRT) + ']'
      Call AFF_BOITE(MSGPROG, NBPHY_TRT, LOK) From GESECRAN

      # Set log value columns
      [L]LOK = fmet CLOG.LOG_INIT_LINE()
      [L]LOK = fmet CLOG.LOG_PUT_INT_COLUMN(1, NBPHY_TRT)
      [L]LOK = fmet CLOG.LOG_PUT_COLUMN(2, PPHYREF)
      [L]LOK = fmet CLOG.LOG_PUT_COLUMN(3, PPHYDES1)
      [L]LOK = fmet CLOG.LOG_PUT_DATE_COLUMN(4, PDATEISS)
      [L]LOK = fmet CLOG.LOG_WRITE([V]CST_AOK)

      # Write contents of stack messages (CLOG is global variable)
      # Issue 110494
      Call LOG_WRITE_AERROR_GENERAL_COUNT(PARAM_PHY, CLOG, [V]NBPHY_INF, NBPHY_WAR, NBPHY_ERR) From FXDLOG_CSTD
#      Call LOG_WRITE_AERROR_STACK_COUNT(PARAM, CLOG, NBPHY_INF, NBPHY_WAR, NBPHY_ERR, NBPHY_ERR) From FXDLOG_CSTD
      # End Issue 110494
    When 3:
    When Default:
  Endcase

End [V]CST_ATRUE


#**
