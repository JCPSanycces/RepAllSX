#######################################################################################
$AREAD_AFTER
Local Integer CTX_PSHAPPHEA(1)
  # SYRAPEDIA: doit-on garder ça comme ça ?
  Local File ATEXTRA [AXX]

  #Set Receipt tax, Issue tax, Other tax 1, and Other tax 2 titles
  Read [AXX]AXX0 = "TABVAT";"DESAXX";this.ACTX.LAN;this.TAXRCP;""
  If !fstat
    this.TAXTITLE1 = [AXX]TEXTE
  Endif
  #Call LECTEXTRA_SYR (this,"",this.TAXTITLE1,"TABVAT","DESAXX",num$(this.TAXRCP),AVOID.ACHAR) From ATEXTRA
  Read [AXX]AXX0 = "TABVAT";"DESAXX";this.ACTX.LAN;this.TAXISS;""
  If !fstat
    this.TAXTITLE2 = [AXX]TEXTE
  Endif
  Read [AXX]AXX0 = "TABVAT";"DESAXX";this.ACTX.LAN;this.TAXOTH1;""
  If !fstat
    this.TAXTITLE3 = [AXX]TEXTE
  Endif
  Read [AXX]AXX0 = "TABVAT";"DESAXX";this.ACTX.LAN;this.TAXOTH2;""
  If !fstat
    this.TAXTITLE4 = [AXX]TEXTE
  Endif

  LogicClose File[AXX]
# FIN SYRAPEDIA: doit-on garder ça comme ça ?

If this.APARENT<>null
  this.LEG    = this.APARENT.LEG
Endif
If this.LEG=AVOID.ACHAR
    #--Chargement de la LEG du site du document
  If this.PSHFCY<>AVOID.ACHAR
    #Local File FACILITY [FCY]
    #Local File COMPANY  [CPY]
    #Read [F:FCY]FCY0=this.PSHFCY
    #If fstat Raz [F:FCY] Endif
    #this.LEG    = [F:FCY]LEG
    this.LEG    = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.PSHFCY,"LEG")
  Endif
Endif

  #--Chargement des propriétés _LEG liées aux propriété déclinées par législation
  #--VACBPR
  Call LOAD_VACBPR_LEG(this) From TRTLOADPROPLEG_SYRA

  # VACITM
  Local Integer WRET
  Local File ITMMASTER [ITM]
  Read [F:ITM]ITM0 = this.ITMREF
  For I = 1 To 3
      If this.C_VACITM(I)=null
        WRET = fmet this.ADDLINE("C_VACITM",[V]CST_ALASTPOS)
        If WRET<>[V]CST_ANOTDEFINED
          Break
        Endif
      Endif
      WRET = I
      this.C_VACITM(WRET).VACITM = [F:ITM]VACITM(I-1)
  Next I
  LogicClose File[ITM]

  this.LINFLG  = 1
  this.PRIFLG  = 2 : # pas de recherche tarif
  #-----
  # blomsg = 0  pour ligne est modifiable                     #
  # blomsg = 18 pour non modifiable car signée  ou partielle  #
  #             attention valeur = 4 pas de gestion des visas #
  # blomsg = 19 pour non modifiable car partiellement cdée    #
  # blomsg = 20 pour non modifiable car commandée             #
  # blomsg = 21 pour non modifiable car soldée                #
  this.BLOMSG  = 0
  CTX_PSHAPPHEA = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "PSHAPPHEA")
  If this.LINAPPFLG>1 & this.LINAPPFLG<4 & CTX_PSHAPPHEA<2
    this.BLOMSG = 18
  Endif
  If this.ORDQTYPUU <> 0 : this.BLOMSG = 19 : Endif
  If this.LINCLEFLG = 2  : this.BLOMSG = 21 : Endif
  If this.LINORDFLG = 2  : this.BLOMSG = 20 : Endif

#  this.LAN=this.ACTX.LAN
#  If this.BPSNUM<>AVOID.ACHAR
#     #lecture BPR
#     Local File BPARTNER [BPR]
#     If [F:BPR]BPRNUM<>this.BPSNUM
#       Read [BPR] BPR0=this.BPSNUM
#       If fstat Raz [F:BPR] : Endif
#     Endif
#     If [F:BPR]LAN<> AVOID.ACHAR : this.LAN=[F:BPR]LAN : Endif
#     LogicClose File [BPR]
#  Endif
#mise à jour de la collection C_DISCRG à partir de la table
#Mise à jour des frais/Remises
For WLINE=1 To maxtab(this.C_DISCRG)
  If evalue("dim(this.DISCRGVAL"+num$(WLINE)+")")>0
      this.C_DISCRG(WLINE).DISCRGVAL = evalue("this.DISCRGVAL"+num$(WLINE))
      this.C_DISCRG(WLINE).DISCRGREN = evalue("this.DISCRGREN"+num$(WLINE))
  Endif
Next

Return

#############################################################################################
$AUPDATE_CONTROL_AFTER
Local Char WMESSAGE(250)
Local Integer WRET
Local Char WPUU(3)

#Modification impossible sur le site
If this.PSHFCY <> this.snapshot.PSHFCY
      WMESSAGE = mess(3,45,1)+ " : " + mess(9,123,1)
      [L]ASTATUS = fmet this.ASETERROR ("PSHFCY", WMESSAGE, [V]CST_AERROR)
      Return
Endif

#Modification impossible sur l'article si ligne de DA déjà saisi
If this.ITMREF <> this.snapshot.ITMREF
        WMESSAGE = mess(162,154,1) + " : " + mess(9,123,1)
        [L]ASTATUS = fmet this.ASETERROR ("ITMREF", WMESSAGE, [V]CST_AERROR)
        Return
Endif


# If blocking message is loaded, line can't be modified
If this.BLOMSG <> 0
   WMESSAGE = mess(this.BLOMSG,123,1)
   [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, [V]CST_AERROR)
   Return
#  #Modification impossible sur la date de demande
#  If this.EXTRCPDAT <> this.snapshot.EXTRCPDAT
