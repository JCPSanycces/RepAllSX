#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################################
$AINSERT_CONTROL_AFTER
Local Char WMESSAGE(250)
Local Integer WRET,WLINE
Local Char WPUU(3)
Local Integer I
#controle sur le site
If func TRTACHCTL1_SYRA.CTL_PRHFCY(this.ACTX,this.CPY,this.PSHFCY, this.ITMREF, WMESSAGE) = [V]CST_AERROR
      [L]ASTATUS = fmet this.ASETERROR ("PSHFCY", WMESSAGE, [V]CST_AERROR)
      Return
Endif
#controle sur la date de demande qui doit être hors de la période d'indisponibilité du site
If this.EXTRCPDAT <> AVOID.ADATE
  If func CONTX3_SYRA.CTL_PER(this.EXTRCPDAT,this.PSHFCY,"1",WMESSAGE)=[V]CST_AERROR
      [L]ASTATUS = fmet this.ASETERROR ("EXTRCPDAT", WMESSAGE, [V]CST_AERROR)
      Return
  Endif
Endif
#controle sur l'article
If func TRTACHCTL1_SYRA.C_ITMREF(this.ITMREF, this.PRHFCY, WMESSAGE) = [V]CST_AERROR
   [L]ASTATUS = fmet this.ASETERROR ("ITMREF", WMESSAGE, [V]CST_AERROR)
   Return
Endif

#Controle sur le fournisseur
If this.BPSNUM <> AVOID.ACHAR
  If func TRTACHCTL1_SYRA.CTL_BPSNUM_FCY(this.BPSNUM,this.PSHFCY, WMESSAGE)=[V]CST_AERROR
        [L]ASTATUS = fmet this.ASETERROR ("BPSNUM", WMESSAGE, [V]CST_AERROR)
        Return
  Endif
  If func CONTX3_SYRA.CTLBPRCPY(this.ACTX,this.BPSNUM, this.PSHFCY, WMESSAGE)=[V]CST_AERROR
        [L]ASTATUS = fmet this.ASETERROR ("BPSNUM", WMESSAGE, [V]CST_AERROR)
        Return
  Endif
   If func TRTACHCTL1_SYRA.CTL_BPSNUM_ITMREF(this.ACTX, this.BPSNUM, this.ITMREF, WPUU, WMESSAGE)<>[V]CST_AOK
    [L]ASTATUS = fmet this.ASETERROR ("BPSNUM", WMESSAGE, WRET)
  Endif

  #controle sur la date théorique de demande qui doit être hors de la période d'indisponibilté du fournisseur
  If this.EXTORDDAT <> AVOID.ADATE
    If func CONTX3_SYRA.CTL_PER(this.EXTORDDAT,this.BPSNUM,"2",WMESSAGE) = [V]CST_AERROR
        [L]ASTATUS = fmet this.ASETERROR ("EXTORDDAT", WMESSAGE, [V]CST_AERROR)
        Return
    Endif
  Endif
Endif

#controle sur les unités qui doivent faire partie des unités se trouvant sur article ou article fournisseur
If this.PUU <> AVOID.ACHAR
  If func TRTACHCTL1_SYRA.PCOUOM (this.PUU,this.BPSNUM,this.ITMREF,3,5,WMESSAGE)=[V]CST_AERROR
      [L]ASTATUS = fmet this.ASETERROR ("PUU", WMESSAGE, [V]CST_AERROR)
      Return
  Endif
Endif

#QTYPUU
#controle sur la quantité en UA
If this.WQTYORDPUU<>0 & this.QTYPUU < this.WQTYORDPUU
   [L]ASTATUS = fmet this.ASETERROR("QTYPUU", mess(3,194,1), [V]CST_AERROR)
   Return
Endif
#controle sur la quantité de la ligne
If this.QTYPUU = 0
   [L]ASTATUS = fmet this.ASETERROR ("QTYPUU",mess(7,194,1),[V]CST_AERROR)
   Return
Endif

#controle sur les taxes
For I=1 To 3
  If this.C_VACITM(I).VAT<>AVOID.ACHAR
    If dim(this)>0
     Callmet this.ASETERROR ("", "PCOVAT", [V]CST_AINFO)
    Endif
    If WRET = func TRTACHCTL1_SYRA.PCOVAT(this.ACTX, this.PSHFCY, this.LEG, this.C_VACITM(I).VAT, this.VACBPR, WMESSAGE) <> CST_AOK
      [L]ASTATUS = fmet this.ASETERROR ("VAT", WMESSAGE, WRET)
    Endif
  Endif
Next

#Récupération de la désignation article dans la langue du fournisseur
If this.BPSNUM<>AVOID.ACHAR
  #lecture BPR
  Local File BPARTNER[BPR]
  Read [BPR] BPR0=this.BPSNUM
  If fstat Raz [F:BPR] : Endif
  If [F:BPR]LAN="" : [F:BPR]LAN=this.ACTX.LAN : Endif
  If this.ITMDES = AVOID.ACHAR
    Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,this.ITMREF,this.ITMDES, "[F:ITM]") From TRTX3_SYRA
  Endif
Else
   If this.ITMDES = AVOID.ACHAR
    Call CHARGE_DEFITMDES("DES1AXX",this.ACTX.LAN,this.ITMREF,this.ITMDES, "[F:ITM]") From TRTX3_SYRA
  Endif
Endif

If this.ITMDES1 = AVOID.ACHAR
  Call CHARGE_DEFITMDES("DES1AXX",this.ACTX.LAN,this.ITMREF,this.ITMDES1, "[F:ITM]") From TRTX3
Endif

#init de ATECORI
this.ATECORI = 2

#Mise à jour des frais/Remises
For WLINE=1 To maxtab(this.C_DISCRG)
  If this.C_DISCRG(WLINE).DISCRGVAL <> AVOID.ADEC
    Assign "this.DISCRGVAL"+num$(WLINE) With this.C_DISCRG(WLINE).DISCRGVAL
    Assign "this.DISCRGREN"+num$(WLINE) With this.C_DISCRG(WLINE).DISCRGREN
  Endif
Next

#----- Récupération des liens texte article ou article-fournisseur -----#
#  If !find(left$(this.LINTEX,3),"PSD")
#    Local File ITMMASTER [ITM]
#    Read [F:ITM]ITM0 = this.ITMREF
#    If fstat : Raz [F:ITM] : Endif
#    this.LINTEX=[F:ITM]PURTEX
#    If this.BPSNUM<>AVOID.ACHAR
#      Local File ITMBPS [ITP]
#      If [F:ITP]ITMREF<>this.ITMREF & [F:ITP]BPSNUM<>this.BPSNUM
#        Read [ITP] ITP0=this.ITMREF;this.BPSNUM : If fstat  Raz [F:ITP] : Endif
#      Endif
#      If [F:ITP]TEX<>AVOID.ACHAR  this.LINTEX=[F:ITP]TEX : Endif
#      LogicClose File [ITP]
#    Endif
#    LogicClose File [ITM]
#  Endif

Return
#######################################################################################
$AINSERT_BEFORE
 Local Integer CTX_APPPSH(1)
 Local Char    CTX_PURVACBPR(GLONTVB)
 Local Integer WRET,REGVAC
 Local Char WMESS(250)
 Local File TABVACBPR [TVB]
 # anciennement sur AM_ITMREF
 #---------------------- Gestion des signatures ------------------#
  CTX_APPPSH = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "APPPSH")
  If CTX_APPPSH  > 1
    this.LINAPPFLG = 1
  Else
    this.LINAPPFLG = 4
  Endif
  #----- Récupération des liens texte article ou article-fournisseur -----#
#  If !find(left$(this.LINTEX,3),"PSD")
#    Local File ITMMASTER [ITM]
#    Read [F:ITM]ITM0 = this.ITMREF
#    If fstat : Raz [F:ITM] : Endif
#    this.LINTEX=[F:ITM]PURTEX
#    If this.BPSNUM<>AVOID.ACHAR
#      Local File ITMBPS [ITP]
#      If [F:ITP]ITMREF<>this.ITMREF & [F:ITP]BPSNUM<>this.BPSNUM
#        Read [ITP] ITP0=this.ITMREF;this.BPSNUM : If fstat  Raz [F:ITP] : Endif
#      Endif
#      If [F:ITP]TEX<>AVOID.ACHAR  this.LINTEX=[F:ITP]TEX : Endif
#      LogicClose File [ITP]
#    Endif
#    LogicClose File [ITM]
#  Endif
#  If this.LINTEX<>""
#    If left$(this.LINTEX,3)="PSD"
#      Call CRE_CLOB(this.LINTEX,WOK) From TRTX3TEX
#      If WOK<1
#         [L]ASTATUS = fmet this.ASETERROR ("", mess(150,199,1)+": TEXCLOB", [V]CST_AERROR)
#         Return
#      Endif
#    Elsif !find(left$(this.LINTEX,3),"ITM","ITP")
#      Call DUP_CLOB("PSD",this.LINTEX,WOK) From TRTX3TEX
#      If WOK<1
#         [L]ASTATUS = fmet this.ASETERROR ("", mess(150,199,1)+": TEXCLOB", [V]CST_AERROR)
#         Return
#      Endif
#    Endif
#  Endif
  #Si date théorique non renseigné, init avec date réception souhaitée - délai de réappro
  If this.EXTORDDAT=AVOID.ADATE
    this.EXTORDDAT = this.EXTRCPDAT - this.OFS
  Endif
  # if BPSNUM not loaded , init VAT
  If this.BPSNUM = [V]AVOID.ACHAR
    CTX_PURVACBPR = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "PURVACBPR")
    If CTX_PURVACBPR<>""
      this.VACBPR=CTX_PURVACBPR
    Else
      Local File AGRPCPY   [AGC]
      Filter [TVB] Where LEG=this.LEG & REGVAC=1 & ENAFLG=2
        For [TVB]TVB0
            # Si le régime est lié à un groupe on ne prend que si le groupe est ok pour la société
            If [F:TVB]SOC<>""
              Look [AGC]AGC0 = [F:TVB]SOC;this.CPY
              If !fstat Break Endif
            Else
              fstat=0 : Break
            Endif
        Next
        Filter [TVB]
        If !fstat
          this.VACBPR=[F:TVB]VACBPR
        Else
          # Aucune régime trouvé avec la leg : Recherche d'un régime actif ss leg
          Local File AGRPCPY    [AGC]
          Filter [TVB] Where LEG="" & REGVAC=1 & ENAFLG=2
          For [TVB]TVB0
            # Si le régime est lié à un groupe on ne prend que si le groupe est ok pour la société
            If [F:TVB]SOC<>""
              Look [AGC]AGC0 = [F:TVB]SOC;this.CPY
              If !fstat Break Endif
            Else
              fstat=0 : Break
            Endif
          Next
          Filter [TVB]
          If !fstat
            this.VACBPR=[F:TVB]VACBPR
          Endif
        Endif
    Endif
    # SR en attendant de faire marcher le sous-pro
    #Call LEC_TVB_LEG(this.ACTX,this.LEG,this.VACBPR,REGVAC,WRET) From TRTLECLEG_SYRA
    #this.VACTYP = REGVAC
    this.VACTYP = REGVAC =1
    # SR fin

    WRET = fmet this._MET_LOADVAT()
  Endif

#détermination du numéro d'en-cours
If this.WIPNUM = AVOID.ACHAR
   Call NUMERO(this.ACTX,"WIP",this.PRHFCY,this.EXTORDDAT,"", this.WIPNUM,WMESS) From ANM_TOOL
   If [L]ASTATUS <> [V]CST_AOK
      [L]ASTATUS = fmet this.ASETERROR ("AINSERT_AFTER", WMESS, [V]CST_AERROR)
   Endif
Endif
#    If this.ACTX.USER="SR" Dbgaff : Endif
Return

#######################################################################################
$AINSERT_AFTER
Local File ITMFACILIT[ITF]

Read [ITF]ITF0=this.ITMREF;this.PRHFCY
If [F:ITF]STOMGTCOD>1
  #lancement de la création des en-cours
  #--Nouvelle instance de la classe métier des paramètres en-cours
#US 71069/260 by RBA 07/29/2016
#  Local Instance WORDERS Using C_ORDERS
#  Local Char WMESS(250)
#  WORDERS = NewInstance C_ORDERS AllocGroup null
#
#  If fmet this.LOADWIPPARAM(WORDERS) =[V]CST_AERROR
#    [L]ASTATUS = fmet this.ASETERROR ("", "Erreur LOADWIPPARAM : Article "-this.ITMREF, [V]CST_AERROR)
#  Endif
#
#  If fmet WORDERS.WIP =[V]CST_AERROR
#       [L]ASTATUS = fmet this.ASETERROR ("", "Erreur WIP : Article "-this.ITMREF, [V]CST_AERROR)
#  Endif
#  FreeGroup WORDERS
#/US 71069/260 by RBA 07/29/2016
#US 71069/260 by RBA 07/29/2016
  Local Instance TECORDERS Using C_TECORDERS
  TECORDERS = NewInstance C_TECORDERS AllocGroup null
  If fmet this.WIP(TECORDERS) =[V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR ("", "Erreur WIP : Article "-this.ITMREF, [V]CST_AERROR)
  Endif
  FreeGroup TECORDERS
#/US 71069/260 by RBA 07/29/2016
Endif
 #/

Return
