#        [L]ASTATUS = fmet this.ASETERROR ("ITMDES", WMESSAGE, [V]CST_AERROR)
#        Return
#  Endif
#
#  #Modification impossible de la désignation de l'article
#  If this.ITMDES1 <> this.snapshot.ITMDES1
#        WMESSAGE = mess(63,154,1) + " : " + mess(9,123,1)
#        [L]ASTATUS = fmet this.ASETERROR ("ITMDES1", WMESSAGE, [V]CST_AERROR)
#        Return
#  Endif
#
#  #Modification impossible du site de réception
#  If this.PRHFCY <> this.snapshot.PRHFCY
#        WMESSAGE = mess(545,197,1) + " : " + mess(9,123,1)
#        [L]ASTATUS = fmet this.ASETERROR ("ITMDES1", WMESSAGE, [V]CST_AERROR)
#        Return
#  Endif
#
#
#  #Modification impossible sur l'unité d'achat
#  If this.PUU <> this.snapshot.PUU
#        WMESSAGE = "unité d'achat" + " : " + mess(9,123,1)
#        [L]ASTATUS = fmet this.ASETERROR ("PUU", WMESSAGE, [V]CST_AERROR)
#        Return
#  Endif
#
#  #Modification impossible sur la quantité en unité d'achat
#  If this.QTYPUU <> this.snapshot.QTYPUU
#        WMESSAGE = "unité d'achat" + " : " + mess(9,123,1)
#        [L]ASTATUS = fmet this.ASETERROR ("QTYPUU", WMESSAGE, [V]CST_AERROR)
#        Return
#  Endif
#
#  #Modification impossible sur le fournisseur
#  If this.BPSNUM <> this.snapshot.BPSNUM
#        WMESSAGE = mess(24,121,1) + " : " + mess(9,123,1)
#        [L]ASTATUS = fmet this.ASETERROR ("BPSNUM", WMESSAGE, [V]CST_AERROR)
