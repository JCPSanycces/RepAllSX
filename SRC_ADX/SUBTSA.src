#<AdxTL>@(#)10.0.0.0 $Revision$
$ACTION
Case ACTION
  When "DEFBOUT"       : Gosub DEFBOUT 
  When "EXEBOUT"       : Gosub EXEBOUT
  When "AV_LISTE"      : Gosub COP_ECRAN
                         OK = 0 
  When "FERME"         : Call IMPSCR From ATRTX3
  When "INICRE"        : Gosub INICRE
  When "INIMOD"        : Gosub INICRE
  When "ANNULE"        : Gosub ANNULE
  When "CHANGE"        : Call CHANGE_AXX ("TABSAFSTO", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
  When Default
Endcase
Return
 
$INICRE
    Call MAJTEXTRA([M:TSA1]SRVRATAXX,"TABSAFSTO","SRVRATAXX",num$([M:TSA1]SRVRAT),"") From ATEXTRA
Return

$ANNULE
    Delete [AXX] Where CODFIC="TABSAFSTO" & ZONE="SRVRATAXX" & CLE1= num$([M:TSA1]SRVRAT)
Return

###########################################################
$DEFBOUT
NBTEX += 1 : CBOUT(NBTEX) = "a" : TEX(NBTEX)   = mess(8,16,1) 
Return
###########################################################
$EXEBOUT 
Return 
############################################################
Subprog VALDEF
#$VALDEF
#
Effzo [M:TSA1]
[M:TSA1]SRVRAT(0) = 70 
[M:TSA1]SRVRAT(1) = 75 
[M:TSA1]SRVRAT(2) = 80 
[M:TSA1]SRVRAT(3) = 90 
[M:TSA1]SRVRAT(4) = 94 
[M:TSA1]SRVRAT(5) = 95 
[M:TSA1]SRVRAT(6) = 96 
[M:TSA1]SRVRAT(7) = 98 
[M:TSA1]SRVRAT(8) = 99
# 
[M:TSA1]SRVRATCOE(0) = 0.800
[M:TSA1]SRVRATCOE(1) = 0.840
[M:TSA1]SRVRATCOE(2) = 1.050
[M:TSA1]SRVRATCOE(3) = 1.600
[M:TSA1]SRVRATCOE(4) = 1.950
[M:TSA1]SRVRATCOE(5) = 2.060
[M:TSA1]SRVRATCOE(6) = 2.190
[M:TSA1]SRVRATCOE(7) = 2.560
[M:TSA1]SRVRATCOE(8) = 2.910
#
[M:TSA1]SRVRATAXX(0) = num$([M:TSA1]SRVRAT(0))-"%"
[M:TSA1]SRVRATAXX(1) = num$([M:TSA1]SRVRAT(1))-"%"
[M:TSA1]SRVRATAXX(2) = num$([M:TSA1]SRVRAT(2))-"%"
[M:TSA1]SRVRATAXX(3) = num$([M:TSA1]SRVRAT(3))-"%"
[M:TSA1]SRVRATAXX(4) = num$([M:TSA1]SRVRAT(4))-"%"
[M:TSA1]SRVRATAXX(5) = num$([M:TSA1]SRVRAT(5))-"%"
[M:TSA1]SRVRATAXX(6) = num$([M:TSA1]SRVRAT(6))-"%"
[M:TSA1]SRVRATAXX(7) = num$([M:TSA1]SRVRAT(7))-"%"
[M:TSA1]SRVRATAXX(8) = num$([M:TSA1]SRVRAT(8))-"%"
#
[M:TSA1]BASPAG = 9
Affzo [M:TSA1]
End

############################################################
$COP_ECRAN
Call PRTSCR("TSA1","","",0,0) From ATRTX3
Return

