#<AdxTL>@(#)0.0.0.0 $Revision$ Bank statement import
######################################################################################################
# Project       : Bank file import (MT940)
# File          : BSIIMPPAR_RSTD
# Version       : 1.0
# Author        : Anton Gregolec
# Creation Date : 02.05.16
######################################################################################################
# Module        : Finance
# Description   : Bank file import parameters (Representation BSIIMPPAR)
######################################################################################################
# Updates :
# Date       |Author |Version| Description
# 2016-08-10 |angre  |U11    | changes in importvolume and move to volume settings
# 2016-08-15 |angre  |U11    | Move to volume mandatory when move file is checked
# 2017-07-06 |DNE    |2017.R5| X3-47552 Corrections for CPYCUR and introduction of VARPRC2 fields
# 2017-08-17 |DNE    |2017.R5| X3-52272 FLGCLS: If active "Suspense account" etc. are disabled.
######################################################################################################


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When "BSIIP"
    Case [L]AEVENT
        When "AREAD_AFTER" : Gosub ENABLE_DISABLE_FIELDS  #enable or disable fields
    Endcase
# Bader 2016-11-04
   When ""
    Case [L]AEVENT
        When "AREAD_AFTER" : this.VARPRC  = "%"
                             this.VARPRC2 = "%"
                             Gosub SET_CPYCUR
    Endcase
# Bader 2016-11-04 end
Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "BSIIP.ALLBPR"
    Case [L]ARULE
      When "PROPAGATE" : Gosub PROP_ALLBPR
    Endcase
  When "BSIIP.ALLTYP"
    Case [L]ARULE
      When "PROPAGATE" : Gosub PROP_ALLTYP
    Endcase
  When "BSIIP.ALLCAT"
    Case [L]ARULE
      When "PROPAGATE" : Gosub PROP_ALLCAT
    Endcase
  When "BSIIP.FLGCLS"
    Case [L]ARULE
      When "PROPAGATE" : Gosub PROP_FLGCLS
    Endcase
  When "BSIIP.TYPIMP"
    Case [L]ARULE
      When "INIT" :    Gosub INIT_TYPIMP
      When "CONTROL" : Gosub PROP_TYPIMP
    Endcase
  When "BSIIP.MOVAFTIMP"
    Case [L]ARULE
      When "INIT" : Gosub PROP_MOVAFTIMP
      When "PROPAGATE" : Gosub PROP_MOVAFTIMP
    Endcase
  When "BSIIP.AMTVAR"
    Case [L]ARULE
      When "INIT" : Gosub PROP_AMTVAR
      When "PROPAGATE" : Gosub PROP_AMTVAR
    Endcase
  When "BSIIP.CPY"
    Case [L]ARULE
      When "PROPAGATE" : If !clalev([F:CDA]) : Local File COMPANY [CPY] : Endif
                         Call LEC_CPY( this.CPY ) From CPTLEC
                         this.APARENT.CPYCUR  = [F:CPY]ACCCUR
    Endcase
  When "BSIIP.FLOTYP"
    Case [L]ARULE
      When "PROPAGATE" : Gosub PROPAGATE_FLOTYP
    Endcase
  When "VARPRC"
    Case [L]ARULE
      When "INIT", "CONTROL" : this.VARPRC = "%"
    Endcase
  When "VARPRC2"
    Case [L]ARULE
      When "INIT", "CONTROL" : this.VARPRC2 = "%"
    Endcase
  When "CPYCUR"
    Case [L]ARULE
      When "INIT", "CONTROL" : Gosub SET_CPYCUR
    Endcase
Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* ...
#* ...
#*!
$SET_CPYCUR
    If !clalev([F:CDA]) : Local File COMPANY [CPY] : Endif

    Call LEC_CPY( this.BSIIP.CPY ) From CPTLEC
    this.CPYCUR  = [F:CPY]ACCCUR
Return


#**
#* Enabling and disabling of fields
#* Is called after reading the data of a stored dataset
#*!
$ENABLE_DISABLE_FIELDS
  Gosub PROP_ALLBPR
  Gosub PROP_ALLTYP
  Gosub PROP_ALLCAT
  Gosub PROP_MOVAFTIMP
  Gosub PROP_AMTVAR
  Gosub PROP_TYPIMP
  Gosub PROP_FLGCLS # 2017-08-17 DNE X3-52272
  Gosub PROPAGATE_FLOTYP
Return

#**
#* Enabling and disabling of the fields BPRSTR and BPREND depending on the Flag ALLBPR
#**
$PROP_ALLBPR
  If this.ALLBPR = CST_AYES Then
    ASTATUS = fmet this.ASETATTRIBUTE ("BPRSTR","$isDisabled","true")
    ASTATUS = fmet this.ASETATTRIBUTE ("BPREND","$isDisabled","true")
  Else
    ASTATUS = fmet this.ASETATTRIBUTE ("BPRSTR","$isDisabled","false")
    ASTATUS = fmet this.ASETATTRIBUTE ("BPREND","$isDisabled","false")
  Endif
Return

#**
#* Enabling and disabling of the fields BPRSTR and BPREND depending on the Flag ALLBPR
#**
$PROP_ALLTYP
  If this.ALLTYP = CST_AYES Then
    ASTATUS = fmet this.ASETATTRIBUTE ("BPRTYP","$isDisabled","true")
  Else
    ASTATUS = fmet this.ASETATTRIBUTE ("BPRTYP","$isDisabled","false")
  Endif
Return

#**
#* Enabling and disabling of the fields CATBPC and CATBPS depending on the Flag ALLCAT
#**
$PROP_ALLCAT
  If this.ALLCAT = CST_AYES Then
    ASTATUS = fmet this.ASETATTRIBUTE ("CATBPC","$isDisabled","true")
    ASTATUS = fmet this.ASETATTRIBUTE ("CATBPS","$isDisabled","true")
  Else
    ASTATUS = fmet this.ASETATTRIBUTE ("CATBPC","$isDisabled","false")
    ASTATUS = fmet this.ASETATTRIBUTE ("CATBPS","$isDisabled","false")
  Endif
Return

#**
#* Set TYPIMP initialy to 1 (client)
#**
$INIT_TYPIMP
  this.TYPIMP = CST_ANO
  Gosub PROP_TYPIMP
Return

#**
#* Enabling and disabling field MOVVOL depending on the Flag MOVAFTIMP
#**
$PROP_MOVAFTIMP
  If this.MOVAFTIMP = CST_AYES Then
    ASTATUS = fmet this.ASETATTRIBUTE ("MOVVOL","$isDisabled","false")
    ASTATUS = fmet this.ASETATTRIBUTE ("RENAFTIMP","$isDisabled","false")
  Else
    ASTATUS = fmet this.ASETATTRIBUTE ("MOVVOL","$isDisabled","true")
    ASTATUS = fmet this.ASETATTRIBUTE ("RENAFTIMP","$isDisabled","true")
  Endif
Return


#**
#* Enabling and disabling field AMTVARLIM depending on the Value of field AMTVAR (Enable if value > 0)
#**
$PROP_AMTVAR
  If this.AMTVAR > 0 Then
    ASTATUS = fmet this.ASETATTRIBUTE ("AMTVARLIM","$isDisabled","false")
  Else
    ASTATUS = fmet this.ASETATTRIBUTE ("AMTVARLIM","$isDisabled","true")
  Endif
Return

$PROP_TYPIMP
  If this.TYPIMP = CST_ANO
    ASTATUS = fmet this.ASETATTRIBUTE ("IMPVOL","$isDisabled","true")
  Else
    ASTATUS = fmet this.ASETATTRIBUTE ("IMPVOL","$isDisabled","false")
  Endif
Return


# 2017-08-17 DNE INSERT BEGIN (X3-52272)
#**
#* Enabling and disabling of 0 of fields ACCSUSPENSE and CDAACCSUSP depending on the Value of field FLGCLS
#**
#*!
$PROP_FLGCLS
    If this.FLGCLS = CST_AYES
        ASTATUS = fmet this.ASETATTRIBUTE ( "ACCSUSPENSE", "$isDisabled", "true"  )
        ASTATUS = fmet this.ASETATTRIBUTE ( "CDAACCSUSP",  "$isDisabled", "true"  )
    Else
        ASTATUS = fmet this.ASETATTRIBUTE ( "ACCSUSPENSE", "$isDisabled", "false" )
        ASTATUS = fmet this.ASETATTRIBUTE ( "CDAACCSUSP",  "$isDisabled", "false" )
    Endif
Return
# 2017-08-17 DNE INSERT END


#**
#*  Enable/disable fields based on the Flow type selection
#*!
$PROPAGATE_FLOTYP
    If this.FLOTYP = 2 Then
        # disable fields
        ASTATUS = fmet this.ASETATTRIBUTE("PAYTYP", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("CDASHOPAY", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("CDAEXCPAY", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("ACCSUSPENSE", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("CDAACCSUSP", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("CDAVARCUR", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("DEPTOL", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("AMTVAR", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("VARPRC", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("AMTVARLIM", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("FLGCLS", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("CPYCUR", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("AMTVARCUR", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("VARPRC2", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("USESEALIS", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("BPRBANID", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("BPRNUM", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("BPRNAM", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("USESUBSTR", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("INVNUM", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("SRCDOC", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("ORDERNUM", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("BVRREFNUM", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("AMT", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("MRGDESFLD", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("ALLBPR", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("BPRSTR", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("BPREND", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("ALLTYP", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("BPRTYP", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("ALLCAT", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("CATBPC", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("CATBPS", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("SEAEXD", "$isDisabled", "true")
        ASTATUS = fmet this.ASETATTRIBUTE("SEAEXDLEN", "$isDisabled", "true")
    Else
        # enable fields
        ASTATUS = fmet this.ASETATTRIBUTE("PAYTYP", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("CDASHOPAY", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("CDAEXCPAY", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("ACCSUSPENSE", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("CDAACCSUSP", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("CDAVARCUR", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("DEPTOL", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("AMTVAR", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("VARPRC", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("AMTVARLIM", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("FLGCLS", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("CPYCUR", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("AMTVARCUR", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("VARPRC2", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("USESEALIS", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("BPRBANID", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("BPRNUM", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("BPRNAM", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("USESUBSTR", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("INVNUM", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("SRCDOC", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("ORDERNUM", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("BVRREFNUM", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("AMT", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("MRGDESFLD", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("ALLBPR", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("BPRSTR", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("BPREND", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("ALLTYP", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("BPRTYP", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("ALLCAT", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("CATBPC", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("CATBPS", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("SEAEXD", "$isDisabled", "false")
        ASTATUS = fmet this.ASETATTRIBUTE("SEAEXDLEN", "$isDisabled", "false")
    Endif
Return

