#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe AQCPROC03A

$METHODS
Case ACTION
  When "AINIT"                       : Gosub UPDATE_LOG
  When "ACONTROL"                    : Gosub UPDATE_LOG
  When "AINSERT_CONTROL_BEFORE"      : Gosub UPDATE_LOG
  When "AINSERT_CONTROL_AFTER"       : Gosub UPDATE_LOG
  When "AINSERT_BEFORE"              : Gosub UPDATE_LOG
  When "AINSERT_AFTER"               : Gosub UPDATE_LOG
  When "AINSERT"                     : Gosub UPDATE_LOG
  When "AINSERT_ABORT"               : Gosub UPDATE_LOG
  When "AREAD_BEFORE"                : Gosub UPDATE_LOG : Gosub AREAD_BEFORE
  When "AREAD_AFTER"                 : Gosub UPDATE_LOG : Gosub AREAD_AFTER
  When "ADELETE_CONTROL_BEFORE"      : Gosub UPDATE_LOG
  When "ADELETE_CONTROL_AFTER"       : Gosub UPDATE_LOG
  When "ADELETE_BEFORE"              : Gosub UPDATE_LOG
  When "ADELETE_AFTER"               : Gosub UPDATE_LOG
  When "AUPDATE_CONTROL_BEFORE"      : Gosub UPDATE_LOG
  When "AUPDATE_CONTROL_AFTER"       : Gosub UPDATE_LOG
  When "AUPDATE_BEFORE"              : Gosub UPDATE_LOG
  When "AUPDATE_AFTER"               : Gosub UPDATE_LOG
  When Default:                      : Gosub UNEXPECTED_ACTION
Endcase
Return

$PROPERTIES
Gosub PROPERTY_ACTION

Case [L]CURPRO
  When "C03P01" : Gosub PROPERTY_C03P01
Endcase
Return

$UNEXPECTED_ACTION
 ASTATUS = fmet this.ASETERROR("UNEXPECTED_ACTION", "Unespected Method Action Execute "+ACTION,[V]CST_AWARNING)
Return

$UPDATE_LOG
  [L]ASTATUS = fmet this.ASETERROR(ACTION, "Execute Method Action "+ACTION,[V]CST_AINFO)
Return



$AINSERT_ABORT
ASTATUS = fmet this.ASETERROR("AINSERT_ABORT", "Execute Method Action  AINSERT_ABORT",[V]CST_AINFO)
Return

$ADELETE_CONTROL_AFTER
If this.C03P01 = "SAM_90758"
 ASTATUS = func ASYRSUB._ASETSTATUS(this,"",0,[V]CST_AERROR,[V]CST_AHTTP_FORBIDDEN,func ASYRFNC.MES1(mess(24,149,1),this.C03P01))
Endif
Return

$AREAD_AFTER
Return
If this.C03P01 = "CCL2"
 ASTATUS = func ASYRSUB._ASETSTATUS(this,"",0,[V]CST_AERROR,[V]CST_AHTTP_FORBIDDEN,func ASYRFNC.MES1(mess(76,100,1),this.C03P01))
Endif
Return

$AREAD_BEFORE
Return
If [L]C03P01 = "ADDD"
 ASTATUS = func ASYRSUB._ASETSTATUS(this,"",0,[V]CST_AERROR,[V]CST_AHTTP_FORBIDDEN,func ASYRFNC.MES1(mess(76,100,1),this.C03P01))
Endif
Return

$PROPERTY_C03P01
Case ACTION
   When "INIT"      Gosub C03P01_INIT
   When "CONTROL"   Gosub C03P01_CONTROL
   When "PROPAGATE" Gosub C03P01_PROPAGATE
   When "GET"       Gosub C03P01_GET
Endcase

Return

$PROPERTY_ACTION
Local Integer MY_STATUS
MY_STATUS = fmet this.ASETERROR("PROPERTY_ACTION", "Property Action Execute "+CURPRO+"-"+ACTION,[V]CST_AINFO)
Return


$C03P01_INIT
this.C03P01 = "InitValue"
Return

$C03P01_CONTROL
If this.C03P01 = "QUNIT"
  [L]ASTATUS = fmet this.ASETERROR("C03P01", this.C03P01+" not valid", [V]CST_AERROR)
  Return
Endif
this.C03P01 = toupper(this.C03P01)
Return

$C03P01_PROPAGATE
Return

this.COL(1).C03P02 = "ResProp"
Return

$C03P01_GET
Return
