# Supervisor
## ACLA-CLASSE ## PROJET_COLBPRFIN
# 2018-11-06 07:13:49 639


####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : BPRFIN BP ( Field BPR 15)
####################################################################

$SET_BPRFIN
If [L]_AOLDVAL<>this.BPRFIN
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_BPRFIN
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.BPRFIN
 Gosub PROPAGATE_BPRFIN
Endif
Return

$INIT_BPRFIN
Gosub DECLARE_VAR From WMC0PROJET_COLBPRFIN
[L]CURPRO = "BPRFIN"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_BPRFIN
Gosub DECLARE_VAR From WMC0PROJET_COLBPRFIN
[L]CURPRO = "BPRFIN"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_BPRFIN                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_BPRFIN                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_BPRFIN
[L]CURPRO = "BPRFIN"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.BPRFIN,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_BPRFIN
[L]CURPRO = "BPRFIN"
If vireblc(this.BPRFIN,2)<>vireblc(format$("K:15c",this.BPRFIN),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_BPRFIN
[L]CURPRO = "BPRFIN"
If vireblc(this.BPRFIN,2)<>""
 If fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent")=""
  [L]ASTATUS =  func WMTYPBPR.ACTRLREF(this,"BPRFIN",this.BPRFIN,this.BPRFIN,2,"")
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Else
  If this.BPRFIN<>evalue("this.APARENT."+fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent"))
   [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(83,123,1)) :  Return : # Invalid value
  Endif
 Endif
Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_BPRFIN
[L]CURPRO = "BPRFIN"
Return

$PROPAGATE_BPRFIN
this.isReadonly = 0
[L]CURPRO = "BPRFIN"
Gosub _LNKPRO_BPRFIN
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_BPRFIN
Gosub DECLARE_VAR From WMC0PROJET_COLBPRFIN
[L]CURPRO = "BPRFIN"
$_LNKPRO_BPRFIN
If vireblc(this.BPRFIN,2)<>""
 # Link BPARTNER
 Local File BPARTNER [WBPR]
 Read [F:WBPR]BPR0 = this.BPRFIN
 If !fstat
  [L]ASTATUS = fmet this.ASETATTRIBUTE("BPRFIN","$title",[F:WBPR]BPRSHO)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("BPRFIN","$description",[F:WBPR]BPRNAM)
 Endif
 LogicClose File [WBPR]
Endif
Return


####################################################################
# 2 : AMTFIN Financed amount ( Field MD0 0)
####################################################################

$SET_AMTFIN
If [L]_AOLDVAL<>this.AMTFIN
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_AMTFIN
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.AMTFIN
 Gosub PROPAGATE_AMTFIN
Endif
Return

$INIT_AMTFIN
Gosub DECLARE_VAR From WMC0PROJET_COLBPRFIN
[L]CURPRO = "AMTFIN"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_AMTFIN
Gosub DECLARE_VAR From WMC0PROJET_COLBPRFIN
[L]CURPRO = "AMTFIN"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_AMTFIN                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_AMTFIN                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_AMTFIN
[L]CURPRO = "AMTFIN"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.AMTFIN=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_AMTFIN
[L]CURPRO = "AMTFIN"
Return

$_AOTHERS_AMTFIN
[L]CURPRO = "AMTFIN"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_AMTFIN
[L]CURPRO = "AMTFIN"
Return

$PROPAGATE_AMTFIN
this.isReadonly = 0
[L]CURPRO = "AMTFIN"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_AMTFIN
Gosub DECLARE_VAR From WMC0PROJET_COLBPRFIN
[L]CURPRO = "AMTFIN"
$_LNKPRO_AMTFIN
Return


####################################################################
# 3 : CURFIN Currency ( Field CUR 3)
####################################################################

$SET_CURFIN
If [L]_AOLDVAL<>this.CURFIN
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_CURFIN
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.CURFIN
 Gosub PROPAGATE_CURFIN
Endif
Return

$INIT_CURFIN
Gosub DECLARE_VAR From WMC0PROJET_COLBPRFIN
[L]CURPRO = "CURFIN"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_CURFIN
Gosub DECLARE_VAR From WMC0PROJET_COLBPRFIN
[L]CURPRO = "CURFIN"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_CURFIN                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_CURFIN                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_CURFIN
[L]CURPRO = "CURFIN"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.CURFIN,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_CURFIN
[L]CURPRO = "CURFIN"
If vireblc(this.CURFIN,2)<>vireblc(format$("K:3c",this.CURFIN),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_CURFIN
[L]CURPRO = "CURFIN"
If vireblc(this.CURFIN,2)<>""
 If fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent")=""
  [L]ASTATUS =  func WMTYPCUR.ACTRLREF(this,"CURFIN",this.CURFIN,this.CURFIN,"")
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Else
  If this.CURFIN<>evalue("this.APARENT."+fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent"))
   [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(83,123,1)) :  Return : # Invalid value
  Endif
 Endif
Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_CURFIN
[L]CURPRO = "CURFIN"
Return

$PROPAGATE_CURFIN
this.isReadonly = 0
[L]CURPRO = "CURFIN"
Gosub _LNKPRO_CURFIN
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_CURFIN
Gosub DECLARE_VAR From WMC0PROJET_COLBPRFIN
[L]CURPRO = "CURFIN"
$_LNKPRO_CURFIN
If vireblc(this.CURFIN,2)<>""
 # Link TABCUR
 Local File TABCUR [WTCU]
 Read [F:WTCU]TCU0 = this.CURFIN
 If !fstat
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="TABCUR" & ZONE="INTSHO" & IDENT1=[F:WTCU]CUR & IDENT2="" & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("CURFIN","$title",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="TABCUR" & ZONE="INTDES" & IDENT1=[F:WTCU]CUR & IDENT2="" & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("CURFIN","$description",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CURFIN","$symbol",[F:WTCU]CURSYM)
  If int(val([F:WTCU]CURFMT1))>0
   Local Char WPREC(10)
   Local Char WSCALE(10)
   WPREC=num$(int(val([F:WTCU]CURFMT1)))
   WSCALE=num$(int(10*(val([F:WTCU]CURFMT1)-int(val([F:WTCU]CURFMT1)))))
   [L]ASTATUS = fmet this.ASETATTRIBUTE("CURFIN","$precision",WPREC)
   [L]ASTATUS = fmet this.ASETATTRIBUTE("CURFIN","$scale",WSCALE)
  Endif
 Endif
 LogicClose File [WTCU]
Endif
Return




