#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################################################################
# UTITC38                                                                  Module Tronc Commun      #
#                                                                             04/04/2012            #
# Concerne le bug 80360 :                                                                           #
# Application d'une formule de taxe :                                                               #
#    Dans le paramétrage de détermination des taxes, la formule créée à partir des 5 critères       #
#    de sélection n'est pas enregistrée dans la table TABVAC Table détermination des taxes,         #
#    mais uniquement les critères eux-mêmes                                                         #
#                                                                                                   #
# But de l'utilitaire :                                                                             #
#    Initialiser le nouveaux champ EXP2 avec la formule déduite des critères de sélection présents  #
#    dans la tables                                                                                 #
#                                                                                                   #
#####################################################################################################
# Issue 78775 - 2011-12-21 by CPO
#####################################################################################################
Call MAJ_UTITC38

End
#-------------------------------------------------------------------
Subprog MAJ_UTITC38

Local Char DOSSIER(30)
DOSSIER=nomap
# Issue 108760 - 2015-08-07 by MAE :
#Call SAIDOS(DOSSIER,"UTITC38 - Tax Determination Process : Update TABVAC") From SAIDOS
Call SAIDOSHIS(DOSSIER,"UTITC38 - Tax Determination Process : Update TABVAC") From SAIDOSHIS

If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITC38 - Tax Determination Process : Update TABVAC") From LECFIC
  Call EXE_UTITC38(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif

End
#-------------------------------------------------------------------
Subprog EXE_UTITC38(DOSSIER)
Value Char    DOSSIER

Call ECR_TIME("UTITC38 : Start folder's process"-DOSSIER) From DOSSUB

#----- Chargement globale GMAXUPDTRS -----#
If dim([V]GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif

Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]

#----- Début du traitement -----#
Gosub TRT_TVC                       : # Traitement de la détermination des taxes
#-----  Fin du traitement  -----#

$FIN_UTITC38
Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Call ECR_TIME("UTITC38 : End folder's process"-DOSSIER) From DOSSUB

End
#------------------------------------------------------------------#
#   Initialisation flag de signature dans les devis                #
# ---------------------------------------------------------------- #
# Table TABVAC   - Table détermination des taxes                   #
#   EXP2           Expression (formule déterminée par les critères #
#------------------------------------------------------------------#
$TRT_TVC

If filinfo(filpath("FIL","TABVAC","fde", DOSSIER),0) < 0 : Return : Endif

Call ECR_TIME("UTITC38 : Tax Determination Process : Update TABVAC") From DOSSUB

Local Integer  IJL,IJL1
Local Shortint STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(80), CRITERE(100)
Local Char     EXPRESSION(250)

Local File =DOSSIER+".TABVAC"    [TVC]
#--Utilisées lors de l'appel EXPRESSION From SELOBJ
Local File =DOSSIER+".ATABZON"   [ATZ]
Local File =DOSSIER+".ATEXTE"    [ATX]
Local File =DOSSIER+".ATYPE"     [ATY]

Local Mask =DOSSIER+".ASELOBJ"   [ASL]
#--

$B_TRT_TVC
If  STOP=1
    CRITERE = '[F:TVC]FLD(0)<>"" & [F:TVC]COD>"'+CLE1+'"'
    STOP = 0
Else
    CRITERE = '[F:TVC]FLD(0)<>""'
Endif

Raz COMPTEUR

Trbegin [TVC]
For [TVC]TVC0 Where evalue(CRITERE)
  #--Création de la formule à partir des champs FLD/OPE/VALI/VALS/ANDOR
  Gosub CHARGEMSK_TVC1
  #--La formule sera dans EXPRESSION
  If EXPRESSION<>""
      [F:TVC]EXP2= vireblc(EXPRESSION,2)
      Rewrite [TVC]
      If fstat
          Call ECR_TRACE("File TABVAC"-[F:TVC]COD+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    COMPTEUR+=1
  Endif
  NBENR+=1
  If COMPTEUR>GMAXUPDTRS CLE1=[F:TVC]COD : STOP=1 : Break : Endif
Next
Commit
If STOP Goto B_TRT_TVC : Endif

Close Local File [TVC]
Close Local Mask [ASL]
Close Local File [ATZ]
Close Local File [ATX]
Close Local File [ATY]

Call ECR_TIME("UTITC38 : Tax Determination Process : Ended :"+"("-num$(NBENR)+" records processed"-")") From DOSSUB

Return
#-----------------------------------------------------------------------------------------------
$CHARGEMSK_TVC1
Raz EXPRESSION
Raz [M:ASL]
[M:ASL]=[F:TVC]

[M]ATB ="TAXLINK" : [M]ABR ="TLK"
[M]TBL1="TAXLINK" : [M]TBL2="TAXLINK" : [M]TBL3="TAXLINK" : [M]TBL4="TAXLINK" : [M]TBL5="TAXLINK"
For IJL=0 To dim([F:TVC]FLD)-1
    If [F:TVC]FLD(IJL)="" : Break : Endif
    If IJL>0
      Assign ("[M]ANDOR"+num$(IJL+1)) With [F:TVC]ANDOR(IJL)
    Endif
    Assign ("[M]FLD"  +num$(IJL+1)) With [F:TVC]FLD(IJL)
    Assign ("[M]OPE"  +num$(IJL+1)) With [F:TVC]OPE(IJL)
    Assign ("[M]VAL"  +num$(IJL+1)) With [F:TVC]VALS(IJL)
    Assign ("[M]VALI" +num$(IJL+1)) With [F:TVC]VALI(IJL)
Next IJL

#--On Raz le [M]EXP1 sinon il sera rajouté dans EXPRESSION par le Gosub EXPRESSION From SELOBJ
Raz [M]EXP1

Local Char ABR(GLONABR)
Gosub EXPRESSION From ASELOBJ

Return
#-----------------------------------------------------------------------------------------------
Subprog PATCH(DOSSIER)
Value Char DOSSIER

If DOSSIER=GDOSX3  End : Endif
If filinfo(filpath("FIL","TABVAC","fde",DOSSIER),0)<=0 : End : Endif

If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-08-07 by MAE :
#Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(DOSSIER)=0 : End : Endif
If func DOSVUE.ISVIEW(DOSSIER,"TABVAC") : End : Endif
# End MAE 108760

Call EXE_UTITC38(DOSSIER)

End
#-----------------------------------------------------------------------------------------------
#------------------------------------------------------------------#
# Pour exécution depuis dosmaj (validation dossier)                #
#------------------------------------------------------------------#
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI=GDOSX3 End Endif
If filinfo(filpath("FIL","TABVAC","fde",APPLI),0)<=0 : End : Endif

If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
# Issue 108760 - 2015-08-07 by MAE :
#Read [ADS]DOSSIER=APPLI : If fstat  Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
If func DOSVUE.ISVIEW(APPLI,"TABVAC") : End : Endif
# End MAE 108760

Call EXE_UTITC38(APPLI)

End

