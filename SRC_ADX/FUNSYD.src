#<AdxTL>@(#)1.0.0.0 $Revision$
###########################################################################################
# Données de synchronisation                             Créé le 04 novemnbre 2005
###########################################################################################
###########################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "AVANT_MEN"    : Gosub AVANT_MEN
    When "BOUTON"       : Gosub BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "RAF"          : Gosub REFRESH
    When "ABA"          : Gosub ABANDON
    When "ENR"          : Gosub ENREGISTRER
    When Default
  Endcase
Return

##########################################################################################################
$REFRESH
Return

##########################################################################################################
$OUVRE
Global Integer GSYDMODIFSYD0

  #Ouvre les fichiers utilisés dans l'ffichage des données de synchronisation
  If !clalev([F:SYD]) : Local File SYNCDATA [SYD] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  GSYDMODIFSYD0 = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If GSYDMODIFSYD0 = 0 Then
    # Désactivation
    ETABOU(GSPE1) = 1
  Else
    ETABOU(GSPE1) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Global Char GSZTSYD0KEY(30)(dim([M:SYD0]SYDNUM))
Global Integer GINBSYD0KEY

  Raz GSZTSYD0KEY
  Raz [SYD0]
  Gosub LOADSYD
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$AVANT_MEN
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub RAZSYD
      Gosub LOADSYD
    When Default
  Endcase
Return
##########################################################################################################
$FINSAI
  If clalev([F:SYD]) : Close Local File [SYD] : Endif
Return

##########################################################################################################
$FIN
  Kill GSZTSYD0KEY
  Kill GINBSYD0KEY
Return

##########################################################################################################
$ABANDON
  Gosub RAZSYD
  Gosub LOADSYD
Return

##########################################################################################################
$ENREGISTRER
Local Integer ICURLIGNE
Local Integer ILIGNESAVE
Local Integer IBERROR

  IBERROR = 0
  Call DEBTRANS From GLOCK
  Trbegin [SYD]
  #Traitement des lignes supprimés
  If GINBSYD0KEY > 0 Then
    For ICURLIGNE = 0 To GINBSYD0KEY-1
      If GSZTSYD0KEY(ICURLIGNE) <> "" Then
        Delete [SYD] Where [F:SYD]SYDNUM = GSZTSYD0KEY(ICURLIGNE)
        If fstat <> 0 Then
          #Erreur lors de la suppression des données de synchronisation+" [F:SYD]SYDNUM="+[F:SYD]SYDNUM
          GMESSAGE = mess(211,177,1) - "[F:SYD]SYDNUM=" + [F:SYD]SYDNUM
          GERR = 2
          OK = 0
          IBERROR = 1
          Break
        Endif
      Endif
    Next ICURLIGNE
  Endif
  If IBERROR = 0 Then
    #Traitement des lignes modifiées
    ICURLIGNE = 0
    ILIGNESAVE = nolign
    While ICURLIGNE<[M:SYD0]NBLIGN 
      If [M:SYD0]TRTLIGNE(ICURLIGNE) = 2 Then
        #Il faut traiter la ligne
        Read [SYD]SYD0=[M:SYD0]SYDNUM(ICURLIGNE)
        If fstat <> 0 Then
          #Erreur lors de la lecture des données de synchronisation+" [F:SYD]SYDNUM="+[F:SYD]SYDNUM
          GMESSAGE = mess(339,177,1) - "[F:SYD]SYDNUM=" + [F:SYD]SYDNUM
          GERR = 2
          OK = 0
          IBERROR = 1
        Else
          Readlock [SYD]Curr
          If fstat = 0 Then
            [F:SYD]SYDATTTYP = "R"
            [F:SYD]SYDOTKSTA = 1
            [F:SYD]SYDUPD = 0
            [F:SYD]SYDDAT = date$
            [F:SYD]SYDHOU = time$
            [F:SYD]UPDUSR= GUSER
            [F:SYD]UPDDAT = date$
            Rewrite [SYD]
            If fstat <> 0 Then
              #Erreur lors de la modification des données de synchonisation+" [F:SYD]SYDNUM=" + [F:SYD]SYDNUM
              GMESSAGE = mess(340,177,1) - "[F:SYD]SYDNUM=" + [F:SYD]SYDNUM
              GERR = 2
              OK = 0
              IBERROR = 1
              Break
            Endif
          Else
            #Impossible de locker les données de synchronisation+" [F:SYD]SYDNUM=" + [F:SYD]SYDNUM
            GMESSAGE = mess(341,177,1) - "[F:SYD]SYDNUM=" + [F:SYD]SYDNUM
            GERR = 2
            OK = 0
            IBERROR = 1
          Endif
        Endif
      Endif
      ICURLIGNE += 1
    Wend
  Endif
  If IBERROR = 0 Then
    Commit
  Else
    Rollback
  Endif
  Gosub RAZSYD
  Gosub LOADSYD
Return

##########################################################################################################
$APRES_MODIF
  If COUZON <> "FILSYDUSR" and COUZON <> "FILSYDTYP" Then
    REP = "M"
  Endif
Return

##########################################################################################################
# Sous-programmes
#########################################################################################
# LOADSYD   : Charge les données de synchronisation
##########################################################################################################
$LOADSYD
Local Integer ICURLIGNE
Local Char SZWHERE(250)
Local Char SZAND(6)

  #Charge les données de synchronisation
  ICURLIGNE = 0
  Raz GSZTSYD0KEY
  GINBSYD0KEY = 0
  Raz SZWHERE
  Raz SZAND
  #Traitement des flitres
  If [M:SYD0]FILSYDUSR <> "" Then
    SZWHERE = "[F:SYD]SYDUSR=[M:SYD0]FILSYDUSR"
    SZAND = " AND "
  Endif
  If [M:SYD0]FILSYDTYP <> "" Then
    SZWHERE = SZWHERE - SZAND - "[F:SYD]SYDTYP=[M:SYD0]FILSYDTYP"
    SZAND = " AND "
  Endif
  If SZWHERE <> "" Then
    Filter [SYD] Where evalue (SZWHERE) Order By [F:SYD]SYDUSR Asc; [F:SYD]SYDDAT Asc
  Else
    Filter [SYD] Order By [F:SYD]SYDUSR Asc; [F:SYD]SYDDAT Asc
  Endif
  #Remplit le tableau
  nolign = 0
  For [SYD]
    If ICURLIGNE = dim([M:SYD0]SYDNUM)-1 Then
      Break
    Endif
    #Transclass des données de synchronisation
    nolign += 1
    [M:SYD0] = [F:SYD]
    ICURLIGNE += 1
  Next
  Filter [SYD]
  [M:SYD0]NBLIGN = ICURLIGNE 
  ICURLIGNE = 0
  Affzo [M:SYD0]1-99
  GSYDMODIFSYD0 = 0
  REP = ""
Return


##########################################################################################################
$RAZSYD
  Effzo [M:SYD0]10
  [M:SYD0]NBLIGN=0
Return
 
##########################################################################################################
Subprog B1_NBLIGN
  [M:SYD0]TRTLIGNE(nolign-1) = 2
  [M:SYD0]SYDATTTYP(nolign-1) = "R"
  Affzo [M:SYD0]TRTLIGNE(nolign-1)
  Affzo [M:SYD0]SYDATTTYP(nolign-1)
  mkstat = 4
  REP = "M"
  GREP = "M"
  GSYDMODIFSYD0 = 1
End

##########################################################################################################
Subprog C_NBLIGN
Local Integer NOL

  If status = 65 Then
    # Annulation simple
    NOL = nolign-1
    Gosub TRT_ANNULATION
  Elsif status = 68 or status = 83 Then
    # Annulation multiple
    For NOL = nolign-1 To nolign1-1
      Gosub TRT_ANNULATION
    Next NOL
  Endif
End

##########################################################################################################
$TRT_ANNULATION
  GSZTSYD0KEY(GINBSYD0KEY) = [M:SYD0]SYDNUM(NOL)
  GINBSYD0KEY += 1
  GSYDMODIFSYD0 = 1
Return

##########################################################################################################
Subprog B2_NBLIGN
Local Integer INOLIGNSAVE
Local Integer ILIGNE

  INOLIGNSAVE = nolign
  ILIGNE = 0
  While ILIGNE < [M:SYD0]NBLIGN
    [M:SYD0]TRTLIGNE(ILIGNE) = 2
    [M:SYD0]SYDATTTYP(ILIGNE) = "R"
    ILIGNE += 1
  Wend
  Affzo [M:SYD0]TRTLIGNE
  Affzo [M:SYD0]SYDATTTYP
  mkstat = 4
  REP = "M"
  GREP = "M"
  GSYDMODIFSYD0 = 1
End

##########################################################################################################
Subprog B3_NBLIGN
## Action GOBJETC1
Local Char    PARMSK(250)(1..20) , SAVACT(20)

  SAVACT = GACTION : GACTION = "GOBJETC1"
  Call OBJET_CHAR([M:SYD0]SYDKEY(nolign - 1),[M:SYD0]SYDTYP(nolign - 1),"") From GOBJET
  GACTION = SAVACT
  #On recharge les données
  Gosub LOADSYD 
End
