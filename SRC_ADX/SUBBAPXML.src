#<AdxTL>@(#)9.0.0.0 $Revision$
###############################################################################################################
#
#   Génération XML d'un Rendez-vous                                                      Version 140
#   Module CRM                             
#
#   XXXINXML    : Objet unique avec ses tables liées en multi-niveaux.
#   XXXLISTXML  : Liste filtrée de la table objet.
#   
###############################################################################################################

Subprog BAPINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF
ICHAPTER = 0
IERRINF = 0
SZFULLRETFILE = ""
SZRETFILENAME = ""

If SZRECNUM = "" : End : Endif

Gosub XMLPART1 From CRMXML140

Call TEXTE(14423, SZHTMLTITLE) From OBJDIV      #Rendez-vous
SZSUBPROG = "BAPINXML"
SZAOBABREV = "BAP"

Gosub XMLPART2 From CRMXML140
If IERRINF : End : Endif

Gosub DOCOREXML

Gosub XMLPART3 From CRMXML140

End

#########################################################################################################################
Subprog BAPLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZCUSTFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFILTER
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF
ICHAPTER = 0
IERRINF = 0
SZFULLRETFILE = ""
SZRETFILENAME = ""

If SZFILTER = ""
    SZFILTER = "1=1"
Endif

Gosub XMLPART1 From CRMXML140

Call TEXTE(14423, SZHTMLTITLE) From OBJDIV      #Rendez-vous
SZSUBPROG = "BAPLISTXML"
SZAOBABREV = "BAP"

Gosub XMLPART2B From CRMXML140
If IERRINF : End : Endif

Gosub DOLISTXML

Gosub XMLPART3 From CRMXML140

End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOLISTXML

Gosub SETBAPEXCEPT From CRMEXCEPT

#On extrait
Filter [BAP] Where evalue(SZFILTER)

For [BAP]
    SZCTAOB = "BAP"
    SZCTAOBNUM = [F:BAP]APTNUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLBAP From CRMEXCEPT
Next

Filter [BAP]
Return

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREXML

Gosub SETBAPEXCEPT From CRMEXCEPT
Gosub SETBPREXCEPT From CRMEXCEPT
Gosub SETBPCEXCEPT From CRMEXCEPT
Gosub SETBPAEXCEPT From CRMEXCEPT
Gosub SETREPEXCEPT From CRMEXCEPT
Gosub SETAINEXCEPT From CRMEXCEPT
Gosub SETRRSEXCEPT From CRMEXCEPT

#On extrait
Filter [BAP] Where [F:BAP]APTNUM = SZRECNUM

For [BAP]
    SZCTAOB = "BAP"
    SZCTAOBNUM = [F:BAP]APTNUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLBAP From CRMEXCEPT

    #Interlocuteurs
    Gosub ADDAIN

    #Représentants
    Gosub ADDREP

    #Réservations de ressources
    If IDISPLAYRRS
        Gosub ADDRRS
    Endif

    #Tiers
    If IDISPLAYBPR
        Gosub ADDBPR
    Endif

    #Client
    If IDISPLAYBPC
        Gosub ADDBPC
    Endif

    #Adresse
    If IDISPLAYBPA
        Gosub ADDBPA
    Endif
Next

Filter [BAP]

Return

##########################################################
# Tiers
##########################################################
$ADDBPR

Filter [BPR] Where [F:BPR]BPRNUM = [F:BAP]APTCMP

For [BPR]
    SZCTAOB = "BPR"
    SZCTAOBNUM = [F:BPR]BPRNUM
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "BAP"
    SZCTPARENTNUM = [F:BAP]APTNUM
    Gosub XMLBPR From CRMEXCEPT
Next

Filter [BPR]
Return

##########################################################
# Client
##########################################################
$ADDBPC

Filter [BPC] Where [F:BPC]BPCNUM = [F:BAP]APTCMP

For [BPC]
    SZCTAOB = "BPC"
    SZCTAOBNUM = [F:BPC]BPCNUM
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "BAP"
    SZCTPARENTNUM = [F:BAP]APTNUM
    Gosub XMLBPC From CRMEXCEPT
Next

Filter [BPC]
Return

##########################################################
# Adresse
##########################################################
$ADDBPA

Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:BAP]APTCMP

For [BPA]
    SZCTAOB = "BPA"
    SZCTAOBNUM = num$([F:BPA]BPATYP) + [F:BPA]BPANUM + [F:BPA]BPAADD
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "BAP"
    SZCTPARENTNUM = [F:BAP]APTNUM
    Gosub XMLBPA From CRMEXCEPT
Next

Filter [BPA]
Return

##########################################################
# Contact
##########################################################
$ADDAIN

Local Integer ITERCCNNUM
ITERCCNNUM = 0

For ITERCCNNUM = 0 To dim([F:BAP]APTCCNNUM) - 1
    If [F:BAP]APTCCNNUM(ITERCCNNUM) <> ""
        Read [AIN] AIN0 = [F:BAP]APTCCNNUM(ITERCCNNUM)
        If !fstat
            SZCTAOB = "AIN"
            SZCTAOBNUM = [F:BAP]APTCCNNUM(ITERCCNNUM)
            SZCTLEVEL = "1"
            SZCTPARENTAOB = "BAP"
            SZCTPARENTNUM = [F:BAP]APTNUM
            Gosub XMLAIN From CRMEXCEPT
        Endif
    Endif
Next
Return

##########################################################
# Représentant
##########################################################
$ADDREP

Local Integer ITERREPNUM
ITERREPNUM = 0

For ITERREPNUM = 0 To dim([F:BAP]APTREPNUM) - 1
    If [F:BAP]APTREPNUM(ITERREPNUM) <> ""
        Read [REP] REP0 = [F:BAP]APTREPNUM(ITERREPNUM)
        If !fstat
            SZCTAOB = "REP"
            SZCTAOBNUM = [F:REP]REPNUM
            SZCTLEVEL = "1"
            SZCTPARENTAOB = "BAP"
            SZCTPARENTNUM = [F:BAP]APTNUM
            Gosub XMLREP From CRMEXCEPT
        Endif
    Endif
Next
Return

##########################################################
# Réservations de ressources
##########################################################
$ADDRRS

ITERRRS = 0
For ITERRRS = 0 To dim([F:BAP]APTRER) - 1
    If [F:BAP]APTRER(ITERRRS) <> ""
        Read [RRS] RRS0 = [F:BAP]APTRER(ITERRRS)
        If !fstat
            SZCTAOB = "RRS"
            SZCTAOBNUM = [F:RRS]NUM
            SZCTLEVEL = "1"
            SZCTPARENTAOB = "BAP"
            SZCTPARENTNUM = [F:BAP]APTNUM
            Gosub XMLRRS From CRMEXCEPT
        Endif
    Endif
Next
Return

