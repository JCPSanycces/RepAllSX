#<AdxTL>@(#)4.0.0.0 $Revision$
# =====================================================================================================
# CBO   18.07.2017 X3-48396  var NOREL too short : now GLONVCR instead of 15
# Bader 2018-06-28 X3-96628  init GSWIPAYQR
# =====================================================================================================

Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"PAYPROPAL"
 GFONCTION="PAYPROPAL" : Call AUTORIS From EXEFNC
Endif
GACTION = "PAYPROPAL"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","PAYPROPAL","DGENPAY",4,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

$ACTION
Case ACTION
 When "INIT"         : Gosub INIT
 When "CONT_BATCH"   : Gosub CONT_BATCH
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE_BATCH"  : Gosub OUVRE_BATCH
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When "SORTIE"       : Gosub SORTIE
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "BOUTON"       : Gosub BOUTON
 When "SETBOUT"      : Gosub DEFAUT
Endcase
Return

#####
$INIT
#####
If !clalev([M:DIA]) : Local Mask PAYPROP0 [DIA] : Endif
If !clalev([M:DI1]) : Local Mask PAYPROP1 [DI1] : Endif
If !clalev([M:DI2]) : Local Mask PAYPROP2 [DI2] : Endif
Gosub DEFAUT
Return

$DEFAUT
Default Mask [DIA]
Default Mask [DI1]
Default Mask [DI2]
Return

############
$CONT_BATCH
############
# 2016-02-03 DNE INSERT BEGIN (SAM #101378)
Gosub SWI_CONT_BVR_ISSUES From SWILIB0
If FIN : Return : Endif
# 2016-02-03 DNE INSERT END
[M:DIA] = [M:DI1]
[M:DIA] = [M:DI2]
Return

############
$OUVRE_BOITE
############
#Raz [M:DIA]  # Bug 22423
Call LECMEMO("STD","[M:DIA]","ppl") From GMEMO
Gosub DEFAUT
If [M:DIA]CPY<>""
 Raz [M:DI1]SACACC, [M:DI2]SACPAYACC
 [M:DI1] = [M:DIA]
 [M:DI2] = [M:DIA]
Endif
Return

######
$DEBUT
######
Affzo [DIA]
Affzo [DI1]
Affzo [DI2]
Setmok [DIA] With 0 : # non géré en Web
Setmok [DI1] With 0 : # non géré en Web
Setmok [DI2] With 0 : # non géré en Web
Gosub GRISE From SUBPAYP


########  SAM REF# 76609 added by angre 05/31/12 ########################
#call to a subprog wich sets the due date in discount section
#visible/invisible depending on general parameter
#########################################################################
#Call SETDSCDUEVISIBILITY() From PAYDEPLIB

########  SAM REF# 76609 added by angre 05/31/12 ########################
#treatment of Date selection mode of the payment proposal screen
#depending on this selection blocks must be activated/deactivated
#########################################################################
Call SETSELECTIONSETTINGS([M:DIA]CPY, [M:DIA]DATSELMODE) From PAYDEPLIB


$OUVRE_BATCH
Onerrgo CHUT From CONTROLE
If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
If !clalev([F:GCU])  : Local File GRPCUR     [GCU]  : Endif
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif
If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
If !clalev([F:BAN])  : Local File BANK       [BAN]  : Endif
If !clalev([F:POO])  : Local File POOL       [POO]  : Endif
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
If !clalev([F:FGR])  : Local File FACGROUP   [FGR]  : Endif
If !clalev([F:AGC])  : Local File AGRPCPY    [AGC]  : Endif

Onerrgo
If GERREUR : GERREUR=0 : Endif
Return


#############
$AVANT_BOUTON
#############
Case BOUT
 When "M", "R" : # Mémo
  [M:DIA] = [M:DI1]
  [M:DIA] = [M:DI2]
Endcase
Return

#######
$BOUTON
#######
Case BOUT
 When "R" : # Rappel
  [M:DI1] = [M:DIA]
  [M:DI2] = [M:DIA]
  Affzo [DI1]
  Affzo [DI2]
  Gosub DEFAUT
  Gosub GRISE From SUBPAYP

  ########  SAM REF# 76609 added by angre 06/19/12 ########################
  #treatment of the "Date selection mode" of the Payment proposal screen and
  #the visibility of the Due date fields in the discount section of the
  #Payment proposal screen
  #########################################################################
  Call SETSELECTIONSETTINGS([M:DIA]CPY ,[M:DIA]DATSELMODE) From PAYDEPLIB
  ########  SAM REF# 76609 added by angre 07/09/12 ########################
  #Treats the Discount settings "Allowance days" and "Allways use discount".
  #########################################################################
  Call SETDISCOUNTSETTINGS([M:DIA]ADDALLDAY, [M:DIA]ALWDISFLG) From PAYDEPLIB


 When "M"
  Gosub DEFAUT
Endcase
Setmok [DIA] With 0 : # non géré en Web
Setmok [DI1] With 0
Setmok [DI2] With 0
Return

#########
$CONTROLE
#########
If GSTATUT<>GSTAOK : FIN=1 : Return : Endif
# 2016-02-03 DNE INSERT BEGIN (SAM #101378)
Gosub SWI_CONT_BVR_ISSUES From SWILIB0
If FIN : Return : Endif
# 2016-02-03 DNE INSERT END
TMP=1 : TIT="O"
[M:DIA] = [M:DI1]
[M:DIA] = [M:DI2]
Return

########
$TERMINE
########
If GSERVEUR & GOK=2 : GOK=1 : Return : Endif  # En batch : il faut que GOK soit <1
If !PROP : # Aucun règlement traité
 GERR=2 : GMESSAGE=mess(2,117,1)
Endif
Return

#####
$EXEC
#####
Onerrgo ERREUR From CONTROLE
If !clalev([F:PYH])  : Local File PAYMENTH   [PYH]  : Endif
If !clalev([F:PYD])  : Local File PAYMENTD   [PYD]  : Endif
If !clalev([F:PYA])  : Local File PAYMENTA   [PYA]  : Endif
If !clalev([F:PYL])  : Local File PAYLOT     [PYL]  : Endif
If !clalev([F:DUD])  : Local File GACCDUDATE [DUD]  : Endif
If !clalev([F:SOI])  : Local File SOI        [SOI]  : Endif
If !clalev([F:TPD])  : Local File TMPPAYDUD  [TPD]  : Endif
If !clalev([F:TPD2]) : Local File TMPPAYDUD  [TPD2] : Endif
If !clalev([F:TP2])  : Local File TMPPAYDUD2 [TP2]  : Endif
If !clalev([F:PYT])  : Local File TMPPAYTOT  [PYT]  : Endif
If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
If !clalev([F:BPA])  : Local File BPADDRESS  [BPA]  : Endif
If !clalev([F:BPC])  : Local File BPCUSTOMER [BPC]  : Endif
If !clalev([F:BPS])  : Local File BPSUPPLIER [BPS]  : Endif
If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
If !clalev([F:GCU])  : Local File GRPCUR     [GCU]  : Endif
If !clalev([F:POO])  : Local File POOL       [POO]  : Endif
If !clalev([F:GSC])  : Local File GRPSAC     [GSC]  : Endif
If !clalev([F:TCA])  : Local File TABCOUAFF  [TCA]  : Endif
If !clalev([F:BID])  : Local File BID        [BID]  : Endif
If !clalev([F:CDA])  : Local File GACCDENCOD [CDA]  : Endif
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif
If !clalev([F:BAN])  : Local File BANK       [BAN]  : Endif
If !clalev([F:CAC])  : Local File GACCCODE   [CAC]  : Endif
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]  : Endif
If !clalev([F:DAE])  : Local File GACCENTRYD [DAE]  : Endif
If !clalev([F:MTB])  : Local File MTCBATCH   [MTB]  : Endif
If !clalev([F:GTE])  : Local File GTYPACCENT [GTE]  : Endif
If !clalev([F:FGR])  : Local File FACGROUP   [FGR]  : Endif
If !clalev([F:AGC])  : Local File AGRPCPY    [AGC]  : Endif
If !clalev([F:TDA])  : Local File TABDEPAGIO [TDA]  : Endif
If clalev([F:SIH])=0 : Local File SINVOICE   [SIH]  : Endif
If clalev([F:PIH])=0 : Local File PINVOICE   [PIH]  : Endif
If clalev([F:SIL])=0 : Local File BPCINVLIG  [SIL]  : Endif
If clalev([F:PIL])=0 : Local File BPSINVLIG  [PIL]  : Endif
If GMODU(5)=2 & clalev([F:SVV])=0 : Local File SVCRVAT [SVV] : Endif
If GMODU(6)=2 & clalev([F:PVV])=0 : Local File PVCRVAT [PVV] : Endif

If filinfo(filpath("FIL","MANDATE","fde",""),0)>0
 If clalev([F:MDT])=0 : Local File MANDATE    [MDT]  : Endif
Endif
If clalev([F:HAE3])=0 : Local File GACCENTRY   [HAE3] : Endif
Local Integer MAJRATINV    # Application du cours facture
Local Decimal WRAT


Local Mask PAY3 [PAY3]
If dim([M:PAY3]RITAMT)>0
 If !clalev([F:PIH]) : Local File PINVOICE   [PIH] : Endif
 If !clalev([F:RTZ]) : Local File RITENZIONE [RTZ] : Endif
Endif
Close Local Mask [PAY3]
Local Mask PAY4 [PAY4]
Local Integer X1
X1 = dim([M:PAY4]PAYNUM)
Close Local Mask [PAY4]
Local Mask POO0 [POO0]
Local Integer NBBAN
[L]NBBAN = max(1,dim([M:POO0]LIN))
Close Local Mask [POO0]
Local Mask VENTILE2 [VT2]
Local Integer NBRVTP, NBRPYA
[L]NBRVTP = max(1,dim([M:VT2]TBAMT))
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

Local Char    CRITPAM(255), CRITSAC(255), CRITCUR(255), CRIT_SOI(255), CRIT_DEP(255), CRITSAC_SOI(255)
Local Char    CRITERE1(255), CRITERE2(255), REGROUP(255), REGROUP_SOI(255), CRITSPE(255), CRITSPE_SOI(255)
Local Char    ORDSYS(200), SYMBOLE(40), TITTRA(50)
Local Char    BPCTYP(3), BPSTYP(3), RTZCUR(3), COMPTLOT(GLONANM), COMPTREG(GLONANM)
Local Char    SEP(5), TIERS(GLONBPR), NOREL(GLONVCR), DEP(10), COMPTE(GLONGAC), OPT(4) # Issue X3-48396
Local Char    IDENT(30) , ZONE(20), ABREV(5), TABLE(20), SAV_GDIV(1)
Local Char    TRA_CUR(GLONCUR), TRA_FCY(GLONFCY), TRA_TPY(GLONTPY), TRA_BAN(GLONBAN)
Local Char    OADXIRS(5), OADXIFS(5)
Local Char    DEVLED(GLONCUR) : # Devise du référentiel principal général (celui qui gère les échéances)
Local Char    DEVISE(GLONCUR)
Local Integer I, J, K, OK, INDTPY, FLAG, STAT, CAS, FBREAK, SIGN, GAIN, NUMLIN, PROP, DELAI, OKTCA
Local Integer RUPT_FCY , RUPT_BPR, OK_GRP
Local Integer NB, NBLMAX, NBLIGREG, NBENR
Local Integer AA, MM, JJ, TAB
Local Decimal TOTREG , TOTREGLOC , TOTPROP, RESTE, MNT, MNTCUR, MONT_ESC
Local Decimal ARQ, ARD, TAUX_ESC, MT, SMT, QTE, SQTE, SUMP, SUMPOI
Local Decimal EXE , PER, PYHAMTLOC, PYHAMTCUR, MTCUR, MTLOC
Local Char    POOBAN(GLONBAN)(1..[L]NBBAN), BAN(GLONBAN), DUDCUR(GLONCUR)
Local Char    IDT_LIN(5)
Local Decimal POOMTMAX(1..[L]NBBAN) , POOMTIMP(1..[L]NBBAN)
Local Date    DAT, TRA_DUDDAT
I=max(1,nbrecord([F:TPY]))
Local Char    LOTID(5)(I), LOTCOD(20)(I), EXT(3)
Local Char    CODCPT(GLONCAC)
Local Integer LOTX(I), NBLOT
Local Integer REMEFFESP, PARARGREC
Local Integer FLGADD
Local Integer INDLED, INDAXE, INDAXI, AXE, NLED, IND
Local Integer VU, SUIVI, AXI
Local Decimal COURS
Local Decimal EXERCICE, PERIODE
Local Char    DEPTAX(GLONVAT)

#Gestion du regroupement par code adresse
Local Integer OK_BPA

# Application du cours facture (DdM 27272)
If clalev([F:HAE3])=0 : Local File GACCENTRY   [HAE3] : Endif
Local Integer STATOK
Local Decimal WBQE

Local Char PAYGRPFCY(GLONFCY)(0..GDIMSIT)

Local Char OLDCCE(GLONCCE)(dim([F:PYA]CCE)-1)

Global Integer GCALL_PT : Raz GCALL_PT
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("PAYPROPAL",GENTSTD(1..GNBENTREE))
 GCALL_PT=1
Endif

#Variable for the parameter "DATDEP" that indicates if the discount is if based on
#due date or on invoice date
Local Char DISCBASE(1)
Local Char DEPMOD(10)

Global Integer GNBPLAN                               : # Nb de plans comptables (max 10)
Global Integer GNBAXE                                : # Nb d'axes à saisir (max 20)
Global Char    GPLAN(GLONCOA)(1..10)                 : # Plans (COA)
Global Char    GAXE(GLONDIE)(1..max(GOPTCANA,20))    : # Axes (DIE)
Global Integer GOBLIG(1..max(GOPTCANA,20))           : # Obligatoire (O/N)
Global Integer GTYPLED(1..10)                        : # Types référentiels

########  SAM REF# 76609 added by angre 05/31/12 ############################
#Parameter DATDEP indicates if Discount is based on due date or invoice date
#'1' => Due date
#else => Invoice date
#The parameter is needed to determine the correct Discount date in the
#function MATCHDISCOUNTTERMS in process PAYDEPLIB
#############################################################################
Call PARAM([M:DIA]CPY,"DATDEP",DISCBASE) From ADOVAL

Call PARAM([M:DIA]CPY,"DEPMGTMOD",DEPMOD) From ADOVAL
GDEPMGTMOD=val(DEPMOD)

# Localization Switzerland, 2015-05-21 Bader
If dim(GSWIPAYBVR) > 0 : GSWIPAYBVR = int(val(func AFNC.PARAM("SWIPAYBVR", [M:DIA]CPY))) : Endif
If dim(GSWIPAYQR)  > 0 : GSWIPAYQR  = int(val(func AFNC.PARAM("SWIPAYQR", [M:DIA]CPY))) : Endif
# End Localization Switzerland

If [M:DIA]ALLTPY<>2  :# 1 type de règlement
 I=1
Else
 I=max(1,nbrecord([F:TPY]))
Endif
Local Char    TABTPYCOD(GLONTPY)(1..I)
Local Integer TABTPYMAX(1..I)

#DdM36730
I=max(1,nbrecord([F:GTE]))
Local Char TTYPGTE(GLONGTE)(1..I) : # Table types pièces à prendre en cpte (flag Gestion des échéances")
Local Integer NBTYP               : # Nombre de types de pièces
#

# Recherche des process actifs
Local Char ORDSYS(250), SID(10) , SCLI(8) , SUID(20), SPID(30)

# Lock
## On contrôle qu'il n'y a pas un autre utilisateur qui est en train de lancer la proposition auto
## sur la même société et même(s) site(s)
Local Char    TSYMBOLE(50)(1..GNBSITE)
Local Integer INDLOCK, NBLOCK
NBLOCK = 0
If [M:DIA]ALLFCY<>2
 If GUSRFCY(1)="\" | find([M:DIA]FCY,GUSRFCY(1..GNBAUZ))
  NBLOCK=1
  TSYMBOLE(NBLOCK) = "PAYPROPAL\"+[M:DIA]FCY
  Lock =TSYMBOLE(NBLOCK) With lockwait=0
  If fstat
   # Opération en cours sur autre poste
   GERR=1 : GMESSAGE=mess(30,100,1)
   FIN=1 : Return
  Endif
 Endif
Else
 For [FCY]FCY0 Where LEGCPY=[M:DIA]CPY
  If GUSRFCY(1)="\" | find([F:FCY]FCY,GUSRFCY(1..GNBAUZ))
   NBLOCK+=1
   TSYMBOLE(NBLOCK) = "PAYPROPAL\"+[F:FCY]FCY
   Lock =TSYMBOLE(NBLOCK) With lockwait=0
   If fstat
    # Opération en cours sur autre poste
    GERR=1 : GMESSAGE=mess(30,100,1)
    FIN=1 : Break
   Endif
  Endif
 Next
 If FIN=1 : Return : Endif
Endif

## Lecture nécessaire de la société
Call LEC_CPY([M:DIA]CPY) From CPTLEC
If [F:CPY]MAIFCY<>""
 Call GETSOC([F:CPY]MAIFCY) From DEVSUB
Else
 GCURLEG = [F:CPY]LEG
 GSOCIETE = [F:CPY]CPY
Endif

## Dem 62598
GPOINT = "VERROU" : Gosub ENTREE From EXEFNC
If FIN : Return : Endif

# Proposition automatique (- Simulation)
Call TITAWI(BCRIT,TITTRA) From OBJDIV
If !GSERVEUR
 Call OUVRE_TRACE(TITTRA-string$([M:DIA]SIM=2,"-"-mess(27,107,1))) From LECFIC
Endif
If func AFNC.PARAM("SPADESVAL",[M:DIA]CPY) = "2" : REMEFFESP = 1 : Else : REMEFFESP = 0 : Endif
If func AFNC.PARAM("ARGREC",[M:DIA]CPY)="2" : PARARGREC = 1 : Else : PARARGREC = 0 : Endif : # Gestion Ordres de paiements/Recibos Argentines

# Destinations comptables des pièces comptables
Case [M:DIA]SNS
 When 1 : Call PARAM([M:DIA]CPY,"DENSPG",GDIV(0)) From ADOVAL     :# Dépense
 When 2 : Call PARAM([M:DIA]CPY,"DENTAK",GDIV(0)) From ADOVAL     :# Recette
Endcase

Call LEC_CDA_LEG([F:CPY]LEG,GDIV(0)) From CPTLEC
If fstat | GDIV(0)=""
 GMESSAGE = GDIV(0)
 If GMESSAGE=""
  Case [M:DIA]SNS
   When 1 : GMESSAGE = "DENSPG"
   When 2 : GMESSAGE = "DENTAK"
  Endcase
 Endif
 Gosub ERR_CDA
Endif
If [F:CDA]ACCTYP<>1 : GMESSAGE = mess(1,612,1) : Gosub ERR_ACCTYP : Endif
If [F:CDA]ACCSNS<>1 : GMESSAGE = mess(1,671,1) : Gosub ERR_ACCSNS : Endif
If [F:CDA]IPTDAC=1  : Gosub ERR_IPTDAC : Endif

# Destinations comptables des acomptes
If [M:DIA]INSFLG=2
 Case [M:DIA]SNS
  When 1 : Call PARAM([M:DIA]CPY,"DENINSSEN",GDIV(1)) From ADOVAL  :# Acompte émis
  When 2 : Call PARAM([M:DIA]CPY,"DENINSRCP",GDIV(1)) From ADOVAL  :# Acompte reçu
 Endcase
 Call LEC_CDA_LEG([F:CPY]LEG,GDIV(1)) From CPTLEC
 If fstat | GDIV(1)=""
  GMESSAGE = GDIV(1)
  Case [M:DIA]SNS
   When 1       : GMESSAGE = "DENINSSEN"
   When 2       : GMESSAGE = "DENINSRCP"
  Endcase
  Gosub ERR_CDA
 Endif
 If [F:CDA]ACCTYP<>1 : GMESSAGE = mess(1,612,1) : Gosub ERR_ACCTYP : Endif
 If [F:CDA]ACCSNS<>1 : GMESSAGE = mess(1,671,1) : Gosub ERR_ACCSNS : Endif
 If [F:CDA]IPTDAC=1  : Gosub ERR_IPTDAC : Endif
Endif

# Destinations comptables des escomptes
Case [M:DIA]SNS
 When 1 : Call PARAM([M:DIA]CPY,"DENPAY",GDIV(2)) From ADOVAL  # AP Discounts
 When 2 : Call PARAM([M:DIA]CPY,"DENDEP",GDIV(2)) From ADOVAL  # AR Discounts
Endcase
If GDIV(2)<>""
 Call LEC_CDA_LEG([F:CPY]LEG,GDIV(2)) From CPTLEC
 If fstat            : GMESSAGE = GDIV(2) : Gosub ERR_CDA : Endif
 If [F:CDA]ACCTYP<>3 : GMESSAGE = mess(3,612,1) : Gosub ERR_ACCTYP : Endif
 If [F:CDA]ACCCOD="" : Gosub ERR_CPT : Endif
 If [F:CDA]IPTDAC=1  : Gosub ERR_IPTDAC : Endif
Endif

# Destinations comptables des agios
Call PARAM([M:DIA]CPY,"DENCRG",GDIV(5)) From ADOVAL
If GDIV(5)<>""
 Call LEC_CDA_LEG([F:CPY]LEG,GDIV(5)) From CPTLEC
 If fstat            : GMESSAGE = GDIV(5) : Gosub ERR_CDA : Endif
 If [F:CDA]ACCTYP<>3 : GMESSAGE = mess(3,612,1) : Gosub ERR_ACCTYP : Endif
 If [F:CDA]ACCCOD="" : Gosub ERR_CPT : Endif : # GH 13/9/99 bug 3198
 If [F:CDA]IPTDAC=1  : Gosub ERR_IPTDAC : Endif
Endif
GMESSAGE=""

If GERR
 Gosub UNLCK_TSYM
 If !GSERVEUR
  Call FERME_TRACE From LECFIC
  TRA=1
 Endif
 GERR=0 : FIN=1 : Return
Endif

[L]SEP="+';'+"

# Autres paramètres

Call PARAM([M:DIA]CPY,"SOICPT",GDIV(4)) From ADOVAL : # Comptabilisation des relevés o/n (1-non & 2-oui)
Call PARAM([M:DIA]CPY,"SOISAC",GDIV(6)) From ADOVAL : # Relevé mono-collectif (1-mono & 2-multi)
Call PARAM("","RTZCUR",[L]RTZCUR) From ADOVAL : # Devise ritenzione
Call PARAM([M:DIA]CPY,"BPCORDTYP",[L]BPCTYP) From ADOVAL : # CCL
If [L]BPCTYP="" [L]BPCTYP="*SO" : Endif
Call PARAM([M:DIA]CPY,"BPSORDTYP",[L]BPSTYP) From ADOVAL : # CCF
If [L]BPSTYP="" [L]BPSTYP="*PO" : Endif
If dim(GSDDMGT)>0
 Call PARAM([M:DIA]CPY,"SDDMGT",OPT) From ADOVAL
 GSDDMGT=val(OPT)
Endif

Call LECTCA(3,OKTCA) From SUBTCA
If OKTCA : COMPTLOT = [F:TCA]CODNUM(6) : Endif : # Lots de saisie

#DdM36730 : Prise en compte uniquement des échéances flaguées "Gestion des échéances"
Raz NBTYP
Filter [GTE] Where LEG=[F:CPY]LEG| LEG="" Order By Key CLE=TYP Asc ; LEG Desc
For [GTE]CLE(1)
 If [F:GTE]DUDDATFLG=2
  NBTYP += 1
  TTYPGTE(NBTYP) = [F:GTE]TYP
 Endif
Next
Filter [GTE]
#

If [M:DI2]CTLFLG <> 2
 Call TEMPON("V") From GESECRAN
Else
 Call TEMPON("R") From GESECRAN
Endif

If [M:DIA]ACCDAT=[0/0/0]
 [M:DIA]ACCDAT = datesyst
Endif

If [M:DIA]ALLTPY<>2  :# 1 type de règlement
 Call LEC_TPY_LEG(GCURLEG,[M:DIA]TPY) From CPTLEC
Endif
# Filtres
Gosub CRITSAC
Gosub CRITCUR
Gosub FILTRE     : # Filtre sur échéances
Gosub FILTRE_SOI : # Filtre sur relevé
If [M:DIA]ALLPAM<>2
 [L]CRITPAM = "PAM='"+[M:DIA]PAM+"'"
Endif

# Site
Local Char CRITFCY(255)
CRITFCY = "1=1"
If [M:DIA]ALLFCY=1
 [L]CRITFCY -= "& FCY='"+[M:DIA]FCY+"'"
Endif

# Tri des tables
# Le site du règlement n'est pas connu à priori, on reprend celui dans l'échéance.
# Pour un règlement multi collectif, les OD inter tiers sont autorisées pour ce site ?
If [M:DIA]FCYPAY="" & [M:DIA]ALLFCY=2 & [M:DIA]PAYSAC<>2 & [M:DIA]PAYDUD<>2 & [M:DIA]SAC="" & [M:DIA]SACPAY=""
 [L]RUPT_FCY = 1
Else
 [L]RUPT_FCY = 0
Endif

# Pas de tiers précisé
# -> un contrôle de chaque tiers doit être fait dans les cas suivants :
# * Type de tiers demandé : contrôle du type du tiers
# * Banque saisie : contrôle de la banque du tiers (uniquement client et fournisseur)
# * Dépense : contrôle tiers non bloqué en paiement (uniquement fournisseur)
# * Collectif de règlement saisi et tous types de tiers : contrôle que le collectif
#   est compatible avec le type du tiers
# * Collectif de règlement non saisi, tous types de tiers et règlement multi
#   collectif : forcage règlement mono collectif si tiers autre que client
#   ou fournisseur
If [M:DIA]ALLBPR=2 &
&  ([M:DIA]ALLTYPBPR=1
&   or [M:DIA]BAN<>""
&   or [M:DIA]SNS=1
&   or ([M:DIA]ALLTYPBPR=2 & [M:DIA]SACPAY<>"")
&   or ([M:DIA]ALLTYPBPR=2 & [M:DIA]SACPAY="" & [M:DIA]PAYSAC<>2
&       & [M:DIA]PAYDUD<>2 & [M:DIA]SAC=""))
  [L]RUPT_BPR = 1
Else
  [L]RUPT_BPR = 0
Endif

Default Mask [M:DIA]
Call TOP_TRACE("PAYPROPAL",1,6,0,0)

# Mise à jour des tables temporaires
Call SETCUR(1,[M]CPY,DEVLED) From CPTDIV
Call SETPLAN([M]CPY,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV
#70442
Call DEBTRANS From GLOCK
If !clalev([F:TPD3])  : Local File TMPPAYDUD [TPD3] Order By Key CLE=UIDUSR : Endif
Gosub TR_PROCESS
#
Call DEBTRANS From GLOCK
Gosub TR
If GOK = 1
 If [M:DI2]CTLFLG = 2
  Call CTL_CRE_REG From SUBPAYC
 Endif
Endif

If GOK=1
 Gosub TAB_POO
 Openo
 ## Fermeture de la vraie trace, Ouverture de la trace de travail
 OADXIRS=adxirs : OADXIFS=adxifs : adxifs="" : adxirs=chr$(10)
 Openo filpath("TRA",GTRACE,"trw",0),0
 PROP=0 : TOTPROP=0 : GCLE=""
 # GRNA 18.08.11 - add sorting with Order By via Filter
 Gosub PAY_SORT From SUBPAYS

 #JOJAC - 2018-09-26 - X3-101273 - START
 Local Char TRACE(20)
 Local Integer STRING_LEN
 If GSERVEUR
  STRING_LEN = 0
  While left$(GTRACE,STRING_LEN) <> GTRACE : STRING_LEN+=1 : Wend
  TRACE = right$(GTRACE,STRING_LEN-10)
 Else
  TRACE = GTRACE
 Endif
 #JOJAC - 2018-09-26 - X3-101273 - END

 For [TP2] Where FLGCRE=2 & CPY=[M:DIA]CPY & evalue(CRITFCY) & UIDUSR=adxpid
  Call DEBTRANS From GLOCK
  Gosub TR2
  If GOK<1 : Break : Endif
 Next : # [TP2]
 Filter [TP2]  # GRNA 18.08.11

 Openo
 ## Tri + Transfert de trace de travail
 Case GOS(1)
  When "unix" : EXT = ""
  When "dos"  : EXT = "bat"
 Endcase
 If filinfo(filpath("!ebin","ae_sort",EXT,0),0)<0
  # Fichier inexistant : ae_sort
  Call ECR_TRACE(mess(101,100,1)-":|"-filpath("!ebin","ae_sort",EXT,0),1) From GESECRAN
 Else
  ORDSYS = "ae_sort"-filpath("TRA",GTRACE,"trw",0)-filpath("TRA",GTRACE,"tmp",0)
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
 Endif
 If filinfo(filpath("TRA",GTRACE,"tmp",0),0)>0
  Openi filpath("TRA",GTRACE,"tmp",0),0
 Else
  Openi filpath("TRA",GTRACE,"trw",0),0
 Endif
 Openo filpath("TRA",GTRACE,"tra",0),-1
 Rdseq GMESSAGE
 While fstat=0
  Wrseq right$(GMESSAGE,46) : # 35+10
  Rdseq GMESSAGE
 Wend
 Openi
 adxirs=OADXIRS : adxifs=OADXIFS
 ORDSYS = "ae_rm"-filpath("TRA",GTRACE,"trw",0)
 Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
 If filinfo(filpath("TRA",GTRACE,"tmp",0),0)>0
  ORDSYS = "ae_rm"-filpath("TRA",GTRACE,"tmp",0)
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
 Endif
 ##
 If !PROP
  # Rien à proposer
  Call ECR_TRACE("\"+mess(26,121,1),0) From GESECRAN
 Else
  Call ECR_TRACE(" ",0) From GESECRAN
  # Total Devise
  #JOJAC - 2018-09-26 - X3-101273 - START
  Filter [PYT] Where TRC=TRACE Order By Key CLE=CUR
  #Filter [PYT] Where TRC=GTRACE Order By Key CLE=CUR
  #JOJAC - 2018-09-26 - X3-101273 - END
  For [PYT]CLE(1)
   MT=0 : For [PYT]CLE : MT+=[F:PYT]AMTCUR : Next
   Call ECR_TRACE(mess(69,116,1)-mess(18,105,1)-[F:PYT]CUR-":"-num$(MT)-[F:PYT]CUR,0) From GESECRAN
  Next

  # Total Transaction
  #JOJAC - 2018-09-26 - X3-101273 - START
  Filter [PYT] Where TRC=TRACE Order By Key CLE=PAYTYP
  #Filter [PYT] Where TRC=GTRACE Order By Key CLE=PAYTYP
  #JOJAC - 2018-09-26 - X3-101273 - START
  For [PYT]CLE(1)
   MT=0 : For [PYT]CLE : MT+=[F:PYT]AMTLOC : Next
   Call ECR_TRACE(mess(69,116,1)-mess(3,871,1)-[F:PYT]PAYTYP-":"-num$(MT)-DEVLED,0) From GESECRAN
  Next

  # Total Site
  #JOJAC - 2018-09-26 - X3-101273 - START
  Filter [PYT] Where TRC=TRACE Order By Key CLE=FCY
  #Filter [PYT] Where TRC=GTRACE Order By Key CLE=FCY
  #JOJAC - 2018-09-26 - X3-101273 - END
  For [PYT]CLE(1)
   MT=0 : For [PYT]CLE : MT+=[F:PYT]AMTLOC : Next
   Call ECR_TRACE(mess(69,116,1)-mess(29,105,1)-[F:PYT]FCY-":"-num$(MT)-DEVLED,0) From GESECRAN
  Next

  # Total Echéance
  #JOJAC - 2018-09-26 - X3-101273 - START
  Filter [PYT] Where TRC=TRACE & DUDDAT<>[0/0/0] Order By Key CLE=DUDDAT
  #Filter [PYT] Where TRC=GTRACE & DUDDAT<>[0/0/0] Order By Key CLE=DUDDAT
  #JOJAC - 2018-09-26 - X3-101273 - END
  For [PYT]CLE(1)
   MT=0 : For [PYT]CLE : MT+=[F:PYT]AMTLOC : Next
   Call ECR_TRACE(mess(69,116,1)-mess(4,871,1)-format$(GFMD,[F:PYT]DUDDAT)-":"-num$(MT)-DEVLED,0) From GESECRAN
  Next

  # Total général
  #JOJAC - 2018-09-26 - X3-101273 - START
  Filter [PYT] Where TRC=TRACE
  #Filter [PYT] Where TRC=GTRACE
  #JOJAC - 2018-09-26 - X3-101273 - START
  MT=0
  For [PYT]PYT0
   MT+=[F:PYT]AMTLOC
  Next
  GMESSAGE=num$(MT)-DEVLED
  Call ECR_TRACE(mess(86,117,1)-":"-GMESSAGE,0) From GESECRAN
 Endif
 GMESSAGE=""
Endif


$F_PROPAL
Gosub TR_RAZ_TPD
Gosub TR_RAZ_TP2
Call TEMPOFF From GESECRAN
Gosub UNLCK_TSYM
If !GSERVEUR
 Call FERME_TRACE From LECFIC
 TRA=1
Endif
Return

$TR_PROCESS
GOK=1
ORDSYS = 'psadx -ix'
Local File (SID,SCLI,SUID,SPID) From System ORDSYS As [SYS_]

Trbegin [TPD]
 For [F:TPD3]CLE(1)
  OK  = 0
  For [SYS_]
   If instr(1,[F:SYS_]SPID,":")>0 & left$([F:SYS_]SPID,instr(1,[F:SYS_]SPID,":")-1)=num$([F:TPD3]UIDUSR)
    OK = 1
    Break
   Endif
  Next
  If !OK
   Delete [TPD] Where CPY=[M:DIA]CPY & UIDUSR=[F:TPD3]UIDUSR
   If fstat=1 | fstat>5
    GOK=-1 : GLOCK = "$TMPPAYDUD"
    Break
   Endif
   Delete [TP2] Where CPY=[M:DIA]CPY & UIDUSR=[F:TPD3]UIDUSR
   If fstat=1 | fstat>5
    GOK=-1 : GLOCK = "$TMPPAYDUD2"
    Break
   Endif
  Endif
 Next
 If GOK=-1
  Goto ROLL_TR_PROCESS
 Endif
Commit
Return

$ROLL_TR_PROCESS
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_PROCESS : Endif
Return

$SORTIE
Gosub UNLCK_TSYM
If dim(GCALL_PT)>0
 Kill GCALL_PT
Endif
Return

$UNLCK_TSYM
If dim(TSYMBOLE)>0
 For INDLOCK=1 To NBLOCK
  Unlock =TSYMBOLE(INDLOCK)
 Next
Endif
Return

$ERR_IPTDAC
# Destination comptable ... : Destination non imputable
Call ECR_TRACE(mess(40,121,1)-[F:CDA]COD+"\"+mess(60,117,1),1) From GESECRAN
GERR=1
Return

$ERR_ACCTYP
# Destination comptable ... : Le schéma de compte doit être
Call ECR_TRACE(mess(40,121,1)-[F:CDA]COD+"\"+mess(87,117,1)-GMESSAGE,1) From GESECRAN
GERR=1
Return

$ERR_ACCSNS
# Destination comptable ... : Sens comptable <>
Call ECR_TRACE(mess(40,121,1)-[F:CDA]COD+"\"+mess(471,200,1)-"<>"-GMESSAGE,1) From GESECRAN
GERR=1
Return

$ERR_CDA
# ... : Destination comptable non paramétrée
Call ECR_TRACE(GMESSAGE-":"-mess(88,117,1),1) From GESECRAN
GERR=1
Return

$ERR_CPT
# Destination comptable ... : Compte inexistant
Call ECR_TRACE(mess(40,121,1)-[F:CDA]COD+"\"+mess(44,102,1),1) From GESECRAN
GERR=1
Return

#################     Raz des tables temporaires    #####################

$TR_RAZ_TPD
GOK=1
Trbegin [TPD]
 Delete [TPD] Where CPY=[M:DIA]CPY & (UIDUSR=adxpid | UIDUSR=0)
 If fstat=1 | fstat>5
  #67365
  #GOK=2 : Call RSTA("TPD",[M:DIA]CPY) From GLOCK
  GOK=-1 : GLOCK = "$TMPPAYDUD"
  Goto ROLL_TR_RAZ_TPD
 Endif
Commit
Return

$TR_RAZ_TP2
GOK=1
Trbegin [TP2]
 Delete [TP2] Where CPY=[M:DIA]CPY & (UIDUSR=adxpid | UIDUSR=0)
 If fstat=1 | fstat>5
  #67365
  #GOK=2 : Call RSTA("TP2",[M:DIA]CPY) From GLOCK
  GOK=-1 : GLOCK = "$TMPPAYDUD2"
  Goto ROLL_TR_RAZ_TP2
 Endif
Commit
Return

$ROLL_TR_RAZ_TP2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_RAZ_TP2 : Endif
Return

$ROLL_TR_RAZ_TPD
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_RAZ_TPD : Endif
Return


$TR_RAZ_PYT
GOK=1
Trbegin [PYT]
 #JOJAC - 2018-09-26 - X3-101273 - START
 Delete [PYT] Where TRC=TRACE
 #Delete [PYT] Where TRC=GTRACE
 #JOJAC - 2018-09-26 - X3-101273 - START
 If fstat=1 | fstat>5
  #JOJAC - 2018-09-26 - X3-101273 - START
  GOK=2 : Call RSTA("PYT",TRACE) From GLOCK
  #GOK=2 : Call RSTA("PYT",GTRACE) From GLOCK
  #JOJAC - 2018-09-26 - X3-101273 - END
 Endif
Commit
Return

################   Transaction principale      #########################

$TR
#67365
GOK = 1
Trbegin [TPD] , [TP2] , [TPD2]
 # MAJ des tables temporaires
 Gosub TR_MAJ
 If GOK=-1 : Goto ROLL_TR
 Elsif !GOK : Goto AB_TR
 Endif

 # Flag des enregistrements OK
 Raz [L]TOTPROP   :# Total proposition
 Gosub TR_FLG
 If GOK=-1 : Goto ROLL_TR
 Elsif !GOK : Goto AB_TR
 Endif

Commit
Return

$ROLL_TR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else Goto TR : Endif

$AB_TR
Rollback : Return

############### Création des règlements #######################

$TR2
Raz [L]PYHAMTCUR, [L]PYHAMTLOC
GOK=1
Trbegin [PYH] , [PYD] , [PYA] , [DUD] , [BAN], [PYL]
Call LEC_TPY_LEG(GCURLEG,[F:TP2]PAYTYP) From CPTLEC
If PARARGREC=1 : # Gestion Ordres de paiements/Recibos Argentines
 Gosub CRE_PAH From PAYPROPAL3
Else
 Gosub CRE_REG From PAYPROPAL2
Endif
If GOK<0     : Goto ROLL_TR2
Elsif GOK<>1 : Goto AB_TR2
Endif
[L]PROP += 1
If [M:DIA]SIM<>2 : Commit : Else : Rollback : Endif

GOK=1
Trbegin [PYT]
 #JOJAC - 2018-09-26 - X3-101273 - START
 Read [PYT]PYT0 = TRACE;TRA_TPY;TRA_FCY;TRA_CUR;"";TRA_DUDDAT;[M:DIA]SNS
 #Read [PYT]PYT0 = GTRACE;TRA_TPY;TRA_FCY;TRA_CUR;"";TRA_DUDDAT;[M:DIA]SNS
 #JOJAC - 2018-09-26 - X3-101273 - END
 If fstat>2 : Raz [F:PYT] : Endif
 [F:PYT]AMTCUR += PYHAMTCUR
 [F:PYT]AMTLOC += PYHAMTLOC




 If [F:PYT]TRC=""
  #JOJAC - 2018-09-26 - X3-101273 - START
  [F:PYT]TRC    = TRACE
  #[F:PYT]TRC    = GTRACE
  #JOJAC - 2018-09-26 - X3-101273 - END
  [F:PYT]CUR    = TRA_CUR
  [F:PYT]FCY    = TRA_FCY
  [F:PYT]PAYTYP = TRA_TPY
  [F:PYT]DUDDAT = TRA_DUDDAT
  [F:PYT]SNS    = [M:DIA]SNS
  Write [PYT]
 Else
  Rewrite [PYT]
 Endif
 If fstat
  #67365
  #GOK=2 : Call FSTA("PYT") From GLOCK
  GOK=0 : Call FSTA("PYT") From GLOCK
  Rollback : Return
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else Goto TR2 : Endif

$AB_TR2
Rollback : Return

###############     MAJ de la table temporaire   #######################

$TR_MAJ
[L]INDTPY = 1
If [M:DIA]ALLTPY<>2  :# 1 type de règlement
 [L]OK=1
 Call LEC_TPY_LEG(GCURLEG,[M:DIA]TPY) From CPTLEC
 If [F:TPY]LEG<>"" & [F:TPY]LEG<>[F:CPY]LEG : [L]OK=0 : Else : [L]OK=1 : Endif
 Gosub CTLGFY
 If [L]OK
  Gosub NBLIGMAX
  If GOK=1
   If [M:DIA]ALLPAM=2
    Gosub CRITPAM  :# Filtre sur modes de règlement
   Endif
   If [L]OK : Gosub TRT_TPY : Endif
  Endif
 Endif
Else                :# Tous types de règlement
 Filter [TPY] Where LEG=[F:CPY]LEG | LEG="" Order By Key CLE=PAYTYP Asc ; LEG Desc
 For [TPY]CLE(1)
  [L]OK=1
  If [F:TPY]SNS<>[M:DIA]SNS | [F:TPY]PAYPPS<>2 | [F:TPY]BANCSH<>1 | [F:TPY]ENAFLG<>2 : [L]OK=0 : Endif
  If [L]OK
   Gosub CTLGFY
   If [L]OK
    If dim([F:TPY]ACS)>0
     Call CONTEXE([F:TPY]ACS) From CPTSUB
     If !mkstat : [L]OK=1 : Else mkstat=0 : [L]OK=0 : GMESSAGE="" : Endif
    Else
     [L]OK=1
    Endif
    If [L]OK
     Gosub NBLIGMAX
     If GOK<1 : Break : Else [L]INDTPY += 1 : Endif
     [L]OK=1
     If [M:DIA]ALLPAM=1
      If !find([M:DIA]PAM,[F:TPY]PAM) : [L]OK=0 : Endif
     Else
      Gosub CRITPAM  :# Filtre sur modes de règlement
     Endif
     If [L]OK
      Gosub TRT_TPY
      If GOK<1 : Break : Endif
     Endif
    Endif : # OK
   Endif : # OK
  Endif : # OK
  Next : # [TPY]
  Filter [TPY]
Endif
Return

# Nombre de lignes de règlement maxi pour un type de règlement
$NBLIGMAX
If clalev([M:PAY]) : Close Local Mask [PAY] : Endif
Onerrgo ERRMSKREG
#Local Mask ="WMPY1"+[F:TPY]PAYTYP [PAY]
Local Mask ="WMP1"+[F:TPY]PAYTYP+[F:TPY]LEG [PAY]
Onerrgo
If GERREUR : GOK=0 : GERREUR=0 : Return : Endif
If dim([M:PAY]NBLIG)<0
 If clalev([M:PAY]) : Close Local Mask [PAY] : Endif
 Onerrgo ERRMSKREG
 #Local Mask ="WMPY2"+[F:TPY]PAYTYP [PAY]
 Local Mask ="WMP2"+[F:TPY]PAYTYP+[F:TPY]LEG [PAY]
 Onerrgo
 If GERREUR : GOK=0 : GERREUR=0 : Return : Endif
 If dim([M:PAY]NBLIG)<0
  # Pas de ligne de règlement dans écran du type de règlement
  Call ECR_TRACE(mess(89,117,1)-[F:TPY]PAYTYP,1) From GESECRAN
  GOK=0 : Return
 Endif
Endif
If dim([M:PAY]LIN)<1
 # Pas de ligne de règlement dans écran du type de règlement
 Call ECR_TRACE(mess(89,117,1)-[F:TPY]PAYTYP,1) From GESECRAN
 GOK=0 : Return
Endif
[L]TABTPYCOD([L]INDTPY) = [F:TPY]PAYTYP
[L]TABTPYMAX([L]INDTPY) = dim([M:PAY]LIN)
Return

$ERRMSKREG
# Ecran non généré pour le type de règlement
GERREUR=errn
Call ECR_TRACE(mess(90,117,1)-[F:TPY]PAYTYP,1) From GESECRAN
Resume

$CTLGFY
Raz PAYGRPFCY
If [L]OK & [F:TPY]GFY<>""
 If [M:DIA]FCY<>""
  Look [FGR]FGR0=[F:TPY]GFY;[M:DIA]FCY
  If fstat : [L]OK=0 : Else : [L]OK=1 : Endif
  Return
 Else
  Look [AGC]AGC0=[F:TPY]GFY;[M:DIA]CPY
  If !fstat
   [L]OK=1 : Return
  Else
   # Groupe de sites paramétré dans le type de règlement
   # Critère de la proposition de règlement uniquement sur société
   [L]OK = 0
   I = 0
   For [FCY] Where LEGCPY=[M:DIA]CPY
    Look [FGR]FGR0=[F:TPY]GFY;[F:FCY]FCY
    If !fstat
     [L]OK = 1
     PAYGRPFCY(I) = [F:FCY]FCY
     I +=1
    Endif
   Next
  Endif
 Endif
Endif
Return

###################   Traitement d'un type de règlement ###########################

$TRT_TPY

[L]OK_BPA=0 : #init pour gestion adresse

# Pas de comptabilisation des relevés
# -> on traite les échéances intégrées dans le relevé
If !RUPT_FCY
 If [M:DIA]FCYPAY<>""  : Call PARAM([M:DIA]FCYPAY,"SEVBPRENT",GDIV(3)) From ADOVAL
 Elsif [M:DIA]ALLFCY=1 : Call PARAM([M:DIA]FCY,"SEVBPRENT",GDIV(3)) From ADOVAL
 Else GDIV(3)="2"      : # si [M:DIA]SAC<>"" | [M:DIA]SACPAY<>""
 Endif
 [L]SAV_GDIV = GDIV(3)
 Gosub REGROUP
 Gosub REGROUP_SOI
Endif

If GDIV(4)="1"
 If GDIV(6)="2" : CRITSAC_SOI = "1=1" : Else CRITSAC_SOI = CRITSAC : Endif
 [L]CAS = 1
 If [L]RUPT_FCY
  If [L]RUPT_BPR
   Filter [SOI] Where evalue([L]CRIT_SOI) & evalue([L]CRITPAM)
&                   & evalue([L]CRITSAC_SOI) & evalue([L]CRITCUR) & evalue([L]CRITSPE_SOI)
&               Order By Key CLE=FCY;BPR
   For [SOI]CLE(1) :# Par site
    If PAYGRPFCY(0)="" | find([F:SOI]FCY,PAYGRPFCY)
    Call PARAM([F:SOI]FCY,"SEVBPRENT",GDIV(3)) From ADOVAL :# OD inter-tiers
    [L]SAV_GDIV = GDIV(3)
    Gosub REGROUP
    Gosub REGROUP_SOI
    For [SOI]CLE(2) :# Par tiers
     [L]OK=1 : [L]TIERS = [F:SOI]BPR
     Gosub VERIF_BPR
     If [L]OK
      If [L]SAV_GDIV="2" & [M:DIA]ALLTYPBPR=2
       # Dans le cas ou le tiers n'est ni client ni fournisseur et règlement
       # multi collectif -> 1 collectif / règlement
       If [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG<>2
        GDIV(3) = "1"
       Else
        GDIV(3) = "2"
       Endif
       Gosub REGROUP
       Gosub REGROUP_SOI
      Endif
      For [SOI]CLE
       [L]OK = 1 : Gosub VERIF_SOI
       If [L]OK
        Gosub TRT_SOI
        If GOK<1 : Break 3 : Endif
       Endif
      Next : # [SOI]
     Endif
    Next : # [SOI]
    Endif
   Next : # [SOI]
  Else
   Filter [SOI] Where evalue([L]CRIT_SOI) & evalue([L]CRITPAM)
&                   & evalue([L]CRITSAC_SOI) & evalue([L]CRITCUR) & evalue([L]CRITSPE_SOI)
&               Order By Key CLE=FCY
   For [SOI]CLE(1) :# Par site
    If PAYGRPFCY(0)="" | find([F:SOI]FCY,PAYGRPFCY)
    Call PARAM([F:SOI]FCY,"SEVBPRENT",GDIV(3)) From ADOVAL :# OD inter-tiers
    Gosub REGROUP
    Gosub REGROUP_SOI
    For [SOI]CLE
     [L]OK = 1 : Gosub VERIF_SOI
     If [L]OK
      ## Bug 14399 (CP : 24/05/02)
      [L]OK=1 : [L]TIERS = [F:SOI]BPR
      Gosub VERIF_BPR
      If [L]OK
       Gosub TRT_SOI
       If GOK<1 : Break 2 : Endif
      Endif
     Endif
    Next : # [SOI]
    Endif
   Next : # [SOI]
  Endif
 Else
  If [L]RUPT_BPR
   Filter [SOI] Where evalue([L]CRIT_SOI) & evalue([L]CRITPAM) & evalue([L]CRITSAC_SOI) & evalue([L]CRITCUR) & evalue([L]CRITSPE_SOI)
&               Order By Key CLE=BPR
   For [SOI]CLE(1) :# Par tiers
    If PAYGRPFCY(0)="" | find([F:SOI]FCY,PAYGRPFCY)
    [L]OK=1 : [L]TIERS = [F:SOI]BPR
    Gosub VERIF_BPR
    If [L]OK
     If [L]SAV_GDIV="2" & [M:DIA]ALLTYPBPR=2 & [M:DIA]SACPAY="" & [M:DIA]PAYSAC<>2 & [M:DIA]PAYDUD<>2 & [M:DIA]SAC=""
      # Dans le cas ou le tiers n'est ni client ni fournisseur et règlement
      # multi collectif -> 1 collectif / règlement
      If [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG<>2
       GDIV(3) = "1"
      Else
       GDIV(3) = "2"
      Endif
      Gosub REGROUP
      Gosub REGROUP_SOI
     Endif
     For [SOI]CLE
      [L]OK = 1 : Gosub VERIF_SOI
      If [L]OK
       Gosub TRT_SOI
       If GOK<1 : Break 2 : Endif
      Endif
     Next : # [SOI]
    Endif
    Endif
   Next : # [SOI]
  Else
   Filter [SOI] Where evalue([L]CRIT_SOI) & evalue([L]CRITPAM)
&                   & evalue([L]CRITSAC_SOI) & evalue([L]CRITCUR) & evalue([L]CRITSPE_SOI)
   For [SOI] With Nohint
    If PAYGRPFCY(0)="" | find([F:SOI]FCY,PAYGRPFCY)
    [L]OK = 1 : Gosub VERIF_SOI
    If [L]OK
     ## Bug 14399 (CP : 24/05/02)
     [L]OK=1 : [L]TIERS = [F:SOI]BPR
     Gosub VERIF_BPR
     If [L]OK
      Gosub TRT_SOI
      If GOK<1 : Break : Endif
     Endif
    Endif
    Endif
   Next : # [SOI]
  Endif
 Endif
 Filter [SOI]
 If GOK<1 : Return : Endif
Endif

# Echéances hors relevé
[L]CAS = 2

If [L]RUPT_FCY
 If [L]RUPT_BPR
  ## Optimisation recherche des échéances non soldées par index DUD3
  Filter [DUD] Where evalue([L]CRITERE1) & evalue([L]CRITERE2) & evalue([L]CRITPAM)
&                  & evalue([L]CRITSAC) & evalue([L]CRITCUR) & evalue([L]CRITSPE)
  For [DUD]DUD3(2)     :# Par site
   If PAYGRPFCY(0)="" | find([F:DUD]FCY,PAYGRPFCY)
   Call PARAM([F:DUD]FCY,"SEVBPRENT",GDIV(3)) From ADOVAL :# OD inter-tiers
   [L]SAV_GDIV = GDIV(3)

   For [DUD]DUD3(3)     :# Par tiers
    [L]OK=1 : [L]TIERS = [F:DUD]BPRPAY

    Gosub VERIF_BPR
    Gosub REGROUP
    Gosub REGROUP_SOI

    If [L]OK
     If [L]SAV_GDIV="2" & [M:DIA]ALLTYPBPR=2
      # Dans le cas ou le tiers n'est ni client ni fournisseur et règlement
      # multi collectif -> 1 collectif / règlement
      If [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG<>2
       GDIV(3) = "1"
      Else
       GDIV(3) = "2"
      Endif
      Gosub REGROUP
      Gosub REGROUP_SOI
     Endif
     For [DUD]DUD3 With Nohint
      Gosub MAJ_TPD
      If GOK<1 : Break 3 : Endif
     Next : # [DUD]
    Endif
    [L]OK_BPA=0 : # reinit pour gestion adresse
   Next : # [DUD]
   Endif
  Next : # [DUD]

 Else

  Filter [DUD] Where evalue([L]CRITERE1) & evalue([L]CRITERE2) & evalue([L]CRITPAM)
&                  & evalue([L]CRITSAC) & evalue([L]CRITCUR) & evalue([L]CRITSPE)

  For [DUD]DUD3(2)     :# Par site
   If PAYGRPFCY(0)="" | find([F:DUD]FCY,PAYGRPFCY)

   Call PARAM([F:DUD]FCY,"SEVBPRENT",GDIV(3)) From ADOVAL :# OD inter-tiers

   For [DUD]DUD3
    ## Bug 14399 (CP : 24/05/02)
    [L]OK=1 : [L]TIERS = [F:DUD]BPRPAY
    Gosub VERIF_BPR
    Gosub REGROUP
    Gosub REGROUP_SOI

    If [L]OK

     Gosub MAJ_TPD
     If GOK<1 : Break 2 : Endif
    Endif
    [L]OK_BPA=0 : #reinit pour gestion adresse
   Next : # [DUD]

   Endif
  Next
 Endif : # [DUD]

Else

 If [L]RUPT_BPR

  Filter [F:DUD] Where evalue([L]CRITERE1) & evalue([L]CRITERE2) & evalue([L]CRITPAM)
&                    & evalue([L]CRITSAC) & evalue([L]CRITCUR) & evalue([L]CRITSPE)
&                Order By Key CLE=FLGCLE;BPRPAY

  For [DUD]CLE(2)    :# Par tiers
   If PAYGRPFCY(0)="" | find([F:DUD]FCY,PAYGRPFCY)

   [L]OK=1 : [L]TIERS = [F:DUD]BPRPAY

   Gosub VERIF_BPR
   Gosub REGROUP
   Gosub REGROUP_SOI

   If [L]OK
    If [L]SAV_GDIV="2" & [M:DIA]ALLTYPBPR=2
&      & [M:DIA]SACPAY="" & [M:DIA]PAYSAC<>2 & [M:DIA]PAYDUD<>2 & [M:DIA]SAC=""
     # Dans le cas ou le tiers n'est ni client ni fournisseur et règlement
     # multi collectif -> 1 collectif / règlement
     If [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG<>2
      GDIV(3) = "1"
     Else
      GDIV(3) = "2"
     Endif
     Gosub REGROUP
     Gosub REGROUP_SOI
    Endif
    For [DUD]CLE With Nohint

     Gosub MAJ_TPD
     If GOK<1 : Break 2 : Endif
    Next : # [DUD]
   Endif

   [L]OK_BPA=0 : #reinit pour gestion adresse
   Endif
  Next : # [DUD]

 Else

  Filter [DUD] Where evalue([L]CRITERE1) & evalue([L]CRITERE2) & evalue([L]CRITPAM)
&                  & evalue([L]CRITSAC) & evalue([L]CRITCUR) & evalue([L]CRITSPE)
  For [DUD]DUD3
   If PAYGRPFCY(0)="" | find([F:DUD]FCY,PAYGRPFCY)

   ## Bug 14399 (CP : 24/05/02)
   [L]OK=1 : [L]TIERS = [F:DUD]BPRPAY

   Gosub VERIF_BPR
   Gosub REGROUP
   Gosub REGROUP_SOI

   If [L]OK

    Gosub MAJ_TPD
    If GOK<1 : Break : Endif
   Endif
   [L]OK_BPA=0 : #reinit pour gestion adresse
   Endif
  Next : # [DUD]

 Endif

Endif
Filter [DUD]
If GOK<1 : Return : Endif
Return


$VERIF_BPR
Call LEC_BPR([L]TIERS) From CPTLEC
If [M:DIA]ALLTYPBPR=1 :# Contrôle type de tiers
 Case [M:DIA]TYPBPR
  When 1 : If [F:BPR]BPCFLG<>2 : [L]OK = 0 : Endif  :# Client
  When 2 : If [F:BPR]BPSFLG<>2 : [L]OK = 0 : Endif  :# Fournisseur
  When 3 : If [F:BPR]BPTFLG<>2 : [L]OK = 0 : Endif  :# Transporteur
  When 4 : If [F:BPR]FCTFLG<>2 : [L]OK = 0 : Endif  :# Factor
  When 5 : If [F:BPR]REPFLG<>2 : [L]OK = 0 : Endif  :# Représentant
  When 6 : If [F:BPR]BPRACC<>2 : [L]OK = 0 : Endif  :# Tiers divers
 Endcase
Endif
If ![L]OK : Return : Endif

# Vérification que le type du tiers est autorisé pour le collectif saisi
If [M:DIA]ALLTYPBPR=2 & [M:DIA]SACPAY<>""
 Read [GAC]GAC1 = [M:DIA]COA;[M:DIA]SACPAY
 OK  = [F:BPR]BPCFLG=2 & [F:GAC]AUZBPR(0)=2
 OK += [F:BPR]BPSFLG=2 & [F:GAC]AUZBPR(1)=2
 OK += [F:BPR]BPTFLG=2 & [F:GAC]AUZBPR(2)=2
 OK += [F:BPR]FCTFLG=2 & [F:GAC]AUZBPR(3)=2
 OK += [F:BPR]REPFLG=2 & [F:GAC]AUZBPR(4)=2
 OK += [F:BPR]BPRACC=2 & [F:GAC]AUZBPR(5)=2
 If ![L]OK : Return : Else : [L]OK=1 : Endif
Endif

# Une banque a été saisie dans les paramètres de génération
# -> Il faut prendre uniquement les tiers n'ayant pas de banque rattachée
#    ou dont la banque est la même que celle saisie
# OK_BPA updated to group payments by address code
If [M:DIA]ALLTYPBPR=2 :# Tous types de tiers
 If [F:BPR]BPCFLG=2 & [F:BPR]BPSFLG=1    : [L]OK = 2 :# Client
 Elsif [F:BPR]BPCFLG=1 & [F:BPR]BPSFLG=2 : [L]OK = 3 :# Fournisseur
 Elsif [F:BPR]BPCFLG=2 & [F:BPR]BPSFLG=2 : Case [M:DIA]SNS
                                            When 1 : [L]OK = 3 :# Dépense -> Fournisseur
                                            When 2 : [L]OK = 2 :# Recette -> Client
                                           Endcase
 Endif
Else Case [M:DIA]TYPBPR
      When 1 : [L]OK = 2
      When 2 : [L]OK = 3
     Endcase
Endif

If find([L]OK,2,3)
 Case [L]OK
  When 2    :# Client
   Call LEC_BPC([L]TIERS) From CPTLEC
   [L]BAN = [F:BPC]PAYBAN
   If [F:BPC]BPCTYP=1 : [L]OK_BPA = 1 : Endif : # Client de type normal pour gestion adresse
  When 3    :# Fournisseur
   Call LEC_BPS([L]TIERS) From CPTLEC
   [L]BAN = [F:BPS]PAYBAN
   If [F:BPS]BPSTYP=1 : [L]OK_BPA = 1 : Endif : # Fournisseur de type normal pour gestion adresse
 Endcase
 # Une banque a été saisie dans les paramètres de génération
 # -> Il faut prendre uniquement les tiers n'ayant pas de banque rattachée
 #    ou dont la banque est la même que celle saisie
 If [M:DIA]BAN<>"" & [L]BAN<>"" & [M:DIA]BAN<>[L]BAN
  [L]OK = 0 : Return
 Else
  [L]OK = 1
 Endif
Endif

# Dépense : contrôle fournisseur non bloqué en paiement
If [M:DIA]SNS=1 & [F:BPR]BPSFLG=2
 Call LEC_BPS([L]TIERS) From CPTLEC
 If fstat<=2 & [F:BPS]PAYLOKFLG=2
  [L]OK = 0 : Return
 Endif
Endif

If GCALL_PT
 GPOINT = "CTLPAYBPR" : Gosub ENTREE From EXEFNC
 If [L]OK=0 : Return : Endif
Endif
Return


$VERIF_SOI
# Montant maximum d'échéance
If [M:DIA]DUDMNTMAX<>0
 If [F:SOI]CUR<>[F:CPY]ACCCUR
  Call CONVERT([F:SOI]CUR,DEVLED,DEVLED,[F:TPY]RATTYP,
&              [F:SOI]SOIDAT,[F:SOI]AMTCUR,[L]MNT,[L]STAT) From TRTDEV
 Else
  [L]MNT = [F:SOI]AMTCUR
 Endif
 If [L]MNT>[M:DIA]DUDMNTMAX : [L]OK = 0 : Endif
Endif
Return

$TRT_SOI
# Suggestion 14203 (CP : 11/04/03)
# Escomptes jusqu'à ...
If [M:DIA]DATDEP<>[0/0/0]
 # Echéances sans code escompte/agio
 [L]CRIT_DEP = "((DEP=''"
 If [M:DIA]DATMIN<>[0/0/0] :  [L]CRIT_DEP -= "& DUDDAT>=["+format$(GFMD,[M:DIA]DATMIN)+"]" : Endif
 If [M:DIA]DATMAX<>[0/0/0] :  [L]CRIT_DEP -= "& DUDDAT<=["+format$(GFMD,[M:DIA]DATMAX)+"]" : Endif
 [L]CRIT_DEP -= ")"

 # Echéances avec code escompte/agio
 [L]CRIT_DEP -= "| (DEP<>''"
 If [M:DIA]DATMIN<>[0/0/0] : [L]CRIT_DEP -= "& DUDDAT>=["+format$(GFMD,[M:DIA]DATMIN)+"]" : Endif

 If [M:DIA]DATDEP<[M:DIA]DATMAX
  [L]CRIT_DEP -= "& DUDDAT<=["+format$(GFMD,[M:DIA]DATMAX)+"]))"
 Else
  [L]CRIT_DEP -= "& DUDDAT<=["+format$(GFMD,[M:DIA]DATDEP)+"]))"
 Endif
#Else
# Déjà fait dans le filtre CRIT_SOI
Endif
If CRIT_DEP="" : CRIT_DEP="1=1" : Endif

Filter [DUD] Where SOINUM=[F:SOI]SOINUM & BPRFCT='' & FLGCLE=1  & evalue(CRIT_DEP)
For [DUD]DUD2
 Gosub MAJ_TPD
 If GOK<1 : Break : Endif
Next : # [DUD]
Filter [DUD]
Return

##  Constitution de la table temporaire
$MAJ_TPD
########  SAM REF# 76609 added by angre 05/31/12  #####################################################################################
#check if the open item matches the 'Discount date from/to' criteria in the 'Discount' section of the payment proposal screen
#if not the open item will not be written in the temporary table and therefore it will not take into account for proposal.
#
#angre 07/26/12 a new parameter [F:DUD]BPRTYP is added.
##############################################################################################################################
If func PAYDEPLIB.MATCHDISCOUNTTERMS([M:DIA]DATSELMODE, [F:DUD]DEP, [F:DUD]DUDDAT, [F:DUD]NUM, [F:DUD]TYP, [F:DUD]BPRTYP, [L]DISCBASE) <> 1 Then : Return : Endif



# Vérif que cette échéance n'a pas déjà été enregistrée
# pour un autre type de règlement
Read [F:TPD]TPD1=[F:DUD]ACCNUM;[F:DUD]DUDLIG
If !fstat : Return : Endif

# Bug 12901 : vérifier que l'échéance n'est pas en cours de lettrage,
# pour ne pas la régler une 2eme fois
Filter [MTB] Where ACCNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
Look [MTB]MTB0 First   :# peu d'enreg
Filter [MTB]
If !fstat
 # Echéance en cours de lettrage
 Call ECR_TRACE([F:DUD]TYP-[F:DUD]NUM-num$([F:DUD]LIG)-num$([F:DUD]DUDLIG)-":"-mess(70,119,1),1) From GESECRAN
 Return
Endif

If [M:DIA]SIM=1
 # Lock de la pièce
 SYMBOLE = "HAE"+num$([F:DUD]NUM)+"\"+num$([F:DUD]TYP)
 Lock =SYMBOLE
 If fstat
  # Pièce verouillée : non prise en compte
  Call ECR_TRACE([F:DUD]TYP-[F:DUD]NUM-mess(91,117,1),0) From GESECRAN
  Return
 Endif
Endif
If [F:DUD]DUDSTA=2
 If [F:HAE]TYP<>[F:DUD]TYP or [F:HAE]NUM<>[F:DUD]NUM
  Read [HAE]HAE0 = [F:DUD]TYP;[F:DUD]NUM
  If fstat : Return : Endif
 Endif


# SAM #110081 angre 21.01.2016
 #original code begin
  #If [F:HAE]FLGREP=2 | left$([F:HAE]REFINT,3)="PYH" | left$([F:HAE]REFINT,3)="FRM" | [F:HAE]CAT<>1 : Return : Endif
 #original code end

 #new code begin
 #get parameter PAYUNALL (local menu #1)
   Local Char PAYUNALL(1)
   Call PARAM([M:DIA]CPY,"PAYUNALL",PAYUNALL) From ADOVAL
   #if parameter set to no
   If PAYUNALL <> "2"
      If left$([F:HAE]REFINT,3)="PYH" | left$([F:HAE]REFINT,3)="FRM" : Return : Endif
   Else
      Read [F:GAC]GAC1 = [M:DIA]COA;[F:DUD]SAC
      If !fstat
        If [F:GAC]FLGVAT = 5 : Return : Endif
      Endif
   Endif
  If [F:HAE]CAT<>1 | [F:HAE]FLGREP=2 : Return : Endif
  #new code end


 If !find([F:DUD]TYP,TTYPGTE(1..NBTYP)) : Return : Endif #DdM36730
Endif

If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]EPACDTTRF=2 & [F:TPY]SNS=2 & [F:DUD]UMRNUM<>""
 If [F:MDT]UMRNUM<>[F:DUD]UMRNUM | [F:MDT]CPY<>[F:DUD]CPY
  Read [MDT]MDT0 = [F:DUD]CPY;[F:DUD]UMRNUM
 Endif
 If fstat or [F:MDT]STA<>2 : Return : Endif
Endif

Raz [F:TPD]
Raz MTCUR
Case [F:TPY]SNS
 When 1  :# Dépense
  MTCUR = -([F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR)*[F:DUD]SNS
  MTLOC =  ([F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC)*[F:DUD]SNS
 When 2  :# Recette
  MTCUR =  ([F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR)*[F:DUD]SNS
  MTLOC = -([F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC)*[F:DUD]SNS
 When 3  :# Indéterminé
  Case [M:DIA]SNS
   When 1 :
      # Dépense
      MTCUR = -([F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR)*[F:DUD]SNS
      MTRPT =  ([F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC)*[F:DUD]SNS
   When 2 :
      # Recette
      MTCUR =  ([F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR)*[F:DUD]SNS
      MTRPT = -([F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC)*[F:DUD]SNS
  Endcase
Endcase

# PRD04B.sn
Raz [M:DIA]DISDAT
If [F:DUD]DEP <> '' # Issue X3-29143
  [M:DIA]DISDAT = func PAYDEPLIB3.SETDISDAT([M:DI2]ACCDAT)
Endif # Issue X3-29143
Affzo [M:DIA]DISDAT

[F:TPD]DISDAT = [M:DIA]DISDAT
# PRD04B.en

[F:TPD]AMTCUR = MTCUR
[F:TPD]AMTLOC = MTLOC
[F:TPD]PAYTYP = [F:TPY]PAYTYP
[F:TPD]ACCNUM = [F:DUD]ACCNUM
[F:TPD]DUDLIG = [F:DUD]DUDLIG
[F:TPD]CPY    = [M:DIA]CPY
[F:TPD]FCY    = [F:DUD]FCY
DUDCUR = [F:DUD]CUR
If [M:DIA]CURPAY<>DUDCUR & DUDCUR<>GEURO
 Call LEC_TCU(DUDCUR) From CPTLEC
 If [F:TCU]EURFLG=2 : DUDCUR = GEURO : Endif
Endif
Case [L]CAS
 When 1  :# Relevé
  [F:TPD]GRPCRI = evalue([L]REGROUP_SOI)
  [F:TPD]DUDDAT = [F:SOI]DUDDAT
 When 2  :# Echéance seule
  [F:TPD]GRPCRI = evalue([L]REGROUP)
  [F:TPD]DUDDAT = [F:DUD]DUDDAT
Endcase
If dim([M:PAY]RITAMT)>0
 GPE = 0
 GPOINT = "UPDAMTRTZ" : Gosub ENTREE From EXEFNC
 If !GPE
  Read [TPD2]TPD1(1) = [F:DUD]ACCNUM
  If fstat
   Filter [PIH] Where GTE=[F:DUD]TYP
   Read [PIH]PIH0 = [F:DUD]NUM
   Filter [PIH]
   If fstat=0
    For I=0 To [F:PIH]RITNBR-1
     Call LECTURE("RTZ",[F:PIH]RITCOD(I),"") From CONTOBJ
     If fstat=0 & [F:RTZ]TYP=1 & [F:RTZ]COE1<>0 : # Retenues sur règlement
      MNT = ([F:PIH]RITAMT(I)-[F:PIH]RITAMTDED(I))*[F:RTZ]COE1/([F:RTZ]COE1+[F:RTZ]COE2)
      Call ARRDEV(MNT,[L]RTZCUR) From TRTDIV
      [F:TPD]RITAMT += MNT
     Endif
    Next I
    If ([F:TPD]RITAMT<>0 | [F:CPY]RTZFLG=2) & ([F:PIH]STA<3 | [F:PIH]RITPAY<>"") : Return : Endif
   Endif
   If [F:TPD]RITAMT<>0
    If [F:TPY]DUDFLG=2 & [F:TPY]STA3<>2 & [F:TPY]STA8<>2 : DAT = [F:TPD]DUDDAT
    Else                                                 : DAT = [M:DIA]ACCDAT
    Endif
    If [F:DUD]CUR=[L]RTZCUR : [F:TPD]RITCUR=[F:TPD]RITAMT
    Else
     Call CONVERT([L]RTZCUR,[F:DUD]CUR,DEVLED,[F:TPY]RATTYP,DAT,[F:TPD]RITAMT,[F:TPD]RITCUR,I) From TRTDEV
    Endif
    If DEVLED=[L]RTZCUR     : [F:TPD]RITLOC=[F:TPD]RITAMT
    Elsif DEVLED=[F:DUD]CUR : [F:TPD]RITLOC=[F:TPD]RITCUR
    Else
     Call CONVERT([L]RTZCUR,DEVLED,DEVLED,[F:TPY]RATTYP,DAT,[F:TPD]RITAMT,[F:TPD]RITLOC,I) From TRTDEV
    Endif
    Case [F:TPY]SNS
     When 1  :# Dépense
      [F:TPD]AMTCUR += [F:TPD]RITCUR*[F:DUD]SNS
      [F:TPD]AMTLOC +=-[F:TPD]RITLOC*[F:DUD]SNS
     When 2  :# Recette
      [F:TPD]AMTCUR +=-[F:TPD]RITCUR*[F:DUD]SNS
      [F:TPD]AMTLOC += [F:TPD]RITLOC*[F:DUD]SNS
    Endcase
   Endif
  Endif
 Endif
Endif
If [M:DI2]CTLFLG = 2
 [F:TPD]FLGCRE = 1
Else
 [F:TPD]FLGCRE = 2
Endif
[F:TPD]UIDUSR = adxpid

# GRNA 02.08.11
[F:TPD]BPR = [F:DUD]BPRPAY

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
If func AFNC.ACTIV("KPO") & func AFNC.PARAM("PORVAT",[F:DUD]FCY) = "2"
  If [F:DUD]BPRTYP = 1
    If func PORLEGLIB.VAL_BPC_CASHVAT([F:DUD]BPRPAY,[F:HAE]ACCDAT) = 2
      Return
    Endif
  Endif
Endif
#94635 RICAR 2014/04/21 - CASH VAT - END

GPE = 0
GPOINT = "BEFWRITPD" : Gosub ENTREE From EXEFNC
If GPE : Return : Endif

Write [TPD]
If fstat
 GOK=0 : Call FSTA("TPD") From GLOCK
Endif : # [L]OK
Return

####################     Flag des échéances OK    #######################

$TR_FLG
If [M:DIA]MNTMAX  :# Montant maximum de la proposition
 [L]FBREAK = 0
 If [M:DIA]POO<>"" & [M:DIA]ALLMOD=2  :# Priorité gros montants
  Filter [TPD] Where CPY=[M:DIA]CPY & FLG=0 & evalue(CRITFCY) & UIDUSR=adxpid Order By Key TPD2
 Else                                 :# Priorité Date d'échéance
  Filter [TPD] Where CPY=[M:DIA]CPY & FLG=0 & evalue(CRITFCY) & UIDUSR=adxpid Order By Key TPD3
 Endif
 # Bug 13303 : si mnt maxi renseigné, le Read Next ne trouvait plus rien suite au 1er Rewrite
 For [TPD]
  Gosub FLG_TPD
  If GOK<1 | [L]FBREAK : Break : Endif
 Next
 Filter [TPD]

Else : # Pas de montant maxi de proposition : # GH bug 4234 15/02/00

 For [TPD]TPD0(2) Where CPY=[M:DIA]CPY & FLG=0 & evalue(CRITFCY) & UIDUSR=adxpid :# ------> Par type de règlement
  [L]INDTPY = find([F:TPD]PAYTYP,[L]TABTPYCOD)
  For [TPD]TPD0(3)  :# ------> Par critère de regroupement
   Raz TOTREG, TOTREGLOC, NBLIGREG : [L]FLAG=1
   [L]OK=1
   # N° de relevé éventuel
   [F:TP2]GRPCRI = [F:TPD]GRPCRI
   Call ELEMNO(";",5,[L]NOREL) From PAYPROPAL2
   For [TPD]TPD0      :# ------> Par échéance du regroupement
    If NBLIGREG=[L]TABTPYMAX([L]INDTPY) :# max de lignes
     # Trop d'échéances à régler pour le regroupement
     Call ECR_TRACE(mess(105,121,1)-[F:TPD]PAYTYP+";"+[F:TPD]GRPCRI,1) From GESECRAN
     [L]OK = 0 : Break
    Endif
    [L]TOTREG    += [F:TPD]AMTCUR
    [L]TOTREGLOC -= [F:TPD]AMTLOC
    [L]NBLIGREG  += 1
   Next : # [TPD]
   If [L]OK
    Gosub MARQ_TPD
    If GOK<1 : Break 2 : Endif
   Endif
  Next  :# Regroupement
 Next  :# Type de règlement
Endif
Return

## Balayage table tempo par priorité
$FLG_TPD
[L]MNTCUR = -[F:TPD]AMTLOC
If [L]TOTPROP + [L]MNTCUR > [M:DIA]MNTMAX  :# Montant maxi atteint
 [L]FBREAK=1 : Return
Endif
# N° de relevé éventuel
[F:TP2]GRPCRI = [F:TPD]GRPCRI
Call ELEMNO(";",5,[L]NOREL) From PAYPROPAL2
If [L]NOREL<>"" | [M:DIA]PAYDUD=1
 [L]OK     = 1
 [L]INDTPY = find([F:TPD]PAYTYP,[L]TABTPYCOD) :# Pour nb lignes maxi

 # Recherche flag
 Raz [L]NB , MNT : [L]FLAG = 1
 If [L]NOREL=""
  Filter [TP2] Where CPY=[M:DIA]CPY & PAYTYP=[F:TPD]PAYTYP & GRPCRI=[F:TPD]GRPCRI & evalue(CRITFCY) & UIDUSR=adxpid
  Read [TP2]TP20 Last
  If fstat=0
   If [F:TP2]NBR=[L]TABTPYMAX([L]INDTPY) :# Nb lignes max
    [L]FLAG += 1
   Else
    [L]FLAG      = [F:TP2]FLG
    [L]NB        = [F:TP2]NBR
    [L]MNT       = -[F:TP2]AMTLOC
   Endif
  Endif
  Filter [TP2]
 Endif

 # Montant minimum de règlement non atteint ou règlement<=0 ou relevé
 If ([M:DIA]PAYMNTMIN & ([L]MNTCUR+[L]MNT<[M:DIA]PAYMNTMIN)) |
&   ([L]MNTCUR+[L]MNT<=0) | NOREL<>""
  If [L]NB+1 = [L]TABTPYMAX([L]INDTPY)  :# Nb lignes max -> KO
   [L]OK = 0 : Return  :# :# Nb lignes max -> KO
  Endif
  Raz [L]TOTREGLOC, NBLIGREG
  If [L]NOREL<>""
   Filter [F:TPD2] Where CPY=[M:DIA]CPY & PAYTYP=[F:TPD]PAYTYP & GRPCRI=[F:TPD]GRPCRI & evalue(CRITFCY) & FLG=0 & UIDUSR=adxpid
&                  Order By Key TPD0
  Elsif [M:DIA]POO<>"" & [M:DIA]ALLMOD=2  :# Priorité gros montants
   Filter [F:TPD2] Where CPY=[M:DIA]CPY & PAYTYP=[F:TPD]PAYTYP & GRPCRI=[F:TPD]GRPCRI & evalue(CRITFCY) & FLG=0 & UIDUSR=adxpid
&                  Order By Key TPD2
  Else
   Filter [TPD2] Where CPY=[M:DIA]CPY & PAYTYP=[F:TPD]PAYTYP & GRPCRI=[F:TPD]GRPCRI & evalue(CRITFCY) & FLG=0 & UIDUSR=adxpid
&                Order By Key TPD3
  Endif
  For [TPD2]
   If !([TPD2]ACCNUM=[F:TPD]ACCNUM & [TPD2]DUDLIG=[F:TPD]DUDLIG)
    [L]TOTREGLOC -= [F:TPD2]AMTLOC
    [L]NBLIGREG  += 1
    If ([L]TOTPROP+[L]MNTCUR+[L]TOTREGLOC>[M:DIA]MNTMAX) |
&      ( ([L]NB+1+[L]NBLIGREG=[L]TABTPYMAX([L]INDTPY)) &
&      ([L]MNTCUR+[L]TOTREGLOC+[L]MNT<[M:DIA]PAYMNTMIN
&        | [L]MNTCUR+[L]TOTREGLOC+[L]MNT<=0) )
     [L]OK=0 : Break   :# Montant max dépassé ou nb lignes max atteint
    Elsif [L]NOREL="" & ([L]MNTCUR+[L]TOTREGLOC+[L]MNT>=[M:DIA]PAYMNTMIN)
&         & ([L]MNTCUR+[L]TOTREGLOC+[L]MNT>0)
     Break             :# Montant mini atteint
    Endif
   Endif
  Next : # [TPD2]
  If ![L]OK : Filter [F:TPD2] : Return : Endif
  If [L]MNTCUR+[L]TOTREGLOC+[L]MNT<[M:DIA]PAYMNTMIN | [L]MNTCUR+[L]TOTREGLOC+[L]MNT<=0
   [L]OK=0 : Filter [F:TPD2] : Return  :# Montant mini non atteint
  Endif
  Raz [L]TOTREGLOC , TOTREG , NBLIGREG
  For [TPD2]
   [L]TOTREGLOC -= [F:TPD2]AMTLOC
   [L]TOTREG    += [F:TPD2]AMTCUR
   [L]NBLIGREG  += 1
   [F:TPD2]FLG = [L]FLAG
   If [F:TPD2]UIDUSR=0
    [F:TPD2]UIDUSR = adxpid
   Endif
   Rewrite [F:TPD2]
   If fstat
    GOK=0 : Call FSTA("TPD2") From GLOCK : Break
   Endif
   If [L]NOREL="" & [L]MNTCUR+[L]TOTREGLOC+[L]MNT>=[M:DIA]PAYMNTMIN
&        & ([L]MNTCUR+[L]TOTREGLOC+[L]MNT>0)
    Break
   Endif
  Next : # [TPD2]
  Filter [TPD2]
  If GOK<1 : Return : Endif
  Gosub MAJ_TP2
  If GOK<1 : Return : Endif
 Endif  :# Montant minimum de règlement non atteint
Else
 [L]FLAG = 1  :# 1 échéance / règlement
Endif

Readlock [TPD2]TPD1=[F:TPD]ACCNUM;[F:TPD]DUDLIG
If fstat=1
 GOK=-1 : GLOCK="$TMPPAYDUD"-num$([F:TPD]ACCNUM)-num$([F:TPD]DUDLIG)
 Return
Elsif fstat
 GOK=0 : Call RSTA("TPD2",num$([F:TPD]ACCNUM)-num$([F:TPD]DUDLIG)) From GLOCK
 Return
Endif
[F:TPD2]FLG = [L]FLAG
If [M:DI2]CTLFLG = 2
 [F:TPD2]FLGCRE = 1
Else
 [F:TPD2]FLGCRE = 2
Endif
If [F:TPD2]UIDUSR=0
 [F:TPD2]UIDUSR = adxpid
Endif
Rewrite [TPD2]
If fstat
 GOK=0 : Call FSTA("TPD2") From GLOCK : Return
Endif
[L]TOTREGLOC = -[F:TPD]AMTLOC
[L]TOTREG    = [F:TPD]AMTCUR
[L]NBLIGREG  = 1
Gosub MAJ_TP2
If GOK<1 : Return : Endif
Return

## Flag des échéances d'un regroupement
$MARQ_TPD
If [L]TOTREG<=0 | [L]TOTREGLOC < [M:DIA]PAYMNTMIN : Return
Else
 Raz NBLIGREG , TOTREGLOC , TOTREG
 For [TPD2]TPD0 Where CPY=[M:DIA]CPY & PAYTYP=[F:TPD]PAYTYP & GRPCRI=[F:TPD]GRPCRI & FLG=0 & evalue(CRITFCY) & UIDUSR=adxpid
  If [L]NBLIGREG=[L]TABTPYMAX([L]INDTPY) : Break : Endif
  [F:TPD2]FLG    = [L]FLAG
  If [F:TPD2]UIDUSR=0
   [F:TPD2]UIDUSR = adxpid
  Endif
  Rewrite [F:TPD2]
  If fstat
   GOK=0 : Call FSTA("TPD2") From GLOCK : Break
  Endif
  [L]TOTREGLOC  -= [F:TPD2]AMTLOC
  [L]TOTREG     += [F:TPD2]AMTCUR
  [L]NBLIGREG   += 1
 Next : # [TPD2]
 If GOK<1 : Return : Endif
 Gosub MAJ_TP2
 If GOK<1 : Return : Endif
Endif
Return

$MAJ_TP2
# GRNA 02.08.11 - read of BPR must occur before Readlock
Call LEC_BPR([F:TPD]BPR) From CPTLEC

Readlock [TP2]TP20=[M:DIA]CPY;[F:TPD]PAYTYP;[F:TPD]GRPCRI;[L]FLAG;adxpid
If fstat=1
 GOK=-1
 GLOCK="$TMPPAYDUD2"-[M:DIA]CPY-num$([F:TPD]PAYTYP)-[F:TPD]GRPCRI-num$([L]FLAG)
 Return
Elsif fstat
 Raz [F:TP2]
 [F:TP2]PAYTYP = [F:TPD]PAYTYP
 [F:TP2]GRPCRI = [F:TPD]GRPCRI
 [F:TP2]FLG    = [L]FLAG
Endif
[F:TP2]AMTCUR += [L]TOTREG
[F:TP2]AMTLOC -= [L]TOTREGLOC
[F:TP2]NBR    += [L]NBLIGREG
[F:TP2]CPY     = [M:DIA]CPY
[F:TP2]FCY     = [F:TPD]FCY
If [M:DI2]CTLFLG = 2
 [F:TP2]FLGCRE = 1
Else
 [F:TP2]FLGCRE = 2
Endif
If [F:TP2]UIDUSR=0
 [F:TP2]UIDUSR = adxpid
Endif

# GRNA 02.08.11
[F:TP2]DUDDAT = [F:TPD]DUDDAT
[F:TP2]DISDAT = [F:TPD]DISDAT
[F:TP2]BPR    = [F:TPD]BPR
[F:TP2]BPRNAM = [F:BPR]BPRNAM

If fstat : Write [TP2] : Else Rewrite [TP2] : Endif
If fstat
 GOK=0 : Call FSTA("TP2") From GLOCK : Return
Endif
[L]TOTPROP += [L]TOTREGLOC
Return

$TAB_POO
## TOTPROP contient le montant total des règlements à constituer
[L]RESTE = -[L]TOTPROP
If [M:DIA]POO<>""
 [L]NBBAN = 0
 For [POO]POO0 Where POO=[M:DIA]POO
  [L]NBBAN += 1
  [L]POOBAN([L]NBBAN)   = [F:POO]BAN
  [L]POOMTMAX([L]NBBAN) = -[L]TOTPROP * [F:POO]PRC/100
  Call ARRDEV([L]POOMTMAX([L]NBBAN),DEVLED) From TRTDIV
  [L]RESTE -= [L]POOMTMAX([L]NBBAN)
 Next : # [POO]
 [L]POOMTMAX([L]NBBAN) += [L]RESTE
 Sorta [L]NBBAN [L]POOMTMAX,[L]POOBAN
Endif
Return

################  Critère de regroupement         ################

## Pour les échéances hors relevé
$REGROUP

[L]REGROUP = "[DUD]CPY"+SEP+"[DUD]BPRPAY"+SEP+"DUDCUR"+SEP+"[DUD]PAM"+SEP+"[DUD]SOINUM"

If [M:DIA]PAYDUD=2         :## 1 échéance / règlement ##
 [L]REGROUP += SEP+"num$([DUD]ACCNUM)+num$([DUD]DUDLIG)"
 [L]REGROUP += SEP+"[DUD]FCY"
 [L]REGROUP += SEP+"[DUD]SAC"
 [L]REGROUP += SEP+"format$('D:YYYYMMDD',[DUD]DUDDAT)"
Else
 [L]REGROUP += "+';'"

 If [M:DIA]PAYFCY=2        :## 1 site / règlement      ##
  [L]REGROUP += SEP+"[DUD]FCY"
 Else
  [L]REGROUP += "+';'"
 Endif

 ## Pour le cas des acomptes, le type de pièce est considéré comme un collectif
 If [M:DIA]PAYSAC = 2      :## 1 collectif / règlement ##
  [L]REGROUP += SEP+"string$(find([DUD]TYP,'*SO','*PO'),[DUD]TYP)"
&               +"+string$(!find([DUD]TYP,'*SO','*PO'),[DUD]SAC)"
 Elsif GDIV(3)="1"  :# Pas d'OD inter-tiers
  [L]REGROUP += SEP+"string$(!find([DUD]TYP,'*SO','*PO'),[DUD]SAC)"
 Else
  [L]REGROUP += "+';'"
 Endif

 If [M:DIA]PAYDUDDAT=2 | [F:TPY]DUDFLG=2 :## 1 Date d'échéance / règlement ##
  [L]REGROUP += SEP+"format$('D:YYYYMMDD',[DUD]DUDDAT)"
 Else
  [L]REGROUP += "+';'"
 Endif
Endif

If [L]OK_BPA #Gestion code adresse
 [L]REGROUP += SEP+"[DUD]BPAPAY"
Else
 [L]REGROUP += "+';'"
Endif

# Des acomptes de codes taxes différents ne peuvent pas être générés sur le même règlement
# si PPYCONSCTL=Oui et Coche Acompte et transaction de type Recette
If [M:DIA]INSFLG=2 & func AFNC.PARAM("PPYCONSCTL",[M:DIA]CPY)="2" & [M:DIA]SNS=2
&& ([M:DIA]ALLTPY=2 | ([F:TPY]STA3=2 | [F:TPY]STA8=2 | [F:TPY]ACETYP91=1 | ([F:TPY]STA5<>2 & [F:TPY]STA7<>2)))
 [L]REGROUP += SEP+"[DUD]VAT"
Else
 [L]REGROUP += "+';'"
Endif

If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2
 [L]REGROUP += SEP+"[DUD]UMRNUM"
Else
 [L]REGROUP += "+';'"
Endif

#################### Point d'entrée REGROUP ####################
[L]OK_GRP = 1
GPOINT = "REGROUP" : Gosub ENTREE From EXEFNC
Return

## Pour les échéances d'un relevé
$REGROUP_SOI
[L]REGROUP_SOI = "[SOI]CPY"+SEP+"[SOI]BPR"+SEP+"[SOI]CUR"+SEP+"[SOI]PAM"
&                +SEP+"[SOI]SOINUM"

[L]REGROUP_SOI += "+';'"

If [M:DIA]PAYFCY=2   :# 1 site / règlement
 [L]REGROUP_SOI += SEP+"[SOI]FCY"
Else
 [L]REGROUP_SOI += "+';'"
Endif

# 1 collectif / règlement ou pas d'OD inter-tiers
If [M:DIA]PAYSAC=2 or GDIV(3)="1"
 [L]REGROUP_SOI += SEP+"[SOI]SAC"
Else
 [L]REGROUP_SOI += "+';'"
Endif

If [M:DIA]PAYDUDDAT=2 | [F:TPY]DUDFLG=2 :# 1 Date d'échéance / règlement
 [L]REGROUP_SOI += SEP+"format$('D:YYYYMMDD',[SOI]DUDDAT)"
Else
 [L]REGROUP_SOI += "+';'"
Endif

If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2
 [L]REGROUP_SOI += SEP+"[DUD]UMRNUM"
Else
 [L]REGROUP_SOI += "+';'"
Endif

#################### Point d'entrée REGROUP ####################
[L]OK_GRP = 0
GPOINT = "REGROUP" : Gosub ENTREE From EXEFNC
Return

################  Filtre sur échéances       ################
## Pour les échéances hors relevé
$FILTRE
[L]CRITERE1 = "FLGCLE=1 & BPRFCT='' & CPY='"+[M:DIA]CPY+"'"
[L]CRITERE2 = ""

# Site
If [M:DIA]ALLFCY=1
 [L]CRITERE1 -= "& FCY='"+[M:DIA]FCY+"'"
Endif

# Acomptes
#   Acomptes ou/et pièces validées
If [M:DIA]INSFLG=1
 [L]CRITERE1 -= "& DUDSTA=2 & SOINUM='' & SOI<>2"
Else
 If func AFNC.PARAM("PPYCONSCTL",[M:DIA]CPY)="2" & [M:DIA]SNS=2
&& ([M:DIA]ALLTPY=2 | ([F:TPY]STA3=2 | [F:TPY]STA8=2 | [F:TPY]ACETYP91=1 | ([F:TPY]STA5<>2 & [F:TPY]STA7<>2)))
  [L]CRITERE1 -= "& (TYP='*SO')"
 Else
  [L]CRITERE1 -= "& (TYP='*SO' | TYP='*PO' | (DUDSTA=2 & SOINUM='' & SOI<>2))"
 Endif
Endif

# Type de pièces
If [M:DIA]ALLTYP=1
 [L]CRITERE1 -= "& TYP='"+[M:DIA]TYP+"'"
 If [M:DIA]PCEDEB<>""
  [L]CRITERE1 -= "& NUM>='"+[M:DIA]PCEDEB+"'"
 Endif
 If [M:DIA]PCEFIN<>""
  [L]CRITERE1 -= "& NUM<='"+[M:DIA]PCEFIN+"'"
 Endif
Endif

# Type de tiers
# Bug 16594 : Filtre sur le type de Tiers si celui demandé est Client ou Fournisseur
If [M:DIA]ALLTYPBPR=1
 If find([M:DIA]TYPBPR,1,2)
  [L]CRITERE2 -= "& BPRTYP="+num$([M:DIA]TYPBPR)
 Endif
Endif

# Tiers
If [M:DIA]ALLBPR=1
 If [M:DIA]BPRDEB<>""
  If [M:DIA]BPRDEB=[M:DIA]BPRFIN
   [L]CRITERE2 -= "& BPRPAY='"+[M:DIA]BPRDEB+"'"
  Else
   [L]CRITERE2 -= "& BPRPAY>='"+[M:DIA]BPRDEB+"'"
  Endif
 Endif
 If [M:DIA]BPRFIN<>"" & [M:DIA]BPRFIN<>[M:DIA]BPRDEB
  [L]CRITERE2 -= "& BPRPAY<='"+[M:DIA]BPRFIN+"'"
 Endif
Else
 [L]CRITERE2 -= "& BPRPAY<>''"
Endif

# Delphine le 20/09/02 : Suggestion n°13009
# Date d'échéance du ... au....
# Suggestion 14203 (CP : 11/04/03)
# Escomptes jusqu'à ...
If [M:DIA]DATDEP<>[0/0/0]
 # Echéances sans code escompte/agio
 [L]CRITERE2 -= "& ((DEP=''"
 If [M:DIA]DATMIN<>[0/0/0] :  [L]CRITERE2 -= "& DUDDAT>=["+format$(GFMD,[M:DIA]DATMIN)+"]"  : Endif
 If [M:DIA]DATMAX<>[0/0/0] :  [L]CRITERE2 -= "& DUDDAT<=["+format$(GFMD,[M:DIA]DATMAX)+"]" : Endif
 [L]CRITERE2 -= " ) "
 # Echéances avec code escompte/agio
 [L]CRITERE2 -= "| (DEP<>''"
 If [M:DIA]DATMIN<>[0/0/0] : [L]CRITERE2 -= "& DUDDAT>=["+format$(GFMD,[M:DIA]DATMIN)+"]" : Endif
 If [M:DIA]DATDEP<[M:DIA]DATMAX
  [L]CRITERE2 -= "& DUDDAT<=["+format$(GFMD,[M:DIA]DATMAX)+"]))"
 Else
  [L]CRITERE2 -= "& DUDDAT<=["+format$(GFMD,[M:DIA]DATDEP)+"]))"
 Endif
Else

########  SAM REF# 76609 added by angre 05/31/12  #####################################
#The commented code below is now handeled within the function GETDUEDATEQUERYSTRING
#from process PAYDEPLIB
#####################################################################

# If [M:DIA]DATMIN<>[0/0/0]
#  [L]CRITERE2 -= "& DUDDAT>=["+format$(GFMD,[M:DIA]DATMIN)+"]"
# Endif
# If [M:DIA]DATMAX<>[0/0/0]
#  [L]CRITERE2 -= "& DUDDAT<=["+format$(GFMD,[M:DIA]DATMAX)+"]"
# Endif



########  SAM REF# 76609 added by angre 05/31/12  ###########################################################################
#The function GETDUEDATEQUERYSTRING from process PAYDEPLIB returns the criteria query string for the due date criteria in
#the payment proposal screen. Depending on the selected 'Date selection mode' it will return the query string for
#the due date criteria from the 'Due date' section or the due date criteria from the 'Discount section' or a combination
#of both.
##############################################################################################################################
  [L]CRITERE2 -= func PAYDEPLIB.GETDUEDATEQUERYSTRING([M:DIA]DATSELMODE)

Endif

# Montant maximum d'échéance
If [M:DIA]DUDMNTMAX<>0
 [L]CRITERE2 -= "& AMTLOC<="+num$([M:DIA]DUDMNTMAX)
Endif

# 1 échéance par règlement
# bug 17142 : niveau de bon à payer à prendre en compte sur avoir fournisseur
[L]CRITERE1 -= "& FLGPAZ="+num$(len(mess(0,510,1)))   :# Niveau de bon à payer
If [M:DIA]PAYDUD=2
 Case [M:DIA]SNS
  When 1 : [L]CRITERE1 -= "& SNS=-1"  :# Dépense
  When 2 : [L]CRITERE1 -= "& SNS=1"  :# Recette
 Endcase
 If [M:DIA]PAYMNTMIN>0
  #  --> Montant minimum du solde = Montant minimum de règlement
  [L]CRITERE2 -= "& AMTLOC-PAYLOC-TMPLOC>="+num$([M:DIA]PAYMNTMIN)
 Endif
 #Else
 # Bon à payer
 # [L]CRITERE1 -= "& (SNS=1 | (SNS=-1 & FLGPAZ="+num$(len(mess(0,510,1)))+"))"
Endif
If [L]CRITERE2="" : [L]CRITERE2="1=1"
Elsif left$([L]CRITERE2,3)=" & ": [L]CRITERE2=right$([L]CRITERE2,4)
Endif

#19/12/07 : suggestion n°32205
#Filtre utilisateur
If [M:DIA]ALLUSR=1
 [L]CRITERE1 -="& CREUSR='"+[M:DIA]USR+"'"
Endif

#################### Point d'entrée FILTRE ####################
Raz [L]CRITSPE
GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
If [L]CRITSPE="" : [L]CRITSPE = "1=1" : Endif

Return

## Pour les échéances d'un relevé
$FILTRE_SOI
[L]CRIT_SOI = "CPY='"+[M:DIA]CPY+"'"

# Site
If [M:DIA]ALLFCY=1
 [L]CRIT_SOI -= "& FCY='"+[M:DIA]FCY+"'"
Endif

# Tiers
If [M:DIA]ALLBPR=1
 If [M:DIA]BPRDEB<>""
  If [M:DIA]BPRDEB=[M:DIA]BPRFIN
   [L]CRIT_SOI -= "& BPR='"+[M:DIA]BPRDEB+"'"
  Else
   [L]CRIT_SOI -= "& BPR>='"+[M:DIA]BPRDEB+"'"
  Endif
 Endif
 If [M:DIA]BPRFIN<>"" & [M:DIA]BPRDEB<>[M:DIA]BPRFIN
  [L]CRIT_SOI -= "& BPR<='"+[M:DIA]BPRFIN+"'"
 Endif
Else
 [L]CRIT_SOI -= "& BPR<>''"
Endif

# Delphine le 20/09/02 : Suggestion n°13009
# Date d'échéance du ... au....
# Suggestion 14203 (CP : 11/04/03)
# Escomptes jusqu'à ...
If [M:DIA]DATDEP=[0/0/0]
 If [M:DIA]DATMIN<>[0/0/0]
  [L]CRIT_SOI -= "& DUDDAT>=["+format$(GFMD,[M:DIA]DATMIN)+"]"
 Endif
 If [M:DIA]DATMAX<>[0/0/0]
  [L]CRIT_SOI -= "& DUDDAT<=["+format$(GFMD,[M:DIA]DATMAX)+"]"
  Endif
#Else
# Au moment du filtre sur le fichiers des échéances, on a besoin du code escompte/agio
Endif

# Critère pour relevés
Case [M:DIA]SNS
 When 1 : [L]CRIT_SOI -= "& AMTCUR<0"  :# Dépense
 When 2 : [L]CRIT_SOI -= "& AMTCUR>0"  :# Recette
Endcase

# Exclure les échéances figurant sur un relevé si PPYCONSCTL=Oui et Coche Acompte et transaction de type recette
# Le règlement ne doit avoir que des acomptes ayant même devise et code taxe
If [M:DIA]INSFLG=2 & func AFNC.PARAM("PPYCONSCTL",[M:DIA]CPY)="2" & [M:DIA]SNS=2
&& ([M:DIA]ALLTPY=2 | ([F:TPY]STA3=2 | [F:TPY]STA8=2 | [F:TPY]ACETYP91=1 | ([F:TPY]STA5<>2 & [F:TPY]STA7<>2)))
 [L]CRIT_SOI -= "& 1=0"
Endif


#################### Point d'entrée FILTRE_SOI ####################
Raz [L]CRITSPE_SOI
GPOINT = "FILTRE_SOI" : Gosub ENTREE From EXEFNC
If [L]CRITSPE_SOI="" : [L]CRITSPE_SOI = "1=1" : Endif
Return


# Filtre sur modes de règlement d'un type de règlement
$CRITPAM
Local Integer K : K=0
[L]CRITPAM = "find(PAM"
For I = 1 To [F:TPY]NBRPAM
 [L]CRITPAM += ",'"+[F:TPY]PAM(I-1)+"'"
 K+=1
Next
If [L]CRITPAM = "find(PAM" : [L]OK=0
Else                         [L]CRITPAM += ")"
Endif
If K=1 : [L]CRITPAM="PAM='"+[F:TPY]PAM(0)+"'" : Endif
Return

$CRITSAC
[L]CRITSAC=""
If [M:DIA]SAC<>""
 [L]CRITSAC = "SAC='"+[M:DIA]SAC+"'"
Elsif [M:DIA]GRPSAC<>""
 Filter [GSC] Where COA=[M:DIA]COA & GRU=[M:DIA]GRPSAC
 [L]CRITSAC = "find(SAC"
 For [GSC]GSC0
  [L]CRITSAC += ",'"+[F:GSC]SAC+"'"
 Next
 [L]CRITSAC += ")"
 Filter [GSC]
Endif
If [L]CRITSAC="" : [L]CRITSAC="1=1" : Endif
Return

$CRITCUR
[L]CRITCUR=""
If [M:DIA]CUR<>""
 [L]CRITCUR = "CUR='"+[M:DIA]CUR+"'"
Elsif [M:DIA]GRPCUR<>""
 Call LEC_GCU([M:DIA]GRPCUR) From CPTLEC
 If !fstat & [F:GCU]NBRCUR>0
  [L]CRITCUR = "find(CUR"
  For I = 1 To [F:GCU]NBRCUR
   [L]CRITCUR += ",'"+[F:GCU]CUR(I-1)+"'"
  Next I
  [L]CRITCUR += ")"
 Endif
Endif
If [L]CRITCUR="" : [L]CRITCUR="1=1" : Endif
Return

#################################################################
# Reprise dans une trace des valeurs saisies dans le masque MSK #
# pour les zones du bloc-rang debut au bloc-rang fin            #
# Le masque MSK doit être le masque par défaut                  #
# GH 25/04/00                                                   #
#################################################################

Subprog TOP_TRACE(MSK,BDEB,BFIN,RDEB,RFIN)
Value Char MSK()
Value Integer BDEB, BFIN
Value Decimal RDEB, RFIN

If GTRACE="" : End : Endif
Onerrgo ERREUR From CONTROLE
If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
If !clalev([F:AMK]) : Local File AMSK    [AMK] : Endif
If !clalev([F:ATY]) : Local File ATYPE   [ATY] : Endif
If !clalev([F:ATX]) : Local File ATEXTE  [ATX] : Endif
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Read [AMK]CODMSK = MSK
If fstat | [F:AMK]NBBLOC=0 : End : Endif

Local Shortint IBLOC([F:AMK]NBBLOC)
Local Integer  I, J, D, K
Local Char     TIT(30), TIT2(40)

If RFIN=0 : RFIN=99 : Endif
For I=0 To [F:AMK]NBBLOC-1
 IBLOC(I)=I+1
Next I
Sorta [F:AMK]NBBLOC [F:AMK]TYPBLOC, [L]IBLOC, [F:AMK]RANG Order By [F:AMK]RANG(indice)

For I = 0 To [F:AMK]NBBLOC-1
 If [F:AMK]TYPBLOC(I) = 2 & [L]IBLOC(I)>=BDEB & [L]IBLOC(I)<=BFIN : # Liste
  For [AMZ]CODZON Where CODMSK=[L]MSK & NUMBLOC=[L]IBLOC(I) & SAIAFF=1
   If ([L]IBLOC(I)<>BDEB | [F:AMZ]NOZONE>=RDEB) & ([L]IBLOC(I)<>BFIN | [F:AMZ]NOZONE<=RFIN)
    Call TEXTE([F:AMZ]INTIT,TIT) From OBJDIV
    Read [ATY]CODTYP = [F:AMZ]CODTYP
    D=evalue("dim([M]"+[F:AMZ]CODZON+")")
    For K=0 To D-1
    If D=1 : TIT2=TIT : Else TIT2=TIT+"("+num$(K)+")" : Endif
     Case [F:ATY]TYPTYP
      When 1         : # Menu local
       J=evalue("[M]"+num$([F:AMZ]CODZON+"("+num$(K)+")"))
       If [F:AMZ]NOLIB=277
        If [M]ALLTYPBPR<>2 : Call ECR_TRACE(TIT2-evalue("mess("+num$(J)+","+num$([F:AMZ]NOLIB)+",1)"),0) From GESECRAN : Endif
       Elsif [F:AMZ]NOLIB<>1 & J>0
        Call ECR_TRACE(TIT2-evalue("mess("+num$(J)+","+num$([F:AMZ]NOLIB)+",1)"),0) From GESECRAN
       Elsif J=2
        Call ECR_TRACE(TIT2,0) From GESECRAN
       Endif
      When 7         : # Alpha
       If evalue("[M]"+[F:AMZ]CODZON+"("+num$(K)+")")<>""
        Call ECR_TRACE(TIT2-evalue("[M]"+[F:AMZ]CODZON+"("+num$(K)+")"),0) From GESECRAN
       Endif
      When 8         : # Date
       If evalue("[M]"+[F:AMZ]CODZON+"("+num$(K)+")")<>[0/0/0]
        Call ECR_TRACE(TIT2-evalue("format$(GFMD,[M]"+[F:AMZ]CODZON+"("+num$(K)+"))"),0) From GESECRAN
       Endif
      When Default   : # Numérique
       If evalue("[M]"+[F:AMZ]CODZON+"("+num$(K)+")")<>0
        Call ECR_TRACE(TIT2-num$(evalue("[M]"+[F:AMZ]CODZON+"("+num$(K)+")")),0) From GESECRAN
       Endif
     Endcase
    Next K
   Endif
  Next : # [AMZ]
 Endif
Next I
End

