#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires de gestion des points                    Module CRM         24 Septembre 2003
#
#   CDTPOINT      : Crédite des points suite à une commande ou au traitement d'un coupon de garantie.
#   BPCPOINT      : Vérifie si un client mérite la création d'un contrat de service
#   DEBPOINT      : Retire des points suite à une commande ou au traitement d'un coupon de garantie.
#   SOHPOINT      : Interface entre les commandes de ventes et CDTPOINT.
#   INVPOINT      : Interface entre les factures de ventes et CDTPOINT.
#
##########################################################################################################
##########################################################################################################
# Crédite des points suite à une commande ou au traitement d'un coupon de garantie.
###########################################################################
Subprog CDTPOINT(SZBPC, SZITM, IQTY, SZUOM, SZCONTEXT, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZBPC
Value Char SZITM
Value Decimal IQTY
Value Char SZUOM
Value Char SZCONTEXT
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZDEFCOTCHX
Local Char SZCONNUM
Local Integer IGIFTPIT
Local Decimal IITMSAUSTU
Local Decimal ISOHSAUSTU
Local Decimal IITMPIT
Local Integer IBPCPIT
Local Integer ICOEF
Local Integer ICSMPIT
Local Integer LERRCOD
Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  LERRCOD = 0
  If GMODU(12) <> 2 Then
    End
  Endif
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 and func CRMUTIL150.GET_CODE_ACTIVITE("TOK") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    # Mais c'est la gestion des jetons (TOK) qui permet de déterminer si on va créer un contrat
    # Donc si on ne gère pas non plus les jetons on ne fait rien ici.
    End
  Endif
  #
  If SZBPC = "" Then
    #Aucun code client n'a été communiqué.
    IERRINF = 470
    ICHAPTER = 182
    IBRETOUR = 0
    End
  Endif
  If SZITM = "" Then
    #Aucun code article n'a été communiqué.
    IERRINF = 471
    ICHAPTER = 182
    IBRETOUR = 0
    End
  Endif
  If IQTY <= 0 Then
    #Aucune quantité n'a été communiquée.
    IERRINF = 472
    ICHAPTER = 182
    IBRETOUR= 0
    End
  Endif
  If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If !clalev([F:COT]) : Local File CONTTEMPL [COT] : Endif
  If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  #LSE CRMMULTISOC
  If !clalev([F:BPCW]) : Local File BPCUSTOMER [BPCW] : Endif
  #
  IITMSAUSTU = 0
  ISOHSAUSTU = 0
  IITMPIT = 0
  IBPCPIT = 0
  IGIFTPIT = 0
  SZCONNUM = ""
  ICOEF = 0
  ICSMPIT = 0
  SZDEFCOTCHX = ""
  #Première étape.
  #On regarde si l'article commandé dispose d'un crédit de point.
  Read [ITM]ITM0=SZITM
  If fstat Then
    #Le code article communiqué est incorrect.
    IERRINF = 474
    ICHAPTER= 182
    IBRETOUR = 0
    GOK = 0
    End
  Endif
  If SZUOM = "" Then
    SZUOM = [F:ITM]STU
  Endif
  #S'il n'y a pas de crédit de défini. Il n'y rien à faire.
  If [F:ITM]PITCDT <= 0 Then
    IBRETOUR = 1
    End
  Endif
  #On converti l'unité article en unité de stock
  If [F:ITM]PITCDTUOM = [F:ITM]STU Then
    IITMSAUSTU = 1
  Else
    Call SREC_COE([F:ITM]ITMREF, SZBPC, [F:ITM]STU, [F:ITM]PITCDTUOM, IITMSAUSTU) From TRTVENQTE
  Endif
  #Calcul le nombre de points à créditer par unité de stock
  IITMPIT = [F:ITM]PITCDT / IITMSAUSTU
  #On converti l'unité commandée en unité de stock
  If SZUOM = [F:ITM]STU Then
    ISOHSAUSTU = 1
  Else
    Call SREC_COE(SZITM, SZBPC, [F:ITM]STU, SZUOM, ISOHSAUSTU) From TRTVENQTE
  Endif
  IBPCPIT = (IITMPIT * ISOHSAUSTU) * IQTY
  #On crédite les points sur le client
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [BPCW]
  Endif
  #LSE CRMMULTISOC
  Readlock [BPCW]BPC0=SZBPC
  If fstat Then
    #Erreur lors de l'attribution des points au client.
    IERRINF = 476
    ICHAPTER= 182
    IBRETOUR = 0
    GOK = 0
  Else
    [F:BPCW]PITCDT += IBPCPIT
    [F:BPCW]TOTPIT = [F:BPCW]PITCDT + [F:BPCW]PITCPT
    Rewrite [BPCW]
    If fstat Then
      #L'attribution des points a échoué.
      IERRINF = 477
      ICHAPTER= 182
      IBRETOUR = 0
      GOK = 0
      Unlock [BPCW]
    Endif
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
  If GOK < 1 Then
    End
  Endif
  #On vérifie si le client à droit à un nouveau contrat
  If [F:BPCW]COTCHX = "" Then
    SZDEFCOTCHX = GDEFCOTCHX
  Else
    SZDEFCOTCHX = [F:BPCW]COTCHX
  Endif
  If SZDEFCOTCHX = "" Then
    End
  Endif
  Read [COT]COT0=SZDEFCOTCHX
  If fstat Then
    #Le contrôle des points a échoué.
    IERRINF = 482
    ICHAPTER= 182
    IBRETOUR = 0
    GOK = 0
    End
  Endif
  If [F:BPCW]COTPITRQD <= 0 Then
    IGIFTPIT = [F:COT]PITRQD
  Else
    IGIFTPIT = [F:BPCW]COTPITRQD
  Endif
  #---------------------------------------------------
  # Si on n'a pas les jetons qu'il faut : pas de contrat de service
  If IGIFTPIT <= 0 Then
    End
  Endif
  If [F:BPCW]TOTPIT < IGIFTPIT Then
    End
  Endif
  #---------------------------------------------------
  #On calcul le nombre de points à affecter au contrat
Global Integer GCON4PITCDT
Global Char GSZDEFCOTCHX

  GSZDEFCOTCHX = SZDEFCOTCHX
  ICOEF = [F:BPCW]TOTPIT / IGIFTPIT
  GCON4PITCDT = [F:COT]PITCDT * ICOEF
  ICSMPIT = IGIFTPIT * ICOEF
  #Maintenant le client a droit à son contrat.
  If dim([F:BPC]WCPY) <= 0 Then
    Read [BPC]BPC0=SZBPC
  Else
    Read [BPC]BPC0=GSOCIETE;SZBPC
  Endif
  If fstat <> 0 Then
    IERRINF = 481
    ICHAPTER= 182
    IBRETOUR= 0
    End
  Endif
  If SZCONTEXT = "" Then
    SZCONTEXT = "TRTPOINT"
  Endif
  Call CRECON(SZCONTEXT, 0, 0, SZCONNUM, LERRCOD) From SUBCONC
  #
  Kill GCON4PITCDT
  Kill GSZDEFCOTCHX
  If LERRCOD <> 0 Then
    #Erreur lors de la création du contrat de service
    IERRINF= 436
    ICHAPTER= 177
    IBRETOUR = 0
    GOK = 0
  Else
    #Création d'un contrat de service par la gestion des points et jetons.
    IERRINF= 438
    ICHAPTER= 177
  Endif
  If GOK < 1 Then
    End
  Endif
  #
  #On enregistre le nouveau crédit de point du client.
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [BPCW]
  Endif
  Readlock [BPCW]BPC0=SZBPC
  If fstat Then
    #Erreur lors de la remise à zéro des points du client.
    IERRINF = 479
    ICHAPTER= 182
    IBRETOUR = 0
    GOK = 0
  Else
    [F:BPCW]PITCDT = [F:BPCW]TOTPIT - ICSMPIT
    [F:BPCW]PITCPT = 0
    [F:BPCW]TOTPIT = [F:BPCW]PITCDT + [F:BPCW]PITCPT
    Rewrite [BPCW]
    If fstat Then
      #La remise à zéro des points du client a échoué.
      IERRINF = 480
      ICHAPTER= 182
      IBRETOUR = 0
      Unlock [BPCW]
      GOK = 0
    Endif
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
  If GOK < 1 Then
    End
  Endif
  #Avertissement du commercial responsable du client par workflow
  #LSE10/01/2006 Mise en commentaire temporaire suite à évolution 150
  Call DOCRMPIT1(1, SZCONNUM) From CRMWFLOW  # FGR 23/03/2010 : X3SUIVI63397 : réactivation du Workflow
End

##########################################################################################################
# Affectation des valeurs pour la création d'un contrat de service.
#############################################################################
$SET_HEA_INFO
  Case IMPZON
    When "CONBPC"     
      [M:CON0]CONBPC = [F:BPC]BPCNUM
      [M:CON1]CONORI = 7
      [M:CON1]CONORIVCR = ""
      [M:CON1]CONORIVCRL = 0
    When "CONCOT"
      [M:CON1]CONCOT = GSZDEFCOTCHX
    When "SIUDAT"
      [M:CON4]SIUDAT = date$
    When "CONAMT"
      [M:CON4]CONAMT = 0
    When "PITCDT"
      [M:CON4]PITCDT = GCON4PITCDT
    When "CONVACBPR"
      [M:CONG]CONVACBPR = [F:BPC]VACBPR
  Endcase
Return

##########################################################################################################
# Vérifie si un client mérite la création d'un contrat de service
###########################################################################
Subprog BPCPOINT(SZBPC, SZCONTEXT, SZCONNUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZBPC
Value Char SZCONTEXT
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR
Variable Char SZCONNUM

Local Integer LERRCOD
Local Char SZDEFCOTCHX
Local Integer IGIFTPIT
Local Decimal IITMSAUSTU
Local Decimal ISOHSAUSTU
Local Decimal IITMPIT
Local Integer IBPCPIT
Local Integer ICOEF
Local Integer ICSMPIT
Local Integer IBDEBTRANSFLG

  SZCONNUM = ""
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  LERRCOD = 0
  If GMODU(12) <> 2 Then
    End
  Endif
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 and func CRMUTIL150.GET_CODE_ACTIVITE("TOK") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    # Mais c'est la gestion des jetons (TOK) qui permet de déterminer si on va créer un contrat
    # Donc si on ne gère pas non plus les jetons on ne fait rien ici.
    End
  Endif
  #
  If SZBPC = "" Then
    #Aucun code client n'a été communiqué.
    IERRINF = 470
    ICHAPTER = 182
    IBRETOUR = 0
    End
  Endif
  If !clalev([F:COT]) : Local File CONTTEMPL [COT] : Endif
  If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  #LSE CRMMULTISOC
  If !clalev([F:BPCW]) : Local File BPCUSTOMER [BPCW] : Endif
  IITMSAUSTU = 0
  ISOHSAUSTU = 0
  IITMPIT = 0
  IBPCPIT = 0
  IGIFTPIT = 0
  SZCONNUM = ""
  ICOEF = 0
  ICSMPIT = 0
  SZDEFCOTCHX = ""
  If dim([F:BPC]WCPY) <= 0 Then
    Read [BPC]BPC0=SZBPC
  Else
    Read [BPC]BPC0=GSOCIETE;SZBPC
  Endif
  If fstat <> 0 Then
    IERRINF = 481
    ICHAPTER = 182
    IBRETOUR = 0
    End
  Endif
  #On vérifie si le client à droit à un nouveau contrat
  If [F:BPC]COTCHX = "" Then
    SZDEFCOTCHX = GDEFCOTCHX
  Else
    SZDEFCOTCHX = [F:BPC]COTCHX
  Endif
  If SZDEFCOTCHX = "" Then
    End 
  Endif
  Read [COT]COT0=SZDEFCOTCHX
  If fstat Then
    #Le contrôle des points a échoué.
    IERRINF = 482
    ICHAPTER = 182
    IBRETOUR = 0
    End
  Endif
  If [F:BPC]COTPITRQD <= 0 Then
    IGIFTPIT = [F:COT]PITRQD
  Else
    IGIFTPIT = [F:BPC]COTPITRQD
  Endif
  #---------------------------------------------------
  # Si on n'a pas les jetons qu'il faut : pas de contrat de service
  If IGIFTPIT <= 0 Then
    End
  Endif
  If [F:BPC]TOTPIT < IGIFTPIT Then
    End
  Endif
  #---------------------------------------------------
  #On calcul le nombre de points à affecter au contrat
Global Integer GCON4PITCDT
Global Char GSZDEFCOTCHX

  GSZDEFCOTCHX = SZDEFCOTCHX
  ICOEF = [F:BPC]TOTPIT / IGIFTPIT
  GCON4PITCDT = [F:COT]PITCDT * ICOEF
  ICSMPIT = IGIFTPIT * ICOEF
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  #Maintenant le client a droit à son contrat.
  If SZCONTEXT = "" Then
    SZCONTEXT = "TRTPOINT"
  Endif
  Call CRECON(SZCONTEXT, 0, 0, SZCONNUM, LERRCOD) From SUBCONC
  Kill GCON4PITCDT
  Kill GSZDEFCOTCHX
  If LERRCOD <> 0 Then
    #Erreur lors de la création du contrat de service
    IERRINF = 436
    ICHAPTER = 177
    IBRETOUR = 0
    End
  Else
    #Création d'un contrat de service par la gestion des points et jetons.
    IERRINF = 438
    ICHAPTER = 177
  Endif
  #On enregistre le nouveau crédit de point du client.
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [BPC]
  Endif
  Readlock [BPCW]BPC0=SZBPC
  If fstat Then
    #Erreur lors de la remise à zéro des points du client.
    IERRINF = 479
    ICHAPTER = 182
    IBRETOUR = 0
    GOK = 0
  Else
    [F:BPCW]PITCDT = [F:BPCW]TOTPIT - ICSMPIT
    [F:BPCW]PITCPT = 0
    [F:BPCW]TOTPIT = [F:BPCW]PITCDT + [F:BPCW]PITCPT
    Rewrite [BPCW]
    If fstat Then
      #La remise à zéro des points du client a échoué.
      IERRINF = 480
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Call FSTA("BPC") From GLOCK
      Unlock [BPCW]
    Endif
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
  #LSE 10/01/2006 Mise en commentaire temporaire suite à évolution 150
  #Avertissement du commercial responsable du client par workflow
  Call DOCRMPIT1(1, SZCONNUM) From CRMWFLOW  # FGR 23/03/2010 : X3SUIVI63397 : réactivation du Workflow
End

##########################################################################################################
# Retire des points suite à une commande ou au traitement d'un coupon de garantie.
###########################################################################
Subprog DEBPOINT(SZBPC, SZITM, IQTY, SZUOM, SZCONTEXT, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZBPC
Value Char SZITM
Value Decimal IQTY
Value Char SZUOM
Value Char SZCONTEXT
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IGIFTPIT
Local Decimal IITMSAUSTU
Local Decimal ISOHSAUSTU
Local Decimal IITMPIT
Local Integer IBPCPIT
Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If GMODU(12) <> 2 Then
    End
  Endif
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 and func CRMUTIL150.GET_CODE_ACTIVITE("TOK") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    # Mais c'est la gestion des jetons (TOK) qui permet de déterminer si on va créer un contrat
    # Donc si on ne gère pas non plus les jetons on ne fait rien ici.
    End
  Endif
  #
  If SZBPC = "" Then
    #Aucun code client n'a été communiqué.
    IERRINF = 470
    ICHAPTER = 182
    IBRETOUR = 0
    End
  Endif
  If SZITM = "" Then
    #Aucun code article n'a été communiqué.
    IERRINF = 471
    ICHAPTER = 182
    IBRETOUR = 0
    End
  Endif
  If IQTY <= 0 Then
    #Aucune quantité n'a été communiquée.
    IERRINF = 472
    ICHAPTER = 182
    IBRETOUR = 0
    End
  Endif
  If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If !clalev([F:COT]) : Local File CONTTEMPL [COT] : Endif
  If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  #LSE CRMMULTISOC
  If !clalev([F:BPCW]) : Local File BPCUSTOMER [BPCW] : Endif
  IITMSAUSTU = 0
  ISOHSAUSTU = 0
  IITMPIT = 0
  IBPCPIT = 0
  IGIFTPIT = 0
  #Première étape.
  #On regarde si l'article commandé dispose d'un crédit de point.
  Read [ITM]ITM0=SZITM
  If fstat Then
    #Le code article communiqué est incorrect.
    IERRINF = 474
    ICHAPTER = 182
    IBRETOUR = 0
    GOK = 0
    End
  Endif
  If SZUOM = "" Then
    SZUOM = [F:ITM]STU
  Endif
  #S'il n'y a pas de crédit de défini. Il n'y rien à faire.
  If [F:ITM]PITCDT <= 0 Then
    IBRETOUR = 1
    End
  Endif
  #On converti l'unité article en unité de stock
  If [F:ITM]PITCDTUOM = [F:ITM]STU Then
    IITMSAUSTU = 1
  Else
    Call SREC_COE([F:ITM]ITMREF, SZBPC, [F:ITM]STU, [F:ITM]PITCDTUOM, IITMSAUSTU) From TRTVENQTE
  Endif
  #Calcul le nombre de points à créditer par unité de stock
  IITMPIT = [F:ITM]PITCDT / IITMSAUSTU
  #On converti l'unité commandée en unité de stock
  If SZUOM = [F:ITM]STU Then
    ISOHSAUSTU = 1
  Else
    Call SREC_COE(SZITM, SZBPC, [F:ITM]STU, SZUOM, ISOHSAUSTU) From TRTVENQTE
  Endif
  IBPCPIT = (IITMPIT * ISOHSAUSTU) * IQTY
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [BPCW]
  Endif
  #On crédite les points sur le client
  Readlock [BPCW]BPC0=SZBPC
  If fstat Then
    #Erreur lors de l'attribution des points au client.
    IERRINF = 476
    ICHAPTER = 182
    IBRETOUR  = 0
    GOK = 0
  Else
    [F:BPCW]PITCDT -= IBPCPIT
    If [F:BPCW]PITCDT < 0 Then
      [F:BPCW]PITCDT = 0
    Endif
    [F:BPCW]TOTPIT = [F:BPCW]PITCDT + [F:BPCW]PITCPT
    Rewrite [BPCW]
    If fstat Then
      #L'attribution des points a échoué.
      IERRINF = 477
      ICHAPTER = 182
      IBRETOUR  = 0
      GOK = 0
      Unlock [BPC]
    Endif
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
# Interface entre les commandes de ventes et CDTPOINT.
##########################################################################
Subprog SOHPOINT(SZVCR, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZVCR
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Decimal IQTY
Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If GMODU(12) <> 2 Then
    End
  Endif
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  If !clalev([F:SOHW]) : Local File SORDER [SOHW] : Endif
  If !clalev([F:SOQW]) : Local File SORDERQ [SOQW] : Endif
  Read [SOHW]SOH0=SZVCR
  If fstat <> 0 Then
    #Erreur lors de la lecture de la commande de ventes
    IERRINF = 254
    ICHAPTER = 177
    IBRETOUR  = 0
  Endif
  IQTY = 0
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [SOQW]
  Endif
  Filter [SOQW] Where [F:SOQW]SOHNUM = SZVCR
  For [SOQW]
    Case [F:SOQW]SOHCAT
      When 1, 3
        #Commande normale
        Gosub SETSOQLINE
      When 4
        #Demande de livraison ferme d'une commande ouverte.
        If [F:SOQW]DEMSTA = 1 Then
          If [F:SOQW]CAD = 1 Then
            Gosub SETSOQLINE
          Endif
        Endif
    Endcase
    If GOK < 1 Then
      Break
    Endif
  Next
  Filter [SOQ]
  If IBDEBTRANSFLG = 0 Then
    If adxlog = 1 Then
      If GOK < 1 Then
        Rollback
      Else
        Commit
      Endif
    Endif
  Endif
End

##########################################################################################################
$SETSOQLINE
  If [F:SOQW]QTYSTU > [F:SOQW]PITFLG Then
    IQTY = [F:SOQW]QTYSTU - [F:SOQW]PITFLG
    Call CDTPOINT([F:SOQW]BPCORD, [F:SOQW]ITMREF, IQTY, "", "TRTCONSOH", IERRINF, ICHAPTER, IBRETOUR)
    If IBRETOUR = 0 Then
      GOK = 0
      Return 
    Endif
    [F:SOQW]PITFLG = [F:SOQW]QTYSTU
    Rewrite [SOQW]
    If fstat Then
      #Erreur lors de la mise à jour du statut de gestion des points.
      IERRINF = 483
      ICHAPTER = 182
      IBRETOUR  = 0
      GOK = 0
    Endif    
  Else
    If [F:SOQW]PITFLG > 0 Then
      If [F:SOQW]QTYSTU < [F:SOQW]PITFLG Then
        #Il faut enlever des points au client
        IQTY = [F:SOQW]PITFLG - [F:SOQW]QTYSTU
        Call DEBPOINT([F:SOQW]BPCORD, [F:SOQW]ITMREF, IQTY, "", "TRTCONSOH", IERRINF, ICHAPTER, IBRETOUR)
        If IBRETOUR = 0 Then
          GOK = 0
          Return 
        Endif
        [F:SOQW]PITFLG = [F:SOQW]QTYSTU
        Rewrite [SOQW]
        If fstat Then
          #Erreur lors de la mise à jour du statut de gestion des points.
          IERRINF = 483
          ICHAPTER = 182
          IBRETOUR  = 0
          GOK = 0
        Endif    
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Interface entre les factures de ventes et CDTPOINT.
##########################################################################
Subprog INVPOINT(SZAPPELANT, SZVCR, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZAPPELANT # FGR 11/10/2007 : X3SUIVI43412 ajout de l'appelant
Value Char SZVCR
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Decimal IQTY
Local Char SZBPC
Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If GMODU(12) <> 2 Then
    IBRETOUR = 1
    End
  Endif
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  # FGR 11/10/2007 : X3SUIVI43412 ajout de l'appelant
  LSZAPPELANT = SZAPPELANT
  If LSZAPPELANT = "" Then
    LSZAPPELANT = "SUBCONC"
  Endif
  If !clalev([F:SOQ]) : Local File SORDERQ [SOQ] : Endif
  If !clalev([F:SDD]) : Local File SDELIVERYD [SDD] : Endif
  # FGR 11/10/2007 : X3SUIVI43412 : Si appelant = SUBSIH par la peine d'ouvrir, c'est déjà fait
  If SZAPPELANT <> "SUBSIHA" Then
    If !clalev([F:SIH]) : Local File SINVOICE [SIH] : Endif
    If !clalev([F:SID]) : Local File SINVOICED [SID] : Endif
  Endif
  IQTY = 0
  SZBPC = ""
  # FGR 11/10/2007 : X3SUIVI43412 : Si appelant = SUBSIH pas la peine de relire on est déjà dessus
  If SZAPPELANT <> "SUBSIHA" Then
    Read [SIH]SIH0=SZVCR
    If fstat Then
      #Le code de la facture communiqué est incorrect.
      IERRINF = 484
      ICHAPTER = 182
      IBRETOUR  = 0
      GOK = 0
      End
    Endif
  Endif
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [SID]
  Endif
  #
  If [F:SIH]INVTYP = 1 Then
    #Facture
    ################################################################
    Filter [SID] Where [F:SID]NUM = SZVCR
    For [SID]
      If [F:SID]SOHNUM = "" Then
        If [F:SID]SDHNUM = "" Then
          #Facture directe
          SZBPC = [F:SID]BPCINV
          Gosub SETINVLINE
        Else
          Read [SDD]SDD0=[F:SID]SDHNUM;[F:SID]SDDLIN
          If !fstat Then
            If [F:SDD]SOHCAT <> 4 Then
              #Livraison directe ou Livraison directe de prêt
              SZBPC = [F:SDD]BPCORD
              Gosub SETINVLINE
            Endif
          Endif
        Endif
      Else
        #Commande de prêt
        Read [SOQ]SOQ0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
        If !fstat Then
          If [F:SOQ]SOHCAT = 2 Then
            SZBPC = [F:SOQ]BPCORD
            Gosub SETINVLINE
          Endif
        Endif
      Endif
      If GOK < 1 Then
        Break
      Endif
    Next
    Filter [SID]
  Elsif [F:SIH]INVTYP = 2 and GOK = 1 Then
    #Avoir
    ################################################################
    Filter [SID] Where [F:SID]NUM = SZVCR
    For [SID]
      If [F:SID]SOHNUM = "" Then
        If [F:SID]SDHNUM = "" Then
          #Facture directe
          SZBPC = [F:SID]BPCINV
          Gosub SETAVOLINE
        Else
          Read [SDD]SDD0=[F:SID]SDHNUM;[F:SID]SDDLIN
          If !fstat Then
            If [F:SDD]SOHCAT <> 4 Then
              #Livraison directe ou Livraison directe de prêt
              SZBPC = [F:SDD]BPCORD
              Gosub SETAVOLINE
            Endif
          Endif
        Endif
      Else
        #Commande de prêt
        Read [SOQ]SOQ0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
        If !fstat Then
          If [F:SOQ]SOHCAT = 2 Then
            SZBPC = [F:SOQ]BPCORD
            Gosub SETAVOLINE
          Endif
        Endif
      Endif
      If GOK < 1 Then
        Break
      Endif
    Next
    Filter [SID]
  Endif
  If IBDEBTRANSFLG = 0 Then
    If adxlog = 1 Then
      If GOK < 1 Then
        Rollback
      Else
        Commit
      Endif
    Endif
  Endif
End

##########################################################################################################
$SETINVLINE
  If [F:SID]QTYSTU > [F:SID]PITFLG Then
    IQTY = [F:SID]QTYSTU - [F:SID]PITFLG
    # FGR 24/04/2008 : X3SUIVIXXXXX ajout de l'appelant
    #Call CDTPOINT(SZBPC, [F:SID]ITMREF, IQTY, "", "TRTPOINT", IERRINF, ICHAPTER, IBRETOUR)
    Call CDTPOINT(SZBPC, [F:SID]ITMREF, IQTY, "", LSZAPPELANT, IERRINF, ICHAPTER, IBRETOUR)
    If IBRETOUR = 0 Then
      GOK = 0
      Return 
    Endif
    [F:SID]PITFLG = [F:SID]QTYSTU
    Rewrite [SID]
    If fstat Then
      #Erreur lors de la mise à jour du statut de gestion des points.
      IERRINF = 483
      ICHAPTER = 182
      IBRETOUR  = 0
      GOK = 0
    Endif    
  Else
    If [F:SID]PITFLG > 0 Then
      If [F:SID]QTYSTU < [F:SID]PITFLG Then
        #Il faut enlever des points au client
        IQTY = [F:SID]PITFLG - [F:SID]QTYSTU
        # FGR 24/04/2008 : X3SUIVIXXXXX ajout de l'appelant
        #Call DEBPOINT(SZBPC, [F:SID]ITMREF, IQTY, "", "TRTPOINT", IERRINF, ICHAPTER, IBRETOUR)
        Call DEBPOINT(SZBPC, [F:SID]ITMREF, IQTY, "", LSZAPPELANT, IERRINF, ICHAPTER, IBRETOUR)
        If IBRETOUR = 0 Then
          GOK = 0
          Return 
        Endif
        [F:SID]PITFLG = [F:SID]QTYSTU
        Rewrite [SID]
        If fstat Then
          #Erreur lors de la mise à jour du statut de gestion des points.
          IERRINF = 483
          ICHAPTER = 182
          IBRETOUR  = 0
          GOK = 0
        Endif    
      Endif
    Endif
  Endif
Return

##########################################################################################################
$SETAVOLINE
  If [F:SID]QTYSTU > [F:SID]PITFLG Then
    IQTY = [F:SID]QTYSTU - [F:SID]PITFLG
    # FGR 24/04/2008 : X3SUIVIXXXXX ajout de l'appelant
    #Call DEBPOINT(SZBPC, [F:SID]ITMREF, IQTY, "", "TRTPOINT", IERRINF, ICHAPTER, IBRETOUR)
    Call DEBPOINT(SZBPC, [F:SID]ITMREF, IQTY, "", LSZAPPELANT, IERRINF, ICHAPTER, IBRETOUR)
    If IBRETOUR = 0 Then
      GOK = 0
      Return 
    Endif
    [F:SID]PITFLG = [F:SID]QTYSTU
    Rewrite [SID]
    If fstat Then
      #Erreur lors de la mise à jour du statut de gestion des points.
      IERRINF = 483
      ICHAPTER = 182
      IBRETOUR  = 0
      GOK = 0
    Endif    
  Else
    If [F:SID]PITFLG > 0 Then
      If [F:SID]QTYSTU < [F:SID]PITFLG Then
        #Il faut enlever des points au client
        IQTY = [F:SID]PITFLG - [F:SID]QTYSTU
        Call CDTPOINT(SZBPC, [F:SID]ITMREF, IQTY, "", "TRTPOINT", IERRINF, ICHAPTER, IBRETOUR)
        If IBRETOUR = 0 Then
          GOK = 0
          Return 
        Endif
        [F:SID]PITFLG = [F:SID]QTYSTU
        Rewrite [SID]
        If fstat Then
          #Erreur lors de la mise à jour du statut de gestion des points.
          IERRINF = 483
          ICHAPTER = 182
          IBRETOUR  = 0
          GOK = 0
        Endif    
      Endif
    Endif
  Endif
Return
