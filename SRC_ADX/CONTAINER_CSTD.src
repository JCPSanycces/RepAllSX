#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe CONTAINER

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE      From CONTAINER_CSTD_EVT
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE      From CONTAINER_CSTD_EVT
        When "AINSERT_CONTROL_AFTER"   : Gosub AINSERT_CONTROL_AFTER       From CONTAINER_CSTD_EVT
        When "AUPDATE_CONTROL_AFTER"   : Gosub AUPDATE_CONTROL_AFTER       From CONTAINER_CSTD_EVT
        When "AINSERT_BEFORE"          : Gosub AINSERT_BEFORE              From CONTAINER_CSTD_EVT
      Endcase
    When "CTRD"
      Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE"  : Gosub CTRD_AINSERT_CONTROL_BEFORE From CONTAINER_CSTD_EVT  #MAE, exi 108538
        When "AUPDATE_CONTROL_BEFORE"  : Gosub CTRD_AUPDATE_CONTROL_BEFORE From CONTAINER_CSTD_EVT  #MAE, exi 108538
        When "AINSERT_CONTROL_AFTER"   : Gosub CTRD_AINSERT_CONTROL_AFTER  From CONTAINER_CSTD_EVT
        When "AUPDATE_CONTROL_AFTER"   : Gosub CTRD_AUPDATE_CONTROL_AFTER  From CONTAINER_CSTD_EVT
        When "ADDLINE_AFTER"           : Gosub CTRD_ADDLINE_AFTER          From CONTAINER_CSTD_EVT
        When "AINSERT_BEFORE"          : Gosub CTRD_AINSERT_BEFORE         From CONTAINER_CSTD_EVT
        When "ADELETE_CONTROL_AFTER"   : Gosub CTRD_ADELETE_CONTROL_AFTER  From CONTAINER_CSTD_EVT
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
  When "SET_SHIPNUM" : Gosub SET_SHIPNUM From CONTAINER_CSTD_MPU
Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "TCTRNUM" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub TCTRNUM_PROPAGATE From CONTAINER_CPRO
      Endcase
  Endcase
Return

