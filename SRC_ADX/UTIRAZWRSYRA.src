#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Raz  parameter AWRSYRA
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Raz  parameter AWRSYRA") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER=nomap
 Local File ADOVAL [ADW]
Else
 Local File =DOSSIER+".ADOVAL" [ADW]
Endif

Gosub MAJADOVAL

Close Local File [ADW]
End

#----------------------------------------------------------------------------------------#
$MAJADOVAL
Trbegin [F:ADW]
 Read [F:ADW]ADW0="";"";"AWRKSYRA"
 If !fstat
  [F:ADW]VALEUR = ""
  Rewrite [F:ADW]
  If fstat
   Call ERREUR("ADOVAL AWRKSYRA",2) From DOSDIC
  Endif
 Endif
Commit
Return
