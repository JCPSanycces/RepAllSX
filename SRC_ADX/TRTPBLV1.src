#<AdxTL>@(#)2.0.0.0 $Revision$
#######################################################################################################################
#  Affichage XML des familles de compétences                                  Module CRM          16 Septembre 2004   #
#######################################################################################################################
##########################################################
# Détail des paramètres 
# PARAM(1) : Collaborateur.
# PARAM(2) : Feuille XSLT.
# PARAM(3) : Contexte d'exécution.
#########################################################
#######################################################################################################################
$ACTION
  Case ACTION
    When "INIT"        : Gosub INITPLG
    When "EXEC"        : Gosub EXECPLG
    When Default
  Endcase
Return

#######################################################################################################################
$INITPLG
Local Char SZXSLTSHEET

  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If PARAM(1) <> "" Then
    Read [AUS]CODUSR=PARAM(1)
    If fstat Then
      #Le collaborateur indiqué est incorrect. Action abandonnée.
      GMESSAGE = mess(163,177,1)
      GERR = 1
      FIN = 1
      Return
    Endif
  Endif
  SZXSLTSHEET = PARAM(2)
  Gosub CHECKXSL From TRTMGGXSL1
  If FIN = 1 Then
    Return
  Endif
Return

#######################################################################################################################
$EXECPLG
Local Char RETOUR
Local Char SZFULLFILENAME(250)
Local Char SZFILENAME(250)
Local Integer ICHAPTER
Local Integer IERRINF

  IERRINF = 0
  ICHAPTER = 0
  If PARAM(2) = "" Then
    Call PBLINXML(PARAM(1), 1, "STD", PARAM(3), SZFULLFILENAME, SZFILENAME, ICHAPTER, IERRINF) From SUBPBLXML
  Else
    Call PBLINXML(PARAM(1), 1, PARAM(2), PARAM(3), SZFULLFILENAME, SZFILENAME, ICHAPTER, IERRINF) From SUBPBLXML
  Endif
  If IERRINF = 0 Then
    Callui RETOUR = "" With "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) + "Report",
&                           "UILocalFile="+ chr$(1) + SZFILENAME
  Endif
Return
