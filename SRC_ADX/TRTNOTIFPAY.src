#<DEBUG>
Raz GBIDC1, GBIDC2
Call OBJET("PAY",GBIDC2,GBIDC3) From GOBJET
End
#<DEBUG>

Funprog GETVALUE( SCREENPREFIX, SCREENFIELD )
Value Char SCREENPREFIX
Value Char SCREENFIELD
    Local Char RETVAL( 255 ) : Raz RETVAL
    Local Integer I
      
    Onerrgo IGNORE

    For I = 0 To 15
        RETVAL = evalue( "[M:" + SCREENPREFIX + num$( I ) + "]" + SCREENFIELD )
        If RETVAL <> ""
            Break
        Endif
    Next        

    Onerrgo
End RETVAL

$IGNORE
Resume

