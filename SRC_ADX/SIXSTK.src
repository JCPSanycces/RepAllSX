#########################################################################
#  SIXSTK : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog SIXSTK                                                        #
#     Recupération des stocks                                           #
#########################################################################
Gosub SI_CONTEXT From SIXFONCTION
SI_SIMU=2
#Local File SIPARX3  [SPX]
If !clalev([F:SPX])  Local File =SI_DOSSIER+".SIPARX3"   [SPX] : Endif
Read [SPX] First
Call EXEC From SIXSTK
End

#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE

If GTRACE = ""
#  "Migration des stocks"
    Call OUVRE_TRACE("SIXSTK : "+SI_MES(95)) From LECFIC     
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR
#---- Création enregistrement BPSUPPLIER ------#
Call ECR_TIME("SI_STOCK : "+mess(213,124,1)+" STOCK") From DOSSUB
Call SI_STOCK
If GOK<>1 : Onerrgo : Goto FIN_FIN : Endif

$FIN_FIN
If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End

$TRT_ERR
    Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
    GOK = 0
Resume

#########################################################################
# Création des stocks
#########################################################################
Subprog SI_STOCK

########--------------------------------------------------------- Ouvertures tables X3 #
If !clalev([F:FCY])  : Local File =SI_DOSSIER+".FACILITY"   [FCY]  : Endif # Socièté
If !clalev([F:ITM])  : Local File =SI_DOSSIER+".ITMMASTER"  [ITM]  : Endif # Article
If !clalev([F:ITF])  : Local File =SI_DOSSIER+".ITMFACILIT" [ITF]  : Endif # Article - site
If !clalev([F:CUN])  : Local File =SI_DOSSIER+".CUNSESSION" [CUN]  : Endif # Session
If !clalev([F:CUL])  : Local File =SI_DOSSIER+".CUNLISTE"   [CUL]  : Endif # Liste  
If !clalev([F:CUD])  : Local File =SI_DOSSIER+".CUNLISDET"  [CUD]  : Endif # Detail
If !clalev([F:ACV])  : Local File =SI_DOSSIER+".ACTIV"      [ACV]  : Endif # code activité
If !clalev([F:STJ])  : Local File =SI_DOSSIER+".STOJOU"     [STJ]  : Endif # Mvt stock
If !clalev([F:STE])  : Local File =SI_DOSSIER+".STOPAR"     [STE]  : Endif # parametre stock
If !clalev([F:ITV])  : Local File =SI_DOSSIER+".ITMMVT"     [ITV]  : Endif # Cumul article 
If !clalev([F:STO])  : Local File =SI_DOSSIER+".STOCK"      [STO]  : Endif # Stock        
If !clalev([F:STL])  : Local File =SI_DOSSIER+".STOLOT"     [STL]  : Endif # Stock lot 
If !clalev([F:STC])  : Local File =SI_DOSSIER+".STOLOC"     [STC]  : Endif # Emplacement 
If !clalev([F:STA])  : Local File =SI_DOSSIER+".STOALL"     [STA]  : Endif # Allocation

If !clalev([M:STW])  : Local Mask  STOWORK                  [STW]  : Endif #  ecran stockage mvt à mettre à jour
If !clalev([M:SIW])  : Local Mask  SISTOINVW                [SIW]  : Endif #  ecran détail inventaire
If !clalev([M:VALW]) : Local Mask  STOVALW                  [VALW] : Endif            
If !clalev([M:SVW])  : Local Mask  STOVALWORK               [SVW]  : Endif

########--------------------------------------------------------- Ouvertures tables Integrale #
If !clalev([F:XADP]) : Local File =SI_DOSSIER+".XIARTDPO"   [XADP] : Endif # Articles/Sites 
If !clalev([F:XAD2]) : Local File =SI_DOSSIER+".XIARTDPO"   [XAD2] : Endif # Articles/Sites (pour flagage) 
If !clalev([F:XART]) : Local File =SI_DOSSIER+".XIART"      [XART] : Endif # Articles
If !clalev([F:XDPO]) : Local File =SI_DOSSIER+".XIDPO"      [XDPO] : Endif # Sites 
If !clalev([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"      [XSOC] : Endif # Société Intégrale

If !clalev([F:XHIS]) : Local File =SI_DOSSIER+".XIMVTSKHIS" [XHIS] : Endif # Mvt stock historique  
If !clalev([F:XLOT]) : Local File =SI_DOSSIER+".XIMVTSRLOT" [XLOT] : Endif # Mvt serie lot  
If !clalev([F:XLO1]) : Local File =SI_DOSSIER+".XIMVTSRLOT" [XLO1] : Endif # Mvt serie lot mvt origine  
If !clalev([F:XVAL]) : Local File =SI_DOSSIER+".XIMVTSTVAL" [XVAL] : Endif # Mvt serie lot valorisé  
If !clalev([F:XVA1]) : Local File =SI_DOSSIER+".XIMVTSTVAL" [XVA1] : Endif # Mvt serie lot valorisé mvt origine 
If !clalev([F:XVA2]) : Local File =SI_DOSSIER+".XIMVTSTVAL" [XVA2] : Endif # Mvt serie lot valorisé (pour flagage)  

If !clalev([F:SPX])  Local File =SI_DOSSIER+".SIPARX3"   [SPX] : Endif

#----- Ouverture des tables -----#
Gosub OPEN_FILES From STKLIB


########--------------------------------------------------------- Définitions rubriques # 

Local Integer STOP
Local Integer LRET
Local Integer LERR    # 0=OK 1=Erreur  
Local Integer W_ORI   # 1 = article suivi en stock uniquement origine XIARTDPO
                      # 2 = article suivi en lot ou serie     origine XIMVTSKHIS
Local Char    WCODDPO (2)           # code DPO pour rupture
Local Char    WSTOFCY(GLONFCY)      # site    X3 en traitement 
Local Char    WITMREF(GLONITM)      # article X3 en traitement
Global Char   SI_CRITERE1  (250)    # Filtre supplémentaire   
Global Char   GSESSION     (GLONVCR) # Session créée        # hcb 59893
Global Date   QDATDEB               # date debut exercice
Global Date   QDATFIN               # date fin   exercice
Local Decimal LQTY
Local Char    WMES(100)
Local Integer WFLAG                 # flagage ARTDPO des articles traitant les mvts
Raz WCODDPO
Raz GDATDEB , GDATFIN
########--------------------------------------------------------- Initialisation variables contextuelles #

SI_SUBPRG = "SIXSTK"
SI_TABLE  = "XIARTDPO"
Gosub SI_CRITSUP From SIXFONCTION
SI_CRITERE1 = SI_CRITERE

SI_SUBPRG = "SIXSTK"
SI_TABLE  = "XIMVTSKHIS"
Gosub SI_CRITSUP From SIXFONCTION

########--------------------------------------------------------- Récuperation des correspondances #
SI_TABLE = "XIMVTSKHIS"
Gosub SI_INIVALEUR From SIXFONCTION

Call GETSOC([F:SPX]FCY) From DEVSUB  # Récupération de la législation...   # hcb 61885

Call STKCTRIPT( [F:SPX]IPTDATSTK, [F:SPX]FCY, "1") From STKLIB
If GERR=1
  # Période indéfinie ou traitement interdit à cette date!
   Call ECR_TRACE(format$("DD2",[F:SPX]IPTDATSTK)-":"-SI_MES(246),-1) From GESECRAN
   End
Endif

If dim(GCOD_INV)<1 
    Global Integer GCOD_INV 
 Endif
Read [ACV] CODACT="INV" 
If !fstat
   GCOD_INV=[F:ACV]DIME              # nombre de détail par liste
Endif 

# lecture societe pour filtrer les mvts stock avec l etat des exercices N et N-1
Read [XSOC]  First
If !fstat
   GDATFIN = [F:XSOC]FINEXCN
   If [F:XSOC]ETAEXCN1 = "O"
      GDATDEB = [F:XSOC]DEBEXCN1
   Else
      GDATDEB = [F:XSOC]DEBEXCN
   Endif
Endif
########--------------------------------------------------------- Traitement #

$LOOP_STK

Call DEBTRANS From GLOCK

#SI_CRITERE1 = "CODART = 'LOT'"
#SI_CRITERE1 = "CODDPO = '31'  "
#SI_CRITERE1 = "CODDPO = 'BE'  & CODART = 'SERIE'"
#SI_CRITERE1 = "CODART >= 'MARCHE' & CODART < 'PIPPAB'& CODDPO < 'ZZ'"

# link de XIARTDPO avec XIART et XIDPO 
#   la cle IND1 permet de traiter depot par depot  (tri depot,article)
#   le link sur XIART et XIDPO permet d avoir la correspondance article et site par la rubrique X3CLE 
Link [XADP] With [F:XART]IND0 = [F:XADP]CODART,[F:XDPO]IND0 = [F:XADP]CODDPO
&       As  [LIE]
&       Where evalue (SI_CRITERE1) 
&             &      FLGREP <2
&             &      [F:XDPO]X3CLE <> ""
&       Order By Key IND1
     For [LIE]
     WMES = [F:XADP]CODDPO+"/"+[F:XADP]CODART
     Call AFFBOITE(WMES) From SUBSIM

     WITMREF = [F:XART]X3CLE

     If WCODDPO <> [F:XADP]CODDPO
        If [M:SIW]NBLIG<>0
           Gosub CRE_NEW_INV 
           If LERR =  1
              Break
           Endif 
        Endif
        If WCODDPO <> ""
           Gosub TRT_VALIDATION
           If SI_SIMU <> 2 
              Gosub TRT_INVENTAIRE 
           Endif
           If LERR =  1
              Break
           Endif 
        Endif 

        WCODDPO = [F:XADP]CODDPO
        WSTOFCY = [F:XDPO]X3CLE
        Gosub CRE_NEW_CUN 
        If LERR =  1
           Break
        Endif 
     Endif
      
#    lecture article X3
     If [F:ITM]ITMREF<>WITMREF
        Read [F:ITM]ITM0=WITMREF
        If fstat
           # Article inexistant dans X3 !
           Call ECR_TRACE([F:XADP]CODART-SI_MES(115)-WITMREF,-1) From GESECRAN
           Goto NEXT_TRT
        Endif
     Endif
     If [F:ITM]STOMGTCOD < 2
        # Article non géré en stock dans X3 !
        Call ECR_TRACE([F:XADP]CODART-SI_MES(113)-WITMREF,-1) From GESECRAN
        Goto NEXT_TRT
     Endif
     If [F:ITM]ITMSTA = 6  
        # Article non utilisable dans X3 !
        Call ECR_TRACE([F:XADP]CODART-SI_MES(114)-WITMREF,-1) From GESECRAN
        Goto NEXT_TRT
     Endif

#    lecture article - site X3
     If [F:ITF]STOFCY <> WSTOFCY | [F:ITF]ITMREF <> WITMREF 
        Read [ITF]ITF0=WITMREF;WSTOFCY
        If fstat
        # Article - site inexistant dans X3 !
           Call ECR_TRACE([F:XADP]CODART-[F:XADP]CODDPO-SI_MES(116)-WITMREF-WSTOFCY,-1) From GESECRAN
           Goto NEXT_TRT
        Endif
     Endif

     If [F:ITM]LOTMGTCOD = 3 | [F:ITM]SERMGTCOD = 3
        W_ORI = 2
        Gosub TRT_HISTORIQUE
        If SI_SIMU <> 2 
           If LERR = 0 & WFLAG = 2 
              Read [XAD2]IND0 = [F:XADP]CODART;[F:XADP]CODDPO  
              If fstat
                 Call ECR_TRACE("XIARTDPO"-[F:XADP]CODART-[F:XADP]CODDPO+")"-mess(27,125,1)-"fstat="+num$(fstat),1) From GESECRAN
                 LERR = 1
                 Break
              Else
                 [F:XAD2]FLGREP = 2
                 Rewrite [XAD2]
              Endif
           Endif
        Endif
     Else
# si article suivi uniquement en stock : calcul du stock puis si >0 ecriture detail
        LQTY             = [F:XADP]QTESTKINI + [F:XADP]QTEENT+ [F:XADP]QTEECAIVT - [F:XADP]QTESOR
        Call QTEARR(LQTY,[F:ITM]STU) From TRTDIV 
        If LQTY > 0
           W_ORI = 1
           Gosub LOA_TABLEAU 
        Else                        # hcb 49043 deb
           If SI_SIMU <> 2
              Read [XAD2]IND0 = [F:XADP]CODART;[F:XADP]CODDPO
              If fstat
                 Call ECR_TRACE("XIARTDPO"-[F:XADP]CODART-[F:XADP]CODDPO+")"-mess(27,125,1)-"fstat="+num$(fstat),1) From GESECRAN
                 LERR = 1
              Else
                 [F:XAD2]FLGREP = 2
                 Rewrite [XAD2]
              Endif
           Endif                    # hcb 49043 fin
        Endif
     Endif
     If LERR <> 0
        Break
     Endif
$NEXT_TRT

   Next
   If LERR = 0
      If [M:SIW]NBLIG<>0
         Gosub CRE_NEW_INV 
         If LERR =  1
            End
         Endif 
      Endif
      Gosub TRT_VALIDATION 
      If SI_SIMU <> 2 
         Gosub TRT_INVENTAIRE 
      Endif
   Else
      If SI_SIMU  = 2
         Gosub SUP_SESSION
      Endif
   Endif
End

##################################################################
#  traitement historique stock integrale XIMVTSTHIS
#  pour les articles gérés en LOT ou SERIE 
##################################################################

$TRT_HISTORIQUE

WFLAG = 2
# Traitement historique stock integrale 
Filter [XHIS] Where    CODDPO  =  [F:XADP]CODDPO 
&                    & CODART  =  [F:XADP]CODART 
&                    & DATMVT  >= GDATDEB 
&                    & DATMVT  <= GDATFIN
&                    & evalue(SI_CRITERE)

For [XHIS]IND1

    Link [XVAL] With [F:XLOT]IND0~=[F:XVAL]PFX;[F:XVAL]NUMORD;[F:XVAL]LETRLQ;[F:XVAL]NUMLIG;[F:XVAL]NUMLIGSERLOT 
&           As [VALX]
&           Where     [F:XLOT]PFX       = [F:XHIS]LETMVT 
&                &    [F:XLOT]NUMORD    = [F:XHIS]NUMORD 
&                &    [F:XLOT]LETRLQ    = [F:XHIS]LETRLQ 
&                &    [F:XLOT]NUMLIG    = [F:XHIS]NUMLIG 
&                &    [F:XLOT]CODART    = [F:XHIS]CODART 
&                &    [F:XLOT]CODDPO    = [F:XHIS]CODDPO 
&                &    [F:XLOT]SENMVT    = "E" 
&                &    [F:XLOT]SLDQTE    = "" 
&                &    [F:XVAL]FLGREP    <  2 
&                &    [F:XVAL]NUMSERBLQ <> "O"  
&                &    [F:XVAL]QTERST    >  0 
&   Order By Key IND0  

    For [VALX] 
        If [F:XLOT]NUMSERLOT <> "" & [F:XLOT]X3CLE = ""
       # Transcodage incorrect
           If [F:ITM]LOTMGTCOD = 3
              Call ECR_TRACE([F:XADP]CODART-SI_MES(3)-SI_MES(127)-":"-[F:XLOT]NUMSERLOT,1) From GESECRAN
           Else
              Call ECR_TRACE([F:XADP]CODART-SI_MES(3)-SI_MES(128)-":"-[F:XLOT]NUMSERLOT,1) From GESECRAN
           Endif
           WFLAG =1
        Else  

           If [F:XVAL]FLGGEN = "G"
              Gosub TRT_HIST_ORIGINE
           Else 
              LQTY = [F:XVAL]QTERST
              Call QTEARR(LQTY,[F:ITM]STU) From TRTDIV 
              If LQTY > 0
                 Gosub LOA_TABLEAU
                 If LERR <> 0
                    Break 2
                 Endif
              Endif
           Endif
        Endif 
    Next
Next

Filter [XHIS]

Return

##################################################################
#  Recherche mouvement origine de celui généré par la cloture
##################################################################
$TRT_HIST_ORIGINE

Filter [XLO1] Where    CODART    = [F:XLOT]CODART
&                    & CODDPO    = [F:XLOT]CODDPO
&                    & NUMSERLOT = [F:XLOT]NUMSERLOT 
&                    & NUMPAL    = [F:XLOT]NUMPAL 
&                    & SENMVT    = "E" 
&                    & SLDQTE    = "" 
For [XLO1]IND4
    Filter [XVA1] Where    PFX               =  [F:XLO1]PFX    
&                        & NUMORD            =  [F:XLO1]NUMORD 
&                        & LETRLQ            =  [F:XLO1]LETRLQ 
&                        & NUMLIG            =  [F:XLO1]NUMLIG 
&                        & NUMLIGSERLOT      =  [F:XLO1]NUMLIGSERLOT 
&                        & NUMSERBLQ <> "O"  
&                        & FLGGEN    =  "C"  
&                        & CODART            =  [F:XLO1]CODART
&                        & QTERST            >  0
    For [XVA1]IND0

        LQTY = [F:XVA1]QTERST
        Call QTEARR(LQTY,[F:ITM]STU) From TRTDIV 
        If LQTY > 0
           Gosub LOA_TABLEAU
           If LERR <> 0
              Break 2
           Endif
        Endif
    Next
    Filter [XVA1]
Next
Filter [XLO1]
Return

##################################################################
#  Resynchronisation inventaire 
##################################################################
$TRT_INVENTAIRE

#-------------------- Vérification statut (CUNLISSTA) du fichier CUNLISTE ----------#
$STOCUL_LOOP
Trbegin [CUL]
Local Integer WACOMPTER
Local Integer WCOMPTER
Local Integer WABANDON
Local Integer WVALIDER
Local Integer WSTATUT
Local Integer WREW
Local Integer WOLD
Local Integer WOLDL        
Local Integer WNBRLIG        

For [CUL]CUL1 Where STOFCY = WSTOFCY
    Raz WACOMPTER
    Raz WCOMPTER
    Raz WABANDON
    Raz WVALIDER
    Raz WSTATUT
    Raz WREW
    Raz WOLD
    Raz WOLDL              
    Raz WNBRLIG            

    Filter [CUD] Where CUNSSSNUM  =[F:CUL]CUNSSSNUM
&                    & CUNLISNUM  =[F:CUL]CUNLISNUM
&                    & STOFCY     =WSTOFCY
           For [CUD]CUD0
               WNBRLIG += 1   
               Case [F:CUD]CUNLISSTA 
                      When 1 :
                            WACOMPTER = 2
                      When 2 :
                            WCOMPTER  = 4
                      When 3 :
                            WABANDON  = 0
                      When 4 :
                            WVALIDER  = 8
                Endcase 
           Next
    Filter [CUD]
 
    WSTATUT = WSTATUT + WACOMPTER + WCOMPTER + WVALIDER + WABANDON

    Read [CUL] Curr     
    If !fstat 
       WOLD  = [F:CUL]CUNLISSTA         
       WOLDL = [F:CUL]NBRLIG            
       If WSTATUT = 0 
          Goto NEXTTST                      
       Endif
       If WSTATUT = 8 &  [F:CUL]CUNLISSTA > 4 
          Goto NEXTTST                    
       Endif
       If WSTATUT = 8 &  [F:CUL]CUNLISSTA < 5 
         [F:CUL]CUNLISSTA = 5
          WREW = 1
       Endif
       If WSTATUT > 8 &  [F:CUL]CUNLISSTA <> 4
         [F:CUL]CUNLISSTA = 4
          WREW = 1
       Endif
       If WSTATUT <  8 &  [F:CUL]CUNLISSTA <> 1
         [F:CUL]CUNLISSTA = 1
         WREW = 1
       Endif
       If [F:CUL]CUNLISSTA = 6
          [F:CUL]CUNLOKFLG = 1
          WREW = 1
       Endif
$NEXTTST                                
       If WNBRLIG <> [F:CUL]NBRLIG
          [F:CUL]NBRLIG = WNBRLIG
          WREW = 1
       Endif                            
       If WREW = 1
          Rewrite  [CUL]  
       Endif
    Endif
$NEXTCUL
Next
Commit

#-------------------- Vérification statut (CUNSSSSTA) du fichier CUNSESSION ----------#
$STOCUN_LOOP
Trbegin [CUN]
Local Integer WPASCLOS
Local Integer WCLOS
Local Integer WSTATUT
Local Integer WREW
Local Integer WOLD

For [CUN]CUN1 Where STOFCY = WSTOFCY 
    Raz WPASCLOS
    Raz WCLOS
    Raz WSTATUT
    Raz WREW
    Raz WOLD
    Filter [CUL] Where STOFCY     =WSTOFCY
&                    & CUNSSSNUM  =[F:CUN]CUNSSSNUM

           For [CUL]CUL1
               Case [F:CUL]CUNLISSTA 
                      When 1 ,2 , 3, 4 , 5 :
                            WPASCLOS = 2
                      When 6 :
                            WCLOS    = 8
                Endcase 
           Next
    Filter [CUL]
 
    WSTATUT = WSTATUT + WPASCLOS + WCLOS

    Read [CUN] Curr     
    If !fstat 
       If WSTATUT = 0 &  [F:CUN]CUNSSSSTA =  1
          Goto NEXTCUN
       Endif
       If WSTATUT = 0 &  [F:CUN]CUNSSSSTA <> 1
          WOLD = [F:CUN]CUNSSSSTA
          [F:CUN]CUNSSSSTA = 1
          WREW = 1
       Endif 
       If WREW = 0
          If WSTATUT  <> 8 &  [F:CUN]CUNSSSSTA <> 2 
             WOLD = [F:CUN]CUNSSSSTA
            [F:CUN]CUNSSSSTA = 2
            WREW = 1
          Endif
          If WSTATUT = 8 &  [F:CUN]CUNSSSSTA <> 3
             WOLD = [F:CUN]CUNSSSSTA
            [F:CUN]CUNSSSSTA = 3
            WREW = 1
          Endif
       Endif
       If WREW = 1
          Rewrite  [CUN]  
       Endif
    Endif
$NEXTCUN
Next
Commit

Return

##################################################################
#  traitement validation inventaire historique stock integrale 
##################################################################
######################################################################## 
# TRT_VALIDATION                                        Validation liste
#     LCUL = "D"  Validation détail  CUNLISDET                                 
#     LCUL = "L"  Validation liste   CUNLISTE                                 
######################################################################## 
$TRT_VALIDATION
Local Integer I
Local Integer LRET

# tableau des articles validables
#Local Char    TITM(GLONITM)(GCOD_INV)      # hcb 46679 
Local Integer IITM

#Raz TITM , IITM                            # hcb 46679 

# Lecture des listes de la session 
Filter [CUL] Where [F:CUL]CUNSSSNUM = GSESSION 
& Order By Key CUL0 

For [CUL]

Local Char    TITM(GLONITM)([F:CUL]NBRLIG)   # hcb 46679 
Raz TITM                                     # hcb 46679
Raz IITM                                     # hcb 46679
 
#recensement des articles validables donc  comptes
     Filter [CUD] Where [F:CUD]CUNSSSNUM = [F:CUL]CUNSSSNUM  
&                     & [F:CUD]CUNLISNUM = [F:CUL]CUNLISNUM 
&                     & [F:CUD]CUNLISSTA = 2
&                       Order By Key CUD0
     For [CUD]
         If !find([F:CUD]ITMREF,TITM(0..IITM))
            TITM(IITM) = [F:CUD]ITMREF
            IITM += 1
         Endif
     Next

     Filter [CUD]
     For I = 0 To IITM-1
         If TITM(I) <> ""
            Gosub MAJ_INVENTAIRE 
         Endif
     Next I
Next

Filter [CUL]

If SI_SIMU  = 2
   Gosub SUP_SESSION
Endif

Return

######################################################################## 
# SUP_SESSION                        Suppression complete d une session 
######################################################################## 
$SUP_SESSION
#suppression des enregistrements bidons
Delete [F:STJ] Where STOFCY     = WSTOFCY    
&              &     UPDCOD    = 2
&              &     REGFLG    = 2
&              &     VCRTYP    = 9
&              &     VCRNUMORI = GSESSION 

#suppression des details
Delete [F:CUD] Where STOFCY     = WSTOFCY   & 
&                    CUNSSSNUM  = GSESSION  

# suppression des listes
Delete [F:CUL] Where STOFCY     = WSTOFCY   & 
&                    CUNSSSNUM  = GSESSION 


#suppression de la session
Delete [F:CUN] Where STOFCY     = WSTOFCY   & 
&                    CUNSSSNUM  = GSESSION 

Return
######################################################################## 
# LOA_TABLEAU                        Chargement des lignes à inventorier 
######################################################################## 
$LOA_TABLEAU
Local Integer  WRET

# Wmaxligcal necessaire pour assurer l arrondi
Local Integer WMAXLIGCAL
WMAXLIGCAL       = ([F:CUN]MAXLIG * [F:CUN]PRCLIG)/100
[M:SIW]STOFCY    = WSTOFCY
[M:SIW]CUNSSSNUM = GSESSION 
[M:SIW]CUR       = GLOCALDEV
[M:SIW]CUNLISDAT = [F:SPX]IPTDATSTK     # hcb 57798

If [M:SIW]NBLIG >= WMAXLIGCAL
    Gosub CRE_NEW_INV
    If LERR <> 0
       Return
    Endif
Endif

[M:SIW]STOFCY    = WSTOFCY

[M:SIW]CUNSSSNUM = GSESSION 
[M:SIW]CUR       = GLOCALDEV
[M:SIW]CUNLISDAT = [F:SPX]IPTDATSTK     # hcb 57798

[M:SIW]NBLIG   += 1
nolign                             = [M:SIW]NBLIG

[M:SIW]ITMREF          (nolign-1)  = WITMREF 
[M:SIW]ABCCLS          (nolign-1)  = [F:ITF]ABCCLS
[M:SIW]LINFLG          (nolign-1)  = 2
[M:SIW]PCU             (nolign-1)  = [F:ITM]STU 
[M:SIW]STA             (nolign-1)  = "A" 
[M:SIW]LOT             (nolign-1)  = ""  
[M:SIW]PALNUM          (nolign-1)  = "" 
[M:SIW]WORI            (nolign-1)  = W_ORI 
#[M:SIW]OWNER           (nolign-1)  = WSTOFCY     # hcb 73168

If W_ORI = 1                      # article uniquement géré stock
   [M:SIW]CODART       (nolign-1)  = [F:XADP]CODART      # article integrale       (flagage XDPO)
   [M:SIW]LOT          (nolign-1)  = ""  
   [M:SIW]QTYPCUNEW    (nolign-1)  = LQTY
   [M:SIW]PCUSTUCOE    (nolign-1)  = 1  
   [M:SIW]QTYSTUNEW    (nolign-1)  = [M:SIW]QTYPCUNEW (nolign-1)
   [M:SIW]SERNUM       (nolign-1)  = "" 
   [M:SIW]PALNUM       (nolign-1)  = "" 
Else   
                          # article géré lot ou série
   [M:SIW]PFX          (nolign-1)  = [F:XVAL]PFX          # prefixe                (flagage XVAL)
   [M:SIW]NUMORD       (nolign-1)  = [F:XVAL]NUMORD       # numero ordre           (flagage XVAL)
   [M:SIW]LETRLQ       (nolign-1)  = [F:XVAL]LETRLQ       # lettre reliquat        (flagage XVAL)
   [M:SIW]NUMLIG       (nolign-1)  = [F:XVAL]NUMLIG       # numero ligne           (flagage XVAL)
   [M:SIW]NUMLIGSER    (nolign-1)  = [F:XVAL]NUMLIGSERLOT # numero ligne serie lot (flagage XVAL)
   [M:SIW]INDX         (nolign-1)  = [F:XVAL]INDX         # indice                 (flagage XVAL)
   If [F:ITM]LOTMGTCOD = 3
      [M:SIW]LOT       (nolign-1)  = [F:XLOT]X3CLE 
      [M:SIW]PALNUM    (nolign-1)  = num$([F:XLOT]NUMPAL)
   Else
      If [F:ITM]SERMGTCOD = 3 
         [M:SIW]SERNUM (nolign-1)  = [F:XLOT]X3CLE 
      Endif
   Endif
   [M:SIW]QTYPCUNEW    (nolign-1)  = LQTY 
   [M:SIW]PCUSTUCOE    (nolign-1)  = 1  
   [M:SIW]QTYSTUNEW    (nolign-1)  = LQTY 
Endif

[M:SIW]QTYSTU    (nolign-1)  = [M:SIW]QTYSTUNEW    (nolign-1) # hcb 57347
Call TRT_VALEUR  (nolign-1,"SIW") From STKINV                 # hcb 57347

Return  

######################################################################## 
# MAJ_INVENTAIRE                       validation inventaire par article
######################################################################## 
$MAJ_INVENTAIRE
Local Decimal LQTA
Local Decimal LSHT
Local Integer LNBR
Local Integer LNBJ
Local Integer LRET
Local Integer K

Call DEBTRANS From GLOCK
Trbegin [CUD]

Local Char WCUNLISNUM
#Lecture article maitre 
Read [ITM]ITM0= TITM(I)
If fstat
#   Erreur lecture fichier !
    Call ECR_TRACE(mess(6,9004,1)-"ITMMASTER"-TITM(I),1) From GESECRAN
    Rollback 
    LERR = 1 
    Return
Endif

#lecture [ITF]  
Read [ITF]ITF0=TITM(I);WSTOFCY     
If fstat
#   Erreur lecture fichier !
    Call ECR_TRACE(mess(6,9004,1)-"ITMFACILIT"-TITM(I),1) From GESECRAN
    Rollback 
    LERR = 1 
    Return
Endif

# creation du STOLOT
Gosub TRT_STOLOT
If LERR <> 0 | GOK < 1
   Rollback 
   Return
Endif

#########################################
# Initialisation de l'en-tête STOWORK
Raz [M:STW]
Raz [M:VALW]
[M:STW]STOFCY     = WSTOFCY             # Site
[M:STW]TRSTYP     = 13                  # inventaire t  (M.704)
[M:STW]VCRTYP     = 9                   # inventaire    (M.701) 
[M:STW]VCRNUM     = [F:CUL]CUNLISNUM    # Numéro liste 
[M:STW]VCRLIN     = 0                   # Numero ligne = itmlisnum dans le détail
[M:STW]VCRTYPORI  = 0  
[M:STW]VCRNUMORI  = [F:CUL]CUNSSSNUM    # Session 
[M:STW]VCRLINORI  = 0 
[M:STW]ITMREF     = TITM(I)             # Article
[M:STW]MVTDES     = SI_MES(124)         # Désignation mouvement
[M:STW]PRIORDH    = 0 
[M:STW]PJT        = "" 
#[M:STW]TRSFAM     = [F:SRT]TRSFAM       # famille mouvement  ??????????
#[M:STW]ENTCOD     = [F:SRT]ENTCOD       # code piece auto    ??????????
[M:STW]TRSCOD     = ""  
[M:STW]IPTDAT     = [F:CUL]CREDAT       # Date imputation
[M:STW]CCECOD     = "STJINV"            # CODE section analytique stock
[M:STW]CUR       = GLOCALDEV            
[M:STW]BPRNUM    = ""       
# LQTA = Total qté inventaire calculé 
# LSHT = Total qté inventaire compté 
# LNBR = Nombre inventaires
# LNBJ = Nombre inventaires justes
Call ALISTOWORK( 8, 0, LQTA, LSHT,LNBR,LNBJ, LRET ) From STKINT
#Mise à jour des stock

If LRET <> 0 | GOK < 1
   Rollback 
   LERR = 1 
   Return
Endif

# appel uniquement si écarts d inventaire  
If [M:STW]NBLIG <> 0
   Call MAJ_STOCK From STKMAJ
   If LRET <> 0 | GOK < 1
      Rollback 
      LERR = 1 
      Return
   Endif
Endif

# lecture STE
If [F:STE]STOFCY <> WSTOFCY | [F:STE]TCLCOD <> "" 
   Read [STE]STE0=WSTOFCY;"" 
   If fstat
#     Erreur lecture fichier !
      Call ECR_TRACE(mess(6,9004,1)-"STOPAR"-WSTOFCY,1) From GESECRAN
      Rollback 
      LERR = 1 
      Return
   Endif
Endif

# Lecture ITV 
Call LECITV(WSTOFCY,TITM(I),"",LRET) From STKLIB
If LRET > 1
#   Erreur lecture fichier !
    Call ECR_TRACE(mess(6,9004,1)-"ITMMVT"-WSTOFCY-TITM(I),1) From GESECRAN
    Rollback 
    LERR = 1 
    Return
Endif
# Mise à jour ITV partie inventaire 
#date dernier inventaire
If [F:CUN]CUNLASFLG = 2
   [F:ITV]LASCUNDAT     =  [F:CUL]CREDAT
   [F:ITV]LASCUNLIS     =  [F:CUL]CUNLISNUM 
Endif  

#Mise à jour stock dernier inventaire (compté) 
[F:ITV]CUNSTO        =  LSHT
# raz compteurs nombre entrées
[F:ITV]CUNRCPMVT     =  0
# raz compteurs nombre sorties #
[F:ITV]CUNISSMVT     =  0  
#Cumul nombre inventaires
[F:ITV]CUNNBR        +=  1
#Cumul nombre inventairesjustes
If LNBR = LNBJ 
  [F:ITV]CUNNBREQU   +=  1
Endif
#Mise à jour statistiques inventaires 
For K = dim([F:ITV]CUNDAT)-2 To 0 Step -1 
   [F:ITV]CUNDAT   (K+1) = [F:ITV]CUNDAT   (K) 
   [F:ITV]CUNQTYCLC(K+1) = [F:ITV]CUNQTYCLC(K) 
   [F:ITV]CUNQTYNEW(K+1) = [F:ITV]CUNQTYNEW(K) 
Next K 
[F:ITV]CUNDAT(0)     = [F:CUL]CREDAT
#Mise à jour stock dernier inventaire (calculé) 
[F:ITV]CUNQTYCLC(0)  = LQTA
#Mise à jour stock dernier inventaire (compté) 
[F:ITV]CUNQTYNEW(0)  = LSHT 
#calcul nombre de ligne statistique 
If [F:ITV]CUNDIM < dim([F:ITV]CUNDAT) 
   [F:ITV]CUNDIM += 1 
Endif
    
# Réécriture ITV                # en simulation pas de reecriture ITV
If SI_SIMU <> 2
   Call REWITV From STKLIB
   If fstat
#     Erreur lecture fichier !
      Call ECR_TRACE(mess(6,9004,1)-"STOPAR"-WSTOFCY-TITM(I),1) From GESECRAN
      Rollback 
      LERR = 1 
      Return
   Endif
Endif

# Mise à jour STE 

Case [F:ITF]ABCCLS 
  When 1 : 
    [F:STE]CUNNBRA += 1 
    [F:STE]LASCUNDATA = [F:CUL]CREDAT
  When 2 : 
    [F:STE]CUNNBRB += 1 
    [F:STE]LASCUNDATB = [F:CUL]CREDAT
  When 3 : 
    [F:STE]CUNNBRC += 1 
    [F:STE]LASCUNDATC = [F:CUL]CREDAT
  When 4 : 
    [F:STE]CUNNBRD += 1 
    [F:STE]LASCUNDATD = [F:CUL]CREDAT
Endcase 
If SI_SIMU <> 2              # en simulation par de reecriture STE
   Rewrite [STE]  
   If fstat  
#     Erreur à la réécriture du fichier
      Call ECR_TRACE(mess(5,9004,1)-"STOPAR"-WSTOFCY,1) From GESECRAN
      Rollback 
      LERR = 1 
      Return
   Endif
Endif

# si sumulation : rollback sinon : commit
If SI_SIMU = 2
   Rollback
Else
   Commit
Endif

Return 

###############################################################################
#  Traitement des STOLOT
# si l article est suivi en lot
#              creation d un enregistrement STOLOT à chaque rupture ARTICLE LOT 
# si l article est suivi uniquement en stock ou suivi en serie  
#               creation d un enregistrement STOLOT par ARTICLE  
###############################################################################
$TRT_STOLOT
Local Integer  Y
Local Integer  WCOD 
Local Date     WREF 
Local Integer  WSHL 
Local Date     WPER
Local Char     WLOT   (GLONLOT)

If [F:ITM]LOTMGTCOD = 3
#----- Boucle de traitement des lignes pour les inventaires (entrées) -----#
# Sélection sur : session,liste,article,site, compté
#           sur la cle CUD0 car trié par article / lot lors de la creation de la liste     

   Filter [CUD] Where [F:CUD]CUNLISNUM = [F:CUL]CUNLISNUM  &
&                     [F:CUD]CUNSSSNUM = [F:CUL]CUNSSSNUM  & 
&                     ITMREF           = TITM(I)           & 
&                     STOFCY           = WSTOFCY           & 
&                     [F:CUD]CUNLISSTA = 2
&               Order By Key CUD0
   For [CUD]
       If WLOT = ""
          WLOT = [F:CUD]LOT
          If WLOT = ""
             Gosub CRE_STOLOT 
          Endif
       Endif
       If WLOT <> [F:CUD]LOT
          Gosub CRE_STOLOT 
          If LERR <> 0 
             Break
          Endif    
          WLOT = [F:CUD]LOT
       Endif
   Next
   Filter [CUD]
   If LERR = 0 &  WLOT <> ""
      Gosub CRE_STOLOT 
   Endif
Else
   Raz WLOT
   Gosub CRE_STOLOT 
Endif
Return

###############################################################################
#  Creation STOLOT

$CRE_STOLOT
Read [STL]STL0=TITM(I);WLOT  
If  fstat
    Raz [F:STL]
    [F:STL]ITMREF    = TITM(I)
    [F:STL]LOT       = WLOT 
    [F:STL]SLO       = ""
    [F:STL]VCRTYP    = 9
    [F:STL]VCRNUM    = [F:CUL]CUNLISNUM
    [F:STL]VCRLIN    = 0
    [F:STL]REFPER    = [F:SPX]IPTDATSTK
    [F:STL]LOTCREDAT = [F:SPX]IPTDATSTK
    If [F:ITM]LOTMGTCOD > 1
       [F:STL]SHL    = [F:ITM]SHL
       [F:STL]REFPER = [F:SPX]IPTDATSTK 
       [F:STL]POT    = 100
       [F:STL]ACT    = 1
       If [F:ITM]STOMGTCOD = 3
          [F:STL]POT = [F:ITM]DEFPOT
       Endif 
       If [F:ITM]EXYMGTCOD > 1
          WCOD = [F:ITM]EXYMGTCOD
          WREF = [F:SPX]IPTDATSTK 
          WSHL = [F:ITM]SHL
          Call CALPER(WCOD,WREF,WSHL,"",WPER) From STKLIB
          [F:STL]SHLDAT = WPER
       Else
          [F:STL]SHLDAT = [31/12/2999]
       Endif
    Endif
    Call ECRSTL From STKLIB
    If fstat
#   Erreur ecriture fichier !
       Call ECR_TRACE(mess(26,125,1)-"STOLOT"-WSTOFCY-TITM(I)-WLOT,1) From GESECRAN
       LERR = 1 
    Endif
Endif
Return

##################################################################
#  Creation CUNSESSION
##################################################################
$CRE_NEW_CUN
Local  Date    LDAT 
LDAT = date$

Raz [F:CUN]
# Création du numéro de session si nécessaire                    
If GSTKCPTMAN(13)<>2 
   Call NUM_SSS(WSTOFCY,LDAT,[F:CUN]CUNSSSNUM) From SUBSNXA                               
   If [F:CUN]CUNSSSNUM = ""  
# erreur sur compteur                                                 
      Call ECR_TRACE("CUNSESSION"-WSTOFCY-mess(104,117,1),1) From GESECRAN
      LERR = 1

      Return                                                    
   Endif                                                         
Else
   [F:CUN]CUNSSSNUM = "SESSION"+WSTOFCY
Endif       
GSESSION          = [F:CUN]CUNSSSNUM
[F:CUN]ABCCLSA    = 2
[F:CUN]ABCCLSB    = 2
[F:CUN]ABCCLSC    = 2
[F:CUN]ABCCLSD    = 2
[F:CUN]CUNLASFLG  = 2
[F:CUN]CUNNULSTK  = 2
[F:CUN]CUNSRTCOD  = 1
[F:CUN]CUNSSSDAT  = [F:SPX]IPTDATSTK
[F:CUN]CUNSSSDES  = SI_MES(124)
[F:CUN]CUNSSSMOD  = 1
[F:CUN]CUNSSSTYP  = 1
[F:CUN]CUNSSSSTA  = 2
[F:CUN]ITMSTA006  = 1
If dim([F:CUN]CUNITMWRH) > 0
   [F:CUN]CUNITMWRH  = 1
Endif
[F:CUN]LOCPOS     = 10
[F:CUN]ITMNBR     = 9999
[F:CUN]MAGLOCFLG  = 2
[F:CUN]MAXLIG     = GCOD_INV
[F:CUN]PICLOCFLG  = 2
[F:CUN]PRCLIG     = 90
[F:CUN]QUALOCFLG  = 2
[F:CUN]RCPLOCFLG  = 2
[F:CUN]RETLOCFLG  = 2
[F:CUN]STOFCY     = WSTOFCY      
[F:CUN]STOLOCFLG  = 2
[F:CUN]TRALOCFLG  = 2
[F:CUN]CREUSR     = GUSER
[F:CUN]CREDAT     = [F:SPX]IPTDATSTK 

# il ni a pas de PE sur la SESSION 
Write [CUN]
If fstat
#session erreur ecriture
   Call ECR_TRACE(mess(51,184,1)-[F:CUN]CUNSSSNUM-"("+WSTOFCY+")"-mess(26,125,1)-"fstat="+num$(fstat),1) From GESECRAN
   LERR = 1
Endif

Return

######################################################################## 
# CRE_NEW_INV                          Creation nouvell liste inventaire
######################################################################## 
$CRE_NEW_INV
Local Decimal WLIN

If [M:SIW]NBLIG = 0 
   Return
Endif 
Local  Date    LDAT 
LDAT = [M:SIW]CUNLISDAT

Call DEBTRANS From GLOCK
Trbegin [CUD]

# Création du numéro de liste                     
If GSTKCPTMAN(06)<>2 
   Call NUM_INV(WSTOFCY,LDAT,[M:SIW]CUNLISNUM) From SUBSNXA                               
   If [M:SIW]CUNLISNUM = ""                                                   
# erreur sur compteur                                                 
      Call ECR_TRACE("CUNLISTE"-WSTOFCY-mess(104,117,1),1) From GESECRAN
      LERR = 1
      Rollback
      Return                                                    
   Endif                                                         
Endif

# tri par article lot pour ameliorer les tps de reponse lors de la creation du STOLOT

Sorta [M:SIW]NBLIG [M:SIW]NBLIG Order By ITMREF(indice),LOT(indice)

For I = 0 To [M:SIW]NBLIG-1 
    nolign = I+1 
    WLIN   = (I+1)*1000 
#creation détail inventaire
    Raz [F:CUD] 
    [F:CUD]CUNSSSNUM = [M:SIW]CUNSSSNUM 
    [F:CUD]CUNLISNUM = [M:SIW]CUNLISNUM 
    [F:CUD]ITMLISNUM = WLIN
    [F:CUD]STOFCY    = [M:SIW]STOFCY
    [F:CUD]OWNER     = [M:SIW]STOFCY    # hcb 73168 
 
    [F:CUD]CUNDAT    = [M:SIW]CUNLISDAT
    [F:CUD]CUNLOKFLG = 1  
    If [M:SIW]CUR = "" 
       Call GETDEV([M:SIW]STOFCY) From DEVSUB
       [M:SIW]CUR = GLOCALDEV
    Endif  
    [F:CUD]CUR       = [M:SIW]CUR    
    [F:CUD]LINFLG    = [M:SIW]LINFLG    (I)
    [F:CUD]ITMREF    = [M:SIW]ITMREF    (I)
    [F:CUD]LOT       = [M:SIW]LOT       (I)
    [F:CUD]STA       = [M:SIW]STA       (I)
    [F:CUD]ABCCLS    = [M:SIW]ABCCLS    (I)
    [F:CUD]PCU       = [M:SIW]PCU       (I)
    [F:CUD]QTYPCUNEW = [M:SIW]QTYPCUNEW (I)
    [F:CUD]PCUSTUCOE = [M:SIW]PCUSTUCOE (I)
    [F:CUD]QTYSTUNEW = [M:SIW]QTYSTUNEW (I)
    [F:CUD]SERNUM    = [M:SIW]SERNUM    (I)
    [F:CUD]CUNCST    = [M:SIW]CUNCST    (I)
    [F:CUD]CUNCSTCOD = [M:SIW]CUNCSTCOD (I)
    [F:CUD]PRIORD    = [M:SIW]PRIORD    (I)
    [F:CUD]PALNUM    = [M:SIW]PALNUM    (I)
    If [F:CUD]PCUSTUCOE = 0 & [F:CUD]LINFLG = 1 & [F:CUD]QTYSTUNEW <> 0 & [F:CUD]QTYPCUNEW <> 0   
       [F:CUD]PCUSTUCOE =     [F:CUD]QTYSTUNEW /  [F:CUD]QTYPCUNEW                               
    Endif                                                                                        
    [F:CUD]CUNLOKFLG = 1  
    [F:CUD]CREUSR    = GUSER 
    [F:CUD]CREDAT    = [F:SPX]IPTDATSTK
    [F:CUD]EXPNUM    = [C]EXPORT
    [F:CUD]ZERSTOFLG = 1  
    [F:CUD]CUNLISSTA = 2

    Write [CUD] 
    If fstat 
#detail inventaire erreur ecriture
       Call ECR_TRACE(SI_MES(109)-[F:CUD]CUNSSSNUM-[F:CUD]CUNLISNUM-mess(26,125,1)-"fstat="+num$(fstat),1) From GESECRAN
       LERR = 1
       Break 
    Endif 
# flagage XIARTDPO si article suivi uniquement en stock    
# flagage XIMVTSTVAL si article suivi lot ou serie   
    If SI_SIMU <> 2
       If [M:SIW]WORI (I) = 1  
          Read [XAD2]IND0 = [M:SIW]CODART(I);WCODDPO 
          If fstat
             Call ECR_TRACE("XIARTDPO"-[M:SIW]CODART(I)-WCODDPO+")"-mess(27,125,1)-"fstat="+num$(fstat),1) From GESECRAN
             LERR = 1
             Break
          Else
             [F:XAD2]FLGREP = 2
             Rewrite [XAD2]
          Endif
       Else

          Read [XVA2]IND0 = [M:SIW]PFX(I);[M:SIW]NUMORD(I);[M:SIW]LETRLQ(I);[M:SIW]NUMLIG(I);[M:SIW]NUMLIGSER(I);[M:SIW]INDX(I)
          If fstat

             Call ECR_TRACE("XIMVTSTVAL"-[M:SIW]PFX(I)-num$([M:SIW]NUMORD(I))-[M:SIW]LETRLQ(I)
&            -num$([M:SIW]NUMLIG(I))-num$([M:SIW]NUMLIGSER(I))-num$([M:SIW]INDX(I))+")"-mess(27,125,1)-"fstat="+num$(fstat),1) From GESECRAN
             LERR = 1
             Break
          Else
             [F:XVA2]FLGREP = 2
             Rewrite [XVA2]
          Endif
       Endif
    Endif
Next I 
  
#creation liste inventaire
If LERR = 0
   Gosub CRE_NEW_CUL
Endif

# creer les enregistrements bidons
If LERR = 0
   Gosub TRT_ECRSTJBID 
Endif

If LERR = 0
   Commit
Else
   Rollback
Endif 

Raz [M:SIW]

Return

######################################################################## 
# CRE_NEW_CUL                                  Creation liste inventaire
######################################################################## 
$CRE_NEW_CUL
Raz [F:CUL] 
[F:CUL]STOFCY    = [M:SIW]STOFCY 
[F:CUL]CUNLISNUM = [M:SIW]CUNLISNUM 
[F:CUL]CUNSSSNUM = [M:SIW]CUNSSSNUM
[F:CUL]CUNLISDAT = [M:SIW]CUNLISDAT
[F:CUL]CUNLISDES = GSESSION 
[F:CUL]CUNLOKFLG = 1 

[F:CUL]CUNLISSTA = 1
[F:CUL]CUNSTADAT = [F:SPX]IPTDATSTK
[F:CUL]NBRLIG    = [M:SIW]NBLIG
[F:CUL]CREUSR    = GUSER 
[F:CUL]CREDAT    = [F:SPX]IPTDATSTK
[F:CUL]EXPNUM    = [C]EXPORT
[F:CUL]MVTDES    = SI_MES(124)
[F:CUL]UPDUSR    = GUSER 
[F:CUL]UPDDAT    = [F:SPX]IPTDATSTK
[F:CUL]IPTDAT    = [F:SPX]IPTDATSTK
[F:CUL]USR       = GUSER 

#SI_TABLE = "CUNLISTE"
#Gosub SI_BEFWRI From SIXFONCTION
Write [CUL] 
If fstat 
#liste inventaire erreur ecriture
   Call ECR_TRACE(SI_MES(108)-GSESSION -[F:CUL]CUNLISNUM-mess(26,125,1)-"fstat="+num$(fstat),1) From GESECRAN
   LERR = 1
Endif   
Return 

######################################################################### 
# TRT_ECRSTJBID                     Recherche enregistrement STOJOU bidon
######################################################################### 
$TRT_ECRSTJBID
Local Char    WITMREF1(GLONITM) 
Local Char    WLIS             

Raz WITMREF1 
Raz WLIS 
Filter [CUD] Where STOFCY    = WSTOFCY        & 
&                  CUNSSSNUM = GSESSION      &   
&                  CUNLISSTA = 2    
&            Order By Key CUD3
For [CUD]
  If WITMREF1 <> [F:CUD]ITMREF | WLIS <>  [F:CUD]CUNLISNUM  
     WITMREF1 =  [F:CUD]ITMREF 
     WLIS     =  [F:CUD]CUNLISNUM                           
     Gosub ECR_ECRSTJBID 
     If LERR <> 0 
        Break
     Endif
  Endif
Next
Filter [CUD]

Return
######################################################################### 
# ECR_ECRSTJBID                      Ecriture enregistrement STOJOU bidon
######################################################################### 
$ECR_ECRSTJBID

Local Integer WRET
If !clalev([F:STJ1])  Local File STOJOU     [STJ1] : Endif
If !clalev([F:STJ])   Local File STOJOU     [STJ]  : Endif
If !clalev([F:ITG])   Local File ITMCATEG   [ITG]  : Endif

Raz [F:STJ]
[F:STJ]STOFCY    = WSTOFCY  
[F:STJ]UPDCOD    = 2
[F:STJ]REGFLG    = 2
[F:STJ]ITMREF    = [F:CUD]ITMREF
[F:STJ]VCRTYP    = 9
[F:STJ]VCRNUM    = [F:CUD]CUNLISNUM
[F:STJ]VCRNUMORI = [F:CUD]CUNSSSNUM
[F:STJ]IPTDAT    = [F:SPX]IPTDATSTK

#----- Création du mouvement de stock -----#
Call ECRSTJ(0,WRET) From STKLIB
If WRET <> 0 
   LERR = 1 
Endif
Return













