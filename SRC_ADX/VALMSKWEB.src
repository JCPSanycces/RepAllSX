#<AdxTL>@(#)3.0.0.0 $Revision$

Local Char MASQUE(GLONAMK),APPLI
Local Char LAN(GLONLAN)(1..5)
Local Integer OK
##MASQUE = "FGRP"
MASQUE = "ZGA1"
LAN(1) = "FRA"
APPLI=nomap
#Dbgaff
GTRACE = ""
Call VALID(MASQUE,APPLI,1,LAN,0,OK) From VALMSK
If OK=1 : Gosub WE_VISU : Endif
End


#  Validation Web des ûˋcrans - Crûˋation de l'XML


$VALWEB
#If APPLI<>"SUP140" : Return : Endif
If dim(GI_DOSS)=-1 or GI_DOSS<>APPLI : Call GLOBWEB(APPLI) From INTRUTILA : Endif
Local Integer WE_BL,WE_CH,WE_AC,WE_NOBL,WE_I,WE_J  : # Variables de travail
Local Integer WE_T1,WE_T2,WE_T3,WE_T4,WE_T5,WE_ATT : # Variables de travail
Local Integer WE_1,WE_2,WE_3,WE_4,WE_ORI,WE_DEST,WLG   : # Variables de travail
Local Integer WE_IDB,WE_IDC,WE_BLCR(1..BLC_NBR)    : # Numûˋrotation des adxid
Local Integer WE_DIMBL : WE_DIMBL=500              : # Nombre max d'ûˋlûˋments dans un bloc
Local Integer WE_BLICOU              : # Ligne de bloc courante
Local Integer WE_MBLIG               : # Nombre maximum de lignes de blocs de l'ûˋcran
Local Integer WE_MBCOL               : # Nombre maximum de colonnes de blocs de l'ûˋcran
Local Integer WE_BOR                 : # Bordure (1 oui , 0 Non)
Local Integer WE_BPOS(1..MAXBLOC)    : # Indice des blocs triûˋs par position
Local Char    WE_PROP(100)           : # Propriûˋtûˋ du noeud
Local Char    WE_ALPHAB(26) : WE_ALPHAB="ABCDEFGHIJKLMNOPQRSTUVWXYZ"
Local Char    WE_BCOU                : # Code du bloc courant
Local Char    WE_VALUE(200)          : # Valeur de la propriûˋtûˋ
Local Char    WE_AIDVAL(150)         : # Zone de travail (info-bulle)
Local Char    WE_SAVVAL(100)         : # Zone de travail
Local Char    WE_CAPCOU(30)          : # Intitulûˋ courant
Local Char    WE_LANGUE              : # Langue courante sauvegardûˋe
Local Char    WE_GBLANC              : # Valeur blanche
Local Char    WE_SAVLANG             : # Langue par dûˋfaut sauvegardûˋe
Local Char    WE_NOMFIC(200)         : # Nom du fichier XML produit
Local Char    WE_VALL1(200)          : # Zone de stockage des tags XML
Local Integer WE_ISRC                : # 1 si il y a des actions clic droit sur le champ, 0 sinon
Local Integer WE_RANK                : # Rang du champ dans les tableaux
Local Integer WE_NTEX                : # No du texte û  traiter
Local Integer WE_TCOL                : # Nombre de colonnes utilisûˋes par les champs d'un tableau
Local Integer WE_PLIG                : # Position en Lig de l'ûˋcran
Local Integer WE_PCOL                : # Position en Col de l'ûˋcran (pour calculer en relatif les pos bloc)
Local Integer WE_PLIG1               : # Position en Lig de l'ûˋcran (pour haute rûˋsolution)
Local Integer WE_PCOL1               : # Position en Col de l'ûˋcran (pour haute rûˋsolution)
Local Integer WE_PCOL2               : # Position en Col de l'ûˋcran (pour haute rûˋsolution avec browser large)
Local Char    WE_CAPDEF(100)         : # Caption dans la langue par dûˋfaut
Local Char    VALLM(200)             : # Caption pour MODVAL
Local Char    WE_INTEV(100)          : # Intitulûˋ ûˋvaluûˋ
Local Integer WE_NOMEN               : # Numûˋro de menu local
Local Integer WE_NOMES               : # Numûˋro de message
Local Integer WE_FORCE               : # 1 si on doit ûˋcrire le libellûˋ mûˆme si il est vide
Local Integer WE_GRAB                : # 1 si une area graphique avec bordure a ûˋtûˋ crûˋe
Local Integer WE_EXCL                : # indice du champ d'exclusion (tableaux)
Local Integer WE_TREC                : # transaction en cours
Local Integer WE_LCH                 : # indice du champ dimensionnûˋ en cours
                                       # (si il y en a un - pour traiter les intitulûˋs ûˋvaluûˋs avec indice)
Local Integer WE_MAXFB(1..MAXBLOC)   : # Indice max des champs par bloc
Local Integer WE_CHCOMB(1..2,1..200) : # Champs en combo :   1 Bloc*1000+Indice relatif du champ
                                     : #                     2 Indice du champ dans LIG_
Local Integer WE_NBCHC               : # Nombre de champs en combo ou en image
Local Char WE_HORDAT(14)             : # Horodatage de gûˋnûˋration
Local Char WE_STY(GLONASY)(1..100)   : # Styles dûˋfinis dans l'ûˋcran
Local Integer WE_NBSTY               : # Nombre de styles
Local Integer  WE1_PLIEC,WE1_PCOEC,WE1_NLIEC,WE1_NCOEC        : # Tailles ûˋcran pour calcul en %
Local Integer  WE1_BPLI,WE1_BPCO,WE1_BNLI,WE1_BNCO            : # Tailles bloc pour calcul en %
Local Integer  WE1_PLI,WE1_PCO,WE1_NLI,WE1_NCO                : # Tailles champ pour calcul en %
Local Decimal  WE_X                  : # Position en valeur dûˋcimale
Local Char WE_TBL(10)(1..WE_DIMBL)        : # Type d'input
Local Integer WE_NBLI,WE_LIGC,WE_ITBL,WE_L
Local Integer WE_TLI(1..WE_DIMBL)    : # Indice en correspondance dans la table des champs
Local Integer WE_FINF(1..WE_DIMBL)   : # =1 Si il faut fermer le tag
Local Integer WE_IND(1..WE_DIMBL)    : # Indice (pour les radio boutons ou pour les champs dimensionnûˋs)
#                                    : # No de ligne pour les lignes de champ

WE_HORDAT=JOUR+left$(HEURE,2)+mid$(HEURE,4,2)+right$(HEURE,7)

If clalev([F:AUR])=0 : Local File =APPLI+".AURL"          [AUR] : Endif
If clalev([F:ASP])=0 : Local File =APPLI+".ASUBPROGD"     [ASP] : Endif


#  On considû´re comme invisible les blocs tableaux ou le champ NBLIG est invisible

For WE_I=1 To BLC_NBR
  If BLC_STY(WE_I)<>"" and !find(BLC_STY(WE_I),WE_STY(1..WE_NBSTY))
    WE_NBSTY+=1
    WE_STY(WE_NBSTY)=BLC_STY(WE_I)
  Endif
  If BLC_TYP(WE_I)=1
    WE_J=find(BLC_BAS(WE_I),LIG_ZON(WE_I,1..LIG_NBR(WE_I)))
    If WE_J > 0 and LIG_SAI(WE_I,WE_J)=3 : BLC_TYP(WE_I)=5 : Endif
  Endif
Next WE_I


If(not(ISJSONONLY) or ISVT)
  # Calcul des dimensions ûˋcrans (dupliquûˋ de VALMSKSRM)
  MAXX = 0
  MAXY = 0
  MINX = 80
  MINY = 21
  For WE_1=1 To BLC_NBR
   If BLC_TYP(WE_1)<>5 & BLC_TYP(WE_1)<>10
    MAXX = max(MAXX,BLC_X(WE_1)+BLC_NCO(WE_1))
    MAXY = max(MAXY,BLC_Y(WE_1)+BLC_NLI(WE_1))
    MINX = min(MINX,BLC_X(WE_1))
    MINY = min(MINY,BLC_Y(WE_1))
   Endif
  Next WE_1


  # Calcul des dimensions ûˋcrans pour haute rûˋsolution
  Local Integer MAXX1,MAXY1,MINX1,MINY1,MAXX2,MINX2
  MAXX1 = 0 : MAXX2=0
  MAXY1 = 0
  MINX1 = 80 : MINX2=80
  MINY1 = 21
  For WE_1=1 To BLC_NBR
   If BLC_TYP(WE_1)<>5 & BLC_TYP(WE_1)<>10
    MAXX1 = max(MAXX1,BLC_X1(WE_1)+BLC_NCO1(WE_1))
    MAXX2 = max(MAXX2,BLC_X2(WE_1)+BLC_NCO2(WE_1))
    MAXY1 = max(MAXY1,BLC_Y1(WE_1)+BLC_NLI1(WE_1))
    MINX1 = min(MINX1,BLC_X1(WE_1))
    MINX2 = min(MINX2,BLC_X2(WE_1))
    MINY1 = min(MINY1,BLC_Y1(WE_1))
   Endif
  Next WE_1

Endif

#  Sûˋquence de numûˋrotation des adxid et d'ûˋclatement des champs dimensionnûˋs

TET_IDX=0
For WE_I=1 To BLC_NBR
  WE_BLCR(WE_I)=BLC_RNG(WE_I)
Next WE_I
Sorta WE_BLCR
For WE_J=1 To BLC_NBR
  WE_NOBL=find(WE_BLCR(WE_J),BLC_RNG(1..BLC_NBR))
  If BLC_TYP(WE_NOBL)=0 or BLC_TYP(WE_NOBL)=5 : Goto $WE_SUIN : Endif
  WE_IDB+=1
  BLC_IDX(WE_NOBL)= WE_IDB*256
  If BLC_TYP(WE_NOBL)=1 :   BLC_IDXT(WE_NOBL)= (WE_IDB+128)*256 : Endif
  WE_IDC=0
  For WE_I=1 To MAXLIG
    If LIG_ZON(WE_NOBL,WE_I)="" : Break 1 : Endif
    If LIG_STY(WE_NOBL,WE_I)<>"" and !find(LIG_STY(WE_NOBL,WE_I),WE_STY(1..WE_NBSTY))
      WE_NBSTY+=1
      WE_STY(WE_NBSTY)=LIG_STY(WE_NOBL,WE_I)
    Endif
    If LIG_STZ(WE_NOBL,WE_I)<>"" and !find(LIG_STZ(WE_NOBL,WE_I),WE_STY(1..WE_NBSTY))
      WE_NBSTY+=1
      WE_STY(WE_NBSTY)=LIG_STZ(WE_NOBL,WE_I)
    Endif
    If LIG_STC(WE_NOBL,WE_I)<>""
      Filter [ASL] Where COD=LIG_STC(WE_NOBL,WE_I)
      For [ASL]
        If !find([F:ASL]STY,WE_STY(1..WE_NBSTY))
          WE_NBSTY+=1
          WE_STY(WE_NBSTY)=[F:ASL]STY
        Endif
      Next
      Filter [ASL]
    Endif
# Pour virer le "NUMLIG" dans les tableaux
#    If BLC_TYP(WE_NOBL)=1 and (WE_I=1 or WE_I=2) & LIG_TYP(WE_NOBL,WE_I)="C" & LIG_SAI(WE_NOBL,WE_I)=2
#      LIG_FTY(WE_NOBL,WE_I) = "-N"
#      LIG_SAI(WE_NOBL,WE_I) = 3
#    Endif
    If (LIG_SAI(WE_NOBL,WE_I)<=2 or (LIG_SAI(WE_NOBL,WE_I)=3 and LIG_TRF(WE_NOBL,WE_I)=2)
&      or BLC_TYP(WE_NOBL)=4)  and LIG_TYP(WE_NOBL,WE_I)<>"W"
      WE_IDC+=1 : LIG_IDX(WE_NOBL,WE_I)=BLC_IDX(WE_NOBL)+WE_IDC
      If LIG_DIM(WE_NOBL,WE_I)>1 and BLC_TYP(WE_NOBL)<>1 and LIG_DUP(WE_NOBL,WE_I)=0
        Gosub WE_DUPFIELD
      Endif
    Endif
  Next WE_I
  BLC_NBC(WE_NOBL)=WE_IDC
$WE_SUIN
Next WE_J

If ISVT : Gosub VT_CONTVT : Endif

# --------------------------------------------------------------------------------
#                 Pilotage gûˋnûˋral
#



If(not(ISJSONONLY) or ISVT)
  # Ouverture fichier XML produit

  Call NAMEFIC(APPLI,"SCRN","",MASQUE,WE_NOMFIC) From INTRUTILA
  Openo WE_NOMFIC,0 Using [HTM_]
  Iomode adxifs "" Using [HTM_]
  Iomode adxirs chr$(10) Using [HTM_]
  Iomode adxium GUTF8 Using [HTM_]
Endif

#  Tri les blocs par ligne/colonne
For WE_I=1 To BLC_NBR
  WE_POS=1
  If BLC_TYP(WE_I)<>0 and BLC_TYP(WE_I)<>5     : # Ni invisible ni inactif
    WE_T1=BLC_NOL(WE_I)+BLC_PDH(WE_I)-1
    If WE_T1>WE_MBLIG : WE_MBLIG=WE_T1 : Endif
    WE_T1=BLC_NOC(WE_I)+BLC_PDS(WE_I)-1
    If WE_T1>WE_MBCOL : WE_MBCOL=WE_T1 : Endif
    For WE_J=1 To BLC_NBR
      If BLC_TYP(WE_J)<>0 and BLC_TYP(WE_J)<>5 and WE_J<>WE_I
        If BLC_NOL(WE_I)>BLC_NOL(WE_J) or (BLC_NOL(WE_I)=BLC_NOL(WE_J) and BLC_NOC(WE_I)>BLC_NOC(WE_J))
          WE_POS+=1
        Endif
      Endif
    Next WE_J
    WE_BPOS(WE_POS)=WE_I
  Endif
Next WE_I


If(not(ISJSONONLY) or ISVT)
  # Ecriture En-tûˆte ûˋcran
  WE_VALL1='<?xml version="1.0" encoding="utf-8" ?>'
  Wrseq WE_VALL1 Using [HTM_]
  Gosub WECR_SCREEN


  #  Pilotage de l'ûˋcriture des blocs
  For WE_BL=1 To BLC_NBR
    WE_NOBL=WE_BPOS(WE_BL)
    If WE_NOBL=0 : Break 1 : Endif
    If BLC_TYP(WE_NOBL)=0 or BLC_TYP(WE_NOBL)=5 : Goto WE_NEXTBLOC : Endif
    If BLC_NOL(WE_NOBL)<>WE_BLICOU
      If WE_BLICOU<>0 : Gosub WECR_FLIGBLOC : Endif
      Gosub WECR_LIGBLOC
    Endif
    If BLC_TYP(WE_NOBL)=1
      Gosub WETABLEAU
      Gosub WECR_FGRID
    Elsif BLC_TYP(WE_NOBL)=4     : # Bloc texte
      Gosub WEBTEXTE
    Else
      Gosub WELISTE
    Endif
    Gosub WECR_FFRAME
  $WE_NEXTBLOC
  Next WE_BL

  If WE_BLICOU<>0 : Gosub WECR_FLIGBLOC : Endif
  Gosub WECR_DATS
  Gosub WECR_STYL
  Gosub WECR_FSCREEN

  Openo Using [HTM_]
  If ISVT : Gosub VT_ECRVISU : Endif
Endif

#  Mise û  jour des liens
If adxlog=0
  Trbegin [AEL],[AEK]
  WE_TREC=1
Endif
Gosub WI_CRESCRN From INTRUTILB
If WE_TREC=1 : Commit : Endif


#  On redefinit les blocs tableaux ou le champ NBLIG est invisible

For WE_I=1 To BLC_NBR
  If BLC_TYP(WE_I)=5 and BLC_BAS(WE_I)<>""
    BLC_TYP(WE_I)=1
  Endif
Next WE_I


Gosub JSON From VALMSKJSON
Return


$WECR_XD1
  WE_1=BLC_IDX(WE_NOBL)/256
  WE_PROP="XD1"
  WE_VALUE=mid$(WE_ALPHAB,WE_1,1)
  WE_1=LIG_IDX(WE_NOBL,WE_F)-BLC_IDX(WE_NOBL)
  WE_VALUE+=num$(WE_1)
  Gosub WE_ADDPROP
Return


$WECR_DATS
  WE_VALL1="<DATS" : Gosub WE_FINF
  WE_1=0
  For WE_NOBL=1 To BLC_NBR
    If BLC_TYP(WE_NOBL)<>0 and BLC_TYP(WE_NOBL)<>5     : # Ni invisible ni inactif
      WE_VALL1="<ds"
      WE_1=BLC_IDX(WE_NOBL)/256
#      WE_1+=1
      WE_BCOU=mid$(WE_ALPHAB,WE_1,1)
      WE_PROP="ID" : WE_VALUE=WE_BCOU : Gosub WE_ADDPROP : Gosub WE_FINF
      WE_J=0
      For WE_CH=1 To WE_MAXFB(WE_NOBL)
        WE_J=find(WE_NOBL*1000+WE_CH,WE_CHCOMB(1,1..WE_NBCHC))
        WE_VALL1="<"+WE_BCOU+num$(WE_CH)
        If WE_J<>0
          If WE_CHCOMB(2,WE_J)>0 & LIG_LIB(WE_NOBL,WE_CHCOMB(2,WE_J))>0
            WE_PROP="MEN" : WE_VALUE=num$(LIG_LIB(WE_NOBL,WE_CHCOMB(2,WE_J))) : Gosub WE_ADDPROP
            If LIG_GRA(WE_NOBL,WE_CHCOMB(2,WE_J))<=1     : # Champ en combo
              WE_PROP="TYP" : WE_VALUE="7" : Gosub WE_ADDPROP
            Endif
          Else
            WE_PROP="TYP" : WE_VALUE="17" :
            If BLC_TYP(WE_NOBL)=7
              WE_VALUE="33" : Gosub WE_ADDPROP
              WE_PROP="GTY"
              Case BLC_TYPG(WE_NOBL)
                When 1 :  WE_VALUE="8"     : # Word
                When 2 :  WE_VALUE="7"     : # Excel
                When 3 :  WE_VALUE="10"     : # Power point
                When Default :  WE_VALUE="9"     : # Banalisûˋ (choix 4 en fait)
              Endcase
              Gosub WE_ADDPROP
            Else
              Gosub WE_ADDPROP
            Endif
          Endif
        Endif
        Gosub WE_FINFF
      Next WE_CH
      WE_VALL1="</ds"  : Gosub WE_FINF
    Endif
  Next WE_NOBL
  WE_VALL1="</DATS" : Gosub WE_FINF
Return

$WECR_STYL
  If WE_NBSTY=0 : Return : Endif
  WE_VALL1="<STYL" : Gosub WE_FINF
  For WE_I=1 To WE_NBSTY
    WE_VALL1='<S V="'+WE_STY(WE_I)+'"/' : Gosub WE_FINF
  Next WE_I
  WE_VALL1="</STYL" : Gosub WE_FINF
Return

# --------------------------------------------------------------------------------
#                Pilotage de l'ûˋcriture des champs û  l'intûˋrieur des blocs


#  Traite les champs du bloc tableau WE_NOBL
$WETABLEAU
  WE_TCOL=0 : # Calcul de la taille rûˋelle des champs dans le bloc tableau (Abel)
  For WE_F=1 To LIG_NBR(WE_NOBL)
    If LIG_SAI(WE_NOBL,WE_F)<=2
      WE_TCOL+=LIG_FLN(WE_NOBL,WE_F)
    Endif
  Next WE_F
  WE_TCOL=WE_TCOL*1.2+10
  If ISVT : Gosub VT_CALTAB : Endif
  Gosub WECR_FRAME
  Gosub WECR_GRID
  WE_RANK=0
  For WE_F=1 To LIG_NBR(WE_NOBL)
    If LIG_SAI(WE_NOBL,WE_F)<=2 or (LIG_SAI(WE_NOBL,WE_F)=3 and LIG_TRF(WE_NOBL,WE_F)=2)
      Gosub WECR_GCOL
      WE_RANK+=1
    Endif
  Next WE_F
Return



#  Traite les champs du bloc texte WE_NOBL
$WEBTEXTE
Raz WE_TBL,WE_NBLI,WE_LIGC,WE_ITBL,WE_L,WE_TLI,WE_FINF,WE_IND

#                                    : # No de ligne pour les lignes de champ
  For WE_CH=1 To LIG_NBR(WE_NOBL)
    WE_LIGC=int(LIG_NUM(WE_NOBL,WE_CH))
    For WE_4=WE_L+1 To WE_LIGC
      WE_ITBL+=1 : WE_TBL(WE_ITBL)="LIGF" : WE_IND(WE_ITBL)=WE_LIGC
      If WE_4 <> WE_LIGC : WE_FINF=1 : Endif
    Next WE_4
    WE_L=WE_LIGC
    WE_ITBL+=1 : WE_TBL(WE_ITBL)="CAPTION" : WE_TLI(WE_ITBL)=WE_CH
    WE_ITBL+=1 : WE_TBL(WE_ITBL)="FLIGF" : WE_IND(WE_ITBL)=WE_LIGC
  Next WE_CH
  Gosub WECR_FRAME
  For WE_I=1 To WE_ITBL
    Case WE_TBL(WE_I)
      When "LIGF"     : Gosub WECR_LIGF
      When "FLIGF"    : Gosub WECR_FLIGF
      When "CAPTION"  : WE_F=WE_TLI(WE_I) : Gosub WECR_CAPTION
      When Default    : Gosub WE_ERR
    Endcase
  Next WE_I
Return

#  Traite les champs du bloc liste WE_NOBL
$WELISTE
  Gosub WETRIFIELD
  If ISVT : Gosub VT_CALBLOC : Endif
  Gosub WECR_FRAME
  For WE_I=1 To WE_ITBL
    Case WE_TBL(WE_I)
      When "LIGF"     : Gosub WECR_LIGF
      When "FLIGF"    : Gosub WECR_FLIGF
      When "FIELD"    : Gosub WECR_FIELD
      When "FFIELD"   : Gosub WECR_FFIELD
      When "AREA"     : Gosub WECR_AREA
      When "FAREA"    : Gosub WECR_FAREA
      When "AREA1"    : Gosub WECR_AREA1
      When "FAREA1"   : Gosub WECR_FAREA1
      When "CAPTION"  : WE_F=WE_TLI(WE_I) : Gosub WECR_CAPTION
      When "FCAPTION" : Gosub WECR_FCAPTION
      When "EMPTY"    : Gosub WECR_EMPTY
      When "FEMPTY"   : Gosub WECR_FEMPTY
      When "GRADIO"   : Gosub WECR_GRADIO
      When "FGRADIO"  : Gosub WECR_FGRADIO
      When "RADIO"    : Gosub WECR_RADIO
      When "FRADIO"   : Gosub WECR_FRADIO
      When Default    : Gosub WE_ERR
    Endcase
  Next WE_I
Return


#  Rend 1 si il y a des actions clic droit sur le champ (0 sinon)
$WE_ISRCLIC:
  WE_ISRC=0
  If LIG_ACT(WE_NOBL,WE_F)=0 : Return : Endif
  For WE_AC=LIG_PTA(WE_NOBL,WE_F) To LIG_PTA(WE_NOBL,WE_F)+LIG_ACT(WE_NOBL,WE_F)-1
    If (ACT_TYP(WE_AC) >= 8 and ACT_TYP(WE_AC)<=12) or (ACT_TYP(WE_AC)>=15 and ACT_TYP(WE_AC)<=30) or
&       ACT_ACT(WE_AC)="%TABSEL" or ACT_ACT(WE_AC)="%SELOBJ" or
&       ACT_ACT(WE_AC)="%SELAVA" or ACT_ACT(WE_AC)="%PROOBJ" or ACT_ACT(WE_AC)="%TUNOBJ"
      WE_ISRC=1
      Break 1
    Endif
  Next WE_AC
#  If WE_ISRC=0 and LIG_AID(WE_NOBL,WE_F)<>"" : WE_ISRC=2 : Endif
Return


#  Traite les actions RCLIC du champ WE_F du bloc WE_BL
#  Ferme le tag FIELD ou GRADIO ouvert
$WE_ACTIONS
  If LIG_ACT(WE_NOBL,WE_F)=0 : Return : Endif
  Gosub WECR_RCLIC
  For WE_AC=LIG_PTA(WE_NOBL,WE_F) To LIG_PTA(WE_NOBL,WE_F)+LIG_ACT(WE_NOBL,WE_F)-1
    If (ACT_TYP(WE_AC) >= 8 and ACT_TYP(WE_AC)<=12) or ACT_TYP(WE_AC)>15 or
&       ACT_ACT(WE_AC)="%TABSEL" or ACT_ACT(WE_AC)="%SELOBJ" or
&       ACT_ACT(WE_AC)="%SELAVA" or ACT_ACT(WE_AC)="%PROOBJ" or ACT_ACT(WE_AC)="%TUNOBJ"
      Gosub WECR_ACTION
    Endif
  Next WE_AC
  If LIG_AID(WE_NOBL,WE_F)<>"" : Gosub WECR_ACTIONA : Endif
  Gosub WECR_FRCLIC
Return


# ----------------------------------------------------------------------------------
#                     Tri des champs dans les blocs listes


$WETRIFIELD
#  On traite le bloc WE_NOBL
#  On ne s'interesse qu'aux champs visibles

Local Integer WE_MAXLIG            : # Nombre de lignes du bloc
Local Integer WE_MAXCOL            : # Nombre de cellules d'une ligne du bloc
Local Integer WE_COL(1..LIGMAX)    : # Nombre de cellules dûˋjû  attribuûˋes sur la ligne I
Local Integer WE_NBLI,WE_LIGC
Local Integer WE_ISC               : # Le champ courant a-t-il un caption (1 Oui, 0 Non)
Local Integer WE_P                 : # Poids de l'ûˋlûˋment courant en nombre de cellules
Local Integer WE_L                 : # Ligne en cours de traitement
Local Integer WE_MAT(1..COLMAX,1..LIGMAX) : # Matrice des champs occupûˋs (0 libre, 1 occupûˋ, 2 occupûˋ rûˋpûˋtitif)
Local Integer WE_VERTI             : # =1 si boutons verticaux

# Phase 1 : On recherche le nombre de lignes et le max de colonnes par ligne
#           On positionne la matrice des champs occupûˋs
For WE_CH=1 To LIG_NBR(WE_NOBL)
  If LIG_SAI(WE_NOBL,WE_CH)=1 or LIG_SAI(WE_NOBL,WE_CH)=2
#&     or (LIG_SAI(WE_NOBL,WE_CH)=3 and LIG_TRF(WE_NOBL,WE_CH)=2)
#and LIG_TYP(WE_NOBL,WE_CH)<>"W"
    WE_ISC=0
    WE_LIGC=int(LIG_NUM(WE_NOBL,WE_CH))
    WE_L=WE_LIGC
    WE_MAXLIG=max(WE_LIGC,WE_MAXLIG)
    WE_P=1+max(LIG_PDS(WE_NOBL,WE_CH)-1,0)
    WE_COL(WE_LIGC)+=WE_P
    If LIG_GRA(WE_NOBL,WE_CH)>1 and LIG_GRA(WE_NOBL,WE_CH)<>10
      If LIG_GRA(WE_NOBL,WE_CH)=3 or LIG_GRA(WE_NOBL,WE_CH)=4 : #  Boutons verticaux
        Gosub WE_RESCEL
   #     WE_NBLI=len(mess(0,LIG_LIB(WE_NOBL,WE_CH),1))
        WE_NBLI=func APLSTD.LENMEN(APPLI,LIG_LIB(WE_NOBL,WE_CH))
        If LIG_GRA(WE_NOBL,WE_CH)=3 : WE_NBLI+=2 : Endif   : # On rûˋserve 2 lignes si il y a des cadres V
        WE_MAXLIG=max(WE_LIGC+WE_NBLI-1,WE_MAXLIG)
        WE_VERTI=1
        For indice=WE_LIGC+1 To WE_LIGC+WE_NBLI-1
          WE_COL(indice)+=1+max(LIG_PDS(WE_NOBL,WE_CH)-1,0)
          WE_L=indice : Gosub WE_RESCEL
        Next indice
        WE_VERTI=0
     Elsif LIG_GRA(WE_NOBL,WE_CH)=5 or LIG_GRA(WE_NOBL,WE_CH)=6  : #  Boutons horizontaux
     #   WE_COL(WE_LIGC)+=len(mess(0,LIG_LIB(WE_NOBL,WE_CH),1))-1
        WE_COL(WE_LIGC)+=func APLSTD.LENMEN(APPLI,LIG_LIB(WE_NOBL,WE_CH))-1

   #     WE_P+=len(mess(0,LIG_LIB(WE_NOBL,WE_CH),1))-1
        WE_P+=func APLSTD.LENMEN(APPLI,LIG_LIB(WE_NOBL,WE_CH))-1

        Gosub WE_RESCEL
      Elsif LIG_GRA(WE_NOBL,WE_CH)>=7     : #  Objets graphiques
        If LIG_TIT(WE_NOBL,WE_CH)<>0 or LIG_EVL(WE_NOBL,WE_CH)<>""
          WE_COL(WE_LIGC)+=1 : WE_P+=1 : WE_ISC=1
        Endif
        Gosub WE_RESCEL
        WE_NBLI=LIG_GP1(WE_NOBL,WE_CH)
        WE_MAXLIG=max(WE_LIGC+WE_NBLI-1,WE_MAXLIG)
        For indice=WE_LIGC+1 To WE_LIGC+WE_NBLI-1
          WE_COL(indice)+=1+max(LIG_PDS(WE_NOBL,WE_CH)-1,0)
          WE_L=indice : Gosub WE_RESCEL
        Next indice
      Elsif LIG_GRA(WE_NOBL,WE_CH)=2     : #  Check Box
        Gosub WE_RESCEL
      Endif
    Else  #  On rajoute une colonne pour l'intitulûˋ dans les autres cas
      If (LIG_TIT(WE_NOBL,WE_CH)<>0 or LIG_EVL(WE_NOBL,WE_CH)<>"") and LIG_TYP(WE_NOBL,WE_CH)<>"W"
        WE_COL(WE_LIGC)+=1 : WE_P+=1 : WE_ISC=1
      Endif
      Gosub WE_RESCEL
    Endif
  Endif
Next WE_CH
WE_MAXCOL=max(WE_COL(1..COLMAX))


# Phase 2 : On dûˋfinit la structure de pilotage, et on affecte les spans

#  Prûˋparation des input
Local Char WE_TBL(10)(1..WE_DIMBL)        : # Type d'input
#               LIGF, FLIGF     : Ligne de champ, Fin de ligne de champs
#               AREA, FAREA     : Zone de regroupement (champs collûˋs), fin de zone
#               FIELD, FFIELD   : Champ, Fin de champ
#               GRADIO, FGRADIO : Groupe de boutons radio
#               CAPTION         : Intitulûˋ de champ
#               EMPTY           : Cellule vide (pour les cadrages en Web)
#               RADIO           : Radio bouton (fils de FIELD)
#
Local Integer WE_TLI(1..WE_DIMBL)    : # Indice en correspondance dans la table des champs
Local Integer WE_COLSP(1..WE_DIMBL)  : # Colspan de l'ûˋlûˋment
Local Integer WE_ROWSP(1..WE_DIMBL)  : # Rowspan de l'ûˋlûˋment (pour les AREA uniquement)
Local Integer WE_FINF(1..WE_DIMBL)   : # =1 Si il faut fermer le tag
Local Integer WE_CAP(1..WE_DIMBL)    : # =1 Si le caption du field n'est pas û  traiter (AREA)
Local Integer WE_COLLE(1..WE_DIMBL)  : # =1 Si regroupement de champs (sur FIELD et AREA)
Local Integer WE_IND(1..WE_DIMBL)    : # Indice (pour les radio boutons ou pour les champs dimensionnûˋs)
#                                    : # No de ligne pour les lignes de champ
Local Integer WE_ITBL                : # Indice courant dans les tables de pilotage
Local Integer WE_NFIELD              : # Indice du champ liûˋ suivant dans la ligne (0 si il n'y en a pas)
Local Integer WE_AEC                 : # Area ouverte
Local Integer WE_RCOL                : # Nombre de colonnes restant û  attribuer sur la ligne courante
Local Integer WE_LAST                : # Dernier ûˋlûˋment d'une ligne pouvant recevoir les span
Local Integer WE_PREM                : # Premier champ de la ligne (1 Oui)
Local Integer WE_ISCAPV              : # Vient-on de traiter un bouton vertical

WE_LIGC=1
WE_ITBL+=1 : WE_TBL(WE_ITBL)="LIGF" : WE_IND(WE_ITBL)=WE_LIGC
For WE_CH=1 To LIG_NBR(WE_NOBL)
  WE_PREM=0
  If WE_CH=1 : WE_PREM=1 : Endif
  If  LIG_SAI(WE_NOBL,WE_CH)=1 or LIG_SAI(WE_NOBL,WE_CH)=2
&     or (LIG_SAI(WE_NOBL,WE_CH)=3 and LIG_TRF(WE_NOBL,WE_CH)=2)
#and LIG_TYP(WE_NOBL,WE_CH)<>"W"
#& or (LIG_TYP(WE_NOBL,WE_CH)="W" and int(LIG_NUM(WE_NOBL,WE_CH))<=WE_MAXLIG)
#  Terminaison de ligne
    If int(LIG_NUM(WE_NOBL,WE_CH))>WE_LIGC Then
      If WE_CH=1 or WE_ISCAPV=1 : WE_LAST=-1 : Endif   : # Pour forcer la crûˋation de tags EMPTY
      Gosub WE_TELIG
    Endif
   WE_ISCAPV=0

#  Doit-on fermer une zone groupe
    If (LIG_GRA(WE_NOBL,WE_CH)>2 and LIG_GRA(WE_NOBL,WE_CH)<>10 and LIG_GRA(WE_NOBL,WE_CH)<>13)
&       or LIG_PDS(WE_NOBL,WE_CH)>0
      Gosub WE_FINZG
    Endif

#  On traite un champ de type W
    If LIG_TYP(WE_NOBL,WE_CH)="W"
      WE_ITBL+=1 : WE_TBL(WE_ITBL)="EMPTY" : WE_TLI(WE_ITBL)=WE_CH
      WE_COLSP(WE_ITBL)=max(LIG_PDS(WE_NOBL,WE_CH),1)
      Goto WE_NTB
    Endif

#  Doit-on crûˋer une AREA pour champs regroupûˋs ?
#  Oui, Si le champ suivant sur la ligne a un poids û  0 et pas d'intitulûˋ
    Gosub WE_NEXTF   :  # Recherche le champ liûˋ suivant sur la ligne
    If  WE_AEC=0 and WE_NFIELD>0
      Gosub WE_FINZG
#  On sort l'intitulûˋ de la zone qui porte le lien sauf si c'est un champ graphique
      If (LIG_GRA(WE_NOBL,WE_CH)<2 or LIG_GRA(WE_NOBL,WE_CH)>12)
        WE_ITBL+=1 : WE_TBL(WE_ITBL)="CAPTION" : WE_TLI(WE_ITBL)=WE_CH
      Endif
      If LIG_DIM(WE_NOBL,WE_CH)>1 : WE_IND(WE_ITBL)=max(1,LIG_DUP(WE_NOBL,WE_CH)) : Endif
      WE_ITBL+=1 : WE_TBL(WE_ITBL)="AREA" : WE_AEC=1 : WE_LAST=WE_ITBL
      WE_COLLE(WE_ITBL)=1
      WE_ITBL+=1 : WE_TBL(WE_ITBL)="LIGF" : : WE_IND(WE_ITBL)=1
      WE_CAP(WE_ITBL+1)=1     : # Pour ne pas ûˋcrire le caption du field dans l'area
    Endif

    Gosub WE_ISCAPT
    If LIG_GRA(WE_NOBL,WE_CH)>=3 and LIG_GRA(WE_NOBL,WE_CH)<=6
      WE_ITBL+=1 : WE_TBL(WE_ITBL)="AREA" : WE_TLI(WE_ITBL)=WE_CH : WE_LAST=WE_ITBL
      WE_ITBL+=1 : WE_TBL(WE_ITBL)="GRADIO" : WE_TLI(WE_ITBL)=WE_CH
      If (LIG_GRA(WE_NOBL,WE_CH)=3 or LIG_GRA(WE_NOBL,WE_CH)=4)
        WE_ISCAPV=1
#        WE_ROWSP(WE_ITBL-1)=len(mess(0,LIG_LIB(WE_NOBL,WE_CH),1))
        WE_ROWSP(WE_ITBL-1)=func APLSTD.LENMEN(APPLI,LIG_LIB(WE_NOBL,WE_CH))
        If LIG_GRA(WE_NOBL,WE_CH)=3 : WE_ROWSP(WE_ITBL-1)+=2 : Endif : # Force 2 lignes de cadre
        WE_LAST=-1    : # Pour forcer la crûˋation de tags EMPTY
        WE_COLSP(WE_ITBL-1)=LIG_PDS(WE_NOBL,WE_CH)
     #   For indice=1 To len(mess(0,LIG_LIB(WE_NOBL,WE_CH),1))
        WLG=func APLSTD.LENMEN(APPLI,LIG_LIB(WE_NOBL,WE_CH))
        For indice=1 To WLG
          WE_ITBL+=1 : WE_TBL(WE_ITBL)="LIGF" : WE_TLI(WE_ITBL)=WE_CH : WE_IND(WE_ITBL)=indice
          WE_ITBL+=1 : WE_TBL(WE_ITBL)="RADIO" : WE_TLI(WE_ITBL)=WE_CH : WE_IND(WE_ITBL)=indice
          WE_ITBL+=1 : WE_TBL(WE_ITBL)="FLIGF" : WE_TLI(WE_ITBL)=WE_CH
        Next indice
      Else
     #   WE_COLSP(WE_ITBL-1)=len(mess(0,LIG_LIB(WE_NOBL,WE_CH),1))+max(LIG_PDS(WE_NOBL,WE_CH)-1,0)
        WE_COLSP(WE_ITBL-1)=func APLSTD.LENMEN(APPLI,LIG_LIB(WE_NOBL,WE_CH))+max(LIG_PDS(WE_NOBL,WE_CH)-1,0)

        WE_ITBL+=1 : WE_TBL(WE_ITBL)="LIGF" : WE_TLI(WE_ITBL)=WE_CH : WE_IND(WE_ITBL)=1
   #     For indice=1 To len(mess(0,LIG_LIB(WE_NOBL,WE_CH),1))
        WLG=func APLSTD.LENMEN(APPLI,LIG_LIB(WE_NOBL,WE_CH))
        For indice=1 To WLG
          WE_ITBL+=1 : WE_TBL(WE_ITBL)="RADIO" : WE_TLI(WE_ITBL)=WE_CH : WE_IND(WE_ITBL)=indice
        Next indice
        WE_ITBL+=1 : WE_TBL(WE_ITBL)="FLIGF" : WE_TLI(WE_ITBL)=WE_CH
      Endif
      WE_ITBL+=1 : WE_TBL(WE_ITBL)="FAREA" : WE_TLI(WE_ITBL)=WE_CH
    Elsif LIG_GRA(WE_NOBL,WE_CH)>=7 and LIG_GRA(WE_NOBL,WE_CH)<>10
&         and left$(LIG_FTY(WE_NOBL,WE_CH),3)<>"KIL"
&         and left$(LIG_FTY(WE_NOBL,WE_CH),3)<>"KIB"       : # Champ graphique
      WE_ITBL+=1 : WE_TBL(WE_ITBL)="AREA1" : WE_TLI(WE_ITBL)=WE_CH : WE_LAST=WE_ITBL
      WE_COLSP(WE_ITBL)=LIG_PDS(WE_NOBL,WE_CH)
      WE_ITBL+=1 : WE_TBL(WE_ITBL)="FIELD" : WE_TLI(WE_ITBL)=WE_CH
      WE_ITBL+=1 : WE_TBL(WE_ITBL)="FAREA1" : WE_TLI(WE_ITBL)=WE_CH
    Else
        WE_ITBL+=1 : WE_TBL(WE_ITBL)="FIELD" : WE_TLI(WE_ITBL)=WE_CH
        If LIG_DIM(WE_NOBL,WE_CH)>1 : WE_IND(WE_ITBL)=max(1,LIG_DUP(WE_NOBL,WE_CH)) : Endif
        If WE_AEC=0
          WE_COLSP(WE_ITBL)=LIG_PDS(WE_NOBL,WE_CH)
          If LIG_PDS(WE_NOBL,WE_CH)=0 and WE_PREM=1 : WE_COLSP(WE_ITBL)=1 : Endif
          WE_LAST=WE_ITBL
        Else    :#  C'est l'area qui porte les span
          If WE_LAST>0
            WE_COLSP(WE_LAST)+=max(LIG_PDS(WE_NOBL,WE_CH),1)
          Else
            WE_ITBL+=1 : WE_TBL(WE_ITBL)="EMPTY" : WE_COLSP(WE_ITBL)=max(LIG_PDS(WE_NOBL,WE_CH),1)
          Endif
          WE_COLLE(WE_ITBL)=1  : # C'est un champ collûˋ
        Endif
    Endif
  Endif
$WE_NTB
Next WE_CH

#  ------------    Ferme la ligne courante (fin de traitement bloc liste)
Gosub WE_FINZG
If WE_LAST<>0
  Gosub WE_COLREST
  If WE_LAST>0
    WE_COLSP(WE_LAST)+=WE_RCOL
  Else
    If WE_RCOL>0
      WE_ITBL+=1 : WE_TBL(WE_ITBL)="EMPTY" : WE_COLSP(WE_ITBL)=WE_RCOL
    Endif
  Endif
Endif
WE_ITBL+=1 : WE_TBL(WE_ITBL)="FLIGF"
  For indice=WE_LIGC+LIG_FLI(WE_NOBL,WE_CH) To WE_MAXLIG
    WE_ITBL+=1 : WE_TBL(WE_ITBL)="LIGF" : WE_IND(WE_ITBL)=indice
    WE_LIGC=indice
    Gosub WE_RCOL1
    WE_ITBL+=1 : WE_TBL(WE_ITBL)="FLIGF"
  Next indice

Return

#  ------------    Combien reste-t-il de cellules vides dans la ligne
$WE_RCOL1
  WE_RCOL=0
  For WE_4=WE_MAXCOL To 1 Step -1
    If WE_MAT(WE_4,WE_LIGC)=0
       WE_RCOL+=1
    Endif
  Next WE_4
  If WE_RCOL>0
    WE_ITBL+=1 : WE_TBL(WE_ITBL)="EMPTY" : WE_COLSP(WE_ITBL)=WE_RCOL
  Endif
Return


#If adxusr="ccora"
#  For indice=1 To WE_ITBL
#    Infbox(num$(indice)-WE_TBL(indice)-"TLI:"+num$(WE_TLI(indice))-"COL:"+num$(WE_COLSP(indice))
#&   -"ROW:"+num$(WE_ROWSP(indice))-"IND:"+num$(WE_IND(indice)))
#  Next indice
#Endif





# Rûˋservation de cellule
$WE_RESCEL
  WE_ATT=max(1,LIG_POS(WE_NOBL,WE_CH)-WE_ISC)
  For WE_T3=WE_ATT To WE_ATT+WE_P-1
    Gosub WE_ATTRIB
  Next WE_T3
Return

#  Attribution de cellule
$WE_ATTRIB
  For WE_T5=WE_T3 To COLMAX
    If WE_MAT(WE_T5,WE_L)=0
      WE_MAT(WE_T5,WE_L)=1+WE_VERTI
      Break 1
    Endif
  Next WE_T5
Return


#  ------------    Fin des zones groupes AREA
$WE_FINZG
  If WE_AEC=1
    WE_ITBL+=1 : WE_TBL(WE_ITBL)="FLIGF"
    WE_ITBL+=1 : WE_TBL(WE_ITBL)="FAREA"
    WE_AEC=0
  Endif
Return


#  ------------    Retourne 1 si le champ WE_CH a un caption et est visible
$WE_ISCAPT:
  WE_ISC=0
  If LIG_TIT(WE_NOBL,WE_CH)<>0 or LIG_EVL(WE_NOBL,WE_CH)<>"" : WE_ISC=1 : Endif
  If LIG_SAI(WE_NOBL,WE_CH)>=3 : WE_ISC=0 : Endif
Return



#  ------------    Dûˋtermine l'indice du champ liûˋ suivant sur la ligne
$WE_NEXTF:
  WE_NFIELD=0
  For indice=WE_CH+1 To LIG_NBR(WE_NOBL)
    If (LIG_SAI(WE_NOBL,indice)=1 or LIG_SAI(WE_NOBL,indice)=2) and LIG_TYP(WE_NOBL,WE_CH)<>"W"
      If int(LIG_NUM(WE_NOBL,indice))<>WE_LIGC : Break 1 : Endif
#      If LIG_GRA(WE_NOBL,indice) > 1 : Break 1 : Endif
      If LIG_GRA(WE_NOBL,indice) > 2 and LIG_GRA(WE_NOBL,indice) <> 13   : Break 1 : Endif
      If LIG_PDS(WE_NOBL,indice)>0 : Break 1 : Endif
#      If LIG_TIT(WE_NOBL,indice)<>0 or LIG_EVL(WE_NOBL,indice)<>"" : Break 1 : Endif
      If (LIG_TIT(WE_NOBL,indice)<>0 or LIG_EVL(WE_NOBL,indice)<>"") and LIG_GRA(WE_NOBL,indice)<>2
        Break 1
      Endif
      WE_NFIELD=indice
      Break 1
    Endif
  Next indice
Return


#  ------------    Ferme la ligne courante et ouvre la suivante
$WE_TELIG
  WE_PREM=1
  Gosub WE_FINZG
  If WE_LAST<>0
    Gosub WE_COLREST
    If WE_LAST>0
      WE_COLSP(WE_LAST)+=WE_RCOL
    Else
      If WE_RCOL>0
        WE_ITBL+=1 : WE_TBL(WE_ITBL)="EMPTY" : WE_COLSP(WE_ITBL)=WE_RCOL
      Endif
    Endif
  Endif
If WE_CH=1 or (WE_CH>1 and LIG_GRA(WE_NOBL,WE_CH-1)<>10 and LIG_GRA(WE_NOBL,WE_CH-1)<>5)
  For indice=WE_LIGC+1 To int(LIG_NUM(WE_NOBL,WE_CH))
    WE_ITBL+=1 : WE_TBL(WE_ITBL)="FLIGF"
    WE_ITBL+=1 : WE_TBL(WE_ITBL)="LIGF" : WE_IND(WE_ITBL)=indice
    WE_LIGC=indice
    If WE_LIGC=int(LIG_NUM(WE_NOBL,WE_CH)) : WE_ISCAPV=0 : Endif
    Gosub WE_DEBCOL
  Next indice
 Else
  WE_ITBL+=1 : WE_TBL(WE_ITBL)="FLIGF"
  For indice=WE_LIGC+LIG_FLI(WE_NOBL,WE_CH-1) To int(LIG_NUM(WE_NOBL,WE_CH))-1
    WE_ITBL+=1 : WE_TBL(WE_ITBL)="LIGF" : WE_IND(WE_ITBL)=indice
    WE_LIGC=indice
    If WE_LIGC=int(LIG_NUM(WE_NOBL,WE_CH)) : WE_ISCAPV=0 : Endif
    Gosub WE_DEBCOL
    WE_ITBL+=1 : WE_TBL(WE_ITBL)="FLIGF"
  Next indice

  WE_ITBL+=1 : WE_TBL(WE_ITBL)="LIGF" : WE_IND(WE_ITBL)=int(LIG_NUM(WE_NOBL,WE_CH))
  WE_LIGC=int(LIG_NUM(WE_NOBL,WE_CH))
  WE_ISCAPV=0
  Gosub WE_DEBCOL
 Endif
Return


#  ------------    Combien reste-t-il de cellules vides en fin de lignes
$WE_COLREST
  WE_RCOL=0
  For WE_4=WE_MAXCOL To 1 Step -1
    If WE_MAT(WE_4,WE_LIGC)=0
       WE_RCOL+=1
    Else
       Break 1
    Endif
  Next WE_4
  If WE_RCOL=0 and WE_ISCAPV=1 : WE_RCOL=1 : Endif
Return


#  ------------    Y-a-t-il des cellules vides en dûˋbut de ligne
$WE_DEBCOL
  WE_RCOL=0
  For WE_4=1 To WE_MAXCOL
    If WE_MAT(WE_4,WE_LIGC)=0
       WE_RCOL+=1
    Else
       If WE_MAT(WE_4,WE_LIGC)=1 : Break 1 : Endif
    Endif
  Next WE_4
  If WE_RCOL<>0 or (WE_RCOL=0 and WE_ISCAPV=1)
    WE_ITBL+=1 : WE_TBL(WE_ITBL)="EMPTY" : WE_COLSP(WE_ITBL)=WE_RCOL
  Endif
Return

# -------------------------------------------------------------------------------
# -------------------------------------------------------------------------------
# -------------------------------------------------------------------------------
# -------------------------------------------------------------------------------
# -------------------------------------------------------------------------------
#   Ecriture par type d'ûˋlûˋment
# -------------------------------------------------------------------------------


#  1 - Type SCREEN

$WECR_SCREEN:
  # Ecriture En-tûˆte ûˋcran
  WE_VALL1="<SCRN"
  WE_PROP="NAM"       : WE_VALUE=MASQUE : Gosub WE_ADDPROP
  WE_PROP="XID"  : WE_VALUE=num$(TET_IDX) : Gosub WE_ADDPROP
  WE_PROP="TIM"  : WE_VALUE=WE_HORDAT : Gosub WE_ADDPROP
  WE_PROP="APP"   : WE_VALUE=APPLI : Gosub WE_ADDPROP
  WE_PROP="VER"  : WE_VALUE=GI_VGEN : Gosub WE_ADDPROP
  WE_NTEX=TET_TIT : WE_CAPDEF=TET_TXT : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub WE_ADDNTEX
  If TET_TAI=2
    WE_PLIG=max(0,int((MINY-1)*8))
    WE_PCOL=max(0,int((MINX-1)*4))
    WE_PROP="PLI"   : WE_VALUE="0" : Gosub WE_ADDPROP
    WE_PROP="PCO"   : WE_VALUE="0" : Gosub WE_ADDPROP
  Else
    WE_PROP="PLI"   : WE1_PLIEC=max(0,int((MINY-1)*8)) : WE_VALUE=num$(WE1_PLIEC) : Gosub WE_ADDPROP
    WE_PROP="PCO"   : WE1_PCOEC=max(0,int((MINX-1)*4)) : WE_VALUE=num$(WE1_PCOEC) : Gosub WE_ADDPROP
  Endif
  WE_PROP="NLI"  : WE1_NLIEC=max((MAXY-MINY+1)*8,10) : WE_VALUE=num$(WE1_NLIEC) : Gosub WE_ADDPROP
  WE1_NLIEC=max((MAXY-MINY)*8,10)  : # Pour les % browser  CC 04/05/2006
  WE_PROP="NCO"  : WE1_NCOEC=max((MAXX-MINX)*4,10) : WE_VALUE=num$(WE1_NCOEC) : Gosub WE_ADDPROP
  If TET_TAI=2
    WE_PLIG1=max(0,int((MINY1-1)*8))
    WE_PCOL1=max(0,int((MINX1-1)*4))
    WE_PCOL2=max(0,int((MINX2-1)*4))
    WE_PROP="PLI1"   : WE_VALUE="0" : Gosub WE_ADDPROP
    WE_PROP="PCO1"   : WE_VALUE="0" : Gosub WE_ADDPROP
    WE_PROP="PCO2"   : WE_VALUE="0" : Gosub WE_ADDPROP
  Else
    WE_PROP="PLI1"   : WE_VALUE=num$(max(0,int((MINY1-1)*8))) : Gosub WE_ADDPROP
    WE_PROP="PCO1"   : WE_VALUE=num$(max(0,int((MINX1-1)*4))) : Gosub WE_ADDPROP
    WE_PROP="PCO2"   : WE_VALUE=num$(max(0,int((MINX2-1)*4))) : Gosub WE_ADDPROP
  Endif
  WE_PROP="NLI1"  : WE_VALUE=num$(max((MAXY1-MINY1+1)*8,10)) : Gosub WE_ADDPROP
  WE_PROP="NCO1"  : WE_VALUE=num$(max((MAXX1-MINX1)*4,10)) : Gosub WE_ADDPROP
  WE_PROP="NCO2"  : WE_VALUE=num$(max((MAXX2-MINX2)*4,10)) : Gosub WE_ADDPROP
  WE_PROP="MXL"   : WE_VALUE=num$(WE_MBLIG) : Gosub WE_ADDPROP
  WE_PROP="MXC"   : WE_VALUE=num$(WE_MBCOL) : Gosub WE_ADDPROP
  WE_PROP="SML"   : WE_VALUE=num$(max((MAXY-MINY)*8,10)) : Gosub WE_ADDPROP
  If ISVT    : Gosub VT_ESCR  : Endif #   Terminaux VT
  Gosub WE_FINF
Return

$WECR_FSCREEN:
  # Ecriture Fin En-tûˆte ûˋcran
  WE_VALL1="</SCRN"
  Gosub WE_FINF
Return

# -------------------------------------------------------------------------------
#  2 - Type LIGBLOC

$WECR_LIGBLOC
  # Ecriture Ligne de bloc
  If BLC_NOL(WE_NOBL)-WE_BLICOU >1
    For WE_J=WE_BLICOU+1 To BLC_NOL(WE_NOBL)-1
      WE_BLICOU=WE_J
      Gosub WECR_CLIGBLOC
    Next WE_J
  Endif
  WE_BLICOU=BLC_NOL(WE_NOBL)
  WE_VALL1="<LBL"
  WE_PROP="NUM"  : WE_VALUE=num$(WE_BLICOU) : Gosub WE_ADDPROP
  Gosub WE_FINF
Return

$WECR_FLIGBLOC
  # Ecriture Fin Ligne de bloc
  WE_VALL1="</LBL"
  Gosub WE_FINF
Return

$WECR_CLIGBLOC
  # Ecriture Ligne de bloc de cadrage
  WE_VALL1="<LBL"
  WE_PROP="NUM"  : WE_VALUE=num$(WE_BLICOU) : Gosub WE_ADDPROP
  Gosub WE_FINF
  Gosub WECR_FLIGBLOC
Return



# -------------------------------------------------------------------------------
#  3 - Type FRAME

$WECR_FRAME
   # Ecriture d'un Frame
 WE_VALL1="<FRM"
                          #  WE_PROP="NOBLOC" : WE_VALUE=num$(WE_NOBL) : Gosub WE_ADDPROP
                          #  WE_PROP="TYPE"   : WE_VALUE=num$(BLC_TYP(WE_NOBL)) : Gosub WE_ADDPROP
  If BLC_STY(WE_NOBL)<>""
   WE_PROP="STX"   : WE_VALUE=num$(BLC_STY(WE_NOBL)) : Gosub WE_ADDPROP
  Endif
  WE_PROP="XID"   : WE_VALUE=num$(BLC_IDX(WE_NOBL)) : Gosub WE_ADDPROP
  WE_PROP="XD1"   : WE_VALUE=mid$(WE_ALPHAB,BLC_IDX(WE_NOBL)/256,1) : Gosub WE_ADDPROP
  WE_PROP="IDF"   : WE_VALUE=num$(TET_IDX) : Gosub WE_ADDPROP
  WE_NTEX=BLC_TIT(WE_NOBL)  : WE_CAPDEF=BLC_TXT(WE_NOBL) : WE_LCH=0
  WE_INTEV=BLC_EVL(WE_NOBL) : WE_FORCE=0
#  If WE_INTEV="" and WE_NTEX=0 : WE_INTEV="WE_GBLANC" : Endif
  Gosub WE_ADDNTEX
  WE_PROP="BOR" : WE_VALUE="1" : Gosub WE_ADDPROP
  If BLC_TYP(WE_NOBL)<>10
   WE_PROP="PLI" : WE1_BPLI=BLC_Y(WE_NOBL)*8-7-WE_PLIG : WE_VALUE=num$(WE1_BPLI) : Gosub WE_ADDPROP
   WE_PROP="PCO" : WE1_BPCO=BLC_X(WE_NOBL)*4-3-WE_PCOL : WE_VALUE=num$(WE1_BPCO) : Gosub WE_ADDPROP
   WE_PROP="NLI" : WE1_BNLI=BLC_NLI(WE_NOBL)*8 : WE_VALUE=num$(WE1_BNLI) : Gosub WE_ADDPROP
   WE_PROP="NCO" : WE1_BNCO=(BLC_NCO(WE_NOBL)-1)*4 : WE_VALUE=num$(WE1_BNCO) : Gosub WE_ADDPROP
   WE_PROP="PLI1" : WE_VALUE=num$(BLC_Y1(WE_NOBL)*8-7-WE_PLIG1) : Gosub WE_ADDPROP
   WE_PROP="PCO1" : WE_VALUE=num$(BLC_X1(WE_NOBL)*4-3-WE_PCOL1) : Gosub WE_ADDPROP
   WE_PROP="PCO2" : WE_VALUE=num$(BLC_X2(WE_NOBL)*4-3-WE_PCOL2) : Gosub WE_ADDPROP
   WE_PROP="NLI1" : WE_VALUE=num$(BLC_NLI1(WE_NOBL)*8) : Gosub WE_ADDPROP
   WE_PROP="NCO1" : WE_VALUE=num$((BLC_NCO1(WE_NOBL)-1)*4) : Gosub WE_ADDPROP
   WE_PROP="NCO2" : WE_VALUE=num$((BLC_NCO2(WE_NOBL)-1)*4) : Gosub WE_ADDPROP
   If BLC_PDS(WE_NOBL) > 1
     WE_PROP="CPA"  : WE_VALUE=num$(BLC_PDS(WE_NOBL)) : Gosub WE_ADDPROP
   Endif
   If BLC_PDH(WE_NOBL) > 1
     WE_PROP="RPA"  : WE_VALUE=num$(BLC_PDH(WE_NOBL)) : Gosub WE_ADDPROP
   Endif
   If BLC_TYP(WE_NOBL)=2
     WE_PROP="MXL"  : WE_VALUE=num$(WE_MAXLIG) : Gosub WE_ADDPROP
     WE_PROP="MXC"  : WE_VALUE=num$(WE_MAXCOL) : Gosub WE_ADDPROP
   Endif

#   Calcul en %   CC 04/05/2006
 #   WE_PROP="X"  : WE_1=WE1_BPLI*100/WE1_NLIEC : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
 #   WE_PROP="Y"  : WE_1=WE1_BPCO*100/WE1_NCOEC : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
 #   WE_PROP="H"  : WE_1=WE1_BNLI*100/WE1_NLIEC : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
 #   WE_PROP="W"  : WE_1=WE1_BNCO*100/WE1_NCOEC : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
  WE_PROP="X"  : WE_X=arr(WE1_BPLI*100/WE1_NLIEC,0.01)
  If WE_X<=1 : WE_X=0 : Endif
  WE_VALUE=ctrans(num$(WE_X),",",".") : Gosub WE_ADDPROP
  WE_PROP="Y"  : WE_X=arr(WE1_BPCO*100/WE1_NCOEC,0.01)
  If WE_X<=1 : WE_X=0 : Endif
  WE_VALUE=ctrans(num$(WE_X),",",".") : Gosub WE_ADDPROP
  WE_PROP="H"  : WE_X=arr(WE1_BNLI*100/WE1_NLIEC,0.01) : WE_VALUE=ctrans(num$(WE_X),",",".") : Gosub WE_ADDPROP
  WE_PROP="W"  : WE_X=arr(WE1_BNCO*100/WE1_NCOEC,0.01) : WE_VALUE=ctrans(num$(WE_X),",",".") : Gosub WE_ADDPROP
    WE1_BNLI=max(WE1_BNLI,1) : WE1_BNCO=max(WE1_BNCO,1)  : # pour ne pas diviser par 0
#   Fin calcul
  Else
   WE_PROP="PLI"  : WE_VALUE="0" : Gosub WE_ADDPROP
   WE_PROP="PCO"  : WE_VALUE="0" : Gosub WE_ADDPROP
   WE_PROP="NLI"  : WE_VALUE="0" : Gosub WE_ADDPROP
   WE_PROP="NCO"  : WE_VALUE="0" : Gosub WE_ADDPROP
   WE_PROP="PLI1" : WE_VALUE="0" : Gosub WE_ADDPROP
   WE_PROP="PCO1" : WE_VALUE="0" : Gosub WE_ADDPROP
   WE_PROP="PCO2" : WE_VALUE="0" : Gosub WE_ADDPROP
   WE_PROP="NLI1" : WE_VALUE="0" : Gosub WE_ADDPROP
   WE_PROP="NCO1" : WE_VALUE="0" : Gosub WE_ADDPROP
   WE_PROP="NCO2" : WE_VALUE="0" : Gosub WE_ADDPROP
   WE_PROP="X"    : WE_VALUE="0" : Gosub WE_ADDPROP
   WE_PROP="Y"    : WE_VALUE="0" : Gosub WE_ADDPROP
   WE_PROP="H"    : WE_VALUE="0" : Gosub WE_ADDPROP
   WE_PROP="W"    : WE_VALUE="0" : Gosub WE_ADDPROP
  Endif
If ISVT
  Gosub VT_EFRM
Endif

  Gosub WE_FINF
Return

$WECR_FFRAME
  #   Ecriture d'une fin de frame
  WE_VALL1="</FRM"
  Gosub WE_FINF
Return

# ------------------------------------------------------------------------------------------------
#  3 bis - Type GPH Flash         Blocs graphiques flash (dûˋcalage de position comme pour les tableaux)

$WECR_GPHFL
   # Ecriture d'un Frame graphique
  WE_VALL1="<GPH"
  WE_PROP="GTY"   : WE_VALUE="1" : Gosub WE_ADDPROP
  WE_PROP="GTD"   : WE_VALUE="2" : Gosub WE_ADDPROP
  Gosub WECR_XD1  : # GPH est fils du champ clob FLD
#  WE_PROP="XD1"   : WE_VALUE=mid$(WE_ALPHAB,BLC_IDX(WE_NOBL)/256,1) : Gosub WE_ADDPROP
  WE_PROP="IDF"   : WE_VALUE=num$(BLC_IDX(WE_NOBL)) : Gosub WE_ADDPROP
  WE_PROP="XID"   : WE_VALUE=num$(BLC_IDX(WE_NOBL)+255-1) : Gosub WE_ADDPROP
  WE_PROP="SID"   : WE_VALUE=num$(LIG_IDX(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  WE_PROP="MAF"   : WE_VALUE=num$(LIG_SAI(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  WE_PROP="BOR"   : WE_VALUE="1" : Gosub WE_ADDPROP
  WE_T1=0
  If BLC_TIT(WE_NOBL)<>0 or BLC_EVL(WE_NOBL)<>"" : WE_T1=1 : Endif
  WE_PROP="PLI" : WE_VALUE=num$(5+WE_T1) : Gosub WE_ADDPROP
  WE_PROP="PCO" : WE1_BPCO=1 : WE_VALUE=num$(WE1_BPCO) : Gosub WE_ADDPROP
  WE_PROP="NLI" : WE1_BNLI=BLC_NLI(WE_NOBL)*8-5-WE_T1 : WE_VALUE=num$(WE1_BNLI) : Gosub WE_ADDPROP
  WE_PROP="NCO" : WE1_BNCO=(BLC_NCO(WE_NOBL)-2)*4 : WE_VALUE=num$(WE1_BNCO) : Gosub WE_ADDPROP
  Gosub WE_ADDLNG

#   Calcul en %
    WE_PROP="X"  : WE_1=1 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
    WE_PROP="Y"  : WE_1=1 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
    WE_PROP="H"  : WE_1=100 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
    WE_PROP="W"  : WE_1=100: WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
    WE1_BNLI=max(WE1_BNLI,1) : WE1_BNCO=max(WE1_BNCO,1)  : # pour ne pas diviser par 0
#   Fin calcul

  Gosub WE_FINFF
Return
# ------------------------------------------------------------------------------------------------
#  3 bis - Type GPHTAB         Blocs graphiques tableau (position idem GRID)

#Local Libelle  BLC_TYPT(1..MAXBLOC)                    : # Type de tableau  (Si 3 Dual)
#Local Libelle  BLC_TYPG(1..MAXBLOC)                    : # Type de graphique
#Local Libelle  BLC_POSG(1..MAXBLOC)                    : # Position graphique
#Local Libelle  BLC_GDEF(1..MAXBLOC)                    : # Graphique par dûˋfaut
#Local Libelle  BLC_AFFD(1..MAXBLOC)                    : # Affichage par dûˋfaut
#Local Libelle  BLC_REPD(1..MAXBLOC)                    : # Reprûˋsentation

$WECR_GPHTAB
   # Ecriture d'un Frame graphique
  WE_VALL1="<GPH"
  WE_PROP="GTY"   : WE_VALUE="1"
  If BLC_TYPG(WE_NOBL)=4 : WE_VALUE="3" : Endif
  Gosub WE_ADDPROP
  WE_PROP="GTD"   : WE_VALUE="1" : Gosub WE_ADDPROP
  WE_PROP="XID"   : WE_VALUE=num$(BLC_IDXT(WE_NOBL)+1) : Gosub WE_ADDPROP
  WE_PROP="IDF"   : WE_VALUE=num$(BLC_IDX(WE_NOBL)) : Gosub WE_ADDPROP
  WE_PROP="XD1"   : WE_VALUE=mid$(WE_ALPHAB,BLC_IDX(WE_NOBL)/256,1) : Gosub WE_ADDPROP
  WE_PROP="SID"   : WE_VALUE=num$(BLC_IDX(WE_NOBL)) : Gosub WE_ADDPROP
  WE_PROP="BOR"   : WE_VALUE="1" : Gosub WE_ADDPROP
  WE_T1=0
  If BLC_TIT(WE_NOBL)<>0 or BLC_EVL(WE_NOBL)<>"" : WE_T1=1 : Endif

#   Calcul en %
    If BLC_TYPT(WE_NOBL)<>3
      WE_PROP="PLI" : WE_VALUE=num$(5+WE_T1) : Gosub WE_ADDPROP
      WE_PROP="PCO" : WE1_BPCO=1 : WE_VALUE=num$(WE1_BPCO) : Gosub WE_ADDPROP
      WE_PROP="NLI" : WE1_BNLI=BLC_NLI(WE_NOBL)*8-5-WE_T1 : WE_VALUE=num$(WE1_BNLI) : Gosub WE_ADDPROP
      WE_PROP="NCO" : WE1_BNCO=(BLC_NCO(WE_NOBL)-2)*4 : WE_VALUE=num$(WE1_BNCO) : Gosub WE_ADDPROP
      WE_PROP="X"  : WE_1=1 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
      WE_PROP="Y"  : WE_1=1 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
      WE_PROP="H"  : WE_1=100 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
      WE_PROP="W"  : WE_1=100 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
    Else
      Case BLC_POSG(WE_NOBL)
         When 1  WE_PROP="X"  : WE_1=1  : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="Y"  : WE_1=51 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="H"  : WE_1=100 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="W"  : WE_1=50 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="PLI" : WE_VALUE=num$(5+WE_T1) : Gosub WE_ADDPROP
                 WE_PROP="NLI" : WE1_BNLI=BLC_NLI(WE_NOBL)*8-5-WE_T1 : WE_VALUE=num$(WE1_BNLI) : Gosub WE_ADDPROP
                 WE_PROP="NCO" : WE1_BNCO=(BLC_NCO(WE_NOBL)-2)*2 : WE_VALUE=num$(WE1_BNCO) : Gosub WE_ADDPROP
                 WE_PROP="PCO" : WE1_BPCO=WE1_BNCO+1 : WE_VALUE=num$(WE1_BPCO) : Gosub WE_ADDPROP
         When 2  WE_PROP="X"  : WE_1=1 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="Y"  : WE_1=1 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="H"  : WE_1=100 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="W"  : WE_1=50 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="PLI" : WE_VALUE=num$(5+WE_T1) : Gosub WE_ADDPROP
                 WE_PROP="PCO" : WE1_BPCO=1 : WE_VALUE=num$(WE1_BPCO) : Gosub WE_ADDPROP
                 WE_PROP="NLI" : WE1_BNLI=BLC_NLI(WE_NOBL)*8-5-WE_T1 : WE_VALUE=num$(WE1_BNLI) : Gosub WE_ADDPROP
                 WE_PROP="NCO" : WE1_BNCO=(BLC_NCO(WE_NOBL)-2)*2 : WE_VALUE=num$(WE1_BNCO) : Gosub WE_ADDPROP
         When 3  WE_PROP="X"  : WE_1=1  : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="Y"  : WE_1=1 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="H"  : WE_1=50 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="W"  : WE_1=100 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="PLI" : WE_VALUE=num$(5+WE_T1) : Gosub WE_ADDPROP
                 WE_PROP="PCO" : WE1_BPCO=1 : WE_VALUE=num$(WE1_BPCO) : Gosub WE_ADDPROP
                 WE_PROP="NLI" : WE1_BNLI=(BLC_NLI(WE_NOBL)*8-5-WE_T1)/2
                 WE_VALUE=num$(WE1_BNLI) : Gosub WE_ADDPROP
                 WE_PROP="NCO" : WE1_BNCO=(BLC_NCO(WE_NOBL)-2)*4 : WE_VALUE=num$(WE1_BNCO) : Gosub WE_ADDPROP
         When 4  WE_PROP="X"  : WE_1=51 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="Y"  : WE_1=1  : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="H"  : WE_1=50 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="W"  : WE_1=100 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
                 WE_PROP="PCO" : WE1_BPCO=1 : WE_VALUE=num$(WE1_BPCO) : Gosub WE_ADDPROP
                 WE_PROP="NLI" : WE1_BNLI=(BLC_NLI(WE_NOBL)*8-5-WE_T1)/2
                 WE_VALUE=num$(WE1_BNLI) : Gosub WE_ADDPROP
                 WE_PROP="PLI" : WE_VALUE=num$(WE1_BNLI+1) : Gosub WE_ADDPROP
                 WE_PROP="NCO" : WE1_BNCO=(BLC_NCO(WE_NOBL)-2)*4 : WE_VALUE=num$(WE1_BNCO) : Gosub WE_ADDPROP
      Endcase
    Endif
    WE1_BNLI=max(WE1_BNLI,1) : WE1_BNCO=max(WE1_BNCO,1)  : # pour ne pas diviser par 0
#   Fin calcul

  Gosub WE_FINF

#  Ecriture des noeuds CPH
  Local Char WE_FCL,WE_FCV(100),WE_FCD(100),WE_GRDYN
  Local Integer WE_TC,WE_GPER
  If BLC_TYPG(WE_NOBL)=4 : Goto WE_ECRTEC : Endif
#  Est-on en graphe personnalisûˋ ou pas ?
  If BLC_TYPG(WE_NOBL)=2
   For WE_F=1 To LIG_NBR(WE_NOBL)
    If (LIG_SAI(WE_NOBL,WE_F)<=2 or (LIG_SAI(WE_NOBL,WE_F)=3 and LIG_TRF(WE_NOBL,WE_F)=2))
&   and (left$(LIG_TRG(WE_NOBL,WE_F),3)="G01" or left$(LIG_TRG(WE_NOBL,WE_F),3)="G02")
      If WE_TC=0
        WE_TC=LIG_TRP(WE_NOBL,WE_F)
      Else
        If WE_TC<>LIG_TRP(WE_NOBL,WE_F) : WE_GPER=1 : Endif
      Endif
    Endif
   Next WE_F
  Endif
  WE_TC=0
  For WE_F=1 To LIG_NBR(WE_NOBL)
    If (LIG_SAI(WE_NOBL,WE_F)<=2  or (LIG_SAI(WE_NOBL,WE_F)=3 and LIG_TRF(WE_NOBL,WE_F)=2))
&   and (LIG_TRG(WE_NOBL,WE_F)<>"" or BLC_TYPG(WE_NOBL)=5 or BLC_TYPG(WE_NOBL)=6)
      WE_TC+=1
      Case left$(LIG_TRG(WE_NOBL,WE_F),3)
        When "G01" : If WE_FCV="" : WE_FCV=num$(WE_TC) : Else : WE_FCV+=";"+num$(WE_TC) : Endif
                     If LIG_EVL(WE_NOBL,WE_F)<>"" : WE_GRDYN="D" : Endif
                     Gosub WE_GPERG
        When "G02" : If WE_FCD="" : WE_FCD=num$(WE_TC) : Else : WE_FCD+=";"+num$(WE_TC) : Endif
                     If WE_FCV="" : WE_FCV=num$(WE_TC) : Else : WE_FCV+=";"+num$(WE_TC) : Endif
                     If LIG_EVL(WE_NOBL,WE_F)<>"" : WE_GRDYN="D" : Endif
                     Gosub WE_GPERG
        When "G03" : If WE_FCL="" : WE_FCL=num$(WE_TC) : Endif
      Endcase
      WE_VALL1="<CPH"
      Gosub WECR_XD1
      Gosub WE_ADDTYP
      Gosub WE_ADDFORM
      WE_PROP="NAM" : WE_VALUE=LIG_ZON(WE_NOBL,WE_F) : Gosub WE_ADDPROP
      If BLC_TYPG(WE_NOBL)=5 or BLC_TYPG(WE_NOBL)=3 or BLC_TYPG(WE_NOBL)=6 : Gosub WE_ADDCHXSL : Endif  : # Caractûˋrisation des champs
      WE_NTEX=LIG_TIT(WE_NOBL,WE_F)  : WE_CAPDEF=LIG_TXT(WE_NOBL,WE_F) : WE_LCH=0
      WE_INTEV=LIG_EVL(WE_NOBL,WE_F) : WE_FORCE=0 : Gosub WE_ADDNTEX
      Gosub WE_FINFF
    Endif
  Next WE_F

#  Ecriture du noeud TEC
$WE_ECRTEC:
Raz [F:AUR]
If BLC_TYPG(WE_NOBL)<>4
  WE_VALL1="<TEC"
  Case BLC_TYPG(WE_NOBL)
    When 3 : WE_VALUE="AGD"
    When 5 : WE_VALUE="GAT"
    When 6 : WE_VALUE="REQ"
    When Default : WE_VALUE="BTAB"
  Endcase
  WE_PROP="GTYP" : Gosub WE_ADDPROP
  WE_PROP="SWF"
  Case BLC_TYPG(WE_NOBL)
    When 1 : WE_VALUE="FGRS"+WE_GRDYN    : #   le type est FGRSD si dynamique
 #   When 2 : If WE_GPER=0 : WE_VALUE="FGRS"+WE_GRDYN : Else : WE_VALUE="FGRP" : Endif
    When 2 : WE_VALUE="FGRS"+WE_GRDYN : #   CC   02/06/2011  Bug 74043
    When 3 : WE_VALUE="FAG" : #   anciennement WE_VALUE="FCA"
    When 5 : WE_VALUE="FGA"
    When 6 : WE_VALUE="REQ"
    When Default : WE_VALUE="FGRS"+WE_GRDYN
  Endcase
  Gosub WE_ADDPROP
  If BLC_TYPG(WE_NOBL)=3
    WE_PROP="PAR1" : WE_VALUE="MENACT" : Gosub WE_ADDPROP
    WE_PROP="VAL1"
    WE_VALUE="1"
    For WE_3=1 To LIG_NBR(WE_NOBL)
      If right$(LIG_TRG(WE_NOBL,WE_3),5)="TYPACT"
        WE_VALUE=num$(LIG_LIB(WE_NOBL,WE_3))
      Endif
    Next WE_3
    Gosub WE_ADDPROP
  Endif
  WE_PROP="Code"  : WE_VALUE=mid$(WE_ALPHAB,BLC_IDX(WE_NOBL)/256,1)  : Gosub WE_ADDPROP
  WE_PROP="FTY"   :
  If BLC_TYPG(WE_NOBL)=1 or BLC_TYPG(WE_NOBL)=2
    Case BLC_GDEF(WE_NOBL)
      When 1 : WE_VALUE="XBAR"
      When 2 : WE_VALUE="XLINE"
      When 3 : WE_VALUE="XAREA"
      When 4 : WE_VALUE="XPIE"
#      When 5 : WE_VALUE="XRADAR"
      When Default : WE_VALUE="XBAR"
    Endcase
  Elsif BLC_TYPG(WE_NOBL)=3
    Case BLC_REPD(WE_NOBL)
      When 4 : WE_VALUE="XMONTH"
      When 5 : WE_VALUE="XWEEK"
      When 6 : WE_VALUE="XDAY"
    Endcase
  Endif
  If BLC_TYPG(WE_NOBL)=2 or WE_GRDYN="D"  :#  Bug 85716   CC  03/12/2012
    Case BLC_REPD(WE_NOBL)
      When 1 : WE_VALUE+="M"
      When 2 : WE_VALUE+="CU"
      When 3 : WE_VALUE+="CO"
      When Default : WE_VALUE+="M"
    Endcase
  Endif
  Gosub WE_ADDPROP
  WE_PROP="FCV"   : WE_VALUE=WE_FCV  : Gosub WE_ADDPROP
  WE_PROP="FCL"   : WE_VALUE=WE_FCL  : Gosub WE_ADDPROP
  WE_PROP="FCD"   : WE_VALUE=WE_FCD  : Gosub WE_ADDPROP
  WE_PROP="FCS"   : WE_VALUE="2"     : Gosub WE_ADDPROP
  WE_PROP="FCC"   : WE_VALUE="2"     : Gosub WE_ADDPROP
  If WE_EXCL<>0
    WE_PROP="EXC"
    WE_1=BLC_IDX(WE_NOBL)/256
    WE_VALUE=mid$(WE_ALPHAB,WE_1,1)
    WE_1=LIG_IDX(WE_NOBL,WE_EXCL)-BLC_IDX(WE_NOBL)
    WE_VALUE+=num$(WE_1)
    Gosub WE_ADDPROP
  Endif
  If BLC_TYPG(WE_NOBL)=5
    WE_T5=9837
    For WE_F=1 To LIG_NBR(WE_NOBL)
      If instr(1,LIG_TRG(WE_NOBL,WE_F),"TYPDAY")>0 : WE_T5=LIG_LIB(WE_NOBL,WE_F) : Break 1 : Endif
#      If left$(LIG_ZON(WE_NOBL,WE_F),6)="TYPDAY" : WE_T5=LIG_LIB(WE_NOBL,WE_F) : Break 1 : Endif
    Next WE_F
    WE_PROP="PAR1"   : WE_VALUE="MENACT"  : Gosub WE_ADDPROP
    WE_PROP="VAL1"   : WE_VALUE=num$(WE_T5)  : Gosub WE_ADDPROP
  Endif
  Gosub WE_FINFF
  If BLC_TYPG(WE_NOBL)=5
      WE_VALL1="<MENS"
      WE_PROP="NO"     : WE_VALUE=num$(WE_T5)  : Gosub WE_ADDPROP
      WE_PROP="COD"    : WE_VALUE="MENACT"     : Gosub WE_ADDPROP
      Gosub WE_FINFF
  Elsif BLC_TYPG(WE_NOBL)=3
      WE_T5=0
      For WE_F=1 To LIG_NBR(WE_NOBL)
        If instr(1,LIG_TRG(WE_NOBL,WE_F),"TYPACT")>0 : WE_T5=LIG_LIB(WE_NOBL,WE_F) : Break 1 : Endif
 #       If left$(LIG_ZON(WE_NOBL,WE_F),6)="TYPACT" : WE_T5=LIG_LIB(WE_NOBL,WE_F) : Break 1 : Endif
      Next WE_F
      If WE_T5<>0
        WE_VALL1="<MENS"
        WE_PROP="NO"     : WE_VALUE=num$(WE_T5)  : Gosub WE_ADDPROP
        WE_PROP="COD"    : WE_VALUE="TYPACT"     : Gosub WE_ADDPROP
        Gosub WE_FINFF
      Endif
  Endif
Else         : #   Tableau reprûˋsentûˋ avec des XSL
  Read [AUR]AUR0=BLC_LIEN1(WE_NOBL)
  If fstat<>0 : Return : Endif
# Surcharge les valeurs par dûˋfaut par les valeurs ûˋcran
  WE_ORI=instr(1,BLC_ACT1(WE_NOBL),"?")
  For WE_3=0 To 4
    WE_DEST=instr(WE_ORI+1,BLC_ACT1(WE_NOBL),"?")
    If WE_DEST-WE_ORI>1
      [F:AUR]UPARDEF(WE_3)=mid$(BLC_ACT1(WE_NOBL),WE_ORI+1,WE_DEST-WE_ORI-1)
    Endif
    WE_ORI=WE_DEST
  Next WE_3
  For WE_F=1 To LIG_NBR(WE_NOBL)
    If (LIG_SAI(WE_NOBL,WE_F)<=2  or (LIG_SAI(WE_NOBL,WE_F)=3 and LIG_TRF(WE_NOBL,WE_F)=2))
      WE_VALL1="<CPH"
      Gosub WECR_XD1
      WE_PROP="NAM" : WE_VALUE=LIG_ZON(WE_NOBL,WE_F) : Gosub WE_ADDPROP
      Gosub WE_ADDTYP
      Gosub WE_ADDFORM
      If [F:AUR]TYPXSL>1 : #  Caractûˋrise les champs dans le tableau associûˋ û  l'XSL pour les XSL X3
        Gosub WE_ADDCHXSL
      Endif
      WE_NTEX=LIG_TIT(WE_NOBL,WE_F)  : WE_CAPDEF=LIG_TXT(WE_NOBL,WE_F) : WE_LCH=0
      WE_INTEV=LIG_EVL(WE_NOBL,WE_F) : WE_FORCE=0 : Gosub WE_ADDNTEX
      Gosub WE_FINFF
    Endif
  Next WE_F
  WE_VALL1="<TEC"
  WE_PROP="GTYP"  : WE_VALUE="XSL" : Gosub WE_ADDPROP
  WE_PROP="TXSL"  : WE_VALUE=num$([F:AUR]TYPXSL) : Gosub WE_ADDPROP
  Local Char WE_PINTER
  For WE_3=0 To 4
    If [F:AUR]UPARCOD(WE_3)<>""
      WE_PROP="PAR"+num$(WE_3+1) : WE_VALUE=num$([F:AUR]UPARCOD(WE_3)) : Gosub WE_ADDPROP
      WE_PROP="VAL"+num$(WE_3+1) : WE_VALUE=num$([F:AUR]UPARDEF(WE_3)) : Gosub WE_ADDPROP
      If [F:AUR]UPARCOD(WE_3)="PINTER" : WE_PINTER=[F:AUR]UPARDEF(WE_3) : Endif
    Endif
  Next WE_3

##     Traitement du style (placûˋ sur le champ XSL)
  WE_3=find(BLC_PAR1(WE_NOBL),LIG_ZON(1..MAXBLOC,1))
  If WE_3<>0
    Read [ASY]ASY0=LIG_STZ(WE_3,1)
    If fstat=0
      WE_PROP="STYLE"
      WE_VALUE=[F:ASY]STY
      Gosub WE_ADDPROP
    Endif
  Endif

##
  Gosub WE_FINFF
  WE_VALL1="<XSLS" :  Gosub WE_FINF
  WE_VALUE=BLC_PAR1(WE_NOBL) : Gosub WE_ADDX
#  WE_VALUE=BLC_PAR2(WE_NOBL) : Gosub WE_ADDX : #    Dûˋsactivûˋ, 1 seul XSL autorisûˋ
  WE_VALL1="</XSLS" :  Gosub WE_FINF
Endif
#  Fermeture du noeud GPH
  Gosub WE_ACTS
  Gosub WE_MENS
  WE_VALL1="</GPH"
  Gosub WE_FINF
Return

$WE_ADDCHXSL
  If LIG_TRG(WE_NOBL,WE_F)<>""
    WE_VALUE=right$(LIG_TRG(WE_NOBL,WE_F),5)
    WE_PROP="TFL"  : Gosub WE_ADDPROP
  Endif
Return


$WE_ACTS
  WE_VALL1="<ACTS" :  Gosub WE_FINF
  For WE_2=0 To 2
    If [F:AUR]UPRG(WE_2)<>"" : Gosub WE_ADACT : Endif
#   If BLC_ACT1(WE_NOBL)<>"" : WE_SAVVAL=BLC_ACT1(WE_NOBL) : WE_2=1 : Gosub WE_ADACT : Endif
  Next WE_2
  WE_VALL1="</ACTS" :  Gosub WE_FINF
Return

$WE_MENS
  For WE_3=0 To 4
    If [F:AUR]UMEN(WE_3)<>0
      WE_VALL1="<MENS"
      WE_PROP="NO"     : WE_VALUE=num$([F:AUR]UMEN(WE_3)) : Gosub WE_ADDPROP
      WE_PROP="COD"    : WE_VALUE=num$([F:AUR]UCOD(WE_3)) : Gosub WE_ADDPROP
      Gosub WE_FINFF
    Endif
  Next WE_3
  For WE_3=0 To 4
    If ([F:AUR]UPARCOD(WE_3)="MENACT" or [F:AUR]UPARCOD(WE_3)="MENSCA" or [F:AUR]UPARCOD(WE_3)="MENCOL")
&   and val([F:AUR]UPARDEF(WE_3))>0
#&   and val([F:AUR]UPARDEF(WE_3))>0 and val([F:AUR]UPARDEF(WE_3))<10000
      WE_VALL1="<MENS"
      WE_PROP="NO"     : WE_VALUE=num$([F:AUR]UPARDEF(WE_3)) : Gosub WE_ADDPROP
      WE_PROP="COD"    : WE_VALUE=num$([F:AUR]UPARCOD(WE_3)) : Gosub WE_ADDPROP
      Gosub WE_FINFF
    Endif
  Next WE_3
Return

$WE_ADACT
#  WE_3=instr(1,WE_SAVVAL,":")
#  Read [ASU]ASU0=left$(WE_SAVVAL,WE_3-1);right$(WE_SAVVAL,WE_3+1)
#  On surcharge le nom du premier programme d'interaction si il est dûˋfini dans l'ûˋcran
  If WE_2<>0 or WE_PINTER="" : WE_PINTER=[F:AUR]UPRG(WE_2) : Endif
# On ne surcharge plus le nom du sous-pro    CC 13/11/2008
#  Read [ASU]ASU0=WE_PINTER;[F:AUR]USPRG(WE_2)
  Read [ASU]ASU0=[F:AUR]UPRG(WE_2);[F:AUR]USPRG(WE_2)
  If fstat<>0
 # Sous-programme inexistant
   Call ECR_TRACE(mess(71,150,1)-WE_PINTER+":"+[F:AUR]USPRG(WE_2),1) From GESECRAN
   Return
  Endif
  WE_VALL1="<ACB"
  WE_PROP="NO"    : WE_VALUE=num$(WE_2+1) : Gosub WE_ADDPROP

  WE_PROP="SUBP"  : WE_VALUE=WE_PINTER+":"+[F:AUR]USPRG(WE_2): Gosub WE_ADDPROP
  Gosub WE_FINF
#  Ajout des paramû´tres
  WE_3=0
  For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
    WE_VALL1="<PAR"
    WE_PROP="NO"    : WE_VALUE=num$(WE_3+1) : Gosub WE_ADDPROP
    WE_PROP="TYP"
    Case [F:ASP]TYPPAR
      When 1 : WE_VALUE="Char"
      When 2 : WE_VALUE="Integer"
      When 3 : WE_VALUE="Decimal"
      When 4 : WE_VALUE="Date"
      When 5 : WE_VALUE="Libelle"
      When 6 : WE_VALUE="Clbfile"
      When 7 : WE_VALUE="Blbfile"
    Endcase
    Gosub WE_ADDPROP
    WE_PROP="SZ"   : WE_VALUE=num$([F:ASP]LONG)  : Gosub WE_ADDPROP
    WE_PROP="DIM"  : WE_VALUE=num$([F:ASP]DIME)  : Gosub WE_ADDPROP
    WE_PROP="NAM"  : WE_VALUE=[F:ASP]PARAM       : Gosub WE_ADDPROP
    Gosub WE_FINFF
    WE_3 += 1
  Next ASP
  WE_VALL1="</ACB" : Gosub WE_FINF
Return

$WE_ADDX
  If WE_VALUE="" : Return : Endif
  WE_VALL1="<XSL"
  WE_3=0
  For WE_1=1 To BLC_NBR
    For WE_2=1 To LIG_NBR(WE_1)
      If WE_VALUE=LIG_ZON(WE_1,WE_2) : WE_3=1 : Break 2 : Endif
    Next WE_2
  Next WE_1
  If WE_3=0 : Return : Endif
  WE_PROP="XIDT"  : WE_VALUE=num$(LIG_IDX(WE_1,WE_2)) : Gosub WE_ADDPROP
  WE_3=BLC_IDX(WE_1)/256
  WE_VALUE=mid$(WE_ALPHAB,WE_3,1)
  WE_3=LIG_IDX(WE_1,WE_2)-BLC_IDX(WE_1)
  WE_VALUE+=num$(WE_3)
  WE_PROP="XD1"
  Gosub WE_ADDPROP
  WE_NTEX=LIG_TIT(WE_1,WE_2)  : WE_CAPDEF=LIG_TXT(WE_1,WE_2) : WE_LCH=0
  WE_INTEV=LIG_EVL(WE_1,WE_2) : WE_FORCE=0 : Gosub WE_ADDNTEX
  Gosub WE_FINFF
Return



$WE_GPERG
If WE_GPER=1
  WE_FCV+=","
  Case LIG_TRP(WE_NOBL,WE_F)
    When 2  : WE_FCV+="b"
    When 3  : WE_FCV+="l"
  Endcase
Endif
Return


#  3 bis - Type GPH Browser

$WECR_GPHBO
Local Integer GPHBO
$WECR_GPHBRW
   # Ecriture d'un Frame graphique
  WE_VALL1="<GPH"
  WE_PROP="GTY"
  WE_VALUE="4"
  If dim(GPHBO)>0 : WE_VALUE="12" : Kill GPHBO : Endif
  Gosub WE_ADDPROP
  WE_PROP="GTD"   : WE_VALUE="2" : Gosub WE_ADDPROP
  Gosub WECR_XD1  : # GPH est fils du champ clob FLD
  WE_PROP="IDF"   : WE_VALUE=num$(BLC_IDX(WE_NOBL)) : Gosub WE_ADDPROP
  WE_PROP="XID"   : WE_VALUE=num$(BLC_IDX(WE_NOBL)+255-1) : Gosub WE_ADDPROP
  WE_PROP="SID"   : WE_VALUE=num$(LIG_IDX(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  WE_PROP="MAF"   : WE_VALUE=num$(LIG_SAI(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  WE_T1=0
  If BLC_TIT(WE_NOBL)<>0 or BLC_EVL(WE_NOBL)<>"" : WE_T1=1 : Endif
  WE_PROP="PLI" : WE_VALUE=num$(5+WE_T1) : Gosub WE_ADDPROP
  WE_PROP="PCO" : WE1_BPCO=1 : WE_VALUE=num$(WE1_BPCO) : Gosub WE_ADDPROP
  WE_PROP="NLI" : WE1_BNLI=BLC_NLI(WE_NOBL)*8-5-WE_T1 : WE_VALUE=num$(WE1_BNLI) : Gosub WE_ADDPROP
  WE_PROP="NCO" : WE1_BNCO=(BLC_NCO(WE_NOBL)-2)*4 : WE_VALUE=num$(WE1_BNCO) : Gosub WE_ADDPROP
  Gosub WE_ADDLNG

#   Calcul en %
    WE_PROP="X"  : WE_1=0 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
    WE_PROP="Y"  : WE_1=0 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP


  WE_PROP="BOR" : WE_VALUE="1" : Gosub WE_ADDPROP

  Gosub WE_FINFF
Return


#  3 quat - Type GPH Editeur

$WECR_GPHEDI
   # Ecriture d'un Frame graphique
  WE_VALL1="<GPH"
  WE_PROP="GTY"   : WE_VALUE="5"
  If LIG_ZON(WE_NOBL,1)="EXPEXC" : WE_VALUE="11" : Endif
  Gosub WE_ADDPROP
  WE_PROP="GTD"   : WE_VALUE="2" : Gosub WE_ADDPROP
  Gosub WECR_XD1  : # GPH est fils du champ clob FLD
  WE_PROP="IDF"   : WE_VALUE=num$(BLC_IDX(WE_NOBL)) : Gosub WE_ADDPROP
  WE_PROP="XID"   : WE_VALUE=num$(BLC_IDX(WE_NOBL)+255-1) : Gosub WE_ADDPROP
  WE_PROP="SID"   : WE_VALUE=num$(LIG_IDX(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  WE_PROP="MAF"   : WE_VALUE=num$(LIG_SAI(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  WE_T1=0
  If BLC_TIT(WE_NOBL)<>0 or BLC_EVL(WE_NOBL)<>"" : WE_T1=1 : Endif
  WE_PROP="PLI" : WE_VALUE=num$(5+WE_T1) : Gosub WE_ADDPROP
  WE_PROP="PCO" : WE1_BPCO=1 : WE_VALUE=num$(WE1_BPCO) : Gosub WE_ADDPROP
  WE_PROP="NLI" : WE1_BNLI=BLC_NLI(WE_NOBL)*8-5-WE_T1 : WE_VALUE=num$(WE1_BNLI) : Gosub WE_ADDPROP
  WE_PROP="NCO" : WE1_BNCO=(BLC_NCO(WE_NOBL)-2)*4 : WE_VALUE=num$(WE1_BNCO) : Gosub WE_ADDPROP
  Gosub WE_ADDLNG

#   Calcul en %
    WE_PROP="X"  : WE_1=0 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
    WE_PROP="Y"  : WE_1=0 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP


  WE_PROP="BOR" : WE_VALUE="1" : Gosub WE_ADDPROP

  Gosub WE_FINFF

Return


#  3 cinq - Type GPH Bureautique

$WECR_GPHBUR
   # Ecriture d'un Frame graphique
  WE_VALL1="<GPH"
  WE_PROP="GTY"
  Case BLC_TYPG(WE_NOBL)
    When 1 :  WE_VALUE="8"     : # Word
    When 2 :  WE_VALUE="7"     : # Excel
    When 3 :  WE_VALUE="10"     : # Power point
    When Default :  WE_VALUE="9"     : # Banalisûˋ (choix 4 en fait)
  Endcase
#  If LIG_ZON(WE_NOBL,WE_F)="BB1" : WE_VALUE="8" : Endif      : # Word
#  If LIG_ZON(WE_NOBL,WE_F)="BB2" : WE_VALUE="7" : Endif      : # Excel
  Gosub WE_ADDPROP
  WE_PROP="GTD"   : WE_VALUE="3" : Gosub WE_ADDPROP
  Gosub WECR_XD1  : # GPH est fils du champ blob FLD
  WE_PROP="IDF"   : WE_VALUE=num$(BLC_IDX(WE_NOBL)) : Gosub WE_ADDPROP
  WE_PROP="XID"   : WE_VALUE=num$(BLC_IDX(WE_NOBL)+255-1) : Gosub WE_ADDPROP
  WE_PROP="SID"   : WE_VALUE=num$(LIG_IDX(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  WE_PROP="MAF"   : WE_VALUE=num$(LIG_SAI(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  WE_T1=0
  If BLC_TIT(WE_NOBL)<>0 or BLC_EVL(WE_NOBL)<>"" : WE_T1=1 : Endif
  WE_PROP="PLI" : WE_VALUE=num$(5+WE_T1) : Gosub WE_ADDPROP
  WE_PROP="PCO" : WE1_BPCO=1 : WE_VALUE=num$(WE1_BPCO) : Gosub WE_ADDPROP
  WE_PROP="NLI" : WE1_BNLI=BLC_NLI(WE_NOBL)*8-5-WE_T1 : WE_VALUE=num$(WE1_BNLI) : Gosub WE_ADDPROP
  WE_PROP="NCO" : WE1_BNCO=(BLC_NCO(WE_NOBL)-2)*4 : WE_VALUE=num$(WE1_BNCO) : Gosub WE_ADDPROP
  Gosub WE_ADDLNG

#   Calcul en %
    WE_PROP="X"  : WE_1=0 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
    WE_PROP="Y"  : WE_1=0 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP


  WE_PROP="BOR" : WE_VALUE="1" : Gosub WE_ADDPROP

  Gosub WE_FINFF
Return




# -------------------------------------------------------------------------------
#  4 - Type GRID


$WECR_GRID
  #   Ecriture d'un Grid
  WE_VALL1="<GRD"
  WE_PROP="XID"   : WE_VALUE=num$(BLC_IDXT(WE_NOBL)) : Gosub WE_ADDPROP
  WE_PROP="IDF"  : WE_VALUE=num$(BLC_IDX(WE_NOBL)) : Gosub WE_ADDPROP
  WE_PROP="OPT"   : WE_VALUE=BLC_OPT(WE_NOBL) : Gosub WE_OPTTAB : Gosub WE_ADDPROP
  WE_PROP="LIG"  : WE_VALUE=num$(BLC_LIG(WE_NOBL)) : Gosub WE_ADDPROP
  If BLC_TYPT(WE_NOBL)>1
    If BLC_TYPT(WE_NOBL)=3 : WE_VALUE="1" : Endif
    If BLC_TYPT(WE_NOBL)=4 : WE_VALUE="2" : Endif
    If BLC_TYPT(WE_NOBL)=2
      If BLC_AFFD(WE_NOBL)=1 :  WE_VALUE="3" : Endif
      If BLC_AFFD(WE_NOBL)=2 :  WE_VALUE="4" : Endif
    Endif
    WE_PROP="GTA"  : Gosub WE_ADDPROP
  Endif
  WE_PROP="COL"  : WE_VALUE=num$(BLC_NBC(WE_NOBL)-1) : Gosub WE_ADDPROP
  WE_T2=0
  For WE_T1=1 To len(BLC_OPT(WE_NOBL))
    WE_T2=val(mid$(BLC_OPT(WE_NOBL),WE_T1,1))
    If WE_T2<>0 : Break 1 : Endif
  Next WE_T1
  WE_PROP="COS"  : WE_VALUE=num$(WE_T2) : Gosub WE_ADDPROP
                             # WE_PROP="BNUMLG"  : WE_VALUE="1" : Gosub WE_ADDPROP

  WE_PROP="NBP"   : WE_VALUE=BLC_BAS(WE_NOBL) : Gosub WE_ADDPROP


# Calcul positions
  WE_T1=0
  If BLC_TIT(WE_NOBL)<>0 or BLC_EVL(WE_NOBL)<>"" : WE_T1=1 : Endif
  If BLC_TYPT(WE_NOBL)<>3
    WE_PROP="X"  : WE_1=0 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
    WE_PROP="Y"  : WE_1=0 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
    WE_PROP="H"  : WE_1=100 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
    WE_PROP="W"  : WE_1=100 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
    WE_PROP="PLI" : WE_VALUE=num$(5+WE_T1) : Gosub WE_ADDPROP
    WE_PROP="PCO" : WE_VALUE="1" : Gosub WE_ADDPROP
    WE_PROP="NLI" : WE_VALUE=num$(BLC_NLI(WE_NOBL)*8-5-WE_T1) : Gosub WE_ADDPROP
    WE_PROP="NCO" : WE_VALUE=num$((BLC_NCO(WE_NOBL)-2)*4) : Gosub WE_ADDPROP
  Else
    Case BLC_POSG(WE_NOBL)
       When 1  WE_PROP="X"  : WE_1=0  : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="Y"  : WE_1=0 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="H"  : WE_1=100 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="W"  : WE_1=50 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="PLI" : WE_VALUE=num$(5+WE_T1) : Gosub WE_ADDPROP
               WE_PROP="PCO" : WE_VALUE="1" : Gosub WE_ADDPROP
               WE_PROP="NLI" : WE_VALUE=num$(BLC_NLI(WE_NOBL)*8-5-WE_T1) : Gosub WE_ADDPROP
               WE_PROP="NCO" : WE_VALUE=num$((BLC_NCO(WE_NOBL)-2)*2) : Gosub WE_ADDPROP
       When 2  WE_PROP="X"  : WE_1=0 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="Y"  : WE_1=50 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="H"  : WE_1=100 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="W"  : WE_1=50 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="PLI" : WE_VALUE=num$(5+WE_T1) : Gosub WE_ADDPROP
               WE_PROP="PCO" : WE_VALUE=num$((BLC_NCO(WE_NOBL)-2)*2+1) : Gosub WE_ADDPROP
               WE_PROP="NLI" : WE_VALUE=num$(BLC_NLI(WE_NOBL)*8-5-WE_T1) : Gosub WE_ADDPROP
               WE_PROP="NCO" : WE_VALUE=num$((BLC_NCO(WE_NOBL)-2)*2) : Gosub WE_ADDPROP
       When 3  WE_PROP="X"  : WE_1=50  : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="Y"  : WE_1=0 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="H"  : WE_1=50 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="W"  : WE_1=100 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="PCO" : WE_VALUE="1" : Gosub WE_ADDPROP
               WE_PROP="NLI" : WE_VALUE=num$((BLC_NLI(WE_NOBL)*8-5-WE_T1)/2) : Gosub WE_ADDPROP
               WE_PROP="PLI" : WE_VALUE=num$((BLC_NLI(WE_NOBL)*8-5-WE_T1)/2+1) : Gosub WE_ADDPROP
               WE_PROP="NCO" : WE_VALUE=num$((BLC_NCO(WE_NOBL)-2)*4) : Gosub WE_ADDPROP
       When 4  WE_PROP="X"  : WE_1=0 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="Y"  : WE_1=0  : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="H"  : WE_1=50 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="W"  : WE_1=100 : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
               WE_PROP="PCO" : WE_VALUE="1" : Gosub WE_ADDPROP
               WE_PROP="NLI" : WE_VALUE=num$((BLC_NLI(WE_NOBL)*8-5-WE_T1)/2) : Gosub WE_ADDPROP
               WE_PROP="PLI" : WE_VALUE=num$(5+WE_T1) : Gosub WE_ADDPROP
               WE_PROP="NCO" : WE_VALUE=num$((BLC_NCO(WE_NOBL)-2)*4) : Gosub WE_ADDPROP
    Endcase
  Endif


  Gosub WE_ACTGRID
  Gosub WE_FINF
Return

$WECR_FGRID
  #   Ecriture d'une fin de Grid
  WE_VALL1="</GRD"
  Gosub WE_FINF
  If BLC_TYPT(WE_NOBL)>1
    Gosub WECR_GPHTAB
  Endif
Return

$WE_ACTGRID     : # Recherche si il y a une action clic droit sur le champ NBLIG du tableau
  For WE_F=1 To LIG_NBR(WE_NOBL)
    If LIG_ZON(WE_NOBL,WE_F)=BLC_BAS(WE_NOBL)
      Gosub WE_ISRCLIC
      If WE_ISRC<>0
        WE_PROP="RCI" : WE_VALUE=num$(WE_ISRC) : Gosub WE_ADDPROP
      Endif
      Break 1
    Endif
  Next WE_F
Return



# -------------------------------------------------------------------------------
#  5 - Type GCOL

$WECR_GCOL
  #   Ecriture du champ WE_F du bloc tableau WE_NOBL
  WE_VALL1="<GCO"
  WE_MAXFB(WE_NOBL)+=1
  WE_PROP="NAM" : WE_VALUE=LIG_ZON(WE_NOBL,WE_F) : Gosub WE_ADDPROP
  If LIG_STZ(WE_NOBL,WE_F)<>""
   WE_PROP="STX"   : WE_VALUE=num$(LIG_STZ(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Endif
  If LIG_STY(WE_NOBL,WE_F)<>""
   WE_PROP="STXC"   : WE_VALUE=num$(LIG_STY(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Endif
  WE_PROP="XID"   : WE_VALUE=num$(LIG_IDX(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Gosub WECR_XD1
  WE_PROP="IDF"  : WE_VALUE=num$(BLC_IDXT(WE_NOBL)) : Gosub WE_ADDPROP
  WE_PROP="RNK" : WE_VALUE=num$(WE_RANK) : Gosub WE_ADDPROP
  Gosub WE_ADDTYP
  Gosub WE_ADDFORM
  WE_PROP="NCO" : WE_VALUE=num$(LIG_FLN(WE_NOBL,WE_F)*4) : Gosub WE_ADDPROP
  WE_NTEX=LIG_TIT(WE_NOBL,WE_F)  : WE_CAPDEF=LIG_TXT(WE_NOBL,WE_F) : WE_LCH=0
  WE_INTEV=LIG_EVL(WE_NOBL,WE_F) : WE_FORCE=0 : Gosub WE_ADDNTEX
  WE_PROP="HLP" : WE_VALUE=LIG_AID(WE_NOBL,WE_F) : Gosub WE_ADDPROP
  Case LIG_MOD(WE_NOBL,WE_F)
    When 1 : WE_VALUE="2"
    When 2 : WE_VALUE="1"
    When 3 : WE_VALUE="0"
    When Default : WE_VALUE="2"
  Endcase
  WE_PROP="SHO" : Gosub WE_ADDPROP
  If LIG_LIB(WE_NOBL,WE_F)<>0
   WE_NBCHC+=1
   WE_CHCOMB(1,WE_NBCHC)=1000*WE_NOBL+WE_MAXFB(WE_NOBL)
   WE_CHCOMB(2,WE_NBCHC)=WE_F
   WE_PROP="MNU" : WE_VALUE=num$(LIG_LIB(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  # WE_PROP="MDI" : WE_VALUE=num$(len(mess(0,LIG_LIB(WE_NOBL,WE_F),1))) : Gosub WE_ADDPROP
   WE_PROP="MDI" : WE_VALUE=num$(func APLSTD.LENMEN(APPLI,LIG_LIB(WE_NOBL,WE_F))) : Gosub WE_ADDPROP
  Endif
  WE_PROP="MAF" : WE_VALUE=num$(LIG_SAI(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  If LIG_OBL(WE_NOBL,WE_F)=2
    WE_PROP="OBL" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  #X3-91078
  If LIG_MAS(WE_NOBL,WE_F)=2
    WE_PROP="MAS" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  ###
  # Issue X3-110075 - 2018-10-03 by ALSHE : Break after field
  If LIG_BRK(WE_NOBL,WE_F)=2
    WE_PROP="BRK" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  # End issue X3-110075
  Gosub WE_ADDLNG
  If LIG_LGR(WE_NOBL,WE_F)<>0 and LIG_LGR(WE_NOBL,WE_F)<>LIG_LNG(WE_NOBL,WE_F)
    WE_PROP="AFL" : WE_VALUE=num$(LIG_LGR(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Endif
  If instr(1,LIG_OPT(WE_NOBL,WE_F),"W")<>0
    WE_PROP="TYW" : WE_VALUE="W" : Gosub WE_ADDPROP
  Endif

  If ISVT
    Gosub VT_EGCO
  Endif
  Gosub WE_ADDTOOLT
  Gosub WE_ACTFIELD
  If WE_ISRC=0
    Gosub WE_FINFF
  Else
    Gosub WE_FINF
    Gosub WE_ACTIONS
    Gosub WECR_FGCOL
  Endif
Return

$WECR_FGCOL
  #   Ecriture d'une fin de Gcol
  WE_VALL1="</GCO"
  Gosub WE_FINF
Return



# -------------------------------------------------------------------------------
#  6 - Type FIELD

$WECR_FIELD
  #   Ecriture du champ    WE_F du bloc WE_NOBL
  WE_F=WE_TLI(WE_I)
  If WE_CAP(WE_I)=0 and (LIG_GRA(WE_NOBL,WE_F)<2 or LIG_GRA(WE_NOBL,WE_F)=10 or LIG_GRA(WE_NOBL,WE_F)=13)
&     and LIG_SAI(WE_NOBL,WE_F)<=2 and BLC_TYP(WE_NOBL)<>8 and BLC_TYP(WE_NOBL)<>11
    Gosub WECR_CAPTION
  Endif
  WE_VALL1="<FLD"
  WE_MAXFB(WE_NOBL)+=1
  WE_PROP="NAM" : WE_VALUE=LIG_ZON(WE_NOBL,WE_F)
#  Nom des champs dimensionnûˋs
#  If WE_IND(WE_I)<>0 : WE_VALUE+="_"+num$(WE_IND(WE_I)) : Endif
  Gosub WE_ADDPROP
  If LIG_STZ(WE_NOBL,WE_F)<>""
   WE_PROP="STX"   : WE_VALUE=num$(LIG_STZ(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Endif
  If BLC_TYP(WE_NOBL)=6 or (BLC_TYP(WE_NOBL)>=7 and LIG_ZON(WE_NOBL,WE_F)=BLC_BAS(WE_NOBL))
    WE_PROP="GTA"  : WE_VALUE="2" : Gosub WE_ADDPROP
  Endif
  WE_PROP="XID"  : WE_VALUE=num$(LIG_IDX(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Gosub WECR_XD1
  WE_PROP="IDF"  : WE_VALUE=num$(BLC_IDX(WE_NOBL)) : Gosub WE_ADDPROP
  Gosub WE_ADDTYP
  Gosub WE_ADDFORM
# Si champ graphique encadrûˋ on dûˋcale d'une ligne et on enlû´ve une ligne
  WE_PROP="PLI" : WE1_PLI=max(1,(LIG_Y(WE_NOBL,WE_F)-1)*8-1+6*WE_GRAB) : WE_VALUE=num$(WE1_PLI) : Gosub WE_ADDPROP
  WE_PROP="PCO" : WE1_PCO=max(1,(LIG_X(WE_NOBL,WE_F)-1)*4-3) : WE_VALUE=num$(WE1_PCO) : Gosub WE_ADDPROP
  WE_PROP="NLI" : WE1_NLI=(LIG_FLI(WE_NOBL,WE_F)-WE_GRAB)*8 : WE_VALUE=num$(WE1_NLI) : Gosub WE_ADDPROP
  WE_PROP="NCO" : WE_VALUE=num$(LIG_FLN(WE_NOBL,WE_F)*4)
  If LIG_TYI(WE_NOBL,WE_F)=1 & LIG_GRA(WE_NOBL,WE_F)=1 : # On enlû´ve 2 pour les combos
    WE_VALUE=num$((LIG_FLN(WE_NOBL,WE_F)-2)*4)
  Endif
  If (LIG_TYI(WE_NOBL,WE_F)=7 & LIG_FLN(WE_NOBL,WE_F)>15 & LIG_GRA(WE_NOBL,WE_F)=1)
    If LIG_FTY(WE_NOBL,WE_F)<>"K" or LIG_FOP(WE_NOBL,WE_F)<>"T"    : # CC 23/01/2004  Zones KT
#& or find(LIG_GRA(WE_NOBL,WE_F),10,11,12): # Pour compenser la rûˋduction du client
      WE_VALUE=num$(int(LIG_FLN(WE_NOBL,WE_F)*COEF11*4))
    Endif
  Endif
  WE1_NCO=val(WE_VALUE)
  Gosub WE_ADDPROP
  WE_GRAB=0
  If WE_COLSP(WE_I) > 1
    WE_PROP="CPA" : WE_VALUE=num$(WE_COLSP(WE_I)) : Gosub WE_ADDPROP
  Endif
  If LIG_GRA(WE_NOBL,WE_F)=2
    WE_NTEX=LIG_TIT(WE_NOBL,WE_F)  : WE_CAPDEF=LIG_TXT(WE_NOBL,WE_F) :  : WE_LCH=WE_IND(WE_I)
    WE_INTEV=LIG_EVL(WE_NOBL,WE_F) : WE_FORCE=0 : Gosub WE_ADDNTEX
  Endif
  WE_PROP="HLP" : WE_VALUE=LIG_AID(WE_NOBL,WE_F) : Gosub WE_ADDPROP
            #  WE_PROP="STY"        : WE_VALUE="" : Gosub WE_ADDPROP
  If LIG_LIB(WE_NOBL,WE_F)<>0
    If LIG_GRA(WE_NOBL,WE_F)=1
      WE_NBCHC+=1
      WE_CHCOMB(1,WE_NBCHC)=1000*WE_NOBL+WE_MAXFB(WE_NOBL)
      WE_CHCOMB(2,WE_NBCHC)=WE_F
    Endif
    WE_PROP="MNU" : WE_VALUE=num$(LIG_LIB(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
 #   WE_PROP="MDI" : WE_VALUE=num$(len(mess(0,LIG_LIB(WE_NOBL,WE_F),1))) : Gosub WE_ADDPROP
    WE_PROP="MDI" : WE_VALUE=num$(func APLSTD.LENMEN(APPLI,LIG_LIB(WE_NOBL,WE_F))): Gosub WE_ADDPROP
  Endif
  WE_PROP="MAF" : WE_VALUE=num$(LIG_SAI(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  If LIG_OBL(WE_NOBL,WE_F)=2
    WE_PROP="OBL" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  #X3-91078
  If LIG_MAS(WE_NOBL,WE_F)=2
    WE_PROP="MAS" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  ###
  # Issue X3-110075 - 2018-10-03 by ALSHE : Break after field
  If LIG_BRK(WE_NOBL,WE_F)=2
    WE_PROP="BRK" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  # End issue X3-110075
  Gosub WE_ADDLNG
  If LIG_LGR(WE_NOBL,WE_F)<>0 and LIG_LGR(WE_NOBL,WE_F)<>LIG_LNG(WE_NOBL,WE_F)
    WE_PROP="AFL" : WE_VALUE=num$(LIG_LGR(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Endif
  If WE_COLLE(WE_I)=1
    WE_PROP="NOC" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  If instr(1,LIG_OPT(WE_NOBL,WE_F),"W")<>0
    WE_PROP="TYW" : WE_VALUE="W" : Gosub WE_ADDPROP
  Endif
  If LIG_GRA(WE_NOBL,WE_F)=13
    Local Char AVV1(80)
    AVV1=LIG_INI(WE_NOBL,WE_F)
    If left$(LIG_INI(WE_NOBL,WE_F),1)<>'"' and left$(LIG_INI(WE_NOBL,WE_F),1)<>"'"
      If instr(1,AVV1,'"')>0
        AVV1="'"+LIG_INI(WE_NOBL,WE_F)+"'"
      Else
        AVV1='"'+LIG_INI(WE_NOBL,WE_F)+'"'
      Endif
    Endif
    If val(evalue(AVV1))<>0
      WE_PROP="DEF" : WE_VALUE=num$(evalue(AVV1)) : Gosub WE_ADDPROP
    Endif
  Endif
#   Calcul en %
#    WE_PROP="X"  : WE_1=WE1_PLI*100/WE1_BNLI : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
#    WE_PROP="Y"  : WE_1=WE1_PCO*100/WE1_BNCO : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
#   Fin calcul

  If ISVT
    Gosub VT_EFLD
  Endif

  Gosub WE_ADDTOOLT
  Gosub WE_ACTFIELD
  If WE_ISRC=0
    Gosub WE_FINFF
  Else
    Gosub WE_FINF
    Gosub WE_ACTIONS
    Gosub WECR_FFIELD
  Endif
  If WE_CAP(WE_I)=0 and LIG_GRA(WE_NOBL,WE_F)>=3 and LIG_GRA(WE_NOBL,WE_F)<=6
    Gosub WECR_CAPTION
  Endif
  If BLC_TYP(WE_NOBL)=6 : Gosub WECR_GPHFL : Endif
  If BLC_TYP(WE_NOBL)=8 and LIG_ZON(WE_NOBL,WE_F)=BLC_BAS(WE_NOBL)
    Gosub WECR_GPHBRW
  Endif
  If BLC_TYP(WE_NOBL)=11 and LIG_ZON(WE_NOBL,WE_F)=BLC_BAS(WE_NOBL)
    Gosub WECR_GPHBO
  Endif
  If BLC_TYP(WE_NOBL)=9 and LIG_ZON(WE_NOBL,WE_F)=BLC_BAS(WE_NOBL)
    Gosub WECR_GPHEDI
  Endif
  If BLC_TYP(WE_NOBL)=7 and LIG_ZON(WE_NOBL,WE_F)=BLC_BAS(WE_NOBL)
    Gosub WECR_GPHBUR
  Endif

Return

$WECR_FFIELD
  #   Ecriture d'une fin de champ
  WE_VALL1="</FLD"
  Gosub WE_FINF
Return



# -------------------------------------------------------------------------------
#  7 - Type GRADIO

$WECR_GRADIO
  #   Ecriture du Gradio  WE_F du bloc WE_NOBL
  WE_F=WE_TLI(WE_I)
  WE_VALL1="<GRA"
  WE_MAXFB(WE_NOBL)+=1
  WE_PROP="XID"   : WE_VALUE=num$(LIG_IDX(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Gosub WECR_XD1
  WE_PROP="IDF"  : WE_VALUE=num$(BLC_IDX(WE_NOBL)) : Gosub WE_ADDPROP
  WE_PROP="TYP" : WE_VALUE="9" : Gosub WE_ADDPROP
#  WE_PROP="PLI" : WE_VALUE=num$((LIG_Y(WE_NOBL,WE_F)-1)*8+max(8*WE_IND(WE_I)-1,0)) : Gosub WE_ADDPROP
  WE_PROP="PLI" : WE1_PLI=(LIG_Y(WE_NOBL,WE_F)-1)*8-1 : WE_VALUE=num$(WE1_PLI) : Gosub WE_ADDPROP
  WE_PROP="PCO" : WE1_PCO=(LIG_X(WE_NOBL,WE_F)-1)*4-3 : WE_VALUE=num$(WE1_PCO) : Gosub WE_ADDPROP
  WE_PROP="NLI" : WE1_NLI=LIG_FLI(WE_NOBL,WE_F)*8 : WE_VALUE=num$(WE1_NLI) : Gosub WE_ADDPROP
  WE_PROP="NCO" : WE1_NCO=LIG_FLN(WE_NOBL,WE_F)*4 : WE_VALUE=num$(WE1_NCO) : Gosub WE_ADDPROP
  If  LIG_GRA(WE_NOBL,WE_F)=3 or LIG_GRA(WE_NOBL,WE_F)=5    : #  Uniquement si on a une zone encadrûˋe
    WE_NTEX=LIG_TIT(WE_NOBL,WE_F)  : WE_CAPDEF=LIG_TXT(WE_NOBL,WE_TLI(WE_I))
    WE_INTEV=LIG_EVL(WE_NOBL,WE_F) : WE_FORCE=0 : WE_LCH=0 : Gosub WE_ADDNTEX
  Endif
  WE_PROP="MNU" : WE_VALUE=num$(LIG_LIB(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
 # WE_PROP="MDI" : WE_VALUE=num$(len(mess(0,LIG_LIB(WE_NOBL,WE_F),1))) : Gosub WE_ADDPROP
  WE_PROP="MDI" : WE_VALUE=num$(func APLSTD.LENMEN(APPLI,LIG_LIB(WE_NOBL,WE_F))) : Gosub WE_ADDPROP
  WE_PROP="MAF" : WE_VALUE=num$(LIG_SAI(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  WE_PROP="HLP" : WE_VALUE=LIG_AID(WE_NOBL,WE_F) : Gosub WE_ADDPROP
  If LIG_OBL(WE_NOBL,WE_F)=2
    WE_PROP="OBL" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  #X3-91078
  If LIG_MAS(WE_NOBL,WE_F)=2
    WE_PROP="MAS" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  ###
  # Issue X3-110075 - 2018-10-03 by ALSHE : Break after field
  If LIG_BRK(WE_NOBL,WE_F)=2
    WE_PROP="BRK" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  # End issue X3-110075
  WE_PROP="ROG"
    WE_VALUE="1"
    If LIG_GRA(WE_NOBL,WE_F)=3 or LIG_GRA(WE_NOBL,WE_F)=4 : WE_VALUE="0" : Endif
  Gosub WE_ADDPROP
  WE_PROP="BOR" : WE_VALUE="0"
  If LIG_GRA(WE_NOBL,WE_F)=3 or LIG_GRA(WE_NOBL,WE_F)=5 : WE_VALUE="1" : Endif
  Gosub WE_ADDPROP

# Suite û  demande OG- Aoû£t 2003
  WE_PROP="NAM" : WE_VALUE=LIG_ZON(WE_NOBL,WE_F) :  Gosub WE_ADDPROP
  Gosub WE_ADDLNG
  Gosub WE_ADDFORM
  Gosub WE_ADDTOOLT

#   Calcul en %
#    WE_PROP="X"  : WE_1=WE1_PLI*100/WE1_BNLI : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
#    WE_PROP="Y"  : WE_1=WE1_PCO*100/WE1_BNCO : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
#   Fin calcul

  Gosub WE_ISRCLIC
  If WE_ISRC<>0
    WE_PROP="RCI" : WE_VALUE=num$(WE_ISRC) : Gosub WE_ADDPROP
  Endif
  Gosub WE_FINFF
Return

$WECR_FGRADIO
  #   Ecriture d'une fin de Gradio
  WE_VALL1="</GRA"
  Gosub WE_FINF
Return



# -------------------------------------------------------------------------------
#  8 - Type EMPTY

$WECR_EMPTY
  #   Ecriture d'un champ Empty
#  If WE_COLSP(WE_I)=4 : Return : Endif
  WE_VALL1="<EMP"
  If WE_COLSP(WE_I) > 1
    WE_PROP="CPA" : WE_VALUE=num$(WE_COLSP(WE_I)) : Gosub WE_ADDPROP
  Endif
  WE_F=WE_TLI(WE_I)
  If WE_F>0 and LIG_LGR(WE_NOBL,WE_F)<>0
    WE_PROP="AFL" : WE_VALUE=num$(LIG_LGR(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Endif
  Gosub WE_FINFF
Return

$WECR_FEMPTY
  #   Ecriture d'une fin de champ Empty
  WE_VALL1="</EMP"
  Gosub WE_FINF
Return

# -------------------------------------------------------------------------------
#  8 bis- Type EMPTY1

$WECR_EMPTY1
  #   Ecriture d'un champ Empty
  WE_VALL1="<EMP"
  Gosub WE_FINFF
Return

# -------------------------------------------------------------------------------
#  9 - Type LIGF

$WECR_LIGF
  #   Ecriture d'une ligne de champs
  WE_VALL1="<LIG"
  WE_PROP="NUM"  : WE_VALUE=num$(WE_IND(WE_I)) : Gosub WE_ADDPROP
  If WE_FINF(WE_I)=0
    Gosub WE_FINF
  Else
    Gosub WE_FINFF
  Endif
Return

$WECR_FLIGF
  #   Ecriture d'une fin de ligne de champs
  WE_VALL1="</LIG"
  Gosub WE_FINF
Return



# -------------------------------------------------------------------------------
#  10 - Type CAPTION

$WECR_CAPTION
  #   Ecriture du caption du champ  WE_F du bloc WE_NOBL
  #   (on ne l'ûˋcrit pas pour les champs occursûˋs sans intitulûˋ ûˋvaluûˋ)
  If LIG_TIT(WE_NOBL,WE_F)=0 and LIG_EVL(WE_NOBL,WE_F)="" : Return : Endif
  If WE_IND(WE_I)>1 and LIG_EVL(WE_NOBL,WE_F)="" : Goto WECR_EMPTY1 : Endif
  WE_VALL1="<CAP"
  If LIG_STY(WE_NOBL,WE_F)<>""
   WE_PROP="STX"  : WE_VALUE=num$(LIG_STY(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Endif
  WE_PROP="XID"  : WE_VALUE=num$(LIG_IDX(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Gosub WECR_XD1
  WE_PROP="IDF"  : WE_VALUE=num$(BLC_IDX(WE_NOBL)) : Gosub WE_ADDPROP
#   La colonne porteuse du libellûˋ est la prûˋcûˋdente du champ sauf pour les ûˋlûˋments graphiques
  If LIG_GRA(WE_NOBL,WE_F)>=2 and LIG_GRA(WE_NOBL,WE_F)<>10 and LIG_GRA(WE_NOBL,WE_F)<>13
    WE_T1 = -BLC_CAR(WE_NOBL,LIG_POS(WE_NOBL,WE_F)+1)
  Else
    If BLC_TYP(WE_NOBL)=4
      WE_T1=BLC_CAR(WE_NOBL,WE_F)-2
      LIG_FLI(WE_NOBL,WE_F)=1
    Else
      WE_T1 = BLC_CAR(WE_NOBL,max(LIG_POS(WE_NOBL,WE_F)-1,1))
    Endif
  Endif
  WE_PROP="PLI"    : WE1_PLI=max((LIG_Y(WE_NOBL,WE_F)-1)*8-1,0) : WE_VALUE=num$(WE1_PLI) : Gosub WE_ADDPROP
  WE_PROP="PCO"    : WE1_PCO=max((LIG_X(WE_NOBL,WE_F)-WE_T1-2)*4-2,0) : WE_VALUE=num$(WE1_PCO) : Gosub WE_ADDPROP
#  WE_PROP="NLI"   : WE1_NLI=LIG_FLI(WE_NOBL,WE_F)*8 : WE_VALUE=num$(WE1_NLI) : Gosub WE_ADDPROP
  WE_PROP="NLI"   : WE1_NLI=8 : WE_VALUE=num$(WE1_NLI) : Gosub WE_ADDPROP
  WE_PROP="NCO"   : WE1_NCO=WE_T1*4 : WE_VALUE=num$(WE1_NCO) : Gosub WE_ADDPROP
  WE_NTEX=LIG_TIT(WE_NOBL,WE_F)  : WE_CAPDEF=LIG_TXT(WE_NOBL,WE_F) : WE_LCH=WE_IND(WE_I)
  WE_INTEV=LIG_EVL(WE_NOBL,WE_F) : WE_FORCE=0 : Gosub WE_ADDNTEX

#   Pour les enrichissements graphiques X2
  If LIG_OBL(WE_NOBL,WE_F)=2
    WE_PROP="OBL" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  #X3-91078
  If LIG_MAS(WE_NOBL,WE_F)=2
    WE_PROP="MAS" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  ###
  # Issue X3-110075 - 2018-10-03 by ALSHE : Break after field
  If LIG_BRK(WE_NOBL,WE_F)=2
    WE_PROP="BRK" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  # End issue X3-110075
  WE_T1=0
  If LIG_PTA(WE_NOBL,WE_F)<>0
    For WE_T2=LIG_PTA(WE_NOBL,WE_F) To LIG_PTA(WE_NOBL,WE_F)+LIG_ACT(WE_NOBL,WE_F)-1
      If ACT_TYP(WE_T2)=9 : WE_T1=1 : Break 1 : Endif
    Next WE_T2
  Endif
  If (LIG_TUN(WE_NOBL,WE_F)=2 or WE_T1=1) and LIG_SAI(WE_NOBL,WE_F)=1
    WE_PROP="TUN" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif


#   Calcul en %
#    WE_PROP="X"  : WE_1=WE1_PLI*100/WE1_BNLI : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
#    WE_PROP="Y"  : WE_1=WE1_PCO*100/WE1_BNCO : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
#    WE_PROP="W"  : WE_1=WE1_NCO*100/WE1_BNCO : WE_VALUE=num$(WE_1) : Gosub WE_ADDPROP
#   Fin calcul

  If ISVT
    Gosub VT_ECAP
  Endif

  Gosub WE_FINFF
Return

$WECR_FCAPTION
  #   Ecriture d'une fin de caption
  WE_VALL1="</CAP"
  Gosub WE_FINF
Return



# -------------------------------------------------------------------------------
#  11 - Type RADIO

$WECR_RADIO
  #   Ecriture du radio bouton WE_F du bloc WE_NOBL  indice WE_IND(WE_I)
  WE_F=WE_TLI(WE_I)
  WE_VALL1="<RAD"
  WE_PROP="NAM"  : WE_VALUE=LIG_ZON(WE_NOBL,WE_F) : Gosub WE_ADDPROP
  WE_PROP="XID"   : WE_VALUE=num$(LIG_IDX(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Gosub WECR_XD1
  WE_PROP="VAL" : WE_VALUE=num$(WE_IND(WE_I)) : Gosub WE_ADDPROP
  WE_NTEX=-(LIG_LIB(WE_NOBL,WE_F)*1000+WE_IND(WE_I)) : WE_LCH=0
  WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=1 : Gosub WE_ADDNTEX
  WE_PROP="MAF" : WE_VALUE=num$(LIG_SAI(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Gosub WE_ACTFIELD
#   On ne met RCLIC que sur le premier RADIO du groupe
  If WE_IND(WE_I)=1
    If WE_ISRC=0
      Gosub WE_FINFF
    Else
      Gosub WE_FINF
      Gosub WE_ACTIONS
      Gosub WECR_FRADIO
    Endif
  Else
    Gosub WE_FINFF
  Endif
Return

$WECR_FRADIO
  #   Ecriture d'une fin de Radio bouton
  WE_VALL1="</RAD"
  Gosub WE_FINF
Return



# -------------------------------------------------------------------------------
#  12 - Type AREA

$WECR_AREA
  #   Ecriture d'une area

  WE_VALL1="<ARE"
  WE_PROP="BOR" : WE_VALUE="0"
  If WE_TLI(WE_I)<>0 and (LIG_GRA(WE_NOBL,WE_TLI(WE_I))=3 or LIG_GRA(WE_NOBL,WE_TLI(WE_I))=5)
    WE_VALUE="1"
  Endif
  Gosub WE_ADDPROP
  If  WE_VALUE="1"      : #  Uniquement si on a une zone encadrûˋe
    WE_NTEX=LIG_TIT(WE_NOBL,WE_TLI(WE_I))  : WE_CAPDEF=LIG_TXT(WE_NOBL,WE_TLI(WE_I))
    WE_INTEV=LIG_EVL(WE_NOBL,WE_TLI(WE_I)) : WE_FORCE=0 : WE_LCH=0 : Gosub WE_ADDNTEX
  Endif
  If WE_COLSP(WE_I) > 1
    WE_PROP="CPA" : WE_VALUE=num$(WE_COLSP(WE_I)) : Gosub WE_ADDPROP
  Endif
  If WE_ROWSP(WE_I) > 1
    WE_PROP="RPA" : WE_VALUE=num$(WE_ROWSP(WE_I)) : Gosub WE_ADDPROP
  Endif
  If WE_COLLE(WE_I)=1
    WE_PROP="TRG" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  Gosub WE_FINF
Return

$WECR_FAREA
  #   Ecriture d'une fin d'area
  WE_VALL1="</ARE"
  Gosub WE_FINF
Return



# -------------------------------------------------------------------------------
#  12 bis - Type AREA1     AREA pour champ graphiques

$WECR_AREA1
  #   Ecriture d'une area graphique
  WE_F=WE_TLI(WE_I)
  WE_VALL1="<ARG"
  WE_PROP="XID"   : WE_VALUE=num$(LIG_IDX(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  WE_PROP="IDF"  : WE_VALUE=num$(BLC_IDX(WE_NOBL)) : Gosub WE_ADDPROP
  WE_BOR=0
  If LIG_TIT(WE_NOBL,WE_F)<>0 or LIG_EVL(WE_NOBL,WE_F)<>""
    WE_BOR=1
  Endif
  If  WE_BOR=1 and LIG_GRA(WE_NOBL,WE_F)<>10 and LIG_GRA(WE_NOBL,WE_F)<>9
#  Bordure Uniquement si on a une zone encadrûˋe et ni texte multiligne ni image
    WE_GRAB=WE_BOR
    WE_NTEX=LIG_TIT(WE_NOBL,WE_TLI(WE_I))  : WE_CAPDEF=LIG_TXT(WE_NOBL,WE_TLI(WE_I))
    WE_INTEV=LIG_EVL(WE_NOBL,WE_TLI(WE_I)) : WE_FORCE=0 : WE_LCH=0 : Gosub WE_ADDNTEX
  Endif
  WE_PROP="BOR" : WE_VALUE=num$(WE_BOR) : Gosub WE_ADDPROP
  WE_PROP="PLI" : WE_VALUE=num$((LIG_Y(WE_NOBL,WE_F)-1)*8-1) : Gosub WE_ADDPROP
  WE_PROP="PCO" : WE_VALUE=num$((LIG_X(WE_NOBL,WE_F)-1)*4-3-WE_BOR) : Gosub WE_ADDPROP
  WE_PROP="NLI": WE_VALUE=num$(LIG_FLI(WE_NOBL,WE_F)*8) : Gosub WE_ADDPROP
  WE_PROP="NCO": WE_VALUE=num$(LIG_FLN(WE_NOBL,WE_F)*4+WE_BOR*2) : Gosub WE_ADDPROP
  If WE_COLSP(WE_I) > 1
    WE_PROP="CPA" : WE_VALUE=num$(WE_COLSP(WE_I)) : Gosub WE_ADDPROP
  Endif
  If LIG_GP1(WE_NOBL,WE_F) > 1
    WE_PROP="RPA" : WE_VALUE=num$(LIG_GP1(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  Endif
  Gosub WE_FINF
Return

$WECR_FAREA1
  #   Ecriture d'une fin d'area
  WE_VALL1="</ARG"
  Gosub WE_FINF
Return



# -------------------------------------------------------------------------------
#  13 - Type RCLIC

$WECR_RCLIC
  #   Ecriture d'un menu Rclic
  WE_VALL1="<RCL"
  Gosub WE_FINF
Return

$WECR_FRCLIC
  #   Ecriture d'une fin de menu Rclic
  WE_VALL1="</RCL"
  Gosub WE_FINF
Return



# -------------------------------------------------------------------------------
#  14 - Type ACTION

$WECR_ACTION
  #   Ecriture de l'action WE_AC du champ WE_CH du bloc WE_BL (c'est une action clic droit)
  WE_VALL1="<ACT"
  WE_PROP="NAM" : WE_VALUE=ACT_ACT(WE_AC) : Gosub WE_ADDPROP
  If ACT_TYP >=9 and ACT_TYP<=12 :   WE_T1=ACT_TYP(WE_AC)+120 : Endif
  If ACT_TYP >=15 and ACT_TYP<=30 :   WE_T1=ACT_TYP(WE_AC)+118 : Endif
  If ACT_TYP=8 or ACT_ACT(WE_AC)="%SELOBJ" or ACT_ACT(WE_AC)="%TABSEL" : WE_T1=2 : Endif
  If ACT_ACT(WE_AC)="%PROOBJ" :   WE_T1=144 : Endif
  If ACT_ACT(WE_AC)="%SELAVA" :   WE_T1=146 : Endif
  If ACT_ACT(WE_AC)="%TUNOBJ" :   WE_T1=129 : Endif
  WE_PROP="NAC" : WE_VALUE=num$(WE_T1) : Gosub WE_ADDPROP
  WE_NTEX=ACT_TIT(WE_AC)  : WE_CAPDEF=ACT_TXT(WE_AC) : WE_LCH=0
  WE_INTEV="" : WE_FORCE=1 : Gosub WE_ADDNTEX
  WE_PROP="TGT" : WE_VALUE="S"
  If (ACT_TYP(WE_AC)>=1 and ACT_TYP(WE_AC)<=6) or left$(ACT_ACT(WE_AC),1)="%"
    WE_VALUE="N"
  Endif
  Gosub WE_ADDPROP
  Gosub WE_FINFF
Return

$WECR_FACTION
  #   Ecriture d'une fin d'action
  WE_VALL1="</ACT"
  Gosub WE_FINF
Return


# -------------------------------------------------------------------------------
#  14 bis  - Type ACTION Aide

$WECR_ACTIONA
  #   Ecriture de l'action d'aide du champ WE_CH du bloc WE_BL
  WE_VALL1="<ACT"
  WE_PROP="NAM" : WE_VALUE="%HELP" : Gosub WE_ADDPROP
  WE_PROP="NAC" : WE_VALUE="148" : Gosub WE_ADDPROP
  WE_NTEX=-150041  : WE_CAPDEF="" : WE_LCH=0
  WE_INTEV="" : WE_FORCE=1 : Gosub WE_ADDNTEX
  WE_PROP="TGT" : WE_VALUE="H" : Gosub WE_ADDPROP
  Gosub WE_FINFF
Return



# -------------------------------------------------------------------------------
# -------------------------------------------------------------------------------
# -------------------------------------------------------------------------------
#   Utilitaires d'ûˋcriture



$WE_FINF
#      Ferme le tag et ûˋcrit l'enregistrement
  WE_VALL1+=">"
  Wrseq WE_VALL1 Using [HTM_]
Return


$WE_FINFF
#      Ferme le tag avec / et ûˋcrit l'enregistrement
  WE_VALL1+="/>"
  Wrseq WE_VALL1 Using [HTM_]
Return


$WE_ADDPROP
#      Ajoute une propriûˋtûˋ et ûˋcrit un enreg si la longueur de la ligne est > 100
  If len(WE_VALL1)+len(WE_PROP)+len(WE_VALUE) > 100
    Wrseq WE_VALL1 Using [HTM_]
    WE_VALL1=WE_PROP+'="'+WE_VALUE+'"'
  Else
    WE_VALL1-=WE_PROP+'="'+WE_VALUE+'"'
  Endif
Return


# -------------------------------------------------------------------------------
#   Traitement des propriûˋtûˋs


$WE_OPTTAB
# Traite les options de tableau
  For WE_T1=1 To 9
    WE_T2 = instr(1,WE_VALUE,num$(WE_T1))
    If WE_T2
      WE_VALUE = left$(WE_VALUE,WE_T2-1)+right$(WE_VALUE,WE_T2+1)
      Break
    Endif
  Next WE_T1
  If instr(1,WE_VALUE,"K")  : WE_VALUE += "M" : Endif : # Option d'enchaûÛnement de saisie
  If !instr(1,WE_VALUE,"G") : WE_VALUE += "G" : Endif
Return

$WE_ADDLNG
  WE_PROP="SZ"
  WE_4=LIG_LNG(WE_NOBL,WE_F)
  If WE_4<>LIG_LNG(WE_NOBL,WE_F)
    WE_3=LIG_LNG(WE_NOBL,WE_F)*10-WE_4*10
    WE_4+=WE_3+1
  Endif
  WE_VALUE=num$(WE_4)
  Gosub WE_ADDPROP
Return

$WE_ADDFORM
  WE_PROP="FMT"
  If LIG_FMT(WE_NOBL,WE_F)=""
    If left$(LIG_FTY(WE_NOBL,WE_F),1)<>"="
      WE_VALUE=LIG_FTY(WE_NOBL,WE_F)+LIG_FOP(WE_NOBL,WE_F)+":"+LIG_FCH(WE_NOBL,WE_F)
      VALLM=WE_VALUE
      Gosub MVALC From INTRUTILA
      WE_VALUE=VALLM
    Else
      WE_VALUE=""
    Endif
    If WE_VALUE=":" : WE_VALUE="" : Endif
# Bug 40658    : CC  10/04/2007
    If WE_VALUE="" and LIG_FNU(WE_NOBL,WE_F)=TABLO
      WE_VALUE="N:4#"
      If BLC_LIG(WE_NOBL)>=10000 : WE_VALUE="N:5#" : Endif
    Endif
    Gosub WE_ADDPROP
  Elsif left$(LIG_FMT(WE_NOBL,WE_F),1)<>"="
    WE_VALUE=LIG_FMT(WE_NOBL,WE_F)
    VALLM=WE_VALUE
    Gosub MVALC From INTRUTILA
    WE_VALUE=VALLM
    If WE_VALUE=":" : WE_VALUE="" : Endif
    Gosub WE_ADDPROP
  Endif
# CC 15/01/2004      ---- Zone numûˋriques sont û  considûˋrer en dûˋcimal
  Case LIG_TYI(WE_NOBL,WE_F)
    When 1,7,8,9,10       : WE_T5=LIG_TYI(WE_NOBL,WE_F)
    When Default          : WE_T5=4
  Endcase
  WE_PROP="TDO" : WE_VALUE=num$(WE_T5) : Gosub WE_ADDPROP
  If LIG_OPT(WE_NOBL,WE_F)="5"      : #  Pour traiter les saisonnalitûˋs JJ/MM (annûˋe imposûˋe)
    WE_PROP="DAI" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  WE_VALUE=""    : # Options de cadrage - Bug 32342   CC 03/10/2005
  If instr(1,LIG_OPT(WE_NOBL,WE_F),">")<>0 : WE_VALUE="0" : Endif
  If instr(1,LIG_OPT(WE_NOBL,WE_F),"<")<>0 : WE_VALUE="1" : Endif
  If instr(1,LIG_OPT(WE_NOBL,WE_F),"=")<>0 : WE_VALUE="2" : Endif
  If WE_VALUE<>"" :  WE_PROP="ALG" : Gosub WE_ADDPROP : Endif
  If LIG_TRF(WE_NOBL,WE_F)=2 and LIG_TYP(WE_NOBL,WE_F)="AEX"
  #  WE_PROP="TFD" : WE_VALUE=num$(LIG_TEC(WE_NOBL,WE_F)) : Gosub WE_ADDPROP
  #  If LIG_TEC(WE_NOBL,WE_F)=3 : WE_EXCL=WE_F : Endif
    WE_EXCL=WE_F
  Endif
Return


$WE_ADDTYP
 #  Type Graphique  ...   Quid de Spin Edit ? Texte multilignes=Rich Text ?
  WE_PROP="TYP" : WE_VALUE="6"
  If LIG_LIB(WE_NOBL,WE_F)<>0
    If LIG_GRA(WE_NOBL,WE_F)<=1 : WE_VALUE="7" : Endif
    If LIG_GRA(WE_NOBL,WE_F)=2 : WE_VALUE="11" : Endif
  Endif
  If LIG_TYI(WE_NOBL,WE_F)=10 : WE_VALUE="8" : Endif
  If LIG_TYI(WE_NOBL,WE_F)=9
    WE_NBCHC+=1
    WE_CHCOMB(1,WE_NBCHC)=1000*WE_NOBL+WE_MAXFB(WE_NOBL)
    WE_CHCOMB(2,WE_NBCHC)=-1
    WE_VALUE="17"
    If BLC_TYP(WE_NOBL)=7 : WE_VALUE="33" : Endif    : # Champ Office
  Endif
  If LIG_GRA(WE_NOBL,WE_F)=8 : WE_VALUE="14" : Endif
  If LIG_GRA(WE_NOBL,WE_F)=9 : WE_VALUE="17" : Endif
  If LIG_GRA(WE_NOBL,WE_F)>=11 and LIG_GRA(WE_NOBL,WE_F)<=12  : WE_VALUE="8" : Endif

# A rajouter dû´s que le nouveau client est distribuûˋ
#  ---------- IcûÇnes
  If left$(LIG_FTY(WE_NOBL,WE_F),3)="KIL" or left$(LIG_FTY(WE_NOBL,WE_F),3)="KIB" : WE_VALUE="29" : Endif
#  ---------- Mots de passe
  If (left$(LIG_FTY(WE_NOBL,WE_F),1)<>"=" and instr(1,LIG_FMT(WE_NOBL,WE_F),"X:"))
&     or instr(1,LIG_OPT(WE_NOBL,WE_F),"X")<>0
    WE_VALUE="30"
  Endif
#
  If LIG_TRF(WE_NOBL,WE_F)=2 : WE_VALUE="32" : Endif
  Gosub WE_ADDPROP
  If BLC_TYP(WE_NOBL)=7
    WE_PROP="GTY"
    Case BLC_TYPG(WE_NOBL)
      When 1 :  WE_VALUE="8"     : # Word
      When 2 :  WE_VALUE="7"     : # Excel
      When 3 :  WE_VALUE="10"     : # Power point
      When Default :  WE_VALUE="9"     : # Banalisûˋ (choix 4 en fait)
    Endcase
    Gosub WE_ADDPROP
  Endif
  If LIG_GRA(WE_NOBL,WE_F)=10
    WE_PROP="MLT" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  If LIG_TYI(WE_NOBL,WE_F)=10      : # Type de texte
    WE_VALUE="3"
    If left$(LIG_FTY(WE_NOBL,WE_F),3)="KR1" : WE_VALUE="1" : Endif
    If left$(LIG_FTY(WE_NOBL,WE_F),3)="KR2" : WE_VALUE="2" : Endif
    WE_PROP="TTE" : Gosub WE_ADDPROP
  Endif
Return

#  Dûˋtermine si il y a des actions sur le champ courant
$WE_ACTFIELD
#  Local Integer WE_INIB,WE_FOCUS,WE_BLUR,WE_CHANGE
#  If LIG_ACT(WE_NOBL,WE_F)=0 : Goto WE_ACTFIELD1 : Endif
#########################################################################################
## Pseudos_actions gûˋrûˋes par le superviseur
#########################################################################################
## %CNTOBJ    ContrûÇle d'un objet
## %LIEN      Affichage zone de lien d'un objet
## %INILNK    Init de la zone de lien
## %DEFOBL    Valeur par dûˋfaut obligatoire (*)
## %DEFVAL    Valeur par dûˋfaut
## %ACCAVT    Code d'accû´s sans visu
## %ACCSAI    Code d'accûˋs avec visu
## %MENINI    Init menu local û  1 (init)
## %MENAVT    Init menu local û  1 (avant_saisie)
## %MENSAI    Init an fonction des choix dûˋsactivûˋs (GMENLOC)
## %MENDIS    Discombos des choix dûˋsactvûˋs (GMENLOC)
## %MENCNT    ContrûÇle des choix dûˋsactivûˋs (GMENLOC)
## %INIBOU    Init des intitulûˋs de boutons
## %TABCNT    ContrûÇle table de contrûÇle
## %CNSSAI    Condition de saisie
## %ADIOBL    Valeur par dûˋfaut table diverse obligatoire
## %BASEVL    Raffraichissement des intitulûˋs ûˋvaluûˋs de colonne
## %BASDEV    Init des variables de formats variables
## %BASAFF    ?? (Bas de tableau affichûˋ) ??
#########################################################################################

#  For WE_AC=LIG_PTA(WE_NOBL,WE_F) To LIG_PTA(WE_NOBL,WE_F)+LIG_ACT(WE_NOBL,WE_F)-1
#    Case ACT_TYP(WE_AC)
#      When 1        : WE_INIB=1
#      When 2,3,4,13 : WE_FOCUS=1
#      When 5,6,14   : WE_BLUR=1
#      When 7        : WE_CHANGE=1
#    Endcase
 #  ajout d'action en fonction de ACT_ACT
 # ACT_ACT(WE_AC)="%TABSEL"
#  Next WE_AC

 $WE_ACTFIELD1
#  If WE_INIB=1   : WE_PROP="INB" : WE_VALUE="1" : Gosub WE_ADDPROP : Endif
#  If WE_FOCUS=1  : WE_PROP="FOC" : WE_VALUE="1" : Gosub WE_ADDPROP : Endif
#  If WE_BLUR=1   : WE_PROP="BLU" : WE_VALUE="1" : Gosub WE_ADDPROP : Endif
#  If WE_CHANGE=1 : WE_PROP="CHG" : WE_VALUE="1" : Gosub WE_ADDPROP : Endif
  Gosub WE_ISRCLIC  : # CC 05/06/03
  If WE_ISRC<>0
    WE_PROP="RCI" : WE_VALUE="1" : Gosub WE_ADDPROP
  Endif
  WE_ISRC=0     : # CC 30/01/2004 le menu clic droit est devenu inutile dans le XML
Return



#    Traitement particulier de la propriûˋtûˋ NTEX  (INTEV est pris en majeur)
#    WE_NTEX   :  No du texte û  traiter
#    WE_CAPDEF :  Caption dans la langue par dûˋfaut
#    WE_INTEV  :  Intitulûˋ ûˋvaluûˋ
#    WE_FORCE  :  =1 si on doit ûˋcrire le libellûˋ mûˆme si il est vide
#    WE_LCH    :  = indice du champ dimensinnûˋ
#                 (si il y en a un - pour traiter les intitulûˋs ûˋvaluûˋs avec indice)
#

#    Pour les champs dimensionnûˋs :
#       Si checkbox le caption est rûˋpûˋtûˋ sur chaque occurence
#       Sinon si l'intitulûˋ commence par # il est rûˋpûˋtûˋ sur chaque ligne (sans le #)
#             si l'intitulûˋ contient des \ c'est la dûˋcomposition sur chaque ligne de l'intitulûˋ
#

# Issue 75246/7 - 2012-07-30 by VPO : mots-clûˋ d'aide (info-bulle)
#$WE_ADDTOOLT
#  If LIG_INF(WE_NOBL,WE_F)=0 : Return : Endif
#  WE_NTEX=LIG_INF(WE_NOBL,WE_F)
#  WE_PROP="NTT" : WE_VALUE=num$(WE_NTEX) : Gosub WE_ADDPROP
#  For WE_T2=1 To GI_NBLAN
#    Gosub WE_LANGC
#    WE_PROP="T_"+GI_LLAN(WE_T2)
#    Gosub WE_ADDPROP
#  Next WE_T2
#Return
$WE_ADDTOOLT
  If LIG_AIDBUL(WE_NOBL,WE_F)="" & LIG_INF(WE_NOBL,WE_F)=0 : Return : Endif
  WE_NTEX=LIG_INF(WE_NOBL,WE_F)
  If WE_NTEX=0 : WE_NTEX=1000 : Endif
  WE_PROP="NTT" : WE_VALUE=num$(WE_NTEX) : Gosub WE_ADDPROP
  For WE_T2=1 To GI_NBLAN
    WE_VALUE=""
    If LIG_AIDBUL(WE_NOBL,WE_F)<>""
      WE_VALUE=LIG_AIDBUL(WE_NOBL,WE_F)
      Gosub WE_LANGC_ADZ
    Endif
    If WE_VALUE="" & WE_NTEX<>1000
      Gosub WE_LANGC
    Endif
    WE_PROP="T_"+GI_LLAN(WE_T2)
    Gosub WE_ADDPROP
  Next WE_T2
Return



$WE_ADDNTEX
  If WE_NTEX<>0 or WE_FORCE=1 or WE_INTEV<>""
    WE_PROP="NTE" : WE_VALUE=num$(WE_NTEX) : Gosub WE_ADDPROP
  Else
    Return
  Endif
  For WE_T2=1 To GI_NBLAN
    If WE_NTEX<0
      Gosub WE_TMENL
    Else
      If WE_INTEV<>""
        Gosub WE_EVALCAP
      Else
#        If GI_LLAN(WE_T2)=GLANGUE
#          WE_VALUE=WE_CAPDEF
#          If WE_VALUE<>""
#            VALLM=WE_VALUE
#            Gosub MVALC From INTRUTILA
#            WE_VALUE=VALLM
#          Endif
#          If WE_VALUE="" and WE_NTEX<>0 : Gosub WE_LANGC : Endif
#        Else
          If WE_NTEX=0
            WE_VALUE=""
          Else
            Gosub WE_LANGC
          Endif
#        Endif
      Endif
    Endif
    WE_PROP="C_"+GI_LLAN(WE_T2)
    If GI_LLAN(WE_T2)=GLANGUE : WE_CAPCOU=WE_VALUE : Endif
    Gosub WE_ADDPROP
  Next WE_T2
Return

$WE_EVALCAP
indice=0
If WE_LCH<>0 : indice=WE_LCH-1 : Endif
Raz WE_VALUE
If left$(WE_INTEV,1)="#"
  If APPLI<>nomap and mid$(WE_INTEV,2,5)="mess("    : # Bug 36294 : menus diffûˋrents entre dossiers
    WE_T4=instr(7,WE_INTEV,",")
    WE_T5=instr(WE_T4+1,WE_INTEV,",")
    WE_VALUE=mid$(WE_INTEV,7,WE_T4-7)
    WE_NOMES=evalue(WE_VALUE)
    WE_VALUE=mid$(WE_INTEV,WE_T4+1,WE_T5-WE_T4-1)
    WE_NOMEN=evalue(WE_VALUE)

    Read [AST]CLE=WE_NOMEN;WE_NOMES;GI_LLAN(WE_T2)
    If fstat=0 Then
      WE_VALUE=[F:AST]LANMES
    Else
      If GI_LLAN(WE_T2)<>GLANGUE
        Read [AST]CLE=WE_NOMEN;WE_NOMES;GLANGUE
      Else
        Read [AST]CLE=WE_NOMEN;WE_NOMES;GLANDEF
      Endif
      If fstat=0 : WE_VALUE=[F:AST]LANMES : Else : WE_VALUE="" : Endif
    Endif
    VALLM=WE_VALUE
    Gosub MVALC From INTRUTILA
    WE_VALUE=VALLM
  Else
    If GI_LLAN(WE_T2)<>GLANGUE     : # Il faut changer la langue par dûˋfaut
      WE_SAVLANG=GLANGUE
      WE_LANGUE=GI_LLAN(WE_T2)
      Gosub WE_SETLANG
      Gosub WE_EVALCAP1
      WE_LANGUE=WE_SAVLANG
      Gosub WE_SETLANG
    Else
      Gosub WE_EVALCAP1
    Endif
  Endif
  If WE_T2=1           : # On ne met EVL qu'une fois
    WE_SAVVAL=WE_VALUE
    VALLM=right$(WE_INTEV,2)
#                        On ûˋvalue indice dans le format stockûˋ dans l'XML pour faciliter la reprise
$WE_ENDLID:
    WE_4=instr(1,VALLM,"indice")
    If WE_4>0
      VALLM=left$(VALLM,WE_4-1)+num$(indice)+right$(VALLM,WE_4+6)
      Goto WE_ENDLID
    Endif
    Gosub MVALC From INTRUTILA
    WE_PROP="EVL" : WE_VALUE=VALLM : Gosub WE_ADDPROP
    WE_VALUE=WE_SAVVAL
  Endif
Endif
Return

$WE_EVALCAP1
  Onerrgo WE_ERREV
  WE_VALUE=evalue(right$(WE_INTEV,2))
  VALLM=WE_VALUE
  Gosub MVALC From INTRUTILA
  WE_VALUE=VALLM
  Onerrgo ERREUR From VALMSK
Return


$WE_ERREV
 WE_VALUE=""
Resume


#  Donne le caption associûˋ û  WE_NTEX dans la langue GI_LLAN(WE_T2)
$WE_LANGC
#If (left$(NTEX,1)="A") : Goto WE_ITEXT2 : Endif
#  Texte normal  (ATT)
Read [ATX]NUMERO = GI_LLAN(WE_T2);WE_NTEX
If fstat=0
 WE_VALUE = [F:ATX]TEXTE
Else
 If GI_LLAN(WE_T2)<>GLANGUE
   Read [ATX]NUMERO = GLANGUE;WE_NTEX
 Else
   Read [ATX]NUMERO = GLANDEF;WE_NTEX
 Endif
 If fstat=0
   WE_VALUE = [F:ATX]TEXTE
 Else
   WE_VALUE = ""
 Endif
Endif
VALLM=WE_VALUE
Gosub MVALC From INTRUTILA
WE_VALUE=VALLM
Return

#  Donne le caption associûˋ û  WE_NTEX dans la langue GI_LLAN(WE_T2)
$WE_LANGC_ADZ
#If (left$(NTEX,1)="A") : Goto WE_ITEXT2 : Endif
#  Texte normal  (ATT)
VALLM=WE_VALUE
WE_VALUE=""
Read [ADZ]ADZ0 = GI_LLAN(WE_T2);VALLM
If fstat=0
 Setlob WE_AIDVAL With [F:ADZ]TEXTE
 WE_VALUE=WE_AIDVAL
Else
 Read [ADZ1]ADZ0 = GI_LLAN(WE_T2);VALLM
 If fstat=0
  Setlob WE_AIDVAL With [F:ADZ1]TEXTE
  WE_VALUE=WE_AIDVAL
 Else
   If GI_LLAN(WE_T2)<>GLANGUE
     Read [ADZ]ADZ0 = GLANGUE;VALLM
   Else
     Read [ADZ]ADZ0 = GLANDEF;VALLM
   Endif
   If fstat=0
     Setlob WE_AIDVAL With [F:ADZ]TEXTE
     WE_VALUE=WE_AIDVAL
   Else
     If GI_LLAN(WE_T2)<>GLANGUE
       Read [ADZ1]ADZ0 = GLANGUE;VALLM
     Else
       Read [ADZ1]ADZ0 = GLANDEF;VALLM
     Endif
     If fstat=0
      Setlob WE_AIDVAL With [F:ADZ1]TEXTE
      WE_VALUE=WE_AIDVAL
     Endif
   Endif
 Endif
Endif
VALLM=WE_VALUE
Gosub MVALC From INTRUTILA
WE_VALUE=VALLM
Return

$WE_ITEXT2:       :#  A voir si nûˋcessaire en 140
#  Texte traductible  (AXX)
Read [AXX]AXX0 = GI_LLAN(WE_T2);WE_NTEX
If fstat=0
  WE_VALUE = [F:AXX]TEXTE
Else
 If GI_LLAN(WE_T2)<>GLANGUE
   Read [AXX]AXX0 = GLANGUE;WE_NTEX
 Else
   Read [AXX]AXX0 = GLANDEF;WE_NTEX
 Endif
 If fstat=0
  WE_VALUE = [F:AXX]TEXTE
 Else
  WE_VALUE = ""
 Endif
Endif
VALLM=WE_VALUE
Gosub MVALC From INTRUTILA
WE_VALUE=VALLM
Return

#  Texte dans un Menu local
$WE_TMENL
WE_NOMEN=-WE_NTEX/1000
WE_NOMES=-WE_NTEX-WE_NOMEN*1000
Read [AST]CLE=WE_NOMEN;WE_NOMES;GI_LLAN(WE_T2)
If fstat=0 Then
  WE_VALUE=[F:AST]LANMES
Else
  If GI_LLAN(WE_T2)<>GLANGUE
    Read [AST]CLE=WE_NOMEN;WE_NOMES;GLANGUE
  Else
    Read [AST]CLE=WE_NOMEN;WE_NOMES;GLANDEF
  Endif
  If fstat=0 : WE_VALUE=[F:AST]LANMES : Else : WE_VALUE="" : Endif
Endif
VALLM=WE_VALUE
Gosub MVALC From INTRUTILA
WE_VALUE=VALLM
If WE_NTEX=-100016 and dim(WE_INDIG)>0 : WE_VALUE-=num$(WE_INDIG-1) : Endif   : # Pour avoir Page n
Return

$WE_ERR:
  WE_VALL1="Erreur "+WE_TBL(WE_I)
  Wrseq WE_VALL1 Using [HTM_]
Return



$WE_SETLANG
adxrob(0)   = "ECR"
adxrob(1)   = "M"+WE_LANGUE
messname(0) = WE_LANGUE
adxtms      = APPLI+".APLSTD"
adxmbm      = adxmbm
GLANGUE     = WE_LANGUE
Return


# -------------------------------------------------------------------------------
# -------------------------------------------------------------------------------
# -------------------------------------------------------------------------------
#   Utilitaires de traitement des champs dimensionnûˋs


#  On traite la duplication du champ dimensionnûˋ WE_I du bloc WE_NOBL
$WE_DUPFIELD
# On cherche avant quel champ insûˋrer
For WE_2=2 To LIG_DIM(WE_NOBL,WE_I)
  For WE_1=WE_I+1 To MAXLIG
    If LIG_ZON(WE_NOBL,WE_1)="" : Break 1 : Endif
    If int(LIG_NUM(WE_NOBL,WE_1))>=int(LIG_NUM(WE_NOBL,WE_I))+WE_2 : Break 1 : Endif
    If int(LIG_NUM(WE_NOBL,WE_1))=int(LIG_NUM(WE_NOBL,WE_I))+WE_2-1
      If LIG_POS(WE_NOBL,WE_1)>LIG_POS(WE_NOBL,WE_I) : Break 1 : Endif
    Endif
  Next WE_1

# On dûˋcale û  partir de WE_1
  Gosub WE_DECAL

# On duplique la ligne origine WE_I û  la position WE_1
  Gosub WE_DUPLIG

# On change les valeurs dûˋpendant de la ligne WE_1
    LIG_NUM(WE_NOBL,WE_1)=LIG_NUM(WE_NOBL,WE_I)+WE_2-1      : # Numûˋro de zone
    LIG_Y(WE_NOBL,WE_1)=LIG_Y(WE_NOBL,WE_I)+WE_2-1          : # Position Y (1..21)
    LIG_IDX(WE_NOBL,WE_1)=LIG_IDX(WE_NOBL,WE_I)+WE_2-1      : # Identifiant numûˋrique de chaque champ
# On incrûˋmente le nombre de champs du bloc et on initialise le compteur de duplication
    LIG_NBR(WE_NOBL)+=1                                     : # Nombre de champs par bloc
    LIG_DUP(WE_NOBL,WE_1)=WE_2                              : # Si champ dupliquûˋ
    LIG_ORI(WE_NOBL,WE_1)=WE_I                              : # Si champ dupliquûˋ
Next WE_2
Return



$WE_DECAL
  For WE_3=LIG_NBR(WE_NOBL) To WE_1 Step -1
    WE_ORI=WE_3 : WE_DEST=WE_3+1 : Gosub WE_DUPL
  Next WE_3
Return


$WE_DUPLIG
    WE_ORI=WE_I : WE_DEST=WE_1 : Gosub WE_DUPL
Return




$WE_DUPL
    LIG_DUP(WE_NOBL,WE_DEST)=LIG_DUP(WE_NOBL,WE_ORI)          : # Si champ dupliquûˋ
    LIG_ZON(WE_NOBL,WE_DEST)=LIG_ZON(WE_NOBL,WE_ORI)          : # Code de la zone
    LIG_DIM(WE_NOBL,WE_DEST)=LIG_DIM(WE_NOBL,WE_ORI)          : # Dimension
    LIG_NUM(WE_NOBL,WE_DEST)=LIG_NUM(WE_NOBL,WE_ORI)          : # Numûˋro de zone
    LIG_PDS(WE_NOBL,WE_DEST)=LIG_PDS(WE_NOBL,WE_ORI)          : # Poids (nb de colonnes)
    LIG_ACV(WE_NOBL,WE_DEST)=LIG_ACV(WE_NOBL,WE_ORI)          : # Code activitûˋ
    LIG_TIT(WE_NOBL,WE_DEST)=LIG_TIT(WE_NOBL,WE_ORI)          : # Intitulûˋ (no texte)
    LIG_TXT(WE_NOBL,WE_DEST)=LIG_TXT(WE_NOBL,WE_ORI)          : # Intitulûˋ (langue courante)
    LIG_INF(WE_NOBL,WE_DEST)=LIG_INF(WE_NOBL,WE_ORI)          : # Info bulle
    # Issue 75246/7 - 2012-07-30 by VPO : mots-clûˋ d'aide (info-bulle)
    LIG_AIDBUL(WE_NOBL,WE_DEST)=LIG_AIDBUL(WE_NOBL,WE_ORI)    : # Mot clûˋ d'aide (Info bulle)
    LIG_TYP(WE_NOBL,WE_DEST)=LIG_TYP(WE_NOBL,WE_ORI)          : # Type de donnûˋe (alpha)
    LIG_TYI(WE_NOBL,WE_DEST)=LIG_TYI(WE_NOBL,WE_ORI)          : # Type de donnûˋes interne (1..8)
    LIG_LNG(WE_NOBL,WE_DEST)=LIG_LNG(WE_NOBL,WE_ORI)          : # Longueur (au sens adonix)
    LIG_LIB(WE_NOBL,WE_DEST)=LIG_LIB(WE_NOBL,WE_ORI)          : # No menu local
    LIG_EVL(WE_NOBL,WE_DEST)=LIG_EVL(WE_NOBL,WE_ORI)          : # Intitulûˋ ûˋvaluûˋ
    LIG_OBL(WE_NOBL,WE_DEST)=LIG_OBL(WE_NOBL,WE_ORI)          : # Zone obligatoire
    LIG_MAS(WE_NOBL,WE_DEST)=LIG_MAS(WE_NOBL,WE_ORI)          : # Is maskable X3-91078
    LIG_BRK(WE_NOBL,WE_DEST)=LIG_BRK(WE_NOBL,WE_ORI)          : # Issue X3-110075 - 2018-10-03 by ALSHE : Break after field
    LIG_TUN(WE_NOBL,WE_DEST)=LIG_TUN(WE_NOBL,WE_ORI)          : # Tunnel
    LIG_LIE(WE_NOBL,WE_DEST)=LIG_LIE(WE_NOBL,WE_ORI)          : # Lien
    LIG_SAI(WE_NOBL,WE_DEST)=LIG_SAI(WE_NOBL,WE_ORI)          : # Saisie/affichûˋ
    LIG_TRF(WE_NOBL,WE_DEST)=LIG_TRF(WE_NOBL,WE_ORI)          : # Option de transmission
 #   LIG_TEC(WE_NOBL,WE_DEST)=LIG_TEC(WE_NOBL,WE_ORI)          : # Type de champ technique
    LIG_MOD(WE_NOBL,WE_DEST)=LIG_MOD(WE_NOBL,WE_ORI)          : # Mode fiche/tableau
    LIG_OBJ(WE_NOBL,WE_DEST)=LIG_OBJ(WE_NOBL,WE_ORI)          : # Objet liûˋ
    LIG_FIC(WE_NOBL,WE_DEST)=LIG_FIC(WE_NOBL,WE_ORI)          : # Fichier liûˋ
    LIG_ABR(WE_NOBL,WE_DEST)=LIG_ABR(WE_NOBL,WE_ORI)          : # Abrûˋviation fichier liûˋ
    LIG_ZLI(WE_NOBL,WE_DEST)=LIG_ZLI(WE_NOBL,WE_ORI)          : # Zone de lien
    LIG_ZTY(WE_NOBL,WE_DEST)=LIG_ZTY(WE_NOBL,WE_ORI)          : # Type de la zone de lien
    LIG_OBP(WE_NOBL,WE_DEST)=LIG_OBP(WE_NOBL,WE_ORI)          : # Options de l'objet
    LIG_OPT(WE_NOBL,WE_DEST)=LIG_OPT(WE_NOBL,WE_ORI)          : # Options de saisie
    LIG_LGR(WE_NOBL,WE_DEST)=LIG_LGR(WE_NOBL,WE_ORI)          : # Longueur spûˋciale
    LIG_LLI(WE_NOBL,WE_DEST)=LIG_LLI(WE_NOBL,WE_ORI)          : # Longueur lien
    LIG_FMT(WE_NOBL,WE_DEST)=LIG_FMT(WE_NOBL,WE_ORI)          : # Format particulier
    LIG_CNS(WE_NOBL,WE_DEST)=LIG_CNS(WE_NOBL,WE_ORI)          : # Condition de saisie
    LIG_INI(WE_NOBL,WE_DEST)=LIG_INI(WE_NOBL,WE_ORI)          : # Valeur par dûˋfaut
    LIG_CTL(WE_NOBL,WE_DEST)=LIG_CTL(WE_NOBL,WE_ORI)          : # Table de contrûÇle
    LIG_ACC(WE_NOBL,WE_DEST)=LIG_ACC(WE_NOBL,WE_ORI)          : # Code d'accû´s
    LIG_AID(WE_NOBL,WE_DEST)=LIG_AID(WE_NOBL,WE_ORI)          : # Mot-clûˋ d'aide
    LIG_GRA(WE_NOBL,WE_DEST)=LIG_GRA(WE_NOBL,WE_ORI)          : # Objet graphique
    LIG_GP1(WE_NOBL,WE_DEST)=LIG_GP1(WE_NOBL,WE_ORI)          : # Paramû´tre 1
    LIG_GP2(WE_NOBL,WE_DEST)=LIG_GP2(WE_NOBL,WE_ORI)          : # Paramû´tre 2
    LIG_GP3(WE_NOBL,WE_DEST)=LIG_GP3(WE_NOBL,WE_ORI)          : # Paramû´tre 3
    LIG_ACT(WE_NOBL,WE_DEST)=LIG_ACT(WE_NOBL,WE_ORI)          : # Nombre d'actions
    LIG_PTA(WE_NOBL,WE_DEST)=LIG_PTA(WE_NOBL,WE_ORI)          : # Pointeur dûˋbut action => ACT_xxx
    LIG_FTY(WE_NOBL,WE_DEST)=LIG_FTY(WE_NOBL,WE_ORI)          : # Type de format (K,N,D,...)
    LIG_FOP(WE_NOBL,WE_DEST)=LIG_FOP(WE_NOBL,WE_ORI)          : # Options de format (3,...)
    LIG_FCH(WE_NOBL,WE_DEST)=LIG_FCH(WE_NOBL,WE_ORI)          : # Chaine de format (10X,...)
    LIG_FNU(WE_NOBL,WE_DEST)=LIG_FNU(WE_NOBL,WE_ORI)          : # Numûˋro de format (302,303,...)
    LIG_FLN(WE_NOBL,WE_DEST)=LIG_FLN(WE_NOBL,WE_ORI)          : # Longueur de la zone en colonnes
    LIG_FLI(WE_NOBL,WE_DEST)=LIG_FLI(WE_NOBL,WE_ORI)          : # Hauteur de la zone en nb de lignes
    LIG_COL(WE_NOBL,WE_DEST)=LIG_COL(WE_NOBL,WE_ORI)          : # Nb de colonnes
    LIG_POS(WE_NOBL,WE_DEST)=LIG_POS(WE_NOBL,WE_ORI)          : # Position en colonne
    LIG_SUI(WE_NOBL,WE_DEST)=LIG_SUI(WE_NOBL,WE_ORI)          : # Flag suite
    LIG_PRO(WE_NOBL,WE_DEST)=LIG_PRO(WE_NOBL,WE_ORI)          : # No de programme
    LIG_X(WE_NOBL,WE_DEST)=LIG_X(WE_NOBL,WE_ORI)              : # Position X (1..64)
    LIG_Y(WE_NOBL,WE_DEST)=LIG_Y(WE_NOBL,WE_ORI)              : # Position Y (1..21)
    LIG_IDX(WE_NOBL,WE_DEST)=LIG_IDX(WE_NOBL,WE_ORI)          : # Identifiant numûˋrique de chaque champ
    LIG_ORI(WE_NOBL,WE_DEST)=LIG_ORI(WE_NOBL,WE_ORI)          : # Indice du premier champ si champ dupliquûˋ
    LIG_STC(WE_NOBL,WE_DEST)=LIG_STC(WE_NOBL,WE_ORI)          : # Style
    LIG_STY(WE_NOBL,WE_DEST)=LIG_STY(WE_NOBL,WE_ORI)          : # Style
    LIG_STZ(WE_NOBL,WE_DEST)=LIG_STZ(WE_NOBL,WE_ORI)          : # Style
    LIG_TRG(WE_NOBL,WE_DEST)=LIG_TRG(WE_NOBL,WE_ORI)          : # Paramû´tre graphique
    LIG_TRP(WE_NOBL,WE_DEST)=LIG_TRP(WE_NOBL,WE_ORI)          : # Type de reprûˋsentation multi graphe
Return


$WE_VISU
  Local Char URL(200),RETOUR(200),AASEP
  AASEP="/"
  If instr(1,GVIRTDIR,"\") : AASEP="\" : Endif
  URL=GVIRTDIR+AASEP+APPLI+AASEP+"GEN"+AASEP+"ALL"+AASEP+"SCRN"
  URL+=+AASEP+MASQUE+".xml"
  URL=ctrans(URL,"\","/")
  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL

Return


# Controle que l'ûˋcran n'a pas de types non supportûˋs pour les ûˋcrans VT
# ou une structure non gûˋrûˋe
# Il faut aussi controler que l'on reste dans la taille prûˋvue

$VT_CONTVT

  Local Integer WT_LCOU : WT_LCOU=1
  Local Integer WT_DBL,WT_NBB
  For WE_NOBL=1 To BLC_NBR
    If BLC_TYP(WE_NOBL)<>0 and BLC_TYP(WE_NOBL)<>5     : # Ni invisible ni inactif
      For WE_CH=1 To LIG_NBR(WE_NOBL)
        If LIG_SAI(WE_NOBL,WE_CH)<=2
        Endif
      Next WE_CH
    Endif
  Next WE_NOBL
Local Integer WT_1,WT_2,WT_3,WT_4,WT_5,WT_NB,WT_LMAX

#Local Char WT_MATE([F:AMK]NBRCOL)(1..[F:AMK]NBRLIG)
Local Char WT_MATE([F:AMK]NBRCOL)(1..30)
For WT_1=1 To [F:AMK]NBRLIG
  WT_MATE(WT_1)=string$([F:AMK]NBRCOL," ")
Next WT_1
Return


$VT_ECRVISU
# Ouverture fichier visu ûˋcran VT produit
Call NAMEFIC(APPLI,"SCRN","",MASQUE,WE_NOMFIC) From INTRUTILA
WE_NOMFIC=left$(WE_NOMFIC,len(WE_NOMFIC)-3)+"txt"
Openo WE_NOMFIC,0 Using [VIS_]
Iomode adxifs "" Using [VIS_]
Iomode adxirs chr$(10) Using [VIS_]
Iomode adxium GUTF8 Using [VIS_]
For WT_1=1 To [F:AMK]NBRLIG
  Wrseq WT_MATE(WT_1) Using [VIS_]
Next WT_1

Openo Using [VIS_]
Return



$VT_CALTAB
Local Integer WT_T(1..6,1..40)
Local Integer WT_C : WT_C=1
  For WE_F=1 To LIG_NBR(WE_NOBL)
    If LIG_SAI(WE_NOBL,WE_F)<=2 and LIG_ZON(WE_NOBL,WE_F)<>BLC_BAS(WE_NOBL)
      WT_1=LIG_LGR(WE_NOBL,WE_F)
      WT_2=LIG_LNG(WE_NOBL,WE_F)
      If WT_1=0 : WT_1=WT_2 : Endif
      WT_NB+=1
      WT_T(2,WT_NB)=WT_C
      WT_C+=WT_1+1
      WT_T(3,WT_NB)=WT_1
      WT_T(4,WT_NB)=WT_2
      WT_T(5,WT_NB)=2
      WT_T(6,WT_NB)=WE_F
    Endif
  Next WE_F
WT_DBL=WT_LCOU
WT_NBB=min([F:AMK]NBRLIG-WT_DBL,BLC_LIG(WE_NOBL))
WT_LCOU+=WT_NBB
Gosub VT_CONTBLC
Return


$VT_CALBLOC
Local Integer WT_1,WT_2,WT_3,WT_4,WT_5,WT_6,WT_NB,WT_LMAX,WT_NLI
Local Integer WT_T(1..6,1..40)
Local Integer WT_P(1..40)
For WT_1=1 To dim(WT_P)
  WT_P(WT_1)=1
Next WT_1

# WT_T(1,NL)   : Numûˋro de ligne
# WT_T(2,NL)   : Position en colonne
# WT_T(3,NL)   : Longueur affichûˋe
# WT_T(4,NL)   : Longueur totale
# WT_T(5,NL)   : Type de champ 1: Caption  2: Champ  3: Champ option W
# WT_T(6,NL)   : Indice du champ en question
# WT_P         : Position courante sur la ligne
  For WE_I=1 To WE_ITBL
    Case WE_TBL(WE_I)
      When "FIELD"    : Gosub VT_FLD
      When "CAPTION"  : Gosub VT_CAP
      When Default    :
    Endcase
  Next WE_I
#For I=1 To WT_NB
#  Infbox(num$(WT_T(1,I))-num$(WT_T(2,I))-num$(WT_T(3,I))-num$(WT_T(4,I))-
#&   num$(WT_T(5,I))-num$(WT_T(6,I)))
#Next I

WT_DBL=WT_LCOU
WT_NBB=WT_LMAX
WT_LCOU+=WT_LMAX
Gosub VT_CONTBLC
Return

$VT_CONTBLC
  If WT_LCOU>[F:AMK]NBRLIG+1
# Pas assez de place en hauteur
    Call ECR_TRACE(ECRAN-":"-mess(75,133,1)-"("+num$([F:AMK]NBRLIG)+"/"+num$(WT_LCOU-1)+")",-1) From GESECRAN
  Endif
#If LARGEUR>LARGMAX
# Call ECR_TRACE(ECRAN-":"-mess(76,133,1)-"("+num$(LARGEUR)+"/"+num$(LARGMAX)+")",-1) From GESECRAN
# Pas assez de place en largeur
#Endif
Return

$VT_FLD
WT_1=int(LIG_NUM(WE_NOBL,WE_TLI(WE_I)))
If WT_1>WT_LMAX : WT_LMAX=WT_1 : Endif
If WE_CAP(WE_TLI(WE_I))=0 : Gosub VT_CAP : Endif
WT_NB+=1
WT_T(1,WT_NB)=WT_1
WT_T(2,WT_NB)=WT_P(WT_1)
WT_2=LIG_LGR(WE_NOBL,WE_TLI(WE_I))
WT_3=LIG_LNG(WE_NOBL,WE_TLI(WE_I))
If LIG_LGR(WE_NOBL,WE_TLI(WE_I))<>0 and LIG_LGR(WE_NOBL,WE_TLI(WE_I))<>LIG_LNG(WE_NOBL,WE_TLI(WE_I))
  WT_3=LIG_LGR(WE_NOBL,WE_TLI(WE_I))
Endif
If WT_2=0 : WT_2=WT_3 : Endif
If WT_P(WT_1)+WT_3 > [F:AMK]NBRCOL
  WT_3=[F:AMK]NBRCOL-WT_T(2,WT_NB)+1
  If WT_3<=0
    Call ECR_TRACE(ECRAN-":"-mess(76,133,1)-"("+LIG_ZON(WE_NOBL,WE_TLI(WE_I))+")",-1) From GESECRAN
    WT_3=0
  Endif
Endif
WT_P(WT_1)+=WT_3+1
WT_T(3,WT_NB)=WT_3
WT_T(4,WT_NB)=WT_2
If LIG_LIB(WE_NOBL,WE_TLI(WE_I))<>0
  WT_4=LIG_LIB(WE_NOBL,WE_TLI(WE_I))
  WT_5=0
#  For I=1 To len(mess(0,WT_4,1))
  WLG=func APLSTD.LENMEN(APPLI,WT_4)
#        --- Attention on pourrait tomber sur le cas ou le menu n'est pas encore dûˋfini dans le dossier de gûˋnûˋration
#            du coup on initialise WT_5 û  2 pour ne pas avoir 0 caractû´res
  WT_5=2
  For I=1 To WLG
    If len(mess(I,WT_4,1))>WT_5
      WT_5=len(mess(I,WT_4,1))
    Endif
  Next I
  WT_T(4,WT_NB)=max(WT_2,WT_5)
Endif
WT_T(5,WT_NB)=2
If find("W",LIG_OPT(WE_NOBL,WE_TLI(WE_I))) : WT_T(5,WT_NB)=3 : Endif
WT_T(6,WT_NB)=WE_TLI(WE_I)
Return

$VT_CAP
If LIG_TIT(WE_NOBL,WE_TLI(WE_I))=0 and LIG_EVL(WE_NOBL,WE_TLI(WE_I))="" : Return : Endif
WT_NB+=1
WT_1=int(LIG_NUM(WE_NOBL,WE_TLI(WE_I)))
If WT_1>WT_LMAX : WT_LMAX=WT_1 : Endif
WT_T(1,WT_NB)=WT_1
WT_T(2,WT_NB)=WT_P(WT_1)
WT_P(WT_1)+=BLC_LNG(WE_NOBL)+1
WT_T(3,WT_NB)=BLC_LNG(WE_NOBL)
WT_T(4,WT_NB)=BLC_LNG(WE_NOBL)
WT_T(5,WT_NB)=1
WT_T(6,WT_NB)=WE_TLI(WE_I)
Return


$VT_ESCR
    WE_PROP="PLIT"   : WE_VALUE="0" : Gosub WE_ADDPROP
    WE_PROP="PCOT"   : WE_VALUE="0" : Gosub WE_ADDPROP
    WE_PROP="NLIT"   : WE_VALUE=num$([F:AMK]NBRLIG) : Gosub WE_ADDPROP
    WE_PROP="NCOT"   : WE_VALUE=num$([F:AMK]NBRCOL)  : Gosub WE_ADDPROP
Return

$VT_EFRM
  WE_PROP="PLIT" : WE_VALUE=num$(WT_DBL) : Gosub WE_ADDPROP
  WE_PROP="PCOT"   : WE_VALUE="0" : Gosub WE_ADDPROP
  WE_PROP="NLIT" : WE_VALUE=num$(WT_NBB) : Gosub WE_ADDPROP
  WE_PROP="NCOT"   : WE_VALUE=num$([F:AMK]NBRCOL)  : Gosub WE_ADDPROP
Return

$VT_EGCO
  WT_1=find(WE_F,WT_T(6,1..WT_NB))
  If WT_1=0 : Return : Endif
  WE_PROP="PCOT" : WE_VALUE=num$(WT_T(2,WT_1)) : Gosub WE_ADDPROP
  WE_PROP="NCOT" : WE_VALUE=num$(WT_T(4,WT_1)) : Gosub WE_ADDPROP
  WE_PROP="AFLT" : WE_VALUE=num$(WT_T(3,WT_1)) : Gosub WE_ADDPROP
  Gosub VT_SELT
  WT_6=0
  For WT_5=WT_T(2,WT_1) To WT_T(2,WT_1)+WT_T(3,WT_1)-1
    WT_MATE(WT_DBL)=left$(WT_MATE(WT_DBL),WT_5-1)
    WT_6+=1
    If mid$(WE_CAPCOU,WT_6,1)<>""
      WT_MATE(WT_DBL)+=mid$(WE_CAPCOU,WT_6,1)
    Else
      WT_MATE(WT_DBL)+=" "
    Endif
    WT_MATE(WT_DBL)+=right$(WT_MATE(WT_DBL),WT_5+1)
  Next WT_5
  For WT_6=WT_DBL+1 To WT_DBL+WT_NBB
    For WT_5=WT_T(2,WT_1) To WT_T(2,WT_1)+WT_T(3,WT_1)-1
      WT_MATE(WT_6)=left$(WT_MATE(WT_6),WT_5-1)+"X"+right$(WT_MATE(WT_6),WT_5+1)
    Next WT_5
  Next WT_6
Return

$VT_EFLD
  WT_1=0
  For WT_2=1 To WT_NB
    If WE_F=WT_T(6,WT_2) and WT_T(5,WT_2)>1 : WT_1=WT_2 : Break 1 : Endif
  Next WT_2
  If WT_1=0 : Return : Endif
  WE_PROP="PLIT" : WE_VALUE=num$(WT_T(1,WT_1)) : Gosub WE_ADDPROP
  WE_PROP="PCOT" : WE_VALUE=num$(WT_T(2,WT_1)) : Gosub WE_ADDPROP
  WE_PROP="NCOT" : WE_VALUE=num$(WT_T(4,WT_1)) : Gosub WE_ADDPROP
  WE_PROP="AFLT" : WE_VALUE=num$(WT_T(3,WT_1)) : Gosub WE_ADDPROP
  Gosub VT_SELT
  WT_NLI=WT_T(1,WT_1)+WT_DBL-1
  For WT_5=WT_T(2,WT_1) To WT_T(2,WT_1)+WT_T(3,WT_1)-1
    WT_MATE(WT_NLI)=left$(WT_MATE(WT_NLI),WT_5-1)+"X"+right$(WT_MATE(WT_NLI),WT_5+1)
  Next WT_5
Return

$VT_SELT
# On positionne une propriûˋtûˋ SELT si une sûˋlection est dûˋfinie sur le champ
  WE_PROP="SELT" : WE_VALUE="0"
  For WE_AC=LIG_PTA(WE_NOBL,WE_F) To LIG_PTA(WE_NOBL,WE_F)+LIG_ACT(WE_NOBL,WE_F)-1
    If ACT_TYP(WE_AC)=8 : WE_VALUE="1" : Break 1 : Endif
  Next WE_AC
  Gosub WE_ADDPROP
Return


$VT_ECAP
  WT_1=0
  For WT_2=1 To WT_NB
    If WE_F=WT_T(6,WT_2) and WT_T(5,WT_2)=1 : WT_1=WT_2 : Break 1 : Endif
  Next WT_2
  If WT_1=0 : Return : Endif
  WE_PROP="PLIT" : WE_VALUE=num$(WT_T(1,WT_1)) : Gosub WE_ADDPROP
  WE_PROP="PCOT" : WE_VALUE=num$(WT_T(2,WT_1)) : Gosub WE_ADDPROP
  WE_PROP="AFLT" : WE_VALUE=num$(WT_T(3,WT_1)) : Gosub WE_ADDPROP
  WT_6=0
  WT_NLI=WT_T(1,WT_1)+WT_DBL-1
  For WT_5=WT_T(2,WT_1) To WT_T(2,WT_1)+WT_T(3,WT_1)-1
    WT_MATE(WT_NLI)=left$(WT_MATE(WT_NLI),WT_5-1)
    WT_6+=1
    If mid$(WE_CAPCOU,WT_6,1)<>""
      WT_MATE(WT_NLI)+=mid$(WE_CAPCOU,WT_6,1)
    Else
      WT_MATE(WT_NLI)+=" "
    Endif
    WT_MATE(WT_NLI)+=right$(WT_MATE(WT_NLI),WT_5+1)
  Next WT_5
Return

