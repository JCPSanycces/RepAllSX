#<AdxTL>@(#)4.0.0.0 $Revision$
#######################################################################
## INTEGABG  Intégration des Serveur batch (Groupes)
#######################################################################
$INTEG
Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
Call ECR_TRACE("Mise à jour des Serveur batch (Groupes)",0) From GESECRAN

Gosub OUVRE

For [SABG]ABG0 Where CODGRP<GXX
 OBJET = [F:SABG]CODGRP
 OKCOP = 1
 Call OKCOP([F:SABG]MODULE,"",OKCOP) From INTEGSUB
 If OKCOP
  Call ECR_TRACE(mess(77,145,1)-"ABG"-OBJET,0) From GESECRAN
  Gosub COPIE
 Else
  Call ECR_TRACE(mess(78,145,1)-"ABG"-OBJET,0) From GESECRAN
 Endif
Next

For [ABG]ABG0 Where MODULE=1 & CODGRP<GXX
 OBJET = [F:ABG]CODGRP
 Read [SABG]ABG0 = [F:ABG]CODGRP
 Call OKSUP(PRODUIT,fstat,"",[F:SABG]MODULE,"",OKSUP) From INTEGSUB
 If OKSUP
  Gosub SUPPRIME
 Endif
Next

Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
Gosub FERME
Return

#-------------------------------------------------------------#
$OUVRE
Local File ABATGRP [SABG]
Local File ATEXTE  [SATX]
Local File ACTIV   [SACV]
Local File =DOSSIER+".ABATGRP"  [ABG]
Local File =DOSSIER+".ATEXTE"   [ATX]
Local File =DOSSIER+".ACTIV"    [ACV]
Return

$FERME
Close Local File [SABG] , [SATX] , [SACV]
Close Local File [ABG]  , [ATX]  , [ACV]
Return

#-------------------------------------------------------------#
$COPIE
If TEST : Return : Endif
Read [ABG]ABG0= OBJET
If !fstat
 Call VERF_MODULE([F:SABG]MODULE,[F:ABG]MODULE,TYPPRO,OKCOP) From INTEGSUB
Endif
If !OKCOP
 Call ECR_TRACE(func AFNC.MES2(mess(76,145,1),"ABG"-OBJET,LIBMOD([F:ABG]MODULE)),1) From GESECRAN
 Return
Endif
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [ABG]
 Read [ABG]ABG0= OBJET
 If fstat
  Gosub TETE
  If GOK<1 : Goto AB_TR1 : Endif
  Write [ABG]
 Else
  Gosub TETE
  If GOK<1 : Goto AB_TR1 : Endif
  Rewrite [ABG]
 Endif
 If fstat
  GOK = 0 : Call FSTA("ABG") From GLOCK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#-------------------------------------------------------------#
$TETE
[F:ABG] = [F:SABG]
Call MODULE([F:SABG]MODULE,TYPPRO,[F:ABG]MODULE) From INTEGSUB
Call TEXTE(DOSSIER,[F:ABG]DES) From INTEGSUB
Return

#-------------------------------------------------------------#
$SUPPRIME
Call ECR_TRACE(mess(2,24,1)-"ABG"-OBJET,0) From GESECRAN
If TEST : Return : Endif
Call DEBTRANS From GLOCK
Gosub TR2
Return

$TR2
GOK = 1
Trbegin [ABG]
 Delete [ABG] Where CODGRP=OBJET
 If fstat=1
  GOK = -1 : GLOCK = "$ABATGRP"-OBJET : Goto ROLL_TR2
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

