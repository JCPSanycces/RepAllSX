#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTAS0C 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:57"
A_USER  = "DOC"
A_STAMP = "20181109230557"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMTAS0C [PJTA0C]
Gosub HORODAT
Local Inpbox "PJMTAS0C" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTA0C] As [SIM_]
Grizo [PJTA0C]25
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJTA0C]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=11
Return

$ON_TASSTATE
Onevent INIT_AREA Call D_TASSTATE(zc) From W1PJMTAS0C
Return

Subprog D_TASSTATE(VALEUR)
Variable Integer VALEUR
If varinit([M]TASSTATE,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_TASDATP
Onevent BEFORE_AREA Gosub AV_TASDATP From W1PJMTAS0C
Return

$AV_TASDATP
Chgfmt [M]TASDATP(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_TASDATL
Onevent BEFORE_AREA Gosub AV_TASDATL From W1PJMTAS0C
Return

$AV_TASDATL
Chgfmt [M]TASDATL(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_TASDATB
Onevent BEFORE_AREA Gosub AV_TASDATB From W1PJMTAS0C
Return

$AV_TASDATB
Chgfmt [M]TASDATB(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_TASDATS
Onevent BEFORE_AREA Gosub AV_TASDATS From W1PJMTAS0C
Return

$AV_TASDATS
Chgfmt [M]TASDATS(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_TASDATH
Onevent BEFORE_AREA Gosub AV_TASDATH From W1PJMTAS0C
Return

$AV_TASDATH
Chgfmt [M]TASDATH(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_CUR
Return

$ON_ZCUR
Onevent BEFORE_AREA Gosub AV_ZCUR From W1PJMTAS0C
Return

$AV_ZCUR
Call LECTEXTRA(zc,"TABCUR","INTDES",num$([M]CUR(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_CREDATTIM
Onevent BEFORE_AREA Gosub AV_CREDATTIM From W1PJMTAS0C
Return

$AV_CREDATTIM
Chgfmt [M]CREDATTIM(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_TASTYP
Onevent INIT_AREA Call D_TASTYP(zc) From W1PJMTAS0C
Return

Subprog D_TASTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]TASTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_TASTLA
Onevent INIT_AREA Call D_TASTLA(zc) From W1PJMTAS0C
Return

Subprog D_TASTLA(VALEUR)
Variable Integer VALEUR
If varinit([M]TASTLA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


