##########################################################################################################
##########################################################################################################
$CODE1
   #Contrôle si le composant a été listé
   If ICCVMODE Then
     Filter [CCVA] Where [F:CCVA]TPL = 2
&                    and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                    and [F:CCVA]RECTYP = "CPN"
&                    and [F:CCVA]RECNUM = [M:SRE7]CPNITM(INOL)
&                    and [F:CCVA]PAEKEY(0) = ""
&                    and [F:CCVA]PAEKEY(1) <> ""
&                    and [F:CCVA]PAEKEY(2) = ""
&                    and [F:CCVA]PAEKEYTYP(1) = "ITM"
&                    and [F:CCVA]CMT = [F:MAC]MACPDTCOD
  Else
    Filter [CCVA] Where [F:CCVA]TPL <> 2
&                   and [F:CCVA]CONNUM = [F:LNK]CONNUM
&                   and [F:CCVA]RECTYP = "CPN"
&                   and [F:CCVA]RECNUM = [M:SRE7]CPNITM(INOL)
&                   and [F:CCVA]PAEKEY(0) = ""
&                   and [F:CCVA]PAEKEY(1) <> ""
&                   and [F:CCVA]PAEKEY(2) = ""
&                   and [F:CCVA]PAEKEYTYP(1) = "ITM"
&                   and [F:CCVA]CMT = [F:MAC]MACPDTCOD
  Endif
  ICPNLISTED = 0
  For [CCVA]
    ICPNLISTED = 1
    Break
  Next
  Filter [CCVA]
  If !ICPNLISTED Then
    If [F:LNK]CPNICDFLG = 2 Then
      Gosub CHKMACCPNCOV From TRTCOVER
    Else
      Call RAZCPNLINE(INOL) From TRTCOVER
    Endif
  Endif
Return

