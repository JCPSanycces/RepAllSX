##########################################################################################################
$COMPLEXMG
Local Integer ICOVERYES
Local Integer ICOVERNO
Local Char SZYESNO

  ICOVERYES = 0
  ICOVERNO = 0
  SZYESNO = ""
  #Parc
  For ITER = 0 To [M:SRE7]NBMAC-1
    Case [M:SRE7]COVSPT(ITER)
      When 1
        ICOVERYES = 1
      When 2
        ICOVERYES = 1
      When 3
        ICOVERYES = 1
      When 4
        ICOVERNO = 1
      When 5
        ICOVERYES = 1
    Endcase
  Next
  #Composants classe M
  For ITER = 0 To [M:SRE7]NBCPN-1
    Case [M:SRE7]CPNCOVSPT(ITER)
      When 1
        ICOVERYES = 1
      When 2
        ICOVERYES = 1
      When 3
        ICOVERYES = 1
      When 4
        ICOVERNO = 1
      When 5
        ICOVERYES = 1
    Endcase
  Next
  #Composants classe F
  If GREP = "C" Then
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0 Order By [F:SRN]CPNITM Asc
  Else
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0 Order By [F:SRN]CPNITM Asc
  Endif
  For [SRN]
    Case [F:SRN]CPNCOVSPT
      When 1
        ICOVERYES = 1
      When 2
        ICOVERYES = 1
      When 3
        ICOVERYES = 1
      When 4
        ICOVERNO = 1
      When 5
        ICOVERYES = 1
    Endcase
  Next
  Filter [SRN]
  If ILINEFLG Then
    If INOL >= 0 Then
      If INOL > [M:SRE7]NBMAC-1 Then
        Case [M:SRE7]COVSPT(INOL)
          When 1
            ICOVERYES = 1
          When 2
            ICOVERYES = 1
          When 3
            ICOVERYES = 1
          When 4
            ICOVERNO = 1
          When 5
            ICOVERYES = 1
        Endcase
      Endif
    Endif
  Endif
  SZYESNO = num$(ICOVERYES) + num$(ICOVERNO)
  Case SZYESNO
    When "00"
      [M:SRE2]OVRCOV = 3
    When "01"
      [M:SRE2]OVRCOV = 3
    When "10"
      [M:SRE2]OVRCOV = 1
    When "11"
      [M:SRE2]OVRCOV = 2
  Endcase
Return

#####################################################################################################################################################################################
# Détermine le statut de couverture globale d'une demande de service en classe écran
###########################################################################
Subprog COVERMGCB(INOL)
Value Integer INOL

Local Integer IERR
Local Integer INBCONTROL
Local Integer IWHOLECOVF
Local Integer ITER
Local Integer ITER2
Local Integer IALLCOVER
Local Char SZFIRCON
Local Integer IMUSTEMPTY
Local Integer ICOVSPTARR(6)

  IERR = 0
  ITER2 = 0
  IALLCOVER = 1
  SZFIRCON = ""
  IMUSTEMPTY = 0
  Raz ICOVSPTARR
  IWHOLECOVF = 0
  INBCONTROL = 0
  #Détermine si la demande est totalement couverte
  #Parc
  For ITER = 0 To [M:SRE7]NBMAC-1
    If [M:SRE7]COVSPT(ITER) > 0 Then
      ICOVSPTARR([M:SRE7]COVSPT(ITER)-1) += 1
      INBCONTROL += 1
    Endif
    If [M:SRE7]COVFLG(ITER) <> 1 Then
      IALLCOVER = 0
      Break
    Endif
  Next
  #Composants classe M
  For ITER = 0 To [M:SRE7]NBCPN-1
    If [M:SRE7]CPNCOVSPT(ITER) > 0 Then
      ICOVSPTARR([M:SRE7]CPNCOVSPT(ITER) - 1) += 1
      INBCONTROL += 1
    Endif
    If [M:SRE7]CPNCOVFLG(ITER) <> 1 Then
      IALLCOVER = 0
      Break
    Endif
  Next
  #Composants ligne courante
  If INOL >= 0 Then
    If INOL > [M:SRE7]NBCPN-1 Then
      If [M:SRE7]CPNCOVSPT(INOL) > 0 Then
        ICOVSPTARR([M:SRE7]CPNCOVSPT(INOL) - 1) += 1
        INBCONTROL += 1
      Endif
      If [M:SRE7]CPNCOVFLG(INOL) <> 1 Then
        IALLCOVER = 0
      Endif
    Endif
  Endif
  #Composants classe F
  If GREP = "C" Then
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]MACNUM <> [M:SRE7]MAC([M:SRE7]PRESRE7NOL) and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
&             Order By [F:SRN]CPNITM Asc
  Else
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]MACNUM <> [M:SRE7]MAC([M:SRE7]PRESRE7NOL) and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0
&             Order By [F:SRN]CPNITM Asc
  Endif
  For [SRN]
    If [F:SRN]CPNCOVSPT > 0 Then
      ICOVSPTARR([F:SRN]CPNCOVSPT - 1) += 1
      INBCONTROL += 1
    Endif
    If [F:SRN]CPNCOVFLG <> 1 Then
      IALLCOVER = 0
      Break
    Endif
  Next
  Filter [SRN]
  If [M:SRE7]CPNCOVFLG(INOL) <> 1 Then
    IALLCOVER = 0
  Endif
  If IALLCOVER Then
    For ITER = 0 To dim(ICOVSPTARR)-1
      If ICOVSPTARR(ITER) > 1 Then
        If ICOVSPTARR(ITER) = INBCONTROL Then
          Case ITER
            When 0
              [M:SRE2]OVRCOV = 1
              IWHOLECOVF = 1
            When 1
              [M:SRE2]OVRCOV = 5
              IWHOLECOVF = 1
            When 2
              [M:SRE2]OVRCOV = 6
              IWHOLECOVF = 1
            When 3
              [M:SRE2]OVRCOV = 7
              IWHOLECOVF = 1
            When 4
              [M:SRE2]OVRCOV = 1
              IWHOLECOVF = 1
          Endcase
        Endif
      Endif
    Next
    [M:SRE2]OVRCOVTYP = ""
    [M:SRE2]SRECOVAUT = 1
    [M:SRE2]SRECOVAUS = ""
    [M:SRE2]COVAUSCLA = ""
    [M:SRE2]SRECOVCTL = ""
    [M:SRE2]CONSPT = ""
    [M:SRE2]CONSPTTYP = ""
    [M:SRE2]CONSPTCLA = ""
    If IWHOLECOVF = 0 Then
      [M:SRE2]SRECOVNUM = ""
      [M:SRE2]OVRCOV = 1
      Gosub COMPLEXMGC From TRTCOVERB
      [M:SRE2]CONSPTFLG = 0
      [M:SRE2]MANUPD = 1
      #Obtient le niveau de réactivité SAV.
      Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
      Gosub AFFSRE2MIS From SUBSREB2
      End
    Endif
    #Contrat support
    For ITER = 0 To [M:SRE7]NBMAC-1
      If [M:SRE7]COVSPT(ITER) = 1 or [M:SRE7]COVSPT(ITER) = 5 Then
        [M:SRE2]CONSPT = [M:SRE7]COVVCR(ITER)
        If [M:SRE7]COVSPT(ITER) = 1 Then
          [M:SRE2]CONSPTTYP = "CON"
        Elsif [M:SRE7]COVSPT(ITER) = 5 Then
          [M:SRE2]CONSPTTYP = "COT"
        Endif
        [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement.
        Break
      Endif
    Next
    #Contrat couvrant
    #Parc
    ITER2 = 0
    SZFIRCON = ""
    IMUSTEMPTY = 0
    For ITER = 0 To [M:SRE7]NBMAC-1
      If [M:SRE7]COVFLG(ITER) <> 3 Then
        If ITER2 = 0 Then
          SZFIRCON = [M:SRE7]COVVCR(ITER)
        Else
          If [M:SRE7]COVVCR(ITER) <> SZFIRCON Then
            IMUSTEMPTY = 1
            Break
          Endif
        Endif
        ITER2 += 1
      Endif
    Next
    #Composants classe M
    If IMUSTEMPTY = 0 Then
      For ITER = 0 To [M:SRE7]NBCPN-1
        If [M:SRE7]CPNCOVFLG(ITER) <> 3 Then
          If [M:SRE7]CPNCOVVCR(ITER) <> SZFIRCON Then
            IMUSTEMPTY = 1
            Break
          Endif
        Endif
      Next
    Endif
    #Composants ligne courante
    If IMUSTEMPTY = 0 Then
      If INOL >= 0 Then
        If INOL > [M:SRE7]NBCPN-1 Then
          If [M:SRE7]CPNCOVFLG(ITER) <> 3 Then
            If [M:SRE7]CPNCOVVCR(ITER) <> SZFIRCON
              IMUSTEMPTY = 1
            Endif
          Endif
        Endif
      Endif
    Endif
    #Composants classe F
    If IMUSTEMPTY = 0 Then
      If GREP = "C" Then
        Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]MACNUM <> [M:SRE7]MAC([M:SRE7]PRESRE7NOL) and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
&                 Order By [F:SRN]CPNITM Asc
      Else
        Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]MACNUM <> [M:SRE7]MAC([M:SRE7]PRESRE7NOL) and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0
&                 Order By [F:SRN]CPNITM Asc
      Endif
      For [SRN]
        If [F:SRN]CPNCOVFLG <> 3 Then
          If [F:SRN]CPNCOVVCR <> SZFIRCON Then
            IMUSTEMPTY = 1
            Break
          Endif
        Endif
      Next
      Filter [SRN]
    Endif
    If IMUSTEMPTY Then
      [M:SRE2]SRECOVNUM = ""
      [M:SRE2]OVRCOVTYP = ""
    Else
      For ITER = 0 To [M:SRE7]NBMAC-1
        If [M:SRE7]COVFLG(ITER) <> 3 Then
          If [M:SRE7]COVVCR(ITER) <> "" Then
            [M:SRE2]SRECOVNUM = [M:SRE7]COVVCR(INOL)
            [M:SRE2]OVRCOVTYP = ""
            If [M:SRE7]COVSPT(INOL) = 1 Then
              [M:SRE2]OVRCOVTYP = "CON"
            Elsif [M:SRE7]COVSPT(INOL) = 5 Then
              [M:SRE2]OVRCOVTYP = "COT"
            Endif
            Break
          Endif
        Endif
      Next
    Endif
    [M:SRE2]CONSPTFLG = 0
    [M:SRE2]MANUPD = 1
    #Obtient le niveau de réactivité SAV.
    Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
    Gosub AFFSRE2MIS From SUBSREB2
    End
  Endif
  IALLCOVER = 1
  #Détermine si la demande est non couverte
  #Parc
  For ITER = 0 To [M:SRE7]NBMAC-1
    If [M:SRE7]COVFLG(ITER) <> 3 Then
      IALLCOVER = 0
      Break
    Endif
  Next
  #Composants classe M
  If IALLCOVER = 1 Then
    For ITER = 0 To [M:SRE7]NBCPN-1
      If [M:SRE7]CPNCOVFLG(ITER) <> 3 Then
        IALLCOVER = 0
        Break
      Endif
    Next
  Endif
  #Composants ligne courante
  If [M:SRE7]CPNCOVFLG(INOL) <> 3 Then
    IALLCOVER = 0
  Endif
  #Composants classe F
  If IALLCOVER = 1 Then
    If GREP = "C" Then
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]MACNUM <> [M:SRE7]MAC([M:SRE7]PRESRE7NOL) and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
&               Order By [F:SRN]CPNITM Asc
    Else
      Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]MACNUM <> [M:SRE7]MAC([M:SRE7]PRESRE7NOL) and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0
&               Order By [F:SRN]CPNITM Asc
    Endif
    For [SRN]
      If [F:SRN]CPNCOVFLG <> 3 Then
        IALLCOVER = 0
        Break
      Endif
    Next
    Filter [SRN]
  Endif
  If IALLCOVER Then
    [M:SRE2]OVRCOV = 3
    [M:SRE2]SRECOVNUM = ""
    [M:SRE2]OVRCOVTYP = ""
    [M:SRE2]SRECOVAUT = 1
    [M:SRE2]SRECOVAUS = ""
    [M:SRE2]COVAUSCLA = ""
    [M:SRE2]SRECOVCTL = ""
    [M:SRE2]CONSPT = ""
    [M:SRE2]CONSPTTYP = ""
    [M:SRE2]CONSPTCLA = ""
    [M:SRE2]CONSPTFLG = 0
    [M:SRE2]MANUPD = 1
    #Obtient le niveau de réactivité SAV.
    Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
  Else
    [M:SRE2]OVRCOV = 2
    [M:SRE2]SRECOVAUT = 1
    [M:SRE2]SRECOVAUS = ""
    [M:SRE2]COVAUSCLA = ""
    [M:SRE2]SRECOVCTL = ""
    #Contrat support
    For ITER = 0 To [M:SRE7]NBMAC-1
      If [M:SRE7]COVFLG(ITER) <> 3 Then
        If [M:SRE7]COVSPT(ITER) = 1 Then
          [M:SRE2]CONSPT = [M:SRE7]COVVCR(ITER)
          [M:SRE2]CONSPTTYP = "CON"
          [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement.
          Break
        Elsif [M:SRE7]COVSPT(ITER) = 5 Then
          [M:SRE2]CONSPT = [M:SRE7]COVVCR(ITER)
          [M:SRE2]CONSPTTYP = "COT"
          [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement.
          Break
        Endif
      Endif
    Next
    If [M:SRE2]CONSPT = "" Then
      [M:SRE2]CONSPTCLA = ""
    Else
      [M:SRE2]CONSPTCLA = mess(301,182,1) #Contrat défini automatiquement.
    Endif
    #Contrat couvrant
    ITER2 = 0
    SZFIRCON = ""
    IMUSTEMPTY = 0
    #Parc
    For ITER = 0 To [M:SRE7]NBMAC-1
      If [M:SRE7]COVFLG(ITER) <> 3 Then
        If ITER2 = 0 Then
          SZFIRCON = [M:SRE7]COVVCR(ITER)
        Else
          If [M:SRE7]COVVCR(ITER) <> SZFIRCON Then
            IMUSTEMPTY = 1
          Endif
        Endif
        ITER2 += 1
      Endif
    Next
    #Composants classe M
    If IMUSTEMPTY = 0 Then
      For ITER = 0 To [M:SRE7]NBCPN-1
        If [M:SRE7]CPNCOVFLG(ITER) <> 3 Then
          If [M:SRE7]CPNCOVVCR(ITER) <> SZFIRCON Then
            IMUSTEMPTY = 1
            Break
          Endif
        Endif
      Next
    Endif
    #Composants ligne courante
    If IMUSTEMPTY = 0 Then
      If INOL >= 0 Then
        If INOL > [M:SRE7]NBCPN-1 Then
          If [M:SRE7]CPNCOVFLG(ITER) <> 3 Then
            If [M:SRE7]CPNCOVVCR(ITER) <> SZFIRCON Then
              IMUSTEMPTY = 1
            Endif
          Endif
        Endif
      Endif
    Endif
    #Composants classe F
    If IMUSTEMPTY = 0 Then
      If GREP = "C" Then
        Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]MACNUM <> [M:SRE7]MAC([M:SRE7]PRESRE7NOL) and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
&                 Order By [F:SRN]CPNITM Asc
      Else
        Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]MACNUM <> [M:SRE7]MAC([M:SRE7]PRESRE7NOL) and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0
&                 Order By [F:SRN]CPNITM Asc
      Endif
      For [SRN]
        If [F:SRN]CPNCOVFLG <> 3 Then
          If [F:SRN]CPNCOVVCR <> SZFIRCON Then
            IMUSTEMPTY = 1
            Break
          Endif
        Endif
      Next
      Filter [SRN]
    Endif
    If IMUSTEMPTY Then
      [M:SRE2]SRECOVNUM = ""
      [M:SRE2]OVRCOVTYP = ""
    Else
      For ITER = 0 To [M:SRE7]NBMAC-1
        If [M:SRE7]COVFLG(ITER) <> 3 Then
          If [M:SRE7]COVVCR(ITER) <> "" Then
            #[M:SRE2]SRECOVNUM = [M:SRE7]COVVCR(INOL)      # FGR 21/06/2016 : X3SUIVI117215
            [M:SRE2]SRECOVNUM = [M:SRE7]COVVCR(ITER)       # FGR 21/06/2016 : X3SUIVI117215
            #If [M:SRE7]COVSPT(INOL) = 1 Then              # FGR 21/06/2016 : X3SUIVI117215
            If [M:SRE7]COVSPT(ITER) = 1 Then               # FGR 21/06/2016 : X3SUIVI117215
              [M:SRE2]OVRCOVTYP = "CON"
            #Elsif [M:SRE7]COVSPT(INOL) = 5 Then           # FGR 21/06/2016 : X3SUIVI117215
            Elsif [M:SRE7]COVSPT(ITER) = 5 Then            # FGR 21/06/2016 : X3SUIVI117215
              [M:SRE2]OVRCOVTYP = "COT"
            Endif
            Break
          Endif
        Endif
      Next ITER
    Endif
    [M:SRE2]CONSPTFLG = 0
    [M:SRE2]MANUPD = 1
    #Obtient le niveau de réactivité SAV.
    Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
  Endif
  [M:SRE2]OVRCOVCLA = ""
  [M:SRE2]OVRCOVREN = 0
  Gosub AFFSRE2MIS From SUBSREB2
End

##########################################################################################################
$COMPLEXMGC
Local Integer ICOVERYES
Local Integer ICOVERNO
Local Char SZYESNO

  ICOVERYES = 0
  ICOVERNO = 0
  SZYESNO = ""
  #Parc
  For ITER = 0 To [M:SRE7]NBMAC-1
    Case [M:SRE7]COVSPT(ITER)
      When 1
        ICOVERYES = 1
      When 2
        ICOVERYES = 1
      When 3
        ICOVERYES = 1
      When 4
        ICOVERNO = 1
      When 5
        ICOVERYES = 1
    Endcase
  Next
  #Composants classe M
  For ITER = 0 To [M:SRE7]NBCPN-1
    Case [M:SRE7]CPNCOVSPT(ITER)
      When 1
        ICOVERYES = 1
      When 2
        ICOVERYES = 1
      When 3
        ICOVERYES = 1
      When 4
        ICOVERNO = 1
      When 5
        ICOVERYES = 1
    Endcase
  Next
  #Composants ligne courante
  Case [M:SRE7]CPNCOVSPT(INOL)
    When 1
      ICOVERYES = 1
    When 2
      ICOVERYES = 1
    When 3
      ICOVERYES = 1
    When 4
      ICOVERNO = 1
    When 5
      ICOVERYES = 1
  Endcase
  #Composants classe F
  If GREP = "C" Then
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]MACNUM <> [M:SRE7]MAC([M:SRE7]PRESRE7NOL) and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
&             Order By [F:SRN]CPNITM Asc
  Else
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]MACNUM <> [M:SRE7]MAC([M:SRE7]PRESRE7NOL) and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0
&             Order By [F:SRN]CPNITM Asc
  Endif
  For [SRN]
    Case [F:SRN]CPNCOVSPT
      When 1
        ICOVERYES = 1
      When 2
        ICOVERYES = 1
      When 3
        ICOVERYES = 1
      When 4
        ICOVERNO = 1
      When 5
        ICOVERYES = 1
    Endcase
  Next
  Filter [SRN]
  SZYESNO = num$(ICOVERYES) + num$(ICOVERNO)
  Case SZYESNO
    When "00"
      [M:SRE2]OVRCOV = 3
    When "01"
      [M:SRE2]OVRCOV = 3
    When "10"
      [M:SRE2]OVRCOV = 1
    When "11"
      [M:SRE2]OVRCOV = 2
  Endcase
Return

