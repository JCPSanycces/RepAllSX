#<AdxTL>@(#)6.0.0.0 $Revision$
Call GENE
End


#----------------------------------------------------------------------------------------#
# Initialisation of short description
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Supp ACTLREF") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#

#----------------------------------------------------------------------------------------#
$MAJTAB

Return : # CCL : deja transféré et exécuté.

If filinfo(filpath("FIL","ATYPERUL","fde",DOSSIER),0)<0 : Return : Endif
If filinfo(filpath("FIL","ATYPERPAR","fde",DOSSIER),0)<0 : Return : Endif

If DOSSIER=nomap
 Local File ATYPE [ATY]
 Local File ATYPERUL   [ATYR]
 Local File ATYPERPAR  [ATYRP]
Else
 Local File =DOSSIER+".ATYPE" [ATY]
 Local File =DOSSIER+".ATYPERUL" [ATYR]
 Local File =DOSSIER+".ATYPERPAR" [ATYRP]
Endif

If  dim([ATYRP]PARCLE)>0
 Trbegin [ATY]
 
 For [ATY] Where TYPSELSYR=2
  For [ATYR]ATYR0 Where [ATYR]CODTYP=[F:ATY]CODTYP & [ATYR]PRGRUL=[V]CST_ANAMCTLREF
   For  [ATYRP]ATYRP1 Where CODTYP=[F:ATY]CODTYP & TRTRUL=[ATYR]TRTRUL  & PRGRUL=[ATYR]PRGRUL
    Delete [ATYRP] Curr
   Next
   Delete [ATYR] Curr
  Next
 Next
 Commit
Endif

Close Local File [ATY],[ATYR],[ATYRP]

End


