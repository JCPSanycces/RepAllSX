# Issue X3-38343 - 2017-06-07 by CPO : Legislation property in SINVOICEV class
#############################################################################
Funprog INIT_CURRLEG_FROM_CPY_FCY(SOBJET,PCPY, PFCY, VCURRLEG)
Variable Instance SOBJET Using OBJECT
Value    Char PCPY
Value    Char PFCY
Variable Char VCURRLEG

Local Integer IRET : IRET = [V]CST_AOK

  #--No need to go further
  If PCPY = "" and PFCY = ""
    VCURRLEG = ""
    End IRET
  Endif
  #--
  VCURRLEG = "" #--setting new current legislation

  #--setting current leg according to the current company
  Local File COMPANY  [CPY]
  Local File FACILITY [FCY]
  # -------------------------------
  If PCPY = "" and PFCY <> "" Then
    PCPY = fmet SOBJET.ACTX.ACACHE.AFCY.AGETVALCHAR(PFCY, "LEGCPY")
  Endif
  # -------------------------------
  If PCPY <> "" Then
    VCURRLEG = fmet SOBJET.ACTX.ACACHE.ACPY.AGETVALCHAR(PCPY, "LEG")
  Endif
  # -------------------------------
  LogicClose File [CPY],[FCY]

End IRET
###################################################################################################
Funprog INIT_VACBPR_LEG(SOBJET, PVACBPR, PCPY, PFCY, VCURRLEG, VACBPR_LEG)
Variable Instance SOBJET Using OBJECT
Value    Char PVACBPR
Value    Char PCPY
Value    Char PFCY
Variable Char VCURRLEG
Variable Char VACBPR_LEG

  Local Integer IRET : IRET = [V]CST_AOK

  VACBPR_LEG = "" # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If PVACBPR = "" : End IRET : Endif
  # ------------------------
  Local File TABVACBPR [TVB]

  If VCURRLEG = ""
    If func ASYRFNC.ACTIV("LEG")=0 Then
      VCURRLEG = fmet SOBJET.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, SOBJET.ACTX.AFOLDER, "DOSLEG")
    Else
      IRET = func INIT_CURRLEG_FROM_CPY_FCY(SOBJET, PCPY, PFCY, VCURRLEG)
      If IRET >= [V]CST_AERROR
        VACBPR_LEG = ""
        End IRET
      Endif
    Endif
  Endif

  If VCURRLEG <> "" Then
    Read [TVB]TVB0=PVACBPR;VCURRLEG
    If fstat Then
      Read [TVB]TVB0=PVACBPR;""
    Endif
  Else
    Read [TVB]TVB0(1)=PVACBPR
  Endif
  VACBPR_LEG = ""
  If !fstat Then
    VACBPR_LEG = [F:TVB]LEG
  Else
    IRET = [V]CST_AERROR
  Endif

  LogicClose File [TVB]

End IRET
###################################################################################################
Funprog INIT_DEP_LEG(SOBJET, PDEP, PCPY, PFCY, VCURRLEG, DEP_LEG)
Variable Instance SOBJET Using OBJECT
Value    Char PDEP
Value    Char PCPY
Value    Char PFCY
Variable Char VCURRLEG
Variable Char DEP_LEG

  Local Integer IRET : IRET = [V]CST_AOK

  DEP_LEG = "" # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If PDEP = "" : End IRET : Endif
  # ------------------------
  Local File TABDEPAGIO [TDA]

  If VCURRLEG = ""
    If func ASYRFNC.ACTIV("LEG")=0 Then
      VCURRLEG = fmet SOBJET.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, SOBJET.ACTX.AFOLDER, "DOSLEG")
    Else
      IRET = func INIT_CURRLEG_FROM_CPY_FCY(SOBJET, PCPY, PFCY, VCURRLEG)
      If IRET >= [V]CST_AERROR
        DEP_LEG = ""
        End IRET
      Endif
    Endif
  Endif

  If VCURRLEG <> "" Then
    Read [TDA]TDA0=PDEP;VCURRLEG
    If fstat Then
      Read [TDA]TDA0=PDEP;""
    Endif
  Else
    Read [TDA]TDA0(1)=PDEP
  Endif
  DEP_LEG = ""
  If !fstat Then
    DEP_LEG = [F:TDA]LEG
  Else
    IRET = [V]CST_AERROR
  Endif

  LogicClose File [TDA]

End IRET
