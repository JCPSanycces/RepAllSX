###################################################################################################
Subprog LOAD_VACBPR_LEG(SOBJET)
Variable Instance SOBJET Using OBJECT

  Local Integer IRET
  Local Char LEG(GLONADI)

  If SOBJET.VACBPR = "" Then
    End
  Endif
  # ------------------------
  Local File TABVACBPR [TVB]

  If func AFNC.ACTIV("LEG") = 0 Then
    [L]LEG = fmet SOBJET.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, SOBJET.ACTX.AFOLDER, "DOSLEG")
  Else
    If dim(SOBJET.LEG) > 0 Then
      [L]LEG = SOBJET.LEG
    Endif
    If [L]LEG="" : Call LEG_FROM_CPY_FCY(SOBJET, [L]LEG) : Endif
  Endif

  If [L]LEG <> "" Then
    Read [TVB]TVB0=SOBJET.VACBPR;[L]LEG
    If fstat Then
      Read [TVB]TVB0=SOBJET.VACBPR;""
    Endif
  Else
    Read [TVB]TVB0(1)=SOBJET.VACBPR
  Endif
  If !fstat Then
    [L]LEG = [F:TVB]LEG
  Endif
  SOBJET.VACBPR_LEG = [L]LEG

  LogicClose File [TVB]

End
