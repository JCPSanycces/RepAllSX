###################################################################################################
Subprog LEG_FROM_CPY_FCY(SOBJET, LEG)
Variable Instance SOBJET Using OBJECT
Variable Char LEG

Local Char SCPY(GLONCPY)
Local Char SFCY(GLONFCY)

  #--Cas particulier : pas de SOBJET.LEG mais société ou site en ligne
  Local File COMPANY  [CPY]
  Local File FACILITY [FCY]
  # -------------------------------
  If dim(SOBJET.CPY) >= 0 and SOBJET.CPY <> "" Then
    SCPY = SOBJET.CPY
  Endif
  If SCPY = "" and (dim(SOBJET.SALFCY) >= 0 and SOBJET.SALFCY <> "") Then
    If dim(SOBJET.SALFCY) >= 0 and SOBJET.SALFCY <> "" Then
      If [F:FCY]FCY <> SOBJET.SALFCY Then
        Read [F:FCY]FCY0=SOBJET.SALFCY
        If fstat
          Raz [F:FCY]
        Endif
      Endif
      SCPY = [F:FCY]LEGCPY
    Endif
  Endif
  # -------------------------------
  If [L]LEG = "" and SCPY <> "" Then
    Read [F:CPY]CPY0=SCPY
    If fstat Then
      Raz [F:CPY]
    Endif
    [L]LEG = [F:CPY]LEG
  Endif
  # -------------------------------
  LogicClose File [CPY],[FCY]
End

