#<AdxTL>@(#)4.0.0.0 $Revision$
########################################################################
# Impression des étiquettes de stocks                                  #
# -------------------------------------------------------------------- #
# Traitements sur champ "Call" de l'écran STOLBEIMP                    #
# Action  : STKLBEIMP (GTRAITE)                                        #
# Fenêtre : ISTOLBE                                                    #
# Traitement de l'action : SUBSLPA                                     #
# Gosub autres           : SUBSLPB                                     #
# -------------------------------------------------------------------- #
########################################################################
    GFONC1="FUNLBEIMP"
    Local Char PARAM(10)(1..3) , VALEUR(10)
    PARAM(1) = "GAL"
    Call TRAITE_CHAR(VALEUR,PARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
    Raz GFONC1
End
##########################################################################
$ACTION
Case ACTION
 When "DEBUT"   : Gosub DEBUT   From SUBSLPA
 When "OUVRE"   : Gosub OUVRE   From SUBSLPA
 When "SETBOUT" : Gosub SETBOUT From SUBSLPA
 When "BOUTON"  : Gosub BOUTON  From SUBSLPA
 When Default
Endcase
Return

#------------------------------------------------------------------------#
#                            Actions champs                              #
#------------------------------------------------------------------------#
Subprog AS_LBEVCRTYP(VALEUR)
#----------------------------#
# Avant saisie type de pièce #
#----------------------------#
Variable Integer VALEUR
Local Integer I
 # hcb 41754
For I=1 To dim(GMENLOC)-1
    If find(I,1,2,3,7,9,10,11,14,16,17,21,22,23,24,25,26,27,30,31,32,34) |         
&     !find(func STKLIB.SENSVCR(I),1,-2,3)
        GMENLOC(I) = 1
    Endif
Next
# sauf si etiquettes de production , assemblage , desassemblage, inventaire
GMENLOC(9)  = 0   # hcb 61166
GMENLOC(10) = 0
GMENLOC(31) = 0   # hcb 41754
GMENLOC(32) = 0   # hcb 41754
GMENLOC(35) = 0   # hcb 41754
#--- Bug 79002
GMENLOC(12) = 0 
End

Subprog AM_IPTDATSTR(VALEUR)
#------------------------#
# Après modif date début #
#------------------------#
Variable Date    VALEUR
If    [M]IPTDATEND = [M]IPTDATSTR : [M]IPTDATEND = VALEUR : Affzo [M]IPTDATEND
Elsif [M]IPTDATEND = [0/0/0]      : [M]IPTDATEND = VALEUR : Affzo [M]IPTDATEND
Elsif [M]IPTDATEND < VALEUR       : [M]IPTDATEND = VALEUR : Affzo [M]IPTDATEND : Endif
End

Subprog AM_VCRNUMSTR(VALEUR)
#-------------#
# Pièce début #
#-------------#
Variable Char    VALEUR()
If    [M]VCRNUMEND = [M]VCRNUMSTR : [M]VCRNUMEND = VALEUR : Affzo [M]VCRNUMEND
Elsif [M]VCRNUMEND = ""           : [M]VCRNUMEND = VALEUR : Affzo [M]VCRNUMEND
Elsif [M]VCRNUMEND < VALEUR       : [M]VCRNUMEND = VALEUR : Affzo [M]VCRNUMEND : Endif
End

Subprog AM_TCLCODSTR(VALEUR)
#-----------#
# Catégorie #
#-----------#
Variable Char    VALEUR()
    If [M:SLP]TCLCODEND=[M:SLP]TCLCODSTR | [M:SLP]TCLCODEND<VALEUR
        [M:SLP]TCLCODEND = VALEUR
        Affzo [M:SLP]TCLCODEND
    Endif
End

Subprog C_TCLCODEND(VALEUR)
#-----------#
# Catégorie #
#-----------#
Variable Char    VALEUR()
    If [M:SLP]TCLCODSTR>VALEUR
        GMESSAGE = mess(44,199,1) 
        mkstat=2
    Endif
    If VALEUR = ""
        VALEUR = [M:SLP]TCLCODSTR
    Endif
End

Subprog AM_ITMREFSTR(VALEUR)
#-------------------------------#
# Apres modif Ref article début #
#-------------------------------#
Variable Char    VALEUR()
    If [M:SLP]ITMREFEND=[M:SLP]ITMREFSTR | [M:SLP]ITMREFEND<VALEUR
        [M:SLP]ITMREFEND = VALEUR
        Affzo [M:SLP]ITMREFEND
    Endif
End

Subprog C_ITMREFEND(VALEUR)
#-------------------------#
# Controle réf art de fin #
#-------------------------#
Variable Char    VALEUR()
    If [M:SLP]ITMREFSTR>VALEUR
        GMESSAGE = mess(44,199,1) 
        mkstat=2
    Endif
    If VALEUR = ""
        VALEUR = [M:SLP]ITMREFSTR
    Endif
    If VALEUR = [M:SLP]ITMREFSTR & VALEUR <>""
        If [F:ITM]ITMREF<>VALEUR
            Read [ITM]ITM0=VALEUR
            If fstat
                GMESSAGE = mess(212,199,1)
                mkstat=2
                End
            Endif
        Endif
        If [F:ITF]ITMREF<>VALEUR
            Read [ITF]ITF0=VALEUR;[M:SLP]STOFCY
            If fstat
                GMESSAGE = mess(25,192,1)
                mkstat=2
                End
            Endif
        Endif
        If [F:ITM]TCLCOD<[M:SLP]TCLCODSTR | ([M:SLP]TCLCODEND<>"" & [F:ITM]TCLCOD>[M:SLP]TCLCODEND)
            GMESSAGE = mess(9,180,1)
            mkstat=2
            End
        Endif
    Endif
End

Subprog IB_NBLIG
GBOUT4 = mess(2,1,1) : # Oui
GBOUT5 = mess(1,1,1) : # Non
End

Subprog AS_NBLIG
#--------------------#
# Avant saisie nblig #
#--------------------#
Raz GBOUT2
Raz GBOUT3
Case [M:SLP]LBEVCRTYP
    When 10      :
        GBOUT2 = mess(166,198,1)
    When Default :
        GBOUT3 = mess(16,198,1)
        [M:SLP]FLT = " [F:STJ]VCRNUM='"+[M:SLP]VCRNUM(nolign-1)+"'"
&                   +"&[F:STJ]UPDCOD="+num$([M:SLP]UPDCOD(nolign-1))
&                   +"&[F:STJ]MVTSEQ="+num$([M:SLP]MVTSEQ(nolign-1))
Endcase
End

Subprog B4_NBLIG
#----------#
# Bouton 4 #
#----------#
Local Integer I
For I=1 To [M]NBLIG
 [M]TRT(I-1) = 2
Next I
Affzo [M]TRT
End

Subprog B5_NBLIG
#----------#
# Bouton 5 #
#----------#
Local Integer I
For I=1 To [M]NBLIG
 [M]TRT(I-1) = 1
Next I
Affzo [M]TRT
End


Subprog C_LBEFMT(VALEUR)
#-------------------#
# Contrôle document #
#-------------------#
Variable Char    VALEUR()
#    Call C_RPTCOD(VALEUR) From AIMP1               # hcb 45363
Local Integer STAT                                  # hcb 45363
Call CONT_RPTCOD(VALEUR,GMESSAGE,STAT) From AIMP1   # hcb 45363

End

Subprog AM_LBEFMT(VALEUR)
#---------------------#
# Apres-modif document#
#---------------------#
Variable Char    VALEUR() 
Local Char TBPAR(15)(1..50),TBVAL(30)(1..50) 
Local Char LPRT(GLONAIM)
# Recherche de l'imprimante par défaut
Call AIMDEF(LPRT,VALEUR,TBPAR,TBVAL) From IMPRIME
[M:SLP]LBEFMT(nolign-1)=VALEUR
If LPRT<>""
    [M:SLP]PRT(nolign-1) = LPRT
Endif
Call C_PRT([M:SLP]PRT(nolign-1))
If mkstat
    Raz GMESSAGE, GERR, mkstat
    Raz [M:SLP]PRT(nolign-1)
Elsif [M:SLP]PRT(nolign-1)<>""
    Diszo [M:SLP]SERIMP(nolign-1), DEFIMP(nolign-1)
Endif
Affzo [M:SLP]PRT(nolign-1), SERIMP(nolign-1), DEFIMP(nolign-1)
End

Subprog B2_LBEFMT(VALEUR)
#------------------------#
# Bouton 2 : MAJ Colonne #
#------------------------#
Variable Char    VALEUR()
Local Integer I
    Call C_LBEFMT(VALEUR)
    If !mkstat
        For I=nolign To [M:SLP]NBLIG-1
            If [M:SLP]TRT(I) = 2
                [M:SLP]LBEFMT(I) = VALEUR
                [M:SLP]PRT(I) = [M:SLP]PRT(nolign-1)
            Endif
        Next
        Affzo [M:SLP]LBEFMT,PRT
    Endif
End

Subprog C_PRT(VALEUR)
#----------------------#
# Contrôle destination #
#----------------------#
Variable Char VALEUR()
If VALEUR<>""
    Call AIMCONT(VALEUR,[M:SLP]LBEFMT(nolign-1),GBATCH) From IMPRIME
    If mkstat
        Raz [M:SLP]SERIMP(nolign-1), DEFIMP(nolign-1)
        End
    Endif
    [M:SLP]SERIMP(nolign-1)    = [F:AIM]PRTSRV
    [M:SLP]DEFIMP(nolign-1)    = [F:AIM]PRTNAM
Else
    Raz [M:SLP]SERIMP(nolign-1), [M:SLP]DEFIMP(nolign-1)
Endif
End

Subprog AM_PRT(VALEUR)
#-------------------------#
# Après-modif destination #
#-------------------------#
Variable Char    VALEUR()
If VALEUR<>""
    Diszo [M:SLP]SERIMP(nolign-1), DEFIMP(nolign-1)
Else
    Actzo [M:SLP]SERIMP(nolign-1), DEFIMP(nolign-1)
Endif
End




##########################################################################


######################################################################################
## Etiquette ajoutée par le superviseur (écran STOLBEIMP) 08/10/2004 14:36:04 (CCC)
######################################################################################
Subprog AS_DEFIMP(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Local Integer I , J , K , NBPAR
 Local Char    PARAMETRE(250)(1..100) , NOMIMP(80)
 If [M]SERIMP(nolign-1)<>"" & right$([M]SERIMP(nolign-1),len([M]SERIMP(nolign-1)))<>"@"
  Listimp PARAMETRE = [M]SERIMP(nolign-1)+"@"
 Else
  Listimp PARAMETRE = [M]SERIMP(nolign-1)
 Endif
 NBPAR = stat1
 K = instr(1,PARAMETRE(2),"=")
 If K=0 : End : Endif
 NOMIMP = right$(PARAMETRE(2),K+2)
 If NOMIMP="" : End : Endif
 Raz NBPAR,PARAMETRE
 NBPAR += 1
 PARAMETRE(NBPAR) = "_PrinterName="+chr$(1)+NOMIMP
 NBPAR += 1
 PARAMETRE(NBPAR) = "_NoVisible="+chr$(1)+"1"
 If [M]SERIMP(nolign-1)<>"" & right$([M]SERIMP(nolign-1),len([M]SERVEUR))<>"@"
  Selimp PARAMETRE = [M]SERIMP(nolign-1)+"@" With PARAMETRE
 Else
  Selimp PARAMETRE = [M]SERIMP(nolign-1) With PARAMETRE
 Endif
 NBPAR = stat1
 Raz [M]PRTDES
 For I=1 To NBPAR
  K = instr(1,PARAMETRE(I),"=")
  If K
   Case left$(PARAMETRE(I),K-1)
    When "_PrinterName"        : VALEUR    = right$(PARAMETRE(I),K+2)
    When "_PrinterPort"        : [M]PRTPOR = right$(PARAMETRE(I),K+2)
    When "_PrinterDriver"      : [M]PRTDRV = right$(PARAMETRE(I),K+2)
#    When "_PrinterCopies"      : [M]NBRCPY = val(right$(PARAMETRE(I),K+2))
    When "_PrinterDescription"
     J = ascii(mid$(PARAMETRE(I),K+1,1))
     If J<=dim([M]PRTDES)
      [M]PRTDES(J-1) = right$(PARAMETRE(I),K+2)
     Endif
   Endcase
  Endif
 Next I
Endif
End


######################################################################################

