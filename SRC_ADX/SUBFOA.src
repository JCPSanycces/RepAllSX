#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Program Name: SUBFOA
# Description : Food allergens selection screen
# Date        : Jun 1, 2010
####################################################################################

####################################################################################
$ACTION

Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "DEBUT"         : Gosub DEBUT
  When "SETBOUT"       : Gosub SETBOUT
  When "BOUTON"        : Gosub EXEBOUT
  When "APRES_MODIF"   : Gosub APRES_MODIF
  When "FIN"           : Gosub FIN
  When "END"           : Gosub ACTEND
  When Default
Endcase

Return

####################################################################################
$OUVRE

Local Char    AZC(20)   : AZC = vireblc(VALEUR,4)  # Remove all spaces
Local Integer ALLOW_UPD : ALLOW_UPD = val(PARAM(2))
Local Integer UPD

If !clalev([F:ADI]) : Local File ATABDIV    [ADI] : Endif : # Miscellaneous Tables

Return

####################################################################################
$DEBUT

Local Integer NOL

Raz [M:DIA]
[M:DIA]ITMREF = PARAM(1)

# Load all possible Allergens
Raz NOL
For [ADI] Where NUMTAB=404
    [M:DIA]CODE(NOL) = [F:ADI]CODE
    Call LECTEXTRA([M:DIA]ALG(NOL),"ATABDIV","LNGDES","404",[F:ADI]CODE) From ATEXTRA
    If instr(1,AZC,[M:DIA]CODE(NOL))
        [M:DIA]SELECT(NOL) = 2
    Endif
    NOL += 1
Next
[M:DIA]NBLIG = NOL

Affzo [M:DIA]

If !ALLOW_UPD
    Diszo [M:DIA]
Endif

Return

####################################################################################
$SETBOUT

Raz CHMEN

If UPD & ALLOW_UPD
    # update in progress
    CHMEN += "S"        # Enable Save
    CHMEN += "C"        # Enable Cancel
    ETABOU(GBFIN) = 0   # Disable End
Else
    ETABOU(GBFIN) = 1
Endif

Gosub SET_BOUT_SPE From GSAISIE

Return

####################################################################################
$EXEBOUT

Case BOUT
  When "S" : Gosub SAVE
  When "C" : Gosub CANCEL
Endcase

Return

####################################################################################
$APRES_MODIF

If ALLOW_UPD
    UPD = -1  # Set update to in progress
Endif


Return

####################################################################################
$FIN

# Set return value of the Allergens/Constraints
VALEUR = vireblc(AZC,4)  # Remove any spaces

Return

####################################################################################
$ACTEND

Local Integer RESP

If UPD
  Call OUINON(mess(265,126,1), RESP) From GESECRAN
  If RESP=1
    FIN = 0  # Response was No, do not exit
  Endif
Endif

XAZC=vireblc(AZC,4)  # Remove any spaces
XLEN=len(XAZC)
If XLEN > 20 :
  FIN = 0
  GERR=1 : GMESSAGE = func AFNC.MES1(mess(5,3501,1),num$(20)) : OK=0
Endif

Return

####################################################################################
$SAVE

# Save current selected Allergens/Constraints to AZC
Raz AZC
For NOL=0 To [M:DIA]NBLIG
  If [M:DIA]SELECT(NOL)=2
    AZC += [M:DIA]CODE(NOL)
  Endif
Next

Affzo [M:DIA]

Raz UPD

Return

####################################################################################
$CANCEL

Gosub DEBUT
Raz UPD

Return
