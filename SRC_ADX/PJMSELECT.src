#<AdxTL>@(#)0.0.0.0 $Revision$ Selections PJM
# PJM selections
###################################################################################################
$ACTION
  Case ACTION
    When "SEL_TABLE"   : Gosub SEL_TABLE
    When "VERF_TABLE"  : Gosub VERF_TABLE
    When "FIN_TABLE"   : Gosub FIN_TABLE
    When "SEL_LISTE"   : Gosub SEL_LISTE
    When "VERF_LISTE"  : Gosub VERF_LISTE
    When Default
  Endcase
Return

###################################################################################################
# Table selection
###################################################################################################
$SEL_TABLE
  Case TABLE
    When "SELPJMOPP"     : Gosub SEL_SELPJMOPP
    When "SELPJMOPP1"    : Gosub SEL_SELPJMOPP
    When "SELPJMOPP2"    : Gosub SEL_SELPJMOPP
    When "SELPJMOPPA"    : Gosub SEL_SELPJMOPPA
    When "SELPJMOPPT"    : Gosub SEL_SELPJMOPPT
    When "SELPJMOPPO"    : Gosub SEL_SELPJMOPPO
    When "SELPJMOPPB"    : Gosub SEL_SELPJMOPPB
    When "SELPJMCOPY"    : Gosub SEL_SELPJMCOPY
    When "WORKSEL"       : Gosub SEL_WORKSEL
    When "SELCRMCOPY"    : Gosub SEL_SELCRMCOPY
    When "SELPJMITM"     : Gosub SEL_SELPJMITM
    When "SELPJMSNP"     : Gosub SEL_SELPJMSNP     # Issue X3-81033 - 2018-03-14 by ALMON
    When "SELPJMFCPY"    : Gosub SEL_SELPJMFCPY    # Issue X3-85280 - 2018-04-19 by TEJAC
    When Default
  Endcase
Return

###################################################################################################
$VERF_TABLE
  Case TABLE
    When "SELPJMOPP"     : Gosub VERF_SELPJMOPP
    When "SELPJMOPP1"    : Gosub VERF_SELPJMOPP
    When "SELPJMOPP2"    : Gosub VERF_SELPJMOPP
    When "SELPJMOPPA"    : Gosub VERF_SELPJMOPPA
    When "SELPJMOPPT"    : Gosub VERF_SELPJMOPPT
    When "SELPJMOPPO"    : Gosub VERF_SELPJMOPPO
    When "SELPJMOPPB"    : Gosub VERF_SELPJMOPPB
    When "WORKSEL"       : Gosub VERF_WORKSEL
    When "SELCRMCOPY"    : Gosub VERF_SELCRMCOPY
    When "SELPJMITM"     : Gosub VERF_SELPJMITM
    When "SELPJMSNP"     : Gosub VERF_SELPJMSNP    # Issue X3-81033 - 2018-03-14 by ALMON
    When "SELPJMFCPY"    : Gosub VERF_SELPJMFCPY   # Issue X3-85280 - 2018-04-19 by TEJAC
    When Default
  Endcase
Return

###################################################################################################
$FIN_TABLE
  Case TABLE
    When "SELPJMOPPA"    : Gosub FIN_SELPJMOPPA
    When "SELPJMOPPT"    : Gosub FIN_SELPJMOPPT
    When "SELPJMOPPO"    : Gosub FIN_SELPJMOPPO
    When "SELPJMCOPY"    : Gosub FIN_SELPJMCOPY
  Endcase
Return

###################################################################################################
# List selection
###################################################################################################
$SEL_LISTE
  Case LISTE
    When "SELPJMTSK"     : Gosub SEL_SELPJMTSK
    When "SELPJMTSKL"    : Gosub SEL_SELPJMTSKL
    When "SELPJMBUD"     : Gosub SEL_SELPJMBUD
    When "SELPJMPROD"    : Gosub SEL_SELPJMPROD
    When "SELPJMPAF"     : Gosub SEL_SELPJMPAF
    When "SELPJTEOPE"    : Gosub SEL_SELPJTEOPE
    When "SELPJMOPEL"    : Gosub SEL_SELPJMOPEL
    When Default
  Endcase
Return

###################################################################################################
$VERF_LISTE
  Case LISTE
    When "SELPJMTSK"     : Gosub VERF_SELPJMTSK
    When "SELPJMTSKL"    : Gosub VERF_SELPJMTSKL
    When "SELPJMBUD"     : Gosub VERF_SELPJMBUD
    When "SELPJMPROD"    : Gosub VERF_SELPJMPROD
    When "SELPJMPAF"     : Gosub VERF_SELPJMPAF
    When "SELPJTEOPE"    : Gosub VERF_SELPJTEOPE
    When "SELPJMOPEL"    : Gosub VERF_SELPJMOPEL
    When Default
  Endcase
Return

###################################################################################################
###################################################################################################
###################################################################################################
# Table selections
###################################################################################################
# SELPJMOPP : PJM Projects selection
# PARAM(1) : actif only Y/N ML1
# PARAM(2) : Assigned Y/N ML1
# PARAM(3) : Assigned user
# PARAM(4) : Template Y/N ML1
# PARAM(5) : Closed Y/N ML1
# PARAM(6) : Sort expression
# PARAM(7) : free filter
# PARAM(8) : free filter
# PARAM(9) : free filter
$SEL_SELPJMOPP
Local Integer IACTIF
Local Integer IASSIGN
Local Char SUSER(GLONAUS)
Local Integer ITPLFLG
Local Integer IPRJCLOSED

  IACTIF = val(PARAM(1))
  IASSIGN = val(PARAM(2))
  SUSER = PARAM(3)
  ITPLFLG = val(PARAM(4))
  IPRJCLOSED = val(PARAM(5))
  # ------------------
  If !clalev([F:OPP])    : Local File OPPOR [OPP]        : Endif
  If !clalev([F:OPPPJM]) : Local File OPPORPJM [OPPPJM]  : Endif
  If !clalev([F:PIM])    : Local File PIMPL [PIM]        : Endif
  If !clalev([F:PJTA])   : Local File PJMTSK [PJTA]      : Endif
  If !clalev([F:OPPAUS]) : Local File PJMOPPAUS [OPPAUS] : Endif
  If !clalev([F:AXX])    : Local File ATEXTRA [AXX]      : Endif
  If !clalev([F:ATZ])    : Local File ATABZON [ATZ]      : Endif
  # ------------------
  CODFIC = "PIMPL"
  DEFPAG = 1
  SIZLIG = 120
  SIZCOL = 400
  CRITERE = "([F:PIM]PIMTYP=2 or [F:PIM]PIMTYP=3)"
  START = "[F:PIM]PIMNUM"
  # ------------------
  If PARAM(6) <> AVOID.ACHAR Then
    ORDRE = PARAM(6)
  Else
    ORDRE = "[F:PIM]PIMNUM"
  Endif
  # ------------------
  #
  If IASSIGN = [V]CST_AYES Then
    Link [OPPAUS]   With
&                      [OPPPJM]OPPPJM0~=[F:OPPAUS]OPPNUM,
&                      [OPP]OPP0~=[F:OPPPJM]OPPNUM,
&                      [PIM]PIM0=[F:OPPPJM]OPPNUM,
&                      [AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;""
&                   As [NEW]
  Else
    Link [OPPPJM] With [PIM]PIM0=[F:OPPPJM]OPPNUM,
&                      [OPP]OPP0=[F:OPPPJM]OPPNUM,
&                      [AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;""
&                   As [NEW]
  Endif
  # ------------------
  Default File [NEW]
  # ------------------
  # Define specific filters
  If IACTIF = [V]CST_AYES Then
    CRITERE -= "& [F:PIM]PIMSTA=" + num$(IACTIF)
  Endif
  #
  If IASSIGN = [V]CST_AYES Then
    If SUSER <> AVOID.ACHAR Then
      CRITERE -= "& [F:OPPAUS]POACLB='" + SUSER + "'"
    Endif
  Endif
  #
  If ITPLFLG = [V]CST_AYES or ITPLFLG = [V]CST_ANO Then
    CRITERE -= "& [F:OPPPJM]OPPMOD=" + num$(ITPLFLG)
  Endif
  #
  If IPRJCLOSED = [V]CST_AYES Then
    CRITERE -= "& [F:PIM]OPPSTATE=4"
  Elsif IPRJCLOSED = [V]CST_ANO Then
    CRITERE -= "& [F:PIM]OPPSTATE<>4"
  Endif
  #
  If PARAM(9) <> AVOID.ACHAR Then
    CRITERE -= '&' - PARAM(9)
  Endif
  #
  # Define columns to display in the list
  NBCOL += 1 : COL(NBCOL) = "[F:OPPPJM]OPPNUM"                              : Call TEXTFIC("PIMPL",  "OPPNUM",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]TASCOD"                                 : Call TEXTFIC("PJMTSK", "TASCOD",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]PBUCOD"                                 : Call TEXTFIC("PJMBUD", "PBUCOD",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"                                  : Call TEXTFIC("PIMPL",  "PIMDESAXX", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:PIM]PIMTYP,2254,1)"                    : Call TEXTFIC("PIMPL",  "PIMTYP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:PIM]OPPSTATE,2249,1)"                  : Call TEXTFIC("PIMPL",  "OPPSTATE",  1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:OPPPJM]OPPMOD,1,1)"                    : Call TEXTFIC("OPPORPJM","OPPMOD",   1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]CPY"                                    : Call TEXTFIC("PIMPL",  "CPY",       1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]FCY"                                    : Call TEXTFIC("PIMPL",  "FCY",       1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]OPPCMP"                                 : Call TEXTFIC("OPPOR",  "OPPCMP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]OPPREP"                                 : Call TEXTFIC("OPPOR",  "OPPREP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "string$([F:PIM]PIMTYP=1,'') + string$([F:PIM]PIMTYP<>1,mess([F:PIM]PIMSTA,1,1))" : Call TEXTFIC("PIMPL",  "PIMSTA",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]PIMNUM"                                 : Call TEXTFIC("PIMPL",  "PIMNUM",    1, TIT(NBCOL)) From OBJDIV
  # ------------------
Return

$VERF_SELPJMOPP
Return

###################################################################################################
# SELPJMOPPA : PJM Projects selection
# PARAM(1) : actif only Y/N ML1
# PARAM(2) : Assigned Y/N ML1
# PARAM(3) : Assigned user
# PARAM(4) : free filter
# PARAM(5) : field receive TASCOD
# PARAM(6) : field receive OPECOD
# PARAM(7) : field receive OPESPLNUM
# PARAM(8) : field receive PBUCOD
$SEL_SELPJMOPPA
Local Char SOPPNUM(GLONOPP)
Local Integer IACTIF
Local Integer IASSIGN
Local Char SUSER(GLONAUS)
Local Integer ILIG

  # ------------------
  SOPPNUM = VALEUR
  IACTIF = val(PARAM(1))
  IASSIGN = val(PARAM(2))
  SUSER = PARAM(3)
  # ------------------
  If !clalev([F:OPP])    : Local File OPPOR [OPP]          : Endif
  If !clalev([F:OPPPJM]) : Local File OPPORPJM [OPPPJM]    : Endif
  If !clalev([F:PIM])    : Local File PIMPL [PIM]          : Endif
  If !clalev([F:PJTA])   : Local File PJMTSK [PJTA]        : Endif
  If !clalev([F:PTKO])   : Local File PJMTSKOPE [PTKO]     : Endif
  If !clalev([F:AXX])    : Local File ATEXTRA [AXX]        : Endif
  If !clalev([F:DPTKO])  : Local File DESPJMTSKOPE [DPTKO] : Endif
  If !clalev([F:ATZ])    : Local File ATABZON [ATZ]        : Endif
  If !clalev([F:VTITA])  : Local File VPJMTIMTAS [VTITA]   : Endif
  # ------------------
  ILIG = 0
  CODFIC = "PIMPL"
  DEFPAG = 1
  SIZLIG = 120
  SIZCOL = 400
  ILIG += 1
  CRITERE(ILIG) = "1=1"
  START = "[F:OPPAUS]OPPNUM"
  ORDRE = "[F:OPPAUS]OPPNUM;[F:OPPAUS]PBUCOD;[F:OPPAUS]TASCOD;[F:OPPAUS]OPENUM;[F:OPPAUS]OPESPLNUM"
  # ------------------
  If !clalev([F:OPPAUS]) : Local File PJMOPPAUSB [OPPAUS] : Endif  # View
  Link [OPPAUS] With
&                    [PTKO]PTKO0=[F:OPPAUS]OPPNUM;[F:OPPAUS]TASCOD;[F:OPPAUS]OPENUM;[F:OPPAUS]OPESPLNUM,
&                    [PJTA]PTA0=[F:OPPAUS]OPPNUM;[F:OPPAUS]TASCOD,
&                    [OPPPJM]OPPPJM0=[F:OPPAUS]OPPNUM,
&                    [OPP]OPP0=[F:OPPAUS]OPPNUM,
&                    [PIM]PIM0=[F:OPPAUS]PIMNUM,
&                    [AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;"",
&                    [DPTKO]DPTKO1=GLANGUE;[F:PTKO]OPPNUM;[F:PTKO]TASCOD;[F:PTKO]OPENUM;[F:PTKO]OPESPLNUM,
&                    [VTITA]VTITA0=[F:PIM]FCY;"PJMTIMTAS"
&                 As [NEW]
  # ------------------
  CRITERE(ILIG) -= "& [F:OPPAUS]OPPNUM>='" + VALEUR + "'"
  CRITERE(ILIG) -= "& ([F:OPPAUS]OPENUM = 0 or [F:PTKO]OPESTA = 4)"
  ILIG += 1
  CRITERE(ILIG) -= "& find([F:PIM]PIMTYP,2,3,4,5,7)<>0"
  ILIG += 1
  CRITERE(ILIG) -= "& (([F:VTITA]VALEUR=2) or ([F:VTITA]VALEUR<>2 and (([F:PIM]PIMTYP<>5 and [F:PIM]PIMTYP<>7) or ([F:PTKO]OPENUM>0))))"         # Issue X3-17823 - 2017-12-20 by FGR
  # ------------------
  Default File [NEW]
  # ------------------
  # Define specific filters
  If IACTIF = [V]CST_AYES Then
    CRITERE(ILIG) -= "& [F:PIM]PIMSTA=" + num$([V]CST_AYES)
  Endif
  #
  If IASSIGN = [V]CST_AYES Then
    If SUSER <> AVOID.ACHAR Then
      CRITERE(ILIG) -= "& [F:OPPAUS]POACLB='" + SUSER + "'"
    Else
      CRITERE(ILIG) -= "& [F:OPPAUS]POACLB<>''"
    Endif
  Else
    CRITERE(ILIG) -= "& [F:OPPAUS]POACLB=''"
  Endif
  #
  If PARAM(4) <> AVOID.ACHAR Then
    ILIG += 1
    CRITERE(ILIG) -= '&' - PARAM(4)
  Endif
  # ------------------
  # Define columns to display in the list
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]OPPNUM"                                 : Call TEXTFIC("PIMPL",     "OPPNUM",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]TASCOD"                                 : Call TEXTFIC("PJMTSK",    "TASCOD",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PTKO]OPENUM"                                : Call TEXTFIC("PJMTSKOPE", "OPENUM",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]PBUCOD"                                 : Call TEXTFIC("PJMBUD",    "PBUCOD",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "string$([F:PTKO]OPENUM=0,[F:AXX]TEXTE) + string$([F:PTKO]OPENUM>0,[F:DPTKO]TEXTE)"
                                                                              Call TEXTFIC("PIMPL",     "PIMDESAXX", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:PIM]PIMTYP,2254,1)"                    : Call TEXTFIC("PIMPL",     "PIMTYP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]CPY"                                    : Call TEXTFIC("PIMPL",     "CPY",       1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]FCY"                                    : Call TEXTFIC("PIMPL",     "FCY",       1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]OPPCMP"                                 : Call TEXTFIC("OPPOR",     "OPPCMP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]OPPREP"                                 : Call TEXTFIC("OPPOR",     "OPPREP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "string$([F:PIM]PIMTYP=1,'') + string$([F:PIM]PIMTYP<>1,mess([F:PIM]PIMSTA,1,1))" : Call TEXTFIC("PIMPL",  "PIMSTA",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PTKO]OPESPLNUM"                             : Call TEXTFIC("PJMTSKOPE", "OPESPLNUM", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]PIMNUM"                                 : Call TEXTFIC("PIMPL",     "PIMNUM",    1, TIT(NBCOL)) From OBJDIV
  # ------------------
Return

$VERF_SELPJMOPPA
Return

$FIN_SELPJMOPPA
  PARAM(5) = [F:OPPAUS]TASCOD
  PARAM(6) = num$([F:OPPAUS]OPENUM)
  PARAM(7) = num$([F:OPPAUS]OPESPLNUM)
  PARAM(8) = [F:OPPAUS]PBUCOD
Return

###################################################################################################
# SELPJMOPPT : PJM Tasks selection
# PARAM(1) : actif only Y/N ML1
# PARAM(2) : Assigned Y/N ML1
# PARAM(3) : Assigned user
# PARAM(4) : free filter
# PARAM(5) : field value OPPNUM
# PARAM(6) : field receive OPECOD
# PARAM(7) : field receive OPESPLNUM
# PARAM(8) : field receive PBUCOD
$SEL_SELPJMOPPT
Local Char SOPPNUM(GLONOPP)
Local Integer IACTIF
Local Integer IASSIGN
Local Char SUSER(GLONAUS)
Local Integer ILIG

  # ------------------
  SOPPNUM = PARAM(5)
  IACTIF = val(PARAM(1))
  IASSIGN = val(PARAM(2))
  SUSER = PARAM(3)
  # ------------------
  If !clalev([F:OPP])    : Local File OPPOR [OPP]          : Endif
  If !clalev([F:OPPPJM]) : Local File OPPORPJM [OPPPJM]    : Endif
  If !clalev([F:PIM])    : Local File PIMPL [PIM]          : Endif
  If !clalev([F:PJTA])   : Local File PJMTSK [PJTA]        : Endif
  If !clalev([F:PTKO])   : Local File PJMTSKOPE [PTKO]     : Endif
  If !clalev([F:DPTKO])  : Local File DESPJMTSKOPE [DPTKO] : Endif
  If !clalev([F:AXX])    : Local File ATEXTRA [AXX]        : Endif
  If !clalev([F:ATZ])    : Local File ATABZON [ATZ]        : Endif
  If !clalev([F:VTITA])  : Local File VPJMTIMTAS [VTITA]   : Endif
  # ------------------
  ILIG = 0
  CODFIC = "PIMPL"
  DEFPAG = 1
  SIZLIG = 120
  SIZCOL = 400
  ILIG += 1
  CRITERE(ILIG) = "1=1"
  START = "[F:OPPAUS]TASCOD"
  ORDRE = "[F:OPPAUS]OPPNUM;[F:OPPAUS]PBUCOD;[F:OPPAUS]TASCOD;[F:OPPAUS]OPENUM;[F:OPPAUS]OPESPLNUM"
  # ------------------
  If !clalev([F:OPPAUS]) : Local File PJMOPPAUSB [OPPAUS] : Endif  # View
  Link [OPPAUS] With
&                    [PTKO]PTKO0=[F:OPPAUS]OPPNUM;[F:OPPAUS]TASCOD;[F:OPPAUS]OPENUM;[F:OPPAUS]OPESPLNUM,
&                    [PJTA]PTA0=[F:OPPAUS]OPPNUM;[F:OPPAUS]TASCOD,
&                    [OPPPJM]OPPPJM0=[F:OPPAUS]OPPNUM,
&                    [OPP]OPP0=[F:OPPAUS]OPPNUM,
&                    [PIM]PIM0=[F:OPPAUS]PIMNUM,
&                    [AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;"",
&                    [DPTKO]DPTKO1=GLANGUE;[F:PTKO]OPPNUM;[F:PTKO]TASCOD;[F:PTKO]OPENUM;[F:PTKO]OPESPLNUM,
&                    [VTITA]VTITA0=[F:PIM]FCY;"PJMTIMTAS"
&                 As [NEW]
  # ------------------
  CRITERE(ILIG) -= "& [F:OPPAUS]OPPNUM='" + SOPPNUM  + "'"
  CRITERE(ILIG) -= "& ([F:PIM]PIMTYP=5 or [F:PIM]PIMTYP=7)"
  ILIG += 1
  CRITERE(ILIG) -= "& (([F:VTITA]VALEUR=2) or ([F:VTITA]VALEUR<>2 and (([F:PTKO]OPENUM>0))))"
  # ------------------
  Default File [NEW]
  # ------------------
  # Define specific filters
  If IACTIF = [V]CST_AYES Then
    CRITERE(ILIG) -= "& [F:PIM]PIMSTA=" + num$([V]CST_AYES)
  Endif
  #
  If IASSIGN = [V]CST_AYES Then
    If SUSER <> AVOID.ACHAR Then
      CRITERE(ILIG) -= "& [F:OPPAUS]POACLB='" + SUSER + "'"
    Else
      CRITERE(ILIG) -= "& [F:OPPAUS]POACLB<>''"
    Endif
  Else
    CRITERE(ILIG) -= "& [F:OPPAUS]POACLB=''"
  Endif
  #
  If PARAM(4) <> AVOID.ACHAR Then
    ILIG += 1
    CRITERE(ILIG) -= '&' - PARAM(4)
  Endif
  # ------------------
  # Define columns to display in the list
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]OPPNUM"                                 : Call TEXTFIC("PIMPL",     "OPPNUM",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]TASCOD"                                 : Call TEXTFIC("PJMTSK",    "TASCOD",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:PJTA]TASTYP,2258,1)"                   : Call TEXTFIC("PJMTSK",    "TASTYP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PTKO]OPENUM"                                : Call TEXTFIC("PJMTSKOPE", "OPENUM",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]PBUCOD"                                 : Call TEXTFIC("PJMBUD",    "PBUCOD",    1, TIT(NBCOL)) From OBJDIV
 #NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"                                  : Call TEXTFIC("PIMPL",     "PIMDESAXX", 1, TIT(NBCOL)) From OBJDIV  # Issue X3-67772 - 2017-12-18 by FGR
  NBCOL += 1 : COL(NBCOL) = "string$([F:PTKO]OPENUM=0,[F:AXX]TEXTE) + string$([F:PTKO]OPENUM>0,[F:DPTKO]TEXTE)"                                  # Issue X3-67772 - 2017-12-18 by FGR
                                                                              Call TEXTFIC("PIMPL",     "PIMDESAXX", 1, TIT(NBCOL)) From OBJDIV  # Issue X3-67772 - 2017-12-18 by FGR
  NBCOL += 1 : COL(NBCOL) = "mess([F:PIM]PIMTYP,2254,1)"                    : Call TEXTFIC("PIMPL",     "PIMTYP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]CPY"                                    : Call TEXTFIC("PIMPL",     "CPY",       1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]FCY"                                    : Call TEXTFIC("PIMPL",     "FCY",       1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]OPPCMP"                                 : Call TEXTFIC("OPPOR",     "OPPCMP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]OPPREP"                                 : Call TEXTFIC("OPPOR",     "OPPREP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "string$([F:PIM]PIMTYP=1,'') + string$([F:PIM]PIMTYP<>1,mess([F:PIM]PIMSTA,1,1))" : Call TEXTFIC("PIMPL",  "PIMSTA",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PTKO]OPESPLNUM"                             : Call TEXTFIC("PJMTSKOPE", "OPESPLNUM", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]PIMNUM"                                 : Call TEXTFIC("PIMPL",     "PIMNUM",    1, TIT(NBCOL)) From OBJDIV
  # ------------------
Return

$VERF_SELPJMOPPT
Return

$FIN_SELPJMOPPT
  PARAM(6) = num$([F:OPPAUS]OPENUM)
  PARAM(7) = num$([F:OPPAUS]OPESPLNUM)
  PARAM(8) = [F:OPPAUS]PBUCOD
Return

###################################################################################################
# SELPJMOPPO : PJM Tasks selection
# PARAM(1) : actif only Y/N ML1
# PARAM(2) : Assigned Y/N ML1
# PARAM(3) : Assigned user
# PARAM(4) : free filter
# PARAM(5) : field value OPPNUM
# PARAM(6) : field receive OPESPLNUM
# PARAM(7) : field receive TASCOD
$SEL_SELPJMOPPO
Local Char SOPPNUM(GLONOPP)
Local Char STASCOD(GLONTAC)
Local Integer IACTIF
Local Integer IASSIGN
Local Char SUSER(GLONAUS)
Local Integer ILIG

  # ------------------
  SOPPNUM = PARAM(5)
  IACTIF = val(PARAM(1))
  IASSIGN = val(PARAM(2))
  SUSER = PARAM(3)
  STASCOD = PARAM(7)
  # ------------------
  If !clalev([F:OPP])    : Local File OPPOR [OPP]          : Endif
  If !clalev([F:OPPPJM]) : Local File OPPORPJM [OPPPJM]    : Endif
  If !clalev([F:PIM])    : Local File PIMPL [PIM]          : Endif
  If !clalev([F:PJTA])   : Local File PJMTSK [PJTA]        : Endif
  If !clalev([F:PTKO])   : Local File PJMTSKOPE [PTKO]     : Endif
  If !clalev([F:DPTKO])  : Local File DESPJMTSKOPE [DPTKO] : Endif
  If !clalev([F:AXX])    : Local File ATEXTRA [AXX]        : Endif
  If !clalev([F:ATZ])    : Local File ATABZON [ATZ]        : Endif
  # ------------------
  ILIG = 0
  CODFIC = "PIMPL"
  DEFPAG = 1
  SIZLIG = 120
  SIZCOL = 400
  ILIG += 1
  CRITERE(ILIG) = "1=1"
  START = "[F:OPPAUS]OPENUM"
  ORDRE = "[F:OPPAUS]OPPNUM;[F:OPPAUS]PBUCOD;[F:OPPAUS]TASCOD;[F:OPPAUS]OPENUM;[F:OPPAUS]OPESPLNUM"
  # ------------------
  If !clalev([F:OPPAUS]) : Local File PJMOPPAUSB [OPPAUS] : Endif  # View
  Link [OPPAUS] With
&                    [PTKO]PTKO0=[F:OPPAUS]OPPNUM;[F:OPPAUS]TASCOD;[F:OPPAUS]OPENUM;[F:OPPAUS]OPESPLNUM,
&                    [PJTA]PTA0=[F:OPPAUS]OPPNUM;[F:OPPAUS]TASCOD,
&                    [OPPPJM]OPPPJM0=[F:OPPAUS]OPPNUM,
&                    [OPP]OPP0=[F:OPPAUS]OPPNUM,
&                    [PIM]PIM0=[F:OPPAUS]PIMNUM,
&                    [AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;"",
&                    [DPTKO]DPTKO1=GLANGUE;[F:PTKO]OPPNUM;[F:PTKO]TASCOD;[F:PTKO]OPENUM;[F:PTKO]OPESPLNUM
&                 As [NEW]
  # ------------------
  CRITERE(ILIG) -= "& [F:OPPAUS]OPPNUM='" + SOPPNUM  + "' and [F:OPPAUS]TASCOD='" + STASCOD  + "'"
  CRITERE(ILIG) -= "& ([F:PIM]PIMTYP=5 or [F:PIM]PIMTYP=7)"
  ILIG += 1
  CRITERE(ILIG) -= "& ([F:PTKO]OPENUM>0)"
  # ------------------
  Default File [NEW]
  # ------------------
  # Define specific filters
  If IACTIF = [V]CST_AYES Then
    CRITERE(ILIG) -= "& [F:PIM]PIMSTA=" + num$([V]CST_AYES)
  Endif
  #
  If IASSIGN = [V]CST_AYES Then
    If SUSER <> AVOID.ACHAR Then
      CRITERE(ILIG) -= "& [F:OPPAUS]POACLB='" + SUSER + "'"
    Else
      CRITERE(ILIG) -= "& [F:OPPAUS]POACLB<>''"
    Endif
  Else
    CRITERE(ILIG) -= "& [F:OPPAUS]POACLB=''"
  Endif
  #
  If PARAM(4) <> AVOID.ACHAR Then
    ILIG += 1
    CRITERE(ILIG) -= '&' - PARAM(4)
  Endif
  # ------------------
  # Define columns to display in the list
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]OPPNUM"                                 : Call TEXTFIC("PIMPL",     "OPPNUM",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]TASCOD"                                 : Call TEXTFIC("PJMTSK",    "TASCOD",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:PJTA]TASTYP,2258,1)"                   : Call TEXTFIC("PJMTSK",    "TASTYP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PTKO]OPENUM"                                : Call TEXTFIC("PJMTSKOPE", "OPENUM",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]PBUCOD"                                 : Call TEXTFIC("PJMBUD",    "PBUCOD",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "string$([F:PTKO]OPENUM=0,[F:AXX]TEXTE) + string$([F:PTKO]OPENUM>0,[F:DPTKO]TEXTE)"
                                                                              Call TEXTFIC("PIMPL",     "PIMDESAXX", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:PIM]PIMTYP,2254,1)"                    : Call TEXTFIC("PIMPL",     "PIMTYP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]CPY"                                    : Call TEXTFIC("PIMPL",     "CPY",       1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]FCY"                                    : Call TEXTFIC("PIMPL",     "FCY",       1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]OPPCMP"                                 : Call TEXTFIC("OPPOR",     "OPPCMP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]OPPREP"                                 : Call TEXTFIC("OPPOR",     "OPPREP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "string$([F:PIM]PIMTYP=1,'') + string$([F:PIM]PIMTYP<>1,mess([F:PIM]PIMSTA,1,1))" : Call TEXTFIC("PIMPL",  "PIMSTA",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PTKO]OPESPLNUM"                             : Call TEXTFIC("PJMTSKOPE", "OPESPLNUM", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]PIMNUM"                                 : Call TEXTFIC("PIMPL",     "PIMNUM",    1, TIT(NBCOL)) From OBJDIV
  # ------------------
Return

$VERF_SELPJMOPPO
Return

$FIN_SELPJMOPPO
  PARAM(6) = num$([F:OPPAUS]OPESPLNUM)
Return

###################################################################################################
# SELPJMOPPB : PJM Budgets selection
# PARAM(1) : actif only Y/N ML1
# PARAM(2) : free filter
# PARAM(3) : field value OPPNUM
$SEL_SELPJMOPPB
Local Char SOPPNUM(GLONOPP)
Local Integer IACTIF

  # ------------------
  SOPPNUM = PARAM(3)
  IACTIF = val(PARAM(1))
  # ------------------
  If !clalev([F:OPP])    : Local File OPPOR [OPP]       : Endif
  If !clalev([F:OPPPJM]) : Local File OPPORPJM [OPPPJM] : Endif
  If !clalev([F:PIM])    : Local File PIMPL [PIM]       : Endif
  If !clalev([F:PJBU])   : Local File PJMBUD [PJBU]     : Endif
  If !clalev([F:AXX])    : Local File ATEXTRA [AXX]     : Endif
  If !clalev([F:ATZ])    : Local File ATABZON [ATZ]     : Endif
  # ------------------
  CODFIC = "PIMPL"
  DEFPAG = 1
  SIZLIG = 120
  SIZCOL = 400
  CRITERE = "1=1"
  START = "[F:PIM]PBUCOD"
  ORDRE = "[F:PIM]OPPNUM;[F:PIM]PBUCOD"
  # ------------------
  Link [PIM] With
&                      [OPPPJM]OPPPJM0=[F:PIM]OPPNUM,
&                      [OPP]OPP0=[F:PIM]OPPNUM,
&                      [PJBU]PJBU0=[F:PIM]OPPNUM;[F:PIM]PBUCOD,
&                      [AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;""
&                   As [NEW]
  # ------------------
  CRITERE -= "& [F:PIM]OPPNUM='" + SOPPNUM  + "'"
  CRITERE -= "& [F:PIM]PIMTYP=4"
  # ------------------
  Default File [NEW]
  # ------------------
  # Define specific filters
  If IACTIF = [V]CST_AYES Then
    CRITERE -= "& [F:PIM]PIMSTA=" + num$([V]CST_AYES)
  Endif
  #
  If PARAM(2) <> AVOID.ACHAR Then
    CRITERE -= '&' - PARAM(4)
  Endif
  # ------------------
  # Define columns to display in the list
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]OPPNUM"                                 : Call TEXTFIC("PIMPL",     "OPPNUM",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]PBUCOD"                                 : Call TEXTFIC("PJMBUD",    "PBUCOD",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"                                  : Call TEXTFIC("PIMPL",     "PIMDESAXX", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:PJBU]PBUIMP,1,1)"                      : Call TEXTFIC("PJMBUD",    "PBUIMP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:PIM]PIMTYP,2254,1)"                    : Call TEXTFIC("PIMPL",     "PIMTYP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]CPY"                                    : Call TEXTFIC("PIMPL",     "CPY",       1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]FCY"                                    : Call TEXTFIC("PIMPL",     "FCY",       1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]OPPCMP"                                 : Call TEXTFIC("OPPOR",     "OPPCMP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]OPPREP"                                 : Call TEXTFIC("OPPOR",     "OPPREP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "string$([F:PIM]PIMTYP=1,'') + string$([F:PIM]PIMTYP<>1,mess([F:PIM]PIMSTA,1,1))" : Call TEXTFIC("PIMPL",  "PIMSTA",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]PIMNUM"                                 : Call TEXTFIC("PIMPL",     "PIMNUM",    1, TIT(NBCOL)) From OBJDIV
  # ------------------
Return

$VERF_SELPJMOPPB
Return

###################################################################################################
$SEL_SELPJMCOPY
Local Char SOPPNUM(GLONOPP)

  # ------------------
  SOPPNUM = VALEUR
  # ------------------
  If !clalev([F:OPP])    : Local File OPPOR [OPP]       : Endif
  If !clalev([F:OPPPJM]) : Local File OPPORPJM [OPPPJM] : Endif
  If !clalev([F:PIM])    : Local File PIMPL [PIM]       : Endif
  If !clalev([F:AXX])    : Local File ATEXTRA [AXX]     : Endif
  If !clalev([F:ATZ])    : Local File ATABZON [ATZ]     : Endif
  # ------------------
  CODFIC = "PIMPL"
  DEFPAG = 1
  SIZLIG = 120
  SIZCOL = 400
  CRITERE = "([F:PIM]PIMTYP=2 or [F:PIM]PIMTYP=3)"
  START = "[F:PIM]OPPNUM"
  ORDRE = "[F:PIM]OPPNUM"
  # ------------------
    Link [PIM] With
&                      [OPPPJM]OPPPJM0=[F:PIM]OPPNUM,
&                      [OPP]OPP0=[F:PIM]OPPNUM,
&                      [AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;""
&                   As [NEW]

  CRITERE -= "& [F:PIM]OPPNUM>='" + VALEUR  + "'"
  # ------------------
  Default File [NEW]
  # ------------------
  # Define columns to display in the list
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]OPPNUM"                                 : Call TEXTFIC("PIMPL",     "OPPNUM",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"                                  : Call TEXTFIC("PIMPL",     "PIMDESAXX", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:PIM]OPPSTATE,2249,1)"                  : Call TEXTFIC("PIMPL",     "OPPSTATE",  1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "string$([F:PIM]PIMTYP=1,'') + string$([F:PIM]PIMTYP<>1,mess([F:PIM]PIMSTA,1,1))" : Call TEXTFIC("PIMPL",  "PIMSTA",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:PIM]PIMTYP,2254,1)"                    : Call TEXTFIC("PIMPL",     "PIMTYP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([OPPPJM]OPPMOD,1,1)"                      : Call TEXTFIC("OPPORPJM",  "OPPMOD",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]FCY"                                    : Call TEXTFIC("PIMPL",     "FCY",       1, TIT(NBCOL)) From OBJDIV
  # ------------------
Return

$VERF_SELPJMCOPY
Return

$FIN_SELPJMCOPY
Return

###################################################################################################
$SEL_WORKSEL
  # ------------------------------------
  If !clalev ([F:MWS]) : Local File WORKSTATIO [MWS] : Endif
  If !clalev([F:AXX])  : Local File ATEXTRA [AXX]    : Endif
  # ------------------------------------
  CODFIC = "WORKSTATIO"
  DEFPAG = 1
  SIZLIG = 120
  SIZCOL = 400
  CRITERE = "[F:MWS]WCRFCY = [M:PJTA0A]TASFCY"   # Issue X3-99916 - 2018-07-11 by FGR : not [M:PJTA0] from now
  START = "[F:MWS]WST"
  ORDRE = "[F:MWS]WST"
  # ------------------------------------
  Link [MWS] With [AXX]AXX0="WORKSTATIO";"WSTDESAXX";GLANGUE;[F:MWS]WST;[F:MWS]WCRFCY As [NEW]
  # ------------------------------------
  CRITERE -= "& [F:MWS]WST>='" + VALEUR  + "'"
  If PARAM(1) <> AVOID.ACHAR Then
    CRITERE -= "& (" + PARAM(1) + ")"
  Endif
  # ------------------------------------
  TIT = mess(466,2260,1)
  Default File [NEW]
  # ------------------------------------
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "WST"                                    : TIT(NBCOL) = mess(86,2260,1)
  NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"                           : TIT(NBCOL) = mess(87,2260,1)
  NBCOL += 1 : COL(NBCOL) = "WCRFCY"                                 : TIT(NBCOL) = mess(103,2260,1)
  NBCOL += 1 : COL(NBCOL) = "WCR"                                    : TIT(NBCOL) = mess(467,2260,1)
  NBCOL += 1 : COL(NBCOL) = "TWD"                                    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "PCCCOD"                                 : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  # ------------------------------------
Return

$VERF_WORKSEL
Return

###################################################################################################
#SELCRMCOPY - CRM project copy selection
# PARAM(1) : PROJET [M:PJMAC0]OPPNUM
# PARAM(2) : FCY [M:PJMAC0]SALFCY
# PARAM(3) : CUR Currency Filter
$SEL_SELCRMCOPY
Local Char SCUR(GLONCUR)
Local Char SFCY(GLONFCY)
Local Char SOPPNUM(GLONOPP)
Local Char SCPY(GLONCPY)

  # ------------------
  SOPPNUM = PARAM(1)
  SFCY = PARAM(2)
  SCUR = PARAM(3)
  # ------------------
  If !clalev([F:OPP])    : Local File OPPOR [OPP]       : Endif
  If !clalev([F:PIM])    : Local File PIMPL [PIM]       : Endif
  If !clalev([F:AXX])    : Local File ATEXTRA [AXX]     : Endif
  If !clalev([F:ATZ])    : Local File ATABZON [ATZ]     : Endif
  # ------------------
  CODFIC = "PIMPL"
  DEFPAG = 1
  SIZLIG = 120
  SIZCOL = 400
  CRITERE = "[F:PIM]PIMTYP=1"
  START = "[F:PIM]OPPNUM"
  ORDRE = "[F:PIM]OPPNUM"
  # ------------------
    Link [PIM] With [OPP]OPP0=[F:PIM]OPPNUM,
&                   [AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;""
&                As [NEW]
  # ------------------
  Default File [NEW]
  # ------------------
  # Define specific selection list filters:
  # Project status "OPEN" only + Project active status "ACTIVE" only
  CRITERE -= "& ([F:OPP]OPPCLO=1 and [F:PIM]PIMSTA=2)"
  # Get company from SOURCE project site
  If SFCY <> AVOID.ACHAR Then
    SCPY = func TRTPJT.GET_CPY_FROM_FCY(SFCY)
    CRITERE -= "& [F:PIM]CPY='" + SCPY  + "'"
  Endif
  # Project currency filter
  If SCUR <> AVOID.ACHAR Then
    CRITERE -= "& [F:OPP]CUR='" + SCUR + "'"
  Endif
  # Define the columns to be displayed in the selection list:
  NBCOL += 1 : COL(NBCOL) = "[F:PIM]OPPNUM"                                 : Call TEXTFIC("PIMPL",     "OPPNUM",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"                                  : Call TEXTFIC("PIMPL",     "PIMDESAXX", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:OPP]CUR"                                    : Call TEXTFIC("OPPOR",     "CUR",       1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:PIM]PIMTYP=1,2254,1)"                  : Call TEXTFIC("PIMPL",     "PIMTYP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "string$([F:PIM]PIMTYP=1,mess([F:PIM]PIMSTA,1,1))" : Call TEXTFIC("PIMPL",  "PIMSTA",    1, TIT(NBCOL)) From OBJDIV
  # ------------------
Return

$VERF_SELCRMCOPY
Return

###################################################################################################
###################################################################################################
# List selections
###################################################################################################
###################################################################################################
$SEL_SELPJMTSK
Local Integer NI
Local Integer NZ
Local Char SZLIBELLE(250)
Local Integer ITER
Local Integer ITYP
Local Char SOPPNUM(GLONPIM)
Local Integer IREADTABLE

  SOPPNUM = PARAM(1)
  If SOPPNUM <> "" Then
    NZ = 0
    IREADTABLE = [V]CST_ANO
    If dim(GZINSPJM) > 0 Then
      If GZINSPJM <> null and GZINSPJM.PJM(1) <> null and GZINSPJM.OPPNUM = SOPPNUM Then
        IREADTABLE = [V]CST_AYES
      Endif
    Endif
    If IREADTABLE = [V]CST_AYES Then
      For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS)
        If GZINSPJM.PJM(1).TAS(NI) <> null and find(GZINSPJM.PJM(1).TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          NZ += 1
          If NZ >= dim(TEX)-1 Then
            Break
          Endif
          # ------------------------------
          TEX(NZ) = GZINSPJM.PJM(1).TAS(NI).TASCOD
          TEXTE(NZ) = GZINSPJM.PJM(1).TAS(NI).TASCOD - "-" - GZINSPJM.PJM(1).TAS(NI).PIMPL.PIMDESAXX
          # ------------------------------
        Endif
      Next NI
    Else
      Local File PJMTSK [PJTA]
      Local File PIMPL [PIM]
      Local File ATEXTRA [AXX]
      Link [PJTA] With [F:PIM]PIM0=[F:PJTA]KEYCONCAT,
&                      [F:AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;""
&                   As [LPJTA]
&                Where [F:PJTA]OPPNUM = SOPPNUM
&                Order By Key KEY1=[F:PJTA]TASCOD
      # ------------------------------
      For [F:LPJTA]KEY1
        NZ += 1
        If NZ >= dim(TEX)-1 Then
          Break
        Endif
        # ------------------------------
        TEX(NZ) = [PJTA]TASCOD
        TEXTE(NZ) = [PJTA]TASCOD - [F:AXX]TEXTE
        # ------------------------------
      Next
    Endif
    NBTEX = NZ
    TIT = mess(189,2260,1)
  Endif
Return

VERF_SELPJMTSK
Return

Subprog TUNPJMTSK(AZC,PROJET)
Variable Char    AZC()
Value    Char    PROJET

Local Char VALBOUT(250) , PARBOUT(250)(1..20)
Local Char SAVACT(GLONACT)
Local Integer FLGEXE
Local Integer IFLGOPPLOC
Local Integer MY_STATUS

  If PROJET <> "" Then
    # Issue X3-99928 - 2018-07-19 by FGR : Check Authorization
    If func SUBPJMA.GET_AUTHORIZATION_GESPJM("5") = [V]CST_ANO Then
      GMESSAGE = mess(2,104,1)
      GERR = 1
      GOK = 0
      End
    Else
      IFLGOPPLOC = [V]CST_ANO
      If dim(GZINSPJM) <= 0 Then
        Global Instance GZINSPJM Using C_OPPOR
        # -------------------
        IFLGOPPLOC = [V]CST_AYES
        GZINSPJM = NewInstance C_OPPOR AllocGroup null
        GZINSPJM.TCHTOREAD = "PJM"
        # -------------------
        [L]MY_STATUS = fmet GZINSPJM.AREAD(PROJET)
        If [L]MY_STATUS >= [V]CST_AERROR Then
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
          GOK = 0
          GERR = 1
          # -------------------
          If GZINSPJM <> null Then
            FreeGroup GZINSPJM
          Endif
          Kill GZINSPJM
          # -------------------
          End
        Endif
      Endif
      # ------------------------------
      SAVACT = GACTION
      PARBOUT(1) = PROJET
      PARBOUT(2) = AZC
      FLGEXE = 1
      GACTION = "PJMACTTAS"
      Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMACTTAS","PJMACTTAS","") From GSAISIE
      AZC = PARBOUT(2)
      GACTION = SAVACT
      # ------------------------------
      If IFLGOPPLOC = [V]CST_AYES Then
        If GZINSPJM <> null Then
          FreeGroup GZINSPJM
        Endif
        Kill GZINSPJM
      Endif
    Endif
  Endif
End

Subprog IBUPJMTSK(PROJET)
Value    Char    PROJET

  If PROJET = "" Then
    Raz GBOUTS
    Raz GBOUT1
  Else
    If find("PJMACTTAS",GNAVIG(1..GPILNAV)) <> 0 Then
      Raz GBOUT1
    Endif
  Endif
End

###################################################################################################
$SEL_SELPJMTSKL
Local Integer NI
Local Integer NE
Local Integer NZ
Local Char SZLIBELLE(250)
Local Integer ITER
Local Integer ITYP
Local Char SOPPNUM(GLONPIM)
Local Char SOPPNUM1(GLONPIM)
Local Char STASCOD(GLONTAC)
Local Char PROJECTLNK(GLONOPP)
Local Char BUDGETLNK(GLONPBU)
Local Char TASKLNK(GLONTAC)
Local Integer IREADTABLE
Local Integer ITAKE

  SOPPNUM = PARAM(1)
  STASCOD = PARAM(2)
  If SOPPNUM <> "" Then
    NZ = 0
    IREADTABLE = [V]CST_ANO
    If dim(GZINSPJM) > 0 Then
      If GZINSPJM <> null and GZINSPJM.PJM(1) <> null and GZINSPJM.OPPNUM = SOPPNUM Then
        IREADTABLE = [V]CST_AYES
      Endif
    Endif
    If IREADTABLE = [V]CST_AYES Then
      For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS)
        If GZINSPJM.PJM(1).TAS(NI) <> null and find(GZINSPJM.PJM(1).TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If fmet GZINSPJM.PJM(1).TAS_IS_PARENT(GZINSPJM.PJM(1).TAS(NI).TASCOD) = [V]CST_ANO and
&            GZINSPJM.PJM(1).TAS(NI).TASSTATE <> 4 and GZINSPJM.PJM(1).TAS(NI).TASCOD <> STASCOD
&         Then
            ITAKE = [V]CST_AYES
            For NE = 1 To maxtab(GZINSPJM.PJM(1).TAS(NI).PTLNK)
              If GZINSPJM.PJM(1).TAS(NI).PTLNK(NE) <> null and find(GZINSPJM.PJM(1).TAS(NI).PTLNK(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
                IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GZINSPJM.ACTX, GZINSPJM.PJM(1).TAS(NI).PTLNK(NE).PIMOPPTASLNK, PROJECTLNK, BUDGETLNK, TASKLNK)
                If TASKLNK = STASCOD Then
                  ITAKE = [V]CST_ANO
                  Break
                Endif
              Endif
            Next NE
            If ITAKE = [V]CST_AYES Then
              NZ += 1
              If NZ >= dim(TEX)-1 Then
                Break
              Endif
              # ------------------------------
              TEX(NZ) = GZINSPJM.PJM(1).TAS(NI).TASCOD
              TEXTE(NZ) = GZINSPJM.PJM(1).TAS(NI).TASCOD - "-" - GZINSPJM.PJM(1).TAS(NI).PIMPL.PIMDESAXX
              # ------------------------------
            Endif
          Endif
        Endif
      Next NI
    Else
      Local File PJMTSK [PJTA]
      Local File PJMTSKLNK [PTLNK]
      Local File PIMPL [PIM]
      Local File ATEXTRA [AXX]
      Link [PJTA] With [F:PIM]PIM0=[F:PJTA]KEYCONCAT,
&                      [F:AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;""
&                   As [LPJTA]
&                Where [F:PJTA]OPPNUM = SOPPNUM and [F:PIM]TASSTATE <> 4
&                Order By Key KEY1=[F:PJTA]TASCOD
      # ------------------------------
      For [F:LPJTA]KEY1
        If func PJMTSK_CSTD_PROGS.IS_PARENT(GACTX, [F:PJTA]OPPNUM, [F:PJTA]TASCOD) = [V]CST_ANO Then
          ITAKE = [V]CST_AYES
          SOPPNUM1 = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GACTX, [F:PJTA]OPPNUM, [F:PJTA]TASCOD)
          Filter [PTLNK] Where [F:PTLNK]OPPNUM = [F:PJTA]OPPNUM and [F:PTLNK]PIMOPPTASLNK = SOPPNUM1
          For [PTLNK]
            ITAKE = [V]CST_ANO
            Break
          Next
          Filter [PTLNK]
          If ITAKE = [V]CST_AYES Then
            NZ += 1
            If NZ >= dim(TEX)-1 Then
              Break
            Endif
            # ------------------------------
            TEX(NZ) = [PJTA]TASCOD
            TEXTE(NZ) = [PJTA]TASCOD - [F:AXX]TEXTE
            # ------------------------------
          Endif
        Endif
      Next
    Endif
    NBTEX = NZ
    TIT = mess(189,2260,1)
  Endif
Return

VERF_SELPJMTSKL
Return

###################################################################################################
$SEL_SELPJMOPEL
Local Char SOPPNUM(GLONPIM)
Local Char STASCOD(GLONTAC)
Local Integer IOPENUM
Local Integer IOPESPLNUM
Local Integer NC
Local Integer NZ
Local Integer ITASLINE
Local Integer IOPELNK
Local Integer IREADTABLE
Local Integer ITAKE

  SOPPNUM = PARAM(1)
  STASCOD = PARAM(2)
  IOPENUM = val(PARAM(3))
  IOPESPLNUM = val(PARAM(4))
  # ------------------------------
  If SOPPNUM <> AVOID.ACHAR Then
    NZ = 0
    NE = 0
    IREADTABLE = [V]CST_ANO
    If dim(GZINSPJM) > 0 Then
      If GZINSPJM <> null and GZINSPJM.PJM(1) <> null and GZINSPJM.OPPNUM = SOPPNUM Then
        IREADTABLE = [V]CST_AYES
      Endif
    Endif
    If IREADTABLE = [V]CST_AYES Then
      ITASLINE = fmet GZINSPJM.PJM(1).TAS_GET_INDEX(STASCOD)
      IOPELNK = fmet GZINSPJM.PJM(1).TAS(ITASLINE).RTKO_GET_INDEX(IOPENUM, IOPESPLNUM)
      For NC = 1 To maxtab(GZINSPJM.PJM(1).TAS(ITASLINE).RTKO)
        If GZINSPJM.PJM(1).TAS(ITASLINE).RTKO(NC) <> null and find(GZINSPJM.PJM(1).TAS(ITASLINE).RTKO(NC).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          ITAKE = [V]CST_AYES
          If NC = IOPELNK or GZINSPJM.PJM(1).TAS(ITASLINE).RTKO(NC).OPESTA = 5 Then
            # If this is the current operation
            #    or if the operation is closed
            # => Operation will not be displayed in the list
            ITAKE = [V]CST_ANO
          Endif
          If ITAKE = [V]CST_AYES Then
            NZ += 1
            If NZ >= dim(TEX)-1 Then
              Break
            Endif
            # ------------------------------
            TEX(NZ) = num$(GZINSPJM.PJM(1).TAS(ITASLINE).RTKO(NC).OPENUM)
            TEXTE(NZ) = num$(GZINSPJM.PJM(1).TAS(ITASLINE).RTKO(NC).OPENUM) - "-" - GZINSPJM.PJM(1).TAS(ITASLINE).RTKO(NC).ROODESAXX
            # ------------------------------
          Endif
        Endif
      Next NC
    Endif
    NBTEX = NZ
    TIT = mess(977,2260,1)
  Endif
Return

$VERF_SELPJMOPEL
Return

###################################################################################################
$SEL_SELPJMBUD
Local Integer NI
Local Integer NZ
Local Char SZLIBELLE(250)
Local Integer ITER
Local Integer ITYP
Local Char SOPPNUM(GLONPIM)
Local Integer IUSABLE
Local Char SFILTER(250)

  # ------------------------------
  SOPPNUM = PARAM(1)
  IUSABLE = val(PARAM(2))
  If IUSABLE <> [V]CST_AYES and IUSABLE <> [V]CST_ANO Then
    # By default all budget will be displayed
    IUSABLE = [V]CST_ANO
  Endif
  # ------------------------------
  If SOPPNUM <> "" Then
    NZ = 0
    If dim(GZINSPJM) > 0 Then
      For NI = 1 To maxtab(GZINSPJM.PJM(1).BUD)
        If GZINSPJM.PJM(1).BUD(NI) <> null and find(GZINSPJM.PJM(1).BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If IUSABLE = [V]CST_ANO or (IUSABLE = [V]CST_AYES and GZINSPJM.PJM(1).BUD(NI).PBUSTATE <> 4 and GZINSPJM.PJM(1).BUD(NI).PBUIMP = [V]CST_AYES) Then
            NZ += 1
            If NZ >= dim(TEX)-1 Then
              Break
            Endif
            # ------------------------------
            TEX(NZ) = GZINSPJM.PJM(1).BUD(NI).PBUCOD
            TEXTE(NZ) = GZINSPJM.PJM(1).BUD(NI).PBUCOD - "-" - GZINSPJM.PJM(1).BUD(NI).PIMPL.PIMDESAXX
            # ------------------------------
          Endif
        Endif
      Next NI
    Else
      Local File PJMBUD [PJBU]
      Local File PIMPL [PIM]
      Local File ATEXTRA [AXX]
      # ------------------------------
      If IUSABLE = [V]CST_ANO Then
        SFILTER = "(1=1)"
      Else
        SFILTER = "(PBUSTATE<>4 and PBUIMP = [V]CST_AYES)"
      Endif
      # ------------------------------
      Link [PJBU] With [F:PIM]PIM0=[F:PJBU]KEYCONCAT,
&                      [F:AXX]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PIM]PIMNUM;""
&                   As [LPJBU]
&                Where [F:PJBU]OPPNUM = SOPPNUM and evalue(SFILTER)
&                Order By Key KEY1=[F:PJBU]PBUCOD
      # ------------------------------
      For [F:LPJBU]KEY1
        NZ += 1
        If NZ >= dim(TEX)-1 Then
          Break
        Endif
        # ------------------------------
        TEX(NZ) = [F:PJBU]PBUCOD
        TEXTE(NZ) = [F:PJBU]PBUCOD-[F:AXX]TEXTE
        # ------------------------------
      Next
    Endif
    NBTEX = NZ
    TIT = mess(188,2260,1)
  Endif
Return

VERF_SELPJMBUD
Return

Subprog TUNPJMBUD(AZC,PROJET)
Variable Char    AZC()
Value    Char    PROJET

Local Char VALBOUT(250) , PARBOUT(250)(1..20)
Local Char SAVACT(GLONACT)
Local Integer FLGEXE
Local Integer IFLGOPPLOC
Local Integer MY_STATUS

  If PROJET <> "" Then
    # Issue X3-99928 - 2018-07-19 by FGR : Check Authorization
    If func SUBPJMA.GET_AUTHORIZATION_GESPJM("2") = [V]CST_ANO Then
      GMESSAGE = mess(2,104,1)
      GERR = 1
      GOK = 0
      End
    Else
      IFLGOPPLOC = [V]CST_ANO
      If dim(GZINSPJM) <= 0 Then
        Global Instance GZINSPJM Using C_OPPOR
        # -------------------
        IFLGOPPLOC = [V]CST_AYES
        GZINSPJM = NewInstance C_OPPOR AllocGroup null
        GZINSPJM.TCHTOREAD = "PJM"
        # -------------------
        [L]MY_STATUS = fmet GZINSPJM.AREAD(PROJET)
        If [L]MY_STATUS >= [V]CST_AERROR Then
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
          GOK = 0
          GERR = 1
          # -------------------
          If GZINSPJM <> null Then
            FreeGroup GZINSPJM
          Endif
          Kill GZINSPJM
          # -------------------
          End
        Endif
      Endif
      # ------------------------------
      SAVACT = GACTION
      PARBOUT(1) = PROJET
      PARBOUT(2) = AZC
      FLGEXE = 1
      GACTION = "PJMACTBUD"
      Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMACTBUD","PJMACTBUD","") From GSAISIE
      AZC = PARBOUT(2)
      GACTION = SAVACT
      # ------------------------------
      If IFLGOPPLOC = [V]CST_AYES Then
        If GZINSPJM <> null Then
          FreeGroup GZINSPJM
        Endif
        Kill GZINSPJM
      Endif
    Endif
  Endif
End

Subprog IBUPJMBUD(PROJET)
Value    Char    PROJET

  If PROJET = "" Then
    Raz GBOUTS
    Raz GBOUT1
  Else
    If find("PJMACTBUD",GNAVIG(1..GPILNAV)) <> 0 Then
      Raz GBOUT1
    Endif
  Endif
End

###################################################################################################
# SELPJMPROD : PJM Products selection
# PARAM(1) : field value CUSTOMER
# PARAM(2) : field value ITMREF
$SEL_SELPJMPROD
Local Char SITMREF(GLONITM)
Local Char SCUSTOM(GLONBPC)
Local Char SZLIBELLE(GLONDCO)
Local Integer NZ
Local Integer NI

  #-----------------------
  SITMREF = PARAM(1)
  SCUSTOM = PARAM(2)
  #-----------------------
  If !clalev ([F:ITU]) : Local File ITMBPC [ITU] : Endif
  If !clalev ([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If !clalev ([F:AXX]) : Local File ATEXTRA [AXX] : Endif
  #-----------------------
  TIT = mess(378,2260,1)
  #-----------------------
  NZ = 0
  #-----------------------
  # Carefull : you have to test that the value is not existing in the TEX(..) list of values before
  If SCUSTOM <> AVOID.ACHAR Then
    #-----------------------
    Read [F:ITU]ITU0=SITMREF;SCUSTOM
    #-----------------------
    If [F:ITU]SAU <> AVOID.ACHAR Then
      If find([F:ITU]SAU,TEX(1..NZ)) = 0 Then
        NZ += 1
        TEX(NZ) = [F:ITU]SAU
        Call LECTEXTRA(SZLIBELLE, "TABUNIT", "DES", [F:ITU]SAU, "") From ATEXTRA      #--Sales Unit
        TEXTE(NZ) = [F:ITU]SAU - SZLIBELLE
      Endif
    Endif
  Endif
  #-----------------------
  Read [F:ITM]ITM0=SITMREF
  #-----------------------
  If NZ < dim(TEX)-1 Then
    If [F:ITM]SAU <> AVOID.ACHAR Then
      If find([F:ITM]SAU,TEX(1..NZ)) = 0 Then
        NZ += 1
        TEX(NZ) = [F:ITM]SAU
        Call LECTEXTRA(SZLIBELLE, "TABUNIT", "DES", [F:ITM]SAU, "") From ATEXTRA      #--Sales Unit
        TEXTE(NZ) = [F:ITM]SAU - SZLIBELLE
      Endif
    Endif
  Endif
  If NZ < dim(TEX)-1 Then
    If [F:ITM]STU <> AVOID.ACHAR Then
      If find([F:ITM]STU,TEX(1..NZ)) = 0 Then
        NZ += 1
        TEX(NZ) = [F:ITM]STU
        Call LECTEXTRA(SZLIBELLE, "TABUNIT", "DES", [F:ITM]STU, "") From ATEXTRA      #--Stock Unit
        TEXTE(NZ) = [F:ITM]STU - SZLIBELLE
      Endif
    Endif
  Endif
  #-----------------------
  #--GRID Fields
  #-----------------------
  If NZ < dim(TEX)-1 Then
    For NI = 0 To dim([F:ITM]PCU)-1
      If [F:ITM]PCU(NI) = AVOID.ACHAR Then
        Break
      Else
        If find([F:ITM]PCU(NI),TEX(1..NZ)) = 0 Then
          NZ += 1
          If NZ >= dim(TEX)-1 Then
            Break
          Endif
          TEX(NZ) = [F:ITM]PCU(NI)
          Call LECTEXTRA(SZLIBELLE, "TABUNIT", "DES", [F:ITM]PCU(NI), "") From ATEXTRA      #--Unit
          TEXTE(NZ) = [F:ITM]PCU(NI) - SZLIBELLE
        Endif
      Endif
    Next NI
  Endif
  #-----------------------
  NBTEX = NZ
Return

$VERF_SELPJMPROD
Return

###################################################################################################
# SELPJMITM : Products selection
# PARAM(1) : Task site - [M:PJMTAS0]TASFCY
$SEL_SELPJMITM
Local Char STASFCY (GLONFCY)

  # ------------------
  STASFCY = PARAM(1)
  # ------------------
  If !clalev ([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If !clalev ([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
  If !clalev ([F:AXX]) : Local File ATEXTRA [AXX] : Endif
  # ------------------
  CODFIC = "ITMMASTER"
  DEFPAG = 1
  SIZLIG = 120
  SIZCOL = 400
  #OBJET = "ITM"
  CRITERE = "[F:ITM]ITMREF>='" + VALEUR + "'"
  START = "[F:ITM]ITMREF"
  ORDRE = "[F:ITM]ITMREF"
  # ------------------
    Link [ITM] With [ITF]ITF0=[ITM]ITMREF;STASFCY,
&                   [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:ITM]ITMREF;""
&                As [NEW]
  # ------------------
  Default File [NEW]
  # ------------------
  # Define specific selection list filters:
  # Product status = ACTIVE
  CRITERE -= "& [F:ITM]ITMSTA=1"
  # Product site = TASK SITE
  CRITERE -= "& [F:ITF]STOFCY='" + STASFCY + "'"

  # Define the columns to be displayed in the selection list:
  NBCOL += 1 : COL(NBCOL) = "[F:ITM]ITMREF"               : Call TEXTFIC("ITMMASTER","ITMREF",1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"                : Call TEXTFIC("ITMMASTER","DES1AXX",1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:ITM]TCLCOD"               : Call TEXTFIC("ITMMASTER","TCLCOD",1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "mess([F:ITM]ITMSTA,246,1)"   : Call TEXTFIC("ITMMASTER","ITMSTA",1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:ITM]EANCOD"               : Call TEXTFIC("ITMMASTER","EANCOD",1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:ITM]SEAKEY"               : Call TEXTFIC("ITMMASTER","SEAKEY",1, TIT(NBCOL)) From OBJDIV
  # ------------------

Return

$VERF_SELPJMITM
Return

###################################################################################################
$SEL_SELPJMSNP
Local Integer IACTIF
Local Char SOPPNUM(GLONPIM)
Local Char SKEYEXT(GLONSNPD)
Local Char SSHOWGRP(GLONADI)
Local Char SSHOWUOM(GLONUOM)
Local Char SSHOWCUR(GLONCUR)
Local Integer ILIG

  # Issue X3-81033 - 2018-03-14 by ALMON : Limit selections to Project and or Snapshot N-1 and or N
  IACTIF = val(PARAM(1))
  SOPPNUM = PARAM(2)
  SKEYEXT = PARAM(3)
  SSHOWGRP = PARAM(4)
  SSHOWUOM = PARAM(5)
  SSHOWCUR = PARAM(6)
  # -----------------
  ILIG = 1
  CRITERE(ILIG) = "(1=1)"
  # -----------------
  Local File PJMSNPH [SNPH]
  Local File PJMSNPD [SNPD]
  Local File PIMPL [PIM]
  Local File ATEXTRA [AX3]
  Local File ATEXTRA [AX4]
  # -----------------
  Link [SNPD] With [SNPH]PSNPH0=[F:SNPD]SNPCOD,
&                  [PIM]PIM0=[F:SNPH]OPPNUM,
&                  [AX3]AXX0="PJMSNPH";"DESAXX";GLANGUE;[F:SNPD]SNPCOD;"",
&                  [AX4]AXX0="PJMSNPD";"DDESAXX";GLANGUE;[F:SNPD]KEYEXT;""
&               As [SNP_]
  # ------------------
  Default File [SNP_]
  # ------------------
  If SOPPNUM <> AVOID.ACHAR Then
    ILIG += 1
    CRITERE(ILIG) -= "& [F:SNPH]OPPNUM='" + SOPPNUM + "'"
  Endif
  If SKEYEXT <> AVOID.ACHAR Then
    ILIG += 1
    CRITERE(ILIG) -= "& [F:SNPD]KEYEXT <> '" + SKEYEXT + "'"
  Endif
  If SSHOWGRP <> AVOID.ACHAR Then
    ILIG += 1
    CRITERE(ILIG) -= "& [F:SNPH]SHOWGRP = '" + SSHOWGRP + "'"
  Endif
  If SSHOWUOM <> AVOID.ACHAR Then
    ILIG += 1
    CRITERE(ILIG) -= "& [F:SNPH]UOM = '" + SSHOWUOM + "'"
  Endif
  If SSHOWCUR <> AVOID.ACHAR Then
    ILIG += 1
    CRITERE(ILIG) -= "& [F:SNPH]CUR = '" + SSHOWCUR + "'"
  Endif
  If IACTIF = [V]CST_AYES Then
    ILIG += 1
    CRITERE(ILIG) -= "& [F:PIM]PIMSTA = " + num$([V]CST_AYES)
  Endif
  # -----------------
  # Define columns to display in the list
  NBCOL += 1 : COL(NBCOL) = "[F:SNPD]KEYEXT"                         : Call TEXTFIC("PJMSNPD",  "KEYEXT",     1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:SNPH]OPPNUM"                         : Call TEXTFIC("PJMSNPH",  "OPPNUM",     1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:SNPD]SNPCOD"                         : Call TEXTFIC("PJMSNPD",  "SNPCOD",     1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:AX3]TEXTE"                           : Call TEXTFIC("PJMSNPH",  "DESAXX",     1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:AX4]TEXTE"                           : Call TEXTFIC("PJMSNPD",  "DDESAXX",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:SNPD]SNPDDTECRE"                     : Call TEXTFIC("PJMSNPD",  "SNPDDTECRE", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:SNPD]SNPSEQ"                         : Call TEXTFIC("PJMSNPD",  "SNPSEQ",     1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:SNPH]SHOWGRP"                        : Call TEXTFIC("PJMSNPH",  "SHOWGRP",    1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:SNPH]UOM"                            : Call TEXTFIC("PJMSNPH",  "UOM",        1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:SNPH]CUR"                            : Call TEXTFIC("PJMSNPH",  "CUR",        1, TIT(NBCOL)) From OBJDIV
  # -----------------
  CODFIC = "SNP_"
  DEFPAG = 1                 # To manage "next pages" by supervisor
  START = "KEYEXT"           # Return value. Allow to not have it at the first place on the object
  ORDRE = "[F:SNPD]KEYEXT"   # Allow to define a sort order which is not the object default one
  # -----------------
Return

$VERF_SELPJMSNP
  # Issue X3-81033 - 2018-03-14 by ALMON
Return

###################################################################################################
$SEL_SELPJMFCPY
# PARAM(1) : complementary filter
# PARAM(2) : company

  # Issue X3-85280 - 2018-04-19 by FGR/TEJAC
  # ------------------------------------
  If !clalev ([F:FCY]) : Local File FACILITY [FCY] : Endif
  # ------------------------------------
  CODFIC = "FACILITY"
  DEFPAG = 1
  SIZLIG = 120
  SIZCOL = 400
  CRITERE = "[F:FCY]LEGCPY = '" + PARAM(2) + "'"
  START = "[F:FCY]FCY"
  ORDRE = "[F:FCY]FCY"
  # ------------------------------------
  CRITERE -= "& [F:FCY]FCY>='" + VALEUR + "'"
  If PARAM(1) <> AVOID.ACHAR Then
    CRITERE -= "& (" + PARAM(1) + ")"
  Endif
  # ------------------------------------
  TIT = mess(1070,2260,1)
  Default File [FCY]
  # ------------------------------------
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "FCY"                                    : TIT(NBCOL) = mess(3,45,1)
  NBCOL += 1 : COL(NBCOL) = "FCYNAM"                                 : TIT(NBCOL) = mess(36,105,1)
  NBCOL += 1 : COL(NBCOL) = "LEGCPY"                                 : TIT(NBCOL) = mess(2,45,1)
  NBCOL += 1 : COL(NBCOL) = "CRY"                                    : TIT(NBCOL) = mess(1576,10031,1)
Return

$VERF_SELPJMFCPY
  # Issue X3-85280 - 2018-04-19 by TEJAC
Return

###################################################################################################
Subprog TUNPJM(AZC)
Variable Char    AZC()

  Call OBJET("PJM", AZC, "") From GOBJET
  Gosub AFF From GSAISIE
End

###################################################################################################
Subprog TUNCRM(AZC)
Variable Char    AZC()

  Call OBJET("OPP", AZC, "") From GOBJET
  Gosub AFF From GSAISIE
End

###################################################################################################
Subprog TUNPJMOPE(PROJET, TAC, OPENUM, OPESPLNUM)
Value    Char    PROJET
Value    Char    TAC
Value    Integer OPENUM
Value    Integer OPESPLNUM

Local Char VALBOUT(250), PARBOUT(250)(1..20)
Local Char SAVACT(GLONACT)
Local Integer FLGEXE
Local Integer IFLGOPPLOC
Local Integer MY_STATUS
Local Integer ITASLINE
Local Integer IOPELINE

  If PROJET <> "" and TAC <> "" and OPENUM <> 0 and OPESPLNUM <> 0 Then
    # Issue X3-99928 - 2018-07-19 by FGR : Check Authorization
    If func SUBPJMA.GET_AUTHORIZATION_PJMACTTAS("6") = [V]CST_ANO Then
      GMESSAGE = mess(2,104,1)
      GERR = 1
      GOK = 0
      End
    Else
      IFLGOPPLOC = [V]CST_ANO
      If dim(GZINSPJM) <= 0 Then
        Global Instance GZINSPJM Using C_OPPOR
        # -------------------
        IFLGOPPLOC = [V]CST_AYES
        GZINSPJM = NewInstance C_OPPOR AllocGroup null
        GZINSPJM.TCHTOREAD = "PJM"
        # -------------------
        [L]MY_STATUS = fmet GZINSPJM.AREAD(PROJET)
        If [L]MY_STATUS >= [V]CST_AERROR Then
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
          GOK = 0
          GERR = 1
          # -------------------
          If GZINSPJM <> null Then
            FreeGroup GZINSPJM
          Endif
          Kill GZINSPJM
          # -------------------
          End
        Endif
      Endif
      # ------------------------------
      SAVACT = GACTION
      PARBOUT(1) = PROJET
      PARBOUT(2) = TAC
      PARBOUT(3) = num$(OPENUM)
      PARBOUT(4) = num$(OPESPLNUM)
      FLGEXE = 1
      GACTION = "PJMACTOPE"
      # ------------------------------
      ITASLINE = fmet GZINSPJM.PJM(1).TAS_GET_INDEX(PARBOUT(2))
      If ITASLINE < 1 Then
        GMESSAGE = func AFNC.MES1(mess(245,2260,1), PARBOUT(2))
        GOK = 0
        GERR = 1
        End
      Endif
      # ------------------------------
      IOPELINE = fmet GZINSPJM.PJM(1).TAS(ITASLINE).RTKO_GET_INDEX(val(PARBOUT(3)), val(PARBOUT(4)))
      If IOPELINE < 1 Then
        GMESSAGE = func AFNC.MES2(mess(246,2260,1), val(PARBOUT(3)), val(PARBOUT(4)))
        GOK = 0
        GERR = 1
        End
      Endif
      Call SAISIE_CHAR(VALBOUT,PARBOUT,"OPJMACTOPE","PJMACTOPE","") From GSAISIE
      PROJET    = PARBOUT(1)
      TAC       = PARBOUT(2)
      OPENUM    = val(PARBOUT(3))
      OPESPLNUM = val(PARBOUT(4))
      GACTION   = SAVACT
      # ------------------------------
      If IFLGOPPLOC = [V]CST_AYES Then
        If GZINSPJM <> null Then
          FreeGroup GZINSPJM
        Endif
        Kill GZINSPJM
      Endif
    Endif
  Endif
End

###################################################################################################
Subprog IBUPJMOPE(PROJET, TAC, OPENUM, OPESPLNUM, BOUTONS)
Value    Char    PROJET
Value    Char    TAC
Value    Integer OPENUM
Value    Integer OPESPLNUM
Value    Char    BOUTONS     # Issue X3-99928 - 2018-08-24 by FGR

  If PROJET = "" or TAC = "" or OPENUM = 0 or OPESPLNUM = 0 or GREP <> "" Then
    #Raz GBOUT1                                  # Issue X3-99928 - 2018-08-24 by FGR
    Assign "GBOUT" + BOUTONS With AVOID.ACHAR    # Issue X3-99928 - 2018-08-24 by FGR
  Else
    If find("PJMACTOPE",GNAVIG(1..GPILNAV)) <> 0 Then
      #Raz GBOUT1                                # Issue X3-99928 - 2018-08-24 by FGR
      Assign "GBOUT" + BOUTONS With AVOID.ACHAR  # Issue X3-99928 - 2018-08-24 by FGR
    Endif
  Endif
  # Issue X3-99928 - 2018-08-24 by FGR : BEGIN
  If evalue("GBOUT" + BOUTONS) <> AVOID.ACHAR and GFCY <> AVOID.ACHAR Then
    If func SUBPJMA.GET_AUTHORIZATION_PJMACTTAS("6") = [V]CST_ANO Then
      Assign "GBOUT" + BOUTONS With AVOID.ACHAR
    Endif
  Endif
  # Issue X3-99928 - 2018-08-24 by FGR : END
End

###################################################################################################
Subprog IBUPIM(AZC)
Variable Char    AZC()

  If AZC <> AVOID.ACHAR Then
    # --------------------------------------------
    Local File PIMPL [PIM]
    # --------------------------------------------
    Read [PIM]PIM0=AZC
    If !fstat Then
      Case [F:PIM]PIMTYP
        When 1
          # CRM
          GBOUT1 = mess(468,2260,1)
          Raz GBOUT2
        When 2
          # PJM mixte
          GBOUT1 = mess(469,2260,1)
          Raz GBOUT2
        When 3
          # PJM mixte
          GBOUT1 = mess(469,2260,1)
          GBOUT2 = mess(468,2260,1)
        When 4
          # Budget
          GBOUT1 = mess(470,2260,1)
          Raz GBOUT2
        When 5, 6, 7
          # Task
          GBOUT1 = mess(471,2260,1)
          Raz GBOUT2
        When Default
          Raz GBOUT1
          Raz GBOUT2
      Endcase
    Endif
  Else
    Raz GBOUT1
    Raz GBOUT2
  Endif
  # --------------------------------------------
End

###################################################################################################
Subprog TUNPIM(AZC)
Variable Char    AZC()

  Local File PIMPL [PIM]
  # --------------------------------------------
  Read [PIM]PIM0=AZC
  If !fstat Then
    Case [F:PIM]PIMTYP
      When 1
        # CRM
        Call TUNCRM(AZC)
      When 2, 3
        # PJM mixte
        Call TUNPJM(AZC)
      When 4
        # Budget
        Call TUNPJMBUD(AZC, [F:PIM]OPPNUM)
      When 5, 6, 7
        # Task
        Call TUNPJMTSK(AZC, [F:PIM]OPPNUM)
    Endcase
  Endif
  # --------------------------------------------
End

###################################################################################################
$SEL_SELPJMPAF
Local Integer NI
Local Integer NZ
Local Char SOPPNUM(GLONPIM)
Local Integer IREADTABLE

  SOPPNUM = PARAM(1)
  If SOPPNUM <> "" Then
    # ------------------------------
    Local File ATEXTRA [AXX]
    # ------------------------------
    NZ = 0
    IREADTABLE = [V]CST_ANO
    If dim(GZINSPJM) > 0 Then
      If GZINSPJM <> null and GZINSPJM.PJM(1) <> null Then
        IREADTABLE = [V]CST_AYES
      Endif
    Endif
    # ------------------------------
    If IREADTABLE = [V]CST_AYES Then
      For NI = 1 To maxtab(GZINSPJM.PJM(1).PAF)
        If GZINSPJM.PJM(1).PAF(NI) <> null and find(GZINSPJM.PJM(1).PAF(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          NZ += 1
          If NZ >= dim(TEX)-1 Then
            Break
          Endif
          # ------------------------------
          Read [F:AXX]AXX0="AUTILIS";"INTUSR";GLANGUE;GZINSPJM.PJM(1).PAF(NI).PAFCLB;AVOID.ACHAR
          If fstat Then
            Raz [F:AXX]
          Endif
          # ------------------------------
          TEX(NZ) = GZINSPJM.PJM(1).PAF(NI).PAFCLB
          TEXTE(NZ) = GZINSPJM.PJM(1).PAF(NI).PAFCLB - "-" - [F:AXX]TEXTE - "-" - GZINSPJM.PJM(1).PAF(NI).PAFROL
          # ------------------------------
        Endif
      Next NI
    Else
      Local File PJMAFF [PJAFF]
      Local File PIMPL [PIM]
      Link [PJAFF] With [F:PIM]PIM0=[F:PJAFF]OPPNUM,
&                      [F:AXX]AXX0="AUTILIS";"INTUSR";GLANGUE;[PJAFF]PAFCLB;AVOID.ACHAR
&                   As [LPAFF]
&                Where [F:PJAFF]OPPNUM = SOPPNUM
&                Order By Key KEY1=[F:PJAFF]PAFCLB
      # ------------------------------
      For [F:LPAFF]KEY1
        NZ += 1
        If NZ >= dim(TEX)-1 Then
          Break
        Endif
        # ------------------------------
        TEX(NZ) = [F:LPAFF]PAFCLB
        TEXTE(NZ) = [F:LPAFF]PAFCLB - "-" - [F:AXX]TEXTE - "-" - [F:LPAFF]PAFROL
        # ------------------------------
      Next
    Endif
    # ------------------------------
    NBTEX = NZ
    TIT =  mess(510,2260,1)
  Endif
Return

$VERF_SELPJMPAF
Return

###################################################################################################
$SEL_SELPJTEOPE
Local Integer NI
Local Integer NZ
Local Integer IREADTABLE
Local Char SPJT(GLONPJT)
Local Char SPROJECT(GLONOPP)
Local Char SBUDGET(GLONPBU)
Local Char STASK(GLONTAC)
Local Char SROODESAXX(GLONDES)

  SPJT = PARAM(1)
  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, SPJT, SPROJECT, SBUDGET, STASK)
  If SPROJECT <> AVOID.ACHAR Then
    # ------------------------------
    Local File PJMTSKOPE [PTKO]
    # ------------------------------
    Filter [PTKO] Where [F:PTKO]OPPNUM = SPROJECT and [F:PTKO]TASCOD = STASK
    For [PTKO]
      NZ += 1
      If NZ >= dim(TEX)-1 Then
        Break
      Endif
      # ------------------------------
      # Issue X3-68131 - 2018-02-12 by FGR : add context : BEGIN
      #SROODESAXX = func PJMTSKOPE_CSTD_PROGS.GET_ROODESAXX(GACTX, func PJMTSKOPE_CSTD_PROGS.GET_KEYCONCAT_VARIABLES([F:PTKO]OPPNUM, [F:PTKO]TASCOD, [F:PTKO]OPENUM, [F:PTKO]OPESPLNUM))
      SROODESAXX = func PJMTSKOPE_CSTD_PROGS.GET_ROODESAXX(GACTX, func PJMTSKOPE_CSTD_PROGS.GET_KEYCONCAT_VARIABLES(GACTX, [F:PTKO]OPPNUM, [F:PTKO]TASCOD, [F:PTKO]OPENUM, [F:PTKO]OPESPLNUM))
      # Issue X3-68131 - 2018-02-12 by FGR : add context : END
      TEX(NZ) = num$([F:PTKO]OPENUM)
      TEXTE(NZ) = func AFNC.MES2(mess(532,2260,1), num$([F:PTKO]OPENUM), SROODESAXX)
    Next
    Filter [PTKO]
    # ------------------------------
    NBTEX = NZ
    TIT = func AFNC.MES2(mess(531,2260,1), SPROJECT, STASK)
  Endif
Return

$VERF_SELPJTEOPE
Return

###################################################################################################
Funprog SELACTIVEPIM()

Local Char SSTRING(250)
Local Char ZCPY(GLONCPY)

  # Called by data type PIM
  SSTRING = "((PIMTYP=1 and PIMSTA=2) or ((PIMTYP=2 or PIMTYP=3) and OPPSTATE<>4))"
  If dim(GPIMLSTFCY) > 0 and GPIMLSTFCY <> AVOID.ACHAR Then
    ZCPY = fmet GACTX.ACACHE.AFCY.AGETVALCHAR(GPIMLSTFCY, "LEGCPY")
    SSTRING += "&CPY='" + ZCPY + "'"
  Endif
End SSTRING

