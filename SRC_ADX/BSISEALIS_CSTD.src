#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
    Case [L]CURPTH
        When ""
            Case [L]AEVENT
                When "AREAD_AFTER"            : Gosub EVENT_AREAD_AFTER
                When "AINSERT_CONTROL_BEFORE" : Gosub EVENT_CONTROL_BEFORE
                When "AUPDATE_CONTROL_BEFORE" : Gosub EVENT_CONTROL_BEFORE
            Endcase
        When "LINES"
            Case [L]AEVENT
                When "AREAD_AFTER"            : Gosub EVENT_AREAD_AFTER_LINES
            Endcase
    Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
    Case [L]CURPRO
        When "CPY" : Gosub PROPERTY_CPY
        When "BAN" : Gosub PROPERTY_BAN
    Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

########################################################################################################################

$EVENT_AREAD_AFTER
    If this.LEG = "" Then
        Local File COMPANY [CPY]
        Read [F:CPY]CPY0 = this.CPY
        If fstat = 0 Then
            this.LEG = [F:CPY]LEG
        Else
# 2017-05-17 DNE MODIF BEGIN
            ASTATUS = fmet this.ASETERROR("CPY", this.CPY - mess(23,100,1), [V]CST_AERROR) # 'Record does not exist'
# 2017-05-17 DNE MODIF ORIG
#            ASTATUS = fmet this.ASETERROR("CPY", "Failed to read COMPANY", [V]CST_AERROR)
# 2017-05-17 DNE MODIF END
        Endif
        LogicClose File [CPY]
    Endif
Return

$EVENT_AREAD_AFTER_LINES
    If this.APARENT.LEG = "" Then
        Local File COMPANY [CPY]
        Read [F:CPY]CPY0 = this.APARENT.CPY
        If fstat = 0 Then
            this.APARENT.LEG = [F:CPY]LEG
        Else
 # 2017-05-17 DNE MODIF BEGIN
           ASTATUS = fmet this.ASETERROR("CPY", this.CPY - mess(23,100,1), [V]CST_AERROR) # 'Record does not exist'
# 2017-05-17 DNE MODIF ORIG
#           ASTATUS = fmet this.ASETERROR("CPY", "Failed to read COMPANY", [V]CST_AERROR)
# 2017-05-17 DNE MODIF END
        Endif
        LogicClose File [CPY]
    Endif
    this.LEG = this.APARENT.LEG
Return

$EVENT_CONTROL_BEFORE
    Local Integer I, J, N
    [L]N = 0

    # loop through all lines
    For [L]I = 1 To maxtab(this.LINES)
        If this.LINES([L]I) <> null
&           and this.LINES([L]I).ASTALIN <> [V]CST_ADEL
&           and this.LINES([L]I).ASTALIN <> [V]CST_ANEWDEL
&       Then
            [L]N += 1
            If this.LINES([L]I).AORDER  <> this.LINES([L]I).LIN Then
                # delete the line
                ASTATUS = fmet this.ADELLINE("LINES", this.LINES([L]I).AORDER)
                # add new line
                [L]J = fmet this.ADDLINE("LINES", this.LINES([L]I).AORDER)
                If [L]J <> [V]CST_ANOTDEFINED Then
                    # copy contents
                    this.LINES([L]J).CPY       = this.CPY
                    this.LINES([L]J).FILFMT    = this.FILFMT
                    this.LINES([L]J).BAN       = this.BAN
                    this.LINES([L]J).LEG       = this.LEG
                    this.LINES([L]J).LIN       = this.LINES([L]I).AORDER
                    this.LINES([L]J).SEAPAYREF = this.LINES([L]I).SEAPAYREF
                    this.LINES([L]J).SEABPRREF = this.LINES([L]I).SEABPRREF
                    this.LINES([L]J).SEAOTH    = this.LINES([L]I).SEAOTH
                    this.LINES([L]J).SEAAMT    = this.LINES([L]I).SEAAMT
                    this.LINES([L]J).DENCOD    = this.LINES([L]I).DENCOD
                    this.LINES([L]J).FCY       = this.LINES([L]I).FCY
                    this.LINES([L]J).COA       = this.LINES([L]I).COA
                    this.LINES([L]J).ACC       = this.LINES([L]I).ACC
                    this.LINES([L]J).BPR       = this.LINES([L]I).BPR
                    this.LINES([L]J).BPRSAC    = this.LINES([L]I).BPRSAC
                    this.LINES([L]J).ACCSAC    = this.LINES([L]I).ACCSAC
                    this.LINES([L]J).VAT       = this.LINES([L]I).VAT
                    this.LINES([L]J).BPAINV    = this.LINES([L]I).BPAINV
                    this.LINES([L]J).DSP       = this.LINES([L]I).DSP
                    this.LINES([L]J).DES       = this.LINES([L]I).DES
                Endif
            Endif
        Endif
    Next [L]I
    If [L]N = 0 Then
        ASTATUS = fmet this.ASETERROR("", mess(32,7703,1), [V]CST_AERROR) # 'Detail lines are required.'
    Endif
Return

########################################################################################################################

$PROPERTY_CPY
    Case [L]ARULE
        When "PROPAGATE" : Gosub PROPERTY_CPY_PROPAGATE
    Endcase
Return

$PROPERTY_BAN
    Case [L]ARULE
        When "CONTROL" : Gosub CHECK_BAN_BELONGS_TO_CPY
    Endcase
Return

########################################################################################################################

$PROPERTY_CPY_PROPAGATE
    Local File COMPANY [CPY]
    Read [F:CPY]CPY0 = this.CPY
    If fstat = 0 Then
        this.LEG = [F:CPY]LEG
    Else
# 2017-05-17 DNE MODIF BEGIN
        ASTATUS = fmet this.ASETERROR("CPY", this.CPY - mess(23,100,1), [V]CST_AERROR) # 'Record does not exist'
# 2017-05-17 DNE MODIF ORIG
#        ASTATUS = fmet this.ASETERROR("CPY", "Failed to read COMPANY", [V]CST_AERROR)
# 2017-05-17 DNE MODIF END
    Endif
    LogicClose File [CPY]
Return

$CHECK_BAN_BELONGS_TO_CPY
    If this.CPY = "" or this.BAN = "" Then
        Return
    Endif

    Local File BANK [BAN]

    If [F:BAN]BAN <> this.BAN Then
        Read [F:BAN]BAN0 = this.BAN
        If fstat
            ASTATUS = fmet this.ASETERROR("BAN", this.BAN - mess(23,100,1), [V]CST_AERROR) # 'Record does not exist'
            Return
        Endif
    Endif

    If [F:BAN]CPY <> this.CPY Then
        ASTATUS = fmet this.ASETERROR("BAN", mess(12,117,1), [V]CST_AERROR) # 'Bank account not held by company'
        Return
    Endif

    LogicClose File [BAN]
Return

########################################################################################################################

