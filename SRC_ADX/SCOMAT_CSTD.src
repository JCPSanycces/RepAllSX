# Class SCOMAT_CSTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#  Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "CPNITMDES" :
      Case [L]ARULE
        When "GET"     : Gosub CPNITMDES_GET
      Endcase
    When "AVAQTY" :
      Case [L]ARULE
        When "GET"     : Gosub AVAQTY_GET
      Endcase
    When "TYPQTY" :
      Case [L]ARULE
        When "GET"     : Gosub TYPQTY_GET
      Endcase
  Endcase
Return

#######################################################################################
$CPNITMDES_GET
  # Get item description
  Call LECTEXTRA_SYR(this,AVOID.ACHAR,this.CPNITMDES,"ITMMASTER", "DES1AXX", this.CPNITMREF, AVOID.ACHAR) From ATEXTRA
Return

#######################################################################################
$AVAQTY_GET
#  # Calculate available quantity
#  # The subprogram to calculate the available quantity has not yet been rewritten for Syracuse.
#  # When it becomes available this logic will need to be updated and the column will need to be
#  # added back to the Materials grid in the representation. ROSCH July 2013
Return

#######################################################################################
$TYPQTY_GET
  # Assign quantity type since it is not in the file
  this.TYPQTY = 1   # 1 = Active
Return

