#<AdxTL>@(#)3.0.0.0 $Revision$
# Historique des prix de revient de fabrication
# Attention : 2è objet sur la table MFGCOST
##################################################
$ACTION
Case ACTION
 When "LIENS"       : Gosub LIENS
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "FILTRE"      : Gosub FILTRE
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "EXEBOUT"     : Gosub EXEBOUT
 When "AFFMASK"     : Gosub AFFMASK
 When "FERME" : GTEST=0
 When Default
Endcase
Return

$OUVRE
Local Char CRI_FLT(250)(3)
Local Mask MFCDET
Local Mask CRITHIM [HIMC]
Local File MFGCOST [MFC2] :# pour les lignes
If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
If !clalev([F:MFG]) : Local File MFGHEAD    [MFG] : Endif     # hcb 74989

Return

$OUVRE_BOITE
Local Integer I
For I=0 To 3
    [M:HIMC]MFCTYPSEL(I) = 2
Next
Return

$FILTRE
# Si l'objet est appelé par programme (depuis Consult PRF)
# d'après la fonction appelante, filtrer les types de MFGCOST
If GFLTITM <> "" : # (positionnée avant le call OBJET)
    FILTSUP = "[F]ITMREF = GFLTITM"
    If GFONC1 = "MFCP"
      FILTSUP += " & MFCTYP<4"
    Else
      FILTSUP += " & MFCTYP=4"
    Endif
Endif
If GFLTFCY <> "" : # (positionnée avant le call OBJET)
  FILTSUP += " & [F]STOFCY = GFLTFCY"
Endif
Return

$SETBOUT
Call VIREBOUT(CHAINE,"CMDAH") From GOBJET
Return

$EXEBOUT

If BOUT="S" & mkstat = 99
    Gosub LIENS
    Affzo [HIM0]
    Affzo [HIM1]
Endif
Return

$LIENS
[M:HIM0] = [M:HIMC]
Local Integer I
Read [ITM]ITM0 = [M:HIM0]ITMREF
If !fstat
   [M:HIM0]STU    = [F:ITM]STU
   [M:HIM0]TCLCOD = [F:ITM]TCLCOD
   [M:HIM0]ITMSTA = [F:ITM]ITMSTA
   [M:HIM0]BRDCOD = [F:ITM]BRDCOD
Endif

Raz [M:HIM1]
# Filtrer la table et charger le tableau  << rajouter tri par type ? 140
# Selon les types de cout STD et BUD, on ne filtre pas sur l'année

If [M:HIM0]TRI = 0 [M:HIM0]TRI = 1 : Endif
If [M:HIM0]SENS = 0 [M:HIM0]SENS = 2 : Endif

Raz CRI_FLT, I
Call ADDCRIT(CRI_FLT,I,"CRI_FLT","STOFCY=[M:HIM0]STOFCY&ITMREF=[M:HIM0]ITMREF","&") From GOBJSUB
If [M]DATSTR <> [0/0/0]
    Call ADDCRIT(CRI_FLT,I,"CRI_FLT","MFCDAT>=[M:HIM0]DATSTR","&") From GOBJSUB
Endif
If [M]DATEND <> [0/0/0]
    Call ADDCRIT(CRI_FLT,I,"CRI_FLT","MFCDAT<=[M:HIM0]DATEND","&") From GOBJSUB
Endif
# d'après la fonction appelante, filtrer les types de MFGCOST (140)
If GFLTITM <> ""          # (positionnée avant le call OBJET)
    If GFONC1 = "MFCP"
      Call ADDCRIT(CRI_FLT,I,"CRI_FLT","MFCTYP<4","&") From GOBJSUB
    Else
      Call ADDCRIT(CRI_FLT,I,"CRI_FLT","MFCTYP=4","&") From GOBJSUB
    Endif
Endif
If find([M:HIM0]MFCTYPSEL,2)>0
    # "find(MFCTYP,x,y)"
    Call ADDCRIT(CRI_FLT,I,"CRI_FLT","find(MFCTYP"+sigma(0,3,string$([M:HIM0]MFCTYPSEL(indcum)=2,","+num$(indcum+1)))+")>0","&") From GOBJSUB
Endif

If [M:HIM0]SENS = 1
  Case [M:HIM0]TRI
   When 1
     Filter [MFC2] Where evalue(CRI_FLT)  Order By MFCDAT
   When 2
     Filter [MFC2] Where evalue(CRI_FLT)  Order By VCRNUM
   When 3
     Filter [MFC2] Where evalue(CRI_FLT)  Order By CSTTOT
   When 4
     Filter [MFC2] Where evalue(CRI_FLT)  Order By CPLRIO
   When 5
     Filter [MFC2] Where evalue(CRI_FLT)  Order By MFCTYP
   When 6
     Filter [MFC2] Where evalue(CRI_FLT)  Order By CPLQTY
  Endcase
Elsif [M:HIM0]SENS = 2
  Case [M:HIM0]TRI
   When 1
     Filter [MFC2] Where evalue(CRI_FLT)  Order By MFCDAT Desc
   When 2
     Filter [MFC2] Where evalue(CRI_FLT)  Order By VCRNUM Desc
   When 3
     Filter [MFC2] Where evalue(CRI_FLT)  Order By CSTTOT Desc
   When 4
     Filter [MFC2] Where evalue(CRI_FLT)  Order By CPLRIO Desc
   When 5
     Filter [MFC2] Where evalue(CRI_FLT)  Order By MFCTYP Desc
   When 6
     Filter [MFC2] Where evalue(CRI_FLT)  Order By CPLQTY Desc
  Endcase
Endif

# Issue 111084 - 2015-12-16 by BEEBE : get the (max) dimension of the table screen
Local Integer MAXOCC : MAXOCC=dim([M:HIM1]VCRNUM)

If [M]TRI<> 0 & [M]SENS <> 0
  [M:HIM1]NBLIG = 0
  nolign = 0
  For [MFC2]
     # Issue 111084 - 2015-12-16 by BEEBE : when max dimension then break before cancel with syntaxerror
     If nolign < MAXOCC
        nolign += 1
     Else
        Call ECR_TRACE(mess(649,199,1),0) From GESECRAN # Issue 111084 - 2015-12-21 by BEEBE : new message, activity code NHI will be used
        Break
     Endif
     [M:HIM1] = [F:MFC2]
# hcb 74989 deb
     If [F:MFG]MFGNUM <> [M:HIM1]VCRNUM(nolign-1)
        Read [MFG]MFG0=  [M:HIM1]VCRNUM(nolign-1)
        If fstat
           Raz [F:MFG]
        Endif
     Endif
     [M:HIM1]CPLQTY(nolign-1) = [F:MFG]CPLQTY
     [M:HIM1]EXTQTY(nolign-1) = [F:MFG]EXTQTY
# hcb 74989 fin
     [M:HIM1]TOTWITOVE(nolign-1) = [M:HIM1]CSTTOT(nolign-1) + [M:HIM1]OVETOT(nolign -1)
  Next
  [M:HIM1]NBLIG = nolign
  Filter [MFC2] : # pour annuler le filtre
#  "Pas de fiche selectionnée"
  If [M:HIM1]NBLIG = 0
     Call MESSAGE(mess(99,100,1)) From GESECRAN
  Endif
Endif

[M:HIM2]MATFLG = 2
[M:HIM2]MACFLG = 2
[M:HIM2]LABFLG = 2
[M:HIM2]SCOFLG = 2
[M:HIM2]INVDTAFLG=2
[M:HIM2]OVEFLG = 2
Gosub CHARG_GRAPHE From SUBHIMG
Return

$AFFMASK
#MAE, 1/04/08, en débranchement depuis article et article site,
#ALIMENTATION des clés pour avoir uniquement ceux de l'article
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM", "GESITF")
        If find(GNAVIG(GPILNAV-1),"GESITM")
            [M:HIM0]ITMREF=[M:ITM0]ITMREF
            Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
            [M:HIM0]STOFCY=GFCY
        Else If find(GNAVIG(GPILNAV-1),"GESITF")
            [M:HIM0]ITMREF=[M:ITF0]ITMREF
            [M:HIM0]STOFCY=[M:ITF0]STOFCY
            Endif
        Endif
        Filter [MFC2] Where STOFCY=[M:HIM0]STOFCY
&                & ITMREF=[M:HIM0]ITMREF
        Read [MFC2]MFC0 First

    If fstat = 0
#          [M]VCRTYP = [F:MFC2]VCRTYP
          [M]MFCTYP = [F:MFC2]MFCTYP
#          [M]UID = [F:MFC2]UID
       Endif

        CLE1=[M]ITMREF
        CLE2(0)=[M]STOFCY
        CLE2(1)=num$([F:MFC2]VCRTYP)
        CLE2(2)=[F:MFC2]VCRNUM
        CLE2(3)=num$([F:MFC2]VCRLIN)
        CLE2(4)=num$([F:MFC2]MFCTYP)
        CLE2(5)=num$([F:MFC2]UID)
    Endif
Endif
Return


$APRES_MODIF
# (re)charger le tableau quand une des zones du 1er bloc est modifiée.
# OK= -1 pour ne pas passer en mode modif  et éviter mkstat=1 du GOBJSUB
# CCC (21/10/05) On affecte la nouvelle valeur dans l'écran HIMC (critères) car un transclasse est fait dans $LIENS
If [M]TRI=0 | [M]SENS = 0 : Return : Endif
Case COUZON
 When "ITMREF"
     If [M:HIM0]STOFCY="" : Return : Endif
     [M:HIM0]ITMREF = zc
     OK = -1
     Gosub LIENS   :# relire les détails et charger l'écran
     Affzo [HIM1]
 When "STOFCY"
     [M:HIM0]STOFCY = zc
     OK = -1
     Gosub LIENS   :# relire les détails et charger l'écran
     Affzo [HIM1]
 When "DATSTR"
     [M:HIMC]DATSTR = zc
     OK = -1
     Gosub LIENS   :# relire les détails et charger l'écran
     Affzo [HIM1]
 When "DATEND"
     [M:HIMC]DATEND = zc
     OK = -1
     Gosub LIENS   :# relire les détails et charger l'écran
     Affzo [HIM1]
 When "TRI"
     [M:HIMC]TRI = zc
     OK = -1
     Gosub LIENS   :# relire les détails et charger l'écran
     Affzo [HIM1]
 When "SENS"
     [M:HIMC]SENS = zc
     OK = -1
     Gosub LIENS   :# relire les détails et charger l'écran
     Affzo [HIM1]

    When "MATFLG"
        [M:HIM2]MATFLG = zc
        OK = -1
        Gosub CHARG_GRAPHE From SUBHIMG
    When "MACFLG"
        [M:HIM2]MACFLG = zc
        OK = -1
        Gosub CHARG_GRAPHE From SUBHIMG
    When "LABFLG"
        [M:HIM2]LABFLG = zc
        OK = -1
        Gosub CHARG_GRAPHE From SUBHIMG
    When "SCOFLG"
        [M:HIM2]SCOFLG = zc
        OK = -1
        Gosub CHARG_GRAPHE From SUBHIMG
    When "INVDTAFLG"
        [M:HIM2]INVDTAFLG = zc
        OK = -1
        Gosub CHARG_GRAPHE From SUBHIMG
    When "OVEFLG"
        [M:HIM2]OVEFLG = zc
        OK = -1
        Gosub CHARG_GRAPHE From SUBHIMG

 When Default
Endcase
Return

########################################

Subprog AS_NBLIG
GBOUT1 = mess(65,198,1) : # Détails
GBOUT2 = mess(166,198,1): # Ordre de fabrication
GBOUT3 = mess(473,198,1): # Subcontract Order

  #112093.sn MJH 22/12/2016
  #We only want to show either the work order or the subcontract order
  If [M:HIM1]VCRTYP(nolign-1) = 36
    Raz GBOUT2
  Else
    Raz GBOUT3
  Endif
  #112093.en MJH 22/12/2016

End

Subprog B1_NBLIG
Read [MFC]MFC0 = [M:HIM0]STOFCY;[M:HIM0]ITMREF;[M:HIM1]VCRTYP(nolign-1);[M:HIM1]VCRNUM(nolign-1);[M:HIM1]VCRLIN(nolign-1);[M:HIM1]MFCTYP(nolign-1);0
End

Subprog AV_CUR(VALEUR)
Variable Char     VALEUR
Call GETDEV([M]STOFCY) From DEVSUB
VALEUR = [F:TCU]CUR
End
########################################

Subprog D_SENS(VALEUR)
Variable Integer  VALEUR
If [M]TRI = 1 : VALEUR = 2 Else VALEUR = 1 : Endif
End

Subprog C_STOFCY(VALEUR)
Variable Char     VALEUR
Look [ITF]ITF0=[M:HIM0]ITMREF;VALEUR
If fstat
    mkstat=2
    GMESSAGE=mess(139,197,1)
    End
Endif

Look [MFC]MFC0(2) = VALEUR;[M]ITMREF
[G:MFC]currlen=0
If fstat
  mkstat=2 : GMESSAGE = mess(23,100,1)
Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 07/05/2003 13:25:06 (TB)
##########################################################################
Subprog IB_NBLIG
GCONSULT = 2 # pour interdire modif et accès suivant préc... (tunnel OF)
End

Subprog C_NBLIG
GCONSULT = 0
End


##########################################################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
If GFLTITM <> ""
  mkstat = 2
  VALEUR = GFLTITM
Endif
End
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
    If [M:HIM0]STOFCY<>""
        Look [ITF]ITF0=VALEUR;[M:HIM0]STOFCY
        If fstat
            Effzo [M:HIM0]STOFCY
        Endif
    Endif
End

##########################################################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
If GFLTFCY <> ""
  mkstat = 2
  VALEUR = GFLTFCY
Endif
End

##########################################################################
Subprog AM_DATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR>[M:HIM0]DATEND & [M:HIM0]DATEND<>[0/0/0]
    [M:HIMC]DATEND=VALEUR
    [M:HIM0]DATEND=VALEUR
Endif
End


######################################################################################

