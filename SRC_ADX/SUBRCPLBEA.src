#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque RCPLBE2

########################################################################
# Impression des étiquettes de stocks                      #
# -------------------------------------------------------------------- #
# Traitements sur champ "Call" de l'écran STOLBEIMP                    #
# Action  : STKLBEIMP (GTRAITE)                                        #
# Fenêtre : ISTOLBE                                                    #
# Traitement de l'action : SUBSLPA                                     #
# Gosub autres           : SUBSLPB                                     #
# -------------------------------------------------------------------- #
########################################################################
$OUVRE
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
Global Integer GWNUMREQ
If !clalev([F:STJ])  : Local File STOJOU       [STJ]  : Endif
If !clalev([F:ITM])  : Local File ITMMASTER    [ITM]  : Endif
If !clalev([F:ITF])  : Local File ITMFACILIT   [ITF]  : Endif
If !clalev([F:ARP])  : Local File AREPORT      [ARP]  : Endif
If !clalev([F:AIM])  : Local File APRINTER     [AIM]  : Endif
If !clalev([F:AID])  : Local File APRINTDES    [AID]  : Endif
If !clalev([F:LBP])  : Local File LABELPRN     [LBP]  : Endif
If !clalev([F:ACV])  : Local File ACTIV        [ACV]  : Endif
If !clalev([F:CUD])  : Local File CUNLISDET    [CUD]  : Endif
If !clalev([F:LPN])  : Local File LPN          [LPN]  : Endif
If !clalev([F:TCTR]) : Local File TABCONTAINER [TCTR] : Endif
If GMODU(8) = 2
   If clalev ([F:MTK]) <= 0 : Local File MFGHEADTRK [MTK] : Endif
   If clalev ([F:MFG]) <= 0 : Local File MFGHEAD    [MFG] : Endif
   If clalev ([F:MFI]) <= 0 : Local File MFGITM     [MFI] : Endif
   If clalev ([F:MKI]) <= 0 : Local File MFGITMTRK  [MKI] : Endif
Endif
If GMODU(6) = 2
   If clalev ([F:PTH]) <= 0 : Local File PRECEIPT   [PTH] : Endif
Endif
If GMODU(5) = 2
   If clalev ([F:SRH]) <= 0 : Local File SRETURN    [SRH] : Endif
Endif

Return

$DEBUT
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
Raz [M:RCB0]
If PARAM(1)<>""
   [M:RCB0]STOFCY = PARAM(1)
Endif
If PARAM(2)<>""
  [M:RCB0]VCRTYP = val(PARAM(2))
Endif
If PARAM(3)<>""
   [M:RCB0]VCRNUMSTR = PARAM(3)
   [M:RCB0]VCRNUMEND = [M:RCB0]VCRNUMSTR
Endif
If dim(PARAM)>3 & PARAM(4)<>""
   [M:RCB0]VCRNUMEND = PARAM(4)
Endif
If dim(PARAM)>4 & PARAM(5)<>""
   Case PARAM(5)
        When "SSL1":
                [M:RCB0]ABRDOC = PARAM(5)
                If !clalev([F:AMK]) : Local File AMSK [AMK] : Endif
                Read [AMK]CODMSK="SSL1"
                If !fstat
                    Call TEXTE([F:AMK]INTMSK,[M:RCB0]TITDOC) From OBJDIV
                Endif
                Raz [M:RCB0]VCRTYP
                # Charger les noms de champs dans les zones de [M:SLP]: WZONVCRTYP, WZONVCRNUM et WZONVCRLIN
                # Pour filtrer dans le masque, remplir [M:SLP]WMSKFIL en utilisant "I" comme indice
                Gosub CHARG_PARAM_SLP From TRTSSLA
        Endcase
    Endif
Affzo [M:RCB0]
# dans les cas suivants VCRNUMEND peut etre <> de VCRNUMSTR :
#  - suivi matiere             (FUNBENCHR 701 = 12)
#  - déclaration de production (FUNBENCHI 701 = 15)
# en conséquence dans le tableau apparait la colonne VCRNUM/Pièce
Global Char GINVVCR
If [M:RCB0]VCRNUMSTR <> [M:RCB0]VCRNUMEND
   GINVVCR ="K:"+num$(GLONVCR)+"X"
Else
   GINVVCR ="-K:"+num$(GLONVCR)+"X"
Endif
Case BOITE
     When "IRCPLBE1" :
          Call RELOADSTO From SUBRCPLBEB
          If [M:RCB1]NBLIG1=0
             FIN=1
          Endif
     When "IRCPLBE2" :
          Call RELOADLPN From SUBRCPLBEB
          If [M:RCB2]NBLIG2=0
             FIN=1
          Endif
     When "IRCPLBE3" :
          Call RELOADSTO From SUBRCPLBEB
          Call RELOADLPN From SUBRCPLBEB
          If [M:RCB1]NBLIG1=0 & [M:RCB2]NBLIG2=0
             FIN=1
          Endif
     When Default
Endcase

Return

$SETBOUT
#-------------------------------#
# Grisage/dégrisage des boutons #
#-------------------------------#
Case BOITE
     When "IRCPLBE1" :
          If  [M:RCB1]NBLIG1=0
              Call VIREBOUT(CHBOU,"2") From GOBJET
          Endif
     When "IRCPLBE2" :
          If  [M:RCB2]NBLIG2=0
              Call VIREBOUT(CHBOU,"2") From GOBJET
          Endif
     When "IRCPLBE3" :
          If  [M:RCB1]NBLIG1=0 & [M:RCB2]NBLIG2=0
              Call VIREBOUT(CHBOU,"2") From GOBJET
          Endif
    When Default
Endcase
Return

$BOUTON
#------------------------#
# Traitement des boutons #
#------------------------#
Local Integer LRET
Case BOUT
    When "1" :
       Case BOITE
           When "IRCPLBE1" :
                Call RELOADSTO From SUBRCPLBEB
           When "IRCPLBE2" :
                Call RELOADLPN From SUBRCPLBEB
           When "IRCPLBE3" :
                Call RELOADSTO From SUBRCPLBEB
                Call RELOADLPN From SUBRCPLBEB
           When Default
       Endcase
    When "2" :
       Case BOITE
           When "IRCPLBE1" :
                Call PRINTSTO(LRET) From SUBRCPLBEB
           When "IRCPLBE2" :
                Call PRINTLPN(LRET) From SUBRCPLBEB
           When "IRCPLBE3" :
                Call PRINTSTO(LRET) From SUBRCPLBEB
                Call PRINTLPN(LRET) From SUBRCPLBEB
           When Default
       Endcase
       Raz GPE
       GPOINT = "RELOADRCP"
       Gosub  ENTREE From EXEFNC
       If GPE =  0
          Case BOITE
              When "IRCPLBE1" :
                   Call RELOADSTO From SUBRCPLBEB
              When "IRCPLBE2" :
                   Call RELOADLPN From SUBRCPLBEB
              When "IRCPLBE3" :
                   Call RELOADSTO From SUBRCPLBEB
                   Call RELOADLPN From SUBRCPLBEB
              When Default
          Endcase
       Endif
    When Default
Endcase
Return

