Gosub INIT_PERIODE
[M:SMVG]DATFIN = WDATFIN
[M:SMVG]DATDEB = WDATDEB
[M:SMVG]STU   =[F:ITM]STU
Affzo [SMVG]5

#----- Récupération du nom du traitement spécifique -----#
If !clalev([F:ACN])  Local File ACONSULT [ACN] : Endif
Read [ACN] ACN0="SMV" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif
# c est le nombre de periode du graphe qui determine la durée de consultation .....
Raz [M:SMV1]INQLTI                      

#----- Positionnement des filtres -----#
Gosub LOAD_FILTER From CNSSMVSTD
WFILSPE="1=1"
If WPROGSPE<>""
  ACTION="FILTRE" : Gosub ACTION From =WPROGSPE
Endif
[M:SMVG]WFIL1   = WFIL1
[M:SMVG]WFIL2   = WFIL2
[M:SMVG]WFILF   = WFILF
[M:SMVG]WFILSPE = WFILSPE
#----- Chargement du tableau -----#
Gosub CHARGE_SMVG2
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_FGRAPHSMV2
nolign=SAVNOLIGN
Return
#----------------------------------------------------------------------#
# Chargement du tableau pour le graphe SMVG
#----------------------------------------------------------------------#
$CHARGE_SMVG2
If dim(I)<1        Local Integer I            : Endif
If dim(J)<1        Local Integer J            : Endif
If dim(WKO)<1      Local Integer WKO          : Endif
If dim(WINDEX)<1   Local Integer WINDEX       : Endif
If dim(WMAXI)<1    Local Integer WMAXI        : Endif
If dim(W0)<1       Local Integer W0           : Endif
If dim(W1)<1       Local Integer W1           : Endif
If dim(W2)<1       Local Integer W2           : Endif
If dim(WDATE)<1    Local Date    WDATE        : Endif
If dim(WPERCOD)<1  Local Integer WPERCOD      : Endif
If dim(WJOUR)<1    Local Integer WJOUR        : Endif
If dim(WSEMAINE)<1 Local Integer WSEMAINE     : Endif
If dim(WMOIS)<1    Local Integer WMOIS        : Endif
If dim(WTRIMEST)<1 Local Integer WTRIMEST     : Endif
If dim(WSEMESTR)<1 Local Integer WSEMESTR     : Endif
If dim(WANNEE)<1   Local Integer WANNEE       : Endif
If dim(WLIBELLE)<1 Local Char    WLIBELLE(15) : Endif
If dim(WDATDEB)<1  Local Date    WDATDEB      : Endif
If dim(WDATFIN)<1  Local Date    WDATFIN      : Endif
#-----
WPERCOD=[M:SMVG]PERCOD
Effzo [SMVG]10
Raz [M:SMVG]NBLIG
#-----
For [STJ] Where evalue([M:SMVG]WFIL1)
&             & evalue([M:SMVG]WFIL2)
&             & evalue([M:SMVG]WFILF)
&             & evalue([M:SMVG]WFILSPE)
&             & [F:STJ]IPTDAT>=[M]DATDEB
&             & [F:STJ]IPTDAT<=[M]DATFIN
&         With Nohint
  #----- Détermination de la période -----#
  WDATE=[F:STJ]IPTDAT : Gosub DETERMINE_PERIODE
  #-----
  If [M:SMVG]NBLIG>0
    I=find(WINDEX,[M:SMVG]INDEXPER(0..[M:SMVG]NBLIG-1))
  Else
    I=0
  Endif
  If I=0
    If [M:SMVG]NBLIG<dim([M:SMVG]PERIODE)
      J=[M:SMVG]NBLIG
      [M:SMVG]DAT     (J)=[F:STJ]IPTDAT
      [M:SMVG]INDEXPER(J)=WINDEX
      [M:SMVG]PERIODE (J)=WLIBELLE
      If [F:STJ]QTYSTU < 0
         [M:SMVG]QTYISS (J) = 1
      Else
         [M:SMVG]QTYRCP (J) = 1 
      Endif
      [M:SMVG]NBLIG+=1
    Endif
  Else
      If [F:STJ]QTYSTU < 0
         [M:SMVG]QTYISS (I-1) += 1
      Else
         [M:SMVG]QTYRCP (I-1) += 1 
      Endif
  Endif  
Next

#----- If faut créer les périodes manquantes -----#
WDATDEB=[M:SMVG]DATDEB
WDATFIN=[M:SMVG]DATFIN
Gosub PERIODES_MANQUANTES

Sorta [M:SMVG]NBLIG [M:SMVG]NBLIG Order By [M:SMVG]INDEXPER(indice)
#-----
Affzo [SMVG]10
Return



####################################################################################
# FGRAPHSMJ2 : Graphique : Nombre mouvements                          HCB 27/12/06 #
####################################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_FGRAPHSMJ2
Local Integer  SAVNOLIGN   : SAVNOLIGN=nolign
Local Integer  CHGPAG      : CHGPAG   =1
Local Integer  WOK
Local Char     WPROGSPE(GLONADC)
Local Char     WFIL1  (250)
Local Char     WFIL2  (250)
Local Char     WFILF  (250)
Local Char     WFILX  (250)
Local Char     WFILSPE(250)
Local Date     SAVDATDEB
Local Date     SAVDATFIN
Local Integer  WPERCOD
Local Integer  WPERNBR
Local Char     WFCY(GLONFCY)

#-----
If !clalev([F:STJ])  Local File STOJOU  [STJ] : Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_FGRAPHSMJ2
Raz [M:SMVG]
WFCY = [M:SMJ1]FCY
Gosub DETERMINE_NBMOIS
[M:SMVG]PERNBR = WPERNBR
[M:SMVG]PERCOD = 4
WPERCOD        = 4
Gosub INIT_PERIODE
[M:SMVG]DATFIN = WDATFIN
[M:SMVG]DATDEB = WDATDEB
Affzo [SMVG]5

#----- Récupération du nom du traitement spécifique -----#
If !clalev([F:ACN])  Local File ACONSULT [ACN] : Endif
Read [ACN] ACN0="SMJ" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif
# c est le nombre de periode du graphe qui determine la durée de consultation .....
Raz [M:SMJ1]STRDAT 
[M:SMJ1]ENDDAT = [31/12/2099]     
#----- Positionnement des filtres -----#
Gosub LOAD_FILTER From CNSSMJSTD
WFILSPE="1=1"
WFIL2  ="1=1"
If WPROGSPE<>""
  ACTION="FILTRE" : Gosub ACTION From =WPROGSPE
Endif
[M:SMVG]WFIL1   = WFIL1
[M:SMVG]WFIL2   = WFIL2
[M:SMVG]WFILF   = WFILF
[M:SMVG]WFILSPE = WFILSPE
#----- Chargement du tableau -----#
Gosub CHARGE_SMVJ2
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_FGRAPHSMJ2
nolign=SAVNOLIGN
[M:SMJ1]STRDAT = date$ 
[M:SMJ1]ENDDAT = date$     

Return
#----------------------------------------------------------------------#
# Chargement du tableau pour le graphe SMVG
#----------------------------------------------------------------------#
$CHARGE_SMVJ2
If dim(I)<1        Local Integer I            : Endif
If dim(J)<1        Local Integer J            : Endif
If dim(WKO)<1      Local Integer WKO          : Endif
If dim(WINDEX)<1   Local Integer WINDEX       : Endif
If dim(WMAXI)<1    Local Integer WMAXI        : Endif
If dim(W0)<1       Local Integer W0           : Endif
If dim(W1)<1       Local Integer W1           : Endif
If dim(W2)<1       Local Integer W2           : Endif
If dim(WDATE)<1    Local Date    WDATE        : Endif
If dim(WPERCOD)<1  Local Integer WPERCOD      : Endif
If dim(WJOUR)<1    Local Integer WJOUR        : Endif
If dim(WSEMAINE)<1 Local Integer WSEMAINE     : Endif
If dim(WMOIS)<1    Local Integer WMOIS        : Endif
If dim(WTRIMEST)<1 Local Integer WTRIMEST     : Endif
If dim(WSEMESTR)<1 Local Integer WSEMESTR     : Endif
If dim(WANNEE)<1   Local Integer WANNEE       : Endif
If dim(WLIBELLE)<1 Local Char    WLIBELLE(15) : Endif
If dim(WDATDEB)<1  Local Date    WDATDEB      : Endif
If dim(WDATFIN)<1  Local Date    WDATFIN      : Endif
#-----
WPERCOD=[M:SMVG]PERCOD
Effzo [SMVG]10
Raz [M:SMVG]NBLIG
Local Char WFILG(100) 

# Sélection numéro article 
If [M:SMJ1]SRTCOD = 2
  WFILG = "[F:STJ]IPTDAT>=[M]DATDEB&[F:STJ]IPTDAT<=[M]DATFIN"
Else
  WFILG = "[F:STJ]CREDAT>=[M]DATDEB&[F:STJ]CREDAT<=[M]DATFIN"
Endif



#-----
For [STJ] Where evalue([M:SMVG]WFIL1)
&             & evalue([M:SMVG]WFIL2)
&             & evalue([M:SMVG]WFILF)
&             & evalue([M:SMVG]WFILSPE)
&             & evalue(WFILG)
&         With Nohint
  #----- Détermination de la période -----#
  If [M:SMJ1]SRTCOD = 2
      WDATE=[F:STJ]IPTDAT : Gosub DETERMINE_PERIODE
  Else
      WDATE=[F:STJ]CREDAT : Gosub DETERMINE_PERIODE
  Endif
   #-----
  If [M:SMVG]NBLIG>0
    I=find(WINDEX,[M:SMVG]INDEXPER(0..[M:SMVG]NBLIG-1))
  Else
    I=0
  Endif
  If I=0
    If [M:SMVG]NBLIG<dim([M:SMVG]PERIODE)
      J=[M:SMVG]NBLIG
      If [M:SMJ1]SRTCOD = 2
         [M:SMVG]DAT     (J)=[F:STJ]IPTDAT 
      Else
         [M:SMVG]DAT     (J)=[F:STJ]CREDAT 
      Endif
      [M:SMVG]INDEXPER(J)=WINDEX
      [M:SMVG]PERIODE (J)=WLIBELLE
      If [F:STJ]QTYSTU < 0
         [M:SMVG]QTYISS (J) = 1
      Else
         [M:SMVG]QTYRCP (J) = 1 
      Endif
      [M:SMVG]NBLIG+=1
    Endif
  Else
      If [F:STJ]QTYSTU < 0
         [M:SMVG]QTYISS (I-1) += 1
      Else
         [M:SMVG]QTYRCP (I-1) += 1 
      Endif
  Endif  
Next

#----- If faut créer les périodes manquantes -----#
WDATDEB=[M:SMVG]DATDEB
WDATFIN=[M:SMVG]DATFIN
Gosub PERIODES_MANQUANTES

Sorta [M:SMVG]NBLIG [M:SMVG]NBLIG Order By [M:SMVG]INDEXPER(indice)
#-----
Affzo [SMVG]10
Return


####################################################################################
# FGRAPHSPR1: Graphique : Quantité / Besoins - ressources            HCB 27/12/06 #
####################################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_FGRAPHSPR1
Local Integer  SAVNOLIGN   : SAVNOLIGN=nolign
Local Integer  CHGPAG      : CHGPAG   =1
Local Integer  WOK
Local Char     WPROGSPE(GLONADC)
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif

Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_FGRAPHSPR1
Raz [M:SPRG]

[M:SPRG]PERCOD = 2                           
If [M:SPR2]STRDAT(0) <> [0/0/0]
   [M:SPRG]REFPER = [M:SPR2]STRDAT(0)                      
Else
   [M:SPRG]REFPER = date$                      
Endif
[M:SPRG]PERNBR = 14                         
[M:SPRG]STU    =[F:ITM]STU
Affzo [SPRG]5

#----- Récupération du nom du traitement spécifique -----#
If !clalev([F:ACN])  Local File ACONSULT [ACN] : Endif
Read [ACN] ACN0="SMV" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif

#----- Chargement du tableau -----#
Gosub CHARGE_SSPRG
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_FGRAPHSPR1
nolign=SAVNOLIGN
Return
#----------------------------------------------------------------------#
# Chargement du tableau pour le graphe SMVG                            #
#----------------------------------------------------------------------#
$CHARGE_SSPRG

Local Integer WROW     
WROW = [M:SPRG]PERNBR          

Local Decimal WSTO       (WROW)
Local Decimal WMAX       (WROW)
Local Decimal WSAF       (WROW)
Local Decimal WDEM       (WROW)
Local Decimal WRES       (WROW)
Local Integer WFLG       (WROW)
Local Char    WABSDAT(20)(WROW)
Local Date    WDAT   
Local Date    WDATPER   
WDAT    = [M:SPRG]REFPER 
WDATPER = [M:SPRG]REFPER 
Local Date    WDATD  (WROW)
Local Date    WDATF  (WROW)
Local Char    WPAR(1)
Local Integer WSEM      : WSEM = 1  : # Premier jour ouvré semaine 
Local Integer WCOR

Local Date    WDTE
Local Date    WDTED
Local Date    WDTEF
Local Integer WSEMD
Local Integer WSEMF
Local Integer WYEA
Local Integer WMON

Local Decimal WDISP                       
Raz           WDISP                      
# Lecture paramètre premier jour ouvré
Call PARAM(GFCYDEF(0),"FIRWRKDAY",WPAR) From ADOVAL
If val(WPAR) < 1 | val(WPAR) > 7
  WSEM = 1
Else
  WSEM = val(WPAR)
Endif

If WSEM = 1
   WCOR = 7
Else
   WCOR = WSEM-1
Endif
   
Local Integer I, J
If [F:ITM]ITMREF <> [M:SPR1]ITMREF
    Read [ITM]ITM0=[M:SPR1]ITMREF
Endif
If [F:ITF]ITMREF <> [M:SPR1]ITMREF
    Read [ITF]ITF0=[M:SPR1]ITMREF;[M:SPR1]FCY
Endif

# constitution graphique  selon périodicité
Case [M:SPRG]PERCOD
     When 1 :
  # Constitution table labels abscisses
          For I = 0 To WROW-1
              WABSDAT(I) = format$("D:"+GFMDAT4,WDAT)
              WDAT += 1 
          Next I
  # Constitution table des valeurs
          Raz WFLG
          WDISP = [M:SPR2]PHYSTO1                             

          For I = 0 To [M:SPR2]NBLIG-1
              If [M:SPR2]WIPTYPSTA(I) = "***" | [M:SPR2]ENDDAT(I) >= WDATPER   
                 J = [M:SPR2]ENDDAT(I) - WDATPER
                     If J < WROW 
                           WFLG(J) = 1
                           WSTO(J) = [M:SPR2]EXTSTO(I)
                           If (func CBNLIB.ISDEM([M:SPR2]WIPTYP(I)))
                               WDEM(J)+= [M:SPR2]RMNEXTQTY(I)
                           Else
                               WRES(J)+= [M:SPR2]RMNEXTQTY(I)
                           Endif       
                     Endif
              Else                                              
                    If (func CBNLIB.ISDEM([M:SPR2]WIPTYP(I)))      
                       WDISP-= [M:SPR2]RMNEXTQTY(I)               
                    Else                                           
                       WDISP+= [M:SPR2]RMNEXTQTY(I)                 
                    Endif                                               
              Endif
          Next I

     When 2 :
          If dayn(WDATPER) = WSEM
             WDATD(0) = WDATPER
             WDATF(0) = WDATPER+6
          Else
             WDATD(0) = WDATPER
             WDATF(0) = WDATPER
             While dayn(WDATF(0)) <> WCOR
                WDATF(0) += 1
             Wend 
          Endif
             WABSDAT(I) = format$("D:"+GFMDAT4,WDATD(0))
             For I = 1 To WROW-1
                 WDATD(I) = WDATF(I-1)+1
                 WDATF(I) = WDATF(I-1)+7
                 WABSDAT(I) = format$("D:"+GFMDAT4,WDATD(I))
             Next I
             Raz I , J 
             WDISP = [M:SPR2]PHYSTO1                             
             For I = 0 To [M:SPR2]NBLIG-1
                 If [M:SPR2]WIPTYPSTA(I) <> "***" & [M:SPR2]ENDDAT(I) >= WDATPER   
                    For J = 0 To WROW-1
                        If [M:SPR2]ENDDAT(I) >= WDATD(J) & [M:SPR2]ENDDAT(I) <= WDATF(J)
                               WSTO(J) =  [M:SPR2]EXTSTO(I)
                               WFLG(J) = 1
                           If (func CBNLIB.ISDEM([M:SPR2]WIPTYP(I)))
                              WDEM(J)+= [M:SPR2]RMNEXTQTY(I)
                           Else
                              WRES(J)+= [M:SPR2]RMNEXTQTY(I)
                           Endif       
                           Break 
                        Endif
                    Next J
                 Else                                             
                    If (func CBNLIB.ISDEM([M:SPR2]WIPTYP(I)))     
                       WDISP-= [M:SPR2]RMNEXTQTY(I)                
                    Else                                            
                       WDISP+= [M:SPR2]RMNEXTQTY(I)                
                    Endif                                              

                 Endif
             Next I

     When 4 :
          WDTE = WDATPER
          Call DATMOIS(WDTE,WDTED,WDTEF,WSEMD,WSEMF,WYEA,WMON,WSEM) From CBNLIB
          WDTE = gdat$(15,month(WDTED+7),year(WDTED+7))
          For I = 0 To WROW-1
              Call DATMOIS(WDTE,WDTED,WDTEF,WSEMD,WSEMF,WYEA,WMON,WSEM) From CBNLIB
              If I = 0
                 WDATD(I) = WDATPER
              Else
                 WDATD(I) = WDTED
              Endif
              WDATF(I) = WDTEF
              WABSDAT(I) = month$(WDTED+7)-num$(year(WDTED+7))
              WDTE = addmonth(WDTE,1)
          Next I  
          Raz I , J 

          WDISP = [M:SPR2]PHYSTO1                              

          For I = 0 To [M:SPR2]NBLIG-1
              If [M:SPR2]WIPTYPSTA(I) <> "***" | [M:SPR2]ENDDAT(I) >= WDATPER   
                 For J = 0 To WROW-1
                     If [M:SPR2]ENDDAT(I) >= WDATD(J) & [M:SPR2]ENDDAT(I) <= WDATF(J)
                            WSTO(J) =  [M:SPR2]EXTSTO(I)
                            WFLG(J) = 1
                        If (func CBNLIB.ISDEM([M:SPR2]WIPTYP(I)))
                           WDEM(J)+= [M:SPR2]RMNEXTQTY(I)
                        Else
                           WRES(J)+= [M:SPR2]RMNEXTQTY(I)
                        Endif       
                        Break 
                     Endif
                 Next J
              Else                                             
                 If (func CBNLIB.ISDEM([M:SPR2]WIPTYP(I)))       
                    WDISP-= [M:SPR2]RMNEXTQTY(I)                
                 Else                                           
                    WDISP+= [M:SPR2]RMNEXTQTY(I)                
                 Endif                                            
              Endif
          Next I
     Endcase 
Raz I
Case GACTION
    When "FGRAPHSPR1"
        For I = 0 To WROW-1
            If I = 0 & WFLG(I) = 0      
                WSTO(I) = WDISP         
            Endif                       

            If  I > 0 & WFLG(I) = 0
                WSTO(I) = WSTO(I-1)
            Endif
            WMAX(I) = int([F:ITF]MAXSTO)
            WSAF(I) = int([F:ITF]SAFSTO)
        Next I
        Raz I
        For I = 0 To WROW-1
            [M:SPRG]WABSDAT(I)  = WABSDAT(I)
            [M:SPRG]WSTO   (I)  = WSTO   (I)
            [M:SPRG]WMAX   (I)  = WMAX   (I)
            [M:SPRG]WSAF   (I)  = WSAF   (I)
            [M:SPRG]WDEM   (I)  = WDEM   (I)  
            [M:SPRG]WRES   (I)  = WRES   (I)  
        Next I
        [M:SPRG]NBLIGC = WROW
    When "FGRAPHSPR2"
        For I = 0 To WROW-1
            [M:SPRG]WABSDAT(I)  = WABSDAT(I)
            [M:SPRG]WDEM   (I)  = WDEM   (I)  
            [M:SPRG]WRES   (I)  = WRES   (I)  
        Next I
       [M:SPRG]NBLIGC = WROW
Endcase
Affzo [M:SPRG]

Return




####################################################################################
# FGRAPHORD1: Graphique : Quantité / Besoins - ressources            HCB 27/12/06 #
####################################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_FGRAPHORD1
Local Integer  SAVNOLIGN   : SAVNOLIGN=nolign
Local Integer  CHGPAG      : CHGPAG   =1
Local Integer  WOK
Local Char     WPROGSPE(GLONADC)
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif

Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_FGRAPHORD1
Raz [M:ORDG]

[M:ORDG]PERCOD = 2                           
If [M:ORD2]STRDAT(0) <> [0/0/0]
   [M:ORDG]REFPER = [M:ORD2]STRDAT(0)                      
Else
   [M:ORDG]REFPER = date$                      
Endif
[M:ORDG]PERNBR = 14                         
[M:ORDG]STU    =[F:ITM]STU
Affzo [ORDG]5

#----- Récupération du nom du traitement spécifique -----#
If !clalev([F:ACN])  Local File ACONSULT [ACN] : Endif
Read [ACN] ACN0="SMV" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif

#----- Chargement du tableau -----#
Gosub CHARGE_SORDG
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_FGRAPHORD1
nolign=SAVNOLIGN
Return
#----------------------------------------------------------------------#
# Chargement du tableau pour le graphe ORDG                            #
#----------------------------------------------------------------------#
$CHARGE_SORDG

Local Integer WROW     
WROW = [M:ORDG]PERNBR         

Local Decimal WSTO       (WROW)
Local Decimal WMAX       (WROW)
Local Decimal WSAF       (WROW)
Local Decimal WDEM       (WROW)
Local Decimal WRES       (WROW)
Local Integer WFLG       (WROW)
Local Char    WABSDAT(20)(WROW)
Local Date    WDAT   
Local Date    WDATPER   
WDAT    = [M:ORDG]REFPER 
WDATPER = [M:ORDG]REFPER 
Local Date    WDATD  (WROW)
Local Date    WDATF  (WROW)
Local Char    WPAR(1)
Local Integer WSEM      : WSEM = 1  : # Premier jour ouvré semaine 
Local Integer WCOR

Local Date    WDTE
Local Date    WDTED
Local Date    WDTEF
Local Integer WSEMD
Local Integer WSEMF
Local Integer WYEA
Local Integer WMON


# Lecture paramètre premier jour ouvré
Call PARAM(GFCYDEF(0),"FIRWRKDAY",WPAR) From ADOVAL
If val(WPAR) < 1 | val(WPAR) > 7
  WSEM = 1
Else
  WSEM = val(WPAR)
Endif

If WSEM = 1
   WCOR = 7
Else
   WCOR = WSEM-1
Endif
   
Local Integer I, J
If [F:ITM]ITMREF <> [M:ORD1]ITMREFSTR
    Read [ITM]ITM0= [M:ORD1]ITMREFSTR
Endif
If [F:ITF]ITMREF <> [M:ORD1]ITMREFSTR
    Read [ITF]ITF0= [M:ORD1]ITMREFSTR;[M:ORD1]FCY
Endif

# constitution graphique  selon périodicité
Case [M:ORDG]PERCOD
     When 1 :
  # Constitution table labels abscisses
          For I = 0 To WROW-1
              WABSDAT(I) = format$("D:"+GFMDAT4,WDAT)
              WDAT += 1 
          Next I
  # Constitution table des valeurs
          Raz WFLG
          For I = 0 To [M:ORD2]NBLIG-1
              If [M:ORD2]WIPTYPSTA(I) <> "***" & [M:ORD2]ENDDAT(I) >= WDATPER   
                 J = [M:ORD2]ENDDAT(I) - WDATPER
                     If J < WROW 
                        If (func CBNLIB.ISDEM([M:ORD2]WIPTYP(I)))
                           WDEM(J)+= [M:ORD2]RMNEXTQTY(I)
                        Else
                           WRES(J)+= [M:ORD2]RMNEXTQTY(I)
                        Endif
                     Endif       
              Endif
          Next I
     When 2 :
          If dayn(WDATPER) = WSEM
             WDATD(0) = WDATPER
             WDATF(0) = WDATPER+6
          Else
             WDATD(0) = WDATPER
             WDATF(0) = WDATPER
             While dayn(WDATF(0)) <> WCOR
                WDATF(0) += 1
             Wend 
          Endif
             WABSDAT(I) = format$("D:"+GFMDAT4,WDATD(0))
             For I = 1 To WROW-1
                 WDATD(I) = WDATF(I-1)+1
                 WDATF(I) = WDATF(I-1)+7
                 WABSDAT(I) = format$("D:"+GFMDAT4,WDATD(I))
             Next I
             Raz I , J 
             For I = 0 To [M:ORD2]NBLIG-1
                 If [M:ORD2]WIPTYPSTA(I) <> "***" | [M:ORD2]ENDDAT(I) >= WDATPER   
                    For J = 0 To WROW-1
                        If [M:ORD2]ENDDAT(I) >= WDATD(J) & [M:ORD2]ENDDAT(I) <= WDATF(J)
                           If (func CBNLIB.ISDEM([M:ORD2]WIPTYP(I)))
                              WDEM(J)+= [M:ORD2]RMNEXTQTY(I)
                           Else
                              WRES(J)+= [M:ORD2]RMNEXTQTY(I)
                           Endif       
                           Break 
                        Endif
                    Next J
                 Endif
             Next I

     When 4 :
          WDTE = WDATPER
          Call DATMOIS(WDTE,WDTED,WDTEF,WSEMD,WSEMF,WYEA,WMON,WSEM) From CBNLIB
          WDTE = gdat$(15,month(WDTED+7),year(WDTED+7))
          For I = 0 To WROW-1
              Call DATMOIS(WDTE,WDTED,WDTEF,WSEMD,WSEMF,WYEA,WMON,WSEM) From CBNLIB
              If I = 0
                 WDATD(I) = WDATPER
              Else
                 WDATD(I) = WDTED
              Endif
              WDATF(I) = WDTEF
              WABSDAT(I) = month$(WDTED+7)-num$(year(WDTED+7))
              WDTE = addmonth(WDTE,1)
          Next I  
          Raz I , J 
          For I = 0 To [M:ORD2]NBLIG-1
              If [M:ORD2]WIPTYPSTA(I) <> "***" | [M:ORD2]ENDDAT(I) >= WDATPER   
                 For J = 0 To WROW-1
                     If [M:ORD2]ENDDAT(I) >= WDATD(J) & [M:ORD2]ENDDAT(I) <= WDATF(J)
                        If (func CBNLIB.ISDEM([M:ORD2]WIPTYP(I)))
                           WDEM(J)+= [M:ORD2]RMNEXTQTY(I)
                        Else
                           WRES(J)+= [M:ORD2]RMNEXTQTY(I)
                        Endif       
                        Break 
                     Endif
                 Next J
              Endif
          Next I
     Endcase 
Raz I
Case GACTION
    When "FGRAPHORD1"
        For I = 0 To WROW-1
            WMAX(I) = int([F:ITF]MAXSTO)
            WSAF(I) = int([F:ITF]SAFSTO)
        Next I
        Raz I
        For I = 0 To WROW-1
            [M:ORDG]WABSDAT(I)  = WABSDAT(I)
            [M:ORDG]WMAX   (I)  = WMAX   (I)
            [M:ORDG]WSAF   (I)  = WSAF   (I)
            [M:ORDG]WDEM   (I)  = WDEM   (I)  
            [M:ORDG]WRES   (I)  = WRES   (I)  
        Next I
        [M:ORDG]NBLIGC = WROW
    When "FGRAPHORD2"
        For I = 0 To WROW-1
            [M:ORDG]WABSDAT(I)  = WABSDAT(I)
            [M:ORDG]WDEM   (I)  = WDEM   (I)  
            [M:ORDG]WRES   (I)  = WRES   (I)  
        Next I
       [M:ORDG]NBLIGC = WROW
Endcase
Affzo [M:ORDG]

Return



####################################################################################
# FGRAPHSHS1 : Graphique : Quantité                                   HCB 27/12/06 #
####################################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_FGRAPHSHS1
Local Integer  SAVNOLIGN   : SAVNOLIGN=nolign
Local Integer  CHGPAG      : CHGPAG   =1
Local Integer  WOK
Local Char     WPROGSPE(GLONADC)
Local Char     WFILX  (250)
Local Char     WFILSPE(250)

Local  Integer INBC
Local  Integer ICOD, ICOF
Local  Integer WNBC : WNBC = 29
Local  Integer WCOL(WNBC)
Local  Decimal EXE
Local  Decimal PER
Local  Date    WDAT

If clalev([F:ITH])=0 : Local File ITMMVTHIS  [ITH] : Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_FGRAPHSHS1
Raz [M:SHSG]

[M:SHSG]STRDAT = [M:SHS1]STRDAT
[M:SHSG]ENDDAT = [M:SHS1]ENDDAT
[M:SHSG]MONNBR = [M:SHS1]MONNBR
[M:SHSG]STU    = [F:ITM]STU
Affzo [SHSG]5

#----- Récupération du nom du traitement spécifique -----#
If !clalev([F:ACN])  Local File ACONSULT [ACN] : Endif
Read [ACN] ACN0="SHS" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif

#----- Positionnement des filtres -----#
WFILSPE="1=1"
If WPROGSPE<>""
  ACTION="FILTRE" : Gosub ACTION From =WPROGSPE
Endif

#----- Chargement du tableau -----#
Gosub CHARGE_SSHSG
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_FGRAPHSHS1
nolign=SAVNOLIGN
Return
#----------------------------------------------------------------------#
# Chargement du tableau pour le graphe SHSG1,2,3                       #
#----------------------------------------------------------------------#
$CHARGE_SSHSG

Local Integer WROW
Local Integer I,J,K,K1,K2,K3,K4
If INBL = 0
   Gosub TXT_LIGNES From CNSSHSSTD
Endif
Gosub TXT_COLONNES

Filter [ITH] Where ITMREF = [M:SHS1]ITMREF &
&                  STOFCY = [M:SHS1]FCY    &
&                  evalue (WFILS)          &
&                  evalue (WFILSPE)
&            Order By Key ITH0 
For [ITH] 
  J = find([F:ITH]PERSTR,WDTE) 
  If J <> 0 Gosub TRT_CUMUL Endif
Next
Filter [ITH]

# Traitements des quantités
Raz K
For J=0 To 11
   If evalue("[M:SHS1]"+right$(WFLD(J),2))=2 K+=1 Endif

   Case GACTION
    When "FGRAPHSHS1"
       Case J
        When  1 : If evalue("[M:SHS1]"+right$(WFLD(J),2))=2 K1=K Else K1=0 Endif
        When  4 : If evalue("[M:SHS1]"+right$(WFLD(J),2))=2 K2=K Else K2=0 Endif
        When  7 : If evalue("[M:SHS1]"+right$(WFLD(J),2))=2 K3=K Else K3=0 Endif
        When 10 : If evalue("[M:SHS1]"+right$(WFLD(J),2))=2 K4=K Else K4=0 Endif
       Endcase
    When "FGRAPHSHS2"
       Case J
        When  2 : If evalue("[M:SHS1]"+right$(WFLD(J),2))=2 K1=K Else K1=0 Endif
        When  5 : If evalue("[M:SHS1]"+right$(WFLD(J),2))=2 K2=K Else K2=0 Endif
        When  8 : If evalue("[M:SHS1]"+right$(WFLD(J),2))=2 K3=K Else K3=0 Endif
        When 11 : If evalue("[M:SHS1]"+right$(WFLD(J),2))=2 K4=K Else K4=0 Endif
       Endcase
    When "FGRAPHSHS3"
       Case J
        When  0 : If evalue("[M:SHS1]"+right$(WFLD(J),2))=2 K1=K Else K1=0 Endif
        When  3 : If evalue("[M:SHS1]"+right$(WFLD(J),2))=2 K2=K Else K2=0 Endif
        When  6 : If evalue("[M:SHS1]"+right$(WFLD(J),2))=2 K3=K Else K3=0 Endif
        When  9 : If evalue("[M:SHS1]"+right$(WFLD(J),2))=2 K4=K Else K4=0 Endif
       Endcase
   Endcase 

Next J

For I=0 To [M:SHS1]MONNBR-1
  [M:SHSG]WABS(I)        = GSCOLDES(I)
  If K1<>0
     [M:SHSG]WAMT1(I)=WCUM(K1-1,I)
  Else 
     [M:SHSG]WAMT1(I)=0 
  Endif
  If K2<>0
     If GACTION="FGRAPHSHS2"
        [M:SHSG]WAMT2(I)=-WCUM(K2-1,I)
     Else 
        [M:SHSG]WAMT2(I)=WCUM(K2-1,I)
     Endif
  Else
     [M:SHSG]WAMT2(I)=0
  Endif
  If K3<>0
     [M:SHSG]WAMT3(I)=WCUM(K3-1,I)
  Else 
     [M:SHSG]WAMT3(I)=0
  Endif
  If K4<>0
     If GACTION="FGRAPHSHS2"
        [M:SHSG]WAMT4(I)=-WCUM(K4-1,I)
     Else
        [M:SHSG]WAMT4(I)=WCUM(K4-1,I)
     Endif
  Else
     [M:SHSG]WAMT4(I)=0 
  Endif
Next I
[M:SHSG]NBLIGC = [M:SHSG]MONNBR
Affzo [M:SHSG]

Return

# Cumul (J contient la colonne)
$TRT_CUMUL
For I = 0 To INBL-1
      #WCUM(I,J-1) = evalue("[F:ITH]"+WLIG(I)) MAE, bg48961
      WCUM(I,J-1) = evalue("[F:ITH]"+GLIG(I))
Next I
Return


################################################################################
# Détermination du nombre de mois par rapport au paramatre INQMVSLTI           #
# ---------------------------------------------------------------------------- #
$DETERMINE_NBMOIS
Local Char    WPAR
Local Integer WLTI

# Détermination délai d'interrogation (défaut 30 jours)
Call PARAM(WFCY,"INQMVSLTI",WPAR) From ADOVAL
If val(WPAR) <> 0
  WLTI = val(WPAR)
Endif
If WLTI < 30
   WLTI = 30
Endif

WPERNBR = WLTI/30
If WPERNBR * 30 <> WLTI
   WPERNBR += 1
Endif
Return

############################################################################
# Initialisation des dates début et fin de période                         #
# ------------------------------------------------------------------------ #
# En entrée                                                                #
#   - WPERNBR  : Nombre de périodes                                        #
#   - WPERCOD  : Code périodicité (1=Jour, 2=Semaine, 4=Mois, 5=Trimestre, #
#                                  6=Semestre, 7=Année)                    #
# En sortie                                                                #
#   - WDATDEB  : Date début                                                #
#   - WDATFIN  : Date fin                                                  #
############################################################################
$INIT_PERIODE
#-----
If dim(WDATDEB)<1  Local Date    WDATDEB      : Endif
If dim(WDATFIN)<1  Local Date    WDATFIN      : Endif
#-----
Case WPERCOD
  When 2       : WDATFIN=date$+(7-dayn(date$))
  When 4,5,6,7 : WDATFIN=eomonth(date$)
  When Default : WDATFIN=date$
Endcase
#----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
Call CALDATPER(WPERCOD,WPERNBR,"-",[0/0/0],WDATFIN,WDATDEB) From TRTX3DAT
If WDATDEB=[0/0/0]
  WDATDEB=WDATFIN
Endif
#-----
Return











################################################################################
# Détermination de la période à partir d'une date et d'un code périodicité     #
# ---------------------------------------------------------------------------- #
# En entrée                                                                    #
#   - WDATE    : Date à traiter                                                #
#   - WPERCOD  : Code périodicité (2=Semaine, 4=Mois, 5=Trimestre, 6=Semestre  #
#                                  7=Année)                                    #
# En sortie                                                                    #
#   - WANNEE   : Année     (AAAA)                                              #
#   - WSEMESTR : Semestre  (P)   1 à  2   si WPERCOD=6                         #
#   - WTRIMEST : Trimestre (P)   1 à  4   si WPERCOD=5                         #
#   - WMOIS    : Mois      (PP)  1 à 12   si WPERCOD=4                         #
#   - WSEMAINE : Semaine   (PP)  1 à 53   si WPERCOD=2                         #
#   - WINDEX   : Numéro d'ordre période (AAAAPPP) PPP = 001 à 004/012/053      #
#   - WLIBELLE : Libellé de la période                                         #
# ---------------------------------------------------------------------------- #
# Nota: C'est un Gosub il faut que toutes les variables ci-dessus existent     #
################################################################################
$DETERMINE_PERIODE
#-----
WANNEE=year(WDATE)
#-----
Case WPERCOD
  When 1       : #----- Jour -----#
    WINDEX  =(WANNEE*1000)+(WDATE-gdat$(1,1,WANNEE))+1
    WLIBELLE=format$("D:"+GFMDAT4,WDATE)
  When 2       : #----- Semaine -----#
    WSEMAINE=week(WDATE)
    If WSEMAINE=53 & year(aweek(WSEMAINE,WANNEE)+3)<>WANNEE
      WSEMAINE=1
    Elsif WSEMAINE=0
      If dayn(aweek(WSEMAINE,WANNEE)+3)<4
        WSEMAINE=1
      Else
        WSEMAINE=53 : WANNEE-=1
      Endif
    Endif
    WINDEX  =(WANNEE*1000)+WSEMAINE
    WLIBELLE=mess(2,2231,1)-num$(WSEMAINE)-right$(num$(WANNEE),3)
  When 5       : #----- Trimestre -----#
    WTRIMEST=int((month(WDATE)-1)/3)+1
    WINDEX  =(WANNEE*1000)+WTRIMEST
    WLIBELLE=mess(5,2231,1)-num$(WTRIMEST)-right$(num$(WANNEE),3)
  When 6       : #----- Semestre -----#
    WSEMESTR=int((month(WDATE)-1)/6)+1
    WINDEX  =(WANNEE*1000)+WSEMESTR
    WLIBELLE=mess(6,2231,1)-num$(WSEMESTR)-right$(num$(WANNEE),3)
  When 7       : #----- Année -----#
    WINDEX  =(WANNEE*1000)
    WLIBELLE=mess(7,2231,1)-num$(WANNEE)
  When Default : #----- Mois -----#
    WMOIS   =month(WDATE)
    WINDEX  =(WANNEE*1000)+WMOIS
    WLIBELLE=format$("D:MMMMMMMMMM",WDATE)-num$(WANNEE)
Endcase
#-----
Return

################################################################################
# Création des périodes manquantes en fonction du code périodicité             #
# ---------------------------------------------------------------------------- #
# En entrée                                                                    #
#   - WDATDEB  : Date début                                                    #
#   - WDATFIN  : Date fin                                                      #
#   - WPERCOD  : Code périodicité (2=Semaine, 4=Mois, 5=Trimestre, 6=Semestre  #
#                                  7=Année)                                    #
# Variables de travail                                                         #
#   - W0       : Maxi période-1                                                #
#   - W1       : Année                                                         #
#   - W2       : Période                                                       #
#   - WINDEX   : Numéro d'ordre période                                        #
#   - WMAXI    : Numéro d'ordre période maxi                                   #
#   - WLIBELLE : Libellé de la période                                         #
# En sortie, chargement de la classe écran (lignes tableau)                    #
#   - [M]DAT     (indice)                                                      #
#   - [M]INDEXPER(indice)                                                      #
#   - [M]PERIODE (indice) ...etc                                               #
# ---------------------------------------------------------------------------- #
# Nota: C'est un Gosub il faut que toutes les variables ci-dessus existent     #
################################################################################
$PERIODES_MANQUANTES
#-----
If [M]NBLIG>0
  WINDEX=min([M]INDEXPER(0..[M]NBLIG-1))
  WMAXI =max([M]INDEXPER(0..[M]NBLIG-1))
Else
  Raz WINDEX, WMAXI
Endif
#-----
If WDATFIN<>[0/0/0]
  WDATE=WDATFIN : Gosub DETERMINE_PERIODE
  If WINDEX>WMAXI
    WMAXI=WINDEX
  Endif
Endif
#-----
If WDATDEB<>[0/0/0]
  WDATE=WDATDEB : Gosub DETERMINE_PERIODE
  If WINDEX>min([M]INDEXPER(0..[M]NBLIG-1))
    WINDEX=min([M]INDEXPER(0..[M]NBLIG-1))
  Endif
Endif
#-----
Case WPERCOD
  When 1       : WDATE=WDATDEB-1
  When 2       : W0=51
  When 5       : W0=3        
  When 6       : W0=1
  When 7       : W0=0
  When Default : W0=11
Endcase

If W0=0
  W1=int(WINDEX/1000)-1
  W2=mod(WINDEX,1000)
Else
  W1=int(WINDEX/1000)
  W2=mod(WINDEX,1000)-1
Endif

While WINDEX<WMAXI
  If [M]NBLIG>dim([M]PERIODE)-1
    WINDEX=WMAXI
  Else
    If WPERCOD=1
      WDATE+=1 : Gosub DETERMINE_PERIODE
    Else
      If W0=0  W2=0 : W1+=1  Elsif W2>W0  W2=1 : W1+=1  Else  W2+=1 : Endif
      WINDEX=(W1*1000)+W2
    Endif
    If [M]NBLIG=0 | !find(WINDEX,[M]INDEXPER(0..[M]NBLIG-1))
      Case WPERCOD
        When 1       : WLIBELLE=format$("D:"+GFMDAT4,WDATE)
        When 2       : WLIBELLE=mess(2,52,1)-num$(W2)-right$(num$(W1),3)
        When 5       : WLIBELLE=mess(5,52,1)-num$(W2)-right$(num$(W1),3)
        When 6       : WLIBELLE=mess(6,2231,1)-num$(W2)-right$(num$(W1),3)
        When 7       : WLIBELLE=mess(7,2231,1)-num$(W1)
        When Default : WLIBELLE=format$("D:MMMMMMMMMM",gdat$(1,W2,W1))-num$(W1)
      Endcase
      [M]DAT     ([M]NBLIG)=[0/0/0]
      [M]INDEXPER([M]NBLIG)=WINDEX
      [M]PERIODE ([M]NBLIG)=WLIBELLE
      If clalev([M:SMVG])
        [M:SMVG]QTYRCP    ([M:SMVG]NBLIG)=0
        [M:SMVG]QTYISS    ([M:SMVG]NBLIG)=0
      Endif
      [M]NBLIG+=1
    Endif
  Endif
Wend
#-----
Return

#########################################################################
# Actions sur champ des masques écrans graphiques                       #
#########################################################################

Subprog AS_PERCOD(VALEUR)
Variable Integer VALEUR

GMENLOC(1)=0 : # Jour      Ok
GMENLOC(2)=0 : # Semaine   Ok
GMENLOC(3)=1 : # Quinzaine
GMENLOC(4)=0 : # Mois      Ok
GMENLOC(5)=0 : # Trimestre Ok
GMENLOC(6)=0 : # Semestre  Ok
GMENLOC(7)=0 : # Année     Ok
GMENLOC(8)=1 : # décade

Case GACTION
  When "FGRAPHSPR1" , "FGRAPHSPR2" , "FGRAPHORD1" , "FGRAPHORD2"
       GMENLOC(1)=0 : # Jour      Ok
       GMENLOC(2)=0 : # Semaine   Ok
       GMENLOC(3)=1 : # Quinzaine
       GMENLOC(4)=0 : # Mois      Ok
       GMENLOC(5)=1 : # Trimestre 
       GMENLOC(6)=1 : # Semestre  
       GMENLOC(7)=1 : # Année     
       GMENLOC(8)=1 : # décade
Endcase


End


Subprog AM_PERCOD(VALEUR)
Variable Integer VALEUR
#----- Recalcul du nbre de périodes -----#
Call CALPERNBR([M]PERCOD,VALEUR,[M]PERNBR) From TRTX3DAT
Affzo PERNBR
[M]PERCOD=VALEUR
Call AM_PERNBR([M]PERNBR)
#-----
End


Subprog AM_DATDEB(VALEUR)
Variable Date    VALEUR
#----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
If dim([M]PERCOD)>0
   Local Date WDATE
   Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]DATDEB,VALEUR,WDATE) From TRTX3DAT
   If WDATE<>[0/0/0]
     [M]DATFIN=WDATE : Affzo DATFIN
   Endif
Elsif VALEUR>[M]DATFIN
  [M]DATFIN=VALEUR
Endif

End


Subprog AM_DATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)>0
#----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
   Local Date WDATE
   Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]DATFIN,VALEUR,WDATE) From TRTX3DAT
   If WDATE<>[0/0/0]
      [M]DATDEB=WDATE : Affzo DATDEB
   Endif
Endif
End

Subprog AM_PERNBR(VALEUR)
Variable Decimal VALEUR
#----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
   Local Date WDATE
   Call CALDATPER([M]PERCOD,VALEUR,"+",[0/0/0],[M]DATDEB,WDATE) From TRTX3DAT
   If WDATE<>[0/0/0]
     [M]DATFIN=WDATE : Affzo DATFIN
   Endif
End


#############################################################
# traitements  ecrans graphiques stock historique : SHSG1,2,3
############################################################
#--- date début et fin de période consultée
$CAL_DATE
Local    Char    SOC(20)
Local    Decimal EXE
Local    Decimal PER

If WDATOK = 1  Return Endif
 
Call LECTURE("FCY",[M:SHS1]FCY,"") From CONTOBJ
SOC = [F:FCY]LEGCPY

Call GETPERSOC(SOC,1,WENDDAT,EXE,PER) From CPTSUB

If WMONNBR > 1  
   Filter [PER] Where CPY=SOC 
   For I = 2 To WMONNBR 
    Read [PER]PER0 Prev
    If fstat WMONNBR=I-1 : [M:SHSG]MONNBR=I-1 Endif
   Next I
   Filter [PER]
Endif

[M:SHSG]STRDAT = [F:PER]PERSTR
Affzo [M:SHSG]STRDAT
Return



############################################################
# traitement des colonnes 
$TXT_COLONNES
Local    Char    SOC(20)
Raz INBC, ICOD, ICOF 
Raz WDTE, WCOL, GSCOLDES
#
Call LECTURE("FCY",[M:SHS1]FCY,"") From CONTOBJ
SOC = [F:FCY]LEGCPY

Filter [PER] Where CPY=SOC 
Case [M:SHS1]SRTCOD
  When 1 :  
    WDAT  = [M:SHSG]STRDAT
    Call GETPERSOC(SOC,1,WDAT,EXE,PER) From CPTSUB
    GSCOLDES(INBC) = format$("D:"+GFMDAT4,[F:PER]PERSTR)
    WDTE(INBC) = [F:PER]PERSTR
    WCOL(INBC) = INBC
    INBC += 1
    If [M:SHSG]MONNBR > 1
       For I = 2 To [M:SHSG]MONNBR 
         Read [PER]PER0 Next
         GSCOLDES(INBC) =  format$("D:"+GFMDAT4,[F:PER]PERSTR)
         WDTE(INBC) = [F:PER]PERSTR
         WCOL(INBC) = INBC
         INBC += 1
         ICOF += 1
       Next I
    Endif
  When Default :
    ICOD  = INBC
    ICOF  = INBC
    WDAT  = [M:SHSG]ENDDAT
    Call GETPERSOC(SOC,1,WDAT,EXE,PER) From CPTSUB
    GSCOLDES(INBC) = format$("D:DD[-]MM[-]YYYY",[F:PER]PERSTR)
    WDTE(INBC) = [F:PER]PERSTR
    WCOL(INBC) = INBC
    INBC += 1
    If [M:SHSG]MONNBR > 1
       For I = 2 To [M:SHSG]MONNBR 
          Read [PER]PER0 Prev
          GSCOLDES(INBC) = format$("D:DD[-]MM[-]YYYY",[F:PER]PERSTR)
          WDTE(INBC) = [F:PER]PERSTR
          WCOL(INBC) = INBC
          INBC += 1
          ICOF += 1
       Next I
   Endif
Endcase 
Filter [PER]
Return



Subprog C_MONNBR(VALEUR)
Variable Decimal VALEUR
If VALEUR < 1 | VALEUR > 24
  mkstat = 2
Endif

End

Subprog AM_MONNBR(VALEUR)
Variable Decimal VALEUR
WENDDAT =[M:SHSG]ENDDAT
WMONNBR =VALEUR  
WDATOK=0
Gosub CAL_DATE From TRTSTKGRH

End

Subprog AV_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0]
  VALEUR = eomonth(addmonth(date$,-1))
Endif

End

Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
WENDDAT =VALEUR
WMONNBR =[M:SHSG]MONNBR  
WDATOK=0
Gosub CAL_DATE From TRTSTKGRH


End


