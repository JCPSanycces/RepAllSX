#<AdxTL>@(#)12.0.0.0 $Revision$


##################################################################################
# TRTSTKGRH          Traitements des graphiques                    Module STOCK  #
# ------------------------------------------------------------------------------ #
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                           #
#   - FGRAPHSMV1 : Graphique mouvements par article : Quantité E/S mouvementée   #
#   - FGRAPHSMV2 : Graphique mouvements par article : Nombre de mouvement E/S    #
#   - FGRAPHSMJ2 : Graphique mouvements par Date    : Nombre de mouvement E/S    #
#   - FGRAPHSPR1 : Graphique stock projeté          : Quantité                   #
#   - FGRAPHSPR2 : Graphique stock projeté          : Ressources / besoins       #
#   - FGRAPHORD1 : Graphique en cours               : Quantité                   #
#   - FGRAPHORD2 : Graphique en cours               : Ressources / besoins       #
#   - FGRAPHSHS1 : Graphique historique stock       : Quantité                   #
#   - FGRAPHSHS2 : Graphique historique stock       : Montants                   #
#   - FGRAPHSHS3 : Graphique historique stock       : Nbre entrées : Sorties     #
#                                                                                #
##################################################################################

$ACTION

Case ACTION
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Case GACTION
   When "FGRAPHSMV1" : Gosub OUV_FGRAPHSMV1 
   When "FGRAPHSMV2" : Gosub OUV_FGRAPHSMV2 
   When "FGRAPHSMJ2" : Gosub OUV_FGRAPHSMJ2 
   When "FGRAPHSPR1" : Gosub OUV_FGRAPHSPR1 
   When "FGRAPHSPR2" : Gosub OUV_FGRAPHSPR1 
   When "FGRAPHORD1" : Gosub OUV_FGRAPHORD1 
   When "FGRAPHORD2" : Gosub OUV_FGRAPHORD1 
   When "FGRAPHSHS1" : Gosub OUV_FGRAPHSHS1 
   When "FGRAPHSHS2" : Gosub OUV_FGRAPHSHS1 
   When "FGRAPHSHS3" : Gosub OUV_FGRAPHSHS1 
  Endcase
 When "TITRE"
  #-------------------------------------------#
  # Titre juste avant ouverture de la fenêtre #
  #-------------------------------------------#
  Local Char WITMDES(GLONDES)                                                           # FGR 30/06/2009 : X3SUIVI56189
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3  # FGR 30/06/2009 : X3SUIVI56189
  Case GACTION
   When "FGRAPHSMV1" : TIT=mess(262,195,1)-[F:ITM]ITMREF -"  "-WITMDES # FGR 30/06/2009 : X3SUIVI56189
   When "FGRAPHSMV2" : TIT=mess(263,195,1)-[F:ITM]ITMREF -"  "-WITMDES # FGR 30/06/2009 : X3SUIVI56189
   When "FGRAPHSPR1" : TIT=mess(285,195,1)-[F:ITM]ITMREF -"  "-WITMDES # FGR 30/06/2009 : X3SUIVI56189
   When "FGRAPHSPR2" : TIT=mess(286,195,1)-[F:ITM]ITMREF -"  "-WITMDES # FGR 30/06/2009 : X3SUIVI56189
   When "FGRAPHORD1" : TIT=mess(285,195,1)-[F:ITM]ITMREF -"  "-WITMDES # FGR 30/06/2009 : X3SUIVI56189
   When "FGRAPHORD2" : TIT=mess(286,195,1)-[F:ITM]ITMREF -"  "-WITMDES # FGR 30/06/2009 : X3SUIVI56189
   When "FGRAPHSHS1" : TIT=mess(288,195,1)-[F:ITM]ITMREF -"  "-WITMDES # FGR 30/06/2009 : X3SUIVI56189
   When "FGRAPHSHS2" : TIT=mess(289,195,1)-[F:ITM]ITMREF -"  "-WITMDES # FGR 30/06/2009 : X3SUIVI56189
   When "FGRAPHSHS3" : TIT=mess(290,195,1)-[F:ITM]ITMREF -"  "-WITMDES # FGR 30/06/2009 : X3SUIVI56189
  Endcase
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  Case GACTION
   When "FGRAPHSMV1" : Gosub DEB_FGRAPHSMV1
   When "FGRAPHSMV2" : Gosub DEB_FGRAPHSMV2
   When "FGRAPHSMJ2" : Gosub DEB_FGRAPHSMJ2
   When "FGRAPHSPR1" : Gosub DEB_FGRAPHSPR1
   When "FGRAPHSPR2" : Gosub DEB_FGRAPHSPR1
   When "FGRAPHORD1" : Gosub DEB_FGRAPHORD1
   When "FGRAPHORD2" : Gosub DEB_FGRAPHORD1
   When "FGRAPHSHS1" : Gosub DEB_FGRAPHSHS1
   When "FGRAPHSHS2" : Gosub DEB_FGRAPHSHS1
   When "FGRAPHSHS3" : Gosub DEB_FGRAPHSHS1
  Endcase
 When "OK"
  #--------------------------------#
  # Après l'exécution du bouton OK #
  #--------------------------------#
  Case GACTION
  Endcase
 When "BOUTON"
  #-----------------------------------------------#
  # Après l'exécution d'un bouton ("R"=Recherche) #
  #-----------------------------------------------#
  If BOUT="R"
    Case GACTION
     When "FGRAPHSMV1" : Gosub CHARGE_SMVG1
     When "FGRAPHSMV2" : Gosub CHARGE_SMVG2
     When "FGRAPHSMJ2" : Gosub CHARGE_SMVJ2
     When "FGRAPHSPR1" : Gosub CHARGE_SSPRG
     When "FGRAPHSPR2" : Gosub CHARGE_SSPRG
     When "FGRAPHORD1" : Gosub CHARGE_SORDG
     When "FGRAPHORD2" : Gosub CHARGE_SORDG
     When "FGRAPHSHS1" : Gosub CHARGE_SSHSG
     When "FGRAPHSHS2" : Gosub CHARGE_SSHSG
     When "FGRAPHSHS3" : Gosub CHARGE_SSHSG
    Endcase
  Endif
 When "ABA"
  #-------------------------------------#
  # Après l'exécution du bouton ABANDON #
  #-------------------------------------#
  Case GACTION
  Endcase
 When "APRES_MODIF"
  #------------------------------------#
  # Après chaque modification de champ #
  #------------------------------------#
  Case GACTION
  Endcase 
 When "FINSAI"
  #------------------------------------------#
  # Avant de revenir à la fenêtre précédente #
  #------------------------------------------#
  Case GACTION
   When "FGRAPHSMV1" : Gosub FINSAI_FGRAPHSMV1
   When "FGRAPHSMV2" : Gosub FINSAI_FGRAPHSMV2
   When "FGRAPHSMJ2" : Gosub FINSAI_FGRAPHSMJ2
   When "FGRAPHSPR1" : Gosub FINSAI_FGRAPHSPR1
   When "FGRAPHSPR2" : Gosub FINSAI_FGRAPHSPR1
   When "FGRAPHORD1" : Gosub FINSAI_FGRAPHORD1
   When "FGRAPHORD2" : Gosub FINSAI_FGRAPHORD1
   When "FGRAPHSHS1" : Gosub FINSAI_FGRAPHSHS1
  Endcase
Endcase
Return




####################################################################################
# FGRAPHSMV1 : Graphique : Quantité mouvementée                       HCB 27/12/06 #
####################################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_FGRAPHSMV1
Local Integer  SAVNOLIGN   : SAVNOLIGN=nolign
Local Integer  CHGPAG      : CHGPAG   =1
Local Integer  WOK
Local Char     WPROGSPE(GLONADC)
Local Char     WFIL1  (250)
Local Char     WFIL2  (250)
Local Char     WFILF  (250)
Local Char     WFILX  (250)
Local Char     WFILSPE(250)
Local Date     SAVDATDEB
Local Date     SAVDATFIN
Local Integer  WPERCOD
Local Integer  WPERNBR
Local Char     WFCY(GLONFCY)

#-----
If !clalev([F:STJ])  Local File STOJOU  [STJ] : Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_FGRAPHSMV1
Raz [M:SMVG]

WFCY = [M:SMV1]FCY
Gosub DETERMINE_NBMOIS
[M:SMVG]PERNBR = WPERNBR
[M:SMVG]PERCOD = 4
WPERCOD        = 4
Gosub INIT_PERIODE
[M:SMVG]DATFIN = WDATFIN
[M:SMVG]DATDEB = WDATDEB

[M:SMVG]STU    =[F:ITM]STU
Affzo [SMVG]5

#----- Récupération du nom du traitement spécifique -----#
If !clalev([F:ACN])  Local File ACONSULT [ACN] : Endif
Read [ACN] ACN0="SMV" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif

# c est le nombre de periode du graphe qui determine la durée de consultation .....
Raz [M:SMV1]INQLTI                      

#----- Positionnement des filtres -----#
Gosub LOAD_FILTER From CNSSMVSTD
WFILSPE="1=1"
If WPROGSPE<>""
  ACTION="FILTRE" : Gosub ACTION From =WPROGSPE
Endif
[M:SMVG]WFIL1   = WFIL1
[M:SMVG]WFIL2   = WFIL2
[M:SMVG]WFILF   = WFILF
[M:SMVG]WFILSPE = WFILSPE
#----- Chargement du tableau -----#
Gosub CHARGE_SMVG1
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_FGRAPHSMV1
nolign=SAVNOLIGN
Return
#----------------------------------------------------------------------#
# Chargement du tableau pour le graphe SMVG                            #
#----------------------------------------------------------------------#
$CHARGE_SMVG1
If dim(I)<1        Local Integer I            : Endif
If dim(J)<1        Local Integer J            : Endif
If dim(WKO)<1      Local Integer WKO          : Endif
If dim(WINDEX)<1   Local Integer WINDEX       : Endif
If dim(WMAXI)<1    Local Integer WMAXI        : Endif
If dim(W0)<1       Local Integer W0           : Endif
If dim(W1)<1       Local Integer W1           : Endif
If dim(W2)<1       Local Integer W2           : Endif
If dim(WDATE)<1    Local Date    WDATE        : Endif
If dim(WPERCOD)<1  Local Integer WPERCOD      : Endif
If dim(WJOUR)<1    Local Integer WJOUR        : Endif
If dim(WSEMAINE)<1 Local Integer WSEMAINE     : Endif
If dim(WMOIS)<1    Local Integer WMOIS        : Endif
If dim(WTRIMEST)<1 Local Integer WTRIMEST     : Endif
If dim(WSEMESTR)<1 Local Integer WSEMESTR     : Endif
If dim(WANNEE)<1   Local Integer WANNEE       : Endif
If dim(WLIBELLE)<1 Local Char    WLIBELLE(15) : Endif
If dim(WDATDEB)<1  Local Date    WDATDEB      : Endif
If dim(WDATFIN)<1  Local Date    WDATFIN      : Endif
#-----

WPERCOD=[M:SMVG]PERCOD
Effzo [SMVG]10
Raz [M:SMVG]NBLIG


#-----
For [STJ] Where evalue([M:SMVG]WFIL1)
&             & evalue([M:SMVG]WFIL2)
&             & evalue([M:SMVG]WFILF)
&             & evalue([M:SMVG]WFILSPE)
&             & [F:STJ]IPTDAT>=[M]DATDEB
&             & [F:STJ]IPTDAT<=[M]DATFIN
&         With Nohint
  #----- Détermination de la période -----#
  WDATE=[F:STJ]IPTDAT : Gosub DETERMINE_PERIODE
  #-----
  If [M:SMVG]NBLIG>0
    I=find(WINDEX,[M:SMVG]INDEXPER(0..[M:SMVG]NBLIG-1))
  Else
    I=0
  Endif
  If I=0
    If [M:SMVG]NBLIG<dim([M:SMVG]PERIODE)
      J=[M:SMVG]NBLIG
      [M:SMVG]DAT     (J)=[F:STJ]IPTDAT
      [M:SMVG]INDEXPER(J)=WINDEX
      [M:SMVG]PERIODE (J)=WLIBELLE
      If [F:STJ]QTYSTU < 0
         [M:SMVG]QTYISS (J) = [F:STJ]QTYSTU * -1
      Else
         [M:SMVG]QTYRCP (J) = [F:STJ]QTYSTU 
      Endif
      [M:SMVG]NBLIG+=1
    Endif
  Else
      If [F:STJ]QTYSTU < 0
         [M:SMVG]QTYISS (I-1) += [F:STJ]QTYSTU * -1
      Else
         [M:SMVG]QTYRCP (I-1) += [F:STJ]QTYSTU 
      Endif
  Endif  
Next

#----- If faut créer les périodes manquantes -----#
WDATDEB=[M:SMVG]DATDEB
WDATFIN=[M:SMVG]DATFIN
Gosub PERIODES_MANQUANTES

Sorta [M:SMVG]NBLIG [M:SMVG]NBLIG Order By [M:SMVG]INDEXPER(indice)
#-----
Affzo [SMVG]10
Return



####################################################################################
# FGRAPHSMV2 : Graphique : Nombre mouvements                          HCB 27/12/06 #
####################################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_FGRAPHSMV2
Local Integer  SAVNOLIGN   : SAVNOLIGN=nolign
