Local Char     WFIL1  (250)
Local Char     WFIL2  (250)
Local Char     WFILF  (250)
Local Char     WFILX  (250)
Local Char     WFILSPE(250)
Local Date     SAVDATDEB
Local Date     SAVDATFIN
Local Integer  WPERCOD
Local Integer  WPERNBR
Local Char     WFCY(GLONFCY)

#-----
If !clalev([F:STJ])  Local File STOJOU  [STJ] : Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_FGRAPHSMV2
Raz [M:SMVG]
