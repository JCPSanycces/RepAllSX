#<AdxTL>@(#)0.0.0.0 $Revision$
# Class CCMIMPITM
# Issue 109096/2 - 2015-11-24 by BAKHA : For non-conformance, send email to actioners

$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
        When "AINIT"                            : Gosub INITIALISE
        When "CREATE_IMPACT_STOCK_BATCH"        : Gosub CREATE_IMPACT_STOCK_BATCH
        When "CREATE_IMPACT_STOCK"              : Gosub CREATE_IMPACT_STOCK
        When "CREATE_IMPACT_STOCK_LINES"        : Gosub CREATE_IMPACT_STOCK_LINES
        When "VALIDATE_IMPLEMENT"               : Gosub VALIDATE_IMPLEMENT
        When "UPDATE_STATUS"                    : Gosub UPDATE_STATUS
        When "AUPDATE_AFTER"                    : Gosub NOTIFY_ACTIONER
      Endcase
Endcase

Return

# --------------------------------------------------
# Initialise Sales order plan Header properties.
$INITIALISE
   Local Integer LINES

  this.HOLD       = 1 # No
  this.IMPLEMENT  = 1 # No
  this.PHYSTO     = 0
  this.PHYALL     = 0
  this.SALSTO     = 0
  this.ORDSTO     = 0
  this.TOTALLINES = 0
  this.ITMPLASTA  = 4

  this.IMPACTANAL = 0

Return

# ------------------------------------------------------
# Operation: CREATE_IMPACT_STOCK_BATCH
#
# Called from Impact Analysis summary links.
# Instantiate Batch Server process, Task: CCMIMPBATT.
#
$CREATE_IMPACT_STOCK_BATCH

  Local Integer LOCAL_STATUS
  Local Instance IMPITM Using C_CCMIMPITM
  IMPITM = NewInstance C_CCMIMPITM AllocGroup null

  Local Char    AFOLDER(30)
  Local Char    USER(30)
  Local Char    TASKNAME(30)
  Local Date    DAT
  Local Char    TIM(5)
  Local Char    TBPAR(30)(1..10)
  Local Char    TBVAL(250)(1..10)
  Local Integer NBPAR
  Local Integer TASKID
  Local Char    TASKMESSAGE(250)

  Local Integer LTIME
  Local Char    CTIME(4)

  # Read impact header
  LOCAL_STATUS = fmet IMPITM.AREAD(CRID)

  ASTATUS = CST_AOK

  If (IMPITM.IMPACTANAL <> 1)

    LTIME = time : CTIME = format$("N00:2", int(LTIME/3600)) +format$("N00:2", int((LTIME -(int(LTIME/3600) *3600)) /60))

    USER       = IMPITM.ACTX.USER
    TASKNAME  = "CCMIMPBATT"
    DAT       = date$
    TIM       = CTIME
    NBPAR = 1  : TBPAR(NBPAR) = "CRID"        : TBVAL(NBPAR) = CRID
    NBPAR += 1 : TBPAR(NBPAR) = "TRANSACTION" : TBVAL(NBPAR) = "11"

    # Impact Analysis 'Created' flag = "No" ...
    IMPITM.IMPACTANAL = 1
    LOCAL_STATUS = fmet IMPITM.AUPDATE()

    ASTATUS = func ASYRMNGTREQ.CRERQT(IMPITM.ACTX,
&                              IMPITM.ACTX.AFOLDER,
&                              USER,
&                              TASKNAME,
&                              DAT,
&                              TIM,
&                              TBPAR,
&                              TBVAL,
&                              NBPAR,
&                              TASKID,
&                              TASKMESSAGE)

  Endif

  FreeGroup IMPITM
  ARET_VALUE = ASTATUS

Return

$CREATE_IMPACT_STOCK
  Local Integer LOCSTATUS
  Local File CCMIMPITMDET [CCMITMD]
  Local Instance SELCHGREQ Using C_CCMCHGREQ
  Local Instance SELIMPITM Using C_CCMIMPITM

  # Begin a Database Transaction ...
  Local Integer TRANSACTION_PENDING
  TRANSACTION_PENDING = adxlog
  If (adxlog = 0)
    Trbegin [CCMITMD]
  Endif

 # Read CHANGE REQUEST
  SELCHGREQ = NewInstance C_CCMCHGREQ AllocGroup null
  LOCSTATUS = fmet SELCHGREQ.AREAD(CRID)

  # Read sales order header
  SELIMPITM = NewInstance C_CCMIMPITM AllocGroup null
  LOCSTATUS = fmet SELIMPITM.AREAD(CRID)

  # If request in review, and refresh can be done
  If (LOCSTATUS = [V]CST_AOK and SELCHGREQ.CRSTATUS = 2 and SELIMPITM.HOLD <> 2)

    # Clear lines ...
    Delete [CCMITMD] Where CRID = SELIMPITM.CRID

    SELIMPITM.HOLD = 1      # No
    SELIMPITM.IMPLEMENT = 1 # No
    SELIMPITM.PHYSTO = 0
    SELIMPITM.PHYALL = 0
    SELIMPITM.SALSTO = 0
    SELIMPITM.ORDSTO = 0
    SELIMPITM.TOTALLINES  = 0

    LOCSTATUS = fmet SELIMPITM.CREATE_IMPACT_STOCK_LINES (SELIMPITM.CRID, SELCHGREQ.PRODUCT, SELCHGREQ.ECCVALMAJ, SELCHGREQ.ECCVALMIN)

  Endif

    #If lines exist then set the status to Plan else Not applicable
    If SELIMPITM.TOTALLINES >= 1
      SELIMPITM.ITMPLASTA = 1 # Plan
    Else
      SELIMPITM.ITMPLASTA = 4 # Not applicable
      # If Plan Status is 4 (None) then Implement flag is always ticked ...
      SELIMPITM.IMPLEMENT = 2
    Endif

    SELIMPITM.IMPACTANAL = 2

    LOCSTATUS= fmet SELIMPITM.AUPDATE()

  # Commit or Rollback the Database Transaction ...
  If (TRANSACTION_PENDING = 0)
    If (ASTATUS <= [V]CST_AINFO)
      Commit
    Else
      Rollback
    Endif
  Endif

  FreeGroup SELIMPITM
  FreeGroup SELCHGREQ
  LogicClose File [CCMITMD]

Return

#  create new stock by site lines

$CREATE_IMPACT_STOCK_LINES

  Local Instance SELCHGREQ Using C_CCMCHGREQ
  SELCHGREQ = NewInstance C_CCMCHGREQ AllocGroup null
  Local Char CRITERIA(250)
  Local Integer I, LOCSTATUS
  #MGG X3-38337_Product_Code_length_&_GLONITM_function
  Local Char LAST_ITMREF(GLONITM) : LAST_ITMREF = ""
  #END MGG X3-38337_Product_Code_length_&_GLONITM_function
  Local Date    WDATREF             : WDATREF=AVOID.ADATE
  Local Integer WLSTTYP             : WLSTTYP=3     # 1=first level, 2=last level, 3= multi-level
  Local Integer WALTTYPSTR          : WALTTYPSTR=1  # 1=Sales (kit), 2=WO (Manufacturing), 3=EO (subcontracting BOM)
  Local Integer WALTTYPEND          : WALTTYPEND=3  # 1=Sales (kit), 2=WO (Manufacturing), 3=EO (subcontracting BOM)
  Local Integer WALTSTR             : WALTSTR=0     # From alt number : 0=all alternatives
  Local Integer WALTEND             : WALTEND=0     # From alt number : 0=all alternatives
  Local Char    MYCRIT(250)         : MYCRIT="1=1"  # No particular Where criteria
  Local Char    MYFOR (GLONFOR)     : MYFOR=""      # Reference of a Formula in table TABFOR [F:TFO] with FORTYP=31
  Local Integer WRET
  Local Integer LINE_NUMBER     : LINE_NUMBER = 0
  Local File ITMMASTER [ITM]
  Local File ITMCATEG [ITG]

  #CATUA X3-38562.sn Set Product Code length to GLONITM
  Local Char SUB_LINES_PRODUCT(GLONITM)
  #CATUA X3-38562.en
  Local Char SUB_ECCVALMAJ(10)
  Local Char SUB_ECCVALMIN(10)

  # Create lines for Change Request Product ...
  SUB_LINES_PRODUCT = PRODUCT
  SUB_ECCVALMAJ = MAJOR_VERSION
  SUB_ECCVALMIN = MINOR_VERSION
  Gosub CREATE_IMPACT_STOCK_SUB_LINES

  # Read Product and Product Category and check for Semi-finished good
  Read [ITM]ITM0 = PRODUCT
  If fstat = 0

  Read [ITG]ITG1 = [F:ITM]TCLCOD; ""
  If fstat = 0 and [F:ITG]SALFLG = 2

      # For CCM: first calculate
      Local File BOMWUS [BOW]

      Call CALCULATE_WHERE_USED_ECC(this.ACTX,PRODUCT,MAJOR_VERSION, MINOR_VERSION, WDATREF,WLSTTYP,WALTTYPSTR,WALTTYPEND,WALTSTR,WALTEND,MYCRIT,MYFOR,WRET) From SUBBOW_SYRA

      # For CCM: retrieve temporary result lines in BOMWUS tables
      For [BOW] Where CREUSR = this.ACTX.USER & BOWUID = adxuid(1)
        If ([F:BOW]ITMREF <> LAST_ITMREF)
          SUB_LINES_PRODUCT = [F:BOW]ITMREF

          # if version managed

          If (fmet SELCHGREQ.IS_PRODUCT_VERSION_MANAGED(SUB_LINES_PRODUCT) > 1)
            Local File ECCVAL [EVL]
            # for each version, create lines
            CRITERIA = " 1=1 "
            If [F:BOW]BOMSTRDAT<>[0/0/0]
              CRITERIA+=" & STRDAT>=["+format$(GFMD,[F:BOW]BOMSTRDAT)+"]"
            Endif
            If [F:BOW]BOMENDDAT<>[0/0/0]
              CRITERIA+=" & STRDAT<=["+format$(GFMD,[F:BOW]BOMENDDAT)+"]"
            Endif

            For [EVL] Where ITMREF=[F:BOW]ITMREF & ECCTYP=[F:BOW]BOMALTTYP & BOMALT=[F:BOW]BOMALT  & evalue(CRITERIA)
              SUB_ECCVALMAJ = [F:EVL]ECCVALMAJ
              SUB_ECCVALMIN = [F:EVL]ECCVALMIN
              Gosub CREATE_IMPACT_STOCK_SUB_LINES
            Next
            Close Local File [EVL]
          Else
            SUB_ECCVALMAJ = ""
            SUB_ECCVALMIN = ""
            Gosub CREATE_IMPACT_STOCK_SUB_LINES
          Endif
        Endif
        LAST_ITMREF = [F:BOW]ITMREF
      Next

      # For CCM: delete temporary result lines in BOMWUS tables
      Delete [BOW] Where CREUSR = this.ACTX.USER & BOWUID = adxuid(1)

      Close Local File [BOW]

    Endif
  Endif

  this.TOTALLINES = LINE_NUMBER

  Close Local File [ITM]
  Close Local File [ITG]
  FreeGroup SELCHGREQ
Return

# For a product, find all sales order lines, and write to
# Impact sales order lines table
#

$CREATE_IMPACT_STOCK_SUB_LINES
  Local Integer LOCSTATUS
  Local Integer STAT
  Local File ITMMVT [ITV]
  Local Instance CCMIMPITMDET Using C_CCMIMPITMDET
  CCMIMPITMDET = NewInstance C_CCMIMPITMDET AllocGroup null

  # create new sales order lines
  For [ITV]ITV0 Where ITMREF = SUB_LINES_PRODUCT

    LOCSTATUS = fmet CCMIMPITMDET.AINIT()

    LINE_NUMBER += 1

    CCMIMPITMDET.CRID = CRID
    CCMIMPITMDET.LINENO = LINE_NUMBER
    CCMIMPITMDET.SORTSEQ = LINE_NUMBER
    CCMIMPITMDET.STOFCY = [F:ITV]STOFCY
    CCMIMPITMDET.ITMREF = SUB_LINES_PRODUCT

    Call STOECCVAL (SUB_LINES_PRODUCT,CCMIMPITMDET.STOFCY, SUB_ECCVALMAJ, SUB_ECCVALMIN, CCMIMPITMDET.FCYPHYSTO) From STKLIB

    # calculate total allocated qty
    CCMIMPITMDET.FCYPHYALL = 0
    Local File STOCK [STO]
    Local Char CRITERIA(250)

    CRITERIA = " 1=1 "
    If (SUB_ECCVALMAJ <> "")
        CRITERIA += " and [F:STO]ECCVALMAJ = SUB_ECCVALMAJ"

    Endif

    Filter [STO] Where [F:STO]ITMREF = SUB_LINES_PRODUCT and evalue(CRITERIA)
    For [STO]STO0
      CCMIMPITMDET.FCYPHYALL += [F:STO]CUMALLQTY
    Next
    LogicClose File [STO]

    # calculate total order qty
    CCMIMPITMDET.FCYSALSTO = 0
    Local File ORDERS [ORD]

    CRITERIA = " 1=1 "
    If (SUB_ECCVALMAJ <> "")
        CRITERIA += " and [F:ORD]ECCVALMAJ = SUB_ECCVALMAJ"

      If (SUB_ECCVALMIN <>  "")
          CRITERIA += " and [F:ORD]ECCVALMIN = SUB_ECCVALMIN"

      Endif
    Endif

    Filter [ORD] Where [F:ORD]ITMREF = SUB_LINES_PRODUCT and [F:ORD]WIPTYP = 1 and
&                      [F:ORD]WIPSTA = 1 and
&                      evalue(CRITERIA)

    For [ORD]ORD0
        CCMIMPITMDET.FCYSALSTO += ([F:ORD]EXTQTY - [F:ORD]CPLQTY)
    Next
    Filter [ORD]

    # calculate total On order qty
    CCMIMPITMDET.FCYORDSTO = 0
    Filter [ORD] Where [F:ORD]ITMREF = SUB_LINES_PRODUCT and [F:ORD]WIPTYP = 2 and
&                      [F:ORD]WIPSTA = 1 and
&                      evalue(CRITERIA)

    For [ORD]ORD0
      CCMIMPITMDET.FCYORDSTO += ([F:ORD]EXTQTY - [F:ORD]CPLQTY)
    Next
    Filter [ORD]
    LogicClose File [ORD]

    CCMIMPITMDET.ECCVALMAJ = SUB_ECCVALMAJ
    CCMIMPITMDET.ECCVALMIN = SUB_ECCVALMIN
    CCMIMPITMDET.BLOCK = 1       # 1 = No
    CCMIMPITMDET.TRANTYPE = 11    # 11 = Stock
    CCMIMPITMDET.LINESTATUS = 1   # 1 = Pending
    CCMIMPITMDET.STARTDATE= AVOID.ADATE
    CCMIMPITMDET.ENDDATE= AVOID.ADATE
    CCMIMPITMDET.COMPLETEDATE= AVOID.ADATE
    CCMIMPITMDET.ACTIONID = ""
    CCMIMPITMDET.ACTIONER = ""
    CCMIMPITMDET.COMMENT = ""
    LOCSTATUS = fmet CCMIMPITMDET.AINSERT()

    # Update summary totals
    this.PHYSTO += CCMIMPITMDET.FCYPHYSTO
    this.PHYALL += CCMIMPITMDET.FCYPHYALL
    this.SALSTO += CCMIMPITMDET.FCYSALSTO
    this.ORDSTO += CCMIMPITMDET.FCYORDSTO
  Next

  FreeGroup CCMIMPITMDET
  LogicClose File [ITV]

Return

# -------------------------------------------------------------------------------
# Update Sales Oreder Detail Plan 'header' status.
#
# Set status to:
#
# 4 'Not applicable'  ... if (No sales order lines) or (No actionable sales order lines and Planning complete),
# 3 'Complete'        ... if (All actionable sales order lines are complete),
# 2 'Implement'       ... if (Actionable sales order lines and Planning complete),
# 1 'Plan'            ... if (Planning is not complete).

$UPDATE_STATUS

  Local Integer STAT, ACTIONLINES, LINESCOMP

  # Count number of action lines ...
  Local File CCMIMPITMDET [CCMITMD]
  Filter [CCMITMD] Where CRID = this.CRID and ACTIONID <> ""
  ACTIONLINES = rowcount([CCMITMD])

  # Count number of action lines completed ...
  Filter [CCMITMD] Where CRID = this.CRID and LINESTATUS = 3
  LINESCOMP = rowcount([CCMITMD])

  Filter [CCMITMD]
  LogicClose File [CCMITMD]

  If (this.TOTALLINES = 0) or
&    (ACTIONLINES = 0 and this.IMPLEMENT = 2)
    this.ITMPLASTA = 4
  Elsif (ACTIONLINES <> 0 and ACTIONLINES = LINESCOMP)
    this.ITMPLASTA = 3
  Elsif (this.IMPLEMENT = 2)
    this.ITMPLASTA = 2
  Else
    this.ITMPLASTA = 1
  Endif

  ARET_VALUE = CST_ATRUE

Return

# -------------------------------------------------------------------------------
# "Planning complete" flag validation ...
$VALIDATE_IMPLEMENT
  Local Integer ACTIONLINES, LOCSTATUS

  # count number of action lines
  Local File CCMIMPITMDET [CCMITMD]
  Filter [CCMITMD] Where CRID = this.CRID and ACTIONID <> ""
  ACTIONLINES = rowcount([CCMITMD])
  Filter [CCMITMD]
  LogicClose File [CCMITMD]

  ASTATUS = CST_AOK

  If (this.snapshot.IMPLEMENT = 1 and this.IMPLEMENT = 2)
    If (this.TOTALLINES > ACTIONLINES)
#      LOCSTATUS = fmet this.ASETERROR ("IMPLEMENT", mess(62,2038,1), CST_AINFO)
      LOCSTATUS = fmet this.ASETERROR ("", mess(62,2038,1), CST_AINFO)

    Endif
  Endif

 ARET_VALUE = ASTATUS

Return

#
# --------------------------------------------------
# FUNCTION NAME:        NOTIFY_ACTIONER
# FUNCTION DESCRIPTION: Notify Actioner
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$NOTIFY_ACTIONER

  Local Instance CHANGE_REQUEST Using C_CCMCHGREQ
  CHANGE_REQUEST = NewInstance C_CCMCHGREQ AllocGroup null
  Local File CCMIMPITMDET [ITMDET]
  Local Char LAST_ACTIONER(5)
  Local Integer STAT
  Local Integer EMAIL_TYPE
  Local Char SUBJECT(250)
  Local Clbfile BODY(0), OTHER_BODY(0)
  Local Integer AC_EMAIL : AC_EMAIL = CST_AFALSE
# Issue 109096/2 - send e-mails to actioners
  Local Integer SENDEMAIL : SENDEMAIL = CST_AFALSE
  STAT = fmet CHANGE_REQUEST.AREAD(this.CRID)

  If (CHANGE_REQUEST.NCSREC = 2)
    # Issue X3-76268 - 2018-02-13 by JUSYN : Remove/deactivate email notification NCS
#    If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "NCSEMAILAC") <> 1 and
#&     this.snapshot.IMPLEMENT = 1 and this.IMPLEMENT = 2)
#
#      SENDEMAIL = CST_ATRUE
#      EMAIL_TYPE = 3713  # Actioner
#      BODY(0) = AVOID.ACLOB
#      OTHER_BODY(0) = AVOID.ACLOB
#      Append OTHER_BODY, mess(11,2039,1) +chr$(10)
#      STAT = fmet CHANGE_REQUEST.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, OTHER_BODY, "NCSPLAITM")
#    Endif
    # End issue X3-76268
  Else
# End issue 109096/2

    If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMEMAILAC") <> 1 and
&     this.snapshot.IMPLEMENT = 1 and this.IMPLEMENT = 2)

      EMAIL_TYPE = 2066  # Actioner
      SENDEMAIL = CST_ATRUE
      BODY(0) = AVOID.ACLOB
      OTHER_BODY(0) = AVOID.ACLOB
      Append OTHER_BODY, mess(11,2039,1) +chr$(10)
      STAT = fmet CHANGE_REQUEST.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, OTHER_BODY, "CCMPLAITM")
    Endif
# Issue 109096/2
  Endif

  If (SENDEMAIL = CST_ATRUE)
# End issue 109096/2

    Filter [ITMDET] Where CRID = this.CRID and ACTIONER <> "" Order By ACTIONER
    For [ITMDET]
      If ([F:ITMDET]ACTIONER <> LAST_ACTIONER and
&         [F:ITMDET]ACTIONER <> this.ACTX.USER)

        STAT = fmet CHANGE_REQUEST.SEND_EMAIL(this.ACTX.USER, [F:ITMDET]ACTIONER, "", SUBJECT, BODY)

        If (STAT = CST_AOK)
          AC_EMAIL = CST_ATRUE
        Endif

        LAST_ACTIONER = [F:ITMDET]ACTIONER

      Endif
    Next

    If (AC_EMAIL = CST_ATRUE)
      ASTATUS = fmet this.ASETERROR("", mess(60,2038,1), CST_AINFO)
    Endif

  Endif

  LogicClose File [ITMDET]
  FreeGroup CHANGE_REQUEST

Return

$PROPERTIES
Case [L]CURPRO
Endcase
Return


