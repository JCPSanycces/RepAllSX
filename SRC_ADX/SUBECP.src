######################################################################################
## Etiquette [M:ECP0] : Entête
######################################################################################

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Raz [F:ECT]CTRNUM
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer J
Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=VALEUR
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If !fstat
 [M:ECP0]FCY     = [F:HRCTR]ETRFCY
 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 [M:ECP0]CPY=[F:FCY]LEGCPY : Affzo [M:ECP0]CPY
 Affzo FCY, CPY
 # FQ81085 - MABON 05/07/12 - Find the good local menu for the title, depending on the site
 Local Char NUMLIB(10)
 Call PARAM([M:ECP0]FCY,"CIVIL",NUMLIB) From ADOVAL
 [M:ECP0]NOLIB=val(NUMLIB)
 If [F:HRCTR]CIVCTR>0 Then [M:ECP0]CIVCTRA=mess([F:HRCTR]CIVCTR,val(NUMLIB),1) : Endif
 # End MABON
 # FQ81085 - 22/11/13 - Find the good local menu for the marital status, depending on the site
 Local Char NUMLIB(10)
 Call PARAM([M:ECP0]FCY,"SITFAM",NUMLIB) From ADOVAL
 [M:ECP1]NOLIBM=val(NUMLIB)
 If [F:ID]SITFAM>0 Then [M:ECP1]SITFAMA=mess([F:ID]SITFAM,val(NUMLIB),1) : Endif
 # End FQ81085
 #LIPET - X3-29323 - 15-03-2017 - START
 Call PARAM([M:ECP0]FCY,"CIVIL",NUMLIB) From ADOVAL
 [M:ECP0]NOLIB=val(NUMLIB)
# If [F:ID]CIV>0 Then [M:ECP0]CIVA=mess([F:ID]CIV,val(NUMLIB),1) : Endif : # only v7-v8
 If [F:ID]CIV>0 Then [M:ECP0]CIVCTRA=mess([F:ID]CIV,val(NUMLIB),1) : Endif
 #LIPET - X3-29323 - 15-03-2017 - END
 #59278
 If func AFNC.ACTIV("FRT")
  [M:ECP0]CAT2483 = [F:HRCTR]CATFRT
  Affzo CAT2483
 Endif
 Read [ACV]CODACT="CAR"
 If !fstat & [F:ACV]FLACT=2
  [M:ECP0]CTRNUM = VALEUR
  Raz [M:ECP2],[M:ECP3],[M:ECP4]
  Gosub CHARGE_EVAL
  Gosub CHARGE_POSTE
  Gosub CHARGE_CPC
  Gosub CHARGE_CPE
  Affzo [ECP2]
  Affzo [ECP3]
  Affzo [ECP4]
 Endif
Endif
End


######################################################################################
## Etiquette [M:ECP2] : Compétences
######################################################################################

Subprog C_NBRCPC
Local Integer I
# Suppression interdite sur les compétences antérieures héritées (non initiale et non manuelle et non poste)
#40643
#If status=65 & [M:ECP2]FLGOLD(nolign-1)=2 & [M:ECP2]ORICPC(nolign-1)<>1 & [M:ECP2]ORICPC(nolign-1)<>5
If status=65 & [M:ECP2]FLGOLD(nolign-1)=2 & !find([M:ECP2]ORICPC(nolign-1),1,4,len(mess(0,10939,1)))
 # Il est interdit de supprimer des compétences mises à jour automatiquement
 GMESSAGE = mess(19,10720,1)
 mkstat = 2 : End
Endif
# On stocke dans le tableau invisible, les compétences supprimées
#40643
#If status=65 & [M:ECP2]FLGOLD(nolign-1)=2 & ([M:ECP2]ORICPC(nolign-1)=1 | [M:ECP2]ORICPC(nolign-1)=5)
If status=65 & [M:ECP2]FLGOLD(nolign-1)=2 & find([M:ECP2]ORICPC(nolign-1),1,4,len(mess(0,10939,1)))
 If [M:ECP2]NBRDLT>=dim([M:ECP2]CPCDLT)
  # Veuillez enregistrer les modifications avant de continuer.
  GMESSAGE = mess(558,9900,1)
  mkstat=2 : End
 Endif
 [M:ECP2]CPCDLT([M:ECP2]NBRDLT) = [M:ECP2]CPC(nolign-1)
 [M:ECP2]DATDLT([M:ECP2]NBRDLT) = [M:ECP2]CPCDAT(nolign-1)
 [M:ECP2]NBRDLT +=1
Endif
End

Subprog AS_CPC(VALEUR)
Variable Char    VALEUR()
# Modification de la compétence interdite si c'est une compétence antérieure
If [M:ECP2]FLGOLD(nolign-1)=2
 mkstat=2 : End
Endif
End

Subprog AM_CPC(VALEUR)
Variable Char    VALEUR()

Call UNICITE(VALEUR,[M]CPC) From OBJDIV
If mkstat : End : Endif

# Afficher le dernier niveau acquis pour cette compétence
Filter [CPE] Where [CPE]REFNUM=[M:ECP0]REFNUM & [CPE]CPC=VALEUR
Read [CPE]CPE1 Last
Filter [CPE]
If !fstat
 [M:ECP2]LEVCPC(nolign-1) = [F:CPE]LEVCPC
Else
 Call BASNIVCPC(VALEUR,[M:EEC2]LEVCPC(nolign-1)) From SUBCPC
Endif
End

Subprog AS_LEVCPC(VALEUR)
Variable Char    VALEUR()
Local    Integer I,J
If VALEUR=""
 Call LECTURE("CPC",[M:ECP2]CPC(nolign-1),"") From CONTOBJ
 If !fstat
  Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
  If !fstat
   I = find("",[F:HRSCA]LEV)
   J = find(min([F:HRSCA]LEVREF(0..I-2)),[F:HRSCA]LEVREF(0..I-2))
   If J : VALEUR = [F:HRSCA]LEV(J-1) : Endif
  Endif
 Endif
Endif
End

Subprog AM_LEVCPC(VALEUR)
Variable Char    VALEUR()
# Modif de l'origine d'une compétence non saisie => on passe l'origine à Manuelle
# JML 13/09/10 ML passe de 2402 à 2400
If [M:ECP2]ORICPC(nolign-1)<>1 | [M:ECP2]ORICPC(nolign-1)<>len(mess(0,10937,1))
 [M:ECP2]ORICPC(nolign-1) = len(mess(0,10937,1))
Endif
[M:ECP2]LEVREF(nolign-1) = func SUBECP.CPC_LEVREF([M:ECP2]CPC(nolign-1),VALEUR)
End

Subprog AS_CPCDAT(VALEUR)
Variable Date    VALEUR
# Modification de la date interdite si c'est une compétence antérieure
If [M:ECP2]FLGOLD(nolign-1)=2
 mkstat=2 : End
Endif
If VALEUR=[0/0/0] : VALEUR = datesyst : Endif
End

Subprog AS_ORICPC(VALEUR)
Variable Integer    VALEUR()
# Modification de l'origine de la compétence interdite si
# la compétence antérieure n'est ni initiale ni manuelle
If [M:ECP2]FLGOLD(nolign-1)=2 & VALEUR<>1 & VALEUR<>len(mess(0,10939,1))
 mkstat=2 : End
Endif
Raz GMENLOC
GMENLOC(2) = 1 : # Stage
GMENLOC(3) = 1 : # Evaluation
GMENLOC(4) = 1 : # Poste
GMENLOC(5) = 1 : # Emploi type
End
###############
Subprog C_NBRVAL
Local Integer I
Local Integer NOL #  SEGAY 05/06/12 - FQ82661
# JML 13/09/10 CG now we can delete
# Suppression interdite sur les compétences antérieures héritées (non initiale et non manuelle et non poste)
#If status=65 & [M:ECP2]FLGOLDVAL(nolign-1)=2 & !find([M:ECP2]ORICPCVAL(nolign-1),1,4,len(mess(0,10939,1)))
# # Il est interdit de supprimer des compétences mises à jour automatiquement
# GMESSAGE = mess(19,10720,1)
# mkstat = 2 : End
#Endif
# On stocke dans le tableau invisible, les compétences supprimées (non initiale et non manuelle et non poste)
# FQ87672 - MABON 01/02/13 - Message si tentative suppression compétences héritées
#If status=65 & [M:ECP2]FLGOLDVAL(nolign-1)=2 & find([M:ECP2]ORICPCVAL(nolign-1),1,4,len(mess(0,2402,1)))
If status=65 & [M:ECP2]FLGOLDVAL(nolign-1)=2 Then
  If !find([M:ECP2]ORICPCVAL(nolign-1),1,4,len(mess(0,2402,1))) Then
   # Il est interdit de supprimer des compétences mises à jour automatiquement
   GMESSAGE = mess(19,720,1)
   mkstat = 2 : End
  Else
   If [M:ECP2]NBRDLTVAL>=dim([M:ECP2]CPCDLTVAL)
    # Veuillez enregistrer les modifications avant de continuer.
    GMESSAGE = mess(558,9900,1)
    mkstat=2 : End
   Endif
   #  SEGAY 05/06/12 - FQ82661
  # [M:ECP2]CPCDLTVAL([M:ECP2]NBRDLT) = [M:ECP2]CPCVAL(nolign-1)
  # [M:ECP2]DATDLTVAL([M:ECP2]NBRDLT) = [M:ECP2]CPCDATVAL(nolign-1)
   [M:ECP2]CPCDLTVAL([M:ECP2]NBRDLTVAL) = [M:ECP2]CPCVAL(nolign-1)
   [M:ECP2]DATDLTVAL([M:ECP2]NBRDLTVAL) = [M:ECP2]CPCDATVAL(nolign-1)
   [M:ECP2]NBRDLTVAL +=1
  Endif
Endif
#  SEGAY 05/06/12 - FQ82661 - Annulation multiple
If status=68 or status=83
 For NOL=nolign-1 To nolign1-1
  # FQ87672 - MABON 01/02/13 - Message si tentative suppression compétences héritées
#  If [M:ECP2]FLGOLDVAL(NOL)=2 & find([M:ECP2]ORICPCVAL(NOL),1,4,len(mess(0,2402,1)))
  If [M:ECP2]FLGOLDVAL(NOL)=2 Then
    If !find([M:ECP2]ORICPCVAL(NOL),1,4,len(mess(0,2402,1)))
     # Il est interdit de supprimer des compétences mises à jour automatiquement
     GMESSAGE = mess(19,720,1)
     mkstat = 2 : Break
    Else
     If [M:ECP2]NBRDLTVAL>=dim([M:ECP2]CPCDLTVAL)
      # Veuillez enregistrer les modifications avant de continuer.
      GMESSAGE = mess(558,9900,1)
      mkstat=2 : Break
     Endif
     [M:ECP2]CPCDLTVAL([M:ECP2]NBRDLTVAL) = [M:ECP2]CPCVAL(NOL)
     [M:ECP2]DATDLTVAL([M:ECP2]NBRDLTVAL) = [M:ECP2]CPCDATVAL(NOL)
     [M:ECP2]NBRDLTVAL +=1
    Endif
  Endif
 Next
Endif

End

Subprog AS_CPCVAL(VALEUR)
Variable Char    VALEUR()
If [M:ECP2]FLGOLDVAL(nolign-1)=2
 mkstat=2 : End
Endif
End
