Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
If dim(GCURLEG2)>0    : Kill GCURLEG2         : Endif
Return

###################################################################################################################
# JML 28/07/10 LOT P02
$DECLARE_PARAM
Local Integer NB_PARAM
NB_PARAM = dim([M:ECP6]LIBSAL)
# Dans le cas où la dimension dans l'écran n'est pas bonne
If NB_PARAM < 6
  Return
Endif
Local Char    P_PARAM(GLONADP)(NB_PARAM)
Local Char    P_PARAM2(GLONADI)(NB_PARAM)
Local Char    P_FRMSAL(type([M:ECP6]FRMSAL)-10)(NB_PARAM)
Local Char    P_LIBSAL(type([M:ECP6]LIBSAL)-10)(NB_PARAM)
Local Char    P_SALAIRE(10)

Raz P_PARAM, P_FRMSAL, P_LIBSAL, P_PARAM2
P_PARAM(0) = "VARSAL"  : P_PARAM2(0) = GCURLEG
P_PARAM(1) = "VARSAL2" : P_PARAM2(1) = GCURLEG
P_PARAM(2) = "VARSAL3" : P_PARAM2(2) = GCURLEG
P_PARAM(3) = "RUBSAL"  : P_PARAM2(3) = GCURLEG
P_PARAM(4) = "RUBSAL2" : P_PARAM2(4) = GCURLEG
P_PARAM(5) = "RUBSAL3" : P_PARAM2(5) = GCURLEG

For L_IJ=0 To 5
 Raz P_SALAIRE
 Call PARAM(P_PARAM2(L_IJ), P_PARAM(L_IJ) , P_SALAIRE) From ADOVAL
 If P_SALAIRE<>""
  P_FRMSAL(L_IJ) = "NP:9.3#"
  If L_IJ<3
   #Read [VRA]VRA0=P_SALAIRE;GCURLEG
   #If !fstat : P_LIBSAL(L_IJ) = [F:VRA]DESSHO : Endif
   Call LECTEXTRA( P_LIBSAL(L_IJ),"VARIA","DESSHO",GCURLEG,P_SALAIRE) From ATEXTRA
  Else
   Call LECTEXTRA(P_LIBSAL(L_IJ),"RUBRIQUE","DESSHO",GCURLEG,P_SALAIRE) From ATEXTRA
  Endif
 Else
  P_FRMSAL(L_IJ) = "-N:9.3#"
  P_LIBSAL(L_IJ) = ""
 Endif : # If P_SALAIRE<>""
Next L_IJ
Return

###################################################################################################################
#LIPET - X3-29323 - 15-03-2017 - START
#FQ96481 - 2426
$FINECP
  # kill globals
  If dim(G_FLXCTR)>0
    Kill G_FLXCTR,G_FLXMAT
  Endif
Return
#LIPET - X3-29323 - 15-03-2017 - END

# JML 28/07/10 LOT P02
$CHARGE_PARAM
For L_IJ=0 To NB_PARAM-1
 Case L_IJ
  When 0 : Chgfmt [M:ECP6]SALVAL  With P_FRMSAL(L_IJ)
  When 1 : Chgfmt [M:ECP6]SALVAL1 With P_FRMSAL(L_IJ)
  When 2 : Chgfmt [M:ECP6]SALVAL2 With P_FRMSAL(L_IJ)
  When 3 : Chgfmt [M:ECP6]SALRUB  With P_FRMSAL(L_IJ)
  When 4 : Chgfmt [M:ECP6]SALRUB1 With P_FRMSAL(L_IJ)
  When 5 : Chgfmt [M:ECP6]SALRUB2 With P_FRMSAL(L_IJ)
 Endcase
 [M:ECP6]LIBSAL(L_IJ) = P_LIBSAL(L_IJ)
Next L_IJ
Return
