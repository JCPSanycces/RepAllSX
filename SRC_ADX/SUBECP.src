#<AdxTL>@(#)0.0.0.0 $Revision$
# JML 26/07/10 Changing Key EPO0 from REFNUM+CTRNUM+NUMLIG to REFNUM+CTRNUM+ORIGINE+DATPOT LOT P01
# JML 28/07/10 LOT P02 Separation of required skills et validate skills
######################################################################################
# Modifications :
#     SEGAY - 24/12/10 - EXI 66105 lot P02 - V6.1 :
#           Test sur trop de compétence
#     SEGAY - 29/12/10 - DM 70239 lot P01 - V6.1
#           Rajout du Profil dans l'onglet carrière (ECP3) + tunel Contrat sur ligne
#     SEGAY - 13/01/11 - BUG 70584+70956 lot P01 - V6.1
#     SEGAY - 11/03/11 - BUG 72311 - V6.1
#            Onglet Stage suivi, afficher  si l’inscription est au moins confirmée
#     SEGAY - 30/03/11 - BUG 72805 - V6.1
#            On ne peut saisir de carrière quand on n'a pas la gestion des temps ni la paye
#     SEGAY - 05/06/12 - BUG 82661 - V6.3
#            Dans l'onglet Compétences, quand on supprime des lignes de compétences validées,
#            celles-ci ne sont pas toujours supprimées.
#     SEGAY - 07/06/12 - BUG 81652 - V6.3
#            Pas de controle sur la date non renseignée sur l'onglet Carrière,
#            WDATPOT écran ECP3. Car à la Validation le contrôle sur le contrat avec date à 0
#            bloque la validation, et si on n'a pas de carrière on ne pouvait pas
#            saisir de Cursus, Ni supprimer toutes les carrières si celles-ci étaient d'Origine
#            manuelle.
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
#     SEGAY - 22/01/13 - BUG 87090 ACTIV CODE CGI (CPC+CPC)sur bas de tableau [M:ECP2]NBRGRA
#     SEGAY - 25/01/13 - BUG 87490 + BUG 87492
#     SEGAY - 19/03/13 - FQ88721 - Suppression historique
######################################################################################

Raz GPILOBJ
Call OBJET("ECP",GBIDC1,"") From GOBJET
End

######################################################################################
## Gestion des carrières
######################################################################################

## Ajout des compétences héritées du poste dans le tableau des compétences [ECP2]
## Règle de gestion :
  # On lit toutes les compétences du poste
  # On regarde si la compétence du poste existe au niveau du salarié :
  #    Si elle n'existe pas on la créee
  #    Si elle existe on compare son niveau avec le niveau de la compétence la plus récente
  #    on la crée SI le niveau est < à celui du poste
  # Suppressions et modifs de compétences au niveau du poste ne sont pas répercutées

$ACTION
Case GBOITE
 When "OECP"   : Gosub ACTION_ECP
 When "CPCHIS" : Gosub ACTION_CPCHIS
Endcase
Return

$ACTION_ECP
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "SETBOUT"    : Gosub SETBOUT
 When "LIENS"      : Gosub LIENS
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "INICRE"     : Gosub INI_CREMOD
 When "INIMOD"     : Gosub INI_CREMOD
 When "APRES_MOD"  : Gosub APRES_MOD
 When "FILTRE"     : Gosub FILTRE
 When "FIN_ACTION" : Gosub FIN_ACTION
 When "APRES_CHOI" : Gosub APRES_CHOI
 When "AVANT_CHOI" : Gosub AVANT_CHOI
 When "AP_FILGAUCHE" : Gosub AP_FILGAUCHE : #SEGAY 13/01/11
 When "FILGAUCHE"  : Gosub FILGAUCHE
 When "FERME"      : Gosub FERME
 When "STYLE"         : Gosub STYLE
 When "APRES_MODIF"   : Gosub APRES_MODIF   : #FQ96481 - 2426
# When "FIN"           : Gosub FINECP        : #FQ96481 - 2426

Endcase
Return
#LIPET - X3-29323 - 15-03-2017 - START
$STYLE
  Gosub SET_STYLE From SUBECPCOM
Return
#LIPET - X3-29323 - 15-03-2017 - END
# Affichage historique des compétences
$ACTION_CPCHIS
Case ACTION
 When "OUVRE"   : Gosub OUVRE_HIS
 When "DEBUT"   : Gosub DEBUT
 When "OK"      : Gosub OKCPCHIS
 When "FIN"     : Gosub FINCPCHIS

Endcase
Return

#LIPET - X3-29323 - 15-03-2017 - START
$APRES_MODIF
  #FQ96481 - 2426
  If zoncou="CTRNUM" and GREP=""
    Read [F:ECT]ECT0 =[M:ECP0]REFNUM;[M:ECP0]CTRNUM
    If !fstat
      Gosub RELIT From GOBJSUB
      Call RESET_IMAGE(3)From GESECRAN
      End
    Endif
  Endif

Return
#LIPET - X3-29323 - 15-03-2017 - END
$OUVRE
