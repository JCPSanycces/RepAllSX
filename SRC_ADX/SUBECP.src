End

Subprog AS_ORICPCVAL(VALEUR)
Variable Integer VALEUR
# Modification de l'origine de la compétence interdite si
# la compétence antérieure n'est ni initiale ni manuelle
If [M:ECP2]FLGOLDVAL(nolign-1)=2 & !find(VALEUR,1,len(mess(0,10939,1)))
 mkstat=2 : End
Endif
Raz GMENLOC
GMENLOC(2) = 1 : # Stage
GMENLOC(3) = 1 : # Evaluation
GMENLOC(4) = 1 : # Poste
GMENLOC(5) = 1 : # Emploi type
End

Subprog AS_CPCDATVAL(VALEUR)
Variable Date    VALEUR
# JML 13/09/10 CG Now it's possible to modify
# Modification de la date interdite si c'est une compétence antérieure
#If [M:ECP2]FLGOLDVAL(nolign-1)=2
# mkstat=2 : End
