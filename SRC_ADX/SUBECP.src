End

Subprog AM_CPCDATVAL(VALEUR)
Variable Date    VALEUR
Local Integer L_IJ
For L_IJ=0 To nolign-2
 If [M:ECP2]CPCVAL(L_IJ)=[M:ECP2]CPCVAL(nolign-1) & [M:ECP2]CPCDATVAL(L_IJ)=VALEUR
  # Compétence déjà saisie à la même date
  GMESSAGE = mess(20,10720,1)
  mkstat = 2 : Break
 Endif
Next L_IJ
If mkstat=2 : End : Endif
# Modif de l'origine d'une compétence à Manuelle
[M:ECP2]ORICPCVAL(nolign-1) = len(mess(0,10939,1))
Affzo [ECP2]ORICPCVAL(nolign-1)
End

######################################################################################
## Etiquette [M:ECP3] : Carrières
######################################################################################

## Tableau des postes

Subprog AS_NBRPOT
Gosub SETNOL
If NOL>=0 & [M:ECP3]NBRPOT>0
 If NOL<=[M:ECP3]NBRPOT
  Gosub AFFECT_POSTE
 Else
  Effzo [M:ECP3]20
 Endif
Else
 Effzo [M:ECP3]20
Endif
End

# SEGAY - 29/12/10 - DM 70239 LOT P02 - V6.1
#**
#* Init Tunel sur contrat
#* Tunel uniquement si origine automatique car la date de la ligne = date du contrat
#*!
Subprog IB_NBRPOT
#LIPET - X3-29323 - 15-03-2017 - START
#If [M:ECP3]ORIGINE(nolign-1)<> 1
If [M:ECP3]ORIGINE(nolign-1)<> 1 or !func ALLUTI()
#LIPET - X3-29323 - 15-03-2017 - END
 Raz GBOUT1
Else
  GBOUT1 = mess(72,10720,1) #Contrat # SEGAY 07/06/12 FQ81652
Endif
End


Subprog C_NBRPOT
If status=82 : # Reprise
 mkstat = 1 : End
Endif
If find(status,65,68,83) : # Annulation ligne(s)
 # JML 26/07/10 ML 399 Automatique
 If [M:ECP3]ORIGINE(nolign-1)=1
  Call ERREUR(mess(15,10715,1)) From GESECRAN : mkstat = 1 : End
  #### Vous ne pouvez pas annuler cette ligne, elle est 'Automatique'
 Endif
 Effzo [M:ECP3]20 : [M:ECP3]FLGADD4 = 1
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ECP3) 12/06/2012 13:06:03 (SEGAY)
######################################################################################
Subprog AS_WDATPOT(VALEUR)
Variable Date    VALEUR
# SEGAY 07/06/12 FQ81652
# Suite à suppression WORIGINE peut-être = 0
If [M:ECP3]WORIGINE=0
  [M:ECP3]WORIGINE=len(mess(0,399,1))
Endif
End

Subprog C_WDATPOT(VALEUR)
Variable Date    VALEUR
Local Integer NOL,I,TROUVE
#If VALEUR = [0/0/0] : mkstat=2 : End : Endif
# SEGAY 07/06/12 FQ81652
# now not control is WDATPOT=[0/0/0]
If VALEUR = [0/0/0] & [M:ECP3]WPOT="" & [M:ECP3]WJOBPOT="" : End : Endif
Read [ID]ID0=[M]REFNUM
If !fstat
 Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT<=VALEUR
&                 & (XITDAT=[0/0/0] | XITDAT>=[L]VALEUR)
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 If fstat & [F:ID]FLGMULCTR=2
  GMESSAGE = mess(12,10715,1) : # Contrat non valide à cette date
  mkstat = 2 : End
 Elsif fstat & [F:ID]FLGMULCTR<>2
  # Salarié non présent le xx/xx/xx
  GMESSAGE = mess(38,10720,1)-num$(VALEUR)
  mkstat = 2 : End
 Endif
Endif
For I=0 To [M:ECP3]NBRPOT-1
 If VALEUR=[M:ECP3]DATPOT(I)
  TROUVE=1 : NOL=I : Break
 Endif
Next
If TROUVE=1
 Gosub AFFECT_POSTE
Else
 [M:ECP3]WORIGINE = 2 : # ML 399 Manuelle
 [M:ECP3]WLIG4    = [M:ECP3]NBRPOT
 Actzo [ECP3]WADD4
Endif
End

Subprog AM_WDATPOT(VALEUR)
Variable Date    VALEUR
# SEGAY 07/06/12 FQ81652
# now control is WDATPOT=[0/0/0]
If VALEUR=[0/0/0]
   # Salarié non présent le xx/xx/xx
   GMESSAGE = mess(38,10720,1)-num$(VALEUR)
   mkstat = 2
   End
Endif

If [M:ECP3]WPOT<>""
 Call CTL_POTDAT([M:ECP3]WPOT,VALEUR,[M:ECP0]CTRNUM)
Endif
End

Subprog AS_WPOT(VALEUR)
Variable Char    VALEUR()
# JML 26/07/10
If [M:ECP3]WORIGINE<>2
 mkstat = 2 : End
Endif

  # FQ81085 - MABON 07/09/12 - US774 The position & Standard job can be in a different legislation than the contract
  # But if one of them is filled, the other must be in the same legislation
  If dim(GCURLEG2)<0 Then Global Char GCURLEG2(GLONADI) : Endif
  GCURLEG2 = ""
  If clalev([F:POT])=0 : Local File POSTE [POT] : Endif
  If [M]WPOT<>"" Then
    Read [F:POT]POT0=[M]WPOT
    If !fstat & [F:POT]LEG<>GCURLEG2 & [F:POT]LEG<>"" Then GCURLEG2=[F:POT]LEG : Endif
  Endif
  If GCURLEG2=GCURLEG or GCURLEG2 = "" Then
    If clalev([F:JOT])=0 : Local File JOBTYP [JOT] : Endif
    If [M]WJOBPOT<>"" Then
      Read [F:JOT]JOT0=[M]WJOBPOT
      If !fstat & [F:JOT]LEG<>GCURLEG2 & [F:JOT]LEG<>"" Then GCURLEG2=[F:JOT]LEG : Endif
    Endif
  Endif
  # End MABON
End

Subprog C_WPOT(VALEUR)
Variable Char    VALEUR()

Local Shortint I

# JML 31/08/10 CG not necessary anymore...
#If VALEUR="" & [M]WDATPOT<>[0/0/0]
# # Zone obligatoire
# GMESSAGE = mess(10,123,1)
# mkstat = 2 : End
#Endif

# Inutile de créer une nouvelle fiche si le poste n'a pas changé.
For I=0 To [M:ECP3]NBRPOT-1
 If [M]WDATPOT=[M:ECP3]DATPOT(I) Then
 Else
   If [L]VALEUR=[M:ECP3]POT(I) & I<>[M:ECP3]WLIG4 & [M]WDATPOT>=[M:ECP3]DATPOT(I)
    # Le poste n'a pas changé.
    # Inutile de créer une nouvelle fiche.
    GMESSAGE = mess(4,10720,1)
    mkstat = 2
   Endif
   Break
 Endif
Next
If mkstat : End : Endif

  # FQ81085 - MABON 07/09/12 - CONTBOJN action has been added on this field, in order to avoid the checking of the
  # leg. So we have to control the field manually here
  If VALEUR="" Then End : Endif
#  If clalev([F:POT])=0 : Local File POSTE [POT] : Endif
#  Read [F:POT]POT0=VALEUR
#  If fstat Then
#    GMESSAGE=mess(23,100,1) : mkstat=2
#  Elsif dim(GCURLEG2)>0 & [F:POT]LEG<>GCURLEG2 & [F:POT]LEG<>"" & GCURLEG<>GCURLEG2 Then
#    GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:POT]LEG : # Réservé à la législation
#    mkstat=2
#  Endif
  Local Char WLEG(GLONADI)
  If VALEUR="" Then End : Endif
  WLEG= GCURLEG
  If [M]WJOBPOT=""  Then
    If clalev([F:POT])=0 : Local File POSTE [POT] : Endif
    Read [F:POT]POT0=VALEUR
    If !fstat & [F:POT]LEG<>GCURLEG2 & [F:POT]LEG<>"" Then GCURLEG2=[F:POT]LEG : Endif
  Endif
  GCURLEG = GCURLEG2
  Call CONTROLE("POT","!",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1  : Endif
  GCURLEG = WLEG

  # End MABON
End

Subprog AM_WPOT(VALEUR)
Variable Char    VALEUR()
#DBA le 09/09
#Call CTL_POTDAT(VALEUR,[M]WDATPOT,[M:ECP0]CTRNUM)
#If mkstat=2 : End : Endif
Local Integer  L_OK
# SEGAY 07/06/12 FQ81652
# now control is WDATPOT=[0/0/0]
If [M]WDATPOT=[0/0/0]
   # Salarié non présent le xx/xx/xx
   GMESSAGE = mess(38,10720,1)-num$([M]WDATPOT)
   VALEUR=""
   [M:ECP3]WPOT=""
   Affzo [M:ECP3]WPOT
   mkstat = 2
   End
Endif

Gosub SETNOL
Call LECTURE("POT",VALEUR,"") From CONTOBJ
# Contrôle que le poste est encore valide
If ([F:POT]DATSTRVLY<>[0/0/0] & [M]WDATPOT<[F:POT]DATSTRVLY)
& |([F:POT]DATENDVLY<>[0/0/0] & [M]WDATPOT>[F:POT]DATENDVLY)
 # Poste actif du xx/xx/xx au xx/xx/xx
 GMESSAGE = VALEUR - mess(18,10720,1)-num$([F:POT]DATSTRVLY)-mess(95,100,1)-num$([F:POT]DATENDVLY)
 # JML 06/09/10 CG Pas de blocage, juste une alerte
 L_OK = 1
 Call AVERTIR(GMESSAGE,L_OK) From GESECRAN
 Raz GMESSAGE
 If L_OK<>2 : mkstat = 2 : End : Endif
Endif
[M:ECP3]POT([M:ECP3]WLIG4)       = VALEUR
[M:ECP3]FLGMOD4([M:ECP3]WLIG4)   = 1
[M:ECP3]DATSTRVLY([M:ECP3]WLIG4) = [F:POT]DATSTRVLY
[M:ECP3]DATENDVLY([M:ECP3]WLIG4) = [F:POT]DATENDVLY
[M:ECP3]JOBPOT([M:ECP3]WLIG4)    = [F:POT]JOBPOT
[M:ECP3]POT2([M:ECP3]WLIG4)      = [F:POT]POT2

#DBA le 09/09
If clalev([F:JOT])=0 : Local File JOBTYP [JOT] : Endif
Call LECTURE("JOT",[F:POT]JOBPOT,"") From CONTOBJ
[M:ECP3]STRVLYJOT([M:ECP3]WLIG4) = [F:JOT]DATSTRVLY
[M:ECP3]ENDVLYJOT([M:ECP3]WLIG4) = [F:JOT]DATENDVLY

#[M:ECP3]CPYPOT([M:ECP3]WLIG4)    = [F:POT]CPYPOT
#[M:ECP3]FCYPOT([M:ECP3]WLIG4)    = [F:POT]FCYPOT
#[M:ECP3]SRVPOT([M:ECP3]WLIG4)    = [F:POT]SRVPOT

[M:ECP3]WDATSTRVLY               = [F:POT]DATSTRVLY
[M:ECP3]WDATENDVLY               = [F:POT]DATENDVLY
[M:ECP3]WJOBPOT                  = [F:POT]JOBPOT
[M:ECP3]WPOT2                    = [F:POT]POT2

###DBA le 09/09
[M:ECP3]WSTRVLYJOT               = [F:JOT]DATSTRVLY
[M:ECP3]WENDVLYJOT               = [F:JOT]DATENDVLY
#[M:ECP3]WCPYPOT                  = [F:POT]CPYPOT
#[M:ECP3]WFCYPOT                  = [F:POT]FCYPOT
#[M:ECP3]WSRVPOT                  = [F:POT]SRVPOT
Effzo [M:ECP3]DATXIT
Effzo [M:ECP3]WJOB
Effzo [M:ECP3]WPROPRF # SEGAY - 29/12/10 - DM 70239 lot P02 - V6.1
Effzo [M:ECP3]WFCYPOT
Effzo [M:ECP3]WSRVPOT
Effzo [M:ECP3]WCPYPOT

If func AFNC.ACTIV("FRT") : Effzo [M:ECP3]WCAT2483 : Endif
If [M:ECP3]ORIGINE([M:ECP3]WLIG4)<>2
 Read[HRCTR]CTR0=[M:ECP0]REFNUM;[M:ECP0]CTRNUM;[M]DATPOT([M:ECP3]WLIG4)
 If !fstat
  [M:ECP3]DATXIT     = [F:HRCTR]XITDAT
  [M:ECP3]WJOB       = [F:HRCTR]JOB
  [M:ECP3]WPROPRF    = [F:HRCTR]PROPRF # SEGAY - 29/12/10 - DM 70239 lot P02 - V6.1
  [M:ECP3]WFCYPOT    = [F:HRCTR]ETRFCY
  [M:ECP3]WSRVPOT    = [F:HRCTR]ETRSRV
  Call LECTURE("FCY",[F:HRCTR]ETRSRV,"") From CONTOBJ
  [M:ECP3]WCPYPOT    = [F:FCY]LEGCPY
  If func AFNC.ACTIV("FRT") : [M:ECP3]WCAT2483   = [F:HRCTR]CATFRT : Endif
 Endif
Endif
###
# JML 14/09/10 Un petit rafraichissement...
Affzo [ECP3]DATPOT([M:ECP3]WLIG4),JOBPOT([M:ECP3]WLIG4),POT([M:ECP3]WLIG4),ORIGINE([M:ECP3]WLIG4)
Affzo [ECP3]20
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ECP3) 26/07/2010 12:18:24 (JML)
######################################################################################
Subprog AS_WJOBPOT(VALEUR)
Variable Char    VALEUR()
# JML 26/07/10
If [M:ECP3]WORIGINE<>2
 mkstat = 2 : End
Endif

  # FQ81085 - MABON 07/09/12 - US774 The position & Standard job can be in a different legislation than the contract
  # But if one of them is filled, the other must be in the same legislation
  If dim(GCURLEG2)<0 Then Global Char GCURLEG2(GLONADI) : Endif
  GCURLEG2 = ""
  If clalev([F:JOT])=0 : Local File JOBTYP [JOT] : Endif
  If [M]WJOBPOT<>"" Then
    Read [F:JOT]JOT0=[M]WJOBPOT
    If !fstat & [F:JOT]LEG<>GCURLEG2 & [F:JOT]LEG<>"" Then GCURLEG2=[F:JOT]LEG : Endif
  Endif
  If GCURLEG2=GCURLEG or GCURLEG2 = "" Then
    If clalev([F:POT])=0 : Local File POSTE [POT] : Endif
    If [M]WPOT<>"" Then
      Read [F:POT]POT0=[M]WPOT
      If !fstat & [F:POT]LEG<>GCURLEG2 & [F:POT]LEG<>"" Then GCURLEG2=[F:POT]LEG : Endif
    Endif
  Endif
  # End MABON
End

Subprog C_WJOBPOT(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" Then End : Endif
  # FQ81085 - MABON 07/09/12 - CONTBOJN action has been added on this field, in order to avoid the checking of the
  # leg. So we have to control the field manually here
#  If clalev([F:JOT])=0 : Local File JOBTYP [JOT] : Endif
#  Read [F:JOT]JOT0=VALEUR
#  If fstat Then
#    GMESSAGE=mess(23,100,1) : mkstat=2
#  Elsif dim(GCURLEG2)>0 & [F:JOT]LEG<>GCURLEG2 & [F:JOT]LEG<>"" & GCURLEG<>GCURLEG2 Then
#    GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:JOT]LEG : # Réservé à la législation
#    mkstat=2
#  Endif
  Local Char WLEG(GLONADI)
  If VALEUR="" Then End : Endif
  WLEG= GCURLEG
  If [M]WPOT="" Then
    If clalev([F:JOT])=0 : Local File JOBTYP [JOT] : Endif
    Read [F:JOT]JOT0=VALEUR
    If !fstat & [F:JOT]LEG<>GCURLEG2 & [F:JOT]LEG<>"" Then GCURLEG2=[F:JOT]LEG : Endif
  Endif

  GCURLEG = GCURLEG2
  Call CONTROLE("JOT","!",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1  : Endif
  GCURLEG = WLEG
  # End MABON
End

Subprog AM_WJOBPOT(VALEUR)
Variable Char    VALEUR()
Local Integer L_OK
#DBA le 09/09
#Call CTL_POTDAT(VALEUR,[M]WDATPOT,[M:ECP0]CTRNUM)
#If mkstat=2 : End : Endif
# SEGAY 07/06/12 FQ81652
# now control is WDATPOT=[0/0/0]
If [M]WDATPOT=[0/0/0]
   # Salarié non présent le xx/xx/xx
   GMESSAGE = mess(38,10720,1)-num$([M]WDATPOT)
   VALEUR=""
   [M:ECP3]WJOBPOT=""
   Affzo [M:ECP3]WJOBPOT
   mkstat = 2
   End
Endif

Gosub SETNOL
If clalev([F:JOT])=0 : Local File JOBTYP [JOT] : Endif
Call LECTURE("JOT",VALEUR,"") From CONTOBJ
# Contrôle que le poste est encore valide
If ([F:JOT]DATSTRVLY<>[0/0/0] & [M]WDATPOT<[F:JOT]DATSTRVLY)
& |([F:JOT]DATENDVLY<>[0/0/0] & [M]WDATPOT>[F:JOT]DATENDVLY)
 # Emploi type actif du xx/xx/xx au xx/xx/xx
 GMESSAGE = VALEUR - mess(56,10720,1)-num$([F:JOT]DATSTRVLY)-mess(95,100,1)-num$([F:JOT]DATENDVLY)
 # JML 06/09/10 CG Pas de blocage, juste une alerte
 L_OK = 1
 Call AVERTIR(GMESSAGE,L_OK) From GESECRAN
 Raz GMESSAGE
 If L_OK<>2 : mkstat = 2 : End : Endif
Endif
[M:ECP3]JOBPOT([M:ECP3]WLIG4)    = VALEUR
[M:ECP3]FLGMOD4([M:ECP3]WLIG4)   = 1
#DBA le 09/09
[M:ECP3]STRVLYJOT([M:ECP3]WLIG4) = [F:JOT]DATSTRVLY
[M:ECP3]ENDVLYJOT([M:ECP3]WLIG4) = [F:JOT]DATENDVLY
[M:ECP3]WSTRVLYJOT               = [F:JOT]DATSTRVLY
[M:ECP3]WENDVLYJOT               = [F:JOT]DATENDVLY
# JML 14/09/10 Un petit rafraichissement...
Affzo [ECP3]DATPOT([M:ECP3]WLIG4),JOBPOT([M:ECP3]WLIG4),POT([M:ECP3]WLIG4),ORIGINE([M:ECP3]WLIG4)
End
######################################################################################

######################################################################################
# Contrôle société/site/service du poste, par rapport au salarié
# On concatène les messages.
# Inutile de concaténer le message société différente avec site différent car c'est évident.

Subprog CTL_POTDAT(VPOT,VDAT,VCTR)
Value Char VPOT, VCTR
Value Date VDAT

Local Date    DATDEB, DATFIN
Local Char    MAT(GLONEML)
Local Integer TROUVE, OK

If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR] : Endif
If clalev([F:FCY])=0    : Local File FACILITY [FCY]   : Endif
If clalev([F:POT])=0    : Local File POSTE    [POT]   : Endif

Call LECTURE("POT",VPOT,"") From CONTOBJ

Filter [HRCTR] Where REFNUM=[M:ECP0]REFNUM & CTRNUM=VCTR & CTRDAT<=VDAT
&                & (XITDAT=[0/0/0] | XITDAT>=VDAT)
Read [HRCTR]CTR1 Last
Filter [HRCTR]
If !fstat
 ##################################################################
 # JML 10/09/10 CG Not necessary anymore
 #Read [FCY]FCY0=[F:HRCTR]ETRFCY
 #If !fstat
 # If [F:POT]CPYPOT<>"" & [F:POT]CPYPOT<>[F:FCY]LEGCPY
 #  # Le poste n'est pas rattaché à la même sociéte que le salarié
 #  GMESSAGE = mess(7,10720,1)
 # Elsif [F:POT]FCYPOT<>"" & [F:POT]FCYPOT<>[F:HRCTR]ETRFCY
 #  # Le poste n'est pas rattaché au même site que le salarié
 #  GMESSAGE = mess(6,10720,1)
 # Endif
 #Endif
 #If [F:POT]SRVPOT<>"" & [F:POT]SRVPOT<>[F:HRCTR]ETRSRV
 # If GMESSAGE<>"" : GMESSAGE +="\" : Endif
 # # Le poste n'est pas rattaché au même service que le salarié
 # GMESSAGE += mess(17,10720,1)
 #Endif
 ##################################################################
Else
 # Salarié non présent le xx/xx/xx
 GMESSAGE = mess(38,10720,1)-num$(VDAT)
 mkstat = 2 : End
Endif
If GMESSAGE<>""
 OK = 1
 # Poste déjà occupé par
 Call AVERTIR(GMESSAGE,OK) From GESECRAN
 If OK=1
  mkstat = 2 : Raz GMESSAGE :  End
 Endif
Endif
# Contrôle que le poste n'est pas déjà occupé
TROUVE = 0
# JML 31/08/10 CG Not necessary anymore
#Gosub POSTEOCCUPE
If TROUVE=1
 OK = 1
 # Poste déjà occupé par
 Call AVERTIR(mess(3,10720,1)-[F:EPO]REFNUM,OK) From GESECRAN
 If OK=1
  mkstat = 2 : End
 Endif
Endif
End

$POSTEOCCUPE
# Recherche de la date de fin d'occupation du poste du salarié qui est soit la date de sortie du salarié
# soit la date d'occupation du poste suivant.
DATDEB = VDAT
DATFIN = [M:ECP3]DATXIT
Filter [EPO] Where REFNUM=[M:ECP0]REFNUM & CTRNUM=VCTR & DATPOT>VDAT
Read [EPO]EPO1 First
If !fstat
 DATFIN = [F:EPO1]DATPOT
Endif
Filter [EPO]
# Recherche d'un salarié occupant ce poste
For [EPO]EPO1 Where REFNUM<>[M:ECP0]REFNUM & POT=[F:POT]COD & (DATPOT<DATFIN | DATFIN=[0/0/0])
 Filter [EPO1] Where REFNUM=[F:EPO]REFNUM & CTRNUM=[F:EPO]CTRNUM & DATPOT>[F:EPO]DATPOT
 Read [EPO1]EPO1 First
 Filter [EPO1]
 # Recherche de la date à laquelle il a changé de poste
 If !fstat & [F:EPO1]DATPOT>=DATDEB
  TROUVE = 1
  Break
 Elsif fstat
  # C'est le dernier poste occupé par le salarié. Le salarié est-il encore présent ?
  Filter [HRCTR] Where REFNUM=[F:EPO]REFNUM & CTRNUM=[F:EPO]CTRNUM
  Read [HRCTR]CTR1 Last
  Filter [HRCTR]
  If !fstat & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=[L]DATDEB)
   TROUVE = 1
   Break
  Endif
 Endif
Next
Return

Subprog AS_WADD4(VALEUR)
Variable Integer VALEUR
Local Integer TROUVE,I,NOL,J
Local Integer MAJ_CPC
If [M:ECP3]WDATPOT<>[0/0/0]
 For I=0 To [M:ECP3]NBRPOT-1
  If [M:ECP3]WDATPOT=[M:ECP3]DATPOT(I)
   TROUVE=1 : Break
  Endif
 Next
 If !TROUVE
  Raz MAJ_CPC
  If [M:ECP3]DATPOT(0)<[M:ECP3]WDATPOT
   MAJ_CPC = 1
  Endif
  [M:ECP3]FLGADD4 = 1
  NOL = [M:ECP3]NBRPOT
  Gosub DECHARGE_POSTE
  [M:ECP3]NBRPOT += 1
  Sorta [M:ECP3]NBRPOT [M:ECP3]NBRPOT Order By [M:ECP3]DATPOT(indice) Desc
  Affzo [M:ECP3]15
  VALEUR = 1
  For I=0 To [M:ECP3]NBRPOT-1
   If [M:ECP3]WDATPOT=[M:ECP3]DATPOT(I)
    [M:ECP3]WLIG4 = I+1 : Break
   Endif
  Next
  # JML 13/09/10 CG Always load the newest competence
  If MAJ_CPC
   Read [ACV]CODACT="CAR"
   If !fstat & [F:ACV]FLACT=2
    Raz [M:ECP2]
    Gosub CHARGE_CPC
    # We don't reload CPE
    Affzo [ECP2]
   Endif
  Endif
  If !GBROWS : zonsui = "WDATPOT" : Endif #72698
 Endif : # If !TROUVE
Endif : # If [M:ECP3]WDATPOT<>[0/0/0]
End

$AFFECT_POSTE
[M:ECP3]WDATPOT    = [M:ECP3]DATPOT(NOL)
[M:ECP3]WPOT       = [M:ECP3]POT(NOL)
[M:ECP3]WDATSTRVLY = [M:ECP3]DATSTRVLY(NOL)
[M:ECP3]WDATENDVLY = [M:ECP3]DATENDVLY(NOL)
[M:ECP3]WJOBPOT    = [M:ECP3]JOBPOT(NOL)
[M:ECP3]WPOT2      = [M:ECP3]POT2(NOL)
# JML 14/09/10 Si Insertion, Date nulle, alors origine manuelle pour permettre annulation
If [M:ECP3]WDATPOT<>[0/0/0]
 [M:ECP3]WORIGINE   = [M:ECP3]ORIGINE(NOL)
Else
# SEGAY 07/06/12 - BUG 81652
# [M:ECP3]ORIGINE(NOL) = len(mess(0,399,1))
 If [M:ECP3]POT(NOL) = "" & [M:ECP3]JOBPOT(NOL) =""
   [M:ECP3]ORIGINE(NOL)=0
 Else
   [M:ECP3]ORIGINE(NOL) = len(mess(0,399,1))
 Endif
 [M:ECP3]WORIGINE   = [M:ECP3]ORIGINE(NOL)
 Affzo [ECP3]ORIGINE(NOL)
Endif
###DBA le 09/09
[M:ECP3]WSTRVLYJOT = [M:ECP3]STRVLYJOT(NOL)
[M:ECP3]WENDVLYJOT = [M:ECP3]ENDVLYJOT(NOL)
#[M:ECP3]WCPYPOT    = [M:ECP3]CPYPOT(NOL)
#[M:ECP3]WFCYPOT    = [M:ECP3]FCYPOT(NOL)
#[M:ECP3]WSRVPOT    = [M:ECP3]SRVPOT(NOL)
#[M:ECP3]WCAT2483   = [M:ECP0]CAT2483
[M:ECP3]WLIG4      = NOL
Effzo [M:ECP3]DATXIT
Effzo [M:ECP3]WJOB
Effzo [M:ECP3]WPROPRF # SEGAY - 29/12/10 - DM 70239 lot P02 - V6.1
Effzo [M:ECP3]WFCYPOT
Effzo [M:ECP3]WSRVPOT
Effzo [M:ECP3]WCPYPOT
If func AFNC.ACTIV("FRT") : Effzo [M:ECP3]WCAT2483 : Endif
If [M:ECP3]ORIGINE(NOL)<>2
 Read[HRCTR]CTR0=[M:ECP0]REFNUM;[M:ECP0]CTRNUM;[M]DATPOT(NOL)
 If !fstat
  [M:ECP3]DATXIT       = [F:HRCTR]XITDAT
  # DBA le 09/09
  [M:ECP3]WJOB       = [F:HRCTR]JOB
  [M:ECP3]WPROPRF    = [F:HRCTR]PROPRF # SEGAY - 29/12/10 - DM 70239 lot P02 - V6.1
  [M:ECP3]WFCYPOT    = [F:HRCTR]ETRFCY
  [M:ECP3]WSRVPOT    = [F:HRCTR]ETRSRV
  If func AFNC.ACTIV("FRT") : [M:ECP3]WCAT2483   = [F:HRCTR]CATFRT : Endif
  #LIPET - 2017-04-12 - X3-30972 - START
  #Call LECTURE("FCY",[F:HRCTR]ETRSRV,"") From CONTOBJ
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  #LIPET - 2017-04-12 - X3-30972 - END
  [M:ECP3]WCPYPOT    = [F:FCY]LEGCPY
 Endif
Endif
###
Affzo [M:ECP3]20
Grizo [M:ECP3]WADD4
Return

$DECHARGE_POSTE
[M:ECP3]DATPOT(NOL)    = [M:ECP3]WDATPOT
[M:ECP3]POT(NOL)       = [M:ECP3]WPOT
[M:ECP3]DATSTRVLY(NOL) = [M:ECP3]WDATSTRVLY
[M:ECP3]DATENDVLY(NOL) = [M:ECP3]WDATENDVLY
[M:ECP3]JOBPOT(NOL)    = [M:ECP3]WJOBPOT
#DBA le 09/09
[M:ECP3]STRVLYJOT(NOL) = [M:ECP3]WSTRVLYJOT
[M:ECP3]ENDVLYJOT(NOL) = [M:ECP3]WENDVLYJOT
#DBA le 09/09 : Add Job's validity period
#[M:ECP3]CPYPOT(NOL)    = [M:ECP3]WCPYPOT
#[M:ECP3]FCYPOT(NOL)    = [M:ECP3]WFCYPOT
#[M:ECP3]SRVPOT(NOL)    = [M:ECP3]WSRVPOT
#[M:ECP3]CAT2483(NOL)   = [M:ECP3]WCAT2483

[M:ECP3]POT2(NOL)      = [M:ECP3]WPOT2
[M:ECP3]ORIGINE(NOL)   = [M:ECP3]WORIGINE
[M:ECP3]WLIG4          = NOL
Grizo [M:ECP3]WADD4
#[M:ECP3]DATSUPPOT([M:ECP3]NBRSUPPOT) = [M:ECP3]WDATPOT
#[M:ECP3]POTSUP([M:ECP3]NBRSUPPOT)    = [M:ECP3]WPOT
#[M:ECP3]NBRSUPPOT +=1
Return


