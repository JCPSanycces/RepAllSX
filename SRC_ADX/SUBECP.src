$SAUVE_POSTE
If [M:ECP3]FLGADD4=1
 # JML 26/07/10 we can only modify Origine=Manuel (Local Menu 399)
 Delete [F:EPO] Where [F:EPO]REFNUM=[F:ID]REFNUM & [F:EPO]CTRNUM=[M:ECP0]CTRNUM
&                   & [F:EPO]ORIGINE=2
 If fstat=1
  GOK = -1 : GLOCK = "$EMPLOPOT"-[F:ID]REFNUM
 Endif
Endif
If GOK<=0 : Return : Endif
For nolign=[M:ECP3]NBRPOT To 1 Step -1
 # JML 26/07/10 we can only modify Origine=Manuel (Local Menu 399)
 If [M:ECP3]ORIGINE(nolign-1)=2
  # JML 26/07/10 Changing Key EPO0 from REFNUM+CTRNUM+NUMLIG to REFNUM+CTRNUM+ORIGINE+DATPOT
  Readlock [F:EPO]EPO1=[M:ECP0]REFNUM;[M:ECP0]CTRNUM;[M:ECP3]DATPOT(nolign-1);[M:ECP3]ORIGINE(nolign-1)
  If fstat
   Raz [F:EPO]
   [F:EPO]       = [M:ECP3]
   [F:EPO]REFNUM = [F:ID]REFNUM
   [F:EPO]CTRNUM = [M:ECP0]CTRNUM
   [F:EPO]NUMLIG = [M:ECP3]NBRPOT-(nolign-1)
   If dim([F:EPO]CREDAT)>0 : [F:EPO]CREDAT = date$     : Endif
   If dim([F:EPO]CRETIM)>0 : [F:EPO]CRETIM = time      : Endif
   If dim([F:EPO]CREUSR)>0 : [F:EPO]CREUSR = GUSER     : Endif
   If dim([F:EPO]EXPNUM)>0 : [F:EPO]EXPNUM = [C]EXPORT : Endif
   Write [F:EPO]
   If fstat
    GOK = 0 : Call FSTA("EPO") From GLOCK : Break
   Endif
  Else
   [F:EPO]=[M:ECP3]
   If dim([F:EPO]UPDDAT)>0 : [F:EPO]UPDDAT = date$     : Endif
   If dim([F:EPO]UPDTIM)>0 : [F:EPO]UPDTIM = time      : Endif
   If dim([F:EPO]UPDUSR)>0 : [F:EPO]UPDUSR = GUSER     : Endif
   If dim([F:EPO]EXPNUM)>0 : [F:EPO]EXPNUM = [C]EXPORT : Endif
   Rewrite [F:EPO]
   If fstat
    GOK = 0 : Call FSTA("EPO") From GLOCK : Break
   Endif
  Endif
 Endif : # If [M:ECP3]ORIGINE(nolign-1)=2
Next nolign
If GOK<=0 : Return : Endif

