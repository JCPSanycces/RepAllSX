#####################################################################################################################
# JML 10/08/10 LOT P02 - 13/09/10 NOT NECESSARY ANYMORE...
Subprog COPY_CPC(P_REFNUM, P_CPC, P_NIV, P_ORICPC)
Value   Char    P_REFNUM()
Value   Char    P_CPC()
Value   Char    P_NIV()
Value   Integer P_ORICPC           : # ML 2402

Local Integer L_COPIER

L_COPIER = 0
If P_CPC="" : End : Endif

Filter [CPE] Where REFNUM=P_REFNUM & CPC=P_CPC & [CPE]CPCDAT=[0/0/0]
Read [CPE]CPE1 Last
Filter [CPE]
If !fstat
 L_COPIER = func COMPNIV(P_CPC,[F:CPE]LEVCPC,P_NIV)
Endif
If fstat | L_COPIER=1
 #61935
# Readlock [F:CPE]CPE0=[M:ECP0]REFNUM;[M:ECP3]DATSUPPOT(I);[F:POT]CPC(J)
 # JML 10/08/10 LOT P02 now required competence don't have any date
 Readlock [F:CPE]CPE0=P_REFNUM;[0/0/0];P_CPC
 If fstat
  Raz [F:CPE]
  [F:CPE]REFNUM = P_REFNUM
  [F:CPE]CPCDAT = [0/0/0]
  [F:CPE]CPC    = P_CPC
  [F:CPE]LEVCPC = P_NIV
  [F:CPE]ORICPC = P_ORICPC : # ML 2402
  If dim([F:CPE]CREDAT)>0 : [F:CPE]CREDAT = date$ : Endif
  If dim([F:CPE]CREUSR)>0 : [F:CPE]CREUSR = GUSER : Endif
  If dim([F:CPE]CRETIM)>0 : [F:CPE]CRETIM = time  : Endif
  Write [CPE]
  If fstat
   GOK = 0 : Call FSTA("CPE") From GLOCK : End
  Endif
 Else
  [F:CPE]LEVCPC = P_NIV
  [F:CPE]ORICPC = P_ORICPC : # ML 2402
  If dim([F:CPE]UPDDAT)>0 : [F:CPE]UPDDAT = date$     : Endif
  If dim([F:CPE]UPDTIM)>0 : [F:CPE]UPDTIM = time      : Endif
  If dim([F:CPE]UPDUSR)>0 : [F:CPE]UPDUSR = GUSER     : Endif
  If dim([F:CPE]EXPNUM)>0 : [F:CPE]EXPNUM = [C]EXPORT : Endif
  Rewrite[F:CPE]
  If fstat
   GOK = 0 : Call FSTA("CPE") From GLOCK : End
  Endif
 Endif
 #Fin 61935
Endif
End
