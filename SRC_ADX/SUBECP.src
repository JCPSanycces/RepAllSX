#Next : # [CPE]CPE0
Call LECTURE("POT",[M:ECP3]POT(0),"") From CONTOBJ
If [M:ECP3]POT(0)<>"" & [F:POT]JOBPOT=[M:ECP3]JOBPOT(0)
  For J=0 To dim([F:POT]CPC)-1
   If [F:POT]CPC(J)="" : Break : Endif
   nolign+=1
   [M:ECP2]CPC(nolign-1)    = [F:POT]CPC(J)
   [M:ECP2]LEVCPC(nolign-1) = [F:POT]NIV(J)
   [M:ECP2]LEVREF(nolign-1) = func SUBECP.CPC_LEVREF([F:POT]CPC(J),[F:POT]NIV(J))
   If [F:POT]ORI(J)<>4
    [M:ECP2]ORICPC(nolign-1) = [F:POT]ORI(J)
   Else
    # Si =4 ML 2400 Groupe de compétence
    [M:ECP2]ORICPC(nolign-1) = 6 : # ML 2400 Poste
   Endif
   Gosub CHARGE_ECP2
  Next J
Elsif [M:ECP3]JOBPOT(0)<>""
  Call LECTURE("JOT",[M:ECP3]JOBPOT(0),"") From CONTOBJ
  For J=0 To dim([F:JOT]CPC)-1
   If [F:JOT]CPC(J)="" : Break : Endif
   nolign+=1
   [M:ECP2]CPC(nolign-1)    = [F:JOT]CPC(J)
   [M:ECP2]LEVCPC(nolign-1) = [F:JOT]NIV(J)
   [M:ECP2]LEVREF(nolign-1) = func SUBECP.CPC_LEVREF([F:JOT]CPC(J),[F:JOT]NIV(J))
   If [F:JOT]ORI(J)<>4
    [M:ECP2]ORICPC(nolign-1) = [F:JOT]ORI(J)
   Else
    # Si =4 ML 2400 Groupe de compétence
    [M:ECP2]ORICPC(nolign-1) = 5 : # ML 2400 Emploi type
   Endif
   Gosub CHARGE_ECP2
  Next J
Endif
[M:ECP2]NBRCPC = nolign
Sorta [M:ECP2]NBRCPC [M:ECP2]NBRCPC Order By [M:ECP2]CPC(indice)
# FIN JML 13/09/10 CG Always read from POSTE or JOBTYP
#################################################################################
Return
$CHARGE_CPE
nolign=0
For [CPE]CPE1(2) Where [F:CPE]REFNUM=[M]REFNUM & [F:CPE]CPCDAT<>[0/0/0]
 # CPE1 * REFNUM+CPC+CPCDAT
# SEGAY - 24/12/10 - EXI 66105 LOT P02 - V6.1
 If nolign>=dim([M:ECP2]CPCVAL)
   # Trop de compétences à analyser
   Call ERREUR( mess(48,10720,1)-num$(dim([M:ECP2]CPCVAL))) From GESECRAN
   Break
 Endif

 nolign+=1
 For [CPE]CPE1
  # Watchout here, don't make a 'transclass' !
  [M:ECP2]CPCVAL(nolign-1)    = [F:CPE]CPC
  [M:ECP2]LEVCPCVAL(nolign-1) = [F:CPE]LEVCPC
  [M:ECP2]LEVREFVAL(nolign-1) = func SUBECP.CPC_LEVREF([F:CPE]CPC,[F:CPE]LEVCPC)
  [M:ECP2]CPCDATVAL(nolign-1) = [F:CPE]CPCDAT
  [M:ECP2]ORICPCVAL(nolign-1) = [F:CPE]ORICPC
  [M:ECP2]FLGMODVAL(nolign-1) = 1
  [M:ECP2]FLGOLDVAL(nolign-1) = 2

  # Now some graphicals, Learned
  L_IJ = find([F:CPE]CPC,[M:ECP2]CPCGRA(0..[M:ECP2]NBRGRA-1))
  If L_IJ
   [M:ECP2]ACQUIS(L_IJ-1)   = [M:ECP2]LEVREFVAL(nolign-1)
  Else
   # DBA 30/09 : Add the condition to make a test about 'full table'
   # SEGAY 22/01/13 BUG 87090 ACTIV CODE CGI
#   If [M:ECP2]NBRGRA<func AFNC.ACTIV("CPC")
   If [M:ECP2]NBRGRA<dim([M:ECP2]CPCGRA)
    [M:ECP2]CPCGRA([M:ECP2]NBRGRA)   = [F:CPE]CPC
    [M:ECP2]ACQUIS([M:ECP2]NBRGRA)   = [M:ECP2]LEVREFVAL(nolign-1)
    [M:ECP2]NBRGRA += 1
   Else
    # Tableau plein
    Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
    Break 2
   Endif
  Endif
 Next : # [CPE]CPE1
 # JML 10/09/10 CG Tunnel Echelle
 Call LECTURE("CPC",[F:CPE]CPC,"") From CONTOBJ
 [M:ECP2]CODSCAVAL(nolign-1) = [F:CPC]CODSCA
Next : # [CPE]CPE1(2)
[M:ECP2]NBRVAL = nolign
Return
#####################################################################################
$CHARGE_ECP2
[M:ECP2]CPCDAT(nolign-1) = [0/0/0]
[M:ECP2]FLGMOD(nolign-1) = 1
[M:ECP2]FLGOLD(nolign-1) = 2
# Now some graphicals, required
If !find([M:ECP2]CPC(nolign-1),[M:ECP2]CPCGRA(0..[M:ECP2]NBRGRA-1))
 # DBA 30/09 : Add the condition to make a test about 'full table'
 # SEGAY 22/01/13 BUG 87090 ACTIV CODE CGI
# If [M:ECP2]NBRGRA<func AFNC.ACTIV("CPC")
 If [M:ECP2]NBRGRA<dim([M:ECP2]CPCGRA)
  [M:ECP2]CPCGRA([M:ECP2]NBRGRA)   = [M:ECP2]CPC(nolign-1)
  [M:ECP2]REQUIS([M:ECP2]NBRGRA)   = [M:ECP2]LEVREF(nolign-1)
  [M:ECP2]NBRGRA += 1
 Else
  # Tableau plein
  Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
 Endif
Endif
# JML 10/09/10 CG Tunnel Echelle
Call LECTURE("CPC",[M:ECP2]CPC(nolign-1),"") From CONTOBJ
[M:ECP2]CODSCACPC(nolign-1) = [F:CPC]CODSCA
Return
#####################################################################################
# JML 28/07/10 LOT P02
$CHARGE_SALARY
#SEGAY - 30/03/11 - BUG 72805 - V6.1
If !func AFNC.ACTIV("HRPAY")
  Return
Endif
#END_BUG 72805
nolign = 0
For [SAL]SAL0 Where [F:SAL]REFNUM=[M:ECP0]REFNUM & [F:SAL]CTRNUM=[M:ECP0]CTRNUM
 nolign += 1
 [M:ECP6] = [F:SAL]
Next : # [SAL]SAL0
[M]NBRSAL = nolign
Return
#####################################################################################

$CHARGE_EXM
nolign=0
#LIPET - X3-29323 - 15-03-2017 - START
#For [F:HREXM]EXM0 Where REFNUM=MATRI
# nolign+=1
# [M:EMP9]=[F:HREXM]
# [M:EMP9]FLGMOD1(nolign-1)=0
#Next
#[M:EMP9]NBREXM=nolign
#Sorta [M]NBREXM [M]NBREXM Order By [M]DATEXM ([S]indice)Desc
#[M:EMP9]FLGADD1=0
#Grizo [M:EMP9]WADD5
#Default Mask [M:EMP9]
ZONE = "NBREXM" : Gosub SET_ZONE From SUBEML2
If MA Then
  For [F:HREXM]EXM0 Where REFNUM=MATRI
   nolign+=1
   [M]=[F:HREXM]
   [M]FLGMOD1(nolign-1)=0
  Next
  [M]NBREXM=nolign
  Sorta [M]NBREXM [M]NBREXM Order By [M]DATEXM ([S]indice)Desc
  [M]FLGADD1=0
  Grizo [M]WADD5
#  Default Mask [M]
Endif
#LIPET - X3-29323 - 15-03-2017 - END
# Fin FQ89889
Call FIRST_NBREXM From SUBEML2

Return

$CHARGE_TRY
nolign=0
#LIPET - X3-29323 - 15-03-2017 - START
#For [F:TRY]TRY0 Where REFNUM=MATRI
#  nolign+=1
# [M:EMP9]=[F:TRY]
# [M:EMP9]FLGMOD2(nolign-1)=0
#Next
#[M:EMP9]NBRTRY=nolign
#Sorta [M]NBRTRY [M]NBRTRY Order By [M]STRDATTRY ([S]indice)Desc
#[M:EMP9]FLGADD2=0
#Grizo [M:EMP9]WADD6
#Default Mask [M:EMP9]
ZONE = "NBRTRY" : Gosub SET_ZONE From SUBEML2
If MA Then
  For [F:TRY]TRY0 Where REFNUM=MATRI
    nolign+=1
    [M]=[F:TRY]
    [M]FLGMOD2(nolign-1)=0
  Next
  [M]NBRTRY=nolign
  Sorta [M]NBRTRY [M]NBRTRY Order By [M]STRDATTRY ([S]indice)Desc
  [M]FLGADD2=0
  Grizo [M]WADD6
#  Default Mask [M]
Endif
#LIPET - X3-29323 - 15-03-2017 - END
# Fin FQ89889
Call FIRST_NBRTRY From SUBEML2
Return

$CHARGE_EVAL
nolign = 0
For [EVE] Where REFNUM=[M:ECP0]REFNUM & CTRNUM=[M:ECP0]CTRNUM & [F:EVE]EVADAT<>[0/0/0] # BUG 88113 test EVADAT <> ""
 nolign +=1
 # JML 24/09/10 Transclass for new zones
 [M:ECP4] = [F:EVE]
 [M:ECP4]EVADAT(nolign-1) = [F:EVE]EVADAT
 [M:ECP4]FLGYEA(nolign-1) = [F:EVE]FLGYEA
 [M:ECP4]EVAJOB(nolign-1) = [F:EVE]EVAJOB
 [M:ECP4]FLGMOB(nolign-1) = [F:EVE]FLGMOB
 [M:ECP4]EVAFCY(nolign-1) = [F:EVE]EVAFCY
# SEGAY - 25/01/13 - BUG 87490 + BUG 87492
 [M:ECP4]EVADATSTR(nolign-1) = [F:EVE]EVADATSTR
 [M:ECP4]EVADATEND(nolign-1) = [F:EVE]EVADATEND
 [M:ECP4]EVATYP(nolign-1) = [F:EVE]EVATYP
# END SEGAY - 25/01/13 - BUG 87490 + BUG 87492

 If [F:EVE]EVAMAT<>""
 #LIMAS - X3-29323- 25-10-2017 - START
  [M:ECP4]EVANAM(nolign-1) = [F:EVE]EVAMAT
  [M:ECP4]EVAMATLIB(nolign-1) = [F:EVE]EVAMAT
  Read [ID2]ID0=[F:EVE]EVAMAT : # Ne pas utiliser [ID]
  If !fstat
   [M:ECP4]EVANAM(nolign-1) -= [F:ID2]NAM
   [M:ECP4]EVAMATLIB(nolign-1) -= [F:ID2]NAM
  Endif
 Else
  [M:ECP4]EVANAM(nolign-1) = [F:EVE]EVALIB
  [M:ECP4]EVAMATLIB(nolign-1) = [F:EVE]EVALIB
 Endif

 #LIMAS - X3-29323- 25-10-2017 - END
 #LIPET - X3-29323 - 15-03-2017 - START
 Gosub SET_LINE_FICT From SUBECPCOM
 #LIPET - X3-29323 - 15-03-2017 - END
Next
[M:ECP4]NBREVA = nolign
#LIPET - X3-29323 - 15-03-2017 - START
nolign=1
Gosub AFF_DETAIL From SUBECPCOM
#LIPET - X3-29323 - 15-03-2017 - END
Return

$CHARGE_POSTE
Local Integer NOL
nolign = 0
NOL = 0
For [F:EPO]EPO1 Where [EPO]REFNUM=[M:ECP0]REFNUM & [EPO]CTRNUM=[M:ECP0]CTRNUM
 Call LECTURE("POT",[F:EPO]POT,"") From CONTOBJ
 nolign +=1
 [M:ECP3] = [F:EPO]
 [M:ECP3] = [F:POT]
 [M:ECP3]JOBPOT(nolign-1)  = [F:EPO]JOBPOT    : # JML 26/07/10
 [M:ECP3]FLGMOD4(nolign-1) = 0
Next
[M:ECP3]NBRPOT = nolign
Sorta [M]NBRPOT [M]NBRPOT Order By DATPOT([S]indice) Desc
[M:ECP3]FLGADD4 = 0
Grizo [M:ECP3]WADD4
Gosub AFFECT_POSTE
Return

$CHARGE_STAGE
nolign = 0
#59216
#Filter [INS] Where REFNUM=MATRI & STA=3
#SEGAY - 11/03/11 - BUG 72311 - V6.1
#Onglet Stage suivi, afficher  si l’inscription est au moins confirmée
#Filter [INS] Where REFNUM=MATRI & STA=3 & CTRNUM=[M:ECP0]CTRNUM
Filter [INS] Where REFNUM=MATRI & STA>=3 & CTRNUM=[M:ECP0]CTRNUM
For [INS]INS0
 nolign +=1
 Call LECTURE("HRSES",[F:INS]SES,"") From CONTOBJ
 [M:ECP5]STG(nolign-1) = [F:INS]STG
 [M:ECP5]SES(nolign-1) = [F:INS]SES
 [M:ECP5]DEBSES(nolign-1) = [F:HRSES]STRDAT
 [M:ECP5]FINSES(nolign-1) = [F:HRSES]ENDDAT
 If [F:HRSES]TCHNAM<>""
  [M:ECP5]TCHNAM(nolign-1) = [F:HRSES]TCHNAM
 Endif
 If [F:HRSES]TCHEMP<>""
  Read [ID2]ID0=[F:HRSES]TCHEMP : # Ne pas utiliser [ID]
  If !fstat
   If [M:ECP5]TCHNAM(nolign-1)<>""
    [M:ECP5]TCHNAM(nolign-1) -= mess(57,147,1)-[F:ID2]NAM
   Else
    [M:ECP5]TCHNAM(nolign-1) = [F:ID2]NAM
   Endif
  Endif
 Endif
Next
[M:ECP5]NBRSTG = nolign
Filter [INS]
Return

