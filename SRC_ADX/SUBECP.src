#LIPET - X3-29323 - 15-03-2017 - START
Funprog GET_NAMFLUX()
End "CAR"
#LIPET - X3-29323 - 15-03-2017 - END

#LIPET - X3-29323 - 15-03-2017 - START
$SET_GLOBALCOL
If(!func ALLUTI())
  Local Integer NIV(0..20)
  Call GET_NIVREQ_ECP(NIV)
  If(find(0,NIV)<>1)
    #on calcule les subordonnées
     Global Char G_FLXMAT(GLONEML)(0..),G_FLXCTR(GLONHRCTR)(0..)
     Local Integer WNBCTR
     Call SET_CTRLIST(GREFNUM,NIV,G_FLXMAT,G_FLXCTR,WNBCTR)
  Endif
Endif
Return
#LIPET - X3-29323 - 15-03-2017 - END

#LIPET - X3-29323 - 15-03-2017 - START
Subprog SET_CTRLIST(MGR, TTYPMGR , TREFNUM, TCTRNUM, NBCTR)
Value Char MGR()
Value Integer TTYPMGR()
Variable Char TREFNUM()(), TCTRNUM()()
Variable Integer NBCTR

Local Char CRITERE(250), CRITERE1(250)
Local Integer ISCHEF, OK_CONTROLE
Local Char WSVCLECTR(100) :
Local Char WTCTR(100)(0..) :
# Ouverture ESB
If !clalev([F:ESB])  : Local File EMPSBD [ESB]    : Endif
If !clalev([F:WCTR_])  : Local File EMPLOCTR [WCTR_]    : Endif
If !clalev([F:WID_])  : Local File EMPLOID [WID_]    : Endif

Local Date TODAY : TODAY=date$

[L]CRITERE = "[F:WID_]ENAFLG=2"
If [L]MGR <> ""
  CRITERE += "& [F:ESB]CHEF="-"'"+[L]MGR+"'"
  CRITERE += "& (([F:WCTR_]FLGRET<>2 & [F:WCTR_]CTRDAT<=date$) | ([F:WCTR_]FLGRET=2 & [F:WCTR_]RETDATEFF<=date$)) & ([F:WCTR_]XITDAT=[0/0/0] or [F:WCTR_]XITDAT>date$)"
Endif


 Link [F:ESB] With
&   [F:WCTR_]CTR0 = [F:ESB]REFNUM;[F:ESB]CTRNUM;[F:ESB]CTRDAT
& , [F:WID_]ID0 = [F:WCTR_]REFNUM
&   As [LNK]
&   Where evalue(CRITERE)
& Order By Key CLE =[F:ESB]CHEF;[F:ESB]REFNUM;[F:ESB]CTRNUM;[F:ESB]CTRDAT


Raz [L]NBCTR, [L]TREFNUM, [L]TCTRNUM
[L]NBCTR = -1

For [F:LNK]
  # Ne retourner qu'une ligne couple matricule/contrat
  [L]WSVCLECTR=[F:WCTR_]REFNUM+"~"+[F:WCTR_]CTRNUM+"~"+[F:WCTR_]CTRDAT
  If [L]NBCTR < 0 | !find([L]WSVCLECTR,[L]WTCTR(0..[L]NBCTR))
    [L]ISCHEF = func TRTPREPAY.ISCHEF([L]MGR, [L]TTYPMGR,
&                                    [F:WCTR_]REFNUM, [F:WCTR_]CTRNUM, [F:WCTR_]CTRDAT, "1234")

    If [L]ISCHEF
        Call CONTROLE([F:WID_]REFNUM, [F:WCTR_]CTRDAT, [F:WCTR_]CTRNUM, "", [L]OK_CONTROLE, 0) From DIVPAYE
        If [L]OK_CONTROLE
            If [L]NBCTR>=dim([L]TREFNUM)
              GERR=1
              Break
            Endif
            [L]NBCTR += 1
            [L]TREFNUM([L]NBCTR) = [F:WCTR_]REFNUM
            [L]TCTRNUM([L]NBCTR) = [F:WCTR_]CTRNUM
            [L]WTCTR([L]NBCTR) = [L]WSVCLECTR
        Endif
    Endif
  Endif
Next
If GERR=1
   GMESSAGE="GET_CTRLIST :"-func AFNC.MES1(mess(80,10701,1),num$(NBCTR))
  End
Endif
[L]NBCTR += 1

Sorta [L]NBCTR [L]TREFNUM, [L]TCTRNUM Order By [L]TREFNUM(indice), [L]TCTRNUM(indice)

End
#LIPET - X3-29323 - 15-03-2017 - END

