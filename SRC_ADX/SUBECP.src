$FILGAUCHE
FILGAUSUP = "[F:ID]FLGNEWSAL<>2"

#LIPET - X3-29323 - 15-03-2017 - START
#FQ96481 - 2426
If dim(G_FLXCTR)>0
  FILGAUSUP -= "& (GREFNUM=[F:ECT]REFNUM or find([F:ECT]CTRNUM,G_FLXCTR))"
Endif
#LIPET - X3-29323 - 15-03-2017 - END
#78892
Call FILTREROLE("EML",FILGAUSUP) From SUBEML
# On cumule...
Call FILTREROLE("ECP",FILGAUSUP) From SUBEML
#LIPET - X3-29323 - 15-03-2017 - START
Call FILTREROLE("CTR",FILGAUSUP) From SUBEML
#LIPET - X3-29323 - 15-03-2017 - END
If GUSRACS<>2
 FILGAUSUP -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))'
 FILGAUSUP -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
Endif
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 FILGAUSUP -= '& find([F:ECT]FCY,GUSRFCY(1..GNBAUZ))'
Endif


#pca - 29/08/2012 - Filter left list based on legislation
FILGAUCHE = "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) | [F:FCY]LEG='' | GLEGFIL='')"
If FILGAUSUP <> '' FILGAUSUP -= '&' Endif
FILGAUSUP -= "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) | [F:FCY]LEG='' | GLEGFIL='')"

Return

$FIN_ACTION
If find(REPONSE,GSTAFIR,GSTASUI,GSTAPRE,GSTALAS) & currbox="GAU_CHE1"
 Gosub REFRESH_LISTGAU
Endif
Return

$AVANT_CHOI
If DEBUT=1
 Gosub REFRESH_LISTGAU
 DEBUT = 0
Endif
Return

# FQ81085 - MABON 22/06/12 - Navigate in the records, taking into account GLEGFIL
$FILECP

  CRITECP = "[F:ID]FLGNEWSAL<>2"
  If GLEGFIL<>""
    If CRITECP<>"" Then CRITECP-="&" : Endif
    CRITECP -= "(([F:FCY]LEG<>'' & (find([F:FCY]LEG,'"+GLEGFIL+"','')>0)) | [F:FCY]LEG='' | GLEGFIL='')"
  Endif

  Call FILTREROLE("EML",CRITECP) From SUBEML
  Call FILTREROLE("ECP",CRITECP) From SUBEML

  If GUSRACS<>2
    CRITECP -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))'
    CRITECP -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
  Endif
  If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
    CRITECP -= '& find([F:ECT]FCY,GUSRFCY(1..GNBAUZ))'
  Endif

  Filter [ECT_] Where evalue(CRITECP)
Return

$APRES_CHOI

  Case REPONSE
    When GSTASUI, GSTAPRE, GSTAFIR,GSTALAS
      Gosub FILECP
      If REPONSE=GSTASUI Then Read [ECT_]ECT0 > [M:ECP0]REFNUM;[M:ECP0]CTRNUM  : Endif
      If REPONSE=GSTAPRE Then Read [ECT_]ECT0 < [M:ECP0]REFNUM;[M:ECP0]CTRNUM  : Endif
      If REPONSE=GSTAFIR Then Read [ECT_]ECT0 First             : Endif
      If REPONSE=GSTALAS Then Read [ECT_]ECT0 Last              : Endif
      Filter [ECT_]
      Gosub SUIVPREC From TOOLSHRLEG
  Endcase
Return
# End MABON

