#Next
ZONE = "NBREXM" : Gosub SET_ZONE From SUBEML2
If MA Then
  If [M]FLGADD1=1
   Delete [F:HREXM] Where REFNUM=[F:ID]REFNUM
   If fstat=1
    GOK = -1 : GLOCK = "$EMPLOEXM"-[F:ID]REFNUM
   Endif
  Endif
  If GOK<=0 : Return : Endif
  For nolign=[M]NBREXM To 1 Step -1
   Readlock [F:HREXM]EXM0=[M:ECP0]REFNUM;[M]NBREXM-(nolign-1)
   If fstat
    Raz [F:HREXM]
    [F:HREXM]=[M]
    [F:HREXM]REFNUM = [F:ID]REFNUM
    [F:HREXM]NUMLIG = [M]NBREXM - (nolign-1)
    If dim([F:HREXM]CREDAT)>0 : [F:HREXM]CREDAT = date$     : Endif
    If dim([F:HREXM]CRETIM)>0 : [F:HREXM]CRETIM = time      : Endif
    If dim([F:HREXM]CREUSR)>0 : [F:HREXM]CREUSR = GUSER     : Endif
    If dim([F:HREXM]EXPNUM)>0 : [F:HREXM]EXPNUM = [C]EXPORT : Endif
    Write[F:HREXM]
    If fstat
     GOK = 0 : Call FSTA("HREXM") From GLOCK : Break
    Endif
   Else
    [F:HREXM]=[M]
    If dim([F:HREXM]UPDDAT)>0 : [F:HREXM]UPDDAT = date$     : Endif
    If dim([F:HREXM]UPDTIM)>0 : [F:HREXM]UPDTIM = time      : Endif
    If dim([F:HREXM]UPDUSR)>0 : [F:HREXM]UPDUSR = GUSER     : Endif
    If dim([F:HREXM]EXPNUM)>0 : [F:HREXM]EXPNUM = [C]EXPORT : Endif
    Rewrite[F:HREXM]
    If fstat
     GOK = 0 : Call FSTA("HREXM") From GLOCK : Break
    Endif
   Endif
  Next
Endif
# Fin FQ89889
#LIPET - X3-29323 - 15-03-2017 - END
Return

