   Readlock [F:TRY]TRY0=[M:ECP0]REFNUM;[M]NBRTRY-(nolign-1)
   If fstat
    Raz [F:TRY]
    [F:TRY]=[M]
    [F:TRY]REFNUM = [F:ID]REFNUM
    [F:TRY]NUMLIG = [M]NBRTRY-(nolign-1)
    If dim([F:TRY]CREDAT)>0 : [F:TRY]CREDAT = date$     : Endif
