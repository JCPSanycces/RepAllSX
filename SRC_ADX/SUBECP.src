$DELETE_EVAFICTIF
If(dim([M:ECP4]NBREVAD)<>-1 and [M]NBREVAD)
Local Integer WI
For WI=0 To [M]NBREVAD-1
 Delete [EVE]EVE0=[M:ECP0]REFNUM;[M:ECP0]CTRNUM;[M:ECP4]DEVADATSTR(WI);[M:ECP4]DEVADATEND(WI);[M:ECP4]DEVATYP(WI)
 If fstat=1
  GOK = -1 : GLOCK = "$EVAEMP"-[M:ECP0]REFNUM-[M:ECP0]CTRNUM-num$([M:ECP4]DEVADATSTR(WI))-num$([M:ECP4]DEVADATEND(WI))-num$([M:ECP4]DEVATYP(WI))
  Break
 Endif
Next

Endif
#LIPET - X3-29323 - 15-03-2017 - END
Return

$SAUVE_CPC
# Des compétences ont-elles été supprimées
If [M:ECP2]NBRDLT>0
 For I=0 To [M:ECP2]NBRDLT-1
  Delete [CPE]CPE0=[M:ECP0]REFNUM;[M:ECP2]DATDLT(I);[M:ECP2]CPCDLT(I)
  If fstat=1
   GOK = -1 : GLOCK = "$CPCEMP"-[M:ECP0]REFNUM-num$([M:ECP2]DATDLT(I))-[M:ECP2]CPCDLT(I)
   Break
  Endif
 Next
Endif
If GOK<=0 : Return : Endif
# Enregistrement
For nolign=[M:ECP2]NBRCPC To 1 Step -1
 Readlock [F:CPE]CPE1=[M:ECP0]REFNUM;[M:ECP2]CPC(nolign-1);[M:ECP2]CPCDAT(nolign-1)
 If fstat
  Raz [F:CPE]
  [F:CPE]REFNUM = [M:ECP0]REFNUM
  [F:CPE]CPCDAT = [M:ECP2]CPCDAT(nolign-1)
  [F:CPE]CPC    = [M:ECP2]CPC(nolign-1)
  [F:CPE]LEVCPC = [M:ECP2]LEVCPC(nolign-1)
  [F:CPE]ORICPC = [M:ECP2]ORICPC(nolign-1)
  If dim([F:CPE]CREDAT)>0 : [F:CPE]CREDAT = date$     : Endif
  If dim([F:CPE]CRETIM)>0 : [F:CPE]CRETIM = time      : Endif
  If dim([F:CPE]CREUSR)>0 : [F:CPE]CREUSR = GUSER     : Endif
  If dim([F:CPE]EXPNUM)>0 : [F:CPE]EXPNUM = [C]EXPORT : Endif
  Write [CPE]
  If fstat
   GOK = 0 : Call FSTA("CPE") From GLOCK : Break
  Endif
 Else
  [F:CPE]LEVCPC = [M:ECP2]LEVCPC(nolign-1)
  [F:CPE]ORICPC = [M:ECP2]ORICPC(nolign-1)
  If dim([F:CPE]UPDDAT)>0 : [F:CPE]UPDDAT = date$     : Endif
  If dim([F:CPE]UPDTIM)>0 : [F:CPE]UPDTIM = time      : Endif
  If dim([F:CPE]UPDUSR)>0 : [F:CPE]UPDUSR = GUSER     : Endif
  If dim([F:CPE]EXPNUM)>0 : [F:CPE]EXPNUM = [C]EXPORT : Endif
  Rewrite[F:CPE]
  If fstat
   GOK = 0 : Call FSTA("CPE") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif
# JML 12/08/10 LOT P02
# Des compétences ont-elles été supprimées
If [M:ECP2]NBRDLTVAL>0
 For I=0 To [M:ECP2]NBRDLTVAL-1
  Delete [CPE]CPE0=[M:ECP0]REFNUM;[M:ECP2]DATDLTVAL(I);[M:ECP2]CPCDLTVAL(I)
  If fstat=1
   GOK = -1 : GLOCK = "$CPCEMP"-[M:ECP0]REFNUM-num$([M:ECP2]DATDLTVAL(I))-[M:ECP2]CPCDLTVAL(I)
   Break
  Endif
 Next
Endif
If GOK<=0 : Return : Endif
For nolign=[M:ECP2]NBRVAL To 1 Step -1
 Readlock [F:CPE]CPE1=[M:ECP0]REFNUM;[M:ECP2]CPCVAL(nolign-1);[M:ECP2]CPCDATVAL(nolign-1)
 If fstat
  Raz [F:CPE]
  [F:CPE]REFNUM = [M:ECP0]REFNUM
  [F:CPE]CPCDAT = [M:ECP2]CPCDATVAL(nolign-1)
  [F:CPE]CPC    = [M:ECP2]CPCVAL(nolign-1)
  [F:CPE]LEVCPC = [M:ECP2]LEVCPCVAL(nolign-1)
  [F:CPE]ORICPC = [M:ECP2]ORICPCVAL(nolign-1)
  If dim([F:CPE]CREDAT)>0 : [F:CPE]CREDAT = date$     : Endif
  If dim([F:CPE]CRETIM)>0 : [F:CPE]CRETIM = time      : Endif
  If dim([F:CPE]CREUSR)>0 : [F:CPE]CREUSR = GUSER     : Endif
  If dim([F:CPE]EXPNUM)>0 : [F:CPE]EXPNUM = [C]EXPORT : Endif
  Write [CPE]
  If fstat
   GOK = 0 : Call FSTA("CPE") From GLOCK : Break
  Endif
 Else
  [F:CPE]LEVCPC = [M:ECP2]LEVCPCVAL(nolign-1)
  [F:CPE]ORICPC = [M:ECP2]ORICPCVAL(nolign-1)
  If dim([F:CPE]UPDDAT)>0 : [F:CPE]UPDDAT = date$     : Endif
  If dim([F:CPE]UPDTIM)>0 : [F:CPE]UPDTIM = time      : Endif
  If dim([F:CPE]UPDUSR)>0 : [F:CPE]UPDUSR = GUSER     : Endif
  If dim([F:CPE]EXPNUM)>0 : [F:CPE]EXPNUM = [C]EXPORT : Endif
  Rewrite[CPE]
  If fstat
   GOK = 0 : Call FSTA("CPE") From GLOCK : Break
  Endif
 Endif
Next nolign
If GOK<1 : Return : Endif
Return

$SAUVE_EXM
