$SETBOUT
Call VIREBOUT (CHAINE,"CDH") From GOBJET
Return

$LIENS
#If [F:ECT]CTRNUM=""
#SEGAY 13/01/11 :# Si on clique sur la liste gauche [F:ECT] est alimenté
#Attention quand on fait F5 on se positionne sur le dernier enregistrement [F:ECT] de la liste gauche
#70584+70956
If [F:ECT]CTRNUM<>"" & [M:ECP0]CTRNUM="" & [F:ECT]REFNUM=[F:ID]REFNUM
  [M:ECP0]CTRNUM = [F:ECT]CTRNUM
Endif
#FIN SEGAY 13/01/11

If [M:ECP0]CTRNUM=""
 Filter [ECT] Where REFNUM=[F:ID]REFNUM
 If GLEGFIL="" Then
  Read [ECT]ECT0 Last
  [M:ECP0]CTRNUM = [F:ECT]CTRNUM
 Else
  For [F:ECT]
    Call LECTURE("FCY", [F:ECT]FCY, "") From CONTOBJ
    If GLEGFIL=func TOOLSHRLEG.GETLEGFCY([F:ECT]FCY) Then
      [M:ECP0]CTRNUM = [F:ECT]CTRNUM
      Break
    Endif
  Next
#SEGAY US 800 28/09/12 For Load (tape)contract if GLEGFIL <> LEG contract
  If [M:ECP0]CTRNUM=""
   Read [ECT]ECT0 Last
   [M:ECP0]CTRNUM = [F:ECT]CTRNUM
  Endif
 Endif
 Filter [ECT]
Endif

#DBA : Push Up in the If
#[M:ECP0]CTRNUM = [F:ECT]CTRNUM
#

Read [ID]ID0=[F:ID]REFNUM
If !fstat
 If [F:ID]FLGMULCTR<>2
  Diszo [M:ECP0]CTRNUM
 Else
  Actzo [M:ECP0]CTRNUM
 Endif
Endif
Affzo [M:ECP0]CTRNUM

#59593
Filter [HRCTR] Where REFNUM=[M:ECP0]REFNUM & CTRNUM=[M:ECP0]CTRNUM
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If !fstat
 [M:ECP0]FCY     = [F:HRCTR]ETRFCY
 Affzo [M:ECP0]FCY
Endif
# FQ83632 - MABON 02/10/12 - The insurance social numbers are added in the contract
[M:ECP1]NUMSSCCTR  = [F:HRCTR]NUMSSCCTR
[M:ECP1]NUMSSCCTR2 = [F:HRCTR]NUMSSCCTR2
# End MABON

# FQ81085 - MABON 05/07/12 - Find the good local menu for the title, depending on the site
Local Char NUMLIB(10)
Call PARAM([M:ECP0]FCY,"CIVIL",NUMLIB) From ADOVAL



If [F:HRCTR]CIVCTR>0 Then [M:ECP0]CIVCTRA=mess([F:HRCTR]CIVCTR,val(NUMLIB),1) : Endif
# End MABON

# FQ81085 - 22/11/13 - Find the good local menu for the marital status, depending on the site
Local Char NUMLIB(10)
Call PARAM([M:ECP0]FCY,"SITFAM",NUMLIB) From ADOVAL
#LIPET - X3-29323 - 15-03-2017 - START
[M:ECP1]NOLIBM=val([L]NUMLIB)
#LIPET - X3-29323 - 15-03-2017 - END
If [F:ID]SITFAM>0 Then [M:ECP1]SITFAMA=mess([F:ID]SITFAM,val(NUMLIB),1) : Endif
# End MABON

Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GSOCIETE=[F:CPY]CPY
[M:ECP0]CPY=[F:CPY]CPY : Affzo [M:ECP0]CPY
If dim([F:CPY]LEG)>0
  GCURLEG=[F:CPY]LEG
  #PCA 29/08/12 - Added the contract leg US720
  [M:ECP0]LEG=GCURLEG
Endif
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

If func AFNC.ACTIV("HRPAY")
  Gosub DECLARE_PARAM
Endif

#59373 + 59675
If func AFNC.ACTIV("FRT")
 Gosub CHARGE_CAT2483
 Gosub CHARGE_EXM
 Gosub CHARGE_TRY
Endif
Gosub CHARGE_PHOTO

Read [ACV]CODACT="CAR"
If !fstat & [F:ACV]FLACT=2
 Gosub CHARGE_EVAL
 Gosub CHARGE_POSTE
 Gosub CHARGE_CPC
 Gosub CHARGE_CPE
Endif
Read [ACV]CODACT="FRT"
If !fstat & [F:ACV]FLACT=2
 Gosub CHARGE_STAGE
Endif
##########################
