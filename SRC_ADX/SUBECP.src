Subprog B2_NBREVA

Gosub SETNOL
[M]DEVATYP([M]NBREVAD)   =[M]EVATYP(NOL)
[M]DEVADATSTR([M]NBREVAD) =[M]EVADATFIC(NOL)
[M]DEVADATEND([M]NBREVAD) =[M]EVADATFIC(NOL)
[M]DEVADAT([M]NBREVAD)    =[M]EVADATFIC(NOL)
[M]NBREVAD+=1

Dela NOL,1 [M]NBREVA
[M:ECP4]NBREVA-=1
Gosub SET_STYLE From SUBECPCOM
Affzo[M:ECP4]5
# force passage en modif
mkstat=4
End

#LIPET - X3-29323 - 15-03-2017 - END

