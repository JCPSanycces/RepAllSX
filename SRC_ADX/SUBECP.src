###############################################################################################
## Compare les niveaux NIV1 et NIV2 de la compétence COMP par rapport à l'echelle de référence
## Renvoie 1 si NIV1<NIV2
###############################################################################################
Funprog COMPNIV(COMP,NIV1,NIV2)
Value    Char    COMP
Value    Char    NIV1
Value    Char    NIV2
Local Integer COPIER

COPIER = 0
Read [CPC]CPC0=COMP
If !fstat
 Read [HRSCA]SCA0=[F:CPC]CODSCA
 If !fstat
  I = find(NIV1,[F:HRSCA]LEV)
  J = find(NIV2,[F:HRSCA]LEV)
  #61855 : ajout sécurité 'If I & J'
  If I & J
   If [F:HRSCA]LEVREF(I-1)<[F:HRSCA]LEVREF(J-1)
    COPIER = 1
   Endif
  Endif
 Endif
Endif
End COPIER

###############################################################################################
## JML 28/07/10 LOT P02 Obtain LEVREF from COMPETENCE
###############################################################################################
Funprog CPC_LEVREF(P_CPC,P_LEV)
Value    Char    P_CPC()    : # Competence
Value    Char    P_LEV()    : # Level

Local Integer   L_IJ
Local Integer   RETOUR_LEVREF

RETOUR_LEVREF = 0
Read [CPC]CPC0=P_CPC
If !fstat
 Read [HRSCA]SCA0=[F:CPC]CODSCA
 If !fstat
  L_IJ = find(P_LEV,[F:HRSCA]LEV)
  If L_IJ
   RETOUR_LEVREF = [F:HRSCA]LEVREF(L_IJ-1)
  Endif
 Endif : # If !fstat [SCA]
Endif : # If !fstat [CPC]
End RETOUR_LEVREF

######################################################################################
# Clic droit sur l'historique d'une compétence

$OUVRE_HIS
If clalev([F:CPE])=0 : Local File CPCEMP [CPE] : Endif
Global   Integer    G_DEL_HIS # SEGAY - 19/03/13 - FQ88721 - Suppression historique
G_DEL_HIS=0

Return

$DEBUT
[M:CPH]NBRHIS=0
# JML 12/08/10 Just show what's learned with CPCDAT<>0
Filter [CPE] Where [CPE]REFNUM=[M:ECP0]REFNUM & [CPE]CPC=PARAM(1) & [CPE]CPCDAT<>[0/0/0]
For [CPE]CPE1
 [M:CPH]CPCHIS([M:CPH]NBRHIS)    = [F:CPE]CPC
 [M:CPH]LEVCPCHIS([M:CPH]NBRHIS) = [F:CPE]LEVCPC
 [M:CPH]CPCDATHIS([M:CPH]NBRHIS) = [F:CPE]CPCDAT
 [M:CPH]ORICPCHIS([M:CPH]NBRHIS) = [F:CPE]ORICPC
 [M:CPH]NBRHIS +=1
Next
Filter [CPE]
Sorta [M]NBRHIS [M]NBRHIS Order By CPCDATHIS([S]indice) Desc
Affzo[CPH]
Return

# SEGAY - 19/03/13 - FQ88721 - Suppression historique
$OKCPCHIS
Local Integer L_OK
If dim(G_DEL_HIS)> 0 & G_DEL_HIS=1
  GMESSAGE = mess(119,10720,1) # Des compétences ont été supprimées, voulez-vous confirmer ?
  L_OK = 1
  Call AVERTIR(GMESSAGE,L_OK) From GESECRAN
  Raz GMESSAGE
Endif
If L_OK<>2 : Return : Endif
GOK = 1
Call DEBTRANS From GLOCK
Trbegin [CPE]
Gosub TRANSAC
If   GOK<0 : Goto ROLL_TR1
Elsif !GOK : Goto AB_TR1
Endif
Commit
Return

# SEGAY - 19/03/13 - FQ88721 - Suppression historique
$TRANSAC
Filter [CPE] Where [CPE]REFNUM=[M:ECP0]REFNUM & [CPE]CPC=PARAM(1) & [CPE]CPCDAT<>[0/0/0]
For [CPE]CPE1
  If !find([F:CPE]CPCDAT,[M]CPCDATHIS(0..[M:CPH]NBRHIS-1)) Then
    Delete
    If fstat=1
     GOK = -1 : GLOCK = "$CPCEMP"-[M:ECP0]REFNUM-PARAM(1)-num$([CPE]CPCDAT)
     Break
    Endif
  Endif
Next
Filter [CPE]
Return

$AB_TR1
Rollback
Call ERREUR(mess (17,10107,1)) From GESECRAN :#Rollback suite à une erreur dans la transaction
Return
#######################################################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto OKCPCHIS : Endif
Return
#######################################################
# SEGAY - 19/03/13 - FQ88721 - Suppression historique
$FINCPCHIS
 If dim(G_DEL_HIS)> 0 : Kill G_DEL_HIS : Endif
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran CPCHIS) 19/03/2013 11:07:46 (SEGAY)
######################################################################################
# SEGAY - 19/03/13 - FQ88721 - Suppression historique
Subprog C_NBRHIS
# Suppression interdite sur les compétences antérieures héritées (non initiale et non manuelle et non poste)
If status=65 Then
  If !find([M:CPH]ORICPCHIS(nolign-1),1,4,len(mess(0,10939,1))) Then
   # Il est interdit de supprimer des compétences mises à jour automatiquement
   GMESSAGE = mess(19,10720,1)
   mkstat = 2 : End
  Endif
  If nolign = 1 Then
   # Il est interdit de supprimer la dernière des compétences
   GMESSAGE = mess(120,10720,1)
   mkstat = 2 : End
  Endif
  If dim(G_DEL_HIS)> 0 : G_DEL_HIS=1 : Endif
Endif
End


