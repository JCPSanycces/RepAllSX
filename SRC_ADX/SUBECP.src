    If dim([F:TRY]UPDUSR)>0 : [F:TRY]UPDUSR = GUSER     : Endif
    If dim([F:TRY]EXPNUM)>0 : [F:TRY]EXPNUM = [C]EXPORT : Endif
    Rewrite[F:TRY]
    If fstat
