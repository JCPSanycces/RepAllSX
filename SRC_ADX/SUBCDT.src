#<AdxTL>@(#)1.0.0.0 $Revision$
#######################################################################
# SUBCDT : Transactions de saisie des comptes/sections   MBT 13/06/06 #
#---------------------------------------------------------------------#
# Gestion de l'écran (actions sur champ) :                            #
#   COADIETRS3 [M:CDT]                                                #
# Tables mise à jour :                                                #
#   DIETRS [F:DTR] Table complément transaction pour axes analytiques #
#   COATRS [F:CAT] Table complément transaction pour comptes cptables #
#   Clé d'accès:                                                      #
#   - ABRFIC abréviation table des transactions de saisie             #
#     "PTR" = Transactions achats                                     #
#     "SLT" = Transactions ventes                                     #
#     "CTR" = Transactions CRM                                        #
#     "SRT" = Transactions stocks                                     #
#     "MTS" = Transactions GPAO                                       #
#     "BTS" = Transactions plans                                      #
#   - DTRTYP type de transaction pour <ABRFIC>                        #
#   - DTRNUM code de transaction pour <ABRFIC>                        #
#######################################################################
# GA 08/2006 selon SUBDST                                             #
#######################################################################


#-----------------------------------------------------#
# Après modification du mode saisie de la répartition #
#-----------------------------------------------------#
Subprog AM_DSPCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=3
  [M:CDT]DSPSCR=1
  If !GIMPORT  Affzo [CDT]DSPSCR : Grizo [CDT]DSPSCR : Endif
Elsif !GIMPORT
  Actzo [CDT]DSPSCR
Endif
End


#------------------------------------------------------#
# Avant saisie du code tableau-fiche de la répartition #
#------------------------------------------------------#
Subprog AS_DSPSCR(VALEUR)
Variable Integer VALEUR
If [M:CDT]DSPCOD=3  VALEUR=1 : mkstat=2 : Endif
End

#CHECK UNUSED_BEGIN
#--------------------#
# Avant saisie NBLED #
#--------------------#
Subprog AS_NBLED
If [M:CDT]NBLED=0
   Gosub CHARG_LED
Endif
End
#CHECK UNUSED_END

#--------------------#
# Avant saisie NBCOA #
#--------------------#
Subprog AS_NBCOA
If [M:CDT]NBCOA=0
   Gosub CHARG_COA
Endif
End


#--------------------#
# Avant saisie NBDIE #
#--------------------#
Subprog AS_NBDIE
If [M:CDT]NBDIE=0 & GOPTCANA>0
   Gosub CHARG_DIE
Endif
End


#-------------------------------------------------------#
# Après modification du mode affichage des plans        #
#-------------------------------------------------------#
Subprog AM_FLGACCSCR1(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR=1
# Plans non affichés pour "Entête"
   For I=0 To [M:CDT]NBCOA-1
       [M:CDT]ACCCOD1(I)=3    : # Invisible
   Next I
   Affzo [M:CDT]ACCCOD1
   Grizo [M:CDT]ACCCOD1
Else
   Actzo [M:CDT]ACCCOD1
Endif
End

#-------------------------------------------------------#
# Après modification du mode affichage des plans        #
#-------------------------------------------------------#
Subprog AM_FLGACCSCR2(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR=1
# Plans non affichés pour "Détail 1"
   For I=0 To [M:CDT]NBCOA-1
       [M:CDT]ACCCOD2(I)=3    : # Invisible
   Next I
   Affzo [M:CDT]ACCCOD2
   Grizo [M:CDT]ACCCOD2
Else
   Actzo [M:CDT]ACCCOD2
Endif
End

#-------------------------------------------------------#
# Après modification du mode affichage des plans        #
#-------------------------------------------------------#
Subprog AM_FLGACCSCR3(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR=1
# Plans non affichés pour "Détail 1"
   For I=0 To [M:CDT]NBCOA-1
       [M:CDT]ACCCOD3(I)=3    : # Invisible
   Next I
   Affzo [M:CDT]ACCCOD3
   Grizo [M:CDT]ACCCOD3
Else
   Actzo [M:CDT]ACCCOD3
Endif
End


#-------------------------------------------------------#
# Après modification du mode affichage des axes         #
#-------------------------------------------------------#
Subprog AM_FLGCCESCR1(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR=1
# Axes non affichés pour "Entête"
   For I=0 To [M:CDT]NBDIE-1
       [M:CDT]CCECOD1 (I)=3    : # Invisible
   Next I
   Affzo [M:CDT]CCECOD1
   Grizo [M:CDT]CCECOD1
Else
   Actzo [M:CDT]CCECOD1
Endif
End

#-------------------------------------------------------#
# Après modification du mode affichage des axes         #
#-------------------------------------------------------#
Subprog AM_FLGCCESCR2(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR=1
# Axes non affichés pour "Détail 1"
   For I=0 To [M:CDT]NBDIE-1
       [M:CDT]CCECOD2(I)=3    : # Invisible
   Next I
   Affzo [M:CDT]CCECOD2
   Grizo [M:CDT]CCECOD2
Else
   Actzo [M:CDT]CCECOD2
Endif
End

#-------------------------------------------------------#
# Après modification du mode affichage des axes         #
#-------------------------------------------------------#
Subprog AM_FLGCCESCR3(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR=1
# Axes non affichés pour "Détail 1"
   For I=0 To [M:CDT]NBDIE-1
       [M:CDT]CCECOD3(I)=3    : # Invisible
   Next I
   Affzo [M:CDT]CCECOD3
   Grizo [M:CDT]CCECOD3
Else
   Actzo [M:CDT]CCECOD3
Endif
End


#CHECK UNUSED_BEGIN
################################################################
# Traitement des axes analytiques et de l'onglet DIESCRTRS     #
# ------------------------------------------------------------ #
# Doivent être chargés :                                       #
#  [L]WDIE_ABRFIC abréviation table des transactions de saisie #
#     "PTR" = Transactions achats                              #
#     "SLT" = Transactions ventes                              #
#     "CTR" = Transactions CRM                                 #
#     "SRT" = Transactions stocks                              #
#     "MTS" = Transactions GPAO                                #
#     "BTS" = Transactions plans                               #
#                                                              #
#  [L]WDIE_DTRTYP type de transaction (1 à ..)                 #
################################################################
# Appel depuis SUBPTE - Actions de l'objet PTE                 #
################################################################
$TRT_CDT
#-----
# ne pas planter si écran absent
If !clalev([M:CDT]) : Return : Endif
#-----
If dim(WDIE_DTRNUM)<=0 : Local Char    WDIE_DTRNUM(GLONTRS) : Endif : # Code de la transaction en cours
If dim(WDIE_INDICE)<=0 : Local Integer WDIE_INDICE          : Endif : # Indice pour chargement/déchargement axes
#-----
#ADNGO - 2016-12-19 - X3-12158- START
#Case ACTION
#  When "OUVRE"     : Gosub OUVRE_DIETRS : Gosub OUVRE_COATRS
#  When "AFFMASK"   : Gosub INVISIBLE
#  When "LIENS"     : Gosub LIENS_DIETRS : Gosub LIENS_COATRS
#  When "RAZCRE"    : Gosub RAZCR_DIETRS : Gosub RAZCR_COATRS
#  When "CREATION"  : Gosub CREAT_DIETRS : Gosub CREAT_COATRS
#  When "MODIF"     : Gosub MODIF_DIETRS : Gosub MODIF_COATRS
#  When "ANNULE"    : Gosub ANNUL_DIETRS : Gosub ANNUL_COATRS
#Endcase
#Return
Case ACTION
  When "OUVRE"     : Gosub OUVRE_DIETRS : Gosub OUVRE_COATRS
  When "AFFMASK"   : Gosub INVISIBLE
  When "LIENS"     : Gosub LIENS_DIETRS : Gosub LIENS_COATRS
  When "FERME"     : Gosub FERME
  When "RAZCRE"    : Gosub RAZCR_DIETRS : Gosub RAZCR_COATRS
  When "CREATION"  : Gosub CREAT_DIETRS : Gosub CREAT_COATRS
  When "MODIF"     : Gosub MODIF_DIETRS : Gosub MODIF_COATRS
  When "ANNULE"    : Gosub ANNUL_DIETRS : Gosub ANNUL_COATRS
Endcase
Return
#ADNGO - 2016-12-19 - X3-12158- END

#####################################################################
# Ouverture de la table transaction saisie analytique si nécessaire #
#####################################################################
$OUVRE_DIETRS
#ADNGO - 2016-12-19 - X3-12158- START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#ADNGO - 2016-12-19 - X3-12158- END
#-----
If !clalev([F:DTR])
  If dim(APPLI)>0 & APPLI<>""
    Local File =APPLI+".DIETRS" [DTR]
  Else
    Local File DIETRS  [DTR]
  Endif
Endif
If GOPTCANA>0
  If !clalev([F:DIE])
    If dim(APPLI)>0 & APPLI<>""
      Local File =APPLI+".GDIE"   [DIE]
    Else
      Local File GDIE  [DIE]
    Endif
  Endif
Endif
#-----
Return


#############################################################################
# Lecture du paramétrage des axes analytiques et chargement du masque écran #
# ------------------------------------------------------------------------- #
#           Table DIETRS [F:DTR] ---> écran DIESCRTRS [M:CDT]               #
#############################################################################
$LIENS_DIETRS
#-----
Gosub RAZCR_DIETRS : # Initialisation de l'onglet "Sections"
#-----
If GOPTCANA=0  Gosub GRISAGE : Return : Endif
#-----
Gosub CODETRANSACT : # Récupération code de la transaction dans [L]WDIE_DTRNUM
#-----
#ADNGO - 2016-12-19 - X3-12158- START
If dim([M:CDT1]LEG)>0 : GCURLEG=[M:CDT1]LEG : Endif
#ADNGO - 2016-12-19 - X3-12158- END

Read [DTR] DTR0=[L]WDIE_ABRFIC;[L]WDIE_DTRTYP;[L]WDIE_DTRNUM;""
If !fstat
  [M:CDT]HEACCECOD=[F:DTR]HEACCECOD
  [M:CDT]DSPCOD   =[F:DTR]DSPCOD
  [M:CDT]DSPSCR   =[F:DTR]DSPSCR
  [M:CDT]STOCCECOD=[F:DTR]STOCCECOD
  If [F:DTR]CCESCR =4    : # Axes non affichés sur "Entête"
     [M:CDT]FLGCCESCR1=1
     Grizo [M:CDT]CCECOD1
  Else
     [M:CDT]FLGCCESCR1=2
     [M:CDT]CCESCR1  =[F:DTR]CCESCR
     Actzo [M:CDT]CCECOD1
  Endif
  If [F:DTR]CCESCR2=4    : # Axes non affichés sur "Détail 1"
     [M:CDT]FLGCCESCR2=1
     Grizo [M:CDT]CCECOD2
  Else
     [M:CDT]FLGCCESCR2=2
     [M:CDT]CCESCR2  =[F:DTR]CCESCR2
     Actzo [M:CDT]CCECOD2
  Endif
  If [F:DTR]CCESCR3=4    : # Axes non affichés sur "Détail 2"
     [M:CDT]FLGCCESCR3=1
     Grizo [M:CDT]CCECOD3
  Else
     [M:CDT]FLGCCESCR3=2
     [M:CDT]CCESCR3  =[F:DTR]CCESCR3
     Actzo [M:CDT]CCECOD3
  Endif
Endif
#-----
For [DTR] DTR0 Where ABRFIC=[L]WDIE_ABRFIC
&                  & DTRTYP=[L]WDIE_DTRTYP
&                  & DTRNUM=[L]WDIE_DTRNUM
&                  & DIE<>""
  If find([F:DTR]DIE,[M:CDT]DIE)
    [L]WDIE_INDICE=find([F:DTR]DIE,[M:CDT]DIE)-1
    [M:CDT]CCECOD1([L]WDIE_INDICE)=[F:DTR]CCECOD
    [M:CDT]CCECOD2([L]WDIE_INDICE)=[F:DTR]CCECOD2
    [M:CDT]CCECOD3([L]WDIE_INDICE)=[F:DTR]CCECOD3
  Endif
Next
#-----
Gosub GRISAGE : # Grisage des champs suivant le contexte
#-----
Return
#ADNGO - 2016-12-19 - X3-12158- START
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
#ADNGO - 2016-12-19 - X3-12158- END
################################################################
# Initialisation des champs écran en début de création ou lien #
################################################################
$RAZCR_DIETRS
#-----
[M:CDT]HEACCECOD  =3
[M:CDT]DSPCOD     =3
[M:CDT]DSPSCR     =1
[M:CDT]STOCCECOD  =3
[M:CDT]FLGCCESCR1 =2 : Actzo [M:CDT]CCECOD1
[M:CDT]FLGCCESCR2 =2 : Actzo [M:CDT]CCECOD2
[M:CDT]FLGCCESCR3 =2 : Actzo [M:CDT]CCECOD3
[M:CDT]CCESCR1    =1
[M:CDT]CCESCR2    =1
[M:CDT]CCESCR3    =1
If GOPTCANA>0
   Gosub CHARG_DIE
Endif
#-----
If ACTION="RAZCRE"
   Gosub GRISAGE : # Grisage des champs suivant le contexte
Endif
#-----
Return


######################################################################
# Création paramètrage des axes analytique à partir du masque écran  #
# ------------------------------------------------------------------ #
#        Ecran DIESCRTRS [M:CDT] ---> table DIETRS [F:DTR]           #
######################################################################
$CREAT_DIETRS
#-----
If GOPTCANA=0  Return : Endif
#-----
Gosub CODETRANSACT : # Récupération code de la transaction dans [L]WDIE_DTRNUM
#-----
Raz [F:DTR]DIE
[F:DTR]=[M:CDT]
[F:DTR]ABRFIC =[L]WDIE_ABRFIC
[F:DTR]DTRTYP =[L]WDIE_DTRTYP
[F:DTR]DTRNUM =[L]WDIE_DTRNUM
[F:DTR]DIE    =""
If [M:CDT]FLGCCESCR1=1 : [F:DTR]CCESCR =4 : Endif
If [M:CDT]FLGCCESCR2=1 : [F:DTR]CCESCR2=4 : Endif
If [M:CDT]FLGCCESCR3=1 : [F:DTR]CCESCR3=4 : Endif
Write [DTR]
If fstat  GOK=0 : Call FSTA("DTR") From GLOCK : Return : Endif
#-----
For [L]WDIE_INDICE=0 To [M:CDT]NBDIE-1
  [F:DTR]DIE    =[M:CDT]DIE    ([L]WDIE_INDICE)
  [F:DTR]CCECOD =[M:CDT]CCECOD1([L]WDIE_INDICE)
  [F:DTR]CCECOD2=[M:CDT]CCECOD2([L]WDIE_INDICE)
  [F:DTR]CCECOD3=[M:CDT]CCECOD3([L]WDIE_INDICE)
  Write [DTR]
  If fstat  GOK=0 : Call FSTA("DTR") From GLOCK : Break : Endif
Next [L]WDIE_INDICE
#-----
Return


#########################################################################
# Mise à jour paramètrage des axes analytique à partir du masque écran  #
# --------------------------------------------------------------------- #
#         Ecran DIESCRTRS [M:CDT] ---> table DIETRS [F:DTR]             #
#########################################################################
$MODIF_DIETRS
#-----
If GOPTCANA=0  Return : Endif
#-----
Gosub ANNUL_DIETRS : If GOK<1  Return : Endif : # Suppression ancien paramétrage
#-----
Gosub CREAT_DIETRS : If GOK<1  Return : Endif : # Enregistrement nouveau paramétrage
#-----
Return


###################################################
# Suppression du paramètrage des axes analytiques #
###################################################
$ANNUL_DIETRS
#-----
If GOPTCANA=0  Return : Endif
#-----
Gosub CODETRANSACT : # Récupération code de la transaction dans [L]WDIE_DTRNUM
#-----
Delete [DTR] Where ABRFIC=[L]WDIE_ABRFIC
&                & DTRTYP=[L]WDIE_DTRTYP
&                & DTRNUM=[L]WDIE_DTRNUM
If fstat=1
  GOK=-1 : GLOCK="$DIETRS"-[L]WDIE_ABRFIC-num$([L]WDIE_DTRTYP)-[L]WDIE_DTRNUM : Return
Endif
#-----
Return


#------------------------------------------------------------#
# Grisage des champs non actifs suivant types de transaction #
#------------------------------------------------------------#
$GRISAGE
# --------- #
# Sections  #
# --------- #
If GOPTCANA=0
  Grizo [CDT]NBDIE
Else
  Actzo [CDT]NBDIE
  If [M:CDT]DSPCOD=3  Grizo [CDT]DSPSCR : Endif
Endif
#-----
Case [L]WDIE_ABRFIC
  When "PTR"
    Case [L]WDIE_DTRTYP
      When 3,6,8
        Gosub AFFZO_DIETRS_LIG
        Gosub AFFZO_COATRS_LIG
      When 9     : # GA 08/2006 ajout TRSTYP=9 transaction d'EO
        Gosub AFFZO_DIETRS_PTE From SUBPTE
        Gosub AFFZO_COATRS_PTE From SUBPTE
    Endcase
Endcase
Return


#------------------------------------------#
# Rendre invisible les champs non utilisés #
#------------------------------------------#
$INVISIBLE
#-----
# --------- #
# Sections  #
# --------- #
If GOPTCANA=0
   Gosub CACHE_DIETRS
Endif
#-----
Case [L]WDIE_ABRFIC
  When "PTR"
    Case [L]WDIE_DTRTYP
      When 1,2   : Chgfmt [M:CDT]HEACCECOD With "-N:1#"
                   Chgfmt [M:CDT]DSPCOD    With "-N:1#"
                   Chgfmt [M:CDT]DSPSCR    With "-N:1#"
                   Chgfmt [M:CDT]STOCCECOD With "-N:1#"
      When 3,4,5 : Chgfmt [M:CDT]DSPCOD    With "-N:1#"
                   Chgfmt [M:CDT]DSPSCR    With "-N:1#"
                   Chgfmt [M:CDT]STOCCECOD With "-N:1#"
      When 6     : Chgfmt [M:CDT]DSPCOD    With "-N:1#"
                   Chgfmt [M:CDT]DSPSCR    With "-N:1#"
      When 7     : Chgfmt [M:CDT]DSPCOD    With "-N:1#"
                   Chgfmt [M:CDT]DSPSCR    With "-N:1#"
                   Chgfmt [M:CDT]STOCCECOD With "-N:1#"
      When 8     : Chgfmt [M:CDT]STOCCECOD With "-N:1#"
      When 9     : Chgfmt [M:CDT]HEACCECOD With "-N:1#" : # GA 08/2006 ajout TRSTYP=9
                   Chgfmt [M:CDT]DSPCOD    With "-N:1#"
                   Chgfmt [M:CDT]DSPSCR    With "-N:1#"
                   Chgfmt [M:CDT]STOCCECOD With "-N:1#"
    Endcase
  When "SLT"
  # Comptes
    Gosub CACHE_COATRS
  # Sections
    Case [L]WDIE_DTRTYP
      When 1,2,3   : Chgfmt [M:CDT]DSPCOD    With "-N:1#"
                     Chgfmt [M:CDT]DSPSCR    With "-N:1#"
                     Chgfmt [M:CDT]STOCCECOD With "-N:1#"
      When 4,5,6,7 : Chgfmt [M:CDT]DSPCOD    With "-N:1#"
                     Chgfmt [M:CDT]DSPSCR    With "-N:1#"
    Endcase
  When "CTR"
  # Comptes
    Gosub CACHE_COATRS
  # Sections
    Case [L]WDIE_DTRTYP
        When 2
            Chgfmt [M:CDT]DSPCOD    With "-N:1#"
            Chgfmt [M:CDT]DSPSCR    With "-N:1#"
            Chgfmt [M:CDT]STOCCECOD With "-N:1#"
        When 3
            Chgfmt [M:CDT]HEACCECOD With "-N:1#"
            Chgfmt [M:CDT]DSPCOD    With "-N:1#"
            Chgfmt [M:CDT]DSPSCR    With "-N:1#"
            Chgfmt [M:CDT]STOCCECOD With "-N:1#"
    Endcase
  When "SRT"
  # Comptes
    Gosub CACHE_COATRS
  # Sections
    Chgfmt [M:CDT]DSPCOD    With "-N:1#"
    Chgfmt [M:CDT]DSPSCR    With "-N:1#"
    Case [L]WDIE_DTRTYP
        When 5
            Chgfmt [M:CDT]HEACCECOD With "-N:1#"
    Endcase


  When "MTS"
  # Comptes
    Gosub CACHE_COATRS
  # Sections
    Chgfmt [M:CDT]HEACCECOD With "-N:1#"
    Chgfmt [M:CDT]DSPCOD    With "-N:1#"
    Chgfmt [M:CDT]DSPSCR    With "-N:1#"
    Chgfmt [M:CDT]STOCCECOD With "-N:1#"
  When "BTS"
  # Comptes
    Gosub CACHE_COATRS
  # Sections
    Chgfmt [M:CDT]HEACCECOD With "-N:1#"
    Chgfmt [M:CDT]DSPCOD    With "-N:1#"
    Chgfmt [M:CDT]DSPSCR    With "-N:1#"
    Chgfmt [M:CDT]STOCCECOD With "-N:1#"
Endcase
#-----
Return



#-----------------------------------#
# Chargement code de la transaction #
#-----------------------------------#
$CODETRANSACT
#-----
Case [L]WDIE_ABRFIC
  When "PTR" : [L]WDIE_DTRNUM=[F:PTR]PTRNUM
  When "SLT" : [L]WDIE_DTRNUM=[F:SLT]STRNUM
  When "CTR" : [L]WDIE_DTRNUM=[F:CTR]CTRNUM
  When "SRT" : [L]WDIE_DTRNUM=[F:SRT]SRTNUM
  When "MTS" : [L]WDIE_DTRNUM=[F:MTS]MTSNUM
  When "BTS" : [L]WDIE_DTRNUM=[F:BTS]BTSNUM
Endcase
#-----
Return


######################################################################
# COPDIETRS : S/P de copie du paramètrage de saisie     MBT 15/06/06 #
#                 des axes analytiques                               #
# ------------------------------------------------------------------ #
# Subprog COPDIETRS (WDIE_ABRFIC,WDIE_DTRTYP,WDIE_DTRNUM)            #
#   WDIE_ABRFIC : Abréviation de la table des transactions de saisie #
#     "PTR" = Transactions achats                                    #
#     "SLT" = Transactions ventes                                    #
#     "CTR" = Transactions CRM                                       #
#     "SRT" = Transactions stocks                                    #
#     "MTS" = Transactions GPAO                                      #
#     "BTS" = Transactions plans                                     #
#                                                                    #
#   WDIE_DTRTYP : Type de transaction (1 à ..)                       #
#                                                                    #
#   WDIE_DTRNUM : Code de la transaction à copier                    #
######################################################################
Subprog COPDIETRS (WDIE_ABRFIC,WDIE_DTRTYP,WDIE_DTRNUM)
Value Char    WDIE_ABRFIC
Value Integer WDIE_DTRTYP
Value Char    WDIE_DTRNUM
#-----
Delete [DTR2] Where ABRFIC=WDIE_ABRFIC
&                 & DTRTYP=WDIE_DTRTYP
&                 & DTRNUM=WDIE_DTRNUM
If fstat=1
  GOK=-1 : GLOCK="$"+[M]DOSDES+".DIETRS"-num$(WDIE_DTRTYP)-WDIE_DTRNUM : End
Elsif fstat
  GOK= 0 : Call RSTA("DTR2",num$(WDIE_DTRTYP)-WDIE_DTRNUM) From GLOCK  : End
Endif
For [DTR1] DTR0 Where ABRFIC=WDIE_ABRFIC
&                   & DTRTYP=WDIE_DTRTYP
&                   & DTRNUM=WDIE_DTRNUM
  [F:DTR2]=[F:DTR1]
  If dim([F:DTR2]UPDUSR)>0  [F:DTR2]UPDUSR=GUSER : Endif
  If dim([F:DTR2]UPDDAT)>0  [F:DTR2]UPDDAT=date$ : Endif
  Write [DTR2]
  If fstat  GOK=0 : Call FSTA("DTR2") From GLOCK : Break : Endif
Next
#-----
End




######################################################################
# COPCOATRS : S/P de copie du paramètrage de saisie     GA  02/08/06 #
#                 des comptes comptables                             #
# ------------------------------------------------------------------ #
# Subprog COPCOATRS (WDIE_ABRFIC,WDIE_DTRTYP,WDIE_DTRNUM)            #
#   WDIE_ABRFIC : Abréviation de la table des transactions de saisie #
#     "PTR" = Transactions achats                                    #
#     "SLT" = Transactions ventes                                    #
#     "CTR" = Transactions CRM                                       #
#     "SRT" = Transactions stocks                                    #
#     "MTS" = Transactions GPAO                                      #
#     "BTS" = Transactions plans                                     #
#                                                                    #
#   WDIE_DTRTYP : Type de transaction (1 à ..)                       #
#                                                                    #
#   WDIE_DTRNUM : Code de la transaction à copier                    #
######################################################################
Subprog COPCOATRS (WDIE_ABRFIC,WDIE_DTRTYP,WDIE_DTRNUM)
Value Char    WDIE_ABRFIC
Value Integer WDIE_DTRTYP
Value Char    WDIE_DTRNUM
#-----
Delete [CAT2] Where ABRFIC=WDIE_ABRFIC
&                 & DTRTYP=WDIE_DTRTYP
&                 & DTRNUM=WDIE_DTRNUM
If fstat=1
  GOK=-1 : GLOCK="$"+[M]DOSDES+".COATRS"-num$(WDIE_DTRTYP)-WDIE_DTRNUM : End
Elsif fstat
  GOK= 0 : Call RSTA("CAT2",num$(WDIE_DTRTYP)-WDIE_DTRNUM) From GLOCK  : End
Endif
For [CAT1] CAT0 Where ABRFIC=WDIE_ABRFIC
&                   & DTRTYP=WDIE_DTRTYP
&                   & DTRNUM=WDIE_DTRNUM
  [F:CAT2]=[F:CAT1]
  If dim([F:CAT2]UPDUSR)>0  [F:CAT2]UPDUSR=GUSER : Endif
  If dim([F:CAT2]UPDDAT)>0  [F:CAT2]UPDDAT=date$ : Endif
  Write [CAT2]
  If fstat  GOK=0 : Call FSTA("CAT2") From GLOCK : Break : Endif
Next
#-----
End


######################################################################
# Ouverture de la table transaction saisie des comptes si nécessaire #
######################################################################
$OUVRE_COATRS
#-----
If !clalev([F:CAT])
  If dim(APPLI)>0 & APPLI<>""
    Local File =APPLI+".COATRS" [CAT]
  Else
    Local File COATRS  [CAT]
  Endif
Endif
If !clalev([F:LED])
  If dim(APPLI)>0 & APPLI<>""
    Local File =APPLI+".GLED"   [LED]
  Else
    Local File GLED  [LED]
  Endif
Endif
If !clalev([F:COA])
  If dim(APPLI)>0 & APPLI<>""
    Local File =APPLI+".GCOA"   [COA]
  Else
    Local File GCOA  [COA]
  Endif
Endif
#-----
Local Char    WDIE_DTRNUM(GLONTRS) : # Code de la transaction en cours
Local Integer WDIE_INDICE          : # Indice pour chargement/déchargement axes
#-----
Return


#############################################################################
# Lecture du paramétrage des axes analytiques et chargement du masque écran #
# ------------------------------------------------------------------------- #
#           Table COATRS [F:CAT] ---> écran COASCRTRS [M:CDT]               #
#############################################################################
$LIENS_COATRS
#-----
Gosub RAZCR_COATRS : # Initialisation de l'onglet "Sections"
#-----
Gosub CODETRANSACT : # Récupération code de la transaction dans [L]WDIE_DTRNUM
#-----
Read [CAT] CAT0=[L]WDIE_ABRFIC;[L]WDIE_DTRTYP;[L]WDIE_DTRNUM;""
If !fstat
  If [F:CAT]ACCSCR1=4    : # Plans de comptes non affichés sur "Entête"
     [M:CDT]FLGACCSCR1=1
     Grizo [M:CDT]ACCCOD1
  Else
     [M:CDT]FLGACCSCR1=2
     [M:CDT]ACCSCR1  =[F:CAT]ACCSCR1
     Actzo [M:CDT]ACCCOD1
  Endif
  If [F:CAT]ACCSCR2=4    : # Plans de comptes non affichés sur "Détail 1"
     [M:CDT]FLGACCSCR2=1
     Grizo [M:CDT]ACCCOD2
  Else
     [M:CDT]FLGACCSCR2=2
     [M:CDT]ACCSCR2  =[F:CAT]ACCSCR2
     Actzo [M:CDT]ACCCOD2
  Endif
  If [F:CAT]ACCSCR3=4    : # Plans de comptes non affichés sur "Détail 2"
     [M:CDT]FLGACCSCR3=1
     Grizo [M:CDT]ACCCOD3
  Else
     [M:CDT]FLGACCSCR3=2
     [M:CDT]ACCSCR3  =[F:CAT]ACCSCR3
     Actzo [M:CDT]ACCCOD3
  Endif
Endif

If dim([M:CDT]NBCOA)>0
# cas Liste des comptes [F:COA]
# -----------------------------
  For [CAT] CAT0 Where ABRFIC=[L]WDIE_ABRFIC
&                    & DTRTYP=[L]WDIE_DTRTYP
&                    & DTRNUM=[L]WDIE_DTRNUM
&                    & COA<>""
    If find([F:CAT]COA,[M:CDT]COA)
      [L]WDIE_INDICE=find([F:CAT]COA,[M:CDT]COA)-1
      [M:CDT]LED    ([L]WDIE_INDICE)=[F:CAT]LED
      [M:CDT]ACCCOD1([L]WDIE_INDICE)=[F:CAT]ACCCOD1
      [M:CDT]ACCCOD2([L]WDIE_INDICE)=[F:CAT]ACCCOD2
      [M:CDT]ACCCOD3([L]WDIE_INDICE)=[F:CAT]ACCCOD3
    Endif
  Next
Elsif dim([M:CDT]NBLED)>0
# cas Liste des référentiels/comptes [F:LED]
# ------------------------------------------
  For [CAT] CAT0 Where ABRFIC=[L]WDIE_ABRFIC
&                    & DTRTYP=[L]WDIE_DTRTYP
&                    & DTRNUM=[L]WDIE_DTRNUM
&                    & LED<>""
    If find([F:CAT]LED,[M:CDT]LED)
      [L]WDIE_INDICE=find([F:CAT]LED,[M:CDT]LED)-1
      [M:CDT]COA    ([L]WDIE_INDICE)=[F:CAT]COA
      [M:CDT]ACCCOD1([L]WDIE_INDICE)=[F:CAT]ACCCOD1
      [M:CDT]ACCCOD2([L]WDIE_INDICE)=[F:CAT]ACCCOD2
      [M:CDT]ACCCOD3([L]WDIE_INDICE)=[F:CAT]ACCCOD3
    Endif
  Next
Endif
#-----
#-----
Gosub GRISAGE : # Grisage des champs suivant le contexte
#-----
Return


################################################################
# Initialisation des champs écran en début de création ou lien #
################################################################
$RAZCR_COATRS
#-----
[M:CDT]FLGACCSCR1 =2 : Actzo [M:CDT]ACCCOD1
[M:CDT]FLGACCSCR2 =2 : Actzo [M:CDT]ACCCOD2
[M:CDT]FLGACCSCR3 =2 : Actzo [M:CDT]ACCCOD3
[M:CDT]ACCSCR1    =2
[M:CDT]ACCSCR2    =3
[M:CDT]ACCSCR3    =2
# cas où on veut charger les comptes [F:COA]
# ------------------------------------------
If dim([M:CDT]NBCOA)>0
  If [M:CDT]NBCOA=0
    Gosub CHARG_COA
  Endif
# cas où on veut charger les référentiels/comptes [F:LED]
# -------------------------------------------------------
Elsif dim([M:CDT]NBLED)>0
  If [M:CDT]NBLED=0
    Gosub CHARG_LED
  Endif
Endif
#-----
If ACTION="RAZCRE"
   Gosub GRISAGE : # Grisage des champs suivant le contexte
Endif
#-----
Return


######################################################################
# Création paramètrage des axes analytique à partir du masque écran  #
# ------------------------------------------------------------------ #
#        Ecran COASCRTRS [M:CDT] ---> table COATRS [F:CAT]           #
######################################################################
$CREAT_COATRS
#-----
Gosub CODETRANSACT : # Récupération code de la transaction dans [L]WDIE_DTRNUM
#-----
Raz [F:CAT]
[F:CAT]=[M:CDT]
[F:CAT]ABRFIC=[L]WDIE_ABRFIC
[F:CAT]DTRTYP=[L]WDIE_DTRTYP
[F:CAT]DTRNUM=[L]WDIE_DTRNUM
[F:CAT]LED   =""
[F:CAT]COA   =""
If [M:CDT]FLGACCSCR1=1 : [F:CAT]ACCSCR1=4 : Endif
If [M:CDT]FLGACCSCR2=1 : [F:CAT]ACCSCR2=4 : Endif
If [M:CDT]FLGACCSCR3=1 : [F:CAT]ACCSCR3=4 : Endif
Write [CAT]
If fstat  GOK=0 : Call FSTA("CAT") From GLOCK : Return : Endif
#-----
Local Integer WNBCOA
If dim([M:CDT]NBCOA)>0
# cas Liste des comptes [F:COA]
# -----------------------------
   WNBCOA = [M:CDT]NBCOA

Elsif dim([M:CDT]NBLED)>0
# cas Liste des référentiels/comptes [F:LED]
# ------------------------------------------
   WNBCOA = [M:CDT]NBLED
Else
   WNBCOA = 0
Endif
For [L]WDIE_INDICE=0 To WNBCOA-1
  [F:CAT]LED    =[M:CDT]LED    ([L]WDIE_INDICE)
  [F:CAT]COA    =[M:CDT]COA    ([L]WDIE_INDICE)
  [F:CAT]ACCCOD1=[M:CDT]ACCCOD1([L]WDIE_INDICE)
  [F:CAT]ACCCOD2=[M:CDT]ACCCOD2([L]WDIE_INDICE)
  [F:CAT]ACCCOD3=[M:CDT]ACCCOD3([L]WDIE_INDICE)
  Write [CAT]
  If fstat  GOK=0 : Call FSTA("CAT") From GLOCK : Break : Endif
Next [L]WDIE_INDICE
#-----
Return


#########################################################################
# Mise à jour paramètrage des axes analytique à partir du masque écran  #
# --------------------------------------------------------------------- #
#         Ecran COASCRTRS [M:CDT] ---> table COATRS [F:CAT]             #
#########################################################################
$MODIF_COATRS
#-----
Gosub ANNUL_COATRS : If GOK<1  Return : Endif : # Suppression ancien paramétrage
#-----
Gosub CREAT_COATRS : If GOK<1  Return : Endif : # Enregistrement nouveau paramétrage
#-----
Return


###################################################
# Suppression du paramètrage des axes analytiques #
###################################################
$ANNUL_COATRS
#-----
Gosub CODETRANSACT : # Récupération code de la transaction dans [L]WDIE_DTRNUM
#-----
Delete [CAT] Where ABRFIC=[L]WDIE_ABRFIC
&                & DTRTYP=[L]WDIE_DTRTYP
&                & DTRNUM=[L]WDIE_DTRNUM
If fstat=1
  GOK=-1 : GLOCK="$COATRS"-[L]WDIE_ABRFIC-num$([L]WDIE_DTRTYP)-[L]WDIE_DTRNUM : Return
Endif
#-----
Return


#-------------------------------------#
# Pas de gestion Sections analytiques #
#-------------------------------------#
$CACHE_COATRS
  Chgtbk [M:CDT]10        With ""
  Chgtbk [M:CDT]15        With ""
  If dim([M:CDT]NBCOA)>0
# cas Liste des comptes [F:COA]
# -----------------------------
    Chgfmt [M:CDT]NBCOA   With "-N:1#"

Elsif dim([M:CDT]NBLED)>0
# cas Liste des référentiels/comptes [F:LED]
# ------------------------------------------
    Chgfmt [M:CDT]NBLED   With "-N:1#"
  Endif
  Chgfmt [M:CDT]ACCSCR1   With "-N:1#"
  Chgfmt [M:CDT]ACCSCR2   With "-N:1#"
  Chgfmt [M:CDT]ACCSCR3   With "-N:1#"
Return

#-------------------------------------#
# Pas de gestion Sections analytiques #
#-------------------------------------#
$CACHE_DIETRS
  Chgtbk [M:CDT]20        With ""
  Chgtbk [M:CDT]25        With ""
  Chgfmt [M:CDT]NBDIE     With "-N:1#"
  Chgfmt [M:CDT]CCESCR1   With "-N:1#"
  Chgfmt [M:CDT]CCESCR2   With "-N:1#"
  Chgfmt [M:CDT]CCESCR3   With "-N:1#"
Return


# ----------------------------#
# Liste des référentiels      #
# ----------------------------#
$CHARG_LED
  If !clalev([F:LED])  Local File =APPLI+".GLED"  [LED] : Endif
  If !clalev([F:GCM])  Local File =APPLI+".GACM"  [GCM] : Endif
  Raz [M:CDT]NBLED
  For [LED] LED0 Where COA<>""         : # uniquement les référentiels associés à un Plan
    [M:CDT]LED    ([M:CDT]NBLED)=[F:LED]LED
    [M:CDT]COA    ([M:CDT]NBLED)=[F:LED]COA
    [M:CDT]ACCCOD1([M:CDT]NBLED)=3
    [M:CDT]ACCCOD2([M:CDT]NBLED)=3
    [M:CDT]ACCCOD3([M:CDT]NBLED)=3
    [M:CDT]NBLED+=1
    If [M:CDT]NBLED>=dim([M:CDT]LED)  Break : Endif
  Next
Return


######################################################################################

# ----------------------------------- #
# Particularités de l'onglet [M:CDT]  #
# Transactions                        #
# - PTC: saisie des commandes         #
# - PTR: saisie des réceptions        #
# - PTF: saisie des factures          #
# ----------------------------------- #
$AFFZO_COATRS_LIG
  Chgtbk [M:CDT]10        With mess(35,0,1)-"-"-mess(5,943,1) : # Mode de saisie - Comptes
  Chgtbk [M:CDT]15        With mess(5,943,1)   : # "Comptes"
  Chgtzn [M:CDT]ACCSCR1   With mess(3,40,1)    : # "Ligne"
  Chgfmt [M:CDT]ACCSCR2   With "-N:1#"
  Chgfmt [M:CDT]ACCSCR3   With "-N:1#"
  Chgfmt [M:CDT]ACCCOD2   With "-N:1#"
  Chgfmt [M:CDT]ACCCOD3   With "-N:1#"

  If dim([M:CDT]NBCOA)>0
# cas Liste des comptes [F:COA]
# -----------------------------
 # "Plan" "Intitulé"  "Ligne"
    Titcol [M:CDT]NBCOA     mess(205,111,1), mess(30,109,1) ,
&                           mess(3,40,1)

  Elsif dim([M:CDT]NBLED)>0
# cas Liste des référentiels/comptes [F:LED]
# ------------------------------------------
 # "Référentiel" "Intitulé"  "Ligne" "Plan" "Intitulé"
    Titcol [M:CDT]NBLED     mess(208,111,1), mess(30,109,1) ,
&                           mess(3,40,1)  ,
&                           mess(205,111,1), mess(30,109,1)
  Endif
  [M:CDT]ACCSCR1=3
Return


#-------------------------------------#
# Gestion des Sections analytiques    #
#-------------------------------------#
$AFFZO_DIETRS_LIG
  Chgtbk [M:CDT]20        With mess(35,0,1)-"-"-mess(401,200,1) : # Mode de saisie - Axe
  Chgtbk [M:CDT]25        With mess(401,200,1) : # "Axes analytiques"
  Chgtzn [M:CDT]CCESCR1   With mess(3,40,1)    : # "Ligne"
  Chgfmt [M:CDT]CCESCR2   With "-N:1#"
  Chgfmt [M:CDT]CCESCR3   With "-N:1#"
  Chgfmt [M:CDT]CCECOD2   With "-N:1#"
  Chgfmt [M:CDT]CCECOD3   With "-N:1#"
 # "Axe"  "Intitulé"  "Ligne"
  Titcol [M:CDT]NBDIE     mess(206,111,1),
&                         mess(30,109,1) ,
&                         mess(3,40,1)
  [M:CDT]CCESCR1=3
Return
#CHECK UNUSED_END


# ----------------------------#
# Liste des sections analytiq #
# ----------------------------#
$CHARG_DIE
  If !clalev([F:DIE])  Local File =APPLI+".GDIE"  [DIE] : Endif
  Raz [M:CDT]NBDIE
  For [DIE] DIE0
    [M:CDT]DIE    ([M:CDT]NBDIE)=[F:DIE]DIE
    [M:CDT]CCECOD1([M:CDT]NBDIE)=3
    [M:CDT]CCECOD2([M:CDT]NBDIE)=3
    [M:CDT]CCECOD3([M:CDT]NBDIE)=3
    [M:CDT]NBDIE+=1
    If [M:CDT]NBDIE>=dim([M:CDT]DIE)  Break : Endif
  Next
Return


# 1 et un seul plan de compte par référentiel,
# mais plusieurs référentiels peuvent utiliser le même plan de compte
# donc il vaut mieux lister les plans de comptes [F:COA] plutôt que [F:LED]


# ----------------------------#
# Liste des plans comptables  #
# ----------------------------#
$CHARG_COA
  If !clalev([F:COA])  Local File =APPLI+".GCOA"  [COA] : Endif
  Raz [M:CDT]NBCOA
  For [COA] COA0
    [M:CDT]COA    ([M:CDT]NBCOA)=[F:COA]COA
    [M:CDT]ACCCOD1([M:CDT]NBCOA)=3
    [M:CDT]ACCCOD2([M:CDT]NBCOA)=3
    [M:CDT]ACCCOD3([M:CDT]NBCOA)=3
    [M:CDT]NBCOA+=1
    If [M:CDT]NBCOA>=dim([M:CDT]COA)  Break : Endif
  Next
Return
