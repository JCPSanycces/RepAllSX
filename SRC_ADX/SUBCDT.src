End

Subprog AS_OBG(VALEUR)
Variable Integer VALEUR
#ADNGO - 2016-12-19 - X3-12158- START
If [M]OPT(nolign-1)<>1 : VALEUR=1 : mkstat=2 : End : Endif
#ADNGO - 2016-12-19 - X3-12158- END
End


