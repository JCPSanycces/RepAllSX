######################################################################################
Subprog C_DIE(VALEUR)
Variable Char    VALEUR()
#ADNGO - 2016-12-19 - X3-12158- START
Local Integer MAXLIG
MAXLIG=27         :#Limite fixée par les spec...
If [M]NBRDIE>=MAXLIG
 GMESSAGE=mess(26,100,1) #: Tableau plein
 mkstat=2 : End
Endif
Call UNICITE(VALEUR,[M]DIE) From OBJDIV
If mkstat : End : Endif
#ADNGO - 2016-12-19 - X3-12158- END
End

