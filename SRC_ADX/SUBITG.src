########################################
# REOMGTCOD : Mode reappro
########################################
Subprog AM_REOMGTCOD(VALEUR)
Variable Integer  VALEUR
If VALEUR < 5
  Effzo [M:ITG7]REOPER
  Grizo [M:ITG7]REOPER
Else
  Actzo [M:ITG7]REOPER
Endif
If find(VALEUR,2,3)
  Actzo [M:ITG7]REOPOL,DAYCOV
Else
  Effzo [M:ITG7]REOPOL,DAYCOV
  Grizo [M:ITG7]REOPOL,DAYCOV
Endif
End

