#<AdxTL>@(#)0.0.0.0 $Revision$ Catégorie article
Call OBJET("ITG", GBIDC1, GBIDC2) From GOBJET
End
#-------------------------------------------------------------------------#
# Gestion des catégories articles version 140    TB  Avril 2002 - SUBITG -#
# la table sert à la fois à la catégorie générale (sans site)             #
# et à la catégorie site pour les informations relatives à l'article-site #
# Gestion des écrans ITG0 à ITG9                                          #
# Actions sur champs : SUBITG                                             #
# Actions de l'objet : SUBITGA                                            #
# Autres             : SUBITGB                                            #
#-------------------------------------------------------------------------#
$ACTION

Case ACTION
 When "OUVRE"         Gosub OUVRE         From SUBITGA
 When "FERME"         Gosub FERME         From SUBITGA
 When "RAZCRE"        Gosub RAZCRE        From SUBITGA
 When "RAZDUP"        Gosub RAZDUP        From SUBITGA
 When "LIENS"         Gosub LIENS         From SUBITGA
 When "APRES_MODIF"   Gosub APRES_MODIF   From SUBITGA
 When "INICRE"        Gosub INICRE        From SUBITGA
 When "CREATION"      Gosub CREATION      From SUBITGA
 When "VERIF_CRE"     Gosub VERIF         From SUBITGA
 When "VERIF_MOD"     Gosub VERIF_MOD     From SUBITGA
 When "APRES_CRE"     Gosub APRES_CRE     From SUBITGA # Issue 84130 - 2013-05-21 by MUARN : landed cost
 When "APRES_MOD"     Gosub APRES_MOD     From SUBITGA # Issue 84130 - 2013-05-21 by MUARN : landed cost
 When "MODIF"         Gosub MODIF         From SUBITGA
 When "VERF_ANU"      Gosub VERF_ANU      From SUBITGA
 When "ANNULE"        Gosub ANNULE        From SUBITGA
 When "AVANT_MODFIC"  Gosub AVANT_MODFIC  From SUBITGA
 When "INIMOD"        Gosub INIMOD        From SUBITGA
 When "SETBOUT"       Gosub SETBOUT       From SUBITGA
 When "CHANGE"      : Call CHANGE_AXX ("ITMCATEG", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase
Return

########################################
# SOUS-PROG D'actions sur zones        #
########################################


############################################################################
# Ecran ITG0
############################################################################
########################################
# TCLCOD : Catégorie
########################################
# en contrôle du code, voir s'il existe une catégorie générale
#     si oui : charger les éléments définissables à la catégorie et les griser
#     si non : griser le site pour obliger à créer l'enreg catégorie (?)
Subprog C_TCLCOD(VALEUR)
Variable Char     VALEUR
End

########################################
# STOFCY : Site de stockage
########################################
Subprog C_STOFCY(VALEUR)
Variable Char     VALEUR
# attention ne suffit pas : interpréter la modif/mise à vide de site... !
If VALEUR <> "" & find(GREP,"C","D")
  Look [ITGG]ITG1=[M:ITG0]TCLCOD;""
  If fstat
    # "la catégorie générale n'a pas été créée !"
    GMESSAGE = mess(350,199,1)
    mkstat = 2
  Endif
Endif
End

Subprog AM_STOFCY(VALEUR)
Variable Char     VALEUR

If VALEUR = "" & GREP = "D"
   # si on est déjà en duplic (C1/S1  > C2 )
   mkstat = 2 : GMESSAGE=mess(348,199,1)
Endif
#-- Non valable en import car la zone est déjà dans l'écran (Mail MB)
#If VALEUR<>"" & [M:ITG0]STOFCY=""
If VALEUR<>""
   Grizo [M:ITG2]1-99
  #--- Bug 74104
  # Site avec gestion de dépôt et gestion stock, on force gestion emplacement
  #If [F:FCY]WRHGES=2 & [M:ITG2]STOMGTCOD>1
  #  [M:ITG9]LOCMGTCOD=2
  #  Diszo [M:ITG9]LOCMGTCOD
  #Elsif [M:ITG2]STOMGTCOD>1
  #  Actzo [M:ITG9]LOCMGTCOD
  #Elsif dim([M:ITG9]LOCMGTCOD)>0
  #  Grizo [M:ITG9]LOCMGTCOD
  #Endif
  If dim([M:ITG2]LOCMGTCOD) > 0                    # hcb X3-71908
     If [M:ITG2]STOMGTCOD>1
        Actzo [M:ITG2]65                            # hcb X3-58069
     Endif
     If [M:ITG2]LOCMGTCOD>1                         # hcb X3-58069
        Actzo [M:ITG2]75                            # hcb X3-71908
     Endif
    #---
  Endif
  #---
  If [M:ITG2]STOMGTCOD < 2
     Grizo [M:ITG2]PCKSTKFLG
    If [M:ITG1]SCSFLG = 2 | [M:ITG1]GENFLG = 2
      Actzo [M:ITG7]REOMINQTY,MFGLOTQTY # pour calc coût art Sous-traitance...
    Endif
  Else
    Actzo [ITG7]1-99 : Affzo [M:ITG7]1-99 # catégorie-site avec gestion stock
  Endif
  Grizo [M:ITG0]TCLAXX : Affzo [M:ITG0]TCLAXX
  Grizo [M:ITG1]1-99   : Actzo [M:ITG1]BUY,PLANNER,ABCCLS : Affzo [M:ITG1]1-99
  Actzo [M:ITG2]CUNCOD,STOCOD
  Actzo [M:ITG2]QUAFLG,QLYCRD,QUAACS,FRTCLS            # hcb V6CQ - 101090, added FRTCLS
  If dim([M:ITG2]NMFC)>0 : Actzo [M:ITG2]NMFC : Endif  # 101090.n
   Affzo [M:ITG2]1-99
  Grizo [M:ITG3]1-99
  Grizo [M:ITG5]5,10   : Affzo [M:ITG5]5,10    # accès aux données de valorisation
  Actzo [M:ITG5]15     : Grizo [M:ITG5]BRDCOD
  Grizo [M:ITG6]1-99   : Affzo [M:ITG6]1-99
  Actzo [M:ITG2]PCK
  Actzo [M:ITG2]PCKCAP
  Actzo [M:ITG2]PCKFLG
  Actzo [M:ITG2]PCKSTKFLG
  If [M:ITG2]STOMGTCOD < 2
     Grizo [M:ITG2]PCKSTKFLG
  Endif


  If [M:ITG1]SALFLG <> 2 & [M:ITG1]DLVFLG <> 2
     Grizo [M:ITG2]PCK
     Grizo [M:ITG2]PCKCAP
     Grizo [M:ITG2]PCKFLG
     Grizo [M:ITG2]PCKSTKFLG
  Endif
  If dim([M:ITG9]ORDWRH)>0
    # Site avec gestion de dépôt, et gestion emplacement
    If [F:FCY]WRHGES=2 & dim([M:ITG2]LOCMGTCOD)>0 & [M:ITG2]LOCMGTCOD=2                    # hcb X3-71908
      Actzo [M:ITG9]10
      Actzo [M:ITG9]20
    Else
      Effzo [M:ITG9]10
      Effzo [M:ITG9]20
      Grizo [M:ITG9]10
      Grizo [M:ITG9]20
    Endif
  Endif
Else
  Grizo [M:ITG1]ABCCLS
  Grizo [M:ITG2]CUNCOD
  Grizo [M:ITG2]STOCOD
  Grizo [M:ITG5]15
  Actzo [M:ITG5]BRDCOD
  #Grizo [M:ITG7]1-99 : TS bug 52190
  If dim([M:ITG2]EXYMGTCOD) > 0
    If dim([M:ITG2]LOTMGTCOD)<0 | [M:ITG2]LOTMGTCOD=1
      Grizo [ITG2]EXYMGTCOD, EXYSTA
    Else
      Actzo [ITG2]EXYMGTCOD, EXYSTA
    Endif
  Endif
#                                                 # hcb 71276 deb
  If dim([M:ITG2]ECCFLG) > 0
    If dim([M:ITG2]LOTMGTCOD)<0 | [M:ITG2]LOTMGTCOD=1
      Grizo [ITG2]ECCFLG,ECCSTO,ECCMIN,ECCMAJ
      Grizo [ITG6]LOAECCFLG
    Else
      Actzo [ITG2]ECCFLG,ECCSTO,ECCMIN,ECCMAJ
      Actzo [ITG6]LOAECCFLG
    Endif
  Endif
#                                                 # hcb 71276 fin
  If dim([M:ITG2]EXYMGTCOD) > 0
    If [M:ITG2]EXYMGTCOD= 1
      Grizo [ITG2]EXYSTA
    Else
      Actzo [ITG2]EXYSTA
    Endif
  Endif
  If dim([M:ITG9]ORDWRH)>0
    Effzo [M:ITG9]10
    Effzo [M:ITG9]20
    Grizo [M:ITG9]10
    Grizo [M:ITG9]20
  Endif
  If dim([M:ITG6]LOAECCFLG)>0        # hcb 71276
     Grizo [M:ITG6]LOAECCFLG
  Endif

  #--- Jira X3-50162
  If dim([M:ITG2]LOCMGTCOD) > 0                                             # hcb X3-71908
    If [M:ITG2]LOCMGTCOD>1                                                  # hcb X3-71908
      Diszo [M:ITG2]DEFLOCTYP, DEFLOC                                       # hcb X3-71908
      Effzo [M:ITG2]DEFLOCTYP, DEFLOC                                       # hcb X3-71908
    Endif
  Endif

  #---

Endif

#101090 - need Societe and Leg set for FRTCLS
If VALEUR<>""
  Call GETSOC(VALEUR) From DEVSUB
Else
  GSOCIETE=""
  GCURLEG=""
  GCURFCY=""
Endif

#101090 - Hide NMFC based on USABOL parameter
If func AFNC.ACTIV("KUS")
  If VALEUR="" | func AFNC.PARAM("USABOL",VALEUR)="2"
    Chgfmt [M:ITG2]NMFC With "K:"  + num$(type([M:ITG2]NMFC)-10) + "X"    # Show enterable
  Else
    Chgfmt [M:ITG2]NMFC With "-K:" + num$(type([M:ITG2]NMFC)-10) + "X"    # Hide enterable
  Endif
Endif


End

############################################################################
############################################################################
# Ecran ITG1
############################################################################
############################################################################

########################################
# ITMREFCOU : Compteur désignation article
########################################
Subprog C_ITMREFCOU(VALEUR)
Variable Char     VALEUR
If !clalev([F:ANM]) Local File ACODNUM [ANM] Endif  # avant modif du dico Objet
If VALEUR <> ""
 For I = 0 To dim([F:ANM]POSTYP)-1
   # FQ 58536 Controler que la formule puisse être évaluée
   If instr(1,[F:ANM]POSCTE(I),"[")
       Onerrgo ERR_FORMU
       Local Char FORMU(GLONVCR)
       FORMU   = evalue([F:ANM]POSCTE(I))
       Onerrgo
       If mkstat = 2
         Break
       Endif
  # Controler que la constante est de type format "c"
  Elsif [F:ANM]POSCTE(I) <> ""
&  & format$("K:"+num$([F:ANM]POSLNG(I))+"c",[F:ANM]POSCTE(I)) = string$([F:ANM]POSLNG(I)," ")
     mkstat = 2
     Break
  Endif
 Next I
 If mkstat = 2
    GERR=1
    GMESSAGE = mess(6,196,1)-"("-[F:ANM]POSCTE(I)-")"
    End                          # hcb 58728
 Endif

 # Controle que le compteur n'est pas déjà utilisé dans une catégorie
 Local File ITMCATEG [ITG2] # pour ne pas écraser le buffer
 For [F:ITG2] Where TCLCOD <> [M:ITG0]TCLCOD & ITMREFCOU = VALEUR
   GMESSAGE = mess(7,196,1)-[F:ITG2]TCLCOD
   GERR = 2 # avertissement seulement
   Break
 Next
Endif
End
$ERR_FORMU
   mkstat = 2
Resume

########################################
# SALFLG : Article vendu (O/N)
########################################
Subprog AS_SALFLG(VALEUR)
Variable Integer VALEUR
If [M:ITG2]STOMGTCOD=3 : mkstat=2 : End : Endif
End

Subprog AM_SALFLG(VALEUR)
Variable Integer VALEUR
Local    Integer WSALFLG
Local Integer OK


If !clalev([F:ITS]) Local File ITMSALES [ITS] Endif
# (dés)activer le bloc vente
If VALEUR < 2 | GMODU(5) < 2
  Effzo [M:ITG6]ITMTYP,SALRMNPRC,MINQTY,MAXQTY,LNDFLG,CTMFLG,CTMQTY
  Grizo [M:ITG6]10
Else
  Actzo [M:ITG6]10
Endif
If GREP = "C"  # or "D" ?
    WSALFLG=VALEUR
    Gosub CHARG_SRU From SUBITGB # charge l'écran ITG4
Else
  # avertir de vérifier les règles
  Call AVERTIR(mess(365,199,1),OK) From GESECRAN
  If OK = 1 : mkstat = 2 : Endif
  # Interdire le passage à non vendu s'il existe des articles ventes
  If [F:ITG]SALFLG = 2 & VALEUR = 1 & GREP <> "D"
    Link [ITS] With [ITM]ITM0 = [F:ITS]ITMREF As [LNK]
&            Where [F:ITM]TCLCOD = [M:ITG0]TCLCOD
    For [LNK]
      GERR = 1
      GMESSAGE = mess(269,199,1)
      mkstat = 2
      Break
    Next
  Endif
Endif

Local Char TRT_ZON(10)
TRT_ZON = "SALFLG"
Gosub TRT_TYP


End

############################################################################
############################################################################
# Ecran ITG2
############################################################################
############################################################################

########################################
# STOMGTCOD
########################################
Subprog AS_STOMGTCOD(VALEUR)
Variable Integer VALEUR
# Désactivation provisoire gestion en UI  (v 140 ??)
##GMENLOC(4) = 1
# types Générique et Sous-traitance : Non géré en stock
If [M:ITG1]SCSFLG = 2 | [M:ITG1]GENFLG = 2
   VALEUR = 1
   mkstat = 2
Endif
End

Subprog AM_STOMGTCOD(VALEUR)
Variable Integer VALEUR
#-- L'article ne peut être géré en titre et vendu
If VALEUR=3 & [M:ITG1]SALFLG=2
  GMESSAGE=mess(211,199,1)
  GERR =1
  mkstat=2 : End
Endif
If VALEUR=3 & GTITACTIV<>2
  GMESSAGE=mess(83,123,1)
  GERR =1
  mkstat=2 : End
Endif
#-- L'article ne peut être géré en titre et en numéro de série
If VALEUR=3 & dim([M:ITG2]SERMGTCOD)>0 & [M:ITG2]SERMGTCOD>1
  GMESSAGE=mess(494,199,1)
  GERR =1
  mkstat=2 : End
Endif
If VALEUR=1
  If dim([M:ITG2]LOCMGTCOD)>0              # hcb X3-58069
    [M:ITG2]LOCMGTCOD=1                    # hcb X3-58069
    #--- Jira X3-50162
    #Raz [M:ITG9]NBINT,LOCDES
    Diszo [M:ITG2]LOCMGTCOD                # hcb X3-58069
    Diszo [M:ITG2]75                       # hcb X3-58069
    Effzo [M:ITG2]NBINT, LOCDES            # hcb X3-58069
    Effzo [M:ITG2]DEFLOCTYP,DEFLOC         # hcb X3-58069
    Affzo [M:ITG2]LOCMGTCOD                # hcb X3-58069
    #---
  Endif
  #MAE, bg75448
  #Effzo [M:ITG5]VLTCOD
  #If dim([M:ITG5]ZVLTCOD)>0 : Effzo [M:ITG5]ZVLTCOD : Endif
  [M:ITG2]STOCOD=3 : Grizo [M:ITG2]STOCOD                      : # dde v142
Elsif VALEUR>=2
    Setmok [ITG5] With 0
    Setmok [ITG8] With 0
    Setmok [ITG4] With 0
    #--- Bug 74104
    # Site avec gestion de dépôt, on force gestion emplacement
    #If [F:FCY]WRHGES=2
    #   [M:ITG9]LOCMGTCOD=2
    #   Diszo [M:ITG9]LOCMGTCOD
    #Elsif dim([M:ITG9]LOCMGTCOD)>0
    #   Actzo [M:ITG9]LOCMGTCOD
    #Endif
    If dim([M:ITG2]LOCMGTCOD)>0                        # hcb X3-58069
       Actzo [M:ITG2]LOCMGTCOD                         # hcb X3-58069
       #--- Jira X3-50162
       If [M:ITG2]LOCMGTCOD>1                          # hcb X3-58069
         If [M:ITG0]STOFCY<>""
           Actzo [M:ITG2]75                            # hcb X3-58069
         Else
           Actzo [M:ITG2]NBINT,LOCDES                  # hcb X3-58069
         Endif
       Endif
       #---
    Endif
    # Issue 112878 - 2015-12-10 by MAE : Mise à jour de RCPFLG si STOMGTCOD > 1
    [M:ITG6]RCPFLG = 2
    Affzo [M:ITG6]RCPFLG
    #---
    If GREP = "C"
       WSALFLG=[M:ITG1]SALFLG
       Gosub CHARG_SRU From SUBITGB # charge l'écran ITG4
    Endif
Endif
# Art non géré en stock --> remise aux valeurs par défaut
If VALEUR=1
  If dim([M:ITG2]LOTMGTCOD) > 0
     Effzo [M:ITG2]LOTMGTCOD,LOTCOU
     Grizo [M:ITG2]LOTMGTCOD,LOTCOU
  Endif
  If dim([M:ITG2]SERMGTCOD) > 0
     Effzo [M:ITG2]SERMGTCOD,SERCOU
     Grizo [M:ITG2]SERMGTCOD,SERCOU
  Endif
#                                   # hcb 71276 deb
  If dim([M:ITG2]ECCFLG) > 0
     Effzo [M:ITG2]ECCFLG,ECCSTO,ECCMIN,ECCMAJ
     Grizo [M:ITG2]ECCFLG,ECCSTO,ECCMIN,ECCMAJ
     Effzo [ITG6]LOAECCFLG
     Grizo [ITG6]LOAECCFLG
  Endif
#                                   # hcb 71276 fin

  Effzo [M:ITG2]STDFLG,CUNCOD,NEGSTO
  Local Char WQUAACS        # hcb V6CQ
  WQUAACS = [M:ITG2]QUAACS  # hcb V6CQ
  Effzo [M:ITG2]10,30-40
  [M:ITG2]QUAACS = WQUAACS  # hcb V6CQ
  Grizo [M:ITG2]STDFLG,CUNCOD,NEGSTO
  Grizo [M:ITG2]10,30-40
  Actzo [M:ITG2]QUAACS   # hcb V6CQ
  [M:ITG2]STOCOD=3
  [M:ITG2]PCKSTKFLG=1
  Affzo [M:ITG2]PCKSTKFLG
  Grizo [M:ITG2]PCKSTKFLG
  Effzo [ITG8]
  Grizo [ITG8]      # règles de gestion
  Effzo [ITG4]
  Grizo [ITG4]      # règles de gestion
  #MAE, bg75448
  #Grizo [ITG5]VLTCOD
  If dim([M:ITG9]ORDWRH)>0
    Effzo [M:ITG9]10
    Effzo [M:ITG9]20
    Grizo [M:ITG9]10
    Grizo [M:ITG9]20
  Endif
  #MAE, bg 72133
  If dim([M:ITG2]TRKCOD)>0
    #--- Bug 55665
    #If dim([M:ITG2]SERMGTCOD) > 0
    #  If [M:ITG2]SERMGTCOD <> 3
    #    Grizo [ITG2]TRKCOD
    #  Else
    #    Actzo [ITG2]TRKCOD
    #  Endif
    #Endif
    [M:ITG2]TRKCOD=1
    Grizo [M:ITG2]TRKCOD
    If dim([M:ITG2]TRKLEV)>0
       [M:ITG2]TRKLEV=1
       Grizo [M:ITG2]TRKLEV
    Endif
    #---
  Endif
Elsif [M:ITG2]STOMGTCOD=1
  # Activer que si la valeur précédente était 1
  # Attention en AM en import on a déjà la valeur dans le masque
  # Ce n'est pas valable en import
  [M:ITG2]STOCOD=1 : Affzo [M:ITG2]STOCOD
  [M:ITG2]CUNCOD=1 : Affzo [M:ITG2]CUNCOD                : # dde v142
  [M:ITG2]STDFLG=3 : Affzo [M:ITG2]STDFLG                : # dde v142
  Actzo [ITG2]1-99

  If dim([M:ITG2]LOTMGTCOD)>0 & [M:ITG2]LOTMGTCOD<2
    Raz [M:ITG2]LOTCOU                                     # hcb 45249
    Grizo [ITG2]LOTCOU                                     # hcb 45249
    If dim([M:ITG2]EXYMGTCOD) > 0                          # hcb 45249
       Raz [M:ITG2]EXYMGTCOD, EXYSTA                       # hcb 45249
       Grizo [ITG2]EXYMGTCOD, EXYSTA                       # hcb 45249
    Endif                                                  # hcb 45249
  Endif
 #                                                         # hcb 71276 deb
  If dim([M:ITG2]ECCFLG)>0 & [M:ITG2]ECCFLG<2
    Raz [M:ITG2]ECCMIN
    Raz [M:ITG2]ECCMAJ
    Raz [M:ITG2]ECCSTO
    Raz [M:ITG6]LOAECCFLG
    Grizo [ITG2]ECCMIN, ECCMAJ, ECCSTO
    Grizo [M:ITG6]LOAECCFLG
  Endif
 #                                                         # hcb 71276 fin

  If dim([M:ITG2]SERMGTCOD) > 0 & [M:ITG2]SERMGTCOD<2
    Raz [M:ITG2]SERCOU
    Grizo [ITG2]SERCOU
  Endif
  If [M:ITG1]SALFLG <> 2 & [M:ITG1]DLVFLG <> 2
     Grizo [M:ITG2]PCK
     Grizo [M:ITG2]PCKCAP
     Grizo [M:ITG2]PCKFLG
     Grizo [M:ITG2]PCKSTKFLG
  Endif

  Actzo [ITG8]1-99
  [M:ITG4]GLOAAAFLG=2 : Affzo [ITG4]GLOAAAFLG
  Actzo [ITG4]1-99
  #MAE, bg75448
  #Actzo [ITG5]VLTCOD

  If dim([M:ITG9]ORDWRH)>0
    # Site avec gestion de dépôt, et gestion emplacement
    If [M:ITG0]STOFCY<>"" & [F:FCY]WRHGES=2 & dim([M:ITG2]LOCMGTCOD)>0 & [M:ITG2]LOCMGTCOD=2         # hcb X3-58069
      Actzo [M:ITG9]10
      Actzo [M:ITG9]20
    Endif
  Endif

Elsif GIMPORT & VALEUR<>1
  # Pour l'import faire systématiquement
  [M:ITG2]STOCOD=3
  Actzo [ITG2]1-99
  If dim([M:ITG2]LOTMGTCOD)>0 & [M:ITG2]LOTMGTCOD < 2
    Raz [M:ITG2]LOTCOU
    Grizo [ITG2]LOTCOU
  Endif
#                                                       # hcb 71276 deb
  If dim([M:ITG2]ECCFLG)>0 & [M:ITG2]ECCFLG<2
    Raz [M:ITG2]ECCMIN
    Raz [M:ITG2]ECCMAJ
    Raz [M:ITG2]ECCSTO
    Raz [M:ITG6]LOAECCFLG
    Grizo [ITG2]ECCMIN, ECCMAJ, ECCSTO
    Grizo [M:ITG6]LOAECCFLG
  Endif
#                                                       # hcb 71276 fin

  If dim([M:ITG2]SERMGTCOD) > 0 & [M:ITG2]SERMGTCOD < 2
    Raz [M:ITG2]SERCOU
    Grizo [ITG2]SERCOU
  Endif
  Actzo [ITG8]1-99
  [M:ITG4]GLOAAAFLG=2 : Affzo [ITG4]GLOAAAFLG
  Actzo [ITG4]1-99
  Actzo [ITG5]VLTCOD
Endif
End

########################################
# STDFLG
########################################
Subprog D_STDFLG(VALEUR)
Variable Integer  VALEUR
If [M:ITG2]STOMGTCOD = 1
  VALEUR = 1
Else
  VALEUR = 3
Endif
End

Subprog AS_STDFLG(VALEUR)
Variable Integer  VALEUR
GMENLOC(2) = 1
If [M:ITG2]STOMGTCOD > 1
  GMENLOC(1) = 1
Else
  VALEUR = 1
  mkstat = 2
Endif
End

Subprog AM_STDFLG(VALEUR)
Variable Integer  VALEUR
If VALEUR <> 3
  Effzo   [M:ITG7]DAYCOV
  Grizo [M:ITG7]DAYCOV
Endif
End

########################################
# CUNCOD
########################################
Subprog D_CUNCOD(VALEUR)
Variable Integer VALEUR
If [M:ITG2]STOMGTCOD = 1
  VALEUR = 3
Else
  VALEUR = 1
Endif
End

Subprog AS_CUNCOD(VALEUR)
Variable Integer VALEUR
If [M:ITG2]STOMGTCOD > 1
  GMENLOC(3) = 1
Else
  VALEUR = 3
  mkstat = 2
Endif
End

#--- Bug 55665
########################################
# TRKCOD
########################################
Subprog AM_TRKCOD(VALEUR)
Variable Integer VALEUR
If dim([M:ITG2]TRKLEV)>0
   If VALEUR=1
      [M:ITG2]TRKLEV=1
      Diszo [M:ITG2]TRKLEV
   Else
      Actzo [M:ITG2]TRKLEV
   Endif
   Affzo [M:ITG2]TRKLEV
Endif
End

########################################
## TRKLEV
########################################
Subprog C_TRKLEV(VALEUR)
Variable Integer VALEUR
If [M:ITG2]TRKCOD<2
   VALEUR=1
Endif
# Si niveau = série et pas de gestion de série E/S
#--- Issue 110327
#If VALEUR=4 & [M:ITG2]SERMGTCOD<>3
If VALEUR=4 & [M:ITG2]SERMGTCOD<3
#---
   GMESSAGE=mess(1033,196,1) : mkstat=2 : End
Endif
# Si niveau = s-lot et pas de gestion de s-lot
If VALEUR=3 & [M:ITG2]LOTMGTCOD<>4
   GMESSAGE=mess(1033,196,1) : mkstat=2 : End
Endif
# Si niveau = lot et pas de gestion de lot
If VALEUR=2 & [M:ITG2]LOTMGTCOD<2
   GMESSAGE=mess(1033,196,1) : mkstat=2 : End
Endif
End
#---

########################################
# LOTMGTCOD
########################################
Subprog AS_LOTMGTCOD(VALEUR)
Variable Integer VALEUR
If [M:ITG2]STOMGTCOD = 1
   mkstat = 2 : End
Endif
# Si pas de gestion de sous-lot
If GSLOACTIV<>2 GMENLOC(4)=1 Endif
End

Subprog AM_LOTMGTCOD(VALEUR)
Variable Integer VALEUR
If VALEUR < 2
   Raz [M:ITG2]LOTCOU
   Affzo [ITG2]LOTCOU     #v142
   Grizo [ITG2]LOTCOU
   Grizo [ITG8]DACLOT,LOTSUPINH # sans les vider
   #MAE, bg 72133
   If dim([M:ITG2]TRKCOD)>0
      If dim([M:ITG2]SERMGTCOD) > 0
          #--- Issue 110327
          #If [M:ITG2]SERMGTCOD <> 3
          If [M:ITG2]SERMGTCOD < 3
             Diszo [M:ITG2]TRKCOD
             [M:ITG2]TRKCOD = 1
             Affzo [M:ITG2]TRKCOD
             #--- Bug 55665
             If dim([M:ITG2]TRKLEV)>0
                [M:ITG2]TRKLEV=1
                Diszo [M:ITG2]TRKLEV
             Endif
             #---
          Else
             Actzo [ITG2]TRKCOD
             #--- Bug 55665
             If dim([M:ITG2]TRKLEV)>0
                If [M:ITG2]TRKCOD<2
                   [M:ITG2]TRKLEV=1
                   Diszo [M:ITG2]TRKLEV
                Else
                   Actzo [M:ITG2]TRKLEV
                   # Si niveau lot ou s-lot --> par défaut
                   If find([M:ITG2]TRKLEV,2,3)
                      [M:ITG2]TRKLEV=1
                   Endif
                Endif
             Endif
             #---
          Endif
          #--- Bug 55665
          If dim([M:ITG2]TRKLEV)>0 : Affzo [M:ITG2]TRKLEV : Endif
          #---
       Endif
   Endif                                    # hcb 69389 fin
Else
   Actzo [ITG2]LOTCOU
   # initialiser par le cpt général affectés aux lots : GSTKCPT(7) en 140
   [M:ITG2]LOTCOU = GSTKCPT(7) : Affzo [ITG2]LOTCOU
   Actzo [ITG8]DACLOT,LOTSUPINH
   If dim([M:ITG2]TRKCOD)>0
      Actzo [ITG2]TRKCOD
      #--- Bug 55665
      If dim([M:ITG2]TRKLEV)>0
         If [M:ITG2]TRKCOD<2
            [M:ITG2]TRKLEV=1
            Diszo [M:ITG2]TRKLEV
         Else
            Actzo [M:ITG2]TRKLEV
            # Si gestion lot facultatif ou obligatoire et niveau s-lot
            # --> niveau lot
            If find(VALEUR,2,3) & [M:ITG2]TRKLEV=3
               [M:ITG2]TRKLEV=2
            Endif
         Endif
         Affzo [M:ITG2]TRKLEV
      Endif
      #---
   Endif                                    # hcb 69389 fin
Endif

If dim([M:ITG2]EXYMGTCOD) > 0
   If VALEUR = 1
      Raz [M:ITG2]EXYMGTCOD, [M:ITG2]EXYSTA
      Affzo  [M:ITG2]EXYMGTCOD
      Affzo  [M:ITG2]EXYSTA
      Grizo  [M:ITG2]EXYMGTCOD, EXYSTA
   Else
      Actzo [ITG2]EXYMGTCOD
   Endif
Endif
End

Subprog C_LOTCOU(VALEUR)
Variable Char VALEUR
If VALEUR <> ""
  Read [ANM]ANM0=VALEUR : If fstat : Raz [F:ANM] : Endif
  If sum([F:ANM]POSLNG(0..dim([F:ANM]POSLNG)-1)) > GLONLOT
    GMESSAGE=VALEUR-mess(223,199,1)
    mkstat = 2
  Endif
Endif
End

########################################
# SERMGTCOD
########################################
Subprog AS_SERMGTCOD(VALEUR)
Variable Integer  VALEUR
#MAE: désactivation de la gestion en entrée sortie globale
#GMENLOC(4) = 1
If [M:ITG2]STOMGTCOD=3 : mkstat=2 : Endif
End

Subprog AM_SERMGTCOD(VALEUR)
Variable Integer VALEUR
If VALEUR < 2
   Raz [M:ITG2]SERCOU
   Grizo [M:ITG2]SERCOU
Else
  Actzo [M:ITG2]SERCOU
  # initialiser par la globale de GLOBSTO : GSTKCPT(12)
  [M:ITG2]SERCOU = GSTKCPT(12)
Endif
Affzo [ITG2]SERCOU
#MAE, bg 72133
# Attention valeur incohérente  : gestion série "entrée - sortie" et tracabilité "agrégée" !
#--- Issue 110327
#If VALEUR = 3 & (dim([M:ITG2]TRKCOD)> 0 & [M:ITG2]TRKCOD = 3)       # hcb 69389
If VALEUR >= 3 & (dim([M:ITG2]TRKCOD)> 0 & [M:ITG2]TRKCOD = 3)       # hcb 69389
#---
   Call MESSAGE(mess(553,199,1)) From GESECRAN
Endif
#MAE, bg 72133
If dim([M:ITG2]TRKCOD)>0       # hcb 69389 deb
   # Issue 110327 - 2017-02-13 by MAE
   #If VALEUR = 3
   If VALEUR >= 3
      Actzo [M:ITG2]TRKCOD
      Affzo [M:ITG2]TRKCOD
      #--- Bug 55665
      If dim([M:ITG2]TRKLEV)>0
         If [M:ITG2]TRKCOD<2
            [M:ITG2]TRKLEV=1
            Diszo [M:ITG2]TRKLEV
         Else
            Actzo [M:ITG2]TRKLEV
         Endif
      Endif
      #---
   Else
      If dim([ITG2]LOTMGTCOD) > 0
         If [ITG2]LOTMGTCOD  < 2
            Diszo [M:ITG2]TRKCOD
            [M:ITG2]TRKCOD = 1
            Affzo [M:ITG2]TRKCOD
            #--- Bug 55665
            If dim([M:ITG2]TRKLEV)>0
               [M:ITG2]TRKLEV=1
               Diszo [M:ITG2]TRKLEV
            Endif
            #---
         Else
            Actzo [M:ITG2]TRKCOD
            #--- Bug 55665
            If dim([M:ITG2]TRKLEV)>0
               If [M:ITG2]TRKCOD<2
                  [M:ITG2]TRKLEV=1
                  Diszo [M:ITG2]TRKLEV
               Else
                  Actzo [M:ITG2]TRKLEV
                  # Si niveau = série --> par défaut
                  If [M:ITG2]TRKLEV=4
                     [M:ITG2]TRKLEV=1
                  Endif
               Endif
            Endif
            #---
         Endif
         #--- Bug 55665
         If dim([M:ITG2]TRKLEV)>0 : Affzo [M:ITG2]TRKLEV : Endif
         #---
      Endif
   Endif
Endif                           # hcb 69389 fin
End
# Issue 110327 - 2017-06-07 by MAE : série globale, pas de stock négatif
Subprog C_SERMGTCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=4 & [M:ITG2]NEGSTO=2
  GMESSAGE=mess(1190,196,1)
  mkstat=2
Endif
End

########################################
# NEGSTO
########################################
Subprog C_NEGSTO(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & [M:ITG2]SERMGTCOD=4
  GMESSAGE=mess(1190,196,1)
  mkstat=2
Endif
End
# End issue 110327

########################################
# SERCOU
########################################
Subprog C_SERCOU(VALEUR)
Variable Char VALEUR
If VALEUR <> ""
  Read [ANM]ANM0=VALEUR : If fstat : Raz [F:ANM] : Endif
  If sum([F:ANM]POSLNG(0..dim([F:ANM]POSLNG)-1)) > GLONSER
    GMESSAGE=VALEUR-mess(223,199,1)
    mkstat = 2
  Endif
Endif
End
