########################################
# RCPFLG
########################################
Subprog AS_RCPFLG(VALEUR)
Variable Integer VALEUR
# code réception forcément à OUI pour art géré en stock ou Sous-traitance
# Issue 112878 - 2015-12-10 by MAE : remplacé par un message et em am du champ SCSFLG et SCPFLG
#If [M:ITG2]STOMGTCOD>1 | [M:ITG1]SCSFLG = 2
#    VALEUR = 2
#    mkstat = 2
#Endif
End

########################################
# PRQFLG
########################################
Subprog C_PRQFLG(VALEUR)
Variable Integer VALEUR
If [M:ITG6]CTMFLG=2 & VALEUR=2
   GMESSAGE=mess(163,196,1) : VALEUR=1 : mkstat=2
Endif  # mais CTMFLG est saisi dans le bloc suivant !!

If clalev ([F:PTO])  = 0 : Local File PARMTO     [PTO]  : Endif
Local File ITMCATEG [ITG2] # pour ne pas écraser le buffer

If [M:ITG0]STOFCY = "" & VALEUR = 2
    For [F:ITG2] Where TCLCOD = [M:ITG0]TCLCOD & STOFCY <> ""
        If [F:ITG2]PTOCOD <> ""
            If [F:PTO]PTOCOD <> [F:ITG2]PTOCOD
                Read [PTO]PTO0=[F:ITG2]PTOCOD
                If fstat : Raz [PTO] : Endif
            Endif
            # FGR 09/02/2010 : X3SUIVI60986
            #If [F:PTO]PTODIR = 2 : GMESSAGE=mess(946,196,1) : VALEUR=1 : mkstat=2 : End : Endif
            If [F:PTO]PTODIR = 2 : GMESSAGE=mess(946,196,1) : VALEUR=1 : mkstat=2 : Break : Endif
        Endif
    Next
Endif
# FGR 09/02/2010 : X3SUIVI60986
If mkstat Then
  End
Endif
End


