Subprog AS_DACPCUCOE(VALEUR)
Variable Integer VALEUR
Read [TUN]TUN0=[M:ITG3]PCU(nolign-1)
If [F:TUN]UOMTYP=6
  VALEUR = 1
  mkstat = 2
Endif
End

