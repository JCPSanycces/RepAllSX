Subprog AM_MFGFLG(VALEUR)
Variable Integer VALEUR
Local Char TRT_ZON(10)
TRT_ZON = "MFGFLG"
Gosub TRT_TYP
# Issue 104427 - 2015-07-28 by BRBAN : If =2 INVPRODTYP must have a different default value
If func AFNC.ACTIV("KPO")>0 & GREP='C'
   If VALEUR = 2
    [M:ITG2]INVPRODTYP=3
    Affzo [M:ITG2]INVPRODTYP
   Endif
Endif
# -
End

