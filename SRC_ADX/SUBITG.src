######################################################################################
## Etiquette ajoutée par le superviseur (écran ITG7) 16/11/2007 16:22:52 (LLC)
######################################################################################
Subprog C_PTOCOD(VALEUR)
Variable Char    VALEUR()
Local    Char    WPTOCOD(GLONPTO)

If clalev ([F:PTO])  = 0 : Local File PARMTO     [PTO]  : Endif

If dim(GDEFPTO)>0   #MAE, bg 72517
  #MAE bug 94504
  #If VALEUR = "" : WPTOCOD = GDEFPTO : Else : WPTOCOD = VALEUR : Endif
  If VALEUR = ""
     Call PARAM([M:ITG0]STOFCY,"DEFPTO",WPTOCOD) From ADOVAL : #  WPTOCOD = GDEFPTO :  MAE 19/11/13 bug 94504
  Else
     WPTOCOD = VALEUR
  Endif
Endif


If [F:PTO]PTOCOD <> WPTOCOD
    Read [PTO]PTO0=WPTOCOD
    If fstat : Raz [PTO] : Endif
Endif
If [F:PTO]PTOCOD = "" : End : Endif

# contrôles
# - si règle affectation 101 (contremarque), DA non obligatoire
# - si contremarque activée sur article, règle d'affectation de type 101 obligatoire
Case [M:ITG6]CTMFLG
    When 1:    If [M:ITG6]PRQFLG = 2 & [F:PTO]PTODIR = 2 : GMESSAGE = mess(164,196,1) : mkstat=2 : End : Endif
    When 2:    If [F:PTO]PTODIR  = 1                     : GMESSAGE = mess(530,199,1) : mkstat=2 : End : Endif
Endcase

End


