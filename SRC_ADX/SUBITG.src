########################################
# PCU :
########################################
Subprog C_PCU(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:ITG3]PCU(0..[M:ITG3]BASTAB-1)) From OBJDIV
If [M:ITG3]PCU(nolign-1) <> "" & VALEUR = ""
  mkstat = 2 : GMESSAGE = mess(217,199,1)
Endif
# PCU ne doit pas être l'unité de stock
If VALEUR = [M:ITG3]STU
  mkstat=2
Endif
End

Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()
Call MODUNIT(VALEUR,[M:ITG3]STU,[M:ITG3]PCUSTUCOE(nolign-1)) From SUBITM
Affzo [M:ITG3]PCUSTUCOE(nolign-1)
End

########################################
# PCUSTUCOE
########################################
Subprog AS_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR
Call COEFCNV([M:ITG3]PCU,[M:ITG3]STU,VALEUR) From SUBITM
End

Subprog D_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR
# si l'UC correspond à l'UA ou à l'UV, reprendre le coeff
If [M:ITG3]PCU(nolign-1) = [M:ITG3]PUU
  VALEUR = [M:ITG3]PUUSTUCOE
Endif
If [M:ITG3]PCU(nolign-1) = [M:ITG3]SAU
  VALEUR = [M:ITG3]SAUSTUCOE
Endif
End

