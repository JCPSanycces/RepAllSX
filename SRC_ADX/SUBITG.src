########################################
# AUZSTAS
########################################
Subprog AS_AUZSTAS(VALEUR)
Variable Integer VALEUR
End

########################################
Subprog AM_AUZSTAS(VALEUR)
Variable Integer VALEUR

# A la création, précharger les modèles de sous-statuts correspondant
If [M:ITG4]AUZSSTS(nolign-1) = ""
 If find(VALEUR,1,3,5,7)
   [M:ITG4]AUZSSTS(nolign-1) += "A*"
 Endif
 If find(VALEUR,2,3,6,7)
   If [M:ITG4]AUZSSTS(nolign-1) <> ""
     [M:ITG4]AUZSSTS(nolign-1) += ","
   Endif
   [M:ITG4]AUZSSTS(nolign-1) += "Q*"
 Endif
 If find(VALEUR,4,5,6,7)
   If [M:ITG4]AUZSSTS(nolign-1) <> ""
     [M:ITG4]AUZSSTS(nolign-1) += ","
   Endif
   [M:ITG4]AUZSSTS(nolign-1) += "R*"
 Endif
Endif
End

########################################
# AUZSSTS
########################################
Subprog C_AUZSSTS(VALEUR)
Variable Char    VALEUR()

# contrôle en cas de saisie directe :
VALEUR = toupper(VALEUR)
Call CTR_LIST_SST(VALEUR,[M:ITG4]AUZSTAS(nolign-1)) From TRTCATEG
# construction de la formule :
Call DECODE_STAT(VALEUR,[M:ITG4]FORSTAS(nolign-1)) From TRTCATEG
End

