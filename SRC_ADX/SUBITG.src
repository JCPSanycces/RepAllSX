# STOCOD
########################################
Subprog AS_STOCOD(VALEUR)
Variable Integer VALEUR
If [M:ITG2]STOMGTCOD=2
   GMENLOC(3)=1
Endif
End

########################################
# EXYMGTCOD
########################################
Subprog AM_EXYMGTCOD(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
 [M:ITG2]EXYSTA = ""
 Grizo [ITG2]EXYSTA
Else
  Actzo [ITG2]EXYSTA
Endif
End

########################################
# EXYSTA
########################################
Subprog AS_EXYSTA(VALEUR)
Variable Char    VALEUR()
If [M:ITG2]EXYMGTCOD = 1 | [M:ITG2]STOMGTCOD = 1 mkstat = 2 Endif
End

Subprog C_EXYSTA(VALEUR)
Variable Char    VALEUR()
If [M:ITG2]EXYMGTCOD <> 1 & VALEUR = ""
   mkstat = 2
   GMESSAGE = mess(10,123,1) #"valeur obligatoire"
Endif
If [M:ITG2]EXYMGTCOD <> 1 & instr(1,"AQR",VALEUR) = 0
 GMESSAGE = mess(21,199,1)
 mkstat = 2
Endif
End

########################################
# LOCMGTCOD
########################################
Subprog AM_LOCMGTCOD(VALEUR)
Variable Integer VALEUR
Local Integer WSALFLG
If VALEUR <> 2
   #--- Jira X3-50162
   Raz [M:ITG2]LOCDES,NBINT                              # hcb X3-58069
   Raz [M:ITG2]DEFLOCTYP,DEFLOC                          # hcb X3-58069
   Diszo [M:ITG2]75                                      # hcb X3-58069
   #Grizo [M:ITG9]30
   #---
   Affzo [M:ITG2]75                                      # hcb X3-58069
   Raz   [M:ITG4]LOCNUM, [M:ITG4]LOCNUM2, [M:ITG4]LOCNUM3,[M:ITG8]LOCNUME
   Grizo [M:ITG4]LOCNUM, LOCNUM2, LOCNUM3
   Affzo [M:ITG4]LOCNUM, LOCNUM2, LOCNUM3
   Grizo [M:ITG8]LOCNUME
   Affzo [M:ITG8]LOCNUME
   If dim([M:ITG9]ORDWRH)>0
      Effzo [M:ITG9]10
      Effzo [M:ITG9]20
      Grizo [M:ITG9]10
      Grizo [M:ITG9]20
   Endif
   # Issue X3FEAT-345 - 2017-11-20 by MAE : Si pas d'emplacement, pas de contenant
   If dim([M:ITG2]LPNMGTCOD)>0
    [M:ITG2]LPNMGTCOD = 1
    Diszo [M:ITG2]LPNMGTCOD
    Affzo [M:ITG2]LPNMGTCOD
   Endif
Else
   #--- Jira X3-50162
   #Actzo [M:ITG9]30
   If [M:ITG0]STOFCY=""
     Actzo [M:ITG2]NBINT, LOCDES                    # hcb X3-71908
   Else
     Actzo [M:ITG2]75                               # hcb X3-71908
   Endif
   #---
   If GREP = "C"
      WSALFLG=[M:ITG1]SALFLG
      Gosub CHARG_SRU From SUBITGB
   Else
      Actzo [M:ITG4]LOCNUM, LOCNUM2, LOCNUM3
      Affzo [M:ITG4]LOCNUM, LOCNUM2, LOCNUM3
      Actzo [M:ITG8]LOCNUME
      Affzo [M:ITG8]LOCNUME
   Endif
   # Site avec gestion de dépôt
   If dim([M:ITG9]ORDWRH)>0 & [M:ITG0]STOFCY<>"" & [F:FCY]WRHGES=2
      #MAE, bug 110809
      #Actzo [M:ITG9]1-99
      Actzo [M:ITG9]10
      Actzo [M:ITG9]20
   Endif
    # Issue X3FEAT-345 - 2017-11-20 by MAE : Si pas d'emplacement, pas de contenant
   If dim([M:ITG2]LPNMGTCOD)>0
    Actzo [M:ITG2]LPNMGTCOD
   Endif
Endif
End

########################################
# NBINT
########################################
Subprog AS_NBINT
If dim([M:ITG2]LOCMGTCOD) > 0                                 # hcb X3-58069
    If [M:ITG2]LOCMGTCOD < 2                                  # hcb X3-58069
       mkstat=2
    Endif
Endif
End

Subprog C_NBINT
Local Integer I
# contrôler/interdire suppression ligne
If status=65
# hcb X3-58069
  If dim([M:ITG2]LOCDES) > 0
     If find([M:ITG2]LOCDES(nolign-1)+1,[M:ITG4]LOCNUM (0..[M:ITG4]NBLOC-1)) |
&       find([M:ITG2]LOCDES(nolign-1)+1,[M:ITG4]LOCNUM2(0..[M:ITG4]NBLOC-1)) |
&       find([M:ITG2]LOCDES(nolign-1)+1,[M:ITG4]LOCNUM3(0..[M:ITG4]NBLOC-1)) |
&       find([M:ITG2]LOCDES(nolign-1)+1,[M:ITG8]LOCNUME(0..[M:ITG8]NBENT-1))
        mkstat=2
        GMESSAGE = mess(499,199,1)
     Endif
  Endif
Endif
# anulation d'un groupe de lignes
If find(status,68,83)
# hcb X3-58069
   If dim([M:ITG2]LOCDES) > 0
      For I=nolign To nolign1
         If find([M:ITG2]LOCDES(nolign-1)+1,[M:ITG4]LOCNUM (0..[M:ITG4]NBLOC-1)) |
&           find([M:ITG2]LOCDES(nolign-1)+1,[M:ITG4]LOCNUM2(0..[M:ITG4]NBLOC-1)) |
&           find([M:ITG2]LOCDES(nolign-1)+1,[M:ITG4]LOCNUM3(0..[M:ITG4]NBLOC-1)) |
&           find([M:ITG2]LOCDES(nolign-1)+1,[M:ITG8]LOCNUME(0..[M:ITG8]NBENT-1))
            mkstat=2
            GMESSAGE = mess(499,199,1)
            Break
         Endif
      Next
   Endif
Endif
End

Subprog APRES_NBINT
End

########################################
# LOCDES
########################################
Subprog AS_LOCDES(VALEUR)
Variable Integer VALEUR
If [M:ITG2]LOCMGTCOD =1                         # hcb X3-58069
  mkstat=2
Endif

# TS
#If GIMPORT & VALEUR<>0 & GREP="C"
#    NOL = nolign-1
#    I=sigma(0,[M:ITG9]NBINT-1,(indcum+1)*([M:ITG9]LOCDES(indcum)=VALEUR &
#&          (indcum<>NOL)))
#    If I<>0
#        mkstat=2 : End
#    Endif
#Endif
End

Subprog C_LOCDES(VALEUR)
Variable Integer VALEUR
Local Integer I, NOL

NOL = nolign-1
# hcb X3-58069
I=sigma(0,[M:ITG2]NBINT-1,(indcum+1)*([M:ITG2]LOCDES(indcum)=VALEUR &
&      (indcum<>NOL)))
If I<>0
 GERR=1
 GMESSAGE = mess(24,123,1)-num$(I) : # Code déjà existant en ligne
 mkstat=2 : End
Endif
#Call UNICITE(VALEUR,[M:ITG9]LOCDES(0..[M:ITG9]NBINT-1)) From OBJDIV
End

Subprog AM_LOCDES(VALEUR)
Variable Integer VALEUR
Local Integer I
# prévenir si ce numéro est utilisé dans le tableau >> ou dans ITG
# pour une combo [M]est déjà chargée en init de zone !! > tester
#MAE, bg 71014
#If VALEUR<>[F:ITG]LOCDES(nolign-1)
#   If [F:ITG]LOCDES(nolign-1)<>0 remplacement de F par M
     If [M:ITG2]LOCDES(nolign-1)<>0                                                         # hcb X3-58069
#MAE, suite bg71014, on teste valeur et pas nolign-1 qui est tjs sur la 1ere ligne.
#      If find([M:ITG9]LOCDES(nolign-1)+1,[M:ITG4]LOCNUM (0..[M:ITG4]NBLOC-1)) |
#&        find([M:ITG9]LOCDES(nolign-1)+1,[M:ITG4]LOCNUM2(0..[M:ITG4]NBLOC-1)) |
#&        find([M:ITG9]LOCDES(nolign-1)+1,[M:ITG4]LOCNUM3(0..[M:ITG4]NBLOC-1)) |
#&        find([M:ITG9]LOCDES(nolign-1)+1,[M:ITG8]LOCNUME(0..[M:ITG8]NBENT-1))
      If find(VALEUR+1,[M:ITG4]LOCNUM (0..[M:ITG4]NBLOC-1)) |
&        find(VALEUR+1,[M:ITG4]LOCNUM2(0..[M:ITG4]NBLOC-1)) |
&        find(VALEUR+1,[M:ITG4]LOCNUM3(0..[M:ITG4]NBLOC-1)) |
&        find(VALEUR+1,[M:ITG8]LOCNUME(0..[M:ITG8]NBENT-1))
         GMESSAGE = mess(499,199,1)
         mkstat = 2
      Endif
   Endif
End

