############################################################################

########################################
# NBENT
########################################
Subprog AVANT_NBENT
If dim([M:ITG2]LOCMGTCOD) > 0                                                       # hcb X3-58069
   If [M:ITG2]LOCMGTCOD > 1 & [M:ITG2]NBINT=0                                       # hcb X3-58069
      mkstat = 2 # Emplacement :le tableau doit contenir au moins 1 ligne
      GMESSAGE = mess(432,199,1) +"\" + mess(205,199,1)
   Endif
Endif
End

########################################
Subprog APRES_NBENT
[M:ITG8]CONCATKEYE(nolign-1) = num$([M:ITG8]TRSTYPE(nolign-1))+[M:ITG8]TRSCODE(nolign-1)
End

########################################
# TRSTYPE
########################################
Subprog AS_TRSTYPE(VALEUR)
Variable Integer VALEUR
# Pas de règle
GMENLOC(7)  = 1
GMENLOC(9)  = 1
GMENLOC(10) = 1
GMENLOC(13) = 1
GMENLOC(14) = 1
GMENLOC(15) = 1
GMENLOC(21) = 1
GMENLOC(22) = 1
GMENLOC(23) = 1
GMENLOC(30) = 1
GMENLOC(31) = 1
GMENLOC(34) = 1
GMENLOC(35) = 1    # Issue 71240 & 78854 - 2012-06-13 by CCC
GMENLOC(36) = 1  : # Issue X3-53322

# Flux de sortie
GMENLOC(2)  = 1
GMENLOC(4)  = 1
GMENLOC(6)  = 1
GMENLOC(11) = 1
GMENLOC(17) = 1
GMENLOC(20) = 1
GMENLOC(24) = 1
GMENLOC(25) = 1
GMENLOC(27) = 1
GMENLOC(29) = 1
GMENLOC(32) = 1
End

########################################
Subprog AM_TRSTYPE(VALEUR)
Variable Integer VALEUR
# Test nécessaire pour l'import
If !find(VALEUR,1,3,5,8,12,16,18,19,26,28,33) End Endif

Local Char LOLDTCL(GLONITG)
Local Char LOLDFCY(GLONFCY)
Local Integer LOLDTYP
Local Char LOLDCOD(GLONADI)

Local Integer NOL
NOL = nolign-1
If [M:ITG8]AUZSTAE(NOL)=0

  If clalev([F:SRU2])=0 Local File TABSTORUL  [SRU2] Endif
  Read [SRU2]SRU0 = "";"";VALEUR;""
  If !fstat
    [M:ITG8] = [F:SRU2]
    If dim([M:ITG8]LOCNUME)>0
       [M:ITG8]LOCNUME(NOL) = [F:SRU2]LOCNUM
    Endif
    If dim([M:ITG2]LOCMGTCOD)>0 & [M:ITG2]LOCMGTCOD=1                                # hcb X3-58069
      Raz [M:ITG8]LOCNUME(NOL)
    Endif
    [M:ITG8]AUZSTAE(NOL) = [F:SRU2]AUZSTA
    [M:ITG8]AUZSSTE(NOL) = [F:SRU2]AUZSST
    [M:ITG8]FORSTAE(NOL) = [F:SRU2]FORSTA
    [M:ITG8]TRSTYPE(NOL) = [F:SRU2]TRSTYP
    #--- Issue X3-53322
    If dim([M:ITG8]DACCTR)>0
      If [M:ITG8]DACCTR(NOL)=0 [M:ITG8]DACCTR(NOL)=1 Endif
    Endif
    #---
    Affzo [M:ITG8]1-99
  Endif
Endif

Call ETAT_ZONE_SRU(VALEUR,NOL) From SUBITGA

Affzo [M:ITG8]QLYCTLFLG(NOL)
If dim([M:ITG8]LOTSUPINH)>0
  Affzo [M:ITG8]LOTSUPINH(NOL)
Endif

End

########################################
# TRSCODE
########################################
Subprog C_TRSCODE(VALEUR)
Variable Char    VALEUR()

Local Char CONC
# Controle d'unicité
CONC = num$([M:ITG8]TRSTYPE(nolign-1)) + VALEUR
Call UNICITE(CONC,[M:ITG8]CONCATKEYE(0..[M:ITG8]NBENT-1)) From OBJDIV
If mkstat = 2 : End : Endif
End

########################################
# LOCNUME
########################################
Subprog AS_LOCNUME(VALEUR)
Variable Integer VALEUR
If [M:ITG2]LOCMGTCOD=1                                            # hcb X3-58069
  mkstat=2 : End
Endif
#If !GIMPORT : # En import locdes sera importé en même temps
    For I=1 To len(mess(0,2707,1))
      If !find(I,[M:ITG2]LOCDES)                                   # hcb X3-71908
        GMENLOC(I+1) = 1
      Endif
    Next
#Endif
End

########################################
Subprog C_LOCNUME(VALEUR)
Variable Integer VALEUR

If VALEUR<2 End Endif
# contrôler qu'on trouve bien valeur dans le tableau LOCDES
If !find(VALEUR-1,[M:ITG2]LOCDES)                                   # hcb X3-71908
   mkstat = 2
   GMESSAGE = mess(345,199,1) #"Le N° doit correspondre à une ligne du tabl intit"
Endif
End

########################################
# AUZSTAE
########################################
Subprog AS_AUZSTAE(VALEUR)
Variable Integer VALEUR
# hcb : restriction suivnte annulée demande : 40793
# Si contrôle qualité pas de statut 'Q'
#If [M:ITG8]TRSTYPE(nolign-1)=8
#  GMENLOC(2)=1
#  GMENLOC(3)=1
#  GMENLOC(6)=1
#  GMENLOC(7)=1
#Endif
If [M:ITG8]TRSTYPE(nolign-1)=34
  GMENLOC(1)=1
  GMENLOC(3)=1
  GMENLOC(4)=1
  GMENLOC(5)=1
  GMENLOC(6)=1
  GMENLOC(7)=1
Endif
End

########################################
Subprog AM_AUZSTAE(VALEUR)
Variable Integer VALEUR

# griser Demande analyse si pas statut Q
If !find(VALEUR,2,3,6,7)
  Effzo [M:ITG8]QLYCTLFLG(nolign-1)
  Grizo [M:ITG8]QLYCTLFLG(nolign-1)
Else
  Actzo [M:ITG8]QLYCTLFLG(nolign-1)
Endif
# à la création, précharger les modèles de sous-statuts correspondant
If [M:ITG8]AUZSSTE(nolign-1) = ""
 If find(VALEUR,1,3,5,7)
   [M:ITG8]AUZSSTE(nolign-1) += "A*"
 Endif
 If find(VALEUR,2,3,6,7)
   If [M:ITG8]AUZSSTE(nolign-1) <> ""
     [M:ITG8]AUZSSTE(nolign-1) += ","
   Endif
   [M:ITG8]AUZSSTE(nolign-1) += "Q*"
 Endif
 If find(VALEUR,4,5,6,7)
   If [M:ITG8]AUZSSTE(nolign-1) <> ""
     [M:ITG8]AUZSSTE(nolign-1) += ","
   Endif
   [M:ITG8]AUZSSTE(nolign-1) += "R*"
 Endif
Endif
End

########################################
# AUZSSTE
########################################
Subprog C_AUZSSTE(VALEUR)
Variable Char    VALEUR()

# contrôle en cas de saisie directe :
VALEUR = toupper(VALEUR)
Call CTR_LIST_SST(VALEUR,[M:ITG8]AUZSTAE(nolign-1)) From TRTCATEG
# construction de la formule :
Call DECODE_STAT(VALEUR,[M:ITG8]FORSTAE(nolign-1)) From TRTCATEG
End

########################################
# DEFSTA
########################################
Subprog AS_DEFSTA(VALEUR)
Variable Char    VALEUR()
Local Integer LSENS
Local Integer NOL
NOL = nolign-1
# Pas de statut par défaut si type mvt = changement emplacement
If [M:ITG8]TRSTYPE(NOL)=26
   mkstat = 2
Endif
#MAE, bg 69177, on utilise plus la variable globale GTYP mais une rubrique de ITG8
[M:ITG8]GTYP(NOL)=[M:ITG8]TRSTYPE(NOL) : # dde 271999 pour passage param à la sélection
End

########################################
Subprog C_DEFSTA(VALEUR)
Variable Char    VALEUR()
Local Char TAB_STAT(GLONTST)(20)
Local Integer I, OK
Local Shortint NB
# contrôler le statut par défaut selon les sous-statuts autorisés
Call DECOUPE_STAT([M:ITG8]AUZSSTE(nolign-1),TAB_STAT,NB) From TRTCATEG
For I=0 To dim(TAB_STAT)-1
  If instr(1,TAB_STAT(I),"*") or instr(1,TAB_STAT(I),"?")
& or instr(1,TAB_STAT(I),"#") or instr(1,TAB_STAT(I),"!")

    If pat(VALEUR,TAB_STAT(I))
      OK = 1
      Break
    Endif
  Else
    If VALEUR = TAB_STAT(I)
      OK = 1
      Break
    Endif
  Endif
Next
If OK = 0
  mkstat=2
  GMESSAGE = mess(357,199,1) #"Valeur non autorisée"
Endif
End

########################################
# QLYCTLFLG
########################################
Subprog AS_QLYCTLFLG(VALEUR)
Variable Integer VALEUR
# Pas de demande d'analyse si type mvt = contrôle qualité
If [M:ITG8]TRSTYPE(nolign-1)=8
   mkstat = 2
Endif
# Pas de demande d'analyse si type mvt = contrôle qualité
If [M:ITG8]TRSTYPE(nolign-1)=34
   mkstat = 2
Endif
End

########################################
# DACLOT : Saisie du lot
########################################
Subprog AS_DACLOT(VALEUR)
Variable Integer VALEUR
If dim([M:ITG2]LOTMGTCOD) < 0 | [M:ITG2]LOTMGTCOD < 2
   mkstat = 2
Endif
# Pas d'accés lot si type mvt = contrôle qualité, retour prêt,
# changement stock, entrée transfert interne, retour liv s-traitance
If find([M:ITG8]TRSTYPE(nolign-1),8,18,26,28,33)
   mkstat = 2
Endif
End

########################################
# LOTSUPINH : Lot par défaut
########################################
Subprog AS_LOTSUPINH(VALEUR)
Variable Integer VALEUR
If dim([M:ITG2]LOTMGTCOD) < 0 | [M:ITG2]LOTMGTCOD < 2
   mkstat = 2
Endif
# Pas d'accés lot si type mvt = contrôle qualité, retour prêt,
# changement stock ou entrée transfert interne, retour liv s-traitance
If find([M:ITG8]TRSTYPE(nolign-1),8,18,26,28,33)
   mkstat = 2
Endif
End


# hcb 28874  deb
######################################################################################
# gestion des rubriques suivantes depuis les actions AM_
######################################################################################
# "PURFLG"  Acheté
# "MFGFLG"  Fabriqué
# "SCPFLG"  Sous-traité
# "DLVFLG"  Livrable
# "SALFLG"  Vendu
# "SCSFLG"  Sous-traitance
# "PHAFLG"  Fantome
# "GENFLG"  Générique
# "TOOFLG"  Outillage
# "MCEFLG"  Maintenance
######################################################################################

$TRT_TYP
If  GMODU(6) <> 2
    Effzo [M:ITG6]FIMHOR,FIMHORUOM,FRTHOR,FRTHORUOM,OFS,MINRMNPRC,RCPFLG,PRQFLG
    Grizo [M:ITG6]5
Endif

Case TRT_ZON
  When "PURFLG"
       [M:ITG1]PURFLG = VALEUR
       Gosub TRT_TYP_LIEN
# Initialisation à "saisi" des coûts pour une catég achetée
       If VALEUR = 2 & GREP="C"
          [M:ITG5]STDCSTUPD = 2
          [M:ITG5]CUTCSTUPD = 2
          [M:ITG5]BUDCSTUPD = 2
          [M:ITG5]SIMCSTUPD = 2
          Affzo [M:ITG5]STDCSTUPD,CUTCSTUPD,BUDCSTUPD,SIMCSTUPD
       Endif
       If VALEUR = 2 & GMODU(6) = 2
          # Issue 70985 - 2012-03-13 by MUARN : landed cost cout forfaitaire
          If [M:ITG6]CPRCOE=0 [M:ITG6]CPRCOE=1  : Affzo [M:ITG6]CPRCOE Endif
          Actzo [M:ITG6]5
       Else
          If VALEUR = 1 & [M:ITG1]SCPFLG = 1 & [M:ITG1]SCSFLG = 1 & [M:ITG1]GENFLG = 1 & [M:ITG1]TOOFLG = 1
             Effzo [M:ITG6]FIMHOR,FIMHORUOM,FRTHOR,FRTHORUOM,OFS,MINRMNPRC,RCPFLG,PRQFLG
             Grizo [M:ITG6]5
          Endif
          # Issue 70985 - 2012-03-12 by MUARN : landed cost cout forfaitaire
          If VALEUR = 1
              Effzo [M:ITG6]CPRCOE, CPRAMT, STCNUM
              Grizo [M:ITG6]CPRCOE, CPRAMT, CUR, STCNUM
          Else
              If [M:ITG6]CPRCOE=0 [M:ITG6]CPRCOE=1  : Affzo [M:ITG6]CPRCOE Endif
          Endif
       Endif

  When "MFGFLG"
       [M:ITG1]MFGFLG = VALEUR
       Gosub TRT_TYP_LIEN
       If VALEUR = 2
          If [M:ITG2]STOCOD = 3
             [M:ITG2]STOCOD = 1
             Affzo [M:ITG2]STOCOD
          Endif
       Else
          If GMODU(6) = 2 & [M:ITG1]PHAFLG = 1 &
&            ([M:ITG1]PURFLG = 2 | [M:ITG1]SCPFLG = 2 | [M:ITG1]SCSFLG = 2 | [M:ITG1]GENFLG = 2 | [M:ITG1]TOOFLG = 2 )
             Actzo [M:ITG6]5
             # Issue 70985 - 2012-03-12 by MUARN : landed cost
             If [M:ITG1]PURFLG = 1
               Effzo [M:ITG6]CPRCOE, CPRAMT, STCNUM
               Grizo [M:ITG6]CPRCOE, CPRAMT, CUR, STCNUM
             Endif
          Endif
       Endif

  When "SCPFLG"
       [M:ITG1]SCPFLG = VALEUR
       Gosub TRT_TYP_LIEN
       If VALEUR = 2 & GMODU(6) = 2
          Actzo [M:ITG6]5
          # Issue 70985 - 2012-03-12 by MUARN : landed cost
          If [M:ITG1]PURFLG = 1
            Effzo [M:ITG6]CPRCOE, CPRAMT, STCNUM
            Grizo [M:ITG6]CPRCOE, CPRAMT, CUR, STCNUM
          Endif
       Else
          If VALEUR = 1 & [M:ITG1]PURFLG = 1 & [M:ITG1]SCSFLG = 1 & [M:ITG1]GENFLG = 1 & [M:ITG1]TOOFLG = 1
             Effzo [M:ITG6]FIMHOR,FIMHORUOM,FRTHOR,FRTHORUOM,OFS,MINRMNPRC,RCPFLG,PRQFLG
             Grizo [M:ITG6]5
          Endif
       Endif
  When "DLVFLG"
       [M:ITG1]DLVFLG = VALEUR
       Gosub TRT_TYP_LIEN
       If VALEUR = 1  & [M:ITG1]SALFLG <> 2
          # Type of flow not deliverable and not sold
          Effzo [M:ITG2]PCK
          Effzo [M:ITG2]PCKCAP
          Effzo [M:ITG2]PCKFLG
          Effzo [M:ITG2]PCKSTKFLG
          Grizo [M:ITG2]PCK
          Grizo [M:ITG2]PCKCAP
          Grizo [M:ITG2]PCKFLG
          Grizo [M:ITG2]PCKSTKFLG
          # 107888 : Scheduled invoices (LD:03/12/15)
          # Invoice term accessible only for Service/Generic category and type of flow sold and not deliverable
          If GMODU(5)=2
              Effzo [M:ITG6]INVCND
              Grizo [M:ITG6]INVCND
          Endif
          # 107888 : Scheduled invoices (LD:03/12/15)
       Else
          # Type of flow not deliverable and sold
          # Type of flow deliverable and sold
          # Type of flow deliverable and not sold
          Actzo [M:ITG2]PCK
          Actzo [M:ITG2]PCKCAP
          Actzo [M:ITG2]PCKFLG
          Actzo [M:ITG2]PCKSTKFLG
          If [M:ITG2]STOMGTCOD < 2
             Grizo [M:ITG2]PCKSTKFLG
          Endif
          # 107888 : Scheduled invoices (LD:03/12/15)
          # Invoice term accessible only for Service/Generic category and type of flow sales and not deliverable
          If GMODU(5)=2
              If ([M:ITG1]SCSFLG=2 | [M:ITG1]GENFLG=2) & [M:ITG1]SALFLG=2 & [M:ITG1]DLVFLG=1
                  Actzo [M:ITG6]INVCND
              Else
                  Effzo [M:ITG6]INVCND
                  Grizo [M:ITG6]INVCND
              Endif
          Endif
          # 107888 : Scheduled invoices (LD:03/12/15)
       Endif


  When "SALFLG"
       [M:ITG1]SALFLG = VALEUR
       Gosub TRT_TYP_LIEN
       If VALEUR = 1  & [M:ITG1]DLVFLG <> 2
          Effzo [M:ITG2]PCK
          Effzo [M:ITG2]PCKCAP
          Effzo [M:ITG2]PCKFLG
          Effzo [M:ITG2]PCKSTKFLG
          Grizo [M:ITG2]PCK
          Grizo [M:ITG2]PCKCAP
          Grizo [M:ITG2]PCKFLG
          Grizo [M:ITG2]PCKSTKFLG
       Else
          Actzo [M:ITG2]PCK
          Actzo [M:ITG2]PCKCAP
          Actzo [M:ITG2]PCKFLG
          Actzo [M:ITG2]PCKSTKFLG
       Endif
       If [M:ITG2]STOMGTCOD < 2
          Grizo [M:ITG2]PCKSTKFLG
       Endif

       If VALEUR  = 2
           # Issue 112531 - 2015-11-16 by MAE : article service
           #Grizo [M:ITG1]DLVFLG
           If[M:ITG1]PHAFLG <> 2    # hcb 81349
             [M:ITG1]DLVFLG = 2
           Else                     # hcb 81349
             [M:ITG1]DLVFLG = 1     # hcb 81349
           Endif                    # hcb 81349
       Else
           Actzo [M:ITG1]DLVFLG
       Endif
       Affzo [M:ITG1]DLVFLG
       # 107888 : Scheduled invoices (LD:03/12/15)
       # Invoice term accessible only for Service/Generic category and not deliverable type of flow
       If GMODU(5)=2
           If ([M:ITG1]SCSFLG=2 | [M:ITG1]GENFLG=2) & [M:ITG1]DLVFLG=1
             Actzo [M:ITG6]INVCND
           Else
             Effzo [M:ITG6]INVCND
             Grizo [M:ITG6]INVCND
           Endif
       Endif
       # 107888 : Scheduled invoices (LD:03/12/15)
  #VPO 31/08/09 ajout MCEFLG
  When "SCSFLG" , "PHAFLG" ,  "GENFLG" , "TOOFLG" , "MCEFLG"
       If TRT_ZON = "SCSFLG"
          [M:ITG1]SCSFLG = VALEUR
          Gosub TRT_TYP_LIEN
          If VALEUR  = 2
             Effzo [ITG2]
             Grizo [ITG2]
             [M:ITG2]STOCOD=3
             Affzo [ITG2]1-99
             Effzo [ITG8]
             Grizo [ITG8]      # flux d'entrée
             Effzo [ITG4]
             Grizo [ITG4]      # flux de sortie
             Grizo [ITG5]VLTCOD
             If VALEUR = 2 & GMODU(6) = 2
                Actzo [M:ITG6]5
                # Issue 70985 - 2012-03-12 by MUARN : landed cost
                If [M:ITG1]PURFLG = 1
                  Effzo [M:ITG6]CPRCOE, CPRAMT, STCNUM
                  Grizo [M:ITG6]CPRCOE, CPRAMT, CUR, STCNUM
                Endif
             Else
                If VALEUR = 1 & [M:ITG1]SCPFLG = 1 & [M:ITG1]PURFLG = 1 & [M:ITG1]GENFLG = 1 & [M:ITG1]TOOFLG = 1
                   Effzo [M:ITG6]FIMHOR,FIMHORUOM,FRTHOR,FRTHORUOM,OFS,MINRMNPRC,RCPFLG,PRQFLG
                   Grizo [M:ITG6]5
                Endif
             Endif
          Else
             If [M:ITG1]GENFLG <> 2
                Actzo [ITG2]STOMGTCOD
                If [M:ITG1]MFGFLG = 2
                   If [M:ITG2]STOCOD = 3
                      [M:ITG2]STOCOD = 1
                      Affzo [M:ITG2]STOCOD
                   Endif
                Else
                   [M:ITG2]STOCOD = 3
                   Affzo [M:ITG2]STOCOD
                Endif
             Endif
          Endif
          # Issue 59757 - 2017-10-23 by MAE : service et vendu => unités accessibles
#          If [M:ITG1]SCSFLG = 2                                  # hcb 103984
#             Grizo [M:ITG3]SAU, SAUSTUCOE, DACSAUCOE             # hcb 103984
#             If [M:ITG3]SAU = "" & [M:ITG1]DLVFLG = 2            # hcb 103984
#                [M:ITG3]SAU =      [M:ITG3]STU                   # hcb 103984
#                [M:ITG3]SAUSTUCOE = 1                            # hcb 103984
#             Endif                                               # hcb 103984
#          Else                                                   # hcb 103984
#             Actzo [M:ITG3]SAU, SAUSTUCOE, DACSAUCOE             # hcb 103984
#          Endif                                                  # hcb 103984

       Else
          If TRT_ZON = "PHAFLG"
             [M:ITG1]PHAFLG = VALEUR
             Gosub TRT_TYP_LIEN
             If VALEUR  = 2
                Effzo [M:ITG6]FIMHOR,FIMHORUOM,FRTHOR,FRTHORUOM,OFS,MINRMNPRC,RCPFLG,PRQFLG
                Grizo [M:ITG6]5
             Else
                If GMODU(6) = 2  &
&                  ([M:ITG1]PURFLG = 2 | [M:ITG1]SCPFLG = 2 | [M:ITG1]SCSFLG = 2 | [M:ITG1]GENFLG = 2 | [M:ITG1]TOOFLG = 2)
                   Actzo [M:ITG6]5
                Endif
             Endif
          Else
             If TRT_ZON = "GENFLG"
                [M:ITG1]GENFLG = VALEUR
                Gosub TRT_TYP_LIEN
                If VALEUR  = 2
                   Effzo [ITG2]
                   Grizo [ITG2]
                   [M:ITG2]STOCOD=3
                   Affzo [ITG2]1-99
                   Effzo [ITG8]
                   Grizo [ITG8]      # flux d'entrée
                   Effzo [ITG4]
                   Grizo [ITG4]      # flux de sortie
                   Grizo [ITG5]VLTCOD
                   If VALEUR = 2 & GMODU(6) = 2
                      Actzo [M:ITG6]5
                      # Issue 70985 - 2012-03-12 by MUARN : landed cost
                      If [M:ITG1]PURFLG = 1
                        Effzo [M:ITG6]CPRCOE, CPRAMT, STCNUM
                        Grizo [M:ITG6]CPRCOE, CPRAMT, CUR, STCNUM
                      Endif
                   Else
                      If VALEUR = 1 & [M:ITG1]SCPFLG = 1 & [M:ITG1]SCSFLG = 1 & [M:ITG1]PURFLG = 1 & [M:ITG1]TOOFLG = 1
                         Effzo [M:ITG6]FIMHOR,FIMHORUOM,FRTHOR,FRTHORUOM,OFS,MINRMNPRC,RCPFLG,PRQFLG
                         Grizo [M:ITG6]5
                      Endif
                   Endif
                Else
                   If [M:ITG1]SCSFLG <> 2
                      Actzo [ITG2]STOMGTCOD
                      If [M:ITG1]MFGFLG = 2
                         If [M:ITG2]STOCOD = 3
                            [M:ITG2]STOCOD = 1
                            Affzo [M:ITG2]STOCOD
                         Endif
                      Else
                         [M:ITG2]STOCOD = 3
                         Affzo [M:ITG2]STOCOD
                      Endif
                   Endif
                Endif
             Else
                If TRT_ZON = "TOOFLG"
                   [M:ITG1]TOOFLG = VALEUR
                   Gosub TRT_TYP_LIEN
                   If VALEUR  = 2
                      If VALEUR = 2 & GMODU(6) = 2
                         Actzo [M:ITG6]5
                         # Issue 70985 - 2012-03-12 by MUARN : landed cost
                         If [M:ITG1]PURFLG = 1
                           Effzo [M:ITG6]CPRCOE, CPRAMT, STCNUM
                           Grizo [M:ITG6]CPRCOE, CPRAMT, CUR, STCNUM
                         Endif
                      Else
                         If VALEUR = 1 & [M:ITG1]SCPFLG = 1 & [M:ITG1]SCSFLG = 1 & [M:ITG1]GENFLG = 1 & [M:ITG1]PURFLG = 1
                            Effzo [M:ITG6]FIMHOR,FIMHORUOM,FRTHOR,FRTHORUOM,OFS,MINRMNPRC,RCPFLG,PRQFLG
                            Grizo [M:ITG6]5
                         Endif
                      Endif
                   Endif
                Else : #VPO 31/08/09 ajout MCEFLG
                    If TRT_ZON = "MCEFLG"
                       [M:ITG1]MCEFLG = VALEUR
                       Gosub TRT_TYP_LIEN
                       If VALEUR  = 2
                          If VALEUR = 2 & GMODU(6) = 2
                             Actzo [M:ITG6]5
                             # Issue 70985 - 2012-03-12 by MUARN : landed cost
                             If [M:ITG1]PURFLG = 1
                               Effzo [M:ITG6]CPRCOE, CPRAMT, STCNUM
                               Grizo [M:ITG6]CPRCOE, CPRAMT, CUR, STCNUM
                             Endif
                          Else
                             If VALEUR = 1 & [M:ITG1]SCPFLG = 1 & [M:ITG1]SCSFLG = 1 & [M:ITG1]GENFLG = 1 & [M:ITG1]PURFLG = 1
                                Effzo [M:ITG6]FIMHOR,FIMHORUOM,FRTHOR,FRTHORUOM,OFS,MINRMNPRC,RCPFLG,PRQFLG
                                Grizo [M:ITG6]5
                             Endif
                          Endif
                       Endif
                    Endif
                Endif
             Endif
          Endif
       Endif

Endcase

# On supprime les lignes de FG qui sont en trop
If VALEUR=1
    GBIDI1 = ([M:ITG1]MFGFLG=2)
&           +([M:ITG1]PURFLG=2)*2
&           +([M:ITG1]SCPFLG=2)*4
&           +([M:ITG1]SCSFLG=2)*8    # Type de flux autorisé sur la catégorie
    For nolign=[M:ITG5]NBTYP To 1 Step -1
        If !func STKVALPAR.WITHOVE([M:ITG5]OTRSTYP(nolign-1),GBIDI1)    # Vérifie que le type de mouvement gère les FG
            Dela nolign-1, 1 [M:ITG5]NBTYP
        Endif
    Next
    Affzo [M:ITG5]
Endif

Return
######################################################################################
# gestion des rubriques suivantes depuis l action LIEN et action AM_
######################################################################################
# "PURFLG"  Acheté
# "MFGFLG"  Fabriqué
# "SCPFLG"  Sous-traité
# "DLVFLG"  Livrable
# "SALFLG"  Vendu
# "SCSFLG"  Sous-traitance
# "PHAFLG"  Fantome
# "GENFLG"  Générique
# "TOOFLG"  Outillage
# "MCEFLG"  Maintenance
######################################################################################

$TRT_TYP_LIEN
#--- Bug 61719
If [M:ITG0]STOFCY<>""
  # Issue 106584 - 2018-08-31 by MAE : Responsive UI
   #Diszo [M:ITG1]25
   #Diszo [M:ITG1]30
   Diszo [M:ITG1]20
   Diszo [M:ITG1]15
   Goto TRT_TYP_AFF
Endif
#---
Actzo [M:ITG1]PHAFLG
Actzo [M:ITG1]GENFLG
Actzo [M:ITG1]TOOFLG
Actzo [M:ITG1]SCSFLG
Actzo [M:ITG1]PURFLG
Actzo [M:ITG1]MFGFLG
Actzo [M:ITG1]SCPFLG
Actzo [M:ITG1]DLVFLG
Actzo [M:ITG1]SALFLG
If dim([M:ITG1]MCEFLG)>0 : Actzo [M:ITG1]MCEFLG : Endif: #VPO 31/08/09 ajout MCEFLG
#Actzo [M:ITG1]INTFLG
# controle existence article
# si existe pas de modif possible (accord du 280306)
Filter [ITM] Where TCLCOD = [M:ITG0]TCLCOD

Look [ITM]ITM0 First
Filter [ITM]

If !fstat
  # Issue 106584 - 2018-08-31 by MAE : Responsive UI
   #Diszo [M:ITG1]25
   #Diszo [M:ITG1]30
   Diszo [M:ITG1]20
   Diszo [M:ITG1]15
   #--- Bug 61719
   #Return
   Goto TRT_TYP_AFF
   #---
Endif


#If [M:ITG1]PURFLG = 2       # hcb 86026
#   Diszo [M:ITG1]PHAFLG
#   [M:ITG1]PHAFLG = 1
#Endif
If [M:ITG1]MFGFLG = 2
   Diszo [M:ITG1]SCSFLG
   Diszo [M:ITG1]TOOFLG
   [M:ITG1]SCSFLG = 1
   [M:ITG1]TOOFLG = 1
   If dim([M:ITG1]MCEFLG)>0 : Diszo [M:ITG1]MCEFLG : [M:ITG1]MCEFLG = 1 : Endif : #VPO 31/08/09 ajout MCEFLG
Endif
If [M:ITG1]SCPFLG = 2
   Diszo [M:ITG1]SCSFLG
   Diszo [M:ITG1]PHAFLG
   Diszo [M:ITG1]GENFLG
   Diszo [M:ITG1]TOOFLG
   [M:ITG1]SCSFLG = 1
   [M:ITG1]PHAFLG = 1
   [M:ITG1]GENFLG = 1
   [M:ITG1]TOOFLG = 1
   If dim([M:ITG1]MCEFLG)>0 : Diszo [M:ITG1]MCEFLG : [M:ITG1]MCEFLG = 1 : Endif : #VPO 31/08/09 ajout MCEFLG
Endif
If [M:ITG1]DLVFLG = 2
   Diszo [M:ITG1]PHAFLG
   #Diszo [M:ITG1]GENFLG
   Diszo [M:ITG1]TOOFLG
   [M:ITG1]PHAFLG = 1
   #[M:ITG1]GENFLG = 1
   [M:ITG1]TOOFLG = 1
   #--- Issue 106761
   #If dim([M:ITG1]MCEFLG)>0 : Diszo [M:ITG1]MCEFLG : [M:ITG1]MCEFLG = 1 : Endif : #VPO 31/08/09 ajout MCEFLG
Endif
If [M:ITG1]SALFLG = 2
   Diszo [M:ITG1]PHAFLG
   #Diszo [M:ITG1]GENFLG
   Diszo [M:ITG1]TOOFLG

   # Issue 112531 - 2015-11-16 by MAE : article service

   # 107888 : Scheduled invoices (LD:03/12/15)
   # To decomment when scheduled invoices will be available
   # Type flow deliverable accessible only for Service/Generic category and type of flow sales
   If [M:ITG1]SCSFLG <> 2 & [M:ITG1]GENFLG <> 2
   # 107888 : Scheduled invoices (LD:03/12/15)
    Diszo [M:ITG1]DLVFLG
   Else
    Actzo [M:ITG1]DLVFLG
   Endif
   # Issue -112531 : retour arriére

   # To comment when scheduled invoices will be available
   # Diszo [M:ITG1]DLVFLG
   # 107888 : Scheduled invoices (LD:03/12/15)

#   [M:ITG1]PHAFLG = 1    # hcb 81349
   #[M:ITG1]GENFLG = 1
   [M:ITG1]TOOFLG = 1

# Issue 122167 - 2017-03-27 by MAE : Partie traitée en dessous
#    # Issue 112531 - 2015-11-16 by MAE : Article service
#    If [M:ITG1]PHAFLG <> 2  & [M:ITG1]SCSFLG <> 2   # hcb 81349
#       [M:ITG1]DLVFLG =  2
#    Endif                      # hcb 81349
# End issue 122167

   # 107888 : Scheduled invoices (LD:04/12/15)
   # Type flow non deliverable possible for Service/Generic category
#   # Issue 112531 - 2015-11-16 by MAE : Article service
#   If [M:ITG1]PHAFLG <> 2  & [M:ITG1]SCSFLG <> 2   # hcb 81349
   If [M:ITG1]PHAFLG <> 2  & [M:ITG1]SCSFLG <> 2 & [M:ITG1]GENFLG <> 2  # hcb 81349
      [M:ITG1]DLVFLG =  2
      If GMODU(5)=2
          Effzo [M:ITG6]INVCND
          Grizo [M:ITG6]INVCND
      Endif
      # 107888 : Scheduled invoices (LD:04/12/15)
   Endif                      # hcb 81349

   #--- 113058
   # Issue US X3-7700 : un article de catégorie acheté et vendu peut être livrable ou non
#   If [M:ITG1]SCSFLG=2 & [M:ITG1]PURFLG=2
#     [M:ITG1]DLVFLG=2
#     Diszo [M:ITG1]DLVFLG
#   Endif
   #---
   #--- Issue 106761
   #If dim([M:ITG1]MCEFLG)>0 : Diszo [M:ITG1]MCEFLG : [M:ITG1]MCEFLG = 1 : Endif : #VPO 31/08/09 ajout MCEFLG
Endif
If [M:ITG1]SCSFLG = 2
   Diszo [M:ITG1]MFGFLG
   Diszo [M:ITG1]SCPFLG
   Diszo [M:ITG1]PHAFLG
   Diszo [M:ITG1]GENFLG
   Diszo [M:ITG1]TOOFLG
   # Issue 112531 - 2015-11-16 by MAE : Articles service
   #Diszo [M:ITG1]PURFLG
   #Diszo [M:ITG1]INTFLG
   #[M:ITG1]INTFLG = 1
   [M:ITG1]MFGFLG = 1
   [M:ITG1]SCPFLG = 1
   [M:ITG1]PHAFLG = 1
   [M:ITG1]GENFLG = 1
   [M:ITG1]TOOFLG = 1
   # Issue 112531 - 2015-11-16 by MAE : Articles service
   #[M:ITG1]PURFLG = 2
   If dim([M:ITG1]MCEFLG)>0 : Diszo [M:ITG1]MCEFLG : [M:ITG1]MCEFLG = 1 : Endif : #VPO 31/08/09 ajout MCEFLG
Endif
If [M:ITG1]PHAFLG = 2
#   Diszo [M:ITG1]PURFLG   # hcb 86026
   Diszo [M:ITG1]SCPFLG
   Diszo [M:ITG1]DLVFLG
#  Diszo [M:ITG1]SALFLG   # hcb 81349
   Diszo [M:ITG1]SCSFLG
   Diszo [M:ITG1]GENFLG
   Diszo [M:ITG1]TOOFLG
   #Diszo [M:ITG1]INTFLG
   #[M:ITG1]INTFLG = 1
#   [M:ITG1]PURFLG = 1   # hcb 86026
   [M:ITG1]SCPFLG = 1
   [M:ITG1]DLVFLG = 1
#  [M:ITG1]SALFLG = 1    # hcb 81349
   [M:ITG1]SCSFLG = 1
   [M:ITG1]GENFLG = 1
   [M:ITG1]TOOFLG = 1
   If dim([M:ITG1]MCEFLG)>0 : Diszo [M:ITG1]MCEFLG : [M:ITG1]MCEFLG = 1 : Endif : #VPO 31/08/09 ajout MCEFLG
Endif

If [M:ITG1]GENFLG = 2
   Diszo [M:ITG1]SCPFLG
   #Diszo [M:ITG1]DLVFLG
   #Diszo [M:ITG1]SALFLG
   Diszo [M:ITG1]SCSFLG
   Diszo [M:ITG1]PHAFLG
   Diszo [M:ITG1]TOOFLG
   #Diszo [M:ITG1]INTFLG
   #[M:ITG1]INTFLG = 1
   [M:ITG1]SCPFLG = 1
   #[M:ITG1]DLVFLG = 1
   #[M:ITG1]SALFLG = 1
   [M:ITG1]SCSFLG = 1
   [M:ITG1]PHAFLG = 1
   [M:ITG1]TOOFLG = 1
   If dim([M:ITG1]MCEFLG)>0 : Diszo [M:ITG1]MCEFLG : [M:ITG1]MCEFLG = 1 : Endif : #VPO 31/08/09 ajout MCEFLG
Endif
If [M:ITG1]TOOFLG = 2
   Diszo [M:ITG1]MFGFLG
   Diszo [M:ITG1]SCPFLG
   Diszo [M:ITG1]DLVFLG
   Diszo [M:ITG1]SALFLG
   Diszo [M:ITG1]SCSFLG
   Diszo [M:ITG1]GENFLG
   Diszo [M:ITG1]PHAFLG
   #Diszo [M:ITG1]INTFLG
   #[M:ITG1]INTFLG = 1
   [M:ITG1]MFGFLG = 1
   [M:ITG1]SCPFLG = 1
   [M:ITG1]DLVFLG = 1
   [M:ITG1]SALFLG = 1
   [M:ITG1]SCSFLG = 1
   [M:ITG1]GENFLG = 1
   [M:ITG1]PHAFLG = 1
   If dim([M:ITG1]MCEFLG)>0 : Diszo [M:ITG1]MCEFLG : [M:ITG1]MCEFLG = 1 : Endif : #VPO 31/08/09 ajout MCEFLG
Endif
If dim([M:ITG1]MCEFLG)>0 : #VPO 31/08/09 ajout MCEFLG
    If [M:ITG1]MCEFLG = 2
       Diszo [M:ITG1]MFGFLG
       Diszo [M:ITG1]SCPFLG
       #--- Issue 106761
       #Diszo [M:ITG1]DLVFLG
       #Diszo [M:ITG1]SALFLG
       Diszo [M:ITG1]SCSFLG
       Diszo [M:ITG1]GENFLG
       Diszo [M:ITG1]PHAFLG
       Diszo [M:ITG1]TOOFLG
       #Diszo [M:ITG1]INTFLG
       #[M:ITG1]INTFLG = 1
       [M:ITG1]MFGFLG = 1
       [M:ITG1]SCPFLG = 1
       #--- Issue 106761
       #[M:ITG1]DLVFLG = 1
       #[M:ITG1]SALFLG = 1
       [M:ITG1]SCSFLG = 1
       [M:ITG1]GENFLG = 1
       [M:ITG1]PHAFLG = 1
       [M:ITG1]TOOFLG = 1
    Endif
Endif
#If [M:ITG1]INTFLG = 2
#   Diszo [M:ITG1]TOOFLG
#   Diszo [M:ITG1]SCSFLG
#   Diszo [M:ITG1]GENFLG
#   Diszo [M:ITG1]PHAFLG
#   [M:ITG1]TOOFLG = 1
#   [M:ITG1]SCSFLG = 1
#   [M:ITG1]GENFLG = 1
#   [M:ITG1]PHAFLG = 1
#Endif

#--- Bug 61719
$TRT_TYP_AFF
#---
Affzo [M:ITG1]PURFLG
Affzo [M:ITG1]MFGFLG
Affzo [M:ITG1]SCPFLG
Affzo [M:ITG1]DLVFLG
Affzo [M:ITG1]SALFLG
Affzo [M:ITG1]SCSFLG
Affzo [M:ITG1]PHAFLG
Affzo [M:ITG1]GENFLG
Affzo [M:ITG1]TOOFLG
If dim([M:ITG1]MCEFLG)>0 : Affzo [M:ITG1]MCEFLG : Endif : #VPO 31/08/09 ajout MCEFLG

Return

Subprog AM_PURFLG(VALEUR)
Variable Integer VALEUR
Local Char TRT_ZON(10)
TRT_ZON = "PURFLG"
Gosub TRT_TYP
End

