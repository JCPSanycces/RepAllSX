End
#---

########################################
Subprog APRES_NBLOC
[M:ITG4]CONCATKEYS(nolign-1) = num$([M:ITG4]TRSTYPS(nolign-1))+[M:ITG4]TRSCODS(nolign-1)
End

########################################
# TRSTYPS
########################################
Subprog AS_TRSTYPS(VALEUR)
Variable Integer VALEUR
# Pas de règle
GMENLOC(7)  = 1
GMENLOC(9)  = 1
GMENLOC(10) = 1
GMENLOC(13) = 1
GMENLOC(14) = 1
GMENLOC(15) = 1
GMENLOC(21) = 1
GMENLOC(22) = 1
GMENLOC(23) = 1
GMENLOC(30) = 1
GMENLOC(31) = 1
GMENLOC(35) = 1    # Issue 71240 & 78854 - 2012-06-13 by CCC
GMENLOC(36) = 1  : # Issue X3-53322
# Flux d'entrée
GMENLOC(1)  = 1
GMENLOC(3)  = 1
GMENLOC(5)  = 1
GMENLOC(8)  = 1
GMENLOC(12) = 1
GMENLOC(16) = 1
GMENLOC(18) = 1
GMENLOC(19) = 1
GMENLOC(26) = 1
GMENLOC(28) = 1
GMENLOC(33) = 1
GMENLOC(34) = 1

End

########################################
Subprog AM_TRSTYPS(VALEUR)
Variable Integer VALEUR

# Test nécessaire pour l'import
If !find(VALEUR,2,4,6,11,17,20,24,25,27,29,32) End Endif

Local Char    LOLDTCL(GLONITG)
Local Char    LOLDFCY(GLONFCY)
Local Integer LOLDTYP
Local Char    LOLDCOD(GLONADI)
Local Integer NOL
NOL = nolign-1

If [M:ITG4]AUZSTAS(NOL)=0
  If clalev([F:SRU2])=0 Local File TABSTORUL  [SRU2] Endif
  Read [SRU2]SRU0 = "";"";VALEUR;""
  If !fstat
    [M:ITG4] = [F:SRU2]
    If dim([M:ITG2]LOCMGTCOD)>0 & [M:ITG2]LOCMGTCOD=1                  # hcb X3-58069
      Raz [M:ITG4]LOCNUM(NOL)
      Raz [M:ITG4]LOCNUM2(NOL)
      Raz [M:ITG4]LOCNUM3(NOL)
    Endif
    [M:ITG4]AUZSTAS(NOL) = [F:SRU2]AUZSTA
    [M:ITG4]AUZSSTS(NOL) = [F:SRU2]AUZSST
    [M:ITG4]FORSTAS(NOL) = [F:SRU2]FORSTA
    #MAE, bg 57261
    [M:ITG4]TRSTYPS(NOL) = [F:SRU2]TRSTYP
    Affzo [M:ITG4]1-99
  Endif
Endif

Call ETAT_ZONE_SRU(VALEUR,NOL) From SUBITGA

End

########################################
# TRSCODS
########################################
Subprog C_TRSCODS(VALEUR)
Variable Char    VALEUR()

Local Char CONC
# Controle d'unicité
CONC = num$([M:ITG4]TRSTYPS(nolign-1)) + VALEUR
Call UNICITE(CONC,[M:ITG4]CONCATKEYS(0..[M:ITG4]NBLOC-1)) From OBJDIV
If mkstat = 2 : End : Endif
End

