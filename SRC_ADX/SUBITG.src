########################################
# VACITM : Niveau de taxe
########################################
Subprog AS_VACITM(VALEUR)
Variable Char    VALEUR()
#MAE, bg71720, on enléve le test, si catégorie acheté ou vendu, le niveau de taxe doit être accessible
#If [M:ITG1]MFGFLG = 2 & [M:ITG1]SALFLG<2 mkstat = 2 Endif
End

Subprog C_VACITM(VALEUR)
Variable Char    VALEUR()
# fantôme non vendu : pas de controle
If [M:ITG1]PHAFLG = 2 & [M:ITG1]SALFLG<2 End Endif
Local Integer TYP_OK
TYP_OK = 1
# "le 1er niveau doit correspondre à une taxe de type TVA"
# If indice = 0 & VALEUR = "" : mkstat=2 : Endif # PAS OBLIGATOIRE dans ITG !
If indice = 0 & VALEUR <> ""
   If clalev([F:TVC])=0 : Local File TABVAC [TVC] : Endif
# recherche de tous les régimes combinés à ce niveau de taxe
   For [TVC] Where VACITM = VALEUR
       If [F:TVC]VATTYP<>1  TYP_OK=0 : Break  Endif
   Next
If TYP_OK = 0 : mkstat=2 : GMESSAGE = mess(133,199,1) : Endif
Endif
End

