######################################################################################
## Section automatically added (screen ITG2) 07/10/2015 13:07:40 (RICAR)
######################################################################################
Subprog AM_INVPRODTYP(VALEUR)
Variable Integer VALEUR

#104427 RICAR 2015/01/14 - Inventory - BEGIN
Local Integer ANSWER          : [L]ANSWER     = 1
#POR: O artigo foi definido como $1$ e o tipo de inventário foi definido como $2$. Pretende continuar?
#ENG: The product was set to $ 1 $ and the type of inventory is defined as $ 2 $. Want to continue?
Local Char    QUESTION0(255)  : [L]QUESTION0  = ''


Case VALEUR
  When 1
    If [M:ITG1]MFGFLG=2
      [L]QUESTION0 = func AFNC.MES2(mess(171,7711,1),mess(2,222,1),mess(VALEUR,2051,1))
      Gosub QST
    Endif
  When 2
    If [M:ITG1]MFGFLG=2 | [M:ITG1]SALFLG=2
      [L]QUESTION0 = func AFNC.MES2(mess(171,7711,1),mess(2,222,1)-mess(56,0,1)-mess(2,853,1),mess(VALEUR,2051,1))
      Gosub QST
    Endif
  When 3
    If [M:ITG1]PURFLG=2
      [L]QUESTION0 = func AFNC.MES2(mess(171,7711,1),mess(1,222,1),mess(VALEUR,2051,1))
      Gosub QST
    Endif
  When 4
    If [M:ITG1]PURFLG=2
      [L]QUESTION0 = func AFNC.MES2(mess(171,7711,1),mess(1,222,1),mess(VALEUR,2051,1))
      Gosub QST
    Endif
  When 5
    If [M:ITG1]PURFLG=2 | [M:ITG1]SALFLG=2
      [L]QUESTION0 = func AFNC.MES2(mess(171,7711,1),mess(1,222,1)-mess(56,0,1)-mess(2,853,1),mess(VALEUR,2051,1))
      Gosub QST
    Endif
Endcase
#104427 RICAR 2015/01/14 - Inventory - END

End

#--- Jira X3-50162
Subprog AS_DEFLOCTYP(VALEUR)
Variable Char    VALEUR()
If [M:ITG2]LOCMGTCOD=1 | [M:ITG0]STOFCY=""                                # hcb X3-58069
  mkstat=2
Endif
End

Subprog C_DEFLOCTYP(VALEUR)
Variable Char    VALEUR()

If VALEUR = "" : End : Endif
VALEUR = toupper(VALEUR)

If instr(1,VALEUR,"?") | instr(1,VALEUR,"#") | instr(1,VALEUR,"!") : End : Endif
# Si joker, controle de format seulement
If instr(1,VALEUR,"*")
   J = instr(1,VALEUR,"*")
   If J > 0 & mid$(VALEUR,J+1,len(VALEUR)-J) <> ""
      mkstat = 2
      # "Le joker(*) ne doit pas être suivi de caractère"
      GMESSAGE = mess(15,196,1)
      End
   Endif
Else
   Call CONTROLE("TLO","!",VALEUR,[M:ITG0]STOFCY,mkstat) From CONTOBJ
Endif
End

Subprog AS_DEFLOC(VALEUR)
Variable Char    VALEUR()
If [M:ITG2]LOCMGTCOD=1 | [M:ITG0]STOFCY=""
  mkstat=2
Endif
End

Subprog C_DEFLOC(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
## > contrôler que la chaine contient que des lettres ou des caractères
##  interprétable par l'instruction pat : * # ? !  (type de donnée ?)
For I=1 To len(VALEUR)
  If !instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789*#!?",seg$(VALEUR,I,I))
    mkstat = 2 : GMESSAGE = mess(149,100,1) # format incorrect
    Break
  Endif
Next
If mkstat | VALEUR="" End Endif
Read [STC]STC0=[M:ITG0]STOFCY;VALEUR
If !fstat
 # L'emplacement correspond-il au type d'emplacement ?
   Local Integer WY
   WY = nolign-1
   If dim(AMSTOFCY) > 0
      WY = AMSTOFCY
   Endif
   If !pat([F:STC]LOCTYP,[M]DEFLOCTYP(WY))
  mkstat=2 : GMESSAGE = mess(68,184,1) : End
 Endif
Else
  If !instr(1,VALEUR,"*") & !instr(1,VALEUR,"?")
&  & !instr(1,VALEUR,"#") & !instr(1,VALEUR,"!")
   mkstat = 2
   GMESSAGE = mess(23,100,1) # "Fiche inexistante"
  Endif
Endif
End
#--- End Jira X3-50162

