VALEUR = [M:ITG3]STU
End

Subprog C_PUU(VALEUR)
Variable Char     VALEUR
If [M:ITG1]MFGFLG <> 2  & [M:ITG1]PHAFLG <> 2 & VALEUR = ""
 mkstat = 2
Endif
End

Subprog AM_PUU(VALEUR)
Variable Char    VALEUR()
Call MODUNIT(VALEUR,[M:ITG3]STU,[M:ITG3]PUUSTUCOE) From SUBITM
Affzo [M:ITG3]PUUSTUCOE
# Issue 70985 - 2012-05-30 by MUARN : landed cost ajout UA sur onglet achat/vente
If VALEUR <> [M:ITG3]PUU & [M:ITG3]PUU <> "" &
& ([M:ITG6]CPRCOE <> 1 | [M:ITG6]CPRAMT<>0 | [M:ITG6]STCNUM<> "") & !GIMPORT
  GMESSAGE = mess(595,199,1) : GERR=2 # "vérifiez les frais d'approche"
Endif
[M:ITG6]ITMPUU = VALEUR
Affzo [M:ITG6]1-99
End

