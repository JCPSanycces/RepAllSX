######################################################################################
Subprog AM_PCKFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
   Effzo [M:ITG2]PCK
   Effzo [M:ITG2]PCKCAP
   Effzo [M:ITG2]PCKSTKFLG
   Grizo [M:ITG2]PCK
   Grizo [M:ITG2]PCKCAP
   Grizo [M:ITG2]PCKSTKFLG
Else
   Actzo [M:ITG2]PCK
   Actzo [M:ITG2]PCKCAP
   Actzo [M:ITG2]PCKSTKFLG
   If [M:ITG2]STOMGTCOD < 2
      Grizo [M:ITG2]PCKSTKFLG
   Endif
Endif

End

######################################################################################
#                                                                  # hcb 71276 deb
Subprog AP_STOMGTCOD(VALEUR)
Variable Integer VALEUR
If dim([M:ITG2]ECCFLG)>0
   If VALEUR = 1
      Raz   [M:ITG2]ECCFLG
      Raz   [M:ITG2]ECCSTO
      Raz   [M:ITG2]ECCMIN
      Raz   [M:ITG2]ECCMAJ
      Raz   [M:ITG6]LOAECCFLG
      Affzo [M:ITG2]ECCFLG
      Affzo [M:ITG2]ECCSTO
      Affzo [M:ITG2]ECCMIN
      Affzo [M:ITG2]ECCMAJ
      Affzo [M:ITG6]LOAECCFLG
      Diszo [M:ITG2]ECCFLG
      Diszo [M:ITG2]ECCSTO
      Diszo [M:ITG2]ECCMIN
      Diszo [M:ITG2]ECCMAJ
      Diszo [M:ITG6]LOAECCFLG
   Else
      If dim([ITG2]LOTMGTCOD) > 0 & [ITG2]LOTMGTCOD > 1
         Actzo [M:ITG2]ECCFLG
      Endif
   Endif
Endif

End

Subprog AP_LOTMGTCOD(VALEUR)
Variable Integer VALEUR
If dim([M:ITG2]ECCFLG)>0
   If VALEUR < 3
      Actzo [M:ITG2]ECCFLG
      [M:ITG2]ECCSTO = 1
      [M:ITG6]LOAECCFLG = 1
      Diszo [M:ITG6]LOAECCFLG

      Diszo [M:ITG2]ECCSTO
      Affzo [M:ITG2]ECCSTO
      Actzo [M:ITG2]ECCMIN
      Actzo [M:ITG2]ECCMAJ
   Elsif VALEUR = 2
      Raz   [M:ITG2]ECCFLG
      Raz   [M:ITG2]ECCSTO
      Raz   [M:ITG2]ECCMIN
      Raz   [M:ITG2]ECCMAJ
      Raz   [M:ITG6]LOAECCFLG
      Affzo [M:ITG2]ECCFLG
      Affzo [M:ITG2]ECCSTO
      Affzo [M:ITG2]ECCMIN
      Affzo [M:ITG2]ECCMAJ
      Affzo [M:ITG6]LOAECCFLG
      Diszo [M:ITG2]ECCFLG
      Diszo [M:ITG2]ECCSTO
      Diszo [M:ITG2]ECCMIN
      Diszo [M:ITG2]ECCMAJ
      Diszo [M:ITG6]LOAECCFLG
   Else
      Actzo [M:ITG2]ECCFLG
      If [M:ITG2]ECCFLG = 2
         Actzo [M:ITG2]ECCSTO
         Actzo [M:ITG6]LOAECCFLG
      Endif
   Endif
Endif

End

Subprog AP_ECCFLG(VALEUR)
Variable Integer VALEUR
   If VALEUR = 1
      Raz   [M:ITG2]ECCSTO
      Raz   [M:ITG2]ECCMIN
      Raz   [M:ITG2]ECCMAJ
      Raz   [M:ITG6]LOAECCFLG
      Affzo [M:ITG2]ECCSTO
      Affzo [M:ITG2]ECCMIN
      Affzo [M:ITG2]ECCMAJ
      Affzo [M:ITG6]LOAECCFLG
      Diszo [M:ITG2]ECCSTO
      Diszo [M:ITG2]ECCMIN
      Diszo [M:ITG2]ECCMAJ
      Diszo [M:ITG6]LOAECCFLG
   Else
      If [M:ITG2]LOTMGTCOD < 3
         [M:ITG2]ECCSTO    = 1
         [M:ITG6]LOAECCFLG = 1
         Affzo [M:ITG2]ECCSTO
         Diszo [M:ITG2]ECCSTO
         Diszo [M:ITG6]LOAECCFLG
         Actzo [M:ITG2]ECCMIN
         Actzo [M:ITG2]ECCMAJ
      Else
         Actzo [M:ITG2]ECCSTO
         Actzo [M:ITG2]ECCMIN
         Actzo [M:ITG2]ECCMAJ
      Endif
   Endif
End


Subprog AP_ECCSTO(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
   Actzo [M:ITG2]ECCMIN
   Actzo [M:ITG2]ECCMAJ
   Raz   [M:ITG6]LOAECCFLG
   Affzo [M:ITG6]LOAECCFLG
   Diszo [M:ITG6]LOAECCFLG
Elsif VALEUR = 2
   Raz   [M:ITG2]ECCMIN
   Affzo [M:ITG2]ECCMIN
   Diszo [M:ITG2]ECCMIN
   Actzo [M:ITG2]ECCMAJ
   Actzo [M:ITG6]LOAECCFLG
Else  VALEUR = 3
   Actzo [M:ITG2]ECCMAJ
   Actzo [M:ITG2]ECCMIN
   Actzo [M:ITG6]LOAECCFLG
Endif
End

Subprog C_ECCMIN(VALEUR)
Variable Char    VALEUR()
If [M:ITG2]ECCSTO = 3 & VALEUR = ""
   GMESSAGE = mess(10,123,1)   : # Zone obligatoire
   mkstat = 2
   End
Endif

End
