Endif
End

########################################
# REOCOD : Type suggestion
########################################
Subprog AS_REOCOD(VALEUR)
Variable Integer VALEUR

GMENLOC(2) = 1
GMENLOC(3) = 1
GMENLOC(5) = 1

If [M:ITG1]PURFLG = 2 |  [M:ITG1]SCPFLG = 2 | [M:ITG1]SCSFLG = 2 | [M:ITG1]GENFLG = 2 | [M:ITG1]TOOFLG = 2
   GMENLOC(2) = 0
   GMENLOC(5) = 0
Endif
If [M:ITG1]MFGFLG = 2 |  [M:ITG1]PHAFLG = 2
   GMENLOC(3) = 0
Endif

End

Subprog AM_REOCOD(VALEUR)
Variable Integer VALEUR
If find(VALEUR,1,2,3)
  Effzo [ITG7]REOFCY
  Grizo [ITG7]REOFCY
Else
  Actzo [ITG7]REOFCY
Endif
End

