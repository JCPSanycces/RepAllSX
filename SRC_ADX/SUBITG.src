# Issue 112878 - 2015-12-10 by MAE : mise à 2 de rcpflg
If VALEUR = 2
  [M:ITG6]RCPFLG = 2
  Affzo [M:ITG6]RCPFLG
Endif
Gosub TRT_TYP
End

End

