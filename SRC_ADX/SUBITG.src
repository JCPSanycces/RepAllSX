Subprog AM_BASPRIORI(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  [M:ITG6]PURPRIPRC = 0
  Affzo [M:ITG6]PURPRIPRC
  Diszo [M:ITG6]PURPRIPRC
Else
  Actzo [M:ITG6]PURPRIPRC
Endif

End


################################################################################################
################################################################################################
## Etiquette ajoutée par le superviseur (écran ITG6) 16/05/2013 16:38:58 (MUARN)
## Issue 84130 - 2013-05-17 by MUARN : landed cost - coeff/cout fixe unitaire/structure de coût
################################################################################################
Subprog AM_CPRCOE(VALEUR)
Variable Decimal VALEUR
Local Integer OK: OK=1
If [M:ITG6]STCNUM <> "" & !GIMPORT
  Call OUINON(mess(601,199,1), OK) From GESECRAN # "une SDC est paramétrée"
  If OK=1
    VALEUR = 1
  Else
    [M:ITG6]STCNUM = ""
    Affzo [ITG6]STCNUM
  Endif
Endif
End

Subprog AM_CPRAMT(VALEUR)
Variable Decimal VALEUR
Local Integer OK : OK=1
If [M:ITG6]STCNUM <> "" & !GIMPORT
  Call OUINON(mess(601,199,1), OK) From GESECRAN # "une SDC est paramétrée"
  If OK = 1
    VALEUR = 0
  Else
    [M:ITG6]STCNUM=""
    Affzo [ITG6]STCNUM
  Endif
Endif
End

Subprog C_STCNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer LRET
If VALEUR <>""
  If [F:STCH]STCNUM<> VALEUR
    Read [STCH]STCH0=VALEUR
    If fstat GMESSAGE=mess(1119,196,1) : mkstat=2 : Endif
  Endif
  If !mkstat & [F:STCH]ENAFLG = 1
    GMESSAGE=mess(2,126,1)
    mkstat=2
  Endif
Endif
End

Subprog AM_STCNUM(VALEUR)
Variable Char    VALEUR()
Local Integer OK : OK=1
If ([M:ITG6]CPRAMT<> 0 | [M:ITG6]CPRCOE <> 1) & !GIMPORT
  Call OUINON(mess(602,199,1), OK) From GESECRAN  # "un coeff ou coût est paramétré"
  If OK=1
    VALEUR =""
  Else
    [M:ITG6]CPRCOE = 1 : [M:ITG6]CPRAMT = 0
    Affzo [ITG6]CPRCOE, CPRAMT
  Endif
Endif
End
