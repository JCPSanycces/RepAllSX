# REOMINQTY : Lot économique
########################################
Subprog C_REOMINQTY(VALEUR)
Variable Decimal VALEUR
# lignes suivantes en commentaires suivant la demande  24033
# Politique de réappro : Qté mini avec ou sans arrondi
#If [M:ITG7]REOPOL <> "" & [F:TRP]REOQTYCOD > 1 & VALEUR = 0
#   mkstat = 2
#   GMESSAGE = mess(275,199,1)
#Endif
End

########################################
# MFGLOTQTY : Lot technique
########################################
Subprog C_MFGLOTQTY(VALEUR)
Variable Decimal VALEUR
Local Integer WLOT
If VALEUR <> 0
  WLOT = [M:ITG7]REOMINQTY / VALEUR
  If mod([M:ITG7]REOMINQTY,VALEUR) <> 0
    mkstat = 2
    GMESSAGE = mess(219,199,1)
  Endif
Else
  VALEUR = [M:ITG7]REOMINQTY
Endif
End

##########################################################################
# VLTCOD / Mode de valorisation
##########################################################################
Subprog C_VLTCOD(VALEUR)
Variable Char     VALEUR

If !clalev([F:ITV]) : Local File ITMMVT      [ITV] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER   [ITM] : Endif
If !clalev([F:ITF]) : Local File ITMFACILIT  [ITF] : Endif
If !clalev([F:TCM]) : Local File TABCOSTMET  [TCM] : Endif
If !clalev([F:TCM2]): Local File TABCOSTMET [TCM2] : Endif
Local Char WTCM(GLONTCM)
Local Integer WRET

If [M:ITG2]STOMGTCOD>1 & VALEUR=""
  mkstat=2 : GMESSAGE = mess(10,123,1)
Endif

#MJH X3-103951.sn
#If not stock managed, only allow standard or revised standard cost
If [F:TCM]VLTCOD<>VALEUR
  Read [TCM]TCM0 = VALEUR
  If fstat
    mkstat=2
    End
  Endif
Endif

If [M:ITG2]STOMGTCOD=1 & VALEUR <> ""
  If !find([F:TCM]ISSVLTCOD,1,2)
    GMESSAGE = mess(237,184,1)
    mkstat = 2
    End
  Endif
Endif
#X3-103951.en

If [M:ITG0]STOFCY<>""
    # Issue 71747 - 2011-02-22 by CCC : autoriser FIFO
    # Issue 66829 - 2010-08-23 by CCC : On ne teste pas la législation FRA mais le paramètre FRADGI
    # Issue 63706 - 2010-06-08 by CCC : seuls Std, std act, pmp et pm lot sont autorisés en législation française
    Call GETSOC([M:ITG0]STOFCY) From DEVSUB
    If func AFNC.PARAM("FRADGI",GSOCIETE)="2"
        If !find([F:TCM]ISSVLTCOD,1,2,4,5,6)
            mkstat=2
            GMESSAGE=mess(372,184,1)
        Endif
    Endif
Endif

# Issue 82144 - 2012-06-29 by CCC
If !find(GREP,"C","D") & VALEUR<>[M:ITG5]VLTCOD
    Raz [F:TCM], [F:TCM2]
    If [F:ITG]TCLCOD<>[M:ITG0]TCLCOD | [F:ITG]STOFCY<>[M:ITG0]STOFCY
        Read [ITG]ITG0=[M:ITG0]TCLCOD;[M:ITG0]STOFCY
    Endif
    Read [TCM]TCM0=[F:ITG]VLTCOD
    Read [TCM2]TCM0=VALEUR
    If [F:TCM]ISSVLTCOD<>[F:TCM2]ISSVLTCOD
        #Recherche des articles-sites avec du stock et sans méthode de valo sur la fiche article-site
        Link [F:ITF] With [ITM]ITM0~=[F:ITF]ITMREF,
&                         [ITV]ITV0~=[F:ITF]ITMREF;[F:ITF]STOFCY
&                    As [LNK]
&                    Where [ITF]VLTCOD=""
&                        & [ITM]TCLCOD=[M:ITG0]TCLCOD
&                        & ([M:ITG0]STOFCY="" | [F:ITF]STOFCY=[M:ITG0]STOFCY)
&                        & [ITV]AVCBASQTY<>0
        For [LNK]
            # Pour chaque article-site trouvé : erreur sauf...
            If [M:ITG0]STOFCY=""
                # ... si la catégorie est déclinée pour le site
                Look [F:ITG]ITG0=[M:ITG0]TCLCOD;[F:ITF]STOFCY
                If !fstat
                    Goto NEXT_ITF
                Endif
            Endif
            GERR = 3
            GMESSAGE = mess(596,199,1)+chr$(13)+mess(597,199,1)-":"-[F:ITF]ITMREF
            $NEXT_ITF
        Next
    Endif
Endif

End

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran ITG5) 09/09/2005 14:47:03 (CCC)
######################################################################################
Subprog AS_OTRSTYP(VALEUR)
Variable Integer VALEUR

Local Integer I,J, LTYP
For I=1 To len(mess(0,704,1))
    LTYP = ([M:ITG1]MFGFLG=2)
&         +([M:ITG1]PURFLG=2)*2
&         +([M:ITG1]SCPFLG=2)*4
&         +([M:ITG1]SCSFLG=2)*8    # Type de flux autorisé sur la catégorie
    If !func STKVALPAR.WITHOVE(I,LTYP)    # Vérifie que le type de mouvement gère les FG
        GMENLOC(I) = 1
    Else
        J = find(I,[M:ITG5]OTRSTYP)
        If J>0 & J<>nolign
            GMENLOC(I) = 1
        Endif
    Endif
Next
End

######################################################################################
Subprog C_OVECOD(VALEUR)
Variable Char    VALEUR()
    If !clalev([F:OVE]) : Local File OVERHEAD [OVE] : Endif
    Read [OVE]OVE0=VALEUR
    # "La devise des frais généraux est différente de celle du site"
    If [M:ITG0]STOFCY<>""
        If [F:OVE]CUR <> GLOCALDEV & [F:OVE]CUR <> ""
            mkstat = 2
            GMESSAGE = mess(204,199,1)
        Endif
    Endif
    If [F:OVE]OVECOD<>VALEUR
        Read [OVE]OVE0=VALEUR
    Endif
    If [F:OVE]CLCLEV <> abs(func STKLIB.SENSTRS([M:ITG5]OTRSTYP(nolign-1)))
        GMESSAGE = mess(246,184,1)
        mkstat = 2
    Endif
    If !func STKVALPAR.WITHOVEORI([M:ITG5]OTRSTYP(nolign-1)) & !find(1,[F:OVE]VCRTRG)
        GMESSAGE = mess(258,184,1)
        mkstat = 2
    Endif
End

