#CHECK UNUSED_SOURCE
##########################################################################################################
#   Articles pour horodatage                                             Module CRM        4 juin 2003
##########################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "ENR"          : Gosub ENREG
 When "ABANDON"      : Gosub ABANDON

# When "AV_CHOIX"     : Gosub AV_CHOIX
# When "AP_CHOIX"     : Gosub AP_CHOIX
# When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "APRES_MODIF"  : Gosub APRES_MODIF
# When "BOUTON"       : Gosub BOUTON
# When "MEN"          : Gosub ONMENU
# When "OK"           : Gosub ONOK
 When Default
Endcase
Return

##########################################################################################################
$OUVRE
If !clalev([F:HOI]) : Local File HOROITM [HOI] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : ENDIF
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : ENDIF
If !clalev([F:PBL]) : Local File FAMPB [PBL] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
If [M:HOI1]DIRTY
    ETABOU(GVALI) = 1
Else
    ETABOU(GVALI) = 0
Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT

#Définition articles supports aux horodatages
[M:HOI1]TIT = mess(204, 182, 2)

Gosub LOAD_HOI
Affzo [M:HOI1]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
#Nettoie l'écran avant de partir.
Raz [M:HOI1]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Gosub LOAD_HOI
REP=""
Affzo [M:HOI1]1-99

Return

##########################################################################################################
$APRES_MODIF
#[M:HOI1]DIRTY = 1
REP="M"
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ENREG

Local Integer IBERROR
IBERROR=0
Local Integer ILIGNE
ILIGNE=0

Call DEBTRANS From GLOCK
Trbegin [HOI]
Delete [HOI] Where [F:HOI]ITMREF <> ""
If fstat<>0
    #Erreur lors de l'enregistrement des articles pour horodatages.
    GMESSAGE = mess(205, 182, 2)
    IBERROR=1
Endif

While (ILIGNE<[M:HOI1]NBITM) and IBERROR=0
    If [M:HOI1]ITMREF(ILIGNE) <> ""
        [F:HOI]MACNUM = [M:HOI1]MACNUM(ILIGNE)
        [F:HOI]PBLNUM = [M:HOI1]PBLNUM(ILIGNE)
        [F:HOI]AUSNUM = [M:HOI1]AUSNUM(ILIGNE)
        [F:HOI]ITMREF = [M:HOI1]ITMREF(ILIGNE)
        Write [HOI]
        If fstat<>0
            #Erreur lors de l'enregistrement des articles pour horodatages.
            GMESSAGE = mess(205, 182, 2)
            IBERROR=1
            Break
        Endif
    Endif
    ILIGNE= ILIGNE+1
Wend

If IBERROR=1
    Rollback
    GOK=0
    GERR=1
Else
    Commit
    Gosub LOAD_HOI
    REP=""
Endif
Affzo [M:HOI1]1-99
Return

##########################################################################################################
$LOAD_HOI

Local Integer ILIGNE
ILIGNE=0

#Raz [M:HOI1]NBITM
#Raz [M:HOI1]MACNUM
#Raz [M:HOI1]PBLNUM
#Raz [M:HOI1]AUSNUM
#Raz [M:HOI1]ITMREF
Effzo [M:HOI1]10
[M:HOI1]NBITM=0
Filter [HOI] Where [F:HOI]ITMREF <> ""
&         Order By [F:HOI]MACNUM Asc; [F:HOI]PBLNUM Asc; [F:HOI]AUSNUM Asc; [F:HOI]ITMREF Asc

For [HOI]
    If ILIGNE>= dim([M:HOI1]MACNUM) : Break : Endif

    [M:HOI1]MACNUM(ILIGNE) = [F:HOI]MACNUM
    [M:HOI1]PBLNUM(ILIGNE) = [F:HOI]PBLNUM
    [M:HOI1]AUSNUM(ILIGNE) = [F:HOI]AUSNUM
    [M:HOI1]ITMREF(ILIGNE) = [F:HOI]ITMREF

#    If [M:HOI1]PBLNUM(ITER) = ""
#        [M:HOI1]PBLCLA(ITER) = ""
#    Else
#        Read [PBL] PBL0 = [M:HOI1]PBLNUM(ITER)
#        If fstat
#            [M:HOI1]PBLCLA(ITER) = ""
#        Else
#            [M:HOI1]PBLCLA(ITER) = [F:PBL]GRPPBLDES
#        Endif
#    Endif

    ILIGNE = ILIGNE+1
Next

Filter [HOI]

[M:HOI1]NBITM = ILIGNE

Return


