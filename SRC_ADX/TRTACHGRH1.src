#<AdxTL>@(#)8.0.0.0 $Revision$
##############################################################################
# TRTACHGRH1          Traitements des graphiques                Module ACHAT #
# -------------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                       #
#   - TRTGRHPO   : Consultation commandes par période (saisie des critères)  #
#   - VISUGRHPO1 : Visualisation Total HT commande par période               #
#   - VISUGRHPO2 : Visualisation Décomposition HT commande par période       #
#                                                                            #
#   - TRTGRHPR   : Consultation réceptions par période (saisie des critères) #
#   - VISUGRHPR1 : Visualisation réceptions facturées  par période           #
#   - VISUGRHPR2 : Visualisation réceptions retournées par période           #
#                                                                            #
#   - TRTGRHPN   : Consultation retours par période (saisie des critères)    #
#   - VISUGRHPN1 : Visualisation retours renplacement-définitif par période  #
#   - VISUGRHPN2 : Visualisation retours et avoirs par période               #
#   - TRTGRHPN2  : Palmarès retours (saisie des critères)                    #
#   - VISUGRHPN3 : Visualisation palmarès motifs retours                     #
#   - VISUGRHPN4 : Visualisation palmarès retours fournisseurs               #
#                                                                            #
#   - TRTGRHPI   : Consultation factures par période (saisie des critères)   #
#   - VISUGRHPI1 : Visualisation types factures/avoirs par période           #
#   - VISUGRHPI2 : Visualisation factures réglées/non réglées par période    #
#   - TRTGRHPI2  : Palmarès factures (saisie des critères)                   #
#   - VISUGRHPI3 : Visualisation palmarès attentes d'avoir fournisseurs      #
#   - VISUGRHPI4 : Visualisation palmarès bon à payer                        #
##############################################################################


$ACTION
Case ACTION
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Case GACTION
   When "TRTGRHPO"   : Gosub OUV_TRTGRHPO
   When "VISUGRHPO1" : Gosub OUV_VISUGRHPO
   When "VISUGRHPO2" : Gosub OUV_VISUGRHPO
   When "TRTGRHPR"   : Gosub OUV_TRTGRHPR
   When "VISUGRHPR1" : Gosub OUV_VISUGRHPR
   When "VISUGRHPR2" : Gosub OUV_VISUGRHPR
   When "TRTGRHPN"   : Gosub OUV_TRTGRHPN
   When "VISUGRHPN1" : Gosub OUV_VISUGRHPN
   When "VISUGRHPN2" : Gosub OUV_VISUGRHPN
   When "TRTGRHPN2"  : Gosub OUV_TRTGRHPN
   When "VISUGRHPN3" : Gosub OUV_VISUGRHPN
   When "VISUGRHPN4" : Gosub OUV_VISUGRHPN
   When "TRTGRHPI"   : Gosub OUV_TRTGRHPI
   When "VISUGRHPI1" : Gosub OUV_VISUGRHPI
   When "VISUGRHPI2" : Gosub OUV_VISUGRHPI
   When "TRTGRHPI2"  : Gosub OUV_TRTGRHPI
   When "VISUGRHPI3" : Gosub OUV_VISUGRHPI
   When "VISUGRHPI4" : Gosub OUV_VISUGRHPI
  Endcase
 When "TITRE"
  #-------------------------------------------#
  # Titre juste avant ouverture de la fenêtre #
  #-------------------------------------------#
  Case GACTION
   When "VISUGRHPO1" : TIT=mess(256,195,1) : # Commandes HT par période
   When "VISUGRHPO2" : TIT=mess(257,195,1) : # Décomposition HT commandes par période
   When "VISUGRHPR1" : TIT=mess(258,195,1) : # Réceptions et factures HT par période
   When "VISUGRHPR2" : TIT=mess(259,195,1) : # Réceptions et retours HT par période
   When "VISUGRHPN1" : TIT=mess(260,195,1) : # Types de retour HT par période
   When "VISUGRHPN2" : TIT=mess(261,195,1) : # Retours et avoirs HT par période
   When "VISUGRHPN3" : TIT=mess(266,195,1) : # Palmarès retours par motif
   When "VISUGRHPN4" : TIT=mess(267,195,1) : # Palmarès retours par fournisseur
   When "VISUGRHPI1" : TIT=mess(264,195,1) : # Types de facture HT par période
   When "VISUGRHPI2" : TIT=mess(265,195,1) : # Factures et règlements HT par période
   When "VISUGRHPI3" : TIT=mess(268,195,1) : # Palmarès avoirs attendus par fournisseur
   When "VISUGRHPI4" : TIT=mess(269,195,1) : # Palmarès factures non réglées par niveau BAP
  Endcase
  #-----
  #US 71069/138  by RBA
#  If clalev([M:CCPO]) & [M:CCPO]BPSNUMDEB<>""
#    TIT=TIT-mess(530,197,1)-[M:CCPO]BPSNUMDEB
#  Elsif clalev([M:CCPR]) & [M:CCPR]BPSNUM<>""
#    TIT=TIT-mess(530,197,1)-[M:CCPR]BPSNUM
#  Elsif clalev([M:CCPN]) & [M:CCPN]BPSNUM<>""
#    TIT=TIT-mess(530,197,1)-[M:CCPN]BPSNUM
#  Elsif clalev([M:CCPI]) & [M:CCPI]BPR<>""
#    TIT=TIT-mess(530,197,1)-[M:CCPI]BPR
#  Endif
  If clalev([M:CCPO]) & [M:CCPO]BPSNUMDEB<>""
    TIT=TIT-mess(530,197,1)-[M:CCPO]BPSNUMDEB
  Elsif clalev([M:CCPR]) & [M:CCPR]BPSNUMDEB<>""
    TIT=TIT-mess(530,197,1)-[M:CCPR]BPSNUMDEB
  Elsif clalev([M:CCPN]) & [M:CCPN]BPSNUMDEB<>""
    TIT=TIT-mess(530,197,1)-[M:CCPN]BPSNUMDEB
  Elsif clalev([M:CCPI]) & [M:CCPI]BPSNUMDEB<>""
    TIT=TIT-mess(530,197,1)-[M:CCPI]BPSNUMDEB
  Endif
#/US 71069/138  by RBA
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  Case GACTION
   When "TRTGRHPO"   : Gosub DEB_TRTGRHPO
   When "VISUGRHPO1" : Gosub DEB_VISUGRHPO
   When "VISUGRHPO2" : Gosub DEB_VISUGRHPO
   When "TRTGRHPR"   : Gosub DEB_TRTGRHPR
   When "VISUGRHPR1" : Gosub DEB_VISUGRHPR
   When "VISUGRHPR2" : Gosub DEB_VISUGRHPR
   When "TRTGRHPN"   : Gosub DEB_TRTGRHPN
   When "VISUGRHPN1" : Gosub DEB_VISUGRHPN
   When "VISUGRHPN2" : Gosub DEB_VISUGRHPN
   When "TRTGRHPN2"  : Gosub DEB_TRTGRHPN
   When "VISUGRHPN3" : Gosub DEB_VISUGRHPN
   When "VISUGRHPN4" : Gosub DEB_VISUGRHPN
   When "TRTGRHPI"   : Gosub DEB_TRTGRHPI
   When "VISUGRHPI1" : Gosub DEB_VISUGRHPI
   When "VISUGRHPI2" : Gosub DEB_VISUGRHPI
   When "TRTGRHPI2"  : Gosub DEB_TRTGRHPI
   When "VISUGRHPI3" : Gosub DEB_VISUGRHPI
   When "VISUGRHPI4" : Gosub DEB_VISUGRHPI
  Endcase
 When "OK"
  #--------------------------------#
  # Après l'exécution du bouton OK #
  #--------------------------------#
  Case GACTION
  Endcase
 When "BOUTON"
  #-----------------------------------------------#
  # Après l'exécution d'un bouton ("R"=Recherche) #
  #-----------------------------------------------#
  If BOUT="R"
    Case GACTION
     When "VISUGRHPO1" : Gosub CHARGE_GRHPO1
     When "VISUGRHPO2" : Gosub CHARGE_GRHPO2
     When "VISUGRHPR1" : Gosub CHARGE_GRHPR1
     When "VISUGRHPR2" : Gosub CHARGE_GRHPR2
     When "VISUGRHPN1" : Gosub CHARGE_GRHPN1
     When "VISUGRHPN2" : Gosub CHARGE_GRHPN2
     When "VISUGRHPN3" : Gosub CHARGE_GRHPN3
     When "VISUGRHPN4" : Gosub CHARGE_GRHPN4
     When "VISUGRHPI1" : Gosub CHARGE_GRHPI1
     When "VISUGRHPI2" : Gosub CHARGE_GRHPI2
     When "VISUGRHPI3" : Gosub CHARGE_GRHPI3
     When "VISUGRHPI4" : Gosub CHARGE_GRHPI4
    Endcase
  Endif
 When "ABA"
  #-------------------------------------#
  # Après l'exécution du bouton ABANDON #
  #-------------------------------------#
  Case GACTION
  Endcase
 When "APRES_MODIF"
  #------------------------------------#
  # Après chaque modification de champ #
  #------------------------------------#
  Case GACTION
  Endcase
 When "FINSAI"
  #------------------------------------------#
  # Avant de revenir à la fenêtre précédente #
  #------------------------------------------#
  Case GACTION
   When "VISUGRHPO1" : Gosub FINSAI_VISUGRHPO
   When "VISUGRHPO2" : Gosub FINSAI_VISUGRHPO
   When "VISUGRHPR1" : Gosub FINSAI_VISUGRHPR
   When "VISUGRHPR2" : Gosub FINSAI_VISUGRHPR
   When "VISUGRHPN1" : Gosub FINSAI_VISUGRHPN
   When "VISUGRHPN2" : Gosub FINSAI_VISUGRHPN
   When "VISUGRHPN3" : Gosub FINSAI_VISUGRHPN
   When "VISUGRHPN4" : Gosub FINSAI_VISUGRHPN
   When "VISUGRHPI1" : Gosub FINSAI_VISUGRHPI
   When "VISUGRHPI2" : Gosub FINSAI_VISUGRHPI
   When "VISUGRHPI3" : Gosub FINSAI_VISUGRHPI
   When "VISUGRHPI4" : Gosub FINSAI_VISUGRHPI
  Endcase
Endcase
Return


####################################################################################
# TRTGRHPO : Consultation commandes par période (saisie des critères) MBT 18/12/06 #
# -------------------------------------------------------------------------------- #
# Paramètres                                                                       #
#  - PARAM(1) = BPRNUM : Fournisseur ("" par défaut)                               #
#  - PARAM(2) = FCY    : Site de commande  (GFCYDEF(6) par défaut)                 #
####################################################################################

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_TRTGRHPO
If !clalev([F:BPS])  Local File BPSUPPLIER [BPS] : Endif
If !clalev([F:FCY])  Local File FACILITY   [FCY] : Endif
# Issue 84130 - 2013-02-21 by MAE : ajout des charges achat
If !clalev([M:CST2]) Local Mask CSTLIN2 [CST2] : Endif
If !clalev([F:PFI])  Local File PFOOTINV [PFI]  : Endif
If !clalev([F:PVF])  Local File PVCRFOOT [PVF]  : Endif
If clalev([F:TCU])= 0 : Local File TABCUR [TCU] : Endif
#Fin MAE
Local Date    WDATDEB
Local Date    WDATFIN
Local Integer WPERCOD
Local Integer WPERNBR

Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_TRTGRHPO
Raz [M:CGPO]
If GNBAUZ=1 : PARAM(2)=GUSRFCY(1) : Endif
If PARAM(1)<>""
  If [F:BPS]BPSNUM<>PARAM(1)
    Read [BPS] BPS0=PARAM(1) : If fstat  Raz [F:BPS], PARAM(1) : Endif
  Endif
  [M:CGPO]BPSNUM=PARAM(1)
Endif
If PARAM(2)<>""
  If [F:FCY]FCY<>PARAM(2)
    Read [FCY] FCY0=PARAM(2) : If fstat  Raz [F:FCY], PARAM(2) : Endif
  Endif
  If (GUSRFCY(1)="\" | find(PARAM(2),GUSRFCY(1..GNBAUZ)))
    [M:CGPO]POHFCY=PARAM(2)
    Call GETDEV([M:CGPO]POHFCY) From DEVSUB
    [M:CGPO]CPY=GSOCIETE
    [M:CGPO]CUR=GLOCALDEV
  Endif
Endif
#-----
If !find([M:CGPO]CLEFLGO,1,2)  [M:CGPO]CLEFLGO=1 : Endif
If !find([M:CGPO]CLEFLGN,1,2)  [M:CGPO]CLEFLGN=2 : Endif
If !find([M:CGPO]APPFLGO,1,2)  [M:CGPO]APPFLGO=2 : Endif
If !find([M:CGPO]APPFLGN,1,2)  [M:CGPO]APPFLGN=2 : Endif
If !find([M:CGPO]RCPFLGO,1,2)  [M:CGPO]RCPFLGO=2 : Endif
If !find([M:CGPO]RCPFLGN,1,2)  [M:CGPO]RCPFLGN=2 : Endif
If !find([M:CGPO]INVFLGO,1,2)  [M:CGPO]INVFLGO=2 : Endif
If !find([M:CGPO]INVFLGN,1,2)  [M:CGPO]INVFLGN=2 : Endif
If !find([M:CGPO]PRNFLGO,1,2)  [M:CGPO]PRNFLGO=2 : Endif
If !find([M:CGPO]PRNFLGN,1,2)  [M:CGPO]PRNFLGN=2 : Endif
If !find([M:CGPO]TRI,1,2)      [M:CGPO]TRI=1     : Endif
#-----
[M:CGPO]PERCOD=4
[M:CGPO]PERNBR=3
#-----
Call LECMEMO("STD","[M:CGPO]","pmo") From GMEMO
#-----
Raz WDATDEB, WDATFIN
WPERCOD=[M:CGPO]PERCOD
WPERNBR=[M:CGPO]PERNBR
Gosub INIT_PERIODE
[M:CGPO]ORDDATDEB=WDATDEB
[M:CGPO]ORDDATFIN=WDATFIN
#-----
Affzo [CGPO]1-99
Return


####################################################################################
# Partie commune aux actions :                                        MBT 14/12/06 #
#   - VISUGRHPO1 : Visualisation Total HT commande par période                     #
#   - VISUGRHPO2 : Visualisation Décomposition HT commande par période             #
# -------------------------------------------------------------------------------- #
# Paramètre                                                                        #
#  - PARAM(1) = WABMSK : Abréviation du masque contenant les critères de sélection #
####################################################################################

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUGRHPO
Local Char     WABMSK(5)   : WABMSK   =PARAM(1)
Local Integer  SAVNOLIGN   : SAVNOLIGN=nolign
Local Integer  CHGPAG      : CHGPAG   =1
Local Integer  WOK
Local Char     WPROGSPE(GLONADC)
Local Char     WFIL (250)
Local Char     WFIL1(250)
Local Char     WFIL2(250)
Local Date     SAVDATDEB
Local Date     SAVDATFIN
Local Date     WDATDEB
Local Date     WDATFIN
Local Integer  WPERCOD
Local Integer  WPERNBR
#-----
If !clalev([F:POH])  Local File PORDER  [POH] : Endif
If !clalev([F:POQ])  Local File PORDERQ [POQ] : Endif

# Issue 93530 - 2013-10-15 by MUARN : site ou société obligatoire
If evalue ("[M:" + WABMSK + "]CPY") = "" & evalue("[M:" + WABMSK + "]POHFCY") = "" & GACTION = "VISUGRHPO1"
  GERR = 1 : FIN = 1 : GMESSAGE=mess(9,109,1)
Endif

If WABMSK<>"CCPO"
  If !clalev([M:CPO1])  Local Mask CONSCPO1 [CPO1] : Endif
  If !clalev([M:CCPO])  Local Mask CRITCPO  [CCPO] : Endif
  [M:CCPO]CPY      =evalue("[M:"+WABMSK+"]CPY")
  [M:CCPO]CUR      =evalue("[M:"+WABMSK+"]CUR")
  [M:CCPO]POHFCY   =evalue("[M:"+WABMSK+"]POHFCY")
#US 71069/138  by RBA
#  [M:CCPO]BPSNUMDEB=evalue("[M:"+WABMSK+"]BPSNUM")
#  [M:CCPO]BPSNUMFIN=evalue("[M:"+WABMSK+"]BPSNUM")
  [M:CCPO]BPSNUMDEB=evalue("[M:"+WABMSK+"]BPSNUM")
  [M:CCPO]BPSNUMFIN=evalue("[M:"+WABMSK+"]BPSNUM")
#/US 71069/138  by RBA
  [M:CCPO]POHNUMDEB=evalue("[M:"+WABMSK+"]POHNUMDEB")
  [M:CCPO]POHNUMFIN=evalue("[M:"+WABMSK+"]POHNUMFIN")
  [M:CCPO]ORDDATDEB=evalue("[M:"+WABMSK+"]ORDDATDEB")
  [M:CCPO]ORDDATFIN=evalue("[M:"+WABMSK+"]ORDDATFIN")
  [M:CCPO]CLEFLGO  =evalue("[M:"+WABMSK+"]CLEFLGO")
  [M:CCPO]APPFLGO  =evalue("[M:"+WABMSK+"]APPFLGO")
  [M:CCPO]RCPFLGO  =evalue("[M:"+WABMSK+"]RCPFLGO")
  [M:CCPO]CLEFLGN  =evalue("[M:"+WABMSK+"]CLEFLGN")
  [M:CCPO]APPFLGN  =evalue("[M:"+WABMSK+"]APPFLGN")
  [M:CCPO]RCPFLGN  =evalue("[M:"+WABMSK+"]RCPFLGN")
  [M:CCPO]INVFLGO  =evalue("[M:"+WABMSK+"]INVFLGO")
  [M:CCPO]PRNFLGO  =evalue("[M:"+WABMSK+"]PRNFLGO")
  [M:CCPO]INVFLGN  =evalue("[M:"+WABMSK+"]INVFLGN")
  [M:CCPO]PRNFLGN  =evalue("[M:"+WABMSK+"]PRNFLGN")
  Gosub ENTCRIT From WWCNSCPO
  SAVDATDEB=[M:CCPO]ORDDATDEB
  SAVDATFIN=[M:CCPO]ORDDATFIN
  WPERCOD=evalue("[M:"+WABMSK+"]PERCOD")
  WPERNBR=evalue("[M:"+WABMSK+"]PERNBR")
Else
  Gosub CRITENT From WWCNSCPO
  SAVDATDEB=[M:CCPO]ORDDATDEB
  SAVDATFIN=[M:CCPO]ORDDATFIN
  WDATDEB  =[M:CCPO]ORDDATDEB
  WDATFIN  =[M:CCPO]ORDDATFIN
  WPERCOD  =4
  WPERNBR  =3
  Gosub INIT_PERIODE
  [M:CCPO]ORDDATDEB=WDATDEB
  [M:CCPO]ORDDATFIN=WDATFIN
Endif
# Issue 84130 - 2013-01-31 by MAE : Déclaration des variables pour les requetes
Local Char REQUETE(255)(3)
Local Integer BASE
Local Char REQUETECPR(255)(3)
Local Integer LRET

Case GTYPDBA
    When 1 : BASE=3 : # Oracle
    When 2 : BASE=5 : # Sql
    When 3 : BASE=2 : # Cisam
    When 4 : BASE=4 : # DB2
  Endcase
#fin MAE 84130

Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUGRHPO
Case GACTION
  When "VISUGRHPO1" : Raz [M:GPO1]
  When "VISUGRHPO2" : Raz [M:GPO2]
Endcase
#----- Chargement de la périodicité et de la devise -----#
[M]PERCOD=WPERCOD
[M]PERNBR=WPERNBR
[M]DATDEB=[M:CCPO]ORDDATDEB
[M]DATFIN=[M:CCPO]ORDDATFIN
[M]CUR   =[M:CCPO]CUR
Affzo 5
#----- Récupération du nom du traitement spécifique -----#
If !clalev([F:ACN])  Local File ACONSULT [ACN] : Endif
Read [ACN] ACN0="CPO" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif
#----- Positionnement des filtres -----#
Gosub LOAD_FILTER From CNSCPOSTD
If WPROGSPE<>""
  ACTION="FILTRE" : Gosub ACTION From =WPROGSPE
Endif
[M]WFIL =WFIL
[M]WFIL1=WFIL1
[M]WFIL2=WFIL2
#----- Chargement du tableau -----#
Case GACTION
  When "VISUGRHPO1" : Gosub CHARGE_GRHPO1
  When "VISUGRHPO2" : Gosub CHARGE_GRHPO2
Endcase
Return

#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUGRHPO
nolign=SAVNOLIGN
[M:CCPO]ORDDATDEB=SAVDATDEB
[M:CCPO]ORDDATFIN=SAVDATFIN
Return

#----------------------------------------------------------------------#
# Chargement du tableau pour le graphe "Total HT commande par période" #
#----------------------------------------------------------------------#
$CHARGE_GRHPO1
#----- Déclaration des variables locales -----#
Gosub DECLARE_VARIABLES
#-----
WPERCOD=[M:GPO1]PERCOD
Effzo [GPO1]10
Raz [M:GPO1]NBLIG
#-----
For [POH] Where evalue([M:GPO1]WFIL)
&             & evalue([M:GPO1]WFIL1)
&             & evalue([M:GPO1]WFIL2)
&         With Nohint
  #----- Filtre sur société si nécessaire -----#
  If [M:CPO1]CPY<>"" & [M:CPO1]POHFCY=""
    If [F:FCY]FCY<>[F:POH]POHFCY
      Read [FCY] FCY0=[F:POH]POHFCY : If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY<>[M:CPO1]CPY  Goto SUIT_GRHPO1 : Endif
  Endif
  #-----
  # Issue 84130 - 2013-02-07 by MAE : requete pour sommer les charges achats de la commande
  #Calcul sur la somme des lignes de commande
  #Charges directes, coût achat, coût acaht réalisé, montant ligne hors taxes
  REQUETE(0) = "SELECT SUM(FCSCSTPUR_0)"
  #taxes non déductibles
  REQUETE(1)=
&
&
&
&
&
&
&
&
&
&
&
&
&
&
& 
& ",SUM((AMTTAXLIN1_0-DEDTAXLIN1_0)+(AMTTAXLIN2_0-DEDTAXLIN2_0)+(AMTTAXLIN3_0-DEDTAXLIN3_0)+(AMTTAXRCP_0-DEDTAXRCP_0)+(AMTTAXISS_0-DEDTAXISS_0)+(AMTTAXOTH1_0-DEDTAXOTH1_0)+(AMTTAXOTH2_0-DEDTAXOTH2_0))"
  REQUETE(2)=" from PORDERQ WHERE POHNUM_0='"+[F:POH]POHNUM+"'"

  For (Decimal WFCSCSTPUR,Decimal WNONDEDTAX) From num$(BASE) Sql REQUETE As [SPOQ]
    [M:GPO1]FCSCSTPUR= [SPOQ]WFCSCSTPUR
    WMNTDES(0) = 0
    Call CONVERT2([F:POH]CUR,[M:GPO1]CUR,[M:GPO1]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                 [SPOQ]WNONDEDTAX,WMNTDES(0),WKO) From TRTDEV
    [M:GPO1]NONDEDTAX =  arr(WMNTDES(0),[F:TCU]CURRND)
  Next

  #Calcul total coefficient d'approche sur les lignes en coeff d'approche
  REQUETECPR(0)="select SUM(LINCSTPUR_0-LINAMT_0-(DISCRGAMT1_0+DISCRGAMT2_0+DISCRGAMT3_0+DISCRGAMT4_0+DISCRGAMT5_0+DISCRGAMT6_0+DISCRGAMT7_0+DISCRGAMT8_0+DISCRGAMT9_0)"
  REQUETECPR(1)=
& "-((AMTTAXLIN1_0-DEDTAXLIN1_0)+(AMTTAXLIN2_0-DEDTAXLIN2_0)+(AMTTAXLIN3_0-DEDTAXLIN3_0)+(AMTTAXRCP_0-DEDTAXRCP_0)+(AMTTAXISS_0-DEDTAXISS_0)+(AMTTAXOTH1_0-DEDTAXOTH1_0)+(AMTTAXOTH2_0-DEDTAXOTH2_0)))"
  REQUETECPR(2)=" from PORDERQ WHERE POHNUM_0='"+[F:POH]POHNUM+"' and (CPRCOE_0<>1 or CPRAMT_0<>0)"

  For (Decimal WDISCGRAMT) From num$(BASE) Sql REQUETECPR As [SPCP]
    WMNTDES(0) = 0
    Call CONVERT2([F:POH]CUR,[M:GPO1]CUR,[M:GPO1]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                 [SPCP]WDISCGRAMT,WMNTDES(0),WKO) From TRTDEV
    [M:GPO1]TOTCOEFFAPP =  arr(WMNTDES(0),[F:TCU]CURRND)
  Next

#Lecture des factures complémentaires
For [POQ] Where [POQ]POHNUM = [F:POH]POHNUM
  Call COST_ADDINV(1,[F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,[F:POQ]POHFCY,[F:POQ]ITMREF,LRET) From STCLIB
  If LRET
    GMESSAGE = mess(44,199,1)
    mkstat = 2
  Endif
  For J=0 To [M:CST2]NBNONDET-1
    If [M:CST2]CURCPY3(J) <> [F:POH]CUR & [F:POH]CHGCOE<>0
      [M:GPO1]AMTNOTLIN += arr([M:CST2]AMTNDTCPY(J)/[F:POH]CHGCOE,[F:TCU]CURRND)
    Else
      [M:GPO1]AMTNOTLIN += [M:CST2]AMTNDTCPY(J)
    Endif
  Next
Next


  Raz WDISCGRAMTMAX

  #Total éléments de facturation :Lecture de PVCRFOOT pour sommer les éléments de facturation
  Filter [PVF] Where [F:PVF]VCRNUM = [F:POH]POHNUM & [F:PVF]VCRTYP=3
  For [PVF]
    Read [PFI] PFI0=[F:PVF]INVDTA : If fstat Raz [F:PFI] : Endif
    If [F:PFI]INCDCR=1
      WDISCGRAMTMAX +=[F:PVF]INVORDAMT
    Endif
  Next
  Filter [PVF]
  [M:GPO1]DISCGRAMTMAX = WDISCGRAMTMAX

  #Total des charges : charges directes + Elts fact maj + taxes non ded + fac compl
  #                    + frais approche
  WTOTAL = [M:GPO1]FCSCSTPUR + [M:GPO1]DISCGRAMTMAX +
&                              [M:GPO1]NONDEDTAX + [M:GPO1]AMTNOTLIN +
&                              [M:GPO1]TOTCOEFFAPP

#Fin MAE

  If [M:GPO1]CUR=[F:POH]CUR
    WMONTANT=[F:POH]TOTORD
  Else
    Call CONVERT([F:POH]CUR,GLOCALDEV,[M:GPO1]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                [F:POH]TOTORD,WMONTANT,WKO) From TRTDEV
    If WKO  WMONTANT=[F:POH]TOTORD : Endif

  Endif
  #----- Détermination de la période -----#
  WDATE=[F:POH]ORDDAT : Gosub DETERMINE_PERIODE
  #-----
  If [M:GPO1]NBLIG>0
    I=find(WINDEX,[M:GPO1]INDEXPER(0..[M:GPO1]NBLIG-1))
  Else
    I=0
  Endif

  If I=0
    If [M:GPO1]NBLIG<dim([M:GPO1]PERIODE)
      J=[M:GPO1]NBLIG
      [M:GPO1]DAT     (J)=[F:POH]ORDDAT
      [M:GPO1]INDEXPER(J)=WINDEX
      [M:GPO1]PERIODE (J)=WLIBELLE
      [M:GPO1]CUMAMT  (J)=WMONTANT
      # Issue 84130 - 2013-02-07 by MAE : charges achat
      If dim([M:CGPO]PECFCSTFLG)>0
        If [M:CGPO]PECFCSTFLG = 2
          [M:GPO1]TOTCHARGACH(J) = WTOTAL
        Else
          [M:GPO1]TOTCHARGACH(J) = 0
        Endif
      Else
        [M:GPO1]TOTCHARGACH(J) = WTOTAL
      Endif
     [M:GPO1]NBLIG+=1
    Endif
  Else
    [M:GPO1]CUMAMT(I-1)+=WMONTANT
    # Issue 84130 - 2013-02-07 by MAE : charges achat
    If dim([M:CGPO]PECFCSTFLG)>0
      If [M:CGPO]PECFCSTFLG = 2
        [M:GPO1]TOTCHARGACH(I-1)+=WTOTAL
      Else
        [M:GPO1]TOTCHARGACH(I-1)+=0
      Endif
    Else
      [M:GPO1]TOTCHARGACH(I-1)+=WTOTAL
    Endif
  Endif
$SUIT_GRHPO1
Next
#----- If faut créer les périodes manquantes -----#
WDATDEB=[M:CCPO]ORDDATDEB
WDATFIN=[M:CCPO]ORDDATFIN
Gosub PERIODES_MANQUANTES
#-----
Sorta [M:GPO1]NBLIG [M:GPO1]NBLIG Order By [M:GPO1]INDEXPER(indice)
#-----
Affzo [GPO1]10
Return

#------------------------------------------------------------------------------#
# Chargement du tableau pour le graphe "Décomposition HT commande par période" #
#------------------------------------------------------------------------------#
$CHARGE_GRHPO2
#----- Déclaration des variables locales -----#
Gosub DECLARE_VARIABLES
If dim(WQTE)<1     Local Decimal WQTE    : Endif
If dim(WCLEAMT)<1  Local Decimal WCLEAMT : Endif
If dim(WINVAMT)<1  Local Decimal WINVAMT : Endif
If dim(WRCPAMT)<1  Local Decimal WRCPAMT : Endif
If dim(WNAPAMT)<1  Local Decimal WNAPAMT : Endif
If dim(WORDAMT)<1  Local Decimal WORDAMT : Endif
#-----
WPERCOD=[M:GPO2]PERCOD
Effzo [GPO2]10
Raz [M:GPO2]NBLIG
#-----
For [POH] Where evalue([M:GPO2]WFIL)
&             & evalue([M:GPO2]WFIL1)
&             & evalue([M:GPO2]WFIL2)
&         With Nohint
  #----- Filtre sur société si nécessaire -----#
  If [M:CPO1]CPY<>"" & [M:CPO1]POHFCY=""
    If [F:FCY]FCY<>[F:POH]POHFCY
      Read [FCY] FCY0=[F:POH]POHFCY : If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY<>[M:CPO1]CPY  Goto SUIT_GRHPO2 : Endif
  Endif
  #----- Détermination de la période -----#
  WDATE=[F:POH]ORDDAT : Gosub DETERMINE_PERIODE
  #-----
  If [M:GPO2]NBLIG>0
    I=find(WINDEX,[M:GPO2]INDEXPER(0..[M:GPO2]NBLIG-1))
  Else
    I=0
  Endif
  If I=0
    If [M:GPO2]NBLIG<dim([M:GPO2]PERIODE)
      J=[M:GPO2]NBLIG
      [M:GPO2]DAT      (J)=[F:POH]ORDDAT
      [M:GPO2]INDEXPER (J)=WINDEX
      [M:GPO2]PERIODE  (J)=WLIBELLE
      [M:GPO2]CUMCLEAMT(J)=0
      [M:GPO2]CUMINVAMT(J)=0
      [M:GPO2]CUMRCPAMT(J)=0
      [M:GPO2]CUMNAPAMT(J)=0
      [M:GPO2]CUMORDAMT(J)=0
      [M:GPO2]NBLIG+=1
    Else
      J=999999
    Endif
  Else
    J=I-1
  Endif
  #-----
  Raz WCLEAMT, WINVAMT, WRCPAMT, WNAPAMT, WORDAMT
  #-----
  If J<>999999
    If [F:POH]APPFLG>2
      # Issue X3-57557 - 2017-10-23 by SR : prendre en compte les articles non gérés en stock
      #For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM & WIPSTA=1
      For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM & find(WIPSTA,0,1)
        #----- Mt soldé ou en commande -----#
        WQTE=[F:POQ]QTYPUU-max([F:POQ]RCPQTYPUU,[F:POQ]INVQTYPUU)
        If WQTE>0
          #----- Mt soldé non réceptionné et non facturé -----#
          If [F:POQ]LINCLEFLG=2
            WCLEAMT+=[F:POQ]LINAMT*WQTE/[F:POQ]QTYPUU
          #----- Mt en commande -----#
          Else
            WORDAMT+=[F:POQ]LINAMT*WQTE/[F:POQ]QTYPUU
          Endif
        Endif
        #----- Mt facturé -----#
        WQTE=min([F:POQ]QTYPUU,[F:POQ]INVQTYPUU)
        If WQTE>0
          WINVAMT+=[F:POQ]LINAMT*WQTE/[F:POQ]QTYPUU
        Endif
        #----- Mt réceptionné non facturé -----#
        WQTE=[F:POQ]RCPQTYPUU-[F:POQ]INVQTYPUU
        If WQTE>0
          WRCPAMT+=[F:POQ]LINAMT*WQTE/[F:POQ]QTYPUU
        Endif
        #-----
      Next
    Else
      #-----  Mt non signé -----#
      WNAPAMT=[F:POH]TOTORD
    Endif
    #----- Conversion des montants si nécessaire -----#
    If [M:GPO2]CUR=[F:POH]CUR
      If WCLEAMT<>0  Call ARRDEV(WCLEAMT,[M:GPO2]CUR) From TRTDIV : Endif
      If WINVAMT<>0  Call ARRDEV(WINVAMT,[M:GPO2]CUR) From TRTDIV : Endif
      If WRCPAMT<>0  Call ARRDEV(WRCPAMT,[M:GPO2]CUR) From TRTDIV : Endif
      If WNAPAMT<>0  Call ARRDEV(WNAPAMT,[M:GPO2]CUR) From TRTDIV : Endif
      If WORDAMT<>0  Call ARRDEV(WORDAMT,[M:GPO2]CUR) From TRTDIV : Endif
    Else
      If WCLEAMT<>0
        Call CONVERT([F:POH]CUR,GLOCALDEV,[M:GPO2]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                    WCLEAMT,WMONTANT,WKO) From TRTDEV
        If !WKO  WCLEAMT=WMONTANT : Endif
      Endif
      If WINVAMT<>0
        Call CONVERT([F:POH]CUR,GLOCALDEV,[M:GPO2]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                    WINVAMT,WMONTANT,WKO) From TRTDEV
        If !WKO  WINVAMT=WMONTANT : Endif
      Endif
      If WRCPAMT<>0
        Call CONVERT([F:POH]CUR,GLOCALDEV,[M:GPO2]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                    WRCPAMT,WMONTANT,WKO) From TRTDEV
        If !WKO  WRCPAMT=WMONTANT : Endif
      Endif
      If WNAPAMT<>0
        Call CONVERT([F:POH]CUR,GLOCALDEV,[M:GPO2]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                    WNAPAMT,WMONTANT,WKO) From TRTDEV
        If !WKO  WNAPAMT=WMONTANT : Endif
      Endif
      If WORDAMT<>0
        Call CONVERT([F:POH]CUR,GLOCALDEV,[M:GPO2]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                    WORDAMT,WMONTANT,WKO) From TRTDEV
        If !WKO  WORDAMT=WMONTANT : Endif
      Endif
    Endif
    #----- Cumuls des montants dans le masque écran -----#
    [M:GPO2]CUMCLEAMT(J)+=WCLEAMT
    [M:GPO2]CUMINVAMT(J)+=WINVAMT
    [M:GPO2]CUMRCPAMT(J)+=WRCPAMT
    [M:GPO2]CUMNAPAMT(J)+=WNAPAMT
    [M:GPO2]CUMORDAMT(J)+=WORDAMT
  Endif
  #-----
$SUIT_GRHPO2
Next
#----- If faut créer les périodes manquantes -----#
WDATDEB=[M:CCPO]ORDDATDEB
WDATFIN=[M:CCPO]ORDDATFIN
Gosub PERIODES_MANQUANTES
#-----
Sorta [M:GPO2]NBLIG [M:GPO2]NBLIG Order By [M:GPO2]INDEXPER(indice)
#-----
Affzo [GPO2]10
Return


#####################################################################################
# TRTGRHPR : Consultation réceptions par période (saisie des critères) MBT 18/12/06 #
# --------------------------------------------------------------------------------- #
# Paramètres                                                                        #
#  - PARAM(1) = BPRNUM : Fournisseur ("" par défaut)                                #
#  - PARAM(2) = FCY    : Site de commande  (GFCYDEF(6) par défaut)                  #
#  - PARAM(3) = NOMZON : Nom du champ                                               #
#####################################################################################

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_TRTGRHPR
If !clalev([F:BPS])  Local File BPSUPPLIER [BPS] : Endif
If !clalev([F:FCY])  Local File FACILITY   [FCY] : Endif
# Issue 84130 - 2013-02-21 by MAE : ajout des charges achat
If !clalev([M:CST2]) Local Mask CSTLIN2 [CST2]  : Endif
If !clalev([F:PFI])  Local File PFOOTINV [PFI]  : Endif
If !clalev([F:PVF])  Local File PVCRFOOT [PVF]  : Endif
If clalev([F:TCU])= 0 : Local File TABCUR [TCU] : Endif
If !clalev([F:PID])  Local File PINVOICED [PID]  : Endif
#Fin MAE
Local Date    WDATDEB
Local Date    WDATFIN
Local Integer WPERCOD
Local Integer WPERNBR
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_TRTGRHPR
Raz [M:CGPR]
If GNBAUZ=1 : PARAM(2)=GUSRFCY(1) : Endif
If PARAM(1)<>""
  If [F:BPS]BPSNUM<>PARAM(1)
    Read [BPS] BPS0=PARAM(1) : If fstat  Raz [F:BPS], PARAM(1) : Endif
  Endif
  [M:CGPR]BPSNUM=PARAM(1)
Endif
If PARAM(2)<>""
  If [F:FCY]FCY<>PARAM(2)
    Read [FCY] FCY0=PARAM(2) : If fstat  Raz [F:FCY], PARAM(2) : Endif
  Endif
  If (GUSRFCY(1)="\" | find(PARAM(2),GUSRFCY(1..GNBAUZ)))
    [M:CGPR]PRHFCY=PARAM(2)
    Call GETDEV([M:CGPR]PRHFCY) From DEVSUB
    [M:CGPR]CPY=GSOCIETE
    [M:CGPR]CUR=GLOCALDEV
  Endif
Endif
If PARAM(3)="NIVDLV"  [M:CGPR]INVFLGO=1 : [M:CGPR]INVFLGN=2 : Endif
#-----
If !find([M:CGPR]INVFLGN,1,2)  [M:CGPR]INVFLGN=2 : Endif
If !find([M:CGPR]PSTFLGO,1,2)  [M:CGPR]PSTFLGO=2 : Endif
If !find([M:CGPR]PSTFLGN,1,2)  [M:CGPR]PSTFLGN=2 : Endif
If !find([M:CGPR]PRNFLGO,1,2)  [M:CGPR]PRNFLGO=2 : Endif
If !find([M:CGPR]PRNFLGN,1,2)  [M:CGPR]PRNFLGN=2 : Endif
If !find([M:CGPR]TRI,1,2)      [M:CGPR]TRI=1     : Endif
#-----
[M:CGPR]PERCOD=4
[M:CGPR]PERNBR=3
#-----
Call LECMEMO("STD","[M:CGPR]","pmr") From GMEMO
#-----
Raz WDATDEB, WDATFIN
WPERCOD=[M:CGPR]PERCOD
WPERNBR=[M:CGPR]PERNBR
Gosub INIT_PERIODE
[M:CGPR]RCPDATDEB=WDATDEB
[M:CGPR]RCPDATFIN=WDATFIN
#-----
Affzo [CGPR]1-99
Return


####################################################################################
# Partie commune aux actions :                                        MBT 18/12/06 #
#   - VISUGRHPR1 : Visualisation Réceptions facturées par période                  #
#   - VISUGRHPR2 : Visualisation Réceptions retournées par période                 #
# -------------------------------------------------------------------------------- #
# Paramètre                                                                        #
#  - PARAM(1) = WABMSK : Abréviation du masque contenant les critères de sélection #
####################################################################################

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUGRHPR
Local Char     WABMSK(5)   : WABMSK   =PARAM(1)
Local Integer  SAVNOLIGN   : SAVNOLIGN=nolign
Local Integer  CHGPAG      : CHGPAG   =1
Local Integer  WOK
Local Char     WPROGSPE(GLONADC)
Local Char     WFIL (250)
Local Char     WFIL1(250)
Local Char     WFIL2(250)
Local Date     SAVDATDEB
Local Date     SAVDATFIN
Local Date     WDATDEB
Local Date     WDATFIN
Local Integer  WPERCOD
Local Integer  WPERNBR
# Issue 84130 - 2013-02-28 by MAE : ajout des couts achats
Local Char REQUETE(255)(3)
Local Integer BASE
Local Char REQUETECPR(255)(3)
Local  Integer  WAMTNOTLIN
Local Integer LRET
Case GTYPDBA
    When 1 : BASE=3 : # Oracle
    When 2 : BASE=5 : # Sql
    When 3 : BASE=2 : # Cisam
    When 4 : BASE=4 : # DB2
  Endcase
#fin MAE 84130

#-----
If !clalev([F:PTH])  Local File PRECEIPT  [PTH] : Endif
If !clalev([F:PTD])  Local File PRECEIPTD [PTD] : Endif

# Issue 93530 - 2013-10-15 by MUARN : site ou société obligatoire
If evalue ("[M:" + WABMSK + "]CPY") = "" & evalue("[M:" + WABMSK + "]PRHFCY") = "" & GACTION = "VISUGRHPR2"
  GERR = 1 : FIN = 1 : GMESSAGE=mess(9,109,1)
Endif

If WABMSK<>"CCPR"
  If !clalev([M:CPR1])  Local Mask CONSCPR1 [CPR1] : Endif
  If !clalev([M:CCPR])  Local Mask CRITCPR  [CCPR] : Endif
  [M:CCPR]CPY      =evalue("[M:"+WABMSK+"]CPY")
  [M:CCPR]CUR      =evalue("[M:"+WABMSK+"]CUR")
  [M:CCPR]PRHFCY   =evalue("[M:"+WABMSK+"]PRHFCY")
#US 71069/138  by RBA
#  [M:CCPR]BPSNUM   =evalue("[M:"+WABMSK+"]BPSNUM")
  [M:CCPR]BPSNUMDEB   =evalue("[M:"+WABMSK+"]BPSNUM")
#/US 71069/138  by RBA
  [M:CCPR]PTHNUMDEB=evalue("[M:"+WABMSK+"]PTHNUMDEB")
  [M:CCPR]PTHNUMFIN=evalue("[M:"+WABMSK+"]PTHNUMFIN")
  [M:CCPR]RCPDATDEB=evalue("[M:"+WABMSK+"]RCPDATDEB")
  [M:CCPR]RCPDATFIN=evalue("[M:"+WABMSK+"]RCPDATFIN")
  [M:CCPR]INVFLGO  =evalue("[M:"+WABMSK+"]INVFLGO")
  [M:CCPR]PSTFLGO  =evalue("[M:"+WABMSK+"]PSTFLGO")
  [M:CCPR]PRNFLGO  =evalue("[M:"+WABMSK+"]PRNFLGO")
  [M:CCPR]INVFLGN  =evalue("[M:"+WABMSK+"]INVFLGN")
  [M:CCPR]PSTFLGN  =evalue("[M:"+WABMSK+"]PSTFLGN")
  [M:CCPR]PRNFLGN  =evalue("[M:"+WABMSK+"]PRNFLGN")
  Gosub ENTCRIT From WWCNSCPR
  SAVDATDEB=[M:CCPR]RCPDATDEB
  SAVDATFIN=[M:CCPR]RCPDATFIN
  WPERCOD=evalue("[M:"+WABMSK+"]PERCOD")
  WPERNBR=evalue("[M:"+WABMSK+"]PERNBR")
Else
  Gosub CRITENT From WWCNSCPR
  SAVDATDEB=[M:CCPR]RCPDATDEB
  SAVDATFIN=[M:CCPR]RCPDATFIN
  WDATDEB  =[M:CCPR]RCPDATDEB
  WDATFIN  =[M:CCPR]RCPDATFIN
  WPERCOD=4
  WPERNBR=3
  Gosub INIT_PERIODE
  [M:CCPR]RCPDATDEB=WDATDEB
  [M:CCPR]RCPDATFIN=WDATFIN
Endif
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUGRHPR
Case GACTION
  When "VISUGRHPR1" : Raz [M:GPR1]
  When "VISUGRHPR2" : Raz [M:GPR2]
Endcase
#----- Chargement de la périodicité et de la devise -----#
[M]PERCOD=WPERCOD
[M]PERNBR=WPERNBR
[M]DATDEB=[M:CCPR]RCPDATDEB
[M]DATFIN=[M:CCPR]RCPDATFIN
[M]CUR   =[M:CCPR]CUR
Affzo 5
#----- Récupération du nom du traitement spécifique -----#
If !clalev([F:ACN])  Local File ACONSULT [ACN] : Endif
Read [ACN] ACN0="CPR" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif
#----- Positionnement des filtres -----#
Gosub LOAD_FILTER From CNSCPRSTD
If WPROGSPE<>""
  ACTION="FILTRE" : Gosub ACTION From =WPROGSPE
Endif
[M]WFIL =WFIL
[M]WFIL1=WFIL1
[M]WFIL2=WFIL2
#----- Chargement du tableau -----#
Case GACTION
  When "VISUGRHPR1" : Gosub CHARGE_GRHPR1
  When "VISUGRHPR2" : Gosub CHARGE_GRHPR2
Endcase
Return

#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUGRHPR
nolign=SAVNOLIGN
[M:CCPR]RCPDATDEB=SAVDATDEB
[M:CCPR]RCPDATFIN=SAVDATFIN
Return

#-------------------------------------------------------------------------#
# Chargement du tableau pour le graphe "Réceptions facturées par période" #
#-------------------------------------------------------------------------#
$CHARGE_GRHPR1
#----- Déclaration des variables locales -----#
Gosub DECLARE_VARIABLES
If dim(WMT2)<1     Local Decimal WMT2    : Endif
If dim(WQTE)<1     Local Decimal WQTE    : Endif
If dim(WNOIAMT)<1  Local Decimal WNOIAMT : Endif
If dim(WINVAMT)<1  Local Decimal WINVAMT : Endif
If dim(WRCPAMT)<1  Local Decimal WRCPAMT : Endif
#-----
WPERCOD=[M:GPR1]PERCOD
Effzo [GPR1]10
Raz [M:GPR1]NBLIG
#-----
For [PTH] Where evalue([M:GPR1]WFIL)
&             & evalue([M:GPR1]WFIL1)
&             & evalue([M:GPR1]WFIL2)
&         With Nohint
  #----- Filtre sur société si nécessaire -----#
  If [M:CPR1]CPY<>"" & [M:CPR1]PRHFCY=""
    If [F:FCY]FCY<>[F:PTH]PRHFCY
      Read [FCY] FCY0=[F:PTH]PRHFCY : If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY<>[M:CPR1]CPY  Goto SUIT_GRHPR1 : Endif
  Endif
  #----- Détermination de la période -----#
  WDATE=[F:PTH]RCPDAT : Gosub DETERMINE_PERIODE
  #-----
  If [M:GPR1]NBLIG>0
    I=find(WINDEX,[M:GPR1]INDEXPER(0..[M:GPR1]NBLIG-1))
  Else
    I=0
  Endif
  If I=0
    If [M:GPR1]NBLIG<dim([M:GPR1]PERIODE)
      J=[M:GPR1]NBLIG
      [M:GPR1]DAT      (J)=[F:PTH]RCPDAT
      [M:GPR1]INDEXPER (J)=WINDEX
      [M:GPR1]PERIODE  (J)=WLIBELLE
      [M:GPR1]CUMNOIAMT(J)=0
      [M:GPR1]CUMINVAMT(J)=0
      [M:GPR1]CUMRCPAMT(J)=0
      [M:GPR1]NBLIG+=1
    Else
      J=999999
    Endif
  Else
    J=I-1
  Endif
  #-----
  Raz WNOIAMT, WINVAMT, WRCPAMT
  #-----
  If J<>999999
    For [PTD] PTD0 Where PTHNUM=[F:PTH]PTHNUM
      #----- Mt réceptionné non facturable (inter-sites) -----#
      If [F:PTH]BETFCY=2 & [F:PTH]BETCPY<>2
        If [M:GPR1]CUR=[F:PTD]NETCUR
          WNOIAMT+=[F:PTD]LINAMT
        Else
          Call CONVERT2([F:PTD]NETCUR,GLOCALDEV,[M:GPR1]CUR,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                       [F:PTD]LINAMT,WMONTANT,WKO) From TRTDEV
          If WKO  WMONTANT=[F:PTD]LINAMT : Endif
          WNOIAMT+=WMONTANT
        Endif
      Endif
      #----- Mt réceptionné facturé -----#
      WQTE=min([F:PTD]QTYPUU,[F:PTD]INVQTYPUU)
      If WQTE>0
        WMONTANT=[F:PTD]LINAMT*WQTE/[F:PTD]QTYPUU
        If [M:GPR1]CUR<>[F:PTD]NETCUR
          Call CONVERT2([F:PTD]NETCUR,GLOCALDEV,[M:GPR1]CUR,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                       WMONTANT,WMT2,WKO) From TRTDEV
          If !WKO  WMONTANT=WMT2 : Endif
        Endif
        WINVAMT+=WMONTANT
      Endif
      #----- Mt réceptionné non facturé -----#
      WQTE=[F:PTD]QTYPUU-[F:PTD]INVQTYPUU
      If WQTE>0
        WMONTANT=[F:PTD]LINAMT*WQTE/[F:PTD]QTYPUU
        If [M:GPR1]CUR<>[F:PTD]NETCUR
          Call CONVERT2([F:PTD]NETCUR,GLOCALDEV,[M:GPR1]CUR,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                       WMONTANT,WMT2,WKO) From TRTDEV
          If !WKO  WMONTANT=WMT2 : Endif
        Endif
        WRCPAMT+=WMONTANT
      Endif
      #-----
    Next
    #----- Arrondi des montants -----#
    If WNOIAMT<>0  Call ARRDEV(WNOIAMT,[M:GPR1]CUR) From TRTDIV : Endif
    If WINVAMT<>0  Call ARRDEV(WINVAMT,[M:GPR1]CUR) From TRTDIV : Endif
    If WRCPAMT<>0  Call ARRDEV(WRCPAMT,[M:GPR1]CUR) From TRTDIV : Endif
    #----- Cumuls des montants dans le masque écran -----#
    [M:GPR1]CUMNOIAMT(J)+=WNOIAMT
    [M:GPR1]CUMINVAMT(J)+=WINVAMT
    [M:GPR1]CUMRCPAMT(J)+=WRCPAMT
  Endif
  #-----
$SUIT_GRHPR1
Next
#----- If faut créer les périodes manquantes -----#
WDATDEB=[M:CCPR]RCPDATDEB
WDATFIN=[M:CCPR]RCPDATFIN
Gosub PERIODES_MANQUANTES
#-----
Sorta [M:GPR1]NBLIG [M:GPR1]NBLIG Order By [M:GPR1]INDEXPER(indice)
#-----
Affzo [GPR1]10
Return

#--------------------------------------------------------------------------#
# Chargement du tableau pour le graphe "Réceptions retournées par période" #
#--------------------------------------------------------------------------#
$CHARGE_GRHPR2
#----- Déclaration des variables locales -----#
Gosub DECLARE_VARIABLES
If dim(WMT2)<1     Local Decimal WMT2    : Endif
If dim(WQTE)<1     Local Decimal WQTE    : Endif
If dim(WRTNAMT)<1  Local Decimal WRTNAMT : Endif
If dim(WRCPAMT)<1  Local Decimal WRCPAMT : Endif
#-----
WPERCOD=[M:GPR2]PERCOD
Effzo [GPR2]10
Raz [M:GPR2]NBLIG
#-----
For [PTH] Where evalue([M:GPR2]WFIL)
&             & evalue([M:GPR2]WFIL1)
&             & evalue([M:GPR2]WFIL2)
&         With Nohint
  #----- Filtre sur société si nécessaire -----#
  If [M:CPR1]CPY<>"" & [M:CPR1]PRHFCY=""
    If [F:FCY]FCY<>[F:PTH]PRHFCY
      Read [FCY] FCY0=[F:PTH]PRHFCY : If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY<>[M:CPR1]CPY  Goto SUIT_GRHPR2 : Endif
  Endif
  #----- Détermination de la période -----#
  WDATE=[F:PTH]RCPDAT : Gosub DETERMINE_PERIODE
  #-----
  If [M:GPR2]NBLIG>0
    I=find(WINDEX,[M:GPR2]INDEXPER(0..[M:GPR2]NBLIG-1))
  Else
    I=0
  Endif
  If I=0
    If [M:GPR2]NBLIG<dim([M:GPR2]PERIODE)
      J=[M:GPR2]NBLIG
      [M:GPR2]DAT      (J)=[F:PTH]RCPDAT
      [M:GPR2]INDEXPER (J)=WINDEX
      [M:GPR2]PERIODE  (J)=WLIBELLE
      [M:GPR2]CUMRTNAMT(J)=0
      [M:GPR2]CUMRCPAMT(J)=0
      [M:GPR2]NBLIG+=1
    Else
      J=999999
    Endif
  Else
    J=I-1
  Endif
  #-----
  Raz WRTNAMT, WRCPAMT
  #-----
  If J<>999999
    Raz WAMTNOTLIN
    For [PTD] PTD0 Where PTHNUM=[F:PTH]PTHNUM
      #----- Mt retourné -----#
      WQTE=min([F:PTD]QTYPUU,[F:PTD]RTNQTYPUU)
      If WQTE>0
        WMONTANT=[F:PTD]LINAMT*WQTE/[F:PTD]QTYPUU
        If [M:GPR2]CUR<>[F:PTD]NETCUR
          Call CONVERT2([F:PTD]NETCUR,GLOCALDEV,[M:GPR2]CUR,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                       WMONTANT,WMT2,WKO) From TRTDEV
          If !WKO  WMONTANT=WMT2 : Endif
        Endif
        WRTNAMT+=WMONTANT
      Endif
      #----- Mt réceptionné -----#
      If [M:GPR2]CUR=[F:PTD]NETCUR
        WRCPAMT+=[F:PTD]LINAMT
      Else
        Call CONVERT2([F:PTD]NETCUR,GLOCALDEV,[M:GPR2]CUR,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                     [F:PTD]LINAMT,WMONTANT,WKO) From TRTDEV
        If WKO  WMONTANT=[F:PTD]LINAMT : Endif
        WRCPAMT+=WMONTANT
      Endif
      # Issue 84130 - 2013-04-08 by MAE : lecteure des factures complémentaires
      Call COST_ADDINV(2,[F:PTD]PTHNUM,[F:PTD]PTDLIN,0,[F:PTD]PRHFCY,[F:PTD]ITMREF,LRET) From STCLIB
      If LRET
        GMESSAGE = mess(44,199,1)
        mkstat = 2
      Endif
      For J=0 To [M:CST2]NBNONDET-1
        If [M:CST2]CURCPY3(J) <> [F:PTH]CUR & [F:PTH]CHGCOE<>0
          [M:GPR2]AMTNOTLIN += arr([M:CST2]AMTNDTCPY(J)/[F:PTH]CHGCOE,[F:TCU]CURRND)
        Else
          [M:GPR2]AMTNOTLIN += [M:CST2]AMTNDTCPY(J)
        Endif
      Next
    Next

  #Calcul sur la somme des lignes de réception
  #Charges directes, coût achat,  montant ligne hors taxes
  REQUETE(0) = "SELECT SUM(FCSCSTPUR_0)"
  #taxes non déductibles
  REQUETE(1)=
&
&
&
&
&
&
&
&
&
&
&
&
&
&
& 
& ",SUM((AMTTAXLIN1_0-DEDTAXLIN1_0)+(AMTTAXLIN2_0-DEDTAXLIN2_0)+(AMTTAXLIN3_0-DEDTAXLIN3_0)+(AMTTAXRCP_0-DEDTAXRCP_0)+(AMTTAXISS_0-DEDTAXISS_0)+(AMTTAXOTH1_0-DEDTAXOTH1_0)+(AMTTAXOTH2_0-DEDTAXOTH2_0))"
  REQUETE(2)=" from PRECEIPTD WHERE PTHNUM_0='"+[F:PTH]PTHNUM+"'"

  For (Decimal WFCSCSTPUR,Decimal WNONDEDTAX) From num$(BASE) Sql REQUETE As [SPOQ]
    [M:GPR2]FCSCSTPUR= [SPOQ]WFCSCSTPUR
    If [F:PTH]CUR<>[M:GPR2]CUR & [F:PTH]CHGCOE<>0
      [M:GPR2]NONDEDTAX=  arr([SPOQ]WNONDEDTAX*[F:PTH]CHGCOE,[F:TCU]CURRND)
    Else
      [M:GPR2]NONDEDTAX=  arr([SPOQ]WNONDEDTAX,[F:TCU]CURRND)
    Endif
  Next

  #Calcul total coefficient d'approche sur les lignes en coeff d'approche
  REQUETECPR(0)="select SUM(LINCSTPUR_0), SUM(LINAMT_0), SUM(DISCRGAMT1_0+DISCRGAMT2_0+DISCRGAMT3_0+DISCRGAMT4_0+DISCRGAMT5_0+DISCRGAMT6_0+DISCRGAMT7_0+DISCRGAMT8_0+DISCRGAMT9_0)"
  REQUETECPR(1)=
&
&
&
&
&
&
&
&
&
&
&
&
&
&
& 
& ",SUM((AMTTAXLIN1_0-DEDTAXLIN1_0)+(AMTTAXLIN2_0-DEDTAXLIN2_0)+(AMTTAXLIN3_0-DEDTAXLIN3_0)+(AMTTAXRCP_0-DEDTAXRCP_0)+(AMTTAXISS_0-DEDTAXISS_0)+(AMTTAXOTH1_0-DEDTAXOTH1_0)+(AMTTAXOTH2_0-DEDTAXOTH2_0))"
  REQUETECPR(2)=" from PRECEIPTD WHERE PTHNUM_0='"+[F:PTH]PTHNUM+"' and (CPRCOE_0<>1 or CPRAMT_0<>0)"

  For (Decimal WLINCSTPUR,Decimal WLINAMT, Decimal WDISCGRAMT, Decimal WNONDEDTAX ) From num$(BASE) Sql REQUETECPR As [SPCP]
    If [F:PTH]CUR<>[M:GPR2]CUR & [F:PTH]CHGCOE<>0
      WTOTCOEFFAPP = WLINCSTPUR-(WLINAMT*[F:PTH]CHGCOE)-(WDISCGRAMT*[F:PTH]CHGCOE)-(WNONDEDTAX*[F:PTH]CHGCOE)
    Else
      WTOTCOEFFAPP = WLINCSTPUR-(WLINAMT)-(WDISCGRAMT)-(WNONDEDTAX)
    Endif
    [M:GPR2]TOTCOEFFAPP =  arr(WTOTCOEFFAPP,[F:TCU]CURRND)
  Next

Raz WDISCGRAMTMAX

#Total éléments de facturation :Lecture de PVCRFOOT pour sommer les éléments de facturation
Filter [PVF] Where [F:PVF]VCRNUM = [F:PTH]PTHNUM & [F:PVF]VCRTYP=6
  For [PVF]
    Read [PFI] PFI0=[F:PVF]INVDTA : If fstat Raz [F:PFI] : Endif
    If [F:PFI]INCDCR=1
      WDISCGRAMTMAX +=[F:PVF]INVDTAAMT
    Endif
 Next
[M:GPR2]DISCGRAMTMAX = WDISCGRAMTMAX
[M:GPR2]AMTNOTLIN    = WAMTNOTLIN

#Total des charges : charges directes + Elts fact maj + taxes non ded + fac compl
#                    + frais approche
WMONTANT = [M:GPR2]FCSCSTPUR + [M:GPR2]DISCGRAMTMAX +
&                              [M:GPR2]NONDEDTAX + [M:GPR2]AMTNOTLIN +
&                              [M:GPR2]TOTCOEFFAPP

  #----- Arrondi des montants -----#
  If WRTNAMT<>0  Call ARRDEV(WRTNAMT,[M:GPR2]CUR) From TRTDIV : Endif
  If WRCPAMT<>0  Call ARRDEV(WRCPAMT,[M:GPR2]CUR) From TRTDIV : Endif
  #----- Cumuls des montants dans le masque écran -----#
  #MAE 84130
  If GPILNAV > 1
      If GNAVIG(GPILNAV)="CONSCPR"
        [M:GPR2]TOTCHARGACH(J) += WMONTANT
      Endif
    Else
      If [M:CGPR]PECFCSTFLG = 2
        [M:GPR2]TOTCHARGACH(J) += WMONTANT
      Else
        [M:GPR2]TOTCHARGACH(J) = 0
      Endif
  Endif
  [M:GPR2]CUMRTNAMT(J)-=WRTNAMT
  [M:GPR2]CUMRCPAMT(J)+=WRCPAMT
Endif
  #-----
$SUIT_GRHPR2
Next
#----- If faut créer les périodes manquantes -----#
WDATDEB=[M:CCPR]RCPDATDEB
WDATFIN=[M:CCPR]RCPDATFIN
Gosub PERIODES_MANQUANTES
#-----
Sorta [M:GPR2]NBLIG [M:GPR2]NBLIG Order By [M:GPR2]INDEXPER(indice)
#-----
Affzo [GPR2]10
Return


#####################################################################################
# TRTGRHPN : Consultation retours par période (saisie des critères)    MBT 29/12/06 #
# --------------------------------------------------------------------------------- #
# Paramètres                                                                        #
#  - PARAM(1) = BPRNUM : Fournisseur ("" par défaut)                                #
#  - PARAM(2) = FCY    : Site de commande  (GFCYDEF(6) par défaut)                  #
#####################################################################################

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_TRTGRHPN
If !clalev([F:BPS])  Local File BPSUPPLIER [BPS] : Endif
If !clalev([F:FCY])  Local File FACILITY   [FCY] : Endif
Local Date    WDATDEB
Local Date    WDATFIN
Local Integer WPERCOD
Local Integer WPERNBR
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_TRTGRHPN
If GACTION="TRTGRHPN"
  Raz [M:CGPN]
Else
  Raz [M:CCPN]
Endif
If GNBAUZ=1 : PARAM(2)=GUSRFCY(1) : Endif
If PARAM(1)<>""
  If [F:BPS]BPSNUM<>PARAM(1)
    Read [BPS] BPS0=PARAM(1) : If fstat  Raz [F:BPS], PARAM(1) : Endif
  Endif
  [M]BPSNUM=PARAM(1)
Endif
If PARAM(2)<>""
  If [F:FCY]FCY<>PARAM(2)
    Read [FCY] FCY0=PARAM(2) : If fstat  Raz [F:FCY], PARAM(2) : Endif
  Endif
  If (GUSRFCY(1)="\" | find(PARAM(2),GUSRFCY(1..GNBAUZ)))
    [M]PNHFCY=PARAM(2)
    Call GETDEV([M]PNHFCY) From DEVSUB
    [M]CPY=GSOCIETE
    [M]CUR=GLOCALDEV
  Endif
Endif
If !find([M]CFMFLGO,1,2)  [M]CFMFLGO=2 : Endif
If !find([M]CFMFLGN,1,2)  [M]CFMFLGN=2 : Endif
If !find([M]INVFLGO,1,2)  [M]INVFLGO=2 : Endif
If !find([M]INVFLGN,1,2)  [M]INVFLGN=2 : Endif
If !find([M]PSTFLGO,1,2)  [M]PSTFLGO=2 : Endif
If !find([M]PSTFLGN,1,2)  [M]PSTFLGN=2 : Endif
If !find([M]PRNFLGO,1,2)  [M]PRNFLGO=2 : Endif
If !find([M]PRNFLGN,1,2)  [M]PRNFLGN=2 : Endif
If !find([M]TRI,1,2)      [M]TRI=1     : Endif
#-----
If GACTION="TRTGRHPN"
  [M:CGPN]PERCOD=4
  [M:CGPN]PERNBR=3
  Call LECMEMO("STD","[M:CGPN]","pmn") From GMEMO
  WPERCOD=[M:CGPN]PERCOD
  WPERNBR=[M:CGPN]PERNBR
Else
  Call LECMEMO("STD","[M:CCPN]","cpn") From GMEMO
  Chgfmt [M:CCPN]ECRAN With "-K:5X"
  Chgfmt [M:CCPN]TRI   With "-N:1#"
  Chgtbk [M:CCPN]15    With ""
  WPERCOD=4
  WPERNBR=3
Endif
#-----
Raz WDATDEB, WDATFIN
Gosub INIT_PERIODE
[M]RTNDATDEB=WDATDEB
[M]RTNDATFIN=WDATFIN
#-----
Affzo 1-99
Return


####################################################################################
# Partie commune aux actions :                                        MBT 29/12/06 #
#   - VISUGRHPN1 : Visualisation retours renplacement-définitif par période        #
#   - VISUGRHPN2 : Visualisation retours et avoirs par période                     #
#   - VISUGRHPN3 : Visualisation palmarès retours par motif                        #
#   - VISUGRHPN4 : Visualisation palmarès retours par fournisseur                  #
# -------------------------------------------------------------------------------- #
# Paramètre                                                                        #
#  - PARAM(1) = WABMSK : Abréviation du masque contenant les critères de sélection #
####################################################################################

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUGRHPN
Local Char     WABMSK(5)   : WABMSK   =PARAM(1)
Local Integer  SAVNOLIGN   : SAVNOLIGN=nolign
Local Integer  CHGPAG      : CHGPAG   =1
Local Integer  WOK
Local Char     WPROGSPE(GLONADC)
Local Char     WFIL (250)
Local Char     WFIL1(250)
Local Char     WFIL2(250)
Local Date     SAVDATDEB
Local Date     SAVDATFIN
Local Date     WDATDEB
Local Date     WDATFIN
Local Integer  WPERCOD
Local Integer  WPERNBR
#-----
If !clalev([F:PNH])  Local File PRETURN    [PNH] : Endif
If !clalev([F:PND])  Local File PRETURND   [PND] : Endif
If !clalev([F:BPR])  Local File BPARTNER   [BPR] : Endif
If !clalev([F:BPS])  Local File BPSUPPLIER [BPS] : Endif
If !clalev([F:ADI])  Local File ATABDIV    [ADI] : Endif
If WABMSK<>"CCPN"
  If !clalev([M:CPN1])  Local Mask CONSCPN1 [CPN1] : Endif
  If WABMSK<>""
    If !clalev([M:CCPN])  Local Mask CRITCPN  [CCPN] : Endif
    [M:CCPN]CPY      =evalue("[M:"+WABMSK+"]CPY")
    [M:CCPN]CUR      =evalue("[M:"+WABMSK+"]CUR")
    [M:CCPN]PNHFCY   =evalue("[M:"+WABMSK+"]PNHFCY")
#    [M:CCPN]BPSNUM   =evalue("[M:"+WABMSK+"]BPSNUM")
    [M:CCPN]BPSNUMDEB   =evalue("[M:"+WABMSK+"]BPSNUM")
    [M:CCPN]PNHNUMDEB=evalue("[M:"+WABMSK+"]PNHNUMDEB")
    [M:CCPN]PNHNUMFIN=evalue("[M:"+WABMSK+"]PNHNUMFIN")
    [M:CCPN]RTNDATDEB=evalue("[M:"+WABMSK+"]RTNDATDEB")
    [M:CCPN]RTNDATFIN=evalue("[M:"+WABMSK+"]RTNDATFIN")
    [M:CCPN]CFMFLGO  =evalue("[M:"+WABMSK+"]CFMFLGO")
    [M:CCPN]CFMFLGN  =evalue("[M:"+WABMSK+"]CFMFLGN")
    [M:CCPN]INVFLGO  =evalue("[M:"+WABMSK+"]INVFLGO")
    [M:CCPN]INVFLGN  =evalue("[M:"+WABMSK+"]INVFLGN")
    [M:CCPN]PSTFLGO  =evalue("[M:"+WABMSK+"]PSTFLGO")
    [M:CCPN]PSTFLGN  =evalue("[M:"+WABMSK+"]PSTFLGN")
    [M:CCPN]PRNFLGO  =evalue("[M:"+WABMSK+"]PRNFLGO")
    [M:CCPN]PRNFLGN  =evalue("[M:"+WABMSK+"]PRNFLGN")
    WPERCOD          =evalue("[M:"+WABMSK+"]PERCOD")
    WPERNBR          =evalue("[M:"+WABMSK+"]PERNBR")
  Endif
  Gosub ENTCRIT From WWCNSCPN
  SAVDATDEB=[M:CCPN]RTNDATDEB
  SAVDATFIN=[M:CCPN]RTNDATFIN
Else
  Gosub CRITENT From WWCNSCPN
  SAVDATDEB=[M:CCPN]RTNDATDEB
  SAVDATFIN=[M:CCPN]RTNDATFIN
  WDATDEB  =[M:CCPN]RTNDATDEB
  WDATFIN  =[M:CCPN]RTNDATFIN
  WPERCOD=4
  WPERNBR=3
  Gosub INIT_PERIODE
  [M:CCPN]RTNDATDEB=WDATDEB
  [M:CCPN]RTNDATFIN=WDATFIN
Endif
#-----
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUGRHPN
Case GACTION
  When "VISUGRHPN1" : Raz [M:GPN1]
  When "VISUGRHPN2" : Raz [M:GPN2]
  When "VISUGRHPN3" : Raz [M:GPN3]
  When "VISUGRHPN4" : Raz [M:GPN4]
Endcase
#----- Chargement de la périodicité et de la devise -----#
If find(GACTION,"VISUGRHPN1","VISUGRHPN2")
  [M]PERCOD=WPERCOD
  [M]PERNBR=WPERNBR
Endif
#----- Valeur par défaut du TOP -----#
If dim([M]NBRTOP)>0
  [M]NBRTOP=10
Endif
#-----
[M]DATDEB=[M:CCPN]RTNDATDEB
[M]DATFIN=[M:CCPN]RTNDATFIN
[M]CUR   =[M:CCPN]CUR
Affzo 5
#----- Récupération du nom du traitement spécifique -----#
If !clalev([F:ACN])  Local File ACONSULT [ACN] : Endif
Read [ACN] ACN0="CPN" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif
#----- Positionnement des filtres -----#
Gosub LOAD_FILTER From CNSCPNSTD
If WPROGSPE<>""
  ACTION="FILTRE" : Gosub ACTION From =WPROGSPE
Endif
[M]WFIL =WFIL
[M]WFIL1=WFIL1
[M]WFIL2=WFIL2
#----- Chargement du tableau -----#
Case GACTION
  When "VISUGRHPN1" : Gosub CHARGE_GRHPN1
  When "VISUGRHPN2" : Gosub CHARGE_GRHPN2
  When "VISUGRHPN3" : Gosub CHARGE_GRHPN3
  When "VISUGRHPN4" : Gosub CHARGE_GRHPN4
Endcase
Return

#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUGRHPN
nolign=SAVNOLIGN
[M:CCPN]RTNDATDEB=SAVDATDEB
[M:CCPN]RTNDATFIN=SAVDATFIN
Return

#-----------------------------------------------------------------------------------#
# Chargement du tableau pour le graphe "Retours remplacement-définitif par période" #
#-----------------------------------------------------------------------------------#
$CHARGE_GRHPN1
#----- Déclaration des variables locales -----#
Gosub DECLARE_VARIABLES
If dim(WREPAMT)<1  Local Decimal WREPAMT : Endif
If dim(WDEFAMT)<1  Local Decimal WDEFAMT : Endif
#-----
WPERCOD=[M:GPN1]PERCOD
Effzo [GPN1]10
Raz [M:GPN1]NBLIG
#-----
For [PNH] Where evalue([M:GPN1]WFIL)
&             & evalue([M:GPN1]WFIL1)
&             & evalue([M:GPN1]WFIL2)
&         With Nohint
  #----- Filtre sur société si nécessaire -----#
  If [M:CPN1]CPY<>"" & [M:CPN1]PNHFCY=""
    If [F:FCY]FCY<>[F:PNH]PNHFCY
      Read [FCY] FCY0=[F:PNH]PNHFCY : If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY<>[M:CPN1]CPY  Goto SUIT_GRHPN1 : Endif
  Endif
  #----- Détermination de la période -----#
  WDATE=[F:PNH]RTNDAT : Gosub DETERMINE_PERIODE
  #-----
  If [M:GPN1]NBLIG>0
    I=find(WINDEX,[M:GPN1]INDEXPER(0..[M:GPN1]NBLIG-1))
  Else
    I=0
  Endif
  If I=0
    If [M:GPN1]NBLIG<dim([M:GPN1]PERIODE)
      J=[M:GPN1]NBLIG
      [M:GPN1]DAT      (J)=[F:PNH]RTNDAT
      [M:GPN1]INDEXPER (J)=WINDEX
      [M:GPN1]PERIODE  (J)=WLIBELLE
      [M:GPN1]CUMREPAMT(J)=0
      [M:GPN1]CUMDEFAMT(J)=0
      [M:GPN1]NBLIG+=1
    Else
      J=999999
    Endif
  Else
    J=I-1
  Endif
  #-----
  Raz WREPAMT, WDEFAMT
  #-----
  If J<>999999
    For [PND] PND0 Where PNHNUM=[F:PNH]PNHNUM
      If [F:PND]ORDFLG>1
        #----- Mt retour pour remplacement -----#
        If [M:GPN1]CUR=[F:PND]NETCUR
          WREPAMT+=[F:PND]LINAMT
        Else
          If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
            Read [BPS] BPS0=[F:PNH]BPSNUM : If fstat  Raz [F:BPS] : [F:BPS]CHGTYP=1 : Endif
          Endif
          Call CONVERT2([F:PND]NETCUR,GLOCALDEV,[M:GPN1]CUR,[F:BPS]CHGTYP,[F:PNH]RTNDAT,
&                       [F:PND]LINAMT,WMONTANT,WKO) From TRTDEV
          If WKO  WMONTANT=[F:PND]LINAMT : Endif
          WREPAMT+=WMONTANT
        Endif
      Else
        #----- Mt retour définitif -----#
        If [M:GPN1]CUR=[F:PND]NETCUR
          WDEFAMT+=[F:PND]LINAMT
        Else
          If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
            Read [BPS] BPS0=[F:PNH]BPSNUM : If fstat  Raz [F:BPS] : [F:BPS]CHGTYP=1 : Endif
          Endif
          Call CONVERT2([F:PND]NETCUR,GLOCALDEV,[M:GPN1]CUR,[F:BPS]CHGTYP,[F:PNH]RTNDAT,
&                       [F:PND]LINAMT,WMONTANT,WKO) From TRTDEV
          If WKO  WMONTANT=[F:PND]LINAMT : Endif
          WDEFAMT+=WMONTANT
        Endif
      Endif
      #-----
    Next
    #----- Arrondi des montants -----#
    If WREPAMT<>0  Call ARRDEV(WREPAMT,[M:GPN1]CUR) From TRTDIV : Endif
    If WDEFAMT<>0  Call ARRDEV(WDEFAMT,[M:GPN1]CUR) From TRTDIV : Endif
    #----- Cumuls des montants dans le masque écran -----#
    [M:GPN1]CUMREPAMT(J)+=WREPAMT
    [M:GPN1]CUMDEFAMT(J)+=WDEFAMT
  Endif
  #-----
$SUIT_GRHPN1
Next
#----- If faut créer les périodes manquantes -----#
WDATDEB=[M:CCPN]RTNDATDEB
WDATFIN=[M:CCPN]RTNDATFIN
Gosub PERIODES_MANQUANTES
#-----
Sorta [M:GPN1]NBLIG [M:GPN1]NBLIG Order By [M:GPN1]INDEXPER(indice)
#-----
Affzo [GPN1]10
Return

#----------------------------------------------------------------------#
# Chargement du tableau pour le graphe "Retours et avoirs par période" #
#----------------------------------------------------------------------#
$CHARGE_GRHPN2
#----- Déclaration des variables locales -----#
Gosub DECLARE_VARIABLES
If dim(WQTE)<1     Local Decimal WQTE    : Endif
If dim(WMT1)<1     Local Decimal WMT1    : Endif
If dim(WMT2)<1     Local Decimal WMT2    : Endif
If dim(WCNOAMT)<1  Local Decimal WCNOAMT : Endif
If dim(WRTNAMT)<1  Local Decimal WRTNAMT : Endif
#-----
WPERCOD=[M:GPN2]PERCOD
Effzo [GPN2]10
Raz [M:GPN2]NBLIG
#-----
For [PNH] Where evalue([M:GPN2]WFIL)
&             & evalue([M:GPN2]WFIL1)
&             & evalue([M:GPN2]WFIL2)
&         With Nohint
  #----- Filtre sur société si nécessaire -----#
  If [M:CPN1]CPY<>"" & [M:CPN1]PNHFCY=""
    If [F:FCY]FCY<>[F:PNH]PNHFCY
      Read [FCY] FCY0=[F:PNH]PNHFCY : If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY<>[M:CPN1]CPY  Goto SUIT_GRHPN2 : Endif
  Endif
  #----- Détermination de la période -----#
  WDATE=[F:PNH]RTNDAT : Gosub DETERMINE_PERIODE
  #-----
  If [M:GPN2]NBLIG>0
    I=find(WINDEX,[M:GPN2]INDEXPER(0..[M:GPN2]NBLIG-1))
  Else
    I=0
  Endif
  If I=0
    If [M:GPN2]NBLIG<dim([M:GPN2]PERIODE)
      J=[M:GPN2]NBLIG
      [M:GPN2]DAT      (J)=[F:PNH]RTNDAT
      [M:GPN2]INDEXPER (J)=WINDEX
      [M:GPN2]PERIODE  (J)=WLIBELLE
      [M:GPN2]CUMCNOAMT(J)=0
      [M:GPN2]CUMRTNAMT(J)=0
      [M:GPN2]NBLIG+=1
    Else
      J=999999
    Endif
  Else
    J=I-1
  Endif
  #-----
  Raz WCNOAMT, WRTNAMT
  #----- WMT1 = Mt des avoirs effectués, WMT2 = Mt des avoirs attendus -----#
  If J<>999999
    For [PND] PND0 Where PNHNUM=[F:PNH]PNHNUM & QTYPUU>0
      If [F:PND]LININVFLG<>2
        If [F:PND]INVQTYPUU=0
          WMT1=0
          WMT2=[F:PND]LINAMT
        Elsif [F:PND]QTYPUU-[F:PND]INVQTYPUU>0
          WMT1=[F:PND]LINAMT*[F:PND]INVQTYPUU/[F:PND]QTYPUU
          WMT2=[F:PND]LINAMT*([F:PND]QTYPUU-[F:PND]INVQTYPUU)/[F:PND]QTYPUU
        Else
          WMT1=[F:PND]LINAMT
          WMT2=0
        Endif
      Elsif [F:PND]INVQTYPUU>0
        WMT1=[F:PND]LINAMT*min([F:PND]QTYPUU,[F:PND]INVQTYPUU)/[F:PND]QTYPUU
        WMT2=0
      Else
        WMT1=0
        WMT2=0
      Endif
      #-----
      If WMT1<>0 | WMT2<>0
        If [M:GPN2]CUR<>[F:PND]NETCUR
          If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
            Read [BPS] BPS0=[F:PNH]BPSNUM : If fstat  Raz [F:BPS] : [F:BPS]CHGTYP=1 : Endif
          Endif
          Call CONVERT2([F:PND]NETCUR,GLOCALDEV,[M:GPN2]CUR,[F:BPS]CHGTYP,[F:PNH]RTNDAT,
&                       WMT1,WMONTANT,WKO) From TRTDEV
          If !WKO  WMT1=WMONTANT : Endif
          Call CONVERT2([F:PND]NETCUR,GLOCALDEV,[M:GPN2]CUR,[F:BPS]CHGTYP,[F:PNH]RTNDAT,
&                       WMT2,WMONTANT,WKO) From TRTDEV
          If !WKO  WMT2=WMONTANT : Endif
        Endif
        #-----
        WCNOAMT+=WMT1
        WRTNAMT+=WMT2
      Endif
      #-----
    Next
    #----- Arrondi des montants -----#
    If WCNOAMT<>0  Call ARRDEV(WCNOAMT,[M:GPN2]CUR) From TRTDIV : Endif
    If WRTNAMT<>0  Call ARRDEV(WRTNAMT,[M:GPN2]CUR) From TRTDIV : Endif
    #----- Cumuls des montants dans le masque écran -----#
    [M:GPN2]CUMCNOAMT(J)+=WCNOAMT
    [M:GPN2]CUMRTNAMT(J)+=WRTNAMT
  Endif
  #-----
$SUIT_GRHPN2
Next
#----- If faut créer les périodes manquantes -----#
WDATDEB=[M:CCPN]RTNDATDEB
WDATFIN=[M:CCPN]RTNDATFIN
Gosub PERIODES_MANQUANTES
#-----
Sorta [M:GPN2]NBLIG [M:GPN2]NBLIG Order By [M:GPN2]INDEXPER(indice)
#-----
Affzo [GPN2]10
Return

#-------------------------------------------------------------------#
# Chargement du tableau pour le graphe "Palmarès retours par motif" #
#-------------------------------------------------------------------#
$CHARGE_GRHPN3
#----- Déclaration des variables locales -----#
Gosub DECLARE_VARIABLES
#-----
Effzo [GPN3]10
Raz [M:GPN3]NBLIG
#-----
For [PNH] Where evalue([M:GPN3]WFIL)
&             & evalue([M:GPN3]WFIL1)
&             & evalue([M:GPN3]WFIL2)
&         With Nohint
  #----- Filtre sur société si nécessaire -----#
  If [M:CPN1]CPY<>"" & [M:CPN1]PNHFCY=""
    If [F:FCY]FCY<>[F:PNH]PNHFCY
      Read [FCY] FCY0=[F:PNH]PNHFCY : If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY<>[M:CPN1]CPY  Goto SUIT_GRHPN3 : Endif
  Endif
  #-----
  For [PND] PND0 Where PNHNUM=[F:PNH]PNHNUM
    #----- Montant HT ligne retour -----#
    If [M:GPN3]CUR=[F:PND]NETCUR
      WMONTANT=[F:PND]LINAMT
    Else
      If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
        Read [BPS] BPS0=[F:PNH]BPSNUM : If fstat  Raz [F:BPS] : [F:BPS]CHGTYP=1 : Endif
      Endif
      Call CONVERT([F:PND]NETCUR,GLOCALDEV,[M:GPN3]CUR,[F:BPS]CHGTYP,[F:PNH]RTNDAT,
&                  [F:PND]LINAMT,WMONTANT,WKO) From TRTDEV
      If WKO  WMONTANT=[F:PND]LINAMT : Endif
    Endif
    #----- Cumul du mt HT suivant le motif -----#
    If [M:GPN3]NBLIG>0
      I=find([F:PND]RTNREN,[M:GPN3]RTNREN(0..[M:GPN3]NBLIG-1))
      If I>0
        [M:GPN3]CUMRTNAMT(I-1)+=WMONTANT
      Endif
    Else
      I=0
    Endif
    If I=0
      If [M:GPN3]NBLIG<dim([M:GPN3]RTNREN)
        J=[M:GPN3]NBLIG
        [M:GPN3]RTNREN(J)=[F:PND]RTNREN
        If [F:PND]RTNREN=""
          [M:GPN3]RTNDES(J)=mess(667,197,1)
        Else
          Read [ADI] CODE=7;[F:PND]RTNREN
          If !fstat
            Call GET_ATEXTRA("ATABDIV","SHODES",GLANGUE,[M:GPN3]RTNDES(J)) From TRTX3TEX
            If [M:GPN3]RTNDES(J)=""
              Call GET_ATEXTRA("ATABDIV","LNGDES",GLANGUE,[M:GPN3]RTNDES(J)) From TRTX3TEX
            Endif
          Else
            [M:GPN3]RTNDES(J)=[F:PND]RTNDES
          Endif
        Endif
        [M:GPN3]CUMRTNAMT(J)=WMONTANT
        [M:GPN3]NBLIG+=1
      Endif
    Endif
  Next
  #-----
$SUIT_GRHPN3
Next
#-----
Sorta [M:GPN3]NBLIG [M:GPN3]NBLIG Order By [M:GPN3]RTNREN(indice)
#-----
Affzo [GPN3]10
Return

#-------------------------------------------------------------------------#
# Chargement du tableau pour le graphe "Palmarès retours par fournisseur" #
#-------------------------------------------------------------------------#
$CHARGE_GRHPN4
#----- Déclaration des variables locales -----#
Gosub DECLARE_VARIABLES
If dim(WMT_AUTRES)<1  Local Decimal WMT_AUTRES : Endif
If dim(WNBRTOP)<1     Local Libelle WNBRTOP    : Endif
#-----
WNBRTOP=[M:GPN4]NBRTOP
Effzo [GPN4]10
Raz [M:GPN4]NBLIG, WMT_AUTRES
#-----
For [PNH] PNH1 Where evalue([M:GPN4]WFIL)
&                  & evalue([M:GPN4]WFIL1)
&                  & evalue([M:GPN4]WFIL2)
&              With Nohint
  #----- Filtre sur société si nécessaire -----#
  If [M:CPN1]CPY<>"" & [M:CPN1]PNHFCY=""
    If [F:FCY]FCY<>[F:PNH]PNHFCY
      Read [FCY] FCY0=[F:PNH]PNHFCY : If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY<>[M:CPN1]CPY  Goto SUIT_GRHPN4 : Endif
  Endif
  #-----
  For [PND] PND0 Where PNHNUM=[F:PNH]PNHNUM
    #----- Montant HT ligne retour -----#
    If [M:GPN4]CUR=[F:PND]NETCUR
      WMONTANT=[F:PND]LINAMT
    Else
      If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
        Read [BPS] BPS0=[F:PNH]BPSNUM : If fstat  Raz [F:BPS] : [F:BPS]CHGTYP=1 : Endif
      Endif
      Call CONVERT([F:PND]NETCUR,GLOCALDEV,[M:GPN4]CUR,[F:BPS]CHGTYP,[F:PNH]RTNDAT,
&                  [F:PND]LINAMT,WMONTANT,WKO) From TRTDEV
      If WKO  WMONTANT=[F:PND]LINAMT : Endif
    Endif
    #----- Cumul du mt HT suivant le fournisseur -----#
    If [M:GPN4]NBLIG>0
      I=find([F:PNH]BPSNUM,[M:GPN4]BPSNUM(0..[M:GPN4]NBLIG-1))
      If I>0
        [M:GPN4]CUMRTNAMT(I-1)+=WMONTANT
      Endif
    Else
      I=0
    Endif
    If I=0
      #----- On ne garde que les x+1 premiers fournisseur ayant le plus gros HT -----#
      If [M:GPN4]NBLIG>WNBRTOP
        Sorta [M:GPN4]NBLIG [M:GPN4]NBLIG Order By [M:GPN4]CUMRTNAMT(indice) Desc
        WMT_AUTRES+=[M:GPN4]CUMRTNAMT(WNBRTOP)
        Raz [M:GPN4]BPSNUM   (WNBRTOP)
        Raz [M:GPN4]BPRNAM   (WNBRTOP)
        Raz [M:GPN4]CUMRTNAMT(WNBRTOP)
        [M:GPN4]NBLIG-=1
      Endif
      #----
      If [F:BPR]BPRNUM<>[F:PNH]BPSNUM
        Read [BPR] BPR0=[F:PNH]BPSNUM : If fstat  Raz [F:BPR] : Endif
      Endif
      J=[M:GPN4]NBLIG
      [M:GPN4]BPSNUM(J)=[F:PNH]BPSNUM
      [M:GPN4]BPRNAM(J)=[F:BPR]BPRNAM(0)
      [M:GPN4]CUMRTNAMT(J)=WMONTANT
      [M:GPN4]NBLIG+=1
      #-----
    Endif
  Next
  #-----
$SUIT_GRHPN4
Next
#-----
Sorta [M:GPN4]NBLIG [M:GPN4]NBLIG Order By [M:GPN4]CUMRTNAMT(indice) Desc
#----- Insertion du cumul des autres fournisseurs -----#
If [M:GPN4]NBLIG>WNBRTOP
  [M:GPN4]BPSNUM   (WNBRTOP) =mess(20,127,1)
  [M:GPN4]BPRNAM   (WNBRTOP) =mess(20,127,1)
  [M:GPN4]CUMRTNAMT(WNBRTOP)+=WMT_AUTRES
Elsif [M:CCPN]BPSNUM=""
  J=[M:GPN4]NBLIG
  [M:GPN4]BPSNUM   (J)=mess(20,127,1)
  [M:GPN4]BPRNAM   (J)=mess(20,127,1)
  [M:GPN4]CUMRTNAMT(J)=0
  [M:GPN4]NBLIG+=1
Endif
#-----
Affzo [GPN4]10
Return


#####################################################################################
# TRTGRHPI : Consultation factures par période (saisie des critères)   MBT 28/12/06 #
# --------------------------------------------------------------------------------- #
# Paramètres                                                                        #
#  - PARAM(1) = BPRNUM : Fournisseur ("" par défaut)                                #
#  - PARAM(2) = FCY    : Site de commande  (GFINRSP par défaut)                     #
#  - PARAM(3) = NOMZON : Nom du champ                                               #
#####################################################################################

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_TRTGRHPI
If !clalev([F:BPS])  Local File BPSUPPLIER [BPS] : Endif
If !clalev([F:FCY])  Local File FACILITY   [FCY] : Endif
Local Date    WDATDEB
Local Date    WDATFIN
Local Integer WPERCOD
Local Integer WPERNBR
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_TRTGRHPI
If GACTION="TRTGRHPI"
  Raz [M:CGPI]
Else
  Raz [M:CCPI]
Endif
If GNBAUZ=1 : PARAM(2)=GUSRFCY(1) : Endif
If PARAM(1)<>""
  If [F:BPS]BPSNUM<>PARAM(1)
    Read [BPS] BPS0=PARAM(1) : If fstat  Raz [F:BPS], PARAM(1) : Endif
  Endif
  [M]BPSNUM=PARAM(1)
Endif
If PARAM(2)<>""
  If [F:FCY]FCY<>PARAM(2)
    Read [FCY] FCY0=PARAM(2) : If fstat  Raz [F:FCY], PARAM(2) : Endif
  Endif
  If (GUSRFCY(1)="\" | find(PARAM(2),GUSRFCY(1..GNBAUZ)))
    [M]FCY=PARAM(2)
    Call GETDEV([M]FCY) From DEVSUB
    [M]FCY=GFINRSP
    [M]CPY=GSOCIETE
    [M]CUR=GLOCALDEV
  Endif
Endif
Case PARAM(3)
  When "NPTINV" : [M]MODT=2 : [M]STAO=1 : [M]STAN=2
  When "INV"    : [M]MODT=2 : [M]STAO=2 : [M]STAN=1
                              [M]BAPO=2 : [M]BAPN=1
  When "INVNBP" : [M]MODT=2 : [M]STAO=2 : [M]STAN=1
                              [M]BAPO=1 : [M]BAPN=2
Endcase
#-----
If !find([M]PIHTYP1,1,2)  [M]PIHTYP1=2 : Endif
If !find([M]PIHTYP2,1,2)  [M]PIHTYP2=2 : Endif
If !find([M]PIHTYP3,1,2)  [M]PIHTYP3=2 : Endif
If !find([M]PIHTYP4,1,2)  [M]PIHTYP4=2 : Endif
If !find([M]STAO,1,2)     [M]STAO=2    : Endif
If !find([M]STAN,1,2)     [M]STAN=2    : Endif
If !find([M]TRI,1,2)      [M]TRI=1     : Endif
If !find([M]MODA,1,2)     [M]MODA=2    : Endif
If !find([M]MODT,1,2)
  GBIDC3=adxpno(3)
  If GBIDC3="WGOBPS"
    [M]MODT=2
  Else
    [M]MODT=1
  Endif
Endif
If !find([M]BAPO,1,2)     [M]BAPO=2    : Endif
If !find([M]BAPN,1,2)     [M]BAPN=2    : Endif
#-----
If GACTION="TRTGRHPI"
  [M:CGPI]PERCOD=4
  [M:CGPI]PERNBR=3
  Call LECMEMO("STD","[M:CGPI]","pmi") From GMEMO
  WPERCOD=[M:CGPI]PERCOD
  WPERNBR=[M:CGPI]PERNBR
Else
  Call LECMEMO("STD","[M:CCPI]","cpi") From GMEMO
  #Chgfmt [M:CCPI]PIHTYP1 With "-N:1#"
  #Chgfmt [M:CCPI]PIHTYP2 With "-N:1#"
  #Chgfmt [M:CCPI]PIHTYP3 With "-N:1#"
  #Chgfmt [M:CCPI]PIHTYP4 With "-N:1#"
  Grizo [M:CCPI]PIHTYP1, PIHTYP2, PIHTYP3, PIHTYP4
  Chgfmt [M:CCPI]ECRAN   With "-K:5X"
  Chgfmt [M:CCPI]TRI     With "-N:1#"
  # Issue 92111 - 2013-08-29 by MUARN : Three way / 15 remplacé par 20
  Chgtbk [M:CCPI]20      With ""
  WPERCOD=4
  WPERNBR=3
Endif
#-----
Raz WDATDEB, WDATFIN
Gosub INIT_PERIODE
[M]BPRDATDEB=WDATDEB
[M]BPRDATFIN=WDATFIN
#-----
Affzo 1-99
Return


####################################################################################
# Partie commune aux actions :                                        MBT 28/12/06 #
#   - VISUGRHPI1 : Visualisation types de facture-avoir par période                #
#   - VISUGRHPI2 : Visualisation factures et règlements par période                #
#   - VISUGRHPI3 : Visualisation palmarès avoirs attendus par fournisseur          #
#   - VISUGRHPI4 : Visualisation palmarès factures par niveau de bon à payer       #
# -------------------------------------------------------------------------------- #
# Paramètre                                                                        #
#  - PARAM(1) = WABMSK : Abréviation du masque contenant les critères de sélection #
####################################################################################

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUGRHPI
Local Char     WABMSK(5)   : WABMSK   =PARAM(1)
Local Integer  SAVNOLIGN   : SAVNOLIGN=nolign
Local Integer  CHGPAG      : CHGPAG   =1
Local Integer  WOK
Local Char     WPROGSPE(GLONADC)
Local Char     WFIL (250)
Local Char     WFIL1(250)
Local Char     WFIL2(250)
Local Date     SAVDATDEB
Local Date     SAVDATFIN
Local Integer  SAVPIHTYP1
Local Integer  SAVPIHTYP2
Local Integer  SAVPIHTYP3
Local Integer  SAVPIHTYP4
Local Integer  SAVBAPO
Local Integer  SAVBAPN
Local Date     WDATDEB
Local Date     WDATFIN
Local Integer  WPERCOD
Local Integer  WPERNBR
#-----
If !clalev([F:PIH])  Local File PINVOICE   [PIH] : Endif
If !clalev([F:DUD])  Local File GACCDUDATE [DUD] : Endif
#----- Top 10 des fournisseurs ayant un montant d'avoirs en attente -----#
If GACTION="VISUGRHPI3"
  If !clalev([F:PNH])  Local File PRETURN    [PNH] : Endif
  If !clalev([F:PND])  Local File PRETURND   [PND] : Endif
  If !clalev([F:BPR])  Local File BPARTNER   [BPR] : Endif
  If !clalev([F:BPS])  Local File BPSUPPLIER [BPS] : Endif
  If !clalev([F:FCY])  Local File FACILITY   [FCY] : Endif
  Link [PND] With [PNH] PNH0=[F:PND]PNHNUM, [BPS] BPS0=[F:PND]BPSNUM, [FCY] FCY0=[F:PND]PNHFCY
&              As [PNX]
&        Order By [F:PND]BPSNUM
Endif
#-----
If WABMSK<>"CCPI"
  If !clalev([M:CPI1])  Local Mask CONSCPI1 [CPI1] : Endif
  If WABMSK<>""
    If !clalev([M:CCPI])  Local Mask CRITCPI  [CCPI] : Endif
    [M:CCPI]CPY      =evalue("[M:"+WABMSK+"]CPY")
    [M:CCPI]CUR      =evalue("[M:"+WABMSK+"]CUR")
    [M:CCPI]FCY      =evalue("[M:"+WABMSK+"]FCY")
#US 71069/138  by RBA
#    [M:CCPI]BPR      =evalue("[M:"+WABMSK+"]BPR")
    [M:CCPI]BPSNUMDEB       =evalue("[M:"+WABMSK+"]BPR")
    [M:CCPI]BPSNUMFIN      =evalue("[M:"+WABMSK+"]BPR")
#/US 71069/138  by RBA
    [M:CCPI]NUMDEB   =evalue("[M:"+WABMSK+"]NUMDEB")
    [M:CCPI]NUMFIN   =evalue("[M:"+WABMSK+"]NUMFIN")
    [M:CCPI]BPRDATDEB=evalue("[M:"+WABMSK+"]BPRDATDEB")
    [M:CCPI]BPRDATFIN=evalue("[M:"+WABMSK+"]BPRDATFIN")
    [M:CCPI]PIHTYP1  =evalue("[M:"+WABMSK+"]PIHTYP1")
    [M:CCPI]PIHTYP2  =evalue("[M:"+WABMSK+"]PIHTYP2")
    [M:CCPI]PIHTYP3  =evalue("[M:"+WABMSK+"]PIHTYP3")
    [M:CCPI]PIHTYP4  =evalue("[M:"+WABMSK+"]PIHTYP4")
    [M:CCPI]STAO     =evalue("[M:"+WABMSK+"]STAO")
    [M:CCPI]MODA     =evalue("[M:"+WABMSK+"]MODA")
    [M:CCPI]BAPO     =evalue("[M:"+WABMSK+"]BAPO")
    [M:CCPI]STAN     =evalue("[M:"+WABMSK+"]STAN")
    [M:CCPI]MODT     =evalue("[M:"+WABMSK+"]MODT")
    [M:CCPI]BAPN     =evalue("[M:"+WABMSK+"]BAPN")
    WPERCOD          =evalue("[M:"+WABMSK+"]PERCOD")
    WPERNBR          =evalue("[M:"+WABMSK+"]PERNBR")
  Endif
  Gosub ENTCRIT From WWCNSCPI
  SAVDATDEB=[M:CCPI]BPRDATDEB
  SAVDATFIN=[M:CCPI]BPRDATFIN
Else
  Gosub CRITENT From WWCNSCPI
  SAVDATDEB=[M:CCPI]BPRDATDEB
  SAVDATFIN=[M:CCPI]BPRDATFIN
  WDATDEB  =[M:CCPI]BPRDATDEB
  WDATFIN  =[M:CCPI]BPRDATFIN
  WPERCOD=4
  WPERNBR=3
  Gosub INIT_PERIODE
  [M:CCPI]BPRDATDEB=WDATDEB
  [M:CCPI]BPRDATFIN=WDATFIN
Endif
#-----
SAVPIHTYP1=[M:CCPI]PIHTYP1
SAVPIHTYP2=[M:CCPI]PIHTYP2
SAVPIHTYP3=[M:CCPI]PIHTYP3
SAVPIHTYP4=[M:CCPI]PIHTYP4
SAVBAPO   =[M:CCPI]BAPO
SAVBAPN   =[M:CCPI]BAPN
#-----
Case GACTION
  When "VISUGRHPI1"
    #----- Les factures et et les avoirs sont inclus -----#
    #[M:CCPI]PIHTYP1=2 : [M:CPI1]PIHTYP1=2
    #[M:CCPI]PIHTYP2=2
    #[M:CCPI]PIHTYP3=2 : [M:CPI1]PIHTYP3=2
    #[M:CCPI]PIHTYP4=2
  When "VISUGRHPI2"
    #----- Les factures sont incluses et les avoirs sont exclus -----#
    #[M:CCPI]PIHTYP1=2 : [M:CPI1]PIHTYP1=2
    #[M:CCPI]PIHTYP2=2
    #[M:CCPI]PIHTYP3=1 : [M:CPI1]PIHTYP3=1
    #[M:CCPI]PIHTYP4=1
  When "VISUGRHPI3"
    #----- Les avoirs sont inclus et les factures sont exclues -----#
    [M:CCPI]PIHTYP1=1 : [M:CPI1]PIHTYP1=1
    [M:CCPI]PIHTYP2=1
    [M:CCPI]PIHTYP3=2 : [M:CPI1]PIHTYP3=2
    [M:CCPI]PIHTYP4=2
  When "VISUGRHPI4"
    #----- Les factures sont incluses et les avoirs sont exclus -----#
    [M:CCPI]PIHTYP1=2 : [M:CPI1]PIHTYP1=2
    [M:CCPI]PIHTYP2=2
    [M:CCPI]PIHTYP3=1 : [M:CPI1]PIHTYP3=1
    [M:CCPI]PIHTYP4=1
    #----- Tous les niveaux de bon à payer sont traités -----#
    #[M:CCPI]BAPO=2
    #[M:CCPI]BAPN=2
Endcase
#-----
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUGRHPI
Case GACTION
  When "VISUGRHPI1" : Raz [M:GPI1]
  When "VISUGRHPI2" : Raz [M:GPI2]
  When "VISUGRHPI3" : Raz [M:GPI3]
  When "VISUGRHPI4" : Raz [M:GPI4]
Endcase
#----- Chargement de la périodicité et de la devise -----#
If find(GACTION,"VISUGRHPI1","VISUGRHPI2")
  [M]PERCOD=WPERCOD
  [M]PERNBR=WPERNBR
Endif
#----- Valeur par défaut du TOP -----#
If dim([M]NBRTOP)>0
  [M]NBRTOP=10
Endif
#-----
[M]DATDEB=[M:CCPI]BPRDATDEB
[M]DATFIN=[M:CCPI]BPRDATFIN
[M]CUR   =[M:CCPI]CUR
Affzo 5
#----- Récupération du nom du traitement spécifique -----#
If !clalev([F:ACN])  Local File ACONSULT [ACN] : Endif
Read [ACN] ACN0="CPI" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif
#----- Positionnement des filtres -----#
Gosub LOAD_FILTER From CNSCPISTD
If WPROGSPE<>""
  ACTION="FILTRE" : Gosub ACTION From =WPROGSPE
Endif
[M]WFIL =WFIL
[M]WFIL1=WFIL1
[M]WFIL2=WFIL2
#----- Ajout du filtre société si nécessaire -----#
If [M:CPI1]CPY<>"" & [M:CPI1]FCY=""
  [M]WFIL=WFIL-"& [F:PIH]CPY=[M:CPI1]CPY"
Endif
#----- Chargement du tableau -----#
Case GACTION
  When "VISUGRHPI1" : Gosub CHARGE_GRHPI1
  When "VISUGRHPI2" : Gosub CHARGE_GRHPI2
  When "VISUGRHPI3" : Gosub CHARGE_GRHPI3
  When "VISUGRHPI4" : Gosub CHARGE_GRHPI4
Endcase
Return

#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUGRHPI
nolign=SAVNOLIGN
[M:CCPI]BPRDATDEB=SAVDATDEB
[M:CCPI]BPRDATFIN=SAVDATFIN
[M:CCPI]PIHTYP1  =SAVPIHTYP1 : [M:CPI1]PIHTYP1  =SAVPIHTYP1
[M:CCPI]PIHTYP2  =SAVPIHTYP2
[M:CCPI]PIHTYP3  =SAVPIHTYP3 : [M:CPI1]PIHTYP3  =SAVPIHTYP3
[M:CCPI]PIHTYP4  =SAVPIHTYP4
[M:CCPI]BAPO     =SAVBAPO
[M:CCPI]BAPN     =SAVBAPN
Return

#---------------------------------------------------------------------#
# Chargement du tableau pour le graphe "Types de facture par période" #
#---------------------------------------------------------------------#
$CHARGE_GRHPI1
#----- Déclaration des variables locales -----#
Gosub DECLARE_VARIABLES
If dim(WCNOAMT)<1  Local Decimal WCNOAMT : Endif
If dim(WINVAMT)<1  Local Decimal WINVAMT : Endif
#-----
WPERCOD=[M:GPI1]PERCOD
Effzo [GPI1]10
Raz [M:GPI1]NBLIG
#-----
For [PIH] Where evalue([M:GPI1]WFIL)
&             & evalue([M:GPI1]WFIL1)
&         With Nohint
  #----- Filtre sur le bon à payer -----#
  For [DUD] DUD1 Where ACCNUM=[F:PIH]ACCNUM
    [F:PIH]PAZ=[F:DUD]FLGPAZ
    Break
  Next
  If evalue([M:GPI1]WFIL2)
    #-----
    If [M:GPI1]CUR=[F:PIH]CUR
      WMONTANT=[F:PIH]AMTNOT
    Else
      Call CONVERT([F:PIH]CUR,GLOCALDEV,[M:GPI1]CUR,[F:PIH]CURTYP,[F:PIH]RATDAT,
&                  [F:PIH]AMTNOT,WMONTANT,WKO) From TRTDEV
      If WKO  WMONTANT=[F:PIH]AMTNOT : Endif
    Endif
    #----- Facture ou avoir ? -----#
    If [F:PIH]INVTYP=1 | [F:PIH]INVTYP=3
      WCNOAMT=0
      WINVAMT=WMONTANT
    Else
      WCNOAMT=WMONTANT
      WINVAMT=0
    Endif
    #----- Détermination de la période -----#
    WDATE=[F:PIH]BPRDAT : Gosub DETERMINE_PERIODE
    #-----
    If [M:GPI1]NBLIG>0
      I=find(WINDEX,[M:GPI1]INDEXPER(0..[M:GPI1]NBLIG-1))
    Else
      I=0
    Endif
    If I=0
      If [M:GPI1]NBLIG<dim([M:GPI1]PERIODE)
        J=[M:GPI1]NBLIG
        [M:GPI1]DAT      (J)=[F:PIH]BPRDAT
        [M:GPI1]INDEXPER (J)=WINDEX
        [M:GPI1]PERIODE  (J)=WLIBELLE
        [M:GPI1]CUMCNOAMT(J)=-WCNOAMT
        [M:GPI1]CUMINVAMT(J)=WINVAMT
        [M:GPI1]NBLIG+=1
      Endif
    Else
      [M:GPI1]CUMCNOAMT(I-1)-=WCNOAMT
      [M:GPI1]CUMINVAMT(I-1)+=WINVAMT
    Endif
  Endif
Next
#----- If faut créer les périodes manquantes -----#
WDATDEB=[M:CCPI]BPRDATDEB
WDATFIN=[M:CCPI]BPRDATFIN
Gosub PERIODES_MANQUANTES
#-----
Sorta [M:GPI1]NBLIG [M:GPI1]NBLIG Order By [M:GPI1]INDEXPER(indice)
#-----
Affzo [GPI1]10
Return

#---------------------------------------------------------------------------#
# Chargement du tableau pour le graphe "Factures et règlements par période" #
#---------------------------------------------------------------------------#
$CHARGE_GRHPI2
#----- Déclaration des variables locales -----#
Gosub DECLARE_VARIABLES
If dim(WPAYAMT)<1  Local Decimal WPAYAMT : Endif
If dim(WNOPAMT)<1  Local Decimal WNOPAMT : Endif
#-----
WPERCOD=[M:GPI2]PERCOD
Effzo [GPI2]10
Raz [M:GPI2]NBLIG
#-----
For [PIH] Where evalue([M:GPI2]WFIL)
&             & evalue([M:GPI2]WFIL1)
&         With Nohint
  #----- Filtre sur le bon à payer -----#
  For [DUD] DUD1 Where ACCNUM=[F:PIH]ACCNUM
    [F:PIH]PAZ=[F:DUD]FLGPAZ
    Break
  Next
  If evalue([M:GPI2]WFIL2)
    #----- Recherche du montant réglé -----#
    Raz WMONTANT
    For [DUD] DUD1 Where ACCNUM=[F:PIH]ACCNUM
      WMONTANT+=[F:DUD]PAYCUR+[F:DUD]TMPCUR
    Next
    #-----
    If [M:GPI2]CUR=[F:PIH]CUR
      WPAYAMT=WMONTANT
      WNOPAMT=[F:PIH]AMTATI-WMONTANT
    Else
      Call CONVERT([F:PIH]CUR,GLOCALDEV,[M:GPI2]CUR,[F:PIH]CURTYP,[F:PIH]RATDAT,
&                  WMONTANT,WPAYAMT,WKO) From TRTDEV
      If WKO  WPAYAMT=WMONTANT : Endif
      Call CONVERT([F:PIH]CUR,GLOCALDEV,[M:GPI2]CUR,[F:PIH]CURTYP,[F:PIH]RATDAT,
&                  [F:PIH]AMTATI-WMONTANT,WNOPAMT,WKO) From TRTDEV
      If WKO  WNOPAMT=[F:PIH]AMTATI-WMONTANT : Endif
    Endif
    #----- Inversion des montants si avoir ou note de crédit -----#
    If find([F:PIH]INVTYP,2,4)
      WPAYAMT=-WPAYAMT : WNOPAMT=-WNOPAMT
    Endif
    #----- Détermination de la période -----#
    WDATE=[F:PIH]BPRDAT : Gosub DETERMINE_PERIODE
    #-----
    If [M:GPI2]NBLIG>0
      I=find(WINDEX,[M:GPI2]INDEXPER(0..[M:GPI2]NBLIG-1))
    Else
      I=0
    Endif
    If I=0
      If [M:GPI2]NBLIG<dim([M:GPI2]PERIODE)
        J=[M:GPI2]NBLIG
        [M:GPI2]DAT      (J)=[F:PIH]BPRDAT
        [M:GPI2]INDEXPER (J)=WINDEX
        [M:GPI2]PERIODE  (J)=WLIBELLE
        [M:GPI2]CUMPAYAMT(J)=WPAYAMT
        [M:GPI2]CUMNOPAMT(J)=WNOPAMT
        [M:GPI2]NBLIG+=1
      Endif
    Else
      [M:GPI2]CUMPAYAMT(I-1)+=WPAYAMT
      [M:GPI2]CUMNOPAMT(I-1)+=WNOPAMT
    Endif
  Endif
Next
#----- Raz des montants négatifs -----#
For I=0 To [M:GPI2]NBLIG-1
  If [M:GPI2]CUMPAYAMT(I)<0  Raz [M:GPI2]CUMPAYAMT(I) : Endif
  If [M:GPI2]CUMNOPAMT(I)<0  Raz [M:GPI2]CUMNOPAMT(I) : Endif
Next I
#----- If faut créer les périodes manquantes -----#
WDATDEB=[M:CCPI]BPRDATDEB
WDATFIN=[M:CCPI]BPRDATFIN
Gosub PERIODES_MANQUANTES
#-----
Sorta [M:GPI2]NBLIG [M:GPI2]NBLIG Order By [M:GPI2]INDEXPER(indice)
#-----
Affzo [GPI2]10
Return

#---------------------------------------------------------------------------------#
# Chargement du tableau pour le graphe "Palmarès avoirs attendus par fournisseur" #
#---------------------------------------------------------------------------------#
$CHARGE_GRHPI3
#----- Déclaration des variables locales -----#
Gosub DECLARE_VARIABLES
If dim(WCRIT)<1      Local Char    WCRIT(250) : Endif
If dim(WINVAMT)<1    Local Decimal WINVAMT    : Endif
If dim(WMT_AUTRES)<1 Local Decimal WMT_AUTRES : Endif
If dim(WNBRTOP)<1    Local Libelle WNBRTOP    : Endif
#-----
WNBRTOP=[M:GPI3]NBRTOP
Effzo [GPI3]10
Raz [M:GPI3]NBLIG, WMT_AUTRES
#----- Constitution du filtre sur le link [PNX] retours-sites-fournisseurs -----#
WCRIT="[F:PNH]CFMFLG=2"
If [M:CCPI]FCY<>""
  WCRIT-="& [F:FCY]FINRSPFCY=[M:CCPI]FCY"
Elsif [M:CCPI]CPY<>""
  WCRIT-="& [F:FCY]LEGCPY=[M:CCPI]CPY"
Endif
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  WCRIT-="& find([F:PND]PNHFCY,GUSRFCY(1..GNBAUZ))"
Endif
#US 71069/138  by RBA
#If [M:CCPI]BPR<>""
If [M:CCPI]BPSNUMDEB<>""
#  WCRIT-="& [F:BPS]BPSINV=[M:CCPI]BPR"
  WCRIT-="& [F:BPS]BPSINV=[M:CCPI]BPSNUMDEB"
#/US 71069/138  by RBA
Endif
If [M:CCPI]BPRDATDEB<>[0/0/0]
  WCRIT-="& [F:PND]RTNDAT>=[M:CCPI]BPRDATDEB"
Endif
If [M:CCPI]BPRDATFIN<>[0/0/0]
  WCRIT-="& [F:PND]RTNDAT<=[M:CCPI]BPRDATFIN"
Endif
WCRIT-="& [F:PND]QTYPUU>0"
#----- Boucle à partir des retours pour chargement des mts en attente d'avoir -----#
For [PNX] Where evalue(WCRIT)
  #----- Calcul du montant en attente d'avoir -----#
  If [F:PND]LININVFLG<>2
    If [F:PND]INVQTYPUU=0
      WMONTANT=[F:PND]LINAMT
    Elsif [F:PND]QTYPUU-[F:PND]INVQTYPUU>0
      WMONTANT=[F:PND]LINAMT*([F:PND]QTYPUU-[F:PND]INVQTYPUU)/[F:PND]QTYPUU
    Else
      WMONTANT=0
    Endif
  Else
    WMONTANT=0
  Endif
  #-----
  If WMONTANT<>0
    If [M:GPI3]CUR<>[F:PND]NETCUR
      Call CONVERT([F:PND]NETCUR,GLOCALDEV,[M:GPI3]CUR,[F:BPS]CHGTYP,[F:PND]RTNDAT,
&                  WMONTANT,WINVAMT,WKO) From TRTDEV
      If WKO  WINVAMT=WMONTANT : Endif
    Else
      WINVAMT=WMONTANT
    Endif
    #----- Cumul du mt HT des avoirs attendus suivant le fournisseur facturant -----#
    If [M:GPI3]NBLIG>0
      I=find([F:BPS]BPSINV,[M:GPI3]BPSNUM(0..[M:GPI3]NBLIG-1))
      If I>0
        [M:GPI3]CUMINVAMT(I-1)+=WINVAMT
      Endif
    Else
      I=0
    Endif
    If I=0
      #----- On ne garde que les x+1 premiers fournisseur ayant le plus gros HT -----#
      If [M:GPI3]NBLIG>WNBRTOP
        Sorta [M:GPI3]NBLIG [M:GPI3]NBLIG Order By [M:GPI3]CUMINVAMT(indice) Desc
        WMT_AUTRES+=[M:GPI3]CUMINVAMT(WNBRTOP)
        Raz [M:GPI3]BPSNUM   (WNBRTOP)
        Raz [M:GPI3]BPRNAM   (WNBRTOP)
        Raz [M:GPI3]CUMINVAMT(WNBRTOP)
        [M:GPI3]NBLIG-=1
      Endif
      #----
      If [F:BPR]BPRNUM<>[F:BPS]BPSINV
        Read [BPR] BPR0=[F:BPS]BPSINV : If fstat  Raz [F:BPR] : Endif
      Endif
      J=[M:GPI3]NBLIG
      [M:GPI3]BPSNUM   (J)=[F:BPS]BPSINV
      [M:GPI3]BPRNAM   (J)=[F:BPR]BPRNAM(0)
      [M:GPI3]CUMINVAMT(J)=WINVAMT
      [M:GPI3]NBLIG+=1
      #-----
    Endif
  Endif
Next
#-----
Sorta [M:GPI3]NBLIG [M:GPI3]NBLIG Order By [M:GPI3]CUMINVAMT(indice) Desc
If [M:GPI3]NBLIG>WNBRTOP
  [M:GPI3]BPSNUM   (WNBRTOP) =mess(20,127,1)
  [M:GPI3]BPRNAM   (WNBRTOP) =mess(20,127,1)
  [M:GPI3]CUMINVAMT(WNBRTOP)+=WMT_AUTRES
#  US 71069/138  By RBA
#  Elsif [M:CCPI]BPR=""
Elsif [M:CCPI]BPSNUMDEB=""
#/US 71069/138  by RBA
  J=[M:GPI3]NBLIG
  [M:GPI3]BPSNUM   (J)=mess(20,127,1)
  [M:GPI3]BPRNAM   (J)=mess(20,127,1)
  [M:GPI3]CUMINVAMT(J)=0
  [M:GPI3]NBLIG+=1
Endif
#----- Boucle à partir des avoirs pour chargement des mts avoirs effectués -----#
If [M:GPI3]NBLIG>0
  For [PIH] PIH1 Where evalue([M:GPI3]WFIL)
&                    & evalue([M:GPI3]WFIL1)
&                With Nohint
    #----- Filtre sur le bon à payer -----#
    For [DUD] DUD1 Where ACCNUM=[F:PIH]ACCNUM
      [F:PIH]PAZ=[F:DUD]FLGPAZ
      Break
    Next
    If evalue([M:GPI3]WFIL2)
      #-----
      If [M:GPI3]CUR=[F:PIH]CUR
        WMONTANT=[F:PIH]AMTNOT
      Else
        Call CONVERT([F:PIH]CUR,GLOCALDEV,[M:GPI3]CUR,[F:PIH]CURTYP,[F:PIH]RATDAT,
&                    [F:PIH]AMTNOT,WMONTANT,WKO) From TRTDEV
        If WKO  WMONTANT=[F:PIH]AMTNOT : Endif
      Endif
      #-----
      I=find([F:PIH]BPR,[M:GPI3]BPSNUM(0..[M:GPI3]NBLIG-1))
      If I
        [M:GPI3]CUMINVAMT2(I-1)+=WMONTANT
      Elsif [M:GPI3]BPSNUM([M:GPI3]NBLIG-1)=mess(20,127,1)
        [M:GPI3]CUMINVAMT2([M:GPI3]NBLIG-1)+=WMONTANT
      Endif
    Endif
  Next
Endif
#-----
Affzo [GPI3]10
Return

#-------------------------------------------------------------------------#
# Chargement du tableau pour le graphe "Palmarès factures par niveau BAP" #
#-------------------------------------------------------------------------#
$CHARGE_GRHPI4
#----- Déclaration des variables locales -----#
Gosub DECLARE_VARIABLES
If dim(WPAYAMT)<1  Local Decimal WPAYAMT : Endif
If dim(WNOPAMT)<1  Local Decimal WNOPAMT : Endif
#-----
Effzo [GPI4]10
Raz [M:GPI4]NBLIG
#-----
For [PIH] Where evalue([M:GPI4]WFIL)
&             & evalue([M:GPI4]WFIL1)
&         With Nohint
  #----- Filtre sur le bon à payer -----#
  For [DUD] DUD1 Where ACCNUM=[F:PIH]ACCNUM
    [F:PIH]PAZ=[F:DUD]FLGPAZ
    Break
  Next
  If evalue([M:GPI4]WFIL2)
    #----- Recherche du montant réglé -----#
    Raz WMONTANT
    For [DUD] DUD1 Where ACCNUM=[F:PIH]ACCNUM
      WMONTANT+=[F:DUD]PAYCUR+[F:DUD]TMPCUR
    Next
    #-----
    If [M:GPI4]CUR=[F:PIH]CUR
      WPAYAMT=WMONTANT
      WNOPAMT=[F:PIH]AMTATI-WMONTANT
    Else
      Call CONVERT([F:PIH]CUR,GLOCALDEV,[M:GPI4]CUR,[F:PIH]CURTYP,[F:PIH]RATDAT,
&                  WMONTANT,WPAYAMT,WKO) From TRTDEV
      If WKO  WPAYAMT=WMONTANT : Endif
      Call CONVERT([F:PIH]CUR,GLOCALDEV,[M:GPI4]CUR,[F:PIH]CURTYP,[F:PIH]RATDAT,
&                  [F:PIH]AMTATI-WMONTANT,WNOPAMT,WKO) From TRTDEV
      If WKO  WNOPAMT=[F:PIH]AMTATI-WMONTANT : Endif
    Endif
    #----- Remise à zéro si montant négatif -----#
    WPAYAMT=max(0,WPAYAMT)
    WNOPAMT=max(0,WNOPAMT)
    #----- Cumul du mt HT non réglé suivant la valeur du bon à payer -----#
    If [M:GPI4]NBLIG>0
      I=find(max([F:PIH]PAZ,1),[M:GPI4]PAZ(0..[M:GPI4]NBLIG-1))
      If I>0
        [M:GPI4]CUMPAYAMT(I-1)+=WPAYAMT
        [M:GPI4]CUMNOPAMT(I-1)+=WNOPAMT
      Endif
    Else
      I=0
    Endif
    If I=0
      J=[M:GPI4]NBLIG
      [M:GPI4]PAZ      (J)=max([F:PIH]PAZ,1)
      [M:GPI4]PAZDES   (J)=mess(max([F:PIH]PAZ,1),510,1)
      [M:GPI4]CUMPAYAMT(J)=WPAYAMT
      [M:GPI4]CUMNOPAMT(J)=WNOPAMT
      [M:GPI4]NBLIG+=1
    Endif
  Endif
Next
#-----
Sorta [M:GPI4]NBLIG [M:GPI4]NBLIG Order By [M:GPI4]PAZ(indice)
#-----
Affzo [GPI4]10
Return


################################################
# Initialisation des dates début et fin        #
# -------------------------------------------- #
# Appelé depuis les consultations listes :     #
# CNSCPOSTD, CNSCPRSTD, CNSCPISTD et CNSCPNSTD #
################################################
$INIT_DATES
#-----
If dim(WDATDEB)<1  Local Date    WDATDEB : Endif
If dim(WDATFIN)<1  Local Date    WDATFIN : Endif
If dim(WPERCOD)<1  Local Integer WPERCOD : Endif
If dim(WPERNBR)<1  Local Integer WPERNBR : Endif
#-----
Raz WDATDEB, WDATFIN
WPERCOD=4
WPERNBR=3
Gosub INIT_PERIODE
Return


############################################################################
# Initialisation des dates début, fin de période et nombre de périodes     #
# ------------------------------------------------------------------------ #
# En entrée                                                                #
#   - WDATDEB  : Date début ou date nulle                                  #
#   - WDATFIN  : Date fin   ou date nulle                                  #
#   - WPERNBR  : Nombre de périodes                                        #
#   - WPERCOD  : Code périodicité (1=Jour, 2=Semaine, 4=Mois, 5=Trimestre, #
#                                  6=Semestre, 7=Année)                    #
# En sortie                                                                #
#   - WDATDEB  : Date début si date nulle en entrée                        #
#   - WDATFIN  : Date fin   si date nulle en entrée                        #
#   - WPERNBR  : Nombre de période si WDATDEB et WDATFIN renseignées       #
############################################################################
$INIT_PERIODE
#-----
If WDATDEB=[0/0/0] & WDATFIN=[0/0/0]
  Case WPERCOD
    When 2       : WDATFIN=date$+(7-dayn(date$))
    When 4,5,6,7 : WDATFIN=eomonth(date$)
    When Default : WDATFIN=date$
  Endcase
  #----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
  Call CALDATPER(WPERCOD,WPERNBR,"-",[0/0/0],WDATFIN,WDATDEB) From TRTX3DAT
  If WDATDEB=[0/0/0]
    WDATDEB=WDATFIN
  Endif
  #-----
Else
  If WDATDEB=[0/0/0]
    #----- Calcul date début en fonction de la périodicité et du nbre de périodes -----#
    Call CALDATPER(WPERCOD,WPERNBR,"-",[0/0/0],WDATFIN,WDATDEB) From TRTX3DAT
    If WDATDEB=[0/0/0]
      WDATDEB=WDATFIN
    Endif
    #-----
  Elsif WDATFIN=[0/0/0]
    #----- Calcul date fin en fonction de la périodicité et du nbre de périodes -----#
    Call CALDATPER(WPERCOD,WPERNBR,"+",[0/0/0],WDATDEB,WDATFIN) From TRTX3DAT
    If WDATFIN=[0/0/0]
      WDATFIN=WDATDEB
    Endif
    #-----
  Else
    #----- Calcul du nbre de périodes (mois) en fonction des dates début et fin -----#
    Local Integer WM1, WM2, WA1, WA2
    WM1=month(WDATDEB) : WM2=month(WDATFIN)
    WA1=year (WDATDEB) : WA2=year (WDATFIN)
    If WM1<=WM2
      WPERNBR=WM2-WM1+1+((WA2-WA1)*12)
    Else
      WPERNBR=12-WM1+1+WM2+((WA2-WA1-1)*12)
    Endif
    #-----
  Endif
Endif
Return


#########################################################################
# Déclaration des variables locales communes aux différents traitements #
#########################################################################
$DECLARE_VARIABLES
If dim(I)<1        Local Integer I            : Endif
If dim(J)<1        Local Integer J            : Endif
If dim(WKO)<1      Local Integer WKO          : Endif
If dim(WINDEX)<1   Local Integer WINDEX       : Endif
If dim(WMAXI)<1    Local Integer WMAXI        : Endif
If dim(W0)<1       Local Integer W0           : Endif
If dim(W1)<1       Local Integer W1           : Endif
If dim(W2)<1       Local Integer W2           : Endif
If dim(WDATDEB)<1  Local Date    WDATDEB      : Endif
If dim(WDATFIN)<1  Local Date    WDATFIN      : Endif
If dim(WDATE)<1    Local Date    WDATE        : Endif
If dim(WPERCOD)<1  Local Integer WPERCOD      : Endif
If dim(WSEMAINE)<1 Local Integer WSEMAINE     : Endif
If dim(WMOIS)<1    Local Integer WMOIS        : Endif
If dim(WTRIMEST)<1 Local Integer WTRIMEST     : Endif
If dim(WSEMESTR)<1 Local Integer WSEMESTR     : Endif
If dim(WANNEE)<1   Local Integer WANNEE       : Endif
If dim(WLIBELLE)<1 Local Char    WLIBELLE(15) : Endif
If dim(WMONTANT)<1 Local Decimal WMONTANT     : Endif
# Issue 84130 - 2013-02-14 by MAE : déclaration variables
If dim(WTOTAL)<1 Local Decimal WTOTAL   : Endif
If dim(WDISCGRAMTMAX)<1 Local Decimal WDISCGRAMTMAX : Endif
Return


################################################################################
# Détermination de la période à partir d'une date et d'un code périodicité     #
# ---------------------------------------------------------------------------- #
# En entrée                                                                    #
#   - WDATE    : Date à traiter                                                #
#   - WPERCOD  : Code périodicité (1=Jour, 2=Semaine, 4=Mois, 5=Trimestre,     #
#                                  6=Semestre, 7=Année)                        #
# En sortie                                                                    #
#   - WANNEE   : Année     (AAAA)                                              #
#   - WSEMESTR : Semestre  (P)   1 à  2   si WPERCOD=6                         #
#   - WTRIMEST : Trimestre (P)   1 à  4   si WPERCOD=5                         #
#   - WMOIS    : Mois      (PP)  1 à 12   si WPERCOD=4                         #
#   - WSEMAINE : Semaine   (PP)  1 à 53   si WPERCOD=2                         #
#   - WINDEX   : Numéro d'ordre période (AAAAPPP) PPP = 000 à 004/012/053/366  #
#   - WLIBELLE : Libellé de la période                                         #
# ---------------------------------------------------------------------------- #
# Nota: C'est un Gosub il faut que toutes les variables ci-dessus existent     #
################################################################################
$DETERMINE_PERIODE
#-----
WANNEE=year(WDATE)
#-----
Case WPERCOD
  When 1       : #----- Jour -----#
    WINDEX  =(WANNEE*1000)+(WDATE-gdat$(1,1,WANNEE))+1
    WLIBELLE=format$("D:"+GFMDAT,WDATE)
  When 2       : #----- Semaine -----#
    WSEMAINE=week(WDATE)
    If WSEMAINE=53 & year(aweek(WSEMAINE,WANNEE)+3)<>WANNEE
      WSEMAINE=1
    Elsif WSEMAINE=0
      If dayn(aweek(WSEMAINE,WANNEE)+3)<4
        WSEMAINE=1
      Else
        WSEMAINE=53 : WANNEE-=1
      Endif
    Endif
    WINDEX  =(WANNEE*1000)+WSEMAINE
    WLIBELLE=mess(2,2231,1)-num$(WSEMAINE)-right$(num$(WANNEE),3)
  When 5       : #----- Trimestre -----#
    WTRIMEST=int((month(WDATE)-1)/3)+1
    WINDEX  =(WANNEE*1000)+WTRIMEST
    WLIBELLE=mess(5,2231,1)-num$(WTRIMEST)-right$(num$(WANNEE),3)
  When 6       : #----- Semestre -----#
    WSEMESTR=int((month(WDATE)-1)/6)+1
    WINDEX  =(WANNEE*1000)+WSEMESTR
    WLIBELLE=mess(6,2231,1)-num$(WSEMESTR)-right$(num$(WANNEE),3)
  When 7       : #----- Année -----#
    WINDEX  =(WANNEE*1000)
    WLIBELLE=mess(7,2231,1)-num$(WANNEE)
  When Default : #----- Mois -----#
    WMOIS   =month(WDATE)
    WINDEX  =(WANNEE*1000)+WMOIS
    WLIBELLE=format$("D:MMMMMMMMMM",WDATE)-num$(WANNEE)
Endcase
#-----
Return


################################################################################
# Création des périodes manquantes en fonction du code périodicité             #
# ---------------------------------------------------------------------------- #
# En entrée                                                                    #
#   - WDATDEB  : Date début                                                    #
#   - WDATFIN  : Date fin                                                      #
#   - WPERCOD  : Code périodicité (1=Jour, 2=Semaine, 4=Mois, 5=Trimestre,     #
#                                  6=Semestre, 7=Année)                        #
# Variables de travail                                                         #
#   - W0       : Maxi période-1                                                #
#   - W1       : Année                                                         #
#   - W2       : Période                                                       #
#   - WINDEX   : Numéro d'ordre période                                        #
#   - WMAXI    : Numéro d'ordre période maxi                                   #
#   - WLIBELLE : Libellé de la période                                         #
# En sortie, chargement de la classe écran (lignes tableau)                    #
#   - [M]DAT     (indice)                                                      #
#   - [M]INDEXPER(indice)                                                      #
#   - [M]PERIODE (indice) ...etc                                               #
# ---------------------------------------------------------------------------- #
# Nota: C'est un Gosub il faut que toutes les variables ci-dessus existent     #
################################################################################
$PERIODES_MANQUANTES
#-----
If [M]NBLIG>0
  WINDEX=min([M]INDEXPER(0..[M]NBLIG-1))
  WMAXI =max([M]INDEXPER(0..[M]NBLIG-1))
Else
  Raz WINDEX, WMAXI
Endif
#-----
If WDATFIN<>[0/0/0]
  WDATE=WDATFIN : Gosub DETERMINE_PERIODE
  If WINDEX>WMAXI
    WMAXI=WINDEX
  Endif
Endif
#-----
If WDATDEB<>[0/0/0]
  WDATE=WDATDEB : Gosub DETERMINE_PERIODE
  If [M]NBLIG>0
    If WINDEX>min([M]INDEXPER(0..[M]NBLIG-1))
      WINDEX=min([M]INDEXPER(0..[M]NBLIG-1))
    Endif
  Endif
Endif
#-----
Case WPERCOD
  When 1       : WDATE=WDATDEB-1
  When 2       : W0=51
  When 5       : W0=3
  When 6       : W0=1
  When 7       : W0=0
  When Default : W0=11
Endcase
If W0=0
  W1=int(WINDEX/1000)-1
  W2=mod(WINDEX,1000)
Else
  W1=int(WINDEX/1000)
  W2=mod(WINDEX,1000)-1
Endif
While WINDEX<WMAXI
  If [M]NBLIG>dim([M]PERIODE)-1
    WINDEX=WMAXI
  Else
    If WPERCOD=1
      WDATE+=1 : Gosub DETERMINE_PERIODE
    Else
      If W0=0  W2=0 : W1+=1  Elsif W2>W0  W2=1 : W1+=1  Else  W2+=1 : Endif
      WINDEX=(W1*1000)+W2
    Endif
    If [M]NBLIG=0 | !find(WINDEX,[M]INDEXPER(0..[M]NBLIG-1))
      Case WPERCOD
        When 1       : WLIBELLE=format$("D:"+GFMDAT,WDATE)
        When 2       : WLIBELLE=mess(2,52,1)-num$(W2)-right$(num$(W1),3)
        When 5       : WLIBELLE=mess(5,52,1)-num$(W2)-right$(num$(W1),3)
        When 6       : WLIBELLE=mess(6,2231,1)-num$(W2)-right$(num$(W1),3)
        When 7       : WLIBELLE=mess(7,2231,1)-num$(W1)
        When Default : WLIBELLE=format$("D:MMMMMMMMMM",gdat$(1,W2,W1))-num$(W1)
      Endcase
      [M]DAT     ([M]NBLIG)=[0/0/0]
      [M]INDEXPER([M]NBLIG)=WINDEX
      [M]PERIODE ([M]NBLIG)=WLIBELLE
      If clalev([M:GPO1])
        [M:GPO1]CUMAMT   ([M:GPO1]NBLIG)=0
      Elsif clalev([M:GPO2])
        [M:GPO2]CUMCLEAMT([M:GPO2]NBLIG)=0
        [M:GPO2]CUMINVAMT([M:GPO2]NBLIG)=0
        [M:GPO2]CUMRCPAMT([M:GPO2]NBLIG)=0
        [M:GPO2]CUMNAPAMT([M:GPO2]NBLIG)=0
        [M:GPO2]CUMORDAMT([M:GPO2]NBLIG)=0
      Elsif clalev([M:GPR1])
        [M:GPR1]CUMNOIAMT([M:GPR1]NBLIG)=0
        [M:GPR1]CUMINVAMT([M:GPR1]NBLIG)=0
        [M:GPR1]CUMRCPAMT([M:GPR1]NBLIG)=0
      Elsif clalev([M:GPR2])
        [M:GPR2]CUMRTNAMT([M:GPR2]NBLIG)=0
        [M:GPR2]CUMRCPAMT([M:GPR2]NBLIG)=0
      Endif
      [M]NBLIG+=1
    Endif
  Endif
Wend
#-----
Return


###############################################################################
# Actions sur champ des masques écrans GRHPO1, GRHPO2, GRHPR1, GRHPR2, etc... #
###############################################################################

Subprog AS_PERCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=0 : # Jour      Ok
GMENLOC(2)=0 : # Semaine   Ok
GMENLOC(3)=1 : # Quinzaine
GMENLOC(4)=0 : # Mois      Ok
GMENLOC(5)=0 : # Trimestre Ok
GMENLOC(6)=0 : # Semestre  Ok
GMENLOC(7)=0 : # Année     Ok
GMENLOC(8)=1 : # décade
End


Subprog AM_PERCOD(VALEUR)
Variable Integer VALEUR
#----- Recalcul du nbre de périodes -----#
Call CALPERNBR([M]PERCOD,VALEUR,[M]PERNBR) From TRTX3DAT
Affzo PERNBR
[M]PERCOD=VALEUR
Call AM_PERNBR([M]PERNBR)
#-----
End


Subprog AM_DATDEB(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)>0
  #----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]DATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]DATFIN=WDATE : Affzo DATFIN
  Endif
  #-----
Elsif VALEUR>[M]DATFIN
  [M]DATFIN=VALEUR
Endif
#-----
If clalev([M:CCPO])
  [M:CCPO]ORDDATDEB=VALEUR
  [M:CCPO]ORDDATFIN=[M]DATFIN
Elsif clalev([M:CCPR])
  [M:CCPR]RCPDATDEB=VALEUR
  [M:CCPR]RCPDATFIN=[M]DATFIN
Elsif clalev([M:CCPI])
  [M:CCPI]BPRDATDEB=VALEUR
  [M:CCPI]BPRDATFIN=[M]DATFIN
Elsif clalev([M:CCPN])
  [M:CCPN]RTNDATDEB=VALEUR
  [M:CCPN]RTNDATFIN=[M]DATFIN
Endif
#-----
End


Subprog AM_DATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)>0
  #----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]DATFIN,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]DATDEB=WDATE : Affzo DATDEB
  Endif
  #-----
Endif
#-----
If clalev([M:CCPO])
  [M:CCPO]ORDDATDEB=[M]DATDEB
  [M:CCPO]ORDDATFIN=VALEUR
Elsif clalev([M:CCPR])
  [M:CCPR]RCPDATDEB=[M]DATDEB
  [M:CCPR]RCPDATFIN=VALEUR
Elsif clalev([M:CCPI])
  [M:CCPI]BPRDATDEB=[M]DATDEB
  [M:CCPI]BPRDATFIN=VALEUR
Elsif clalev([M:CCPN])
  [M:CCPN]RTNDATDEB=[M]DATDEB
  [M:CCPN]RTNDATFIN=VALEUR
Endif
#-----
End


Subprog AM_PERNBR(VALEUR)
Variable Decimal VALEUR
#----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
Local Date WDATE
Call CALDATPER([M]PERCOD,VALEUR,"+",[0/0/0],[M]DATDEB,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]DATFIN=WDATE : Affzo DATFIN
Endif
#-----
If clalev([M:CCPO])
  [M:CCPO]ORDDATFIN=[M]DATFIN
Elsif clalev([M:CCPR])
  [M:CCPR]RCPDATFIN=[M]DATFIN
Elsif clalev([M:CCPI])
  [M:CCPI]BPRDATFIN=[M]DATFIN
Elsif clalev([M:CCPN])
  [M:CCPN]RTNDATFIN=[M]DATFIN
Endif
#-----
End


Subprog C_NBRTOP(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 | VALEUR>60
  GMESSAGE=mess(6,199,1) : mkstat=1 : End : # Valeur incorrecte !
Endif
End

