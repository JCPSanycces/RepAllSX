#<AdxTL>@(#)6.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("MHV",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Etiquette ajoutée par le superviseur (Objet MHV) 25/02/2009 13:36:13 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "LIENS"       : Gosub LIENS
 When "ANNULE"      : Gosub ANNULE
 When "INIMOD"      : Gosub INIMOD
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_CRE"   : Call GENHYPO(nomap,[F:MHV]COD) From SUBMHV
 When "APRES_MOD"   : Call GENHYPO(nomap,[F:MHV]COD) From SUBMHV
 When "RAZDUP"      : Gosub RAZDUP
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "FERME"       : Gosub FERME
Endcase
Return


#####################################
$OUVRE
If clalev ([F:MHV])=0 : Local File MSHYPVAH  [MHV] : Endif
If clalev ([F:MHL])=0 : Local File MSHYPVAL  [MHL] : Endif
If clalev ([F:MHD])=0 : Local File MSHYPVAD  [MHD] : Endif
If clalev ([F:MCL])=0 : Local File MSSCENAL  [MCL] : Endif
If clalev ([F:MCH])=0 : Local File MSSCENAH  [MCH] : Endif
If clalev ([F:BCB])=0 : Local File BCLOB     [BCB] : Endif
If clalev ([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif
If clalev ([F:ID]) =0 : Local File EMPLOID   [ID]  : Endif
If clalev ([F:CPY])=0 : Local File COMPANY   [CPY] : Endif

Local Char    COMPTEUR(GLONANM)
Local Integer STAT

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG = 'FRA' #Total Payroll is FRA only
Return

#####################################
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#####################################
$SETBOUT
If GREP<>"" | !VERROU | [M:MHV0]FLGCLO=2
 Call VIREBOUT (CHAINE,"AH") From GOBJET
Endif
If [M:MHV0]FLGCLO=2
 Call VIREBOUT (CHAINE,"M") From GOBJET
Endif
Return

#####################################
$LIENS
#If [F:MCH]CPY<>""
#  Call LECTURE("CPY",[F:MCH]CPY,"") From CONTOBJ
#  GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
#Endif
#If GNBLEG=1 : GCURLEG = GDOSLEG : Endif
# On décoche Définitif si l'hypothèse n'est stockée dans aucun scénario définitif
Link [MCL] With [MCH]MCH0=[MCL]COD
& As [LMC]
& Where [MCH]FLGCLO=2 & [MCL]TYPHYP=1 & [MCL]CODHYP=[F:MHV]COD
Read [LMC]MCL1 First
If fstat
 [M:MHV0]FLGCLO = 1
 Call DEBTRANS From GLOCK
 Gosub TR_LIEN
Endif
#Charge Tableau des variables avec  AG
Gosub CHARGE_VAR
#Charge Tableau des valeurs avec AI
If [F:MHV]TYPINC=2
 Effzo [M:MHV1]10 : Grizo [M:MHV1]10
 Gosub CHARGE_VAL
 Call AFFICHAGE ([M:MHV1]NBVAR)
Else
 Actzo [M:MHV1]10
 #Charge Entête
 Gosub CHARGE_ENT
 Call AFFICHAGE (0)
Endif
#CMT
Default Mask [M:MHV1]
Call CHARGE_CMT ("SUBMHV",[F:MHV]COD,"","","")From SUBMSR
Return

$TR_LIEN
Trbegin [MHV]
 [F:MHV]FLGCLO = 1
 Rewrite[MHV]
 If fstat : Call FSTA("MHV") From GLOCK : Rollback : Return : Endif
Commit
Return

#####################################
$CHARGE_ENT
If [F:MHV]CPY=""
 [M:MHV1]ALLCPY=2 : Grizo [M:MHV1]CPY
Else
 [M:MHV1]ALLCPY=1
Endif
If [F:MHV]FCY=""
 [M:MHV1]ALLFCY=2 : Grizo [M:MHV1]FCY
Else
 [M:MHV1]ALLFCY=1
Endif
If [F:MHV]SRV=""
 [M:MHV1]ALLSRV=2 : Grizo [M:MHV1]SRV
Else
 [M:MHV1]ALLSRV=1
Endif
If [F:MHV]PRF=""
 [M:MHV1]ALLPRF=2 : Grizo [M:MHV1]PRF
Else
 [M:MHV1]ALLPRF=1
Endif
#72635
If [F:MHV]JOBPOT=""
 [M:MHV1]ALLJOBPOT=2 : Grizo [M:MHV1]JOBPOT
Else
 [M:MHV1]ALLJOBPOT=1
Endif
If [F:MHV]POT=""
 [M:MHV1]ALLPOT=2 : Grizo [M:MHV1]POT
Else
 [M:MHV1]ALLPOT=1
Endif
#end 72635
Return


#####################################
$CHARGE_VAR
nolign=0
For [MHL]MHL0 Where COD=[F:MHV]COD
 nolign += 1
 [M:MHV1]=[F:MHL]
 For [MHD]MHD0 Where COD=[F:MHL]COD & VARCOD=[F:MHL]VARCOD & REFNUM=""
  [M:MHV1]VARVAL(nolign-1)=[F:MHD]VARVAL
 Next
 [M:MHV1]NUMCOL(nolign-1)=nolign
Next
[M:MHV1]NBVAR=nolign
Gosub CHARGE_STYLE
Return

#####################################
$CHARGE_STYLE
# Affzo avant le chgstl sinon ça marche pas !?!
Affzo [M:MHV1]15
For nolign=1 To [M:MHV1]NBVAR
 If [M:MHV1]ENAFLG1(nolign-1)=2
  Chgstl [M:MHV1]NBVAR(nolign-1) With "CONTRAT"
 Else
  Chgstl [M:MHV1]NBVAR(nolign-1) With ""
 Endif
 Call AFF_AMTMINMAX([M:MHV1]VARTYP(nolign-1)) :#89556
Next
Return

#####################################
$CHARGE_VAL
For I=1 To [M:MHV1]NBVAR
 nolign=0
 For [MHD]MHD0 Where COD=[F:MHV]COD & REFNUM<>"" & VARCOD=[M:MHV1]VARCOD(I-1)
  nolign += 1
  [M:MHV2]REFNUM(nolign-1)=[F:MHD]REFNUM
  [M:MHV2]CTRNUM(nolign-1)=[F:MHD]CTRNUM
  #Pour contrôler les doublons sur le couple Matricule+contrat
  [M:MHV2]REFCTR(nolign-1)=[F:MHD]REFNUM+"|"+[F:MHD]CTRNUM
  [M:MHV2]CMTLIG2(nolign-1)=[F:MHD]CMTLIG
  Read [ID]ID0 =[M:MHV2]REFNUM(nolign-1)
  If !fstat : [M:MHV2]SRN(nolign-1)=[F:ID]NAM-[F:ID]SRN : Endif
  ZONE="[M:MHV2]VARVAL"+num$([M:MHV1]NUMCOL(I-1))+"("+num$(nolign-1)+")"
  Assign ZONE With [F:MHD]VARVAL
 Next
 [M:MHV2]NBMAT=nolign
Next
Return


#####################################
## Changement de clé
$AP_CHANGE
Call APCHANGE(1,OCODE,NCODE) From SUBMHR
Return


#####################################
$RAZCRE
[M:MHV0]FLGCLO=1 : Call AFFICHAGE (0)
Return

#####################################
$RAZDUP
[M:MHV0]FLGCLO=1 : Affzo [M:MHV0]FLGCLO
Return

#####################################
$INICRE
$INIMOD
## Affectation du no de MSR
If [F:MHV]COD=""
 Call LECTCA(15,STAT) From SUBTCA
 If !STAT
  GMESSAGE = mess(51,10722,1) : # Compteur MSR non défini
  GOK = 0 : Return
 Else
  COMPTEUR= [F:TCA]CODNUM(10)
 Endif
Call NUMERO(COMPTEUR,"",date$,"",[F:MHV]COD,STAT) From SUBANM
 If STAT
  # Erreur sur compteur
  GMESSAGE = mess(4,10702,1)-COMPTEUR
  GOK = 0 : Return
 Endif
 Call VERIF_CPT([F:MHV]COD,COMPTEUR)
 If GOK=0 : Return : Endif
 [M:MHV0]COD = [F:MHV]COD
 Affzo [M:MHV0]COD
Endif
#Sauve Tableau des variables AG
Gosub SAUVE_VAR
#Sauve Tableau des valeurs AI
If [F:MHV]TYPINC=2 : Gosub SAUVE_VAL2 : Endif
#CMT
Default Mask [M:MHV1]
Call SAUVE_CMT ("SUBMHV",[F:MHV]COD,"","","")From SUBMSR
Return

####################################
Subprog VERIF_CPT(NUM,COMPTEUR)
Variable Char NUM
Value    Char COMPTEUR
Local Integer STAT
If clalev([F:MHVZ])=0 : Local File MSHYPVAH [MHVZ] : Endif
Read [MHVZ]MHV0=NUM
If fstat : End : Endif
While !fstat
 Call NUMERO(COMPTEUR,"",date$,"",NUM,STAT) From SUBANM
 Read [MHVZ]MHV0=NUM
Wend
If STAT
 # Erreur sur compteur
 GMESSAGE = mess(4,10702,1)-COMPTEUR
 GOK = 0 : End
Endif
End

#####################################
$SUPPRIME
Delete [MHL] Where COD=[F:MHV]COD
If fstat=1
 GOK =-1 : GLOCK = "MSHYPVAL" : Return
Endif
Delete [MHD] Where COD=[F:MHV]COD
If fstat=1
 GOK =-1 : GLOCK = "MSHYPVAD" : Return
Endif
Return

#####################################
$SAUVE_VAR
Gosub SUPPRIME
If GOK<0 : Return : Endif
For nolign=1 To [M:MHV1]NBVAR
 Raz [F:MHL]
 [F:MHL]       = [M:MHV1]
 [F:MHL]COD    = [M:MHV0]COD
 [F:MHL]NUMLIG = nolign
 #Si AG
 If [F:MHV]TYPINC<>2
  Gosub SAUVE_VAL1
  If !GOK : Break : Endif
 Endif
 Write[F:MHL]
 If fstat<>0
  GOK = 0 : Call FSTA("MHL") From GLOCK : Break
 Endif
Next
Return

#####################################
#Sauve les valeurs AG
$SAUVE_VAL1
Raz [F:MHD]
[F:MHD]=[F:MHL]
[F:MHD]VARVAL=[M:MHV1]VARVAL(nolign-1)
Write[F:MHD]
If fstat<>0
 GOK = 0 : Call FSTA("MHD") From GLOCK
Endif
Return

#####################################
#Sauve les valeurs AI
$SAUVE_VAL2
For I=1 To [M:MHV1]NBVAR
 For nolign=1 To [M:MHV2]NBMAT
  Raz [F:MHD]
  [F:MHD]=[M:MHV2]
  [F:MHD]COD    = [M:MHV0]COD
  [F:MHD]VARCOD = [M:MHV1]VARCOD(I-1)
  ZONE="[M:MHV2]VARVAL"+num$(I)+"("+num$(nolign-1)+")"
  [F:MHD]VARVAL = evalue(ZONE)
  [F:MHD]CMTLIG = [M:MHV2]CMTLIG2(nolign-1)
  Write[F:MHD]
  If fstat<>0
   GOK = 0 : Call FSTA("MHD") From GLOCK : Break
  Endif
Next
Next
Return

#####################################
$ANNULE
#CMT commun à toutes les lignes
Call ANNULE_CMT ("SUBMHV",[F:MHV]COD,"","","")From SUBMSR
# Suppression du prgrm généré
Call DELTRT("WPMS1"+[F:MHV]COD,nomap) From SUBADC
Return

####################################
Subprog AFFICHAGE (NBRCOL)
Value Integer NBRCOL
Local Integer I,J
Local Char AMTFMT (10)(0..2)
AMTFMT(0)='N3:9.3' :#Affichée
AMTFMT(1)='-N3:9.3' :#Invisible
Gosub AFF_ONGLET
Affzo[M:MHV2]
End

####################################
$AFF_ONGLET
#Affiche si variable.
For I=1 To NBRCOL
 Case I
  When  1  : Chgfmt [M:MHV2]VARVAL1  With AMTFMT(0)
  When  2  : Chgfmt [M:MHV2]VARVAL2  With AMTFMT(0)
  When  3  : Chgfmt [M:MHV2]VARVAL3  With AMTFMT(0)
  When  4  : Chgfmt [M:MHV2]VARVAL4  With AMTFMT(0)
  When  5  : Chgfmt [M:MHV2]VARVAL5  With AMTFMT(0)
  When  6  : Chgfmt [M:MHV2]VARVAL6  With AMTFMT(0)
  When  7  : Chgfmt [M:MHV2]VARVAL7  With AMTFMT(0)
  When  8  : Chgfmt [M:MHV2]VARVAL8  With AMTFMT(0)
  When  9  : Chgfmt [M:MHV2]VARVAL9  With AMTFMT(0)
  When  10 : Chgfmt [M:MHV2]VARVAL10 With AMTFMT(0)
  When  11 : Chgfmt [M:MHV2]VARVAL11 With AMTFMT(0)
  When  12 : Chgfmt [M:MHV2]VARVAL12 With AMTFMT(0)
  When  13 : Chgfmt [M:MHV2]VARVAL13 With AMTFMT(0)
  When  14 : Chgfmt [M:MHV2]VARVAL14 With AMTFMT(0)
  When  15 : Chgfmt [M:MHV2]VARVAL15 With AMTFMT(0)
 Endcase
Next

#Invisible si pas de variable.
For I=NBRCOL+1 To 15
 Case I
  When  1  : Chgfmt [M:MHV2]VARVAL1  With AMTFMT(1)
  When  2  : Chgfmt [M:MHV2]VARVAL2  With AMTFMT(1)
  When  3  : Chgfmt [M:MHV2]VARVAL3  With AMTFMT(1)
  When  4  : Chgfmt [M:MHV2]VARVAL4  With AMTFMT(1)
  When  5  : Chgfmt [M:MHV2]VARVAL5  With AMTFMT(1)
  When  6  : Chgfmt [M:MHV2]VARVAL6  With AMTFMT(1)
  When  7  : Chgfmt [M:MHV2]VARVAL7  With AMTFMT(1)
  When  8  : Chgfmt [M:MHV2]VARVAL8  With AMTFMT(1)
  When  9  : Chgfmt [M:MHV2]VARVAL9  With AMTFMT(1)
  When  10 : Chgfmt [M:MHV2]VARVAL10 With AMTFMT(1)
  When  11 : Chgfmt [M:MHV2]VARVAL11 With AMTFMT(1)
  When  12 : Chgfmt [M:MHV2]VARVAL12 With AMTFMT(1)
  When  13 : Chgfmt [M:MHV2]VARVAL13 With AMTFMT(1)
  When  14 : Chgfmt [M:MHV2]VARVAL14 With AMTFMT(1)
  When  15 : Chgfmt [M:MHV2]VARVAL15 With AMTFMT(1)
 Endcase
Next
Return

###############################################################################################################
# ECRAN 1
###############################################################################################################

Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo [M:MHV1]CPY: Grizo [M:MHV1]CPY
Else
  Actzo [M:MHV1]CPY
Endif
End

Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo [M:MHV1]FCY: Grizo [M:MHV1]FCY
Else
  Actzo [M:MHV1]FCY
Endif
End

Subprog AM_ALLSRV(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo [M:MHV1]SRV: Grizo [M:MHV1]SRV
Else
  Actzo [M:MHV1]SRV
Endif
End

Subprog AM_ALLPRF(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo [M:MHV1]PRF: Grizo [M:MHV1]PRF
Else
  Actzo [M:MHV1]PRF
Endif
End

Subprog AM_TYPINC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M:MHV1]10 : Grizo [M:MHV1]10
 Raz [M:MHV2]
 #89556
 If GREP="D" & [M:MHV1]NBVAR>0
  For nolign=1 To [M:MHV1]NBVAR
    [M:MHV1]VARVAL(nolign-1)=0
  Next
  Affzo [M:MHV1]15
 Endif
 #end 89556
Else
 Actzo [M:MHV1]10
 Gosub CHARGE_ENT
Endif
End

#72635
Subprog AM_ALLJOBPOT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo [M:MHV1]JOBPOT: Grizo [M:MHV1]JOBPOT
Else
  Actzo [M:MHV1]JOBPOT
Endif
End

Subprog AM_ALLPOT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo [M:MHV1]POT: Grizo [M:MHV1]POT
Else
  Actzo [M:MHV1]POT
Endif
End
#end 72635

Subprog C_ENAFLG1(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Chgstl [M:MHV1]NBVAR(nolign-1) With "CONTRAT"
Else
 Chgstl [M:MHV1]NBVAR(nolign-1) With ""
Endif
End

Subprog AS_VARVAL(VALEUR)
Variable Decimal VALEUR
#Pas saisir la valeur ici si Aug Individuelle
If [M:MHV1]TYPINC=2 : mkstat=1 : End : Endif
End

Subprog C_NBVAR
# En sortie du tableau
If adxgtb
 # Affichage du tableau 2
 If [M:MHV1]TYPINC=2
   Gosub NEWMSK
 Else
  Call AFFICHAGE (0)
 Endif
Endif
End

# Ouverture sous une nouvelle abrev du mask de l'onglet 2
# pour sauvegarder et restiture les valeurs déjà saisies
# avant insertions et/ou suppression dans la liste des variables (onglet 1)
$NEWMSK
Local Mask MHV2 [MHVZ]
[M:MHVZ]=[M:MHV2]
Raz [M:MHV2]
Call AFFICHAGE ([M:MHV1]NBVAR)
Gosub NEWCHARGE
Return

#Je replace les valeurs dans leur nouvelle colonne
#et j'initialise les nouvelles colonnes à 0
$NEWCHARGE
Local Char ZONE1 (50)
Local Char ZONE2 (50)
# Transclass pour récup infos matricule & nb lignes
[M:MHV2]=[M:MHVZ]
# Affectations des  valeurs
For I=1 To[M:MHV1]NBVAR
 For J=1 To [M:MHVZ]NBMAT
  If [M:MHV1]NUMCOL(I-1)>0
   ZONE1="[M:MHV2]VARVAL"+num$(I)+"("+num$(J-1)+")"
   ZONE2="[M:MHVZ]VARVAL"+num$([M:MHV1]NUMCOL(I-1))+"("+num$(J-1)+")"
   Assign ZONE1 With evalue(ZONE2)
  Else
   ZONE1="[M:MHV2]VARVAL"+num$(I)+"("+num$(J-1)+")"
   Assign ZONE1 With 0
  Endif
 Next
 #renumérotation des colonnes
 [M:MHV1]NUMCOL(I-1)=I
Next
[M:MHV2]NBMAT=[M:MHVZ]NBMAT
Affzo [M:MHV2]
Return

###############################################################################################################
# ECRAN 2
###############################################################################################################
Subprog C_NBMAT
## Bloque la saisie dans le tableau si Aug Générale
If !adxgtb & [M:MHV1]TYPINC<>2
 mkstat=2 : End
Endif
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char CTR(GLONHRCTR)
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Read [ID]ID0 =VALEUR
[M:MHV2]SRN(nolign-1) = [F:ID]NAM-[F:ID]SRN
# Contrôle déclenché que si salarié en mono-ctr
If [F:ID]FLGMULCTR<>2
 Call CHERCHE_CTR(VALEUR,date$,CTR) From DIVPAYE
 [M:MHV2]REFCTR(nolign-1)=VALEUR+"|"+CTR
 Call UNICITE([M:MHV2]REFCTR(nolign-1),[M:MHV2]REFCTR(0..[M:MHV2]NBMAT-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
If VALEUR="" : Call SELCTR([M:MHV2]REFNUM(nolign-1),date$,date$,VALEUR) From DIVPAYE : Endif
Read [ID]ID0 =[M:MHV2]REFNUM(nolign-1)
If fstat | [F:ID]FLGMULCTR<>2
 mkstat=2 : End
Endif
End

# Contrôle déclenché que si salarié en multi-ctr
Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
[M:MHV2]REFCTR(nolign-1)=[M:MHV2]REFNUM(nolign-1)+"|"+VALEUR
Call UNICITE([M:MHV2]REFCTR(nolign-1),[M:MHV2]REFCTR(0..[M:MHV2]NBMAT-1)) From OBJDIV
If mkstat=2 : End : Endif
End


###############################################################################################################
# Génération Traitement lié à l'hypoyhèse courante
# Ce traitement doit se nommer ainsi : "WPMS"+1+COD    (Chiffre 1 cause ML 485)
# L'étiquette doit se nommer  : "$HYPOVAR"
###############################################################################################################

#################################
Subprog GENHYPO(APPLI, CODHYP)
Value Char APPLI ()
Value Char CODHYP()
Local Integer AMT_AUG_IS_DECLARED :#89556

If clalev ([F:MHV2])=0 : Local File MSHYPVAH  [MHV2] : Endif
If clalev ([F:MHL2])=0 : Local File MSHYPVAL  [MHL2] : Endif
If clalev ([F:MHD2])=0 : Local File MSHYPVAD  [MHD2] : Endif
If clalev ([F:VRA])=0  : Local File VARIA      [VRA] : Endif

Local Char TETADO (50), PROG (30), FICSRC(250)
Local Integer OK
Local Char    SAVIFS(5) , SAVIRS(5)

SAVIFS = adxifs
SAVIRS = adxirs
adxifs = ""
adxirs = chr$(10)


Read [F:MHV2]MHV0=CODHYP
If !fstat
 TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
 PROG = "WPMS1"+[F:MHV2]COD
 FICSRC = filpath("TRT",PROG,"src",APPLI)
 Openo FICSRC , 0
 Wrseq TETADO-mess(17,10722,1) :#Hypothèse de variables
 Wrseq "###############################################"
 Wrseq "$HYPOVAR"
 If [F:MHV2]TYPINC=1 : Gosub AUG_GENER : Endif
 If [F:MHV2]TYPINC=2 : Gosub AUG_INDIV : Endif
 Openo
 Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Endif

adxirs = SAVIRS
adxifs = SAVIFS

End

###############################
$AUG_GENER
[L]AMT_AUG_IS_DECLARED = 0 :#89556
#CHECK IGNORE_BEGIN
Wrseq "OK=1"
If [F:MHV2]CPY<>""         : Wrseq "If SOCIETE <>'" +[F:MHV2]CPY    +"': OK = 0 : Return : Endif" : Endif
If [F:MHV2]FCY<>""         : Wrseq "If SITE <>'"    +[F:MHV2]FCY    +"': OK = 0 : Return : Endif" : Endif
If [F:MHV2]PRF<>""         : Wrseq "If PROFIL<>'"   +[F:MHV2]PRF    +"': OK = 0 : Return : Endif" : Endif
If [F:MHV2]SRV<>""         : Wrseq "If SERVICE<>'"  +[F:MHV2]SRV    +"': OK = 0 : Return : Endif" : Endif
#72635
If [F:MHV2]JOBPOT<>""      : Wrseq "If EMPLOITYP<>'" +[F:MHV2]JOBPOT    +"': OK = 0 : Return : Endif" : Endif
If [F:MHV2]POT<>""         : Wrseq "If POSTE<>'" +[F:MHV2]POT    +"': OK = 0 : Return : Endif" : Endif
#end 72635
If [F:MHV2]CRI<>""         : Wrseq "If !evalue('"   +[F:MHV2]CRI  +"') : OK = 0 : Return : Endif" : Endif
If [F:MHV2]POP<>""
 Wrseq "Read [HRPOA]POA0='"+[F:MHV2]POP+"';MATRI"   : # 66632
 Wrseq "If fstat : OK = 0 : Return : Endif"
Endif
Wrseq "If OK"
For [F:MHL2]MHL0 Where COD=[F:MHV2]COD & ENAFLG1=2
 Read [F:VRA]VRA0=GCURLEG;[F:MHL2]VARCOD
 If !fstat
  NEWSAL=0
  For [F:MHD2]MHD0 Where COD=CODHYP & VARCOD=[F:MHL2]VARCOD
   Case [F:MHL2]VARTYP
    When 1 :
      #89556
      If ![L]AMT_AUG_IS_DECLARED
        Wrseq space$(1)+"Local Double AMT_AUG"
        [L]AMT_AUG_IS_DECLARED +=1
      Endif
      Wrseq space$(1)+"[L]AMT_AUG ="-format$('K:15X','V_'+[F:VRA]COD)-'*'-num$([F:MHD2]VARVAL/100)
      #valeur plancher
      If [F:MHL2]AMTMIN : Wrseq space$(1)+"[L]AMT_AUG = max([L]AMT_AUG,"+num$([F:MHL2]AMTMIN)+")" : Endif
      #valeur planfond
      If [F:MHL2]AMTMAX : Wrseq space$(1)+"[L]AMT_AUG = min([L]AMT_AUG,"+num$([F:MHL2]AMTMAX)+")" : Endif
      #increase the variable by the computed amount
      Wrseq space$(1)+format$('K:15X','V_'+[F:VRA]COD)-'+= [L]AMT_AUG'
      #end 89556
    When 2 :  Wrseq space$(1)+format$('K:15X','V_'+[F:VRA]COD)-'+='-num$([F:MHD2]VARVAL)
    When 3 :  Wrseq space$(1)+format$('K:15X','V_'+[F:VRA]COD)-' ='-num$([F:MHD2]VARVAL)
   Endcase
  Next
 Endif
Next
Wrseq "Endif"
Wrseq "Return"
Wrseq
#CHECK IGNORE_END
Return

###############################################
$AUG_INDIV
[L]AMT_AUG_IS_DECLARED = 0 :#89556
For [F:MHL2]MHL0 Where COD=[F:MHV2]COD & ENAFLG1=2
 Read [F:VRA]VRA0=GCURLEG;[F:MHL2]VARCOD
 If !fstat
  NEWSAL=0
  #89556
  Case [F:MHL2]VARTYP
    When 1 :
     If ![L]AMT_AUG_IS_DECLARED
       Wrseq "Local Double AMT_AUG"
       [L]AMT_AUG_IS_DECLARED +=1
     Endif
     Wrseq "AMT_AUG = 0"
     For [F:MHD2]MHD0 Where COD=CODHYP & VARCOD=[F:MHL2]VARCOD
      Wrseq "If MATRI='"+[F:MHD2]REFNUM+"' & CTR='"+[F:MHD2]CTRNUM+"'"
       Wrseq space$(1)+"[L]AMT_AUG ="-format$('K:15X','V_'+[F:VRA]COD)-'*'-num$([F:MHD2]VARVAL/100)
       #valeur plancher
       If [F:MHL2]AMTMIN : Wrseq space$(1)+"[L]AMT_AUG = max([L]AMT_AUG,"+num$([F:MHL2]AMTMIN)+")" : Endif
       #valeur planfond
       If [F:MHL2]AMTMAX : Wrseq space$(1)+"[L]AMT_AUG = min([L]AMT_AUG,"+num$([F:MHL2]AMTMAX)+")" : Endif
       #increase the variable by the computed amount
       Wrseq space$(1)+format$('K:15X','V_'+[F:VRA]COD)-'+= [L]AMT_AUG'
      Wrseq "Endif"
    Next
    When 2 :
     For [F:MHD2]MHD0 Where COD=CODHYP & VARCOD=[F:MHL2]VARCOD
      Wrseq "If MATRI='"+[F:MHD2]REFNUM+"' & CTR='"+[F:MHD2]CTRNUM+"'"
      Wrseq space$(1)+format$('K:15X','V_'+[F:VRA]COD)-'+='-num$([F:MHD2]VARVAL)
      Wrseq "Endif"
     Next
    When 3 :
     For [F:MHD2]MHD0 Where COD=CODHYP & VARCOD=[F:MHL2]VARCOD
      Wrseq "If MATRI='"+[F:MHD2]REFNUM+"' & CTR='"+[F:MHD2]CTRNUM+"'"
      Wrseq space$(1)+format$('K:15X','V_'+[F:VRA]COD)-' ='-num$([F:MHD2]VARVAL)
      Wrseq "Endif"
     Next
  Endcase
  #89556
 Endif
Next
Wrseq "Return"
Return

#89556
# On grise les colonnes AMTMIN et AMTMAX si augmentation pas de type %
# car inutile si type valeur ou affectation.
Subprog AM_VARTYP(VALEUR)
Variable Integer VALEUR
Call AFF_AMTMINMAX(VALEUR)
End

Subprog AFF_AMTMINMAX(VALEUR)
Value Integer VALEUR
If VALEUR>1
  Raz [M:MHV1]AMTMIN(nolign-1) : Grizo [M:MHV1]AMTMIN(nolign-1)
  Raz [M:MHV1]AMTMAX(nolign-1) : Grizo [M:MHV1]AMTMAX(nolign-1)
Else
  Actzo [M:MHV1]AMTMIN(nolign-1)
  Actzo [M:MHV1]AMTMAX(nolign-1)
Endif
End
######################################################################################
