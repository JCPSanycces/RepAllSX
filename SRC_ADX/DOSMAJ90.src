#<AdxTL>@(#)0.0.0.0 $Revision$
##################################################################################
# DOSMAJ90 : Mises à jour à effectuer lors du passage à la version 12 (Release 90)
# Moulinette avant version 11
##################################################################################


#-------------------------------------#
#         Avant mise à jour           #
#-------------------------------------#

#######################################
Subprog AMAJ
Local Integer RELEASE
Local Integer OKTRT

Onerrgo ERREUR

RELEASE = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ90 - AMAJ - RELEASE = "-num$(RELEASE),-1) From GESECRAN

#----- Superviseur en premier
Call EXISTE_ADX("","","SUPMAJ90",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJDIC SUPMAJ90 *************",-1) From GESECRAN
#----- Préparation Superviseur :
# Rajout des types de données
# Rajout des codes activités
# Rajout des nouveaux champs
  Call MAJDIC From SUPMAJ90

  Call ECR_TRACE("************** AMAJ SUPMAJ90 ***************",-1) From GESECRAN
  Call AMAJ From SUPMAJ90 : # Moulinettes Superviseur
Endif


#----- Puis Tronc commun

Call EXISTE_ADX("","","TRCMAJ90",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ TRCMAJ90 ***************",-1) From GESECRAN
  Call AMAJ From TRCMAJ90
Endif

#----- Ensuite les autres modules

Call EXISTE_ADX("","","CPTMAJ90",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ CPTMAJ90 ***************",-1) From GESECRAN
  Call AMAJ From CPTMAJ90 : # Moulinettes Compta
Endif

Call EXISTE_ADX("","","TRSMAJ90",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ TRSMAJ90 ***************",-1) From GESECRAN
  Call AMAJ From TRSMAJ90 : # Moulinettes Tiers
Endif

Call EXISTE_ADX("","","VENMAJ90",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ VENMAJ90 ***************",-1) From GESECRAN
  Call AMAJ From VENMAJ90 : # Moulinettes Ventes
Endif

#JASMI - 2017-12-06 - X3-47299 - START
If GPRODUIT=2 #X3 People
  Call EXISTE_ADX("","","EMHRMAJ90",OKTRT) From ORDSYS
  If OKTRT
    Call ECR_TRACE("************** AMAJ EMHRMAJ90 ***************",-1) From GESECRAN
    Call AMAJ From EMHRMAJ90 #Update X3 People version 9 to version 12
  Endif
Endif
#JASMI - 2017-12-06 - X3-47299 - END

Call EXISTE_ADX("","","ACHMAJ90",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ ACHMAJ90 ***************",-1) From GESECRAN
    Call AMAJ From ACHMAJ90 : # Moulinettes Achats
Endif

# Issue 112754 - 2017-01-27 by SR : Validation des TRT générés Achats (transactions, tarifs)
If  [F:ADS]MODULE(5)=2
    GVALTRANS(6)=2
Endif

Call EXISTE_ADX("","","STOMAJ90",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ STOMAJ90 ***************",-1) From GESECRAN
  Call AMAJ From STOMAJ90 : # Moulinettes Stocks
Endif

Call EXISTE_ADX("","","GPAMAJ90",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ GPAMAJ90 ***************",-1) From GESECRAN
  Call AMAJ From GPAMAJ90 : # Moulinettes GPAO
Endif

Call EXISTE_ADX("","","CRMMAJ90",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ CRMMAJ90 ***************",-1) From GESECRAN
  Call AMAJ From CRMMAJ90 : # Moulinettes HDK (support client)
Endif

Call EXISTE_ADX("","","FASMAJ90",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ FASMAJ90 ***************",-1) From GESECRAN
  Call AMAJ From FASMAJ90 : # Moulinettes Immobilisations
Endif

Onerrgo
End



#-------------------------------------#
#          Après mise à jour          #
#-------------------------------------#

#######################################
