Onerrgo ERREUR

RELEASE = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ90 - MAJ - RELEASE = "-num$(RELEASE),-1) From GESECRAN

