#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################################################
#   Traitement de gestion d'un appel entrant                           Module CRM         28 juillet 2000
#########################################################################################################
#########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "AVANT_MEN"    : Gosub AVANT_MEN
    When Default
  Endcase
Return

#########################################################################################################
$OUVRE
  #PARAM(1) : Chrono fiche parc
  #PARAM(2) : Utilisateur final
  If PARAM(1) = "" Then
    #Aucun code de fiche parc n'a été communiquée. Accès refusé.
    GMESSAGE = mess(425,182,1)
    GERR = 1
    FIN = 1
  Endif
  If PARAM(2) = "" Then
    #Aucun utilisateur final n'a été communiqué. Accès refusé.
    GMESSAGE = mess(428,182,1)
    GERR = 1
    FIN = 1
  Endif
  If !clalev([F:CCV]) : Local File CONTCOV [CCV] : Endif
  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:PBL]) : Local File FAMPB [PBL] : Endif
Return

#########################################################################################################
$DEFBOUT
Return

#########################################################################################################
$SETBOUT
Return

#########################################################################################################
$OUVRE_BOITE
Return

#########################################################################################################
$DEBUT
  #Liste des couvertures indirectes applicables à la fiche parc : 
  [M:MACE]MACNUM = PARAM(1)
  [M:MACE]BPC = PARAM(2)
  [M:MACE]TTR = mess(424,182,1) - [M:MACE]MACNUM
  Read [BPR]BPR0=[M:MACE]BPC
  If fstat Then
    [M:MACE]BPCNAM = ""
  Else
    [M:MACE]BPCNAM = [F:BPR]BPRNAM
  Endif
  Read [MAC]MAC0=[M:MACE]MACNUM
  If fstat Then
    #Erreur lors de la lecture des couvertures indirectes.
    GMESSAGE = mess(426,182,1)
    GERR = 1
    FIN = 1
    Return
  Else
    If [F:MAC]MACPDTCOD = "" Then
      #La fiche parc indiquée ne comporte par de code article. Lecture abandonnée.
      GMESSAGE = mess(427,182,1)
      GERR = 1
      FIN = 1
      Return
    Else
      Read [ITM]ITM0=[F:MAC]MACPDTCOD
      If fstat Then
        #Erreur lors de la lecture des couvertures indirectes.
        GMESSAGE = mess(426,182,1)
        GERR = 1
        FIN = 1
        Return
      Else
        [M:MACE]ITMREF = [F:MAC]MACPDTCOD
        [M:MACE]FAMCIA = [F:ITM]TSICOD(GFAMCIA-1)
      Endif
    Endif
  Endif
  Gosub LOADMAC8
  Gosub LOADMAC9
  Affzo [M:MACE]
  Affzo [M:MAC8]
  Affzo [M:MAC9]
Return

#########################################################################################################
$AV_CHOIX
Return

#########################################################################################################
AP_CHOIX
Return

#########################################################################################################
$AVANT_BOUTON
Return

#########################################################################################################
$AVANT_MEN
Return

#########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:MACE]
  Raz [M:MAC8]
  Raz [M:MAC9]
Return

#########################################################################################################
$FIN
Return

#########################################################################################################
$ABANDON
Return

#########################################################################################################
$APRES_MODIF
Return

#########################################################################################################
$BOUTON
Return

#########################################################################################################
$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################
# Chargement des couvertures normales
#########################################################################################################
$LOADMAC8
  Raz [M:MAC8]
  #Couverture de niveau référence article
  Filter [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]BPC = [M:MACE]BPC and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "ITM"
&                and [F:CCV]CMT = [M:MACE]ITMREF and [F:CCV]PAEKEY(0) = ""
  For [CCV]CCV1
    If [M:MAC8]NBNOR >= dim([M:MAC8]CONNUM)-1 Then
      Break
    Endif
    Gosub SETMAC8LINE
  Next
  Filter [CCV]
  #Couverture de niveau famille commerciale
  Filter [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]BPC = [M:MACE]BPC and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "CIA"
&                and [F:CCV]CMT = [M:MACE]FAMCIA and [F:CCV]PAEKEY(0) = ""
  For [CCV]CCV1
    If [M:MAC8]NBNOR >= dim([M:MAC8]CONNUM)-1 Then
      Break
    Endif
    Gosub SETMAC8LINE
  Next
  Filter [CCV]
  #Couverture de type tous le parc
  # FGR 19/08/2009 : X3SUIVI57246 Ajout du site dans le filtre
  Filter [CON] Where [F:CON]CONBPC = [M:MACE]BPC and [F:CON]EVRMAC = 2 and [F:CON]SALFCY = [F:MAC]SALFCY
  For [CON]CON2
    If [M:MAC8]NBNOR >= dim([M:MAC8]CONNUM)-1 Then
      Break
    Endif
    [M:MAC8]CONNUM([M:MAC8]NBNOR) = [F:CON]CONNUM
    [M:MAC8]CONNAM([M:MAC8]NBNOR) = [F:CON]CONNAM
    [M:MAC8]CONCAT([M:MAC8]NBNOR) = [F:CON]CONCAT
    [M:MAC8]CONSTRDAT([M:MAC8]NBNOR) = [F:CON]CONSTRDAT
    [M:MAC8]CONENDDAT([M:MAC8]NBNOR) = [F:CON]CONENDDAT
    [M:MAC8]CONBPC([M:MAC8]NBNOR) = [F:CON]CONBPC
    [M:MAC8]FDDFLG([M:MAC8]NBNOR) = [F:CON]FDDFLG
    [M:MAC8]RSIFLG([M:MAC8]NBNOR) = [F:CON]RSIFLG
    [M:MAC8]COVTYP([M:MAC8]NBNOR) = 4
    If [M:MAC8]CONBPC([M:MAC8]NBNOR) = "" Then
      [M:MAC8]CONBPCNAM([M:MAC8]NBNOR) = ""
    Else
      Read [BPR]BPR0=[M:MAC8]CONBPC([M:MAC8]NBNOR)
      If fstat Then
        [M:MAC8]CONBPCNAM([M:MAC8]NBNOR) = ""
      Else
        [M:MAC8]CONBPCNAM([M:MAC8]NBNOR) = [F:BPR]BPRNAM
      Endif
    Endif
    [M:MAC8]NBNOR += 1
  Next
  Filter [CON]
Return

#########################################################################################################
$SETMAC8LINE
  # FGR 19/08/2009 : X3SUIVI57246 Ajout du site dans le filtre (début)
  Read [CON]CON0=[F:CCV]CONNUM
  If not fstat Then
    If [F:CON]SALFCY <> [F:MAC]SALFCY Then
      Raz [F:CON]
      Return
    Endif
  Endif
  [M:MAC8]CONNUM([M:MAC8]NBNOR) = [F:CCV]CONNUM
  #Read [CON]CON0=[M:MAC8]CONNUM([M:MAC8]NBNOR)
  # FGR 19/08/2009 : X3SUIVI57246 Ajout du site dans le filtre (fin)
  If fstat Then
    [M:MAC8]CONNAM([M:MAC8]NBNOR) = ""
    [M:MAC8]CONCAT([M:MAC8]NBNOR) = 0
    [M:MAC8]CONSTRDAT([M:MAC8]NBNOR) = [00/00/00]
    [M:MAC8]CONENDDAT([M:MAC8]NBNOR) = [00/00/00]
    [M:MAC8]CONBPC([M:MAC8]NBNOR) = ""
    [M:MAC8]FDDFLG([M:MAC8]NBNOR) = 1
    [M:MAC8]RSIFLG([M:MAC8]NBNOR) = 1
  Else
    [M:MAC8]CONNAM([M:MAC8]NBNOR) = [F:CON]CONNAM
    [M:MAC8]CONCAT([M:MAC8]NBNOR) = [F:CON]CONCAT
    [M:MAC8]CONSTRDAT([M:MAC8]NBNOR) = [F:CON]CONSTRDAT
    [M:MAC8]CONENDDAT([M:MAC8]NBNOR) = [F:CON]CONENDDAT
    [M:MAC8]CONBPC([M:MAC8]NBNOR) = [F:CON]CONBPC
    [M:MAC8]FDDFLG([M:MAC8]NBNOR) = [F:CON]FDDFLG
    [M:MAC8]RSIFLG([M:MAC8]NBNOR) = [F:CON]RSIFLG
  Endif
  Case [F:CCV]SBBRECTYP
    When "MAC"
      [M:MAC8]COVTYP([M:MAC8]NBNOR) = 1
    When "ITM"
      [M:MAC8]COVTYP([M:MAC8]NBNOR) = 2
    When "CIA"
      [M:MAC8]COVTYP([M:MAC8]NBNOR) = 3
  Endcase
  If [M:MAC8]CONBPC([M:MAC8]NBNOR) = "" Then
    [M:MAC8]CONBPCNAM([M:MAC8]NBNOR) = ""
  Else
    Read [BPR]BPR0=[M:MAC8]CONBPC([M:MAC8]NBNOR)
    If fstat Then
      [M:MAC8]CONBPCNAM([M:MAC8]NBNOR) = ""
    Else
      [M:MAC8]CONBPCNAM([M:MAC8]NBNOR) = [F:BPR]BPRNAM
    Endif
  Endif
  [M:MAC8]NBNOR += 1
Return

#########################################################
# Chargement des couvertures croisées
#########################################################################################################
$LOADMAC9
  Raz [M:MAC9]
  #Couverture de niveau fiche parc
  Filter [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC" and [F:CCV]CMT = [M:MACE]MACNUM and [F:CCV]PAEKEY(0) <> ""
  For [CCV]
    If [M:MAC9]NBCRS >= dim([M:MAC9]PBL)-1 Then
      Break
    Endif
    Gosub SETMAC9LINE
  Next
  Filter [CCV]
  #Couverture de niveau référence article
  Filter [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]BPC = [M:MACE]BPC and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "ITM" and [F:CCV]CMT = [M:MACE]ITMREF
&                and [F:CCV]PAEKEY(0) <> ""
  For [CCV]CCV1
    If [M:MAC9]NBCRS >= dim([M:MAC9]PBL)-1 Then
      Break
    Endif
    Gosub SETMAC9LINE
  Next
  Filter [CCV]
  #Couverture de niveau famille commerciale
  Filter [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]BPC = [M:MACE]BPC and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "CIA" and [F:CCV]CMT = [M:MACE]FAMCIA
&                and [F:CCV]PAEKEY(0) <> ""
  For [CCV]CCV1
    If [M:MAC9]NBCRS >= dim([M:MAC9]PBL)-1 Then
      Break
    Endif
    Gosub SETMAC9LINE
  Next
  Filter [CCV]
Return

#########################################################################################################
$SETMAC9LINE
  [M:MAC9]PBL([M:MAC9]NBCRS) = [F:CCV]PAEKEY(0)
  Read [PBL]PBL0=[M:MAC9]PBL([M:MAC9]NBCRS)
  If fstat Then
    [M:MAC9]PBLNAM([M:MAC9]NBCRS) = ""
  Else
    # FGR 23/09/2009 : X3SUIVI58024
    #[M:MAC9]PBLNAM([M:MAC9]NBCRS) = [F:PBL]GRPPBLDES
    Call LECTEXTRA([M:MAC9]PBLNAM([M:MAC9]NBCRS),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
  Endif
  [M:MAC9]BCONNUM([M:MAC9]NBCRS) = [F:CCV]CONNUM
  Read [CON]CON0=[M:MAC9]BCONNUM([M:MAC9]NBCRS)
  # FGR 19/08/2009 : X3SUIVI57246 Ajout du site dans le filtre (début)
  If not fstat Then
    If [F:CON]SALFCY <> [F:MAC]SALFCY Then
      Raz [F:CON]
      Raz [M:MAC9]PBLNAM([M:MAC9]NBCRS)
      Raz [M:MAC9]BCONNUM([M:MAC9]NBCRS)
      Return
    Endif
  Endif
  # FGR 19/08/2009 : X3SUIVI57246 Ajout du site dans le filtre (fin)
  If fstat Then
    [M:MAC9]BCONNAM([M:MAC9]NBCRS) = ""
    [M:MAC9]BCONCAT([M:MAC9]NBCRS) = 0
    [M:MAC9]BCONSTRDAT([M:MAC9]NBCRS) = [00/00/00]
    [M:MAC9]BCONENDDAT([M:MAC9]NBCRS) = [00/00/00]
    [M:MAC9]BCONBPC([M:MAC9]NBCRS) = ""
    [M:MAC9]BFDDFLG([M:MAC9]NBCRS) = 1
    [M:MAC9]BRSIFLG([M:MAC9]NBCRS) = 1
  Else
    [M:MAC9]BCONNAM([M:MAC9]NBCRS) = [F:CON]CONNAM
    [M:MAC9]BCONCAT([M:MAC9]NBCRS) = [F:CON]CONCAT
    [M:MAC9]BCONSTRDAT([M:MAC9]NBCRS) = [F:CON]CONSTRDAT
    [M:MAC9]BCONENDDAT([M:MAC9]NBCRS) = [F:CON]CONENDDAT
    [M:MAC9]BCONBPC([M:MAC9]NBCRS) = [F:CON]CONBPC
    [M:MAC9]BFDDFLG([M:MAC9]NBCRS) = [F:CON]FDDFLG
    [M:MAC9]BRSIFLG([M:MAC9]NBCRS) = [F:CON]RSIFLG
  Endif
  Case [F:CCV]SBBRECTYP
    When "MAC"
      [M:MAC9]BCOVTYP([M:MAC9]NBCRS) = 1
    When "ITM"
      [M:MAC9]BCOVTYP([M:MAC9]NBCRS) = 2
    When "CIA"
      [M:MAC9]BCOVTYP([M:MAC9]NBCRS) = 3
  Endcase
  If [M:MAC9]BCONBPC([M:MAC9]NBCRS) = "" Then
    [M:MAC9]BCONBPCNAM([M:MAC9]NBCRS) = ""
  Else
    Read [BPR]BPR0=[M:MAC9]BCONBPC([M:MAC9]NBCRS)
    If fstat Then
      [M:MAC9]BCONBPCNAM([M:MAC9]NBCRS) = ""
    Else
      [M:MAC9]BCONBPCNAM([M:MAC9]NBCRS) = [F:BPR]BPRNAM
    Endif
  Endif
  [M:MAC9]NBCRS += 1
Return
