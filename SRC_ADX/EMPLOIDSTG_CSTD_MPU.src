#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
  When "PROPVALUE"          : Gosub PROPVALUE
  When "EMPLOID_AINSERT"    : Gosub EMPLOID_AINSERT
Endcase
Return




$PROPVALUE
#(PPROPERTY,PVALUE,PLEG,PERROR_MSG) - Parameters
Gosub PROPVALUE From PIHRMFAIR_FUNCTIONS
Return



$EMPLOID_AINSERT
#Parameter BID_DATA
#Parameter INTCLASS Using C_PIHRMFAIR
#Parameter INTUID
#Parameter TOKENVAL
#Parameter BID_SERV
#Parameter PROCESSID
#Parameter LEG

Local Char ERRTABLE(GLONATB)

#Setting the return value for the method
[L]ARET_VALUE = [V]CST_AOK

#Clear the data for all employee staging classes
If func DELETE_STG_TABLE(ERRTABLE) = [V]CST_AERROR
  #Add message for user
  [L]ARET_VALUE = fmet this.ASETERROR("",mess(00010,11820,1)-ERRTABLE,[V]CST_AERROR)
  Return
Endif


#Declare all variables and instances needed
Gosub DECLARE_INSTANCE_VARIABLES  From PIHRMFAIR_FUNCTIONS

#Calling the payroll batch
If func PIHRMFAIR_FUNCTIONS.PAYROLL_BATCH_REQUEST(INTCLASS,TOKENVAL,HTTP_FUNC,W_MESS_FUNC,PAYBATCH_RESBODY,PAYBATCH_RESHEAD,PROCESSID,BID_DATA,BID_SERV) = [V]CST_AERROR
  #Handle the error
  [L]ARET_VALUE = fmet this.ASETERROR("",mess(00011,11820,1)-num$(HTTP_FUNC)+":"+W_MESS_FUNC,[V]CST_AERROR)
  Return
Endif

#Parsing the Json file from the payroll batch
If [L]ARET_VALUE = [V]CST_AOK
  If func PIHRMFAIR_FUNCTIONS.PARSE_JSON_BATCHLIST(INTCLASS,PAYBATCH_RESBODY,PAYROLLBATCHID,PAGECOUNT) = [V]CST_AERROR
    [L]ARET_VALUE = fmet this.ASETERROR("",mess(00009,11820,1),[V]CST_AERROR)
    Return
  Endif
Endif

#Calling the member list
#Convert the pagecount to int and process the members per page
INT_PAGECOUNT = val(PAGECOUNT)

#Loop through the pages
If [L]ARET_VALUE = [V]CST_AOK
  For I = 0 To INT_PAGECOUNT
    Raz EMPLOYEE_RESBODY
    Raz EMPLOYEE_RESHEAD
    If func PIHRMFAIR_FUNCTIONS.GET_EMPLOYEE_LIST(INTCLASS.TIMSEC,HTTP_FUNC,TOKENVAL,EMPLOYEE_RESBODY,EMPLOYEE_RESHEAD,PAYROLLBATCHID,PROCESSID,I,W_MESS_FUNC) = [V]CST_AERROR
      [L]ARET_VALUE = fmet this.ASETERROR("",mess(00008,11820,1)-num$(HTTP_FUNC)+":"+W_MESS_FUNC,[V]CST_AERROR)
      Break
      Return
    Else
      #Convert return body and process
      RETBODY_UNESCJSON_MEMBER=unescJson(EMPLOYEE_RESBODY)

      #Process
      [L]ARET_VALUE  = func PARSE_JSON_EMPLOYEE(INTCLASS,RETBODY_UNESCJSON_MEMBER,INTUID,LEG,PROCESSID)
    Endif
  Next I
Endif


#Check for errors and send messages back
#If [L]ARET_VALUE = [V]CST_AOK
  Raz EMPLOYEE_RESBODY
  Raz EMPLOYEE_RESHEAD
  [L]ARET_VALUE = func PIHRMFAIR_FUNCTIONS.SEND_ERRORLIST(HTTP_FUNC,TOKENVAL,PAYROLLBATCHID,PROCESSID,W_MESS_FUNC,LEG,PROCESSID,INTUID)
  If [L]ARET_VALUE = [V]CST_AERROR
    [L]ARET_VALUE = fmet this.ASETERROR("","Not able to send error list"-num$(HTTP_FUNC)+":"+W_MESS_FUNC,[V]CST_AERROR)
  Endif
#Endif

Return


$SET_GET_BATCHLIST
#Set variables for the batch list
AUTHOR = "Bearer"

WEBSERNAME = "FAIRSAILINS"
HTTPMETHOD = "POST"
SUBURL =  "/services/apexrest/"+V_BID_SERV

HCOD(1) = "Content-Type"
HVAL(1) = '"application/json"'

###Bearer fixed + get from URL"
HCOD(2) = "Authorization"
HVAL(2) ='"'+AUTHOR + " " +TOKENVAL+'"'

DATA_SENT = V_BID_DATA

FUTURE=0 : # We wait for the answer
Return



$SET_EMPLOYEE_ERROR
AUTHOR = "Bearer"

WEBSERNAME = "FAIRSAILINS"
HTTPMETHOD = "POST"
#The SUBURL is now build up using the response from the previous call
#If the pagecount is 0/"" it means no paging was done. This might be the case where all the data is only vailable on single or all members

SUBURL =  "/services/apexrest"+V_PAYROLLBATCHID+"/teammembers/"+V_TEAMMEMBERID+"/errors"

HCOD(1) = "Content-Type"
HVAL(1) = '"application/json"'

###Bearer fixed + get from URL"
HCOD(2) = "Authorization"
HVAL(2) = '"'+AUTHOR + " " +TOKENVAL+'"'

FUTURE=0 : # We wait for the answer
Return

$BUILD_DATA_ERROR


Return


$SET_EMPLOYEE_REQUEST
AUTHOR = "Bearer"

WEBSERNAME = "FAIRSAILINS"
HTTPMETHOD = "GET"
#The SUBURL is now build up using the response from the previous call
#If the pagecount is 0/"" it means no paging was done. This might be the case where all the data is only vailable on single or all members
If VPAGECOUNT = 0
  SUBURL =  "/services/apexrest"+V_PAYROLLBATCHID+"/teammembers"
Else
  SUBURL =  "/services/apexrest"+V_PAYROLLBATCHID+"/teammembers?page="+num$(VPAGECOUNT)
Endif

HCOD(1) = "Content-Type"
HVAL(1) = '"application/json"'

###Bearer fixed + get from URL"
HCOD(2) = "Authorization"
HVAL(2) = '"'+AUTHOR + " " +TOKENVAL+'"'

DATA_SENT = "{}"
FUTURE=0 : # We wait for the answer
Return

Funprog PARSE_JSON_EMPLOYEE(I_PCLASS,V_EMPLOYEE_RESBODY,VUNIQID,VLEG,VPROCESSID)
Variable Instance I_PCLASS Using C_PIHRMFAIR
Value Char VLEG
Value Clbfile V_EMPLOYEE_RESBODY
Value Integer VUNIQID,VPROCESSID
Local Integer I_NODE,FIRSTREC, INITCLASS
Local Integer RETVAL : RETVAL = [V]CST_AERROR
Local Integer PROPRETVAL,WRITE_OK,TRANSACTION_PENDING
Local Char PROPVAL(255),PROPERTY(50)
Local Char ACTIVE_CLASS(GLONACLA),CLASS_CHECK(GLONACLA)

RETVAL = [V]CST_AOK
WRITE_OK  = [V]CST_AOK

#Declare NODES
Gosub INIT_NODE From PIHRMFAIR_FUNCTIONS

#Clear the Json table
Local File PIHRMFAIRNOD [PHND1]
Lock [PHND1]
If fstat = [V]CST_AOK
  Delete [PHND1] Where PRO >= ""
  If fstat <> [V]CST_AOK
    End [V]CST_AERROR
  Endif
  Unlock [PHND1]
Else
  End [V]CST_AERROR
Endif

TRANSACTION_PENDING=adxlog
If TRANSACTION_PENDING=0 : Trbegin [PHND1] : Endif

#Insert the Json file into the ASYRJSO (Supervisor) class
If func ASYRJSONPARSE.PARSEJSON(I_PCLASS.ACTX,V_EMPLOYEE_RESBODY,NODES,NODE) = [V]CST_AOK
  RETVAL = [V]CST_AOK
  For [L]I_NODE = 1 To maxtab(NODES)
    #For [L]I_NODE = 1 To
    If (NODES([L]I_NODE) <> null)
      If  NODES([L]I_NODE).START = 0 or NODES([L]I_NODE).LENGTH <3 #Get rid of the """
        PROPVAL = ""
      Else
        PROPVAL = mid$(NODES([L]I_NODE).CLB.CLB,NODES([L]I_NODE).START+1,NODES([L]I_NODE).LENGTH-2)
      Endif
      Raz [PHND1]
      [F:PHND1]LIGNUM = [L]I_NODE
      [F:PHND1]PRO = NODES([L]I_NODE).PRO
      [F:PHND1]NODVAL = num$(PROPVAL)
      Write [PHND1]
      If fstat <> [V]CST_AOK
        Break
        WRITE_OK  = [V]CST_AERROR
      Endif
    Endif
  Next
Endif

If TRANSACTION_PENDING=0
  If WRITE_OK <> [V]CST_AOK
    Rollback
    End [V]CST_AERROR
  Else
    Commit
  Endif
Endif

LogicClose File [PHND1]

#Loop through the table and write the classes
Local File PIHRMFAIRNOD [PHND2]
Filter [F:PHND2] Where PRO <> "" Order By Key PHND1 Asc
For [PHND2]PHND1
  #Check each property and get the mapped code for the class
  #Each class will be initiated by the mapped code XXX and "a" - XXXX_a
  If mid$([F:PHND2]PRO,6,1) = "a"
    #Set the active class
    ACTIVE_CLASS = func PIHRMFAIR_FUNCTIONS.GET_MAPPED_TABLE(mid$([F:PHND2]PRO,1,4))
    #Initiate the class
    If ACTIVE_CLASS <> AVOID.ACHAR
        Gosub INIT_CURRCLASS From =ACTIVE_CLASS+"_CSTD_MPU"
        If INITCLASS <> [V]CST_AOK
          ACTIVE_CLASS = "9999999"
        Endif
    Endif
  Endif

  #Add properties to the active class
  If mid$([F:PHND2]PRO,6,1) <> "a" and mid$([F:PHND2]PRO,6,1) <> "Z" and [F:PHND2]PRO <> ""
    CLASS_CHECK = func PIHRMFAIR_FUNCTIONS.GET_MAPPED_TABLE(mid$([F:PHND2]PRO,1,4))
    If CLASS_CHECK <> AVOID.ACHAR and CLASS_CHECK = ACTIVE_CLASS
      #Add property
        PROPERTY = mid$([F:PHND2]PRO,6,45)
        PROPVAL = [F:PHND2]NODVAL
        Gosub PROPVAL_INIT From =ACTIVE_CLASS+"_CSTD_MPU"
        If PROPRETVAL <> [V]CST_AOK
          #Handle the error
        Endif
    Endif
  Endif

  #Write the record to the class
  If mid$([F:PHND2]PRO,6,1) = "Z"
    CLASS_CHECK = func PIHRMFAIR_FUNCTIONS.GET_MAPPED_TABLE(mid$([F:PHND2]PRO,1,4))
    If CLASS_CHECK <> AVOID.ACHAR and CLASS_CHECK = ACTIVE_CLASS
      #Write
      Gosub WRITE_CURRCLASS From =ACTIVE_CLASS+"_CSTD_MPU"
    Endif
  Endif
 Next
Gosub FREE_NODE From PIHRMFAIR_FUNCTIONS

End RETVAL


$INIT_CURRCLASS
Local Integer EMPSTGINIT
Local Instance  I_EMPLOIDSTG  Using C_EMPLOIDSTG
I_EMPLOIDSTG  = NewInstance C_EMPLOIDSTG AllocGroup null
INITCLASS  = [V]CST_AOK
Return

$WRITE_CURRCLASS
Local Integer WRITESTATUS,ERRHANDLE
#Invoke the creation process and handle the error if applicable
#We will always invoke creation here as it is the staging tables
#Before writing the values - we need to check for errors

#Add system properties / keys
I_EMPLOIDSTG.INTUID = VUNIQID

#Additional handling
#Control of fields or Legislation specific handling
Gosub CONTROL_FIELDS

#Handle possible errors - ERRHANLDE will be called before and during the AINSERT
#ERRHANDLE = func PIHRMFAIR_FUNCTIONS.HANDLE_EMPLOYEE_ERRORS_CLASS(I_EMPLOIDSTG,"Employment",1,"Validation","ERROR",VUNIQID,VLEG,VPROCESSID,I_EMPLOIDSTG.INTID,I_EMPLOIDSTG.REFNUM,ACTIVE_CLASS)

[L]WRITESTATUS = fmet I_EMPLOIDSTG.AINSERT()
If ([L]WRITESTATUS >= [V]CST_AERROR)
  ERRHANDLE = func PIHRMFAIR_FUNCTIONS.HANDLE_EMPLOYEE_ERRORS_CLASS(I_EMPLOIDSTG,"Employment",1,"Validation","ERROR",VUNIQID,VLEG,VPROCESSID,I_EMPLOIDSTG.INTID,I_EMPLOIDSTG.REFNUM,ACTIVE_CLASS)
Endif

Gosub FREE_CURRCLASS
Return

$FREE_CURRCLASS
FreeGroup I_EMPLOIDSTG
Return

#**
#* Label for deleting the staging table(s)
#* @param Local char (GLONATB) VERRTABLE, returns the first table that could not be cleared
#* @return CST_AERROR or CST_AOK
#*!
Funprog DELETE_STG_TABLE(VERRTABLE)
Variable Char VERRTABLE
Local Integer DEL_OK

Local File PIHRMFAIRERR [PHFE1]
Local File EMPLOIDSTG   [ESTG1]
Local File EMPLOCTRSTG  [HRCSG1]
Local File EMPUKISTG    [IDUSG1]
Local File EMPCTRUKISTG [CTRUSG1]
Local File EMPLORIBSTG  [RIBSG1]

TRANSACTION_PENDING=adxlog
If TRANSACTION_PENDING=0
  Trbegin [ESTG1],[HRCSG1],[IDUSG1],[CTRUSG1],[RIBSG1]
Endif

VERRTABLE = "EMPLOIDSTG"
Delete [ESTG1] Where REFNUM >= ""

VERRTABLE = "EMPLOCTRSTG"
Delete [HRCSG1] Where REFNUM >= ""

VERRTABLE = "EMPUKISTG"
Delete [IDUSG1] Where REFNUM >= ""

VERRTABLE = "EMPCTRUKISTG"
Delete [CTRUSG1] Where [CTRUSG1]REFNUM >= ""

VERRTABLE = "EMPLORIBSTG"
Delete [RIBSG1] Where REFNUM >= ""

If TRANSACTION_PENDING=0
  If DEL_OK <> [V]CST_AOK
    Rollback
    End [V]CST_AERROR
  Else
    Commit
  Endif
Endif

LogicClose File     [ESTG1]
LogicClose File     [HRCSG1]
LogicClose File     [IDUSG1]
LogicClose File     [CTRUSG1]
LogicClose File     [RIBSG1]

End [V]CST_AOK


$HANDLE_DEL
If fstat <> [V]CST_AOK
  DEL_OK = [V]CST_AERROR
Endif
Return

$EMPLOID_UPDATE
Local Integer READSTATUS,UPDSTATUS,WRITESTATUS,INITSTATUS

#This was set as a method on the class but removed and set as normal prog
#Setting the return value for the method
[L]ARET_VALUE = [V]CST_AWARNING
[L]INITSTATUS = [V]CST_AWARNING
[L]WRITESTATUS = [V]CST_AERROR

#Instantiate the employee class
Local Instance  I_EMPINS  Using C_EMPINS
If (I_EMPINS  <> null) : FreeGroup I_EMPINS  : Endif
I_EMPINS  = NewInstance C_EMPINS AllocGroup null
READSTATUS = fmet I_EMPINS.AREAD(I_EMPLOIDSTG_UPD.REFNUM)
#Test the read status to decide if the record must be updated or created
If READSTATUS = [V]CST_AOK
  #Record exist - Update
  Gosub UPDATE_FIELD From EMPINS_CSTD
  [L]ARET_VALUE = UPDSTATUS
Else
  INITSTATUS    = fmet I_EMPINS.AINIT()
  If INITSTATUS = [V]CST_AOK
    Gosub DUPLICATE From EMPINS_CSTD
    [L]ARET_VALUE = WRITESTATUS
  Endif
Endif

Return

$PROPVAL_INIT
Local Char ERROR_MSG(250)
Local Integer INVOKE_ERROR
PROPRETVAL = fmet I_EMPLOIDSTG.PROPVALUE(PROPERTY,PROPVAL,VLEG,ERROR_MSG)

##Handle the possible error - Add it as a warning and let the supervisor handle it on CRUD
#If ([L]PROPRETVAL >= [V]CST_AWARNING)
#  INVOKE_ERROR = fmet I_EMPLOIDSTG.ASETERROR(PROPERTY,ERROR_MSG,PROPRETVAL)
#Endif
Return

$CONTROL_FIELDS
#Updating the legislation - this might be added to the Json file from People
I_EMPLOIDSTG.TCH_LEG = VLEG
Return

$CLASS_UPDATE
Local Integer READSTATUS,UPDSTATUS,AINITSTATUS,NUMREC,EMP_UPDFLG,NUMERR
Local Char ERRMSG(250)
Local File EMPLOIDSTG [IDSG1]
For [IDSG1]IDSG5 Where INTUID = PINTUID
  Local Instance  I_EMPLOIDSTG_UPD  Using C_EMPLOIDSTG
  If (I_EMPLOIDSTG_UPD <> null) : FreeGroup I_EMPLOIDSTG_UPD : Endif
  I_EMPLOIDSTG_UPD  = NewInstance C_EMPLOIDSTG AllocGroup null
  [L]READSTATUS = fmet I_EMPLOIDSTG_UPD.AREAD([F:IDSG1]REFNUM)
  #Test READSTATUS
  If [L]READSTATUS = [V]CST_AOK
    Gosub EMPLOID_UPDATE
    If [L]ARET_VALUE <>[V]CST_AOK
      [L]EMP_UPDFLG = [V]CST_AWARNING
      [L]NUMERR+=1
      Call GET_ERRORS(I_EMPINS,ERRMSG)
    Else
      [L]NUMREC+=1
    Endif
  Endif
  FreeGroup I_EMPLOIDSTG_UPD
Next


#TODO: Create function - pass results back to main method
If [L]EMP_UPDFLG = [V]CST_AOK
  ASTATUS = fmet this.ASETERROR("","Employee main records updated : "+num$(NUMREC),[V]CST_AINFO)
Else
  ASTATUS = fmet this.ASETERROR("","Employee main records updated : "+num$(NUMREC)+ " , Errors found ; "+num$(NUMERR)-ERRMSG,[V]CST_AWARNING)
Endif
LogicClose File [IDSG1]
Return

Subprog GET_ERRORS(WCONTAINER,VERRMSG)
Variable Char VERRMSG
Variable Instance WCONTAINER Using C_EMPINS

Local Integer I
Local Char WTEXTE(50)

 VERRMSG = func LCCLIB.MAXMSG(WCONTAINER)
End

