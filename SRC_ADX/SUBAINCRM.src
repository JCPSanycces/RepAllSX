#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################################################
# Sous-programmes pour la gestion des interlocuteurs                                      2 décembre 2003
#
# CREAINFROMCOR : initialisation création interlocuteur à partir d'un correspondant
##########################################################################################################
##########################################################################################################
# FGR 26/11/2013 : X3SUIVI94714 (début)
#$GEREAINCOR_DEL             # Issue X3-69333 - 2018-02-23 by FGR
Subprog GEREAINCOR_DEL()     # Issue X3-69333 - 2018-02-23 by FGR
Local Integer IBERROR
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IBUSRSYNC_OK
Local Integer ILIGNE
Local Integer INBCORL
Local Integer ICOREXIST
Local Char SZCOR(GLONCOR)
Local Integer NI
Local Char SZSYDUSR(GLONAUS)
Local Integer SVSILENCE
Local Integer SVIMPORT

  IBERROR = 0
  IBUSRSYNC_OK = 0
  # Issue X3-69333 - 2018-02-23 by FGR : BEGIN
  #If !clalev([F:CORL]) : Local File CORRESPOND [CORL] : Endif
  Local File CORRESPOND [CORL]
  # Issue X3-69333 - 2018-02-23 by FGR : END
  #
  For [CORL] Where [F:CORL]CNTNUM = [F:AIN]CNTNUM and [F:CORL]CORTYP = "AIN"
    Call DELCOR("SUBAINCRM", 1, 0, [F:CORL]CORNUM, IBERROR) From SUBCORCA
    If IBERROR Then
      Break
    Endif
  Next
  If IBERROR Then
    If GFONCTION = "GESAIN" Then
      If dim(GAINMESSAGE) >= 0 Then
        GMESSAGE = GAINMESSAGE
        Kill GAINMESSAGE
      Endif
    Endif
    GOK = 0
    #Return  # Issue X3-69333 - 2018-02-23 by FGR
    End      # Issue X3-69333 - 2018-02-23 by FGR
  Endif
#Return  # Issue X3-69333 - 2018-02-23 by FGR
End      # Issue X3-69333 - 2018-02-23 by FGR
# FGR 26/11/2013 : X3SUIVI94714 (fin)

##########################################################################################################
# initialisation création interlocuteur à partir d'un correspondant
$CREAINFROMCOR
  [M:AIN0]CNTTTL = [M:COR0]TTL
  [M:AIN0]CNTLNA = [M:COR0]LNA
  [M:AIN0]CNTFNA = [M:COR0]FNA
  #
  [M:AIN1]CNTLAN = [M:COR3]LAN
  [M:AIN1]CNTBIR = [M:COR3]BIR
  [M:AIN1]CNTCSP = [M:COR3]CSP
  [M:AIN1]CRY = [M:COR3]HOMCRY
  [M:AIN1]CRYNAM = [M:COR3]HOMCRYNAM
  [M:AIN1]CNTETS = [M:COR3]HOMTEL
  [M:AIN1]CNTFAX = [M:COR3]HOMFAX
  [M:AIN1]CNTMOB = [M:COR3]HOMMOB
  [M:AIN1]CNTEMA = [M:COR3]HOMEML
  If dim([M:AIN2]ADD1) > 0 Then
    [M:AIN2]ADD1 = [M:COR3]HOMADD(0)
  Endif
  If dim([M:AIN2]ADD2) > 0 Then
    [M:AIN2]ADD2 = [M:COR3]HOMADD(1)
  Endif
  If dim([M:AIN2]ADD3) > 0 Then
    [M:AIN2]ADD3 = [M:COR3]HOMADD(2)
  Endif
  [M:AIN2]ZIP = [M:COR3]HOMZIP
  [M:AIN2]CTY = [M:COR3]HOMCTY
  If dim([M:AIN2]SAT) > 0 and dim([M:COR3]HOMSAT) > 0 Then
    [M:AIN2]SAT = [M:COR3]HOMSAT
  Endif
  # FGR 28/01/2014 : X3SUIVI96198 (début)
  If [M:COR2]BPRNUM <> "" Then
    [M:AIN3]NBLIG += 1
    nolign = [M:AIN3]NBLIG
    [M:AIN3]BPATYP(nolign-1) = 1
    [M:AIN3]BPANUM(nolign-1) = [M:COR2]BPRNUM
    [M:AIN3]CNTFNC(nolign-1) = [M:COR2]FNC
    [M:AIN3]CNTSRV(nolign-1) = [M:COR2]SRV
    [M:AIN3]CNTMSS(nolign-1) = [M:COR2]MSS
    Affzo [M:AIN3]1-99
  Endif
  # FGR 28/01/2014 : X3SUIVI96198 (fin)
  Affzo [M:AIN0]1-99
  Affzo [M:AIN1]1-99
  Affzo [M:AIN2]1-99
Return

##########################################################################################################
#$GEREAINCOR                 # Issue X3-69333 - 2018-02-23 by FGR
Subprog GEREAINCOR()         # Issue X3-69333 - 2018-02-23 by FGR
Local Integer IBERROR
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IBUSRSYNC_OK
Local Integer ILIGNE
Local Integer INBCORL                  # FGR 29/03/2010 : X3SUIVI63506
Local Integer ICOREXIST                # FGR 29/03/2010 : X3SUIVI63506
Local Char SZCOR(GLONCOR)              # FGR 29/03/2010 : X3SUIVI63506
Local Integer NI                       # FGR 29/03/2010 : X3SUIVI63506
Local Char SZSYDUSR(GLONAUS)           # FGR 29/03/2010 : X3SUIVI63506
Local Integer SVSILENCE                # FGR 18/06/2010 : X3SUIVI65260
Local Integer SVIMPORT                 # FGR 18/06/2010 : X3SUIVI65260
Local Char SMESSGE(type(GMESSAGE)-10)  # FGR 27/11/2013 : X3SUIVI94714
Local Char SZREP(GLONREP)              # FGR 27/11/2013 : X3SUIVI94714


  IBERROR = 0
  IBUSRSYNC_OK = 0
  # Issue X3-69333 - 2018-02-22 by FGR : BEGIN : Issue linked to the fact that filed are shared whit the previous level
  #If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif     # FGR 29/03/2010 : X3SUIVI63506
  #If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif   # FGR 29/03/2010 : X3SUIVI63506
  #If !clalev([F:BPD]) : Local File BPDLVCUST [BPD] : Endif    # FGR 07/12/2010 : X3SUIVI69722
  ##If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif   # FGR 29/03/2010 : X3SUIVI63506
  #If !clalev([F:BPAZ]) : Local File BPADDRESS [BPAZ] : Endif  # FGR 01/06/2010 : X3SUIVI65140 : Prendre un autre abrégé sur BPADDRESS
  #If !clalev([F:REP]) : Local File SALESREP [REP] : Endif     # FGR 29/03/2010 : X3SUIVI63506
  #If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif      # FGR 29/03/2010 : X3SUIVI63506
  #If !clalev([F:SYD]) : Local File SYNCDATA [SYD] : Endif
  #If !clalev([F:CORL]) : Local File CORRESPOND [CORL] : Endif
  #If !clalev([F:COPL]) : Local File CORREP [COPL] : Endif
  Local File BPARTNER [BPR]
  Local File BPCUSTOMER [BPC]
  Local File BPDLVCUST [BPD]
  Local File BPADDRESS [BPAZ]
  Local File SALESREP [REP]
  Local File CONTACT [CNT]
  Local File SYNCDATA [SYD]
  Local File CORRESPOND [CORL]
  Local File CORREP [COPL]
  # Issue X3-69333 - 2018-02-22 by FGR : END
  #
  INBCORL = 0
  If [M:AIN3]NBLIG > 0 Then
    ILIGNE = 0
    While ILIGNE < [M:AIN3]NBLIG
      If [M:AIN3]BPATYP(ILIGNE) = 1 Then
        # Seulement pour les tiers
        INBCORL += 1
        ICOREXIST = 0
        Raz SZCOR
        #For [CORL] Where [F:CORL]CNTNUM = [F:AIN]CNTNUM and [F:CORL]CORTYP = "AIN" and [F:CORL]BPRNUM = [M:AIN3]BPANUM(ILIGNE) and [F:CORL]CNTNUM <> ""
        For [CORL] Where [F:CORL]CNTNUM = [F:AIN]CNTNUM and [F:CORL]CORTYP = "AIN" and [F:CORL]BPRNUM = [M:AIN3]BPANUM(ILIGNE)   # FGR 27/11/2013 : X3SUIVI94714
          ICOREXIST = 1
          SZCOR = [F:CORL]CORNUM
          Break
        Next
        #-----
        # FGR 18/06/2010 : X3SUIVI65260 (début)
        If ICOREXIST = 0 Then
          # FGR 03/01/2010 : X3SUIVI70159 (début)
          Gosub TEST_CRECOR
          # FGR 03/01/2010 : X3SUIVI70159 (fin)
          If GZCRMCPTCOR = "~" Then
            # Si on vient là c'est que le compteur n'est pas défini et qu'on devrait créer : donc on part (mais c'est pas une erreur)
            Break
          Endif
        Endif
        # FGR 18/06/2010 : X3SUIVI65260 (fin)
        #-----
        # On lit le tiers et l'adresse par défaut
        Read [BPR]BPR0=[M:AIN3]BPANUM(ILIGNE)
        If fstat Then
          Raz [F:BPR]
        Endif
        Read [BPC]BPC0=[F:BPR]BPRNUM
        If fstat Then
          Raz [F:BPC]
        Else
          # On charge les représentants comme affectations
          GINBREP = 0
          Raz GSTBREP
          # FGR 07/12/2010: X3SUIVI69722 : (début) je ne vois pas à quoi ça sert
          #GSTBREP(GINBREP) = "" # La première position est réservé à l'utilisateur qui fait la manipulation
          #GINBREP += 1
          # FGR 07/12/2010: X3SUIVI69722 : (fin)
          For NI = 0 To dim([F:BPC]REP)-1
            If [F:BPC]REP(NI) <> "" Then
              Call SYDUSRFROMREP([F:BPC]REP(NI), SZSYDUSR, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
              If IBUSRSYNC_OK <> 0 Then
                #If SZSYDUSR <> "" and SZSYDUSR <> GUSER Then  # FGR 07/12/2010: X3SUIVI69722 : je ne vois pas à quoi ça sert
                  GSTBREP(GINBREP) = [F:BPC]REP(NI)
                  GINBREP += 1
                #Endif                                         # FGR 07/12/2010: X3SUIVI69722 : je ne vois pas à quoi ça sert
              Endif
            Endif
          Next NI
          # FGR 07/12/2010: X3SUIVI69722 : (début) ajouter aussi les représentant des clients livrés.
          For [BPD] Where [F:BPD]BPCNUM = [F:BPC]BPCNUM and [F:BPD]ENAFLG = 2
            For NI = 0 To dim([F:BPD]REP)-1
              If [F:BPD]REP(NI) <> "" Then
                Call SYDUSRFROMREP([F:BPD]REP(NI), SZSYDUSR, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
                If IBUSRSYNC_OK <> 0 Then
                  # Si c'est un représentant, on regarde s'il n'est pas déjà dans GSTBREP. On ne l'ajoute qu'une seule fois.
                  If find([F:BPD]REP(NI), GSTBREP(0..GINBREP-1)) = 0 Then
                    GSTBREP(GINBREP) = [F:BPD]REP(NI)
                    GINBREP += 1
                  Endif
                Endif
              Endif
            Next NI
          Next
          # FGR 07/12/2010: X3SUIVI69722 : (fin)
        Endif
        Read [CNT]CNT0=[M:AIN3]BPATYP(ILIGNE);[F:BPR]BPRNUM;[F:AIN]CNTNUM
        If fstat Then
          Raz [F:CNT]
          Read [BPAZ]BPA0=[M:AIN3]BPATYP(ILIGNE);[F:BPR]BPRNUM;[F:BPR]BPAADD
          If fstat Then
            Raz [F:BPAZ]
          Endif
        Else
          Read [BPAZ]BPA0=[F:CNT]BPATYP;[F:CNT]BPANUM;[F:CNT]BPAADD
          If fstat Then
            Raz [F:BPAZ]
            Read [BPAZ]BPA0=[M:AIN3]BPATYP(ILIGNE);[F:BPR]BPRNUM;[F:BPR]BPAADD
            If fstat Then
              Raz [F:BPAZ]
            Endif
          Endif
        Endif
        #
        GSCNTFNC = [M:AIN3]CNTFNC(ILIGNE)
        GSCNTSRV = [M:AIN3]CNTSRV(ILIGNE)
        GSCNTMSS = [M:AIN3]CNTMSS(ILIGNE)
        If ICOREXIST = 0 Then
          Call CRECOR("SUBAINCRM", 1, 0, SZCOR, IBERROR) From SUBCORCC
        Else
          Call UPDCOR("SUBAINCRM", 1, 0, SZCOR, IBERROR) From SUBCORCM
        Endif
        If IBERROR Then
          Break
        Endif
      Endif
      ILIGNE += 1
    Wend
    If IBERROR Then
      # FGR 22/07/2010 (début)
      If GFONCTION = "GESAIN" Then
        If dim(GAINMESSAGE) >= 0 Then
          GMESSAGE = GAINMESSAGE
          Kill GAINMESSAGE
        Endif
      Endif
      # FGR 22/07/2010 (fin)
      GOK = 0
      #Return  # Issue X3-69333 - 2018-02-23 by FGR
      End      # Issue X3-69333 - 2018-02-23 by FGR
    Endif
  Endif
  If INBCORL = 0 Then
    Raz [F:BPAZ]   # FGR 05/04/2016 : X3SUIVI77755 : sinon la classe contient on ne sait quoi
    # Il n'y a pas de ligne en relation : le correspondant "est tout seul"
    # FGR 26/11/2013 : X3SUIVI94714 (début)
    For [CORL] Where [F:CORL]CNTNUM = [F:AIN]CNTNUM and [F:CORL]CORTYP = "AIN"
      ICOREXIST = 1
      SZCOR = [F:CORL]CORNUM
      Break
    Next
    # FGR 26/11/2013 : X3SUIVI94714 (fin)
    #
    # FGR 03/01/2010 : X3SUIVI70159 (début)
    Gosub TEST_CRECOR
    If GZCRMCPTCOR = "~" Then
      # Si on vient là c'est que le compteur n'est pas défini et qu'on devrait créer : donc on part (mais c'est pas une erreur)
      #Return  # Issue X3-69333 - 2018-02-23 by FGR
      End      # Issue X3-69333 - 2018-02-23 by FGR
    Endif
    # FGR 03/01/2010 : X3SUIVI70159 (fin)
    # FGR 26/11/2013 : X3SUIVI94714 (début)
    #Call CRECOR("SUBCORAIND", 1, 0, SZCOR, IBERROR) From SUBCORCC
    If ICOREXIST = 0 Then
      # En création il est automatiquement affecté au représentant qui synchronise
      GINBREP = 0
      Raz GSTBREP
      Call GETREPFROMUTI (GUSER, SZREP, SMESSGE, IBERROR) From CRMUTIL150
      Raz IBERROR
      If SZREP <> "" Then
        GSTBREP(GINBREP) = SZREP
        GINBREP += 1
      Endif
      Call CRECOR("SUBAINCRM", 1, 0, SZCOR, IBERROR) From SUBCORCC
    Else
      # Quand le correspondant n'est pas lié à un tiers on conserve les représentants qu'il y a sinon ça le supprime dans Outlook
      GINBREP = 0
      Raz GSTBREP
      For [COPL] Where [F:COPL]COPNUM = SZCOR
        GSTBREP(GINBREP) = [F:COPL]COPREP
        GINBREP += 1
      Next
      # ----------------------------------------
      If [F:CORL]CPYBPANUM = "" Then
        # Issue X3-54626 - 2017-10-25 by FGR
        LogicClose File [F:BPAZ]
      Else
        # FGR 07/11/2016 : X3SUIVI116772 (début)
        Local Integer ICNTDELETED
        ICNTDELETED = 1
        Filter [F:CNT] Where [F:CNT]BPATYP = [F:CORL]CPYBPATYP and [F:CNT]BPANUM = [F:CORL]CPYBPANUM  and [F:CNT]CCNCRM = [F:AIN]CNTNUM
        For [F:CNT]
          ICNTDELETED = 0
          Break
        Next
        Filter [F:CNT]
        If ICNTDELETED = 1 Then
          # If the contact has been deleted
          Raz [F:BPR]
          Raz [F:BPAZ]
        Endif
        # FGR 07/11/2016 : X3SUIVI116772 (end)
      Endif
      # ----------------------------------------
      Call UPDCOR("SUBAINCRM", 1, 0, SZCOR, IBERROR) From SUBCORCM
    Endif
    # FGR 26/11/2013 : X3SUIVI94714 (fin)
    If IBERROR Then
      GOK = 0
      # FGR 22/10/2010 (début) : X3SUIVI68366
      If GFONCTION = "GESAIN" Then
        If dim(GAINMESSAGE) >= 0 Then
          GMESSAGE = GAINMESSAGE
          Kill GAINMESSAGE
        Endif
      Endif
      # FGR 22/10/2010 (fin) : X3SUIVI68366
      #Return  # Issue X3-69333 - 2018-02-23 by FGR
      End      # Issue X3-69333 - 2018-02-23 by FGR
    Endif
  Else
    # FGR 06/04/2016 : X3SUIVI77755 : S'il y a le correspondant tout seul, on le supprime
    ICOREXIST = 0
    Raz SZCOR
    For [CORL] Where [F:CORL]CNTNUM = [F:AIN]CNTNUM and [F:CORL]CORTYP = "AIN" and [F:CORL]BPRNUM = ""
      ICOREXIST = 1
      SZCOR = [F:CORL]CORNUM
      Break
    Next
    If ICOREXIST = 1 Then
      Call DELCOR("SUBAINCRM", 1, 0, SZCOR, IBERROR) From SUBCORCA
      If IBERROR Then
        GOK = 0
        If GFONCTION = "GESAIN" Then
          If dim(GAINMESSAGE) >= 0 Then
            GMESSAGE = GAINMESSAGE
            Kill GAINMESSAGE
          Endif
        Endif
      Endif
    Endif
  Endif
  # FGR 29/03/2010 : X3SUIVI63506 (fin)
#Return  # Issue X3-69333 - 2018-02-23 by FGR
End      # Issue X3-69333 - 2018-02-23 by FGR

##########################################################################################################
# FGR 03/01/2010 : X3SUIVI70159 (début)
$TEST_CRECOR
  # Le correspondant n'existe pas. il va falloir le créer. Regarder si le compteur existe :
  #    - Si oui, c'est bon
  #    - Si non, on affiche un message (une seule fois), et on ne crée pas
  If dim(GZCRMCPTCOR) < 0 Then
    Global Char GZCRMCPTCOR(GLONANM)

    GZCRMCPTCOR = ""
  Endif
  If GZCRMCPTCOR = "" Then
    # On va lire le compteur des correspondants
    If !clalev ([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
    Read [TCA]TCA0=13
    If fstat Then
      Raz [F:TCA]
    Endif
    GZCRMCPTCOR = [F:TCA]CODNUM(11)
    If GZCRMCPTCOR = "" Then
      SVSILENCE = GSILENCE
      SVIMPORT = GIMPORT
      If GZCRMIMPORT < 0 or (GZCRMIMPORT >= 0 and GZCRMIMPORT = 0) Then
        # Si on n'est pas en import (de tiers par exemple) on force l'affichage du message
        GSILENCE = 0
        GIMPORT = 0
      Endif
      Call MESSAGE(mess(983,196,1) + "\" + mess(984,196,1)) From GESECRAN
      GSILENCE = SVSILENCE
      GIMPORT = SVIMPORT
    Endif
  Endif
  If GZCRMCPTCOR = "" or GZCRMCPTCOR = "~" Then
    # Si GZCRMCPTCOR = "", Comme il y a eu [OK] on regarde si l'utilisateur est allé alimenter le compteur...
    # Si GZCRMCPTCOR = "~", Le compteur n'était pas défini, on regarde la situation a changé
    # Mais ici il n'y aura pas de message
    If !clalev ([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
    Read [TCA]TCA0=13
    If fstat Then
      Raz [F:TCA]
    Endif
    If [F:TCA]CODNUM(11) <> "" Then
      # ... S'il l'a fait, la création du correspondant va pouvoir se faire
      GZCRMCPTCOR = [F:TCA]CODNUM(11)
    Else
      # ... S'il ne l'a pas fait on ne créera pas le correspondant, mais l'enregistrement se poursuivra
      GZCRMCPTCOR = "~"  # Pour afficher le message que la première fois
    Endif
  Endif
Return
# FGR 03/01/2010 : X3SUIVI70159 (fin)
##########################################################################################################

##########################################################################################################
#CHECK UNUSED_BEGIN
$GEREAINCOR_OLD
Local Integer IBMODIF
Local Integer IBERROR
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZCOPUSER
Local Integer IBUSRSYNC_OK
Local Integer INBRECORD
Local Integer ILIGNE
Local Integer ILIGNEOLD
Local Integer IBTROUVE

  IBMODIF = 0
  IBERROR = 0
  Raz SZCOPUSER
  IBUSRSYNC_OK = 0
  INBRECORD = 0
  If !clalev([F:SYD]) : Local File SYNCDATA [SYD] : Endif
  If !clalev([F:CORL]) : Local File CORRESPOND [CORL] : Endif
  If !clalev([F:COPL]) : Local File CORREP [COPL] : Endif
  #Est ce qu'il y a des modifs dans la partie AIN
  #Gosub TEST_AIN_AIN_SAVE  # FGR 29/03/2010 : X3SUIVI63506
  If IBMODIF = 1 Then
    #Il y a eu des changements
    For [CORL] Where [F:CORL]CNTNUM=[F:AIN]CNTNUM and [F:CORL]CORTYP="AIN" and [F:CORL]CNTNUM<>""
      #On verifie si différence
      Gosub TEST_AIN_F_CORW_F_AIN
      If IBMODIF = 1 Then
        #On a des différences, on reporte
        [F:CORL]TTL = [M:AIN0]CNTTTL
        [F:CORL]LNA = [M:AIN0]CNTLNA
        [F:CORL]FNA = [M:AIN0]CNTFNA
        [F:CORL]BIR = [M:AIN1]CNTBIR
        [F:CORL]LAN = [M:AIN1]CNTLAN
        [F:CORL]CSP = [M:AIN1]CNTCSP
        [F:CORL]HOMCRY = [M:AIN1]CRY
        [F:CORL]HOMCRYNAM = [M:AIN1]CRYNAM
        If dim([M:AIN2]ADD1) > 0 Then
          [F:CORL]HOMADD(0) = [M:AIN2]ADD1
        Endif
        If dim([M:AIN2]ADD1) > 0 Then
          [F:CORL]HOMADD(1) = [M:AIN2]ADD2
        Endif
        If dim([M:AIN2]ADD1) > 0 Then
          [F:CORL]HOMADD(2) = [M:AIN2]ADD3
        Endif
        [F:CORL]HOMZIP = [M:AIN2]ZIP
        [F:CORL]HOMCTY = [M:AIN2]CTY
        If dim([M:AIN2]SAT) > 0 Then
          [F:CORL]HOMSAT = [M:AIN2]SAT
        Endif
        [F:CORL]HOMTEL = [M:AIN1]CNTETS
        [F:CORL]HOMFAX = [M:AIN1]CNTFAX
        [F:CORL]HOMMOB = [M:AIN1]CNTMOB
        [F:CORL]HOMEML = [M:AIN1]CNTEMA
        [F:CORL]UPDUSR = GUSER
        [F:CORL]UPDDAT = date$
        Rewrite [CORL]
        If fstat <> 0 Then
          IBERROR = 1
          #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
          GMESSAGE = mess(285,177,1) - ":"- [F:CORL]CORNUM
          GOK = 0
        Endif
        If IBERROR = 0 Then
          Gosub GERE_COP From SUBCORB
        Endif
        If IBERROR = 1 Then
          Break
        Endif
      Endif
    Next
  Endif
  If IBERROR = 1 Then
    GOK = 0
    Return
  Endif
  #On test si il y a des modifications sur la partie contact
  ILIGNE = 0
  ILIGNEOLD = 0
  IBTROUVE = 0
  While ILIGNE < [M:AIN3]NBLIG
    IBTROUVE = 0
    If [M:AIN3]BPATYP(ILIGNE) = 1 Then
      If [M:AIN3]BPANUM(ILIGNE) <> "" Then
        #On va rechercher i présent au depart
        ILIGNEOLD = 0
        While ILIGNEOLD < [M:IN3S]NBLIG
          If [M:IN3S]BPATYP(ILIGNEOLD) = 1 Then
            If [M:IN3S]BPANUM(ILIGNEOLD) = [M:AIN3]BPANUM(ILIGNE) Then
              IBTROUVE = 1
              Break
            Endif
          Endif
          ILIGNEOLD += 1
        Wend
        If IBTROUVE = 1 Then
          #La ligne existait, il faut comparé les valeurs
          Gosub TEST_CNT_CNT_SAVE
          If IBMODIF = 1 Then
            #Il y a eu des changements
            For [CORL] Where [F:CORL]BPRNUM = [M:AIN3]BPANUM(ILIGNE)
              #On verifie si différence
              Gosub TEST_CNT_F_CORW_F_CNT
              If IBMODIF = 1 Then
                #On a des différences, on reporte
                [F:CORL]FNC = [M:AIN3]CNTFNC(ILIGNE)
                [F:CORL]SRV = [M:AIN3]CNTSRV(ILIGNE)
                [F:CORL]MSS = [M:AIN3]CNTMSS(ILIGNE)
                [F:CORL]UPDUSR = GUSER
                [F:CORL]UPDDAT = date$
                Rewrite [CORL]
                If fstat <> 0 Then
                  IBERROR = 1
                  #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
                  GMESSAGE = mess(285,177,1) - ":"- [F:CORL]CORNUM
                  GOK=0
                Endif
                If IBERROR = 0 Then
                  Gosub GERE_COP From SUBCORB
                Endif
                If IBERROR = 1 Then
                  Break
                Endif
              Endif
            Next
          Endif
        Endif
      Endif
    Endif
    ILIGNE += 1
  Wend
  If IBERROR = 1 Then
    GOK=0
  Endif
Return
#CHECK UNUSED_END

##########################################################################################################
$UPDCORORIGINE
  If !clalev([F:CORL]) : Local File CORRESPOND [CORL] : Endif
  Read [CORL]COR0=[M:COR0]CORNUM
  If fstat <> 0 Then
    #Erreur lors de la lecture du correspondant+" : "+[M:COR0]CORNUM
    GMESSAGE = mess(271,177,1) - ":" - [M:COR0]CORNUM
    GERR = 2
    GOK = 0
  Else
    [F:CORL]CNTNUM = [F:AIN]CNTNUM
    [F:CORL]UPDCNTNUM = 0
    [F:CORL]UPDUSR = GUSER
    [F:CORL]UPDDAT = date$
    Rewrite [CORL]
    If fstat <> 0 Then
      #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
      GMESSAGE = mess(285,177,1) - ":" - [F:CORL]CORNUM
      GOK = 0
      GERR = 2
    Endif
  Endif
Return

##########################################################################################################
$OUVRE_CRM
  # FGR 27/03/2015 : X3SUIVI107276 (début)
#Global Integer GIBAINCREFROMLDS
Local Integer IIBAINCREFROMLDS
#Global Integer GIBAINCREFROMCOR
Local Integer IIBAINCREFROMCOR
Local Integer IGBCRMFLGUPD
Local Integer IGBCRMFLGNEW

  IGBCRMFLGUPD = GBCRMFLGUPD
  IGBCRMFLGNEW = GBCRMFLGNEW
  # FGR 27/03/2015 : X3SUIVI107276 (fin)
Global Decimal GSCNTFNC           # FGR 29/03/2010 : X3SUIVI63506
Global Char GSCNTSRV(GLONDES)     # FGR 29/03/2010 : X3SUIVI63506
Global Char GSCNTMSS(GLONADI)     # FGR 29/03/2010 : X3SUIVI63506
Global Integer GINBREP            # FGR 29/03/2010 : X3SUIVI63506
Global Char GSTBREP(GLONREP)(10)  # FGR 29/03/2010 : X3SUIVI63506

  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  Gosub OUVRE_CRM_COR From TRTBPCRM # FGR 18/06/2010 : X3SUIVI65260
  Local Mask AIN0 [IN0S]
  Local Mask AIN1 [IN1S]
  Local Mask AIN2 [IN2S]
  Local Mask AIN3 [IN3S]
  Raz [M:IN0S]
  Raz [M:IN1S]
  Raz [M:IN2S]
  Raz [M:IN3S]
Return

##########################################################################################################
$LIENS_CRM
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
  #[M:IN0S] = [M:AIN0]
  #[M:IN1S] = [M:AIN1]
  #[M:IN2S] = [M:AIN2]
  #[M:IN3S] = [M:AIN3]
  Raz [M:IN0S] : Transmask [M:AIN0] To [M:IN0S]
  Raz [M:IN1S] : Transmask [M:AIN1] To [M:IN1S]
  Raz [M:IN2S] : Transmask [M:AIN2] To [M:IN2S]
  Raz [M:IN3S] : Transmask [M:AIN3] To [M:IN3S]
  # Issue X3-35454 - 2017-05-03 by FGR : END
Return

##########################################################################################################
$FERME_CRM
  # FGR 27/03/2015 : X3SUIVI107276 (début)
  #If dim(GIBAINCREFROMLDS) > 0 Then
  #  Kill GIBAINCREFROMLDS
  #Endif
  #If dim(GIBAINCREFROMCOR) > 0 Then
  #  Kill GIBAINCREFROMCOR
  #Endif
  # FGR 27/03/2015 : X3SUIVI107276 (fin)
  # FGR 29/03/2010 : X3SUIVI63506 (début)
  If dim(GSCNTFNC) > 0 Then
    Kill GSCNTFNC
  Endif
  If dim(GSCNTSRV) > 0 Then
    Kill GSCNTSRV
  Endif
  If dim(GSCNTMSS) > 0 Then
    Kill GSCNTMSS
  Endif
  If dim(GINBREP) > 0 Then
    Kill GINBREP
  Endif
  If dim(GSTBREP) > 0 Then
    Kill GSTBREP
  Endif
  # FGR 29/03/2010 : X3SUIVI63506 (fin)
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  If clalev([M:IN0S]) Then
    Close Local Mask [IN0S]
    Close Local Mask [IN1S]
    Close Local Mask [IN2S]
    Close Local Mask [IN3S]
  Endif
  Gosub FERME_CRM_COR From TRTBPCRM  # FGR 18/06/2010 : X3SUIVI65260
Return

##########################################################################################################
$RAZCRE_CRM
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  # FGR 07/04/2008 : Je ne sais pas pourquoi les mask étaient fermés ici !
  #Close Local Mask [IN0S]
  #Close Local Mask [IN1S]
  #Close Local Mask [IN2S]
  #Close Local Mask [IN3S]
  Raz [M:IN0S]
  Raz [M:IN1S]
  Raz [M:IN2S]
  Raz [M:IN3S]
  If !GIMPORT Then
    If GPILNAV > 1 Then
      If GNAVIG(GPILNAV-1) = "GESCOR" Then
        If IGBCRMFLGNEW = 1 Then
          IIBAINCREFROMCOR = 1
          Gosub CREAINFROMCOR
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$RAZDUP_CRM
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  Raz [M:IN0S]
  Raz [M:IN1S]
  Raz [M:IN2S]
  Raz [M:IN3S]
Return

##########################################################################################################
$AVANT_CHOI_CRM
  If GMODU(13) = 2 Then
    #If GBCRMFLGNEW = 1 Then           # FGR 27/03/2015 : X3SUIVI107276
    If IGBCRMFLGNEW = 1 Then           # FGR 27/03/2015 : X3SUIVI107276
      REPONSE = GSTANEW
      Gosub NOUVEAU From GOBJSUB
      Gosub SETBOUT From GOBJSUB
      #GBCRMFLGNEW = 0                 # FGR 27/03/2015 : X3SUIVI107276
      IGBCRMFLGNEW = 0                 # FGR 27/03/2015 : X3SUIVI107276
    Endif
    #If GBCRMFLGUPD = 1 Then           # FGR 27/03/2015 : X3SUIVI107276
    If IGBCRMFLGUPD = 1 Then           # FGR 27/03/2015 : X3SUIVI107276
      Gosub ENTRE_MODIF From GOBJSUB
      Gosub GEREORIGINEMODIF
      #GBCRMFLGUPD = 0                 # FGR 27/03/2015 : X3SUIVI107276
      IGBCRMFLGUPD = 0                 # FGR 27/03/2015 : X3SUIVI107276
      Gosub SETBOUT From GOBJSUB
    Endif
  Endif
Return

##########################################################################################################
$AB_CREATION_CRM
  If dim(IIBAINCREFROMCOR) > 1 Then
    IIBAINCREFROMCOR = 0
  Endif
Return

##########################################################################################################
$AB_MODIF_CRM
  If dim(IIBAINCREFROMCOR) > 1 Then
    IIBAINCREFROMCOR = 0
  Endif
Return
##########################################################################################################
$ABANDON_CRM
  If dim(IIBAINCREFROMCOR) > 1 Then
    IIBAINCREFROMCOR = 0
  Endif
Return

##########################################################################################################
$CREATION_CRM
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  If IIBAINCREFROMCOR = 1 Then
    Gosub UPDCORORIGINE
    IIBAINCREFROMCOR = 0
  Endif
  If GOK < 1 Then
    Return
  Endif
  #Gosub GEREAINCOR          # Issue X3-69333 - 2018-02-23 by FGR
  Call GEREAINCOR()          # Issue X3-69333 - 2018-02-23 by FGR
Return

##########################################################################################################
$MODIF_CRM
  If IIBAINCREFROMLDS = 1 Then
    Gosub TRANSAINLDS From SUBLDSB
    If GOK < 1 Then
      Return
    Endif
  Endif
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  #Gosub GEREAINCOR          # Issue X3-69333 - 2018-02-23 by FGR
  Call GEREAINCOR()          # Issue X3-69333 - 2018-02-23 by FGR
Return

##########################################################################################################
$ANNULE_CRM
  # FGR 26/11/2013 : X3SUIVI94714 : traiter la suppression du correspondant
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    Return
  Endif
  #
  #Gosub GEREAINCOR_DEL      # Issue X3-69333 - 2018-02-23 by FGR
  Call GEREAINCOR_DEL()      # Issue X3-69333 - 2018-02-23 by FGR
Return

##########################################################################################################
$GEREORIGINEMODIF
  If !GIMPORT Then
    If GPILNAV > 1 Then
      If GNAVIG(GPILNAV-1) = "GESLDS" Then
        If IGBCRMFLGUPD = 1 Then
          [M:AIN0]CNTTYP = 1
          IIBAINCREFROMLDS = 1
        Endif
      Endif
    Endif
  Endif
Return

