##########################################################################################################
$TEST_AIN_F_CORW_F_AIN
  IBMODIF = 0
  # On teste les différentes zones
  If [F:CORL]TTL <> [M:AIN0]CNTTTL Then
    IBMODIF = 1
  Elsif [F:CORL]LNA <> [M:AIN0]CNTLNA Then
    IBMODIF = 1
  Elsif [F:CORL]FNA <> [M:AIN0]CNTFNA Then
    IBMODIF = 1
  Elsif [F:CORL]BIR <> [M:AIN1]CNTBIR Then
    IBMODIF = 1
  Elsif [F:CORL]LAN <> [M:AIN1]CNTLAN Then
    IBMODIF = 1
  Elsif [F:CORL]CSP <> [M:AIN1]CNTCSP Then
    IBMODIF = 1
  Elsif [F:CORL]HOMCRY <> [M:AIN1]CRY Then
      IBMODIF = 1
  Elsif [F:CORL]HOMCRYNAM <> [M:AIN1]CRYNAM Then
    IBMODIF = 1
  Endif
  If dim([M:AIN2]ADD1) > 0 Then
    If [M:AIN2]ADD1 <> [F:CORL]HOMADD(0) Then
      IBMODIF = 1
    Endif
  Endif
  If dim([M:AIN2]ADD2) > 0 Then
    If [M:AIN2]ADD2 <> [F:CORL]HOMADD(1) Then
      IBMODIF = 1
    Endif
  Endif
  If dim([M:AIN2]ADD3) > 0 Then
    If [M:AIN2]ADD3 <> [F:CORL]HOMADD(2) Then
      IBMODIF = 1
    Endif
  Endif
  If [F:CORL]HOMZIP <> [M:AIN2]ZIP Then
    IBMODIF = 1
  Elsif [F:CORL]HOMCTY <> [M:AIN2]CTY Then
    IBMODIF = 1
  Endif
  If dim([M:AIN2]SAT) > 0 Then
    If [F:CORL]HOMSAT <> [M:AIN2]SAT Then
      IBMODIF = 1
    Endif
  Endif
  If [F:CORL]HOMTEL <> [M:AIN1]CNTETS Then
    IBMODIF = 1
  Elsif [F:CORL]HOMFAX <> [M:AIN1]CNTFAX Then
    IBMODIF = 1
  Elsif [F:CORL]HOMMOB <> [M:AIN1]CNTMOB Then
    IBMODIF = 1
  Elsif [F:CORL]HOMTEL <> [M:AIN1]CNTEMA Then
    IBMODIF = 1
  Endif
Return

##########################################################################################################
$TEST_CNT_CNT_SAVE
  IBMODIF = 0
  #On test les différentes zones
  If [M:AIN3]CNTFNC(ILIGNE) <> [M:IN3S]CNTFNC(ILIGNEOLD) Then
    IBMODIF = 1
  Elsif [M:AIN3]CNTSRV(ILIGNE) <> [M:IN3S]CNTSRV(ILIGNEOLD) Then
    IBMODIF = 1
  Elsif [M:AIN3]CNTMSS(ILIGNE) <> [M:IN3S]CNTMSS(ILIGNEOLD) Then
    IBMODIF = 1
  Endif
Return

##########################################################################################################
$TEST_CNT_F_CORW_F_CNT
  IBMODIF = 0
  #On test les différentes zones
  If [F:CORL]FNC <> [M:AIN3]CNTFNC(ILIGNE) Then
    IBMODIF = 1
  Elsif [F:CORL]SRV <> [M:AIN3]CNTSRV(ILIGNE) Then
    IBMODIF = 1
  Elsif [F:CORL]MSS <> [M:AIN3]CNTMSS(ILIGNE) Then
    IBMODIF = 1
  Endif
Return

##########################################################################################################
# FGR 29/03/2010 : X3SUIVI63506 (début)
$COR_SET_HEA_INFO
  Case IMPZON
    When "CNTNUM"
      #Code interlocuteur
      [M:COR0]CNTNUM = [F:AIN]CNTNUM
      [M:COR0]UPDCNTNUM = 0
    When "HOMEML"
      #E-mail personnel
      [M:COR3]HOMEML = [F:AIN]CNTEMA
    When "HOMZIP"
      [M:COR3]HOMZIP = [F:AIN]ZIP
    When "HOMSAT"
      #Etat personnel
      [M:COR3]HOMSAT = [F:AIN]SAT
    When "LNA"
      #Nom
      [M:COR0]LNA = [F:AIN]CNTLNA
    When "HOMCRY"
      #Pays (personnel)
      [M:COR3]HOMCRY = [F:AIN]CRY
    When "HOMCRYNAM"
      #Libellé Pays (personnel)
      [M:COR3]HOMCRYNAM = [F:AIN]CRYNAM
    When "FNA"
      #Prénom
      [M:COR0]FNA = [F:AIN]CNTFNA
    When "HOMADD"
      #Adresse rue (personnel)
      Case indice
        When 0
          [M:COR3]HOMADD(0) = [F:AIN]ADD(0)
        When 1
          [M:COR3]HOMADD(1) = [F:AIN]ADD(1)
        When 2
          [M:COR3]HOMADD(2) = [F:AIN]ADD(2)
      Endcase
    When "HOMFAX"
      #Fax (personnel)
      # FGR 29/07/2010 : X3SUIVI66067
      If func CTLTEL([F:AIN]CNTFAX, [F:AIN]CRY) = 1 Then
        [M:COR3]HOMFAX = ""
      Else
        [M:COR3]HOMFAX = [F:AIN]CNTFAX
      Endif
    When "HOMTEL"
      #Téléphone (personnel)
      # FGR 29/07/2010 : X3SUIVI66067
      If func CTLTEL([F:AIN]CNTETS, [F:AIN]CRY) = 1 Then
        [M:COR3]HOMTEL = ""
      Else
        [M:COR3]HOMTEL = [F:AIN]CNTETS
      Endif
    When "HOMMOB"
      #telephone portable (personnel)
      [M:COR3]HOMMOB = [F:AIN]CNTMOB
    When "TTL"
      #Civilité
      [M:COR0]TTL = [F:AIN]CNTTTL
    When "HOMCTY"
      #Ville (personnel)
      [M:COR3]HOMCTY = [F:AIN]CTY
    When "BIR"
      # Anniversaire
      [M:COR3]BIR = [F:AIN]CNTBIR
    When "LAN"
      # Langue
      [M:COR3]LAN = [F:AIN]CNTLAN
    When "CSP"
      # Catégorie
      [M:COR3]CSP = [F:AIN]CNTCSP
    When "CPYEML"
      # email professionnel : FGR 01/06/2010 : X3SUIVI65140 on prenait 2x l'email personnel
      [M:COR2]CPYEML = [F:CNT]WEB
    When "BPRNUM"
      # Tiers
      [M:COR2]BPRNUM = [F:BPR]BPRNUM
      [M:COR2]UPDBPRNUM = 0
    #
    When "CPYBPANUM"
      # FGR 25/08/2010 : X3SUIVI66843
      # [F:CNT]BPATYP;[F:CNT]BPANUM;[F:CNT]BPAADD
      #[M:COR2]CPYBPATYP = [F:BPAZ]BPATYP
      #[M:COR2]CPYBPANUM = [F:BPAZ]BPAADD   : # FGR 01/06/2010 : X3SUIVI65140 : Utilisation mauvais champ [F:BPAZ]BPANUM
      [M:COR2]CPYBPATYP = [F:CNT]BPATYP
      [M:COR2]CPYBPANUM = [F:CNT]BPAADD
    When "CPYBPADES"
      [M:COR2]CPYBPADES = [F:BPAZ]BPADES
    When "CPYCRY"
      [M:COR2]CPYCRY = [F:BPAZ]CRY
    When "CPYADD"
      [M:COR2]CPYADD(indice) = [F:BPAZ]BPAADDLIG(indice)
    When "CPYSAT"
      [M:COR2]CPYSAT = [F:BPAZ]SAT
    When "CPYZIP"
      [M:COR2]CPYZIP = [F:BPAZ]POSCOD
    When "CPYCTY"
      [M:COR2]CPYCTY = [F:BPAZ]CTY
    When "CPYTEL"
      If [F:CNT]TEL = "" Then
        [M:COR2]CPYTEL = [F:BPAZ]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPAZ]TEL
      Else
        [M:COR2]CPYTEL = [F:CNT]TEL
      Endif
    When "CPYFAX"
      If [F:CNT]FAX = "" Then
        [M:COR2]CPYFAX = [F:BPAZ]TEL(1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPAZ]FAX
      Else
        [M:COR2]CPYFAX = [F:CNT]FAX
      Endif
    When "CPYMOB"
      If [F:CNT]MOB = "" Then
        #[M:COR2]CPYMOB = [F:AIN]CNTMOB  # FGR 04/04/2016 : X3SUIVI77755 plus [F:AIN]CNTMOB puisqu'il peut être différent
        [M:COR2]CPYFAX = [F:BPAZ]TEL(4)  # FGR 04/04/2016 : X3SUIVI77755
      Else
        [M:COR2]CPYMOB = [F:CNT]MOB
      Endif
    When "FNC"
      [M:COR2]FNC = GSCNTFNC
    When "MSS"
      [M:COR2]MSS = GSCNTMSS
    When "SRV"
      [M:COR2]SRV = GSCNTSRV
    When Default
  Endcase
Return

#############################################################################
#DETAIL
$COR_SET_DET_INFO
  Case IMPZON
    When "NBLIGNCOP"
      #If GREP = "C" Then                         # FGR 07/12/2010: X3SUIVI69722 : je ne vois pas à quoi ça sert
        [M:COR4]NBLIGNCOP = GINBREP
      #Endif                                      # FGR 07/12/2010: X3SUIVI69722 : je ne vois pas à quoi ça sert
    When "COPREP"
      #If GREP = "C"  Then                        # FGR 07/12/2010: X3SUIVI69722 : je ne vois pas à quoi ça sert
        If dim(GSZREP) >= 0 Then
          If indice = 0 Then
            If GSZREP <> "" Then
              [M:COR4]COPREP(indice) = GSZREP
            Endif
          Endif
        Else                                     # FGR 07/12/20110 : X3SUIVI69722 Endif
          #If indice > 0 Then                    # FGR 07/12/2010: X3SUIVI69722 : je ne vois pas à quoi ça sert
          [M:COR4]COPREP(indice) = GSTBREP(indice)
          #Endif
        Endif
      #Endif                                      # FGR 07/12/2010: X3SUIVI69722 : je ne vois pas à quoi ça sert
  Endcase
Return
# FGR 29/03/2010 : X3SUIVI63506 (fin)

#############################################################################
Funprog CTLTEL(TEL, PAYS)
Value Char TEL
Value Char PAYS

Local Char MESSA(250)
Local Integer AERROR

  # FGR 29/07/2010 : X3SUIVI66067
  AERROR = 0
  #MAE, bg 66067, appel de la fonction CONTTEL qui tient compte de la valeur du paramétre CTLTEL
  #et qui fait aussi le GOSUB OUVRE
  #Gosub OUVRE From CONTNUM
  #Call CNTTEL(TEL, MESSA) From CONTNUM
  Call CONTTEL(TEL,PAYS) From CONTNUM
  If GMESSAGE <> "" Then
    AERROR = 1
  Endif
End AERROR

