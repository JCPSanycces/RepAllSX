#**
#* Evaluates an expression
#* @param EXPR the expression to evaluate
#* @return RETOUR error code (0=OK) + separator + evaluated result
#*!
Funprog EVALUE_EXPR(EXPR)
Value Char EXPR()

Local Clbfile EVAL(10)
Local Clbfile RETOUR(11)
Local Char ERR(250)
Local Integer ERRCODE
Local Char ERRPRG(250), SERRPRG(250)
Local Integer ERRLINE, SERRLINE
Local Libelle DEBUGMODE

DEBUGMODE = [S]dbgmode
[S]dbgmode=2

ERRCODE = parse(EXPR)

Onerrgo EVALUE_EXPR_ERROR

Local Integer OK
Call FLUSHADX(OK) From AFLUSHADX

EVAL = ""
RETOUR = ""
If ERRCODE = 0
  EVAL = evalue(EXPR + "+''")
  # If the error has been trapped ERRCODE is not 0 at this point
  If ERRCODE <> 0
    ERRCODE = 0
    EVAL = num$(evalue(EXPR))
  Endif
Endif

If ERRCODE = 6
  ERRCODE = 0
  SERRPRG = ERRPRG
  SERRLINE = ERRLINE
  EVAL = evalue("func " + EXPR)
  If ERRCODE = 39
    # Non-existent Label, restore previous error
    ERRCODE = 6
    ERRPRG = SERRPRG
    ERRLINE = SERRLINE
  Endif
Endif

If ERRCODE = 0
  ERR = "1" + GXDT_NL_SEP
  RETOUR = ERR + EVAL
Else
  ERR = "0" + GXDT_NL_SEP + errmes$(ERRCODE) + "[" + ERRPRG + ":" + num$(ERRLINE) + "]" + GXDT_NL_SEP + num$(ERRCODE)
  RETOUR = ERR
Endif

Onerrgo

[S]dbgmode=DEBUGMODE

End RETOUR


$EVALUE_EXPR_ERROR
  ERRCODE = errn
  ERRPRG = errp
  ERRLINE = errl + 1
Resume

#**
#* Return <code>0</code> if file exists in the X3CLI directory and
#* <code>1</code> if it not exists
#* @param FILE_NAME
#* @param FILE_EXT
#*!
Funprog GET_X3CLI_FILE_INFO(FILE_NAME, FILE_EXT, INFO)
Value Char FILE_NAME
Value Char FILE_EXT
Variable Char INFO()()

Local Char REP(GDIMFIC)
Local Char NAMEREP(GDIMFIC)
Local Integer RETVAL

REP = "X3_ROOT/X3CLI"
# == get filename ==
#NAMEREP = filpath(REP, FILE_NAME, FILE_EXT, "X3_PUB", "", adxmac(-1))
# without adxmac to get the right machine in case of running in a process server
NAMEREP = filpath(REP, FILE_NAME, FILE_EXT, "X3_PUB")
INFO(0) = NAMEREP
# == get size ==
INFO(1) = num$(filinfo(NAMEREP,7))
#Infbox "ret=" + num$(FILE_ERR)
If val(INFO(1)) > 0
#  Infbox mess(101,100,1) + " : " + NAMEREP
  # == get modification date ==
  INFO(2) = num$(filinfo(NAMEREP,9))
  RETVAL = 0 : #OK
Else
  RETVAL = 1 : #KO
Endif

End RETVAL

#**
#* @return if ASUBPROGD table is present (used to determine which method to use).
#*!
Funprog ISASUBPROGDOK()
  Local Integer PRESENT
  PRESENT = filinfo(filpath("FIL", "ASUBPROGD", "fde", -1), 0)  # Table exists
End PRESENT

#**
#* Return method (Funprog or Subprog) info from ASUBPROG table
#* @param PROGRAM
#* @param SUBPRO
#*!
Funprog GETMETHODINFO(PROGRAM, SUBPRO)
Value Char    PROGRAM()
Value Char    SUBPRO()

Local Char    NAME(255)
Local Clbfile TEXT(4)
Local Clbfile FIELDS(4)
Local Char SUBPRO_TYPE(255)
Local Integer OK
Local Integer MAXPARAMIDX

If clalev([F:ASU])=0 : Local File ASUBPROG  [ASU] : Endif

# Initializations
NAME = ""
FIELDS = ""
TEXT = ""

Read [F:ASU]ASU0=PROGRAM;SUBPRO
If fstat=0
    Call TEXTE([F:ASU]INTIT, NAME) From OBJDIV
    If ([F:ASU]FONCTION = 1)
      SUBPRO_TYPE = "Subprog"
    Else
      SUBPRO_TYPE = "Funprog"
    Endif

    # Read text
    TEXT = func GETTEXT("ASU", PROGRAM + "_" + SUBPRO)

    # Concat method informations
    FIELDS = PROGRAM
    Append FIELDS, "."
    Append FIELDS, SUBPRO
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, NAME
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, SUBPRO_TYPE
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, num$([F:ASU]TYPFCT)
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, mess([F:ASU]TYPFCT, 33, 1)
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, [F:ASU]CODACT
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, num$([F:ASU]MODULE)
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, mess([F:ASU]MODULE, 14, 1)
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, num$([F:ASU]TYPASU)
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, mess([F:ASU]TYPASU, 7849, 1)
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, TEXT
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, GXDT_VALUE_SEP # deprecated
    Append FIELDS, GXDT_VALUE_SEP # see
    Append FIELDS, GXDT_VALUE_SEP # since
    Append FIELDS, GXDT_VALUE_SEP # return

    # Concat method parameters informations
    Local Integer ASUBPROGDOK : ASUBPROGDOK = func ISASUBPROGDOK()
    If ASUBPROGDOK > 0

      #------------------------------------------------------------------------------------
      # New method (params in a different table, ASUBPROGD)
      #------------------------------------------------------------------------------------
      If clalev([F:ASP])=0 : Local File ASUBPROGD [ASP] : Endif

      For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
        Call TEXTE([F:ASP]INTITPAR, NAME) From OBJDIV
        Append FIELDS, [F:ASP]PARAM
        Append FIELDS, GXDT_VALUE_SEP
        Append FIELDS, NAME
        Append FIELDS, GXDT_VALUE_SEP
        Append FIELDS, num$([F:ASP]TYPPAR)
        Append FIELDS, GXDT_VALUE_SEP
        Append FIELDS, mess([F:ASP]TYPPAR, 33, 1)
        Append FIELDS, GXDT_VALUE_SEP
        Append FIELDS, num$([F:ASP]DIME)
        Append FIELDS, GXDT_VALUE_SEP
        Append FIELDS, num$([F:ASP]ADRVAL)
        Append FIELDS, GXDT_VALUE_SEP
        Append FIELDS, mess([F:ASP]ADRVAL, 34, 1)
        Append FIELDS, GXDT_VALUE_SEP
      Next ASP
      Close Local File [F:ASP]
      #------------------------------------------------------------------------------------

    Else

      #------------------------------------------------------------------------------------
      # Old method (params in ASUBPROG table)
      #------------------------------------------------------------------------------------
      MAXPARAMIDX = [F:ASU]NBRPAR - 1
      For I = 0 To MAXPARAMIDX Step 1
        Call TEXTE([F:ASU]INTITPAR(I), NAME) From OBJDIV
        Append FIELDS, [F:ASU]PARAM(I)
        Append FIELDS, GXDT_VALUE_SEP
        Append FIELDS, NAME
        Append FIELDS, GXDT_VALUE_SEP
        Append FIELDS, num$([F:ASU]TYPPAR(I))
        Append FIELDS, GXDT_VALUE_SEP
        Append FIELDS, mess([F:ASU]TYPPAR(I), 33, 1)
        Append FIELDS, GXDT_VALUE_SEP
        Append FIELDS, num$([F:ASU]DIME(I))
        Append FIELDS, GXDT_VALUE_SEP
        Append FIELDS, num$([F:ASU]ADRVAL(I))
        Append FIELDS, GXDT_VALUE_SEP
        Append FIELDS, mess([F:ASU]ADRVAL(I), 34, 1)
        Append FIELDS, GXDT_VALUE_SEP
      Next I
      #------------------------------------------------------------------------------------

    Endif

    Append FIELDS, GXDT_NL_SEP

Endif
Close Local File [F:ASU]
End FIELDS

#**
#* Set text documentation (ASUBPROG)
#* @param PROGRAM
#* @param SUBPRO
#* @param TEXT
#*!
Subprog SETMETHODINFOTEXT(PROGRAM, SUBPRO, TEXT, MODUL, ACTIVITY)
Value Char    PROGRAM()
Value Char    SUBPRO()
Value Clbfile TEXT()
Value Integer MODUL
Value Char    ACTIVITY()

Local Char TIT
Call SETTEXT("ASU", PROGRAM + "_" + SUBPRO, TEXT, TIT, MODUL, ACTIVITY)
End


#**
#* Set method info (ASUBPROG)
#* @param PROGRAM
#* @param SUBPRO
#* @param RECORD infos (concateneted with separator)
#* @param TEXT explaination
#*!
Funprog SET_METHOD_INFO(PROGRAM, SUBPRO, RECORD, TEXT)
Value Char  PROGRAM()
Value Char  SUBPRO()
Value Clbfile RECORD()
Value Clbfile TEXT()

Local Char RETOUR(250)

Local Integer INTIT_NUMBER
Local Integer I
Local Integer PARAM_IDX, PARAM_NBR
Local Integer NBSPLIT
Local Integer MAXPARAMIDX
Local Integer NBSPLITMAX : NBSPLITMAX = 265
Local Integer WFSTAT
Local Char    TABSPLIT(255)(NBSPLITMAX+1)

Local Char SYMBOLE

If clalev([F:ASU])=0 : Local File ASUBPROG  [ASU] : Endif

SYMBOLE="ASU"+SUBPRO+"\"+PROGRAM
Lock =SYMBOLE With lockwait=0
If [S]fstat = 1     # locked record
    RETOUR = "0" + GXDT_NL_SEP + PROGRAM + "." + SUBPRO + " : " + mess(60,100,1)
Else
  Trbegin [ASU]
  Readlock [F:ASU]ASU0 = PROGRAM;SUBPRO
  WFSTAT = [S]fstat
  If WFSTAT <> 1
    NBSPLIT = func SPLIT_LOB(RECORD, GXDT_VALUE_SEP, TABSPLIT)

    # No longer create texts because of it generates too many translatable texts
    #Call SETMETHODINFOTEXT(PROGRAM, SUBPRO, TEXT, val(TABSPLIT(2)), TABSPLIT(1))

    Call NUMERO(TABSPLIT(0), INTIT_NUMBER) From OBJDIV
    [F:ASU]INTIT = INTIT_NUMBER
    [F:ASU]CODACT = TABSPLIT(1)
    [F:ASU]MODULE = val(TABSPLIT(2))
    [F:ASU]TYPASU = val(TABSPLIT(3))
    [F:ASU]FONCTION = val(TABSPLIT(4))
    [F:ASU]TYPFCT = val(TABSPLIT(5))

    # Parameters informations
    PARAM_IDX = 6 # number of occurences
    PARAM_NBR = 5 # number of elements by occurence
    MAXPARAMIDX = ( NBSPLIT - PARAM_IDX ) / PARAM_NBR

    Local Integer ASUBPROGDOK : ASUBPROGDOK = func ISASUBPROGDOK()
    If ASUBPROGDOK > 0
      #------------------------------------------------------------------------------------
      # New method (params in a different table, ASUBPROGD)
      #------------------------------------------------------------------------------------
      If clalev([F:ASP])=0 : Local File ASUBPROGD [ASP] : Endif

      Delete [ASP] Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
      If fstat
       Rollback : RETOUR = "0" + GXDT_NL_SEP + "" + PROGRAM + "." + SUBPRO
       Close Local File [F:ASU],[F:ASP]
       End RETOUR
      Endif

      [F:ASU]NBRPAR = MAXPARAMIDX

      If WFSTAT <> 0
        [F:ASU]PRG = PROGRAM
        [F:ASU]SUBPRG = SUBPRO
        Write [F:ASU]
      Else
        Rewrite [F:ASU]
      Endif

      # write parameters in ASUBPROGD
      If fstat = 0
        For I = 0 To MAXPARAMIDX - 1 Step 1
          [F:ASP]PRG = [F:ASU]PRG
          [F:ASP]SUBPRG = [F:ASU]SUBPRG
          [F:ASP]LIGNE = I
          [F:ASP]PARAM = TABSPLIT(I * PARAM_NBR + PARAM_IDX + 0)
          Call NUMERO(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 1), INTIT_NUMBER) From OBJDIV
          [F:ASP]INTITPAR = INTIT_NUMBER
          [F:ASP]TYPPAR = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 2))
          [F:ASP]DIME = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 3))
          [F:ASP]ADRVAL = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 4))
          Write [F:ASP]
        Next I
      Endif
      Close Local File [F:ASU],[F:ASP]
      #------------------------------------------------------------------------------------

    Else

      #------------------------------------------------------------------------------------
      # Old method (params in ASUBPROG table)
      #------------------------------------------------------------------------------------
      [F:ASU]NBRPAR = MAXPARAMIDX
      For I = 0 To MAXPARAMIDX - 1 Step 1
        [F:ASU]PARAM(I) = TABSPLIT(I * PARAM_NBR + PARAM_IDX + 0)
        Call NUMERO(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 1), INTIT_NUMBER) From OBJDIV
        [F:ASU]INTITPAR(I) = INTIT_NUMBER
        [F:ASU]TYPPAR(I) = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 2))
        [F:ASU]DIME(I) = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 3))
        [F:ASU]ADRVAL(I) = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 4))
      Next I

      If WFSTAT <> 0
        [F:ASU]PRG = PROGRAM
        [F:ASU]SUBPRG = SUBPRO
        Write [F:ASU]
      Else
        Rewrite [F:ASU]
      Endif
      #------------------------------------------------------------------------------------

    Endif
    Commit
    Unlock =SYMBOLE
    RETOUR = "1"
  Else      # locked record
    Rollback
    RETOUR = "0" + GXDT_NL_SEP + "" + PROGRAM + "." + SUBPRO + " : " + mess(60,100,1)
  Endif
Endif

Close Local File [F:ASU]

End RETOUR

Funprog GETTEXT(TYP, COD)
Value Char    TYP()
Value Char    COD()

If clalev([F:ADO])=0 : Local File ADOCUMENT  [ADO] : Endif
If clalev([F:ADH])=0 : Local File ADOCCLB    [ADH] : Endif

Local Integer OK
Local Clbfile TEXT(6) : TEXT = ""
Call LECTURE_DOC(TYP, COD, TEXT, OK) From SUBADO

#Close Local File [F:ADO]
#Close Local File [F:ADH]

End TEXT


Subprog SETTEXT(TYP,COD,TEX,TIT,MODU,ACT)
Value Char TYP , COD
Value Clbfile TEX
Value Char TIT
Value Integer MODU
Value Char ACT

If clalev([F:ADO])=0 : Local File ADOCUMENT  [ADO] : Endif
If clalev([F:ADH])=0 : Local File ADOCCLB    [ADH] : Endif

Call ECRIRE_DOC(TYP,COD,TEX,TIT,MODU,ACT) From SUBADO

#Close Local File [F:ADO]
#Close Local File [F:ADH]

End

#**
#* Return folder info (displayed in About dialog)
#* @param FLDER folder
#* @return info values
#*!
Funprog GET_PROJECT_INFO(FLDER)
Value Char FLDER

Local Char VERSION, RELEASE, NOPATCH
Local Char PROCESS_SVR(255)
Local Char RESULT(255)

Call VERSX3(FLDER, VERSION, RELEASE, NOPATCH) From INTRUTILA

# Process server
PROCESS_SVR = func GET_ENGINE_VERSION()

RESULT = "VER"
Append RESULT, GXDT_VALUE_SEP
Append RESULT, VERSION
Append RESULT, GXDT_NL_SEP
Append RESULT, "REL"
Append RESULT, GXDT_VALUE_SEP
Append RESULT, RELEASE
Append RESULT, GXDT_NL_SEP
Append RESULT, "PCH"
Append RESULT, GXDT_VALUE_SEP
Append RESULT, NOPATCH
Append RESULT, GXDT_NL_SEP
Append RESULT, "PROSVR"
Append RESULT, GXDT_VALUE_SEP
Append RESULT, PROCESS_SVR
Append RESULT, GXDT_NL_SEP
Append RESULT, "SOL"
Append RESULT, GXDT_VALUE_SEP
Append RESULT, GINSTID
Append RESULT, GXDT_NL_SEP
Append RESULT, "SOLVER"
Append RESULT, GXDT_VALUE_SEP
Append RESULT, GVERSOL
Append RESULT, GXDT_NL_SEP
Append RESULT, "SOLADR"
Append RESULT, GXDT_VALUE_SEP
Append RESULT, "http://"
Append RESULT, GVIRTDIR
Append RESULT, "/"
Append RESULT, GXDT_NL_SEP

End RESULT

#**
#* Returns the engine version in the forme XXr.YYY
#*!
Funprog GET_ENGINE_VERSION()
End func AXDTMAIN.PARTSEP(ver$(0),2," ")

#**
#* Returns filtered sessions list
#*!
Funprog GET_SESSIONS(FILTERS)
  Value Char FILTERS()
End func GET_SESSIONS_EX("", FILTERS)

#**
#* Returns filtered sessions list for a given folder
#*!
Funprog GET_SESSIONS_EX(FOLDER_FILTER, FILTERS)
  Value Char FOLDER_FILTER()
  Value Char FILTERS()

  Local Clbfile SESSIONS(6)
  SESSIONS = ""

  Local Char ID(250)
  Local Char PORT(250)
  Local Char CLI(250)
  Local Char TYP(25)
  Local Char PROC(250)
  Local Char PROCID(250)
  Local Char USER(250)
  Local Char UID(250)
  Local Char ADDR(250)
  Local Char FLDR(250)

  Local Char    WFUNCTION(250)
  Local Integer WMODULE
  Local Char    WLOGIN(250)

  Local Integer PORT_NUM

  Local Integer POS
  Local Char COMMAND(250)
  # a : Client address
  # f : Folder
  # g : X3 user (GUSER)
  # h : Date and time of the connection
  # i : Adonix ID
  # n : Login
  # t : Session type
  # p : Port number
  # x : Process ID
  # z : CPU time
  # -l LANG
  # -b APPLI
  # -u USER
  [L]COMMAND = "psadx -axptgfn"

  If FOLDER_FILTER <> ""
    [L]COMMAND += " -b " + FOLDER_FILTER
  Endif

  If FILTERS = ""
    Local File (SID, SPORT, SCLI, SADDR, SFLDR, SUSER, SUID, STYP, SPROC) From System adxmac(0)+"@" + [L]COMMAND + " " As [SYS_]
  Else
    Local File (SID, SPORT, SCLI, SADDR, SFLDR, SUSER, SUID, STYP, SPROC) From System adxmac(0)+"@" + [L]COMMAND + " " As [SYS_] Where evalue(FILTERS)
  Endif
  Onerrgo GET_SESS_ERR
  For [SYS_]
    If [F:SYS_]SID <> "Id" and left$([F:SYS_]SID,1) <> "-"
      If [F:SYS_]SPORT <> "" : [L]PORT = [F:SYS_]SPORT : Endif
      If [F:SYS_]SCLI <> "" : [L]CLI = [F:SYS_]SCLI : Endif
      If [F:SYS_]STYP <> "" : [L]TYP = [F:SYS_]STYP : Endif
      If [F:SYS_]SADDR <> "" : [L]ADDR = [F:SYS_]SADDR : Endif
      If [F:SYS_]SFLDR <> "" : [L]FLDR = [F:SYS_]SFLDR : Endif
      If [F:SYS_]SPROC = ""
        [L]PROC = [F:SYS_]SID
      Else
        [L]PROC = [F:SYS_]SPROC
      Endif
      If [F:SYS_]SUSER <> "" : [L]USER = [F:SYS_]SUSER : Endif
      If [F:SYS_]SUID <> "" : [L]UID = [F:SYS_]SUID : Endif

      POS = instr(0, [L]PORT, ":")
      If POS > 1
        [L]PORT = left$([L]PORT, POS - 1)
      Endif
      PORT_NUM = val([L]PORT)
      If PORT_NUM > 0

        POS = instr(0, [F:SYS_]SID, ":")
        If POS > 1
          [L]ID = left$([L]ID, POS - 1)
        Else
          [L]ID = [F:SYS_]SID
        Endif

        POS = instr(0, [L]PROC, ":")
        If POS > 1
          [L]PROCID = left$([L]PROC, POS - 1)
          [L]PROC = right$([L]PROC, POS + 1)
        Endif

        [L]WFUNCTION = ""
        [L]WMODULE = -1
        [L]WLOGIN = ""
        Call GET_CURFCT("", [L]FLDR, [F:SYS_]SID, [L]WFUNCTION, [L]WMODULE, [L]WLOGIN) From PSADX
        Append SESSIONS, [L]ID
        Append SESSIONS, GXDT_VALUE_SEP
        Append SESSIONS, GXDT_VALUE_SEP
        Append SESSIONS, [L]PROCID
        Append SESSIONS, GXDT_VALUE_SEP
        Append SESSIONS, [L]TYP
        Append SESSIONS, GXDT_VALUE_SEP
        Append SESSIONS, [L]CLI
        Append SESSIONS, GXDT_VALUE_SEP
        Append SESSIONS, [L]PORT
        Append SESSIONS, GXDT_VALUE_SEP
        Append SESSIONS, [L]UID
        Append SESSIONS, GXDT_VALUE_SEP
        Append SESSIONS, [L]PROC
        Append SESSIONS, GXDT_VALUE_SEP
        Append SESSIONS, [L]ADDR
        Append SESSIONS, GXDT_VALUE_SEP
        Append SESSIONS, [L]FLDR
        Append SESSIONS, GXDT_VALUE_SEP
        Append SESSIONS, [L]WFUNCTION
        Append SESSIONS, GXDT_VALUE_SEP
        Append SESSIONS, [L]USER
        Append SESSIONS, GXDT_NL_SEP
      Endif
    Endif
  Next SYS_
  Onerrgo
  Close Local File [SYS_]

End SESSIONS

$GET_SESS_ERR
Resume

Funprog GET_OSLOGIN()
  If dim(GXDT_OSLOGIN) > 0
    End GXDT_OSLOGIN
  Endif

  Global Char GXDT_OSLOGIN(50)
  GXDT_OSLOGIN = func GET_PID_OSLOGIN(adxpid)
End GXDT_OSLOGIN

Funprog GET_PID_OSLOGIN(PID)
  Value Integer PID

  Local Char FILTERS(50), OSLOGIN(50), COMMAND(250)

  FILTERS = "left$([F:SYS_]SPROC," + num$(len(num$(PID))) + ")='" + num$(PID) + "'"

  [L]COMMAND = "psadx -axptgfn -b " + nomap

  Local File (SID, SPORT, SCLI, SADDR, SFLDR, SUSER, SUID, STYP, SPROC) From System adxmac(0)+"@" + [L]COMMAND + " " As [SYS_] Where evalue(FILTERS)

  Onerrgo ERR_OSLOGIN
  # read header
  Read [SYS_] Next
  # read first line
  Read [SYS_] Next
  OSLOGIN = [F:SYS_]SUSER
  Onerrgo
  Close Local File [SYS_]
End OSLOGIN

#**
#* Attach to process
#*
#* @param ID proccess id to attach
#*!
Funprog ATTACH_PROCESS(HOST, PORT, ID)
Value Char HOST()
Value Char PORT()
Value Char ID()

  If func IS_TRACE_ON()
    Call TRACE(".ATTACH_PROCESS: host=" + HOST + ", port=" + PORT + ", process id=" + ID)
  Endif

  Local Clbfile RES(2)
  Local Char OSLOGIN(50), PID_OSLOGIN(50)

  Onerrgo ERR_OSLOGIN
  OSLOGIN = func GET_OSLOGIN
  PID_OSLOGIN = func GET_PID_OSLOGIN(val(ID))
  Onerrgo

  If func IS_TRACE_ON()
    Call TRACE("  OSLOGIN=" + OSLOGIN + ", PID_OSLOGIN=" + PID_OSLOGIN)
  Endif
  If OSLOGIN <> PID_OSLOGIN
    [L]RES = "0" + GXDT_NL_SEP
&    + "Process must run with the same system login as your Eclipse session"
&    + ": Eclipse='" + OSLOGIN + "', target='" + PID_OSLOGIN + "'"
  Else
    Local Integer STAT
    Local Char METHODNAME(250)
    [L]METHODNAME = "AXDTMAIN.ATTACH_PROCESS"
    [L]STAT = func =METHODNAME With (HOST, PORT, ID)

    If func IS_TRACE_ON()
      Call TRACE(".ATTACH_PROCESS: call " + [L]METHODNAME + ", return " + num$([L]STAT))
    Endif

    If [L]STAT = 0
      [L]RES = "1"
    Else
      [L]RES = "0" + GXDT_NL_SEP + "(" + [L]STAT + ") " + errmes$([L]STAT)
    Endif
  Endif
End [L]RES

$ERR_OSLOGIN
Resume

Funprog INIT_ENV(TRACEON)
  Value Libelle TRACEON

  Local Char RES(1)
  RES = func INIT_VARIABLES()

  If TRACEON
    Call TRACE_CLEAR()
    Call TRACE(".INIT_ENV: traceon=" + num$(TRACEON) + ", dim(GXDT_TRACE)=" + num$(dim(GXDT_TRACE)))
  Endif

  GXDT_TRACE = TRACEON
End ""

#**
#* Initialize global variables
#*!
Funprog INIT_VARIABLES()
  Local Char RES(1)
  RES = func AXDTMAIN.INIT_VARIABLES()
End RES

Funprog IS_TRACE_ON()
  If dim(GXDT_TRACE) < 0
    End 0
  Endif
End GXDT_TRACE

Subprog TRACE(DBGT_LINE)
  Value Char DBGT_LINE()

  Onerrgo ERR_TRACE
  Openo filpath("TRA","XDT_" + ctrans(toupper(adxusr),".\/|*@","______"),"tra",0), -1 Using [XTR_]
  Wrseq date$ + "-" + time$ + ": " + DBGT_LINE Using [XTR_]

  Openo Using [XTR_]
  Onerrgo
End

Subprog TRACE_CLEAR
  Onerrgo ERR_TRACE
  Openo filpath("TRA","XDT_" + ctrans(toupper(adxusr),".\/|*@","______"),"tra",0), 0 Using [XTR_]
  Openo Using [XTR_]
  Onerrgo
End

$ERR_TRACE
Resume

############################################################################################
# Rendez-vous management : call to AECLIRDV program
############################################################################################

Funprog ADDRDV(TRT,WRK,NAM,REF,MES)
Value    Char    TRT : # Nom du traitement
Value    Char    WRK : # Nom du Workspace IDE
Value    Char    NAM : # Alias de l'IDE
Variable Char    REF : # Identifiant interne du rendez-vous (unique pour la solution)
Variable Char    MES : # Message du statut en clair
  Local Integer STA : STA = -1
  Onerrgo ERR_RDV
  STA = func AECLIRDV.ADDRDV(TRT, WRK, NAM, REF, MES)
  Onerrgo
End STA

Funprog ADDRD2(TRT,WRK,NAM,TYP,UID,PRT,MAC,REF,MES)
Value    Char    TRT : # Nom du traitement
Value    Char    WRK : # Nom du Workspace IDE
Value    Char    NAM : # Alias de l'IDE
Value    Char    TYP : # Type d'exécution : EXE ou DBG
Value    Char    UID : # Id unique (adxuid(2))
Value    Char    PRT : # Port de debug
Value    Char    MAC : # Machine de debug
Variable Char    REF : # Identifiant interne du rendez-vous (unique pour la solution)
Variable Char    MES : # Message du statut en clair
  Local Integer STA : STA = -1
  Onerrgo ERR_RDV
  STA = func AECLIRDV.ADDRD2(TRT, WRK, NAM, TYP, UID, PRT, MAC, REF, MES)
  Onerrgo
End STA

$ERR_RDV
Resume

############################################################################################

$TEST
Return

