#**
#* Lock a file
#*
#* @param APPL
#* @param DIR
#* @param NAME
#* @param EXT extension
#* @since 01/04/2010
#*!
Funprog LOCK_FILE(APPL, DIR, NAME, EXT)
Value Char APPL()
Value Char DIR()
Value Char NAME()
Value Char EXT()
Local Clbfile VERROU(1)
VERROU = func INTERNAL_LOCK_FILE(APPL, DIR, NAME, EXT, 1)
End VERROU


#**
#* Lock a file
#*
#* @param APPL
#* @param DIR
#* @param NAME
#* @param EXT extension
#* @since 01/04/2010
#*!
Funprog INTERNAL_LOCK_FILE(APPL, DIR, NAME, EXT, WITHEXT)
Value Char APPL()
Value Char DIR()
Value Char NAME()
Value Char EXT()
Value Integer WITHEXT

Local Clbfile VERROU(1)
Local Char    FICLCK(GDIMFIC)
Local Char    LOCKDATE(30)
Local Char    LOCKRESULT(1)

FICLCK = filpath(DIR, NAME, "LCK"+EXT, APPL)
If filinfo(FICLCK,0)>0
 LOCKRESULT = "0"
 LOCKDATE = func GETLOCKDATETIME(FICLCK)
Else
 LOCKDATE = format$(GFMD,date$)-"-"-time$
 Openo FICLCK Using [LOK]
 Iomode adxifs ""       Using [LOK]
 Iomode adxirs chr$(10) Using [LOK]
 Iomode adxium GASCII   Using [LOK]
 Wrseq adxmac(-2) Using [LOK]
 Wrseq adxusr Using [LOK]
 Wrseq LOCKDATE Using [LOK]
 Wrseq "version: " + func GETVERSION Using [LOK]
 Wrseq "plugin: " + func GETPLUGINVERSION Using [LOK]
 Openo Using [LOK]
 LOCKRESULT = "1"
Endif

VERROU = LOCKRESULT
Append VERROU, GXDT_NL_SEP
Append VERROU, NAME
If WITHEXT<>0
  Append VERROU, "."
  Append VERROU, EXT
Endif
Append VERROU, GXDT_VALUE_SEP
Append VERROU, adxmac(-2)
Append VERROU, GXDT_VALUE_SEP
Append VERROU, adxusr
Append VERROU, GXDT_VALUE_SEP
Append VERROU, LOCKDATE

If LOCKRESULT <> "1"
 Append VERROU, GXDT_NL_SEP
 Append VERROU, func GETMESSLOCK(FICLCK)
Endif
End VERROU



#**
#* Unlock a file
#*
#* @param APPL
#* @param DIR
#* @param NAME
#* @since 01/04/2010
#*!
Subprog UNLOCK_FILE(APPL, DIR, NAME, EXT)
Value Char APPL()
Value Char DIR()
Value Char NAME()
Value Char EXT()

Local Char    FICLCK(GDIMFIC)
Local Integer STAT

FICLCK = filpath(DIR, NAME, "LCK"+EXT, APPL)

If FICLCK<>"" & filinfo(FICLCK, 0)>0
 Call EFFACE(FICLCK, STAT) From ORDSYS
Endif
End

#**
#* Gets lock message
#*
#* @param LOCKEDFILE
#*!
Funprog GETMESSLOCK(LOCKEDFILE)
Value Char    LOCKEDFILE()

Local Char LCKERR(250)(1..3)
Local Clbfile MESSLOCK(1)

Openi LOCKEDFILE Using [LOK]

Iomode adxifs ""       Using [LOK]
Iomode adxirs chr$(10) Using [LOK]
Iomode adxium GASCII   Using [LOK]

Rdseq LCKERR(1) Using [LOK]
Rdseq LCKERR(2) Using [LOK]
Rdseq LCKERR(3) Using [LOK]
Openi Using [LOK]
#Call ERREUR(mess(200,124,1)+"\|"+LCKERR(1)+"|\|"+LCKERR(2)+"|\|"+LCKERR(3)) From GESECRAN
MESSLOCK = mess(200,124,1)+" "+LCKERR(1)+" ("+LCKERR(2)+") - "+LCKERR(3)
End MESSLOCK

#**
#* Gets lock date time
#* @param LOCKEDFILE
#*!
Funprog GETLOCKDATETIME(LOCKEDFILE)
Value Char    LOCKEDFILE()

Local Char LCKERR(250)(1..3)
Local Char MESSLOCK(250)

Openi LOCKEDFILE Using [LOK]

Iomode adxifs ""       Using [LOK]
Iomode adxirs chr$(10) Using [LOK]
Iomode adxium GASCII   Using [LOK]

Rdseq LCKERR(1) Using [LOK]
Rdseq LCKERR(2) Using [LOK]
Rdseq LCKERR(3) Using [LOK]
Openi Using [LOK]
MESSLOCK = LCKERR(3)
End MESSLOCK

#**
#* Compiles a file
#*
#* @param PROG the program name without extension
#* @param FLDR the folder name
#*!
Funprog COMPILTRT(TRT, FLDR)
Value    Char    TRT()
Value    Char    FLDR()

Local Integer STAT , SAVSEEK
Local Char    FICTRA(GDIMFIC)
Local Char    ORDSYS(250)(1..2)
Local Char    MESSAGE(80)(1..5) , MESSA(80)
Local Char    SAVIFS(20), SAVIRS(20)
Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)
Local Char    VERSION(20)
Local Clbfile MESSCOMPILE(1)
Local Char EXT(10)
Local Char PROG(255)

EXT = tolower(func AXDTMAIN.PARTSEP(TRT, 2, "."))
PROG = func AXDTMAIN.PARTSEP(TRT, 1, ".")

If func IS_TRACE_ON()
  Call TRACE(".COMPILTRT: trt=" + TRT + ", prog=" + PROG + ", ext=" + EXT)
Endif

VERSION = func GET_ENGINE_VERSION()
Call MACHINE(FLDR, MACHINE, APPLI) From ORDSYS

SAVIFS = adxifs
SAVIRS = adxirs
Case EXT
 When "stc"
  ORDSYS(1) = "valstc"
  MESSA = mess(2,140,1) : # Erreur en validation de la classe
 When Default
  ORDSYS(1) = "valtrt"
  MESSA = mess(20,123,1) : # Erreur en validation du traitement
Endcase

If VERSION >= "16r.216"
  ORDSYS(1) -= ("-l" - GLANGUE)
Endif
ORDSYS(1) -= (APPLI - PROG)

FICTRA = filpath("tmp", PROG, "tra", APPLI, "", MACHINE)
Openo FICTRA, 0
Openo

ORDSYS(2)  = FICTRA

If func IS_TRACE_ON()
  Call TRACE("....: machine=" + MACHINE + ", ordsys(1)=" + ORDSYS(1) + ", ordsys(2)=" + ORDSYS(2))
Endif

Call SYSTEME(MACHINE, ORDSYS, "", STAT) From ORDSYS
#If STAT
# Call ECR_TRACE(mess(6,123,1)-NUM$(STAT)-"SYSTEME"+"\|"+ORDSYS(1),1) From GESECRAN : # Erreur
#Endif

adxifs = ""
adxirs = chr$(10)
Openi FICTRA
Raz MESSAGE
Rdseq MESSAGE(1)
Rdseq MESSAGE(2)
Rdseq MESSAGE(3)
Rdseq MESSAGE(4)
Rdseq MESSAGE(5)
Openi

If MESSAGE(1)<>""
  If func IS_TRACE_ON()
    Call TRACE(".==> Error: " + MESSA-PROG+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3)+"|\|"+MESSAGE(4))
  Endif
  MESSCOMPILE = MESSA
  Append MESSCOMPILE, " "
  Append MESSCOMPILE, PROG
  Append MESSCOMPILE, GXDT_VALUE_SEP
  Append MESSCOMPILE, MESSAGE(1)
  Append MESSCOMPILE, GXDT_VALUE_SEP
  Append MESSCOMPILE, MESSAGE(2)
  Append MESSCOMPILE, GXDT_VALUE_SEP
  Append MESSCOMPILE, MESSAGE(3)
  Append MESSCOMPILE, GXDT_VALUE_SEP
  Append MESSCOMPILE, MESSAGE(4)
Else
  If func IS_TRACE_ON()
    Call TRACE(".==> OK")
  Endif
  MESSCOMPILE = "1"
  Call EFFACE(FICTRA, STAT) From ORDSYS
# If STAT
#  Call ECR_TRACE(mess(6,123,1)-NUM$(STAT)-"EFFACE"+"\|"+FICTRA,1) From GESECRAN : # Erreur
# Endif
Endif

adxifs = SAVIFS
adxirs = SAVIRS

End MESSCOMPILE


#**
#* Get local menu label or messages from chapter if number = -1
#*
#* @param CHAPTER
#* @param NUMBER
#* @param FILENUMBER
#*!
Funprog GETLOCALMENU(CHAPTER, NUMBER, FILENUMBER)
Value    Char    CHAPTER()
Value    Char    NUMBER()
Value    Char    FILENUMBER()

Local Integer NCHAPTER
Local Integer NNUMBER
Local Integer NFILENUMBER

NCHAPTER = val(CHAPTER)
NNUMBER = val(NUMBER)
NFILENUMBER = val(FILENUMBER)

Local Clbfile MESSAGE(6)
Local Char MSG(250)
Local Char CHAPTER_TITLE(250)
Local Integer I
Local Integer NBMAX : NBMAX = 300

If NNUMBER = -1 # return all messages from chapter

  # Read local menu title
  If clalev([F:AST7])=0 : Local File APLSTD  [AST7] : Endif
  If NCHAPTER<100
    Read [AST7]CLE = 0;NCHAPTER;GLANGUE
  Else
    Read [AST7]CLE = 200;NCHAPTER-200;GLANGUE
  Endif
  If fstat
    Read [AST7]CLE = NCHAPTER;0;GLANGUE
  Endif
  If !fstat
    CHAPTER_TITLE = [F:AST7]LANMES

    # Read first NBMAX records
    For I = 1 To NBMAX
      MSG = mess(I, NCHAPTER, NFILENUMBER)
      If MSG <> ""
        If MESSAGE <> ""
          Append MESSAGE, GXDT_VALUE_SEP
        Endif
        Append MESSAGE, num$(I)
        Append MESSAGE, " - "
        Append MESSAGE, MSG
      Endif
    Next I

    # If more than NBMAX records, display "..."
    MSG = mess(NBMAX + 1, NCHAPTER, NFILENUMBER)
    If MSG <> ""
      If MESSAGE <> ""
        Append MESSAGE, GXDT_VALUE_SEP
      Endif
      Append MESSAGE, " ... "
    Endif

    If MESSAGE <> ""
      MSG = CHAPTER
      Append MSG, " - '"
      Append MSG, CHAPTER_TITLE
      Append MSG, "'"
      Append MSG, GXDT_VALUE_SEP

      MESSAGE = MSG + MESSAGE
    Endif
  Endif

Else
  MESSAGE = mess(NNUMBER, NCHAPTER, NFILENUMBER)
Endif
End MESSAGE


#**
#* Format source header
#*!
Funprog GETFILEHEADER()
Local Char FILEHEADER(80)
FILEHEADER = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
FILEHEADER = ctrans(FILEHEADER,chr$(0),"")
End FILEHEADER

#**
#* Gets source from server (as a clob)
#*
#* @param X3FOLDER folder
#* @param SRCCODE file name
#* @param FILEEXT file extension (src, stc)
#* @param FILEDIR file directory (TRT, STC)
#*
#* @since 12/05/2011 : Gets source from server (as a clob) with no CR+LF at lines end (only LF)
#*!
Funprog GET_FILE(X3FOLDER, SRCCODE, FILEEXT, FILEDIR)
Value Char    X3FOLDER()
Value Char    SRCCODE()
Value Char    FILEEXT()
Value Char    FILEDIR()
End func INTERNAL_GET_FILE(X3FOLDER, SRCCODE, FILEEXT, FILEDIR, 0)


#**
#* Gets source from server (as a clob)
#*
#* @param X3FOLDER folder
#* @param SRCCODE file name
#* @param FILEEXT file extension (src, stc)
#* @param FILEDIR file directory (TRT, STC)
#* @param ADD_CR_LF add CR+LF at the end of each line if equals 1
#* @private
#*!
Funprog INTERNAL_GET_FILE(X3FOLDER, SRCCODE, FILEEXT, FILEDIR, ADD_CR_LF)
Value Char    X3FOLDER()
Value Char    SRCCODE()
Value Char    FILEEXT()
Value Char    FILEDIR()
Value Integer ADD_CR_LF

#Local Char    FILEHEADER(80)
#FILEHEADER = func GETFILEHEADER()

Local Char SRCNAME(GDIMFIC)
SRCNAME = filpath(FILEDIR, SRCCODE, FILEEXT, X3FOLDER)

Local Clbfile FILECONTENT(11)
Raz FILECONTENT

Local Integer DIME, I, J, K, NB, R
If filinfo(SRCNAME, 0)<0 : End FILECONTENT : Endif

Local Char    CHAINE(250)
DIME = 10000
Local Char    LINE(255)(1..DIME)

Openi SRCNAME Using [TRT]
Iomode adxifs "" Using [TRT]
Iomode adxirs chr$(10) Using [TRT]
Iomode adxium GUTF8 Using [TRT]

Raz LINE, NB
Rdseq CHAINE Using [TRT]
#If !fstat & left$(CHAINE,5)<>left$(FILEHEADER,5)
 NB += 1
 LINE(NB) = ctrans(CHAINE,chr$(0),"_") + chr$(10)
#Endif

Iomode adxirs "" Using [TRT]
Rdseq CHAINE Using [TRT]
While CHAINE<>""
 While CHAINE<>""
  If NB>=DIME
#   Call ERREUR("|"+SRCNAME-"|\"-mess(175,115,1)) From GESECRAN : # Taille du fichier trop grande
   Break 2
  Else
   K = instr(1,CHAINE,chr$(10))
   If K
    NB += 1
    LINE(NB) = left$(CHAINE,K)
    CHAINE = right$(CHAINE,K+1)
   Else
    NB += 1
    LINE(NB) = CHAINE
    CHAINE = ""
   Endif
  Endif
 Wend
 Rdseq CHAINE Using [TRT]
Wend
Openi Using [TRT]
fstat=0

If ADD_CR_LF
  # Le fichier .src contient des LF en fin de ligne
  # La saisie du clob par le client x3 rajoute des CR+LF en fin de ligne
  # A la lecture du .src , on rajoute des CR+LF en bout de ligne pour eviter une apres_modif inutile
  R = 1
  For I=1 To NB
   K = len(LINE(I))
   If right$(LINE(I),K)=chr$(10)
  #  If R
  #   LINE(I) = format$("KTv1:"+num$(type(LINE))+"X",left$(LINE(I),K-1))+chr$(13)+chr$(10)
  #  Else
     LINE(I) = left$(LINE(I),K-1)+chr$(13)+chr$(10)
  #  Endif
    R = 1
   Else
    R = 0
   Endif
  Next I
Endif

Setlob FILECONTENT With LINE

If func IS_TRACE_ON()
  Call TRACE(".GET_FILE: name=" + SRCNAME + ", lines=" + num$(NB))
Endif
End FILECONTENT



#**
#* Puts source to server (receive as a clob)
#*
#* @param X3FOLDER folder
#* @param SRCCODE file name
#* @param FILEEXT file extension (src, stc)
#* @param FILEDIR file directory (TRT, STC)
#* @param FILECONTENT file content
#* @since 01/04/2010
#*!
Funprog PUT_FILE(X3FOLDER, SRCCODE, FILEEXT, FILEDIR, FILECONTENT)
Value Char    X3FOLDER()
Value Char    SRCCODE()
Value Char    FILEEXT()
Value Char    FILEDIR()
Value Clbfile FILECONTENT()

Local Char OK(1)
Local Integer DIME , I , K , NB
DIME = 10000
Local Char    LIGNE(255)(1..DIME)

#Local Char    FILEHEADER(80)
#FILEHEADER = func GETFILEHEADER()

Local Char SRCNAME(GDIMFIC)
SRCNAME = filpath(FILEDIR, SRCCODE, FILEEXT, X3FOLDER)

Local Integer STA
Local Char    MACHINE(250), APPLI(GLONADS)
Local Char    MES(250)

Raz LIGNE
Setlob LIGNE With FILECONTENT
If LIGNE=""
 # Delete empty file
 Call DELETE_FILE(SRCCODE, X3FOLDER, "1", "", FILEEXT, FILEDIR)
 OK = "0"
 End
Endif

OK = "1"
NB = DIME
While NB & LIGNE(NB)=""
 NB -= 1
Wend
# Deletion of CR from clob before writing file
For I=1 To NB
 LIGNE(I) = ctrans(LIGNE(I),chr$(13),"")
Next I

Openo SRCNAME, 0 Using [TRT]
Iomode adxifs ""       Using [TRT]
Iomode adxirs chr$(10) Using [TRT]
Iomode adxium GUTF8 Using [TRT]

#Wrseq FILEHEADER-[M]DES Using [TRT]
#Wrseq FILEHEADER       Using [TRT]
Iomode adxirs ""       Using [TRT]
For I=1 To NB
 Wrseq LIGNE(I) Using [TRT]
Next I
Openo Using [TRT]

# Fill ADICTRT table
Onerrgo ERR_RECOVERABLE
Call MACHINE(X3FOLDER, MACHINE, APPLI) From ORDSYS
STA = func SUBADC.DICTRT(SRCCODE, FILEEXT, X3FOLDER, MACHINE, "", 1, MES)
Onerrgo

If func IS_TRACE_ON()
  Call TRACE(".PUT_FILE: name=" + SRCNAME + ", lines=" + num$(NB))
Endif
End OK

$ERR_RECOVERABLE
If dim(ERR_INFO) > 0
  ERR_INFO = errmes$(errn) + "(" + num$(errn) + ") [" + errp + ":" + num$(errl) + "]"
Endif
Resume

#**
#* Delete a file from server
#*
#* @param SRCCODE trt code (eg SUBITM)
#* @param X3FOLDER folder (eg SUPERV)
#* @param DELETEADX "1" for ADX deletion
#* @param CONDITION deletion condition (eg GADONIX<>2)
#* @param FILEEXT file extension (src, stc)
#* @param FILEDIR file directory (TRT, STC)
#* @since 01/04/2010
#*!
Subprog DELETE_FILE(SRCCODE, X3FOLDER, DELETEADX, CONDITION, FILEEXT, FILEDIR)
  Value Char    SRCCODE()
  Value Char    X3FOLDER()
  Value Char    DELETEADX()
  Value Char    CONDITION()
  Value Char    FILEEXT()
  Value Char    FILEDIR()

  Local Integer STAT
  Local Char NOMSRC(GDIMFIC)
  Local Integer NEED_TO_DELETE

  If CONDITION = ""
    NEED_TO_DELETE = 1
  Else
    NEED_TO_DELETE = evalue(CONDITION)
  Endif

  If NEED_TO_DELETE = 1
    NOMSRC = filpath(FILEDIR, SRCCODE, FILEEXT, X3FOLDER)
    Call EFFACE(NOMSRC, STAT) From ORDSYS
    If DELETEADX = "1"
      Call EFFACE_ADX("", X3FOLDER, SRCCODE, STAT) From ORDSYS
    Endif
    # Delete the dictionary entry if this is a "trt"
    If FILEEXT="src"
      Call DEL_DIC_PRG(X3FOLDER, SRCCODE)
    Endif
  Endif
End

#**
#* Delete the dictionary entry for the given program
#*
#* @param X3FOLDER folder in which the program is supposed to be
#* @param SRCCODE the code of program (so without extension)
#*!
Subprog DEL_DIC_PRG(X3FOLDER, SRCCODE)
  Value Char X3FOLDER(), SRCCODE()

  Onerrgo ERR_RECOVERABLE
    If X3FOLDER="" | X3FOLDER=nomap
     Local File ADICTRT [ADC] , ADOCUMENT [ADO] , ADOCCLB [ADH] , ATEXTE [ATX]
    Else
     Local File =X3FOLDER+".ADICTRT"   [ADC]
     Local File =X3FOLDER+".ADOCUMENT" [ADO]
     Local File =X3FOLDER+".ADOCCLB"   [ADH]
     Local File =X3FOLDER+".ATEXTE"    [ATX]
    Endif
    Call DEL(SRCCODE) From SUBADC
    Close Local File [ADC] , [ADO] , [ADH] , [ATX]
  Onerrgo
End

#**
#* Gets the list of programs on server (in a folder)
#* Exclude W* programs (generated programs)
#*
#* @param DOSSIER
#* @param START
#* @param NBMAX
#*!
Funprog GETFILESLIST(DOSSIER, START, NBMAX)

Value Char    DOSSIER()
Value Char    START()
Value Char    NBMAX()

Local Char    FILTRE(250)
Local Clbfile FILES(10)

FILTRE = 'left$(TRT,1)<>"W"'
FILES = func GETFILTEREDFILESLIST(DOSSIER, START, FILTRE, NBMAX)

End FILES


#**
#* Gets the filtered list of programs on server (in a folder)
#* @param DOSSIER
#* @param START
#* @param FILTERS
#* @param NBMAX
#*!
Funprog GETFILTEREDFILESLIST(DOSSIER, START, FILTERS, NBMAX)
Value Char    DOSSIER()
Value Char    START()
Value Char    FILTERS()
Value Char    NBMAX()

Local Clbfile FILES(10)
FILES = func GETFILES(DOSSIER, START, FILTERS, NBMAX, "src", "TRT")
End FILES


#**
#* Gets a filtered list of files on server (in specified folder and directory)
#*
#* @param DOSSIER folder
#* @param START starting name
#* @param FILTERS caller filters
#* @param NBMAX max number of files returned
#* @param FILEEXT file extension (src, stc)
#* @param FILEDIR file directory (TRT, STC)
#* @since 01/04/2010
#*!
Funprog GETFILES(DOSSIER, START, FILTERS, NBMAX, FILEEXT, FILEDIR)
Value Char    DOSSIER()
Value Char    START()
Value Char    FILTERS()
Value Char    NBMAX()
Value Char    FILEEXT()
Value Char    FILEDIR()

Local Char    FILTRE(250), REPERT(GDIMFIC)
Local Char    MACHINE(250), APPLI(GLONADS), ORDSYS(250)
Local Char    CODTRT(GLONADC)
Local Integer NB_TRT, K
Local Integer NB_MAX

Local Clbfile FILES(10)


# Default values initialization
If NBMAX = "-1" : NB_MAX = GNBSEL : Else : NB_MAX = val(NBMAX) : Endif
If DOSSIER="" : DOSSIER = nomap : Endif

Call MACHINE(DOSSIER, MACHINE, APPLI) From ORDSYS
REPERT = filpath(FILEDIR, "", "", APPLI, "", MACHINE)

# Insert start filter
If START=""
  FILTRE = ""
Else
  FILTRE = 'TRT>="'+START+'"'
Endif

# Exclude empty named files
If FILTRE<>"" : Append FILTRE, "&" : Endif
Append FILTRE, 'TRT<>""'

# insert caller filters
If FILTERS<>""
  If FILTRE<>"" : Append FILTRE, "&" : Endif
  Append FILTRE, FILTERS
Endif

If clalev([F:TRT_])>0 : Close Local File [TRT_] : Endif
Case FILEEXT
 When "src"
  ORDSYS = MACHINE+"@"+'lsadx -a'-toupper(APPLI)-REPERT
  Append FILTRE, '& pat(TRT,"*.src")'
 When "stc"
  ORDSYS = MACHINE+"@"+'lsadx -a'-toupper(APPLI)-REPERT
  Append FILTRE, '& pat(TRT,"*.stc")'
 When Default
  ORDSYS = MACHINE+"@"+'archive -d '+DOSSIER-' -t "adx" -l "*" -v'
Endcase
Local File (TRT(30)) From System ORDSYS As [TRT_]

NB_TRT =0
For [TRT_] Where evalue(FILTRE)
 NB_TRT += 1
 K = instr(1, [F:TRT_]TRT, "."+FILEEXT)
 If K
  CODTRT = left$([F:TRT_]TRT, K-1)
 Else
  CODTRT = [F:TRT_]TRT
 Endif
 If NB_TRT > NB_MAX
   Break
 Endif
 Append FILES, CODTRT
 Append FILES, GXDT_VALUE_SEP
Next TRT_
End FILES


$KEEP_ERROR
ER = errn
Resume

#**
#* Gets the list of files modified since a timestamp
#*
#* @param DOSSIER
#* @param START
#* @param FILTERS
#* @param NBMAX
#* @param FILEEXT
#* @param FILEDIR
#*!
Funprog GET_MODIFIED_FILES(DOSSIER, START, FILTERS, OPT, NB_MAX, FILEEXT, FILEDIR, TIMEREF)
  Value Char    DOSSIER()
  Value Char    START()
  Value Char    FILTERS()
  Value Char    OPT()
  Value Integer NB_MAX
  Value Char    FILEEXT()
  Value Char    FILEDIR()
  Value Integer TIMEREF

  Local Char    FILTRE(250), REPERT(GDIMFIC)
  Local Char    MACHINE(250), APPLI(GLONADS), ORDSYS(250)
  Local Char    CODTRT(GLONADC)
  Local Integer NB_TRT, K

  Local Clbfile RES(10)
  Local Char TSTART(20)

  TSTART = timestamp$
  # Default values initialization
  If NB_MAX = -1 : NB_MAX = GNBSEL : Endif
  If DOSSIER="" : DOSSIER = nomap : Endif

  Call MACHINE(DOSSIER, MACHINE, APPLI) From ORDSYS
  REPERT = filpath(FILEDIR, "", "", APPLI, "", MACHINE)

  # Insert start filter
  If START=""
    FILTRE = ""
  Else
    FILTRE = 'TRT>="'+START+'"'
  Endif

  # Exclude empty named files
  If FILTRE<>"" : Append FILTRE, "&" : Endif
  Append FILTRE, 'TRT<>""'

  # insert caller filters
  If FILTERS<>""
    If FILTRE<>"" : Append FILTRE, "&" : Endif
    Append FILTRE, FILTERS
  Endif

  If clalev([F:TRT_])>0 : Close Local File [TRT_] : Endif
  ORDSYS = MACHINE+"@"+'lsadx -a'-toupper(APPLI) - OPT -REPERT-FILEEXT
  Local File (TRT(30)) From System ORDSYS As [TRT_]

  Local Char REP(GDIMFIC)
  Local Char NAMEREP(GDIMFIC)
  Local Integer RETVAL
  Local Integer TIMEMAX, TIMEMOD
  NB_TRT = 0
  For [TRT_] Where evalue(FILTRE)
    If NB_TRT >= NB_MAX
      Break
    Endif
    K = instr(1, [F:TRT_]TRT, "."+FILEEXT)
    If K
      CODTRT = left$([F:TRT_]TRT, K-1)
    Else
      CODTRT = [F:TRT_]TRT
    Endif
    NAMEREP = filpath(REPERT, CODTRT, FILEEXT, DOSSIER)
    TIMEMOD = filinfo(NAMEREP,9)
    If TIMEMAX < TIMEMOD : TIMEMAX = TIMEMOD : Endif
    If TIMEMOD >= TIMEREF
      NB_TRT += 1
      Append RES, CODTRT
      Append RES, GXDT_VALUE_SEP
      Append RES, num$(TIMEMOD)
      Append RES, GXDT_NL_SEP
    Endif
  Next TRT_
  Append RES, GXDT_NL_SEP
  Append RES, num$(NB_TRT)
  Append RES, GXDT_VALUE_SEP
  Append RES, num$(TIMEREF)
  Append RES, GXDT_VALUE_SEP
  Append RES, num$(TIMEMAX)
  Append RES, GXDT_VALUE_SEP
  Append RES, num$(val(timestamp$) - val(TSTART))
  Append RES, GXDT_VALUE_SEP

End RES

#**
#* Get locked files list
#* @since 01/04/2010
#*!
Funprog GET_LOCKED_FILES
Local Clbfile FILELIST(10)
FILELIST = func INTERNAL_GET_LOCKED_FILES("STC", "stc", 1)
Append FILELIST, func INTERNAL_GET_LOCKED_FILES("TRT", "src", 1)
End FILELIST

#**
#* Get locked files list for special directory and extension
#*
#* @param DIR directory
#* @param EXT extension
#*!
Funprog INTERNAL_GET_LOCKED_FILES(DIR, EXT, WITHEXT)
Value Char DIR()
Value Char EXT()
Value Integer WITHEXT

Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Char    APPLI(GLONADS) , FILEEXT(10)
Local Char    FICHIER(250)
Local Integer NBTRT, I, J, LINE
Local Char    TBTRT(GLONADC+2)(1..300)
Local Char    STR(250)(10)

Local Clbfile FILES(10)

APPLI = nomap
FILEEXT   = "LCK"+EXT

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GASCII

# Infbox(adxtct-adxmac(-1)-" | "-adxmac(-2))
Call SYSTEME2(adxmac(0), "lsadx -a"-APPLI-DIR-FILEEXT, "", NBTRT, TBTRT) From ORDSYS
For I=1 To min(NBTRT, dim(TBTRT))
 FICHIER = filpath(DIR, TBTRT(I), FILEEXT, APPLI)
 If filinfo(FICHIER, 0)>=0
  Openi FICHIER
  LINE = 0
  Repeat
    Rdseq STR(LINE)
    LINE += 1
  Until fstat <> 0 | LINE = 10
  Openi

  # Program / Machine / User / DateTime / Version / Plugin
  Append FILES, TBTRT(I)
  If WITHEXT <> 0
    Append FILES, "."
    Append FILES, EXT
  Endif
  For J = 0 To LINE-1
    Append FILES, GXDT_VALUE_SEP
    Append FILES, STR(J)
  Next J
  Append FILES, GXDT_NL_SEP

 Endif
Next I

adxirs = SAVIRS
adxifs = SAVIFS
adxium = SAVIUM
End FILES


#**
#* Get default help location
#*!
Funprog GET_HELP_PATH()
Local Char RETOUR(200)
Local Integer OK
Call RECHPROP("doc.files.clientwebaccessurl", RETOUR, OK) From INTRUTILA
End RETOUR

#**
#* Get Solution name
#*!
Funprog GET_SOLUTION_NAME()
 If dim(GINSTID) > 0 & GINSTID <> ""
   End GINSTID
 Endif

 Local Char SOLUTION(200)
 Local Char NOMFIC(200), VALL1(200)

 Call NAMEFIC(nomap,"SOL","","",NOMFIC) From INTRUTILA
 If filinfo(NOMFIC,7)<0 : Goto ERRLEC : Endif
 fstat=0
 Openi NOMFIC,0 Using [CST_]
 If fstat<>0 : Goto ERRLEC : Endif
 Iomode adxifs ""  Using [CST_]
 Iomode adxirs chr$(10)  Using [CST_]
 Iomode adxium GUTF8  Using [CST_]
 fstat=0
 While fstat=0
   Rdseq VALL1 Using [CST_]
   If instr(1,VALL1,"<solution")<>0
     I1=instr(1,VALL1,"name")
     I2=instr(I1+6,VALL1,'"')
     If I2-I1-6>0
       SOLUTION=vireblc(mid$(VALL1,I1+6,I2-I1-6),2)
     Endif
   Endif
 Wend
 Openi Using [CST_]
End SOLUTION

$ERRLEC:
End ""

#**
#* Return folder where source file could be found
#*
#* @param SOURCEFILE source name (with or without extension)
#*!
Funprog GET_FOLDER(SOURCEFILE)
Value Char SOURCEFILE()

If SOURCEFILE = ""
  End ""
Endif

Local Char SOURCENAME(250)
Local Char FOLDR(250)
Local Char WNAME(GDIMFIC)
Local Integer POSEXT
POSEXT = instr(0, SOURCEFILE, ".")
If POSEXT > 0
  SOURCENAME = left$(SOURCEFILE, POSEXT - 1)
Else
  SOURCENAME = SOURCEFILE
Endif

Local Integer I
For I = 0 To dim(nomap) - 1
  If nomap(I) <> ""
    WNAME = filpath("TRT", SOURCENAME, "src", I)
    If filinfo(WNAME, 0) >= 0
      FOLDR = nomap(I)
      Break
    Endif
  Endif
Next I
End FOLDR


#**
#* Get file properties (infos displayed in ADICTRT)
#*
#* @param NOMFIC
#*!
Funprog GET_FILE_PROPERTIES(NOMFIC)
Value Char NOMFIC()

Local Clbfile RETOUR(6)

Local Char WSRC(250)
Local Char WSRCINT(250)
Local Char WINFO(250)(0..6)
Local Char WSEPARATOR(5) : WSEPARATOR = "|"
Local Clbfile TEXT(4) : TEXT = ""

If clalev([F:ADC])=0 : Local File ADICTRT [ADC] : Endif

NAME = ""

Read [F:ADC]ADC0=NOMFIC
If !fstat
#    Call TEXTE([F:ADC]INTITFIC, NAME) From OBJDIV

    If [F:ADC]SRC <> 2
        WSRC = "false"
    Else
        WSRC = "true"
    Endif

    If [F:ADC]SRCINT <> 2
        WSRCINT = "false"
    Else
        WSRCINT = "true"
    Endif

    Call INFOS(NOMFIC, WINFO)

    TEXT = func GETTEXT("TRT", NOMFIC)

    Append RETOUR, [F:ADC]CODTRT
    Append RETOUR, GXDT_VALUE_SEP
    Append RETOUR, [F:ADC]DES
    Append RETOUR, GXDT_VALUE_SEP
    Append RETOUR, num$([F:ADC]MODULE)
    Append RETOUR, GXDT_VALUE_SEP
    Append RETOUR, mess([F:ADC]MODULE, 14, 1)
    Append RETOUR, GXDT_VALUE_SEP
    Append RETOUR, [F:ADC]CODACT
    Append RETOUR, GXDT_VALUE_SEP
    Append RETOUR, WSRC
    Append RETOUR, GXDT_VALUE_SEP
    Append RETOUR, WSRCINT
    Append RETOUR, GXDT_VALUE_SEP
    Append RETOUR, TEXT
    Append RETOUR, GXDT_VALUE_SEP
    Append RETOUR, WINFO(0)
    Append RETOUR, WSEPARATOR
    Append RETOUR, WINFO(1)
    Append RETOUR, WSEPARATOR
    Append RETOUR, WINFO(2)
    Append RETOUR, WSEPARATOR
    Append RETOUR, WINFO(3)
    Append RETOUR, WSEPARATOR
    Append RETOUR, WINFO(4)
    Append RETOUR, WSEPARATOR
    Append RETOUR, WINFO(5)
    Append RETOUR, WSEPARATOR
    Append RETOUR, WINFO(6)
    Append RETOUR, GXDT_NL_SEP

Endif

Close Local File [F:ADC]

End RETOUR

#**
#*
#* @param FICHIER
#* @param INFOS
#*!
Subprog INFOS(FICHIER, INFOS)
Value Char    FICHIER()
Variable Char INFOS()(0..6)
Raz INFOS
Local Integer L

Local Decimal PROPRIO
Local Decimal TAILLE
Local Date    DATMOD
Local Char    HREMOD(8)
Local Integer OK

Gosub CHARGE_USR From SUBADC

L = 0
Call INFOFIC("TRT", FICHIER, "src", PROPRIO, TAILLE, DATMOD, HREMOD, OK) From SUBADC
If OK<0
 INFOS(L) = mess(55,100,1)
 Append INFOS(L), " src "
 Append INFOS(L), mess(87,100,1)
Else
 INFOS(L) = mess(55,100,1)
 Append INFOS(L), " src "
 Append INFOS(L), mess(172,126,1)
 Append INFOS(L), " "
 Append INFOS(L), nomap(OK)
 L += 1
 INFOS(L) = num$(TAILLE)
 Append INFOS(L), " "
 INFOS(L) = mess(133,133,1)
 If NBUSER
  Gosub USER From SUBADC
  Append INFOS(L), ", "
  Append INFOS(L), mess(134,133,1)
  Append INFOS(L), " "
  Append INFOS(L), IDUSR
 Endif
 Append INFOS(L), ", "
 Append INFOS(L), mess(162,124,1)
 Append INFOS(L), " "
 Append INFOS(L), format$("D:"+GFMDAT4,DATMOD)
 Append INFOS(L), " "
 Append INFOS(L), HREMOD
 Append INFOS(L), " GMT"
Endif
L += 2
Call INFOADX(FICHIER,PROPRIO,TAILLE,DATMOD,HREMOD,OK) From SUBADC
If OK<0
 INFOS(L) = mess(158,139,1) : # Traitement inexistant dans l'archive
Else
 INFOS(L) = mess(159,139,1)
 Append INFOS(L), " "
 Append INFOS(L), nomap(OK)
Endif
If TAILLE>=0
 L += 1
 INFOS(L) = num$(TAILLE)
 Append INFOS(L), " "
 Append INFOS(L), mess(133,133,1)

 If NBUSER
  Gosub USER From SUBADC
  Append INFOS(L), ", "
  Append INFOS(L), mess(134,133,1)
  Append INFOS(L), " "
  Append INFOS(L), IDUSR
 Endif
 Append INFOS(L), ", "
 Append INFOS(L), mess(162,124,1)
 Append INFOS(L), " "
 Append INFOS(L), format$("D:"+GFMDAT4,DATMOD)
 Append INFOS(L), " "
 Append INFOS(L), HREMOD
 Append INFOS(L), " GMT"

Endif
L += 2
Call VERSACH(nomap,INFOS(L)) From SUBADC
INFOS(L) = mess(199,115,1)
Append INFOS(L), " -> "
Append INFOS(L), INFOS(L)
End

#**
#* Gets modules
#*!
Funprog GETMODULES()

Local Clbfile MODULES(9)

Local Clbfile LABEL(0)
Local Integer INDEX
Local Integer NB
Local Integer CHAPTER : CHAPTER = 14

MODULES = ""

 NB = len(mess(0, CHAPTER, 1))
For INDEX=1 To NB
    LABEL = func GETLOCALMENU(num$(CHAPTER), num$(INDEX), "1")
    Append MODULES, num$(INDEX)
    Append MODULES, GXDT_VALUE_SEP
    Append MODULES, LABEL
    Append MODULES, GXDT_NL_SEP
Next INDEX

End MODULES

#**
#* Set file properties (with additional TEXT parameter) in ADICTRT
#*
#* @param NOMFIC
#* @param RECORD
#* @param TEXT
#*!
Funprog SET_FILE_PROPERTIES(NOMFIC, RECORD, TEXT)
Value Char NOMFIC()
Value Char RECORD()
Value Clbfile TEXT()

Local Char RETOUR(250)

Local Char WDES(250)
Local Integer WMODULE
Local Char WCODACT(250)
Local Integer WSRC
Local Integer WSRCINT

Local Integer NBMOT
Local Integer NBMOTMAX : NBMOTMAX = 30
Local Char    TABSPLIT(255)(NBMOTMAX+1) :

Local Char SYMBOLE

If clalev([F:ADC])=0 : Local File ADICTRT [ADC] : Endif

SYMBOLE="ADC"+NOMFIC
Lock =SYMBOLE With lockwait=0
If [S]fstat = 1     # locked record
    RETOUR = "0" + GXDT_NL_SEP + NOMFIC + " : " + mess(60,100,1)
Else
  Trbegin [ADC]
  Readlock [F:ADC]ADC0 = NOMFIC
  If [S]fstat <> 1

    NBMOT = func SPLIT(RECORD, GXDT_VALUE_SEP, TABSPLIT)

    WDES = TABSPLIT(0)
    WMODULE = val(TABSPLIT(1))
    WCODACT = TABSPLIT(2)
    WSRC = val(TABSPLIT(3))
    WSRCINT = val(TABSPLIT(4))
    If TEXT = ""
      Setlob TEXT With TABSPLIT(5)
    Endif

    [F:ADC]DES = WDES
    [F:ADC]MODULE = WMODULE
    [F:ADC]CODACT = WCODACT
    [F:ADC]SRC = WSRC
    [F:ADC]SRCINT = WSRCINT

    If [S]fstat=0
      Rewrite [F:ADC]
    Else
      [F:ADC]CODTRT = NOMFIC
      Write [F:ADC]
    Endif
    Call SETTEXT("TRT", NOMFIC, TEXT, WDES, WMODULE, WCODACT)

    Commit
    Unlock =SYMBOLE
    RETOUR = "1"
  Else      # locked record
    Rollback
    RETOUR = "0" + GXDT_NL_SEP + NOMFIC + " : " + mess(60,100,1)
  Endif
Endif

Close Local File [F:ADC]

End RETOUR


#fonction deja presente dans ARECHMEN (voir pour la centraliser quelque-part)
#**
#* Splits a string with a given separator
#*
#* @param CHAINE
#* @param SEPARATEUR
#* @param RETOUR
#*!
Funprog SPLIT(CHAINE,SEPARATEUR,RETOUR)
Value Char CHAINE()
Value Char SEPARATEUR()
Variable Char RETOUR()()

Local Clbfile CHAINE_LOB(1)
CHAINE_LOB = CHAINE

Local Integer NBMOT
NBMOT = func SPLIT_LOB(CHAINE_LOB, SEPARATEUR, RETOUR)
End NBMOT

#**
#* Splits a clbfile with a given separator
#*
#* @param CHAINE
#* @param SEPARATEUR
#* @param RETOUR
#*!
Funprog SPLIT_LOB(CHAINE,SEPARATEUR,RETOUR)
Value Clbfile CHAINE()
Value Char SEPARATEUR()
Variable Char RETOUR()() #tableau de chaines de caracteres ou sont renvoyees les chaines decoupees

Local Integer DEBUT , FIN , FINBOUCLE , NBMOT

DEBUT=1 #debut du mot
FIN=1 #fin du mot
FINBOUCLE=0 #sortie de boucle
NBMOT=0 #nombre de mot

#parcourt de la chaine
Repeat
 #recherche d'un mot
 FIN=instr(DEBUT,CHAINE,SEPARATEUR)
 If FIN=0
  FINBOUCLE=1
  FIN=len(CHAINE)+1
 Endif
 RETOUR(NBMOT)=seg$(CHAINE,DEBUT,FIN-1) #ajout du mot au retour
 DEBUT=FIN+len(SEPARATEUR)
 NBMOT+=1
Until FINBOUCLE | NBMOT=dim(RETOUR)
End NBMOT

