#**
#* Return mask code (search if mask code is an abbreviation code)
#*
#* @since 05/01/2010
#* @param MASKCODE searched code
#*!=================================================================
Funprog GETMASKCODE(MASKCODE)
Value Char    MASKCODE()
Local Char    REALMASKCODE(255)

REALMASKCODE= ""
If clalev([F:MSK])=0 : Local File AMSK [MSK] : Endif
# Take first MASKCODE as a mask code...
Read [F:MSK]CODMSK=MASKCODE
If fstat = 0
  REALMASKCODE= MASKCODE
Else
  # ...if not found, take it as a mask abbreviation (the first one)
  Filter [F:MSK] Where [F:MSK]ABRMSK = MASKCODE Order By [F:MSK]CODMSK Asc
  Read [F:MSK] First
  If fstat = 0
    REALMASKCODE= [F:MSK]CODMSK
  Endif
  Filter [F:MSK]
Endif
Close Local File [MSK]
End REALMASKCODE

#**
#* Return mask fields
#* @param MASKCODE the mask code
#*!
Funprog GETMASKFIELDS(MASKCODE)
Value Char    MASKCODE()

Local Clbfile FIELDS(6)
Local Char    LIBFIELDS(255)
Local Char    LIBTYPE(255)
Local Char    LIBACTIVITE(255)
Local Integer LGNFIELD(5)

Local Char    TYPTYP(255)
Local Char    FORTYP(255)
Local Char    OPTION(255)

If clalev([F:AMK])=0 : Local File AMSKZON [AMK] : Endif

FIELDS = ""
LIBFIELDS = ""

MASKCODE = func GETMASKCODE(MASKCODE)

Filter [F:AMK] Where [F:AMK]CODMSK = MASKCODE Order By [F:AMK]CODZON Asc
For [F:AMK]

    If [F:AMK]INTIT = 0
      If [F:AMK]INTEVAL <> ""
        LIBFIELDS = "$" - " (" + [F:AMK]INTEVAL + ")"
      Else
      LIBFIELDS = ""
      Endif
    Else
      Call TEXTE([F:AMK]INTIT, LIBFIELDS) From OBJDIV
    Endif

    LGNFIELD = [F:AMK]LONG

    # Lecture du Libelle Type
    Call GETLIBELTYPE([F:AMK]CODTYP, LIBTYPE, LGNFIELD, TYPTYP, FORTYP, OPTION)

    # Lecture du Libelle activite
    LIBACTIVITE = func  GETLIBACTIVITE([F:AMK]CODACT)

    Append FIELDS, [F:AMK]CODZON
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, LIBFIELDS
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, [F:AMK]CODTYP
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, LIBTYPE
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, num$(LGNFIELD)
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, [F:AMK]CODACT
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, LIBACTIVITE
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, num$([F:AMK]NOLIB)
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, num$([F:AMK]DIME)
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, TYPTYP
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, FORTYP
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, OPTION
    Append FIELDS, GXDT_NL_SEP

Next
Filter [F:AMK]
Close Local File [AMK]

End FIELDS

#**
#* Return global vars list (only codes)
#*
#* @since 1.0.1 - 22/01/2010
#*
#*!
Funprog GETGVARLIST()
  Local Clbfile VARS(9)

  If clalev([F:AGB])=0 : Local File AGLOBVAR [AGB] : Endif
  VARS = ""
  For [F:AGB]AGB0
      Append VARS, [F:AGB]CODVAR
      Append VARS, GXDT_NL_SEP
  Next
  Close Local File [AGB]
End VARS

#**
#* Return global var info of a global var
#*
#* @param CODE the global var code
#*
#* @since 1.0.1 - 22/01/2010
#*!
Funprog GETGVARINFO(CODE)
Value Char CODE()

Local Clbfile VARS(9)

Local Char    LIBFIELDS(255)
Local Char    LIBTYPE(255)
Local Char    LIBACTIVITE(255)
Local Char    LOCALMENU(10)
Local Integer LGNFIELD(5)

Local Char    TYPTYP(255)
Local Char    FORTYP(255)
Local Char    OPTION(255)

If clalev([F:FIC])=0 : Local File AGLOBVAR [FIC] : Endif

VARS = ""
LIBFIELDS = ""

Read [F:FIC]AGB0=CODE
If fstat = 0
    Call TEXTE([F:FIC]INTIT, LIBFIELDS ) From OBJDIV

    LGNFIELD = 0
    If len([F:FIC]LNGTYP) > 0
        LGNFIELD = val([F:FIC]LNGTYP)
    Endif

    # Lecture du Libelle Type
    Call GETLIBELTYPE([F:FIC]CODTYP, LIBTYPE, LGNFIELD, TYPTYP, FORTYP, OPTION)

    # Lecture du Libelle activite
    LIBACTIVITE = func GETLIBACTIVITE([F:FIC]CODACT)

    # Lecture du menu local
    LOCALMENU = func FINDLOCALMENU([F:FIC]PARAM)

    Append VARS, [F:FIC]CODVAR
    Append VARS, GXDT_VALUE_SEP
    Append VARS, LIBFIELDS
    Append VARS, GXDT_VALUE_SEP
    Append VARS, [F:FIC]CODTYP
    Append VARS, GXDT_VALUE_SEP
    Append VARS, LIBTYPE
    Append VARS, GXDT_VALUE_SEP
    Append VARS, num$(LGNFIELD)
    Append VARS, GXDT_VALUE_SEP
    Append VARS, [F:FIC]CODACT
    Append VARS, GXDT_VALUE_SEP
    Append VARS, LIBACTIVITE
    Append VARS, GXDT_VALUE_SEP
    Append VARS, TYPTYP
    Append VARS, GXDT_VALUE_SEP
    Append VARS, FORTYP
    Append VARS, GXDT_VALUE_SEP
    Append VARS, OPTION
    Append VARS, GXDT_VALUE_SEP
    Append VARS, LOCALMENU
    Append VARS, GXDT_NL_SEP # 20110111 : issue 70517

Endif

Close Local File [FIC]

End VARS

#**
#* Return counters
#*!
Funprog GETCOUNTERS()

Local Clbfile VARS(9)

Local Char    LIBCOUNTER(255)
Local Char    CODCOUNTER(255)
Local Char    RAZ_LEVEL(255)
Local Char    DEF_LEVEL(255)
Local Char    COUNTER_TYPE(255)


#If clalev([F:FIC])=0 : Local File ACODNUM [FIC] : Endif
If clalev([F:FIC])=0 : Local File APLCOM [FIC] : Endif

VARS = ""

For [F:FIC]

    RAZ_LEVEL = num$([F:FIC]COMIND)
    DEF_LEVEL = num$([F:FIC]COMFLD)
    COUNTER_TYPE = mess(func GETCOUNTERSTYPE([F:FIC]COMTYP), 30, 1)

     #LIBCOUNTER = [F:FIC]COMNOM - "(" + num$([F:FIC]COMIND) + ")"
     LIBCOUNTER = ""
     CODCOUNTER = [F:FIC]COMNOM

     If [F:FIC]COMIND > 0
        Append CODCOUNTER, "("
        Append CODCOUNTER, num$([F:FIC]COMIND)
        Append CODCOUNTER, ")"
     Endif

    Append VARS, CODCOUNTER
    Append VARS, GXDT_VALUE_SEP
    Append VARS, LIBCOUNTER
    Append VARS, GXDT_VALUE_SEP
    Append VARS, COUNTER_TYPE
    Append VARS, GXDT_VALUE_SEP
    Append VARS, num$([F:FIC]COMLEN)
    Append VARS, GXDT_VALUE_SEP
    Append VARS, RAZ_LEVEL
    Append VARS, GXDT_VALUE_SEP
    Append VARS, DEF_LEVEL
    Append VARS, GXDT_NL_SEP

Next

Close Local File [FIC]

End VARS

#**
# Return the real counter type, the one to use with mess(x,30,1)
# @param COUNTERTYPE counter type number stored in table
#*!
Funprog GETCOUNTERSTYPE(COUNTERTYPE)
Value Integer COUNTERTYPE
Local Integer MESSCOUNTERTYPE
MESSCOUNTERTYPE = COUNTERTYPE - 299
End MESSCOUNTERTYPE

#**
#* Return type label
#*
#* @param CODE
#* @param NAME
#* @param LGN
#* @param TYPTYP
#* @param FORTYP
#* @param OPTION
#*!
Subprog GETLIBELTYPE(CODE,  NAME , LGN, TYPTYP, FORTYP, OPTION)
Value Char CODE()
Variable Char NAME()
Variable Integer LGN()
Variable Char TYPTYP()
Variable Char FORTYP()
Variable Char OPTION()

Local Char    NAME(255)
Local Clbfile LABEL(0)

NAME = ""
TYPTYP = ""
FORTYP = ""
OPTION = ""

If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif

Read [ATY]CODTYP=CODE
If fstat=0
    Call TEXTE([F:ATY]INTITTYP, NAME) From OBJDIV

    If LGN  = 0
        LGN =[F:ATY]LNGTYP
    Endif

    If [F:ATY]TYPTYP >= 0
        LABEL = func GETLOCALMENU( "30", num$([F:ATY]TYPTYP), "1")
        TYPTYP = LABEL
    Endif
    FORTYP = [F:ATY]FORTYP
    OPTION = [F:ATY]OPTION

Endif
Close Local File [ATY]

End


#**
#* Return activity label
#*
#* @param CODE the activity code
#*!
Funprog GETLIBACTIVITE(CODE)
Value Char CODE()

Local Char NAME(255)

NAME = ""

If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif

Read [ACV]CODACT=CODE
If fstat=0
    Call TEXTE([F:ACV]LIBACT, NAME ) From OBJDIV
Endif
Close Local File [ACV]

End NAME

#**
#* Return local menu number of a global variable (if significant)
#*
#* @param PARAM the global variable parameter code
#*!
Funprog FINDLOCALMENU(PARAM)
Value Char PARAM
Local Char LOCALMENU(10) : [L]LOCALMENU = "0"
If clalev([F:ADP])=0 : Local File ADOPAR [ADP] : Endif
VALEUR = ""
Read [ADP]ADP1=PARAM
If fstat < 2
  LOCALMENU = num$([F:ADP]NOLIB)
Endif
Close Local File [ADP]
End LOCALMENU

