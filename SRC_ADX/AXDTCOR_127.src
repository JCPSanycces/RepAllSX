#**
#* Return field table name
#* @param TABLECODE the table code
#* @param FIELDCODE the field code
#*!
Funprog GETFIELDNAME(TABLECODE, FIELDCODE)
Value Char    TABLECODE()
Value Char    FIELDCODE()
#Value Char    LAN()
Local Char    NAME(255)
Local Integer LGNFIELDS(5)

If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif

NAME = ""

Read [ATZ]CODZONE=TABLECODE;FIELDCODE
If fstat=0
    #Call TEXTELAN([F:ATZ]NOLONG, NAME, LAN) From OBJDIV
    Call TEXTE([F:ATZ]NOLONG, NAME) From OBJDIV
Endif

Close Local File [ATZ]

End NAME

#**
#* Return table code (search if table code is an abbreviation code)
#*
#* @param TABLECODE the table or abbreviation code
#*!=================================================================
Funprog GETTABLECODE(TABLECODE)
Value Char    TABLECODE()
Local Char    REALTABLECODE(255)

REALTABLECODE = ""
If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
# Take first TABLECODE as a table code...
Read [F:ATB]CODFIC=TABLECODE
If fstat = 0
  REALTABLECODE = TABLECODE
Else
  # ...if not found, take it as a table abbreviation
  Read [F:ATB]ABRFIC=TABLECODE
  If fstat = 0
    REALTABLECODE = [F:ATB]CODFIC
  Endif
Endif
Close Local File [ATB]
End REALTABLECODE

#**
#* Return view code (search if view code is an abbreviation code)
#*
#* @param OBJECTCODE the view or abbreviation code
#*!=================================================================
Funprog GETVIEWCODE(OBJECTCODE)
Value Char    OBJECTCODE()
Local Char    REALOBJECTCODE(255)

REALOBJECTCODE = ""
If clalev([F:AVW])=0 : Local File AVIEW [AVW] : Endif
# Take first OBJECTCODE as a view code...
Read [F:AVW]AVW0=OBJECTCODE
If fstat = 0
  REALOBJECTCODE = OBJECTCODE
Else
  # ...if not found, take it as an abbreviation
  Read [F:AVW]AVW1=OBJECTCODE
  If fstat = 0
    REALOBJECTCODE = [F:AVW]CODVUE
  Endif
Endif
Close Local File [AVW]
End REALOBJECTCODE

#Funprog GETTABLEFIELDS(TABLECODE, LAN)
#**
#* Return table fields
#* @param TABLECODE the table code
#*!=================================================================
Funprog GETTABLEFIELDS(TABLECODE)
Value Char    TABLECODE()
#Value Char    LAN()
Local Clbfile FIELDS(6)
Local Char    LIBFIELDS(255)
Local Char    LIBTYPE(255)
Local Char    LIBACTIVITE(255)
Local Integer LGNFIELD(5)

Local Char    TYPTYP(255)
Local Char    FORTYP(255)
Local Char    OPTION(255)

If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif

FIELDS = ""
NAME = ""

TABLECODE = func GETTABLECODE(TABLECODE)

Filter [F:ATZ] Where [F:ATZ]CODFIC = TABLECODE Order By [F:ATZ]CODZONE Asc
For [F:ATZ]
    Call TEXTE([F:ATZ]NOLONG, LIBFIELDS) From OBJDIV
    LGNFIELD = [F:ATZ]LONG

    # Lecture du Libelle Type
    Call GETLIBELTYPE([F:ATZ]CODTYP, LIBTYPE, LGNFIELD, TYPTYP, FORTYP, OPTION)

    # Lecture du Libelle activite
    LIBACTIVITE = func GETLIBACTIVITE([F:ATZ]CODACT)
    Append FIELDS, [F:ATZ]CODZONE
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, LIBFIELDS
    Append FIELDS, GXDT_VALUE_SEP

    Append FIELDS, [F:ATZ]CODTYP
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, LIBTYPE
    Append FIELDS, GXDT_VALUE_SEP

    Append FIELDS, num$(LGNFIELD)
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, [F:ATZ]CODACT
    Append FIELDS, GXDT_VALUE_SEP

    Append FIELDS, LIBACTIVITE
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, num$([F:ATZ]NOLIB)
    Append FIELDS, GXDT_VALUE_SEP

    Append FIELDS, num$([F:ATZ]DIME)
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, TYPTYP
    Append FIELDS, GXDT_VALUE_SEP

    Append FIELDS, FORTYP
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, OPTION
    Append FIELDS, GXDT_NL_SEP
Next
Filter [F:ATZ]
Close Local File [ATZ]

End FIELDS

#**
#* Return table index
#* @param TABLECODE the table code
#*!=================================================================
Funprog GETTABLEINDEX(TABLECODE)
Value Char    TABLECODE()
Local Clbfile INDEX(6)
Local Char    NAME(255)

TABLECODE = func GETTABLECODE(TABLECODE)

If clalev([F:AIX])=0 : Local File ATABIND [AIX] : Endif

INDEX = ""
NAME = ""

Filter [F:AIX] Where [F:AIX]CODFIC = TABLECODE Order By [F:AIX]CODIND Asc
For [F:AIX]
    Append INDEX, [F:AIX]CODIND
    Append INDEX, GXDT_VALUE_SEP
    Append INDEX, [F:AIX]DESCRIPT
    Append INDEX, GXDT_NL_SEP
Next
Filter [F:AIX]
Close Local File [AIX]

End INDEX

#**
#* Return view fields
#* @param VIEWCODE the view code
#*!=================================================================
Funprog GETVIEWFIELDS(VIEWCODE)
Value Char    VIEWCODE()
#Value Char    LAN()
Local Clbfile FIELDS(6)
Local Char    LIBFIELDS(255)
Local Char    LIBTYPE(255)
Local Char    LIBACTIVITE(255)
Local Integer LGNFIELD(5)

Local Char    TYPTYP(255)
Local Char    FORTYP(255)
Local Char    OPTION(255)

If clalev([F:AVD])=0 : Local File AVIEWD [AVD] : Endif

FIELDS = ""
NAME = ""

VIEWCODE = func GETVIEWCODE(VIEWCODE)

Filter [F:AVD] Where [F:AVD]CODVUE = VIEWCODE Order By [F:AVD]FLDVUE Asc
For [F:AVD]
    Call TEXTE([F:AVD]FLDINT, LIBFIELDS) From OBJDIV
    LGNFIELD = [F:AVD]LNG

    # Lecture du Libelle Type
    Call GETLIBELTYPE([F:AVD]CODTYP, LIBTYPE, LGNFIELD, TYPTYP, FORTYP, OPTION)

    # Lecture du Libelle activite
    LIBACTIVITE = func GETLIBACTIVITE([F:AVD]FLDACT)
    Append FIELDS, [F:AVD]FLDVUE
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, LIBFIELDS
    Append FIELDS, GXDT_VALUE_SEP

    Append FIELDS, [F:AVD]CODTYP
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, LIBTYPE
    Append FIELDS, GXDT_VALUE_SEP

    Append FIELDS, num$(LGNFIELD)
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, [F:AVD]FLDACT
    Append FIELDS, GXDT_VALUE_SEP

    Append FIELDS, LIBACTIVITE
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, num$([F:AVD]NOLIB)
    Append FIELDS, GXDT_VALUE_SEP

    Append FIELDS, num$([F:AVD]DIME)
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, TYPTYP
    Append FIELDS, GXDT_VALUE_SEP

    Append FIELDS, FORTYP
    Append FIELDS, GXDT_VALUE_SEP
    Append FIELDS, OPTION
    Append FIELDS, GXDT_NL_SEP
Next
Filter [F:AVD]
Close Local File [AVD]

End FIELDS

