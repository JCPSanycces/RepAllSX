#LIPET - X3-57954 - 2017-09-29 - START
#LIPET - X3-39524 - 2017-09-21 - START
#If func AFNC.ACTIV("GLM")
If func AFNC.ACTIV("GLM") & !func DIVPAYE.IS_KUK_LEG(GCURLEG) Then
#LIPET - X3-57954 - 2017-09-29 - END
  If [M:HRTIM0]LVEENHANCE = 2 Then
    Local Integer FOUND : FOUND = 0
    For nolign=1 To dim([M:HRTIM4]LVESUBTYP)
      If [M:HRTIM4]LVESUBTYP(nolign-1) <> "" Then
##PEVAN - 2017-10-06 - X3-58886 - START
#        Filter [F:HRACCR1] Where [F:HRACCR1]LVEACCLST = [M:HRTIM4]LVESUBTYP(nolign-1)
        Filter [F:HRACCR1] Where [F:HRACCR1]LVEACCLST = [M:HRTIM4]LVESUBTYP(nolign-1) and [F:HRACCR1]LVEACCTYP <> "Linking"
##PEVAN - 2017-10-06 - X3-58886 - END
        Read [F:HRACCR1] First
        Filter [F:HRACCR1]
          If fstat = 0 Then
            FOUND += 1
          Endif
      Endif
    Next

    If FOUND <> 0 : Goto CL :Endif
    If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
    If clalev([F:FCY1])=0  : Local File FACILITY [FCY1]  : Endif
    If clalev([F:DCG3])=0  : Local File DEMCONGE [DCG3]  : Endif

    Link [F:DCG3] With
&   [HRCTR3]CTR0(2)=[DCG3]REFNUM;[DCG3]CTRNUM,
&   [FCY1]FCY0=[F:HRCTR3]ETRFCY
&    As [LNK] Where [DCG3]TIM = COD and [FCY1]LEG = GCURLEG

    If rowcount([LNK])> 0 Then
      FOUND = 1
    Endif
    Filter [F:HRCTR3]
    Filter [F:FCY1]
    Filter [F:DCG3]
    : CL
    If FOUND > 0
        Grizo [M:HRTIM0]LVEENHANCE
##PEVAN - 2017-10-02 - X3-57954 - START
#        Grizo [M:HRTIM4]5
##PEVAN - 2017-10-02 - X3-57954 - END
      Else
        Actzo [M:HRTIM0]LVEENHANCE
        Actzo [M:HRTIM4]5
    Endif

  Elsif [M:HRTIM0]LVEENHANCE = 1 Then
    Actzo [M:HRTIM0]LVEENHANCE
    Actzo [M:HRTIM4]5
  Endif
  Affzo [M:HRTIM4]
Endif
#LIPET - X3-39524 - 2017-09-21 - END

