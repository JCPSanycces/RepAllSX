Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
#Filter [FCY] Where FCY=VALEUR & LEG=GCURLEG | FCY = VALEUR & GCURLEG = ""
Filter [FCY] Where FCY=VALEUR & LEG=GCURLEG
Look [FCY] First
Filter [FCY]
If fstat
#ADNGO - 2016-11-28 - START
  If VALEUR <> ""
#ADNGO - 2016-11-28 - END
    mkstat=2
    GMESSAGE=VALEUR-mess(171,187,1)-'"'+GCURLEG-'"'
  Endif
Endif
End
