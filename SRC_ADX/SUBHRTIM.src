######################################################################################
## Section automatically added (screen HRTIM4) 04/04/2017 12:19:02 (SAVAN)
######################################################################################
Subprog C_LVESUBTYP(VALEUR)
Variable Char    VALEUR()
Local Integer ROW
Local Integer COUNTER
Local Integer S

    If func AFNC.ACTIV("GLM")
    #LIPET - 2017-08-16 - X3-52939 - START
    Filter [F:TIM] Where ([TIM]LVEENHANCE=2 & ([TIM]CATTIM=3 |[F:TIM]CATTIM=2))  and [TIM]ENAFLG=2
    For [TIM]
      For S=1 To dim([TIM]LVESUBTYP)
        If [TIM]LVESUBTYP(S-1) <> "" and [TIM]LVESUBTYP(S-1) = VALEUR and [TIM]COD <> [M]COD and [TIM]LEG = GCURLEG
          GERR=1:GMESSAGE="This leave sub type has been linked to"-[TIM]COD : mkstat=2 : End
        Endif
      Next
    Next
    Filter [F:TIM]
    #LIPET - 2017-08-16 - X3-52939 - END
    For COUNTER=1 To dim([M:HRTIM4]LVESUBTYP)
    If VALEUR <> ""
        ROW += 1
    Endif
    Next

    If VALEUR <> ""
      If [M:HRTIM4]LVESUBTYP(nolign-1) <> VALEUR
        Call UNICITE(VALEUR,[M:HRTIM4]LVESUBTYP(0..ROW-1)) From OBJDIV
        If mkstat=2 : End : Endif
      Endif
    Else
      GMESSAGE = mess(259,10702,1)
      mkstat=2 : End
    Endif
  Endif
End


