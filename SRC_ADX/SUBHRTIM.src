#                  Endcase
#                Endif
#              Next
#
#            If [HRLSTD]LEV=3
#              Link [HRCTR] With
#&             [ID]ID0=[F:HRCTR]REFNUM,
#&             [FCY]FCY0=[F:HRCTR]ETRFCY,
#&             [CPY]CPY0=[F:FCY]LEGCPY,
#&             [SRV]SRV0=[F:HRCTR]ETRSRV,
#&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
#&             [PRF]PRF0=[F:HRCTR]PROPRF,
#&             [HRPOA]POA0=[F:HRLSTD]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
#&             As [LNK]
#&             Where evalue(CRITACC1) or evalue(CRITACC2)
#            Else
#              Link [HRCTR] With
#&             [ID]ID0=[F:HRCTR]REFNUM,
#&             [FCY]FCY0=[F:HRCTR]ETRFCY,
#&             [CPY]CPY0=[F:FCY]LEGCPY,
#&             [SRV]SRV0=[F:HRCTR]ETRSRV,
#&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
#&             [PRF]PRF0=[F:HRCTR]PROPRF
#&             As [LNK]
#&             Where evalue(CRITACC1) or evalue(CRITACC2)
#            Endif
#
#            Filter [LNK] Where CTRNUM=[M]CTRNUM(nolign-1) and [F:HRCTR]CTRDAT = [M]CTRDAT(nolign-1)
#
#              #If rowcount([LNK])>0 & !find([TIM]LVESUBTYP(S-1),LIS_HRLST(0..100)) : LIS_HRLST(L) = [TIM]LVESUBTYP(S-1) : L+=1 : Endif
#              If rowcount([LNK])>0 & !find([TIM]COD,LIS_TPS(0..100))
#                LIS_TPS(L) = [TIM]COD
#                L+=1
#              Endif
#              Filter [LNK]
#            Endif
#          Next
#        Next
#        Filter [TIM]
#FRLAA X3-86842 2018-05-15 - END
        If LIS_TPS(0)<>""
          [L]CRITERE(1) = "find(COD,LIS_TPS)>0"
        Else
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:TIM]LEG="'+GCURLEG+'" | [F:TIM]LEG="")&[F:TIM]LVEENHANCE=1',"&") From GOBJSUB
        Endif
        Elsif GFONCTION = "GESVRA"
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:TIM]LEG="'+GCURLEG+'" | [F:TIM]LEG="")',"&") From GOBJSUB
    #ADNGO - 2017-08-15 - X3-32858 - END
        Else
    #Filter based on code legislation
      #ADNGO - 2017-08-15 - X3-32858 - START
      #Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:TIM]LEG="'+GCURLEG+'" | [F:TIM]LEG="")',"&") From GOBJSUB
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:TIM]LEG="'+GCURLEG+'" | [F:TIM]LEG="")&[F:TIM]LVEENHANCE=1',"&") From GOBJSUB
      #ADNGO - 2017-08-15 - X3-32858 - END
      Endif
    #ADNGO - 2017-08-03 - X3-32847 - END
    Endif
  Endcase
  Elsif func AFNC.ACTIV("HRESS")
  Case TABLE
  When "SELHRTIM"
    If clalev ([F:TIM])=0 : Local File TIMCOD [TIM] : Endif
    Filter [F:TIM]
    OBJET="HRTIM"
      If GFONCTION = "ESSDCG"
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:TIM]LEG="'+GCURLEG+'" | [F:TIM]LEG="")&[F:TIM]AUZPRH = 2',"&") From GOBJSUB
      Elsif GFONCTION = "GESVRA"
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:TIM]LEG="'+GCURLEG+'" | [F:TIM]LEG="")',"&") From GOBJSUB
      Else
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:TIM]LEG="'+GCURLEG+'" | [F:TIM]LEG="")&[F:TIM]LVEENHANCE=1',"&") From GOBJSUB
     Endif
     Endcase
Else
  Case TABLE
  When "SELHRTIM"
    If clalev ([F:TIM])=0 : Local File TIMCOD [TIM] : Endif
    Filter [F:TIM]
    OBJET="HRTIM"
###    START="[F:TIM]COD"
  #Filter based on code legislation
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:TIM]LEG="'+GCURLEG+'" | [F:TIM]LEG="")',"&") From GOBJSUB
  Endcase
Endif
Return

#JOJAC - 2016-11-01 - START
########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
  Call SUPTEXTRA("TIMCOD","DES",[L]CODE,SUPP) From ATEXTRA
  Call SUPTEXTRA("TIMCOD","SHO",[L]CODE,SUPP) From ATEXTRA

Return
#JOJAC - 2016-11-01 - END


Subprog CONTHRTIM(COD)
Variable Char    COD()

  If GFONCTION = "GESHRTIM" | COD="" : End : Endif

  If clalev([F:TIM])=0 : Local File TIMCOD [TIM] : Endif

#  If COD <> ""
#    #ADNGO - 2016-11-28 - START
#    Filter [F:TIM] Where COD=[L]COD
#    Read [F:TIM] First
#    #Read [F:TIM]TIM0 = COD
#    #Read [F:TIM]TIM0 = GCURLEG;COD
#    #ADNGO - 2016-11-28 - END
#    Filter [F:TIM]
#    If fstat
#        GMESSAGE = COD-":"-mess(23,100,1)
#        mkstat = 2 : End
#    Endif
#  Endif
# Filter [F:TIM]

#MIPEA 2017-09-15 START
#  If [L]COD <> ""
#    Filter [F:TIM] Where COD=[L]COD
#    Read [F:TIM] First
#    Filter [F:TIM]
#    If fstat
#        GMESSAGE = [L]COD-":"-mess(23,100,1)
#        mkstat = 2 : End
#    Else
#        Read [F:TIM]TIM0 = GCURLEG;[L]COD
#        If fstat
#          Filter [F:TIM] Where COD=[L]COD
#          Read [F:TIM] First
#          Filter [F:TIM]
#          GMESSAGE = [L]COD-":"-mess(62,127,1)-":"-[F:TIM]LEG
#          mkstat = 2 : End
#        Endif
#    Endif
#  Endif

  If [L]COD <> ""
   #If !func AFNC.ACTIV("GLM")| func AFNC.ACTIV("GLM")
      Filter [F:TIM] Where COD=[L]COD
      Read [F:TIM] First
      Filter [F:TIM]
      If fstat
          GMESSAGE = [L]COD-":"-mess(23,100,1)
          mkstat = 2 : End
       Else
            Read [F:TIM]TIM0 = GCURLEG;[L]COD
            If fstat
              Filter [F:TIM] Where COD=[L]COD
              Read [F:TIM] First
              Filter [F:TIM]
              GMESSAGE = [L]COD-":"-mess(62,127,1)-":"-[F:TIM]LEG
              mkstat = 2 : End
            Endif
         Endif
     #Elsif func AFNC.ACTIV("GLM")
     If func AFNC.ACTIV("GLM")
          #ADNGO - 2017-08-03 - X3-32847 - START
          If GFONCTION = "GESHRLSE" Then
            Filter [F:TIM] Where (COD=[L]COD & [F:TIM]LEG=GCURLEG & [F:TIM]LVEENHANCE=2)
            Read [F:TIM] First
            If fstat
              GMESSAGE = [L]COD-":"-mess(16,11691,1)
              mkstat = 2 : End
            Endif
            #ADNGO - 2017-08-03 - X3-32847 - END
            #ADNGO - 2017-08-16 - X3-32847 - START
            Elsif GFONCTION ="GESCNG" or GFONCTION="INITCP" or GFONCTION="GESCNE" or GFONCTION="CONSCCG" or GFONCTION="GESHRSUS"  Then
            Filter [F:TIM] Where (COD=[L]COD & [F:TIM]LEG=GCURLEG & [F:TIM]LVEENHANCE=2)
            Read [F:TIM] First
            If !fstat
              GMESSAGE = [L]COD-":"-mess(15,11691,1)
              mkstat = 2 : End
            Endif
            #ADNGO - 2017-08-16 - X3-32847 - END
            #ADNGO - 2017-08-18 - START
            Elsif GFONCTION="GESDCG" Then
                If clalev([HRLSTD]) = 0      : Local File HRLVESUBDET [HRLSTD] Endif
                If clalev([HRLSTH]) = 0      : Local File HRLVESUBHEA [HRLSTH] Endif
                If clalev([HRCTR]) = 0    : Local File EMPLOCTR [HRCTR] Endif
                If clalev ([ID]) = 0      : Local File EMPLOID [ID] Endif
                If clalev ([FCY]) = 0     : Local File FACILITY [FCY] Endif
                If clalev ([CPY]) = 0     : Local File COMPANY [CPY] Endif
                If clalev ([HRPOA]) = 0   : Local File POPULA [HRPOA] Endif
                If clalev ([HRCLV]) = 0   : Local File HRCLLCVT [HRCLV] Endif
                If clalev ([SRV]) = 0   : Local File SERVICE [SRV] Endif
                If clalev ([PRF]) = 0   : Local File PROFIL [PRF] Endif

                Local Integer S, L
                Local Char CRITACC1(250),CRITACC2(250),CRITACC3(250)
                Global Char LIS_TPS(GLONTPS)(0..100)
                Local Integer CRITCOUNT
                Filter [F:TIM] Where ([TIM]LVEENHANCE=2 & ([TIM]CATTIM=3 |[F:TIM]CATTIM=2))  and [TIM]ENAFLG=2
            #Looping 1. HRTIM 2. HRLST 3.HRCTR/HRMAT
                For [TIM]
                  For S=1 To dim([TIM]LVESUBTYP)
                      CRITACC1 = "1=0"
                      CRITACC2 = "1=0"
                      CRITACC3 = "1=0"
                    If [TIM]LVESUBTYP(S-1) <> ""
                      CRITCOUNT=1
                      For [HRLSTD] Where [HRLSTD]COD = [TIM]LVESUBTYP(S-1)
                        If len(CRITACC1)>=200 : CRITCOUNT=2 : If len(CRITACC2)>=200 : CRITCOUNT=3 : Endif : Endif
                        If CRITCOUNT=1
                          Case [HRLSTD]LEV
                            When 1  : CRITACC1 = CRITACC1 - " | 1=1"  #Folder
                            When 2  : CRITACC1 = CRITACC1 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                            When 3  : CRITACC1 = CRITACC1 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                            When 4  : CRITACC1 = CRITACC1 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                            When 5  : CRITACC1 = CRITACC1 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                            When 6  : CRITACC1 = CRITACC1 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                            When 7  : CRITACC1 = CRITACC1 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                            When 8  : CRITACC1 = CRITACC1 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                            When 9  : CRITACC1 = CRITACC1 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                            When 10 : CRITACC1 = CRITACC1 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
                          Endcase
                         Elsif CRITCOUNT=2
                           Case [HRLSTD]LEV
                            When 1  : CRITACC2 = CRITACC2 - " | 1=1"  #Folder
                            When 2  : CRITACC2 = CRITACC2 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                            When 3  : CRITACC2 = CRITACC2 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                            When 4  : CRITACC2 = CRITACC2 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                            When 5  : CRITACC2 = CRITACC2 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                            When 6  : CRITACC2 = CRITACC2 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                            When 7  : CRITACC2 = CRITACC2 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                            When 8  : CRITACC2 = CRITACC2 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                            When 9  : CRITACC2 = CRITACC2 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                            When 10 : CRITACC2 = CRITACC2 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
                          Endcase
                         Else
                           Case [HRLSTD]LEV
                            When 1  : CRITACC3 = CRITACC3 - " | 1=1"  #Folder
                            When 2  : CRITACC3 = CRITACC3 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                            When 3  : CRITACC3 = CRITACC3 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                            When 4  : CRITACC3 = CRITACC3 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                            When 5  : CRITACC3 = CRITACC3 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                            When 6  : CRITACC3 = CRITACC3 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                            When 7  : CRITACC3 = CRITACC3 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                            When 8  : CRITACC3 = CRITACC3 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                            When 9  : CRITACC3 = CRITACC3 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                            When 10 : CRITACC3 = CRITACC3 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
                          Endcase
                        Endif
                     Next

  If [HRLSTD]LEV=3
             Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF,
&             [HRPOA]POA0=[F:HRLSTD]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&          As [LNK]
&          Where evalue(CRITACC1) or evalue(CRITACC2) or evalue(CRITACC3)
  Else
             Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF
& As [LNK]
&          Where evalue(CRITACC1) or evalue(CRITACC2) or evalue(CRITACC3)
  Endif

            #Filter [LNK] Where CTRNUM=PARAM(1)
            Filter [LNK] Where CTRNUM=[M]CTRNUM(nolign-1)
      If rowcount([LNK])>0 & !find([TIM]COD,LIS_TPS(0..100)) : LIS_TPS(L) = [TIM]COD : L+=1 : Endif
            Filter [LNK]
                      Endif
                    Next
                  Next
            Filter [TIM]

      If LIS_TPS(0) <> ""
        If !find([L]COD,LIS_TPS(0..100)) : GERR=1 : GMESSAGE=mess(17,11691,1) : mkstat=2 : End : Endif
      Else
        Filter [TIM] Where [TIM]COD=[L]COD & ([TIM]LVEENHANCE<>2 & ([TIM]CATTIM=3 |[F:TIM]CATTIM=2))  and [TIM]ENAFLG=2 & LEG = GCURLEG
        If rowcount([TIM])=0 : GERR=1 : GMESSAGE=mess(17,11691,1) : mkstat=2 : End : Endif
        Filter [TIM]
      Endif
      #ADNGO - 2017-08-18 - END
      Endif
    Endif
  Endif
#MIPEA 2017-09-15 END

#ADNGO - 2017-02-08 - START
Filter [F:TIM]
#ADNGO - 2016-02-08 - END
End

Subprog TUNHRTIM(COD)
Variable Char    COD()

Local Integer TOKILL

  TOKILL = 0
  If dim(VCOD)<1
   Global Char VCOD(GLONTPS)
   TOKILL = 1
  Endif

  If clalev([F:TIM])=0 : Local File TIMCOD [TIM] : Endif

  VCOD = COD
  #ADNGO - 2017-04-12 - START
  #Read [TIM]TIM0 = GCURLEG;VCOD
  If VCOD="" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
  Filter [TIM] Where LEG=GCURLEG
  Read [F:TIM] First
  Filter [TIM]
  If !fstat : VCOD=[F:TIM]COD : Endif
  Else
   Read [TIM]TIM0 = GCURLEG;VCOD
  Endif
  #ADNGO - 2017-04-12 - END

   #ADNGO - 2017-04-12 - START
   #Call OBJET("HRTIM",GCURLEG,VCOD) From GOBJET
   Call OBJET("HRTIM",VCOD,GCURLEG) From GOBJET
   #ADNGO - 2017-04-12 - END
  COD = VCOD

  If TOKILL : Kill VCOD : Endif
End
#JASMI - 2016-10-31 - END

Subprog GRISE_PLNGRP(VALCAT)
Value Integer VALCAT
If VALCAT=1
 [M:HRTIM1]PLNGRP = len(mess(0,10418,1))
 Grizo [HRTIM1]PLNGRP
Else
 Actzo [HRTIM1]PLNGRP
Endif
Affzo [HRTIM1]PLNGRP
End

# 63813
Subprog GRISE_BLC(VALCAT)
Value Integer VALCAT
If func AFNC.ACTIV("GLM") Then
If VALCAT<>3 : # 3=Congés
 [M:HRTIM1]FLGBLC = 1
 [M:HRTIM1]BLCMIN = 0
 Grizo [HRTIM1]FLGBLC,BLCMIN
Else
 Actzo [HRTIM1]FLGBLC
 If [M:HRTIM1]FLGBLC=2
  Actzo [HRTIM1]BLCMIN
 Else
  Grizo [HRTIM1]BLCMIN
 Endif
Endif
Affzo [HRTIM1]FLGBLC,BLCMIN
Endif
End

Subprog AM_CATTIM(VALEUR)
Variable Integer VALEUR
#MIPEA 2017-09-15 START
If func AFNC.ACTIV("GLM")
#MIPEA 2017-09-15 END
  Local Integer SHOWHIDE
  If [M:HRTIM0]LVEENHANCE = 2 and VALEUR <> 1 and VALEUR <> 4
    SHOWHIDE = 1
  Else
    SHOWHIDE = 2
  Endif
  Call TOGGLE_LEAVESUBTYPE_TAB(SHOWHIDE)
  Call TOGGLE_NOTEREQ_BLOCK(SHOWHIDE)
#MIPEA 2017-09-15 START
Endif
#MIPEA 2017-09-15 END
  If GTPS
   Call GRISE_CATTIM (VALEUR)
  Endif
  Call GRISE_PLNGRP(VALEUR)
  #63813
  Call GRISE_BLC(VALEUR)
End

#Gestion des reports et demande de congés uniquement pour les evènements de catégorie <> "Travail"
#Gestion des plages horaire et des natures d'activité uniquement pour les evènements de catégorie = "Travail"
#########################################
Subprog GRISE_CATTIM (CATEG)
Value Libelle CATEG
If CATEG=1
 Effzo [M:HRTIM1]25 : Grizo [M:HRTIM1]25
 Actzo [M:HRTIM1]NATACT
 Actzo [M:HRTIM1]PLGHOR
Else
 Actzo [M:HRTIM1]25
 Effzo [M:HRTIM1]NATACT
 Effzo [M:HRTIM1]PLGHOR
 Grizo [M:HRTIM1]NATACT
 Grizo [M:HRTIM1]PLGHOR
Endif
End

######################################################################################
## Etiquettes écran HRTIM1
######################################################################################
Subprog AM_DAYDAC(VALEUR)
Variable Integer VALEUR
If [L]VALEUR=2
 Actzo [HRTIM1] VLTEVT
Else
 Effzo [HRTIM1] VLTEVT
 Grizo [HRTIM1] VLTEVT
 If func AFNC.ACTIV("PRH")   : # 62913 alimentation par défaut du code design portail
#ADNGO - X3PEOP-1226 - 2016-10-19 - START
#Filter [F:ADI] Where NUMTAB = 701
  Filter [F:ADI] Where NUMTAB = 10701
#ADNGO - X3PEOP-1226 - 2016-10-19 - END
  Read [F:ADI]CODE First
  [M:HRTIM3]DESIGN = [F:ADI]CODE
  Filter [F:ADI]
 Endif
Endif
If dim([M:HRTIM3]AUZPRH)>0 & dim([M:HRTIM1]CTLDAC)>0
#SEGAY 73376 27/07/11
# If [L]VALEUR=2 & [M:HRTIM1]CTLDAC<2 : Actzo [HRTIM3] : Else Effzo [HRTIM3] : Grizo [HRTIM3] : Endif
 If [L]VALEUR=2 & [M:HRTIM1]CTLDAC<2 Then
   Actzo [HRTIM3]
   If [M:HRTIM3]AUZPRH=0 Then
      [M:HRTIM3]AUZPRH=1
   Endif
   If [M:HRTIM3]AUZCAL=0 Then
      [M:HRTIM3]AUZCAL=1
   Endif
   If [M:HRTIM3]DSPSLD=0 Then
      [M:HRTIM3]DSPSLD=1
   Endif
   If [M:HRTIM3]JUSTIF=0 Then
      [M:HRTIM3]JUSTIF=1
   Endif
   If [M:HRTIM3]AUZCAL<>2 Then
     [HRTIM3]OVERWR=1
     Grizo [HRTIM3]OVERWR
   Endif
   Affzo[HRTIM3]
 Else
  Effzo [HRTIM3]
  Grizo [HRTIM3]
 Endif
#END 73376 27/07/11
Endif
End

Subprog AM_CTLDAC(VALEUR)
Variable Integer VALEUR
If dim([M:HRTIM3]AUZPRH)=1
#SEGAY 73376 27/07/11
# If [M:HRTIM1]DAYDAC=2 & [L]VALEUR<2 : Actzo [HRTIM3] : Else Effzo [HRTIM3] : Grizo [HRTIM3] : Endif
 If [M:HRTIM1]DAYDAC=2 & [L]VALEUR<2 Then
   Actzo [HRTIM3]
   If [M:HRTIM3]AUZPRH=0 Then
      [M:HRTIM3]AUZPRH=1
   Endif
   If [M:HRTIM3]AUZCAL=0 Then
      [M:HRTIM3]AUZCAL=1
   Endif
   If [M:HRTIM3]DSPSLD=0 Then
      [M:HRTIM3]DSPSLD=1
   Endif
   If [M:HRTIM3]JUSTIF=0 Then
      [M:HRTIM3]JUSTIF=1
   Endif

   If [M:HRTIM3]AUZCAL<>2 Then
     Grizo [HRTIM3]OVERWR
   Endif
   Affzo[HRTIM3]
 Else
  Effzo [HRTIM3]
  Grizo [HRTIM3]
 Endif
#END 73376 27/07/11
Endif
End

#63813
Subprog C_FLGBLC(VALEUR)
Variable Integer  VALEUR
If VALEUR=2
 Actzo [HRTIM1]BLCMIN
Else
 Raz [M:HRTIM1]BLCMIN
 Diszo [HRTIM1]BLCMIN
Endif
Affzo [HRTIM1]BLCMIN
End
######################################################################################
## Etiquettes écran HRTIM3
######################################################################################
#SEGAY 73376 27/07/11
Subprog AM_AUZCAL(VALEUR)
Variable Integer VALEUR
 If [M:HRTIM3]AUZCAL<>2 & [L]VALEUR=2 Then
  [M:HRTIM3]OVERWR=2
   Actzo [HRTIM3]OVERWR
   Affzo [HRTIM3]OVERWR
 Else
  [M:HRTIM3]OVERWR=1
  Affzo [HRTIM3]OVERWR
  Grizo [HRTIM3]OVERWR
 Endif
End


