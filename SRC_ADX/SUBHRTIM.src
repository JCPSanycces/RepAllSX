$APRES_CHOI
If REPONSE = GSTAANU
  If clalev([F:TIM]) = 0 : Local File TIMCOD [TIM] : Endif
  Local Integer L
  Filter [TIM] Where [TIM]COD = [HRTIM0]COD
  Read [TIM] First
  Filter [TIM]
  For L = 1 To dim([TIM]LVESUBTYP) - 1
    If [TIM]LVESUBTYP(L-1) <> ""
      GERR = 1
      GMESSAGE = mess(31,11691,1)
      REPONSE = 0
      Return
    Endif
  Next
Endif
Return

