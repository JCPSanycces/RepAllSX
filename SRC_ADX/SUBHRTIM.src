Subprog C_LVEENHANCE(VALEUR)
Variable Integer VALEUR
  Local Integer SHOWHIDE
If VALEUR = 2 and [M:HRTIM1]CATTIM<>1 and [M:HRTIM1]CATTIM<>4
  SHOWHIDE = 1
Else
  SHOWHIDE = 2
Endif
  Call TOGGLE_LEAVESUBTYPE_TAB(SHOWHIDE)
  Call TOGGLE_NOTEREQ_BLOCK(SHOWHIDE)
 #ADNGO - 2017-08-01 - X3-32650 - START
 If func AFNC.ACTIV("GLM")>0 and VALEUR = 2 Then
  If dim([M:HRTIM1]FLGBLC)>0 : Chgfmt [M:HRTIM1]FLGBLC With '-LA:1' : Endif
  If dim([M:HRTIM1]BLCMIN)>0 : Chgfmt [M:HRTIM1]BLCMIN With '-Nz:9.2' : Endif
  If dim([M:HRTIM1]LVEINSOPT)>0 : Chgfmt [M:HRTIM1]LVEINSOPT With 'Nz:9.2' : Endif
  If dim([M:HRTIM1]LVEMAXOPT)>0 : Chgfmt [M:HRTIM1]LVEMAXOPT With 'LA:1' : Endif
  If dim([M:HRTIM1]LVEMAXCRE)>0 : Chgfmt [M:HRTIM1]LVEMAXCRE With 'Nz:9.2' : Endif
  If dim([M:HRTIM1]RSNMAN)>0 : Chgfmt [M:HRTIM1]RSNMAN With 'Nz:9.2' : Endif
  If dim([M:HRTIM1]CAPFRC)>0 : Chgfmt [M:HRTIM1]CAPFRC With 'Nz:9.2' : Endif
 Else
  If dim([M:HRTIM1]FLGBLC)>0 : Chgfmt [M:HRTIM1]FLGBLC With 'LA:1' : Endif
  If dim([M:HRTIM1]BLCMIN)>0 : Chgfmt [M:HRTIM1]BLCMIN With 'Nz:9.2' : Endif
  If dim([M:HRTIM1]LVEINSOPT)>0 : Chgfmt [M:HRTIM1]LVEINSOPT With '-Nz:9.2' : Endif
  If dim([M:HRTIM1]LVEMAXOPT)>0 : Chgfmt [M:HRTIM1]LVEMAXOPT With '-LA:1' : Endif
  If dim([M:HRTIM1]LVEMAXCRE)>0 : Chgfmt [M:HRTIM1]LVEMAXCRE With '-Nz:9.2' : Endif
  If dim([M:HRTIM1]RSNMAN)>0 : Chgfmt [M:HRTIM1]RSNMAN With '-Nz:9.2' : Endif
  If dim([M:HRTIM1]CAPFRC)>0 : Chgfmt [M:HRTIM1]CAPFRC With '-Nz:9.2' : Endif
 Endif
 #ADNGO - 2017-08-01 - X3-32650 - END
End


######################################################################################

Subprog TOGGLE_LEAVESUBTYPE_TAB(SHOW)
Variable Integer SHOW
  If SHOW = 1
     Chgfmt [M:HRTIM4]LVESUBNR With 'LA:1'
     #Chgfmt [M:HRTIM4]LVESUBDES With 'K:50'
     Chgfmt [M:HRTIM4]LVESUBPRI With 'NZ:4'
     Chgfmt [M:HRTIM4]LVESUBTYP With 'K:15'
     Affzo [M:HRTIM4]5
  Else
     Chgfmt [M:HRTIM4]LVESUBNR With '-LA:1'  : Raz [M:HRTIM4]LVESUBNR
     #Chgfmt [M:HRTIM4]LVESUBDES With '-K:50' : Raz [M:HRTIM4]LVESUBDES
     Chgfmt [M:HRTIM4]LVESUBPRI With '-NZ:4' : Raz [M:HRTIM4]LVESUBPRI
     Chgfmt [M:HRTIM4]LVESUBTYP With '-K:15' : Raz [M:HRTIM4]LVESUBTYP
     Affzo [M:HRTIM4]5
  Endif
End

