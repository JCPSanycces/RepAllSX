Subprog C_NONBUS(VALEUR)
Variable Integer VALEUR
#LIPET - 2017-08-29 - START
If VALEUR = 2 and [M]NBRDAY = 0 Then
  zonsui = "[M]NBRDAY"
  GERR=1
  [V]GMESSAGE = mess(10,123,1) : mkstat = 2
  GOK=0 :End
Endif
#LIPET - 2017-08-29 - END
End

######################################################################################
#LIPET - 2017-09-15 - X3-56163 - START
Subprog TOGGLE_NOTEREQ_BLOCK(SHOW)
Variable Integer SHOW

  If SHOW = 1
     Chgfmt [M:HRTIM1]NONBUS With 'LA:1'
     Chgfmt [M:HRTIM1]BFRNON With 'LA:1'
     Chgfmt [M:HRTIM1]AFTNON With 'LA:1'
     Chgfmt [M:HRTIM1]NBRDAY With 'NZ:3'
#     Chgfmt [M:HRTIM1]PLNGRP With '-LA:10418'    : Raz [M:HRTIM1]PLNGRP
     Affzo [M:HRTIM1]30
     Affzo [M:HRTIM1]50-55
  Else

     Chgfmt [M:HRTIM1]NONBUS With '-LA:1'    : Raz [M:HRTIM1]NONBUS
     Chgfmt [M:HRTIM1]BFRNON With '-LA:1'    : Raz [M:HRTIM1]BFRNON
     Chgfmt [M:HRTIM1]AFTNON With '-LA:1'    : Raz [M:HRTIM1]AFTNON
     Chgfmt [M:HRTIM1]NBRDAY With '-NZ:3'    : Raz [M:HRTIM1]NBRDAY
#     Chgfmt [M:HRTIM1]PLNGRP With 'LA:10418'
     Affzo [M:HRTIM1]30
     Affzo [M:HRTIM1]50-55
  Endif
End
#LIPET - 2017-09-15 - X3-56163 - END
