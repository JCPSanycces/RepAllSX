      ROW += 1
      #Call LECTEXTRA([M:HRTIM4]LVESUBDES(nolign-1),"HRLVESUBHEA","DES",GCURLEG,[M:HRTIM4]LVESUBTYP(nolign-1)) From ATEXTRA
