$SEL_TABLE
If func AFNC.ACTIV("GLM")
  Case TABLE
  When "SELHRTIM"
    If clalev ([F:TIM])=0 : Local File TIMCOD [TIM] : Endif
    If clalev ([F:TIM3])=0 : Local File TIMCOD [TIM3] : Endif #FRLAA X3-91927 2018-07-18
    Filter [F:TIM]
    OBJET="HRTIM"
###    START="[F:TIM]COD"
    #ADNGO - 2017-08-03 - X3-32847 - START
    If GFONCTION="GESHRLSE" Then
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:TIM]LEG="'+GCURLEG+'" & [F:TIM]LVEENHANCE=2)',"&") From GOBJSUB
    #ADNGO - 2017-08-15 - X3-32858 - START
    Else
      #FRLAA X3-91927 2018-07-18 - START
      If GFONCTION= "GESDCG" | GFONCTION = "ESSDCG" | GFONCTION = "ESSMGRDCG"
      #If GFONCTION= "GESDCG" | GFONCTION = "ESSDCG"
      #FRLAA X3-91927 2018-07-18 - END
        #FRLAA X3-86842 2018-05-15 - START
        Local Char LVESUBTYPES(GLONHRLST)(0..,0..9)
        Local Char PCTRNUM(GLONHRCTR)
        Local Date PENDDAT
        Local Integer I,L
        Global Char LIS_TPS(GLONTPS)(0..100)
        If GFONCTION= "GESDCG"
          PCTRNUM = [M]CTRNUM(nolign-1)
          PENDDAT = [M]ENDDAT(nolign-1)
        Elsif GFONCTION= "ESSDCG"
          PCTRNUM = [M]CTRNUM
          PENDDAT = [M]ENDDAT
        Endif
         #Call GET_LEAVE_SUB_TYPES(PCTRNUM, PENDDAT, LVESUBTYPES) From SUBHRBAL
         #FRLAA X3-86842 2018-05-15 - START
        Call GET_LEAVE_SUB_TYPES(PCTRNUM, PENDDAT,"", LVESUBTYPES) From SUBHRBAL
        #Call GET_LEAVE_SUB_TYPES([M]CTRNUM(nolign-1), [M]ENDDAT(nolign-1),"", LVESUBTYPES) From SUBHRBAL
        #FRLAA X3-86842 2018-05-15 - END
        For I = 0 To maxtab(LVESUBTYPES)
         If LVESUBTYPES(I,1)="" : Break : Endif
          #PEVAN - 2018-06-15 - X3-NANDOS - START
          #If LVESUBTYPES(I,3) <> "" and LVESUBTYPES(I,2) ="1"
          If LVESUBTYPES(I,3) <> ""# and LVESUBTYPES(I,2) ="1"
          #PEVAN - 2018-06-15 - X3-NANDOS - END
            #FRLAA X3-91927 2018-07-18 - START
            If GFONCTION = "ESSDCG" | GFONCTION = "ESSMGRDCG"
              Read [F:TIM3]TIM0 = GCURLEG; LVESUBTYPES(I,3)
              If !fstat
                If [F:TIM3]AUZPRH = 2 #For ESS, the user must only see events where enterable on portal

                  #PEVAN - 2018-06-15 - X3-NANDOS - START
                  #LIS_TPS(L) = LVESUBTYPES(I,3)
                  #L+=1
                  If !find(LVESUBTYPES(I,3),LIS_TPS)
                    LIS_TPS(L) = LVESUBTYPES(I,3)
                    L+=1
                  Endif
                  #PEVAN - 2018-06-15 - X3-NANDOS - START
                Endif
              Endif
            Else
              #PEVAN - 2018-06-15 - X3-NANDOS - START
              #LIS_TPS(L) = LVESUBTYPES(I,3)
              #L+=1
              If !find(LVESUBTYPES(I,3),LIS_TPS)
                LIS_TPS(L) = LVESUBTYPES(I,3)
                L+=1

              Endif
              #PEVAN - 2018-06-15 - X3-NANDOS - START
            Endif
          Endif
         #FRLAA X3-91927 2018-07-18 - END
        Next I
#        #If clalev([F:TIM]) =0     : Local File TIMCOD [TIM] Endif
#        If clalev([HRLSTD]) = 0      : Local File HRLVESUBDET [HRLSTD] Endif
#        If clalev([HRLSTH]) = 0      : Local File HRLVESUBHEA [HRLSTH] Endif
#        #If clalev([HRLSTH1]) = 0      : Local File HRLVESUBHEA [HRLSTH1] Endif
#        If clalev([HRCTR]) = 0    : Local File EMPLOCTR [HRCTR] Endif
#        If clalev ([ID]) = 0      : Local File EMPLOID [ID] Endif
#        If clalev ([FCY]) = 0     : Local File FACILITY [FCY] Endif
#        If clalev ([CPY]) = 0     : Local File COMPANY [CPY] Endif
#        If clalev ([HRPOA]) = 0   : Local File POPULA [HRPOA] Endif
#        If clalev ([HRCLV]) = 0   : Local File HRCLLCVT [HRCLV] Endif
#        If clalev ([SRV]) = 0   : Local File SERVICE [SRV] Endif
#        If clalev ([PRF]) = 0   : Local File PROFIL [PRF] Endif
#        Local Date LVESUBCTRDAT #FRLAA X3-86842 2018-05-15
#        Local Integer S, L
#        Local Char CRITACC1(250),CRITACC2(250)
