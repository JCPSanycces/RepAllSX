  RETVAL = NBRDAY

End RETVAL

Funprog SSPACCDATE(REFNUM,CTRNUM)
Value Char REFNUM, CTRNUM
Local Date RETVAL

    If clalev([DCG10])= 0 : Local File DEMCONGE  [DCG10] : Endif
    Filter [F:DCG10] Where REFNUM = [L]REFNUM & CTRNUM = [L]CTRNUM & SXPCAT = "SSP" and UID > 0 and LNKPIW = 2 and ([DCG]STA=1|[DCG]STA=2|[DCG]STA=3|[DCG]STA=4|[DCG]STA=5)
&                Order By Key DCGX = STRDAT

  Read [F:DCG10]Last
  Filter [F:DCG10]
  If !fstat
      RETVAL = [F:DCG10]ENDDAT+56
  Endif

End RETVAL

Funprog ACCDAYS
Local Integer RETVAL

  RETVAL = 90

End RETVAL

$CLR_MSK_SSP

  If dim([M:DCG1]SSPLNKPIW) > 0 : Effzo [M:DCG1]SSPLNKPIW         : Endif
  If dim([M:DCG1]SSPPIW) > 0    : Effzo [M:DCG1]SSPPIW            : Endif
  If dim([M:DCG1]SSPWAIDAY) > 0 : Effzo [M:DCG1]SSPWAIDAY         : Endif
  If dim([M:DCG1]SSPQUADAY) > 0 : Effzo [M:DCG1]SSPQUADAY         : Endif
  If dim([M:DCG1]SSPPAIDAY) > 0 : Effzo [M:DCG1]SSPPAIDAY         : Endif
  If dim([M:DCG1]SSPRPSTR) > 0  : Effzo [M:DCG1]SSPRPSTR          : Endif
  If dim([M:DCG1]SSPRPEND) > 0  : Effzo [M:DCG1]SSPRPEND          : Endif
  If dim([M:DCG1]SSPCER) > 0    : Effzo [M:DCG1]SSPCER            : Endif
#MASHI - 2017-10-05 X3-53788 START
#  Effzo [M:DCG1]SSPREA         With WSIGN+"K:30X"
  If dim([M:DCG1]SSPREA) > 0    : Effzo [M:DCG1]SSPREA            : Endif
#MASHI - 2017-10-05 X3-53788 START
  If dim([M:DCG1]SSPEXC) > 0    : Effzo [M:DCG1]SSPEXC            : Endif
  If dim([M:DCG1]CURPERSIC) > 0 : Effzo [M:DCG1]CURPERSIC         : Endif
  If dim([M:DCG1]PIW) > 0       : Effzo [M:DCG1]PIW               : Endif
  If dim([M:DCG1]LNKPIW) > 0    : Effzo [M:DCG1]LNKPIW            : Endif
  If dim([M:DCG1]WAIDAY) > 0    : Effzo [M:DCG1]WAIDAY            : Endif
  If dim([M:DCG1]PAIDAY) > 0    : Effzo [M:DCG1]PAIDAY            : Endif
  If dim([M:DCG1]RELPER) > 0    : Effzo [M:DCG1]RELPER            : Endif
  If dim([M:DCG1]SSPAVEERN) > 0 : Effzo [M:DCG1]SSPAVEERN         : Endif
  If dim([M:DCG1]SSPELI) > 0    : Effzo [M:DCG1]SSPELI            : Endif
  If dim([M:DCG1]NBWEK) > 0     : Effzo [M:DCG1]NBWEK             : Endif
  If dim([M:DCG1]WEKCOM) > 0    : Effzo [M:DCG1]WEKCOM            : Endif
  If dim([M:DCG1]WEKEND) > 0    : Effzo [M:DCG1]WEKEND            : Endif
  If dim([M:DCG1]LVERNGSTR) > 0 : Effzo [M:DCG1]LVERNGSTR         : Endif
  If dim([M:DCG1]LVERNGEND) > 0 : Effzo [M:DCG1]LVERNGEND         : Endif
  If dim([M:DCG1]WD1) > 0       : Effzo [M:DCG1]WD1               : Endif
  If dim([M:DCG1]QD1) > 0       : Effzo [M:DCG1]QD1               : Endif
  If dim([M:DCG1]WAIDAY1) > 0   : Effzo [M:DCG1]WAIDAY1           : Endif
  If dim([M:DCG1]PD1) > 0       : Effzo [M:DCG1]PD1               : Endif
  If dim([M:DCG1]RPD) > 0       : Effzo [M:DCG1]RPD               : Endif
  If dim([M:DCG1]SSPPRO) > 0    : Effzo [M:DCG1]SSPPRO            : Endif
#MASHI - 2017-09-08 X3-47523 START
  If dim([M:DCG1]NBPIW) > 0    : Effzo [M:DCG1]NBPIW             : Endif
#MASHI - 2017-09-08 X3-47523 END


  #TODO - Check average earnings column
#  Effzo [M:DCG1]AVEERN         With WSIGN+"Nz:9.5"
#MASHI - 2017-09-08 X3-47523 END

  If dim([M:DCG1]PIWSTRDAT) > 0 : Effzo [M:DCG1]PIWSTRDAT         : Endif
  If dim([M:DCG1]PIWENDDAT) > 0 : Effzo [M:DCG1]PIWENDDAT         : Endif
  If dim([M:DCG1]PIWELI)    > 0 : Effzo [M:DCG1]PIWELI            : Endif
  If dim([M:DCG1]PIWWAI)    > 0 : Effzo [M:DCG1]PIWWAI            : Endif
  If dim([M:DCG1]PIWREA)    > 0 : Effzo [M:DCG1]PIWREA            : Endif

  #ALHAR - 2017-09-14 X3-47501 START
  If dim([M:DCG1]SSPPRO) > 0    : Effzo [M:DCG1]SSPPRO            : Endif
  #ALHAR - 2017-09-14 X3-47501 END

Return

Funprog SOA_SSPPIW(SSPSTR,SSPEND,PERSCK,SXPCAT,SSPPIW,SSPSTA,SSPSTAREA,RETVAL)
Variable Date SSPSTR
Variable Date SSPEND
Variable Char PERSCK, SSPSTAREA
Variable Integer SSPPIW, SSPSTA,RETVAL

Value Char SXPCAT

Local Date STRDATE
#Local Char PERSCK(30)
Local Integer STAT : STAT = 1
Local Decimal SSP_LINK_P


#JOJAC - 2018-02-01 - START
#Comment out - STRDAT passed in as a parameter
#  If [L]SSPSTR = [0/0/0]
#    SSPSTR = [M:DCG1]STRDAT(nolign-1)
#  Endif

#  If [L]SSPEND = [0/0/0]
#    SSPEND = [M:DCG1]ENDDAT(nolign-1)
#  Endif
#JOJAC - 2018-02-01 - END

  #Period of sickness
  PERSCK = num$(SSPSTR)+" - "+num$(SSPEND)

#  [M:DCG1]CURPERSIC = PERSCK
#  Affzo [M:DCG1]CURPERSIC

  #Validate SSP record for PIW
  #If [M:DCG1]SXPCAT(nolign-1) <> ""
  If SXPCAT <> ""
    #If [M:DCG1]SXPCAT(nolign-1) = "SSP"
    If SXPCAT = "SSP"
       NBDAYS = 0 : NBHOURS = 0
       NBDAYS = ([L]SSPEND-[L]SSPSTR)+1
#       NBDAYS = ([M:DCG1]ENDDAT(nolign-1)-[M:DCG1]STRDAT(nolign-1))+1
      If NBDAYS >= 4
        #[M:DCG1]SSPPIW(nolign-1) = 2
        SSPPIW = 2
      Else
        #[M:DCG1]SSPSTA(nolign-1)    = 1       #: Affzo [M:DCG1]SSPSTA(nolign-1)       : Grizo [M:DCG1]SSPSTA(nolign-1)
        #[M:DCG1]SSPSTAREA(nolign-1) = 'L'     #: Affzo [M:DCG1]SSPSTAREA(nolign-1)    : Grizo [M:DCG1]SSPSTAREA(nolign-1)
        SSPSTA = 1
        SSPSTAREA = 'L'
      Endif
      #Affzo [M:DCG1]SSPPIW(nolign-1)
    Endif
  Endif

RETVAL = 1

End RETVAL

Funprog SOA_SSPLNKPIW(STRDAT,SXPCAT,SSPPIW,REFNUM,SSPLNKPIW)
Value Date STRDAT
Value Char SXPCAT,REFNUM
Value Integer SSPPIW
Variable  Integer SSPLNKPIW
Local Integer RETVAL : RETVAL = 1

Local Integer STAT : STAT = 1
Local Integer I
Local Decimal SSP_LINK_P

#Infbox num$(STRDAT)-num$(SXPCAT)-num$(SSPPIW)-num$(REFNUM)-num$(SSPLNKPIW)

  #Determine if this is a linked PIW
  #Mask
  #[L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",[M:DCG1]STRDAT(nolign-1))
  [L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",STRDAT)
  [L]SSP_LINK_P+=1

  #If [M:DCG1]SXPCAT(nolign-1) <> ""
  If SXPCAT <> ""
    #If [M:DCG1]SXPCAT(nolign-1) = "SSP" and [M:DCG1]SSPPIW(nolign-1) = 2
    If SXPCAT = "SSP" and SSPPIW = 2
        #Mask
#        For I = 0 To [M:DCG1]NBLIG
#          If I = nolign-1 : Break : Endif
#          If [M:DCG1]SXPCAT(I) = "SSP" and [M:DCG1]SSPPIW(I) = 2 and [M:DCG1]STRDAT(I) >= ([M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P)
#            STAT = 0
#          Endif
#        Next
#        If STAT <> 0
  #        #Table
  #        #TODO - Test that the transaction is not in the database yet


    If clalev([F:DCG_LNK])=0      : Local File DEMCONGE    [DCG_LNK] : Endif
    Filter [F:DCG_LNK] Where REFNUM = REFNUM & SXPCAT = "SSP" and SSPPIW = 2 and UID > 0 and ENDDAT >= (STRDAT-[L]SSP_LINK_P)
&   and ([DCG_LNK]STA=1|[DCG_LNK]STA=2|[DCG_LNK]STA=3|[DCG_LNK]STA=4|[DCG_LNK]STA=5)
  #         #Determine if any other SSP transactions within 56 days
    Read [DCG_LNK] First
    Filter [F:DCG_LNK]
    If !fstat
      STAT = 0
    Endif

    If STAT = 0
      #[M:DCG1]SSPLNKPIW(nolign-1) = 2
      SSPLNKPIW = 2
     Else
      #[M:DCG1]SSPLNKPIW(nolign-1) = 1
      SSPLNKPIW = 1
     Endif
     #Affzo [M:DCG1]SSPLNKPIW(nolign-1)
    Endif
  Endif

End RETVAL

Funprog SOA_PREVLNKPIW(STRDAT,REFNUM,LNKUID,RETVAL)
Local Decimal SSP_LINK_P
#Local Integer LNKUID
Variable Date STRDAT
Value Char REFNUM
Variable Integer LNKUID

Variable Integer RETVAL : RETVAL = 1

  #[L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",[M:DCG1]STRDAT(nolign-1))
  [L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",[F:DCG]STRDAT)
  [L]SSP_LINK_P+=1

  If clalev([F:DCG9])=0      : Local File DEMCONGE    [DCG9] : Endif
#  Filter [F:DCG9] Where REFNUM = [M:DCG1]REFNUM & SXPCAT = "SSP" and SSPPIW = 2 and UID > 0
#&                 and ENDDAT >= [M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P and ([DCG]STA=1|[DCG]STA=2|[DCG]STA=3|[DCG]STA=4|[DCG]STA=5)

   Filter [F:DCG9] Where REFNUM = REFNUM & SXPCAT = "SSP" and SSPPIW = 2 and UID > 0
&                  and ENDDAT >= STRDAT-[L]SSP_LINK_P and ([DCG9]STA=1|[DCG9]STA=2|[DCG9]STA=3|[DCG9]STA=4|[DCG9]STA=5)


  Read [F:DCG9] First
  Filter [F:DCG9]
  If !fstat
    LNKUID = [F:DCG9]LNKUID
  Else
    LNKUID = [F:DCG]UID
  Endif

  [F:DCG]LNKUID = LNKUID
  #[M:DCG1]LNKUID(nolign-1) = [L]LNKUID : Affzo [M:DCG1]LNKUID(nolign-1)

End RETVAL

Funprog SOA_SSPELI_AWE(STRDAT,LNKUID,REFNUM,SSPRPEND,AVEERN,SSPSTA,SSPSTAREA,RETVAL)
Local Decimal AWE
Local Decimal SSP_MAWE

Variable Date STRDAT
Variable Integer RETVAL : RETVAL=1
Value Integer LNKUID
Value Char REFNUM
Value Date SSPRPEND
Variable Decimal AVEERN
Variable Integer SSPSTA
Variable Char SSPSTAREA

#MASHI - 2017-09-06 X3-53819 START
    #If [M:DCG1]SSPRPEND(nolign-1)=[0/0/0]
     #Infbox "Missing Extraction Periods."
    #Endif
#MASHI - 2017-09-06 X3-53819 END

  #SSP_MAWE = func SUBDCGUKI.SETVARIABLE("SSP_MAWE",[M:DCG1]STRDAT(nolign-1))
  SSP_MAWE = func SUBDCGUKI.SETVARIABLE("SSP_MAWE",STRDAT)
  If SSP_MAWE = 0
  #TODO
    Infbox "Legal Variable SSP_MAWE value has not been populated"
  Endif


  If clalev([F:DCG_AVE])=0      : Local File DEMCONGE    [DCG_AVE] : Endif
  #If [M:DCG1]LNKUID(nolign-1) <> 0
    #Filter [F:DCG_AVE] Where LNKUID=[M:DCG1]LNKUID(nolign-1) and LNKUID <> 0 and SXPCAT = 'SSP'
    Filter [F:DCG_AVE] Where LNKUID=LNKUID and LNKUID <> 0 and SXPCAT = 'SSP'
    Read [F:DCG_AVE] First
    Filter [F:DCG_AVE]

    If !fstat
      [L]AWE = [F:DCG_AVE]AVEERN
    Else
      #[L]AWE =  func SSP_AVERAGE_EARNING([M:DCG1]REFNUM,[M:DCG1]SSPRPEND(nolign-1))
      [L]AWE =  func SSP_AVERAGE_EARNING(REFNUM,SSPRPEND)
    Endif


#[L]AWE =  func SSP_AVERAGE_EARNING([M:DCG1]REFNUM,[M:DCG1]SSPRPEND(nolign-1))


  If [L]AWE = 0
    #TODO
    Infbox "Average Earning are below the limit"
  Else
    #[M:DCG1]AVEERN(nolign-1) = [L]AWE
    AVEERN = [L]AWE
  Endif

  #[M:DCG1]SSPAVEERN   = [M:DCG1]AVEERN(nolign-1)  : Affzo [M:DCG1]SSPAVEERN

  If [L]AWE < [L]SSP_MAWE
    #[M:DCG1]SSPSTA(nolign-1) = 1 : Affzo [M:DCG1]SSPSTA(nolign-1)
    SSPSTA = 1
    #[M:DCG1]SSPSTAREA(nolign-1) = "E" : Affzo [M:DCG1]SSPSTAREA(nolign-1)
    SSPSTAREA = "E"
    #zonsui = "[M:DCG1]SSPSTAREA(nolign-1)"
    #Affzo [M:DCG1]30
  Endif

End RETVAL

Funprog SOA_SSPQUADAY(STRDAT,ENDDAT,REFNUM,TIM,FCY,CTRNUM,SSPPIW,SSPQUADAY,SSPWAIDAY,SSPPAIDAY,RETVAL)
Local Decimal NBDAYS, NBHOURS
Local Decimal SSP_WAIT_D

Variable Integer RETVAL,SSPWAIDAY,SSPPAIDAY
Value Date STRDAT, ENDDAT
Value Char REFNUM, TIM, FCY, CTRNUM
Value Integer SSPPIW,SSPQUADAY


  #Determine qualifying days
  [L]NBDAYS = 0 : NBHOURS = 0

  #Call VALORIS_L([M:DCG1]STRDAT(nolign-1),[M:DCG1]ENDDAT(nolign-1),[M:DCG1]REFNUM,[M:DCG1]TIM(nolign-1),NBDAYS,NBHOURS,[M:DCG1]FCY,[M:DCG1]CTRNUM(nolign-1)) From SUBACCRUAL
  #Call VALORIS([M:DCG1]STRDAT(nolign-1),[M:DCG1]ENDDAT(nolign-1),[M:DCG1]REFNUM,[M:DCG1]TIM(nolign-1),[L]NBDAYS,[L]NBHOURS,[M:DCG1]FCY,[M:DCG1]CTRNUM(nolign-1)) From SUBPLN
  Call VALORIS(STRDAT,ENDDAT,REFNUM,TIM,[L]NBDAYS,[L]NBHOURS,FCY,CTRNUM) From SUBPLN

  #SSP_WAIT_D = func SUBDCGUKI.SETVARIABLE("SSP_WAIT_D",[M:DCG1]STRDAT(nolign-1))
  SSP_WAIT_D = func SUBDCGUKI.SETVARIABLE("SSP_WAIT_D",STRDAT)

  If [L]SSPSTA = 2
    #If [M:DCG1]SSPPIW(nolign-1) = 2
    If SSPPIW = 2
      #[M:DCG1]SSPQUADAY(nolign-1)=[L]NBDAYS
      SSPQUADAY = [L]NBDAYS
    Else
      #[M:DCG1]SSPQUADAY(nolign-1)=0
      SSPQUADAY = 0
    Endif

    #Affzo [M:DCG1]SSPQUADAY(nolign-1)


  Local Decimal SSP_WAIT_D
  #SSP_WAIT_D = func SUBDCGUKI.SETVARIABLE("SSP_WAIT_D",[M:DCG1]STRDAT(nolign-1))
  SSP_WAIT_D = func SUBDCGUKI.SETVARIABLE("SSP_WAIT_D",STRDAT)

    If WDAY < SSP_WAIT_D
      #If [M:DCG1]SSPPIW(nolign-1) = 2
      If SSPPIW = 2
        If NBDAYS < (SSP_WAIT_D-WDAY) and SSP_WAIT_D-WDAY> 0
          #[M:DCG1]SSPWAIDAY(nolign-1) = [L]NBDAYS
          SSPWAIDAY = [L]NBDAYS
        Else
          #[M:DCG1]SSPWAIDAY(nolign-1) = SSP_WAIT_D-WDAY
          SSPWAIDAY = SSP_WAIT_D-WDAY
        Endif
      Endif
    Else
      #[M:DCG1]SSPWAIDAY(nolign-1) = 0
      SSPWAIDAY = 0
    Endif
    #Affzo [M:DCG1]SSPWAIDAY(nolign-1)

    #Affzo [M:DCG1]SSPQUADAY(nolign-1)

    #Paid days
    #If [M:DCG1]SSPQUADAY(nolign-1) > 0
    If SSPQUADAY > 0
      #[M:DCG1]SSPPAIDAY(nolign-1)=[M:DCG1]SSPQUADAY(nolign-1)-[M:DCG1]SSPWAIDAY(nolign-1)
      SSPPAIDAY = SSPQUADAY-SSPWAIDAY
    Endif
    #Affzo [M:DCG1]SSPPAIDAY(nolign-1)

  Else

    #[M:DCG1]SSPQUADAY(nolign-1) = 0     :     Affzo [M:DCG1]SSPQUADAY(nolign-1)
    #[M:DCG1]SSPWAIDAY(nolign-1) = 0     :     Affzo [M:DCG1]SSPWAIDAY(nolign-1)
    #[M:DCG1]SSPPAIDAY(nolign-1) = 0     :     Affzo [M:DCG1]SSPPAIDAY(nolign-1)
    SSPQUADAY = 0
    SSPWAIDAY = 0
    SSPPAIDAY = 0

  Endif

End RETVAL

Funprog SOA_SSPRELPER(CTRNUM,STRDAT,ENDDAT,RETVAL,AVEERN,SSPRPSTR,SSPRPEND)
Variable Integer RETVAL
Value Char CTRNUM
Value Date STRDAT, ENDDAT
Variable Decimal AVEERN
Variable Date SSPRPSTR, SSPRPEND

Local Char VPERCOD
Local Date STR1, END1
Local Date STRRELPER
Local Date ENDRELPER
Local Integer LNKUID
Local Decimal SSP_LINK_P


#Determine relevant period
  If clalev([F:HRCTR9])=0  : Local File EMPLOCTR  [HRCTR9]  : Endif
  If clalev([F:HRPEOH9])=0 : Local File HRPEOHEA  [HRPEOH9] : Endif
  If clalev([F:HRPEOD9])=0 : Local File HRPEODET  [HRPEOD9] : Endif

  #Filter [HRCTR9] Where CTRNUM = [M:DCG1]CTRNUM(nolign-1)
  Filter [HRCTR9] Where CTRNUM = CTRNUM
  Read [HRCTR9] First
  Filter [HRCTR9]
  If !fstat
    [L]VPERCOD = [F:HRCTR9]PERCOD
  Endif

  #STR1 = [M:DCG1]STRDAT(nolign-1)
  #END1 = [M:DCG1]ENDDAT(nolign-1)

  #[L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",[M:DCG1]STRDAT(nolign-1))
  [L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",STRDAT)
  #[L]SSP_LINK_P+=1

  If clalev([F:DCG7])=0      : Local File DEMCONGE    [DCG7] : Endif
  #Filter [F:DCG7] Where REFNUM = [M:DCG1]REFNUM & SXPCAT = "SSP" and SSPPIW = 2 and UID > 0 and STRDAT >= ([M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P)
#  Filter [F:DCG7] Where REFNUM = [M:DCG1]REFNUM and CTRNUM = [M:DCG1]CTRNUM(nolign-1)  & SXPCAT = "SSP" and SSPPIW = 2
#&                 and UID > 0 and ENDDAT >= ([M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P) and ([DCG]STA=1|[DCG]STA=2|[DCG]STA=3|[DCG]STA=4|[DCG]STA=5)
  Filter [F:DCG7] Where REFNUM = [M:DCG1]REFNUM and CTRNUM = CTRNUM  & SXPCAT = "SSP" and SSPPIW = 2
&                 and UID > 0 and ENDDAT >= (STRDAT-[L]SSP_LINK_P) and ([DCG]STA=1|[DCG]STA=2|[DCG]STA=3|[DCG]STA=4|[DCG]STA=5)

  Read [DCG7] First
  Filter [F:DCG7]
  If !fstat
    LNKUID = [DCG7]LNKUID
  Endif

  If clalev([F:DCG6])=0      : Local File DEMCONGE    [DCG6] : Endif
  Filter [F:DCG6] Where LNK = [L]LNKUID
  Read [F:DCG6] First
  Filter [F:DCG6]
  If !fstat
    [L]STRRELPER=[F:DCG6]SSPRPSTR
    [L]ENDRELPER=[F:DCG6]SSPRPEND
#    [M:DCG1]AVEERN(nolign-1) = [F:DCG6]AVEERN
    #Affzo [M:DCG1]AVEERN(nolign-1)
  Else
    #Last normal payday before the first complete day of sickness
    Filter [HRPEOD9] Where PERCOD = [L]VPERCOD and PYRDAT < STR1
    #Filter [HRPEOD9] Where PERCOD = [L]VPERCOD and PYRDAT <= STR1
    Read [HRPEOD9] Last
    Filter [HRPEOD9]
    If !fstat
    #[L]ENDRELPER = [F:HRPEOD9]PYRDAT
    #[L]STRRELPER = ([F:HRPEOD9]PYRDAT - [L]SSP_LINK_P)
    SSPRPEND = [F:HRPEOD9]PYRDAT
    SSPRPSTR = ([F:HRPEOD9]PYRDAT-[L]SSP_LINK_P)
    SSPRPSTR+=1
   Endif

    #Last normal payday not falling less that 8 weeks before the end of the relevant period
  #  Local Date STRRELPER
  #  Filter [HRPEOD9] Where PERCOD = [L]VPERCOD and PYRDAT >= [L]ENDRELPER-56
  #  Read [HRPEOD9] First
  #  If !fstat
  #  [L]STRRELPER = [F:HRPEOD9]PYRDAT
  #  Endif
  #  Filter [HRPEOD9]
#MASHI - 2017-09-06 X3-53819 START
#    If [M:DCG1]AVEERN(nolign-1) = 0
    If [L]ENDRELPER=[0/0/0]
     Infbox "Missing Extraction Periods."
     mkstat=2
    #Elsif [M:DCG1]AVEERN(nolign-1) = 0
    Elsif AVEERN = 0
#MASHI - 2017-09-06 X3-53819 END
     #[M:DCG1]AVEERN(nolign-1) = func SSP_AVERAGE_EARNING([M:DCG1]REFNUM,[L]ENDRELPER)
     AVEERN = func SSP_AVERAGE_EARNING(REFNUM,[L]ENDRELPER)
     #Affzo [M:DCG1]AVEERN(nolign-1)
    Endif
  Endif

  #[M:DCG1]SSPRPSTR(nolign-1) = [L]STRRELPER     : Affzo [M:DCG1]SSPRPSTR(nolign-1)
  #[M:DCG1]SSPRPEND(nolign-1) = [L]ENDRELPER     : Affzo [M:DCG1]SSPRPEND(nolign-1)

End RETVAL

Funprog SOA_SSPWAIDAY(STRDAT,REFNUM,RETVAL)
#Waiting days
Local Integer WDAY : WDAY = 0
Local Decimal SSP_LINK_P

Variable Integer RETVAL
Value Date STRDAT
Value Char REFNUM

  #[L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",[M:DCG1]STRDAT(nolign-1))
  [L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",STRDAT)
  [L]SSP_LINK_P += 1

  #Mask
#  For I = 0 To [M:DCG1]NBLIG
#    If I <> nolign-1
#        If [M:DCG1]SXPCAT = "SSP"
#          If [M:DCG1]UID(I) = 0 and [M:DCG1]ENDDAT(I) >= [M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P
#            WDAY += [M:DCG1]SSPWAIDAY(I)
#          Endif
#        Endif
#    Endif
#  Next

#  #Table
#  For [DCG] Where [DCG]REFNUM = [M:DCG1]REFNUM and [DCG]CTRNUM = [M:DCG1]CTRNUM(nolign-1) and [DCG]UID > 0 and [DCG]SXPCAT = "SSP"
#& and [DCG]SSPPIW = 2 and [DCG]ENDDAT >= ([M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P) and [DCG]STRDAT < [M:DCG1]STRDAT(nolign-1)  #Determine if
#  # any other
#  # SSP transactions within 56 days
#  WDAY += [DCG]SSPWAIDAY
#  Next

  Local Integer LNKUID1
  #Table

  If clalev([DCG_WD])= 0 : Local File DEMCONGE  [DCG_WD] : Endif
  Filter [DCG_WD] Where [DCG_WD]REFNUM = [M:DCG1]REFNUM and [DCG_WD]CTRNUM = [M:DCG1]CTRNUM(nolign-1) and [DCG_WD]UID > 0 and [DCG_WD]SXPCAT = "SSP"
& and [DCG_WD]SSPPIW = 2 and [DCG_WD]ENDDAT >= ([M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P) and [DCG_WD]ENDDAT < [M:DCG1]STRDAT(nolign-1)

  Read [DCG_WD] First
  Filter [DCG_WD]

  If !fstat
    [L]LNKUID1 = [DCG_WD]LNKUID
    For [DCG] Where LNKUID = [L]LNKUID1 and UID>0 and ENDDAT < [M:DCG1]STRDAT(nolign-1)
      WDAY += [DCG]SSPWAIDAY
    Next
  Endif

End RETVAL

#ANCOA - X3-77322 - 21/02/2018 - Start
#**
#* Updates all linked SSP absences to have a the same average weekly earnings amount
#*
#* @param LINK_UID Unique link id that links SSP records together
#* @param RECORD_UID Unique id for the current record - will be ignored from the update
#* @param AWE_AMOUNT Average weekly earnings amount to assign to the linked records
#*!
Subprog UPDATE_LINKED_AWE (LINK_UID, RECORD_UID, AWE_AMOUNT)
  Value Integer LINK_UID, RECORD_UID, I
  Value Decimal AWE_AMOUNT

  For I = 0 To [M:DCG1]NBLIG
    If [M:DCG1]LNKUID(I) = LINK_UID and [M:DCG1]UID(I) <> RECORD_UID
      [M:DCG1]AVEERN(I) = AWE_AMOUNT
      Affzo [M:DCG1]AVEERN(I)
    Endif
  Next
End
#ANCOA - X3-77322 - 21/02/2018 - End

