#<AdxTL>@(#)0.0.0.0 $Revision$ 
#MIPEA SOURCE REMERGE

$SSPPIW
Local Date STRDATE
Local Char PERSCK(30)
Local Integer STAT : STAT = 1
Local Decimal SSP_LINK_P


  If [L]SSPSTR = [0/0/0]
    SSPSTR = [M:DCG1]STRDAT(nolign-1)
  Endif

  If [L]SSPEND = [0/0/0]
    SSPEND = [M:DCG1]ENDDAT(nolign-1)
  Endif

  #Period of sickness
  PERSCK = num$(SSPSTR)+" - "+num$(SSPEND)
  [M:DCG1]CURPERSIC = PERSCK
  Affzo [M:DCG1]CURPERSIC

  #Validate SSP record for PIW
  If [M:DCG1]SXPCAT(nolign-1) <> ""
    If [M:DCG1]SXPCAT(nolign-1) = "SSP"
       NBDAYS = 0 : NBHOURS = 0
       NBDAYS = ([L]SSPEND-[L]SSPSTR)+1
#       NBDAYS = ([M:DCG1]ENDDAT(nolign-1)-[M:DCG1]STRDAT(nolign-1))+1
      If NBDAYS >= 4
        [M:DCG1]SSPPIW(nolign-1) = 2
      Else
        [M:DCG1]SSPSTA(nolign-1)    = 1       : Affzo [M:DCG1]SSPSTA(nolign-1)       : Grizo [M:DCG1]SSPSTA(nolign-1)
        [M:DCG1]SSPSTAREA(nolign-1) = 'L'     : Affzo [M:DCG1]SSPSTAREA(nolign-1)    : Grizo [M:DCG1]SSPSTAREA(nolign-1)
      Endif
      Affzo [M:DCG1]SSPPIW(nolign-1)
    Endif
  Endif

Return

$SSPLNKPIW
Local Integer STAT : STAT = 1
Local Integer I
Local Decimal SSP_LINK_P

  #Determine if this is a linked PIW
  #Mask
  [L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",[M:DCG1]STRDAT(nolign-1))
  [L]SSP_LINK_P+=1

  If [M:DCG1]SXPCAT(nolign-1) <> ""
    If [M:DCG1]SXPCAT(nolign-1) = "SSP" and [M:DCG1]SSPPIW(nolign-1) = 2
        #Mask
#        For I = 0 To [M:DCG1]NBLIG
#          If I = nolign-1 : Break : Endif
#          If [M:DCG1]SXPCAT(I) = "SSP" and [M:DCG1]SSPPIW(I) = 2 and [M:DCG1]STRDAT(I) >= ([M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P)
#            STAT = 0
#          Endif
#        Next
#        If STAT <> 0
  #        #Table
  #        #TODO - Test that the transaction is not in the database yet


    If clalev([F:DCG_LNK])=0      : Local File DEMCONGE    [DCG_LNK] : Endif
#MASHI - 2018-02-22 - X3-77321 - START
    Filter [F:DCG_LNK] Where REFNUM = [M:DCG1]REFNUM & SXPCAT = "SSP" and SSPPIW = 2 and UID > 0 and ENDDAT >= ([M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P)
&   and ENDDAT < [M:DCG1]STRDAT(nolign-1) and ([DCG_LNK]STA=1|[DCG_LNK]STA=2|[DCG_LNK]STA=3|[DCG_LNK]STA=4|[DCG_LNK]STA=5)
#MASHI - 2018-02-22 - X3-77321 - END
  #         #Determine if any other SSP transactions within 56 days
    Read [DCG_LNK] First
    Filter [F:DCG_LNK]
    If !fstat
      STAT = 0
    Endif

    If STAT = 0
      [M:DCG1]SSPLNKPIW(nolign-1) = 2
     Else
      [M:DCG1]SSPLNKPIW(nolign-1) = 1
     Endif
     Affzo [M:DCG1]SSPLNKPIW(nolign-1)
    Endif
  Endif
Return

#JOJAC - 2017-08-21 - X3-15908 - START
#link piw's to each other with uid
$PREVLNKPIW
Local Decimal SSP_LINK_P
Local Integer LNKUID

  #[L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",[M:DCG1]STRDAT(nolign-1))
  [L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",[F:DCG]STRDAT)
  [L]SSP_LINK_P+=1

  If clalev([F:DCG9])=0      : Local File DEMCONGE    [DCG9] : Endif
#MASHI - 2018-02-22 - X3-77321 - START
#ANCOA - 2018-02-27 - X3-78493 - START - Include future SSP absences which might be linked
  Filter [F:DCG9] Where REFNUM = [M:DCG1]REFNUM & SXPCAT = "SSP" and SSPPIW = 2 and UID > 0
&                 and ((ENDDAT < [M:DCG1]STRDAT(nolign-1) and ENDDAT >= [M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P) or
&                      (STRDAT > [M:DCG1]ENDDAT(nolign-1)  and STRDAT <= [M:DCG1]ENDDAT(nolign-1) + [L]SSP_LINK_P ))
&                 and ([DCG9]STA=1|[DCG9]STA=2|[DCG9]STA=3|[DCG9]STA=4|[DCG9]STA=5)
#ANCOA - 2018-02-27 - X3-78493 - END
#MASHI - 2018-02-22 - X3-77321 - END
  Read [F:DCG9] First
  Filter [F:DCG9]
  If !fstat
    [L]LNKUID = [F:DCG9]LNKUID
  Else
#MASHI - 2018-02-22 - X3-77321 - START
    [L]LNKUID =uniqid([TIP]) #[F:DCG]UID
#MASHI - 2018-02-22 - X3-77321 - END
  Endif

  #[F:DCG]LNKUID = [L]LNKUID
  [M:DCG1]LNKUID(nolign-1) = [L]LNKUID : Affzo [M:DCG1]LNKUID(nolign-1)

Return
#JOJAC - 2017-08-21 - X3-15908 - END

#X3-46019
#Determine if a record is eligible for SSP according to linked PIW
$SSPELI_LNKPIW
Return

#X3-46058
#Determine if a record is eligible for SSP according to AWE
$SSPELI_AWE
Local Decimal AWE
Local Decimal SSP_MAWE
Local Integer SSP_BK
#SAVAN - 2018/02/23 - start
[L]SSP_BK = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",[F:DCG]STRDAT)
[L]SSP_BK+=1
#SAVAN - 2018/02/23 - end
#MASHI - 2017-09-06 X3-53819 START
    If [M:DCG1]SSPRPEND(nolign-1)=[0/0/0]
     Infbox "Missing Extraction Periods."
    Endif
#MASHI - 2017-09-06 X3-53819 END

  SSP_MAWE = func SUBDCGUKI.SETVARIABLE("SSP_MAWE",[M:DCG1]STRDAT(nolign-1))
  If SSP_MAWE = 0
  #TODO
    Infbox "Legal Variable SSP_MAWE value has not been populated"
  Endif


  If clalev([F:DCG_AVE])=0      : Local File DEMCONGE    [DCG_AVE] : Endif
  #If [M:DCG1]LNKUID(nolign-1) <> 0
  #SAVAN - 2018/03/06 - added the check for tracking - start
    Filter [F:DCG_AVE] Where LNKUID=[M:DCG1]LNKUID(nolign-1) and LNKUID <> 0 and SXPCAT = 'SSP' and ENDDAT < [M:DCG1]STRDAT(nolign-1) and ENDDAT >= [M:DCG1]STRDAT(nolign-1)-[L]SSP_BK and ([DCG_AVE]STA
& =1|[DCG_AVE]STA=2|[DCG_AVE]STA=3|[
& DCG_AVE]STA=4|[DCG_AVE]STA=5)
  #SAVAN - 2018/03/06 - added the check for tracking - end
    Read [F:DCG_AVE] First
    Filter [F:DCG_AVE]

    If !fstat
      [L]AWE = [F:DCG_AVE]AVEERN
    Else
      [L]AWE =  func SSP_AVERAGE_EARNING([M:DCG1]REFNUM,[M:DCG1]SSPRPEND(nolign-1))
    Endif
    # Has the user overwritten the AWE? If so retain
#    If [L]AWE = 0 and [M:DCG1]AVEERN(nolign-1) > 0
#      [L]AWE = [M:DCG1]AVEERN(nolign-1)
#    Endif

#[L]AWE =  func SSP_AVERAGE_EARNING([M:DCG1]REFNUM,[M:DCG1]SSPRPEND(nolign-1))
#SAVAN - 2018/02/23 - start
Local Decimal SSP_MAWE_CHK
      [L]SSP_MAWE_CHK = func SUBDCGUKI.SETVARIABLE("SSP_MAWE",[M:DCG1]STRDAT(nolign-1))
  If [L]AWE < SSP_MAWE_CHK
  #If [L]AWE = 0
#SAVAN - 2018/02/23 - end
    #TODO
    Infbox "Average Earning are below the limit"
  Else
    # Replaced by lines above
    [M:DCG1]AVEERN(nolign-1) = [L]AWE
  Endif

  [M:DCG1]SSPAVEERN   = [M:DCG1]AVEERN(nolign-1)  : Affzo [M:DCG1]SSPAVEERN

  If [L]AWE < [L]SSP_MAWE
    [M:DCG1]SSPSTA(nolign-1) = 1 : Affzo [M:DCG1]SSPSTA(nolign-1)
    [M:DCG1]SSPSTAREA(nolign-1) = "E" : Affzo [M:DCG1]SSPSTAREA(nolign-1)
    zonsui = "[M:DCG1]SSPSTAREA(nolign-1)"
    #Affzo [M:DCG1]30
    Else
      [M:DCG1]SSPSTA(nolign-1) = 2
  Endif
  #SAVAN 2018/02/20 - start - keep displaying AWE on the grid and also the Payment Transaction sign
  Affzo [M:DCG1]AVEERN
  [M:DCG1]SSPPRO(nolign-1) = 2
  Affzo [M:DCG1]SSPPRO(nolign-1)
  #Affzo [M:DCG1]SSPPAIDAY(nolign-1)
  #SAVAN 2018/02/20 - end - keep displaying AWE on the grid and also the Payment Transaction sign

Return

#X3-46020
$SHOWLNKPIW

  Raz [M:DCG1]PIWSTRDAT
  Raz [M:DCG1]PIWENDDAT
  Raz [M:DCG1]PIWELI
  Raz [M:DCG1]PIWWAI
  Raz [M:DCG1]PIWREA

  If clalev([F:DCG8])=0      : Local File DEMCONGE    [DCG8] : Endif

  A=0
  For [DCG8] Where LNKUID = [M:DCG1]LNKUID(nolign-1) and UID > 0 and ENDDAT <= [M:DCG1]STRDAT(nolign-1) and SSPPIW = 2
     [M:DCG1]PIWSTRDAT(A) = [DCG8]STRDAT
     [M:DCG1]PIWENDDAT(A) = [DCG8]ENDDAT
     [M:DCG1]PIWELI(A)    = [DCG8]SSPSTA
     [M:DCG1]PIWWAI(A)    = [DCG8]SSPWAIDAY
     [M:DCG1]PIWREA(A)    = [DCG8]SSPSTAREA
     [M:DCG1]NBPIW = A
     A+=1
  Next
  [M:DCG1]NBPIW = A
  Affzo [M:DCG1]85
  #Filter [DCG8]


Return


$SSPQUADAY
Local Decimal NBDAYS, NBHOURS
Local Decimal SSP_WAIT_D

  #Determine qualifying days
  [L]NBDAYS = 0 : NBHOURS = 0

  #Call VALORIS_L([M:DCG1]STRDAT(nolign-1),[M:DCG1]ENDDAT(nolign-1),[M:DCG1]REFNUM,[M:DCG1]TIM(nolign-1),NBDAYS,NBHOURS,[M:DCG1]FCY,[M:DCG1]CTRNUM(nolign-1)) From SUBACCRUAL
  Call VALORIS([M:DCG1]STRDAT(nolign-1),[M:DCG1]ENDDAT(nolign-1),[M:DCG1]REFNUM,[M:DCG1]TIM(nolign-1),[L]NBDAYS,[L]NBHOURS,[M:DCG1]FCY,[M:DCG1]CTRNUM(nolign-1)) From SUBPLN

  SSP_WAIT_D = func SUBDCGUKI.SETVARIABLE("SSP_WAIT_D",[M:DCG1]STRDAT(nolign-1))

  If [L]SSPSTA = 2
    If [M:DCG1]SSPPIW(nolign-1) = 2
      [M:DCG1]SSPQUADAY(nolign-1)=[L]NBDAYS
    Else
      [M:DCG1]SSPQUADAY(nolign-1)=0
    Endif

    Affzo [M:DCG1]SSPQUADAY(nolign-1)


  Local Decimal SSP_WAIT_D
  SSP_WAIT_D = func SUBDCGUKI.SETVARIABLE("SSP_WAIT_D",[M:DCG1]STRDAT(nolign-1))

    If WDAY < SSP_WAIT_D
      If [M:DCG1]SSPPIW(nolign-1) = 2
        If NBDAYS < (SSP_WAIT_D-WDAY) and SSP_WAIT_D-WDAY> 0
          [M:DCG1]SSPWAIDAY(nolign-1) = [L]NBDAYS
        Else
          [M:DCG1]SSPWAIDAY(nolign-1) = SSP_WAIT_D-WDAY
        Endif
      Endif
    Else
      [M:DCG1]SSPWAIDAY(nolign-1) = 0
    Endif
    Affzo [M:DCG1]SSPWAIDAY(nolign-1)

    Affzo [M:DCG1]SSPQUADAY(nolign-1)

    #Paid days
    If [M:DCG1]SSPQUADAY(nolign-1) > 0
      [M:DCG1]SSPPAIDAY(nolign-1)=[M:DCG1]SSPQUADAY(nolign-1)-[M:DCG1]SSPWAIDAY(nolign-1)
    Endif
    Affzo [M:DCG1]SSPPAIDAY(nolign-1)

  Else

    [M:DCG1]SSPQUADAY(nolign-1) = 0     :     Affzo [M:DCG1]SSPQUADAY(nolign-1)
    [M:DCG1]SSPWAIDAY(nolign-1) = 0     :     Affzo [M:DCG1]SSPWAIDAY(nolign-1)
    [M:DCG1]SSPPAIDAY(nolign-1) = 0     :     Affzo [M:DCG1]SSPPAIDAY(nolign-1)

  Endif

Return

$SSPRELPER
Local Char VPERCOD
Local Date STR1, END1
Local Date STRRELPER
Local Date ENDRELPER
Local Integer LNKUID
Local Decimal SSP_LINK_P

#Determine relevant period
  If clalev([F:HRCTR9])=0 : Local File EMPLOCTR  [HRCTR9] : Endif
  If clalev([F:HRPEOH9])=0 : Local File HRPEOHEA  [HRPEOH9] : Endif
  If clalev([F:HRPEOD9])=0 : Local File HRPEODET  [HRPEOD9] : Endif

  Filter [HRCTR9] Where CTRNUM = [M:DCG1]CTRNUM(nolign-1)
  Read [HRCTR9] First
  Filter [HRCTR9]
  If !fstat
    [L]VPERCOD = [F:HRCTR9]PERCOD
  Endif

  STR1 = [M:DCG1]STRDAT(nolign-1)
  END1 = [M:DCG1]ENDDAT(nolign-1)

  [L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",[M:DCG1]STRDAT(nolign-1))
  #[L]SSP_LINK_P+=1

  If clalev([F:DCG7])=0      : Local File DEMCONGE    [DCG7] : Endif
  #Filter [F:DCG7] Where REFNUM = [M:DCG1]REFNUM & SXPCAT = "SSP" and SSPPIW = 2 and UID > 0 and STRDAT >= ([M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P)
  #ANCOA - X3-80942 - only look to past absences to copy the relevant period (ENDDAT < [M:DCG1]STRDAT(nolign-1))
  Filter [F:DCG7] Where REFNUM = [M:DCG1]REFNUM and CTRNUM = [M:DCG1]CTRNUM(nolign-1)  & SXPCAT = "SSP" and SSPPIW = 2
&                 and UID > 0 and ENDDAT >= ([M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P) and ([DCG7]STA=1|[DCG7]STA=2|[DCG7]STA=3|[DCG7]STA=4|[DCG7]STA=5)
&                 and ENDDAT < [M:DCG1]STRDAT(nolign-1)

  Read [DCG7] First
  Filter [F:DCG7]
  If !fstat
    LNKUID = [DCG7]LNKUID
  Endif

  If clalev([F:DCG6])=0      : Local File DEMCONGE    [DCG6] : Endif
  Filter [F:DCG6] Where LNK = [L]LNKUID
  Read [F:DCG6] First
  Filter [F:DCG6]
  If !fstat
    [L]STRRELPER=[F:DCG6]SSPRPSTR
    [L]ENDRELPER=[F:DCG6]SSPRPEND
#    [M:DCG1]AVEERN(nolign-1) = [F:DCG6]AVEERN
    Affzo [M:DCG1]AVEERN(nolign-1)
  Else
    #Last normal payday before the first complete day of sickness
    Filter [HRPEOD9] Where PERCOD = [L]VPERCOD and PYRDAT < STR1
    #Filter [HRPEOD9] Where PERCOD = [L]VPERCOD and PYRDAT <= STR1
    Read [HRPEOD9] Last
    Filter [HRPEOD9]
    If !fstat
    [L]ENDRELPER = [F:HRPEOD9]PYRDAT
    [L]STRRELPER = ([F:HRPEOD9]PYRDAT - [L]SSP_LINK_P)
    [L]STRRELPER+=1
   Endif

    #Last normal payday not falling less that 8 weeks before the end of the relevant period
  #  Local Date STRRELPER
  #  Filter [HRPEOD9] Where PERCOD = [L]VPERCOD and PYRDAT >= [L]ENDRELPER-56
  #  Read [HRPEOD9] First
  #  If !fstat
  #  [L]STRRELPER = [F:HRPEOD9]PYRDAT
  #  Endif
  #  Filter [HRPEOD9]
#MASHI - 2017-09-06 X3-53819 START
#    If [M:DCG1]AVEERN(nolign-1) = 0
    If [L]ENDRELPER=[0/0/0]
     Infbox "Missing Extraction Periods."
     mkstat=2
    Elsif [M:DCG1]AVEERN(nolign-1) = 0
#MASHI - 2017-09-06 X3-53819 END
     [M:DCG1]AVEERN(nolign-1) = func SSP_AVERAGE_EARNING([M:DCG1]REFNUM,[L]ENDRELPER)
     Affzo [M:DCG1]AVEERN(nolign-1)
    Endif
  Endif

  [M:DCG1]SSPRPSTR(nolign-1) = [L]STRRELPER     : Affzo [M:DCG1]SSPRPSTR(nolign-1)
  [M:DCG1]SSPRPEND(nolign-1) = [L]ENDRELPER     : Affzo [M:DCG1]SSPRPEND(nolign-1)
Return

Funprog SSP_AVERAGE_EARNING(EMPID,PAYDATE)
Value Char EMPID
Value Date PAYDATE
Local Decimal AMOUNT
Local Integer WEEKCOUNT
Local Integer PAYFRQ
Local Char EMPREF(20)
Local Integer STARTER
STARTER=0

  If clalev([HSP])=0 : Local File HISTOPAYE [HSP]  : Endif
  If clalev([HRCTR9])= 0  : Local File EMPLOCTR[HRCTR9] : Endif
  If clalev([F:HRPEOD9])=0 : Local File HRPEODET[HRPEOD9] : Endif
  If clalev([HRPEOH])= 0  : Local File HRPEOHEA[HRPEOH] : Endif
  #SAVAN 2018/02/19 - start _ open DCG again to check for last overidden AWE
  If clalev([DCGSSP])= 0  : Local File DEMCONGE[DCGSSP] : Endif
  #SAVAN 2018/02/19 - end  _ open DCG again to check for last overidden AWE
Local Char VPERCOD

  Filter [HRCTR9] Where CTRNUM = [M:DCG1]CTRNUM(nolign-1)
#  Filter [HRCTR9] Where [HRCTR9]REFNUM = EMPID
  Read [HRCTR9] First
  Filter [HRCTR9]
  If !fstat
    [L]VPERCOD = [F:HRCTR9]PERCOD
    Filter [HRPEOH] Where PERCOD = [HRCTR9]PERCOD and FLGENA = 2
    Read [HRPEOH] First
    Filter [HRPEOH]
    If !fstat
        [L]PAYFRQ = [HRPEOH]PAYFRQ
    Endif
  Endif

  Local Decimal SSP_LINK_P
  #SSP_LINK_P = 56
  [L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",[M:DCG1]STRDAT(nolign-1))
  #[L]SSP_LINK_P +=1

  Filter [F:HSP] Where EMP = EMPID and RUB = 'NAT_IN_MTD' and TYP = 6 and DAT < (PAYDATE - [L]SSP_LINK_P)
  Read [HSP] Last
  Filter [HSP]
  If !fstat
     STARTER = 0
  Else
     STARTER = 2
  Endif

  Filter [F:HRPEOD9] Where PERCOD = [L]VPERCOD and PYRDAT > (PAYDATE - [L]SSP_LINK_P) and PYRDAT <= PAYDATE
  Read [F:HRPEOD9] First
  If !fstat
    For [F:HRPEOD9]# Where PERCOD = [L]VPERCOD and PYRDAT > (PAYDATE - [L]SSP_LINK_P) and PYRDAT <= PAYDATE
    #  For [F:HSP] Where EMP = EMPID and RUB = 'NAT_IN_MTD' and TYP = 6 and DAT >= (PAYDATE - [L]SSP_LINK_P) and DAT <= PAYDATE
       Filter [F:HSP] Where EMP = EMPID and RUB = 'NAT_IN_MTD' and TYP = 6 and DAT = [F:HRPEOD9]PYRDAT
       Read [HSP] First
       Filter [HSP]
       If !fstat
          Case  [L]PAYFRQ
           When 1  # Weekly
             WEEKCOUNT += 1
             AMOUNT += [F:HSP]AMT
           When 2 # Bi-monthly
             WEEKCOUNT += 8
             AMOUNT += ([F:HSP]AMT * 6) / 13
           When 3 # Fortnightly
             WEEKCOUNT += 2
             AMOUNT += [F:HSP]AMT
           When 4 # 4 week
             WEEKCOUNT += 4
            AMOUNT += [F:HSP]AMT
           When 5 # Quarterly
             WEEKCOUNT += 8
             AMOUNT += ([F:HSP]AMT * 4) / 13 / 2
           When 6 # Monthly
             WEEKCOUNT += 4
             AMOUNT += ([F:HSP]AMT * 12) / 13
           When 7 # Annual
             WEEKCOUNT += 8
             AMOUNT += ([F:HSP]AMT * 4) / 13 / 6
           Endcase
       Else
         Case  [L]PAYFRQ
           When 1  # Weekly
             WEEKCOUNT += 1
           When 2 # Bi-monthly
             WEEKCOUNT += 8
           When 3 # Fortnightly
             WEEKCOUNT += 2
           When 4 # 4 week
             WEEKCOUNT += 4
           When 5 # Quarterly
             WEEKCOUNT += 8
           When 6 # Monthly
             WEEKCOUNT += 4
           When 7 # Annual
             WEEKCOUNT += 8
          Endcase
       Endif
    Next
  Else
    #TODO Add message as per X3 methodology
    #Confirm if we need to stop function at this point from Mark
    #Infbox 'No extraction period could be determined for the employee'
  Endif
  Filter [F:HRPEOD9]

  If WEEKCOUNT > 8 or STARTER = 0
    WEEKCOUNT = 8
  Endif
  If WEEKCOUNT <> 0
    AMOUNT = AMOUNT / WEEKCOUNT
    AMOUNT = fix((AMOUNT * 100000 + 0.99))   / 100000
  Endif
 #SAVAN 2018/02/19 - start AVERAGE TEST for 0 and taking the last one for override
# If AMOUNT=0
#  Filter [F:DCGSSP] Where [F:DCGSSP]STRDAT<=[M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P
#  Read [F:DCGSSP] Last
#   If !fstat
#    AMOUNT=[F:DCGSSP]AVEERN
#   Endif
#  Filter [F:DCGSSP]
# Endif
 #SAVAN 2018/02/19 - end AVERAGE TEST for 0 and taking the last one for override
End AMOUNT

#Funprog SSP_AVERAGE_EARNING(EMPID,PAYDATE)
#Value Char EMPID
#Value Date PAYDATE
#Local Decimal AMOUNT
#Local Integer WEEKCOUNT
#Local Integer PAYFRQ
#Local Char EMPREF(20)
#
#
#  If clalev([HSP])=0 : Local File HISTOPAYE [HSP]  : Endif
#  If clalev([HRCTR])= 0  : Local File EMPLOCTR[HRCTR] : Endif
#  If clalev([HRPEOH])= 0  : Local File HRPEOHEA[HRPEOH] : Endif
#
#  Local Decimal SSP_LINK_P
#  [L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",[M:DCG1]STRDAT(nolign-1))
#
#  For [F:HSP] Where EMP = EMPID and RUB = 'NAT_IN_MTD' and TYP = 6 and DAT >= (PAYDATE - [L]SSP_LINK_P) and DAT <= PAYDATE
#    Filter [HRCTR] Where REFNUM = [F:HSP]EMP  and CTRNUM = [F:HSP]CTRNUM
#    Read [HRCTR] First
#     If !fstat
#      [L]EMPREF=[F:HRCTR]REFNUM
#      Filter [HRPEOH] Where PERCOD = [HRCTR]PERCOD and FLGENA = 2
#      Read [HRPEOH] First
#      If !fstat
#          [L]PAYFRQ = [HRPEOH]PAYFRQ
#       Case  [HRPEOH]PAYFRQ
#       When 1  # Weekly
#         WEEKCOUNT += 1
#         AMOUNT += [F:HSP]AMT
#       When 2 # Bi-monthly
#         WEEKCOUNT += 8
#         AMOUNT += ([F:HSP]AMT * 6) / 13
#       When 3 # Fortnightly
#         WEEKCOUNT += 2
#         AMOUNT += [F:HSP]AMT
#       When 4 # 4 week
#         WEEKCOUNT += 4
#        AMOUNT += [F:HSP]AMT
#       When 5 # Quarterly
#         WEEKCOUNT += 8
#         AMOUNT += ([F:HSP]AMT * 4) / 13 / 2
#       When 6 # Monthly
#         WEEKCOUNT += 4
#         AMOUNT += ([F:HSP]AMT * 12) / 13
#       When 7 # Annual
#         WEEKCOUNT += 8
#         AMOUNT += ([F:HSP]AMT * 4) / 13 / 6
#       Endcase
#    Endif
#   Endif
#   Filter [HRCTR]
#  Next
#  Filter [HSP]
#  If WEEKCOUNT > 8
#    WEEKCOUNT = 8
#  Endif
#  If WEEKCOUNT <> 0
#   AMOUNT = AMOUNT / WEEKCOUNT
#   AMOUNT = fix((AMOUNT * 100 + 0.99))   / 100
#  Endif
#
#End AMOUNT

$SSPSTATWEK
Local Integer I
Local Integer J
Local Date SDAT
Local Decimal NBDAYS
Local Decimal NBHOURS
Local Integer WDAY
Local Integer SUBWDAY


  If [M:DCG1]SSPSTA(nolign-1) = 2
    If ([M]ENDDAT(nolign-1)-[M]STRDAT(nolign-1))/7 = fix(([M]ENDDAT(nolign-1)-[M]STRDAT(nolign-1))/7) and
&      fix(([M]ENDDAT(nolign-1)-[M]STRDAT(nolign-1))/7) > 0
      J = ([M]ENDDAT(nolign-1)-[M]STRDAT(nolign-1))/7
    Else
      J = fix(([M]ENDDAT(nolign-1)-[M]STRDAT(nolign-1))/7)+1
    Endif

    For L = 0 To 6
      If day$([M]STRDAT(nolign-1)+L) = "Saturday"
        SDAT =  ([M]STRDAT(nolign-1)+L)-6 : Break
      Endif
    Next

    K=1
    While SDAT < [M]ENDDAT(nolign-1)
      [M]WEKCOM(K-1) = SDAT
      [M]WEKEND(K-1) = SDAT+6
      If [M]STRDAT(nolign-1) > [M]WEKCOM(K-1)
          [M]LVERNGSTR(K-1) = [M]STRDAT(nolign-1)
      Else
        [M]LVERNGSTR(K-1) = [M]WEKCOM(K-1)
      Endif


      If [M]ENDDAT(nolign-1) > [M]WEKEND(K-1)
        [M]LVERNGEND(K-1) = [M]WEKEND(K-1)
      Else
        [M]LVERNGEND(K-1) = [M]ENDDAT(nolign-1)
      Endif

      Affzo [M]WEKCOM(K-1)
      Affzo [M]WEKEND(K-1)
      Affzo [M]LVERNGSTR(K-1)
      Affzo [M]LVERNGEND(K-1)
      [M]NBWEK = K
## PEVAN - 2018-04-25 - X3-74480x - START
#      Call VALORIS_L([M:DCG1]WEKCOM(K-1),[M:DCG1]WEKEND(K-1),[M:DCG1]REFNUM,[M:DCG1]TIM(nolign-1),NBDAYS,NBHOURS,[M:DCG1]FCY,[M:DCG1]CTRNUM(nolign-1)) From SUBACCRUAL
      Call VALORIS_L([M:DCG1]WEKCOM(K-1),[M:DCG1]WEKEND(K-1),[M:DCG1]REFNUM,[M:DCG1]TIM(nolign-1),NBDAYS,NBHOURS,[M:DCG1]FCY,[M:DCG1]CTRNUM(nolign-1),0,GCURLEG,[0/0/0]) From SUBACCRUAL
## PEVAN - 2018-04-25 - X3-74480 - END
      [M]WD1(K-1) = NBDAYS

## PEVAN - 2018-04-25 - X3-74480 - START
#      Call VALORIS_L([M:DCG1]LVERNGSTR(K-1),[M:DCG1]LVERNGEND(K-1),[M:DCG1]REFNUM,[M:DCG1]TIM(nolign-1),NBDAYS,NBHOURS,[M:DCG1]FCY,[M:DCG1]CTRNUM(nolign-1)) From SUBACCRUAL
      Call VALORIS_L([M:DCG1]LVERNGSTR(K-1),[M:DCG1]LVERNGEND(K-1),[M:DCG1]REFNUM,[M:DCG1]TIM(nolign-1),NBDAYS,NBHOURS,[M:DCG1]FCY,[M:DCG1]CTRNUM(nolign-1),0,GCURLEG,[0/0/0]) From SUBACCRUAL
## PEVAN - 2018-04-25 - X3-74480 - END
      [M]QD1(K-1) = NBDAYS

      #Get SSP weekly rate from legal variables
      Local Decimal SSP_WK_RT
      [L]SSP_WK_RT = func SUBDCGUKI.SETVARIABLE("SSP_WK_RT",[M:DCG1]STRDAT(nolign-1))
       If [L]SSP_WK_RT > 0 and [M]WD1(K-1) > 0
        [M]RPD(K-1) = func UK_FUNCTIONS.RNDSSP([L]SSP_WK_RT/[M]WD1(K-1))
      Endif

      Affzo [M]RPD(K-1)

      SDAT = SDAT+7
      K+=1
    Wend

    Gosub SSPWAIDAY

    Local Decimal SSP_WAIT_D
    SSP_WAIT_D = func SUBDCGUKI.SETVARIABLE("SSP_WAIT_D",[M:DCG1]STRDAT(nolign-1))
    SUBWDAY = SSP_WAIT_D-WDAY

    For I = 0 To [M]NBWEK
      If SUBWDAY > 0
        If SUBWDAY < [M]QD1(I)
            [M]WAIDAY1(I) = SUBWDAY
            SUBWDAY = 0
        Else
            [M]WAIDAY1(I) = [M]QD1(I)
            SUBWDAY = SUBWDAY-[M]QD1(I)
        Endif
      Else
        [M]WAIDAY1(I) = 0
      Endif

    #Paid days
    #If [M:DCG1]QUADAY(nolign-1) > 0
    [M:DCG1]PD1(I)=[M:DCG1]QD1(I)-[M:DCG1]WAIDAY1(I)
    #Endif

    Affzo [M:DCG1]PD1(I)
    Next

  Else

    Effzo [M:DCG1]NBWEK
    Effzo [M:DCG1]WEKCOM
    Effzo [M:DCG1]WEKEND
    Effzo [M:DCG1]WD1
    Effzo [M:DCG1]QD1
    Effzo [M:DCG1]WAIDAY1
    Effzo [M:DCG1]PD1
    Effzo [M:DCG1]RPD

  Endif

  Grizo [M:DCG1]NBWEK
  Grizo [M:DCG1]WEKCOM
  Grizo [M:DCG1]WEKEND
  Grizo [M:DCG1]WD1
  Grizo [M:DCG1]QD1
  Grizo [M:DCG1]WAIDAY1
  Grizo [M:DCG1]PD1
  Grizo [M:DCG1]RPD

  Affzo [M:DCG1]65

Return


$SSPWAIDAY
#Waiting days
Local Integer WDAY : WDAY = 0
Local Decimal SSP_LINK_P

  [L]SSP_LINK_P = func SUBDCGUKI.SETVARIABLE("SSP_LINK_P",[M:DCG1]STRDAT(nolign-1))
  [L]SSP_LINK_P += 1

  #Mask
#  For I = 0 To [M:DCG1]NBLIG
#    If I <> nolign-1
#        If [M:DCG1]SXPCAT = "SSP"
#          If [M:DCG1]UID(I) = 0 and [M:DCG1]ENDDAT(I) >= [M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P
#            WDAY += [M:DCG1]SSPWAIDAY(I)
#          Endif
#        Endif
#    Endif
#  Next

#  #Table
#  For [DCG] Where [DCG]REFNUM = [M:DCG1]REFNUM and [DCG]CTRNUM = [M:DCG1]CTRNUM(nolign-1) and [DCG]UID > 0 and [DCG]SXPCAT = "SSP"
#& and [DCG]SSPPIW = 2 and [DCG]ENDDAT >= ([M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P) and [DCG]STRDAT < [M:DCG1]STRDAT(nolign-1)  #Determine if
#  # any other
#  # SSP transactions within 56 days
#  WDAY += [DCG]SSPWAIDAY
#  Next

  Local Integer LNKUID1
  #Table

  If clalev([DCG_WD])= 0 : Local File DEMCONGE  [DCG_WD] : Endif
  Filter [DCG_WD] Where [DCG_WD]REFNUM = [M:DCG1]REFNUM and [DCG_WD]CTRNUM = [M:DCG1]CTRNUM(nolign-1) and [DCG_WD]UID > 0 and [DCG_WD]SXPCAT = "SSP"
& and [DCG_WD]SSPPIW = 2 and [DCG_WD]ENDDAT >= ([M:DCG1]STRDAT(nolign-1)-[L]SSP_LINK_P) and [DCG_WD]ENDDAT < [M:DCG1]STRDAT(nolign-1)

  Read [DCG_WD] First
  Filter [DCG_WD]

  If !fstat
    [L]LNKUID1 = [DCG_WD]LNKUID
    For [DCG] Where LNKUID = [L]LNKUID1 and UID>0 and ENDDAT < [M:DCG1]STRDAT(nolign-1)
      WDAY += [DCG]SSPWAIDAY
    Next
  Endif

Return

Funprog SSPACCRUAL

End


Subprog AVANT_NBLIG

  #ALHAR - 2017-10-05 X3-53821 START
  #If status <> 65
  #ALHAR - 2017-10-05 X3-53821 END

    Call SHOWHIDE(nolign-1) From SUBDCGUKI

    Local Char DES
    Call LECTEXTRA([L]DES,"ATABDIV","LNGDES","10408",[M:DCG1]SSPSTAREA(nolign-1)) From ATEXTRA : Affzo [M:DCG1]SSPEXC
    [M:DCG1]SSPEXC      = [L]DES                                                                   : Affzo [M:DCG1]SSPEXC
    [M:DCG1]CURPERSIC   = num$([M:DCG1]STRDAT(nolign-1))+" - "+num$([M:DCG1]ENDDAT(nolign-1))      : Affzo [M:DCG1]CURPERSIC
    [M:DCG1]PIW         = [M:DCG1]SSPPIW(nolign-1)                                                 : Affzo [M:DCG1]PIW
    [M:DCG1]LNKPIW      = [M:DCG1]SSPLNKPIW(nolign-1)                                              : Affzo [M:DCG1]LNKPIW
    [M:DCG1]WAIDAY      = [M:DCG1]SSPWAIDAY(nolign-1)                                              : Affzo [M:DCG1]WAIDAY
    [M:DCG1]PAIDAY      = [M:DCG1]SSPPAIDAY(nolign-1)                                              : Affzo [M:DCG1]PAIDAY
    [M:DCG1]RELPER      = num$([M:DCG1]SSPRPSTR(nolign-1))+" - "+num$([M:DCG1]SSPRPEND(nolign-1))  : Affzo [M:DCG1]RELPER
    [M:DCG1]SSPAVEERN   = [M:DCG1]AVEERN(nolign-1)                                                 : Affzo [M:DCG1]SSPAVEERN
    [M:DCG1]SSPELI       = [M:DCG1]SSPSTA(nolign-1)                                                : Affzo [M:DCG1]SSPELI
    #[M:DCG1]SSPEXC      = [M:DCG1]SSPSTAREA(nolign-1)

    Gosub SSPSTATWEK
    Gosub SHOWLNKPIW

  #ALHAR - 2017-10-05 X3-53821 START
#  Else
#    # After delete clear screen values
#    If dim([M:DCG1]CURPERSIC)>0   : Raz [M:DCG1]CURPERSIC   : Affzo [M:DCG1]CURPERSIC    : Endif
#    If dim([M:DCG1]PIW)>0         : Raz [M:DCG1]PIW         : Affzo [M:DCG1]PIW          : Endif
#    If dim([M:DCG1]LNKPIW)>0      : Raz [M:DCG1]LNKPIW      : Affzo [M:DCG1]LNKPIW       : Endif
#    If dim([M:DCG1]WAIDAY)>0      : Raz [M:DCG1]WAIDAY      : Affzo [M:DCG1]WAIDAY       : Endif
#    If dim([M:DCG1]PAIDAY)>0      : Raz [M:DCG1]PAIDAY      : Affzo [M:DCG1]PAIDAY       : Endif
#    If dim([M:DCG1]RELPER)>0      : Raz [M:DCG1]RELPER      : Affzo [M:DCG1]RELPER       : Endif
#    If dim([M:DCG1]SSPAVEERN)>0   : Raz [M:DCG1]SSPAVEERN   : Affzo [M:DCG1]SSPAVEERN    : Endif
#    If dim([M:DCG1]SSPELI)>0      : Raz [M:DCG1]SSPELI      : Affzo [M:DCG1]SSPELI       : Endif
#    # Clear Qualifying pattern grid
#    Raz [M]WEKCOM
#    Raz [M]WEKEND
#    Raz [M]LVERNGSTR
#    Raz [M]LVERNGEND
#    Raz [M]RPD
#    [M]NBWEK = 0
#    # Clear Linked PIW's grid
#    Raz [M:DCG1]PIWSTRDAT
#    Raz [M:DCG1]PIWENDDAT
#    Raz [M:DCG1]PIWELI
#    Raz [M:DCG1]PIWWAI
#    Raz [M:DCG1]PIWREA
#    [M:DCG1]NBPIW = 0
#    Affzo [M:DCG1]
#  Endif
#  #ALHAR - 2017-10-05 X3-53821 END

End

#JASMI - 2017-08-09 - START
Funprog SSP_SPLIT(DCG_ID, SUB_TYPE)
#parameters
Value Integer DCG_ID
Value Char SUB_TYPE
Local Decimal RESULT_STAT #return 1 = correct, 0 = error

#variables
Local Date TEMP_DATE, STAT_START, STAT_END
#JOJAC - 2017-08-21 - START
Local Integer DAY_DIFF, SUB_TYPE_INDEX, SUB_TYPE_INDEX2
#Local Integer DAY_DIFF, SUB_TYPE_INDEX
#JOJAC - 2017-08-21 - END
Local Decimal SUB_TYPE_DAYS, STAT_WORK_DAYS_IN_WEEK, STAT_LEAVE_DAYS_IN_WEEK, NBHOURS
Local Decimal DAYS_BEFORE_SUBTYPE : DAYS_BEFORE_SUBTYPE=0
Local Decimal LVESUBBAL(1..7) : [L]LVESUBBAL(1..7) = 0

  RESULT_STAT=1 #initialize to correct

  If clalev([F:HRLSTH_T]) = 0 : Local File HRLVESUBHEA [HRLSTH_T] Endif
  If clalev([F:DCG_T])=0      : Local File DEMCONGE    [DCG_T] : Endif
  If clalev([F:CTR_T])=0      : Local File EMPLOCTR    [CTR_T] : Endif

  #get entry of absense record
  Read [F:DCG_T]DCG2 = DCG_ID
  If fstat
    [L]RESULT_STAT=0
    End [L]RESULT_STAT
  Endif

  #get sub type record
  Read [F:HRLSTH_T]HRLST1 = SUB_TYPE
  If fstat
    [L]RESULT_STAT=0
    End [L]RESULT_STAT
  Endif

  #get latest contract before start of absense
  Filter [F:CTR_T] Where [F:CTR_T]REFNUM=[F:DCG_T]REFNUM & [F:CTR_T]CTRNUM=[F:DCG_T]CTRNUM
&                        & [F:CTR_T]CTRDAT<=[F:DCG_T]STRDAT
&                  Order By [F:CTR_T]CTRDAT
  Read [F:CTR_T] Last
  Filter [F:CTR_T]
  If fstat
    [L]RESULT_STAT=0
    End [L]RESULT_STAT
  Endif

  #check if sub type exist on entry and get index
  [L]SUB_TYPE_INDEX=find(SUB_TYPE,[F:DCG_T]LVESUBTYP(0..(dim([F:DCG_T]LVESUBTYP)-1)))
  If [L]SUB_TYPE_INDEX=0
    End [L]RESULT_STAT
  Endif

  [L]SUB_TYPE_DAYS=[F:DCG_T]LVESUBBAL([L]SUB_TYPE_INDEX-1) #set sub type days

  For I = 0 To [L]SUB_TYPE_INDEX-2 #up to the previous sub type
    [L]DAYS_BEFORE_SUBTYPE += [F:DCG_T]LVESUBBAL(I)
  Next I

  [L]TEMP_DATE=[F:DCG_T]STRDAT
  While [L]DAYS_BEFORE_SUBTYPE>0
    Call VALORIS([L]TEMP_DATE,[L]TEMP_DATE,[F:DCG_T]REFNUM,[F:DCG_T]TIM,[L]STAT_WORK_DAYS_IN_WEEK,NBHOURS,[F:CTR_T]ETRFCY,[F:DCG_T]CTRNUM) From SUBPLN
    If [L]STAT_WORK_DAYS_IN_WEEK<>0
      [L]DAYS_BEFORE_SUBTYPE-=1
    Endif
    [L]TEMP_DATE+=1
  Wend

  #calc days to start of first stat stat week
  Case dayn([L]TEMP_DATE)
  When 1,2,3,4,5,6
    [L]DAY_DIFF=dayn([L]TEMP_DATE)
  When Default
    [L]DAY_DIFF=0
  Endcase
  [L]STAT_START = [L]TEMP_DATE - [L]DAY_DIFF #set start of first stat week

  #JOJAC - 2017-08-21 - START
  Local Integer L : L=1
  #JOJAC - 2017-08-21 - END

  Raz [L]LVESUBBAL(1..7)

  While [L]SUB_TYPE_DAYS>0 #loop until all days are allocated
    [L]STAT_END = ([L]STAT_START+6) #set stat end

    #get number of work days in stat week
    Call VALORIS([L]STAT_START,[L]STAT_END,[F:DCG_T]REFNUM,[F:DCG_T]TIM,[L]STAT_WORK_DAYS_IN_WEEK,NBHOURS,[F:CTR_T]ETRFCY,[F:DCG_T]CTRNUM) From SUBPLN

    #get number of possible leave days in stat week
    If [L]TEMP_DATE<>[L]STAT_START
      Call VALORIS([L]TEMP_DATE,[L]STAT_END,[F:DCG_T]REFNUM,[F:DCG_T]TIM,[L]STAT_LEAVE_DAYS_IN_WEEK,NBHOURS,[F:CTR_T]ETRFCY,[F:DCG_T]CTRNUM) From SUBPLN
    Else
      [L]STAT_LEAVE_DAYS_IN_WEEK=[L]STAT_WORK_DAYS_IN_WEEK
    Endif

    If [L]STAT_LEAVE_DAYS_IN_WEEK<>0
    #JOJAC - 2017-08-31 - X3-15908 - START
    Case [L]STAT_WORK_DAYS_IN_WEEK
      When 1
        [L]LVESUBBAL(1) += min([L]SUB_TYPE_DAYS,[L]STAT_LEAVE_DAYS_IN_WEEK)
      When 2
        [L]LVESUBBAL(2) += min([L]SUB_TYPE_DAYS,[L]STAT_LEAVE_DAYS_IN_WEEK)
      When 3
        [L]LVESUBBAL(3) += min([L]SUB_TYPE_DAYS,[L]STAT_LEAVE_DAYS_IN_WEEK)
      When 4
        [L]LVESUBBAL(4) += min([L]SUB_TYPE_DAYS,[L]STAT_LEAVE_DAYS_IN_WEEK)
      When 5
        [L]LVESUBBAL(5) += min([L]SUB_TYPE_DAYS,[L]STAT_LEAVE_DAYS_IN_WEEK)
      When 6
        [L]LVESUBBAL(6) += min([L]SUB_TYPE_DAYS,[L]STAT_LEAVE_DAYS_IN_WEEK)
      When 7
        [L]LVESUBBAL(7) += min([L]SUB_TYPE_DAYS,[L]STAT_LEAVE_DAYS_IN_WEEK)
    Endcase

      #set sub split fields
#      #JOJAC - 2017-08-21 - START
#      If L=1
#        [F:DCG_T]LVESUBTYP([L]SUB_TYPE_INDEX-1)=SUB_TYPE
#        [F:DCG_T]LVESUBBAL([L]SUB_TYPE_INDEX-1)=min([L]SUB_TYPE_DAYS,[L]STAT_LEAVE_DAYS_IN_WEEK)
#        [F:DCG_T]LVESUBRAT([L]SUB_TYPE_INDEX-1)=[L]STAT_WORK_DAYS_IN_WEEK
#       Else
#        [L]SUB_TYPE_INDEX2=find("",[F:DCG_T]LVESUBTYP(0..(dim([F:DCG_T]LVESUBTYP)-1)))
#        [F:DCG_T]LVESUBTYP([L]SUB_TYPE_INDEX2-1)=SUB_TYPE
#        [F:DCG_T]LVESUBBAL([L]SUB_TYPE_INDEX2-1)=min([L]SUB_TYPE_DAYS,[L]STAT_LEAVE_DAYS_IN_WEEK)
#        [F:DCG_T]LVESUBRAT([L]SUB_TYPE_INDEX2-1)=[L]STAT_WORK_DAYS_IN_WEEK
#      Endif
#        #[F:DCG_T]LVESUBTYP([L]SUB_TYPE_INDEX-1)=SUB_TYPE
#        #[F:DCG_T]LVESUBBAL([L]SUB_TYPE_INDEX-1)=min([L]SUB_TYPE_DAYS,[L]STAT_LEAVE_DAYS_IN_WEEK)
#        #[F:DCG_T]LVESUBRAT([L]SUB_TYPE_INDEX-1)=[L]STAT_WORK_DAYS_IN_WEEK
#        #JOJAC - 2017-08-21 - END
#
#      #[L]SUB_TYPE_INDEX+=1 #next sub type index
#      #JOJAC - 2017-08-21 - START
#      L+=1
      #JOJAC - 2017-08-21 - END
      #JOJAC - 2017-08-31 - X3-15908 - END
      [L]SUB_TYPE_DAYS=[L]SUB_TYPE_DAYS-[L]STAT_LEAVE_DAYS_IN_WEEK #reduce taken days
    Endif

    [L]STAT_START+=7 #set start of next stat week
    [L]TEMP_DATE=[L]STAT_START #after first week, starts are alligned

  Wend

  #JOJAC - 2017-08-31 - X3-15908 - START
  Local Integer A : A=0
  For L = 1 To 7
    If [L]LVESUBBAL(L) <> 0
      #JOJAC - 2017-10-19 - X3-15908 - START
      #If [M:DCG1]SSPPRO(nolign-1) = 2
      If [F:DCG_T]SSPPRO = 2
      #JOJAC - 2017-10-19 - X3-15908 - END
        A+=1
          If A=1
            [F:DCG_T]LVESUBTYP([L]SUB_TYPE_INDEX-1)=SUB_TYPE
            [F:DCG_T]LVESUBBAL([L]SUB_TYPE_INDEX-1)=[L]LVESUBBAL(L)
            [F:DCG_T]LVESUBRAT([L]SUB_TYPE_INDEX-1)=L
            Assign "[M:DCG1]LVESUBRAT" + num$([L]SUB_TYPE_INDEX-1) + "(" + num$(GPARENT_NOLIGN) + ")" With L
           Else
            [L]SUB_TYPE_INDEX2=find("",[F:DCG_T]LVESUBTYP(0..(dim([F:DCG_T]LVESUBTYP)-1)))
            [F:DCG_T]LVESUBTYP([L]SUB_TYPE_INDEX2-1)=SUB_TYPE
            [F:DCG_T]LVESUBBAL([L]SUB_TYPE_INDEX2-1)=[L]LVESUBBAL(L)
            [F:DCG_T]LVESUBRAT([L]SUB_TYPE_INDEX2-1)=L
            Assign "[M:DCG1]LVESUBRAT" + num$([L]SUB_TYPE_INDEX2-1) + "(" + num$(GPARENT_NOLIGN) + ")" With L
          Endif
      Else
        [F:DCG_T]LVESUBTYP([L]SUB_TYPE_INDEX-1)=SUB_TYPE
        [F:DCG_T]LVESUBBAL([L]SUB_TYPE_INDEX-1)=[L]LVESUBBAL(L)
        [F:DCG_T]LVESUBRAT([L]SUB_TYPE_INDEX-1)=8
        Assign "[M:DCG1]LVESUBRAT" + num$([L]SUB_TYPE_INDEX-1) + "(" + num$(GPARENT_NOLIGN) + ")" With L
      Endif
    Endif
  Next
  #JOJAC - 2017-08-31 - X3-15908 - END

  Rewrite [F:DCG_T]
  If fstat
    [L]RESULT_STAT=0
    End [L]RESULT_STAT
  Endif

End RESULT_STAT
#JASMI - 2017-08-09 - END

Subprog C_SSPSTA(VALEUR)
Variable Integer    VALEUR()
Local Integer RESULT
Local Integer SSPSTA()

#If VALEUR = [M:DCG1]SSPSTA(nolign-1) : End : Endif

[L]SSPSTA = VALEUR
If [L]SSPSTA = 2
  Grizo [M:DCG1]SSPSTAREA(nolign-1)
Else
  Actzo [M:DCG1]SSPSTAREA(nolign-1)
Endif

If [M:DCG1]SXPCAT(nolign-1) = "SSP"
  Gosub SSPWAIDAY From SUBDCGSSP
  Gosub SSPQUADAY From SUBDCGSSP     #SSP Qualyfying days
  #Gosub SSPRELPER From SUBDCGSSP     #SSP Relevant Period
  #Gosub SSPSTATWEK From SUBDCGSSP    #Statutory weeks=
  #Populate daughter grids
  Call AVANT_NBLIG
Endif

End

Subprog AM_TIM(VALEUR)
Variable Char    VALEUR()
Local Date SSPSTR
Local Date SSPEND
#SAVAN - 2018/03/02 - IS_CONSECUTIVE_ABSENCE - Concurrent transactions to combined tranasactions for ease of use. - start
#**
#* Function to determine if a particular start date will be consecutive with an existing absence for the employee/contract
#* function params --> IS_CONSECUTIVE_ABSENCE(EMPLOYEE, CONTRACT, CONTRACT_DATE,ABSENCE_TYPE, ABSENCE_START_DATE)
#*!
# | GUSER="ANBEE")
  Local Integer CONC_UID
  #If clalev([F:HRCTR_CC])=0  : Local File EMPLOCTR  [HRCTR_CC]  : Endif
  #Filter [HRCTR9] Where CTRNUM = [M:DCG1]CTRNUM(nolign-1)
  #Filter [HRCTR_CC] Where [HRCTR_CC]CTRNUM = [M:DCG1]CTRNUM(nolign-1)
  #Read [HRCTR_CC] First
  CONC_UID = func SUBDCGGLM.IS_CONSECUTIVE_ABSENCE([M:DCG1]REFNUM,[M:DCG1]CTRNUM(nolign-1),"SSP",[M:DCG1]STRDAT(nolign-1),[M:DCG1]ENDDAT(nolign-1))
  #**
  #* From here populate the THISLEAVEDAT with the STRDAT from the UID found that is concurrent
  #*!
#  If GUSER="SAVAN"
#    Infbox "[HRCTR_CC]CTRDAT" - num$([HRCTR_CC]CTRDAT) - "[M:DCG1]CTRNUM(nolign-1) " - num$([M:DCG1]CTRNUM(nolign-1)) - "CONC_UID "-num$(CONC_UID) - " [M:DCG1]STRDAT(nolign-1)" - num$([M:DCG1]STRDAT(
#& nolign-1))
#     Endif
   If CONC_UID>0
     If clalev([F:CONCDCG])=0    : Local File DEMCONGE [CONCDCG]         : Endif
     Read [CONCDCG]DCG2 = CONC_UID
     If  ([CONCDCG]NBRDAY<4) | ([M:DCG1]NBRDAY(nolign-1)<4)
    #   [L]THISLEAVEDATE = [F:CONCDCG]STRDAT
    #   Call VALORIS_L([L]THISLEAVEDATE,[F:DCG]ENDDAT,[F:DCG]REFNUM,[F:DCG]TIM,[L]THISLEAVEDAYS,[L]THISLEAVEHOURS,[FCYT]FCY,[F:DCG]CTRNUM) From SUBACCRUAL
    #   [F:DCG]STRDAT=[F:CONCDCG]STRDAT
    #   #SAVAN - 2018/03/02 - Cancelled accepte status on previous "linked" record - start
    #   [F:DCG]NBRDAY=[L]THISLEAVEDAYS
    #   [F:DCG]NBRHOU=[L]THISLEAVEHOURS
    #   Update [CONCDCG] Where [CONCDCG]UID=CONC_UID With STA=6
    #   Affzo [M:DCG1]STA
        Call ERREUR(mess(23,11828,1) - " " - mess(22,11828,1) - num$([F:CONCDCG]STRDAT) - " to " - num$([F:CONCDCG]ENDDAT)) From GESECRAN
        #GERR = 1 :  GMESSAGE = mess(23,11828,1) - " " - mess(22,11828,1) - num$([F:CONCDCG]STRDAT) - " to " - num$([F:CONCDCG]ENDDAT) : mkstat = 2 : End
        mkstat = 2
        GOK=0
        End
      Endif
    Endif
  [L]SSPSTR = [M:DCG1]STRDAT(nolign-1)
  [L]SSPEND = [M:DCG1]ENDDAT(nolign-1)

  Gosub CHECKSAVESTATUS From SUBDCGSSP
  Gosub SSPPIW From SUBDCGSSP        #SSP PIW
  Gosub SSPLNKPIW From SUBDCGSSP     #SSP Link PIW
  Gosub PREVLNKPIW From SUBDCGSSP
  Gosub SSPRELPER From SUBDCGSSP     #SSP Relevant Period
  Gosub SSPELI_AWE From SUBDCGSSP     #Average Earnings

  Call AVANT_NBLIG

  zonsui = "[M:DCG1]SSPSTA(nolign-1)"

End

Subprog C_AVEERN(VALEUR)
Local Decimal SSP_MAWE
Local Integer WRET

#If VALEUR = [M:DCG1]AVEERN(nolign-1) : End : Endif

  If VALEUR <> [M:DCG1]AVEERN(nolign-1)
    [L]SSP_MAWE = func SUBDCGUKI.SETVARIABLE("SSP_MAWE",[M:DCG1]STRDAT(nolign-1))
    If VALEUR < [L]SSP_MAWE
      [M:DCG1]SSPSTA(nolign-1) = 1      : Affzo [M:DCG1]SSPSTA(nolign-1)
      [M:DCG1]SSPSTAREA(nolign-1) = "E" : Affzo [M:DCG1]SSPSTAREA(nolign-1)
      zonsui = "[M:DCG1]SSPSTAREA(nolign-1)"
    Else
      [M:DCG1]SSPSTA(nolign-1) = 2      : Affzo [M:DCG1]SSPSTA(nolign-1)
      Raz [M:DCG1]SSPSTAREA(nolign-1)   : Affzo [M:DCG1]SSPSTAREA(nolign-1)
      zonsui = "[M:DCG1]SSPSTAREA(nolign-1)"
      #ALHAR - 2018-02-26 - X3-78515 - Start
      Local Date SSPSTR
      Local Date SSPEND
      Gosub SSPPIW From SUBDCGSSP #SSP PIW
      #ALHAR - 2018-02-26 - X3-78515 - End

    Endif
  Endif

  Affzo [M:DCG1]30

  Local Integer SSPSTA()
  [L]SSPSTA = [M:DCG1]SSPSTA(nolign-1)
  If [L]SSPSTA = 2
    Grizo [M:DCG1]SSPSTAREA(nolign-1)
  Else
    Actzo [M:DCG1]SSPSTAREA(nolign-1)
  Endif

  If [M:DCG1]SXPCAT(nolign-1) = "SSP"
    Gosub SSPWAIDAY From SUBDCGSSP
    Gosub SSPQUADAY From SUBDCGSSP     #SSP Qualyfying days
  Endif

  #JOJAC - 2017-11-01 - X3-62400 - START
  [M:DCG1]AVEERN(nolign-1) = VALEUR
  Affzo [M:DCG1]AVEERN(nolign-1)
  Call AVANT_NBLIG
  #JOJAC - 2017-11-01 - X3-62400 - END
  #ANCOA - X3-77322 - 21/02/2018 - Start
    Call UPDATE_LINKED_AWE([M:DCG1]LNKUID(nolign-1),[M:DCG1]UID(nolign-1),[M:DCG1]AVEERN(nolign-1))
  #ANCOA - X3-77322 - 21/02/2018 - End
End

Subprog SHOWHIDESSP(WSIGN)
Value Char WSIGN

#  Chgfmt [M:DCG1]SSPSTA         With WSIGN+"LA:1"
#MASHI - 2017-09-08 X3-47523 START
#  Chgfmt [M:DCG1]SSPSTAREA      With WSIGN+"K:30"
#MASHI - 2017-09-08 X3-47523 END
  #Chgfmt [M:DCG1]SSPLNKPIW      With WSIGN+"LA:1"
  Chgfmt [M:DCG1]SSPPIW         With WSIGN+"LA:1"
  Chgfmt [M:DCG1]SSPWAIDAY      With WSIGN+"N:4"
  Chgfmt [M:DCG1]SSPQUADAY      With WSIGN+"N:4"
  Chgfmt [M:DCG1]SSPPAIDAY      With WSIGN+"N:4"
  Chgfmt [M:DCG1]SSPRPSTR       With WSIGN+"D:"+GFMDAT4
  Chgfmt [M:DCG1]SSPRPEND       With WSIGN+"D:"+GFMDAT4
  Chgfmt [M:DCG1]SSPCER         With WSIGN+"K:1X"
#MASHI - 2017-10-05 X3-53788 START
#  Chgfmt [M:DCG1]SSPREA         With WSIGN+"K:30X"
  Chgfmt [M:DCG1]SSPREA         With "-K:30X"
#MASHI - 2017-10-05 X3-53788 START
  Chgfmt [M:DCG1]SSPEXC         With WSIGN+"K:250X"
  Chgfmt [M:DCG1]CURPERSIC      With WSIGN+"K:30X"
  Chgfmt [M:DCG1]PIW            With WSIGN+"K:30X"
  Chgfmt [M:DCG1]LNKPIW         With WSIGN+"LA:1"
  Chgfmt [M:DCG1]WAIDAY         With WSIGN+"N:4"
  Chgfmt [M:DCG1]PAIDAY         With WSIGN+"N:4"
  Chgfmt [M:DCG1]RELPER         With WSIGN+"K:30X"
  Chgfmt [M:DCG1]SSPAVEERN      With WSIGN+"Nz:9.5"
  Chgfmt [M:DCG1]SSPELI         With WSIGN+"LA:1"
  Chgfmt [M:DCG1]NBWEK          With WSIGN+"N:4"
  Chgfmt [M:DCG1]WEKCOM         With WSIGN+"D:"+GFMDAT4
  Chgfmt [M:DCG1]WEKEND         With WSIGN+"D:"+GFMDAT4
  Chgfmt [M:DCG1]LVERNGSTR      With WSIGN+"D:"+GFMDAT4
  Chgfmt [M:DCG1]LVERNGEND      With WSIGN+"D:"+GFMDAT4
  Chgfmt [M:DCG1]WD1            With WSIGN+"N:4"
  Chgfmt [M:DCG1]QD1            With WSIGN+"N:4"
  Chgfmt [M:DCG1]WAIDAY1        With WSIGN+"N:4"
  Chgfmt [M:DCG1]PD1            With WSIGN+"N:4"
  Chgfmt [M:DCG1]RPD            With WSIGN+"N:4.2"
  Chgfmt [M:DCG1]SSPPRO         With WSIGN+"LA:1"
#MASHI - 2017-09-08 X3-47523 START
  Chgfmt [M:DCG1]NBPIW          With WSIGN+"K:20X"
#MASHI - 2017-09-08 X3-47523 END


  #TODO - Check average earnings column
  Chgfmt [M:DCG1]AVEERN         With WSIGN+"Nz:9.5"
#MASHI - 2017-09-08 X3-47523 END

  Chgfmt [M:DCG1]PIWSTRDAT             With WSIGN+"D:"+GFMDAT4
  Chgfmt [M:DCG1]PIWENDDAT             With WSIGN+"D:"+GFMDAT4
  Chgfmt [M:DCG1]PIWELI                With WSIGN+"LA:1"
  Chgfmt [M:DCG1]PIWWAI                With WSIGN+"N:4"
  Chgfmt [M:DCG1]PIWREA                With WSIGN+"K:30"

  #ALHAR - 2017-09-14 X3-47501 START
  Chgfmt [M:DCG1]SSPPRO                With WSIGN+"LA:1"
  #ALHAR - 2017-09-14 X3-47501 END
  Chgfmt [M:DCG1]SSPSTA                With WSIGN+"LA:1"

  #ALHAR - 2017-11-22 X3-64134 START
  #Chgfmt [M:DCG1]SSPSTAREA             With WSIGN+"K:20"
  Chgfmt [M:DCG1]SSPSTAREA             With WSIGN+"K:20"
  #ALHAR - 2017-11-22 X3-64134 END

  #Chgfmt [M:DCG1]SSPSTAREA             With WSIGN+"K:20"
  Chgfmt [M:DCG1]SSPRPSTR              With WSIGN+"D:"+GFMDAT4
  #MASHI - 2018-02-09 X3-76141 START
  If WSIGN = ""
    [M:DCG1]SSPELI = 2
  #ALHAR - 2018-03-05 X3-81097 START
  #[M:DCG1]SSPPRO = 2
  If [M:DCG1]SSPPRO <> 1
    [M:DCG1]SSPPRO = 2
  Endif
  #ALHAR - 2018-03-05 X3-81097 END
    Affzo [M:DCG1]SSPELI
    Affzo [M:DCG1]SSPPRO
  Endif
#MASHI - 2018-02-09 X3-76141 END
End


$CHECKSAVESTATUS
Local Integer K

  For K = 0 To [M:DCG1]NBLIG
    If K <> nolign-1
      If [M:DCG1]UID(K) = 0 and [M:DCG1]SXPCAT(K) = 'SSP'
        #TODO
        Infbox "You have unsaved SSP transactions on the grid - please save grid before entering new SSP transactions"
        #mkstat = 2
      Endif
    Endif
  Next

Return


