#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTICPT13   Pyramide FIRST                                 Module CPT   #
#            Pyramide crée lors de la migration V6 (compte de cumuls V5) #  
#            Ré-initialise le RANG                                       #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTICPT13(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT13(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTICPT13 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:GRY])  =0  Local File =DOSSIER+".GACCGRUPYM"   [GRY] : Endif
Filter [GRY] Where PYM="FIRST"
If !rowcount([GRY]) : Goto FIN : Endif

Local Integer RANG
Local Integer NBNIV : NBNIV = GLONGRY

Raz COMPTEUR
Call DEBTRANS From GLOCK
 

Trbegin [GRY]

For I=0 To NBNIV
 
 Filter [GRY] Where PYM="FIRST" and len(GRU)=I
 RANG=10
 For [GRY]GRY0(2)

  For [GRY]GRY0
   Readlock [GRY] Curr    
   If !fstat
    # --- alimentation des champs et réécriture enreg
    [F:GRY]PRNROW = RANG
    Rewrite [F:GRY]
    If !fstat COMPTEUR += 1 Endif
   Endif
  Next
  RANG+=10
 Next
Next
Commit
Close Local File [GRY]

$FIN
Call ECR_TRACE("UTICPT13 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : ENDIF
If filinfo(filpath("FIL","GACCGRUPYM","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTICPT13(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If filinfo(filpath("FIL","GACCGRUPYM","fde",APPLI),0)<=0 : End : Endif   
Call MAJ_UTICPT13(APPLI)
End


