######################################################################################################
# Module        : Common data
# Description   : Library for waste disposal management
######################################################################################################
# Updates       :
# Date          | Author | Version | Description
# 2017-01-31    | Bader  | U11_03  | remove parameters PSTRDAT and PENDDAT from ACTIVE_ITEM
# 2017-02-10    | Bader  | U11_03  | EXCLUDE_BP: Filter was wrong (<= instead of >= and vice versa)
######################################################################################################

Local Char TESTSCMCOD(30)
Local Char TESTMSG(250)
Local Integer TESTSTA
Local Date TESTSTRDAT, TESTENDDAT
TESTSCMCOD = "ARA_VHAT2"
TESTSTRDAT = [01/01/2017]
TESTENDDAT = [31/12/2017]
TESTSTA    = 0
TESTMSG    = ""
#Dbgaff
If func DMW_EXIST(TESTSCMCOD,TESTSTRDAT,TESTENDDAT)
    Call DMW_DELETE(TESTSCMCOD,TESTSTRDAT,TESTENDDAT,TESTSTA,TESTMSG)
Endif
Call DMW_CALCULATE(TESTSCMCOD,TESTSTRDAT,TESTENDDAT,TESTSTA,TESTMSG)
End

#**
#* Purpose: Create waste disposal data for a scheme (referencing a company) and a period
#*
#* @param PSCMCOD      Waste disposal scheme to use
#* @param PSTRDAT      Date from
#* @param PENDDAT      Date to
#* @param PSTA         status of data creation 0 : OK, 1 : scheme not found, 3 : various.
#* @param PMSG         Message corresponding to status.
#*!
Subprog DMW_CALCULATE(PSCMCOD,PSTRDAT,PENDDAT,PSTA,PMSG)
Value Char PSCMCOD     # Waste disposal scheme to use
Value Date PSTRDAT     # Date from
Value Date PENDDAT     # Date to
Variable Integer PSTA  # status of data creation 0 : OK, 1 : scheme not found, 3 : various
Variable Char PMSG     # Message corresponding to status

PSTA = 0
Gosub INIT

Read [F:DMWSC]DMWSC0 = PSCMCOD  # read scheme
If !fstat
    Filter [F:FCY] Where LEGCPY = [F:DMWSC]CPY   # find all sites of company for loop over STOJOU
    For [F:FCY]                                  # loop over STOJOU for each site of the company
        Gosub HANDLE_FCY
    Next
    Filter [F:FCY]
Else
    PSTA = 1
    PMSG = PSCMCOD - mess(1,7707,1) # 'Waste disposal scheme not found'
Endif
End


######################################################################################################
$INIT
If !clalev ([F:DMWSC])     : Local File DMWSCHEME [DMWSC]      : Endif
If !clalev ([F:DMWPPAD])   : Local File DMWPRODPACKD [DMWPPAD] : Endif
If !clalev ([F:DMWPPAH])   : Local File DMWPRODPACKH [DMWPPAH] : Endif
If !clalev ([F:DMWQTY])    : Local File DMWQTY [DMWQTY]        : Endif
If !clalev ([F:DMWWEI])    : Local File DMWWEIGHT [DMWWEI]     : Endif
If !clalev ([F:DMWBPE])    : Local File DMWBPREXC [DMWBPE]     : Endif
If !clalev ([F:FACILITY])  : Local File FACILITY [FCY]         : Endif
If !clalev ([F:STJ])       : Local File STOJOU [STJ]           : Endif
If !clalev ([F:SDH])       : Local File SDELIVERY [SDH]        : Endif
If !clalev ([F:SIV])       : Local File SINVOICEV [SIV]        : Endif
Return


######################################################################################################
# Loop over stock journal (STOJOU) for a facility:
# All journal entries with TRSTYP = 4 (Customer delivery) or 12 (Shipment return, only if there is a reference to a previous shipment
# in field VCRNUMORI) are taken into account if they are in the given date range.
# For each journal entry it is checked if a waste disposal has to be done or omitted for the customer.
# If disposal has to be done and the delivery was sent to the country of the waste disposal scheme,
# and the product has to be disposed, a record with the corresponding quantity is created in table DMWQTY.
# Additionally records are created in DMWWEIGHT for each packing material of the delivered product
######################################################################################################
$HANDLE_FCY
Local Char DOCNUM(GLONVCR)
Local Char SCRY(GLONCRY), DCRY(GLONCRY)
Local Integer FOUND
Local Char BPR(GLONBPR)

Filter [F:STJ] Where STOFCY = [F:FCY]FCY and UPDCOD = 2 and IPTDAT >= PSTRDAT and IPTDAT <= PENDDAT and
& (TRSTYP = 4 or (TRSTYP = 12 and VCRNUMORI <> ""))
For [F:STJ]
  If !func EXCLUDE_BP(PSCMCOD,PSTRDAT,PENDDAT,[F:STJ]BPRNUM) # check if disposal has to be done for customer
    If func ACTIVE_ITEM(PSCMCOD,[F:STJ]ITMREF,[F:STJ]IPTDAT) # check if item is active for dispensation
        If [F:STJ]TRSTYP = 4                          # transaction type = Customer delivery
          DOCNUM = [F:STJ]VCRNUM
          If [F:STJ]VCRTYP = 4                        # document type = Delivery
              Read [F:SDH]SDH0 = DOCNUM               # read header of delivery note
              FOUND = !fstat
              If FOUND
                DCRY = [F:SDH]BPDCRY                  # country of delivery address
                BPR  = [F:SDH]BPCORD                  # Customer
              Endif
          Elsif [F:STJ]VCRTYP = 5                     # document type = Sales invoice
              Read [F:SIV]SIV0 = DOCNUM               # read SINVOICEV for invoice
              FOUND = !fstat
              If FOUND
                DCRY = [F:SIV]BPDCRY                  # country of delivery address
                BPR  = [F:SIV]BPCORD                  # Customer
              Endif
          Endif
        Elsif [F:STJ]TRSTYP = 12                      # transaction type = Shipment return
          DOCNUM = [F:STJ]VCRNUMORI
          Read [F:SDH]SDH0 = DOCNUM                   # read header of original delivery note
          FOUND = !fstat
          If FOUND
            DCRY = [F:SDH]BPDCRY                      # country of delivery address
            BPR  = [F:SDH]BPCORD                      # Customer
          Endif
        Endif
        If FOUND
            Case [F:DMWSC]CRY
                When 1 : SCRY = "DE"
                When 2 : SCRY = "AT"
                When Default : Raz DCRY
            Endcase
            If DCRY = SCRY                            # check if country equals the scheme country, otherwise nothing to do
                Gosub CREATE_QTY_RECORD               # create record in quantity table
                If !PSTA                              # Everything OK?
                    Gosub CREATE_WEIGHT_RECORDS       # create records in weight table
                Endif
            Endif
        Else
            PSTA = 3
            PMSG = PSCMCOD - mess(239,192,1) - DOCNUM
            Break
        Endif
    Endif
  Endif
Next
Filter [F:STJ]
Return


######################################################################################################
# Checks in table of BP exceptions for scheme, if customer is excluded from disposal in the given period
######################################################################################################
Funprog EXCLUDE_BP(PSCMCOD,PSTRDAT,PENDDAT,PBPR)
Value Char PSCMCOD     # Waste disposal scheme to use
Value Date PSTRDAT     # Date from
Value Date PENDDAT     # Date to
Value Char PBPR        # Customer
If [F:DMWBPE]BPR = PBPR : End 1 : Endif   # BP found before? Yes -> BP excluded
Filter [F:DMWBPE] Where BPR = PBPR and SCMCOD = PSCMCOD and  STRDAT <= PSTRDAT and (ENDDAT >= PENDDAT or ENDDAT = [0/0/0])
Read [F:DMWBPE] First
If !fstat : End 1 : Endif                 # BP found -> BP excluded
End 0


######################################################################################################
# checks if the product is active for dispensation
######################################################################################################
Funprog ACTIVE_ITEM(PSCMCOD,PITMREF,PIPTDAT)
Value Char PSCMCOD     # Waste disposal scheme to use
Value Char PITMREF     # product
Value Date PIPTDAT     # transaction date
Filter [F:DMWPPAH] Where SCMCOD = PSCMCOD and ITMREF = PITMREF and STRDAT <= PIPTDAT and (ENDDAT >= PIPTDAT or ENDDAT = [0/0/0])
Read [F:DMWPPAH] First
Filter [F:DMWPPAH]
If !fstat : End 1 : Endif
End 0


######################################################################################################
# Creates a record in the quantity table for the scheme and product and document
######################################################################################################
$CREATE_QTY_RECORD
Raz [F:DMWQTY]
[F:DMWQTY]SCMCOD       = PSCMCOD
[F:DMWQTY]ITMREF       = [F:STJ]ITMREF
[F:DMWQTY]TRSTYP       = [F:STJ]TRSTYP
If [F:STJ]TRSTYP = 4                          # shipment
  [F:DMWQTY]VCRNUM       = [F:STJ]VCRNUM      # -> no reference of return
Elsif [F:STJ]TRSTYP = 12                      # return
  [F:DMWQTY]VCRNUM       = [F:STJ]VCRNUMORI   # document = original shipment number
  [F:DMWQTY]VCRNUMRET    = [F:STJ]VCRNUM      # number of corresponding return document
Endif
[F:DMWQTY]QTYSTU       = -[F:STJ]QTYSTU
[F:DMWQTY]STOFCY       = [F:STJ]STOFCY
[F:DMWQTY]IPTDAT       = [F:STJ]IPTDAT
[F:DMWQTY]MVTSEQ       = [F:STJ]MVTSEQ
[F:DMWQTY]MVTIND       = [F:STJ]MVTIND
Write [F:DMWQTY]
If fstat
    PSTA = 3
    PMSG = PSCMCOD - mess(40,9014,1) - "[F:DMWQTY]! fstat="+num$(fstat)
Endif
Return


######################################################################################################
# Create records in the weight table for the scheme and product and document for each packing material
######################################################################################################
$CREATE_WEIGHT_RECORDS
Raz [F:DMWWEI]
# check if a product packaging assigment exists
Filter [F:DMWPPAH] Where SCMCOD = PSCMCOD and ITMREF = [F:STJ]ITMREF and STRDAT <= [F:STJ]IPTDAT and (ENDDAT >= [F:STJ]IPTDAT or ENDDAT = [0/0/0])
Read [F:DMWPPAH] First
Filter [F:DMWPPAH]
If !fstat
    [F:DMWWEI]SCMCOD       = PSCMCOD
    [F:DMWWEI]ITMREF       = [F:STJ]ITMREF
    [F:DMWWEI]VCRNUM       = [F:DMWQTY]VCRNUM
    [F:DMWWEI]VCRNUMRET    = [F:DMWQTY]VCRNUMRET
    [F:DMWWEI]IPTDAT       = [F:STJ]IPTDAT
    [F:DMWWEI]BPR          = BPR
    # loop over all packing materials of the product and calculate weight
    Filter [F:DMWPPAD] Where PKGNUM = [F:DMWPPAH]PKGNUM
    For [F:DMWPPAD]
        If [F:DMWPPAD]FLGPKG = 2      # packing material to be disposed?
            [F:DMWWEI]ITMWEI = [F:DMWQTY]QTYSTU * [F:DMWPPAD]ITMWEI
            Call QTEARR([F:DMWWEI]ITMWEI, [F:DMWPPAD]STU) From TRTDIV # rounding
            [F:DMWWEI]WEU          = [F:DMWPPAD]STU
            [F:DMWWEI]PKGMAT       = [F:DMWPPAD]PKGMAT
            [F:DMWWEI]PKGSIZ       = [F:DMWPPAD]PKGSIZ
            [F:DMWWEI]TAFCAT       = [F:DMWPPAD]TAFCAT
            [F:DMWWEI]ITMGRP       = [F:DMWPPAD]ITMGRP
            Write [F:DMWWEI]
            If fstat
                PSTA = 3
                PMSG = PSCMCOD - mess(40,9014,1) - "[F:DMWWEI]! fstat="+num$(fstat)
                Break
            Endif
        Endif
    Next
Else
    PMSG = PSCMCOD - func AFNC.MES1(mess(2,7707,1),[F:STJ]ITMREF) # 'No product packaging assignment found for product $1$.'
Endif
Return


#**
#* Purpose: Delete waste disposal data for a scheme and a period
#*
#* @param PSCMCOD      Waste disposal scheme to use
#* @param PSTRDAT      Date from
#* @param PENDDAT      Date to
#* @param PSTA         status of data creation 0 : OK, 1 : scheme not found, 3 : various.
#* @param PMSG         Message corresponding to status.
#*!
Subprog DMW_DELETE(PSCMCOD,PSTRDAT,PENDDAT,PSTA,PMSG)
Value Char PSCMCOD     # Waste disposal scheme to use
Value Date PSTRDAT     # Date from
Value Date PENDDAT     # Date to
Variable Integer PSTA  # status of data deletion 0 : OK, 1 : scheme not found, 3 : various
Variable Char PMSG     # Message corresponding to status

PSTA = 0
Gosub INIT

Read [F:DMWSC]DMWSC0 = PSCMCOD  # read scheme
If !fstat
    # Delete all records of scheme from weight table for given period
    Delete [F:DMWWEI] Where SCMCOD = PSCMCOD and IPTDAT >= PSTRDAT and IPTDAT <= PENDDAT
    If !fstat
        # Delete all records of scheme from quantity table for given period
        Delete [F:DMWQTY] Where SCMCOD = PSCMCOD and IPTDAT >= PSTRDAT and IPTDAT <= PENDDAT
        If fstat
            PSTA = 3
            PMSG = PSCMCOD - mess(40,9014,1) - "[F:DMWQTY]! fstat="+num$(fstat)
        Endif
    Else
        PSTA = 3
        PMSG = PSCMCOD - mess(40,9014,1) - "[F:DMWWEI]! fstat="+num$(fstat)
    Endif
Else
    PSTA = 1
    PMSG = PSCMCOD - mess(1,7707,1) # 'Waste disposal scheme not found'
Endif
End


#**
#* Purpose: Check if waste disposal data exist for a scheme and a period
#*
#* @param PSCMCOD      Waste disposal scheme to use
#* @param PSTRDAT      Date from
#* @param PENDDAT      Date to
#* @return decimal: 1 -> data exist for period; 0 -> no data exist for period
#*!
Funprog DMW_EXIST(PSCMCOD,PSTRDAT,PENDDAT)
Value Char PSCMCOD     # Waste disposal scheme to use
Value Date PSTRDAT     # Date from
Value Date PENDDAT     # Date to

Gosub INIT

Read [F:DMWSC]DMWSC0 = PSCMCOD  # read scheme
If !fstat
    Filter [F:DMWQTY] Where SCMCOD = PSCMCOD and IPTDAT >= PSTRDAT and IPTDAT <= PENDDAT
    Read [F:DMWQTY] First
    Filter [F:DMWQTY]
    If !fstat
        End 1
    Else
        End 0
    Endif
Endif
End 0

