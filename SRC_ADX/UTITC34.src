#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UTITC34   Table BPCUSTOMER Initialisation de BPCSNCDAT       Module TC #
#           avec CREDAT lorsque c'est un client (pas un prospect)        #
##########################################################################
# FGR 03/06/2010 : X3SUIVI64450
##########################################################################
Local Char DOSSIER(30)

  If 0=1 Then
    DOSSIER = nomap
    Call SAIDOS(DOSSIER, "") From SAIDOS
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      Read [ADS]DOSSIER=[L]DOSSIER
      If fstat THEN
        Raz [F:ADS]
      Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("Correction") From LECFIC
      Call MAJ_UTITC34(DOSSIER) 
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTITC34(DOSSIER) 
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC34(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer ICOUNT

  IERR = 0
  ICOUNT = 0
  Call ECR_TRACE("UTITC34: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table BPCUSTOMER
  #
  If filinfo(filpath("FIL", "BPCUSTOMER", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".BPCUSTOMER" [BPC]
  If dim([F:BPC]BPCSNCDAT) >= 0 Then
    Trbegin [BPC]
    For [BPC]BPC0 Where BPCTYP <> 4 and BPCSNCDAT = [0/0/0] and CREDAT <> [0/0/0]
      [F:BPC]BPCSNCDAT = [F:BPC]CREDAT
      IUPDATE = 1
      If IUPDATE = 1 Then
        Rewrite [BPC]
        ICOUNT += 1
      Endif
    Next
    If IERR = 0 Then
      Commit
    Else
      Rollback
    Endif
  Endif
  Close Local File [BPC]
  #
  Call ECR_TRACE("UTITC34 : records processed" - num$(ICOUNT), 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat THEN
    Raz [F:ADS]
  Endif
  Call MAJ_UTITC34(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTITC34(APPLI)
End
