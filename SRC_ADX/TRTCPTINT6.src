#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################################################################
#
# PARAMETRAGE COMPTABLE OUTILS DE DIAGNOSTIC ET DE CONTROLE
# =========================================================
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Liste des sous-programmes :
# -------------------------
# 
# Subprog LIST_CAC_BY_ACC(PACCCODTYP,PCOA,PACCOUNT)
# Subprog LIST_ACC_USED_IN_CAC(PACCCODTYP,PCOA)
#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $LST_CAC_BY_ACC
# $LST_ACC_USED_IN_CAC
#
########################################################################################################################
 Gosub PARAM
 Gosub EXEC
End

$PARAM
 Local Char    PCPY       : PCPY       = "TVF"
 Local Integer PACCCODTYP : PACCCODTYP = 15
 Local Char    PCOA       : PCOA       = "SOC"
 Local Char    PACCOUNT   : PACCOUNT   = "145000IAS"
Return

$EXEC
 #Call LIST_COA_BY_CPY(PCPY)                             # Liste des plans de compte Social et IAS. 
  Call LIST_ACC_USED_IN_CAC(PACCCODTYP,PCOA)             # Liste des comptes utilisé dans les codes comptable d'un type donné
 #Call LIST_CAC_BY_ACC(PACCCODTYP,PCOA,PACCOUNT)         # Liste des codes comptables d'un type donné utilisant un compte d'un plan de compte passé en paramétre.
 #Call DIAG_ACCOUNT_CPYCOA(PCPY,PCOA,PACCOUNT)           # Diagnostic du paramétrage d'un compte
Return

#-------------------------------------------------------------
# Liste des codes comptables d'un type donné dans lesquels
# le compte PACCOUNT du référentiel PCOA est référencé.
# Fournit la ligne
#-------------------------------------------------------------
Subprog LIST_CAC_BY_ACC(PACCCODTYP,PCOA,PACCOUNT)
Value Integer PACCCODTYP
Value Char    PCOA
Value Char    PACCOUNT 
 
 Gosub LST_CAC_BY_ACC

End

#-------------------------------------------------------------
$LST_CAC_BY_ACC
 If GTRACE="" 
  Call OUVRE_TRACE("Liste des codes comptables dans lesquel est utilisé le compte "+PACCOUNT+" du référentiel"-PCOA) From LECFIC
  Local Integer LTRC
 Endif
 If !clalev([F:CAC]) : Local File GACCCODE [CAC] : Endif
 Filter [F:CAC] Where TYP=PACCCODTYP & COA=PCOA
 For [F:CAC]
  Local Integer IDX_ACC
  IDX_ACC=find(PACCOUNT,[F:CAC]ACC)
  If IDX_ACC
   Call ECR_TRACE("   "+[F:CAC]ACCCOD+space$(20-len([F:CAC]ACCCOD))+[F:CAC]DES+space$(50-len([F:CAC]DES))+"ligne"-num$(IDX_ACC),0) From GESECRAN
  Endif
 Next  
 If dim(LTRC)>0
  Call LEC_TRACE From LECFIC    
 Endif
Return

#-------------------------------------------------------------
# Liste des comptes du référentiel SOC utilisés dans 
# l'ensemble des codes comptable du type PACCCODTYP.
#-------------------------------------------------------------
Subprog LIST_ACC_USED_IN_CAC(PACCCODTYP,PCOA)
Value Integer PACCCODTYP
Value Char    PCOA

 Gosub LST_ACC_USED_IN_CAC

End

#-------------------------------------------------------------
$LST_ACC_USED_IN_CAC
 If GTRACE=""
  Call OUVRE_TRACE("Liste des comptes utilisés dans les codes comptables pour le référentiel"-PCOA) From LECFIC
  Local Integer LTRC
 Endif
 Local Integer LNBACCMAX : LNBACCMAX=80
 Local Char    LLSTACC(10)(1..LNBACCMAX)
 Local Char    LLSTCAC(80)(1..LNBACCMAX)
 Local Integer LNBACC
 Local Integer I_ACC
 
 If !clalev([F:CAC]) : Local File GACCCODE [CAC] : Endif
 If !clalev([F:GAC]) : Local File GACCOUNT [GAC] : Endif

 Filter [F:CAC] Where TYP=PACCCODTYP & COA=PCOA
 For [F:CAC]
  For I_ACC=0 To 49
   If [F:CAC]ACC(I_ACC)<>""
    If !find([F:CAC]ACC(I_ACC),LLSTACC)    
     LNBACC+=1 
     If LNBACC<LNBACCMAX
      LLSTACC(LNBACC)=[F:CAC]ACC(I_ACC)
     Else
      Read [F:GAC]GAC0=PCOA;[F:CAC]ACC(I_ACC)
      If fstat=5
       Call ECR_TRACE([F:CAC]ACC(I_ACC)+space$(10-len([F:CAC]ACC(I_ACC)))+space$(50)+"COMPTE INEXISTANT utilisé dans :"+" "+[F:CAC]ACC(I_ACC),1) From GESECRAN      
      Elsif !fstat
       Call ECR_TRACE([F:CAC]ACC(I_ACC)+space$(10-len([F:CAC]ACC(I_ACC)))+
&                     [F:GAC]DES+space$(50-len([F:GAC]DES))+
&                     mess([F:GAC]GACACN,2628,1),0) From GESECRAN           
      Endif
     Endif
    Endif
   Endif
  Next I_ACC
 Next 
 Filter [F:CAC]
 Sorta LLSTACC

 FICHIER="#@D:\list_comptes_ref_"+PCOA+".csv"
 SAVADXIFS=adxifs :   SAVADXIRS=adxirs 
 adxifs =";" : adxirs=chr$(10)
 Openo FICHIER,0 Using [ACC]
 Wrseq "Compte",
&      "Intitulé",
&      "Erreur"
&      Using [ACC]
 For I_ACC=1 To LNBACCMAX
  If LLSTACC(I_ACC)<>""
   Read [F:GAC]GAC0=PCOA;LLSTACC(I_ACC)
   If fstat=5
    Call ECR_TRACE(LLSTACC(I_ACC)+space$(10-len(LLSTACC(I_ACC)))+space$(50)+"COMPTE INEXISTANT utilisé dans :"+" "+LLSTCAC(I_ACC),1) From GESECRAN
    PACCOUNT=LLSTACC(I_ACC)
    Call LIST_CAC_BY_ACC(PACCCODTYP,PCOA,LLSTACC(I_ACC))
    Wrseq LLSTACC(I_ACC),[F:GAC]DES,"COMPTE INEXISTANT" Using [ACC]
   Elsif !fstat
    Call ECR_TRACE(LLSTACC(I_ACC)+space$(10-len(LLSTACC(I_ACC)))+
&                  [F:GAC]DES+space$(50-len([F:GAC]DES))+
&                  mess([F:GAC]GACACN,2628,1),0) From GESECRAN    
    Call DIAG_ACCOUNT_CPYCOA("",PCOA,LLSTACC(I_ACC))
    Wrseq LLSTACC(I_ACC),[F:GAC]DES,"" Using [ACC]
   Endif
 Endif
 Next I_ACC
 If dim(LTRC)>0
  Call LEC_TRACE From LECFIC
 Endif
 Openo Using [ACC]
Return

#-------------------------------------------------------------
# Comparaison des plans de compte social et IAS d'une 
# société passée en paramétre.
#-------------------------------------------------------------
Subprog LIST_COA_BY_CPY(PCPY)
Value Char PCPY
 Gosub LST_COA_BY_CPY
End

#-------------------------------------------------------------
$LST_COA_BY_CPY

 Local Char    LIGNE(110)
 Local Char    LIGSOC(55)
 Local Char    LIGIAS(55)
 Local Integer ERR
 Local Char    LCOASOC
 Local Char    LCOAIAS

 If !clalev([M:FPC]) : Local Mask FASPARCPY [FPC] : Endif

 If GTRACE=""
  Call OUVRE_TRACE("Plans comptables utilisés par la société"-PCPY) From LECFIC
  Local Integer LTRC
 Endif
 Call LOAD_FASPARCPY(PCPY,"",G_OUI,ERR) From GLOFCYCPY
 Call ECR_TRACE("Modèle comptable        : "+[M:FPC]GCM,0) From GESECRAN
 LCOASOC=[M:FPC]COA([M:FPC]GENLEDTYP-1)
 LCOAIAS=[M:FPC]COA([M:FPC]IASLEDTYP-1)
 Call ECR_TRACE("Plan référentiel social :"-LCOASOC,0) From GESECRAN
 Call ECR_TRACE("Plan référentiel IAS    :"-LCOAIAS,0) From GESECRAN

 If !clalev([F:GACS]) : Local File GACCOUNT [GACS] : Endif
 If LCOASOC<>LCOAIAS
  If !clalev([F:GACI]) : Local File GACCOUNT [GACI] : Endif
 Endif
 Call ECR_TRACE("",0) From GESECRAN
 If LCOASOC=LCOAIAS | LCOAIAS=""
  Filter [F:GACS] Where COA=LCOASOC
  For [F:GAC]
   LIGNE=[F:GAC]ACC+space$(15-len([F:GAC]ACC))+[F:GAC]DES
  Next
 Endif
 If LCOASOC<>LCOAIAS
  Filter [F:GACS] Where COA=LCOASOC
  Filter [F:GACI] Where COA=LCOAIAS
  For [F:GACS]
   If left$([F:GACS]ACC,6)>left$([F:GACI]ACC,6)
    While left$([F:GACS]ACC,6)>left$([F:GACI]ACC,6)
     Read [F:GACI] Next
     LIGSOC=space$(55)
     LIGIAS=[F:GACI]ACC
    Wend
   Endif
   If left$([F:GACS]ACC,6)=left$([F:GACI]ACC,6)
    LIGSOC=[F:GACS]ACC+space$(55-len([F:GACS]ACC))
    LIGIAS=[F:GACI]ACC    
   Endif
   If left$([F:GACS]ACC,6)<left$([F:GACI]ACC,6)
    LIGSOC=[F:GACS]ACC+space$(55-len([F:GACS]ACC))
    LIGIAS=""
   Endif   
   LIGNE=LIGSOC+LIGIAS
   Call ECR_TRACE(LIGNE,0) From GESECRAN
  Next
 Endif
 If dim(LTRC)>0
  Call LEC_TRACE From LECFIC
 Endif

Return

#-------------------------------------------------------------
# Synthèse du paramétrage d'un compte par rapport aux 
# autres plans de compte d'une société
#-------------------------------------------------------------
Subprog DIAG_ACCOUNT_CPYCOA(PCPY,PCOA,PACCOUNT)
Value Char PCPY
 Gosub DIA_ACCOUNT_CPYCOA
End

#-------------------------------------------------------------
$DIA_ACCOUNT_CPYCOA
 If !clalev([M:FPC]) : Local Mask FASPARCPY [FPC] : Endif

 Local Char    LIGNE(110)
 Local Char    LIGSOC(55)
 Local Char    LIGIAS(55)
 Local Integer ERR
 Local Char    LCOASOC
 Local Char    LCOAIAS
 Local Integer IDX_COA

 If GTRACE=""
  Call OUVRE_TRACE("Plans comptables utilisés par la société"-PCPY) From LECFIC
  Local Integer LTRC
 Endif

 If !clalev([F:GAC])  : Local File GACCOUNT [GAC]  : Endif
 If !clalev([F:GAC2]) : Local File GACCOUNT [GAC2] : Endif
 If PCPY<>"" : Call LOAD_FASPARCPY(PCPY,"",G_OUI,ERR) From GLOFCYCPY : Endif
 Read [F:GAC]GAC0=PCOA;PACCOUNT
 If fstat
  CALl ECR_TRACE(space$(5)+PACCOUNT-"Compte inexistant dans le plan de compte"-PCOA,1) From GESECRAN
 Endif
 For IDX_COA=1 To dim([F:GAC]OTHCOA)
  If [F:GAC]OTHCOA(IDX_COA-1)="" : Break : Endif
  If [F:GAC]DEFACC(IDX_COA-1)<>""
   Read [F:GAC2]GAC0=[F:GAC]OTHCOA(IDX_COA-1);[F:GAC]DEFACC(IDX_COA-1)
   If fstat=5
    Call ECR_TRACE(space$(5)+[F:GAC]OTHCOA(IDX_COA-1)+space$(5)+[F:GAC]DEFACC(IDX_COA-1)-"inexistant dans ce plan de compte",1) From GESECRAN
   Elsif !fstat
    Call ECR_TRACE(space$(5)+[F:GAC]OTHCOA(IDX_COA-1)+space$(5)+[F:GAC]DEFACC(IDX_COA-1)+space$(15-len([F:GAC]DEFACC(IDX_COA-1)))+
&                  [F:GAC]SCRACC(IDX_COA-1)+space$(15-len([F:GAC]SCRACC(IDX_COA-1)))+
&                  mess([F:GAC]OBYIPT(IDX_COA-1),1,1),0) From GESECRAN
   Endif
  Endif
 Next IDX_COA

 If dim(LTRC)>0
  Call LEC_TRACE From LECFIC
 Endif
Return
