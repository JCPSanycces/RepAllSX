#<AdxTL>@(#)0.0.0.0 $Revision$
# Class CCMIMPMFGH, Impact Analysis - Works Orders
# ================================================
# Issue 109096/2 - 2015-11-25 by BAKHA : For non-conformance, send email to actioners

$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
        When "AINIT"                       : Gosub INITIALISE
        When "CREATE_WORK_ORDERS_BATCH"    : Gosub CREATE_WORK_ORDERS_BATCH
        When "CREATE_WORK_ORDERS"          : Gosub CREATE_WORK_ORDERS
        When "CREATE_WORK_ORDERS_LINES"    : Gosub CREATE_WORK_ORDERS_LINES
        When "VALIDATE_IMPLEMENT"          : Gosub VALIDATE_IMPLEMENT
        When "UPDATE_STATUS"               : Gosub UPDATE_STATUS
        When "AUPDATE_AFTER"               : Gosub NOTIFY_ACTIONER
      Endcase
Endcase
Return

# --------------------------------------------------
# Initialise Purchase order plan Header properties.
$INITIALISE

  Local Integer LINES

  this.HOLD       = 1 # No
  this.IMPLEMENT  = 1 # No
  this.WOHORDERS  = 0
  this.WOHQTY     = 0
  this.TOTALLINES = 0
  this.WOHPLASTA  = 4

  this.IMPACTANAL = 0

Return

# ------------------------------------------------------
# Operation: CREATE_WORK_ORDERS_BATCH
#
# Called from Impact Analysis summary links.
# Instantiate Batch Server process, Task: CCMIMPBATT.
#
$CREATE_WORK_ORDERS_BATCH

  Local Integer LOCAL_STATUS
  Local Instance IMPMFGH Using C_CCMIMPMFGH
  IMPMFGH = NewInstance C_CCMIMPMFGH AllocGroup null

  Local Char    AFOLDER(30)
  Local Char    USER(30)
  Local Char    TASKNAME(30)
  Local Date    DAT
  Local Char    TIM(5)
  Local Char    TBPAR(30)(1..10)
  Local Char    TBVAL(250)(1..10)
  Local Integer NBPAR
  Local Integer TASKID
  Local Char    TASKMESSAGE(250)

  Local Integer LTIME
  Local Char    CTIME(4)

  # Read impact header
  LOCAL_STATUS = fmet IMPMFGH.AREAD(CRID)

  ASTATUS = CST_AOK

  If (IMPMFGH.IMPACTANAL <> 1)

    LTIME = time : CTIME = format$("N00:2", int(LTIME/3600)) +format$("N00:2", int((LTIME -(int(LTIME/3600) *3600)) /60))

    USER       = IMPMFGH.ACTX.USER
    TASKNAME  = "CCMIMPBATT"
    DAT       = date$
    TIM       = CTIME
    NBPAR = 1  : TBPAR(NBPAR) = "CRID"        : TBVAL(NBPAR) = CRID
    NBPAR += 1 : TBPAR(NBPAR) = "TRANSACTION" : TBVAL(NBPAR) = "14"

    # Impact Analysis 'Created' flag = "No" ...
    IMPMFGH.IMPACTANAL = 1
    LOCAL_STATUS = fmet IMPMFGH.AUPDATE()

    ASTATUS = func ASYRMNGTREQ.CRERQT(IMPMFGH.ACTX,
&                              IMPMFGH.ACTX.AFOLDER,
&                              USER,
&                              TASKNAME,
&                              DAT,
&                              TIM,
&                              TBPAR,
&                              TBVAL,
&                              NBPAR,
&                              TASKID,
&                              TASKMESSAGE)

  Endif

  FreeGroup IMPMFGH
  ARET_VALUE = ASTATUS

Return

# -------------------------------------------
# Create new purchase order line
$CREATE_WORK_ORDERS
  Local Integer COUNT, I, LINES, LOCSTATUS, FOUND
  Local File CCMIMPMFGD [CCMMFGD]
  Local Instance SELCHGREQ Using C_CCMCHGREQ
  Local Instance SELIMPMFGH Using C_CCMIMPMFGH

  # Begin a Database Transaction ...
  Local Integer TRANSACTION_PENDING
  TRANSACTION_PENDING = adxlog
  If (adxlog = 0)
    Trbegin [CCMMFGD]
  Endif

  # If CHANGE REQUEST status is IN REVIEW, and PRODUCT exists
  SELCHGREQ = NewInstance C_CCMCHGREQ AllocGroup null
  LOCSTATUS = fmet SELCHGREQ.AREAD(CRID)

  # Read purchase order header
  SELIMPMFGH = NewInstance C_CCMIMPMFGH AllocGroup null
  LOCSTATUS = fmet SELIMPMFGH.AREAD(CRID)

  If (LOCSTATUS = [V]CST_AOK and SELCHGREQ.CRSTATUS = 2)

    # Clear detail lines and reset header totals ...

    Delete [CCMMFGD] Where CRID = SELIMPMFGH.CRID

    # Create new purchase order lines
    SELIMPMFGH.HOLD = 1       # No
    SELIMPMFGH.IMPLEMENT = 1  # No
    SELIMPMFGH.WOHORDERS = 0
    SELIMPMFGH.WOHQTY = 0
    SELIMPMFGH.TOTALLINES = 0

    LOCSTATUS = fmet SELIMPMFGH.CREATE_WORK_ORDERS_LINES (SELIMPMFGH.CRID, SELCHGREQ.PRODUCT, SELCHGREQ.ECCVALMAJ, SELCHGREQ.ECCVALMIN)

  Endif

    # If lines exist then set the status to Pending else set to No lines
    If SELIMPMFGH.WOHORDERS >= 1
      SELIMPMFGH.WOHPLASTA = 1 # Plan
    Else
      SELIMPMFGH.WOHPLASTA = 4 # Not applicable
      # If Plan Status is 4 (None) then Implement flag is always ticked ...
      SELIMPMFGH.IMPLEMENT = 2
    Endif

    SELIMPMFGH.IMPACTANAL = 2

    LOCSTATUS = fmet SELIMPMFGH.AUPDATE()

  # Commit or Rollback teh Database Transaction ...
  If (TRANSACTION_PENDING = 0)
    If (ASTATUS <= [V]CST_AINFO)
      Commit
    Else
      Rollback
    Endif
  Endif

  Close Local File [CCMMFGD]
  FreeGroup SELIMPMFGH
  FreeGroup SELCHGREQ

Return

#----------------------------------------------
# Create new work order lines for main product, and then find all
# semi-finished/finished products and create all WO lines for these
$CREATE_WORK_ORDERS_LINES
  Local Instance SELCHGREQ Using C_CCMCHGREQ
  SELCHGREQ = NewInstance C_CCMCHGREQ AllocGroup null
  Local Char CRITERIA(250)
  Local Integer I, LOCSTATUS, BLANK_VERSION
  #MGG X3-38337_Product_Code_length_&_GLONITM_function
  Local Char LAST_ITMREF(GLONITM) : LAST_ITMREF = ""
  #END MGG X3-38337_Product_Code_length_&_GLONITM_function
  Local Date    WDATREF             : WDATREF=AVOID.ADATE
  Local Integer WLSTTYP             : WLSTTYP=3     # 1=first level, 2=last level, 3= multi-level
  Local Integer WALTTYPSTR          : WALTTYPSTR=1  # 1=Sales (kit), 2=WO (Manufacturing), 3=EO (subcontracting BOM)
  Local Integer WALTTYPEND          : WALTTYPEND=3  # 1=Sales (kit), 2=WO (Manufacturing), 3=EO (subcontracting BOM)
  Local Integer WALTSTR             : WALTSTR=0     # From alt number : 0=all alternatives
  Local Integer WALTEND             : WALTEND=0     # From alt number : 0=all alternatives
  Local Char    MYCRIT(250)         : MYCRIT="1=1"  # No particular Where criteria
  Local Char    MYFOR (GLONFOR)     : MYFOR=""      # Reference of a Formula in table TABFOR [F:TFO] with FORTYP=31
  Local Integer WRET,OK
  Local Integer LINE_NUMBER     : LINE_NUMBER = 0
  Local Char MYMFGNUM (GLONMFG)(0..)
  Local Integer NO_ORDERS : NO_ORDERS = 0
  #CATUA X3-38562.sn Set Product Code length to GLONITM
  Local Char SUB_LINES_PRODUCT(GLONITM)
  #CATUA X3-38562.en
  Local Char SUB_ECCVALMAJ(10)
  Local Char SUB_ECCVALMIN(10)

  Local File ITMMASTER [ITM]
  Local File ITMCATEG [ITG]

  # create log file

  # Create lines for Change Request Product ...
  BLANK_VERSION = CST_ATRUE
  SUB_LINES_PRODUCT = PRODUCT
  SUB_ECCVALMAJ = MAJOR_VERSION
  SUB_ECCVALMIN = MINOR_VERSION
  Gosub CREATE_WORK_ORDERS_SUB_LINES

  # Read Product and Product category and check for semi-finished good
  Read [ITM]ITM0 = PRODUCT
  If fstat = 0

    Read [ITG]ITG1 = [F:ITM]TCLCOD; ""
    If fstat = 0 and [F:ITG]MFGFLG = 2

      # For CCM: First CALCULATE
      Local File BOMWUS [BOW]

      Call CALCULATE_WHERE_USED_ECC(this.ACTX,PRODUCT,MAJOR_VERSION, "",WDATREF,WLSTTYP,WALTTYPSTR,WALTTYPEND,WALTSTR,WALTEND,MYCRIT,MYFOR,WRET) From SUBBOW_SYRA

      Filter [BOW] Where CREUSR = this.ACTX.USER and
&                        BOWUID = adxuid(1)
&                  Order By ITMREF
      For [BOW]
        If ([F:BOW]ITMREF <> LAST_ITMREF)
          SUB_LINES_PRODUCT = [F:BOW]ITMREF
          # if version managed

          If (fmet SELCHGREQ.IS_PRODUCT_VERSION_MANAGED(SUB_LINES_PRODUCT) > 1)
            Local File ECCVAL [EVL]
            # for each version, create lines
            CRITERIA = " 1=1 "
            If [F:BOW]BOMSTRDAT<>[0/0/0]
              CRITERIA+=" & STRDAT>=["+format$(GFMD,[F:BOW]BOMSTRDAT)+"]"
            Endif
            If [F:BOW]BOMENDDAT<>[0/0/0]
              CRITERIA+=" & STRDAT<=["+format$(GFMD,[F:BOW]BOMENDDAT)+"]"
            Endif

            BLANK_VERSION = CST_ATRUE
            For [EVL] Where ITMREF=[F:BOW]ITMREF & ECCTYP=[F:BOW]BOMALTTYP & BOMALT=[F:BOW]BOMALT  & evalue(CRITERIA)
              SUB_ECCVALMAJ = [F:EVL]ECCVALMAJ
              SUB_ECCVALMIN = [F:EVL]ECCVALMIN
              Gosub CREATE_WORK_ORDERS_SUB_LINES
              If (BLANK_VERSION = CST_ATRUE)
                BLANK_VERSION = CST_AFALSE
              Endif
            Next
            Close Local File [EVL]
          Else
            BLANK_VERSION = CST_AFALSE
            SUB_ECCVALMAJ = ""
            SUB_ECCVALMIN = ""
            Gosub CREATE_WORK_ORDERS_SUB_LINES
          Endif
        Endif
        LAST_ITMREF = [F:BOW]ITMREF
      Next

      # For CCM: delete temporary result lines in BOMWUS tables
      Delete [BOW] Where CREUSR = this.ACTX.USER & BOWUID = adxuid(1)

      Close Local File [BOW]

    Endif
  Endif

  # Update summary totals ...
  this.WOHORDERS = NO_ORDERS
  this.TOTALLINES = LINE_NUMBER

  Close Local File [ITM]
  Close Local File [ITG]
  FreeGroup SELCHGREQ
Return


#----------------------------------------------
#Create new work order line
$CREATE_WORK_ORDERS_SUB_LINES

  Local Integer LOCSTATUS
  Local File MFGITM [MFI]
  Local Instance CCMIMPMFGD Using C_CCMIMPMFGD
  CCMIMPMFGD = NewInstance C_CCMIMPMFGD AllocGroup null
  Local Char CRITERIA(250)

  CRITERIA = " 1=1 "
  If (SUB_ECCVALMAJ <> "")
    If (BLANK_VERSION = CST_ATRUE)
      CRITERIA += " and [F:MFI]ECCVALMAJ = '' or [F:MFI]ECCVALMAJ = SUB_ECCVALMAJ"
    Else
      CRITERIA += " and [F:MFI]ECCVALMAJ = SUB_ECCVALMAJ"
    Endif

    If (SUB_ECCVALMIN <>  "")
      If (BLANK_VERSION = CST_ATRUE)
        CRITERIA += " and [F:MFI]ECCVALMIN = '' or [F:MFI]ECCVALMIN = SUB_ECCVALMIN"
      Else
        CRITERIA += " and [F:MFI]ECCVALMIN = SUB_ECCVALMIN"
      Endif
    Endif
  Endif

  # Create new work order lines
  Filter [MFI] Where [F:MFI]ITMREF = SUB_LINES_PRODUCT and
&        [F:MFI]MFGSTA <> 4 and
&        evalue(CRITERIA)

  For [MFI]MFI0
    LOCSTATUS = fmet CCMIMPMFGD.AINIT()
    LINE_NUMBER += 1

    CCMIMPMFGD.CRID = CRID
    CCMIMPMFGD.LINENO = LINE_NUMBER
    CCMIMPMFGD.SORTSEQ = LINE_NUMBER
    CCMIMPMFGD.MFGNUM = [F:MFI]MFGNUM
    CCMIMPMFGD.MFGLIN = [F:MFI]MFGLIN
    CCMIMPMFGD.PLNFCY = [F:MFI]PLNFCY
    CCMIMPMFGD.MFGFCY = [F:MFI]MFGFCY
    CCMIMPMFGD.ITMREF = [F:MFI]ITMREF
    CCMIMPMFGD.ECCVALMAJ = [F:MFI]ECCVALMAJ
    CCMIMPMFGD.ECCVALMIN = [F:MFI]ECCVALMIN
    CCMIMPMFGD.TRANTYPE = 14    # 14 = Work order
    CCMIMPMFGD.LINESTATUS = 1    # 1 = Pending
    CCMIMPMFGD.BLOCK = 1       # 1 = No
    CCMIMPMFGD.STARTDATE= AVOID.ADATE
    CCMIMPMFGD.ENDDATE= AVOID.ADATE
    CCMIMPMFGD.COMPLETEDATE= AVOID.ADATE
    CCMIMPMFGD.ACTIONID = ""
    CCMIMPMFGD.ACTIONER = ""
    CCMIMPMFGD.COMMENT = ""
    CCMIMPMFGD.BPCTYPDEN = [F:MFI]BPCTYPDEN
    If (CCMIMPMFGD.BPCTYPDEN = 1)
      CCMIMPMFGD.SHIPTOSITE = [F:MFI]BPCNUM
      CCMIMPMFGD.BPCNUM = ""
    Else
      CCMIMPMFGD.BPCNUM  = [F:MFI]BPCNUM
      CCMIMPMFGD.SHIPTOSITE = ""
    Endif

    CCMIMPMFGD.UOMEXTQTY = [F:MFI]UOMEXTQTY
    CCMIMPMFGD.EXTQTY = [F:MFI]EXTQTY
    CCMIMPMFGD.MFGSTA = [F:MFI]MFGSTA
    CCMIMPMFGD.ITMSTA = [F:MFI]ITMSTA

    # Update summary totals
    this.WOHQTY += CCMIMPMFGD.EXTQTY

    LOCSTATUS = fmet CCMIMPMFGD.AINSERT()
    # Calculate total number of orders

    FOUND = CST_AFALSE
    For COUNT = 0 To NO_ORDERS
      If CCMIMPMFGD.MFGNUM = MYMFGNUM(COUNT)
        FOUND = CST_ATRUE
        Break
      Endif
    Next
    If FOUND = CST_AFALSE
      MYMFGNUM(NO_ORDERS) = CCMIMPMFGD.MFGNUM
      NO_ORDERS = NO_ORDERS+1
    Endif

  Next

  LogicClose File [MFI]

  # search through componenets table as well
  Gosub CREATE_MATERIAL_SUB_LINES
  FreeGroup CCMIMPMFGD

Return

#----------------------------------------------
#Create new material line
$CREATE_MATERIAL_SUB_LINES

  Local Integer LOCSTATUS
  Local File MFGMAT [MFM]

  CRITERIA = " 1=1 "
  If (SUB_ECCVALMAJ <> "")
    If (BLANK_VERSION = CST_ATRUE)
      CRITERIA += " and [F:MFM]ECCVALMAJ = '' or [F:MFM]ECCVALMAJ = SUB_ECCVALMAJ"
    Else
      CRITERIA += " and [F:MFM]ECCVALMAJ = SUB_ECCVALMAJ"
    Endif

    If (SUB_ECCVALMIN <>  "")
      If (BLANK_VERSION = CST_ATRUE)
        CRITERIA += " and [F:MFM]ECCVALMIN = '' or [F:MFM]ECCVALMIN = SUB_ECCVALMIN"
      Else
        CRITERIA += " and [F:MFM]ECCVALMIN = SUB_ECCVALMIN"
      Endif
    Endif
  Endif

  # Create new work order lines
  Filter [MFM] Where [F:MFM]ITMREF = SUB_LINES_PRODUCT and
&        [F:MFM]MFGSTA <> 4 and
&        evalue(CRITERIA)

  For [MFM]MFM0
    LOCSTATUS = fmet CCMIMPMFGD.AINIT()
    LINE_NUMBER += 1
    CCMIMPMFGD.CRID = CRID
    CCMIMPMFGD.LINENO = LINE_NUMBER
    CCMIMPMFGD.SORTSEQ = LINE_NUMBER
    CCMIMPMFGD.MFGNUM = [F:MFM]MFGNUM
    CCMIMPMFGD.MFGLIN = [F:MFM]MFGLIN
    CCMIMPMFGD.PLNFCY = [F:MFM]PLNFCY
    CCMIMPMFGD.MFGFCY = [F:MFM]MFGFCY
    CCMIMPMFGD.ITMREF = [F:MFM]ITMREF
    CCMIMPMFGD.ECCVALMAJ = [F:MFM]ECCVALMAJ
    CCMIMPMFGD.ECCVALMIN = [F:MFM]ECCVALMIN
    CCMIMPMFGD.TRANTYPE = 14    # 14 = Work order
    CCMIMPMFGD.LINESTATUS = 1    # 1 = Pending
    CCMIMPMFGD.BLOCK = 1       # 1 = No
    CCMIMPMFGD.STARTDATE= AVOID.ADATE
    CCMIMPMFGD.ENDDATE= AVOID.ADATE
    CCMIMPMFGD.COMPLETEDATE= AVOID.ADATE
    CCMIMPMFGD.ACTIONID = ""
    CCMIMPMFGD.ACTIONER = ""
    CCMIMPMFGD.COMMENT = ""
    CCMIMPMFGD.BPCTYPDEN = 0
    CCMIMPMFGD.BPCNUM  = ""
    CCMIMPMFGD.SHIPTOSITE = ""
    CCMIMPMFGD.UOMEXTQTY = [F:MFM]RETQTY
    CCMIMPMFGD.EXTQTY = [F:MFM]RETQTY
    CCMIMPMFGD.MFGSTA = [F:MFM]MFGSTA
    CCMIMPMFGD.ITMSTA = [F:MFM]MATSTA

    # Update summary totals
    this.WOHQTY += CCMIMPMFGD.UOMEXTQTY
    LOCSTATUS = fmet CCMIMPMFGD.AINSERT()

    # Calculate total number of orders

    FOUND = CST_AFALSE
    For COUNT = 0 To NO_ORDERS
      If CCMIMPMFGD.MFGNUM = MYMFGNUM(COUNT)
        FOUND = CST_ATRUE
        Break
      Endif
    Next
    If FOUND = CST_AFALSE
      MYMFGNUM(NO_ORDERS) = CCMIMPMFGD.MFGNUM
      NO_ORDERS = NO_ORDERS+1
    Endif

  Next

  LogicClose File [MFM]

Return

# -------------------------------------------------------------------------------
# Update Work Oreders Detail Plan 'header' status.
#
# Set status to:
#
# 4 'Not applicable'  ... if (No sales order lines) or (No actionable sales order lines and Planning complete),
# 3 'Complete'        ... if (All actionable sales order lines are complete),
# 2 'Implement'       ... if (Actionable sales order lines and Planning complete),
# 1 'Plan'            ... if (Planning is not complete).

$UPDATE_STATUS

  Local Integer STAT, ACTIONLINES, LINESCOMP

#Start the profile
#Local Char WFICTRACE(60)
#STAT = func ASYRTIMING.START("",1)

  # Count number of action lines ...
  Local File CCMIMPMFGD [CCMMFGD]
  Filter [CCMMFGD] Where CRID = this.CRID and ACTIONID <> ""
  ACTIONLINES = rowcount([CCMMFGD])

  # Count number of action lines complete ...
  Filter [CCMMFGD] Where CRID = this.CRID and LINESTATUS = 3
  LINESCOMP = rowcount([CCMMFGD])

  Filter [CCMMFGD]
  LogicClose File [CCMMFGD]

  If (this.WOHORDERS = 0) or
&    (ACTIONLINES = 0 and this.IMPLEMENT = 2)
    this.WOHPLASTA = 4
  Elsif (ACTIONLINES <> 0 and ACTIONLINES = LINESCOMP)
    this.WOHPLASTA = 3
  Elsif (this.IMPLEMENT = 2)
    this.WOHPLASTA = 2
  Else
    this.WOHPLASTA = 1
  Endif

  ARET_VALUE = CST_ATRUE

Return


# -------------------------------------------------------------------------------
# "Planning complete" flag validation ...
$VALIDATE_IMPLEMENT
  Local Integer ACTIONLINES, LOCSTATUS

  # count number of action lines
  Local File CCMIMPMFGD [CCMMFGD]
  Filter [CCMMFGD] Where CRID = this.CRID and ACTIONID <> ""
  ACTIONLINES = rowcount([CCMMFGD])
  LogicClose File [CCMMFGD]

  ASTATUS = CST_AOK

  If (this.snapshot.IMPLEMENT = 1 and this.IMPLEMENT = 2)
    If (this.TOTALLINES > ACTIONLINES)
#      LOCSTATUS = fmet this.ASETERROR ("IMPLEMENT", mess(62,2038,1), CST_AINFO)
      LOCSTATUS = fmet this.ASETERROR ("", mess(62,2038,1), CST_AINFO)
    Endif
  Endif

 ARET_VALUE = ASTATUS

Return

#
# --------------------------------------------------
# FUNCTION NAME:        NOTIFY_ACTIONER
# FUNCTION DESCRIPTION: Notify Actioner
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$NOTIFY_ACTIONER

  Local Instance CHANGE_REQUEST Using C_CCMCHGREQ
  CHANGE_REQUEST = NewInstance C_CCMCHGREQ AllocGroup null
  Local File CCMIMPMFGD [MFGD]
  Local Char LAST_ACTIONER(5)
  Local Integer STAT
  Local Integer EMAIL_TYPE
  Local Char SUBJECT(250)
  Local Clbfile BODY(0), OTHER_BODY(0)
  Local Integer AC_EMAIL : AC_EMAIL = CST_AFALSE
# Issue 109096/2 - send e-mails to actioners
  Local Integer SENDEMAIL : SENDEMAIL = CST_AFALSE
  STAT = fmet CHANGE_REQUEST.AREAD(this.CRID)

  If (CHANGE_REQUEST.NCSREC = 2)
    # Issue X3-76268 - 2018-02-13 by JUSYN : Remove/deactivate email notification NCS
#    If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "NCSEMAILAC") <> 1 and
#&     this.snapshot.IMPLEMENT = 1 and this.IMPLEMENT = 2)
#
#      SENDEMAIL = CST_ATRUE
#      EMAIL_TYPE = 3713  # Actioner
#      BODY(0) = AVOID.ACLOB
#      OTHER_BODY(0) = AVOID.ACLOB
#      Append OTHER_BODY, mess(14,2039,1) +chr$(10)
#      STAT = fmet CHANGE_REQUEST.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, OTHER_BODY, "NCSPLAMFGH")
#    Endif
    # End issue X3-76268
  Else
# End issue 109096/2

    If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMEMAILAC") <> 1 and
&     this.snapshot.IMPLEMENT = 1 and this.IMPLEMENT = 2)

      EMAIL_TYPE = 2066  # Actioner
      BODY(0) = AVOID.ACLOB
      OTHER_BODY(0) = AVOID.ACLOB
      Append OTHER_BODY, mess(14,2039,1) +chr$(10)
      STAT = fmet CHANGE_REQUEST.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, OTHER_BODY, "CCMPLAMFGH")
    Endif
# Issue 109096/2
  Endif

  If (SENDEMAIL = CST_ATRUE)
# End issue 109096/2

    Filter [MFGD] Where CRID = this.CRID and ACTIONER <> "" Order By ACTIONER
    For [MFGD]
      If ([F:MFGD]ACTIONER <> LAST_ACTIONER and
&         [F:MFGD]ACTIONER <> this.ACTX.USER)

        STAT = fmet CHANGE_REQUEST.SEND_EMAIL(this.ACTX.USER, [F:MFGD]ACTIONER, "", SUBJECT, BODY)

        If (STAT = CST_AOK)
          AC_EMAIL = CST_ATRUE
        Endif

        LAST_ACTIONER = [F:MFGD]ACTIONER

      Endif
    Next

    If (AC_EMAIL = CST_ATRUE)
      ASTATUS = fmet this.ASETERROR("", mess(60,2038,1), CST_AINFO)
    Endif

  Endif

  LogicClose File [MFGD]
  FreeGroup CHANGE_REQUEST

Return

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return


