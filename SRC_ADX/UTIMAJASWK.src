#<AdxTL>@(#)4.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Copy data from table ASHWLNK, ASHWPAR
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Update data from table ASHWLNK, ASHWPAR") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER=nomap
 Local File ASHWLNK [ASWK]
 Local File ASHWPAR [ASWP]
Else
 Local File =DOSSIER+".ASHWLNK" [ASWK]
 Local File =DOSSIER+".ASHWPAR" [ASWP]
Endif

#If dim([F:ASWP]AFFLNK)>0
#Gosub MAJTAB1
#Gosub MAJTAB2
#Gosub MAJTAB3
#Endif

#If dim([F:ASWK]ORDTECLNK)>0
#Gosub MAJTAB4
#Endif

Gosub MAJTAB5

Close Local File [ASWK],[ASWP]
End

#----------------------------------------------------------------------------------------#
$MAJTAB2
Trbegin [ASWP]
  For [ASWP] Where AFFLNK=0
    If [F:ASWP]TYPPAR=2
      Delete [ASWP]Curr
    Elsif [F:ASWP]TYPPAR=1
      [F:ASWP]AFFLNK=1
      If [F:ASWP]PARENT=0 : [F:ASWP]PARENT=1 : Endif
      If [F:ASWP]PARFIL=0 : [F:ASWP]PARFIL=1 : Endif
      Rewrite [ASWP]
      If fstat
       Call ERREUR("ASHWPAR"-[F:ASWP]CODREP-num$([F:ASWP]AFFLNK)-[F:ASWP]CODFLD,2) From DOSDIC
      Endif
    Endif
 Next
Commit

Return


$MAJTAB1
Local Char WCODLNK_OLD(GLONAVA)
Local Integer BTROUVE : BTROUVE=0

Filter [ASWK] Where ATTLNK=0
Read [ASWK]First
If !fstat
  BTROUVE=1
Endif
Filter [ASWK]
If BTROUVE=0 : Return : Endif

Trbegin [ASWK]
 For [ASWK]
    WCODLNK_OLD=[F:ASWK]CODLNK
    If [F:ASWK]FLGSTDLNK=0
     [F:ASWK]ENALNK=2
     [F:ASWK]ATTLNK=1
     [F:ASWK]FLGSTDLNK=1
     Raz [F:ASWK]REMSTDLNK
    Endif
    If [F:ASWK]ATTLNK=0
     [F:ASWK]ATTLNK=1
    Endif
    If [F:ASWK]CODLNK="$details"
      [F:ASWK]ATTLNK=2
      [F:ASWK]CODLNK="DETAIL"
    Elsif [F:ASWK]CODLNK="$browse"
      [F:ASWK]CODLNK="BROWSE"
    Elsif left$([F:ASWK]CODLNK,1)="$"
      [F:ASWK]ENALNK=1
      [F:ASWK]CODLNK=toupper(right$([F:ASWK]CODLNK,2))
    Else
      [F:ASWK]CODLNK=toupper([F:ASWK]CODLNK)
    Endif
#    If GPRODUIT=-1 & (left$([F:ASWK]CODLNK,1)<>"A" | left$([F:ASWK]CODREP,1)="Z")
#      If left$([F:ASWK]ACVLNK,1)="Z" | left$([F:ASWK]CODREP,1)="Z"
#      [F:ASWK]CODLNK="Z"+[F:ASWK]CODLNK
#      Else
#      [F:ASWK]CODLNK="A"+[F:ASWK]CODLNK
#      Endif
#    Endif
    Rewrite [ASWK]
    If fstat
     Call ERREUR("ASHWLNK"-[F:ASWK]CODREP-num$([F:ASWK]AFFLNK)-[F:ASWK]ANCLNK-WCODLNK_OLD,2) From DOSDIC
    Else
      For [ASWP] Where TYPPAR=3 & CODREP=[F:ASWK]CODREP & AFFLNK=0 & CODFLD=WCODLNK_OLD
        [F:ASWP]CODFLD=[F:ASWK]ANCLNK
        [F:ASWP]AFFLNK=[F:ASWK]AFFLNK
        [F:ASWP]CODLNK=[F:ASWK]CODLNK
        Rewrite [ASWP]
        If fstat
         Call ERREUR("ASHWPAR"-[F:ASWP]CODREP-num$([F:ASWP]AFFLNK)-[F:ASWP]CODFLD-[F:ASWP]CODLNK,2) From DOSDIC
        Endif
      Next
    Endif
 Next
Commit

Return
#----------------------------------------------------------------------------------------#
$MAJTAB3
Local Integer BTROUVE : BTROUVE=0
Trbegin [ASWK],[ASWP]
 For [ASWK] Where CMPLNK=9
  BTROUVE=0
  For [ASWP] Where TYPPAR=3 & CODREP=[F:ASWK]CODREP & TYPKEY=2 & CODLNK=[F:ASWK]CODLNK & AFFLNK=[F:ASWK]AFFLNK & CODFLD=[F:ASWK]ANCLNK
   If [F:ASWP]VALEUR=[F:ASWK]ANCLNK
    BTROUVE=1
    If [F:ASWP]ADRVAL<>1
     [F:ASWP]ADRVAL=1
     Rewrite [ASWP]
     If fstat
      Call ERREUR("ASHWPAR"-[F:ASWP]CODREP-num$([F:ASWP]AFFLNK)-[F:ASWP]CODFLD-[F:ASWP]CODLNK,2) From DOSDIC
     Endif
    Endif
   Endif
  Next
  If BTROUVE=0
    #Au moins une clé du lien doit correspondre à l'ancre et avoir le mode "$1$"
    Call ECR_TRACE("ASHWLNK"-[F:ASWK]CODREP-num$([F:ASWK]AFFLNK)-[F:ASWK]ANCLNK-[F:ASWK]CODLNK-":"-"Au moins une clé du lien doit correspondre à l'ancre et avoir le mode 'Par adresse'",-1) From
& GESECRAN
  Endif
 Next
Commit

Return

#----------------------------------------------------------------------------------------#
$MAJTAB4
Trbegin [ASWK]
 For [ASWK]
  If [F:ASWK]FLGSTDLNK=2 & [F:ASWK]ORDLNK=0
    Case [F:ASWK]CMPLNK
    When 1  : # Créer une fiche
      [F:ASWK]ORDLNK=150
    When 2  : # Afficher détail
      [F:ASWK]ORDLNK=200
    When 3  : # Modifier une fiche
      [F:ASWK]ORDLNK=250
    When 4  : # Supprimer une fiche
      [F:ASWK]ORDLNK=350
    When 5  : # Afficher liste
      [F:ASWK]ORDLNK=500
    When 6  : # Dupliquer une fiche
      [F:ASWK]ORDLNK=300
    When 7  : # Afficher dans Excel
      [F:ASWK]ORDLNK=600
    When 8  : # Lister dans Excel
      [F:ASWK]ORDLNK=650
    When 9  : # Sélection
      [F:ASWK]ORDLNK=400
    When 10 : # Afficher résumé
      [F:ASWK]ORDLNK=450
    When 11 : # Afficher en PDF
      [F:ASWK]ORDLNK=700
    When 12 : # Lister en PDF
      [F:ASWK]ORDLNK=750
    When 13 : # Afficher dans Word
      [F:ASWK]ORDLNK=800
    When 14 : # Lister dans Word
      [F:ASWK]ORDLNK=850
    When 15 : # Publiposter fiche
      [F:ASWK]ORDLNK=900
    When 16 : # Publiposter liste
      [F:ASWK]ORDLNK=950
    When 17 : # Enregistrer
      [F:ASWK]ORDLNK=50
    When 18 : # Abandon
      [F:ASWK]ORDLNK=100
    Endcase
    [F:ASWK]ORDTECLNK=func BUILD_ASWK_ORDTECLNK
  Endif
  If [F:ASWK]ORDTECLNK=0
   [F:ASWK]ORDTECLNK=func BUILD_ASWK_ORDTECLNK
  Endif
  Rewrite [ASWK]
  If fstat
   Call ERREUR("ASHWLNK"-[F:ASWK]CODREP-num$([F:ASWK]AFFLNK)-[F:ASWK]ANCLNK-[F:ASWK]CODLNK,2) From DOSDIC
  Endif
 Next
Commit

Return


#----------------------------------------------------------#
# build the field [F:ASWK]ORDTECLNK
Funprog BUILD_ASWK_ORDTECLNK
Local Integer ORDTECLNK
[L]ORDTECLNK=[F:ASWK]ORDLNK
If [F:ASWK]ORDLNK<=0 : [L]ORDTECLNK=9999 : Endif
If [F:ASWK]AFFLNK=2 : [L]ORDTECLNK+=10000 : Endif
If [F:ASWK]AFFLNK=3 : [L]ORDTECLNK+=20000 : Endif
End [L]ORDTECLNK

#----------------------------------------------------------------------------------------#
$MAJTAB5
Trbegin [ASWK],[ASWP]
 Delete [ASWK] Where AFFLNK=3
 Delete [ASWP] Where TYPPAR=3 & AFFLNK=3
Commit
Return
