Return

#JOJAC - 2017-06-01 - START
$ADDLINE_AFTER
#this.NBCNT = 1 + max(this.NBCNT(1..maxtab(this.NBCNT)).NUMLIG)
Return
#JOJAC - 2017-06-01 - END


$SET_WORKFLOW
Local Integer REQNUM,TYPEVT,STAT
Local Char    CODEVT(30)
Local Char    OPERAT(30)
Local Char    MSG(250),CLEOBJ(250)

 TYPEVT=2             : # Object based event
 CODEVT="EML"         : # The object is DCG
 OPERAT="M"           : # Modification and creation
 CLEOBJ=this.REFNUM   : # Current key
# STAT = func ASYRWRKCLASSIC.WORKFLOW(this.ACTX,TYPEVT,CODEVT,OPERAT,CLEOBJ,REQNUM,MSG)
# ASTATUS = fmet this.ASETERROR("",num$(MSG),[V]CST_AOK)
Return

#FRLAA X3-76638 2018-05-08 - START
$CHECK_LEGCLASS

If func AFNC.ACTIV("KZA")>0
  If !func DIVPAYE.IS_KZA(this.TCH_LEG)
    Gosub CHECK_LEGCLASS_NKZA
  Endif
Endif

If func AFNC.ACTIV("KUK")>0
  If !func DIVPAYE.IS_KUK_LEG(this.TCH_LEG)
    Gosub CHECK_LEGCLASS_NKUK
  Endif
Endif
Return

$CHECK_LEGCLASS_NKZA
#Remove records if not KZA
If this.EMPLOIDSA <> null
  For I = 1 To maxtab(this.EMPLOIDSA)
    OK=fmet this.ADELLINE("EMPLOIDSA", 1)
  Next
Endif
Return

$CHECK_LEGCLASS_NKUK
#Remove records if not KZA
If this.EMPLOIDUKI <> null
  For I = 1 To maxtab(this.EMPLOIDUKI)
    OK=fmet this.ADELLINE("EMPLOIDUKI", 1)
  Next
Endif
Return

#FRLAA X3-76638 2018-05-08 - END

