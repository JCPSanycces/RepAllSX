#Handling all events for EMPLOID_CSTD
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"                :      Gosub AREAD_AFTER
      When "AUPDATE_CONTROL_AFTER"      :      Gosub AUPDATE_CONTROL_AFTER
      When "ADDLINE_AFTER"              :      Gosub ADDLINE_AFTER
    Endcase
Endcase
Return


$AREAD_AFTER

#Set the current legislation for the record
this.TCH_LEG = func DIVPAYE_SOA.GET_LEG_EMP(this.REFNUM, 1) #Site level

#FRLAA X3-76638 2018-05-08 - START
#Check records for the legislation
Gosub CHECK_LEGCLASS
#FRLAA X3-76638 2018-05-08 - END
Return


$AUPDATE_CONTROL_AFTER

