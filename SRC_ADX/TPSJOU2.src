#<AdxTL>@(#)0.0.0.0 $Revision$
$AM_PLAGE

## Si on supprime une plage et que l'ÃĐvÃĻnement associÃĐ est de type plage horaire, on supprime l'ÃĐvÃĻnement.
## Quand on supprime un ÃĐvÃĻnement, on efface toutes les zones associÃĐes Ã  l'ÃĐvÃĻnement
## Si le paramÃĻtre de recopie est positionnÃĐ Ã  Oui et qu'on modifie la plage 1, on recopie les donnÃĐes
## sur les autres plages.

Local Char PLG
Local Integer PLAG, COL, RECOPIE

PLG  = right$(COUZON,len(COUZON))
PLAG = val(PLG)
COL  = val(mid$(COUZON,len(COUZON)-1,1))
If CZ="" & left$(COUZON,len(COUZON)-2)="STRTIM"
 Effzo ="[M]ENDTIM"+num$(COL)+PLG
Elsif CZ="" & left$(COUZON,len(COUZON)-2)="ENDTIM"
 Effzo ="[M]STRTIM"+num$(COL)+PLG
Endif

If PLG=left$([M]NUMPLG,1)
 ## Plage courante
 If CZ=""
  Effzo ="[M]BRKTIM"+num$(COL)
  If evalue("dim([M]NBRHOU"+num$(COL)+")")>0 : Effzo ="[M]NBRHOU"+num$(COL) : Endif
  If evalue("dim([M]NBRDAY"+num$(COL)+")")>0 : Effzo ="[M]NBRDAY"+num$(COL) : Endif
  #LIPET - 10-01-2017 - X3-18688 - START
  #Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
  Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
  #LIPET - 10-01-2017 - X3-18688 - END
  If [F:TIM]PLGHOR=2
   ## EvÃĻnement de type plage horaire
   Effzo ="[M]TIM"+num$(COL)
   Gosub TIMVIDE From TPSJOU1
  Endif
  Return
 Endif
 Case left$(COUZON,len(COUZON)-2)
  When "STRTIM"
   Call MAJHOU(PLAG,COL,CZ,evalue("[M]ENDTIM"+num$(COL)+PLG),evalue("[M]BRKTIM"+num$(COL)),
&              "[M]NBRHOU"+num$(COL),"[M]NBRDAY"+num$(COL),1,0)
   If mkstat=2
    GERR = 1
    Return
   Endif
   If evalue("dim([M]NBRHOU"+num$(COL)+")")>0 : Affzo ="[M]NBRHOU"+num$(COL) : Endif
   If evalue("dim([M]NBRDAY"+num$(COL)+")")>0 : Affzo ="[M]NBRDAY"+num$(COL) : Endif
  When "ENDTIM"
   Call MAJHOU(PLAG,COL,evalue("[M]STRTIM"+num$(COL)+PLG),CZ,evalue("[M]BRKTIM"+num$(COL)),
&              "[M]NBRHOU"+num$(COL),"[M]NBRDAY"+num$(COL),1,0)
   If mkstat=2
    GERR = 1
    Return
   Endif
   If evalue("dim([M]NBRHOU"+num$(COL)+")")>0 : Affzo ="[M]NBRHOU"+num$(COL) : Endif
   If evalue("dim([M]NBRDAY"+num$(COL)+")")>0 : Affzo ="[M]NBRDAY"+num$(COL) : Endif
 Endcase
Else
 ## Pas sur la plage courante
 If CZ=""
  Assign "[M:TPSI]KBRKTIM"+PLG+"("+num$(COL-1)+")" With 0
  Assign "[M:TPSI]KNBRHOU"+PLG+"("+num$(COL-1)+")" With 0
  Assign "[M:TPSI]KNBRDAY"+PLG+"("+num$(COL-1)+")" With 0
  #LIPET - 10-01-2017 - X3-18688 - START
  #Call LECTURE("TIM",evalue("[M:TPSI]KTIM"+PLG+"("+num$(COL-1)+")"),"") From CONTOBJ
  Call LECTURE("HRTIM",evalue("[M:TPSI]KTIM"+PLG+"("+num$(COL-1)+")"),GCURLEG) From CONTOBJ
  #LIPET - 10-01-2017 - X3-18688 - END
  If [F:TIM]PLGHOR=2
   Assign "[M:TPSI]KTIM"+PLG+"("+num$(COL-1)+")" With ""
   # Zones alpha
   For ZONCOP="NATCOD","FLD1","FLD2","CPY","BPCNUM","SOHNUM","CMT","STAFLG","DSP","CCE1","CCE2","CCE3",
&           "CCE4","CCE5","CCE6","CCE7","CCE8","CCE9"
    If evalue("dim([M:TPSJ]"+ZONCOP+num$(COL)+")")>0
     Assign "[M:TPSI]K"+ZONCOP+PLG+"("+num$(COL-1)+")" With ""
    Endif
   Next
   # Zones numÃĐriques
   For ZONCOP="BRKTIM","DAYNGT","TYPDAY","QTY1","QTY2","SOHLIG","INVFLG","NBRDAY","NBRHOU"
    If evalue("dim([M:TPSJ]"+ZONCOP+num$(COL)+")")>0
     Assign "[M:TPSI]K"+ZONCOP+PLG+"("+num$(COL-1)+")" With 0
    Endif
   Next
  Endif
  Return
 Endif
 Case left$(COUZON,len(COUZON)-2)
  When "STRTIM"
   Call MAJHOU(PLAG,COL,CZ,evalue("[M]ENDTIM"+num$(COL)+PLG),evalue("[M:TPSI]KBRKTIM"+PLG+"("+num$(COL-1)+")")
&     ,"[M:TPSI]KNBRHOU"+PLG+"("+num$(COL-1)+")"
&     ,"[M:TPSI]KNBRDAY"+PLG+"("+num$(COL-1)+")",1,0)
   If mkstat=2
    GERR = 1
    Return
   Endif
  When "ENDTIM"
   Call MAJHOU(PLAG,COL,evalue("[M]STRTIM"+num$(COL)+PLG),CZ,evalue("[M:TPSI]KBRKTIM"+PLG+"("+num$(COL-1)+")")
&     ,"[M:TPSI]KNBRHOU"+PLG+"("+num$(COL-1)+")"
&     ,"[M:TPSI]KNBRDAY"+PLG+"("+num$(COL-1)+")",1,0)
   If mkstat=2
    GERR = 1
    Return
   Endif
 Endcase
Endif
Return


Subprog MAJHOU(PLAG,COL,DEBTIM,FINTIM,BRKTIM,NBHOU,NBDAY,SAI,CTLHRE)
Value Integer PLAG, COL
Value Char    DEBTIM, FINTIM
Value Decimal BRKTIM
Value Char    NBHOU, NBDAY
Value Integer SAI, CTLHRE

Local Decimal SUMHRS, VALHMDEB, VALHMFIN
Local Integer I, J, JNUIT
Local Decimal JOUR , HEURE, NBJ, VALHOU

If DEBTIM="" | FINTIM="" : End : Endif

## Calcul du nb d'heure = Heure fin-heure debut-temps de pause

Call CONVERTHM(DEBTIM,VALHMDEB)From SUBSTY
Call CONVERTHM(FINTIM,VALHMFIN)From SUBSTY

If CTLHRE=1 & ((VALHMFIN>=VALHMDEB & BRKTIM>VALHMFIN-VALHMDEB)
&            |(VALHMFIN<VALHMDEB & BRKTIM>=24-VALHMDEB+VALHMFIN))
 # Temps de pause incorrect
 #ADNGO - 26-01-2017 - X3-18688 - START
 #GMESSAGE = mess(115,709,1)
 GMESSAGE = mess(115,10709,1)
 #ADNGO - 26-01-2017 - X3-18688 - END
 mkstat = 2 : End
Endif

If VALHMFIN>=VALHMDEB
 SUMHRS = VALHMFIN-VALHMDEB
Else
 SUMHRS = 24-VALHMDEB + VALHMFIN
Endif
SUMHRS -=  BRKTIM
SUMHRS = ar2(SUMHRS)


## ContrÃīle du nombre d'heures calculÃĐes

For I=1 To [M:TPSI]NBHOR
 If I=PLAG
  HEURE += SUMHRS
 Elsif SAI=1 & I=val(left$([M]NUMPLG,1)) & evalue("dim([M]NBRHOU"+num$(COL)+")")>0
  HEURE += evalue("[M]NBRHOU"+num$(COL))
  If evalue("dim([M]NBRDAY"+num$(COL)+")")>0
   NBJ  += evalue("[M]NBRDAY"+num$(COL))
  Endif
 Else
  HEURE += evalue("[M:TPSI]KNBRHOU"+num$(I)+"("+num$(COL-1)+")")
  NBJ   += evalue("[M:TPSI]KNBRDAY"+num$(I)+"("+num$(COL-1)+")")
 Endif
Next I

# Si on est sur la zone BRKTIM (Pause) CTLHRE=1

If CTLHRE=1
 VALHOU=val(func AFNC.PARAM("HOUDAYLEG",[M]FCY))
 If VALHOU>0 & HEURE>VALHOU
  # Maximum d'heures par jour
  #ADNGO - 26-01-2017 - X3-18688 - START
  #GMESSAGE = mess(4,709,1)-":"-num$(VALHOU)
  GMESSAGE = mess(4,10709,1)-":"-num$(VALHOU)
  #ADNGO - 26-01-2017 - X3-18688 - END
  mkstat = 2 : End
 Endif
Endif

Call VALORIS([M]DAT(COL-1),[M]DAT(COL-1),[M]REFNUM,evalue("[M]TIM"+num$(COL)),JOUR,HEURE,[M]FCY,[M]CTRNUM) From SUBPLN

If evalue("dim("+NBHOU+")")>0
 Assign NBHOU With SUMHRS
Else
 Assign "[M:TPSI]KNBRHOU"+num$(PLAG)+"("+num$(COL-1)+")" With SUMHRS
Endif

If evalue("dim("+NBDAY+")")>0
 If HEURE<>0
  If NBJ + min(JOUR,ar2(SUMHRS*JOUR/HEURE))>1
   Assign NBDAY With 1-NBJ
  Else
   Assign NBDAY With min(JOUR,ar2(SUMHRS*JOUR/HEURE))
  Endif
 Else
  Assign NBDAY With 0
 Endif
Else
 If HEURE<>0
  Assign "[M:TPSI]KNBRDAY"+num$(PLAG)+"("+num$(COL-1)+")" With min(JOUR,ar2(SUMHRS*JOUR/HEURE))
 Else
  Assign "[M:TPSI]KNBRDAY"+num$(PLAG)+"("+num$(COL-1)+")" With 0
 Endif
Endif

# On modifie la zone BRKTIM, on recalcule le nombre de jours de toutes les plages
If SAI=1 & evalue("dim("+NBDAY+")")>0
 Raz NBJ
 # EvÃĻnement sans plage horaire
 For I=1 To [M:TPSI]NBHOR
  If I<>PLAG & evalue("[M]STRTIM"+num$(COL)+num$(I))=""
   NBJ += evalue("[M:TPSI]KNBRDAY"+num$(I)+"("+num$(COL-1)+")")
  Endif
 Next
 # EvÃĻnement de la plage courante => recalcul du nombre de jours
 If HEURE<>0
  If NBJ + min(JOUR,ar2(SUMHRS*JOUR/HEURE))>1
   Assign NBDAY With 1-NBJ
   NBJ = 1
  Else
   Assign NBDAY With min(JOUR,ar2(SUMHRS*JOUR/HEURE))
   NBJ +=  min(JOUR,ar2(SUMHRS*JOUR/HEURE))
  Endif
 Else
  Assign NBDAY With 0
 Endif
 # EvÃĻnement des autres plages => recalcul du nombre de jours
 For I=1 To [M:TPSI]NBHOR
  If I<>PLAG &evalue("[M]STRTIM"+num$(COL)+num$(I))<>""
   Call CONVERTHM(evalue("[M]STRTIM"+num$(COL)+num$(I)),VALHMDEB)From SUBSTY
   Call CONVERTHM(evalue("[M]ENDTIM"+num$(COL)+num$(I)),VALHMFIN)From SUBSTY
   If VALHMFIN>=VALHMDEB
    SUMHRS = VALHMFIN-VALHMDEB
   Else
    SUMHRS = 24-VALHMDEB + VALHMFIN
   Endif
   SUMHRS -=  evalue("[M:TPSI]KBRKTIM"+num$(I)+"("+num$(COL-1)+")")
   SUMHRS = ar2(SUMHRS)
   If HEURE<>0
    If NBJ + min(JOUR,ar2(SUMHRS*JOUR/HEURE))>1
     Assign "[M:TPSI]KNBRDAY"+num$(I)+"("+num$(COL-1)+")" With 1-NBJ
     NBJ = 1
    Else
     Assign "[M:TPSI]KNBRDAY"+num$(I)+"("+num$(COL-1)+")" With min(JOUR,ar2(SUMHRS*JOUR/HEURE))
     NBJ += min(JOUR,ar2(SUMHRS*JOUR/HEURE))
    Endif
   Else
    Assign "[M:TPSI]KNBRDAY"+num$(I)+"("+num$(COL-1)+")" With 0
   Endif
  Endif
 Next
Endif
End

