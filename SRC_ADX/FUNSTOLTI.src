#<AdxTL>@(#)12.0.0.0 $Revision$


# Fonction de changement statut lots re-controle SAISTOLTI
###########################################################
$ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub OUVRE
  When "EXEC"           : Gosub EXEC_STAPER
  When "TERMINE"        : Gosub TERMINE_STAPER
  When "INIT_DIA"       : Gosub INIT_DIA_STAPER
  When "TIT_DIA"        : [M:DIA]NBLIG=  GDIANBLIG   # hcb 79438
  When "CONTROLE"       : Gosub OK_STAPER
  When "CONT_BATCH"     : Gosub OK_STAPER
  When "END"            : Gosub END_STAPER
Endcase
Return

#############################################################
$OUVRE
Gosub OPEN_FILE From SUBLTIB
Return


############################################################
# Met à jour les statuts sur les lignes de stock
############################################################
$EXEC_STAPER
Global Integer GSTOPRET
If [M:DIA]STOFCY <> ""
    # modif pour permettre une date de reference nulle en saisie
    # Quand elle est nulle on prend la date du jour
    Local Char WFIL(150)
    Raz WFIL
    #--- Bug 80121 (suppression du = )
    If [M:DIA]REFDAT=[0/0/0]
       WFIL += "[F:STLP]NEWLTIDAT < (date$)"
    Else
       WFIL += "[F:STLP]NEWLTIDAT<([M:DIA]REFDAT)"
    Endif
    Gosub TRAITEMENT
Endif
Kill GSTOPRET
Return
############################################################
$TERMINE_STAPER
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
Return
############################################################
$INIT_DIA_STAPER

Gosub OPEN_FILE From SUBLTIB
Raz [M:DIA]
[M:DIA]STOFCY = GFCYDEF(7)          # hcb 79438
[M:DIA]IPTDAT = date$
[M:DIA]REFDAT = date$
[M:DIA]SIMFLG = 2
Raz GSCSNUM                # hcb 50197
Gosub LOA_STATUTS From FUNSTOLTI
Global Integer GDIANBLIG   # hcb 79438
GDIANBLIG = [M:DIA]NBLIG   # hcb 79438
Affzo [M:DIA]
Return
############################################################
$OK_STAPER
For J = 0 To 5    # On fait 6 tentatives maxi
    Gosub MAJ_TST  From SUBLTIB
    If GOK = 1
        Break
    Endif
Next J
FIN  = (GOK<>1)    # On continue uniquement si l'enregistrement s'est bien passé
If FIN
    Call FSTA("TST") From GLOCK
Endif
Return
############################################################
$END_STAPER
Raz [M:DIA]
FIN = 1
Return
############################################################
$TRAITEMENT
Local Char    WFCY
Local Date    WDAT
Local Integer WTAB
Local Integer WSIM
Local Integer LRET
Local Integer I, J
Local Char    WSTA(GLONSTA)
Local Char    WMSG(120)
Local Integer WBAT
#--- GSINTEMP sert à savoir si les emplacements sont gérés ---#
Read [ACV]CODACT="EMP"
If fstat = 0 & [F:ACV]FLACT = 1
  GSINTEMP = ""
Else
  GSINTEMP = mess(44,197,1)
Endif

#--------------- Début du traitement --------------------#
If [M:DIA]SIMFLG = 2
  If [M:DIA]REFDAT <> [0/0/0]
     WMSG = mess(2,395,1)-mess(947,196,1)+" : "+num$([M:DIA]REFDAT)+" / "-[M:DIA]STOFCY
  Else
     WMSG = mess(2,395,1)-mess(947,196,1)+" : "-mess(311,184,1)+" / "-[M:DIA]STOFCY
  Endif
Else
  If [M:DIA]REFDAT <> [0/0/0]
      WMSG = mess(947,196,1)+" : "+num$([M:DIA]REFDAT)+" / "-[M:DIA]STOFCY
  Else
      WMSG = mess(947,196,1)+" : "-mess(311,184,1)+" / "-[M:DIA]STOFCY
  Endif
Endif
If GSERVEUR
  Onerrgo ERRBATCH From SUBLTIB
  Call ECR_TRACE(WMSG,0,0)  From SUBLTIB
Else
  Call OUVRE_TRACE(WMSG) From LECFIC
  Call ECR_TRACE(WMSG,0,0) From SUBLTIB
Endif

#
WFCY = [M:DIA]STOFCY
WDAT = [M:DIA]REFDAT
WSIM = [M:DIA]SIMFLG
Call TRTCHG(WFCY,WFIL,WSIM,LRET) From FUNSTOLTI
Return

###########################################################
# Chargement du tableau de correspondance des statuts
###########################################################
$LOA_STATUTS
Local Char WSTAQ(GLONSTA), WSTAR(GLONSTA)
Call TEMPON("O") From GESECRAN

[M:DIA]NBLIG = 0
Local Char WFIL(50)
Raz WFIL
#--- Bug 80121 (suppression du = )
If [M:DIA]REFDAT=[0/0/0]
   WFIL += "[F:STLP]NEWLTIDAT < (date$)"
Else
   WFIL += "[F:STLP]NEWLTIDAT<([M:DIA]REFDAT)"
Endif

Link [STLP] With [SLF]SLF0(3)=[F:STLP]ITMREF;[F:STLP]LOT;[F:STLP]SLO,[F:ITM]ITM0=[F:STLP]ITMREF
&           As [LNK]
&           Where evalue(WFIL)
&                 & [F:SLF]AAACUMQTY <> 0
&                 & [F:SLF]STOFCY    =  [M:DIA]STOFCY
&           Order By Key STL3
For [LNK]
    Gosub LEC_STOCK
Next
Filter [STLP]
Affzo [M:DIA]1-99
# Mise à jour statuts péremption
If [M:DIA]NBLIG > 0
  For J = 0 To 5    # On fait 6 tentatives maxi
    Gosub MAJ_TST  From SUBLTIB
    If GOK = 1
      Break
    Endif
  Next J
Endif
Call TEMPOFF From GESECRAN
Return

###########################################################
# Pour chaque ligne de stock, ajoute au tableau
# les correspondances de statut
###########################################################
$LEC_STOCK
Columns [STOP] (STA)
Filter [STOP] Where ITMREF = [F:STLP]ITMREF  &
&                   STOFCY = [M:DIA]STOFCY   &
&                   LOT    = [F:STLP]LOT     &
&                   SLO    = [F:STLP]SLO     &
&                   QTYSTU <> 0              &
&                   left$(STA,1) = "A"
For [STOP]
  I = find([F:STOP]STA,[M:DIA]STASTO(0..[M:DIA]NBLIG-1))
  If I = 0
    If [M:DIA]NBLIG < dim([M:DIA]STASTO)-1
      Read [TST]TST0=[F:STOP]STA
      If fstat
          Raz [TST]
      Else
          WSTAQ = [F:TST]EXYQQQSTA
          WSTAR = [F:TST]EXYRRRSTA
      Endif
      [M:DIA]STASTO([M:DIA]NBLIG) = [F:STOP]STA
      Call GET_ATEXTRA("TABSTASTO","STAAXX",GLANGUE,[M:DIA]STAAXX([M:DIA]NBLIG)) From TRTX3TEX
      Read [TST]TST0=WSTAQ
      If fstat
          WSTAQ = "Q"+mid$([F:STOP]STA,2,2)
          Read [TST]TST0=WSTAQ
      Endif
      If fstat
        [M:DIA]NEWSTAQQQ([M:DIA]NBLIG) = "Q"
        # FGR 15/01/2010 : X3SUIVI60986
        #[M:DIA]SHOQQQAXX([M:DIA]NBLIG) = mess(2,265,1)
        [M:DIA]SHOAXXQQQ([M:DIA]NBLIG) = mess(2,265,1)
      Else
        [M:DIA]NEWSTAQQQ([M:DIA]NBLIG) = WSTAQ
        Call GET_ATEXTRA("TABSTASTO","STASHOAXX",GLANGUE,[M:DIA]SHOAXXQQQ([M:DIA]NBLIG)) From TRTX3TEX
      Endif
      Read [TST]TST0=WSTAR
      If fstat
          WSTAR = "R"+mid$([F:STOP]STA,2,2)
          Read [TST]TST0=WSTAR
      Endif
      If fstat
        [M:DIA]NEWSTARRR([M:DIA]NBLIG) = "R"
        # FGR 15/01/2010 : X3SUIVI60986
        #[M:DIA]SHORRRAXX([M:DIA]NBLIG) = mess(3,265,1)
        [M:DIA]SHOAXXRRR([M:DIA]NBLIG) = mess(3,265,1)
      Else
        [M:DIA]NEWSTARRR([M:DIA]NBLIG) = WSTAR
        Call GET_ATEXTRA("TABSTASTO","STASHOAXX",GLANGUE,[M:DIA]SHOAXXRRR([M:DIA]NBLIG)) From TRTX3TEX
      Endif
      [M:DIA]NBLIG += 1
    Endif
  Endif
Next
Filter [STOP]
Columns [STOP]
Return
###########################################################
#Traitement re-controle
# LFCY = Site de stockage
# LDAT = Date de péremption de référence
# LSIM = 2 si simulation
# LRET = nombre d'erreurs
#
Subprog TRTCHG(LFCY,WFIL,LSIM,LRET)
Value    Char     LFCY
#Value   Char     LDAT
Value    Char     WFIL
Value    Integer  LSIM
Variable Integer  LRET
#
Local    Decimal  WQTA1
Local    Decimal  WQTQ1
Local    Decimal  WQTR1
Local    Decimal  WQTA2
Local    Decimal  WQTQ2
Local    Decimal  WQTR2
Local    Decimal  WACT
Local    Decimal  WQMV
Local    Char     WSTA(GLONSTA)
Local    Char     WCAL(3)
Local    Char     WANA(15)
Local    Integer  WFSTAT, WDEL, WTDE
Local    Char     WMSG(120)
Local Integer LSEQ
Local Integer LNEW : LNEW = 1   #-- On force la création de nouvelles lignes de doc à chaque ligne de stock
Local Integer LVCRLIN
Local Char    WWRH(GLONWRH)

Local Date LFILSHL            : Raz LFILSHL
Local Char LFILITM(GLONITM)   : Raz LFILITM
Local Char LFILLOT(GLONLOT)   : Raz LFILLOT
Local Char LFILSLO(GLONSLO)   : Raz LFILSLO
Local Integer LSTOCOU         : Raz LSTOCOU

Local Date LSAVSHL            : Raz LSAVSHL
Local Char LSAVITM(GLONITM)   : Raz LSAVITM
Local Char LSAVLOT(GLONLOT)   : Raz LSAVLOT
Local Char LSAVSLO(GLONSLO)   : Raz LSAVSLO
Local Integer LSAVCOU         : Raz LSAVCOU

Local Integer LSTOP : Raz LSTOP

If !clalev([SCS1]) : Local Mask SCS1       [SCS1] : Endif
If !clalev([SGW])  : Local Mask STOCHGW    [SGW]  : Endif
If !clalev([STW])  : Local Mask STOWORK    [STW]  : Endif
If !clalev([SVW])  : Local Mask STOVALWORK [SVW]  : Endif
If !clalev([SVWD]) : Local Mask STOVALWORK [SVWD] : Endif   # Issue 76853 - 2011-10-05 by CCC

Raz [M:SCS1]
Raz [M:SGW]
Raz [M:STW]
Gosub INIT_SCS1
#MAE, bg 78860
Call GETDEV(LFCY) From DEVSUB    #--> renseigne GTYPGEN
[F:SRT]CHGEMPCOD = 1
[F:SRT]CHGSTACOD = 2
[F:SRT]CHGPCUCOD = 1
[F:SRT]PRNCOD1   = 1
Global Integer GSCSTRACE
Raz GSCSTRACE
GSCSTRACE = 4
Local Integer LDEBUG : LDEBUG=1
#
Gosub OPEN_FILE From SUBLTIB
Gosub STK_INILOC From STKLOC
LRET = 0
#
Local Integer LFIRST : LFIRST=1
Call TEMPON("O") From GESECRAN
#---------- A chaque tour on crée un nouveau document ----------#
While !LSTOP
    LSTOP = 1
    Default Mask [SCS1]
    Gosub INIT_SCS1

    LSAVITM = LFILITM
    LSAVLOT = LFILLOT
    LSAVSLO = LFILSLO
    LSAVSHL = LFILSHL
    LSAVOCU = LSTOCOU
    LVCRLIN = 0


# hcb v6per rajout ITM dans le link et evalue WFIL
    If [M:DIA]DOCITMFLG=2
        Link [STLP] With [SLFP]SLF0~=[F:STLP]ITMREF;[F:STLP]LOT;[F:STLP]SLO;LFCY,[F:ITM]ITM0=[F:STLP]ITMREF
&                   As [LNK]
&                   Where evalue(WFIL) & [F:SLFP]AAACUMQTY <> 0
&                         &( ([F:STLP]ITMREF=LFILITM & [F:STLP]LOT=LFILLOT & [F:STLP]SLO=LFILSLO & [F:STLP]NEWLTIDAT > LFILSHL)
&                          | ([F:STLP]ITMREF=LFILITM & [F:STLP]LOT=LFILLOT & [F:STLP]SLO>LFILSLO)
&                          | ([F:STLP]ITMREF=LFILITM & [F:STLP]LOT>LFILLOT )
&                          | ([F:STLP]ITMREF>LFILITM) )
&                   Order By ITMREF;LOT;SLO;NEWLTIDAT

    Else
        Link [STLP] With [SLFP]SLF0~=[F:STLP]ITMREF;[F:STLP]LOT;[F:STLP]SLO;LFCY,[F:ITM]ITM0=[F:STLP]ITMREF
&                   As [LNK]
&                   Where evalue(WFIL) & [F:SLFP]AAACUMQTY <> 0
&                         &( [F:STLP]NEWLTIDAT = LFILSHL & [F:STLP]ITMREF=LFILITM & [F:STLP]LOT=LFILLOT & [F:STLP]SLO>LFILSLO
&                          | [F:STLP]NEWLTIDAT = LFILSHL & [F:STLP]ITMREF=LFILITM & [F:STLP]LOT>LFILLOT
&                          | [F:STLP]NEWLTIDAT = LFILSHL & [F:STLP]ITMREF>LFILITM
&                          | [F:STLP]NEWLTIDAT > LFILSHL)
&                   Order By NEWLTIDAT;ITMREF;LOT;SLO

    Endif
    For [LNK]
        #-- Si 1 seul article par doc
        # + si article en cours<> article précédent
        # + si article précédent<>""
        # + si pas premier tour dans la boucle
        If [M:DIA]DOCITMFLG=2 & LFILITM<>[STLP]ITMREF & LFILITM<>"" & LSTOP=0
            Break
        Endif
        LSTOP = 0
        WFSTAT = fstat
        Gosub TRT_STOCK
        fstat = WFSTAT
        If GSTOPRET=2
            Raz GSTOPRET
            Break
        Endif
        LFILSHL = [F:STLP]NEWLTIDAT
        LFILITM = [F:STLP]ITMREF
        LFILLOT = [F:STLP]LOT
        LFILSLO = [F:STLP]SLO
    Next
    Filter [STLP]

    If LFILITM = LSAVITM
&    & LFILLOT = LSAVLOT
&    & LFILSLO = LSAVSLO
&    & LFILSHL = LSAVSHL
&    & LSTOCOU = LSAVCOU
        LSTOP = 1    # Test pour éviter une boucle infinie
    Endif
    #--- Enregistrement du doc Changement de statut ----#
    #--- via les actions objets                     ----#
    If LSIM<>2 & [M:SCS1]NBLIG>0
        Call TEMPOFF From GESECRAN
        Local Char ABREV(10) : ABREV="SCS"
        Gosub DEFVAR From GOBJET
        GOBJET     = 1
        GORITITCOL = 0
        GABREV     = ABREV
        GPROGRAMME = "GOBJSUB"
        GTRAITE    = "GOBJET"
        Call NOMTRTWIN("O"+ABREV,WINPROG) From MSKDIV
        Gosub DEFVAR From =WINPROG

        Gosub CREATION From GOBJET1
    Else
        Raz GOK
    Endif

    If !GOK
        Call DELSTOCHGW("SCS1", [M:SCS1]STOFCY, -1, -1, 1, LRET) From SUBSCSB
    Endif
    Raz [M:SCS1]
    Raz [M:SGW]
    Raz [M:STW]
Wend
Call TEMPOFF From GESECRAN # Au cas où...
End

###########################################################
$INIT_SCS1
[M:SCS1]VCRTYP = 29 # Changement stock
Call TEXTE(8424,[M:SCS1]VCRDES) From OBJDIV
[M:SCS1]STOFCY = LFCY
[M:SCS1]FCYDES = LFCY
[M:SCS1]BETCPY = 1
[M:SCS1]BETFCYCOD = 1
If [M:DIA]DATJOUR = 2
   [M:SCS1]IPTDAT = date$
Else
   [M:SCS1]IPTDAT = [M:DIA]IPTDAT
Endif
[M:SCS1]MISFLG = 9  # (ORIGINE re-controle pour creer STOQLYH avec fiche technique de re-controle)

[M:SGW]TRSTYP  = 0    # Changement de statut uniquement
[M:SGW]FCYDES  = [M:SCS1]FCYDES

Return
###########################################################
#Mise a jour nouveaux statuts
$TRT_STOCK
[F:SRT]CHGEMPCOD = 1           # hcb 50197
[F:SRT]CHGSTACOD = 2
[F:SRT]CHGPCUCOD = 1
[F:SRT]PRNCOD1   = 1
Look [ITF]ITF0=[F:STLP]ITMREF;[M:DIA]STOFCY
If fstat : Return : Endif
#Lecture article maitre
If [F:ITM]ITMREF<>[F:STLP]ITMREF
    Read [ITM]ITM0=[F:STLP]ITMREF
    If fstat
      WMSG = mess(49,125,1)+" [ITM] : "+[F:ITM]ITMREF
      Call ECR_TRACE(WMSG,1,LSIM) From SUBLTIB
      Return
    Endif
Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [M:DIA]STOFCY | [F:ITF]ITMREF <> [F:STLP]ITMREF
   Read [ITF]ITF0 = [F:STLP]ITMREF;[M:DIA]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif


#Pas de traitement des articles sans péremption
If [F:ITM]EXYMGTCOD = 1
  WMSG = [F:ITM]ITMREF+" : "+mess(143,199,1)
  Call ECR_TRACE(WMSG,1,LSIM) From SUBLTIB
  Return
Endif

#Pas de traitement  Article bloqué pour inventaire
If [F:ITF]CUNFLG = 2
    WMSG = [F:ITM]ITMREF+" : "+mess(185,199,1)
   Call ECR_TRACE(WMSG,1,LSIM) From SUBLTIB
   Return
Endif

#Pas de traitement  pour les Article-site sans statut re-controle
If [F:ITF]NEWLTISTA = "" & [F:ITF]SHLLTI <> 0                             # hcb  116974
    WMSG = [F:ITM]ITMREF+" : "+mess(537,199,1)
   Call ECR_TRACE(WMSG,1,LSIM) From SUBLTIB
   Return
Endif

#Lecture cumuls article site
Call LECITV(LFCY,[F:ITM]ITMREF,"",LRET) From STKLIB
If LRET > 1
  WMSG = mess(49,125,1)+"[ITV] : "+[F:ITM]ITMREF-LFCY
  Call ECR_TRACE(WMSG,1,LSIM) From SUBLTIB
  Return
Endif

# Relecture lot
Readlock [STLP] Curr
If fstat
  WMSG = mess(20,100,1)+" [STL] : "+[F:STLP]ITMREF-[F:STLP]LOT
  Call ECR_TRACE(WMSG,1,LSIM) From SUBLTIB
  Return
Endif

GPOINT = "CTRBEFTRT"
GPE    = 0
Gosub  ENTREE From EXEFNC
If GPE <> 0
   Return
Endif

#Calcul coefficient activité
Case [F:ITF]STOMGTCOD
  When 3       : WACT = ([F:STLP]POT/100)
  When 4       : WACT = [F:STLP]ACT
  When Default : WACT = 1
Endcase
Raz WQTA1, WQTQ1, WQTR1, WQTA2, WQTQ2, WQTR2
#Traitement lignes du lot
GOK  = 1
WANA = ""

Filter [STOP] Where STOFCY = LFCY
&                 & STOCOU > LSTOCOU
&                 & ITMREF = [F:STLP]ITMREF
&                 & LOT    = [F:STLP]LOT
&                 & SLO    = [F:STLP]SLO
&                 & QTYSTU <> 0
&                 & left$(STA,1) = "A"
For [STOP]
    #--- Pour éviter le message "STOCHGW tableau plein"             -----#
    #--- Pour chaque changement de statut il faut 2 lignes dans SGW -----#
    If [M:SGW]NBLIG>=dim([M:SGW]WSTOSEQ)-2
        GSTOPRET = 2
        Break
    Endif
    If [M:SCS1]NBLIG>=dim([M:SCS1]ITMREF)-1
        Break
    Endif
    If [M:SCS1]NBLIG=0 & [M:SGW]NBLIG>0    #--- pour éviter de perdre des lignes dans SGW inutilement ----#
        Raz [M:SGW]
        Gosub INIT_SCS1
    Endif
  # On vérifie d'abord que l'enregistrement n'est pas locké
  Readlock [STO]STO0=[F:STOP]STOFCY;[F:STOP]STOCOU
  If fstat
    WMSG = mess(20,100,1)+" [STO] : "+[F:STOP]STOFCY-num$([F:STOP]STOCOU)-"("+[F:STOP]ITMREF+" / "+[F:STOP]LOT+" / "+[F:STOP]SLO+")"
    Call ECR_TRACE(WMSG,1,LSIM)  From SUBLTIB
    GOK = 0
    Break
  Endif
  Unlock [STO]
#Pas de traitement si quantité allouées
  If [F:STOP]CUMALLQTY <> 0 | [F:STOP]CUMWIPQTY <> 0
    WMSG = [F:STOP]ITMREF+" / "+[F:STOP]LOT+" "+
&          format$(GFMDAT4,[F:STLP]NEWLTIDAT)+" "+format$("K:3X",[F:STOP]STA)+
&          " : "+mess(142,199,1)
    Call ECR_TRACE(WMSG,1,LSIM) From SUBLTIB
  Else
    WMSG = [F:STOP]ITMREF+" / "+[F:STOP]LOT+" "+
&          format$(GFMDAT4,[F:STLP]NEWLTIDAT)+" "+
&          mess(79,196,1)+ " : "+format$("K:3X",[F:STOP]STA)+"/"

#Cumul zones travail ancien statut
    Case left$([F:STOP]STA,1)
      When "A" :
        WQTA1 += ([F:STOP]QTYSTU*WACT)
      When "Q" :
        WQTQ1 += ([F:STOP]QTYSTU*WACT)
      When "R" :
        WQTR1 += ([F:STOP]QTYSTU*WACT)
    Endcase
#--------------------------------------------------------------------#
#--------------------------------------------------------------------#
#--------------------------------------------------------------------#
# Algo:
# Charger SCS1 avec la ligne de stock
# Modifier le statut
# Contrôler l'emplacement
#  -> si pas bon: supprimer la ligne de SCS1 (et de STOCHGW)
#  -> si bon: traitement de fin de ligne
# Après la boucle mise à jour de la table lot et de ITV
# Lancer l'enregistrement
#--------------------------------------------------------------------#
#--------------------------------------------------------------------#
#--------------------------------------------------------------------#
    nolign = [M:SCS1]NBLIG+1
    Call STKWSTOSEQ ("SCS1", [M:SCS1]NBLIG, [M:SCS1]NBLIG, 2, LSEQ, LRET) From STKECR
    OK=1
#                                                                            # hcb X3-63996 deb
    If [F:ITM]SERMGTCOD = 4
       Gosub NEW_STATUTH
    Endif
#                                                                            # hcb X3-63996 fin
    Gosub ALI_DOC From SUBSCSB
    If OK=0 mkstat=2 Endif
    If GSTOPRET=2 | left$([F:ITF]NEWLTISTA,1)= "A" | GSTOPRET = 9                                          # hcb 110327
       Call DEPICK([F:STOP]STOFCY, [F:STOP]STOCOU, "SCS1", LRET) From SUBSCSB
       If GSTOPRET=9                                                                                       # hcb 110327
          Goto NEXSTOP                                                                                     # hcb 110327
       Else                                                                                                # hcb 110327
          Break
       Endif                                                                                               # hcb 110327
    Endif
    LVCRLIN+=1000
    [M:SCS1]VCRLIN(nolign-1) = LVCRLIN

    Gosub NEW_STATUT
    #--- Contrôle emplacement valide avec nouveau statut
    If GSINTEMP <> "" & [F:STOP]LOC <> ""
        [M:SCS1]LOCTYPDES(nolign-1) = [M:SCS1]LOCTYP(nolign-1)
        [M:SCS1]LOCDES(nolign-1)    = [M:SCS1]LOC(nolign-1)
        Call STKMODREMP([M:SCS1]WLOCSEQ(nolign-1),
&                       [M:SCS1]FCYDES,
&                       [M:SCS1]ITMREF(nolign-1),
&                       [M:SCS1]PCU(nolign-1),
&                       [M:SCS1]QTYPCU(nolign-1),
&                       [M:SCS1]STA(nolign-1),
&                       [M:SCS1]LOC(nolign-1),
&                       "",
&                       mkstat,
&                       "") From STKLOC
        If !mkstat
            If dim([M:SCS1]WRHDES) > 0
               WWRH=[M:SCS1]WRHDES(nolign-1)
            Else
               WWRH=""
            Endif
            Call STKCTREMP([M:SCS1]WLOCSEQ(nolign-1),
&                          [M:SCS1]TRSTYP,
&                          [M:SCS1]TRSCOD,
&                          [M:SCS1]FCYDES,
&                          [M:SCS1]ITMREF(nolign-1),
&                          [M:SCS1]PCUDES(nolign-1),
&                          [M:SCS1]QTYPCUDES(nolign-1),
&                          [M:SCS1]STADES(nolign-1),
&                          [M:SCS1]LOCTYPDES(nolign-1),
&                          [M:SCS1]LOCDES(nolign-1),
&                          "",
&                          0,
&                          mkstat,
&                          GBIDD1,
&                          "",
&                          "LOCCAT<=2",
&                          WWRH) From STKLOC
        Endif
    Endif

    WMSG = [F:STOP]ITMREF-"/"-[F:STOP]LOT-[F:STOP]SLO-GSINTEMP-[F:STOP]LOC-[F:STOP]STA
    WMSG = WMSG-[M:SCS1]STADES(nolign-1)-"("+[M:SCS1]PCU(nolign-1)-num$([M:SCS1]QTYPCU(nolign-1))+")"
    If mkstat
        Call DEPICK([F:STOP]STOFCY, [F:STOP]STOCOU, "SCS1", LRET) From SUBSCSB
        WMSG -= mess(117,184,1)
        Call ECR_TRACE(WMSG,1,LSIM) From SUBLTIB
    Else
        Call TEXTE(33859,[M:SCS1]MVTDES(nolign-1)) From OBJDIV     # hcb 79136
        [M:SCS1]MVTDES(nolign-1) -= num$([F:STLP]NEWLTIDAT)        # hcb 79295
        Call OUVCHG("SCS1", nolign-1, [M:SCS1]STOFCY) From SUBSCSB
        If GOUVENT | GSTOPRET=2 | [M:SCS1]WSTOFLG(nolign-1)=0
            Call DEPICK([F:STOP]STOFCY, [F:STOP]STOCOU, "SCS1", LRET) From SUBSCSB
            If GSTOPRET=2        #-- SGW plein --#
                Break
            Endif
            WMSG -= mess(117,184,1)    # A priori il ne peut y avoir qu'un problème emplacement/statut
            Call ECR_TRACE(WMSG,1,LSIM) From SUBLTIB
        Else
            LSTOCOU = [F:STOP]STOCOU
            Call ECR_TRACE(WMSG,0,LSIM) From SUBLTIB
        Endif
    Endif
#Cumul zones travail nouveau statut
    Case left$([M:SCS1]STADES(nolign-1),1)
      When "A" :
        WQTA2 += ([M:SCS1]QTYSTUDES(nolign-1)*WACT)
      When "Q" :
        WQTQ2 += ([M:SCS1]QTYSTUDES(nolign-1)*WACT)
      When "R" :
        WQTR2 += ([M:SCS1]QTYSTUDES(nolign-1)*WACT)
    Endcase
  Endif
$NEXSTOP                                                                                     # hcb 110327
Next
Filter [STOP]
If !GSTOPRET
    Raz LSTOCOU    # On en a fini avec ce lot/sous-lot => raz de Lstocou
Endif
Return
###########################################################
$NEW_STATUT

Local Integer  LRET
Call LECSRU([M:SCS1]STOFCY,[F:ITM]TCLCOD,26,[M:SCS1]TRSCOD,"",LRET)
&             From STKLIB
If LRET<>0
   mkstat=2
Endif

Read [TST]TST0=[F:STOP]STA
  If fstat = 0
    [M:SCS1]QLYCTLFLG(nolign-1)=[F:SRU]QLYCTLFLG
    Case left$([F:ITF]NEWLTISTA,1)
      When "Q" :
        If [F:TST]EXYQQQSTA <> ""
          [M:SCS1]STADES(nolign-1) = [F:TST]EXYQQQSTA
        Else
          WSTA = "Q"+right$([F:STOP]STA,2)
          Read [TST]TST0=WSTA
            If  fstat = 0
              [M:SCS1]STADES(nolign-1) = WSTA
            Else
              [M:SCS1]STADES(nolign-1) = "Q"
            Endif
        Endif
        [M:SCS1]QLYCTLFLG=[F:SRU]QLYCTLFLG
      When "R" :
        If [F:TST]EXYRRRSTA <> ""
          [M:SCS1]STADES(nolign-1) = [F:TST]EXYRRRSTA
        Else
          WSTA = "R"+right$([F:STOP]STA,2)
          Read [TST]TST0=WSTA
            If  fstat = 0
              [M:SCS1]STADES(nolign-1) = WSTA
            Else
              [M:SCS1]STADES(nolign-1) = "R"
            Endif
        Endif
    Endcase
#                                             # hcb 112557 deb
    GPOINT = "NEWSTATUT"
    Gosub  ENTREE From EXEFNC
#                                             # hcb 112557 fin

  Endif
Return

#                                                                            # hcb X3-63996 deb
$NEW_STATUTH

Local Integer  LRET
Call LECSRU([M:SCS1]STOFCY,[F:ITM]TCLCOD,26,[M:SCS1]TRSCOD,"",LRET)
&             From STKLIB
If LRET<>0
   mkstat=2
Endif

Read [TST]TST0=[F:STOP]STA
  If fstat = 0
    Case [F:ITM]EXYSTA
      When "Q" :
        If [F:TST]EXYQQQSTA <> ""
           [M:SCS1]STADESH = [F:TST]EXYQQQSTA
        Else
          WSTA = "Q"+right$([F:STOP]STA,2)
          Read [TST]TST0=WSTA
            If  fstat = 0
                [M:SCS1]STADESH = WSTA
            Else
                [M:SCS1]STADESH = "Q"
            Endif
        Endif
      When "R" :
        If [F:TST]EXYRRRSTA <> ""
           [M:SCS1]STADESH = [F:TST]EXYRRRSTA
        Else
          WSTA = "R"+right$([F:STOP]STA,2)
          Read [TST]TST0=WSTA
            If  fstat = 0
                [M:SCS1]STADESH = WSTA
            Else
                [M:SCS1]STADESH = "R"
            Endif
        Endif
    Endcase
  Endif
Return
#                                                                            # hcb X3-63996 deb

