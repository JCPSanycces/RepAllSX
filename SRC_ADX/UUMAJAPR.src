#<AdxTL>@(#)11.0.0.0 $Revision$
##############################################################################
## Prise ne compte des textes sous format éditeur html dans l'objet APR
##############################################################################
Call OUVRE_TRACE("Update processus description text") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Gosub MAJ
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

$MAJ
Local Integer ERR
Local Char LIBF1(50)
Local Clbfile CLB1(2)
Local File =DOSSIER+".APROCESSUS" [APR_] 
 Local File =DOSSIER+".ADOCUMENT" [ADO]
 Local File =DOSSIER+".ADOCCLB"   [ADH]

Trbegin [ADO],[ADH],[APR_]
For [APR_]
  If [F:APR_]CODLEG=""
    Call ECR_TRACE("Update text for"-[F:APR_]CODPRO,ERR) From GESECRAN
  Else
  Call ECR_TRACE("Update text for"-[F:APR_]CODPRO-"---"-[F:APR_]CODLEG,ERR) From GESECRAN
  Endif
  If [F:APR_]DESCR<>""
    CLB1=[F:APR_]DESCR
    Call LECTEXTRA(LIBF1,"APROCESSUS","INTIT1",[F:APR_]CODPRO,"") From ATEXTRA
    # JPGA 27-27-2010 BUG-66277 : ECRIRE_DOC 2 parametres ajoutes : Module et Code activité
    # Call ECRIRE_DOC("APR",[F:APR_]CODPRO+"_"+[F:APR_]CODLEG,CLB1,LIBF1) From SUBADO
    [F:APR_]DESCR=""
    Rewrite [APR_]
  Endif
Next
Commit

Return



