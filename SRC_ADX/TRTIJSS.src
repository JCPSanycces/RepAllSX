#<AdxTL>@(#)1.0.0.0 $Revision$
# Gestion du masque TRTIJSS
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTIJSS","TRTIJSS",4,"") From GTRAITE
End

#########################################
## Traitement des actions : TRTIJSS
#########################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
 When "OK"          : Gosub OK
 When "END"         : FIN = 1
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "BOUTON"      : Gosub BOUTON :#81085
Endcase
Return


#########################################
$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Gosub OUVFIC

Local Char    VALPAR(10), NOMPAR(GLONADP)
Local Char    MALSALAIRE(GLONVRA), MATSALAIRE(GLONVRA), ATSALAIRE(GLONVRA)
Local Char    MALNBLIG(GLONVRA), MATNBLIG(GLONVRA), ATNBLIG(GLONVRA)
Local Char    ATJOURS(GLONVRA), MALJOURS(GLONVRA),MATJOURS(GLONVRA)
Local Char    TEMSUBRO(GLONVRA)
Local Char    CRITERE1(250), CRITERE2(250)
#57223
Local Char    CRITVEP(250)

Local Char    MATRI(GLONEML), CTR(GLONHRCTR)
Local Date    DATMAT
Local Integer NBPCE , FLGAT, I, COK
Local Decimal RESULTAT
Local Char    SYMBOLE(80)

TIT = mess(35,10710,1)     : # Déversement des attestations dans la paie

Local Mask TRTIJSS [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","ijss") From GMEMO
Call AFF_MEMO From DIVPAYE: #81085
#70778
#If GPILNAV>1
# Case GNAVIG(GPILNAV-1)
If GPILNAV>0
 Case GNAVIG(GPILNAV)
  When "GESMAL"
   Raz [M:DIA]
   [M:DIA]MATDEB    = [M:MAL0]REFNUM
   [M:DIA]MATFIN    = [M:MAL0]REFNUM
   [M:DIA]STRDAT    = [M:MAL0]DAT
   [M:DIA]ENDDAT    = [M:MAL0]DAT
   [M:DIA]TYPATTMAL = 2
   [M:DIA]TYPATTAT  = 1
  When "GESTAT"
   Raz [M:DIA]
   [M:DIA]MATDEB    = [M:TAT0]REFNUM
   [M:DIA]MATFIN    = [M:TAT0]REFNUM
   [M:DIA]STRDAT    = [M:TAT0]DAT
   [M:DIA]ENDDAT    = [M:TAT0]DAT
   [M:DIA]TYPATTMAL = 1
   [M:DIA]TYPATTAT  = 2
 Endcase
Endif
Return

######################################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

######################################################
$DEBUT
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
#86255
GCURLEG="FRA"
If dim([M:DIA]LEG)>0 : [M:DIA]LEG=GCURLEG : Endif
Affzo [DIA]
Setmok [DIA] With 0
Call AFF_MEMO From DIVPAYE: #81085
#71386
#If GPILNAV>0
If GPILNAV>1
 Grizo [M:DIA]5-10
 Grizo [M]ALLPRF
Endif

Return

#81085
######################################################
$BOUTON
Case BOUT
  When "R" :
   # Button "Rappel MEMO"
   Call AFF_MEMO From DIVPAYE
Endcase
Return

######################################################
$OUVFIC
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:HRTAT])=0  : Local File TABAT      [HRTAT]  : Endif
If clalev([F:TAT2])=0 : Local File TABAT      [TAT2] : Endif
If clalev([F:MAL])=0  : Local File MALADIE    [MAL]  : Endif
If clalev([F:MAL2])=0 : Local File MALADIE    [MAL2] : Endif
If clalev([F:HRPOA])=0  : Local File POPULA     [HRPOA]  : Endif
If clalev([F:ECT])=0  : Local File EMPCTR     [ECT]  : Endif
If clalev([F:VEP])=0  : Local File VALEMP     [VEP]  : Endif
If clalev([F:VLA])=0  : Local File VALEUR     [VLA]  : Endif
Gosub OUVRE From WPDEFTABLE
Return

#########################################
$OK
If [M:DIA]TYPATTMAL<>2 & [M:DIA]TYPATTAT<>2
 GERR = 1 : FIN = 0
 # Il faut saisir au moins un type d'attestation
 GMESSAGE = mess(36,10710,1)
 Return
Endif
Return

#########################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

#########################################
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
NBPCE = 0

Gosub RECUP_PARAM

CRITERE1 = "[F]STAATT=2"
# Borne matricules
If [M:DIA]MATDEB<>"" : CRITERE1 -= '& [F]REFNUM>="'+[M:DIA]MATDEB+'"' : Endif
If [M:DIA]MATFIN<>"" : CRITERE1 -= '& [F]REFNUM<="'+[M:DIA]MATFIN+'"' : Endif
# Bornes dates d'arrêt
If [M:DIA]STRDAT<>[0/0/0] : CRITERE1 -= '& [F]DAT>=['+format$(GFMD,[M:DIA]STRDAT)+']' : Endif
If [M:DIA]ENDDAT<>[0/0/0] : CRITERE1 -= '& [F]DAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']' : Endif

CRITERE2 = "1=1"
If [M:DIA]ALLCPY<>2 : CRITERE2 -= '& [F:FCY]LEGCPY="'+[M:DIA]CPY+'"' : Endif
If [M:DIA]ALLFCY<>2 : CRITERE2 -= '& [F:ECT]FCY="'+[M:DIA]FCY+'"'    : Endif
If [M:DIA]ALLSRV<>2 : CRITERE2 -= '& [F:ECT]SRV="'+[M:DIA]SRV+'"'    : Endif
If [M:DIA]ALLPRF<>2 : CRITERE2 -= '& [F:ECT]PRF="'+[M:DIA]PRF+'"'    : Endif

#57223
CRITVEP = "1=1"
If [M:DIA]FLGVAR=2    : CRITVEP -= '& [F:VEP]FLGVAR <> 2'  : Endif
If [M:DIA]FLGPRFSUP=2 : CRITVEP -= '& [F:VEP]PRFSUP = "" ' : Endif

If [M:DIA]TYPATTMAL=2
#86255
# If [M:DIA]POP<>""
#  Link [MAL] With
#&    [ECT]ECT0=[F:MAL]REFNUM;[F:MAL]CTRNUM
#& ,  [FCY]FCY0=[F:ECT]FCY
#& ,  [HRPOA]POA0=[M:DIA]POP;[F:MAL]REFNUM
#&    As [LNK]
#&    Where evalue(CRITERE1) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
#&    Order By [F:MAL]REFNUM;[F:MAL]CTRNUM;[F:MAL]DAT
# Else
#  Link [MAL] With
#&    [ECT]ECT0=[F:MAL]REFNUM;[F:MAL]CTRNUM
#& ,  [FCY]FCY0=[F:ECT]FCY
#&    As [LNK]
#&    Where evalue(CRITERE1) & evalue(CRITERE2)
#&    Order By [F:MAL]REFNUM;[F:MAL]CTRNUM;[F:MAL]DAT
# Endif
If [M:DIA]POP<>""
  Link [MAL] With
&    [ECT]ECT0=[F:MAL]REFNUM;[F:MAL]CTRNUM
& ,  [FCY]FCY0=[F:ECT]FCY
& ,  [HRPOA]POA0=[M:DIA]POP;[F:MAL]REFNUM;[F:MAL]CTRNUM;[F:MAL]CTRDAT
&    As [LNK]
&    Where evalue(CRITERE1) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
&    Order By [F:MAL]REFNUM;[F:MAL]CTRNUM;[F:MAL]DAT
 Else
  Link [MAL] With
&    [ECT]ECT0=[F:MAL]REFNUM;[F:MAL]CTRNUM
& ,  [FCY]FCY0=[F:ECT]FCY
&    As [LNK]
&    Where evalue(CRITERE1) & evalue(CRITERE2)
&    Order By [F:MAL]REFNUM;[F:MAL]CTRNUM;[F:MAL]DAT
  Endif
 FLGAT = 0 : # Maladie
 Gosub TR1
Endif

If [M:DIA]TYPATTAT=2
 If [M:DIA]POP<>""
  Link [HRTAT] With
&    [ECT]ECT0=[F:HRTAT]REFNUM;[F:HRTAT]CTRNUM
& ,  [FCY]FCY0=[F:ECT]FCY
& ,  [HRPOA]POA0=[M:DIA]POP;[F:HRTAT]REFNUM
&    As [LNK]
&    Where evalue(CRITERE1) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
&    Order By [F:HRTAT]REFNUM;[F:HRTAT]CTRNUM;[F:HRTAT]DAT
 Else
  Link [HRTAT] With
&    [ECT]ECT0=[F:HRTAT]REFNUM;[F:HRTAT]CTRNUM
& ,  [FCY]FCY0=[F:ECT]FCY
&    As [LNK]
&    Where evalue(CRITERE1) & evalue(CRITERE2)
&    Order By [F:HRTAT]REFNUM;[F:HRTAT]CTRNUM;[F:HRTAT]DAT
 Endif
 FLGAT = 1 : # AT
 Gosub TR1
Endif

If !NBPCE
 Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN : # Aucun matricule à traiter
Else
 Call ECR_TRACE(num$(NBPCE)-mess(37,10710,1),0) From GESECRAN : # déversements effectués
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

$RECUP_PARAM
# Recupération des variables de paie à mettre à jour
For [L]NOMPAR="MALSALAIRE","MATSALAIRE","ATSALAIRE","MALNBLIG","MATNBLIG","ATNBLIG","ATJOURS","MALJOURS","MATJOURS","TEMSUBRO"
 Call PARAM("",[L]NOMPAR,VALPAR) From ADOVAL
 If VALPAR=""
  Call ECR_TRACE([L]NOMPAR-mess(1,10710,1),-1) From GESECRAN
 Endif
 Assign [L]NOMPAR With VALPAR
Next
Return

$TR1
Trbegin [VLA],[HRTAT],[MAL]
 For [LNK]
  MATRI  = [F:ECT]REFNUM
  DATMAT = [F:LNK]DAT
  CTR    = [F:ECT]CTRNUM
  Gosub LECEMP From WPDEFTABLE
  Call CONTROLE(MATRI,DATMAT,CTR,[M:DIA]CRI,OK,0) From DIVPAYE
  If OK
   #57223 : Add evalue(CRITVEP)
   ##**82073 et 90775
   Filter [VEP] Where EMP=[F:ECT]REFNUM & CTRNUM=[F:ECT]CTRNUM & PST=1 & ENDDAT>=DATMAT & FLGOUT<>2 & evalue(CRITVEP) :# & STA=1
   Read [VEP]VEP4 Last
   #Filter [VEP]
   If !fstat
#95669
#   Filter [VEP] Where EMP=[F:ECT]REFNUM & CTRNUM=[F:ECT]CTRNUM & PST=1 & ENDDAT>=DATMAT & FLGOUT<>2 & evalue(CRITVEP) & STA=1
#   Read [VEP]VEP4 First
#   If !fstat
#    # Verrouillé US 2022 65062
#    Filter [VEP] Where EMP=[F:ECT]REFNUM & CTRNUM=[F:ECT]CTRNUM & PST=1 & ENDDAT>=DATMAT & FLGOUT<>2 & evalue(CRITVEP) & STA=1 & FLGLOCK<>2
#    Read [VEP]VEP4 First
#    If !fstat
      If [F:VEP]FLGLOCK<>2
       If [F:VEP]STA=1
# end 95669
        # Verrou
        ##**82073
        #SYMBOLE = "VEP"+format$("D:"+GFMDAT4,[F:VEP]PYRDAT)+"\"+[F:VEP]EMP+"\"+[F:VEP]CTRNUM
        Call VEPSYMBOLE (SYMBOLE, "VEP") From DIVPAYE
        Lock =SYMBOLE
        If fstat
         Call ECR_TRACE([F:VEP]EMP-":"-mess(10,100,1),1) From GESECRAN
         OK = 0
        Endif
       Else
        #95669
        #Call ECR_TRACE([F:ECT]REFNUM-[F:ID]NAM-[F:ID]SRN-":"-mess(47,10710,1),1) From GESECRAN
        #Pas de déversement de l'attestation car aucune paie disponible sur la période (paie calculée)
        Call ECR_TRACE([F:ECT]REFNUM-[F:ID]NAM-[F:ID]SRN-":"-mess(44,10710,1),1) From GESECRAN
        #
        OK = 0
       Endif
      Else
       #95669
       #Call ECR_TRACE([F:ECT]REFNUM-[F:ID]NAM-[F:ID]SRN-":"-mess(44,10710,1),1) From GESECRAN
       #Pas de déversement de l'attestation car aucune paie disponible sur la période (paie verrouillée)
       Call ECR_TRACE([F:ECT]REFNUM-[F:ID]NAM-[F:ID]SRN-":"-mess(47,10710,1),1) From GESECRAN
       #
       OK = 0
      Endif
   Else
    Filter [VEP] Where EMP=[F:ECT]REFNUM & CTRNUM=[F:ECT]CTRNUM & PST=1 & FLGOUT=2 & ENDDAT>=DATMAT & evalue(CRITVEP)
    Read [VEP]VEP4 First
    If !fstat
     #Pas de déversement de l'attestation car aucune paie disponible sur la période (paie exclue des attestations)
     Call ECR_TRACE([F:ECT]REFNUM-[F:ID]NAM-[F:ID]SRN-":"-mess(48,10710,1),1) From GESECRAN
    Else
     #Pas de déversement de l'attestation car aucune paie disponible sur la période (paie comptabilisée)
     Call ECR_TRACE([F:ECT]REFNUM-[F:ID]NAM-[F:ID]SRN-":"-mess(34,10710,1),1) From GESECRAN
    Endif
    OK = 0
   Endif
   # end 95669
   Filter [VEP]
   #fin 90775
   If OK
    If FLGAT
     Gosub IJAT
    Else
     Gosub IJMAL
    Endif

    Unlock =SYMBOLE

    If   GOK<0 : Goto ROLL_TR1
    Elsif !GOK : Goto AB_TR1
    Endif

    NBPCE +=1

    If !FLGAT
     # Mise à jour de l'attestation à "Validé" + Mise à jour du numéro de bulletin dans l'attestation
     [F:MAL]STAATT = 3
     [F:MAL]BUL    = [F:VEP]BUL
     Rewrite [F:MAL]Curr
     #Attestation Mal/Mat/Pat du xx/xx/xx déversée dans paie du yy/yy/yy
     Call ECR_TRACE([F:ECT]REFNUM-[F:ID]NAM-[F:ID]SRN-":"-func AFNC.MES1(mess(39,10710,1),num$(DATMAT))
&                  -format$("D:"+GFMDAT4,[F:VEP]PYRDAT),0) From GESECRAN
    Else
     # Mise à jour de l'attestation à "Validé"
     [F:HRTAT]STAATT = 3
     [F:HRTAT]BUL    = [F:VEP]BUL
     Rewrite [F:HRTAT]Curr
     #Attestation AT/Maladie prof. du xx/xx/xx déversée dans paie du yy/yy/yy
     Call ECR_TRACE([F:ECT]REFNUM-[F:ID]NAM-[F:ID]SRN-":"-func AFNC.MES1(mess(38,10710,1),num$(DATMAT))
&                  -format$("D:"+GFMDAT4,[F:VEP]PYRDAT),0) From GESECRAN
    Endif
   Endif
  Endif
 Next
Commit
Return

$IJAT
## Attestation AT/Maladie professionnelle
For [L]NOMPAR="ATSALAIRE","ATNBLIG","ATJOURS","TEMSUBRO"
 Raz RESULTAT
 Case [L]NOMPAR
  When "ATSALAIRE" : Gosub SALAIRE1
  When "ATNBLIG"   : RESULTAT = find(0,[F:HRTAT]AMT1)-1
  When "ATJOURS"   : RESULTAT = [F:HRTAT]NBRDAYMON
  When "TEMSUBRO"  : RESULTAT = ([F:HRTAT]ENAFLG>=2)
 Endcase
 Gosub MAJVLA
 If GOK<=0 : Break : Endif
Next
Return

$IJMAL
If [F:MAL]GRDABS=1
 ## Attestation Maladie
 COK = 1
 For [L]NOMPAR="MALSALAIRE","MALNBLIG","MALJOURS","TEMSUBRO"
  Raz RESULTAT
  Case [L]NOMPAR
   When "MALSALAIRE" : Gosub SALAIRE2
   When "MALNBLIG"   : RESULTAT = [F:MAL]NBRPYR
   When "MALJOURS"   : RESULTAT = [F:MAL]NBRDAYMON
   When "TEMSUBRO"   : RESULTAT = ([F:MAL]ENAFLG>=2)
  Endcase
  If COK=1 : Gosub MAJVLA : Endif
  If GOK<=0 : Break : Endif
 Next
Else
 ## Attestation Maternité/Paternité
 COK = 1
 For [L]NOMPAR="MATSALAIRE","MATNBLIG","MATJOURS","TEMSUBRO"
  Raz RESULTAT
  Case [L]NOMPAR
   When "MATSALAIRE" : Gosub SALAIRE2
   When "MATNBLIG"   : RESULTAT = [F:MAL]NBRPYR
   When "MATJOURS"   : RESULTAT = [F:MAL]NBRDAYMON
   When "TEMSUBRO"   : RESULTAT = ([F:MAL]ENAFLG>=2)
  Endcase
  If COK=1 : Gosub MAJVLA : Endif
  If GOK<=0 : Break : Endif
 Next
Endif
Return

$SALAIRE1
RESULTAT = sigma(0,dim([F:HRTAT]AMT1)-1,[F:HRTAT]AMT1(indcum))
RESULTAT += sigma(0,dim([F:HRTAT]AMT2)-1,[F:HRTAT]AMT2(indcum))
RESULTAT += sigma(0,dim([F:HRTAT]LOSSAL)-1,[F:HRTAT]LOSSAL(indcum))
Return

$SALAIRE2
For I=0 To [F:MAL]NBRPYR-1
 If [F:MAL]SALRES(I)<>0
  #78261 : prendre le min entre brut et plafond
  If dim([F:MAL]PLFPYR)>=0 & [F:MAL]PLFPYR(I)<>0 & [F:MAL]PLFPYR(I)<[F:MAL]SALRES(I)
   RESULTAT += [F:MAL]PLFPYR(I)
  Else
   RESULTAT += [F:MAL]SALRES(I)
  Endif
 Else
  #78261 : prendre le min entre brut et plafond
  If dim([F:MAL]PLFPYR)>=0 & [F:MAL]PLFPYR(I)<>0 & [F:MAL]PLFPYR(I)<[F:MAL]AMTPYR(I)
   RESULTAT += [F:MAL]PLFPYR(I)
  Else
   RESULTAT += [F:MAL]AMTPYR(I)
  Endif
 Endif
Next
If [F:MAL]FLGGEN<>2 & [F:MAL]FLGSPE<>2   : COK = -1 : Endif  # Si pas les droits, ne rien envoyer en paie
Return

## Mise à jour des variables de paie
$MAJVLA
Readlock [VLA]VLA0=4;"";"";"";[F:VEP]EMP;[F:VEP]PYRDAT;evalue([L]NOMPAR);[F:VEP]BUL
If fstat=1
 GOK=-1 : GLOCK="$VALEUR"-[F:VEP]EMP-num$([F:VEP]PYRDAT)-evalue([L]NOMPAR)-[F:VEP]BUL
 Return
Elsif fstat
 Raz [F:VLA]
 [F:VLA]TYP    = 4
 [F:VLA]EMP    = [F:VEP]EMP
 [F:VLA]DAT    = [F:VEP]PYRDAT
 [F:VLA]VARCOD = evalue([L]NOMPAR)
 [F:VLA]BUL    = [F:VEP]BUL
 [F:VLA]VARVAL = RESULTAT
 Write [VLA]
Else
 If [L]NOMPAR="TEMSUBRO"
  [F:VLA]VARVAL = RESULTAT
 Else
  # Si 2 arrêts initiaux ou 2 prolongations le même mois, on cumule les salaires et le nombre de salaires
  [F:VLA]VARVAL += RESULTAT
 Endif
 Rewrite [VLA]
Endif
If fstat
 GOK = 0 : Call FSTA("VLA") From GLOCK
 Return
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else: Goto TR1 : Endif
