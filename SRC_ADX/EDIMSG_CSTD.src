#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDIMSG                                                           #
# JUCON + RBA                                                                 #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_AFTER"   : Gosub AINSERT_CONTROL_AFTER
        When "AUPDATE_CONTROL_AFTER"   : Gosub AUPDATE_CONTROL_AFTER
        When "ADELETE_CONTROL_AFTER"   : Gosub ADELETE_CONTROL_AFTER
      Endcase
    When "EMSD"
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub EMSD_AREAD_AFTER
        When "ADDLINE_BEFORE"          : Gosub EMSD_ADDLINE_BEFORE
        When "ADDLINE_AFTER"           : Gosub EMSD_ADDLINE_AFTER
        When "ADELLINE_AFTER"          : Gosub EMSD_ADELLINE_AFTER
      Endcase
    When "EMSA"
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub EMSA_AREAD_AFTER
        When "ADDLINE_AFTER"           : Gosub EMSA_ADDLINE_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_VALIDATE"            : Gosub MET_VALIDATE
    When "MET_POST_JSON"           : Gosub MET_POST_JSON
    When "MET_PUT_JSON"            : Gosub MET_PUT_JSON
    When "MET_DEL_JSON"            : Gosub MET_DEL_JSON
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "CACHEUUID"
      Case [L]ARULE
        When "INIT"      : Gosub CACHEUUID_INIT
       Endcase
    When "MSGCOD"
      Case [L]ARULE
        When "CONTROL"  : Gosub MSGCOD_CONTROL
        When "PROPAGATE": Gosub MSGCOD_PROPAGATE
      Endcase
    When "MSGREL"
      Case [L]ARULE
        When "CONTROL"  : Gosub MSGREL_CONTROL
        When "PROPAGATE": Gosub MSGREL_PROPAGATE
      Endcase
    When "MSGDIR"
      Case [L]ARULE
        When "INIT"     : Gosub MSGDIR_INIT
        When "CONTROL"  : Gosub MSGDIR_CONTROL
        When "PROPAGATE": Gosub MSGDIR_PROPAGATE
      Endcase
    When "MSGOPE"
      Case [L]ARULE
        When "INIT"     : Gosub MSGOPE_INIT
        When "CONTROL"  : Gosub MSGOPE_CONTROL
        When "PROPAGATE": Gosub MSGOPE_PROPAGATE
      Endcase
    When "MSGTYP"
      Case [L]ARULE
        When "INIT"     : Gosub MSGTYP_INIT
        When "PROPAGATE": Gosub MSGTYP_PROPAGATE
      Endcase
    When "CATCOD"
      Case [L]ARULE
        When "PROPAGATE": Gosub CATCOD_PROPAGATE
      Endcase
    When "MSGTPL"
      Case [L]ARULE
        When "PROPAGATE": Gosub MSGTPL_PROPAGATE
        When "CONTROL"  : Gosub MSGTPL_CONTROL
      Endcase
    When "MSGTRGTAB"
      Case [L]ARULE
        When "PROPAGATE": Gosub MSGTRGTAB_PROPAGATE
      Endcase
    When "REPCOD"
      Case [L]ARULE
        When "CONTROL"  : Gosub REPCOD_CONTROL
        When "PROPAGATE": Gosub REPCOD_PROPAGATE
      Endcase
    When "EMSD.ALIAS"
      Case [L]ARULE
        When "PROPAGATE"  : Gosub EMSD_ALIAS_PROPAGATE
      Endcase
    When "EMSD.CODPRO"
      Case [L]ARULE
        When "CONTROL"   : Gosub EMSD_CODPRO_CONTROL
        When "PROPAGATE" : Gosub EMSD_CODPRO_PROPAGATE
      Endcase
    When "EMSD.EXPRESSION"
      Case [L]ARULE
        When "CONTROL"   : Gosub EMSD_EXPRESSION_CONTROL
        When "PROPAGATE" : Gosub EMSD_EXPRESSION_PROPAGATE
      Endcase
    When "EMSD.FLGREC"
      Case [L]ARULE
        When "PROPAGATE": Gosub EMSD_FLGREC_PROPAGATE
      Endcase
    When "EMSD.MANDATORY"
      Case [L]ARULE
      When "PROPAGATE": Gosub EMSD_MANDATORY_PROPAGATE
    Endcase
    When "EMSA.CODE"
      Case [L]ARULE
        When "PROPAGATE"  : Gosub EMSA_CODE_PROPAGATE
      Endcase
    When "EMSA.ALIAS"
      Case [L]ARULE
        When "PROPAGATE": Gosub EMSA_ALIAS_PROPAGATE
      Endcase
  Endcase
Return

####################################################################

$CACHEUUID_INIT
  this.CACHEUUID = NullUuid()
Return

#####################################################################

$MSGCOD_CONTROL
  If this.MSGCOD <> ""
  #  this.MSGCOD = format$("Kv4:20B",toupper(this.MSGCOD))
    this.MSGCOD = func EDILIBA.FORMATVAL("MSGCOD", this.MSGCOD)
  Endif
Return

$MSGCOD_PROPAGATE
  Gosub TEST_EDIMSG
  this.VALID = [V]CST_ANO
Return

####################################################################

$MSGREL_CONTROL
  If this.MSGREL <> ""
  #  this.MSGREL =format$("Kv4:5B",toupper(this.MSGREL))
    this.MSGREL = func EDILIBA.FORMATVAL("MSGREL", this.MSGREL)
  Endif
Return

$MSGREL_PROPAGATE
  Gosub TEST_EDIMSG
  this.VALID = [V]CST_ANO
Return

####################################################################

$MSGDIR_INIT
  this.MSGDIR = 1
Return

$MSGDIR_CONTROL
  If this.snapshot <> null and this.snapshot.MSGDIR <> this.MSGDIR
    If this.MSGCOD <> "" and this.MSGREL <> ""
      Local File EDISEQFIL [ESF]
      Filter [ESF] Where [ESF]MSGCOD = this.MSGCOD and [ESF]MSGREL = this.MSGREL
      For [ESF]ESF0
        #"Sequential file exists. Impossible to change the Sense"
        ASTATUS = fmet this.ASETERROR("MSGDIR",mess(78,2006,1),[V]CST_AERROR)
        Break
      Next
      Filter [ESF]
      LogicClose File [ESF]
    Endif
  Endif
Return

$MSGDIR_PROPAGATE
  Call DELETELINES(this, "EMSA") From EDILIBA
  If this.MSGDIR = 2
    Call GET_KEYS(this)
    this.MSGOPE = 2
  Else
    this.MSGOPE = 1
  Endif
  If this.MSGTPL <> ""
    this.MSGTPL = ""
  Endif
Return

####################################################################

$MSGOPE_INIT
  this.MSGOPE = 1 #temp
Return

$MSGOPE_CONTROL
  If this.MSGDIR = 2
    If this.MSGOPE <> 2
      #Value is not allowed
      ASTATUS = fmet this.ASETERROR("MSGOPE",mess(105,2006,1),[V]CST_AERROR)
    Endif
  Else
    If this.MSGOPE <> 1
      #Value is not allowed
      ASTATUS = fmet this.ASETERROR("MSGOPE",mess(105,2006,1),[V]CST_AERROR)
    Endif
  Endif
Return

$MSGOPE_PROPAGATE
Return

####################################################################

$MSGTYP_INIT
  this.MSGTYP = 1
Return

$MSGTYP_PROPAGATE
  If this.MSGTYP <> 1
    this.MSGTYP = 1 #no changes in V1
  Endif
Return

####################################################################

$CATCOD_PROPAGATE
  If this.CATCOD <> ""
    Local File EDICAT [ECA]
    Read [ECA]ECA0 = this.CATCOD
    If !fstat
      this.MSGTRGTAB = [ECA]CATTRGTAB
      this.MSGDIR    = [ECA]CATACT #only in V1
    Else
      this.MSGTRGTAB = ""
      this.MSGDIR    = 1
    Endif
    If [ECA]VALID = 1
      ASTATUS = fmet this.ASETERROR("CATCOD",mess(40,2006,1),[V]CST_AWARNING)
    Endif
    LogicClose File [ECA]
    this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")
  Else
    this.MSGTRGTAB = ""
    this.MSGDIR    = 1
    this.CATDES    = ""
  Endif
  If this.REPCOD   <> ""
    this.REPCOD   = ""
  Endif

  this.VALID = [V]CST_ANO
Return

####################################################################

$MSGTPL_CONTROL
  # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  If this.CATCOD <> "" and this.MSGTPL <> ""
   Local Integer WFLGSYRA : WFLGSYRA = [V]CST_ANO
   Local File EDICAT [ECA]
   Read [ECA]ECA0 = this.CATCOD
   If fstat = [V]CST_AOK
     If [ECA]FLGSYRA = [V]CST_AYES #CRUD
       ASTATUS = fmet this.ASETERROR("MSGTPL", mess(105,2006,1),[V]CST_AERROR) #Impossible d'indiquer un modèle d'import. L'objet est géré en CRUD
     Endif
   Endif
   LogicClose File [ECA]
  Endif
  #/ Issue US X3-7673

  If this.MSGDIR = 2 #receipt
    If this.MSGTPL = ""
      #ASTATUS = fmet this.ASETERROR("MSGTPL", mess(104,2006,1),[V]CST_AWARNING) # X3-7673 EDI improvements CRUD method for receipt
    Else
      Local File AOBJEXT [AOE]
      Read [F:AOE]AOE0 = this.MSGTPL
      If !fstat
        If this.CATCOD="FACTURAER" and [F:AOE]FIL(0)="PINVOICE": Return: Endif    ## 112148
        If this.MSGTRGTAB <> [F:AOE]FIL(0)
          ASTATUS = fmet this.ASETERROR("MSGTPL", mess(34,2006,1),[V]CST_AERROR)
        Endif
      Endif
      LogicClose File [AOE]
    Endif
  Endif
Return

$MSGTPL_PROPAGATE
  this.VALID = [V]CST_ANO

  Local Integer WPOS
  Local Integer I
  Local Char LNKEXP(60)
  Local Char ABRFIC(8)
  Local Char WFIELD(12)

  If this.MSGTPL = ""
    Call DELETELINES(this, "EMSD") From EDILIBA
  Else

    Local File AOBJEXT [AOE]
    Local File AOBJEXTD [AOD]
    Local File ATABLE [ATB]
    Local File ATABZON [ATZ]
    Local File ATYPE [ATY]

    Read [F:AOE]AOE0 = this.MSGTPL
    If !fstat
      ###### We fill the EDIMSGD table from the import template

      Call DELETELINES(this, "EMSD") From EDILIBA

      #for each line of the template
      I = 0
      For [F:AOD]AOD0 Where EXT = this.MSGTPL
        WPOS = fmet this.ADDLINE('EMSD', [V]CST_ALASTPOS)
        I = I + 1
        this.EMSD(WPOS).FLDTYP = 0
        Raz fstat
        If [F:AOD]FIL <> [F:ATB]CODFIC
          Read [ATB]CODFIC = [F:AOD]FIL
        Endif
        If !fstat
          this.EMSD(WPOS).LOC = [F:AOD]LOC
          this.EMSD(WPOS).LNG = [F:AOD]LNG
          If [F:AOD]FLD <> '/'
            If left$([F:AOD]FLD,1) <> '*'
              this.EMSD(WPOS).EXPRESSION = '[F:'+[F:ATB]ABRFIC+']'+[F:AOD]FLD
            Else
              this.EMSD(WPOS).EXPRESSION = [F:AOD]FLD
            Endif
          Else
            If [F:AOD]NUMLIG<>1
              this.EMSD(WPOS).EXPRESSION = '/'
              this.EMSD(WPOS).FLDTYP = 2
            Else
              this.EMSD(WPOS).SASVAR = ""
              this.EMSD(WPOS).EXPRESSION = "/"
              this.EMSD(WPOS).FLDTYP = 0
            Endif
          Endif
        Endif

        WFIELD = [F:AOD]FLD
        If instr(0,WFIELD,'(')
          WFIELD = left$(WFIELD,instr(0,WFIELD,'(')-1)
        Endif

        Read [ATZ]CODZONE = [F:ATB]CODFIC;WFIELD
        If !fstat
          this.EMSD(WPOS).MANDATORY = [F:ATZ]OBLIG
          Read [ATY]CODTYP = [F:ATZ]CODTYP
          If !fstat
            this.EMSD(WPOS).FLDTYP = [F:ATY]TYPTYP
          Endif
        Endif

        this.EMSD(WPOS).FLGREC = [F:AOD]TYP
      Next
    Endif

    LogicClose File [AOE]
    LogicClose File [AOD]
    LogicClose File [ATB]
    LogicClose File [ATZ]
    LogicClose File [ATY]
  Endif

Return

#####################################################################

$REPCOD_CONTROL
  Local Char WMSG(100)

  If this.snapshot <> null
&   and this.snapshot.REPCOD <> this.REPCOD
&   and this.MSGCOD <> ""
&   and this.MSGREL <> ""
    Local File EDISEQFIL [ESF]
    Filter [ESF] Where MSGCOD = this.MSGCOD and MSGREL = this.MSGREL
    Read [ESF] First
    If !fstat
      #"Message mapping is already used. Change is not allowed"
      WMSG = mess(11,2006,1)+"."-mess(12,2006,1)
      ASTATUS = fmet this.ASETERROR("REPCOD",WMSG,[V]CST_AERROR)
    Else
      Local File ASHW [ASW]
      Local File ACLASSE [ACLA]
      Read [ASW]ASW0=this.REPCOD
      If !fstat
        Read [ACLA]ACLA0=[F:ASW]CODCLA
        If !fstat
          If [F:ACLA]TABREF<>this.MSGTRGTAB
            If [F:ACLA]TABREF <> "" #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
              #"The class doesn't match with the triggering table"
              WMSG = mess(83,2006,1)
              ASTATUS = fmet this.ASETERROR("REPCOD",WMSG,[V]CST_AERROR)
            Endif #/Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
          Else
            #ok
          Endif
        Else
          #error:  class not exist
          WMSG = mess(7,9014,1)
          ASTATUS = fmet this.ASETERROR("REPCOD",WMSG,[V]CST_AERROR)
        Endif
      Else
        #pb ?
      Endif
      LogicClose File [ACLA]
      LogicClose File [ASW]
    Endif
    LogicClose File [ESF]
  Endif
Return

$REPCOD_PROPAGATE
  Local File ASHW [ASW]
  Read [ASW]ASW0=this.REPCOD
  If !fstat
    this.ABRCLA = [ASW]ABRCLA
  Else
    this.ABRCLA = ""
  Endif
  LogicClose File [ASW]

  Local Integer I
  For I = 1 To maxtab(this.EMSA)
    this.EMSA(I).REPCOD = this.REPCOD
    this.EMSA(I).ALIAS  = ""
  Next I

Return

####################################################################

$MSGTRGTAB_PROPAGATE
  this.VALID = [V]CST_ANO
Return

####################################################################

$EMSA_CODE_PROPAGATE
  this.CODNAM = func EDILIBA.GET_CODNAM(this.CODE)
Return

####################################################################

$EMSA_ALIAS_PROPAGATE
  Local Char WTXT(120)
  Local Char WLAN(3)

  this.REPCOD=this.APARENT.REPCOD

  If this.ALIAS <> ""
    WOK = func TEST_ALIAS(this)
    If WOK=0 or WOK=3
      If this.REPCOD <> ""
        Local File ASHWEXPPRO [ASWR]
        Read [ASWR]ASWR0 = this.REPCOD;this.ALIAS
        If !fstat
          this.CODPRO = [ASWR]CODPRO
          WLAN = this.ACTX.LAN
#         WLAN="ENG"
          ##Always propose the english text
          Call TEXTELAN([ASWR]INTPRO,WTXT,WLAN) From OBJDIV
          this.DESCRIPTION = WTXT
        Else
          this.CODPRO = ""
          this.DESCRIPTION = ""
          ASTATUS = fmet this.ASETERROR("ALIAS",mess(00126,00143,1) ,[V]CST_AERROR)
        Endif
        LogicClose File [ASWR]
      Else
        this.CODPRO = ""
        this.DESCRIPTION = ""
      Endif
    Endif
  Else
    this.CODPRO = ""
    this.DESCRIPTION = ""
  Endif

  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################

Funprog TEST_ALIAS(WOBJECT)
Variable Instance WOBJECT Using OBJECT
Local Char WCODTYP(8)
Local Integer WSTA : WSTA = [V]CST_AOK
Local Shortint WKO
  #check zone
  WOBJECT.ALIAS = toupper(WOBJECT.ALIAS)

  Local File ASHWFLD [ASWF]
  Read [ASWF]ASWF0=WOBJECT.APARENT.REPCOD;WOBJECT.ALIAS
  If !fstat
    WCODTYP=[F:ASWF]CODTYP
    WKO=1
    Gosub CHECK_TYP
  Endif
  LogicClose File [ASWF]
  If WKO<2
  ## INI 112148
#    Local File ATABZON [ATZ]
#    Read [ATZ]CODZONE = WOBJECT.APARENT.MSGTRGTAB;WOBJECT.ALIAS
#    If !fstat
#      WCODTYP=[F:ATZ]CODTYP
#      WKO=1
#      Gosub CHECK_TYP
#    Endif

    Local File ACLAFLD [ACLAF]
    Read [ACLAF]ACLAF0 = WOBJECT.APARENT.MSGTRGTAB;WOBJECT.ALIAS
    If !fstat
      WCODTYP=[F:ACLAF]CODTYP
      WKO=1
      Gosub CHECK_TYP
    Endif

    If WOBJECT.APARENT.REPCOD="EDIPIHFACE" and WKO=0
      Read [ACLAF]ACLAF0 = "FACTURAEP";WOBJECT.ALIAS
      If !fstat
        WCODTYP=[F:ACLAF]CODTYP
        WKO=1
        Gosub CHECK_TYP
      Endif
    Endif
    ## END 112148

    If WKO=1
      #Non valid field
      ASTATUS = fmet WOBJECT.ASETERROR("ALIAS",mess(7,09950,1) ,[V]CST_AWARNING)
      WSTA = [V]CST_AWARNING
#      WSTA = [V]CST_AERROR
    Elsif WKO=0
      #Nonexistent field
      ASTATUS = fmet WOBJECT.ASETERROR("ALIAS",mess(58,188,1),[V]CST_AERROR)
      WSTA = [V]CST_AERROR
    Endif
    LogicClose File [ACLAF]
  Endif

End WSTA

####################################################################

$CHECK_TYP
#110811_US11
  Case WOBJECT.CODE
    When "BPANUM":
      If WCODTYP="A" or WCODTYP="BPR" or WCODTYP="BPC" or WCODTYP="BPS" or WCODTYP="BPT" or WCODTYP="BPN"
        WKO=2
      Endif
    When "BPAADD":
      If WCODTYP="A" or WCODTYP="ADR" or WCODTYP="ADL" or WCODTYP="BPA" or WCODTYP="BPD"
        WKO=2
      Endif
    When "FCY":
      If WCODTYP="A" or WCODTYP="FCY"
        WKO=2
      Endif
  Endcase
#/110811_US11
Return

####################################################################

$EMSD_ALIAS_PROPAGATE
  Local Char WTXT(120)
  Local Char WLAN(3)

  this.REPCOD=this.APARENT.REPCOD
  If this.ALIAS <> "" and this.REPCOD <> ""
    Local File ASHWEXPPRO [ASWR]
    Read [ASWR]ASWR0 = this.REPCOD;this.ALIAS
    If !fstat
      this.CODPRO = [ASWR]CODPRO
      If this.DESCRIPTION=""
        WLAN = this.ACTX.LAN
        #WLAN="ENG"
        ##Always propose the english text
        Call TEXTELAN([ASWR]INTPRO,WTXT,WLAN) From OBJDIV
        this.DESCRIPTION = WTXT
      Endif
      this.PROTOPATH = func EDILIBC.GET_PROTOPATH(this.ALIAS, this.CODPRO, this.APARENT.REPCOD)
     Else
      this.CODPRO = ""
      this.DESCRIPTION= ""
      this.PROTOPATH = ""
      ASTATUS = fmet this.ASETERROR("ALIAS",mess(00126,00143,1) ,[V]CST_AERROR)
    Endif
    LogicClose File [ASWR]
  Else
    this.CODPRO = ""
    this.DESCRIPTION= ""
    this.PROTOPATH = ""
  Endif

  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################

$EMSD_CODPRO_CONTROL
  Local Integer WOK
  Local Char WERR(250)
  Local File ASHWEXPPRO
  this.CODPRO=toupper(this.CODPRO)
  If this.CODPRO<>""
    Read [ASWR]ASWR3=this.APARENT.REPCOD;this.CODPRO
    If fstat<>[V]CST_AOK
      WERR = mess(00126,00143,1) # invalid value
      ASTATUS = fmet this.ASETERROR("CODPRO",WERR,[V]CST_AERROR)
    Endif
  Endif
Return

$EMSD_CODPRO_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################

$EMSD_EXPRESSION_CONTROL
  If this.EXPRESSION <> ""
    this.EXPRESSION = func EDILIBA.FORMATVAL("EXPRESSION", this.EXPRESSION)
  Endif
  #WARNING --> The formula should be tested here, but it's not our job, it's AFF datatype's job thanks to Syracuse controls
Return

$EMSD_EXPRESSION_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################

$EMSD_FLGREC_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
Return

#####################################################################

$EMSD_MANDATORY_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
Return

#********************************************************************
# Event EMSD_AREAD_AFTER
#********************************************************************
#*
#*!
$EMSD_AREAD_AFTER
  this.REPCOD = this.APARENT.REPCOD

  Local Char WTXT(120)
  Local Char WLAN(3)

  If this.ALIAS <> "" and this.REPCOD <> ""
    Local File ASHWEXPPRO [ASWR]
    Read [ASWR]ASWR0 = this.REPCOD;this.ALIAS
    If !fstat
      this.CODPRO = [ASWR]CODPRO
      WLAN = this.ACTX.LAN
      Call TEXTELAN([ASWR]INTPRO,WTXT,WLAN) From OBJDIV
      this.DESCRIPTION = WTXT
    Else
      this.CODPRO = ""
      this.DESCRIPTION = ""
    Endif
    LogicClose File [ASWR]
  Else
    this.CODPRO = ""
    this.DESCRIPTION = ""
  Endif

Return

#********************************************************************
# Event EMSD_ADDLINE_BEFORE
#********************************************************************
#*
#*!
$EMSD_ADDLINE_BEFORE
  If this.MSGDIR = 1 #    issue
    #Insertion not possible"
    ASTATUS = fmet this.ASETERROR("", mess(122,199,1),[V]CST_AERROR)
  Else #this.MSGDIR = 2 receive
    If this.MSGTYP = 2 or this.MSGTYP = 3
      #Insertion not possible"
      ASTATUS = fmet this.ASETERROR("", mess(122,199,1),[V]CST_AERROR)
    Endif
  Endif
Return

#********************************************************************
# Event EMSD_ADELLINE_AFTER
#********************************************************************
#*
#*!
$EMSD_ADELLINE_AFTER
  this.APARENT.VALID = [V]CST_ANO
Return

#********************************************************************
# Event EMSD_ADDLINE_AFTER
#********************************************************************
#*
#*!
$EMSD_ADDLINE_AFTER
  this.REPCOD = this.APARENT.REPCOD

  this.APARENT.VALID = [V]CST_ANO

  this.MANDATORY = [V]CST_ANO

  this.NUMLIN=1+max(this.APARENT.EMSD(1..maxtab(this.APARENT.EMSD)).NUMLIN)

  #Manage the SORT property
  Local Integer I, BEF_LINE, AFT_LINE #positions in collection (they have a 0 value here)
  #Where are the previous and next lines ?
  For I = 1 To maxtab(this.APARENT.EMSD)
    If this.APARENT.EMSD(I) <> null
      If this.APARENT.EMSD(I).AORDER = this.AORDER - 1
        BEF_LINE=I
      Elsif this.APARENT.EMSD(I).AORDER = this.AORDER + 1
        AFT_LINE=I
      Endif
    Endif
  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT, OFFSET_LINE #positions in the sort order
  Local Integer MY_STEP #Step in the sort order between two records
  MY_STEP = 100
  #If the new line is inserted in the middle of the array, not in 1st position
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.EMSD(AFT_LINE).SORT
    #Test if a next line exists
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EMSD(BEF_LINE).SORT : Endif
    #If there is enough space then we insert using a dichotomy method
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if there is not enough space, we reassign the SORT property of all lines from the new inserted line
      For I=1 To maxtab(this.APARENT.EMSD)
        If this.APARENT.EMSD(I) <> null
          OFFSET_LINE = this.APARENT.EMSD(I).AORDER - this.AORDER
#          If this.APARENT.EMSD(I).AORDER >= this.AORDER
          If OFFSET_LINE>=0
            #Assign the SORT property
            this.APARENT.EMSD(I).SORT = BEF_LINE_SORT + MY_STEP + (OFFSET_LINE * MY_STEP)
          Endif
        Endif
      Next I
    Endif
  #If the new inserted line is at the 1st position in the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #Test if a next line exists
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EMSD(BEF_LINE).SORT : Endif
    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP
  Endif
Return

#********************************************************************
# Event EMSA_AREAD_AFTER
#********************************************************************
#*
#*!
$EMSA_AREAD_AFTER
  this.REPCOD = this.APARENT.REPCOD
Return

#********************************************************************
# Event EMSA_ADDLINE_AFTER
#********************************************************************
#*
#*!
$EMSA_ADDLINE_AFTER
  this.REPCOD = this.APARENT.REPCOD


  this.NUMLIN=1+max(this.APARENT.EMSA(1..maxtab(this.APARENT.EMSA)).NUMLIN)

  #Manage the SORT property
  Local Integer I, BEF_LINE, AFT_LINE #positions in collection (they have a 0 value here)
  #Where are the previous and next lines ?
  For I = 1 To maxtab(this.APARENT.EMSA)
    If this.APARENT.EMSA(I) <> null
      If this.APARENT.EMSA(I).AORDER = this.AORDER - 1
        BEF_LINE=I
      Elsif this.APARENT.EMSA(I).AORDER = this.AORDER + 1
        AFT_LINE=I
      Endif
    Endif
  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT, OFFSET_LINE #positions in the sort order
  Local Integer MY_STEP #Step in the sort order between two records
  MY_STEP = 100
  #If the new line is inserted in the middle of the array, not in 1st position
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.EMSA(AFT_LINE).SORT
    #Test if a next line exists
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EMSA(BEF_LINE).SORT : Endif
    #If there is enough space then we insert using a dichotomy method
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if there is not enough space, we reassign the SORT property of all lines from the new inserted line
      For I=1 To maxtab(this.APARENT.EMSA)
        If this.APARENT.EMSA(I) <> null
          OFFSET_LINE = this.APARENT.EMSA(I).AORDER - this.AORDER
#          If this.APARENT.EMSA(I).AORDER >= this.AORDER
          If OFFSET_LINE>=0
            #Assign the SORT property
            this.APARENT.EMSA(I).SORT = BEF_LINE_SORT + MY_STEP + (OFFSET_LINE * MY_STEP)
          Endif
        Endif
      Next I
    Endif
  #If the new inserted line is at the 1st position in the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #Test if a next line exists
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EMSA(BEF_LINE).SORT : Endif
    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP
  Endif
Return

#********************************************************************
# Method MET_POST_JSON
#********************************************************************
#* @param WERR
#* @return WOK
#*!
$MET_POST_JSON
  Local Integer WOK             : WOK = [V]CST_AOK
  Local Char WREP(20)           : WREP = ""
  Local Char WENTITY_TYPE(30)   : WENTITY_TYPE = "messageMapping"
  Local Char WKEY(250)          : WKEY = this.MSGCOD+"~"+this.MSGREL
  If this.APARENT <> null
    WREP = this.APARENT.AINF.NAMCLA
  Else
    WREP = "R_EDIMSG"
  Endif
  Gosub JSON_DELETE From EDILIBC
  Gosub JSON_CREATE From EDILIBC
  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_PUT_JSON
#********************************************************************
#* @param WERR
#* @return WOK
#*!
$MET_PUT_JSON
  Local Integer WOK             : WOK = [V]CST_AOK
  Local Char WREP(20)           : WREP = ""
  If this.APARENT <> null
    WREP = this.APARENT.AINF.NAMCLA
  Else
    WREP = "R_EDIMSG"
  Endif
  Gosub JSON_UPDATE From EDILIBC
  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_DEL_JSON
#********************************************************************
#* @param WERR
#* @return WOK
#*!
$MET_DEL_JSON
  Local Integer WOK             : WOK = [V]CST_AOK
  Local Char WENTITY_TYPE(30)   : WENTITY_TYPE = "messageMapping"
  Local Char WKEY(250)          : WKEY = this.MSGCOD+"~"+this.MSGREL
  Gosub JSON_DELETE From EDILIBC
  ARET_VALUE = WOK
Return

#********************************************************************
# Method AINSERT_CONTROL_AFTER
#********************************************************************
#
#********************************************************************
$AINSERT_CONTROL_AFTER
  Local Integer WOK
  Local Char WERR(250)

  WOK = fmet this.MET_VALIDATE()
  If WOK = [V]CST_ATRUE
    WOK = fmet this.MET_POST_JSON(WERR)
    If WOK <> [V]CST_AINFO
      ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
    Endif
  Else
    this.CACHEUUID = NullUuid()
    WERR = mess(42,2006,1)
    ASTATUS = fmet this.ASETERROR("VALID", WERR, [V]CST_AWARNING)
  Endif
Return

#********************************************************************
# Method AUPDATE_CONTROL_AFTER
#********************************************************************
#
#********************************************************************
$AUPDATE_CONTROL_AFTER
  Local Integer WOK
  Local Char WERR(250)
  WOK = fmet this.MET_VALIDATE()
  If WOK = [V]CST_ATRUE
    WOK = fmet this.MET_PUT_JSON(WERR)
    If WOK <> [V]CST_AINFO
      ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
    Endif
  Else
    this.CACHEUUID = NullUuid()
    #"Invalid Message mapping setup"
    WERR = mess(42,2006,1)
    ASTATUS = fmet this.ASETERROR("VALID", WERR, [V]CST_AWARNING)
  Endif
Return

#********************************************************************
# Method ADELETE_CONTROL_AFTER
#********************************************************************
#*
#*!
$ADELETE_CONTROL_AFTER
  Local Integer WOK
  Local Char WERR(250)

  Local File EDIFLOD [EFLD]
  Local File EDISEQFIL [ESF]

  Filter [ESF] Where MSGCOD=this.MSGCOD and MSGREL=this.MSGREL
  Read [ESF]ESF0 First
  If !fstat
    ASTATUS = fmet this.ASETERROR("",mess(101,126,1)-[F:ESF]MSGCOD+"~"+[F:ESF]MSGREL +"~"+[F:ESF]MSGFILNOR - mess(198,133,1)-"EDISEQFIL",[V]CST_AERROR)
    Return
  Endif

  Filter [EFLD] Where MSGCOD=this.MSGCOD and MSGREL=this.MSGREL
  Read [EFLD]EFLD0 First
  If !fstat
    ASTATUS = fmet this.ASETERROR("",mess(101,126,1)-[F:EFLD]FLOCOD+"~"+[F:EFLD]FLOREL+"~"+num$([F:EFLD]NUMLIN) - mess(198,133,1)-"EDIFLOD",[V]CST_AERROR)
    Return
  Endif
  LogicClose File [ESF]
# LogicClose File [EXF]
  LogicClose File [EFLD]

  WOK = fmet this.MET_DEL_JSON(WERR)
  If WOK <> [V]CST_AINFO
    ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
  Endif
Return

#********************************************************************
# Method MET_VALIDATE
#********************************************************************
#*
#*!
$MET_VALIDATE
  Local Integer WOK
  Local Integer WNBERR : WNBERR = 0
  Local Char WERR(250) : WERR = ""
  Local Integer WRET_VALUE
  Local Integer I

  #generate proto path
  For I = 1 To maxtab(this.EMSD)
    If this.EMSD(I)<>null and find(this.EMSD(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      If this.EMSD(I).ALIAS="" and this.EMSD(I).MANDATORY=2  #check for mandatory alias
        WNBERR = WNBERR + 1
        WERR = mess(10,123,1) #"mandatory field"
        ASTATUS = fmet this.EMSD(I).ASETERROR("ALIAS", WERR, [V]CST_AWARNING)
        Break
      Endif
      this.EMSD(I).PROTOPATH = func EDILIBC.GET_PROTOPATH(this.EMSD(I).ALIAS, this.EMSD(I).CODPRO, this.REPCOD)
    Endif
  Next I
  #/generate proto path

  If this.REPCOD= ""
    WNBERR = WNBERR + 1
  Endif

  # X3-7673 EDI improvements CRUD method for receipt
#  If this.MSGTPL = ""
#    If this.MSGDIR = 2 #receipt
#      WNBERR = WNBERR + 1
#    Endif
#  Endif

  If this.CATCOD = ""
    WNBERR = WNBERR + 1
  Else
    Local File EDICAT [ECA]
    Read [ECA]ECA0 = this.CATCOD
    If !fstat
      If [ECA]VALID = 1
        WNBERR = WNBERR + 1
      Endif
    Endif
    LogicClose File [ECA]
  Endif

  If this.MSGDIR = 2 #receipt
    For I = 1 To maxtab(this.EMSA)
      If this.EMSA(I).ALIAS = ""
        WNBERR = WNBERR + 1
        WERR = mess(10,123,1) #"mandatory field"
        ASTATUS = fmet this.EMSA(I).ASETERROR("ALIAS", WERR, [V]CST_AWARNING)
      Else
        WOK = func TEST_ALIAS(this.EMSA(I))
        If WOK <> [V]CST_AOK
          WNBERR = WNBERR + 1
        Endif
      Endif
    Next I
  Endif

  If WNBERR > 0
    this.VALID = [V]CST_ANO
    #if the message mapping begins not valid, all linked flows mustn't be valid and activated
    #unvalidate and unactivate all flows activated and/or validated using this EDISMG

    Local Instance WEDIFLO Using C_EDIFLO
    WEDIFLO = NewInstance C_EDIFLO AllocGroup null

    Local File EDIFLOD [EFLD]
    Filter [EFLD] Where [EFLD]MSGCOD = this.MSGCOD and [EFLD]MSGREL = this.MSGREL
    For [EFLD]
      WOK = fmet WEDIFLO.AREAD([EFLD]FLOCOD,[EFLD]FLOREL)
      If WOK = [V]CST_AOK and (WEDIFLO.VALID = [V]CST_AYES or WEDIFLO.FLGACT = [V]CST_AYES)
        WOK = fmet WEDIFLO.MET_UNVALIDATE()
        WOK = fmet WEDIFLO.AUPDATE()
        #Flow has been invalided and deactivated"
        WERR = mess(28,2006,1)-":"-[EFLD]FLOCOD+"~"+[EFLD]FLOREL
        ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AWARNING)
      Endif
    Next
    LogicClose File [EFLD]
    FreeGroup WEDIFLO : WEDIFLO=null

  Else
    # Set Valid
    this.VALID = [V]CST_AYES
  Endif

  If this.VALID = [V]CST_AYES
    WRET_VALUE = [V]CST_ATRUE
  Else
    WRET_VALUE = [V]CST_AFALSE
  Endif

  ARET_VALUE = WRET_VALUE

Return

#********************************************************************
# Suprog GET_KEYS
#********************************************************************
# Get keys
#
#********************************************************************
Subprog GET_KEYS(WEDIMSG)
Value Instance WEDIMSG Using C_EDIMSG
  Local Integer WPOS
  Local File EDICATREF [ECR]    #110811 US11
  Read[ECR]ECR0=[ECA]CATTYP;[ECA]CATTRGTAB
  If fstat=[V]CST_AOK
    WPOS = fmet WEDIMSG.ADDLINE("EMSA",[V]CST_ALASTPOS): WEDIMSG.EMSA(WPOS).CODE = [F:ECR]AUTCOD1: WEDIMSG.EMSA(WPOS).REPCOD = WEDIMSG.REPCOD
    WPOS = fmet WEDIMSG.ADDLINE("EMSA",[V]CST_ALASTPOS): WEDIMSG.EMSA(WPOS).CODE = [F:ECR]AUTCOD2: WEDIMSG.EMSA(WPOS).REPCOD = WEDIMSG.REPCOD
    WPOS = fmet WEDIMSG.ADDLINE("EMSA",[V]CST_ALASTPOS): WEDIMSG.EMSA(WPOS).CODE = [F:ECR]AUTCOD3: WEDIMSG.EMSA(WPOS).REPCOD = WEDIMSG.REPCOD
    If [F:ECR]AUTCOD4<>""
      WPOS = fmet WEDIMSG.ADDLINE("EMSA",[V]CST_ALASTPOS): WEDIMSG.EMSA(WPOS).CODE = [F:ECR]AUTCOD4: WEDIMSG.EMSA(WPOS).REPCOD = WEDIMSG.REPCOD
      If [F:ECR]AUTCOD5<>""
        WPOS = fmet WEDIMSG.ADDLINE("EMSA",[V]CST_ALASTPOS): WEDIMSG.EMSA(WPOS).CODE = [F:ECR]AUTCOD5: WEDIMSG.EMSA(WPOS).REPCOD = WEDIMSG.REPCOD
      Endif
    Endif
  Else      #110811 US11
    WPOS = fmet WEDIMSG.ADDLINE("EMSA",[V]CST_ALASTPOS) : WEDIMSG.EMSA(WPOS).CODE = "BPANUM" : WEDIMSG.EMSA(WPOS).REPCOD = WEDIMSG.REPCOD
    WPOS = fmet WEDIMSG.ADDLINE("EMSA",[V]CST_ALASTPOS) : WEDIMSG.EMSA(WPOS).CODE = "BPAADD" : WEDIMSG.EMSA(WPOS).REPCOD = WEDIMSG.REPCOD
#    WPOS = fmet WEDIMSG.ADDLINE("EMSA",[V]CST_ALASTPOS) : WEDIMSG.EMSA(WPOS).CODE = "CPY"    : WEDIMSG.EMSA(WPOS).REPCOD = WEDIMSG.REPCOD   # 114061 US10
    WPOS = fmet WEDIMSG.ADDLINE("EMSA",[V]CST_ALASTPOS) : WEDIMSG.EMSA(WPOS).CODE = "FCY"    : WEDIMSG.EMSA(WPOS).REPCOD = WEDIMSG.REPCOD
  Endif
  LogicClose File [ECR] #110811 US11
End

#********************************************************************
# $TEST_EDIMSG
#********************************************************************
#
#* Test if the message mapping already exists
#* @param WOBJECT --> OBJECT
#* @return WOK    --> Status [V]CST_ATRUE/[V]CST_AFALSE
#*!
$TEST_EDIMSG
  If this.MSGCOD <> "" and this.MSGREL <> ""
    Local File EDIMSG [EMS]
    Read [F:EMS]EMS0 = this.MSGCOD;this.MSGREL
    If !fstat
      ASTATUS = fmet this.ASETERROR("MSGREL",mess(45,7779,1)-":"-this.MSGCOD+"~"+this.MSGREL,[V]CST_AERROR)
    Endif
    LogicClose File [EMS]
  Endif
Return

