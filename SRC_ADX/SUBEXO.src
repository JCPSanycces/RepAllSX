Subprog AM_RUBCOD(VALEUR)
Variable Char    VALEUR()
End


#JOJAC - 2016-07-19 - REQ114309 - START
Subprog TUNEXO(COD)
Variable Char    COD()
Local Integer TOKILL

  TOKILL = 0
  If dim(VCOD)<1
   Global Char VCOD(GLONRUB)
   TOKILL = 1
  Endif

  If clalev([F:EXO])=0 : Local File EXOPAY [EXO] : Endif

  # To update the EXO code after the tunnel order
  VCOD = [L]COD

  If VCOD="" & GLECOBJ=2
    #If no code is specified, it's better to select one of the curent legislation
    Filter [EXO] Where LEG=GCURLEG
    Read [F:EXO] First
    Filter [EXO]
    If !fstat : VCOD=[F:EXO]COD : Endif
  Else
    #Read [EXO]EXO0 = GCURLEG;VCOD;""
    Filter [F:EXO] Where LEG=GCURLEG & COD=VCOD ####ASK JACO#####
    Read [EXO]EXO0 First
  Endif

  Call OBJET("EXO",VCOD,GCURLEG) From GOBJET

  [L]COD = VCOD

  If TOKILL : Kill VCOD : Endif

End

Subprog CONTEXO(CODE)
Variable Char CODE()
#JASMI - END

  If GFONCTION = "GESEXO" | CODE="" : End : Endif

  #35971
  If instr(1,CODE,"-")
   GMESSAGE = "- :"-mess(94,123,1)
   mkstat=2 : End
  Endif
  If instr(1,CODE,"/")
   GMESSAGE = "/ :"-mess(94,123,1)
   mkstat=2 : End
  Endif
  ###

  If clalev([F:EXO])=0 : Local File EXOPAY [EXO] : Endif

  If CODE <> ""
    Filter [F:EXO] Where COD=[L]CODE
    Read [F:EXO] First
    If fstat
        GMESSAGE = [L]CODE-":"-mess(23,100,1)
        mkstat = 2 : End
    Else
        Filter [F:EXO]
        #Read [EXO]EXO0 = GCURLEG;VCOD;""
        Filter [F:EXO] Where LEG=GCURLEG & COD=[L]CODE ####ASK JACO
        Read [F:EXO]
        If fstat
          Filter [F:EXO] Where COD=[L]CODE
          Read [F:EXO] First
          GMESSAGE = [L]CODE-":"-mess(62,127,1)-":"-[F:EXO]LEG
          mkstat = 2 : End
        Endif
    Endif
  Endif
  Filter [F:EXO]
  #JASMI - END

  Call CONTROLE("EXO","",CODE,GCURLEG,mkstat) From CONTOBJ

  #Acces code
  If GUSRACS<>2
   If [F:EXO]CODACC <> ""
    If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
    Read [F:ACC]CODACC = GUSER;[F:EXO]CODACC
    If fstat or [F:ACC]CONSUL<>2
     GMESSAGE = [F:EXO]COD-":"-mess(3,104,1) :#Access denied
     mkstat = 2 : End
    Endif
   Endif
  Endif

  #Activity code
  If [F:EXO]CODACT<>""
   If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
   Read [ACV]CODACT = [F:RUB]CODACT
   If fstat or [F:ACV]FLACT<>2
    GMESSAGE = mess(42,10703,1) : # Variable diseable
    mkstat = 2 : End
   Endif
  Endif



End

