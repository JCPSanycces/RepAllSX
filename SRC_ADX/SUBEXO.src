#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du fichier GEXOPAY
Call OBJET("EXO",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SEL_TABLE"  : Gosub SEL_TABLE
 When "SETBOUT"    : Gosub SETBOUT
 When "LIENS"      : Gosub LIENS
 When "LIENS2"     : Gosub LIENS2
 When "APRES_CRE"  : Gosub APRES_CRE
 When "APRES_MOD"  : Gosub APRES_MOD
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "FERME"      : Gosub FERME
 When "ANNULE"     : Gosub ANNULE
 When "MODIF"      : Gosub MODIF
 When "CREATION"   : Gosub CREATION
 When "AS_COD"      : Gosub AS_COD
 When "BS_COD"      : Gosub BS_COD
Endcase
Return

$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#JOJAC - 2016-07-19 - REQ114309 - START
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONRUB) : Endif
VCOD = CLE1
#JOJAC - 2016-07-19 - REQ114309 - END
Return

#Before selection on field COD
#############
$AS_COD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_COD
# To do nothing if the user doesn't select a record
If [F:EXO]COD<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:EXO]LEG)>=0 : [M:EXO]LEG=[F:EXO]LEG: Endif
 GCURLEG=[F:EXO]LEG
Else
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:EXO]LEG)>=0
  GCURLEG=[M:EXO]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif

Return

$SETBOUT
If REP<>"" | CLECUR=0 | GHISTO=1
 Call VIREBOUT(CHAINE,"8") From GOBJET
Endif
#Objet à 3 éléments de clé : ajout du btn suppression après que GOBJET l'ait viré !
If CLECUR & VERROU : CHAINE+="A" : Endif
Return

$LIENS
GCURLEG=[F:EXO]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]DES,"EXOPAY","DES",GCURLEG,[M]COD) From ATEXTRA
Call LECTEXTRA([M]SHO,"EXOPAY","SHO",GCURLEG,[M]COD) From ATEXTRA

Read [F:RUB]RUB0 = GCURLEG;[F:EXO]RUBCOD
If !fstat
 [M:EXO]RUBROW(nolign-1) = [F:RUB]ROW
 [M:EXO]RUBTYP(nolign-1) = [F:RUB]TYPRUB
 Call LECTEXTRA([M:EXO]RUBDES(nolign-1),"RUBRIQUE","DES",GCURLEG,[F:EXO]RUBCOD) From ATEXTRA
Endif
#SAVAN
#X3-32839
#  Local Integer ROW
#  Local Integer HEAD
#  For nolign=1 To dim([M:EXO]LVESUBTYP)
#  If [M:EXO]LVESUBTYP(nolign-1) <> ""
#      ROW += 1
#      Call LECTEXTRA([M:EXO]LVESUBDES(nolign-1),"HRLVESUBHEA","DES",GCURLEG,[M:EXO]LVESUBTYP(nolign-1)) From ATEXTRA
#      Call LECTEXTRA([M:EXO]LVESUBSHO(nolign-1),"HRLVESUBHEA","SHO",GCURLEG,[M:EXO]LVESUBTYP(nolign-1)) From ATEXTRA
#  Endif
#  Next
#  [M:EXO]LVESUBNR = ROW
#  Affzo [M:EXO]LVESUBTYP
#
#  For nolign=1 To dim([M:EXO]RUBCOD)
#  If [M:EXO]RUBCOD(nolign-1) <> ""
#      HEAD += 1
#  Endif
#  Next
#  nolign=HEAD
Return

$LIENS2
If [M:EXO]FLG<>2
 Grizo RAT1,RAT2,MAX1,MAX2
Else
 Actzo RAT1,RAT2
 If [M]RAT1<>100
  Grizo MAX1
 Else
  Actzo MAX1
 Endif
 If [M]RAT2<>100
  Grizo MAX2
 Else
  Actzo MAX2
 Endif
Endif
Return

$CREATION
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

#######################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
########################################
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("EXOPAY","DES",CLECUR1,"","EXOPAY","DES",GCURLEG,[F:EXO]COD)  From ATEXTRA
 Call DUPTEXTRA("EXOPAY","SHO",CLECUR1,"","EXOPAY","SHO",GCURLEG,[F:EXO]COD)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DES,"EXOPAY","DES",GCURLEG,[F:EXO]COD) From ATEXTRA
Call MAJTEXTRA([M]SHO,"EXOPAY","SHO",GCURLEG,[F:EXO]COD) From ATEXTRA
Return


$SEL_TABLE
Case TABLE
 When "SELRUBEXO"
  OBJET="RUB"
  START="COD"
  #CRITERE="[F:RUB]TYPRUB=5 | [F:RUB]TYPRUB=6"
  ORDRE = "COD"
  #JOJAC - 2016-07-19 - REQ114309 - START
 When "SELEXO"
    If clalev ([F:EXO])=0 : Local File EXOPAY [EXO] : Endif
#JASMI - START
    Filter [F:EXO]
    OBJET="EXO"
    START = "[F:EXO]COD"
    #JASMI - START
    EXPSTART  = "[F:EXO]COD>='"+VALEUR+"'"
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:EXO]LEG="'+GCURLEG+'" | [F:RUB]LEG="")',"&") From GOBJSUB
    #JASMI - END
    If PARAM(2)<>""
     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",PARAM(2),"&") From GOBJSUB
    Endif
    #JOJAC - 2016-07-19 - REQ114309 - END
Endcase
Return

$APRES_CRE
$APRES_MOD
$AP_ANNULE
Call SETPAR From GENPLAN
Return

$AP_CHANGE
Call CHGTEXTRA("EXOPAY","DES",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Call CHGTEXTRA("EXOPAY","SHO",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Call SETPAR From GENPLAN
Return

$ANNULE
Call SUPTEXTRA("EXOPAY","DES",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("EXOPAY","SHO",SUPP,[L]CODE) From ATEXTRA
Return


########################################
Subprog C_FLG(VALEUR)
Variable Integer VALEUR
If VALEUR <> 2
 Effzo RAT1,RAT2,MAX1,MAX2
 Grizo RAT1,RAT2,MAX1,MAX2
Else
 Actzo RAT1,RAT2,MAX1,MAX2
Endif
End

########################################
Subprog C_RAT1(VALEUR)
Variable Decimal VALEUR
If VALEUR>100
 mkstat = 1
Elsif VALEUR<>100
 Effzo [M]MAX1
 Grizo [M]MAX1
Else
 Actzo [M]MAX1
Endif
End

########################################
Subprog C_RAT2(VALEUR)
Variable Decimal VALEUR
If VALEUR>100
 mkstat = 1
Elsif VALEUR<>100
 Effzo [M]MAX2
 Grizo [M]MAX2
Else
 Actzo [M]MAX2
Endif
End

########################################
Subprog C_RUBCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE (VALEUR,[M:EXO]RUBCOD(0..[M]TBL-1)) From OBJDIV
If mkstat : End : Endif
Call LECTURE("RUB",VALEUR,GCURLEG) From CONTOBJ
[M:EXO]RUBROW(indice) = [F:RUB]ROW
[M:EXO]RUBTYP(indice) = [F:RUB]TYPRUB

#MAPAD - 2016-02-25 - Req 114309 - START
If [M:EXO]RUBTYP(indice) <> 5 and [M:EXO]RUBTYP(indice) <> 6
Local Integer YESNO
YESNO = 2
Call OUINON(mess(307,10717,1) +" ,do you wish to continue and apply the changes ?",YESNO) From GESECRAN
  If YESNO = 1
    mkstat = 2
    End
  Endif
Endif

#MAPAD - 2016-02-25 - Req 114309 - START
#If [M:EXO]RUBTYP(indice) <> 5 and [M:EXO]RUBTYP(indice) <> 6
#  Wrnbox mess(307,10717,1)
#Endif

#MAPAD - 2016-02-25 - Req 114309 - END


Call LECTEXTRA([M:EXO]RUBDES(indice),"RUBRIQUE","DES",GCURLEG,[F:RUB]COD) From ATEXTRA
Affzo RUBROW(indice),RUBDES(indice),RUBTYP(indice)
End


########################################
Subprog AS_MAX1(VALEUR)
Variable Char    VALEUR()
If [M]RAT1<>100 : mkstat = 1 : End : Endif
End

########################################
Subprog AS_MAX2(VALEUR)
Variable Char    VALEUR()
If [M]RAT2<>100 : mkstat = 1 : End : Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran EXO0) 25/05/2012 18:28:59 (DBA)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
Effzo [M]MAX1,MAX2
Effzo [M]40
End

