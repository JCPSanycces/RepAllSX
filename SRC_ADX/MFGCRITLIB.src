#<AdxTL>@(#)9.0.0.0 $Revision$
#--------------------------------------------------------------------------#
# Gestion des fenêtres Critères des plans de travail
# ACTIONS:
#            - CRITBENCH1    Critères planning global
#            - CRITBENCH2    Critères regroupement production/inter-site
#            - CRITBENCH3    Critères regroupement achat
#            - CRITBENCH4    Critères plan de travail
#            - CRITBENCH6    Critères plan de l'acheteur
#            - CRITBENCH7    Critères PEC sur commandes
#            - CRITBENCH8    Critères PEC sur ordes de sous-traitance
#            - TRTCRIMBO     Critères plan de suivi des temps
#            - TRTCRIMBI     Critères plan de déclaration de production
#            - TRTCRIMBM     Critères plan de suivi des matières
#            - TRTCRIMBR     Critères réintégration
#            - TRTCRIMWG     Critères pesée
#            - TRTCRIMBP     Critères pilotage des plans
#            - CRITSCD1      Paramètres ordonnancement
#            - CRITSCD2      Paramètres optimisation
#            - TRTCRIMBT     Critères fiches techniques
#--------------------------------------------------------------------------#
$ACTION
Case ACTION
    When "OUVRE"    :    Gosub OUVRE
    When "DEBUT"    :    Gosub DEBUT
    When "SETBOUT"  :    Gosub SETBOUT
    When "ABANDON"  :    Gosub ABANDON
    When "OK"       :    Gosub OK
    When "AP_CHOIX" :    Gosub AP_CHOIX
    When "BOUTON"   :    Gosub BOUTON
Endcase
Return

###########################################################################
# ouverture
$OUVRE
Local Char     PARBOUT(10)(1..3)
Local Char     VALBOUT(10)
Local Integer  WFLT

Return

###########################################################################
# chargement
$DEBUT
Case GACTION
    When "CRITBENCH1":   Raz [M:MFB1]
                         [M:MFB1] = [M:MGB]
                         Affzo [M:MFB1]
    When "CRITBENCH2":   Raz [M:MFB2]
                         WFLT = [M:MGP]FLT
                         [MFB2] = [MGP]
                         [M:MFB2]WOS = 1
                         [M:MFB2]WOP = 1
                         [M:MFB2]SOF = 1
                         [M:MFB2]MWF = 1
                         [M:MFB2]TPF = 1
                         If WFLT > 15 : [M:MFB2]WOS = 2 : WFLT -= 16 : Endif
                         If WFLT > 7  : [M:MFB2]WOP = 2 : WFLT -= 8  : Endif
                         If WFLT > 3  : [M:MFB2]SOF = 2 : WFLT -= 4  : Endif
                         If WFLT > 1  : [M:MFB2]MWF = 2 : WFLT -= 2  : Endif
                         If WFLT > 0  : [M:MFB2]TPF = 2 : WFLT -= 1  : Endif
                         Affzo [M:MFB2]
    When "CRITBENCH3":   Raz [M:MFB3]
                         WFLT = [M:MGP]FLT
                         [MFB3] = [MGP]
                         If [F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2
                             [M:MFB3]POS = 1
                             [M:MFB3]POP = 1
                             [M:MFB3]SOF = 1
                             [M:MFB3]MWF = 1
                             [M:MFB3]TPF = 1
                             [M:MFB3]EOF = 1    : # GA 01/09/2006 achat ss-trait
                             # GH 07/03/2014 bug 86424
                             #[M:MFB3]SCF = 1
                             #If WFLT > 31 : [M:MFB3]SCF = 2 : [M:MFB3]EOF = 2 : WFLT -= 32 : Endif
                             If WFLT > 31 : [M:MFB3]EOF = 2 : WFLT -= 32 : Endif
                             If WFLT > 15 : [M:MFB3]POS = 2 : WFLT -= 16 : Endif
                             If WFLT > 7  : [M:MFB3]POP = 2 : WFLT -= 8  : Endif
                             If WFLT > 3  : [M:MFB3]SOF = 2 : WFLT -= 4  : Endif
                             If WFLT > 1  : [M:MFB3]MWF = 2 : WFLT -= 2  : Endif
                             If WFLT > 0  : [M:MFB3]TPF = 2 : WFLT -= 1  : Endif
                         Endif
                         If [F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2
                             [M:MFB3]POS = 1
                             [M:MFB3]SOF = 1
                             [M:MFB3]MWF = 1
                             [M:MFB3]TPF = 1
                             If WFLT > 7  : [M:MFB3]POS = 2 : WFLT -= 8  : Endif
                             If WFLT > 3  : [M:MFB3]SOF = 2 : WFLT -= 4  : Endif
                             If WFLT > 1  : [M:MFB3]MWF = 2 : WFLT -= 2  : Endif
                             If WFLT > 0  : [M:MFB3]TPF = 2 : WFLT -= 1  : Endif
                             Grizo [M:MFB3]POP
                             #Grizo [M:MFB3]SCF : # GH 07/03/2014 bug 86424
                             Grizo [M:MFB3]EOF : # GA 01/09/2006 achat ss-trait
                         Endif
                         Affzo [M:MFB3]
    When "CRITBENCH4":   Raz [M:MFB4]
                         # FQ 70722 GA 01/2011 pb si GFONCTION="FUNGBENCH" car on est venu en tunnel du planning global
                         ###Case GFONCTION
                         ###    When "FUNDBENCH", "FUNDBENCHA" : [M:MFB4] = [M:MGD]
                         ###    When "FUNMLINK" , "FUNMLINKA"  : [M:MFB4] = [M:MLB]
                         ###Endcase
                         If     clalev([M:MGD])  [M:MFB4] = [M:MGD]
                         Elsif  clalev([M:MLB])  [M:MFB4] = [M:MLB]
                         Endif
                         Affzo [M:MFB4]
    When "CRITBENCH5":   Raz [M:MFB5]
                         WFLT = [M:MGP]FLT
                         [MFB5] = [MGP]
                         [M:MFB5]EOS = 1
                         [M:MFB5]EOP = 1
                         [M:MFB5]SOF = 1
                         [M:MFB5]MSF = 1
                         [M:MFB5]TPF = 1
                         If WFLT > 15 : [M:MFB5]EOS = 2 : WFLT -= 16 : Endif
                         If WFLT > 7  : [M:MFB5]EOP = 2 : WFLT -= 8  : Endif
                         If WFLT > 3  : [M:MFB5]SOF = 2 : WFLT -= 4  : Endif
                         If WFLT > 1  : [M:MFB5]MSF = 2 : WFLT -= 2  : Endif
                         If WFLT > 0  : [M:MFB5]TPF = 2 : WFLT -= 1  : Endif
                         Affzo [M:MFB5]
    When "CRITBENCH6":  Raz [M:MFB6]  # Issue 10622 - 2011-12-28 by MUARN : plan acheteur
                        [M:MFB6] = [M:PPI2]
                        [M:MFB6]FCY = [M:POI1]POHFCY # Issue 71069 - 2016-03-18 by MUARN : PJT
                        # Issue 118480 - 2016-10-25 by SR : Gestion mémo std
                        If filinfo(filpath("ETM",GUSER+"_"+GPTRNUM+"_STD","ppi2",0),0)>=0
                            Raz [M:MFB6]
                            Call LECMEMO("STD","[M:MFB6]",GPTRNUM+"~ppi2") From GMEMO
                        Endif
                        Affzo [M:MFB6]
                        # End issue 118480
    When "CRITBENCH7":  Raz [M:MFB7] # Issue 10622 - 2011-12-28 by MUARN : PEC sur commandes
                        [M:MFB7] = [M:PPI1]
                       # Issue 118480 - 2016-10-25 by SR : Gestion mémo std
                        If GFONCTION="GESPOD"
                         If filinfo(filpath("ETM",GUSER+"_"+"STD","ppi",0),0)>=0
                            Raz [M:MFB7]
                            Call LECMEMO("STD","[M:MFB7]", "ppi") From GMEMO
                         Endif
                         Grizo [M:MFB7]PJTSTR, PJTEND
                        Else
                          If filinfo(filpath("ETM",GUSER+"_"+GPTRNUM+"_STD","ppi",0),0)>=0
                              Raz [M:MFB7]
                              Call LECMEMO("STD","[M:MFB7]",GPTRNUM+"~ppi") From GMEMO
                          Endif
                        Endif
                        # Issue 71069 - 2016-03-29 by MUARN : PJT et DL
                        # Issue 118480 - 2016-10-25 by SR :  Déplacé
#                        If GFONCTION="GESPOD"
#                          Grizo [M:MFB7]PJTSTR, PJTEND
#                        Endif
                         # End issue 118480
                        Affzo [M:MFB7]
    When "CRITBENCH8":  Raz [M:MFB8] # Issue 79579 - 2011-12-28 by MUARN : PEC sur ordes sous-traitance
                        [M:MFB8] = [M:PPI1]
                        # Issue 118480 - 2016-10-25 by SR : Gestion mémo std
                        If filinfo(filpath("ETM",GUSER+"_"+GSCOPTRNUM+"_STD","ppi1",0),0)>=0
                            Raz [M:MFB8]
                            Call LECMEMO("STD","[M:MFB8]",GSCOPTRNUM+"~ppi1") From GMEMO
                        Endif
                        # End issue 118480
                        # Issue 71069 - 2016-04-27 by MUARN : PJT
                        If [M:PPI1]PJTDOC <> "" : [M:MFB8]PJTSTR = [M:PPI1]PJTDOC : [M:MFB8]PJTEND = [M:PPI1]PJTDOC : Endif
                        Affzo [M:MFB8]
    When "TRTCRIMBO" :  Raz [M:MTB1]
                        Gosub DEBUT_CRIMBO
                        Affzo [M:MTB1]
    When "TRTCRIMBI" :  Raz [M:MTB3]
                        Gosub DEBUT_CRIMBI
                        Affzo [M:MTB3]
    When "TRTCRIMBM" :  Raz [M:MTB2]
                        Gosub DEBUT_CRIMBM
                        Affzo [M:MTB2]
    When "TRTCRIMBR" :  Raz [M:MTB2]
                        Gosub DEBUT_CRIMBR
                        Affzo [M:MTB2]
    When "TRTCRIMWG" :  Raz [M:MFW1]
                        Gosub DEBUT_CRIMWG
                        Affzo [M:MFW1]
    When "TRTCRIMBP" :  Raz [M:MTB4]
                        Gosub DEBUT_CRIMBP
                        Affzo [M:MTB4]
    When "CRITSCD1":    Raz [M:MOP2]
                        [M:MOP2] = [M:MOP1]
                        [M:MOP2]UPDWCR = 2
                        # 15806 MM 05.05 : gestion memo STD
                        If filinfo(filpath("ETM",GUSER+"_"+"STD","scd",0),0)>=0
                            Raz [M:MOP2]
                            Call LECMEMO("STD","[M:MOP2]", "scd") From GMEMO
                        Endif
                        Affzo [M:MOP2]
    When "CRITSCD2" :   # 15806 MM 05.05 : gestion memo STD
                        Raz [M:MOP2]
                        [M:MOP2] = [M:MOP1]
                        [M:MOP2]UPDWCR = 2
                        If filinfo(filpath("ETM",GUSER+"_"+"STD","sce",0),0)>=0
                            Raz [M:MOP2]
                            Call LECMEMO("STD","[M:MOP2]", "sce") From GMEMO
                        Endif
                        Affzo [M:MOP2]
    When "TRTCRIMBT" :  Raz [M:MTB5]
                        Gosub DEBUT_CRIMBT
                        Affzo [M:MTB5]

Endcase
Return

###########################################################################
# état boutons
$SETBOUT
Case GACTION
    When "CRITBENCH1":    ETABOU(GVALI)=1
                          ETABOU(GABAN)=1
                          ETABOU(GSPE1)=1
                          ETABOU(GSPE2)=1
                          ETABOU(GSPE3)=1
                          ETABOU(GPREM)=0
                          ETABOU(GDERN)=0
                          ETABOU(GSUIV)=0
                          ETABOU(GPREC)=0
    When "CRITBENCH2","CRITBENCH3","CRITBENCH5"
                          ETABOU(GVALI)=1
                          ETABOU(GABAN)=1
                          # GH 07/03/2014 bug 97631 en mode consultatif Mémo et Eff.mémo inactifs
                          #ETABOU(GSPE1)=1
                          #If [F:BTS]TRSCNL <> 2
                          #    ETABOU(GSPE2)=1
                          #    ETABOU(GSPE3)=1
                          #Endif
                          ETABOU(GSPE2)=1     : # Rappel mémo
                          If [F:BTS]TRSCNL = 2
                              ETABOU(GSPE1)=0 : # Mémo
                              ETABOU(GSPE3)=0 : # Eff. mémo
                          Endif
Endcase
Return

###########################################################################
# action bouton OK
$OK
Case GACTION
    When "CRITBENCH1":    [M:MGB]= [M:MFB1]
                          [M:MGB]REACT = 2
                          Affzo [M:MGB]           # 15806 MM 05.05
    When "CRITBENCH2":    [M:MGP]= [M:MFB2]
                          If [M:MFB2]WOS = 2 : WFLT += 16 : Endif
                          If [M:MFB2]WOP = 2 : WFLT += 8  : Endif
                          If [M:MFB2]SOF = 2 : WFLT += 4  : Endif
                          If [M:MFB2]MWF = 2 : WFLT += 2  : Endif
                          If [M:MFB2]TPF = 2 : WFLT += 1  : Endif
                          [M:MGP]FLT = WFLT
                          [M:MGP]REACT = 2
    When "CRITBENCH3":    [M:MGP]      = [M:MFB3]
                          If [F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2
                              #If [M:MFB3]SCF = 2 | [M:MFB3]EOF = 2 : WFLT += 32 : Endif : # GH 07/03/2014 bug 86424
                              If [M:MFB3]EOF = 2 : WFLT += 32 : Endif
                              If [M:MFB3]POS = 2 : WFLT += 16 : Endif
                              If [M:MFB3]POP = 2 : WFLT += 8  : Endif
                              If [M:MFB3]SOF = 2 : WFLT += 4  : Endif
                              If [M:MFB3]MWF = 2 : WFLT += 2  : Endif
                              If [M:MFB3]TPF = 2 : WFLT += 1  : Endif
                          Endif
                          If [F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2
                              If [M:MFB3]POS = 2 : WFLT += 8  : Endif
                              If [M:MFB3]SOF = 2 : WFLT += 4  : Endif
                              If [M:MFB3]MWF = 2 : WFLT += 2  : Endif
                              If [M:MFB3]TPF = 2 : WFLT += 1  : Endif
                          Endif
                          [M:MGP]FLT = WFLT
                          [M:MGP]REACT = 2
    When "CRITBENCH4":
                         # FQ 70722 GA 01/2011 pb si GFONCTION="FUNGBENCH" car on est venu en tunnel du planning global
                         ### Case GFONCTION
                         ###     When "FUNDBENCH","FUNDBENCHA":    [M:MGD]      = [M:MFB4]
                         ###                                       [M:MGD]REACT = 2
                         ###     When "FUNMLINK","FUNMLINKA":      [M:MLB]      = [M:MFB4]
                         ###                                       [M:MLB]REACT = 2
                         ### Endcase
                         If     clalev([M:MGD]) : [M:MGD] = [M:MFB4]
                                                  [M:MGD]REACT = 2
                         Elsif  clalev([M:MLB]) : [M:MLB] = [M:MFB4]
                                                  [M:MLB]REACT = 2
                         Endif
    When "CRITBENCH5":    [M:MGP]      = [M:MFB5]
                          If [M:MFB5]EOS = 2 : WFLT += 16 : Endif
                          If [M:MFB5]EOP = 2 : WFLT += 8  : Endif
                          If [M:MFB5]SOF = 2 : WFLT += 4  : Endif
                          If [M:MFB5]MSF = 2 : WFLT += 2  : Endif
                          If [M:MFB5]TPF = 2 : WFLT += 1  : Endif
                          [M:MGP]FLT = WFLT
                          [M:MGP]REACT = 2
                          # Issue 10622 - 2011-12-28 by MUARN : plan acheteur
    When "CRITBENCH6":    [M:PPI2]      = [M:MFB6]
                          Affzo [PPI2]1-99
                          Effzo [PPI2]10 : Raz [M:PPI2]TOTQTY
    When "CRITBENCH7":    # Issue 10622 - 2011-12-28 by MUARN : PEC sur commandes
                          [M:PPI1]=[M:MFB7]
                          Affzo [PPI1]1-99
                          Effzo[PPI1]10 : Raz[M:PPI1]TOTQTY
                          # Issue 79579 - 2011-12-28 by MUARN : PEC sur ordres sous-traitance
    When "CRITBENCH8":    [M:PPI1]=[M:MFB8]
                          Affzo [PPI1]1-99
                          Effzo[PPI1]10 : Raz[M:PPI1]TOTQTY
    When "TRTCRIMBO" :    Gosub OK_CRIMBO
                          [M:MBO]REACT = 2
    When "TRTCRIMBI" :    Gosub OK_CRIMBI
                          [M:MBI]REACT = 2
    When "TRTCRIMBM" :    Gosub OK_CRIMBM
                          [M:MBM]REACT = 2
    When "TRTCRIMBR" :    Gosub OK_CRIMBR
                          [M:MBR]REACT = 2
    When "TRTCRIMWG" :    Gosub OK_CRIMWG
                          [M:MWG]REACT = 2
    When "TRTCRIMBP" :    Gosub OK_CRIMBP
                          [M:MBP]REACT = 2
    When "CRITSCD1":      [M:MOP1]      = [M:MOP2]
    When "CRITSCD2":      [M:MOP1]      = [M:MOP2]
    When "TRTCRIMBT" :    Gosub OK_CRIMBT
                          [M:MBT]REACT = 2
Endcase
Return

###########################################################################
# action bouton ABANDON
$ABANDON
Case GACTION
     When "TRTCRIMBO" : Gosub ABA_CRIMBO
     When "TRTCRIMBI" : Gosub ABA_CRIMBI
     When "TRTCRIMBM" : Gosub ABA_CRIMBM
     When "TRTCRIMBR" : Gosub ABA_CRIMBR
     When "TRTCRIMWG" : Gosub ABA_CRIMWG
     When "TRTCRIMBP" : Gosub ABA_CRIMBP
     When "TRTCRIMBT" : Gosub ABA_CRIMBT
Endcase
Return

###########################################################################
# 15806 MM 05.05 : memo standard
$AP_CHOIX

Case GACTION
    When "CRITBENCH2"
        If REPONSE = 1101    #bouton memo
             If [M:MFB2]WOS = 2 : WFLT += 16 : Endif
             If [M:MFB2]WOP = 2 : WFLT += 8  : Endif
             If [M:MFB2]SOF = 2 : WFLT += 4  : Endif
             If [M:MFB2]MWF = 2 : WFLT += 2  : Endif
             If [M:MFB2]TPF = 2 : WFLT += 1  : Endif
             [M:MFB2]TMPFLT = WFLT
        Endif
    When "CRITBENCH3"
        If REPONSE = 1101    #bouton memo
            If [F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2
                # If [M:MFB3]SCF = 2 | [M:MFB3]EOF = 2 : WFLT += 32 : Endif : # GH 07/03/2014 bug 86424
                If [M:MFB3]EOF = 2 : WFLT += 32 : Endif
                If [M:MFB3]POS = 2 : WFLT += 16 : Endif
                If [M:MFB3]POP = 2 : WFLT += 8  : Endif
                If [M:MFB3]SOF = 2 : WFLT += 4  : Endif
                If [M:MFB3]MWF = 2 : WFLT += 2  : Endif
                If [M:MFB3]TPF = 2 : WFLT += 1  : Endif
            Endif
            If [F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2
                If [M:MFB3]POS = 2 : WFLT += 8  : Endif
                If [M:MFB3]SOF = 2 : WFLT += 4  : Endif
                If [M:MFB3]MWF = 2 : WFLT += 2  : Endif
                If [M:MFB3]TPF = 2 : WFLT += 1  : Endif
            Endif
            [M:MFB3]TMPFLT = WFLT
        Endif
    When "CRITBENCH5"
        If REPONSE = 1101    #bouton memo
             If [M:MFB5]EOS = 2 : WFLT += 16 : Endif
             If [M:MFB5]EOP = 2 : WFLT += 8  : Endif
             If [M:MFB5]SOF = 2 : WFLT += 4  : Endif
             If [M:MFB5]MSF = 2 : WFLT += 2  : Endif
             If [M:MFB5]TPF = 2 : WFLT += 1  : Endif
             [M:MFB5]TMPFLT = WFLT
        Endif
    When "TRTCRIMBO"
        If REPONSE = 1101
            Raz  [M:MTB1]WSRT
            Case [M:MTB1]CRIT1 :
                 When 1 : [M:MTB1]WSRT += 1
                 When 2 : [M:MTB1]WSRT += 2
                 When 3 : [M:MTB1]WSRT += 4
                 When 4 : [M:MTB1]WSRT += 8
            Endcase
            Case [M:MTB1]CRIT2 :
                 When 1 : [M:MTB1]WSRT += 16
                 When 2 : [M:MTB1]WSRT += 32
                 When 3 : [M:MTB1]WSRT += 64
                 When 4 : [M:MTB1]WSRT += 128
            Endcase
        Endif
     When "TRTCRIMBI"
        If REPONSE = 1101
            Raz  [M:MTB3]WSRT
            Case [M:MTB3]CRIT1 :
                When 1 : [M:MTB3]WSRT += 1
                When 2 : [M:MTB3]WSRT += 2
                When 3 : [M:MTB3]WSRT += 4
            Endcase
            Case [M:MTB3]CRIT2 :
                When 1 : [M:MTB3]WSRT += 8
                When 2 : [M:MTB3]WSRT += 16
                When 3 : [M:MTB3]WSRT += 32
            Endcase
        Endif
    When "TRTCRIMBM"
        $TRT_REP
        If REPONSE = 1101
            Raz  [M:MTB2]WSRT
            Case [M:MTB2]CRIT1 :
                 When 1 : [M:MTB2]WSRT += 1
                 When 2 : [M:MTB2]WSRT += 2
                 When 3 : [M:MTB2]WSRT += 4
                 When 4 : [M:MTB2]WSRT += 8
            Endcase
            Case [M:MTB2]CRIT2 :
                 When 1 : [M:MTB2]WSRT += 16
                 When 2 : [M:MTB2]WSRT += 32
                 When 3 : [M:MTB2]WSRT += 64
                 When 4 : [M:MTB2]WSRT += 128
            Endcase
        Endif
    When "TRTCRIMBR"
        Goto TRT_REP
    When "TRTCRIMBT"
        If REPONSE = 1101
            Raz [M:MTB5]WSRT
            Case [M:MTB5]CRIT1 :
                When 1 : [M:MTB5]WSRT += 1
                When 2 : [M:MTB5]WSRT += 2
                When 3 : [M:MTB5]WSRT += 4
                When 4 : [M:MTB5]WSRT += 8
            Endcase
            Case [M:MTB5]CRIT2 :
                When 1 : [M:MTB5]WSRT += 16
                When 2 : [M:MTB5]WSRT += 32
                When 3 : [M:MTB5]WSRT += 64
                When 4 : [M:MTB5]WSRT += 128
            Endcase
        Endif
Endcase

Return

###########################################################################
# 15806 MM 05.05 : memo standard
$BOUTON
Case GACTION
    When "CRITBENCH2" :
        Case BOUT
            When "1" :  #bouton memo
                If [F:BTS]PLANNER = 2 : [M:MGP]FLT = 24: Endif
                Raz WFLT,[M:MFB2]TMPFLT
        Endcase
    When "CRITBENCH3" :
        Case BOUT
            When "1" :
                If [F:BTS]APPBUY  = 2 | [F:BTS]APPINT = 2  : [M:MGP]FLT = 15 : Endif
                If [F:BTS]BUYER   = 2 | [F:BTS]INTBUY = 2
                    If [F:BTS]BUYER   = 2  : [M:MGP]FLT = 56 : Else : [M:MGP]FLT = 24 : Endif
                Endif
                Raz WFLT,[M:MFB3]TMPFLT
        Endcase
    When "CRITBENCH5" :
        Case BOUT
            When "1" :  #bouton memo
                If [F:BTS]PLANNER = 2 : [M:MGP]FLT = 24: Endif
                Raz WFLT,[M:MFB5]TMPFLT
        Endcase
     When "TRTCRIMBO"
         Case BOUT
             When "M" : Raz  [M:MTB1]WSRT
         Endcase
     When "TRTCRIMBI"
         Case BOUT
             When "M" : Raz  [M:MTB3]WSRT
         Endcase
     When "TRTCRIMBM"
         Case BOUT
             When "M" : Raz  [M:MTB2]WSRT
         Endcase
    When "TRTCRIMBR"
         Case BOUT
             When "M" : Raz  [M:MTB2]WSRT
         Endcase
