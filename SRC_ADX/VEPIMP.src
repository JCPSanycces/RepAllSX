#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","VEPIMP","VEPIMP",3,"") From GTRAITE
End

################################################################################
$ACTION
Case [L]ACTION
 When "INIT_DIA" : Goto INIT_DIA
 When "CONTROLE" : [L]TMP=1
 When "EXEC"     : Goto EXEC
#-------------------------------------------------------------------------------
 When "SEL_TABLE"
  Case [L]COUZON
   When "RPT"    : [L]OBJET="ARP"
   When "PRT"    : Goto SEL_PRT
  Endcase
 When "CHX_TABLE"
  Case [L]COUZON
   When "RPT"    : Goto CHX_RPT
  Endcase
Endcase
Return

################################################################################
#
# GTRAITE
#
################################################################################

$INIT_DIA
If !clalev([F:ARX]) : Local File AREPORTX [ARX] : Endif
If !clalev([F:AIM]) : Local File APRINTER [AIM] : Endif
Raz [M:VEI]
#81084
#Call PARAM(GCURLEG,"GRURPTBUL",[M:VEI]GRURPTBUL) From ADOVAL
Return

#-------------------------------------------------------------------------------
$EXEC
Local Integer I, K
Local Date    PYRDAT
Local Char    FICHIER(255), TBPAR(20)(1..50), TBVAL(20)(1..50), RPTBUL([V]GLONARP)
Local Char    CRITERE(255)
If !clalev([F:VEP2]) : Local File VALEMP [VEP2] : Endif

CRITERE = 'PYRDAT>=[M:VEI]DATPAYSTR & PYRDAT<=[M:VEI]DATPAYEND'
If [M:VEI]ALLCPY<>2 : CRITERE -= '& CPY = [M:VEI]CPY' : Endif
If [M:VEI]ALLFCY<>2 : CRITERE -= '& FCY = [M:VEI]FCY' : Endif

Repeat
 If [M:VEI]ALLRPT=2
  Filter [ARX] Where TYPCOD=1 & INTCOD=[M:VEI]GRURPTBUL & EXTCOD>[L]RPTBUL
  Read [ARX]ARX0 First
  Filter [ARX]
  If fstat : Break : Else [L]RPTBUL=[F:ARX]EXTCOD : Endif
 Elsif [L]RPTBUL=""
  [L]RPTBUL=[M:VEI]RPT
 Else
  Break
 Endif
 Filter [VEP2] Where evalue(CRITERE) & RPTBUL=[L]RPTBUL & STA=2
 For [VEP2]
  I = find([F:VEP2]FCY,GSITE)
  [L]PYRDAT =[F:VEP2]PYRDAT
  [L]FICHIER=[F:VEP2]BUL
  [L]FICHIER=[M:VEI]FDR+"\"+[L]FICHIER+".pdf"
    If [M:VEI]FIL2<2
     If [F:AIM]PRTSRV="" : # bogue 41909
      Call EXISTE("#@"+[L]FICHIER,K) From ORDSYS
     Elsif instr(1,[F:AIM]PRTSRV,adxmac(-1))=1
      Call EXISTE([L]FICHIER,K) From ORDSYS
     Else : # impossible de vérifier donc on force le réarchivage
      K=0
     Endif
    Else
     K=0
    Endif

    If !K
     Raz [L]TBVAL, [L]TBPAR
     K+=1 : [L]TBPAR(K)="matdeb"      : [L]TBVAL(K)=[F:VEP2]EMP
     K+=1 : [L]TBPAR(K)="matfin"      : [L]TBVAL(K)=[F:VEP2]EMP
     K+=1 : [L]TBPAR(K)="buldeb"      : [L]TBVAL(K)=[F:VEP2]BUL
     K+=1 : [L]TBPAR(K)="bulfin"      : [L]TBVAL(K)=[F:VEP2]BUL
     K+=1 : [L]TBPAR(K)="cpy"         : [L]TBVAL(K)=GSOCSITE(I)
     K+=1 : [L]TBPAR(K)="fcydeb"      : [L]TBVAL(K)=[F:VEP2]FCY
     K+=1 : [L]TBPAR(K)="fcyfin"      : [L]TBVAL(K)=[F:VEP2]FCY
     K+=1 : [L]TBPAR(K)="datdeb"      : [L]TBVAL(K)=num$([L]PYRDAT)
     K+=1 : [L]TBPAR(K)="datfin"      : [L]TBVAL(K)=num$([L]PYRDAT)
     K+=1 : [L]TBPAR(K)="tri"         : [L]TBVAL(K)=num$([M:VEI]SRT)
     K+=1 : [L]TBPAR(K)="flgprn"      : [L]TBVAL(K)="1"
     K+=1 : [L]TBPAR(K)="txt"         : [L]TBVAL(K)=mess(182,10703,1) : # Duplicata
     K+=1 : [L]TBPAR(K)="impsim"      : [L]TBVAL(K)=num$([M:VEI]SHOPYR)
     K+=1 : [L]TBPAR(K)="impsel"      : [L]TBVAL(K)="1"
     K+=1 : [L]TBPAR(K)="archivage"   : [L]TBVAL(K)="1"
     If [M:VEI]BAT=2
      Call ETATDIFF( [L]RPTBUL    ,[M:VEI]PRT   ,[V]GLANGUE,0,"",[L]TBPAR,[L]TBVAL
&                  , [M:VEI]BATDAT,[M:VEI]BATTIM) From AIMP3
     Else
      Call ETAT([L]RPTBUL,[M:VEI]PRT,[V]GLANGUE,0,"",[L]TBPAR,[L]TBVAL) From AIMP3
     Endif
    Endif
 Next
 Filter [VEP2]
Until 0

Call DEBTRANS From GLOCK

Trbegin [VEP2]
 Filter [VEP2] Where evalue(CRITERE) & RPTBUL=[L]RPTBUL & STA=2
 For [VEP2]
  [F:VEP2]STA = 3
  Rewrite [VEP2]
  If fstat
   GOK=0 : Call FSTA("VEP") From GLOCK : Break
  Endif
 Next
 Filter [VEP2]
 If GOK=0 : Goto ROLL_VEP : Endif
Commit
Return

$ROLL_VEP
Rollback
Return

################################################################################
#
# Etiquettes de l'écran VEPIMP
#
################################################################################

$INIRPT
Local Char GRURPTBUL([V]GLONARX)
If clalev([M:VEI])
 [L]GRURPTBUL=[M:VEI]GRURPTBUL
Else
 Call PARAM(GCURLEG,"GRURPTBUL",[L]GRURPTBUL) From ADOVAL
Endif
If [L]GRURPTBUL=""
 If !clalev([F:ADP]) : Local File ADOPAR [ADP] : Endif
 Read [ADP]ADP1="GRURPTBUL"
 [V]GMESSAGE=mess(171,133,1)-": GRURPTBUL ("+func AFNC.TEXTE([F:ADP]NAM)+")"
 #           Paramètre non renseigné
 mkstat     =2
 Return
Endif
If !clalev([F:ARP]) : Local File AREPORT  [ARP] : Endif
If !clalev([F:ARX]) : Local File AREPORTX [ARX] : Endif
If !clalev([F:ACC]) : Local File ACCES    [ACC] : Endif
Return

########################################
Subprog C_BAT(VALEUR)
Variable Integer VALEUR

If [L]VALEUR=2 : Actzo [VEI] BATDAT, BATTIM
Else             Effzo [VEI] BATDAT, BATTIM : Diszo [VEI] BATDAT, BATTIM
Endif

End

########################################
Subprog AS_BATDAT(VALEUR)
Variable Date    VALEUR

If [M:VEI]BAT<2 : mkstat=1 : Elsif [L]VALEUR=[0/0/0] : [L]VALEUR=datesyst : Endif

End

########################################
Subprog AS_BATTIM(VALEUR)
Variable Char    VALEUR()

If    [M:VEI]BAT<2 : mkstat=1
Elsif [L]VALEUR="" : [L]VALEUR=left$(ctrans(time$,":",""),4)
Endif

End

########################################
Subprog C_ALLRPT(VALEUR)
Variable Integer VALEUR

If [L]VALEUR=2 : Effzo [VEI] RPT : Diszo [VEI] RPT
Else             Actzo [VEI] RPT
Endif

End

########################################
Subprog AS_RPT(VALEUR)
Variable Char    VALEUR()

If    [M:VEI]ALLRPT=2 : mkstat   =1
Elsif [L]VALEUR=""    : [L]VALEUR=[V]GNOMRPTBUL
Endif

End

########################################
$CHX_RPT
Gosub INIRPT
If mkstat
 Call ERREUR([V]GMESSAGE) From GESECRAN
 Raz [L]SENS, [V]GMESSAGE, status
 Return
Endif
#81084
Link [ARP] With [ARX]ARX0(1)~=[L]GRURPTBUL;1;RPTCOD
&             , [ATX]NUMERO  =[V]GLANGUE;RPTDES
&             , [ACC]CODACC  =[V]GUSER;ACS
&            As [LNK]
&         Where [ARX]LAN=[V]GLANGUE or [ARX]LAN=""
#end 81084
Default File [LNK]
Return

########################################
Subprog C_RPT(VALEUR)
Variable Char    VALEUR()

Gosub INIRPT
If mkstat : End : Endif

#81084
Filter [ARX] Where INTCOD=[L]GRURPTBUL & TYPCOD=1 & EXTCOD=[L]VALEUR & (LAN=[V]GLANGUE or LAN="")
Look [ARX]ARX0 First
Filter [ARX]
If fstat
  [V]GMESSAGE=mess(104,10720,1) : # Incompatibilité de législation
  mkstat     =2
Endif
#end 81084
End

########################################
Subprog AS_PRT(VALEUR)
Variable Char    VALEUR()

If [L]VALEUR>"" : End : Endif

If [M:VEI]BAT=2 : Filter [AIM] Where PRTSRV>"" : Endif
For [AIM] Where PRT=4 & PRTFMT=29
 If [L]VALEUR="" : [L]VALEUR=[F:AIM]COD : Else [L]VALEUR="" : Break : Endif
Next
Filter [AIM]

End

########################################
$SEL_PRT
[L]OBJET  ="AIM"
[L]CRITERE="PRT=4 & PRTFMT=29"-string$([M:VEI]BAT=2 | [V]GBROWS,"& PRTSRV>''")
Filter [AIM] Where evalue([L]CRITERE)
If !rowcount([AIM]) : [L]CRITERE="" : Endif
Filter [AIM]
Return

########################################
Subprog C_PRT(VALEUR)
Variable Char    VALEUR()

Call LECTURE("AIM",[L]VALEUR,"") From CONTOBJ
If [F:AIM]PRT<>4 | [F:AIM]PRTFMT<>29
 [V]GMESSAGE=mess(180,10703,1)
 #           La sortie de l'imprimante n'est pas sous forme de fichier PDF
 mkstat     =2
Elsif ([M:VEI]BAT=2 | [V]GBROWS) & [F:AIM]PRTSRV=""
 [V]GMESSAGE=mess(90,150,1) : # Le serveur d'impression doit être renseigné
 mkstat     =2
Endif

End

########################################
Subprog IB_FDR

# 41909
If [F:AIM]PRTSRV="" | instr(1,[F:AIM]PRTSRV,adxmac(-1))<>1 : Raz [V]GBOUTS : Endif

End

########################################
Subprog C_FDR(VALEUR)
Variable Char    VALEUR()

Local Integer STAT

# 41909
If left$(VALEUR,2)="#@"
 [V]GMESSAGE="#@ :"-mess(127,100,1) : # Fonction impossible dans le contexte
 mkstat     =2
Elsif !instr(1,[L]VALEUR,"/") & !instr(1,[L]VALEUR,"\") & ([V]GBROWS | [M:VEI]BAT=2)
 [V]GMESSAGE=mess(160,100,1) : # Le chemin doit être indiqué en absolu
 mkstat     =2
Else
 If instr(1,[F:AIM]PRTSRV,adxmac(-1))=1
  Call EXISTE([L]VALEUR,[L]STAT) From ORDSYS
 Elsif [F:AIM]PRTSRV=""
  Call EXISTE("#@"+[L]VALEUR,[L]STAT) From ORDSYS
 Else
  [L]STAT=2 : # on peut pas vérifier l'existence du répertoire,
              # on fait confiance à l'utilisateur
 Endif
 Case [L]STAT
  When 2
  When 0       : mkstat=2 : [V]GMESSAGE=mess(9,141,1)     : # Répertoire inexistant
  When Default : mkstat=2 : [V]GMESSAGE=mess(181,10703,1) : # Répertoire incorrect
 Endcase
Endif
# fin 41909

End

################################################################################
#
# Appelé par TRT/ADOVAL (Valeurs paramètres)
#
################################################################################

Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM, VALEUR
Variable Integer OK

Case [L]PARAM
When "GRURPTBUL"
 If !clalev([F:ARX]) : Local File AREPORTX [ARX] : Endif
 Look [ARX]ARX0(1)=[L]VALEUR
 If fstat
  Call ERREUR(mess(178,10703,1)) From GESECRAN : # Code impression inexistant
  [L]OK=0
 Else
  [L]OK=1
 Endif
Endcase

End

#81084
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
Call PARAM(GCURLEG,"GRURPTBUL",[M:VEI]GRURPTBUL) From ADOVAL
End
#End 81084

######################################################################################
## Etiquette ajoutée par le superviseur (écran VEPIMP) 07/08/2013 16:33:30 (DLE)
######################################################################################
Subprog D_INI(VALEUR)
Variable Char VALEUR
If [M]ALLRPT=2 : Diszo [M]RPT    : Else : Actzo [M]RPT    : Endif
If [M]BAT=2    : Actzo BATDAT, BATTIM : Else : Diszo BATDAT, BATTIM : Endif
End
######################################################################################
