#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du fichier FAMPB
Call OBJET ("PBL", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "FERME"       : Gosub FERME
    When "SETBOUT"     : Gosub SETBOUT
    When "LIENS"       : Gosub LIENS
    When "RAZCRE"      : Gosub RAZCRE
    When "RAZDUP"      : Gosub RAZDUP
    When "INICRE"      : Gosub INICRE
    When "CREATION"    : Gosub CREATION
    When "MODIF"       : Gosub MODIF
    When "ANNULE"      : Gosub ANNULE     # FGR 23/09/2009 : X3SUIVI58024
    When "APRES_CRE"   : Gosub APRES_CRE
    When "APRES_MOD"   : Gosub APRES_MOD
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GCPBLCPT(GLONANM)   # Code compteur pour famille de compétence.
Global Char SZTAB_REP(GLONREP)(dim([M:PBL1]REPNUM))
Global Integer INBTAB_REP
Global Char SZTAB_QUE(GLONVCR)(dim([M:PBL2]QUENUM))
Global Integer INBTAB_QUE

  Raz SZTAB_REP
  Raz SZTAB_QUE
  INBTAB_REP = 0
  INBTAB_QUE = 0
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If !clalev ([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=12
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(5)
  #  GCPBLCPT = [F:TCA]CODNUM(5)
  GSOCIETE = ""
  GCURLEG = ""
  Call READ_COUNTER("", 12, 5, GSOCIETE, GCURLEG, GCPBLCPT, GMANCOU) From CRM_UTIL
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
Return

##########################################################################################################
$FERME
  Close Local File [PBR]
  Close Local File [PBQ]
  Kill GCPBLCPT
  Kill SZTAB_REP
  Kill INBTAB_REP
  Kill SZTAB_QUE
  Kill INBTAB_QUE
Return

##########################################################################################################
$SETBOUT
  If REP = "" Then
    CHMEN += "23"
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$RAZDUP
  Gosub RAZ_SZTAB_REP From SUBPBLB
  Gosub RAZ_SZTAB_QUE From SUBPBLB
  [M:PBL0]SUT = ""
Return

##########################################################################################################
$RAZCRE
  Gosub RAZ_SZTAB_REP From SUBPBLB
  Gosub RAZ_SZTAB_QUE From SUBPBLB
  Grizo [M:PBL1]ALLREP
  Grizo [M:PBL2]ALLQUE
  Actzo [M:PBL2]PBLBPC
  Affzo [M:PBL0]1-99
  Affzo [M:PBL1]1-99
  Affzo [M:PBL2]1-99
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # Récupération du compteur de contrat de service.
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK", "", GCPBLCPT, date$, "", [M:PBL0]NUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:PBL]NUM = [M:PBL0]NUM
      Affzo [M:PBL0]NUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
$LIENS
  #Charge les tableaux collaborateurs et queues.
  Gosub LOAD_REP From SUBPBLB
  Gosub LOAD_QUE From SUBPBLB
  #Charge les points à débiter
  Gosub LOAD_PIT From SUBPBLB
  #Affichage de la description de la famille de compétence parent
  If [M:PBL0]PAEGRPNUM = "" Then
    [M:PBL0]PBLCLA = ""
  Else
    Read [PBL]PBL0=[M:PBL0]PAEGRPNUM
    If fstat Then
      [M:PBL0]PBLCLA = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:PBL0]PBLCLA = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:PBL0]PBLCLA,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  [M:PBL1]ALLREP = 1
  [M:PBL2]ALLQUE = 1
  Gosub LOAD_SZTAB_REP From SUBPBLB
  Gosub LOAD_SZTAB_QUE From SUBPBLB
  [M:PBL0]PREPAE = [M:PBL0]PAEGRPNUM
  [M:PBL2]PREBPC = [M:PBL2]PBLBPC
  #Grise ou dégrise les champs Récupérer de la famille parent.
  If [M:PBL0]PAEGRPNUM = "" Then
    Grizo [M:PBL1]ALLREP
    Grizo [M:PBL2]ALLQUE
    Actzo [M:PBL2]PBLBPC
  Else
    Actzo [M:PBL1]ALLREP
    Actzo [M:PBL2]ALLQUE
    Grizo [M:PBL2]PBLBPC
  Endif
  Affzo [M:PBL1]1-99
  Affzo [M:PBL2]1-99
Return

##########################################################################################################
$CREATION
  # FGR 23/09/2009 : X3SUIVI58024
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:PBL0]GRPPBLDESAXX,"FAMPB","GRPPBLDESAXX",[M:PBL0]NUM,"") From ATEXTRA
  Gosub SAVE_REP From SUBPBLB
  If GOK < 0 Then
    GERR = 1
    Return
  Endif
  Gosub SAVE_QUE From SUBPBLB
  If GOK < 0 Then
    GERR = 1
    Return
  Endif
  Gosub SAVE_PIT From SUBPBLB
  If GOK < 0 Then
    GERR = 1
    Return
  Endif
Return

##########################################################################################################
$MODIF
  # FGR 23/09/2009 : X3SUIVI58024
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:PBL0]GRPPBLDESAXX,"FAMPB","GRPPBLDESAXX",[M:PBL0]NUM,"") From ATEXTRA
  Gosub SAVE_REP From SUBPBLB
  If GOK < 0 Then
    GERR = 1
    Return
  Endif
  Gosub SAVE_QUE From SUBPBLB
  If GOK < 0 Then
    GERR = 1
    Return
  Endif
  #On a modifié le filtre client ou on a modifié la compétence parent
  If [M:PBL2]PREBPC <> [M:PBL2]PBLBPC or [M:PBL0]PREPAE <> [M:PBL0]PAEGRPNUM Then
    Gosub SETPBLPAE From SUBPBLB
  Endif
  If GOK < 0 Then
    GERR = 1
    Return
  Endif
  Gosub SAVE_PIT From SUBPBLB
  If GOK < 0 Then
    GERR = 1
    Return
  Endif
Return

##########################################################################################################
$ANNULE
  # FGR 23/09/2009 : X3SUIVI58024
  #--- maj de la table des libéllés traduisibles
  Call SUPTEXTRA("FAMPB","GRPPBLDESAXX",[M:PBL0]NUM,"") From ATEXTRA
Return

##########################################################################################################
$APRES_CRE
  Gosub LOAD_SZTAB_REP From SUBPBLB
  Gosub LOAD_SZTAB_QUE From SUBPBLB
  [M:PBL0]PREPAE = [M:PBL0]PAEGRPNUM
  [M:PBL2]PREBPC = [M:PBL2]PBLBPC
Return

##########################################################################################################
$APRES_MOD
  Gosub LOAD_SZTAB_REP From SUBPBLB
  Gosub LOAD_SZTAB_QUE From SUBPBLB
  [M:PBL0]PREPAE = [M:PBL0]PAEGRPNUM
  [M:PBL2]PREBPC = [M:PBL2]PBLBPC
Return

##########################################################################################################
Subprog AM_ALLREP(VALEUR)
Variable Integer VALEUR

Local Integer ILIGNE

  If VALEUR = 2 Then
    Raz [M:PBL1]ALLREP
    Raz [M:PBL1]NBREP
    Raz [M:PBL1]REPNUM
    Raz [M:PBL1]SRECOU
    Effzo [M:PBL1]10
    [M:PBL1]NBREP = 0
    #Remplissage du tableau avec les collaborateurs Help-Desk de la famille parent.
    ILIGNE = 0
    Filter [PBR] Where [F:PBR]GRPPBLNUM = [M:PBL0]PAEGRPNUM and [F:PBR]STTFLG = 0
    For [PBR]
      If ILIGNE < dim([M:PBL1]REPNUM) Then
        [M:PBL1]REPNUM(ILIGNE) = [F:PBR]REPNUM
        ILIGNE = ILIGNE + 1
      Endif
    Next
    [M:PBL1]NBREP = ILIGNE
    Filter [PBR]
  Endif
  Affzo [M:PBL1]1-99
End

##########################################################################################################
Subprog AM_ALLQUE(VALEUR)
Variable Integer VALEUR

Local Integer ILIGNE

  If VALEUR = 2 Then
    Raz [M:PBL2]ALLQUE
    Raz [M:PBL2]NBQUE
    Raz [M:PBL2]QUENUM
    Raz [M:PBL2]SRECOU
    Effzo [M:PBL2]10
    [M:PBL2]NBQUE = 0
    ILIGNE = 0
    #Remplissage du tableau avec les queues de la famille parent.
    Filter [PBQ] Where [F:PBQ]GRPPBLNUM = [M:PBL0]PAEGRPNUM and [F:PBQ]STTFLG = 0
    For [PBQ]
      If ILIGNE < dim([M:PBL2]QUENUM) Then
        [M:PBL2]QUENUM(ILIGNE) = [F:PBQ]QUENUM
        ILIGNE = ILIGNE + 1
      Endif
    Next
    [M:PBL2]NBQUE = ILIGNE
    Filter [PBQ]
  Endif
  Affzo [M:PBL2]1-99
End

##########################################################################################################
Subprog AM_PAEGRPNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    Grizo [M:PBL1]ALLREP
    Grizo [M:PBL2]ALLQUE
    Actzo [M:PBL2]PBLBPC
    [M:PBL2]PBLBPC = ""
  Else
    Actzo [M:PBL1]ALLREP
    Actzo [M:PBL2]ALLQUE
    Grizo [M:PBL2]PBLBPC
    Read [PBL]PBL0=VALEUR
    If fstat Then
      [M:PBL2]PBLBPC = ""
    Else
      [M:PBL2]PBLBPC = [F:PBL]PBLBPC
    Endif
  Endif
  [M:PBL0]PAEGRPNUM = VALEUR
  If [M:PBL0]PAEGRPNUM = "" Then
    [M:PBL0]PBLCLA = ""
  Else
    Read [PBL]PBL0=[M:PBL0]PAEGRPNUM
    If fstat Then
      [M:PBL0]PBLCLA = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:PBL0]PBLCLA = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:PBL0]PBLCLA,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  Affzo [M:PBL0]1-99
  Affzo [M:PBL1]1-99
  Affzo [M:PBL2]1-99
End

##########################################################################################################
Subprog C_REPNUM(VALEUR)
Variable Char    VALEUR()

Local Integer I
Local Integer IONREP
Local Char SZMESS(250)
Local Char SZHDKREP
Local Integer IHDKREP
Local Integer NUMLIGNE

  NUMLIGNE = nolign-1
  SZHDKREP = ""
  IHDKREP = 0
  IONREP = 0
  SZMESS = ""
  #Vérifie si ce code collaborateur n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:PBL1]REPNUM)-1
    If I <> nolign-1 Then
      If [M:PBL1]REPNUM(I) = VALEUR and [M:PBL1]REPNUM(I) <> "" Then
        VALEUR = ""
        mkstat = 2
        GMESSAGE = mess(432,196,1) #Ce collaborateur a déjà été saisie.
        GERR = 2
        Break
      Endif
    Endif
  Next
  If GERR Then
    End
  Endif
  #Vérifie si l'utilisateur saisi est un collaborateur Help-Desk
  Read [AUS]CODUSR=VALEUR
  If fstat Then
    GMESSAGE = mess(83,123,1) #Valeur incorrecte
    GERR = 2
    mkstat = 2
  Else
    Call PARAMUTIL("AUSHDKA", SZHDKREP, VALEUR, "") From SUBAUS
    If SZHDKREP = "" Then
      IHDKREP = 1
    Else
      IHDKREP = val(SZHDKREP)
    Endif
    If IHDKREP <> 2 Then
      #XXX n'est pas un collaborateur du service Support client. Confirmez-vous la saisie ?
      SZMESS = [F:AUS]NOMUSR - mess(619,196,1)
      Call OUINON(SZMESS, IONREP) From GESECRAN
      If IONREP <> 2 Then
        VALEUR = ""
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog C_QUENUM(VALEUR)
Variable Char    VALEUR()

Local Integer I

  #Vérifie si cette queue n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:PBL2]QUENUM)-1
    If I <> nolign-1 Then
      If [M:PBL2]QUENUM(I) = VALEUR and [M:PBL2]QUENUM(I) <> "" Then
        VALEUR = ""
        mkstat = 2
        GMESSAGE = mess(433,196,1) #Cette queue a déjà été saisie.
        GERR = 2
      Endif
    Endif
  Next
End

##########################################################################################################
Subprog C_PAEGRPNUM(VALEUR)
Variable Char    VALEUR()

  Gosub CTLSHORTCUT From SUBPBLB
  If VALEUR <> "" Then
    If [M:PBL0]NUM <> "" Then
      If VALEUR = [M:PBL0]NUM Then
        VALEUR = ""
        GMESSAGE = mess(442,196,1) #Impossible d'associer une famille de compétence à elle-même. Saisie refusée.
        GERR = 2
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog IB_PAEGRPNUM

  #Sélection arborescente
  GBOUT1 = mess(639,196,1)
End

##########################################################################################################
Subprog C_SUT(VALEUR)
Variable Char    VALEUR()

Local Char SZDES(GLONDCO)   # FGR 23/09/2009 : X3SUIVI58024

  If VALEUR <> "" Then
    Filter [PBL] Where [F:PBL]SUT = VALEUR and [F:PBL]NUM <> [M:PBL0]NUM
    For [PBL]PBL2
      #Ce raccourci est déjà utilisé par la famille de compétence : XXXXX.
      # FGR 23/09/2009 : X3SUIVI58024
      #GMESSAGE = mess(402,182,1) - [F:PBL]GRPPBLDES - "(" + [F:PBL]NUM + ")"
      Call LECTEXTRA(SZDES,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
      GMESSAGE = mess(402,182,1) - SZDES - "(" + [F:PBL]NUM + ")"
      GERR = 1
      mkstat = 2
      Break
    Next
    Filter [PBL]
  Endif
End
