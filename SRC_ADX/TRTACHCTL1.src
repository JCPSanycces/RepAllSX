#<AdxTL>@(#)7.0.0.0 $Revision$
# TRTACHCTL1              Traitements de contrôle               Module ACHAT #
# Contrôle sur champs - Après modif sur champs -                             #
# -------------------------------------------------------------------------- #
# Actions sur champs :                                                       #
#   - C_ITMREF   : Contrôle référence article                                #
#   - C_FCY      : Contrôle paramétrage règle de signature                   #
#   - C_RCPFCY   : Contrôle site de réception et même société juridique      #
#   - C_INVFCY   : Contrôle site financier et même société juridique         #
#   - C_PRHFCY   : Contrôle article-site réception en DA et cde ouverte      #
#   - PCOUOM     : Contrôle d'une unité                                      #
#   - PCOVAT     : Contrôle correspondance régime taxe d'un code taxe        #
#                                                                            #
# Sous-programmes divers :                                                   #
#   - CTLITMBUY  : Contrôle qu'un article est géré par l'acheteur            #
#   - CTLITMFCY  : Contrôle existence d'un article-site                      #
#   - CTLPER     : Contrôle période comptable                                #
#   - CTRL_INTERSITE : S/P de contrôle et chargement zones pour inter-sites  #
#                                                                            #
# Actions sur champs :                                                       #
#   - AM_BPSNUM  : Après modif fournisseur                                   #
#   - AM_ITMREF  : Après modif référence article                             #
#   - PAMPRHFCY  : Après modif site de réception en DA et commande           #
#   - PAMQTYSCO  : Après modif quantité article sous-traitance               #
# -------------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                     #
#   - TRTPRHFCY  : Contrôle existence article-site et création si nécessaire #
#                                                                            #
# ACTIONS modélisation WEB (Affichages divers GACTION)                       #
#   - CTLPCOITMR : Contrôle référence article achat                          #
#   - CTLPRHFCY  : Contrôle du site de réception                             #
##############################################################################


$ACTION
Case ACTION
 When "INIT"
  #-----------------------------------------------#
  # Initialisations avant exécution du traitement #
  #-----------------------------------------------#
  Case GACTION
   When "TRTPRHFCY"   : Gosub INIT_TRTPRHFCY
  Endcase
 When "EXEC"
  #-------------------------#
  # Exécution du traitement #
  #-------------------------#
  Case GACTION
   When "TRTPRHFCY"   : Gosub EXEC_TRTPRHFCY
  Endcase
 When "TERMINE"
  #-----------------------------------#
  # Fin après exécution du traitement #
  #-----------------------------------#
  Case GACTION
   When "TRTPRHFCY"   : Gosub TERM_TRTPRHFCY
  Endcase
 When "TRT_DIV"
  Case TRAIT
   When "CTLPCOITMR"  : Gosub CTL_ITMREF
   When "CTLPRHFCY"   : Gosub CTL_PRHFCY
  Endcase
 When Default
Endcase
Return


##########################################################################
# TRTPRHFCY  : Contrôle création article-site en après modif.            #
# ---------------------------------------------------------------------- #
# Paramètres de l'action TRTPRHFCY :                        MBT 05/12/00 #
#   VALEUR   = zone courante                                             #
#   PARAM(1) = ITMREF : Référence article                                #
# Nota : Appelé en après modif et suivi d'une action suite GOBJETC0A     #
##########################################################################
#------------------------------------------#
# Récupération des paramètres pour le Call #
#------------------------------------------#
$INIT_TRTPRHFCY
Local Char REFART(GLONITM) : REFART=PARAM(1)
Raz GBIDI1 : # GBIDI1=0 Empêche l'action suite GOBJETC0A de s'exécuter
#----- Lecture article si nécessaire -----#
If [F:ITM]ITMREF<>REFART
  Read [ITM] ITM0=REFART : If fstat Raz [F:ITM] : Endif
Endif
#----- Lecture article-site si nécessaire -----#
If [F:ITF]ITMREF<>REFART | [F:ITF]STOFCY<>VALEUR
  Read [ITF] ITF0=REFART;VALEUR
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
#--------------------------------------------------#
# Le contrôle de l'article-site est fait :         #
#    - En action de contrôle si IMPORT             #
#    - En action d'après modif dans les autres cas #
#      à cause du choix pour la création           #
#--------------------------------------------------#
#----- Article non géré en stock ou article-site existe ou import c'est fini ! -----#
If [F:ITF]STOMGTCOD<2 | GIMPORT | [F:ITF]ITMREF<>""
  FIN=1 : Return
Endif
Return
#---------------------------------------#
# Choix pour création de l'article-site #
#---------------------------------------#
$EXEC_TRTPRHFCY
GBIDI1=1 : # Empêche l'action suite de s'exécuter et restaure l'ancienne valeur
GMESSAGE=mess(244,199,1) : GERR=3 : # Call AVERTIR
Return
#--------------------------------------------------#
# Après exécution du traitement màj des paramètres #
#--------------------------------------------------#
$TERM_TRTPRHFCY
GBIDI1=2 : # Active l'action suite GOBJETC0A
Return


##############################################
# CTL_PRHFCY : Contrôle du site de réception #
##############################################
$CTL_PRHFCY
Local Char WITMREF(GLONITM) : WITMREF =  PARAM(1)
#------------------------------------------------------------------#
# VéRIFICATION ARTICLE - SITE : BLOQUANT SI N EXISTE PAS           #
# POUR LES ARTICLES GéRES EN STOCK                                 #
# EN COMMANDE OBLIGATOIRE POUR MISE A JOUR DES MOUVEMENTS ARTICLES #
# UTILISé EN DA ET CONTRAT  / ACTION PCOPRHFCY                     #
#------------------------------------------------------------------#
If [F:ITM]ITMREF<>WITMREF
  Read [ITM] ITM0=WITMREF : If fstat  Raz [F:ITM] : Endif
Endif
#----- On vient de faire un contobj dans le AUT, on a la classe F en ligne -----#
If VALEUR=""
  GERR=1 : GMESSAGE=mess(10,123,1) : mkstat=2 : Return : Endif
If [F:ITM]STOMGTCOD<>1 & [F:FCY]WRHFLG<>2
  GERR=1 : GMESSAGE=mess(58,199,1) : mkstat=2 : Return : Endif
#----- Sur même société juridique GSOCIETE -----#
If [F:FCY]LEGCPY<>GSOCIETE
  GERR=1 : GMESSAGE=VALEUR-mess(2,194,1) : mkstat=2 : Return
Endif
#----------------------------------------#
# controle uniquement lorsque on importe #
# sinon controle est fait en apres modif #
#----------------------------------------#
If [F:ITM]STOMGTCOD<>1 & GIMPORT
  Read [ITF] ITF0=WITMREF;VALEUR
  If fstat
    Raz [F:ITF] : GERR=1 : GMESSAGE=mess(25,192,1)-VALEUR : mkstat=2 : Return
  Endif
Endif
#-----------------------------------------------#
# Contrôle de l'approvisionneur (PLANNER) si DA #
#-----------------------------------------------#
If clalev([M:PSH0])>0
  If [F:ITF]ITMREF<>WITMREF | [F:ITF]STOFCY<>VALEUR
    Read [ITF] ITF0=WITMREF;VALEUR : If fstat Raz [F:ITF] : Endif
  Endif
  If [F:ITF]ITMREF<>""
    If GPLNFLT=2 & ([F:ITF]PLANNER<>[M:PSH0]REQUSR & [F:ITF]PLANNER<>"")
      GERR = 1 : GMESSAGE=mess(217,194,1) : mkstat=2 : Return
    Endif
    If GPLNFLT=3 & [F:ITF]PLANNER<>[M:PSH0]REQUSR
      GERR = 1 : GMESSAGE=mess(217,194,1) : mkstat=2 : Return
    Endif
  Endif
Endif
Return


#######################################################
# CTL_ITMREF : Contrôle sur référence article         #
# --------------------------------------------------- #
# L'article ne doit pas être un article               #
# sous-traitance ou sous-traité                       #
# Ce contrôle est appelé par l'action CTLPCOITMR      #
# utilisée par les écrans :                           #
#   - PSH1 demandes d'achat                           #
#   - PTH1 réceptions (on doit passer par le picking) #
#######################################################
$CTL_ITMREF
#----- Test article de sous-traitance ou sous-traité -----#
If ([F:ITM]SCSFLG=2 | [F:ITM]SCPFLG=2) & [F:ITM]PURFLG<>2
  GMESSAGE=[F:ITM]ITMREF-":"-mess(70,197,1) : mkstat=2 : Return
Endif
Return


################################################
# C_ITMREF : Contrôle sur référence article    #
# -------------------------------------------- #
# L'article doit être acheté et ne pas être    #
# un article sous-traitance ou sous-traité     #
# Ce contrôle est appelé pour les :            #
#   - demandes d'achat                         #
#   - contrats (commandes ouvertes)            #
################################################
# Issue 112754 - 2016-09-23 by SR : les articles de type service sont autorisés en DA
Subprog C_ITMREF(LORI,VALEUR)
Value    Char    LORI
Variable Char    VALEUR()
#----- Test article non acheté -----#
Call CONTROLE("ITM","B!",VALEUR,"",mkstat) From CONTOBJ
If mkstat  End : Endif
#----- Test article de sous-traitance -----#
# Issue 112754 - 2016-09-23 by SR
If [F:ITM]SCSFLG=2 & !find(LORI,"PSD","POC")
  GMESSAGE=[F:ITM]ITMREF-":"-mess(164,199,1) : mkstat=2 : End
Endif
#----- Test article sous-traité -----#
If [F:ITM]SCPFLG=2 & [F:ITM]PURFLG<>2
  GMESSAGE=[F:ITM]ITMREF-":"-mess(70,197,1)  : mkstat=2 : End
Endif
#----- Test article acheté -----#
If [F:ITM]PURFLG<>2
  GMESSAGE=[F:ITM]ITMREF-":"-mess(70,197,1)  : mkstat=2 : End
Endif
End


#################################################
# C_ITMREF2 : Contrôle sur référence article    #
# --------------------------------------------- #
# L'article doit être acheté                    #
# Ce contrôle est appelé par l'action PCOITMREF #
# utilisée par les écran de la GPAO :           #
#   - PBENCHW3                                  #
#   - PBENCHW4                                  #
#################################################
Subprog C_ITMREF2(VALEUR)
Variable Char    VALEUR()
#----- Test article non acheté -----#
Call CONTROLE("ITM","B!",VALEUR,"",mkstat) From CONTOBJ
If mkstat  End : Endif
End


######################################################################
# C_RCPFCY : Contrôle site de réception dans la gestion des contrats #
######################################################################
Subprog C_RCPFCY(VALEUR)
Variable Char    VALEUR()
Local Char BETRCPFCY(GLONFCY)
Local Char BPCNUM   (GLONBPC)
#----------------------------------------------------------------#
# Contrôle site de réception sur même société juridique GSOCIETE #
# Le contrôle site de stockage est fait par le type de données   #
#----------------------------------------------------------------#
If [F:FCY]LEGCPY<>GSOCIETE
  GMESSAGE=mess(2,194,1) : mkstat=2 : End
Endif
#--------------------------------------------------------------------#
# Contrôle spécifique pour contrat inter-site :                      #
# Le site de réception doit être également défini comme tiers client #
# Le site de réception doit être différent du site d'expédition      #
#--------------------------------------------------------------------#
If dim([M:POC0]SALFCY)>0 & [M:POC0]SALFCY<>""
  [L]BETRCPFCY=VALEUR
  [L]BPCNUM=[M:POC0]BPCORD
  If [L]BETRCPFCY=[M:POC1]STOFCY
    GMESSAGE=mess(259,194,1) : mkstat=2 : End
  Endif
  Gosub CTRL_BPRADD From TRTACHCTL1
  If [L]BETRCPFCY="" : GMESSAGE=mess(267,194,1) : mkstat=2 : End : Endif
Endif
End


##############################################
# Action PCOINVFCY : Contrôle site financier #
##############################################
Subprog C_INVFCY(VALEUR)
Variable Char    VALEUR()
#--------------------------------------------------------#
# Uniquement sur société juridique GSOCIETE              #
# Contrôle sur site financier fait par le type de donnée #
# Contrôle sur site d'achat   fait par le type de donnée #
#--------------------------------------------------------#
If [F:FCY]LEGCPY<>GSOCIETE
  GMESSAGE=mess(2,194,1) : mkstat=2 : End
Endif
End


######################################################################
# CONTROLE SITE RECEPTION EN DA ET COMMANDES OUVERTES                #
#                                                      CG JANVIER 98 #
######################################################################
Subprog C_PRHFCY(VALEUR,WITMREF)
Variable Char    VALEUR()
Value Char WITMREF
#------------------------------------------------------------------#
# VéRIFICATION ARTICLE - SITE : BLOQUANT SI N EXISTE PAS           #
# POUR LES ARTICLES GéRES EN STOCK                                 #
# EN COMMANDE OBLIGATOIRE POUR MISE A JOUR DES MOUVEMENTS ARTICLES #
# UTILISé EN DA ET CONTRAT  / ACTION PCOPRHFCY                     #
#------------------------------------------------------------------#
If [F:ITM]ITMREF<>WITMREF
  Read [ITM] ITM0=WITMREF
  If fstat  Raz [F:ITM] : Endif
Endif
#-------------------------------------------------------------#
# CONTROLE A FAIRE A LA MAIN                                  #
# DANS LE CAS DES ARTICLES GéRES EN STOCK -- FILTRE SUR DéPOT #
# SINON PAS DE FILTRE   à GéRER                               #
#-------------------------------------------------------------#
If [F:ITM]STOMGTCOD=1
  Call CONTROLE("FCY","",VALEUR,"",mkstat)  From CONTOBJ
Else
  Call CONTROLE("FCY","D",VALEUR,"",mkstat) From CONTOBJ
Endif
If mkstat  End : Endif
#----------------------------------------#
# SUR MEME SOCIETE JURIDIQUE  GSOCIETE   #
#----------------------------------------#
If [F:FCY]LEGCPY <> GSOCIETE
  GMESSAGE=VALEUR-mess(2,194,1)-"("+[F:FCY]LEGCPY-"<>"-GSOCIETE+")" : mkstat=2 : End
Endif
#----------------------------------------#
# controle uniquement lorsque on importe #
# sinon controle est fait en apres modif #
#----------------------------------------#
If [F:ITM]STOMGTCOD<>1 & GIMPORT
  Read [ITF] ITF0=WITMREF;VALEUR
  If fstat
    Raz [F:ITF] : GMESSAGE=mess(25,192,1)-VALEUR : mkstat=2 : End
  Endif
Endif
#-------------------------------#
# ON EST EN GESTION DES CONTRAT #
# CAS AJOUT LIGNE SUR CONTRAT   #
# SI LIGNE ARTICLE - SITE EXIST #
# AJOUT DE LIGNE IMPOSSIBLE     #
# ATTENTION CLE SANS DUPKEY     #
#-------------------------------#
If GFONCTION1="GESPOC" & [M:POC2]LINCREFLG=0
  Look [POC]POC1=[M:POC0]POHNUM;WITMREF;VALEUR
  If !fstat GMESSAGE=mess(90,194,1) : mkstat=2 : End : Endif
Endif
#-----------------------------------------------#
# Contrôle de l'approvisionneur (PLANNER) si DA #
#-----------------------------------------------#
If clalev([M:PSH0])>0
  If [F:ITF]ITMREF<>WITMREF | [F:ITF]STOFCY<>VALEUR
    Read [ITF] ITF0=WITMREF;VALEUR : If fstat Raz [F:ITF] : Endif
  Endif
  If [F:ITF]ITMREF<>""
    If GPLNFLT=2 & ([F:ITF]PLANNER<>[M:PSH0]REQUSR & [F:ITF]PLANNER<>"")
      GMESSAGE=mess(217,194,1) : mkstat=2 : End
    Endif
    If GPLNFLT=3 & [F:ITF]PLANNER<>[M:PSH0]REQUSR
      GMESSAGE=mess(217,194,1) : mkstat=2 : End
    Endif
  Endif
Endif
End


#########################################################################
# PCOUOM : S/P DE CONTRôLE D'UNE UNITé PARMI CELLES SE     MBT 20/03/98 #
#           TROUVANT DANS L'ARTICLE OU L'ARTICLE-FOURNISSEUR            #
#-----------------------------------------------------------------------#
# Subprog PCOUOM (UNITE,FOURN,REFART,INDFIC,INDUNI)                     #
#   UNITE  : UNITé à CONTROLER (zc)                                     #
#   FOURN  : NUMéRO DU FOURNISSEUR DONT LES UNITéS SONT à CONTRôLER     #
#   REFART : RéFéRENCE DE L'ARTICLE DONT LES UNITéS SONT à CONTRôLER    #
#   INDFIC : INDICATEUR FICHIERS à TRAITER                              #
#            1 = ARTICLE (ITMMASTER)                                    #
#            2 = ARTICLE-FOURNISSEUR (ITMBPS)                           #
#            3 = ARTICLE + ARTICLE-FOURNISSEUR (ITMMASTER+ITMBPS)       #
#   INDUNI : INDICATEUR UNITéS à TRAITER                                #
#            1 = UNITé D'ACHAT (UA)                                     #
#            2 = UNITé DE CONDITIONNEMENT (UC)                          #
#            3 = UNITé DE STOCK (US)                                    #
#            4 = UNITé D'ACHAT + UNITé DE CONDITIONNEMENT (UA+UC)       #
#            5 = LES TROIS UNITéS (UA+UC+US)                            #
#                                                                       #
# ATTENTION : CE S/P EST APPELé PAR UNE ACTION "CONTRôLE"               #
#             SI ERREUR mkstat=2                                        #
#########################################################################
Subprog PCOUOM (UNITE,FOURN,REFART,INDFIC,INDUNI)
Value    Char    UNITE
Value    Char    FOURN
Value    Char    REFART
Value    Integer INDFIC
Value    Integer INDUNI
#----- Variables locales -----#
If clalev([F:ITM])=0 Local File ITMMASTER [ITM] : Endif
Local    Char    TABCODE(GLONUOM)(dim([F:ITM]PCU)+4)
Local    Integer I, J
#----- Si réf. article non renseignée contrôle si existe dans table des unités -----#
If REFART=""
   Call CONTROLE("TUN","",UNITE,"",mkstat) From CONTOBJ : End
Endif
#----- Contrôle validité des indicateurs -----#
If INDFIC=0 | INDFIC>3 End : Endif
If INDUNI=0 | INDUNI>5 End : Endif
#----- Ouverture et lecture des fichiers si nécessaire -----#
If INDFIC=1 | INDFIC=3
   If clalev([F:ITM])=0 Local File ITMMASTER [ITM] : Endif
   If [F:ITM]ITMREF<>REFART
      Read [ITM] ITM0=REFART
      If fstat Raz [F:ITM] : Endif
   Endif
Endif
If INDFIC=2 | INDFIC=3
   If clalev([F:ITP])=0 Local File ITMBPS    [ITP] : Endif
   If [F:ITP]ITMREF<>REFART | [F:ITP]BPSNUM<>FOURN
      Read [ITP] ITP0=REFART;FOURN
      If fstat Raz [F:ITP] : Endif
   Endif
Endif
#----- CONTRôLE DE L'UNITé -----#
If INDFIC=1 | INDFIC=3
  If (INDUNI=1 | INDUNI=4 | INDUNI=5) & [F:ITM]PUU<>""
                           TABCODE(I)=[F:ITM]PUU    : I+=1 : Endif
  If INDUNI=2 | INDUNI=4 | INDUNI=5
    For J=0 To dim([F:ITM]PCU)-1
      If [F:ITM]PCU(J)<>"" TABCODE(I)=[F:ITM]PCU(J) : I+=1 : Endif
    Next J
  Endif
  If (INDUNI=3 | INDUNI=5) & [F:ITM]STU<>""
                           TABCODE(I)=[F:ITM]STU    : I+=1 : Endif
Endif
If INDFIC=2 | INDFIC=3
   If (INDUNI=1 | INDUNI=4 | INDUNI=5) & [F:ITP]PUU<>""
                           TABCODE(I)=[F:ITP]PUU    : I+=1 : Endif
   If (INDUNI=2 | INDUNI=4 | INDUNI=5) & [F:ITP]PCU<>""
                           TABCODE(I)=[F:ITP]PCU    : I+=1 : Endif
Endif
If !find(UNITE,TABCODE)
  GMESSAGE=mess(397,198,1)-'"'+UNITE+'"'-mess(6,199,1)
  mkstat=2
Else
  Raz GMESSAGE, mkstat
Endif
End


#########################################################################
# PCOVAT : S/P de contrôle correspondance régime de taxe   MBT 15/10/98 #
#          d'un code taxe + contrôle législation                        #
#-----------------------------------------------------------------------#
# Subprog PCOVAT (CODTAX,REGIME)                                        #
#   CODTAX : Code taxe à contrôler (zc)                                 #
#   REGIME : Régime de taxe pour contrôle                               #
#                                                                       #
# ATTENTION : Ce S/P est appelé par une action "Contrôle"               #
#             Le contrôle dépend de la valeur du paramètre GPCTLVAT     #
#             GPCTLVAT = 1 : Pas de contrôle                            #
#                        2 : Contrôle non bloquant (Choix)              #
#                        3 : Contrôle bloquant (Si erreur mkstat=2)     #
#########################################################################
Subprog PCOVAT (CODTAX,REGIME)
Value    Char CODTAX
Value    Char REGIME
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
#-----
If CODTAX="" | GPCTLVAT=1  End : Endif
#-----
#If [F:TVT]VAT<>CODTAX :#--CPO 71937 le test est fait dans le sous-pro, sinon il faut tester aussi la leg
  # Issue 71937 - 2012-03-27 by SR : comment
  Call LEC_TVT_LEG(GCURLEG,CODTAX,WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
#  Read [TVT] TVT0=CODTAX : If fstat  Raz [F:TVT] : Endif
#Endif
#----- Pas de contrôle pour la migration Intégrale vers X3 -----#
If clalev([F:XEPA]) & clalev([F:XLPA])  End : Endif
#-----
Local Libelle WERR : Raz WERR
Local Char    WMSG(80)
#----- Contrôle et chargement code erreur -----#
If [F:TVT]VATVAC<>"" & [F:TVT]VATVAC<>REGIME
  WERR+=1
Endif
If [F:TVT]LEG<>"" & GCURLEG<>"" & [F:TVT]LEG<>GCURLEG
  WERR+=2
Endif
If [F:TVT]GRP<>""
  If !clalev([F:AGC])  Local File AGRPCPY [AGC] : Endif
  Look [AGC] AGC0=[F:TVT]GRP;GSOCIETE
  If fstat  WERR+=4 : Endif
Endif
#-----
If WERR=0  End : Endif
#----- Chargement libellé de l'erreur -----#
Case WERR
  When 1 : WMSG=mess(149,194,1)                     : # Régime de taxe incorrect !
  When 2 : WMSG=mess(379,194,1)                     : # Législation incorrecte !
  When 3 : WMSG=mess(149,194,1)+"\"+mess(379,194,1) : # Régime et Législation incorrects !
  When 4 : WMSG=mess(382,194,1)                     : # Groupe de sociétés incorrect !
  When 5 : WMSG=mess(149,194,1)+"\"+mess(382,194,1) : # Régime et groupe incorrects !
  When 6 : WMSG=mess(379,194,1)+"\"+mess(382,194,1) : # Législation et groupe incorrects !
  When 7 : WMSG=mess(149,194,1)+"\"+mess(379,194,1) : # Régime, législation et
           WMSG+="\"+mess(382,194,1)                : # groupe incorrects !
Endcase
#----- Si import, il faut préciser le code taxe avant le message d'erreur -----#
If GIMPORT  WMSG=mess(39,105,1)-CODTAX-":"-WMSG : Endif
#----- Avertissement ou blocage selon valeur du paramètre -----#
If GPCTLVAT=2
  Local Integer OK
  OK=2 : Call AVERTIR(WMSG,OK) From GESECRAN
  If OK=1  mkstat=2 : End : Endif
Else
  GMESSAGE=WMSG : GERR=1 : mkstat=2 : End
Endif
End


########################################################################
# CTLITMBUY : S/P DE CONTRôLE DU CODE ACHETEUR            MBT 01/12/97 #
#----------------------------------------------------------------------#
# Subprog CTLITMBUY (REFART,ACHETEUR,STAT)                             #
#   REFART   : RéFéRENCE DE L'ARTICLE à CONTRôLER                      #
#   ACHETEUR : CODE DE L'ACHETEUR à CONTRôLER                          #
#   STAT     : STATUT RETOUR (0=OK, 1=ARTICLE NON GéRé PAR L'ACHETEUR  #
#                                                                      #
# ATTENTION  : GSOCIETE DOIT êTRE LA SOCIéTé JURIDIQUE COURANTE        #
#              GBUYFLT  LE PARAMèTRE FILTRE ACHETEUR DOIT êTRE CHARGé  #
#              GFCY     DOIT êTRE LE SITE DE COMMANDE                  #
########################################################################
Subprog CTLITMBUY (REFART,ACHETEUR,STAT)
Value    Char     REFART
Value    Char     ACHETEUR
Variable Shortint STAT
STAT=0
#-----------------------------------#
# Test si filtre acheteur est à OUI #
#-----------------------------------#
If GBUYFLT<>2 End : Endif
#-------------------------------#
# Lecture article si nécessaire #
#-------------------------------#
If clalev([F:ITM])<=0 Local File ITMMASTER  [ITM] : Endif
If [F:ITM]ITMREF<>REFART
   Read [ITM] ITM0=REFART
   If fstat Raz [F:ITM] : Endif
Endif
#---------------------------------------------------------------#
# Article non géré en stock : Test code acheteur dans l'article #
#---------------------------------------------------------------#
If [F:ITM]STOMGTCOD<2
   If [F:ITM]BUY<>"" & [F:ITM]BUY<>ACHETEUR
      STAT=1 : GMESSAGE=mess(27,194,1) : Endif
   End
Endif
#----------------------------------------------------------------#
# Article géré en stock : Test code acheteur dans l'article-site #
#----------------------------------------------------------------#
If clalev([F:ITF])<=0 Local File ITMFACILIT [ITF] : Endif
If [F:ITF]ITMREF<>REFART | [F:ITF]STOFCY<>GFCY
   Read [ITF] ITF0=REFART;GFCY
   If fstat Raz [F:ITF] : Endif
Endif
If [F:ITF]BUY<>"" & [F:ITF]BUY<>ACHETEUR
   STAT=1 : GMESSAGE=mess(27,194,1)
Elsif [F:ITF]BUY = "" : # CG LE 10 MARS 1998
   #------------------------------------------------------#
   # SI LE CODE ACHETEUR DE ARTICLE-SITE DEMANDE = ""     #
   # ON REGARDE PAR RAPPORT AU CODE ACHETEUR DE L'ARTICLE #
   #------------------------------------------------------#
   If [F:ITM]BUY<>"" & [F:ITM]BUY<>ACHETEUR
         STAT=1 : GMESSAGE=mess(27,194,1)
   Endif
Endif
End


########################################################################
# CTLITMFCY : S/P CONTRôLE EXISTENCE D'UN ARTICLE-SITE    MBT 29/01/98 #
# Modifié par HN le 15/05/03                                           #
#----------------------------------------------------------------------#
# Subprog CTLITMFCY (REFART,RCPFCY,STAT)                               #
#   REFART  : Référence de l'article à contrôler                       #
#   RCPFCY  : Site de réception                                        #
#   STAT    : Statut retour (0=Ok, 1=Article-site inexistant)          #
#                                                                      #
# Attention : GSOCIETE doit être la société juridique courante         #
#             GRCPFCY  doit être le site de réception par défaut       #
########################################################################
Subprog CTLITMFCY (REFART,RCPFCY,STAT)
Value    Char     REFART
Variable Char     RCPFCY
Variable Shortint STAT
#----- Variables locales -----#
Local    Char     BETRCPFCY(GLONFCY)
Local    Char     FCYTROUV (GLONFCY)
Local    Char     BPCNUM   (GLONBPC)
#-----
STAT=0

#-------------------------------#
# Test si article géré en stock #
#-------------------------------#
If clalev([F:ITM])<=0 Local File ITMMASTER  [ITM] : Endif
If [F:ITM]ITMREF<>REFART
   Read [ITM] ITM0=REFART
   If fstat Raz [F:ITM] : Endif
Endif
If [F:ITM]STOMGTCOD<2 End : Endif

#-----------------------------#
# Test existence article-site #
#-----------------------------#
Look [ITF] ITF0=REFART;GRCPFCY
If !fstat  End : Endif
#----- Si non trouvé en inter-site et site de réception doit être unique -----#
If clalev([M:POH0]) & [M:POH0]BETFCY=2 & [M:POH0]SALFCY<>"" &
&  [M:POH2]NBLIG<>0 &  ([M:POH0]DME=3 | GLINBPD<>2) & !GIMPORT
  STAT=1 : GMESSAGE=mess(266,194,1)-"\"-mess(25,192,1)-GRCPFCY : End
Endif

#--------------------------------------------------------#
# Recherche d'un couple article-site sur la même société #
#--------------------------------------------------------#
If clalev([F:ITF])<=0 Local File ITMFACILIT [ITF] : Endif
If clalev([F:FCY])<=0 Local File FACILITY   [FCY] : Endif
Link [ITF] With [FCY]FCY0=[F:ITF]STOFCY As [ITY]
For [ITY] ITF0 Where [F:ITF]ITMREF=REFART
&                  & [F:FCY]LEGCPY=GSOCIETE
  #----- Si inter-site -----#
  If clalev([M:POH0]) & [M:POH0]SALFCY<>""
    [L]BETRCPFCY=[F:ITF]STOFCY
    [L]BPCNUM   =[M:POH0]BPCORD
    Gosub CTRL_BPRADD : # Vérification existence adresse de livraison
    If [L]BETRCPFCY<>"" [L]FCYTROUV=[F:ITF]STOFCY : Break : Endif
  #----- Autres cas -----#
  Else
    [L]FCYTROUV=[F:ITF]STOFCY : Break
  Endif
Next
#-----
If [L]FCYTROUV<>""
  #------------------------------------------------------------#
  # Point d'entrée CTLITMFCY pour chargement site de réception #
  #          dans le cas où le site par défaut ne convient pas #
  # ---------------------------------------------------------- #
  # Variable utilisable par le point d'entrée                  #
  #                                                            #
  # WFLAG   : Indicateur de chargement du site de réception    #
  #           0 = Pas de chargement (site vide)                #
  #           1 = Chargement du site de réception              #
  #------------------------------------------------------------#
  Local Libelle WFLAG : WFLAG=1
  GPOINT="CTLITMFCY" : Gosub ENTREE From EXEFNC
  If WFLAG=1
    RCPFCY=[L]FCYTROUV
  Else
    Raz RCPFCY
  Endif
Else
  STAT=1
  If clalev([M:POH0]) & [M:POH0]SALFCY<>""
    GMESSAGE=mess(270,194,1) : # Inter-sites : Aucun article-site trouvé !
  Else
   #GMESSAGE=mess(25,192,1)  : # Article inexistant sur le site !
    GMESSAGE=REFART-mess(248,197,1) : # Article-site introuvable !
  Endif
Endif
End


$CTRL_BPRADD
#------------------------------------------------------------------------#
# Vérication que le site de réception est lié à une adresse client livré #
# ---------------------------------------------------------------------- #
# [L]BETRCPFCY doit exister et contient le site                          #
# [L]BPCNUM    doit exister et contient le numéro le numéro client       #
#------------------------------------------------------------------------#
If clalev ([F:BPD])=0  Local File BPDLVCUST  [BPD] Endif
Filter [BPD] Where BPCNUM=[L]BPCNUM & RCPFCY=[L]BETRCPFCY & ENAFLG=2
Read [BPD] BPD1 First
Filter [BPD]
If fstat  Raz [L]BETRCPFCY : Endif
Return


########################################################################
# CTLPER : S/P Contrôle de la période comptable           MBT 26/02/04 #
#----------------------------------------------------------------------#
# Subprog CTLPER (SIT,DAT,EXE,PER)                                     #
#   SIT   : Site à contrôler                                           #
#   DAT   : Date à contrôler                                           #
#                                                                      #
# Nota : GMESSAGE et mkstat positionné si erreur                       #
########################################################################
Subprog CTLPER (SIT,DAT)
Value    Char    SIT
Value    Date    DAT
#----- Variables locales -----#
Local Decimal EXE
Local Decimal PER
#-----
If !clalev([F:PER])  Local File PERIOD   [PER] : Endif
Raz GMESSAGE, mkstat
#----- Lecture des périodes -----#
Call GETPER (SIT,GTYPGEN,DAT,EXE,PER) From CPTSUB
#----- Période incorrecte ? -----#
If EXE=0 | PER=0
  GMESSAGE=mess(10,116,1) : mkstat=1
#----- Période non ouverte ? -----#
Elsif [F:PER]PERSTA<2
  GMESSAGE=mess(35,101,1) : mkstat=1
#----- Période fermée ? -----#
Elsif [F:PER]PERSTA>2
  GMESSAGE=mess(36,101,1) : mkstat=1
Endif
#-----
If mkstat
  GMESSAGE=format$("DD2",[F:PER]PERSTR)-"-"-format$("DD2",[F:PER]PEREND)-":"-GMESSAGE
Endif
End


########################################################################
# AM_BPSNUM : Après modif fournisseur appelé par l'action PAMBPSNUM    #
# -------------------------------------------------------------------- #
# Contrôle fournisseur douteux                                         #
########################################################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""  End : Endif
Local    Integer WRETOUR
# Issue 122166 - 2017-03-22 by MUARN : lecture BPS, il peut être perdu
If [F:BPS]BPSNUM<>VALEUR
  Read [BPS] BPS0=VALEUR : If fstat  Raz [F:BPS] : Endif
Endif
#----- Contrôle fournisseur douteux -----#
If [F:BPS]DOUFLG=3
  GMESSAGE=mess(4,194,1) : GERR=1 : VALEUR="" : mkstat=2
Elsif [F:BPS]DOUFLG=2
  GMESSAGE=mess(4,194,1) : WRETOUR=2
  Call AVERTIR(GMESSAGE,WRETOUR) From GESECRAN
  If WRETOUR=1  VALEUR="" : mkstat=2 : Endif
  Raz GMESSAGE, GERR
Endif
End


############################################
# AM_ITMREF: APRES MODIF REFERENCE ARTICLE #
# Laissé pour la GPAO                      #
############################################
Subprog AM_ITMREF(VALEUR)
Variable Char   VALEUR()
Local Integer   WRETOUR
Local Integer   STAT
Local Decimal   YEA_COUT

#-----------------------------------------------------------------------#
# On doit vérifier que l'article n'a pas fait l'objet d'une cde ouverte #
#-----------------------------------------------------------------------#
Filter [POC] Where ITMREF=VALEUR & STRDAT<=date$ & ENDDAT>=date$
Look [POC]POC2 First
Filter [POC]
If fstat=0
   GMESSAGE=mess(1,194,1) : WRETOUR=2
   Call AVERTIR(GMESSAGE,WRETOUR) From GESECRAN
   If WRETOUR=1 VALEUR="" : mkstat=2 : Endif
Endif
If WRETOUR=1 End :  Endif

#-------------------------------------------#
# INITIALISATION DU PRIX NET                #
# RéCUPéRATION DU PRIX STANDARD ARTICLE     #
#-------------------------------------------#
If clalev([F:ITC])=0  Local File ITMCOST [ITC] : Endif

#---------------------------------------#
# EN CREATION SITE NON CHARGE           #
# donc attention en apres modif du site #
#---------------------------------------#
If [M]PRHFCY (nolign-1) = "" : End : Endif
If [M]NETPRI (nolign-1) <> 0 : End : Endif
Call GETPRI(VALEUR,"","",[M]PRHFCY(nolign-1),[M]PRQDAT,1,"","",1,GBIDD3,STAT) From STKVAL
If fstat = 0
  GBIDD3 = [F:ITC]VLTTOT
  #-------------------------------------------------#
  # LE COUT STANDARD EST EN DEVISE SITE STOCKAGE    #
  # DONC LA DEVISE EST GCUR (MEME SOCIETE JURIDIQUE)#
  # plus de diviseur prix le 16 oct 98  cg          #
  #-------------------------------------------------#
  If GCUR <> [M]CUR (nolign-1)
     Call CONVERT2(GCUR,[M]CUR (nolign-1),GCUR,[M]CHGTYP(nolign-1),datesyst,
&                  [F:ITC]VLTTOT,GBIDD3,STAT) From TRTDEV
  Endif
  #------ Conversion si nécessaire à cause de l'unité ------#
  If [F:ITM]PUU<>[F:ITM]STU
    #----- Appel du S/P pour chargement du coefficient avec précision maxi -----#
    Call PCAL_QTY([M]QTYPUU(nolign-1),[F:ITM]PUU,GBIDD1,[F:ITM]STU,
&                 [F:ITM]ITMREF,[M]BPSNUM(nolign-1),1,GBIDD2) From TRTACHQTE1
    If GBIDD2=0 GBIDD2=1 : Endif
    GBIDD3=GBIDD3*GBIDD2
  Endif
  [M]NETPRI (nolign-1) =  arr(GBIDD3,10^-GDECPRI)
  [M]GROPRI (nolign-1) = [M]NETPRI (nolign-1)                : # MBT 01/09/00
  #-------------------#                                      : # MBT 01/09/00
  # motif  prix brut  #                                      : # MBT 01/09/00
  #-------------------#                                      : # MBT 01/09/00
  If dim([M]PRIREN)>0 [M]PRIREN(nolign-1)=GUPDPRIPUR : Endif : # MBT 01/09/00
Endif
End


########################################################################
# PAMPRHFCY : S/P de vérification de l'existence de       MBT 01/03/99 #
#             l'article-site et possibilité de le créer                #
#             par tunnel en après modification du site de réception    #
#----------------------------------------------------------------------#
# Subprog PAMPRHFCY (VALEUR,OLDFCY,REFART)                             #
#   VALEUR : Zone courante (zc)                                        #
#   OLDFCY : Valeur du site avant modification (valeur classe [M])     #
#   REFART : Référence de l'article                                    #
#                                                                      #
# Attention : Ce S/P est appelé par une action "Après_Modif"           #
########################################################################
Subprog PAMPRHFCY(VALEUR,OLDFCY,REFART)
Variable Char     VALEUR()
Value    Char     OLDFCY
Value    Char     REFART
Local    Char     SITE(GLONFCY)
Local    Integer  OK
If [F:ITM]ITMREF<>REFART
   Read [ITM] ITM0=REFART : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>REFART | [F:ITF]STOFCY<>VALEUR
   Read [ITF] ITF0=REFART;VALEUR : If fstat Raz [F:ITF] : Endif
Endif
$CREATION_ITF
#--------------------------------------------------#
# Le contrôle de l'article-site est fait :         #
#    - En action de contrôle si IMPORT             #
#    - En action d'après modif dans les autres cas #
#      à cause du choix pour la création           #
#--------------------------------------------------#
If [F:ITM]STOMGTCOD>1 & !GIMPORT & [F:ITF]ITMREF=""
   SITE=VALEUR
   OK=1
   Call AVERTIR (mess(244,199,1),OK)  From GESECRAN
   #-----------------------------------------------#
   # Restauration de l'ancienne valeur pour éviter #
   # un deuxième message d'alerte après Shift-Tab  #
   #-----------------------------------------------#
   If OK=1 mkstat=2 : VALEUR=OLDFCY : End : Endif
   Call OBJET("ITF",SITE,REFART) From GOBJET
   Read [ITF] ITF0=REFART;VALEUR
   If fstat Raz [F:ITF] : Goto CREATION_ITF : Endif
Endif
End


########################################################################
# PAMQTYSCO : S/P de contrôle modification de la          MBT 29/05/98 #
#             quantité d'un article sous-traitance                     #
#----------------------------------------------------------------------#
# Subprog PAMQTYSCO (VALEUR,WABMSK,NOLIG,NOMZON)                       #
#   VALEUR : Zone courante (AZC)                                       #
#   WABMSK : Abréviation du masque écran contenant les lignes          #
#   NOLIG  : Indice de la ligne active (nolign-1)                      #
#   NOMZON : Nom du champ courant (remplace le zoncou)    MBT 07/12/00 #
#                                                                      #
# ATTENTION : Ce S/P est appelé par une action "Après_modif"           #
########################################################################
Subprog PAMQTYSCO (VALEUR,WABMSK,NOLIG,NOMZON)
Value  Decimal  VALEUR
Value  Char     WABMSK
Value  Integer  NOLIG
Value  Char     NOMZON
#----- Lecture ITMMASTER si nécessaire -----#
Local  Decimal  QTEUA, QTEUS, QTEMAX
Local  Char     WBPSNUM(GLONBPS), WITMREF(GLONITM), WPUU(GLONUOM), WSTU(GLONUOM)
WITMREF=evalue("[M:"+WABMSK+"]ITMREF(NOLIG)")
If [F:ITM]ITMREF<>WITMREF
   Read [ITM] ITM0=WITMREF
   If fstat Raz [F:ITM] : Endif
Endif
#-----------------------------------------------------------------#
# Si la ligne vient d'être créée :                                #
#    Pas de modification possible à cause du fichier de travail.  #
#    Dans ce cas il faut supprimer et recréer la ligne concernée. #
# Si la ligne a été créée antérieurement :                        #
#    Modification possible de la quantité mais avec une valeur    #
#    inférieure uniquement.                                       #
#-----------------------------------------------------------------#
If [F:ITM]SCSFLG=2
  End : # Contrôle court-circuité le 20/02/2001 suite à la demande de LLC
  If evalue("[M:"+WABMSK+"]CREFLG(NOLIG)")=0
    GMESSAGE=mess(122,194,1) : GERR=1 : mkstat=2 : End
  Endif
  If VALEUR<=evalue("[M:"+WABMSK+"]"+NOMZON+"(NOLIG)") End : Endif
  WSTU  =evalue("[M:"+WABMSK+"]STU(NOLIG)")
  QTEMAX=evalue("[M:"+WABMSK+"]RETQTYSTU(NOLIG)")
  If NOMZON="QTYUOM"
    If WABMSK="POH2" WBPSNUM=[M:POH0]BPSNUM        : Endif
    If WABMSK="POI1" WBPSNUM=[M:POI1]BPSNUM(NOLIG) : Endif
    WPUU=evalue("[M:"+WABMSK+"]PUU(NOLIG)")
    QTEUA=VALEUR*evalue("[M:"+WABMSK+"]UOMPUUCOE(NOLIG)")
    Call QTEARR(QTEUA,WPUU) From TRTDIV
    Call PCAL_QTY(QTEUA,WPUU,QTEUS,WSTU,WITMREF,WBPSNUM,1,GBIDD1) From TRTACHQTE1
  Else
    QTEUS=VALEUR
  Endif
  If QTEUS>QTEMAX
    GMESSAGE=mess(163,194,1)-format$("N:15F",QTEMAX)-WSTU : GERR=1 : mkstat=2 : End
  Endif
Endif
End


#########################################################################
# CTRL_INTERSITE : S/P de contrôle et chargement zones pour inter-sites #
#-----------------------------------------------------------------------#
# Subprog CTRL_INTERSITE                                  MBT 12/06/03  #
# --------------------------------------------------------------------- #
# Paramètres en entrée                                                  #
#   WPOHFCY : Site de commande                                          #
#   WBPSNUM : Fournisseur de la commande                                #
#   WTRAIT  : Code traitement 0-1=auto sans choix                       #
#                             2=interactif                              #
#                             3=interactif & blocage si fou inter-sites #
#   GRCPFCY : Site de réception si celui-ci est déjà connu !            #
# --------------------------------------------------------------------- #
# Paramètres en sortie                                                  #
#   WBETFCY : Indicateur inter-sites                                    #
#   WBETCPY : Indicateur inter-sociétés                                 #
#   WSALFCY : Site de vente                                             #
#   WSTOFCY : Site d'expédition                                         #
#   WBPCORD : Client commande                                           #
#   WINVFCY : Site de facturation                                       #
#   WBPCINV : Client  facture                                           #
#   WDME    : Livr. partielle (1=oui, 2=ligne complète, 3=cde complète) #
# Les globales suivantes sont chargées                                  #
#   GRCPFCY : Site de réception par défaut est chargé                   #
#   GLINBPD : Client livré à la ligne (1=non, 2=oui)                    #
#   GCPY    : Société de la commande de vente                           #
# Si anomalie GMESSAGE est chargé et mkstat positionné                  #
#########################################################################
Subprog CTRL_INTERSITE(WPOHFCY,WBPSNUM,WTRAIT,WBETFCY,WBETCPY,WSALFCY,WSTOFCY,WBPCORD,WINVFCY,WBPCINV,WDME)
Value    Char    WPOHFCY
Value    Char    WBPSNUM
Value    Integer WTRAIT
Variable Integer WBETFCY
Variable Integer WBETCPY
Variable Char    WSALFCY
Variable Char    WSTOFCY
Variable Char    WBPCORD
Variable Char    WINVFCY
Variable Char    WBPCINV
Variable Integer WDME
#-----
Local    Char    WCHAR(10)
Local    Char    WBPCNUM(GLONBPC)
Local    Integer WBPCDME, I
# 26113  : Inter-site : Price recalculation (LD:06/07/15)
Local    Integer WTRFPRI
Local    Char    WMSG(250)
Local    Integer WRET
# 26113  : Inter-site : Price recalculation (LD:06/07/15)

If !clalev([F:BPR2])  Local File BPARTNER  [BPR2] : Endif
Filter [BPR2] Where BPCFLG=2
Read [BPR2] BPR2(2)=2;WPOHFCY
If fstat  Raz [F:BPR2] : Endif
[G:BPR2]currind=1 : [G:BPR2]currlen=0 : # Réinitialisation clé par défaut
Filter [BPR2]
#----- Lecture du Business Partner fournisseur si nécessaire -----#
If [F:BPR]BPRNUM<>WBPSNUM
  Read [BPR] BPR0=WBPSNUM
  If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
#----- le fournisseur ne doit pas être associé au même site que la commande -----#
If WPOHFCY=[F:BPR]FCY
  GMESSAGE=WBPSNUM-WPOHFCY-mess(334,194,1) : mkstat=1 : End
Endif
#-----
If [F:BPR2]FCY="" | [F:BPR]FCY=""
  Raz WSALFCY, WSTOFCY, WBPCORD, WBPCINV,WDME
  WBETFCY=1
  WBETCPY=1
  Call DEFRCPFCY(WPOHFCY) From TRTACHDEF1
Else
  #----- Le fournisseur inter-sites n'est pas autorisé -----#
  If WTRAIT=3 & WBETFCY=1
    GMESSAGE=WBPSNUM-mess(276,194,1) : mkstat=1 : End
  Endif
  #----- Le site associé au fournisseur (site de vente) doit exister -----#
  Read [FCY] FCY0=[F:BPR]FCY
  If fstat
    Raz [F:FCY] : GMESSAGE=[F:BPR]FCY-mess(14,14,1) : mkstat=1 : End
  Endif
  #----- Le flux automatique est-il autorisé ? -----#
  If GFONC1<>"GESPOC"
    Call IS_FLUX (14,WPOHFCY,[F:BPR]FCY,WTRFPRI, GBIDI2) From FUNBCH : # 26113  : Inter-site : Price recalculation (LD:06/07/15)
  Else
    GBIDI2=1 : # Flux automatique obligatoire pour les contrats !
  Endif
  #----- Inter-sites avec correspondance dans les ventes -----#
  If GBIDI2
    #----- Le module vente doit être actif -----#
    If GMODU(5)<>2
      GMESSAGE=mess(182,194,1) : mkstat=1 : End
    Endif
    #----- Vérification que le tiers associé au site commande est client -----#
    If [F:BPR2]BPCFLG<>2
      GMESSAGE=WPOHFCY-mess(258,194,1) : mkstat=1 : End
    Endif
    #----- Vérification que le client est actif -----#
    Read [BPC] BPC0=[F:BPR2]BPRNUM : If fstat Raz [F:BPC] : Endif
    If [F:BPC]BPCSTA<>2
      GMESSAGE=[F:BPR2]BPRNUM-":"-mess(4,119,1) : mkstat=1 : End
    Endif
    [L]WBPCNUM=[F:BPC]BPCNUM
    [L]WBPCDME=[F:BPC]DME
    #----- Le client commande doit être autorisé pour la société du site de vente -----#
    Call CTLBPRCPY([L]WBPCNUM,[F:BPR]FCY) From CONTX3
    If mkstat  GMESSAGE+=" "+[F:FCY]LEGCPY : End : Endif
    #----- Vérification si le site associé au fournisseur est vente -----#
    If [F:FCY]SALFLG<>2     : # Ce n'est pas un site de vente !
      GMESSAGE=mess(256,194,1) : mkstat=1 : End
    Endif
    #-----
    WBETFCY=2
    GCPY=[F:FCY]LEGCPY
    If GCPY<>GSOCIETE  WBETCPY=2 Else  WBETCPY=1 : Endif
    WSALFCY=[F:BPR]FCY
    WBPCORD=[L]WBPCNUM
    WDME=[L]WBPCDME
    #----- Chargement site de réception et site d'expédition par défaut -----#
    Call DEFBETRCPFCY([L]WBPCNUM) From TRTACHDEF1
    If GRCPFCY=""
      #----- Aucun site de réception pour le client -----#
      GMESSAGE=mess(267,194,1)-[L]WBPCNUM : mkstat=1 : End
    Endif
    #----- Si inter-sites et site fournisseur = site de stockage différent du site cde -----#
    If WBETCPY=1 & [F:FCY]WRHFLG=2 & [F:FCY]FCY<>WPOHFCY
      GSTOFCY=[F:FCY]FCY : # le site fournisseur (vente) devient le site d'expédition
      WSTOFCY=[F:FCY]FCY
    Else
      #----- Vérification site d'expédition -----#
      If GSTOFCY<>""
        #----- Le site expédition doit appartenir à la même société que le site vente -----#
        If find(GSTOFCY,GSITE(1..GNBSITE)) & GSOCSITE(find(GSTOFCY,GSITE(1..GNBSITE)))=GCPY
          WSTOFCY=GSTOFCY
        Else
          Raz GSTOFCY
        Endif
      Endif
      If GSTOFCY="" & [F:FCY]WRHFLG=2 & ([F:FCY]FCY<>WPOHFCY | WBETCPY=1)
        #----- Si c'est possible le site de vente devient le site d'expédition -----#
        GSTOFCY=[F:FCY]FCY : WSTOFCY=[F:FCY]FCY
      Elsif GSTOFCY=""
        Raz WSTOFCY
      Endif
    Endif
    #----- Le site d'expédition doit être différent du site de réception -----#
    If GSTOFCY<>"" & GSTOFCY=GRCPFCY
      Raz GSTOFCY, WSTOFCY
    Endif
    #----- Chargement globale GLINBPD (Client livré à la ligne) -----#
    Call PARAM([F:BPR]FCY,"LINBPD",[L]WCHAR) From ADOVAL : GLINBPD=val([L]WCHAR)
    #----- Traitement client facture et site financier achats -----#
    #If WBETCPY=2
      Raz WINVFCY : # On efface le site financier
      If [F:BPC]BPCNUM<>WBPCORD
        Read [BPC] BPC0=WBPCORD : If fstat  Raz [F:BPC] : Endif
      Endif
      WBPCINV=[F:BPC]BPCINV
      #----- Contrôle automatique sans choix -----#
      If WTRAIT<2
        #----- Vérification que le client est actif -----#
        If [F:BPC]BPCNUM<>WBPCINV
          Read [BPC] BPC0=WBPCINV : If fstat  Raz [F:BPC] : Endif
          If [F:BPC]BPCSTA<>2
            GMESSAGE=WBPCINV-":"-mess(4,119,1) : mkstat=1 : End
          Endif
        Endif
        #----- Le client commande doit être autorisé pour la société du site vente -----#
        Call CTLBPRCPY(WBPCINV,WSALFCY) From CONTX3
        If mkstat  GMESSAGE+=" "+GCPY : End : Endif
      #----- Contrôle interactif avec choix possible -----#
      Else
        Call C_BPCINV(WBPCINV,WSALFCY) From TRTVENISOC
        If mkstat  End : Endif
      Endif
      #----- Recherche site financier associé au client facture -----#
      Read [BPR] BPR0=WBPCINV : If fstat  Raz [F:BPR] : Endif
      WINVFCY=[F:BPR]FCY
      If WINVFCY=""    GMESSAGE=mess(316,194,1)-"("+WBPCINV+")" : mkstat=1 : End : Endif
      Read [FCY] FCY0=WINVFCY
      If fstat
        GMESSAGE=mess(316,194,1)-"("+WBPCINV+"/"+WINVFCY+")"
        Raz [F:FCY], WINVFCY : mkstat=1 : End
      Endif
      If [F:FCY]LEGCPY<>GSOCIETE
        GMESSAGE=mess(298,194,1)-[F:FCY]LEGCPY-"<>"-GSOCIETE
        Raz WBPCINV : mkstat=1 : End
      Endif

      # 26113  : Inter-site : Price recalculation (LD:06/07/15)
      # Si transfert des prix="Oui" il faut vérifier la cohérence Structure tarif fournisseur et Structure tarif site de vente
      If WTRFPRI=2
          If GFONC1<>"GESPOC"
              WRET = func TRTVENISOC.CTLPLISTC(WBPSNUM,WSALFCY,WMSG)
              If WRET mkstat=1 : GMESSAGE=WMSG : End : Endif
          Endif
      Endif
      # 26113  : Inter-site : Price recalculation (LD:06/07/15)

    #Endif
  Else
    #----- Inter-sites sans correspondance dans les ventes -----#
    WBETFCY=2
    GCPY=[F:FCY]LEGCPY
    If GCPY<>GSOCIETE  WBETCPY=2 Else  WBETCPY=1 : Endif
    Raz WSALFCY, WBPCINV, WDME, WBPCORD
    #----- Chargement du client commande -----#
    If GMODU(5)=2 & [F:BPR2]BPCFLG=2
      Read [BPC] BPC0=[F:BPR2]BPRNUM : If fstat Raz [F:BPC] : Endif
      If [F:BPC]BPCSTA=2
        Call CTLBPRCPY([F:BPC]BPCNUM,[F:BPR]FCY) From CONTX3
        If !mkstat  WBPCORD=[F:BPC]BPCNUM  Else  Raz mkstat, WBPCORD : Endif
      Endif
    Endif
    #----- Chargement site de réception et site d'expédition par défaut -----#
    If WBPCORD<>""
      Call DEFBETRCPFCY(WBPCORD) From TRTACHDEF1
    Else
      Raz GSTOFCY
    Endif
    #----- Chargement site de réception par défaut si non chargé -----#
    If GRCPFCY=""  Call DEFRCPFCY(WPOHFCY) From TRTACHDEF1 : Endif
    #----- Si inter-sites et site fournisseur = site de stockage différent du site cde -----#
    If WBETCPY=1 & [F:FCY]WRHFLG=2 & [F:FCY]FCY<>WPOHFCY
      GSTOFCY=[F:FCY]FCY : # le site fournisseur (vente) devient le site d'expédition
    Else
      #----- Vérification site d'expédition -----#
      If GSTOFCY<>""
        #----- Le site expédition doit appartenir à la même société que le site vente -----#
        If find(GSTOFCY,GSITE(1..GNBSITE)) & GSOCSITE(find(GSTOFCY,GSITE(1..GNBSITE)))=GCPY
          WSTOFCY=GSTOFCY
        Else
          Raz GSTOFCY
        Endif
      Endif
      If GSTOFCY="" & [F:FCY]WRHFLG=2 & ([F:FCY]FCY<>WPOHFCY | WBETCPY=1)
        #----- Si c'est possible le site de vente devient le site d'expédition -----#
        GSTOFCY=[F:FCY]FCY : WSTOFCY=[F:FCY]FCY
      Elsif GSTOFCY=""
        Raz WSTOFCY
      Endif
    Endif
    #----- Le site d'expédition doit être différent du site de réception -----#
    If GSTOFCY<>"" & GSTOFCY=GRCPFCY
      Raz GSTOFCY, WSTOFCY
    Endif
    #-----
  Endif
Endif
End

# Issue X3-55891 - 2018-08-07 by MUARN : Composant de contrôle de DOUFLG
########################################################################
# CONTROLE DU FLAG DOUTEUX                           MUARN 07/08/2018  #
#     - WTYP       : Type de contrôle                                  #
#                    1 Complet : DOUFLG et référencement               #
#                    2 Partiel : DOUFLG uniquement (pour Intersite)    #
#     - WITMREF    : article                                           #
#     - WBPSNUM    : fournisseur                                       #
#     - WFCY       : site                                              #
#     - WITMBPS    : fournisseur par défaut trouvé                     #
#                    0 non trouvé                                      #
#                    1 dans ITMBPS                                     #
#                    2 dans ITMBPSFCY                                  #
#     - WRETOUR    : code retour                                       #
#                    0 OK                                              #
#                    1 Fournisseur bloqué                              #
#                    2 Référence non trouvée au niveau Art/Fou         #
#                    3 Référence non trouvée au niveau Art/Fou/site    #
########################################################################
Subprog CTRL_DOUFLG(WTYP,WITMREF,WBPSNUM,WFCY,WITMBPS,WRETOUR)
Value    Integer WTYP
Value    Char    WITMREF
Value    Char    WBPSNUM
Value    Char    WFCY
Variable Integer WITMBPS
Variable Integer WRETOUR

If clalev([F:ITP])=0   Local File ITMBPS     [ITP]   : Endif
If clalev([F:ITPF])=0  Local File ITMBPSFCY  [ITPF]  : Endif

Call FIND_ITMBPSFCY_ITMBPS(WITMREF,WBPSNUM,WFCY,WITMBPS) From TRTACHDEF1
If WITMBPS > 0
  If WITMBPS =1
    # données la plus fine dans article/fournisseu
    #----- Test du code blocage -----#
    If [F:ITP]DOUFLG=3
      GMESSAGE=func AFNC.MES1(mess(591,194,1),WBPSNUM) : GERR=1 : mkstat=2 : WRETOUR = 1 : End
    Elsif [F:ITP]DOUFLG=2
      WRETOUR = 2
      #Call AVERTIR(mess(9,194,1),WRETOUR) From GESECRAN
      GMESSAGE=func AFNC.MES1(mess(591,194,1),WBPSNUM)
      Call AVERTIR(GMESSAGE,WRETOUR) From GESECRAN
      If WRETOUR = 2 : WRETOUR = 0 : Endif
      Raz GMESSAGE
    Endif
  Else
    # données la plus fine dans article/fournisseu/site
    #----- Test du code blocage -----#
    If [F:ITPF]DOUFLG=3
      GMESSAGE=func AFNC.MES2(mess(592,194,1),WBPSNUM, WFCY) : GERR=1 : mkstat=2 : WRETOUR = 1 : End
    Elsif [F:ITPF]DOUFLG=2
      WRETOUR = 2
      #Call AVERTIR(mess(9,194,1),WRETOUR) From GESECRAN
      GMESSAGE=func AFNC.MES2(mess(592,194,1),WBPSNUM, WFCY)
      Call AVERTIR(GMESSAGE,WRETOUR) From GESECRAN
      If WRETOUR = 2 : WRETOUR = 0 : Endif
      Raz GMESSAGE
    Endif
  Endif
#Else
#  # référencement inutile si fournisseur de type Divers
#  If [F:BPS]BPSNUM<>WBPSNUM
#    Read [BPS] BPS0=WBPSNUM : If fstat Raz [F:BPS] : Endif
#  Endif
#  #----- Si fournisseur <> Divers -----#
#  If [F:BPS]BPSTYP<>3
#    #----- Si article non générique -----#
#    If [F:ITM]GENFLG<>2
#      If GITMBPS=1
#        GMESSAGE=mess(8,194,1) : GERR=1 : mkstat=2 : WRETOUR = 1 : End
#      Elsif GITMBPS=2
#        Call AVERTIR(mess(8,194,1),WRETOUR) From GESECRAN
#      Endif
#    Endif
#  Endif
Endif

#contrôle du référencement article si contrôle total demandé et que tout est OK
If WTYP = 1 & WRETOUR<>1
  Call CTRL_ITMBPS(WITMREF,WBPSNUM,WFCY,WITMBPS,WRETOUR) From TRTACHCTL1
Endif

End


# Issue X3-55891 - 2018-08-17 by SR : Récupération de DOUFLG sans message
########################################################################
# Récupération valeur flag douteux sans message         SR 17/08/2018  #
# Douteux avec avertissement = Pas de blocage                          #
#     - WTYP       : Type de contrôle                                  #
#                    1 Complet : DOUFLG et référencement               #
#                    2 Partiel : DOUFLG uniquement (pour Intersite)    #
#     - WITMREF    : article                                           #
#     - WBPSNUM    : fournisseur                                       #
#     - WFCY       : site                                              #
# En sortie                                                            #
#     - WITMBPS    : fournisseur trouvé                                #
#                    0 non trouvé                                      #
#                    1 dans ITMBPS                                     #
#                    2 dans ITMBPSFCY                                  #
#     - WRETROUR   : Code retour                                       #
#                    0 OK                                              #
#                    1 Fournisseur bloqué                              #
#                    2 Référence non trouvée au niveau Art/Fou         #
#                    3 Référence non trouvée au niveau Art/Fou/site    #
########################################################################
Subprog BPSNUM_DOUBTFUL_LEVEL(WTYP,WITMREF,WBPSNUM,WFCY,WITMBPS,WRETOUR)
Value    Integer WTYP
Value    Char    WITMREF
Value    Char    WBPSNUM
Value    Char    WFCY
Variable Integer WITMBPS
Variable Integer WRETOUR

If clalev([F:ITP]) =0  Local File ITMBPS     [ITP]   : Endif
If clalev([F:ITPF])=0  Local File ITMBPSFCY  [ITPF]  : Endif
If clalev([F:BPS]) =0  Local File BPSUPPLIER [BPS]   : Endif
If clalev([F:ITM]) =0  Local File ITMMASTER  [ITM]   : Endif

If [F:ITM]ITMREF <> WITMREF
  Read [F:ITM]ITM0 = WITMREF
  If fstat  : Raz [F:ITM] : Endif
Endif

Raz WRETOUR, WITMBPS
If [F:ITPF]ITMREF<>WITMREF | [F:ITPF]BPSNUM<>WBPSNUM | [F:ITPF]STOFCY<>WFCY
  Read [ITPF] ITPF0=WITMREF;WBPSNUM;WFCY
  If fstat
    Raz [F:ITPF]
    If [F:ITP]ITMREF<>WITMREF | [F:ITP]BPSNUM<>WBPSNUM
      Read [ITP] ITP0=WITMREF;WBPSNUM
      If fstat : Raz [F:ITP] : End : Endif
    Endif
    WITMBPS = 1
    If [F:ITP]DOUFLG > 2 : WRETOUR = 1 : Endif
    End
  Endif
Endif
# On arrive ici si on était déjà sur le bon buffer ITPF ou si la lecture de ITPF est OK
WITMBPS = 2
If [F:ITPF]DOUFLG > 2 : WRETOUR = 1 : End : Endif
# On se positionne sur le bon buffer ITP
If [F:ITP]ITMREF<>WITMREF | [F:ITP]BPSNUM<>WBPSNUM
   Read [ITP] ITP0=WITMREF;WBPSNUM
   If fstat : Raz [F:ITP] : Endif
Endif

# Contrôle référencement obligatoire (avertissement = Pas de blocage)
If WTYP = 1 & WRETOUR <> 1
  # référencement inutile si fournisseur de type Divers
  If [F:BPS]BPSNUM<>WBPSNUM
    Read [BPS] BPS0=WBPSNUM : If fstat Raz [F:BPS] : Endif
  Endif
  #----- Si fournisseur <> Divers -----#
  If [F:BPS]BPSTYP<>3
    #----- Si article non générique -----#
    If [F:ITM]GENFLG<>2
      # Obligatoire niveau Art/Fou/Site et non trouvé
      If GITMBPSFCY = 1 & WITMBPS<2
         WRETOUR = 3 : End
      # Obligatoire niveau Art/Fou et non trouvé
      Elsif GITMBPS = 1  & WITMBPS<1
        WRETOUR = 2 : End
      Endif
    Endif
  Endif
Endif
End

# Issue X3-55891 - 2018-08-07 by MUARN : Composant de contrôle de référencement fournisseur
########################################################################
# CONTROLE DU FLAG DOUTEUX                           MUARN 07/08/2018  #
#     - WITMREF    : article                                           #
#     - WBPSNUM    : fournisseur                                       #
#     - WFCY       : site                                              #
#     - WITMBPS    : fournisseur par défaut trouvé                     #
#                    0 non trouvé                                      #
#                    1 dans ITMBPS                                     #
#                    2 dans ITMBPSFCY                                  #
#     - WRETOUR    : code retour                                       #
#                    0 OK                                              #
#                    2 non référencé dans ITMBPS                       #
#                    3 non référencé dans ITMBPSFCY                    #
########################################################################
Subprog CTRL_ITMBPS(WITMREF,WBPSNUM,WFCY,WITMBPS,WRETOUR)
Value    Char    WITMREF
Value    Char    WBPSNUM
Value    Char    WFCY
Value    Integer WITMBPS
Variable Integer WRETOUR

If clalev([F:BPS])=0   Local File BPSUPPLIER [BPS]   : Endif
If clalev([F:ITM])=0   Local File ITMMASTER  [ITM]   : Endif

# référencement inutile si fournisseur de type Divers
If [F:BPS]BPSNUM<>WBPSNUM
  Read [BPS] BPS0=WBPSNUM : If fstat Raz [F:BPS] : Endif
Endif
#----- Si fournisseur <> Divers -----#
If [F:BPS]BPSTYP<>3
  #----- Si article non générique -----#
  If [F:ITM]GENFLG<>2
    # référencement site obligatoire, non référencé dans ITMBPSFCY
    If GITMBPSFCY=1 & WITMBPS<2
      GMESSAGE=func AFNC.MES2(mess(594,194,1),WBPSNUM, WFCY) : GERR=1 : mkstat=2 : WRETOUR = 3 : End
    # référencement site facultatif, non référencé dans ITMBPSFCY et référencement fournisseur obligatoire, non référencé dans ITMBPS
    Elsif (GITMBPSFCY=2 & WITMBPS<2) & (GITMBPS=1 & WITMBPS<1)
      GMESSAGE=func AFNC.MES1(mess(593,194,1),WBPSNUM) : GERR=1 : mkstat=2 : WRETOUR = 2 : End
    # référencement site facultatif, non référencé dans ITMBPSFCY et référencement fournisseur obligatoire, référencé dans ITMBPS
    Elsif (GITMBPSFCY=2 & WITMBPS<2) & (GITMBPS=1 & WITMBPS>0)
      GMESSAGE=func AFNC.MES2(mess(594,194,1),WBPSNUM, WFCY)
      WRETOUR = 2
      Call AVERTIR(GMESSAGE,WRETOUR) From GESECRAN
      If WRETOUR = 1 : WRETOUR = 3 : Else  : WRETOUR = 0 : Endif
      Raz GMESSAGE
    # référencement site facultatif, non référencé dans ITMBPSFCY
    Elsif (GITMBPSFCY=2 & WITMBPS<2)
      GMESSAGE=func AFNC.MES2(mess(594,194,1),WBPSNUM, WFCY)
      WRETOUR = 2
      Call AVERTIR(GMESSAGE,WRETOUR) From GESECRAN
      If WRETOUR = 1 : WRETOUR = 3 : Else : WRETOUR = 0 : Endif
      Raz GMESSAGE
    # référencement fournisseur obligatoire, non référencé dans ITMBPS
    Elsif (GITMBPS=1 & WITMBPS<1)
      GMESSAGE=func AFNC.MES1(mess(593,194,1),WBPSNUM) : GERR=1 : mkstat=2 : WRETOUR = 2 : End
    # référencement fournisseur facultatif, non référencé dans ITMBPS
    Elsif (GITMBPS=2 & WITMBPS<1)
      GMESSAGE=func AFNC.MES1(mess(593,194,1),WBPSNUM)
      WRETOUR = 2
      Call AVERTIR(GMESSAGE,WRETOUR) From GESECRAN
      If WRETOUR = 1 : WRETOUR = 2 : Else : WRETOUR = 0 : Endif
      Raz GMESSAGE
    Endif
  Endif
Endif
End

