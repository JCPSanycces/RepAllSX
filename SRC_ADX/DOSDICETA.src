#<AdxTL>@(#)6.0.0.0 $Revision$
############################################################
## DOSDICETA Remplissage du dico des états
############################################################
$DICETA
# Remplissage du dico des états
Call ECR_TIME(mess(15,125,1)-mess(22,125,1)) From DOSSUB
# MAJ dictionnaire - Etats
Local File =GDOSREF+".AREPORT"  [ARP]
&         ,=GDOSREF+".AREPORTD" [ARD]
&         ,=GDOSREF+".AREPORTS" [ARO]
&         ,=GDOSREF+".AREPORTX" [ARX]
&         ,=GDOSREF+".AREPORTV" [ARV]
Local File =[F:ADS]DOSSIER+".AREPORT"    [DARP]
&         ,=[F:ADS]DOSSIER+".AREPORT"    [DAR2]
&         ,=[F:ADS]DOSSIER+".AREPORTD"   [DARD]
&         ,=[F:ADS]DOSSIER+".AREPORTS"   [DARO]
&         ,=[F:ADS]DOSSIER+".AREPORTX"   [DARX]
&         ,=[F:ADS]DOSSIER+".AREPORTV"   [DARV]

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(22,125,1),"") From GESECRAN
Endif

Local Integer ONBPAR , AROSTA
Local Char    OPAR(15)(1..100) , OACS(GLONACS)(1..100)

## Suppression des vieux états

If !GCRE
 Trbegin [DARP] , [DARD]
  For [DARP]ARP0 Where RPTCOD<GXX
   Call SPEC([F:DARP]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ARP]ARP0 = [F:DARP]RPTCOD
    If fstat
     Call EFFACE([F:DARP]RPTCOD)
    Endif
   Endif
  Next
 Commit
Endif

## Création mise à jour

For [ARP]ARP0 Where RPTCOD<GXX
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(22,125,1),[F:ARP]RPTCOD) From GESECRAN
 Endif
 Trbegin [DARP] , [DARD] , [DARO]
  OLD = 0
  SPEC = 0
  Read [DARP]ARP0 = [F:ARP]RPTCOD
  If !fstat
   OLD = 1
   Call SPEC([F:DARP]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ARP]CODACT,[F:ARP]MODULE,NEWREC) From DOSSUB
  If !SPEC

   If OLD & !NEWREC : # On le vire

    Call EFFACE([F:ARP]RPTCOD)

   Elsif NEWREC & !OLD

    Raz [F:DARP]
    [F:DARP] = [F:ARP]
    #111383
    If dim([F:DARP]DEVUSR)>0 : Raz [F:DARP]DEVUSR : Endif
    If dim([F:DARP]DEVSRV)>0 : Raz [F:DARP]DEVSRV : Endif
    If dim([F:DARP]DEVSTA)>0 : Raz [F:DARP]DEVSTA : Endif
    If dim([F:DARP]DEVDAT)>0 : Raz [F:DARP]DEVDAT : Endif
    If dim([F:DARP]DEVLAN)>0 : Raz [F:DARP]DEVLAN : Endif
    If dim([F:DARP]DEVAPP)>0 : Raz [F:DARP]DEVAPP : Endif
    #
    [F:DARP]CREDAT = date$
    [F:DARP]CREUSR = GUSER
    If dim([F:DARP]CRETIM)>0 : [F:DARP]CRETIM = time : Endif
    Write [DARP]
    If fstat : Call ERREUR("AREPORT"-[F:DARP]RPTCOD,1) From DOSDIC : Endif
    Read [ARO]ARO0 = [F:ARP]RPTCOD
    If !fstat
     [F:DARO] = [F:ARO]
     Write [DARO]
     If fstat : Call ERREUR("AREPORTS"-[F:DARO]RPTCOD,1) From DOSDIC : Endif
    Endif
    ONBPAR = 0
    Gosub CREDET

   Elsif NEWREC & OLD

    [F:DAR2] = [F:DARP]
    [F:DARP] = [F:ARP]

    ## Restauration des zones attribuées à l'utilisateur (sauf chez nous)

    If !GSOPHIA
     [F:DARP]GRP    = [F:DAR2]GRP
     [F:DARP]ACS    = [F:DAR2]ACS
     [F:DARP]PRTNAT = [F:DAR2]PRTNAT
     [F:DARP]PRTDEF = [F:DAR2]PRTDEF
     [F:DARP]PRTOBL = [F:DAR2]PRTOBL
     [F:DARP]PRTFRM = [F:DAR2]PRTFRM
     [F:DARP]ENAFLG = [F:DAR2]ENAFLG
     [F:DARP]PARSEG = [F:DAR2]PARSEG
     [F:DARP]EXEBAT = [F:DAR2]EXEBAT
     [F:DARP]HOR    = [F:DAR2]HOR
     [F:DARP]TRTSPE = [F:DAR2]TRTSPE
     [F:DARP]IMPLIE = [F:DAR2]IMPLIE
     If dim([F:DAR2]CODZPL)>0 & [F:DAR2]CODZPL<>""
      [F:DARP]CODZPL = [F:DAR2]CODZPL
      [F:DARP]GESZPL = [F:DAR2]GESZPL
     Endif
    Endif

    ## Réécriture
    #111383
    If dim([F:DARP]DEVUSR)>0 : Raz [F:DARP]DEVUSR : Endif
    If dim([F:DARP]DEVSRV)>0 : Raz [F:DARP]DEVSRV : Endif
    If dim([F:DARP]DEVSTA)>0 : Raz [F:DARP]DEVSTA : Endif
    If dim([F:DARP]DEVDAT)>0 : Raz [F:DARP]DEVDAT : Endif
    If dim([F:DARP]DEVLAN)>0 : Raz [F:DARP]DEVLAN : Endif
    If dim([F:DARP]DEVAPP)>0 : Raz [F:DARP]DEVAPP : Endif
    #
    [F:DARP]UPDDAT = date$
    [F:DARP]UPDUSR = GUSER
    If dim([F:DARP]UPDTIM)>0 : [F:DARP]UPDTIM = time : Endif
    Rewrite [DARP]
    If fstat : Call ERREUR("AREPORT"-[F:DARP]RPTCOD,2) From DOSDIC : Endif

    ## Sauvegarde des codes d'accès

    ONBPAR = 0
    For [DARD]ARD0 Where RPTCOD=[F:ARD]RPTCOD & PARACS<>""
     ONBPAR += 1
     OPAR(ONBPAR) = [F:DARD]PARCOD
     OACS(ONBPAR) = [F:DARD]PARACS
    Next

    ## Création des paramètres

    Delete [DARD] Where RPTCOD=[F:ARP]RPTCOD
    If fstat=1 : Call ERREUR("AREPORTD"-[F:ARP]RPTCOD,3) From DOSDIC : Endif
    Gosub CREDET

    ## Sources de données

    Read [ARO]ARO0 = [F:ARP]RPTCOD
    If !fstat
     Read [DARO]ARO0 = [F:ARP]RPTCOD
     AROSTA = fstat
     If AROSTA : Raz [F:DARO] : Endif
     [F:DARO]NBRTBL = [F:ARO]NBRTBL
     For I=0 To [F:DARO]NBRTBL-1
      [F:DARO]TBL(I) = [F:ARO]TBL(I)
      [F:DARO]NUM(I) = [F:ARO]NUM(I)
     Next I
     [F:DARO]NBRSRC = [F:ARO]NBRSRC
     For I=0 To [F:ARO]NBRSRC-1
      [F:DARO]SRC(I) = [F:ARO]SRC(I)
      If [F:DARO]DOSSIER(I)=""
       [F:DARO]DOSSIER(I) = [F:ARO]DOSSIER(I)
      Endif
     Next I
     If AROSTA
      [F:DARO]RPTCOD = [F:ARP]RPTCOD
      Write [DARO]
      If fstat : Call ERREUR("AREPORTS"-[F:DARO]RPTCOD,1) From DOSDIC : Endif
     Else
      Rewrite [DARO]
      If fstat : Call ERREUR("AREPORTS"-[F:DARO]RPTCOD,2) From DOSDIC : Endif
     Endif
    Else
     Delete [DARO] Where RPTCOD=[F:ARP]RPTCOD
     If fstat=1 : Call ERREUR("AREPORTS"-[F:ARP]RPTCOD,3) From DOSDIC : Endif
    Endif
   Endif
  Endif
 Commit
Next

## Création des nouveaux codes internes

For [ARX]ARX0(2) Where INTCOD<GXX & TYPCOD=1
 Read [DARX]ARX0(2) = [F:ARX]INTCOD;1
 If fstat
  Trbegin [DARX]
   For [ARX]ARX0
    [F:DARX] = [F:ARX]
    Write [DARX]
    If fstat : Call ERREUR("AREPORTX"-[F:DARX]INTCOD-[F:DARX]EXTCOD-[F:DARX]LAN,1) From DOSDIC : Endif
   Next
  Commit
 Endif
Next

# Suppression des vieilles références

For [DARX]ARX0 Where TYPCOD=1
 Read [DARP]ARP0 = [F:DARX]EXTCOD
 If fstat
  Trbegin [DARX]
   Delete [DARX]
  Commit
 Endif
Next

Close Local File [ARP]  , [ARD]  , [ARX]  , [ARV]
&              , [DARP] , [DAR2] , [DARD] , [DARX] , [DARV]
&              , [ARO] , [DARO]
Return

## Création paramètres

$CREDET
For [ARD]ARD0 Where RPTCOD=[F:ARP]RPTCOD
 [F:DARD] = [F:ARD]
 K = find([F:ARD]PARCOD,OPAR(1..ONBPAR))
 If K
  [F:DARD]PARACS = OACS(K)
 Endif
 Write [DARD]
 If fstat : Call ERREUR("AREPORTD"-[F:DARD]RPTCOD-[F:DARD]PARCOD,1) From DOSDIC : Endif
Next

## Création valeurs par défaut inexistantes

For [ARV]ARV0 Where ETAT=[F:ARP]RPTCOD & TYPCOD=1
 Read [DARV]ARV0 = [F:ARV]FONCTION;1;[F:ARV]ETAT;[F:ARV]PARAM
 If fstat
  [F:DARV] = [F:ARV]
  Write [DARV]
  If fstat : Call ERREUR("AREPORTV"-[F:DARV]FONCTION-[F:DARV]ETAT-[F:DARV]PARAM,1) From DOSDIC : Endif
 Endif
Next
Return

## Effacement d'un état

Subprog EFFACE(ETAT)
Value Char ETAT
Delete [DARD] Where RPTCOD=ETAT
If fstat=1 : Call ERREUR("AREPORTD"-ETAT,3) From DOSDIC : Endif
Delete [DARV] Where ETAT=[L]ETAT & TYPCOD = 1
If fstat=1 : Call ERREUR("AREPORTV"-ETAT,3) From DOSDIC : Endif
Delete [DARX] Where EXTCOD=ETAT  & TYPCOD = 1
If fstat=1 : Call ERREUR("AREPORTX"-ETAT,3) From DOSDIC : Endif
Delete [DARO] Where RPTCOD=ETAT
If fstat=1 : Call ERREUR("AREPORTS"-ETAT,3) From DOSDIC : Endif
Delete [DARP] Where RPTCOD=ETAT
If fstat=1 : Call ERREUR("AREPORT"-ETAT,3) From DOSDIC : Endif
End

