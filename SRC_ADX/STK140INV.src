################################################################
# Copie TABLE
################################################################
Subprog COPTAB(PTAB1,PTAB2)
Local File =PTAB1 [T1]
Local File =PTAB2 [T2]
Local Decimal C
Local Integer I
Local Integer CMAX : CMAX=1000

GOK=1
Trbegin [T2]
Call OUVRE_BOITE("Copie table:"+PTAB1-"vers"-PTAB2-"("+num$(nbrecord([T1]))+")",nbrecord([T1])) From GESECRAN
Raz C
For [T1]
    C+=1
    Call AFF_BOITE(num$(C),C,I) From GESECRAN
    [F:T2]=[F:T1]
    Write [T2]
    If fstat    
        Call FSTA("T2") From GLOCK
        Break
    Endif
    If mod(C,CMAX)=0
        Break
    Endif
Next
Close Local File [T1]
Close Local File [T2]
Call FERME_BOITE From GESECRAN
If GOK=1
    Commit
Else
    Rollback
Endif
End


#########################################################################
#  STKCVCUD  : Conversion table  CUNLISDET
# Paramètres E : LDOS   = Dossier
#                LFCY   = Site ou rien si tous sites
#                LPAR   = paramètre 0 = Première fois
#                                   1 = On refait le traitement
#########################################################################

Subprog STKCVCUD(LDOS,LFCY,LPAR)
Value Char    LDOS
Value Char    LFCY
Value Integer LPAR
#
Local File =LDOS+".CUNLISDET"     [CUD]    # Pour la lecture
Local File =LDOS+".CUNLISDET"     [CUD1]   # Pour l ecriture 
#
Local Integer LRET
Local Integer C
Local Integer I
Local Integer WITMLISNUM

If clalev([F:CUH]) = 0 : Local File CUNLISHEA   [CUH] : Endif
If clalev([F:CUS]) = 0 : Local File CUNLISSER   [CUS] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER   [ITM] : Endif


Call DEBTRANS From GLOCK
Trbegin [CUD1]

Call OUVRE_BOITE("Trt table:  CUNLISDET Phase 1 ("+num$(nbrecord([CUD]))+")",nbrecord([CUD])) From GESECRAN
Raz C
GOK=1
Local Integer WI
Raz WI
For [CUD]
    C+=1
    Call AFF_BOITE(num$(C),C,I) From GESECRAN

    If [F:CUD]CUNSSSNUM <> "" 
        Goto $CUD_NEXT
    Endif
    If [F:CUD]LINUPDFLG  <> 2
        If WI = 0
          Call ECR_TRACE(mess(52,184,1),1) From GESECRAN
          WI = 1
        Endif
       GMESSAGE=mess(18,7,1)-[F:CUD]ITMREF-mess(23,107,1)-[F:CUD]LOT-mess(44,197,1)-[F:CUD]LOC-mess(33,105,1)-num$([F:CUD]QTYSTU)-mess(137,124,1)-[F:CUD]CUNLISNUM
       Call ECR_TRACE(GMESSAGE,1) From GESECRAN
       Raz GMESSAGE
       Goto  $CUD_NEXT
    Endif

    Read [CUH]CUH0=[F:CUD]CUNLISNUM 
    If fstat 
       Raz [F:CUH] 
    Endif
    [F:CUD1]             = [F:CUD]
    [F:CUD1]CUNLOKFLG    = 2
    [F:CUD1]CUNSSSNUM    = [F:CUD]CUNLISNUM  
    [F:CUD1]IPTDAT       = [F:CUH]IPTDAT  
    If [F:CUD]LINUPDFLG  = 2
       [F:CUD1]CUNLISSTA = 4
       [F:CUD1]CUNLOKFLG = 1
    Endif  

    Write [CUD1]
$CUD_NEXT
Next
Call FERME_BOITE From GESECRAN

Commit
End


#########################################################################
#  STKCVCUD1  : Suppression session à spaces table  CUNLISDET
# Paramètres E : LDOS   = Dossier
#                LFCY   = Site ou rien si tous sites
#                LPAR   = paramètre 0 = Première fois
#                                   1 = On refait le traitement
#########################################################################

Subprog STKCVCUD1(LDOS,LFCY,LPAR)
Value Char    LDOS
Value Char    LFCY
Value Integer LPAR
#
Local File =LDOS+".CUNLISDET"     [CUD]  
#
Local Integer LRET



Call DEBTRANS From GLOCK
Trbegin [CUD]

Call OUVRE_BOITE("Trt table:  CUNLISDET Phase 2 ("+num$(nbrecord([CUD]))+")",nbrecord([CUD])) From GESECRAN
Delete [F:CUD] Where CUNSSSNUM  = "" 

Call FERME_BOITE From GESECRAN

Commit

End




#########################################################################
#  STKCVCUNCUL  : Creation  table  CUNSESSION CUNLISTE
# Paramètres E : LDOS   = Dossier
#                LFCY   = Site ou rien si tous sites
#                LPAR   = paramètre 0 = Première fois
#                                   1 = On refait le traitement
#########################################################################

Subprog STKCVCUNCUL(LDOS,LFCY,LPAR)
Value Char    LDOS
Value Char    LFCY
Value Integer LPAR
#
If clalev([F:CUH]) = 0 : Local File CUNLISHEA   [CUH] : Endif
Local File =LDOS+".CUNSESSION"     [CUN]  
Local File =LDOS+".CUNLISTE"       [CUL]  
#
Local Integer LRET
Local Integer C
Local Integer I

Call DEBTRANS From GLOCK
Trbegin [CUN]

Call OUVRE_BOITE("Trt table:  CUNSESSION  ("+num$(nbrecord([CUH]))+")",nbrecord([CUH])) From GESECRAN
Raz C
GOK=1
For [CUH]
    C+=1
    Call AFF_BOITE(num$(C),C,I) From GESECRAN

    [F:CUN]             = [F:CUH]
    [F:CUL]             = [F:CUH]

##############################
#rubriques par trans-classe              
##############################
#Site de stockage               
#Classe A/B/C
#Comptage Article A/B/C
#Comptage Demandes A/B/C
#Emplacement reception   
#Emplacement Stochage    
#Emplacement Picking     
#Derniere imputation                

##############################
#rubriques par correspondance            
##############################
#Session                        
    [F:CUN]CUNSSSNUM    = [F:CUH]CUNLISNUM  
    [F:CUL]CUNSSSNUM    = [F:CUH]CUNLISNUM  
#Liste                        
    [F:CUL]CUNLISNUM    = [F:CUH]CUNLISNUM  

#Intitule                      
    [F:CUN]CUNSSSDES    = [F:CUH]CUNLISDES  
    [F:CUL]CUNLISDES    = [F:CUH]CUNLISDES  
#Choix traitement               
    [F:CUN]CUNSSSMOD    = [F:CUH]CUNLISTYP
    If [F:CUN]CUNSSSMOD = 4
       [F:CUN]CUNSSSMOD = 1
    Endif  
     
#Statut                       
     If [F:CUH]UPDFLG    = 2
       [F:CUN]CUNSSSSTA = 3
       [F:CUL]CUNLISSTA = 6
    Else
       [F:CUN]CUNSSSSTA = 2
       [F:CUL]CUNLISSTA = 1
    Endif  
#Date inventaire                
    [F:CUN]CUNSSSDAT    = [F:CUH]CUNLISDAT
    [F:CUL]CUNLISDAT    = [F:CUH]CUNLISDAT
#Date statut                
    [F:CUL]CUNSTADAT    = [F:CUH]UPDDAT
#Operateur                
    [F:CUL]USR          = [F:CUH]UPDUSR

##############################
#rubriques nouvelles 
##############################
# Type inventaire
    [F:CUN]CUNSSSTYP    = 1  
# Maximum lignes
    [F:CUN]MAXLIG       = 9999
#  % limite      
    [F:CUN]PRCLIG       = 100
# Nombre article 
    [F:CUN]ITMNBR       = 9999
# Position emplacement
    [F:CUN]LOCPOS       = 10
# Classe D            
    [F:CUN]ABCCLSD      = 1
#Emplacement Poste W
    [F:CUN]TRALOCFLG    = 1
#Emplacement Quai    
    [F:CUN]QUALOCFLG    = 1
#Emplacement Magasin
    [F:CUN]MAGLOCFLG    = 1
#Emplacement Retour 
    [F:CUN]RETLOCFLG    = 1
#Maj Der inventaire
    [F:CUN]CUNLASFLG    = 2
#Stock verrouillé
    [F:CUL]CUNLOKFLG    = 2
    If [F:CUH]UPDFLG    = 2
       [F:CUL]CUNLOKFLG = 1
    Endif

##############################
#rubriques nouvelles à spaces 
##############################
# Formule        
# Article debut / fin
# Type emp debut /fin
# Emplacement debut / fin
# Categorie debut / fin
# Tiers debut / fin
# Acheteur debut / fin
# Famille stat debut / fin
# Lot debut / fin

##############################
#rubriques nouvelles à 0 
##############################
# Comptage article D
# Comptage demande D
# nbrlig
##############################
#rubriques ne pouvant pas etre recuperées
##############################
# tri inventaire
    [F:CUN]CUNSRTCOD    = 1  

    Write [CUN]
    Write [CUL]
Next
Call FERME_BOITE From GESECRAN

Commit

End

