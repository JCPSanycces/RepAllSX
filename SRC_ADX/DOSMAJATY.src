#<AdxTL>@(#)12.0.0.0 $Revision$
###############################################################################
# Mise à jour des types de données en 2 étapes :
# - Rajout et modification des types de données pour la validation des tables
# - Moulinette d'initialisation des nouveaux champs de la table ATYPE
###############################################################################

$DOSMAJATY

Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
Call ECR_TRACE("Update Data Types",0) From GESECRAN

Call PARAM("","SUPDOS",X3) From ADOVAL
If X3="" : X3 = "X3" : Endif

NBACTS = 0
For [ADA]ADA0 Where DOSSIER=[F:ADS]DOSSIER & CODACT>="X"
 If [F:ADS]DOSREF=X3 or [F:ADA]COP<>2
  NBACTS += 1
  TABACTS(NBACTS) = [F:ADA]CODACT
 Endif
Next ADA

Gosub OUVTAB From DOSMAJATB
OUVFIC = 1
OBJET = "ATYPE"
Gosub COPIE From DOSMAJATB : # Rajout des nouvelles zones
OBJET = "ATYPERUL"
Gosub COPIE From DOSMAJATB
OBJET = "ATYPERPAR"
Gosub COPIE From DOSMAJATB

OBJET = "ATYPELNK"
Gosub COPIE From DOSMAJATB
OBJET = "ATYPELPAR"
Gosub COPIE From DOSMAJATB

Gosub FERTAB From DOSMAJATB
Call ATYPE : # Intialisation des nouvelles zones

Local File =[F:ADS]DOSREF+".ATYPE"     [SATY]
Local File =[F:ADS]DOSREF+".ATYPERUL"   [SATYR]
Local File =[F:ADS]DOSREF+".ATYPERPAR"  [SATYRP]
Local File =[F:ADS]DOSREF+".ATYPELNK"   [SATYL]
Local File =[F:ADS]DOSREF+".ATYPELPAR"  [SATYLP]
Local File =[F:ADS]DOSREF+".ATEXTE"    [SATX]
Local File =[F:ADS]DOSREF+".ACTIV"     [SACV]

Local File =[F:ADS]DOSSIER+".ATYPE"    [ATY]
Local File =[F:ADS]DOSSIER+".ATYPERUL"  [ATYR]
Local File =[F:ADS]DOSSIER+".ATYPERPAR" [ATYRP]
Local File =[F:ADS]DOSSIER+".ATYPELNK"  [ATYL]
Local File =[F:ADS]DOSSIER+".ATYPELPAR" [ATYLP]
Local File =[F:ADS]DOSSIER+".ATYPE"    [ATY2]
Local File =[F:ADS]DOSSIER+".ATEXTE"   [ATX]

For [SATY]
 OKCOP = 1
 OBJET = [F:SATY]CODTYP
 Call OKCOP([F:SATY]MODULE,[F:SATY]CODACT,OKCOP) From DOSMAJSUB
 If OKCOP
  If DETAIL : Call ECR_TRACE("Update data type"-OBJET,0) From GESECRAN : Endif
  Gosub COPIE
 Else
  If DETAIL : Call ECR_TRACE("No update data type"-OBJET,0) From GESECRAN : Endif
 Endif
Next

Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
Close Local File [SATY] , [SATX] , [SACV] , [SATYR], [SATYRP], [SATYL], [SATYLP]
Close Local File [ATY] , [ATY2] , [ATX], [ATYR], [ATYRP], [ATYL], [ATYLP]
Return

$COPIE
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [ATY],[ATYR],[ATYRP]
 Read [ATY]CODTYP = [F:SATY]CODTYP
 If fstat
  Raz [F:ATY]
  Gosub TETE
  Write [ATY]
 Elsif !find([F:ATY]CODACT,TABACTS(1..NBACTS))
  Gosub TETE
  Rewrite [ATY]
 Endif
 If fstat
  GOK = 0 : Call FSTA("ATY") From GLOCK : Goto AB_TR1
 Endif
 #delete standard rules
 For [ATYR] Where CODTYP=[F:ATY]CODTYP
   If !find([F:ATYR]ACTRUL,TABACTS(1..NBACTS))
      Delete [ATYRP] Where CODTYP=[F:ATYR]CODTYP & TYPRUL=[F:ATYR]TYPRUL & TRTRUL=[F:ATYR]TRTRUL & PRGRUL=[F:ATYR]PRGRUL
      If fstat : GOK = 0 : Call ERREUR("ATYPERPAR"-[F:ATYR]CODTYP-num$([F:ATYR]TYPRUL)-[F:ATYR]TRTRUL-[F:ATYR]PRGRUL,3) From DOSDIC : Endif
      Delete [ATYR] Curr
      If fstat : GOK = 0 : Call ERREUR("ATYPERUL"-[F:ATYR]CODTYP-num$([F:ATYR]TYPRUL)-[F:ATYR]TRTRUL-[F:ATYR]PRGRUL,3) From DOSDIC : Endif
   Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 #insert standard rules
 For [SATYR] Where CODTYP=[F:ATY]CODTYP
   If !find([F:ATYR]ACTRUL,TABACTS(1..NBACTS))
     [F:ATYR]=[F:SATYR]
     Call ACTIV([F:ATYR]ACTRUL) From DOSMAJSUB
     Write [F:ATYR]
     If fstat
      GOK = 0 : Call FSTA("ATYR") From GLOCK : Break
     Endif

     For [SATYRP]ATYRP0 Where CODTYP=[F:ATYR]CODTYP & TYPRUL=[F:ATYR]TYPRUL & TRTRUL=[F:ATYR]TRTRUL & PRGRUL=[F:ATYR]PRGRUL
       [F:ATYRP]=[F:SATYRP]
       Call TEXTE([F:ATYRP]PARTIT) From DOSMAJSUB
       If GOK<1 : Break 2 : Endif
       Write [F:ATYRP]
       If fstat
        GOK = 0 : Call FSTA("ATYRP") From GLOCK : Break 2
       Endif
     Next
   Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
#delete standard links
 For [ATYL] Where CODTYP=[F:ATY]CODTYP
   If !find([F:ATYL]ACTRUL,TABACTS(1..NBACTS))
      Delete [ATYLP] Where CODTYP=[F:ATYL]CODTYP & CODLNK=[F:ATYL]CODLNK
      If fstat : GOK = 0 : Call ERREUR("ATYPELPAR"-[F:ATYL]CODTYP-[F:ATYL]CODLNK,3) From DOSDIC : Endif
      Delete [ATYL] Curr
      If fstat : GOK = 0 : Call ERREUR("ATYPELNK"-[F:ATYL]CODTYP-[F:ATYL]CODLNK,3) From DOSDIC : Endif
   Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 #insert standard links
 For [SATYL] Where CODTYP=[F:ATY]CODTYP
   If !find([F:ATYL]ACTRUL,TABACTS(1..NBACTS))
     [F:ATYL]=[F:SATYL]
     Call ACTIV([F:ATYL]ACTRUL) From DOSMAJSUB
     Write [F:ATYL]
     If fstat
      GOK = 0 : Call FSTA("ATYL") From GLOCK : Break
     Endif

     For [SATYLP]ATYLP0 Where CODTYP=[F:ATYL]CODTYP & CODLNK=[F:ATYL]CODLNK
       [F:ATYLP]=[F:SATYLP]
       Call TEXTE([F:ATYLP]PARTIT) From DOSMAJSUB
       If GOK<1 : Break 2 : Endif
       Write [F:ATYLP]
       If fstat
        GOK = 0 : Call FSTA("ATYLP") From GLOCK : Break 2
       Endif
     Next
   Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$TETE
[F:ATY2] = [F:ATY]
[F:ATY] = [F:SATY]
Case [F:ATY]CODTYP
 When "ABB" : [F:ATY]LNGTYP = [F:ADS]BLBLNG
 When "ACB" : [F:ATY]LNGTYP = [F:ADS]CLBLNG
Endcase
[F:ATY]MODULE = 1
Call ACTIV([F:ATY]CODACT) From DOSMAJSUB
Call TEXTE([F:ATY]INTITTYP) From DOSMAJSUB
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

#############################################################################
Subprog ATYPE
Local Integer I , J, TROUVE
Local Char    SUP(30), OLDACT(20)
Local File =[F:ADS]DOSSIER+".ATYPE"    [ATY]
Call ECR_TRACE(mess(81,125,1)-": ATYPE"-time$,0) From GESECRAN : # maj table
Trbegin [ATY]
 For [ATY]
  I = 0
  J = 0
  TROUVE=0
  For SUP = "IB", "AVANT", "INI", "SAI", "CONT", "APRES", "MODIF", "SEL"
&         , "BOU(0)", "BOU(1)", "BOU(2)", "BOU(3)", "AVL" , "APL"
&         , "BOU(4)", "BOU(5)", "BOU(6)", "BOU(7)"
&         , "BOU(8)", "BOU(9)", "BOU(10)", "BOU(11)"
   I += 1
   If evalue("dim([F:ATY]ACT"+SUP+")")>0
    TROUVE=1
    OLDACT = evalue("[F:ATY]ACT"+SUP)
    If OLDACT<>""
     [F:ATY]ACTTYP(J) = I
     [F:ATY]ACTION(J) = OLDACT
     [F:ATY]EXEACT(J) = 1
     J += 1
    Endif
   Endif
  Next I
  # Issue 83901 - 2013-01-21 by VPO : perte action SPE sur type SPE
  If TROUVE
    [F:ATY]NBTYP = J
  Endif
  # Issue 83901 - 2013-01-21 by VPO : perte action SPE sur type SPE
  # On perd aussi le module
  If [F:ATY]MODULE=0
    [F:ATY]MODULE = 9 : # Tronc commun
  Endif
  Rewrite [ATY]
  If fstat
   Call ERREUR("ATYPE"-[F:ATY]CODTYP,1) From DOSDIC
  Endif
 Next ATY
Commit
End
