#<AdxTL>@(#)2.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Update data of ACLAFLD table
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Update data of ACLAFLD table") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER=nomap
 Local File ACLAFLD [ACLAF]
 Local File ATYPE [ATY]
Else
 Local File =DOSSIER+".ACLAFLD" [ACLAF]
 Local File =DOSSIER+".ATYPE" [ATY]
Endif


Gosub MAJTAB7

Close Local File [ACLAF],[ATY]
End

#----------------------------------------------------------------------------------------#
$MAJTAB7
Trbegin [ACLAF]
 For [ACLAF]ACLAF0
  Read [ATY]CODTYP=[F:ACLAF]CODTYP
  If !fstat & find([F:ATY]TYPTYP,8,11,12)
   [F:ACLAF]LONG=0
  Elsif !fstat & find([F:ATY]TYPTYP,9,10)
   [F:ACLAF]LONG=1
  Endif
  Rewrite [ACLAF]
  If fstat
   Call ERREUR("ACLAFLD"-[F:ACLAF]CODCLA-[F:ACLAF]FLDCLA,2) From DOSDIC
  Endif
 Next
Commit

Return
