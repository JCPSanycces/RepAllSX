#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque ALLBENCH
########################################
Subprog C_QTYTOALL(VALEUR)
Variable Decimal VALEUR

If VALEUR > [M]RETQTY 
    GMESSAGE = mess(445,196,1) 
    If [M]VCRTYP=10 mkstat = 2 Else GERR=3 : Endif 
Endif
[M]WQTYTOALL = VALEUR

End

########################################
Subprog B1_NBLIG
Local Decimal WWRK

If [M]ALLQTY(nolign-1) = 0 
    # calcul reste à allouer
    WWRK = [M]QTYTOALL - [M]PECQTY
    # si nul, pas de sélection
    If WWRK = 0 : VALEUR = 1 : End : Endif

    # si qté dispo ligne > reste à allouer, PEC partielle
    If [M]AVAQTY(nolign-1) >=  WWRK
        [M]ALLQTY(nolign-1) =  WWRK
        [M]PECQTY          += WWRK
    Else
        [M]ALLQTY(nolign-1) = [M]AVAQTY(nolign-1)
        [M]PECQTY          += [M]AVAQTY(nolign-1)
    Endif
    [M]UOMALLQTY(nolign-1)  = [M]ALLQTY(nolign-1) / [M]UOMSTUCOE(nolign-1)
    Call QTEARR([M]UOMALLQTY(nolign-1),[M]UOM(nolign-1)) From TRTDIV
    [M]PECFLG(nolign-1) = 2
Else
    [M]PECQTY              -= [M]ALLQTY(nolign-1)    
    [M]ALLQTY(nolign-1)     = 0
    [M]UOMALLQTY(nolign-1)  = 0
    [M]PECFLG(nolign-1) = 1
Endif
Affzo [M]10-15
mkstat = 4
End

########################################
Subprog B2_NBLIG
# tri pour afficher les lignes allouées en début de tableau
Sorta [M:ALB]NBLIG [M:ALB]NBLIG Order By [M:ALB]XPECFLG(indice), [M:ALB]LOT(indice), [M:ALB]LOC(indice)
Affzo [M]10-15
End

########################################
Subprog IB_NBLIG
Raz GBOUT1
Raz GBOUT2
If [M]STOCOU(nolign-1) <> 0 : GBOUT1 = mess(306,198,1) : GBOUT2 = mess(396,198,1) : Endif
End

########################################!
Subprog AS_NBLIG
End

########################################
Subprog AM_PECFLG(VALEUR)
Variable Integer VALEUR
Local Decimal WWRK
Case VALEUR
    When 1:    [M]PECQTY -= [M]ALLQTY(nolign-1)
               [M]ALLQTY(nolign-1) = 0
               [M]UOMALLQTY(nolign-1)  = 0
               [M]XPECFLG(nolign-1) = 2
    When 2:    # calcul reste à allouer
               WWRK = [M]QTYTOALL - [M]PECQTY
               # si nul, pas de sélection
               If WWRK <= 0 : VALEUR = 1 : End : Endif

               # si qté dispo ligne > reste à allouer, PEC partielle
               If [M]AVAQTY(nolign-1) >=  WWRK
                   [M]ALLQTY(nolign-1) =  WWRK
                   [M]PECQTY          += WWRK
               Else
                   [M]ALLQTY(nolign-1) = [M]AVAQTY(nolign-1)
                   [M]PECQTY          += [M]AVAQTY(nolign-1)
               Endif
               [M]UOMALLQTY(nolign-1)  = [M]ALLQTY(nolign-1) / [M]UOMSTUCOE(nolign-1)
               Call QTEARR([M]UOMALLQTY(nolign-1),[M]UOM(nolign-1)) From TRTDIV
               [M]XPECFLG(nolign-1) = 1
Endcase
[M]PECFLG(nolign-1) = VALEUR
Affzo [M]10
End

########################################
Subprog AV_ALLQTY(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 :     pcolor = GCOUL(3) : Endif
End

########################################
Subprog AM_ALLQTY(VALEUR)
Variable Decimal VALEUR
Local    Decimal  WWRK, WWRK2

If VALEUR > [M]ALLQTY(nolign-1)
    WWRK2 = VALEUR - [M]ALLQTY(nolign-1) 

    # calcul reste à allouer
    WWRK = [M]QTYTOALL - [M]PECQTY
    If WWRK2 > WWRK 
        GMESSAGE = mess(445,196,1) 
        If [M]VCRTYP=10 
            mkstat = 2 : End 
        Else 
            Local Integer OK : OK=1
            Call AVERTIR (GMESSAGE, OK) From GESECRAN
            If OK=1 mkstat = 2 : Raz GMESSAGE : End : Endif                
        Endif
    Endif
Endif
If VALEUR = 0
    [M]PECQTY -= [M]ALLQTY(nolign-1)
    [M]UOMALLQTY(nolign-1)  = 0
    [M]PECFLG(nolign-1)  = 1
    [M]XPECFLG(nolign-1)  = 2
Else
    [M]PECQTY -= [M]ALLQTY(nolign-1)
    [M]PECQTY += VALEUR
    [M]UOMALLQTY(nolign-1)  = VALEUR / [M]UOMSTUCOE(nolign-1)
    Call QTEARR([M]UOMALLQTY(nolign-1),[M]UOM(nolign-1)) From TRTDIV
    [M]PECFLG(nolign-1)  = 2
    [M]XPECFLG(nolign-1) = 1
Endif
[M]ALLQTY(nolign-1) = VALEUR
Affzo [M]10
Affzo [M]PECFLG(nolign-1)
End

########################################
Subprog C_ALLQTY(VALEUR)
Variable Decimal VALEUR
If VALEUR > [M]AVAQTY(nolign-1) : GMESSAGE = mess(446,196,1) : mkstat = 2 : Endif
End

