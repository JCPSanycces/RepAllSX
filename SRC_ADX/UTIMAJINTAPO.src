#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# init description from object APO
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("init description from object APO") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#

#----------------------------------------------------------------------------------------#
$MAJTAB
If DOSSIER=nomap
 Local File APROMEN [APO]
 Local File ATABZON [ATZ]
 Local File ATEXTRA [AXX]
Else
 Local File =DOSSIER+".APROMEN" [APO]
 Local File =DOSSIER+".ATABZON" [ATZ]
 Local File =DOSSIER+".ATEXTRA" [AXX]
Endif

Read [ATZ]CODZONE="APROMEN";"LEG"
If !fstat
 Trbegin [APO]
 For [APO]
  If [F:APO]INTIT<>""
   Call MAJTEXTRA([F:APO]INTIT,"APROMEN","INTLNG",[APO]LEG,[F:APO]CODMEN) From ATEXTRA
   [F:APO]INTIT=""
  Endif
  If [F:APO]DESCR<>""
   Call MAJTEXTRA([F:APO]DESCR,"APROMEN","COMMENT",[APO]LEG,[F:APO]CODMEN) From ATEXTRA
   [F:APO]DESCR=""
  Endif
  Rewrite [APO]
  If fstat
   Call ERREUR("APROMEN"-[APO]CODMEN,2) From DOSDIC
  Endif
 Next
 Commit
Endif
Close Local File  [APO],[ATZ],[AXX]
Call MAJ_SEL(DOSSIER,"APO") From PATCHAOB
Return
