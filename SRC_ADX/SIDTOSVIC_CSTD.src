#------------------------------------------------------------------------------
#** SET_LIG_SIHNUM Set up the SIHNUM/SIDLIN flag for the given schedule invoices line
#* @param IN     : PVCRINVCNDLIN
#* @param IN     : PSIHNUM
#* @param IN     : PSIDLIN
#*!
$SET_LIG_SIHNUM
Local Integer WLINE

  If PVCRINVCNDLIN=AVOID.AINT : Return : Endif

  If maxtab(this.SVCRINVCND)=AVOID.AINT : Return : Endif

  If this.SVIC_INDEX>0
    If this.SVCRINVCND(this.SVIC_INDEX)<>null and find(this.SVCRINVCND(this.SVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      [L]ARET_VALUE = fmet this.SVCRINVCND(this.SVIC_INDEX).SET_LINE_INVOICE_NUM(PVCRINVCNDLIN,PSIHNUM,PSIDLIN)
      If [L]ARET_VALUE>=[V]CST_AERROR

      Endif
    Endif
  Endif

Return
#------------------------------------------------------------------------------
#** IS_PICK_ALLOWED Return [V]cst_ayes in VOK if the schedule invoice line object of the picking action
#* has not been consumed by qty/percent/amount increases on other schedule invoice lines, for the actual invoice
#* @param IN     : PVCRINVCNDLIN
#* @param IN     : PINVCNDQTY
#* @param IN     : PINVCNDAMT The date base value of INVCNDAMTNOT or INVCNDAMTATI according to PRITYP header value
#* @param OUT    : VOK
#*!
$IS_PICK_ALLOWED
Local Integer WLINE,WFOUND

  VOK=[V]CST_AYES

  If PVCRINVCNDLIN=AVOID.AINT : Return : Endif

  If maxtab(this.SVCRINVCND)=AVOID.AINT : Return : Endif

  WFOUND = [V]CST_ANOTDEFINED

  If this.SVIC_INDEX>0
    If this.SVCRINVCND(this.SVIC_INDEX)<>null and find(this.SVCRINVCND(this.SVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      For WLINE=1 To maxtab(this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN)
        If this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN<>null
          If this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WLINE).VCRINVCNDLIN = PVCRINVCNDLIN
            If find(this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
              WFOUND = WLINE
              Break
            Else
              VOK = [V]CST_ANO :#--the actual line was marked as to be deleted (it has been consumed by another)
            Endif
          Endif
        Endif
      Next
    Endif
  Endif

  If WFOUND = [V]CST_ANOTDEFINED : Return : Endif #--It's good, no changes done yet

  #--Is the line number present and is it qty changed flagged ?
  If    this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WFOUND).INVCNDQTY<>PINVCNDQTY
    VOK=[V]CST_ANO : Return
  Elsif this.SVCRINVCND(this.SVIC_INDEX).PRITYP=2 and
&       this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WFOUND).INVCNDAMTATI<>PINVCNDAMT
    VOK=[V]CST_ANO : Return
  Elsif this.SVCRINVCND(this.SVIC_INDEX).PRITYP<>2 and
&       this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WFOUND).INVCNDAMTNOT<>PINVCNDAMT
    VOK=[V]CST_ANO : Return
  Elsif this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WFOUND).INVCNDSTA>1
    VOK=[V]CST_ANO : Return
  Else
    #--Should check the SIDTOSVICD entries, but should not happen..so it's ok
  Endif

Return
#------------------------------------------------------------------------------
#** IS_DEPICK_ALLOWED Return [V]cst_ayes in VOK if the schedule invoice line object of the depicking action
#* has not been modified (qty/percent/amount increases/decreases), for the actual invoice
#* @param IN     : PVCRINVCNDLIN
#* @param OUT    : VOK
#*!
$IS_DEPICK_ALLOWED
Local Integer WLINE,WFOUND
Local File SVCRINVCNDD [SVICD]

  VOK=[V]CST_AYES

  If PVCRINVCNDLIN=AVOID.AINT : Return : Endif

  If maxtab(this.SVCRINVCND)=AVOID.AINT : Return : Endif

  WFOUND = [V]CST_ANOTDEFINED

  If this.SVIC_INDEX>0
    If this.SVCRINVCND(this.SVIC_INDEX)<>null and find(this.SVCRINVCND(this.SVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      For WLINE=1 To maxtab(this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN)
        If this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN<>null
          If this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WLINE).VCRINVCNDLIN = PVCRINVCNDLIN
            If find(this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
              WFOUND = WLINE
              Break
            Else
              VOK = [V]CST_ANO :#--the actual line was marked as to be deleted (it has been consumed by another)
            Endif
          Endif
        Endif
      Next
    Endif
  Endif

  If WFOUND = [V]CST_ANOTDEFINED : Return : Endif #--It's good, no changes done yet

  Read [F:SVICD]SVICD0 = this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WFOUND).VCRTYP;
&                        this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WFOUND).VCRNUMORI;
&                        this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WFOUND).VCRLINORI;
&                        this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WFOUND).VCRSEQORI;
&                        this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WFOUND).VCRINVCNDLIN
  If fstat : VOK=[V]CST_ANO : Return : Endif

  #--Is the line number present and is it qty changed flagged ?
  If    this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WFOUND).INVCNDQTY<>[F:SVICD]INVCNDQTY
    VOK=[V]CST_ANO : Return
  Elsif this.SVCRINVCND(this.SVIC_INDEX).PRITYP=2 and
&       this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WFOUND).INVCNDAMTATI<>[F:SVICD]INVCNDAMTATI
    VOK=[V]CST_ANO : Return
  Elsif this.SVCRINVCND(this.SVIC_INDEX).PRITYP<>2 and
&       this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(WFOUND).INVCNDAMTNOT<>[F:SVICD]INVCNDAMTNOT
    VOK=[V]CST_ANO : Return
  Else
    #--Should check the SIDTOSVICD entries, but should not happen..so it's ok
  Endif

Return
#------------------------------------------------------------------------------
#** INV_LINE_DELETED Called after deletion of an invoice line comming from a schedule invoice;
#*  it cancels the asked modifications for the PVCRINVCNDLIN scheduling invoice line
#*  and mark the schedule invoice line as 'To be invoiced'
#* @param IN     : PVCRINVCNDLIN
#* @param OUT    : [L]ARET_VALUE set to CST_AYES if everything was done properly
#*!
$INV_LINE_DELETED
Local Integer IJCPO

  If PVCRINVCNDLIN=AVOID.AINT : Return : Endif

  For IJCPO=1 To maxtab(this.SIDTOSVICD)
    If this.SIDTOSVICD(IJCPO)<>null and
&   find(this.SIDTOSVICD(IJCPO).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      If this.SIDTOSVICD(IJCPO).VCRINVCNDLIN = PVCRINVCNDLIN
        [L]ARET_VALUE = fmet this.ADELLINE("SIDTOSVICD",this.SIDTOSVICD(IJCPO).AORDER)
        If [L]ARET_VALUE=[V]CST_ANOTDEFINED
          [L]ARET_VALUE = [V]CST_AERROR
          Break
        Endif
      Endif
    Endif
  Next
  If [L]ARET_VALUE = [V]CST_AERROR : Return : Endif

  #--Let's force the call if no modifications were marked (deleting a line without previously modifying it)
  [L]ARET_VALUE = fmet this.SET_LIG_INVCNDSTA(PVCRINVCNDLIN,1)
  If [L]ARET_VALUE>=[V]CST_AERROR
    Return
  Endif
  [L]ARET_VALUE = fmet this.SET_LIG_SIHNUM(PVCRINVCNDLIN,AVOID.ACHAR,AVOID.AINT)
  If [L]ARET_VALUE>=[V]CST_AERROR
    Return
  Endif

Return
#------------------------------------------------------------------------------
#** BEFORE_CHANGES Called before an invoice line modification
#*  It enables the snapshot of the actual invoice schedule that will be used for
#*  reverting to snaphsot values in case of modification cancelling (by using Esc on a line, etc.)
#* @param IN     : PVCRINVCNDLIN
#* @param OUT    : [L]ARET_VALUE set to CST_AYES if everything was done properly
#*!
$BEFORE_CHANGES
#  If 1=0
#  #--In order to handle abandonned modifications (on GESSIH, when a line is abandoned - exp : using Escape)
#  If this.APARENT<>null and this.SVIC_INDEX>0 and this.SVCRINVCND(this.SVIC_INDEX)<>null and
#&    find(this.SVCRINVCND(this.SVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
#    If this.APARENT.snapshot<>null
#      [L]ARET_VALUE = this.APARENT.freeSnapshot
#    Endif
#    If this.APARENT.snapshotEnabled = 0
#      this.APARENT.snapshotEnabled = 1 #--snapshot enabeling if not done yet
#    Endif
#  Endif
#  Else
  #--In order to handle abandonned modifications (on GESSIH, when a line is abandoned - exp : using Escape)
  If this.SVIC_INDEX>0 and this.SVCRINVCND(this.SVIC_INDEX)<>null and
&    find(this.SVCRINVCND(this.SVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
    If this.SVCRINVCND(this.SVIC_INDEX).snapshot<>null
      [L]ARET_VALUE = this.SVCRINVCND(this.SVIC_INDEX).freeSnapshot
    Endif
    If this.SVCRINVCND(this.SVIC_INDEX).snapshotEnabled = 0
      this.SVCRINVCND(this.SVIC_INDEX).snapshotEnabled = 1 #--snapshot enabeling if not done yet
    Endif
  Endif
#  Endif

Return
#------------------------------------------------------------------------------
#** CANCEL_CHANGES Called after canceling an invoice line modification (exemple : throught Escape, or going to browser list without validation
#*  It cancels the asked modifications for the PVCRINVCNDLIN scheduling invoice line
#*  by reverting to snaphsot values
#* @param IN     : PVCRINVCNDLIN
#* @param OUT    : [L]ARET_VALUE set to CST_AYES if everything was done properly
#*!
$CANCEL_CHANGES
Local Char MODIFIED_PROPS(100)(1..)
Local Integer WNB, WLINE

#  If 1=0
  #  #--In order to handle abandonned modifications (on GESSIH, when a line is abandoned - exp : using Escape)
  #  If this.APARENT<>null and this.SVIC_INDEX>0 and this.SVCRINVCND(this.SVIC_INDEX)<>null and
  #&      find(this.SVCRINVCND(this.SVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  #    If this.APARENT.snapshot<>null
  #      [L]ARET_VALUE = this.APARENT.revertToSnapshot
  #      #--Doing a global control, just in case...
  #      [L]ARET_VALUE = fmet this.SVCRINVCND(this.SVIC_INDEX).ACONTROL
  #      If [L]ARET_VALUE>=[V]CST_AERROR
  #        Return
  #      Endif
  #    Endif
  #  Endif
#    If this.SVIC_INDEX>0 and this.SVCRINVCND(this.SVIC_INDEX)<>null and
#&    find(this.SVCRINVCND(this.SVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
#      #--Doing a global control, just in case...
#      [L]ARET_VALUE = fmet this.SVCRINVCND(this.SVIC_INDEX).ACONTROL
#      If [L]ARET_VALUE>=[V]CST_AERROR
#        Return
#      Endif
#    Endif
#  Else
  #--In order to handle abandonned modifications (on GESSIH, when a line is abandoned - exp : using Escape)
  If this.SVIC_INDEX>0 and this.SVCRINVCND(this.SVIC_INDEX)<>null and
&    find(this.SVCRINVCND(this.SVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
    If this.SVCRINVCND(this.SVIC_INDEX).snapshot<>null
      [L]ARET_VALUE = this.SVCRINVCND(this.SVIC_INDEX).revertToSnapshot
      #--Doing a global control, just in case...
      [L]ARET_VALUE = fmet this.SVCRINVCND(this.SVIC_INDEX).ACONTROL
      If [L]ARET_VALUE>=[V]CST_AERROR
        Return
      Endif
    Endif
  Endif
#  Endif

Return
#------------------------------------------------------------------------------
#** AFTER_CHANGES Called after an invoice line modification; it frees the snapshot
#* @param IN     : PVCRINVCNDLIN
#* @param OUT    : [L]ARET_VALUE set to CST_AYES if everything was done properly
#*!
$AFTER_CHANGES
#  If 1=0
#  #--In order to handle abandonned modifications (on GESSIH, when a line is abandoned - exp : using Escape)
#  If this.APARENT<>null and this.SVIC_INDEX>0 and this.SVCRINVCND(this.SVIC_INDEX)<>null and
#&    find(this.SVCRINVCND(this.SVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
#    If this.APARENT.snapshot<>null
#      [L]ARET_VALUE = this.APARENT.freeSnapshot
#    Endif
#    If this.APARENT.snapshotEnabled = 0
#      this.APARENT.snapshotEnabled = 1 #--snapshot enabeling if not done yet
#    Endif
#  Endif
#  Else
  #--In order to handle abandonned modifications (on GESSIH, when a line is abandoned - exp : using Escape)
  If this.SVIC_INDEX>0 and this.SVCRINVCND(this.SVIC_INDEX)<>null and
&    find(this.SVCRINVCND(this.SVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
    If this.SVCRINVCND(this.SVIC_INDEX).snapshot<>null
      [L]ARET_VALUE = this.SVCRINVCND(this.SVIC_INDEX).freeSnapshot
    Endif
    If this.SVCRINVCND(this.SVIC_INDEX).snapshotEnabled = 0
      this.SVCRINVCND(this.SVIC_INDEX).snapshotEnabled = 1 #--snapshot enabeling if not done yet
    Endif
  Endif
#  Endif
Return
#------------------------------------------------------------------------------
#** SET_FROM_CREDITNOTE Set up the IS_QTY_CHANGED flag and the changed qty value into NEWQTY property
#* Adds a line into the SIDTOSVICD collection
#* @param IN     : PVCRINVCNDLIN
#* @param IN     : PCNQTY
#* @param IN     : PCNAMOUNT
#*!
$SET_FROM_CREDITNOTE
Local Integer WLINE

  If PVCRINVCNDLIN=AVOID.AINT : Return : Endif

  If maxtab(this.SVCRINVCND)=AVOID.AINT : Return : Endif

  If this.SVIC_INDEX>0
    If this.SVCRINVCND(this.SVIC_INDEX)<>null and find(this.SVCRINVCND(this.SVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      [L]ARET_VALUE = fmet this.SVCRINVCND(this.SVIC_INDEX).SET_CREDITNOTE_UPDTOTALS(PVCRINVCNDLIN,PCNQTY,PCNAMOUNT)
      If [L]ARET_VALUE>=[V]CST_AERROR

      Endif
    Endif
  Endif

Return

