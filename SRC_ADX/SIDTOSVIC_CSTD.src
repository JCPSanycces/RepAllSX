  #Case [L]CURPRO
  #   Case [L]ARULE
  #   Endcase
  #Endcase

Return
#------------------------------------------------------------------------------
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS

  Case [L]AMETHOD
    When "SET_NEW_QTY"         : Gosub SET_NEW_QTY
    When "SET_NEW_AMOUNT"      : Gosub SET_NEW_AMOUNT
    When "SET_NEW_PRICE"       : Gosub SET_NEW_PRICE
    When "SET_NEW_PERCENT"     : Gosub SET_NEW_PERCENT
    When "UNSET_NEW"           : Gosub UNSET_NEW
    When "DO_CHANGES"          : Gosub DO_CHANGES
    When "DO_CHANGES_ALL"      : Gosub DO_CHANGES_ALL
    When "SET_LIG_INVCNDSTA"   : Gosub SET_LIG_INVCNDSTA
    When "SET_LIG_SIHNUM"      : Gosub SET_LIG_SIHNUM
    When "IS_PICK_ALLOWED"     : Gosub IS_PICK_ALLOWED
    When "IS_DEPICK_ALLOWED"   : Gosub IS_DEPICK_ALLOWED
    When "INV_LINE_DELETED"    : Gosub INV_LINE_DELETED
    When "BEFORE_CHANGES"      : Gosub BEFORE_CHANGES
    When "CANCEL_CHANGES"      : Gosub CANCEL_CHANGES
    When "AFTER_CHANGES"       : Gosub AFTER_CHANGES
    When "SET_FROM_CREDITNOTE" : Gosub SET_FROM_CREDITNOTE
  Endcase

Return
#------------------------------------------------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS

  #Case [L]AOPERATION
  #Endcase

Return
#------------------------------------------------------------------------------
#** SET_NEW_QTY Set up the IS_QTY_CHANGED flag and the changed qty value into NEWQTY property
#* Adds a line into the SIDTOSVICD collection
#* @param IN     : PVCRINVCNDLIN
#* @param IN     : PNEWQTY
#*!
$SET_NEW_QTY

Local Integer WLINE,WFOUND

  If PVCRINVCNDLIN=AVOID.AINT : Return : Endif

  WFOUND = [V]CST_ANOTDEFINED

  For WLINE=1 To maxtab(this.SIDTOSVICD)
    If this.SIDTOSVICD(WLINE)<>null and find(this.SIDTOSVICD(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      #--Is the line number present and is it qty changed flagged ?
      If this.SIDTOSVICD(WLINE).VCRINVCNDLIN = PVCRINVCNDLIN and this.SIDTOSVICD(WLINE).IS_QTY_CHG=[V]CST_AYES
        WFOUND = WLINE
        Break
      Endif
    Endif
  Next

  If WFOUND = [V]CST_ANOTDEFINED
    WLINE = fmet this.ADDLINE("SIDTOSVICD",[V]CST_ALASTPOS)
    If WLINE = [V]CST_ANOTDEFINED
      Return
    Endif
    WFOUND = WLINE
  Endif
  #--Concerned line from the schedule invoice
  this.SIDTOSVICD(WFOUND).VCRINVCNDLIN = PVCRINVCNDLIN
  #--What changed
  this.SIDTOSVICD(WFOUND).IS_QTY_CHG   = [V]CST_AYES
  this.SIDTOSVICD(WFOUND).NEWQTY       = PNEWQTY
  this.SIDTOSVICD(WFOUND).IS_EXTRABILL = PIS_EXTRABILL

Return
#------------------------------------------------------------------------------
#** SET_NEW_AMOUNT Set up the IS_AMT_CHG flag and the changed qty value into NEWAMOUNT property
#* #* Adds a line into the SIDTOSVICD collection
#* @param IN     : PVCRINVCNDLIN
#* @param IN     : PNEWAMOUNT
#*!
$SET_NEW_AMOUNT

Return
#------------------------------------------------------------------------------
#** SET_NEW_PRICE Set up the IS_PRICE_CHG flag and the changed qty value into NEWPRICE property
#* #* Adds a line into the SIDTOSVICD collection
#* @param IN     : PVCRINVCNDLIN
#* @param IN     : PNEWPRICE
#*!
$SET_NEW_PRICE

Local Integer WLINE,WFOUND

  If PVCRINVCNDLIN=AVOID.AINT : Return : Endif

  WFOUND = [V]CST_ANOTDEFINED

  For WLINE=1 To maxtab(this.SIDTOSVICD)
    If this.SIDTOSVICD(WLINE)<>null and find(this.SIDTOSVICD(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      #--Is the line number present and is it qty changed flagged ?
      If this.SIDTOSVICD(WLINE).VCRINVCNDLIN = PVCRINVCNDLIN and this.SIDTOSVICD(WLINE).IS_PRICE_CHG=[V]CST_AYES
        WFOUND = WLINE
        Break
      Endif
    Endif
  Next

  If WFOUND = [V]CST_ANOTDEFINED
    WLINE = fmet this.ADDLINE("SIDTOSVICD",[V]CST_ALASTPOS)
    If WLINE = [V]CST_ANOTDEFINED
      [L]ARET_VALUE = [V]CST_AERROR
      Return
    Endif
    WFOUND = WLINE
  Endif

  #--Concerned line from the schedule invoice
  this.SIDTOSVICD(WFOUND).VCRINVCNDLIN = PVCRINVCNDLIN
  #--What changed
  this.SIDTOSVICD(WFOUND).IS_PRICE_CHG = [V]CST_AYES
  this.SIDTOSVICD(WFOUND).NEWPRICE     = PNEWPRICE

Return
#------------------------------------------------------------------------------
#** SET_NEW_PERCENT Set up the IS_PERC_CHG flag and the changed qty value into NEWPERCENT property
#* #* Adds a line into the SIDTOSVICD collection
#* @param IN     : PVCRINVCNDLIN
#* @param IN     : PNEWPERCENT
#*!
$SET_NEW_PERCENT
Local Integer WLINE,WFOUND

  If PVCRINVCNDLIN=AVOID.AINT : Return : Endif

  WFOUND = [V]CST_ANOTDEFINED

  For WLINE=1 To maxtab(this.SIDTOSVICD)
    If this.SIDTOSVICD(WLINE)<>null and find(this.SIDTOSVICD(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      #--Is the line number present and is it qty changed flagged ?
      If this.SIDTOSVICD(WLINE).VCRINVCNDLIN = PVCRINVCNDLIN and this.SIDTOSVICD(WLINE).IS_PRC_CHG = [V]CST_AYES
        WFOUND = WLINE
        Break
      Endif
    Endif
  Next

  If WFOUND = [V]CST_ANOTDEFINED
    WLINE = fmet this.ADDLINE("SIDTOSVICD",[V]CST_ALASTPOS)
    If WLINE = [V]CST_ANOTDEFINED
      [L]ARET_VALUE = [V]CST_AERROR
      Return
    Endif
    WFOUND = WLINE
  Endif

  #--Concerned line from the schedule invoice
  this.SIDTOSVICD(WFOUND).VCRINVCNDLIN = PVCRINVCNDLIN
  #--What changed
  this.SIDTOSVICD(WFOUND).IS_PRC_CHG   = [V]CST_AYES
  this.SIDTOSVICD(WFOUND).NEWPERCENT   = PNEWPERCENT
  this.SIDTOSVICD(WFOUND).IS_EXTRABILL = PIS_EXTRABILL

Return
#------------------------------------------------------------------------------
#** UNSET_NEW Cancels the asked modifications for the PVCRINVCNDLIN scheduling invoice line
#* @param IN     : PVCRINVCNDLIN
#* @param OUT    : VIS_LAST_LINE set to CST_AYES if no other lines from the same scehdule invoice are marked as changed
#*!
$UNSET_NEW
Local Integer IJCPO,WALREADY_CALLED

  If PVCRINVCNDLIN=AVOID.AINT : Return : Endif

  WALREADY_CALLED = [V]CST_ANO

  VIS_LAST_LINE = [V]CST_AYES

  For IJCPO=1 To maxtab(this.SIDTOSVICD)
    If this.SIDTOSVICD(IJCPO)<>null and
&   find(this.SIDTOSVICD(IJCPO).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      If this.SIDTOSVICD(IJCPO).VCRINVCNDLIN = PVCRINVCNDLIN
        [L]ARET_VALUE = fmet this.ADELLINE("SIDTOSVICD",this.SIDTOSVICD(IJCPO).AORDER)
        If [L]ARET_VALUE=[V]CST_ANOTDEFINED
          [L]ARET_VALUE = [V]CST_AERROR
          Break
        Endif
      Else
        VIS_LAST_LINE = [V]CST_ANO
      Endif
    Endif
  Next
  If [L]ARET_VALUE = [V]CST_AERROR : Return : Endif

  #--Doesn't suffice to only set VIS_LAST_LINE to ANO if other schedule lines in SIDTOSVICD collection...
  #--This collection only contains modifications 'marked' for the DO_CHANGES
  #--Except that, sometime, the DO_CHANGES is called right after marking the changing
  If this.SVIC_INDEX>0 and this.SVCRINVCND(this.SVIC_INDEX)<>null and
&    find(this.SVCRINVCND(this.SVIC_INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
    For IJCPO=1 To maxtab(this.SVCRINVCND(this.SVIC_INDEX))
      If this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(IJCPO)<>null and find(this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(IJCPO).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        If this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(IJCPO).VCRINVCNDLIN<>PVCRINVCNDLIN and
&          this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(IJCPO).ASTALIN=[V]CST_AUPD and
&          this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(IJCPO).INVCNDSTA=5 and
&          (this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(IJCPO).SIHNUM=AVOID.ACHAR or
&           this.SVCRINVCND(this.SVIC_INDEX).VCRINVCNDLIN(IJCPO).SIHNUM=PSIHNUM)
           VIS_LAST_LINE = [V]CST_ANO : Break
        Endif
      Endif
    Next
  Endif

Return
#------------------------------------------------------------------------------
#** DO_CHANGES According to each modified propery, the proper method is called for the SVCRINVCND instance
#* @param IN     : PVCRINVCNDLIN schedule invoice line's key n° component
#*!
$DO_CHANGES
Local Integer WLINE

  If PVCRINVCNDLIN=AVOID.AINT : Return : Endif

  If this.SVIC_INDEX=0 or this.SVCRINVCND(this.SVIC_INDEX)=null or maxtab(this.SVCRINVCND)=AVOID.AINT : Return : Endif

  For WLINE=1 To maxtab(this.SIDTOSVICD)
    If this.SIDTOSVICD(WLINE)<>null and find(this.SIDTOSVICD(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      #--Is the line number present and is it qty/percent/price/amount changed flagged ?
      If this.SIDTOSVICD(WLINE).VCRINVCNDLIN = PVCRINVCNDLIN
        If    this.SIDTOSVICD(WLINE).IS_QTY_CHG=[V]CST_AYES
          [L]ARET_VALUE = fmet this.SVCRINVCND(this.SVIC_INDEX).SET_INVOICE_QTY_CHANGED(PVCRINVCNDLIN,this.SIDTOSVICD(WLINE).NEWQTY,this.SIDTOSVICD(WLINE).IS_EXTRABILL)
          If [L]ARET_VALUE>=[V]CST_AERROR
            Break
          Endif
          this.SIDTOSVICD(WLINE).IS_QTY_CHG=[V]CST_ANO
        Elsif this.SIDTOSVICD(WLINE).IS_PRC_CHG=[V]CST_AYES
          [L]ARET_VALUE = fmet this.SVCRINVCND(this.SVIC_INDEX).SET_INVOICE_PRC_CHANGED(PVCRINVCNDLIN,this.SIDTOSVICD(WLINE).NEWPERCENT,this.SIDTOSVICD(WLINE).IS_EXTRABILL)
          If [L]ARET_VALUE>=[V]CST_AERROR
            Break
          Endif
          this.SIDTOSVICD(WLINE).IS_PRC_CHG=[V]CST_ANO
        Elsif this.SIDTOSVICD(WLINE).IS_PRICE_CHG=[V]CST_AYES
          [L]ARET_VALUE = fmet this.SVCRINVCND(this.SVIC_INDEX).SET_INVOICE_PRICE_CHANGED(PVCRINVCNDLIN,this.SIDTOSVICD(WLINE).NEWPRICE)
          If [L]ARET_VALUE>=[V]CST_AERROR
            Break
          Endif
          this.SIDTOSVICD(WLINE).IS_PRICE_CHG=[V]CST_ANO
#        Elsif this.SIDTOSVICD(WLINE).IS_AMT_CHG=[V]CST_AYES
#          [L]ARET_VALUE = fmet this.SVCRINVCND(this.SVIC_INDEX).SET_INVOICE_AMT_CHANGED(PVCRINVCNDLIN,this.SIDTOSVICD(WLINE).NEWAMT,this.SIDTOSVICD(WLINE).is_extrabill)
#          If [L]ARET_VALUE>=[V]CST_AERROR
#            Break
#          Endif
#          this.SIDTOSVICD(WLINE).IS_AMT_CHG=[V]CST_ANO
        Endif

        #--After doing the marked modifications, we delete the collection line
        [L]ARET_VALUE = fmet this.ADELLINE("SIDTOSVICD",this.SIDTOSVICD(WLINE).AORDER)
        If [L]ARET_VALUE=[V]CST_ANOTDEFINED
          [L]ARET_VALUE = [V]CST_AERROR
          Break
        Endif
      Endif
    Endif
  Next

Return
#------------------------------------------------------------------------------
#** DO_CHANGES_ALL According to each modified propery, the proper method is called for the SVCRINVCND instance
#*
#*!
$DO_CHANGES_ALL
Local Integer WLINE

  If this.SVIC_INDEX=0 or this.SVCRINVCND(this.SVIC_INDEX)=null or maxtab(this.SVCRINVCND)=AVOID.AINT : Return : Endif

  For WLINE=1 To maxtab(this.SIDTOSVICD)
    If this.SIDTOSVICD(WLINE)<>null and find(this.SIDTOSVICD(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      #--Is the line number present and is it qty changed flagged ?
      If this.SVIC_INDEX>0
        If    this.SIDTOSVICD(WLINE).IS_QTY_CHG=[V]CST_AYES
          [L]ARET_VALUE = fmet this.SVCRINVCND(this.SVIC_INDEX).SET_INVOICE_QTY_CHANGED(this.SIDTOSVICD(WLINE).VCRINVCNDLIN,this.SIDTOSVICD(WLINE).NEWQTY,this.SIDTOSVICD(WLINE).IS_EXTRABILL)
          If [L]ARET_VALUE>=[V]CST_AERROR
            Break
          Endif
        Elsif this.SIDTOSVICD(WLINE).IS_PRC_CHG=[V]CST_AYES
          [L]ARET_VALUE = fmet this.SVCRINVCND(this.SVIC_INDEX).SET_INVOICE_PRC_CHANGED(this.SIDTOSVICD(WLINE).VCRINVCNDLIN,this.SIDTOSVICD(WLINE).NEWPERCENT)
          If [L]ARET_VALUE>=[V]CST_AERROR
            Break
          Endif
        Elsif this.SIDTOSVICD(WLINE).IS_PRICE_CHG=[V]CST_AYES
          [L]ARET_VALUE = fmet this.SVCRINVCND(this.SVIC_INDEX).SET_INVOICE_PRICE_CHANGED(this.SIDTOSVICD(WLINE).VCRINVCNDLIN,this.SIDTOSVICD(WLINE).NEWPRICE)
          If [L]ARET_VALUE>=[V]CST_AERROR
            Break
          Endif
#        Elsif this.SIDTOSVICD(WLINE).IS_AMT_CHG=[V]CST_AYES
#          [L]ARET_VALUE = fmet this.SVCRINVCND(this.SVIC_INDEX).SET_INVOICE_AMT_CHANGED(this.SIDTOSVICD(WLINE).VCRINVCNDLIN,this.SIDTOSVICD(WLINE).NEWAMT)
#          If [L]ARET_VALUE>=[V]CST_AERROR
#            Break
#          Endif
        Endif

        #--After doing the marked modifications, we delete the collection line
        [L]ARET_VALUE = fmet this.ADELLINE("SIDTOSVICD",this.SIDTOSVICD(WLINE).AORDER)
        If [L]ARET_VALUE=[V]CST_ANOTDEFINED
          [L]ARET_VALUE = [V]CST_AERROR
          Break
        Endif

      Else
        #--No schedule invoice instance loaded...
      Endif
    Endif
  Next

Return
