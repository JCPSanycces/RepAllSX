#<AdxTL>@(#)7.0.0.0 $Revision$
###################################
#     Trt de l'état BPCINV        #
# Aide à la récupération des taux #
###################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Integer MAXSOC : MAXSOC = 1000
Local Integer NBSOC, NBRLEG, I ,K, KNUMLIG
Local Char    TBSOC(GLONCPY)(1..MAXSOC)
Local Char    SOCIETE(GLONCPY), ETAT(GLONARP), PARAM(50)
Local Char    TABLEG(GLONADI)(1..GNBSOC)
Local Char    LEGCPY(GLONADI)
Local Char    CNUMREQ(30)
Local Char    MULCOPPAR(1)
Local Integer INBCOP, LNBCOP

If clalev([F:ARM])=0  : Local File AREPORTM   [ARM]  : Endif
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif

If clalev([SIH])=0 : Local File SINVOICE   [SIH] : Endif
If clalev([SIT])=0 : Local File BPCINVVAT  [SIT] : Endif
If clalev([TRA])=0 : Local File TABRATVAT  [TRA] : Endif
If clalev([TVT])=0 : Local File TABVAT     [TVT] : Endif
If clalev([TVB])=0 : Local File TABVACBPR  [TVB] : Endif
If clalev([TDA])=0 : Local File TABDEPAGIO [TDA] : Endif
If clalev([F:TARPT])=0 : Local File TMPARPT    [TARPT]  : Endif

####################################################
## Récup paramètres
####################################################
Local Integer TYPETAT
Local Char    PARAM(30) , ETAT(GLONARP), NOM_ETAT(GLONARP)
Local Integer NUMREQ , LIGNE
Local Integer K, I, J

Local Char    SOCIETE(GLONCPY) , SITDEB(GLONFCY) , SITFIN(GLONFCY)
Local Char    NUMDEB(20) , NUMFIN(20), CRITERE(250)
Local Date    DATDEB , DATFIN
Local Integer DUPLICATA , NBRCPY , DESTIMP

Local Char    CODE(GLONVAT)(0..dim([F:SIH]TAX)-1), TEX(80)(0..dim([F:SIH]TAX)-1)
Local Decimal TAUX(0..dim([F:SIH]TAX)-1)

Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT
NUMREQ = val(PARAM)

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,PARAM) From ETAT
K = instr(1,PARAM,".")
If K : PARAM = left$(PARAM,K-1) : Endif
ETAT = PARAM

Call GETPARAM("societe",NBPAR,PARAMETRE,[L]SOCIETE)   From ETAT
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,[L]SITDEB)    From ETAT
Call GETPARAM("sitefin",NBPAR,PARAMETRE,[L]SITFIN)    From ETAT
Call GETPARAM("datedeb",NBPAR,PARAMETRE,PARAM)        From ETAT   : [L]DATDEB   = PARAM
Call GETPARAM("datefin",NBPAR,PARAMETRE,PARAM)        From ETAT   : [L]DATFIN   = PARAM
Call GETPARAM("numdeb",NBPAR,PARAMETRE,[L]NUMDEB)     From ETAT
Call GETPARAM("numfin",NBPAR,PARAMETRE,[L]NUMFIN)     From ETAT
Call GETPARAM("duplicata",NBPAR,PARAMETRE,PARAM)      From ETAT   :[L]DUPLICATA = val(PARAM)
Call GETPARAM("_PrinterCopies",NBPAR,PARAMETRE,PARAM) From ETAT   :[L]NBRCPY  = val(PARAM)


PARAM = func AFNC.PARAM( "SDDMGT", [L]SOCIETE )
If PARAM = "2" Then
    PARAM = func AFNC.PARAM( "SDDPRN", [L]SOCIETE )
    If PARAM = "" Then
        PARAM = "1"
    Endif
Else
    PARAM = "1"
Endif
Call SETPARAM ("sddprn", [L]NBPAR, [L]PARAMETRE, PARAM ) From ETAT


CRITERE = "1=1"
If [L]SOCIETE<>""     : CRITERE -= "& CPY='"+SOCIETE+"'"                     : Endif
If [L]DATDEB<>[0/0/0] : CRITERE -= "& ACCDAT>=["+format$(GFMD,[L]DATDEB)+"]" : Endif
If [L]DATFIN<>[0/0/0] : CRITERE -= "& ACCDAT<=["+format$(GFMD,[L]DATFIN)+"]" : Endif

If SOCIETE<>""
 Read [CPY]CPY0 = SOCIETE
 If fstat
  # Société incorrecte
  Call ECR_TRACE(mess(81,116,1),1) From GESECRAN
  GOK = 0 : End
 Endif
 If [F:CPY]CPYLEGFLG<>2
  NBSOC = 0
  For [FGR]FGR0 Where CPY=SOCIETE
   Read [FCY]FCY0 = [F:FGR]FCY
   If !find([F:FCY]LEGCPY,TBSOC(1..NBSOC))
    If NBSOC>=MAXSOC : Break : Endif
    NBSOC += 1
    TBSOC(NBSOC) = [F:FCY]LEGCPY
   Endif
  Next
  Read [CPY]CPY0 = TBSOC(1)
 Else
  NBSOC = 1
  TBSOC(1) = SOCIETE
 Endif
Else
 For [CPY] Where CPYLEGFLG=2
  If NBSOC>=MAXSOC : Break : Endif
   NBSOC += 1
   TBSOC(NBSOC) = [F:CPY]CPY
 Next
 If NBSOC>=MAXSOC
  # Trop de sociétés
  Call ECR_TRACE(mess(108,104,1),1) From GESECRAN
  GOK = 0 : End
 Endif
Endif
Call LEGCPY(TBSOC,NBRLEG,TABLEG) From CPTDIV
Gosub TRTPAM From RPTLEG
Gosub TRT_TVB From RPTLEG
Gosub TRT_TDA From RPTLEG

KNUMLIG = [F:ARM]NUMLIG
Call SETPARAM ("usr",[L]NBPAR,[L]PARAMETRE,GUSER) From ETAT
Call SETPARAM ("etat",[L]NBPAR,[L]PARAMETRE,[L]ETAT) From ETAT
CNUMREQ = num$([L]NUMREQ)
Call SETPARAM ("numedt",[L]NBPAR,[L]PARAMETRE,CNUMREQ) From ETAT

Raz [F:ARM]

[F:ARM]USR    = GUSER
[F:ARM]RPTCOD = [F:ARP]RPTCOD
[F:ARM]NUMREQ = [L]NUMREQ
[F:ARM]CREDAT = date$

Filter [SIH] Where NUM>=NUMDEB & NUM<=NUMFIN & ORIMOD=3 & evalue(CRITERE)  : #& CPY=SOCIETE & ACCDAT>=DATDEB & ACCDAT<=DATFIN
Local Integer OK
For [SIH]SIH0

 Call DEBTRANS From GLOCK
 Trbegin [SIT]
  Delete [SIT] Where NUM=[F:SIH]NUM
  If fstat=1 | fstat>5
   GOK = 0
   Call RSTA("SIT","") From GLOCK
   Rollback : Break
  Endif
 Commit

 If NBRLEG=1
  [L]LEGCPY = TABLEG(1)
 Elsif NBRLEG>1
   Call LEC_CPY([F:SIH]CPY) From CPTLEC
   [L]LEGCPY = [F:CPY]LEG
 Endif

 #RMA
 Gosub MULCOP

 K = 0
 Raz CODE, TAUX , TEX
 For I=0 To dim([F:SIH]TAX)-1
  OK=1
  Call LEC_TVT_LEG([L]LEGCPY,[F:SIH]TAX(I)) From CPTLEC
  # Cas particulier société ??
  Filter [TRA] Where CPY=[F:SIH]CPY & VAT=[F:SIH]TAX(I) & STRDAT<=[F:SIH]ACCDAT & LEG=[F:TVT]LEG
  Read [TRA]TRA0 Last
  If fstat>2
   # sinon on se rabat sur le code dossier
   Filter [TRA] Where CPY="" & VAT=[F:SIH]TAX(I) & STRDAT<=[F:SIH]ACCDAT & LEG=[F:TVT]LEG
   Read [TRA]TRA0 Last
   If fstat>2 : Break : Endif
  Endif
  J=find([F:TRA]VAT,CODE(0..dim([F:SIH]TAX)-1))
  If !J
   CODE(I)=[F:TRA]VAT
   TAUX(I)=[F:TRA]VATRAT


   Call LECTEXTRA(TEX(K),"TABVAT","TEXAXX",[F:TVT]VAT,[F:TVT]LEG) From ATEXTRA
   If len(TEX(K))<>0
    K +=1
   Endif
  Endif
 Next
 Call DEBTRANS From GLOCK
 Gosub TR1
 If !GOK : Rollback : Break : Endif
Next
Filter [SIH]
Filter [TRA]

End

$TR1
Trbegin [SIT]
 Raz [F:SIT]

 ## Mise à jour de la zone STARPT dans SINVOICE qui indique si la facture définitive a été imprimée
 ## [F:SIT]DOC=mention à imprimer sur la facture 1=Pas de mention à imprimer, car facture définitive, 2=Duplicata, 3=Provisoire
 If [L]DUPLICATA = 0 : # Pas de duplicata demandé
  [F:SIT]DOC = 1
 Else                : # Duplicata demandé
  [F:SIT]DOC = 2
 Endif

 If [F:SIH]STARPT<>2 : # Facture définitive non imprimée=>Maj STARPT + Pas de duplicata possible
  Case func AFNC.PARAM("SIVCFM",[F:SIH]FCY)
   When "1" : #Non
    [F:SIH]STARPT = 2
    [F:SIT]DOC    = 1 : #Définitive
   When "2" : #Oui
    [F:SIH]STARPT = 2
    [F:SIT]DOC    = 1 : #Définitive
   When "3" : #Oui après validation
    If [F:SIH]STA=3 : #Facture validée
     [F:SIH]STARPT = 2
     [F:SIT]DOC    = 1 : #Facture Définitive
    Else
     [F:SIT]DOC    = 3 : #Facture Provisoire
    Endif
  Endcase
 Endif
 [F:SIT]NUM  = [F:SIH]NUM
 For I=0 To dim([F:SIH]TAX)-1
  [F:SIT]CODE(I) = CODE(I)
  [F:SIT]TAUX(I) = TAUX(I)
  [F:SIT]TEX(I)  = TEX(I)
 Next
 Write [SIT]
 If fstat : GOK=0 : Call FSTA("SIT") From GLOCK : Return : Endif
 Rewrite [SIH]
 If fstat : GOK=0 : Call FSTA("SIH") From GLOCK : Return : Endif

# 2016-01-08 DNE INSERT BEGIN (SAM #99458) ##############################
  #
  # Note: - For Swiss ISR printing we have to fetch some data and
  #         write it into table AREPORTM.
  #       - This is only done for an active ACV "KSW" and enabled ISR
  #         printing (parameter SWICUSBVR active).
  #
  Gosub FILL_BVRREFNUM_INVTOTAL_PAYBAN From SWILIB0
# 2016-01-08 DNE INSERT END #############################################

 Gosub ALIM_ARM
 If GOK=0 : Return : Endif
 If func AFNC.ACTIV("KPO")
   Gosub ALIM_TARPT
   If GOK=0 : Return : Endif
 Endif
Commit
Return
#########################################################################
#########################################################################
$ALIM_ARM

Raz [F:ARM]NUMCOP

If MULCOPPAR="2"
  LNBCOP = max(1,[M:RPT]NBRCPY)
Else
  LNBCOP = 1
Endif

For [L]INBCOP = 1 To [L]LNBCOP

  KNUMLIG += 1
  [F:ARM]NUMLIG= KNUMLIG
  If MULCOPPAR="2" : [F:ARM]NUMCOP+= 1 : Else : [F:ARM]NUMCOP = 0 : Endif
  [F:ARM]CLEA1  = [F:SIH]NUM

  Gosub ALIMETAT_PE From ETAT
  Write [ARM]
  If fstat  GOK=0 : Call FSTA("ARM") From GLOCK : Break : Endif

Next

Return
#########################################################################
#########################################################################
$ALIM_TARPT

Raz [F:TARPT]

[F:TARPT] = [F:ARM]
[F:TARPT]VCRNUM = [F:SIH]NUM

Write [F:TARPT]
If fstat : GOK=0 : Call FSTA("TARPT") From GLOCK : Endif

Return
#########################################################################
#########################################################################
$MULCOP

#Found MULCOPRINT parameter value print POR
Call PARAM ([F:SIH]CPY,"MULCOPRINT",MULCOPPAR) From ADOVAL

#Set the param in Crystal Report : fill in by default by No if the parameter is empty
If MULCOPPAR=""
 MULCOPPAR="1"
Endif
Call SETPARAM ("mulcoprint",[L]NBPAR,[L]PARAMETRE,MULCOPPAR) From ETAT

If MULCOPPAR="2"

 #reset the printer copies to 1
 Local Char WPARAM1(2)
 WPARAM1 = chr$(1)+"1"
 Call SETPARAM ("_PrinterCopies",[L]NBPAR,[L]PARAMETRE,WPARAM1) From ETAT

Endif

Return
#########################################################################
#########################################################################
$ALIM_ETAT

Local Integer MAXSOC : MAXSOC = 1000
Local Integer NBSOC, NBRLEG, I ,K, KNUMLIG
Local Char    TBSOC(GLONCPY)(1..MAXSOC)
Local Char    PARAM(50)
Local Char    TABLEG(GLONADI)(1..GNBSOC)
Local Char    LEGCPY(GLONADI)
Local Char    MULCOPPAR(1)
Local Integer INBCOP, LNBCOP

If clalev([F:ARM])=0   : Local File AREPORTM   [ARM]   : Endif
If clalev([F:CPY])=0   : Local File COMPANY    [CPY]   : Endif
If clalev([SIT])=0     : Local File BPCINVVAT  [SIT]   : Endif
If clalev([TRA])=0     : Local File TABRATVAT  [TRA]   : Endif
If clalev([TVT])=0     : Local File TABVAT     [TVT]   : Endif
If clalev([TVB])=0     : Local File TABVACBPR  [TVB]   : Endif
If clalev([TDA])=0     : Local File TABDEPAGIO [TDA]   : Endif
If clalev([F:TARPT])=0 : Local File TMPARPT    [TARPT] : Endif

NBSOC = 1
TBSOC(1) = [F:SIH]CPY

Call LEGCPY(TBSOC,NBRLEG,TABLEG) From CPTDIV

If [L]WADXLOG=0
  Call DEBTRANS From GLOCK
  Trbegin [SIT], [ARM], [SIV], [SIH]
Endif

Raz [F:ARM]
[F:ARM]NUMREQ = REQUETE
[F:ARM]USR    = GUSER
[F:ARM]RPTCOD = ETAT
[F:ARM]NUMLIG = LIGNE
[F:ARM]SEQREQ = SEQUENCE
[F:ARM]CLEA1  = [F:SIH]NUM
[F:ARM]CREDAT = date$

Gosub ALIM_ARM
K = KNUMLIG

Gosub TRT_TAM
If GOK = 0
  If [L]WADXLOG=0 : Rollback : Endif
  Return
Endif

Gosub TRT_TVB
If GOK = 0
  If [L]WADXLOG=0 : Rollback : Endif
  Return
Endif

Gosub TRT_TDA
If GOK = 0
  If [L]WADXLOG=0 : Rollback : Endif
  Return
Endif

Delete [SIT] Where NUM=[F:SIH]NUM
If fstat=1 | fstat>5
  GOK = 0
  Call RSTA("SIT","") From GLOCK
  If [L]WADXLOG=0 : Rollback : Endif
  Return
Endif

[L]LEGCPY = TABLEG(1)

#Gosub MULCOP

Raz CODE, TAUX , TEX, K

For I=0 To dim([F:SIH]TAX)-1
  OK=1
  Call LEC_TVT_LEG([L]LEGCPY,[F:SIH]TAX(I)) From CPTLEC
  # Cas particulier société ??
  Filter [TRA] Where CPY=[F:SIH]CPY & VAT=[F:SIH]TAX(I) & STRDAT<=[F:SIH]ACCDAT & LEG=[F:TVT]LEG
  Read [TRA]TRA0 Last
  If fstat>2
    # sinon on se rabat sur le code dossier
    Filter [TRA] Where CPY="" & VAT=[F:SIH]TAX(I) & STRDAT<=[F:SIH]ACCDAT & LEG=[F:TVT]LEG
    Read [TRA]TRA0 Last
    If fstat>2 : Break : Endif
  Endif
  J=find([F:TRA]VAT,CODE(0..dim([F:SIH]TAX)-1))
  If !J
    CODE(I)=[F:TRA]VAT
    TAUX(I)=[F:TRA]VATRAT
    Call LECTEXTRA(TEX(K),"TABVAT","TEXAXX",[F:TVT]VAT,[F:TVT]LEG) From ATEXTRA
    If len(TEX(K))<>0
      K +=1
    Endif
  Endif
Next
Filter [TRA]

Raz [F:SIT]

If [F:SIH]STARPT<>2 : # Facture définitive non imprimée=>Maj STARPT + Pas de duplicata possible
  Case func AFNC.PARAM("SIVCFM",[F:SIH]FCY)
    When "1" : #Non
      [F:SIH]STARPT = 2
      [F:SIT]DOC    = 1 : #Définitive
    When "2" : #Oui
      [F:SIH]STARPT = 2
      [F:SIT]DOC    = 1 : #Définitive
    When "3" : #Oui après validation
      If [F:SIH]STA=3 : #Facture validée
        [F:SIH]STARPT = 2
        [F:SIT]DOC    = 1 : #Facture Définitive
      Else
        [F:SIT]DOC    = 3 : #Facture Provisoire
      Endif
  Endcase
Endif

[F:SIT]NUM  = [F:SIH]NUM

For I=0 To dim([F:SIH]TAX)-1
  [F:SIT]CODE(I) = CODE(I)
  [F:SIT]TAUX(I) = TAUX(I)
  [F:SIT]TEX(I)  = TEX(I)
Next

Write [SIT]
If fstat
  GOK=0
  Call FSTA("SIT") From GLOCK
  If [L]WADXLOG=0
    Rollback
  Endif
  Return
Endif

Rewrite [SIH]
If fstat
  GOK=0
  Call FSTA("SIH") From GLOCK
  If [L]WADXLOG=0
    Rollback
  Endif
  Return
Endif

Gosub FILL_BVRREFNUM_INVTOTAL_PAYBAN From SWILIB0

If GOK=0 : Return : Endif
If func AFNC.ACTIV("KPO")
  Gosub ALIM_TARPT
  If GOK=0 : Return : Endif
Endif

Commit

Return
#########################################################################
#########################################################################
$TRT_TAM

Raz [F:ARM]
For I=1 To NBRLEG
  Filter [TAM] Where LEG=[L]TABLEG(I) | LEG="" Order By Key CLE=PAM Asc ; LEG Desc
  For [TAM]CLE(1)
    K += 1
    [F:ARM]RPTCOD = ETAT
    [F:ARM]USR    = GUSER
    [F:ARM]NUMREQ = REQUETE
    [F:ARM]NUMLIG = K
    [F:ARM]CLEA1 = [F:TAM]PAM
    [F:ARM]CLEA2 = [F:TAM]LEG
    [F:ARM]CLEA3 = [L]TABLEG(I)
    [F:ARM]CLEA4 = "TABPAM"
    Write [F:ARM]
    If fstat
      GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
    Endif
  Next
Next
Filter [TAM]

Return
#########################################################################
#########################################################################
$TRT_TVB

Raz [F:ARM]
# K = 0 A ne pas faire !
For I=1 To NBRLEG
  Filter [TVB] Where LEG=[L]TABLEG(I) | LEG="" Order By Key CLE=VACBPR Asc ; LEG Desc
  For [TVB]CLE(1)
    K += 1
    [F:ARM]RPTCOD = ETAT
    [F:ARM]USR    = GUSER
    [F:ARM]NUMREQ = REQUETE
    [F:ARM]NUMLIG = K
    [F:ARM]CLEA1 = [F:TVB]VACBPR
    [F:ARM]CLEA2 = [F:TVB]LEG
    [F:ARM]CLEA3 = [L]TABLEG(I)
    [F:ARM]CLEA4 = "TABVACBPR"
    Write [F:ARM]
    If fstat
      GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
    Endif
  Next
Next
Filter [TVB]

Return
#########################################################################
#########################################################################
$TRT_TDA

Raz [F:ARM]
# K = 0 A ne pas faire !
For I=1 To NBRLEG
  Filter [TDA] Where LEG=[L]TABLEG(I) | LEG="" Order By Key CLE=DEP Asc ; LEG Desc
  For [TDA]CLE(1)
    K += 1
    [F:ARM]RPTCOD = ETAT
    [F:ARM]USR    = GUSER
    [F:ARM]NUMREQ = REQUETE
    [F:ARM]NUMLIG = K
    [F:ARM]CLEA1 = [F:TDA]DEP
    [F:ARM]CLEA2 = [F:TDA]LEG
    [F:ARM]CLEA3 = [L]TABLEG(I)
    [F:ARM]CLEA4 = "TABDEPAGIO"
    Write [F:ARM]
    If fstat
      GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
    Endif
  Next
  # If the invoice doesn't have an early discount, we have to create an empty record
  # in order that the link with the AREPORT table works in Crystal report
  K += 1
  [F:ARM]RPTCOD = ETAT
  [F:ARM]USR    = GUSER
  [F:ARM]NUMREQ = REQUETE
  [F:ARM]NUMLIG = K
  [F:ARM]CLEA1 = ""
  [F:ARM]CLEA2 = ""
  [F:ARM]CLEA3 = [L]TABLEG(I)
  [F:ARM]CLEA4 = "TABDEPAGIO"
  Write [F:ARM]
  If fstat
    GOK = 0 : Call FSTA("ARM") From GLOCK : Break
  Endif
Next
Filter [TDA]

Return
#########################################################################
#########################################################################

