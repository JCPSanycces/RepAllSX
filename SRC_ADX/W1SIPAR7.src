#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIPAR7 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:28"
A_USER  = "DOC"
A_STAMP = "20181109230628"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask SIPAR7 [SIP7]
Gosub HORODAT
Local Inpbox "SIPAR7" From GFONCTION At A_STAMP With A_WINDPREV Mask [SIP7] As [SIM_]
Grizo [SIP7]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [SIP7]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=116 : Y1(0)=1 : Y2(0)=17
Return

$ON_OPTDEV
Onevent CONTROL Call C_OPTDEV(zc) From W1SIPAR7
Onevent INIT_AREA Call D_OPTDEV(zc) From W1SIPAR7
Onevent BEFORE_INPUT Call AS_OPTDEV(zc) From W1SIPAR7
Return

Subprog D_OPTDEV(VALEUR)
Variable Integer VALEUR
If varinit([M]OPTDEV,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_OPTDEV(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_OPTDEV(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_OPTDEV(VALEUR) From SUBSIP
If mkstat : GERR = 1 : GZONE = "OPTDEV" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_OPTMULDEV
Onevent INIT_AREA Call D_OPTMULDEV(zc) From W1SIPAR7
Onevent BEFORE_INPUT Call AS_OPTMULDEV(zc) From W1SIPAR7
Return

Subprog D_OPTMULDEV(VALEUR)
Variable Integer VALEUR
If varinit([M]OPTMULDEV,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_OPTMULDEV(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_AMTDIF
Onevent BEFORE_AREA Gosub AV_AMTDIF From W1SIPAR7
Onevent INIT_AREA Call D_AMTDIF(zc) From W1SIPAR7
Return

$AV_AMTDIF
## Action INIDEV
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M]CURCPY,GDEVISE(1..GNBDEV)),1))
Chgfmt [M]AMTDIF(indice) With "Nz3:"+GDEVFMT
Gosub _AFF
Return

Subprog D_AMTDIF(VALEUR)
Variable Decimal VALEUR
If varinit([M]AMTDIF,indice)=0
 VALEUR = 0
Endif
Gosub _AFF
End

$ON_CURCPY
Return

$ON_OPTDIF
Onevent INIT_AREA Call D_OPTDIF(zc) From W1SIPAR7
Onevent BEFORE_INPUT Call AS_OPTDIF(zc) From W1SIPAR7
Return

Subprog D_OPTDIF(VALEUR)
Variable Integer VALEUR
If varinit([M]OPTDIF,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_OPTDIF(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_ACCRNDDEB
Onevent BEFORE_AREA Gosub AV_ACCRNDDEB From W1SIPAR7
Onevent CONTROL Call C_ACCRNDDEB(zc) From W1SIPAR7
Onevent BEFORE_INPUT Call AS_ACCRNDDEB(zc) From W1SIPAR7
Onevent AFTER_CHANGE Gosub AMM_ACCRNDDEB From W1SIPAR7
Return

$AV_ACCRNDDEB
## Action INIACCFMT
Call INIACCFMT(num$([M:SIP5]COA)) From SETGLBCOA
If GFMTACC<>""
 Chgfmt [M]ACCRNDDEB(indice) With "K:"+GFMTACC
Else
 Chgfmt [M]ACCRNDDEB(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog AS_ACCRNDDEB(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6127,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_ACCRNDDEB(zc) From W1SIPAR7
Onkey   2 Titled GBOUTS Call S_ACCRNDDEB(zc) From W1SIPAR7
Onkey 144 Titled GBOUTP Call P_ACCRNDDEB(zc) From W1SIPAR7
Onkey 146 Titled GBOUTA Call SA_ACCRNDDEB(zc) From W1SIPAR7
Gosub _AFF
End

Subprog C_ACCRNDDEB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action GACCHOICE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GACCHOICE"
 PARMSK(1) = num$([M:SIP5]COA)
 Call S_TAB_CHAR(VALEUR,PARMSK,"GACCHOICE","TRTSEL","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ACCRNDDEB" : GZNUM = 32449 : Endif
Endif
If !GWEBSERV
 If !mkstat
  ## Action CONTCPT
  Call CONTCPT(VALEUR,num$([M:SIP5]COA)) From CPTSUB
  If mkstat : GERR = 1 : GZONE = "ACCRNDDEB" : GZNUM = 32449 : Endif
 Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("GAC","!G",VALEUR,num$([M:SIP5]COA),mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ACCRNDDEB" : GZNUM = 32449 : Endif
Endif
Gosub _AFF
End

$AMM_ACCRNDDEB
Call AM_ACCRNDDEB(zc)
If !mkstat & GOBJET
 zoncou = "ACCRNDDEB" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ACCRNDDEB(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZACCRNDDEB)")>indice
 [M]ACCRNDDEB(indice) = VALEUR
 Affzo ZACCRNDDEB(indice)
Endif
Gosub _AFF
End

Subprog S_ACCRNDDEB(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "GAC"
PARMSK(2) = "!G"
PARMSK(3) = num$([M:SIP5]COA)
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_ACCRNDDEB(VALEUR)
Variable Char    VALEUR()
Call OBJET("GAC",VALEUR,num$([M:SIP5]COA)) From GOBJET
Gosub _AFF
End

Subprog SA_ACCRNDDEB(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "GAC"
PARMSK(2) = num$([M:SIP5]COA)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ACCRNDDEB(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$([M:SIP5]COA)
Call VISU("GAC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZACCRNDDEB
Onevent BEFORE_AREA Gosub AV_ZACCRNDDEB From W1SIPAR7
Return

$AV_ZACCRNDDEB
Call LECTEXTRA(zc,"GACCOUNT","DESTRA",num$([M:SIP5]COA),num$([M]ACCRNDDEB(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_ACCRNDCDT
Onevent BEFORE_AREA Gosub AV_ACCRNDCDT From W1SIPAR7
Onevent CONTROL Call C_ACCRNDCDT(zc) From W1SIPAR7
