Subprog AS_ACCRNDCDT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6127,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_ACCRNDCDT(zc) From W1SIPAR7
Onkey   2 Titled GBOUTS Call S_ACCRNDCDT(zc) From W1SIPAR7
Onkey 144 Titled GBOUTP Call P_ACCRNDCDT(zc) From W1SIPAR7
Onkey 146 Titled GBOUTA Call SA_ACCRNDCDT(zc) From W1SIPAR7
Gosub _AFF
End

Subprog C_ACCRNDCDT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action GACCHOICE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GACCHOICE"
 PARMSK(1) = num$([M:SIP5]COA)
 Call S_TAB_CHAR(VALEUR,PARMSK,"GACCHOICE","TRTSEL","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ACCRNDCDT" : GZNUM = 32448 : Endif
Endif
If !GWEBSERV
 If !mkstat
  ## Action CONTCPT
  Call CONTCPT(VALEUR,num$([M:SIP5]COA)) From CPTSUB
  If mkstat : GERR = 1 : GZONE = "ACCRNDCDT" : GZNUM = 32448 : Endif
 Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("GAC","!G",VALEUR,num$([M:SIP5]COA),mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ACCRNDCDT" : GZNUM = 32448 : Endif
Endif
Gosub _AFF
End

$AMM_ACCRNDCDT
Call AM_ACCRNDCDT(zc)
If !mkstat & GOBJET
 zoncou = "ACCRNDCDT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ACCRNDCDT(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZACCRNDCDT)")>indice
 [M]ACCRNDCDT(indice) = VALEUR
 Affzo ZACCRNDCDT(indice)
Endif
Gosub _AFF
