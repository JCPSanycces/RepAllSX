#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM006
# Issue X3-8078/120078 - 2016-11-29 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM006(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM006(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NI
Local Integer NE
Local Integer NCOUNTOK
Local Integer NCOUNTERROR

  IERR = 0
  Call ECR_TRACE("UTIPJM006: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table PJMTIMEMP
  #
  If filinfo(filpath("FIL", "PJMSOLITMD", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PJMSOLITMD" [PSOD]
  Local File =SZAPPLI + ".SQUOTED" [SQD]
  Local File =SZAPPLI + ".SORDERQ" [SOQ]
  Local File =SZAPPLI + ".SINVOICED" [SID]
  # -------------------------
  If dim([F:SQD]SQDPSONUM) > 0 and dim([F:SOQ]SOQPSONUM) > 0 and  dim([F:SID]SIDPSONUM) > 0 Then
    Trbegin [PSOD]
    NCOUNT = 0
    NCOUNTERROR = 0
    Call ECR_TRACE("UTIPJM006: Updating SQUOTED/SORDERQ/SINVOICED", 0) From GESECRAN
    Filter [PSOD] Where [F:PSOD]DOCNUM <> ""
    For [PSOD]PSOD0
      # -----------------------------
      Case [F:PSOD]DOCTYP
        When 1
          # Quotes
          Filter [SQD] Where [F:SQD]SQDPSONUM = "" and [F:SQD]SQDSEQNUM = 0 and [F:SQD]SQHNUM = [F:PSOD]DOCNUM and [F:SQD]ITMREF = [F:PSOD]ITMREF
          For [SQD]SQD0
            [F:SQD]SQDPSONUM = [F:PSOD]PSONUM
            [F:SQD]SQDSEQNUM = [F:PSOD]SEQNUM
            NCOUNT += 1
            Rewrite [SQD]
            If fstat Then
              Call ECR_TRACE("File SQUOTED" - [F:SQD]SQHNUM - num$([F:SQD]SQDLIN) + ", Error =" - num$(fstat), 1) From GESECRAN
              GOK = 1
              IERR = 1
              NCOUNTERROR += 1
            Endif
            Break
          Next
          Filter [SQD]
        When 2
          # Sales orders
          Filter [SOQ] Where [F:SOQ]SOQPSONUM = "" and [F:SOQ]SOQSEQNUM = 0 and [F:SOQ]SOHNUM = [F:PSOD]DOCNUM and [F:SOQ]ITMREF = [F:PSOD]ITMREF
          For [SOQ]SOQ0
            [F:SOQ]SOQPSONUM = [F:PSOD]PSONUM
            [F:SOQ]SOQSEQNUM = [F:PSOD]SEQNUM
            NCOUNT += 1
            Rewrite [SOQ]
            If fstat Then
              Call ECR_TRACE("File SORDERQ" - [F:SOQ]SOHNUM - num$([F:SOQ]SOPLIN) - num$([F:SOQ]SOQSEQ) + ", Error =" - num$(fstat), 1) From GESECRAN
              GOK = 1
              IERR = 1
              NCOUNTERROR += 1
            Endif
            Break
          Next
          Filter [SOQ]
        When 3
          # Sales invoices
          Filter [SID] Where [F:SID]SIDPSONUM = "" and [F:SID]SIDSEQNUM = 0 and [F:SID]NUM = [F:PSOD]DOCNUM and [F:SID]ITMREF = [F:PSOD]ITMREF
          For [SID]SID0
            [F:SID]SIDPSONUM = [F:PSOD]PSONUM
            [F:SID]SIDSEQNUM = [F:PSOD]SEQNUM
            NCOUNT += 1
            Rewrite [SID]
            If fstat Then
              Call ECR_TRACE("File SINVOICED" - [F:SID]NUM - num$([F:SID]SIDLIN) + ", Error =" - num$(fstat), 1) From GESECRAN
              GOK = 1
              IERR = 1
              NCOUNTERROR += 1
            Endif
            Break
          Next
          Filter [SID]
      Endcase
      # -----------------------------
    Next
    Filter [PSOD]
    # -------------------------
    If NCOUNTERROR = 0 Then
      Call ECR_TRACE("UTIPJM006: SQUOTED/SORDERQ/SINVOICED" - num$(NCOUNT) - "updated.", 0) From GESECRAN
    Else
      Call ECR_TRACE("UTIPJM006: SQUOTED/SORDERQ/SINVOICED" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
    Endif
    # -----------
    If IERR = 0 Then
      Commit
      Call ECR_TRACE("UTIPJM006 : records processed without error.", 0) From GESECRAN
    Else
      Rollback
      Call ECR_TRACE("UTIPJM006 : records processed with error(s).", 0) From GESECRAN
    Endif
    # -------------------------
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIPJM006(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  Call MAJ_UTIPJM006(APPLI)
End

