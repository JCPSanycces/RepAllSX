#<AdxTL>@(#)2.0.0.0 $Revision$

Local Char PARAM(10)(1..2) , VALEUR(10)
PARAM(2) = "ATABLE"
Call TRAITE_CHAR(VALEUR,PARAM,"","ASHWSELZON","ASHWSELZON",3,"") From GTRAITE
End


#------------------------------#
$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
 When "SORTIE"  : If SAVNOLI<> NOLI : mkstat = 4 : Endif
Endcase
Return

#------------------------------#
$INIT
Global Integer GENTERFCT : GENTERFCT = 0
Local Integer NOLI,SAVNOLI
Local Char WBLC(20)
Local Integer WORD
NOLI = nolign-1
SAVNOLI = NOLI
If !clalev([ACLA])  : Local File ACLASSE [ACLA] : Endif
If !clalev([ACLAF]) : Local File ACLAFLD [ACLAF] : Endif
Local Mask ASHWSELZON [DIA]
Raz [M:DIA]
If NOLI=0 & [M:ASW4]ALIAS(NOLI)<>""
 WBLC = [M:ASW4]BLCPRO(NOLI)
 WORD = [M:ASW4]ORDPRO(NOLI)
Elsif NOLI>0 & [M:ASW4]ALIAS(NOLI-1)<>""
 WBLC = [M:ASW4]BLCPRO(NOLI-1)
 WORD = [M:ASW4]ORDPRO(NOLI-1)
Else
 If [M:ASW2]SECBLC(0)="" or [M:ASW2]CODBLC(0)=""
  Call ERREUR(mess(144,123,1)) From GESECRAN
  FIN  =1
  Return
 Endif
 WSEC = [M:ASW2]SECBLC(0)
 WBLC = [M:ASW2]CODBLC(0)
Endif
Gosub LOAD_PATH

Raz NBPTH
[M]REPPTH(NBPTH) = [M:ASW0]CODREP
[M]CLAPTH(NBPTH) = ""
[M]ORIPTH(NBPTH) = ""
[M]NBPTH +=1
For I=1 To NBCHE
 [M]REPPTH(NBPTH) = [M:ASW0]CODREP
 [M]CLAPTH(NBPTH) = CHECLA(I)
 [M]ORIPTH(NBPTH) = CHEMIN(I)
 [M]NBPTH +=1
Next
Return
If PARAM(1)<>""
 Read [ACLA]ACLA0= PARAM(1)
 If !fstat
  [M:DIA]ORICLA = [F:ACLA]CODCLA
  [M:DIA]CLA = [M:ASW1]ABRCLA
  Call AM_ORICLA ([M:DIA]ORICLA)
 Endif
Endif
Return

#------------------------------#
$EXEC
Local Integer OKFLD , NUMTEX
Local Char    TEXTE(80) , CHAMP(250) , WCHAMP(250) , WALIAS(250), CHAINE(250),MESSERR(250)
Gosub CHARGE
Return

#------------------------------#
$CHARGE
Local Integer I,WI,J
For I=0 To [M:DIA]NBLIG-1
 If [M:DIA]SELECT(I)=2
  If [M:DIA]CLA<>""
   CHAMP = [M:DIA]CLA+"."+[M:DIA]FLDCLA(I)
   If !find(right$(CHAMP,len([M]CLA)+2),[ASW4]ALIAS(0..[M:ASW4]NBRPRO-1)) & !find(CHAMP,[ASW4]CODPRO(0..[M:ASW4]NBRPRO-1))
    WALIAS = right$(CHAMP,len([M]CLA)+2)
    WCHAMP = CHAMP
    Gosub ADD_FIELDS
   Elsif !find(CHAMP,[ASW4]CODPRO(0..[M:ASW4]NBRPRO-1))
    Raz WALIAS
    CHAINE = CHAMP
    WI = instr(1,CHAINE,".")
    While WI>0
     WALIAS += left$(CHAINE,instr(1,CHAINE,".")-1)+"_"
     CHAINE = right$(CHAINE,instr(1,CHAINE,".")+1)
     WI = instr(1,CHAINE,".")
    Wend
    WALIAS += CHAINE
    WCHAMP = CHAMP
    Gosub ADD_FIELDS
   Endif
  Else
   WCHAMP = [M:DIA]FLDCLA(I)
   If !find(WCHAMP,[ASW4]CODPRO(0..[M:ASW4]NBRPRO-1)) & !find(WCHAMP,[ASW4]ALIAS(0..[M:ASW4]NBRPRO-1))
    WALIAS = WCHAMP
    Gosub ADD_FIELDS_REP
   Elsif !find(WCHAMP,[ASW4]CODPRO(0..[M:ASW4]NBRPRO-1))
    Raz WALIAS
    For WI=2 To 100
     If find(WCHAMP+num$(WI),[ASW4]ALIAS(0..[M:ASW4]NBRPRO-1))=0
      Break
     Endif
    Next
    If WI<100
     WALIAS = WCHAMP+num$(WI)
     Gosub ADD_FIELDS_REP
    Endif
   Endif
  Endif
 Endif
Next
Affzo [ASW1] : #109787
Affzo [ASW4]
[M:ASW4]STALIN(SAVNOLI)=1 : #109787
Gosub MAJ_STDLNK_FCT_2 From SUBASW
[M:ASW4]STALIN(SAVNOLI)=0
Return


$ADD_FIELDS_REP
M = find(WCHAMP,[ASW9]CODFLD(0..[M:ASW9]NBRFLD-1))
Insa  NOLI,1,[M:ASW4]NBRPRO [M:ASW4]NBRPRO
J = NOLI
NOLI += 1
[M:ASW4]NBRPRO += 1
[M:ASW4]ALIAS(J)    = WALIAS
If [M:ASW9]FLDGRP(M-1)<>""
 WCHAMP = [M:ASW9]FLDGRP(M-1)+"."+WCHAMP
Endif
[M:ASW4]CODPRO(J)   = WCHAMP
Call CONTROLE_CODPRO(1,[M:ASW4]CODPRO(J),J,0,0,MESSERR ) From SUBASW2
[M:ASW4]INTPRO(J)   = [M:ASW9]INTFLD(M-1)
[M:ASW4]AZINTPRO(J) = [M:ASW9]AZINTFLD(M-1)
[M:ASW4]INTSHTPRO(J)   = [M:ASW9]INTSHTFLD(M-1)
[M:ASW4]AZINTSHTPRO(J) = [M:ASW9]AZINTSHTFLD(M-1)
[M:ASW4]ACTPRO(J) = [M:ASW9]ACTFLD(M-1):#94200
[M:ASW4]BLCPRO(J)   = WBLC
If J>0
 [M:ASW4]ORDPRO(J)   = [M:ASW4]ORDPRO(J-1)+10
Else
 [M:ASW4]ORDPRO(J)   = 10
Endif
#
#109787 [M:ASW4]STALIN(J)=1
# refresh "Collection"
[M:ASW4]FLDGRPPRO(J) =  func SUBASW_TOOL.GET_COL_FROM_PRO_PATH_SCREEN([M:ASW4]CODPRO(J),1)
Gosub ADD_DEFAULT
Return

$ADD_FIELDS
Read [ACLAF]ACLAF0 = [M:DIA]ORICLA;[M:DIA]FLDCLA(I)
If !fstat
 Insa  NOLI,1,[M:ASW4]NBRPRO [M:ASW4]NBRPRO
 J = NOLI
 NOLI += 1
 [M:ASW4]NBRPRO += 1
 [M:ASW4]ALIAS(J)    = WALIAS
 If [ACLAF]FLDGRP<>""
   [M:ASW4]CODPRO(J)  = left$(WCHAMP,len(WCHAMP)-len([M:DIA]FLDCLA(I)))+[ACLAF]FLDGRP+"."+[M:DIA]FLDCLA(I)
 Else
  [M:ASW4]CODPRO(J)   = WCHAMP
 Endif
 Call CONTROLE_CODPRO(1,[M:ASW4]CODPRO(J),J,0,0,MESSERR ) From SUBASW2
 Call TEXTE([F:ACLAF]INTFLD,TEXTE) From OBJDIV
 [M:ASW4]INTPRO(J)   = [F:ACLAF]INTFLD
 [M:ASW4]AZINTPRO(J) = TEXTE
 Call TEXTE([F:ACLAF]INTSHTFLD,TEXTE) From OBJDIV
 [M:ASW4]INTSHTPRO(J)   = [F:ACLAF]INTSHTFLD
 [M:ASW4]AZINTSHTPRO(J) = TEXTE
 [M:ASW4]ACTPRO(J) = [F:ACLAF]ACTFLD:#94200
 [M:ASW4]BLCPRO(J)   = WBLC
 If J>0
  [M:ASW4]ORDPRO(J)   = [M:ASW4]ORDPRO(J-1)+10
 Else
  [M:ASW4]ORDPRO(J)   = 10
 Endif
 #
 #109787 [M:ASW4]STALIN(J)=1
 # refresh "Collection"
 [M:ASW4]FLDGRPPRO(J) =  func SUBASW_TOOL.GET_COL_FROM_PRO_PATH_SCREEN([M:ASW4]CODPRO(J),1)
 Gosub ADD_DEFAULT
Endif
Return

$ADD_DEFAULT
#109787
Local Integer OK
Local Char L_ERR_MSG(250)
If [M:DIA]QRYPRO=2
  If [M:ASW4]FLDGRPPRO(J)<>""
   Call CONTROLE_QRYPRO([M:ASW0]CODREP,[M:ASW4]ALIAS(J),[M:ASW4]CODPRO(J),[M:ASW4]FLDGRPPRO(J),[M:ASW1]CODCLA,[M:ASW1]ABRCLA,OK,L_ERR_MSG) From SUBASW2
   If OK
    [M:ASW4]QRYPRO(J) = 2
   Endif
  Else
   [M:ASW4]QRYPRO(J) = 2
  Endif
Else
[M:ASW4]QRYPRO(J) = [M:DIA]QRYPRO
Endif
[M:ASW4]STAQRYPRO(J) = [M:DIA]STAQRYPRO
[M:ASW4]DETPRO(J) = [M:DIA]DETPRO
[M:ASW4]STADETPRO(J) = [M:DIA]STADETPRO

[M:ASW4]EDIPRO(J) = [M:DIA]EDIPRO
[M:ASW4]STAEDIPRO(J) = [M:DIA]STAEDIPRO
If [M:DIA]TYPAFFPRO=2
  If [M:ASW4]STAEDIPRO(J)=1 & [M:ASW4]EDIPRO(J)=2
   If [M:ASW4]CODPROATY(J)<>""
    Read [ATY]CODTYP=[M:ASW4]CODPROATY(J)
    If !(!fstat & [F:ATY]FMTPROSYR=6)
     [M:ASW4]TYPAFFPRO(J)=2
    Endif
   Else
    [M:ASW4]TYPAFFPRO(J)=2
   Endif
  Endif
Else
[M:ASW4]TYPAFFPRO(J) = [M:DIA]TYPAFFPRO
Endif

If [M:DIA]LOKPRO=2
 If [M:ASW4]FLDGRPPRO(J)<>""
  Call CONTROLE_LOKPRO([M:ASW0]CODREP,[M:ASW4]ALIAS(J),[M:ASW4]CODPRO(J),[M:ASW4]FLDGRPPRO(J),[M:ASW1]CODCLA,[M:ASW1]ABRCLA,OK,L_ERR_MSG) From SUBASW2
  If OK
   [M:ASW4]LOKPRO(J) = 2
  Endif
 Else
  [M:ASW4]LOKPRO(J) = 2
 Endif
Else
[M:ASW4]LOKPRO(J) = [M:DIA]LOKPRO
Endif
[M:ASW4]STALOKPRO(J) = [M:DIA]STALOKPRO
[M:ASW4]SUMPRO(J) = [M:DIA]SUMPRO
[M:ASW4]STASUMPRO(J) = [M:DIA]STASUMPRO

If find(2,[M:ASW4]QRYPRO)=0 :# Query
 [M:ASW1]ENAFAC(2)=1
Else
 [M:ASW1]ENAFAC(2)=2
Endif
If find(2,[M:ASW4]DETPRO)=0 : # detail
 [M:ASW1]ENAFAC(0)=1
Else
 [M:ASW1]ENAFAC(0)=2
Endif
If find(2,[M:ASW4]EDIPRO)=0 : # Edit
 [M:ASW1]ENAFAC(1)=1
Else
 [M:ASW1]ENAFAC(1)=2
Endif
If find(2,[M:ASW4]LOKPRO)=0 : # lookup
 [M:ASW1]ENAFAC(3)=1
Else
 [M:ASW1]ENAFAC(3)=2
Endif
If find(2,[M:ASW4]SUMPRO)=0 : # Summary
 [M:ASW1]ENAFAC(4)=1
Else
 [M:ASW1]ENAFAC(4)=2
Endif
Return


#------------------------------#
# Etiquettes Ecrans
#------------------------------#

Subprog IB_NBLIG
GBOUT2 = mess(202,124,1) : # Oui à tout le reste
GBOUT3 = mess(203,124,1) : # Non à tout le reste
GBOUT4 = mess(229,124,1) : # Non à toutes les propriétés systèmes
End

Subprog B2_NBLIG
Local Integer I
For I=nolign To [M]NBLIG
 [M]SELECT(I-1) = 2
Next I
Affzo 15
End

Subprog B3_NBLIG
Local Integer I
For I=nolign To [M]NBLIG
 [M]SELECT(I-1) = 1
Next I
Affzo 15
End

Subprog B4_NBLIG
Gosub SET_FLDSYS From SUBATB
For I=nolign To [M]NBLIG
 If find([M]FLDCLA(I-1), FLDSYS)
  [M]SELECT(I-1) = 1
 Endif
Next I
Affzo 15
End

Subprog AS_ORICLA(VALEUR)
Variable Char    VALEUR()
If ![V]GENTERFCT : [V]GENTERFCT = 1 : End : Endif
Call S_ORICLA(VALEUR)
End

Subprog C_ORICLA(VALEUR)
Variable Char    VALEUR()
zonsui = "[M:DIA]SELECT(1)"
End

Subprog AM_ORICLA(VALEUR)
Variable Char    VALEUR()
End


Subprog S_ORICLA(VALEUR)
Variable Char    VALEUR()
End


$LOAD_PATH
If !clalev([ACLA])  : Local File ACLASSE [ACLA] : Endif
If !clalev([ACLAF]) : Local File ACLAFLD [ACLAF] : Endif

Local Char CHEMIN(250)(1..500)
Local Char CHECLA(250)(1..500)
Local Integer NBCHE
Local Integer NIVEAU(1..16)

NBCHE+=1
CHEMIN(NBCHE) = [M:ASW1]ABRCLA
CHECLA(NBCHE) = [M:ASW1]CODCLA
For [ACLAF] Where CODCLA=[M:ASW1]CODCLA& find(CODTYP,"")
 NBCHE+=1
 CHEMIN(NBCHE) = [M:ASW1]ABRCLA+"."+[ACLAF]FLDCLA
 CHECLA(NBCHE) = [ACLAF]LNKCLA
Next

NIVEAU(1) = NBCHE+1
For I=2 To NBCHE
 For [ACLAF] Where CODCLA=CHECLA(I) & find(CODTYP,"")
  NBCHE+=1
  CHEMIN(NBCHE) = CHEMIN(I)+"."+[ACLAF]FLDCLA
  CHECLA(NBCHE) = [ACLAF]LNKCLA
 Next
Next

NIVEAU(2) = NBCHE+1
For I=NIVEAU(1)To NBCHE
 For [ACLAF] Where CODCLA=CHECLA(I) & find(CODTYP,"")
  NBCHE+=1
  CHEMIN(NBCHE) = CHEMIN(I)+"."+[ACLAF]FLDCLA
  CHECLA(NBCHE) = [ACLAF]LNKCLA
 Next
Next

NIVEAU(3) = NBCHE+1
For I=NIVEAU(2)To NBCHE
 For [ACLAF] Where CODCLA=CHECLA(I) & find(CODTYP,"")
  NBCHE+=1
  CHEMIN(NBCHE) = CHEMIN(I)+"."+[ACLAF]FLDCLA
  CHECLA(NBCHE) = [ACLAF]LNKCLA
 Next
Next

NIVEAU(4) = NBCHE+1
For I=NIVEAU(3)To NBCHE
 For [ACLAF] Where CODCLA=CHECLA(I) & find(CODTYP,"")
  NBCHE+=1
  CHEMIN(NBCHE) = CHEMIN(I)+"."+[ACLAF]FLDCLA
  CHECLA(NBCHE) = [ACLAF]LNKCLA
 Next
Next

NIVEAU(5) = NBCHE+1
For I=NIVEAU(4)To NBCHE
 For [ACLAF] Where CODCLA=CHECLA(I) & find(CODTYP,"")
  NBCHE+=1
  CHEMIN(NBCHE) = CHEMIN(I)+"."+[ACLAF]FLDCLA
  CHECLA(NBCHE) = [ACLAF]LNKCLA
 Next
Next

NIVEAU(6) = NBCHE+1
For I=NIVEAU(5)To NBCHE
 For [ACLAF] Where CODCLA=CHECLA(I) & find(CODTYP,"")
  NBCHE+=1
  CHEMIN(NBCHE) = CHEMIN(I)+"."+[ACLAF]FLDCLA
  CHECLA(NBCHE) = [ACLAF]LNKCLA
 Next
Next

NIVEAU(7) = NBCHE+1
For I=NIVEAU(6)To NBCHE
 For [ACLAF] Where CODCLA=CHECLA(I) & find(CODTYP,"")
  NBCHE+=1
  CHEMIN(NBCHE) = CHEMIN(I)+"."+[ACLAF]FLDCLA
  CHECLA(NBCHE) = [ACLAF]LNKCLA
 Next
Next

NIVEAU(8) = NBCHE+1
For I=NIVEAU(7)To NBCHE
 For [ACLAF] Where CODCLA=CHECLA(I) & find(CODTYP,"")
  NBCHE+=1
  CHEMIN(NBCHE) = CHEMIN(I)+"."+[ACLAF]FLDCLA
  CHECLA(NBCHE) = [ACLAF]LNKCLA
 Next
Next

NIVEAU(9) = NBCHE+1
For I=NIVEAU(8)To NBCHE
 For [ACLAF] Where CODCLA=CHECLA(I) & find(CODTYP,"")
  NBCHE+=1
  CHEMIN(NBCHE) = CHEMIN(I)+"."+[ACLAF]FLDCLA
  CHECLA(NBCHE) = [ACLAF]LNKCLA
 Next
Next
Return




######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran ASHWSELZON) 13/12/2012 11:25:26 (CCL)
######################################################################################
Subprog AS_NBPTH
If REPPTH(nolign-1) = "" : End : Endif
Local Integer OK,NOL
Local Char WFLD(80)
Effzo 15
NOL = nolign-1
nolign = 0
Gosub SET_FLDSYS From SUBATB

If [M]CLAPTH(NOL)<>""
 For [ACLAF]ACLAF1 Where CODCLA=[M]CLAPTH(NOL) & LNKCLA=""
  WFLD = [M]ORIPTH(NOL)+"."
  If [ACLAF]FLDGRP<>""
   WFLD += [ACLAF]FLDGRP+"."
  Endif
  WFLD += [ACLAF]FLDCLA
  If !find(WFLD,[M:ASW4]CODPRO(0..[M:ASW4]NBRPRO-1))
   nolign += 1
   [M] = [F:ACLAF]
   Call TEXTE([F:ACLAF]INTFLD,[M]INTIT(nolign-1)) From OBJDIV
   Call TEXTE([F:ACLAF]INTSHTFLD,[M]INTITSHT(nolign-1)) From OBJDIV
   If !find([ACLAF]FLDCLA,FLDSYS(1..NBFLD)) & !find([ACLAF]FLDCLA,"CREDAT","UPDDAT","EXPNUM")
    [M]SELECT(nolign-1) = 2
   Else
    [M]SELECT(nolign-1) = 1
   Endif
  Endif
 Next
Else
 For I=0 To [M:ASW9]NBRFLD-1
  WFLD = ""
  If [M:ASW9]FLDGRP(I)<>""
   WFLD += [M:ASW9]FLDGRP(I)+"."
  Endif
  WFLD += [M:ASW9]CODFLD(I)
  If !find(WFLD,[M:ASW4]CODPRO(0..[M:ASW4]NBRPRO-1))
  nolign += 1
  [M] = [M:ASW9]
  [M]FLDCLA(nolign-1) = [M:ASW9]CODFLD(I)
  [M]INTIT(nolign-1) = [M:ASW9]AZINTFLD(I)
  [M]INTITSHT(nolign-1) = [M:ASW9]AZINTSHTFLD(I)
  If !find( [M]FLDCLA(nolign-1),FLDSYS(1..NBFLD)) & !find([M]FLDCLA(nolign-1),"CREDAT","UPDDAT","EXPNUM")
   [M]SELECT(nolign-1) = 2
  Else
   [M]SELECT(nolign-1) = 1
  Endif
  Endif
 Next
Endif
[M:DIA]CLA = [M]ORIPTH(NOL)
[M:DIA]ORICLA = [M]CLAPTH(NOL)
[M]NBLIG = nolign

Chgstl [M]NBPTH With ""
Chgstl [M]NBPTH(NOL) With "AMKCUR"

Affzo 15
Affzo [M:DIA]ORICLA
Affzo [M:DIA]CLA
End



######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran ASHWSELZON) 13/12/2012 13:00:42 (CCL)
######################################################################################
Subprog C_NBPTH
If REPPTH(nolign-1)="" : mkstat = 1 : Endif
End


