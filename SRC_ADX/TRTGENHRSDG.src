#60971
$AUCUN
RESULT = 0
Return

###############################################################################
## Décodage des formules
###############################################################################
$DECODE_FORMULE
Raz NFRM,NRUB,NCUM,NVAR,NPAT

For K=1 To [F:HRSDS]NBRCOL
  If [F:HRSDS]TYPAMT(K-1)=9
    EXPR = vireblc(format$("KT:250X",[F:HRSDS]RUBCOD(K-1)),2)
    I = 1
    While I<=len(EXPR)
      OPE = mid$(EXPR,I,2)
      If find(OPE,"R_","V_","C_","F0")
        J = I+2 : I += 2
        While I<len(EXPR) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(EXPR,I+1,1))
          I += 1
        Wend
        CODE = seg$(EXPR,J,I)
        If OPE="R_"
          If mid$(EXPR,I+1,3)="(1)"
            I += 3
          Elsif mid$(EXPR,I+1,3)="(2)"
            OPE = "P_" : I += 3
          Endif
        Endif
        Case OPE
        When "R_"
          L = find(CODE,CRUB(1..NRUB))
          If L=0
          NRUB += 1
          CRUB(NRUB) = CODE
          L = NRUB
          Endif
          REMPL = "RU("+num$(L)+")"
        When "P_"
          L = find(CODE,CPAT(1..NPAT))
          If L=0
          NPAT += 1
          CPAT(NPAT) = CODE
          L = NPAT
          Endif
          REMPL = "PA("+num$(L)+")"
        When "C_"
          L = find(CODE,CCUM(1..NCUM))
          If L=0
          NCUM += 1
          CCUM(NCUM) = CODE
          L = NCUM
          Endif
          REMPL = "CU("+num$(L)+")"
        When "V_"
          L = find(CODE,CVAR(1..NVAR))
          If L=0
          NVAR += 1
          CVAR(NVAR) = CODE
          L = NVAR
          Endif
          REMPL = "VA("+num$(L)+")"
        When "F0"
          REMPL = "MONTP("+CODE+")"
        Endcase
        If (J-3)+len(REMPL)+len(right$(EXPR,I+1))>250
          GERR = 1
#MIPEA - 2018-01-26- US X3-71997- START
          GMESSAGE =  mess(109,10702,1)-":"-[F:HRSDS]RUBCOD(K-1) : # L'évaluation de la formule dépasse les 250 caractères
#          GMESSAGE =  mess(109,702,1)-":"-[F:HRSDS]RUBCOD(K-1) : # L'évaluation de la formule dépasse les 250 caractères
#MIPEA - 2018-01-26- US X3-71997- END
          Break
        Endif
        EXPR = left$(EXPR,J-3)+REMPL+right$(EXPR,I+1)
        I = (J-3)+len(REMPL)
      Endif
      I += 1
    Wend
    NFRM += 1
    FORMULE(NFRM) = EXPR
  Endif
Next K

Return

#=================================================================================
$ELIBCOL
Local Integer I
Local Char    LIBCOL(30)(1..dim([F:HRSDS]DESCOL))

Filter [F:HRSDS] Where COD=[M]MDLDCL
For I=1 To  [F:HRSDS]NBRCOL
  LIBCOL(I)= [F:HRSDS]DESCOL(I-1)
Next
Filter [F:HRSDS]

Return

