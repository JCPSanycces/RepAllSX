######################################################################################
## Section automatically added (screen GENHRSDG0) 09/06/2016 10:51:15 (DEHEN)
######################################################################################
Subprog C_MDLDCL(VALEUR)
Variable Char    VALEUR()
Local Date XDATE1,XDATE2
If VALEUR <> [M]MDLDCL #OLCAU X3-69872 Start #LIPET - X3-80550 - 2018-04-19
  XDATE1 = gdat$(1,1,year(gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))))
  If VALEUR="CIMR" Then
    XDATE2=gdat$(1,month(XDATE1)+2,year(XDATE1))
    [M]ENDDAT=eomonth(XDATE2)
  Elsif VALEUR="9421"
    [M]ENDDAT=gdat$(31,12,year(XDATE1))
  Endif
Endif #OLCAU X3-69872 End
End

