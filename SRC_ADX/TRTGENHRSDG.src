Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
Call AS_ALLCPY(VALEUR) From DIVPAYE
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz [M:HRSDG0]CPY
  Grizo [M:HRSDG0]CPY
Else
  Actzo [M:HRSDG0]CPY
Endif
End

