#<AdxTL>@(#)0.0.0.0 $Revision$
#############################
$ACTION
Case ACTION
When "OUVRE"       : Gosub OUVRE
When "CONTROLE"    : Gosub CONTROLE
When "DEBUT"       : Gosub DEBUT
When "OK"          : Gosub EXEC
#When "OK"         : FIN = 1 : GOK = 1
When "END"         : FIN = 1
Endcase

Return
#When "INIT"        : Gosub OUVRE

#############################
$OUVRE
Global Integer GLONXMA : GLONXMA = 10

Local Mask GENHRSDG0 [HRSDG0]

Raz [M:HRSDG0]

If clalev([F:HSP])=0      : Local File HISTOPAYE    [HSP] : Endif
If clalev([F:VEP])=0      : Local File VALEMP       [VEP] : Endif
If clalev([F:XVLA])=0     : Local File VALEUR       [XVLA] : Endif
If clalev([F:FGR])=0      : Local File FACGROUP     [FGR] : Endif
If clalev([F:CPY])=0      : Local File COMPANY      [CPY] : Endif
If clalev([F:RUB])=0      : Local File RUBRIQUE     [RUB] : Endif
If clalev([F:HRSDS])=0    : Local File HRSTADCLSET  [HRSDS] : Endif
If clalev([F:HREDC])=0    : Local File HREMPDLC     [HREDC] : Endif
If clalev([F:ATB])=0      : Local File ATABLE       [ATB] : Endif
If clalev([F:ATZ])=0      : Local File ATABZON      [ATZ] : Endif
If clalev([F:ATY])=0      : Local File ATYPE        [ATY] : Endif
If clalev([F:ATX])=0      : Local File ATEXTE       [ATX] : Endif
If clalev([F:AXX])=0      : Local File ATEXTRA      [AXX] : Endif
If clalev([F:DIC])=0      : Local File DICOEMP      [DIC] : Endif
If clalev([F:HRPOA])=0      : Local File POPULA       [HRPOA] : Endif
If clalev([F:ACC])=0      : Local File ACCES        [ACC] : Endif
If clalev([F:CUM])=0      : Local File CUMUL        [CUM] : Endif
If clalev([F:ECT])=0      : Local File EMPCTR       [ECT] : Endif
If clalev([F:ID]) =0      : Local File EMPLOID      [ID]  : Endif
If clalev([F:XATB])=0     : Local File ATABLE       [XATB]: Endif
If clalev([F:XATZ])=0     : Local File ATABZON      [XATZ]: Endif
If clalev([F:HRIDC])=0    : Local File HRINCDLC     [HRIDC] : Endif #EELKA
If clalev([F:HRSDS1])=0   : Local File HRSTADCLSET  [HRSDS1] : Endif #EELKA
If clalev([F:XIDD])=0     : Local File EMPLOID      [XIDD]: Endif #EELKA
If clalev([F:XADD])=0     : Local File EMPLOAD      [XADD]: Endif #EELKA
If clalev([F:XAD2])=0     : Local File EMPLOAD      [XAD2]: Endif #EELKA
If clalev([F:EAF])=0      : Local File EMPLOIDAFR   [EAF] : Endif
If clalev([F:EAF2])=0     : Local File EMPLOIDAFR   [EAF2]: Endif
If clalev([F:CTRA])=0     : Local File EMPLOCTRAFR  [CTRA]: Endif
#DEHEN - 2016-09-06 - Added Tables to clear - START
If clalev([F:TRA])=0      : Local File HRSTADCLTRA  [TRA] : Endif
If clalev([F:BEN])=0      : Local File HRSTADCLBEN  [BEN]: Endif
If clalev([F:SAV])=0      : Local File HRSTADCLBSP  [SAV]: Endif
#DEHEN - 2016-09-06 - Added Tables to clear - END

#11/02/08
If clalev([F:CPY2])=0 : Local File COMPANY    [CPY2] : Endif
Local Char    LIBCOL(30)(1..dim([F:HRSDS]DESCOL))

#66728
If clalev([F:ADI2])=0 : Local File ATABDIV    [ADI2] : Endif

[M:HRSDG0]STRDAT= gdat$(1,1,year(gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))))
#DEHEN - 2016-08-19 - START : End date not fired when default, forced to enter date
[M:HRSDG0]ENDDAT= gdat$(func DIVPAYE.INIPARUSR("FINPAY","","")) #- ORIGINAL CODE
#[M:HRSDG0]ENDDAT= [01/01/00]
#DEHEN - 2016-08-19 - END
[M:HRSDG0]YEA   = year(gdat$(func DIVPAYE.INIPARUSR("DATPAY","","")))

#[M:HRSDG0]ALLCPY = 2
#[M:HRSDG0]ALLFCY = 2
#[M:HRSDG0]ALLSRV = 2
#[M:HRSDG0]ALLPRF = 2

Return

$DEBUT

Grizo [M]FCY
Grizo [M]SRV
Grizo [M]PRF

Affzo [M:HRSDG0] : Setmok [HRSDG0] With 0

Return

#############################
$CONTROLE
If GSTATUT<>GSTAOK
FIN = 1
Else
TMP = 1
TRA = 1
Endif

Return

#############################
$EXEC
Local Char TIT (50)

CRITFCY="1=1"
If [M:HRSDG0]ALLCPY<>2
CRITFCY -= '& CPY="'+[M:HRSDG0]CPY+'"'
Endif

Call DEBTRANS From GLOCK
GOK = 1
Call GENERATION

Unlock =SYMBOLE

Return

###################################
Subprog GENERATION
#Variable Integer NBPAR
#Variable Char    PARAMETRE()(1..)
Local Integer NBPAR

Gosub OUVRE From WPDEFTABLE
#MIPEA - 2018-01-26- US X3-71997- START
Local Char    SOCIETE(GLONCPY) , SITEDEB(GLONFCY) , SITEFIN(GLONFCY) , MATDEB(GLONEML) , MATFIN(GLONEML)
#Local Char    SOCIETE(GLONCPY) , SITEDEB(GLONFCY) , SITEFIN(GLONFCY) , MATDEB(GLONMAT) , MATFIN(GLONMAT)
#MIPEA - 2018-01-26- US X3-71997- END
Local Date    DATEDEB , DATEFIN
Local Char    PARAM(20) , PROFIL(GLONPRF) , SERVICE(GLONSRV) , MODELE(GLONHRSDS)
Local Char    CRIT1(250), CRIT2(250)
Local Integer DETPAY
Local Integer I , J , K , NBMOIS , GRP , NUMREQ , LIGTMP , NCOL , OK

Local Decimal MONTP(1..200)
Local Integer DECP(1..200)

Local Char    CHAMP(20) , OBJ(3), CHAMP2(30)
Local Integer TABDIV(1..10) , NOLIB(1..10)
Local Char    FICHIER(10)(1..10) , OBJET(3)(1..10) , CHLIB(20)(1..10) , LIBEL(30)(1..10)
Local Char    CRIT(20)(1..10) , LIB(30)(1..10)
Local Char    MATRI(GLONEML) , POPULATION(GLONPOP), CTR(GLONHRCTR)
Local Date    DATMAT

Local Integer NFRM , NRUB , NCUM , NVAR , NPAT , IFRM
Local Char    FORMULE(250)(1..dim([F:HRSDS]RUBCOD))
Local Char    EXPR(250) , OPE(2) , CODE(20) , REMPL(30)
Local Char    CRUB(15)(1..200) , CPAT(15)(1..200)
Local Char    CCUM(GLONCUM)(1..200) , CVAR(GLONVRA)(1..200)
Local Decimal RU(1..200) , PA(1..200) , CU(1..200) , VA(1..200)
Local Decimal CL(1..dim([F:HRSDS]RUBCOD))
Local Integer WER(1..dim([F:HRSDS]RUBCOD))
Local Char    RUBRIQUE(50)
Local Char    TABLE(GLONATB)
Local Integer TYPMONT , BASE
Local Integer LIGNUL , ZERO

Local Char    XRUB(15)(1..200)  #EELKA
Local Integer XTYPAFF(1..200)  #EELKA

Local Integer XTYPR,XAFFEC,XTYPAMT  #EELKA
Local Integer XL,XE,XTRUE            #EELKA

MODELE=[M:HRSDG0]MDLDCL
SOCIETE=[M:HRSDG0]CPY
SITEDEB=[M:HRSDG0]FCY
SITEFIN=[M:HRSDG0]FCY
POPULATION=[M:HRSDG0]POP
MATDEB=[M:HRSDG0]MATDEB
MATFIN=[M:HRSDG0]MATFIN
DATEDEB =[M:HRSDG0]STRDAT
DATEFIN =[M:HRSDG0]ENDDAT
PROFIL=[M:HRSDG0]PRF
PROFIL=[M:HRSDG0]SRV
DETPAY=1
LIGNUL=1

Read [HRSDS]HRSDS0 = MODELE
If fstat
#JASMI
#     Call ERREUR(Modèle non défini") From GESECRAN : # A créer un message / To create a message
  Call ERREUR(mess(150,141,1)) From GESECRAN : # A créer un message / To create a message
  #JASMI
  GOK = 0 : End
Else
  NCOL = [F:HRSDS]NBRCOL
Endif

Gosub ELIBCOL

If SOCIETE <> ""
  Read [CPY]CPY0 = SOCIETE
  If fstat
  Call ERREUR(mess(65,10702,1)) From GESECRAN : # Société inexistante / Company does not exist
  GOK = 0 : End
  Endif
Endif
GERR = 0

Gosub DECODE_FORMULE

If GERR
  Call ERREUR(GMESSAGE) From GESECRAN
  GOK = 0 : End
Endif

Call TEMPON("O") From GESECRAN

For I=1 To [F:HRSDS]NBRSRT
  CHAMP = [F:HRSDS]CRI(I-1)
  K = instr(1,CHAMP,"]")
  If K : CHAMP = right$(CHAMP,K+1) : Endif
  Read [DIC]DIC0 = CHAMP
  If !fstat
  Read [ATZ]CODZONE = [F:DIC]TBL;CHAMP
  If !fstat
    Call TEXTE([F:ATZ]NOLONG,LIBEL(I)) From OBJDIV
    If [F:ATZ]CODTYP="ADI"
    TABDIV(I) = val([F:ATZ]EXPLIEN)
    Else
    If [F:ATZ]NOLIB<>0
      NOLIB(I) = [F:ATZ]NOLIB
    Endif
    Read [ATY]CODTYP = [F:ATZ]CODTYP
    If !fstat
      If [F:ATY]FICLIEN<>""
      OBJ = [F:ATY]OBJLIEN
      Read [ATB]CODFIC = [F:ATY]FICLIEN
        If [F:ATB]INTIT<>""
        CHP = [F:ATB]INTIT
        Elsif [F:ATB]INTITC<>""
        CHP = [F:ATB]INTIT
        Endif
        If CHP<>""
        Read [ATZ]CODZONE = [F:ATY]FICLIEN;CHP
        If !fstat
          Read [F:ATY]CODTYP = [F:ATZ]CODTYP
          If !fstat
          If [F:ATY]TYPTYP=7
            OBJET(I)   = OBJ
            FICHIER(I) = [F:ATB]CODFIC
            CHLIB(I)   = "[F:"+[F:ATB]ABRFIC+"]"+CHP
          Endif
          Endif
        Endif
        Endif
      Endif
    Endif
    Endif
  Endif
  Endif
Next I

PARAM = num$([F:HRSDS]NBRSRT)

For I=1 To [F:HRSDS]NBRSRT
  If FICHIER(I)<>""
    Read [ATB]CODFIC = FICHIER(I)
    If evalue("clalev([F:"+[F:ATB]ABRFIC+"])")=0
      Local File =FICHIER(I)
    Endif
  Endif
  PARAM = num$(([F:HRSDS]TOT(I-1)=2))
  PARAM = num$(([F:HRSDS]PAG(I-1)=2))
Next I

CRIT1 = '1=1' :#Salarié
If MATDEB<>""
  CRIT1 -= '& [F:ID]REFNUM>="'+MATDEB+'"'
Endif
If MATFIN<>""
  CRIT1 -= '& [F:ID]REFNUM<="'+MATFIN+'"'
Endif
CRIT2 = '1=1'
If SITEDEB<>""
  CRIT2 -= '& [F:VEP]FCY>="'+SITEDEB+'"'
Endif
If SITEFIN<>""
  CRIT2 -= '& [F:VEP]FCY<="'+SITEFIN+'"'
Endif
If PROFIL<>""
  CRIT2 -= '& [F:VEP]PRF="'+PROFIL+'"'
Endif
If SERVICE<>""
  CRIT2 -= '& [F:VEP]SRV="'+SERVICE+'"'
Endif

If POPULATION<>""
  Link [ECT] With
&   [ID]ID0=[F:ECT]REFNUM
& , [HRPOA]HRPOA0=POPULATION;[F:ID]REFNUM
&   As [LID]
&   Where evalue(CRIT1) & [F:HRPOA]REFNUM<>""
&   Order By Key CLE=[F:ID]REFNUM;[F:ECT]CTRNUM
Else
  Link [ECT] With
&   [ID]ID0=[F:ECT]REFNUM
&   As [LID]
&   Where evalue(CRIT1)
&   Order By Key CLE=[F:ID]REFNUM;[F:ECT]CTRNUM
Endif

SVFONCTION = GFONCTION
#Call GETPARAM("X3FCT",NBPAR,PARAMETRE,GFONCTION)

Call AUTORIS From EXEFNC
Call DEBTRANS From GLOCK

Gosub TR1
Call TEMPOFF From GESECRAN

End

$TR1
#--- MZOUH
Local Integer XE,XT,XTRA : Raz XE,XTRA,XT #MZOUH
Local Integer XEXCLU     : Raz XEXCLU
Local Char TIT (50) , TIT2 (50)
Local Integer XTRA  #MZOUH

TIT="Génération Réglementaire"
If !GSERVEUR
  Call OUVRE_TRACE(TIT) From LECFIC : XTRA=1 #MZOUH
Endif
#--- MZOUH

Trbegin [HREDC],[HRIDC]
#JASMI - 2016-11-17 - X3PEOP-2602 - START
#Delete [HREDC] Where MDLDCL=[M:HRSDG0]MDLDCL & YEA =[M:HRSDG0]YEA & STRDAT=[M:HRSDG0]STRDAT
#Delete [HRIDC] Where MDLDCL=[M:HRSDG0]MDLDCL & YEA =[M:HRSDG0]YEA & STRDAT=[M:HRSDG0]STRDAT #EELKA
#JASMI - 2017-11-08 - X3-58570 - START
#Delete [HREDC] Where MDLDCL=[M:HRSDG0]MDLDCL & YEA =[M:HRSDG0]YEA & STRDAT=[M:HRSDG0]STRDAT & CPY=[M:HRSDG0]CPY
#Delete [HRIDC] Where MDLDCL=[M:HRSDG0]MDLDCL & YEA =[M:HRSDG0]YEA & STRDAT=[M:HRSDG0]STRDAT & CPY=[M:HRSDG0]CPY
Delete [HREDC] Where MDLDCL=[M:HRSDG0]MDLDCL & STRDAT=[M:HRSDG0]STRDAT & CPY=[M:HRSDG0]CPY
Delete [HRIDC] Where MDLDCL=[M:HRSDG0]MDLDCL & STRDAT=[M:HRSDG0]STRDAT & CPY=[M:HRSDG0]CPY
#JASMI - 2017-11-08 - X3-58570 - END
#JASMI - 2016-11-17 - X3PEOP-2602 - END
Commit

Raz WER
GOK = 1
LIGTMP = 0
Trbegin [HREDC],[HRIDC]

For TABLE = "EMPLOCPT","EMPLOAD","EMPLOCUM","EMPLOID","EMPLOCTR","EMPLOEXM","EMPLOCHD","EMPLOMED","EMPLOTRY","EMPLORIB","EMPLOSAL"
  Gosub DEFAUT From WPDEFTABLE
Next
##Delete [HREDC] Where USR=GUSER & CREDAT<date$
##Delete [HREDC] Where MODELE=[M:HRSDG0]MDLDCL & YEA =[M:HRSDG0]YEA & STRDAT=[M:HRSDG0]STRDAT

If fstat=1
  GOK = -1 : GLOCK = "TMPLIVRE"-GUSER : Goto ROLL_TR1
Endif

For [LID]CLE : # Salarié+Contrat
  MATRI  = [F:ECT]REFNUM
  CTR    = [F:ECT]CTRNUM

  [L]XEXCLU=0   #EELKA
  Filter [F:XIDD] : Filter [F:EAF2]
  Read[F:XIDD]ID0=MATRI
#DEHEN - Move EMPTYP to CTR from EMP
  Read[F:EAF2]EAF0=MATRI
  Filter [CTRA] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATEFIN
  Read [CTRA]CTRAFR0 Last
  Filter [CTRA]
  If fstat
    OK = 0
  Endif
#DEHEN - Move EMPTYP to CTR from EMP
  If [M:HRSDG0]MDLDCL="CIMR" Then #EELKA
  #If fstat or [F:XIDD]XG_RECIMR="0" or [F:XIDD]XG_RECIMR="" Then
    If fstat or [F:EAF2]RETNUM="0" or [F:EAF2]RETNUM="" Then
      [L]XEXCLU=2
    Endif
  Elsif [M:HRSDG0]MDLDCL="9421" Then
  #DEHEN - Move EMPTYP to CTR from EMP
    Read[F:EAF2]EAF0=MATRI
  #If fstat or [F:EAF2]EMPTYP=5 Then
    If fstat or [F:CTRA]EMPTYP=5 Then
  #DEHEN - Move EMPTYP to CTR from EMP
      [L]XEXCLU=2
    Endif
  Endif
  Read[F:EAF]EAF0=MATRI
  If [L]XEXCLU=0 Then #EELKA
    Raz XE              #EELKA
    For [VEP]VEP0  Where EMP=MATRI & PYRDAT>=DATEDEB & PYRDAT<=DATEFIN & evalue(CRIT2)& CTRNUM=CTR
      For [HSP] Where EMP=MATRI & DAT>=DATEDEB & DAT<=DATEFIN  #MZOUH
        XE=1  : Break #MZOUH
      Next
      If XE=1 Then
        DATMAT = [F:VEP]ENDDAT
        Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
        Read [HRCTR]CTR0 Last
        Filter [HRCTR]
        If !fstat
          Call CONTROLE(MATRI,DATMAT,CTR,"",OK,0) From DIVPAYE
        Else
          OK = 0
        Endif
      #JASMI - 2016-11-16 - X3PEOP-2938 - START
        If [M:HRSDG0]MDLDCL="CIMR" Then
          If !fstat
            Read [CTRA]CTRAFR0 = [HRCTR]REFNUM;[HRCTR]CTRNUM;[HRCTR]CTRDAT
            If fstat
              OK = 0
            Endif
          Endif
        Endif
      #JASMI - 2016-11-16 - X3PEOP-2938 - END
        Read [FGR]FGR0=SOCIETE;[F:VEP]FCY
        If !fstat & OK Then
          Gosub LECEMP From WPDEFTABLE
          Raz CRIT,LIB
          For I=1 To [F:HRSDS]NBRSRT
            CRIT(I) = num$(evalue([F:HRSDS]CRI(I-1)))
            If NOLIB(I)
              CRIT(I) = mess(val(CRIT(I)),NOLIB(I),1)
            Endif

            If CRIT(I)<>""
              If TABDIV(I)<>0
                Read [ADI]CODE = TABDIV(I);CRIT(I)
                Read[F:AXX]AXX0="ATABDIV";"LNGDES";GLANGUE;num$(TABDIV(I));CRIT(I)
                LIB(I) = [F:AXX]TEXTE
              Elsif OBJET(I)<>""
                Call LECTURE(OBJET(I),CRIT(I),"") From CONTOBJ
                LIB(I) = evalue(CHLIB(I))
              Endif
            Endif
          Next I
          Raz MONTP,RU,PA,VA,CU
          Raz XRUB, XTYPAFF #EELKA
          ###56118
          Raz DECP
          ZERO = 1
          For K=1 To NRUB
            RUBRIQUE = CRUB(K)
            TYPMONT  = 1
            BASE     = 0
            Gosub RUBRIQUE
            RU(K) = RESULT
          Next K
          For K=1 To NPAT
            RUBRIQUE = CPAT(K)
            TYPMONT  = 2
            BASE     = 0
            Gosub RUBRIQUE
            PA(K) = RESULT
          Next K
          For K=1 To NCUM
            RUBRIQUE = CCUM(K)
            TYPMONT  = 6
            BASE     = 0
            Gosub RUBRIQUE
            CU(K) = RESULT
          Next K
          For K=1 To NVAR
            RUBRIQUE = CVAR(K)
            Gosub VARIA
            VA(K) = RESULT
          Next K
          IFRM = 0
          Raz XAFFEC #EELKA
          For K=1 To [F:HRSDS]NBRCOL
            Case [F:HRSDS]TYPAMT(K-1)
              When 1,2,3,4,5,6
                RUBRIQUE = [F:HRSDS]RUBCOD(K-1) #NIN_1
                TYPMONT  = [F:HRSDS]TYPAMT(K-1)
                XAFFEC   = [F:HRSDS]ALLHEA(K-1) #EELKA
                BASE     = ([F:HRSDS]BAS(K-1)=2)
                Gosub RUBRIQUE
              When 7
                RUBRIQUE = [F:HRSDS]RUBCOD(K-1)
                XAFFEC   = [F:HRSDS]ALLHEA(K-1) #EELKA
                Gosub VARIA
              #60971
              When 8
                XAFFEC   = [F:HRSDS]ALLHEA(K-1) #EELKA
                Gosub AUCUN
              When 9
                IFRM += 1
                RUBRIQUE = [F:HRSDS]RUBCOD(K-1)
                Onerrgo ERRFRM
                RESULT = evalue(FORMULE(IFRM))
                XAFFEC   = [F:HRSDS]XTYPSALB(K-1) #EELKA
                Onerrgo
              #Taxe Band
              When 13,14,15,16,17,18
                RUBRIQUE = [F:HRSDS]RUBCOD(K-1)
                XAFFEC   = [F:HRSDS]ALLHEA(K-1) #EELKA
                TYPMONT  = [F:HRSDS]TYPAMT(K-1)-3
                BASE     = ([F:HRSDS]BAS(K-1)=2)
                Gosub RUBRIQUE
            Endcase
            MONTP(K)  = RESULT
            XRUB(K)   = RUBRIQUE  #EELKA
            XTYPAFF(K)= XAFFEC    #EELKA
            #57869
            If !DECP(K) : DECP(K)=2 : Endif
            If MONTP(K)<>0
              ZERO = 0
            Endif
          Next K

          Raz XL #EELKA
          If LIGNUL or !ZERO
            For GRP=1 To int(([F:HRSDS]NBRCOL-1)/NCOL)+1
              If sigma(NCOL*(GRP-1)+1,NCOL*GRP,abs(MONTP(indcum)))<>0
                Raz [F:HREDC]
                If DETPAY Then
                  For I=1 To NCOL
                    J = NCOL*(GRP-1)+I
                    If J<=[F:HRSDS]NBRCOL Then
                      If [M]MDLDCL="9421" Then #EELKA
                      #DEHEN - Move EMPTYP to CTR from EMP
                        #If ([F:EAF]EMPTYP=1 and find(XTYPAFF(J),2,4)) or([F:EAF]EMPTYP=2 and find(XTYPAFF(J),3,4)) Then
                        If ([F:CTRA]EMPTYP=1 and find(XTYPAFF(J),2,4)) or([F:CTRA]EMPTYP=2 and find(XTYPAFF(J),3,4)) Then
                      #DEHEN - Move EMPTYP to CTR from EMP
                          XL+=1
                          [F:HREDC]AMT(XL-1)   = MONTP(J)
                          [F:HREDC]DEC(XL-1)   = DECP(J)
                          [F:HREDC]RUBCOD(XL-1)= XRUB(J) #EELKA
                        Endif
                      Else #CIMR
                        [F:HREDC]AMT(I-1)    = MONTP(J)
                        [F:HREDC]DEC(I-1)    = DECP(J)
                        [F:HREDC]RUBCOD(I-1) = XRUB(J) #EELKA
                      Endif
                    Endif
                  Next I
                  LIGTMP += 1
                  [F:HREDC]LIG      = LIGTMP
                  [F:HREDC]USR      = GUSER
                  [F:HREDC]RQT      = [L]NUMREQ
                  [F:HREDC]GRP      = GRP
                  [F:HREDC]EMP      = [F:VEP]EMP
                  [F:HREDC]DAT      = [F:VEP]PYRDAT
                  [F:HREDC]CTR      = [F:VEP]CTRNUM
                  [F:HREDC]CREDAT   = date$
                  [F:HREDC]STRDAT   = [M:HRSDG0]STRDAT
                  [F:HREDC]ENDDAT   = [M:HRSDG0]ENDDAT
                  [F:HREDC]YEA      = [M:HRSDG0]YEA
                  [F:HREDC]MDLDCL   = [M:HRSDG0]MDLDCL
                  [F:HREDC]CPY      = [M:HRSDG0]CPY   #Z.Meryame 13/03/2014
                #DEHEN - Move EMPTYP to CTR from EMP
                  #[F:HREDC]EMPTYP   = [F:EAF]EMPTYP  #EELKA
                  [F:HREDC]EMPTYP   = [F:CTRA]EMPTYP  #EELKA
                #DEHEN - Move EMPTYP to CTR from EMP
                #JASMI - 2016-11-16 - X3PEOP-2938 - START
                  If [M:HRSDG0]MDLDCL="CIMR" Then
                    [F:HREDC]CAICAT=[F:CTRA]CAICAT
                  Else
                    [F:HREDC]CAICAT=""
                  Endif
                #JASMI - 2016-11-16 - X3PEOP-2938 - END
                  Raz XL
                  For I=0 To [F:HRSDS]NBRCOL-1
                    If [M]MDLDCL="9421" Then #EELKA
                      #DEHEN - Move EMPTYP to CTR from EMP
                        #If ([F:EAF]EMPTYP=1 and find([F:HRSDS]ALLHEA(I),2,4)) or ([F:EAF]EMPTYP=2 and  find([F:HRSDS]ALLHEA(I),3,4)) Then
                      If ([F:CTRA]EMPTYP=1 and find([F:HRSDS]ALLHEA(I),2,4)) or ([F:CTRA]EMPTYP=2 and  find([F:HRSDS]ALLHEA(I),3,4)) Then
                      #DEHEN - Move EMPTYP to CTR from EMP
                        XL+=1
                        [F:HREDC]DESCOL(XL-1)=LIBCOL(I+1)
                      Endif
                    Else #CIMR
                      [F:HREDC]DESCOL(I)=LIBCOL(I+1)
                    Endif
                  Next I

                  For I=1 To [F:HRSDS]NBRSRT
                    [F:HREDC]TRI(I-1) = CRIT(I)
                    [F:HREDC]LIB(I-1) = LIB(I)
                  Next I

                  ##HISTORISATION DES champs

                  Local Integer X,XX : Raz X      #--- MZOUH
                  Local Char XY,XAB,XCP,XABR,XCHP #--- MZOUH
                  Raz XL
                  For I=0 To [F:HRSDS]NBRFLD-1
                    If [F:HRSDS]FLD(I) <> '' Then
                      #--- MZOUH v
                      Raz XY,XAB,XCP,XABR,XCHP
                      Raz XX
                      For X =1 To len ([F:HRSDS]FLD(I))
                        XY = mid$([F:HRSDS]FLD(I),X,1)
                        If XY <> "]" and XX = 0 Then
                          XAB += XY
                        Else
                          XX =1
                          XCP += XY
                        Endif
                      Next

                      XABR= mid$(XAB ,4,len(XAB))
                      XCHP= mid$(XCP ,2,len(XCP))
                      For  [F:XATB] Where ABRFIC = XABR
                        Read [F:XATZ]CODZONE=[F:XATB]CODFIC;XCHP
                        If !fstat Then
                          If [M]MDLDCL="9421" Then #EELKA
                          #DEHEN - Move EMPTYP to CTR from EMP
                            #If ([F:EAF]EMPTYP=1 and find([F:HRSDS]ALLDTA(I),2,4)) or ([F:EAF]EMPTYP=2 and find([F:HRSDS]ALLDTA(I),3,4)) Then
                            If ([F:CTRA]EMPTYP=1 and find([F:HRSDS]ALLDTA(I),2,4)) or ([F:CTRA]EMPTYP=2 and find([F:HRSDS]ALLDTA(I),3,4)) Then
                          #DEHEN - Move EMPTYP to CTR from EMP
                              XL+=1
                              If [F:XATZ] CODTYP <> "ADL" Then
                              #--- MZOUH
                                Case type([F:HRSDS]TYP(I))
                                  When 1, 2, 4, 5, 6, 7, 9
                                    [F:HREDC]FLD(XL-1)=num$(evalue([F:HRSDS]FLD(I)))
                                  When 3
                                    [F:HREDC]FLD(XL-1) = num$(day([F:HRSDS]FLDTYP(I)))+"/"+num$(month([F:HRSDS]FLDTYP(I)))+"/"+num$(year([F:HRSDS]FLDTYP(I)
& ))
                                  When Default
                                    [F:HREDC]FLD(XL-1)=num$(evalue([F:HRSDS]FLD(I)))
                                Endcase
                                #DEHEN - Translation text
                                #[F:HREDC]TITFLD(XL-1)=num$([F:HRSDS]TIT(I))
                                Call LECTEXTRA([F:HREDC]TITFLD(XL-1),"HRSTADCLSET","TIT",[M:HRSDG0]MDLDCL,[HRSDS]FLD(I)) From ATEXTRA
                              Else
                                Case type([F:HRSDS]FLDTYP(I))
                                  When 1, 2, 4, 5, 6, 7, 9
                                    [F:HREDC]FLD(XL-1)=num$(evalue([F:HRSDS]FLD(I))+" "+[ID]ADD2+" "+[ID]ADD3+" "+" "+[ID]CODPOS+" "+[ID]CTY)
                                  When 3
                                    [F:HREDC]FLD(XL-1) = num$(day([F:HRSDS]FLDTYP(I)))+"/"+num$(month([F:HRSDS]FLDTYP(I)))+"/"+num$(year([F:HRSDS]FLDTYP(I)
& ))
                                  When Default
                                    [F:HREDC]FLD(XL-1)=num$(evalue([F:HRSDS]FLD(I)))
                                Endcase
                                Call LECTEXTRA([F:HREDC]TITFLD(XL-1),"HRSTADCLSET","TIT",[M:HRSDG0]MDLDCL,[HRSDS]FLD(I)) From ATEXTRA
                              Endif
                            Endif
                          Else  #CIMR
                            If [F:XATZ] CODTYP <> "ADL" Then
                            #--- MZOUH
                              Case type([F:HRSDS]FLDTYP(I))
                                When 1, 2, 4, 5, 6, 7, 9
                                  [F:HREDC]FLD(I)=num$(evalue([F:HRSDS]FLD(I)))
                                When 3
                                  [F:HREDC]FLD(I) = num$(day([F:HRSDS]FLDTYP(I)))+"/"+num$(month([F:HRSDS]FLDTYP(I)))+"/"+num$(year([F:HRSDS]FLDTYP(I)))
                                When Default
                                  [F:HREDC]FLD(I)=num$(evalue([F:HRSDS]FLD(I)))
                              Endcase
                              #[F:HREDC]TITFLD(I)=[F:HRSDS]TIT(I)
                              Call LECTEXTRA([F:HREDC]TITFLD(I),"HRSTADCLSET","TIT",[M:HRSDG0]MDLDCL,[HRSDS]FLD(I)) From ATEXTRA
                            Else
                              Case type([F:HRSDS]FLDTYP(I))
                                When 1, 2, 4, 5, 6, 7, 9
                                  [F:HREDC]FLD(I)=num$(evalue([F:HRSDS]FLD(I))+" "+[ID]ADD2+" "+[ID]ADD3+" "+" "+[ID]CODPOS+" "+[ID]CTY)
                                When 3
                                  [F:HREDC]FLD(I) = num$(day([F:HRSDS]FLDTYP(I)))+"/"+num$(month([F:HRSDS]FLDTYP(I)))+"/"+num$(year([F:HRSDS]FLDTYP(I)))
                                When Default
                                  [F:HREDC]FLD(I)=num$(evalue([F:HRSDS]FLD(I)))
                              Endcase
                              [F:HREDC]LIB(I)=[F:HRSDS]TIT(I)
                            Endif
                          Endif #MODELE
                        Endif
                      Next
                    Else
                      Break
                    Endif
                  Next I

                  Read[HREDC]HREDC0=[M:HRSDG0]MDLDCL;[F:VEP]EMP;[M:HRSDG0]STRDAT;[F:VEP]PYRDAT #EELKA
                  If fstat Then
                    Write [HREDC]
                    If fstat
                      GOK = 0 : Call FSTA("TMP") From GLOCK : Break 2
                    Endif
                  Endif
                Else
                  Filter [HREDC] Where USR=GUSER & RQT=[L]NUMREQ & GRP=[L]GRP & EMP=[F:ID]REFNUM & CTR=[F:ECT]CTRNUM
&             &   DAT=date$ & CREDAT=date$ & TRI(0)=CRIT(1) & TRI(1)=CRIT(2) & TRI(2)=CRIT(3)
&             &   TRI(3)=CRIT(4) & TRI(4)=CRIT(5) & TRI(5)=CRIT(6) & TRI(6)=CRIT(7)
&             &   TRI(7)=CRIT(8) & TRI(8)=CRIT(9) & TRI(9)=CRIT(10)
                  Readlock [HREDC]HREDC0 First
                  Filter [HREDC]
                  If fstat=1
                    GOK = -1 : GLOCK = "$TMPLIVRE" : Break 2
                  Elsif fstat=0
                    Raz XL
                    For I=1 To NCOL
                      J = NCOL*(GRP-1)+I
                      If J<=[F:HRSDS]NBRCOL
                        If [M]MDLDCL="9421" Then #EELKA
                        #DEHEN - Move EMPTYP to CTR from EMP
                          #If ([F:EAF]EMPTYP=1 and find(XTYPAFF(J),2,4)) or([F:EAF]EMPTYP=2 and find(XTYPAFF(J),3,4)) Then
                          If ([F:CTRA]EMPTYP=1 and find(XTYPAFF(J),2,4)) or([F:CTRA]EMPTYP=2 and find(XTYPAFF(J),3,4)) Then
                        #DEHEN - Move EMPTYP to CTR from EMP
                            XL+=1
                            [F:HREDC]AMT(XL-1) += MONTP(J)
                            [F:HREDC]RUBCOD(XL-1)= XRUB(J)
                            Rewrite [HREDC]
                            If fstat Then GOK = 0 : Break : Endif
                          Endif
                        Else #CIMR
                          [F:HREDC]AMT(I-1) += MONTP(J)
                          [F:HREDC]RUBCOD(I-1)= XRUB(J) #EELKA
                          Rewrite [HREDC]
                          If fstat Then GOK = 0 : Break : Endif
                        Endif
                      Endif
                    Next I
                  Elsif fstat>1
                    [F:HREDC]USR = GUSER
                    [F:HREDC]RQT = [L]NUMREQ
                    [F:HREDC]GRP = GRP
                    [F:HREDC]EMP = [F:ID]REFNUM
                    [F:HREDC]CTR      = [F:ECT]CTRNUM
                    [F:HREDC]DAT      = date$
                    [F:HREDC]CREDAT   = date$
                    [F:HREDC]STRDAT   = [M:HRSDG0]STRDAT
                    [F:HREDC]ENDDAT   = [M:HRSDG0]ENDDAT
                    [F:HREDC]YEA      = [M:HRSDG0]YEA
                    [F:HREDC]MDLDCL   = [M:HRSDG0]MDLDCL
                    [F:HREDC]CPY      = [M:HRSDG0]CPY
                  #DEHEN - Move EMPTYP to CTR from EMP
                    #[F:HREDC]EMPTYP   = [F:EAF]EMPTYP
                    [F:HREDC]EMPTYP   = [F:CTRA]EMPTYP
                  #DEHEN - Move EMPTYP to CTR from EMP
                  #JASMI - 2016-11-16 - X3PEOP-2938 - START
                    If [M:HRSDG0]MDLDCL="CIMR" Then
                      [F:HREDC]CAICAT=[F:CTRA]CAICAT
                    Else
                      [F:HREDC]CAICAT=""
                    Endif
                  #JASMI - 2016-11-16 - X3PEOP-2938 - END
                    Raz XL
                    For I=0 To [F:HRSDS]NBRCOL-1
                      If [M]MDLDCL="9421" Then #EELKA
                      #DEHEN - Move EMPTYP to CTR from EMP
                        #If ([F:EAF]EMPTYP=1 and find([F:HRSDS]ALLDTA(I),2,4)) or ([F:EAF]EMPTYP=2 and find([F:HRSDS]ALLDTA(I),3,4)) Then
                        If ([F:CTRA]EMPTYP=1 and find([F:HRSDS]ALLDTA(I),2,4)) or ([F:CTRA]EMPTYP=2 and find([F:HRSDS]ALLDTA(I),3,4)) Then
                      #DEHEN - Move EMPTYP to CTR from EMP
                          XL+=1
                          [F:HREDC]DESCOL(XL-1)=LIBCOL(I+1)
                        Endif
                      Else #CIMR
                        [F:HREDC]DESCOL(I)=LIBCOL(I+1)
                      Endif
                    Next I

                    For I=1 To [F:HRSDS]NBRSRT
                      [F:HREDC]TRI(I-1) = CRIT(I)
                      [F:HREDC]LIB(I-1) = LIB(I)
                    Next I

                    Raz XL
                    For I=1 To NCOL
                      J = NCOL*(GRP-1)+I
                      If J<=[F:HRSDS]NBRCOL
                        If [M]MDLDCL="9421" Then #EELKA
                        #DEHEN - Move EMPTYP to CTR from EMP
                          #If([F:EAF]EMPTYP=1 and find(XTYPAFF(J),2,4)) or([F:EAF]EMPTYP=2 and find(XTYPAFF(J),3,4)) Then
                          If([F:CTRA]EMPTYP=1 and find(XTYPAFF(J),2,4)) or([F:CTRA]EMPTYP=2 and find(XTYPAFF(J),3,4)) Then
                        #DEHEN - Move EMPTYP to CTR from EMP
                            XL+=1
                            [F:HREDC]AMT(XL-1)   = MONTP(J)
                            [F:HREDC]DEC(XL-1)   = DECP(J)
                            [F:HREDC]RUBCOD(XL-1)= XRUB(J) #EELKA
                          Endif
                        Else #CIMR
                          [F:HREDC]AMT(I-1) = MONTP(J)
                          [F:HREDC]DEC(I-1) = DECP(J)
                          [F:HREDC]RUBCOD(I-1)= XRUB(J) #EELKA
                        Endif
                      Endif
                    Next I

                  ### HISTORISATION DES champs
                    Raz XL
                    For I=1 To [F:HRSDS]NBRFLD
                      If [M]MDLDCL="9421" Then #EELKA
                      #DEHEN - Move EMPTYP to CTR from EMP
                        #If ([F:EAF]EMPTYP=1 and find([F:HRSDS]ALLDTA(I),2,4)) or ([F:EAF]EMPTYP=2 and find([F:HRSDS]ALLDTA(I),3,4)) Then
                        If ([F:CTRA]EMPTYP=1 and find([F:HRSDS]ALLDTA(I),2,4)) or ([F:CTRA]EMPTYP=2 and find([F:HRSDS]ALLDTA(I),3,4)) Then
                      #DEHEN - Move EMPTYP to CTR from EMP
                          XL+=1
                          [F:HREDC]FLD=evalue([F:HRSDS]FLD(I))     #####<!>
                        Endif
                      Else #CIMR
                        [F:HREDC]FLD=evalue([F:HRSDS]FLD(I))
                      Endif
                    Next I
                    LIGTMP += 1
                    [F:HREDC]LIG = LIGTMP
                    Write [HREDC]
                    If fstat Then
                      GOK = 0 : Call FSTA("TMP") From GLOCK : Break 2
                    Endif
                  Endif
                Endif : # DETPAY
              Endif #sigma
            Next GRP
          Endif : # lignul
        Endif : # !fstat & OK
      Endif
    Next : # VEP
  Endif #EXCLU ##EELKA
Next : # ID

XTRUE=0
#<EELKA deb>remplissage de la table HRIDC a partir de la table HREDC
Filter [HREDC] Where MDLDCL=[M:HRSDG0]MDLDCL & YEA =[M:HRSDG0]YEA & STRDAT=[M:HRSDG0]STRDAT Order By [HREDC]EMP
For [HREDC]
  #XTRUE=0
  Filter [HRIDC]
#JASMI - 2016-11-16 - X3PEOP-2938 - START
#  Read[HRIDC]HRIDC0=[HREDC]MDLDCL;[HREDC]EMP;[HREDC]STRDAT;[HREDC]ENDDAT
  Read[HRIDC]HRIDC0=[HREDC]MDLDCL;[HREDC]EMP;[HREDC]STRDAT;[HREDC]ENDDAT;[HREDC]CAICAT
#JASMI - 2016-11-16 - X3PEOP-2938 - END
  If fstat Then
    [F:HRIDC]=[F:HREDC]
    [F:HRIDC]YEA=[F:HREDC]YEA
    Write [F:HRIDC]
    If fstat Then GOK = 0 : Break : Endif
    XTRUE=2
    Call ECR_TRACE (mess(44,11706,1)-":"-[HRIDC]EMP,0) From GESECRAN #DEHEN - 2016-08-19 : Replaced text with message
  Else
    For I=0 To dim([F:HREDC]RUBCOD)-1
      Raz XTYPR,XTYPAMT
      For [F:HRSDS1] Where COD=[M]MDLDCL
        For J=0 To dim([F:HRSDS1]RUBCOD)-1
          If [F:HRSDS1]RUBCOD(J)=[HREDC]RUBCOD(I)
            XTYPAMT=[F:HRSDS1]TYPAMT(J)
            XTYPR  =[F:HRSDS1]TYPRUB(J)
            Break : Break 2
          Endif
        Next
      Next
      Filter [F:HRSDS1]
      If XTYPR=1 and XTYPAMT<>7 Then
        [F:HRIDC]DEC(I)+=[F:HREDC]DEC(I)
        [F:HRIDC]AMT(I)+=[F:HREDC]AMT(I)
        Rewrite [F:HRIDC]
        If fstat Then GOK = 0 : Break : Endif
        XTRUE=2
        Call ECR_TRACE (mess(44,11706,1)-":"-[HRIDC]EMP,0) From GESECRAN #DEHEN - 2016-08-19 : Replaced text with message
      Endif
    Next I
  Endif
Next
Filter [HREDC]: Filter [HRIDC]
If XTRA=1 Then
  If XTRUE=0 Then
    Call ECR_TRACE (mess(45,11706,1),0) From GESECRAN #Message : No regulatory attended up generation
  Endif
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
#<EELKA fin>

If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$ERRFRM
If WER(IFRM)=0
WER(IFRM) = 1
Call ECR_TRACE([F:HRSDS]RUBCOD(K-1)+"\"+errmes$(errn)+"\"+errm,1) From GESECRAN
Endif
RESULT = 0
Resume


#==================================================================================
$RUBRIQUE
RESULT = 0

###56118 : calcul du nb de décimales à l'afficher à l'édition
Call LECTURE("RUB",RUBRIQUE,"") From CONTOBJ
If [F:RUB]DEC
  DECP(K)=len(num$([F:RUB]DEC))-len(num$(fix([F:RUB]DEC)))-1 :#-1 pour le séparateur ,
Endif
###57869 : pour les arrondis défini par une valeur entière
If DECP(K)<0 : DECP(K)=0 : Endif

Read [HSP]HSP3 = [F:VEP]BUL;RUBRIQUE;TYPMONT
If !fstat
  If BASE
    RESULT = [F:HSP]BAS
  Else
    If TYPMONT<>6
      RESULT = [F:HSP]AMT
    Else
      #\38252
      If [F:HSP]AMT<>[F:HSP]BAS
        RESULT = [F:HSP]AMT-[F:HSP]BAS
      Else
        Read [CUM]CUM0=[L]RUBRIQUE
        If !fstat and mid$(func AFNC.PARAM("PERCUM"+num$([F:CUM]CUMPER),[F:VEP]FCY),month([F:VEP]ENDDAT),1)="O"
          RESULT=[F:HSP]AMT
        Else
          RESULT=0
        Endif
      Endif
    #/38252
    Endif
  Endif
#JASMI - 2016-10-31 - START
  If [F:HRSDS]TYPRUB(K-1)=2 #rate
    RESULT=[F:HSP]RAT
  Endif
#JASMI - 2016-10-31 - END
Endif

#Gestion des réguls
If TYPMONT<3
  Read [HSP]HSP3 = [F:VEP]BUL;RUBRIQUE;(TYPMONT+6)
  If !fstat
    If BASE
      RESULT += [F:HSP]BAS
    Else
      RESULT += [F:HSP]AMT
    Endif
  #JASMI - 2016-10-31 - START
    If [F:HRSDS]TYPRUB(K-1)=2 #rate
      RESULT=[F:HSP]RAT
    Endif
  #JASMI - 2016-10-31 - END
  Endif
Endif

Return

#==========================================================================
$VARIA
RESULT = 0

#Récupérer la valeur de la varible M.Z 08/04/2014
If !clalev ([VRA]) Then Local File VARIA [VRA] : Endif
Local Integer XTYP : Raz XTYP
Read [VRA]VRA0=RUBRIQUE
If !fstat Then
  If [VRA]FLGEMP =2 Then
    XTYP = 4 : Gosub XGRECUP
  Elsif [VRA]FLGFCY = 2 Then
    XTYP = 3 : Gosub XGRECUP
  Elsif [VRA]FLGCPY = 2 Then
    XTYP = 2 : Gosub XGRECUP
  Elsif [VRA]FLGFDR = 2 Then
    XTYP = 1 : Gosub XGRECUP
  Endif
Endif
Return

#==========================================================================
$XGRECUP
#Modif EELKA 13/02/2015
If !clalev ([XCPY]) Then Local File COMPANY [XCPY] : Endif
Local Char XFCY

###For [F:VLA] Where TYP=XTYP and VARCOD=RUBRIQUE and month([F:VLA]DAT)=month([F:VEP]PYRDAT) and year([F:VLA]DAT) = year([F:VEP]PYRDAT)
Filter [F:XVLA] Where TYP=XTYP and VARCOD=RUBRIQUE Order By [F:XVLA]DAT Desc #Lire le max date
Read[F:XVLA]First
If !fstat Then
  If XTYP=4 Then
    If [F:XVLA]EMP = [F:VEP]EMP Then
      RESULT = [F:XVLA]VARVAL : Goto XBREAK
    Endif
  Elsif XTYP=3 Then
    Read [XCPY]CPY0=[M:HRSDG0]CPY
    If !fstat Then
      XFCY = [XCPY]MAIFCY
    Endif
    If [F:XVLA]FCY = XFCY Then
      RESULT = [F:XVLA]VARVAL : Goto XBREAK
    Endif
  Elsif XTYP=2 Then
    If [F:XVLA]CPY = [M:HRSDG0]CPY Then
      RESULT = [F:XVLA]VARVAL : Goto XBREAK
    Endif
  Elsif XTYP=1
    RESULT = [F:XVLA]VARVAL : Goto XBREAK
  Endif
Endif

$XBREAK
Filter [F:XVLA]
If clalev ([XCPY]) Then Close Local File [XCPY] : Endif
Return

