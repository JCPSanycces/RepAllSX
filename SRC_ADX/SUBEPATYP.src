##################################################
Subprog CONTEPATYP(COD)
Variable Char    COD()

  If GFONCTION = "GESEPATYP" | COD="" : End : Endif

  If clalev([F:EPATYP])=0 : Local File EPATYP [EPATYP] : Endif

  If COD <> ""
    Filter [F:EPATYP] Where EPATYP=[L]COD
    Read [F:EPATYP] First
    Filter [F:EPATYP]
    If fstat
        GMESSAGE = COD-":"-mess(23,100,1)
        mkstat = 2 : End
    Else
        Read [F:EPATYP]EPATYP2 = [L]COD;GCURLEG#GCURLEG;[L]COD

        If fstat
          Filter [F:EPATYP] Where EPATYP=[L]COD & LEG=GCURLEG
          Read [F:EPATYP] First
          Filter [F:EPATYP]
          If [F:EPATYP]LEG<>""
            GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:EPATYP]LEG
            mkstat = 2 : End
          Endif
        Endif
    Endif
  Endif
  Filter [F:EPATYP]
End


##################################################

Subprog TUNEPATYP(COD)
Variable Char    COD()
Local Integer TOKILL

  TOKILL = 0
  If dim(VCOD)<1
   Global Char VCOD(GLONEPATYP)
   TOKILL = 1
  Endif

  If clalev([F:EPATYP])=0 : Local File EPATYP [EPATYP] : Endif

  VCOD = COD

  #ADNGO - 2017-04-12 - START
  If VCOD="" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
    If GLEGFIL <> ''
      Filter [EPATYP] Where LEG=GLEGFIL
      Read [F:EPATYP] First
      #Filter [EPATYP]
    Else
      Filter [EPATYP] Where LEG=GCURLEG
      Read [F:EPATYP] First
      #Filter [EPATYP]
    Endif
    #Read [F:EPATYP] First
    Filter [EPATYP]
    If !fstat : VCOD=[F:EPATYP]EPATYP : Endif
  Else
    Read [EPATYP]EPATYP2 = VCOD;GCURLEG#GCURLEG;VCOD
  Endif
  #ADNGO - 2017-04-12 - END

  #ADNGO - 2017-02-09 - START
  #Raz GLEGFIL
  #ADNGO - 2017-02-09 - END

  #ADNGO - 2017-04-12 - START
  #Call OBJET("NAT",VCOD,"") From GOBJET
  #Call OBJET("NAT",GCURLEG,VCOD) From GOBJET
  Call OBJET("EPATYP",VCOD,GCURLEG) From GOBJET
  #ADNGO - 2017-04-12 - END
  COD = VCOD

  If TOKILL : Kill VCOD : Endif


End

