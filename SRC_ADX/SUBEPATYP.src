$FILTRE
#ADNGO - 2018-02-15 - X3-77388 - START
   If GCURLEG <> '' and GLEGFIL <> '' and GCURLEG <> GLEGFIL
      FILTSUP = 'LEG=GCURLEG'
   Else
    If GLEGFIL <> ''
      FILTSUP = 'LEG=GLEGFIL'
    Endif
   Endif
#ADNGO - 2018-02-15 - X3-77388 - END
Return

