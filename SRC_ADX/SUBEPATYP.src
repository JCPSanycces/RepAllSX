#<AdxTL>@(#)0.0.0.0 $Revision$
#FRLAA - 2016-12-02 - REQUIREMENT X3-11647 US X3-12771 - START

#Hybrid development
$ACTION
Case ACTION
  When "OUVRE"          : Gosub OUVRE
  When "LIENS"          : Gosub LIENS
  When "RAZCRE"         : Gosub RAZCRE
  When "CREATION"       : Gosub CREATION
  When "APRES_CRE"      : Gosub APRES_CRE
  When "MODIF"          : Gosub MODIF
  When "APRES_MOD"      : Gosub APRES_MOD
  When "RAZDUP"         : Gosub RAZDUP
  When "AV_ANNULE"      : Gosub AV_ANNULE
  When "ANNULE"         : Gosub ANNULE
  When "FERME"          : Gosub FERME
  #When "FILGAUCHE"      : Gosub FILGAUCHE #LIMAS - 2018-01-22 - X3-57798
  When "AP_CHANGE"      : Gosub AP_CHANGE
  When "ANNULE"         : Gosub ANNULE
  When "TEXTRA"         : Gosub TEXTRA
  When "SEL_TABLE"      : Gosub SEL_TABLE
  When "FILTRE"        : Gosub FILTRE
Endcase
Return

$OUVRE
#Disabling the classic CUD operation - Hybrid development (ANOWRITE)
Local Integer ANOWRITE
ANOWRITE = 1
#ADNGO - 2018-02-15 - X3-77388 - START
#If GLEGFIL <> ''
#  GCURLEG = GLEGFIL
#Else
#  GCURLEG = ""
#Endif
#ADNGO - 2018-02-15 - X3-77388 - END
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

#Opening tables and declaring an instance of the main class
If clalev([F:EPATYP]) = 0 : Local File EPATYP         [EPATYP]         : Endif
If clalev([F:EPASLV]) = 0 : Local File EPASETVAR      [EPASLV]         : Endif

Global Instance I_EPATYP Using C_EPATYP

Return

$FERME
#Free the instance after leaving the transaction
#LIMAS - 2018-01-25 - X3-57806 - START
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#LIMAS - 2018-01-25 - X3-57806 - END
If (I_EPATYP <> null) : FreeGroup I_EPATYP : Endif
Return

#LIMAS - 2018-01-22 - X3-57798 - START
#$FILGAUCHE
#  If GLEGFIL <> ""
#    FILGAUCHE ="[F:EPATYP]LEG='"+GLEGFIL+"'"
#  Else
#    FILGAUCHE = ""
#  Endif
#Return
#LIMAS - 2018-01-22 - X3-57798 - END
$LIENS
#This will be the only Supervisor action we will allow in classic mode
# We wil let the supervisor read from the database and populate the mask
#Instantiate the class with the key from the screen to have it online for update/delete transactions
If (I_EPATYP <> null) : FreeGroup I_EPATYP : Endif
I_EPATYP = NewInstance C_EPATYP AllocGroup null
Local Integer READSTATUS
[L]READSTATUS = fmet I_EPATYP.AREAD([M:EPATYP0]EPATYP)
If ([L]READSTATUS  >= [V]CST_AERROR)
  Call GET_ERRORS(I_EPATYP)
  If GOK=0 : Return : Endif
Endif
#LIMAS - 2018-01-25 - X3-57806 - START
If dim([M:EPATYP0]LEG)>0 : GCURLEG=[M:EPATYP0]LEG : Endif
#LIMAS - 2018-01-25 - X3-57806 - END

#The supervisor will not load the collections from the table to the mask - this must be done using the collections from the class to the mask!
#Reading from the collections to the mask = Collection instantiated with the main class
Gosub LOAD_COLLECTIONS

Affzo [M:EPATYP0]1-99
Affzo [M:EPATYP1]1-99

#LIMAS - 2018-01-23 - X3-57806 - START
Call LECTEXTRA([M]EPATIT,"EPATYP","EPATIT",[M]EPATYP,GCURLEG) From ATEXTRA
#LIMAS - 2018-01-23 - X3-57806 - END
Return

$MODIF
Local Integer WRITESTATUS, MY_STATUS
#Set the instance the same as for CREATION
SetInstance I_EPATYP With [F:EPATYP]

#LIMAS - 2018-01-23 - X3-57806 - START
Gosub TEXTRA
#LIMAS - 2018-01-23 - X3-57806 - END

#Setting the fields to the child classes (collections)
#Not checking the status of the lines - Deleting all the lines in the collection and creating new ones based on the mask
#Setting variable
For I = 1 To maxtab(I_EPATYP.EPASETVAR)
  If I_EPATYP.EPASETVAR(1) <> null : [L]MY_STATUS = fmet I_EPATYP.ADELLINE("EPASETVAR",1) : Endif
   If ([L]MY_STATUS >= [V]CST_AERROR)
    Call GET_ERRORS(I_EPATYP)
    GOK=0 : GERR=1 : Return
  Endif
Next I

#Adding lines to the collections
#Setting variable
Gosub WRITE_COLLECTIONS

I_EPATYP.LEG = [M:EPATYP0]LEG
#Invoke the creation process and handle the error if applicable
[L]WRITESTATUS = fmet I_EPATYP.AUPDATE()
If ([L]WRITESTATUS >= [V]CST_AERROR)
  Call GET_ERRORS(I_EPATYP)
  If GOK=0 : Return : Endif
Endif
Return

$APRES_MOD
#This action is called after a successful update. You may have to refresh some screen fields
Gosub RELIT From GOBJSUB
Return

$RAZCRE

#LIMAS - 2018-01-25 - X3-57806 - START
If GNBLEG = 1
 GCURLEG = GDOSLEG
Else
  GCURLEG = ""
Endif
#LIMAS - 2018-01-25 - X3-57806 - END
Local Integer MY_STATUS
If (I_EPATYP <> null) : FreeGroup I_EPATYP : Endif
I_EPATYP = NewInstance C_EPATYP AllocGroup null

[L]MY_STATUS = fmet I_EPATYP.AINIT()
If ([L]MY_STATUS >= [V]CST_AERROR)
  Call GET_ERRORS(I_EPATYP)
  GOK = 0 : GERR = 1
  Return
Endif

SetInstance [F:EPATYP] With I_EPATYP

Affzo [M:EPATYP0]1-99

Return

$CREATION
#Transfer the data from the file to the class - all field names are the same
#The supervisor has already transfered the data from the mask to the file
#[F:EPATYP]LEG = [M:EPATYP0]LEG

#LIMAS - 2018-01-23 - X3-57806 - START
Gosub TEXTRA
#LIMAS - 2018-01-23 - X3-57806 - END

SetInstance I_EPATYP With [F:EPATYP]
#Adding lines to the collections
#Setting variable

#Call DEBUG_TRACE(1,"EPA", "Before WRITE_COLLECTIONS") From DEBUGTRACE
Gosub WRITE_COLLECTIONS
#Call DEBUG_TRACE(1,"EPA", "After WRITE_COLLECTIONS") From DEBUGTRACE

#Invoke the creation process and handle the error if applicable
##Call DEBUG_TRACE(1,"EPA", "#Invoke the creation process and handle the error if applicable") From DEBUGTRACE
Local Integer WRITESTATUS

I_EPATYP.LEG = [M:EPATYP0]LEG

[L]WRITESTATUS = fmet I_EPATYP.AINSERT()

#Call DEBUG_TRACE(1,"EPA", "[L]WRITESTATUS: " + num$([L]WRITESTATUS)) From DEBUGTRACE
#Call DEBUG_TRACE(1,"EPA", "[V]CST_AERROR: " + num$([V]CST_AERROR)) From DEBUGTRACE

If ([L]WRITESTATUS >= [V]CST_AERROR)
  Call GET_ERRORS(I_EPATYP)
  If GOK=0 : Return : Endif
Endif

#Call DEBUG_TRACE(1,"EPA", "After a successful insert, refresh the [F] file because the key may be generated in the AINSERT method") From DEBUGTRACE
#After a successful insert, refresh the [F] file because the key may be generated in the AINSERT method
SetInstance [F:EPATYP] With I_EPATYP
Return

$APRES_CRE
#This action is called after a successful creation. You may have to refresh some screen fields
Gosub RELIT From GOBJSUB
Return

$AV_ANNULE
#Diable supervisor - separate process
Local Integer ANOWRITE
ANOWRITE = 1
Return

$ANNULE
#The class should not be instantiated already as a read in LIENS
#Invoke the delete method
Local Integer DELETESTATUS
[L]DELETESTATUS = fmet I_EPATYP.ADELETE()
If ([L]DELETESTATUS >= [V]CST_AERROR)
  Call GET_ERRORS(I_EPATYP)
  If GOK=0 : Return : Endif
Endif
Return

$RAZDUP
Local Integer MY_STATUS
If (I_EPATYP <> null) : FreeGroup I_EPATYP : Endif
I_EPATYP = NewInstance C_EPATYP AllocGroup null

[L]MY_STATUS = fmet I_EPATYP.AINIT()
If ([L]MY_STATUS >= [V]CST_AERROR)
  Call GET_ERRORS(I_EPATYP)
  GOK = 0 : GERR = 1
  Return
Endif

Affzo [M:EPATYP0]1-99
Affzo [M:EPATYP1]1-99
#LIMAS - 2018-01-23 - X3-57806 - START
 Call SUPTEXTRA("EPATYP","EPATIT",[M:EPATYP0]EPATYP,GCURLEG) From ATEXTRA
#LIMAS - 2018-01-23 - X3-57806 - END
Return

$SEL_TABLE
  Case TABLE
  When "SELEPATYP"
#    If !clalev ([F:EPATYP]) : Local File EPATYP [EPATYP] : Endif
#    Filter [F:EPATYP]
#    OBJET="EPATYP"
#    START="[F:EPATYP]EPATYP"
#    CRITERE = 'LEG="'+GCURLEG+'" | LEG=""'
#    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:EPATYP]LEG="'+GCURLEG+'")',"&") From GOBJSUB
    If clalev ([F:EPATYP])=0 : Local File EPATYP [EPATYP] : Endif
#    If !clalev ([F:EPATYP]) : Local File EPATYP [EPATYP] : Endif
    Filter [F:EPATYP]
    OBJET="EPATYP"
    START="[F:EPATYP]EPATYP"
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:EPATYP]LEG="'+GCURLEG+'")',"&") From GOBJSUB

Endcase
Return

$WRITE_COLLECTIONS
Local Char ALLFIELDS(35)
Local Integer I,INDEX
#Adding lines to the collections
#Setting variable
For nolign = 1 To [M:EPATYP1]EPAVARNBR
  ALLFIELDS = [M:EPATYP1]INSVAR(nolign-1)+[M:EPATYP1]ADMVAR(nolign-1)+[M:EPATYP1]BALVAR(nolign-1)+[M:EPATYP1]ADDPAYVAR(nolign-1)
  If ALLFIELDS = "" : Break : Endif

  #Add new line to the collection
  INDEX = fmet I_EPATYP.ADDLINE("EPASETVAR", [V]CST_ALASTPOS)
  If INDEX = [V]CST_ANOTDEFINED
    Call GET_ERRORS(I_EPATYP)
    GOK=0 : GERR=1 : Return
  Endif

  #Transfer data on the line to the collection line
  #Raz [F:EPASLV]
  [F:EPASLV] = [M:EPATYP1]
  SetInstance I_EPATYP.EPASETVAR(INDEX) With [F:EPASLV]
  I_EPATYP.EPASETVAR(INDEX).EPATYP            = [M:EPATYP0]EPATYP
  I_EPATYP.EPASETVAR(INDEX).LIGNBR            = INDEX
Next nolign
Return


Subprog GET_ERRORS(WCONTAINER)
Variable Instance WCONTAINER Using C_EPATYP

Local Integer I
Local Char WTEXTE(50)

 GMESSAGE = func LCCLIB.MAXMSG(WCONTAINER)
 If GMESSAGE = AVOID.ACHAR
   #--- Lines errors

  ##Call DEBUG_TRACE(1, " #--- Lines errors", "EPA") From DEBUGTRACE
  For I=1 To maxtab(WCONTAINER.EPASETVAR)
    GMESSAGE = func LCCLIB.MAXMSG(WCONTAINER.EPASETVAR(I))
    If GMESSAGE <> AVOID.ACHAR
      Call TEXTE(53658, WTEXTE) From OBJDIV
      GMESSAGE = WTEXTE + " : " + GMESSAGE
      Break:  Endif
  Next I
Endif
GOK=0 : GERR=1
End


Subprog AM_LEV(VALEUR)
Variable Integer VALEUR
Default Mask [EPATYP1]

  # On annule d'abord la valeur du champ rattaché à l'ancien niveau
  Case [M]LEV(nolign-1)
    When 1 : [M]LEG(nolign-1)     = ""
    When 2 : [M]POP(nolign-1)     = ""
    When 3 : [M]CPY(nolign-1)     = ""
    When 4 : [M]FCY(nolign-1)     = ""
    When 5 : [M]REFNUM(nolign-1)  = ""
    When 6 : [M]CTRNUM(nolign-1)  = ""
    When 7 : [M]SERVICE(nolign-1) = ""
    When 8 : [M]CLLCVT(nolign-1)  = ""
    When 9 : [M]PRFCOD(nolign-1)  = ""
  Endcase

  If VALEUR=1 Then
    [M]LEV(nolign-1)=VALEUR
    [M]LEG(nolign-1) = [M:EPATYP0]LEG
  Else
    [M]LEG(nolign-1) = ""
  Endif

End

