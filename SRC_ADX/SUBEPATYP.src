$LOAD_COLLECTIONS
Local Integer NI
nolign = 0
If I_EPATYP.EPASETVAR <> null
  For NI=1 To maxtab(I_EPATYP.EPASETVAR)
    If I_EPATYP.EPASETVAR(NI) <> null and find(I_EPATYP.EPASETVAR(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
       nolign += 1
       [M:EPATYP1]LIGNBR(nolign-1)    = I_EPATYP.EPASETVAR(NI).LIGNBR
       [M:EPATYP1]LEV(nolign-1)       = I_EPATYP.EPASETVAR(NI).LEV
       #[M:EPATYP1]ADXDOS(nolign-1)    = I_EPATYP.EPASETVAR(NI).ADXDOS
       [M:EPATYP1]LEG(nolign-1)       = I_EPATYP.EPASETVAR(NI).LEG
       [M:EPATYP1]CPY(nolign-1)       = I_EPATYP.EPASETVAR(NI).CPY
       [M:EPATYP1]FCY(nolign-1)       = I_EPATYP.EPASETVAR(NI).FCY
       [M:EPATYP1]SERVICE(nolign-1)   = I_EPATYP.EPASETVAR(NI).SERVICE
       [M:EPATYP1]REFNUM(nolign-1)    = I_EPATYP.EPASETVAR(NI).REFNUM
       [M:EPATYP1]CTRNUM(nolign-1)    = I_EPATYP.EPASETVAR(NI).CTRNUM
       [M:EPATYP1]POP(nolign-1)       = I_EPATYP.EPASETVAR(NI).POP
       [M:EPATYP1]CLLCVT(nolign-1)    = I_EPATYP.EPASETVAR(NI).CLLCVT
       [M:EPATYP1]PRFCOD(nolign-1)    = I_EPATYP.EPASETVAR(NI).PRFCOD
       [M:EPATYP1]INSVAR(nolign-1)    = I_EPATYP.EPASETVAR(NI).INSVAR
       [M:EPATYP1]ADMVAR(nolign-1)    = I_EPATYP.EPASETVAR(NI).ADMVAR
       [M:EPATYP1]ADDPAYVAR(nolign-1) = I_EPATYP.EPASETVAR(NI).ADDPAYVAR
       [M:EPATYP1]BALVAR(nolign-1)    = I_EPATYP.EPASETVAR(NI).BALVAR

       #SetInstance [M:EPATYP1]5 With I_EPATYP.EPASETVAR(NI) #New functionality - Ignore errors on the sub 2016-12-05
    Endif
  Next NI
Endif

[M:EPATYP1]EPAVARNBR = nolign

Return

