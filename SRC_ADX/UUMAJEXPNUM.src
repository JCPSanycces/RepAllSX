#<AdxTL>@(#)8.0.0.0 $Revision$
#----------------------------------------------------------------------------------------------------------#
# Modification des champs EXPNUM suite la réinitialisation du compteur EXPORT à 1
#----------------------------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update EXPNUM") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3 or 1=1
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub EXPNUM
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub EXPNUM
End

#-------------------#
$EXPNUM

# Une table est à récupérer si on trouve un EXPNUM>CHRCUR
Local Decimal  CHRCUR    : # Chrono courant

# La récupération consiste à repérer les enregistrements modifiés après DATRAZEXP
# et dont EXPNUM<NUMMAX dans la table à récupérer
Local Date     DATRAZEXP : # Date approximative du raz du compteur
Local Integer  NUMMAX    : # Dernier numéro du compteur approximatif
DATRAZEXP = [01/11/2009]
NUMMAX    = 9000

# Ancienne limite du compteur
CHRMAX = 9999

# Simulation
Local Integer SIMUL
SIMUL = 1

If SIMUL
 Call ECR_TRACE("Test - no update",-1) From GESECRAN
Endif

Local Shortint MAXFIL : MAXFIL = 500
Local Integer  I , NUMCUR , NBRTAB , RECUP
Local Integer  FLGTAB(1..MAXFIL) , RECTAB(1..MAXFIL)
Local Char     TABLE(GLONATB) , TABTAB(GLONATB)(1..MAXFIL)

Local File =DOSSIER+".ATABZON" [ATZ] , =DOSSIER+".AOBJEXT" [AOE]
&        , =DOSSIER+".AOBJET"  [AOB] , =DOSSIER+".APLCOM" [ACM]

Read [ACM]COMCLE(1)="EXPORT"
CHRCUR = val([F:ACM]COMFLD)

# Tables avec un champ EXPNUM
Raz TABTAB , FLGTAB , NBRTAB , RECTAB
For [ATZ] Where CODZONE="EXPNUM"
 If !find([F:ATZ]CODFIC,TABTAB(1..NBRTAB))
  NBRTAB += 1
  TABTAB(NBRTAB) = [F:ATZ]CODFIC
 Endif
Next ATZ

# Tables affectées à un modèle
For [AOE] Where ENAFLG=2 & CHRNUM<>0
 If [F:AOE]OBJ<>""
  Read [AOB]ABREV = [F:AOE]OBJ
  TABLE = [F:AOB]NOMFIC
 Else
  TABLE = [F:AOE]FLGFIL(0)
 Endif
 I = find(TABLE,TABTAB(1..NBRTAB))
 If I
  FLGTAB(I) = 2
 Endif
Next AOE

# Récupération des EXPNUM des tables
For I=1 To NBRTAB
 If FLGTAB(I)=2
  Local File =DOSSIER+"."+TABTAB(I) [AAA_]
  RECUP = 0
  For [AAA_] Where EXPNUM>NUMMAX
   If [F:AAA_]EXPNUM>CHRCUR
    RECUP = 1 : Break
   Endif   
  Next AAA_
  If RECUP
   If dim([F:AAA_]UPDDAT)<0 & dim([F:AAA_]CREDAT)<0
    Call ECR_TRACE("File"-TABTAB(I)-"UPDDAT/CREDAT field not found",-1) From GESECRAN
   Else
    J = 0
    Trbegin [AAA_]
     For [AAA_] Where EXPNUM<NUMMAX 
      If (dim([F:AAA_]UPDDAT)>0 & [F:AAA_]UPDDAT>DATRAZEXP) or (dim([F:AAA_]CREDAT)>0 & [F:AAA_]CREDAT>DATRAZEXP)
       J += 1
       [F:AAA_]EXPNUM += (CHRMAX+1)
       If !SIMUL
        Rewrite [AAA_]
        If fstat
         Call ERREUR(TABTAB(I),2) From DOSDIC
        Endif
       Endif
      Endif
     Next AAA_
    Commit
    If J>0
     RECTAB(I) = 2
     Call ECR_TRACE("File"-TABTAB(I)-":"-num$(J)-"updated record",0) From GESECRAN
    Endif
   Endif
  Endif
  Close Local File [AAA_]
 Endif
Next I

# Récupération des chrono dans les modèles

Trbegin [AOE]
 For [AOE] Where ENAFLG=2 & CHRNUM<>0
  If [F:AOE]OBJ<>""
   Read [AOB]ABREV = [F:AOE]OBJ
   TABLE = [F:AOB]NOMFIC
  Else
   TABLE = [F:AOE]FLGFIL(0)
  Endif
  I = find(TABLE,TABTAB(1..NBRTAB))
  If I & RECTAB(I)=2 & CHRNUM<NUMMAX
   [F:AOE]CHRNUM += (CHRMAX+1)
   If !SIMUL
    Rewrite [AOE]
    If fstat
     Call ERREUR("AOBJEXT"-[F:AOE]EXT,2) From DOSDIC
    Endif
   Endif
   Call ECR_TRACE("Template"-[F:AOE]EXT-"Updated from"-num$([F:AOE]CHRNUM-(CHRMAX+1))-"to"-num$([F:AOE]CHRNUM),0) From GESECRAN
  Endif
 Next AOE
Commit

# Mise à jour du chrono EXPORT

If sum(RECTAB)>0 : # Il y a eu au moins une récup
 Trbegin [ACM]
  Read [ACM]COMCLE(1)="EXPORT"
  [F:ACM]COMFLD = num$(val([F:ACM]COMFLD)+(CHRMAX+1))
  If !SIMUL
   Rewrite [ACM]
   If fstat
    Call ERREUR("APLCOM EXPORT",2) From DOSDIC
   Endif
  Endif
  Call ECR_TRACE("Update EXPORT number from"-num$(val([F:ACM]COMFLD)-(CHRMAX+1))-"to"-[F:ACM]COMFLD,0) From GESECRAN 
 Commit
Endif

Close Local File
Return
