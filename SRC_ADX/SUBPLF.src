    If !fstat & [F:FCY]LEG<>"" Then
      If [F:FCY]LEG<>[M:PLF0]LEGPLF Then
        GMESSAGE=mess(270,10717,1)-[M:PLF0]LEGPLF : # La législation du site doit être
        mkstat=2
      Endif
    Endif
  Endif
End
