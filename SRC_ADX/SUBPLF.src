#################################################
## Etiquettes du tableau des coûts prévisionnels
#################################################

Subprog AS_NBRCST
## Recopie de la saisie des coûts dans les zones du tableau invisible
Local Integer I,J : # J = Numéro de la ligne de stage dans le 1er tableau
# SYMEU - Fiche 70042 : division par 0 lors du calcul du montant individuel par rapport au montant
# collectif, quand on saisit les frais d'une ligne sans stage dans le tableau des stages
#If [M:PLF0]LIGCUR=0
If [M:PLF0]LIGCUR=0 or [M:PLF1]NBREMP([M:PLF0]LIGCUR-1)=0 Then
 # Bug 70042 : SYMEU 28/12/2010 : Suppression du message pour griser le tableau (sinon,
 # message à l'enregistrement du plan, quand on a modifié la dernière ligne de stage et
 # quand le curseur est sur la prochaine ligne de stage qui est vide)
 # "Il faut d'abord sélectionner une ligne de stage"
 # GMESSAGE = mess(37,10717,1)
 # mkstat = 2
 Diszo [M:PLF1]NBRCST
 End
# Bug 70042 : SYMEU 28/12/2010
Else
 Actzo [M:PLF1]NBRCST
Endif

J = [M:PLF0]LIGCUR
If [M:PLF1]NUMLIG(J-1)=0 : End : Endif : # Ligne vide
Call EFFCOUT([M:PLF1]NUMLIG(J-1))

For I=0 To [M:PLF1]NBRCST-1

 [M:PLF1]NUMLIGI([M:PLF1]NBRINV)    = [M:PLF1]NUMLIG(J-1)
 [M:PLF1]TYPCRGI([M:PLF1]NBRINV)    = [M:PLF1]TYPCRG(I)
 [M:PLF1]TYPCSTI([M:PLF1]NBRINV)    = [M:PLF1]TYPCST(I) # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
 [M:PLF1]CSTTOTCLLI([M:PLF1]NBRINV) = [M:PLF1]CSTTOTCLL(I)
 [M:PLF1]CSTTOTIDVI([M:PLF1]NBRINV) = [M:PLF1]CSTTOTIDV(I)
 [M:PLF1]CSTIPTCLLI([M:PLF1]NBRINV) = [M:PLF1]CSTIPTCLL(I)
 [M:PLF1]CSTIPTIDVI([M:PLF1]NBRINV) = [M:PLF1]CSTIPTIDV(I)
 [M:PLF1]DESTYPFRTI([M:PLF1]NBRINV) = [M:PLF1]DESTYPFRT(I)
 [M:PLF1]TYPFINI([M:PLF1]NBRINV)    = [M:PLF1]TYPFIN(I)
 [M:PLF1]ORGFINI([M:PLF1]NBRINV)    = [M:PLF1]ORGFIN(I)
 [M:PLF1]LNKREPI([M:PLF1]NBRINV)    = [M:PLF1]LNKREP(I) :# X3-17093 TIVAN
 [M:PLF1]CHAMP([M:PLF1]NBRINV)      = num$([M:PLF1]NUMLIG(J-1))+[M:PLF1]TYPCRG(I)
 [M:PLF1]NBRINV +=1
Next

Call REMP_PLF2([M:PLF1]NBRPLF)
# SYMEU : EXI 66191 LOT 10 - V6.1 : onglet des coûts par type de financement
Call REMP_PLF3([M:PLF1]NBRPLF) : Affzo [PLF3]

Affzo [PLF2]
Affzo [PLF0]TOT,IPT
# SYMEU : EXI 66191 LOT 10 - V6.1 : plan définitif
Call GRISE_FLGCLO([M:PLF0]FLGCLO) From SUBPLF2
End


## Suppression des côuts correspondant à la ligne du plan
Subprog EFFCOUT(J)
Value Decimal J
Local Integer I,L
I = find(J,[M:PLF1]NUMLIGI)
While I
 Dela I-1,1 [M]NBRINV
 L +=1
 I = find(J,[M:PLF1]NUMLIGI)
Wend
[M:PLF1]NBRINV -=L
End

######################################################################################
# SEGAY 81085 US 460 (écran PLF1) 15/06/2012 14:53:15 (SEGAY)
######################################################################################
Subprog AS_ORGFIN(VALEUR)
Variable Char    VALEUR()
Call AS_ORGFIN(VALEUR) From SUBSTG
End

Subprog C_ORGFIN(VALEUR)
Variable Char    VALEUR()
# On teste l'unicité de la ligne sur les zones : TYPCRG/TYPFIN/ORGFIN/DESTYPFRT
Local Shortint I
For I=0 To [M]NBRCST-1
 # SYMEU : EXI 66191 LOT 10 - V6.1 : AUTRE BUG : TEST UNICITE SANS LE DISPOSITIF
 # If I<>nolign-1 & [M]TYPCRG(I)=[M]TYPCRG(nolign-1) & [M]DESTYPFRT(I)=[M]DESTYPFRT(nolign-1)
 #& & [M]TYPFIN(I)=[M]TYPFIN(nolign-1) & [M]ORGFIN(I)=[L]VALEUR
 If I<>nolign-1 & [M]TYPCRG(I)=[M]TYPCRG(nolign-1)
& & [M]TYPFIN(I)=[M]TYPFIN(nolign-1) & [M]ORGFIN(I)=[L]VALEUR
  # SYMEU : EXI 66191 LOT 10 - V6.1 : AUTRE BUG [M]GMESSAGE
  # [M]GMESSAGE=mess(84,10717,1)-num$(I+1) : # Ligne de coût déjà existante en ligne x
  GMESSAGE=mess(84,10717,1)-num$(I+1) : # Ligne de coût déjà existante en ligne x
  mkstat     =2
  Break
 Endif
Next
End


######################################################################################
# Fiche 73076 - SYMEU - 07/04/2011 : lecture du service qui est passé en paramètre
# à l'action CONTEXE du champ SRV dans l'écran PLF1
######################################################################################
Subprog C_SRV(VALEUR)
Variable Char    VALEUR()
  Raz [F:SRV]
  If VALEUR <> "" Then
    Read [F:SRV]SRV0 = VALEUR
  Endif

  # FQ81085 - MABON 22/05/12 - Controls that service is in the same LEG than LEGPLF
  If dim([M:PLF0]LEGPLF)>0 & [M:PLF0]LEGPLF<>"" Then
    If clalev([F:SRV])=0 : Local File SERVICE [SRV] : Endif
    Read [F:SRV]SRV0=VALEUR
    If !fstat & [F:SRV]LEG<>"" Then
      If [F:SRV]LEG<>[M:PLF0]LEGPLF Then
        GMESSAGE=mess(274,10717,1)-[M:PLF0]LEGPLF : # La législation du service doit être
        mkstat=2
      Endif
    Endif
  Endif
End

########################  Cout total collectif ########################

Subprog AS_CSTTOTCLL(VALEUR)
Variable Decimal VALEUR
Call AS_CSTTOTCLL(VALEUR) From TRTCOUT
# SYMEU : EXI 66191 LOT 10 - V6.1 : Dans le cas où on change le type de coût en cours de
# saisie de ligne (coût non calculé remplacé par coût salarial ou patronal)
If mkstat = 2 and VALEUR <> 0 Then
  Raz VALEUR
  Raz [M:PLF1]CSTIPTCLL(nolign-1) : Affzo [M:PLF1]CSTIPTCLL(nolign-1)
  mkstat = 2 # L'affzo le remet à 0
Endif
End

Subprog AM_CSTTOTCLL(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0
 # SYMEU : EXI 66191 LOT 10 - V6.1 : AUTRE BUG : arrondi à 2 décimales
 # [M:PLF1]CSTTOTIDV(nolign-1) = arr((VALEUR/[M:PLF1]NBREMP([M:PLF0]LIGCUR-1)),0.1)
 [M:PLF1]CSTTOTIDV(nolign-1) = arr((VALEUR/[M:PLF1]NBREMP([M:PLF0]LIGCUR-1)),0.01)
 Affzo [M:PLF1]CSTTOTIDV(nolign-1)
Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation. On passe le flag à Manuel
[M:PLF1]TYPCST(nolign-1) = 2 # Manuel
Affzo [M:PLF1]TYPCST(nolign-1)
# X3-17093 - MAJ LNKREP lié TIVAN
Gosub SET_FLGCHG From SUBPLF2
End

######################## Cout total individuel  #######################

Subprog AS_CSTTOTIDV(VALEUR)
Variable Decimal VALEUR
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif

## Si un coût collectif a été saisi, on ne saisit pas l'individuel
If [M:PLF1]CSTTOTCLL(nolign-1)<>0
 mkstat = 2 : End
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : pas de récupération automatique des coûts
If L_STAGE_NON_DEF = [M:PLF1]STG([M:PLF0]LIGCUR-1) Then
  End
Endif

## Si un formateur interne existe au niveau de la session ou du stage,
## on valorise ses charges salariales et patronales
If VALEUR=0
 Read[F:ADI]CODE=10451;[M]TYPCRG(nolign-1)
 If !fstat & [F:ADI]N1<3 & [F:ADI]N2=2     : # coût calculable pour formateur interne
  Gosub RECH_FORMATEUR
  If FORMATEUR<>""
   Call TAUX_HORAIRE (FORMATEUR,CTRFORM,date$,TAUX,[F:ADI]N1,2,1) From TRTCOUT
   VALEUR = arr(TAUX*NBH,0.01) :# Nb d'heures imputables
  # SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts du formateur : DEBUT
  Else
   Local Integer FLAG_TROUVE : FLAG_TROUVE = 1
   Gosub RECH_FORMATEUR_NBHRES
   If FLAG_TROUVE = 2 Then
    Call CALC_COUT_FORMATEUR([M:PLF1]CPY([M:PLF0]LIGCUR-1),date$,TAUX,[F:ADI]N1,2,1)
    VALEUR = arr(TAUX*NBH,0.01)
   Endif
  # SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts du formateur : FIN
  Endif
 Endif
Endif
End

######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation : si on modifie le montant, le
# flag passe à Manuel.
######################################################################################
Subprog AM_CSTTOTIDV(VALEUR)
Variable Decimal VALEUR
  [M:PLF1]TYPCST(nolign-1) = 2 # Manuel
  Affzo [M:PLF1]TYPCST(nolign-1)
  # X3-17093 - MAJ LNKREP lié TIVAN
  Gosub SET_FLGCHG From SUBPLF2
End


$RECH_FORMATEUR
Local Decimal TAUX, NBH
Local Char    FORMATEUR(GLONEML), CTRFORM(GLONHRCTR)
Local Char    CATEG (3)
If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
If clalev([F:STG])=0 : Local File STAGE    [STG] : Endif
If [M:PLF1]SES([M:PLF0]LIGCUR-1)<>""
 Read [HRSES]SES0=[M:PLF1]SES([M:PLF0]LIGCUR-1)
 If !fstat & [F:HRSES]TCHEMP<>""
  FORMATEUR = [F:HRSES]TCHEMP
  CTRFORM   = [F:HRSES]CTRNUM
  NBH       = [F:HRSES]NBRHOUIPT
 Endif
Endif
If FORMATEUR=""
 Read [STG]STG0=[M:PLF1]STG([M:PLF0]LIGCUR-1)
 If !fstat & [F:STG]TCHEMP<>""
  # SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts du formateur interne.
  # Lors de la recherche du formateur interne de la session ou du stage, quand on prend
  # celui du stage, c'est la variable FORMATEU qui est renseignée au lieu de FORMATEUR (BUG n° 67263)
  # FORMATEU  = [F:STG]TCHEMP
  FORMATEUR = [F:STG]TCHEMP
  CTRFORM   = [F:STG]CTRNUM
  NBH       = [F:STG]NBRHOUIPT
 Endif
Endif
Return

# SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71873
$RECH_FORMATEUR_PROPOS
Local Decimal TAUX, NBH
Local Char    FORMATEUR(GLONEML), CTRFORM(GLONHRCTR)
Local Char    CATEG (3)
If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
If clalev([F:STG])=0 : Local File STAGE    [STG] : Endif
If [F:DEM]SES<>""
 Read [HRSES]SES0=[F:DEM]SES
 If !fstat & [F:HRSES]TCHEMP<>""
  FORMATEUR = [F:HRSES]TCHEMP
  CTRFORM   = [F:HRSES]CTRNUM
  NBH       = [F:HRSES]NBRHOUIPT
 Endif
Endif
If FORMATEUR=""
 Read [STG]STG0=[F:DEM]STG
 If !fstat & [F:STG]TCHEMP<>""
  FORMATEUR = [F:STG]TCHEMP
  CTRFORM   = [F:STG]CTRNUM
  NBH       = [F:STG]NBRHOUIPT
 Endif
Endif
Return

#**######################################################################################
#*
#* SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts du formateur
#* Recherche du nombre d'heures quand aucun formateur n'est identifié à condition
#* que ce soit une session ou un stage interne.
#* SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71873
#*!
$RECH_FORMATEUR_NBHRES_PROPOS
  If [F:DEM]SES<>""
    Read [HRSES]SES0=[F:DEM]SES
    # FQ71040 - MABON 22/03/11 - Ajout conditions sur ORG et TCHNAM pour le formateur externe
    If !fstat & [F:HRSES]TCHEMP="" & [F:HRSES]FRTINT = 2 & [F:HRSES]ORG="" & [F:HRSES]TCHNAM="" Then
      NBH = [F:HRSES]NBRHOUIPT
      FLAG_TROUVE = 2
    Endif
  Endif
  If FLAG_TROUVE = 1 Then
    Read [STG]STG0=[F:DEM]STG
    # FQ71040 - MABON 22/03/11 - Ajout conditions sur ORG et TCHNAM pour le formateur externe
    If !fstat & [F:STG]TCHEMP="" & [F:STG]FRTINT = 2 & [F:STG]ORG="" & [F:STG]TCHNAM=""  Then
      NBH = [F:STG]NBRHOUIPT
      FLAG_TROUVE = 2
    Endif
  Endif
Return

#**######################################################################################
#*
#* SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts du formateur
#* Recherche du nombre d'heures quand aucun formateur n'est identifié à condition
#* que ce soit une session ou un stage interne.
#*!
$RECH_FORMATEUR_NBHRES
  If [M:PLF1]SES([M:PLF0]LIGCUR-1)<>""
    Read [HRSES]SES0=[M:PLF1]SES([M:PLF0]LIGCUR-1)
    # FQ71040 - MABON 22/03/11 - Ajout conditions sur ORG et TCHNAM pour le formateur externe
    If !fstat & [F:HRSES]TCHEMP="" & [F:HRSES]FRTINT = 2 & [F:HRSES]ORG="" & [F:HRSES]TCHNAM=""  Then
      NBH = [F:HRSES]NBRHOUIPT
      FLAG_TROUVE = 2
    Endif
  Endif
  If FLAG_TROUVE = 1 Then
    Read [STG]STG0=[M:PLF1]STG([M:PLF0]LIGCUR-1)
    # FQ71040 - MABON 22/03/11 - Ajout conditions sur ORG et TCHNAM pour le formateur externe
    If !fstat & [F:STG]TCHEMP="" & [F:STG]FRTINT = 2 & [F:STG]ORG="" & [F:STG]TCHNAM=""  Then
      NBH = [F:STG]NBRHOUIPT
      FLAG_TROUVE = 2
    Endif
  Endif
Return

#**######################################################################################
#*
#* SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts du formateur
#* Calcul du coût du formateur quand il n'est pas identifié : soit le coût moyen,
#* soit le taux horaire de la catégorie stockée dans une nouvelle valeur paramètre société
#* (TRNCAT), en fonction d'une nouvelle valeur paramètre société de calcul du taux horaire
#* (CLCHRSRAT).
#*
#* @param P_CPY     : Société
#* @param P_DATE    : Date utilisée pour le calcul du coût moyen
#* @param P_TAUX    : Taux calculé, renvoyé à la fonction appelante
#* @param P_TYPTX   : 1 = taux salarial, 2 = taux patronal
#* @param P_TYPCOUT : 1 = Prévisionnel, 2 = Réel
#* @param P_COLONNE : 1 = total, 2 = imputable
#*!
Subprog CALC_COUT_FORMATEUR(P_CPY,P_DATE,P_TAUX,P_TYPTX,P_TYPCOUT,P_COLONNE)
Value    Char    P_CPY
Value    Date    P_DATE
Variable Decimal P_TAUX
Value    Decimal P_TYPTX
Value    Integer P_TYPCOUT
Value    Integer P_COLONNE

Local Char    L_VALEUR(3), L_TRNCAT(3)
Local Integer L_CLCHRSRAT

If FLAG_MESSAGE = 1 # Non
  # Calcul en cours...
  Call TEMPON(mess(105,100,1)) From GESECRAN
Endif

Raz P_TAUX
# Quel est le mode de calcul : 1 = coût moyen, 2 = taux horaire
Local Char L_SOCIETE(GLONCPY)
If P_CPY <> "" Then
  # CPY contient la société de la ligne
  L_SOCIETE = P_CPY
Else
  # CPY de la ligne n'est pas renseigné pour une demande collective
  If clalev([M:PLF0])>0 Then
    If [M:PLF0]CPYPLF <> "" Then
      # Je prends la société du plan
      L_SOCIETE = [M:PLF0]CPYPLF
    Elsif [M:PLF0]FCYPLF <> "" Then
      Read [FCY]FCY0=[M:PLF0]FCYPLF
      If !fstat Then
        # ou la société du site du plan
        L_SOCIETE = [F:FCY]LEGCPY
      Endif
    Endif
  Else
    L_SOCIETE=""
  Endif
Endif
Call PARAM(L_SOCIETE,"CLCHRSRAT",L_VALEUR)From ADOVAL
L_CLCHRSRAT = val(L_VALEUR)
Case L_CLCHRSRAT
  When 0  # Fiche 70539 - SYMEU - 11/01/2011
          Call MESSAGE(mess(206,10717,1)) From GESECRAN
  When 1  # Coût moyen
          Call CALC_COUT_MOYEN_FORMATEUR(P_DATE,P_TYPTX,P_TYPCOUT,P_COLONNE,P_TAUX)
  When 2  # Taux horaire
          Call PARAM(L_SOCIETE,"TRNCAT",L_TRNCAT)From ADOVAL
          If L_TRNCAT <> "" Then
            # Recherche des taux horaires de la catégorie 2483
            Read[F:ADI2]CODE=10453;L_TRNCAT
            If !fstat
              If P_TYPTX=2 Then     # Taux patronal
                If P_COLONNE= 1     # Total
                  P_TAUX = val([F:ADI2]A2)
                Else                # Imputable
                  P_TAUX = [F:ADI2]N2
                Endif
              Else                  # Taux salarial
                If P_COLONNE= 1     # Total
                  P_TAUX = val([F:ADI2]A1)
                Else                # Imputable
                  P_TAUX = [F:ADI2]N1
                Endif
              Endif
            Endif
          Endif
  When Default
Endcase

If FLAG_MESSAGE = 1 # Non
  # Suppression du message
  Call TEMPOFF From GESECRAN
Endif

End

#**######################################################################################
#*
#* SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts du formateur
#* Calcul du taux moyen des formateurs internes actifs
#*
#* @param P_DATE       : date utilisée pour le calcul du coût moyen
#* @param P_TYPTX      : 1=Salarial, 2=Patronal
#* @param P_TYPCOUT    : 1=Prévisionnel, 2=Réel
#* @param P_COLONNE    : 1=Total, 2= Imputable
#* @param P_TAUX       : taux calculé
#*!
Subprog CALC_COUT_MOYEN_FORMATEUR(P_DATE,P_TYPTX,P_TYPCOUT,P_COLONNE,P_TAUX)
Value    Date    P_DATE
Value    Decimal P_TYPTX
Value    Integer P_TYPCOUT
Value    Integer P_COLONNE
Variable Decimal P_TAUX

  If clalev([F:TRN])=0 : Local File TRAINER [TRN] : Endif
  Local Decimal TAUX_CALCULE
  Local Integer NB_CALCULE

  # On ne prend que les formateurs actifs
  For [F:TRN] Where ENAFLG=2
    # Recherche du taux
    Call RESULT_TAUX([F:TRN]REFNUM,[F:TRN]CTRNUM,P_COLONNE,P_TYPTX,P_TYPCOUT,P_DATE,TAUX_CALCULE,NB_CALCULE)
  Next
  If NB_CALCULE > 0 Then
    P_TAUX = TAUX_CALCULE/NB_CALCULE
  Endif

End

#**######################################################################################
#*
#* SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts du formateur
#* Récupération du taux horaire du salarié reçu en paramètre et alimentation des variables
#* contenant la somme des taux horaires et le nombre de formateurs
#*
#* @param P_REFNUM    : matricule
#* @param P_CONTRAT   : contrat
#* @param P_COLONNE   : 1 = Total, 2 = Imputable
#* @param P_TYPTX     : 1 = taux salarial, 2 = taux patronal
#* @param P_TYPCOUT   : 1 = Prévisionnel, 2 = Réel
#* @param P_DATE_TAUX : date utilisée pour le calcul du coût moyen
#* @param P_TAUX_R    : cumul des taux
#* @param P_NB_R      : cumul du nombre de formateurs
#*!
Subprog RESULT_TAUX(P_REFNUM,P_CONTRAT,P_COLONNE,P_TYPTX,P_TYPCOUT,P_DATE_TAUX,P_TAUX_R,P_NB_R)
Value    Char    P_REFNUM, P_CONTRAT
Value    Integer P_COLONNE
Value    Decimal P_TYPTX
Value    Integer P_TYPCOUT
Value    Date    P_DATE_TAUX
Variable Decimal P_TAUX_R
Variable Integer P_NB_R

  # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUFOR, on calcule ou pas les coûts du formateur
  If GCALCOUFOR<>2 Then End : Endif

  Local Decimal TAUX
  Call TAUX_HORAIRE(P_REFNUM, P_CONTRAT, P_DATE_TAUX, TAUX, P_TYPTX, P_TYPCOUT, P_COLONNE) From TRTCOUT
  If TAUX > 0 Then
    P_TAUX_R += TAUX
    P_NB_R   += 1
  Endif
End

#**######################################################################################
#*
#* SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts des participants
#* Calcul du taux moyen des participants
#*
#* @param P_CAT     : catégorie 2483
#* @param P_DATE_1  : date limite pour la date de contrat
#* @param P_DATE_2  : date minimum pour la date de sortie du contrat
#* @param P_TXSAL1  : salarial total
#* @param P_TXSAL2  : salarial imputable
#* @param P_TXPAT1  : patronal total
#* @param P_TXPAT2  : patronal imputable
#*!
Subprog CALC_COUT_MOYEN_PARTICIPANT(P_CAT,P_DATE_1,P_DATE_2,P_TXSAL1,P_TXSAL2,P_TXPAT1,P_TXPAT2)
Value    Char    P_CAT
Value    Date    P_DATE_1, P_DATE_2
Variable Decimal P_TXSAL1, P_TXSAL2, P_TXPAT1, P_TXPAT2

  Raz P_TXSAL1, P_TXSAL2, P_TXPAT1, P_TXPAT2
  If P_CAT = "" Then
    End
  Endif

  If FLAG_MESSAGE = 1 # Non
    # Calcul en cours...
    Call TEMPON(mess(105,100,1)) From GESECRAN
  Endif

  Local Integer FLAG_TROUVE # 1 = Non, 2 = Oui
  # Variables de cumul des taux des participants
  Local Decimal L_TX_SAL1, L_TX_SAL2, L_TX_PAT1, L_TX_PAT2
  # Variables comptant le nombre de taux trouvés
  Local Integer L_NB_SAL1, L_NB_SAL2, L_NB_PAT1, L_NB_PAT2
  # Critères de sélection du contrat et du site pour le link
  Local Char    CRITERE_CONTRAT(100), CRITERE_SITE(100)

  # Critères sur le contrat ou le site
  # Contrat : la catégorie du contrat doit être égale à celle du stage, la date de
  # contrat doit être <= date reçue en paramètre (date du jour). De plus, si le site du
  # plan est renseigné, le contrat doit être sur ce site.
  # Site : Si la société du plan est renseignée, on ne prend que les sites qui sont ratta-
  # chés à cette société.
  CRITERE_CONTRAT  = '[F:HRCTR]CATFRT="'+P_CAT+'"'
  CRITERE_CONTRAT -= '& [F:HRCTR]CTRDAT<=['+format$(GFMD,P_DATE_1)+']'
  If [M:PLF0]FCYPLF <> "" Then
    CRITERE_CONTRAT -= '& [F:HRCTR]ETRFCY="'+[M:PLF0]FCYPLF+'"'
    CRITERE_SITE    = '1=1'
  Else
    CRITERE_CONTRAT -= '& 1=1'
    If [M:PLF0]CPYPLF <> "" Then
      CRITERE_SITE  = '[F:FCY]LEGCPY ="'+[M:PLF0]CPYPLF+'"'
    Else
      CRITERE_SITE  = '1=1'
    Endif
  Endif

  Link [F:ID] With [F:HRCTR]CTR0(1)=[F:ID]REFNUM,
&                  [F:FCY]FCY0=[F:HRCTR]ETRFCY,
&                  [F:CPY]CPY0=[F:FCY]LEGCPY
&           As     [LIEN]
&           Where  [F:ID]ENAFLG = 2
&           and    evalue(CRITERE_SITE) and evalue(CRITERE_CONTRAT)
&           Order By Key ID0

  For [LIEN]
    FLAG_TROUVE = 1

    If [F:ID]FLGMULCTR <> 2 Then # Mono-contrat
      # Lecture du contrat du salarié le plus récent
      Filter [F:CTR2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT<=P_DATE_1
      Read [CTR2]CTR0 Last
      Filter [CTR2]
      If !fstat and [F:CTR2]CTRDAT = [F:HRCTR]CTRDAT Then
        # Le contrat en cours dans le link est le plus récent
        FLAG_TROUVE = 2
      Endif
    Else # Multi-contrat
      # Parcours des contrats valides du salarié
      If ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=P_DATE_2)
        FLAG_TROUVE = 2
      Endif
    Endif
    If FLAG_TROUVE = 2 Then
      # Récupération des taux horaires, màj total taux horaire et nb participants
      Call CALC_QUATRE_TAUX([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,P_DATE_1,L_TX_SAL1,L_TX_SAL2,L_TX_PAT1,L_TX_PAT2,L_NB_SAL1,L_NB_SAL2,L_NB_PAT1,L_NB_PAT2)
    Endif
  Next

  # Calcul des quatre taux à renvoyer
  # taux salarial total
  If L_NB_SAL1 > 0 Then
    P_TXSAL1 = L_TX_SAL1/L_NB_SAL1
  Endif
  # taux salarial imputable
  If L_NB_SAL2 > 0 Then
    P_TXSAL2 = L_TX_SAL2/L_NB_SAL2
  Endif
  # taux patronal total
  If L_NB_PAT1 > 0 Then
    P_TXPAT1 = L_TX_PAT1/L_NB_PAT1
  Endif
  # taux patronal imputable
  If L_NB_PAT2 > 0 Then
    P_TXPAT2 = L_TX_PAT2/L_NB_PAT2
  Endif

  If FLAG_MESSAGE = 1 # Non
    # Suppression du message
    Call TEMPOFF From GESECRAN
  Endif

End

#**######################################################################################
#*
#* SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts des participants
#* Calcul des 4 taux du participant reçu en paramètre
#*
#* @param P_REFNUM  # matricule du participant
#* @param P_CTRNUM  # contrat du participant
#* @param P_DATE    # date pour la recherche du taux
#* @param P_TX_SAL1 # taux salarial total
#* @param P_TX_SAL2 # taux salarial imputable
#* @param P_TX_PAT1 # taux patronal total
#* @param P_TX_PAT2 # taux patronal imputable
#* @param P_NB_SAL1 # nb taux salarial total
#* @param P_NB_SAL2 # nb taux salarial imputable
#* @param P_NB_PAT1 # nb taux patronal total
#* @param P_NB_PAT2 # nb taux patronal imputable
#*!
Subprog CALC_QUATRE_TAUX(P_REFNUM,P_CTRNUM,P_DATE,P_TX_SAL1,P_TX_SAL2,P_TX_PAT1,P_TX_PAT2,P_NB_SAL1,P_NB_SAL2,P_NB_PAT1,P_NB_PAT2)
Value Char P_REFNUM, P_CTRNUM
Value Date P_DATE
Variable Decimal P_TX_SAL1, P_TX_SAL2, P_TX_PAT1, P_TX_PAT2
Variable Integer P_NB_SAL1, P_NB_SAL2, P_NB_PAT1, P_NB_PAT2

  # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUPAR, on calcule ou pas les coûts du participant
  If GCALCOUPAR<>2 Then End : Endif

  # Variable ramenant le taux de la fonction TAUX_HORAIRE
  Local Decimal TAUX

  # salarial total
  Call TAUX_HORAIRE (P_REFNUM,P_CTRNUM,P_DATE,TAUX,1,2,1) From TRTCOUT
  If TAUX > 0 Then
    P_TX_SAL1 += TAUX
    P_NB_SAL1 += 1
  Endif
  # salarial imputable
  Call TAUX_HORAIRE (P_REFNUM,P_CTRNUM,P_DATE,TAUX,1,2,2) From TRTCOUT
  If TAUX > 0 Then
    P_TX_SAL2 += TAUX
    P_NB_SAL2 += 1
  Endif
  # patronal total
  Call TAUX_HORAIRE (P_REFNUM,P_CTRNUM,P_DATE,TAUX,2,2,1) From TRTCOUT
  If TAUX > 0 Then
    P_TX_PAT1 += TAUX
    P_NB_PAT1 += 1
  Endif
  # patronal imputable
  Call TAUX_HORAIRE (P_REFNUM,P_CTRNUM,P_DATE,TAUX,2,2,2) From TRTCOUT
  If TAUX > 0 Then
    P_TX_PAT2 += TAUX
    P_NB_PAT2 += 1
  Endif
End

######################## Cout imputable collectif ########################

Subprog AS_CSTIPTCLL(VALEUR)
Variable Decimal VALEUR
Call AS_CSTIPTCLL(VALEUR) From TRTCOUT
End

Subprog C_CSTIPTCLL(VALEUR)
Variable Decimal VALEUR
Call C_CSTIPTCLL(VALEUR) From TRTCOUT
End

Subprog AM_CSTIPTCLL(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0
 # SYMEU : EXI 66191 LOT 10 - V6.1 : AUTRE BUG : arrondi à 2 décimales
 # [M:PLF1]CSTIPTIDV(nolign-1) = arr((VALEUR/[M:PLF1]NBREMP([M:PLF0]LIGCUR-1)),0.1)
 [M:PLF1]CSTIPTIDV(nolign-1) = arr((VALEUR/[M:PLF1]NBREMP([M:PLF0]LIGCUR-1)),0.01)
 Affzo [M:PLF1]CSTIPTIDV(nolign-1)
Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation. On passe le flag en manuel
[M:PLF1]TYPCST(nolign-1) = 2 # Manuel
Affzo [M:PLF1]TYPCST(nolign-1)
# X3-17093 - MAJ LNKREP lié TIVAN
Gosub SET_FLGCHG From SUBPLF2
End

######################## Cout imputable individuel ########################

Subprog AS_CSTIPTIDV(VALEUR)
Variable Decimal VALEUR
Local Decimal VALMG, NBRDAY

## Si un coût collectif a été saisi, on ne saisit pas l'individuel
If [M:PLF1]CSTIPTCLL(nolign-1)<>0
 mkstat = 2 : End
Endif

## Si un coût d'hébergement a été saisi, on valorise son coût en fonction du Minimum garanti
## Frais d'hebergement imputable individuel = 5*MG*Nb jours
# SYMEU : EXI 66191 LOT 10 - V6.1 : seulement si différent du stage non défini
#If [M:PLF1]TYPCRG(nolign-1)="HEB" & VALEUR=0
If [M:PLF1]TYPCRG(nolign-1)="HEB" & VALEUR=0 & L_STAGE_NON_DEF <> [M:PLF1]STG([M:PLF0]LIGCUR-1)
 Gosub MINIMUM_GARANTI
 # SYMEU : EXI 66191 LOT 10 - V6.1 : AUTRE BUG : arrondi à 2 décimales
 # If [M]CSTTOTIDV(nolign-1)<arr(5*VALMG*NBRDAY,0.1)
 If [M]CSTTOTIDV(nolign-1)<arr(5*VALMG*NBRDAY,0.01)
  VALEUR = [M]CSTTOTIDV(nolign-1)
 Else
  # SYMEU : EXI 66191 LOT 10 - V6.1 : AUTRE BUG : arrondi à 2 décimales
  # VALEUR = arr(5*VALMG*NBRDAY,0.1)
  VALEUR = arr(5*VALMG*NBRDAY,0.01)
 Endif
Endif

## Si un formateur interne existe au niveau de la session ou du stage,
## on valorise ses charges salariales et patronales en fonction de sa catégorie 2483
# SYMEU : EXI 66191 LOT 10 - V6.1 : seulement si différent du stage non défini
#If VALEUR=0
If VALEUR=0 & L_STAGE_NON_DEF <> [M:PLF1]STG([M:PLF0]LIGCUR-1)
 Read[F:ADI]CODE=10451;[M]TYPCRG(nolign-1)
 If !fstat & [F:ADI]N1<3 & [F:ADI]N2=2       : # coût calculable pour formateur interne
  Gosub RECH_FORMATEUR
  If FORMATEUR<>""
   Call TAUX_HORAIRE (FORMATEUR,CTRFORM,date$,TAUX,[F:ADI]N1,2,2) From TRTCOUT
   # SYMEU : EXI 66191 LOT 10 - V6.1 : AUTRE BUG : arrondi à 2 décimales
   # VALEUR = arr(TAUX*NBH,0.1) :# Nb d'heures imputables
   VALEUR = arr(TAUX*NBH,0.01) :# Nb d'heures imputables
  # SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts du formateur : DEBUT
  Else
   Local Integer FLAG_TROUVE : FLAG_TROUVE = 1
   Gosub RECH_FORMATEUR_NBHRES
   If FLAG_TROUVE = 2 Then
    Call CALC_COUT_FORMATEUR([M:PLF1]CPY([M:PLF0]LIGCUR-1),date$,TAUX,[F:ADI]N1,2,2)
    VALEUR = arr(TAUX*NBH,0.01)
   Endif
  # SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts du formateur : FIN
  Endif
 Endif
Endif
If VALEUR=0 : VALEUR=[M]CSTTOTIDV(nolign-1) : Endif
End


Subprog C_CSTIPTIDV(VALEUR)
Variable Decimal VALEUR
Local Decimal VALMG, NBRDAY
If VALEUR>[M]CSTTOTIDV(nolign-1)
 # Coût imputable supérieur au coût total
 GMESSAGE = mess(7,10717,1)
 mkstat = 2 : End
Endif
## On contrôle que le coût imputable individuel n'est pas > au minimum garanti en cas de frais d'hebergement
# SYMEU : EXI 66191 LOT 10 - V6.1 : seulement si différent du stage non défini
#If [M]TYPCRG(nolign-1)="HEB"
If [M]TYPCRG(nolign-1)="HEB" & L_STAGE_NON_DEF <> [M:PLF1]STG([M:PLF0]LIGCUR-1)
 Gosub MINIMUM_GARANTI
 # SYMEU : EXI 66191 LOT 10 - V6.1 : AUTRE BUG : arrondi à 2 décimales
 # If VALEUR>arr(5*VALMG*NBRDAY,0.1)
 If VALEUR>arr(5*VALMG*NBRDAY,0.01)
  # Coût imputable supérieur au minimum garanti
  GMESSAGE=mess(51,10717,1)
  # SYMEU : EXI 66191 LOT 10 - V6.1 : ajout du minimum garanti dans le message
  GMESSAGE-=num$(arr(5*VALMG*NBRDAY,0.01))
  mkstat=2 : End
 Endif
Endif
End

######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation. On passe le flag en manuel
######################################################################################
Subprog AM_CSTIPTIDV(VALEUR)
Variable Decimal VALEUR
  [M:PLF1]TYPCST(nolign-1) = 2 # Manuel
  Affzo [M:PLF1]TYPCST(nolign-1)
  # X3-17093 - MAJ LNKREP lié TIVAN
  Gosub SET_FLGCHG From SUBPLF2
End

$MINIMUM_GARANTI
Local Char    VALPAR(6)
Local Date DATREF

If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
If clalev([F:STG])=0 : Local File STAGE    [STG] : Endif

DATREF=date$

## Recherche du minimum garanti et du nombre de jours
If [M:PLF1]SES([M:PLF0]LIGCUR-1)<>""
 Read [HRSES]SES0=[M:PLF1]SES([M:PLF0]LIGCUR-1)
 If !fstat :
  NBRDAY = [F:HRSES]NBRDAY
  DATREF = [F:HRSES]ENDDAT
 Endif
Endif
If NBRDAY=0
 Read [STG]STG0=[M:PLF1]STG([M:PLF0]LIGCUR-1)
 If !fstat :
  NBRDAY = [F:STG]NBRDAY
  DATREF = [F:STG]ENDVLY
 Endif
Endif

Call RECUP_MG([M:PLF1]CPY([M:PLF0]LIGCUR-1),[M:PLF1]FCY([M:PLF0]LIGCUR-1),[M:PLF1]EMP([M:PLF0]LIGCUR-1),DATREF,VALMG) From TRTCOUT

Return


######################################################################################
## Etiquettes de l'écran PLF2
######################################################################################
Subprog AV_NBRSTG
Local Integer I
## Chargement des coûts dans le deuxième tableau (détail des coûts par stage) à partir
## du tableau invisible
[M:PLF2]NBRDET = 0
For I=0 To [M:PLF2]NBRINV2-1
 If [M:PLF2]STGI2(I)=[M:PLF2]STG2(nolign-1)
  If [M:PLF2]NBRDET < dim([M:PLF2]TYPCRGSTG) Then # SYMEU - fiche 71793 (tester limite variable bas de tableau)
    [M:PLF2]TYPCRGSTG([M:PLF2]NBRDET) = [M:PLF2]TYPCRGI2(I)
    [M:PLF2]CSTTOT([M:PLF2]NBRDET)    = [M:PLF2]CSTTOTI2(I)
    [M:PLF2]CSTIPT([M:PLF2]NBRDET)    = [M:PLF2]CSTIPTI2(I)
    [M:PLF2]NBRDET += 1
  Endif # SYMEU - fiche 71793 (tester limite variable bas de tableau)
 Endif
Next
Affzo [PLF2]15
End


######################################################################################
## Etiquettes de l'écran PLF3
# SYMEU : EXI 66191 LOT 10 - V6.1 : onglet des coûts par type de financement
######################################################################################
Subprog AV_NBRFIN
Local Integer I
## Chargement des coûts dans le deuxième tableau (détail des coûts par type de frais
## pour le type de financement en cours) à partir du tableau invisible
[M:PLF3]NBRCRG = 0
For I=0 To [M:PLF3]NBRINV3-1
 If [M:PLF3]TYPFINI(I)=[M:PLF3]TYPFIN3(nolign-1)
   If [M:PLF3]NBRCRG < dim([M:PLF3]TYPCRGFIN) Then # SYMEU - fiche 71793 (tester limite variable bas de tableau)
    [M:PLF3]TYPCRGFIN([M:PLF3]NBRCRG) = [M:PLF3]TYPCRGFINI(I)
    [M:PLF3]CSTTOTFIN([M:PLF3]NBRCRG) = [M:PLF3]CSTTOTFINI(I)
    [M:PLF3]CSTIPTFIN([M:PLF3]NBRCRG) = [M:PLF3]CSTIPTFINI(I)
    [M:PLF3]NBRCRG += 1
   Endif # SYMEU - fiche 71793 (tester limite variable bas de tableau)
 Endif
Next
Affzo [PLF3]15

End

