######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation. On passe le flag en manuel
######################################################################################
Subprog AM_TYPCRG(VALEUR)
Variable Char    VALEUR()
  [M:PLF1]TYPCST(nolign-1) = 2 # Manuel
