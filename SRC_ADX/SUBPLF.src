$AP_FILGAUCHE
If currbox = BOXPIC
 WPICK=2 : Gosub RAFF_PIC
Endif
Return


$TIROIR
If currbox = BOXPIC
 Gosub REMP_PIC
 WPICK=2
 Gosub RAFF_PIC
Endif
Return

$FILTRE
FILTSUP = "1=1"
If GACTION<>"SELYEA" Then
  If [M:PFI]NAL=2
   FILTSUP -= '& FCY = ""'
  Else
    If [M:PFI]ALLCPY<>2
      FILTSUP -= '& CPY = "'+[M:PFI]CPY+'"'
    Endif
    If [M:PFI]ALLFCY<>2
      FILTSUP -= '& FCY = "'+[M:PFI]FCY+'"'
    Endif
  Endif
  #LIPET - 2017-05-11 - X3-35993 - START
  # Issue X3-11279 - 2017-01-24 by BRBAN : added Department filter
  If [M:PFI]ALLSRV<>2
    FILTSUP -= '& SRV = "'+[M:PFI]SRV+'"'
  Endif
  # -
  #LIPET - 2017-05-11 - X3-35993 - END
Endif
Return

$LIENS0
# SYMEU : EXI 66191 LOT 10 - V6.1 : (dé)grisage du site et de la société
#TIVAN - Start
# JML 22/10/15 Le Call AM_ va écraser [M], du coup je surcharge [M] Ici :#TIVAN
[M:PLF0]YEAPLF = [F:PLF]YEAPLF : [M:PLF0]CPYPLF = [F:PLF]CPYPLF : [M:PLF0]FCYPLF = [F:PLF]FCYPLF
#TIVAN - End
Call AM_CPYPLF([F:PLF]CPYPLF)
Call AM_FCYPLF([F:PLF]FCYPLF)

# SYMEU : EXI 66191 LOT 10 - V6.1 : récupération du budget de référence
Call GET_AMTBUDREF([F:PLF]YEAPLF,[F:PLF]CPYPLF,[F:PLF]FCYPLF)

I = 0
Return

