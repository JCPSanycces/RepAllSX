End
# FQ81085 - MABON 22/05/12 - Controls that type is in the same LEG than LEGPLF
Subprog C_TYPFINBUD(VALEUR)
Variable Char    VALEUR()

  If dim([M:PLF0]LEGPLF)>0 & [M:PLF0]LEGPLF<>"" Then
    If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
    Read [F:ADI]CODE=10462;VALEUR
    If !fstat & [F:ADI]LEG<>"" Then
      If [F:ADI]LEG<>[M:PLF0]LEGPLF Then
        GMESSAGE=mess(278,10717,1)-[M:PLF0]LEGPLF : # La législation du type doit être
        mkstat=2
      Endif
    Endif
  Endif
End
######################################################################################
## 25/05/2012 PCA - Refresh screen after legislation changed.
######################################################################################
Subprog AM_LEGPLF(VALEUR)
Variable Char    VALEUR()

  GCURLEG = VALEUR
  Call DISPLAY_HIDE() From SUBPLFLEG
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran PLF0) 05/06/2012 16:08:06 (MABON)
######################################################################################
Subprog AP_LEGPLF(VALEUR)
Variable Char    VALEUR()
  GCURLEG = VALEUR
End

Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
#LIPET - 2017-05-11 - X3-35993 - START
If VALEUR=[0/0/0]
 VALEUR = gdat$(01,01,year(date$))
Endif
#LIPET - 2017-05-11 - X3-35993 - END
End

Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
#LIPET - 2017-05-11 - X3-35993 - START
[M:PLF0]ENDDAT = addmonth(VALEUR,12) - 1
If [M:PLF0]ENDDAT<>[0/0/0] & VALEUR>[M:PLF0]ENDDAT
 Call ECR_TRACE(mess(1,104,1)-">"-format$("D:"+GFMDAT,[M:PLF0]ENDDAT),1) From GESECRAN
 #### Date incorrecte
 mkstat = 2 : End
Endif
#LIPET - 2017-05-11 - X3-35993 - END
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
#LIPET - 2017-05-11 - X3-35993 - START
If day(VALEUR)<>day(eomonth(VALEUR)) Then
   GMESSAGE=mess(312,10717,1) : # La date de fin doit être le dernier jour d'un mois
   mkstat=2
Endif
If !mkstat Then Call CTRL_DATES_PLF([M:PLF0]STRDAT,VALEUR)From SUBPLF2 : Endif
#LIPET - 2017-05-11 - X3-35993 - END
End

Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
#LIPET - 2017-05-11 - X3-35993 - START
If VALEUR<[M:PLF0]STRDAT
 Call ECR_TRACE(mess(1,104,1)-"<"-format$("D:"+GFMDAT,[M:PLF0]STRDAT),1) From GESECRAN
 #### Date incorrecte
 mkstat = 2 : End
Endif
#LIPET - 2017-05-11 - X3-35993 - END
End

######################################################################################
