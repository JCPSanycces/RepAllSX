$ANNULE
Local Char MLEGPLF(5)
## Annulation des coûts
Local Char FILTSUP(240)
Gosub FILTRE
# SYMEU : EXI 66191 LOT 10 - V6.1 : on récupère la société et le site
# Filter [PLF] Where YEAPLF=[M:PLF0]YEAPLF & VERPLF=[M:PLF0]VERPLF & evalue(FILTSUP)
# FQ81085 - MABON 22/05/12 - Adding field LEGPLF
MLEGPLF=GCURLEG
If dim([M:PLF0]LEGPLF)>0 Then MLEGPLF=[M:PLF0]LEGPLF : Endif
Filter [PLF] Where YEAPLF=[M:PLF0]YEAPLF & VERPLF=[M:PLF0]VERPLF & evalue(FILTSUP)
&                & CPYPLF=[M:PLF0]CPYPLF & FCYPLF=[M:PLF0]FCYPLF
&                & LEGPLF=MLEGPLF
For [PLF]PLF0
 # SYMEU : EXI 66191 LOT 10 - V6.1 : on récupère la société et le site
 # Delete [PLC] Where YEAPLF=[F:PLF]YEAPLF & VERPLF=[F:PLF]VERPLF & NUMLIG=[F:PLF]NUMLIG
 # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
 Delete [PLC] Where YEAPLF=[F:PLF]YEAPLF & VERPLF=[F:PLF]VERPLF & NUMLIG=[F:PLF]NUMLIG
&                 & CPYPLF=[F:PLF]CPYPLF & FCYPLF=[F:PLF]FCYPLF
&                 & LEGPLF=[F:PLF]LEGPLF
 If fstat
  GOK = 0 : Call FSTA("PLC") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif

Filter [PLF]
## Mise à jour du flag suivi des demandes uniquement pour le plan definitif
If [M:PLF0]FLGCLO=2
 Filter [F:PLF]
 # SYMEU : EXI 66191 LOT 10 - V6.1 : on récupère la société et le site
 # For [F:PLF]PLF0 Where YEAPLF=[M:PLF0]YEAPLF & VERPLF=[M:PLF0]VERPLF & DEMNUM<>""
 # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
 For [F:PLF]PLF0 Where YEAPLF=[M:PLF0]YEAPLF & VERPLF=[M:PLF0]VERPLF & DEMNUM<>""
&                    & CPYPLF=[M:PLF0]CPYPLF & FCYPLF=[M:PLF0]FCYPLF
&                    & LEGPLF=MLEGPLF
   Filter [DML] Where DEMNUM=[F:PLF]DEMNUM & EMP=[F:PLF]EMP & FCY=[F:PLF]FCY & CATFRT=[F:PLF]CATFRT
&                   & CTRNUM=[F:PLF]CTRNUM & SRV=[F:PLF]SRV
   Readlock [F:DML]DML0 First
   Filter [DML] # SYMEU : EXI 66191 LOT 10 - V6.1
   If !fstat
     [F:DML]FLGINS=[F:DML]OLDFLGINS  :#Demande -> retour à l'état antérieur
     Rewrite [F:DML]
     If fstat
      GOK = 0 : Call FSTA("DML") From GLOCK : Break
     Endif
   Endif
   # SYMEU : EXI 66191 LOT 11 - V6.1 : effacement de l'année du plan définitif dans les demandes
   Readlock [F:DEM2]DEM0 = [F:PLF]DEMNUM
   If fstat=1 Then # enregistrement déjà verrouillé
     [V]GOK =-1
     [V]GLOCK="$"+"DEM2"-[F:PLF]DEMNUM
     Break
   Elsif fstat Then # autre erreur
     [V]GOK = 0
     Call RSTA("DEM2",[F:PLF]DEMNUM) From GLOCK
     Break
   Elsif [F:DEM2]YEAPLF <> "" Then
     Raz [F:DEM2]YEAPLF, [F:DEM2]STRDAT, [F:DEM2]ENDDAT  : # JML 27/08/15 STRDAT, ENDDAT :#TIVAN
     Rewrite [F:DEM2]
     If fstat Then
       [V]GOK = 0
       Call FSTA("DEM2") From GLOCK
       Break
     Endif
   Endif
 Next
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts : suppression - DEBUT
If GOK<=0 : Return : Endif
# FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
Delete [HRPLB] Where YEAPLF=[M:PLF0]YEAPLF & VERPLF=[M:PLF0]VERPLF
&                & CPYPLF=[M:PLF0]CPYPLF & FCYPLF=[M:PLF0]FCYPLF
&                & LEGPLF=MLEGPLF
If fstat
  GOK = 0 : Call FSTA("HRPLB") From GLOCK
Endif
If GOK=0 : Return : Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts : suppression - FIN

Return

# SYMEU : EXI 66191 LOT 10 - V6.1 : après la validation, s'ils sont renseignés, il faut
# griser la société et le site
$DEGRISE
  # (dé)grisage du site et de la société
  Call AM_CPYPLF([F:PLF]CPYPLF)
  Call AM_FCYPLF([F:PLF]FCYPLF)
Return

# SYMEU : EXI 66191 LOT 10 - V6.1 : pb de rafraîchissement de l'écran de picking quand
# on abandonne (BUG n° 67263)
$ABANDON
# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
FLAG_REVALO = 1
# SYMEU : EXI 66191 LOT 10 - V6.1 : (dé)grisage du site et de la société
Call AM_CPYPLF([F:PLF]CPYPLF)
Call AM_FCYPLF([F:PLF]FCYPLF)

If currbox = BOXPIC
  # Quand on est sur le tiroir du picking, on commence par dépicker toutes les lignes
  # avant de recharger la liste et de rafraîchir le picking
  For [LDML]CLE(3)
    # Je parcours la liste des demandes qui servent au picking et je me positionne sur
    # la ligne correspondante du picking (objet DE2)
    # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation - DEBUT
    # Filter [DDEM] Where DEMNUM=[F:DEM]DEMNUM
    # Read [DDEM] First
    # Filter [DDEM]
    Filter [TDM] Where DEMNUM=[F:DEM]DEMNUM
    Read [TDM] First
    Filter [TDM]
    # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation - FIN
    WPICK = 2
    Gosub DEPICK From GOBJSUB
  Next
Endif
Return

###################################################################################################
## Le picking
###################################################################################################

$REMP_PIC
If currbox = BOXPIC
 I=0
# SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation - DEBUT
# For [LDML]CLE(3)
#  I +=1
#  WTHM(I)    = [F:DEM]THM
#  Call LECTEXTRA(WDESTHM(I),"ATABDIV","LNGDES","457",WTHM(I)) From ATEXTRA
#  WSTG(I)    = [F:DEM]STG
#  WDEMNUM(I) = [F:DEM]DEMNUM
#  WNAM(I)    = [F:ID]NAM
#  WSRN(I)    = [F:ID]SRN # SYMEU : EXI 66191 LOT 10 - V6.1 : on renseigne le prénom
#  WDATDEM(I) = [F:DEM]DATDEM
#  WYEAPLF(I) = [F:DEM]YEAPLF
#  WCPY(I)    = [F:DML]CPY
#  WFCY(I)    = [F:DML]FCY
# Next
# For J=I+1 To dim(WTHM)
#  WTHM(J) = chr$(255)
# Next

 # Fiche 70502 - SYMEU - 11/01/20100 : EXI 66191 LOT 10 - V6.1 : picking des demandes de
 # formation : on dépicke tout car au changement d'enregistrement, les lignes restaient pickées
 For [F:TDM] Where [F:TDM]DEMNUM<>""
   Gosub DEPICK From GOBJSUB
 Next

 # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation
 Local Integer FLAG_TRAITE

 # SYMEU : EXI 66191 LOT 10 - V6.1 : RAZ de la table temporaire
 Delete [F:TDM] Where THM>=""
 # SYMEU : EXI 66191 LOT 10 - V6.1 : Alimentation de la table temporaire
 For [LDML]CLE(3)
  # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation - DEBUT
  # Vérification qu'il y a cohérence entre la société de la ligne de demande et
  # la société du plan, si elle est renseignée
  FLAG_TRAITE = 2
  If [M:PLF0]CPYPLF <> "" & [F:DML]CPY <> "" & [F:DML]CPY <> [M:PLF0]CPYPLF Then
    FLAG_TRAITE = 1
  Endif
  # Vérification qu'il y a cohérence entre le site de la ligne de demande et
  # le site du plan, s'il est renseigné
  If [M:PLF0]FCYPLF <> "" & [F:DML]FCY <> "" & [F:DML]FCY <> [M:PLF0]FCYPLF Then
    FLAG_TRAITE = 1
  Endif
  If [M:PLF0]FLGCLO = 2
    # Pas de picking sur plan définitif
    FLAG_TRAITE = 1
  Endif

  # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation - FIN

  If FLAG_TRAITE = 2 Then # SYMEU : EXI 66191 LOT 10 - V6.1
    I +=1
    Raz [F:TDM]
    [TDM]THM    = [F:DEM]THM
    Call LECTEXTRA([TDM]DESTHM,"ATABDIV","LNGDES","10457",[TDM]THM) From ATEXTRA
    [TDM]STG    = [F:DEM]STG
    [TDM]DEMNUM = [F:DEM]DEMNUM
    [TDM]NAM    = [F:ID]NAM
    [TDM]SRN    = [F:ID]SRN # SYMEU : EXI 66191 LOT 10 - V6.1 : on renseigne le prénom
    [TDM]DATDEM = [F:DEM]DATDEM
    [TDM]YEAPLF = [F:DEM]YEAPLF
    [TDM]CPY    = [F:DML]CPY
    [TDM]FCY    = [F:DML]FCY
    Read [F:FCY]FCY0=[F:ECT]FCY
    If !fstat Then
      [TDM]LEG  = [F:FCY]LEG
    Endif
    Write [F:TDM]
  Endif # SYMEU : EXI 66191 LOT 10 - V6.1
 Next
 # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation - FIN
 adxmxl = I
 # 40594
 SAVADXMXL = adxmxl

Endif
Return

$RAFF_PIC
# SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation : on dépicke tout
# car au changement d'enregistrement, les lignes restaient pickées
# Fiche 70502 - SYMEU - 11/01/2011 : déplacé dans REMP_FIC
#If currbox=BOXPIC : # Demande
#  For [F:TDM] Where [F:TDM]DEMNUM<>""
#    Gosub DEPICK From GOBJSUB
#  Next
#Endif

## Raffraichissement des listes de picking pour les lignes déjà saisies
For I=0 To [M:PLF1]NBRPLF-1
 If [M:PLF1]DEMNUM(I)<>"" & currbox=BOXPIC : # Demande
  # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation - DEBUT
  # Filter [DDEM] Where DEMNUM=[M:PLF1]DEMNUM(I)
  # Read [DDEM] First
  # Filter [DDEM]
  Filter [TDM] Where DEMNUM=[M:PLF1]DEMNUM(I)
  Read [TDM] First
  Filter [TDM]
  # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation - FIN
  # SYMEU : EXI 66191 LOT 10 - V6.1 - Si la demande du plan n'est pas dans la liste gauche
  # on ne doit pas aller dans depick / repick (BUG n° 67263)
  # If    WPICK=1 : Gosub DEPICK From GOBJSUB
  # Elsif WPICK=2 : Gosub REPICK From GOBJSUB
  # Endif
  If !fstat Then
    If    WPICK=1 : Gosub DEPICK From GOBJSUB
    Elsif WPICK=2 : Gosub REPICK From GOBJSUB
    Endif
  Else Gosub DEPICK From GOBJSUB
  Endif
 Endif
Next I

# Fiche 70502 - SYMEU - 11/01/2011 : je vais sur un plan avec des demandes pickées et je vais
# dans le tiroir de picking : les demandes sont pickées. Puis je vais dans le tiroir principal,
# je vais sur un plan pour lequel il n'y a aucune demande, je vais dans le tiroir de picking :
# j'ai à tort la liste des demandes du plan précédent. Donc si le tiroir est vide, je force
# son remplissage (ce qui n'est pas fait dans REMP_LISGAU de GOBJSUB quand adxmxl = 0)
If adxmxl = 0
  Case currbox
   When "GAU_CHE1"  : Gosub REMPLIT_1  From =WINPROG
   When "GAU_CHE2"  : Gosub REMPLIT_2  From =WINPROG
   When "GAU_CHE3"  : Gosub REMPLIT_3  From =WINPROG
   When "GAU_CHE4"  : Gosub REMPLIT_4  From =WINPROG
   When "GAU_CHE5"  : Gosub REMPLIT_5  From =WINPROG
   When "GAU_CHE6"  : Gosub REMPLIT_6  From =WINPROG
   When "GAU_CHE7"  : Gosub REMPLIT_7  From =WINPROG
   When "GAU_CHE8"  : Gosub REMPLIT_8  From =WINPROG
   When "GAU_CHE10" : Gosub REMPLIT_10 From =WINPROG
  Endcase
 Endif

Return

$PICKE
# On ne peut pas picker les demandes sur plan
# Pb si on dépicke puis on veut repicker. Il faut d'abord enregistrer

# SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation
Local Integer FLAG_TRAITE
#TIVAN - START
Local Integer NOT_PICKING :# X3-11689
#TIVAN - END
Local Char MLEGPLF(5) : # FQ81085 - SEGAY 25/05/12 - Field LEGPLF has been added
# SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation
# For [DML]DML0 Where DEMNUM=[F:DDEM]DEMNUM & STA=len(mess(0,10454,1)) & FLGINS=1
For [DML]DML0 Where DEMNUM=[F:TDM]DEMNUM & STA=len(mess(0,10454,1)) & FLGINS=1
  # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation - DEBUT
  # Vérification qu'il y a cohérence entre la société de la ligne de demande et
  # la société du plan, si elle est renseignée
  FLAG_TRAITE = 2
  If [M:PLF0]CPYPLF <> "" & [F:DML]CPY <> "" & [F:DML]CPY <> [M:PLF0]CPYPLF Then
    FLAG_TRAITE = 1
  Endif
  # Vérification qu'il y a cohérence entre le site de la ligne de demande et
  # le site du plan, s'il est renseigné
  If [M:PLF0]FCYPLF <> "" & [F:DML]FCY <> "" & [F:DML]FCY <> [M:PLF0]FCYPLF Then
    FLAG_TRAITE = 1
  Endif
  # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation - FIN

  If FLAG_TRAITE = 2 Then # SYMEU : EXI 66191 LOT 10 - V6.1
     I                  = [M:PLF1]NBRPLF
     [M:PLF0]MAXNUMLIG += 1
     [M:PLF1]NBRPLF    += 1
     # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation - DEBUT
     # [M:PLF1]STG(I)     = [F:DDEM]STG
     # [M:PLF1]DEMNUM(I)  = [F:DDEM]DEMNUM
     [M:PLF1]STG(I)     = [F:TDM]STG
     [M:PLF1]DEMNUM(I)  = [F:TDM]DEMNUM
     # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation - FIN
     [M:PLF1]NUMLIG(I)  = [M:PLF0]MAXNUMLIG
     [M:PLF1]NBREMP(I)  = [F:DML]NBREMP
     [M:PLF1]EMP(I)     = [F:DML]EMP
     # SYMEU : EXI 66191 LOT 10 - V6.1 : on récupère le prénom du salarié
     If [M:PLF1]EMP(I) <> "" Then
       Read [ID]ID0=[M:PLF1]EMP(I)
       [M:PLF1]SRN(I)   = [F:ID]SRN
     Endif
     # SYMEU : EXI 66191 LOT 10 - V6.1 - DEBUT
     # on renseigne les colonnes supplémentaires de la demande
     Call LECTURE("DEM",[M:PLF1]DEMNUM(I),"") From CONTOBJ
     [M:PLF1]STA(I) = [F:DML]STA
     [M:PLF1]ORI(I) = [F:DEM]ORIDEM
     [M:PLF1]FLGPRO(I) = [F:DEM]FLGPRO
     [M:PLF1]DAT(I) = [F:DEM]DATDEM
     [M:PLF1]DOM(I) = [F:DEM]DOM
     [M:PLF1]THM(I) = [F:DEM]THM
     [M:PLF1]PIO(I) = [F:DEM]PIO
     [M:PLF1]SES(I) = [F:DEM]SES
     # SYMEU : EXI 66191 LOT 10 - V6.1 - fiche 71317
     # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg <>FRA
     If GCURLEG="FRA" Then
       [M:PLF1]NATFIS(I) = [F:DEM]DESNATFIS
       [M:PLF1]CATACN(I) = [F:DEM]DESCATACN
#       If [M:PLF1]NATFIS(I) = 0 Then
#         [M:PLF1]NATFIS(I) = len(mess(0,10452,1))
#       Endif
#       If [M:PLF1]CATACN(I) = 0 Then
#         [M:PLF1]CATACN(I) = len(mess(0,10453,1))
#       Endif
     Endif
     # SYMEU : EXI 66191 LOT 10 - V6.1 - FIN
     [M:PLF1]CTRNUM(I)  = [F:DML]CTRNUM
     # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg <>FRA
     If GCURLEG="FRA" Then
      [M:PLF1]CATFRT(I) = [F:DML]CATFRT
     Endif
     [M:PLF1]SEX(I)     = [F:DML]SEX
     [M:PLF1]AGE(I)     = [F:DML]AGE
     [M:PLF1]FCY(I)     = [F:DML]FCY
     [M:PLF1]SRV(I)     = [F:DML]SRV
     # SYMEU : EXI 66191 LOT 10 - V6.1 : on renseigne l'emploi type et le poste
     If [M:PLF1]EMP(I) <> "" and [M:PLF1]CTRNUM(I) <> "" Then
       Filter [HRCTR] Where REFNUM=[M:PLF1]EMP(I) & CTRNUM=[M:PLF1]CTRNUM(I) & CTRDAT<=date$
       Read [HRCTR]CTR0 Last
       Filter [HRCTR]
       If !fstat
         [M:PLF1]JOBPOT(I) = [F:HRCTR]JOBPOT
         [M:PLF1]POT(I)    = [F:HRCTR]POT
       Endif
     Else
       # SYMEU : EXI 66191 LOT 10 - V6.1 - fiche 71781
       [M:PLF1]JOBPOT(I) = [F:DML]JOBPOT
       [M:PLF1]POT(I)    = [F:DML]POT
     Endif
     # SYMEU : EXI 66191 LOT 10 - V6.1 : inhiber les stages des calculs
     [M:PLF1]CLCFLG(I) = 2
     # SYMEU : EXI 66191 LOT 10 - V6.1 : inhiber les stages des calculs : dégrisage de la ligne
     Chgstl [M:PLF1]NBRPLF(I) With ""

     Call LECTURE("FCY",[F:DML]FCY,"") From CONTOBJ
     [M:PLF1]CPY(I)    = [F:FCY]LEGCPY
     # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation
     # Call LECTURE("DEM",[F:DDEM]DEMNUM,"") From CONTOBJ
     Call LECTURE("DEM",[F:TDM]DEMNUM,"") From CONTOBJ
     If [F:DEM]SES<>""
      Filter [COU] Where TYPCOU=2 & SES=[F:DEM]SES
      Filter [HRCOR] Where TYPCOU=2 & SES=[F:DEM]SES
      For [HRCOR]
       # FQ72847 - MABON 07/04/11 - Selon paramètres utilisateur CALCOUPAR et CALCOUFOR, on calcule ou pas les coûts participant et formateur
       Read [F:ADI]CODE = 10451;[F:HRCOR]TYPCRG2
       If ([F:ADI]N1<3) & (([F:ADI]N2=1 & GCALCOUPAR<>2) | ([F:ADI]N2=2 & GCALCOUFOR<>2)) Then
       Else
         J = [M:PLF1]NBRINV
         [M:PLF1]NBRINV +=1
         [M:PLF1]NUMLIGI(J)    = [M:PLF1]NUMLIG(I)
         [M:PLF1]TYPCRGI(J)    = [F:HRCOR]TYPCRG2
         [M:PLF1]TYPCSTI(J)    = 1 # Automatique  # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
         [M:PLF1]CSTTOTIDVI(J) = [F:HRCOR]CSTTOTIDV2
         [M:PLF1]CSTIPTIDVI(J) = [F:HRCOR]CSTIPTIDV2
         # SYMEU : EXI 66191 LOT 10 - V6.1 : Lecture ADI : Harmonisation avec saisie manuelle des frais AUTRE BUG
         Read [F:ADI]CODE = 10451;[M:PLF1]TYPCRGI(J)
         If !fstat and [F:ADI]N1 = 3 Then # Coût "Non calculé"
           # 22/02/2011 - DEBUT
           # [M:PLF1]CSTTOTCLLI(J) = arr(([M:PLF1]CSTTOTIDVI(J)*[F:DML]NBREMP),0.01)
           # [M:PLF1]CSTIPTCLLI(J) = arr(([M:PLF1]CSTIPTIDVI(J)*[F:DML]NBREMP),0.01)
           # S'ils sont renseignés, on récupère les coûts collectifs et on recalcule les coûts individuels
           If [F:HRCOR]CSTTOTCLL2<>0 and [F:DML]NBREMP<>0
             [M:PLF1]CSTTOTCLLI(J) = [F:HRCOR]CSTTOTCLL2
             # [M:PLF1]CSTTOTIDVI(J) = arr(([F:HRCOR]CSTTOTCLL2/[F:DML]NBREMP),0.01)
           Endif
           If [F:HRCOR]CSTIPTCLL2<>0 and [F:DML]NBREMP<>0
             [M:PLF1]CSTIPTCLLI(J) = [F:HRCOR]CSTIPTCLL2
             # [M:PLF1]CSTIPTIDVI(J) = arr(([F:HRCOR]CSTIPTCLL2/[F:DML]NBREMP),0.01)
           Endif
           # 22/02/2011 - FIN
         Endif
         # SYMEU : EXI 66191 LOT 10 - V6.1 : Lecture ADI : Harmonisation avec AS_CSTIPTIDV AUTRE BUG
         #LIPET - 2017-05-11 - X3-35993 - START
         # uniquement les lignes qui ne sont pas réparties : [F:COR]LNKREP=""
         If [F:HRCOR]LNKREP="" & [M:PLF1]CSTIPTIDVI(J)=0 Then
         #If [M:PLF1]CSTIPTIDVI(J)=0 Then
         #LIPET - 2017-05-11 - X3-35993 - END
           [M:PLF1]CSTIPTIDVI(J)=[M:PLF1]CSTTOTIDVI(J)
         Endif
         [M:PLF1]DESTYPFRTI(J) = [F:HRCOR]DESTYPFRT2
         [M:PLF1]TYPFINI(J)    = [F:HRCOR]TYPFIN2
         [M:PLF1]ORGFINI(J)    = [F:HRCOR]ORGFIN2
         #LIPET - 2017-05-11 - X3-35993 - START
         [M:PLF1]LNKREP(J)     = [F:HRCOR]LNKREP :  # X3-17093
         #LIPET - 2017-05-11 - X3-35993 - END
         [M:PLF1]CHAMP(J)      = num$([M:PLF1]NUMLIG(I))+[M:PLF1]TYPCRGI(J)
       Endif
      Next
      Filter [HRCOR]
     Else
      # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation
      # Filter [COU] Where TYPCOU=1 & STG=[F:DDEM]STG
      Filter [COU] Where TYPCOU=1 & STG=[F:TDM]STG
     Endif
     For [COU]
      # FQ72847 - MABON 07/04/11 - Selon paramètres utilisateur CALCOUPAR et CALCOUFOR, on calcule ou pas les coûts participant et formateur
      Read [F:ADI]CODE = 10451;[F:COU]TYPCRG
      If ([F:ADI]N1<3) & (([F:ADI]N2=1 & GCALCOUPAR<>2) | ([F:ADI]N2=2 & GCALCOUFOR<>2)) Then
      Else
        J = [M:PLF1]NBRINV
        [M:PLF1]NBRINV +=1
        [M:PLF1]NUMLIGI(J)    = [M:PLF1]NUMLIG(I)
        [M:PLF1]TYPCRGI(J)    = [F:COU]TYPCRG
        [M:PLF1]TYPCSTI(J)    = 1 # Automatique # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
        [M:PLF1]CSTTOTIDVI(J) = [F:COU]CSTTOTIDV
        [M:PLF1]CSTIPTIDVI(J) = [F:COU]CSTIPTIDV
        # SYMEU : EXI 66191 LOT 10 - V6.1 : Lecture ADI : Harmonisation avec saisie manuelle des frais AUTRE BUG
        Read [F:ADI]CODE = 10451;[M:PLF1]TYPCRGI(J)
        If !fstat and [F:ADI]N1 = 3 Then # Coût "Non calculé"
          # 22/02/2011 - DEBUT
          # [M:PLF1]CSTTOTCLLI(J) = arr(([M:PLF1]CSTTOTIDVI(J)*[F:DML]NBREMP),0.01)
          # [M:PLF1]CSTIPTCLLI(J) = arr(([M:PLF1]CSTIPTIDVI(J)*[F:DML]NBREMP),0.01)
          # S'ils sont renseignés, on récupère les coûts collectifs et on recalcule les coûts individuels
          If [F:COU]CSTTOTCLL<>0 and [F:DML]NBREMP<>0
           [M:PLF1]CSTTOTCLLI(J) = [F:COU]CSTTOTCLL
           # [M:PLF1]CSTTOTIDVI(J) = arr(([F:COU]CSTTOTCLL/[F:DML]NBREMP),0.01)
          Endif
          If [F:COU]CSTIPTCLL<>0 and [F:DML]NBREMP<>0
           [M:PLF1]CSTIPTCLLI(J) = [F:COU]CSTIPTCLL
           # [M:PLF1]CSTIPTIDVI(J) = arr(([F:COU]CSTIPTCLL/[F:DML]NBREMP),0.01)
          Endif
          # 22/02/2011 - FIN
        Endif
        # SYMEU : EXI 66191 LOT 10 - V6.1 : Lecture ADI : Harmonisation avec AS_CSTIPTIDV AUTRE BUG
        #LIPET - 2017-05-11 - X3-35993 - START
        # uniquement les lignes qui ne sont pas réparties : [F:COU]LNKREP=""
        If [F:COU]LNKREP="" & [M:PLF1]CSTIPTIDVI(J)=0 Then
        #If [M:PLF1]CSTIPTIDVI(J)=0 Then
        #LIPET - 2017-05-11 - X3-35993 - END
          [M:PLF1]CSTIPTIDVI(J)=[M:PLF1]CSTTOTIDVI(J)
        Endif
        [M:PLF1]DESTYPFRTI(J) = [F:DML]DESTYPFRT
        [M:PLF1]TYPFINI(J)    = [F:COU]TYPFIN
        [M:PLF1]ORGFINI(J)    = [F:COU]ORGFIN
        #LIPET - 2017-05-11 - X3-35993 - START
        [M:PLF1]LNKREPI(I)    = [F:COU]LNKREP  :# X3-17093
        #LIPET - 2017-05-11 - X3-35993 - END
        [M:PLF1]CHAMP(J)      = num$([M:PLF1]NUMLIG(I))+[F:COU]TYPCRG
      Endif
     Next
     Filter [COU]
     ## Recherche du coût salarial et du coût patronal du salarié
     # SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts : ajout de la société en paramètre
     # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation
     # Call COUT_PATSAL([F:DML]EMP,[F:DML]CTRNUM,[F:DML]CATFRT,[F:DDEM]STG,[F:DEM]SES,[F:DML]DESTYPFRT)
#     Call COUT_PATSAL([F:DML]EMP,[F:DML]CTRNUM,[F:DML]CATFRT,[F:TDM]STG,[F:DEM]SES,[F:DML]DESTYPFRT,[M:PLF1]CPY(I))
     # FQ81085 - US 1637 - 31/05/13 - [M:PLF1]CATFRT(I) car peut être vide si GCURLEG<>FRA
     Call COUT_PATSAL([F:DML]EMP,[F:DML]CTRNUM,[M:PLF1]CATFRT(I),[F:TDM]STG,[F:DEM]SES,[F:DML]DESTYPFRT,[M:PLF1]CPY(I))

     # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUFOR, on calcule ou pas les coûts du formateur
     If GCALCOUFOR=2 Then
       # SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71873 : DEBUT
       # Récupération des coûts <> "Non calculé" du formateur
       Local Integer FLAG_TROUVE, SAV_LIGCUR
       Local Decimal TAUX_TOTAL, TAUX_IMPUTABLE
       # Sauvegarde de LIGCUR et remplacement par valeur en cours, car on en a besoin dans
       # rech_formateur
       SAV_LIGCUR = [M:PLF0]LIGCUR
       [M:PLF0]LIGCUR = [M:PLF1]NBRPLF
       Gosub RECH_FORMATEUR
       If FORMATEUR<>"" # Le formateur est connu
         FLAG_TROUVE = 2
       Else # Le formateur est inconnu, on regarde si c'est un stage interne
         FLAG_TROUVE = 1
         Gosub RECH_FORMATEUR_NBHRES
       Endif
       # Récupération de l'ancienne valeur
       [M:PLF0]LIGCUR = SAV_LIGCUR
       If FLAG_TROUVE = 2 Then
         # FQ72847 - MABON 08/04/11 - Vérifier existence du coût avant de le créer, sinon création en double
         Local Integer VERF_EXIST
  # FQ81085 - SEGAY 25/05/12 - Field LEGPLF has been added
         MLEGPLF=GCURLEG
         If dim([M:PLF0]LEGPLF)>0 Then MLEGPLF=[M:PLF0]LEGPLF : Endif
     Gosub DECL_REPART From SUBPLF2 :#X3-11689 TIVAN
         Filter [ADI] Where NUMTAB=10451 & N1<3 & N2=2 & (LEG="" | LEG=MLEGPLF)
         For [ADI]CODE
           # FQ72847 - MABON 08/04/11 - Vérifier existence du coût avant de le créer, sinon création en double
           VERF_EXIST=1
           IV = find([F:ADI]CODE, [M:PLF1]TYPCRGI)
           If IV>0 & ([M:PLF1]CSTTOTCLLI(IV-1)<>0 | [M:PLF1]CSTTOTIDVI(IV-1)<>0 | [M:PLF1]CSTIPTCLLI(IV-1)<>0 | [M:PLF1]CSTIPTIDVI(IV-1)<>0)
             VERF_EXIST=2
           Endif
           If VERF_EXIST=1 Then
           # Fin MABON
             If FORMATEUR<>"" # Le formateur est connu
               # Coût réel total
               Call TAUX_HORAIRE (FORMATEUR,CTRFORM,date$,TAUX_TOTAL,[F:ADI]N1,2,1) From TRTCOUT
               # Coût réel imputable
               Call TAUX_HORAIRE (FORMATEUR,CTRFORM,date$,TAUX_IMPUTABLE,[F:ADI]N1,2,2) From TRTCOUT
             Else # Le formateur est inconnu, mais c'est un stage interne
               # Coût réel total
               Call CALC_COUT_FORMATEUR([M:PLF1]CPY(I),date$,TAUX_TOTAL,[F:ADI]N1,2,1)
               # Coût réel imputable
               Call CALC_COUT_FORMATEUR([M:PLF1]CPY(I),date$,TAUX_IMPUTABLE,[F:ADI]N1,2,2)
             Endif
       #TIVAN - Start
             # Repartition # X3-11689
             Gosub IS_REPART_TODO From SUBPLF2
       #TIVAN - End
             #--- Mise à jour de la table invisible des coûts
#TIVAN - Start
#             J = [M:PLF1]NBRINV :# deplacé - chgt indice -< remplacé J par J-1
             [M:PLF1]NBRINV +=1
#TIVAN - End
             J = [M:PLF1]NBRINV
#TIVAN - Start
             [M:PLF1]NUMLIGI(J-1)    = [M:PLF1]NUMLIG(I)
             [M:PLF1]TYPCRGI(J-1)    = [F:ADI]CODE
             [M:PLF1]TYPCSTI(J-1)    = 1 # Automatique # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
             Raz [M:PLF1]CSTTOTCLLI(J-1), CSTIPTCLLI(J-1)
             [M:PLF1]CSTTOTIDVI(J-1) = arr(TAUX_TOTAL*NBH,0.01)
             [M:PLF1]CSTIPTIDVI(J-1) = arr(TAUX_IMPUTABLE*NBH,0.01)
             [M:PLF1]DESTYPFRTI(J-1) = [F:DML]DESTYPFRT
             # X3-11689 - déplacé
             [M:PLF1]CHAMP(J-1)      = num$([M:PLF1]NUMLIG(I))+[F:ADI]CODE
             # X3-11689
             If [L]REPART_TODO=0 : # X3-11689
               If J>1
         #LIPET - 2017-05-11 - X3-35993 - START
                 Raz [M:PLF1]LNKREPI(J-1) : # X3-17093
         #LIPET - 2017-05-11 - X3-35993 - END
                 [M:PLF1]TYPFINI(J-1)   = [M:PLF1]TYPFINI(J-2)
                 [M:PLF1]ORGFINI(J-1)   = [M:PLF1]ORGFINI(J-2)
               Endif
             Else
                NOT_PICKING=0
                INV1=J-1 : : # indice 1st line
                Gosub REPART_PLF1_INV From SUBPLF2
             Endif : # end X3-11689
#TIVAN - End
           Endif
         Next
         Filter [ADI]
       Endif
       # SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71873 : FIN
     Endif

  Endif # SYMEU : EXI 66191 LOT 10 - V6.1
Next
Affzo [PLF1]10
Return

$DEPICK
NBSUP = 0
# X3-11689
#For I=0 To [M:PLF1]NBRPLF-1 : # X3-11689 - TIVAN
For I=[M:PLF1]NBRPLF-1 To 0 Step -1 : # X3-11689 - TIVAN
 # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation
 # If [M:PLF1]DEMNUM(I)=[F:DDEM]DEMNUM
 If [M:PLF1]DEMNUM(I)=[F:TDM]DEMNUM
  Call EFFCOUT([M:PLF1]NUMLIG(I))
  #TIVAN - 04/07/2017 - X3-11689 - Start
#  Dela I [M]NBRPLF :# X3-11689
#  NBSUP +=1
#  I -=1 : # Car le Dela tasse les lignes vers le haut
  Dela I,1 [M:PLF1]NBRPLF
  [M:PLF1]NBRPLF-=1
  #TIVAN - 04/07/2017 - end X3-11689
 Endif
Next

#[M:PLF1]NBRPLF -=NBSUP # X3-11689 - TIVAN
Affzo [PLF1]10
# Effacement des coûts prévisionnels quand on dépick
Effzo [PLF1]15
Return


$FIN_PICK
# Calcul de l'onglet Coût par stage et des totaux plan
Call REMP_PLF2([M:PLF1]NBRPLF)
# SYMEU : EXI 66191 LOT 10 - V6.1 : onglet des coûts par type de financement
Call REMP_PLF3([M:PLF1]NBRPLF) : Affzo [PLF3]
Affzo [PLF2]
Affzo [PLF0]TOT,IPT
Return

# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
$INIT_ACTIONS
  If GACTION = "PLFPRO" Then
    Gosub INIT
  Else
    Gosub INIT_PLFVAL
  Endif
Return

# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
$SORTIE_ACTIONS
  If GACTION = "PLFPRO" Then
    Gosub SORTIE
  Endif
Return

# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
$CONTROLE_ACTIONS
  If GACTION = "PLFPRO" Then
    Gosub CONTROLE
  Endif
Return

# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
$EXEC_ACTIONS
  If GACTION = "PLFPRO" Then
    # FQ70605 - MABON 28/03/11 - Maintenant qu'on a une fenêtre principale dans l'action PLFPRO, on ne fait plus le
    # traitement dans EXEC, mais dans OK
#    Gosub EXEC
  Else
    Gosub EXEC_PLFVAL
  Endif
Return

$OK
  If GACTION = "PLFPRO" Then
    Gosub EXEC
  Endif
Return

# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
$FIN
  If GACTION<>"PLFPRO" Then
    If dim(FLAG_REVALO)>0     : Kill FLAG_REVALO      : Endif
    If dim(FLAG_MESSAGE)>0    : Kill FLAG_MESSAGE     : Endif
    If dim(L_STAGE_NON_DEF)>0 : Kill L_STAGE_NON_DEF  : Endif
  Endif
Return

# SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation
# Quand on crée une nouvelle fiche (bouton nouveau), si on est sur le tiroir de picking, on
# le rafraîchit
$RAZCRE
If currbox=BOXPIC : # Liste de picking
  Gosub ABANDON
Endif
If dim([M:PLF0]LEGPLF)>0 Then
  [M:PLF0]LEGPLF=GLEGFIL
Endif
Return

# SYMEU : EXI 66191 LOT 10 - V6.1 : inhiber les stages des calculs : grisage de la ligne
# si son flag Calcul est à Non
$STYLE
For L_INDICE = 0 To [M:PLF1]NBRPLF-1
  If [M:PLF1]CLCFLG(L_INDICE) = 1 Then
    Chgstl [M:PLF1]NBRPLF(L_INDICE) With "PLAGE"
  Else
    Chgstl [M:PLF1]NBRPLF(L_INDICE) With ""
  Endif
Next

Return

###################################################################################################
## Action PLFPRO de type Gtraite
###################################################################################################

# FQ70605 - MABON 28/03/11 - On ne peut pas ajouter de lignes dans la sélection affichée
Subprog AS_NBDEMPLF

  If nolign>[M:LDEM]NBDEMPLF Then
    mkstat=2
  Endif
End

# FQ70605 - MABON 28/03/11 - On coche ou décoche toutes les lignes
$BOUTON

  Case BOUT
    When "C" : For I=0 To [M:LDEM]NBDEMPLF-1 : [M:LDEM]SELFLG(I)=2 : Next
    When "D" : For I=0 To [M:LDEM]NBDEMPLF-1 : [M:LDEM]SELFLG(I)=1 : Next
  Endcase
  Affzo [M:LDEM]
Return

# FQ70605 - MABON 28/03/11 - Remplissage du masque
Subprog FILL_LDEM(IND, OKENR)
Value    Integer IND
Variable Integer OKENR
Local    Char    CONTRAT(GLONHRCTR)

  OKENR=2
  If dim([M:DIA]LEGPLF1)>0 Then
    # Verify the LEG of the training course
    If [F:DEM]STG<>"" Then
      Read [F:STG]STG0=[F:DEM]STG
      If !fstat & [F:STG]LEG<>"" Then
        If [F:STG]LEG<>[M:DIA]LEGPLF1 Then
          OKENR=1
        Endif
      Endif
    Endif

    # Verify the LEG of the session
    If OKENR=2 & [F:DEM]SES<>"" Then
      Read [F:HRSES]SES0=[F:DEM]SES
      If !fstat & [F:HRSES]LEG<>"" Then
        If [F:HRSES]LEG<>[M:DIA]LEGPLF1 Then
          OKENR=1
        Endif
      Endif
    Endif

    # Verify the LEG of the employee
    If OKENR=2 & [F:DML]EMP<>"" Then
      If [F:DML]CTRNUM="" Then
        Read [ID]ID0=[F:DML]EMP
        If !fstat & [F:ID]FLGMULCTR<>2 Then
          Call CHERCHE_CTR([F:DML]EMP,date$,CONTRAT) From DIVPAYE
          Filter [HRCTR] Where REFNUM=[F:DML]EMP & CTRNUM=CONTRAT & CTRDAT<=date$
          Read [HRCTR]CTR0 Last
          Filter [HRCTR]
          Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
          If [F:FCY]LEG<>"" & [F:FCY]LEG<>[M:DIA]LEGPLF1 Then
            OKENR=1
          Endif
        Endif
      Else
        Filter [HRCTR] Where REFNUM=[F:DML]EMP & CTRNUM=[F:DML]CTRNUM & CTRDAT<=date$
        Read [HRCTR]CTR0 Last
        Filter [HRCTR]
        Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
        If [F:FCY]LEG<>"" & [F:FCY]LEG<>[M:DIA]LEGPLF1 Then
          OKENR=1
        Endif
      Endif
    Endif

    # Verify the LEG of the company
    If OKENR=2 & [F:DML]CPY<>"" Then
      Read [F:CPY]CPY0=[F:DML]CPY
      If !fstat & [F:CPY]LEG<>"" Then
        If [F:CPY]LEG<>[M:DIA]LEGPLF1 Then
          OKENR=1
        Endif
      Endif
    Endif

    # Verify the LEG of the site
    If OKENR=2 & [F:DML]FCY<>"" Then
      Read [F:FCY]FCY0=[F:DML]FCY
      If !fstat & [F:FCY]LEG<>"" Then
        If [F:FCY]LEG<>[M:DIA]LEGPLF1 Then
          OKENR=1
        Endif
      Endif
    Endif

    # Verify the LEG of the domain
    If OKENR=2 & [F:DEM]DOM<>"" Then
      Read [F:ADI]CODE=10381;[F:DEM]DOM
      If !fstat & [F:ADI]LEG<>"" Then
        If [F:ADI]LEG<>[M:DIA]LEGPLF1 Then
          OKENR=1
        Endif
      Endif
    Endif

    # Verify the LEG of the theme
    If OKENR=2 & [F:DEM]THM<>"" Then
      Read [F:ADI]CODE=10457;[F:DEM]THM
      If !fstat & [F:ADI]LEG<>"" Then
        If [F:ADI]LEG<>[M:DIA]LEGPLF1 Then
          OKENR=1
        Endif
      Endif
    Endif
  Endif

  If OKENR=2 Then
    [M:LDEM]SELFLG(IND)    = 2
    [M:LDEM]STA(IND)       = [F:DML]STA
    [M:LDEM]DEMNUM(IND)    = [F:DEM]DEMNUM
    [M:LDEM]STG(IND)       = [F:DEM]STG
    [M:LDEM]DATSTR(IND)    = [F:DEM]DATSTR
    [M:LDEM]DATEND(IND)    = [F:DEM]DATEND
    [M:LDEM]YEAPLF(IND)    = [F:DEM]YEAPLF
    [M:LDEM]PIO(IND)       = [F:DEM]PIO
    [M:LDEM]ORIDEM(IND)    = [F:DEM]ORIDEM
    [M:LDEM]SES(IND)       = [F:DEM]SES
    [M:LDEM]DESNATFIS(IND) = [F:DEM]DESNATFIS
    [M:LDEM]DESCATACN(IND) = [F:DEM]DESCATACN
    [M:LDEM]REFNUM(IND)    = [F:DML]EMP
    # FQ81085 - US1637 - 31/05/13 - Ajout Contrat dans la fenêtre de sélection
    [M:LDEM]CTRNUM(IND)    = [F:DML]CTRNUM
    [M:LDEM]LIGNUM(IND)    = [F:DML]NUMLIG
    [M:LDEM]JOBPOT(IND)    = [F:DML]JOBPOT
    [M:LDEM]POT(IND)       = [F:DML]POT
    [M:LDEM]DOM(IND)       = [F:DEM]DOM
    [M:LDEM]THM(IND)       = [F:DEM]THM
    If [F:DML]CTRNUM<>"" Then
      Filter [HRCTR] Where REFNUM=[F:DML]EMP & CTRNUM=[F:DML]CTRNUM & CTRDAT<=date$
      Read [HRCTR]CTR0 Last
      Filter [HRCTR]
      If !fstat
        Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
        Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
        [M:LDEM]CPY(IND)   = [F:CPY]CPY
        [M:LDEM]FCY(IND)   = [F:HRCTR]ETRFCY
      Endif
    Else
      [M:LDEM]CPY(IND)   = [F:DML]CPY
      [M:LDEM]FCY(IND)   = [F:DML]FCY
    Endif
    # FQ81085 - US1637 - 31/05/13 - Ajout Catégorie 2483 dans la fenêtre de sélection
    [M:LDEM]CATFRT(IND)  = [F:DML]CATFRT
  Endif
End

# FQ70605 - MABON 28/03/11 - Remplissage de la grille des demandes sélectionnables
$DEBUT
Local Integer I, OKENR
Local Char    CRIT1 (250), CRIT2 (250), CRIT3 (250), CRIT4 (250)

  # FQ81085 - US1637 - 31/05/13 - Ajout Catégorie 2483 dans la fenêtre de sélection, uniquement si FRA
  Case [M:DIA]LEGPLF1
    When "FRA"
      Chgfmt [M:LDEM]CATFRT With "KP:10BX"
    When Default
      Chgfmt [M:LDEM]CATFRT With "-KP:10AX"
      Raz [M:LDEM]CATFRT
  Endcase
  # Fin FQ81085

  # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (plus de filtre sur l'année)
  # CRITDEM = 'STG<>"" & YEAPLF="'+num$([M:DIA]YEAPLF1)+'"'
  # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (la demande ne doit pas être sur un plan définitif)
  CRITDEM = '[F:DEM]STG<>""  & [F:DEM]YEAPLF=""'
  # SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : on ne le prend pas
  If L_STAGE_NON_DEF <> "" Then
    CRITDEM -= '& [F:DEM]STG<>"'+L_STAGE_NON_DEF+'"'
  Endif
  # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (filtre sur les demandes qui ne
  # sont pas hors plan)
  CRITDEM -= '& [F:DEM]FLGPLF=1'
  # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (prendre en compte la borne de
  # dates de demande)
  If [M:DIA]STRDAT <> [0/0/0] Then
    CRITDEM -= '& [F:DEM]DATDEM >=['+format$(GFMD,[M:DIA]STRDAT)+']'
  Endif
  If [M:DIA]ENDDAT <> [0/0/0] Then
    CRITDEM -= '& [F:DEM]DATDEM <=['+format$(GFMD,[M:DIA]ENDDAT)+']'
  Endif

  CRITDML = '[F:DML]FLGINS=1' : # Demande saisie (ni sur plan définitif, ni inscrite, ni réalisée)
  # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
  If [M:DIA]CPYPLF1 <> "" Then
    CRITDML -= '& [F:DML]CPY="'+[M:DIA]CPYPLF1+'"'
  Endif
  If [M:DIA]FCYPLF1 <> "" Then
    CRITDML -= '& [F:DML]FCY="'+[M:DIA]FCYPLF1+'"'
  Endif

  For L=1 To len(mess(0,10454,1))
    If [M:DIA]REPDEM(L-1)=1
      CRITDML -= '& [F:DML]STA<>'+num$(L)
    Endif
  Next

  Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM As [DM_] Where evalue(CRITDEM) & evalue(CRITDML)
  I=0
  For [F:DM_]
    If I<dim([M:LDEM]SELFLG) Then
      Call FILL_LDEM(I, OKENR)
      If OKENR=2 Then I += 1 : Endif
    Else
      Break
    Endif
  Next
  [M:LDEM]NBDEMPLF=I
  Affzo [M:LDEM]
Return

$INIT
Local Integer I, J, K, L
Local Decimal NBH
# SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
# Local Char    CRITDEM(100), SYMB(30),CRITDML(100)
Local  Char    CRITDEM(100), SYMB(40),CRITDML(100)
Global Char    SAV_GCURLEG(5) : SAV_GCURLEG=GCURLEG
Return

$SORTIE
# SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
# If OK<>2 : PARAM(3) = "-1" : Endif : # Abandon de la proposition par Fin
If OK<>2 : PARAM(5) = "-1" : Endif : # Abandon de la proposition par Fin

  GCURLEG=SAV_GCURLEG
  Kill SAV_GCURLEG
Return

$CONTROLE
Local Char MLEGPLF1(5)
If sum([M]REPDEM)=[M]NBDEM
 # Au moins un type de demande doit être sélectionné
 GERR = 1 : GMESSAGE = mess(80,10717,1)
 Return
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
# Contrôle sur l'existence d'un plan de formation clos pour l'année, la société et le site.
# Ce contrôle était initialement fait dans le contrôle de l'année (C_YEAPLF1), mais comme
# il faut aussi le faire pour la société et le site, c'est plus simple de le faire ici. De
# plus, en laissant le contrôle dans l'année, quand on saisit l'année (société et site
# vide), s'il y a un plan clos, on avait un message bloquant qui était gênant si on voulait
# créer un plan pour une société ou un site.
# FQ81085 - MABON 22/05/12 - Adding field LEGPLF
MLEGPLF1=GCURLEG
If dim([M:DIA]LEGPLF1)>0 Then MLEGPLF1=[M:DIA]LEGPLF1 : Endif
Filter [PLF] Where YEAPLF=[M:DIA]YEAPLF1 & CPYPLF=[M:DIA]CPYPLF1
&                & FCYPLF=[M:DIA]FCYPLF1 & FLGCLO=2
&                & LEGPLF=MLEGPLF1
Read [PLF]PLF0 First
Filter[PLF]
If !fstat
 # Plan de formation clos pour l'année
 GMESSAGE = mess(29,10717,1)-[M:DIA]YEAPLF1
 # SYMEU : EXI 66191 LOT 10 - V6.1 : on complète le message avec la société ou le site,
 # s'ils sont renseignés
 If [M:DIA]CPYPLF1 <> "" Then
   # et la société XXXXX
   GMESSAGE -= mess(119,10717,1)-[M:DIA]CPYPLF1
 Elsif [M:DIA]FCYPLF1 <> "" Then
   # et le site YYYYY
   GMESSAGE -= mess(120,10717,1)-[M:DIA]FCYPLF1
 Endif
 GERR = 1 : Return
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
# Filter [PLF] Where YEAPLF=[M:DIA]YEAPLF1 & VERPLF=[M:DIA]VERPLF1
 # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
Filter [PLF] Where YEAPLF=[M:DIA]YEAPLF1 & CPYPLF=[M:DIA]CPYPLF1
&                & FCYPLF=[M:DIA]FCYPLF1 & VERPLF=[M:DIA]VERPLF1
&                & LEGPLF=MLEGPLF1
Read [PLF]PLF0 First
Filter [PLF]
If !fstat
 # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
 # SYMB = "PLF"+[M:DIA]VERPLF1+"\"+[M:DIA]YEAPLF1
 # FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
 SYMB = "PLF"+[M:DIA]YEAPLF1+"\"+MLEGPLF1+"\"+[M:DIA]CPYPLF1+"\"+[M:DIA]FCYPLF1+"\"+[M:DIA]VERPLF1
 Lock =SYMB
 If fstat
  # Plan de formation déjà existant.
  # Modification en cours sur un autre poste.
  GERR = 1 : GMESSAGE = mess(81,10717,1)+"\"+mess(10,100,1)
  Unlock =SYMB
  Return
 Else
  # Plan de formation déjà existant. Voulez-vous le supprimer ?
  GERR = 3 : GMESSAGE = mess(14,10717,1)
  Return
 Endif
Endif
TMP = 1
#TIVAN - 04/07/2017 - X3-35993 - Start
# JML 22/09/15 - 26/10/15 From [BUR]
Read [BUR]BUR0(3)=[M:DIA]YEAPLF1;[M:DIA]CPYPLF1;[M:DIA]FCYPLF1
If !fstat
 [M:DIA]STRDAT = [F:BUR]STRDAT
 [M:DIA]ENDDAT = [F:BUR]ENDDAT
 Affzo [DIA]STRDAT, ENDDAT
Endif
#TIVAN - 04/07/2017 - X3-35993 - End
Return

$EXEC
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=0 : Return : Endif
If I>0 : # Plan généré avec au moins une ligne
 PARAM(1) = [M:DIA]YEAPLF1
 # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
 # PARAM(2) = [M:DIA]VERPLF1
 # PARAM(3) = "1"
 PARAM(2) = [M:DIA]CPYPLF1
 PARAM(3) = [M:DIA]FCYPLF1
 PARAM(4) = [M:DIA]VERPLF1
 PARAM(5) = "1"
 # FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
 If dim([M:DIA]LEGPLF1)>0 Then
  PARAM(6) = [M:DIA]LEGPLF1
 Else
  PARAM(6) = GCURLEG
 Endif
 # End MABON
Endif
Return

$TR1
# FQ79023 - MABON 03/01/12 - Si le stage ou la session de la demande n'existe plus, le filtre sur COU et COR
# ne peut se faire, et donc les enregistrements de PLNCOUT ne sont pas calculés
Local Integer ERR_COU
# Fin MABON
Local Char MLEGPLF1(5)

Trbegin [PLF], [PLC]
 GOK = 1
 # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
 # Delete [PLF] Where YEAPLF=[M:DIA]YEAPLF1 & VERPLF=[M:DIA]VERPLF1
 # FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
 MLEGPLF1=GCURLEG
 If dim([M:DIA]LEGPLF1)>0 Then MLEGPLF1=[M:DIA]LEGPLF1 : Endif
 Delete [PLF] Where YEAPLF=[M:DIA]YEAPLF1 & CPYPLF=[M:DIA]CPYPLF1
&                 & FCYPLF=[M:DIA]FCYPLF1 & VERPLF=[M:DIA]VERPLF1
&                 & LEGPLF=MLEGPLF1
 If fstat
  GOK = 0 : Call FSTA("PLF") From GLOCK
  Goto AB_TR1
 Endif
 Raz [F:PLF]

 # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
 # Delete [PLC] Where YEAPLF=[M:DIA]YEAPLF1 & VERPLF=[M:DIA]VERPLF1
 # FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
 Delete [PLC] Where YEAPLF=[M:DIA]YEAPLF1 & CPYPLF=[M:DIA]CPYPLF1
&                 & FCYPLF=[M:DIA]FCYPLF1 & VERPLF=[M:DIA]VERPLF1
&                 & LEGPLF=MLEGPLF1
 If fstat
  GOK = 0 : Call FSTA("PLC") From GLOCK
  Goto AB_TR1
 Endif
 Raz [F:PLC]

 # SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts : suppression - DEBUT
 # FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
 Delete [HRPLB] Where YEAPLF=[M:DIA]YEAPLF1 & CPYPLF=[M:DIA]CPYPLF1
&                 & FCYPLF=[M:DIA]FCYPLF1 & VERPLF=[M:DIA]VERPLF1
&                 & LEGPLF=MLEGPLF1
 If fstat
   GOK = 0 : Call FSTA("HRPLB") From GLOCK
   Goto AB_TR1
 Endif
 Raz [F:HRPLB]
 # SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts : suppression - FIN

 I = 0
 [F:PLF]YEAPLF = [M:DIA]YEAPLF1
 # FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
 If dim([M:DIA]LEGPLF1)>0 Then
  [F:PLF]LEGPLF = [M:DIA]LEGPLF1
 Else
  [F:PLF]LEGPLF = GCURLEG
 Endif
 # End MABON
 # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
 [F:PLF]CPYPLF = [M:DIA]CPYPLF1
 [F:PLF]FCYPLF = [M:DIA]FCYPLF1
 [F:PLF]VERPLF = [M:DIA]VERPLF1
 # JML 26/10/15 - TIVAN - Start
 [F:PLF]STRDAT = [M:DIA]STRD
 [F:PLF]ENDDAT = [M:DIA]ENDD
 #TIVAN - 04/07/2017 - X3-35993 - End
 # Fiche 70685 - V6.1 - SYMEU - 18/01/2011 : flag non renseigné
 [F:PLF]FLGCLO = 1
 [F:PLF]CREDAT = date$
 [F:PLF]CREUSR = GUSER
 [F:PLF]CRETIM = time
 DEBL    = 0
 # FQ70605 - MABON 28/03/11 - On passe par une liste de demandes, affichée dans une fenêtre
 # Le filtre se fait donc avant, dans l'étiquette $DEBUT
# # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (plus de filtre sur l'année)
# # CRITDEM = 'STG<>"" & YEAPLF="'+num$([M:DIA]YEAPLF1)+'"'
# # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (la demande ne doit pas être sur un plan définitif)
# CRITDEM = 'STG<>""  & YEAPLF=""'
# # SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : on ne le prend pas
# If L_STAGE_NON_DEF <> "" Then
#  CRITDEM -= '& STG<>"'+L_STAGE_NON_DEF+'"'
# Endif
# # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (filtre sur les demandes qui ne
# # sont pas hors plan)
# CRITDEM -= '& FLGPLF=1'
# # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (prendre en compte la borne de
# # dates de demande)
# If [M:DIA]STRDAT <> [0/0/0] Then
#  CRITDEM -= '& DATDEM >=['+format$(GFMD,[M:DIA]STRDAT)+']'
# Endif
# If [M:DIA]ENDDAT <> [0/0/0] Then
#  CRITDEM -= '& DATDEM <=['+format$(GFMD,[M:DIA]ENDDAT)+']'
# Endif
#
# CRITDML = 'FLGINS=1' : # Demande saisie (ni sur plan définitif, ni inscrite, ni réalisée)
# # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
# If [M:DIA]CPYPLF1 <> "" Then
#  CRITDML -= '& CPY="'+[M:DIA]CPYPLF1+'"'
# Endif
# If [M:DIA]FCYPLF1 <> "" Then
#  CRITDML -= '& FCY="'+[M:DIA]FCYPLF1+'"'
# Endif
#
# For L=1 To len(mess(0,10454,1))
#  If [M:DIA]REPDEM(L-1)=1
#   CRITDML -= '& STA<>'+num$(L)
#  Endif
# Next

 # Demande acceptée sur l'année du plan
 # FQ70605 - MABON 28/03/11 - Les demandes sont sélectionnées dans la fenêtre LISDEMPLF : c'est donc maintenant sur
 # ces demandes qu'on fait la boucle For
# Filter [DEM] Where evalue(CRITDEM)
# For [DEM]DEM0
 For J=0 To [M:LDEM]NBDEMPLF-1
  If [M:LDEM]SELFLG(J)=2 Then
    # FQ70605 - MABON 28/03/11 - Pour chaque ligne de l'écran LISDEM, on relit la demande et on relit la ligne
    Call LECTURE("DEM", [M:LDEM]DEMNUM(J), "") From CONTOBJ
    Read [F:DML]DML0=[M:LDEM]DEMNUM(J);[M:LDEM]LIGNUM(J)
    # Fin MABON
    # FQ79023 - MABON 03/01/12
    ERR_COU=1
    # Fin MABON
    If [F:DEM]SES<>""
     Read[HRSES]SES0=[F:DEM]SES
     If !fstat
      NBH = [F:HRSES]NBRHOUIPT
      Filter [COU]   Where TYPCOU=2 & SES=[F:DEM]SES
      Filter [HRCOR] Where TYPCOU=2 & SES=[F:DEM]SES
     Else
      ERR_COU=2
     # Fin MABON
     Endif
    Elsif [F:DEM]STG<>""
     Read[STG]STG0=[F:DEM]STG
     If !fstat
      NBH = [F:STG]NBRHOUIPT
      Filter [COU] Where TYPCOU=1 & STG=[F:DEM]STG
     # FQ79023 - MABON 03/01/12
     Else
      ERR_COU=2
     # Fin MABON
     Endif
    Endif
    # FQ70605 - MABON 28/03/11 - La nouvelle boucle For ci-dessus inclut déjà cette 2nde boucle For
  #  For [DML] Where DEMNUM=[F:DEM]DEMNUM & evalue(CRITDML)
     I +=1
     [F:PLF]NUMLIG = I
     [F:PLF]NBREMP = [F:DML]NBREMP
     [F:PLF]EMP    = [F:DML]EMP
     [F:PLF]CTRNUM = [F:DML]CTRNUM
     # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg <>FRA
     If GCURLEG="FRA" Then
      [F:PLF]CATFRT = [F:DML]CATFRT
     Endif
     [F:PLF]SEX    = [F:DML]SEX
     [F:PLF]AGE    = [F:DML]AGE
     [F:PLF]SRV    = [F:DML]SRV
     [F:PLF]FCY    = [F:DML]FCY
     [F:PLF]CPY    = [F:DML]CPY
     [F:PLF]STG    = [F:DEM]STG
     [F:PLF]DEMNUM = [F:DEM]DEMNUM
     # SYMEU : EXI 66191 LOT 10 - V6.1 - colonnes supplémentaires
     [F:PLF]DOM    = [F:DEM]DOM
     [F:PLF]THM    = [F:DEM]THM
     [F:PLF]PIO    = [F:DEM]PIO
     Raz [F:PLF]JOBPOT, [F:PLF]POT
     If [F:PLF]EMP <> "" and [F:PLF]CTRNUM <> "" Then
       Filter [HRCTR] Where REFNUM=[F:PLF]EMP & CTRNUM=[F:PLF]CTRNUM & CTRDAT<=date$
       Read [HRCTR]CTR0 Last
       Filter [HRCTR]
       If !fstat
         [F:PLF]JOBPOT = [F:HRCTR]JOBPOT
         [F:PLF]POT    = [F:HRCTR]POT
       Endif
     Else
       # SYMEU : EXI 66191 LOT 10 - V6.1 - fiche 71781
       [F:PLF]JOBPOT = [F:DML]JOBPOT
       [F:PLF]POT    = [F:DML]POT
     Endif
     # SYMEU : EXI 66191 LOT 10 - V6.1 - fiche 71317
     # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg <>FRA
     If GCURLEG="FRA" Then
       [F:PLF]NATFIS = [F:DEM]DESNATFIS
       [F:PLF]CATACN = [F:DEM]DESCATACN
#       If [F:PLF]NATFIS = 0 Then
#         [F:PLF]NATFIS = len(mess(0,10452,1))
#       Endif
#       If [F:PLF]CATACN = 0 Then
#         [F:PLF]CATACN = len(mess(0,10453,1))
#       Endif
     Endif
     # Fiche 70518 - SYMEU - 11/01/2011 : renseignement du flag Calcul à Oui
     [F:PLF]CLCFLG = 2
     Write [PLF]
     If fstat
      GOK = 0 : Call FSTA("PLF") From GLOCK : Break 2
     Endif
     # FQ79023 - MABON 03/01/12 - Ajout condition sur ERR_COU
     If ERR_COU=1 Then
      Gosub CRE_PLC
     Endif
     # Fin MABON
     If GOK=0 : Break 2 : Endif
#  Next
    Filter [COU]
    Filter [HRCOR]
  Endif
 Next
# Filter [DEM]
 If GOK=0 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$CRE_PLC
Local Char MLEGPLF1(5)
# Recherche des coûts prévisionnels
For [COU]COU1
 Gosub REMP_PLC
 [F:PLC]TYPCRG    = [F:COU]TYPCRG
 [F:PLC]CSTTOTIDV = [F:COU]CSTTOTIDV
 [F:PLC]CSTIPTIDV = [F:COU]CSTIPTIDV
 # SYMEU : EXI 66191 LOT 10 - V6.1 : Lecture ADI : Harmonisation avec saisie manuelle des frais AUTRE BUG
 Read [F:ADI]CODE = 10451;[F:PLC]TYPCRG
 If !fstat and [F:ADI]N1 = 3 Then # Coût "Non calculé"
  # 22/02/2011 - DEBUT
  # [F:PLC]CSTTOTCLL = arr(([F:PLC]CSTTOTIDV*[F:DML]NBREMP),0.01)
  # [F:PLC]CSTIPTCLL = arr(([F:PLC]CSTIPTIDV*[F:DML]NBREMP),0.01)
  # S'ils sont renseignés, on récupère les coûts collectifs et on recalcule les coûts individuels
  If [F:COU]CSTTOTCLL<>0 and [F:DML]NBREMP<>0
    [F:PLC]CSTTOTCLL = [F:COU]CSTTOTCLL
    # [F:PLC]CSTTOTIDV = arr(([F:COU]CSTTOTCLL/[F:DML]NBREMP),0.01)
  Endif
  If [F:COU]CSTIPTCLL<>0 and [F:DML]NBREMP<>0
   [F:PLC]CSTIPTCLL = [F:COU]CSTIPTCLL
   # [F:PLC]CSTIPTIDV = arr(([F:COU]CSTIPTCLL/[F:DML]NBREMP),0.01)
  Endif
  # 22/02/2011 - FIN
 Endif
 # SYMEU : EXI 66191 LOT 10 - V6.1 : Harmonisation avec AS_CSTIPTIDV (récup montant individuel total) AUTRE BUG
 If [F:PLC]CSTIPTIDV=0 Then
   [F:PLC]CSTIPTIDV=[F:PLC]CSTTOTIDV
 Endif
 [F:PLC]DESTYPFRT = [F:DML]DESTYPFRT
 [F:PLC]TYPFIN    = [F:COU]TYPFIN
 [F:PLC]ORGFIN    = [F:COU]ORGFIN
 #LIPET - 2017-05-11 - X3-35993 - START
 [F:PLC]LNKREP    = [F:COU]LNKREP :# X3-17093
 #LIPET - 2017-05-11 - X3-35993 - END
 Write [PLC]
 If fstat
  GOK = 0 : Call FSTA("PLC") From GLOCK : Break
 Endif
Next
If GOK <= 0 : Return : Endif # 71873

If [F:DEM]SES<>""
 # Recherche des coûts réels de la session (formateur)
 For [HRCOR]COR1
  # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUPAR, on calcule ou pas les coûts participants
  Read [F:ADI]CODE = 10451;[F:HRCOR]TYPCRG2
  If [F:ADI]N1<3 & [F:ADI]N2=2 & GCALCOUFOR<>2 Then
  Else
    Gosub REMP_PLC
    [F:PLC]TYPCRG    = [F:HRCOR]TYPCRG2
    [F:PLC]CSTTOTIDV = [F:HRCOR]CSTTOTIDV2
    [F:PLC]CSTIPTIDV = [F:HRCOR]CSTIPTIDV2
    # SYMEU : EXI 66191 LOT 10 - V6.1 : Lecture ADI : Harmonisation avec saisie manuelle des frais AUTRE BUG
    Read [F:ADI]CODE = 10451;[F:PLC]TYPCRG
    If !fstat and [F:ADI]N1 = 3 Then # Coût "Non calculé"
     # 22/02/2011 - DEBUT
     #[F:PLC]CSTTOTCLL = arr(([F:PLC]CSTTOTIDV*[F:DML]NBREMP),0.01)
     #[F:PLC]CSTIPTCLL = arr(([F:PLC]CSTIPTIDV*[F:DML]NBREMP),0.01)
     # S'ils sont renseignés, on récupère les coûts collectifs et on recalcule les coûts individuels
     If [F:HRCOR]CSTTOTCLL2<>0 and [F:DML]NBREMP<>0
       [F:PLC]CSTTOTCLL = [F:HRCOR]CSTTOTCLL2
       # [F:PLC]CSTTOTIDV = arr(([F:HRCOR]CSTTOTCLL2/[F:DML]NBREMP),0.01)
     Endif
     If [F:HRCOR]CSTIPTCLL2<>0 and [F:DML]NBREMP<>0
       [F:PLC]CSTIPTCLL = [F:HRCOR]CSTIPTCLL2
       # [F:PLC]CSTIPTIDV = arr(([F:HRCOR]CSTIPTCLL2/[F:DML]NBREMP),0.01)
     Endif
     # 22/02/2011 - FIN
    Endif
    # SYMEU : EXI 66191 LOT 10 - V6.1 : Harmonisation avec AS_CSTIPTIDV (récup montant individuel total) AUTRE BUG
    If [F:PLC]CSTIPTIDV=0 Then
      [F:PLC]CSTIPTIDV=[F:PLC]CSTTOTIDV
    Endif
    [F:PLC]DESTYPFRT = [F:HRCOR]DESTYPFRT2
    [F:PLC]TYPFIN    = [F:HRCOR]TYPFIN2
    [F:PLC]ORGFIN    = [F:HRCOR]ORGFIN2
    #LIPET - 2017-05-11 - X3-35993 - START
    [F:PLC]LNKREP    = [F:HRCOR]LNKREP  :# X3-17093
    #LIPET - 2017-05-11 - X3-35993 - END
    Write [PLC]
    If fstat
     GOK = 0 : Call FSTA("PLC") From GLOCK : Break
    Endif
  Endif
 Next
Endif
If GOK <= 0 : Return : Endif # 71873

# SYMEU : EXI 66191 LOT 10 - V6.1 - MIS EN COMMENTAIRES
# Calcul des charges salariales et patronales suivant la catégorie des participants
#Read[F:ADI2]CODE=10453;[F:DML]CATFRT
#If !fstat
# Raz [F:PLC]
# For [ADI] Where NUMTAB=10451 & N1<3 & N2=1
#  Gosub REMP_PLC
#  [F:PLC]TYPCRG = [F:ADI]CODE
#  [F:PLC]DESTYPFRT = [F:DML]DESTYPFRT
#  [F:PLC]TYPFIN    = [F:DML]TYPFIN
#  [F:PLC]ORGFIN    = [F:DML]ORGFIN
#  Case [F:ADI]N1
#   When 1 : # Salarial
#    [F:PLC]CSTTOTIDV = arr(val([F:ADI2]A1)*NBH,0.01) : # salarial total
#    # SYMEU : EXI 66191 LOT 10 - V6.1 : AUTRE BUG : arrondi à 2 décimales
#    # [F:PLC]CSTIPTIDV = arr([F:ADI2]N1*NBH,0.1)      : # salarial imputable
#    [F:PLC]CSTIPTIDV = arr([F:ADI2]N1*NBH,0.01)      : # salarial imputable
#   When 2 : # Patronal
#    [F:PLC]CSTTOTIDV = arr(val([F:ADI2]A2)*NBH,0.01) : # patronal total
#    [F:PLC]CSTIPTIDV = arr([F:ADI2]N2*NBH,0.01)      : # patronal imputable
#  Endcase
#  Write [PLC]
#  If fstat
#   # SYMEU : EXI 66191 LOT 10 - V6.1
#   # GOK = 0 : Call FSTA("PLC") From GLOCK : Break 3
#   GOK = 0 : Call FSTA("PLC") From GLOCK : Break
#  Endif
# Next
#Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 - REMPLACE CE QUI PRECEDE : SOIT TAUX PARTICIPANT, SOIT
# TAUX CATEGORIE 2483
Local Decimal TXSAL1,TXSAL2,TXPAT1,TXPAT2
Local Char    CAT(5)
# FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUPAR, on calcule ou pas les coûts participants
#TIVAN - 05/07/2017 - X3-35993
Gosub DECL_REPART From SUBPLF2 : # X3-11689
Gosub GET_REPART_CODE From SUBPLF2 : # X3-11689
#TIVAN - 05/07/2017 - X3-35993
If GCALCOUPAR=2 Then
  # Lecture du site pour récupérer la société légale
  Call LECTURE("FCY",[F:DML]FCY,"") From CONTOBJ
  # Récupération des taux horaires du salarié ou de la catégorie
  # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg <>FRA
  If [F:PLC]LEGPLF="FRA" Then
    CAT=[F:DML]CATFRT
  Else
    CAT=""
  Endif
#  Call CALC_TAUX_HORAIRE ([F:DML]EMP,[F:DML]CTRNUM,[F:DML]CATFRT,[F:FCY]LEGCPY,TXSAL1,TXSAL2,TXPAT1,TXPAT2)
  Call CALC_TAUX_HORAIRE ([F:DML]EMP,[F:DML]CTRNUM,CAT,[F:FCY]LEGCPY,TXSAL1,TXSAL2,TXPAT1,TXPAT2)
  # Lecture de la table des coûts
  # N1 : 1=Salarial 2=Patronal
  # N2 : 1=Participant
  # FQ81085 - SEGAY 25/05/12 - Field LEGPLF has been added
  MLEGPLF1=GCURLEG
  If dim([M:DIA]LEGPLF1)>0 Then MLEGPLF1=[M:DIA]LEGPLF1 : Endif
  For [ADI] Where NUMTAB=10451 & N1<3 & N2=1 & (LEG="" | LEG=MLEGPLF1)
    If ([F:ADI]N1=1 & (TXSAL1*NBH<>0 | TXSAL2*NBH<>0))
&   |  ([F:ADI]N1=2 & (TXPAT1*NBH<>0 | TXPAT2*NBH<>0))
      # SYMEU - 07/03/2011 - 72147 : ne créer que les coûts inexistants
      # FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
#      MLEGPLF1=""
#      If dim([M:DIA]LEGPLF1)>0 Then MLEGPLF1=[M:DIA]LEGPLF1 : Endif
      Read [F:PLC]PLC0=[M:DIA]YEAPLF1;MLEGPLF1;[M:DIA]CPYPLF1;[M:DIA]FCYPLF1;[M:DIA]VERPLF1;I;[F:ADI]CODE;[F:DML]TYPFIN;[F:DML]ORGFIN
      If fstat Then
        Raz [F:PLC]
        Gosub REMP_PLC
        Gosub IS_REPART_TODO From SUBPLF2 :# X3-11689
        [F:PLC]TYPCRG = [F:ADI]CODE
        [F:PLC]DESTYPFRT = [F:DML]DESTYPFRT
        #[F:PLC]TYPFIN    = [F:DML]TYPFIN
        #[F:PLC]ORGFIN    = [F:DML]ORGFIN
        If [F:ADI]N1=1
          [F:PLC]CSTTOTIDV = arr(TXSAL1*NBH,0.01)
          [F:PLC]CSTIPTIDV = arr(TXSAL2*NBH,0.01)
        Else
          [F:PLC]CSTTOTIDV = arr(TXPAT1*NBH,0.01)
          [F:PLC]CSTIPTIDV = arr(TXPAT2*NBH,0.01)
        Endif
#TIVAN - 05/07/2017 - X3-35993 - Start
        If [L]REPART_TODO=0 : # X3-11689
          [F:PLC]TYPFIN    = [F:DML]TYPFIN
          [F:PLC]ORGFIN    = [F:DML]ORGFIN
        Else : # X3-11689
          Gosub REPART_PLC From SUBPLF2
          If GOK=0 : Break : Endif
#        # end X3-11689
        Endif
        Write [F:PLC]
#TIVAN - 05/07/2017 - X3-35993 - End
        If fstat
          GOK = 0 : Call FSTA("PLC") From GLOCK : Break
        Endif
      Endif # 72147
    Endif
  Next
Endif
If GOK <= 0 : Return : Endif # 71873

# SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71873 : DEBUT
# Récupération des coûts <> "Non calculé" du formateur
Local Integer FLAG_TROUVE
Local Decimal TAUX_TOTAL, TAUX_IMPUTABLE
Gosub RECH_FORMATEUR_PROPOS
If FORMATEUR<>"" # Le formateur est connu
  FLAG_TROUVE = 2
Else # Le formateur est inconnu, on regarde si c'est un stage interne
  FLAG_TROUVE = 1
  Gosub RECH_FORMATEUR_NBHRES_PROPOS
Endif
If FLAG_TROUVE = 2 Then
  # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUFOR, on calcule ou pas les coûts du formateur
  If GCALCOUFOR=2 Then
    Local Integer VERF_EXIST
    # FQ81085 - SEGAY 25/05/12 - Field LEGPLF has been added
    MLEGPLF1=GCURLEG
    If dim([M:DIA]LEGPLF1)>0 Then MLEGPLF1=[M:DIA]LEGPLF1 : Endif
    Filter [ADI] Where NUMTAB=10451 & N1<3 & N2=2 & (LEG="" | LEG=MLEGPLF1)
    For [ADI]CODE
      # FQ72847 - MABON 08/04/11 - Vérifier existence du coût avant de le créer, sinon création en double
      VERF_EXIST=1
      # FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
#      MLEGPLF1=""
#      If dim([M:DIA]LEGPLF1)>0 Then MLEGPLF1=[M:DIA]LEGPLF1 : Endif
      # FQ88277 - MABON 08/03/13 - Vérifier existence du coût sur la même ligne, d'où l'ajout du test sur NUMLIG=I
      Filter [F:PLC] Where YEAPLF=[M:DIA]YEAPLF1 & LEGPLF=MLEGPLF1 & CPYPLF=[M:DIA]CPYPLF1 & FCYPLF=[M:DIA]FCYPLF1
&                        & VERPLF=[M:DIA]VERPLF1 & TYPCRG=[F:ADI]CODE & NUMLIG=I
     For [F:PLC]
        If [F:PLC]CSTTOTCLL<>0 | [F:PLC]CSTTOTIDV<>0 | [F:PLC]CSTIPTCLL<>0 | [F:PLC]CSTIPTIDV<>0
          VERF_EXIST=2 : Break
        Endif
      Next
      Filter [F:PLC]
      If VERF_EXIST=1 Then
        If FORMATEUR<>"" # Le formateur est connu
          # Coût réel total
          Call TAUX_HORAIRE (FORMATEUR,CTRFORM,date$,TAUX_TOTAL,[F:ADI]N1,2,1) From TRTCOUT
          # Coût réel imputable
          Call TAUX_HORAIRE (FORMATEUR,CTRFORM,date$,TAUX_IMPUTABLE,[F:ADI]N1,2,2) From TRTCOUT
        Else # Le formateur est inconnu, mais c'est un stage interne
          # Coût réel total
          Call CALC_COUT_FORMATEUR([F:DML]CPY,date$,TAUX_TOTAL,[F:ADI]N1,2,1)
          # Coût réel imputable
          Call CALC_COUT_FORMATEUR([F:DML]CPY,date$,TAUX_IMPUTABLE,[F:ADI]N1,2,2)
        Endif
        # SYMEU - 07/03/2011 - 72147 : ne créer que les coûts inexistants
        # FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
        Read [F:PLC]PLC0=[M:DIA]YEAPLF1;MLEGPLF1;[M:DIA]CPYPLF1;[M:DIA]FCYPLF1;[M:DIA]VERPLF1;I;[F:ADI]CODE;[F:DML]TYPFIN;[F:DML]ORGFIN
        If fstat Then
          # Création du coût
          Raz [F:PLC]
          Gosub REMP_PLC
          Gosub IS_REPART_TODO From SUBPLF2 :# X3-11689 TIVAN
          [F:PLC]TYPCRG = [F:ADI]CODE
          [F:PLC]DESTYPFRT = [F:DML]DESTYPFRT
          [F:PLC]TYPFIN    = [F:DML]TYPFIN
          [F:PLC]ORGFIN    = [F:DML]ORGFIN
          [F:PLC]CSTTOTIDV = arr(TAUX_TOTAL*NBH,0.01)
          [F:PLC]CSTIPTIDV = arr(TAUX_IMPUTABLE*NBH,0.01)

          If [L]REPART_TODO=0 : # X3-11689 - TIVAN
            [F:PLC]TYPFIN    = [F:DML]TYPFIN
            [F:PLC]ORGFIN    = [F:DML]ORGFIN
          Else  : # X3-11689
            Gosub REPART_PLC From SUBPLF2
            If GOK=0 : Break : Endif
          Endif : # TIVAN

          Write [PLC]
          If fstat
            GOK = 0 : Call FSTA("PLC") From GLOCK : Break
          Endif
        Endif # 72147
      Endif
    Next
    Filter [ADI]
  Endif
Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71873 : FIN

Return

$REMP_PLC
Raz [F:PLC]
[F:PLC]NUMLIG    = I

[F:PLC]YEAPLF    = [M:DIA]YEAPLF1
# FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
If dim([M:DIA]LEGPLF1)>0 Then
  [F:PLC]LEGPLF    = [M:DIA]LEGPLF1
Else
  [F:PLC]LEGPLF    = GCURLEG
Endif
# End MABON
# SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
[F:PLC]CPYPLF    = [M:DIA]CPYPLF1
[F:PLC]FCYPLF    = [M:DIA]FCYPLF1
[F:PLC]VERPLF    = [M:DIA]VERPLF1
[F:PLC]CREDAT    = date$
[F:PLC]CREUSR    = GUSER
[F:PLC]CRETIM    = time
[F:PLC]CUR       = GSYSCUR
[F:PLC]TYPCST    = 1 # Automatique  # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
Return

#*
#* SYMEU : EXI 66191 LOT 10 - V6.1 : calcul du % entre le total du plan et le budget de référence
#*!
$CALCUL_PRCPLFBUD
Raz [M:PLF0]PRCPLFBUD
If [M:PLF0]AMTBUDREF <> 0 Then
  [M:PLF0]PRCPLFBUD = [M:PLF0]TOT / [M:PLF0]AMTBUDREF * 100
Endif
Affzo [PLF0]PRCPLFBUD
Return

###################################################################################################
#**
#*  SYMEU : EXI 66191 LOT 10 - V6.1 : Revalorisation des coûts
#*  Action PLFVAL
#*
#*!
###################################################################################################
$INIT_PLFVAL
  # Confirmez-vous la revalorisation des coûts
  TIT = mess(152,10717,1)
Return

# Ajout d'une ligne dans le tableau invisible si le coût n'existe pas
# FQ79026 - MABON 06/01/12 - Ajout paramètre DESTYPFRT
Subprog ADD_LIG_INV(IS, TYPCRG, TYPFIN, ORGFIN, DESTYPFRT)
Value Integer IS
Value Char    TYPCRG, TYPFIN, ORGFIN, DESTYPFRT()
Local Integer I, J, FOUND

  # On cherche dans le tableau invisible si ce coût de type automatique ou manuel existe déjà
  # Il faut vérifier que ce coût n'existe pas en manuel, car si c'est le cas, on n'en crée pas un en automatique,
  # et on n'écrase pas le manuel. Donc, pas de test sur TYPCSTI à 1
  FOUND = 1
  For I=0 To [M:PLF1]NBRINV-1
    If  [M:PLF1]NUMLIG(IS)=[M:PLF1]NUMLIGI(I)
&     & [M:PLF1]TYPCRGI(I)=TYPCRG
&     & ([M:PLF1]TYPFINI(I)=TYPFIN | TYPFIN="")
&     & ([M:PLF1]ORGFINI(I)=ORGFIN | ORGFIN="") Then
      FOUND=2 : Break
    Endif
  Next

  # On n'a pas trouvé ce coût dans les coûts existants, il faut donc le créer
  If FOUND=1 Then
    J = [M:PLF1]NBRINV
    [M:PLF1]NBRINV +=1
    [M:PLF1]NUMLIGI(J)    = [M:PLF1]NUMLIG(IS)
    [M:PLF1]TYPCRGI(J)    = TYPCRG
    [M:PLF1]TYPCSTI(J)    = 1 # Automatique
    # FQ79026 - MABON 06/01/12 - Utilisation paramètre DESTYPFRT
#    [M:PLF1]DESTYPFRTI(J) = [M:PLF1]DESTYPFRT(IS)
    [M:PLF1]DESTYPFRTI(J) = DESTYPFRT
    # Fin MABON
    #If [M:PLF1]DESTYPFRTI(J)=0 & J>0 Then
    If [M:PLF1]DESTYPFRTI(J)="" & J>0 Then
      [M:PLF1]DESTYPFRTI(J)  = [M:PLF1]DESTYPFRTI(J-1)
    Endif
    [M:PLF1]TYPFINI(J)    = TYPFIN
    If TYPFIN="" & J>0 Then
      [M:PLF1]TYPFINI(J)  = [M:PLF1]TYPFINI(J-1)
    Endif
    [M:PLF1]ORGFINI(J)    = ORGFIN
    If ORGFIN="" & J>0 Then
      [M:PLF1]ORGFINI(J)  = [M:PLF1]ORGFINI(J-1)
    Endif
    [M:PLF1]CHAMP(J)      = num$([M:PLF1]NUMLIG(IS))+TYPCRG
  Endif
End

#**
#* FQ71883 - MABON 25/03/11 - Vérifier l'existence du coût dans le tableau des coûts par stage
#* Car si un coût a été ajouté dans le stage ou la session APRES création du plan, il ne sera pas dans le plan, et
#* il faut donc l'ajouter, s'il n'existe pas déjà en saisie manuelle
#* On vérifie d'abord les coûts réels et prévisionnels de la session (car c'est comme ça qu'on procède ensuite
#* dans EXEC_PLFVAL), et si celle-ci n'est pas renseignée, on regarde les coûts du stage
#*!
Subprog VERIF_EXIST_ALL_COU(IS)
Value Integer IS
Local Integer I, J, K, FOUND

  If [M:PLF1]SES(IS)<>"" Then
    # Vérification des coûts réels de la session
    Filter [HRCOR] Where TYPCOU=2 & SES=[M:PLF1]SES(IS)
    For [F:HRCOR]
      If [F:HRCOR]CSTTOTIDV2<>0 or [F:HRCOR]CSTIPTIDV2<>0 or [F:HRCOR]CSTTOTCLL2<>0 or [F:HRCOR]CSTIPTCLL2<>0 Then
        # Si le coût réel de la session n'existe pas encore, il faut le créer dans le tableau des coûts
        # prévisionnels invisible, sans indiquer les montants puisqu'ils vont être recalculés
        # FQ79026 - MABON 06/01/12 - Ajout paramètre [F:COR]DESTYPFRT2
        Call ADD_LIG_INV(IS, [F:HRCOR]TYPCRG2, [F:HRCOR]TYPFIN2, [F:HRCOR]ORGFIN2, [F:COR]DESTYPFRT2)
      Endif
    Next
    Filter [F:HRCOR]

    # Vérification des coûts prévisionnels de la session
    Filter [COU] Where TYPCOU=2 & SES=[M:PLF1]SES(IS)
    For [F:COU]
      If [F:COU]CSTTOTIDV<>0 or [F:COU]CSTIPTIDV<>0 or [F:COU]CSTTOTCLL<>0 or [F:COU]CSTIPTCLL<>0 Then
        # Si le coût prévisionnel de la session n'existe pas encore, il faut le créer dans le tableau des coûts
        # prévisionnels invisible, sans indiquer les montants puisqu'ils vont être recalculés
        # FQ79026 - MABON 06/01/12 - Ajout paramètre DESTYPFRT à 0
        Call ADD_LIG_INV(IS, [F:COU]TYPCRG, [F:COU]TYPFIN, [F:COU]ORGFIN, "") : # JML TIVAN
      Endif
    Next
    Filter [COU]
  Else
    # Vérification des coûts prévisionnels du stage
    Filter [COU] Where TYPCOU=1 & STG=[M:PLF1]STG(IS)
    For [F:COU]
      If [F:COU]CSTTOTIDV<>0 or [F:COU]CSTIPTIDV<>0 or [F:COU]CSTTOTCLL<>0 or [F:COU]CSTIPTCLL<>0 Then
        # Si le coût prévisionnel du stage n'existe pas encore, il faut le créer dans le tableau des coûts
        # prévisionnels invisible, sans indiquer les montants puisqu'ils vont être recalculés
        # FQ79026 - MABON 06/01/12 - Ajout paramètre DESTYPFRT à 0
        Call ADD_LIG_INV(IS, [F:COU]TYPCRG, [F:COU]TYPFIN, [F:COU]ORGFIN, "") :# TIVAN - X3-35993
      Endif
    Next
    Filter [COU]
  Endif
End

#**
#* FQ72847 - MABON 07/04/11 - Vérifier l'existence des coûts calculés dans le tableau des coûts par stage
#* Car si ces coûts n'existent pas, alors que les paramètres CALCOUPAR et/ou CALCOUFOR sont à Oui, il faut les
#* recalculer
#*!
Subprog VERIF_EXIST_COU_CAL(IS, TYP,MLEGPLF)
Value Integer IS, TYP
Value Char MLEGPLF : # FQ81085 - SEGAY 25/05/12 - Field LEGPLF has been added
  For [F:ADI] Where NUMTAB=10451 & N1<3 & N2=TYP & (LEG="" | LEG=MLEGPLF)
    #LIPET - 2017-05-11 - X3-35993 - START
    # supprime les lignes automatiques participants ou formateurs
     Call EFFTYPCRGI([M:PLF1]NUMLIG(IS),[F:ADI]CODE,1) From SUBPLF2 # X3-17093
    #LIPET - 2017-05-11 - X3-35993 - END
    # FQ79026 - MABON 06/01/12 - Ajout paramètre DESTYPFRT à 0
    Call ADD_LIG_INV(IS, [F:ADI]CODE, "", "", "") :# TIVAN - X3-35993
  Next
End

#**
#*  SYMEU : EXI 66191 LOT 10 - V6.1 : Revalorisation des coûts
#*  Action PLFVAL
#*!
$EXEC_PLFVAL
  # Calcul en cours...
  Call TEMPON(mess(105,100,1)) From GESECRAN
  FLAG_MESSAGE = 2 # Oui

  Local Integer IND_NBRPLF, IND_NBRINV, CALC_MTT
  Local Integer NBH
  Local Decimal TXSAL1,TXSAL2,TXPAT1,TXPAT2
  # Pour le minimum garanti
  Local Integer IND_LIGCUR
  Local Decimal VALMG, NBRDAY
  Local Integer FLAG_TROUVE
  Local Char    MLEGPLF(5) : # FQ81085 - SEGAY 25/05/12 - Field LEGPLF has been added
  Local Char    CAT(5)
  MLEGPLF=GCURLEG
  If dim([M:PLF0]LEGPLF)>0 Then MLEGPLF=[M:PLF0]LEGPLF : Endif

  FLAG_REVALO = 1

  # Sauvegarde de l'indice en cours
  IND_LIGCUR = [M:PLF0]LIGCUR
  # Parcours de la grille des stages
  #LIPET - 2017-05-11 - X3-35993 - START
  Gosub DECL_REPART From SUBPLF2 : # X3-17093
  #LIPET - 2017-05-11 - X3-35993 - END
  For IND_NBRPLF = 0 To [M:PLF1]NBRPLF-1

    # FQ71883 - MABON 25/03/11 - Vérifier l'existence du coût dans le tableau des coûts par stage
    # Car si un coût a été ajouté dans le stage ou la session après création du plan, il ne sera pas dans le plan
    Call VERIF_EXIST_ALL_COU(IND_NBRPLF)
    # FQ72847 - MABON 07/04/11 - Selon paramètres utilisateur CALCOUPAR et CALCOUFOR, on calcule ou pas les coûts du participant et formateur
    If GCALCOUPAR=2 Then
      Call VERIF_EXIST_COU_CAL(IND_NBRPLF, 1, MLEGPLF)
    Endif
    If GCALCOUFOR=2 Then
      Call VERIF_EXIST_COU_CAL(IND_NBRPLF, 2, MLEGPLF)
    Endif

    # Va servir pour le minimum garanti
    [M:PLF0]LIGCUR = IND_NBRPLF+1
    # Parcours de la grille invisible de tous les coûts prévisionnels, pour traiter ceux
    # de la ligne des stages en cours qui ont un type de coût automatique
    #LIPET - 2017-05-11 - X3-35993 - START
    # X3-17093
    #For IND_NBRINV = 0 To [M:PLF1]NBRINV-1
    [L]IND_NBRINV=0
    While [L]IND_NBRINV<=[M:PLF1]NBRINV-1
      W_REPART_NO_MOD=0 # Repartition CSTIPTIDVI= 0 not modification
    #LIPET - 2017-05-11 - X3-35993 - END
      If  [M:PLF1]NUMLIG(IND_NBRPLF)=[M:PLF1]NUMLIGI(IND_NBRINV)
&     and [M:PLF1]TYPCSTI(IND_NBRINV) = 1 Then # Automatique

        # Initialisation des montants que l'on va calculer
        Raz [M:PLF1]CSTTOTCLLI(IND_NBRINV),CSTTOTIDVI(IND_NBRINV),CSTIPTCLLI(IND_NBRINV),CSTIPTIDVI(IND_NBRINV)
        # Initialisation des variables de travail
        Raz NBH
        FLAG_REVALO = 1

        # FQ72847 - MABON 07/04/11 - Selon paramètres utilisateur CALCOUPAR et CALCOUFOR, on calcule ou pas les coûts participant et formateur
        CALC_MTT=2
        Read [F:ADI]CODE=10451;[M:PLF1]TYPCRGI(IND_NBRINV)
        If !fstat Then
          If [F:ADI]N1<3 Then
            If ([F:ADI]N2=1 & GCALCOUPAR<>2) | ([F:ADI]N2=2 & GCALCOUFOR<>2) | [F:ADI]N2=3 Then
              CALC_MTT=1
            Endif
          Endif
        Endif

        If CALC_MTT=2 Then
          # Positionnement sur les coûts prévisionnels et réels de la session et du stage, pour
          # le type de frais / type de financement / organisme de financement en cours
          If [M:PLF1]SES(IND_NBRPLF)<>"" Then
            Read[HRSES]SES0=[M:PLF1]SES(IND_NBRPLF)
            If !fstat
              NBH = [F:HRSES]NBRHOUIPT
            Endif
            Filter [HRCOR] Where TYPCOU=2 & SES=[M:PLF1]SES(IND_NBRPLF)
&                            & TYPCRG2=[M:PLF1]TYPCRGI(IND_NBRINV)
&                            & TYPFIN2=[M:PLF1]TYPFINI(IND_NBRINV)
&                            & ORGFIN2=[M:PLF1]ORGFINI(IND_NBRINV)
            # Lecture ADI : Harmonisation avec saisie manuelle des frais
            Read [F:ADI]CODE = 10451;[M:PLF1]TYPCRGI(IND_NBRINV)
            If fstat Then [F:ADI]N1 = 0 Endif
            # Recherche des coûts réels de la session
            For [HRCOR]COR1
              [M:PLF1]CSTTOTIDVI(IND_NBRINV) = [F:HRCOR]CSTTOTIDV2
              [M:PLF1]CSTIPTIDVI(IND_NBRINV) = [F:HRCOR]CSTIPTIDV2
              #LIPET - 2017-05-11 - X3-35993 - START
              [M:PLF1]LNKREPI(IND_NBRINV)    = [F:HRCOR]LNKREP  :# X3-17093
              #LIPET - 2017-05-11 - X3-35993 - END
              If [F:ADI]N1 = 3 # Harmonisation avec saisie manuelle des frais # Coût "Non calculé"
                # S'ils sont renseignés, on récupère les coûts collectifs et on recalcule les coûts individuels
                If [F:HRCOR]CSTTOTCLL2<>0 and [M:PLF1]NBREMP(IND_NBRPLF)<>0 # 22/02/2011
                  [M:PLF1]CSTTOTCLLI(IND_NBRINV) = [F:HRCOR]CSTTOTCLL2
                  # [M:PLF1]CSTTOTIDVI(IND_NBRINV) = arr(([F:HRCOR]CSTTOTCLL2/[M:PLF1]NBREMP(IND_NBRPLF)),0.01)
                Endif # 22/02/2011
                If [F:HRCOR]CSTIPTCLL2<>0 and [M:PLF1]NBREMP(IND_NBRPLF)<>0 # 22/02/2011
                  [M:PLF1]CSTIPTCLLI(IND_NBRINV) = [F:HRCOR]CSTIPTCLL2
                  # [M:PLF1]CSTIPTIDVI(IND_NBRINV) = arr(([F:HRCOR]CSTIPTCLL2/[M:PLF1]NBREMP(IND_NBRPLF)),0.01)
                Endif # 22/02/2011
              Endif
              If [M:PLF1]CSTIPTIDVI(IND_NBRINV)=0 Then
                # Repartition CSTIPTIDVI= 0 not modification
                If [M:PLF1]LNKREPI(IND_NBRINV)<>"" & [M:PLF1]TYPCSTI(IND_NBRINV) = 1
                  W_REPART_NO_MOD=1
                Else
                  [M:PLF1]CSTIPTIDVI(IND_NBRINV)=[M:PLF1]CSTTOTIDVI(IND_NBRINV)
                Endif
              Endif
              FLAG_REVALO = 2
              Break
            Next
            Filter [HRCOR]
            If FLAG_REVALO <> 2 Then
              Filter [COU] Where TYPCOU=2 & SES=[M:PLF1]SES(IND_NBRPLF)
&                              & TYPCRG=[M:PLF1]TYPCRGI(IND_NBRINV)
&                              & TYPFIN=[M:PLF1]TYPFINI(IND_NBRINV)
&                              & ORGFIN=[M:PLF1]ORGFINI(IND_NBRINV)
            Endif
          Else
            Read[STG]STG0=[M:PLF1]STG(IND_NBRPLF)
            If !fstat
              NBH = [F:STG]NBRHOUIPT
            Endif
            Filter [COU] Where TYPCOU=1 & STG=[M:PLF1]STG(IND_NBRPLF)
&                            & TYPCRG=[M:PLF1]TYPCRGI(IND_NBRINV)
&                            & TYPFIN=[M:PLF1]TYPFINI(IND_NBRINV)
&                            & ORGFIN=[M:PLF1]ORGFINI(IND_NBRINV)
          Endif
          If FLAG_REVALO = 1 Then
            # Lecture ADI : Harmonisation avec saisie manuelle des frais
            Read [F:ADI]CODE = 10451;[M:PLF1]TYPCRGI(IND_NBRINV)
            If fstat Then [F:ADI]N1 = 0 Endif
            # Recherche des coûts prévisionnels
            For [COU]COU1
              [M:PLF1]CSTTOTIDVI(IND_NBRINV) = [F:COU]CSTTOTIDV
              [M:PLF1]CSTIPTIDVI(IND_NBRINV) = [F:COU]CSTIPTIDV
              [M:PLF1]LNKREPI(IND_NBRINV)    = [F:COU]LNKREP  :# X3-17093 TIVAN
              If [F:ADI]N1 = 3 # Harmonisation avec saisie manuelle des frais # Coût "Non calculé"
                # S'ils sont renseignés, on récupère les coûts collectifs et on recalcule les coûts individuels
                If [F:COU]CSTTOTCLL<>0 and [M:PLF1]NBREMP(IND_NBRPLF)<>0 # 22/02/2011
                  [M:PLF1]CSTTOTCLLI(IND_NBRINV) = [F:COU]CSTTOTCLL
                  # [M:PLF1]CSTTOTIDVI(IND_NBRINV) = arr(([F:COU]CSTTOTCLL/[M:PLF1]NBREMP(IND_NBRPLF)),0.01)
                Endif # 22/02/2011
                If [F:COU]CSTIPTCLL<>0 and [M:PLF1]NBREMP(IND_NBRPLF)<>0 # 22/02/2011
                  [M:PLF1]CSTIPTCLLI(IND_NBRINV) = [F:COU]CSTIPTCLL
                  # [M:PLF1]CSTIPTIDVI(IND_NBRINV) = arr(([F:COU]CSTIPTCLL/[M:PLF1]NBREMP(IND_NBRPLF)),0.01)
                Endif # 22/02/2011
              Endif
              If [M:PLF1]CSTIPTIDVI(IND_NBRINV)=0 Then
                # Repartition CSTIPTIDVI= 0 not modification TIVAN
                If [M:PLF1]LNKREPI(IND_NBRINV)<>"" & [M:PLF1]TYPCSTI(IND_NBRINV) = 1
                  W_REPART_NO_MOD=1
                Else
                  [M:PLF1]CSTIPTIDVI(IND_NBRINV)=[M:PLF1]CSTTOTIDVI(IND_NBRINV)
                Endif :# TIVAN
              Endif
              FLAG_REVALO = 2
            Next
            Filter [COU]
          Endif
        Endif
        If [M:PLF1]STG(IND_NBRPLF)<>[F:STG]COD : # TIVAN
          Read [STG]STG0=[M:PLF1]STG(IND_NBRPLF)
          If fstat : Raz [F:STG] : Endif
        Endif
        [L]WTCRCOD= [F:STG]TCRCOD : # TIVAN
        If FLAG_REVALO = 1 Then
          # Lecture de la table des coûts pour le coût de la ligne en cours
          # N1 : 1=Salarial 2=Patronal
          # N2 : 1=Participant
          # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUPAR, on calcule ou pas les coûts du participant
          If GCALCOUPAR=2 Then
#            Filter [ADI] Where NUMTAB=10451 & N1<3 & N2=1 & CODE=[M:PLF1]TYPCRGI(IND_NBRINV)
# FQ81085 - SEGAY 25/05/12 - Field LEGPLF has been added
            Filter [ADI] Where NUMTAB=10451 & N1<3 & N2=1 & CODE=[M:PLF1]TYPCRGI(IND_NBRINV) & (LEG="" | LEG=MLEGPLF)
            If rowcount([ADI]) > 0 Then
              # Récupération des taux horaires du salarié ou de la catégorie
              # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg <>FRA
              If GCURLEG="FRA" Then
                CAT=[M:PLF1]CATFRT(IND_NBRPLF)
              Else
                CAT=""
              Endif
#              Call CALC_TAUX_HORAIRE ([M:PLF1]EMP(IND_NBRPLF),[M:PLF1]CTRNUM(IND_NBRPLF),[M:PLF1]CATFRT(IND_NBRPLF),[M:PLF1]CPY(IND_NBRPLF),TXSAL1,TXSAL2,TXPAT1,TXPAT2)
              Call CALC_TAUX_HORAIRE ([M:PLF1]EMP(IND_NBRPLF),[M:PLF1]CTRNUM(IND_NBRPLF),CAT,[M:PLF1]CPY(IND_NBRPLF),TXSAL1,TXSAL2,TXPAT1,TXPAT2)
            Endif
            For [ADI]CODE

              If ([F:ADI]N1=1 & (TXSAL1*NBH<>0 | TXSAL2*NBH<>0))
&             |  ([F:ADI]N1=2 & (TXPAT1*NBH<>0 | TXPAT2*NBH<>0))
              #LIPET - 2017-05-11 - X3-35993 - START
              Gosub IS_REPART_TODO From SUBPLF2:# Repartition # X3-17093
              #LIPET - 2017-05-11 - X3-35993 - END
                If [F:ADI]N1=1
                 [M:PLF1]CSTTOTIDVI(IND_NBRINV) = arr(TXSAL1*NBH,0.01)
                 [M:PLF1]CSTIPTIDVI(IND_NBRINV) = arr(TXSAL2*NBH,0.01)
                Else
                 [M:PLF1]CSTTOTIDVI(IND_NBRINV) = arr(TXPAT1*NBH,0.01)
                 [M:PLF1]CSTIPTIDVI(IND_NBRINV) = arr(TXPAT2*NBH,0.01)
                Endif
                #LIPET - 2017-05-11 - X3-35993 - START
                If [L]REPART_TODO :# X3-17093
                  NOT_PICKING=0
                  INV1=IND_NBRINV : # indice 1st line
                  # X3-17093
                  If [M:PLF1]CSTIPTIDVI(INV1)=0 Then
                    [M:PLF1]CSTIPTIDVI(INV1)=[M:PLF1]CSTTOTIDVI(INV1)
                  Endif
                  Gosub REPART_PLF1_INV From SUBPLF2
                  # Repartition CSTIPTIDVI= 0 not modification
                  W_REPART_NO_MOD=1
                  [L]IND_NBRINV+=1
                Endif
                #LIPET - 2017-05-11 - X3-35993 - EBD
                FLAG_REVALO = 2
              Endif
            Next
            Filter [ADI]
          Endif
        Endif

          # Cas du type de coût HEB
        If [M:PLF1]TYPCRGI(IND_NBRINV) = "HEB"
          If [M:PLF1]CSTIPTCLLI(IND_NBRINV) = 0 Then    # Imputable collectif
            Gosub MINIMUM_GARANTI
            If [M:PLF1]CSTIPTIDVI(IND_NBRINV) = 0 Then  # Imputable individuel
              # Si un coût d'hébergement a été saisi, on valorise son coût en fonction du
              # Minimum garanti
              # Frais d'hebergement imputable individuel = 5*MG*Nb jours
              If [M:PLF1]CSTTOTIDVI(IND_NBRINV)<arr(5*VALMG*NBRDAY,0.01)
                [M:PLF1]CSTIPTIDVI(IND_NBRINV) = [M:PLF1]CSTTOTIDVI(IND_NBRINV)
              Else
                [M:PLF1]CSTIPTIDVI(IND_NBRINV) = arr(5*VALMG*NBRDAY,0.01)
              Endif
              FLAG_REVALO = 2
            Else
              If [M:PLF1]CSTIPTIDVI(IND_NBRINV)>arr(5*VALMG*NBRDAY,0.01)
                [M:PLF1]CSTIPTIDVI(IND_NBRINV) = arr(5*VALMG*NBRDAY,0.01)
                FLAG_REVALO = 2
              Endif
            Endif
          Endif
        Endif

        If FLAG_REVALO = 1 Then
          # Lecture de la table des coûts pour le coût de la ligne en cours
          # N1 : 1=Salarial 2=Patronal
          # N2 : 2=Formateur interne
          If  [M:PLF1]CSTIPTCLLI(IND_NBRINV) = 0
&         and [M:PLF1]CSTIPTIDVI(IND_NBRINV) = 0 Then
            # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUFOR, on calcule ou pas les coûts du formateur
            If GCALCOUFOR=2 Then
#              Filter [ADI] Where NUMTAB=10451 & N1<3 & N2=2 & CODE=[M:PLF1]TYPCRGI(IND_NBRINV)
# FQ81085 - SEGAY 25/05/12 - Field LEGPLF has been added
              Filter [ADI] Where NUMTAB=10451 & N1<3 & N2=2 & CODE=[M:PLF1]TYPCRGI(IND_NBRINV) & (LEG="" | LEG=MLEGPLF)
              For [ADI]CODE
                Gosub RECH_FORMATEUR
                #LIPET - 2017-05-11 - X3-35993 - START
                Gosub IS_REPART_TODO From SUBPLF2:# Repartition # X3-17093
                #LIPET - 2017-05-11 - X3-35993 - END
                If FORMATEUR<>""
                  # Coût réel total
                  Call TAUX_HORAIRE (FORMATEUR,CTRFORM,date$,TAUX,[F:ADI]N1,2,1) From TRTCOUT
                  [M:PLF1]CSTTOTIDVI(IND_NBRINV) = arr(TAUX*NBH,0.01)
                  # Coût réel imputable
                  Call TAUX_HORAIRE (FORMATEUR,CTRFORM,date$,TAUX,[F:ADI]N1,2,2) From TRTCOUT
                  [M:PLF1]CSTIPTIDVI(IND_NBRINV) = arr(TAUX*NBH,0.01)
                  #LIPET - 2017-05-11 - X3-35993 - START
                  If [L]REPART_TODO :# X3-17093
                    NOT_PICKING=0
                    INV1=IND_NBRINV : # indice 1st line
                    # X3-17093
                    If [M:PLF1]CSTIPTIDVI(INV1)=0 Then
                      [M:PLF1]CSTIPTIDVI(INV1)=[M:PLF1]CSTTOTIDVI(INV1)
                    Endif
                    Gosub REPART_PLF1_INV From SUBPLF2
                    # Repartition CSTIPTIDVI= 0 not modification
                    W_REPART_NO_MOD=1
                    [L]IND_NBRINV+=1
                  Endif
                  #LIPET - 2017-05-11 - X3-35993 - END
                  FLAG_REVALO = 2
                Else
                  FLAG_TROUVE = 1
                  Gosub RECH_FORMATEUR_NBHRES
                  If FLAG_TROUVE = 2 Then
                    # Coût réel total
                    Call CALC_COUT_FORMATEUR([M:PLF1]CPY([M:PLF0]LIGCUR-1),date$,TAUX,[F:ADI]N1,2,1)
                    [M:PLF1]CSTTOTIDVI(IND_NBRINV) = arr(TAUX*NBH,0.01)
                    # Coût réel imputable
                    Call CALC_COUT_FORMATEUR([M:PLF1]CPY([M:PLF0]LIGCUR-1),date$,TAUX,[F:ADI]N1,2,2)
                    [M:PLF1]CSTIPTIDVI(IND_NBRINV) = arr(TAUX*NBH,0.01)
                    #LIPET - 2017-05-11 - X3-35993 - START
                    If [L]REPART_TODO :# X3-17093
                      NOT_PICKING=0
                      INV1=IND_NBRINV : # indice 1st line
                      # X3-17093
                      If [M:PLF1]CSTIPTIDVI(INV1)=0 Then
                        [M:PLF1]CSTIPTIDVI(INV1)=[M:PLF1]CSTTOTIDVI(INV1)
                      Endif
                      Gosub REPART_PLF1_INV From SUBPLF2
                      # Repartition CSTIPTIDVI= 0 not modification
                      W_REPART_NO_MOD=1
                      [L]IND_NBRINV+=1
                    Endif
                    #LIPET - 2017-05-11 - X3-35993 - END
                    FLAG_REVALO = 2
                  Endif
                Endif
              Next
              Filter [ADI]
            Endif
            If [M:PLF1]CSTIPTIDVI(IND_NBRINV)=0 Then
              [M:PLF1]CSTIPTIDVI(IND_NBRINV)=[M:PLF1]CSTTOTIDVI(IND_NBRINV)
              FLAG_REVALO = 2
            Endif
          Endif
        Endif
        If [M:PLF1]CSTIPTIDVI(IND_NBRINV)=0 Then
          # Repartition CSTIPTIDVI= 0 not modification TIVAN
          If W_REPART_NO_MOD=1 & FLAG_REVALO = 2
          Else
             [M:PLF1]CSTIPTIDVI(IND_NBRINV)=[M:PLF1]CSTTOTIDVI(IND_NBRINV)
          Endif : # TIVAN
        Endif
      Endif
    #LIPET - 2017-05-11 - X3-35993 - START
      # X3-17093
#    Next
    [L]IND_NBRINV+=1
    Wend
    # end X3-17093
    #LIPET - 2017-05-11 - X3-35993 - START
  Next

  # Suppression du message
  Call TEMPOFF From GESECRAN
  FLAG_MESSAGE = 1 # Non

  # Récupération de la sauvegarde de l'indice
  [M:PLF0]LIGCUR = IND_LIGCUR

  # Calcul de l'onglet Coût par stage et des totaux plan
  Call REMP_PLF2([M:PLF1]NBRPLF)
  # SYMEU : EXI 66191 LOT 10 - V6.1 : onglet des coûts par type de financement
  Call REMP_PLF3([M:PLF1]NBRPLF) : Affzo [PLF3]
  Affzo [PLF2]
  Affzo [PLF0]TOT,IPT

  # Pour afficher le tableau des coûts de ligne en cours
  nolign=[M:PLF0]LIGCUR
  Call AS_NBRPLF

Return

