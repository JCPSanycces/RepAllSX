######################################################################################
Subprog AM_ORGFIN(VALEUR)
Variable Char    VALEUR()
# X3-17093 - MAJ LNKREP lié
  If [M:PLF1]LNKREP(nolign-1)<>""
    # uniquement si clé de répartition sur la ligne, passage en manuel
    [M:PLF1]TYPCST(nolign-1) = 2 # Manuel
    Affzo [M:PLF1]TYPCST(nolign-1)

    Gosub SET_FLGCHG From SUBPLF2
  Endif
End


######################################################################################

######################################################################################
## Section automatically added (screen PLF1) 07/03/2017 15:40:41 (TIVAN)
######################################################################################
Subprog C_NBRCST
If status=65 | status=68 | status=83
  If [M:PLF1]LNKREP(nolign-1)<>""
    Local Integer OK
    Call OUINON(mess(322,10717,1)+chr$(10)+mess(205,100,1),OK) From GESECRAN
    #"Vous allez supprimer une ligne liée à une répartition. En cas de revalorisation, cette ligne apparaîtra de nouveau."
    #Voulez-vous continuer ?'
    If OK=1 : mkstat=2 : End : Endif
  Endif
  # Update LNKREP
  Gosub SET_FLGCHG From SUBPLF2
  Gosub RESET_LNKREP From SUBPLF2
Endif
End


######################################################################################

######################################################################################
## Section automatically added (screen PLF1) 07/06/2017 15:04:28 (TIVAN)
######################################################################################
# X3-17093
Subprog APRES_NBRCST
If status=6
  Gosub RESET_FLGCHG From SUBPLF2
Endif
Gosub RESET_LNKREP From SUBPLF2
Call AS_NBRCST
End


