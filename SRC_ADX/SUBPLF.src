######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1
# Après_modif de la société du plan : accès ou pas au site du plan
######################################################################################
Subprog AM_CPYPLF(VALEUR)
Variable Char    VALEUR()
  # On grise ou on dégrise le site
  If VALEUR = "" Then
   Actzo [M:PLF0]FCYPLF
  Else
   Diszo [M:PLF0]FCYPLF
  Endif
  # Récupération du budget de référence et calcul du pourcentage plan/budget
  Call GET_AMTBUDREF([M:PLF0]YEAPLF,VALEUR,[M:PLF0]FCYPLF)
  [F:PLF]YEAPLF = [M:PLF0]YEAPLF : [F:PLF]CPYPLF = VALEUR : [F:PLF]FCYPLF = [M:PLF0]FCYPLF : Gosub READ_BUR From SUBPLF2 : # JML 22/09/15 :#TIVAN
  Gosub CALCUL_PRCPLFBUD

End

######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1
# Après_modif du site du plan : accès ou pas à la société du plan
######################################################################################
Subprog AM_FCYPLF(VALEUR)
Variable Char    VALEUR()
  # On grise ou on dégrise la société
  If VALEUR = "" Then
   Actzo [M:PLF0]CPYPLF
  Else
   Diszo [M:PLF0]CPYPLF
  Endif
  # Récupération du budget de référence et calcul du pourcentage plan/budget
  Call GET_AMTBUDREF([M:PLF0]YEAPLF,[M:PLF0]CPYPLF,VALEUR)
  Gosub CALCUL_PRCPLFBUD

End

######################################################################################
#*
#* SYMEU : EXI 66191 LOT 10 - V6.1
#* Gestion du message d'erreur entre le site de la ligne et celui du plan
#*!
Subprog MES_ERR_SITE (P_SITE_LIGNE)
Value Char P_SITE_LIGNE
  # Le site (XXXXX) doit être identique à celui du plan (YYYYY)
  GMESSAGE = mess(121,10717,1)-"("+P_SITE_LIGNE+")"-mess(122,10717,1)-"("+[M:PLF0]FCYPLF+")"
  mkstat = 2
End

######################################################################################
#*
#* SYMEU : EXI 66191 LOT 10 - V6.1
#* Gestion du message d'erreur entre la société du site de la ligne et celle du plan
#*!
Subprog MES_ERR_SOC (P_SOC_LIGNE,P_SITE_LIGNE)
Value Char P_SOC_LIGNE
Value Char P_SITE_LIGNE
  # La société (VVVVV) du site (XXXXX) doit être identique à celle du plan (YYYYY)
  GMESSAGE = mess(123,10717,1)-"("+P_SOC_LIGNE+")"-mess(124,10717,1)-"("+P_SITE_LIGNE+")"-mess(125,10717,1)-"("+[M:PLF0]CPYPLF+")"
  mkstat = 2
End

######################################################################################
#*
#* SYMEU : EXI 66191 LOT 10 - V6.1 : récupération du budget de référence.
#* On récupère le montant global s'il est renseigné, ou la somme des montants par type
#* de financement.
#*!
Subprog GET_AMTBUDREF(P_YEAPLF,P_CPYPLF,P_FCYPLF)
Value Char P_YEAPLF, P_CPYPLF,P_FCYPLF

Raz [M:PLF0]AMTBUDREF
Filter [F:BUR] Where BUDYEA = P_YEAPLF and CPY = P_CPYPLF
&                and FCY    = P_FCYPLF and TYPFIN = ""
Read [F:BUR]BUR0 First
If !fstat
  [M:PLF0]AMTBUDREF = [F:BUR]AMTDET
Endif
Filter [F:BUR]

If [M:PLF0]AMTBUDREF = 0 Then
  Local Decimal L_AMTTOT
  Filter [F:BUR] Where BUDYEA = P_YEAPLF and CPY = P_CPYPLF
&                  and FCY    = P_FCYPLF and TYPFIN <> ""
  For [F:BUR]
    # cumul des montants par type de financement
    L_AMTTOT += [F:BUR]AMTDET
  Next
  Filter [F:BUR]
  [M:PLF0]AMTBUDREF = L_AMTTOT
Endif
Affzo [M:PLF0]AMTBUDREF
End

######################################################################################
#**
#* SYMEU : EXI 66191 LOT 10 - V6.1 : onglet des coûts par type de financement
#* On remplit l'écran PLF3 "coûts par type de financement" (tableau 1 et 3)
#*!
Subprog REMP_PLF3(NBR_PLF)
Value Integer NBR_PLF
Local Integer I, J, K, IND
Local Integer FLAG_OK # SYMEU - fiche 71793 (tester limite variable bas de tableau)

Raz [PLF3]
# Parcours du tableau des stages de l'écran PLF1
For I=0 To NBR_PLF-1
  # SYMEU : EXI 66191 LOT 10 - V6.1 : inhiber les stages des calculs, si flag = Non
  # Fiche 71549 - SYMEU - 14/02/2011
  If [M:PLF1]CLCFLG(I) = 2 Then
    Raz FLAG_OK # SYMEU - fiche 71793 (tester limite variable bas de tableau)
    ## Parcours du tableau invisible des coûts de [PLF1] pour remplir le tableau des coûts par type financement
    ## On ne prend que les coûts du stage en cours
    For K=0 To [M:PLF1]NBRINV-1
      If [M:PLF1]NUMLIG(I)=[M:PLF1]NUMLIGI(K)
        # Recherche du type de financement dans le 1er tableau de l'écran PLF3
        J = find([M:PLF1]TYPFINI(K),[M:PLF3]TYPFIN3(0..[M:PLF3]NBRFIN-1))
        If J : # Type de financement déjà comptabilisé
          IND = J-1
          FLAG_OK = 1 # SYMEU - fiche 71793 (tester limite variable bas de tableau)
        Else : # Nouveau type de financement
          If [M:PLF3]NBRFIN < dim([M:PLF3]TYPFIN3) Then # SYMEU - fiche 71793 (tester limite variable bas de tableau)
            [M:PLF3]TYPFIN3([M:PLF3]NBRFIN) = [M:PLF1]TYPFINI(K)
            # SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71793, afficher Non défini si vide
            If [M:PLF3]TYPFIN3([M:PLF3]NBRFIN) = "" Then
              [M:PLF3]TYPFINLIB3([M:PLF3]NBRFIN) = mess(205,10717,1) # Non défini
            Else
              [M:PLF3]TYPFINAFF3([M:PLF3]NBRFIN) = [M:PLF3]TYPFIN3([M:PLF3]NBRFIN)
              Call LECTEXTRA([M:PLF3]TYPFINLIB3([M:PLF3]NBRFIN),"ATABDIV","LNGDES","10462",[M:PLF3]TYPFINAFF3([M:PLF3]NBRFIN)) From ATEXTRA
            Endif
            IND = [M:PLF3]NBRFIN
            # Renseignement du montant du budget pour l'année, la société, le site, le type
            # de financement
            Filter [F:BUR] Where BUDYEA = [M:PLF0]YEAPLF and CPY = [M:PLF0]CPYPLF
&                            and FCY    = [M:PLF0]FCYPLF and TYPFIN = [M:PLF1]TYPFINI(K)
            Read [F:BUR]BUR0 First
            If !fstat
              [M:PLF3]AMTBUDFIN(IND) = [F:BUR]AMTDET
            Endif
            Filter [F:BUR]
            [M:PLF3]NBRFIN +=1
            FLAG_OK = 1 # SYMEU - fiche 71793 (tester limite variable bas de tableau)
          Endif # SYMEU - fiche 71793 (tester limite variable bas de tableau)
        Endif

        ## On remplit le tableau des coûts par type de financement
        If FLAG_OK = 1 Then # SYMEU - fiche 71793 (tester limite variable bas de tableau)
          [M:PLF3]FINTOT(IND) += [M:PLF1]CSTTOTIDVI(K)*[M:PLF1]NBREMP(I)
          [M:PLF3]FINIPT(IND) += [M:PLF1]CSTIPTIDVI(K)*[M:PLF1]NBREMP(I)
        Endif # SYMEU - fiche 71793 (tester limite variable bas de tableau)

        # On remplit le tableau invisible du détail des coûts par frais
        OK = 0
        For L=0 To [M:PLF3]NBRINV3-1
          If [M:PLF3]TYPFINI(L)=[M:PLF1]TYPFINI(K) & [M:PLF3]TYPCRGFINI(L) = [M:PLF1]TYPCRGI(K)
            OK = 1
            [M:PLF3]CSTTOTFINI(L) += [M:PLF1]CSTTOTIDVI(K)*[M:PLF1]NBREMP(I)
            [M:PLF3]CSTIPTFINI(L) += [M:PLF1]CSTIPTIDVI(K)*[M:PLF1]NBREMP(I)
            Break
          Endif
        Next
        If OK=0
&       and [M:PLF3]NBRINV3 < dim([M:PLF3]TYPFINI) Then # SYMEU - fiche 71793 (tester limite variable bas de tableau)
          [M:PLF3]TYPFINI([M:PLF3]NBRINV3)    = [M:PLF1]TYPFINI(K)
          [M:PLF3]TYPCRGFINI([M:PLF3]NBRINV3) = [M:PLF1]TYPCRGI(K)
          [M:PLF3]CSTTOTFINI([M:PLF3]NBRINV3) = [M:PLF1]CSTTOTIDVI(K)*[M:PLF1]NBREMP(I)
          [M:PLF3]CSTIPTFINI([M:PLF3]NBRINV3) = [M:PLF1]CSTIPTIDVI(K)*[M:PLF1]NBREMP(I)
          [M:PLF3]NBRINV3 +=1
        Endif
      Endif
    Next
  Endif # Fiche 71549 - SYMEU - 14/02/2011
Next

# Fiche 71793 - SYMEU - 23/02/2011 : inclure les montants des enveloppes dans l'onglet
# des coûts par type de financement
# Boucle sur le tableau des enveloppes
For I=0 To [M:PLF4]NBRBUD-1
  Raz FLAG_OK
  # Recherche du type de financement dans le 1er tableau de l'écran PLF3
  J = find([M:PLF4]TYPFINBUD(I),[M:PLF3]TYPFIN3(0..[M:PLF3]NBRFIN-1))
  If J : # Type de financement déjà comptabilisé
    IND = J-1
    FLAG_OK = 1
  Else : # Nouveau type de financement
    If [M:PLF3]NBRFIN < dim([M:PLF3]TYPFIN3) Then
      [M:PLF3]TYPFIN3([M:PLF3]NBRFIN) = [M:PLF4]TYPFINBUD(I)
      # SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71793, afficher Non défini si vide
      If [M:PLF3]TYPFIN3([M:PLF3]NBRFIN) = "" Then
        [M:PLF3]TYPFINLIB3([M:PLF3]NBRFIN) = mess(205,10717,1) # Non défini
      Else
        [M:PLF3]TYPFINAFF3([M:PLF3]NBRFIN) = [M:PLF3]TYPFIN3([M:PLF3]NBRFIN)
        Call LECTEXTRA([M:PLF3]TYPFINLIB3([M:PLF3]NBRFIN),"ATABDIV","LNGDES","10462",[M:PLF3]TYPFINAFF3([M:PLF3]NBRFIN)) From ATEXTRA
      Endif
      IND = [M:PLF3]NBRFIN
      [M:PLF3]NBRFIN +=1
      FLAG_OK = 1
    Endif
  Endif
  ## On remplit le tableau des coûts par type de financement
  If FLAG_OK = 1 Then
    [M:PLF3]FINTOT(IND) += [M:PLF4]CSTTOTBUD(I)
    [M:PLF3]FINIPT(IND) += [M:PLF4]CSTIPTBUD(I)
  Endif

  # On remplit le tableau invisible du détail des coûts par frais
  OK = 0
  For L=0 To [M:PLF3]NBRINV3-1
    If [M:PLF3]TYPFINI(L)=[M:PLF4]TYPFINBUD(I) & [M:PLF3]TYPCRGFINI(L) = [M:PLF4]TYPCRGBUD(I)
      OK = 1
      [M:PLF3]CSTTOTFINI(L) += [M:PLF4]CSTTOTBUD(I)
      [M:PLF3]CSTIPTFINI(L) += [M:PLF4]CSTIPTBUD(I)
      Break
    Endif
  Next
  If OK=0
& and [M:PLF3]NBRINV3 < dim([M:PLF3]TYPFINI) Then # SYMEU - fiche 71793 (tester limite variable bas de tableau)
    [M:PLF3]TYPFINI([M:PLF3]NBRINV3)    = [M:PLF4]TYPFINBUD(I)
    [M:PLF3]TYPCRGFINI([M:PLF3]NBRINV3) = [M:PLF4]TYPCRGBUD(I)
    [M:PLF3]CSTTOTFINI([M:PLF3]NBRINV3) = [M:PLF4]CSTTOTBUD(I)
    [M:PLF3]CSTIPTFINI([M:PLF3]NBRINV3) = [M:PLF4]CSTIPTBUD(I)
    [M:PLF3]NBRINV3 +=1
  Endif
Next

End

######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts : chargement de l'écran
######################################################################################
Subprog REMP_PLF4
Raz [PLF4]
Local Integer I
# FQ81085 - MABON 22/05/12 - Adding field LEGPLF
Filter [HRPLB] Where YEAPLF=[F:PLF]YEAPLF & VERPLF=[F:PLF]VERPLF
&                & CPYPLF=[F:PLF]CPYPLF & FCYPLF=[F:PLF]FCYPLF
&                & LEGPLF=[F:PLF]LEGPLF
For [HRPLB]PLB0
 [M:PLF4]TYPCRGBUD(I)    = [F:HRPLB]TYPCRG
 [M:PLF4]CSTTOTBUD(I)    = [F:HRPLB]CSTTOT
 [M:PLF4]CSTIPTBUD(I)    = [F:HRPLB]CSTIPT
 [M:PLF4]DESTYPFRTBUD(I) = [F:HRPLB]DESTYPFRT
 [M:PLF4]TYPFINBUD(I)    = [F:HRPLB]TYPFIN
 [M:PLF4]ORGFINBUD(I)    = [F:HRPLB]ORGFIN
 I +=1
Next
Filter [HRPLB]
[M:PLF4]NBRBUD = I
Affzo [M:PLF4]1-99
End

######################################################################################
#**
#* SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts
#*
#* @param EMP       : matricule
#* @param CTR       : contrat
#* @param CAT       : catégorie 2483
#* @param CPY       : société
#* @param TXSAL1    : taux salarial total calculé
#* @param TXSAL2    : taux salarial imputable calculé
#* @param TXPAT1    : taux patronal total calculé
#* @param TXPAT2    : taux patronal imputable calculé
#*!
Subprog CALC_TAUX_HORAIRE (EMP,CTR,CAT,CPY,TXSAL1,TXSAL2,TXPAT1,TXPAT2)
Value    Char    EMP ()
Value    Char    CTR
Value    Char    CAT
Value    Char    CPY
Variable Decimal TXSAL1, TXSAL2, TXPAT1, TXPAT2

Raz TXSAL1, TXSAL2, TXPAT1, TXPAT2

If EMP<>""
 Call TAUX_HORAIRE (EMP,CTR,date$,TXSAL1,1,2,1) From TRTCOUT  : # salarial total
 Call TAUX_HORAIRE (EMP,CTR,date$,TXSAL2,1,2,2) From TRTCOUT  : # salarial imputable
 Call TAUX_HORAIRE (EMP,CTR,date$,TXPAT1,2,2,1) From TRTCOUT  : # patronal total
 Call TAUX_HORAIRE (EMP,CTR,date$,TXPAT2,2,2,2) From TRTCOUT  : # patronal imputable
Else
 # On récupère soit les taux de la catégorie 2483, soit le coût moyen des participants,
 # selon la valeur paramètre CLCHRSRAT
 Local Char    L_VALEUR(5)
 Local Integer L_CLCHRSRAT
 # Quel est le mode de calcul : 1 = coût moyen, 2 = taux horaire
 Local Char L_SOCIETE(GLONCPY)
 If CPY <> "" Then
  # CPY contient la société de la ligne
  L_SOCIETE = CPY
 Else
  # CPY de la ligne n'est pas renseigné pour une demande collective
  If [M:PLF0]CPYPLF <> "" Then
    # Je prends la société du plan
    L_SOCIETE = [M:PLF0]CPYPLF
  Elsif [M:PLF0]FCYPLF <> "" Then
    Read [FCY]FCY0=[M:PLF0]FCYPLF
    If !fstat Then
      # ou la société du site du plan
      L_SOCIETE = [F:FCY]LEGCPY
    Endif
  Endif
 Endif
 Call PARAM(L_SOCIETE,"CLCHRSRAT",L_VALEUR)From ADOVAL
 L_CLCHRSRAT = val(L_VALEUR)
 If L_CLCHRSRAT = 1 Then # Coût moyen
   Call CALC_COUT_MOYEN_PARTICIPANT(CAT,date$,date$,TXSAL1,TXSAL2,TXPAT1,TXPAT2)
 Elsif L_CLCHRSRAT = 2 Then # Taux horaire
   If CAT <> "" Then
     # Recherche des taux horaires de la catégorie 2483
     Read[F:ADI2]CODE=10453;CAT
     If !fstat
       TXSAL1 = val([F:ADI2]A1) : # salarial total
       TXSAL2 = [F:ADI2]N1      : # salarial imputable
       TXPAT1 = val([F:ADI2]A2) : # patronal total
       TXPAT2 = [F:ADI2]N2      : # patronal imputable
     Endif
   Else # catégorie non renseignée
     End
   Endif
 Else # Valeur paramètre non définie
   # Fiche 70539 - SYMEU - 11/01/2011
   Call MESSAGE(mess(206,10717,1)) From GESECRAN
   End
 Endif
Endif
End

######################################################################################

# FQ81085 - MABON 22/05/12 - Controls that company is in the same LEG than LEGPLF
Subprog C_CPYPLF(VALEUR)
Variable Char    VALEUR()

  If dim([M:PLF0]LEGPLF)>0 & [M:PLF0]LEGPLF<>"" Then
    If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
    Read [F:CPY]CPY0=VALEUR
    If !fstat & [F:CPY]LEG<>"" Then
      If [F:CPY]LEG<>[M:PLF0]LEGPLF Then
        GMESSAGE=mess(269,10717,1)-[M:PLF0]LEGPLF : # La législation de la société doit être
        mkstat=2
      Endif
    Endif
  Endif
End
# End MABON
