######################################################################################
# Fiche 70518 - SYMEU - 11/01/2011 : contrôle sur les dates
######################################################################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR > [M:PLF0]ENDDAT and [M:PLF0]ENDDAT <> [00/00/00] Then
    [M:PLF0]ENDDAT = VALEUR : Affzo [M:PLF0]ENDDAT
  Endif
  If day(VALEUR)<>1 Then
    GMESSAGE=mess(311,717,1) : # La date de début doit être le premier jour d'un mois
    mkstat=2
  Endif
  If !mkstat Then Call CTRL_DATES_PLF(VALEUR,[M:PLF0]ENDDAT) From SUBPLF2 : Endif
End

