## Etiquettes de l'écran PLF4
# SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts
######################################################################################

######################################################################################
## SEGAY 81085 US 460  (SEGAY) (écran PLF4) 15/06/2012 16:52:41 (SEGAY)
######################################################################################
Subprog AVANT_NBRBUD
# SEGAY 81085 US 460
[M]WLEGLIG(nolign-1)=GCURLEG

End


# SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts
# Avant_saisie de la variable de bas de tableau
Subprog AS_NBRBUD
  # SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts (fiche 71793)
  Call REMP_PLF3([M:PLF1]NBRPLF) :  : Affzo [PLF3]
  # Calcul du total du plan prévisionnel
  Gosub CALC_MTT_PLAN
  Affzo [PLF0]TOT,IPT
End

######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts : recalcul des montants du plan
# (tableau des coûts et enveloppes)
######################################################################################
$CALC_MTT_PLAN
  Local Integer I, J
  Raz [M:PLF0]TOT, [M:PLF0]IPT

  # Boucle sur le tableau des stages
  For I=0 To [M:PLF1]NBRPLF-1
    # Boucle sur le tableau invisible des coûts de [PLF1]
    For J=0 To [M:PLF1]NBRINV-1
      # SYMEU : EXI 66191 LOT 10 - V6.1 : inhiber les stages des calculs, si flag = Non
      If [M:PLF1]NUMLIG(I)=[M:PLF1]NUMLIGI(J) and [M:PLF1]CLCFLG(I) = 2 Then
        [M:PLF0]TOT += [M:PLF1]CSTTOTIDVI(J)*[M:PLF1]NBREMP(I)
        [M:PLF0]IPT += [M:PLF1]CSTIPTIDVI(J)*[M:PLF1]NBREMP(I)
      Endif
    Next
  Next

  # Ajout des montants des enveloppes
  Gosub AJOUT_ENVELOPPES
  # Calcul du % entre le total du plan et le budget de référence
  Gosub CALCUL_PRCPLFBUD

Return

######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts
# Ajout des montants des enveloppes au total et au total imputable du plan prévisionnel
######################################################################################
$AJOUT_ENVELOPPES
  Local Integer I
  # Boucle sur le tableau des enveloppes
  For I=0 To [M:PLF4]NBRBUD-1
    [M:PLF0]TOT += [M:PLF4]CSTTOTBUD(I)
    [M:PLF0]IPT += [M:PLF4]CSTIPTBUD(I)
  Next
Return

# Avant_saisie du montant imputable
Subprog AS_CSTIPTBUD(VALEUR)
Variable Decimal VALEUR
  If VALEUR=0 & [M:PLF4]CSTTOTBUD(nolign-1)<>0 Then
    VALEUR=[M:PLF4]CSTTOTBUD(nolign-1)
  Endif
End

# Contrôle du montant total
Subprog C_CSTIPTBUD(VALEUR)
Variable Decimal VALEUR
If VALEUR>[M:PLF4]CSTTOTBUD(nolign-1)
 GMESSAGE=mess(7,10717,1) # Coût imputable supérieur au coût total
 mkstat=2 : End
Endif
End

######################################################################################
## SEGAY 81085 US 460  (SEGAY) (écran PLF4) 15/06/2012 16:52:41 (SEGAY)
######################################################################################
Subprog AS_ORGFINBUD(VALEUR)
Variable Char    VALEUR()
 If VALEUR=""
    If nolign>1
      VALEUR = [M]ORGFINBUD(nolign-2)
    Else
      # Pour l'inscription on alimente avant GOFIDEF avev le paramètre niveau société
      If dim(GOFIDEF )>0 Then
       # SEGAY 81085 US 460
#      VALEUR = GOFIDEF
       Local Char WLEG(GLONADI)
       Local Integer WOK
#      Call PARAM(GSOCIETE,"OFIDEF",WOFI) From ADOVAL : # CCL
       WLEG=[M]WLEGLIG(nolign-1)
       INDEX=3
       Call CHECKLEG_CRGFINOFT(GOFIDEF,INDEX,0,WLEG,WOK) From SUBSTG
       If WOK
        VALEUR = GOFIDEF
       Endif
      Endif
    Endif
  Endif

End

# Contrôle de l'organisme de financement
Subprog C_ORGFINBUD(VALEUR)
Variable Char    VALEUR()
# On teste l'unicité de la ligne sur les zones : TYPCRGBUD/TYPFINBUD/ORGFINBUD
Local Shortint I
For I=0 To [M]NBRBUD-1
 If I<>nolign-1 & [M:PLF4]TYPCRGBUD(I)=[M:PLF4]TYPCRGBUD(nolign-1)
& & [M:PLF4]TYPFINBUD(I)=[M:PLF4]TYPFINBUD(nolign-1) & [M:PLF4]ORGFINBUD(I)=[L]VALEUR
  GMESSAGE=mess(84,10717,1)-num$(I+1) : # Ligne de coût déjà existante en ligne x
  mkstat=2
  Break
 Endif
Next
End


