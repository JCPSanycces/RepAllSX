Subprog AVANT_NBRCST
# SEGAY 81085 US 460
[M]WLEGLIG(nolign-1)=GCURLEG
Gosub RESET_FLGCHG From SUBPLF2 #TIVAN - 06/07/2017 - X3-35993
End


######################################################################################


Subprog AS_NBRPLF
Local Integer I, J
[M:PLF0]LIGCUR = nolign
# Chargement des coûts dans le deuxième tableau
Raz [M:PLF1]TYPCRG,CSTTOTCLL,CSTTOTIDV,CSTIPTCLL,CSTIPTIDV,DESTYPFRT,TYPFIN,ORGFIN
Raz [M:PLF1]TYPCST  # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
#LIPET - 2017-05-11 - X3-35993 - START
Raz [M:PLF1]LNKREP : # X3-17093
#LIPET - 2017-05-11 - X3-35993 - END

J = 0
For I=0 To [M:PLF1]NBRINV-1
 # SYMEU : EXI 66191 LOT 10 - V6.1 - fiche 71884 : seulement si au moins un montant <> 0
 If [M:PLF1]NUMLIG(nolign-1)=[M:PLF1]NUMLIGI(I)
& and ([M:PLF1]CSTTOTCLLI(I) <> 0 or [M:PLF1]CSTTOTIDVI(I) <> 0 or [M:PLF1]CSTIPTCLLI(I) <> 0 or [M:PLF1]CSTIPTIDVI(I) <> 0)
#LIPET - 2017-05-11 - X3-35993 - START
#  # X3-17093
  If J>=dim([M:PLF1]TYPCRG)
    # 'Tableau des coûts plein'
    Call MESSAGE(mess(304,10717,1)) From GESECRAN
    Break
  Endif
#LIPET - 2017-05-11 - X3-35993 - END
  [M:PLF1]TYPCRG(J)    = [M:PLF1]TYPCRGI(I)
  [M:PLF1]TYPCST(J)    = [M:PLF1]TYPCSTI(I) # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
  [M:PLF1]CSTTOTCLL(J) = [M:PLF1]CSTTOTCLLI(I)
  [M:PLF1]CSTTOTIDV(J) = [M:PLF1]CSTTOTIDVI(I)
  [M:PLF1]CSTIPTCLL(J) = [M:PLF1]CSTIPTCLLI(I)
  [M:PLF1]CSTIPTIDV(J) = [M:PLF1]CSTIPTIDVI(I)
  [M:PLF1]DESTYPFRT(J) = [M:PLF1]DESTYPFRTI(I)
  [M:PLF1]TYPFIN(J)    = [M:PLF1]TYPFINI(I)
  [M:PLF1]ORGFIN(J)    = [M:PLF1]ORGFINI(I)
  #LIPET - 2017-05-11 - X3-35993 - START
  [M:PLF1]LNKREP(J)    = [M:PLF1]LNKREPI(I) : # X3-17093
  #LIPET - 2017-05-11 - X3-35993 - END
  J +=1
  #LIPET - 2017-05-11 - X3-35993 - START
  # X3-17093
  [M:PLF1]NBRCST=J
  #LIPET - 2017-05-11 - X3-35993 - END
 Endif
Next
[M:PLF1]NBRCST = J
Affzo [PLF1]15
# Bug 70042 : SYMEU 28/12/2010 : accès au tableau des coûts, qui a pu être désactivé dans AS_NBRCST
If [M:PLF1]NBRCST > 0 Then
  Actzo [M:PLF1]NBRCST
Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : plan définitif
Call GRISE_FLGCLO([M:PLF0]FLGCLO) From SUBPLF2
End

Subprog APRES_NBRPLF
Local Integer NBR_PLF
# SYMEU : EXI 66191 LOT 10 - V6.1 : AUTRE BUG : si modif du nombre de participants, il y a
# eu recalcul des coûts collectifs. Il faut les sauvegarder dans le tableau invisible.
# De même, si on a modifié le stage, le tableau des coûts a été mis à jour, mais pas le tableau
# invisible. Donc, je supprime les coûts du tableau invisible et je recopie les coûts prévi-
# sionnels dans le tableau invisible (pour le NUMLIG en cours).
If [M]FLGMOD(nolign-1)=1 Then # modif de ligne
  Call EFFCOUT([M:PLF1]NUMLIG(nolign-1))
  For I=0 To [M:PLF1]NBRCST-1
   [M:PLF1]NUMLIGI([M:PLF1]NBRINV)    = [M:PLF1]NUMLIG(nolign-1)
   [M:PLF1]TYPCRGI([M:PLF1]NBRINV)    = [M:PLF1]TYPCRG(I)
   [M:PLF1]TYPCSTI([M:PLF1]NBRINV)    = [M:PLF1]TYPCST(I) # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
   [M:PLF1]CSTTOTCLLI([M:PLF1]NBRINV) = [M:PLF1]CSTTOTCLL(I)
   [M:PLF1]CSTTOTIDVI([M:PLF1]NBRINV) = [M:PLF1]CSTTOTIDV(I)
   [M:PLF1]CSTIPTCLLI([M:PLF1]NBRINV) = [M:PLF1]CSTIPTCLL(I)
   [M:PLF1]CSTIPTIDVI([M:PLF1]NBRINV) = [M:PLF1]CSTIPTIDV(I)
   [M:PLF1]DESTYPFRTI([M:PLF1]NBRINV) = [M:PLF1]DESTYPFRT(I)
   [M:PLF1]TYPFINI([M:PLF1]NBRINV)    = [M:PLF1]TYPFIN(I)
   [M:PLF1]ORGFINI([M:PLF1]NBRINV)    = [M:PLF1]ORGFIN(I)
   #LIPET - 2017-05-11 - X3-35993 - START
   [M:PLF1]LNKREPI([M:PLF1]NBRINV)    = [M:PLF1]LNKREP(I) : # X3-17093
   #LIPET - 2017-05-11 - X3-35993 - END
   [M:PLF1]CHAMP([M:PLF1]NBRINV)      = num$([M:PLF1]NUMLIG(nolign-1))+[M:PLF1]TYPCRG(I)
   [M:PLF1]NBRINV +=1
  Next
Endif
If [M]FLGMOD(nolign-1)=1 | status=65 | status=83 | status=68
 NBR_PLF = [M:PLF1]NBRPLF
 # En cas d'ajout ou d'insertion on a une ligne en plus
 # Le status est à 1 qu'on soit en modif, insertion ou ajout d'1 ligne
 If status<>65 & status<>83 & status<>68 : NBR_PLF +=1 : Endif

 # SYMEU : EXI 66191 LOT 10 - V6.1 : inhiber les stages des calculs : grisage de la ligne
 # si son flag Calcul est à Non
 If [M:PLF1]CLCFLG(nolign-1) = 1 Then # Non
   Chgstl [M:PLF1]NBRPLF(nolign-1) With "PLAGE"
 Else
   Chgstl [M:PLF1]NBRPLF(nolign-1) With ""
 Endif

 Call REMP_PLF2(NBR_PLF)
 # SYMEU : EXI 66191 LOT 10 - V6.1 : onglet des coûts par type de financement
 Call REMP_PLF3(NBR_PLF) : Affzo [PLF3]
 Affzo [PLF2]
 Affzo [PLF0]TOT,IPT
Endif
Raz [M]FLGMOD(nolign-1)
End

Subprog C_NBRPLF
# SYMEU : EXI 66191 LOT 10 - V6.1 : supprimé, car vient écraser le n° de ligne de la ligne
# courante, ce qui entraîne un décalage entre PLNFORM et PLNCOUT (BUG n° 67263)
#If status=73 | status=82
# [M:PLF0]MAXNUMLIG += 1
# [M:PLF1]NUMLIG(nolign-1) = [M:PLF0]MAXNUMLIG
#Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : en cas de suppression de ligne, màj du tableau
# invisible, sinon les coûts sont créés dans PLNCOUT à la validation (BUG n° 67263)
If status = 65 or status = 83 or status = 68 Then
  Call EFFCOUT([M:PLF1]NUMLIG(nolign-1))
Endif

End

Subprog IB_NBRPLF
If [M:PLF1]DEMNUM(nolign-1)=""
 Raz GBOUT1
Else
 GBOUT1 = mess(13,10717,1) : # Demande
Endif
End

Subprog AM_NBREMP(VALEUR)
Variable Decimal VALEUR
Local Integer I
If VALEUR<>1
 Effzo [M:PLF1]EMP(nolign-1)
 # SYMEU : EXI 66191 LOT 10 - V6.1 : on initialise le prénom
 Effzo [M:PLF1]SRN(nolign-1)
Endif

# La modif du nombre de participants, entraine le recalcul des montants individuels si le collectif est <>0
# 22/02/2011 - DEBUT
# On ne calcule plus le montant individuel
#For I=0 To [M:PLF1]NBRCST-1
# If [M:PLF1]CSTTOTCLL(I)<>0
#  [M:PLF1]CSTTOTIDV(I)=arr(([M:PLF1]CSTTOTCLL(I)/VALEUR),0.01)
#  Affzo [M:PLF1]CSTTOTIDV(I)
# Endif
# If [M:PLF1]CSTIPTCLL(I)<>0
#  [M:PLF1]CSTIPTIDV(I)=arr(([M:PLF1]CSTIPTCLL(I)/VALEUR),0.01)
#  Affzo [M:PLF1]CSTIPTIDV(I)
# Endif
#Next
# 22/02/2011 - FIN

# La modif du nombre de participants, modifie le nombre de salariés par stage dans l'écran PLF2
[M:PLF1]FLGMOD(nolign-1) = 1
End


Subprog C_STG(VALEUR)
Variable Char    VALEUR()
If [M:PLF1]DEMNUM(nolign-1)<>""
 Read [DEM]DEM0=[M:PLF1]DEMNUM(nolign-1)
 If !fstat & [F:DEM]STG<>VALEUR
  # Stage incompatible avec la demande
  GMESSAGE = mess(52,10717,1)
  GERR = 3 : End
 Endif
Endif

# FQ81085 - MABON 22/05/12 - Controls that training course is in the same LEG than LEGPLF
If dim([M:PLF0]LEGPLF)>0 & [M:PLF0]LEGPLF<>"" Then
  If clalev([F:STG])=0 : Local File STAGE [STG] : Endif
  Read [F:STG]STG0=VALEUR
  If !fstat & [F:STG]LEG<>"" Then
    If [F:STG]LEG<>[M:PLF0]LEGPLF Then
      GMESSAGE=mess(271,10717,1)-[M:PLF0]LEGPLF : # La législation du stage doit être
      mkstat=2
    Endif
  Endif
Endif
End


Subprog AM_STG(VALEUR)
Variable Char    VALEUR()
Local Integer I,J
# FQ81085 - SEGAY 25/05/12 - Field LEGPLF has been added
Local Char    MLEGPLF(5)
Local Char    CAT(5)
MLEGPLF=GCURLEG
If dim([M:PLF0]LEGPLF)>0 Then MLEGPLF=[M:PLF0]LEGPLF : Endif

Gosub DECL_REPART From SUBPLF2 : # X3-11689 TIVAN
# SYMEU : EXI 66191 LOT 10 - V6.1 : alimentation de NUMLIG (était dans C_NBRPLF)
# (BUG n° 67263)
If [M:PLF1]NUMLIG(nolign-1) = 0 Then
 [M:PLF0]MAXNUMLIG += 1
 [M:PLF1]NUMLIG(nolign-1) = [M:PLF0]MAXNUMLIG
 [M:PLF1]STA(nolign-1) = 0
 [M:PLF1]ORI(nolign-1) = 0
 [M:PLF1]FLGPRO(nolign-1) = 0
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 - fiche 71317
If [M:PLF1]DEMNUM(nolign-1)<>"" Then
  Read [F:DEM]DEM0=[M:PLF1]DEMNUM(nolign-1)
  If !fstat Then
    # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg <>FRA
    If GCURLEG="FRA" Then
      [M:PLF1]NATFIS(nolign-1) = [F:DEM]DESNATFIS
      [M:PLF1]CATACN(nolign-1) = [F:DEM]DESCATACN
    Endif
  Endif
Else
  Read [F:STG]STG0=VALEUR
  If !fstat Then
    # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg <>FRA
    If GCURLEG="FRA" Then
      [M:PLF1]NATFIS(nolign-1) = [F:STG]NATFIS
      [M:PLF1]CATACN(nolign-1) = [F:STG]CATACN
    Endif
  Endif
  # SYMEU : EXI 66191 LOT 10 - V6.1 - fiche 71781
  [M:PLF1]DOM(nolign-1) = [F:STG]DOM
  [M:PLF1]THM(nolign-1) = [F:STG]THM
  Affzo [M:PLF1]DOM(nolign-1), THM(nolign-1)
Endif
# FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg <>FRA
If GCURLEG="FRA" Then
#TIVAN - 07/07/2017 - X3-35993 - Start - Is this necessary anymore?
  If [M:PLF1]NATFIS(nolign-1) = "" Then
    [M:PLF1]NATFIS(nolign-1) = ""
  Endif
#TIVAN - 07/07/2017 - X3-35993 - End
#  If [M:PLF1]CATACN(nolign-1) = 0 Then
#    [M:PLF1]CATACN(nolign-1) = len(mess(0,10453,1)) :# Check later
#  Endif
  Affzo [M:PLF1]NATFIS(nolign-1), CATACN(nolign-1)
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : pas de récupération automatique des coûts
If L_STAGE_NON_DEF = VALEUR Then
  # raz du tableau des coûts, qui sera recopié dans le tableau invisible si la modification
  # de la ligne est validée
  Effzo [M:PLF1]15
  # La modif du stage modifie le cumul par stage dans l'écran PLF2
  [M:PLF1]FLGMOD(nolign-1) = 1
  End
Endif

## Mise à jour dans 2ème tableau des coûts de la ligne
## Mise à jour dans les zones invisibles des coûts
Filter [COU] Where TYPCOU=1 & STG=VALEUR
For [COU]COU0
 # FQ72847 - MABON 07/04/11 - Selon paramètres utilisateur CALCOUPAR et CALCOUFOR, on calcule ou pas les coûts participant et formateur
 Read [F:ADI]CODE = 10451;[F:COU]TYPCRG
 If [F:ADI]N1<3 & (([F:ADI]N2=1 & GCALCOUPAR<>2) | ([F:ADI]N2=2 & GCALCOUFOR<>2)) Then
 Else
   [M:PLF1]TYPCRG(I)    = [F:COU]TYPCRG
   [M:PLF1]TYPCST(I)    = 1 # Automatique # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
   [M:PLF1]CSTTOTIDV(I) = [F:COU]CSTTOTIDV
   [M:PLF1]CSTIPTIDV(I) = [F:COU]CSTIPTIDV
   # SYMEU : EXI 66191 LOT 10 - V6.1 : Lecture ADI : Harmonisation avec saisie manuelle des frais AUTRE BUG
   Read [F:ADI]CODE = 10451;[M:PLF1]TYPCRG(I)
   If !fstat and [F:ADI]N1 = 3 Then # Coût "Non calculé"
     # 22/02/2011 - DEBUT
     # [M:PLF1]CSTTOTCLL(I) = arr(([M:PLF1]CSTTOTIDV(I)*[M:PLF1]NBREMP(nolign-1)),0.01)
     # [M:PLF1]CSTIPTCLL(I) = arr(([M:PLF1]CSTIPTIDV(I)*[M:PLF1]NBREMP(nolign-1)),0.01)
     # S'ils sont renseignés, on récupère les coûts collectifs et on recalcule les coûts individuels
     If [F:COU]CSTTOTCLL<>0 and [M:PLF1]NBREMP(nolign-1)<>0
       [M:PLF1]CSTTOTCLL(I) = [F:COU]CSTTOTCLL
       # [M:PLF1]CSTTOTIDV(I) = arr(([F:COU]CSTTOTCLL/[M:PLF1]NBREMP(nolign-1)),0.01)
     Endif
     If [F:COU]CSTIPTCLL<>0 and [M:PLF1]NBREMP(nolign-1)<>0
       [M:PLF1]CSTIPTCLL(I) = [F:COU]CSTIPTCLL
       # [M:PLF1]CSTIPTIDV(I) = arr(([F:COU]CSTIPTCLL/[M:PLF1]NBREMP(nolign-1)),0.01)
     Endif
     # 22/02/2011 - FIN
   Endif
   # SYMEU : EXI 66191 LOT 10 - V6.1 : Harmonisation avec AS_CSTIPTIDV (récup montant individuel total) AUTRE BUG
   # uniquement les lignes qui ne sont pas réparties : [F:COR]LNKREP="" TIVAN
   If [F:COU]LNKREP="" & [M:PLF1]CSTIPTIDV(I)=0 Then
     [M:PLF1]CSTIPTIDV(I)=[M:PLF1]CSTTOTIDV(I)
   Endif
   # SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71873 : seulement si au moins un montant renseigné
   #LIPET - 2017-05-11 - X3-35993 - START
#   If [M:PLF1]CSTTOTIDV(I) <> 0 or [M:PLF1]CSTIPTIDV(I) <> 0 or [M:PLF1]CSTTOTCLL(I) <> 0 or [M:PLF1]CSTIPTCLL(I) <> 0
#     [M:PLF1]DESTYPFRT(I) = len(mess(0,10455,1)) : # Non défini
#     [M:PLF1]TYPFIN(I)    = [F:COU]TYPFIN
#     [M:PLF1]ORGFIN(I)    = [F:COU]ORGFIN
   If [M:PLF1]CSTTOTIDV(I) <> 0 or [M:PLF1]CSTIPTIDV(I) <> 0 or [M:PLF1]CSTTOTCLL(I) <> 0 or [M:PLF1]CSTIPTCLL(I) <> 0
     [M:PLF1]DESTYPFRT(I) = '' : # len(mess(0,455,1)) : # Non défini TIVAN
     [M:PLF1]TYPFIN(I)    = [F:COU]TYPFIN
     [M:PLF1]ORGFIN(I)    = [F:COU]ORGFIN
     [M:PLF1]LNKREPI(I)    = [F:COU]LNKREP : # X3-17093
     #LIPET - 2017-05-11 - X3-35993 - END
     J = find(num$([M:PLF1]NUMLIG(nolign-1))+[F:COU]TYPCRG,[M:PLF1]CHAMP)
     If J=0
      [M:PLF1]NBRINV +=1
      J = [M:PLF1]NBRINV
     Endif
     [M:PLF1]NUMLIGI(J-1)    = [M:PLF1]NUMLIG(nolign-1)
     [M:PLF1]TYPCRGI(J-1)    = [M:PLF1]TYPCRG(I)
     [M:PLF1]TYPCSTI(J-1)    = 1 # Automatique  # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
     [M:PLF1]CSTTOTCLLI(J-1) = [M:PLF1]CSTTOTCLL(I)
     [M:PLF1]CSTTOTIDVI(J-1) = [M:PLF1]CSTTOTIDV(I)
     [M:PLF1]CSTIPTCLLI(J-1) = [M:PLF1]CSTIPTCLL(I)
     [M:PLF1]CSTIPTIDVI(J-1) = [M:PLF1]CSTIPTIDV(I)
     [M:PLF1]DESTYPFRTI(J-1) = [M:PLF1]DESTYPFRT(I)
     [M:PLF1]TYPFINI(J-1)    = [M:PLF1]TYPFIN(I)
     [M:PLF1]ORGFINI(J-1)    = [M:PLF1]ORGFIN(I)
     #LIPET - 2017-05-11 - X3-35993 - START
     [M:PLF1]LNKREPI(J-1)    = [M:PLF1]LNKREP(I)  : # X3-17093
     #LIPET - 2017-05-11 - X3-35993 - END
     [M:PLF1]CHAMP(J-1)      = num$([M:PLF1]NUMLIG(nolign-1))+[M:PLF1]TYPCRG(I)
     I +=1
   Endif # 71873
 Endif
Next
Filter [COU]
[M:PLF1]NBRCST = I
# FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg = FRA
If (GCURLEG="FRA" & [M:PLF1]CATFRT(nolign-1)<>"") | [M:PLF1]EMP(nolign-1)<>""
 # SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts : ajout de la société en paramètre
 If GCURLEG="FRA" Then
  CAT=[M:PLF1]CATFRT(nolign-1)
 Else
  CAT=""
 Endif
# Call COUT_PATSAL([M:PLF1]EMP(nolign-1),[M:PLF1]CTRNUM(nolign-1),[M:PLF1]CATFRT(nolign-1),VALEUR,[M:PLF1]SES(nolign-1),len(mess(0,10455,1)),[M:PLF1]CPY(nolign-1))
 Call COUT_PATSAL([M:PLF1]EMP(nolign-1),[M:PLF1]CTRNUM(nolign-1),[M:PLF1]CATFRT(nolign-1),VALEUR,[M:PLF1]SES(nolign-1),"",[M:PLF1]CPY(nolign-1))
 #LIPET - 2017-05-11 - X3-35993 - START
 If GMESSAGE<>"" : mkstat=2 : End  : Endif : # X3-17093
 #LIPET - 2017-05-11 - X3-35993 - END
Endif


# SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71873 : DEBUT
# Récupération des coûts <> "Non calculé" du formateur
Local Integer FLAG_TROUVE
Local Decimal TAUX_TOTAL, TAUX_IMPUTABLE

[M:PLF1]STG(nolign-1) = VALEUR
Gosub RECH_FORMATEUR
If FORMATEUR<>"" # Le formateur est connu
  FLAG_TROUVE = 2
Else # Le formateur est inconnu, on regarde si c'est un stage interne
  FLAG_TROUVE = 1
  Gosub RECH_FORMATEUR_NBHRES
Endif
If FLAG_TROUVE = 2 Then
  # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUPAR, on calcule ou pas les coûts du formateur
  If GCALCOUFOR=2 Then
#    Filter [ADI] Where NUMTAB=10451 & N1<3 & N2=2
# FQ81085 - SEGAY 25/05/12 - Field LEGPLF has been added
    Filter [ADI] Where NUMTAB=10451 & N1<3 & N2=2 & (LEG="" | LEG=MLEGPLF)
    For [ADI]CODE
      If FORMATEUR<>"" # Le formateur est connu
        # Coût réel total
        Call TAUX_HORAIRE (FORMATEUR,CTRFORM,date$,TAUX_TOTAL,[F:ADI]N1,2,1) From TRTCOUT
        # Coût réel imputable
        Call TAUX_HORAIRE (FORMATEUR,CTRFORM,date$,TAUX_IMPUTABLE,[F:ADI]N1,2,2) From TRTCOUT
      Else # Le formateur est inconnu, mais c'est un stage interne
        # Coût réel total
        Call CALC_COUT_FORMATEUR([M:PLF1]CPY([M:PLF0]LIGCUR-1),date$,TAUX_TOTAL,[F:ADI]N1,2,1)
        # Coût réel imputable
        Call CALC_COUT_FORMATEUR([M:PLF1]CPY([M:PLF0]LIGCUR-1),date$,TAUX_IMPUTABLE,[F:ADI]N1,2,2)
      Endif
      #--- Mise à jour de la table visible des coûts
      # X3-11689 TIVAN
#      I = find([F:ADI]CODE,[M:PLF1]TYPCRG(0..[M:PLF1]NBRCST))
#      If I=0
#        [M:PLF1]NBRCST +=1
#        I = [M:PLF1]NBRCST
#      Endif
      Gosub IS_REPART_TODO From SUBPLF2
      Call EFFTYPCRG([F:ADI]CODE) From SUBPLF2
      [M:PLF1]NBRCST +=1
      I = [M:PLF1]NBRCST
      # end X3-11689 TIVAN
      [M:PLF1]TYPCRG(I-1)    = [F:ADI]CODE
      [M:PLF1]TYPCST(I-1)    = 1 # Automatique # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
      Raz [M:PLF1]CSTTOTCLL(I-1), CSTIPTCLL(I-1)
      [M:PLF1]DESTYPFRT(I-1) = ''
      If I>1
        [M:PLF1]TYPFIN(I-1)   = [M:PLF1]TYPFIN(I-2)
        [M:PLF1]ORGFIN(I-1)   = [M:PLF1]ORGFIN(I-2)
      Endif
      [M:PLF1]CSTTOTIDV(I-1) = arr(TAUX_TOTAL*NBH,0.01)
      [M:PLF1]CSTIPTIDV(I-1) = arr(TAUX_IMPUTABLE*NBH,0.01)

      If [L]REPART_TODO=0 : # X3-11689 TIVAN
        If I>1
          [M:PLF1]TYPFIN(I-1)   = [M:PLF1]TYPFIN(I-2)
          [M:PLF1]ORGFIN(I-1)   = [M:PLF1]ORGFIN(I-2)
          Raz [M:PLF1]LNKREP(I-1)  : # X3-17093
        Endif
       Else: # X3-11689
        [M]TYPFIN(I-1)=[F:HRTCR]TYPFIN
        [M]ORGFIN(I-1)=[F:HRTCR]ORGFIN
        # 2nd line in table
        Gosub REPART_PLF1_CST From SUBPLF2
        If GMESSAGE<>"" : Break  : Endif # X3-17093
      Endif: # X3-11689

      ### add a line in invisible tab
      # nolign from the table of stage TIVAN
      #--- Mise à jour de la table invisible des coûts
      # Répartition # X3-11689 TIVAN
#      J = find(num$([M:PLF1]NUMLIG(nolign-1))+[F:ADI]CODE,[M:PLF1]CHAMP)
#      If J=0
#        [M:PLF1]NBRINV +=1
#        J = [M:PLF1]NBRINV
#      Endif
      Call EFFTYPCRGI([M:PLF1]NUMLIG(nolign-1), [F:ADI]CODE,0) From SUBPLF2 :# X3-17093
      [M:PLF1]NBRINV +=1
      J = [M:PLF1]NBRINV
      If [L]REPART_TODO=1
        [M:PLF1]NBRINV +=1
      Endif
      # end X3-11689 TIVAN
      [M:PLF1]TYPCRGI(J-1)    = [F:ADI]CODE
      [M:PLF1]TYPCSTI(J-1)    = 1 # Automatique # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
      Raz [M:PLF1]CSTTOTCLLI(J-1), CSTIPTCLLI(J-1)
      # X3-11689 TIVAN
#      [M:PLF1]CSTTOTIDVI(J-1) = arr(TAUX_TOTAL*NBH,0.01)
#      [M:PLF1]CSTIPTIDVI(J-1) = arr(TAUX_IMPUTABLE*NBH,0.01)
      [M:PLF1]CSTTOTIDVI(J-1) = [M:PLF1]CSTTOTIDV(I-1)
      [M:PLF1]CSTIPTIDVI(J-1) = [M:PLF1]CSTIPTIDV(I-1)
      # end X3-11689 TIVAN
      [M:PLF1]DESTYPFRTI(J-1) = '' : # JML len(mess(0,455,1)) # Non défini
      [M:PLF1]NUMLIGI(J-1)   = [M:PLF1]NUMLIG(nolign-1)
      [M:PLF1]TYPFINI(J-1)   = [M:PLF1]TYPFIN(I-1)
      [M:PLF1]ORGFINI(J-1)   = [M:PLF1]ORGFIN(I-1)
      [M:PLF1]LNKREPI(J-1)   = [M:PLF1]LNKREP(I-1)    :# X3-17093 TIVAN
      [M:PLF1]CHAMP(J-1)     = num$([M:PLF1]NUMLIG(nolign-1))+[F:ADI]CODE
      # X3-11689 TIVAN
      If [L]REPART_TODO=1
         # 2nd line
         [M:PLF1]TYPCRGI(J)    = [F:ADI]CODE
         [M:PLF1]TYPCSTI(J)    = [M:PLF1]TYPCSTI(J-1)
         [M:PLF1]CSTTOTCLLI(J) = [M:PLF1]CSTTOTCLLI(I) :# X3-17093
         [M:PLF1]CSTIPTCLLI(J) = [M:PLF1]CSTIPTCLLI(I) :# X3-17093
         [M:PLF1]DESTYPFRTI(J) = [M:PLF1]DESTYPFRTI(I) :# X3-17093

         [M:PLF1]NUMLIGI(J)    = [M:PLF1]NUMLIGI(J-1)
         [M:PLF1]LNKREPI(J)    = [M:PLF1]LNKREP(I)     :# X3-17093
         [M:PLF1]CHAMP(J)      = [M:PLF1]CHAMP(J-1)

         [M:PLF1]TYPFINI(J)    = [M:PLF1]TYPFIN(I)
         [M:PLF1]ORGFINI(J)    = [M:PLF1]ORGFIN(I)

         [M:PLF1]CSTTOTIDVI(J) = [M:PLF1]CSTTOTIDV(I)
         [M:PLF1]CSTIPTIDVI(J) = [M:PLF1]CSTIPTIDV(I)

      Endif :# TIVAN

    Next
    Filter [ADI]
  Endif
Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71873 : FIN
# X3-17093 TIVAN
If GMESSAGE<>"" : mkstat=2 : End : Endif

# La modif du stage, modifie le cumul par stage dans l'écran PLF2
[M:PLF1]FLGMOD(nolign-1) = 1
Affzo [PLF1]15
# Bug 70042 : SYMEU 28/12/2010
Actzo [M:PLF1]NBRCST
End

######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : inhiber les stages des calculs
######################################################################################
Subprog AM_CLCFLG(VALEUR)
Variable Integer VALEUR
  # La modif du flag de calcul entraîne le recalcul des totaux du plan
  [M:PLF1]FLGMOD(nolign-1) = 1
End

Subprog AS_EMP(VALEUR)
Variable Char    VALEUR()
If [M:PLF1]NBREMP(nolign-1)>1
 mkstat = 1 : End
Endif
# Fiche 70600 - SYMEU - 11/01/2011 : ne pas pouvoir modifier le matricule quand la demande
# est renseignée
If [M:PLF1]DEMNUM(nolign-1)<>""
 mkstat = 2 : End
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini, pas d'accès au matricule et raz prénom
If L_STAGE_NON_DEF = [M:PLF1]STG(nolign-1) Then
 Effzo [M:PLF1]SRN(nolign-1)
 mkstat = 1
 End
Endif
End


Subprog AM_EMP(VALEUR)
Variable Char    VALEUR()
Local    Char    CONTRAT(GLONHRCTR)
Local    Char    CAT(5)
If clalev([F:ADI])=0   : Local File ATABDIV  [ADI]  : Endif
If clalev([F:FCY])=0   : Local File FACILITY [FCY]  : Endif
If VALEUR<>""
 Read [ID]ID0=VALEUR
 If !fstat
  Filter [ADI] Where NUMTAB=10454 Order By Key CLE=N1
  For [ADI]CLE
   If fix((date$-[F:ID]DATBRN)/365)<=[F:ADI]N1
    Break
   Endif
  Next
  Filter [ADI]
  # SYMEU : EXI 66191 LOT 10 - V6.1 : on récupère le prénom
  [M:PLF1]SRN(nolign-1)    = [F:ID]SRN
  [M:PLF1]AGE(nolign-1)    = [F:ADI]CODE
  [M:PLF1]SEX(nolign-1)    = [F:ID]SEX
  [M:PLF1]NBREMP(nolign-1) = 1
  Raz [M:PLF1]CTRNUM(nolign-1)
  # FQ70589 - MABON 25/03/11 - Vérifier que le lien a été mis dans la transaction
#  Affzo [M:PLF1]NBREMP(nolign-1), SEX(nolign-1), AGE(nolign-1), ZAGE(nolign-1)
  Affzo [M:PLF1]NBREMP(nolign-1), SEX(nolign-1), AGE(nolign-1)
  If dim([M:PLF1]ZAGE)>0 Then Affzo [M:PLF1]ZAGE(nolign-1) : Endif
  If [F:ID]FLGMULCTR<>2
   Call CHERCHE_CTR(VALEUR,date$,CONTRAT) From DIVPAYE
   [M:PLF1]CTRNUM(nolign-1) = CONTRAT
   Filter [HRCTR] Where REFNUM=VALEUR & CTRNUM=CONTRAT & CTRDAT<=date$
   Read [HRCTR]CTR0 Last
   Filter [HRCTR]
   If !fstat
    # SYMEU : EXI 66191 LOT 10 - V6.1 : le site du contrat doit être compatible avec le
    # site du plan, s'il est renseigné
    If [M:PLF0]FCYPLF <> "" and [F:HRCTR]ETRFCY <> [M:PLF0]FCYPLF Then
      Call MES_ERR_SITE ([F:HRCTR]ETRFCY)
      End
    Endif
    [M:PLF1]FCY(nolign-1)    = [F:HRCTR]ETRFCY
    [M:PLF1]SRV(nolign-1)    = [F:HRCTR]ETRSRV
    # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg = FRA
    If GCURLEG="FRA" Then
      [M:PLF1]CATFRT(nolign-1) = [F:HRCTR]CATFRT
    Endif
    # SYMEU : EXI 66191 LOT 10 - V6.1 : renseignement des colonnes supplémentaires de
    # la demande : emploi type et poste
    [M:PLF1]JOBPOT(nolign-1) = [F:HRCTR]JOBPOT
    [M:PLF1]POT(nolign-1)    = [F:HRCTR]POT
    # FQ70589 - MABON 25/03/11 - Vérifier que le lien a été mis dans la transaction
#    Affzo [M:PLF1]JOBPOT(nolign-1),POT(nolign-1), ZJOBPOT(nolign-1), ZPOT(nolign-1)
    Affzo [M:PLF1]JOBPOT(nolign-1),POT(nolign-1)
    If dim([M:PLF1]ZJOBPOT)>0 Then Affzo [M:PLF1]ZJOBPOT(nolign-1) : Endif
    If dim([M:PLF1]ZPOT)>0 Then Affzo [M:PLF1]ZPOT(nolign-1) : Endif
    Read [FCY]FCY0=[F:HRCTR]ETRFCY
    If !fstat
     # SYMEU : EXI 66191 LOT 10 - V6.1 : la société du site du contrat doit être compatible
     # avec la société du plan, si elle est renseignée
     If [M:PLF0]CPYPLF <> "" and [F:FCY]LEGCPY <> [M:PLF0]CPYPLF Then
       Call MES_ERR_SOC ([F:FCY]LEGCPY,[F:HRCTR]ETRFCY)
       End
     Endif
     [M:PLF1]CPY(nolign-1) = [F:FCY]LEGCPY
    Endif
    # SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts : ajout de la société en paramètre
    # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg = FRA
    If GCURLEG="FRA" Then
      CAT=[M:PLF1]CATFRT(nolign-1)
    Else
      CAT=""
    Endif
#    Call COUT_PATSAL(VALEUR,CONTRAT,[M:PLF1]CATFRT(nolign-1),[M:PLF1]STG(nolign-1),[M:PLF1]SES(nolign-1),len(mess(0,10455,1)),[M:PLF1]CPY(nolign-1))
    Call COUT_PATSAL(VALEUR,CONTRAT,[M:PLF1]CATFRT(nolign-1),[M:PLF1]STG(nolign-1),[M:PLF1]SES(nolign-1),"",[M:PLF1]CPY(nolign-1))
    If GMESSAGE<>"" : mkstat=2 : End  : Endif : # X3-17093
   # X3-17093 TIVAN
   Endif
  Endif
  # FQ70589 - MABON 25/03/11 - Vérifier que le lien a été mis dans la transaction
#  Affzo [M:PLF1]CTRNUM(nolign-1), CATFRT(nolign-1), FCY(nolign-1), SRV(nolign-1), ZSRV(nolign-1)
  # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg = FRA
#  Affzo [M:PLF1]CTRNUM(nolign-1), CATFRT(nolign-1), FCY(nolign-1), SRV(nolign-1)
  Affzo [M:PLF1]CTRNUM(nolign-1), FCY(nolign-1), SRV(nolign-1)
  If GCURLEG="FRA"       Then Affzo [M:PLF1]CATFRT(nolign-1) : Endif
  If dim([M:PLF1]ZSRV)>0 Then Affzo [M:PLF1]ZSRV(nolign-1)   : Endif
  # SYMEU : EXI 66191 LOT 10 - V6.1 : on affiche le prénom
  Affzo [M:PLF1]SRN(nolign-1)
 Endif
Else
  # FQ81085 - SEGAY 25/05/12 - Field LEGPLF has been added
  [M:PLF1]SRN(nolign-1)=""
  Affzo [M:PLF1]SRN(nolign-1)
Endif
End


Subprog C_EMP(VALEUR)
Variable Char    VALEUR()
Local    Integer I, NOL, OK
Local    Char    CONTRAT(GLONHRCTR)
If VALEUR<>""
 NOL = nolign-1
 I = find(VALEUR,[M:PLF1]EMP(0..NOL-1),[M:PLF1]EMP(NOL+1..dim([M:PLF1]EMP)-1))
 If I
  If I>NOL
   I += 1
  Endif
  OK = 2
  # Code déjà existant en ligne
  Call AVERTIR(mess(24,123,1)-num$(I),OK) From GESECRAN
  If OK=1 : mkstat=2 : End : Endif
 Endif

 # FQ81085 - MABON 22/05/12 - Verifies LEG
 If dim([M:PLF0]LEGPLF)>0 & [M:PLF0]LEGPLF<>"" Then
   Read [ID]ID0=VALEUR
   If !fstat & [F:ID]FLGMULCTR<>2 Then
     Call CHERCHE_CTR(VALEUR,date$,CONTRAT) From DIVPAYE
     Filter [HRCTR] Where REFNUM=VALEUR & CTRNUM=CONTRAT & CTRDAT<=date$
     Read [HRCTR]CTR0 Last
     Filter [HRCTR]
     If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
     Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
     If [F:FCY]LEG<>"" & [F:FCY]LEG<>[M:PLF0]LEGPLF Then
      GMESSAGE=mess(275,10717,1)-[M:PLF0]LEGPLF : # La législation du matricule doit être
      mkstat=2
     Endif
   Endif
 Endif
Endif
End


Subprog AS_CTRNUM(VALEUR)
Variable Char     VALEUR
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Read[ID]ID0=[M:PLF1]EMP(nolign-1)
If fstat | [M:PLF1]NBREMP(nolign-1)>1
 mkstat = 1 : End
Endif
If [F:ID]FLGMULCTR<>2
 mkstat = 2 : End
Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini, pas d'accès au contrat
If L_STAGE_NON_DEF = [M:PLF1]STG(nolign-1) Then
 mkstat = 1 : End
Endif
If [M:PLF1]CTRNUM(nolign-1)=""
 Local Char SGCURLEG(5) : SGCURLEG=GCURLEG
 Call SELCTR([M:PLF1]EMP(nolign-1),date$,date$,VALEUR) From DIVPAYE
 If VALEUR="" Then GCURLEG=SGCURLEG : Endif
Endif
End


Subprog AM_CTRNUM(VALEUR)
Variable Char     VALEUR
Local    Char    CAT(5)
If clalev([F:FCY])=0 : Local File FACILITY [FCY]: Endif
Filter [HRCTR] Where REFNUM=[M:PLF1]EMP(nolign-1) & CTRNUM=VALEUR & CTRDAT<=date$
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If !fstat
 # FQ81085 - MABON 22/05/12 - Verifies LEG
 Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
 If dim([M:PLF0]LEGPLF)>0 & [F:FCY]LEG<>"" & [F:FCY]LEG<>[M:PLF0]LEGPLF Then
  GMESSAGE=mess(276,10717,1)-[M:PLF0]LEGPLF : # La législation du contrat doit être
  mkstat=2
  End
 Endif
 # SYMEU : EXI 66191 LOT 10 - V6.1 : le site du contrat doit être compatible avec le
 # site du plan, s'il est renseigné
 If [M:PLF0]FCYPLF <> "" and [F:HRCTR]ETRFCY <> [M:PLF0]FCYPLF Then
   Call MES_ERR_SITE ([F:HRCTR]ETRFCY)
   End
 Endif
 [M:PLF1]FCY(nolign-1)    = [F:HRCTR]ETRFCY
 [M:PLF1]SRV(nolign-1)    = [F:HRCTR]ETRSRV
 # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg = FRA
 If GCURLEG="FRA" Then
  [M:PLF1]CATFRT(nolign-1) = [F:HRCTR]CATFRT
  CAT=[M:PLF1]CATFRT(nolign-1)
 Else
  CAT=""
 Endif
 # SYMEU : EXI 66191 LOT 10 - V6.1 : renseignement des colonnes supplémentaires de
 # la demande : emploi type et poste
 [M:PLF1]JOBPOT(nolign-1) = [F:HRCTR]JOBPOT
 [M:PLF1]POT(nolign-1)    = [F:HRCTR]POT
 # FQ70589 - MABON 25/03/11 - Vérifier que le lien a été mis dans la transaction
# Affzo [M:PLF1]JOBPOT(nolign-1),POT(nolign-1),ZJOBPOT(nolign-1),ZPOT(nolign-1)
 Affzo [M:PLF1]JOBPOT(nolign-1),POT(nolign-1)
 If dim([M:PLF1]ZJOBPOT)>0 Then Affzo [M:PLF1]ZJOBPOT(nolign-1) : Endif
 If dim([M:PLF1]ZPOT)>0 Then Affzo [M:PLF1]ZPOT(nolign-1) : Endif
 Read [FCY]FCY0=[F:HRCTR]ETRFCY
 If !fstat
  # SYMEU : EXI 66191 LOT 10 - V6.1 : la société du site du contrat doit être compatible
  # avec la société du plan, si elle est renseignée
  If [M:PLF0]CPYPLF <> "" and [F:FCY]LEGCPY <> [M:PLF0]CPYPLF Then
    Call MES_ERR_SOC ([F:FCY]LEGCPY,[F:HRCTR]ETRFCY)
    End
  Endif
  [M:PLF1]CPY(nolign-1) = [F:FCY]LEGCPY
 Endif
 # SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts : ajout de la société en paramètre
 # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg = FRA
# Call COUT_PATSAL([M:PLF1]EMP(nolign-1),VALEUR,[M:PLF1]CATFRT(nolign-1),[M:PLF1]STG(nolign-1),[M:PLF1]SES(nolign-1),len(mess(0,10455,1)),[M:PLF1]CPY(nolign-1))
 Call COUT_PATSAL([M:PLF1]EMP(nolign-1),VALEUR,[M:PLF1]CATFRT(nolign-1),[M:PLF1]STG(nolign-1),[M:PLF1]SES(nolign-1),"",[M:PLF1]CPY(nolign-1))
 # X3-17093
  If GMESSAGE<>"" : mkstat=2 : End  : Endif : # X3-17093 TIVAN
# FQ70589 - MABON 25/03/11 - Vérifier que le lien a été mis dans la transaction
# Affzo [M:PLF1]CATFRT(nolign-1), FCY(nolign-1), SRV(nolign-1), ZSRV(nolign-1)
 # FQ81085 - US 1637 - 31/05/13 - Ajout vérif sur la leg = FRA
# Affzo [M:PLF1]CATFRT(nolign-1), FCY(nolign-1), SRV(nolign-1)
 Affzo [M:PLF1]FCY(nolign-1), SRV(nolign-1)
 If GCURLEG="FRA"       Then Affzo [M:PLF1]CATFRT(nolign-1) : Endif
 If dim([M:PLF1]ZSRV)>0 Then Affzo [M:PLF1]ZSRV(nolign-1)   : Endif
Endif
End

Subprog AS_CATFRT(VALEUR)
Variable Char    VALEUR()
If [M:PLF1]EMP(nolign-1)<>"" & VALEUR<>""
 mkstat = 2 : End
Endif
End


Subprog AM_CATFRT(VALEUR)
Variable Char    VALEUR()
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : pas de récupération automatique des coûts
If L_STAGE_NON_DEF = [M:PLF1]STG(nolign-1) Then
  End
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts : ajout de la société en paramètre
#Call COUT_PATSAL([M:PLF1]EMP(nolign-1),[M:PLF1]CTRNUM(nolign-1),VALEUR,[M:PLF1]STG(nolign-1),[M:PLF1]SES(nolign-1),len(mess(0,455,1)),[M:PLF1]CPY(nolign-1))
# JML 21/09/15 TIVAN
Call COUT_PATSAL([M:PLF1]EMP(nolign-1),[M:PLF1]CTRNUM(nolign-1),VALEUR,[M:PLF1]STG(nolign-1),[M:PLF1]SES(nolign-1),"",[M:PLF1]CPY(nolign-1))
# X3-17093
 If GMESSAGE<>"" : mkstat=2 : End  : Endif : # X3-17093 TIVAN
Affzo [M:PLF1]15
End

# SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts : ajout de la société en paramètre
Subprog COUT_PATSAL(EMP,CTR,CAT,STG,SES,TYP,CPY)
Value Char    EMP()
Value Char    CTR()
Value Char    CAT()
Value Char    STG()
Value Char    SES()
Value Char    TYP() : # JML TIVAN
Value Char    CPY # SYMEU : EXI 66191 LOT 10 - V6.1

# FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUPAR, on calcule ou pas les coûts du participant
If GCALCOUPAR<>2 Then End : Endif

Local Decimal TXSAL1, TXSAL2, TXPAT1, TXPAT2, NBH
Local Integer I, J
# FQ81085 - SEGAY 25/05/12 - Field LEGPLF has been added
Local Char MLEGPLF(5)
MLEGPLF=GCURLEG
If dim([M:PLF0]LEGPLF)>0 Then MLEGPLF=[M:PLF0]LEGPLF : Endif
# X3-11689 TIVAN
Local Integer NOT_PICKING :
Gosub DECL_REPART From SUBPLF2

If status<>GSTALF4
  NOT_PICKING=1
Endif
# end X3-11689 TIVAN

If clalev([F:ADI])=0  : Local File ATABDIV  [ADI]  : Endif
If clalev([F:STG])=0  : Local File STAGE    [STG]  : Endif
If clalev([F:HRSES])=0  : Local File SESSIONS [HRSES]  : Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts : DEBUT
#If EMP<>""
# Call TAUX_HORAIRE (EMP,CTR,date$,TXSAL1,1,2,1) From TRTCOUT  : # salarial total
# Call TAUX_HORAIRE (EMP,CTR,date$,TXSAL2,1,2,2) From TRTCOUT  : # salarial imputable
# Call TAUX_HORAIRE (EMP,CTR,date$,TXPAT1,2,2,1) From TRTCOUT  : # patronal total
# Call TAUX_HORAIRE (EMP,CTR,date$,TXPAT2,2,2,2) From TRTCOUT  : # patronal imputable
#Elsif CAT<>""
# # Recherche des taux horaires de la catégorie 2483
# Read[ADI]CODE=10453;CAT
# TXSAL1 = val([F:ADI]A1) : # salarial total
# TXSAL2 = [F:ADI]N1      : # salarial imputable
# TXPAT1 = val([F:ADI]A2) : # patronal total
# TXPAT2 = [F:ADI]N2      : # patronal imputable
#Else
# End
#Endif
Call CALC_TAUX_HORAIRE (EMP,CTR,CAT,CPY,TXSAL1,TXSAL2,TXPAT1,TXPAT2)
# SYMEU : EXI 66191 LOT 10 - V6.1 : valorisation des coûts : FIN

# Recherche du nombre d'heures imputables
If SES<>""
 If SES<>[F:HRSES]COD :# TIVAN
   Read [HRSES]SES0=SES
   If fstat : Raz [F:HRSES] : Endif :# TIVAN
 Endif
 If ([F:HRSES]STG=STG | [F:HRSES]STG="") & [F:HRSES]NBRHOUIPT<>0 :# TIVAN
     NBH = [F:HRSES]NBRHOUIPT
   Endif :# TIVAN
 Endif
If STG<>"" :# TIVAN
  If STG<>[F:STG]COD
    Read [STG]STG0=STG
    If fstat : Raz [F:STG] : Endif
  Endif
  [L]WTCRCOD= [F:STG]TCRCOD
  If NBH=0 & [F:STG]NBRHOUIPT<>0
    NBH = [F:STG]NBRHOUIPT
  Endif
Endif :# TIVAN

# Maj du tableau des coûts avec SAL et PAT
# N1 : 1=Salarial 2=Patronal
# N2 : 1=Participant
#Filter [ADI] Where NUMTAB=10451 & (N1=1 | N1=2) & N2=1
# FQ81085 - SEGAY 25/05/12 - Field LEGPLF has been added
Filter [ADI] Where NUMTAB=10451 & (N1=1 | N1=2) & N2=1 & (LEG="" | LEG=MLEGPLF)
For [ADI]CODE
 If ([F:ADI]N1=1 & (TXSAL1*NBH<>0 | TXSAL2*NBH<>0))
&|  ([F:ADI]N1=2 & (TXPAT1*NBH<>0 | TXPAT2*NBH<>0))
  Gosub IS_REPART_TODO From SUBPLF2 :# X3-11689 TIVAN
#  If status<>GSTALF4 : # X3-11689 -> If NOT_PICKING
  If NOT_PICKING : # On ne fait pas de picking => on affiche
   # X3-11689
#  I = find([F:ADI]CODE,[M:PLF1]TYPCRG(0..[M:PLF1]NBRCST))
#   If I=0
#    [M:PLF1]NBRCST +=1
#    I = [M:PLF1]NBRCST
#   Endif
    Call EFFTYPCRG([F:ADI]CODE) From SUBPLF2 :# X3-11689
    If ([M:PLF1]NBRCST+[L]REPART_TODO) >=dim([M:PLF1]TYPCRG)
       GMESSAGE=mess(304,10717,1) :# 'Tableau des coûts plein'
       Break
    Endif :# TIVAN
    [M:PLF1]NBRCST +=1
    I = [M:PLF1]NBRCST
   Endif
    # end X3-11689 TIVAN

    [M:PLF1]TYPCRG(I-1)    = [F:ADI]CODE
    [M:PLF1]TYPCST(I-1)    = 1 # Automatique
#    Affzo [M:PLF1]TYPCST(I-1) :# X3-11689
    [M:PLF1]CSTTOTCLL(I-1) = 0
    [M:PLF1]CSTIPTCLL(I-1) = 0
    [M:PLF1]DESTYPFRT(I-1) = TYP
    # X3-11689 - déplacé
#    If I>1
#     [M:PLF1]TYPFIN(I-1)   = [M:PLF1]TYPFIN(I-2)
#     [M:PLF1]ORGFIN(I-1)   = [M:PLF1]ORGFIN(I-2)
#    Endif
    # end X3-11689
    If [F:ADI]N1=1
       # salarial
        [M:PLF1]CSTTOTIDV(I-1) = arr(TXSAL1*NBH,0.01)
        [M:PLF1]CSTIPTIDV(I-1) = arr(TXSAL2*NBH,0.01)
    Else
       # patronal
        [M:PLF1]CSTTOTIDV(I-1) = arr(TXPAT1*NBH,0.01)
        [M:PLF1]CSTIPTIDV(I-1) = arr(TXPAT2*NBH,0.01)
    Endif :# TIVAN
  # X3-11689 TIVAN
    If [L]REPART_TODO=0
      # X3-11689 - déplacé
      If I>1
       # report previous line
        [M:PLF1]TYPFIN(I-1)   = [M:PLF1]TYPFIN(I-2)
        [M:PLF1]ORGFIN(I-1)   = [M:PLF1]ORGFIN(I-2)
        Raz [M:PLF1]LNKREP(I-1)  : # X3-17093
      Endif
    Else
      Gosub REPART_PLF1_CST From SUBPLF2 : # X3-11689
    Endif
    # end X3-11689 TIVAN

    # search in invisible table
    # X3-11689
#    Affzo [PLF1]TYPCRG(I-1),CSTTOTCLL(I-1),CSTTOTIDV(I-1),CSTIPTCLL(I-1),CSTIPTIDV(I-1)
#    J = find(num$([M:PLF1]NUMLIG(nolign-1))+[F:ADI]CODE,[M:PLF1]CHAMP)
    # nolign from the table of stage
    Call EFFTYPCRGI([M:PLF1]NUMLIG(nolign-1), [F:ADI]CODE,0) From SUBPLF2 :# X3-17093

  Else : # On fait picking
    # X3-11689
#    J = find(num$([M:PLF1]NUMLIG([M:PLF1]NBRPLF-1))+[F:ADI]CODE,[M:PLF1]CHAMP)
    Call EFFTYPCRGI([M:PLF1]NUMLIG([M:PLF1]NBRPLF-1), [F:ADI]CODE,0) From SUBPLF2 : # X3-17093
  Endif

## add a line in invisible tab
   # X3-11689 TIVAN
#  If J=0
#   [M:PLF1]NBRINV +=1
#   J = [M:PLF1]NBRINV
#  Endif
  [M:PLF1]NBRINV +=1
  J = [M:PLF1]NBRINV

  # end X3-11689 TIVAN
  [M:PLF1]TYPCRGI(J-1)    = [F:ADI]CODE
  [M:PLF1]TYPCSTI(J-1)    = 1 # Automatique # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
  [M:PLF1]CSTTOTCLLI(J-1) = 0
  [M:PLF1]CSTIPTCLLI(J-1) = 0
  [M:PLF1]DESTYPFRTI(J-1) = TYP

  #  If status<>GSTALF4 : # X3-11689 -> If NOT_PICKING TIVAN
  If NOT_PICKING
   # from visible table
   [M:PLF1]NUMLIGI(J-1)   = [M:PLF1]NUMLIG(nolign-1)
   [M:PLF1]TYPFINI(J-1)   = [M:PLF1]TYPFIN(I-1)
   [M:PLF1]ORGFINI(J-1)   = [M:PLF1]ORGFIN(I-1)
   [M:PLF1]LNKREPI(J-1)   = [M:PLF1]LNKREP(I-1)   :# X3-17093 TIVAN
   [M:PLF1]CHAMP(J-1)     = num$([M:PLF1]NUMLIG(nolign-1))+[F:ADI]CODE
   # X3-11689 TIVAN
   [M:PLF1]CSTTOTIDVI(J-1) = [M:PLF1]CSTTOTIDV(I-1)
   [M:PLF1]CSTIPTIDVI(J-1) = [M:PLF1]CSTIPTIDV(I-1)
   If [L]REPART_TODO=1
     INV1=J-1 : # indice 1st line
     Gosub REPART_PLF1_INV From SUBPLF2
   Endif
   # end X3-11689 TIVAN

  # 40594
  Else # Picking TIVAN

    [M:PLF1]NUMLIGI(J-1)   = [M:PLF1]NUMLIG([M:PLF1]NBRPLF-1)
    # X3-11689 - déplacé
#    [M:PLF1]TYPFINI(J-1)   = [F:DML]TYPFIN
#    [M:PLF1]ORGFINI(J-1)   = [F:DML]ORGFIN
    [M:PLF1]CHAMP(J-1)     = num$([M:PLF1]NUMLIG([M:PLF1]NBRPLF-1))+[F:ADI]CODE
    If [F:ADI]N1=1
      [M:PLF1]CSTTOTIDVI(J-1) = arr(TXSAL1*NBH,0.01)
      [M:PLF1]CSTIPTIDVI(J-1) = arr(TXSAL2*NBH,0.01)
    Else
      [M:PLF1]CSTTOTIDVI(J-1) = arr(TXPAT1*NBH,0.01)
      [M:PLF1]CSTIPTIDVI(J-1) = arr(TXPAT2*NBH,0.01)
    Endif
    # X3-11689
    If [L]REPART_TODO=0
      # X3-11689 - déplacé
      Raz [M:PLF1]LNKREPI(J-1) :# X3-17093
      [M:PLF1]TYPFINI(J-1)   = [F:DML]TYPFIN
      [M:PLF1]ORGFINI(J-1)   = [F:DML]ORGFIN
    Else
      INV1=J-1 : # indice 1st line
      Gosub REPART_PLF1_INV From SUBPLF2
    Endif
    # end X3-11689 TIVAN
  Endif
# Endif
Next
Filter [ADI]
If GMESSAGE<>"" : End : Endif :# TIVAN
Affzo [M:PLF1]15 # SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 71873
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M:PLF1]EMP(nolign-1)<>""
 mkstat = 2 : End
Endif
End

######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : contrôle de la cohérence entre le site de la ligne
# et le site de l'en-tête; entre la société du site de la ligne et la société de l'en-tête
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
  If VALEUR <> "" Then
    If [M:PLF0]FCYPLF <> "" and VALEUR <> [M:PLF0]FCYPLF Then
      Call MES_ERR_SITE (VALEUR)
      End
    Endif
    If [M:PLF0]CPYPLF <> "" Then
      # Lecture du site
      Read [FCY]FCY0=VALEUR
      If !fstat and [F:FCY]LEGCPY <> [M:PLF0]CPYPLF Then
        Call MES_ERR_SOC ([F:FCY]LEGCPY,VALEUR)
        End
      Endif
    Endif
  Endif

  # FQ81085 - MABON 22/05/12 - Controls that facility is in the same LEG than LEGPLF
  Call C_FCYPLF(VALEUR)
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 [M:PLF1]CPY(nolign-1)="" : End
Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Read [FCY]FCY0=VALEUR
If !fstat
 [M:PLF1]CPY(nolign-1)=[F:FCY]LEGCPY
Endif
End


######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : pas d'accès au sexe si le stage
# est différent du stage non défini  et si la demande est renseignée
######################################################################################
Subprog AS_SEX(VALEUR)
Variable Integer VALEUR
  If L_STAGE_NON_DEF <> [M:PLF1]STG(nolign-1)
& and [M:PLF1]DEMNUM(nolign-1)<>""  Then # SYMEU : EXI 66191 LOT 10 - V6.1 - fiche 71781
   mkstat = 2 : End
  Endif
End


