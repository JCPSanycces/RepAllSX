$OUVRE_BOITE
Local Char    BOXPIC(10)
# SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation
# BOXPIC = "GAU_CHE"+num$(find("DE2",OBJLIS(1..dim(OBJLIS)-1)))
# FQ70605 - MABON 28/03/11 - Avec l'ajout de la fenêtre de sélection des demandes dans l'action PLFPRO, on passe aussi
# dans cette étiquette. Il faut donc préciser le GACTION
If GACTION<>"PLFPRO" Then
  BOXPIC = "GAU_CHE"+num$(find("DE3",OBJLIS(1..dim(OBJLIS)-1)))
Endif
Return

$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#  If dim(SAV_GLEGFIL)>0 : Kill SAV_GLEGFIL : Endif
Return

