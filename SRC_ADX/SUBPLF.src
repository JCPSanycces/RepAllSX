# On stocke les coûts du plan dans le tableau invisible
# SYMEU : EXI 66191 LOT 10 - V6.1 : on ajoute la société et le site
# Filter [PLC] Where YEAPLF=[F:PLF]YEAPLF & VERPLF=[F:PLF]VERPLF & NUMLIG=[F:PLF]NUMLIG
# FQ81085 - MABON 22/05/12 - Adding field LEGPLF
#Filter [PLC] Where YEAPLF=[F:PLF]YEAPLF & VERPLF=[F:PLF]VERPLF & NUMLIG=[F:PLF]NUMLIG
#&                & CPYPLF=[F:PLF]CPYPLF & FCYPLF=[F:PLF]FCYPLF
#&                & LEGPLF=[F:PLF]LEGPLF
#For [PLC]PLC0
# [M:PLF1]NUMLIGI(I)    = [F:PLC]NUMLIG
# [M:PLF1]TYPCRGI(I)    = [F:PLC]TYPCRG
# [M:PLF1]TYPCSTI(I)    = [F:PLC]TYPCST # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
# [M:PLF1]CSTTOTCLLI(I) = [F:PLC]CSTTOTCLL
# [M:PLF1]CSTTOTIDVI(I) = [F:PLC]CSTTOTIDV
# [M:PLF1]CSTIPTCLLI(I) = [F:PLC]CSTIPTCLL
# [M:PLF1]CSTIPTIDVI(I) = [F:PLC]CSTIPTIDV
# [M:PLF1]DESTYPFRTI(I) = [F:PLC]DESTYPFRT
# [M:PLF1]TYPFINI(I)    = [F:PLC]TYPFIN
# [M:PLF1]ORGFINI(I)    = [F:PLC]ORGFIN
 #LIPET - 2017-05-11 - X3-35993 - START
# [M:PLF1]LNKREPI(I)    = [F:PLC]LNKREP   :# X3-17093
 #LIPET - 2017-05-11 - X3-35993 - END
# [M:PLF1]CHAMP(I)      = num$([F:PLC]NUMLIG)+[F:PLC]TYPCRG
# I +=1
#Next
#Filter [PLC]
# SYMEU : EXI 66191 LOT 10 - V6.1 : on renseigne le prénom, l'emploi type et le poste - DEBUT
#If [M:PLF1]EMP(nolign-1) <> "" Then
#  If [M:PLF1]EMP(nolign-1) <> [F:ID]REFNUM Then
#    Read [ID]ID0=[M:PLF1]EMP(nolign-1)
#  Endif
#  [M:PLF1]SRN(nolign-1) = [F:ID]SRN
#  If [M:PLF1]CTRNUM(nolign-1) <> "" Then
#    Filter [HRCTR] Where REFNUM=[M:PLF1]EMP(nolign-1) & CTRNUM=[M:PLF1]CTRNUM(nolign-1) & CTRDAT<=date$
#    Read [HRCTR]CTR0 Last
#    Filter [HRCTR]
#    If !fstat
#      [M:PLF1]JOBPOT(nolign-1) = [F:HRCTR]JOBPOT
#      [M:PLF1]POT(nolign-1)    = [F:HRCTR]POT
      #SBA : 27/06/2012
      # ne sert à rien. GCURLEG suffit. GSOCIETE pose problème car uniquement inititalisé sur la présence
      # d'un contrat au chargement du document. Il n'est jamais réinitialisé par la suite
#      Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
#      Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#      GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
      #SBA fin
#    Endif
#  Endif
#Else
#  [M:PLF1]JOBPOT(nolign-1) = [F:PLF]JOBPOT
#  [M:PLF1]POT(nolign-1)    = [F:PLF]POT
#Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : on renseigne le prénom, l'emploi type et le poste - FIN
#If GNBLEG=1 : GCURLEG = GDOSLEG : Endif

#PCA 25/05/12 SHOW FIELDS BASED ON LEG
#GCURLEG = [F:PLF]LEGPLF
#If dim([M:PLF0]LEGPLF)>0 Then
#  [M:PLF0]LEGPLF=GCURLEG
#Endif
# Call DISPLAY_HIDE() From SUBPLFLEG
#Return
#TIVAN - 06/07/2017 - X3-35993 - End

$LIENS2
# SYMEU : EXI 66191 LOT 10 - V6.1 : on ajoute la société et le site
# Filter [PLFF] Where YEAPLF=[F:PLF]YEAPLF & VERPLF=[F:PLF]VERPLF
# FQ81085 - MABON 22/05/12 - Adding field LEGPLF
#Filter [PLFF] Where YEAPLF=[F:PLF]YEAPLF & VERPLF=[F:PLF]VERPLF
#&                 & CPYPLF=[F:PLF]CPYPLF & FCYPLF=[F:PLF]FCYPLF
# JML 27/08/15
#TIVAN - Start
Filter [PLFF] Where YEAPLF=[F:PLF]YEAPLF & VERPLF=[F:PLF]VERPLF
&                 & CPYPLF=[F:PLF]CPYPLF & FCYPLF=[F:PLF]FCYPLF & STRDAT>=[M:PLF0]STRDAT & ENDDAT<=[M:PLF0]ENDDAT
&                 & LEGPLF=[F:PLF]LEGPLF
#TIVAN - End
Read [PLFF]PLF0 Last
If !fstat
  [M:PLF0]MAXNUMLIG = [F:PLFF]NUMLIG
Else
  [M:PLF0]MAXNUMLIG = 0
Endif
Filter [PLFF]

# Mise à jour variable bas de tableau
[M:PLF1]NBRINV = I
# On remplit [M:PLF0]
[M:PLF0]YEAPLF = [F:PLF]YEAPLF
# FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
If dim([M:PLF0]LEGPLF)>0 Then
  [M:PLF0]LEGPLF = [F:PLF]LEGPLF
Endif
# End MABON
# SYMEU : EXI 66191 LOT 10 - V6.1 : on récupère la société et le site
[M:PLF0]CPYPLF = [F:PLF]CPYPLF
[M:PLF0]FCYPLF = [F:PLF]FCYPLF
[M:PLF0]VERPLF = [F:PLF]VERPLF
[M:PLF0]FLGCLO = [F:PLF]FLGCLO
If [F:PLC]CUR<>""
 [M:PLF0]CUR = [F:PLC]CUR
Else
 [M:PLF0]CUR = GSYSCUR
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts (onglet PLF4)
Call REMP_PLF4

# On remplit [M:PLF2] "coûts par stage"
Call REMP_PLF2([M:PLF1]NBRPLF)
# SYMEU : EXI 66191 LOT 10 - V6.1 : onglet des coûts par type de financement
Call REMP_PLF3([M:PLF1]NBRPLF)
Affzo [PLF0]TOT,IPT
# La variable bas de tableau est chargée, on met à jour la liste de picking
Gosub REMP_PIC
WPICK=2
Gosub RAFF_PIC
# SYMEU EXI 66191 LOT 10 - V6.1 : picking (29/12/2010)
If (REPONSE = GSTAFIR or REPONSE = GSTALAS or REPONSE = GSTASUI or REPONSE = GSTAPRE)
&  and currbox=BOXPIC Then
  # Quand on se déplace par les boutons de navigation et quand on est sur le tiroir du
  # picking, rafraîchissement du tiroir
  Local Integer L_SVE_GSTA : L_SVE_GSTA = REPONSE
  REPONSE = GSTARAF
  Gosub RAFFRAICHIR From GOBJSUB
  REPONSE = L_SVE_GSTA
Endif
# Pour afficher le tableau des coûts de la 1ère ligne du stage
nolign=1
Call AS_NBRPLF
# Fiche 70626 - SYMEU - 11/01/2011 ; je remets tout sans style avant l'affichage du plan
If [M:PLF1]NBRPLF> 0
  Chgstl [M:PLF1]NBRPLF With ""
Endif

# FQ74363 - MABON 14/06/11 - Si on filtre les données, il ne faut pas pouvoir rendre un plan définitif.
# Par ailleurs, on affiche une info dans l'écran
If FILTSUP<>"1=1" Then
  Grizo [M:PLF0]FLGCLO
  [M:PLF0]LIBFILT= mess(246,10717,1) : # Données filtrées
  # Issue X3-11279 - 2017-01-26 by BRBAN : New filter message
  #LIPET - 2017-05-11 - X3-35993 - START
  If [M:PFI]CPY<>''
    [M:PLF0]LIBFILT -= mess(4,10508,1)-[M:PFI]CPY
  Endif
  If [M:PFI]FCY<>''
     [M:PLF0]LIBFILT -= mess(5,10508,1)-[M:PFI]FCY
  Endif
  If [M:PFI]SRV<>''
     [M:PLF0]LIBFILT -= mess(8,10508,1)-[M:PFI]SRV
  Endif
  If [M:PFI]NAL = 2
     [M:PLF0]LIBFILT -= mess(1,10381,1)-mess(4,10508,1)
  Endif
  # -
  #LIPET - 2017-05-11 - X3-35993 - END
Else
  Actzo [M:PLF0]FLGCLO
  [M:PLF0]LIBFILT=""
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : plan définitif
Call GRISE_FLGCLO([M:PLF0]FLGCLO) From SUBPLF2
Return


## On remplit l'écran PLF2 "coûts par stage"
## On met à jour le coût total plan dans PLF0

Subprog REMP_PLF2(NBR_PLF)
Value Integer NBR_PLF
Local Integer I, J, K, IND
Raz [PLF2]
Raz [M:PLF0]TOT, [M:PLF0]IPT
Local Integer FLAG_OK # SYMEU - fiche 71793 (tester limite variable bas de tableau)

For I=0 To NBR_PLF-1
 # SYMEU : EXI 66191 LOT 10 - V6.1 : inhiber les stages des calculs, si flag = Non
 # Fiche 71549 - SYMEU - 14/02/2011
 If [M:PLF1]CLCFLG(I) = 2 Then
   Raz FLAG_OK # SYMEU - fiche 71793 (tester limite variable bas de tableau)
   J = find([M:PLF1]STG(I),[M:PLF2]STG2)
   If J : # Stage déjà comptabilisé
    IND = J-1
    If [M:PLF1]SES(I)<>"" & !find([M:PLF1]SES(I),[M:PLF1]SES(0..I-1))
     [M:PLF2]NBRSES(J-1) += 1
    Endif
    FLAG_OK = 1 # SYMEU - fiche 71793 (tester limite variable bas de tableau)
   Else : # Nouveau stage
    If [M:PLF2]NBRSTG < dim([M:PLF2]STG2) Then # SYMEU - fiche 71793 (tester limite variable bas de tableau)
      [M:PLF2]STG2([M:PLF2]NBRSTG) = [M:PLF1]STG(I)
      IND = [M:PLF2]NBRSTG
      If [M:PLF1]SES(I)<>""
       [M:PLF2]NBRSES(IND) += 1
      Endif
      [M:PLF2]NBRSTG +=1
      FLAG_OK = 1 # SYMEU - fiche 71793 (tester limite variable bas de tableau)
    Endif # SYMEU - fiche 71793 (tester limite variable bas de tableau)
   Endif

   If FLAG_OK = 1 Then # SYMEU - fiche 71793 (tester limite variable bas de tableau)
     [M:PLF2]NBREMP2(IND) += [M:PLF1]NBREMP(I)
   Endif # SYMEU - fiche 71793 (tester limite variable bas de tableau)

   ## Parcours du tableau invisible des côuts de [PLF1] pour remplir le tableau des coûts par stage
   For K=0 To [M:PLF1]NBRINV-1
    If [M:PLF1]NUMLIG(I)=[M:PLF1]NUMLIGI(K)
     ## On remplit le tableau des coûts par stage
     If FLAG_OK = 1 Then # SYMEU - fiche 71793 (tester limite variable bas de tableau)
       [M:PLF2]CRGTOT(IND) += [M:PLF1]CSTTOTIDVI(K)*[M:PLF1]NBREMP(I)
       [M:PLF2]CRGIPT(IND) += [M:PLF1]CSTIPTIDVI(K)*[M:PLF1]NBREMP(I)
     Endif # SYMEU - fiche 71793 (tester limite variable bas de tableau)
     [M:PLF0]TOT         += [M:PLF1]CSTTOTIDVI(K)*[M:PLF1]NBREMP(I)
     [M:PLF0]IPT         += [M:PLF1]CSTIPTIDVI(K)*[M:PLF1]NBREMP(I)
     # On remplit le tableau invisible du détail des coûts par stage
     OK = 0
     For L=0 To [M:PLF2]NBRINV2-1
      If [M:PLF2]STGI2(L)=[M:PLF1]STG(I) & [M:PLF2]TYPCRGI2(L) = [M:PLF1]TYPCRGI(K)
       OK = 1
       [M:PLF2]CSTTOTI2(L) += [M:PLF1]CSTTOTIDVI(K)*[M:PLF1]NBREMP(I)
       [M:PLF2]CSTIPTI2(L) += [M:PLF1]CSTIPTIDVI(K)*[M:PLF1]NBREMP(I)
       Break
      Endif
     Next
     If OK=0
&    and [M:PLF2]NBRINV2 < dim([M:PLF2]STGI2) Then # SYMEU - fiche 71793 (tester limite variable bas de tableau)
      [M:PLF2]STGI2([M:PLF2]NBRINV2)    = [M:PLF1]STG(I)
      [M:PLF2]TYPCRGI2([M:PLF2]NBRINV2) = [M:PLF1]TYPCRGI(K)
      [M:PLF2]CSTTOTI2([M:PLF2]NBRINV2) = [M:PLF1]CSTTOTIDVI(K)*[M:PLF1]NBREMP(I)
      [M:PLF2]CSTIPTI2([M:PLF2]NBRINV2) = [M:PLF1]CSTIPTIDVI(K)*[M:PLF1]NBREMP(I)
      [M:PLF2]NBRINV2 +=1
     Endif
    Endif
   Next
 Endif # Fiche 71549 - SYMEU - 14/02/2011
Next

# SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts : mise à jour des totaux
Gosub AJOUT_ENVELOPPES

# SYMEU : EXI 66191 LOT 10 - V6.1 : calcul du % entre le total du plan et le budget de référence
Gosub CALCUL_PRCPLFBUD
End

$SETBOUT
# FQ70605 - MABON 28/03/11 - Avec l'ajout de la fenêtre de sélection des demandes dans l'action PLFPRO, on passe aussi
# dans cette étiquette. Il faut donc préciser le GACTION
If GACTION<>"PLFPRO" Then
  # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation : on force la modification
  If FLAG_REVALO = 2 Then
    REP = "M"
  Endif

  # Bouton Supprimer
  If REP=""
   CHAINE += "A"
  Endif
  If CLECUR=0 | REP="M" | !VERROU
   Call VIREBOUT(CHAINE,"AO") From GOBJET : # Bouton filtre
  Endif
  # 39925
  If GREP<>"" | GHISTO=1
   Call VIREBOUT(CHAINE,"Q") From GOBJET : # Bouton proposition
  Endif
  # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation : pas de bouton sur plan définitif
  If [M:PLF0]FLGCLO = 2 Then
    Call VIREBOUT(CHAINE,"V") From GOBJET : # Bouton revalorisation
  Endif
  #LIPET - 2017-05-11 - X3-35993 - START
  # SYMEU : EXI 66191 LOT 10 - V6.1 : bouton Filtre
#  If [M:PLF0]CPYPLF <> "" or [M:PLF0]FCYPLF <> "" Then
#    Call VIREBOUT(CHAINE,"O") From GOBJET : # Bouton filtre
#  Endif
  # Issue X3-11279 - 2017-01-24 by BRBAN : Enabling filter button for Company Level and Folder Level
  If [M:PLF0]FCYPLF <> "" Then
    Call VIREBOUT(CHAINE,"O") From GOBJET : # Bouton filtre
  Endif
  # Issue X3-11279 - 2017-01-24 by BRBAN : If there is a filter buttons must be inactive
  If FILTSUP<>"1=1"
    Call VIREBOUT(CHAINE,"QVCA") From GOBJET : # Bouton filtre
  Endif
  # -
  #LIPET - 2017-05-11 - X3-35993 - END
Endif
Return


$APRES_MODIF
Local Char MLEGPLF(5)
# Interdiction de saisir un plan sur 1 année où il y a déjà un plan définitif.
Case COUZON
 When "YEAPLF"
#TIVAN - Start
  [F:PLF]YEAPLF = CZ : [F:PLF]CPYPLF = [M:PLF0]CPYPLF : [F:PLF]FCYPLF = [M:PLF0]FCYPLF : Gosub READ_BUR From SUBPLF2 : # JML 02/09/15
#TIVAN - End
  If [M:PLF0]VERPLF<>""
   # SYMEU : EXI 66191 LOT 10 - V6.1 : on ajoute la société et le site
   # Read [PLF]PLF0=CZ;[M:PLF0]VERPLF
   # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
   MLEGPLF=GCURLEG
   If dim([M:PLF0]LEGPLF)>0 Then MLEGPLF=[M:PLF0]LEGPLF : Endif
   Read [PLF]PLF0=CZ;MLEGPLF;[M:PLF0]CPYPLF;[M:PLF0]FCYPLF;[M:PLF0]VERPLF
   # Fiche 70502 - SYMEU - 10/01/2011 - Je ne charge le picking que si l'enregistrement
   # existe pour tous les champs de la clé - DEBUT
   # If !fstat : Return : Endif
   If !fstat Then
    If currbox=BOXPIC : # Liste de picking
     [M:PLF0]YEAPLF=CZ
     Gosub REMP_PIC
     WPICK=2
     Gosub RAFF_PIC
     REPONSE = GSTARAF
     Gosub RAFFRAICHIR From GOBJSUB
    Endif
    Return
   Endif
   # Fiche 70502 - SYMEU - 10/01/2011 - FIN

   # SYMEU : EXI 66191 LOT 10 - V6.1 : on ajoute la société et le site
   # Filter [PLF] Where YEAPLF=CZ & FLGCLO=2
   # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
   Filter [PLF] Where YEAPLF=CZ & FLGCLO=2
&                   & CPYPLF=[M:PLF0]CPYPLF & FCYPLF=[M:PLF0]FCYPLF
&                   & LEGPLF=MLEGPLF
   Gosub PLFCLO
  Endif
 When "VERPLF"
  # SYMEU : EXI 66191 LOT 10 - V6.1 : on ajoute la société et le site
  # Read [PLF]PLF0=[M:PLF0]YEAPLF;CZ
  # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
  MLEGPLF=GCURLEG
  If dim([M:PLF0]LEGPLF)>0 Then MLEGPLF=[M:PLF0]LEGPLF : Endif
  Read [PLF]PLF0=[M:PLF0]YEAPLF;MLEGPLF;[M:PLF0]CPYPLF;[M:PLF0]FCYPLF;CZ
  # Fiche 70502 - SYMEU - 10/01/2011 - Je ne charge le picking que si l'enregistrement
  # existe pour tous les champs de la clé - DEBUT
  # If !fstat : Return : Endif
  If !fstat Then
   If currbox=BOXPIC : # Liste de picking
    [M:PLF0]VERPLF=CZ
    Gosub REMP_PIC
    WPICK=2
    Gosub RAFF_PIC
    REPONSE = GSTARAF
    Gosub RAFFRAICHIR From GOBJSUB
   Endif
   Return
  Endif
  # Fiche 70502 - SYMEU - 10/01/2011 - FIN

  # SYMEU : EXI 66191 LOT 10 - V6.1 : on ajoute la société et le site
  # Filter [PLF] Where YEAPLF=[M:PLF0]YEAPLF & FLGCLO=2
  # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
  Filter [PLF] Where YEAPLF=[M:PLF0]YEAPLF & FLGCLO=2
&                  & CPYPLF=[M:PLF0]CPYPLF & FCYPLF=[M:PLF0]FCYPLF
&                  & LEGPLF=MLEGPLF
  Gosub PLFCLO
 # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation : rafraîchissement
 # de la liste gauche de picking - DEBUT
 When "CPYPLF"
  [F:PLF]YEAPLF = [M:PLF0]YEAPLF : [F:PLF]CPYPLF = CZ : [F:PLF]FCYPLF = [M:PLF0]FCYPLF : Gosub READ_BUR From SUBPLF2 : # JML 02/09/15
  If currbox=BOXPIC : # Liste de picking
    # Fiche 70502 - SYMEU - 10/01/2011 - Je ne charge le picking que si l'enregistrement
    # existe pour tous les champs de la clé
    # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
    MLEGPLF=GCURLEG
    If dim([M:PLF0]LEGPLF)>0 Then MLEGPLF=[M:PLF0]LEGPLF : Endif
    Read [PLF]PLF0=[M:PLF0]YEAPLF;MLEGPLF;CZ;[M:PLF0]FCYPLF;[M:PLF0]VERPLF
    If fstat : Return : Endif

    [M:PLF0]CPYPLF=CZ
    Gosub REMP_PIC
    WPICK=2
    Gosub RAFF_PIC
    REPONSE = GSTARAF
    Gosub RAFFRAICHIR From GOBJSUB
  Endif
 When "FCYPLF"
  [F:PLF]YEAPLF = [M:PLF0]YEAPLF : [F:PLF]CPYPLF = [M:PLF0]CPYPLF : [F:PLF]FCYPLF = CZ : Gosub READ_BUR From SUBPLF2 : # JML 02/09/15
  If currbox=BOXPIC : # Liste de picking
    # Fiche 70502 - SYMEU - 10/01/2011 - Je ne charge le picking que si l'enregistrement
    # existe pour tous les champs de la clé
    # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
    MLEGPLF=GCURLEG
    If dim([M:PLF0]LEGPLF)>0 Then MLEGPLF=[M:PLF0]LEGPLF : Endif
    Read [PLF]PLF0=[M:PLF0]YEAPLF;MLEGPLF;[M:PLF0]CPYPLF;CZ;[M:PLF0]VERPLF
    If fstat : Return : Endif

    [M:PLF0]FCYPLF=CZ
    Gosub REMP_PIC
    WPICK=2
    Gosub RAFF_PIC
    REPONSE = GSTARAF
    Gosub RAFFRAICHIR From GOBJSUB
  Endif
 # SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation : rafraîchissement
 # de la liste gauche de picking - FIN
 # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
 When "LEGPLF"
  If currbox=BOXPIC : # Liste de picking
    # Fiche 70502 - SYMEU - 10/01/2011 - Je ne charge le picking que si l'enregistrement
    # existe pour tous les champs de la clé
    Read [PLF]PLF0=[M:PLF0]YEAPLF;CZ;[M:PLF0]CPYPLF;[M:PLF0]FCYPLF;[M:PLF0]VERPLF
    If fstat : Return : Endif

    [M:PLF0]LEGPLF=CZ
    Gosub REMP_PIC
    WPICK=2
    Gosub RAFF_PIC
    REPONSE = GSTARAF
    Gosub RAFFRAICHIR From GOBJSUB
  Endif
Endcase
Return

$PLFCLO
Read [PLF]PLF0 First
Filter [PLF]
If !fstat
 # Plan de formation clos pour l'année
 GMESSAGE = mess(29,10717,1)-[F:PLF]YEAPLF
 # SYMEU : EXI 66191 LOT 10 - V6.1 : on complète le message avec la société ou le site,
 # s'ils sont renseignés
 If [F:PLF]CPYPLF <> "" Then
   # et la société XXXXX
   GMESSAGE -= mess(119,10717,1)-[F:PLF]CPYPLF
 Elsif [F:PLF]FCYPLF <> "" Then
   # et le site YYYYY
   GMESSAGE -= mess(120,10717,1)-[F:PLF]FCYPLF
 Endif
 OK = 0
Endif
Return


$EXEBOUT
Case REP
 When "Q"
  # Bouton Proposition : Action PLFPRO
  # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
  #If PARBOUT(3)= "1"
  If PARBOUT(5)= "1"
   [F:PLF]YEAPLF = [M:PLF0]YEAPLF
   # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
   If dim([M:PLF0]LEGPLF)>0 Then
    [F:PLF]LEGPLF = [M:PLF0]LEGPLF
   Else
    [F:PLF]LEGPLF=GCURLEG
   Endif
   # End MABON
   # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
   [F:PLF]CPYPLF = [M:PLF0]CPYPLF
   [F:PLF]FCYPLF = [M:PLF0]FCYPLF
   [F:PLF]VERPLF = [M:PLF0]VERPLF
   [F:PLF]NUMLIG = 1
   Gosub LECTURE From GOBJSUB
   Affzo [PLF1]
  # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
  # Elsif PARBOUT(3)="0"
  Elsif PARBOUT(5)="0"
   # Pas de proposition de plan de formation
   Call MESSAGE(mess(15,10717,1)) From GESECRAN
  Endif
 When "O"
 #LIPET - 2017-05-11 - X3-35993 - START
   #Gosub RAFFRAICHIR From GOBJSUB
   #Gosub LECTURE From GOBJSUB
   # Issue X3-11279 - 2017-01-25 by BRBAN : This was necessary to not enable Modification mode
   If [V]WOKFIL = 1
    Gosub REMPLIT From GOBJSUB
    Gosub RECHARGE From GOBJSUB
    Gosub LECTURE From GOBJSUB
   Endif
 #LIPET - 2017-05-11 - X3-35993 - END
Endcase
Return

$VERIF_MOD
$VERIF_CRE
Local Char MLEGPLF(5)
# SYMEU : EXI 66191 LOT 10 - V6.1 : vérification qu'il y a cohérence entre la société des
# lignes et la société du plan, si elle est renseignée
If [M:PLF0]CPYPLF <> "" Then
  For I=0 To [M:PLF1]NBRPLF-1
    If [M:PLF1]CPY(I)<>"" & [M:PLF1]CPY(I) <> [M:PLF0]CPYPLF Then
      Call MES_ERR_SOC([M:PLF1]CPY(I),[M:PLF1]FCY(I))
      GMESSAGE = mess(126,10717,1)-num$(I+1)-":"-GMESSAGE
      GERR=1 : GOK=0
      Break
    Endif
  Next I
  If GOK = 0 Then Return Endif
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : vérification qu'il y a cohérence entre le site des
# lignes et le site du plan, s'il est renseigné
If [M:PLF0]FCYPLF <> "" Then
  For I=0 To [M:PLF1]NBRPLF-1
    If [M:PLF1]FCY(I)<>"" & [M:PLF1]FCY(I) <> [M:PLF0]FCYPLF Then
      Call MES_ERR_SITE([M:PLF1]FCY(I))
      GMESSAGE = mess(126,10717,1)-num$(I+1)-":"-GMESSAGE
      GERR=1 : GOK=0
      Break
    Endif
  Next I
  If GOK = 0 Then Return Endif
Endif

# Cas où 2 utilisateurs sont sur deux plans de la même année, chacun coche le sien en définitif,
# puis chacun enregistre le sien : on a 2 plans définitifs pour la même année.
If [M:PLF0]FLGCLO=2
 # SYMEU : EXI 66191 LOT 10 - V6.1 : on ajoute la société et le site
 # Filter [PLF] Where YEAPLF=[M:PLF0]YEAPLF & VERPLF<>[M:PLF0]VERPLF & FLGCLO=2
 # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
 MLEGPLF=GCURLEG
 If dim([M:PLF0]LEGPLF)>0 Then MLEGPLF=[M:PLF0]LEGPLF : Endif
 Filter [PLF] Where YEAPLF=[M:PLF0]YEAPLF & VERPLF<>[M:PLF0]VERPLF & FLGCLO=2
&                 & CPYPLF=[M:PLF0]CPYPLF & FCYPLF=[M:PLF0]FCYPLF
&                 & LEGPLF=MLEGPLF
 Gosub PLFCLO
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : en cas de saisie de ligne et echap avant la fin de la
# saisie, le tableau invisible de l'onglet des plans n'a pas été mis à jour, donc les coûts
# sont créés dans PLNCOUT à la validation (BUG n° 67263)
# Je vais donc balayer ce tableau invisible, et je supprime toutes les occurrences dont
# le numéro de ligne n'est pas trouvé dans le tableau des plans
Local Integer I, L_IND
For L_IND = 0 To [M:PLF1]NBRINV
  If [M:PLF1]NUMLIGI(L_IND) <> 0 Then
    I = find([M:PLF1]NUMLIGI(L_IND),[M:PLF1]NUMLIG)
    If I=0 Then
      Call EFFCOUT([M:PLF1]NUMLIGI(L_IND))
    Endif
  Endif
Next

Return

# Pb de numérotation car on peut n'extraire qu'une partie du plan de formation
# A l'enreg : Effacement de la partie du plan de formation qui a été extraite
# et renumérotation des lignes de cette partie avec le dernier numéro de ligne de la partie conservée+1

$DEBUT_MOD
Local Char MLEGPLF(5)
Filter [PLF]
# SYMEU : EXI 66191 LOT 10 - V6.1 : on ajoute la société et le site
# For [PLF]PLF0 Where YEAPLF=[M:PLF0]YEAPLF & VERPLF=[M:PLF0]VERPLF & evalue(FILTSUP)
# FQ81085 - MABON 22/05/12 - Adding field LEGPLF
MLEGPLF=GCURLEG
If dim([M:PLF0]LEGPLF)>0 Then MLEGPLF=[M:PLF0]LEGPLF : Endif
For [PLF]PLF0 Where YEAPLF=[M:PLF0]YEAPLF & VERPLF=[M:PLF0]VERPLF & evalue(FILTSUP)
&                 & CPYPLF=[M:PLF0]CPYPLF & FCYPLF=[M:PLF0]FCYPLF
&                 & LEGPLF=MLEGPLF
  ## Suppression des coûts
  # SYMEU : EXI 66191 LOT 10 - V6.1 : on ajoute la société et le site
  # Delete [PLC] Where YEAPLF=[F:PLF]YEAPLF & VERPLF=[F:PLF]VERPLF & NUMLIG=[F:PLF]NUMLIG
  # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
  Delete [PLC] Where YEAPLF=[F:PLF]YEAPLF & VERPLF=[F:PLF]VERPLF & NUMLIG=[F:PLF]NUMLIG
&                  & CPYPLF=[F:PLF]CPYPLF & FCYPLF=[F:PLF]FCYPLF
&                  & LEGPLF=[F:PLF]LEGPLF
  If fstat
    GOK = 0 : Call FSTA("PLC") From GLOCK : Break
  Endif

  ## Le plan est définitif => on passe à l'état "saisie" toutes les demandes du plan qui étaient en état "plan"
  ## On passera les demandes du plan à l'état "plan" dans $CREATION
  If [F:PLF]FLGCLO=2 & [F:PLF]DEMNUM<>""
    Filter [DML] Where DEMNUM=[F:PLF]DEMNUM & EMP=[F:PLF]EMP & CTRNUM=[F:PLF]CTRNUM & FCY=[F:PLF]FCY & CATFRT=[F:PLF]CATFRT
&                    & SRV=[F:PLF]SRV
    Readlock [F:DML]DML0 First
    Filter [DML]
    If !fstat & [F:DML]FLGINS=2
     [F:DML]FLGINS = [F:DML]OLDFLGINS  :#Demande -> Saisie
     Rewrite [F:DML]
     If fstat
      GOK = 0 : Call FSTA("DML") From GLOCK : Break
     Endif
    Endif

    # SYMEU : EXI 66191 LOT 11 - V6.1 : effacement de l'année du plan définitif dans les demandes
    Readlock [F:DEM2]DEM0 = [F:PLF]DEMNUM
    If fstat=1 Then # enregistrement déjà verrouillé
      [V]GOK =-1
      [V]GLOCK="$"+"DEM2"-[F:PLF]DEMNUM
      Break
    Elsif fstat Then # autre erreur
      [V]GOK = 0
      Call RSTA("DEM2",[F:PLF]DEMNUM) From GLOCK
      Break
    Elsif [F:DEM2]YEAPLF <> "" Then
      Raz [F:DEM2]YEAPLF, [F:DEM2]STRDAT, [F:DEM2]ENDDAT  : # JML 27/08/15 STRDAT, ENDDAT :#TIVAN
      Rewrite [F:DEM2]
      If fstat Then
        [V]GOK = 0
        Call FSTA("DEM2") From GLOCK
        Break
      Endif
    Endif
  Endif
Next

# SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts : suppression - DEBUT
If GOK <= 0 : Return : Endif
# FQ81085 - MABON 22/05/12 - Adding field LEGPLF
Delete [HRPLB] Where YEAPLF=[M:PLF0]YEAPLF & VERPLF=[M:PLF0]VERPLF
&                & CPYPLF=[M:PLF0]CPYPLF & FCYPLF=[M:PLF0]FCYPLF
&                & LEGPLF=MLEGPLF
If fstat
  GOK = 0 : Call FSTA("HRPLB") From GLOCK
Endif
If GOK = 0 : Return : Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts : suppression - FIN

Return

$INICRE
[F:PLF] = [M:PLF0] : # JML 11/09/15 What a bad idea to take GOBJET3 ! :#TIVAN
# Objet combiné charge uniquement PLF1
[F:PLF]YEAPLF = [M:PLF0]YEAPLF
# FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
If dim([M:PLF0]LEGPLF)>0 Then
  [F:PLF]LEGPLF = [M:PLF0]LEGPLF
Else
  [F:PLF]LEGPLF = GCURLEG
Endif
# End MABON
# SYMEU : EXI 66191 LOT 10 - V6.1 : on récupère la société et le site
[F:PLF]CPYPLF = [M:PLF0]CPYPLF
[F:PLF]FCYPLF = [M:PLF0]FCYPLF
[F:PLF]VERPLF = [M:PLF0]VERPLF
[F:PLF]FLGCLO = [M:PLF0]FLGCLO
[F:PLF]NUMLIG = [M:PLF1]NUMLIG(nolign-1)
Return

$CREATION
## Mise à jour du flag suivi des demandes uniquement pour le plan definitif
If [M:PLF0]FLGCLO=2 & [M:PLF1]DEMNUM(nolign-1)<>""
 # Plan devient définitif
 Filter [DML] Where DEMNUM=[M:PLF1]DEMNUM(nolign-1) & EMP=[M:PLF1]EMP(nolign-1) & FCY=[M:PLF1]FCY(nolign-1)
&& CTRNUM=[M:PLF1]CTRNUM(nolign-1) & CATFRT=[M:PLF1]CATFRT(nolign-1) & SRV=[M:PLF1]SRV(nolign-1)
 Readlock [F:DML]DML0 First
 Filter [DML] # SYMEU : EXI 66191 LOT 10 - V6.1
 If !fstat & [F:DML]FLGINS<2
  [F:DML]OLDFLGINS = [F:DML]FLGINS
  [F:DML]FLGINS    = 2  :#Demande -> Plan
  Rewrite [F:DML]
  If fstat
   GOK = 0 : Call FSTA("DML") From GLOCK : Return
  Endif
 Endif
Endif
Return

