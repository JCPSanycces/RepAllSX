Subprog AM_YEAPLF(VALEUR)
Variable Char    VALEUR()
  Call GET_AMTBUDREF(VALEUR,[M:PLF0]CPYPLF,[M:PLF0]FCYPLF)
  [F:PLF]YEAPLF = VALEUR : [F:PLF]CPYPLF = [M:PLF0]CPYPLF : [F:PLF]FCYPLF = [M:PLF0]FCYPLF : Gosub READ_BUR From SUBPLF2 : # JML 22/09/15 TIVAN
  Gosub CALCUL_PRCPLFBUD
End

######################################################################################

Subprog C_FLGCLO(VALEUR)
Variable Integer VALEUR
Local Char MLEGPLF(5)
If VALEUR=2
 # SYMEU : EXI 66191 LOT 10 - V6.1 : on ajoute la société et le site
 # Filter [PLF] Where YEAPLF=[M:PLF0]YEAPLF & VERPLF<>[M:PLF0]VERPLF & FLGCLO=2
 # FQ81085 - MABON 22/05/12 - Adding field LEGPLF
 MLEGPLF=GCURLEG
 If dim([M:PLF0]LEGPLF)>0 Then MLEGPLF=[M:PLF0]LEGPLF : Endif
 Filter [PLF] Where YEAPLF=[M:PLF0]YEAPLF & VERPLF<>[M:PLF0]VERPLF & FLGCLO=2
&                 & CPYPLF=[M:PLF0]CPYPLF & FCYPLF=[M:PLF0]FCYPLF
&                 & LEGPLF=MLEGPLF

 Read [PLF]PLF0 First
 Filter [PLF]
 If !fstat
  # Un plan définitif existe déjà sur l'année AAAA
  GMESSAGE = mess(44,10717,1)-[M:PLF0]YEAPLF
  # SYMEU : EXI 66191 LOT 10 - V6.1 : on complète le message avec la société ou le site,
  # s'ils sont renseignés
  If [M:PLF0]CPYPLF <> "" Then
    # et la société XXXXX
    GMESSAGE -= mess(119,10717,1)-[M:PLF0]CPYPLF
  Elsif [M:PLF0]FCYPLF <> "" Then
    # et le site YYYYY
    GMESSAGE -= mess(120,10717,1)-[M:PLF0]FCYPLF
  Endif
  mkstat = 2 : End
 Endif
 # SYMEU : EXI 66191 LOT 10 - V6.1 : fiche 72038 : vérification qu'il n'y a pas des lignes
 # de stage dont le flag calcul est à Non
 If find(1,[M:PLF1]CLCFLG) > 0 Then
  # Vous ne pouvez pas rendre ce plan définitif, car il y a des stages exclus des calculs
  GMESSAGE -= mess(229,10717,1)
  mkstat = 2
  End
 Endif
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : plan définitif
Call GRISE_FLGCLO(VALEUR) From SUBPLF2
End

