#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Modifications :
# SEGAY - 25/02/11 - Bug 71922
# Si on est sur un stage cours il faut filtrer les jours de sessions par rapport au bornes de dates
# Si on est sur un stage long il faut filtrer les jours de sessions par rapport à la borne de date de début seulement
######################################################################################


Call SAISIE_CHAR(VALEUR,PARAM,"VSTAGE","VSTAGE","") From GSAISIE
End

$ACTION

Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When Default
Endcase
Return


$DEBUT
If clalev([F:STG])=0 : Local File STAGE      [STG] : Endif
If clalev([F:HRSES])=0 : Local File SESSIONS   [HRSES] : Endif
#59119
If clalev([F:SEJ])=0 : Local File SESJOU   [SEJ] : Endif
Local Integer NOL , K , N , ANNEE
Local Decimal LONG
Local Date    DDEB , DFIN, OLDDAT #59119
Raz [M]
ANNEE = year(datesyst)
Read [HRSES]SES3 First
If fstat<=2
 ANNEE = max(ANNEE,year([F:HRSES]STRDAT))
Endif
Read [HRSES]SES3 Last
If fstat<=2
 ANNEE = min(ANNEE,year([F:HRSES]ENDDAT))
Endif
[M]DATDEB = gdat$(1,1,ANNEE)
[M]DATFIN = gdat$(31,12,ANNEE)
Affzo 1-19
Gosub REMPLIT
Return

$APRES_MODIF
If find(COUZON,"DATDEB","DATFIN")
 Assign "[M]"+COUZON With zc
 Effzo [M]20
 Gosub REMPLIT
Endif
Return

$REMPLIT
nolign = 0
N = 0
For [HRSES]SES1(1) Where STG<>"" & STRDAT<=[M]DATFIN & ENDDAT>=[M]DATDEB
  Read [STG]STG0 = [F:HRSES]STG

  #DKA -23/05/12 - US30: Only display relevant training periods
  If ([F:STG]LEG = GLEGFIL | [F:STG]LEG='' | GLEGFIL='')

    nolign += 1
    [M] = [F:STG]
    N += 1
    If N>len(mess(0,10419,1))
      N = 1
    Endif
    For [F:HRSES]SES1
      #59119
      #nolign + =1
      #NOL = nolign-1
      #DDEB = max([F:HRSES]STRDAT,[M]DATDEB)
      #DFIN = min([F:HRSES]ENDDAT,[M]DATFIN)
      #[M]COD(NOL)     = [F:STG]COD
      #[M]DAT(NOL)     = DDEB
      #[M]DATI(NOL)    = format$("D:YYYYMMDD",[M]DAT(NOL))+[F:HRSES]STRTIM
      #LONG  = 60*(val(left$([F:HRSES]ENDTIM,2))-val(left$([F:HRSES]STRTIM,2)))
      #LONG += val(right$([F:HRSES]ENDTIM,3))-val(right$([F:HRSES]STRTIM,3))
      #[M]DURAFF(NOL)  = DFIN-DDEB+(LONG/(24*60)) : # Largeur de la barre
      #[M]DUREE(NOL)   = [F:HRSES]NBRDAY            : # Durée en nb de jours ouvrés
      #[M]TYPJOU(NOL)  = N
      #[M]SESSION(NOL) = [F:HRSES]COD
  # SEGAY 25/02/11 Bug 71922
  # Si on est sur un stage cours il faut filtrer les jours de sessions par rapport au bornes de dates
  # Si on est sur un stage long il faut filtrer les jours de sessions par rapport à la borne de date de début seulement
  #    For [SEJ] Where SES=[F:HRSES]COD
      For [SEJ] Where SES=[F:HRSES]COD
&        & (([F:SEJ]DAT<=[M]DATFIN & [F:SEJ]DAT>=[M]DATDEB & [F:STG]TYPSTG<>2) |([F:STG]TYPSTG=2 & [F:SEJ]DAT<=[M]DATFIN))
       If OLDDAT=[0/0/0]
          Gosub DEBSEG
        Elsif [F:SEJ]DAT=OLDDAT+1
          DFIN = min([F:SEJ]DAT,[M]DATFIN)
          OLDDAT = DFIN
          [M]DUREE(NOL)   += [F:SEJ]NBRJOU
        Else
          Gosub FINSEG
          Gosub DEBSEG
        Endif
      Next
      Gosub FINSEG
      # fin 59119
    Next

Endif

Next
[M]NBLIG = nolign
Affzo 20
Return

#59119
$DEBSEG
nolign + =1
NOL      = nolign-1
[M]COD(NOL)     = [F:STG]COD
[M]SESSION(NOL) = [F:HRSES]COD
DDEB = max([F:SEJ]DAT,[M]DATDEB)
DFIN = min([F:SEJ]DAT,[M]DATFIN)
# FQ70881 - MABON 25/01/11
If [F:STG]TYPSTG=2 Then
  DFIN=[F:HRSES]ENDDAT
Endif
OLDDAT = DFIN
[M]DUREE(NOL)   = [F:SEJ]NBRJOU
[M]TYPJOU(NOL)  = N
Return

$FINSEG
If OLDDAT<>[0/0/0]
 [M]DAT(NOL)     = DDEB
 [M]DATI(NOL)    = format$("D:YYYYMMDD",[M]DAT(NOL))+[F:HRSES]STRTIM
 LONG  = 60*(val(left$([F:HRSES]ENDTIM,2))-val(left$([F:HRSES]STRTIM,2)))
 LONG += val(right$([F:HRSES]ENDTIM,3))-val(right$([F:HRSES]STRTIM,3))
 [M]DURAFF(NOL)  = DFIN-DDEB+(LONG/(24*60)) : # Largeur de la barre
 # FQ70881 - MABON 25/01/11 - Ce cas peut arriver exceptionnellement quand un stage court commence un vendredi et se finit la
 # semaine suivante, et qu'en plus, aucune heure ou jour n'est défini (ne devrait pas arriver)
 # Ou quand stage long, sur une seule journée
 If DFIN=DDEB & LONG=0 Then
   [M]DURAFF(NOL)=1
 Endif
 If [M]DUREE(NOL)=0 Then
   [M]DUREE(NOL)=arr([M]DURAFF(NOL),1)
 Elsif [M]DURAFF(NOL)=0 Then
   [M]DURAFF(NOL)=[M]DUREE(NOL)
 Endif
 Raz OLDDAT
Endif
Return

#fin 59119
######################################################################################
## Ecran VSTAGE
## Clic gauche : Tunnel sur le stage
######################################################################################
Subprog B1_NBLIG
#49194
#Local Integer NOL , J , K
#NOL = 0
#For K=0 To [M]NBLIG-1
# If [M]DES(K)<>""
#  NOL += 1
#  If NOL=nolign
#   J = K : Break
#  Endif
# Endif
#Next K
#Call OBJET("STG",[M]COD(J),"") From GOBJET
Call OBJET("STG",[M]COD(nolign-1),"") From GOBJET
End

######################################################################################
## Ecran VSTAGE
## Clic gauche : Tunnel sur la session
######################################################################################
Subprog B2_NBLIG
  #ADNGO - 2017-06-26 - X3-29545 - START
  #Call OBJET("SES",[M]SESSION(nolign-1),"") From GOBJET
  Call OBJET("HRSES",[M]SESSION(nolign-1),"") From GOBJET
  #ADNGO - 2017-06-26 - X3-29545 - END
End

######################################################################################

