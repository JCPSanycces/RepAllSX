#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
## Programme de traitement de l'onglet articles lancés des O.F SUBMFG1  ##
##########################################################################
# En remplacement de TABLEAUX suite à modif refusée par MBT  # FQ 50547  #
##########################################################################
# Issue X3-55431 - 2017-09-15 by BAKHA : reset of global flag GREVMESSC removed
$OUVRE
Gosub DECLARE From TABLEAUX
Return

########################################################################
$FERME
Return

########################################################################
$APRES_MODIF
MMODIF=1
Return

###########################################################################
## Action technique de définition du filtre de lecture
$DEFLIG
Default Mask [MFG1]
Default File [MFI]
CRIT   = 'MFGNUM="'+[M:MFG0]MFGNUM+'"'
FICLIG = "MFGITM"
ABLIG  = "MFI"
ZONLIG = "MFGLIN"
Return

###########################################################################
## Lecture des lignes
#########################################################################
$LIENS
Local Integer LRET
Gosub LIENS From TABLEAUX

# Issue 119469 GH 04/11/16 - performance enhancement
#Affzo [M:MFG1] : # 107513 - needed to have correct colors for the first reading
Raz [M:MFG1]ITMERRCOD, [M:MFG1]ITMERRMSG
Raz [M:MFG1]ECCERRCOD, [M:MFG1]ECCERRMSG

# FQ 61033 GA 12/2009 on perd certaines infos c/le sous-produit en modif d'un OF
#                     voir CHARGLIGNE appelé en INIMOD dans SUBMFGA
For I=0 To [M:MFG1]NBLIG-1
    # 107513 - Clear styles
    #Affzo [M:MFG1]NBLIG(nolign-1) # Issue 119469 GH 04/11/16 - wrong instruction
    #Chgstl [M:MFG1]NBLIG(nolign-1) With ""
    #Raz [M:MFG1]ITMERRCOD, [M:MFG1]ITMERRMSG
    #Raz [M:MFG1]ECCERRCOD, [M:MFG1]ECCERRMSG

    If [M:MFG1]ITMTYP(I) = 2  # Sous-produit
        If [F:MFI]MFGLIN<>[M:MFG1]MFGLIN(I)
           Read [F:MFI]MFI0=[M:MFG0]MFGNUM;[M:MFG1]MFGLIN(I)
           If fstat Break Endif
        Endif
        [M:MFG1]XMFGLIN(I) = [F:MFI]ITMLIN
        #[M:MFG1]ITMTYP(I) = [F:MFI]ITMTYP
        #[M:MFG1]CSTFLG(I) = [F:MFI]CSTFLG
        [M:MFG1]SPDAT(I)   = [F:MFI]ENDDAT
        [M:MFG1]SPOPE(I)   = [F:MFI]BOMOPE
        [M:MFG1]SPOFS(I)   = [F:MFI]BOMOFS
        # Set MFG2 because by-products are considered as component for this control
        LRET=0
        Call CONTMATITM([M:MFG1]ITMREF(I), [M:MFG0]MFGFCY, "MFG2", LRET, [M:MFG1]ITMERRMSG(I)) From MFGLIB
        [M:MFG1]ITMERRCOD(I) = LRET
        # Issue 119469 GH 04/11/16 - performance enhancement
        #If [M:MFG1]ITMERRCOD(I)>0
        #    Call HIGHLIGHT("MFG1", I) From ECCLIB
        #Endif
    Endif
Next
Gosub LIENS From SUBMFGECC
Return

###########################################################################
## Modification des lignes
#########################################################################
$MODIF
Gosub MODIF From TABLEAUX
Return

###########################################################################
## Création des lignes
#########################################################################
$CREATION
#Gosub CREATION From TABLEAUX
Local Char SAVACT(GLONACT) : SAVACT=ACTION
ACTION = "DEFLIG" : Gosub T_ACTION From TABLEAUX
Assign "[G:"+ABLIG+"]currind" With 1
Assign "[G:"+ABLIG+"]currlen" With 0
For nolign=1 To [M]NBLIG
 Raz [F]
 [F] = [M]
 If evalue("[F]"+ZONLIG)=0      # FQ 50547 GA 06/2009 sauf si déjà renseigné
    Assign "[F]"+ZONLIG With 1000*nolign : # On numérote de 1000 en 1000
 Endif
 Gosub INICRE_LIG From TABLEAUX
 If GOK<1 : Break : Endif : # Propagation des erreurs
 Write
 If fstat
  GOK=0 : Call FSTA(ABLIG) From GLOCK : Break
 Endif
 TRTLIG = "C"
 SIGN = +1 : Gosub VALLIG From TABLEAUX
 If GOK<1 : Break : Endif : # Propagation des erreurs
Next nolign
ACTION=SAVACT
Return

###########################################################################
## Annulation des lignes
#########################################################################
$ANNULE
Gosub ANNULE From TABLEAUX
Return

