#<AdxTL>@(#)10.0.0.0 $Revision$
#########################################################################
# IMPPIH : Import/Export des factures d'achat            MBT 11/04/2000 #
# --------------------------------------------------------------------- #
# Traitements des actions spécifiques à l'import/export                 #
#########################################################################

$ACTION
Case ACTION
  When "IMP_AVANT_OUVRE"
    If !clalev([F:CFL])  Local File CPTFOOTLNK [CFL] : Endif
    #-----  Si module ventes actif -----#
    If GMODU(5)=2
      If !clalev([F:SIH])  Local File SINVOICE   [SIH] : Endif
      If !clalev([F:SIV])  Local File SINVOICEV  [SIV] : Endif
      If !clalev([F:SID])  Local File SINVOICED  [SID] : Endif
    Endif
    #-----
  When "IMP_OUVRE"     : Gosub OUVRE
  When "IMP_RAZCRE"    : Gosub IMP_RAZCRE
  When "IMPORT"        : Gosub IMPORT
  When "IMP_ZONE"      : Gosub IMP_ZONE
  When "IMP_TAB"       : Gosub IMP_TAB
  When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
  When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD
  When "IMP_FERME"     : Gosub FERME
  #-----
  When "EXP_OUVRE"     : Gosub EXP_OUVRE
  When "EXPORT"        : Gosub EXPORT
  When "EXP_ZONE"      : Gosub EXP_ZONE
  When "EXP_FERME"     : Gosub EXP_FERME
Endcase
Return


##########################################################################
#                              IMPORT / EXPORT                           #
##########################################################################

#---------------------------------------------------------------#
# Début import/export, étiquette appelée depuis le traitement : #
#   - IMPPIH            si import (G_IMPORT=1)                  #
#   - IMPPIH            si export (G_EXPORT=1)                  #
# ------------------------------------------------------------- #
# Entête *71 à *78  / Pied *81 à *88  / Ligne *91 à *98         #
#     les zones TSTCHAMP  1 à  8 déterminent l'entête           #
#     les zones TSTCHAMP 11 à 18 déterminent le pied            #
#     les zones TSTCHAMP 21 à 28 déterminent le détail          #
#---------------------------------------------------------------#
$OUVRE_TEXTE
#----- Lignes texte entête  -----#
Raz GIMP(71), GIMP(72), GIMP(73), GIMP(74), GIMP(75), GIMP(76), GIMP(77), GIMP(78)
TSTCHAMP(1) ="PIV*71" : TSTCHAMP(2) ="PIV*72" : TSTCHAMP(3) ="PIV*73" : TSTCHAMP(4) ="PIV*74"
TSTCHAMP(5) ="PIV*75" : TSTCHAMP(6) ="PIV*76" : TSTCHAMP(7) ="PIV*77" : TSTCHAMP(8) ="PIV*78"
#----- Lignes texte pied -----#
Raz GIMP(81), GIMP(82), GIMP(83), GIMP(84), GIMP(85), GIMP(86), GIMP(87), GIMP(88)
TSTCHAMP(11)="PIV*81" : TSTCHAMP(12)="PIV*82" : TSTCHAMP(13)="PIV*83" : TSTCHAMP(14)="PIV*84"
TSTCHAMP(15)="PIV*85" : TSTCHAMP(16)="PIV*86" : TSTCHAMP(17)="PIV*87" : TSTCHAMP(18)="PIV*88"
#----- Lignes texte détail -----#
Raz GIMP(91), GIMP(92), GIMP(93), GIMP(94), GIMP(95), GIMP(96), GIMP(97), GIMP(98)
TSTCHAMP(21)="PID*91" : TSTCHAMP(22)="PID*92" : TSTCHAMP(23)="PID*93" : TSTCHAMP(24)="PID*94"
TSTCHAMP(25)="PID*95" : TSTCHAMP(26)="PID*96" : TSTCHAMP(27)="PID*97" : TSTCHAMP(28)="PID*98"
#-----
Gosub OUVRE_TEXTE From TRTX3IMP
Return


##########################################################################
#                                  IMPORT                                #
##########################################################################

#--------------------------#
# Début de l'import/export #
#--------------------------#
$OUVRE
Local  Integer  OKCHAMP, NBPOSTE
Local  Shortint WNOL, J, K, L, SAVNOLIGN
Local  Shortint WINVDTA(15)
Local  Decimal  WINVDTAAMT(15), WINVORDAMT(15)
Local  Char     WACC(GLONGAC)(15),   WCNA(GLONCNA)(15)
Local  Decimal  PVV_AMTTAX   (max(func AFNC.ACTIV("PVA"),20))
Local  Integer  PVF_INVDTA   (max(func AFNC.ACTIV("PFI"),20))
Local  Decimal  PVF_INVORDAMT(max(func AFNC.ACTIV("PFI"),20))
Local  Char     PVF_INVDTAVAT(GLONVAT)(max(func AFNC.ACTIV("PFI"),20))
Local  Decimal  WTOTTAXCLC, WMAX, WCUM, WMT, WMTTAX
Local  Integer  OK_INVDTA, OK_INVDTAAMT, OK_INVORDAMT, OK_INVDTAVAT
Local  Integer  OK_AMTTAX
Local  Integer  OK_PIVTYP, OK_PIHTYP, OK_INVTYP, OK_STA, OK_TOTTAXAMT, OK_EECNAT
Local  Integer  OK_EECSCH, OK_EECTRN, OK_EECLOC, OK_QTYUOM, OK_SEQORI, OK_PRIREN
Local  Integer  OK_EECICT, OK_ICTCTY, OK_EECNUM, OK_FFWNUM, OK_FFWADD
Local  Integer  OK_BPRNAM, OK_BPYNAM, OK_BPAINV, OK_BPAPAY
Local  Integer  OK_TOTLINAMT, OK_TOTTAXAMT
Local  Integer  OK_DISCRGVAL(1..9), OK_DISCRGREN(1..9)
Local  Integer  OK_SIHNUM
Global Integer  GOK_ORIQTYPUU, GOK_ORINETPRI, GOK_VAT(3)
# Issue 76951/1 - 2011-10-10 by VPO : si on n'a pas TYPORI,NUMORI,LINORI -> type divers=5
Local Integer   OK_TYPORI, OK_NUMORI, OK_LINORI
Local Integer   WRET :#--CPO 71937

Raz GPTRNUM : # Pas de transaction en import
#----- Chargement des indicateurs champs paramétrés dans le modèle -----#
GOK_VAT(0)=find("PID VAT(0)",[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
GOK_VAT(1)=find("PID VAT(1)",[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
GOK_VAT(2)=find("PID VAT(2)",[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
#-----
Call TST_CHAMP("PVF","INVDTA",OK_INVDTA)        From SUBIMPOBJ
Call TST_CHAMP("PVF","INVDTAAMT",OK_INVDTAAMT)  From SUBIMPOBJ
Call TST_CHAMP("PVF","INVORDAMT",OK_INVORDAMT)  From SUBIMPOBJ
Call TST_CHAMP("PVF","INVDTAVAT",OK_INVDTAVAT)  From SUBIMPOBJ
#-----
Call TST_CHAMP("PVV","AMTTAX",OK_AMTTAX)        From SUBIMPOBJ
#-----
Call TST_CHAMP("PIH","PIVTYP",OK_PIVTYP)        From SUBIMPOBJ
Call TST_CHAMP("PIH","PIHTYP",OK_PIHTYP)        From SUBIMPOBJ
Call TST_CHAMP("PIH","INVTYP",OK_INVTYP)        From SUBIMPOBJ
Call TST_CHAMP("PIH","STA",OK_STA)              From SUBIMPOBJ
Call TST_CHAMP("PIV","TOTTAXAMT",OK_TOTTAXAMT)  From SUBIMPOBJ
Call TST_CHAMP("PIH","EECNAT",OK_EECNAT)        From SUBIMPOBJ
Call TST_CHAMP("PIH","EECSCH",OK_EECSCH)        From SUBIMPOBJ
Call TST_CHAMP("PIH","EECTRN",OK_EECTRN)        From SUBIMPOBJ
Call TST_CHAMP("PIH","EECICT",OK_EECICT)        From SUBIMPOBJ
Call TST_CHAMP("PIH","EECLOC",OK_EECLOC)        From SUBIMPOBJ
Call TST_CHAMP("PIH","EECLOC",OK_ICTCTY)        From SUBIMPOBJ
Call TST_CHAMP("PIH","EECLOC",OK_EECNUM)        From SUBIMPOBJ
Call TST_CHAMP("PIH","EECLOC",OK_FFWNUM)        From SUBIMPOBJ
Call TST_CHAMP("PIH","EECLOC",OK_FFWADD)        From SUBIMPOBJ
Call TST_CHAMP("PIH","BPRNAM(0)",OK_BPRNAM)     From SUBIMPOBJ
Call TST_CHAMP("PIH","BPYNAM(0)",OK_BPYNAM)     From SUBIMPOBJ
Call TST_CHAMP("PIH","BPAINV",OK_BPAINV)        From SUBIMPOBJ
Call TST_CHAMP("PIH","BPAPAY",OK_BPAPAY)        From SUBIMPOBJ
Call TST_CHAMP("PID","QTYUOM",OK_QTYUOM)        From SUBIMPOBJ
# Issue 76951/1 - 2011-10-10 by VPO : si on n'a pas TYPORI,NUMORI,LINORI -> type divers=5
Call TST_CHAMP("PID","TYPORI",OK_TYPORI)        From SUBIMPOBJ
Call TST_CHAMP("PID","NUMORI",OK_NUMORI)        From SUBIMPOBJ
Call TST_CHAMP("PID","LINORI",OK_LINORI)        From SUBIMPOBJ

Call TST_CHAMP("PID","SEQORI",OK_SEQORI)        From SUBIMPOBJ
Call TST_CHAMP("PID","PRIREN",OK_PRIREN)        From SUBIMPOBJ
Call TST_CHAMP("PID","ORIQTYPUU",GOK_ORIQTYPUU) From SUBIMPOBJ
Call TST_CHAMP("PID","ORINETPRI",GOK_ORINETPRI) From SUBIMPOBJ
Call TST_CHAMP("PIV","TOTLINAMT",OK_TOTLINAMT)  From SUBIMPOBJ
Call TST_CHAMP("PIV","TOTTAXAMT",OK_TOTTAXAMT)  From SUBIMPOBJ
Call TST_CHAMP("PIV","SIHNUM",OK_SIHNUM)        From SUBIMPOBJ
For J=1 To 9
  Call TST_CHAMP("PID","DISCRGVAL"+num$(J),OK_DISCRGVAL(J)) From SUBIMPOBJ
  Call TST_CHAMP("PID","DISCRGREN"+num$(J),OK_DISCRGREN(J)) From SUBIMPOBJ
Next J
# Issue 119080 - 2016-10-14 by SR : Import des cours devise
Global Integer G_RATMLT (0..9),G_RATDIV (0..9)
Local  Char    WFLD
Local  Integer WI
For WI=0 To dim([F:PIH]RATMLT)-1
  WFLD="RATMLT("+num$(WI)+")"
  Call TST_CHAMP ("PIH",WFLD,G_RATMLT(WI))   From SUBIMPOBJ
  WFLD="RATDIV("+num$(WI)+")"
  Call TST_CHAMP ("PIH",WFLD,G_RATDIV(WI))   From SUBIMPOBJ
Next
# End issue 119080
#----- GESTION DES TEXTES -----#
Gosub DECLARE_TEXTE From TRTX3IMP
G_IMPORT=1 : Gosub OUVRE_TEXTE
#----- Changement pseudo table CPTFOOTLNK par CPTANALIN bis -----#
If clalev([F:CFL])  Close Local File [CFL] : Endif
Local File CPTANALIN [CFL]
Local Integer RET
#-----
Return

#----------------------------------------------------#
# Pas d'appel automatique de préchargement en import #
#----------------------------------------------------#
$IMP_RAZCRE
[M:PIH3]PCLFLG=1
Return

#-----------------------------------------------------#
# Après lecture d'un enregistrement (entête ou ligne) #
#                                                     #
# IMPFIC : Abréviation du fichier en cours            #
#-----------------------------------------------------#
$IMPORT
Gosub IMPORT_TEXTE
Case IMPFIC
  When "PIH", "PIV"
    Raz PVF_INVDTA, PVF_INVORDAMT, PVF_INVDTAVAT
    #---------------------------------------#
    # Entête facture en création uniquement #
    #---------------------------------------#
    If GREP="C"
      GFCY=[F:PIH]FCY : Gosub CHARG_PARAM From SUBPIHA
      #----- Traitement du type de facture -----#
      If OK_PIVTYP
        Call LEC_TPV_LEG(GCURLEG,[F:PIH]PIVTYP,WRET) From TRTLECLEG
        #Read [TPV] TPV0=[F:PIH]PIVTYP :
        If WRET Raz [F:TPV] : Endif
        [M:PIH0]PIHTYP=[F:TPV]PIHTYP
      Else
        If OK_PIHTYP
          #-- X3suivi 71937 - T249 : Multi-Leg--#
          Filter [TPV] Where PIHTYP=[F:PIH]PIHTYP & INVTYP<3 & (LEG=GCURLEG | LEG="")
&              Order By Key CLE=[F:TPV]PIHTYP Asc; [F:TPV]LEG Desc
          Read [TPV]CLE First : If fstat Raz [F:TPV] : Endif
          Filter [TPV]
          [M:PIH0]PIVTYP=[F:TPV]PIVTYP
          [M:PIH0]PIHTYP=[F:PIH]PIHTYP
        Else
          If OK_INVTYP
            Case [F:PIH]INVTYP
              When 1 : [M:PIH0]PIHTYP=1
              When 2 : [M:PIH0]PIHTYP=3
            Endcase
          Else
            [M:PIH0]PIHTYP=1
          Endif
          #-- X3suivi 71937 - T249 : Multi-Leg--#
          Filter [TPV] Where PIHTYP=[M:PIH0]PIHTYP & INVTYP<3 & (LEG=GCURLEG | LEG="")
&              Order By Key CLE=[F:TPV]PIHTYP Asc; [F:TPV]LEG Desc
          Read [TPV]CLE First : If fstat Raz [F:TPV] : Endif
          Filter [TPV]
          [M:PIH0]PIVTYP=[F:TPV]PIVTYP
        Endif
      Endif
      #----- Traitement des éléments de facturation -----#
      #MAE, déplacement du CHARG_PARAM pour avoir GCURLEG renseigné avant la lecture de TPV
      #GFCY=[F:PIH]FCY : Gosub CHARG_PARAM From SUBPIHA
      If [F:PIH]BPR<>[F:BPR]BPRNUM
        Read [BPR] BPR0=[F:PIH]BPR
        If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
      Endif
      [M:PIH0]LAN=[F:BPR]LAN
      If [F:PIH]BPR<>[F:BPS]BPSNUM
        Read [BPS] BPS0=[F:PIH]BPR
        If fstat Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
      Endif
      GCUR=[F:BPS]CUR
      [M:PIH1]CUR   =[F:BPS]CUR
      [M:PIH1]CURTYP=[F:BPS]CHGTYP
      #----- Chargement du régime taxe fournisseur ------#
      Call INIT_REGIME([F:PIH]BPR,[F:PIH]FCY,"F",[M:PIH1]VAC) From CPTSUB
       # Issue 117271 - 2016-06-28 by SR :
      #----- Chargement du type de régime taxe -----#
#      If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[M:PIH1]VAC
#        Read [ADI] CODE=1;[M:PIH1]VAC : If fstat Raz [F:ADI] : Endif
#      Endif
#      [M:PIH1]VACTYP=[F:ADI]N1
       Raz WRET
       Call LEC_TVB_LEG(GCURLEG,[M:PIH1]VAC,WRET) From TRTLECLEG
       If WRET Raz [F:TVB] : Endif
       [M:PIH1]VACTYP= [F:TVB]REGVAC
       # End issue 117271
      #----- Chargement libellés et formats colonnes tarif -----#
      Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
      Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
      Call FMTREM("PIH3",GCUR)         From TRTPRICE
      If GPLISTC<>[F:BPS]PLISTC
         GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE : Endif
      #----- Chargement des éléments de facturation -----#
      [M:PIH0]BPR=[F:PIH]BPR
      Call INIT_ELEMENTS (8,[M:PIH1]CURTYP,[F:BPS]CUR,GCUR) From TRTACHELT1
      [M:PIH0]BPR=""
      #----- Traitement du code statut de la facture -----#
      # Issue X3-76033 - 2018-02-08 by SR : Ne pas importer le statut
      # "Validé =3 " est interdit et les autres valeurs seront calculées plus tard
      # dans REAJUST_ECART
      #If OK_STA [M:PIH1]STA=[F:PIH]STA : Endif
    Endif
    #--------------------------------------------#
    # Entête facture en création ou modification #
    #--------------------------------------------#
    #----- Traitement des informations CEE -----#
    If OK_EECNAT [M:PCEZ]EECNAT=[F:PIH]EECNAT : Endif
    If OK_EECSCH [M:PCEZ]EECSCH=[F:PIH]EECSCH : Endif
    If OK_EECTRN [M:PCEZ]EECTRN=[F:PIH]EECTRN : Endif
    If OK_EECICT [M:PCEZ]EECICT=[F:PIH]EECICT : Endif
    If OK_EECLOC [M:PCEZ]EECLOC=[F:PIH]EECLOC : Endif
    If OK_ICTCTY [M:PCEZ]ICTCTY=[F:PIH]ICTCTY : Endif
    If OK_EECNUM [M:PCEZ]EECNUM=[F:PIH]EECNUM : Endif
    If OK_FFWNUM [M:PCEZ]FFWNUM=[F:PIH]FFWNUM : Endif
    If OK_FFWADD [M:PCEZ]FFWADD=[F:PIH]FFWADD : Endif
    #----- Chargement adresse fournisseur facturant (facture) -----#
    If OK_BPRNAM | OK_BPAINV
      [M:AD66]=[F:PIH]
      [M:AD66]BPAADD=[F:PIH]BPAINV
      [M:AD66]ADBBPR=[F:PIH]BPR
      [M:AD66]ADBFLG=2
    Endif
    #----- Chargement adresse fournisseur payé (règlement) -----#
    If OK_BPYNAM | OK_BPAPAY
      [M:AD67]BPAADD      =[F:PIH]BPAPAY
      [M:AD67]BPRNAM(0)   =[F:PIH]BPYNAM(0)
      [M:AD67]BPRNAM(1)   =[F:PIH]BPYNAM(1)
      [M:AD67]BPAADDLIG(0)=[F:PIH]BPYADDLIG(0)
      [M:AD67]BPAADDLIG(1)=[F:PIH]BPYADDLIG(1)
      [M:AD67]BPAADDLIG(2)=[F:PIH]BPYADDLIG(2)
      [M:AD67]CRY         =[F:PIH]BPYCRY
      [M:AD67]CRYNAM      =[F:PIH]BPYCRYNAM
      [M:AD67]SAT         =[F:PIH]BPYSAT
      [M:AD67]POSCOD      =[F:PIH]BPYPOSCOD
      [M:AD67]CTY         =[F:PIH]BPYCTY
      [M:AD67]ADBBPR      =[F:PIH]BPRPAY
      [M:AD67]ADBFLG      =2
    Endif
    #----- Traitement champ invisible numéro facture vente -----#
    If OK_SIHNUM & [F:PIV]SIHNUM<>""
      [M:PIH0]SIHNUM=[F:PIV]SIHNUM : # Numéro facture vente inter-sociétés
      [F:SIH]NUM=[F:PIV]SIHNUM
      Gosub PICKE_SIH From SUBPIHD
    Endif
    #-----
  When "PID"
    #-----------------------------------------------------------#
    # Lignes facture : Déterminer si nouvelle ligne (nolign<>0) #
    #-----------------------------------------------------------#
    Raz WNOL
    Gosub IMP_DECLARE From TRTX3IMP
    If GREP="M"
       ICLEPRIM(0)="PIDLIN"
       If [F:PID]TYPORI<>5
         ICLEPRIM(1)="ITMREF" : ICLESEC(1)="TYPORI" : ICLESEC2(1)="NUMORI"
         # Issue 76951/3 - 2011-10-17 by VPO : si on a LINORI -> on s'en sert pour la recherche
         If OK_LINORI & OK_NUMORI & OK_TYPORI
             ICLEPRIM(1)="NUMORI" : ICLESEC(1)="TYPORI" : ICLESEC2(1)="LINORI"
         Endif
       Else
         ICLEPRIM(1)="ITMREF" : ICLESEC(1)="TYPORI"
       Endif
#      ICLEPRIM(2)="ITMREF" : # Détermination ligne sur référence seule court-circuitée
       NBASTAB="NBLIG"
       Gosub RECHERCHE_LIGNE From TRTX3IMP
       WNOL=nolign
       # Issue 76951/2 - 2011-10-10 by VPO : controler ITMREF même si document origine
       If WNOL<>0 & [M:PIH3]ITMREF(WNOL-1)<>"" & [M:PIH3]ITMREF(WNOL-1)<>[F:PID]ITMREF
        Call ERREUR ([F:PID]ITMREF-mess(424,194,1)-[M:PIH3]ITMREF(WNOL-1)) From GESECRAN
        GERR=1
        OK=0
        mkstat=2
        Return
       Endif
       #---------------------------------------------------------------------#
       # Cas de la suppression de ligne (Qté facturée = 0 & Mt ligne HT = 0) #
       #---------------------------------------------------------------------#
       If OK_QTYUOM & [F:PID]QTYUOM=0 & [F:PID]AMTNOTLIN=0 & nolign<>0
          status=65
          Call C_NBLIG     From SUBPIH : If mkstat Return : Endif
          Call AVANT_NBLIG From SUBPIH
          Call APRES_NBLIG From SUBPIH
       Endif
    Endif
    #----- Calcul de l'indice de la ligne -----#
    If WNOL=0 WNOL=[M:PIH3]NBLIG Else WNOL-=1 : Endif
    #----- Chargement du numéro de séquence d'origine -----#
    If OK_SEQORI [M:PIH3]SEQORI(WNOL)=[F:PID]SEQORI : Endif
    # Issue 76951/1 - 2011-10-10 by VPO : si on n'a pas TYPORI,NUMORI,LINORI -> type divers=5
    If GREP="C"
      If !OK_TYPORI | !OK_NUMORI | !OK_LINORI
          [M:PIH3]TYPORI(WNOL)=5
      Endif
    Endif
    #----- Chargement des valeurs frais/remises -----#
    If OK_DISCRGVAL(1) & dim([M:PIH3]DISCRGVAL1)>0
       [M:PIH3]DISCRGVAL1(WNOL)=[F:PID]DISCRGVAL1
    Endif
    If OK_DISCRGVAL(2) & dim([M:PIH3]DISCRGVAL2)>0
       [M:PIH3]DISCRGVAL2(WNOL)=[F:PID]DISCRGVAL2
    Endif
    If OK_DISCRGVAL(3) & dim([M:PIH3]DISCRGVAL3)>0
       [M:PIH3]DISCRGVAL3(WNOL)=[F:PID]DISCRGVAL3
    Endif
    If OK_DISCRGVAL(4) & dim([M:PIH3]DISCRGVAL4)>0
       [M:PIH3]DISCRGVAL4(WNOL)=[F:PID]DISCRGVAL4
    Endif
    If OK_DISCRGVAL(5) & dim([M:PIH3]DISCRGVAL5)>0
       [M:PIH3]DISCRGVAL5(WNOL)=[F:PID]DISCRGVAL5
    Endif
    If OK_DISCRGVAL(6) & dim([M:PIH3]DISCRGVAL6)>0
       [M:PIH3]DISCRGVAL6(WNOL)=[F:PID]DISCRGVAL6
    Endif
    If OK_DISCRGVAL(7) & dim([M:PIH3]DISCRGVAL7)>0
       [M:PIH3]DISCRGVAL7(WNOL)=[F:PID]DISCRGVAL7
    Endif
    If OK_DISCRGVAL(8) & dim([M:PIH3]DISCRGVAL8)>0
       [M:PIH3]DISCRGVAL8(WNOL)=[F:PID]DISCRGVAL8
    Endif
    If OK_DISCRGVAL(9) & dim([M:PIH3]DISCRGVAL9)>0
       [M:PIH3]DISCRGVAL9(WNOL)=[F:PID]DISCRGVAL9
    Endif
    #----- Chargement des motifs tarif -----#
    If OK_PRIREN
       Call CTLREN ([F:PID]PRIREN,6,[M:PIH3]PRIREN(WNOL),
&                   [M:PIH3]GROPRI(WNOL)) From TRTPRICE
       If !mkstat [M:PIH3]PRIREN(WNOL)=[F:PID]PRIREN Else mkstat=0 : Endif
    Endif
    If OK_DISCRGREN(1) & dim([M:PIH3]DISCRGREN1)>0
       Call CTLREN ([F:PID]DISCRGREN1,6,[M:PIH3]DISCRGREN1(WNOL),
&                   [M:PIH3]DISCRGVAL1(WNOL)) From TRTPRICE
       If !mkstat [M:PIH3]DISCRGREN1(WNOL)=[F:PID]DISCRGREN1 Else mkstat=0 : Endif
    Endif
    If OK_DISCRGREN(2) & dim([M:PIH3]DISCRGREN2)>0
       Call CTLREN ([F:PID]DISCRGREN2,6,[M:PIH3]DISCRGREN2(WNOL),
&                   [M:PIH3]DISCRGVAL2(WNOL)) From TRTPRICE
       If !mkstat [M:PIH3]DISCRGREN2(WNOL)=[F:PID]DISCRGREN2 Else mkstat=0 : Endif
    Endif
    If OK_DISCRGREN(3) & dim([M:PIH3]DISCRGREN3)>0
       Call CTLREN ([F:PID]DISCRGREN3,6,[M:PIH3]DISCRGREN3(WNOL),
&                   [M:PIH3]DISCRGVAL3(WNOL)) From TRTPRICE
       If !mkstat [M:PIH3]DISCRGREN3(WNOL)=[F:PID]DISCRGREN3 Else mkstat=0 : Endif
    Endif
    If OK_DISCRGREN(4) & dim([M:PIH3]DISCRGREN4)>0
       Call CTLREN ([F:PID]DISCRGREN4,6,[M:PIH3]DISCRGREN4(WNOL),
&                   [M:PIH3]DISCRGVAL4(WNOL)) From TRTPRICE
       If !mkstat [M:PIH3]DISCRGREN4(WNOL)=[F:PID]DISCRGREN4 Else mkstat=0 : Endif
    Endif
    If OK_DISCRGREN(5) & dim([M:PIH3]DISCRGREN5)>0
       Call CTLREN ([F:PID]DISCRGREN5,6,[M:PIH3]DISCRGREN5(WNOL),
&                   [M:PIH3]DISCRGVAL5(WNOL)) From TRTPRICE
       If !mkstat [M:PIH3]DISCRGREN5(WNOL)=[F:PID]DISCRGREN5 Else mkstat=0 : Endif
    Endif
    If OK_DISCRGREN(6) & dim([M:PIH3]DISCRGREN6)>0
       Call CTLREN ([F:PID]DISCRGREN6,6,[M:PIH3]DISCRGREN6(WNOL),
&                   [M:PIH3]DISCRGVAL6(WNOL)) From TRTPRICE
       If !mkstat [M:PIH3]DISCRGREN6(WNOL)=[F:PID]DISCRGREN6 Else mkstat=0 : Endif
    Endif
    If OK_DISCRGREN(7) & dim([M:PIH3]DISCRGREN7)>0
       Call CTLREN ([F:PID]DISCRGREN7,6,[M:PIH3]DISCRGREN7(WNOL),
&                   [M:PIH3]DISCRGVAL7(WNOL)) From TRTPRICE
       If !mkstat [M:PIH3]DISCRGREN7(WNOL)=[F:PID]DISCRGREN7 Else mkstat=0 : Endif
    Endif
    If OK_DISCRGREN(8) & dim([M:PIH3]DISCRGREN8)>0
       Call CTLREN ([F:PID]DISCRGREN8,6,[M:PIH3]DISCRGREN8(WNOL),
&                   [M:PIH3]DISCRGVAL8(WNOL)) From TRTPRICE
       If !mkstat [M:PIH3]DISCRGREN8(WNOL)=[F:PID]DISCRGREN8 Else mkstat=0 : Endif
    Endif
    If OK_DISCRGREN(9) & dim([M:PIH3]DISCRGREN9)>0
       Call CTLREN ([F:PID]DISCRGREN9,6,[M:PIH3]DISCRGREN9(WNOL),
&                   [M:PIH3]DISCRGVAL9(WNOL)) From TRTPRICE
       If !mkstat [M:PIH3]DISCRGREN9(WNOL)=[F:PID]DISCRGREN9 Else mkstat=0 : Endif
    Endif
  When "CAL"
    #-------------------------------------------------------------------#
    # Traitement des comptes et sections analytiques des lignes facture #
    #            left$([M:AOE1]FLGLNK(SEPNUM-1),5)='"PID"'              #
    #-------------------------------------------------------------------#
    [F:CAL]ABRFIC="PID"
    [F:CAL]VCRTYP=0
    Call IMPORT_ACCCCE(WNOL,"[M:PIH3]LINACC","[M:PIH3]LINDSP","[M:PIH3]CCE") From TRTX3CPT
    nolign=WNOL+1 : status=75 : # Modif élément
  When "PVF"
    #----------------------------------------#
    # Traitement des éléments de facturation #
    #----------------------------------------#
    If [F:PVF]INVDTA<>0
      If [M:PIH4]NBFAC>0
        K=find([F:PVF]INVDTA,[M:PIH4]INVDTA(0..[M:PIH4]NBFAC-1))
        If K & OK_INVDTAVAT
          If (GREP<>"C" | find([F:PVF]INVDTA,PVF_INVDTA(0..[M:PIH4]NBFAC-1)))
            If [M:PIH4]INVDTAVAT(K-1)<>[F:PVF]INVDTAVAT
              L=find([F:PVF]INVDTA,[M:PIH4]INVDTA(K..[M:PIH4]NBFAC-1))
              If L
                K+=L
                If [M:PIH4]INVDTAVAT(K-1)<>[F:PVF]INVDTAVAT
                  L=find([F:PVF]INVDTA,[M:PIH4]INVDTA(K..[M:PIH4]NBFAC-1))
                  If L
                    K+=L
                    If [M:PIH4]INVDTAVAT(K-1)<>[F:PVF]INVDTAVAT
                      L=find([F:PVF]INVDTA,[M:PIH4]INVDTA(K..[M:PIH4]NBFAC-1))
                      If L
                        K+=L
                        If [M:PIH4]INVDTAVAT(K-1)<>[F:PVF]INVDTAVAT
                          K=0
                        Endif
                      Else
                        K=0
                      Endif
                    Endif
                  Else
                    K=0
                  Endif
                Endif
              Else
                K=0
              Endif
            Endif
          Endif
        Endif
      Else
        K=0
      Endif
      If K=0
        PVF_INVDTA     ([M:PIH4]NBFAC)=[F:PVF]INVDTA
        PVF_INVORDAMT  ([M:PIH4]NBFAC)=[F:PVF]INVORDAMT
        PVF_INVDTAVAT  ([M:PIH4]NBFAC)=[F:PVF]INVDTAVAT
       #[M:PIH1]INVDTA1([M:PIH4]NBFAC)=[F:PVF]INVDTA
       #[M:PIH4]INVDTA ([M:PIH4]NBFAC)=[F:PVF]INVDTA
       #Read [PFI] PFI0=[F:PVF]INVDTA : If fstat  Raz [F:PFI] : Endif
       #Call GET_ATEXTRA("PFOOTINV","SHOAXX",GLANGUE,[M:PIH4]INVDTALIB([M:PIH4]NBFAC)) From TRTX3TEX
       #[M:PIH1]NBFAC+=1
       #[M:PIH4]NBFAC+=1
        [F:PVF]IND=[M:PIH4]NBFAC+1
        nolign=0 : status=73 : # Nouvel élément
      Else
        PVF_INVDTA    (K-1)=[F:PVF]INVDTA
        PVF_INVORDAMT (K-1)=[F:PVF]INVORDAMT
        PVF_INVDTAVAT (K-1)=[F:PVF]INVDTAVAT
        [F:PVF]IND=K
        nolign=K : status=75 : # Modif élément
      Endif
    Endif
    #----- Si création alors màj bases taxables et calcul taxes éléments -----#
    #If GREP="C"
    #  For J=0 To [M:PIH1]NBFAC1-1
    #    If [M:PIH1]INVDTA(J)<>0
    #      Call MAJ_ELEMENT (J,0,+1) From SUBPIHB
    #    Endif
    #  Next J
    #Endif
    #-----
  When "CFL"
    #----------------------------------------------------------------------------#
    # Traitement des comptes et sections analytiques des éléments de facturation #
    #                 left$([M:AOE1]FLGLNK(SEPNUM-1),5)='"PVF"'                  #
    #----------------------------------------------------------------------------#
    WNOL=[F:PVF]IND-1
    [F:CFL]ABRFIC="PVF"
    [F:CFL]VCRTYP=8
    [F:CAL]=[F:CFL]
    Call IMPORT_ACCCCE(WNOL,"[M:PIH4]ACC","[M:PIH4]DSP","[M:PIH4]PFICCE")    From TRTX3CPT
    nolign=WNOL+1 : status=75 : # Modif élément
  When "PVV"
    #----------------------#
    # Traitement des taxes #
    #----------------------#
    If [F:PVV]TAX<>""
      If [M:PIH4]NBTAX>0
        K=find([F:PVV]TAX,[M:PIH4]TAX(0..[M:PIH4]NBTAX-1))
        If K
          If [M:PIH4]PURTYP(K-1)<>max([F:PVV]PURTYP,1)
            L=find([F:PVV]TAX,[M:PIH4]TAX(K..[M:PIH4]NBTAX-1))
            If L
              K+=L
              If [M:PIH4]PURTYP(K-1)<>max([F:PVV]PURTYP,1)
                L=find([F:PVV]TAX,[M:PIH4]TAX(K..[M:PIH4]NBTAX-1))
                If L
                  K+=L
                  If [M:PIH4]PURTYP(K-1)<>max([F:PVV]PURTYP,1)
                    K=0
                  Endif
                Else
                  K=0
                Endif
              Endif
            Else
              K=0
            Endif
          Endif
        Endif
      Else
        K=0
      Endif
      #-----
      If K=0
        [M:PIH4]TAX   ([M:PIH4]NBTAX)=[F:PVV]TAX
        PVV_AMTTAX    ([M:PIH4]NBTAX)=[F:PVV]AMTTAX
        [M:PIH4]PURTYP([M:PIH4]NBTAX)=max([F:PVV]PURTYP,1)
        # Issue 71937 - 2012-03-27 by SR report CPO : comment
        Call LEC_TVT_LEG(GCURLEG,[F:PVV]TAX,RET) From TRTLECLEG
        If WRET: Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[F:PVV]TAX : If fstat  Raz [F:TVT] : Endif
        Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:PIH4]LIBTAX([M:PIH4]NBTAX)) From TRTX3TEX
        [M:PIH4]VATTYP([M:PIH4]NBTAX)=max([F:PVV]VATTYP,1)
        [M:PIH4]NBTAX+=1
        [F:PVV]IND=[M:PIH4]NBTAX
      Else
        PVV_AMTTAX(K-1)=[F:PVV]AMTTAX
        [F:PVV]IND=K
      Endif
      nolign=[F:PVV]IND : status=75 : # Modif taxe
    Endif
    #----- Calcul du total taxe si seul le détail est importé -----#
    If !OK_TOTTAXAMT [M:PIH4]TOTTAXAMT=sum([M:PIH4]AMTTAX) : Endif
    #-----
Endcase
Return

#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
#                                         #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#-----------------------------------------#
$IMP_ZONE
Gosub TRT_IMP_ZONE
Case IMPFIC
  When "PIH", "PIV"
    Case IMPZON
      When "CCE"       : If [F:PIH]CCE(indice)=""  OK=0 : Endif
      When "NBFAC1"    : mkstat=1 : # Ne pas exécuter la boucle d'import des éléments
      When "NBFAC"     : mkstat=1 : # Ne pas exécuter la boucle d'import des éléments
      When "INVORDAMT" : OK=0     : # Ne pas exécuter l'import STD (sera traité en IMP_VERIF)
      When "NBTAX"     : mkstat=1 : # Ne pas exécuter la boucle d'import du tableau taxes
      When "AMTTAX"    : OK=0     : # Ne pas exécuter l'import STD (sera traité en IMP_VERIF)
      When "TOTLINAMT1"           : # Un des derniers champs saisissables de l'entête
        Gosub IMP_ZONE_TEXTE      : # Traitement des textes entête et pied
        # Issue 119080 - 2016-10-17 by SR
        If sum(G_RATMLT,G_RATDIV)<>0
            Local Integer WI
            For WI=0 To dim([F:PIH]RATMLT)-1
              If G_RATDIV(WI)
                Assign ("[M:PIH1]RATDIV("+num$(WI)+")") With [F:PIH]RATDIV(WI)
              Endif
              If G_RATMLT(WI)
                Assign ("[M:PIH1]RATMLT("+num$(WI)+")") With [F:PIH]RATMLT(WI)
              Endif
            Next
            Local Integer INDLED
            # GTYPGEN : Type du référentiel général principal de la société
            # (initialisé par Call SETMAINREF(CPY,GTYPGEN,GTYPANA) From CPTDIV
            INDLED=find(GTYPGEN,[M:SCL]LEDTYP(0..[M:SCL]NBRC-1))
            If INDLED
              [M:PIH1]RAT1=[M:PIH1]RATDIV(INDLED-1)
              [M:PIH1]RAT2=[M:PIH1]RATMLT(INDLED-1)
            Endif
        Endif
        # End issue 119080
    Endcase
Endcase
Return

#-------------------------------------------#
# Equivalent à la saisie d'un champ tableau #
#                                           #
# IMPFIC : Abréviation du fichier           #
# IMPMSK : Nom de l'écran en cours          #
# IMPZON : Nom du champ en cours            #
# IMPMOD : Déclenche l'Après_modif          #
# OK     : Conditionne IMP_ZONE standard    #
#-------------------------------------------#
$IMP_TAB
# Issue 84130 - 2013-02-21 by SR : Gérer zones impactantes sur PIH3
Gosub TRT_IMP_ZONE
Case IMPFIC
  When "PID"
    Case IMPZON
      When "LINACC1","LINACC2","LINACC3","LINACC4","LINACC5",
&          "LINACC6","LINACC7","LINACC8","LINACC9","LINACC10","LINDSP",
&          "CCE1", "CCE2", "CCE3", "CCE4", "CCE5", "CCE6", "CCE7", "CCE8", "CCE9", "CCE10",
&          "CCE11","CCE12","CCE13","CCE14","CCE15","CCE16","CCE17","CCE18","CCE19","CCE20"
        #----- Pas de contrôle si les comptes et sections sont importés avec "CAL" -----#
        If find("CPTANALIN",[M:AOE1]FLGFIL(0..[M:AOE1]NBRFLG))
          OK=0 : mkstat=1 : # Zones non concernées par PINVOICED
        Endif
        #-----
    Endcase
    #----- Chargement des codes taxes -----#
    If IMPZON="VAT1" & GOK_VAT(0) [M:PIH3]VAT1(nolign-1)=[F:PID]VAT(0) : IMPMOD=1 : Endif
    If IMPZON="VAT2" & GOK_VAT(1) [M:PIH3]VAT2(nolign-1)=[F:PID]VAT(1) : IMPMOD=1 : Endif
    If IMPZON="VAT3"
      If GOK_VAT(2) [M:PIH3]VAT3(nolign-1)=[F:PID]VAT(2) : IMPMOD=1 : Endif
      #--------------------------------------------------#
      # Dernier champ saisissable de la ligne de facture #
      #--------------------------------------------------#
      Gosub IMP_ZONE_TEXTE : # Traitement des textes entête et pied
      #----- Chargement de la qté d'origine -----#
      If GOK_ORIQTYPUU
        [M:PIH3]ORIQTYPUU(nolign-1)=[F:PID]ORIQTYPUU
      Endif
      #----- Chargement du prix unitaire d'origine -----#
      If GOK_ORINETPRI
        [M:PIH3]ORINETPRI(nolign-1)=[F:PID]ORINETPRI
      Endif
    Endif
    If find(IMPZON,"TYPORI","NUMORI","LINORI","ITMREF","GROPRI","QTYUOM","QTYVOU","QTYWEU","UOM")
         [M:PIH3]WSTCUPD(nolign-1) = 2
    Endif
  When "CAL"
    Case IMPZON
      When "ITMDES","ITMDES1","UOM","QTYUOM","NETPRI","AMTNOTLIN","PJT","LINPURTYP",
&          "VAT1","VAT2","VAT3","TAXRCP","TAXISS","TAXOTH1","TAXOTH2"
        OK=0 : # Zones non concernées par CPTANALIN
    Endcase
  When "PVF"
    Case IMPZON
      When "NBFAC1"    : mkstat=1 : # Ne pas exécuter la boucle d'import des éléments
      When "NBFAC"     : mkstat=1 : # Ne pas exécuter la boucle d'import des éléments
      When "INVDTA1"   : #If [M:PIH1]INVDTA1(nolign-1)<>0  OK=0 : Endif
      When "INVDTA"    : #If [M:PIH4]INVDTA (nolign-1)<>0  OK=0 : Endif
      When "INVORDAMT" : OK=0     : # Ne pas exécuter l'import STD (sera traité en IMP_VERIF)
      When "INVDTAVAT" : # Il faut laisser s'exécuter l'import STD même si rechargé plus tard
      When "ACC1","ACC2","ACC3","ACC4","ACC5","ACC6","ACC7","ACC8","ACC9","ACC10","DSP",
&          "PFICCE1", "PFICCE2", "PFICCE3", "PFICCE4", "PFICCE5", "PFICCE6", "PFICCE7",
&          "PFICCE8", "PFICCE9", "PFICCE10","PFICCE11","PFICCE12","PFICCE13","PFICCE14",
&          "PFICCE15","PFICCE16","PFICCE17","PFICCE18","PFICCE19","PFICCE20"
        #----- Pas de contrôle si les comptes et sections sont importés avec "CFL" -----#
        If find("CPTFOOTLNK",[M:AOE1]FLGFIL(0..[M:AOE1]NBRFLG))
          OK=0 : mkstat=1 : # Zones non concernées par PVCRFOOT
        Endif
        #-----
    Endcase
  When "CFL"
    Case IMPZON
      When "INVDTAAMT","INVORDAMT","INVDTAVAT" : OK=0 : # Zones non concernées par CPTANALIN
    Endcase
  When "PVV"
    Case IMPZON
      When "NBTAX"  : mkstat=1 : # Ne pas exécuter la boucle d'import du tableau taxes
      When "AMTTAX" : OK=0     : # Ne pas exécuter l'import STD (sera traité en IMP_VERIF)
    Endcase
Endcase
Return

#--------------------------------------------#
# Vérification avant transaction de création #
#--------------------------------------------#
$IMP_VERIF_CRE
Gosub MAJ_DETAIL_TAX
Gosub REAJUST_ECART
Return

#------------------------------------------------#
# Vérification avant transaction de modification #
#------------------------------------------------#
$IMP_VERIF_MOD
Gosub MAJ_DETAIL_TAX
Gosub REAJUST_ECART
Return

#-------------------------#
# Réajustement des écarts #
#-------------------------#
$REAJUST_ECART
SAVNOLIGN=nolign
#----- Mise à jour des champs calculés par sécurité -----#
[M:PIH4]TOTTAXCLC=sum([M:PIH4]AMTTAX)
[M:PIH4]CLCLINAMT=[M:PIH3]CUMLINAMT1
#----- Si total HT saisi non importé alord on prend le total lignes HT calculé -----#
If !OK_TOTLINAMT [M:PIH4]TOTLINAMT=[M:PIH4]CLCLINAMT : Endif
#----- Réajustement des éléments de facturation -----#
For nolign=1 To dim([M:PIH4]INVDTA)
  #----- Traitement montant issu de la commande -----#
  If [M:PIH4]INVORDFLG(nolign-1)=2
    If !OK_INVORDAMT
      If OK_INVDTAAMT & GPIHIMPCTL<>2
        [M:PIH4]INVORDAMT(nolign-1)=[M:PIH4]INVDTAAMT(nolign-1)
      Endif
    Else
      [M:PIH4]INVORDAMT(nolign-1)=PVF_INVORDAMT(nolign-1)
    Endif
    If !OK_INVDTAAMT
      [M:PIH4]INVDTAAMT(nolign-1)=[M:PIH4]INVORDAMT(nolign-1)
      Call AM_INVDTAAMT([M:PIH4]INVDTAAMT(nolign-1)) From SUBPIH
      Call APRES_NBFAC From SUBPIH
    Endif
  #----- Traitement montant issu d'un élément tarif ligne -----#
  Elsif [M:PIH4]INVLINFLG(nolign-1)=6
    If [M:PIH4]INVDTAAMT(nolign-1)<>0 & GPIHIMPCTL<>2 &
&      [M:PIH4]INVDTAAMT(nolign-1)<>[M:PIH4]INVLINAMT(nolign-1)
      J=find([M:PIH4]INVDTA(nolign-1),GINVDTALIN(0..8)) : Raz WCUM
      If [M:PIH3]NBLIG>0 & [M:PIH3]CUMLINAMT1<>0
        For K=0 To [M:PIH3]NBLIG-1
          If K<[M:PIH3]NBLIG-1
            WMT=[M:PIH4]INVDTAAMT(nolign-1)*[M:PIH3]AMTNOTLIN(K)/[M:PIH3]CUMLINAMT1
            Call ARRDEV(WMT,GCUR) From TRTDIV
          Else
            WMT=[M:PIH4]INVDTAAMT(nolign-1)-WCUM
          Endif
          Assign "[M:PIH3]DISCRGVAL"+num$(J)+"(K)" With WMT
          WCUM+=WMT
        Next K
      Endif
      [M:PIH4]INVLINAMT(nolign-1)=[M:PIH4]INVDTAAMT(nolign-1)
    Elsif !OK_INVDTAAMT
      [M:PIH4]INVDTAAMT(nolign-1)=[M:PIH4]INVLINAMT(nolign-1)
      Call AM_INVDTAAMT([M:PIH4]INVDTAAMT(nolign-1)) From SUBPIH
      Call APRES_NBFAC From SUBPIH
    Endif
  Endif
  #----- Traitement code taxe de l'élément de facturation -----#
  If OK_INVDTAVAT & PVF_INVDTAVAT(nolign-1)<>""
    [M:PIH4]INVDTAVAT(nolign-1)=PVF_INVDTAVAT(nolign-1)
  Endif
  #----- Mise à jour Mt écart ligne -----#
  Call AV_INVDIFAMT([M:PIH4]INVDIFAMT(nolign-1)) From SUBPIH
Next nolign
#----- Si facture CEE pas de contrôle du total taxes -----#
If [M:PIH1]VACTYP=4
  Raz [M:PIH1]TOTTAXAMT1, [M:PIH4]TOTTAXAMT, [M:PIH4]DIFTAXAMT
Else
  #----- Si total taxe saisi non importé alors on prend le total taxe calculé -----#
  If !OK_TOTTAXAMT [M:PIH4]TOTTAXAMT=[M:PIH4]TOTTAXCLC : Endif
  #----- Réajustement des taxes -----#
  If [M:PIH4]TOTTAXAMT<>[M:PIH4]TOTTAXCLC & [M:PIH4]TOTTAXAMT<>0
    If [M:PIH4]TOTTAXCLC<>0
      WTOTTAXCLC=[M:PIH4]TOTTAXCLC
    Else
      WTOTTAXCLC=[M:PIH4]TOTTAXAMT
    Endif
    Raz WMAX, J
    For nolign=1 To dim([M:PIH4]TAX)
      WMTTAX=[M:PIH4]AMTTAX(nolign-1)*[M:PIH4]TOTTAXAMT/WTOTTAXCLC
      Call ARRDEV(WMTTAX,GCUR) From TRTDIV
      #----- Repérage du plus gros montant de taxe -----#
      If WMTTAX>WMAX
        WMAX=WMTTAX : J=nolign
      Endif
      #----- Réajustement des taxes sur éléments de pied et lignes facture -----#
      Call AM_AMTTAX(WMTTAX) From SUBPIH
      [M:PIH4]AMTTAX(nolign-1)=WMTTAX
    Next nolign
    #----- Si reliquat report sur le plus gros montant de taxe -----#
    GBIDD1=[M:PIH4]TOTTAXAMT-[M:PIH4]TOTTAXCLC
    If GBIDD1<>0
      nolign=max(J,1)
      WMTTAX=[M:PIH4]AMTTAX(nolign-1)+GBIDD1
      #----- Réajustement des taxes sur éléments de pied et lignes facture -----#
      Call AM_AMTTAX(WMTTAX) From SUBPIH
      [M:PIH4]AMTTAX(nolign-1)=WMTTAX
    Endif
  Endif
  #----- Mise à jour écart taxe -----#
  [M:PIH4]DIFTAXAMT=[M:PIH4]TOTTAXAMT-[M:PIH4]TOTTAXCLC
Endif
#----- Mise à jour Mts d'écart -----#
[M:PIH4]DIFLINAMT=[M:PIH4]TOTLINAMT-[M:PIH4]CLCLINAMT
[M:PIH4]AMTATI=sum([M:PIH4]INVDTAAMT)+[M:PIH4]TOTLINAMT+[M:PIH4]TOTTAXAMT
Call AV_DIFAMTATI([M:PIH4]DIFAMTATI) From SUBPIH
#----- Mise à jour statut de la facture -----#
If [M:PIH1]STA<>3
  If [M:PIH4]DIFTAXAMT<>0 | [M:PIH4]DIFLINAMT<>0 |
&    [M:PIH4]DIFAMTATI<>0 | sum([M:PIH4]INVDIFAMT)<>0 [M:PIH1]STA=1
                                                 Else [M:PIH1]STA=2 : Endif
Endif
#----- Restauration de nolign ------#
nolign=SAVNOLIGN
#----- Si SIVNULL=2 (interdiction création pièce à zéro) -----#
If GSIVNULL=2 & [M:PIH4]AMTATI=0 & [M:PIH4]DIFAMTATI=0
   GMESSAGE=mess(277,199,1) : GERR=1 : OK=0 : Return
Endif
Return

#--------------------------------------------------#
# Reprise détail mts taxe car écrasé par le calcul #
#--------------------------------------------------#
$MAJ_DETAIL_TAX
SAVNOLIGN=nolign
For nolign=1 To dim([M:PIH4]TAX)
  If OK_AMTTAX & PVV_AMTTAX(nolign-1)<>[M:PIH4]AMTTAX(nolign-1)
    Call AM_AMTTAX(PVV_AMTTAX(nolign-1)) From SUBPIH
    [M:PIH4]AMTTAX(nolign-1)=PVV_AMTTAX(nolign-1)
  Endif
Next nolign
nolign=SAVNOLIGN
Return

#------------------------#
# Fin de l'import/export #
#------------------------#
$FERME
# Issue 107597 - 2015-04-13 by SR
# if needed, suppression of  all locks remaining
Local Char    SYMBOL_IMP(30)
If !clalev([F:ALK]) : Local File APLLCK [ALK] : Endif
Filter [F:ALK] Where LCKPID = adxuid(2) & find(left$(LCKSYM,3),"POH","PTH","PNH","PIH")
For [F:ALK]
    SYMBOL_IMP=[F:ALK]LCKSYM
    Unlock=SYMBOL_IMP
Next
Filter [F:ALK]
# End issue 107597

If dim(GOK_ORIQTYPUU)>0
  Kill GOK_ORIQTYPUU, GOK_ORINETPRI
Endif
Return

#------------------------------------#
# Traitements de IMP_ZONE et IMP_TAB #
#------------------------------------#
$TRT_IMP_ZONE
Case IMPFIC
  When "PIH", "PIV" :
    #----------------------------------------------------------#
    # Entête facture : Déterminer la bonne abréviation fichier #
    #----------------------------------------------------------#
    Local Shortint I
    I=find(IMPZON,[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
    If I=0
      I=find(IMPZON+"(0)",[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
    Endif
    If I & find(left$([M:AOE2]ZONE(I-1),3),"PIH","PIV")
      IMPFIC=left$([M:AOE2]ZONE(I-1),3)
    Endif
Endcase
Return

#--------------------------------------------------------------------#
# Import d'un texte, étiquette appelée depuis les traitements IMPPIH #
#--------------------------------------------------------------------#
$IMPORT_TEXTE
Raz G_NLDET
Case IMPFIC
  When "PIH", "PIV" :
    If G_ENT     : # --- Texte entete ---
       Raz [M:ITC]T_CLE_CLOB(1)
       Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(1)=G_CLE_CLOB
    Endif
    If G_PIE     : # --- Texte pied ---
       Raz [M:ITC]T_CLE_CLOB(2)
       Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(2)=G_CLE_CLOB
    Endif
  When "PID"
    If G_DET     : # --- Texte detail ---
       Raz [M:ITC]T_CLE_CLOB(3)
       Gosub IMP_T3 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(3)=G_CLE_CLOB
    Endif
Endcase
Return

#---------------------------------------------------------------------#
# Chargement de la clé du texte dans les classes [M:PIH0] et [M:PIH3] #
#---------------------------------------------------------------------#
$IMP_ZONE_TEXTE
Case IMPFIC
  When "PIH", "PIV"
    If G_ENT & [M:ITC]T_CLE_CLOB(1)<>"" & GREP="C" : # --- Texte entête ---
      [M:PIH0]TEX1=[M:ITC]T_CLE_CLOB(1)
   Endif
    If G_PIE & [M:ITC]T_CLE_CLOB(2)<>"" & GREP="C" : # --- Texte pied ---
      [M:PIH0]TEX2=[M:ITC]T_CLE_CLOB(2)
    Endif
  When "PID"
    If G_DET & [M:ITC]T_CLE_CLOB(3)<>"" & GREP="C" : # --- texte détail ligne ---
      [M:PIH3]LINTEX(nolign-1)=[M:ITC]T_CLE_CLOB(3)
    Endif
Endcase
Return


##########################################################################
#                                   EXPORT                               #
##########################################################################

#-----------------------------------------------------------------#
# Début export, étiquette appelée directement depuis le SUBEXPOBJ #
#-----------------------------------------------------------------#
$EXP_OUVRE
#----- Gestion dess textes -----#
Gosub DECLARE_TEXTE From TRTX3IMP
G_EXPORT=1 : Gosub OUVRE_TEXTE
#----- Changement pseudo table CPTFOOTLNK par CPTANALIN bis -----#
If clalev([F:CFL])  Close Local File [CFL] : Endif
Local File CPTANALIN [CFL]
#-----
Return

#---------------------------------------------------#
# Après lecture d'un enregistrement (entête, ligne) #
# ------------------------------------------------- #
# EXPFIC : Abréviation du fichier en cours          #
#---------------------------------------------------#
$EXPORT
Case EXPFIC
  When "PIH", "PIV"
    # Issue 78080 - 2012-02-02 by VPO : PIV pas forcement ouverte
    If clalev([F:PIV])
    If EXPFIC="PIH"  Read [PIV] PIV0=[F:PIH]NUM : If fstat  Raz [F:PIV] : Endif : Endif
    Endif
    If EXPFIC="PIV"  Read [PIH] PIH0=[F:PIV]NUM : If fstat  Raz [F:PIH] : Endif : Endif
    If G_ENT
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:PIV]TEX1)>0 & [F:PIV]TEX1<>""
          G_CLE_CLOB=[F:PIV]TEX1   : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif
    If G_PIE
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:PIV]TEX2)>0 & [F:PIV]TEX2<>""
          G_CLE_CLOB=[F:PIV]TEX2   : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP
       Endif
    Endif
  When "PID"
    If G_DET
       Gosub EXP_RAZ_T3 From TRTX3IMP
       If dim([F:PID]LINTEX)>0 & [F:PID]LINTEX<>""
          G_CLE_CLOB=[F:PID]LINTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T3 From TRTX3IMP
       Endif
    Endif
Endcase
Return

#------------------------------------------#
# Export d'un champ                        #
# ---------------------------------------- #
# EXPFIC : Abréviation du fichier en cours #
#------------------------------------------#
$EXP_ZONE
Return

#---------------------------------------------------------------#
# Fin export, étiquette appelée directement depuis le SUBEXPOBJ #
#---------------------------------------------------------------#
EXP_FERME
Return

