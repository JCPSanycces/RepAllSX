#<AdxTL>@(#)0.0.0.0 $Revision$
# Supervisor
## BI-DIMENSION ## Synchronization rule BUDENT

$OUVRE
Local Char FILTRE(250)
OUVTAB = GDOSSIER+".ENTITE" : If clalev([F:ENT])=0 : Local File =OUVTAB [ENT] : Endif
OUVTAB = GDOSSIER+".ATEXTRA" : If clalev([F:AXX1])=0 : Local File =OUVTAB [AXX1] : Endif
OUVTAB = GDOSSIER+".ATEXTRA" : If clalev([F:AXX2])=0 : Local File =OUVTAB [AXX2] : Endif
OUVTAB = "Link [ENT]"
Link [ENT] With
& [AXX1]AXX0 = "ENTITE";"DESTRA";GLANGUE;[F:ENT]ENT;"",
& [AXX2]AXX0 = "ENTITE";"SHOTRA";GLANGUE;[F:ENT]ENT;""
& As [LNK_]
& Where [F:ENT]ENAFLG=2 & [F:ENT]ENTFLG=2
& Order By Key CLE = [ENT]ENT
FILTRE = ""
Return

$FERME
If clalev([F:ENT]) : Close local File [ENT] : Endif
If clalev([F:AXX1]) : Close local File [AXX1] : Endif
If clalev([F:AXX2]) : Close local File [AXX2] : Endif
Return

$DCLE
Local Char    DCLE(GLONAVA)(1..1)
Local Integer DTYP(1..1)
Local Integer NBDCLE
NBDCLE = 1
DCLE(1) = "ENT"
DTYP(1) =  7
Return

$CHARGE_CLE
If dim([F:AAA_]ENT)>0
 [F:AAA_]ENT = [F:ENT]ENT
Endif
Return

########################################################################
# Return the filter necessary for incremental delete in synchroonization
Subprog GET_FLTDELINC(PFLT)
Variable Clbfile PFLT
PFLT = "1=1"
Append PFLT, " & [F:AAA_]ENT=[F:ENT]ENT"

End

$MAJFLD
### ENT
[L]FLD="ENT"
[L]FORMULE='[F:ENT]ENT'
If dim([F:AAA_]ENT)>0
 [F:AAA_]ENT = [F:ENT]ENT
Endif

### DES
[L]FLD="DES"
[L]FORMULE='[F:AXX1]TEXTE'
If dim([F:AAA_]DES)>0
 [F:AAA_]DES = [F:AXX1]TEXTE
Endif

### SHO
[L]FLD="SHO"
[L]FORMULE='[F:AXX2]TEXTE'
If dim([F:AAA_]SHO)>0
 [F:AAA_]SHO = [F:AXX2]TEXTE
Endif

### CPY
[L]FLD="CPY"
[L]FORMULE='[F:ENT]CPY'
If dim([F:AAA_]CPY)>0
 [F:AAA_]CPY = [F:ENT]CPY
Endif

### ENTRAT
[L]FLD="ENTRAT"
[L]FORMULE='[F:ENT]ENTRAT'
If dim([F:AAA_]ENTRAT)>0
 [F:AAA_]ENTRAT = [F:ENT]ENTRAT
Endif

### ENTAPP
[L]FLD="ENTAPP"
[L]FORMULE='[F:ENT]ENTAPP'
If dim([F:AAA_]ENTAPP)>0
 [F:AAA_]ENTAPP = [F:ENT]ENTAPP
Endif

### LEV
[L]FLD="LEV"
[L]FORMULE='[F:ENT]LEV'
If dim([F:AAA_]LEV)>0
 [F:AAA_]LEV = [F:ENT]LEV
Endif

### USR
[L]FLD="USR"
[L]FORMULE='[F:ENT]USR'
If dim([F:AAA_]USR)>0
 [F:AAA_]USR = [F:ENT]USR
Endif


Return

