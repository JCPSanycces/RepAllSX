#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
#  Sous programmes pour la gestion des correspondants                        Module CRM 10 avril 2006
##########################################################################################################
#                                                                                                        #
# CRECOR    : Sous-programme de création d'un correspondant
#                                                                                                        #
##########################################################################################################
Subprog TEST
Local Char SZCORNUM
Local Integer LERRCOD

  GSYNCOUTLOOK = 1
  Call CRECOR("SUBCORCC", 2, 2, SZCORNUM, LERRCOD)
  GSYNCOUTLOOK = 0
End

##########################################################################################################
# Sous-programme de création d'un correspondant
#########################################
Subprog CRECOR(SZCRECORTRT, ITRACE, ILEC_TRACE, SZCORNUM, LERRCOD)
Value Char SZCRECORTRT
Value Integer ITRACE
Value Integer ILEC_TRACE
Variable Char SZCORNUM
Variable Integer LERRCOD

Global Char GSZCRECORTRT
Global Integer GICRECORTRACE
Local Integer IBOPENTRACE
Local Integer IBDEBTRANSFLG

  IBOPENTRACE = 0
  GSZCRECORTRT = SZCRECORTRT
  GICRECORTRACE = ITRACE
  If GSZCRECORTRT = ""
    GSZCRECORTRT = "SUBCORCC"
  Endif
  Raz LERRCOD, GMESSAGE
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If ITRACE Then
    If GTRACE = "" Then
      #Création de correspondant démarré à partir du contexte : + GSZCRECORTRT
      Call OUVRE_TRACE (mess(267,177,1) - GSZCRECORTRT) From LECFIC
      IBOPENTRACE = 1
    Endif
  Endif
  #--- variables
Local Integer OK, SAVGIMPORT
Local Char ACTION(20), ABREV(GLONABR)
Local Char SAVGABREV(GLONABR)

  #--- declaration et chargement des variables objet
  ABREV = "COR"
  SAVGABREV = GABREV
  GABREV = "COR"
  Gosub DEFVAR From GOBJET    # FGR 07/06/2010 : X3SUIVI64666 A faire juste après GABREV
  #
  SAVFONC = GFONCTION         # FGR 16/09/2009 : X3SUIVI57846
  GFONCTION = "GES" + ABREV   # FGR 16/09/2009 : X3SUIVI57846
  #Gosub DEFVAR From GOBJET   # FGR 07/06/2010 : X3SUIVI64666 là on perd SAVFONC !
  SAVGIMPORT = GIMPORT
  GIMPORT = 1
  #Gestion des autorisations
  Call AUTORIS From EXEFNC
  GOK = 1
  OK = 1
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=AVANT_OUVRE",0) From GESECRAN
  Endif
  ACTION="AVANT_OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR AVANT_OUVRE", 1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #--- ouverture de la fenêtre contrat
  If !clalev([M:COR0]) : Local Mask COR0 [COR0] : Endif
  If !clalev([M:COR1]) : Local Mask COR1 [COR1] : Endif
  If !clalev([M:COR2]) : Local Mask COR2 [COR2] : Endif
  If !clalev([M:COR3]) : Local Mask COR3 [COR3] : Endif
  If !clalev([M:COR4]) : Local Mask COR4 [COR4] : Endif
  Raz [M:COR0], [M:COR1], [M:COR2], [M:COR3], [M:COR4]
  #--- ouverture des tables necessaires
  If !clalev([F:COR]) : Local File CORRESPOND [COR] : Endif
  Gosub OUVRE From WOCOR
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=OUVRE",0) From GESECRAN
  Endif
  ACTION = "OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  # --------------------------------------
  # FGR 10/02/2016 : X3SUIVI114388 (début)
  Global Char GIMPLDS(10)
  GIMPLDS = ACTION
  # FGR 10/02/2016 : X3SUIVI114388 (fin)
  # --------------------------------------
  WINPROG = "WGOCOR"
  GREP = "C"
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=RAZCRE",0) From GESECRAN
  Endif
  ACTION = "RAZCRE" : Gosub ACTION From GOBJSUB
  If GERR = 1 Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR RAZCRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #--- chargement des masques de objet
  If ITRACE > 1 Then
    Call ECR_TRACE("MASK",0) From GESECRAN
  Endif
  #------------------------------------------------------------------------
  # chargement masques enregistrement tache
  Default Mask [COR0]
  Call SAIMSK("COR","IMP_ZONE","SUBCORCC") From W0COR0
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK COR0 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [COR1]
  Call SAIMSK("COR","IMP_ZONE","SUBCORCC") From W0COR1
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK COR1 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [COR2]
  Call SAIMSK("COR","IMP_ZONE","SUBCORCC") From W0COR2
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK COR2 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [COR3]
  Call SAIMSK("COR","IMP_ZONE","SUBCORCC") From W0COR3
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK COR3 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [COR4]
  Call SAIMSK("COR","IMP_ZONE","SUBCORCC") From W0COR4
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK COR4(IMP_ZONE) mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [COR4]
  Call SAIMSK("COP","IMP_TAB","SUBCORCC") From W0COR4
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK COR4(IMP_TAB) mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  GPOINT = "MSKCRECOR" : Gosub ENTREE From EXEFNC  #CHECK IGNORE_LINE
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  GPOINT=MSKCRECOR mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 8
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=VERIF_CRE",0) From GESECRAN
  Endif
  ACTION = "VERIF_CRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR VERIF_CRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  GOK = 1
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [COR]
  Endif
  Raz [F:COR]
  Default File [F:COR]
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=INICRE",0) From GESECRAN
  Endif
  ACTION = "INICRE" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR INICRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  [F:COR] = [M:COR0]
  [F:COR] = [M:COR1]
  [F:COR] = [M:COR2]
  [F:COR] = [M:COR3]
  [F:COR] = [M:COR4]
  [F:COR]CREUSR = GUSER
  [F:COR]CREDAT = date$
  If ITRACE > 1 Then
    #Ecriture [F:COR]  -  CORNUM=+[F:COR]CORNUM
    Call ECR_TRACE(mess(268,177,1) - [F:COR]CORNUM,0) From GESECRAN
  Endif
  Write [F:COR]
  If fstat Then
    #Erreur lors de l'écriture du correspondant+" CORNUM="+[F:COR]CORNUM
    GMESSIMP = "~" + mess(394,177,1) - "CORNUM=" + [F:COR]CORNUM  # FGR 22/10/2010 : X3SUIVI68366
    Call ECR_TRACE(mess(394,177,1) - "CORNUM=" + [F:COR]CORNUM,1) From GESECRAN
    LERRCOD = 9
    GOK = 0
    Call FSTA("COR") From GLOCK
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=CREATION",0) From GESECRAN
  Endif
  ACTION = "CREATION" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR CREATION",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If IBDEBTRANSFLG = 0 Then
    Commit
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=APRES_CRE",0) From GESECRAN
  Endif
  ACTION = "APRES_CRE" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR APRES_CRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If ITRACE Then
    #Call ECR_TRACE("[M:COR0]CORNUM=" + [M:COR0]CORNUM - "GOK="+num$(GOK),0) From GESECRAN
    Call ECR_TRACE(mess(667,177,1)+[M:COR0]CORNUM,0) From GESECRAN
  Endif
  If GOK <= 0 Then
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  SZCORNUM = [M:COR0]CORNUM
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=FERME",0) From GESECRAN
  Endif
  ACTION = "FERME" : Gosub ACTION From GOBJSUB
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  # --------------------------------------
  # FGR 10/02/2016 : X3SUIVI114388 (début)
  Kill GIMPLDS
  # FGR 10/02/2016 : X3SUIVI114388 (fin)
  # --------------------------------------
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC         # FGR 16/09/2009 : X3SUIVI57846
  # FGR 06/04/2011 : X3SUIVI72587 : Restauration Gestion des autorisations
  Call AUTORIS From EXEFNC
  Kill GSZCRECORTRT
  Kill GICRECORTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC
    Endif
  Endif
End

##########################################################################################################
$ACTION
Local Char SZVALBEFORE
Local Char SZVALAFTER
Local Integer IBTESTOK
Local Integer WI # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse

  IBTESTOK = 0
  Raz SZVALBEFORE
  Raz SZVALAFTER
  If evalue ("type([M]"+IMPZON+")") < 300 Then
    IBTESTOK = 1
  Endif
  If IBTESTOK = 1 Then
    SZVALBEFORE = num$(evalue("[M]"+IMPZON))
  Endif
  If GICRECORTRACE > 1 Then
    Call ECR_TRACE("ACTION = "+ACTION-"IMPZON="+IMPZON-"XOK="+num$(XOK),0) From GESECRAN
    If IBTESTOK = 1 Then
      #"    "+Valeur avant = +" : " +SZVALBEFORE
      Call ECR_TRACE("    " - mess(369,177,1) - ":" - SZVALBEFORE,0) From GESECRAN
    Endif
  Endif
  WI = func SUBLDSB.GET_IND_ADD_PRINC() # FGR 26/08/2008 : X3SUIVI48267 : Gestion de l'onglet Adresse
  Case ACTION
    When "IMP_ZONE"
      Gosub COR_SET_HEA_INFO From=GSZCRECORTRT
    When "IMP_TAB"
      Gosub COR_SET_DET_INFO From=GSZCRECORTRT
  Endcase
  If IBTESTOK = 1 Then
    SZVALAFTER = num$(evalue("[M]"+IMPZON))
    If SZVALAFTER <> SZVALBEFORE Then
      IMPMOD = 1
    Endif
  Else
    IMPMOD = 1
  Endif
  If GICRECORTRACE > 1 Then
    If IBTESTOK = 1 Then
      #"    "+Valeur après = +" : " +SZVALAFTER
      Call ECR_TRACE("    " - mess(370,177,1) - ":" - SZVALAFTER,0) From GESECRAN
    Endif
  Endif
Return

##########################################################################################################
$ONERROR
  If IBDEBTRANSFLG = 0 Then
    If adxlog Then
      Rollback
    Endif
  Endif
  # FGR 20/07/2010 (début)
  If dim(GAINMESSAGE) < 0 Then
    Global Char GAINMESSAGE(type(GMESSAGE)-10)

    GAINMESSAGE = "COR~(C)" - GMESSIMP
  Endif
  # FGR 20/07/2010 (fin)
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GOK = 0
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC         # FGR 16/09/2009 : X3SUIVI57846
  Kill GSZCRECORTRT
  Kill GICRECORTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC
    Endif
  Endif
Return

##########################################################################################################
# Affectation des valeurs pour la création d'un correspondant. (exemple)
#############################################################################
#ENTETE
$COR_SET_HEA_INFO
  Case IMPZON
     When "CORNUM"
       #Chrono
       [M:COR0]CORNUM = ""
     When "CORTYP"
       #type
       [M:COR0]CORTYP = "COR"
     When "TTL"
       #Civilité
       [M:COR0]TTL = 1
     When "LNA"
       #Nom
       [M:COR0]LNA = "DUPUIS"
     When "FNA"
       #Prénom
       [M:COR0]FNA = "Jacques"
     When "BPRLIB"
       #Libellé société
       [M:COR2]BPRLIB = "Ma petite société"
     When "FNCLIB"
       #Libellé fonction
       [M:COR2]FNCLIB = "Directeur"
     When "CPYBPADES"
       #Intitullé adresse professionnelle
       [M:COR2]CPYBPADES = "Mon adresse soc"
     When "CPYADD"
       Case indice
         When 0
           #Adresse 1 professionnelle
           [M:COR2]CPYADD(0) = "2 chemin du travail"
         When 1
           #Adresse 2 professionnelle
           [M:COR2]CPYADD(1) = "batiment 5"
         When 2
           #Adresse 3 professionnelle
           [M:COR2]CPYADD(2) = ""
       Endcase
     When "CPYCTY"
       #Ville professionnelle
       [M:COR2]CPYCTY = "Thones"
     When "CPYZIP"
       #Code postal professionnelle
       [M:COR2]CPYZIP = "74200"
     When "CPYCRYNAM"
       #Nom pays professionnelle
       [M:COR2]CPYCRYNAM = "France"
     When "CPYEML"
       #E-MAIL professionnelle
       [M:COR2]CPYEML = "monadresse@boite.fr"
    When "CPYTEL"
      #Téléphone professionnelle
      [M:COR2]CPYTEL = "0102567890"
    When "CPYFAX"
      #Fax professionnelle
      [M:COR2]CPYFAX = "0102567889"
    When "CPYMOB"
      #Portable professionnelle
      [M:COR2]CPYMOB = "0607085023"
  Endcase
Return

#############################################################################
#DETAIL
$COR_SET_DET_INFO
  Case IMPZON
    When "COPREP"
      IMPMOD = 1
      [M:COR4]COPREP(0) = "LSE12"
  Endcase
Return

