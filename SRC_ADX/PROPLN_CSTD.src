###################################################################
#            Property  - PPLENDDATH
###################################################################
$PPLENDDATH
Case ACTION
   When "INIT"                    : Gosub PPLENDDATH_INIT              : # Init method attached to PPLENDDATH
   When "CONTROL"                 : Gosub PPLENDDATH_CONTROL           : # Control method attached to PPLENDDATH
   When "PROPAGATE"               : Gosub PPLENDDATH_PROPAGATE         : # Propagate method attached to PPLENDDATH
Endcase
Return
#---------------------
$PPLENDDATH_INIT
Return
#---------------------
$PPLENDDATH_CONTROL
    # If not significative
    If (this.PPLENDDATH = AVOID.ADATE) Then : Return : Endif
    # Facility is not keyed
    If (this.FCY = AVOID.ACHAR) Then
      ASTATUS = fmet this.ASETERROR(CURPRO,"Le site doit être saisi au préalable",[V]CST_AERROR)
    Endif
    # Production end plan date must be in the current period or in one of the following one
    If (this.PPLENDDATH < this.CURPERSTR) Then
      ASTATUS = fmet this.ASETERROR(CURPRO,mess(580,[V]CST_MSGFAS,1),[V]CST_AERROR)
    Endif
Return
#---------------------
$PPLENDDATH_PROPAGATE

  #this.SETACCESSORENABLED = 0
  Call BUILD_PROD_PLAN_LINES ( this, this.PPLENDDATH )
  #this.SETACCESSORENABLED = 1

Return
#---------------------
$PPLENDDATH_GET
Return

###################################################################
#            Property  - EXTQTY
###################################################################
$PROPLNL_EXTQTY

Case ACTION
   When "INIT"                    : Gosub PROPLNL_EXTQTY_INIT             : # Init method attached to PROPLNL_EXTQTY
   When "CONTROL"                 : Gosub PROPLNL_EXTQTY_CONTROL           : # Control method attached to PROPLNL_EXTQTY
   When "PROPAGATE"               : Gosub PROPLNL_EXTQTY_PROPAGATE         : # Propagate method attached to PROPLNL_EXTQTY
Endcase
Return
#---------------------
$PROPLNL_EXTQTY_INIT
Return
#---------------------
$PROPLNL_EXTQTY_CONTROL
Return
#---------------------
$PROPLNL_EXTQTY_PROPAGATE

 If ( this.PERSTRDAT = this.APARENT.CURPERSTR ) Then
    this.CPLQTY = this.EXTQTY
  Endif
  # EXTQTY has been modified
  #Call RESIDUAL_UNITS ( this.APARENT, this.APARENT.PPLENDDATH, this.APARENT.CURPERSTR  )
  Gosub RESIDUAL_UNITS
Return



###################################################################
#            Property  - PLNQTYH
###################################################################
$PLNQTYH
Case ACTION
   When "INIT"                    : Gosub PLNQTYH_INIT              : # Init method attached to PLNQTYH
   When "CONTROL"                 : Gosub PLNQTYH_CONTROL           : # Control method attached to PLNQTYH
   When "PROPAGATE"               : Gosub PLNQTYH_PROPAGATE         : # Propagate method attached to PLNQTYH
   When "GET"                     : Gosub PLNQTYH_GET               : # Get method attached to PLNQTYH
Endcase
Return
#---------------------
$PLNQTYH_INIT
Return
#---------------------
$PLNQTYH_CONTROL
Return
#---------------------
$PLNQTYH_PROPAGATE
  # If preriquisite don't match
  If ( this.CPY = AVOID.ACHAR or this.CNX = AVOID.AINT ) Then : Return : Endif

  Local Decimal LPLNQTY
  Local Integer   I_LIN
  For [L]I_LIN = maxtab(this.PROPLNL) To 1 Step -1
    # On the last defined PROPLNL line
    #If (this.PROPLNL([L]I_LIN) <> null) Then
    If ( find(this.PROPLNL([L]I_LIN).ASTALIN, CST_ADEL, CST_ANEWDEL) = 0) Then
      [L]LPLNQTY = this.PROPLNL([L]I_LIN).PLNQTY
      Break
    Endif
  Next

  # PLNQTYH has been modified
  Local Integer I_PL
  [L]I_PL = find(this.CURPERSTR, this.PROPLNL(1..maxtab(this.PROPLNL)).PERSTRDAT)
  this.PROPLNL([L]I_PL).RSDQTY += this.PLNQTYH - [L]LPLNQTY

  Call PROPAGATE_RSDQTY_CPLQTY_ON_PROD_PLAN_LINES ( this, [L]I_PL,  this.PPLENDDATH, [L]I_PL )
  Call PROPAGATE_PLNQTY_CUMQTY_FIYQTY_ON_PROD_PLAN_LINES ( this, this.PPLENDDATH, [L]I_PL, this.PLNQTYH )


Return
#---------------------
$PLNQTYH_GET
Local Integer   I_LIN
  If ( maxtab(this.PROPLNL) = 0) Then
    this.PLNQTYH = 0
  Else
    For [L]I_LIN = maxtab(this.PROPLNL) To 1 Step -1
      # On then last defined PROPLNL line
      If ( find(this.PROPLNL([L]I_LIN).ASTALIN, CST_ADEL, CST_ANEWDEL) = 0) Then
        this.PLNQTYH = this.PROPLNL([L]I_LIN).PLNQTY
        Break
      Endif
    Next
  Endif
Return



###################################################################
#            Procedures, Subprograms & Functions  - PROPLN
###################################################################

#*************************************************
Subprog CLEAR_PROD_PLAN_LINES ( PROPLN , RSTATUS)
Variable Instance PROPLN Using C_PROPLN
Variable Integer RSTATUS

#
#    Production plan lines deletion
#

Local Integer I_RET
Local Integer I_LIN
Local Integer I_POS

If ( RSTATUS <> CST_AOK ) Then : End : Endif

  # Empty array
  If (maxtab(PROPLN.PROPLNL) = 0) Then : End : Endif

  #>>>>>>>>>>>>>
  For [L]I_LIN  = 1 To maxtab(PROPLN.PROPLNL)
     If (find(PROPLN.PROPLNL([L]I_LIN).ASTALIN, CST_ADEL, CST_ANEWDEL) = 0) Then
       # Any active line is deleted
       PROPLN.PROPLNL([L]I_LIN).FIYSTRDAT = AVOID.ADATE
       PROPLN.PROPLNL([L]I_LIN).PERSTRDAT = AVOID.ADATE
       [L]I_RET=fmet PROPLN.ADELLINE("PROPLNL",[L]I_LIN)
       If [L]I_RET= ANOTDEFINED
          [L]I_RET=fmet PROPLN.ASETERROR("","error",[V]CST_AERROR)
          RSTATUS=CST_AERROR
          Break
        Endif
     Endif
  Next
  #<<<<<<<<<<<<<

End
#*************************************************
Subprog BUILD_PROD_PLAN_LINES ( PROPLN, PPPLENDDAT )
Variable Instance PROPLN Using C_PROPLN
Value Date PPPLENDDAT

#
#    Le découpage du plan de production est calqué sur le découpage en périodes
#    Si le plan n'est pas encore chargé (PLIN = 1)
#        le plan est défini depuis la période courante du contexte gérant les UO
#        jusqu'à la dernière période du dernier exercice défini
#    Si la date de fin du plan n'est pas ou plus précisée
#       le plan est défini jusqu'à la dernière période du dernier exercice défini
#    Si la date de fin du plan est précisée
#       le plan est défini jusqu'à la période contenant la date de fin du plan de production
#       à défaut le plan est défini jusqu'à la dernière période du dernier exercice défini

Local Integer I_RET
Local Integer I_LIN
Local Integer I_POS

  # If preriquisite don't match
  If ( PROPLN.CPY = AVOID.ACHAR or PROPLN.CNX = AVOID.AINT ) Then : End : Endif

  # Skip deleted lines from company or context change
  [L]I_LIN = 0
  If (maxtab(PROPLN.PROPLNL) <> 0) Then
    #>>>>>>>>>>>>>
    For [L]I_LIN  = 1 To maxtab(PROPLN.PROPLNL)
       If (find(PROPLN.PROPLNL([L]I_LIN).ASTALIN, CST_ADEL, CST_ANEWDEL) = 0) Then
         # When an active line is detected
         [L]I_LIN -= 1
         Break
       Endif
    Next
    #<<<<<<<<<<<<<
  Endif

  Local File FISCYEAR     [FIS]
  Local File FISCPER      [FIP]
  # Loop on fiscal years
  #>1 >>>>>>>>>>>>>
  For [FIS]FIS1 Where CPY= PROPLN.CPY and CNX= PROPLN.CNX
    # Loop on periods
    #>2 >>>>>>>>>>>>>
    For [FIP]FIP0 Where CPY= PROPLN.CPY and CNX= PROPLN.CNX and
&                       FIYSTRDAT=[F:FIS]FIYSTRDAT and PERSTRDAT >= PROPLN.CURPERSTR

        # Production plan line
        [L]I_LIN += 1


          # If the line is not defined, it is created
          If ( maxtab(PROPLN.PROPLNL) = 0 or PROPLN.PROPLNL([L]I_LIN) = null ) Then
            [L]I_POS=fmet PROPLN.ADDLINE("PROPLNL",[L]I_LIN)
            PROPLN.PROPLNL([L]I_LIN).FIYSTRDAT = [F:FIS]FIYSTRDAT
            PROPLN.PROPLNL([L]I_LIN).FIYENDDAT = [F:FIS]FIYENDDAT
            PROPLN.PROPLNL([L]I_LIN).PERSTRDAT = [F:FIP]PERSTRDAT
            PROPLN.PROPLNL([L]I_LIN).PERENDDAT = [F:FIP]PERENDDAT
            # Plan units number
            If (PROPLN.PROPLNL([L]I_LIN).PERSTRDAT >= PROPLN.CURPERSTR) Then
              PROPLN.PROPLNL([L]I_LIN).PPLENDDAT = PPPLENDDAT
            Endif
            PROPLN.PROPLNL([L]I_LIN).PLNQTY    = 0
          Else
            # If line is defined and deleted, and end date greater than the read period
            # activation of the deleted line
            If (PPPLENDDAT = AVOID.ADATE or PPPLENDDAT >= [F:FIP]PERSTRDAT) Then
              If ( find(PROPLN.PROPLNL([L]I_LIN).ASTALIN, CST_ADEL, CST_ANEWDEL) > 0) Then
                If (PROPLN.PROPLNL([L]I_LIN).ASTALIN = CST_ADEL ) Then
                  PROPLN.PROPLNL([L]I_LIN).ASTALIN = CST_ALL
                Elsif (PROPLN.PROPLNL([L]I_LIN).ASTALIN = CST_ANEWDEL) Then
                  PROPLN.PROPLNL([L]I_LIN).ASTALIN = CST_ANEW
                Endif
                PROPLN.PROPLNL([L]I_LIN).FIYSTRDAT = [F:FIS]FIYSTRDAT
                PROPLN.PROPLNL([L]I_LIN).FIYENDDAT = [F:FIS]FIYENDDAT
                PROPLN.PROPLNL([L]I_LIN).PERSTRDAT = [F:FIP]PERSTRDAT
                PROPLN.PROPLNL([L]I_LIN).PERENDDAT = [F:FIP]PERENDDAT
                # Plan units number
                If (PROPLN.PROPLNL([L]I_LIN).PERSTRDAT >= PROPLN.CURPERSTR) Then
                  PROPLN.PROPLNL([L]I_LIN).PPLENDDAT = PPPLENDDAT
                Endif
                PROPLN.PROPLNL([L]I_LIN).PLNQTY    = 0
              Endif
            Endif
            # If line is defined and not deleted, and end date less than the read period
            # deletion of the active line
            If ( find(PROPLN.PROPLNL([L]I_LIN).ASTALIN, CST_ADEL, CST_ANEWDEL) = 0) Then
              # Taking into account the end production plan date if defined
              If ( PPPLENDDAT <> AVOID.ADATE and PPPLENDDAT < [F:FIP]PERSTRDAT ) Then
                # In that situation, production line must be deleted
                # I = fmet PROPLN.AGETINDBYLINE("PROPLNL",2) (syntaxe)
#               If (PROPLN.PROPLNL([L]I_LIN) <> null ) Then
#                 [L]I_RET=fmet PROPLN.ADELLINE("PROPLNL",[L]I_LIN)
#               Endif
                If (find(PROPLN.PROPLNL([L]I_LIN).ASTALIN , CST_ALL, CST_AUPD) > 0) Then
                  PROPLN.PROPLNL([L]I_LIN).ASTALIN = CST_ADEL
                Elsif (PROPLN.PROPLNL([L]I_LIN).ASTALIN = CST_ANEW) Then
                  PROPLN.PROPLNL([L]I_LIN).ASTALIN = CST_ANEWDEL
                Endif
              Endif
            Endif
          Endif

    Next
    #>2 >>>>>>>>>>>>>
  Next
  #<1 <<<<<<<<<<<<<<

End


#*************************************************
Subprog PROPAGATE_RSDQTY_CPLQTY_ON_PROD_PLAN_LINES ( PROPLN, PLIN,  PPPLENDDAT, PCURPERLIN )
Variable Instance PROPLN Using C_PROPLN
Value Integer PLIN
Value Date    PPPLENDDAT
Value Integer PCURPERLIN

Local Integer I_LIN
Local Integer IPPL
Local Integer LQTY

  # If preriquisite don't match
  If ( PROPLN.CPY = AVOID.ACHAR or PROPLN.CNX = AVOID.AINT ) Then : End : Endif


  # Skip deleted lines from company or context change
  [L]I_LIN = 1
    #>>>>>>>>>>>>>
  If (maxtab(PROPLN.PROPLNL) <> 0) Then
    For [L]I_LIN  = 1 To maxtab(PROPLN.PROPLNL)
       If (find(PROPLN.PROPLNL([L]I_LIN).ASTALIN, CST_ADEL, CST_ANEWDEL) = 0) Then
         # When an active line is detected
         If ([L]I_LIN > 1 ) Then : [L]I_LIN -= 1 : Endif
         Break
       Endif
    Next
    #<<<<<<<<<<<<<
  Endif

  #>>>>>>>>>>>
  For IPPL = [L]I_LIN To maxtab(PROPLN.PROPLNL)
    If ( find(PROPLN.PROPLNL(IPPL).ASTALIN, CST_ADEL, CST_ANEWDEL) = 0 ) Then
      # Each active production plan line
      If (PROPLN.PROPLNL(IPPL).CPLQTY <> 0 ) Then
        LQTY = PROPLN.PROPLNL(IPPL).CPLQTY
      Else
        LQTY = PROPLN.PROPLNL(IPPL).EXTQTY
      Endif
      If ( IPPL <> maxtab(PROPLN.PROPLNL) ) Then
        If ( PROPLN.PROPLNL(IPPL).RSDQTY - LQTY > 0 ) Then
          PROPLN.PROPLNL(IPPL+1).RSDQTY = PROPLN.PROPLNL(IPPL).RSDQTY - LQTY
        Else
          PROPLN.PROPLNL(IPPL+1).RSDQTY = 0
          PROPLN.PROPLNL(IPPL).EXTQTY = PROPLN.PROPLNL(IPPL).RSDQTY
          If ( PROPLN.PROPLNL(IPPL).CPLQTY <> 0 ) Then
            PROPLN.PROPLNL(IPPL).CPLQTY = PROPLN.PROPLNL(IPPL).RSDQTY
          Endif
        Endif
      Endif
      If ( PPPLENDDAT <> AVOID.ADATE ) Then
        If ( PPPLENDDAT >= PROPLN.PROPLNL(IPPL).PERSTRDAT and PPPLENDDAT <= PROPLN.PROPLNL(IPPL).PERENDDAT ) Then
          PROPLN.PROPLNL(IPPL).EXTQTY = PROPLN.PROPLNL(IPPL).RSDQTY
          If ( IPPL = PCURPERLIN ) Then
            PROPLN.PROPLNL(IPPL).CPLQTY = PROPLN.PROPLNL(IPPL).EXTQTY
          Endif
        Endif
      Endif
    Endif
  Next IPPL
  #>>>>>>>>>>>
End

#*************************************************
Subprog PROPAGATE_PLNQTY_CUMQTY_FIYQTY_ON_PROD_PLAN_LINES ( PROPLN, PPPLENDDAT, PCURPERLIN, PPLNQTY )
Variable Instance PROPLN Using C_PROPLN
Value Date    PPPLENDDAT
Value Integer PCURPERLIN
Value Decimal PPLNQTY

Local Integer I_LIN
Local Integer IPPL
Local Integer LFIYQTY
Local Integer LCUM

  # If preriquisite don't match
  If ( PROPLN.CPY = AVOID.ACHAR or PROPLN.CNX = AVOID.AINT ) Then : End : Endif

  # Skip deleted lines from company or context change
  [L]I_LIN = 1
  If (maxtab(PROPLN.PROPLNL) <> 0) Then
    #>>>>>>>>>>>>>
    For [L]I_LIN  = 1 To maxtab(PROPLN.PROPLNL)
       If (find(PROPLN.PROPLNL([L]I_LIN).ASTALIN, CST_ADEL, CST_ANEWDEL) = 0) Then
         # When an active line is detected
         If ([L]I_LIN > 1 ) Then : [L]I_LIN -= 1 : Endif
         Break
       Endif
    Next
    #<<<<<<<<<<<<<
  Endif

  LFIYQTY = 0
  LCUM   = 0
  #>>>>>>>>>>>
  # First, accumulated Units is calculated for each fiscal year. The result is stored on the array line
  # corresponding to each fiscal year last period and to production plan last period if then production
  # plan has an end date
  For [L]IPPL =[L]I_LIN To maxtab(PROPLN.PROPLNL)
    If ( find(PROPLN.PROPLNL([L]IPPL).ASTALIN, CST_ADEL, CST_ANEWDEL) = 0) Then
      # Plan units number
        If (PROPLN.PROPLNL([L]IPPL).PERSTRDAT >= PROPLN.CURPERSTR) Then
          PROPLN.PROPLNL([L]IPPL).PLNQTY    = PPLNQTY
        Endif
        If (PROPLN.PROPLNL([L]IPPL).CPLQTY <> 0 ) Then
          LFIYQTY += PROPLN.PROPLNL([L]IPPL).CPLQTY
          LCUM    += PROPLN.PROPLNL([L]IPPL).CPLQTY
        Else
          LFIYQTY += PROPLN.PROPLNL([L]IPPL).EXTQTY
          LCUM    += PROPLN.PROPLNL([L]IPPL).EXTQTY
        Endif
        PROPLN.PROPLNL([L]IPPL).CUMQTY = LCUM
        If ( PROPLN.PROPLNL([L]IPPL).PERENDDAT = PROPLN.PROPLNL([L]IPPL).FIYENDDAT )
&       or ( (PPPLENDDAT <> AVOID.ADATE) and (PROPLN.PROPLNL([L]IPPL).PERENDDAT >= PPPLENDDAT) ) Then
           PROPLN.PROPLNL([L]IPPL).FIYQTY = LFIYQTY
           LFIYQTY = 0
        Endif
      Endif
    Next [L]IPPL
    #>>>>>>>>>>>

  #>>>>>>>>>>>
  # Then, each accumulated fiscal year units, located in the last period on the fiscal year or on the period
  # in which the production plan ends when an end production plan date is present, is stored on each fiscal year period.
    LFIYQTY = 0
    For [L]IPPL = PCURPERLIN To maxtab(PROPLN.PROPLNL)
      If ( find(PROPLN.PROPLNL([L]IPPL).ASTALIN, CST_ADEL, CST_ANEWDEL) = 0 ) Then
        PROPLN.PROPLNL([L]IPPL).PPLENDDAT = PPPLENDDAT
        If ( LFIYQTY = 0 ) Then
          If (PPPLENDDAT <> AVOID.ADATE) and (PROPLN.PROPLNL([L]IPPL).FIYENDDAT >= PPPLENDDAT)
            LFIYQTY = PROPLN.PROPLNL(maxtab(PROPLN.PROPLNL)).FIYQTY
          Else
            LFIYQTY =
&           PROPLN.PROPLNL(find(PROPLN.PROPLNL([L]IPPL).FIYENDDAT, PROPLN.PROPLNL(1..maxtab(PROPLN.PROPLNL)).PERENDDAT)).FIYQTY
          Endif
        Endif
        PROPLN.PROPLNL([L]IPPL).FIYQTY = LFIYQTY
        If ( PROPLN.PROPLNL([L]IPPL).PERENDDAT = PROPLN.PROPLNL([L]IPPL).FIYENDDAT )
&       or ( (PPPLENDDAT <> AVOID.ADATE) and (PROPLN.PROPLNL([L]IPPL).PERENDDAT >= PPPLENDDAT) ) Then
          LFIYQTY = 0
        Endif
      Endif
    Next [L]IPPL
    #>>>>>>>>>>>

End

##*************************************************
