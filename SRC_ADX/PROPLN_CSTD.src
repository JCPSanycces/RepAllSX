###################
# DATA CLASS PROPLN
###################
$ACTION
  Case CURPRO
    When ""         : Gosub METHODS    : # If CURPRO is empty, we are on class methods
    When Default    : Gosub PROPERTIES : # Otherwise it is a hook called on properties
  Endcase

Return

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
          When "AREAD_AFTER"             : Gosub AREAD_AFTER             : # Get method attached to AREAD_AFTER
          When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE  : # Get method attached to AINSERT_CONTROL_BEFORE
    Endcase
  When "PPLN.PPLNL"
    Case [L]AEVENT
        When "ADDLINE_AFTER" Gosub PROPLNL_ADDLINE_AFTER
    Endcase
Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


###############
# METHOD
###############
$METHODS
  If (dim(CURPTH) > 0) Then
    Case CURPTH
      When ""
        Case AMETHOD
          When Default
        Endcase
      When "PROPLNL"
      When "PPLN.PPLNL"
      When Default
    Endcase
  Endif
Return


###################################################################
#            Methods on classe  -  PROPLN
###################################################################
$AREAD_AFTER
  this.CURFIYSTR = fmet this.ACTX.ACACHE.CNX.AGETVALDAT(this.CPY,this.CNX,"CURFIYSTR")
  this.CURPERSTR = fmet this.ACTX.ACACHE.CNX.AGETVALDAT(this.CPY,this.CNX,"CURPERSTR")
Return

$AINSERT_CONTROL_BEFORE



  # Automatic production plan referencing
  Local Integer PPLAUTNUM  : [L]PPLAUTNUM = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,this.CPY,"PPLAUTNUM")



  Local Char    PROPLN     : [L]PROPLN = this.PROPLN
  # If the asset is registerable and the bar code is null and mandatory, a bar code is generated
  If ( [L]PPLAUTNUM  = [V]CST_NUMMANDATORY or ( [L]PPLAUTNUM  = [V]CST_NUMOPTIONAL and [L]PROPLN = "") ) Then
#    #TODO Réviser le sous_programme hors variable globale
#    Local Integer STAT
#    Call GET_NUMERO("PLP",3,1,this.CPY,this.FCY,date$,[L]PROPLN,[L]STAT) From GLOBIENS
#    If ([L]STAT) Then
#      ASTATUS = fmet this.ASETERROR(CURPRO,mess(22,[V]CST_MSGFASPAR,1),[V]CST_AERROR)
#    Endif
  Endif
  # Propagate production plan référence on production lines
  this.PROPLN = [L]PROPLN

Return

$PROPLNL_ADDLINE_AFTER
#remplir les valeurs
Return

###############
# PROPERTY
###############

$PROPERTIES
  Case CURPRO
    When "CPY"             : Gosub CPY
    When "FCY"             : Gosub FCY
    When "CNX"             : Gosub CNX
    When "PROPLN"          : Gosub PROPLN
    When "UOM"             : Gosub UOM
    When "ENAFLG"          : Gosub ENAFLG
    When "PPLENDDATH"      : Gosub PPLENDDATH

    When "PROPLNL.EXTQTY"   : Gosub PROPLNL_EXTQTY

    When "PLNQTYH"         : Gosub PLNQTYH

    When Default
    Endcase
  Return



###################################################################
#            Property  - CPY
###################################################################
$CPY
Case ACTION
   When "INIT"                    : Gosub CPY_INIT              : # Init method attached to CPY
   When "CONTROL"                 : Gosub CPY_CONTROL           : # Control method attached to CPY
   When "PROPAGATE"               : Gosub CPY_PROPAGATE         : # Propagate method attached to CPY
Endcase
Return
#---------------------
$CPY_INIT
Return
#---------------------
$CPY_CONTROL
Return
#---------------------
$CPY_PROPAGATE
  #this.SETACCESSORENABLED = 0
  # CONTEXT cached class
  #-1 -----------
  If ( this.CPY <> AVOID.ACHAR and this.CNX <> AVOID.AINT ) Then
    this.CURFIYSTR = fmet this.ACTX.ACACHE.CNX.AGETVALDAT(this.CPY,this.CNX,"CURFIYSTR")
    this.CURPERSTR = fmet this.ACTX.ACACHE.CNX.AGETVALDAT(this.CPY,this.CNX,"CURPERSTR")
  Endif

  Local Integer L_STATUS
  Call CLEAR_PROD_PLAN_LINES (this, L_STATUS)
  #If (fmet this.AGETMAXERROR("") < CST_AWARNING) Then : Return : Endif
  If ([L]L_STATUS <> CST_AOK) Then : Return : Endif

  Call BUILD_PROD_PLAN_LINES (this, this.PPLENDDATH)
  #this.SETACCESSORENABLED = 1
Return
#---------------------
$CPY_GET
Return


###################################################################
#            Property  - FCY
###################################################################
$FCY
Case ACTION
   When "INIT"                    : Gosub FCY_INIT              : # Init method attached to FCY
   When "CONTROL"                 : Gosub FCY_CONTROL           : # Control method attached to FCY
   When "PROPAGATE"               : Gosub FCY_PROPAGATE         : # Propagate method attached to FCY
Endcase
Return
#---------------------
$FCY_INIT
Return
#---------------------
$FCY_CONTROL
Return
#---------------------
$FCY_PROPAGATE
  Local File FACILITY     [FCY]
  Read [FCY]FCY0=this.FCY
  If !(fstat) Then
    this.CPY = [F:FCY]LEGCPY
  Endif
Return
#---------------------
$FCY_FET
Return


###################################################################
#            Property  - CNX
###################################################################
$CNX
Case ACTION
   When "INIT"                    : Gosub CNX_INIT              : # Init method attached to CNX
   When "CONTROL"                 : Gosub CNX_CONTROL           : # Control method attached to CNX
   When "PROPAGATE"               : Gosub CNX_PROPAGATE         : # Propagate method attached to CNX
Endcase
Return
#---------------------
$CNX_INIT
Return
#---------------------
$CNX_CONTROL
Return
#---------------------
$CNX_PROPAGATE
  #this.SETACCESSORENABLED = 0
  Local Integer L_STATUS
  Call CLEAR_PROD_PLAN_LINES (this, [L]L_STATUS)
  #If (fmet this.AGETMAXERROR("") < CST_AWARNING) Then : Return : Endif
  If ([L]L_STATUS <> CST_AOK) Then : Return : Endif

  Call BUILD_PROD_PLAN_LINES (this, this.PPLENDDATH)
  #this.SETACCESSORENABLED = 1
Return
#---------------------
$CNX_GET
