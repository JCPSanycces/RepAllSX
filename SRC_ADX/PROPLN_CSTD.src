##*************************************************
$RESIDUAL_UNITS
Local Integer IPPL
Local Integer LQTY
Local Integer LDEB

    [L]LDEB = this.AORDER
    #>>>>>>>>>>>
    For [L]IPPL = [L]LDEB To maxtab(this.APARENT.PROPLNL)
      If ( find(this.APARENT.PROPLNL([L]IPPL).ASTALIN, CST_ADEL, CST_ANEWDEL) = 0 ) Then
        If (this.APARENT.PROPLNL([L]IPPL).CPLQTY <> 0 ) Then
          LQTY = this.APARENT.PROPLNL([L]IPPL).CPLQTY
        Else
          LQTY = this.APARENT.PROPLNL([L]IPPL).EXTQTY
        Endif
        If ( [L]IPPL <> maxtab(this.APARENT.PROPLNL) ) Then
          If ( this.APARENT.PROPLNL([L]IPPL).RSDQTY - LQTY > 0 ) Then
            this.APARENT.PROPLNL([L]IPPL+1).RSDQTY = this.APARENT.PROPLNL([L]IPPL).RSDQTY - LQTY
          Else
            this.APARENT.PROPLNL([L]IPPL+1).RSDQTY     = 0
            #If ( this.APARENT.PROPLNL([L]IPPL).CPLQTYFLG <> CST_AYES ) Then
              this.APARENT.PROPLNL([L]IPPL).EXTQTY   = this.APARENT.PROPLNL([L]IPPL).RSDQTY
            #Endif
            If ( this.APARENT.PROPLNL([L]IPPL).CPLQTY <> 0 ) Then
              this.APARENT.PROPLNL([L]IPPL).CPLQTY = this.APARENT.PROPLNL([L]IPPL).RSDQTY
            Endif
          Endif
        Endif
        If ( this.APARENT.PPLENDDATH <> AVOID.ADATE ) Then
          If ( this.APARENT.PPLENDDATH >= this.APARENT.PROPLNL([L]IPPL).PERSTRDAT and
&              this.APARENT.PPLENDDATH <= this.APARENT.PROPLNL([L]IPPL).PERENDDAT ) Then
            #If ( this.APARENT.PROPLNL([L]IPPL).CPLQTYFLG <> CST_AYES ) Then
              this.APARENT.PROPLNL([L]IPPL).EXTQTY = this.APARENT.PROPLNL([L]IPPL).RSDQTY
            #Endif
            If ( this.APARENT.PROPLNL([L]IPPL).PERSTRDAT = this.APARENT.CURPERSTR ) Then
              this.APARENT.PROPLNL([L]IPPL).CPLQTY = this.APARENT.PROPLNL([L]IPPL).EXTQTY
            Endif
          Endif
        Endif
      Endif
    Next IPPL
    #>>>>>>>>>>>

Return

