#            Endif
#          Endif
#        Endif
#        If ( PDTFNPPL <> [0/0/0] ) Then
#          If ( PDTFNPPL >= PROPLN.PROPLNL([L]IPPL).PERSTRDAT and
#&              PDTFNPPL <= PROPLN.PROPLNL([L]IPPL).PERENDDAT ) Then
#            #If ( PROPLN.PROPLNL([L]IPPL).CPLQTYFLG <> CST_AYES ) Then
#              PROPLN.PROPLNL([L]IPPL).EXTQTY = PROPLN.PROPLNL([L]IPPL).RSDQTY
#            #Endif
#            If ( PROPLN.PROPLNL([L]IPPL).PERSTRDAT = PCURPERSTR ) Then
#              PROPLN.PROPLNL([L]IPPL).CPLQTY = PROPLN.PROPLNL([L]IPPL).EXTQTY
