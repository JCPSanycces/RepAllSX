#              PROPLN.PROPLNL([L]IPPL).EXTQTY   = PROPLN.PROPLNL([L]IPPL).RSDQTY
#            #Endif
#            If ( PROPLN.PROPLNL([L]IPPL).CPLQTY <> 0 ) Then
