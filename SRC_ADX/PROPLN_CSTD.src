###################################################################
#            Property  - PROPLN
###################################################################
$PROPLN
Case ACTION
   When "INIT"                    : Gosub PROPLN_INIT              : # Init method attached to PROPLN
   When "CONTROL"                 : Gosub PROPLN_CONTROL           : # Control method attached to PROPLN
   When "PROPAGATE"               : Gosub PROPLN_PROPAGATE         : # Propagate method attached to PROPLN
Endcase
Return
#---------------------
$PROPLN_INIT
Return
#---------------------
$PROPLN_CONTROL
Return
#---------------------
$PROPLN_PROPAGATE
    Local Integer IPPL
    #>>>>>>>>>>>
    # Production plan reference on each defined production plan line
    For [L]IPPL = find(this.CURPERSTR, this.PROPLNL(1..maxtab(this.PROPLNL)).PERSTRDAT) To maxtab(this.PROPLNL)
      If ( find(this.PROPLNL([L]IPPL).ASTALIN, CST_ADEL, CST_ANEWDEL) = 0 ) Then
        this.PROPLNL([L]IPPL).PROPLN = this.PROPLN
      Endif
    Next IPPL
    #>>>>>>>>>>>

Return
#---------------------
$PROPLN_GET
Return
###################################################################
#            Property  - UOM
###################################################################
$UOM
Case ACTION
   When "INIT"                    : Gosub UOM_INIT              : # Init method attached to UOM
   When "CONTROL"                 : Gosub UOM_CONTROL           : # Control method attached to UOM
   When "PROPAGATE"               : Gosub UOM_PROPAGATE         : # Propagate method attached to UOM
Endcase
Return
#---------------------
$UOM_INIT
  this.UOM = fmet this.ACTX.APARAM.AGETVALCHAR(1,this.ACTX.AFOLDER,"DEFUOM")
  Local Integer L_ERROR
  L_ERROR = fmet this.ACTX.APARAM.AGETVALERR
  If (L_ERROR) Then
    L_ERROR = fmet this.ASETERROR(CURPRO,"error on reading DEFUOM parametre - Code ="-num$(L_ERROR),[V]CST_AERROR)
  Endif
Return
#---------------------
$UOM_CONTROL
Return
#---------------------
$UOM_PROPAGATE
Return
#---------------------
$UOM_GET
Return

###################################################################
#            Property  - ENAFLG
###################################################################
$ENAFLG
Case ACTION
   When "INIT"                    : Gosub ENAFLG_INIT              : # Init method attached to ENAFLG
   When "CONTROL"                 : Gosub ENAFLG_CONTROL           : # Control method attached to ENAFLG
   When "PROPAGATE"               : Gosub ENAFLG_PROPAGATE         : # Propagate method attached to ENAFLG
Endcase
