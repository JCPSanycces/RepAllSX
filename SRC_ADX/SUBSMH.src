#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du fichier SCREMPH
#** V7 : Waiting Time Mangement **#
#*********************************#
Raz GPILOBJ
GACTION = "GESSMH"
Call OBJET("SMH",GBIDC1,GBIDC2) From GOBJET
End
#############################################################################
# MABOS - 22/01/14 - FQ92313 - US2312 - add table EMPLOJNT
#############################################################################

$ACTION
If GACTION="SMHEXP"
 Case ACTION
  When "INIT"      : Gosub INIT_EXP
  When "DEBUT"     : Gosub DEBUT_EXP
  When "EXEC"      : Gosub EXEC_EXP
 Endcase
Else
 Case ACTION
  When "OUVRE"     : Gosub OUVRE
  When "CREATION"  : Gosub CREATION
  When "MODIF"     : Gosub MODIF
  When "LIENS"     : Gosub LIENS
  When "APRES_CRE" : Gosub APRES_CRE
  When "APRES_MOD" : Gosub APRES_MOD
  When "SETBOUT"   : Gosub SETBOUT
  When "EXEBOUT"   : Gosub EXEBOUT
  When "FILTRE"    : Gosub FILTRE
  When "ANNULE"    : Gosub ANNULE
  When "VERIF_CRE" : Gosub VERIF
  When "VERIF_MOD" : Gosub VERIF
  When "AP_CHANGE"  : Gosub AP_CHANGE
  When "FERME"     : Gosub FERME
  When "AS_COD"      : Gosub AS_COD
  When "BS_COD"      : Gosub BS_COD
 Endcase
Endif
Return

$OUVRE
Local Integer ACCEPTE , NOL
Local Char    LIBEL (50)
Local Mask GENEMPEX [GEX]
Default Mask [SMH1]
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return


#Before selection on field COD
#############
$AS_COD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_COD
# To do nothing if the user doesn't select a record
If [F:HRSMH]COD<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:SMH1]LEG)>=0 : [M:SMH1]LEG=[F:HRSMH]LEG: Endif
 GCURLEG=[F:HRSMH]LEG
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:SMH1]LEG)>=0
  GCURLEG=[M:SMH1]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return

$LIENS
GCURLEG=[F:HRSMH]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]DES,"SCREMPH","DES",GCURLEG,[M]COD) From ATEXTRA

nolign = 0
For [HRSMD]SMD0 Where COD=[F:HRSMH]COD & LEG=[F:HRSMH]LEG
 nolign += 1
 [M] = [F:HRSMD]
 If [F:HRSMD]FLD = "FORMULE"
  [M]FLD(nolign-1) = toupper(mess(59,10709,1))
  Affzo [M]IND(nolign-1)
  Grizo [M]IND(nolign-1)
 Else
  Read [DIC]DIC0 = [F:HRSMD]FLD

  If func TRTEMP1.IS_EMP_CHILD_TABLE([F:DIC]TBL) = 0 and func TRTEMP1.EMP_FIELD_DIMENSION([F:DIC]TBL, [F:DIC]FLD) <= 1
   Affzo [M]IND(nolign-1)
   Grizo [M]IND(nolign-1)
  Endif
 Endif
Next
[M]NBRLIG = nolign
Return

$FILTRE
If GACTION="SELOBJW"
 If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif
 CRITERE = '1=1'
 For [HRSMH]SMH1(1) Where CODACT<>""
  Read [ACV]CODACT=[F:HRSMH]CODACT
  If fstat| [F:ACV]FLACT<>2
   CRITERE -= ' & CODACT<>"'+[F:HRSMH]CODACT+'"'
  Endif
 Next
Endif
Return

$FIN_SEL
If GACTION="SELOBJW"
 Filter [HRSMH]
Endif
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif

For nolign=1 To [M]NBRLIG
 Raz [F:HRSMD]
 [F:HRSMD] = [M]
 If [F:HRSMD]FLD = toupper(mess(59,10709,1))
  [F:HRSMD]FLD = "FORMULE"
 Endif
 [F:HRSMD]LIG = nolign
 [F:HRSMD]LEG = GCURLEG
 Write [HRSMD]
 If fstat
  GOK = 0 : Call FSTA("HRSMD") From GLOCK : Break
 Endif
Next nolign
Return

########################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("SCREMPH","DES",CLECUR1,"","SCREMPH","DES",GCURLEG,[F:HRSMH]COD)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DES,"SCREMPH","DES", GCURLEG,[F:HRSMH]COD) From ATEXTRA
Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
Call CHGTEXTRA("SCREMPH","DES",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Return

$SETBOUT
#78428 : Add 'or TUNNEL'
If !CLECUR or REP<>"" or !VERROU
 Call VIREBOUT(CHAINE,"12") From GOBJET
Elsif TUNNEL
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Return

$EXEBOUT
#Case REP
# BOUT it's better, REP is too old now ! :)
Case BOUT
 When "1"
  Call GENECR(nomap,GCURLEG,[F:HRSMH]COD) From SUBSMH2
Endcase
Return

$APRES_CRE
$APRES_MOD
Call GENECR(nomap,GCURLEG,[F:HRSMH]COD) From SUBSMH2
Return

$MODIF
Delete [HRSMD] Where COD=[F:HRSMH]COD & LEG=[F:HRSMH]LEG
If fstat=1
 GOK = -1 : GLOCK = "$SCREMPD" : Return
Endif
Gosub CREATION
Return

$VERIF
If [M]FLGMAT=2
 For I=0 To [M]NBRLIG-1
  If ([M]TYPFRM(I)>1 & [M]TYPFRM(I)<5) | find([M]TBL(I),"EMPLOCTR","EMPLOPOT","EMPLOCUM","EMPLOMED","EMPLOSAL")
   OK = 0
   # La zone "Uniquement champs salarié" ne peut pas être cochée. L'écran contient une formule/table qui fait appel au contrat.
   Call ERREUR(mess(83,10701,1))From GESECRAN
   Break
  Endif
 Next
Endif

#JASMI - 2016-03-04 - Req 114309 US8 - START
##MABOS-FQ92313-US2312-add table EMPLOJNT
##In EMPLOJNT, NUMLIG began at 2
#For I=0 To [M]NBRLIG-1
#  If find([M]TBL(I),"EMPLOJNT")
#    If [M]IND(I)<2
#      OK = 0
#      Call ERREUR([M]FLD(I)+":"-mess(178,10701,1)-"1")From GESECRAN
#      # Le numéro de ligne doit être supérieur à 1
#      Break
#    Endif
#  Endif
#Next
##end MABOS-FQ92313-US2312-add table EMPLOJNT
#MABOS-FQ92313-US2312-add table EMPLOJNT
If func AFNC.ACTIV("JNT")>0
  For I=0 To [M]NBRLIG-1
    If [M]TBL(I)="EMPLOJNT"
      If [M]IND(I)<2
        OK = 0
        Call ERREUR([M]FLD(I)+":"-mess(178,10701,1)-"1")From GESECRAN
        # Le numéro de ligne doit être supérieur à 1
        Break
      Endif
    Endif

    If instr(1,[M]FLD(I),"SITFAM")>0 | instr(1,[M]FLD(I),"JNT")>0
&     | instr(1,[M]FLD(I),"LNKPAR")>0
      If [M]OPT(I)<2
         Call MESSAGE(func AFNC.MES1(mess(179,10701,1), [M]FLD(I))) From GESECRAN
         # 'Le champ $1$ ne sera pas saisissable dans le contexte'
      Endif
    Endif
  Next
Else
  For I=0 To [M]NBRLIG-1
  If find([M]TBL(I),"EMPLOJNT") | find([M]FLD(I),"LNKPAR")
    OK = 0
    Call ERREUR(func AFNC.MES1(mess(180,10701,1), [M]FLD(I)))From GESECRAN
    # 'Le champ $1$ ne peut être utilisé dans le contexte'
    Break
  Endif
  Next
Endif
#End MABOS-FQ92313-US2312-ADD TABLE EMPLOJNT
#JASMI - 2016-03-04 - Req 114309 US8 - START
Return

$ANNULE
Call SUPTEXTRA("SCREMPH","DES",SUPP,[L]CODE) From ATEXTRA
# Annulation de l'écran et de la fenêtre
Local Char MASQUE(12)
Local Char NOMWIN(12)
MASQUE = "WMEM"+GCURLEG+[M:SMH1]COD
Call DELMSK(MASQUE,nomap) From MSKDIV
If GOK<1 : Return : Endif
NOMWIN = "WFEM"+GCURLEG+[M:SMH1]COD
Call DELWIN(NOMWIN,nomap) From MSKDIV
If GOK<1 : Return : Endif
Return


$INIT_EXP
Local Integer NUMLIG
NUMLIG = val(PARAM(1))
If toupper(VALEUR)=toupper(mess(59,10709,1)) : # Formule
 [M:GEX]EXPR   = [M:SMH1]FRM(NUMLIG-1)
 [M:GEX]TYP    = [M:SMH1]TYP(NUMLIG-1)
 [M:GEX]LNG    = [M:SMH1]LNG(NUMLIG-1)
 [M:GEX]NOLIB  = [M:SMH1]MNL(NUMLIG-1)
 [M:GEX]LIB    = [M:SMH1]TIT(NUMLIG-1)
 [M:GEX]TYPFRM = [M:SMH1]TYPFRM(NUMLIG-1)

 [M:GEX]PRDTYP = [M:SMH1]PRDTYP(NUMLIG-1)
 [M:GEX]PRDMTH = [M:SMH1]PRDMTH(NUMLIG-1)
 [M:GEX]PRDQTR = [M:SMH1]PRDQTR(NUMLIG-1)
 [M:GEX]PRDHLF = [M:SMH1]PRDHLF(NUMLIG-1)
 [M:GEX]PRDANN = [M:SMH1]PRDANN(NUMLIG-1)
 [M:GEX]PRDFRM = [M:SMH1]PRDFRM(NUMLIG-1)
 [M:GEX]PRDUTL = [M:SMH1]PRDUTL(NUMLIG-1)
 [M:GEX]RELDATFRM = [M:SMH1]RELDATFRM(NUMLIG-1)
 [M:GEX]RELDATUTL = [M:SMH1]RELDATUTL(NUMLIG-1)
 [M:GEX]TOTTYP    = [M:SMH1]TOTTYP(NUMLIG-1)
 [M:GEX]TOTTYPCOD = [M:SMH1]TOTTYPCOD(NUMLIG-1)
 [M:GEX]TOTTYPELM = [M:SMH1]TOTTYPELM(NUMLIG-1)
 #76200
 [M:GEX]FLGFRM    = [M:SMH1]FLGFRM(NUMLIG-1)

 If dim([M:GEX]TPS1)>0   : [M:GEX]TPS1   = [M:SMH1]TPS1(NUMLIG-1)   : Endif
 If dim([M:GEX]TPS2)>0   : [M:GEX]TPS2   = [M:SMH1]TPS2(NUMLIG-1)   : Endif
 If dim([M:GEX]TPS3)>0   : [M:GEX]TPS3   = [M:SMH1]TPS3(NUMLIG-1)   : Endif
 If dim([M:GEX]TYPTPS)>0 : [M:GEX]TYPTPS = [M:SMH1]TYPTPS(NUMLIG-1) : Endif
 If dim([M:GEX]TIMVAR)>0 : [M:GEX]TIMVAR = [M:SMH1]TIMVAR(NUMLIG-1) : Endif
Else
 FIN = 1 : Return
Endif
Return

$DEBUT_EXP
Affzo [GEX]
Return

$EXEC_EXP
If GSTATUT=GSTAOK
 [M:SMH1]FRM(NUMLIG-1)    = [M:GEX]EXPR
 [M:SMH1]TYP(NUMLIG-1)    = [M:GEX]TYP
 [M:SMH1]LNG(NUMLIG-1)    = [M:GEX]LNG
 [M:SMH1]MNL(NUMLIG-1)    = [M:GEX]NOLIB
 [M:SMH1]TIT(NUMLIG-1)    = [M:GEX]LIB
 [M:SMH1]TYPFRM(NUMLIG-1) = [M:GEX]TYPFRM

 [M:SMH1]PRDTYP(NUMLIG-1) = [M:GEX]PRDTYP
 [M:SMH1]PRDMTH(NUMLIG-1) = [M:GEX]PRDMTH
 [M:SMH1]PRDQTR(NUMLIG-1) = [M:GEX]PRDQTR
 [M:SMH1]PRDHLF(NUMLIG-1) = [M:GEX]PRDHLF
 [M:SMH1]PRDANN(NUMLIG-1) = [M:GEX]PRDANN
 [M:SMH1]PRDFRM(NUMLIG-1) = [M:GEX]PRDFRM
 [M:SMH1]PRDUTL(NUMLIG-1) = [M:GEX]PRDUTL
 [M:SMH1]RELDATFRM(NUMLIG-1) = [M:GEX]RELDATFRM
 [M:SMH1]RELDATUTL(NUMLIG-1) = [M:GEX]RELDATUTL
 [M:SMH1]TOTTYP(NUMLIG-1) = [M:GEX]TOTTYP
 [M:SMH1]TOTTYPCOD(NUMLIG-1) = [M:GEX]TOTTYPCOD
 [M:SMH1]TOTTYPELM(NUMLIG-1) = [M:GEX]TOTTYPELM
 #76200
 [M:SMH1]FLGFRM(NUMLIG-1)    = [M:GEX]FLGFRM

 If dim([M:GEX]TPS1)>0   : [M:SMH1]TPS1(NUMLIG-1)   = [M:GEX]TPS1   : Endif
 If dim([M:GEX]TPS2)>0   : [M:SMH1]TPS2(NUMLIG-1)   = [M:GEX]TPS2   : Endif
 If dim([M:GEX]TPS3)>0   : [M:SMH1]TPS3(NUMLIG-1)   = [M:GEX]TPS3   : Endif
 If dim([M:GEX]TYPTPS)>0 : [M:SMH1]TYPTPS(NUMLIG-1) = [M:GEX]TYPTPS : Endif
 If dim([M:GEX]TIMVAR)>0 : [M:SMH1]TIMVAR(NUMLIG-1) = [M:GEX]TIMVAR : Endif
 Affzo [SMH1]TIT(NUMLIG-1)
Endif
Return

########################################
$TRTCOP
If [M]DOSORG=nomap
 Local File SCREMPH [SMH1] , SCREMPD [SMD1]
Else
 Local File =[M]DOSORG+".SCREMPH" [SMH1] , =[M]DOSORG+".SCREMPD" [SMD1]
Endif
If [M]DOSDES=nomap
 Local File SCREMPH [SMH2] , SCREMPD [SMD2]
Else
 Local File =[M]DOSDES+".SCREMPH" [SMH2] , =[M]DOSDES+".SCREMPD" [SMD2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [SMH1], [SMH2], [SMD1], [SMD2]
Return

$TR_COP
GOK = 1
Trbegin [SMH2] , [SMD2]
 Delete [SMH2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".SCREMPH" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SMH2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [SMD2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".SCREMPD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SMD2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [SMD1] Where COD=TABLE
  [F:SMD2] = [F:SMD1]
  If dim([F:SMD2]UPDUSR)>0 : [F:SMD2]UPDUSR = GUSER : Endif
  If dim([F:SMD2]UPDDAT)>0 : [F:SMD2]UPDDAT = date$ : Endif
  If dim([F:SMD2]UPDTIM)>0 : [F:SMD2]UPDTIM = time : Endif
  Write [SMD2]
  If fstat
   GOK = 0 : Call FSTA("SMD2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [SMH1] Where COD=TABLE
  [F:SMH2] = [F:SMH1]
  If dim([F:SMH2]UPDUSR)>0 : [F:SMH2]UPDUSR = GUSER : Endif
  If dim([F:SMH2]UPDDAT)>0 : [F:SMH2]UPDDAT = date$ : Endif
  If dim([F:SMH2]UPDTIM)>0 : [F:SMH2]UPDTIM = time : Endif
  Write [SMH2]
  If fstat
   GOK = 0 : Call FSTA("SMH2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

Subprog GENDOS(APPLI)
Value Char APPLI()
If clalev([F:HRSMH])=0  : Local File =APPLI+".SCREMPH"    [HRSMH]  : Endif
Local Integer I
For I=1 To GNBLEG
 For [HRSMH]SMH0 Where LEG=GDOSLEG(I)
  If GTRACE<>"" : Call ECR_TRACE([F:HRSMH]LEG-[F:HRSMH]COD,0) From GESECRAN : Endif
  Call GENECR(APPLI,[F:HRSMH]LEG,[F:HRSMH]COD) From SUBSMH2
  If GOK=0 : Break 2: Endif
 Next
Next
End

##############################################################
Subprog PATCH(APPLI)
Value Char APPLI
#62332
If APPLI="PAIE" : End : Endif
#
If clalev([F:HRSMH])=0  : Local File =APPLI+".SCREMPH"    [HRSMH]  : Endif
For I=1 To GNBLEG
 For [HRSMH]SMH0 Where LEG=GDOSLEG(I)
  If GTRACE<>"" : Call ECR_TRACE([F:HRSMH]LEG-[F:HRSMH]COD,0) From GESECRAN : Endif
  Call GENECR(APPLI,[F:HRSMH]LEG,[F:HRSMH]COD) From SUBSMH2
  If GOK=0 : Break 2: Endif
 Next
Next
End


########################################
Subprog C_FLD(VALEUR)
Variable Char    VALEUR()

If toupper(VALEUR)<>toupper(mess(59,10709,1))
 Actzo [M]IND(nolign-1)
 Call VALIDATE_FIELD_AND_INDEX(VALEUR,[M]FLD,[M]IND)

 If !mkstat and nolign > 0
   If func TRTEMP1.IS_EMP_CHILD_TABLE([F:DIC]TBL) = 0
     Call VALIDATE_TABLE_FIELD_INDEX([M]TBL(nolign-1), VALEUR, [M]IND(nolign-1))
   Endif
 Endif

 If mkstat : End : Endif
 Read [DIC]DIC0 = VALEUR
#JASMI - 2016-03-04 - Req 114309 US8 - START
# If fstat
 If fstat | left$([F:DIC]TBL,5)<>"EMPLO"
#JASMI - 2016-03-04 - Req 114309 US8 - END
  GMESSAGE = mess(41,100,1)    : # Champ inexistant
  mkstat = 2
  End
 Elsif [F:DIC]ENAFLG=1
  GMESSAGE = mess(106,10702,1) : # Champ inactif
  mkstat = 2
  End
 Endif
 If VALEUR<>[M]FLD(nolign-1)
  Call TEXTE([F:DIC]DES,[M]TIT(nolign-1)) From OBJDIV
 Endif
 [M]TBL(nolign-1) = [F:DIC]TBL
 [M]FRM(nolign-1) = ""
 If func TRTEMP1.IS_EMP_CHILD_TABLE([F:DIC]TBL) = 0 and func TRTEMP1.EMP_FIELD_DIMENSION([F:DIC]TBL, [F:DIC]FLD) <= 1
   [M]IND(nolign-1) = 0
   Affzo [M]IND(nolign-1)
   Grizo [M]IND(nolign-1)
   Call UNICITE(VALEUR,[M]FLD) From OBJDIV
 Endif
Else
  [M]IND(nolign-1) = 0
  Affzo [M]IND(nolign-1)
  Grizo [M]IND(nolign-1)
Endif

#79017
[M]TITFLG(nolign-1) = 1
End

## Validate that the field entered has not already been used with the same index
Subprog VALIDATE_FIELD_AND_INDEX(VALEUR, TABLFLD, TABLIND)
Local Integer I, NOL
NOL = nolign-1
Local Char VALEUR_COPY(250): VALEUR_COPY = VALEUR
If (TABLIND(NOL) <> 0)
  For I = 0 To dim(TABLFLD) -1
    If I <> NOL and (TABLIND(I) = TABLIND(NOL)) and (TABLFLD(I) = VALEUR_COPY)
      GERR=1
      GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
      mkstat=2 : End
    Endif
  Next I
Endif
End

Subprog C_IND(VALEUR)
Variable Decimal VALEUR
If VALEUR < 0
  mkstat = 2
Else
  Call VALIDATE_INDEX_AND_FIELD(VALEUR,[M]FLD,[M]IND)
Endif

If !mkstat and nolign > 0
  If func TRTEMP1.IS_EMP_CHILD_TABLE([F:DIC]TBL) = 0
    Call VALIDATE_TABLE_FIELD_INDEX([M]TBL(nolign-1), [M]FLD(nolign-1), VALEUR)
  Endif
Endif
End

## Validate that the index entered has not already been used with the same field
Subprog VALIDATE_INDEX_AND_FIELD(VALEUR, TABLFLD, TABLIND)
Local Integer I, NOL
NOL = nolign-1
Local Decimal VALEUR_COPY: VALEUR_COPY = VALEUR

For I = 0 To dim(TABLFLD) -1
  If I <> NOL and (TABLFLD(I) = TABLFLD(NOL)) and (TABLIND(I) = VALEUR_COPY)
    GERR=1
    GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
    mkstat=2 : End
  Endif
Next I
End

## Validate that the index entered is not too high for the field
Subprog VALIDATE_TABLE_FIELD_INDEX(TABLENAME, FIELDNAME, INDEX)
Local Shortint MAX_DIMENSION
MAX_DIMENSION = func TRTEMP1.EMP_FIELD_DIMENSION(TABLENAME, FIELDNAME)
If INDEX > MAX_DIMENSION
  GERR=1
  GMESSAGE = mess(35, 199, 1)# Indice trop grand
  mkstat=2 : End
Endif
End

Subprog B2_FLD(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(mess(59,10709,1))
mkstat = 99
End

Subprog AS_OPT(VALEUR)
Variable Integer VALEUR
If toupper([M]FLD(nolign-1))=toupper(mess(59,10709,1))
 GMENLOC(1) = 1
Endif
End

########################################
## Ecran GENEMPEX
########################################
Subprog C_NBRLIG
End

Subprog AV_INIT(VALEUR)
Variable Char    VALEUR()
Call C_TYPFRM([M]TYPFRM)
Call C_PRDTYP([M]PRDTYP)
Call C_TOTTYP([M]TOTTYP)
End

Subprog C_TYPFRM(VALEUR)
Variable Integer VALEUR
Raz [M]TBL
If GPAYE=0 & VALEUR=2
 GMESSAGE = mess(2,14,1)-":"-mess(58,125,1)  : # Paye : Module non implanté dans le dossier
 mkstat   = 2 : End
Endif

#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If GTPS=0 &  VALEUR=4
#** GMESSAGE = mess(0,10709,1)-":"-mess(58,125,1) : # Temps : Module non implanté dans le dossier
#** mkstat   = 2 : End
#**Endif
#*!
If GTPS=0 &  VALEUR=4
 GMESSAGE = mess(0,10709,1)-":"-mess(58,125,1) : # Temps : Module non implanté dans le dossier
 mkstat   = 2 : End
Endif
#LIPET - 2017-05-20 - END

Case VALEUR
 When 1 #Salarié
  Actzo EXPR,TYP,LNG,NOLIB
  If dim([M:GEX]TPS1)>0   : Effzo TPS1   : Endif
  If dim([M:GEX]TPS2)>0   : Effzo TPS2   : Endif
  If dim([M:GEX]TPS3)>0   : Effzo TPS3   : Endif
  If dim([M:GEX]TYPTPS)>0 : Effzo TYPTPS : Endif
  If dim([M:GEX]TIMVAR)>0 : Effzo TIMVAR : Endif
  If dim([M:GEX]TPS1)>0   : Grizo TPS1   : Endif
  If dim([M:GEX]TPS2)>0   : Grizo TPS2   : Endif
  If dim([M:GEX]TPS3)>0   : Grizo TPS3   : Endif
  If dim([M:GEX]TYPTPS)>0 : Grizo TYPTPS : Endif
  If dim([M:GEX]TIMVAR)>0 : Grizo TIMVAR : Endif
  Effzo TOTTYP, TOTTYPCOD, TOTTYPELM, FLGFRM  #76200
  Grizo TOTTYP, TOTTYPCOD, TOTTYPELM, FLGFRM  #76200
  Effzo PRDTYP, PRDMTH, PRDQTR, PRDHLF, PRDANN, PRDUTL, PRDFRM, RELDATFRM, RELDATUTL
  Grizo PRDTYP, PRDMTH, PRDQTR, PRDHLF, PRDANN, PRDUTL, PRDFRM, RELDATFRM, RELDATUTL
  [M]TBL(0) = "EMPLOID"
  [M]TBL(1) = "EMPLOAD"
  [M]TBL(2) = "EMPLOCTR"
 When 2 #Historique de paie
  Actzo LNG,FLGFRM  #76200
  If [M:GEX]FLGFRM=2  #76200
   Actzo EXPR
   Effzo TOTTYP, TOTTYPCOD, TOTTYPELM
   Grizo TOTTYP, TOTTYPCOD, TOTTYPELM
  Else
   Grizo EXPR
   Actzo TOTTYP, TOTTYPCOD, TOTTYPELM
   Call C_TOTTYP([M]TOTTYP)
  Endif
  Effzo NOLIB
  If dim([M:GEX]TPS1)>0   : Effzo TPS1   : Endif
  If dim([M:GEX]TPS2)>0   : Effzo TPS2   : Endif
  If dim([M:GEX]TPS3)>0   : Effzo TPS3   : Endif
  If dim([M:GEX]TYPTPS)>0 : Effzo TYPTPS : Endif
  If dim([M:GEX]TIMVAR)>0 : Effzo TIMVAR : Endif
  Grizo NOLIB
  If dim([M:GEX]TPS1)>0   : Grizo TPS1   : Endif
  If dim([M:GEX]TPS2)>0   : Grizo TPS2   : Endif
  If dim([M:GEX]TPS3)>0   : Grizo TPS3   : Endif
  If dim([M:GEX]TYPTPS)>0 : Grizo TYPTPS : Endif
  If dim([M:GEX]TIMVAR)>0 : Grizo TIMVAR : Endif
  Actzo PRDTYP, PRDMTH, PRDQTR, PRDHLF, PRDANN, PRDUTL, PRDFRM, RELDATFRM, RELDATUTL
  Call C_PRDTYP([M]PRDTYP)
  [M]TBL(0) = "[P]RUB"
  [M]TBL(1) = "[P]VAR"
  [M]TBL(2) = "[P]CUM"
 When 3 #Historique des temps
  If dim([M:GEX]TPS1)>0   : Actzo TPS1   : Endif
  If dim([M:GEX]TPS2)>0   : Actzo TPS2   : Endif
  If dim([M:GEX]TPS3)>0   : Actzo TPS3   : Endif
  If dim([M:GEX]TYPTPS)>0 : Actzo TYPTPS : Endif
  Effzo TYP,LNG,NOLIB,EXPR
  Grizo TYP,LNG,NOLIB,EXPR
  Effzo TOTTYP, TOTTYPCOD, TOTTYPELM, FLGFRM  #76200
  Grizo TOTTYP, TOTTYPCOD, TOTTYPELM, FLGFRM  #76200
  Actzo PRDTYP, PRDMTH, PRDQTR, PRDHLF, PRDANN, PRDUTL, PRDFRM, RELDATFRM, RELDATUTL
  Call C_PRDTYP([M]PRDTYP)
  If dim([M:GEX]TIMVAR)>0 : Effzo TIMVAR : Grizo TIMVAR : Endif
 When 4 #Synthèse des temps
  If dim([M:GEX]TIMVAR)>0 : Actzo TIMVAR : Endif
  Effzo EXPR,TYP,LNG,NOLIB
  If dim([M:GEX]TPS1)>0   : Effzo TPS1   : Endif
  If dim([M:GEX]TPS2)>0   : Effzo TPS2   : Endif
  If dim([M:GEX]TPS3)>0   : Effzo TPS3   : Endif
  If dim([M:GEX]TYPTPS)>0 : Effzo TYPTPS : Endif
  Grizo EXPR,TYP,LNG,NOLIB
  Effzo TOTTYP, TOTTYPCOD, TOTTYPELM, FLGFRM  #76200
  Grizo TOTTYP, TOTTYPCOD, TOTTYPELM, FLGFRM  #76200
  Actzo PRDTYP, PRDMTH, PRDQTR, PRDHLF, PRDANN, PRDUTL, PRDFRM, RELDATFRM, RELDATUTL
  Call C_PRDTYP([M]PRDTYP)
  If dim([M:GEX]TPS1)>0   : Grizo TPS1   : Endif
  If dim([M:GEX]TPS2)>0   : Grizo TPS2   : Endif
  If dim([M:GEX]TPS3)>0   : Grizo TPS3   : Endif
  If dim([M:GEX]TYPTPS)>0 : Grizo TYPTPS : Endif
 When 5 #Calcul
  Actzo EXPR,TYP,LNG
  Effzo NOLIB
  If dim([M:GEX]TPS1)>0   : Effzo TPS1   : Endif
  If dim([M:GEX]TPS2)>0   : Effzo TPS2   : Endif
  If dim([M:GEX]TPS3)>0   : Effzo TPS3   : Endif
  If dim([M:GEX]TYPTPS)>0 : Effzo TYPTPS : Endif
  If dim([M:GEX]TIMVAR)>0 : Effzo TIMVAR : Endif
  Grizo NOLIB
  Effzo TOTTYP, TOTTYPCOD, TOTTYPELM, FLGFRM #76200
  Grizo TOTTYP, TOTTYPCOD, TOTTYPELM, FLGFRM #76200
  Effzo PRDTYP, PRDMTH, PRDQTR, PRDHLF, PRDANN, PRDUTL, PRDFRM, RELDATFRM, RELDATUTL
  Grizo PRDTYP, PRDMTH, PRDQTR, PRDHLF, PRDANN, PRDUTL, PRDFRM, RELDATFRM, RELDATUTL
  If dim([M:GEX]TPS1)>0   : Grizo TPS1   : Endif
  If dim([M:GEX]TPS2)>0   : Grizo TPS2   : Endif
  If dim([M:GEX]TPS3)>0   : Grizo TPS3   : Endif
  If dim([M:GEX]TYPTPS)>0 : Grizo TYPTPS : Endif
  If dim([M:GEX]TIMVAR)>0 : Grizo TIMVAR : Endif
Endcase
End

Subprog AS_TYP(VALEUR)
Variable Char    VALEUR()
If [M]TYPFRM>2 & [M]TYPFRM<5 : mkstat = 2 : End : Endif
If [M]TYPFRM=2 : VALEUR="DCB" : mkstat = 2 : End : Endif
If VALEUR="" : VALEUR = "A" : Endif
End

Subprog AS_LNG(VALEUR)
Variable Decimal VALEUR
If [M]TYPFRM>2 & [M]TYPFRM<5 : mkstat = 2 : End : Endif
Call LECTURE("ATY",[M]TYP,"") From CONTOBJ
If [F:ATY]TYPTYP=8
 mkstat = 1 : End
Elsif [F:ATY]LNGTYP<>0
 VALEUR = [F:ATY]LNGTYP
 mkstat = 2 : End
Endif
If VALEUR=0
 Case [F:ATY]TYPTYP
  When 1       : VALEUR = 15
  When 2       : VALEUR = 4
  When 3       : VALEUR = 8
  When 7       : VALEUR = 30
  When Default : VALEUR = 9.2
 Endcase
Endif
End

Subprog C_LNG(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]TYP,"") From CONTOBJ
Local Integer OK
OK = 1
Case [F:ATY]TYPTYP
 When 1,7
  VALEUR = int(VALEUR)
  If VALEUR>250 : OK = 0 : Endif
 When 2
  VALEUR = int(VALEUR)
  If VALEUR>5 : OK = 0 : Endif
 When 3
  VALEUR = int(VALEUR)
  If VALEUR>8 : OK = 0 : Endif
 When Default
  If VALEUR>20 : OK = 0 : Endif
Endcase
If !OK
 GMESSAGE = mess(111,123,1) : # Longueur incorrecte
 mkstat = 2 : End
Endif
End

Subprog AS_NOLIB(VALEUR)
Variable Decimal VALEUR
If [M]TYPFRM>1 : mkstat = 2 : End : Endif
Call LECTURE("ATY",[M]TYP,"") From CONTOBJ
If [F:ATY]TYPTYP<>1
 mkstat = 1 : End
Elsif [F:ATY]NOLIB<>0
 VALEUR = [F:ATY]NOLIB
 mkstat = 2 : End
Endif
End

Subprog C_NOLIB(VALEUR)
Variable Decimal VALEUR
If VALEUR>=100 & VALEUR<=200
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Endif
End

Subprog IB_EXPR
Case [M]TYPFRM
 When 1
  Raz GBOUT2,GBOUT3,GBOUT4
 When 5
  Raz GBOUT2,GBOUT3,GBOUT4,GBOUT5
Endcase
End

Subprog C_EXPR(VALEUR)
Variable Char    VALEUR()
If [M]TYPFRM=2
 Call CONTFRM(VALEUR) From SUBRUB
Endif
End

Subprog C_TPS1(VALEUR)
Variable Char    VALEUR()
Goto C_TPS
End

Subprog C_TPS2(VALEUR)
Variable Char    VALEUR()
Goto C_TPS
End

Subprog AS_TPS3(VALEUR)
Variable Char    VALEUR()
If [M]TPS2="" : mkstat = 1 : End : Endif
End

Subprog C_TPS3(VALEUR)
Variable Char    VALEUR()
Goto C_TPS
End

$C_TPS
VALEUR = toupper(VALEUR)
If VALEUR<>""
 If !instr(1,VALEUR,"?") & !instr(1,VALEUR,"*")
  Call CONTROLE("TIM","",VALEUR,"",mkstat) From CONTOBJ
 Endif
Endif
End

Subprog C_TIMVAR(VALEUR)
Variable Char    VALEUR()
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
Read [ATZ]CODZONE = "TIMRECAP";VALEUR
If fstat or [F:ATZ]CODTYP<>"CDY"
 GMESSAGE = mess(24,10709,1) : # Variable non définie dans TIMRECAP
 mkstat = 2 : End
Endif
End

########################################
Subprog APRES_NBRLIG
Local Integer I , J , K , L , NOL
NOL = nolign-1
If find(status,65,68,83)
 For I=0 To [M]NBRLIG-1
  L = 0
  If [M]TYPFRM(I)=5
   For J=NOL+1 To 99
    K = 0
    Repeat
     K = instr(K+1,[M]FRM(I),"F"+format$("N0:2#",J))
     If K
      [M]FRM(I) = left$([M]FRM(I),K-1)+"F"+format$("N0:2#",J-1)+right$([M]FRM(I),K+3)
      L = 1
     Endif
    Until K=0
   Next J
  Endif
  If L
   Affzo FRM(I)
  Endif
 Next I
Elsif [M]STA(NOL)=73
 For I=0 To [M]NBRLIG-1
  L = 0
  If [M]TYPFRM(I)=5
   For J=99 To NOL+1 Step -1
    K = 0
    Repeat
     K = instr(K+1,[M]FRM(I),"F"+format$("N0:2#",J))
     If K
      [M]FRM(I) = left$([M]FRM(I),K-1)+"F"+format$("N0:2#",J+1)+right$([M]FRM(I),K+3)
      L = 1
     Endif
    Until K=0
   Next J
  Endif
  If L
   Affzo FRM(I)
  Endif
 Next I
Endif
[M]STA(NOL) = 0
End

Subprog AVANT_NBRLIG
[M]STA(nolign-1) = status
End

########################################
Subprog AS_TYPTPS(VALEUR)
Variable Integer  VALEUR
GMENLOC(5)=1 #Remove extension
End

#make the correct controls available based on the period type chosen
Subprog C_PRDTYP(VALEUR)
Variable Integer VALEUR
Case VALEUR
  When 1, 2 #De la période, Paie en cours
   Effzo PRDMTH, PRDQTR, PRDHLF, PRDANN, PRDFRM, PRDUTL, RELDATFRM, RELDATUTL
   Grizo PRDMTH, PRDQTR, PRDHLF, PRDANN, PRDFRM, PRDUTL, RELDATFRM, RELDATUTL
 When 3 #Mensuelle
   Effzo PRDQTR, PRDHLF, PRDFRM, PRDUTL, RELDATFRM, RELDATUTL
   Grizo PRDQTR, PRDHLF, PRDFRM, PRDUTL, RELDATFRM, RELDATUTL
   Actzo PRDMTH, PRDANN
 When 4 #Trimestrielle
  Effzo PRDMTH, PRDHLF, PRDFRM, PRDUTL, RELDATFRM, RELDATUTL
  Grizo PRDMTH, PRDHLF, PRDFRM, PRDUTL, RELDATFRM, RELDATUTL
  Actzo PRDQTR, PRDANN
 When 5 #Semestrielle
  Effzo PRDMTH, PRDQTR, PRDFRM, PRDUTL, RELDATFRM, RELDATUTL
  Grizo PRDMTH, PRDQTR, PRDFRM, PRDUTL, RELDATFRM, RELDATUTL
  Actzo PRDHLF, PRDANN
 When 6 #Annuelle
  Effzo PRDMTH, PRDQTR, PRDHLF, PRDFRM, PRDUTL, RELDATFRM, RELDATUTL
  Grizo PRDMTH, PRDQTR, PRDHLF, PRDFRM, PRDUTL, RELDATFRM, RELDATUTL
  Actzo PRDANN
 When 7 #Date à Date
  Effzo PRDMTH, PRDQTR, PRDHLF, PRDANN
  Grizo PRDMTH, PRDQTR, PRDHLF, PRDANN
  Actzo PRDFRM, PRDUTL, RELDATFRM, RELDATUTL
 When Default
Endcase
End

Subprog AS_TOTTYP(VALEUR)
Variable Integer VALEUR
# Only want heading, cumul and variable
GMENLOC(2)=1
GMENLOC(3)=1
GMENLOC(4)=1
GMENLOC(5)=1
#Hide all tax band here
For I=8 To len(mess(0,10344,1))
 GMENLOC(I)=1
Next
End

Subprog AS_TOTTYPELM(VALEUR)
Variable Integer VALEUR
# Only want Employee, Employer, Band A to C, Base, Employer Rate, Employee Rate
GMENLOC(6) = 1
GMENLOC(7) = 1
GMENLOC(8) = 1
GMENLOC(9) = 1
#Display Tax band (D to I) what you need
For I=func AFNC.ACTIV("TXB")+10 To len(mess(0,10355,1))
 GMENLOC(I)=1
Next
End

#Element should only be available for Rubrique
Subprog C_TOTTYP(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 #Rubrique
 Actzo TOTTYPELM
Else
 Effzo TOTTYPELM
 Grizo TOTTYPELM
Endif
End

#Check that the Rubrique, Variable or Cumul selected is valid, then populate EXPR
Subprog C_TOTTYPCOD(VALEUR)
Variable Char    VALEUR()
Local Char TOTEST(250)

Case [M]TOTTYP
 When 7
   TOTEST = "V_"
   Call CONTROLE("VRA","",VALEUR,GCURLEG,mkstat) From CONTOBJ
 When 6
   TOTEST = "C_"
   Call CONTROLE("CUM","",VALEUR,GCURLEG,mkstat) From CONTOBJ
   If mkstat <> 2
     Read [F:CUM]CUM0=GCURLEG;VALEUR
     If [F:CUM]CUMTMP=2
       GMESSAGE = mess(48,10703,1) : # Cumul intermédiaire
       mkstat = 2 : End
     Endif
   Endif
 When 1
   TOTEST = "R_"
   Call CONTROLE("RUB","",VALEUR,GCURLEG,mkstat) From CONTOBJ
Endcase
TOTEST += VALEUR

If mkstat <> 2
  Call POPULATE_EXPR([M]TOTTYP, VALEUR, [M]TOTTYPELM)
Endif
End

#when changing the element of a rubrique update EXPR
Subprog C_TOTTYPELM(VALEUR)
Variable Integer VALEUR

Case VALEUR
  When 1,2,3,4,5,13,14,15,16,17,18 #Employee Amount, Employer Amount, Band A, B, C....H
    Read [F:RUB]RUB0=GCURLEG;[M]TOTTYPCOD
    If [F:RUB]TMPCAL=2
      GMESSAGE = mess(213,10703,1) : # Rubrique intermédiaire
      mkstat = 2 : End
    Endif
  When 11, 12 #Employee Rate, Employer Rate
    Read [F:RUB]RUB0=GCURLEG;[M]TOTTYPCOD
    #Cotisation et Régularisation et Montant=Base*taux (/100)
    If [F:RUB]TYPRUB<>6 & [F:RUB]TYPRUB<>9 & [F:RUB]TYPRUB<>2 & [F:RUB]TYPRUB<>3
      GMESSAGE = mess(47,10703,1) : # Ce n'est pas une cotisation
      mkstat = 2 : End
    Endif
Endcase

Call POPULATE_EXPR([M]TOTTYP, [M]TOTTYPCOD, VALEUR)
End

#Helper to populate EXPR then validate it
Subprog POPULATE_EXPR(TOTTYP, TOTTYPCOD, TOTTYPELM)
Variable Integer TOTTYP
Variable Char TOTTYPCOD()
Variable Integer TOTTYPELM

Local Char PRE(10)
Local Char MID(200)
Local Char SUF(10)

Case TOTTYP
 When 7 : PRE = "V_" #Variable
 When 6 : PRE = "C_" #Cumulator
 When 1 : PRE = "R_" #Heading
Endcase

#Tax band
If TOTTYP = 1 #Heading
 Case TOTTYPELM
  When 3  : PRE = "TA_" #Heading Band A
  When 4  : PRE = "TB_" #Heading Band B
  When 5  : PRE = "TC_" #Heading Band C
  When 13 : PRE = "TD_" #Heading Band D
  When 14 : PRE = "TE_" #Heading Band E
  When 15 : PRE = "TF_" #Heading Band F
  When 16 : PRE = "TG_" #Heading Band G
  When 17 : PRE = "TH_" #Heading Band H
  When 18 : PRE = "TI_" #Heading Band I
 Endcase
Endif

MID = TOTTYPCOD

If TOTTYP = 1
 Case TOTTYPELM
  When 1 : SUF = "(1)" #Employee Amount
  When 11 : SUF = "(3)" # Employee Rate
  When 2 : SUF = "(2)" #Employer Amount
  When 12 : SUF = "(4)" # Employer Rate
  When 10 : SUF = "(0)" # Base
 Endcase
Endif

[M]EXPR = PRE + MID + SUF
Affzo [M]EXPR

Call C_EXPR([M]EXPR)

End


######################################################################################
## Etiquette ajoutée par le superviseur (écran GENEMPEX) 28/07/2011 11:45:09 (DLE)
######################################################################################
Subprog S_TOTTYPCOD(VALEUR)
Variable Char    VALEUR()

Local Char    PARMSK(250)(1..20) , SAVACT(20)

# Decide which lookup to display
Case [M]TOTTYP
  When 1
    # lookup headings
    If !GWEBSERV
      ## Action EXPRUB
      SAVACT = GACTION : GACTION = "EXPRUB"
      PARMSK(1) = GCURLEG
      Call S_TAB_CHAR(VALEUR,PARMSK,"EXPRUB","SELPLAN","") From GACTION
      GACTION = SAVACT
    Endif
    If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
    Gosub AFF From GSAISIE
  When 6
    # lookup accumulators
    If !GWEBSERV
      ## Action EXPCUM
      SAVACT = GACTION : GACTION = "EXPCUM"
      PARMSK(1) = GCURLEG
      Call S_TAB_CHAR(VALEUR,PARMSK,"EXPCUM","SELPLAN","") From GACTION
      GACTION = SAVACT
    Endif
    If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
    Gosub AFF From GSAISIE
  When 7
    # lookup variables
    If !GWEBSERV
      ## Action EXPVRA
      SAVACT = GACTION : GACTION = "EXPVRA"
      PARMSK(1) = GCURLEG
      Call S_TAB_CHAR(VALEUR,PARMSK,"EXPVRA","SELPLAN","") From GACTION
      GACTION = SAVACT
    Endif
    If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
    Gosub AFF From GSAISIE
Endcase

End

Subprog IB_TBL
End

Subprog IB_RELDATFRM
End

#76200
Subprog AM_FLGFRM(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M:GEX]TOTTYP,TOTTYPCOD,TOTTYPELM
 Grizo [M:GEX]TOTTYP,TOTTYPCOD,TOTTYPELM
 Actzo [M:GEX]EXPR
Else
 Actzo [M:GEX]TOTTYP,TOTTYPCOD,TOTTYPELM
 Grizo [M:GEX]EXPR
Endif
End

######################################################################################
## Section automatically added (screen SMH1) 09/01/2012 17:46:07 (OLY)
######################################################################################
Subprog AM_TIT(VALEUR)
Variable Char    VALEUR()

#79017
[M]TITFLG(nolign-1) = 2
End
######################################################################################
## Section automatically added (screen SMH1) 26/06/2012 10:10:08 (ADW)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

Local Shortint ERR_CHECK
GCURLEG = VALEUR

For I= [M]NBRLIG-1 To 0 Step -1
  If [M]FLD(I)=toupper(mess(59,10709,1)) & ([M]TYPFRM(I) = 2 | [M]TYPFRM(I) = 5 | [M]FLGFRM(I) = 2)
    ERR_CHECK=0
    Case [M]TOTTYP(I)
      When 7
        Call CONTROLE("VRA","",[M]TOTTYPCOD(I),GCURLEG,ERR_CHECK) From CONTOBJ
      When 6
        Call CONTROLE("CUM","",[M]TOTTYPCOD(I),GCURLEG,ERR_CHECK) From CONTOBJ    :#test reverse order in the index
      When 1
        Call CONTROLE("RUB","",GCURLEG,[M]TOTTYPCOD(I),ERR_CHECK) From CONTOBJ
    Endcase
    If ERR_CHECK > 0 | [M]TYPFRM(I) = 5 | [M]FLGFRM(I) = 2
      #Delete the line as it's not valid
      Dela I,1 [M]NBRLIG
      [M]NBRLIG-=1
      Affzo [M]NBRLIG,FLD,TIT,IND,OPT,FRM
    Endif
  Endif
Next

End


