#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque USAPRDSEA 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:07:00"
A_USER  = "DOC"
A_STAMP = "20181109230700"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask USAPRDSEA [UPS]
Gosub HORODAT
Local Inpbox "USAPRDSEA" From GFONCTION At A_STAMP With A_WINDPREV Mask [UPS] As [SIM_]
Grizo [UPS]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [UPS]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=32 : X2(0)=80 : Y1(0)=12 : Y2(0)=16
Return

$ON_SLDFLG
Onevent INIT_AREA Call D_SLDFLG(zc) From W1USAPRDSEA
Onevent BEFORE_INPUT Call AS_SLDFLG(zc) From W1USAPRDSEA
Onevent CONTROL Call C_SLDFLG(zc) From W1USAPRDSEA
Return

Subprog D_SLDFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]SLDFLG,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_SLDFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_SLDFLG(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SLDFLG" : GZNUM = 20387 : Endif
Gosub _AFF
End

$CHG_STY
Return


