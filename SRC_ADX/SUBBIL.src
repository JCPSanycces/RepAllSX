#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
GACTION = "SAIBIL"
Close Local Mask
Call SAISIE_CHAR(VALEUR,PARAM,"FBIL","SUBBIL","") From GSAISIE
End

$ACTION
Case GACTION
 When "BILPRP"
  Case ACTION 
   When "DEBUT"       : Gosub PROPRIETES
  Endcase
 When Default
  Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "OUVRE_BOITE" : Gosub OUVRE_BOITE
   When "DEBUT"       : Gosub DEBUT
   When "SETBOUT"     : Gosub SETBOUT
   When "APRES_MODIF" : Gosub APRES_MODIF
   When "ENR"         : Gosub ENREGISTRE
   When "ABA"         : Gosub ABANDON
   When "FIR"         : Gosub PREMIER
   When "LAS"         : Gosub DERNIER
   When "SUI"         : Gosub SUIVANT
   When "PRE"         : Gosub PRECEDENT
   When "GAU"         : Gosub GAUCHE
   When "SUP"         : Gosub ANNULE
   When "FIN"         : Gosub FIN
   When "BOUTON"      : Gosub BOUTON
  Endcase
Endcase
Return

$OUVRE
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:BIN])=0 : Local File BILIND   [BIN] : Endif
If clalev([F:BIL])=0 : Local File BILRES   [BIL] : Endif
If clalev([F:BIX])=0 : Local File BILTXT   [BIX] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
###46095
If clalev([F:ADV])=0 : Local File ATABTAB  [ADV] : Endif
###
If clalev([F:ADW])=0 : Local File ADOVAL   [ADW] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif
Local Integer MAXCAT : MAXCAT = 20 : # Maximum de catégories
Local Integer MODIF , CLECUR , FL0 , FLBOX
Local Integer TYP , I , LONG , VERROU , WOK , SECTEUR
Local Char    FMT(30) , VALPAR(10) , STYLE(GLONASY)
Local Char    SYMBOLE(50)
Local Decimal SOMME , TOTGEN
Local Decimal TBVAL(1..MAXCAT,1..MAXCAT)
Local Integer FLCRE , FLMOD , WTIM
Local Date    WDAT
Local Char    WUSR(GLONAUS)
Return

$OUVRE_BOITE
Call PARAM(GDEFSOC,"BILSEC",VALPAR) From ADOVAL
SECTEUR = val(VALPAR)
If SECTEUR<1 or SECTEUR>len(mess(0,10503,1)) : SECTEUR = 1 : Endif
FLBOX = 0
Gosub FILGAUCHE
Return

$FILGAUCHE
If FLBOX=0
 FILGAUSUP = "CPYFLG=2"
Else
 FILGAUSUP = "FCYFLG=2"
Endif
FILGAUSUP -= "& SEC("+num$(SECTEUR-1)+")=2"
Return

$DEBUT
Raz [M]
MODIF  = 0
CLECUR = 0
[M]CPY = GDEFSOC
[M]SEC = SECTEUR
[M]EXE = num$(year(date$)-1)
Affzo CPY,ZCPY,SEC,EXE
For I=1 To len(mess(0,10504,1))
 [M]LIBCOL(I-1) = mess(I,10504,1)
Next I
Affzo 25
Return

$APRES_MODIF
Case COUZON
 When "EXE"
  If MODIF : Gosub ABORT : If WOK<>2 : Return : Endif : Endif
  [M]EXE = CZ : Gosub LIRE
 When "CPY"
  If MODIF : Gosub ABORT : If WOK<>2 : Return : Endif : Endif
  Call PARAM(CZ,"BILSEC",VALPAR) From ADOVAL
  SECTEUR = val(VALPAR)
  If SECTEUR<1 or SECTEUR>len(mess(0,10503,1)) : SECTEUR = 1 : Endif
  If [M]COD<>""
   Call VERF_COD([M]COD,[M]FCY,SECTEUR)
   If GERR : Return : Endif
  Endif
  [M]SEC = SECTEUR
  [M]FCY = ""
  Affzo FCY,SEC
  FLBOX = 0
  Gosub FILGAUCHE
  Gosub REMPLIT_1 From WGFBIL
  Call LECTURE("BIN",[M]COD,"") From CONTOBJ
  [M]CPY = CZ : Gosub LIRE
 When "FCY"
  If MODIF : Gosub ABORT : If WOK<>2 : Return : Endif : Endif
  If [M]COD<>""
   Call VERF_COD([M]COD,CZ,SECTEUR)
   If GERR : Return : Endif
  Endif
  If CZ="" & FLBOX=1
   FLBOX = 0
   Gosub FILGAUCHE
   Gosub REMPLIT_1 From WGFBIL
  Elsif CZ<>"" & FLBOX=0
   FLBOX = 1
   Gosub FILGAUCHE
   Gosub REMPLIT_1 From WGFBIL
  Endif
  Call LECTURE("BIN",[M]COD,"") From CONTOBJ
  [M]FCY = CZ
  Gosub LIRE
 When "COD"
  If MODIF : Gosub ABORT : If WOK<>2 : Return : Endif : Endif
  Call VERF_COD(CZ,[M]FCY,SECTEUR)
  If GERR : Return : Endif
  [M]COD = CZ
  Gosub CHANGE_COD
 When Default
  If MODIF=0 & VERROU
   MODIF = 1
  Endif
Endcase
Return

Subprog VERF_COD(CODE,SITE,SECTEUR)
Value Char    CODE
Value Char    SITE
Value Integer SECTEUR
GERR = 0
Call LECTURE("BIN",CODE,"") From CONTOBJ
If SITE=""
 If [F:BIN]CPYFLG<>2
  GMESSAGE = mess(9,10716,1) : # Indicateur non saisi au niveau société
  GERR = 1 : End
 Endif
Else
 If [F:BIN]FCYFLG<>2
  GMESSAGE = mess(10,10716,1) : # Indicateur non saisi au niveau site
  GERR = 1 : End
 Endif
Endif
If [F:BIN]SEC(SECTEUR-1)<>2
 GMESSAGE = mess(18,10716,1)-mess(SECTEUR,10503,1) : # Indicateur non défini pour le secteur
 GERR = 1 : End
Endif
End

$CHANGE_COD
TYP = [F:BIN]LIG : LONG = 1 : Gosub TEXTES
If [F:BIN]TOTLIG=2
 NBTEX += 1 : TEXTE(NBTEX) = mess(14,10716,1) : # Total
 [M]EXCL(NBTEX-1) = "X"
Endif
[M]NBLIG = NBTEX
For I=1 To [M]NBLIG
 [M]INTIT(I-1) = TEXTE(I)
Next I
[M]LIBCOD(0) = [F:BIN]DESLNG(0)
[M]LIBCOD(1) = [F:BIN]DESLNG(1)
TYP = [F:BIN]COL : LONG = 0 : Gosub TEXTES
[M]NBCOL = NBTEX
If [F:BIN]DEC=0
 FMT = "N3z:9#"
Else
 FMT = "N3z:9."+num$([F:BIN]DEC)
Endif
If [F:BIN]TOTCOL=2
 Chgfmt [M]VALTOT With FMT
Else
 Chgfmt [M]VALTOT With "-N3:9.2"
Endif
Raz [M]LIBCOL
For I=1 To NBTEX
 [M]LIBCOL(I-1) = TEXTE(I)
 Case I
  When  1 : Chgfmt [M]VAL01 With FMT
  When  2 : Chgfmt [M]VAL02 With FMT
  When  3 : Chgfmt [M]VAL03 With FMT
  When  4 : Chgfmt [M]VAL04 With FMT
  When  5 : Chgfmt [M]VAL05 With FMT
  When  6 : Chgfmt [M]VAL06 With FMT
  When  7 : Chgfmt [M]VAL07 With FMT
  When  8 : Chgfmt [M]VAL08 With FMT
  When  9 : Chgfmt [M]VAL09 With FMT
  When 10 : Chgfmt [M]VAL10 With FMT
  When 11 : Chgfmt [M]VAL11 With FMT
  When 12 : Chgfmt [M]VAL12 With FMT
  When 13 : Chgfmt [M]VAL13 With FMT
  When 14 : Chgfmt [M]VAL14 With FMT
  When 15 : Chgfmt [M]VAL15 With FMT
  When 16 : Chgfmt [M]VAL16 With FMT
  When 17 : Chgfmt [M]VAL17 With FMT
  When 18 : Chgfmt [M]VAL18 With FMT
  When 19 : Chgfmt [M]VAL19 With FMT
  When 20 : Chgfmt [M]VAL20 With FMT
 Endcase
Next I
For I=NBTEX+1 To 20
 Case I
  When  1 : Chgfmt [M]VAL01 With "-N3:9.2"
  When  2 : Chgfmt [M]VAL02 With "-N3:9.2"
  When  3 : Chgfmt [M]VAL03 With "-N3:9.2"
  When  4 : Chgfmt [M]VAL04 With "-N3:9.2"
  When  5 : Chgfmt [M]VAL05 With "-N3:9.2"
  When  6 : Chgfmt [M]VAL06 With "-N3:9.2"
  When  7 : Chgfmt [M]VAL07 With "-N3:9.2"
  When  8 : Chgfmt [M]VAL08 With "-N3:9.2"
  When  9 : Chgfmt [M]VAL09 With "-N3:9.2"
  When 10 : Chgfmt [M]VAL10 With "-N3:9.2"
  When 11 : Chgfmt [M]VAL11 With "-N3:9.2"
  When 12 : Chgfmt [M]VAL12 With "-N3:9.2"
  When 13 : Chgfmt [M]VAL13 With "-N3:9.2"
  When 14 : Chgfmt [M]VAL14 With "-N3:9.2"
  When 15 : Chgfmt [M]VAL15 With "-N3:9.2"
  When 16 : Chgfmt [M]VAL16 With "-N3:9.2"
  When 17 : Chgfmt [M]VAL17 With "-N3:9.2"
  When 18 : Chgfmt [M]VAL18 With "-N3:9.2"
  When 19 : Chgfmt [M]VAL19 With "-N3:9.2"
  When 20 : Chgfmt [M]VAL20 With "-N3:9.2"
 Endcase
Next I
Titcol [M]NBLIG mess(11,10716,1),TEXTE(1),TEXTE(2),TEXTE(3),TEXTE(4),TEXTE(5)
&               ,TEXTE(6),TEXTE(7),TEXTE(8),TEXTE(9),TEXTE(10),TEXTE(11),TEXTE(12)
&               ,TEXTE(13),TEXTE(14),TEXTE(15),TEXTE(16),TEXTE(17)
&               ,TEXTE(18),TEXTE(19),TEXTE(20),mess(14,10716,1)
Gosub LIRE
Return

$SETBOUT
If [M]NBLIG=0
 CHBOU = ""
Elsif MODIF
 If VERROU : CHBOU = "EA" : Endif
Else
 If VERROU : CHBOU = "S" : Endif
Endif
If [M]EXE<>"" & [M]CPY<>""
 CHBOU += "<>09P"
Endif
CHBOU += "I"
CHMEN = ""
If [M]COD<>"" & [M]EXE<>"" & [M]CPY<>"" & !MODIF & [F:BIN]CALFLG=2
 CHMEN = "1"
Endif
Return

$ABORT
WOK = 2
Call OUINON(mess(51,100,1),WOK) From GESECRAN : # Abandon de l'opération en cours
Return

$ENREGISTRE
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 Affzo AUT
 MODIF = 0
 SUIZON = "NBLIG"
Endif
Return

$ABANDON
MODIF = 0
Gosub LIRE
SUIZON = "NBLIG"
Return

$LIRE
Gosub DEVERROU
Effzo 25
Chgstl [M]NBLIG With ""
TYP = [F:BIN]LIG : LONG = 1 : Gosub TEXTES
If [F:BIN]TOTLIG=2
 NBTEX += 1 : TEXTE(NBTEX) = mess(14,10716,1) : # Total
 [M]EXCL(NBTEX-1) = "X"
Endif
[M]NBLIG = NBTEX
For I=1 To [M]NBLIG
 [M]INTIT(I-1) = TEXTE(I)
Next I
If [M]EXE="" or [M]CPY="" or [M]COD="" : Return : Endif
Raz [M]VAL01,VAL02,VAL03,VAL04,VAL05,VAL06,VAL07,VAL08,VAL09,VAL10
Raz [M]VAL11,VAL12,VAL13,VAL14,VAL15,VAL16,VAL17,VAL18,VAL19,VAL20
Raz [M]TXT , [M]AUT
Raz TBVAL
For [BIL] Where EXE=[M]EXE & CPY=[M]CPY & FCY=[M]FCY & COD=[M]COD
 TBVAL([F:BIL]LIG,[F:BIL]COL) = [F:BIL]VALEUR
 Assign "[M]VAL"+format$("N0:##",[F:BIL]COL)+"("+num$([F:BIL]LIG-1)+")"
& With [F:BIL]VALEUR
 [M]AUT = [F:BIL]AUT
Next
Gosub CALTOT
Read [BIX]BIX0 = [M]EXE;[M]CPY;[M]FCY;[M]COD
If !fstat
 [M]TXT = [F:BIX]TXT
Endif
Gosub VERROU
If !VERROU
 Grizo 20-25
Else
 Actzo 20-25
Endif
Affzo 10-25
STYLE = "RELIEF"
If [F:BIN]TOTCOL=2
 Chgstl [M]VALTOT With STYLE : Affzo [M]VALTOT
Endif
If [F:BIN]TOTLIG=2
 Chgstl [M]INTIT([M]NBLIG-1) With STYLE : Affzo INTIT([M]NBLIG-1)
 For I1=1 To [M]NBCOL
  Case I1
   When  1 : Chgstl [M]VAL01([M]NBLIG-1) With STYLE : Affzo [M]VAL01([M]NBLIG-1)
   When  2 : Chgstl [M]VAL02([M]NBLIG-1) With STYLE : Affzo [M]VAL02([M]NBLIG-1)
   When  3 : Chgstl [M]VAL03([M]NBLIG-1) With STYLE : Affzo [M]VAL03([M]NBLIG-1)
   When  4 : Chgstl [M]VAL04([M]NBLIG-1) With STYLE : Affzo [M]VAL04([M]NBLIG-1)
   When  5 : Chgstl [M]VAL05([M]NBLIG-1) With STYLE : Affzo [M]VAL05([M]NBLIG-1)
   When  6 : Chgstl [M]VAL06([M]NBLIG-1) With STYLE : Affzo [M]VAL06([M]NBLIG-1)
   When  7 : Chgstl [M]VAL07([M]NBLIG-1) With STYLE : Affzo [M]VAL07([M]NBLIG-1)
   When  8 : Chgstl [M]VAL08([M]NBLIG-1) With STYLE : Affzo [M]VAL08([M]NBLIG-1)
   When  9 : Chgstl [M]VAL09([M]NBLIG-1) With STYLE : Affzo [M]VAL09([M]NBLIG-1)
   When 10 : Chgstl [M]VAL10([M]NBLIG-1) With STYLE : Affzo [M]VAL10([M]NBLIG-1)
   When 11 : Chgstl [M]VAL11([M]NBLIG-1) With STYLE : Affzo [M]VAL11([M]NBLIG-1)
   When 12 : Chgstl [M]VAL12([M]NBLIG-1) With STYLE : Affzo [M]VAL12([M]NBLIG-1)
   When 13 : Chgstl [M]VAL13([M]NBLIG-1) With STYLE : Affzo [M]VAL13([M]NBLIG-1)
   When 14 : Chgstl [M]VAL14([M]NBLIG-1) With STYLE : Affzo [M]VAL14([M]NBLIG-1)
   When 15 : Chgstl [M]VAL15([M]NBLIG-1) With STYLE : Affzo [M]VAL15([M]NBLIG-1)
   When 16 : Chgstl [M]VAL16([M]NBLIG-1) With STYLE : Affzo [M]VAL16([M]NBLIG-1)
   When 17 : Chgstl [M]VAL17([M]NBLIG-1) With STYLE : Affzo [M]VAL17([M]NBLIG-1)
   When 18 : Chgstl [M]VAL18([M]NBLIG-1) With STYLE : Affzo [M]VAL18([M]NBLIG-1)
   When 19 : Chgstl [M]VAL19([M]NBLIG-1) With STYLE : Affzo [M]VAL19([M]NBLIG-1)
   When 20 : Chgstl [M]VAL20([M]NBLIG-1) With STYLE : Affzo [M]VAL20([M]NBLIG-1)
  Endcase
 Next I1
Endif
Gosub SETBOX From WGFBIL
Return

$CALTOT
If [F:BIN]TOTCOL=2
 For I1=1 To [M]NBLIG
  SOMME = 0
  For I2=1 To [M]NBCOL
   SOMME += evalue("[M]VAL"+format$("N0:##",I2)+"("+num$(I1-1)+")")
  Next I2
  [M]VALTOT(I1-1) = SOMME
 Next I1
Endif
If [F:BIN]TOTLIG=2
 TOTGEN = 0
 For I1=1 To [M]NBCOL
  SOMME = 0
  For I2= 1 To [M]NBLIG-1
   SOMME += evalue("[M]VAL"+format$("N0:##",I1)+"("+num$(I2-1)+")")
  Next I2
  Assign "[M]VAL"+format$("N0:##",I1)+"("+num$([M]NBLIG-1)+")" With SOMME
  TOTGEN += SOMME
 Next I1
 If [F:BIN]TOTCOL=2
  [M]VALTOT([M]NBLIG-1) = TOTGEN
 Endif
Endif
Return

$PREMIER
Gosub FILTRE
Read [BIN]BIN0 First
Goto CHARGE

$DERNIER
Gosub FILTRE
Read [BIN]BIN0 Last
Goto CHARGE

$SUIVANT
Gosub FILTRE
Read [BIN]BIN0 > [M]COD
Goto CHARGE

$PRECEDENT
Gosub FILTRE
Read [BIN]BIN0 < [M]COD
Goto CHARGE

$GAUCHE
Read [BIN]BIN0 =
Goto CHARGE

$FILTRE
If [M]FCY=""
 Filter [BIN] Where CPYFLG=2 & SEC(SECTEUR-1)=2
Else
 Filter [BIN] Where FCYFLG=2 & SEC(SECTEUR-1)=2
Endif
Return

$CHARGE
Filter [BIN]
If fstat<=2 & [M]EXE<>"" & [M]CPY<>""
 If MODIF : Gosub ABORT : If WOK<>2 : Return : Endif : Endif
 [M]COD = [F:BIN]COD
 Gosub CHANGE_COD
 If !GERR
  Affzo COD,LIBCOD
 Endif
Endif
MODIF  = 0
SUIZON = "NBLIG"
Return

$BOUTON
Gosub LIRE
Return

$VERROU
SYMBOLE = "BIL"-[M]CPY-[M]FCY-[M]EXE-[M]COD
Lock =SYMBOLE With lockwait=0
If fstat=1
 Call MESSAGE(mess(10,100,1)) From GESECRAN
 VERROU = 0
Else
 VERROU = 1
Endif
Return

$DEVERROU
If VERROU
 Unlock =SYMBOLE
Endif
Return

$FIN
Gosub DEVERROU
Return

$TR1
GOK = 1
Trbegin [BIL]
 FLMOD = 0
 FLCRE = 0
 Filter [BIL] Where EXE=[M]EXE & CPY=[M]CPY & FCY=[M]FCY & COD=[M]COD
 Read [BIL]BIL0 First
 Filter [BIL]
 If fstat<=2
  WDAT = [F:BIL]CREDAT
  WTIM = [F:BIL]CRETIM
  WUSR = [F:BIL]CREUSR
  For I=1 To [M]NBLIG-([F:BIN]TOTLIG=2)
   For J=1 To [M]NBCOL
    If TBVAL(I,J)<>evalue("[M]VAL"+format$("N0:##",J)+"("+num$(I-1)+")")
     FLMOD = 1 : Break
    Endif
   Next J
  Next I
 Else
  FLCRE = 1
  FLMOD = 1
 Endif
 If FLMOD
  Delete [BIL] Where EXE=[M]EXE & CPY=[M]CPY & FCY=[M]FCY & COD=[M]COD
  If fstat=1
   GOK = -1 : GLOCK = "$BILRES"-[M]EXE-[M]CPY-[M]FCY-[M]COD : Goto ROLL_TR1
  Endif
  For I=1 To [M]NBLIG-([F:BIN]TOTLIG=2)
   Raz [F:BIL]
   [F:BIL]EXE = [M]EXE
   [F:BIL]CPY = [M]CPY
   [F:BIL]FCY = [M]FCY
   [F:BIL]COD = [M]COD
   [F:BIL]LIG = I
   [F:BIL]AUT = 1
   For J=1 To [M]NBCOL
    [F:BIL]COL = J
    [F:BIL]VALEUR = evalue("[M]VAL"+format$("N0:##",J)+"("+num$(I-1)+")")
    [F:BIL]LIBLIG = [M]INTIT(I-1)
    [F:BIL]LIBCOL = [M]LIBCOL(J-1)
    If FLCRE
     [F:BIL]CREDAT = date$
     [F:BIL]CREUSR = GUSER
     [F:BIL]CRETIM = time
    Else
     [F:BIL]CREDAT = WDAT
     [F:BIL]CREUSR = WUSR
     [F:BIL]CRETIM = WTIM
     [F:BIL]UPDDAT = date$
     [F:BIL]UPDUSR = GUSER
     [F:BIL]UPDTIM = time
    Endif
    Write [BIL]
    If fstat
     GOK = 0 : Call FSTA("BIL") From GLOCK : Break 2
    Endif
   Next J
  Next I
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
 Endif
 Readlock [BIX]BIX0 = [M]EXE;[M]CPY;[M]FCY;[M]COD
 If fstat=1
  GOK = -1 : GLOCK = "$BILTXT"-[M]EXE-[M]CPY-[M]FCY-[M]COD : Goto ROLL_TR1
 Elsif fstat
  fstat = 0
  If len([M]TXT)<>0
   [F:BIX]EXE = [M]EXE
   [F:BIX]CPY = [M]CPY
   [F:BIX]FCY = [M]FCY
   [F:BIX]COD = [M]COD
   [F:BIX]TXT = [M]TXT
   Write [BIX]
  Endif
 Else
  If len([M]TXT)<>0
   [F:BIX]TXT = [M]TXT
   Rewrite [BIX]
  Else
   Delete [BIX]
  Endif
 Endif
 If fstat
  GOK = 0 : Call FSTA("BIX") From GLOCK : Goto AB_TR1
 Endif
Commit
If FLMOD
 [M]AUT = 1
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$ANNULE
Call DEBTRANS From GLOCK
Gosub TR2
If GOK=1
 Effzo COD,NBLIG,TXT
 SUIZON = "COD"
Endif
Return

$TR2
GOK = 1
Trbegin [BIL]
 Delete [BIL] Where EXE=[M]EXE & CPY=[M]CPY & FCY=[M]FCY & COD=[M]COD
 If fstat=1
  GOK = -1 : GLOCK = "$BILRES"-[M]EXE-[M]CPY-[M]FCY-[M]COD : Goto ROLL_TR2
 Endif
 Delete [BIX] Where EXE=[M]EXE & CPY=[M]CPY & FCY=[M]FCY & COD=[M]COD
 If fstat=1
  GOK = -1 : GLOCK = "$BILTXT"-[M]EXE-[M]CPY-[M]FCY-[M]COD : Goto ROLL_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

###########################################################################
$PROPRIETES
Local Integer HH , MM , SS
Raz [M:AOV]
Filter [BIL] Where EXE=[M:BIL1]EXE & CPY=[M:BIL1]CPY & FCY=[M:BIL1]FCY & COD=[M:BIL1]COD
Read [BIL]BIL0 First
Filter [BIL]
If fstat<=2
 If [F:BIL]CREDAT<>[0/0/0]
  [M:AOV]DES([M:AOV]NBLIG)    = mess(160,124,1) : # Créé le
  [M:AOV]VALEUR([M:AOV]NBLIG) = format$("D:"+GFMDAT,[F:BIL]CREDAT)
  If [F:BIL]CRETIM>0
   HH = int([F:BIL]CRETIM/3600)
   MM = int(mod([F:BIL]CRETIM,3600)/60)
   SS = mod([F:BIL]CRETIM,60)
   [M:AOV]VALEUR([M:AOV]NBLIG) -= num$(HH)+":"+num$(MM)+":"+num$(SS)
  Endif
  If [F:BIL]CREUSR<>""
   [M:AOV]VALEUR([M:AOV]NBLIG) -= mess(161,124,1)-[F:BIL]CREUSR : # par
  Endif
  [M:AOV]NBLIG += 1
 Endif
 If [F:BIL]UPDDAT<>[0/0/0]
  [M:AOV]DES([M:AOV]NBLIG)    = mess(162,124,1) : # Modifié le
  [M:AOV]VALEUR([M:AOV]NBLIG) = format$("D:"+GFMDAT,[F:BIL]UPDDAT)
  If [F:BIL]UPDTIM>0
   HH = int([F:BIL]UPDTIM/3600)
   MM = int(mod([F:BIL]UPDTIM,3600)/60)
   SS = mod([F:BIL]UPDTIM,60)
   [M:AOV]VALEUR([M:AOV]NBLIG) -= num$(HH)+":"+num$(MM)+":"+num$(SS)
  Endif
  If [F:BIL]UPDUSR<>""
   [M:AOV]VALEUR([M:AOV]NBLIG) -= mess(161,124,1)-[F:BIL]UPDUSR : # par
  Endif
  [M:AOV]NBLIG += 1
 Endif
Endif
If [M:AOV]NBLIG=0
 FIN = 1
Else
 Affzo [AOV]
Endif
Return

###########################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Local Char SITE(GLONFCY)
If GUSRFCY(1)<>"\"
 If VALEUR<>""
  If !find(VALEUR,GUSRFCY(1..GNBAUZ))
   mkstat = 2 : SITE = VALEUR
  Endif
 Else
  For [FGR]FGR0 Where CPY=[M]CPY
   If !find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
    mkstat = 2 : SITE = [F:FGR]FCY : Break
   Endif
  Next
 Endif
 If mkstat
  GMESSAGE = SITE-":"-mess(32,10702,1) : # Vous n'avez pas accès à ce site
  End
 Endif
Endif
End

$TEXTES
Local Integer NBTEX , TABNUM , II, COLNUM
Local Char    TEXTE(30)(1..21)
Local Char    VALPAR(30) , NOMCHAMP(10)
If LONG
 NOMCHAMP = "LNGDES"
Else
 NOMCHAMP = "SHODES"
Endif
Case TYP
 When 1 : # Aucune
  NBTEX = 1
  TEXTE(1) = mess(14,10716,1) : # Total
 When 2 : # Hommes/Femmes
  NBTEX = 2
  TEXTE(1) = mess(12,10716,1) : # Hommes
  TEXTE(2) = mess(13,10716,1) : # Femmes
 When 3 : # Ages
  NBTEX = 0
  For [ADI]CODE Where NUMTAB=10503
   If NBTEX>=dim(TEXTE)-1
    Break
   Endif
   NBTEX += 1
   Call LECTEXTRA(TEXTE(NBTEX),"ATABDIV",NOMCHAMP,"10503",[F:ADI]CODE) From ATEXTRA
  Next
 When 4 : # Ancienneté
  NBTEX = 0
  For [ADI]CODE Where NUMTAB=10504
   If NBTEX>=dim(TEXTE)-1
    Break
   Endif
   NBTEX += 1
   Call LECTEXTRA(TEXTE(NBTEX),"ATABDIV",NOMCHAMP,"10504",[F:ADI]CODE) From ATEXTRA
  Next
 When 5 : # Nationalité
  NBTEX = 2
  TEXTE(1) = mess(15,10716,1) : # Français
  TEXTE(2) = mess(16,10716,1) : # Etrangers
 When 6 : # CSP1
  NBTEX = len(mess(0,10504,1))
  For II=1 To NBTEX
   TEXTE(II) = mess(II,10504,1)
  Next II
 When 7 : # CSP2
  Call PARAM("","BILCSPA",VALPAR) From ADOVAL
  TABNUM = val(VALPAR)
  NBTEX = 0
  ###46095
  Call PARAM("","BILCSPC2",VALPAR) From ADOVAL
  COLNUM = val(VALPAR)
  Read[F:ADV]CODE=TABNUM
  If !fstat
   Case COLNUM
    When 1       : TABNUM = val([F:ADV]SUP1)
    When Default : TABNUM = val([F:ADV]SUP2)
   Endcase
   ###
   For [ADI]CODE Where NUMTAB=TABNUM
    If NBTEX>=dim(TEXTE)-1
     Break
    Endif
    NBTEX += 1
    Call LECTEXTRA(TEXTE(NBTEX),"ATABDIV",NOMCHAMP,num$(TABNUM),[F:ADI]CODE) From ATEXTRA
   Next
  Endif
 When 8 : # Maladie
  NBTEX = 0
  For [ADI]CODE Where NUMTAB=10505
   If NBTEX>=dim(TEXTE)-1
    Break
   Endif
   NBTEX += 1
   Call LECTEXTRA(TEXTE(NBTEX),"ATABDIV",NOMCHAMP,"10505",[F:ADI]CODE) From ATEXTRA
  Next
 When 9 : # Salaires
  NBTEX = 0
  For [ADI]CODE Where NUMTAB=10506
   If NBTEX>=dim(TEXTE)-1
    Break
   Endif
   NBTEX += 1
   Call LECTEXTRA(TEXTE(NBTEX),"ATABDIV",NOMCHAMP,"10506",[F:ADI]CODE) From ATEXTRA
  Next
 When 10 : # Manuel
  If LONG
   NBTEX = [F:BIN]NBLIG
   For II=1 To NBTEX
    TEXTE(II) = [F:BIN]LIBLIG(II-1)
   Next II
  Else
   NBTEX = [F:BIN]NBCOL
   For II=1 To NBTEX
    TEXTE(II) = [F:BIN]LIBCOL(II-1)
   Next II
  Endif
 When Default
  #81271 : Affectation des intitulés des ventilations supplémentaires
  GPE = 0
  GPOINT = "INTVTL" : Gosub ENTREE From EXEFNC
Endcase
Return
 
$AS_VAL
If [F:BIN]TXTFLG=2
& or ([F:BIN]TOTLIG=2 & nolign=[M]NBLIG)
 mkstat = 2 : End
Endif
End

Subprog APRES_NBLIG
Local Decimal SOMME , TOTGEN
Local Integer I1 , I2 , NOL
NOL = nolign-1
Gosub CALTOT
If [F:BIN]TOTCOL=2
 Affzo VALTOT(NOL)
Endif
If [F:BIN]TOTLIG=2
 For I1=1 To [M]NBCOL
  Case I1
   When  1 : Affzo VAL01([M]NBLIG-1)
   When  2 : Affzo VAL02([M]NBLIG-1)
   When  3 : Affzo VAL03([M]NBLIG-1)
   When  4 : Affzo VAL04([M]NBLIG-1)
   When  5 : Affzo VAL05([M]NBLIG-1)
   When  6 : Affzo VAL06([M]NBLIG-1)
   When  7 : Affzo VAL07([M]NBLIG-1)
   When  8 : Affzo VAL08([M]NBLIG-1)
   When  9 : Affzo VAL09([M]NBLIG-1)
   When 10 : Affzo VAL10([M]NBLIG-1)
   When 11 : Affzo VAL11([M]NBLIG-1)
   When 12 : Affzo VAL12([M]NBLIG-1)
   When 13 : Affzo VAL13([M]NBLIG-1)
   When 14 : Affzo VAL14([M]NBLIG-1)
   When 15 : Affzo VAL15([M]NBLIG-1)
   When 16 : Affzo VAL16([M]NBLIG-1)
   When 17 : Affzo VAL17([M]NBLIG-1)
   When 18 : Affzo VAL18([M]NBLIG-1)
   When 19 : Affzo VAL19([M]NBLIG-1)
   When 20 : Affzo VAL20([M]NBLIG-1)
  Endcase
  If [F:BIN]TOTCOL=2
   Affzo [M]VALTOT([M]NBLIG-1)
  Endif
 Next I1
Endif
End

