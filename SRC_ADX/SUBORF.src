#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Gestion du masque ORF1 (Organisme de formation)
# Gestion de fiche ORGANISME (table ORGANISME)
# Création :
#
# Modifications :
#     SEGAY -  - 19/07/10 - EXI 66191 LOT 1
#                         - Rajout tableau spécificité, Siret, Site Internet
#                           Statut actif
#
# Modification :
#     SEGAY -  - 13/06/12 - EXI 81085 US 460
#     Remplacement fiche ORGANISME par ORGFINTRA (table ORGFINTRA)
#     MABOS -  - 30/05/13 - FQ81084 - US1612
#                         - value of GCURLEG
#                         - test dim([M:OFI0]LEG)
######################################################################################
Raz GPILOBJ
Call OBJET("ORF",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "FILTRE"     : Gosub FILTRE
 When "LIENS"      : Gosub LIENS
 When "INIMOD"     : Gosub SAUVE_ECRAN
#--STA_EXI 66191 LOT 1
# When "INICRE"     : [F:ORG]TYP=1 : Gosub SAUVE_ECRAN
 When "INICRE"     : Gosub INICRE #--SEGAY filtre sur les organisme de formation
#--END_EXI 66191 LOT 1
 When "RAZCRE"      : Gosub RAZCRE #SEGAY -  - 19/07/10 - EXI 66191 LOT 1
 When "RAZDUP"      : Gosub RAZDUP #SEGAY -  - 19/07/10 - EXI 66191 LOT 1
 When "FERME"       : Gosub FERME #--SEGAY 81085 LEG
 When "ABANDON"     : Gosub ABANDON #--SEGAY 81085 LEG
 When "VERF_ANU"    : Gosub VERF_ANU #--SEGAY 83205
Endcase
Return

$OUVRE
If clalev([F:OFT])=0 : Local File ORGFINTRA  [OFT] : Endif
#--SEGAY 81085 LEG
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
#--SEGAY 81085 LEG
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$ABANDON
#--SEGAY 81085 LEG
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#--SEGAY 83205
$VERF_ANU
If GMODU(20)=2
Local Char WTIT, WDES(GLONAX3)
If clalev([F:HRATS])=0 : Local File TASSEDIC  [HRATS] : Endif
   Filter [F:HRATS] Where [F:HRATS]ORGDIF=[F:OFT]COD
   If rowcount([F:HRATS]) > 0
#      enregistrement existe
     Read [HRATS] First
     If !fstat
       GERR=1
       [L]OK=0
       Call TITFNC("GESHRATS",WTIT) From CONTOBJ
 # La fiche est utilisée par ... dans ... il faut d'abord supprimer ce lien
       GMESSAGE = mess(101,126,1)-[F:HRATS]REFNUM+"-"+num$([F:HRATS]XITDAT)+"-"+num$([F:HRATS]CTRNUM)-mess(198,133,1)-"TASSEDIC ("+WTIT+")\"-mess(176,115,1)
     Endif
   Endif
   Filter [F:HRATS]
Endif
Return

$INICRE
#--STA_EXI 66191 LOT 1
#--SEGAY filtre sur les organisme de formation
[F:OFT]TYP=1 :#Organisme de formation uniquement
Gosub SAUVE_ECRAN
#--END_EXI 66191 LOT 1
Return
$FILTRE
#--STA_EXI 66191 LOT 1
#--SEGAY filtre sur les organisme de formation
#If FILTSUP<>"" : FILTSUP += " & " : Endif
#FILTSUP += "(TYP=1)" :#Organisme de formation uniquement
#--END_EXI 66191 LOT 1
#--PCA add LEG to filter as well as type
If FILTSUP<>"" : FILTSUP += " & " : Endif
#Not OK error Oracle
#FILTSUP += "(TYP=1)" :#Organisme de formation uniquement
#FILTSUP += "([F:OFT]LEG='' | GLEGFIL='' | (find([F:OFT]LEG,'"+GLEGFIL+"','')>0) )"
#FILTSUP += "((find([F:OFT]LEG,'"+GLEGFIL+"','')>0) & (TYP=1)) | ([F:OFT]LEG='' & (TYP=1)) | (GLEGFIL='' & (TYP=1))"
FILTSUP += "(TYP=1)" :#Organisme de formation uniquement

Return

#**#####################################################################################
#* SEGAY - 30/12/10 - En création, on initialise l'icone web
#*!
$RAZCRE
Call ACTIV_ICOORFWEB([M]ORFWEB)
Affzo [M]ICOORFWEB
#SEGAY - 13/06/12 - EXI 81085 US 460
Raz GCURLEG
GCURLEG = GLEGFIL :#MABOS-FQ81084-US1612
If dim([M:ORF1]LEG)>0 Then
  [M:ORF1]LEG=GLEGFIL
  Affzo [M:ORF1]LEG
Endif

Return
#**#####################################################################################
#* SEGAY - 30/12/10 - En création, on initialise l'icone web
#*!
$RAZDUP
Call ACTIV_ICOORFWEB([M]ORFWEB)
Affzo [M]ICOORFWEB
Return

$LIENS
#--SEGAY 81085 LEG
GCURLEG = [F:OFT]LEG  #--SEGAY 81085 LEG
If GNBLEG=1 : GCURLEG = GDOSLEG : Endif

[M]ADD1=[F:OFT]ADD(0)
[M]ADD2=[F:OFT]ADD(1)
[M]ADD3=[F:OFT]ADD(2)
#--STA_EXI 66191 LOT 1
# Segay FORMATION V6.1
# Taleau de 10 Spécialités
nolign=1
For I=0 To dim([F:OFT]SPEORG)-1
 If [M]SPEORG(I) = "" : Break : Endif
 [M]SPEORG(I)=[F:OFT]SPEORG(I)
 nolign+=1
Next
[M]NBRSPE=nolign-1
Call ACTIV_ICOORFWEB([M]ORFWEB)
#--END_EXI 66191 LOT 1
If dim([M:OFI0]LEG)>0 :[M:ORF1]LEG=GCURLEG :Endif :#MABOS

Return

$SAUVE_ECRAN
[F:OFT]ADD(0)=[M]ADD1
[F:OFT]ADD(1)=[M]ADD2
[F:OFT]ADD(2)=[M]ADD3
Return
#--STA_EXI 66191 LOT 1
#**#####################################################################################
#* Clique sur l'icône du site web
#* SEGAY
#* @since 19/07/10
#* @param VALEUR :
#*!
Subprog CL_ICOORFWEB(VALEUR)
Variable Char    VALEUR()
If  [M]ORFWEB <> "" Then
 Callui RETOUR="" With "UIAction="+chr$(1)+"OpenFile",
& "UILocalDir="+ chr$(1) +"HTTP",
& "UILocalFile="+ chr$(1) + [M]ORFWEB
Endif

End

#**#####################################################################################
#* Activation/Déactivation de l'icône site web
#* SEGAY
#* @since 19/07/10
#* @param VALEUR : Valeur du site web
#*!
Subprog ACTIV_ICOORFWEB(VALEUR)
Variable Char    VALEUR()
If  VALEUR <> "" Then
  Actzo [M]ICOORFWEB
Else
  Grizo [M]ICOORFWEB
Endif
End

#**#####################################################################################
#* Aprés modification du site web
#* SEGAY
#* @since 19/07/10
#* @param VALEUR : Valeur du site web
#*!
Subprog AM_ORFWEB(VALEUR)
Variable Char    VALEUR()
Call ACTIV_ICOORFWEB(VALEUR)
End
#--END_EXI 66191 LOT 1
######################################################################################
## 14/06/12 - SEGAY -  81085 Refresh screen after legislation changed.
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
Local Char WMASK(30)
    WMASK=maskcou
    GCURLEG = VALEUR
    If WMASK="OFI0"
      Call DISPLAY_HIDE() From SUBOFILEG
    Endif

End


######################################################################################
######################################################################################
## Section automatically added (screen ORF1) 05/25/2017 10:29:26 (TIVAN)
######################################################################################
Subprog AM_CRY(VALEUR)
Variable Char    VALEUR()
# TIVAN 25/05/2017 - Start
  If VALEUR <> [M:ORF1]CRY
    Raz [M:ORF1]POS, CTY
    Affzo [M:ORF1]POS, CTY
    If VALEUR = ""
      Raz [M:ORF1]CRYNAM
      Affzo [M:ORF1]CRYNAM
    Endif
  Endif
# TIVAN 25/05/2017 - End
End


