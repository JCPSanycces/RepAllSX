#                                                        # hcb 51961 deb
Subprog AM_INICUNFLG(VALEUR)
Variable Integer VALEUR
Local Integer WRET
If VALEUR  = 2
   If [M:STE2]CYCCUNDAT <> [F:STE]CYCCUNDAT
      Call OUINON(mess(677,199,1), WRET) From GESECRAN # Les comptages réalisés seront remis à zéro
   Else
      Call OUINON(mess(678,199,1)+"\"+mess(677,199,1),WRET) From GESECRAN # Attention : la date départ inventaire tournant n'a pas été modidiée
                                                                          # Les comptages réalisés seront remis à zéro
   Endif
   If WRET = 1
      [M:STE2]INICUNFLG = 1
      Affzo [M:STE2]INICUNFLG
   Else
      Raz   [M:STE2]CUNNBRA
      Raz   [M:STE2]CUNNBRB
      Raz   [M:STE2]CUNNBRC
      Raz   [M:STE2]CUNNBRD
      Affzo [M:STE2]CUNNBRA
      Affzo [M:STE2]CUNNBRB
      Affzo [M:STE2]CUNNBRC
      Affzo [M:STE2]CUNNBRD
   Endif
Else
   [M:STE2]CUNNBRA = [F:STE]CUNNBRA
   [M:STE2]CUNNBRB = [F:STE]CUNNBRB
   [M:STE2]CUNNBRC = [F:STE]CUNNBRC
   [M:STE2]CUNNBRD = [F:STE]CUNNBRD
   Affzo [M:STE2]CUNNBRA
   Affzo [M:STE2]CUNNBRB
   Affzo [M:STE2]CUNNBRC
   Affzo [M:STE2]CUNNBRD
Endif
End

#                                                        # hcb 51961 fin

