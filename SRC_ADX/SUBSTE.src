#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "APRES_MOD" : Gosub APRESMODIF   # hcb 51961
  When "LIENS"      : Gosub LIENS
  When "RAZCRE"     : Gosub RAZCRE
  When "RAZDUP"     : Gosub RAZDUP
  When "CREATION"   : Gosub CREATION
  When "AV_IMPRIME" :
    Gosub COP_ECRAN
    OK = 0
  When "FERME" :
    Call IMPSCR        From ATRTX3
Endcase
Return

$APRESMODIF                        # hcb 51961
[M:STE2]INICUNFLG = 1              # hcb 51961
Affzo [M:STE2]INICUNFLG           # hcb 51961

Return                             # hcb 51961
############################################################
$LIENS
# Bug 58295
Call GETDEV([M]STOFCY) From DEVSUB
[M:STE1]MON001 = mess(5,291,1)
[M:STE1]MON002 = mess(5,291,1)
[M:STE1]MON003 = mess(5,291,1)
[M:STE1]MON004 = mess(5,291,1)
[M:STE1]MON005 = mess(5,291,1)
[M:STE1]MON006 = mess(5,291,1)
[M:STE1]MON007 = mess(5,291,1)
[M:STE1]MON008 = mess(5,291,1)
[M:STE1]ORDCSTCUR = GLOCALDEV
[M:STE2]DAY001 = mess(1,291,1)
[M:STE2]DAY002 = mess(1,291,1)
[M:STE2]DAY003 = mess(1,291,1)
[M:STE2]DAY004 = mess(1,291,1)
[M:STE2]INICUNFLG = 1              # hcb 51961
#
If clalev([M:STE2]) > 0
  If [M:STE0]TCLCOD = ""
    Call CAL_INV
  Endif
  Actzo [M:STE2]10
  Grizo [M:STE2]15
  Actzo [M:STE2]20
  Grizo [M:STE2]25
  Actzo [M:STE2]30
  Grizo [M:STE2]35
  If [M:STE0]TCLCOD <> ""
    Grizo [M:STE2]5
    Grizo [M:STE2]YEACUNNBRA
    Grizo [M:STE2]YEACUNNBRB
    Grizo [M:STE2]YEACUNNBRC
    Grizo [M:STE2]YEACUNNBRD
  Else
    Actzo [M:STE2]5
  Endif
Endif
If [M:STE0]TCLCOD <> ""
  Affzo [M:STE3]
  Grizo [M:STE2]40
Else
  Affzo [M:STE2]40
  Actzo [M:STE2]40
  If [M:STE3]SHTPAR1 = 0
    [M:STE3]SHTPAR1 = 2
    [F:STE]SHTPAR1  = 2
  Endif
  If [M:STE3]SHTPAR2 = 0
    [M:STE3]SHTPAR2 = 3
    [F:STE]SHTPAR2  = 3
  Endif
  If [M:STE3]SHTPAR3 = 0
    [M:STE3]SHTPAR3 = 4
    [F:STE]SHTPAR3  = 4
  Endif
  If [M:STE3]SHTCAT1 = 0
    [M:STE3]SHTCAT1 = 2
    [F:STE]SHTCAT1  = 2
  Endif
  If [M:STE3]SHTCAT2 = 0
    [M:STE3]SHTCAT2 = 3
    [F:STE]SHTCAT2  = 3
  Endif
  If [M:STE3]SHTCAT3 = 0
    [M:STE3]SHTCAT3 = 4
    [F:STE]SHTCAT3  = 4
  Endif
  Affzo [M:STE3]
Endif
Return
############################################################
$RAZCRE
Actzo [M:STE1]
Actzo [M:STE2]
# Bug 58295
Call GETDEV([M]STOFCY) From DEVSUB
[M:STE1]MON001 = mess(5,291,1)
[M:STE1]MON002 = mess(5,291,1)
[M:STE1]MON003 = mess(5,291,1)
[M:STE1]MON004 = mess(5,291,1)
[M:STE1]MON005 = mess(5,291,1)
[M:STE1]MON006 = mess(5,291,1)
[M:STE1]MON007 = mess(5,291,1)
[M:STE1]MON008 = mess(5,291,1)
[M:STE1]ORDCSTCUR = GLOCALDEV
[M:STE2]DAY001 = mess(1,291,1)
[M:STE2]DAY002 = mess(1,291,1)
[M:STE2]DAY003 = mess(1,291,1)
[M:STE2]DAY004 = mess(1,291,1)
#
Affzo [M:STE1]
Affzo [M:STE2]
Return
############################################################
$RAZDUP
Raz [M:STE2]YEACUNNBRA
Raz [M:STE2]YEACUNNBRB
Raz [M:STE2]YEACUNNBRC
Raz [M:STE2]YEACUNNBRD
Raz [M:STE2]LASCUNDATA
Raz [M:STE2]LASCUNDATA
Raz [M:STE2]LASCUNDATB
Raz [M:STE2]LASCUNDATC
Raz [M:STE2]LASCUNDATD
Raz [M:STE2]CUNNBRA
Raz [M:STE2]CUNNBRB
Raz [M:STE2]CUNNBRC
Raz [M:STE2]CUNNBRD
Affzo [M:STE2]
Return
############################################################
$CREATION
Return
############################################################
$COP_ECRAN
Local Char WINT(20)(2)
Local Char WTIT(100)
Call TEXTFIC("STOPAR","STOFCY",2,WINT(0)) From OBJDIV
Call TEXTFIC("STOPAR","TCLCOD",2,WINT(1)) From OBJDIV
WTIT = "+"+WINT(0)+" : "+[M:STE0]STOFCY
If [M:STE0]TCLCOD <> ""
  WTIT -= (WINT(1)+" : "+[M:STE0]TCLCOD)
Endif
Call PRTSCR("STE1","",WTIT,0,0) From ATRTX3
Call PRTSCR("STE2","",WTIT,0,0) From ATRTX3
If [M:STE0]TCLCOD = ""
  Call PRTSCR("STE3","",WTIT,0,0) From ATRTX3
Endif
Return
############################################################
Subprog CAL_INV

Local Decimal WTO1       : WTO1 = 0
Local Decimal WTO2       : WTO2 = 0
Local Decimal WTO3       : WTO3 = 0
Local Decimal WTOT(5,14)
Local Char    WMSG(120)  : WMSG = ""
Call TRT_CAL([M:STE0]STOFCY,WTO1,WTO2,WTO3,WTOT,WMSG) From CNSSCISTD
If WTO1 <> 0 & WMSG = ""
  [M:STE2]YEACUNNBRA = WTOT(0,0)
  [M:STE2]YEACUNNBRB = WTOT(1,0)
  [M:STE2]YEACUNNBRC = WTOT(2,0)
  [M:STE2]YEACUNNBRD = WTOT(3,0)
  Affzo [M:STE2]YEACUNNBRA
  Affzo [M:STE2]YEACUNNBRB
  Affzo [M:STE2]YEACUNNBRC
  Affzo [M:STE2]YEACUNNBRD
Endif
End
############################################################
Subprog C_TCLCOD(VALEUR)
Variable Char     VALEUR
# Fait par le type de donnée: voir AUTSTE0
# Call CONTROLE("ITG","!",VALEUR,"",mkstat) From CONTOBJ
If clalev([M:STE2]) > 0
  Actzo [M:STE2]10
  Grizo [M:STE2]15
  Actzo [M:STE2]20
  Grizo [M:STE2]25
  Actzo [M:STE2]30
  Grizo [M:STE2]35
  If VALEUR <> ""
    Grizo [M:STE2]5
    Grizo [M:STE2]YEACUNNBRA
    Grizo [M:STE2]YEACUNNBRB
    Grizo [M:STE2]YEACUNNBRC
    Grizo [M:STE2]YEACUNNBRD
  Endif
Endif
End
###########################################################
Subprog AP_TCLCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" & (GREP = "C" | GREP = "D")
  Call CAL_INV
Endif
End
############################################################
Subprog C_SAFMAXHIS(VALEUR)
Variable Decimal  VALEUR
If VALEUR < [M:STE1]SAFMINHIS
  mkstat = 2
  GMESSAGE = mess(44,199,1)
Endif
End
############################################################
Subprog C_EOQMAXHIS(VALEUR)
Variable Decimal  VALEUR
If VALEUR < [M:STE1]EOQMINHIS
  mkstat = 2
  GMESSAGE = mess(44,199,1)
Endif
End
############################################################
Subprog C_SRVRATA(VALEUR)
Variable Decimal  VALEUR
If ([M:STE1]SAFMINHIS <> 0 & VALEUR = 0) |
&  ([M:STE1]SAFMAXHIS <> 0 & VALEUR = 0)
  mkstat = 2
Endif
End
############################################################
Subprog C_SRVRATB(VALEUR)
Variable Decimal VALEUR
If ([M:STE1]SAFMINHIS <> 0 & VALEUR = 0) |
&  ([M:STE1]SAFMAXHIS <> 0 & VALEUR = 0)
  mkstat = 2
Endif
End
############################################################
Subprog C_SRVRATC(VALEUR)
Variable Decimal VALEUR
If ([M:STE1]SAFMINHIS <> 0 & VALEUR = 0) |
&  ([M:STE1]SAFMAXHIS <> 0 & VALEUR = 0)
  mkstat = 2
Endif
End
############################################################
Subprog C_ORDCST(VALEUR)
Variable Decimal  VALEUR
If ([M:STE1]EOQMINHIS <> 0 & VALEUR = 0) |
&  ([M:STE1]EOQMAXHIS <> 0 & VALEUR = 0)
  mkstat = 2
Endif
End
############################################################
Subprog C_STOCSTRAT(VALEUR)
Variable Decimal VALEUR
If ([M:STE1]EOQMINHIS <> 0 & VALEUR = 0) |
&  ([M:STE1]EOQMAXHIS <> 0 & VALEUR = 0)
  mkstat = 2
Endif
End
############################################################
Subprog AV_TCLAXX(VALEUR)
Variable Char     VALEUR
If [M:STE0]TCLCOD = ""
  VALEUR = mess(92,196,1)
Else
  Read [ITG]ITG0="";[M:STE0]TCLCOD     # <TB> 22/08/02
  Call GET_ATEXTRA("ITMCATEG","TCLAXX",GLANGUE,VALEUR) From TRTX3TEX
Endif
End
############################################################
Subprog C_MAXMAXHIS(VALEUR)
Variable Decimal  VALEUR
If VALEUR < [M:STE1]MAXMINHIS
  mkstat = 2
  GMESSAGE = mess(44,199,1) : # <MG> 20/04/00
Endif
End
############################################################
Subprog AS_CYCCUNDAT(VALEUR)
Variable Date     VALEUR
If VALEUR = [0/0/0]
  VALEUR = date$
Endif
End
