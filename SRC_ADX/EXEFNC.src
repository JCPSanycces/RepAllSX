#<AdxTL>@(#)12.0.0.0 $Revision$

######################################################################
## Traitement de lancement d'une fonction à partir du menu
######################################################################

$INITMEN

# Rafraîchissement des masques, traitements, ...

Local Decimal TIMESTAMP
TIMESTAMP = filinfo(filpath("","timestamp",""),9)
If !find(nomap(1),"",nomap(0))
 TIMESTAMP = max(TIMESTAMP,filinfo(filpath("","timestamp","",nomap(1)),9))
Endif
If !find(nomap(2),"",nomap(0..1))
 TIMESTAMP = max(TIMESTAMP,filinfo(filpath("","timestamp","",nomap(2)),9))
Endif
If TIMESTAMP>GTIMESTAMP
 #Close File
 #Close Mask
 adxmpr = adxmpr
 adxmbm = adxmbm
 GTIMESTAMP = TIMESTAMP
Endif

# Remise à zéro de certaines variables

If dim(GNBMASKOUV)>0
 Raz GNBMASKOUV,GMASKOUV
 If dim(GFENMAJ)>0 : Raz GFENMAJ : Endif
Endif
If dim(GVALIDDIFF)>0
 Raz GVALIDDIFF
Endif
If dim([V]I)>0 : Kill [V]I : Endif
If dim([V]J)>0 : Kill [V]J : Endif
If dim([V]K)>0 : Kill [V]K : Endif

Raz GTRACE
Raz GEDIDIF
Raz GPILSEL , GPILSELDOC
Raz GCONSULT, GORITITCOL
Raz GTUNCPT
Raz GOBJET , GPROGRAMME
Raz GERREUR , GTRANS , GPICK
Raz GPILBOITE
Raz GWINDOW , GWINCRIT , GTYPPROG , GPROG , GBOITE , GABREV
Raz GAFF , GNBAFF , GERR
Raz GPILLNK
Raz GPILOBJ
Raz GFONC1
Raz GBATCH
Raz GPILNAV
Raz GCURFCY , GGRPFCY , GCURLEG
pcolor = GCOUL(0) : # Au cas où pour les formats variables

##  En cas de plantage lors de la génération d'un dossier
##  On réactive les Call ERREUR() à l'écran

If GSERVEUR=2
 GSERVEUR=0
Endif
Return

# ----------------------------------------------------------------------------------------

Subprog MENU

# Initialisation des variables

Local Decimal OTIMESTAMP
OITMESTAMP = GTIMESTAMP
Gosub INITMEN
If GTIMESTAMP<>OTIMESTAMP
 Close File
 Close Mask
Endif

# On est censé récupérer un numéro de fonction et une variante

Local Integer NUMFONC
Local Char    VARIANTE(20)
Local Integer MODULE , MONO
Local Char    FONCTION(GLONAFC)

MODULE   = 0
MONO     = 0
FONCTION = ""
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
If dim(NNUMF)<0
  NUMFONC  = menchoix
##    A-t-on passé un nom de fonction ou un numéro ?
  If left$(adxpam,1)="~" and NUMFONC=1
    Local Char CFONC(20),VARIN
    Local Integer FFON
    CFONC=adxpam
    FFON=instr(2,adxpam,"~")
    If FFON<>0
      CFONC=mid$(adxpam,2,FFON-2)
      VARIN =right$(adxpam,FFON+1)
    Else
      CFONC=right$(adxpam,2)
      VARIN=""
    Endif
    Read [AFC]CODINT=CFONC
    If fstat=0
      NUMFONC=[F:AFC]NUMFNC
    Endif
  Endif
Else
  NUMFONC=NNUMF
  Kill NNUMF
Endif
VARIANTE = GFLAG     : # Pour l'instant

If adxpam<>""
 VARIANTE = adxpam
 If left$(adxpam,1)="~" and dim(VARIN)>=1
   VARIANTE =VARIN
 Endif
Endif

If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif

# Fonctions spéciales pour le Portail

Case NUMFONC
 When GSTAPTL  : Read [AFC]CODINT = "APTLREQ"
 When GSTAPTL2 : Read [AFC]CODINT = "APTLOBJ"
 When Default  : Read [AFC]NUMFNC = NUMFONC
Endcase
If !fstat
 [L]MONO     = [F:AFC]MONO
 [L]MODULE   = [F:AFC]MODULE
 [L]FONCTION = [F:AFC]CODINT
Endif

Close Local File [AFC]

If [L]FONCTION=""
 Call ERREUR(num$(NUMFONC)-":"-mess(2,130,1)) From GESECRAN : # Code fonction inexistant
 End
Endif

# Pb du mode mono

If dim([V]GLCKOPT)>0 & [V]GLCKOPT=3 & [L]MONO<>2
 If GLCKFLG([L]MODULE)=1
  Local Integer T , STA
  T = time
  Repeat
   Lock ="MONOA"
  Until !fstat or time>T+10
  STA = fstat
  If !STA
   Lock ="MONOB"+format$("N0:2#",[L]MODULE)
   STA = fstat
   If !STA
    Unlock ="MONOB"+format$("N0:2#",[L]MODULE)
   Endif
   Unlock ="MONOA"
  Endif
  If STA
   Call ERREUR(mess(121,126,1)-mess([L]MODULE,14,1)) From GESECRAN
   End
  Endif
 Endif
Endif

# Raz des boutons

For I=1 To GNBBOU
 GETABOU(I) = 2
Next I
Enable GSTAHLP

If dim(GGBOUTGLO)<0 : Gosub BOUTGLO : Endif

# Exécution proprement dite

Call EXEFNC([L]FONCTION,VARIANTE)

# Grisage des boutons

Local Integer ETABOU(1..GNBBOU)
Raz ETABOU
Call SETBOUT(ETABOU) From GESECRAN
For I=1 To dim(GSTASPE)
 GSTASPE(I) = GSTABOU+I
Next I

# Raz buffer des valeurs des paramètres généraux

If dim(GSIPARAM)>0
 Raz GSIPARAM , GNUPARAM
Endif

# Raz des variables

Raz GBIDI1,GBIDI2,GBIDI3
Raz GBIDC1,GBIDC2,GBIDC3
Raz GBIDD1,GBIDD2,GBIDD3
Raz GBIDA1,GBIDA2,GBIDA3
Raz GFLAG
GREPORT1 = "" : GREPORT2 = ""

# Pour Géode
Call AFF_ENV From MENU

End

$ERRSTAGLOB
Resume

$BOUTGLO
Global Integer GGBOUTGLO
Enable GSTAHLP
Global Onkey GSTAHLP Titled mess(139,124,1) Call HELP From HLPINF
Global Onkey GSTADLU Titled mess(196,123,1) Call DLU From HLPINF
Onerrgo ERRSTAGLOB
Global Onkey GSTAEXP Titled mess(218,151,1) Call AEXPXML(GBOITE,"XML") From AEXPXML
Global Onkey GSTAEXC Titled mess(219,151,1) Call AEXPXML(GBOITE,"EXCEL") From AEXPXML
Global Onkey GSTAEXT Titled mess(219,151,1) Call AEXPEXCT(GBOITE,maskcou,zoncou,1) From AEXPXML
#X3-16906
If dim(GSTACSV)<0 : #Sécurité
 Global Integer  GSTACSV
 GSTACSV  =   164
Endif
Global Onkey GSTACSV Titled mess(282,151,1) Call AEXPEXCT(GBOITE,maskcou,zoncou,2) From AEXPXML

Onerrgo
Enable GSTAEXP
Enable GSTAEXC
Enable GSTAEXT
Enable GSTACSV :#X3-16906
Enable GSTAEUR
Enable GSTARAF
Enable GSTADAT
Enable GSTADLU
Global Onkey GSTAEUR Titled mess(176,123,1) Call EURO From SUBEURO
If GDEBUG=2
 Enable GSTADBG
 Global Onkey GSTADBG Titled "Debug"        Call ON_KEY From DEBUGGERJ
Else
 Disable GSTADBG
Endif
Return

# Exécution d'un point d'entrée

$ENTREE
If GPOINT<>"" & dim(GNBENTREE)>0
Local Integer IEXEPRG , NPEEX , RPEEX(1..)   , IPEEX
Local Char    EXEPRG(250) , TPEEX(30)(1..)
EXEPRG = adxpno(1)
Repeat
  IEXEPRG = instr(1,EXEPRG,"/")
  If IEXEPRG
   EXEPRG = right$(EXEPRG,IEXEPRG+1)
  Endif
Until !IEXEPRG
IEXEPRG = instr(1,EXEPRG,"$")
If IEXEPRG
  EXEPRG = left$(EXEPRG,IEXEPRG-1)
Endif
IEXEPRG = instr(1,EXEPRG,"@")
If IEXEPRG
  EXEPRG = right$(EXEPRG,IEXEPRG+1)
Endif
IEXEPRG = instr(1,EXEPRG,".")
If IEXEPRG
  EXEPRG = right$(EXEPRG,IEXEPRG+1)
Endif
If EXEPRG="EXEFNC2"
  EXEPRG = "EXEFNC"
Endif
IEXEPRG = find(EXEPRG,GENTSTD(1..GNBENTREE))
If IEXEPRG
  If dim(GENTRNG)>0
   Raz NPEEX , RPEEX , TPEEX
   For IPEEX=1 To GNBENTREE
    If GENTSTD(IPEEX)=EXEPRG
     NPEEX += 1
     RPEEX(NPEEX) = GENTRNG(IPEEX)
     TPEEX(NPEEX) = GENTSPE(IPEEX)
    Endif
   Next IPEEX
   If NPEEX>1
    # On trie d'après le rang
    Local Integer SAVIND : SAVIND=indice          : # CCL 18/01/2016 113735
    Sorta NPEEX RPEEX,TPEEX Order By RPEEX(indice+1)
    indice=SAVIND                    : # CCL  18/01/2016 113735
   Endif
  Else
   NPEEX = 1
   TPEEX(NPEEX) = GENTSPE(IEXEPRG)
  Endif
  If dim([V]GPOINTTRA)>0 & GPOINTTRA=1
   Call ECR_TRACE(mess(118,133,1)-":"-EXEPRG-GPOINT,0) From GESECRAN
   # Appel du point d'entrée
  Endif
  Local Char    SAVACTPEEX(20)
  If dim([L]ACTION)>0
   SAVACTPEEX = ACTION
  Else
   Local Char ACTION(20)
  Endif
  For IPEEX=1 To NPEEX
   ACTION = GPOINT
   Gosub ACTION From =TPEEX(IPEEX)
  Next IPEEX
  If SAVACTPEEX<>""
   ACTION = SAVACTPEEX
  Endif
Endif
Endif
Return

#################################################
## Mise à jour du fichier timestamp
#################################################
Subprog STAMP
Openo filpath("","timestamp","") , 0
Wrseq date$-time$
Openo
End

###########################################################################################
## Exécution d'une fonction gobjet depuis un contexte convergence ou défini dans adxctx
###########################################################################################
Subprog EXEFNCCNV(FONCTION,AVARCNV,AOPER,AKEY)
Value Char FONCTION
Value Char AVARNCV
Value Char AOPER
Value Char AKEY
If dim(GCHXCREMOD)>0 : GCHXCREMOD = AOPER : Endif
Goto SUITEXEF

###########################################################################################
## Exécution d'une fonction depuis un traitement pour les liens processus (SUBAPR)
###########################################################################################
Subprog EXEFNCK(FONCTION,VARIA,AKEY)
Value Char FONCTION
Value Char VARIA
Value Char AKEY
Goto SUITEXEF

#############################################################################
## Exécution d'une fonction depuis syracuse (avec paramètre)
#############################################################################
Subprog EXEFNCP(FONCTION,VARIA,ACODPAR,AVALPAR)
Value Char FONCTION
Value Char VARIA
Value Char ACODPAR
Value Char AVALPAR
Goto SUITEXEF

#################################################
## Exécution d'une fonction depuis un traitement
#################################################
Subprog EXEFNC(FONCTION,VARIA)
Value Char FONCTION
Value Char VARIA

$SUITEXEF
Local File AMENUSER  [AMU]
Local File AFONCTION [AFC]
Local File AFCTFCY   [AFF]
Local File AFCTPRF   [AFP]
Local File AFCTFCT   [AFT]
Local File AUTILIS   [AUS]

Local Char    SAVFNC(GLONAFC) , SAVFNC1(GLONAFC) , SAVPRG(GLONADC) , SAVVAR(GLONAVA) , SAVACT(GLONACT)
Local Char    SAVREP1(GLONARP) , SAVREP2(GLONARP)
Local Integer SAVGCONSULT:#SAM121925
Local Integer TOUCHE , OKTRT , LICENCE
Local Char    ACTCUR(GLONACT) , ACTSUI(GLONACT) , FCTCUR(GLONAFC)
Local Char    VALPAR(250)(1..20)
Local Char    CODTRT(GLONADC) , SPETRT(GLONADC) , ACTION(20)
Local Char    PARAM1(GLONACN) , PARAM2(GLONFEN) , PARAM4(GLONFEN) , PARAM5(10)
Local Integer PARAM3 , TYPACT , NOPAR , TYPVAL , FLGNAV

Local Char VARIANTE(30)
If dim(AVARCNV)>0
 VARIANTE = AVARCNV
Else
 VARIANTE = VARIA
 If left$(VARIANTE,1)="#"
  Local Integer II
  II = instr(2,VARIANTE,"#")
  If II<>0
   VARIANTE = right$(VARIANTE,II+1)
  Else
   VARIANTE = ""
  Endif
 Elsif left$(VARIANTE,3)="/#@"
  VARIANTE = right$(VARIANTE,2)
 Endif
Endif

If dim([V]GACTION)<=0 : Global Char GACTION(20) : Endif : # provisoire
SAVFNC   = GFONCTION
If dim(GFONCTION1)>0
 SAVFNC1  = GFONCTION1
Endif
SAVVAR   = GFLAG
SAVPRG   = GTRAITE
SAVACT   = GACTION
SAVREP1  = GREPORT1
SAVREP2  = GREPORT2
ACTSUI   = ""
SAVGCONSULT = GCONSULT:#SAM121925

Read [AFC]CODINT = FONCTION

GPE = 0
GPOINT = "FONCTION" : Gosub ENTREE From EXEFNC2
If GPE : End : Endif : # mb 12.6.3 demande 18496

ACTION = "FONCTION"
Call EXISTE_ADX("","","EXEFNCB",OKTRT) From ORDSYS
If OKTRT
 Gosub ACTION From EXEFNCB
Endif

If GHISTO
 GCONSULT = 1
Endif

GFONCTION = [F:AFC]CODINT
GTRAITE   = [F:AFC]TRAIT
GFLAG     = VARIANTE
If dim(GFONCTION1)>0
 GFONCTION1 = GFONCTION
Endif

# Menus utilisateurs

Call SET_MENU(GFONCTION)

# Autorisations utilisateurs

If GTRAITE<>"GOBJET" & [F:AFC]ACTION<>"GOBJET" : # C'est fait dans GOBJET
 Call AUTORIS
 If GNBAUZ=0
  If GNBSITE=0
   Call ERREUR(mess(33,104,1)) From GESECRAN : # Vous devez d'abord créer un site dans le dossier
   End
  Else
   Call ERREUR(GFONCTION-":"-mess(1,123,1)) From GESECRAN  : # Fonction non autorisée
   End
  Endif
 Endif
 Call AFF_MES_LIC(GFONCTION,[V]CST_ATRUE) From ASYRLIC
Endif

# Init des variables fonctions

For I=0 To [F:AFC]NBVAR-1
 If [F:AFC]VALEUR(I)<>"#"
  Onerrgo EVAL
  Assign [F:AFC]VARIA(I) With evalue([F:AFC]VALEUR(I))
  Onerrgo
 Else
  Assign [F:AFC]VARIA(I) With GFLAG
 Endif
Next I
If [F:AFC]RPT1<>""
 GREPORT1 = [F:AFC]RPT1
Endif
If [F:AFC]RPT2<>""
 GREPORT2 = [F:AFC]RPT2
Endif

If dim([V]GCHGENV)>0
 If dim([F:AFC]DEPENV)>0 & [F:AFC]DEPENV=2 : # Chgt environnement
  GCHGENV=2
 Elsif dim([F:AFC]FCYENV)>0 & [F:AFC]FCYENV=2
  GCHGENV=1
 Else
  GCHGENV=0
 Endif
Endif

# Messagerie

Call WORKFLOW(3,GFONCTION,"",GUSER) From AWRK

# Statistiques d'utilisation
#87108
#Call NOMBRA(12,LICENCE) From GLOCK
#If mod(I,32)>=16 or GUSRNOMME>0 : # Case à cocher "STAT" dans les licences
# Call MAJSTA(GUSER,2,GFONCTION,num$([F:AFC]MODULE)) From AUSRSTA
#Endif

# Exécution

Close Local File [AMU] , [AFF] , [AFP] , [AFT] , [AUS]

If GTRAITE="" : GTRAITE = GFONCTION : Endif : # Temporaire

If [F:AFC]ACTION=""
 Call EXISTE_ADX("","",GTRAITE,OKTRT) From ORDSYS
 If !OKTRT
  Call ERREUR(GTRAITE-":"-mess(90,123,1)) From GESECRAN
  # Traitement inexistant
  End
 Else
  Call SET_DERFCT([F:AFC]CODINT,"")
  Close Local File [AFC]
  Run =[V]GTRAITE
  End
 Endif
Else
 Call SET_DERFCT([F:AFC]CODINT,GFLAG)
Endif

If [F:AFC]TYP <> 2 or GPILNAV<2
 FLGNAV = 1
  GPILNAV += 1
 GNAVIG(GPILNAV) = GFONCTION
Endif

# Traitement des actions
ACTCUR = [F:AFC]ACTION

$SUITE
If ACTCUR<>""
 If clalev([F:ACT])=0 : Local File ACTION    [ACT] : Endif
 If clalev([F:ATR])=0 : Local File ACTPAR    [ATR] : Endif
 If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
 Read [ACT]ACTION = ACTCUR
 If [F:AFC]CODINT<>GFONCTION
  Read [AFC]CODINT = GFONCTION
 Endif
 GACTION = [F:ACT]ACTION
 FCTCUR  = [F:AFC]CODINT
 ACTSUI  = [F:ACT]ACTSUI
 TYPACT  = [F:ACT]TYP
 CODTRT  = [F:ACT]CODTRT
 SPETRT  = [F:ACT]SPETRT
 PARAM1  = [F:ACT]PARAM1
 PARAM2  = [F:ACT]PARAM2
 PARAM3  = [F:ACT]PARAM3
 PARAM4  = [F:ACT]PARAM4
 PARAM5  = [F:ACT]PARAM5

 # Initialisation des paramètres de l'action

 If [F:ACT]TYPACT=2 & [F:ACT]NBPAR>0
  Read [ATR]NOPAR = [F:ACT]ACTION;1
  Case [F:ATR]TYPPAR
   When 1   : TYPVAL = 1 : Local Char    VALEUR(250)
   When 2,5 : TYPVAL = 2 : Local Integer VALEUR
   When 3   : TYPVAL = 3 : Local Decimal VALEUR
   When 4   : TYPVAL = 4 : Local Date    VALEUR
   When 6   : TYPVAL = 6 : Local Clbfile VALEUR
   When 7   : TYPVAL = 7 : Local Blbfile VALEUR
  Endcase
 Else
  TYPVAL = 1 : Local Char VALEUR(250)
 Endif
 Raz VALPAR
 NOPAR = 0
 If dim(ACODPAR)>0
  #VPO gestion appel fonction convergence avec paramètres EXEFNCP
   For I=1 To [F:ACT]NBPAR
    If (I>1 or [F:ACT]TYPACT<>2)
     NOPAR += 1
     Read [ATR]NOPAR = [F:ACT]ACTION;I
     K = find([F:ATR]CODPAR,ACODPAR)
     If K & AVALPAR(K-1)<>""
      Onerrgo EVAL
      Case [F:ATR]TYPPAR
       When 4
        #on essaye YYYY-MM-DD
        If pat(AVALPAR(K-1),"????-??-??")
          VALPAR(NOPAR) = left$(AVALPAR(K-1),4)+mid$(AVALPAR(K-1),6,2)+right$(AVALPAR(K-1),9)
        Else
          VALPAR(NOPAR) = AVALPAR(K-1)
        Endif
       When 10
        #on essaye YYYY-MM-DD
        If pat(AVALPAR(K-1),"????-??-??")
          VALPAR(NOPAR) = left$(AVALPAR(K-1),4)+mid$(AVALPAR(K-1),6,2)+right$(AVALPAR(K-1),9)
        Else
          VALPAR(NOPAR) = AVALPAR(K-1)
        Endif
       When Default
        VALPAR(NOPAR) = AVALPAR(K-1)
      Endcase
      Onerrgo
     Else
      VALPAR(NOPAR) = ""
     Endif
    Endif
   Next I
 Else
   For I=1 To [F:ACT]NBPAR
    If (I>1 or [F:ACT]TYPACT<>2)
     NOPAR += 1
     Read [ATR]NOPAR = [F:ACT]ACTION;I
     K = find([F:ATR]CODPAR,[F:AFC]CODPAR(0..dim([F:AFC]CODPAR)-1))
     If K & [F:AFC]VALPAR(K-1)<>""
      Onerrgo EVAL
      Case [F:ATR]TYPPAR
       When 1,4,6
        VALPAR(NOPAR) = evalue([F:AFC]VALPAR(K-1))
       When Default
        VALPAR(NOPAR) = num$(evalue([F:AFC]VALPAR(K-1)))
      Endcase
      Onerrgo
     Else
      VALPAR(NOPAR) = ""
     Endif
    Endif
   Next I
 Endif
 Close Local File [AFC] , [ACT] , [ATR]

 # Exécution de l'action

 # Pour pouvoir naviguer en prenant en compte la variante même en "tunnel"
 Global Integer GNAVEXEFNC : GNAVEXEFNC=1
 Case TYPACT
  When 1 : # Objet
   If dim(AKEY)>0 and AKEY<>"" : Gosub EVALKEY : Endif   : # CC 15/07/2009  pour passer les clés pour les processus
   Case TYPVAL
    When 1   : Call OBJET_CHAR(VALEUR,VALPAR(1),VALPAR(2)) From GOBJET
    When 2,5 : Call OBJET_LIB(VALEUR,VALPAR(1),VALPAR(2)) From GOBJET
    When 3   : Call OBJET_NUM(VALEUR,VALPAR(1),VALPAR(2)) From GOBJET
    When 4   : Call OBJET_DAT(VALEUR,VALPAR(1),VALPAR(2)) From GOBJET
    When 6   : Call OBJET_CLOB(VALEUR,VALPAR(1),VALPAR(2)) From GOBJET
    When 7   : Call OBJET_BLOB(VALEUR,VALPAR(1),VALPAR(2)) From GOBJET
   Endcase
  When 2 : # Consultation
   If GHISTO : GCONSULT = 0 : Endif
   Call GCONSULT(PARAM1,GFLAG,VALPAR) From GCONSULT
  When 3 : # Traitement
   If PARAM3=5 or PARAM3=6
    Case TYPVAL
     When 1   : Call TRAITE_CHAR(VALEUR,VALPAR,PARAM2,CODTRT,PARAM5,PARAM3,SPETRT) From GTRAITE
     When 2,5 : Call TRAITE_LIB(VALEUR,VALPAR,PARAM2,CODTRT,PARAM5,PARAM3,SPETRT) From GTRAITE
     When 3   : Call TRAITE_NUM(VALEUR,VALPAR,PARAM2,CODTRT,PARAM5,PARAM3,SPETRT) From GTRAITE
     When 4   : Call TRAITE_DAT(VALEUR,VALPAR,PARAM2,CODTRT,PARAM5,PARAM3,SPETRT) From GTRAITE
     When 6   : Call TRAITE_CLOB(VALEUR,VALPAR,PARAM2,CODTRT,PARAM5,PARAM3,SPETRT) From GTRAITE
     When 7   : Call TRAITE_BLOB(VALEUR,VALPAR,PARAM2,CODTRT,PARAM5,PARAM3,SPETRT) From GTRAITE
    Endcase
   Else
    Case TYPVAL
     When 1   : Call TRAITE_CHAR(VALEUR,VALPAR,PARAM2,CODTRT,PARAM4,PARAM3,SPETRT) From GTRAITE
     When 2,5 : Call TRAITE_LIB(VALEUR,VALPAR,PARAM2,CODTRT,PARAM4,PARAM3,SPETRT) From GTRAITE
     When 3   : Call TRAITE_NUM(VALEUR,VALPAR,PARAM2,CODTRT,PARAM4,PARAM3,SPETRT) From GTRAITE
     When 4   : Call TRAITE_DAT(VALEUR,VALPAR,PARAM2,CODTRT,PARAM4,PARAM3,SPETRT) From GTRAITE
     When 6   : Call TRAITE_CLOB(VALEUR,VALPAR,PARAM2,CODTRT,PARAM4,PARAM3,SPETRT) From GTRAITE
     When 7   : Call TRAITE_BLOB(VALEUR,VALPAR,PARAM2,CODTRT,PARAM4,PARAM3,SPETRT) From GTRAITE
    Endcase
   Endif
  When 4 : # Saisie
   If dim(AKEY)>0 and AKEY<>"" : Gosub EVALKEY : Endif   : # CC 15/07/2009  pour passer les clés pour les processus
   Case TYPVAL
    When 1   : Call SAISIE_CHAR(VALEUR,VALPAR,PARAM2,CODTRT,SPETRT) From GSAISIE
    When 2,5 : Call SAISIE_LIB(VALEUR,VALPAR,PARAM2,CODTRT,SPETRT) From GSAISIE
    When 3   : Call SAISIE_NUM(VALEUR,VALPAR,PARAM2,CODTRT,SPETRT) From GSAISIE
    When 4   : Call SAISIE_DAT(VALEUR,VALPAR,PARAM2,CODTRT,SPETRT) From GSAISIE
    When 6   : Call SAISIE_CLOB(VALEUR,VALPAR,PARAM2,CODTRT,SPETRT) From GSAISIE
    When 7   : Call SAISIE_BLOB(VALEUR,VALPAR,PARAM2,CODTRT,SPETRT) From GSAISIE
   Endcase
  When 5 : # Sel liste
   Case TYPVAL
    When 1   : Call S_LIS_CHAR(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 2,5 : Call S_LIS_LIB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 3   : Call S_LIS_NUM(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 4   : Call S_LIS_DAT(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 6   : Call S_LIS_CLOB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 7   : Call S_LIS_BLOB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
   Endcase
  When 6 : # Sel table
   Case TYPVAL
    When 1   : Call S_TAB_CHAR(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 2,5 : Call S_TAB_LIB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 3   : Call S_TAB_NUM(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 4   : Call S_TAB_DAT(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 6   : Call S_TAB_CLOB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 7   : Call S_TAB_BLOB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
   Endcase
  When 7 : # Aff divers
   Case TYPVAL
    When 1   : Call S_AFF_CHAR(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 2,5 : Call S_AFF_LIB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 3   : Call S_AFF_NUM(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 4   : Call S_AFF_DAT(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 6   : Call S_AFF_CLOB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 7   : Call S_AFF_BLOB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
   Endcase
 Endcase

 # Mise à jour des paramètres passés par adresse (si action suite)

 If ACTSUI<>""
  If clalev([F:ACT])=0 : Local File ACTION    [ACT] : Endif
  If clalev([F:ATR])=0 : Local File ACTPAR    [ATR] : Endif
  If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
  Read [ACT]ACTION = ACTCUR
  Read [AFC]CODINT = FCTCUR
  NOPAR = 0
  For I=1 To [F:ACT]NBPAR
   If (I>1 or [F:ACT]TYPACT<>2)
    NOPAR += 1
    Read [ATR]NOPAR = [F:ACT]ACTION;I
    If [F:ATR]ADRVAL=1
     K = find([F:ATR]CODPAR,[F:AFC]CODPAR(0..dim([F:AFC]CODPAR)-1))
     If K & [F:AFC]VALPAR(K-1)<>""
      Onerrgo EVAL
      Case [F:ATR]TYPPAR
       When 1,4,6
        Assign [F:AFC]VALPAR(K-1) With VALPAR(NOPAR)
       When Default
        Assign [F:AFC]VALPAR(K-1) With val(VALPAR(NOPAR))
      Endcase
      Onerrgo
     Endif
    Endif
   Endif
  Next I
  ACTCUR = ACTSUI
  Goto SUITE
 Endif
Endif

Call RESET_MENU(GFONCTION)

GFONCTION = SAVFNC
If dim(GFONCTION1)>0
 GFONCTION1 = SAVFNC1
Endif
GTRAITE   = SAVPRG
GACTION   = SAVACT
GFLAG     = SAVVAR
GREPORT1  = SAVREP1
GREPORT2  = SAVREP2
GCONSULT = SAVGCONSULT :#SAM121925

If FLGNAV
 GPILNAV -= 1
 GPILNAV = max(0,GPILNAV)
Endif

If GFONCTION<>""
 Call AUTORIS
Else
 Call SET_CURFCT("",0,"") From PSADX
Endif

End

##########################################################################
# CC 15/07/2009  pour passer les clés pour les processus
##########################################################################

$EVALKEY
Local Char AKEY1(100) , AKEY2(100), WAKEY(250)
Local Integer D1,D2

WAKEY = AKEY

If TYPACT=1 and GPRODUIT=1 : # 118996
 Onerrgo EVAL
 Local Char     PROGOBJ(GLONADC)
 PROGOBJ  = "WO"+VALPAR(1)
 Gosub SETCLE From =PROGOBJ
 If dim(CLEFCY)>0 and dim(CLEDEP) and (CLEFCY<>"" or CLEDEP<>"")
  If (CLEPRIM=CLEFCY and CLEFCY<>"" ) or (CLEPRIM=CLEDEP and CLEDEP<>"")
   D2 = instr(1,WAKEY,"~")
   If D2>0
    WAKEY=right$(WAKEY,D2+1)
   Endif
  Endif
  If (CLESEC(0)=CLEFCY and CLEFCY<>"" ) or (CLESEC(0)=CLEDEP and CLEDEP<>"")
   D2 = instr(1,WAKEY,"~")
   If D2>0
    WAKEY=right$(WAKEY,D2+1)
   Endif
  Endif
 Endif
 Onerrgo
Endif
D1 = instr(1,WAKEY,"~")
If D1<>0
 AKEY1 = left$(WAKEY,D1-1)
 AKEY2 = right$(WAKEY,D1+1)
Else
 AKEY1 = WAKEY
Endif
Case TYPVAL
 When 1   : VALEUR = AKEY1      : VALPAR(2) = AKEY2 : # Char
 When 2,5 : VALEUR = val(AKEY1) : VALPAR(2) = AKEY2 : # Integer
 When 3   : VALEUR = val(AKEY1) : VALPAR(2) = AKEY2 : # Decimal
 When 4   : VALEUR = AKEY1      : VALPAR(2) = AKEY2 : # Date (elle doit être donnée sous la forme SSAAMMJJ)
Endcase
Return

$EVAL
Resume

##########################################################################
## Autorisations utilisateurs                                          ###
##########################################################################
Subprog AUTORIS
Local Integer I, ISITE, ISOC
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY   [AFF] : Endif
If clalev([F:AFP])=0 : Local File AFCTPRF   [AFP] : Endif
If clalev([F:AFT])=0 : Local File AFCTFCT   [AFT] : Endif
Call LECTURE("AFC",GFONCTION,"") From CONTOBJ
If fstat
 Raz [F:AFC]
Else
 # gh 02/12/98 pour gérer les fonctions TRTGAS, TRTGASA, GESGAUT
 I = find("GFONCTION",[F:AFC]VARIA(0..[F:AFC]NBVAR-1))
 If I
  GFONCTION = [F:AFC]VALEUR(I-1)
  If find(left$(GFONCTION,1),"'",'"') : GFONCTION = right$(GFONCTION,2) : Endif
  I = len(GFONCTION)
  If find(right$(GFONCTION,I),"'",'"') : GFONCTION = left$(GFONCTION,I-1) : Endif
  # Ne pas faire Call LECTURE("AFC",GFONCTION,"") From CONTOBJ pour les GBID...
 Endif
Endif

Raz GUSRAUZ, GUSRFCY, GNBAUZ

If dim(GUSRVID)>0 : Raz GUSRVID : Endif
Read [AFT]AFT0 = GPROFIL
If [F:AFT]ALLFCT=2   : # Toutes fonctions autorisées pour le profil
 If [F:AFC]FCYAUZ<>2 or GFONCTION="GESFCY" : # Fonctions sans sites
  If [F:AFC]TYP=2 or ([F:AFC]TYP=0 & left$(GFONCTION,3)="GES") : # Objet
   GUSRAUZ(1) = "CMNS"
  Endif
  GUSRAUZ(1) += sum([F:AFC]FLAG)
  GUSRFCY(1)  = "\"
  GNBAUZ      = 1
 Else
  For I=1 To GNBSITE
   If [F:AFC]TYP=2 : # Objet
    GUSRAUZ(I) = "CMNS"
   Endif
   GUSRAUZ(I) += sum([F:AFC]FLAG)
   GUSRFCY(I)  = GSITE(I)
  Next I
  GNBAUZ = GNBSITE
 Endif
 If dim(GUSRVID)>0
  If [F:AFC]TYP=2 : # Objet
   GUSRVID = "CMNS"
  Endif
  GUSRVID += sum([F:AFC]FLAG)
 Endif
Else
 If [F:AFC]FCYAUZ<>2 : # Fonctions sans sites
  Read [AFP]AFP0 = GPROFIL ; GFONCTION ; ""
  If !fstat & [F:AFP]ACS=2
   GUSRAUZ(1) = [F:AFP]OPT
   GUSRFCY(1) = "\"
   GNBAUZ     = 1
  Endif
 Else
  If dim(GUSRVID)>0
   Read [AFP]AFP0 = GPROFIL ; GFONCTION ; ""
   If !fstat
    If [F:AFP]ACS=2
     GUSRVID = [F:AFP]OPT
    Else
     GUSRVID = "!" : # Non accés au site vide
    Endif
   Else
    If [F:AFC]TYP=2 : # Objet
     GUSRVID = "CMNS"
    Endif
    GUSRVID += sum([F:AFC]FLAG)
   Endif
  Endif
  For [AFF]AFF1 Where PRFCOD=GPROFIL & FNC=GFONCTION & FCY<>""
   ISITE = find([F:AFF]FCY,GSITE(1..GNBSITE))
   If ISITE
    GNBAUZ += 1
    GUSRAUZ(GNBAUZ) = [F:AFF]OPT
    GUSRFCY(GNBAUZ) = [F:AFF]FCY
   Endif
  Next
  #117035 cas ADMCA sur GESFCY
  If GNBAUZ=0 & GFONCTION="GESFCY"
   Read [AFP]AFP0 = GPROFIL ; GFONCTION ; ""
   If !fstat & [F:AFP]ACS=2
    GUSRAUZ(1) = [F:AFP]OPT
    GUSRFCY(1) = "\"
    GNBAUZ     = 1
   Endif
  Endif
 Endif
Endif

If [F:AFC]FCYAUZ<>2
 GUSRFCT = ""
Else
 GUSRFCT = GFONCTION
Endif
GFCYDEF(0) = GFCYDEF([F:AFC]MODULE) : # Le site par défaut du module
ISITE      = find(GFCYDEF(0),GSITE(1..GNBSITE))
If ISITE<>0
 GDEFSOC = GSOCSITE(ISITE) : # Société par défaut
Else
 # mb 19.8.13 Ce paramètre n'existe plus
 #GDEFSOC = func AFNC.PARAMUTIL("DEFSOC","","")
 #If GDEFSOC<>"" & !find(GDEFSOC,GSOC(1..GNBSOC))
 # GDEFSOC = ""
 #Endif
 If GDEFSOC=""
  GDEFSOC = GSOCSITE(1)
 Endif
Endif
ISOC = find(GDEFSOC,GSOC(1..GNBSOC))
If ISOC
 GLOCALDEV = GDEVSOC(ISOC)
Else
 GLOCALDEV = GSYSCUR
Endif

GPOINT = "AUTORIS" : Gosub ENTREE From EXEFNC2

#87108
If dim(GACTX)>0
 If fmet GACTX.AGETLIC_EXPIRED(func ASYRLIC.GET_CHPRODUCTSTDCODE)=[V]CST_ATRUE | fmet GACTX.AGETLICFCT(GFONCTION)<>[V]CST_ATRUE
  Raz GUSRAUZ(1)
  Raz GUSRVID
  If GCONSULT<>2
   GCONSULT=1
  Endif
  End
 Endif
Endif

# Infos pour psadx
Call SET_CURFCT(GFONCTION,[F:AFC]MODULE,"") From PSADX

End

#####################################################################
## Intitulé d'une fonction                                        ###
#####################################################################
Subprog TITFONC(FONCTION,TIT,TYP)
Variable Char TIT()
Variable Char FONCTION()
Value Integer TYP
TIT=""
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
Call LECTURE("AFC",FONCTION,"") From CONTOBJ
If fstat=0
 If TYP=0 & [F:AFC]LIBMENU<>0
  Call TEXTE([F:AFC]LIBMENU,TIT) From OBJDIV
 Elsif TYP=1 & [F:AFC]NOM
  Call TEXTE([F:AFC]NOM,TIT) From OBJDIV
 Endif
Endif
Close Local File [AFC]
End

#####################################################################
## Menus utilisateurs
#####################################################################
Subprog MENADD

Local File AFONCTION [AFC] , AUTILIS [AUS] , ATEXTE [ATX]
Local Integer J, K
K = GSTAFCT-1

Read [AUS]CODUSR = GUSER
If [F:AUS]NBFNC>0
 Additm 2047 Titled "" To 298 At 70
 Additm 2047 Titled "" To 320 At 70
 Additm 2047 Titled "" To 325 At 70
 For J=1 To [F:AUS]NBFNC
  Read [AFC]CODINT = [F:AUS]FNCCOD(J-1)
  GFNCUSR(J) = [F:AUS]FNCCOD(J-1)
  Call TEXTE([F:AFC]LIBMENU,TEXTE) From OBJDIV
  Additm K+J,627+J Titled TEXTE-[F:AUS]FNCPAR(J-1) To 298 At 70+J : # Shift F5..12
  Additm K+J,627+J Titled TEXTE-[F:AUS]FNCPAR(J-1) To 320 At 70+J : # Shift F5..12
  Additm K+J,627+J Titled TEXTE-[F:AUS]FNCPAR(J-1) To 325 At 70+J : # Shift F5..12
  Case J
   When 1 : Global Onkey K+1 Titled TEXTE Call EXEMEN1 From EXEFNC
   When 2 : Global Onkey K+2 Titled TEXTE Call EXEMEN2 From EXEFNC
   When 3 : Global Onkey K+3 Titled TEXTE Call EXEMEN3 From EXEFNC
   When 4 : Global Onkey K+4 Titled TEXTE Call EXEMEN4 From EXEFNC
   When 5 : Global Onkey K+5 Titled TEXTE Call EXEMEN5 From EXEFNC
   When 6 : Global Onkey K+6 Titled TEXTE Call EXEMEN6 From EXEFNC
   When 7 : Global Onkey K+7 Titled TEXTE Call EXEMEN7 From EXEFNC
   When 8 : Global Onkey K+8 Titled TEXTE Call EXEMEN8 From EXEFNC
  Endcase
 Next J
Endif
Close Local File [AFC] , [AUS] , [ATX]
End

#####################################################################
Subprog EXEMEN1
Local Integer TOUCHE : TOUCHE = 1 : Goto EXECMEN
Subprog EXEMEN2
Local Integer TOUCHE : TOUCHE = 2 : Goto EXECMEN
Subprog EXEMEN3
Local Integer TOUCHE : TOUCHE = 3 : Goto EXECMEN
Subprog EXEMEN4
Local Integer TOUCHE : TOUCHE = 4 : Goto EXECMEN
Subprog EXEMEN5
Local Integer TOUCHE : TOUCHE = 5 : Goto EXECMEN
Subprog EXEMEN6
Local Integer TOUCHE : TOUCHE = 6 : Goto EXECMEN
Subprog EXEMEN7
Local Integer TOUCHE : TOUCHE = 7 : Goto EXECMEN
Subprog EXEMEN8
Local Integer TOUCHE : TOUCHE = 8 : Goto EXECMEN

$EXECMEN
Local Integer FLGAUS , J
Local Char    FONCTION(GLONAFC) , VARIANTE(10)
Local Char    CONTEXTE
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : FLGAUS = 1 : Endif
Read [AUS]CODUSR = GUSER
FONCTION = [F:AUS]FNCCOD(TOUCHE-1)
VARIANTE = [F:AUS]FNCPAR(TOUCHE-1)
If FLGAUS : Close Local File [AUS] : Endif
If FONCTION<>""
 CONTEXTE = FONCTION+"~"+VARIANTE
 Nap =CONTEXTE
Endif
mkstat = 2
End

$ERREXE
Call ERREUR(errmes$(errn)-errm) From GESECRAN
End

#####################################################################
Subprog SET_MENU(FNC)
Value Char FNC
Local Integer TOUCHE
For TOUCHE=1 To 8
 If FNC=GFNCUSR(TOUCHE)
  GTOUCHE(TOUCHE) = 1
  Disable GSTAFCT+TOUCHE-1
 Endif
Next TOUCHE
End

#####################################################################
Subprog RESET_MENU(FNC)
Value Char FNC
Local Integer TOUCHE
For TOUCHE=1 To 8
 If FNC=GFNCUSR(TOUCHE)
  GTOUCHE(TOUCHE) = 0
  Enable GSTAFCT+TOUCHE-1
 Endif
Next TOUCHE
End

###################################################################################################
# Sélection d'une fonction et Exécution de cette fonction (Fichier/Exécuter du menu principal)
###################################################################################################

$ACTION
#Infbox ACTION
Case ACTION
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
 When "OUVRE"       : Gosub OUVRE
 When "INIT"        : Gosub INIT
 When "SETBOUT"     : Gosub SETBOUT
 When "DEBUT"       : Gosub DEBUT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "BOUTON"      : Gosub BOUTON
 When "OK"          : Gosub OK
 When "SORTIE"      : Gosub SORTIE
 When "AP_CHOIX"    : Gosub APCHOIX
Endcase
Return

$APCHOIX
#  Autoriser Return à la place du clic pour exécuter la fonction saisie
If REPONSE<>GSTARET : Return : Endif
If [M]FONCTION=""  & [M]RECHFCT="": Return : Endif
Read [F:AFC]CODINT = [M]FONCTION
If !fstat
 GBIDC1 = [M]FONCTION
 GBIDC2 = ""
 mkstat = 1024+7
Elsif [M]RECHFCT<> ""
 Local Char   PARMSK(250)(1..20)
 PARMSK(1)   = [M:EXE]RECHFCT
 PARMSK(2)   = "1"
 GBIDC1 = ""
 Call SAISIE_CHAR(GBIDC1,PARMSK,"ARECHMEN","ARECHMEN","SPEARECHMEN") From GSAISIE
 [M]FONCTION = GBIDC1
 GBIDC2 =""
 mkstat = 1024+7
Endif
Return

$INIT
Local Integer OGCHGENV
Local Char    SAVFONC1(GLONAFC)
If dim(GCHGENV)>0 : # Géode
 OGCHGENV = GCHGENV
 GCHGENV = 0
Endif
If dim(GFONC1)>0 : # X3
 SAVFONC1 = GFONC1
Endif
# Contrôle qu'il n'y a pas une maj en cours
If (GNBMASKOUV>0 and GREP<>"") or (dim(GFENMAJ)>0 and GNBMASKOUV>1 and find(1,GFENMAJ(1..GNBMASKOUV-1)))
  # Vous êtes en mise à jour, il faut valider votre travail avant de passer à la fonction demandée
  Call ERREUR(mess(58,127,1)) From GESECRAN
  FIN = 1 : Return
Endif

Return

$SORTIE
If dim(GCHGENV)>0 : # Géode
 GCHGENV = OGCHGENV
Endif
If dim(GFONC1)>0 : # X3
 GFONC1 = SAVFONC1
Endif
Return

$OUVRE
Local Integer ER , IRG , OKFAV
Local Char    MESSAG(100)
Raz GMESSAGE
Return

$SETBOUT
If GHISTO or !OKFAV
 Call VIREBOUT(CHMEN,"a") From GOBJET
Endif
Return

$BOUTON
Case BOUT
 When "a" : Gosub DEBUT
Endcase
Return

$DEBUT
# On charge la liste des favoris utilisateurs
Onerrgo ER
If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
If clalev([F:AFE])=0 : Local File AFCTEXE   [AFE] : Endif
If clalev([F:AFP])=0 : Local File AFCTPRF   [AFP] : Endif
If clalev([F:AFT])=0 : Local File AFCTFCT   [AFT] : Endif
Onerrgo
Read [AUS]CODUSR=GUSER
If fstat : Grizo [M]10 : Return : Endif
OKFAV = 0
Read [AFT]AFT0 = GPROFIL
If [F:AFT]ALLFCT=2
 OKFAV = 1
Else
 Read [AFP]AFP0 = GPROFIL ; "CHXPERSO"
 If !fstat & [F:AFP]ACS=2
  OKFAV = 1
 Endif
Endif
Raz [M]
IRG = 0
[M]NBLIG=0 #X3-110596 9/28/18
For I=1 To min(dim([F:AUS]FNCCOD),dim([M]F1))
 If [F:AUS]FNCCOD(I-1)<>""
  Raz MESSAG
  Call CNAVIG(3,[F:AUS]FNCCOD(I-1),"","","","","",MESSAG)
  If MESSAG="" & [F:AUS]FNCCOD(I-1)<>"CHGENV" & IRG<dim([M]F1)
   [M]FONC1(IRG)  = [F:AUS]FNCCOD(I-1)
   [M]F1(IRG)     = "12"
   [M]TRA1(IRG)   = [F:AUS]FNCPAR(I-1)
   Read [AFC]CODINT = [F:AUS]FNCCOD(I-1)
   If !fstat
    Call TEXTE([F:AFC]NOM,[M]LIBF1(IRG)) From OBJDIV
   Endif
   IRG += 1
   [M]NBLIG += 1 #X3-110596 9/28/18
  Endif
 Endif
Next I
Raz GBIDC1 , GBIDC2
# Historique fonctions
If clalev([F:AFE])>0
 Filter [AFE] Where USR=GUSER & FCT<>"" Order By Key AFE0 Desc
 IRG = 0
 [M]NBLIG2=0 #X3-110596 9/28/18
 For [AFE]AFE0
  Call CNAVIG(3,[F:AFE]FCT,"","","","","",MESSAG)
  If MESSAG="" and [F:AFE]FCT<>"CHGENV"
   If IRG>=dim([M]F2) : Break : Endif
   [M]F2(IRG)="12"
   [M]FONC2(IRG)  = [F:AFE]FCT
   [M]TRA2(IRG)   = [F:AFE]TRN
   Read [AFC]CODINT=[F:AFE]FCT
   Call TEXTE([F:AFC]NOM,[M]LIBF2(IRG)) From OBJDIV
   IRG += 1
   [M]NBLIG2 += 1 #X3-110596 9/28/18
  Endif
 Next AFE
 Filter [AFE]
Endif
Affzo [M]
Chgtbk [M]40 With space$(9)+mess(243,139,1) : # Favoris fonctions
Chgtbk [M]30 With space$(9)+mess(3,139,1)   : # Historique
Chgtbk [M]10 With space$(9)+mess(242,139,1) : # Appel Direct
Chgtbk [M]20 With space$(9)+mess(43,100,1)  : # Recherche
zonsui = "FONCTION"
Return

$OK
If [M]FONCTION<>""
 GBIDC2 = ""
 GBIDC1 = [M]FONCTION
Elsif [M:EXE]RECHFCT<>""
 Local Char   PARMSK(250)(1..20)
 PARMSK(1)   = [M:EXE]RECHFCT
 PARMSK(2)   = "1"
 GBIDC1 = ""
 Call SAISIE_CHAR(GBIDC1,PARMSK,"ARECHMEN","ARECHMEN","SPEARECHMEN") From GSAISIE
 [M]FONCTION = GBIDC1
 GBIDC2 =""
Else
 FIN = 0
Endif
Return

$CONTROLE
If GBIDC1<>"" : FIN = 0 : Endif
Return

$EXEC
If GBIDC1<>""
 If dim(GGBOUTGLO)<0 : Gosub BOUTGLO : Endif
 If GNBMASKOUV<=0 : Gosub INITMEN : Endif
 Call EXEFNC(GBIDC1,GBIDC2)
Endif
Return

##############################################
$SEL_TABLE
Case TABLE
 When "SELEXEFNC" : Gosub SEL_EXEFNC
Endcase
Return

$FIN_TABLE
Case TABLE
 When "SELEXEFNC" : Gosub FIN_EXEFNC
Endcase
Return

$SEL_EXEFNC
OBJET   = "AFC"
OPTIONS = "T"
Gosub OUV_EXEFNC
DEFPAG = 1
Default File [AFC_]
Return

$OUV_EXEFNC
If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif
If clalev([F:AMU])=0 : Local File AMENUSER  [AMU] : Endif
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY   [AFF] : Endif
If clalev([F:AFP])=0 : Local File AFCTPRF   [AFP] : Endif
If clalev([F:AFT])=0 : Local File AFCTFCT   [AFT] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE    [ATX] : Endif
If clalev([F:AME])=0 : Local File AMETUTI   [AME] : Endif
Read [AUS]CODUSR = GUSER
Read [AFT]AFT0 = GPROFIL
Local Char WPRFMEN(10)
If [F:AUS]PRFMEN=""
 Read [AME]AME0 = [F:AUS]CODMET
 WPRFMEN = [F:AME]PRFMEN
Else
 WPRFMEN = [F:AUS]PRFMEN
Endif
# Dans un dossier historique, on n'autorise que les fonctions définies dans le profil menu
If GHISTO & [F:AFT]ALLFCT=2
 Link [AFC] With
& [AMU]MENFCT ~= WPRFMEN;[F:AFC]CODINT,
& [ATX]NUMERO = GLANGUE;[F:AFC]NOM
& As [AFC_]
Elsif GHISTO
 Link [AFC] With
& [AFF]AFF0 ~= "";GPROFIL;[F:AFC]CODINT,
& [AMU]MENFCT ~= WPRFMEN;[F:AFC]CODINT,
& [AFP]AFP0 = GPROFIL;[F:AFC]CODINT;"",
& [ATX]NUMERO = GLANGUE;[F:AFC]NOM
& As [AFC_]
& Where [F:AFC]FCYAUZ=2 or [F:AFP]ACS=2
Elsif [F:AFT]ALLFCT=2
 Link [AFC] With
& [ATX]NUMERO = GLANGUE;[F:AFC]NOM
& As [AFC_]
Else
 Link [AFC] With
& [AFF]AFF0 ~= "";GPROFIL;[F:AFC]CODINT,
& [AFP]AFP0 = GPROFIL;[F:AFC]CODINT;"",
& [ATX]NUMERO = GLANGUE;[F:AFC]NOM
& As [AFC_]
& Where [F:AFC]FCYAUZ=2 or [F:AFP]ACS=2
Endif
Return

$FIN_EXEFNC
Close Local File [AUS] , [AMU] , [AFC] , [AFF] , [AFP] , [AFT] , [ATX]
Return

Subprog C_FONCTION(VALEUR)
Variable Char    VALEUR()
Local Char MESSAG(100)
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
If VALEUR="" : [M]LIBFON="" : Affzo [M]LIBFON : End : Endif
#   Bug 40620  --  On n'accède pas aux fonctions autre que superviseur sur dossier mère
If nomap=GDOSX3 and GADONIX<>2
  Read [AFC]CODINT=VALEUR
  If fstat<>0 or !find([F:AFC]MODULE,1,9,10)
    Call ERREUR(mess(1,123,1)) From GESECRAN  : # Fonction non autorisée
    mkstat = 2 : End
  Endif
Endif
Raz MESSAG
Call CNAVIG(3,VALEUR,"","","","","",MESSAG)
If MESSAG<>"" or VALEUR="CHGENV"
 If MESSAG="" : MESSAG=mess(17,130,1) : Endif
 # Issue X3-56454 - 2018-07-10 by ALSHE : second line of message not needed any more
 # +"\"+mess(145,127,1) : Endif : # "Fonction non appelable dans le contexte" S'il vous plaît fermer la session et essayez à nouveau.
 Call ERREUR(MESSAG) From GESECRAN : # Fonction non appelable dans le contexte
 mkstat = 2 : End
Else
 Gosub OUV_EXEFNC
 Read [AFC_] = VALEUR
 If !fstat
  Call TEXTE([F:AFC]NOM,[M]LIBFON) From OBJDIV
 Else
  Call ERREUR(mess(1,123,1)) From GESECRAN  : # Fonction non autorisée
  mkstat = 2 : End
 Endif
 Gosub FIN_EXEFNC
Endif
End

Subprog AS_FFR(VALEUR)
Variable Char     VALEUR
If [M]RECHFCT="" : mkstat = 2 : Endif
End

Subprog AS_FFO(VALEUR)
Variable Char     VALEUR
If [M]FONCTION="" : mkstat = 2 : Endif
End

Subprog CL_FFO(VALEUR)
Variable Char    VALEUR()
