GBIDC1 = "ARECHMEN"
GBIDC2 = ""
GBIDRECH = [M]RECHFCT
mkstat = 1024+7
End

#########################################################
## Exécution d'une fonction depuis le navigateur V5
#########################################################
Subprog EXEFNC1(FONCTION,VARIANTE)
Value Char FONCTION
Value Char VARIANTE

Local Char    MESSAG(100) , VARIA(30) , SAVFONC1(GLONAFC)
Raz MESSAG

# Contrôle qu'il n'y a pas une maj en cours
If GREP<>"" or (dim(GFENMAJ)>0 and GNBMASKOUV>1 and find(1,GFENMAJ(1..GNBMASKOUV-1)))
  # Vous êtes en mise à jour, il faut valider votre travail avant de passer à la fonction demandée
  Call ERREUR(mess(58,127,1)) From GESECRAN
  End
Endif

# Controle que la fonction peut être appelée
Call CNAVIG(3,FONCTION,"","","","","",MESSAG)
VARIA = VARIANTE
If VARIA="0" : VARIA = "" : Endif
If MESSAG=""
  If GNBMASKOUV=0 : Gosub INITMEN : Endif
  SAVFONC1 = GFONC1
  Call EXEFNC(FONCTION,VARIA)
  GFONC1 = SAVFONC1

# Pour Géode               Bug 65015   CC 11/10/2010
  Call AFF_ENV From MENU

Else
  Call ERREUR(MESSAG) From GESECRAN
Endif
End

Subprog CNAVIG(TYP,FONCT,ACTION,OBJET,CONSULT,WIND1,WIND2,MESSAG)
Value Integer TYP
Value Char FONCT
Value Char ACTION
Value Char OBJET
Value Char CONSULT
Value Char WIND1
Value Char WIND2
Variable Char MESSAG

#   Contrôle la navigation et charge l'empilement si autorisé dans GMASKOUV
#   Pour les fonctions à 2 fenêtres possibles (consultations et Gtraite) on les met dans le même niveau
#   Le fonctionement est exclusif. C'est la première valeur non nulle qui impose le mode de fonctionnement.
#   Si FONCT est non nul on travaille sur une fonction, si ACTION est non nul .... le reste est ignoré.
#   Seule exception WIND1 et WIND2 sont traités tous les 2
#   Selon la valeur de TYP, dans tous les cas on charge GMASKOUV si OK
#   TYP=1 si pb on renvoie le message d'erreur dans MESSAG si on n'a pas pu empiler
#   TYP=2 si pb on génère un Call ERREUR
#   TYP=3 on ne fait que contrôler et on ne génère pas de Call ERREUR
Local Char FEN1,FEN2,FENXX(20)(1..10)     : # FENXX a été rajouté pour traiter les actions suite bug 45531
Local Integer NBXX,CONTACSUI,INBX
Local Char CONS : CONS=CONSULT
Local Char ACT : ACT=ACTION
Local Char OBJ : OBJ=OBJET
Raz MESSAG
If dim(GNBMASKOUV)<0 : End : Endif
#  Controle par rapport au niveau (on limite à 10) ou à saturation des ressources

#  freemem         : # Mémoire libre (en octets)
#  maxmem          : # mémoire totale (en octets)
#  [S]dbglong(9)   : # Nombre de tables ouvertes
#  [S]dbglong(11)  : # Nombre max de tables ouvertes autorisées (adxmto)
#  [S]dbglong(12)  : # Nombre de masques ouverts
#  [S]dbglong(14)  : # Nombre maximum de masques ouverts autorisés (en dur dans le moteur)
#  [S]dbglong(19)  : # Nombre de traitements en mémoire chargés
#  adxmpr          : # Nombre maximum de traitements en mémoire autorisés

If GNBMASKOUV>=10
  MESSAG=mess(79,9014,1) : # "Trop de fonctions ouvertes"
  Goto TRAITERR
Endif

If FONCT<>"" : Gosub FONCT : Goto WIND  : Endif
If ACT<>""   : Gosub ACT   : Goto WIND  : Endif
If OBJ<>""   : Gosub OBJ   : Goto WIND  : Endif
If CONS<>""  : Gosub CONS  : Goto WIND  : Endif

FEN1=WIND1
FEN2=WIND2

$WIND
GPOINT = "CONTNAVIG" : Gosub ENTREE From EXEFNC2 : # mb 16.1.8
If FEN1="" and FEN2<>"" : FEN1=FEN2 : FEN2="" : Endif
If MESSAG<>"" : Goto TRAITERR : Endif : #118612
Onerrgo ERRFEN
If FEN1<>"" : Gosub NAVIGMSK From="WG"+FEN1 : Endif
If NAVMSK<>"" : Gosub CONTMSK  : Endif
If MESSAG<>"" : Goto TRAITERR : Endif
If FEN2<>""
  Gosub NAVIGMSK From="WG"+FEN2
  If NAVMSK<>"" : Gosub CONTMSK : Endif
  If MESSAG<>""
    If FEN1<>"" :GNBMASKOUV-=1 : Endif
    Goto TRAITERR
  Endif
Endif
If NBXX>0
  CONTACSUI=1
  For INBX=1 To NBXX
    Gosub NAVIGMSK From="WG"+FENXX(INBX)
    If NAVMSK<>"" : Gosub CONTMSK : Endif
    If MESSAG<>""
      If FEN1<>"" :GNBMASKOUV-=1 : Endif
      If FEN2<>"" :GNBMASKOUV-=1 : Endif
      Goto TRAITERR
    Endif
  Next INBX
Endif
Onerrgo
Gosub AFFM
End

$TRAITERR
Onerrgo
If TYP=2
  Call ERREUR(MESSAG) From GESECRAN
Endif
Gosub AFFM
End

$CONTMSK
If GNBMASKOUV=0 : Goto ADDMSK : Endif
# Contrôle qu'il n'y a pas déjà un masque de même abréviation ouvert
Local Char MASKC(20)(1..50)
Local Integer I,J,D1,DOLD,NBKC
D1=0
For I=1 To 100
  DOLD=D1+1
  D1=instr(D1+1,NAVMSK,";")
  If D1=0 : Break 1 : Endif
  NBKC+=1
  MASKC(NBKC)=mid$(NAVMSK,DOLD,D1-DOLD+1)
Next I
For I=1 To NBKC
  For J=1 To GNBMASKOUV
    # Issue X3-53895 - 2018-02-05 by CCC : by adding ";" at the begining, the mask to find must be between 2 ";"
    #If instr(1,GMASKOUV(J),MASKC(I))<>0
    If instr(1,";"+GMASKOUV(J),";"+MASKC(I))<>0
      MESSAG=mess(17,130,1)
      # Issue X3-56454 - 2018-07-10 by ALSHE : second line of message not needed any more
      #+"\"+mess(145,127,1) : # "Fonction non appelable dans le contexte" S'il vous plaît fermer la session et essayez à nouveau.
      Break 2
    Endif
  Next J
Next I
If MESSAG<>"" : Return : Endif
$ADDMSK
If TYP<>3
  GNBMASKOUV+=1
  GMASKOUV(GNBMASKOUV)=NAVMSK
  If dim(GFENMAJ)>0 and GNBMASKOUV>1
    GFENMAJ((GNBMASKOUV-1))=0
    If GREP<>"" GFENMAJ((GNBMASKOUV-1))=1 : Endif
  Endif
Endif
Return

$ERRFEN
Resume

$FONCT
Local File AFONCTION [AF_C]
If GNBMASKOUV>0
 Read [AF_C]CODINT=GFONCTION
 If !fstat & dim([F:AF_C]NAVIG)>0 & find([F:AF_C]NAVIG,3,4) : # Interdite depuis/Interdite dans tous les cas
  MESSAG=mess(272,139,1)  : #  Navigation interdite
  Return
 Endif
Endif
Read [AF_C]CODINT=FONCT
If fstat<>0
  MESSAG=mess(162,123,1)  : #  Fonction inexistante
  Return
Elsif dim([F:AF_C]NAVIG)>0 & find([F:AF_C]NAVIG,2,4) & GNBMASKOUV>0 : # Interdite vers/Interdite dans tous les cas
  MESSAG=mess(272,139,1)  : #  Navigation interdite
  Return
Endif
ACT=[F:AF_C]ACTION
If ACT="" and [F:AF_C]TRAIT<>"" : Return : Endif  : # Pour pouvoir exécuter des traitements

$ACT
Local File ACTION [AC_T]
Read [AC_T]ACTION=ACT
If fstat<>0
  MESSAG=ACT-":"-mess(84,133,1)  : #  Action inexistante
  Return
Elsif dim([F:AC_T]NOWEB)>0 & [F:AC_T]NOWEB=2 & GBROWS
  MESSAG=ACT-":"-mess(267,139,1)  : #  Cette action ne peut pas être lancée en interactif
  Return
Endif

#  Gestion d'objet (on ne devrait jamais arriver par ce canal, on n'a pas le code objet)
If [F:AC_T]TYP=1
  If FONCT<>""
    OBJ=vireblc([F:AF_C]VALPAR(0),2)
    If find(left$(OBJ,1),'"',"'") & find(right$(OBJ,len(OBJ)),'"',"'")
      OBJ=seg$(OBJ,2,len(OBJ)-1)
      Goto OBJ
    Endif
  Else
    # MESSAG="Controle appel objet impossible"   on laisse passer, c'est le GOBJET qui bloquera
    Return
  Endif
Endif

#  Consultation (on ne devrait jamais arriver par ce canal, mais on a le code consultation)
If [F:AC_T]TYP=2 : CONS=PARAM1 : Goto CONS : Endif

#  --- Fenêtres appelées par l'action  (PARAM2 et PARAM4)
If [F:AC_T]PARAM2<>"" : FEN1=[F:AC_T]PARAM2 : Endif
If [F:AC_T]PARAM4<>"" : FEN2=[F:AC_T]PARAM4 : Endif

#  --- CC 31/01/2008  Ajout du contrôle de la (des) action(s) suite (on gère à 3 niveaux)^$ACTSUINAV
$ACTSUINAV
If [F:AC_T]ACTSUI<>""
  Read [AC_T]ACTION=[F:AC_T]ACTSUI
  If fstat=0
    If [F:AC_T]PARAM2<>"" : NBXX+=1 : FENXX(NBXX)=[F:AC_T]PARAM2 : Endif
    If [F:AC_T]PARAM4<>"" : NBXX+=1 : FENXX(NBXX)=[F:AC_T]PARAM4 : Endif
    If NBXX<10 : Goto ACTSUINAV : Endif
  Endif
Endif
Return

$OBJ
FEN1="O"+OBJ
FEN2=""
Local File AWINDOW [AW_I]
Read [AW_I]AWI0 = FEN1
If fstat or [F:AW_I]MDL=2 or [F:AW_I]ENAFLG<>2 : # On remplace la fenetre modele par une existante
  Filter [AW_I] Where OBJ=[L]OBJ & [F:AW_I]MDL<>2 & [F:AW_I]ENAFLG=2
  For [AW_I]
    FEN1=[F:AW_I]WIN
    Break 1
  Next
  Filter [AW_I]
Endif
Close Local File [AW_I]
Return

$CONS
Local File ACONSULT [AC_N]
Read [AC_N]ACN0 = CONS
If fstat : # Consultation non définie
  MESSAG=mess(16,126,1)
  Return
Endif
FEN1=[F:AC_N]WND1      : # Fenêtre principale
Return

$AFFM
Return
Local Char TTT(250)
TTT=num$(GNBMASKOUV)-MESSAG+"\"
For I=1 To GNBMASKOUV
  TTT+=GMASKOUV(I)+"\"
Next I
Call MESSAGE(TTT) From GESECRAN
Return

#---------------------------------------------------------------------------------#
Subprog SET_DERFCT(FONCTION,VARIANTE)
Value Char    FONCTION , VARIANTE
Local Integer I , K , OK , ER , MAXFCT
Local Char SYMBOLE(30)
MAXFCT = 16
Onerrgo ER
If clalev([F:AFE])=0 : Local File AFCTEXE [AFE] : Endif
Onerrgo
If ER : End : Endif
If !adxlog
 SYMBOLE = "AFCTEXE/"+GUSER
 Lock =SYMBOLE With lockwait=0
 If !fstat
  Gosub TR_FCT
  Unlock =SYMBOLE
 Endif
Else
 Gosub MAJ_FCT
Endif
End

$ER
ER = errn
Resume

$TR_FCT
GOK = 1
Trbegin [AFE]
 Gosub MAJ_FCT
 If GOK=0 : Goto AB_TR_FCT : Endif
Commit
Return

$AB_TR_FCT
Rollback
Return

$MAJ_FCT
Filter [AFE] Where USR=GUSER
Read [AFE]AFE0 Last
If fstat<=2
 If [F:AFE]LIG>=32000
  Delete [AFE] Where USR=GUSER
  K = 1
 Else
  K = [F:AFE]LIG+1
 Endif
Else
 K = 1
Endif
Raz I, OK
For [AFE]AFE0
 If [F:AFE]FCT=FONCTION
  OK = 1 : Break
 Endif
 I += 1
Next
Filter [AFE]
If OK
 [F:AFE]TRN = VARIANTE
 [F:AFE]LIG = K
 Rewrite [AFE]
Else
 If I>=MAXFCT
  Read [AFE]AFE0(1) = GUSER
  If fstat<=2 : OK = 1 : Endif
 Endif
 Raz [F:AFE]
 [F:AFE]USR  = GUSER
 [F:AFE]FCT  = FONCTION
 [F:AFE]TRN  = VARIANTE
 [F:AFE]LIG  = K
 If !OK
  Write [AFE]
 Else
  Rewrite [AFE]
 Endif
Endif
If fstat
 GOK = 0 : Call FSTA("AFE") From GLOCK
Endif
Return

#################################################################
## Contrôle que le site est autorisé pour la fonction courante ##
#################################################################
Subprog CONTFCY(VALEUR)
Variable Char     VALEUR
If VALEUR="" : End : Endif
If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
 GMESSAGE = VALEUR-":"-mess(2,104,1) : # Vous n'avez pas les droits pour ce site
 mkstat = 2
Else
 mkstat = 0    # CP : 13/04/01
Endif
End

Subprog CONTCPY(SOC)
Variable Char    SOC
Local    Integer ISITE, I, OK
If [L]SOC="" : End : Endif
If GUSRFCY(1)="\" : End : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
OK = 0
Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
Case [F:CPY]CPYLEGFLG
 When 2  : # Société juridique
  For I=1 To GNBSITE
   If [L]SOC=GSOCSITE(I) & find(GSITE(I),GUSRFCY(1..GNBAUZ))
    OK = 1 : Break
   Endif
  Next I
 When Default
  For [FGR]FGR0 Where CPY=[L]SOC
   If find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
    OK = 1 : Break
   Endif
  Next
Endcase
If !OK
 GMESSAGE = [L]SOC-mess(31,104,1) : # Aucun site n'est accessible dans cette société
 mkstat = 1
Endif
End

#################################################################
## Recherche du site par défaut d'une société                  ##
#################################################################
Subprog INIFCY(SITE,SOC)
Variable Char    SITE
Value    Char    SOC
Local    Integer I, K
Local    Char    NEWSITE(GLONFCY)
If mkstat : End : Endif   :# GB 260301 : ajout mkstat
K = 0
If [L]SOC=""
 If GUSRFCY(1)="\"
  [L]NEWSITE = GFCYDEF(0)
 Elsif find(GFCYDEF(0),GUSRFCY(1..GNBAUZ)) : # A-t-on les autorisations pour le site par défaut ?
  [L]NEWSITE = GFCYDEF(0)
  If GNBAUZ=1
   K = 1 : # C'est le seul site
  Endif
 Else
  [L]NEWSITE = GUSRFCY(1) : # On prend le premier site autorisé
  If GNBAUZ=1
   K = 1 : # C'est le seul site
  Endif
 Endif
Else
 If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
 If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
 Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
 Case [F:CPY]CPYLEGFLG
  When 2 : # Société juridique
   I = find(GFCYDEF(0),GSITE(1..GNBSITE))
   If I & GSOCSITE(I)=[L]SOC & (GUSRFCY(1)="\" | find(GFCYDEF(0),GUSRFCY(1..GNBAUZ)))
    [L]NEWSITE = GFCYDEF(0)
   Else
    I = find([F:CPY]MAIFCY,GSITE(1..GNBSITE))
    If I & GSOCSITE(I)=[L]SOC & (GUSRFCY(1)="\" | find([F:CPY]MAIFCY,GUSRFCY(1..GNBAUZ)))
     [L]NEWSITE = [F:CPY]MAIFCY
    Endif
   Endif
   For I=1 To GNBSITE
    If [L]SOC=GSOCSITE(I) & (GUSRFCY(1)="\" | find(GSITE(I),GUSRFCY(1..GNBAUZ)))
     If [L]NEWSITE=""
      [L]NEWSITE = GSITE(I)
     Endif
     K += 1
    Endif
   Next I
  When Default
   For [FGR]FGR0 Where CPY=[L]SOC
    If GUSRFCY(1)="\" | find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
     If [L]NEWSITE="" | [F:FGR]FCY=GFCYDEF(0)
      [L]NEWSITE = [F:FGR]FCY
     Endif
     K += 1
    Endif
   Next
 Endcase
Endif
If [L]SITE="" | ([L]SITE<>[L]NEWSITE & K=1)  # GB 28/09/01: si site<>"", il n'était pas réaffecté
 [L]SITE = [L]NEWSITE
Endif
## PP 06/11/2001 : Ce mkstat=2 posait problème dans les écrans qui appelaient l'action
## INIFCY et qui appelaient d'autres actions en contrôle, après zone, après modif
## (écrans saisie pièces, saisie par lot, fiche immo,...)
#If K=1 : # Un seul site accessible dans la société
# mkstat = 2
#Endif
End

Subprog INICPY(SOC)
Variable Char     SOC
Local    Integer  ISITE, OK, I
If [L]SOC<>"" : End : Endif
If GUSRFCY(1)="\" : # Pas d'autorisation par site -> on prend la société du site par défaut
 ISITE = find(GFCYDEF(0),GSITE(1..GNBSITE))
 If ISITE
  [L]SOC = GSOCSITE(ISITE)
 Endif
Elsif GNBAUZ=1 : # Accès qu'à un site
 ISITE = find(GUSRFCY(1),GSITE(1..GNBSITE))
 If ISITE
  [L]SOC = GSOCSITE(ISITE)
  # mkstat = 2 : # PP 08/03/2001 : Bug 13335 (Idem ce qui a été corrigé dans INIFCY le 06/11/01)
 Endif
Else  : # On prend le site par défaut du module
 ISITE = find(GFCYDEF(0),GSITE(1..GNBSITE))
 If ISITE
  OK = 0
  For I=1 To GNBSITE
   If GSOCSITE(I)=GSOCSITE(ISITE) & find(GSITE(I),GUSRFCY(1..GNBAUZ))
    OK = 1 : Break : # Il existe au moins un site accessible dans cette société
   Endif
  Next I
  If OK
   [L]SOC = GSOCSITE(ISITE)
  Else : # On prend le premier site accessible
   ISITE = find(GUSRFCY(1),GSITE(1..GNBSITE))
   If ISITE
    [L]SOC = GSOCSITE(ISITE)
   Endif
  Endif
 Endif
Endif
End

Subprog CONTFCYCPY(SITE,SOC)
Value    Char    SITE
Value    Char    SOC
If [L]SITE="" or [L]SOC="" : End : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
Call LECTURE("FCY",[L]SITE,"") From CONTOBJ
Case [F:CPY]CPYLEGFLG
 When 2
  If [F:FCY]LEGCPY<>[L]SOC
   GMESSAGE = [L]SITE-mess(30,106,1)-[F:FCY]LEGCPY : # Ce site est dans la société
   mkstat = 2 : End
  Endif
 When Default
  Look [FGR]FGR0 = [L]SOC ; [L]SITE
  If fstat
   GMESSAGE = [L]SITE-mess(34,104,1)-[L]SOC : # Le site doit appartenir au groupe
   mkstat = 2 : End
  Endif
Endcase
End

################################################################
## Contrôle que tous les sites d'une société sont accessibles  #
################################################################
Subprog CONTALLFCY(SOC)
Value Char    SOC
Local Integer OK
Call VERFALLFCY(SOC,OK)
Raz mkstat
Case OK
 When  0
  GMESSAGE = [L]SOC-mess(31,104,1) : # Aucun site n'est accessible dans cette société
  mkstat = 2 : End
 When -1
  GMESSAGE = mess(32,104,1)-[L]SOC : # Tous les sites ne sont pas accessibles dans la société
  mkstat = 2 : End
Endcase
End

Subprog VERFALLFCY(SOC,OK)
Value    Char     SOC
Variable Integer  OK
Local    Integer  I
OK = 1
If [L]SOC="" : End : Endif
If GUSRFCY(1)="\" : End : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
Raz OK
Case [F:CPY]CPYLEGFLG
 When 2 : # Société juridique
  OK = find([L]SOC,GSOCSITE(1..GNBSITE))
  For I=1 To GNBSITE
   If [L]SOC=GSOCSITE(I) & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
    OK = -1 : Break
   Endif
  Next I
 When Default
  For [FGR]FGR0 Where CPY=[L]SOC
   OK = 1
   If !find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
    OK = -1 : Break
   Endif
  Next
Endcase
End

#################################################################
#   Contrôle de limite de validité d'une date                   #
#################################################################
Subprog CTLVLYDAT(DAT,DATDEB,DATFIN)
Value    Date     DAT
Value    Date     DATDEB
Value    Date     DATFIN
If !(DAT>=DATDEB & (DATFIN=[0/0/0] | DAT<=DATFIN))
 GMESSAGE = mess(13,104,1) : # Hors limite des dates de validité
 mkstat = 2
Endif
End

################################################################
## Contrôle qu'une date de fin est inférieure à date début    ##
################################################################
Subprog DATDEBFIN(DATFIN,DATDEB)
Value Date DATDEB
Value Date DATFIN
If DATFIN<>[0/0/0] & DATFIN<DATDEB
 #GMESSAGE = mess(1,104,1) # FGR 27/08/2015 : X3SUIVI110593
 GMESSAGE = mess(1,104,1) - ":" - format$("D:"+GFMDAT4,DATFIN) - "<" - format$("D:"+GFMDAT4,DATDEB) # FGR 27/08/2015 : X3SUIVI110593
 mkstat = 2
# Date incorrecte
Endif
End

################################################################
## Droit de modifier la zone utilisateur                      ##
################################################################
Subprog CONTUSR(SOCIETE,SITE)
Value Char    SOCIETE, SITE
Call CONTAUZ(SOCIETE,SITE,"U")
End

################################################################
## Contrôle droit pour une option d'une fonction              ##
################################################################
Subprog CONTAUZ(SOCIETE,SITE,OPT)
Value Char    SOCIETE, SITE, OPT
Local Char    AUZ(23)
Local Integer I, OK

If OPT="" : End : Endif

If clalev([F:AFT])=0 : Local File AFCTFCT   [AFT] : Endif
Read [AFT]AFT0 = GPROFIL
If [F:AFT]ALLFCT=2 : End : Endif

If SITE<>""
 Call DROITSITE(SITE,AUZ,OK)
 If !OK | !instr(1,AUZ,OPT)
  mkstat = 2
 Endif
Elsif SOCIETE=""
 For I=1 To GNBSITE
  Call DROITSITE(GSITE(I),AUZ,OK)
  If !OK | !instr(1,AUZ,OPT)
   mkstat = 2 : Break
  Endif
 Next I
Else
 For I=1 To GNBSITE
  If GSOCSITE(I)=SOCIETE
   Call DROITSITE(GSITE(I),AUZ,OK)
   If !OK | !instr(1,AUZ,OPT)
    mkstat = 2 : Break
   Endif
  Endif
 Next I
Endif
End

################################################################
##  Droits sur site pour la fonction                          ##
##  Avec recherche droit sur la fonction associée à l'option  ##
################################################################
Subprog DROITSITE(SITE,AUZ,OK)
Value    Char     SITE
Variable Char     AUZ
Variable Integer  OK
Local    Integer  I, J, ISITE
Local    Char     BID(23), AUZAFC(23), OCODINT(GLONAFC)

Gosub DROIT : # Droit sur la fonction courante
If !OK : End : Endif

If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
OCODINT = [F:AFC]CODINT
Call LECTURE("AFC",GFONCTION,"") From CONTOBJ

Raz AUZAFC
For I=1 To len(AUZ)
 Raz OK
 J = find(mid$(AUZ,I,1),[F:AFC]FLAG(0..dim([F:AFC]FLAG)-1)) : # Fonction associée à l'option ?
 If J & [F:AFC]FNCOPT(J-1)<>""
  Call DROITSITEF([F:AFC]FNCOPT(J-1),SITE,BID,OK)
  Call LECTURE("AFC",GFONCTION,"") From CONTOBJ
 Else
  OK = 1
 Endif
 If OK : AUZAFC += mid$(AUZ,I,1) : Endif
Next I
AUZ = AUZAFC
OK  = 1 : # Il a quand même droit à la fonction courante

If OCODINT<>[F:AFC]CODINT & OCODINT<>""
 Call LECTURE("AFC",OCODINT,"") From CONTOBJ
Endif
End

$DROIT
Raz OK, AUZ
If GNBAUZ=0
 # mkstat = 1 : GMESSAGE = mess(1,123,1) : # Fonction non autorisée
Elsif GUSRFCY(1)="\"
 AUZ = GUSRAUZ(1)
 OK  = 1
Elsif SITE<>""
 ISITE = find(SITE,GUSRFCY(1..GNBAUZ))
 If ISITE
  AUZ = GUSRAUZ(ISITE)
  OK  = 1
 Else
  # mkstat = 1 : GMESSAGE = SITE-":"-mess(2,104,1) : # Vous n'avez pas les droits pour ce site
 Endif
Elsif SITE="" : # Condensé des autorisations tous sites confondus
 For I=1 To GNBAUZ
  For J=1 To len(GUSRAUZ)
   If !instr(1,AUZ,mid$(GUSRAUZ(I),J,1))
    AUZ += mid$(GUSRAUZ(I),J,1)
   Endif
  Next J
 Next I
 OK = 1
Endif
Return

################################################################
## Droits sur site pour une fonction                          ##
################################################################
Subprog DROITSITEF(FNC,SITE,AUZ,OK)
Value    Char    FNC
Value    Char    SITE
Variable Char    AUZ
Variable Integer OK
Local    Integer ISITE
Local    Char    OGFONCTION(GLONAFC)
OGFONCTION = GFONCTION
If FNC<>GFONCTION
 GFONCTION  = FNC
 Call AUTORIS From EXEFNC
Endif
Gosub DROIT
If GFONCTION<>OGFONCTION
 GFONCTION = OGFONCTION
 Call AUTORIS From EXEFNC
Endif
End

