#<AdxTL>@(#)0.0.0.0 $Revision$
#-----------------------------------------------------#
# Lecture des législations d'un dossier
#-----------------------------------------------------#

Subprog SETLEG(DOSSIER,DOSLEG,NBLEG)
Value Char DOSSIER
Variable Char DOSLEG()(1..)
Variable Shortint NBLEG
Local Char CHAINE(250)
Local Integer K , ER
NBLEG = 0
Onerrgo ERDOS
If filinfo(filpath("FIL","ADOVAL","fde",DOSSIER),0)>0
 If DOSSIER="" or DOSSIER=nomap
  Local File ADOVAL [ADW_]
 Else
  Local File =DOSSIER+".ADOVAL" [ADW_]
 Endif
 Read [ADW_]ADW0="";"";"DOSLEG"
 If !fstat
  CHAINE = [F:ADW_]VALEUR
  While CHAINE<>""
   NBLEG += 1
   K = instr(1,CHAINE,"~")
   If K
    DOSLEG(NBLEG) = left$(CHAINE,K-1)
    CHAINE = right$(CHAINE,K+1)
   Else
    DOSLEG(NBLEG) = CHAINE
    CHAINE = ""
   Endif
  Wend
 Endif
 Close Local File [ADW_]
Endif
Onerrgo
End


$ERDOS
ER = errn
Resume
