#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC08   Migration de la table BPSUPPLIER       Module TC        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   #--- Issue 108760 by TS
   #Call SAIDOS(DOSSIER,"") From SAIDOS
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
   #---
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  #--- Issue 108760 By TS
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  #---
  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC08") From LECFIC
  Endif
  #Call RAZ_UUMGTRTTRC08(DOSSIER)
  Call MAJ_UUMGTRTTRC08(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

Subprog MAJ_UUMGTRTTRC08(DOSSIER)
Value Char DOSSIER

#--- Issue 108760 by TS
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
#---
##1 - verifications
####################

If [F:ADS]MODULE(8)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

Local Integer ERR
Local Char WNAMBPSM
Call MIGTABNAME (DOSSIER,"BPSUPPLIER",WNAMBPSM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC08",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMBPSM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC08",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC08",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC08",7,ERR) From TRTMIG : #7=Erreur
  End
Endif


Local Integer NBLUS, ERR, NBCOMMIT
# Issue 112030 - 2015-11-09 by MAE : déplacement des variables
#Local Char WTAB_BPS (100) (adxwrb)
#Local Shortint WCPT_BPS

Call ECR_TIME("UUMGTRTTRC08 tables BPS Process : Update BPS") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC08 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"BPSUPPLIER",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:BPS])  = 0 : Local File =DOSSIER+".BPSUPPLIER"    [BPS]  : Endif   # Fichier X3 "Vide"

If clalev([F:BPSM]) = 0 : Local File =DOSSIER+"."+WNAMBPSM   [BPSM] : Endif   # Fichier X3 renommé Avant Migration

If clalev([F:BPR]) = 0 : Local File =DOSSIER+".BPARTNER"   [BPR] : Endif   # Tiers

# FGR 16/07/2015 : X3SUIVI106944 (début)
If clalev([F:NTS]) = 0 : Local File =DOSSIER+".NOTE"      [NTS] : Endif
#If clalev([F:AXX]) = 0 : Local File =DOSSIER+".ATEXTRA"   [AXX] : Endif
Local File =DOSSIER+".ATEXTRA"   [AXX]   # Note FGR : ouvrir en local la table est déjà ouverte sur le dossier racine
If clalev([F:NTG]) = 0 : Local File =DOSSIER+".NOTCATEG"  [NTG] : Endif
If clalev([F:ATI]) = 0 : Local File =DOSSIER+".ATABIND"   [ATI] : Endif
If clalev([F:AST]) = 0 : Local File =DOSSIER+".APLSTD"    [AST] : Endif
# FGR 16/07/2015 : X3SUIVI106944 (fin)

#-----  Déclaration des variables -----#
# Issue 112030 - 2015-11-09 by MAE : déplacement des variables
Local Char WTAB_BPS (100) (adxwrb)
Local Shortint WCPT_BPS
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=2
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE,NBCOMMIT

# Déclaration des variables communes de travail
Local Integer I, J

#Lecture de la table CADIEDEF
Local File =[F:ADS]DOSSIER+".CADIEDEF"     [CDI]
Local Integer NBCDI : NBCDI=nbrecord([CDI])
Local Char WDIE(GLONDIE)(0..20)
Local Integer WNBRDIE
Local Integer WI
Raz WI
Read [CDI]CDI0 = 3
  If !fstat
    WNBRDIE = [F:CDI]NBRDIE
    For WI=0 To [F:CDI]NBRDIE-1
      WDIE(WI)=[F:CDI]DIE(WI)
    Next
  Endif

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTTRC08",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(2))

  # --------------------------------------
  # FGR 16/07/2015 : X3SUIVI106944 (début)
  # version < V7, maj des champs v7
  If val(VERSION)<GMIGX3VER70 Then
    # On regardes si les catégories CLIENT et PROSPECT existent.
    # Si l'une ou l'autre n'existent pas on ne traitera pas la partie correspondante ici. On pourra lancer à la main UTITC44.
    Local Char WNOTA(250)
    Local Integer INTGIDX
    Local Char SNTGCOD_BPS(type([F:NTG]NTGCOD)-10)   # Fournisseur

    SNTGCOD_BPS = left$(toupper(ctrans(mess(17,7,1))),    type([F:NTG]NTGCOD)-10)    # Fournisseur
    # ------------------------------
    INTGIDX = 0
    Read [ATI]CODIND="NOTCATEG";"NTG0"
    If fstat Then
      Raz [F:ATI]
    Endif
    If [F:ATI]DESCRIPT = "NTGCOD+NTGTYP" Then
      INTGIDX = 1  # Nouvel index
    Elsif [F:ATI]DESCRIPT = "NTGTYP+NTGCOD" Then
      INTGIDX = 2  # Ancien index
    Endif
    If INTGIDX = 0 Then
      # Cas où ça ne serait aucun index : on ne saurait pas lire ! Donc on sort
      Raz SNTGCOD_BPS
    Endif
    # ------------------------------
    If SNTGCOD_BPS <> "" Then
      If INTGIDX = 1 Then
        Read [F:NTG]NTG0=SNTGCOD_BPS;3
      Else
        Read [F:NTG]NTG0=3;SNTGCOD_BPS
      Endif
      If fstat Then
        Raz SNTGCOD_BPS
      Endif
    Endif
    # ------------------------------
  Endif
  # FGR 16/07/2015 : X3SUIVI106944 (fin)
  # --------------------------------------

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC08" : FILTRELIN=0 : Raz CRITERESPE : Raz HINTSPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_BPS00
Raz NB
If STOP=1
 STOP = 0
 CRITERE = "[F:BPSM]BPSNUM>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [BPS]
GOK = 1

For [BPSM] Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1
  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTTRC08" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_BPS
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_BPS
  Endif
  [F:BPS] = [F:BPSM]


  #Appel proc de migration sur entete
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_BPS
    If GOK<1 : Break : Endif
  Endif
  # version < V7, maj des champs v7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_BPS
    If GOK<1 : Break : Endif
  Endif

  ############################
  #-- Boucle sur les lignes
  ############################
  If GOK<1 : Break : Endif

  # --- alimentation des champs et écriture enreg
  #--- Issue 108760 by TS
  #If NEWMOTEUR
  #    Gosub BPS_STK : # pour stocker ref
  #    WriteB [F:BPS]
  #Else
  #    Write [F:BPS]
  #Endif
  #If fstat
  #  If NEWMOTEUR & adxwrb>1
  #    Call ECR_TRACE("File BPSUPPLIER, Error ="-num$(fstat),1) From GESECRAN
  #    Gosub BPS_ERRTRA : # pour afficher les ref
  #  Else
  #    Call ECR_TRACE("File BPSUPPLIER(BPSNUM)"-[F:BPS]BPSNUM+", Error ="-num$(fstat),1) From GESECRAN
  #  Endif
  #  GOK=0 : Break
  #Endif
  Gosub BPS_STK : # pour stocker ref
  WriteB [F:BPS]
  If fstat
    Call ECR_TRACE("File BPSUPPLIER, Error ="-num$(fstat),1) From GESECRAN
    Gosub BPS_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  #---

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:BPSM]BPSNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC08",7,ERR) From TRTMIG : #7=Erreur
Else
  #--- Issue 108760 by TS
  #If NEWMOTEUR & adxwrb>1
    Flush [F:BPS]
    If fstat
        Call ECR_TRACE("File BPSUPPLIER, Error ="-num$(fstat),1) From GESECRAN
        Gosub BPS_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  #--- Issue 108760 by TS
  #Endif
  # FGR 03/11/2015 : X3SUIVI112252 (début)
  #  # --------------------------------------
  #  # FGR 16/07/2015 : X3SUIVI106944 (début)
  #  # version < V7, maj des champs v7
  #  If val(VERSION)<GMIGX3VER70 Then
  #    Flush [F:NTS]
  #    If fstat
  #        Call ECR_TRACE("File NOTE, Error ="-num$(fstat),1) From GESECRAN
  #        Gosub BPS_ERRTRA : # pour afficher les ref
  #        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
  #    Endif
  #  Endif
  #  # FGR 16/07/2015 : X3SUIVI106944 (fin)
  #  # --------------------------------------
  # FGR 03/11/2015 : X3SUIVI112252 (début)
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(2)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTTRC08",NBMIGKEY,TABMIGKEY,NBLUS,NB+NBCOMMIT,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTTRC08",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_BPS00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [BPS]
Close Local File [BPSM]
Close Local File [BPR]
# FGR 16/07/2015 : X3SUIVI106944 (début)
Close Local File [NTS]
Close Local File [AXX]
Close Local File [NTG]
Close Local File [ATI]
Close Local File [AST]
# FGR 16/07/2015 : X3SUIVI106944 (fin)
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"BPSUPPLIER",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTTRC08") From TRTMIG
Call ECR_TIME("UUMGTRTTRC08 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End
################################################
$RAZV6_BPS
Raz [F:BPS]AGTPCP
Raz [F:BPS]AGTSATTAX
Raz [F:BPS]BPAADD
Raz [F:BPS]BPAINV
Raz [F:BPS]BPAPAY
Raz [F:BPS]BPSRSK
Raz [F:BPS]CNTNAM
If dim([F:BPS]CRESTP)>0 Raz [F:BPS]CRESTP Endif
Raz [F:BPS]CUR
Raz [F:BPS]DIE
Raz [F:BPS]FLGSATTAX
If dim([F:BPS]IDTSGL)>0 Raz [F:BPS]IDTSGL : Endif
If dim([F:BPS]UPDSTP)>0 Raz [F:BPS]UPDSTP : Endif
Raz [F:BPS]SATTAX
Return
################################################
$RAZV7_BPS
Return
################################################
$MAJV6_BPS
Gosub RECUP_BPR
Return
################################################
$MAJV7_BPS
  # --------------------------------------
  # FGR 16/07/2015 : X3SUIVI106944 (début)
  If [F:BPS]BPSREM <> "" and SNTGCOD_BPS <> "" Then
    # -----------------------------------
    WNOTA = left$([F:BPS]BPSNUM,type([F:NTS]NTSCOD)-10)
    # ----------------------
    SKEY2 = WNOTA + "~" + "3" + "~" + "" + "~" + SNTGCOD_BPS
    Read [F:NTS]NTS0=[F:BPS]BPSNUM;SKEY2
    If fstat Then
      Raz [F:NTS]
      #
      [F:NTS]CODE = [F:BPS]BPSNUM
      [F:NTS]NTSCOD = WNOTA
      [F:NTS]NTGTYP = 3
      [F:NTS]NTGCOD = SNTGCOD_BPS                                          # Fournisseur
      [F:NTS]AUTODISP = 2                                                  # Auto display
      [F:NTS]BPSNUM = [F:BPS]BPSNUM   # FGR 02/11/2015 : X3SUIVI112200 pas [F:NTS]BPCNUM
      [F:NTS]EFFDAT = [F:BPS]CREDAT
      [F:NTS]ENDDAT = gdat$(day(date$),month(date$),year(date$)+10)        # Valable 10 ans par défaut (?)
      [F:NTS]PRIORITY = 1
      [F:NTS]NOTE = [F:BPS]BPSREM
      #
      If dim([F:NTS]NTSCOD2) >= 0 Then
        [F:NTS]NTSCOD2 = [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD
      Endif
      Write [F:NTS]
      If fstat Then
        # FGR 03/11/2015 : X3SUIVI112252 (début)
        #        If NEWMOTEUR & adxwrb>1
        #          Call ECR_TRACE("File BPSUPPLIER, Error ="-num$(fstat),1) From GESECRAN
        #          Gosub BPS_ERRTRA : # pour afficher les ref
        #        Else
        #          Call ECR_TRACE("File BPSUPPLIER(BPSNUM)"-[F:BPS]BPSNUM+", Error ="-num$(fstat),1) From GESECRAN
        #        Endif
        Call ECR_TRACE("File BPSUPPLIER(BPSNUM)"-[F:BPS]BPSNUM+", Error ="-num$(fstat),1) From GESECRAN
        # FGR 03/11/2015 : X3SUIVI112252 (fin)
        GOK = 0
        Return     ### S'il y a une erreur on part d'ici donc BPCREM reste différent de ""
      Else
        Call TRANSLATED_FIELD(17, 7, "NOTE", "NTSDESAXX", GLONAX1, [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD) From UTITC44
        Call TRANSLATED_FIELD(17, 7, "NOTE", "NTSSHOAXX", GLONAX3, [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD) From UTITC44
      Endif
    Endif
    # -----------------------------------
    [F:BPS]BPSREM = ""
    # -----------------------------------
  Endif
  # FGR 16/07/2015 : X3SUIVI106944 (fin)
  # --------------------------------------
Return
################################################
$RECUP_BPR

      If [F:BPS]BPRPAY=""  [F:BPS]BPRPAY=[F:BPS]BPSNUM : Endif
      If [F:BPS]BPSINV=""  [F:BPS]BPSINV=[F:BPS]BPSNUM : Endif
      If [F:BPS]BPAPAY=""
        If [F:BPR]BPRNUM<>[F:BPS]BPRPAY
          Read [BPR] BPR0=[F:BPS]BPRPAY : If fstat  Raz [F:BPR] : Endif
        Endif
        [F:BPS]BPAPAY=[F:BPR]BPAADD
      Endif
      If [F:BPS]BPAINV=""
        If [F:BPR]BPRNUM<>[F:BPS]BPSINV
          Read [BPR] BPR0=[F:BPS]BPSINV : If fstat  Raz [F:BPR] : Endif
        Endif
        [F:BPS]BPAINV=[F:BPR]BPAADD
      Endif
      If [F:BPS]CUR="" | [F:BPS]BPAADD="" | [F:BPS]CNTNAM=""
        If [F:BPR]BPRNUM<>[F:BPS]BPSNUM
          Read [BPR] BPR0=[F:BPS]BPSNUM : If fstat  Raz [F:BPR] : Endif
        Endif
        If [F:BPS]CUR=""    [F:BPS]CUR   =[F:BPR]CUR    : Endif
        If [F:BPS]BPAADD="" [F:BPS]BPAADD=[F:BPR]BPAADD : Endif
        If [F:BPS]CNTNAM="" [F:BPS]CNTNAM=[F:BPR]CNTNAM : Endif
      Endif
      If [F:BPS]BPSRSK=""
        Case GINIBPRRSK
          When 1       : [F:BPS]BPSRSK=[F:BPS]BPSINV
          When 2       : [F:BPS]BPSRSK=[F:BPS]BPRPAY
          When 3       : [F:BPS]BPSRSK=[F:BPS]BPSGRU
          When Default : [F:BPS]BPSRSK=[F:BPS]BPSINV
        Endcase
      Endif
#mise à jour des sections analytiques
Raz WI
For WI=0 To WNBRDIE-1
   If WI<dim([F:BPS]DIE)
    If [F:BPS]DIE(WI)="" [F:BPS]DIE(WI)=WDIE(WI) : Endif
   Else
    Break
   Endif
Next
Return


################################################
$BPS_STK
Call STK (WTAB_BPS,WCPT_BPS,[F:BPS]BPSNUM) From TRTMIG
Return
##############################################################################################
$BPS_ERRTRA
Call ERRTRA (WTAB_BPS,WCPT_BPS,"File BPSUPPLIER(BPSNUM)=") From TRTMIG
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
#--- Issue 108760 by TS
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
#---
Call MAJ_UUMGTRTTRC08(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTTRC08(APPLI)
End

#######################################################################
# Suppression pour pouvoir relancer la moulinette
########################################################################
Subprog RAZ_UUMGTRTTRC08(DOSSIER)
Value Char DOSSIER

Local Integer ERR
##1 - verifications
####################
If [F:ADS]MODULE(8)<>2 : End : Endif          : # N= no module

Local Char WNAMBPSM
Call MIGTABNAME (DOSSIER,"BPSUPPLIER",WNAMBPSM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMBPSM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif

Call MIGTABRAZ (DOSSIER,"BPSUPPLIER",ERR) From TRTMIG

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGTRTTRC08",ERR) From TRTMIG

End

