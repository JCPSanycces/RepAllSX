NBCOND = 0
OPTSEL = ''
Return

$LIBPAR
Local Char LIBPAR(30)
Call TEXTE(26213,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(20)(0..GNBDERNIER)
Local Char     A_BUF2(5)(0..GNBDERNIER)
Local Char     A_BUF3(80)(0..GNBDERNIER)
Local Char     A_BUF4(5)(0..GNBDERNIER)
If clalev([F:HRSMH9])>0 : Close Local File [HRSMH9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(20),
& Char     A_TAB2(5),
& Char     A_TAB3(80),
& Char     A_TAB4(5)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4
& As [HRSMH9]
Return

$LEC_DERLU
Read [ACC]CODACC = GUSER ; [F:HRSMH]CODACS
If fstat : Raz [F:ACC] : Endif
Read [AXX]AXX0="SCREMPH";"DES";GLANGUE;[F:HRSMH]LEG;[F:HRSMH]COD
If fstat : Raz [F:AXX] : Endif
Return

$CHARGE_DERLU
If clalev([F:HRSMH9])>0
 Read [HRSMH9] = [F:HRSMH9]A_TABI
 [L]CLE = [F:HRSMH9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:HRSMH9])>0
 Filter [HRSMH9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [SMH1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:HRSMH9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:HRSMH]COD+"~"
 A_CLEDERLU += [F:HRSMH]LEG+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:HRSMH9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:HRSMH9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 0
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:HRSMH]LEG"
Call TEXTE(26213,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:HRSMH]LEG"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:HRSMH]COD"
Call TEXTE(5296,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:HRSMH]COD"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:AXX]TEXTE"
Call TEXTE(8,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:80X"
SELFOR(NBSEL) = "K:80X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:AXX]TEXTE"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:HRSMH]CODACT"
Call TEXTE(35058,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "KTD:5B"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:HRSMH]CODACT"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:HRSMH_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif
If clalev([F:AXX])=0 : Local file ATEXTRA [AXX] : Endif
Link [HRSMH] With
& [ACC]CODACC=GUSER;[F:HRSMH]CODACS,
& [AXX]AXX0="SCREMPH";"DES";GLANGUE;[F:HRSMH]LEG;[F:HRSMH]COD
& As [HRSMH_]
Return

$DEFAUT_LISTE
Default file [HRSMH_]
Return

$OUVRE_JOIN
Local Char    ORDRE_JOI(250)
ORDRE_JOI = "A_TABJ1;A_TABJ2"
Local Char     A_BUFJ1(20)(1..GNBSEL)
Local Char     A_BUFJ2(5)(1..GNBSEL)
Local Char     A_BUFJ3(15)(1..GNBSEL)
Local Char     A_BUFJ4(80)(1..GNBSEL)
Local File(
& Char     A_TABJ1(20),
& Char     A_TABJ2(5),
& Char     A_TABJ3(15),
& Char     A_TABJ4(80)
& ) From Variable A_BUFJ1, A_BUFJ2, A_BUFJ3, A_BUFJ4
& As [PCEJ]
Return

$TIT_JOIN
Local Char TITJOI(30)(1..4)
Call TEXTE(26213,TITJOI(1)) From OBJDIV
Call TEXTE(5296,TITJOI(2)) From OBJDIV
TITJOI(3) = mess(59,100,1) : # Type
TITJOI(4) = mess(38,100,1) : # Nom
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Kf:5c"
LG = 0
TIT = ""
End

Subprog FORMCLE2(FMT)
Variable Char    FMT()
FMT = "Kf:20B"
End

$LIENS
Read [AXX]AXX0 = "SCREMPH";"DES";GLANGUE;[F:HRSMH]LEG;[F:HRSMH]COD
If fstat : Raz [F:AXX] : Endif
Return

