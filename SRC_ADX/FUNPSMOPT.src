#<AdxTL>@(#)0.0.0.0 $Revision$
# Update WOs, suggestions for scheduling in Planner One - FUNPSMOPT
$ACTION
Case ACTION
    When "OUVRE"          : Gosub OUVRE
    When "DEBUT"          : Gosub DEBUT
    When "TITRE"          : TIT = mess(177,195,1)
    When "OK"             : Gosub OK
Endcase
Return

$DEBUT
    [M:MPSOP1]WOSFLG = 1
    Grizo [M:MPSOP1]MRPFLG
    Affzo [M:MPSOP1]WOSFLG
Return

$OUVRE

Local Char WFCY(GLONFCY) : WFCY = PARAM(1)

Local Integer  J, K
Local Integer  OK
Local Integer  NBOF
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
Local Char     CUSFLT(255)
Local Char     FORMULE1(255)                        # 05.05 30049
Local Char     WMESS(150)
Local Integer  WHDEB,WHFIN, WHWRK
Local Integer  MFGSTA

# 03.06 distinction 35512 # 05/2008 V6 GLONFCY au lieu de (3)
If dim(GOPTFCY) <= 0 : Global Char    GOPTFCY(GLONFCY) : Endif

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub CHARG_PARAM

# Ouverture des fichiers utilisés
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING  [SCH]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif

Return


$OK
    FIN = 0
    # Read the site code
    Call LECTURE ("FCY", [M:MPSOP1]MFGFCY, "") From CONTOBJ

    # Output tracing info.
    If [M:MPSOP1]TRACE1 = 2
        Call OUVRE_TRACE(TIT) From LECFIC
        Call ECR_TRACE(" ",0) From GESECRAN
        Call ECR_TRACE(string$(82,"-"),0) From GESECRAN
        Call PRTSCR("MAUTPSOPT1","MPSOP1","",0,1) From ATRTX3
        Call ECR_TRACE(string$(82,"-"),0) From GESECRAN
        Call ECR_TRACE(" ",0) From GESECRAN
        WHDEB = time
    Endif

    # Popup 'updating' screen
    Call TEMPON(mess(195,195,1)) From GESECRAN

    # Prepare the filtering
    Gosub SEL_OF

    # traitement des OF
    NBOF = 0 : # GH 22/07/15 bug 108630

    # Update the works orders
    Gosub TRT_OF

    # Close 'updating' screen
    Call TEMPOFF From GESECRAN

    # Output tracing information
    If [M:MPSOP1]TRACE1 = 2
        WHFIN = time
        WHWRK = WHFIN-WHDEB
        J = mod(WHWRK,60)
        K = WHWRK/60
        K = int(K)
        WMESS=mess(106,190,1)+":"-num$(K)-mess(2,301,1)-num$(J)
        Call ECR_TRACE(WMESS,0) From GESECRAN
        # fermeture trace
        Call FERME_TRACE From LECFIC
    Endif
    # Output the number of orders updated
    If NBOF
        Call MESSAGE(num$(NBOF)-mess(354,193,1)) From GESECRAN
    Else
        Call MESSAGE(mess(88,193,1)) From GESECRAN
    Endif
    # aucun OF extrait ou lecture trace
    If [M:MPSOP1]TRACE1 = 2 : Call LEC_TRACE From LECFIC : Endif

Return

Subprog AM_WOSFLG(VALEUR)
Variable Integer VALEUR

    If VALEUR = 1
        Grizo [M:MPSOP1]MRPFLG
    Else
        [M:MPSOP1]MRPFLG = 3
        Actzo [M:MPSOP1]MRPFLG
    Endif
    Affzo [M:MPSOP1]MRPFLG
End


######################################################################################
########################################################################
# Chargement variables globales
$CHARG_PARAM
# Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO

# Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA

Return

########################################################################
# Préparation du filtre sur la table encours (WOx)
$SEL_OF
Raz CRITERE
Raz CRITERE1
Raz CRITERE2

If [M:MPSOP1]WOSFLG = 2
    Case [M:MPSOP1]MRPFLG
        When 1:     CRITERE  = "[F:OPS]OPSSTA=3&[F:OPS]OPSTYP=2"
        When 2:     CRITERE  = "[F:OPS]OPSSTA=3&[F:OPS]OPSTYP=1"
        When 3:     CRITERE  = "[F:OPS]OPSSTA=3"
    Endcase
    Gosub LOAD_CRITERE
Endif

If [M:MPSOP1]WOPFLG = 2
    CRITERE  = "[F:OPS]OPSSTA=2"
    Gosub LOAD_CRITERE
Endif

If [M:MPSOP1]WOFFLG = 2
    CRITERE  = "[F:OPS]OPSSTA=1"
    Gosub LOAD_CRITERE
Endif

# fin de la première partie
CRITERE1 += ")"
GPE = 0
#----------------------------------------------------------------------------------------------
GPOINT = "OPTDATSEL"
Gosub  ENTREE From EXEFNC
If !GPE
    CRITERE = "[F:OPS]OPESTR>=[M:MPSOP1]STRDAT"
    Gosub LOAD_CRITERE2

    CRITERE = "[F:OPS]OPEEND<=[M:MPSOP1]ENDDAT"
    Gosub LOAD_CRITERE2

    CRITERE  = "[F:OPS]MFGFCY = [M:MPSOP1]MFGFCY"
    Gosub LOAD_CRITERE2
Endif

Return

########################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

########################################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 225
  CRITERE1 += "&"
  CRITERE1 += CRITERE
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return

########################################################################
# Traitement des ordres
$TRT_OF
Raz FORMULE1
If CRITERE2 = "" : CRITERE2 = "1=1" : Endif

# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
  Raz CUSFLT
  GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
  If CUSFLT = "" : CUSFLT = "1=1" : Endif

# 05.05 30049
# analyse présence formule de sélection
If [M:MPSOP1]FORMULE  <> ""
    Read [F:TFO]TFO0=10;[M:MPSOP1]FORMULE
    If !fstat
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

# -----------------------------------------------------------
#   PE pour extraction des liens de succession entre OFs
GPOINT = "INIT_ACTLINK"  : Gosub ENTREE From EXEFNC
# -----------------------------------------------------------

fstat = 0
# s'il existe une formule on débranche sur un link
If FORMULE1 <> ""
## GH 25/09/2013 bug 82915
#    Link [OPS] With [MFG]MFG0~=[F:OPS]MFGNUM, [ITF]ITF0~=[F:MFG]ROUNUM;[F:MFG]MFGFCY, [ITM]ITM0~=[F:ITF]ITMREF As [OPX]
#&              Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
#&              Order By Key OPS1(1)
    Link [OPS] With [MFG]MFG0=[F:OPS]MFGNUM, [ITF]ITF0=[F:MFG]ROUNUM;[F:MFG]MFGFCY, [ITM]ITM0=[F:ITF]ITMREF As [OPX]
&              Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
&              Order By Key OPS1(1)
    For [OPX]
       # ---- PE CHECKOPS
       GOK = 1
       GPE = 0
       GPOINT="CHECKOPS" : Gosub ENTREE From EXEFNC
       If GOK  :  Gosub PROCESS_OF : Endif
    Next
Else
    Filter [OPS] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT)
&               Order By Key OPS1(1)
    For [OPS]
       # ---- PE CHECKOPS
       GOK = 1
       GPE = 0
       GPOINT="CHECKOPS" : Gosub ENTREE From EXEFNC
       If GOK  :  Gosub PROCESS_OF : Endif
    Next
    Filter [OPS]
Endif
Return

########################################################################
# 05.05 30049
$PROCESS_OF
OK = 2
If find([F:OPS]OPSSTA,1,2)
    If FORMULE1 = ""
        Read [MFG]MFG0=[F:OPS]MFGNUM
        If fstat : Goto NXT2 : Endif
    Endif
    #----------------------------------------------------------------------------------------------
    GPE = 0
    GPOINT = "OPTDATCONT"
    Gosub  ENTREE From EXEFNC
    If !GPE
        If [F:MFG]STRDAT < [M:MPSOP1]STRDAT | [F:MFG]ENDDAT > [M:MPSOP1]ENDDAT
          Goto NXT2
        Endif
    Endif
    MFGSTA = [F:MFG]MFGSTA
Else
    Read [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM
    If fstat : Goto NXT2 : Endif
    If [F:SCH]OPESTRDAT = [0/0/0] : Goto NXT2 : Endif
    For [ORD]ORD3 Where STOFCY = [M:MPSOP1]MFGFCY & VCRTYP = 11 & VCRNUM = [F:OPS]MFGNUM & WIPTYP = 5
        #----------------------------------------------------------------------------------------------
        GPE = 0
        GPOINT = "OPTDATCONT"
        Gosub  ENTREE From EXEFNC
        If !GPE
            If [F:ORD]STRDAT < [M:MPSOP1]STRDAT | [F:ORD]ENDDAT > [M:MPSOP1]ENDDAT
                OK = 0
            Endif
        Endif
    Next
    MFGSTA = [F:ORD]WIPSTA
Endif
If !OK : Goto NXT2 : Endif

If find([F:OPS]OPSSTA,1,2)
    Gosub SEL_OFCOMPL
    If OK = 1 : Goto NXT2 : Endif
Endif

# Check if suggestions have already been included
If [F:OPS]OPSSTA = 3
    Gosub SEL_OFCOMPLSUG
    If OK = 1 : Goto NXT2 : Endif
Endif

Gosub TRTEXT
$NXT2
Return

########################################################################
# Traitement extraction
$TRTEXT
If !OK : Return : Endif
Call DEBTRANS From GLOCK
GOK = 1
Gosub EXTRAC
Return

########################################################################
# Extraction
$EXTRAC
    Local Char MFGNUM(GLONVCR)

Trbegin [MFG]

# mise à jour OF pour statut "à l'étude" si mode mise à jour
If [L]MFGSTA <> 3
    Readlock [MFG]MFG0=[F:MFG]MFGNUM
    If fstat=1 & !GSERVEUR
        WTAB="MFG"
        WCLE=[F:MFG]MFGNUM
        Goto ROL_TRTEXT
    Endif
    If fstat
        WTAB="MFG"
        WCLE=[F:MFG]MFGNUM
        Goto AB_TRTEXT
    Endif
    [F:MFG]OPTFLG = 2
    [F:MFG]OPTUSR = GUSER
    Rewrite [MFG]
    Unlock [MFG]
    [L]MFGNUM = [F:MFG]MFGNUM
    [L]MFGSTA = [F:MFG]MFGSTA
Else
    # Need to update optimisation flag for suggestions if being included.
    Readlock [ORD]ORD0=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
    If fstat=1 & !GSERVEUR
        WTAB="ORD"
        WCLE=[F:ORD]WIPNUM
        Goto ROL_TRTEXT
    Endif
    If fstat
        WTAB="ORD"
        WCLE=[F:ORD]WIPNUM
        Goto AB_TRTEXT
    Endif
    [F:ORD]OPTFLG = 2
    [F:ORD]UPDDAT = date$
    [F:ORD]UPDUSR = GUSER
    Rewrite [ORD]
    Unlock [ORD]
    [L]MFGNUM = [F:ORD]WIPNUM
    [L]MFGSTA = [F:ORD]WIPSTA
Endif

# traces
If [M:MPSOP1]TRACE1 = 2
    WMESS   = mess(156,197,1)+" "+mess([L]MFGSTA,317,1)+" "+[L]MFGNUM+" "+mess(214,197,1)
    Call ECR_TRACE(WMESS,0) From GESECRAN
Endif
NBOF += 1

Commit
Raz fstat
Return

########################################################################
# Sélections complémentaires
$SEL_OFCOMPL
OK=1
# Issue X3-31754 - 2017-04-26 by CCC : If the WO is (being) optimized, it's already in PS => don't process it
If [F:MFG]OPTFLG = 2 | [F:MFG]SCDFLG = 4
#    WMESS   = mess(156,197,1)+" "+mess([F:MFG]MFGSTA,317,1)+" "+[F:MFG]MFGNUM+" "+
#&             mess(125,193,1)+"("+[F:MFG]OPTUSR+")"
#
#    If [M:MPSOP1]TRACE1 = 2
#        Call ECR_TRACE(WMESS,1) From GESECRAN
#    Endif
    Return
Endif
If !find([F:MFG]SCDFLG,2,4)
    # 11.05 33303
    WMESS   = mess(156,197,1)+" "+mess([F:MFG]MFGSTA,317,1)+" "+[F:MFG]MFGNUM+" "+mess(1,335,1)
    If [M:MPSOP1]TRACE1 = 2
        # Issue X3-31754 - 2017-04-26 by CCC : alert because an action can be needed
        #Call ECR_TRACE(WMESS,0) From GESECRAN
        Call ECR_TRACE(WMESS,-1) From GESECRAN
    Endif
    Return
Endif
If [F:MFG]MFGTRKFLG > 4 : Return : Endif
If [F:MFG]CFMFLG <> 2
    WMESS   = mess(156,197,1)+" "+mess([F:MFG]MFGSTA,317,1)+" "+[F:MFG]MFGNUM+" "+
&             mess(182,197,1)
    If [M:MPSOP1]TRACE1 = 2
        Call ECR_TRACE(WMESS,1) From GESECRAN
    Endif
    Return
Endif

OK=2

Return

# Check if suggestions have already been included and output a message if tracing
$SEL_OFCOMPLSUG
OK=1
If [F:ORD]OPTFLG = 2
    WMESS   = mess(156,197,1)+" "+mess([F:ORD]WIPSTA,317,1)+" "+[F:ORD]WIPNUM+" "+
&             mess(125,193,1)
    If [M:MPSOP1]TRACE1 = 2
        Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif
    Return
Endif
OK=2

Return

########################################################################
# Rollback
$ROL_TRTEXT
Rollback
Call ROLL From GLOCK
If GROLL
     If [M:MPSOP1]TRACE1 = 2
         Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
     Endif
Else Goto EXTRAC :Endif
Return

########################################################################
# Abandon
$AB_TRTEXT
Rollback
If [M:MPSOP1]TRACE1 = 2
    Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Endif
Return





