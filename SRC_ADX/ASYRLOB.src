#**
#* Funprog HANDLER_DELETE_DATA()
#*!
Funprog HANDLER_DELETE_DATA(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Local Integer   ERROR : ERROR = [V]CST_AOK
Local Char ENT_TYPE(10) : ENT_TYPE=CST_AURLBLOB
Local Char KEYS(250) : KEYS = PSYR.SELREP
Local Integer COUNT
Gosub DEL
End ERROR


#------------------------------------------------------------#
# Request detail LOB management
#------------------------------------------------------------#

$GET

Local Clbfile WCLOB(1)
Local Blbfile WBLOB(1)
Local Char _CNT(100)

# $edit
If PSYR.WRKUID<>NullUuid
  Gosub GET_LOB
  Return
Endif

If toupper(ENT_TYPE)=CST_AURLBLOB
  Call READ_LOB(toupper(ENT_TYPE),KEYS,_CNT,ASNB,WCLOB,ASNB.DATA)
  ASNB.URL      = PSYR.PREFIX+'/'+toupper(ENT_TYPE)+"('"+KEYS+"')"
  # Issue 2075
  #ASNB.CONTTYPE = tolower(ENT_TYPE)
  If [L]_CNT<>""
   ASNB.CONTTYPE = [L]_CNT
  Else
   ASNB.CONTTYPE = tolower(ENT_TYPE)
  Endif
  If len(ASNB.DATA)=0
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NO_CONTENT,mess(34,149,1))
  Endif
Else
  Call READ_LOB(toupper(ENT_TYPE),KEYS,_CNT,ASND,ASND.DATA,WBLOB)
  ASND.URL      = PSYR.PREFIX+'/'+toupper(ENT_TYPE)+"('"+KEYS+"')"
  # Issue 2075
  #ASND.CONTTYPE = tolower(ENT_TYPE)
  If [L]_CNT<>''
   ASND.CONTTYPE = [L]_CNT
  Else
   ASND.CONTTYPE = tolower(ENT_TYPE)
  Endif
  If len(ASND.DATA)=0
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NO_CONTENT,mess(34,149,1))
  Endif
Endif

Return

#------------------------------------------------------------#
# Request edit LOB management
#------------------------------------------------------------#

$PUT

ERROR = func ASYRDELSYS.SEARCH_WORKING_COPY(ACTX,ASWK,ARCV,PSYR.WRKUID,COUNT)
If ERROR <> [V]CST_AOK : Return : Endif

Local Instance UPD(1..) Using C_ADELTA
Local Instance ULN(1..) Using C_ADELTALIN : # Uncommitted lines of collection by the serveur
Local Instance REP      Using C_AREPENT
Local Char    PRGREP(30)
Local Clbfile WCLOB(1)
Local Blbfile WBLOB(1)
Local Char _CNT(100)
Local Uuident  UIDINS :# for ENABLE_BUTTONS
Local Instance WREP Using OBJECT:# for ENABLE_BUTTONS

# Load the representation's description :
PRGREP = func SUBASW.PREFIX_TRT+ASWK(COUNT).REPRES : # WMREP
Call DESCRIPTION_REPRESENTATION(REP,ASWK(COUNT).REPNAM) From =PRGREP

# Load representation's parameters
Call SET_REP_PARAMETERS(ASWK(COUNT).DATCLA,ARCV) From ASYRMAIN

#Enable buttons :
WREP = ASWK(COUNT).DATCLA
Gosub ENABLE_BUTTONS From ASYREDT

ASWK(COUNT).DATCLA.setAccessorEnabled = 1
Call SET_SYSSNAPSHOT(ASWK(COUNT).DATCLA,1) From ASYRDELSYS

If toupper(ENT_TYPE)=CST_AURLBLOB
  Call PUT_LOB(toupper(ENT_TYPE),PSYR.CNTTYP,ASWK(COUNT).METCLA,ASWK(COUNT).DATCLA,KEYS,_CNT,WCLOB,ARCV.JSON)
  If len(ARCV.JSON)=0
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NO_CONTENT,mess(34,149,1))
  Endif
Else
  #PSYR.CNTTYP is initialised in ASYRMAIN. It defines the type of data sent by the client
  If instr(1,PSYR.CNTTYP,"text") > 0
   I = strDecode(ARCV.JSON,WCLOB,GUTF8)
   Call PUT_LOB(toupper(ENT_TYPE),PSYR.CNTTYP,ASWK(COUNT).METCLA,ASWK(COUNT).DATCLA,KEYS,_CNT,WCLOB,WBLOB)
   If len(WCLOB)=0
    ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NO_CONTENT,mess(34,149,1))
   Endif
  Else
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_UNSUPPORTED_MEDIA,mess(35,149,1))
   Endif
Endif

# Load changes set to the representation while setting the LOB :
Call LOAD_DELTA(ASWK(COUNT).DATCLA,REP,UPD,ULN) From ASYRDELSRV
Call SET_SYSSNAPSHOT(ASWK(COUNT).DATCLA,0) From ASYRDELSYS
ASWK(COUNT).DATCLA.setAccessorEnabled = 0
#Genereate the answer to be sent to the client :
Call DETAIL_JSON(REP,ASWK(COUNT).DATCLA,ASWK(COUNT),PSYR,UPD,ASND.DATA) From ASYRDATDEL

ASND.URL      = PSYR.PREFIX+'/'+PSYR.URLUPD+"('"+num$(ASWK(COUNT).TRCKID)+"')"+PSYR.URLREP+ASWK(COUNT).REPRES+".$edit"
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+ASWK(COUNT).REPRES+".$edit"
Return

#------------------------------------------------------------#
# Request delete LOB management
#------------------------------------------------------------#
$DEL

ERROR = func ASYRDELSYS.SEARCH_WORKING_COPY(ACTX,ASWK,ARCV,PSYR.WRKUID,COUNT)
If ERROR <> [V]CST_AOK : Return : Endif

Local Clbfile WCLOB(1)
Local Blbfile WBLOB(1)
Local Char _CNT(100)

If toupper(ENT_TYPE)=CST_AURLBLOB
  Call PUT_LOB(toupper(ENT_TYPE),"",ASWK(COUNT).METCLA,ASWK(COUNT).DATCLA,KEYS,_CNT,WCLOB,WBLOB)
Else
  Call PUT_LOB(toupper(ENT_TYPE),"",ASWK(COUNT).METCLA,ASWK(COUNT).DATCLA,KEYS,_CNT,WCLOB,WBLOB)
Endif
ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NO_CONTENT,mess(34,149,1))
ASND.URL      = PSYR.PREFIX+'/'+PSYR.URLUPD+"('"+num$(ASWK(COUNT).TRCKID)+"')"+PSYR.URLREP+ASWK(COUNT).REPRES+".$edit"
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+ASWK(COUNT).REPRES+".$edit"
Return

#------------------------------------------#
# Error response
#------------------------------------------#

$ERR_DETAIL
Resume

#--------------------------------------------------------------------------#
# Miscellaneous programs
#--------------------------------------------------------------------------#

$GET_LOB

ERROR = func ASYRDELSYS.SEARCH_WORKING_COPY(ACTX,ASWK,ARCV,PSYR.WRKUID,COUNT)
If ERROR <> [V]CST_AOK : Return : Endif

If toupper(ENT_TYPE)=CST_AURLBLOB
  Call GET_LOB_CLASS(toupper(ENT_TYPE),ASWK(COUNT).METCLA,ASWK(COUNT).DATCLA,KEYS,_CNT,WCLOB,ASNB.DATA)
  ASNB.URL      = PSYR.PREFIX+'/'+toupper(ENT_TYPE)+"('"+KEYS+"')"
  # Issue 2075
  #ASNB.CONTTYPE = tolower(ENT_TYPE)
  If [L]_CNT<>''
   ASNB.CONTTYPE = [L]_CNT
  Else
   ASNB.CONTTYPE = tolower(ENT_TYPE)
  Endif
  If len(ASNB.DATA)=0
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NO_CONTENT,mess(34,149,1))
  Endif
Else
  Call GET_LOB_CLASS(toupper(ENT_TYPE),ASWK(COUNT).METCLA,ASWK(COUNT).DATCLA,KEYS,_CNT,ASND.DATA,WBLOB)
  ASND.URL      = PSYR.PREFIX+'/'+toupper(ENT_TYPE)+"('"+KEYS+"')"
  # Issue 2075
  #ASND.CONTTYPE = tolower(ENT_TYPE)
  If [L]_CNT<>''
   ASND.CONTTYPE = [L]_CNT
  Else
   ASND.CONTTYPE = tolower(ENT_TYPE)
  Endif
  If len(ASND.DATA)=0
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NO_CONTENT,mess(34,149,1))
  Endif
Endif
Return

# GET_LOB_UUID : Extract the UUID contained in the LOB's keys
# _KEYVAL (in): keys of the LOB as defined in the URL
# _UUID (out): uuid found in the keys
Subprog GET_LOB_UUID(_KEYVAL,_UUID)
Value Char _KEYVAL
Variable Uuident  _UUID

Gosub DECODE_KEYVAL
[L]_UUID = toUuid([L]_KEYVALTAB(3))
End

#----------------------------------------------------#
# DECODE_KEYVAL :  _KEYVAL ---> _KEYVALTAB(1..
#----------------------------------------------------##----------------------------------------------------##----------------------------------------------------#

$DECODE_KEYVAL
Local Integer I,J,KEY0
KEY0=0
Local Char _KEYVALTAB(250)(1..16)
I=instr(1,[L]_KEYVAL,[V]CST_AURLSEPLOB)
If I=0
 I=instr(1,[L]_KEYVAL,[V]CST_AURLSEPLOB_ASCII)
 KEY0=1
Endif
While I>0
 J+=1
 [L]_KEYVALTAB(J) = left$([L]_KEYVAL,I-1)
 If KEY0=1
  [L]_KEYVAL = right$([L]_KEYVAL,I+len([V]CST_AURLSEPLOB_ASCII))
  I=instr(1,[L]_KEYVAL,[V]CST_AURLSEPLOB_ASCII)
 Else
  [L]_KEYVAL = right$([L]_KEYVAL,I+len([V]CST_AURLSEPLOB))
  I=instr(1,[L]_KEYVAL,[V]CST_AURLSEPLOB)
 Endif

  # Restore ~ characters
 [L]_KEYVALTAB(J) = ctrans([L]_KEYVALTAB(J) ,[V]CST_ESCTILDE ,[V]CST_TILDE)
Wend
J+=1
[L]_KEYVALTAB(J)=[L]_KEYVAL
Return

#-----------------------------------------------------#
# Decode [V]CST_AURLSEPLOB/CST_AURLSEPLOB_ASCII separator key
#-----------------------------------------------------#

Subprog DECODE_KEY(KEYS,NBKEY,KEYVAL)
Value    Char    KEYS
Variable Integer NBKEY
Variable Char    KEYVAL()(1..)
Local Char CHAINE(250)
Local Integer K,KEY0
KEY0=0
NBKEY = 0
CHAINE = KEYS
K = instr(1,CHAINE,[V]CST_AURLSEPLOB)
If K=0
 K = instr(1,CHAINE,[V]CST_AURLSEPLOB_ASCII)
 KEY0=1
Endif
While CHAINE<>"" & NBKEY<dim(KEYVAL)
 NBKEY += 1
 If KEY0=1
  K = instr(1,CHAINE,[V]CST_AURLSEPLOB_ASCII)
 Else
  K = instr(1,CHAINE,[V]CST_AURLSEPLOB)
 Endif
 If K
  KEYVAL(NBKEY) = left$(CHAINE,K-1)
  If KEY0=1
   CHAINE = right$(CHAINE,K+len([V]CST_AURLSEPLOB_ASCII))
  Else
   CHAINE = right$(CHAINE,K+len([V]CST_AURLSEPLOB))
  Endif
 Else
  KEYVAL(NBKEY) =  CHAINE
  CHAINE = ""
 Endif
 KEYVAL(NBKEY) = ctrans(KEYVAL(NBKEY) ,[V]CST_ESCTILDE ,[V]CST_TILDE)
Wend
End

#-------------------------------------------#
Funprog READ_LOB(ENT_TYPE,KEYS,_CNT,ASEND,CLOB,BLOB)
Value    Char    ENT_TYPE
Value    Char    KEYS
Variable Char    _CNT
Variable Instance ASEND Using OBJECT
Variable Clbfile CLOB
Variable Blbfile BLOB
Local Integer I , NBKEY , ASTATUS
Local Char    KEYVAL(250)(1..16) , NOMTRT(250) , REPNAM(20) , CHAINE(250)

Call DECODE_KEY(KEYS,NBKEY,KEYVAL)
If ENT_TYPE=CST_AURLBLOB
  REPNAM = "WBLB"
Else
  REPNAM = "WCLB"
Endif
Local Instance WCLA Using =KEYVAL(1)
WCLA = evalue ("Newinstance ["+REPNAM+"] , "+KEYVAL(1))
CHAINE = ""
# Search name of property
# $details & $query
# keyval(1) Classe name
# keyval(2) Property name
For I=3 To NBKEY
 If I>3 : CHAINE += [V]CST_AURLSEPLOB : Endif
 CHAINE += KEYVAL(I)
Next I
If ENT_TYPE=CST_AURLBLOB
  ASTATUS = fmet WCLA.AREAD_BLB(KEYVAL(2),CHAINE,_CNT,BLOB)
Else
  ASTATUS = fmet WCLA.AREAD_CLB(KEYVAL(2),CHAINE,_CNT,CLOB)
Endif
FreeInstance WCLA

#SAM 109102
If ASTATUS=[V]CST_AOK
  ASEND.HEADERCOD(1) = "content-disposition"
  ASEND.HEADERVAL(1) = "attachement;filename="+KEYVAL(4)
Endif
End

#---------------------------------------------------------#
Subprog GET_LOB_CLASS(ENT_TYPE,REP,WREP,KEYS,_CNT,CLOB,BLOB)
Value    Char    ENT_TYPE
Variable Instance REP       Using C_AREPENT
Variable Instance WREP      Using OBJECT
Value    Char     KEYS
Variable Char     _CNT
Variable Clbfile  CLOB
Variable Blbfile  BLOB
Local Integer I
Local Integer NBKEY
Local Char    KEYVAL(250)(1..16)
Local Uuident  UIF
Local Char    CHAINE(250)
Local Char    WNAMINS(250)
# Search name of property
# $edit
# keyval(1) Classe name
# keyval(2) Property name
# keyval(3) Uuid of instance
Call DECODE_KEY(KEYS,NBKEY,KEYVAL)
# Find property blob image
For I=1 To maxtab(REP.PRO)
 If REP.PRO(I)<>null & REP.PRO(I).PRO=KEYVAL(2)
  CHAINE = REP.PRO(I).PTH
  Break
 Endif
Next I
# Assign blob class only once
If CHAINE<>""
  UIF=toUuid(KEYVAL(3))
  #TODO Call FIND_UUID_INSTANCE(WREP,UIF,"",WNAMINS) From ASYRUID
  Call FIND_UUID_INSTANCE_EX(WREP,REP,null,UIF,"WREP",WNAMINS) From ASYRUID
  If WNAMINS = ""
   WNAMINS = "WREP"
  Endif
  CHAINE = func ASYRDELCLI.PATH_PROCOL(WNAMINS,CHAINE)
# If WREP.snapshotEnabled & evalue("WREP."+CHAINE+".MODIFIED")
  If ENT_TYPE=CST_AURLBLOB
    BLOB = evalue(CHAINE)
    Call TRACE("representation get clob="+num$(len(BLOB))-"in property="+CHAINE) From ASYRCOM
  Else
    CLOB = evalue(CHAINE)
    Call TRACE("representation get clob="+num$(len(CLOB))-"in property="+CHAINE) From ASYRCOM
  Endif
  # Issue 2075
  [L]_CNT = evalue('fmet '+func ASYRDATDET.PREFIX_INSTANCE(CHAINE)+'.AGETATTRIBUTE(func ASYRDATDET.FINAL_INSTANCE(CHAINE),"$contentType")')
# Else
#  Call READ_LOB(ENT_TYPE,KEYS,CLOB,BLOB)
#  If ENT_TYPE=CST_AURLBLOB
#    Call TRACE("base get blob="+num$(len(BLOB))-"in property="+"WREP."+CHAINE) From ASYRCOM
#    Assign "WREP."+CHAINE With BLOB
#  Else
#    Call TRACE("base get clob="+num$(len(CLOB))-"in property="+"WREP."+CHAINE) From ASYRCOM
#    Assign "WREP."+CHAINE With CLOB
#  Endif
# Endif
Endif
End

#---------------------------------------------------------#
Subprog PUT_LOB(ENT_TYPE,CONTENTTYPE,REP,WREP,KEYS,_CNT,CLOB,BLOB)
Value    Char    ENT_TYPE,CONTENTTYPE
Variable Instance REP       Using C_AREPENT
Variable Instance WREP      Using OBJECT
Value    Char     KEYS
Variable Char     _CNT
Variable Clbfile  CLOB
Variable Blbfile  BLOB
Local Integer I,ASTATUS
Local Integer NBKEY
Local Char    KEYVAL(250)(1..16)
Local Uuident  UIF
Local Char    CHAINE(250)
Local Char    WNAMINS(250)
# Search name of property
# $edit
# keyval(1) Classe name
# keyval(2) Property name
# keyval(3) Uuid of instance
Call DECODE_KEY(KEYS,NBKEY,KEYVAL)
# Find property blob image
For I=1 To maxtab(REP.PRO)
 If REP.PRO(I)<>null & REP.PRO(I).PRO=KEYVAL(2)
  CHAINE = REP.PRO(I).PTH
  Break
 Endif
Next I
# Assign blob class only once
If CHAINE<>""
  UIF=toUuid(KEYVAL(3))
  #TODO Call FIND_UUID_INSTANCE(WREP,UIF,"",WNAMINS) From ASYRUID
  Call FIND_UUID_INSTANCE_EX(WREP,REP,null,UIF,"WREP",WNAMINS) From ASYRUID

  If WNAMINS = ""
   WNAMINS = "WREP"
  Endif
  CHAINE = func ASYRDELCLI.PATH_PROCOL(WNAMINS,CHAINE)
  If ENT_TYPE=CST_AURLBLOB
    Assign CHAINE With BLOB
    Call TRACE("put blob="+num$(len(BLOB))-"in property="+CHAINE) From ASYRCOM
  Else
    Assign CHAINE With CLOB
    Call TRACE("put clob="+num$(len(CLOB))-"in property="+CHAINE) From ASYRCOM
  Endif
  [L]ASTATUS = evalue('fmet '+func ASYRDATDET.PREFIX_INSTANCE(CHAINE)+'.ASETATTRIBUTE(func ASYRDATDET.FINAL_INSTANCE(CHAINE),"$contentType",CONTENTTYPE)')
  For I=1 To maxtab(WREP._APARAMURL)
    If WREP._APARAMURL(I).PAR="x-file-name"
     [L]ASTATUS = evalue('fmet '+func ASYRDATDET.PREFIX_INSTANCE(CHAINE)+'.ASETATTRIBUTE(func ASYRDATDET.FINAL_INSTANCE(CHAINE),"$filename",WREP._APARAMURL(I).VPR)')
     Break
    Endif
  Next I
Endif
End



#-----------------------------------------------------#
# AML7806 To ATYP Values
#-----------------------------------------------------#
Funprog F_AML7806_TO_ATYP(VAL7806)
Value Integer VAL7806

Case VAL7806
 When 2 : #Texte
  End "ATYPE9"
 When 3 : #Image
  End "ATYPE9-1"
 When 4 : #Bureautique
  End "ATYPE9"
 When 5 : #Word
  End "DOC"
 When 6 : #Excel
  End "XLS"
 When 7 : #PowerPoint
  End "PPT"
Endcase
End "ATYPE9"

#-----------------------------------------------------#
# ATYP To AML7806 Values
#-----------------------------------------------------#
Funprog F_CNTTYP_TO_AML7806(VALCNTTYP)
Value Char VALCNTTYP

If instr(1,VALCNTTYP,"text")
 End 2
Elsif instr(1,VALCNTTYP,"image")
 End 3
Elsif instr(1,VALCNTTYP,"word")
 End 5
Elsif instr(1,VALCNTTYP,"excel")
 End 6
Elsif instr(1,VALCNTTYP,"powerpoint")
 End 7
Endif
End 1

#-----------------------------------------------------#
# ADI902 To ATYP Values
#-----------------------------------------------------#
Funprog F_ADI902_TO_CNTTYP(VALTYPTYP,DOSSIER,VAL902)
Value Integer VALTYPTYP : #Valeur de type de données interne CST_ATYPBLOB=Blob , CST_ATYPCLOB=Clob
Value Char DOSSIER,VAL902

If DOSSIER="" | DOSSIER=nomap
 Local File ATABDIV [ADI]
 Local File ATYPEPRO [ATYP]
Else
 Local File =DOSSIER+".ATABDIV" [ADI]
 Local File =DOSSIER+".ATYPEPRO" [ATYP]
Endif

Read [ADI]CODE=902;VAL902
If !fstat
 If [F:ADI]A2<>""
  Read [ATYP]ATYP0=[F:ADI]A2
  If !fstat
   If VALTYPTYP=[F:ATYP]TYPTYP
    End [F:ADI]A2
   Endif
  Endif
 Endif
Endif
End ""

Funprog F_ADI902_TO_ATYP(VALTYPTYP,DOSSIER,VAL902)
Value Integer VALTYPTYP : #Valeur de type de données interne CST_ATYPBLOB=Blob , CST_ATYPCLOB=Clob
Value Char DOSSIER,VAL902

If DOSSIER="" | DOSSIER=nomap
 Local File ATABDIV [ADI]
 Local File ATYPEPRO [ATYP]
Else
 Local File =DOSSIER+".ATABDIV" [ADI]
 Local File =DOSSIER+".ATYPEPRO" [ATYP]
Endif

Read [ADI]CODE=902;VAL902
If !fstat
 If [F:ADI]A2<>""
  Read [ATYP]ATYP0=[F:ADI]A2
  If !fstat
   If VALTYPTYP=[F:ATYP]TYPTYP
    End [F:ADI]A2
   Endif
  Endif
 Endif
Endif
If VALTYPTYP=CST_ATYPCLOB
 End "ATYPE10"
Elsif VALTYPTYP=CST_ATYPBLOB
 End "ATYPE9"
Endif
End "ATYPE10"

#-----------------------------------------------------#
# ADI902 To ATYP Values
#-----------------------------------------------------#
Funprog F_CNTTYP_TO_ADI902(VALTYPTYP,DOSSIER,AVALFILENAME)
Value Integer VALTYPTYP : #Valeur de type de données interne CST_ATYPBLOB=Blob , CST_ATYPCLOB=Clob
Value Char DOSSIER,AVALFILENAME

Local Char WCODE(GLONADI)
If DOSSIER="" | DOSSIER=nomap
 Local File ATABDIV [ADI]
Else
 Local File =DOSSIER+".ATABDIV" [ADI]
Endif

#1 - on cherche l'extension
If len(AVALFILENAME)
 For [ADI] Where NUMTAB=902
  If len(AVALFILENAME)>len([F:ADI]A1)
   If right$(toupper(AVALFILENAME),len(AVALFILENAME)-len([F:ADI]A1))="."+toupper([F:ADI]A1)
    WCODE=[F:ADI]CODE
    Break
   Endif
  Endif
 Next
 If WCODE<>"" : End WCODE : Endif
Endif

# 2 - on prend le DIV
For [ADI] Where NUMTAB=902 & A1="" & A2=""
 WCODE=[F:ADI]CODE
 Break
Next
If WCODE<>"" : End WCODE : Endif
#3 - On n'a pas trouvé
End ""

#-----------------------------------------------------#
# CNTTYP To ATYP Values
#-----------------------------------------------------#
Funprog F_CNTTYP_TO_ATYP(VALTYPTYP,DOSSIER,VALCNTTYP)
Value Integer VALTYPTYP : #Valeur de type de données interne CST_ATYPBLOB=Blob , CST_ATYPCLOB=Clob
Value Char DOSSIER,VALCNTTYP

If instr(1,VALCNTTYP,"image") & VALTYPTYP=CST_ATYPBLOB
 End "ATYPE9-1"
Endif

Local Char WATYP(GLONATYP)
If DOSSIER="" | DOSSIER=nomap
 Local File ATYPEPRO [ATYP]
Else
 Local File =DOSSIER+".ATYPEPRO" [ATYP]
Endif

For [ATYP]ATYP0 Where STDFLG=2 & TYPTYP=VALTYPTYP & PROTYP=VALCNTTYP
 WATYP=[F:ATYP]COD
 Break
Next
If WATYP<>"" : End WATYP : Endif
For [ATYP]ATYP0 Where STDFLG<>2 & TYPTYP=VALTYPTYP & PROTYP=VALCNTTYP
 WATYP=[F:ATYP]COD
 Break
Next
If WATYP<>"" : End WATYP : Endif
If VALTYPTYP=CST_ATYPCLOB
 End "ATYPE10"
Elsif VALTYPTYP=CST_ATYPBLOB
 End "ATYPE9"
Endif
End "ATYPE10"

