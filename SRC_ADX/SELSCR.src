#Default File [GBS]
#CRITERE = "FLGHIS="+PARAM(3)
#Call SELOBJ("GBS","",NBCOL,COL,TIT) From CONTOBJ
#TIT(0)  = mess(18,100,1) :#Sélection
ORDRE   = "COD"
START   = "COD"
Return
