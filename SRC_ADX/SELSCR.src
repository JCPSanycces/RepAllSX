$ACTION
Case ACTION
 When "SEL_TABLE" : Gosub SEL_TABLE
Endcase
Return

$SEL_TABLE
Case TABLE
 When "SELSCR"    : Gosub S_SCR
Endcase
Return

$S_SCR
