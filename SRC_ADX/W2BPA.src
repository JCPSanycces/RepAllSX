#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque BPA 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_XWEB5
Onevent AFTER_CHANGE Gosub AMM_XWEB5 From W2BPA
Onevent BEFORE_INPUT Call AS_XWEB5(zc) From W2BPA
Return

Subprog AS_XWEB5(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_XWEB5(zc) From W2BPA
Gosub _AFF
End

$AMM_XWEB5
Call AM_XWEB5(zc)
If !mkstat & GOBJET
 zoncou = "XWEB5" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_XWEB5(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_XWEB5(VALEUR) From TRTBPA
If mkstat : GERR = 1 : GZONE = "XWEB5" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog S_XWEB5(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ASELEMAIL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ASELEMAIL"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELEMAIL","TRTBPA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_TRTBPAB
Return

$CHG_STY
Return


