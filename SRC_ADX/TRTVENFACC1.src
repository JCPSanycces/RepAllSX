#        Call RNDTVA(TBASTAX(I),TTAUTAX(I),[F:TCU]CURRND,WAMTTAX) From SUBTVT
#    Else                             : # Dde 81811 : Optimisation
#        #WAMTTAX                      : # Dde 81811 : Optimisation : # 88927
#        WAMTTAX=0                    : # Dde 81811 : Optimisation  : # 88927
#    Endif                            : # Dde 81811 : Optimisation
#
#    If WAMTTAX<>TAMTTAX(I)
#        # Le Montant total taxe calculé est différent de la somme des montants de taxe
#        # --> Il faut répartir la différence
#        #
