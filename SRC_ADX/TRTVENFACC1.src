#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
# TRTVENFACC1 : Calcul de la facture
#
# Suite TRTVENFACC
#------------------------------------------------------------------------
# En cas de modification : verifier le report sur TRTTAXUSA
#########################################################################
# Issue 119119 - 20161116 by LD : Calcul des frais de port facture
# Issue 122450 - 20170502 by LD : Invoicing element from column erroneously rounded

# ------------------------------------------------------------------------------------------------ #
# Vérifier pour chaque taxe que :                                                                  #
# --> Montant total de taxe = montant total taxe produit + montant total taxe de ts les éléments   #
# Si différence :                                                                                  #
# --> Garder le Montant total de taxe calculé                                                      #
# --> Répartir la différence sur la taxe des éléments les + élévés                                 #
#     NB : On ne répartit pas sur les éléments en TTC (cela modifierait la valeur TTC saisie)      #
# ------------------------------------------------------------------------------------------------ #
$REGUL_MONTANT_TAXE

Local Decimal WAMTTAX, WAMTREGUL : # Bug 71568
Local Integer WNBRCLC
Local Decimal WDTANOT, WDTANET   : # Bug 119119

# Calcul pour chaque taxe de la base de taxe et du total de la taxe
Gosub CHARGE_TTAX From TRTVENFACC

# Traitement de chaque taxe
For I=0 To dim(TBASTAX)-1
    # Calcul du montant total de la taxe en partant du Total de la base de taxe
    If TBASTAX(I)<>0                 : # Dde 81811 : Optimisation
        Call RNDTVA(TBASTAX(I),TTAUTAX(I),[F:TCU]CURRND,WAMTTAX) From SUBTVT
    Else                             : # Dde 81811 : Optimisation
        #WAMTTAX                      : # Dde 81811 : Optimisation : # 88927
        WAMTTAX=0                    : # Dde 81811 : Optimisation  : # 88927
    Endif                            : # Dde 81811 : Optimisation

    If WAMTTAX<>TAMTTAX(I)
        # Le Montant total taxe calculé est différent de la somme des montants de taxe
        # --> Il faut répartir la différence
        # Remplissage du tableau de travail servant à la répartition de la différence
        #
        # La différence est répartie sur les mnts de taxe des élts de facturation
        # On réparti en priorité sur les mnts les + élevés
        # On réparti également sur les mnts à 0 si la base est différente de 0
        # On ne prend pas en compte les élts en TTC
        # Tableau de répartition :
        # [M:SIHV]CLCTOT        : Montant total taxe calculé
        # [M:SIHV]CLCARR        : Arrondi de la devise : C'est l'unité servant à la répartition
        # [M:SIHV]CLCVALIN(J)   : Mnt taxe de l'élt avant répartition
        # [M:SIHV]CLCVALOUT(J)  : Mnt taxe de l'élt après répartition
        # [M:SIHV]CLCFLG(J)     : Flag de travail
        #                       : -1 = Elt avec mnt taxe à  0 à répartir
        #                       :  0 = Elt avec mnt taxe <> 0 à répartir
        #                       :  1 = A ne pas répartir
        #                       :  2 = Répartition effectuée
        # [M:SIHV]CLCNUM(J)     :  Indice
        # [M:SIHV]CLCALP(J)     :  N° de l'élt
        [M:SIHV]CLCTOT = WAMTTAX
        [M:SIHV]CLCARR = [F:TCU]CURRND
        Raz [M:SIHV]CLCVALIN, [M:SIHV]CLCVALOUT, [M:SIHV]CLCFLG, [M:SIHV]CLCNUM, [M:SIHV]CLCALP
        WNBRCLC=0
        For J=0 To dim([M:SIHV]XFNUM)-1
            # 96695 : Prise en cpte base HT d'un élt ds la base HT des taxes si mnt de taxe de l'elt nul
            # On réparti sur les élts qui ont un mnt de taxe ou qui ont une base
            #If [M:SIHV]XFVATAMT(J)<>0
            If [M:SIHV]XFVATAMT(J)<>0 | [M:SIHV]XFSMI(J)<>0
            # 96695
                If [M:SIHV]XFTAX(J)=TTAX(I) | [M:SIHV]VATRUL(J)=1
                    For K=0 To dim([M:SIHV]XVTAX)-1
                        If evalue ("dim([M:SIHV]DTAVAT"+format$("N0:2",K+1)+")")>0
                            If evalue ("[M:SIHV]DTAVAT"+format$("N0:2",K+1)+"("+num$(J)+")")=TTAX(I)
                                [M:SIHV]CLCVALIN(WNBRCLC)=evalue("[M:SIHV]DTAVATMT"+format$("N0:2",K+1)+"("+num$(J)+")")
                                [M:SIHV]CLCNUM(WNBRCLC)=K+1
                                Break
                            Endif
                        Endif
                    Next
                    # 96695 : Prise en cpte base HT d'un élt ds la base HT des taxes si mnt de taxe de l'elt nul
                    # On réparti sur les éléments qui ont un mnt de taxe ou qui ont une base
#                    If [M:SIHV]CLCVALIN(WNBRCLC)<>0
#                        [M:SIHV]CLCALP(WNBRCLC)  = num$([M:SIHV]XFNUM(J))
#                        # On ne fait pas de régul sur les éléments en TTC : On le flag
#                        If [M:SIHV]VALTYP(J)=2 [M:SIHV]CLCFLG(WNBRCLC)=1 Endif
#                        WNBRCLC+=1
#                    Endif
                    # 102264
#                    If [M:SIHV]CLCVALIN(WNBRCLC)<>0
#                        # L'élément a un montant de taxe
#                        [M:SIHV]CLCALP(WNBRCLC)  = num$([M:SIHV]XFNUM(J))
#                        # On ne fait pas de régul sur les éléments en TTC : On le flag
#                        If [M:SIHV]VALTYP(J)=2 [M:SIHV]CLCFLG(WNBRCLC)=1 Endif
#                        WNBRCLC+=1
#                    Elsif [M:SIHV]XFSMI(J)<>0
#                        # L'élément a une base : On le différencie en positionnant CLCFLG à -1
#                        [M:SIHV]CLCFLG(WNBRCLC)= -1
#                        [M:SIHV]CLCALP(WNBRCLC)  = num$([M:SIHV]XFNUM(J))
#                        # On ne fait pas de régul sur les éléments en TTC : On le flag
#                        If [M:SIHV]VALTYP(J)=2 [M:SIHV]CLCFLG(WNBRCLC)=1 Endif
#                        WNBRCLC+=1
#                    Endif
                    If [M:SIHV]XFVATAMT(J)<>0
                        If [M:SIHV]CLCVALIN(WNBRCLC)<>0
                            # L'élément a un montant de taxe
                            [M:SIHV]CLCALP(WNBRCLC)  = num$([M:SIHV]XFNUM(J))
                            # On ne fait pas de régul sur les éléments en TTC : On le flag
                            If [M:SIHV]VALTYP(J)=2 [M:SIHV]CLCFLG(WNBRCLC)=1 Endif
                            WNBRCLC+=1
                        Endif
                    Elsif [M:SIHV]XFSMI(J)<>0
                        If [M:SIHV]CLCNUM(WNBRCLC)<>0
                            # L'élément a une base et il est soumis à la taxe dt on veut répartir le montant
                            # On le différencie en positionnant CLCFLG à -1
                            [M:SIHV]CLCFLG(WNBRCLC)= -1
                            [M:SIHV]CLCALP(WNBRCLC)  = num$([M:SIHV]XFNUM(J))
                            # On ne fait pas de régul sur les éléments en TTC : On le flag
                            If [M:SIHV]VALTYP(J)=2 [M:SIHV]CLCFLG(WNBRCLC)=1 Endif
                            WNBRCLC+=1
                        Endif
                    Endif
                   # 102264
                    # 96695
                Endif
            Endif
        Next
        # Dernier poste rempli avec la taxe correspondant aux produits
        RV=find(TTAX(I),[M:SIHV]XVTAX(0..dim([M:SIHX]XVTAX)-1))
        If RV
            [M:SIHV]CLCVALIN(WNBRCLC)= [M:SIHV]XVAMT(RV-1)
            [M:SIHV]CLCALP(WNBRCLC)  = "9999"
            [M:SIHV]CLCFLG(WNBRCLC)  = 1
        Endif
        If WNBRCLC>=1 & sum([M:SIHV]CLCFLG)<=WNBRCLC
            # 96695
            #Gosub DISPATCH_VALS From TRTVENFACC : # Appel du traitement de répartition
           Gosub DISPATCH_VALS From TRTVENFACC1 : # Appel du traitement de répartition
            # 96695
            # On réinjecte les montants régularisés
            For J=0 To WNBRCLC-1
#               97076 : Ecart d'arrondi sur calcul TVA
#               Il faut traiter le cas où le mnt régularisé ([M:SIHV]CLCVALOUT(J)) est passé à 0
#               On teste s'il y a une différence entre mnt avt régul ([M:SIHV]CLCVALIN(J)) et mnt après régul ([M:SIHV]CLCVALOUT(J))
#                If [M:SIHV]CLCVALOUT(J)<>0 & [M:SIHV]CLCFLG(J)<>1 & [M:SIHV]CLCALP(J)<>"9999"
                If [M:SIHV]CLCVALOUT(J)<>[M:SIHV]CLCVALIN(J) & [M:SIHV]CLCFLG(J)<>1 & [M:SIHV]CLCALP(J)<>"9999"
#               97076
                    RV=find(val([M:SIHV]CLCALP(J)),[M:SIHV]XFNUM(0..dim([M:SIHX]XFNUM)-1))
                    If RV
                        WDTAVATAMT=evalue("[M:SIHV]DTAVATMT"+format$("N0:2",[M:SIHV]CLCNUM(J))+"("+num$(RV-1)+")")
                        # On régularise le montant de la taxe dans le tableau du détail des taxes
                        Assign ("[M:SIHV]DTAVATMT"+format$("N0:2",[M:SIHV]CLCNUM(J))+"("+num$(RV-1)+")") With [M:SIHV]CLCVALOUT(J)#                        If [M:SIHV]XFTAX(RV-1)=TTAX(I)
#                            [M:SIHV]XFVATAMT(RV-1)=[M:SIHV]CLCVALOUT(J)
#                        Endif
                        # On régularise le montant de la taxe total de l'élément
                        [M:SIHV]XFVATAMT(RV-1)-=WDTAVATAMT
                        [M:SIHV]XFVATAMT(RV-1)+=[M:SIHV]CLCVALOUT(J)
                        # Issue 122450
#                        # Issue 119119
##                        # On recalcule le montant TTC de l'élément
##                        # Bug 71568 : Régularisation de la taxe sur le TTC Produit ou ligne
##                        #[M:SIHV]XFATIP(RV-1)=[M:SIHV]XFNOTP(RV-1)+[M:SIHV]XFVATAMT(RV-1)
##                        WAMTREGUL=[M:SIHV]CLCVALOUT(J)-WDTAVATAMT
##                        If [M:SIHV]XFNOTP(RV-1)<>0
##                          [M:SIHV]XFATIP(RV-1)+=WAMTREGUL
##                        Elsif [M:SIHV]XFNOTL(RV-1)<>0
##                          [M:SIHV]XFATIL(RV-1)+=WAMTREGUL
##                        Endif
##                        # Bug 71568
##                        [M:SIHV]XFATI(RV-1) =[M:SIHV]XFATIP(RV-1)+[M:SIHV]XFATIL(RV-1)
#                        # Le montant TTC ne doit pas bouger et on garde le montant de taxe calculé
#                        # On doit donc recalculer le montant HT et le montant soulis de l'élément et non le montant TTC
#                        WAMTREGUL=[M:SIHV]CLCVALOUT(J)-WDTAVATAMT
#                        If [M:SIHV]XFNOTP(RV-1)<>0
#                          [M:SIHV]XFNOTP(RV-1)-=WAMTREGUL
#                          [M:SIHV]XFSMIP(RV-1)-=WAMTREGUL
#                        Elsif [M:SIHV]XFNOTL(RV-1)<>0
#                          [M:SIHV]XFNOTL(RV-1)-=WAMTREGUL
#                          [M:SIHV]XFSMIL(RV-1)-=WAMTREGUL
#                        Endif
#                        [M:SIHV]XFNOT(RV-1) =[M:SIHV]XFNOTP(RV-1)+[M:SIHV]XFNOTL(RV-1)
#                        [M:SIHV]XFSMI(RV-1) =[M:SIHV]XFSMIP(RV-1)+[M:SIHV]XFSMIL(RV-1)
#                        # On régularise le montant HT et le montant soumis dans le tableau du détail des taxes
#                        WDTANOT=evalue("[M:SIHV]DTANOT"+format$("N0:2",[M:SIHV]CLCNUM(J))+"("+num$(RV-1)+")")
#                        If WDTANOT<>0
#                            WDTANOT-=WAMTREGUL
#                            Assign ("[M:SIHV]DTANOT"+format$("N0:2",[M:SIHV]CLCNUM(J))+"("+num$(RV-1)+")") With WDTANOT
#                        Endif
#                        WDTANET=evalue("[M:SIHV]DTANET"+format$("N0:2",[M:SIHV]CLCNUM(J))+"("+num$(RV-1)+")")
#                        If WDTANET<>0
#                            WDTANET-=WAMTREGUL
#                            Assign ("[M:SIHV]DTANET"+format$("N0:2",[M:SIHV]CLCNUM(J))+"("+num$(RV-1)+")") With WDTANET
#                        Endif
#                        # End issue 119119
                        If [M:SIH1]PRITYP=2
                            # Le document est en TTC :
                            # --> Le montant TTC ne doit pas bouger et on garde le montant de taxe calculé
                            # --> On doit donc recalculer le montant HT et le montant soulis de l'élément et non le montant TTC
                            WAMTREGUL=[M:SIHV]CLCVALOUT(J)-WDTAVATAMT
                            If [M:SIHV]XFNOTP(RV-1)<>0
                              [M:SIHV]XFNOTP(RV-1)-=WAMTREGUL
                              [M:SIHV]XFSMIP(RV-1)-=WAMTREGUL
                            Elsif [M:SIHV]XFNOTL(RV-1)<>0
                              [M:SIHV]XFNOTL(RV-1)-=WAMTREGUL
                              [M:SIHV]XFSMIL(RV-1)-=WAMTREGUL
                            Endif
                            [M:SIHV]XFNOT(RV-1) =[M:SIHV]XFNOTP(RV-1)+[M:SIHV]XFNOTL(RV-1)
                            [M:SIHV]XFSMI(RV-1) =[M:SIHV]XFSMIP(RV-1)+[M:SIHV]XFSMIL(RV-1)
                            # On régularise le montant HT et le montant soumis dans le tableau du détail des taxes
                            WDTANOT=evalue("[M:SIHV]DTANOT"+format$("N0:2",[M:SIHV]CLCNUM(J))+"("+num$(RV-1)+")")
                            If WDTANOT<>0
                                WDTANOT-=WAMTREGUL
                                Assign ("[M:SIHV]DTANOT"+format$("N0:2",[M:SIHV]CLCNUM(J))+"("+num$(RV-1)+")") With WDTANOT
                            Endif
                            WDTANET=evalue("[M:SIHV]DTANET"+format$("N0:2",[M:SIHV]CLCNUM(J))+"("+num$(RV-1)+")")
                            If WDTANET<>0
                                WDTANET-=WAMTREGUL
                                Assign ("[M:SIHV]DTANET"+format$("N0:2",[M:SIHV]CLCNUM(J))+"("+num$(RV-1)+")") With WDTANET
                            Endif
                        Else
                            # Le document est en HT :
                            # --> Le montant HT ne doit pas bouger et on garde le montant de taxe calculé
                            # --> On doit donc recalculer le montant TTC
                            WAMTREGUL=[M:SIHV]CLCVALOUT(J)-WDTAVATAMT
                            If [M:SIHV]XFNOTP(RV-1)<>0
                              [M:SIHV]XFATIP(RV-1)+=WAMTREGUL
                            Elsif [M:SIHV]XFNOTL(RV-1)<>0
                              [M:SIHV]XFATIL(RV-1)+=WAMTREGUL
                            Endif
                            [M:SIHV]XFATI(RV-1) =[M:SIHV]XFATIP(RV-1)+[M:SIHV]XFATIL(RV-1)
                        Endif
                        # Issue 122450
                    Endif
                Endif
            Next
        Endif
    Endif
Next I

Return

###########################################################################

#----------------------------------------------------------------------------------------#
#    Répartition d'erreur d'arrondi, en fonction d'un total                              #
#----------------------------------------------------------------------------------------#
# Tableau de répartition :
# [M:SIHV]CLCTOT        : Montant total calculé
# [M:SIHV]CLCARR        : Arrondi de la devise : C'est l'unité servant à la répartition
# [M:SIHV]CLCVALIN(J)   : Mnt avant répartition
# [M:SIHV]CLCVALOUT(J)  : Mnt après répartition
# [M:SIHV]CLCFLG(J)     : Flag de travail
#                       : -1 = Mnt =  0 à répartir
#                          (Il faut pouvoir répartir sur les mnts à 0)
#                       :  0 = Mnt <> 0 à répartir
#                       :  1 = A ne pas répartir
#                       :  2 = Répartition effectuée
# [M:SIHV]CLCNUM(J)     :  Indice
# [M:SIHV]CLCALP(J)     :  N° de l'élt
#----------------------------------------------------------------------------------------#
$DISPATCH_VALS
# Var de travail
Local Integer WJL        : # ligne en cours de traitement
Local Decimal WREPARTIR  : # montant à repartir

# Copie initiale des ValIn dans ValOut
For WJL=0 To dim([M:SIHV]CLCALP)-1
    [M:SIHV]CLCVALOUT(WJL) = [M:SIHV]CLCVALIN(WJL)
Next

# Calcul du montant à répartir : Mnt total calculé - Somme des mnts
WREPARTIR=[M:SIHV]CLCTOT - sum([M:SIHV]CLCVALOUT)

# On boucle tant que l'on a quelque chose à répartir
While arr(WREPARTIR,[M:SIHV]CLCARR) <> 0
    # Copie dans colonne de travail
    For WJL=0 To dim([M:SIHV]CLCALP)-1
        [M:SIHV]CLCVALTMP(WJL) = abs(func DISPATCH_VALS_TMP([M:SIHV]CLCVALOUT(WJL),[M:SIHV]CLCFLG(WJL)))
    Next

    # Erreur à gérer au cas ou, sinon la boucle While boucle : # Bug 63250
    # 96695 : Prise en cpte base HT d'un élt ds la base HT des taxes si mnt de taxe de l'elt nul
    #Break ( max([M:SIHV]CLCVALTMP)=0 )                       : # Bug 63250
    # Si ts les mnts servant à la répartition qui étaient différents de 0 au départ sont passés à 0
    # alors on sort de la boucle
    If max([M:SIHV]CLCVALTMP)=0 & !find(-1, [M:SIHV]CLCFLG)
        Break
    Endif
    # 96695

    # On recherche la valeur avec la valeur absolue la plus importante, non flagée
    WJL=find( max( [M:SIHV]CLCVALTMP ), [M:SIHV]CLCVALTMP )

    # Ne devrait pas se produire
    # Erreur à gérer au cas ou, sinon la boucle While boucle
    Break ( WJL=0 )

    # 96695 : Prise en cpte base HT d'un élt ds la base HT des taxes si mnt de taxe de l'elt nul
    # Il faut pouvoir répartir sur les mnts à 0
    #If [M:SIHV]CLCVALTMP(WJL-1)<>0
    If [M:SIHV]CLCVALTMP(WJL-1)<>0 | [M:SIHV]CLCFLG(WJL-1)=-1
    # 96695
        If WREPARTIR>0
            [M:SIHV]CLCVALOUT(WJL-1)+=[M:SIHV]CLCARR
            WREPARTIR-=[M:SIHV]CLCARR
        Else
            [M:SIHV]CLCVALOUT(WJL-1)-=[M:SIHV]CLCARR
            WREPARTIR+=[M:SIHV]CLCARR
        Endif
        [M:SIHV]CLCFLG(WJL-1)=2
    Else
        # On a fait un tour, tous les Flag sont à 1 ou 2
        # On reset les flag 2->0 pour refaire un tour
        For WJL=0 To dim([M:SIHV]CLCALP)-1
            # 96695 : Prise en cpte base HT d'un élt ds la base HT des taxes si mnt de taxe de l'elt nul
            # Il faut pouvoir répartir sur les mnts à 0
            #If [M:SIHV]CLCFLG(WJL) = 2
            If [M:SIHV]CLCFLG(WJL) = 2 | [M:SIHV]CLCFLG(WJL) = -1
            # 96695
                [M:SIHV]CLCFLG(WJL) = 0
            Endif
        Next
    Endif
Wend
Return
# Retourne 0 si le flag est mis (<>0)
Funprog DISPATCH_VALS_TMP(VALEUR, FLG)
Variable Decimal VALEUR
Variable Decimal FLG
Local Decimal RESULT
If FLG<>0
    RESULT=0
Else
    RESULT=VALEUR
Endif
End RESULT

###########################################################################
###########################################################################

