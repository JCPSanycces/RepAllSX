#        # [M:SIHV]CLCVALOUT(J)  : Mnt taxe de l'élt après répartition
#        # [M:SIHV]CLCFLG(J)     : Flag de travail
#        #                       : -1 = Elt avec mnt taxe à  0 à répartir
#        #                       :  0 = Elt avec mnt taxe <> 0 à répartir
