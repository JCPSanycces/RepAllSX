#        [M:SIHV]CLCTOT = WAMTTAX
#        [M:SIHV]CLCARR = [F:TCU]CURRND
#        Raz [M:SIHV]CLCVALIN, [M:SIHV]CLCVALOUT, [M:SIHV]CLCFLG, [M:SIHV]CLCNUM, [M:SIHV]CLCALP
#        WNBRCLC=0
#        For J=0 To dim([M:SIHV]XFNUM)-1
#            # 96695 : Prise en cpte base HT d'un élt ds la base HT des taxes si mnt de taxe de l'elt nul
#            # On réparti sur les élts qui ont un mnt de taxe ou qui ont une base
#            #If [M:SIHV]XFVATAMT(J)<>0
#            If [M:SIHV]XFVATAMT(J)<>0 | [M:SIHV]XFSMI(J)<>0
#            # 96695
#              If [M:SIHV]XFTAX(J)=TTAX(I) | [M:SIHV]VATRUL(J)=1
#                    For K=0 To dim([M:SIHV]XVTAX)-1
#                        If evalue ("dim([M:SIHV]DTAVAT"+format$("N0:2",K+1)+")")>0
#                            If evalue ("[M:SIHV]DTAVAT"+format$("N0:2",K+1)+"("+num$(J)+")")=TTAX(I)
#                                [M:SIHV]CLCVALIN(WNBRCLC)=evalue("[M:SIHV]DTAVATMT"+format$("N0:2",K+1)+"("+num$(J)+")")
#                                [M:SIHV]CLCNUM(WNBRCLC)=K+1
