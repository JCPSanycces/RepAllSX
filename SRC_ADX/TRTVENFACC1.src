[M:SIHX]CLCORD(JNOL-1)    = [F:SFI]CLCORD
[M:SIHX]DEFVAL(JNOL-1)    = [F:SFI]DEFVAL
[M:SIHX]DEFVAL(JNOL-1)    = [F:SFI]DEFVAL
[M:SIHX]ACTCLCBAS(JNOL-1) = [F:SFI]ACTCLCBAS
[M:SIHX]PRGCLCBAS(JNOL-1) = [F:SFI]PRGCLCBAS
[M:SIHX]TSDMIN(JNOL-1)    = [F:SFI]TSDMIN
[M:SIHX]TSDMAX(JNOL-1)    = [F:SFI]TSDMAX
[M:SIHX]VATRUL(JNOL-1)    = [F:SFI]VATRUL
[M:SIHX]VACITM(JNOL-1)    = [F:SFI]VACITM
[M:SIHX]EXCTAXRUL(JNOL-1) = [F:SFI]EXCTAXRUL
[M:SIHX]SPETAXRUL(JNOL-1) = [F:SFI]SPETAXRUL
[M:SIHX]CLCVACITM(JNOL-1) = [F:SFI]CLCVACITM
[M:SIHX]INVFOOGRU(JNOL-1) = [F:SFI]INVFOOGRU
[M:SIHX]INVFOOBRD(JNOL-1) = [F:SFI]INVFOOBRD
[M:SIHX]DSPLIN(JNOL-1)    = [F:SFI]DSPLIN
[M:SIHX]DSP(JNOL-1)       = [F:SFI]DSP
[M:SIHX]DTADEPFLG(JNOL-1) = [F:SFI]DEPFLG                   #gbn-81683
If [F:SFI]INCDCR=2 : [M:SIHX]DTADEPFLG(JNOL-1)=2 : Endif    #gbn-81683

Return

############################################################################
# Issue 119119
# ----------------------------------------------------------------------------------------------- #
# Pour une facture TTC :                                                                          #
# Vérification de la cohérence entre les montants HT Taxe et TTC                                  #
# Vérifier pour chaque taxe :                                                                     #
# --> Montant taxe calculée = Montant taxe extrait du TTC                                         #
# Si différence :                                                                                 #
# --> Garder le Montant taxe extrait du TTC et en déduire le HT                                   #
# --> Répartir la différence sur le montant HT des lignes concernées par cette taxe               #
#     NB : On ne traite que les taxes de type TVA, on ne fait rien s'il y a des taxes secondaires #
# ----------------------------------------------------------------------------------------------- #
$VERIF_COHERENCE_TOTAUX
Local Integer WNBRCLC : WNBRCLC=0 : # Bug 76201

For JL=0 To dim([M:SIHX]XVTAX)-1
  # On travaille sur les taxes type TVA, si le taux est différent de 0
  If [M:SIHX]XVTYP(JL)=1 & [M:SIHX]XVTAX(JL)<>"" & [M:SIHX]XVRAT(JL)<>0
    If [M:SIHX]XVSUP(JL)=0   : # On ne fait rien s'il y a des taxes secondaires
        WDTANET=arr([M:SIHX]XVATI(JL)/(([M:SIHX]XVRAT(JL)/100)+1),[F:TCU]CURRND)
        WDTAVATAMT=[M:SIHX]XVATI(JL)-WDTANET
        If WDTAVATAMT<>[M:SIHX]XVAMT(JL)
            # Différence entre la taxe extraite du TTC et le montant de taxe calculé : il faut régulariser
            # Remplissage du tableau de travail servant à la répartition de la différence
            [M:SIHV]CLCTOT = WDTANET
            [M:SIHV]CLCARR = [F:TCU]CURRND
            Raz [M:SIHV]CLCVALIN, [M:SIHV]CLCVALOUT, [M:SIHV]CLCFLG, [M:SIHV]CLCNUM, [M:SIHV]CLCALP
            WNBRCLC=0
            For J=0 To [M:SIH4]NBLIG-1
                If [M:SIH4]VAT1(J)=[M:SIHX]XVTAX(JL)
                    [M:SIHV]CLCVALIN(WNBRCLC)=[M:SIH4]AMTNOTLIN(J)
                    [M:SIHV]CLCNUM(WNBRCLC)=J
                    WNBRCLC+=1
                Endif
            Next
            If WNBRCLC>1
                # 96695
                #Gosub DISPATCH_VALS From TRTVENFACC : # Appel du traitement de répartition
                Gosub DISPATCH_VALS From TRTVENFACC1 : # Appel du traitement de répartition
                # 96695
                # On réinjecte les montants régularisés : On régularise le HT et on recalcule la taxe
                For J=0 To WNBRCLC-1
                    # On régularise la base de taxe 1 de la ligne
                    [M:SIH4]BASTAXLIN1([M:SIHV]CLCNUM(J))+=([M:SIHV]CLCVALOUT(J)-[M:SIH4]AMTNOTLIN([M:SIHV]CLCNUM(J)))
                    # On régularise le montant HT et la base soumise de la taxe dans le tableau des taxes
                    [M:SIHX]XVNOT (JL)+=([M:SIHV]CLCVALOUT(J)-[M:SIH4]AMTNOTLIN([M:SIHV]CLCNUM(J)))
                    [M:SIHX]XVSMIP(JL)+=([M:SIHV]CLCVALOUT(J)-[M:SIH4]AMTNOTLIN([M:SIHV]CLCNUM(J)))
                    # On remet à jour de montant HT de la ligne
                    [M:SIH4]AMTNOTLIN([M:SIHV]CLCNUM(J))=[M:SIHV]CLCVALOUT(J)

                    # 102423 : Belgium Early discounts
                    # HT amount is modified : Discount amount must be recalculed
                    If GDEPMGTMOD=5 & [M:SIH2]DEPRAT<>0
                        [M:SIH4]AMTDEPLIN([M:SIHV]CLCNUM(J))= arr([M:SIH4]AMTNOTLIN([M:SIHV]CLCNUM(J))*[M:SIH2]DEPRAT/100,[F:TCU]CURRND)
                    Endif
                    # 102423

                    [M:SIHX]XVAMT(JL)-=[M:SIH4]AMTTAXLIN1([M:SIHV]CLCNUM(J))
                    # On recalcule le montant de taxe 1 de la ligne
                    [M:SIH4]AMTTAXLIN1([M:SIHV]CLCNUM(J))=[M:SIH4]AMTATILIN([M:SIHV]CLCNUM(J))-[M:SIH4]AMTNOTLIN([M:SIHV]CLCNUM(J))
                    # On recalcule le montant de la taxe du tableau des taxes
                    [M:SIHX]XVAMT(JL)+=[M:SIH4]AMTTAXLIN1([M:SIHV]CLCNUM(J))
                Next
            Endif
        Endif
    Endif
  Endif
Next JL

Return
# End issue 119119

# X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)
###################################################################
# TAXES_PROV : En calcul des factures ventes                      #
#             Chargement des taxes provinciales dans [M:SIHV]     #
# Point d'entrée : TAXVENARG : Appel multiple                     #
#                              (tester la valeur de PE_COD)       #
#     - PE_COD="START"  --> garnir le tableau des taxes [M:SIHV]  #
#                           (voir $CHARG_VAT_ARG)                 #
#                           positionner GPE=1                     #
#     - PE_COD="END"    --> modifier le tableau des taxes [M:SIHV]#
###################################################################
$TAXES_PROV
Local Integer IJL0, IJL1,IJL2
Local Char    PE_COD (10)

Raz GPE : PE_COD="START" : GPOINT="TAXVENARG" : Gosub ENTREE From EXEFNC
If GPE : Raz GPE : Goto T_ARG_END : Endif

Local Char    PROV_TAX  (GLONVAT) (0..10)                                   : # tableaux pour taxes provinciales
Local Decimal PROV_BAS            (0..10)
Local Decimal PROV_RAT            (0..10)
Local Decimal PROV_AMT            (0..10)
Local Integer PROV_I, PROV_J
Local Decimal WSEUIL
Local Decimal WVATRAT                                                                        : # Bug 65067
Local Integer WTYPREG : WTYPREG=func TRTVENFACC.RECH_TYPREG ([M:SIH1]VACBPR)                            : # Bug 65067

If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif

If clalev([F:TFO]) = 0 Local File TABFOR [TFO] Endif
If clalev([F:TVT]) = 0 Local File TABVAT [TVT] Endif
If clalev([F:TCU]) = 0 Local File TABCUR [TCU] Endif

# --- Taxes provinciales ------------------------------------------------
Raz PROV_TAX, PROV_BAS, PROV_RAT, PROV_AMT

Call RECHVATCOD(2,1,[M:SIH1]BPCORD,"","SIHV",0,PROV_TAX) From TRTX3

# --- Chargement des taxes provinciales dans le tableau des taxes
For PROV_J=0 To dim(PROV_TAX)-1
    If PROV_TAX(PROV_J)<>""
       # X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)
#        WVAT=PROV_TAX(PROV_J) : Gosub LEC_VAT From TRTVENFACC
#        If [F:TVT]VAT<>""                                                                    : # Bug 65067
#            If [F:TVT]VATBAS=1
#                 PROV_BAS (PROV_J)=sum([M:SIHV]XVNOT)
#            Else
#                # --- Calcul des montants de base si taxe liée à une formule
#                Call ALIBASTAX(2, 0, "SIHV", PROV_TAX(PROV_J), PROV_BAS(PROV_J)) From TRTX3
#            Endif
#            WVATRAT=[F:TRA]VATRAT                                                            : # Bug 65067
#            If WTYPREG<>1 & dim([F:TRA]VATEXEFLG)>0 & [F:TRA]VATEXEFLG=2 : WVATRAT=0 : Endif : # Bug 65067
#            # Calcul de la taxe
#            Call RNDTVA(PROV_BAS(PROV_J),WVATRAT,[F:TCU]CURRND,PROV_AMT(PROV_J)) From SUBTVT : # Bug 65067
#            If dim([F:TRA]AMTTSD)>0 & [F:TRA]AMTTSD<>0
#                If GCURSHR<>[M:SIH2]CUR     : # Issue 74556 - Optimisation
#                  Call CONVERT(GCURSHR,[M:SIH2]CUR,GLOCALDEV,[M:SIH0]CHGTYP,
#&                             [M:SIH0]INVDAT,[F:TRA]AMTTSD,WSEUIL,STAT) From TRTDEV
#                Else
#                  WSEUIL=[F:TRA]AMTTSD      : # Issue 74556 - Optimisation
#                Endif
#                If PROV_AMT(PROV_J)<WSEUIL  Raz PROV_AMT(PROV_J) : Endif
#            Endif
#            Gosub CHARG_VAT_PROV
#        Endif                                                                                : # Bug 65067
        Local Integer ZWUSINGCACHECLASS : [L]ZWUSINGCACHECLASS = [V]CST_ANO
        WVAT=PROV_TAX(PROV_J)
        If dim(GACTX)<0
            Gosub LEC_VAT From TRTVENFACC
            If [F:TVT]VAT<>""                                                                    : # Bug 65067
                If [F:TVT]VATBAS=1
                     PROV_BAS (PROV_J)=sum([M:SIHV]XVNOT)
                Else
                    # --- Calcul des montants de base si taxe liée à une formule
                    Call ALIBASTAX(2, 0, "SIHV", PROV_TAX(PROV_J), PROV_BAS(PROV_J)) From TRTX3
                Endif
                WVATRAT=[F:TRA]VATRAT                                                            : # Bug 65067
                If WTYPREG<>1 & dim([F:TRA]VATEXEFLG)>0 & [F:TRA]VATEXEFLG=2 : WVATRAT=0 : Endif : # Bug 65067
                # Calcul de la taxe
                Call RNDTVA(PROV_BAS(PROV_J),WVATRAT,[F:TCU]CURRND,PROV_AMT(PROV_J)) From SUBTVT : # Bug 65067
                If dim([F:TRA]AMTTSD)>0 & [F:TRA]AMTTSD<>0
                    If GCURSHR<>[M:SIH2]CUR     : # Issue 74556 - Optimisation
                      Call CONVERT(GCURSHR,[M:SIH2]CUR,GLOCALDEV,[M:SIH0]CHGTYP,
&                                [M:SIH0]INVDAT,[F:TRA]AMTTSD,WSEUIL,STAT) From TRTDEV
                    Else
                      WSEUIL=[F:TRA]AMTTSD      : # Issue 74556 - Optimisation
                    Endif
                    If PROV_AMT(PROV_J)<WSEUIL  Raz PROV_AMT(PROV_J) : Endif
                Endif
                Gosub CHARG_VAT_PROV
            Endif
        Else
            Local Decimal WAMTTSD
            [L]ZWUSINGCACHECLASS = [V]CST_ANO
            Gosub LEC_VAT_OPTIMIZED From TRTVENFACC_OPTIMIZED
            If [L]ZWUSINGCACHECLASS = [V]CST_AYES
              If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT<>""
                  If GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATBAS=1
                       PROV_BAS (PROV_J)=sum([M:SIHV]XVNOT)
                  Else
                      # --- Calcul des montants de base si taxe liée à une formule
                      Call ALIBASTAX(2, 0, "SIHV", PROV_TAX(PROV_J), PROV_BAS(PROV_J)) From TRTX3
                  Endif
                  WVATRAT=GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).VATRAT
                  If WTYPREG<>1 & dim(GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).VATEXEFLG)>0 & GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).VATEXEFLG=2 : WVATRAT=0 : Endif
                  # Calcul de la taxe
                  Call RNDTVA(PROV_BAS(PROV_J),WVATRAT,[F:TCU]CURRND,PROV_AMT(PROV_J)) From SUBTVT : # Bug 65067
                  If dim(GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).AMTTSD)>0
                      WAMTTSD = GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).AMTTSD
                      If WAMTTSD<>0
                          If GCURSHR<>[M:SIH2]CUR     : # Issue 74556 - Optimisation
                            Call CONVERT(GCURSHR,[M:SIH2]CUR,GLOCALDEV,[M:SIH0]CHGTYP,
&                                        [M:SIH0]INVDAT,WAMTTSD,WSEUIL,STAT) From TRTDEV
                          Else
                            WSEUIL=WAMTTSD      : # Issue 74556 - Optimisation
                          Endif
                          If PROV_AMT(PROV_J)<WSEUIL  Raz PROV_AMT(PROV_J) : Endif
                      Endif
                  Endif
                  Gosub CHARG_VAT_PROV_OPTIMIZED From TRTVENFACC_OPTIMIZED
              Endif
            Else
              If [F:TVT]VAT<>""
                If [F:TVT]VATBAS=1
                     PROV_BAS (PROV_J)=sum([M:SIHV]XVNOT)
                Else
                    # --- Calcul des montants de base si taxe liée à une formule
                    Call ALIBASTAX(2, 0, "SIHV", PROV_TAX(PROV_J), PROV_BAS(PROV_J)) From TRTX3
                Endif
                WVATRAT=[F:TRA]VATRAT                                                            : # Bug 65067
                If WTYPREG<>1 & dim([F:TRA]VATEXEFLG)>0 & [F:TRA]VATEXEFLG=2 : WVATRAT=0 : Endif : # Bug 65067
                # Calcul de la taxe
                Call RNDTVA(PROV_BAS(PROV_J),WVATRAT,[F:TCU]CURRND,PROV_AMT(PROV_J)) From SUBTVT : # Bug 65067
                If dim([F:TRA]AMTTSD)>0 & [F:TRA]AMTTSD<>0
                    If GCURSHR<>[M:SIH2]CUR     : # Issue 74556 - Optimisation
                      Call CONVERT(GCURSHR,[M:SIH2]CUR,GLOCALDEV,[M:SIH0]CHGTYP,
&                                [M:SIH0]INVDAT,[F:TRA]AMTTSD,WSEUIL,STAT) From TRTDEV
                    Else
                      WSEUIL=[F:TRA]AMTTSD      : # Issue 74556 - Optimisation
                    Endif
                    If PROV_AMT(PROV_J)<WSEUIL  Raz PROV_AMT(PROV_J) : Endif
                Endif
                Gosub CHARG_VAT_PROV
              Endif
            Endif
        Endif
    Endif
Next

$T_ARG_END

PE_COD="END" : GPOINT="TAXVENARG" : Gosub ENTREE From EXEFNC

#Affzo [M:SIHV] : # Bug 66823

Return

$ERR_FORMULE
WTAXBAS = 0
Call ECR_TRACE (mess(253,192,1),1) From GESECRAN
Resume

# --- Constitution d'une nouvelle ligne dans tableau des taxes XV
$CHARG_VAT_PROV
Local Integer WRET :#--CPO 71937 TVT et multi-lèg
PROV_I=find("",[M:SIHV]XVTAX)
If PROV_I & PROV_BAS(PROV_J)<>0
   [M:SIHV]XVTAX(PROV_I-1) = WVAT
   [M:SIHV]XVTYP(PROV_I-1) = [F:TVT]VATTYP
   [M:SIHV]XVTYP(PROV_I-1) = 4                     : # A SUPPRIMER QUAND TOUT SERA OK
   [M:SIHV]XVBAS(PROV_I-1) = [F:TVT]VATBAS
   [M:SIHV]XVCHA(PROV_I-1) = [F:TVT]VATCHA
   If dim(GMIGRATION)<=0        : # Dde 81811 : Optimisation
     #--CPO 71937 TVT et multi-lèg
     Call LEC_TVT_LEG(GCURLEG,[M:SIHV]XVTAX(PROV_I-1),WRET) From TRTLECLEG
     If WRET : Raz [F:TVT] Endif
     Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:SIHV]XVSHO(PROV_I-1)) From TRTX3TEX
   Endif                        : # Dde 81811 : Optimisation
   [M:SIHV]XVRAT(PROV_I-1) = WVATRAT                                                        : # Bug 65067
   [M:SIHV]XVSMI(PROV_I-1) = PROV_BAS(PROV_J)
   [M:SIHV]XVAMT(PROV_I-1) = PROV_AMT(PROV_J) : [M:SIHV]XVATI(PROV_I-1) = PROV_AMT(PROV_J)
   [M:SIHV]NBVAT +=1
Endif
Return
# X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)

