############################################################################
############################################################################
###########################################################################
# 105193
#------------------------------------------------------------------------
# Vérification des élts dont la règle de taxe est "ventilation"
#------------------------------------------------------------------------
# Pour chaque élt dont la règle de taxe est "ventilation"
# --> Vérification qu'il existe un élt éclaté pour chaque code taxe
#------------------------------------------------------------------------
$VERIF_ECLATEMENT
Local Integer WI, WJ, WK, WM
#Dbgaff
# S'il n'y a aucun élt en ventilation inutile de faire la vérification
If find(5,[M:SIHV]VATRUL(0..WNBXFNUM)) = 0 Return Endif
#If sigma(WI=0,WNBXFNUM,[M:SIHV]VATRUL(WI)=5 & [M:SIHV]XFNOT(WI)<>0) Return Endif

For WI=0 To WNBXFNUM
    # Vérification de chaque élt en "ventilation" ayant un montant <> 0
    If [M:SIHV]VATRUL(WI)=5 & [M:SIHV]XFNOT(WI)<>0
        # Vérification qu'il existe au moins un élt éclaté : S'il n'y en a aucun, inutile de poursuivre le contrôle
        WJ=0
        If find([M:SIHV]XFNUM(WI),[M:SIHV]INVFOOBRD(0..WNBXFNUM)) <> 0
            # Au moins un élt éclaté : On poursuit le contrôle
            # Vérification qu'il existe un élt éclaté pour chaque code taxe
            For WJ=0 To dim([M:SIHV]XVTAX)-1
              If TVANOT(WJ)<>0
                # Vérification qu'il existe un élt éclaté portant ce code taxe
                WK=0 : WL=1 : WM=1
                While WL>0
                  # Recherche d'un élt éclaté
                  WL=find([M:SIHV]XFNUM(WI),[M:SIHV]INVFOOBRD(WK..WNBXFNUM))
                  If WL>0
                      # Vérification du code taxe : On l'a trouvé : La recherche est terminée pour ce code taxe
                      WK+=WL
                      If [M:SIHV]XFTAX(WK-1)=TVACOD(WJ) Break Endif
                  Endif
                Wend
                If WL=0 GERR=1 : Break 2 Endif
              Endif
            Next
        Else
            # Aucun un élt éclaté
            GERR=1 : Break
        Endif
    Endif
Next

If GERR=1
      # Problème lors de la valorisation
      # "Ventilation de l'élément : "Intitulé de l'élément" par taxe"
      # "Il manque un élément de facturation pour la taxe"
      GMESSAGE = mess(268,191,1)
      GMESSAGE += "\"
      GMESSAGE += mess(69,191,1)-":"-num$([M:SIHV]XFSHO(WI))
      GMESSAGE += "\"
      If WJ<>0
          GMESSAGE += mess(162,192,1)-":"-num$(TVACOD(WJ))
      Else
      # "Ventilation de l'élément : "Intitulé de l'élément" par taxe"
      # "Il manque les éléments de facturation par taxe"
          GMESSAGE += mess(267,191,1)
      Endif
      If GTRACE=""
          Call ERREUR(GMESSAGE) From GESECRAN
      Else
          # (Cas Migration V5-V6 : Ajouter le n°doc et ne pas afficher la trace en rouge)
          Call ECR_TRACE([M:SIH0]NUM-GMESSAGE,1) From GESECRAN
      Endif
      Raz GMESSAGE : Raz GERR
Endif

Return
# 105193

# 101874 : V9 : Taxe code control
#------------------------------------------------------------------------
# Etiquette de contrôle des taxes
#------------------------------------------------------------------------
# Appelée lors du calcul facture :
# Après chargement des écrans SIH ($CHARG_TABLEAUX de TRTVENFACC) et avant le calcul ($CAL_FACTURE de TRTVENFACC)
# Appelée dans les documents valorisés par VALTTC, le bouton valorisation
# Appelée dans les factures (gestion, bouton, trt autos) lors du calcul facture
# Paramètres complementaires contrôle des taxes
#------------------------------------------------------------------------
# PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
# PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non avec msg/2=Oui avec msg/3=Non sans msg/4=Non sans msg)
# PARAM_T(2) : Flag retour                         (1=KO/2=OK)
#------------------------------------------------------------------------
$CTLVAT

Local Integer WOUVTRACE
Local Char    WNOMTRACE
Local Char    WSAVEGTRACE(255)
Local Integer WSAVEGERRTRACE
Local Integer WOK, WRET

#If GUSER="LD" Infbox ("controle taxe") Endif

WOK=2
WRET = func TRTVENCTL1.CTLVAT(WNOMTRACE,WOUVTRACE)
If WRET>=[V]CST_AERROR | WOUVTRACE>0
    # Il y a des erreurs ou pas d'erreur mais il y a quand même qqch dans la trace (cas utilisation GEXETAX)
    # WOUVTRACE=1 : La fonction de ctrl n'a pas ouvert la trace
    # WOUVTRACE=2 : La fonction de ctrl a ouvert la trace

    # Si ctrl non bloquant, faire apparaitre les erreurs en vert
    # Si ctrl bloquant,     faire apparaitre les erreurs en rouge
    If GCTLTAX=2 WCOLOR=-1 Else WCOLOR=1 Endif

    If find(PARAM_T(1),"1","2")
        If WRET>=[V]CST_AERROR
            # Affichage du msg d'avertissement ou d'erreur
            If GCTLTAX=2
              Call AVERTIR (mess(849,197,1), WOK) From GESECRAN
            Elsif GCTLTAX=3
              WOK=1 : Call ERREUR (mess(849,197,1)) From GESECRAN
            Endif
        Endif
    Elsif find(PARAM_T(1),"3","4")
        If WRET>=[V]CST_AERROR
            # Pas d'affichage du msg d'avertissement ou d'erreur, ecriture dans la trace
            Call ECR_TRACE(mess(849,197,1),WCOLOR) From GESECRAN
            If GCTLTAX=3 WOK=1 Endif
        Endif
    Endif
    If WOK=1 Raz [M:SIHV] Endif

    # Lecture de la trace par le sous-pro de contrôle
    # Sinon la lecture de la trace se fera par le traitement appelant
    If find(PARAM_T(1),"2","4")
        WSAVEGTRACE    = GTRACE
        WSAVEGERRTRACE = GERRTRACE
        GTRACE    = WNOMTRACE
        GERRTRACE = 0
        Call LEC_TRACE From LECFIC
        GTRACE    = WSAVEGTRACE
        GERRTRACE = WSAVEGERRTRACE
        If GTRACE = WNOMTRACE : Raz GTRACE : Endif
    Endif

Endif
PARAM_T(2)=num$(WOK)  : # 1=KO, 2=OK

Return

#------------------------------------------------------------------------
# 101874 : V9 : Taxe code control
#------------------------------------------------------------------------
# Etiquette de contrôle des taxes pour les commandes ouvertes
#------------------------------------------------------------------------
# Contrôle particularisé car les commandes ouvertes ne sont pas valorisées
# Appelée en gestion des lignes articles en VERIF
#------------------------------------------------------------------------
# Paramètres complementaires contrôle des taxes
# PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
# PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non avec msg/2=Oui avec msg/3=Non sans msg/4=Non sans msg)
# PARAM_T(2) : Flag retour                         (1=KO/2=OK)
#------------------------------------------------------------------------
$CTLVATSOI

Local Integer WOUVTRACE
Local Char    WNOMTRACE
Local Char    WSAVEGTRACE(255)
Local Integer WSAVEGERRTRACE
Local Integer WOK, WRET

#If GUSER="LD" Infbox ("controle taxe") Endif

WOK=2
WRET = func TRTVENCTL1.CTLVATSOI(WNOMTRACE,WOUVTRACE)
If WRET>=[V]CST_AERROR | WOUVTRACE>0
    # Il y a des erreurs
    # WOUVTRACE=1 : La fonction de ctrl n'a pas ouvert la trace
    # WOUVTRACE=2 : La fonction de ctrl a ouvert la trace

    # Si ctrl non bloquant, faire apparaitre les erreurs en vert
    # Si ctrl bloquant,     faire apparaitre les erreurs en rouge
    If GCTLTAX=2 WCOLOR=-1 Else WCOLOR=1 Endif

    If find(PARAM_T(1),"1","2")
        # Affichage du msg d'avertissement ou d'erreur
        If GCTLTAX=2
          Call AVERTIR (mess(849,197,1), WOK) From GESECRAN
        Elsif GCTLTAX=3
          WOK=1 : Call ERREUR (mess(849,197,1)) From GESECRAN
        Endif
    Elsif find(PARAM_T(1),"3","4")
        # Pas d'affichage du msg d'avertissement ou d'erreur, ecriture dans la trace
        Call ECR_TRACE(mess(849,197,1),WCOLOR) From GESECRAN
        If GCTLTAX=3 WOK=1 Endif
    Endif

    # Lecture de la trace par le sous-pro de contrôle
    # Sinon la lecture de la trace se fera par le traitement appelant
    If find(PARAM_T(1),"2","4")
        WSAVEGTRACE    = GTRACE
        WSAVEGERRTRACE = GERRTRACE
        GTRACE    = WNOMTRACE
        GERRTRACE = 0
        Call LEC_TRACE From LECFIC
        GTRACE    = WSAVEGTRACE
        GERRTRACE = WSAVEGERRTRACE
        If GTRACE = WNOMTRACE : Raz GTRACE : Endif
    Endif

Endif
PARAM_T(2)=num$(WOK)  : # 1=KO, 2=OK

Return

# 101874

#---- trop codes taxe a stocker dans les tables
$OUT_NBVAT
GMESSAGE=mess(299,192,1)           : # Trop de codes taxe differents
JLNONOK=1

