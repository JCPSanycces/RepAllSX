#<AdxTL>@(#)9.0.0.0 $Revision$
# Gestion du masque PKE1


#########################################################################
#                                                                       #
#     ETIQUETTES DE COLISAGE                                            #
#                                                                       #
#     - Traitement        : FUNPKE                                      #
#     - Action e_commerce : SAIPKE      (Saisie fenêtre)                #
#                           TRTPKE      (Traitement divers)             #
#                                                                       #
#########################################################################
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION

#--- Actions liées à la saisie fenêtre 
Case ACTION
 When "OUVRE"       : Case GACTION
                       When "SAIPKE" , "TRTPKE"  : Gosub OUVRE_TRTPKE
                      Endcase
 When "OUVRE_BOITE" : Case GACTION
                       When "SAIPKE" , "TRTPKE"  : Gosub OUVRE_BOITE_TRTPKE
                      Endcase
 When "DEBUT"       : Case GACTION
                       When "SAIPKE" , "TRTPKE"  : Gosub DEBUT_TRTPKE
                      Endcase 
 When Default
Endcase
#--- Actions liées au traitement divers 
Case ACTION
 When "TRT_DIV"     : Case TRAIT
                       When "IMPPACKLBE" : Gosub IMPRESSION 
                                           FIN=1
                                           If GFONC1="TRTPKE" FIN=0 Endif 
                      Endcase
 When Default
Endcase
Return

#########################################################################
# Détail des actions liées à la saisie fenêtre                          #
#########################################################################

#########################################################################
$OUVRE_TRTPKE
Global Integer  GVCRTYP 
Global Char     GVCRNUM     
Raz GVCRTYP
Raz GVCRNUM

If !clalev ([F:SPH]) Local File SPACK      [SPH] Endif 
If !clalev ([F:SPD]) Local File SPACKD     [SPD] Endif 
If !clalev ([F:SDH]) Local File SDELIVERY  [SDH] Endif 
If !clalev ([F:SDD]) Local File SDELIVERYD [SDD] Endif 
If !clalev ([F:ARP]) Local File AREPORT    [ARP] Endif 
If !clalev ([F:ADW]) Local File ADOVAL     [ADW] Endif 
If !clalev ([F:LBP]) Local File LABELPRN   [LBP] Endif 
If !clalev ([F:PRH]) Local File STOPREH    [PRH] Endif
If !clalev ([F:PRE]) Local File STOPRED    [PRE] Endif


# Définition des critères de sélection des livraisons
#--- depuis le menu colisage
If GACTION = "SAIPKE"
   GVCRTYP = val(PARAM(1))
   GVCRNUM   = PARAM(2)
Endif 

Return

#########################################################################
$OUVRE_BOITE_TRTPKE

Return

#########################################################################
$DEBUT_TRTPKE

Raz [M:PKE1]
If GACTION = "SAIPKE"
   [M:PKE1]VCRTYP = GVCRTYP 
   [M:PKE1]VCRNUM = GVCRNUM
Endif 


# Initialisation de la destination 
If [M:PKE1]LBLNAM<>"" 
    Call AIMDEF([M:PKE1]LBLDEN,[M:PKE1]LBLNAM,GBIDC1,GBIDC2) From IMPRIME 
    If [M:PKE1]LBLDEN<>"" Affzo [M:PKE1]LBLDEN Endif
Endif


nolign=0
If GVCRTYP <> 0 & GVCRNUM  <>""
   For [SPH]SPH0 Where VCRTYP=GVCRTYP & VCRNUM=GVCRNUM
      nolign+=1
      [M:PKE1]                      = [F:SPH]
      [M:PKE1]LBLNBR(nolign-1)      = 1
      If [M:PKE1]LBLFMT(nolign-1)   = "" 
         [M:PKE1]LBLFMT(nolign-1)   = [M:PKE1]LBLNAM 
         [M:PKE1]DEFDEN(nolign-1)   = [M:PKE1]LBLDEN
      Elsif [M:PKE1]LBLFMT(nolign-1)= [M:PKE1]LBLNAM 
         [M:PKE1]DEFDEN(nolign-1)   = [M:PKE1]LBLDEN
      Else
      # Initialisation de la destination 
         Call AIMDEF([M:PKE1]DEFDEN(nolign-1),[M:PKE1]LBLFMT(nolign-1),GBIDC1,GBIDC2) From IMPRIME 
      Endif
   Next
   [M:PKE1]NBLIG=nolign
Endif
Affzo [M:PKE1]
# Pas de saisie no document si accès depuis colisage (on traite une seule livraison)
If GACTION = "SAIPKE"
   Diszo [M:PKE1]VCRTYP
   Diszo [M:PKE1]VCRNUM
Else
   Actzo [M:PKE1]VCRTYP
   Actzo [M:PKE1]VCRNUM
Endif

Return

#######################################################################
# Bouton impression des étiquettes de colis                           #
#######################################################################
$IMPRESSION
Local Char    WMSG(80), WDEFDEN(GLONAIM), WLBLFMT
Local Integer I, J, K, WNUMREQ, WNB, WNUMLIG
Global Integer GWNUMREQ     : # pour passage du no de requete 

# TRI du tableau selon imprimante,format,no colis 
Sorta [M:PKE1]NBLIG [M:PKE1]NBLIG 
&     Order By [M:PKE1]DEFDEN(indice),[M:PKE1]LBLFMT(indice),[M:PKE1]PACNUM(indice)
Raz WDEFDEN, WLBLFMT, WNB, WNUMLIG 
For I=0 To [M:PKE1]NBLIG-1
    If [M:PKE1]LBLNBR(I)<>0 & [M:PKE1]LBLFMT(I)<>"" & [M:PKE1]DEFDEN(I)<>"" 
       If [M:PKE1]DEFDEN(I)<>WDEFDEN | [M:PKE1]LBLFMT(I)<>WLBLFMT
          If WDEFDEN<>"" & WNB>0
             Local Char TBPAR(15)(1..50),TBVAL(30)(1..50) 
             [M:PKE1]LBLDEN=WDEFDEN
             Call ETAT(WLBLFMT,WDEFDEN,"",1,"",TBPAR,TBVAL) From AIMP3
          Endif
          WDEFDEN=[M:PKE1]DEFDEN(I)
          WLBLFMT=[M:PKE1]LBLFMT(I)
          GWNUMREQ=uniqid([LBP])
          Raz WNB, WNUMLIG 
       Endif
       Gosub REMPL_LBP
    Endif
Next I

If WNB>0
   Local Char TBPAR(15)(1..50),TBVAL(30)(1..50) 
   [M:PKE1]LBLDEN=WDEFDEN
   Call ETAT(WLBLFMT,WDEFDEN,"",1,"",TBPAR,TBVAL) From AIMP3
Endif

Return

############################################################################
$REMPL_LBP
#On arrive ici pour chaque ligne du tableau
Call DEBTRANS From GLOCK 
Trbegin [LBP]
Raz [F:LBP]
[F:LBP]USR       = GUSER
[F:LBP]NUMREQ    = GWNUMREQ
[F:LBP]CREDAT    = date$
[F:LBP]CREUSR    = GUSER
[F:LBP]RPTCOD    = [M:PKE1]LBLFMT(I)
[F:LBP]STOFCY    = [M:PKE1]STOFCY
[F:LBP]VCRTYP    = [M:PKE1]VCRTYP
[F:LBP]VCRNUM    = [M:PKE1]VCRNUM
[F:LBP]PCKSTKFLG = [M:PKE1]PCKSTKFLG
[F:LBP]PACNUM    = [M:PKE1]PACNUM(I)
[F:LBP]PACSEQ    = [M:PKE1]PACSEQ(I)
For J=1 To [M:PKE1]LBLNBR(I)
    [F:LBP]NUMLIG = J + WNUMLIG
    Write [F:LBP]
    If fstat : GOK = 0 : Break : Endif
Next J
If GOK = 0
   Rollback 
Else
   Commit
   WNB    += 1 
   WNUMLIG = [F:LBP]NUMLIG 
Endif
Return

###########################################################################
#   Actions sur les champs de l'écran PKE1[PKE1]                    #
###########################################################################
Subprog AM_VCRNUM(VALEUR)
Variable Char    VALEUR()
nolign=0
If VALEUR = "" End Endif
For [SPH]SPH0 Where VCRTYP=[M:PKE1]VCRTYP & VCRNUM=VALEUR
    nolign+=1
    [M:PKE1]                 = [F:SPH]
    [M:PKE1]LBLNBR(nolign-1) = 1
   # Vérification du format de l'étiquette récupéré de l'emballage
    Call ARPCONT([M:PKE1]LBLFMT(nolign-1)) From IMPRIME
    If mkstat=2
       Raz [M:PKE1]LBLFMT(nolign-1) 
       mkstat=0 
       Raz GMESSAGE 
    Endif
    If [M:PKE1]LBLFMT    (nolign-1)    = "" 
       [M:PKE1]LBLFMT    (nolign-1)    = [M:PKE1]LBLNAM 
       [M:PKE1]DEFDEN    (nolign-1)    = [M:PKE1]LBLDEN
    Elsif [M:PKE1]LBLFMT (nolign-1)    = [M:PKE1]LBLNAM 
       [M:PKE1]DEFDEN    (nolign-1)    = [M:PKE1]LBLDEN
    Else
       # Initialisation de la destination 
       Call AIMDEF([M:PKE1]DEFDEN(nolign-1),[M:PKE1]LBLFMT(nolign-1),GBIDC1,GBIDC2) From IMPRIME 
       If [M:PKE1]DEFDEN(nolign-1)<>"" Affzo [M:PKE1]DEFDEN(nolign-1) Endif
    Endif
Next
[M:PKE1]NBLIG=nolign
Affzo [M:PKE1]
End
# ----------------------------- LBLNAM Format étiquette ---------------------------------
Subprog AM_LBLNAM(VALEUR)
Variable Char    VALEUR()
Local Char TBPAR(15)(1..50),TBVAL(30)(1..50) 
Local Integer OK, WOBLIG
If VALEUR <> ""
   # Vérification du format de l'étiquette récupéré de l'emballage
    Call ARPCONT(VALEUR) From IMPRIME
Endif
# Recherche de l'imprimante par défaut
Call AIMDEF([M]LBLDEN,VALEUR,TBPAR,TBVAL) From IMPRIME
Affzo [M]LBLDEN 
# Demande de répercution sur les lignes détails
Call OUINON (mess(67,196,1),OK) From GESECRAN
If OK=2
    For I=0 To [M]NBLIG-1
        [M:PKE1]LBLFMT(I) = VALEUR   
        [M:PKE1]DEFDEN(I) = [M]LBLDEN
    Next
    Affzo [M:PKE1]10
Endif
End
##########################################################################
# ----------------------------- LBLDEN Destination ---------------------------------
Subprog C_LBLDEN(VALEUR)
Variable Char    VALEUR()
# Imprimante obligatoire si impression 
If [M]LBLNAM <> "" & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
Endif
End

##########################################################################
Subprog AP_LBLDEN(VALEUR)
Variable Char    VALEUR()
Call INIT_SRV(VALEUR, [M]LBLSRV,[M]LBLIMP) From TRTVENIMP
Affzo [M]LBLSRV, LBLIMP
End

##########################################################################
Subprog AM_LBLDEN(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If VALEUR <> ""
   # Vérification du format de l'étiquette récupéré de l'emballage
    Call AIMCONT(VALEUR,[M]LBLNAM,0) From IMPRIME
# Demande de répercution sur les lignes détails
    Call OUINON (mess(67,196,1),OK) From GESECRAN
    If OK=2
       For I=0 To [M]NBLIG-1
           [M:PKE1]LBLFMT(I) = [M]LBLNAM  
           [M:PKE1]DEFDEN(I) = VALEUR
       Next
       Affzo [M:PKE1]10
    Endif
Endif
End
# ----------------------------- LBLFMT Format étiquette tableau ---------------------------------
Subprog C_LBLFMT(VALEUR)
Variable Char    VALEUR()
Local    Char AUTSIT(10)
Local    Integer OK
# Format étiquette obligatoire si impression nb étiquettes > 0
If [M:PKE1]LBLNBR(nolign-1) <> 0 & VALEUR = ""
   mkstat = 2
   End
Endif
End
Subprog AM_LBLFMT(VALEUR)
Variable Char    VALEUR()
Local Char TBPAR(15)(1..50),TBVAL(30)(1..50)
# Recherche de l'imprimante par défaut
Call AIMDEF([M]DEFDEN(nolign-1),VALEUR,TBPAR,TBVAL) From IMPRIME
Affzo [M]DEFDEN(nolign-1)
End


Subprog C_DEFDEN(VALEUR)
Variable Char    VALEUR()
# Imprimante obligatoire si impression 
If [M]LBLFMT(nolign-1) <> "" & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
Endif
End


Subprog AS_VCRTYP(VALEUR)
Variable Integer VALEUR

Local Integer I
For I=1 To len(mess(0,701,1))
    If !find(I,3,4)
        GMENLOC(I) = 1
    Endif
Next

End

Subprog AP_VCRTYP(VALEUR)
Variable Integer VALEUR

[M:PKE1]VCRTYP = VALEUR

If VALEUR = 4 
   [M:PKE1]OBJET   = "SDH"          # livraison
Else
   [M:PKE1]OBJET   = "PRH"          # preparation
Endif

End



