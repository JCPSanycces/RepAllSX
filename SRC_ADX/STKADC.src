#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################
# Traitement STKADC - Librairie de composants stock pour l'ADC         #
########################################################################
# Sous-programmes
#-----------------------------------------------------------------------
# RECSTO        Recherche des lignes de stock correspondantes aux
#               caractéristiques stocks saisie
#
# CHGSOW_SMO    Sorties diverses :
#               Traitement des lignes de stock sélectionnées pour
#               alimentation STOSORW
#
# CHGSOW_MBM    Consommation matières :
#               Traitement des lignes de stock sélectionnées pour
#               alimentation STOSORW
#
# CHGSTOCHGW    Changement stock, transfert inter-sites et sous-traitants :
#               Traitement des lignes de stock sélectionnées pour
#               alimentation STOCHGW
#
# ALIM_PRNETI   Alimentation état et destination pour impression étiquettes
#
# ALIM_PRNDOC   Alimentation destination pour impression documents
#
# PRINT_ETI     Impression des étiquettes
#
########################################################################

########################################################################
# RECSTO        Recherche des lignes de stock correspondantes aux
#               caractéristiques stocks saisie et stockage dans STOCOUW
#-----------------------------------------------------------------------
# Paramètres E : LORI    = Fonction origine
#                          0 : Pour recherche article (en sortie matière)
#                          1 : Sortie diverse
#                          2 : Changement de stock
#                          3 : Transfert Inter-Site
#                          4 : Transfert pour Sous-Traitance
#                          5 : Sorties matières
#                LTRSCOD = Code mouvement
#                LTYP    = Type de données
#                          1 : Article Lot Sous-Lot
#                          2 : Article Lot
#                          3 : Lot Sous-Lot
#                          4 : Lot
#                          5 : Article Série
#                          6 : Série
#                          7 : Article Emplacement
#                          8 : Emplacement
#                          9 : Article Identifiant1
#                         10 : Identifiant1
#                LFCY    = Site
#                LDES    = Site destination (si transfert inter-sites)
#                LITM    = Article
#                LLOT    = Lot
#                LSLO    = Sous-Lot
#                LSER    = No série
#                LLOC    = Emplacement
#                LPAL    = Identifiant 1
#
# Paramètres S : LITM    = Article     ou
#                          "*****"     si plusieurs articles
#                LLOT    = Lot         ou
#                          "*****"     si plusieurs lots
#                          ""          si article(s) sans gestion de lot
#                LSLO    = Sous-Lot    ou
#                          "*****"     si plusieurs sous-lots
#                          ""          si article(s) sans gestion de sous-lot
#                LSER    = Série       ou
#                          "*****"     si plusieurs séries
#                          ""          si article(s) sans gestion de série en entrée
#                LLOC    = Emplacement ou
#                          "*****"     si plusieurs emplacements
#                          ""          si article(s) sans gestion d'emplacement
#                LSTA    = Statut      ou
#                          "***"       si plusieurs statuts
#                LPCU    = Unité conditionnement ou
#                          "***"       si plusieurs UC
#                LPCUSTUCOE = Coef PCU/STU
#                issue 110327 : numéro de série fin
#                LSERF   = Numéro de série fin si SERMGTCOD=4
#                LQTY    = Quantité à traiter
#                LQTA    = Quantité allouée (si LORI=5)
#
# Prérequis    : Ces tables doivent être ouvertes  STOCK     [STO]
#                                                  TABSTORUL [SRU]
#
#                Ces écrans doivent être ouverts   STOCOUW   [STCW]
#
#                Si LORI=5 l'enregistrement [F:MFM] (ligne OF matière)
#                          doit être en ligne
#
########################################################################
#--- Issue 103217
#Subprog RECSTO (LORI,LTRSCOD,LTYP,LFCY,LDES,LITM,LLOT,LSLO,LSER,LLOC,LPAL,LSTA,LQTY,LQTA)
# Issue 110327
#Subprog RECSTO (LORI,LTRSCOD,LTYP,LFCY,LDES,LITM,LLOT,LSLO,LSER,LLOC,LPAL,LSTA,LPCU,LPCUSTUCOE,LQTY,LQTA)
Subprog RECSTO (LORI,LTRSCOD,LTYP,LFCY,LDES,LITM,LLOT,LSLO,LSER,LSERF,LLOC,LPAL,LSTA,LPCU,LPCUSTUCOE,LQTY,LQTA)
#---
Value    Integer LORI
Value    Char    LTRSCOD
Value    Integer LTYP
Value    Char    LFCY
Value    Char    LDES
Variable Char    LITM
Variable Char    LLOT
Variable Char    LSLO
Variable Char    LSER
Variable Char    LSERF         : # Issue 110327
Variable Char    LLOC
Value    Char    LPAL
Variable Char    LSTA
Variable Char    LPCU          : #--- Issue 103217
Variable Decimal LPCUSTUCOE    : #--- Issue 103217
Variable Decimal LQTY
Variable Decimal LQTA

Local   Integer  I, LRET
Local   Shortint LRETS
Local   Decimal  WPCUDIS, WSTUDIS, WSTUACTDIS
Local   Decimal  WALLQTY, WALLQTA
Local   Char     WFIL1(80)
Local   Char     WITM(GLONITM), WITMNO(GLONITM), WITMUNI(GLONITM)
Local   Char     WLOT(GLONLOT), WLOTUNI(GLONLOT)
Local   Char     WSLO(GLONSLO), WSLOUNI(GLONSLO)
Local   Char     WSER(GLONSER), WSERUNI(GLONSER)
Local   Char     WLOC(GLONLOC), WLOCUNI(GLONLOC)
Local   Char     WSTA(GLONSTA), WSTAUNI(GLONSTA)
#--- Issue 103217
Local   Char     WPCUUNI(GLONUOM)
# Issue 110327
Local Decimal WRET,WSTOCOU

If LORI=5
   If !clalev([F:STA]) Local File STOALL [STA] Endif
Endif

Raz [M:STCW]

Case LTYP
 When 1,2,7   : WFIL1="ITMREF=LITM & STOFCY=LFCY"
                If LTYP=1
                   WFIL1+="& LOT=LLOT & SLO=LSLO"
                Elsif LTYP=2
                   WFIL1+="& LOT=LLOT"
                Else
                   WFIL1+="& LOC=LLOC"
                Endif
                Filter [STO] Where evalue(WFIL1) Order By Key STO3
 When 3,4     : If LTYP=3
                   WFIL1="LOT=LLOT & SLO=LSLO"
                Else
                   WFIL1="LOT=LLOT"
                Endif
                WFIL1+="& STOFCY=LFCY"
                Filter [STO] Where evalue(WFIL1) Order By Key STONEW1=LOT;SLO;STOFCY
 When 5       :
                If [F:ITM]SERMGTCOD <> 4      # Issue 110327
                  WFIL1="ITMREF=LITM & SERNUM=LSER & STOFCY=LFCY"
                  Filter [STO] Where evalue(WFIL1) Order By Key STO5
                # Issue 110327 - 2017-03-07 by MAE
                Else
                  If LSERF <> ""
                    WFIL1="ITMREF=LITM & (SERNUM>=LSER & SERNUM <=LSERF) & STOFCY=LFCY"
                  Else
                    WFIL1="ITMREF=LITM & SERNUM=LSER & STOFCY=LFCY"
                  Endif
                  Filter [STS] Where evalue(WFIL1) Order By Key STONEW2=SERNUM;STOFCY
                Endif
                # End issue 110327
 When 6       :
                If [F:ITM]SERMGTCOD <> 4    # Issue 110327
                  WFIL1="SERNUM=LSER & STOFCY=LFCY"
                  Filter [STO] Where evalue(WFIL1) Order By Key STONEW2=SERNUM;STOFCY
                # Issue 110327 - 2017-03-07 by MAE
                Else
                  If LSERF <> ""
                    WFIL1="(SERNUM>=LSER & SERNUM<=LSERF) & STOFCY=LFCY"
                  Else
                    WFIL1="SERNUM>=LSER  & STOFCY=LFCY"
                  Endif
                  Filter [STS] Where evalue(WFIL1) Order By Key STONEW2=SERNUM;STOFCY
                Endif
                # End issue 110327
 When 8       : WFIL1="STOFCY=LFCY & LOC=LLOC & LOC<>''"
                Filter [STO] Where evalue(WFIL1) Order By Key STO4
 When 9,10    : WFIL1="STOFCY=LFCY & PALNUM=LPAL & PALNUM<>''"
                If LTYP=9
                   WFIL1+="& ITMREF=LITM"
                Endif
                Filter [STO] Where evalue(WFIL1) Order By Key STO1
 When Default : End
Endcase

WITM="" : WITMUNI="" : WITMNO=""
WLOT="" : WLOTUNI=""
WSLO="" : WSLOUNI=""
WSER="" : WSERUNI=""
WLOC="" : WLOCUNI=""
WSTA="" : WSTAUNI=""
#--- Issue 103217
WPCUUNI=""
LPCUSTUCOE=0
#---
# Issue 110327 - 2016-10-14 by MAE
If [F:ITM]SERMGTCOD = 4 & (LTYP=5 | LTYP = 6)
  For [STS]
    If WSTOCOU <> [F:STS]STOCOU
      #lecture de la table STOCK
      Read [STO]STO0=LFCY;[F:STS]STOCOU
      If fstat  Break : Endif
      WSTOCOU = [F:STS]STOCOU
      Gosub CTR_STOCK
      If WRET = 1
        Break
      Elsif WRET = 2
        Goto LOOP_STS
      Endif
    Endif

$LOOP_STS
Next

Filter [STS]
Endif

If ([F:ITM]SERMGTCOD <> 4) | (LTYP<>5 & LTYP <> 6)
  I=0
  For [STO]
#   If [F:STO]ITMREF=WITMNO Goto LOOP_STO Endif
#   WITMNO=""
#   # Si rupture article
#   If [F:STO]ITMREF<>WITM
#      Call LECITM2([F:STO]STOFCY,[F:STO]ITMREF,"",LRET) From STKLIB
#      # Si erreur ou article non utilisable ou en inventaire
#      If LRET<>0 | [F:ITM]ITMSTA=6 | [F:ITF]CUNFLG = 2
#         WITMNO=[F:STO]ITMREF
#         Goto LOOP_STO
#      Endif
#      # Si transfert inter-site, l'article doit exister sur le site destination
#      If LORI=3 & LDES<>""
#         Read [ITF]ITF0=[F:STO]ITMREF;LDES
#         If fstat | [F:ITF]STOMGTCOD=1
#            WITMNO=[F:STO]ITMREF
#            Goto LOOP_STO
#         Endif
#      Endif
#
#      Raz LRET
#      Raz [F:SRU]
#      # Règles de gestion :  2 = sortie diverse
#      #                     27 = sortie transfert interne
#      #                      6 = sortie matière
#      Case LORI
#       When 1   : Call LECSRU([F:STO]STOFCY,[F:ITM]TCLCOD,2, LTRSCOD,"",LRET) From STKLIB
#       When 3,4 : Call LECSRU([F:STO]STOFCY,[F:ITM]TCLCOD,27,LTRSCOD,"",LRET) From STKLIB
#       When 5   : Call LECSRU([F:STO]STOFCY,[F:ITM]TCLCOD,6 ,LTRSCOD,"",LRET) From STKLIB
#      Endcase
#      If LRET<>0
#         WITMNO=[F:STO]ITMREF
#         Goto LOOP_STO
#      Endif
#
#      # Article unique ?
#      WITM=[F:STO]ITMREF
#      If WITMUNI=""
#         WITMUNI=WITM
#      Elsif WITMUNI<>WITM
#         WITMUNI="*****"
#      Endif
#   Endif
#
#   # Si uniquement recherche article, on s'arrête ou on passe à la ligne suivante
#   If LORI=0
#      If WITMUNI="*****"
#         Break
#      Else
#         Goto LOOP_STO
#      Endif
#   Endif
#
#   # Si emplacement en attente de rangement
#   If [F:STO]LOCCAT=2
#      # Contrôle que la ligne de stock en attente de rangement est complète
#      Call CTLPLFLOC([F:STO]ITMREF,"",LRET) From STKSOR
#      If LRET<>0 Goto LOOP_STO Endif
#      # Si changement de stock, transfert inter-site ou sous-traitant
#      If LORI>1
#         # La ligne de stock est elle dans une liste à ranger ?
#         Filter [SGW] Where STOCOU=[F:STO]STOCOU
#         Read [SGW]First
#         Filter [SGW]
#         If !fstat  Goto LOOP_STO Endif
#      Endif
#   Endif
#
#   Raz [L]WALLQTA, [L]WALLQTY
#   If LORI<>2
#      # Ligne de stock avec demande d'analyse
#      If [F:STO]QLYCTLDEM<>"" Goto LOOP_STO Endif
#      # Contrôle si statut autorisé
#      Call STKCTRSTA([F:STO]STA,[F:SRU]AUZSST,0,0,0,LRETS) From STKACT
#      Raz GMESSAGE
#      If LRETS=2 Goto LOOP_STO Endif
#      # Si gestion de lot et lot périmé interdit, contrôle lot
#      If [F:ITM]LOTMGTCOD>1 & [F:SRU]SHLLOT<>3                             # hcb v6dlu
#         Call STKCTRLOTS([F:STO]LOT,[F:STO]ITMREF,date$,"",LFCY) From STKACT
#         Raz GMESSAGE
#         If mkstat=2 Goto LOOP_STO Endif
#      Endif
#
#      # Si sortie matière, recherche de la quantité allouée
#      If LORI=5
#         If [F:STO]CUMALLQTA<>0 & [F:MFM]MFGNUM<>"" & [F:MFM]MFGLIN<>0
#            Read [STA]STA1=10;[F:MFM]MFGNUM;[F:MFM]MFGLIN;[F:MFM]BOMSEQ;[F:STO]STOCOU
#            If !fstat
#               [L]WALLQTA += [F:STA]QTYSTUACT
#               [L]WALLQTY += [F:STA]QTYSTU
#            Endif
#         Endif
#      Endif
#
#      # Contrôle du disponible pour sortie sur la ligne de stock
#      Call STODISSOR("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
#
#      # Si sortie matière, rajout de la quantité allouée au disponible
#      If LORI=5
#         [L]WSTUACTDIS += [L]WALLQTA
#         [L]WSTUDIS    += [L]WALLQTY
#      Endif
#   Else
#      [L]WSTUDIS    = [F:STO]QTYSTU   -[F:STO]CUMWIPQTY
#      [L]WSTUACTDIS = [F:STO]QTYSTUACT-[F:STO]CUMWIPQTA
#   Endif
#
#   # Pas de stock disponible
#   If [L]WSTUDIS<=0 Goto LOOP_STO Endif
#
#   # Lot et sous-lot uniques ?
#   If [F:ITM]LOTMGTCOD>1 & [F:STO]LOT<>WLOT
#      WLOT=[F:STO]LOT
#      If WLOTUNI=""
#         WLOTUNI=WLOT
#      Elsif WLOTUNI<>WLOT
#         WLOTUNI="*****"
#      Endif
#   Endif
#   If [F:ITM]LOTMGTCOD=4 & WLOTUNI<>"*****" & [F:STO]SLO<>WSLO
#      WSLO=[F:STO]SLO
#      If WSLOUNI=""
#         WSLOUNI=WSLO
#      Elsif WSLOUNI<>WSLO
#         WSLOUNI="*****"
#      Endif
#   Endif
#
#   # Série unique ?
#   If [F:ITM]SERMGTCOD=3 & [F:STO]SERNUM<>WSER
#      WSER=[F:STO]SERNUM
#      If WSERUNI=""
#         WSERUNI=WSER
#      Elsif WSERUNI<>WSER
#         WSERUNI="*****"
#      Endif
#   Endif
#
#   # Emplacement unique ?
#   If [F:ITF]LOCMGTCOD=2 & [F:STO]LOC<>WLOC
#      WLOC=[F:STO]LOC
#      If WLOCUNI=""
#         WLOCUNI=WLOC
#      Elsif WLOCUNI<>WLOC
#         WLOCUNI="*****"
#      Endif
#   Endif
#
#   # Statut unique ?
#   If [F:STO]STA<>WSTA
#      WSTA=[F:STO]STA
#      If WSTAUNI=""
#         WSTAUNI=WSTA
#      Elsif WSTAUNI<>WSTA
#         WSTAUNI="***"
#      Endif
#   Endif
#
#   #--- Issue 103217
#   # PCU unique ?
#   If WPCUUNI=""
#      WPCUUNI   =[F:STO]PCU
#      LPCUSTUCOE=[F:STO]PCUSTUCOE
#   Elsif WPCUUNI<>"***" & ([F:STO]PCU<>WPCUUNI | ([F:STO]PCU=WPCUUNI & [F:STO]PCUSTUCOE<>LPCUSTUCOE))
#      WPCUUNI="***"
#   Endif
#   #---
#
#   # Chargement de la ligne dans [M:STCW]
#   [M:STCW]WITM(I)       = [F:STO]ITMREF
#   [M:STCW]WSTOCOU(I)    = [F:STO]STOCOU
#   [M:STCW]WQTYSTU(I)    = [L]WSTUDIS
#   [M:STCW]WQTYSTUACT(I) = [L]WSTUACTDIS
#   [M:STCW]WALLSTU(I)    = [L]WALLQTY
#   [M:STCW]WALLSTUACT(I) = [L]WALLQTA
#   LQTY += [L]WSTUDIS
#   LQTA += [L]WALLQTY
#
#   I+=1
#   If I>dim([M:STCW]WSTOCOU)-1 Break Endif
  Gosub CTR_STOCK
  If WRET = 1
    Break
  Elsif WRET = 2
      Goto LOOP_STO
  Endif
# End issue 110327

  $LOOP_STO
  Next
Filter [STO]
Endif

# Si uniquement recherche article
If LORI=0
   LITM=WITMUNI : End
Endif

[M:STCW]NBLIG = I

# Si sortie matière, tri pour privilégier la quantité allouée
If LORI=5
   Sorta [M:STCW]NBLIG [M:STCW]NBLIG Order By [M:STCW]WALLSTUACT(indice) Desc
# Si possibilité d'articles multiples, tri pour regrouper les articles
Elsif find(LTYP,3,4,8,10)
   Sorta [M:STCW]NBLIG [M:STCW]NBLIG Order By [M:STCW]WITM(indice)
Endif
# Article(s) à traiter
LITM=WITMUNI
# Lot(s) et sous-lot(s) à traiter
LLOT=WLOTUNI
LSLO=WSLOUNI
# Série(s) à traiter
LSER=WSERUNI
# Emplacement(s) à traiter
LLOC=WLOCUNI
# Statut(s) à traiter
LSTA=WSTAUNI
#--- Issue 103217
LPCU=WPCUUNI

mkstat=0
End

# Issue 110327 - 2016-10-14 by MAE : controle  d'une ligne de stock
$CTR_STOCK
WRET = 0
# si WRET = 1, on passe à la ligne suivante
# si WRET = 2, on sort de la boucle
   If [F:STO]ITMREF=WITMNO
    # Issue 110327
    WRET = 1
    Return
    #Goto LOOP_STO
   Endif
   WITMNO=""
   # Si rupture article
   If [F:STO]ITMREF<>WITM
      Call LECITM2([F:STO]STOFCY,[F:STO]ITMREF,"",LRET) From STKLIB
      # Si erreur ou article non utilisable ou en inventaire
      If LRET<>0 | [F:ITM]ITMSTA=6 | [F:ITF]CUNFLG = 2
         WITMNO=[F:STO]ITMREF
         # Issue 110327
         WRET = 1
         Return
         #Goto LOOP_STO
      Endif
      # Si transfert inter-site, l'article doit exister sur le site destination
      If LORI=3 & LDES<>""
         Read [ITF]ITF0=[F:STO]ITMREF;LDES
         If fstat | [F:ITF]STOMGTCOD=1
            WITMNO=[F:STO]ITMREF
            # Issue 110327
            WRET = 1: Return
            #Goto LOOP_STO
         Endif
      Endif

      Raz LRET
      Raz [F:SRU]
      # Règles de gestion :  2 = sortie diverse
      #                     27 = sortie transfert interne
      #                      6 = sortie matière
      Case LORI
       When 1   : Call LECSRU([F:STO]STOFCY,[F:ITM]TCLCOD,2, LTRSCOD,"",LRET) From STKLIB
       When 3,4 : Call LECSRU([F:STO]STOFCY,[F:ITM]TCLCOD,27,LTRSCOD,"",LRET) From STKLIB
       When 5   : Call LECSRU([F:STO]STOFCY,[F:ITM]TCLCOD,6 ,LTRSCOD,"",LRET) From STKLIB
      Endcase
      If LRET<>0
         WITMNO=[F:STO]ITMREF
         # Issue 110327
         WRET = 1: Return
         #Goto LOOP_STO
      Endif

      # Article unique ?
      WITM=[F:STO]ITMREF
      If WITMUNI=""
         WITMUNI=WITM
      Elsif WITMUNI<>WITM
         WITMUNI="*****"
      Endif
   Endif

   # Si uniquement recherche article, on s'arrête ou on passe à la ligne suivante
   If LORI=0
      If WITMUNI="*****"
         # Issue 110327
         WRET = 2: Return
         #Break
      Else
         # Issue 110327
         WRET = 1: Return
         #Goto LOOP_STO
      Endif
   Endif

   # Si emplacement en attente de rangement
   If [F:STO]LOCCAT=2
      # Contrôle que la ligne de stock en attente de rangement est complète
      Call CTLPLFLOC([F:STO]ITMREF,"",LRET) From STKSOR
      If LRET<>0
        # Issue 110327
        WRET = 2 : Return
        #Goto LOOP_STO
      Endif
      # Si changement de stock, transfert inter-site ou sous-traitant
      If LORI>1
         # La ligne de stock est elle dans une liste à ranger ?
         Filter [SGW] Where STOCOU=[F:STO]STOCOU
         Read [SGW]First
         Filter [SGW]
         If !fstat
          # Issue 110327
          WRET = 2 : Return
          #Goto LOOP_STO
         Endif
      Endif
   Endif

   Raz [L]WALLQTA, [L]WALLQTY
   If LORI<>2
      # Ligne de stock avec demande d'analyse
      If [F:STO]QLYCTLDEM<>"" Goto LOOP_STO Endif
      # Contrôle si statut autorisé
      Call STKCTRSTA([F:STO]STA,[F:SRU]AUZSST,0,0,0,LRETS) From STKACT
      Raz GMESSAGE
      If LRETS=2
        # Issue 110327
        WRET = 2 : Return
        #Goto LOOP_STO
      Endif
      # Si gestion de lot et lot périmé interdit, contrôle lot
      If [F:ITM]LOTMGTCOD>1 & [F:SRU]SHLLOT<>3                             # hcb v6dlu
         Call STKCTRLOTS([F:STO]LOT,[F:STO]ITMREF,date$,"",LFCY) From STKACT
         Raz GMESSAGE
         If mkstat=2
          # Issue 110327
          WRET = 2 : Return
          #Goto LOOP_STO
         Endif
      Endif

      # Si sortie matière, recherche de la quantité allouée
      If LORI=5
         If [F:STO]CUMALLQTA<>0 & [F:MFM]MFGNUM<>"" & [F:MFM]MFGLIN<>0
            Read [STA]STA1=10;[F:MFM]MFGNUM;[F:MFM]MFGLIN;[F:MFM]BOMSEQ;[F:STO]STOCOU
            If !fstat
               [L]WALLQTA += [F:STA]QTYSTUACT
               [L]WALLQTY += [F:STA]QTYSTU
            Endif
         Endif
      Endif

      # Contrôle du disponible pour sortie sur la ligne de stock
      Call STODISSOR("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB

      # Si sortie matière, rajout de la quantité allouée au disponible
      If LORI=5
         [L]WSTUACTDIS += [L]WALLQTA
         [L]WSTUDIS    += [L]WALLQTY
      Endif
   Else
      [L]WSTUDIS    = [F:STO]QTYSTU   -[F:STO]CUMWIPQTY
      [L]WSTUACTDIS = [F:STO]QTYSTUACT-[F:STO]CUMWIPQTA
   Endif

   # Pas de stock disponible
   If [L]WSTUDIS<=0
    # Issue 110327
    WRET = 2 : Return
    #Goto LOOP_STO
   Endif

   # Lot et sous-lot uniques ?
   If [F:ITM]LOTMGTCOD>1 & [F:STO]LOT<>WLOT
      WLOT=[F:STO]LOT
      If WLOTUNI=""
         WLOTUNI=WLOT
      Elsif WLOTUNI<>WLOT
         WLOTUNI="*****"
      Endif
   Endif
   If [F:ITM]LOTMGTCOD=4 & WLOTUNI<>"*****" & [F:STO]SLO<>WSLO
      WSLO=[F:STO]SLO
      If WSLOUNI=""
         WSLOUNI=WSLO
      Elsif WSLOUNI<>WSLO
         WSLOUNI="*****"
      Endif
   Endif

   # Série unique ?
   If [F:ITM]SERMGTCOD=3 & [F:STO]SERNUM<>WSER
      WSER=[F:STO]SERNUM
      If WSERUNI=""
         WSERUNI=WSER
      Elsif WSERUNI<>WSER
         WSERUNI="*****"
      Endif
   Endif

   # Emplacement unique ?
   If [F:ITF]LOCMGTCOD=2 & [F:STO]LOC<>WLOC
      WLOC=[F:STO]LOC
      If WLOCUNI=""
         WLOCUNI=WLOC
      Elsif WLOCUNI<>WLOC
         WLOCUNI="*****"
      Endif
   Endif

   # Statut unique ?
   If [F:STO]STA<>WSTA
      WSTA=[F:STO]STA
      If WSTAUNI=""
         WSTAUNI=WSTA
      Elsif WSTAUNI<>WSTA
         WSTAUNI="***"
      Endif
   Endif

   #--- Issue 103217
   # PCU unique ?
   If WPCUUNI=""
      WPCUUNI   =[F:STO]PCU
      LPCUSTUCOE=[F:STO]PCUSTUCOE
   Elsif WPCUUNI<>"***" & ([F:STO]PCU<>WPCUUNI | ([F:STO]PCU=WPCUUNI & [F:STO]PCUSTUCOE<>LPCUSTUCOE))
      WPCUUNI="***"
   Endif
   #---
   # X3-61630 JOBRO
   # Entry point to allow the Stock to be skipped
   Raz GPE
   GPOINT="LOAD_STOCK" : Gosub ENTREE From EXEFNC
   If GPE<>0
     Raz GPE
     WRET=2
     Return
   Endif
   # X3-61630
   # Chargement de la ligne dans [M:STCW]
   [M:STCW]WITM(I)       = [F:STO]ITMREF
   [M:STCW]WSTOCOU(I)    = [F:STO]STOCOU
   [M:STCW]WQTYSTU(I)    = [L]WSTUDIS
   [M:STCW]WQTYSTUACT(I) = [L]WSTUACTDIS
   [M:STCW]WALLSTU(I)    = [L]WALLQTY
   [M:STCW]WALLSTUACT(I) = [L]WALLQTA
   LQTY += [L]WSTUDIS
   LQTA += [L]WALLQTY

   I+=1
   If I>dim([M:STCW]WSTOCOU)-1
    # Issue 110327
    WRET = 1: Return
    #Break
   Endif

Return


########################################################################
# CHGSOW_SMO    Sorties diverses :
#               Traitement des lignes de stock sélectionnées et
#               stockées dans STOCOUW pour alimentation de STOSORW
#-----------------------------------------------------------------------
# Paramètres E : LABR   = Abréviation du masque de saisie
#                LQTY   = Quantité physique à traiter
#
#            S : LQTY   = Quantité physique traitée
#                LRET   = 0 --> OK / >0 --> Erreur
#
########################################################################
Subprog CHGSOW_SMO(LABR,LQTY,LRET)
Value     Char     LABR
Variable  Decimal  LQTY
Variable  Integer  LRET

Local  Integer  I, J, K, NOL
Local  Integer  WLIG, WRET
Local  Char     WITM(GLONITM), LSEC
Local  Char     WMSK
Local  Decimal  WQTYTRT, WSVGQTYSTU
# Quantité à traiter
WQTYTRT = LQTY
LQTY    = 0

Raz LRET
Default Mask "["+LABR+"]"

Trbegin [STO]

WITM=""
For I=0 To [M:STCW]NBLIG-1
   Raz WRET
   # Si rupture article
   If [M:STCW]WITM(I)<>WITM
      Read [ITM]ITM0=[M:STCW]WITM(I)
      If fstat Break Endif
      [M:SMO1]NBLIG+=1
      nolign = [M:SMO1]NBLIG
      NOL    = nolign-1
      [M:SMO0] = [M]
      [M:SMO1] = [M]
      [M:SMO1] = [F:ITM]
      [M:SMO1]PCU(NOL)       = [F:ITM]STU
      [M:SMO1]PCUSTUCOE(NOL) = 1

      Default Mask [SMO1]
      For J=1 To GNBDIE
         If evalue("dim([M:SMO1]CCE"+num$(J)+")")>0
            Call INISEC (LSEC, "STKSODD", J) From TRTX3CPT
            Assign "[M:SMO1]CCE"+num$(J)+"(nolign-1)" With LSEC
         Else
            Break
         Endif
      Next J
      #MA=1
      #Gosub SETMASK From=WINPROG
      If NOL=0
         [M:SMO1]VCRLIN(NOL)=1000
      Else
         [M:SMO1]VCRLIN(NOL)=[M:SMO1]VCRLIN(NOL-1)+1000
      Endif
      # Initialisation zone lien avec ligne document [M:SMO1]WSTOSEQ(NOL)
      Call STKWSTOSEQ("SMO1",NOL,[M:SMO1]NBLIG,1,WLIG,WRET) From STKECR
      If WRET<>0 Break Endif
      # Alimentation article de rupture
      WITM=[M:STCW]WITM(I)
   Endif

   Readlock [STO]STO0=[M:SMO0]STOFCY;[M:STCW]WSTOCOU(I)
   If fstat Goto NEXT1 Endif

   K = [M:SOW]NBLIG
   If K>=dim([M:SOW]WSTOSEQ)
      Call ERREUR(mess(352,199,1)) From GESECRAN
      WRET=1 : Break
   Endif

   # La quantité est supérieure au reste à traiter
   If [M:STCW]WQTYSTU(I)>WQTYTRT-LQTY
      WSVGQTYSTU = [M:STCW]WQTYSTU(I)
      [M:STCW]WQTYSTU(I)=WQTYTRT-LQTY
      [M:STCW]WQTYSTUACT(I)=[M:STCW]WQTYSTU(I)*[M:STCW]WQTYSTUACT(I)/WSVGQTYSTU
   Endif

   If [M:STCW]WQTYSTUACT(I)>[F:STO]QTYSTUACT-[F:STO]CUMALLQTA-[F:STO]CUMWIPQTA
      GMESSAGE = mess(160,195,1)-num$(I+1)-":"-mess(142,184,1)-"\"-
&                mess(45,196,1)-num$([M:STCW]WQTYSTUACT(I))-mess(46,196,1)-
&                num$([F:STO]QTYSTUACT-[F:STO]CUMALLQTA-[F:STO]CUMWIPQTA)
      Call ERREUR(GMESSAGE) From GESECRAN
      WRET=1 : Break
   Endif

   # Création quantité en cours de traitement
   Call CRE_STOWIPW([F:STO]STOCOU,[M:STCW]WQTYSTU(I),[M:STCW]WQTYSTUACT(I)) From STKLIB
   [F:STO]CUMWIPQTY += [M:STCW]WQTYSTU(I)
   [F:STO]CUMWIPQTA += [M:STCW]WQTYSTUACT(I)
   Rewrite [STO]
   If fstat
      Call FSTA("STO1") From GLOCK
      WRET=1 : Break
   Endif

   # Alimentation quantité dans [SMO1]
   [M:SMO1]QTYSTU(NOL)   += [M:STCW]WQTYSTU(I)
   [M:SMO1]QTYPCU(NOL)   += [M:STCW]WQTYSTU(I)

   # Alimentation STOSORW
   [M:SOW]WSTOSEQ(K)    = [M:SMO1]WSTOSEQ(NOL)
   [M:SOW]WSTOCOU(K)    = [F:STO]STOCOU
   [M:SOW]WQTYSTU(K)    = [M:STCW]WQTYSTU(I)
   [M:SOW]WQTYSTUACT(K) = [M:STCW]WQTYSTUACT(I)
   [M:SOW]WALLSTU(K)    = 0
   [M:SOW]WALLSTUACT(K) = 0
   Raz [M:SOW]WLOT(K), [M:SOW]WSLO(K), [M:SOW]WLOC(K)
   Raz [M:SOW]WSTA(K), [M:SOW]WSERNUM(K), [M:SOW]WPLFSTO(K)
   # Issue 110327
   If [F:ITM]SERMGTCOD=4 & [M:SMO1]SERNUM(NOL)<>""
    [M:SOW]WSERNUM(K) = [M:SMO1]SERNUM(NOL)
    Call CRE_STOSERW([F:STO]ITMREF,[M:SOW]WSERNUM(K),[M:STCW]WQTYSTU(I),WRET) From STKLIB
   Endif
   # End issue 110327
   [M:SOW]NBLIG += 1

   # Transfert zones de la ligne de document vers l'écran STOSORW
   GPOINT="DOC_SOW" : Gosub ENTREE From EXEFNC

   LQTY += [M:SOW]WQTYSTU(K)
   If LQTY>=WQTYTRT Break Endif

$NEXT1
Next I

# Pas de quantité traitée
If LQTY=0 WRET=1 Endif

LRET = WRET
If LRET=0
   Commit
Else
   Raz LQTY
   Rollback
Endif

Raz [M:STCW]

End

########################################################################
# CHGSOW_MBM    Consommation matières :
#               Traitement des lignes de stock sélectionnées et
#               stockées dans STOCOUW pour alimentation de STOSORW
#-----------------------------------------------------------------------
# Paramètres E : LABR   = Abréviation du masque de saisie
#                LQTY   = Quantité physique à traiter
#
#            S : LQTY   = Quantité physique traitée
#                LRET   = 0 --> OK / >0 --> Erreur
#
########################################################################
Subprog CHGSOW_MBM(LABR,LQTY,LRET)
Value     Char     LABR
Variable  Decimal  LQTY
Variable  Integer  LRET

Local  Integer  I, J, K, NOL
Local  Integer  WLIG, WRET
Local  Char     WITM(GLONITM), LSEC
Local  Char     WMSK
Local  Decimal  WQTYTRT, WSVGQTYSTU
# Quantité à traiter
WQTYTRT = LQTY
LQTY    = 0

Raz LRET
Default Mask "["+LABR+"]"

Trbegin [STO]

WITM=""
For I=0 To [M:STCW]NBLIG-1
   Raz WRET
   # Si rupture article
   If [M:STCW]WITM(I)<>WITM
      Read [ITM]ITM0=[M:STCW]WITM(I)
      If fstat Break Endif
      [M:MBM]NBLIG+=1
      nolign = [M:MBM]NBLIG
      NOL    = nolign-1
      [M:MBM] = [F:MFM]
      [M:MBM] = [M]
      #[M:MBM] = [F:ITM]
      [M:MBM]MFMITMREF(NOL) = [F:ITM]ITMREF

      #----- Chargement de la ligne de production -----#
      If [F:MFG]MFGNUM<>[M:MBM]MFGNUM(NOL)
        Read [MFG]MFG0=[M:MBM]MFGNUM(NOL)
        If fstat : Raz [F:MFG] : Endif
      Endif
      If [F:MFM]MFGNUM<>[M:MBM]MFGNUM(NOL) | [F:MFM]MFGLIN<>[M:MBM]MFGLIN(NOL)
&     |  [F:MFM]BOMSEQ<>[M:MBM]BOMSEQ(NOL) | [F:MFM]ITMREF<>[M:MBM]ITMREF(NOL)
         Read [MFM] MFM0 = [M:MBM]MFGNUM(NOL);[M:MBM]MFGLIN(NOL);[M:MBM]BOMSEQ(NOL);[M:MBM]ITMREF(NOL)
         If fstat : Raz [F:MFI] : Endif
      Endif
      If [F:ITM]ITMREF<>[M:MBM]ITMREF(NOL)
         Read [ITM] ITM0=[M:MBM]ITMREF(NOL)
         If fstat : Raz [F:ITM] : Endif
      Endif
      [M:MBM]MATTYP(NOL) = 1
      Gosub CHARG_ANA_MBM From ENVADC

      If NOL=0
         [M:MBM]WLINUM(NOL)=1000
      Else
         [M:MBM]WLINUM(NOL)=[M:MBM]WLINUM(NOL-1)+1000
      Endif

      # Initialisation zone lien avec ligne document [M:MBM]WSTOSEQ(NOL)
      Call STKWSTOSEQ("MBM",NOL,[M:MBM]NBLIG,1,WLIG,WRET) From STKECR
      If WRET<>0 Break Endif
      # Alimentation article de rupture
      WITM=[M:STCW]WITM(I)
   Endif

   Readlock [STO]STO0=[M:MBM]FCY;[M:STCW]WSTOCOU(I)
   If fstat Goto NEXT2 Endif

   K = [M:SOW]NBLIG
   If K>=dim([M:SOW]WSTOSEQ)
      Call ERREUR(mess(352,199,1)) From GESECRAN
      WRET=1 : Break
   Endif

   # La quantité est supérieure au reste à traiter
   If [M:STCW]WQTYSTU(I)>WQTYTRT-LQTY
      WSVGQTYSTU            = [M:STCW]WQTYSTU(I)
      [M:STCW]WQTYSTU(I)    = WQTYTRT-LQTY
      [M:STCW]WQTYSTUACT(I) = [M:STCW]WQTYSTU(I)*[M:STCW]WQTYSTUACT(I)/WSVGQTYSTU
      [M:STCW]WALLSTU(I)    = min([M:STCW]WQTYSTU(I),[M:STCW]WALLSTU(I))
      [M:STCW]WALLSTUACT(I) = min([M:STCW]WQTYSTUACT(I),[M:STCW]WALLSTUACT(I))
   Endif

   If [M:STCW]WQTYSTUACT(I)-[M:STCW]WALLSTUACT(I)>[F:STO]QTYSTUACT-[F:STO]CUMALLQTA-[F:STO]CUMWIPQTA
      GMESSAGE = mess(160,195,1)-num$(I+1)-":"-mess(142,184,1)-"\"-
&                mess(45,196,1)-num$([M:STCW]WQTYSTUACT(I))-mess(46,196,1)-
&                num$([F:STO]QTYSTUACT-[F:STO]CUMALLQTA-[F:STO]CUMWIPQTA)
      Call ERREUR(GMESSAGE) From GESECRAN
      WRET=1 : Break
   Endif

   # Création quantité en cours de traitement
   Call CRE_STOWIPW([F:STO]STOCOU,[M:STCW]WQTYSTU(I),[M:STCW]WQTYSTUACT(I)) From STKLIB
   [F:STO]CUMWIPQTY += [M:STCW]WQTYSTU(I)-[M:STCW]WALLSTU(I)
   [F:STO]CUMWIPQTA += [M:STCW]WQTYSTUACT(I)-[M:STCW]WALLSTUACT(I)
   Rewrite [STO]
   If fstat
      Call FSTA("STO1") From GLOCK
      WRET=1 : Break
   Endif

   # Alimentation quantité dans [MBM]
   [M:MBM]USEQTY(NOL)   += [M:STCW]WQTYSTU(I)
   [M:MBM]WQTY(NOL)     += [M:STCW]WQTYSTU(I)

   # Alimentation STOSORW
   [M:SOW]WSTOSEQ(K)    = [M:MBM]WSTOSEQ(NOL)
   [M:SOW]WSTOCOU(K)    = [F:STO]STOCOU
   [M:SOW]WQTYSTU(K)    = [M:STCW]WQTYSTU(I)
   [M:SOW]WQTYSTUACT(K) = [M:STCW]WQTYSTUACT(I)
   [M:SOW]WALLSTU(K)    = [M:STCW]WALLSTU(I)
   [M:SOW]WALLSTUACT(K) = [M:STCW]WALLSTUACT(I)
   Raz [M:SOW]WLOT(K), [M:SOW]WSLO(K), [M:SOW]WLOC(K)
   Raz [M:SOW]WSTA(K), [M:SOW]WSERNUM(K), [M:SOW]WPLFSTO(K)
   # Issue 110327
   If [F:ITM]SERMGTCOD=4 & [M:MBM]SERNUM(NOL)<>""
    [M:SOW]WSERNUM(K) = [M:MBM]SERNUM(NOL)
    Call CRE_STOSERW([F:STO]ITMREF,[M:SOW]WSERNUM(K),[M:STCW]WQTYSTU(I),WRET) From STKLIB
   Endif
   # End issue 110327
   [M:SOW]NBLIG += 1

   # Transfert zones de la ligne de document vers l'écran STOSORW
   GPOINT="DOC_SOW" : Gosub ENTREE From EXEFNC

   LQTY += [M:SOW]WQTYSTU(K)
   If LQTY>=WQTYTRT Break Endif

$NEXT2
Next I

# Pas de quantité traitée
If LQTY=0 WRET=1 Endif

LRET = WRET
If LRET=0
   Commit
Else
   Raz LQTY
   Rollback
Endif

Raz [M:STCW]

End

########################################################################
# CHGSTOCHGW    Traitement des lignes de stock sélectionnées et
#               stockées dans STOCOUW pour alimentation de STOCHGW
#-----------------------------------------------------------------------
# Paramètres E : LABR   = Abréviation du masque de saisie
#                LORI   = Fonction origine
#                         2 : Changement de stock
#                         3 : Transfert Inter-Site
#                         4 : Transfert pour Sous-Traitance
#                LFOU   = Fournisseur destination (si LORI=4)
#                LADR   = Adresse destination     (si LORI=4)
#                LQTY   = Quantité physique à traiter
#
#            S : LQTY   = Quantité physique traitée
#                LRET   = 0 --> OK / >0 --> Erreur
#
########################################################################
Subprog CHGSTOCHGW(LABR,LORI,LFOU,LADR,LQTY,LRET)
Value     Char     LABR
Value     Integer  LORI
Value     Char     LFOU
Value     Char     LADR
Variable  Decimal  LQTY
Variable  Integer  LRET

Local  Integer  I, J, K, NOL, OK
Local  Integer  WLIG, WRET
Local  Char     WITM(GLONITM), LSEC
Local  Char     WMSK
Local  Decimal  WQTYTRT, WSVGQTYSTU
Local   Char    WSERNUM(GLONSER)    # Issue 110327 - 2017-03-07 by MAE
# Quantité à traiter
WQTYTRT = LQTY
LQTY    = 0

Raz LRET

Trbegin [STO]

For I=0 To [M:STCW]NBLIG-1
   Raz WRET
   Default Mask "["+LABR+"]"

   Read [STO]STO0=[M]STOFCY;[M:STCW]WSTOCOU(I)
   If fstat Goto NEXT3 Endif
   Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
   If fstat Goto NEXT3 Endif

   # Alimentation écran SCS1 et STOCHGW
   Call POSTABLE([M:SCS1]FCYDES,[F:STO]ITMREF,[F:STO]LOT,[F:STO]SLO,WRET)
&       From SUBSCSB
   If WRET
      Goto NEXT3
   Endif

   Call STKWSTOSEQ ("SCS1",[M:SCS1]NBLIG,[M:SCS1]NBLIG,2,WLIG,WRET) From STKECR
   If WRET<>0 Break Endif
   nolign = [M:SCS1]NBLIG+1
   NOL    = nolign-1

   [M:SCS1] = [M]
   # Issue 110327
   WSERNUM = [M:SCS1]SERNUM(NOL)
   [M:SCS1] = [F:STO]
   #[M:SCS1]ITMDES1(NOL) = [F:ITM]ITMDES1
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SCS1]ITMDES1(NOL), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
   [M:SCS1]WSTOCOU(NOL) = [F:STO]STOCOU
   # Issue 110327
   [M:SCS1]SERNUM(NOL) = WSERNUM

   # La quantité est supérieure au reste à traiter
   If [M:STCW]WQTYSTU(I)>WQTYTRT-LQTY
      WSVGQTYSTU = [M:STCW]WQTYSTU(I)
      [M:STCW]WQTYSTU(I)=WQTYTRT-LQTY
      [M:STCW]WQTYSTUACT(I)=[M:STCW]WQTYSTU(I)*[M:STCW]WQTYSTUACT(I)/WSVGQTYSTU
   Endif

   # Alimentation quantité
   [M:SCS1]STU(NOL)       = [F:ITM]STU
   [M:SCS1]QTYSTUDES(NOL) = [M:STCW]WQTYSTU(I)
   [M:SCS1]QTYPCU(NOL)    = [M:STCW]WQTYSTU(I)/[F:STO]PCUSTUCOE

   [M:SCS1]PCUDES(NOL)    = [M:SCS1]PCU(NOL)
   [M:SCS1]QTYPCUDES(NOL) = [M:SCS1]QTYPCU(NOL)
   [M:SCS1]COEDES(NOL)    = [F:STO]PCUSTUCOE

   If dim([M:SCS1]PALNUMDES(NOL)) > 0           # hcb 71011
      [M:SCS1]PALNUMDES(NOL) = [F:STO]PALNUM
   Endif
   If dim([M:SCS1]CTRNUMDES(NOL)) > 0           # hcb 71011
      [M:SCS1]CTRNUMDES(NOL) = [F:STO]CTRNUM
   Endif
   # Si pas de statut/emplacement destination, on met l'origine
   If [M:SCS1]STADES(NOL)=""
      [M:SCS1]STADES(NOL)   =[F:STO]STA
   Endif
   If dim([M:SCS1]LOCDES(NOL)) > 0              # hcb 71011
      If [M:SCS1]LOCDES(NOL)=""
         [M:SCS1]LOCDES(NOL)   =[F:STO]LOC
         [M:SCS1]LOCTYPDES(NOL)=[F:STO]LOCTYP
      Endif
   Endif
   Local Char WLOC(GLONLOC)                     # hcb 71011
   Local Char WLOCDES(GLONLOC)
   Raz WLOC
   Raz WLOCDES
   If dim([M:SCS1]LOCDES(NOL)) > 0
      WLOC    = [M:SCS1]LOC(NOL)
      WLOCDES = [M:SCS1]LOCDES(NOL)
   Endif
   # Si statuts et emplacements identiques --> rien à traiter
   If [M:SCS1]STADES(NOL)=[M:SCS1]STA(NOL) &
&     WLOCDES = WLOC
      Goto NEXT3
   Endif
   If [M:SCS1]BETCPY=2
      [M:SCS1]INVSGH=2
   Else
      [M:SCS1]INVSGH=1
   Endif
   Default Mask [SCS1]
   If [M:SCS1]STOFCY<>[M:SCS1]FCYDES
      For J=1 To GNBDIE
         If [M:SCS1]BETCPY=2
            Call INISEC (LSEC, "ICOD", J) From TRTX3CPT
         Else
            Call INISEC (LSEC, "TRSD", J) From TRTX3CPT
         Endif
         Assign "[M:SCS1]CCE"+num$(J)+"(NOL)" With LSEC
      Next
   Endif

   If NOL=0
      [M:SCS1]VCRLIN(NOL)=1000
   Else
      [M:SCS1]VCRLIN(NOL)=[M:SCS1]VCRLIN(NOL-1)+1000
   Endif
   Case [M:SCS1]BETFCYCOD
    When 1,2 : If left$([M]STADES(NOL),1)="Q" & left$([F:STO]STA,1)<>"Q"
                  [M:SCS1]QLYCTLFLG(NOL)=[F:SRU]QLYCTLFLG
               Else
                  [M:SCS1]QLYCTLFLG(NOL)=1
               Endif
    When 3,4 : [M:SCS1]QLYCTLFLG(NOL)=1
   Endcase
   Case [F:ITM]STOMGTCOD
    When 3       : [M:SCS1]POT(NOL) = [F:STL]POT
    When 4       : [M:SCS1]POT(NOL) = [F:STL]ACT/100
    When Default : [M:SCS1]POT(NOL) = 1
   Endcase

   Default Mask [SCS1]
   Call OUVCHG("SCS1",NOL,[M:SCS1]STOFCY) From SUBSCSB
   If GOUVENT>0
      Call DELSTOCHGW("SCS1",[M:SCS1]STOFCY,[M:SCS1]NBLIG-1,[M:SCS1]NBLIG-1,1,WRET) From SUBSCSB
      Goto NEXT3
   Else
      If [M:SCS1]BETCPY=2
          # En inter-sociétés, alimentation du prix
          If [M:SCS1]PRI(NOL)=0
              Call DEFPRI([M:SCS1]ITMREF(NOL),[F:STL]ECCVALMAJ,[F:STL]ECCVALMIN,[M:SCS1]FCYDES,[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,
&                         "","",[M:SCS1]IPTDAT,[M:SCS1]QTYSTUDES(NOL),[M:SCS1]QTYSTUDES(NOL),0,
&                         GBIDI1,[M:SCS1]PRI(NOL),LRET) From STKVAL
          Endif
          Call SETNEWPRIOVE([M:SCS1]ITMREF(NOL),[F:STL]ECCVALMAJ,[F:STL]ECCVALMIN,[M:SCS1]FCYDES,[M:SCS1]IPTDAT,
&                         [M:SCS1]WSTOSEQ(NOL),[M:SCS1]PRI(NOL),
&                         [M:SCS1]TRSTYP,[M:SCS1]QTYSTUDES(NOL),"",LRET) From STKVAL
      Endif
   Endif

   [M:SCS1]NBLIG+=1

   LQTY += [M:SCS1]QTYSTUDES(NOL)
   If LQTY>=WQTYTRT Break Endif

$NEXT3
Next I

# Pas de quantité traitée
If LQTY=0 WRET=1 Endif

LRET = WRET
If LRET=0
   Commit
Else
   Raz LQTY
   Rollback
Endif

Raz [M:STCW]

End

########################################################################
# ALIM_PRNETI   Alimentation de l'état et la destination pour
#               impression des étiquettes
#-----------------------------------------------------------------------
# Paramètres E : LITM   = Article
#                LUNIT  = Unité
#            S : LETAT  = Etat (étiquettee)
#                LPRN   = Destination
#
########################################################################
Subprog ALIM_PRNETI(LITM,LUNIT,LETAT,LPRN)
Value     Char     LITM
Value     Char     LUNIT
Variable  Char     LETAT
Variable  Char     LPRN

Local Integer I, OBLIG

If clalev([F:AIA])=0 : Local File APRTAUS   [AIA] : Endif
If clalev([F:AIM])=0 : Local File APRINTER  [AIM] : Endif
If clalev([F:ARP])=0 : Local File AREPORT   [ARP] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif
If clalev([F:ACC])=0 : Local File ACCES     [ACC] : Endif

If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif

If [F:ITM]ITMREF<>LITM
   Read [ITM]ITM0=LITM
   If fstat End Endif
Endif

LPRN = GVTETI

# Récupération étiquette
If LUNIT=[F:ITM]STU
   LETAT=[F:ITM]STULBEFMT
Else I=find(LUNIT,[F:ITM]PCU(0..dim([F:ITM]PCU)-1))
   If I>0
      LETAT=[F:ITM]LBEFMT(I-1)
   Endif
Endif
# Si pas d'étiquettes ou destination connu, on sort
If LETAT="" | LPRN<>"" End Endif

# Récupération destination
Call DEFIMP(LETAT,GUSER,"",LPRN,OBLIG) From IMPRIME

End

########################################################################
# ALIM_PRNDOC   Alimentation de la destination pour impression
#               des documents
#-----------------------------------------------------------------------
# Paramètres E : LETAT  = Etat (Document)
#            S : LPRN   = Destination
#
########################################################################
Subprog ALIM_PRNDOC(LETAT,LPRN)
Value     Char     LETAT
Variable  Char     LPRN

Local Integer OBLIG

If clalev([F:AIA])=0 : Local File APRTAUS  [AIA] : Endif
If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif
If clalev([F:ARP])=0 : Local File AREPORT  [ARP] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif
If clalev([F:ACC])=0 : Local File ACCES    [ACC] : Endif

LPRN = GVTDOC

# Si destination connu, on sort
If LPRN<>"" End Endif
# Récupération destination
Call DEFIMP(LETAT,GUSER,"",LPRN,OBLIG) From IMPRIME

End

########################################################################
# PRINT_ETI   Impression des étiquettes
#-----------------------------------------------------------------------
# Paramètres E : LFCY   = Site
#                LTYP   = Type de pièce
#                LNUM   = No de pièce
#
########################################################################
Subprog PRINT_ETI(LFCY,LTYP,LNUM)
Value     Char     LFCY
Value     Integer  LTYP
Value     Char     LNUM

Local     Integer  LRET

Gosub OUVRE From SUBSLPA

If !clalev([M:SLP]) Local Mask STOLBEIMP [SLP] Endif

If GFONC1 = "VXASY"
   [M:SLP]ABRDOC = "SSL1"
Else
   Raz [M:SLP]
Endif
[M:SLP]STOFCY    = LFCY
[M:SLP]LBEVCRTYP = LTYP
[M:SLP]VCRNUMSTR = LNUM
[M:SLP]VCRNUMEND = LNUM

Call RELOAD From SUBSLPB
If [M:SLP]NBLIG=0 End Endif

#--- Bug 67929
Call TEMPON(mess(144,100,1)) From GESECRAN
Call PRINT(LRET) From SUBSLPB
#--- Bug 67929
Sleep 3
Call TEMPOFF     From GESECRAN
#---
End

