#<AdxTL>@(#)0.0.0.0 $Revision$
# Class ASYRMET

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINSERT_CONTROL_BEFORE"       : Gosub AINSERT_CONTROL_BEFORE
      When "AUPDATE_CONTROL_BEFORE"       : Gosub AUPDATE_CONTROL_BEFORE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "USRBI"                 : Gosub BI_CONTROL
  When "PRFXTD"                : Gosub WAS_CONTROL
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return









###########################################################################################
$AINSERT_CONTROL_BEFORE
Gosub WAS_CONTROL
Gosub BI_CONTROL
Return

###########################################################################################
$AUPDATE_CONTROL_BEFORE
Gosub WAS_CONTROL
Gosub BI_CONTROL
Return

###########################################################################################
$BI_CONTROL
# BI User profile - no class yet available
If this.USRBI<>""
  Local File ABIPRFUSR [AIU]
  Filter [AIU] Where PRF=this.USRBI
  Read [AIU] First
  If fstat <> [V]CST_AOK
    [L]ASTATUS = fmet this.ASETERROR("AIU",mess(77,148,1),[V]CST_AERROR)
  Endif
Endif
Return

###########################################################################################
$WAS_CONTROL
# Safe X3 WAS profile - no class yet available
If this.PRFXTD<>""
  Local File AYTPRFUSR [AYH]
  Filter [AYH] Where CODPRF=this.PRFXTD
  Read [AYH] First
  If fstat <> [V]CST_AOK
    [L]ASTATUS = fmet this.ASETERROR("AYH",mess(108,9901,1)-mess(42,151,1)-mess(40,9016,1),[V]CST_AERROR)
  Endif
Endif
Return

