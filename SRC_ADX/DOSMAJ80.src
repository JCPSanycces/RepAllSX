#<AdxTL>@(#)0.0.0.0 $Revision$
##################################################################################
# DOSMAJ80 : Mises à jour à effectuer lors du passage à l'update 11 (Release 80)
# Moulinette avant l'update 11 (CHALLENGER)
##################################################################################


#-------------------------------------#
#         Avant mise à jour           #
#-------------------------------------#

#######################################
Subprog AMAJ
Local Integer RELEASE
Local Integer OKTRT

Onerrgo ERREUR

RELEASE = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ80 - AMAJ - RELEASE = "-num$(RELEASE),-1) From GESECRAN

#----- Superviseur en premier
Call EXISTE_ADX("","","SUPMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJDIC SUPMAJ80 *************",-1) From GESECRAN
#----- Préparation Superviseur :
# Rajout des types de données
# Rajout des codes activités
# Rajout des nouveaux champs
  Call MAJDIC From SUPMAJ80

  Call ECR_TRACE("************** AMAJ SUPMAJ80 ***************",-1) From GESECRAN
  Call AMAJ From SUPMAJ80 : # Moulinettes Superviseur
Endif


#----- Puis Tronc commun

Call EXISTE_ADX("","","TRCMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ TRCMAJ80 ***************",-1) From GESECRAN
  Call AMAJ From TRCMAJ80
Endif

#----- Ensuite les autres modules

Call EXISTE_ADX("","","CPTMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ CPTMAJ80 ***************",-1) From GESECRAN
  Call AMAJ From CPTMAJ80 : # Moulinettes Compta
Endif

Call EXISTE_ADX("","","TRSMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ TRSMAJ80 ***************",-1) From GESECRAN
  Call AMAJ From TRSMAJ80 : # Moulinettes Tiers
Endif

Call EXISTE_ADX("","","VENMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ VENMAJ80 ***************",-1) From GESECRAN
  Call AMAJ From VENMAJ80 : # Moulinettes Ventes
  # 71065 : PJT
  GVALTRANS(5)=2          : # Validation des TRT générés Ventes (transactions, tarifs)
  # 71065 : PJT
Endif

Call EXISTE_ADX("","","ACHMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ ACHMAJ80 ***************",-1) From GESECRAN
  Call AMAJ From ACHMAJ80 : # Moulinettes Achats
Endif
# Issue 119814 - 2016-11-18 by SR : Validation des TRT générés Achats (transactions, tarifs)
If  [F:ADS]MODULE(5)=2
    GVALTRANS(6)=2
Endif

Call EXISTE_ADX("","","STOMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ STOMAJ80 ***************",-1) From GESECRAN
  Call AMAJ From STOMAJ80 : # Moulinettes Stocks
Endif

Call EXISTE_ADX("","","GPAMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ GPAMAJ80 ***************",-1) From GESECRAN
  Call AMAJ From GPAMAJ80 : # Moulinettes GPAO
Endif

Call EXISTE_ADX("","","CRMMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ CRMMAJ80 ***************",-1) From GESECRAN
  Call AMAJ From CRMMAJ80 : # Moulinettes HDK (support client)
Endif

Call EXISTE_ADX("","","FASMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ FASMAJ80 ***************",-1) From GESECRAN
  Call AMAJ From FASMAJ80 : # Moulinettes Immobilisations
Endif

Call EXISTE_ADX("","","UTIEDI80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ UTIEDI80 ***************",-1) From GESECRAN
  Call AMAJ From UTIEDI80 : # Moulinettes EDI
Endif

Onerrgo
End



#-------------------------------------#
#          Après mise à jour          #
#-------------------------------------#

#######################################
Subprog MAJ
Local Integer RELEASE
Local Integer OKTRT

Onerrgo ERREUR

RELEASE = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ80 - MAJ - RELEASE = "-num$(RELEASE),-1) From GESECRAN

#----- Superviseur en premier

Call EXISTE_ADX("","","SUPMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ SUPMAJ80 ***************",-1) From GESECRAN
  Call MAJ From SUPMAJ80 : # Moulinettes Superviseur
Endif

#----- Puis Tronc commun

Call EXISTE_ADX("","","TRCMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ TRCMAJ80 ***************",-1) From GESECRAN
  Call MAJ From TRCMAJ80 : # Moulinettes Tronc commun
Endif

#----- Ensuite les autres modules

Call EXISTE_ADX("","","CPTMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ CPTMAJ80 ***************",-1) From GESECRAN
  Call MAJ From CPTMAJ80 : # Moulinettes Compta
Endif

Call EXISTE_ADX("","","TRSMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ TRSMAJ80 ***************",-1) From GESECRAN
  Call MAJ From TRSMAJ80 : # Moulinettes Tiers
Endif

Call EXISTE_ADX("","","VENMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ VENMAJ80 ***************",-1) From GESECRAN
  Call MAJ From VENMAJ80 : # Moulinettes Ventes
Endif

Call EXISTE_ADX("","","ACHMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ ACHMAJ80 ***************",-1) From GESECRAN
  Call MAJ From ACHMAJ80 : # Moulinettes Achats
Endif

# Issue 121084/121085 - 2017-02-27 by SR : Revalider les consultations si pas dossier historique
If [F:ADS]MODULE(4)=2 | [F:ADS]MODULE(5)=2
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    Call GENDOS([F:ADS]DOSSIER)   From SUBGTC
  Endif
Endif

Call EXISTE_ADX("","","STOMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ STOMAJ80 ***************",-1) From GESECRAN
  Call MAJ From STOMAJ80 : # Moulinettes Stocks
Endif

Call EXISTE_ADX("","","GPAMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ GPAMAJ80 ***************",-1) From GESECRAN
  Call MAJ From GPAMAJ80 : # Moulinettes GPAO
Endif

Call EXISTE_ADX("","","CRMMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ CRMMAJ80 ***************",-1) From GESECRAN
  Call MAJ From CRMMAJ80 : # Moulinettes HDK (support client)
Endif

Call EXISTE_ADX("","","FASMAJ80",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ FASMAJ80 ***************",-1) From GESECRAN
  Call MAJ From FASMAJ80 : # Moulinettes Immobilisations
Endif

Onerrgo
End

###################################################################################
###################################################################################
###################################################################################

$ERREUR
GERRDOS = errn
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Resume

