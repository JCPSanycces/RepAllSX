#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICPT92 - VNEXT   UTI process                                    Module CPT   #
#            correction utility
#
# Issue X3-51971 - 2017-09-04 by BEFOU : Add a parameter to trigger or not the new behavior
# Issue X3-56195 - 2017-09-15 by GLE   : Fix issue on archive folders
# Issue X3-71910 - 2018-01-23 by BEFOU : Adapting because of backport of the param LOWMTCGEN
#
##########################################################################


Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTICPT92(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT92(DOSSIER)
Value Char DOSSIER

# Issue X3-56195 - 2017-09-15 by GLE : Do not perform on archive folders
If (func DOSSUB.ISHISTFOLD(DOSSIER))
  Call ECR_TRACE("UTICPT92 : Not to perform on archive folder : "+DOSSIER,0) From GESECRAN
  End
Endif

Local Integer WCOMPTEUR
Call ECR_TRACE("UTICPT92 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ADW])  =0  Local File =DOSSIER+".ADOVAL"   [ADW] : Endif

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [ADW]
 Read [ADW]ADW1="LOWMTCGEN";"" ;""
 If fstat
    Raz [ADW]
    [F:ADW]CMP=""
    [F:ADW]FCY=""
    [F:ADW]PARAM="LOWMTCGEN"
    [F:ADW]VALEUR="2" #YES
    Write [F:ADW]
 # Issue X3-71910 - 2018-01-23 by BEFOU : Keep the value of the last
  #Else
  #   [F:ADW]VALEUR="2" #YES
  #   Rewrite  [F:ADW]
  Endif
  If !fstat Then WCOMPTEUR += 1 Endif
  If !fstat
    Call ECR_TRACE("Write of default value parameter LOWMTCGEN - OK  "+DOSSIER,0) From GESECRAN
  Else
    Call ECR_TRACE("Write of default value parameter LOWMTCGEN - No OK  "+DOSSIER,1) From GESECRAN
  Endif

Commit

Close Local File [ADW]

Call ECR_TRACE("UTICPT92 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

If [F:ADS]MODULE(2)<>2 : End : Endif                                 : # 2 module compta

Call MAJ_UTICPT92(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 : # 2 module compta

Call MAJ_UTICPT92(APPLI)
End

