#<AdxTL>@(#)0.0.0.0 $Revision$ 
Local File EXPENSESHEA [EXSH]
Local File HREXPENSES  [HREXS]


Trbegin [EXSH]
GOK=1
For [HREXS]HREXS0 Where LIN = 1
  Read [EXSH]EXSH0 = [F:HREXS]REFNUM;[F:HREXS]EXSNUM;[F:HREXS]CTRNUM
  If fstat
    Raz [EXSH]
    [F:EXSH]  = [F:HREXS]
    Write [F:EXSH]
    If fstat
      GOK = 0 : Call FSTA("EXSH") From GLOCK : Break
    Endif

  Endif
Next
If GOK=0 : Rollback : Endif
Commit
End




