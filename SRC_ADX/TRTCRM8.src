#<AdxTL>@(#)10.0.0.0 $Revision$
#########################################################################################################
#   Consultation des numéros de téléphone d'un interlocuteur           Module CRM         27 juillet 2000
#########################################################################################################
#########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  #PARAM(1) = Code interlocuteur
  If PARAM(1) = "" Then
    GMESSAGE = mess(247,196,1) #Aucun interlocuteur n'est mentionné pour la recherche de numéros de téléphone.
    GERR = 2
    FIN = 1
    Return
  Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  #Initialise l'en-tête
  Read [AIN]AIN0=PARAM(1)
  If fstat Then
    [M:CRMH]CNT = PARAM(1)
  Else
    Call BUILDFULNAM("AIN", [M:CRMH]CNT) From CRMUTIL140
  Endif
  Gosub LOADTEL
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If dim([M:CRMH]CNT) > 0 Then
    #Nettoie l'écran avant de partir.
    Raz [M:CRMH]
  Endif
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Charge la liste des numéros de téléphone
$LOADTEL
Local Integer I
Local Integer ITERCTL

  I = 0
  If PARAM(1) = "" Then
    Return
  Endif
  #Affichage des numéros personnels
  Read [AIN]AIN0=PARAM(1)
  If !fstat Then
    [M:CRMH]PSLTEL = [F:AIN]CNTETS
    [M:CRMH]PSLMOB = [F:AIN]CNTMOB
    [M:CRMH]PSLZIP = [F:AIN]ZIP
    [M:CRMH]PSLCTY = [F:AIN]CTY
    [M:CRMH]PSLCRY = [F:AIN]CRY
  Endif
  #Affichage des numéros professionnels
  Filter [CNT] Where [F:CNT]CCNCRM = PARAM(1)
  For [CNT] CNT2
    If I = dim([M:CRMH]TYP)-1 Then
      Break
    Endif
    Case [F:CNT]BPATYP
      When 1
        Read [BPR]BPR0=[F:CNT]BPANUM
        If !fstat Then
          Gosub LOADBPRADD
        Endif
      When 2
        Read [CPY]CPY0=[F:CNT]BPANUM
        If !fstat Then
          Gosub LOADCPYADD
        Endif
      When 3
        Read [FCY]FCY0=[F:CNT]BPANUM
        If !fstat Then
          Gosub LOADFCYADD
        Endif
      When Default
    Endcase
  Next
  Filter [CNT]
  [M:CRMH]NBTEL = I
  Affzo [M:CRMH]
Return

##########################################################################################################
# Chargement des informations d'adresse d'un tiers
$LOADBPRADD
  ITERCTL = 0
  If [F:CNT]BPAADD = "" Then
    If [F:CNT]BPANUM <> "" Then
      Read [BPA]BPA0=1;[F:CNT]BPANUM;[F:BPR]BPAADD
      If !fstat Then
        [M:CRMH]TYP(I) = 4
        [M:CRMH]NAM(I) = [F:BPR]BPRNAM
        [M:CRMH]TELTYP(I) = 2
        [M:CRMH]TEL(I) = [F:CNT]TEL
        [M:CRMH]ZIP(I) = [F:BPA]POSCOD
        [M:CRMH]CTY(I) = [F:BPA]CTY
        [M:CRMH]CRY(I) = [F:BPA]CRY
        I += 1
      Endif
    Endif
  Else
    If [F:CNT]BPANUM <> "" Then
      Read [BPA]BPA0=1;[F:CNT]BPANUM;[F:CNT]BPAADD
      If !fstat Then
        [M:CRMH]TYP(I) = 4
        [M:CRMH]NAM(I) = [F:BPR]BPRNAM
        [M:CRMH]TELTYP(I) = 2
        [M:CRMH]TEL(I) = [F:CNT]TEL
        [M:CRMH]ZIP(I) = [F:BPA]POSCOD
        [M:CRMH]CTY(I) = [F:BPA]CTY
        [M:CRMH]CRY(I) = [F:BPA]CRY
        I += 1
      Endif
    Endif
  Endif
  Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:CNT]BPANUM
  For [BPA]
    If I = dim([M:CRMH]TYP)-1 Then
      Break
    Endif
    If [F:BPA]TEL(0) <> "" Then        # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      [M:CRMH]TYP(I) = 1
      [M:CRMH]NAM(I) = [F:BPR]BPRNAM
      [M:CRMH]TELTYP(I) = 1
      [M:CRMH]TEL(I) = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      [M:CRMH]ZIP(I) = [F:BPA]POSCOD
      [M:CRMH]CTY(I) = [F:BPA]CTY
      [M:CRMH]CRY(I) = [F:BPA]CRY
      I += 1
    Endif
  Next
  Filter [BPA]
Return

##########################################################################################################
# Chargement des informations d'adresse d'une société
$LOADCPYADD
  ITERCTL = 0
  If [F:CNT]BPAADD = "" Then
    If [F:CNT]BPANUM <> "" Then
      Read [BPA]BPA0=2;[F:CNT]BPANUM;[F:CPY]BPAADD
      If !fstat Then
        [M:CRMH]TYP(I) = 4
        [M:CRMH]NAM(I) = [F:CPY]CPYNAM
        [M:CRMH]TELTYP(I) = 2
        [M:CRMH]TEL(I) = [F:CNT]TEL
        [M:CRMH]ZIP(I) = [F:BPA]POSCOD
        [M:CRMH]CTY(I) = [F:BPA]CTY
        [M:CRMH]CRY(I) = [F:BPA]CRY
        I += 1
      Endif
    Endif
  Else
    If [F:CNT]BPANUM <> "" Then
      Read [BPA] BPA0 = 2;[F:CNT]BPANUM;[F:CNT]BPAADD
      If !fstat Then
        [M:CRMH]TYP(I) = 4
        [M:CRMH]NAM(I) = [F:CPY]CPYNAM
        [M:CRMH]TELTYP(I) = 2
        [M:CRMH]TEL(I) = [F:CNT]TEL
        [M:CRMH]ZIP(I) = [F:BPA]POSCOD
        [M:CRMH]CTY(I) = [F:BPA]CTY
        [M:CRMH]CRY(I) = [F:BPA]CRY
        I += 1
      Endif
    Endif
  Endif
  Filter [BPA] Where [F:BPA]BPATYP = 2 and [F:BPA]BPANUM = [F:CNT]BPANUM
  For [BPA]
    If I = dim([M:CRMH]TYP)-1 Then
      Break
    Endif
    If [F:BPA]TEL(0) <> "" Then        # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      [M:CRMH]TYP(I) = 2
      [M:CRMH]NAM(I) = [F:CPY]CPYNAM
      [M:CRMH]TELTYP(I) = 1
      [M:CRMH]TEL(I) = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      [M:CRMH]ZIP(I) = [F:BPA]POSCOD
      [M:CRMH]CTY(I) = [F:BPA]CTY
      [M:CRMH]CRY(I) = [F:BPA]CRY
      I += 1
    Endif
  Next
  Filter [BPA]
Return

##########################################################################################################
# Chargement des informations d'adresse d'un site
$LOADFCYADD
  ITERCTL = 0
  If [F:CNT]BPAADD = "" Then
    If [F:CNT]BPANUM <> "" Then
      Read [BPA]BPA0=3;[F:CNT]BPANUM;[F:FCY]BPAADD
      If !fstat Then
        [M:CRMH]TYP(I) = 4
        [M:CRMH]NAM(I) = [F:FCY]FCYNAM
        [M:CRMH]TELTYP(I) = 2
        [M:CRMH]TEL(I) = [F:CNT]TEL
        [M:CRMH]ZIP(I) = [F:BPA]POSCOD
        [M:CRMH]CTY(I) = [F:BPA]CTY
        [M:CRMH]CRY(I) = [F:BPA]CRY
        I += 1
      Endif
    Endif
  Else
    If [F:CNT]BPANUM <> "" Then
      Read [BPA]BPA0=3;[F:CNT]BPANUM;[F:CNT]BPAADD
      If !fstat Then
        [M:CRMH]TYP(I) = 4
        [M:CRMH]NAM(I) = [F:FCY]FCYNAM
        [M:CRMH]TELTYP(I) = 2
        [M:CRMH]TEL(I) = [F:CNT]TEL
        [M:CRMH]ZIP(I) = [F:BPA]POSCOD
        [M:CRMH]CTY(I) = [F:BPA]CTY
        [M:CRMH]CRY(I) = [F:BPA]CRY
        I += 1
      Endif
    Endif
  Endif
  Filter [BPA] Where [F:BPA]BPATYP = 3 and [F:BPA]BPANUM = [F:CNT]BPANUM
  For [BPA]
    If I = dim([M:CRMH]TYP)-1 Then
      Break
    Endif
    If [F:BPA]TEL(0) <> "" Then        # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      [M:CRMH]TYP(I) = 3
      [M:CRMH]NAM(I) = [F:FCY]FCYNAM
      [M:CRMH]TELTYP(I) = 1
      [M:CRMH]TEL(I) = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      [M:CRMH]ZIP(I) = [F:BPA]POSCOD
      [M:CRMH]CTY(I) = [F:BPA]CTY
      [M:CRMH]CRY(I) = [F:BPA]CRY
      I += 1
    Endif
  Next
  Filter [BPA]
Return

