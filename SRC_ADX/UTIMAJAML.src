#<AdxTL>@(#)8.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour table nouveau champ "NONTRA" dans la table AMENLOC
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE('Update "NONTRA" field on "AMENLOC" file') From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJ
Gosub MAJ1
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJ
Gosub MAJ1
End

#-------------------#
$MAJ

Local File =DOSSIER+".AMENLOC"   [AML]

If dim([F:AML]NONTRA)<0
 Close Local File [AML]
 Return
Endif

# Mise à jour de la table AMENLOC
Call ECR_TRACE(mess(81,125,1)-"AMENLOC:"-time$,0) From GESECRAN
Trbegin [AML]
 For [AML]MENLOC Where NONTRA=0
  If [F:AML]NONTRA=0
   [F:AML]NONTRA = 1
   Rewrite [AML]
   If fstat
    Call ERREUR("AMENLOC"-[F:AML]MENLOC,2) From DOSDIC
   Endif
  Endif
 Next
Commit

Close Local File [AML]

Return

#-------------------#
$MAJ1

Local File =DOSSIER+".AMENLOC"   [AML]

If dim([F:AML]NONTRA)<0
 Close Local File [AML]
 Return
Endif

Local File =DOSSIER+".APLSTD"   [AST]

# Mise à jour de la table APLSTD
Call ECR_TRACE(mess(81,125,1)-"APLSTD:"-time$,0) From GESECRAN
Trbegin [AML],[AST]
 For [AML]MENLOC Where NONTRA=2
  For [AST] Where LANCHP=[F:AML]MENLOC and LANORI<>""
   If [F:AST]LANORI<>""
    [F:AST]LANORI = ""
    Rewrite [AST]
    If fstat
     Call ERREUR("APLSTD"-[F:AML]MENLOC,2) From DOSDIC
    Endif
   Endif
  Next
 Next
Commit

Close Local File [AST]
Close Local File [AML]

Return
