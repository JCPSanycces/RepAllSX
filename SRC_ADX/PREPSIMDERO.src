#<AdxTL>@(#)3.0.0.0 $Revision$

#########################################################################################
# Programme : PREPSIMDERO                                                               #
#                                                                                       #
# Fonction  :  Programme d'init pour l'état DEPSIMUDERO                                 #                                          #
#              Maj de la table TMPSIMDERO                                               #
#    Création :  08/2012                                                                #
#########################################################################################
#    Modification :
# UUUUU jj.mm.aaaa nnnnnn_nn Cccccccccccccccccccccccccccccccccccccccccccccccccccccccc
#
# MDJ   03.02.2016 114161    Intitulés Code comptable absents (en sqlserver)
# MDJ   09/10/2012 FQ-85003  Variable [F:TDSM]FIYSTRDDAT inexistante + récupérations Intitulé
# MDJ   05/12/2012 FQ-84980  Variable GCOA remplacée par GWCOA
#########################################################################################
$ACTION

    Case ACTION
        When "OUVRE" :   Gosub OUVRE
        When "EXEC"  :   Gosub EXEC
        When "FIN"   :   Gosub FIN
    Endcase
Return
######################################################################################
$OUVRE
#=============================================================================
# traitement PREPSIMDERO : alimentation de la table TMPSIMDERO
#=============================================================================

If clalev([F:CPY])=0    :    Local File COMPANY         [CPY]   : Endif    # Sociétés
If clalev([F:FCY])=0    :    Local File FACILITY        [FCY]   : Endif    # Sites financiers
If clalev([F:CNX])=0    :    Local File CONTEXT         [CNX]   : Endif
If clalev([F:FIY])=0    :    Local File FISCYEAR        [FIY]   : Endif

If clalev([F:FAS])=0    :    Local File FXDASSETS       [FAS]   : Endif    # Immobilisations
If clalev([F:DEPC])=0   :    Local File DEPREC          [DEPC]  : Endif    # DEPREC comptable
If clalev([F:DEPF])=0   :    Local File DEPREC          [DEPF]  : Endif    # DEPREC fiscal

If clalev([F:CAC])=0    :    Local File GACCCODE        [CAC]   : Endif    # Codes comptables
If clalev([F:GACC])=0   :    Local File GACCOUNT        [GACC]  : Endif    # Comptes généraux PCG
If clalev([F:GACI])=0   :    Local File GACCOUNT        [GACI]  : Endif    # Comptes généraux IAS

If clalev([F:AFF])=0   :    Local File AFCTFCY          [AFF]  : Endif       # Profil fonction site

If clalev([F:TDS])=0    :    Local File TMPSIMDERO      [TDS]   : Endif
If clalev([F:TDSM])=0   :    Local File TMPSIMDERO      [TDSM]  : Endif

Return
######################################################################################
$FIN

Unlock PREPDERO

Return
######################################################################################
$EXEC


Lock PREPSIMDERO With lockwait = 3
If fstat
   Return
Endif

Gosub MAJ_TMPSIMDERO


Return
###################################################
$MAJ_TMPSIMDERO
#------------------------------------------------------------------------------------#
#--- Création table temporaire TMPSIMDERO pour les états s/dérogatoire               ---#
#------------------------------------------------------------------------------------#

Gosub OUVRE

    Local Integer I             # Compteur de paramètres
    Local Char LCPYDEB          # Société deb
    Local Char LCPYFIN
    Local Char LFCYDEB          # Site deb
    Local Char LFCYFIN
    Local Char LCCPTDEB         # Code comptable deb
    Local Char LCCPTFIN         # Code comptable fin
    Local Char LACCDEB          # Compte PCG deb
    Local Char LACCFIN          # Compte PCG fin
    Local Char LIASACDEB        # Compte IAS deb
    Local Char LIASACFIN        # Compte IAS fin
    Local Integer LTYPDETDEB    # Type dét deb
    Local Integer LTYPDETFIN    # Type dét  fin
    Local Integer LHORIZ        # Horizon
    Local Char    LREFDEB       # réf deb
    Local Char    LREFFIN       # réf fin
    Local Integer LENCOURS      # Encours ?
    Local Integer LACTIF        # Actif ?
    Local Integer LDET          # Détail ?
    Local Integer LEDTNUM       # Identifiant session
    Local Char    LCRITERE  (250) # Critère de sélection
    Local Char    LCRITERE2 (250) # Critère de sélection
    Local Decimal WTOTLEG
    Local Decimal WENDDPET
    Local Char    SCPY

    Local Date    ENDDATHORI   # Date fin Horizon
    Local Char    SFCY         # Site financier traité
    Local Char    X3PRF        # Code profil user
    Local Char    X3FCT        # Fonction

    Global Integer GDERO      : GDERO=G_NON
    Global Char    GWCOA         # Globale sur plan de compte

    If clalev([TDS])=0 : Local File TMPSIMDERO [TDS] : Endif

    Trbegin [TDS]
    Delete [TDS] Where CREUSR = GUSER
    If fstat = 1
      Rollback
    Else
       Commit
    Endif

   Call GETPARAM("cpydeb",NBPAR,PARAMETRE,LCPYDEB)
   Call GETPARAM("cpyfin",NBPAR,PARAMETRE,LCPYFIN)
   Call GETPARAM("fcydeb",NBPAR,PARAMETRE,LFCYDEB)
   Call GETPARAM("fcyfin",NBPAR,PARAMETRE,LFCYFIN)
   Call GETPARAM("ccptdeb",NBPAR,PARAMETRE,LCCPTDEB)
   Call GETPARAM("ccptfin",NBPAR,PARAMETRE,LCCPTFIN)
   Call GETPARAM("accdeb",NBPAR,PARAMETRE,LACCDEB)
   Call GETPARAM("accfin",NBPAR,PARAMETRE,LACCFIN)
   Call GETPARAM("accifrsdeb",NBPAR,PARAMETRE,LIASACDEB)
   Call GETPARAM("accifrsfin",NBPAR,PARAMETRE,LIASACFIN)
   Call GETPARAM("typdetdeb",NBPAR,PARAMETRE,PARAM)    : LTYPDETDEB = val(PARAM)
   Call GETPARAM("typdetfin",NBPAR,PARAMETRE,PARAM)    : LTYPDETFIN = val(PARAM)
   Call GETPARAM("horizon",NBPAR,PARAMETRE,PARAM)      : LHORIZ     = val(PARAM)
   Call GETPARAM("refdeb",NBPAR,PARAMETRE,LREFDEB)
   Call GETPARAM("reffin",NBPAR,PARAMETRE,LREFFIN)
   Call GETPARAM("encours",NBPAR,PARAMETRE,PARAM)      : LENCOURS   = val(PARAM)
   Call GETPARAM("detail",NBPAR,PARAMETRE,PARAM)       : LDET       = val(PARAM)
   Call GETPARAM("edtnum",NBPAR,PARAMETRE,PARAM)       : LEDTNUM    = val(PARAM)

   Call GETPARAM("X3PRF",NBPAR,PARAMETRE,X3PRF)
   Call GETPARAM("X3FCT",NBPAR,PARAMETRE,X3FCT)

   LCRITERE = "1=1"
   For I=1 To NBPAR
      J=instr(1,[L]PARAMETRE(I),"=")
      If J
         [L]PARAM  = left$([L]PARAMETRE(I),J-1)
         [L]VALEUR = right$([L]PARAMETRE(I),J+1)
         Case [L]PARAM
            When "cpydeb" :
                  If LCPYDEB <> ""
                     LCRITERE =    "CPY>='"+LCPYDEB+"'"
                  Else
                     LCRITERE =    "CPY<='"+LCPYFIN+"'"
                  Endif
            When "cpyfin" :
                  If LCPYDEB <> ""
                     LCRITERE += "& CPY<='"+LCPYFIN+"'"
                  Endif
            When "fcydeb"     :     LCRITERE += "& FCY>='"+LFCYDEB+"'"
            When "fcyfin"     :     LCRITERE += "& FCY<='"+LFCYFIN+"'"
            When "ccptdeb"    :     LCRITERE += "& ACCCOD>='"+LCCPTDEB+"'"
            When "ccptfin"    :     LCRITERE += "& ACCCOD<='"+LCCPTFIN+"'"
            When "accdeb"     :     LCRITERE += "& GAC>='"+LACCDEB+"'"
            When "accfin"     :     LCRITERE += "& GAC<='"+LACCFIN+"'"
            When "accifrsdeb" :     LCRITERE += "& IASACC>='"+LIASACDEB+"'"
            When "accifrsfin" :     LCRITERE += "& IASACC<='"+LIASACFIN+"'"
            When "refdeb"     :     LCRITERE += "& AASREF>='"+LREFDEB+"'"
            When "reffin"     :     LCRITERE += "& AASREF<='"+LREFFIN+"'"
            When "encours"
                  If LENCOURS=1
                     LCRITERE2 =    "GACACN <3"
                  Else
                     LCRITERE2 =    "GACACN<>1"
                  Endif
         Endcase
      Endif
   Next
#--------------------------------
   Trbegin [TDS]
   Delete [TDS] Where CREUSR = GUSER
   If fstat=0
       Commit
   Else
      Rollback
   Endif
   #--------------------------------
    #
   Trbegin [TDS]
   SCPY= ""
   SFCY= ""
   GWCOA= ""
   Filter [FAS] Where ( evalue(LCRITERE) &  evalue(LCRITERE2) )  and
&                     ( OWNTYP >= LTYPDETDEB  and OWNTYP <= LTYPDETFIN ) and
&                     ( ENAFAS=G_OUI )
   For [FAS]
      If [F:FAS]CPY <> SCPY
         # Lecture contexte FISCAL & COMPTABLE
         Read [CNX] CNX0= [F:FAS]CPY;G300CPFI
         If fstat=0
            I_COA = find(G301CPT,[F:CNX]PLNCAA(0..[F:CNX]NBPLC-1))
            If I_COA > 0
               GWCOA= [F:CNX]COA(I_COA-1)
            Endif
         Endif
         # Lecture exercice courant FISCAL & COMPTABLE
         Filter [FIY] Where CPY=[F:FAS]CPY and CNX = G300CPFI and STAFIY=2
         Read [FIY]First
         Filter [FIY]
         SCPY= [F:FAS]CPY
         # Calcul de la date de fin horizon à partir de la valeur du paramètre horizon
         ENDDATHORI = gdat$ (day([F:FIY]DATENDFIY), month([F:FIY]DATENDFIY), year([F:FIY]DATENDFIY)+LHORIZ-1)
      Endif
      If [F:FAS]FCY <> SFCY
         Read [AFF]AFF0 = [F:FAS]FCY;X3PRF;X3FCT
         If fstat <> 0
            Goto NEXTFAS
         Endif
         SFCY= [F:FAS]FCY
      Endif
      #1------------
      Raz[TDSM]
      [F:TDSM] = [F:FAS]
       If [F:TDSM]EXTISSFLG = 0
          [F:TDSM]EXTISSFLG = G_NON
       Endif
      [F:TDSM]COA = GWCOA
      #=========================================================
      # Récupération des intitulés des champs
      #=========================================================
      Read [CPY]CPY0    = [F:FAS]CPY
      If fstat=0 :     [F:TDSM]CPYNAM    = [F:CPY]CPYNAM  : Endif
      Read [FCY]FCY0    = [F:FAS]FCY
      If fstat=0 :     [F:TDSM]FCYNAM    = [F:FCY]FCYNAM : Endif
      [F:TDSM]AASDES1   = [F:FAS]AASDES1
      #FQ-85003 Read[CAC]CAC0="15";[F:FAS]ACCCOD;GWCOA
      Read[CAC]CAC0=15;[F:FAS]ACCCOD;GWCOA
      If fstat=0
         Call LECTEXTRA([F:TDSM]ACCDES,"GACCCODE","DESTRA","15",[F:FAS]ACCCOD) From ATEXTRA
         # Issue 114161 [F:TDSM]ACCDES=[F:CAC]DESTRA
      Endif
      Read[GACC]GAC0=GWCOA;[F:FAS]GAC
      If fstat=0
         Call LECTEXTRA([F:TDSM]GACDES,"GACCOUNT","DESTRA",GWCOA,[F:FAS]GAC) From ATEXTRA
      Endif
      Read[GACI]GAC0=GWCOA;[F:FAS]IASACC
      If fstat=0
         Call LECTEXTRA([F:TDSM]IASACCDES,"GACCOUNT","DESTRA",GWCOA,[F:FAS]IASACC) From ATEXTRA
      Endif
      Read[DSP]DSP0=[F:FAS]DSP;1
      If fstat=0
       [F:TDSM]DSPDES = [F:DSP]DESTRA
      Endif
      [F:TDSM]HORIZON = LHORIZ
      [F:TDSM]ENDDATHORI = ENDDATHORI
      #=========================================================
      GDERO=G_NON
    #========================================================
    # Récupération des infos en provenance du plan comptable
    #========================================================
    #----- Exercice -----
     Filter [DEPC] Where ( CPY=[F:FAS]CPY    & AASREF=[F:FAS]AASREF & DPRPLN=G301CPT         &
&                          FIYENDDAT >= [F:FIY]DATSTRFIY & FIYENDDAT <= ENDDATHORI & STRDPRDAT<=ENDDATHORI )
        For[DEPC]DEP0
           If [F:DEPC]PERENDDAT <> [F:DEPC]FIYENDDAT
              Goto NEXTDEP
           Endif
           WTOTLEG = 0
           WTOTLEG =  [F:DEPC]LEG
           WTOTLEG += [F:DEPC]LEGRVE
           WTOTLEG += [F:DEPC]LEGCUM
           WTOTLEG += [F:DEPC]LEGRVECUM
           WTOTLEG += [F:DEPC]PERLEGCUM
           WTOTLEG += [F:DEPC]PERLEGRVE
           WTOTLEG += [F:DEPC]LEGRVECUM
           If WTOTLEG <> 0
              GDERO=G_OUI
              Gosub CHARGE_TDSM_EXE_CPT
           Else
              GDERO=G_NON
           Endif
           #========================================================
           # Récupération des infos en provenance du plan fiscal
           #========================================================
           If GDERO=G_OUI
              #----- Exercice ----- )
            Read[DEPF]DEP0=[F:FAS]AASREF;G301FIS;[F:DEPC]FIYENDDAT; [F:DEPC]PERENDDAT
            If fstat=0
                Gosub CHARGE_TDSM_EXE_FIS
            Endif
            If [F:FAS]ISSDAT > [0/0/0] and [F:FAS]ISSDAT >= [F:TDSM]FIYSTRDATF and [F:FAS]EXTISSFLG <> G_OUI
               If [F:DEPC]NBV >= [F:DEPF]NBV
                 [F:TDSM]REPSOR =  [F:DEPC]NBV - [F:DEPF]NBV
               Endif
            Endif
            If [F:FAS]ISSDAT >= [F:TDSM]FIYSTRDATC and [F:FAS]ISSDAT <= [F:TDSM]FIYENDDATC and [F:FAS]EXTISSFLG <> G_OUI
               [F:TDSM]SOLFINEX = 0
            Else
               [F:TDSM]SOLFINEX  = [F:TDSM]SOLDEBEX + ([F:TDSM]PROVISION - [F:TDSM]REPRISE)
            Endif
            [F:TDS]=[F:TDSM]
            [F:TDS]EDTNUM = LEDTNUM
            [F:TDS]CREUSR = GUSER
            [F:TDS]CREDAT = date$
            If ([F:TDS]ISSDAT > [0/0/0] and [F:TDS]ISSDAT < [F:TDS]FIYSTRDATF) and  ([F:FAS]EXTISSFLG <> G_OUI)
               Goto NEXTDEP
            Endif
            Write [F:TDS]
            If fstat <> 0
               GOK=0
               Rollback
               #Infbox("Impossible de lancer l'état. Erreur d'écriture sur le fichier de travail !")
            Else
               Commit
            Unlock[TDS]
         Endif
         #1------------
      Endif
      $NEXTDEP
    Next
    Filter[DEPC]
   $NEXTFAS
   Next
   Filter[FAS]

If GDERO=G_NON : Rollback : Return : Endif
Commit
Unlock PREPSIMDERO

Return
######################################################################################
$CHARGE_TDSM_EXE_CPT

             #*Fq-85003 [F:TDSM]FIYSTRDDAT   = [F:DEPC]FIYSTRDAT
             [F:TDSM]FIYSTRDAT   = [F:DEPC]FIYSTRDAT
             [F:TDSM]FIYENDDAT    = [F:DEPC]FIYENDDAT
             [F:TDSM]PERENDDAT    = [F:DEPC]PERENDDAT
             [F:TDSM]FIYENDDATC   = [F:DEPC]FIYENDDAT
             [F:TDSM]STRDPRDATC   = [F:DEPC]STRDPRDAT
             [F:TDSM]ENDDPRDATC   = [F:DEPC]ENDDPRDAT
             [F:TDSM]FIYSTRDATC   = [F:FIY]DATSTRFIY
             [F:TDSM]DPRBASC      = [F:DEPC]DPRBAS
             [F:TDSM]DPRCUMC      = [F:DEPC]DPRCUM
             [F:TDSM]DPMC         = [F:DEPC]DPM
             [F:TDSM]DPRRATC      = [F:DEPC]DPRRAT
             [F:TDSM]DPRDURC      = [F:DEPC]DPRDUR
             [F:TDSM]PERCLOCUMC   = [F:DEPC]PERCLOCUM
             [F:TDSM]PERENDDPEC   = [F:DEPC]PERENDDPE
             [F:TDSM]ENDDPEC      = [F:DEPC]ENDDPE
             [F:TDSM]DOTCPT       = [F:DEPC]ENDDPE
             [F:TDSM]DPETC        = [F:DEPC]DPET
             [F:TDSM]EXCDPRC      = [F:DEPC]EXCDPR
             [F:TDSM]FLGUPDISSC   = [F:DEPC]FLGUPDISS
             [F:TDSM]DATISSPSTC   = [F:FAS]DATISSPST
             [F:TDSM]NBVC         = [F:DEPC]NBV
             [F:TDSM]LEG          = [F:DEPC]LEG
             [F:TDSM]PERLEGCUM    = [F:DEPC]PERLEGCUM
             [F:TDSM]PERLEGRVE    = [F:DEPC]PERLEGRVE
             [F:TDSM]LEGCUMC      = [F:DEPC]LEGCUM
             [F:TDSM]LEGRVECUMC   = [F:DEPC]LEGRVECUM
             [F:TDSM]PROVISION    = [F:DEPC]LEG    + [F:DEPC]PERLEGCUM
             [F:TDSM]REPRISE      = [F:DEPC]LEGRVE + [F:DEPC]PERLEGRVE
             [F:TDSM]SOLDEBEX     = [F:DEPC]LEGCUM + [F:DEPC]LEGRVECUM



Return
#
######################################################################################
$CHARGE_TDSM_EXE_FIS

             If [F:DEPF]ENDDPRDAT >=[F:TDSM]ENDDPRDATC
                [F:TDSM]FIYSTRDAT = [F:DEPF]FIYSTRDAT
             Endif
             [F:TDSM]STRDPRDATF   = [F:DEPF]STRDPRDAT
             [F:TDSM]ENDDPRDATF   = [F:DEPF]ENDDPRDAT
             [F:TDSM]FIYSTRDATF   = [F:DEPF]FIYSTRDAT
             [F:TDSM]FIYENDDATF   = [F:DEPF]FIYENDDAT
             [F:TDSM]DPRBASF      = [F:DEPF]DPRBAS
             [F:TDSM]DPRCUMF      = [F:DEPF]DPRCUM
             [F:TDSM]DPMF         = [F:DEPF]DPM
             [F:TDSM]DPRRATF      = [F:DEPF]DPRRAT
             [F:TDSM]DPRDURF      = [F:DEPF]DPRDUR
             [F:TDSM]PERCLOCUMF   = [F:DEPF]PERCLOCUM
             [F:TDSM]PERENDDPEF   = [F:DEPF]PERENDDPE
             [F:TDSM]ENDDPEF      = [F:DEPF]ENDDPE
             [F:TDSM]DOTFI        = [F:DEPF]ENDDPE + [F:DEPF]EXCDPR
             [F:TDSM]DPETF        = [F:DEPF]DPET
             [F:TDSM]EXCDPRF      = [F:DEPF]EXCDPR
             [F:TDSM]FLGUPDISSF   = [F:DEPF]FLGUPDISS
             [F:TDSM]DATISSPSTF   = [F:FAS]DATISSPST
             [F:TDSM]NBVF         = [F:DEPF]NBV

Return
######################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
End
####################################################
#================================================================
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L

   Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
   L = len(PARAM)
   If right$(PARAM,L-2)="deb"
      If VALEUR=string$(len(VALEUR)," ")
          VALEUR = ""
      Endif
   Endif

End
####################################################

