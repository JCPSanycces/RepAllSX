#<AdxTL>@(#)1.0.0.0 $Revision$
####################################################################################
# Program Name: VXAIT
# Description : ADC Intersite Transfer
# Author      : Deutschbauer/Bromley
# Date        : April 17th, 2006
####################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)

Call SAISIE_CHAR(VALEUR,PARAM,"XAIT","XAIT","XWVXAIT") From GSAISIE
End

########################################################
# Intersite Transfer - Stock Change
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# STOFCY, FCYDES, ITMREF,
# PCU, QTYPCU, STU, QTYSTUDES, PCUSTUCOE
# STA, LOC, LOT, SLO, PALNUM, CTRNUM, SERNUM, SERNUMF
# STADES, LOCDES, LOCTYPDES
# PCUDES, COEDES, QTYPCUDES
# WSTOSEQ, WLOCSEQ

# Necessary value in Entry transaction
# ------------------------------------
# Field 'Movement type'  --> Inter-site
# Field 'Form'           --> No print
#
# VXAIT is the VT screen
#
########################################################

########################################################
$ACTION

#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "AVANT_OK"      : Gosub AVANT_OK
 When "OK"            : Gosub OK
 When "BOUTON"        : Gosub BOUTON
 When "END"           : Gosub CHECK
 When "FIN"           : Gosub FIN
Endcase

Return

########################################################
# Actions liées à la fenètre de saisie
########################################################

########################################################
$OUVRE

GVTMOD=1

# Initialisation du site de stock
Gosub INIT_STOFCY From ENVADC
Local Integer TUNNEL            #--- Lot V01
Gosub OUVRE_SCS From ENVADC

Return

########################################################
$DEBUT

Local Integer WOK, WCPT

# GFLAG contains the stock change transaction
GFLAG = func ENVADC.SETTRANS(4)

[M:XAIT]SRTNUM = GFLAG

Gosub DEBUT_SCS From ENVADC

Gosub INIT_SCREEN

If GXAFCY=""
   Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN = 1 : Return
Endif

Return

########################################################
$SETBOUT

If !find("O",CHBOU) CHBOU+="O" Endif
If !find("1",CHMEN) CHMEN+="1" Endif

Return

########################################################
$APRES_MODIF

Gosub APRES_MODIF_SCS From ENVADC

Return

########################################################
$AVANT_OK

If [M:XAIT]ITMREF="" | [M:XAIT]PCU="" | [M:XAIT]QTYPCU<=0
   GMESSAGE=mess(17,7750,1)
Else
   Gosub AVANT_OK_SCS From ENVADC
   If LRET=1
      GMESSAGE=mess(21,7750,1) # "No stock corresponding to the entry"
   Elsif LRET=2
      GMESSAGE=mess(20,7750,1) # "Quantity greater than the available stock"
   Elsif LRET=3
      GMESSAGE=mess(19,7750,1) # "Stock with quality control"
   Elsif LRET=4
      GMESSAGE=mess(18,7750,1) # "No change: location, status and unit are the same"
   Endif
Endif

If GMESSAGE <> ""
   GERR=1 : FIN=0
   zonsui="[M:XAIT]ITMREF" : Return
Endif

Return

########################################################
$OK

Gosub OK_SCS From ENVADC

If LRET<>0
   GERR=1 : GMESSAGE=mess(12,7750,1) : zonsui="[M:XAIT]ITMREF" : Return
Endif

[L]WCPT = [M:XAIT]WCPT
Effzo [M:XAIT]1-99
[M:XAIT]WCPT   = [L]WCPT+1
[M:XAIT]STOFCY = [M:SCS1]STOFCY
[M:XAIT]FCYDES = [M:SCS1]FCYDES   # hcb 100730
[M:XAIT]SRTNUM = GFLAG
Affzo [M:XAIT]1-99

zonsui="[M:XAIT]ITMREF"

Return

########################################################
$BOUTON

# Création
If BOUT="1" Gosub CRE Endif
# Abandon
If BOUT="2" Gosub ABA Endif

Return

########################################################
$ABA
# Issue 110327
If [M:SCS1]NBLIG >0
  Call DELSTOCHGW("SCS1",[M:SCS1]STOFCY,-1,-1,1,LRET) From SUBSCSB
Else
  Call RAZSTOCHGW From SUBSCSB
Endif
# End Issue 110327 - 2016-09-13 by MAE
Gosub INIT_SCREEN
GREP = ""
zonsui = "[M:XAIT]ITMREF"

Return

########################################################
$CRE

# Si article renseigné, enregistrement de la saisie (bouton OK)
If [M:XAIT]ITMREF<>""
   Gosub AVANT_OK
   If GERR=1 Return Endif
   Gosub OK
   If GERR=1 Return Endif
Endif

If [M:SCS1]NBLIG=0
   Call ERREUR(mess(17,7750,1)) From GESECRAN
   zonsui="[M:XAIT]ITMREF" : Return
Endif

Call CRE_SCS From ENVADC
#--- Lot V01
#-----impression des étiquettes ----#
If [F:SRT]PRNCOD1 = 2
   Call PRINT_ETI([M:SCS1]FCYDES ,[M:SCS1]VCRTYP,[M:SCS1]VCRNUM) From STKADC
Endif

GPROGRAMME = "GSAISIE"
GBOITE     = BOITE
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From= WINPROG
GREP="" : REP=""
GNOLIG = 0

Gosub INIT_SCREEN

GREP = ""
# Issue 102210 - 2014-08-28 by SR : Se positionner sur le site
#zonsui = "[M:XAIT]ITMREF"
zonsui = "[M:XAIT]FCYDES"

Return

########################################################
$CHECK

If [M:SCS1]NBLIG<>0
   WOK=1
   # Pièce en cours de saisie non enregistrée
   Call OUINON(mess(38,7750,1),WOK) From GESECRAN
   If WOK<>2
      FIN=0 : zonsui="[M:XAIT]ITMREF" : Return
   Endif
Endif

Return
########################################################
$FIN

Gosub FIN_SCS From ENVADC

GVTMOD=0

Return

########################################################
$INIT_SCREEN

Raz [M:SCS1]

# [M:SCS1]IPTDAT contains the date
# [M:SCS1]STOFCY contains the site
[M:SCS1]IPTDAT = date$
[M:SCS1]STOFCY = GXAFCY

Raz [M:XAIT]

Gosub INIT_SCS From ENVADC

# Chargement du paramétrage lié au site
If GFCY<>[M:SCS1]STOFCY
   GFCY=[M:SCS1]STOFCY
   Gosub CHARG_PARAM From SUBSCSA
Endif

Affzo [M:XAIT]1-99

Return

########################################################
# Actions champs
########################################################

