########################################################
Subprog C_FCYDES(VALEUR)
Variable Char    VALEUR()

Local Char WLIB(30)

# Destination site must be different than source site
If VALEUR=[M:SCS1]STOFCY : mkstat=2 : End : Endif

If clalev([F:FCY1])=0 : Local File FACILITY [FCY1] : Endif
Read [FCY1]FCY1 = [F:FCY]LEGCPY;[M:SCS1]STOFCY
# Inter-société
If fstat
  Local Char WFINFCY(GLONFCY)
  Local Char WLEGFCY(GLONCPY)
  [M:SCS1]BETCPY = 2
  Raz [F:FCY1]
  Read [FCY1]FCY0 = [M:SCS1]STOFCY
  If !fstat & [F:FCY1]SALFLG<>2
    WLEGCPY = [F:FCY1]LEGCPY
    Read [FCY1]FCY0 = [F:FCY1]FINRSPFCY
    If !fstat & [F:FCY1]SALFLG<>2
      WFINFCY=[F:FCY1]FCY
      Filter [FCY1] Where FINRSPFCY=WFINFCY & SALFLG=2
      Read [FCY1]FCY0 First
      Filter [FCY1]
      If fstat
        Filter [FCY1] Where LEGCPY=WLEGCPY & SALFLG=2
        Read [FCY1]FCY1 First
        Filter [FCY1]
      Endif
    Endif
  Endif
  If fstat
    # Pas de site de vente dans cette société
    Call TEXTE(1720,WLIB) From OBJDIV
    GMESSAGE=WLIB-":"-[M:SCS1]STOFCY-"\"+mess(132,184,1)-":"-WLEGCPY
    mkstat=2 : End
  Else
    # Alimentation site de vente
    [M:SCS1]SALFCY = [F:FCY1]FCY
    [M:SCS1]INVSGH = 2
    # Alimentation site d'achat
    If [F:FCY]PURFLG=2
      [M:SCS1]PURFCY=VALEUR
    Else
      Filter [FCY1] Where LEGCPY=[F:FCY]LEGCPY & PURFLG=2
      Read [FCY1]FCY1 First
      Filter [FCY1]
      If fstat
        # Pas de site d'achat dans cette société
        Call TEXTE(18038,WLIB) From OBJDIV
        GMESSAGE=WLIB-":"-VALEUR-"\"+mess(133,184,1)-":"-[F:FCY]LEGCPY
        mkstat=2 : End
      Else
        [M:SCS1]PURFCY=[F:FCY1]FCY
      Endif
    Endif
  Endif
# Intra-société
Else
  [M:SCS1]BETCPY = 1
  Raz [M:SCS1]SALFCY,PURFCY
  [M:SCS1]INVSGH = 1
Endif
[M:SGW]FCYDES = VALEUR

End

##########################################################################
Subprog AM_FCYDES(VALEUR)
Variable Char    VALEUR()

Local Char    LSEC
Local Integer I

[M:SCS1]FCYADD = [F:FCY]BPAADD

# Récupération de la société
[M:SCS1]CPYDES = [F:FCY]LEGCPY
# Récupération des devises
Call GETDEV(VALEUR) From DEVSUB
[M:SCS1]CURDES = GLOCALDEV
Call GETDEV([M:SCS1]STOFCY) From DEVSUB    # Pour positionner glocaldev
If [M:SCS1]BETCPY<>2
   Raz [M:SCS1]PRI
Endif

# Initialisation des sections ana
# doit être fait en am_fcydes car des sections peuvent être fonction du site
[M:SCS1]FCYDES=VALEUR
For I=1 To GNBDIE
    If dim([M:SCS1]CCE)>0
        If [M:SCS1]BETCPY=2
            Call INISEC (LSEC, "ICOH", I) From TRTX3CPT
        Else
            Call INISEC (LSEC, "TRSH", I) From TRTX3CPT
        Endif
        [M:SCS1]CCE(I-1) = LSEC
    Else
        Break
    Endif
Next

End

######################################################################################
# Issue 110327
######################################################################################
## Etiquette ajoutée par le superviseur (écran VXAIT) 07/03/2017 09:08:23 (MAE)
######################################################################################
Subprog IB_SERNUM
#si l'article est géré en entrée sortie globale, la sélection sur le numéro de série est particulière
If [F:ITM]SERMGTCOD < 4
  Raz GBOUT2
Else
  Raz GBOUT1
Endif
End
# End issue 110327


