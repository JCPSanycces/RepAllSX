End

########################################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
# Issue 110327
Local    Char    LSERF(GLONSER)
Local    Decimal LQTYF
Local    Integer J, WRET, WNBSERIE, PNOL
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER), PABR(GLONABR)


If !clalev([F:STO2])  Local File STOCK  [STO2]  Endif
Raz [M]SERNUMF
If VALEUR="" : Return : Endif
# End issue 110327

If [F:ITM]SERMGTCOD <>4 # Issue 110327
  Read [STO]STO5=[M:XAIT]ITMREF;VALEUR
  If fstat
    mkstat=2
  Else
    If dim([M:XAIT]LOT)>0    : [M:XAIT]LOT=[F:STO]LOT       : Endif
    If dim([M:XAIT]SLO)>0    : [M:XAIT]SLO=[F:STO]SLO       : Endif
    If dim([M:XAIT]PALNUM)>0 : [M:XAIT]PALNUM=[F:STO]PALNUM : Endif
    If dim([M:XAIT]CTRNUM)>0 : [M:XAIT]CTRNUM=[F:STO]CTRNUM : Endif
    [M:XAIT]STA=[F:STO]STA
    If [M:XAIT]STADES=""     : [M:XAIT]STADES=[M:XAIT]STA   : Endif
    If dim([M:XAIT]LOC)>0    : [M:XAIT]LOC=[F:STO]LOC       : Endif
    [M:XAIT]PCU       = [F:STO]PCU
    [M:XAIT]QTYPCU    = 1
    [M:XAIT]PCUSTUCOE = 1
    [M:XAIT]PCU       = [F:STO]PCU
    [M:XAIT]PCUDES    = [M:XAIT]PCU
    [M:XAIT]COEDES    = [M:XAIT]PCUSTUCOE
    [M:XAIT]QTYPCUDES = [M:XAIT]QTYPCU
    Affzo [M:XAIT]1-99
  Endif
# Issue 110327
Else
# Issue 110327 - 2016-09-02 by MAE : Gestion des numéros de série globaux
  Read [STS]STS0=[M]ITMREF;VALEUR
    If !fstat
       Read [STO2]STO0=[M]STOFCY;[F:STS]STOCOU
       If dim([M:XAIT]LOT)>0   : [M:XAIT]LOT = [F:STO2]LOT  : Endif
       If dim([M:XAIT]SLO)>0   : [M:XAIT]SLO = [F:STO2]SLO  : Endif
       If dim([M:XAIT]LOC)>0   : [M:XAIT]LOC = [F:STO2]LOC  : Endif
       [M:XAIT]STA = [F:STO2]STA
       If [M:XAIT]STADES=""    : [M:XAIT]STADES=[M:XAIT]STA : Endif
       [M:XAIT]PCU       = [F:STO2]PCU
       [M:XAIT]PCUSTUCOE = 1
       [M:XAIT]PCUDES    = [M:XAIT]PCU
       [M:XAIT]COEDES    = [M:XAIT]PCUSTUCOE
       [M:XAIT]QTYPCUDES = [M:XAIT]QTYPCU
      Affzo [M:XAIT]1-99
     Endif

  #Détermination numéro de série fin
  # Issue 110327
  If [M:XAIT]QTYPCU=1
    [M:XAIT]SERNUMF = VALEUR
  Else
    # Vérification que les no série existent et sont disponibles
    # et alimentation du no série fin
    WNBSERIE = [M:XAIT]QTYPCU
    WNUMDEB  = VALEUR
    For J=2 To WNBSERIE
       Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
       If WRET=0
          #controle sur le numéro de série fin
          Read [STS]STS0=[M:XAIT]ITMREF;WNUMFIN
          If fstat
            GMESSAGE=WNUMFIN-":"-mess(43,196,1) # numéro de série inexistant
            mkstat = 2: Break
          Endif
          If [F:STS]ISSDAT<>[0/0/0]
            GMESSAGE=VALEUR-":"-mess(37,184,1)  # numéro de série sorti par une autre piece
            mkstat=2 : Break
          Endif
          If [F:STS]SDHNUM<>""
            GMESSAGE=VALEUR-":"-mess(443,184,1) # numero de série alloué par une autre piece
            mkstat=2 :  Break
          Endif
          WRET = func STKLIB.REC_STOSERW([M:XAIT]ITMREF,WNUMFIN)
          If WRET = 1
            GMESSAGE=WNUMFIN-":"-mess(449,184,1)  # numero de série en cours de traitement
            mkstat=2 : Break
          Endif
          WNUMDEB = WNUMFIN
       Else
          GMESSAGE=WNUMDEB-":"-mess(476,197,1) # erreur sur incrementation des numéros de serie
          mkstat=2 : Break
       Endif
    Next J
    If mkstat=2
      End
    Endif
    [M:XAIT]SERNUMF = WNUMFIN
  Endif
Endif
  # End issue 110327
End

