End

##########################################################################################################
# enlève le caractère * à la find'une chaine
Subprog VIRE_ASTERIX_END(SZVALEUR)
Variable Char SZVALEUR()

Local Char SZCHAINE(100)
Local Char SZCHAR

  Raz SZCHAINE
  Raz SZCHAR
  SZCHAINE = vireblc (SZVALEUR, 1)
  SZCHAR = right$ (SZCHAINE, len(SZCHAINE))
  If SZCHAR = "*" Then
    SZVALEUR = left$ (SZCHAINE, len(SZCHAINE)-1)
  Endif
End

##########################################################################################################
#Converti une chaine en tableau en utilisant ";" comme séparateur
Subprog CRMTOKEN (SZCHAINE, SZTABRESULT, INBTABRESULT, SZMESSAGE, IBRETOUR)
Value Char SZCHAINE
Variable Char SZTABRESULT
Variable Integer INBTABRESULT
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Integer IBCONTINUE
Local Integer IPOS
Local Char SZWORK
Local Char SZTABLE

  Raz SZTABRESULT
  INBTABRESULT = 0
  Raz SZMESSAGE
  IBRETOUR = 1
  IBCONTINUE = 1
  IPOS = 0
  SZWORK = SZCHAINE
  Raz SZTABLE
  While IBCONTINUE = 1
    IPOS = instr(0, SZWORK, ";")
    If IPOS > 0 Then
      SZTABLE= left$(SZWORK, IPOS-1)
    Else
      SZTABLE = SZWORK
      IBCONTINUE = 0
    Endif
    If SZTABLE <> "" Then
      SZTABRESULT(INBTABRESULT) = SZTABLE
      INBTABRESULT = INBTABRESULT + 1
    Endif
    If INBTABRESULT > dim(SZTABRESULT) Then
      Break
    Endif
    If IBCONTINUE = 0 Then
      Break
    Endif
    If IPOS > 0 Then
      SZWORK = right$(SZWORK, IPOS+1)
    Endif
  Wend
End

##########################################################################################################
# converti une date en date interne
Subprog CONVDI(DATEX,DATI)
Value Date DATEX
Variable Char DATI

Local Integer AN, MOIS, JMOIS

  AN = year(DATEX)
  MOIS = month(DATEX)
  JMOIS = day(DATEX)
  DATI = num$(AN) + format$("N0:##", MOIS) + format$("N0:##", JMOIS)
End

##########################################################################################################
# converti une date interne  en date
Subprog CONVID(DATI,DATEX)
Value Char DATI
Variable Date DATEX

Local Integer AN,MOIS,JMOIS

  AN = val(left$(DATI,4))
  MOIS = val(mid$(DATI,5,2))
  JMOIS = val(mid$(DATI,7,2))
  DATEX = gdat$(JMOIS, MOIS, AN)
End

##########################################################################################################
Subprog DAY_ADD_DURE( DTDATEDEB, HMHOURDEB, INBDAY, INBHOUR, INBMIN, DTDATERES, HMHOURRES, SZMESSAGE, IBRETOUR)
Value Date DTDATEDEB
Value Char HMHOURDEB
Value Integer INBDAY
Value Integer INBHOUR
Value Integer INBMIN
Variable Date DTDATERES
Variable Char HMHOURRES
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Integer INBDAYDEB
Local Integer INBHOURDEB
Local Integer INBMINDEB
Local Integer INBMINTOT
Local Integer INBHEURE
Local Integer INBMINUTE
Local Integer INBMINDAY
Local Char SZHEURE
Local Char SZMINUTE

  Raz SZMESSAGE
  IBRETOUR = 1

  INBDAYDEB = 0
  INBHOURDEB = 0
  INBMINDEB = 0
  INBMINTOT = 0
  INBMINTOT = 0
  INBHEURE = 0
  INBMINUTE = 0
  Raz SZHEURE
  Raz SZMINUTE
  If DTDATEDEB <> [00/00/00] Then
    INBDAYDEB = nday(DTDATEDEB)
  Endif
  If HMHOURDEB <> "" Then
    INBHOURDEB = val(left$(HMHOURDEB, 2))
    INBMINDEB = val(right$(HMHOURDEB, 3))
  Else
    INBHOURDEB = 0
    INBMINDEB = 0
  Endif

  #On a le nombre de minutes depuis le 1/1/1600
  INBMINTOT = (INBDAYDEB*24*60) + (INBHOURDEB*60) + INBMINDEB

  #On rajoute la durée
  INBMINTOT = INBMINTOT + (INBDAY*24*60) + (INBHOUR*60) + INBMIN

  #Nombre de jour
  INBDAYTOT = int(INBMINTOT/(24*60))

  #Nombre de minutes (heures comprises)
  INBMINDAY = INBMINTOT - (INBDAYTOT*24*60)

  #Nombre d'heure
  INBHEURE = int(INBMINDAY/60)
  If len( num$(INBHEURE)) = 1 Then
    SZHEURE = "0" + num$(INBHEURE)
  Else
    SZHEURE = num$(INBHEURE)
  Endif

  #Nombre de minutes
  INBMIN = INBMINDAY - (INBHEURE*60)
  If len(num$(INBMIN)) = 1 Then
    SZMINUTE = "0" + num$(INBMIN)
  Else
    SZMINUTE = num$(INBMIN)
  Endif

  #Nouvelle heure
  HMHOURRES = SZHEURE + SZMINUTE

  #Nouveau jour
  DTDATERES = nday$(INBDAYTOT)
End

##########################################################################################################
#Vérifie la coherence entre une date/hour début et une date/heure fin
# IBRETOUR à 1 si ok
# IBRETOUR à 0 sinon et SZMESSAGE contient le message
Subprog VERDATEDEBFIN (DTDATEDEB, HMHOURDEB,  DTDATEFIN, HMHOURFIN,  SZMESSAGE, IBRETOUR)
Value Date DTDATEDEB
Value Char HMHOURDEB
Value Date DTDATEFIN
Value Char HMHOURFIN
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Integer INBDAY
Local Integer INBHOUR
Local Integer INBMIN
Local Integer INBTOTDEB
Local Integer INBTOTFIN

  Raz SZMESSAGE
  IBRETOUR = 1

  INBDAY = 0
  INBHOUR = 0
  INBMIN = 0
  INBTOTDEB = 0
  INBTOTFIN = 0
  #Normalement les dates ont été vérifiées avant et sont nonnul
  If DTDATEDEB > DTDATEFIN Then
    #Erreur : la date de début doit être inférieur à la date de fin.
    SZMESSAGE = mess(489,177,1)
    IBRETOUR = 0
    End
  Endif

  #date /heure début
  INBDAY = nday(DTDATEDEB)
  If HMHOURDEB <> "" Then
    INBHOUR = val(left$(HMHOURDEB, 2))
    INBMIN = val(right$(HMHOURDEB, 3))
  Else
    INBHOUR = 0
    INBMIN = 0
  Endif

  #On a le nombre de minutes depuis le 1/1/1600
  INBTOTDEB = (INBDAY*24*60) + (INBHOUR*60) + INBMIN

  #date /heure fin
  INBDAY = nday(DTDATEFIN)
  If HMHOURFIN <> "" Then
    INBHOUR = val(left$(HMHOURFIN, 2))
    INBMIN = val(right$(HMHOURFIN, 3))
  Else
    INBHOUR = 0
    INBMIN = 0
  Endif

  #On a le nombre de minutes depuis le 1/1/1600
  INBTOTFIN = (INBDAY*24*60) + (INBHOUR*60) + INBMIN
  If INBTOTFIN < INBTOTDEB Then
    #Erreur : La date et heure de fin est inférieure à la date et heure de début.
    SZMESSAGE = mess(514,177,1)
    IBRETOUR = 0
    End
  Endif
End

##########################################################################################################
# Enlève les caractères retour ligne en début de paragraphe
# ------------------------------------------------------------
Subprog TRIMDEBPARA (LBCLOB)
Variable Clbfile  LBCLOB

Local Integer IBCONTINUE
Local Char SZCHAR

  IBCONTINUE = 1
  Raz SZCHAR
  While IBCONTINUE = 1
    SZCHAR = left$(LBCLOB, 1)
    If SZCHAR = chr$(13) or SZCHAR = chr$(10) Then
      LBCLOB = right$(LBCLOB, 2)
    Else
      IBCONTINUE = 0
      Break
    Endif
  Wend
End

##########################################################################################################
# Enlève les caractères retour ligne en fin de paragraphe
# ------------------------------------------------------------
Subprog TRIMFINPARA (LBCLOB)
Variable Clbfile  LBCLOB

Local Char SZCHAR
Local Integer IBCONTINUE

  IBCONTINUE = 1
  Raz SZCHAR
  While IBCONTINUE = 1
    SZCHAR = right$(LBCLOB, len(LBCLOB))
    If SZCHAR = chr$(13) or SZCHAR = chr$(10) Then
      LBCLOB = left$(LBCLOB, len(LBCLOB)-1)
    Else
      IBCONTINUE = 0
      Break
    Endif
  Wend
End

##########################################################################################################
# Vérifie si le couple objet\code est correct
# ------------------------------------------------------------
Subprog VERIFOBJCODE (SZOBJET, SZCTRL, SZCODE, SZMESSAGE, IBRETOUR)
Value Char SZOBJET
Value Char SZCTRL
Value Char SZCODE
Variable Char SZMESSAGE
Variable Integer IBRETOUR

  IBRETOUR = 1
  If SZOBJET = "" or SZCODE = "" Then
    End
  Endif
  Case SZOBJET
    When "SRE"
      #Demande de service
      If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
      Read [SRE]SRE0=SZCODE
    When "OMM"
      #Publipostage
      If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
      Read [OMM]OMM0=SZCODE
    When "OMP"
      #Campagne d'appels
      If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
      Read [OMP]OMP0=SZCODE
    When "OMT"
      #Salons professionnels
      If !clalev([F:OMT]) : Local File TRADESHOW [OMT] : Endif
      Read [OMT]OMT0=SZCODE
    When "OMN"
      #Campagne presse
      If !clalev([F:OMN]) : Local File MEDIA [OMN] : Endif
      Read [OMN]OMN0=SZCODE
    When "CMG"
      #Campagne marketing
      If !clalev([F:CMG]) : Local File CMARKETING [CMG] : Endif
      Read [CMG]CMG0=SZCODE
    When "OPP"
      #Affaire
      If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
      Read [OPP]OPP0=SZCODE
  Endcase
  If fstat <> 0 Then
    #Numéro de pièce incorrect
    SZMESSAGE = mess(525,177,1)
    IBRETOUR = 0
  Else
    # FGR 20/01/2009 : X3SUIVI33671 : controle la compatibilité du site
    Case SZOBJET
      When "SRE"
        #Demande de service
        If [F:SRE]SALFCY <> SZCTRL and [F:SRE]SALFCY <> "" Then
          SZMESSAGE = mess(616,177,1)
          IBRETOUR = 0
        Endif
      When "OMM"
        #Publipostage
        If [F:OMM]FCY <> SZCTRL and [F:OMM]FCY <> "" Then
          SZMESSAGE = mess(616,177,1)
          IBRETOUR = 0
        Endif
      When "OMP"
        #Campagne d'appels
        If [F:OMP]FCY <> SZCTRL and [F:OMP]FCY <> "" Then
          SZMESSAGE = mess(616,177,1)
          IBRETOUR = 0
        Endif
      When "OMT"
        #Salons professionnels
        If [F:OMT]FCY <> SZCTRL and [F:OMT]FCY <> "" Then
          SZMESSAGE = mess(616,177,1)
          IBRETOUR = 0
        Endif
      When "OMN"
        #Campagne presse
        If [F:OMN]FCY <> SZCTRL and [F:OMN]FCY <> "" Then
          SZMESSAGE = mess(616,177,1)
          IBRETOUR = 0
        Endif
      When "CMG"
        #Campagne marketing
        If [F:CMG]FCY <> SZCTRL and [F:CMG]FCY <> "" Then
          SZMESSAGE = mess(616,177,1)
          IBRETOUR = 0
        Endif
      When "OPP"
        #Affaire
        If dim(SZCTRL) = 1 Then
          # FGR 04/02/2010 X3SUIVI61570
          #If [F:OPP]SALFCY <> SZCTRL and [F:OPP]SALFCY <> "" Then
          If [F:OPP]SALFCY <> SZCTRL and [F:OPP]SALFCY <> "" and SZCTRL <> "***" Then
            SZMESSAGE = mess(616,177,1)
            IBRETOUR = 0
          Endif
        Else
          # SZCTRL(0) = Site
          # SZCTRL(1) = Tiers
          If [F:OPP]SALFCY <> SZCTRL(0) and [F:OPP]SALFCY <> "" Then
            SZMESSAGE = mess(616,177,1)
            IBRETOUR = 0
            End
          Endif
          If dim(SZCTRL) > 1 Then
            If SZCTRL(1) <> "" and [F:OPP]OPPCMP <> SZCTRL(1) and [F:OPP]OPPCMP <> "" Then
              SZMESSAGE = mess(617,177,1)
              IBRETOUR = 0
              End
            Endif
          Endif
        Endif
    Endcase
  Endif
End

##########################################################################################################
# Rend le code de la campagne marketing associée lorsqu'il est alimenté
# ------------------------------------------------------------
Subprog GETCMG_OBJCODE (DOSSIER, SZOBJET, SZCODE, SZCMGNUM, SZMESSAGE, IBRETOUR)
Value Char DOSSIER
Value Char SZOBJET
Value Char SZCODE
Variable Char SZCMGNUM
Variable Char SZMESSAGE
Variable Integer IBRETOUR

  # FGR 01/12/2008 : X3SUIVI50722
  Raz SZCMGNUM
  IBRETOUR = 1
  If SZOBJET = "" or SZCODE = "" Then
    End
  Endif
  Case SZOBJET
    When "OMM"
      #Publipostage
      If DOSSIER = "" Then
        If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
      Else
        If !clalev([F:OMM]) : Local File =DOSSIER+".MAILING" [OMM] : Endif
      Endif
      Read [OMM]OMM0=SZCODE
      SZCMGNUM = [F:OMM]CMGNUM
    When "OMP"
      #Campagne d'appels
      If DOSSIER = "" Then
        If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
      Else
        If !clalev([F:OMP]) : Local File =DOSSIER+".PHONING" [OMP] : Endif
      Endif
      Read [OMP]OMP0=SZCODE
      SZCMGNUM = [F:OMP]CMGNUM
    When "OMT"
      #Salons professionnels
      If DOSSIER = "" Then
        If !clalev([F:OMT]) : Local File TRADESHOW [OMT] : Endif
      Else
        If !clalev([F:OMT]) : Local File =DOSSIER+".TRADESHOW" [OMT] : Endif
      Endif
      Read [OMT]OMT0=SZCODE
      SZCMGNUM = [F:OMT]CMGNUM
    When "OMN"
      #Campagne presse
      If DOSSIER = "" Then
        If !clalev([F:OMN]) : Local File MEDIA [OMN] : Endif
      Else
        If !clalev([F:OMN]) : Local File =DOSSIER+".MEDIA" [OMN] : Endif
      Endif
      Read [OMN]OMN0=SZCODE
      SZCMGNUM = [F:OMN]CMGNUM
    When "CMG"
      #Campagne marketing
      If DOSSIER = "" Then
        If !clalev([F:CMG]) : Local File CMARKETING [CMG] : Endif
      Else
        If !clalev([F:CMG]) : Local File =DOSSIER+".CMARKETING" [CMG] : Endif
      Endif
      Read [CMG]CMG0=SZCODE
      SZCMGNUM = [F:CMG]NUM
  Endcase
  #
  If fstat <> 0 Then
    #Numéro de pièce incorrect
    SZMESSAGE = mess(525,177,1)
    IBRETOUR = 0
    Raz SZCMGNUM
  Endif
End

##########################################################################################################
# Définit l'image des icônes
######################################################
$DEFICONNUM
Local Char SZICOSYN
Local Char SZICOSYNDON

  SZICOSYNDON = ""
  SZICOSYN = ""
  #On vérifie les GICOSYN
  If GICOSYN = "" Then
    SZICOSYN = "71"
  Else
    SZICOSYN = GICOSYN
  Endif
  If GICOSYNDON = "" Then
    SZICOSYNDON = "117"
  Else
    SZICOSYNDON = GICOSYNDON
  Endif
Return

##########################################################################################################
# CRMAFFAGD  : Présente une chaine concaténé avec libellé /code pour affichage Agenda
Subprog CRMAFFAGD (SZCODE, SZLIBELLE, SZRESULT)
Value Char SZCODE ()
Value Char SZLIBELLE()
Variable Char SZRESULT ()

  If SZLIBELLE <> "" Then
    SZRESULT = SZLIBELLE + " #" + SZCODE + "#"
  Else
    SZRESULT = SZCODE
  Endif
End

##########################################################################################################
Subprog GETNBPARENTHESE (SZPARENTHESE,ITYPE, INBPAR,SZRESULT, SZMESSAGE, IBRETOUR)
Value Char  SZPARENTHESE()
Value Integer ITYPE
    #ITYPE= 0 ouvrantes
    #ITYPE= 1 fermantes
Variable Integer INBPAR
Variable Char SZRESULT
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Char SZVALEUR
Local Char SZCHAINE
Local Char SZNEWCHAINE
Local Integer IMAX
Local Integer IPOSITION
Local Char SZCHERCHE

  Raz SZMESSAGE
  IBRETOUR = 1

  Raz SZRESULT
  INBPAR = 0
  Raz SZVALEUR
  Raz SZCHAINE
  Raz SZNEWCHAINE
  IMAX = 0
  IPOSITION = 0
  Raz SZCHERCHE

  SZCHAINE = vireblc(SZPARENTHESE, 4)
  IMAX = len (SZCHAINE)
  If SZCHAINE = "" Then
    INBPAR = 0
    End
  Endif
  If ITYPE = 0 Then
    SZCHERCHE = "("
  Elsif ITYPE = 1 Then
    SZCHERCHE = ")"
  Else
    IBRETOUR = 0
    #Recherche du nombre de parenthèses impossibe. Type de recherche inconu.
    SZMESSAGE = mess(540,177,1)
    End
  Endif
  INBPAR = 0
  IPOSITION = 1
  While IPOSITION < IMAX+1
    SZVALEUR = mid$(SZCHAINE, IPOSITION, 1)
    If SZVALEUR = SZCHERCHE Then
      INBPAR = INBPAR + 1
      SZNEWCHAINE = SZNEWCHAINE + SZCHERCHE
    Endif
    IPOSITION = IPOSITION + 1
  Wend
  SZRESULT = SZNEWCHAINE
End

##########################################################################################################
Subprog CTRLPARENTHESE (SZPARENTHESE,ITYPE, SZMESSAGE, IBRETOUR)
Value Char  SZPARENTHESE()
Value Integer ITYPE
    #ITYPE= 0 ouvrantes
    #ITYPE= 1 fermantes
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Char SZVALEUR
Local Char SZCHAINE
Local Char SZNEWCHAINE
Local Integer IMAX
Local Integer IPOSITION
Local Char SZCHERCHE

  Raz SZMESSAGE
  IBRETOUR = 1

  Raz SZVALEUR
  Raz SZCHAINE
  Raz SZNEWCHAINE
  IMAX = 0
  IPOSITION = 0
  Raz SZCHERCHE
  SZCHAINE = vireblc(SZPARENTHESE, 4)
  IMAX = len (SZCHAINE)
  If SZCHAINE = "" Then
    INBPAR = 0
    End
  Endif
  If ITYPE = 0 Then
    SZCHERCHE = "("
  Elsif ITYPE = 1 Then
    SZCHERCHE = ")"
  Else
    IBRETOUR = 0
    #Recherche du nombre de parenthèses impossibe. Type de recherche inconu.
    SZMESSAGE = mess(540,177,1)
    End
  Endif
  INBPAR = 0
  IPOSITION = 1
  While IPOSITION < IMAX+1
    SZVALEUR = mid$(SZCHAINE, IPOSITION,1)
    If SZVALEUR <> SZCHERCHE Then
      If ITYPE = 0 Then
        #Erreur Vous ne pouvez saisir que des parenthèses ouvrantes "("
        SZMESSAGE = mess(541,177,1)
        IBRETOUR = 0
        Break
      Else
        #Erreur Vous ne pouvez saisir que des parenthèses fermantes ")"
        SZMESSAGE = mess(542,177,1)
        IBRETOUR = 0
        Break
      Endif
    Endif
    IPOSITION = IPOSITION + 1
  Wend
End

##########################################################################################################
Funprog GET_CHAMP_SSIND (SZCHAMP)
Value Char SZCHAMP

Local Char SZLEFTCRIFIE(GLONAVA)

  # FGR 12/01/2009 : X3SUIVI51579
  If instr(1, SZCHAMP, '(') Then
    SZLEFTCRIFIE = left$(SZCHAMP, instr(1, SZCHAMP, '(')-1)
  Else
    SZLEFTCRIFIE = SZCHAMP
  Endif
End SZLEFTCRIFIE

##########################################################################################################
Subprog CTRL_CHAMP_TABLE (SZTABLE,  SZCHAMP, SZLEFTCRIFIE, SZMESSAGE, IBRETOUR)
Value Char SZTABLE
Variable Char SZCHAMP
Variable Char SZLEFTCRIFIE
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Char SZVALEUR
Local Integer IUSERDIMLEV
Local Integer IDIMLEVPOS1
Local Integer IDIMLEVPOS2
Local Integer IDIMLEVPOS3
Local Integer ICRIFIEDIM
Local Integer ICRIFIETYP

  # FGR 12/01/2009 : X3SUIVI51579
  IBRETOUR = 1
  SZMESSAGE = ""
  SZLEFTCRIFIE = ""
  SZVALEUR = ""
  IUSERDIMLEV = 0
  IUSEUSERDIM = 0
  IDIMLEVPOS1 = 0
  IDIMLEVPOS2 = 0
  IDIMLEVPOS3 = 0
  ICRIFIETYP = 0
  #
  If SZTABLE = "" Then
    #Zone obligatoire : TABLE obligatoire
    IBRETOUR = 0
    SZMESSAGE = mess(10,123,1)
    End
  Endif
  If SZCHAMP = "" Then
    #Zone obligatoire : CHAMP obligatoire
    IBRETOUR = 0
    SZMESSAGE = mess(10,123,1)
    End
  Else
    SZCHAMP = toupper(ctrans(SZCHAMP))
    SZVALEUR = SZCHAMP
    If instr(1, SZVALEUR, '(') Then
      IDIMLEVPOS1 =  instr(1, SZVALEUR, '(')
      If instr(1, SZVALEUR, ')') Then
        IDIMLEVPOS2 =  instr(1, SZVALEUR, ')')
        If IDIMLEVPOS2 < IDIMLEVPOS1 Then
          # La paranthèse fermante doit être après la parenthèse ouvrante
          IBRETOUR = 0
          SZMESSAGE = mess(1002,182,1)
          End
        Endif
      Else
        # Il manque la parenthèse fermante
        IBRETOUR = 0
        SZMESSAGE = mess(1001,182,1)
        End
      Endif
    Endif
    SZLEFTCRIFIE = func GET_CHAMP_SSIND (SZVALEUR)
    Read [ATZ]CODZONE=SZTABLE;SZLEFTCRIFIE
    If fstat Then
      # XX n'est pas un champ de la table : YY
      IBRETOUR = 0
      SZMESSAGE = SZLEFTCRIFIE - mess(574,196,1) - SZTABLE
      End
    Else
      If [F:ATZ]CODTYP = "AXX" Then
        #Ce type de champ n'est pas supporté. Saisie refusée.
        IBRETOUR = 0
        SZMESSAGE = mess(846,182,1)
        End
      Endif
    Endif
    #Contrôle des clobs et blobs
    # FGR 04/02/2015 : X3SUIVI105938 (début) on refuse tous les type au dessus de 500
    #Local File =SZTABLE [TYPX]
    #ICRIFIETYP = evalue("Type([F:TYPX]" + SZLEFTCRIFIE + ")")
    #Close Local File [TYPX]
    #If ICRIFIETYP = 522 or ICRIFIETYP = 523 Then
    #  #Ce type de champ n'est pas supporté. Saisie refusée.
    #  IBRETOUR = 0
    #  SZMESSAGE = mess(846,182,1)
    #  End
    #Endif
    If func IS_TBLFIELD_USABLE(SZTABLE, SZLEFTCRIFIE) = [V]CST_ANO Then
      #Ce type de champ n'est pas supporté. Saisie refusée.
      IBRETOUR = 0
      SZMESSAGE = mess(846,182,1)
      End
    Endif
    # FGR 04/02/2015 : X3SUIVI105938 (fin)
    #Contrôle pour champs dimensionnés
    If instr(1, SZVALEUR, '(') Then
      IDIMLEVPOS1 =  instr(1, SZVALEUR, '(')
      If instr(1, SZVALEUR, ')') Then
        IDIMLEVPOS2 =  instr(1, SZVALEUR, ')')
        If IDIMLEVPOS2 > IDIMLEVPOS1 Then
          IDIMLEVPOS3 = IDIMLEVPOS2 - IDIMLEVPOS1
          If IDIMLEVPOS3 > 1 Then
            IUSERDIMLEV = val(mid$(SZVALEUR, IDIMLEVPOS1+1, IDIMLEVPOS3-1))
            #Obtient la dimension du champ
            Local File =SZTABLE [TYPX]
            ICRIFIEDIM = evalue("Dim([F:TYPX]" + SZLEFTCRIFIE + ")")
            Close Local File [TYPX]
            If IUSERDIMLEV >= ICRIFIEDIM Then
              #La valeur de l'indice est supérieure à la valeur maximum autorisée de NN. Saisie refusée.
              IBRETOUR = 0
              SZMESSAGE = mess(781,196,1) - num$(ICRIFIEDIM-1) + '.' - mess(627,196,1)
              End
            Endif
          Else
            # XX n'est pas un champ de la table : YY
            IBRETOUR = 0
            SZMESSAGE = SZVALEUR - mess(574,196,1) - [M:MGG2]CRITAB(nolign-1)
            End
          Endif
        Else
          # XX n'est pas un champ de la table : YY
          IBRETOUR = 0
          SZMESSAGE = SZVALEUR - mess(574,196,1) - [M:MGG2]CRITAB(nolign-1)
          End
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Funprog IS_TBLFIELD_USABLE(STABLE, SFIELD)
Value Char STABLE
Value Char SFIELD

Local Integer IARENDRE
Local Integer ITYPFIELD

  # FGR 04/02/2015 : X3SUIVI105938 : les champs de type>500 ne sont pas utilisables
  IARENDRE = [V]CST_AYES
  If STABLE <> "" and SFIELD <> "" Then
    Local File =STABLE [TYPX]
    ITYPFIELD = evalue("type([F:TYPX]" + SFIELD + ")")
    Close Local File [TYPX]
    If ITYPFIELD > 500 or ITYPFIELD <= 0 Then
      IARENDRE = [V]CST_ANO
    Endif
  Else
    IARENDRE = [V]CST_ANO
  Endif
End IARENDRE

##########################################################################################################
Subprog LOAD_SITE_GRP(ZGROUPE)
Value Char ZGROUPE

Local Integer NBFGRFILTER
Local Integer NBFGR

  # FGR 14/01/2009 : X3SUIVI48957
  NBFGR = 0
  If dim(GLST_SITE) > 0 Then
    Kill GLST_SITE
  Endif
  If ZGROUPE <> "" Then
    If !clalev([F:FGR]) : Local File FACGROUP [FGR] : Endif
    Filter [FGR] Where CPY = ZGROUPE
    NBFGRFILTER = rowcount([FGR])
    If NBFGRFILTER > 0 Then
      Global Char GLST_SITE(GLONFCY)(NBFGRFILTER)
      #
      For [FGR]
        GLST_SITE(NBFGR) = [FGR]FCY
        NBFGR += 1
      Next
      Filter [FGR]
    Endif
  Endif
End

##########################################################################################################
Funprog GET_FILTRE_SITE_GRP (SZCHAMP)
Value Char SZCHAMP

Local Char ZSWHERE(250)

  # FGR 14/01/2009 : X3SUIVI48957
  ZSWHERE = "1=1"
  If dim(GLST_SITE) > 0 Then
    # Note FGR : Quand le tableau excède 60, on ne peut pas mettre <> 0, ça fait planter.
    #            <>0 est cependant plus performant.
    #            Je teste le dimensionnement pour ne le faire que si c'est possible
    If dim(GLST_SITE) < 60 Then
      ZSWHERE = "(find("+SZCHAMP+", GLST_SITE) <> 0"
    Else
      ZSWHERE = "(find("+SZCHAMP+", GLST_SITE)"
    Endif
    ZSWHERE = ZSWHERE - "or" - SZCHAMP + "=''"   # On accepte soit le sites de la liste soit lorsque le site n'est pas renseigné
    ZSWHERE = ZSWHERE + ")"
  Endif
End ZSWHERE

##########################################################################################################
Funprog GET_CODE_ACTIVITE (SZCODACT)
Value Char SZCODACT

Local Integer IARENDRE
Local Integer IINDICE
Local Integer ISIZE
Local Integer INEWSIZE

  If nomap = GDOSX3 Then
    # FGR 19/10/2009 : X3SUIVI58905 : Si on est sur le dossier mère, on ne gère pas la pile. On l'efface à chaque fois
    If dim(GCRMCODACT) < 0 Then
      # Si les globales n'existent pas on ne fait rien
    Else
      # Si elles existent on le vides pour toujours relire la valeur du code activité
      Raz GCRMCODACT
      Raz GCRMVALACT
      GCRMLASACT = ""
      GCRMINDACT = -1
    Endif
  Endif
  #
  # FGR 29/01/2009 : X3SUIVI41698 : Rend 2 si le code activité demandé est actif et 1 s'il ne l'est pas
  If dim(GCRMCODACT) < 0 Then
    # Les variables globales d'optimisation n'existent pas
    Global Char GCRMCODACT(GLONACV)(10)  # Liste des codes activités lus
    Global Integer GCRMVALACT(10)        # Valeurs des codes activités correspondants
    Global Char GCRMLASACT(GLONACV)      # Dernier code activité lu
    Global Integer GCRMINDACT            # Indice dernier code activité lu

    Raz GCRMCODACT
    Raz GCRMVALACT
    GCRMLASACT = ""
    GCRMINDACT = -1
  Endif
  #
  If GCRMLASACT = SZCODACT and GCRMINDACT >= 0 Then
    # La valeur qu'on interroge est la dernière lu
    IARENDRE = GCRMVALACT(GCRMINDACT)
  Else
    # Ca n'est pas la dernière valeur : on regarde dans le tableau si on l'a dejà lu
    IINDICE = find(SZCODACT, GCRMCODACT)-1
    If IINDICE < 0 Then
      # On n'a pas encore lu ce code activité
      # 1°) On le lit
      # FGR 19/10/2009 : X3SUIVI58905 : Pour la validation depuis le dossier X3, le table doit être ouverte
      #                                 dans FUNHDKTRS sur le dossier à traiter.
      If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif
      Read [ACV]CODACT=SZCODACT
      If fstat Then
        IARENDRE = 1
      Else
        If [F:ACV]FLACT <> 2 Then
          IARENDRE = 1
        Else
          IARENDRE = 2
        Endif
      Endif
      # 2°) on le mémorise pour la prochaine fois
      IINDICE = find("", GCRMCODACT)-1
      If IINDICE < 0 Then
        # 2,5°) Si on est dans ce cas, c'est que le tableau est plein : faut en augmenter la taille
        ISIZE = dim(GCRMCODACT)
        #
        Local Char WCODACT(GLONACV)(ISIZE)
        Local Integer WVALACT(ISIZE)
        # a. On recopie les 2 tableaux dans les tableaux tampons
        For IINDICE = 0 To ISIZE
          WCODACT(IINDICE) = GCRMCODACT(IINDICE)
          WVALACT(IINDICE) = GCRMVALACT(IINDICE)
        Next IINDICE
        # b. On recrée les tableaux globaux avec une taille augmentée de 10
        INEWSIZE = ISIZE + 10 # On va créer une nouvelle taille de 10 de plus
        Kill GCRMCODACT
        Kill GCRMVALACT
        #
        Global Char GCRMCODACT(GLONACV)(INEWSIZE)  # Liste des codes activités lus
        Global Integer GCRMVALACT(INEWSIZE)        # Valeurs des codes activités correspondants
        # c. On recopie les 2 tableaux tampons dans les nouveaux tableaux globaux
        Raz GCRMCODACT
        Raz GCRMVALACT
        For IINDICE = 0 To ISIZE
          GCRMCODACT(IINDICE) = WCODACT(IINDICE)
          GCRMVALACT(IINDICE) = WVALACT(IINDICE)
        Next IINDICE
        # d. On récupère l'indice de la première place ligne
        IINDICE = find("", GCRMCODACT)-1
      Endif
      # 2,6°) Cette fois la valeur de IINDICE est obligatoirement possible
      GCRMLASACT = SZCODACT
      GCRMINDACT = IINDICE
      GCRMCODACT(GCRMINDACT) = GCRMLASACT
      GCRMVALACT(GCRMINDACT) = IARENDRE
    Else
      # On a déjà mémorisé ce code activité : on le mémorise comme le dernier et on rend sa valeur
      GCRMINDACT = IINDICE
      GCRMLASACT = SZCODACT
      IARENDRE = GCRMVALACT(GCRMINDACT)
    Endif
  Endif
End IARENDRE

##########################################################################################################
Subprog CTRL_CODE_OPP(AZC, FCY, BPRNUM)
Variable Char    AZC()
Value    Char    FCY
Value    Char    BPRNUM

Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZCONTROL(50)(2)

  # FGR 23/02/2009 : X3SUIVI33671
  If GMODU(13) = 2 Then
    If GCTLOPPCOD = 2 Then
      If AZC <> "" Then
        AZC = toupper(ctrans(AZC))
        SZCONTROL(0) = FCY
        SZCONTROL(1) = BPRNUM
        Call VERIFOBJCODE("OPP", SZCONTROL, AZC, SZMESSAGE, IBRETOUR) From CRMUTIL150
        If IBRETOUR = 0 Then
          GMESSAGE = SZMESSAGE
          mkstat = 1
          End
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
# Assure l'exactitude de l'origine des réservations de ressources.
#################################################################################
Subprog CLEANRRSORI (IRRSORI, SZRRSORIVCR, SZCHAMP, SZMESSAGE, IRETOUR)
Value Integer IRRSORI
Value Char SZRRSORIVCR
Value Char SZCHAMP
Variable Char SZMESSAGE
Variable Integer IRETOUR

Local Integer IEXISTFLG
Local Integer ITER
Local Integer ITO
Local Char SZDANSCHAMPS

  IRETOUR = 1
  SZMESSAGE = ""
  IEXISTFLG = 0
  ITO = evalue("dim(" + SZCHAMP + ")")
  #Contrôle que chaque réservation relative à un rendez-vous est bien stockée dans le rendez-vous
  Filter [RRS] Where [F:RRS]RRSORI = IRRSORI and [F:RRS]RRSORIVCR = SZRRSORIVCR
  For [RRS]RRS1
    IEXISTFLG = 0
    For ITER = 0 To ITO-1
      SZDANSCHAMPS = evalue(SZCHAMP + "(" + num$(ITER) + ")")
      If SZDANSCHAMPS <> "" Then
        If SZDANSCHAMPS = [F:RRS]NUM Then
          IEXISTFLG = 1
          Break
        Endif
      Endif
    Next
    If !IEXISTFLG Then
      #On remet une origine de type Création manuelle.
      [F:RRS]RRSORI = 99
      [F:RRS]RRSORIVCR = ""
      [F:RRS]RRSORIVCRL = 0
      Rewrite [RRS]
      If fstat Then
        #Erreur lors la suppression de l'origine des réservations de ressources.
        SZMESSAGE = mess(173,182,1) - "(a)"
        IRETOUR = 0
        Break
      Endif
    Endif
  Next
  Filter [RRS]
  If IRETOUR = 0 Then
    End
  Endif
  #Maintenant on supprime
  Delete [RRS] Where [F:RRS]RRSORI = 99
  If fstat Then
    #Erreur lors la suppresion des réservations de ressources.
    SZMESSAGE = mess(173,182,1) - "(b)"
    IRETOUR = 0
  Endif
End

##########################################################################################################
# Affiche, lorsqu'il y en a une, l'observation sur la fiche client
# (déclenche action OBSERCLIEN en AM_ C_ ou AZ_ (après zone)
#################################################################################
Subprog AFFICHE_OBS_CLIENT(AZC)
Variable Char    AZC()

Local Integer IBPCX

  If !GIMPORT and AZC <> "" Then
    IBPCX = 0
    If !clalev([F:BPCX]) : Local File BPCUSTOMER [BPCX] : IBPCX = 1 : Endif
    Read [BPCX]BPC0=AZC
    If !fstat Then
      If len(vireblc([F:BPCX]BPCREM, 2)) and GERR = 0 Then
        GMESSAGE = [F:BPCX]BPCREM
        GERR = 2
      Endif
    Endif
    If IBPCX = 1 Then
      Close Local File [BPCX]
    Endif
  Endif
End

##########################################################################################################
Subprog AJOUTE_CONDITION_ROLE (SZFILGAUSUP, IFILGAUSUP, SZOBJET)
Variable Char SZFILGAUSUP()()
Variable Integer IFILGAUSUP
Value Char SZOBJET

# Issue X3-69477 - 2017-12-28 by SR : 240 charcaters instead of 250
Local Char SZFILROLE(240)(0..5)  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
Local Integer NI

  Call FILROLE(SZOBJET, SZFILROLE) From SUBARL
  If SZFILROLE <> "" and SZFILROLE <> "1=1" Then
    For NI = 0 To dim(SZFILROLE)-1
      If SZFILROLE(NI) <> "" and SZFILROLE(NI) <> "1=1" Then
       # Issue X3-69477 - 2017-12-28 by SR : Add "&" character only for the first occurence
       If NI = 0 Then
         Call ADDCRIT(SZFILGAUSUP, IFILGAUSUP, "FILGAUSUP", SZFILROLE(NI), "&") From GOBJSUB
       Else
         Call ADDCRIT(SZFILGAUSUP, IFILGAUSUP, "FILGAUSUP", SZFILROLE(NI), "") From GOBJSUB
       Endif
       # End issue X3-69477
      Endif
    Next NI
  Endif
End

##########################################################################################################
Funprog TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE)
