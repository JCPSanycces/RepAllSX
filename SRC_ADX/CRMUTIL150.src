##########################################################################################################
#     ENSEMBLE de sous-programmes utilitaires créés pour le CRM                     Version 150          #
##########################################################################################################
##########################################################################################################
# GETUTIFROMREP    : récupération de l'utilisateur en fonction du représentant
# GETREPFROMUTI    : récupération du représentant en fonction d'un utilisateur
# VIRE_ASTERIX_END : enlève le caractère * à la find'une chaine
#
# CRMTOKEN         : Converti une chaine en tableau en utilisant ";" comme séparateur
# CONVDI           : converti une date en date interne
# CONVID           : converti une date interne  en date
# DAY_ADD_DURE     : ajout une durée à une date
# VERDATEDEBFIN    : Vérifie la coherence entre une date/hour début et une date/heure FIN
# TRIMDEBPARA      : Enlève les caractères retour ligne en fin de paragraphe
# TRIMFINPARA      : Enlève les caractères retour ligne en début de paragraphe
# VERIFOBJCODE     : Vérifie si le couple objet\code est correct
# DEFICONNUM       : Définit l'image des icônes
# CRMAFFAGD        : Présente une chaine concaténé avec libellé /code pour affichage Agenda
# GETNBPARENTHESE  : renvoi le nombre de parenthese ouvrante ou fermantes dans une chaine
# CTRLPARENTHESE   : controle que la chaine saisie ne contient que des parenthèses
##########################################################################################################
##########################################################################################################
# Rend un téléphone formaté selon le pays (encapsulé)
##########################################################################################################
Funprog GET_TELFORMATED(STEL, SCRY)
Value Char STEL
Value Char SCRY

Local Char SARENDRE(200)

  # FGR 22/10/2015 : X3SUIVI111911
  SARENDRE = func CRMUTIL150_SYRA.GET_TELFORMATED(STEL, SCRY)
End SARENDRE

#####################################################
Subprog GERE_TEXTE_SYNTHESE(OLDTEXTE, NEWTEXTE, SYNTHESE)
Value Clbfile OLDTEXTE
Value Clbfile NEWTEXTE
Variable Char SYNTHESE

  # FGR 06/08/2014 : X3SUIVI95250
  If len(OLDTEXTE) > GLONCLE and len(NEWTEXTE) <= GLONCLE Then
    SYNTHESE = NEWTEXTE
  Elsif len(OLDTEXTE) <= GLONCLE and len(NEWTEXTE) <= GLONCLE Then
    SYNTHESE = NEWTEXTE
  Elsif len(NEWTEXTE) > GLONCLE and SYNTHESE = "" Then
    SYNTHESE = left$(NEWTEXTE,GLONCLE)
  Endif
End

#####################################################
$ERR_BOITE_GOBJET
  # FGR 11/02/2015 : X3SUIVI106120
Resume

#####################################################
$BOITE_GOBJET
  # FGR 22/01/2015 : X3SUIVI105640 : pas en webservice et en import
  If (!GIMPORT & !(dim(GWEBSERV) = 1 & GWEBSERV = 1)) Then
    # FGR 31/07/2014 : X3SUIVI101463
    If dim(STRTSUB) > 0 and STRTSUB <> "" Then
      Assign "[G:"+ABFIC+"]currind" With INDCUR
      Assign "[G:"+ABFIC+"]currlen" With 0
      If MENFON<>"" : OGFONCTION=GFONCTION : GFONCTION=MENFON : Endif    : #  Pour traiter la navigation V5 il faut le rattachement
      #Gosub OUVRE_BOITE From =WINPROG
      # -----------------------------------------
      Gosub INIT_BOITE From =WINPROG
      # -----------------------------------------
      # FGR 11/02/2015 : X3SUIVI106120 (début)
      # On traite ici l'ordre inverse habituel :
      #    1 : SPE
      #    2 : SPV
      #    3 : STD
      # Pour le SPE : s'il les browsers ont été adaptés il faut gérer les Links.
      #               Dans SUB<spe>.$BOITE, déclarer la variable Integer ILNKSPE et l'affecter avec 1
      #               Dans ce cas on appellera l'étiquette REDEFINE_LINK dans PROGSPE pour y redéfinir les Links
      # Pour le SPV,  s'il les browsers ont été adaptés il faut gérer les Links.
      #               Dans SUB<spv>.$BOITE, déclarer la variable Integer ILNKSPV et l'affecter avec 1
      #               Dans ce cas on appellera l'étiquette REDEFINE_LINK dans PROGSPV pour y redéfinir les Links
      #               Cette partie ne se fera que si les browsers n'ont pas été redéfinis en spécifique.
      # A défaut c'est l'étiquette SUB<std>.REDEFINE_LINK qui sera appelée.
      # Si elle ne peut s'exécuter, les filtres par défaut resteront appliqués, et les habilitations ne le seront pas.
      #Gosub REDEFINE_LINK From =STRTSUB
      If PSPE Then
        If dim(ILNKSPE) > 0 and ILNKSPE = 1 Then
          Onerrgo ERR_BOITE_GOBJET
          Gosub REDEFINE_LINK From =PROGSPE
          Onerrgo
        Endif
      Endif
      #
      If PSPV Then
        If dim(ILNKSPE) < 0 Then
          # S'il y a du SPE sur les browsers, c'est lui qui doit redéfinir les Links
          If dim(ILNKSPV) > 0 and ILNKSPV = 1 Then
            Onerrgo ERR_BOITE_GOBJET
            Gosub REDEFINE_LINK From =PROGSPV
            Onerrgo
          Endif
        Endif
      Endif
      #
      If dim(ILNKSPE) < 0 and dim(ILNKSPV) < 0 Then
        Gosub REDEFINE_LINK From =STRTSUB
      Endif
      # FGR 11/02/2015 : X3SUIVI106120 (fin)
      # -----------------------------------------
      Gosub DEF_BOITE From =WINPROG
      Gosub AFF_BOITE From =WINPROG
      # -----------------------------------------
      If MENFON<>"" : GFONCTION=OGFONCTION : Endif
      OK = 0
    Endif
  Endif
Return

