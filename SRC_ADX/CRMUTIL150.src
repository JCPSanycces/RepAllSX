##########################################################################################################
Subprog GETUTIFROMREP (SZREP, SZUTI, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZREP
Variable Char SZUTI
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  IBRETOUR = 1
  If !clalev([F:REPW]) : Local File SALESREP [REPW] : Endif
  Read [REPW]REP0=SZREP
  If fstat Then
    #erreur : Aucun utilisateur n'est défini pour ce représentant.
    IERRINF = 209
    ICHAPTER = 177
    End
  Endif
  SZUTI = [F:REPW]AUSNUM
  If SZUTI = "" Then
     #erreur : Aucun utilisateur n'est défini pour ce représentant.
    IERRINF = 209
    ICHAPTER = 177
    End
  Endif
End

