##########################################################################################################
Subprog DEFOBJORI(SAOB, SORIAVA)
Value Char SAOB
Variable Char SORIAVA

  # FGR 05/03/2010 : X3SUIVI62924
  # Rend le champ de la clé primaire de l'objet indiqué
  Raz SORIAVA
  If SAOB <> "" Then
    Gosub SETCLE From ="WO" + SAOB
    SORIAVA = CLEPRIM
  Endif
End

##########################################################################################################
Subprog B1ORIVCR(VALEUR, SORIAOB)
Variable Char    VALEUR()
Value Char SORIAOB

Local Integer IEXIST
Local Char SORIAVA(GLONAVA)
Local Char SWHERE(250)

  # FGR 05/03/2010 : X3SUIVI62924 : Obligé de faire un exception à cause de FUP
  #----------------------
  If VALEUR <> "" Then
    # L'enregistrement peut avoir été supprimé.
    # On teste ici qu'il existe toujours pour partir en tunnel ou pas
    # Avec un message permet d'être plus clair plutôt que de ne pas afficher le bouton
    If !clalev([AOB]) : Local File AOBJET [AOB] : Endif
    #
    IEXIST = 0
    Read [AOB]ABREV=SORIAOB
    Local File =[F:AOB]NOMFIC [TFP0]
    Call DEFOBJORI(SORIAOB, SORIAVA)
    SWHERE = "[F:TFP0]" + SORIAVA + "=VALEUR"
    Filter [TFP0] Where evalue(SWHERE)
    For [TFP0]
      IEXIST = 1
      Break
    Next
    Filter [TFP0]
    Close Local File [TFP0]
    If IEXIST = 0 Then
      # Si l'enregistrement a été supprimé, on interdit de se débrancher dessus
      GMESSAGE = mess(641,177,1)
      GERR = 1
      End
    Endif
  Endif
  #----------------------
  # FGR 13/04/2012 : X3SUIVI81213 (début)
  If dim(GB1ORIVCR) < 0 Then
    Global Char GB1ORIVCR((type(SORIAOB)-10)+GLONVCR+5)
  Endif
  If GB1ORIVCR = "" Then
    # Permet de savoir qu'on est sur le premier tunnel
    GB1ORIVCR = SORIAOB + "~" + VALEUR
  Endif
  # FGR 13/04/2012 : X3SUIVI81213 (fin)
  # Vérifier qu'on n'est pas déjà venu en tunnel de l'objet où on souhaite se rendre
  If GPILNAV > 1 Then
    # Si on est déjà venu ici par tunnel depuis FUP on interdit d'y retourner
    IFUPEXIST = find("GES" + SORIAOB, GNAVIG(1..GPILNAV))  # FGR 11/10/2011 : X3SUIVI77025 il fallait ajouter : (1..GPILNAV)
    If IFUPEXIST <> 0 Then
      # On est venu par tunnel (+/- loin). On ne peut pas les rappeler comme ça
      GMESSAGE = mess(116,126,1)
      GERR = 1
      End
    Endif
  Endif
  #----------------------
  If SORIAOB = "FUP" Then
    # Gestion des relances
    Local Char LPARAM(GLONVCR)(1..2), LVALEUR(10)
    LVALEUR     = ""
    LPARAM(1)   = VALEUR
    GERR        = 0
    GPROG       = "TRTCFUP"
    GTYPPROG    = 4
    GWINDOW     = "DFUP"
    GWINCRIT    = "CRITFUP"
    Call TRAITE_CHAR(LVALEUR, LPARAM, GWINDOW, GPROG, GWINCRIT, GTYPPROG, "") From GTRAITE
  Else
    ## Action GOBJETC1
    Local Char    PARMSK(250)(1..20) , SAVACT(20)
    SAVACT = GACTION : GACTION = "GOBJETC1"
    Call OBJET_CHAR(VALEUR, SORIAOB, "") From GOBJET
    GACTION = SAVACT
  Endif
  # FGR 13/04/2012 : X3SUIVI81213 (début)
  If GB1ORIVCR = SORIAOB + "~" + VALEUR Then
    # Permet de savoir qu'on est sur le premier tunnel, et donc qu'on peut détruire la globale
    Kill GB1ORIVCR
  Endif
  # FGR 13/04/2012 : X3SUIVI81213 (fin)
End

##########################################################################################################
Subprog B1FILTORIVCR(SORIAOB)
Value Char SORIAOB

  # FGR 05/03/2010 : X3SUIVI62924 : Proposer des filtres par défaut pour restreindre la liste quand c'est possible
  If dim(GFILTORIVCR) < 0 Then
    Global Char GFILTORIVCR(250)
  Endif
  #
  Raz GFILTORIVCR
  Case SORIAOB
    When "OMM"
      GFILTORIVCR = "CLO<>2"
    When "OMP"
      GFILTORIVCR = "CLO<>2"
    When "OMT"
      GFILTORIVCR = "CLO<>2"
    When "OMN"
      GFILTORIVCR = "CLO<>2"
    When "CMG"
      GFILTORIVCR = "CLO<>2"
    When Default
  Endcase
End

##########################################################################################################
Subprog CRMCTLNUM(VALEUR, SAOB)
Variable Char    VALEUR()
Value Char SAOB

Local Char SCHAMPAVA(GLONAVA)
Local Integer IEXIST
Local Char SWHERE(250)

  # FGR 11/03/2010 : X3SUIVI62865
  If SAOB <> "" and dim(ABREV) >= 0 Then
    If SAOB = ABREV Then
      # FGR 15/03/2010 : "and SAOB = ABREV" ne déclenche le controle que si on est en gestion de cet objet
      If GREP <> "C" and GREP <> "D" Then
        If !clalev([AOB]) : Local File AOBJET [AOB] : Endif
        Read [AOB]ABREV=SAOB
        Call DEFOBJORI(SAOB, SCHAMPAVA)
        If evalue("dim([M]" + SCHAMPAVA + ")") >= 0 Then
          Local File =[F:AOB]NOMFIC [TFP0]
          If evalue ("[M]" + SCHAMPAVA) <> "" Then
            IEXIST = 0
            SWHERE = "[F:TFP0]" + SCHAMPAVA + "=" + "[M]" + SCHAMPAVA
            Filter [TFP0] Where evalue(SWHERE)
            For [TFP0]
              IEXIST = 1
              Break
            Next
            Filter [TFP0]
            If IEXIST = 0 Then
              SWHERE = "[F:TFP0]" + SCHAMPAVA + "=VALEUR"
              Filter [TFP0] Where evalue(SWHERE)
              For [TFP0]
                IEXIST = 1
                Break
              Next
              Filter [TFP0]
              If IEXIST = 0 Then
                # Il n'y avait pas d'enreg.en ligne et la clé saisie n'existe pas --> Création interdite
                GMESSAGE = mess(178,199,1)
                mkstat = 2
              Endif
            Endif
          Else
            IEXIST = 0
            SWHERE = "[F:TFP0]" + SCHAMPAVA + "=VALEUR"
            Filter [TFP0] Where evalue(SWHERE)
            For [TFP0]
              IEXIST = 1
              Break
            Next
            Filter [TFP0]
            If IEXIST = 0 Then
              GMESSAGE = mess(178,199,1)
              mkstat = 2
            Endif
          Endif
          Close Local File [TFP0]
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog CTRL_AXE_H (SBASTAB, SABRMSK, SCHACCE, DDATE)
Value Char SBASTAB
Value Char SABRMSK
Value Char SCHACCE
Value Date DDATE

Local Integer I
Local Integer IERROR
Local Char SMSKCHA(50)
Local Char SZSECTION(GLONCCE)
Local Integer INBAXE

  # FGR 19/03/2010 : X3SUIVI63222
  If GIMPORT  Then
    # Rien n'est controlé en import
    End
  Endif
  SMSKCHA = "[M:" + SABRMSK + "]" + SBASTAB
  INBAXE = evalue(SMSKCHA)
  If INBAXE <= 0 Then
    # Rien n'est controlé s'il n'y a pas d'axe
    End
  Endif
  IERROR = 0
  If GHEADIE = 1 Then
    # Sections d'entête saisissables
    If !find(status, 1, 4, 5, 20, 21, 26, 92, 93) Then
      End
    Endif
    #----- Contrôle sections obligatoires -----#
    For I = 1 To INBAXE
      SMSKCHA = "[M:" + SABRMSK + "]" + SCHACCE + "(I-1)"
      If evalue(SMSKCHA) = "" and GOBLDIE(I) = 2 and GENVDIE(I) <> 2 Then
        GMESSAGE = mess(177,199,1)
        GERR = 1
        mkstat = 1
        IERROR = 1
        Break
      Endif
    Next I
    If IERROR Then
      End
    Endif
    #----- Contrôle sections valides -----#
    # Sections d'entête saisissables
    For I = 1 To INBAXE
      SMSKCHA = "[M:" + SABRMSK + "]" + SCHACCE + "(I-1)"
      SZSECTION = evalue(SMSKCHA)
      Call CTRL_CCEH(SZSECTION, I, GFINRSP, DDATE) From TRTX3CPT
      Assign SMSKCHA With SZSECTION
      If mkstat Then
        IERROR = 1
        Break
      Endif
    Next I
    If IERROR Then
      End
    Endif
  Endif
End

##################################################
Subprog INIHMD(HEURE)
Variable Char HEURE

  # FGR 23/07/2014 : X3SUIVI101618
  If HEURE<>""
    HEURE = left$(HEURE+"00000",5)
  Endif
End

#####################################################
Subprog CONTHMD(HEURE)
Variable Char HEURE

Local Integer HH, MM
Local Char    WH(type(HEURE)-10)

  # FGR 23/07/2014 : X3SUIVI101618
  # On ne contrôle que les minutes qui ne doivent pas excéder 59.
  # Le nombre d'heure n'est limité que par le format, soit 99.
  WH = HEURE
  Case len(WH)
    When 0
      WH = "00000"
    When 1
      WH = "00" + WH + "00"
    When 2
      WH = "0" + WH + "00"
    When 3
      WH = "0" + WH
  Endcase
  HH = val(left$(WH,3))
  MM = val(right$(WH,4))
  If MM > 59 Then
    mkstat = 1
    GMESSAGE = mess(69,134,1)
    End
  Endif
  HEURE = WH
End

