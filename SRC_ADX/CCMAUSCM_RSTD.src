#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation script: CCMCAUSCM_RSTD, Change Managers

#####################
# METHODS           #
#####################
$METHODS
  Case CURPTH
    When ""
      Case ACTION
        When "AQUERY_CRITERIA_AFTER" : Gosub AQUERY_CRITERIA_AFTER
        When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
      Endcase
  Endcase
Return

# --------------------------------------------------
# Add filter to Users [AUS] to return change managers.
$AQUERY_CRITERIA_AFTER

  Local Integer CHANGE_MANAGER_COUNT
  Local Char CCMCHGMAN(30)
  Local Char CHANGE_MANAGER(10)(1..)
  Local Integer I

  If (clalev([AUS]) = 0) : Local File AUTILIS [AUS] : Endif

  # Build array (CHANGE_MANAGER) of change manager users ...
  CHANGE_MANAGER_COUNT = 0
  For [AUS] Where ENAFLG = 2
    Call PARAMUTIL("CCMCHGMAN", CCMCHGMAN, [F:AUS]USR, "") From SUBAUS
    If (CCMCHGMAN = "2")
      CHANGE_MANAGER_COUNT += 1
      CHANGE_MANAGER(CHANGE_MANAGER_COUNT) = [F:AUS]USR
    Endif
  Next

  # Build 'where clause' (PQRY.QWHERE) from array (above) ...
  If (CHANGE_MANAGER_COUNT = 0)
    If (PQRY.QWHERE <> "")
      PQRY.QWHERE = "(" +PQRY.QWHERE +") and 1 eq 0"
    Else
      PQRY.QWHERE = "1 eq 0"
    Endif
  Else
    For I = 1 To CHANGE_MANAGER_COUNT
      If (I = 1)
        If (PQRY.QWHERE <> "")
          PQRY.QWHERE = "(" +PQRY.QWHERE +") and USR in ('" +CHANGE_MANAGER(1) +"'"
        Else
          PQRY.QWHERE = "USR in ('" +CHANGE_MANAGER(1) +"'"
        Endif
      Else
        PQRY.QWHERE = PQRY.QWHERE +", '"+CHANGE_MANAGER(I)+"'"
      Endif
    Next I
    PQRY.QWHERE = PQRY.QWHERE +")"
  Endif

Return

# --------------------------------------------------
# Populate role and department.
$AQUERY_TRANS_AFTER

  Local Char ROLE(30), DEPT(30)

  Call PARAMUTIL("CCMROLE", ROLE, this.AUS.USR, "") From SUBAUS
  Call PARAMUTIL("CCMDEPT", DEPT, this.AUS.USR, "") From SUBAUS
  If (ROLE <> "" & ROLE <> "1")
    this.ROLE = mess(val(ROLE), 2036, 1)
  Else
    this.ROLE = ""
  Endif
  If (DEPT <> "" & DEPT <> "1")
    this.DEPARTMENT = mess(val(DEPT), 2037, 1)
  Else
    this.DEPARTMENT = ""
  Endif

Return

$PROPERTIES
Case [L]CURPRO
Endcase
Return


