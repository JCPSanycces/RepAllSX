#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe OPPOR
#######################################################################################
# PJM METHODS                                                                         #
#######################################################################################
$ADELETE_CONTROL_AFTER
Return

#######################################################################################
$PJM_PROPAGATE_TECH_PROP
Local Integer NI
Local Integer NE
Local Integer NZ

  # ---------------------------------
  # Mandatory to do that from here. It's not possible to use AREAD_AFTER at each level because AREAD_AFTER
  # if going from the lower level to the upper lever. And in this case, the need is the opposite.
  # Maybe there is another way to do that, but I don't know it. :-(
  # ---------------------------------
  [L]ARET_VALUE = fmet this.PJM_INIT_TECH_PROP()
  For NI = 1 To maxtab(this.PJM(1).BUD)
    If this.PJM(1).BUD(NI) <> null and find(this.PJM(1).BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = fmet this.PJM(1).BUD_INIT_TECH_PROP(NI)
      For NE = 1 To maxtab(this.PJM(1).BUD(NI).BUDLIG)
        If this.PJM(1).BUD(NI).BUDLIG(NE) <> null and find(this.PJM(1).BUD(NI).BUDLIG(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = fmet this.PJM(1).BUD(NI).BUDLIG_INIT_TECH_PROP(NE)
        Endif
      Next NE
      # ---------------------------------
      For NE = 1 To maxtab(this.PJM(1).BUD(NI).SPLD)
        If this.PJM(1).BUD(NI).SPLD(NE) <> null and find(this.PJM(1).BUD(NI).SPLD(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = fmet this.PJM(1).BUD(NI).SPLD_INIT_TECH_PROP(NE)
        Endif
      Next NE
    Endif
  Next NI
  # ---------------------------------
  For NI = 1 To maxtab(this.PJM(1).TAS)
    If this.PJM(1).TAS(NI) <> null and find(this.PJM(1).TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = fmet this.PJM(1).TAS_INIT_TECH_PROP(NI)
      # ---------------------------------
      For NE = 1 To maxtab(this.PJM(1).TAS(NI).RITT)
        If this.PJM(1).TAS(NI).RITT(NE) <> null and find(this.PJM(1).TAS(NI).RITT(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = fmet this.PJM(1).TAS(NI).RITT_INIT_TECH_PROP(NE)
        Endif
      Next NE
      # ---------------------------------
      For NE = 1 To maxtab(this.PJM(1).TAS(NI).RTKO)
        If this.PJM(1).TAS(NI).RTKO(NE) <> null and find(this.PJM(1).TAS(NI).RTKO(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = fmet this.PJM(1).TAS(NI).RTKO_INIT_TECH_PROP(NE)
          # ---------------------------------
          For NZ = 1 To maxtab(this.PJM(1).TAS(NI).RTKO(NE).RAFFT)
            If this.PJM(1).TAS(NI).RTKO(NE).RAFFT(NZ) <> null and find(this.PJM(1).TAS(NI).RTKO(NE).RAFFT(NZ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
              [L]ARET_VALUE = fmet this.PJM(1).TAS(NI).RTKO(NE).RAFFT_INIT_TECH_PROP(NZ)
            Endif
          Next NZ
        Endif
      Next NE
      # ---------------------------------
      For NE = 1 To maxtab(this.PJM(1).TAS(NI).SPLD)
        If this.PJM(1).TAS(NI).SPLD(NE) <> null and find(this.PJM(1).TAS(NI).SPLD(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = fmet this.PJM(1).TAS(NI).SPLD_INIT_TECH_PROP(NE)
        Endif
      Next NE
      # ---------------------------------
      For NE = 1 To maxtab(this.PJM(1).TAS(NI).PTLNK)
        If this.PJM(1).TAS(NI).PTLNK(NE) <> null and find(this.PJM(1).TAS(NI).PTLNK(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = fmet this.PJM(1).TAS(NI).PTLNK_INIT_TECH_PROP(NE)
        Endif
      Next NE
      # ---------------------------------
    Endif
  Next NI
  # ---------------------------------
  For NI = 1 To maxtab(this.PJM(1).SPLD)
    If this.PJM(1).SPLD(NI) <> null and find(this.PJM(1).SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE = fmet this.PJM(1).SPLD_INIT_TECH_PROP(NI)
    Endif
  Next NI
Return

#######################################################################################
$PJM_RESET_ERRORS
Local Integer NI
Local Integer NE
Local Integer NZ

  # ---------------------------------
  # Mandatory to do that from here. It's not possible to use AREAD_AFTER at each level because AREAD_AFTER
  # if going from the lower level to the upper lever. And in this case, the need is the opposite.
  # Maybe there is another way to do that, but I don't know it. :-(
  # ---------------------------------
  # Issue X3-96497 - 2018-06-28 by FGR : BEGIN : Moved in RESET_ERRORS method
  #[L]ARET_VALUE = fmet this.ADELETERRORALL()
  #
  #For NI = 1 To maxtab(this.SBB)
  #  [L]ARET_VALUE = fmet this.SBB(NI).ADELETERRORALL()
  #Next NI
  #For NI = 1 To maxtab(this.CPP)
  #  [L]ARET_VALUE = fmet this.CPP(NI).ADELETERRORALL()
  #Next NI
  # Issue X3-96497 - 2018-06-28 by FGR : END
  If this.PJM(1) <> null Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).ADELETERRORALL())
    For NI = 1 To maxtab(this.PJM(1).BUD)
      If this.PJM(1).BUD(NI) <> null and find(this.PJM(1).BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).BUD(NI).ADELETERRORALL())
        For NE = 1 To maxtab(this.PJM(1).BUD(NI).BUDLIG)
          If this.PJM(1).BUD(NI).BUDLIG(NE) <> null and find(this.PJM(1).BUD(NI).BUDLIG(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).BUD(NI).BUDLIG(NE).ADELETERRORALL())
          Endif
        Next NE
        For NE = 1 To maxtab(this.PJM(1).BUD(NI).SPLD)
          If this.PJM(1).BUD(NI).SPLD(NE) <> null and find(this.PJM(1).BUD(NI).SPLD(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).BUD(NI).SPLD(NE).ADELETERRORALL())
          Endif
        Next NE
      Endif
    Next NI
    For NI = 1 To maxtab(this.PJM(1).TAS)
      If this.PJM(1).TAS(NI) <> null and find(this.PJM(1).TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).TAS(NI).ADELETERRORALL())
        For NE = 1 To maxtab(this.PJM(1).TAS(NI).RITT)
          If this.PJM(1).TAS(NI).RITT(NE) <> null and find(this.PJM(1).TAS(NI).RITT(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).TAS(NI).RITT(NE).ADELETERRORALL())
          Endif
        Next NE
        For NE = 1 To maxtab(this.PJM(1).TAS(NI).RTKO)
          If this.PJM(1).TAS(NI).RTKO(NE) <> null and find(this.PJM(1).TAS(NI).RTKO(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).TAS(NI).RTKO(NE).ADELETERRORALL())
            For NZ = 1 To maxtab(this.PJM(1).TAS(NI).RTKO(NE).RAFFT)
              If this.PJM(1).TAS(NI).RTKO(NE).RAFFT(NZ) <> null and find(this.PJM(1).TAS(NI).RTKO(NE).RAFFT(NZ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
                [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).TAS(NI).RTKO(NE).RAFFT(NZ).ADELETERRORALL())
              Endif
            Next NZ
            For NZ = 1 To maxtab(this.PJM(1).TAS(NI).RTKO(NE).OPLNK)
              If this.PJM(1).TAS(NI).RTKO(NE).OPLNK(NZ) <> null and find(this.PJM(1).TAS(NI).RTKO(NE).OPLNK(NZ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
                [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).TAS(NI).RTKO(NE).OPLNK(NZ).ADELETERRORALL())
              Endif
            Next NZ
          Endif
        Next NE
        For NE = 1 To maxtab(this.PJM(1).TAS(NI).PTLNK)
          If this.PJM(1).TAS(NI).PTLNK(NE) <> null and find(this.PJM(1).TAS(NI).PTLNK(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).TAS(NI).PTLNK(NE).ADELETERRORALL())
          Endif
        Next NE
        For NE = 1 To maxtab(this.PJM(1).TAS(NI).SPLD)
          If this.PJM(1).TAS(NI).SPLD(NE) <> null and find(this.PJM(1).TAS(NI).SPLD(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).TAS(NI).SPLD(NE).ADELETERRORALL())
          Endif
        Next NE
      Endif
    Next NI
    For NI = 1 To maxtab(this.PJM(1).SPLD)
      If this.PJM(1).SPLD(NI) <> null and find(this.PJM(1).SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).SPLD(NI).ADELETERRORALL())
      Endif
    Next NI
    For NI = 1 To maxtab(this.PJM(1).PAF)
      If this.PJM(1).PAF(NI) <> null and find(this.PJM(1).PAF(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).PAF(NI).ADELETERRORALL())
      Endif
    Next NI
  Endif
Return

#######################################################################################
$PJM_INIT_TECH_PROP
  If this.PJM(1) <> null Then
    this.PJM(1).CUR = this.CUR
    this.PJM(1).OPPCMP = this.OPPCMP
    this.PJM(1).TCHCHGTYP = this.CHGTYP
    this.PJM(1).SALFCY = this.SALFCY
    this.PJM(1).CPY = this.CPY
  Endif
Return

#######################################################################################
$PJM_COPY
#Variable Instance TECCLA Using C_PJMACOPY : #
#Variable Char NEWSEQNUM ()
#Variable Char LOGERROR ()
#Local Integer ARET_VALUE

Local Instance LOGFILE Using C_ALOG
Local Integer STA

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------------------------------------------
  Raz NEWSEQNUM
  LOGFILE = NewInstance C_ALOG AllocGroup null
  If LOGERROR <> AVOID.ACHAR Then
    STA = fmet LOGFILE.APPENDLOG(LOGERROR)
  Else
    STA = fmet LOGFILE.ABEGINLOG("PROJECT_COPY_LOG" - this.OPPNUM)
  Endif
  TECCLA.CRMFLG = [V]CST_ANO
  # -----------------------------------------------------------------
  Local File PIMPL [PIM]
  # -----------------------------------------------------------------
  # Preliminary controls
  If fmet this.COM_IS_PJM_OPPOR() = [V]CST_AFALSE Then
    [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES1(mess(177,2260,1), mess(this.PIMPL.PIMTYP,2254,1)), [V]CST_AERROR)
  Endif
  If [L]ARET_VALUE < [V]CST_AERROR Then
    Read [PIM]PIM0=TECCLA.DESTAFF
    If !fstat Then
      TECCLA.CRMFLG = [V]CST_AYES
    Endif
  Endif
  # -----------------------------------------------------------------
  If [L]ARET_VALUE < [V]CST_AERROR Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._PJM_COPY(TECCLA, NEWSEQNUM, LOGFILE))
  Endif
  # -----------------------------------------------------------------
  If [L]ARET_VALUE >= [V]CST_AWARNING Then
    STA = fmet LOGFILE.APUTLINE(mess(1010,2260,1),[V]CST_AINFO)
    Call MSGSTACK_DUMP_MESSAGES_INTO_LOG(this, LOGFILE) From SYRSTACKTOOLS
    STA = fmet LOGFILE.AFLUSHLOG()
    STA = fmet LOGFILE.AENDLOG()
    LOGERROR = LOGFILE.NAME
  Endif
  # -----------------------------------------------------------------
  If LOGFILE <> null Then
    FreeGroup LOGFILE
  Endif
  # -----------------------------------------------------------------
Return

#######################################################################################
$_PJM_COPY
#Variable Instance TECCLA Using C_PJMACOPY : #
#Variable Char NEWSEQNUM ()
#Variable Instance LOGFILE Using C_ALOG : #
#Local Integer ARET_VALUE

Local Instance TARGET Using C_OPPOR
Local Instance TECPJMCOPY Using C_TECPJMCOPY
Local Integer NI
Local Integer NE
Local Integer ILINE
Local Integer ISRCLINE
Local Integer STA
Local Integer ICREATE
Local Integer IADXLOG
Local Char SPROJECT(GLONOPP)
Local Char SBUDGET(GLONPBU)
Local Char STASK(GLONTAC)
Local Integer IRET
Local Integer ITSKLINE
Local Integer NCDIE                               # Issue X3-95507 - 2018-06-12 by FGR

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------------------------------------------
  Raz NEWSEQNUM
  Raz TARGET
  Raz TECPJMCOPY
  # -----------------------------------------------------------------
  # 1°) Initialize new instance of the destination class
  TARGET = NewInstance C_OPPOR AllocGroup null
  If TECCLA.CRMFLG = [V]CST_ANO Then
    # Create a new project
    [L]ARET_VALUE = fmet TARGET.AINIT()
    TARGET.TCHTOREAD = "PJM"
  Else
    # Update a CRM project as a mixed one
    TARGET.TCHTOREAD = "PJM"
    [L]ARET_VALUE = fmet TARGET.AREAD(TECCLA.DESTAFF)
    If [L]ARET_VALUE >= [V]CST_AERROR Then
      Call MSGSTACK_COPY_TO(TARGET, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Endif
    this.PIMPL.TCHACTION = "STATUS"    # Issue X3-110479 - 2018-10-09 by FGR
  Endif
  # -----------------------------------------------------------------
  # 2°) The TARGET is promoted as PJM project (=> PJM or mixed, depending of the case)
  If [L]ARET_VALUE < [V]CST_AERROR Then
    [L]ARET_VALUE = fmet TARGET.COM_PROMOTE_PJM()
  Endif
  # -----------------------------------------------------------------
  If [L]ARET_VALUE < [V]CST_AERROR Then
    TECPJMCOPY = NewInstance C_TECPJMCOPY AllocGroup null
    [L]ARET_VALUE = fmet this.PJM_COPY_LOAD_PROPERTIES(TECPJMCOPY, TECCLA)
    If [L]ARET_VALUE >= [V]CST_AERROR Then
      Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Endif
  Endif
  # -----------------------------------------------------------------
  # 3°) Copy for the header
  If [L]ARET_VALUE < [V]CST_AERROR Then
    [L]ARET_VALUE = func TECPJMCOPY_CSTD.DO_COPY(TECPJMCOPY, TECCLA, this, TARGET)
    If [L]ARET_VALUE >= [V]CST_AERROR Then
      Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Endif
  Endif
  # -----------------------------------------------------------------
  # 4°) because the translated properties management, the Trbegin have to be at the copy method level
  Local File PIMPL [PIM]
  IADXLOG = adxlog
  If [L]ARET_VALUE < [V]CST_AERROR Then
    If !IADXLOG Then
      Trbegin [F:PIM]
    Endif
  Endif
  # -----------------------------------------------------------------
  # Issue X3-69664 - 2018-03-06 by FGR : BEGIN
  # 4.2°) Analytical dimension
  If [L]ARET_VALUE < [V]CST_AERROR Then
    If TECCLA.TCHREPDIECCE = [V]CST_AYES or TECCLA.TCHREPDIECCE = [V]CST_ANO Then
      TARGET.PJM(1).TCHREPDIECCE = TECCLA.TCHREPDIECCE
    Endif
    If TARGET.ASTALIN = [V]CST_ANEW or (TARGET.ASTALIN = [V]CST_AUPD and TARGET.PIMPL.snapshot.PIMTYP = 1) Then
      #   * Only on a new projet
      #   * or on a CRM project which become a mixt project.
      If fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.SALFCY, "LEGCPY") = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(TARGET.SALFCY, "LEGCPY") Then
        # Only if this is the same company
        Local File GDIE [DIE]
        For NI = 1 To maxtab(this.PJM(1).CDIE)
          If this.PJM(1).CDIE(NI) <> null and find(this.PJM(1).CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            Call LEC_DIE(this.PJM(1).CDIE(NI).DIE) From CPTLEC
            If [F:DIE]PJMFLG <> [V]CST_AYES Then
              # Issue X3-95507 - 2018-06-12 by FGR : BEGIN
              # This is not mandatory NI on both side. And structure could have changed
              #TARGET.PJM(1).CDIE(NI).CCE = this.PJM(1).CDIE(NI).CCE
              For NCDIE = 1 To maxtab(TARGET.PJM(1).CDIE)
                If TARGET.PJM(1).CDIE(NCDIE) <> null and find(TARGET.PJM(1).CDIE(NCDIE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
                  If TARGET.PJM(1).CDIE(NCDIE).DIE = this.PJM(1).CDIE(NI).DIE Then
                    TARGET.PJM(1).CDIE(NCDIE).CCE = this.PJM(1).CDIE(NI).CCE
                    Break
                  Endif
                Endif
              Next NCDIE
              # Issue X3-95507 - 2018-06-12 by FGR : END
            Endif
          Endif
        Next NI
      Endif
    Endif
  Endif
  # Issue X3-69664 - 2018-03-06 by FGR : END
  # -----------------------------------------------------------------
  # 5°) In case of to create a new project call immediatly AINSERT to have to right OPPNUM. (so after we will do an AUPDATE)
  If [L]ARET_VALUE < [V]CST_AERROR Then
    If TECCLA.CRMFLG = [V]CST_ANO Then
      # Create immediatly the new projet with only the header
      # Create a new project
      TARGET.OPPNUM = TECCLA.DESTAFF       # Note FGR : Imperative : to do just before AINSERT method call
      [L]ARET_VALUE = fmet TARGET.AINSERT()
      If [L]ARET_VALUE >= [V]CST_AERROR Then
        Call MSGSTACK_COPY_TO(TARGET, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
      Endif
      # and reload it the have the right OPPNUM value
      If [L]ARET_VALUE < [V]CST_AERROR Then
        NEWSEQNUM = TARGET.OPPNUM
        FreeGroup TARGET
        TARGET = NewInstance C_OPPOR AllocGroup null
        TARGET.TCHTOREAD = "PJM"
        [L]ARET_VALUE = fmet TARGET.AREAD(NEWSEQNUM)
        If [L]ARET_VALUE >= [V]CST_AERROR Then
          Call MSGSTACK_COPY_TO(TARGET, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
        Endif
      Endif
    Else
      NEWSEQNUM = TARGET.OPPNUM
    Endif
  Endif
  # -----------------------------------------------------------------
  # 6°) Get the translated texts at the header level
  If [L]ARET_VALUE < [V]CST_AERROR Then
    [L]ARET_VALUE = func TECPJMCOPY_CSTD.DO_COPY_AXX(TECPJMCOPY, TECCLA, this, TARGET)
    If [L]ARET_VALUE >= [V]CST_AERROR Then
      Call MSGSTACK_COPY_TO(TECPJMCOPY, TARGET) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
      Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS    # Get the error from the TARGET class into the this class
    Endif
  Endif
  # -----------------------------------------------------------------
  # 7°) Budgets Copy
  # -----------------------------------------------------------------
  For NI = 1 To maxtab(TECCLA.BUDGET)
    If TECCLA.BUDGET(NI) <> null and find(TECCLA.BUDGET(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If TECCLA.BUDGET(NI).SELBUD = [V]CST_AYES Then
        If fmet TARGET.PJM(1).BUD_GET_INDEX(fmet TECCLA.GET_BUDGET_RECODIFIED(TECCLA.BUDGET(NI).PBUCOD)) > 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(919,2260,1), fmet TECCLA.GET_BUDGET_RECODIFIED(TECCLA.BUDGET(NI).PBUCOD)), [V]CST_AERROR))
        Endif
      Endif
    Endif
  Next NI
  # -----------------------------------------------------------------
  If [L]ARET_VALUE < [V]CST_AERROR Then
    Repeat
      ICREATE = [V]CST_ANO
      For NI = 1 To maxtab(TECCLA.BUDGET)
        If TECCLA.BUDGET(NI) <> null and find(TECCLA.BUDGET(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If TECCLA.BUDGET(NI).SELBUD = [V]CST_AYES Then
            ISRCLINE = fmet this.PJM(1).BUD_GET_INDEX(TECCLA.BUDGET(NI).PBUCOD)
            If this.PJM(1).BUD(ISRCLINE) <> null and find(this.PJM(1).BUD(ISRCLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
              If fmet TARGET.PJM(1).BUD_GET_INDEX(fmet TECCLA.GET_BUDGET_RECODIFIED(this.PJM(1).BUD(ISRCLINE).PBUCOD)) = 0 Then
                # If the task has not yet been created in the duplicated project.
                If this.PJM(1).BUD(ISRCLINE).PBUPAE = AVOID.ACHAR or
&                 (this.PJM(1).BUD(ISRCLINE).PBUPAE <> AVOID.ACHAR and fmet TARGET.PJM(1).BUD_GET_INDEX(fmet TECCLA.GET_BUDGET_RECODIFIED(this.PJM(1).BUD(ISRCLINE).PBUPAE)) > 0) Then
                  # If there is no parent
                  # Or if the parent has already been created in the duplicated project.
                  ICREATE = [V]CST_AYES
                  ILINE = fmet TARGET.PJM(1).ADDLINE("BUD", [V]CST_ALASTPOS)
                  If ILINE = [V]CST_ANOTDEFINED Then
                    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(180,2260,1), [V]CST_AERROR))
                    Break
                  Endif
                  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).BUD(ISRCLINE).COPY(TARGET.PJM(1).BUD(ILINE), TECCLA, NI))
                Endif
              Endif
            Endif
          Endif
        Endif
      Next NI
    Until ICREATE = [V]CST_ANO
  Endif
  # -----------------------------------------------------------------
  # 8°) Tasks Copy
  # -----------------------------------------------------------------
  For NI = 1 To maxtab(TECCLA.TASK)
    If TECCLA.TASK(NI) <> null and find(TECCLA.TASK(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If TECCLA.TASK(NI).SELTAC = [V]CST_AYES Then
        If fmet TARGET.PJM(1).TAS_GET_INDEX(fmet TECCLA.GET_TASK_RECODIFIED(TECCLA.TASK(NI).TASCOD)) > 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(920,2260,1), fmet TECCLA.GET_TASK_RECODIFIED(TECCLA.TASK(NI).TASCOD)), [V]CST_AERROR))
        Endif
      Endif
    Endif
  Next NI
  # -----------------------------------------------------------------
  If [L]ARET_VALUE < [V]CST_AERROR Then
    Repeat
      ICREATE = [V]CST_ANO
      For NI = 1 To maxtab(TECCLA.TASK)
        If TECCLA.TASK(NI) <> null and find(TECCLA.TASK(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If TECCLA.TASK(NI).SELTAC = [V]CST_AYES Then
            ISRCLINE = fmet this.PJM(1).TAS_GET_INDEX(TECCLA.TASK(NI).TASCOD)
            If this.PJM(1).TAS(ISRCLINE) <> null and find(this.PJM(1).TAS(ISRCLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
              If fmet TARGET.PJM(1).TAS_GET_INDEX(fmet TECCLA.GET_TASK_RECODIFIED(this.PJM(1).TAS(ISRCLINE).TASCOD)) = 0 Then
                # If the task has not yet been created in the duplicated project.
                If this.PJM(1).TAS(ISRCLINE).TASPAE = AVOID.ACHAR or
&                 (this.PJM(1).TAS(ISRCLINE).TASPAE <> AVOID.ACHAR and fmet TARGET.PJM(1).TAS_GET_INDEX(fmet TECCLA.GET_TASK_RECODIFIED(this.PJM(1).TAS(ISRCLINE).TASPAE)) > 0) Then
                  # If there is no parent or if the parent has already been created in the duplicated project.
                  ICREATE = [V]CST_AYES
                  ILINE = fmet TARGET.PJM(1).ADDLINE("TAS",[V]CST_ALASTPOS)
                  If ILINE = [V]CST_ANOTDEFINED Then
                    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(181,2260,1), [V]CST_AERROR))
                    Break
                  Endif
                  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).TAS(ISRCLINE).COPY(TARGET.PJM(1).TAS(ILINE), TECCLA, NI))
                Endif
              Endif
            Endif
          Endif
        Endif
      Next NI
    Until ICREATE = [V]CST_ANO
    # Need to do this here and not in PJMTSK because we must be sure that linked task is existing, which is not yet the case in PJMTSK class
    If [L]ARET_VALUE < [V]CST_AERROR Then
      If TECCLA.TACLNK = [V]CST_ANO Then
        For NE = 1 To maxtab(this.PJM(1).TAS)
          If this.PJM(1).TAS(NE) <> null and find(this.PJM(1).TAS(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            For NI = 1 To maxtab(this.PJM(1).TAS(NE).PTLNK)
              If this.PJM(1).TAS(NE).PTLNK(NI) <> null and find(this.PJM(1).TAS(NE).PTLNK(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
                IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(this.ACTX, this.PJM(1).TAS(NE).PTLNK(NI).PIMOPPTASLNK, SPROJECT, SBUDGET, STASK)
                If SPROJECT = this.OPPNUM Then
                  # If on the same project
                  ITSKLINE = fmet TARGET.PJM(1).TAS_GET_INDEX(fmet TECCLA.GET_TASK_RECODIFIED(this.PJM(1).TAS(NE).TASCOD))
                  If ITSKLINE > 0 Then
                    # current task must exist on destination
                    If fmet TARGET.PJM(1).TAS_GET_INDEX(fmet TECCLA.GET_TASK_RECODIFIED(STASK)) > 0 Then
                      # Linked task must exist on destination
                      # ---------------------------
                      ILINE = fmet TARGET.PJM(1).TAS(ITSKLINE).ADDLINE("PTLNK", [V]CST_ALASTPOS)
                      If ILINE = [V]CST_ANOTDEFINED Then
                        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).TAS(NE).PTLNK(NI).SETERROR("", mess(1005,2260,1), [V]CST_AERROR))
                        Break
                      Endif
                      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).TAS(NE).PTLNK(NI).COPY(TARGET.PJM(1).TAS(ITSKLINE).PTLNK(ILINE), TECCLA, NI))
                      # ---------------------------
                    Endif
                  Endif
                Endif
              Endif
            Next NI
          Endif
        Next NE
      Endif
    Endif
  Endif
  # -----------------------------------------------------------------
  # 9°) Employee assignments Copy
  If [L]ARET_VALUE < [V]CST_AERROR Then
    For NI = 1 To maxtab(this.PJM(1).PAF)
      If this.PJM(1).PAF(NI) <> null and find(this.PJM(1).PAF(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        IFOUND = [V]CST_ANO
        For NE = 1 To maxtab(TARGET.PJM(1).PAF)
          If TARGET.PJM(1).PAF(NE) <> null and find(TARGET.PJM(1).PAF(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If this.PJM(1).PAF(NI).PAFCLB = TARGET.PJM(1).PAF(NE).PAFCLB Then
              IFOUND = [V]CST_AYES
              Break
            Endif
          Endif
        Next NE
        If IFOUND = [V]CST_ANO Then
          ILINE = fmet TARGET.PJM(1).ADDLINE("PAF",[V]CST_ALASTPOS)
          If ILINE = [V]CST_ANOTDEFINED Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(182,2260,1), [V]CST_AERROR))
            Break
          Endif
          ISRCLINE = NI
          If this.PJM(1).PAF(ISRCLINE) <> null and find(this.PJM(1).PAF(ISRCLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.PJM(1).PAF(NI).COPY(TARGET.PJM(1).PAF(ILINE), TECCLA, NI))
          Endif
        Endif
      Endif
    Next NI
  Endif
  # -----------------------------------------------------------------
  # Issue X3-69664 - 2018-03-06 by FGR : BEGIN : too late here
  # 10°) Analytical dimension
  #If [L]ARET_VALUE < [V]CST_AERROR Then
  #  If TECCLA.TCHREPDIECCE = [V]CST_AYES or TECCLA.TCHREPDIECCE = [V]CST_ANO Then
  #    TARGET.PJM(1).TCHREPDIECCE = TECCLA.TCHREPDIECCE
  #  Endif
  #  If TARGET.ASTALIN = [V]CST_ANEW or (TARGET.ASTALIN = [V]CST_AUPD and TARGET.PIMPL.snapshot.PIMTYP = 1) Then # Issue X3-49749 - 2017-08-25 by FGR
  #    # Issue X3-49749 - 2017-08-25 by FGR :
  #    #   * Only on a new projet
  #    #   * or on a CRM project which become a mixt project.
  #    If fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.SALFCY, "LEGCPY") = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(TARGET.SALFCY, "LEGCPY") Then
  #      # Only if this is the same company
  #      Local File GDIE [DIE]
  #      For NI = 1 To maxtab(this.PJM(1).CDIE)
  #        If this.PJM(1).CDIE(NI) <> null and find(this.PJM(1).CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
  #          Call LEC_DIE(this.PJM(1).CDIE(NI).DIE) From CPTLEC
  #          If [F:DIE]PJMFLG <> [V]CST_AYES Then
  #            TARGET.PJM(1).CDIE(NI).CCE = this.PJM(1).CDIE(NI).CCE
  #          Endif
  #        Endif
  #      Next NI
  #    Endif
  #  Endif
  #Endif
  # Issue X3-69664 - 2018-03-06 by FGR : END
  # -----------------------------------------------------------------
  # 9°) Update the project
  If [L]ARET_VALUE < [V]CST_AERROR Then
    TARGET.PJM(1).TASBUDAUT = this.PJM(1).TASBUDAUT        # Issue X3-67802 - 2018-07-24 by FGR : Mandatory just before .AINSERT.
                                                           # Early, all task without budget are going to be created with a new budget.
    [L]ARET_VALUE = fmet TARGET.AUPDATE()
  Endif
  # -----------------------------------------------------------------
  # 10°) Transaction management : depending of the success or not of AINSERT
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    If !IADXLOG Then
      Rollback
    Endif
  Else
    If !IADXLOG Then
      Commit
    Endif
  Endif
  If [L]ARET_VALUE >= [V]CST_AWARNING Then
    STA = fmet LOGFILE.APUTLINE(mess(1009,2260,1),[V]CST_AINFO)
    Call MSGSTACK_DUMP_MESSAGES_INTO_LOG(TARGET, LOGFILE) From SYRSTACKTOOLS
  Endif
  # -----------------------------------------------------------------
  If TARGET <> null Then
    FreeGroup TARGET
  Endif
  # -----------------------------------------------------------------
Return

#######################################################################################
$PJM_COPY_LOAD_PROPERTIES
#Variable Instance TECPJMCOPY Using C_TECPJMCOPY : #
#Variable Instance TECCLA Using C_PJMACOPY : #
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  If TECCLA.CRMFLG = [V]CST_ANO Then
    # Only when copy to create a new project
    If TECCLA.SALFCY <> this.SALFCY Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("#TECCLA.SALFCY", "SALFCY"))
    Else
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("SALFCY", AVOID.ACHAR))
    Endif
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("OPPEXTNUM", AVOID.ACHAR))
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("OPPCMP", AVOID.ACHAR))
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("OPPMCN", AVOID.ACHAR))
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("OPPTYP", AVOID.ACHAR))
    If TECCLA.CUR <> this.CUR Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD(">" + TECCLA.CUR, "CUR"))
    Else
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("CUR", AVOID.ACHAR))
    Endif
    If TECCLA.CHGTYP <> this.CHGTYP Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("#TECCLA.CHGTYP", "CHGTYP"))
    Else
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("CHGTYP", AVOID.ACHAR))
    Endif
    #
    If TECCLA.DESDES = "" or TECCLA.DESDES = this.PIMPL.PIMDESAXX Then
      # The originale description will be the new project description
      # Because this is a translater property, we have to copy all existing translated values
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD_AXX("PIMPL.PIMDESAXX", AVOID.ACHAR, "PIMPL", "PIMDESAXX", "PIMPL.PIMNUM", AVOID.ACHAR))
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD_AXX("PIMPL.PIMDESAX1", AVOID.ACHAR, "PIMPL", "PIMDESAX1", "PIMPL.PIMNUM", AVOID.ACHAR))
    Else
      # If the user give another description to the project : this description become the description for the new project
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD(">" + TECCLA.DESDES, "PIMPL.PIMDESAXX"))
    Endif
    If TECCLA.TACDAT = [V]CST_ANO Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PJM(1).STRDAT", AVOID.ACHAR))
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PJM(1).ENDDAT", AVOID.ACHAR))
    Endif
    If TECCLA.TACDUEDAT = [V]CST_ANO Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PJM(1).DUEDAT", AVOID.ACHAR))
    Endif
  Endif
  # --------------------
  # In all cases
  If TECCLA.OPEDEFFCY <> this.PJM(1).OPEDEFFCY Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("#TECCLA.OPEDEFFCY", "PJM(1).OPEDEFFCY"))
  Else
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PJM(1).OPEDEFFCY", AVOID.ACHAR))
  Endif
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PJM(1).OPPINT", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PJM(1).OPPFRT", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PJM(1).OPPPROACTIV", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PJM(1).CUROPP", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PJM(1).OPPIMPT", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PJM(1).OPPMOD", AVOID.ACHAR))
  If TECCLA.AFFDESC = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PJM(1).OPPDESTEX", AVOID.ACHAR))
  Endif
  If TECCLA.AFFCOM = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PJM(1).OPPCOMTEX", AVOID.ACHAR))
  Endif
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD(">COPY", "PJM(1).TCHACTION"))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("OPPNUM", "PJM(1).ORIOPP"))
Return

