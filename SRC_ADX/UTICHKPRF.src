#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICHKPRF   Utilitaire de vérification des profiles                    #
##########################################################################


Call MAJ_UTICHKPRF
End


Subprog MAJ_UTICHKPRF
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTICHKPRF - Check profiles") From SAIDOS
If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTICHKPRF : Check profiles") From LECFIC
  Call EXE_UTICHKPRF(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTICHKPRF(DOSSIER)
Value Char DOSSIER

# This utility can be run only :
#   on SKY environment: process server name finishes with '-app' & Solution name = "X3CLOUD"
#   or Mindo environnement: getenv$("PUBLICCLOUD")<>""
# If both conditions are false => it's not a environment to update
If not (  (pat(adxmac(-1),'*-app')=1 & GINSTID = 'X3CLOUD' )
&       | (getenv$("PUBLICCLOUD")<>"") )
    End
Endif

#-----
Call ECR_TIME("UTICHKPRF : Start checking profiles for folder"-DOSSIER) From DOSSUB
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
#-----
Local File =DOSSIER+".AFCTPRF"  [AFP]
Local File =DOSSIER+".AFCTPRF"  [AFP2]
Local Integer I
Local Char FORBIDDEN_FUNCTIONS(GLONAFC)(1..)
I+=1 : FORBIDDEN_FUNCTIONS(I) = "ACOPAPH"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "ADOTRT"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "ADXD"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "AECLIPSE"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "APATCH"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "APATCHA"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "AVISULIC"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "CHDOS"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "EXETRT"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "GESAPB"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "GESAPH"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "GESAPT"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "GESAPW"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "GESAWE"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "IMPDOS"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "PATCH"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "PATCHT"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "SYSTEME"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "TRTPROP"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "UTIBASE"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "GESAYH"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "GESANU"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "GESADLV"
I+=1 : FORBIDDEN_FUNCTIONS(I) = "GESADLK"

#-----
Trbegin [AFP]
For [AFP]AFP0(2) Where find(FNC,[L]FORBIDDEN_FUNCTIONS)<>0
    Call ECR_TRACE("Profile:"-[F:AFP]PRFCOD-"Function:"-[F:AFP]FNC-"Access:"-mess([F:AFP]ACS,1,1),0) From GESECRAN
    For [AFP]AFP0
        Delete [AFP2]AFP0=[F:AFP]PRFCOD;[F:AFP]FNC;[F:AFP]FCYGRU
        If fstat=[V]CST_AOK
            Call ECR_TRACE("FCYGRU='"+[F:AFP]FCYGRU+"' ---> deleted",0) From GESECRAN
        Else
            Call ECR_TRACE("FCYGRU='"+[F:AFP]FCYGRU+"' ---> can't be deleted (fstat="+num$(fstat)+")",1) From GESECRAN
        Endif
    Next
Next
Commit
#----- Fin du traitement -----#
$FIN_UTICHKPRF
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Call ECR_TIME("UTICHKPRF : Process ended") From DOSSUB
Close Local File [AFP]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
#If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call EXE_UTICHKPRF(APPLI)
End

