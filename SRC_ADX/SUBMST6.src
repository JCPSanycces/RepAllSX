##########################################################################################################
# gestion de l'écran MST6         module action commercial (CRM)
##########################################################################################################
##########################################################################################################
Subprog AS_MANASSSCT(VALEUR)
Variable Integer VALEUR

  GMENLOC(2) = 1
End

##########################################################################################################
Subprog AS_MANASSREP(VALEUR)
Variable Integer VALEUR
  GMENLOC(2) = 1
End

##########################################################################################################
Subprog AM_BPRMIN(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    [M:MST6]BPRMAX = VALEUR
    Affzo [M:MST6]BPRMAX
  Endif
End


