#<AdxTL>@(#)6.0.0.0 $Revision$ Librairies générateur de doc
###################################################################
# AGENLIB  
# Ensemble de procédures appelées depuis tous les programmes du générateur de DOC.
#
#  Prog splitté en deux car on a atteint a la limte
#  AGENLIB et AGENLIBA (à partir de la v7)
###################################################################
Local Char PARAM(30)(1..10) , VALEUR(30)
Call TRAITE_CHAR(VALEUR,PARAM,"","AGENLIB","AGENLIB",3,"") From GTRAITE
End

###################################################################
$ACTION
Case ACTION
 When "INIT_DIA"   : Gosub INIT_DIA From AGENLIBA
 When "CONTROLE"   : Gosub CONTROLE From AGENLIBA
 When "EXEC"       : Gosub EXEC     From AGENLIBA
Endcase
Return

######################################################################################
#     ETIQUETTES ECRANS
######################################################################################
Subprog AS_LAN(VALEUR)
Variable Char    VALEUR()
End


Subprog AM_LAN(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M:DIA]LANREF
        GERR = 1
        GMESSAGE = mess(54,176,1)
        SAI=1
        [S]mkstat=2
Endif
End


Subprog AM_LANREF(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M:DIA]LAN
        GERR = 1
        GMESSAGE = mess(54,176,1)
        SAI=1
        [S]mkstat=2
Endif
End

######################################################################################

Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TYP : Grizo TYP
 Effzo CODDEB , CODFIN : Grizo CODDEB , CODFIN
Else
 Actzo TYP , CODDEB , CODFIN
Endif
End

Subprog AS_TYP(VALEUR)
Variable Char VALEUR()
##If VALEUR=""
##   VALEUR="AFC"
##Endif
End

######################################################################################

Subprog C_ALLCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]CODDEB = "" : Affzo CODDEB : Grizo CODDEB
 [M]CODFIN = "" : Affzo CODFIN : Grizo CODFIN
Else
 Actzo CODDEB
 Actzo CODFIN
Endif
End

Subprog AM_ALLCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]HLPFIL=2 : Affzo HLPFIL
 [M]HLPLNKFLD=2 : Affzo HLPLNKFLD
Endif
End

Subprog AM_CODDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" and [M]CODFIN=""
    [M]CODFIN=VALEUR : Affzo [M]CODFIN
Endif
If VALEUR<>""
 [M]HLPFIL=2 : Affzo HLPFIL
 [M]HLPLNKFLD=2 : Affzo HLPLNKFLD
Endif
End

Subprog AS_CODFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:DIA]CODDEB
   If VALEUR=""
       VALEUR="X"
   Endif
Endif
End

Subprog AM_CODFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<>"X"
 [M]HLPFIL=2 : Affzo HLPFIL
 [M]HLPLNKFLD=2 : Affzo HLPLNKFLD
Endif
End


######################################################################################

Subprog AS_HLPFIL(VALEUR)
Variable Integer VALEUR
If ([M]TYP="" and [M]ALLTYP=1) or ([M]CODDEB="" and [M]CODFIN="" and [M]ALLCOD=1)
    [S]mkstat=1
Endif
End


######################################################################################

Subprog C_HLPFLD(VALEUR)
Variable Integer VALEUR
If VALEUR=1
    Effzo FLDDEB,FLDFIN
    Grizo FLDDEB,FLDFIN
Else
    Actzo FLDDEB , FLDFIN
Endif
End

Subprog AM_FLDDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" and [M]FLDFIN=""
    [M]FLDFIN=VALEUR : Affzo [M]FLDFIN
Endif
End

Subprog AM_FLDFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:DIA]FLDDEB
   If VALEUR=""
       VALEUR="X"
   Endif
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran AGENLIB) 19/10/2012 15:24:59 (JPGA)
######################################################################################
Subprog AV_ALLCREGRP(VALEUR)
Variable Integer VALEUR
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  #Le modèle "Traitement Standard-Boite de dialogue" ne permet pas chgfmt en INIT_DIA : on le fait donc en Avant-zone de champ
  Call AFFMASK_GROUPE("[M:DIA]ALLCREGRP") From AGENLIBA
End
######################################################################################

