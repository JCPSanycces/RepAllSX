#<AdxTL>@(#)3.0.0.0 $Revision$
#<AdxTJ>@(#)6.0.0.0 $Revision:   1.7  $
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End
################################################################################################
# HISTO = 1 => Historisation                                                                   #
#                                                                                              #
#              Les données passent d'APPLI vers HISAPL                                         #
#              Les données historisées sont supprimées d'APPLI                                 #
#              Uniquement des contrôles liés au dossier APPLI                                  #
#                                                                                              #
#                                                                                              #
# OKEPU  = 1 => Epuration                                                                      #
#                                                                                              #
#    Soit Epuration seule (OKEPU=1 et HISTO=0)                                                 #
#              Les données sont supprimées d'APPLI                                             #
#              Uniquement des contrôles liés au dossier APPLI.                                 #
#                                                                                              #
#    Soit Epuration suite à l'historisation (OKEPU=1 et HISTO=1)                               #
#              L'historisation a fait les vérifications nécessaires (cf HISTO=1)               #
#              L'épuration concerne donc le dossier HISAPL mais aucun contrôle sur ce dossier. #
# ---------------------------------------------------------------------------------------------#
#    MDJ - 17.07.2013 - FQ 91142 - Table 952 "en dur" dans les traitements au lieu de 962 (GTD_EVENT)
#    MDJ - 01.06.2012 - FQ-82485 - Corrections suite outil de vérification                                                                                                          #
################################################################################################
#####################################################################################################
# EPURPHY            Traitements des épurations    Module Immobilisations                             #
# --------------------------------------------------------------------------------------------------#
# Règles d'épuration/historisation                         MDJ 14/06/2011                           #
#  1- PHYELT      : Epuration des Elmts Phys. sortis san mvts en attente                            #
#  2- EVEPHY      : Epuration des événements sur Eléments Physiques                                #
# --------------------------------------------------------------------------------------------------#
#   Fonctions                        # Formules          Param                                      #
#   ===========                        ==========        =========                                  #
#   func EPURPHY.GETDATREF(PSOC)     # PHYELT            (CPY)                                      #
#   func EPURPHY.GETDATCLO_INF(PSOC) # EVEPHY            (CPY)                                      #
#   func EPURPHY.GETDATCLO_SUP(PSOC) # EVEPHY            (CPY)                                      #
#                                                                                                   #
#####################################################################################################

$ACTION

Case ACTION

  When "OUVRE"
    #-----------------------------------------#
    # Ouvertures des fichiers complémentaires #
    #-----------------------------------------#
    Case [F:AHI]COD
      When "PHYELT"                     : Gosub OUVRE_PHYELT
      When "EVEPHY"                     : Gosub OUVRE_EVEPHY
    Endcase

  When "FILTRE"
    #----------------------------------------------------------------------------#
    # Vérifications complémentaires si critères insuffisants (OK=0 pour refuser) #
    #----------------------------------------------------------------------------#
    Case [F:AHI]COD
      When "PHYELT"                     : Gosub FILTRE_PHYELT
      When "EVEPHY"                     : Gosub FILTRE_EVEPHY
    Endcase

  When "EPURE"
    #-------------------------------------------------------------------------#
    # Suppressions enregistrements tables complémentaires non liées à l'objet #
    #-------------------------------------------------------------------------#
    Case [F:AHI]COD
      When "PHYELT"                     : Gosub EPURE_PHYELT
      When "EVEPHY"                     : Gosub EPURE_EVEPHY
    Endcase

  When "HISTO"
    #-------------------------------------------------------------------------#
    # Suppressions enregistrements tables complémentaires non liées à l'objet #
    #-------------------------------------------------------------------------#
    Case [F:AHI]COD
      When "PHYELT"                      : Gosub HISTO_PHYELT
      When "EVEPHY"                     : Gosub HISTO_EVEPHY
    Endcase
  When "FERME"
    #-----------------------------------------#
    # Fermetures des fichiers complémentaires #
    #-----------------------------------------#
    Case [F:AHI]COD
      When "PHYELT"                     : Gosub FERME_PHYELT
      When "EVEPHY"                     : Gosub FERME_EVEPHY
    Endcase
Endcase

Return
######################################################################
#    Epuration des  Contrats de Location financement                 #
# -------------------------------------------------------------------#
# Sélection PHYELT   :                                                #
#  ISSDAT <> [0/0/0]
#                                                                    #
######################################################################
#-----------------------------------------#
# Ouvertures des fichiers complémentaires #
#-----------------------------------------#
$OUVRE_PHYELT

#----- Historisation -----#
If HISTO
  #----- Epuration après historisation -----#
  If OKEPU
    If !clalev([F:PHY])  Local File =[L]HISAPL+".PHYELT"      [PHY]  : Endif
    If !clalev([F:FAS])  Local File =[L]HISAPL+".FXDASSETS"  [FAS]  : Endif
  #----- Historisation -----#
  Else
    If !clalev([F:PHY])  Local File =[L]APPLI +".PHYELT"      [PHY]  : Endif
    If !clalev([F:FAS])  Local File =[L]APPLI +".FXDASSETS"  [FAS]  : Endif
  Endif
#----- Epuration sans historisation -----#
Else
  If !clalev([F:PHY])  Local File =[L]APPLI +".PHYELT"        [PHY]  : Endif
  If !clalev([F:FAS])    Local File =[L]APPLI +".FXDASSETS"  [FAS]  : Endif
Endif
#----- Ouverture tables complémentaires -----#
If clalev([F:ADI])=0   : Local File ATABDIV      [ADI]  : Endif    # tables diverses
# Si GADONIX=2 GTEST est forcé à 1 (dossier développement), pas de delete
# Si GADONIX=1 GTEST est forcé à 0, delete
# Forcer GTEST à 0 pour que les delete se fassent
#GTEST=0
#Infbox(GTRACE-"GTEST="+num$(GTEST))

Return
#-------------------------------------------------------------------------------#
# Vérifications complémentaires si critères insuffisants (OK=0 pour refuser)    #
#------------------------------------------------------------------------------ #
# Les enregistrements PHYELT ne peuvent être purgés que si les dates de rachat,  #
# de résiliation ou de fin de contrat appartiennent à un exercice clos          #
# et que cet exercice clos est antérieur ou égal au dernier exercice clos -3    #
#-------------------------------------------------------------------------------#
$FILTRE_PHYELT

Case TABLE
 When "PHYELT"       : FILTSUP = ""
 When  Default       : FILTSUP = ""
Endcase

Return
#-------------------------------------------------------------------------#
# Suppressions enregistrements tables complémentaires non liées à l'objet #
# ----------------------------------------------------------------------- #
$HISTO_PHYELT

#* - si le statut du contrat est "Echu", la date de fin de contrat doit être antérieure à la date
#* de début de l'exercice clos -3
#* - si le statut du contrat est "Rachat", la date de levée d'option d'achat doit être antérieure à la date
#* de début de l'exercice clos -3
#* - si le statut du contrat est "Résilié", la date de résiliation doit être antérieure à la date
#* de début de l'exercice clos -3.

Read [FAS]FAS0= [F:F1]AASREF
If fstat=0
   If [F:FAS]ISSDAT = [0/0/0] or [F:FAS]EXTISSFLG=G_OUI
      OKHIS = 0
   Endif
Endif

If OKHIS
   If !SIMUL
      #-----<L3>  Suppression événements s/PHY -----#
      #*Fq-91142  For [ADI] Where NUMTAB=952 & N2 = GVMLOMPHY
      For [ADI] Where NUMTAB=GTD_EVENT & N2 = GVMLOMPHY
         If !find([F:ADI]A2,GTABEVT)
            Goto $NEXT_EVTPHY
         Endif
         If clalev([F:EPHY])  : Close Local File [EPHY] : Endif
         Local File =[F:ADI]A2 [EPHY]
         Filter[EPHY] Where (CPY=[F:F1]CPY & REF=[F:F1]PHYREF)
         For [EPHY]EVE0
            Delete [EPHY] Where REF=[F:F1]PHYREF
            If fstat=1
               Call ECR_TRACE(num$(GTABEVT)-[F:EFS]REF-mess(10,100,1),1) From GESECRAN
            Else
               If fstat = 0 and TRACEDET
                 # "Evénements s/Eléments physiques historisés"
                 Call ECR_TRACE (num$([F:ADI]A2)-[F:EFS2]REF-mess(24,GML_MSGMIS,1),0) From GESECRAN
               Endif
            Endif
         Next
         Filter[EPHY]
         $NEXT_EVTPHY
      Next
      #-----</L3>
    #>>>>>>>>>>>>> Simulation
   Else
      #*Fq-91142 For [ADI] Where NUMTAB=952 & N2 = GVMLOMPHY
      For [ADI] Where NUMTAB=GTD_EVENT & N2 = GVMLOMPHY
         If !find([F:ADI]A2,GTABEVT)
            Goto NEXT_EVTPHYR
         Endif
         If clalev([F:ELE2])  : Close Local File [ELE2] : Endif
         Local File =[F:ADI]A2 [ELE2]
         Filter[ELE2] Where (CPY=[F:F1]CPY & REF=[F:F1]PHYELT)
         For [ELE2]
            L3 +=1
         Next
         Filter[ELE2]
         $NEXT_EVTPHYR
      Next
   Endif
   If TRACEDET and (L3 > 0)
      # "Evénements s/Eléments physiques "
      WMESSAGE = mess(24,GML_MSGMIS,1)- ":" - [F:F1]AASREF - mess(748,182,1) - ":" - [L]APPLI
      Call ECR_TRACE( WMESSAGE, 0) From GESECRAN
   Endif
Endif


Return
#-------------------------------------------------------------------------#
# Suppressions enregistrements tables complémentaires non liées à l'objet #
#-------------------------------------------------------------------------#
$EPURE_PHYELT

# Même contrôle que l'historisation
Local Integer SVG_OKHIS
SVG_OKHIS = OKHIS
OKHIS = OKEPU
Gosub HISTO_PHYELT
OKEPU = OKHIS
OKHIS = SVG_OKHIS

Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_PHYELT

  If clalev([F:FAS])>0 : Close Local File [FAS] : Endif

Return
######################################################################
#    Epuration des événements sur Contrats de Location financement   #
# -------------------------------------------------------------------#
# Formule EVEPHY  :                                                  #
#     (EVT = "EVEPHY")                                               #
#     & (EVTDAT<=(func EPURPHY.GETDATCLO(CPY)))                      #
######################################################################
#-----------------------------------------#
# Ouvertures des fichiers complémentaires #
#-----------------------------------------#
$OUVRE_EVEPHY

If clalev([F:ADI])=0   : Local File ATABDIV      [ADI]  : Endif    # tables diverses

Return
#-------------------------------------------------------------------------------#
# Vérifications complémentaires si critères insuffisants (OK=0 pour refuser)    #
#------------------------------------------------------------------------------ #
# Les enregistrements DEPREC ne peuvent être purgés que si :                    #
# - ils appartiennet à un exercice clos                                         #
# - que cet exercice clos est antérieur ou égal au dernier exercice clos -3     #
#-------------------------------------------------------------------------------#
$FILTRE_EVEPHY

Case TABLE
 When  Default      : FILTSUP = ""
Endcase

Return
#-------------------------------------------------------------------------#
# Suppressions enregistrements tables complémentaires non liées à l'objet #
# ----------------------------------------------------------------------- #
$HISTO_EVEPHY


#* - La date d'effet de l'événement doit être <= date de fin de l'exercice clos

If [F:F1]EVTDAT > (func EPURPHY.GETDATCLO_SUP ([F:F1]CPY,G300CPFI))
 OKHIS = 0
Endif


Return
#-------------------------------------------------------------------------#
# Suppressions enregistrements tables complémentaires non liées à l'objet #
#-------------------------------------------------------------------------#
$EPURE_EVEPHY


# Même contrôle que l'historisation
Local Integer SVG_OKHIS
SVG_OKHIS = OKHIS
OKHIS = OKEPU
Gosub HISTO_EVEPHY
OKEPU = OKHIS
OKHIS = SVG_OKHIS


Return
#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_EVEPHY

If clalev([F:FAS])   Close Local File [FAS]  : Endif

Return
#**********************************************#
#                 FONCTIONS                    #
#**********************************************#
#################################################################################################
# Fonction :  GETDATREF(PSOC)                                                                       #
#  -> Récupère dans la formule d'histo/épuration la date permettant de filtrer les enreg DEPREC #
#     à traiter en fonction de chaque contexte                                                  #
#################################################################################################
Funprog GETDATREF(PSOC)

 Value Char    PSOC
 Local Char    LSOC
 Local Date    CPYSTRFIY(1..G300MAX)
 Local Date    CPYENDFIY(1..G300MAX)
 Local Integer CPYFLGPER(1..G300MAX)
 Local Date    CPYSTRPER(1..G300MAX)
 Local Date    CPYENDPER(1..G300MAX)
 Local Integer RETOUR
 Local Integer I_CNX
 Local Integer N_EXE
 Local Date    CNXDATMAX
 Local Date    LWDAT
 Local Date    DATREF

LSOC=PSOC

#----- Récupération des dates de fin d'exercice courant de chaque contexte  -----#
#Fq-82485 Call GET_CPY_DAT(LSOC,CPYSTRFIY,CPYENDFIY,CPYFLGPER,CPYSTRPER,CPYENDPER,RETOUR) From GLOBIENS
Call GET_CPY_DAT(LSOC,CPYSTRFIY,CPYENDFIY,CPYSTRPER,CPYENDPER,RETOUR) From GLOBIENS


#===================================================================
# Récupération de la valeur du paramètre NBEXNOTHIS du chapitre "FIN"
#===================================================================
#
#Local Char L_PARAM
Local Integer I_PARAM

# Call PARAM("","NBEXNOTHIS",L_PARAM) From ADOVAL
# I_PARAM=val(L_PARAM)

 I_PARAM=GGRTNOHIS

 If I_PARAM > 0 Then
   N_EXE = I_PARAM
 Else
  N_EXE = 3
 Endif


If CPYSTRFIY(1) <> [0/0/0]
  CNXDATMAX = gdat$(day(CPYSTRFIY(1)), month(CPYSTRFIY(1)), year(CPYSTRFIY(1))- N_EXE)
Endif

For I_CNX=2 To G300MAX
 If CPYSTRFIY(I_CNX)<>[0/0/0]
   LWDAT = gdat$(day(CPYSTRFIY(I_CNX)), month(CPYSTRFIY(I_CNX)), year(CPYSTRFIY(I_CNX))- N_EXE)
   If LWDAT <  CNXDATMAX
      CNXDATMAX = LWDAT
   Endif
  Endif
Next I_CNX

If CNXDATMAX > [0/0/0]
  DATREF = CNXDATMAX
Endif


End DATREF
#==============
#################################################################################################
# Fonction :  GETDATCLO(PSOC)                                                                 #
#  -> Récupère dans la formule d'histo/épuration la date permettant de fin du dernier exercice  #
#     clos du contexte comptable et fiscal                                                      #
#################################################################################################
Funprog GETDATCLO(PSOC)

Value Char    PSOC
Local Char    LSOC
Local Date    DATINF
Local Integer PRET
Local Date    LCNXDAT(1..5)
Local Date    DATEXCLO

LSOC=PSOC

#
# on récupère la date de fin du dernier exercice clos
# du contexte comptable et fiscal dans LCNXDAT(5)
Call GET_CNX_DAT(LSOC,1,LCNXDAT,PRET) From GLOBIENS

#
# la formule va prendre en compte les enreg ayant EVTDAT <= LCNXDAT(5)
#
If LCNXDAT(5) <> [0/0/0]
  DATINF=LCNXDAT(5)
  DATEXCLO =  gdat$(day(DATINF), month(DATINF), year(DATINF))
Endif


End DATEXCLO
#==============
#################################################################################################
# Fonction :  GETDATCLO_INF(PSOC, PCNX)                                                         #
#  -> Récupère dans la formule d'histo/épuration la date de débutd e l'exercice clos            #
#################################################################################################
Funprog GETDATCLO_INF(PSOC,PCNX)

Value Char    PSOC
Value Integer PCNX
Local Date    DATINF
Local Date    DATSUP
Local Char    LSOC
Local Integer LCNX
Local Integer RCNX
Local Integer PRET
Local Date    LCNXDAT(1..5)

LSOC=PSOC
LCNX=PCNX

#
# on récupère la date de fin du dernier exercice clos dans LCNXDAT(5)
#
Call GET_CNX_DATPREC(LSOC,LCNX,GVML_TEPREC,LCNXDAT,PRET)

#
# la formule va prendre en compte les enreg ayant FIYENDDAT >= LCNXDAT(1)
#
If LCNXDAT(1) <> [0/0/0]
  DATINF=LCNXDAT(1)
Endif


End DATINF
#==============
#################################################################################################
# Fonction :  GETDATCLO_SUP(PSOC, PCNX)                                                         #
#  -> Récupère dans la formule d'histo/épuration la date de fin de l'exercice clos              #
#################################################################################################
Funprog GETDATCLO_SUP(PSOC,PCNX)

Value Char    PSOC
Value Integer PCNX
Local Date    DATINF
Local Date    DATSUP
Local Char    LSOC
Local Integer LCNX
Local Integer RCNX
Local Integer PRET
Local Date    LCNXDAT(1..5)

LSOC=PSOC
LCNX=PCNX

#
# on récupère la date de fin du dernier exercice clos dans LCNXDAT(5)
#
Call GET_CNX_DATPREC(LSOC,LCNX,GVML_TEPREC,LCNXDAT,PRET)

#
# la formule va prendre en compte les enreg ayant FIYENDDAT <= LCNXDAT(2)
#
If LCNXDAT(2) <> [0/0/0]
  DATSUP=LCNXDAT(2)
Endif


End DATSUP
#==============
#---------------------------------------------------------------------
# Récupération des dates d'un contexte dans la variable dimensionnée
# PCNXDAT :
#
#  1 Date de début d'exercice clos
#  2 Date de fin d'exercice clos
#
#---------------------------------------------------------------------
Subprog GET_CNX_DATPREC(PCPY, PCNX, PEXE, PCNXDAT, PRET)
Value    Char    PCPY
Value    Integer PCNX
Value    Integer PEXE
Variable Date    PCNXDAT(1..5)
Variable Integer PRET

 If !(clalev([F:FIY])) : Local File FISCYEAR [FIY] : Endif
 Filter [FIY] Where CPY=PCPY & CNX=PCNX & STAFIY=PEXE
 Read [FIY]FIY0 Last : Filter [FIY]
 If fstat
  PRET=-1
  End
 Endif
 PCNXDAT(1)=[F:FIY]DATSTRFIY
 PCNXDAT(2)=[F:FIY]DATENDFIY
End
#=============
