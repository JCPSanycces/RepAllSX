#<AdxTL>@(#)11.0.0.0 $Revision$
#######################################################################
#             TRAITEMENTS COMMUNS X3 : COMPTEURS [F:TCA]              #
#######################################################################
# Subprog NUMERO(IMODULE,ICODNUM,LCODNUM,LFCY,LDAT,LCOD,VCRNUM,STAT)  #
#     Multi-société Beryl:                                            #
#     recherche du compteur approprié et affectation du numéro        #
#######################################################################


#######################################################################
# Subprog NUMERO(IMODULE,ICODNUM,LCODNUM,LFCY,LDAT,LCOD,VCRNUM,STAT)  #
#   IMODULE   No de module X3                                         #
#   ICODNUM   Indice du compteur                                      #
#   LCODNUM   Code du compteur par défaut                             #
#   LFCY      Site                                                    #
#   LDAT      Date                                                    #
#   LCOD      Code complémentaire                                     #
#   VCRNUM    Valeur du compteur (en entrée/sortie)                   #
#   STAT      Code retour                                             #
#######################################################################
Subprog NUMERO(IMODULE,ICODNUM,LCODNUM,LFCY,LDAT,LCOD,VCRNUM,STAT)
Value    Integer IMODULE
Value    Integer ICODNUM
Value    Char    LCODNUM
Value    Char    LFCY
Value    Date    LDAT
Value    Char    LCOD
Variable Char    VCRNUM()
Variable Integer STAT

Local    Char    WCODNUM
Local    Integer WMANCOU, WRET, WOK

If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif 

If [F:TCA]MODULE<>IMODULE | [F:TCA]CPY<>GSOCIETE
   Call LECTCA(IMODULE,WOK) From SUBTCA
   If WOK=0 
      GMESSAGE = mess(58,105,1)-mess(IMODULE,14,1)-":"-mess(250,199,1)
      STAT=1 : GERR=1 : GOK=0 : End 
   Endif 
Endif 

If [F:TCA]CODNUM(ICODNUM)<>"" 
   WCODNUM = [F:TCA]CODNUM(ICODNUM) 
   WMANCOU = [F:TCA]MANCOU(ICODNUM)   # compteur manuel ?
Else
   WCODNUM = LCODNUM 
   WMANCOU = 2                        # compteur manuel ?
Endif

If WMANCOU <> 2 | (WMANCOU = 2 & vireblc(VCRNUM,2) = "")
   Call NUMERO(WCODNUM,LFCY,LDAT,LCOD,VCRNUM,WRET) From SUBANM 
   If GOK < 0 : End : Endif  
Endif    
If WRET
   Case WRET
     When 1  : GMESSAGE = WCODNUM -":"-mess(12,114,1)  : # Compteur inexistant
     When 2  : GMESSAGE = WCODNUM -":"-mess(13,114,1)  : # Dépassement de compteur
     When 3  : GMESSAGE = WCODNUM -":"-mess(20,101,1)  : # Exercice non ouvert
     When 4  : GMESSAGE = WCODNUM -":"-mess(111,123,1) : # Longueur incorrecte
     When 99 : GMESSAGE = WCODNUM -":"-mess(135,133,1) : # Compteur verrouillé
   Endcase
   STAT=WRET : GERR=1 : GOK=0 : End
Endif

End
