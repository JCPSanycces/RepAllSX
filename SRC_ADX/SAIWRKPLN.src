#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char PARAM(250)(1..4) , VALEUR(10)
PARAM(1) = ""
PARAM(2) = ""
PARAM(3) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SAIWRKPLN","LISWRKTRN",5,"") From GTRAITE
End

#-----------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC

 When "OUVRE"       : Gosub OUVRE
 When "TITRE"       : Gosub TIT
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "BOUTON"      : Gosub BOUTON
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "TRN"         : Gosub TRANSAC
 When "RAF"         : Gosub RECHERCHE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "FIN_LISTE"   : Gosub FIN_LISTE
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

#-------------------  GTRAITE  -----------------------------#
$INIT
If clalev([F:AWW])=0 : Local File AWRKTRN    [AWW] : Endif
If clalev([F:AWD])=0 : Local File AWRKTRND   [AWD] : Endif
If clalev([F:AWF])=0 : Local File AWRKPARF   [AWF] : Endif
If clalev([F:AWS])=0 : Local File AWRKHISSUI [AWS] : Endif
If clalev([F:AWG])=0 : Local File AWRKHISMES [AWG] : Endif
If clalev([F:AWO])=0 : Local File AWRKHISDES [AWO] : Endif
If clalev([F:AWU])=0 : Local File AWRKUSR    [AWU] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif
If clalev([F:AOB])=0 : Local File AOBJET     [AOB] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
Return

#---------------------------#
$CONTROLE
Local Char TRN(GLONAWW) , AUZ(23)
TRN = VALEUR
Read [AWW]AWW0 = TRN
If fstat : FIN = 1 : Return : Endif
Call DROITSITE("",AUZ,OK) From EXEFNC
If !OK : FIN = 1 : Return : Endif
Gosub SET_PREF From SUBAWW
BOITE = PREF+TRN
Return

#---------------------------#
$EXEC
If PARAM(1)="TRANSAC"
 PARAM(1) = ""
 SAI = 1
Endif
Return

#-------------------  GSAISIE  -----------------------------#
$OUVRE
Local Integer M , OPTION , PAG(1..8) , MAXPAG(1..8)
Local Char    NBRDAY(10) , PROGWRK(GLONADC) , TRN(GLONAWW)
Local Char    FILTPAG(250)(1..8) , FILTSUP(250) , CLELISTE(250) , FILTSAI(250)(1..8)
Local Char    CHAINE(250) , INTFOLD(50)(1..8)
Local Integer DELEXP
Local Char    NUMORG(GLONVCR) , CHRONO(GLONVCR)
Local Mask    AWPX [AWPX]
Gosub SET_PREF From SUBAWW
TRN = right$(BOITE,len(PREF)+1)
PROGWRK = PREF+TRN
Gosub INIT From =PROGWRK
Return

#---------------------------#
$TIT
Raz INTFOLD
For M=1 To NBRMSK
 Call LECTEXTRA(INTFOLD(M),"AWRKTRND","INTSHO",[L]TRN,num$(M)) From ATEXTRA
Next M
Read [AWW]AWW0 = TRN
Call LECTEXTRA(TIT,"AWRKTRN","INTIT",TRN,"") From ATEXTRA
TIT -= "("+TRN+")"
Return

#---------------------------#
$DEBUT
Call PARAMUTIL("WRKDAY",NBRDAY,GUSER,"") From SUBAUS
If PARAM(2)<>"" & PARAM(3)<>""
 [M:AWP0]DATDEB = PARAM(2)
 [M:AWP0]DATFIN = PARAM(3)
Else
 [M:AWP0]DATDEB = date$-val(NBRDAY)
 [M:AWP0]DATFIN = date$
Endif
Call DROITSITE("",[M]AUZ,OK) From EXEFNC
Raz [M:AWP0]TABDEL
I = 0
For [AWU] Where TYPDEL=3 & USRDEL=GUSER
 If !find([F:AWU]USER+"~"+[F:AWU]NATURE,[M:AWP0]TABDEL(0..I-1))
  If I<dim([M:AWP0]TABDEL)
   I += 1
   [M:AWP0]TABDEL(I-1) = [F:AWU]USER+"~"+[F:AWU]NATURE
  Endif
 Endif
Next AWU
[M:AWP0]NBRDEL = I
[M:AWP0]DELEXP = 1
Affzo [AWP0]DELEXP
If !instr(1,[M]AUZ,"G") | [M:AWP0]NBRDEL=0
 Grizo [AWP0]DELEXP
Else
 Actzo [AWP0]DELEXP
Endif
Gosub GRISE_USR
Affzo [AWP0]5
For M=1 To NBRMSK
 Case M
  When 1 : Gosub TIT_COL_1 From =PROGWRK
  When 2 : Gosub TIT_COL_2 From =PROGWRK
  When 3 : Gosub TIT_COL_3 From =PROGWRK
  When 4 : Gosub TIT_COL_4 From =PROGWRK
  When 5 : Gosub TIT_COL_5 From =PROGWRK
  When 6 : Gosub TIT_COL_6 From =PROGWRK
  When 7 : Gosub TIT_COL_7 From =PROGWRK
  When 8 : Gosub TIT_COL_8 From =PROGWRK
 Endcase
Next M
Gosub RECHERCHE
zonsui = "NBLIG"
Return

#---------------------------#
$GRISE_USR
If !instr(1,[M]AUZ,"U") and [M:AWP0]DELEXP<>2
 [M:AWP0]USER  = GUSER
 Affzo [AWP0]USER
 Diszo [AWP0]USER
Else
 Actzo [AWP0]USER
Endif
Return

#---------------------------#
$SETBOUT
If instr(1,CHBOU,"=")=0 : CHBOU += "="  : Endif
If instr(1,CHBOU,"T")=0 : CHBOU += "T"  : Endif : # Transaction
Return

#---------------------------#
$TRANSAC
PARAM(1) = "TRANSAC"
FIN = 1
Return

#---------------------------#
$BOUTON
Case BOUT
 When "R" : Gosub RECHERCHE : # Recherche
Endcase
Return

#---------------------------#
$RECHERCHE
Raz IFILSUITE , FILSUITE
Raz FILTSUP
[L]DELEXP = ([M:AWP0]DELEXP=2)
If [M:AWP0]USER<>""
 FILTSUP += 'DEST="'+[M:AWP0]USER+'"'
Endif
If [M:AWP0]DATDEB<>[0/0/0]
 If FILTSUP<>"" : FILTSUP += " & " : Endif
 FILTSUP += 'DATENV>=['+format$(GFMD,[M:AWP0]DATDEB)+']'
Endif
If [M:AWP0]DATFIN<>[0/0/0]
 If FILTSUP<>"" : FILTSUP += " & " : Endif
 FILTSUP += 'DATENV<=['+format$(GFMD,[M:AWP0]DATFIN)+']'
Endif
For M=1 To NBRMSK
 Gosub MAXPAG
Next M
Raz PAG

GPOINT = "LOADPAGE" : Gosub ENTREE From EXEFNC

For M=1 To NBRMSK
 PAG(M) = 1
 Gosub CHARGE
Next M
Return

#---------------------------#
$MAXPAG
Gosub SET_FOLD
If FILTSUP=""    : FILTSUP    = "1=1" : Endif
If FILTPAG=""    : FILTPAG    = "1=1" : Endif
If FILTSAI(M)="" : FILTSAI(M) = "1=1" : Endif
Filter [AWS]
& Where evalue(FILTPAG) & evalue(FILTSUP) & evalue(FILTSAI(M))
& Order With CLELISTE
I = 0
For [AWS]
 OK = ![L]DELEXP
 If [M:AWP0]NBRDEL>0
  OK += find([F:AWS]DEST+"~",[M:AWP0]TABDEL(0..[M:AWP0]NBRDEL-1))
  OK += find([F:AWS]DEST+"~"+[F:AWS]NATURE,[M:AWP0]TABDEL(0..[M:AWP0]NBRDEL-1))
 Endif
 If OK
  I += 1
 Endif
Next AWS
Filter [AWS]
MAXPAG(M) = int((I-1)/MAXLIG)+1
Return

#---------------------------#
$CHARGE
Gosub SET_FOLD
If FILTSUP=""    : FILTSUP    = "1=1" : Endif
If FILTPAG=""    : FILTPAG    = "1=1" : Endif
If FILSUITE=""   : FILSUITE   = "1=1" : Endif
If FILTSAI(M)="" : FILTSAI(M) = "1=1" : Endif
Filter [AWS]
& Where evalue(FILTPAG) & evalue(FILTSUP) & evalue(FILSUITE) & evalue(FILTSAI(M))
& Order With CLELISTE
nolign = 0
For [AWS]
 OK = ![L]DELEXP
 If [M:AWP0]NBRDEL>0
  OK += find([F:AWS]DEST+"~",[M:AWP0]TABDEL(0..[M:AWP0]NBRDEL-1))
  OK += find([F:AWS]DEST+"~"+[F:AWS]NATURE,[M:AWP0]TABDEL(0..[M:AWP0]NBRDEL-1))
 Endif
 If OK
  If nolign>=MAXLIG
   Break
  Endif
  nolign += 1
  [M] = [F:AWS]
 Endif
Next AWS
Filter [AWS]
[M]NBLIG = nolign
[M]PAGCUR = mess(16,100,1)-num$(PAG(M))+"/"+num$(max(1,MAXPAG(M))) : # Page
Affzo
Default [F] , [M] , [S] , [V] , [L]
For nolign=1 To [M]NBLIG
 [F:AWS] = [M]
 Onerrgo ERR
 Case M
  When 1 : Gosub STYLE_1 From =PROGWRK
  When 2 : Gosub STYLE_2 From =PROGWRK
  When 3 : Gosub STYLE_3 From =PROGWRK
  When 4 : Gosub STYLE_4 From =PROGWRK
  When 5 : Gosub STYLE_5 From =PROGWRK
  When 6 : Gosub STYLE_6 From =PROGWRK
  When 7 : Gosub STYLE_7 From =PROGWRK
  When 8 : Gosub STYLE_8 From =PROGWRK
 Endcase
 Onerrgo
Next nolign
Default [L] , [V] , [S] , [F] , [M]
Return

$ERR
ER = errn
Resume

#---------------------------#
$SET_FOLD
Default File [AWS]
Case M
 When 1 : Default Mask [AWP1] : Gosub SET_FOLD_1 From =PROGWRK
 When 2 : Default Mask [AWP2] : Gosub SET_FOLD_2 From =PROGWRK
 When 3 : Default Mask [AWP3] : Gosub SET_FOLD_3 From =PROGWRK
 When 4 : Default Mask [AWP4] : Gosub SET_FOLD_4 From =PROGWRK
 When 5 : Default Mask [AWP5] : Gosub SET_FOLD_5 From =PROGWRK
 When 6 : Default Mask [AWP6] : Gosub SET_FOLD_6 From =PROGWRK
 When 7 : Default Mask [AWP7] : Gosub SET_FOLD_7 From =PROGWRK
 When 8 : Default Mask [AWP8] : Gosub SET_FOLD_8 From =PROGWRK
Endcase
Return

#---------------------------#
$APRES_MODIF
Case zoncou
 When "DATFIN"
  [M]DATFIN = zc
  Gosub RECHERCHE
 When Default
  Case status
   When 178 : # Clic sur icône
    M = val(right$(maskcou,len(maskcou)))
    Case num$(zc)
     When "9"  : # First
      Raz IFILSUITE , FILSUITE
      PAG(M) = 1
      Gosub CHARGE
     When "10" : # Précedent
      Gosub SET_FOLD
      nolign = 1
      [F:AWS] = [M]
      Call SUIGAUCHE("<",MAXLIG,CLELISTE,FILTPAG,FILTSUP,FILTSAI(M),IFILSUITE,FILSUITE,OK)
      If PAG(M)>1 : PAG(M) -= 1 : Endif
      Gosub CHARGE
     When "11" : # Suivant
      Gosub SET_FOLD
      nolign = [M]NBLIG
      [F:AWS] = [M]
      Call SUIGAUCHE(">",MAXLIG,CLELISTE,FILTPAG,FILTSUP,FILTSAI(M),IFILSUITE,FILSUITE,OK)
      If OK
       PAG(M) += 1
      Else
       PAG(M) = MAXPAG(M)
      Endif
      Gosub CHARGE
     When "12" : # Dernier
      Gosub SET_FOLD
      If FILTSUP=""    : FILTSUP    = "1=1" : Endif
      If FILTPAG=""    : FILTPAG    = "1=1" : Endif
      If FILTSAI(M)="" : FILTSAI(M) = "1=1" : Endif
      Filter [AWS] Where evalue(FILTPAG) & evalue(FILTSUP) & evalue(FILTSAI(M)) Order With CLELISTE
      Read [AWS] Last
      Call SUIGAUCHE("<",MAXLIG-2,CLELISTE,FILTPAG,FILTSUP,FILTSAI(M),IFILSUITE,FILSUITE,OK)
      PAG(M) = MAXPAG(M)
      Gosub CHARGE
     When "147" : # Critères
      [M:AWPX]CRITERE = FILTSAI(M)
      Call DIALWIN(OK,mess(174,124,1),"AWPX") From GESECRAN : # Critères de sélection
      If OK<>2 : Return : Endif
      ER = 0
      Onerrgo ERR
      Filter [AWS] Where evalue([M:AWPX]CRITERE)
      Read [AWS] Last
      Filter [AWS]
      Onerrgo
      If ER
       # Erreur sur critère de sélection
       Call ERREUR(mess(33,100,1)+"\"+errmes$(ER)+"\|"+errm+"|") From GESECRAN
       Return
      Endif
      FILTSAI(M) = [M:AWPX]CRITERE
      Raz IFILSUITE , FILSUITE
      Gosub MAXPAG
      PAG(M) = 1
      Gosub CHARGE
    Endcase
   When 134 , 135 : # Clic sur boutons B6 B7
    Read [AWS]AWS0 = [M]CHRONO(nolign-1);[M]DEST(nolign-1)
    [M] = [F:AWS]
    Affzo [M]
   When 136 : # Clic sur bouton B8
    [L]CHRONO = [M]CHRONO(nolign-1)
    If [M]NUMORG(nolign-1)<>"" : # Signature sur évènement déclenchant
     [L]NUMORG = [M]NUMORG(nolign-1)
    Else
     [L]NUMORG = [M]CHRONO(nolign-1)
    Endif
    For nolign=1 To [M]NBLIG
     If [M]CHRONO(nolign-1)=[L]CHRONO or [M]NUMORG(nolign-1)=[L]NUMORG
      Read [AWS]AWS0 = [M]CHRONO(nolign-1);[M]DEST(nolign-1)
      [M] = [F:AWS]
     Endif
    Next nolign
    Affzo [M]
  Endcase
Endcase
Return

#--------------------------------------------------------------------------------------------------------#
Subprog SUIGAUCHE(SENS,MAXLIG,CLELISTE,FILTPAG,FILTSUP,FILTSAI,IFILSUITE,FILSUITE,OK)
Value    Char    SENS
Value    Integer MAXLIG
Value    Char    CLELISTE
Value    Char    FILTPAG
Value    Char    FILTSUP
Value    Char    FILTSAI
Variable Integer IFILSUITE
Variable Char    FILSUITE()()
Variable Integer OK
If CLELISTE="" : End : Endif
Local Integer I , J , K , T , NBCLE , SNSLIS
Local Char    VALC(80)(1..16) , ACTION(20)
Local Char    CLELIS(30)(1..16) , ASCDES(10) , CHAINE(250)
Local Char    ZONCLE(30) , ZONCLE2(30)
Local Integer ICRITBUF , IFILPREV , IFILSAV , DIMS , DIMB , PRE
DIMS = dim(FILSUITE)-1
DIMB = dim(FILTPAG)-1
Local Char    CRITBUF(250)(0..DIMB)
Local Char    FILTRE(250)(0..DIMS) , FILSAV(250)(0..DIMS) , FILPREV(250)(0..DIMS)
If GTYPDBA=1 & dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 Gosub SET_FIRST From GOBJACT
Endif
Raz CLELIS, NBCLE, SNSLIS
CHAINE = CLELISTE
While CHAINE<>""
 I = instr(1,CHAINE,";")
 NBCLE += 1
 If I
  CLELIS(NBCLE) = vireblc(left$(CHAINE,I-1),2)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLELIS(NBCLE) = vireblc(CHAINE,2)
  CHAINE = ""
 Endif
 ASCDES = ""
 K = instr(1,CLELIS(NBCLE)," ")
 If K
  ASCDES = tolower(vireblc(right$(CLELIS(NBCLE),K+1),2))
  CLELIS(NBCLE) = left$(CLELIS(NBCLE),K)
 Endif
 CLELIS(NBCLE) = vireblc(CLELIS(NBCLE),2)
 If NBCLE=1 & ASCDES="desc"
  SNSLIS = 2
 Endif
Wend
If SENS=">"
 IFILSAV = IFILSUITE
 For I=0 To dim(FILSUITE)-1
  FILSAV(I) = FILSUITE(I)
 Next I
Endif
Gosub FILSUITE
Default File [AWS]
Raz CRITBUF, ICRITBUF
For I=0 To dim(FILTPAG)-1
 Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",FILTPAG(I),"&") From GOBJSUB
Next I
Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",FILTSAI,"&") From GOBJSUB
Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",FILTSUP,"&") From GOBJSUB
If CRITBUF="" : CRITBUF = "1=1" : Endif
If SENS="<"
 Call CHANGE_SENS(CLELISTE,CHAINE) From GOBJACT
 If FILPREV="" : FILPREV = "1=1" : Endif
 Filter [F] Where evalue(CRITBUF) & evalue(FILPREV) Order With CHAINE
Else
 If FILSUITE="" : FILSUITE = "1=1" : Endif
 Filter [F] Where evalue(CRITBUF) & evalue(FILSUITE) Order With CLELISTE
Endif
K = 0
PRE = 0
If dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 For [F] Hint Key=""
  OK = ([M:AWP0]DELEXP<>2)
  If [M:AWP0]NBRDEL>0
   OK += find([F]DEST+"~",[M:AWP0]TABDEL(0..[M:AWP0]NBRDEL-1))
   OK += find([F]DEST+"~"+[F]NATURE,[M:AWP0]TABDEL(0..[M:AWP0]NBRDEL-1))
  Endif
  If OK
   K += 1
   If K>MAXLIG
    PRE=1 : Break
   Elsif K=MAXLIG & SENS=">"
    Break
   Endif
  Endif
 Next
Else
 For [F]
  OK = ([M:AWP0]DELEXP<>2)
  If [M:AWP0]NBRDEL>0
   OK += find([F]DEST+"~",[M:AWP0]TABDEL(0..[M:AWP0]NBRDEL-1))
   OK += find([F]DEST+"~"+[F]NATURE,[M:AWP0]TABDEL(0..[M:AWP0]NBRDEL-1))
  Endif
  If OK
   K += 1
   If K>MAXLIG
    PRE=1 : Break
   Elsif K=MAXLIG & SENS=">"
    Break
   Endif
  Endif
 Next
Endif
OK = 1
If SENS="<"
 If !PRE
  Raz FILSUITE, IFILSUITE
  FILSUITE = "1=1"
 Else
  Gosub FILSUITE
 Endif
Elsif !K : # pas d'enreg suivant
 IFILSUITE = IFILSAV
 For I=0 To dim(FILSUITE)-1
  FILSUITE(I) = FILSAV(I)
 Next I
 OK = 0
Endif
Filter [F]
If GTYPDBA=1 & dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 Gosub UNSET_FIRST From GOBJACT
Endif
End

#----------------------#
$FILSUITE
Raz FILSUITE, FILPREV, IFILSUITE, IFILPREV
NBCLE = 0
For I=1 To dim(CLELIS)
 If CLELIS(I)="" : Break : Endif
 NBCLE += 1
 If instr(1,CLELIS(I),"[")
  ZONCLE = CLELIS(I)
 Else
  ZONCLE = "[F:AWS]"+CLELIS(I)
 Endif
 T = evalue("type("+ZONCLE+")")
 Case T
  When 1,2,4,5,6,7,8,9
   VALC(I) = num$(evalue(ZONCLE))
  When 3
   If evalue(ZONCLE)=[0/0/0]
    VALC(I) = '[0/0/0]'
   Else
    VALC(I) = '['+format$(GFMD,evalue(ZONCLE))+']'
   Endif
  When Default
   VALC(I) = evalue(ZONCLE)
   If instr(1,VALC(I),"'") & instr(1,VALC(I),'"')
    VALC(I) = ctrans(VALC(I),"'","&")
    VALC(I) = ctrans(VALC(I),'"',"!")
    VALC(I) = '"'+VALC(I)+'"'
   Elsif instr(1,VALC(I),'"') & !instr(1,VALC(I),"'")
    VALC(I) = "'"+VALC(I)+"'"
   Else
    VALC(I) = '"'+VALC(I)+'"'
   Endif
 Endcase
 If I=1
  FILSUITE = ZONCLE+">"+VALC(I)
  FILPREV  = ZONCLE+"<"+VALC(I)
 Else
  Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE","| (","") From GOBJSUB
  If FILSUITE="" : Break : Endif
  Call ADDCRIT(FILPREV,IFILPREV,"FILPREV","| (","") From GOBJSUB
  If FILPREV="" : Break : Endif
  For J=1 To I-1
   If instr(1,CLELIS(J),"[")
    ZONCLE2 = CLELIS(J)
   Else
    ZONCLE2 = "[F:AWS]"+CLELIS(J)
   Endif
   Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE",ZONCLE2+"="+VALC(J)-"& ","") From GOBJSUB
   If FILSUITE="" : Break 2 : Endif
   Call ADDCRIT(FILPREV,IFILPREV,"FILPREV",ZONCLE2+"="+VALC(J)-"& ","") From GOBJSUB
   If FILPREV="" : Break 2 : Endif
  Next J
  Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE",ZONCLE+">"+VALC(I)+")","") From GOBJSUB
  If FILSUITE="" : Break : Endif
  Call ADDCRIT(FILPREV,IFILPREV,"FILPREV",ZONCLE+"<"+VALC(I)+")","") From GOBJSUB
  If FILPREV="" : Break : Endif
 Endif
Next I
If FILSUITE=""   : Raz FILPREV
Elsif FILPREV="" : Raz FILSUITE
Endif
If SNSLIS=2
 For I=0 To dim(FILSUITE)-1
  FILTRE(0)   = FILSUITE(I)
  FILSUITE(I) = FILPREV(I)
  FILPREV(I)  = FILTRE(0)
 Next I
Endif
Return

#-----------------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "LISWRKTRN" : Gosub LISWRKTRN
 When "ASELDEL"   : Gosub ASELDEL
Endcase
Return

#-----------------------------------------------------------#
$FIN_LISTE
Case LISTE
 When "LISWRKTRN" : If GSTATUT=7 : VALEUR = "" : Endif
Endcase
Return

#---------------------------#
$LISWRKTRN
Local Char CRITERE(250) , TEXTE(30)(1..dim(TEX),1..2)
Local Integer ICRITERE
If GUSRACS<>2
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AWW]ACS="" or [F:ACC]CONSUL=2)',"&") From GOBJSUB
Endif
If PARAM(1)<>""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:AWW]WRKTRN = "'+PARAM(1)+'"',"&") From GOBJSUB
Endif
If CRITERE=""
 CRITERE = '1=1'
Endif
NBTEX = 0
Link [AWW] With [ACC]CODACC=GUSER;[F:AWW]ACS As [AWW_] Where evalue(CRITERE)
For [AWW_]
 NBTEX += 1
 TEX(NBTEX) = [F:AWW_]WRKTRN
 Call LECTEXTRA(TEXTE(NBTEX,2),"AWRKTRN","INTIT",[F:AWW_]WRKTRN,"") From ATEXTRA
Next AWW_
TIT = mess(3,126,1) : # Choix transaction
TIT(1) = mess(37,100,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
Return

#---------------------------#
$ASELDEL
Local Char TEXTE(30)(1..dim(TEX),1..2) , BID(GLONAUS)
Local File AUTILIS [AUS]
For I=0 To dim([M:AWP0]TABDEL)-1
 If [M:AWP0]TABDEL(I)<>""
  K = instr(1,[M:AWP0]TABDEL(I),"~")
  If K
   BID = left$([M:AWP0]TABDEL(I),K-1)
  Else
   BID = [M:AWP0]TABDEL(I)
  Endif
  If !find(BID,TEX)
   If NBTEX>=dim(TEX)
    Call ERREUR(mess(161,115,1)) From GESECRAN : # Trop de lignes
    Break
   Endif
   NBTEX += 1
   TEX(NBTEX) = BID
   Read [AUS]CODUSR=BID
   If !fstat
    TEXTE(NBTEX,2) = [F:AUS]NOMUSR
   Endif
  Endif
 Endif
Next I
Close Local File [AUS]
TIT(0) = mess(163,75,1) : # Délégués
TIT(1) = mess(37,100,1) : # Code
TIT(2) = mess(38,100,1) : # Nom
Return

#-----------------------------------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "MESGRP" : Gosub SEL_MESGRP : # Mail du groupe
 When "MESCHR" : Gosub SEL_MESCHR : # Historique mail d'un chrono
 When "SUICHR" : Gosub SEL_SUICHR : # Historique suivi d'un chrono
Endcase
Return

#-------------------------------------#
$SEL_MESGRP
If clalev([F:AWG])=0 : Local File AWRKHISMES [AWG] : Endif
If clalev([F:AWO])=0 : Local File AWRKHISDES [AWO] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS    [AUS] : Endif
CRITERE = '[F:AWG]NUMGRP="'+PARAM(1)+'"'
If PARAM(2)<>""
 For [AUS] Where USR=PARAM(2)
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:AWO]EMAIL="'+[F:AUS]ADDEML+'"',"&") From GOBJSUB
 Next AUS
Endif
OBJET = "AWO"
Return

#-------------------------------------#
$SEL_MESCHR
If clalev([F:AWG])=0 : Local File AWRKHISMES [AWG] : Endif
If clalev([F:AWS])=0 : Local File AWRKHISSUI [AWS] : Endif
If PARAM(2)<>""
 CRITERE = '([F:AWS]CHRONO="'+PARAM(2)+'"'
 CRITERE += ' | [F:AWS]NUMORG="'+PARAM(2)+'")'
Else
 CRITERE = '([F:AWS]CHRONO="'+PARAM(1)+'"'
 CRITERE += ' | [F:AWS]NUMORG="'+PARAM(1)+'")'
Endif
CRITERE += ' & [F:AWS]ENVOI>1'
If PARAM(3)<>""
 CRITERE -= '& [F:AWS]DEST="'+PARAM(3)+'"'
Endif
OBJET = "AWG"
Return

#-------------------------------------#
$SEL_SUICHR
If clalev([F:AWG])=0 : Local File AWRKHISMES [AWG] : Endif
If clalev([F:AWS])=0 : Local File AWRKHISSUI [AWS] : Endif
If PARAM(2)<>""
 CRITERE = '([F:AWS]CHRONO="'+PARAM(2)+'"'
 CRITERE += ' | [F:AWS]NUMORG="'+PARAM(2)+'")'
Else
 CRITERE = '([F:AWS]CHRONO="'+PARAM(1)+'"'
 CRITERE += ' | [F:AWS]NUMORG="'+PARAM(1)+'")'
Endif
If PARAM(3)<>""
 CRITERE -= '& [F:AWS]DEST="'+PARAM(3)+'"'
Endif
OBJET = "AWS"
Return

