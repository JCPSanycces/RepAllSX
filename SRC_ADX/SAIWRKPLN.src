#----------------------------------------------------#
Subprog IB_NBLIG
Local Integer OK
Raz GBOUT1 , GBOUT2 , GBOUT3 , GBOUT4 , GBOUT5 , GBOUT6 , GBOUT7 , GBOUT8
If [M]TYPEVT(nolign-1)=2 & [M]CLEOBJ(nolign-1)<>""
 GBOUT1 = mess(72,75,1) : # Opération déclenchante
Elsif [M]TYPEVT(nolign-1)=9 & [M]NUMORG(nolign-1)<>""
 Read [AWS]AWS0 = [M]NUMORG(nolign-1);[M]USRORG(nolign-1)
 If !fstat & [F:AWS]TYPEVT=2 & [F:AWS]CLEOBJ<>""
  GBOUT1 = mess(101,75,1) : # Opération déclenchante origine
 Endif
Endif
If [M]IDENTRET(nolign-1)<>""
 GBOUT2 = mess(42,109,1) : # Retour
Endif
Read [AWG]AWG1 = [M]NUMGRP(nolign-1)
If !fstat
 GBOUT3 = mess(68,75,1) : # Mails du groupe
Endif
Read [AWG]AWG0 = [M]CHRONO(nolign-1)
If !fstat
 GBOUT4 = mess(70,75,1) : # Historique mails
Endif
If [M]NUMORG(nolign-1)<>""
 OK = 1
Else
 Read [AWS]AWS0(1) = [M]CHRONO(nolign-1)
 OK = !fstat
Endif
If OK
 GBOUT5 = mess(69,75,1) : # Historique suivis
Endif
If [M]FLGSIG(nolign-1)=3 & instr(1,[M]AUZ,"G")
 GBOUT6 = mess(71,75,1) : # Signature
Endif
If [M]FLGSIG(nolign-1)=2 & [M]USRSIG(nolign-1)="" &  instr(1,[M]AUZ,"G")
 GBOUT7 = mess(177,75,1) : # Lecture
Endif
If [M]FLGSIG(nolign-1)>4 & instr(1,[M]AUZ,"A")
 If [M]NUMORG(nolign-1)<>""
  Read [AWS]AWS0(1)=[M]NUMORG(nolign-1)
  If !fstat
   Read [AWF]AWF0=[F:AWS]CODWRK
   If !fstat & find("CAN",[F:AWF]OPESIG)
    GBOUT8 = mess(50,100,1) : # Annuler
   Endif
  Endif
 Elsif [M]CHRONO(nolign-1)<>""
  Read [AWF]AWF0=[M]CODWRK(nolign-1)
  If !fstat & find("CAN",[F:AWF]OPESIG)
   GBOUT8 = mess(50,100,1) : # Annuler
  Endif
 Endif
Endif
End

# Tunnel opération déclenchante
#----------------------------------------------------#
Subprog CNSAWWTUN1(CHRONO,DEST,NUMORG,USRORG)
Value Char CHRONO , DEST , NUMORG , USRORG
Local Char    CHAINE(250)
If clalev([F:AWS])=0 : Local File AWRKHISSUI [AWS] : Endif
If clalev([F:AOB])=0 : Local File AOBJET     [AOB] : Endif
Read [AWS]AWS0 = [L]CHRONO;[L]DEST
If [F:AWS]TYPEVT=2 & [F:AWS]CLEOBJ<>""
 CHAINE  = [F:AWS]CODEVT+"/"+[F:AWS]CLEOBJ
Else
 Read [AWS]AWS0 = [L]NUMORG;[L]USRORG
 If !fstat & [F:AWS]TYPEVT=2 & [F:AWS]CLEOBJ<>""
  CHAINE  = [F:AWS]CODEVT+"/"+[F:AWS]CLEOBJ
 Endif
Endif
Gosub SETCLE
Read [AOB]ABREV = LIEN
If fstat : End : Endif
Call OBJET(LIEN,CLE1,CLE2) From GOBJET
End

$SETCLE
Local Char    LIEN(30) , CLE1(GLONID1) , CLE2(GLONID2)(1..16)
Local Integer K , NBCLE
K = instr(1,CHAINE,"/")
If !K
 LIEN = CHAINE
 CHAINE = ""
Else
 LIEN = left$(CHAINE,K-1)
 CHAINE = right$(CHAINE,K+1)
 K = instr(1,CHAINE,"~")
 If K
  CLE1 = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  CLE1 = CHAINE
  CHAINE = ""
 Endif
Endif
While CHAINE<>""
 NBCLE += 1
 K = instr(1,CHAINE,"~")
 If K
  CLE2(NBCLE) = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  CLE2(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
If left$(LIEN,3)="GES"
 LIEN = right$(LIEN,4)
Endif
Gosub SETCLE From ="WO"+LIEN
If dim([L]CLEVALEUR)>0 : # GEODE
 # Les variables CLE1 et CLE2 contiennent les valeurs correspondant aux champs CLEPRIM et CLESEC(0..)
 # Pour Géode, il faut extraire le site et le déposant de ces variables et réorganiser les variables CLE1 et CLE2
 # sous la forme CLE1=CLEVALEUR et CLESEC(0)=CLEFCY, CLESEC(1)=CLEDEP, CLESEC(2..)=CLESUPP(0..)
 Local Integer I , J
 Local Char    DEP(GLONDEP) , FCY(GLONFCY) , SUPP(GLONID1)(1..16) , CODE(GLONID1)
 I = find(CLEVALEUR,CLEPRIM,CLESEC)
 If I=1 : CODE = CLE1
 Else   : CODE = CLE2(I-1)
 Endif
 K = 0
 If CLESUPP(0)<>""
  For J=0 To dim(CLESUPP)-1
   K += 1
   I = find(CLESUPP(J),CLEPRIM,CLESEC)
   If I=1 : SUPP(K) = CLE1
   Else   : SUPP(K) = CLE2(I-1)
   Endif
  Next J
 Endif
 If CLEFCY<>""
  I = find(CLEFCY,CLEPRIM,CLESEC)
  If I=1 : FCY = CLE1
  Else   : FCY = CLE2(I-1)
  Endif
 Endif
 If CLEDEP<>""
  I = find(CLEDEP,CLEPRIM,CLESEC)
  If I=1 : DEP = CLE1
  Else   : DEP = CLE2(I-1)
  Endif
 Endif
 CLE1 = CODE
 Raz CLE2 , K
 If CLEFCY<>""
  K += 1
  CLE2(K) = FCY
 Endif
 If CLEDEP<>""
  K += 1
  CLE2(K) = DEP
 Endif
 If CLESUPP(0)<>""
  For J=0 To dim(CLESUPP)-1
   K += 1
   CLE2(K) = SUPP(K)
  Next J
 Endif
Endif
Return

# Tunnel retour
#----------------------------------------------------#
Subprog CNSAWWTUN2(IDENTRET)
Value Char IDENTRET
Local Char    CHAINE(250)
If clalev([F:AOB])=0 : Local File AOBJET     [AOB] : Endif
CHAINE  = [L]IDENTRET
Gosub SETCLE
Read [AOB]ABREV = LIEN
If fstat : End : Endif
Call OBJET(LIEN,CLE1,CLE2) From GOBJET
End

# Mails d'un groupe
#----------------------------------------------------#
Subprog CNSAWWTUN3(NUMGRP,USER)
Value Char NUMGRP , USER
Local Char VALEUR(30) , PARAM(30)(1..3)
PARAM(1) = num$([L]NUMGRP)
PARAM(2) = [L]USER
Call S_TAB_CHAR(VALEUR,PARAM,"MESGRP","SAIWRKPLN","") From GACTION
If GSTATUT<>28 : End : Endif
Call CONSULT_MES([F:AWG]CHRONO)
End

Subprog CONSULT_MES(CHRONO)
Value Char CHRONO
Local Char VALMSK(30) , PARMSK(30)(1..3) , SPETRT(GLONADC)
If clalev([F:AWG])=0 : Local File AWRKHISMES [AWG] : Endif
If clalev([F:AWO])=0 : Local File AWRKHISDES [AWO] : Endif
If GTYPDBA=2 : # Bug sql sur les link avec tables contenant un clob
 Close Local File [AWG]
 Local File AWRKHISMES [AWG]
Endif
Read [AWG]AWG0 = [L]CHRONO
Local Mask AWAX [AWAY]
For [AWO] Where CHRONO=[F:AWG]CHRONO
 Case [F:AWO]ENVOI
  When 1
   [M:AWAY]NBDEST += 1 : [M:AWAY]DEST([M:AWAY]NBDEST-1) = [F:AWO]EMAIL
  When Default
   [M:AWAY]NBCOP += 1 : [M:AWAY]COP([M:AWAY]NBCOP-1) = [F:AWO]EMAIL
 Endcase
Next AWO
[M:AWAY]TEXTE  = [F:AWG]TEXTE
[M:AWAY]TEXOBJ = [F:AWG]OBJET
[M:AWAY]REQREC = [F:AWG]REQREC
[M:AWAY]TYPMES = [F:AWG]TYPMES
GBATCH = 1
GCONSDIA = 1
Call TRTSPE(nomap,"SAIWRKMES",SPETRT) From SUBACT
Call SAISIE_CHAR(VALMSK,PARMSK,"SAIWRKMES","SAIWRKMES",SPETRT) From GSAISIE
Close Local Mask [AWAY]
Raz GBATCH , GCONSDIA
End

# Historique mail d'un chrono
#----------------------------------------------------#
Subprog CNSAWWTUN4(CHRONO,NUMORG,USER)
Value Char CHRONO , NUMORG , USER
Local Char VALEUR(30) , PARAM(30)(1..3)
PARAM(1) = [L]CHRONO
PARAM(2) = [L]NUMORG
PARAM(3) = [L]USER
If clalev([F:AWG])=0 : Local File AWRKHISMES [AWG] : Endif
Call S_TAB_CHAR(VALEUR,PARAM,"MESCHR","SAIWRKPLN","") From GACTION
If GSTATUT<>28 : End : Endif
Call CONSULT_MES([F:AWG]CHRONO)
End

# Historique d'un suivi
#----------------------------------------------------#
Subprog CNSAWWTUN5(CHRONO,NUMORG,USER)
Value Char CHRONO , NUMORG , USER
Local Char VALEUR(30) , PARAM(30)(1..3)
PARAM(1) = [L]CHRONO
PARAM(2) = [L]NUMORG
PARAM(3) = [L]USER
Call S_TAB_CHAR(VALEUR,PARAM,"SUICHR","SAIWRKPLN","") From GACTION
End

# Signature
#----------------------------------------------------#
Subprog CNSAWWTUN6(CHRONO,DEST,EMAIL)
Value Char CHRONO , DEST , EMAIL
Local Char PARAM(250)(1..6) , VALEUR(250) , SPETRT(GLONADC)
PARAM(1) = [L]CHRONO
PARAM(2) = [L]DEST
PARAM(3) = GUSER
PARAM(4) = [L]EMAIL
Call TRTSPE(nomap,"SIGWRK",SPETRT) From SUBACT
Call TRAITE_CHAR(VALEUR,PARAM,"","SAIWRKSIG","",5,SPETRT) From GTRAITE
mkstat = 4
End

# Viser
#----------------------------------------------------#
Subprog CNSAWWTUN7(CHRONO,DEST)
Value Char CHRONO , DEST

# On vérifie que personne n'est en train de modifier ce chrono
Local Integer OK
Local Char    SYMBOLE(80)
SYMBOLE = "AWS"+[L]CHRONO
Call VERROU(SYMBOLE,OK)
If !OK
 Call ERREUR(GMESSAGE) From GESECRAN
 End
Endif
If clalev([F:AWS])=0 : Local File AWRKHISSUI [AWS] : Endif
Call DEBTRANS From GLOCK
Gosub TR1
Unlock =SYMBOLE
mkstat = 4
End

$TR1
Trbegin [AWS]
 For [AWS] Where [F]CHRONO=[L]CHRONO & [F]DEST=[L]DEST
  Readlock [AWS]AWS0 Curr
  If fstat=1
   GOK=-1 : GLOCK="$AWRKHISSUI" : Goto ROLL_TR1
  Elsif fstat
   GOK=0 : Call FSTA("AWS") From GLOCK : Goto AB_TR1
  Endif
  [F:AWS]FLGSIG = 4 : # Visé
  [F:AWS]USRSIG = GUSER
  [F:AWS]MAISIG = ""
  [F:AWS]DATSIG = date$
  [F:AWS]TIMSIG = left$(time$,2)+mid$(time$,4,2)+right$(time$,7)
  Rewrite [AWS]
  If fstat
   GOK=0 : Call FSTA("AWS") From GLOCK : Goto AB_TR1
  Endif
 Next AWS
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

# Annulation de signature
#----------------------------------------------------#
Subprog CNSAWWTUN8(CHRONO,DEST)
Value Char CHRONO , DEST
If clalev([F:AWS])=0 : Local File AWRKHISSUI [AWS] : Endif
Read [AWS]AWS0 = [L]CHRONO;[L]DEST
Call ANUSIG([L]CHRONO,[L]DEST) From ANUWRKSIG
mkstat = 4
End

#-----------------------------------------------------------#
Subprog VERROU(SYMBOLE,OK)
Value Char SYMBOLE
Variable Integer OK
Local Char    USER(20) , POSTE(80)
Local Integer VERROU
Raz GMESSAGE
Call DEBTRANS From GLOCK
Gosub LOCK_SYMBOLE
If !VERROU
 Call QUILOCKE(SYMBOLE,POSTE,USER) From OBJDIV
 GMESSAGE = mess(82,75,1) : # Signature en cours
 If USER<>""
  GMESSAGE += "\"+USER+"\"+POSTE
 Endif
 GMESSAGE += "\("+mess(20,100,1)-mess(56,100,1)+" |"+SYMBOLE+"|)" : # Erreur de verrouillage sur Symbole
 OK = 0
Else
 OK = 1
Endif
End

$LOCK_SYMBOLE
Lock =SYMBOLE With lockwait=0
If !fstat
 VERROU = 1
Else
 GLOCK = "%"+SYMBOLE
 Call ROLL From GLOCK
 If GROLL
  VERROU = 0
 Else
  Goto LOCK_SYMBOLE
 Endif
Endif
Return

#-----------------------------------------------------------#
Subprog C_NBLIG
Call AS_NBLIG From ="W1"+maskcou : # Pour exécuter IB_NBLIG
If adxgtb=0 & status<>71 : # Cas de la saisie dans le tableau et pas en mode commande
 mkstat = 1 : # On est obligé de mettre en saisie les champs d'un tableau pour que le style fonctionne
Endif
End

Subprog C_USER(VALEUR)
Variable Char    VALEUR()
Local Integer I , K , OK
If VALEUR<>""
 OK = 0
 If [M:AWP0]DELEXP=2 & [M:AWP0]NBRDEL<>0
  For I=0 To [M:AWP0]NBRDEL-1
   K = instr(1,[M:AWP0]TABDEL(I),"~")
   If K
    If VALEUR=left$([M:AWP0]TABDEL(I),K-1)
     OK += 1 : Break
    Endif
   Elsif VALEUR=[M:AWP0]TABDEL(I)
    OK += 1 : Break
   Endif
  Next I
 Elsif instr(1,[M]AUZ,"U")
  OK = 1
 Elsif VALEUR=GUSER
  OK = 1
 Endif
 If !OK
  mkstat = 1 : End
 Endif
Endif
End

Subprog IB_USER
If [M:AWP0]DELEXP<>2 or [M:AWP0]NBRDEL=0
 GBOUT2 = ""
Endif
If !instr(1,[M]AUZ,"U")
 GBOUT1 = ""
 GBOUTS = ""
Endif
End
