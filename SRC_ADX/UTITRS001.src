#<AdxTL>@(#)6.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
##########################################################################
# UTITRS001   Renseignement des paramètres AMTVIR1, AMTVIR2 et AMTVIR3   #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap

  If DOSSIER <> ""
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  
    Call TEMPON("O") From GESECRAN
    If !GSERVEUR
      Call OUVRE_TRACE("Moulinette UTITRS001") From LECFIC
    Endif
  
    If nomap<>GDOSX3 Then
      Call MAJ_UTIAMTVIR(nomap)
    Else
      Local Integer OK
      Call OUINON("Exécuter cette moulinette sur l'ensemble des dossiers de la solution",OK) From GESECRAN
      If OK<>2 : End : Endif
      If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
      For [ADS]
        If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
          Call MAJ_UTIAMTVIR([F:ADS]DOSSIER)
        Endif
      Next
    Endif

    Call TEMPOFF From GESECRAN
    If !GSERVEUR
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE   From LECFIC
    Endif
  Endif
End

Subprog MAJ_UTIAMTVIR(DOSSIER)
Value Char    DOSSIER
Local Integer OK

  Call ECR_TRACE("UTITRS001 : Process Start on : "+DOSSIER,0) From GESECRAN

  Local File  =DOSSIER+".ADOVAL" [ADV]
  Local File  =DOSSIER+".ACTIV"  [ACV]

  Trbegin [ADV] : GOK=1
  
  Call UPDATE_PARAM("AMTVIR1","50000",GOK) : If GOK=0 Then Goto FIN Endif
  Call UPDATE_PARAM("AMTVIR2","12500",GOK) : If GOK=0 Then Goto FIN Endif
  Call UPDATE_PARAM("AMTVIR3","12500",GOK) : If GOK=0 Then Goto FIN Endif

$FIN
  If GOK=1
    Commit
  Else
    Rollback
  Endif
 
  #----- Fin du traitement -----#
  Call ECR_TRACE("UTITRS001 : Process Finish on : "+DOSSIER,0) From GESECRAN
End

Subprog UPDATE_PARAM(NAMPAR, VALPAR, LRET)
Value Char       NAMPAR, VALPAR
Variable Integer LRET

  LRET=1
  Filter [ADV] Where PARAM=NAMPAR
  If rowcount([F:ADV]) Then
    Update [ADV] Where PARAM=NAMPAR With VALEUR=VALPAR
    If fstat Then
      LRET=0
    Else
      Call ECR_TRACE("UTITRS001 : "+NAMPAR+" updated",0) From GESECRAN
    Endif
  Else
    Raz [F:ADV]   
    [F:ADV]CMP   = ""
    [F:ADV]FCY   = ""
    [F:ADV]PARAM = NAMPAR
    [F:ADV]CREDAT= date$
    [F:ADV]CRETIM= time
    [F:ADV]CREUSR= GUSER
    [F:ADV]JEU   = ""
    [F:ADV]VALEUR= VALPAR
    Write [F:ADV]
    If fstat Then
      LRET=0
    Else
      Call ECR_TRACE("UTITRS001 : "+NAMPAR+" created",0) From GESECRAN
    Endif
  Endif
  Filter [F:ADV]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If [F:ADS]MODULE(2)<>2 : End : Endif
  If filinfo(filpath("FIL","AOBJET","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","ATYPE", "fde",APPLI),0)<=0 : End : Endif
  Call MAJ_UTIAMTVIR(APPLI)        
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH_X3(APPLI)
Value Char    APPLI

  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If [F:ADS]MODULE(2)<>2 : End : Endif
  If filinfo(filpath("FIL","AOBJET","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","ATYPE", "fde",APPLI),0)<=0 : End : Endif
  Call MAJ_UTIAMTVIR(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

#  If APPLI=GDOSX3 End : Endif
  If [F:ADS]MODULE(2)<>2 : End : Endif
  If filinfo(filpath("FIL","AOBJET","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","ATYPE", "fde",APPLI),0)<=0 : End : Endif
  Call MAJ_UTIAMTVIR(APPLI)
End

