# Superviseur
# Gestion du masque CHGITG0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone TCLCODOLD
mkstat = 0
zoncou = "TCLCODOLD"
indice = 0
WCHAR = [M]TCLCODOLD
If varmode([M]TCLCODOLD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TCLCODOLD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]TCLCODOLD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TCLCODOLD" : GZNUM = 707 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("ITG","$",[M]TCLCODOLD,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "TCLCODOLD" : GZNUM = 707 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_TCLCODOLD([M]TCLCODOLD) From SUBCHGITG
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TCLCODOLD" : GZNUM = 707 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]TCLCODOLD or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_TCLCODOLD([M]TCLCODOLD) From SUBCHGITG
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "TCLCODOLD" : GZNUM = 707 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

