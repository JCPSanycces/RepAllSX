#Return

#-----------------------------------------------------#
# Vérification de la saisie du paramètre PHYAUTNUM
# (numérotation des éléments physiques)
#-----------------------------------------------------#
$VERF_PHYAUTNUM

  Local Char PARAM
# FQ109840
#  If val(VALEUR) = GVML_AUCUNE or val(VALEUR) = GVML_FACUL Then
#    # On va forcer à Non PHYNUMBCO et PHYAUTCRE
#    PARAM = "PHYNUMBCO"
#    Call MAJ_PARAM(PARAM,G_NON,1)
#  Endif
  If val(VALEUR) = GVML_AUCUNE Then
    PARAM = "PHYAUTCRE"
    Call MAJ_PARAM(PARAM,G_NON,1)
  Endif

Return

#-----------------------------------------------------#
# Vérification de la saisie du paramètre PHYAUTCRE
# (création automatique élément)
#-----------------------------------------------------#
$VERF_PHYAUTCRE

  If val(VALEUR) = G_NON Then
    # si param = Non, on sort
    Return
  Endif

  # si PHYAUTNUM est à Aucune, on ne peut pas mettre PHYNUMBCO à Oui
  Local Integer VALPHYAUTNUM
  Call RECUP_VAL_PAR_NUM("PHYAUTNUM",VALPHYAUTNUM)

  If VALPHYAUTNUM = GVML_AUCUNE Then
    # Vous ne pouvez pas modifier ce paramètre, car le paramètre PHYAUTNUM est à Aucune
    Call ALIM_MSG(GMESSAGE,mess(127,7775,1),OK)
  Endif
  If OK = 0 Then Return Endif

Return

#-----------------------------------------------------#
# Récupération de la valeur d'un paramètre passé en paramètre, en recherchant
# dans la table des paramètres de l'écran ADWP ou de l'écran ADW1
# La valeur du paramètre est numérique
#-----------------------------------------------------#
Subprog RECUP_VAL_PAR_NUM(PPARAM,VALPARAM)
Value Char PPARAM
Variable Integer VALPARAM

  Local Integer TROUVE
  # recherche dans l'écran des paramètres en cours ADWP
  Call RECUP_VAL_PAR_NUM_ADWP(PPARAM,VALPARAM,TROUVE)
  If TROUVE = G_NON
    # recherche dans ADW1
    # Recherche du groupe du paramètre auquel appartient le paramètre
    Call RECUP_VAL_PAR_NUM_ADW1(PPARAM,VALPARAM,TROUVE)
  Endif

End

#-----------------------------------------------------#
# Récupération de la valeur d'un paramètre passé en paramètre, en recherchant
# dans la table des paramètres de l'écran ADWP
# La valeur du paramètre est numérique
#-----------------------------------------------------#
Subprog RECUP_VAL_PAR_NUM_ADWP(PPARAM,VALPARAM,TROUVE)
Value Char PPARAM
Variable Integer VALPARAM
Variable Integer TROUVE

  TROUVE = G_NON
  For IND = 0 To [M:ADWP]NBVAR-1
    If [M:ADWP]PARAM(IND) = PPARAM Then
      VALPARAM = val([M:ADWP]VALINT(IND))
      TROUVE = G_OUI
      Break
    Endif
  Next IND

End

#-----------------------------------------------------#
# Récupération de la valeur d'un paramètre passé en paramètre, en recherchant
# dans la table des paramètres de l'écran ADW1
# La valeur du paramètre est numérique
#-----------------------------------------------------#
Subprog RECUP_VAL_PAR_NUM_ADW1(PPARAM,VALPARAM,TROUVE)
Value Char PPARAM
Variable Integer VALPARAM
Variable Integer TROUVE

  Local Char GROUPE
  Call RECUP_GROUPE(PPARAM,GROUPE)
  If GROUPE = "" Then End Endif

  TROUVE = G_NON
  For IND = 0 To [M:ADW1]NBVAR-1
    If [M:ADW1]GRPPAR(IND) = GROUPE and [M:ADW1]PARAM(IND) = PPARAM Then
      VALPARAM = val([M:ADW1]VALINT(IND))
      TROUVE = G_OUI
      Break
    Endif
  Next IND

End

#-----------------------------------------------------#
# Récupération de la valeur d'un paramètre passé en paramètre, en recherchant
# dans la table des paramètres de l'écran ADWP ou de l'écran ADW1
# La valeur du paramètre est alphanumérique
#-----------------------------------------------------#
Subprog RECUP_VAL_PAR_CAR(PPARAM,VALPARAM)
Value Char PPARAM
Variable Char VALPARAM

  Local Integer TROUVE
  # recherche dans l'écran des paramètres en cours ADWP
  Call RECUP_VAL_PAR_CAR_ADWP(PPARAM,VALPARAM,TROUVE)
  If TROUVE = G_NON
    # recherche dans ADW1
    Call RECUP_VAL_PAR_CAR_ADW1(PPARAM,VALPARAM,TROUVE)
  Endif

End

#-----------------------------------------------------#
# Récupération de la valeur d'un paramètre passé en paramètre, en recherchant
# dans la table des paramètres de l'écran ADWP
# La valeur du paramètre est numérique
#-----------------------------------------------------#
Subprog RECUP_VAL_PAR_CAR_ADWP(PPARAM,VALPARAM,TROUVE)
Value Char PPARAM
Variable Char VALPARAM
Variable Integer TROUVE

  TROUVE = G_NON
  For IND = 0 To [M:ADWP]NBVAR-1
    If [M:ADWP]PARAM(IND) = PPARAM Then
      VALPARAM = [M:ADWP]VALINT(IND)
      TROUVE = G_OUI
      Break
    Endif
  Next IND

End


#-----------------------------------------------------#
# Récupération de la valeur d'un paramètre passé en paramètre, en recherchant
# dans la table des paramètres de l'écran ADW1
# La valeur du paramètre est numérique
#-----------------------------------------------------#
Subprog RECUP_VAL_PAR_CAR_ADW1(PPARAM,VALPARAM,TROUVE)
Value Char PPARAM
Variable Char VALPARAM
Variable Integer TROUVE

  Local Char GROUPE
  Call RECUP_GROUPE(PPARAM,GROUPE)
  If GROUPE = "" Then End Endif

  TROUVE = G_NON
  For IND = 0 To [M:ADW1]NBVAR-1
    If [M:ADW1]GRPPAR(IND) = GROUPE and [M:ADW1]PARAM(IND) = PPARAM Then
      VALPARAM = [M:ADW1]VALINT(IND)
      TROUVE = G_OUI
      Break
    Endif
  Next IND

End

#-------------------------------------------------------------------------------------#
# Récupération du groupe dans lequel se situe un paramètre, pour le chapitre en cours
#-------------------------------------------------------------------------------------#
Subprog RECUP_GROUPE(PPARAM,VALPARAM)
Value Char PPARAM
Variable Char VALPARAM

  Local Integer OPEN_FILE : OPEN_FILE=0
  If clalev([F:ADPZ])=0 Then
    Local File ADOPAR [ADPZ] # Paramètres
    OPEN_FILE=1
  Endif

  # Lecture du paramétrage du paramètre reçu en paramètre
  Read [F:ADPZ]ADP0 = [M:ADW1]CHAPITRE;PPARAM
  If fstat = 0 Then
    VALPARAM = [F:ADPZ]GRPPAR
  Endif

  If OPEN_FILE=1 : Close Local File [F:ADPZ] : Endif

End

#-------------------------------------------------------------------------------------#
# Mise à jour de la valeur d'un paramètre dans l'écran ADWP ou dans l'écran ADW1
#-------------------------------------------------------------------------------------#
Subprog MAJ_PARAM(PPARAM,PVALEUR,PMESSAGE)
Value Char PPARAM
Value Integer PVALEUR
Value Integer PMESSAGE

  Local Integer VALPARAM, TROUVE

  # recherche dans l'écran des paramètres en cours ADWP
  Call RECUP_VAL_PAR_NUM_ADWP(PPARAM,VALPARAM,TROUVE)
  If TROUVE = G_OUI Then
    Call MAJ_PARAM_ADWP(PPARAM,PVALEUR,PMESSAGE)
  Else
    # recherche dans l'écran des paramètres en cours ADW1
    Call RECUP_VAL_PAR_NUM_ADW1(PPARAM,VALPARAM,TROUVE)
    If TROUVE = G_OUI Then
      Call MAJ_PARAM_ADW1(PPARAM,PVALEUR,PMESSAGE)
    Endif
  Endif

End

#-------------------------------------------------------------------------------------#
# Mise à jour de la valeur d'un paramètre dans l'écran ADWP
#-------------------------------------------------------------------------------------#
Subprog MAJ_PARAM_ADWP(PPARAM,PVALEUR,PMESSAGE)
Value Char PPARAM
Value Integer PVALEUR
Value Integer PMESSAGE

  For IND = 0 To [M:ADW1]NBVAR-1
    If [M:ADWP]PARAM(IND) = PPARAM Then
      [M:ADWP]VALINT(IND) = num$(PVALEUR)
      [M:ADWP]VALEUR(IND) = mess(PVALEUR,PMESSAGE,1)
      Affzo [M:ADWP]VALEUR(IND)
      Break
    Endif
  Next IND

End

#-------------------------------------------------------------------------------------#
# Mise à jour de la valeur d'un paramètre dans l'écran ADW1
#-------------------------------------------------------------------------------------#
Subprog MAJ_PARAM_ADW1(PPARAM,PVALEUR,PMESSAGE)
Value Char PPARAM
Value Integer PVALEUR
Value Integer PMESSAGE

  Local Char GROUPE
  # Recherche du groupe du paramètre
  Call RECUP_GROUPE(PPARAM,GROUPE)
  If GROUPE = "" Then End Endif

  For IND = 0 To [M:ADW1]NBVAR-1
    If [M:ADW1]GRPPAR(IND) = GROUPE and [M:ADW1]PARAM(IND) = PPARAM Then
      [M:ADW1]VALINT(IND) = num$(PVALEUR)
      [M:ADW1]VALEUR(IND) = mess(PVALEUR,PMESSAGE,1)
      Break
    Endif
  Next IND

End

################################################################
# ALIM_MSG : Alimentation du message d'erreur qui peut contenir
# plusieurs messages successifs.
# Si la longueur du message dépasse 250 (longueur maximum de
# GMESSAGE), on ne concatène pas le dernier message.
################################################################
# Paramètres E/S : P_MSG : Message actuel et message retourné
#            E   : PNEW_MSG : Message à ajouter
#            E/S : OK
################################################################
Subprog ALIM_MSG(P_MSG,PNEW_MSG,OK)
Variable Char P_MSG
Value Char PNEW_MSG
Variable Integer OK

  Local Char L_MSG(251)

  If P_MSG = "" Then
     L_MSG = PNEW_MSG
  Else
     L_MSG = P_MSG + chr$(10) + chr$(13) + PNEW_MSG
  Endif
  If len(L_MSG) <= 250 Then
     # le nouveau message n'est pas trop long pour GMESSAGE, donc je le récupère
     P_MSG = L_MSG
  Endif
  OK=0
End

