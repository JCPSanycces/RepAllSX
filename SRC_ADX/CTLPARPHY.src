#-----------------------------------------------------#
# Vérification des paramètres
#-----------------------------------------------------#
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM        # Nom du paramètre en cours de saisie
Variable Char VALEUR    # Valeur saisie à contrôler
Variable Integer OK     # 1 si contrôle satisfait, 0 si saisie incorrecte

Case PARAM
  When "PHYAUTNUM"  Gosub VERF_PHYAUTNUM
  When "PHYAUTCRE"  Gosub VERF_PHYAUTCRE
  # FQ109840 When "PHYNUMBCO"  Gosub VERF_PHYNUMBCO
  # FQ109841 When "PHYFMTCOU"  Gosub VERF_PHYFMTCOU
  When Default
Endcase

End

