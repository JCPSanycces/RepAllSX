#----------------------------------------------------------------------------------#
# Recherche du nombre de fois où le mot clé reçu en paramètre est présent dans la
# valeur du paramètre société reçue en paramètre
#----------------------------------------------------------------------------------#
Subprog CAL_NB_FOIS(PVALEUR,PMOTCLE,LNB_FOIS,LDEB_PARAM)
Value Char PVALEUR  # valeur dans laquelle on va chercher le mot clé
Value Char PMOTCLE  # mot clé que l’on recherche dans la valeur
Variable Integer LNB_FOIS   # nombre de fois où le mot clé est présent dans la valeur
Variable Integer LDEB_PARAM   # 1ère position du mot clé dans la valeur

Local Integer LPOS_DEB   # Position de départ de la recherche dans une chaîne
Local Integer LPOS_PARAM # Position du paramètre recherché dans la chaîne

LNB_FOIS=0 : LDEB_PARAM=0 : LPOS_DEB=1 : LPOS_PARAM=0
Repeat
  If LPOS_DEB>len(PVALEUR) # on a parcouru toute la valeur
    LPOS_PARAM=0
  Else
    LPOS_PARAM=instr(LPOS_DEB,PVALEUR,PMOTCLE)
    If LPOS_PARAM>0 # on l’a trouvé
      LNB_FOIS+=1
      If LNB_FOIS=1 Then
        # Sauvegarde de la 1ère position du mot clé
        LDEB_PARAM=LPOS_PARAM
      Endif
      LPOS_DEB=LPOS_PARAM+len(PMOTCLE)
    Endif
  Endif
Until LPOS_PARAM=0
End

