#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTOPNPER","FOPNPER",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
 When "SORTIE"      : Gosub SORTIE # <JFL>
Endcase
Return

$OUVRE
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
Return

$INIT
Gosub OUVRE
Return

$INIT_DIA
Raz [M:DIA]
Return

$CONTROLE
# <JFL>
Call UNLOCKCPY() From AX3MONO
Call LOCKCPY([M]CPY, OK) From AX3MONO
If !OK : FIN=1 : Endif
# </JFL>
Return

$SORTIE
Call UNLOCKCPY() From AX3MONO # <JFL>
Return

$EXEC
TIT = mess(76,107,1)  :# Ré-ouverture période
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(2,116,1)-":"-[M]CPY-"\",0) From GESECRAN

Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ

OK=0
Call DEBTRANS From GLOCK
Gosub TR1

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
TRA = 1
Return

$TR1
Trbegin [PER]

OK=0
For I=0 To [M]NBLIG-1
 If [M]OPNPER(I)=2

  Call OPNPER([M]CPY,[M]LEDTYP(I),[M]STRDAT(I),OK)
  If OK : Break : Endif

 Endif
Next I

GPOINT = "AFTOPNPER" : Gosub ENTREE From EXEFNC

Case OK
 When 1 : Goto AB_TR1
 When 2 : Goto ROLL_TR1
Endcase
Commit
Return


Subprog OPNPER(SOC,LEDTYP,DATDEB,STAT)
Value Char SOC
Value Integer LEDTYP
Value Date DATDEB
Variable Integer STAT
Local Decimal EXERCICE, PERIODE

Call GETPERSOC(SOC,LEDTYP,DATDEB,EXERCICE,PERIODE) From CPTSUB
Readlock [PER]PER0 = SOC ; LEDTYP ; EXERCICE ; PERIODE
If fstat = 1
 GOK = -1 : GLOCK="$PERIOD"-SOC-num$(LEDTYP)-num$(EXERCICE)-num$(PERIODE) : STAT=2 : End
Elsif fstat
 GOK = 0 : Call RSTA("PER",SOC-num$(LEDTYP)-num$(EXERCICE)-num$(PERIODE)) From GLOCK : STAT=1 : End
Else
 [F:PER]PERSTA = 2
 [F:PER]CLODAT = [0/0/0]    : # Raz de la date de clôture
 Rewrite [PER]
 If fstat
  GOK = 0 : Call FSTA("PER") From GLOCK : STAT=1 : End
 Endif
 Call PERAUT(SOC,LEDTYP,EXERCICE,PERIODE,GOK) From SUBPER
 If !GOK : STAT=1 : End : Endif
 If GTRACE<>""
  Call ECR_TRACE(mess(2,116,1)-":"-SOC-mess(3,116,1)-num$(EXERCICE)-":"-mess(59,116,1)-num$(PERIODE)-"("+mess(LEDTYP,2644,1)+")",0)
&  From GESECRAN
 Endif
Endif
End

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif


######################################################################
# Etiquettes du masque GACOPNPER [OPN]
######################################################################

Subprog C_CPY(VALEUR)
Variable Char     VALEUR()
Local Integer I, NOK

Filter [PER] Where CPY=VALEUR & PERSTA=3
Read [PER]PER0 Last
If fstat
 Effzo STRDAT, ENDDAT
 # Il n'y a aucune période à ré-ouvrir
 GMESSAGE = mess(44,101,1)
 mkstat = 2 : End
Endif

If VALEUR<>""
 Call LECTURE("CPY",VALEUR,"") From CONTOBJ
 If func AFNC.PARAM("FRADGI",VALEUR)="2"
  GMESSAGE = mess(175,107,1) : # Réouverture interdite pour cette société
  mkstat = 2
  End
 Endif
 Call LECTURE("CPY",VALEUR,"") From CONTOBJ
 Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
 [M:DIA]NBLIG=0
 NOK=0
 For I=0 To len(mess(0,2644,1))-1
  If [F:GCM]LED(I)<>"" & [F:GCM]CFMAUT(I)<>2
   [M:DIA]LEDTYP([M]NBLIG)=I+1
   Filter [PER] Where LEDTYP=[M:DIA]LEDTYP([M]NBLIG) & CPY=VALEUR & PERSTA=3
   Read [PER]PER0 Last
   If !fstat
    [M:DIA]STRDAT([M]NBLIG) = [F:PER]PERSTR
    [M:DIA]ENDDAT([M]NBLIG) = [F:PER]PEREND
    Affzo STRDAT, ENDDAT
   Elsif fstat
    Effzo STRDAT([M]NBLIG), ENDDAT([M]NBLIG)
    Grizo OPNPER([M]NBLIG)
    NOK+=1
   Endif
   [M:DIA]NBLIG +=1
   Filter [PER]
  Endif
 Next I
 If NOK=[M]NBLIG
  # Il n'y a aucune période à ré-ouvrir
  GMESSAGE = mess(44,101,1)
  mkstat = 2 : End
 Endif
 Affzo [M:DIA]
Endif
End

$SETNOL
Local Integer NOL
NOL=nolign-1
Return

Subprog C_OPNPER(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If VALEUR = 2
 If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
 Local Decimal EXE
 Call GETEXE([M:DIA]CPY,[M:DIA]LEDTYP(NOL),[M:DIA]STRDAT(NOL),EXE) From CPTSUB
 Read [FIY]FIY0 = [M:DIA]CPY;[M:DIA]LEDTYP(NOL);EXE
 If !fstat & [F:FIY]FIYSTA=3
  ## Ré-ouverture période impossible : exercice fermé
  GMESSAGE = mess(69,101,1)-":"-tolower(mess(42,101,1))
  mkstat = 2 : End
 Endif
Endif
End

