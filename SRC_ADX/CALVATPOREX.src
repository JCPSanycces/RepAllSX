#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
######################################################################################
$EXPORT

Iomode adxirs chr$(10)        Using [VATF]
Iomode adxifs ''              Using [VATF]
Iomode adxium 50              Using [VATF]

Gosub DEC_EXP_VARS

[L]LINRECCOUNT = 0
[L]DCLRECCOUNT = 0
[L]FILRECCOUNT = 0
[L]DCLPAG      = 1

#----- File Header -----#

Wrseq format$("K:02X","01")                           ;Using [VATF]  # Record type
Wrseq format$("K:05X","ASCII")                        ;Using [VATF]  # File type
Wrseq format$("N0:02",1)                              ;Using [VATF]  # File version (fixed value of 01)
Wrseq format$("D:YYYYMMDD", date$)                    ;Using [VATF]  # File Date
Wrseq format$("K:117X","")                            Using [VATF]  # Filler (117 spaces)

#----- Declaration Header -----#
Wrseq format$("K:02X","02")                           ;Using [VATF]  # Record type
Wrseq format$("K:05X","DRECA")                        ;Using [VATF]  # Declaration type
Wrseq format$("N0:09",ctrans([F:CPY]EECNUM,"PT",""))  ;Using [VATF]  # EECNUM
Wrseq format$("D:YYYY", [F:DVPH]ENDDAT)               ;Using [VATF]  # Declaration year
Wrseq format$("K:03X", [F:DVPH]FPERIOD)               ;Using [VATF]  # Month / Quarter
If [F:DVPH]DCLQUA = 0
  Wrseq format$("K:4X","")                            ;Using [VATF]
Else
  Wrseq format$("D:MM", [F:DVPH]STRDAT)               ;Using [VATF]  # Month 1
  Wrseq format$("D:MM", [F:DVPH]ENDDAT)               ;Using [VATF]  # Month 2
Endif
Wrseq format$("K:107X","")                            Using [VATF]  # Filler (107 spaces)

FILRECCOUNT +=1 #Nﾂｺ of lines on the file

#----- Recapitulative Header -----#
Wrseq format$("K:02X","03")                          ;Using [VATF] # Record type
Wrseq format$("N0:01",[F:DVPH]FTIPENT)               ;Using [VATF] # Declaration type: 1 = first; 2- substitution; 0 = neither
If [F:DVPH]FTIPENT = 1
  # There was change in the period of submission from quarterly to monthly
  If [F:DVPH]PERCHG = 2
    Wrseq format$("N0:01",1)                         ;Using [VATF] # 1 = yes
  Else
    Wrseq format$("N0:01",2)                         ;Using [VATF] # 2 = no
  Endif
  Wrseq format$("N0:01",0)                           ;Using [VATF] #  0 = neither
  Wrseq format$("N0:01",0)                           ;Using [VATF] #  0 = neither
  Wrseq format$("N0:01",0)                           ;Using [VATF] #  0 = neither
  Wrseq format$("N0:01",0)                           ;Using [VATF] #  0 = neither
Else [F:DVPH]FTIPENT = 2
  Wrseq format$("N0:01",0)                           ;Using [VATF] #  0 = neither
  If [M:DVPHE2]NBLIG <= 0
    Wrseq format$("N0:01",0)                         ;Using [VATF] #  0 = neither
    Wrseq format$("N0:01",0)                         ;Using [VATF] #  0 = neither
    Wrseq format$("N0:01",1)                         ;Using [VATF] #  1 = yes
    Wrseq format$("N0:01",0)                         ;Using [VATF] #  0 = neither
  Else
    If [F:DVPH]PERCHG = 2
      Wrseq format$("N0:01",1)                         ;Using [VATF] # 1 = yes
      If [F:DVPH]AMTSBS = 2
        Wrseq format$("N0:01",1)                       ;Using [VATF] # 1 = yes substitution of declared value
      Else
        Wrseq format$("N0:01",2)                       ;Using [VATF] # 2 = no  substitution of declared value
      Endif
      Wrseq format$("N0:01",0)                         ;Using [VATF] #  0 = neither
      Wrseq format$("N0:01",0)                         ;Using [VATF] #  0 = neither
    Else
      Wrseq format$("N0:01",0)                         ;Using [VATF] #  0 = neither
      Wrseq format$("N0:01",0)                         ;Using [VATF] #  0 = neither
      Wrseq format$("N0:01",0)                         ;Using [VATF] #  0 = neither
      Wrseq format$("N0:01",1)                         ;Using [VATF] #  1 = yes
    Endif
  Endif
Endif
Wrseq format$("K:126X","")                            Using [VATF] # Filler (126 spaces)

[L]FILRECCOUNT +=1 # Nﾂｺ of lines on the file
[L]DCLRECCOUNT +=1 # Nﾂｺ of lines on the declaration

#----- Recapitulative lines -----
For [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM
  If [F:DVPL]AMTBAS >= 0
    [L]SNSC = "+"
  Else
    [L]SNSC = "-"
  Endif

  Wrseq format$("K:02X","04")                    ;Using [VATF]              # record type
  Wrseq format$("N0:5",[F:DVPL]LSTLIN )          ;Using [VATF]              # line number
  Wrseq format$("K:02X",[F:DVPL]CRY)             ;Using [VATF]              # prefix
  Wrseq format$("K:12X",[F:DVPL]EECNUM)          ;Using [VATF]              # NIF
  Wrseq format$("K:01X",[L]SNSC)                 ;Using [VATF]              # signal
  Wrseq format$("N0:12",abs([F:DVPL]AMTBAS*100)) ;Using [VATF]              # value
  Wrseq format$("N0:1",[F:DVPL]OPETYP)           ;Using [VATF]              # operation type
  Wrseq format$("K:99X","")                      Using [VATF]              # Filler of 99 spaces

  [L]LINRECCOUNT +=1 # Nﾂｺ of detail lines
  [L]DCLRECCOUNT +=1 # Nﾂｺ of lines on the declaration
  [L]FILRECCOUNT +=1 # Nﾂｺ of lines on the file

Next

#---- End of recapitulative
Wrseq format$("K:02X","09")                          ;Using [VATF]              # record type
Wrseq format$("N0:05",LINRECCOUNT)                   ;Using [VATF]              # Nﾂｺ of detail records
Wrseq format$("N0:09",[F:CPY]PORCTFACN)              ;Using [VATF]              # TOC NIF
[L]DCLFLD = "010" : Gosub READ_FLD_VAL
Wrseq [L]SNSC+format$("N0:12",abs([F:DVPF]AMT*100))  ;Using [VATF]
[L]DCLFLD = "011" : Gosub READ_FLD_VAL
Wrseq [L]SNSC+format$("N0:12",abs([F:DVPF]AMT*100))  ;Using [VATF]
[L]DCLFLD = "017" : Gosub READ_FLD_VAL
Wrseq [L]SNSC+format$("N0:12",abs([F:DVPF]AMT*100))  ;Using [VATF]
[L]DCLFLD = "018" : Gosub READ_FLD_VAL
Wrseq [L]SNSC+format$("N0:12",abs([F:DVPF]AMT*100))  ;Using [VATF]
[L]DCLFLD = "019" : Gosub READ_FLD_VAL
Wrseq [L]SNSC+format$("N0:12",abs([F:DVPF]AMT*100))  ;Using [VATF]
Wrseq format$("K:66X","")                            Using [VATF]              # Filler of 62 spaces


[L]FILRECCOUNT +=1 # Nﾂｺ of lines on the file
[L]DCLRECCOUNT +=1 # Nﾂｺ of lines on the declaration

#--- end of declaration

Wrseq format$("K:02X","89")                     ;Using [VATF]             # record type
Wrseq format$("N0:09",[L]DCLRECCOUNT)           ;Using [VATF]          # nﾂｺ of records
Wrseq format$("K:123X","")                       Using [VATF]             # Filler of 123 spaces

[L]FILRECCOUNT +=1 # Nﾂｺ of lines on the file

#-- end of file

Wrseq format$("K:02X","99")                     ;Using [VATF]             # record type
Wrseq format$("N0:09",[L]FILRECCOUNT)           ;Using [VATF]          # nﾂｺ of records
Wrseq format$("K:123X","")                      Using [VATF]             # Filler of 123 spaces


Return
######################################################################################
######################################################################################
$READ_FLD_VAL

Read [F:DVPF]DVPF0 = [L]DCLNUM;[L]DCLPAG;[L]DCLFLD
If fstat : Raz [F:DVPF] : Endif

If [F:DVPF]AMT >= 0
  [L]SNSC = "+"
Else
  [L]SNSC = "-"
Endif

Return
######################################################################################
######################################################################################
$DEC_EXP_VARS

Local Integer  LINRECCOUNT
Local Integer  DCLRECCOUNT
Local Integer  FILRECCOUNT

Local Integer DCLPAG
Local Char    DCLFLD(3)
Local Char     SNSC(1)

Return
######################################################################################
######################################################################################

