#**
#* This Funprog is used to get parameter value defined at
#* Folder/Legislation/Company/Site level.
#*
#* Note that:
#* - The "Definition Level" of the parameter to search could be at any level.
#* - But the search level TYPCOD can only be Folder/Legislation/Company/Site,
#*   for search of value at User level, please use Funprog GET_PARAM_SUER.
#* - An heritage logic is implemented in this Funprog, which means:
#*   - If no value found for the given site, looking for the value defined
#*     for this site's company.
#*   - If no value found for the given company, looking for the value defined
#*     for this company's Legislation.
#*   - If no value found for the given legislation, looking for the value defined
#*     at Folder level.
#*
#* @param APPLI   Folder
#* @param TYPCOD  1-Folder;  2-Company;  3-Site;  5-Legislation; 0-not specified
#* @param TYPVAL  value corresponds to the TYPCOD
#* @param PARAM   Parameter code
#* @return PARAMVAL  value of parameter
#*!
Funprog GET_PARAM(APPLI, TYPCOD, TYPVAL, PARAM)
Value Char APPLI
Value Integer TYPCOD
Value Char TYPVAL, PARAM

Local Integer RES_FOUND
Local Char PARAMVAL
#
Call _GET_PARAM_SUB(APPLI, TYPCOD, TYPVAL, PARAM, RES_FOUND, PARAMVAL)

End PARAMVAL


#**
#* This Funprog is used to get parameter value defined for a given user.
#*
#* Note that:
#* - The "Definition Level" of the parameter to search must be at User level.
#* - An heritage logic is implemented in this Funprog, which means:
#*   - If no value found for the given user, looking for the Site defined in
#*     user's function profile for this parameter's Module.
#*   - Then looking for the value at this Site level.
#*   - If not found, looking at the Site's company.
#*   - If not found, looking at the company's legislation.
#*   - If not found, looking for the value defined at Folder level.
#*
#* @param APPLI   Folder
#* @param USER    User code
#* @param PARAM   Parameter code
#* @return PARAMVAL  value of parameter
#*!
Funprog GET_PARAM_USER(APPLI, USER, PARAM)
Value Char APPLI
Value Char USER, PARAM

Local Integer RES_FOUND
Local Char PARAMVAL
Local Char WSITE
WSITE = ""
#
Call _GET_PARAM_USER_SUB(APPLI, USER, WSITE, PARAM, RES_FOUND, PARAMVAL)
End PARAMVAL


#**
#* @param APPLI   Folder
#* @param CPY     Company
#* @return LEG    Legislation
#*!
Funprog GET_LEG_FROM_CPY(APPLI, CPY)
Value Char APPLI, CPY

Local Char LEG(GLONADI)
If APPLI = "" or CPY = ""
      End LEG
Endif
If APPLI = nomap
      Local File COMPANY [CPY]
Else
      Local File =APPLI+".COMPANY" [CPY]
Endif

Read [CPY]CPY0 = CPY
If !fstat
      LEG = [CPY]LEG
Endif
#Close Local File [CPY]
LogicClose File [CPY]
End LEG


#**
#* @param APPLI   Folder
#* @param SITE    Site
#* @return CPY    Company
#*!
Funprog GET_CPY_FROM_SITE(APPLI, SITE)
Value Char APPLI, SITE

Local Char CPY(GLONCPY)
If APPLI = "" or SITE = ""
      End CPY
Endif
If APPLI = nomap
      Local File FACILITY [FCY]
Else
      Local File =APPLI+".FACILITY" [FCY]
Endif
Read [FCY]FCY0 = SITE
If !fstat
     CPY = [FCY]LEGCPY
Endif
#Close Local File [FCY]
LogicClose File [FCY]
End CPY


#**
#* @param APPLI   Folder
#* @param SITE    Site
#* @return LEG    Legislation
#*!
Funprog GET_LEG_FROM_SITE(APPLI, SITE)
Value Char APPLI, SITE

Local Char LEG(GLONADI),CPY(GLONCPY)
CPY = func GET_CPY_FROM_SITE(APPLI, SITE)
If CPY <> ""
      LEG = func GET_LEG_FROM_CPY(APPLI, CPY)
Endif
End LEG


#** PRIVATE
#* This Funprog is used to get parameter value defined at
#* Folder/Legislation/Company/Site level.
#* The returned value will be put into PARAMVAL.
#*
#* Note that:
#* - The "Definition Level" of the parameter to search could be at any level.
#* - But the search level TYPCOD can only be Folder/Legislation/Company/Site,
#*   for search of value at User level, please use Subprog GET_PARAM_SUER_SUB.
#* - An heritage logic is implemented in this Subprog, which means:
#*   - If no value found for the given site, looking for the value defined
#*     for this site's company.
#*   - If no value found for the given company, looking for the value defined
#*     for this company's Legislation.
#*   - If no value found for the given legislation, looking for the value defined
#*     at Folder level.
#*
#* @param APPLI   Folder
#* @param TYPCOD  1-Folder;  2-Company;  3-Site;  5-Legislation; 0-not specified
#* @param TYPVAL  value corresponds to the TYPCOD
#* @param PARAM   Parameter code
#* @param RES_FOUND   1-value is found;   0-No value found for the given parameter
#* @param PARAMVAL    value of parameter
#*!
Subprog _GET_PARAM_SUB(APPLI, TYPCOD, TYPVAL, PARAM, RES_FOUND, PARAMVAL)
Value Char APPLI
Value Integer TYPCOD
Value Char TYPVAL, PARAM
Variable Integer RES_FOUND
Variable Char PARAMVAL


 Raz RES_FOUND, PARAMVAL
 If APPLI = "" : End : Endif

 Local Char L_LEG(GLONADI), L_CPY(GLONCPY)
 If APPLI=nomap
    Local File ADOVAL [ADW]
    Local File ADOPAR [ADP]
 Else
  Onerrgo L_APPLI_ERR_SUB
      Local File =[L]APPLI+".ADOVAL" [ADW]
      Local File =[L]APPLI+".ADOPAR" [ADP]
  Onerrgo
 Endif

 Read [ADP]ADP1 = PARAM
 If fstat : End : Endif


# typcod must be a right value - must be equal to the value of ADP]NIVDEF
# case nivdef = user only typcod = 3
# read with ADP NIVDEF to be sure to have the right value in NIVDEF


# typval site companies or leg ?
# a site must not be a cpy - the code must be different (control in GESFCY is done)


 Case [F:ADP]NIVDEF
   When 1: # looking for value at "Dossier" level
        Gosub READ_FOLDER
   #-------------------------------------------------#
   When 5: # looking for value at "Législation" level
      # hierarchie leg and then folder
      # search the right leg? typval is a leg or cpy or site  ?
      L_LEG = func GET_LEG_FROM_CPY(APPLI,TYPVAL)
      If L_LEG <> ""
           Gosub READ_LEG
           If RES_FOUND <> 1
                Gosub READ_FOLDER
           Endif
      Else
           L_CPY = func GET_CPY_FROM_SITE(APPLI, TYPVAL)
           If L_CPY <> ""
                  L_LEG = func GET_LEG_FROM_CPY(APPLI, L_CPY)
                  If L_LEG <> ""
                      Gosub READ_LEG
                      If RES_FOUND <> 1
                            Gosub READ_FOLDER
                      Endif
                  Else
                      L_LEG = TYPVAL
                      Gosub READ_LEG
                      If  RES_FOUND <> 1
                          Gosub READ_FOLDER
                      Endif
                  Endif
           Else
                L_LEG = TYPVAL
                Gosub READ_LEG
                If  RES_FOUND <> 1
                      Gosub READ_FOLDER
                Endif
           Endif
      Endif
   #-------------------------------------------------#
   When 2: # looking for value at "Société" level
       #typval is a cpy or not ?
       # a site must not be a cpy - the code must be different (control in GESFCY is done)
       L_CPY = TYPVAL
       Gosub READ_CPY
       If RES_FOUND <> 1
             # typval is a site , search cpy
             L_CPY = func GET_CPY_FROM_SITE(APPLI, TYPVAL)
             If L_CPY <> ""
                  Gosub READ_CPY
                  If RES_FOUND <> 1
                       L_LEG = func GET_LEG_FROM_CPY(APPLI, L_CPY)
                       If L_LEG <> ""
                            Gosub READ_LEG
                            If  RES_FOUND <> 1
                                Gosub READ_FOLDER
                            Endif
                        Else
                            Gosub READ_FOLDER
                        Endif
                  Endif
              Else
                  # recherch leg de la societe typval est une soc
                  L_CPY = TYPVAL
                  L_LEG = func GET_LEG_FROM_CPY(APPLI, L_CPY)
                  If L_LEG <> ""
                       Gosub READ_LEG
                       If  RES_FOUND <> 1
                                Gosub READ_FOLDER
                       Endif
                  Else
                        # it can be a leg in typval
                        L_LEG = TYPVAL
                        Gosub READ_LEG
                        If RES_FOUND <> 1
                             Gosub READ_FOLDER
                        Endif
                  Endif
              Endif
        Endif
    #-------------------------------------------------#
   When 3: # looking for value at "Site" level
       #typval is a site ?
       Read [ADW]ADW0 = "";TYPVAL;PARAM
       If !fstat
            RES_FOUND = 1
       Else
            Gosub READ_WITH_HERITAGE
       Endif
    #-------------------------------------------------#
   When 4: # looking for value at "user" level
       If [F:ADP]VALDEF= 2
           # on a le droit - heritage du niveau superiuer autorisé
           # typcod = 3 on vient du call user ou on n a pas trouvé
           # typcod = 3 on vient aussi de adoval
           If TYPCOD = 3
                 Read [ADW]ADW0 = "";TYPVAL;PARAM
                 If !fstat
                      RES_FOUND = 1
                 Else
                      Gosub READ_WITH_HERITAGE
                 Endif
             Endif
       Endif
  Endcase

  If RES_FOUND = 1
        PARAMVAL = [F:ADW]VALEUR
  Endif

LogicClose File [ADP]
LogicClose File [ADW]

End

#** PRIVATE
#* This Funprog is used to get parameter value defined for a given user.
#* Returned value is put into PARAMVAL.
#*
#* Note that:
#* - The "Definition Level" of the parameter to search must be at User level.
#* - An heritage logic is implemented in this Funprog, which means:
#*   - If no value found for the given user, looking for the Site defined in
#*     user's function profile for this parameter's Module.
#*   - Then looking for the value at this Site level.
#*   - If not found, looking at the Site's company.
#*   - If not found, looking at the company's legislation.
#*   - If not found, looking for the value defined at Folder level.
#*
#* @param APPLI  Folder
#* @param USER   User code
#* @param SITE   site code if call by subaus else empty (in some case the site is given instead of user)
#* @param PARAM  Parameter code
#* @param RES_FOUND  1-value is found;   0-No value found for the given parameter
#* @param PARAMVAL  value of parameter
#*!
Subprog _GET_PARAM_USER_SUB(APPLI, USER, SITE, PARAM, RES_FOUND, PARAMVAL)
Value Char APPLI
Value Char USER
Value Char SITE
Value Char PARAM
Variable Integer RES_FOUND
Variable Char PARAMVAL

 Raz RES_FOUND, PARAMVAL

 If APPLI = "" : End : Endif

 Local Integer  L_MODULE
 Local Char L_SITE(GLONFCY), L_PROFILE(GLONAFT)
 If APPLI=nomap
      Local File ADOPAR    [ADP]
      Local File ADOVALAUS [ADU]
      Local File AUTILIS   [AUS]
      Local File AMETUTI   [AME]
      Local File ADOVAL    [ADW]
 Else
  Onerrgo L_APPLI_ERR_SUB
      Local File =APPLI+".ADOPAR"    [ADP]
      Local File =APPLI+".ADOVALAUS" [ADU]
      Local File =APPLI+".AUTILIS"   [AUS]
      Local File =APPLI+".AMETUTI"   [AME]
      Local File =APPLI+".ADOVAL"    [ADW]
  Onerrgo
 Endif

 Read [ADP]ADP1 = PARAM
 If fstat : End : Endif

 Read [ADU]ADU0 = USER; PARAM
 If !fstat
      PARAMVAL = [F:ADU]VALEUR
      RES_FOUND = 1
 Endif

 If !RES_FOUND and [F:ADP]VALDEF=2
      # in some case the  site must be given in the call
      If SITE <> ""
           Call _GET_PARAM_SUB(APPLI, 3, SITE, PARAM, RES_FOUND, PARAMVAL)
      Else
          # Get the site of user
          L_PROFILE = ""
          Read [AUS]CODUSR = USER
          If fstat = 0
              If [F:AUS]PRFFCT=""
                  Read [AME]AME0 = [F:AUS]CODMET
                  If fstat = 0
                     L_PROFILE = [F:AME]PRFFCT
                  Endif
              Else
                  L_PROFILE = [F:AUS]PRFFCT
              Endif
          Endif
          # the profil can not be empty ....if empty the connexion in x3 is not available
          # get value at Site level
          # add in 901 ADI module for chapter
          If L_PROFILE<>""
                # get Module from Chapter
                L_MODULE = func AFNC.GET_MODULE_FROM_CHP(APPLI,[F:ADP]CHAPITRE)
                # get site from adi 901
                L_SITE = func AFNC.GET_SITE_FROM_MDL(APPLI,L_MODULE,L_PROFILE)
                If L_SITE <> ""
                      Call _GET_PARAM_SUB(APPLI, 3, L_SITE, PARAM, RES_FOUND, PARAMVAL)
                Endif
          Endif
      Endif

      If !RES_FOUND
        # get value at "Dossier" level
        #Call GET_PARAM_SUB(APPLI, 1, APPLI, PARAM, RES_FOUND, PARAMVAL)
        Gosub READ_FOLDER
        If RES_FOUND = 1
               PARAMVAL = [F:ADW]VALEUR
        Endif
     Endif
 Endif

 LogicClose File [ADP]
 LogicClose File [ADU]
 LogicClose File [AUS]
 LogicClose File [AME]
 LogicClose File [ADW]
End


$L_APPLI_ERR_SUB
End


#------------------#
# read data in dababase direcly
# jira 85115 simplified the code
# gosub can be launched from adoval and site must be used in some cases
# valeur is used and param
Subprog _READ_DATA_ADOVAL(APPLI, SITE, PARAM, RES_FOUND, PARAMVAL)
Value Char APPLI
Value Char SITE
Value Char PARAM
Variable Integer RES_FOUND
Variable Char PARAMVAL

Raz RES_FOUND, PARAMVAL

Local Integer WTYPCOD
WTYPCOD = 3

Call _GET_PARAM_SUB(APPLI, WTYPCOD, SITE, PARAM, RES_FOUND, PARAMVAL)
If RES_FOUND <> 1
      Raz PARAMVAL
Endif
End

#------------------#
# read data in dababase direcly
# jira 85115 simplified the code
# gosub can be launched from subaus and  site must be used in some cases
# valeur is used and param
Subprog _READ_DATA_ADOVALAUS(APPLI, USER, SITE, PARAM, RES_FOUND, PARAMVAL)
Value Char APPLI
Value Char USER
Value Char SITE
Value Char PARAM
Variable Integer RES_FOUND
Variable Char PARAMVAL

Raz RES_FOUND, PARAMVAL

Call _GET_PARAM_USER_SUB (APPLI, USER, SITE, PARAM, RES_FOUND, PARAMVAL)
If RES_FOUND <> 1
        Raz PARAMVAL
Endif
End


#------------------#
# read value cpy in database
$READ_CPY
Read [ADW]ADW0 = L_CPY;"";PARAM
If !fstat : RES_FOUND = 1 : Endif
Return

#------------------#
# read value leg in database
$READ_LEG
Read [ADW]ADW0 = "*";L_LEG;PARAM
If !fstat : RES_FOUND = 1 : Endif
Return

#------------------#
# read value folder in database
$READ_FOLDER
Read [ADW]ADW0 = "";"";PARAM
If !fstat : RES_FOUND = 1 : Endif
Return

#------------------#
# read in  using heritage in database
# company - leg - folder
$READ_WITH_HERITAGE
L_CPY = func GET_CPY_FROM_SITE(APPLI, TYPVAL)
If L_CPY <> ""
       Gosub READ_CPY
       If RES_FOUND <> 1
               L_LEG = func GET_LEG_FROM_CPY(APPLI, L_CPY)
               If L_LEG <> ""
                       Gosub READ_LEG
                       If RES_FOUND <> 1
                              Gosub READ_FOLDER
                       Endif
               Else
                       Gosub READ_FOLDER
               Endif
       Endif
 Else
       # it can be a societe
       L_CPY = TYPVAL
       Gosub READ_CPY
       If RES_FOUND <> 1
             # it can be a leg in typval
             L_LEG = func GET_LEG_FROM_CPY(APPLI, L_CPY)
             If L_LEG <> ""
                   Gosub READ_LEG
                   If  RES_FOUND <> 1
                          Gosub READ_FOLDER
                   Endif
             Else
                   L_LEG = TYPVAL
                   Gosub READ_LEG
                   If RES_FOUND <> 1
                           Gosub READ_FOLDER
                   Endif
             Endif
       Endif
Endif
Return

