#<AdxTL>@(#)3.0.0.0 $Revision$
# Class BPSUPPLIERM
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"             :  Gosub AREAD_AFTER
        When "AQUERY_TRANS_AFTER"      :  Gosub AQUERY_TRANS_AFTER
      Endcase
    When "BPS.BPD"
      Case [L]AEVENT
        When "AREAD_AFTER"             :  Gosub AREAD_AFTER_BPD
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#  Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#  Endcase
Return

###################################################################################################
$AREAD_AFTER
Local Integer IRET
Local Shortint IOSTCTL

#--Chargement des libellés des adresses
Gosub LOAD_ADDNAM
Return

###################################################################################################
$AQUERY_TRANS_AFTER
  Local File BPADDRESS [BPA]
  Read [F:BPA]BPA0=1;this.BPS.BPSNUM;this.BPS.BPAADD
  If !fstat
   #this.RPOSCOD =  [F:BPA]POSCOD
  Endif
Return

###################################################################################################
$AREAD_AFTER_BPD
Local Integer IRET

  If this.APARENT=null Return Endif
  Local File BPADDRESS [BPA]
  #--Libellé code adresse client livré
  If this.BPAADD<>"" and this.BPSNUM<>"" and this.APARENT.BPSTYP>0
  Read [F:BPA]BPA0=this.APARENT.BPSTYP;this.BPSNUM;this.BPAADD
  If fstat : Raz [F:BPA] Endif
  this.BPAADDNAM = [F:BPA]BPADES
  Endif
Return

###################################################################################################
$LOAD_ADDNAM
  Local File BPADDRESS [BPA]
  #--Libellé code adresse tiers facture
  If this.BPS.BPAINV<>"" and this.BPS.BPSINV<>"" and this.BPS.BPSTYP>0
  Read [F:BPA]BPA0=this.BPS.BPSTYP;this.BPS.BPSINV;this.BPS.BPAINV
  If fstat : Raz [F:BPA] Endif
  this.BPAINVNAM = [F:BPA]BPADES
  Endif
Return

