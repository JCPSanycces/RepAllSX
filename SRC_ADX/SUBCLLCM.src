#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
#   Composants technique de gestion des appels     Module CRM       mai 2006
#
# UPDCLL    : Sous-programme de mise à jour d'un appel.
#
##########################################################################################################
Subprog TEST
Local Char SZCLLNUM
Local Integer LERRCOD

  GSYNCOUTLOOK = 1
  SZCLLNUM = "000000000069542"
  If GTRACE <> "" Then
    Call FERME_TRACE From LECFIC
  Endif
  Call UPDCLL("SUBCLLCM", 2, 2, SZCLLNUM, LERRCOD) 
  GSYNCOUTLOOK = 0
  If GTRACE <> "" Then
    Call FERME_TRACE From LECFIC
  Endif
End

##########################################################################################################
Subprog UPDCLL(SZUPDCLLTRT, ITRACE, ILEC_TRACE, SZCLLNUM, LERRCOD) 
Value Char SZUPDCLLTRT
Value Integer ITRACE
Value Integer ILEC_TRACE
Value Char SZCLLNUM
Variable Integer LERRCOD

Global Char GSZUPDCLLTRT
Global Integer GIUPDCLLTRACE

Local Integer IBOPENTRACE
Local Integer IBDEBTRANSFLG

  IBOPENTRACE = 0
  GSZUPDCLLTRT = SZUPDCLLTRT
  GIUPDCLLTRACE = ITRACE
  If GSZUPDCLLTRT = "" Then
    GSZUPDCLLTRT = "SUBCLLCM"
  Endif
  Raz LERRCOD, GMESSAGE
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If ITRACE Then
    If GTRACE = "" Then
      #Modification d'un appel démarré à partir du contexte : + GSZUPDCLLTRT
      Call OUVRE_TRACE (mess(344,177,1) + GSZUPDCLLTRT) From LECFIC
      IBOPENTRACE = 1
    Endif
  Endif
  If ITRACE Then
    #Modification de l'appel + " : " + SZCLLNUM
    Call ECR_TRACE(mess(345,177,1)+ " : " + SZCLLNUM,0)From GESECRAN
  Endif
#--- variables
Local  Integer OK, SAVGIMPORT 
Local  Char    ACTION(20), ABREV(5) 
Local Char SAVGABREV

  #--- declaration et chargement des variables objet 
  ABREV = "CLL"
  SAVGABREV = GABREV
  GABREV = "CLL"
  Gosub DEFVAR From GOBJET    # FGR 07/06/2010 : X3SUIVI64666 A faire juste après GABREV
  #
  SAVFONC = GFONCTION         # FGR 16/09/2009 : X3SUIVI57846
  GFONCTION = "GES"+ABREV     # FGR 16/09/2009 : X3SUIVI57846
  #Gosub DEFVAR From GOBJET   # FGR 07/06/2010 : X3SUIVI64666 là on perd SAVFONC !
  SAVGIMPORT = GIMPORT
  GIMPORT = 1
  #Gestion des autorisations
  Call AUTORIS From EXEFNC
  GOK = 1
  OK = 1
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=AVANT_OUVRE",0) From GESECRAN
  Endif
  ACTION = "AVANT_OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR AVANT_OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #--- ouverture de la fenêtre contrat
  If clalev([M:CLL0])=0 : Local Mask CLL0 [CLL0] : Endif
  If clalev([M:CLL1])=0 : Local Mask CLL1 [CLL1] : Endif
  If clalev([M:CLL3])=0 : Local Mask CLL3 [CLL3] : Endif
  Raz [M:CLL0], [M:CLL1], [M:CLL3]
  #--- ouverture des tables necessaires
  If clalev([F:CLL])=0 : Local File PHONECALL [CLL] : Endif
  Gosub OUVRE From WOCLL 
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=OUVRE",0) From GESECRAN
  Endif
  ACTION = "OUVRE"       : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  WINPROG = "WGOCLL"
  GREP = "M"
  Read [CLL]CLL0=SZCLLNUM
  If fstat Then
    LERRCOD = 4
    #Erreur lors de la lecture de l'appel + " : " +SZCLLNUM
    Call ECR_TRACE(mess(346,177,1)+ " : " +SZCLLNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  [M:CLL0] = [F:CLL]
  [M:CLL1] = [F:CLL]
  [M:CLL3] = [F:CLL]
  Default Mask [CLL0]
  Default Mask [CLL1]
  Default Mask [CLL3]
  ACTION = "LIENS"   : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR LIENS",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #------------------------------------------------------------------------ 
  #--- chargement des masques de objet
  If ITRACE > 1 Then
    Call ECR_TRACE("MASK",0) From GESECRAN
  Endif
  # chargement masques enregistrement entête tache
  Default Mask [CLL0]
  Call SAIMSK("CLL","IMP_ZONE","SUBCLLCM") From W0CLL0
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK CLL0 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [CLL1]
  Call SAIMSK("CLL","IMP_ZONE","SUBCLLCM") From W0CLL1
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK CLL1 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [CLL3]
  Call SAIMSK("CLL","IMP_ZONE","SUBCLLCM") From W0CLL3
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK CLL3 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  GPOINT = "MSKUPDCLL" : Gosub ENTREE From EXEFNC  #CHECK IGNORE_LINE
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  GPOINT=MSKUPDCLL mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 8
    Gosub ONERROR
    End
  Endif
  OK = 1
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=VERIF_CRE",0) From GESECRAN
  Endif
  ACTION = "VERIF_MOD"   : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR VERIF_MOD",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  Read [CLL]CLL0=SZCLLNUM
  If fstat Then
    LERRCOD = 4
    #Erreur lors de la lecture de l'appel + " : " +SZCLLNUM
    Call ECR_TRACE(mess(346,177,1)+ " : " +SZCLLNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  Readlock [CLL]Curr
  If fstat <> 0 Then
    #Impossible de locker l'appel+" : "+SZCLLNUM
    Call ECR_TRACE(mess(347,177,1)+" : "+SZCLLNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  Raz [F:CLL]
  Default File [F:CLL]
  [F:CLL] = [M:CLL0]
  [F:CLL] = [M:CLL1]
  [F:CLL] = [M:CLL3]
  [F:CLL]UPDUSR = GUSER
  [F:CLL]UPDDAT = date$
  If ITRACE > 1 Then
    #Réécriture [F:CLL]  -  CLLNUM=+[F:CLL]CLLNUM
    Call ECR_TRACE(mess(348,177,1)+[F:CLL]CLLNUM,0) From GESECRAN
  Endif
  GOK = 1
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [CLL]
  Endif
  Rewrite [F:CLL]
  If fstat Then
    Call ECR_TRACE("  ERROR Rewrite [F:CLL] fstat="+num$(fstat),1) From GESECRAN
    LERRCOD = 9
    GOK = 0
    Call FSTA("CLL") From GLOCK
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=MODIF",0) From GESECRAN
  Endif
  ACTION = "MODIF"    : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR MODIF",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If IBDEBTRANSFLG = 0 Then
    Commit
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=APRES_MOD",0) From GESECRAN
  Endif
  ACTION = "APRES_MOD"   : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR APRES_MOD",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=FERME",0) From GESECRAN
  Endif
  ACTION = "FERME"       : Gosub ACTION From GOBJSUB
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC         # FGR 16/09/2009 : X3SUIVI57846
  Kill GSZUPDCLLTRT 
  Kill GIUPDCLLTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC  
    Endif
  Endif
End

##########################################################################################################
$ACTION
Local Char SZVALBEFORE
Local Char SZVALAFTER
Local Integer IBTESTOK

  IBTESTOK = 0
  Raz SZVALBEFORE
  Raz SZVALAFTER
  If evalue("type([M]"+IMPZON+")") < 300 Then
    IBTESTOK = 1
  Endif
  If IBTESTOK = 1 Then
    SZVALBEFORE = num$(evalue("[M]"+IMPZON))
  Endif
  If GIUPDCLLTRACE > 1 Then
    Call ECR_TRACE("ACTION = "+ACTION-"IMPZON="+IMPZON-"XOK="+num$(XOK),0) From GESECRAN 
    If IBTESTOK = 1 Then
      #"    "+Valeur avant = +" : " +SZVALBEFORE 
      Call ECR_TRACE("    "+  mess(369,177,1)+" : "+ SZVALBEFORE ,0) From GESECRAN 
    Endif
  Endif
  Case ACTION 
    When "IMP_ZONE"
      Gosub CLL_SET_HEA_INFO From=GSZUPDCLLTRT
    When "IMP_TAB"
      Gosub CLL_SET_DET_INFO From=GSZUPDCLLTRT
  Endcase
  If IBTESTOK = 1 Then
    SZVALAFTER = num$(evalue("[M]"+IMPZON))
    If SZVALAFTER <> SZVALBEFORE Then
      IMPMOD = 1
    Endif
  Else
    IMPMOD = 1
  Endif
  If GIUPDCLLTRACE > 1 Then
    If IBTESTOK = 1 Then
      #"    "+Valeur après = +" : " +SZVALAFTER
      Call ECR_TRACE("    "+mess(370,177,1)+" : "+ SZVALAFTER,0) From GESECRAN 
    Endif
  Endif
Return

##########################################################################################################
$ONERROR
  If IBDEBTRANSFLG = 0 Then
    If adxlog Then
      Rollback
    Endif
  Endif
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GOK = 0
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC         # FGR 16/09/2009 : X3SUIVI57846
  Kill GSZUPDCLLTRT 
  Kill GIUPDCLLTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC  
    Endif
  Endif
Return

##########################################################################################################
# Affectation des valeurs pour la création d'un appel. (exemple)
#############################################################################
$CLL_SET_HEA_INFO
  Case IMPZON
    When "CLLNUM"     
      #[M:CLL0]CLLNUM=""       
    When "SALFCY"
      #[M:CLL0]SALFCY=""
    When "CLLCMP"
      [M:CLL0]CLLCMP="SERVCORP"
    When "CLLDON"
      [M:CLL0]CLLDON=1
    When "CLLCCN"
      #[M:CLL0]CLLCCN=""
    When "CLLPJT"
      #[M:CLL0]CLLPJT=""
    When "CLLDAT"
      [M:CLL1]CLLDAT=date$+10
    When "CLLSTR"
      [M:CLL1]CLLSTR=date$
      #[M:CLL1]CLLORI=1
      [M:CLL1]CLLORIADI = "MAN1"  # FGR 05/03/2010 : X3SUIVI62924
      #[M:CLL1]CLLORITXT=""
      [M:CLL1]CLLORIVCR=""
      [M:CLL1]CLLORIVCRL=0
      [M:CLL1]CLLCMGNUM=""
      [M:CLL1]CLLOPGNUM=""    
      [M:CLL1]CLLOPGTYP=""
    When "CLLTYP"
      [M:CLL0]CLLTYP=2
    When "CLLREP"
      [M:CLL1]CLLREP="LSE12"
    When "CLLSAO"
      #[M:CLL3]CLLSAO=""
  Endcase
Return

##########################################################################################################
# Affectation des valeurs pour la création d'un appel. (exemple)
#############################################################################
$CLL_SET_HEA_INFO_EXMPLE
  Case IMPZON
    When "CLLNUM"     
      [M:CLL0]CLLNUM=""       
    When "SALFCY"
      [M:CLL0]SALFCY=""
    When "CLLCMP"
      [M:CLL0]CLLCMP=""
    When "CLLCCN"
      [M:CLL0]CLLCCN=""
    When "CLLPJT"
      [M:CLL0]CLLPJT=""
    When "CLLDON"
      [M:CLL0]CLLDON=""
    When "CLLDAT"
      [M:CLL1]CLLDAT=""
    When "CLLSTR"
      [M:CLL1]CLLSTR=""
      #[M:CLL1]CLLORI=""
      [M:CLL1]CLLORIADI = "MAN1"  # FGR 05/03/2010 : X3SUIVI62924
      #[M:CLL1]CLLORITXT=""
      [M:CLL1]CLLORIVCR=""
      [M:CLL1]CLLORIVCRL=""
      [M:CLL1]CLLCMGNUM=""
      [M:CLL1]CLLOPGNUM=""    
      [M:CLL1]CLLOPGTYP=""
    When "CLLTYP"
      [M:CLL0]CLLTYP=""
    When "CLLREP"
      [M:CLL1]CLLREP=""
    When "CLLDEL"
      [M:CLL1]CLLDEL=""
    When "CREDAT"
      [M:CLL1]CREDAT=""
    When "CREHOUP"
      [M:CLL1]CREHOU=""
    When "HOUTIMPSG"
      [M:CLL2]HOUTIMPSG=""
    When "MNTTIMSPG"
      [M:CLL2]MNTTIMSPG=""
    When "CLLSAO"
      [M:CLL2]CLLSAO=""
  Endcase
Return
