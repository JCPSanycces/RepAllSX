#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
#                    Situation weighing containers                         #
############################################################################
# Action parameters via PARAM()                                            #
# 1  = site/SITE                                                           #
# 2  = Document No/VCRNUM                                                  #
############################################################################

Local Char PARAM(20)(1..10)
PARAM(1) = "GAL"
PARAM(2) = ""
Call GCONSULT("SHO","",PARAM) From GCONSULT
End

$ACTION
  Case ACTION
    When "AUTORIS"    : Gosub AUTORIS
    When "FERME"      : Gosub FERME
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "SETBOUT"    : Gosub SETBOUT
    When "EXEBOUT"    : Gosub EXEBOUT
    When "FIN_CRIT"   : Gosub FIN_CRIT
    When Default
  Endcase
Return

############################################################
$AUTORIS
Return

############################################################
$OUVRE
  Local Integer WSRT,WRET
  Local Char    CRITERE(255)
  Local Char    CRITERE1(255)
  Local Char    CRITERE2(255)
  Local Char    CRITERE3(255)
  Local Char    FORMULE1(250)

  If clalev ([F:FCY])  <= 0 : Local File FACILITY   [FCY] : Endif
  If clalev ([F:MFM])  <= 0 : Local File MFGMAT     [MFM] : Endif

  Gosub DEFCRIT

  NAVIG="CONSMWN"
Return

#############################################################################
$FERME
Return

############################################################################
$FIN_CRIT
Return

#############################################################################
# Parameter analysis
$DEFCRIT
  For I = 1 To dim(PARAM)
    Case I
      When 1 : # site
        If PARAM(I) <> ""
          Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
          If !fstat & [F:FCY]MFGFLG = 2 : [M:MWN1]MFGFCY = PARAM(I) : Endif
      Endif

      When 2 : # vcrnum
        If PARAM(I) <> ""
          [M:MWN1]MFGNUMSTR = PARAM(I)
        Endif

      When Default: Break
    Endcase
  Next I
Return

############################################################
$LECTURE
  Local Char T_CTN (8)    (1000)
  Local Shortint T_WGGSTA (1000)

  Raz T_CTN
  Raz T_WGGSTA

  #if sorting is not passed in parameter, no automatic loading
  If [M:MWN1]MFGFCY = ""  : NBLU = 0 : Return : Endif
  Gosub CHANGE_MSK From GCONSULT
  If CHGPAG < 0 : NOL = MAXLIG : Endif

  Gosub LOAD_FILTER

  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif

  Local Integer I
  Local Char LCRITERE(255)

  LCRITERE = "MFGFCY = [M:MWN1]MFGFCY & MFGNUM = [M:MWN1]MFGNUMSTR & MATSTA < 4 & PKC > 1"

  If [M:MWN1]CTNSTR <> ""
    LCRITERE += "& CTN>=[M:MWN1]CTNSTR"             # container start
  Endif

  If [M:MWN1]CTNEND <> ""
    LCRITERE += "& CTN<=[M:MWN1]CTNEND"             # container end
  Endif

  For [MFM]MFM3 Where evalue(LCRITERE)
    For I = 0 To 999 Step 1
      If T_CTN (I) = ""
        T_CTN (I) = [F:MFM]CTN
        T_WGGSTA (I) = [F:MFM]WGGSTA
        Break
      Endif

      If T_CTN (I) = [F:MFM]CTN
        If [F:MFM]WGGSTA <  T_WGGSTA (I)
           T_WGGSTA (I) = [F:MFM]WGGSTA
        Endif
        Break
      Endif
    Next I
  Next

  Gosub FILLGRID

Return

#############################################################################
$FILLGRID

  Local Integer I
  SUITE   = 1
  RETOUR  = 1

  For I = 0 To 999 Step 1
    If T_CTN (I) =  "" : Break : Endif

    If NBLU = 1
      If CHGPAG = 2 | CHGPAG = -2 : Raz [M:MWN2] : Endif
      NBLU = 2
    Endif

    If CHGPAG > 0
      If NOL >= MAXLIG-1 : SUITE = 2 : Break : Endif
      NOL    += 1
    Else
      If NOL <= 0 : RETOUR = 2 : Break : Endif
      NOL    -= 1
    Endif

    nolign = NOL+1

    [M:MWN2]MFGNUM(nolign-1) = [M:MWN1]MFGNUMSTR
    [M:MWN2]CTN(nolign-1) = T_CTN (I)
    [M:MWN2]WGGSTA(nolign-1) = T_WGGSTA (I)
   Next I

Return


#############################################################################
# Préparation du filtre                                                     #
#############################################################################
$LOAD_FILTER
Return

#############################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

#############################################################################
$LOAD_CRITERE2
If len(CRITERE2)<>0 : CRITERE2 += "&" : Endif
CRITERE2 += CRITERE
Return

#############################################################################
$LOAD_CRITERE3
If len(CRITERE3)<>0 : CRITERE3 += "&" : Endif
CRITERE3 += CRITERE
Return

#############################################################################
$SETBOUT
Return

#############################################################################
$EXEBOUT
Return

#############################################################################
Subprog AM_CTNSTR(VALEUR)
Variable Char    VALEUR()

  If [M:MWN1]CTNEND = ""     : [M:MWN1]CTNEND = VALEUR : Affzo [M:MWN1]CTNEND : Endif
  If [M:MWN1]CTNEND < VALEUR : [M:MWN1]CTNEND = VALEUR : Affzo [M:MWN1]CTNEND : Endif
End

#########################################################################
# For execution validation consultation screens in patch management     #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(8)<>2 End Endif

Call VALGTC(APPLI,"MWN") From SUBGTC

End

