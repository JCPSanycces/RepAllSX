#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENEMPV 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:25"
A_USER  = "DOC"
A_STAMP = "20181109230425"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "BPAG"
  If [M]BPAG=0
  Endif
 When "NBHIS"
  If [M]NBHIS=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask GENEMPV [DIB]
Gosub HORODAT
Local Inpbox "GENEMPV" From GFONCTION At A_STAMP With A_WINDPREV Mask [DIB] As [SIM_]
Grizo [DIB]20
Grizo [DIB]30
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DIB]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=25 : X2(0)=88 : Y1(0)=5 : Y2(0)=14
X1(1)=25 : X2(1)=88 : Y1(1)=15 : Y2(1)=23
Return

$ON_OPT
Onevent INIT_AREA Call D_OPT(zc) From W1GENEMPV
Onevent BEFORE_INPUT Call AS_OPT(zc) From W1GENEMPV
Return

Subprog D_OPT(VALEUR)
Variable Integer VALEUR
If varinit([M]OPT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_OPT(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CODFIC
Onevent CONTROL Call C_CODFIC(zc) From W1GENEMPV
Onevent BEFORE_INPUT Call AS_CODFIC(zc) From W1GENEMPV
Return

Subprog AS_CODFIC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CODFIC(zc) From W1GENEMPV
Onkey 144 Titled GBOUTP Call P_CODFIC(zc) From W1GENEMPV
Onkey 146 Titled GBOUTA Call SA_CODFIC(zc) From W1GENEMPV
Gosub _AFF
End

Subprog C_CODFIC(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ATB","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "CODFIC" : GZNUM = 6 : Endif
Gosub _AFF
End

Subprog S_CODFIC(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ATB"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_CODFIC(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ATB"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CODFIC(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ATB",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

