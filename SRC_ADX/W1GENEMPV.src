$ON_HISTBL
Onevent CONTROL Call C_HISTBL(zc) From W1GENEMPV
Onevent BEFORE_INPUT Call AS_HISTBL(zc) From W1GENEMPV
Return

Subprog AS_HISTBL(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_HISTBL(zc) From W1GENEMPV
Onkey   2 Titled GBOUTS Call S_HISTBL(zc) From W1GENEMPV
Onkey 144 Titled GBOUTP Call P_HISTBL(zc) From W1GENEMPV
Onkey 146 Titled GBOUTA Call SA_HISTBL(zc) From W1GENEMPV
Gosub _AFF
End

Subprog C_HISTBL(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ATB","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "HISTBL" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog S_HISTBL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ATB"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_HISTBL(VALEUR)
Variable Char    VALEUR()
Call OBJET("ATB",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_HISTBL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ATB"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_HISTBL(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ATB",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$CHG_STY
Return


