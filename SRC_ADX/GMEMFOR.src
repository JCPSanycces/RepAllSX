#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE

 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "CHX_TABLE"   : Gosub CHX_TABLE

 When "OUVRE"       : Gosub OUVRE
 When "TITRE"       : Gosub TIT
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
Endcase
Return

######################################################################################

$INIT
Gosub OUVRE
If FIN : Return : Endif

If find(WACT,"2","3") : TYPPRG=6 : Endif

If WACT="3"
 Local Char WVAL(GLONFOG), WCLE(GLONFOG)
 WVAL = VALEUR
Endif
Return

$CONTROLE
If GSTATUT=GSTAESC : FIN=1 
Elsif WACT="2" : mkstat=99
Elsif [F:FOG]FORCOD<>""
 GOK=1
 GCLE = [F:FOG]CODMSK-[F:FOG]CODZON-[F:FOG]USR-[F:FOG]FORCOD
 WCLE = [F:FOG]FORCOD
 Trbegin [FOG]
   Delete [FOG] =
   If fstat=1 | fstat>5
      GOK=0 : Call RSTA("FOG",GCLE) From GLOCK : Rollback : Return
   Endif
   GOK=adxdlrec
 Commit
 If GOK>0
    Call MESSAGE(WCLE-":"-mess(39,109,1)) From GESECRAN : # Mémo effacé
 Endif
 GOK=1
 VALEUR=WVAL
Endif
Return

######################################################################################

$SEL_TABLE
OBJET="FOG" : START = '[FOG]FORCOD' : ORDRE='[FOG]FORCOD;[FOG]GLOB'

Gosub SETZON
CRITERE="[FOG]CODMSK='"+WMSK+"'"-"& [FOG]CODZON='"+WZON+"'"

Local Char FORGLO(1)
If GACTION="MEMFOR2" : FORGLO="2"
Else                 : Call PARAMUTIL("FORGLO",FORGLO,"","") From SUBAUS
Endif
If FORGLO<>"2" : CRITERE+= " & [FOG]USR='"+GUSER+"'"
Else           : CRITERE+= " & find([FOG]USR,'','"+GUSER+"')<>0"
Endif
Return

$CHX_TABLE
Case GACTION
  When "MEMFOR2" : TIT(0)=mess(111,126,1) : # Rappel mémo
  When "MEMFOR3" : TIT(0)=mess(112,126,1) : # Effacement mémo
Endcase
Return

######################################################################################

$OUVRE
If !clalev([F:AMP]) : Local File AMSKPAR [AMP] : Endif
If !clalev([F:FOG]) : Local File MEMFOR  [FOG] : Endif

Local Char WACT(1), WTYP(2), FORGLO(1)

If left$(GACTION,6)="MEMFOR" : WACT = right$(GACTION,7) : Endif
If !find(WACT,"1","2","3") : FIN=1 : Return : Endif

Read [AMP]CODPAR = 1;maskcou;zoncou;"TFO"
If fstat : FIN=1 : Return : Endif

Gosub SETZON
WTYP=[F:AMP]VALPAR
Return

$SETZON
Local Char WZON(30), WMSK(GLONAMK)
WMSK=maskcou
WZON=zoncou
If evalue("dim([M]"+WZON+")")>1 
   WZON+="("+num$(indice)+")"
Else
   WZON+="("+num$(0)+")"
Endif
Return

$TIT
TIT = mess(110,126,1) : # Enregistrement mémo
Return

$DEBUT
Raz [M] : [M]CODMSK=WMSK : [M]CODZON=WZON : [M]FORTYP=val(WTYP) : [M]ACT=WACT

Call PARAMUTIL("FORGLO",FORGLO,"","") From SUBAUS
If FORGLO="2" : Actzo GLOB : Else Diszo GLOB : Endif

[M]GLOB=1
[M]VALDEF=1
Read [FOG]FOG0 = [M]CODMSK;[M]CODZON;GUSER;VALEUR
If fstat & FORGLO="2"
   Read [FOG]FOG0 = [M]CODMSK;[M]CODZON;"";VALEUR
Endif
If !fstat
   [M]VALDEF = [F:FOG]VALDEF
   [M]GLOB   = 1+([F:FOG]USR="")
Endif

[M]FORMULE = zc
Call LECTEXTRA([M]DES,"TABFOR","DES",WTYP,[M]FORMULE) From ATEXTRA
Affzo
Setmok [M] With 0
Return

$OK
Call DEBTRANS From GLOCK
Trbegin [FOG]
    Raz [F:FOG]
    [F:FOG]FORTYP = [M]FORTYP
    [F:FOG]FORCOD = [M]FORMULE
    [F:FOG]CODMSK = WMSK
    [F:FOG]CODZON = WZON
    [F:FOG]VALDEF = [M]VALDEF
    [F:FOG]GLOB   = [M]GLOB
    [F:FOG]USR    = string$([M]GLOB<>2,GUSER)
    Write [FOG]
    If fstat
       Rewrite [FOG]
    Endif

    If [M]VALDEF=2 : # une seule valeur par défaut globale/par utilsateur par zone écran
       Update [FOG] Where VALDEF=2 & USR=string$([M]GLOB<>2,GUSER) & CODMSK=WMSK & CODZON=WZON & FORCOD<>[M]FORMULE With VALDEF=1
    Endif
Commit
Return

######################################################################################
# Action MEMFOR0 : init formule selon mémos
######################################################################################
Subprog MEMINI(VALEUR)
Variable Char VALEUR

If !clalev([F:FOG]) : Local File MEMFOR [FOG] : Endif

Gosub SETZON

Filter [FOG] Where VALDEF=2
Read [FOG]FOG0(3) = WMSK;WZON;GUSER
If fstat
   Read [FOG]FOG0(3) = WMSK;WZON;""
Endif
Filter [FOG]
If !fstat : VALEUR=[F:FOG]FORCOD : Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran MEMFOR) 05/11/2012 17:16:18 (GH)
######################################################################################

Subprog AM_FORMULE(VALEUR)
Variable Char    VALEUR()

If !clalev([F:FOG]) : Local File MEMFOR [FOG] : Endif

Call LECTEXTRA([M]DES,"TABFOR","DES",num$([M]FORTYP),VALEUR) From ATEXTRA
Affzo DES

[M]GLOB=1
[M]VALDEF=1
Read [FOG]FOG0 = [M]CODMSK;[M]CODZON;GUSER;VALEUR
If fstat  & varmode([M]GLOB)=0
   Read [FOG]FOG0 = [M]CODMSK;[M]CODZON;"";VALEUR
Endif
If !fstat
   [M]VALDEF = [F:FOG]VALDEF
   [M]GLOB   = 1+([F:FOG]USR="")
Endif
Affzo GLOB, VALDEF
End

######################################################################################

Subprog AM_GLOB(VALEUR)
Variable Integer VALEUR

If !clalev([F:FOG]) : Local File MEMFOR [FOG] : Endif

[M]VALDEF=1
If VALEUR
   Read [FOG]FOG0(3) = [M]CODMSK;[M]CODZON;"";[M]FORMULE
Else
   Read [FOG]FOG0(3) = [M]CODMSK;[M]CODZON;GUSER;[M]FORMULE
Endif
If !fstat
   [M]VALDEF=[F:FOG]VALDEF
Endif
Affzo VALDEF
End

