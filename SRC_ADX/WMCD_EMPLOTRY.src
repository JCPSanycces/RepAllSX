############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(EMPLOTRY,ASTATUS)
Variable Instance EMPLOTRY Using C_EMPLOTRY
Variable Integer ASTATUS

If EMPLOTRY = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOTRY

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_EMPLOTRY

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EMPLOTRY,ASTATUS)
Variable Instance EMPLOTRY Using C_EMPLOTRY
Variable Integer ASTATUS

If EMPLOTRY = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOTRY
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EMPLOTRY
Else
 Gosub ADELETE_EMPLOTRY
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EMPLOTRY,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EMPLOTRY.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOTRY.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EMPLOTRY
Trbegin [F:TRY]
 Gosub ADELETE_EMPLOTRY
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_EMPLOTRY
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(EMPLOTRY,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOTRY._MAJSQL_EMPLOTRY(EMPLOTRY))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EMPLOTRY.snapshotEnabled=1
 [L]A_RETIK = EMPLOTRY.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOTRY.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



