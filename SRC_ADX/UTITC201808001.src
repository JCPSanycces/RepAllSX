#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTITC201808001
# Issue X3-88081 - 2018-05-21 by USA
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTITC201808001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC201808001(DOSSIER)
Value Char DOSSIER

  Local Integer COUNTUPDATED: Raz COUNTUPDATED
  Local Integer IERR: Raz IERR

  Call ECR_TRACE("UTITC201808001: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Open needed tables -----#
  Local File =DOSSIER + ".DEFBPS"    [DRS] #view returns list of default reorder suppliers      for each product
  Local File =DOSSIER + ".DEFCTMBPS" [DBS] #view returns list of default back-to-back suppliers for each product
  Local File =DOSSIER + ".ITMBPS"    [ITP]
  # -----------------
  Trbegin [ITP]
# ----------------------------------------------------------------------------------------------------------
  Call ECR_TRACE("Start updating column 'Default reorder supplier'",0) From GESECRAN
  For [DRS]
    Read [F:ITP]ITP0 = [DRS]ITMREF;[DRS]BPSNUM #in [ITP] find Product with Supplier according to record from [DRS]
    If [F:ITP]DEFBPSFLG <> 2 Then #verify in [ITP]record: Is flag <> 2 for Produkt,Suplier

      Update[F:ITP] Where [F:ITP]ITMREF = [DRS]ITMREF and [F:ITP]DEFBPSFLG <> 1  With [F:ITP]DEFBPSFLG = 1 #set 1 for all supplires
        If fstat Then
          # Error
          Call ECR_TRACE("Error during updating. File ITMBPS, product:" + [DRS]ITMREF + ", supplier:" + [DRS]BPSNUM + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          Break
        Endif

      Update[F:ITP] Where [F:ITP]ITMREF = [DRS]ITMREF and [F:ITP]BPSNUM = [DRS]BPSNUM With [F:ITP]DEFBPSFLG = 2 #set 2 for default supplier
        If fstat Then
          # Error
          Call ECR_TRACE("Error during updating. File ITMBPS, product:" + [DRS]ITMREF + ", supplier:" + [DRS]BPSNUM + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          Break
        Else
          # Success
          #Call ECR_TRACE("Set as default for Product:" + [DRS]ITMREF + ", Supplier:" + [DRS]BPSNUM, 0) From GESECRAN
          COUNTUPDATED +=1
        Endif

    Endif
  Next
  Call ECR_TRACE("End updating column 'Default reorder supplier'",0) From GESECRAN

  Call ECR_TRACE("Start updating column 'Default back-to-back supplier'",0) From GESECRAN
  For [DBS]
    Read [F:ITP]ITP0 = [DBS]ITMREF;[DBS]BPSNUM #in [ITP] find Product with Supplier according to record from [DBS]
    If [F:ITP]DEFCTMBPSFLG <> 2 Then #verify in [ITP]record: Is flag <> 2 for Produkt,Suplier

      Update[F:ITP] Where [F:ITP]ITMREF = [DBS]ITMREF and [F:ITP]DEFCTMBPSFLG <> 1  With [F:ITP]DEFCTMBPSFLG = 1 #set 1 for all btb supplires
        If fstat Then
          # Error
          Call ECR_TRACE("Error during updating. File ITMBPS, product:" + [DBS]ITMREF + ", supplier:" + [DBS]BPSNUM + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          Break
        Endif

      Update[F:ITP] Where [F:ITP]ITMREF = [DBS]ITMREF and [F:ITP]BPSNUM = [DBS]BPSNUM With [F:ITP]DEFCTMBPSFLG = 2 #set 2 for default btb supplier
        If fstat Then
          # Error
          Call ECR_TRACE("Error during updating. File ITMBPS, product:" + [DBS]ITMREF + ", supplier:" + [DBS]BPSNUM + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          Break
        Else
          # Success
          #Call ECR_TRACE("Set as default for Product:" + [DBS]ITMREF + ", Supplier:" + [DBS]BPSNUM, 0) From GESECRAN
          COUNTUPDATED +=1
        Endif

    Endif
  Next
  Call ECR_TRACE("End updating column 'Default back-to-back supplier'",0) From GESECRAN

# ----------------------------------------------------------------------------------------------------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTITC201808001: Success:) " - num$(COUNTUPDATED) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTITC201808001: records processed with error(s).", 0) From GESECRAN
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ITMBPS","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ITMBPS") : End : Endif
  # -------------------------
  Call MAJ_UTITC201808001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ITMBPS","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ITMBPS") : End : Endif
  # -------------------------
  Call MAJ_UTITC201808001(APPLI)
End

