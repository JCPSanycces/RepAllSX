#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMPORT"      : Gosub IMPORT
Endcase
Return


$IMPORT
Case IMPFIC
 When "DAD"

  GBIDC1 = [F:DAD]LED
  If dim([M:DAD1]LED)>0 : [M:DAD1]LED = GBIDC1 : Endif
  GBIDC2 = [F:DAD]COD 
  If dim([M:DAD1]COD)>0 : [M:DAD1]COD = GBIDC2 : Endif

  ## Recherche du numéro de ligne en modif
  If GREP="M" & [F:DAD]LIN>=1 & [F:DAD]LIN<=[M]NBRDSP : # Modif ligne existante
   nolign = [F:DAD]LIN
  Else                                               : # Ajout d'une ligne
   [M]NBRDSP += 1
   nolign = [M]NBRDSP
  Endif
Endcase
Return
