#<AdxTL>@(#)2.0.0.0 $Revision$
# GA 07/09/2005 : ajout des manquants provenant des ordres de sous-traitance
# GA 14/03/2006 : MFGNUM,MFGLIN,BOMSEQ => VCRTYPORI=10, VCRNUMORI, VCRLINORI, VCRSEQORI
# --------------------------------------------------------------------------
$ACTION
Case ACTION
  When "OUVRE" :
    Case GACTION
      When "SAISHTSCO"   : Gosub OUVRE_SHTSCO
      When "SELSHTSCO"   : Gosub OUVRE_SELSCO
    Endcase
  When "DEBUT" :
    Case GACTION
      When "SAISHTSCO"   : Gosub DEBUT_SHTSCO
      When "SELSHTSCO"   : Gosub DEBUT_SELSCO
    Endcase
  When "AVANT_BOUTON" :
    Case GACTION
      When "SELSHTSCO"   :
          If GFONCTION="GESSDH"
             Gosub AVTBOUTON_SELSCO_SDH
          Endif
    Endcase
  When "BOUTON" :
    Case GACTION
      When "SELSHTSCO"   : Gosub BOUTON_SELSCO
    Endcase
  When "AVANT_OK" :
    Case GACTION
      When "SAISHTSCO"   :
          If GFONCTION="GESSDH"
             Gosub AVTOK_SHTSCO_SDH
          Endif
    Endcase
  When "OK" :
    Case GACTION
      When "SAISHTSCO"   :
          If GFONCTION="GESSDH"
             Gosub OK_SHTSCO_SDH
          Else
             Gosub OK_SHTSCO_SST
          Endif
    Endcase
  When "END" :
    Case GACTION
      When "SAISHTSCO"   : Gosub END_SHTSCO
    Endcase
  When "SETBOUT" :                                          # hcb 29578
       Case GACTION                                         # hcb 29578
             When "SAISHTSCO"   : Gosub  SETBOUT_SHTSCO     # hcb 29578
       Endcase                                              # hcb 29578
Endcase
Return
############################################################
# Issue  29578 HCB : ajout boutons tout inclure/tout exclure   deb
$SETBOUT_SHTSCO
If [M:SSCO]NBLIG=0
  ETABOU(GSPE1)=0 : ETABOU(GSPE2)=0 : # Désactivation Inclure / Exclure
Else
  ETABOU(GSPE1)=1 : ETABOU(GSPE2)=1 : # Activation    Inclure / Exclure
Endif
Return
Subprog EXCLURE
#------------------------------------#
# Raz de toutes les quantités prises #
#------------------------------------#
Local Integer I
For I = 0 To [M:SSCO]NBLIG-1
  Raz[M:SSCO]TRFQTY(I)
Next I
Affzo [M:SSCO] 15
End
Subprog INCLURE
#------------------------------------#
# Inclure toutes les lignes          #
#------------------------------------#
Gosub DEBUT_SHTSCO
End
# Issue  29578 HCB : ajout boutons tout inclure/tout exclure   fin

$OUVRE_SHTSCO
Global Char    WFCY(GLONFCY)  : WFCY = PARAM(1)               # hcb 29578
Global Char    WBPR(GLONBPR)  : WBPR = PARAM(2)               # hcb 29578
Global Char    WEMP(GLONLOC)  : WEMP = PARAM(3)               # hcb 29578
Local Decimal WSTO, WPCUDIS, WSTUDIS, WSTUACTDIS             # hcb 29578
Local Integer I, WRET
Local Char    WCRITSTA(90)
#
If GMODU(8) = 2 : # GA 07/09/2005: test MFGMAT ssi module GP
   If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
Endif
If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif
If clalev([F:BPR])  = 0 : Local File BPARTNER    [BPR]  : Endif
If clalev([F:BPS])  = 0 : Local File BPSUPPLIER  [BPS]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:STO])  = 0 : Local File STOCK       [STO]  : Endif
If clalev([F:STC])  = 0 : Local File STOLOC      [STC]  : Endif
If clalev([F:STA])  = 0 : Local File STOALL      [STA]  : Endif
If clalev([F:SCM])  = 0 : Local File SCOMAT      [SCM]  : Endif : # GA 07/09/2005
If clalev([F:STL1]) = 0 : Local File STOLOT      [STL1] : Endif
If clalev([F:STO1]) = 0 : Local File STOCK       [STO1] : Endif
If clalev([F:ITS])  = 0 : Local File ITMSALES    [ITS]  : Endif
#--- Dem 51992
If GMODU(5) = 2
   If clalev([F:SDD])  = 0 : Local File SDELIVERYD  [SDD]  : Endif
   If clalev([F:SDH])  = 0 : Local File SDELIVERY   [SDH]  : Endif
Endif
If clalev([F:AXX])  = 0 : Local File ATEXTRA     [AXX]  : Endif      # FGR 10/07/2014 : X3SUIVI96345
#---

#
Read [FCY]FCY0=WFCY
If fstat
  FIN = 1
  Goto OUVRE_SHTSCO_FIN
Endif
Read [BPR]BPR0= WBPR
If fstat
  FIN = 1
  Goto OUVRE_SHTSCO_FIN
Endif
Read [STC]STC0=WFCY;WEMP
If fstat
  FIN = 1
  Goto OUVRE_SHTSCO_FIN
Endif
If [F:STC]LOCCAT <> 4
  FIN = 1
  Goto OUVRE_SHTSCO_FIN
Endif
$OUVRE_SHTSCO_FIN
Return
############################################################
$DEBUT_SHTSCO
Local Decimal WDLVQTY
Local Decimal WSTO, WPCUDIS, WSTUDIS, WSTUACTDIS             # hcb 29578
Local Integer I, WRET                                        # hcb 29578
Local Char    WCRITSTA(90)                                   # hcb 29578

Raz [M:SSCO]
[M:SSCO]STOFCY    = [F:FCY]FCY
[M:SSCO]FCYSHO    = [F:FCY]FCYSHO
[M:SSCO]BPANUMDEN = [F:BPR]BPRNUM
[M:SSCO]BPRNAMDEN = [F:BPR]BPRNAM(0)
[M:SSCO]BPRLOCDEN = [F:STC]LOC

# GA 07/09/2005: cas des Ordres de sous-traitance
# Filtre de consultation des ruptures appel de CONSSMQ
#[M:SSCO]FILSMQ    = "VCRTYP=10 "
[M:SSCO]FILSMQ    = "(VCRTYP=10 | VCRTYP=36)"

#If GMODU(8) = 2      : # GA 07/09/2005: chargement MFGMAT ssi module GP
#  # Lecture MFGMAT
#  Filter [MFM] Where MFGFCY = WFCY &
#&                    SCOFLG = 2    &
#&                    LOC    = WEMP
#&              Order By Key MFM1
#  For [MFM]
#    #--- Dem 51992
#    If GFONCTION = "GESSDH"
#      Raz WDLVQTY
#      Filter [SDD] Where ITMREF    = [F:MFM]ITMREF &
#&                        VCRTYPORI = 10            &
#&                        VCRNUMORI = [F:MFM]MFGNUM &
#&                        VCRLINORI = [F:MFM]MFGLIN &
#&                        VCRSEQORI = [F:MFM]BOMSEQ
#      For [SDD]
#        Read [SDH]SDH0=[F:SDD]SDHNUM
#        If !fstat & [F:SDH]CFMFLG<2 & [F:SDH]SCO=2
#          WDLVQTY += [F:SDD]QTYSTU
#        Endif
#      Next
#      Filter [SDD]
#    Endif
#    #---
#
#    Filter [STA] Where ITMREF = [F:MFM]ITMREF &
#&                    VCRTYP = 10            &
#&                    VCRNUM = [F:MFM]MFGNUM &
#&                    VCRLIN = [F:MFM]MFGLIN &
#&                    VCRSEQ = [F:MFM]BOMSEQ &
#&                    ALLTYP = 4             &
#&                    STOFCY = [F:MFM]MFGFCY
#&              Order By Key STA2
#    For [STA]
#        If GFONCTION = "GESSDH"
#            Gosub LOA_LIGNE_SDH
#        Else
#            Gosub LOA_LIGNE_SST
#        Endif
#    Next
#    Filter [STA]
#  Next
#  Filter [MFM]
#  Raz [F:MFM]
#Endif
  # -----------------------------------
  # FGR 10/07/2014 : X3SUIVI96345 (début)
  If GMODU(8) = 2      : # GA 07/09/2005: chargement MFGMAT ssi module GP
    Link [MFM] With [F:STA]STA2~=[F:MFM]ITMREF;10;[F:MFM]MFGNUM;[F:MFM]MFGLIN;[F:MFM]BOMSEQ;4;[F:MFM]MFGFCY
&                As [LMFM]
&      Order By Key KEY1=[F:MFM]MFGFCY;[F:MFM]RETDAT;[F:STA]ITMREF;[F:STA]VCRTYP;[F:STA]VCRNUM;[F:STA]VCRLIN;[F:STA]VCRSEQ
    #
#--- Issue 102454
#    Filter [LMFM] Where [F:MFM]MFGFCY = WFCY &
#&                       [F:MFM]SCOFLG = 2    &
#&                       [F:MFM]LOC    = WEMP
    Filter [LMFM] Where [F:MFM]MFGFCY = WFCY &
&                       [F:MFM]SCOFLG = 2    &
&                       [F:MFM]LOC    = WEMP &
&                       [F:STA]SRGQTYSTU=0
#---
    For [LMFM]KEY1
      #--- Dem 51992
      If GFONCTION = "GESSDH"
        Raz WDLVQTY
        Filter [SDD] Where ITMREF    = [F:MFM]ITMREF &
&                          VCRTYPORI = 10            &
&                          VCRNUMORI = [F:MFM]MFGNUM &
&                          VCRLINORI = [F:MFM]MFGLIN &
&                          VCRSEQORI = [F:MFM]BOMSEQ
        For [SDD]
          Read [SDH]SDH0=[F:SDD]SDHNUM
          If !fstat & [F:SDH]CFMFLG<2 & [F:SDH]SDHCAT=2
            WDLVQTY += [F:SDD]QTYSTU
          Endif
        Next
        Filter [SDD]
      Endif
      #---
      If GFONCTION = "GESSDH"
        Gosub LOA_LIGNE_SDH
      Else
        Gosub LOA_LIGNE_SST
      Endif
      #---
      If  [M:SSCO]NBLIG >= dim([M:SSCO]ITMREF)-1 Then
        # Si le tableau est plein pas la peine de continuer
        Break
      Endif
    Next
    Filter [LMFM]
    Close File [LMFM]
    Raz [F:MFM]
  Endif
  # FGR 10/07/2014 : X3SUIVI96345 (fin)
  # -----------------------------------

## GA 07/09/2005
## --------------------------------------------
## recherche des matières manquantes SCO
## --------------------------------------------
## Lecture SCOMAT
#Filter [SCM] Where STOFCY = WFCY &
#&                  SCOFLG = 2    &
#&                  LOC    = WEMP
#&              Order By Key SCM1
#For [SCM]
#  #--- Dem 51992
#  If GFONCTION = "GESSDH"
#    Local Decimal WDLVQTY
#    Raz WDLVQTY
#
#    #--- Dem 63242
#    # Les ruptures sur ordres SST sont décrémentées dés la création
#    # des livraisons de SST --> pas de qté en cours de livraison
#    #Filter [SDD] Where ITMREF    = [F:MFM]ITMREF &
##&                      VCRTYPORI = 36            &
##&                      VCRNUMORI = [F:SCM]SCONUM &
##&                      VCRLINORI = [F:SCM]SCILIN &
##&                      VCRSEQORI = [F:SCM]SCMLIN
#    #For [SDD]
#    #  Read [SDH]SDH0=[F:SDD]SDHNUM
#    #  If !fstat & [F:SDH]CFMFLG<2 & [F:SDH]SDHCAT=2
#    #    WDLVQTY += [F:SDD]QTYSTU
#    #  Endif
#    #Next
#    #Filter [SDD]
#    #--- Dem 63242 end
#
#  Endif
#  #---
#  Filter [STA] Where ITMREF = [F:SCM]CPNITMREF &
#&                    VCRTYP = 36            &
#&                    VCRNUM = [F:SCM]SCONUM &
#&                    VCRLIN = [F:SCM]SCILIN &
#&                    VCRSEQ = [F:SCM]SCMLIN &
#&                    ALLTYP = 4             &
#&                    STOFCY = [F:SCM]STOFCY
#&              Order By Key STA2
#  For [STA]
#        If GFONCTION = "GESSDH"
#            Gosub LOA_LIGNE_SDH
#        Else
#            Gosub LOA_LIGNE_SST
#        Endif
#  Next
#  Filter [STA]
#Next
#Filter [SCM]
#Raz [F:SCM]
## FIN - GA 07/09/2005
  # -----------------------------------
  # FGR 10/07/2014 : X3SUIVI96345 (début)
  If  [M:SSCO]NBLIG < dim([M:SSCO]ITMREF)-1 Then
    # Si le tableau est déjà plein, c'est pas la peine de venir ici
    Link [SCM] With [F:STA]STA2~=[F:SCM]CPNITMREF;36;[F:SCM]SCONUM;[F:SCM]SCILIN;[F:SCM]SCMLIN;4;[F:SCM]STOFCY
&                As [LSCM]
&      Order By Key KEY1=[F:SCM]STOFCY;[F:SCM]DLVDAT;[F:STA]ITMREF;[F:STA]VCRTYP;[F:STA]VCRNUM;[F:STA]VCRLIN;[F:STA]VCRSEQ
    #
#--- Issue 102454
#    Filter [LSCM] Where [F:SCM]STOFCY = WFCY &
#&                       [F:SCM]SCOFLG = 2    &
#&                       [F:SCM]LOC    = WEMP
    Filter [LSCM] Where [F:SCM]STOFCY = WFCY &
&                       [F:SCM]SCOFLG = 2    &
&                       [F:SCM]LOC    = WEMP &
&                       [F:STA]SRGQTYSTU=0
#---
    For [LSCM]KEY1
      #--- Dem 51992
      If GFONCTION = "GESSDH"
        Raz WDLVQTY
      Endif
      #---
      If GFONCTION = "GESSDH"
        Gosub LOA_LIGNE_SDH
      Else
        Gosub LOA_LIGNE_SST
      Endif
      #---
      If [M:SSCO]NBLIG >= dim([M:SSCO]ITMREF)-1 Then
        # Si le tableau est plein pas la peine de continuer
        Break
      Endif
    Next
    Filter [LSCM]
    Close File [LSCM]
    Raz [F:SCM]
  Endif
  # FGR 10/07/2014 : X3SUIVI96345 (fin)
  # -----------------------------------

# Contrôle avec stock physique
For I = 0 To [M:SSCO]NBLIG-1
  Read [ITM]ITM0=[M:SSCO]ITMREF(I)
  If !fstat
    # Lecture de la règle de gestion à utiliser
    If GFONCTION = "GESSDH"
      Call LECSRU([M:SDH0]STOFCY,[F:ITM]TCLCOD,[M:SDH0]TRSTYP,[M:SDH0]TRSCOD,"",WRET)
&                 From STKLIB
    Else
      Call LECSRU([M:SCS1]STOFCY,[F:ITM]TCLCOD,27,[M:SCS1]TRSCOD,"",WRET)
&                 From STKLIB
    Endif
    If WRET=0
      Raz WCRITSTA
      # Prise en compte des sous-statuts autorisés
      Call CREE_FORMULE([F:SRU]FORSTA,"[F:STO]STA",WCRITSTA) From TRTCATEG

      WSTO = 0
      Filter [STO] Where ITMREF = [M:SSCO]ITMREF(I) &
&                        STOFCY = WFCY              &
&                        LOCCAT<=2                  &
&                        evalue(WCRITSTA)           &
&                        QTYSTU > 0
&                  Order By Key STO3
      For [STO]
        Call STODIS("","","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
        If WSTUDIS > 0
          WSTO += WSTUDIS
        Endif
      Next
      Filter [STO]
      [M:SSCO]AVASTO(I) = WSTO

      #--- Dem 63242
      #If WSTO > [M:SSCO]SHTQTY(I)
      #  [M:SSCO]TRFQTY(I) = [M:SSCO]SHTQTY(I)
      #  [M:SSCO]AVAFLG(I) = 2
      #Else
      #  [M:SSCO]TRFQTY(I) = WSTO
      #  [M:SSCO]AVAFLG(I) = 1
      #Endif
      If [M:SSCO]SHTQTY(I)-[M:SSCO]DLVQTY(I)<=0
         [M:SSCO]TRFQTY(I) = 0
         [M:SSCO]AVAFLG(I) = 1
      #--- Bug 82952
      #Elsif WSTO > [M:SSCO]SHTQTY(I)-[M:SSCO]DLVQTY(I)
      Elsif WSTO >= [M:SSCO]SHTQTY(I)-[M:SSCO]DLVQTY(I)
      #---
        [M:SSCO]TRFQTY(I) = [M:SSCO]SHTQTY(I)-[M:SSCO]DLVQTY(I)
        [M:SSCO]AVAFLG(I) = 2
      Else
        [M:SSCO]TRFQTY(I) = WSTO
        [M:SSCO]AVAFLG(I) = 1
      Endif
      #--- Dem 63242 end

    Else
      # Pas de règle de gestion
      [M:SSCO]TRFQTY(I) = 0
      [M:SSCO]AVAFLG(I) = 1
    Endif
  Else
    # Problème lecture article
    [M:SSCO]TRFQTY(I) = 0
    [M:SSCO]AVAFLG(I) = 1
  Endif
  [M:SSCO]TRFQTYW(I) =   [M:SSCO]TRFQTY(I)      # hcb 29578
Next I
Affzo [M:SSCO]
Return

############################################################
$LOA_LIGNE_SST
If [F:ITM]ITMREF <> [F:STA]ITMREF
    Read [ITM]ITM0=[F:STA]ITMREF
    If fstat Return Endif
Endif
If [M:SSCO]NBLIG < dim([M:SSCO]ITMREF)-1
   [M:SSCO]ITMREF     ([M:SSCO]NBLIG) = [F:ITM]ITMREF
   #[M:SSCO]ITMDES1    ([M:SSCO]NBLIG) = [F:ITM]ITMDES1
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SSCO]ITMDES1([M:SSCO]NBLIG), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
   [M:SSCO]STU        ([M:SSCO]NBLIG) = [F:ITM]STU
   [M:SSCO]SHTQTY     ([M:SSCO]NBLIG) = [F:STA]QTYSTUACT
 # GA 14/03/2006
   [M:SSCO]VCRTYPORI  ([M:SSCO]NBLIG) = [F:STA]VCRTYP
   [M:SSCO]VCRNUMORI  ([M:SSCO]NBLIG) = [F:STA]VCRNUM
   [M:SSCO]VCRLINORI  ([M:SSCO]NBLIG) = [F:STA]VCRLIN
   [M:SSCO]VCRSEQORI  ([M:SSCO]NBLIG) = [F:STA]VCRSEQ
   [M:SSCO]NBLIG += 1
Endif
Return
############################################################
$LOA_LIGNE_SDH
If [F:ITM]ITMREF <> [F:STA]ITMREF
    Read [ITM]ITM0=[F:STA]ITMREF
    If fstat Return Endif
Endif
If  [M:SSCO]NBLIG < dim([M:SSCO]ITMREF)-1
    [M:SSCO]ITMREF    ([M:SSCO]NBLIG) = [F:ITM]ITMREF
    #[M:SSCO]ITMDES1   ([M:SSCO]NBLIG) = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SSCO]ITMDES1([M:SSCO]NBLIG), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    [M:SSCO]STU       ([M:SSCO]NBLIG) = [F:ITM]STU
    [M:SSCO]SHTQTY    ([M:SSCO]NBLIG) = [F:STA]QTYSTUACT
    If GMODU(8) = 2 & [F:MFM]MFGNUM<>""         : # GA 07/09/2005: chargement MFGMAT ssi module GP
      [M:SSCO]VCRNUMORI    ([M:SSCO]NBLIG) = [F:MFM]MFGNUM
      [M:SSCO]VCRLINORI    ([M:SSCO]NBLIG) = [F:MFM]MFGLIN
      [M:SSCO]VCRSEQORI    ([M:SSCO]NBLIG) = [F:MFM]BOMSEQ
      [M:SSCO]VCRTYPORI    ([M:SSCO]NBLIG) = 10
    Elsif [F:SCM]SCONUM <> ""
      [M:SSCO]VCRNUMORI    ([M:SSCO]NBLIG) = [F:SCM]SCONUM
      [M:SSCO]VCRLINORI    ([M:SSCO]NBLIG) = [F:SCM]SCILIN
      [M:SSCO]VCRSEQORI    ([M:SSCO]NBLIG) = [F:SCM]SCMLIN
      [M:SSCO]VCRTYPORI    ([M:SSCO]NBLIG) = 36
    Endif
    #--- Dem 51992
    [M:SSCO]DLVQTY    ([M:SSCO]NBLIG) = max(0,min(WDLVQTY,[F:STA]QTYSTUACT))
    WDLVQTY -= [M:SSCO]DLVQTY([M:SSCO]NBLIG)
    #---
  # FIN - GA 07/09/2005
    [M:SSCO]NBLIG += 1
Endif
Return
############################################################
$AVTOK_SHTSCO_SDH
Local Integer WOK
Default Mask [SDH0]
Default Mask [SDH1]
Default Mask [SDH2]
Default Mask [SDH3]
For I = 0 To [M:SSCO]NBLIG-1
  If [M:SSCO]TRFQTY(I) > 0
      WOK=2
      If [F:ITM]ITMREF <> [M:SSCO]ITMREF(I)
          Read [ITM]ITM0=[M:SSCO]ITMREF(I)
          If fstat = 0 Gosub VRF_SEL_SDH From TRTVENLIV Endif
      Else
          Gosub VRF_SEL_SDH From TRTVENLIV
      Endif
      If WOK=1 [M:SSCO]TRFQTY(I)=0 : Endif
  Endif
Next I

Return
############################################################
$OK_SHTSCO_SDH

If sum([M:SSCO]TRFQTY) = 0 FIN=1 Endif

For I = 0 To [M:SSCO]NBLIG-1
  If [M:SSCO]TRFQTY(I) > 0
      If [F:ITM]ITMREF <> [M:SSCO]ITMREF(I)
          Read [ITM]ITM0=[M:SSCO]ITMREF(I)
          If fstat = 0 Gosub LOA_SEL_SDH From TRTVENLIV Endif
      Else
          Gosub LOA_SEL_SDH From TRTVENLIV
      Endif
  Endif
Next I
Affzo [M:SDH1]20
Affzo [M:SDH2]20
mkstat=4
FIN = 1
Return

############################################################
$OK_SHTSCO_SST

Call AM_ITMREFSEL([M:SSCO]ITMREF(nolign-1)) From SUBSCS

[M:SCS1]ITMREFSEL = [M:SSCO]ITMREF(nolign-1)
Affzo [M:SCS1]ITMREFSEL
mkstat=4
FIN = 1
Return

############################################################
$END_SHTSCO

Return

############################################################
# Action SELSHTSCO Selection sous traitants avec manquants
############################################################
$OUVRE_SELSCO
  If GMODU(8) = 2             : # GA 07/09/2005: test uniquement sur MFGOPE + ne pas planter sinon
   # ouverture tables si nécessaire
     Gosub OPEN_FILES_MFG From MFGLIB
  Endif
  Local Char    WFCY(GLONFCY): WFCY = PARAM(1)
  If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif
  If clalev([F:BPR])  = 0 : Local File BPARTNER    [BPR]  : Endif
  If clalev([F:BPS])  = 0 : Local File BPSUPPLIER  [BPS]  : Endif
  If clalev([F:STA])  = 0 : Local File STOALL      [STA]  : Endif
  Gosub OPEN_FILES_SCO From SCOLIB
#
  Read [FCY]FCY0=WFCY
  If fstat
    FIN = 1
  Endif
Return
############################################################
$DEBUT_SELSCO

Raz [M:SSHT]
[M:SSHT]STOFCY = [F:FCY]FCY
[M:SSHT]FCYNAM = [F:FCY]FCYNAM
#
# -----------------------------
# Allocations provenant des OF
# -----------------------------
Local Char WSTOFCY (GLONFCY)
Local Char WRCPFCY (GLONFCY)
Local Char WLOC    (GLONREF)

# FQ 59732 GA 11/2009 tri par no ordre STA0 => STA1
Filter [STA] Where STOFCY = WFCY &
&                  VCRTYP = 10   &
&                  ALLTYP = 4
&            Order By Key STA1
For [STA]

      Filter [MFO] Where MFGNUM  = [F:STA]VCRNUM &
&                        SCOCOD >= 2             &
&                        BPRNUM <> ""
&                  Order By Key MFO0
      For [MFO]
      # Est-ce qu'il s'agit d'une sous-traitance ?
        If !find([F:MFO]BPRNUM,[M:SSHT]BPSNUM(0..[M:SSHT]NBLIG-1))
          Read [BPS]BPS0=[F:MFO]BPRNUM
          If fstat = 0
            If [M:SSHT]NBLIG < dim([M:SSHT]BPSNUM)
               [M:SSHT]BPSNUM([M:SSHT]NBLIG)  = [F:BPS]BPSNUM
               [M:SSHT]BPSNAM([M:SSHT]NBLIG)  = [F:BPS]BPSNAM(0)
               [M:SSHT]BPAADD([M:SSHT]NBLIG)  = [F:MFO]BPAADD
               Call FIND_SCOLOC ( [F:MFO]BPRNUM, [F:MFO]BPAADD, WLOC,WRCPFCY,WSTOFCY ) From BPRLIB
               [M:SSHT]LOC   ([M:SSHT]NBLIG)  = WLOC
               [M:SSHT]NBLIG += 1
            Else
               Break 2
            Endif
          Endif
        Endif
      Next
      Filter [MFO]
Next
Filter [STA]
#
# GA 07/09/2005
# -----------------------------
# Allocations provenant des SCO
# -----------------------------
# FQ 59732 GA 11/2009 tri par no ordre (mono-fournisseur) + ne pas proposer plusieurs fois le même STA0 => STA1
Local Integer WSCILIN : WSCILIN=1000
Filter [STA] Where STOFCY = WFCY &
&                  VCRTYP = 36   &
&                  ALLTYP = 4
&            Order By Key STA1
For [STA]
  # FQ 58276 & 58238 Read [SCI]SCI0=[F:STA]VCRNUM
  Read [SCO]SCO0=[F:STA]VCRNUM
  If !fstat & !find([F:SCO]BPRNUM,[M:SSHT]BPSNUM(0..[M:SSHT]NBLIG-1)) # FQ 59732 GA 11/2009
    # Recherche adresse+emplacement de sous-traitance [F:SCI]BPAADD,LOC
      Read [SCI]SCI0=[F:SCO]SCONUM;WSCILIN
      If fstat : Raz [F:SCI] : Endif
    # Recherche du fournisseur concerné sur l'entête de SCO
      Read [BPS]BPS0=[F:SCO]BPRNUM
      If fstat = 0
        If [M:SSHT]NBLIG < dim([M:SSHT]BPSNUM)
           [M:SSHT]BPSNUM([M:SSHT]NBLIG)  = [F:BPS]BPSNUM
           [M:SSHT]BPSNAM([M:SSHT]NBLIG)  = [F:BPS]BPSNAM(0)
           [M:SSHT]BPAADD([M:SSHT]NBLIG)  = [F:SCI]BPAADD
           [M:SSHT]LOC   ([M:SSHT]NBLIG)  = [F:SCI]LOC
           [M:SSHT]NBLIG += 1
        Else
           Break 3
        Endif
      Endif
  Endif
Next
Filter [STA]
#
Affzo [M:SSHT]
Return
############################################################
$AVTBOUTON_SELSCO_SDH
Case BOUT
  When "a" :
    If nolign > 0
      Read [BPR]BPR0=[M:SSHT]BPSNUM(nolign-1)
      If fstat | [F:BPR]BPCFLG <> 2 GERR=1 : GMESSAGE=mess(236,192,1) : Endif
    Endif
Endcase
Return
############################################################
$BOUTON_SELSCO
Case BOUT
  When "a" :
    If nolign > 0
      Read [BPS]BPS0=[M:SSHT]BPSNUM(nolign-1)
      If fstat = 0
        PARAM(2) = [M:SSHT]BPSNUM(nolign-1)
      Endif
    Endif
    FIN = 1
Endcase
Return
############################################################
# Actions écran
############################################################
Subprog C_TRFQTY(VALEUR)
Variable Decimal VALEUR
If GFONC1="GESSST" & VALEUR > [M:SSCO]AVASTO(nolign-1)
  mkstat = 2
Endif
End
############################################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
If [M:SSCO]TRFQTYW(nolign-1) < [M:SSCO]SHTQTY(nolign-1)    # hcb  29578
  pcolor = GCOUL(1)
Else
  pcolor = GCOUL(0)
Endif
End
