#<AdxTL>@(#)8.0.0.0 $Revision$
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = nomap
Call CPTMAJ14
Call TRSMAJ14
Call IMMMAJ14
End

####################################################
## Subprog ACPTMAJ14
## Subprog CPTMAJ14
## Subprog AIMMMAJ14
## Subprog IMMMAJ14
## Subprog ATRSMAJ14
## Subprog TRSMAJ14

####################################################
## Module compta
####################################################

####################################################
Subprog ACPTMAJ14

# Reprise du paramétrage des tableaux de bord 130

# Delete de la table GACTXSCTL
Call DELTAB("GACTXSCTL")

# Création des tables
Call MAJTAB("TXSA")
Call MAJTAB("TXSD")

# Mise à jour
Local File =[F:ADS]DOSSIER+".GACTXSARR"  [TXA]
Local File =[F:ADS]DOSSIER+".GACTXSARRD" [TAD]
Local File =[F:ADS]DOSSIER+".GACTXSDES"  [TDS]
Local File =[F:ADS]DOSSIER+".GACTXSFIE"  [TXF]
Local File =[F:ADS]DOSSIER+".GRUCPYE"    [GPY]
Local File =[F:ADS]DOSSIER+".TXSA"       [TXS]
Local File =[F:ADS]DOSSIER+".TXSD"       [TXD]

Local Integer I, J
Local Char CUMUL(20)(20), NOMGRP(50), EXPR(30), CHAINE(20), CAR(1), CARP(1), CARS(1)
Local Char ZONE(250)

Call ECR_TRACE(mess(81,125,1)-": TXSA, TXSD",0) From GESECRAN : # maj table

Filter [TXA] Where PAGE=len(mess(0,667,1))   :# autres tableaux
Trbegin [TXA], [TXD]
GOK = 1
For [TXA]TXA1(1)   # groupe de sociétés
 Raz NOMGRP
 Read [GPY]CYE0 = [F:TXA]GRUCPY
 If !fstat
  NOMGRP = [F:GPY]GRUCPYNAM
 Endif

 For [TXA]TXA1    :# tableau
  Raz CUMUL, [F:TXS]
  [F:TXS]LSTGRP = [F:TXA]GRUCPY
  [F:TXS]GRPDES = NOMGRP
  [F:TXS]TXSNAM = [F:TXA]TXSARRCOD
  [F:TXS]TXSDES = [F:TXA]DES
  [F:TXS]NBRCOL = [F:TXA]NBRCOL
  [F:TXS]NBLIG  = [F:TXA]NBLIG
  [F:TXS]DETACC = 1
  [F:TXS]DETBPR = 1
  [F:TXS]DETCCE = 1
  [F:TXS]DETIMM = 1
  [F:TXS]NEGSTO = 1
  [F:TXS]ACS    = [F:TXA]ACS
  For I=0 To [F:TXA]NBRCOL-1
   [F:TXS]NAMCOL(I) = [F:TXA]NAMCOL(I)
   [F:TXS]DIVCOL(I) = 1
   [F:TXS]DECCOL(I) = 0
   Case [F:TXA]FMTPRN(I)
    When 1 : [F:TXS]FMTCOL(I) = 1 : [F:TXS]EFFCOL(I) = 1
    When 2 : [F:TXS]FMTCOL(I) = 2 : [F:TXS]EFFCOL(I) = 1
    When 3 : [F:TXS]FMTCOL(I) = 3 : [F:TXS]EFFCOL(I) = 1
    When 4 : [F:TXS]FMTCOL(I) = 1 : [F:TXS]EFFCOL(I) = 3
    When 5 : [F:TXS]FMTCOL(I) = 2 : [F:TXS]EFFCOL(I) = 3
    When 6 : [F:TXS]FMTCOL(I) = 3 : [F:TXS]EFFCOL(I) = 3
   Endcase
   If [F:TXA]SNSCUMLIG(I)<>""
    If CUMUL([F:TXA]COLNUM-1)="" & [F:TXA]SNSCUMLIG(I)="+"
     CUMUL([F:TXA]COLNUM-1)+=num$(I+1)
    Else
     CUMUL([F:TXA]COLNUM-1)+=[F:TXA]SNSCUMLIG(I)+num$(I+1)
    Endif
   Endif
  Next I
  For I=0 To [F:TXA]NBRCOL-1
   If CUMUL(I)<>""
    [F:TXS]COLNUM(I) = CUMUL(I)
   Endif
  Next I
  [F:TXS]CREUSR = GUSER
  [F:TXS]CREDAT = datesyst
  Write [TXS]
  If fstat
   Call ERREUR("TXSA"-[F:TXS]LSTGRP-[F:TXS]TXSNAM,1) From DOSDIC
  Endif

  # Intitulé des lignes
  For [TDS]TDS0 Where GRUCPY=[F:TXA]GRUCPY & YEAPAR=[F:TXA]YEAPAR & TXSARRCOD=[F:TXA]TXSARRCOD
   Raz [F:TXD]
   [F:TXD]TXSNAM = [F:TXA]TXSARRCOD
   [F:TXD]LIG = [F:TDS]LIG
   [F:TXD]COL = 0
   [F:TXD]FRM = vireblc(ctrans([F:TDS]DES,"#",""),0)
   Case [F:TDS]FMTPRN
    When 1 : [F:TXD]FMTPRN = 1 : [F:TXD]EFFPRN = 1
    When 2 : [F:TXD]FMTPRN = 2 : [F:TXD]EFFPRN = 1
    When 3 : [F:TXD]FMTPRN = 3 : [F:TXD]EFFPRN = 1
    When 4 : [F:TXD]FMTPRN = 1 : [F:TXD]EFFPRN = 3
    When 5 : [F:TXD]FMTPRN = 2 : [F:TXD]EFFPRN = 3
    When 6 : [F:TXD]FMTPRN = 3 : [F:TXD]EFFPRN = 3
   Endcase
   Write [TXD]
   If fstat
    Call ERREUR("TXSD"-[F:TXD]TXSNAM,1) From DOSDIC
    Break 3
   Endif
  Next

  # Formules
  Filter [TAD] Where GRUCPY=[F:TXA]GRUCPY & YEAPAR=[F:TXA]YEAPAR & TXSARRCOD=[F:TXA]TXSARRCOD
&                  & TXSCOD<>""
  For [TAD]TAD0
   Read [TXF]TXF0 = [F:TAD]GRUCPY;[F:TAD]YEAPAR;[F:TAD]TXSCOD
   If !fstat
    Raz [F:TXD]
    [F:TXD]TXSNAM = [F:TAD]TXSARRCOD
    [F:TXD]LIG = [F:TAD]LIG
    [F:TXD]COL = [F:TAD]COLNUM
    ZONE = [F:TXF]FORLIG
    Gosub TRT_FORMULE
    [F:TXD]FRM = ZONE
    Case [F:TAD]FMTPRN
     When 1 : [F:TXD]FMTPRN = 1 : [F:TXD]EFFPRN = 1
     When 2 : [F:TXD]FMTPRN = 2 : [F:TXD]EFFPRN = 1
     When 3 : [F:TXD]FMTPRN = 3 : [F:TXD]EFFPRN = 1
     When 4 : [F:TXD]FMTPRN = 1 : [F:TXD]EFFPRN = 3
     When 5 : [F:TXD]FMTPRN = 2 : [F:TXD]EFFPRN = 3
     When 6 : [F:TXD]FMTPRN = 3 : [F:TXD]EFFPRN = 3
    Endcase
    Write [TXD]
    If fstat
     Call ERREUR("TXSD"-[F:TXD]TXSNAM,1) From DOSDIC
     Break 3
    Endif
   Endif
  Next
  Filter [TAD]

  # Formules issues des cumuls entre colonnes
  For I=1 To [F:TXS]NBRCOL-1
   CHAINE = CUMUL(I)
   If CHAINE<>""
    Gosub SET_FRM
    Update [TXD] Where TXSNAM=[F:TXS]TXSNAM & COL=I+1 With FRM=EXPR
    If fstat
     Call ERREUR("TXSD"-[F:TXS]TXSNAM,2) From DOSDIC
     Break 3
    Endif
   Endif
  Next I

 Next   :# tableau
Next
If GOK<1 : Rollback
Else     : Commit
Endif
Filter [TXA]

Close Local File [TXA], [TAD], [TDS], [TXF], [GPY], [TXS], [TXD]


##################################################
## Copie nouvelles pièces auto
##################################################
## Copie des pièces auto CCA et PCA (Charges et produits constatée d'avance)
## Copie des pièces auto de règlements : PRINC, PYODT, PYODH, PYODD, BKACC, ACCBQ, STEPN, PYDVN
## Copie des pièces auto UNPAI et UNPAY

Local File =[F:ADS]DOSREF+".GAUTACE"    [GAU0]
Local File =[F:ADS]DOSREF+".GAUTACE"    [GAU1]
Local File =[F:ADS]DOSREF+".GAUTACED"   [GAD1] 
Local File =[F:ADS]DOSREF+".GAUTACEF"   [GAG1]
Local File =[F:ADS]DOSREF+".GVARPARVAL" [GVV1]

Local File =[F:ADS]DOSSIER+".GAUTACE"    [GAU2]
Local File =[F:ADS]DOSSIER+".GAUTACED"   [GAD2] 
Local File =[F:ADS]DOSSIER+".GAUTACEF"   [GAG2]
Local File =[F:ADS]DOSSIER+".GVARPARVAL" [GVV2]
Local Char TABLE(10)
For [GAU0]GAU0
 If [F:ADS]MODULE([F:GAU0]MODULE-1)=2
  Read [GAU2]GAU0 = [F:GAU0]COD
  ## On recopie : 
  ##  - toutes les nouvelles pièces auto
  ##  - toutes les pièces auto qui concernent les modules stocks et GPAO (demande 24578)
  ##  - toutes les pièces qui concerne la comptabilisation de règlements (on les énumère car certaines avaient le même nom en V130) 
  If fstat | find([F:GAU0]MODULE,7,8) | find([F:GAU0]COD,'CCA','PCA','PRINC','PYODT','PYODH','PYODD','BKACC','ACCBQ','STEPN','PYDVN','UNPAY','UNPAI')
   TABLE = [F:GAU0]COD
   Gosub TR_COP From SUBGAU
  Endif
 Endif
Next
Close Local File [GAU0] , [GAU1] , [GAD1] , [GAG1] , [GVV1] , [GAU2] , [GAD2] , [GAG2] , [GVV2]
End

End   :# ACPTMAJ14


$TRT_FORMULE
I=0
Repeat
 I = instr(I+1,ZONE,"-")
 If I
  CARP = mid$(ZONE,I-1,1) : CARS = mid$(ZONE,I+1,1)
  If CARP>="0" & CARP<="9" & CARS>="0" & CARS<="9"
   ZONE = left$(ZONE,I-1) + ".." + right$(ZONE,I+1)
  Endif
 Endif
Until !I
Return

$SET_FRM
Raz EXPR
For J=1 To len(CHAINE)
 CAR = mid$(CHAINE,J,1) : CARP = mid$(CHAINE,J-1,1) : CARS = mid$(CHAINE,J+1,1)
 If CAR>="0" & CAR<="9"
  If CARP<"0" | CARP>"9"
   EXPR += "L("+CAR
  Else
   EXPR += CAR
  Endif
  If (CARS<"0" | CARS>"9")
   EXPR += ")"
  Endif
 Else
  EXPR += CAR
 Endif
Next J
If EXPR<>"" : EXPR = "R(" + EXPR + ")" : Endif
Return

####################################################
Subprog MAJTAB(TABLE)
Local File =[F:ADS]DOSSIER+".ATABLE"  [ATB]
Local File =[F:ADS]DOSSIER+".ATABZON" [ATZ]
Local File =[F:ADS]DOSSIER+".ATABIND" [ATI]
Local File =[F:ADS]DOSSIER+".ATEXTE"  [ATX]
Local File =[F:ADS]DOSSIER+".ATYPE"   [ATY]
Local File =[F:ADS]DOSSIER+".ACTIV"   [ACV]
Local File =[F:ADS]DOSSIER+".AINDEX"  [ANX]
If dim(GCOEFTAB)<0
 Global Decimal GCOEFTAB
 GCOEFTAB = 0.5
Endif
Call MAJTAB(TABLE,0) From DOSTAB
End

####################################################
Subprog DELTAB(TABLE)
Local File =[F:ADS]DOSSIER+".ATABLE"  [ATB]
Local File =[F:ADS]DOSSIER+".ATABZON" [ATZ]
Local File =[F:ADS]DOSSIER+".ATABIND" [ATI]
Local Integer STAT
Local Char    SUF(3) , FICTRT(GDIMFIC)
Delete [ATB] Where CODFIC=TABLE
If fstat : Call ERREUR("ATB"-TABLE,3) From DOSDIC : Endif
Delete [ATZ] Where CODFIC=TABLE
If fstat : Call ERREUR("ATZ"-TABLE,3) From DOSDIC : Endif
Delete [ATI] Where CODFIC=TABLE
If fstat : Call ERREUR("ATI"-TABLE,3) From DOSDIC : Endif
Call SYSTEME(adxmac(0),"valfil -n"-[F:ADS]DOSSIER-TABLE,"",STAT) From ORDSYS
Call SYSTEME(adxmac(0),"valfil -d"-[F:ADS]DOSSIER-TABLE,"",STAT) From ORDSYS
For SUF = "srf", "fde", "dat", "idx"
 FICTRT = filpath("TRT",TABLE,SUF,[F:ADS]DOSSIER)
 If filinfo(FICTRT,0)>=0
  Call EFFACE(FICTRT,STAT) From ORDSYS
 Endif
Next SUF
End

####################################################
Subprog CPTMAJ14
Local File =[F:ADS]DOSSIER+".GACCENTRYD"   [DAE]
Call ECR_TRACE(mess(81,125,1)-": GACCENTRYD",0) From GESECRAN : # maj table
GOK = 1
Trbegin [DAE]
 For [DAE]DAE0 Where MTC = "ZZZZZ"
  [F:DAE]FLGMTC = 1 
  Rewrite [DAE]
  If fstat
   Call ERREUR("GACCENTRYD"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIG),2) From DOSDIC
  Endif
 Next
Commit
Close Local File [DAE]

# Mise à jour de la Balance / Grand livre consolidé

Local File =[F:ADS]DOSSIER+".ACTIV" [XACV]
Read [XACV]CODACT = "CSL"
If !fstat & [F:XACV]FLACT=2

    Call ECR_TRACE(mess(81,125,1)-": BALCONSO",0) From GESECRAN : # maj table
    Call ECR_TRACE(mess(81,125,1)-": GLCONSO",0) From GESECRAN : # maj table
    Local File =[F:ADS]DOSSIER+".BALCONSO" [BLC]
    Local File =[F:ADS]DOSSIER+".GLCONSO"  [GLC]
    Trbegin [BLC], [GLC]

    Update [BLC] Where FLG=0 With FLG=1
    If fstat
       Call ERREUR("BALCONSO",2) From DOSDIC
    Endif
    Update [GLC] Where FLG=0 With FLG=1
    If fstat
       Call ERREUR("GLCONSO",2) From DOSDIC
    Endif
    Commit
    Close Local File [BLC], [GLC]
Endif

# Mise à jour sections par défaut : si une section est associée au choix 20 (Aucune en V130), alors on la
# passe à 21 (le choix 'Aucune' étant passé en position 21)
Local File =[F:ADS]DOSSIER+".CACCEDEF"   [CDE]
Call ECR_TIME(mess(81,125,1)-": CACCEDEF") From DOSSUB : : # maj table
Local Integer AXE, MODIF

GOK = 1
Trbegin [CDE]
 For [CDE]CDE0
  MODIF = 0
  For AXE=1 To 9
   If evalue("[F:CDE]CCE"+num$(AXE)) = 20
    MODIF = 1
    Assign "[F:CDE]CCE"+num$(AXE) With 21
   Endif
  Next
  If MODIF
   Rewrite [CDE]
   If fstat
    Call ERREUR("CACCEDEF"-[F:CDE]COD,2) From DOSDIC
   Endif
  Endif
 Next
Commit
Close Local File [CDE]

End


####################################################
## Module immos
####################################################

####################################################
Subprog AIMMMAJ14
End

####################################################
Subprog IMMMAJ14
End


####################################################


####################################################
## Module tiers
####################################################

####################################################
Subprog ATRSMAJ14

##########################################################################################################
## Destinations comptables : initialisation du nouveau champ ACCVCRFLG (flag pièce séparée) : ce champ
## doit être initialisé à 'Oui' dès lors que la destination comptable était associée à une pièce séparée
## en version 130 (champ ACCVRC en 130)
## NB : Dans les AXXMAJ, on a les anciens + les nouveaux champs dans les tables... 
##########################################################################################################
Local File =[F:ADS]DOSSIER+".GACCDENCOD"    [CDA]

Call ECR_TRACE(mess(81,125,1)-": GACCDENCOD",0) From GESECRAN : # maj table
Trbegin [CDA]
 For [CDA]CDA0
  If [F:CDA]ACCVCR<>""
   [F:CDA]ACCVCRFLG = 2
  Else
   [F:CDA]ACCVCRFLG = 1
  Endif
  Rewrite [CDA]
  If fstat
   Call ERREUR("GACCDENCOD"-[F:CDA]COD,1) From DOSDIC
  Endif
 Next
Commit
Close Local File [CDA]


##########################################################################################################
## Transactions règlement : initialisation des champs : 
## 1°) AUTACE3, AUTACE8, AUTACE9 (on avait des codes pièces auto, on a en 140 des groupes de pièces auto)
## 2°) JOU3, JOU8, JOU9 (le type de journal est défini au niveau de la transaction et pour chaque étape
##     de comptabilisation alors qu'en 130 il était défini sur les pièces auto de règlements)
## 3°) ACETYP91 et ACETYP92 (regroup si escompte, regroup si encaissement). En 130, on avait qu'un seul
##     champ ACETYP9 (même regroupement quel que soit le type de remise). On initialise les nouveaux
##     champs ACETYP91 et ACETYP92 par ACETYP9
##########################################################################################################
Local File =[F:ADS]DOSSIER+".TABPAYTYP"    [TPY]

Call ECR_TRACE(mess(81,125,1)-": TABPAYTYP",0) From GESECRAN : # maj table
Trbegin [TPY]
 For [TPY]TPY0
  If [F:TPY]STA3 = 2
   [F:TPY]AUTACE3 = "STEP1"
   If [F:TPY]SNS = 2
    [F:TPY]JOU3 = 3
   Elsif [F:TPY]SNS = 1
    [F:TPY]JOU3 = 4
   Else
    Call ERREUR("TABPAYTYP"-[F:TPY]PAYTYP-":"-"Type de journal à renseigner",1) From DOSDIC
   Endif
   If [F:TPY]STA8 = 2
    [F:TPY]AUTACE8 = "STEPN"
    [F:TPY]JOU8  = 2
    [F:TPY]JOU82 = 2
   Endif
   If [F:TPY]STA9 = 2
    [F:TPY]AUTACE9 = "STEPN"
    [F:TPY]ACETYP91 = [F:TPY]ACETYP9
    [F:TPY]ACETYP92 = [F:TPY]ACETYP9
    [F:TPY]JOU9 = 1
   Else
    Call ERREUR("TABPAYTYP"-[F:TPY]PAYTYP-":"-"Pas d'étape de remise en banque définie",1) From DOSDIC
   Endif
  Elsif [F:TPY]STA8 = 2
   [F:TPY]AUTACE8 = "STEP1"
   [F:TPY]JOU8  = 2
    [F:TPY]JOU8 = 2
   If [F:TPY]STA9 = 2
    [F:TPY]AUTACE9 = "STEPN"
    [F:TPY]ACETYP91 = [F:TPY]ACETYP9
    [F:TPY]ACETYP92 = [F:TPY]ACETYP9
    [F:TPY]JOU9 = 1
   Else
    Call ERREUR("TABPAYTYP"-[F:TPY]PAYTYP-":"-"Pas d'étape de remise en banque définie",1) From DOSDIC
   Endif
  Elsif [F:TPY]STA9 = 2
   [F:TPY]AUTACE9 = "STEP1"
   [F:TPY]ACETYP91 = [F:TPY]ACETYP9
   [F:TPY]ACETYP92 = [F:TPY]ACETYP9
   [F:TPY]JOU9 = 1
  Else
   Call ERREUR("TABPAYTYP"-[F:TPY]PAYTYP-":"-"Aucune étape de comptabilisation définie",1) From DOSDIC
  Endif
  Rewrite [TPY]
  If fstat
   Call ERREUR("TABPAYTYP"-[F:TPY]PAYTYP,1) From DOSDIC
  Endif
 Next
Commit
Close Local File [TPY]


############################################################
## Flag soldée sur les échéances
## Type d'échéance
## Clé unique 
############################################################
Local Char    INTERM

Onerrgo ERREUR

Local File =[F:ADS]DOSSIER+".GACCDUDATE" [DUD]
Local File =[F:ADS]DOSSIER+".PAYMENTH"   [PYH]
Local File =[F:ADS]DOSSIER+".GACCENTRY"  [HAE]
Local File =[F:ADS]DOSSIER+".GACCENTRYD" [DAE]
Local File =[F:ADS]DOSSIER+".SINVOICE"   [SIH]
Local File =[F:ADS]DOSSIER+".PINVOICE"   [PIH]

Call ECR_TRACE(mess(81,125,1)-": GACCDUDATE",0) From GESECRAN : # maj table
Trbegin [DUD]
 For [DUD]DUD0
  If [F:DUD]AMTCUR=[F:DUD]PAYCUR 
   [F:DUD]FLGCLE=2    : # soldée définitivement
  Elsif [F:DUD]AMTCUR=[F:DUD]PAYCUR+[F:DUD]TMPCUR
   [F:DUD]FLGCLE=4    : # soldée temporairement
  Else
   [F:DUD]FLGCLE=1    : # non soldée
  Endif
  ## Type d'échéance    
  If [F:DUD]TYPDUD=0
   Gosub TYPECHE
  Endif
  ## Clé unique
  INTERM = num$([F:DUD]ACCNUM)+"/"+num$([F:DUD]DUDLIG)
  [F:DUD]NUMDUD=INTERM
  Rewrite [DUD]
  If fstat
   Call ERREUR("GACCDUDATE"-[F:DUD]TYP-[F:DUD]NUM-num$([F:DUD]LIG)-num$([F:DUD]DUDLIG),1) From DOSDIC
  Endif
 Next
Commit
Close Local File [DUD],[SIH],[PIH],[PYH],[HAE],[DAE]



############################################################
## Création d'une clé dans le fichier des relevés bancaires 
## (utilisation pour le Browser hiérarchisé)
############################################################
Local File =[F:ADS]DOSSIER+".RELBANK" [RBK]

Call ECR_TRACE(mess(81,125,1)-": RELBANK",0) From GESECRAN : # maj table
Trbegin [RBK]
 For [RBK]RBK0
  If [F:RBK]NUMRBK=0
       [F:RBK]NUMRBK=uniqid([F:RBK])
  Endif  
  Rewrite [RBK]
  If fstat
   Call ERREUR("RELBANK"-[F:RBK]BAN-[F:RBK]RBKNUM-num$([F:RBK]RECTYP)-num$([F:RBK]RBKLIN),1) From DOSDIC
  Endif
 Next
Commit
Close Local File [RBK]
End


$TYPECHE
# Autre
[F:DUD]TYPDUD=4

# Commande
If [F:DUD]TYP="*SO" | [F:DUD]TYP="*PO"
 [F:DUD]TYPDUD=1 : Return   
Endif

# Facture
Case [F:DUD]BPRTYP
 When 1
  Read [SIH]SIH0 = [F:DUD]NUM
  If !fstat : [F:DUD]TYPDUD=2 : Return : Endif
 When 2
  Read [PIH]PIH0 = [F:DUD]NUM
  If !fstat : [F:DUD]TYPDUD=2 : Return : Endif
Endcase

#Règlement
Read [DAE]DAE2=[F:DUD]ACCNUM
If !fstat  
 Read [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM
 If !fstat 
  If left$([F:HAE]REFINT,3)="PYH" : [F:DUD]TYPDUD=3 :  Return : Endif      
 Endif
Endif  
Return


####################################################
Subprog TRSMAJ14

Local File =[F:ADS]DOSSIER+".PAYMENTH"   [PYH]
Local File =[F:ADS]DOSSIER+".PAYMENTD"   [PYD]
Local File =[F:ADS]DOSSIER+".PAYACCNUM"  [PAN]
Local File =[F:ADS]DOSSIER+".TABPAYTYP"  [TPY]
Local File =[F:ADS]DOSSIER+".BANK"       [BAN]
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]
Local File =[F:ADS]DOSSIER+".GACCDUDATE" [DUD]
Local File =[F:ADS]DOSSIER+".GACCENTRYD" [DAE]
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU2]
Local File =[F:ADS]DOSSIER+".TABCHANGE"  [TCH]

Local Integer MAJ_AMTFORCE
Local Integer STAT
Local Integer ACC_NUM
Local Decimal MT1, MT2, MT3

Call ECR_TRACE(mess(81,125,1)-": PAYMENTH, PAYMENTD",0) From GESECRAN : # maj table
## Règlements 130 -> 140
## - Stockage dans PAYMENTH du compte de trésorerie mouvementé à chaque étape de comptabilisation 
## - Init des champs BPRINV, BPRSACINV, AMTBANFRC, AMTBANFRC1, AMTBANFRC2 de PAYMENTD
## - Pas d'initialisation du nouveau champ ACETYP rajouté dans le fichier PAYACCNUM. Ce champ rajouté
##   en version 140 permet de savoir le type de génération de la pièce (par règlement/par bordereau/par date échéance)
##   Pour les règlements validés en 140, si
##        ACETYP = 1 => on a une pièce par règlement
##        ACETYP = 2 => on a une pièce pour X règlements -> gestion d'une table PAYACCUMD : la validation par
##                      bordereau pouvant se faire en 140 sans passer par une comptabilisation intermédiaire, ce
##                      fichier nous permet de tracer les comptes et montants mouvementés pour un règlement
##                      (utile pour l'annulation comptable)
##        ACETYP = 3 => on a une pièce par date d'échéance
##   Dans le programme d'annulation comptable si ACETYP=0, on fait ce qu'on faisait avant...
## - MAJ de PAYDAT de GACCDUDATE
GOK = 1
Trbegin [PYH], [PYD], [DUD]
 For [PYH]PYH0
  For [PAN]PAN0 Where TYPNUM=3 & NUM=[F:PYH]NUM & CPTBAN=2
   If [F:PAN]STA = 3
    [L]ACC_NUM = [F:PAN]ACCNUM
   Endif 
   [F:PYH]ACCNUMTRE([F:PAN]ACCSTA-1) = [F:PAN]ACCNUM
   Rewrite [PYH]
   If fstat
    Call ERREUR("PAYMENTH"-[F:PYH]NUM,2) From DOSDIC
   Endif
  Next
  # Dmd 27619 
  #Call LECTURE("BAN",[F:PYH]BAN,"") From CONTOBJ
  #Call LECTURE("CPY",[F:PYH]CPY,"") From CONTOBJ
  #Call LECTURE("TPY",[F:PYH]PAYTYP,"") From CONTOBJ
  #Call LECTURE("TCU",[F:BAN]CUR,"") From CONTOBJ
  Read [BAN]BAN0 = [F:PYH]BAN
  Read [CPY]CPY0 = [F:PYH]CPY
  Read [TPY]TPY0 = [F:CPY]LEG;[F:PYH]PAYTYP
  Read [TCU]TCU0 = [F:BAN]CUR

  MAJ_AMTFORCE = 0
  Read [TCU2]TCU0 = [F:PYH]CUR
  If [F:PYH]AMTBAN<>0 & [F:PYH]CUR<>[F:BAN]CUR & ([F:TCU]EURFLG=1 | [F:TCU2]EURFLG=1)
   MAJ_AMTFORCE = 1 : MT1 = 0 : MT2 = 0 : MT3 = 0
  Endif
  For [PYD]PYD0 Where NUM=[F:PYH]NUM
   If [F:PYD]VCRNUM<>""
    Read [DUD]DUD1 = [F:PYD]DUDNUM ; [F:PYD]DUDLIG
    If !fstat
     [F:PYD]BPRINV    = [F:DUD]BPR
     [F:PYD]BPRSACINV = [F:DUD]SAC
     Read [DAE]DAE2   = [L]ACC_NUM
     If !fstat
      If [F:DUD]PAYDAT = [0/0/0]
       [F:DUD]PAYDAT = [F:DAE]ACCDAT
      Else
       [F:DUD]PAYDAT = min([F:DUD]PAYDAT,[F:DAE]ACCDAT)
      Endif
      Rewrite [DUD]
      If fstat
       Call ERREUR("GACCDUDATE"-[F:DUD]TYP-[F:DUD]NUM-num$([F:DUD]LIG)-num$([F:DUD]DUDLIG),2) From DOSDIC
      Endif
     Endif
    Endif
   Endif
   If MAJ_AMTFORCE & [F:PYD]ACCTYP = 1
    If [F:BAN]CUR = [F:CPY]ACCCUR 
     MT1 = ([F:PYD]AMTLIN2+MT3)*[F:PYH]AMTBAN/[F:PYH]AMTCUR : # [PYD]AMTBANFRC est en devise locale...
     Call ARRDEV(MT1,[F:CPY]ACCCUR) From TRTDIV
     MT2 = MT3*([F:PYH]AMTBAN/[F:PYH]AMTCUR)
     Call ARRDEV(MT2,[F:CPY]ACCCUR) From TRTDIV
     [F:PYD]AMTBANFRC  = MT1-MT2 : MT3+=[F:PYD]AMTLIN2
     [F:PYD]AMTBANFRC1 = MT1-MT2 : MT3+=[F:PYD]AMTLIN2
     If [F:CPY]ACCCUR = GSYSCUR
      [F:PYD]AMTBANFRC2 = [F:PYD]AMTBANFRC1
     Else
      [F:PYD]AMTBANFRC2 = 0
     Endif
    Elsif [F:BAN]CUR = GSYSCUR
     MT1 = ([F:PYD]AMTLIN2+MT3)*[F:PYH]AMTBAN/[F:PYH]AMTCUR : # [PYD]AMTBANFRC est en devise reporting...
     Call ARRDEV(MT1,GSYSCUR) From TRTDIV
     MT2 = MT3*([F:PYH]AMTBAN/[F:PYH]AMTCUR)
     Call ARRDEV(MT2,[F:CPY]ACCCUR) From TRTDIV
     [F:PYD]AMTBANFRC  = MT1-MT2 : MT3+=[F:PYD]AMTLIN2
     [F:PYD]AMTBANFRC2 = MT1-MT2 : MT3+=[F:PYD]AMTLIN2
     If GSYSCUR = [F:CPY]ACCCUR
      [F:PYD]AMTBANFRC1 = [F:PYD]AMTBANFRC2
     Else
      [F:PYD]AMTBANFRC1 = 0
     Endif
    Else
     MT1 = ([F:PYD]AMTLIN2+MT3)*[F:PYH]AMTBAN/[F:PYH]AMTCUR : # [PYD]AMTBANFRC est en devise de banque...
     Call ARRDEV(MT1,[F:BAN]CUR) From TRTDIV
     MT2 = MT3*([F:PYH]AMTBAN/[F:PYH]AMTCUR)
     Call ARRDEV(MT2,[F:BAN]CUR) From TRTDIV
     [F:PYD]AMTBANFRC = MT1-MT2 : MT3+=[F:PYD]AMTLIN2
     Call CONVERT([F:BAN]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,[F:TPY]RATTYP,[F:PYH]ACCDAT
&                ,[F:PYD]AMTBANFRC,[F:PYD]AMTBANFRC1,STAT) From TRTDEV
     If STAT
      # Règlement [F:PYH]NUM : Pas de cours [F:BAN]CUR -> [F:CPY]ACCCUR (ACCDAT)
      Call ECR_TRACE(mess(47,109,1)-[F:PYH]NUM-":"-mess(4,109,1)-[F:BAN]CUR-"=>"-[F:CPY]ACCCUR-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")",1) From GESECRAN  
     Endif
     Call CONVERT([F:BAN]CUR,GSYSCUR,[F:CPY]ACCCUR,[F:TPY]RATTYP,[F:PYH]ACCDAT
&                ,[F:PYD]AMTBANFRC,[F:PYD]AMTBANFRC2,STAT) From TRTDEV
     If STAT
      # Règlement [F:PYH]NUM : Pas de cours [F:BAN]CUR -> GSYSCUR (ACCDAT)
      Call ECR_TRACE(mess(47,109,1)-[F:PYH]NUM-":"-mess(4,109,1)-[F:BAN]CUR-"=>"-GSYSCUR-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")",1) From GESECRAN  
     Endif
    Endif
   Endif
   Rewrite [PYD]
   If fstat
    Call ERREUR("PAYMENTD"-[F:PYD]NUM-num$([F:PYD]LINNUM),2) From DOSDIC
   Endif
  Next
 Next
Commit
Close Local File [PYH],[PYD],[PAN],[TPY],[BAN],[CPY],[DUD],[DAE],[TCU],[TCU2],[TCH]

############################################################
## Plus haut niveau de relance atteint par un client (Pour la balance âgée)
############################################################
Local File =[F:ADS]DOSSIER+".BPCUSTMVT" [MVC]
Call ECR_TRACE(mess(81,125,1)-": BPCUSTMVT",0) From GESECRAN : # maj table
Trbegin [MVC]
 For [F:MVC]MVC0
  [F:MVC]MAXFUPLEV=[F:MVC]FUPLEV
  Rewrite [F:MVC]
  If fstat
   Call ERREUR("BPCUSTMVT"-[F:MVC]BPCNUM-[F:MVC]FINRSPFCY,1) From DOSDIC
  Endif
 Next
Commit
Close Local File [MVC]

############################################################
## Gestion de l'historisation des échéances
## A FAIRE IMPERATIVEMENT APRES TOUTES MAJ SUR GACCDUDATE !!!
############################################################
Local File =[F:ADS]DOSSIER+".GACCDUDATE" [DUD]
Local File =[F:ADS]DOSSIER+".ACTIV"      [ACT]
Read [ACT]CODACT="HDU"
If !fstat & [ACT]FLACT=2    :#Code activité actif
 #DBA 20/09/04 : Bug no 25031
 #Si code activité inactif, ne pas tenter d'ouvrir HISTODUD...
 Local File =[F:ADS]DOSSIER+".HISTODUD"   [HDU]
 Call ECR_TRACE(mess(81,125,1)-": HISTODUD",0) From GESECRAN : # maj table
 Trbegin [HDU]
  For [DUD]DUD0
   Raz[F:HDU]
   [F:HDU]=[F:DUD]
   [F:HDU]CREDAT=[F:DUD]DUDDAT
   [F:HDU]CREUSR= GUSER
   [F:HDU]NUMHDU=uniqid([HDU])
   [F:HDU]DATEVT=[F:DUD]DUDDAT
   Write [HDU]
   If fstat
    Call ERREUR("HISTODUD"-[F:DUD]TYP-[F:DUD]NUM-num$([F:DUD]LIG)-num$([F:DUD]DUDLIG),1) From DOSDIC
   Endif
  Next
 Commit
 Close Local File [HDU]
Endif
Close Local File [DUD],[ACT]


############################################################
## Gestion Adresse de facturation en fonction des RIB Tiers.
## Par défaut, Adr="Adresse par défaut" & Collectif="indifférent"
############################################################
Local File =[F:ADS]DOSSIER+".BID" [BID]
Local File =[F:ADS]DOSSIER+".BPARTNER" [BPR]
Call ECR_TRACE(mess(81,125,1)-": BID",0) From GESECRAN : # maj table
For [BPR]BPR0
 For [BID]BID0 Where BPATYP=1 & BPANUM=[F:BPR]BPRNUM
  If BPAADD="" :  [F:BID]BPAADD=[F:BPR]BPAADD : Endif
  If dim([F:BID]BIDSAC)>0 : [F:BID]BIDSAC=3 : Endif
  Rewrite [BID] 
  If fstat
   Call ERREUR("BID"-num$([F:BID]BPATYP)-[F:BID]BPANUM-num$([F:BID]BIDNUM),1) From DOSDIC
  Endif
 Next
Next
Close Local File [BID],[BPR]



############################################################
## Redescend le [F:HAE]REFINT vers [F:DAE]REFINTLIN
############################################################
Local File =[F:ADS]DOSSIER+".GACCENTRY"  [HAE]
Local File =[F:ADS]DOSSIER+".GACCENTRYD" [DAE]

Call ECR_TRACE(mess(81,125,1)-": GACCENTRYD",0) From GESECRAN : # maj table
Trbegin [DAE]
 Filter [HAE] Where left$([F:HAE]REFINT,3)="PYH"
 For [HAE]HAE0
  Update [DAE] Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM With [F:DAE]REFINTLIN=[F:HAE]REFINT
  If fstat
    Call ERREUR("GACCENTRYD"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIG),2) From DOSDIC
    Break 
  Endif
 Next
Commit
Close Local File [HAE],[DAE]

End

####################################################
$ERREUR
Call ECR_TRACE("CPTMAJ14"-num$(errl)-errmes$(errn)-errm,1) From GESECRAN
Resume


