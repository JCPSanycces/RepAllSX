#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UTIACH5        Utilitaire de récupération du bug 13053    Module ACHAT #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   S'assurer que les champs suivants sont bien renseignés :             #
#     - [F:POQ]BPSINV    : Fournisseur facturant                         #
#     - [F:POQ]LININVFLG : Indicateur ligne facturée                     #
#     - [F:POQ]LINPRNFLG : Indicateur ligne imprimée                     #
##########################################################################

Call MAJ_UTIACH5
End


Subprog MAJ_UTIACH5
Local Char DOSSIER(30) : DOSSIER=nomap
Call OUVRE_TRACE("UTIACH5 : Utilitaire vérification champs non initialisés dans PORDERQ") From LECFIC
Call TEMPON("O") From GESECRAN
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>"" Call EXE_UTIACH5(DOSSIER) : Endif
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End




Subprog EXE_UTIACH5(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Char     WMSG(80), WNUM(GLONPOH), CLE1(GLONPOH), CRITERE(70), WLINA(8), WSEQA(8)
Local Integer COMPTEUR, STOP
Local Integer  NBENR,    NBCOR, WLIN, WSEQ, CLE2, CLE3
Local Libelle  WINVFLG,  WPRNFLG
#-----
#Call TEMPON("O") From GESECRAN
#Call OUVRE_TRACE("UTIACH5 : Utilitaire vérification champs non initialisés dans PORDERQ") From LECFIC
Call ECR_TRACE("UTIACH5 : Début traitement du dossier "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:POQ]) =0  Local File =DOSSIER+".PORDERQ"    [POQ] : Endif 
If clalev([F:POH]) =0  Local File =DOSSIER+".PORDER"     [POH] : Endif 
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, CLE2, CLE3, NBENR, NBCOR
#-----
$DEBUT
Raz COMPTEUR
Trbegin [POQ]
$BOUCLE_POH
  If STOP=1
    STOP=2 : CRITERE='POHNUM="'+CLE1+'" & POPLIN='+num$(CLE2)+' & POQSEQ>'+num$(CLE3)
  Elsif STOP=2
    STOP=3 : CRITERE='POHNUM="'+CLE1+'" & POPLIN>'+num$(CLE2)
  Elsif STOP=3
    STOP=0 : CRITERE='POHNUM>"'+CLE1+'"'
  Else
    CRITERE="1=1"
  Endif
  For [POQ] POQ0 Where evalue(CRITERE) & POHTYP=2
    WNUM =[F:POQ]POHNUM
    WLIN =[F:POQ]POPLIN
    WSEQ =[F:POQ]POQSEQ
    WLINA=mid$("        ",1,8-len(num$([F:POQ]POPLIN)))+num$([F:POQ]POPLIN)
    WSEQA=mid$("        ",1,8-len(num$([F:POQ]POQSEQ)))+num$([F:POQ]POQSEQ)
    If COMPTEUR=0
      Call ECR_TRACE("----- Début de transaction ("+WNUM-num$(WLIN)-num$(WSEQ)+")",0) From GESECRAN
    Endif
    NBENR+=1
    If [F:POQ]BPSINV="" | [F:POQ]LININVFLG=0 | [F:POQ]LINPRNFLG=0
      WMSG ="Demandes de livraison"-WNUM+WLINA+WSEQA-"Champs initialisés !"
      If [F:POH]POHNUM<>[F:POQ]POHNUM
        Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
      Endif
      If [F:POQ]LININVFLG=0 WINVFLG=1 Else WINVFLG=[F:POQ]LININVFLG : Endif
      If [F:POQ]LINPRNFLG=0 WPRNFLG=1 Else WPRNFLG=[F:POQ]LINPRNFLG : Endif
      Update [POQ] Where POHNUM=WNUM & POPLIN=WLIN & POQSEQ=WSEQ
&                  With  BPSINV=[F:POH]BPSINV, LININVFLG=WINVFLG, LINPRNFLG=WPRNFLG
      If fstat
        GOK=0 : Call FSTA("POQ") From GLOCK
      Else
        NBCOR+=1 : Call ECR_TRACE(WMSG,1) From GESECRAN
      Endif
    Endif
    If GOK=1
      COMPTEUR+=1
      If COMPTEUR>GMAXUPDTRS
        CLE1=[F:POQ]POHNUM : CLE2=[F:POQ]POPLIN : CLE3=[F:POQ]POQSEQ : STOP=1 : Break
      Endif
    Else
      Break
    Endif
  Next
  If GOK=0
    Rollback
    Call ECR_TRACE("----- Transaction abandonnée ("+WNUM-num$(WLIN)-num$(WSEQ)+")",1) From GESECRAN
    Goto FIN_UTIACH5
  Endif
  If STOP & COMPTEUR<GMAXUPDTRS+1 Goto BOUCLE_POH : Endif
Commit
If COMPTEUR>0
  Call ECR_TRACE("----- Transaction validée ("+WNUM-num$(WLIN)-num$(WSEQ)+")",0) From GESECRAN
Endif
If COMPTEUR>GMAXUPDTRS Goto DEBUT : Endif
#----- Fin du traitement -----#
$FIN_UTIACH5
#Call TEMPOFF From GESECRAN
WMSG ="UTIACH5 : Nbre d'enregistrements traités :"-num$(NBENR)
WMSG+=" dont corrigés :"-num$(NBCOR)
Call ECR_TRACE(WMSG,0) From GESECRAN
#Call FERME_TRACE From LECFIC
#Call LEC_TRACE   From LECFIC

Close Local File [POH]
Close Local File [POQ]
End


#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

If [F:ADS]MODULE(5) <> 2 : End : Endif
Call EXE_UTIACH5 (APPLI)
End



