#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe AQCPROC01


##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AINIT"                       : Gosub UPDATE_LOG
      When "ACONTROL"                    : Gosub UPDATE_LOG
      When "AINSERT_CONTROL_BEFORE"      : Gosub UPDATE_LOG
      When "AINSERT_CONTROL_AFTER"       : Gosub UPDATE_LOG
      When "AINSERT_BEFORE"              : Gosub UPDATE_LOG
      When "AINSERT_AFTER"               : Gosub UPDATE_LOG
      When "AINSERT"                     : Gosub UPDATE_LOG
      When "AINSERT_ABORT"               : Gosub UPDATE_LOG
      When "AREAD_BEFORE"                : Gosub UPDATE_LOG : Gosub AREAD_BEFORE
      When "AREAD_AFTER"                 : Gosub UPDATE_LOG : Gosub AREAD_AFTER
      When "ADELETE_CONTROL_BEFORE"      : Gosub UPDATE_LOG
      When "ADELETE_CONTROL_AFTER"       : Gosub UPDATE_LOG
      When "ADELETE_BEFORE"              : Gosub UPDATE_LOG
      When "ADELETE_AFTER"               : Gosub UPDATE_LOG
      When "AUPDATE_CONTROL_BEFORE"      : Gosub UPDATE_LOG
      When "AUPDATE_CONTROL_AFTER"       : Gosub UPDATE_LOG
      When "AUPDATE_BEFORE"              : Gosub UPDATE_LOG
      When "AUPDATE_AFTER"               : Gosub UPDATE_LOG
      When Default:                      : Gosub UNEXPECTED_ACTION
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Gosub PROPERTY_ACTION

Case [L]CURPRO
  When "C01P01" : Gosub PROPERTY_C01P01
Endcase

Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
Endcase
Return

##########################################################################################################
$UNEXPECTED_ACTION
 ASTATUS = fmet this.ASETERROR("UNEXPECTED_ACTION", "Unespected Method Event Execute "+[L]AEVENT,[V]CST_AWARNING)
Return

$UPDATE_LOG
  [L]ASTATUS = fmet this.ASETERROR(ACTION, "Execute Event Action "+[L]AEVENT,[V]CST_AINFO)
Return



$AINSERT_ABORT
ASTATUS = fmet this.ASETERROR("AINSERT_ABORT", "Execute Method Action  AINSERT_ABORT",[V]CST_AINFO)
Return

$ADELETE_CONTROL_AFTER
If this.C01P01 = "SAM_90758"
 ASTATUS = func ASYRSUB._ASETSTATUS(this,"",0,[V]CST_AERROR,[V]CST_AHTTP_FORBIDDEN,func ASYRFNC.MES1(mess(24,149,1),this.C01P01))
Endif
Return

$AREAD_AFTER
If this.C01P01 = "CCL2"
 ASTATUS = func ASYRSUB._ASETSTATUS(this,"",0,[V]CST_AERROR,[V]CST_AHTTP_FORBIDDEN,func ASYRFNC.MES1(mess(76,100,1),this.C01P01))
Endif
Return

$AREAD_BEFORE
If [L]C01P01 = "ADDD"
 ASTATUS = func ASYRSUB._ASETSTATUS(this,"",0,[V]CST_AERROR,[V]CST_AHTTP_FORBIDDEN,func ASYRFNC.MES1(mess(76,100,1),this.C01P01))
Endif
Return

$PROPERTY_C01P01
Case [L]ARULE
   When "INIT"      Gosub C01P01_INIT
   When "CONTROL"   Gosub C01P01_CONTROL
   When "PROPAGATE" Gosub C01P01_PROPAGATE
   When "GET"       Gosub C01P01_GET
Endcase

Return

$PROPERTY_ACTION
Local Integer MY_STATUS
MY_STATUS = fmet this.ASETERROR("PROPERTY_ACTION", "Property ARULE Execute "+CURPRO+"-"+[L]ARULE,[V]CST_AINFO)
Return


$C01P01_INIT
this.C01P01 = "InitValue"
Return

$C01P01_CONTROL
If this.C01P01 = "QUNIT"
  [L]ASTATUS = fmet this.ASETERROR("C01P01", this.C01P01+" not valid", [V]CST_AERROR)
  Return
Endif
this.C01P01 = toupper(this.C01P01)
Return

$C01P01_PROPAGATE
this.C01P02 = "ResProp"
Return

$C01P01_GET
Return

