#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################
#  Traitement de vérification des types non affectés dans un pgm :
#  
#  Une affectation dans le code d'une ou à une variable de classe F ou M à une variable déclarée Char chp1(10)
#  on vérifie que le type à la même longueur et/ou on précise la variable globale devant être utilisée
#
# 
#-----------------------------------------------------------------------------------------------------------#
#If func FNOMARG("", 0) = ""
#Infbox "dedans"
#Endif
#Infbox "dehors"
#End
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT,PARBOUT, "", "AVERIFSRC", "AVERIFSRC", 3, "") From GTRAITE
End
 
Subprog AVERIFTYPE(CHEMINTRA, PATCH, SRCPATCH, NOMTRT, DOSSIER, PMODULE, OWNER, EXCLSUP,
&   PORT, MACHINE, CHEMINTRAW, NBERRTOT, NBWARTOT, PNUMERREUR, NBVARGLOB, 
&   NBVARGLOBDIC, NBVARGLOBSRC, PTYPE, PLONGUEUR, POPERATEUR, PDEMANDEUR, PLIBVERIF)

Value Char CHEMINTRA    :  # Chemin où seront créés les fichiers de trace
Value Char PATCH        :  # Si patch, on ne vérifie que les traitement modifiés
Value Char SRCPATCH     :  # Si patch, chemin où sont les traitements patchés
Value Char NOMTRT       :  # Nom du source à analyser (jokers autorisés)
Value Char DOSSIER      :  # Si non patch, dossier analysé

Value Integer PMODULE    :  # Si travail sur sources d'un module particulier
Value Integer OWNER     :  # Si on veut travailler sur les sources d'un owner particulier
Value Integer EXCLSUP   :  # exclure le module superviseur
Value Integer PORT      :  # port du dossier
Value Char MACHINE      :  # machine du dossier
Value Char CHEMINTRAW
Variable Integer NBERRTOT, NBWARTOT
Value Integer PNUMERREUR : # pour ne travailler que sur une seule erreur
Variable Integer NBVARGLOB, NBVARGLOBDIC, NBVARGLOBSRC
Value Char PTYPE
Value Integer PLONGUEUR
Value Char POPERATEUR
Value Integer PDEMANDEUR : # niveau indus, dev, distri, spe...
Value Char PLIBVERIF


# a intégrer en paramètre pour Sage dev puis les distri...


Local Integer DEMANDEUR
#  0 = Sage Indus
DEMANDEUR = 0



# cbo cbo cbo ===========================================================================

Local Char NOMPROG(GMAX_LGSSPRO), NOMCALL(GMAX_LGSSPRO)

Local Char FICHIERS(GLONABR)(1..GMAX_NBFIC)
Local Char MASQUES(GLONABR)(1..GMAX_NBMSK)
Local Shortint INDFIC(1..GMAX_NBFIC)
Local Char ZONESFIC(GLONAVA)(GMAX_ZONEFIC)

Local Char ZONMSK(GLONAVA)(1..GMAX_ZONEMSK), ZONMSKB(GLONAVA)(1..GMAX_ZONEMSK)
Local Char TYPMZO(10)(1..GMAX_ZONEMSK), TYPMZOB(10)(1..GMAX_ZONEMSK)
Local Integer TYGZO(1..GMAX_ZONEFIC) , TYGMZO(1..GMAX_ZONEMSK), TYGMZOB(1..GMAX_ZONEMSK)


Local Char TCODTYPATY(GLONATY)(1..GMAX_TYPE)
Local Integer TLGTYPATY(1..GMAX_TYPE), NBTYPEATY, WECRERREUR

Local Char VARIA(20),ABV(20), DOSSIER2(100)

Local Integer INDERREUR, TERREUR(50), I, J, NBERREUR

Local Integer WNBFI, NBZO, NBMA, NBZM, NBZA, TYPCOUR
Local Char TYPZO(10)(1..GMAX_ZONEFIC)
Local Integer INDMAS(1..GMAX_NBMSK), NBWARNING, WERRTEXTE
Local Integer NS1, NG1, NF, NBTRAITES
Local Shortint PPTPRO(1..GMAX_SOUSPRO), PPTGOS(1..GMAX_SOUSPRO), SAUVEMODULE

Local Char WTITRE(150), WTITRE2(150), WTEXTE(250), TXTERR(200)
Local Integer IB, MI1, MI2, MI3, TITAECRIRE, IS, IS2, TITAECRIREW, WMIGRATE


Local Integer WCODRET(3), BCHAINELEC, FST
Local Char WFILE(10), WABREV(5)


Local Char WCODE(20)(3), WTYPE(20)(3), WABV(10)(3)
Local Integer WTYPELG(3), WCODRET(3) 
Local Integer WIGNWRSEQ, WIGNWRTRT
Local Char ERRMES(100)(46)

Local Clbfile CHAINE(3), CHAINE1(3), CHAINELEC(3), CHAININS(3), CHAINECPT(3)

Local Char ALPHA(27) : ALPHA="ABCDEFGHIJKLMNOPQRSTUVWXYZ_"
Local Char ALPHAN(37) : ALPHAN=ALPHA+"0123456789"
Local Char SPACEN(37) : SPACEN=space$(len(ALPHAN))


# VARLOC contient les var locales de type chaine et VARLOCAUT celles d'autres types
Local Char VARLOC(20)(1..GMAX_VAR), PARLOC(20)(1..GMAX_VAR)
Local Integer NBVARLOC, NBPARLOC
Local Shortint TYPVARLOC(1..GMAX_VAR)
Local Char LIBTYPLOC(20)(1..GMAX_VAR), WSTYPE(20)

Local Char REPVAR(20)(1..100),REPTRT(GLONADC)
Local Integer PTREP

Local Char VARGLOBEXCEPT(12)(1..10) : # Variables globales à exclure des tests
Local Integer WNBEGACTRL, NLIG, NLIGSAV

Local Char VARLOCAUT(20)(1..GMAX_VAR), VARGLOBAUT(20)(1..GMAX_VAR), VARNONTROUVE(20)(1..GMAX_VAR)
Local Integer NBVARLOCAUT, NBVARGLOBAUT, NBVARNONTROUVE, TLGVARLOCAUT(1..GMAX_VAR)

Local Char TVARS(20)(1..GMAX_VAR)
Local Integer NBVARS, NSK, NSKLEC, NBZMB, IR, ILF

Local Char TABINSTR(200)(1..2000), ZADXIFS, ZADXIRS, CH1(80), CH2(80), CH12(80), CHP(80)
Local Integer NBINSTR, NS2, NG2, ITY, NBPARENTH
# ----------------------------------------------------------------------------------------------------------

PNUMERREUR = mod(PNUMERREUR, 100)

VARGLOBEXCEPT(1)= "TYP"


ZADXIFS=adxifs
ZADXIRS=adxirs
adxifs=chr$(0):adxirs=chr$(10)


Call TEMPON("VERIFTYPE Initialisation du traitement...") From GESECRAN
SAUVEMODULE = -1

If MACHINE = ""
    DOSSIER2 = DOSSIER
Else
    DOSSIER2 = MACHINE + ":" + num$(PORT) + "@" + DOSSIER
Endif

If clalev ([F:ATY])
    Close File [ATY]
Endif
If clalev ([F:ADC])
    Close File [ADC]
Endif
If clalev ([F:ATZ])
    Close File [ATZ]
Endif

If clalev ([F:ATB])
    Close File [ATB]
Endif
If clalev ([F:AMZ])
    Close File [AMZ]
Endif
If clalev ([F:AMK])
    Close File [AMK]
Endif
If clalev ([F:AMK1])
    Close File [AMK1]
Endif
If clalev ([F:AGB])
    Close File [AGB]
Endif
If clalev ([F:AST])
    Close File [AST]
Endif

Local File = DOSSIER2 + "."+"ATYPE"  [ATY]
Local File = DOSSIER2 + ".ADICTRT"   [ADC] : # table des traitements 
Local File = DOSSIER2 + ".ATABZON"   [ATZ]
Local File = DOSSIER2 + ".ATABLE"    [ATB]

Local File = DOSSIER2 + ".AMSKZON"   [AMZ]
Local File = DOSSIER2 + ".AMSK"      [AMK]
Local File = DOSSIER2 + ".AMSK"      [AMK1]
Local File = DOSSIER2 + ".AGLOBVAR"  [AGB]
Local File = DOSSIER2 + ".APLSTD"    [AST]

        # paramétrage du contrôle par rapport aux longueurs de champs > < <= = T
#        WOPE = "<="
        # -----------------------
        
    If POPERATEUR = "="
        GBTDESACTIVE(GNUMMOUL, 1) = 1
        GBTDESACTIVE(GNUMMOUL, 3) = 1
        GBTDESACTIVE(GNUMMOUL, 4) = 1
    Elsif POPERATEUR = "<"
        GBTDESACTIVE(GNUMMOUL, 1) = 1
        GBTDESACTIVE(GNUMMOUL, 2) = 1
        GBTDESACTIVE(GNUMMOUL, 4) = 1
    Elsif POPERATEUR = ">"
        GBTDESACTIVE(GNUMMOUL, 2) = 2
        GBTDESACTIVE(GNUMMOUL, 3) = 1
        GBTDESACTIVE(GNUMMOUL, 4) = 1
    Elsif POPERATEUR = "<="
        GBTDESACTIVE(GNUMMOUL, 1) = 1
        GBTDESACTIVE(GNUMMOUL, 4) = 1
    Elsif POPERATEUR = ">="
        GBTDESACTIVE(GNUMMOUL, 3) = 1
        GBTDESACTIVE(GNUMMOUL, 4) = 1
    Endif
    
    Openo CHEMINTRA, -1
    Wrseq
    Wrseq
    Wrseq
    Wrseq "-------------------------### Vérification des" - PLIBVERIF + ". ###---------------------------"
    Wrseq
    Wrseq
    
    If PNUMERREUR
        If GBTWARNING(GNUMMOUL, PNUMERREUR)
            Wrseq "Attention, seule l'anomalie n°" -num$(400 + PNUMERREUR) - " est recherchée"
        Else
            Wrseq "Attention, seule l'erreur n°" -num$(400 + PNUMERREUR) - " est recherchée"
        Endif
    Endif
    Wrseq
    
    Openo
    
    Openo CHEMINTRA, -1  Using [FER]
    
    Openo CHEMINTRAW, -1
    Wrseq
    Wrseq
    Wrseq
    Wrseq "-------------------------### Vérification des" - PLIBVERIF + ". ###---------------------------"
    Wrseq
    Wrseq
    
    If PNUMERREUR
        If GBTWARNING(GNUMMOUL, PNUMERREUR)
            Wrseq "Attention, seule l'anomalie n°" -num$(400 + PNUMERREUR) - " est recherchée"
        Else
            Wrseq "Attention, seule l'erreur n°" -num$(400 + PNUMERREUR) - " est recherchée"
        Endif
    Endif
    Wrseq
    
    Openo
    
    Openo CHEMINTRAW, -1  Using [FWR]
    
    
    Raz INDERREUR, TERREUR, NBERREUR, WNBEGACTRL



#--------------------------------#
# Tableau des var classe S
#--------------------------------#

    NBVARS = clanbs([S], 1)
    For I = 1 To NBVARS
#        TVARS(I) = clavar([S], I)
        TVARS(I) = vireblc(format$("KT:12X",clavar([S], I)), 4)
    Next I

    J = clanbs([G], 1)
    For I = 1 To J
        TVARS(NBVARS + I) = vireblc(format$("KT:12X",clavar([G], I)), 4)
    Next I
    
    NBVARS += J
    
    
    J = clanbs([V], 1)
    For I = 1 To J
        TVARS(NBVARS + I) = vireblc(format$("KT:12X",clavar([V], I)), 4)
    Next I
    
    NBVARS += J






#----------------
# tableau des types
#----------------

    Call TEMPON("VERIFTYPE : chargement des types") From GESECRAN
    NBTYPEATY = 0
    For [ATY]
        # TYPTYP(WNBFI) = 2*([ATY]TYPTYP<=6)+1*([ATY]TYPTYP=7)+3*([ATY]TYPTYP=8) +4*([ATY]TYPTYP=9) + 5*([ATY]TYPTYP=10)
        # ? var GLOB :GLON + CODTYP (de type alpha) 

        # on ne traite que les chaînes
        If [F:ATY]TYPTYP = 7
            If PTYPE = "" or (PTYPE <> "" and ([F:ATY]CODTYP = PTYPE or [F:ATY]CODTYP = "A"))
                NBTYPEATY += 1
                TCODTYPATY(NBTYPEATY) = [F:ATY]CODTYP
                TLGTYPATY(NBTYPEATY)  = [F:ATY]LNGTYP
                IS2 = find([F:ATY]CODTYP, GTVARGLOBSRC(1..NBVARGLOBSRC))
            
                If IS2
                    If (GTLGVARGLOBSRC(IS2) <> [F:ATY]LNGTYP)
                        TERREUR(6) += 1
                        NBERREUR += 1
                        GTRECAPERR(GNUMMOUL, [F:ATY]MODULE, 6) += 1
                        Wrseq "  *** (err 406) le type de données" - [F:ATY]CODTYP - "a pour longueur" - num$([F:ATY]LNGTYP) - "et la variable globale a" - num$(GTLGVARGLOBSRC(IS2)) Using[FER]
                    Endif
                    
                    If GTLGVARGLOBSRC(IS2) = 0 or [F:ATY]LNGTYP = 0
                        TERREUR(6) += 1
                        NBERREUR += 1
                        GTRECAPERR(GNUMMOUL, [F:ATY]MODULE, 6) += 1
                        Wrseq "  *** (err 406) Longueur à 0 : type de données" - [F:ATY]CODTYP - "=" - num$([F:ATY]LNGTYP) - "et la variable globale =" - num$(GTLGVARGLOBSRC(IS2)) Using[FER]
                    Endif
                Else
                    If [F:ATY]CODTYP <> "A"
                        TERREUR(6) += 1
                        NBERREUR += 1
                        GTRECAPERR(GNUMMOUL, [F:ATY]MODULE, 6) += 1
                        Wrseq "  *** (err 406) le type de données" - [F:ATY]CODTYP - " n'a pas sa déclaration en" - GPREFIXE Using[FER]
                    Endif
                Endif
            Endif
        Endif
    Next
    Wrseq "" Using [FER]
    Wrseq "Types alpha. trouvés :" - num$(NBTYPEATY) Using [FER]
    Wrseq "" Using [FER]


    For IS = 1 To NBVARGLOBSRC
    
        If find(GTVARGLOBSRC(IS), TCODTYPATY(1..NBTYPEATY)) = 0
            TERREUR(7) += 1
            NBERREUR += 1
            GTRECAPERR(GNUMMOUL, 0, 7) += 1
            Wrseq "  *** (err 407) La variable globale" - GPREFIXE + GTVARGLOBSRC(IS) - "n'a pas de correspondance dans la table des Types" Using[FER]
        Endif
    Next IS
    Wrseq "" Using [FER]
    Wrseq "" Using [FER]
    
#------------------------------#
# Table des variables fichiers
#------------------------------#

    Call TEMPON("VERIFTYPE : chargement des champs de tables") From GESECRAN

    WNBFI=0
    NBZO=1
    For [ATZ]CODZONE(1)
        Read [ATB]CODFIC=[ATZ]CODFIC
        WNBFI+=1
        FICHIERS(WNBFI)=[ATB]ABRFIC
        INDFIC(WNBFI)=NBZO
        For [ATZ]CODZONE

            # on ne va charger que des champs alphas vu que le tableau TCODTYPATY n'est chargé que de ce type
            IS = find([F:ATZ]CODTYP, TCODTYPATY)
            If IS
                ZONESFIC(NBZO) = [F:ATZ]CODZONE
                TYPZO(NBZO) = [F:ATZ]CODTYP
                If [F:ATZ]CODTYP = "A" or TLGTYPATY(IS) = 0
                    TYGZO(NBZO) = [F:ATZ]LONG
                Else
                    TYGZO(NBZO) = TLGTYPATY(IS)   # longueur du type prédéfini
                Endif
        
                NBZO+=1
            Endif
        Next
    Next
    INDFIC(WNBFI+1)=NBZO

#----------------------------#
# Table des variables masques
#----------------------------#

    Call TEMPON("VERIFTYPE : chargement des champs de masques") From GESECRAN

    NBMA=0
    NBZM=1
    NBZMB=1


    Filter [AMZ] Where CODMSK < "VXACC"
    For [AMZ]CODE(1)
        Read [AMK]CODMSK=[AMZ]CODMSK
        NBZA=0
        For [AMK1]ABRMSK Where ABRMSK=[AMK]ABRMSK
            NBZA+=1
        Next
        If NBZA=1 : # Un seul masque possède cette abréviation, on a donc des chances
            NBMA+=1

            MASQUES(NBMA)=[AMK]ABRMSK
            INDMAS(NBMA)=NBZM
            For [AMZ]CODE
      
                If NBZM > GMAX_ZONEMSK
                    IS = find([F:AMZ]CODTYP, TCODTYPATY)

                    # on ne va charger que des champs alphas vu que le tableau TCODTYPATY n'est chargé que de ce type
                    If IS
                        ZONMSKB(NBZMB) = [F:AMZ]CODZON
                        TYPMZOB(NBZMB) = [F:AMZ]CODTYP
                        If [F:AMZ]CODTYP = "A" or TLGTYPATY(IS) = 0
                            TYGMZOB(NBZMB) = [F:AMZ]LONG
                        Else
                            TYGMZOB(NBZMB) = TLGTYPATY(IS)   # longueur du type prédéfini
                        Endif
    
                        NBZM  += 1
                        NBZMB += 1
                    Endif
        
                    If NBZMB > GMAX_ZONEMSK
#                        Infbox "MAX_ZONMSK dépassé (2° tableau)"
                        Break 2
                    Endif
                
                Else
                    IS = find([AMZ]CODTYP, TCODTYPATY)

                    # on ne va charger que des champs alphas vu que le tableau TCODTYPATY n'est chargé que de ce type
                    If IS
                        ZONMSK(NBZM) = [F:AMZ]CODZON
                        TYPMZO(NBZM) = [F:AMZ]CODTYP
                        If [F:AMZ]CODTYP = "A" or TLGTYPATY(IS) = 0
                            TYGMZO(NBZM) = [F:AMZ]LONG
                        Else
                            TYGMZO(NBZM) = TLGTYPATY(IS)   # longueur du type prédéfini
                        Endif
            
                        NBZM += 1
                    Endif
                Endif
            Next
        Endif
    Next

    Filter [AMZ]
    INDMAS(NBMA+1)=NBMA

    
    Call TEMPON("VERIFTYPE : Analyse") From GESECRAN


    If NOMTRT <> "" and NOMTRT <> "*" and instr(1, NOMTRT, "*") = 0
        NF = find(NOMTRT, GTTRAITEMENTS(1..GNBTRTADX))
        If NF
            Gosub ANALYSE
        Endif
    Else
        If PNUMERREUR
            If PMODULE
                MI2 = PMODULE
                MI3 = PMODULE
            Else
                If instr(1, DOSSIER, "GE")
                    MI2 = 1
                    MI3 = 2
                Elsif instr(1, DOSSIER, "PA") or  instr(1, DOSSIER, "HR")
                    MI2 = 1
                    MI3 = 10
                Else
                    MI2 = 1
                    MI3 = 14
                Endif
            Endif
            For MI1 = MI2 To MI3
    
                PMODULE = MI1
                Wrseq "" Using [FER]
                Wrseq "" Using [FER]
                Wrseq "Module" - num$(PMODULE) - func AVERIFSRC.LIBMODULE (PMODULE, SAUVEMODULE) - ") _____________________________________________________________"
&               Using [FER]
                Wrseq "" Using [FER]
            

                For NF=1 To GNBTRTADX
                    If PATCH = "" | filinfo(SRCPATCH + "/" + GTTRAITEMENTS(NF) + ".src", 0) > 0
                      Gosub ANALYSE
                    Endif
                Next NF
            
            Next MI1
            
        Else
            For NF=1 To GNBTRTADX
                If PATCH = "" | filinfo(SRCPATCH + "/" + GTTRAITEMENTS(NF) + ".src", 0) > 0
                    Gosub ANALYSE
                Endif
            Next NF
        Endif
    Endif

    NS1+=1
    NG1+=1
    NF = GNBTRTADX + 1
    
    PPTPRO(NF)=NS1
    PPTGOS(NF)=NG1 : # A voir


$FIN2P


    adxifs=ZADXIFS
    adxirs=ZADXIRS
    
    Wrseq Using [FER]
    Wrseq Using [FER]
    Wrseq num$(NBERREUR) - "erreurs sur" - num$(WNBEGACTRL) - "affectations contrôlées et" - num$(NBTRAITES) - "sources contrôlés."  Using [FER]
    Wrseq Using [FER]

    Wrseq Using [FWR]
    Wrseq Using [FWR]
    Wrseq num$(NBWARNING) - "erreurs sur" - num$(WNBEGACTRL) - "affectations contrôlées et" - num$(NBTRAITES) - "sources contrôlés."  Using [FWR]
    
    Wrseq Using [FWR]
    
    
    NBERRTOT += NBERREUR
 
    If PNUMERREUR
        IR = PNUMERREUR
        ILF = PNUMERREUR
    Else    
        IR = 1
        ILF = GNBERREUR(GNUMMOUL)
    Endif
    
    For INDERREUR = IR To ILF
    
        If GBTWARNING(GNUMMOUL, INDERREUR)
            WTEXTE = "Ano"
        Else
            WTEXTE = "Err"
        Endif
        If GBTDESACTIVE(GNUMMOUL, INDERREUR)
            WTEXTE = WTEXTE - num$(INDERREUR + 400) - "(désactivée)"
        Else
            WTEXTE = WTEXTE - num$(INDERREUR + 400) - "Nombre :"  - num$(TERREUR(INDERREUR))
        Endif
        
        IB = len(WTEXTE)
        IB = 40 - IB

        If IB > 0
            WTEXTE = WTEXTE + string$(IB, " ")
        Else
            WTEXTE = WTEXTE
        Endif
        If GBTWARNING(GNUMMOUL, INDERREUR)
            Wrseq WTEXTE + GTLIBERREUR(GNUMMOUL, INDERREUR) Using [FWR]
        Else
            Wrseq WTEXTE + GTLIBERREUR(GNUMMOUL, INDERREUR) Using [FER]
        Endif
    
    Next INDERREUR
    Wrseq Using [FER]
    Wrseq "Fin de vérifications des" - PLIBVERIF + "." - time$ Using [FER]
    Wrseq Using [FER]

    Openo  Using [FER]

    Wrseq Using [FWR]
    Wrseq "Fin de vérifications des" - PLIBVERIF + "." - time$ Using [FWR]
    Wrseq Using [FWR]

    Openo  Using [FWR]

    Call TEMPOFF From GESECRAN

    Close File [ATY]
    Close File [ADC]
    Close File [ATZ]

    Close File [ATB]
    Close File [AMZ]
    Close File [AMK]
    Close File [AMK1]
    Close File [AGB]
    Close File [AST]

    Goto FINCALL
#------------------------------------------------------------------------------------------------------------------------#


$ANALYSE

    NS1 += 1
    NG1 += 1
    PPTPRO(NF)=NS1 : # Pointeur vers sous-programme courant
    PPTGOS(NF)=NG1
    NS2=0 
    NG2=0 
    NBVARLOC=0
    NBPARLOC=0
    
    NBVARLOCAUT  = 0
    Raz TLGVARLOCAUT
    NBVARNONTROUVE = 0
    

    If mod(NF,100) = 0
        If PNUMERREUR
           Call TEMPON("VERIFTYPE :" - num$(NF) + "/" + num$(GNBTRTADX) - GTTRAITEMENTS(NF) + ".src" -
&               "module" - num$(PMODULE)) From GESECRAN
        Else
           Call TEMPON("VERIFTYPE :" - num$(NF) + "/" + num$(GNBTRTADX) - GTTRAITEMENTS(NF) + ".src" -
&              "Err" - num$(NBERREUR) -
&              "module" - num$(PMODULE)) From GESECRAN
        Endif
    Endif    

    If func AVERIFSRC.SRCAPASTRAITER (GTTRAITEMENTS(NF), NOMTRT, DOSSIER2, PMODULE, EXCLSUP, PATCH, SRCPATCH,
&           OWNER, TXTERR, PDEMANDEUR)
        Return
    Endif

    TITAECRIRE = 1
    TITAECRIREW = 1
    NBTRAITES += 1
    
    If PATCH <>"" and filinfo(SRCPATCH+"/"+GTTRAITEMENTS(NF)+".src",0) > 0
       Openi SRCPATCH+"/"+GTTRAITEMENTS(NF)+".src",0
    Else
       Openi filpath("TRT", GTTRAITEMENTS(NF), "src", DOSSIER2), 0
    Endif
    
    Raz WFILE, WABREV, WIGNWRSEQ, WIGNWRTRT, ERRMES
    FST=0
    NLIG = -1
    CHAINELEC = ""
    BCHAINELEC = 0
    Raz TABINSTR, NBINSTR
    
    While FST=0
        Call LIREETFMT(CHAINE, CHAINELEC, BCHAINELEC, FST, NLIG, NSK, NSKLEC) From AVERIFSRC
        Call VIRECOMCHK (CHAINE, 0, 0, WFILE, WABREV, WIGNWRSEQ, WIGNWRTRT, WMIGRATE) From AVERIFSRC
        If WIGNWRTRT = 1 or WIGNWRTRT = 3
            Return
        Endif
        CHAININS = CHAINE
        CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
#If NLIG = 69
#Dbgaff
#Endif
        While CHAINE <> ""
            # mémo de la chaine intacte (complète avant traitement pour test sur DBGAFF)
            CHAINECPT = CHAINE

            If pat(CHAINE, "Local*")
                Gosub ANAVARLOC
            Elsif pat(CHAINE, "Subprog*") or pat(CHAINE, "Funprog*")
                Raz VARLOC, NBVARLOC, PARLOC, NBPARLOC
                Raz VARLOCAUT, NBVARLOCAUT, TLGVARLOCAUT
            Elsif pat(CHAINE, "Value*")
                IS = 1
                Gosub ANAPARLOC
            Elsif pat(CHAINE, "Variable*")
                IS = 2
                Gosub ANAPARLOC

            Elsif pat(CHAINE, "*=*")

                Gosub ANAEGAL
            Endif
      
            CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
        Wend
    Wend 
 
Return


# signe égal trouvé ?
$ANAEGAL

    If left$(CHAINE, 2) = "If"
        CHAINE = right$(CHAINE, 3)
    Elsif left$(CHAINE, 4) = "Else"
        CHAINE = right$(CHAINE, 5)
    Elsif left$(CHAINE, 5) = "Elsif"
        CHAINE = right$(CHAINE, 6)
    Elsif left$(CHAINE, 5) = "While"
        CHAINE = right$(CHAINE, 6)
    Elsif left$(CHAINE, 5) = "Until"
        CHAINE = right$(CHAINE, 6)
    Elsif left$(CHAINE, 3) = "For" or
&         left$(CHAINE, 6) = "Filter" or
&         left$(CHAINE, 4) = "Read" or
&         left$(CHAINE, 6) = "Update" or
&         left$(CHAINE, 6) = "Delete" or
&         left$(CHAINE, 4) = "Link"

        Return
    Endif
    If pat(CHAINE, "*Func*")
        Return
#        CHAINE = right$(CHAINE, 5)
#        I = instr(1, CHAINE, ".")
#        If I
#            CHAINE = right$(CHAINE, I + 1)
#        Endif
    Endif

    CHAINE = vireblc(CHAINE, 4)
    
    I = instr(1, CHAINE, "=")
    CH1 = left$(CHAINE, I - 1)
    If instr(1, CH1, "Call")
        Return
    Endif
    CH2 = right$(CHAINE, I + 1)


    CH12 = CH1
    I = 1
    Gosub ANACH12
    If WCODRET(I) <= 0
        Return
    Endif
    
    CH12 = CH2
    I = 2
    Gosub ANACH12
    If WCODRET(I) <= 0
        Return
    Endif    

    WNBEGACTRL += 1
    

    If WTYPE(1) <> WTYPE(2) and (WTYPE(1) = "A" or WTYPE(2) = "A") and
&       (PTYPE = "" or (PTYPE <> "" and (PTYPE = WTYPE(1) or PTYPE = WTYPE(2)))) and
&       (PLONGUEUR = 0 or (PLONGUEUR and ((WTYPE(1) = "A" and WTYPELG(1) = PLONGUEUR) or (WTYPE(2) = "A" and WTYPELG(2) = PLONGUEUR))))

        # paramétrage du contrôle par rapport aux longueurs de champs > < <= = T
#        WOPE = "<="
        # -----------------------
        
        IS = WTYPELG(1) - WTYPELG(2)
        If POPERATEUR = ">"
            If IS < 0
                IS = 0
            Endif
        Elsif POPERATEUR = ">="
            If IS < 0
                IS = 0
            Elsif IS = 0
                IS = -1
            Endif
        Elsif POPERATEUR = "="
            If IS = 0
                IS = 1
            Else
                IS = 0
            Endif
        Elsif POPERATEUR = "<"
            If IS > 0
                IS = 0
            Endif
        Elsif POPERATEUR = "<="
            If IS > 0
                IS = 0
            Elsif IS = 0
                IS = 1
            Endif
        Endif

        If IS or POPERATEUR = "T"
            If WCODRET(1) = 30 or WCODRET(2) = 30    
                WECRERREUR = 4
            Else
                If POPERATEUR = "T"
                    If IS > 0
                        WECRERREUR = 1
                    Elsif IS = 0
                        WECRERREUR = 2
                    Else
                        WECRERREUR = 3
                    Endif
                Else
                    If POPERATEUR = "="
                        WECRERREUR = 2
                    Elsif POPERATEUR = "<"
                        WECRERREUR = 3
                    Elsif POPERATEUR = "<="
                        If IS > 0
                            WECRERREUR = 2
                        Else
                            WECRERREUR = 3
                        Endif
                    Elsif POPERATEUR = ">="
                        If IS < 0
                            WECRERREUR = 2
                        Else
                            WECRERREUR = 1
                        Endif
                    Else
                        WECRERREUR = 1
                    Endif
                Endif
            Endif

            If WABV(1) <> "" and left$(WABV(1), 1) <> "["
                WABV(1) = "[" + WABV(1) + "]"
            Endif
            If WABV(2) <> "" and left$(WABV(2), 1) <> "["
                WABV(2) = "[" + WABV(2) + "]"
            Endif
            ERRMES(1) = "Variable 1 :" - func CADRECHAINE(WABV(1) + WCODE(1), 20) + "de type" - func CADRECHAINE(WTYPE(1), 10)
            If WCODRET(1) = 30
                ERRMES(1) = ERRMES(1) + "sans longueur définie"
            Else
                ERRMES(1) = ERRMES(1)  + "et longueur" - num$(WTYPELG(1))
            Endif
            ERRMES(2) = "Variable 2 :" - func CADRECHAINE(WABV(2) + WCODE(2), 20) + "de type" - func CADRECHAINE(WTYPE(2), 10)
            If WCODRET(2) = 30
                ERRMES(2) = ERRMES(2) + "sans longueur définie"
            Else
                ERRMES(2) = ERRMES(2)  + "et longueur" - num$(WTYPELG(2))
            Endif

            Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE,
&                CHAINECPT, NBERREUR, NBWARNING, NLIG, NLIGSAV, WECRERREUR, TERREUR, SAUVEMODULE,
&                PNUMERREUR, TITAECRIREW, TABINSTR, NBINSTR, PATCH)

        Endif
    Endif
Return

$ANACH12

# WCODRET = 0 rien trouvé
#         = 1 table
#         = 2 masque
#         = 3 var loc ou globale

    WCODE(I)  = ""
    WABV(I)   = ""
    WTYPE(I)  = ""
    WTYPELG(I) = 0
    WCODRET(I) = 0

    If left$(CH12, 1) = "["
        If left$(CH12, 3) = "[F:"
            ABV = right$(CH12, 4)
            IS = instr(1, ABV, "]")
            If IS
                CHP = right$(ABV, IS + 1)
                ABV = left$(ABV, IS - 1)
                WABV(I)   = "[F:" + ABV + "]"
                
                Gosub RECHVARFIC
            Endif
        Elsif left$(CH12, 3) = "[M:"
            ABV =right$(CH12, 4)
            IS = instr(1, ABV, "]")
            If IS
                CHP = right$(ABV, IS + 1)
                ABV = left$(ABV, IS - 1)
                WABV(I)   = "[M:" + ABV + "]"
            
                Gosub RECHVARMSK
            Endif
        Else
            ABV = right$(CH12, 2)
            IS = instr(1, ABV, "]")
            If IS
                CHP = right$(ABV, IS + 1)
                ABV = left$(ABV, IS - 1)
                WABV(I)   = "[" + ABV + "]"
                
                Gosub RECHVARFIC
                If WCODRET(I) = 0
                    Gosub RECHVARMSK
                Endif
            Endif
        Endif
    Else
        # on ne peut rechercher une table ou un masque : on cherche les variables
        ABV = ""
        CHP = CH12

        Gosub RECHVARAUT
    Endif
        
Return


# Recherche dans le tableau des fichiers
$RECHVARFIC

    IS2 = find(ABV, FICHIERS(1..WNBFI))
    If IS2
        IS = find(CHP, ZONESFIC(INDFIC(IS2)..INDFIC(IS2 + 1) - 1))
        If IS
            IS = IS + INDFIC(IS2) - 1
        Endif
    Else
        IS = 0
    Endif
    
    If IS
        WCODRET(I) = 1
        WCODE(I)  = CHP
        WTYPE(I)  = TYPZO(IS)
        WTYPELG(I) = TYGZO(IS)
        
        If WTYPELG(I) = 0 and WTYPE(I) <> "A"
            IS = find(WTYPE(I), GTVARGLOBSRC(1..NBVARGLOBSRC))
            If IS
                WTYPELG(I) = GTLGVARGLOBSRC(IS)
            Endif
        Endif
    Endif
    
Return

# Recherche dans les 2 tableaux des infos de la zone masque
$RECHVARMSK

    IS = find(ABV, MASQUES(1..NBMA))
    If IS = 0
        WCODRET(I) = 0
        Return
    Endif
    
    # 2° tableau
    If INDMAS(IS) > GMAX_ZONEMSK

        ITY = find(CHP, ZONMSKB(INDMAS(IS) - GMAX_ZONEMSK..INDMAS(IS+1)-1 - GMAX_ZONEMSK))
        If ITY
#            TYPCOUR = TYPMZOB(INDMAS(IS)+ITY-1 - GMAX_ZONEMSK)
            WCODE(I)  = ZONMSKB(INDMAS(IS)+ITY-1 - GMAX_ZONEMSK)
            WTYPE(I)  = TYPMZOB(INDMAS(IS)+ITY-1 - GMAX_ZONEMSK)
            WTYPELG(I) = TYGMZOB(INDMAS(IS)+ITY-1 - GMAX_ZONEMSK)

            If WTYPELG(I) = 0
                IS = find(WTYPE(I), GTVARGLOBSRC(1..NBVARGLOBSRC))
                If IS
                    WTYPELG(I) = GTLGVARGLOBSRC(IS)
                Endif
            Endif
            WCODRET(I) = 2
        Endif
    Else
        # à cheval sur les 2 tableaux
        If INDMAS(IS+1)-1 > GMAX_ZONEMSK

            ITY=find(CHP, ZONMSK(INDMAS(IS)..GMAX_ZONEMSK))
            If ITY
#                TYPCOUR = TYPMZO(INDMAS(IS)+ITY-1)
                WCODE(I)  = ZONMSK(INDMAS(IS)+ITY-1)
                WTYPE(I)  = TYPMZO(INDMAS(IS)+ITY-1)
                WTYPELG(I) = TYGMZO(INDMAS(IS)+ITY-1)
                If WTYPELG(I) = 0
                    IS = find(WTYPE(I), GTVARGLOBSRC(1..NBVARGLOBSRC))
                    If IS
                        WTYPELG(I) = GTLGVARGLOBSRC(IS)
                    Endif
                Endif
                WCODRET(I) = 2
            Else

                ITY = find(CHP, ZONMSKB(1..INDMAS(IS+1)-1 - GMAX_ZONEMSK))
                If ITY
#                    TYPCOUR = TYPMZOB(ITY)
                    WCODE(I)  = ZONMSKB(ITY)
                    WTYPE(I)  = TYPMZOB(ITY)
                    WTYPELG(I) = TYGMZOB(ITY)
                    If WTYPELG(I) = 0
                        IS = find(WTYPE(I), GTVARGLOBSRC(1..NBVARGLOBSRC))
                        If IS
                            WTYPELG(I) = GTLGVARGLOBSRC(IS)
                        Endif
                    Endif
                    WCODRET(I) = 2
                Endif
            Endif

        # 1° tableau
        Else

            ITY=find(CHP, ZONMSK(INDMAS(IS)..INDMAS(IS+1)-1))
            If ITY
#                TYPCOUR = TYPMZO(INDMAS(IS)+ITY-1)
                WCODE(I)  = ZONMSK(INDMAS(IS)+ITY-1)
                WTYPE(I)  = TYPMZO(INDMAS(IS)+ITY-1)
                WTYPELG(I) = TYGMZO(INDMAS(IS)+ITY-1)
                If WTYPELG(I) = 0
                    IS = find(WTYPE(I), GTVARGLOBSRC(1..NBVARGLOBSRC))
                    If IS
                        WTYPELG(I) = GTLGVARGLOBSRC(IS)
                    Endif
                Endif
                WCODRET(I) = 2
            Endif
        Endif
    Endif
Return

#  Recherche dans les tableaux de variables locales et/ou celui des globales 
$RECHVARAUT

            
    IS = len(CHP) - len(vireblc(ctrans(CHP, ALPHAN, SPACEN), 0))
    CHP  = vireblc(left$(CHP, IS), 2)

    
    If find(CHP, PARLOC(1..NBPARLOC))
        WCODRET(I) = -1
        Return
    Endif
    
    IS = find(CHP, VARLOC(1..NBVARLOC))
    If IS
        WCODRET(I) = 3
        WCODE(I)  = CHP
        IS2 = find(LIBTYPLOC(IS), TCODTYPATY(1..NBTYPEATY))
        If IS2
            WTYPE(I)  = LIBTYPLOC(IS)
            WTYPELG(I) = TLGTYPATY(IS2)
        Else
            If func AVERIFSRC.VALN(LIBTYPLOC(IS)) = -1
                If LIBTYPLOC(IS) = GSANSLG
                    WTYPE(I) = "A"
                    WTYPELG(I) = 30
                    WCODRET(I) = 30
                Else
                    If find(LIBTYPLOC(IS), PARLOC(1..NBPARLOC))
                        WCODRET(I) = -1
                        Return
                    Endif

                    WTYPE(I) = LIBTYPLOC(IS)
                    Read [AGB]AGB0 = LIBTYPLOC(IS)
                    If fstat
                              If WTYPELG(I) = 0 and WTYPE(I) <> "A"
                                  IS = find(WTYPE(I), VARLOCAUT(1..NBVARLOCAUT))
                                  If IS
                                      WTYPELG(I) = TLGVARLOCAUT(IS)
                                  Endif
                              Endif

                        WTYPELG(I) = 0
                        WCODRET(I) = -1
                    Else
                        WTYPELG(I) = val([AGB]FORINI)
                    Endif
                Endif
            Else
                WTYPE(I)  = "A"
                WTYPELG(I) = val(LIBTYPLOC(IS))
            Endif
        Endif
        Return
    Endif


    IS = find(CHP, GTVARGLOB(1..NBVARGLOB))
    If IS
        WCODRET(I) = 3
        WCODE(I)  = CHP
        If GTLGVARGLOB(IS) > 0
            WTYPE(I)  = GLIBTYPGLOB(IS)
            WTYPELG(I) = GTLGVARGLOB(IS2)
        Else

            IS2 = find(GLIBTYPGLOB(IS), TCODTYPATY(1..NBTYPEATY))
            If IS2
                WTYPE(I)  = GLIBTYPGLOB(IS)
                WTYPELG(I) = TLGTYPATY(IS2)
            Else
                If func AVERIFSRC.VALN(GLIBTYPGLOB(IS)) = -1
                    If GLIBTYPGLOB(IS) = GSANSLG
                        WTYPE(I) = "A"
                        WTYPELG(I) = 30
                        WCODRET(I) = 30
                    Else
                        WTYPE(I)  = GLIBTYPGLOB(IS)
    
                        Read [AGB]AGB0 = GLIBTYPGLOB(IS)
                        If fstat
                            WTYPELG(I) = 0
                            WCODRET(I) = -1
                        Else
                            WTYPELG(I) = val([AGB]FORINI)
                        Endif
                    Endif
                Else
                    WTYPE(I)  = "A"
                    WTYPELG(I) = val(GLIBTYPGLOB(IS))
                Endif
            Endif
        Endif
        Return
    Endif
        
    # recherche des var non déclarées
    If CHP <> '""' and CHP <> "''" and CHP <> ""
    
        IS = find(CHP, VARLOCAUT(1..NBVARLOCAUT))
        If IS
            # noter si partie 2 = nombre qui peut être une dimension de var...
            If I = 1 and TLGVARLOCAUT(IS) <= 0
#Wrseq GTTRAITEMENTS(NF) - num$(NLIG) - CH2 - num$(TLGVARLOCAUT(IS)) - num$(IS) Using [FWR]
#Openo
#Openo CHEMINTRAW, -1  Using [FWR]
                TLGVARLOCAUT(IS) = func AVERIFSRC.VALN(CH2)
            Endif
            Return
        Endif
        
        
 ##       IS = find(CHP, VARGLOBAUT(1..NBVARGLOBAUT))
 ##       If IS
#                    If I = 1 and TLGVARGLOBAUT(IS) <= 0
#                        TLGVARGLOBAUT(IS) = func AVERIFSRC.VALN(CH2)
#                    Endif
 ##           Return
 ##       Endif



        # on a trouvé une affectation de variable à une valeur : on affecte
        # pour utilisation plus loin
        IS = find(CHP, GTVARGLOB(1..NBVARGLOB))
        If IS
            If I = 1 and GTLGVARGLOB(IS) <= 0
                GTLGVARGLOB(IS) = func AVERIFSRC.VALN(CH2)
            Endif
            Return
        Endif

        IS = find(CHP, GTVARGLOBDIC(1..NBVARGLOBDIC))
        If IS
            If I = 1 and GTLGVARGLOBDIC(IS) <= 0
                GTLGVARGLOBDIC(IS) = func AVERIFSRC.VALN(CH2)
            Endif
            Return
        Endif

        IS = find(CHP, GTVARGLOBSRC(1..NBVARGLOBSRC))
        If IS
            If I = 1 and GTLGVARGLOBSRC(IS) <= 0
                GTLGVARGLOBSRC(IS) = func AVERIFSRC.VALN(CH2)
            Endif
            Return
        Endif

        IS = find(CHP, PARLOC(1..NBPARLOC))
        If IS
            Return
        Endif

        IS = find(CHP, TVARS(1..NBVARS))
        If IS
            Return
        Endif


        # est-elle déjà repérée ?
        IS = find(CHP, VARNONTROUVE(1..NBVARNONTROUVE))
        If IS = 0 and PTYPE = ""
            ERRMES(1) = "Variable" - CHP - "non déclarée"
                    Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE,
&                        CHAINECPT, NBERREUR, NBWARNING, NLIG, NLIGSAV, 8, TERREUR, SAUVEMODULE,
&                        PNUMERREUR, TITAECRIREW, TABINSTR, NBINSTR, PATCH)
            
            NBVARNONTROUVE +=1
            VARNONTROUVE(NBVARNONTROUVE) = CHP
        Endif
    Endif

Return




# _____________
$SKIPAR : # On va à la prochaine parenthèse ouvrante (on sait qu'existe) et on cherche la suivante appariée

###    WNOMARG = func FNOMARG (CHAINE, instr(1, CHAINE, "(") - 1)

    CHAINE=right$(CHAINE,instr(1,CHAINE,"("))

$SAUTEPAR : # On saute jusqu'à la dernière parenthèse du groupe
    NBPARENTH=1
    CHAINE=right$(CHAINE,2)
    Repeat
    # On saute à la prochaine parenthèse (ouvrante ou fermante) ou à la prochaine quote (simple ou double)
        CHAINE=right$(CHAINE,min(instr(1,CHAINE+"(","("),instr(1,CHAINE+")",")"),
&             instr(1,CHAINE+"'","'"),instr(1,CHAINE+'"','"')))
    
        If instr(1,"'"+'"',left$(CHAINE,1))
    # On saute à la double ou simple quote suivante (à la fin s'il n'y en a pas)
            CHAINE=right$(CHAINE,instr(2,CHAINE+left$(CHAINE,1),left$(CHAINE,1))+1)
        Else
            NBPARENTH+=(left$(CHAINE,1)="(")-(left$(CHAINE,1)=")")
            CHAINE=right$(CHAINE,2)
        Endif
    Until NBPARENTH=0 or CHAINE=""
Return


#___________________________________________
# Analyse des variables locales dans un Call
$ANAVARLOC

    CHAINE=vireblc(right$(CHAINE, instr(1, CHAINE, "Local ")+6), 0)

    If  pat(CHAINE,"Libelle *")
        CHAINE=vireblc(right$(CHAINE,8),0)
        TYPCOUR=2
        Gosub RECHVARLOC
    Elsif pat(CHAINE,"Shortint *")
        CHAINE=vireblc(right$(CHAINE,9),0)
        TYPCOUR=2
        Gosub RECHVARLOC
    Elsif pat(CHAINE,"Integer *")
        CHAINE=vireblc(right$(CHAINE,8),0)
        TYPCOUR=2
        Gosub RECHVARLOC
    Elsif pat(CHAINE,"Decimal *")
        CHAINE=vireblc(right$(CHAINE,8),0)
        TYPCOUR=2
        Gosub RECHVARLOC
    Elsif pat(CHAINE,"Date *")
        CHAINE=vireblc(right$(CHAINE,5),0)
        TYPCOUR=3
        Gosub RECHVARLOC
    Elsif pat(CHAINE,"Char *")
        CHAINE=vireblc(right$(CHAINE,5),0)
        TYPCOUR=1
        Gosub RECHVARLOC
    Elsif pat(CHAINE,"Clbfile *")
        CHAINE=vireblc(right$(CHAINE,8),0)
        TYPCOUR=5
        Gosub RECHVARLOC
    Elsif pat(CHAINE,"Blbfile *")
        CHAINE=vireblc(right$(CHAINE,8),0)
        TYPCOUR=6
        Gosub RECHVARLOC
    Endif : # Sinon, c'était un Local File ou une autre déclaration
Return

#___________________________________________
$RECHVARLOC

    #on ne stocke que les chaînes
#    If TYPCOUR <> 1
#        CHAINE = ""
#    Endif


    While CHAINE <> "" & instr(1, ALPHA, left$(CHAINE, 1)) : # On trouve une variable locale
        IS = len(CHAINE) - len(vireblc(ctrans(CHAINE, ALPHAN, SPACEN), 0))
        VARIA  = vireblc(left$(CHAINE,IS), 2)
        CHAINE = vireblc(right$(CHAINE,IS + 1), 0)

        #chaine
        If TYPCOUR = 1
            IS=find(VARIA, VARLOC(1..NBVARLOC))
            If IS
                TYPVARLOC(IS)=TYPCOUR
            Else
                NBVARLOC+=1
                VARLOC(NBVARLOC)=VARIA
                TYPVARLOC(NBVARLOC)=TYPCOUR
                IS = NBVARLOC
            Endif
            LIBTYPLOC(IS) = ""
            
            While left$(CHAINE,1)="(" : # On empile/dépile les parenthèses
                NBPARENTH=1
                CHAINE=right$(CHAINE,2)
                If LIBTYPLOC(IS) = ""
                    LIBTYPLOC(IS) = left$(CHAINE, min(instr(1,CHAINE+"(","("),instr(1,CHAINE+")",")")) - 1)
                
                    If left$(LIBTYPLOC(IS), len(GPREFIXE)) = GPREFIXE
                        LIBTYPLOC(IS) = right$(LIBTYPLOC(IS), len(GPREFIXE) + 1)
                    Endif
                Endif
      
                Repeat
                    CHAINE = right$(CHAINE, min(instr(1,CHAINE+"(","("),instr(1,CHAINE+")",")")))
                    NBPARENTH+=(left$(CHAINE,1)="(")-(left$(CHAINE,1)=")")
                    CHAINE=right$(CHAINE,2)
                Until NBPARENTH=0 or CHAINE=""
                CHAINE=vireblc(CHAINE,0)
            Wend
            
            LIBTYPLOC(IS) = vireblc(LIBTYPLOC(IS), 4)
            # longueur par défaut d'1 chaîne
            If LIBTYPLOC(IS) = ""
                LIBTYPLOC(IS) = GSANSLG
            Else
                If func AVERIFSRC.VALN(LIBTYPLOC(IS)) = -1
                    If func AVERIFSRC.MTCLEFCOMPLEXE(LIBTYPLOC(IS)) = 0
                        # cbo cbo : rechercher aussi les var loc et glob des src : non on ne peut avoir leur valeur
                        WSTYPE = LIBTYPLOC(IS)
#########################

#########################
                        If left$(WSTYPE, len(GPREFIXE)) = GPREFIXE
                            WSTYPE = right$(WSTYPE, len(GPREFIXE) + 1)
                        Endif
                        # type de données    
                        If find(WSTYPE, TCODTYPATY(1..NBTYPEATY)) = 0

                            # définition de longueur par une variable locale
                            IS2 = find(WSTYPE, VARLOCAUT(1..NBVARLOCAUT))
                            If IS2
                                LIBTYPLOC(IS) = num$(TLGVARLOCAUT(IS2))
#                                X = TLGVARLOCAUT(IS2)
                            Else
                                # définition de longueur par une variable globale (de source)
                                IS2 = find(WSTYPE, GTVARGLOB(1..NBVARGLOB))
                                If IS2
                                    LIBTYPLOC(IS) = num$(GTLGVARGLOB(IS2))
                                Else
                                    # définition de longueur par une variable globale (du dico)
                                    IS2 = find(WSTYPE, GTVARGLOBDIC(1..NBVARGLOBDIC))
                                    If IS2
                                        LIBTYPLOC(IS) = num$(GTLGVARGLOBDIC(IS2))
                                    Endif
                                
                                Endif
                            Endif
                            
                            If IS2 = 0
                            
                                IS2 = find(WSTYPE, PARLOC(1..NBPARLOC))
                                If IS2 = 0

                                    Read [AGB]AGB0 = WSTYPE
                                    If fstat
# on sort tous les cas ou c'est une var locale qui définit la longueur... un peu beaucoup
                                        If PTYPE = ""
                   ERRMES(1) = "La variable locale" - VARIA - " est de longueur non décodée :" - LIBTYPLOC(IS)
                   Call ECRERREUR(PMODULE, GTTRAITEMENTS(NF), ERRMES, TITAECRIRE,
&                    CHAINECPT, NBERREUR, NBWARNING, NLIG, NLIGSAV, 5, TERREUR, SAUVEMODULE,
&                    PNUMERREUR, TITAECRIREW, TABINSTR, NBINSTR, PATCH)
                                        Endif
    
                                        NBVARLOC -= 1
                                    Endif
                                Endif
                            Endif
                        Endif
                    Else
                        NBVARLOC -= 1
                    Endif
                Endif
    
            Endif

        # autres types (différents de chaine)
        Else
            IS = instr(1, VARIA, "(")
            If IS
                VARIA = left$(VARIA, IS - 1)
            Endif
            IS = find(VARIA, VARLOCAUT(1..NBVARLOCAUT))
            If IS
#                TYPVARLOCAUT(IS) = TYPCOUR
            Else
                NBVARLOCAUT += 1
                VARLOCAUT(NBVARLOCAUT) = VARIA
#                TYPVARLOC(NBVARLOC) = TYPCOUR
            Endif

            While left$(CHAINE,1)="(" : # On empile/dépile les parenthèses
                NBPARENTH=1
                CHAINE=right$(CHAINE,2)
      
                Repeat
                    CHAINE = right$(CHAINE, min(instr(1, CHAINE + "(", "("), instr(1, CHAINE + ")", ")")))
                    NBPARENTH += (left$(CHAINE, 1) = "(") - (left$(CHAINE, 1) = ")")
                    CHAINE = right$(CHAINE, 2)
                Until NBPARENTH = 0 or CHAINE = ""
                CHAINE = vireblc(CHAINE, 0)
            Wend
        
        Endif
        
        # Une autre variable suit
        If left$(CHAINE,1) = ","
            CHAINE = vireblc(right$(CHAINE, 2), 0)
        Endif
    Wend
Return

#___________________________________________
# Analyse des variables paramètres de subprog ou funprog
$ANAPARLOC

    If IS = 1
        CHAINE = vireblc(right$(CHAINE, instr(1, CHAINE,"Value ") + 6), 0)
    Else
        CHAINE = vireblc(right$(CHAINE, instr(1, CHAINE,"Variable ") + 9), 0)
    Endif

    If  pat(CHAINE,"Libelle *")
        CHAINE=vireblc(right$(CHAINE,8),0)
        TYPCOUR=2
        Gosub RECHPARLOC
    Elsif pat(CHAINE,"Shortint *")
        CHAINE=vireblc(right$(CHAINE,9),0)
        TYPCOUR=2
        Gosub RECHPARLOC
    Elsif pat(CHAINE,"Integer *")
        CHAINE=vireblc(right$(CHAINE,8),0)
        TYPCOUR=2
        Gosub RECHPARLOC
    Elsif pat(CHAINE,"Decimal *")
        CHAINE=vireblc(right$(CHAINE,8),0)
        TYPCOUR=2
        Gosub RECHPARLOC
    Elsif pat(CHAINE,"Date *")
        CHAINE=vireblc(right$(CHAINE,5),0)
        TYPCOUR=3
        Gosub RECHPARLOC
    Elsif pat(CHAINE,"Char *")
        CHAINE=vireblc(right$(CHAINE,5),0)
        TYPCOUR=1
        Gosub RECHPARLOC
    Elsif pat(CHAINE,"Clbfile *")
        CHAINE=vireblc(right$(CHAINE,8),0)
        TYPCOUR=5
        Gosub RECHPARLOC
    Elsif pat(CHAINE,"Blbfile *")
        CHAINE=vireblc(right$(CHAINE,8),0)
        TYPCOUR=6
        Gosub RECHPARLOC
    Endif : # Sinon, c'était un Local File ou une autre déclaration
Return


#___________________________________________
$RECHPARLOC

    #on ne stocke que les chaînes
#    If TYPCOUR <> 1
#        CHAINE = ""
#    Endif


    While CHAINE <> "" & instr(1, ALPHA, left$(CHAINE, 1)) : # On trouve un paramètre
        IS = len(CHAINE) - len(vireblc(ctrans(CHAINE, ALPHAN, SPACEN), 0))
        VARIA  = vireblc(left$(CHAINE,IS), 2)
        CHAINE = vireblc(right$(CHAINE,IS + 1), 0)

        IS = find(VARIA, PARLOC(1..NBPARLOC))
        If IS = 0
            NBPARLOC += 1
            PARLOC(NBPARLOC) = VARIA
            IS = NBPARLOC
        Endif
        
        While left$(CHAINE,1)="(" : # On empile/dépile les parenthèses
            NBPARENTH=1
            CHAINE=right$(CHAINE,2)
  
            Repeat
                CHAINE = right$(CHAINE, min(instr(1,CHAINE+"(","("),instr(1,CHAINE+")",")")))
                NBPARENTH+=(left$(CHAINE,1)="(")-(left$(CHAINE,1)=")")
                CHAINE=right$(CHAINE,2)
            Until NBPARENTH=0 or CHAINE=""
            CHAINE=vireblc(CHAINE,0)
        Wend
            
        # Une autre variable suit
        If left$(CHAINE, 1) = ","
            CHAINE = vireblc(right$(CHAINE, 2), 0)
        Endif
    Wend
Return


$FINCALL
End

Funprog FNOMARG (PCHAINE, PPOS)
Value Clbfile PCHAINE
Value Integer PPOS

    If PPOS > 0 and PCHAINE <> ""
        End left$(PCHAINE, PPOS)
    Endif
    
End PCHAINE


Funprog CADRECHAINE(PCHAINE, PLONGUEUR)
Value Char PCHAINE
Value Integer PLONGUEUR

Local Integer IB

    IB = PLONGUEUR - len(PCHAINE)
        
    If IB > 0
        End PCHAINE + string$(IB, " ")
    Endif
                    
End PCHAINE
   
#------------------------------------------------------------------------------------------------------------------------#

Subprog ECRERREUR(PMODULE, TRAITEMENT, ERRMES, TITAECRIRE, CHAINE,
&       NBERREUR, NBWARNING, NLIG, NLIGSAV, INDERREUR, TERREUR, SAUVEMODULE, PNUMERREUR,
&       TITAECRIREW, TABINSTR, NBINSTR, PATCH)
Value Integer PMODULE
Variable Char TRAITEMENT
Variable Char ERRMES()
Variable Integer TITAECRIRE
Value Clbfile CHAINE
Variable Integer NBERREUR, NBWARNING
Variable Integer NLIG, NLIGSAV
Value Integer INDERREUR
Variable Integer TERREUR()
Variable Shortint SAUVEMODULE
Value Integer PNUMERREUR
Variable Integer TITAECRIREW
Variable Char TABINSTR()
Variable Integer NBINSTR
Value Char PATCH


Local Integer IC


    If (PNUMERREUR <> 0 and PNUMERREUR <> INDERREUR) or GBTDESACTIVE(GNUMMOUL, INDERREUR)
        End
    Endif

    # ne présenter qu'une fois la même instruction
    If find(CHAINE, TABINSTR(1..NBINSTR))
        End
    Endif
    NBINSTR += 1
    TABINSTR(NBINSTR) = CHAINE
 
     

    Call ECRIRETITRE(TITAECRIRE, TITAECRIREW, INDERREUR, PMODULE, TRAITEMENT, SAUVEMODULE,
&           NBERREUR, NBWARNING, NLIG, NLIGSAV) From AVERIFSRC   
    
    TERREUR(INDERREUR) += 1
    GTRECAPERR(GNUMMOUL, [F:ADC]MODULE, INDERREUR) += 1

        # Ecrire le titre (si) et la première ligne d'erreur
    If GBTWARNING(GNUMMOUL, INDERREUR)
        Wrseq "  *** (Ligne" - num$(NLIG) - "ano" - num$(INDERREUR + 400) + ")" - ERRMES(1) Using [FWR]

        IC = 2
        While IC <= 20
            If ERRMES(IC) <> ""
                Wrseq "  ***" - ERRMES(IC) Using [FWR]
                ERRMES(IC) = ""
            Endif
            IC += 1
        Wend
        
        If CHAINE <> "" and PATCH <> ""
            Wrseq "  -->" - CHAINE  Using [FWR]
        Endif

    Else
        If ERRMES(2) = ""
            Wrseq "  *** (Ligne" - num$(NLIG) - "err" - num$(INDERREUR + 400) + ")" - ERRMES(1) Using [FER]
            IC = 2
        Else
            Wrseq "  *** (Ligne" - num$(NLIG) - "err" - num$(INDERREUR + 400) + ")" Using [FER]
            IC = 1
        Endif

        While IC <= 20
            If ERRMES(IC) <> ""
                Wrseq "  ***" - ERRMES(IC) Using [FER]
                ERRMES(IC) = ""
            Endif
            IC += 1
        Wend
        
        If CHAINE <> "" and PATCH <> ""
            Wrseq "  -->" - CHAINE  Using [FER]
        Endif
    Endif

End
