#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(30)(1..5) , VALEUR(10)
Call S_TAB_CHAR(VALEUR,PARAM,"SELCDA","SELCDA","") From GACTION
End

#######################################################################
# Action SELCDA
#######################################################################
$ACTION
Case ACTION
 When "SEL_TABLE"
  Case TABLE
    When "SELCDA"    : Gosub SELCDA
  Endcase
Endcase
Return

$SELCDA
If clalev([F:CDA])=0  : Local File GACCDENCOD [CDA]  : Endif
If clalev([F:CDAS])=0 : Local File LEGCDASEL  [CDAS] : Endif # Vues
If clalev([F:CDAG])=0 : Local File LEGCDAGFY  [CDAG] : Endif # Vues
If clalev([F:CDAP])=0 : Local File LEGCDAPAR  [CDAP] : Endif # Vues
If clalev([F:CDAY])=0 : Local File LEGCDAYGRP [CDAY] : Endif # Vues
If clalev([F:CDAZ])=0 : Local File LEGCDAZGRP [CDAZ] : Endif # Vues

If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif

Local Char    FCY(GLONFCY)
Local Char    CPY(GLONCPY)
Local Char    LEG(GLONADI)
Local Char    GRP(GLONAGC)

Local Char SAVE_FCY(GLONFCY) : SAVE_FCY=GCURFCY
Local Char SAVE_CPY(GLONCPY) : SAVE_CPY=GSOCIETE
Local Char SAVE_LEG(GLONADI) : SAVE_LEG=GCURLEG
Local Char SAVE_GRP(GLONAGC) : SAVE_GRP=GGRPFCY

#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------

If GFONCTION="ADPVAL" : # Saisie valeurs paramètres. Type de données = PCD
 FCY = [M:ADWP]FCY
 CPY = [M:ADWP]CMP
 If dim([M:ADWP]LEG)>0
  LEG = [M:ADWP]LEG
 Else
  LEG = GDOSLEG
 Endif
Elsif dim([M:RPT]ETAT)>0  #GACTION="AFMTSEL" : # = Sélection paramètres d'édition
 I = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
 If I
  CPY = [M:RPT]VALINT1(I-1)
  Call LEC_CPY(CPY) From CPTLEC
  LEG = [F:CPY]LEG
 Endif
Elsif GFONCTION<>"GEXPOBJ"
 LEG    = PARAM(1)
 GRP    = PARAM(2)
 If GCURFCY  <>""  & [L]FCY="" : [L]FCY = GCURFCY  : Endif
 If GSOCIETE <>""  & [L]CPY="" : [L]CPY = GSOCIETE : Endif
 If GCURLEG  <>""  & [L]LEG="" : [L]LEG = GCURLEG  : Endif
 If GGRPFCY  <>""  & [L]GRP="" : [L]GRP = GGRPFCY  : Endif
Endif

# Initialisations diverses FCY/CPY/LEG & GCURFCY/GSOCIETE/GCURLEG
If [L]FCY<>""
 Call LEC_FCY([L]FCY) From CPTLEC
 Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
 [L]CPY = [F:CPY]CPY : GSOCIETE = [L]CPY
 [L]LEG = [F:CPY]LEG : GCURLEG  = [L]LEG
 [L]GRP = ""
Elsif [L]CPY<>""
 Call LEC_CPY([L]CPY) From CPTLEC
 [L]CPY = [F:CPY]CPY : GSOCIETE = [L]CPY
 [L]LEG = [F:CPY]LEG : GCURLEG  = [L]LEG
 [L]GRP = ""
Endif

# Si groupe de société (non société juridique) alors GCURLEG et LEG à vide pour que la sélection présente toutes les données
If [L]CPY<>""
 Call LEC_CPY([L]CPY) From CPTLEC
 If [F:CPY]CPYLEGFLG<>2
  [L]LEG="" : GCURLEG="" : [L]GRP = [L]CPY : [L]CPY="" : [L]FCY=""
 Endif
Endif

#--------------------------------------------------------------------------------------------------
# Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------

Gosub OUVRE_LISTE From WOCDA

For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I) = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I

NBCOL  = NBSEL
SIZCOL = 240
SIZLIG = 100
TIT(0) = mess(12,123,1)  # Choix
Call TITOBJ("CDA","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START  = "[F:CDA]COD"
ORDRE  = "[F:CDA]COD;[F:CDA]LEG"
OBJET  = ""

#--------------------------------------------------------------------------------------------------
# Critères pour la sélection standard
#--------------------------------------------------------------------------------------------------

## Critères de sélection
## Le link fait des liaisons "externes gauches"
## Toute la subtilité de la chose est de mettre des fonctions qui
## ne sont pas transmises à la base de données : len() , num$()
## sinon celle-ci ne renvoie rien du tout

CRITERE(1)  = '[F:CDA]ENAFLG=2'

If [L]LEG<>""
 CRITERE(1) -= '& ([F:CDA]LEG="'+[L]LEG+'" | [F:CDA]LEG="")'
Endif
If [L]FCY<>""
 CRITERE(1) -= '& ([F:CDA]GFY="" | ([F:CDA]GFY<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
Elsif [L]CPY<>""
 CRITERE(1) -= '& ([F:CDA]GFY="" | ([F:CDA]GFY<>"" & [F:CDAG]LEGCPY="'+[L]CPY+'"))'
Elsif [L]GRP<>""
 If [L]LEG<>""
  CRITERE(1) -= '& ([F:CDA]GFY="" | ([F:CDA]GFY<>"" & [F:CDAY]GRPORI="'+[L]GRP+'"))'
 Else
  CRITERE(1) -= '& ([F:CDA]GFY="" | ([F:CDA]GFY<>"" & [F:CDAZ]GRPORI="'+[L]GRP+'"))'
 Endif
Endif
CRITERE(1) -= '& (GUSRACS=2 | [F:CDA]ACS="" | num$([F:ACC]CONSUL)="2")'
If dim(SELCAR)>0 & SELCAR<>0
 CRITERE(1) -= '& left$([F:CDA]CDA,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

ICRITERE = 2
Call FILROLE("CDA",FILROLE) From SUBARL
If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

#--------------------------------------------------------------------------------------------------
# Appel à la vue
#--------------------------------------------------------------------------------------------------
If [L]LEG<>""
 # Vues via LEG/FCY
 If [L]FCY<>""
  Link [CDA] With [AXX]AXX0    = "GACCDENCOD";"DESTRA";GLANGUE;[F:CDA]COD;[F:CDA]LEG
&              , [ACC]CODACC   =  GUSER;[F:CDA]ACS
&              , [FGR]FGR1     =  [L]FCY;[F:CDA]GFY
&              , [CDAS]CDA0   ~=  [F:CDA]COD;[F:CDA]LEG;[L]LEG
&              , [CDAG]CDA0    =  [F:CDA]COD;[F:CDA]LEG;[F:CDA]GFY;[L]CPY
& As [LNC]
 Elsif [L]CPY<>""
  # Vues via LEG/CPY
  Link [CDA] With [AXX]AXX0    = "GACCDENCOD";"DESTRA";GLANGUE;[F:CDA]COD;[F:CDA]LEG
&              , [ACC]CODACC   =  GUSER;[F:CDA]ACS
&              , [CDAS]CDA0   ~=  [F:CDA]COD;[F:CDA]LEG;[L]LEG
&              , [CDAG]CDA0    =  [F:CDA]COD;[F:CDA]LEG;[F:CDA]GFY;[L]CPY
& As [LNC]
 Elsif [L]GRP<>""
  # Vues via LEG/GRP
  Link [CDA] With [AXX]AXX0    = "GACCDENCOD";"DESTRA";GLANGUE;[F:CDA]COD;[F:CDA]LEG
&              , [ACC]CODACC   =  GUSER;[F:CDA]ACS
&              , [CDAS]CDA0   ~=  [F:CDA]COD;[F:CDA]LEG;[L]LEG
&              , [CDAY]CDAY0  ~=  [L]GRP;[F:CDA]COD;[F:CDA]GFY;[F:CDA]LEG
& As [LNC]
 Else
  # Vues via LEG/No FCY, No CPY, No GRP
  Link [CDA] With [AXX]AXX0    = "GACCDENCOD";"DESTRA";GLANGUE;[F:CDA]COD;[F:CDA]LEG
&              , [ACC]CODACC   =  GUSER;[F:CDA]ACS
&              , [CDAS]CDA0   ~=  [F:CDA]COD;[F:CDA]LEG;[L]LEG
& As [LNC]
 Endif
Else
 If [L]FCY<>""
   # Vues via No LEG but FCY
  Link [CDA] With [AXX]AXX0    = "GACCDENCOD";"DESTRA";GLANGUE;[F:CDA]COD;[F:CDA]LEG
&              , [ACC]CODACC   =  GUSER;[F:CDA]ACS
&              , [FGR]FGR1     =  [L]FCY;[F:CDA]GFY
&              , [CDAP]CDA0   ~=  [F:CDA]COD;[F:CDA]LEG
&              , [CDAG]CDA0    =  [F:CDA]COD;[F:CDA]LEG;[F:CDA]GFY;[L]CPY
& As [LNC]
 Elsif [L]CPY<>""
  # Vues via No LEG but CPY
  Link [CDA] With [AXX]AXX0    = "GACCDENCOD";"DESTRA";GLANGUE;[F:CDA]COD;[F:CDA]LEG
&              , [ACC]CODACC   =  GUSER;[F:CDA]ACS
&              , [CDAP]CDA0   ~=  [F:CDA]COD;[F:CDA]LEG
&              , [CDAG]CDA0    =  [F:CDA]COD;[F:CDA]LEG;[F:CDA]GFY;[L]CPY
& As [LNC]
 Elsif [L]GRP<>""
  # Vues via No LEG but GRP
  Link [CDA] With [AXX]AXX0    = "GACCDENCOD";"DESTRA";GLANGUE;[F:CDA]COD;[F:CDA]LEG
&              , [ACC]CODACC   =  GUSER;[F:CDA]ACS
&              , [CDAP]CDA0   ~=  [F:CDA]COD;[F:CDA]LEG
&              , [CDAZ]CDAZ0  ~=  [L]GRP;[F:CDA]COD;[F:CDA]GFY;[F:CDA]LEG
& As [LNC]
 Else
  # Vues via No LEG and No FCY/CPY/GRP
  Link [CDA] With [AXX]AXX0    = "GACCDENCOD";"DESTRA";GLANGUE;[F:CDA]COD;[F:CDA]LEG
&              , [ACC]CODACC   =  GUSER;[F:CDA]ACS
&              , [CDAP]CDA0   ~=  [F:CDA]COD;[F:CDA]LEG
& As [LNC]
 Endif
Endif
Default File [LNC]
DEFPAG = 1

GCURFCY  = SAVE_FCY
GSOCIETE = SAVE_CPY
GCURLEG  = SAVE_LEG
GGRPFCY  = SAVE_GRP
Return

