#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
# Handling of FUP mask : list of BPs to be reminded
##########################################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
GPROG    = "TRTCFUP"
GTYPPROG = 4
GWINDOW  = "DFUP"
GWINCRIT = "CRITFUP"
Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,GPROG,GWINCRIT,GTYPPROG,"") From GTRAITE
End

######################################################################################

$ACTION
Case GACTION
 When"VALFUP"
  Case ACTION
   When "INIT"        : Gosub INIT_VALFUP
   When "FIN"         : Gosub FIN_VALFUP
  Endcase
 When Default
  Case ACTION
   When "APRES_MODIF" : Gosub APRES_MODIF
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub LECTURE
   When "TERMINE"     : Gosub FIN
   When "SETBOUT"     : Gosub SETBOUT
   When "ENR"         : Gosub ENR # clic sur Enregistrer
   When "ABA"         : Gosub ABA # clic sur Abandon
   When "BOUTON"      : Gosub BOUTON
   When "FIN"         : Gosub DEVERROU
   When "EDI"         : Gosub EDITION
   When "LIS"         : Gosub PRINT_FUPSIM2 # 25.09.2012 mamay SAM-82431
 Endcase
Endcase

# Enable File/Print menu
Enable GSTAEDI
Enable GSTALIS # 25.09.2012 mamay SAM-82310

Gosub ENABLE_DISABLE_BUTTONS
Return

$ENABLE_DISABLE_BUTTONS
# activation/désactivation des boutons Validation et Réimpression
If [M:CFP0]VALIDE=2
 Disable GSTABOU+1
 If clalev([F:FUP])=0  : Local File FUP        [FUP]  : Endif
 Filter [FUP] Where NUMEDT=[M:CFP0]QURNUM
 If rowcount([FUP])=0
  Disable GSTABOU+2
 Else
  Enable GSTABOU+2
 Endif
 Filter [FUP]
Elsif dim(GBIDI1)>0 and GBIDI1=1
 If clalev([F:TFP2])=0 : Local File TMPFUP2    [TFP2] : Endif
 Filter [TFP2] Where NUMREQ=[M:CFP0]QURNUM and SEL=2
 If rowcount([TFP2])=0
  Disable GSTABOU+1
 Else
  Enable GSTABOU+1
 Endif
 Filter [TFP2]
Endif
GBIDI1 = 0
Return

$BOUTON
Case BOUT
 When "R" : # Return
  FIN=1
 When "V" : # Validation
  Gosub VALIDATION From TRTFUPVAL
 When "I" : # Reprint
  Gosub IMPRESSION From TRTFUPVAL
 When Default
Endcase
Return

######################################################################################
$INIT_VALFUP
Local Integer FUPCRM
Local Char VALPAR(1)

Call PARAM("","FUPCRM",VALPAR) From ADOVAL
FUPCRM = val(VALPAR)

# Do nothing if Customer Relation module missing
If FUPCRM<>2 or GMODU(13)<>2 : FIN=1 : Endif
Return

$FIN_VALFUP
SAI=1 : FIN = 1 : GOK = 1
Return

######################################################################################
$OUVRE_TABLES
Local Char VALPAR(1)

Call PARAM("","FUPCRM",VALPAR) From ADOVAL
FUPCRM = val(VALPAR)

If clalev([F:TFP0])=0 : Local File TMPFUP0    [TFP0] : Endif
If clalev([F:TFP1])=0 : Local File TMPFUP1    [TFP1] : Endif
If clalev([F:TFP2])=0 : Local File TMPFUP2    [TFP2] : Endif
If clalev([F:TFP3])=0 : Local File TMPFUP1    [TFP3] : Endif
If clalev([F:TFP4])=0 : Local File TMPFUP2    [TFP4] : Endif
If clalev([F:TCF])=0  : Local File TMPFUPCMT  [TCF]  : Endif
If clalev([F:FUP])=0  : Local File FUP        [FUP]  : Endif
If clalev([F:FGP])=0  : Local File FUPGRP     [FGP]  : Endif

If clalev([F:HIM])=0  : Local File HISTOOMM   [HIM]  : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif

If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:BPC])=0  : Local File BPCUSTOMER [BPC]  : Endif
If clalev([F:BPR])=0  : Local File BPARTNER   [BPR]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:FPT])=0  : Local File FUPTXT     [FPT]  : Endif
If clalev([F:ACV])=0  : Local File ACTIV      [ACV]  : Endif
If FUPCRM=2 and GMODU(13)=2 # générer les tâches CRM si présence module "Action commerciale"
 If clalev([F:TSK])=0 : Local File TASK       [TSK]  : Endif
 If clalev([F:HD6])=0 : Local File HD6CLOB    [HD6]  : Endif
Endif
If clalev([F:TCA])=0  : Local File TABCOUAFF  [TCA]  : Endif # Table affectation compteurs
If clalev([F:REP])=0  : Local File SALESREP   [REP]  : Endif
If clalev([F:AUS])=0  : Local File AUTILIS    [AUS]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV    [ADI]  : Endif
If clalev([F:AMZ])=0  : Local File AMSKZON    [AMZ]  : Endif
If clalev([F:BPA])=0  : Local File BPADDRESS  [BPA]  : Endif
Return

$OUVRE
Gosub OUVRE_TABLES

Global Integer CMTLEN
Read [AMZ]CODE="FUP";"CMT"
CMTLEN=[AMZ]LONG

# code pour historisations des échéances
If func AFNC.ACTIV("HDU")
 If clalev ([F:HDU])=0  : Local File HISTODUD   [HDU] : Endif
Endif

Local Char    DEVORG(GLONCUR), DEVSOC(GLONCUR), VALPAR(200)
Local Char    ICONE1(GLONICO), ICONE2(GLONICO), ICONE3(GLONICO)
Local Integer SELMOD, MAXBPC, TYPCOURS, STAT
Local Decimal MTDES, AMTDEP, NUMEDT
Local Decimal SOLRELT, SOLNONRELT, AGIOS, TOTFUPT
Local Char ABR(4) # Used by FSTA() calls

Global Char DEVDES(GLONCUR)

ICONE1= ""    # No open item selected
ICONE2= "251" # Some open items selected
ICONE3= "252" # All open items selected

MAXBPC = dim([M:FUP]BPC)

Filter [TFP1] Where NUMREQ=[M:CFP0]QURNUM and BPC<>""
Raz [M:FUP]
For N=0 To dim([M:FUP]UPD)-1
 [M:FUP]UPD(N)=1
Next

# Type de cours (tronc commun TC)
Call PARAM("","CHGTYP",VALPAR) From ADOVAL
TYPCOURS = val(VALPAR)
Return

$FIN
If clalev([F:TFP2])=0 : Local File TMPFUP2    [TFP2] : Endif
SAI=1 # permet de retourner sur la fenêtre de saisie des critères
Return

# 58722
$VERROU
SYMBOLE = "FUP"+[M:CFP0]QURNUM
Lock =SYMBOLE With lockwait=0
If fstat
 VERROU = 0
Else
 VERROU = 1
Endif
Return

$DEVERROU
If VERROU
 Unlock =SYMBOLE
 VERROU = 0
Endif
Return

$APRES_MODIF
If zoncou<>"CMT2"
 [M:FUP]UPD(nolign-1)=2
 Affzo [M:FUP]CMT, CMT2
Endif
# 63033
If GCONSULT
 Call ERREUR(mess(9,123,1)) From GESECRAN : # Modification not possible
 mkstat = 2 : Return
Elsif !VERROU
 Call ERREUR(mess(10,100,1)) From GESECRAN : # Change In Progress on another workstation
 mkstat = 2 : Return
Endif
Return

$UPD_FUPTOTAMT
For [TFP1]TFP1(2) Where NUMREQ=[M:CFP0]QURNUM
 Local Decimal SOLRELT
 Raz SOLRELT # Variable totalisation par tiers
 # Parcours des échéances du tiers
 For [TFP1]TFP1
  If [F:BPC]BPCNUM<>[F:TFP1]BPC : Read [F:BPC]BPC0=[F:TFP1]BPC : Endif
  Link [TFP2] With [DUD]DUD8=[TFP2]NUMDUD As [LNK2]
&  Where [TFP2]NUMREQ=[M:CFP0]QURNUM and [TFP2]BPC=[TFP1]BPC and [DUD]CPY=[TFP1]CPY and [DUD]FCY=[TFP1]FCY
  For [LNK2] # boucle sur toutes les échéances correspondant au BPC/CPY/FCY en cours
   MTDES = ([F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC)*[F:DUD]SNS
   # Remplissage des colonnes "Solde relançable" et "Solde non relançable" + Bloc Totaux, Ligne ECHEANCES
   If [TFP2]SEL=2 : SOLRELT += MTDES : Endif
  Next # [LNK2]
 Next # fin [LNK0]
 Update [TFP1] Where NUMREQ=[M:CFP0]QURNUM and BPC=[F:BPC]BPCNUM With FUPTOTAMT=[L]SOLRELT, UPDUSR=GUSER, UPDDAT=date$
 If fstat : Break : Endif
 If UPD=0 and adxuprec<>0 : UPD=1 : Endif
Next # TFP1
Return

######################################################################################
# saving user-changeable values
# update only if the line was modified
######################################################################################
$ROLL_TR1
Rollback
Call TEMPOFF From GESECRAN
Call ROLL From GLOCK
If GROLL : Return : Else : Goto ENR : Endif

$ENR
Local Integer UPD

# Saving
Call TEMPON(mess(87,116,1)) From GESECRAN
Trbegin [TFP1], [TFP2]
 For N=0 To [M:FUP]NBLIG
  Raz UPD
  If [M:FUP]UPD(N)=2
   Update [TFP1] Where [F:TFP1]NUMREQ=[M:CFP0]QURNUM and BPC=[M:FUP]BPC(N) With [F:TFP1]SEL=[M:FUP]SEL(N), UPDUSR=GUSER, UPDDAT=date$
   If fstat=1
    GOK = -1 : GLOCK = "$TMPFUP1"-num$([M:CFP0]QURNUM)-[M:FUP]BPC(N) : Break
   Elsif fstat
    ABR = "TFP1" : GOK = 0 : Break
   Else
    If UPD=0 and adxuprec<>0 : UPD=1 : Endif
   Endif

   If [M:FUP]SEL(N)<>2 # Sélection nulle ou sélection totale
    Update [TFP2] Where [F:TFP2]NUMREQ=[M:CFP0]QURNUM and BPC=[M:FUP]BPC(N) With [F:TFP2]SEL=[M:FUP]SEL(N)
    If fstat=1
     GOK = -1 : GLOCK = "$TMPFUP2"-num$([M:CFP0]QURNUM)-[M:FUP]BPC(N) : Break
    Elsif fstat
     ABR = "TFP2" : GOK = 0 : Break
    Endif
   Endif
   [M:FUP]UPD(N)=1
  Endif
 Next # N

 If GOK=-1
  Goto ROLL_TR1
 Elsif GOK=0
  Call FSTA(ABR) From GLOCK : Rollback
 Endif

 $ENR2
 Gosub UPD_FUPTOTAMT
 If UPD
  Update [TFP0] Where QURNUM=[M:CFP0]QURNUM With UPDUSR=GUSER, UPDDAT=date$
  If fstat=1
   GOK = -1 : GLOCK = "$TMPFUP0"-num$([M:CFP0]QURNUM)
  Elsif fstat
   ABR = "TFP0" : GOK = 0 : Goto $ENR2
  Endif
 Endif
Commit
Gosub LECTURE
Call TEMPOFF From GESECRAN
Return

######################################################################################

$ABA
# Loading...
Call TEMPON(mess(31,9139,1)) From GESECRAN
For N=0 To dim([M:FUP]UPD)-1
 [M:FUP]UPD(N)=1
Next
Gosub LECTURE
Call TEMPOFF From GESECRAN
Return

######################################################################################

$SETBOUT
If find(2,[M:FUP]UPD)=0 # nothing to save
 REP=""
 Call VIREBOUT(CHBOU,"EA") From GOBJET
 If instr(1,CHMEN,"V")=0 : CHMEN+="V" : Endif
Elsif find(2,[M:FUP]UPD)<>0 # there's something to save
 REP="M"
 Call VIREBOUT(CHMEN,"V") From GOBJET
 If instr(1,CHBOU,"E")=0 : CHBOU+="E" : Endif
 If instr(1,CHBOU,"A")=0 : CHBOU+="A" : Endif
Endif

# if the current campaign already validated, disable "Save", "Cancel" and "Validation" buttons
Read [TFP0]TFP0=[M:CFP0]QURNUM
If [TFP0]VALIDE=2
 Call VIREBOUT(CHBOU,"E") From GOBJET
 Call VIREBOUT(CHBOU,"A") From GOBJET
 Call VIREBOUT(CHMEN,"V") From GOBJET
Else
 # disable Reprint button
 Call VIREBOUT(CHMEN,"I") From GOBJET
Endif

# enable/disable Validation button
Filter [TFP2] Where NUMREQ=[M:CFP0]QURNUM and SEL=2
If rowcount([TFP2])=0
 Call VIREBOUT(CHMEN,"V") From GOBJET
Else
 If instr(1,CHMEN,"V")=0 : CHMEN+="V" : Endif
Endif
Filter [TFP2]

If !VERROU
 IMGFLG(3) = 1 : # display padlock
Else
 IMGFLG(3) = 0
Endif
Return

######################################################################################

$PREMIER
Read [TFP1] First
If fstat<>0
 #  Pas d'enregistrement courant
 Call ERREUR(mess(154,115,1)) From GESECRAN
 Return
Endif
If [M:FUP]BPCDEB=[TFP1]BPC
 # Start/End of file
 Call ERREUR(mess(11,100,1)) From GESECRAN
Else
 [M:FUP]BPCDEB=[TFP1]BPC
 Gosub LECTURE
Endif
Return

######################################################################################

$PRECEDENT
Read [TFP1]<[M:FUP]BPC(0)
N=1
If fstat>2
 # Start/End of file
 Call ERREUR(mess(11,100,1)) From GESECRAN
Else
 While N<MAXBPC and fstat<=2
  Read [TFP1] Prev
  N+=1
 Wend
 [M:FUP]BPCDEB=[TFP1]BPC
 Gosub LECTURE
Endif
Return

######################################################################################

$SUIVANT
If [M:FUP]NBLIG<1
 Return
Endif
Read [TFP1]>[M:FUP]BPC([M:FUP]NBLIG-1)
If fstat>2
 # Start/End of file
 Call ERREUR(mess(11,100,1)) From GESECRAN
Else
 [M:FUP]BPCDEB=[TFP1]BPC
 Gosub LECTURE
Endif
Return

######################################################################################

$DERNIER
N=0
Read [TFP1] Last
Repeat
 Read [TFP1] Prev
 N+=1
Until N>=MAXBPC-1 or fstat>2
If [M:FUP]BPCDEB=[TFP1]BPC
 # Start/End of file
 Call ERREUR(mess(11,100,1)) From GESECRAN
Else
 [M:FUP]BPCDEB=[TFP1]BPC
 Gosub LECTURE
Endif
Return

######################################################################################

# computes number of emails and letters to be created for the current campaign
$MAJ_NBM_NBL
Raz [M:FUP]NBL, NBM

Filter [TFP2]

Local Integer FUPCUR, FUPFCY, INC, FUPMOD, K
Local Char CUR(GLONCUR)

# 1 = Letter, 2 = Email
For [L]FUPMOD=1 To 2
 # loop on each BP
 For [TFP2]TFP3(1) Where [TFP2]NUMREQ=[M:CFP0]QURNUM and [TFP2]FUPMOD=[L]FUPMOD and [TFP2]SEL=2
  INC = 0
  If [F:BPC]BPCNUM<>[F:TFP2]BPC : Read [BPC]BPC0=[F:TFP2]BPC : Endif
  If [F:FGP]GRP<>[F:BPC]GRP : Read [FGP]FGP0=[F:BPC]GRP : Endif

  # close and reopen table to avoid a crash with Filter/Link and "Order By Key" statements inside "For" loops
  # DO NOT REMOVE THESE LINES !
  Close Local File [TFP4]
  If clalev([F:TFP4])=0 : Local File TMPFUP2 [TFP4] : Endif

  If fstat=0
   # relance par devise de transaction
   If [F:FGP]FUPCUR=2 : [L]FUPCUR=1 : Else : [L]FUPCUR=0 : Endif
   # Reminder by site
   If [F:FGP]FUPFCY=2 : [L]FUPFCY=1 : Else : [L]FUPFCY=0 : Endif

   If [BPC]FUPTYP=2 # By invoice
    Filter [TFP4] Where [TFP4]NUMREQ=[M:CFP0]QURNUM and [TFP4]BPC=[TFP2]BPC and [TFP4]FUPMOD=[TFP2]FUPMOD and [TFP4]SEL=2
    INC = rowcount([TFP4])
    Filter [TFP4]

   Elsif [BPC]FUPTYP=3 # Global
    If [L]FUPCUR & [L]FUPFCY
     # relance par site et par devise de transaction
     Link [TFP4] With [DUD]DUD8=[TFP4]NUMDUD As [LNK] Where [TFP4]NUMREQ=[M:CFP0]QURNUM and [TFP4]BPC=[TFP2]BPC
&     and [TFP4]FUPMOD=[TFP2]FUPMOD and [TFP4]SEL=2
&     Order By Key CLE=[DUD]CUR;[DUD]FCY
     For [LNK]CLE(2)
      INC+=1
     Next
    Elsif [L]FUPCUR
     # relance par devise de transaction
     Link [TFP4] With [DUD]DUD8=[TFP4]NUMDUD As [LNK] Where [TFP4]NUMREQ=[M:CFP0]QURNUM and [TFP4]BPC=[TFP2]BPC
&     and [TFP4]FUPMOD=[TFP2]FUPMOD and [TFP4]SEL=2
&     Order By Key CLE=[DUD]CUR
     For [LNK]CLE(1)
      INC+=1
     Next
    Elsif [L]FUPFCY
     # relance par site
     Filter [TFP4] Where [TFP4]NUMREQ=[M:CFP0]QURNUM and [TFP4]BPC=[TFP2]BPC and [TFP4]FUPMOD=[TFP2]FUPMOD and [TFP4]SEL=2
      For [TFP4]TFP5(2)
       INC+=1
      Next
     Filter [TFP4]
    Else
     INC+=1
    Endif

   Elsif [BPC]FUPTYP=4 # Global by level
# Les échéances sont regroupées par niveau identique, et le client reçoit au plus une lettre de relance par niveau.
# Chaque lettre de relance contient l'ensemble des échéances échues pour un niveau donné.
# une lettre PAR NIVEAU
    If [L]FUPCUR & [L]FUPFCY
     # relance par site et par devise de transaction
     # reminder by site and by currency
     Link [TFP4] With [DUD]DUD8=[TFP4]NUMDUD As [LNK] Where [TFP4]NUMREQ=[M:CFP0]QURNUM and [TFP4]BPC=[TFP2]BPC
&     and [TFP4]FUPMOD=[TFP2]FUPMOD and [TFP4]SEL=2
&     Order By Key CLE=[DUD]CUR;[DUD]FCY;[DUD]LEVFUP
     For [LNK]CLE(3)
      INC+=1
     Next
    Elsif [L]FUPCUR
     Link [TFP4] With [DUD]DUD8=[TFP4]NUMDUD As [LNK] Where [TFP4]NUMREQ=[M:CFP0]QURNUM and [TFP4]BPC=[TFP2]BPC
&     and [TFP4]FUPMOD=[TFP2]FUPMOD and [TFP4]SEL=2
&     Order By Key CLE=[DUD]CUR;[DUD]LEVFUP
     For [LNK]CLE(2)
      INC+=1
     Next
    Elsif [L]FUPFCY
     Filter [TFP4] Where [TFP4]NUMREQ=[M:CFP0]QURNUM and [TFP4]BPC=[TFP2]BPC and [TFP4]FUPMOD=[TFP2]FUPMOD and
& [TFP4]SEL=2 Order By Key CLE=[TFP4]LEVFUP;[TFP4]FCY
      For [TFP4]CLE(2)
       INC+=1
      Next
     Filter [TFP4]
    Else
     For [TFP4]TFP6(2) Where [TFP4]NUMREQ=[M:CFP0]QURNUM and [TFP4]BPC=[TFP2]BPC and [TFP4]FUPMOD=[TFP2]FUPMOD and [TFP4]SEL=2
      INC+=1
     Next
    Endif

   Elsif [BPC]FUPTYP=5 # Global by delay
# Les échéances sont regroupées par plages de retard (ex : toutes les échéances qui sont échues depuis 30 à 60 jours)
# Le client reçoit au plus une lettre de relance par plage de retard.
# Chaque lettre de relance contient l'ensemble des échéances échues pour une plage de retard donnée. Les valeurs de ces délais sont
# modifiables par l'intermédiaire de paramètres.
# Ainsi, il est tout à fait possible, pour un client donné de passer d'une lettre de relance de niveau 1 à une lettre de relance de niveau 3
# si le nombre de jours d'écart le justifie.
    For K=1 To dim([F:FGP]SEUILS)
     If K<dim([F:FGP]SEUILS) and [F:FGP]SEUILS(K) <> 0 : # X3-38447
      # the lateness is between the values of K-1 threshold and K threshold
      Link [TFP4] With [DUD]DUD8=[TFP4]NUMDUD As [LNK4]
&      Where [TFP4]NUMREQ=[M:CFP0]QURNUM and [TFP4]BPC=[TFP2]BPC and [TFP4]FUPMOD=[TFP2]FUPMOD and [TFP4]SEL=2
&       and [M:CFP1]REFDAT-[DUD]DUDDAT>=[F:FGP]SEUILS(K-1) and [M:CFP1]REFDAT-[DUD]DUDDAT<[F:FGP]SEUILS(K)
#&       and [M:CFP1]REFDAT-[DUD]DUDDAT>[F:FGP]SEUILS(K-1) and [M:CFP1]REFDAT-[DUD]DUDDAT<[TFP2]BPC(K) : # X3-38447
      INC += (rowcount([LNK4])>0) # only one letter for each threshold
     Else
      If [F:FGP]SEUILS(K-1) <> 0 : # X3-38447
       # the lateness is greater than the last threshold
       Link [TFP4] With [DUD]DUD8=[TFP4]NUMDUD As [LNK4]
&       Where [TFP4]NUMREQ=[M:CFP0]QURNUM and [TFP4]BPC=[TFP2]BPC and [TFP4]FUPMOD=[TFP2]FUPMOD and [TFP4]SEL=2
&        and [M:CFP1]REFDAT-[DUD]DUDDAT>=[F:FGP]SEUILS(K-1)
       INC += (rowcount([LNK4])>0) # only one letter for each threshold
      Endif
     Endif
    Next
   Endif

   If [L]FUPMOD=1
    [M:FUP]NBL += INC*[FGP]NBRCOP
   Elsif [L]FUPMOD=2
    [M:FUP]NBM += INC*[FGP]NBRCOP
   Endif
  Endif # fstat
 Next # TFP2
Next # [L]FUPMOD

Affzo [M:FUP]NBL, NBM
Return

######################################################################################

$LECTURE
Gosub VERROU
# backup [M:FUP]BPCDEB (used for pagination) and nolign before erasing the mask
Local Integer NOL
BPCTMP=[M:FUP]BPCDEB
NOL = [M:FUP]NOLIG
Raz [M:FUP]
[M:FUP]NOLIG = NOL
[M:FUP]BPCDEB=BPCTMP

If [M:FUP]BPCDEB=""
 Read [TFP1] First
 [M:FUP]BPCDEB=[TFP1]BPC
Endif

[M:FUP]QURNUM=[M:CFP0]QURNUM

# Si la relance est faite pour plusieurs sociétés, alors les totalisations sont exprimées en devise zone commune (GCURSHR)
# Si la relance est faite pour une seule société, alors les totalisations sont exprimées en devise société
If [M:CFP1]CPY=""
 [M:FUP]CUR = GCURSHR
Else
 If [F:CPY]CPY<>[M:CFP1]CPY : Read [CPY]CPY0=[M:CFP1]CPY : Endif
 [M:FUP]CUR = [F:CPY]ACCCUR
Endif

nolign=0 : N=0

Raz [M:FUP]TOTAGIOS, [M:FUP]TOTFUP1, [M:FUP]TOTFUP2, [M:FUP]ECH1, [M:FUP]ECH2

Gosub MAJ_NBM_NBL

[M:FUP]SUPTOT = [V]CST_AFALSE
Local Integer OK
[L]OK = 1
GPOINT = "LECTURE" : Gosub ENTREE From EXEFNC
If [L]OK = 0 Then
    [M:FUP]SUPTOT = [V]CST_ATRUE
Endif

# Campaign number + BP
For [TFP3]TFP1(2) Where NUMREQ=[M:CFP0]QURNUM

 Raz SOLRELT, SOLNONRELT, AGIOS, TOTFUPT : # Variables totalisation par tiers

 # Parcours des échéances du tiers
 For [TFP3]TFP1
  [M:FUP]TOT(N) = 1 # ligne normale
  [M:FUP]SEL(N) = [F:TFP3]SEL
  # sauvegarde de la valeur de la sélection
  [M:FUP]SELCOP(N) = [F:TFP3]SEL
  [M:FUP]BPC(N) = [F:TFP3]BPC

  If [F:BPC]BPCNUM<>[M:FUP]BPC(N) : Read [F:BPC]BPC0=[M:FUP]BPC(N) : Endif

  [M:FUP]BPCNAM(N) = [F:BPC]BPCNAM
  [M:FUP]CPY(N) = [F:TFP3]CPY
  [M:FUP]FCY(N) = [F:TFP3]FCY
  [M:FUP]CMT(N) = [F:TFP3]CMT
  If len([F:TFP3]CMT)>CMTLEN
   [M:FUP]CMT(N) = left$([M:FUP]CMT(N),CMTLEN-3)+"..."
  Endif
  [M:FUP]FUPTYP(N) = [F:BPC]FUPTYP

  Link [TFP2] With [DUD]DUD8=[TFP2]NUMDUD As [LNK2]
&  Where [TFP2]NUMREQ=[M:CFP0]QURNUM and [TFP2]BPC=[TFP3]BPC and [DUD]CPY=[TFP3]CPY and [DUD]FCY=[TFP3]FCY

  For [LNK2] # loop on all open items matching the current BPC/CPY/FCY

   MTDES = ([F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC)*[F:DUD]SNS

   # Remplissage des colonnes "Solde relançable" et "Solde non relançable" + Bloc Totaux, Ligne ECHEANCES
   If [TFP2]SEL=2
    [M:FUP]SOLREL(N) += MTDES
    SOLRELT += MTDES
    [M:FUP]ECH2 += MTDES
   Else
    [M:FUP]SOLNONREL(N) += MTDES
    SOLNONRELT += MTDES
    [M:FUP]ECH1 += MTDES
   Endif

   # Remplissage de la colonne "Solde total échu" = "Solde relançable" +  "Solde non relançable"
   # bug 58502
   [M:FUP]CLEFUPTOT(N) += MTDES

   ## Calcul des montants d'escompte/agio : c'est la somme des esc/agios de toutes les échéances restant à règler
   ## (TMP* et PAY* déduits) du tiers pour la société et le site et répondant aux critères sélectionnés.
   ## Ce montant est exprimé en devise société si la campagne de relance porte sur une seule société. Il est exprimé
   ## en devise GCURSHR si la campagne de relances est lancée sur plusieurs sociétés (même raisonnement que le solde
   ## relançable et le solde non relançable)
   # 71932
   If [M:CFP2]AGIO=2
    # les agios sont stockés en positif dans TMPFUP2
    [L]AMTDEP = [F:TFP2]AMTDEP

    # Remplissage de la colonne "Agio" + Bloc Totaux, Ligne AGIOS
    # Le montant des agios est négatif. Il doit être positif et ainsi il s’ajoutera au solde relançable
    # pour donner le total relançable.
    [M:FUP]AGIOS(N) += AMTDEP
    [L]AGIOS = [M:FUP]AGIOS(N)
   Else
    [L]AMTDEP = 0
   Endif

   # Remplissage de la colonne "Total Relançable" + Bloc Totaux, Ligne TOTAL  (cela dépend de la 1ère colonne : Sélection)
   If [F:TFP2]SEL=2 # échéance sélectionnée
    [M:FUP]TOTFUPLIG(N) += MTDES+AMTDEP
    [L]TOTFUPT += MTDES+AMTDEP
    [M:FUP]TOTFUP2 += MTDES+AMTDEP
   Else
    [M:FUP]TOTFUP1 += MTDES+AMTDEP
   Endif
  Next # [LNK2]

  If [M:FUP]TOT(N)<>2 : [M:FUP]TOTAGIOS += [M:FUP]AGIOS(N) : Endif
  N+=1
  If N>=MAXBPC-2
   # Tableau plein
   Call ERREUR(mess(26,100,1)) From GESECRAN
   Break
  Endif

 Next # fin [LNK0]

 If [M:FUP]SUPTOT = [V]CST_AFALSE Then
  [M:FUP]BPCNAM(N) = [F:BPC]BPCNAM
  # 72091
  [M:FUP]TOT(N) = 2 # ligne de total
  # 72196
  [M:FUP]SEL(N) = 0

  [M:FUP]BPC(N) = [TFP3]BPC
  # Total relance
  [M:FUP]CMT(N) = mess(227,117,1)
  [M:FUP]FUPTYP(N) = [F:BPC]FUPTYP
  [M:FUP]SOLREL(N) = [L]SOLRELT
  # Le montant des agios est négatif. Il doit être positif et ainsi il s’ajoutera au solde relançable
  # pour donner le total relançable.
  [M:FUP]AGIOS(N)  = [L]AGIOS
  [M:FUP]SOLNONREL(N) = [L]SOLNONRELT
  [M:FUP]TOTFUPLIG(N) = [L]TOTFUPT
  N+=1
 Endif

 If N>=MAXBPC-1
  # Tableau plein
  Break
 Endif
Next # TFP3

[M:FUP]NBLIG = N
Affzo [M:FUP]
Diszo [M:FUP]CMT2
Return

###############################################################################################
## Etiquettes du masque FUP
###############################################################################################

# FUPSIM report printing
$EDITION
Local Char TBPAR(30)(1..50), TBVAL(30)(1..50)
Local Integer NBPAR

NBPAR += 1
TBPAR(NBPAR) = "numedt"
TBVAL(NBPAR) = [M:CFP0]QURNUM

Call ETATN("FUPSIM",GFONCTION,TBPAR,TBVAL) From ETAT
Return

###############################################################################################
# FUPSIM2 report printing
# 25.09.2012 mamay (Marc-Andre Mayer) SAM-82431
###############################################################################################
$PRINT_FUPSIM2
Local Char TBPAR(30)(1..50), TBVAL(30)(1..50)
Local Integer NBPAR
Local Char RPT(20)

NBPAR += 1
TBPAR(NBPAR) = "numedt"
TBVAL(NBPAR) = [M:CFP0]QURNUM

Call SAIETAT( "FUPSIM2", RPT ) From GCONSULT
If RPT <> "" : Call ETATN( RPT, GFONCTION, TBPAR, TBVAL ) From ETAT : Endif
Return

Subprog IB_NBLIG
Local Char VALPAR(1)

If [M:FUP]TOT(nolign-1)=1
 # BP reminders
 GBOUT1 = mess(228,117,1)-[M:FUP]BPC(nolign-1)
Else
 Raz GBOUT1
Endif

Call PARAM("","FUPCRM",VALPAR) From ADOVAL
FUPCRM = val(VALPAR)

If FUPCRM=2 and GMODU(13)=2
 # we choose the more "accurate" CRM task
 If !clalev([F:TSK]) : Local File TASK [TSK] : Endif
 Filter [TSK] Where TSKORIADI="CPT4" and TSKORIVCR=[M:CFP0]QURNUM and TSKCMP=[M:FUP]BPC(nolign-1) and SALFCY=[M:FUP]FCY(nolign-1)
 If rowcount([TSK])<>0
  Read [TSK] First
 Else
  # same filter, but without the condition on the facility (less restricting than previous filter)
  Filter [TSK] Where TSKORIADI="CPT4" and TSKORIVCR=[M:CFP0]QURNUM and TSKCMP=[M:FUP]BPC(nolign-1)
  If rowcount([TSK])<>0
   Read [TSK] First
  Else
   Raz GBOUT4
  Endif
 Endif
 Filter [TSK]
Else
 Raz GBOUT4
Endif
End

# tunnel vers la fiche client
Subprog B2_NBLIG
Call OBJET_CHAR([M:FUP]BPC(nolign-1),"BPC","") From GOBJET
Gosub ENABLE_DISABLE_BUTTONS
End

# tunnel vers la situation tiers
Subprog B3_NBLIG
Local Char    PARMSK(250)(1..20)
Local Decimal BASPAG
PARMSK(1) = "1"
PARMSK(2) = [M:FUP]BPC(nolign-1)
PARMSK(3) = [M:CFP1]FCY
PARMSK(4) = [M]CPY(nolign-1)
PARMSK(5) = [M:CFP1]REFDAT
PARMSK(6) = "1"
PARMSK(7) = ""
Call CONSULT_NUM(BASPAG,"BAG",PARMSK) From GCONSULT
Gosub ENABLE_DISABLE_BUTTONS
End

# tunnel vers la fonction des tâches CRM
Subprog B4_NBLIG
# si présence module Action commerciale
Local Integer FUPCRM
Local Char VALPAR(1)

Call PARAM("","FUPCRM",VALPAR) From ADOVAL
FUPCRM = val(VALPAR)

If FUPCRM=2 and GMODU(13)=2
 # [F:TSK] is initialized in Subprog IB_NBLIG (for every right-click)
 GBIDC1 = [F:TSK]TSKNUM
 Call OBJET("TSK", GBIDC1, GBIDC2) From GOBJET
 Gosub ENABLE_DISABLE_BUTTONS
Endif
End

Subprog AS_NBLIG
If [M:FUP]TOT(nolign-1)<>1 # ligne de total
 Effzo [M:FUP]CMT2
 Diszo [M:FUP]CMT2
Else
 # Mise à jour de la valeur du champ [M:FUP]CMT2 avec le commentaire associé au tiers de la ligne courante
 # NB : le commentaire est le même pour un tiers et pour toutes les sociétés/sites
 Actzo [M:FUP]CMT2
 Read [TFP3]TFP1=[M:FUP]QURNUM;[M:FUP]BPC(nolign-1);[M:FUP]CPY(nolign-1);[M:FUP]FCY(nolign-1)
 If fstat=0
  If [M:FUP]CMT2<>[F:TFP3]CMT
   [M:FUP]CMT2=[F:TFP3]CMT
   Affzo [M:FUP]CMT2
  Endif
 Else
  Raz [M:FUP]CMT2
 Endif
Endif
[M:FUP]NOLIG=nolign
# Will be re-enabled later
#Chgstl [M:FUP]NBLIG With "" # removing all styles
#Chgstl [M:FUP]NBLIG(nolign-1) With "AWARN" # add style on the current line

# No Affzo here, or else sorting a column will no longer work
Envzo
End

Subprog AM_CMT2(VALEUR)
Variable Clbfile VALEUR
 If [M:FUP]TOT([M:FUP]NOLIG-1)=1 # ce n'est pas une ligne de total
  # Attention : il faut utiliser Rewrite pour mettre à jour un champ Clob (plantage avec Update)
  # voir le bug 30087 pour plus d'infos
  # mais ça fonctionne en V6 avec Update ??
  Trbegin [TFP3]
  # mise à jour du commentaire concernant le triplet tiers/société/site
  For [TFP3]TFP1 Where BPC=[M:FUP]BPC([M:FUP]NOLIG-1) and CPY=[M:FUP]CPY([M:FUP]NOLIG-1) and FCY=[M:FUP]FCY([M:FUP]NOLIG-1)
   [F:TFP3]UPDUSR = GUSER
   [F:TFP3]UPDDAT = date$
   [F:TFP3]CMT = VALEUR
####################################
# Types de blob : voir menu local 7806
# 1) Indéterminé
# 2) Texte
# 3) Image
# 4) Bureautique
# 5) Word
# 6) Excel
# 7) PowerPoint
####################################
   [F:TFP3]TYPBLB = 2
   Rewrite [F:TFP3]
   If fstat : Break : Endif
  Next # TFP3
  If fstat
   Call FSTA('TFP3') From GLOCK
   Rollback
   zoncou = "CMT2"
  Else
   Commit
   If len(VALEUR)>CMTLEN
    VALEUR = left$(VALEUR, CMTLEN-3)+"..."
   Endif
   [M:FUP]CMT([M:FUP]NOLIG-1) = VALEUR
   Affzo [M:FUP]CMT([M:FUP]NOLIG-1)
  Endif
 Endif
End


######################################################################################
# recompute value of field [M:FUP]TOTFUP2
Subprog CALC_TOTFUP2
# les agios sont affichés positifs mais comptabilisés en négatif
# les escomptes sont affichés négatifs mais comptabilisés en positif
[M:FUP]TOTFUP2=[M:FUP]ECH2+[M:FUP]TOTAGIOS
Affzo [M:FUP]TOTFUP2
End

######################################################################################
# recompute value of field [M:FUP]TOTAGIOS
Subprog CALC_TOTAGIOS
Raz [M:FUP]TOTAGIOS
If [M:CFP2]AGIO=2
 For N=0 To [M:FUP]NBLIG-1
  If [M:FUP]TOT(N)<>2
   [M:FUP]TOTAGIOS += [M:FUP]AGIOS(N)
  Endif
 Next
 Affzo [M:FUP]TOTAGIOS
 Call CALC_TOTFUP2
Endif
End

######################################################################################
Subprog AM_SEL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 # Incorrect value
 GMESSAGE = mess(6,199,1)
 mkstat = 2
 End
Endif
End

######################################################################################
Subprog C_NBLIG
# Bug 94710: prevents double-clicking from looking for the next editable field in the table, since all fields are in display mode
If adxgtb=0 & status=75 : mkstat=2 : Endif
End

