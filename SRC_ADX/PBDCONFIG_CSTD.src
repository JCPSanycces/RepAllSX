#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When "" :    # manage plausibilities on configuration before insert/update
        Case [L]AEVENT
           When "AINSERT_CONTROL_AFTER" : Gosub CONTROL_AFTER   # Before insert but after field controls
           When "AUPDATE_CONTROL_AFTER" : Gosub CONTROL_AFTER   # Before update but after field controls
           When "AUPDATE_CONTROL_BEFORE": Gosub UPDATE_BEFORE
        Endcase

     When "LINESINCL" :    # manage the handling of the "data to include" collection: set CODE + LEG + LINE + ISINCLUDED
        Case [L]AEVENT
           When "ADDLINE_AFTER" : Gosub ADDLINE_AFTER_INCL   # A line is added
        Endcase

     When "LINESEXCL" :   # manage the handling of the "data to exclude" collection: set CODE + LEG + LINE + ISINCLUDED
        Case [L]AEVENT
           When "ADDLINE_AFTER" : Gosub ADDLINE_AFTER_EXCL    # A line is added
        Endcase
  Endcase
#When "AINSERT_BEFORE"        : Gosub INSERT_BEFORE
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


# SAM # 111399 $METHODS outcommented content is now implemented in $EVENT
$METHODS
