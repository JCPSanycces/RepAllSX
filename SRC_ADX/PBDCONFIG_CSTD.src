# SAM # 111399 changed ACTION to ARULE
$PROPERTIES
Case [L]CURPRO
When "CODE"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PROP_CODE
      Endcase
When "LEG"
      Case [L]ARULE
        When "CONTROL"   : Gosub CTRL_LEG
        When "PROPAGATE" : Gosub PROP_LEG
      Endcase
When "GRPORCPY"
      Case [L]ARULE
        When "CONTROL"   : Gosub CTRL_GRPORCPY
        When "PROPAGATE" : Gosub PROP_GRPORCPY
      Endcase
When "LEDTYP"
      Case [L]ARULE
        When "INIT"      : Gosub INIT_LEDTYP
        When "CONTROL"   : Gosub CTRL_LEDTYP
        When "PROPAGATE" : Gosub PROP_LEDTYP
      Endcase
When "ROOTACC"
      Case [L]ARULE
        When "CONTROL" : Gosub CTRL_ROOTACC
      Endcase
Endcase
Return

############################################################################################
# Implementation of the METHODS
############################################################################################

$CONTROL_AFTER

   # check uniqueness of combination LEG - Group or Company
   Local File PBDCONFIG [PBDCNF]
   For [F:PBDCNF] Where LEG = this.LEG
      If [F:PBDCNF]GRPORCPY = this.GRPORCPY and [F:PBDCNF]CODE <> this.CODE
         ASTATUS = fmet this.ASETERROR( "", func AFNC.MES2( mess(355,107,1), this.GRPORCPY, this.LEG), [V]CST_AERROR )
            # The combination of Legislation and Group + cy must be unique. The Group + cy "$1$" already exists for Legislation $2$
         Break
      Endif
   Next
   # check uniqueness of CROOTACC in all lines of LINESINCL and LINESEXCL
   Local Integer I, J
   For I=1 To maxtab(this.LINESINCL)
     If this.LINESINCL(I)<>null and this.LINESINCL(I).ASTALIN <> [V]CST_ADEL and this.LINESINCL(I).ASTALIN <> [V]CST_ANEWDEL
       For J = 1 To maxtab(this.LINESINCL)
         If J <> I and this.LINESINCL(J)<>null and this.LINESINCL(J).ASTALIN <> [V]CST_ADEL and this.LINESINCL(J).ASTALIN <> [V]CST_ANEWDEL and
&           this.LINESINCL(I).CROOTACC = this.LINESINCL(J).CROOTACC and this.LINESINCL(I).BPGROUP = this.LINESINCL(J).BPGROUP and
&           this.LINESINCL(I).DOCTYPE = this.LINESINCL(J).DOCTYPE
           ASTATUS = fmet this.ASETERROR( "", func AFNC.MES1( mess(356,107,1), this.LINESINCL(I).CROOTACC), [V]CST_AERROR )
                                                                                         # The line for account $1$ is not unique.
           Break
         Endif
       Next J
       If ASTATUS = [V]CST_AOK
         For J = 1 To maxtab(this.LINESEXCL)
           If this.LINESINCL(I)<>null and this.LINESEXCL(J).ASTALIN <> [V]CST_ADEL and this.LINESEXCL(J).ASTALIN <> [V]CST_ANEWDEL and
&             this.LINESINCL(I).CROOTACC = this.LINESEXCL(J).CROOTACC and this.LINESINCL(I).BPGROUP = this.LINESEXCL(J).BPGROUP and
&             this.LINESINCL(I).DOCTYPE = this.LINESEXCL(J).DOCTYPE
               ASTATUS = fmet this.ASETERROR( "", func AFNC.MES1( mess(356,107,1), this.LINESINCL(I).CROOTACC), [V]CST_AERROR )
                                                                                         # The line for account $1$ is not unique.
             Break
           Endif
         Next J
       Endif
     Endif
     If ASTATUS <> [V]CST_AOK : Break : Endif
   Next I
   If ASTATUS = [V]CST_AOK
     For I=1 To maxtab(this.LINESEXCL)
       If this.LINESEXCL(I)<>null and this.LINESEXCL(I).ASTALIN <> [V]CST_ADEL and this.LINESEXCL(I).ASTALIN <> [V]CST_ANEWDEL
         For J = 1 To maxtab(this.LINESEXCL)
           If J <> I and this.LINESEXCL(J).ASTALIN <> [V]CST_ADEL and this.LINESEXCL(J).ASTALIN <> [V]CST_ANEWDEL and
&             this.LINESEXCL(I).CROOTACC = this.LINESEXCL(J).CROOTACC and this.LINESEXCL(I).BPGROUP = this.LINESEXCL(J).BPGROUP and
&             this.LINESEXCL(I).DOCTYPE = this.LINESEXCL(J).DOCTYPE
             ASTATUS = fmet this.ASETERROR( "", func AFNC.MES1( mess(356,107,1), this.LINESEXCL(I).CROOTACC), [V]CST_AERROR )
                                                                                         # The line for account $1$ is not unique.
             Break
           Endif
         Next J
       Endif
     Next I
   Endif
Return

$ADDLINE_AFTER_INCL
   this.CODE = this.APARENT.CODE
   this.LEG  = this.APARENT.LEG
   this.COA  = this.APARENT.COA
   this.LINE = 1 + max(this.APARENT.LINESINCL(1..maxtab(this.APARENT.LINESINCL)).LINE)
   this.ISINCLUDED = 2
Return

$ADDLINE_AFTER_EXCL
   this.CODE = this.APARENT.CODE
   this.LEG  = this.APARENT.LEG
   this.COA  = this.APARENT.COA
   this.LINE = 1 + max(this.APARENT.LINESEXCL(1..maxtab(this.APARENT.LINESEXCL)).LINE)
   this.ISINCLUDED = 1
Return


############################################################################################
# Implementation of the PROPERTIES
############################################################################################

$PROP_CODE
   # Loop on all the lines of "data included" and "data excluded" to assign CODE
   Local Integer I
   For I=1 To maxtab(this.LINESINCL)
     If this.LINESINCL(I)<>null : this.LINESINCL(I).CODE=this.CODE : Endif
   Next I
   For I=1 To maxtab(this.LINESEXCL)
     If this.LINESEXCL(I)<>null : this.LINESEXCL(I).CODE=this.CODE : Endif
   Next I
Return

$CTRL_LEG
   # if the given legislation doesn't exist -> message
   Local File ATABDIV [ADI]
   Read [ADI]CODE = 909;this.LEG
   If fstat
     ASTATUS = fmet this.ASETERROR("LEG", func AFNC.MES1( mess(345,107,1), this.LEG ), [V]CST_AERROR ) # "$1$ is not a valid legislation."
   Else
     # if the parameter 'PAYBALDCL' is not set for the given legislation -> message
     If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVLEG,this.LEG,"PAYBALDCL") <> 2
       ASTATUS = fmet this.ASETERROR( "LEG", func AFNC.MES2( mess(346,107,1), this.LEG, "PAYBALDCL" ), [V]CST_AERROR )
                                           # "$1$ is not a valid legislation in this context. Please check parameter '$2$'."
     Endif
   Endif
Return


$PROP_LEG
    # Loop on all the lines of "data included" and "data excluded" to assign LEG
    Local Integer I
    For I=1 To maxtab(this.LINESINCL)
      If this.LINESINCL(I)<>null : this.LINESINCL(I).LEG=this.LEG : Endif
    Next I
    For I=1 To maxtab(this.LINESEXCL)
      If this.LINESEXCL(I)<>null : this.LINESEXCL(I).LEG=this.LEG : Endif
    Next I

    # Initialize field process type with "Open items" for Germany / Austria
    Case this.LEG
      When "AUT" : this.PROCESSTYPE = 2  # for Austria process type is always "Open items"
      When "GER" : this.PROCESSTYPE = 2  # for Germany process type is always "Open items"
      When "POR" : this.PROCESSTYPE = 3  # for Portugal process type is always "Both"
    Endcase

    # Check ledger type again after change of legislation
    If this.LEDTYP > 0 Then
       Gosub PROP_GRPORCPY
    Endif
Return


$CTRL_GRPORCPY
  Local File COMPANY [CPY]

  Read [F:CPY]CPY0 = this.GRPORCPY
  If !fstat
     If [F:CPY]CPYLEGFLG = 2            # legal company
       If [F:CPY]LEG <> this.LEG
          ASTATUS = fmet this.ASETERROR( "GRPORCPY", func AFNC.MES2( mess(347,107,1), this.GRPORCPY, this.LEG ), [V]CST_AERROR )
                                           # "The company $1$ doesn't belong to the chosen legislation $2$."
       Endif
     Else                               # company group
       Local File AGRPCPY [AGC]
       For [F:AGC] Where GRP = this.GRPORCPY
         Read [F:CPY]CPY0 = [F:AGC]CPY
         If [F:CPY]LEG <> this.LEG
            ASTATUS = fmet this.ASETERROR( "GRPORCPY", func AFNC.MES3( mess(348,107,1), [F:CPY]CPY, this.GRPORCPY, this.LEG ), [V]CST_AERROR )
                                           # "The company '$1$' of the group $2$ doesn't belong to the chosen legislation $3$."
            Break
         Endif
       Next
       LogicClose File [AGC]
     Endif
  Endif

  LogicClose File [CPY]
Return

$PROP_GRPORCPY
   # Check ledger type again after change of group or company
   Gosub CTRL_LEDTYP
   If ASTATUS = [V]CST_AOK
     Gosub PROP_LEDTYP
   Endif
Return


#** #############################################################################################
#*  If no company or group of companies is entered, the ledger type must exist in at least one core model of the LEG.
#*  If a single company is entered, the ledger type must belong to this company.
#*  If a group of companies is entered, the ledger type must belong to all companies of the group.
#*  In all cases, no automatic ledgers are allowed.
#*  Additionally it is checked whether a unique chart of accounts (COA) belongs to all involved companies.
#*  If there isn't a unique COA, a blocking error is generated.
#*! #############################################################################################

$CTRL_LEDTYP
If this.LEG <> ""
  Local Char COA(10), TMPCOA(10)
  Local File GACM [GCM] # core model
  Local Integer OK
  If this.GRPORCPY <> ""     # a company or group is entered -> check if ledger type belongs to company or all companies of group
    Local File COMPANY [CPY]
    Read [F:CPY]CPY0 = this.GRPORCPY
    If !fstat
      If [F:CPY]CPYLEGFLG = 2            # legal company
        Gosub CHECK_CORE_MODEL_LEDGER    # check if core model contains ledger type and check COA
      Else                               # company group
        Local File AGRPCPY [AGC]
        For [F:AGC] Where GRP = this.GRPORCPY  # check for each company of the group if it contains the ledger type
          Read [F:CPY]CPY0 = [F:AGC]CPY
          If !fstat
            Gosub CHECK_CORE_MODEL_LEDGER    # check if core model contains ledger type and check COA
            If not OK Break : Endif
          Endif
        Next
        LogicClose File [AGC]
      Endif
    Endif
    LogicClose File [CPY]
  Else                       # no company/group entered -> check if ledger type exists in at least one core model with this.LEG
    If this.LEDTYP > 0 Then
      For [F:GCM] Where LEG = this.LEG
        OK = [F:GCM]LED(this.LEDTYP-1) <> "" and [F:GCM]CFMAUT(this.LEDTYP-1) = 1 # no automtic ledger -> OK
        If OK
           Gosub CHECK_COA
           If not OK Break : Endif
        Endif
      Next
    Endif
    If not OK ASTATUS = fmet this.ASETERROR( "LEDTYP", func AFNC.MES1( mess(349,107,1), this.LEG ), [V]CST_AERROR ) : Endif
                             # "This ledger type is not allowed for the legislation $1$."
  Endif
  LogicClose File [GCM]
Endif
Return


$INIT_LEDTYP
  this.LEDTYP = 1
Return


#** #############################################################################################
#*  Read the core model of company [F:CPY]CPY. Then check if it contains the
#*  entered ledger type (this.LEDTYPE; this.LEDTYPE is the index of the ledger types in core model).
#*  IF yes, only non automatic ledger types are allowed.
#*  Sets variable OK to 1, if ledger type found and correct, otherwise OK is set to 0
#*! #############################################################################################
$CHECK_CORE_MODEL_LEDGER
   Read [F:GCM]GCM0 = [F:CPY]ACM    # read core model of company
   If !fstat
     If this.LEDTYP > 0 Then
       OK = [F:GCM]LED(this.LEDTYP-1) <> "" and [F:GCM]CFMAUT(this.LEDTYP-1) = 1 # no automatic ledger -> OK
       If OK
          Gosub CHECK_COA
       Else
          ASTATUS = fmet this.ASETERROR( "LEDTYP", func AFNC.MES1( mess(350,107,1), [F:CPY]CPY), [V]CST_AERROR )
                                       # "Ledger type not found for company $1$."
       Endif
     Endif
   Endif
Return


#** #############################################################################################
#*  Read the ledger linked to the ledger type in the core model of the company.
#*  Checks if the COA of the ledger is the same as the previously checked ones (in local var COA)
#*  Sets variable OK to 1, if COA is unique, otherwise OK is set to 0
#*! #############################################################################################
$CHECK_COA
  If this.LEDTYP < 1 Then
    Return
  Endif
   Local File GLED [LED] # ledger
   Read [F:LED]LED0 = [F:GCM]LED(this.LEDTYP-1) # read ledger to get COA
   If !fstat
      TMPCOA = [F:LED]COA
      If COA = "" : COA = TMPCOA : Endif  # first initialization
      If COA <> TMPCOA                    # different COA found -> not allowed -> error
         OK = 0
         ASTATUS = fmet this.ASETERROR( "LEDTYP", mess(351,107,1), [V]CST_AERROR )
                                          # "Different charts of account found for ledger type and legislation / group of companies."
      Endif
   Endif
   LogicClose File [LED]
Return



#** #############################################################################################
#*  The unique COA (uniqueness is checked in CTRL_LEDTYP) is assigned to property "COA".
#*  It is needed for the plausibility check of the root accounts.
#*! #############################################################################################

$PROP_LEDTYP
If this.LEG <> ""
  Local File GACM [GCM] # core model
  Local Integer OK
  If this.GRPORCPY <> ""     # a company or group is entered -> read COA through ledger of company / group
    Local File COMPANY [CPY]
    Read [F:CPY]CPY0 = this.GRPORCPY
    If !fstat
      If [F:CPY]CPYLEGFLG = 2            # legal company
        Gosub SET_COA_BY_LED             # read core model and set COA
      Else                               # company group
        Local File AGRPCPY [AGC]
        Read [F:AGC]AGC0(1) = this.GRPORCPY # read first company of group
        If !fstat
          Read [F:CPY]CPY0 = [F:AGC]CPY
          If !fstat
            Gosub SET_COA_BY_LED         # read core model and set COA
          Endif
        Endif
        LogicClose File [AGC]
      Endif
    Endif
    LogicClose File [CPY]
  Else                       # no company/group entered -> read COA through ledger of first found core model with ledger type
    For [F:GCM] Where LEG = this.LEG
        OK = [F:GCM]LED(this.LEDTYP-1) <> "" and [F:GCM]CFMAUT(this.LEDTYP-1) = 1 # no automtic ledger -> OK
        If OK
           Gosub SET_COA
           Break
        Endif
    Next
  Endif

  Gosub CTRL_ROOTACC # after change of ledger type -> check already entered root accounts again

  LogicClose File [GCM]
Endif
Return


#** #############################################################################################
#*  Read the core model of the company.
#*  Sets COA in class and all lines of LINESINCL and LINESEXCL
#*! #############################################################################################
$SET_COA_BY_LED
   Read [F:GCM]GCM0 = [F:CPY]ACM    # read core model of company
   If !fstat
      Gosub SET_COA
   Endif
Return


#** #############################################################################################
#*  Read the ledger linked to the ledger type in the core model of the company.
#*  Sets COA in class and all lines of LINESINCL and LINESEXCL
#*! #############################################################################################
$SET_COA
  If this.LEDTYP < 1 Then
    Return
  Endif
   Local File GLED [LED] # ledger
   Read [F:LED]LED0 = [F:GCM]LED(this.LEDTYP-1) # read ledger to get COA
   If !fstat
      this.COA = [F:LED]COA
      # Loop on all the lines of "data included" and "data excluded" to assign COA
      Local Integer I
      For I=1 To maxtab(this.LINESINCL)
        If this.LINESINCL(I)<>null : this.LINESINCL(I).COA=this.COA : Endif
      Next I
      For I=1 To maxtab(this.LINESEXCL)
        If this.LINESEXCL(I)<>null : this.LINESEXCL(I).COA=this.COA : Endif
      Next I
   Endif
   LogicClose File [LED]
Return



$CTRL_ROOTACC
  If len(this.ROOTACC) > 0
    Local Integer I
    Local Integer OKACC : OKACC = 1
    Local Char TMPROOTACC (200)
    Local Char TMPACC (20)
    Local File GACCOUNT [GAC] # accounts

    TMPROOTACC = this.ROOTACC
    I=1
    While (I > 0 and OKACC)             # look for next blank as separator
      I = instr(1,TMPROOTACC," ")
      If I>0                            # blank found -> check account
        TMPACC = left$(TMPROOTACC,I-1)  # get next root account
        TMPROOTACC = right$(TMPROOTACC,I+1)
      Else
        TMPACC = TMPROOTACC             # no more blank -> get last account
      Endif
      Gosub CHECK_ACCOUNT
    Wend
    If OKACC                            # if OK -> check CROOTACC of all lines in LINESINCL and LINESEXCL
      For I=1 To maxtab(this.LINESINCL)
        If this.LINESINCL(I)<>null : ASTATUS = func PBDCONFIGD_CSTD.CHECK_ACC(this.ROOTACC,this.LINESINCL(I).CROOTACC,this.LINESINCL(I)) : Endif
      Next I
      For I=1 To maxtab(this.LINESEXCL)
        If this.LINESEXCL(I)<>null : ASTATUS = func PBDCONFIGD_CSTD.CHECK_ACC(this.ROOTACC,this.LINESEXCL(I).CROOTACC,this.LINESEXCL(I)) : Endif
      Next I
    Endif
    LogicClose File [GAC]
  Endif
Return


$CHECK_ACCOUNT
   Local Char TMP (200)
   TMP = right$(TMPACC,len(TMPACC))   # get last character of account to check for "*"
   If TMP <> "*"                      # only check single accounts (without wildcard *)
      If this.COA = ""
        ASTATUS = fmet this.ASETERROR( "ROOTACC", mess(352,107,1), [V]CST_AERROR )
                                      # "Please choose a ledger type first."
        OKACC = 0
      Else
        Read [F:GAC]GAC0 = this.COA;TMPACC  # try to find account
        If fstat                            # not found
           ASTATUS = fmet this.ASETERROR( "ROOTACC", func AFNC.MES1( mess(353,107,1), TMPACC), [V]CST_AERROR )
                                            # "Invalid account $1$."
           OKACC = 0
        Endif
      Endif
   Endif
Return

##
# The following functionality is used to set the order of the include rules if the user has changed the order
# This functionality is not integrated in the standard yet. So we have to manage it by our own.
#
$UPDATE_BEFORE
  Local Integer I, C, Z
  Local Integer LENGTH
  Local Integer ORDERN
  Local Integer LINE
  Local Char ECO(10)
  Local Char BPGR(10)
  Local Char CROOTACC(250)
  Local Char DOCT(10)
  Local Char NOTE(30)
  Local Decimal AMOUNT
  Local Integer SIGN
  Local Integer ORIENT
  # loop throug all lines
  For C = 1 To maxtab(this.LINESINCL)
     If this.LINESINCL(C) <> null and this.LINESINCL(C).ASTALIN <> [V]CST_ADEL and this.LINESINCL(C).ASTALIN <> [V]CST_ANEWDEL and this.LINESINCL(C).AORDER <> this.LINESINCL(C).LINE Then

         # store in variables
         ORDERN = this.LINESINCL(C).AORDER
         SIGN = this.LINESINCL(C).ACCSIGN
         AMOUNT = this.LINESINCL(C).BALAMT
         CROOTACC = this.LINESINCL(C).CROOTACC
         BPGR = this.LINESINCL(C).BPGROUP
         DOCT = this.LINESINCL(C).DOCTYPE
         ECO = this.LINESINCL(C).PBDECO
         NOTE = this.LINESINCL(C).NOTES
         ORIENT = this.LINESINCL(C).ORIENT

         #delete line where linnumber and ordernumber are different
         ASTATUS = fmet this.ADELLINE("LINESINCL" ,this.LINESINCL(C).AORDER)

         #add line with new linenumber
         LIN = fmet this.ADDLINE("LINESINCL" , ORDERN)
         If LIN<>[V]CST_ANOTDEFINED  #: # If the addition is allowed
             this.LINESINCL(LIN).LEG = this.LEG
             this.LINESINCL(LIN).LINE = ORDERN
             this.LINESINCL(LIN).ISINCLUDED = 2
             this.LINESINCL(LIN).ACCSIGN = SIGN
             this.LINESINCL(LIN).BALAMT = AMOUNT
             this.LINESINCL(LIN).CODE = this.CODE
             this.LINESINCL(LIN).COA = this.COA
             this.LINESINCL(LIN).CROOTACC = CROOTACC
             this.LINESINCL(LIN).BPGROUP = BPGR
             this.LINESINCL(LIN).DOCTYPE = DOCT
             this.LINESINCL(LIN).PBDECO = ECO
             this.LINESINCL(LIN).NOTES = NOTE
             this.LINESINCL(LIN).ORIENT = ORIENT

          Endif
      Endif
  Next


Return

