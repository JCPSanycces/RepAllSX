#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque UKAPPLEV0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
If varmode([M]CPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTCPY"
 Call CONTSOC([M]CPY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 33782 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CPY","!",[M]CPY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 33782 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone PAYTHR
mkstat = 0
zoncou = "PAYTHR"
indice = 0
IMPENT = [M]PAYTHR
If varinit([M]PAYTHR,indice)=0
 IMPENT = 1
Endif
[M]PAYTHR = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone CURCPY
mkstat = 0
zoncou = "CURCPY"
indice = 0
IMPENT = [M]CURCPY
If varinit([M]CURCPY,indice)=0
 IMPENT = 1
Endif
If varmode([M]CURCPY,indice)=0
 [M]CURCPY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CURCPY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CURCPY(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_CURCPY(IMPENT) From SUBUAPPLEV0
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CURCPY" : GZNUM = 28056 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]CURCPY = IMPENT

## Zone ALLCPY
mkstat = 0
zoncou = "ALLCPY"
indice = 0
IMPENT = [M]ALLCPY
If varinit([M]ALLCPY,indice)=0
 IMPENT = 1
Endif
[M]ALLCPY = IMPENT

## Zone RECALC
mkstat = 0
zoncou = "RECALC"
indice = 0
IMPENT = [M]RECALC
If varinit([M]RECALC,indice)=0
 IMPENT = 1
Endif
[M]RECALC = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "UKAPPLEV0"
Return

