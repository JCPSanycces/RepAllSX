    Call ECR_TRACE('          '+ctrans(GCONITM_FIC(I),"\","/"),0) From GESECRAN
Next I
Call ECR_TRACE("",0) From GESECRAN

# nombre d'enreg lus
Call ECR_TRACE(mess(3,7710,1)-':'-num$(GCONITM_ENR),0) From GESECRAN
# nombre d'enreg importés en insertion
Call ECR_TRACE('     '+mess(4,7710,1)-':'-num$(GCONITM_NEW),0) From GESECRAN
