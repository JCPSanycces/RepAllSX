#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBPLMINT","PLMINT",4,"SPEPLMINT") From GTRAITE
End

######################################################################################
$ACTION
Case ACTION
 When "OUVRE_BATCH"  : Gosub OUVRE : #entrée en Batch
 When "INIT"         : Gosub OUVRE : #entrée en Interactif
 When "DEBUT"        : Gosub DEBUT
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When Default
Endcase
Return

######################################################################################
$OUVRE
Local Integer NBERR : NBERR=0
Local Integer OK , STAT
Local Char   FICREF(GDIMFIC),FICREJ(GDIMFIC), WFICHIER (GDIMFIC) , WFICCLI(GDIMFIC) , URL(GDIMFIC)

Local Mask PLMINT [DIA] : # Saisie paramètres
Raz [M:DIA]
If clalev ([F:PPA]) = 0 : Local File PLMPAR [PPA] : Endif
Call GET_DERLU([M:DIA]ID,"PLM","")
If [M:DIA]ID<>""
    Call AP_ID([M:DIA]ID)
Endif
[M:DIA]TRACE=2
Return

$DEBUT
# Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution
If [M:DIA]ID<>""
 Call AM_TYPEXP([M:DIA]TYPEXP)
Endif
#/ Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution
Affzo [M:DIA]
Return

#######################################################
$CONTROLE
If !GSERVEUR
 TMP = 1
Endif
If GSTATUT=7
 FIN = 1 : # Sortie du GSAISIE par la touche FIN
Endif
Return

###############################################################
$TERMINE
  TRA=0
  If !GSERVEUR & ( [M:DIA]TRACE=2 | NBERR>0)
    TRA = 1
  Endif
  Gosub SUP_VAR
Return

######################################################################################
$EXEC
TIT  = mess(1,7710,1)

If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

Gosub INI_VAR
Gosub DEB_CPTRENDU

Gosub TRAIT_ITM

Gosub TRAIT_BOM

Gosub FIN_CPTRENDU

If NBERR>0
#on doit envoyer un mail
If pat(GVERSION,"1.5.*")
    Gosub SEND_MAIL_V5
Else
    Gosub SEND_MAIL_V6
Endif
Endif
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

$TRAIT_ITM
If [M:DIA]TYPEXP=1
    WFICCLI = "itm.csv"
    FICREJ = "itm_rej.csv"
    FICREF = "refitm.csv"
    Call SET_FICNAM(WFICCLI,WFICHIER,URL) From ORDSYS
    Call COPSRV(WFICCLI,WFICHIER,STAT) From ORDSYS
    If STAT : Return : Endif
    Call IMPORT("ITM",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
Else
    WFICCLI = ""
    FICREJ = ""
    FICREF = ""
    WFICHIER=[M:DIA]DRTRCP
    Call IMPORT("ITM",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
    Call IMPORT("itm",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
Endif
Return

$TRAIT_BOM
If [M:DIA]TYPEXP=1
    WFICCLI = "bom.csv"
    FICREJ = "bom_rej.csv"
    FICREF = "refbom.csv"
    Call SET_FICNAM(WFICCLI,WFICHIER,URL) From ORDSYS
    Call COPSRV(WFICCLI,WFICHIER,STAT) From ORDSYS
    If STAT : Return : Endif
    Call IMPORT("BOM",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
Else
    WFICCLI = ""
    FICREJ = ""
    FICREF = ""
    WFICHIER=[M:DIA]DRTRCP
    Call IMPORT("BOM",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
    Call IMPORT("bom",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
Endif
Return

######################################################################################
$INI_VAR
# Déclaration des variables globales
Gosub INIVARNB From CONNECTITM
Gosub INIVARNB From CONNECTBOM
Return

$SUP_VAR
# Désallocation des variables globales
Gosub SUPVARNB From CONNECTITM
Gosub SUPVARNB From CONNECTBOM
Return

######################################################################################
$DEB_CPTRENDU
Local Char WCLIGNE (100)
WCLIGNE="======================================================================"
Local Char    TIT_DIR(50)
If clalev([F:AMZC])=0 : Local File AMSKZON [AMZC] : Endif

#Call ECR_TRACE("",0) From GESECRAN
#Call ECR_TRACE("",0) From GESECRAN
#Call ECR_TRACE(WCLIGNE,0) From GESECRAN
#Call ECR_TRACE(WCLIGNE,0) From GESECRAN
Call ECR_TRACE(format$("K=:70X", mess(1,7710,1)),0) From GESECRAN
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
#Call ECR_TRACE(WCLIGNE,0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN

Call ECR_TRACE(mess(24,7710,1)-" : "-[M:DIA]ID-[M:DIA]INTIT,0) From GESECRAN

If [M:DIA]TYPEXP=1
    Call ECR_TRACE(mess(22,7710,1),0) From GESECRAN : #Fichiers sur le poste client
Else
    Call ECR_TRACE(mess(21,7710,1),0) From GESECRAN : #Fichiers sur serveur
Endif
If [M:DIA]TYPEXP<>1
    TIT_DIR="DRTRCP"
    Read [AMZC]CODE="PLMINT";"DRTRCP"
    If fstat=0 Then
      TIT_DIR=func RDT([F:AMZC]INTIT)
    Endif
    Call ECR_TRACE(TIT_DIR-" : "-ctrans([M:DIA]DRTRCP,"\","/"),0) From GESECRAN

    TIT_DIR="DRTSTO"
    Read [AMZC]CODE="PLMINT";"DRTSTO"
    If fstat=0 Then
      TIT_DIR=func RDT([F:AMZC]INTIT)
    Endif
    Call ECR_TRACE(TIT_DIR-" : "-ctrans([M:DIA]DRTSTO,"\","/"),0) From GESECRAN

    TIT_DIR="DRTISS"
    Read [AMZC]CODE="PLMINT";"DRTISS"
    If fstat=0 Then
      TIT_DIR=func RDT([F:AMZC]INTIT)
    Endif
    Call ECR_TRACE(TIT_DIR-" : "-ctrans([M:DIA]DRTISS,"\","/"),0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Endif
#########"
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
#Call ECR_TRACE(WCLIGNE,0) From GESECRAN
Return

#######################################################
$FIN_CPTRENDU
Local Char WCLIGNE (100)
WCLIGNE="======================================================================"

Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN

#########"
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
############
# Import des articles
Call ECR_TRACE("=========="-mess(7,7710,1),0) From GESECRAN
# nombre de fichiers traités
