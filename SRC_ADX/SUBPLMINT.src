If [F:PPA]ADDEML1<>""
   L_ENVOI = 2
   Raz L_TEXTE
   L_TEXTE(1) = mess(85,115,1)-":"-nomap
   L_TEXTE(2) -= mess(175,124,1)-":"-GUSER
   L_TEXTE(3) -= mess(12,7710,1)-format$("D:"+GFMDAT,date$)-time$
   L_OBJET = L_TEXTE(1)-L_TEXTE(3)
   L_EXPMAIL=adxmac(-1)
   L_EMAIL=[F:PPA]ADDEML1
   L_PCE=filpath("TRA",GTRACE,"tra")
    Setlob TEXCLB With L_TEXTE(1..3)


##   Call ENVOI_MAIL(2,1,GUSER,L_EXPMAIL,"","",num$(adxuid(1)),0
