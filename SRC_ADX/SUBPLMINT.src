If GCONITM_REJ > 0
Call ECR_TRACE('     '+mess(6,7710,1)-':'-num$(GCONITM_REJ),-1) From GESECRAN
Else
Call ECR_TRACE('     '+mess(6,7710,1)-':'-num$(GCONITM_REJ),0) From GESECRAN
Endif
Call ECR_TRACE("",0) From GESECRAN


#########"
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
#Call ECR_TRACE(WCLIGNE,0) From GESECRAN
############
# Import des nomenclatures
Call ECR_TRACE("=========="-mess(8,7710,1),0) From GESECRAN
# nombre de fichiers traités
Call ECR_TRACE(mess(2,7710,1)-':'-num$(GCONBOM_NBF),0) From GESECRAN
For I=1 To GCONBOM_NBF
    Call ECR_TRACE('          '+ctrans(GCONBOM_FIC(I),"\","/"),0) From GESECRAN
Next I
Call ECR_TRACE("",0) From GESECRAN

# nombre d'enreg lus
Call ECR_TRACE(mess(3,7710,1)-':'-num$(GCONBOM_ENR),0) From GESECRAN
# Nombre de nomenclatures lues
Call ECR_TRACE(mess(15,7710,1)-':'-num$(GCONBOM_BOM),0) From GESECRAN
# Nombre de nomenclatures importées en insertion
Call ECR_TRACE('     '+mess(18,7710,1)-':'-num$(GCONBOM_NEW),0) From GESECRAN
# Nombre de nomenclatures importées en mise à jour
Call ECR_TRACE('     '+mess(19,7710,1)-':'-num$(GCONBOM_MAJ),0) From GESECRAN
# Nombre de nomenclatures rejetées
If GCONBOM_REJ > 0
Call ECR_TRACE('     '+mess(20,7710,1)-':'-num$(GCONBOM_REJ),-1) From GESECRAN
Else
Call ECR_TRACE('     '+mess(20,7710,1)-':'-num$(GCONBOM_REJ),0) From GESECRAN
Endif
Call ECR_TRACE("",0) From GESECRAN

#########"
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
#Call ECR_TRACE(WCLIGNE,0) From GESECRAN
Return


##########################################################################
## CONTROLES DES REPERTOIRES SAISIS
##########################################################################
######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
# Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution
#If GBATCH & VALEUR=1
# GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
# mkstat = 2 : End
#Endif
If VALEUR=1
 If GBATCH : GMESSAGE = mess(163,141,1) : mkstat = 2 : End
 Else
   Raz [M]VOLFILISS : Grizo [M]VOLFILISS
   Raz [M]VOLFILSTO : Grizo [M]VOLFILSTO
   Raz [M]VOLFILRCP : Grizo [M]VOLFILRCP
 Endif
Endif
#/ Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution

End

######################################################################################
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
# Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution
#  Call SET_NOMFIC("DRTRCP",[M:DIA]DRTRCP,VALEUR)
#  Call SET_NOMFIC("DRTSTO",[M:DIA]DRTSTO,VALEUR)
#  Call SET_NOMFIC("DRTISS",[M:DIA]DRTISS,VALEUR)
#  Affzo [M:DIA]DRTRCP
#  Affzo [M:DIA]DRTSTO
#  Affzo [M:DIA]DRTISS
#  If VALEUR=1
#     Grizo [M:DIA]DRTRCP
#     Grizo [M:DIA]DRTSTO
#     Grizo [M:DIA]DRTISS
#  Else
#     Actzo [M:DIA]DRTRCP
#     Actzo [M:DIA]DRTSTO
#     Actzo [M:DIA]DRTISS
#  Endif

If VALEUR=1
 Raz [M:DIA]VOLFILISS
 Grizo [M:DIA]VOLFILISS
 Raz [M:DIA]VOLFILSTO
 Grizo [M:DIA]VOLFILSTO
 Raz [M:DIA]VOLFILRCP
 Grizo [M:DIA]VOLFILRCP
Else
 Actzo [M:DIA]VOLFILISS
 Actzo [M:DIA]VOLFILSTO
 Actzo [M:DIA]VOLFILRCP
Endif
Affzo [M:DIA]VOLFILISS
Affzo [M:DIA]VOLFILSTO
Affzo [M:DIA]VOLFILRCP
#/ Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution

End

Subprog SET_NOMFIC(COLREP,NOMIMP,TYPEXP)
Value Char COLREP()
Variable Char NOMIMP()
Value Integer TYPEXP
Local Char    FICSRV(GDIMFIC) , URL(GDIMFIC)
Local Char    REPERT(GDIMFIC) , MACHINE(GDIMFIC)

Read [PPA]PPA0=[M:DIA]ID
If !fstat
    If (GOS(1)="unix" & pat(left$([F:PPA]DRTRCP,3),"!:\")) or left$([F:PPA]DRTRCP,1)="#"
     If TYPEXP=1
        NOMIMP=evalue("[F:PPA]"+COLREP)
     Endif
    Elsif GOS(1)<>"unix" & pat(left$([F:PPA]DRTRCP,3),"!:\") & filinfo([F:PPA]DRTRCP,0)<=0
     If TYPEXP=1
        NOMIMP=evalue("[F:PPA]"+COLREP)
     Endif
    Else
     If TYPEXP=2
        NOMIMP=evalue("[F:PPA]"+COLREP)
     Else
        Call SET_NAMCLI(NOMIMP) From ORDSYS
     Endif
    Endif
Else
  If TYPEXP=1
    Call SET_NAMCLI(NOMIMP) From ORDSYS
  Endif
Endif

End

######################################################################################
Subprog C_DRTRCP(VALEUR)
Variable Char VALEUR()
If VALEUR="" : End : Endif
# contrôle du répertoire
Call CONTREP(VALEUR)
If mkstat : End : Endif
End

Subprog C_DRTSTO(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
# contrôle du répertoire
Call CONTREP(VALEUR)
If mkstat : End : Endif
End

Subprog C_DRTISS(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
# contrôle du répertoire
Call CONTREP(VALEUR)
If mkstat : End : Endif
End

Subprog CONTREP(NAMEREP)
Variable Char NAMEREP()
Local Integer ER
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10)
  If left$(NAMEREP,1)="#"
   GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
   mkstat   = 2
   End
  Endif
  Call MACHINE(NAMEREP,MACHINE,REPERT) From ORDSYS
  Call GET_OS(MACHINE,OS) From ORDSYS
  If OS="" Then
    GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
    mkstat=2 : End
  Endif
  Call EXISTE(NAMEREP,ER) From ORDSYS
  If ER<>2 Then
    GERR=1
    GMESSAGE = mess(9,141,1) :  # Répertoire inexistant
    mkstat = 2 : End
  Endif
End

######################################################################################
Subprog REPERT(CHEMIN,REPERT,FICHIER,EXT)
Value    Char CHEMIN()
Variable Char REPERT()
Variable Char FICHIER()
Variable Char EXT()
Local Integer I , J , K
K = 0
Repeat
 I = instr(K+1,CHEMIN,"/")
 J = instr(K+1,CHEMIN,"\")
 If I or J
  K = max(I,J)
 Endif
Until I=0 & J=0
If K
 FICHIER = right$(CHEMIN,K+1)
 REPERT  = left$(CHEMIN,K-1)
Else
 FICHIER = CHEMIN
 REPERT  = ""
Endif
I = instr(1,FICHIER,".")
If I
 EXT     = right$(FICHIER,I+1)
 FICHIER = left$(FICHIER,I-1)
Else
 EXT     = ""
Endif
End


######################################################################################
Subprog IMPORT(NOMBASE,FICBASE,FICCLI,FICREJ,FICREF,NBERR)
Value    Char    NOMBASE(),FICBASE(),FICCLI(),FICREJ(),FICREF()
Variable Integer NBERR
#----------------------#
Local Char     MACHINE(GDIMFIC) , MACFIC(GDIMFIC),WFICREF(GDIMFIC),WFICREJ(GDIMFIC),WFICTMP(GDIMFIC)
Local Char     OS(20)(1..2)
Local Integer  TYPFIC,NBTRAIT
# Issue 90266 - 2013-07-26 by RBA
#Local Shortint MAXFIL : MAXFIL = 1000
#Local Char     TRAIT(200)(1..MAXFIL), EXT(30)
Local Shortint MAXFIL
Local Char WMAXFIL(10)
  Call PARAM(GFCY,"PLMMAXFIL",WMAXFIL) From ADOVAL
  MAXFIL = val(WMAXFIL)
Local Char     TRAIT(200)(1..MAXFIL), EXT(30)
#/ Issue 90266 - 2013-07-26 by RBA

Read [PPA]PPA0=[M:DIA]ID

If toupper(NOMBASE)="ITM"
    CONPROG="CONNECTITM"
    CONPIT=[F:PPA]ITMPIT
    REJ=1
    REF=1
Else
    CONPROG="CONNECTBOM"
    CONPIT=[F:PPA]BOMPIT
    REJ=1
    REF=0
Endif

If find(right$(FICBASE,len(FICBASE)),"\","/")
 FICBASE= left$(FICBASE,len(FICBASE)-1)
Endif

Call MACHINE(FICBASE,MACHINE,MACFIC) From ORDSYS
Call EXISTE(FICBASE,TYPFIC) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
Case TYPFIC
 When 2 : # C'est un répertoire
  EXT = "csv"
  Call SYSTEME2(MACHINE,'lsadx "'+MACFIC+'" "'+NOMBASE+"*."+EXT+'"','',NBTRAIT,TRAIT) From ORDSYS
  If NBTRAIT>dim(TRAIT)
   Call ECR_TRACE(mess(29,139,1)-"."+EXT-"("+num$(NBTRAIT)+"/"+num$(dim(TRAIT))+")",1) From GESECRAN : # Trop de fichiers
   NBERR+=1
   End
  Endif
 When 1 : # C'est un fichier normal
  NBTRAIT  = 1
  If FICCLI<>""
   Call SETNAM(FICCLI,TRAIT(1),EXT) From GOBJTXT
  Else
      #Call REPERT(FICBASE,FICBASE,TRAIT(1),EXT)
      Call ECR_TRACE("|"+FICBASE-":"-mess(159,141,1),1) From GESECRAN : # Fichier ou répertoire inexistant
      NBERR+=1
      End
  Endif
 When Default : # Ca n'existe pas
      Call ECR_TRACE("|"+FICBASE-":"-mess(159,141,1),1) From GESECRAN : # Fichier ou répertoire inexistant
      NBERR+=1
      End
Endcase

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium

For P=1 To NBTRAIT
 If FICCLI<>""
      FICCSV = FICBASE
      WFICREF= FICBASE+"_ref"
      WFICREJ= FICBASE+"_rej"
 Else
    J=instr(1,TRAIT(P),EXT)
    If J>2
        TRAIT(P)=left$(TRAIT(P),J-2)
    Endif
    FICCSV = filpath(FICBASE,TRAIT(P),EXT,"","",MACHINE)
    Call MACHINE([M:DIA]DRTISS,MACHINE,MACFIC) From ORDSYS
    WFICREF= filpath([M:DIA]DRTISS,"REF"+TRAIT(P),EXT,"","",MACHINE)
    Call MACHINE([M:DIA]DRTSTO,MACHINE,MACFIC) From ORDSYS
    WFICREJ= filpath([M:DIA]DRTSTO,TRAIT(P)+"_rej",EXT,"","",MACHINE)
 Endif
 TAILFIC = filinfo(FICCSV,7)
 If TAILFIC<0 : # Il aurait pu disparaître!!
  Call ECR_TRACE("|"+FICCSV-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
  NBERR+=1
 Else
  Gosub INTEGRE
 Endif

Next P

Openi

adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
End

######################################################################################
$INTEGRE
Local Integer ERR : ERR=0
Local Integer ERRNOFIC : ERRNOFIC=0
Local Integer OK , STAT
 Raz ERR,ERRNOFIC

 Call TRAITE(OS(1),FICCSV,FICCLI,CONPIT,[M:DIA]ID,REJ,WFICREJ,REF,WFICREF,ERR,ERRNOFIC) From=CONPROG
 If ERR
    #erreur sur un des fichiers
    NBERR+=1
 Endif
 #on doit basculer le fichier dans le repertoire des fichiers traites ssi sur serveur
 If FICCLI="" & !ERRNOFIC
    WFICTMP= filpath([M:DIA]DRTSTO,TRAIT(P),EXT,"","",MACHINE)
    Call MOVE_EMPTY(FICCSV,WFICTMP,STAT) From ORDSYS
 Endif

 #si fichier des rejets, on doit le recuperer
 If FICCLI<>"" & REJ=1
# Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution
  Call COPCLI(WFICREJ,FICREJ,STAT) From ORDSYS
#    Call MOVCLI(WFICREJ,FICREJ,STAT) From ORDSYS
#/ Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution
 Endif
 #si fichier des references, on doit le récuperer
 If FICCLI<>"" & REF=1
# Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution
  Call COPCLI(WFICREF,FICREF,STAT) From ORDSYS
#      Call MOVCLI(WFICREF,FICREF,STAT) From ORDSYS
#/ Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution
 Endif
Return

######################################################################################
$SEND_MAIL_V5
#CHECK IGNORE_BEGIN  # Analyse des sources, ne pas planter sur ce code V5
Local Char    L_EMAIL(40)(1..1)
Local Char    L_TEXTE(250)(1..3) , L_OBJET(250) , L_PCE(200)
Local Char    L_EXPMAIL(250)
Local Integer L_ENVOI(1..1) , L_SUIVI(1..1)

Read [PPA]PPA0=[M:DIA]ID

##Subprog ENVOI_MAIL(TYPMES,REQREC,USER,MAIL,OBJJOI,CLEOBJ,CHRONO,ERD
##&                 ,USR_EMAIL,USR_ENVOI,USR_SUIVI,USR_NB,
###&                TEXTE,NBTEX,TEXOBJ
##&                 ,PCEJOI,NBJOI,TYPJOI,CATJOI,CONTXT)

If [F:PPA]ADDEML1<>""
   L_ENVOI = 2
   Raz L_TEXTE
   L_TEXTE(1) = mess(85,115,1)-":"-nomap
   L_TEXTE(2) -= mess(175,124,1)-":"-GUSER
   L_TEXTE(3) -= mess(12,7710,1)-format$("D:"+GFMDAT,date$)-time$
   L_OBJET = L_TEXTE(1)-L_TEXTE(3)
   L_EXPMAIL=adxmac(-1)
   L_EMAIL=[F:PPA]ADDEML1
   L_PCE=filpath("TRA",GTRACE,"tra")

   Call ENVOI_MAIL(2,1,GUSER,L_EXPMAIL,"","",num$(adxuid(1)),0
&                 ,L_EMAIL,L_ENVOI,L_SUIVI,1,
&                 L_TEXTE,3,L_OBJET,L_PCE,
&                 1,"",0,"") From AWRKMEL

Endif

If [F:PPA]ADDEML2<>"" & [F:PPA]ADDEML1<>[F:PPA]ADDEML2
   L_ENVOI = 2
   Raz L_TEXTE
   L_TEXTE(1) = mess(85,115,1)-":"-nomap
   L_TEXTE(2) -= mess(175,124,1)-":"-GUSER
   L_TEXTE(3) -= mess(12,7710,1)-format$("D:"+GFMDAT,date$)-time$
   L_OBJET = L_TEXTE(1)-L_TEXTE(3)
   L_EXPMAIL=adxmac(-1)
   L_EMAIL=[F:PPA]ADDEML2
   L_PCE=filpath("TRA",GTRACE,"tra")

   Call ENVOI_MAIL(2,1,GUSER,L_EXPMAIL,"","",num$(adxuid(1)),0
&                 ,L_EMAIL,L_ENVOI,L_SUIVI,1,
&                 L_TEXTE,3,L_OBJET,L_PCE,
&                 1,"",0,"") From AWRKMEL
Endif
#CHECK IGNORE_END # Analyse des sources, ne pas planter sur ce code V5
Return


######################################################################################
$SEND_MAIL_V6
Local Char    L_EMAIL(40)(1..1)
Local Char    L_TEXTE(250)(1..3) , L_OBJET(250) , L_PCE(200)
Local Char    L_EXPMAIL(250)
Local Integer L_ENVOI(1..1) , L_SUIVI(1..1)
Local Clbfile  TEXCLB(5)

Read [PPA]PPA0=[M:DIA]ID

