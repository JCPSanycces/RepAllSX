#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion objet AYG
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AYG",GBIDC1,GBIDC2) From GOBJET
End

Local File AYTPAG [AYG1]
Infbox "NB rec: "+num$(nbrecord([AYG1]))
Local Integer NB
For [AYG1]AYG0 Where FCYCOD="ZJPJ" With Stability 
NB+=1
Next
Infbox "NB site ZJPJ"-num$(NB)
#End
Local File AYTPAG [AYG2]
Local Integer WI
Trbegin [AYG2]
For [AYG1]AYG0 Where FCYCOD="ZJPJ" With Stability 
  For WI=1 To 200
    [F:AYG2]=[F:AYG1]
    [F:AYG2]PAGCOD+="-A"+num$(WI)
    Write [AYG2]
  Next
Next
Commit

NB=0
For [AYG1]AYG0 Where FCYCOD="ZJPJ" With Stability 
NB+=1
Next
Infbox "NB site ZJPJ"-num$(NB)

End
######################################################################################
## Xtend:  Gestion des Alias de page 
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "AVANT_OUVRE"    : Gosub AVANT_OUVRE
 When "EXEBOUT"        : Gosub EXEBOUT
 When "EXEACT"         : Gosub EXEACT
 When "FERME"          : Gosub FERME
 When "FILTRE"         : Gosub FILTRE
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "LIENS"          : Gosub LIENS
 When "OUVRE"          : Gosub OUVRE
 When "RAZCRE"         : Gosub RAZCRE
 When "STATUT"         : Gosub STATUT
 When "SETBOUT"        : Gosub SETBOUT
 When "TITRE"          : Gosub TITRES 
 When "MODIF"          : Gosub MODIF
 When "CREATION"       : Gosub CREATION
 When "ANNULE"         : Gosub ANNULE
 When default
Endcase
Return

#---------------------------------------------------------------#
$MODIF
$CREATION
Call MAJTEXTRA([M]INTIT,"AYTPAG","INTIT",[M]FCYCOD,[M]PAGCOD) From ATEXTRA
Return

#---------------------------------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="AYTPAG" & ZONE = "INTIT"   & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
Return

#---------------------------------------------------------------#
$AVANT_OUVRE
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Gosub INICTLFCY From SUBAYS
Return

#---------------------------------------------------------------#

$OUVRE
Local Char WSTR1 (250)
Local Integer WI
Gosub DSYFCY From SUBAYS     # Infos site
Return

#---------------------------------------------------------------#
$FERME
Gosub DSYCLRFCY From SUBAYS # Clear affichage site
Return

#---------------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, copie
Else
 CHMEN+="1"    # Validation avec vérification 
Endif
CHMEN+="3"
Return

#---------------------------------------------------------------#
$EXEBOUT
Return

#---------------------------------------------------------------#
$EXEACT
Case BOUT
When "S"
    Call USG_SUPP([M]FCYCOD, GABREV, [M:AYG0]PAGCOD, WI) From CNSAYUSTD
    If WI : OK=0 : Endif
Endcase
Return

#---------------------------------------------------------------#
$TITRES
#FCYLIB=func SUBAYS.GETTITFCYWRK
#TIT = FCYLIB+":"-TIT
Return

#---------------------------------------------------------------#
$INICRE
$INIMOD
# Clé browser X3
[F]BRWX3=[F]FCYCOD+"_"+[F]PAGCOD 
Return

#---------------------------------------------------------------#
$LIENS
Gosub DSYFCY From SUBAYS     # Infos site
Return

#---------------------------------------------------------------#
$FILTRE
FILTSUP+=func SUBAYS.FILTFCY
Return

#---------------------------------------------------------------#
$RAZCRE
Gosub DSYFCY From SUBAYS     # Infos site
#[M]CODACT=WFCY_CODACT     # Code activité site
Return

#---------------------------------------------------------------#
$STATUT
Return

######################################################################################
## Actions
######################################################################################
#-----------------------------------------------------------------#
$SEL_TABLE
Return


### Action AYGSEL ###   Sélection alias de page d'un site
$AYGSEL
Local Char FCYWRK(GLONAYG)
If clalev([F:AYG])=0 : Local File AYGPAG [AYG] : Endif
[L]FCYWRK= PARAM(1) : # site de travail
CRITERE = 'FCYCOD = "'+ [L]FCYWRK +'"'
Default File [AYG]
START   = "[F:AYG]PAGCOD"
DEFPAG=1    # Gestion pagination MB
TIT(0) = mess(12,123,1)
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "PAGCOD"
NBCOL += 1 : COL(NBCOL) = "DES"
Return


######################################################################################
## Ecran AYG1
######################################################################################
Subprog S_FICDEF(VALEUR)    # Sélection page htm
Variable Char    VALEUR()
LANDEF= func SUBAYS.LANDEF([M]FCYCOD)
Call S1_FIC(LANDEF,VALEUR)
End

Subprog S1_FIC(LAN, VALEUR)    # Sélection page htm/langue
Value Char    LAN
Variable Char    VALEUR()
If !GWEBSERV
 Local Char RACINE(200),WVAL(250),WLAN(GLONLAN)
 Local Char LANDEF(GLONLAN)
 Local Integer WI
 WLAN = LAN
 Read [AYS]AYS0 = [M]FCYCOD
 If !fstat & [F:AYS]DIRLAN<>2 : WLAN="" : Endif
 RACINE= func AYTGESFILE.GETPATH("",nomap,"DIRPAG",WLAN,[M]FCYCOD,"")+
&        func AYTGESFILE.GETPATH("",nomap,"DIRSEP","","","")
 WVAL=RACINE+VALEUR
 ## <=> Action SELFICREP  (TRT SELFICREP)
 Call SELFICREP(WVAL) From SELFICREP
 #
 ## Action SELFICREP
 #Local Char    PARMSK(250)(1..20) , SAVACT(20)
 #Call SAISIE_CHAR(WVAL,PARMSK,"DFICREP","SELFICREP","XWDFICREP") From GSAISIE
 WI=instr(0,WVAL,RACINE)
 If WI
    VALEUR=right$(WVAL,len(RACINE)+1)
 Else
    mkstat=2
    GERR=1 : GMESSAGE=mess(16,7900,1)-WVAL
 Endif 
Endif
End

Subprog C_FICDEF(VALEUR)    # Ctl
Variable Char    VALEUR()
Local Char LANDEF
LANDEF= func SUBAYS.LANDEF([M]FCYCOD)
Call C1_FIC(LANDEF,VALEUR)
End

Subprog C1_FIC(LAN,VALEUR)    # Ctl fich/langue
Variable Char    VALEUR()
Local Char RACINE(200),FILEPATH(250),WLAN(GLONLAN)
Local Char LANDEF(GLONLAN)
Local Integer WI
WLAN = LAN
Read [AYS]AYS0 = [M]FCYCOD
If !fstat & [F:AYS]DIRLAN<>2 : WLAN="" : Endif
RACINE= func AYTGESFILE.GETPATH("",nomap,"DIRPAG",WLAN,[M]FCYCOD,"")+
&        func AYTGESFILE.GETPATH("",nomap,"DIRSEP","","","")
FILEPATH=RACINE+VALEUR
Call EXISTE(FILEPATH, WI) From ORDSYS
If WI<>1     # pas un fichier
    GERR=3 : GMESSAGE=mess(17,7900,1)-VALEUR        # GERR=3: avertissement GERR=2: message
Endif
End

Subprog C_FICLANCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]FICLANCOD) From OBJDIV
End

Subprog C_FICLAN(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
NOL = nolign-1
Call C1_FIC([M]FICLANCOD(NOL),VALEUR)
End

Subprog S_FICLAN(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
NOL = nolign-1
Call S1_FIC([M]FICLANCOD(NOL),VALEUR)
End

Subprog AS_WEBPRO(VALEUR)
Variable Integer VALEUR
For WI=4 To 10
    GMENLOC(WI)=1
Next
End
