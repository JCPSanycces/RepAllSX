###############################################################################
Subprog IB_PJTFIN

Local Char SPJT(GLONPIM)
Local Char SPJTBDG(GLONTAC)
Local Char SPJTTSK(GLONPBU)
Local Integer IRET

  # Issue X3-100249 - 2018-07-26 by FGR
  If [M:PTE0]PJTDEB <> AVOID.ACHAR Then
    IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:PTE0]PJTDEB, SPJT, SPJTBDG, SPJTTSK)
    If SPJTBDG <> AVOID.ACHAR Then
      # If begin is a budget : end is mandatory a budget too
      Raz GBOUT2   # Tunnel to project
      Raz GBOUT4   # Tunnel to task
      Raz GBOUT16  # Project selection
      Raz GBOUT18  # Task selection
    Elsif SPJTTSK <> AVOID.ACHAR Then
      # If begin is a task : end is mandatory a task too
      Raz GBOUT2   # Tunnel to project
      Raz GBOUT3   # Tunnel to budget
      Raz GBOUT16  # Project selection
      Raz GBOUT17  # Budget selection
    Else
      # If begin is a project : end is mandatory a project too
      Raz GBOUT3   # Tunnel to budget
      Raz GBOUT4   # Tunnel to task
      Raz GBOUT17  # Budget selection
      Raz GBOUT18  # Task selection
    Endif
  Endif
End

###############################################################################
Subprog C_PJTFIN(VALEUR)
Variable Char    VALEUR()

Local Char SPJT(GLONPIM)
Local Char SPJTBDG(GLONTAC)
Local Char SPJTTSK(GLONPBU)
Local Integer IRET

  # Issue X3-100249 - 2018-07-26 by FGR
  If [M:PTE0]PJTDEB <> AVOID.ACHAR and VALEUR <> AVOID.ACHAR Then
    IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:PTE0]PJTDEB, SPJT, SPJTBDG, SPJTTSK)
    If SPJTBDG <> AVOID.ACHAR Then
      # If begin is a budget : end is a budget too
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, VALEUR, SPJT, SPJTBDG, SPJTTSK)
      If SPJTBDG = AVOID.ACHAR Then
        GMESSAGE = mess(1108,2260,1)
        mkstat = 2
        End
      Endif
    Elsif SPJTTSK <> AVOID.ACHAR Then
      # If begin is a task : end is a task too
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, VALEUR, SPJT, SPJTBDG, SPJTTSK)
      If SPJTTSK = AVOID.ACHAR Then
        GMESSAGE = mess(1109,2260,1)
        mkstat = 2
        End
      Endif
    Else
      # If begin is a project : end is a project too
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, VALEUR, SPJT, SPJTBDG, SPJTTSK)
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, VALEUR, SPJT, SPJTBDG, SPJTTSK)
      If SPJTTSK <> AVOID.ACHAR or SPJTBDG <> AVOID.ACHAR Then
        GMESSAGE = mess(1110,2260,1)
        mkstat = 2
        End
      Endif
    Endif
  Endif
End

