#<AdxTL>@(#)0.0.0.0 $Revision$ Inquiry PTE
###############################################################################
# PTE : Time entry inquiry
# JIRA : X3-27531
# --------------------------------------------------------------------------
# Inquiry variables available :
# CHGPAG :
#  Button clicked to read
#    * = 1 : Search(apply)
#    * =-1 : Last
#    * = 2 : Next
#    * =-2 : Previous
#    * = 3 : F5
# MAXLIG :
#  Maximum lines in the grid
# NBLU :
#  Number of readed records
# NOL :
#  Index in the grid
#    * NOL += 1 if CHGPAG > 0
#    * NOL -= 1 if CHGPAG < 0
# SUITE :
#    * =1 : buttons "Next" and "Last" will be disable
# RETOUR :
#    * =1 : buttons "Previous" will be disable
###############################################################################
$ACTION
  Case GACTION
    When "CONSPTE"
      Case ACTION
        When "OUVRE"         : Gosub OUVRE
        When "LECTURE"       : Gosub LECTURE
        When "DEB_CRIT"      : Gosub DEB_CRIT
        When "SETBOUT"       : Gosub SETBOUT
        When Default
      Endcase
    When Default
  Endcase
Return

###############################################################################
$OUVRE
# Filters
Local Integer IFIL
Local Char WFIL(250)(0..100)
# Navigation management
Local Char SBEGKEYCONCAT(200)
Local Char SENDKEYCONCAT(200)

  # ----------------------------
  # Issue 94962 - 2018-06-18 by FGR : BEGIN
  #If clalev([F:VPTE]) = 0 : Local File VPJMTIMEMP [VPTE] : Endif
  #If clalev([F:PTKO]) = 0 : Local File PJMTSKOPE  [PTKO] : Endif
  #If clalev([F:PJOA]) = 0 : Local File PJMOPEAFF  [PJOA] : Endif
  Local File VPJMTIMEMP [VPTE]
  Local File PJMTSKOPE  [PTKO]
  Local File PJMOPEAFF  [PJOA]
  # Issue 94962 - 2018-06-18 by FGR : END
  # ----------------------------
  NAVIG = "CONSPTE"
  Gosub DEFCRIT
Return

###############################################################################
$SETBOUT
  Call DISPLAY_WITH_STYLE()
Return

###############################################################################
$DEFCRIT
Local Char SPJT(GLONPJT)
Local Char SFCY(GLONFCY)
Local Integer IOPENUM
Local Date DDEBDAT
Local Char SPROJECT(GLONOPP)
Local Char SBUDGET(GLONPBU)
Local Char STASK(GLONTAC)
Local Char SCLB(GLONAUS)     # Issue 94962 - 2018-06-18 by FGR

  # ----------------------------
  SPJT = PARAM(1)
  SFCY = PARAM(2)
  DDEBDAT = PARAM(4)
  IOPENUM = val(PARAM(3))
  SCLB = PARAM(5)            # Issue 94962 - 2018-06-18 by FGR
  # ----------------------------
  # Issue 94962 - 2018-06-18 by FGR : BEGIN
  If SCLB <> AVOID.ACHAR Then
    [M:PTE0]PAUS = SCLB
  Endif
  # Issue 94962 - 2018-06-18 by FGR : END
  [M:PTE0]PTESTA1 = [V]CST_AYES
  [M:PTE0]PTESTA2 = [V]CST_AYES
  # Issue X3-94973 - 2018-06-14 by TEJAC : START
  [M:PTE0]PTESTA3 = [V]CST_AYES
  [M:PTE0]PTESTA4 = [V]CST_AYES
  [M:PTE0]PTESTA5 = [V]CST_AYES
  # Issue X3-94973 - 2018-06-14 by TEJAC : END
  [M:PTE0]UOM = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, SFCY, "UNITWORK")
  # ----------------------------
  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, SPJT, SPROJECT, SBUDGET, STASK)
  # ----------------------------
  [M:PTE0]FCY = SFCY
  [M:PTE0]PJTDEB = SPJT
  [M:PTE0]PJTFIN = SPJT
  If SPJT <> AVOID.ACHAR and SBUDGET = AVOID.ACHAR and STASK = AVOID.ACHAR Then
    # from PJT
    [M:PTE0]PJTDSPALL = [V]CST_AYES
  Else
    # Others cases
    [M:PTE0]PJTDSPALL = [V]CST_ANO
  Endif
  # ----------------------------
  If DDEBDAT <> [0/0/0] Then
    [M:PTE0]PTEDATDEB = DDEBDAT
    [M:PTE0]PTEDATDEB = gdat$(01,month([M:PTE0]PTEDATDEB),year([M:PTE0]PTEDATDEB))
  Else
    [M:PTE0]PTEDATDEB = gdat$(01,month(date$)-2,year(date$))
  Endif
  [M:PTE0]PTEDATFIN = eomonth(date$)
  # ----------------------------
  If IOPENUM > 0 Then
    [M:CPTE]OPENUM = IOPENUM
  Endif
  # ----------------------------
  # Copy of the Criteria Screen (M:CPTE) vers le masque 1 (M:PTE0)
  Gosub CRITENT From =PROGCNS
Return

###############################################################################
$DEB_CRIT
Local Char SPJT(GLONPJT)
Local Char SPROJECT(GLONOPP)
Local Char SBUDGET(GLONPBU)
Local Char STASK(GLONTAC)

  # ----------------------------------
  SPJT = [M:CPTE]PJTDEBC                                                       # Issue X3-100249 - 2018-07-26 by FGR
  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, SPJT, SPROJECT, SBUDGET, STASK)
  # ----------------------------
  If (SPROJECT <> AVOID.ACHAR and STASK = AVOID.ACHAR) or SPROJECT = AVOID.ACHAR Then
    Diszo [M:CPTE]OPENUM
    #Diszo [M:CPTE]PJTDSPALL                                                   # Issue X3-100249 - 2018-07-26 by FGR
  Endif
  # ----------------------------
  If [M:PTE0]PJTDEB <> [M:PTE0]PJTFIN or [M:PTE0]PJTDSPALL = [V]CST_AYES Then  # Issue X3-100249 - 2018-07-26 by FGR
    [M:CPTE]OPENUM = 0
    Diszo [M:CPTE]OPENUM
  Endif
  # ----------------------------
Return

###############################################################################
$LECTURE
Local Char SKEYCONCAT(250)
Local Decimal DQTY

  # ----------------------------------
  # Issue X3-100249 - 2018-07-30 by FGR : BEGIN
  #If SPJT <> AVOID.ACHAR Then
  #  Diszo [M:PTE0]PJTDEB
  #  Diszo [M:PTE0]PJTFIN
  #Endif
  #If SPJT = AVOID.ACHAR or (SPJT <> AVOID.ACHAR and SBUDGET = AVOID.ACHAR and STASK = AVOID.ACHAR) Then
  #  # Try to see later to hide/show this field
  #  Diszo [M:PTE0]PJTDSPALL
  #Endif
  # Issue X3-100249 - 2018-07-30 by FGR : END
  #-----------------------------------------------
  If GPILNAV > 1 Then
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:PTE0]PJTDEB
      Diszo [M:PTE0]PJTFIN
    Endif
  Endif
  Gosub CHANGE_MSK From GCONSULT
  If CHGPAG < 0 Then
    NOL = MAXLIG
  Endif
  #-----------------------------------------------
  #Load and Apply Filters
  Gosub LOAD_FILTER
  If PROGSPE <> AVOID.ACHAR Then
    ACTION = "FILTRE"
    Gosub ACTION From =PROGSPE
  Endif
  #-----------------------------------------------
  Link [PTE] With [F:VPTE]VPTE0=[F:PTE]CLB;[F:PTE]OPPNUM;[F:PTE]PTEDAT;[F:PTE]PTESEQ,
&                 [F:PTKO]PTKO0=[F:PTE]OPPNUM;[F:PTE]TASCOD;[F:PTE]OPENUM;[F:PTE]OPESPLNUM,
&                 [F:PJOA]PJOA0=[F:PTE]OPPNUM;[F:PTE]TASCOD;[F:PTE]OPENUM;[F:PTE]OPESPLNUM;[F:PTE]POANUM
&              As [LNK]
  #-----------------------------------------------
  If CHGPAG > 0 Then
    SUITE = 1
    If CHGPAG = 1 Then
      RETOUR = 1
    Elsif CHGPAG = 2 Then
      RETOUR = 2
    Endif
    Filter [LNK] Where evalue(WFIL) Order By [F:VPTE]KEYCONCAT
  Else
    RETOUR = 1
    If CHGPAG = -1 Then
      SUITE = 1
    Else
      SUITE = 2
    Endif
    Filter [LNK] Where evalue(WFIL) Order By [F:VPTE]KEYCONCAT Desc
  Endif
  If CHGPAG <> 2 & CHGPAG <> -2 Then
    Raz [M:PTE1]
  Endif
  # --------------------------------
  $BOUCLE
  For [LNK] With Nohint
    # Company filter
    If [M:PTE0]CPY <> AVOID.ACHAR Then
      If [F:FCY]FCY <> [F:PTE]FCY Then
        Read [F:FCY]FCY0=[F:PTE]FCY
        If fstat Then
          Raz [F:FCY]
        Endif
      Endif
      If [F:FCY]LEGCPY <> [M:PTE0]CPY Then
        Goto SUIV
      Endif
    Endif
    # ------------------------------
    If NBLU = 1 Then
      If CHGPAG = 2 or CHGPAG = -2 Then
        Raz [M:PTE1]
      Endif
      NBLU = 2
    Endif
    # ------------------------------
    If CHGPAG > 0 Then
      If NOL >= MAXLIG-1 Then
        SUITE = 2
        Break
      Endif
      NOL += 1
      If NOL = 0 Then
        If CHGPAG = 2 Then
          If [F:VPTE]KEYCONCAT <= SENDKEYCONCAT
            NOL -= 1
            Goto SUIV
          Endif
        Endif
        Gosub SAVE_BEGIN_KEY
      Endif
      Gosub SAVE_END_KEY
    Else
      If NOL <= 0 Then
        RETOUR = 2
        Break
      Endif
      NOL -= 1
      If NOL = MAXLIG-1 Then
        If CHGPAG = -2 Then
          If [F:VPTE]KEYCONCAT >= SBEGKEYCONCAT Then
            NOL+=1
            Goto SUIV
          Endif
        Endif
        Gosub SAVE_END_KEY
      Endif
      Gosub SAVE_BEGIN_KEY
    Endif
    # -----------------------------
    nolign = NOL+1
    [M:PTE1] = [F:PTKO]
    [M:PTE1] = [F:PTE]
    # -----------------------------
    If [F:PTE]OPENUM > 0 Then
        [M:PTE1]ASNPLN(nolign-1) = [F:PJOA]POASTDQTY
        [M:PTE1]ASNCSM(nolign-1) = [F:PJOA]POACSMQTY
        [M:PTE1]ASNREM(nolign-1) = [F:PJOA]POARMNQTY
    Endif
    # -----------------------------
    [M:PTE1]PAUS(nolign-1)=[F:PTE]CLB
    Call LECTEXTRA([M:PTE1]PTENAM(nolign-1), "AUTILIS", "INTUSR", [M:PTE1]PAUS(nolign-1), AVOID.ACHAR) From ATEXTRA
    # -----------------------------
    If [M:PTE1]OPPNUM(nolign-1) <> AVOID.ACHAR Then
      [M:PTE1]OPPDES(nolign-1) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [M:PTE1]OPPNUM(nolign-1))
    Endif
    # -----------------------------
    If [M:PTE1]PBUCOD(nolign-1) <> AVOID.ACHAR Then
      SKEYCONCAT = func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(GACTX, [M:PTE1]OPPNUM(nolign-1), [M:PTE1]PBUCOD(nolign-1))
      [M:PTE1]PBUDES(nolign-1) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, SKEYCONCAT)
    Endif
    # -----------------------------
    If [M:PTE1]TASCOD(nolign-1) <> AVOID.ACHAR Then
      SKEYCONCAT = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GACTX, [M:PTE1]OPPNUM(nolign-1), [M:PTE1]TASCOD(nolign-1))
      [M:PTE1]TASDES(nolign-1) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, SKEYCONCAT)
    Endif
    # -----------------------------
    If [M:PTE1]OPENUM(nolign-1) > 0 Then
      # Issue X3-68131 - 2018-02-12 by FGR : add context : BEGIN
      #SKEYCONCAT = func PJMTSKOPE_CSTD_PROGS.GET_KEYCONCAT_VARIABLES([M:PTE1]OPPNUM(nolign-1), [M:PTE1]TASCOD(nolign-1), [M:PTE1]OPENUM(nolign-1), 1)
      SKEYCONCAT = func PJMTSKOPE_CSTD_PROGS.GET_KEYCONCAT_VARIABLES(GACTX, [M:PTE1]OPPNUM(nolign-1), [M:PTE1]TASCOD(nolign-1), [M:PTE1]OPENUM(nolign-1), 1)
      # Issue X3-68131 - 2018-02-12 by FGR : add context : END
      [M:PTE1]OPEDES(nolign-1) = func PJMTSKOPE_CSTD_PROGS.GET_ROODESAXX(GACTX, SKEYCONCAT)
    Endif
    # -----------------------------
    If [M:PTE0]UOM <> [M:PTE1]PTEUOM(nolign-1) Then
      DQTY = [M:PTE1]PTEQTY(nolign-1)
      Call CONVERT_QTY(GACTX, [M:PTE1]PTEUOM(nolign-1), [M:PTE0]UOM, DQTY) From TRTX3_SYRA
      [M:PTE1]INQQTY(nolign-1) = DQTY
      [M:PTE1]INQUOM(nolign-1) = [M:PTE0]UOM
    Else
      [M:PTE1]INQQTY(nolign-1) = [M:PTE1]PTEQTY(nolign-1)
      [M:PTE1]INQUOM(nolign-1) = [M:PTE1]PTEUOM(nolign-1)
    Endif
    # -----------------------------
    $SUIV
  Next
  Filter [LNK]
  # ----------------------------------
Return

###############################################################################
# CONSPTE0
###############################################################################
Subprog IB_PJTDEB

Local Char SPJT(GLONPIM)
Local Char SPJTBDG(GLONTAC)
Local Char SPJTTSK(GLONPBU)
Local Integer IRET

  # Issue X3-100249 - 2018-07-26 by FGR
  If [M:PTE0]PJTFIN <> AVOID.ACHAR Then
    IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:PTE0]PJTFIN, SPJT, SPJTBDG, SPJTTSK)
    If SPJTBDG <> AVOID.ACHAR Then
      # If end is a budget : begin is mandatory a budget too
      Raz GBOUT2   # Tunnel to project
      Raz GBOUT4   # Tunnel to task
      Raz GBOUT16  # Project selection
      Raz GBOUT18  # Task selection
    Elsif SPJTTSK <> AVOID.ACHAR Then
      # If end is a task : begin is mandatory a task too
      Raz GBOUT2   # Tunnel to project
      Raz GBOUT3   # Tunnel to budget
      Raz GBOUT16  # Project selection
      Raz GBOUT17  # Budget selection
    Else
      # If end is a project : begin is mandatory a project too
      Raz GBOUT3   # Tunnel to budget
      Raz GBOUT4   # Tunnel to task
      Raz GBOUT17  # Budget selection
      Raz GBOUT18  # Task selection
    Endif
  Endif
End

###############################################################################
# Issue X3-100249 - 2018-07-26 by FGR : BEGIN
Subprog AM_PJTDEB(VALEUR)
Variable Char    VALEUR()

Local Char SPJT(GLONPJT)
Local Char SPROJECT(GLONOPP)
Local Char SBUDGET(GLONPBU)
Local Char STASK(GLONTAC)

  [M:CPTE]PJTFINC = VALEUR
  [M:PTE0]PJTFIN = VALEUR
  [M:CPTE]OPENUM = 0
  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, VALEUR, SPROJECT, SBUDGET, STASK)
  If STASK = AVOID.ACHAR Then
    Diszo [M:CPTE]OPENUM
  Else
    Actzo [M:CPTE]OPENUM
  Endif
  If STASK = AVOID.ACHAR and SBUDGET = AVOID.ACHAR Then
    [M:PTE0]PJTDSPALL = [V]CST_AYES
    Affzo [M:PTE0]PJTDSPALL
  Endif
  Affzo [M:CPTE]OPENUM
End

