  If STASK = AVOID.ACHAR and SBUDGET = AVOID.ACHAR Then
    [M:CPTE]PJTDSPALL = [V]CST_AYES
    Affzo [M:CPTE]PJTDSPALL
  Endif
  Affzo [M:CPTE]OPENUM
End

