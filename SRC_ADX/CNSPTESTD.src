###############################################################################
Subprog C_PJTFINC(VALEUR)
Variable Char    VALEUR()

Local Char SPJT(GLONPIM)
Local Char SPJTBDG(GLONTAC)
Local Char SPJTTSK(GLONPBU)
Local Integer IRET

  # Issue X3-100249 - 2018-07-26 by FGR
  If [M:CPTE]PJTDEBC <> AVOID.ACHAR and VALEUR <> AVOID.ACHAR Then
    IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:CPTE]PJTDEBC, SPJT, SPJTBDG, SPJTTSK)
    If SPJTBDG <> AVOID.ACHAR Then
      # If begin is a budget : end is a budget too
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, VALEUR, SPJT, SPJTBDG, SPJTTSK)
      If SPJTBDG = AVOID.ACHAR Then
        GMESSAGE = mess(1108,2260,1)
        mkstat = 2
        End
      Endif
    Elsif SPJTTSK <> AVOID.ACHAR Then
      # If begin is a task : end is a task too
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, VALEUR, SPJT, SPJTBDG, SPJTTSK)
      If SPJTTSK = AVOID.ACHAR Then
        GMESSAGE = mess(1109,2260,1)
        mkstat = 2
        End
      Endif
    Else
      # If begin is a project : end is a project too
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, VALEUR, SPJT, SPJTBDG, SPJTTSK)
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, VALEUR, SPJT, SPJTBDG, SPJTTSK)
      If SPJTTSK <> AVOID.ACHAR or SPJTBDG <> AVOID.ACHAR Then
        GMESSAGE = mess(1110,2260,1)
        mkstat = 2
        End
      Endif
    Endif
  Endif
End

###############################################################################
# SUBROUTNES
###############################################################################
$SAVE_BEGIN_KEY
  SBEGKEYCONCAT = [F:VPTE]KEYCONCAT
Return

###############################################################################
$SAVE_END_KEY
  SENDKEYCONCAT = [F:VPTE]KEYCONCAT
Return

###############################################################################
$LOAD_FILTER
Local Char SPJT(GLONPIM)
Local Char SPJTBUDGET(GLONTAC)
Local Char SPJTTASK(GLONPBU)
Local Integer IRET

  # ----------------------------------
  IFIL = 0
  Raz WFIL
  WFIL(IFIL) = "1=1"
  # ---------------------------------------
  IFIL += 1
  If [M:PTE0]FCY <> AVOID.ACHAR Then
    WFIL(IFIL) += "&[F:PTE]FCY=[M:PTE0]FCY"
  Endif
  # Time actegory
  If [M:PTE0]PTETYP <> AVOID.ACHAR Then
    WFIL(IFIL) += "&[F:PTE]PTETYP=[M:PTE0]PTETYP"
  Endif
  # Employee
  If [M:PTE0]PAUS <> AVOID.ACHAR Then
    WFIL(IFIL) += '&[F:PTE]CLB=[M:PTE0]PAUS'
  Endif
  # Issue X3-100249 - 2018-07-26 by FGR : BEGIN
  ## Budget code
  #If SBUDGET <> AVOID.ACHAR Then
  #  If [M:PTE0]PJTDSPALL <> [V]CST_AYES Then
  #    IFIL += 1
  #    WFIL(IFIL) += "&[F:PTE]PBUCOD='" + SBUDGET + "'"
  #  Endif
  #Endif
  ## Task code
  #If STASK <> AVOID.ACHAR Then
  #  If [M:PTE0]PJTDSPALL <> [V]CST_AYES Then
  #    IFIL += 1
  #    WFIL(IFIL) += "&[F:PTE]TASCOD='" + STASK + "'"
  #  Endif
  #Endif
  # Issue X3-100249 - 2018-07-26 by FGR : END
  # Operation code
  If [M:PTE0]PJTDSPALL <> [V]CST_AYES Then
    If [M:CPTE]OPENUM > 0 Then
      IFIL += 1
      WFIL(IFIL) += "&[F:PTE]OPENUM=[M:CPTE]OPENUM"
    Endif
  Endif
  # Project cost type
  If [M:CPTE]PJMPCC <> AVOID.ACHAR Then
    IFIL += 1
    WFIL(IFIL) += "&[F:PTE]PJMPCC=[M:CPTE]PJMPCC"
  Endif
  # Employee cost type
  If [M:CPTE]CLBPCC <> AVOID.ACHAR Then
    IFIL += 1
    WFIL(IFIL) += "&[F:PTE]CLBPCC=[M:CPTE]CLBPCC"
  Endif
  # Issue X3-94973 - 2018-06-14 by TEJAC : START
  # Status: New, Validated, Controlled, Approved, Posted
  IFIL += 1
  WFIL(IFIL) += '&('
  If [M:PTE0]PTESTA1 = [V]CST_AYES Then
    WFIL(IFIL) += '[F:PTE]PTESTA=1'
  Endif
  If [M:PTE0]PTESTA2 = [V]CST_AYES Then
    If WFIL(IFIL) <> "&(" Then
      WFIL(IFIL) += "|"
    Endif
    WFIL(IFIL) += '[F:PTE]PTESTA=2'
  Endif
  If [M:PTE0]PTESTA3 = [V]CST_AYES Then
    If WFIL(IFIL) <> "&(" Then
      WFIL(IFIL) += "|"
    Endif
    WFIL(IFIL) += '[F:PTE]PTESTA=3'
  Endif
  If [M:PTE0]PTESTA4 = [V]CST_AYES Then
    If WFIL(IFIL) <> "&(" Then
      WFIL(IFIL) += "|"
    Endif
    WFIL(IFIL) += '[F:PTE]PTESTA=4'
  Endif
  If [M:PTE0]PTESTA5 = [V]CST_AYES Then
    If WFIL(IFIL) <> "&(" Then
      WFIL(IFIL) += "|"
    Endif
    WFIL(IFIL) += '[F:PTE]PTESTA=5'
  Endif
  If WFIL(IFIL) = "&(" Then
    WFIL(IFIL) += "0=1"
  Endif
  WFIL(IFIL) += ')'
  #If [M:PTE0]PTESTA1 = [V]CST_ANO and [M:PTE0]PTESTA2 = [V]CST_ANO Then
  #  IFIL += 1
  #  WFIL(IFIL) += '&0=1'
  #Else
  #  IFIL += 1
  #  WFIL(IFIL) += '&('
  #  If [M:PTE0]PTESTA1 = [V]CST_AYES and [M:PTE0]PTESTA2 = [V]CST_AYES Then
  #    WFIL(IFIL) += '[F:PTE]PTESTA=1|[F:PTE]PTESTA=2'
  #  Elsif [M:PTE0]PTESTA1 = [V]CST_AYES Then
  #    WFIL(IFIL) += '[F:PTE]PTESTA=1'
  #  Elsif [M:PTE0]PTESTA2 = [V]CST_AYES Then
  #    WFIL(IFIL) += '[F:PTE]PTESTA=2'
  #  Endif
  #  WFIL(IFIL) += ')'
  #Endif
  # Issue X3-94973 - 2018-06-14 by TEJAC : END
  # ---------------------------------------
  # Project
  # Issue X3-100249 - 2018-07-26 by FGR : BEGIN
  #If dim([M:CPTE]PJTDSPALL) >= 0 and [M:CPTE]PJTDSPALL = [V]CST_AYES and [M:CPTE]PJTDEB <> AVOID.ACHAR Then
  #  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:CPTE]PJTDEB, SPJT, SPJTBUDGET, SPJTTASK)
  #  IFIL += 1
  #  WFIL(IFIL) += '&[F:PTE]OPPNUM="' + SPJT + '"'
  #Else
  #  If [M:CPTE]PJTDEB <> AVOID.ACHAR Then
  #    IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:CPTE]PJTDEB, SPJT, SPJTBUDGET, SPJTTASK)
  #    IFIL += 1
  #    WFIL(IFIL) += '&[F:PTE]OPPNUM>="' + SPJT + '"'
  #  Endif
  #  If [M:CPTE]PJTFIN <> AVOID.ACHAR Then
  #    IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:CPTE]PJTFIN, SPJT, SPJTBUDGET, SPJTTASK)
  #    IFIL += 1
  #    WFIL(IFIL) += '&[F:PTE]OPPNUM<="' + SPJT + '"'
  #  Endif
  #Endif
  If [M:PTE0]PJTDSPALL = [V]CST_AYES Then
    If [M:PTE0]PJTDEB <> AVOID.ACHAR Then
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:PTE0]PJTDEB, SPJT, SPJTBUDGET, SPJTTASK)
      IFIL += 1
      WFIL(IFIL) += '&[F:PTE]OPPNUM>="' + SPJT + '"'
    Endif
    If [M:PTE0]PJTFIN <> AVOID.ACHAR Then
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:PTE0]PJTFIN, SPJT, SPJTBUDGET, SPJTTASK)
      IFIL += 1
      WFIL(IFIL) += '&[F:PTE]OPPNUM<="' + SPJT + '"'
    Endif
  Else
    If [M:PTE0]PJTDEB <> AVOID.ACHAR Then
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:PTE0]PJTDEB, SPJT, SPJTBUDGET, SPJTTASK)
      If SPJTBUDGET <> AVOID.ACHAR Then
        IFIL += 1
        WFIL(IFIL) += '&[F:PTE]PIMPBUCOD>="' + [M:PTE0]PJTDEB + '"'
      Elsif SPJTTASK <> AVOID.ACHAR Then
        IFIL += 1
        WFIL(IFIL) += '&[F:PTE]PIMTASCOD>="' + [M:PTE0]PJTDEB + '"'
      Else
        # Not possible to arrive. But will restrict list for this condition. So, list will be empty
        IFIL += 1
        WFIL(IFIL) += '&[F:PTE]OPPNUM>="' + [M:PTE0]PJTDEB + '"'
        WFIL(IFIL) += '&[F:PTE]TASCOD=""'
        WFIL(IFIL) += '&[F:PTE]PBUCOD=""'
      Endif
    Endif
    If [M:PTE0]PJTFIN <> AVOID.ACHAR Then
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:PTE0]PJTFIN, SPJT, SPJTBUDGET, SPJTTASK)
      If SPJTBUDGET <> AVOID.ACHAR Then
        IFIL += 1
        WFIL(IFIL) += '&[F:PTE]PIMPBUCOD<="' + [M:PTE0]PJTFIN + '"'
      Elsif SPJTTASK <> AVOID.ACHAR Then
        IFIL += 1
        WFIL(IFIL) += '&[F:PTE]PIMTASCOD<="' + [M:PTE0]PJTFIN + '"'
      Else
        # Not possible to arrive. But will restrict list for this condition. So, list will be empty
        IFIL += 1
        WFIL(IFIL) += '&[F:PTE]OPPNUM<="' + [M:PTE0]PJTFIN + '"'
        WFIL(IFIL) += '&[F:PTE]TASCOD=""'
        WFIL(IFIL) += '&[F:PTE]PBUCOD=""'
      Endif
    Endif
  Endif
  # Issue X3-100249 - 2018-07-26 by FGR : END
  # Dates
  If [M:PTE0]PTEDATDEB <> [0/0/0] Then
    IFIL += 1
    WFIL(IFIL) += '&[F:PTE]PTEDAT>=[M:PTE0]PTEDATDEB'
  Endif
  If [M:PTE0]PTEDATFIN <> [0/0/0] Then
    IFIL += 1
    WFIL(IFIL) += '&[F:PTE]PTEDAT<=[M:PTE0]PTEDATFIN'
  Endif
  # ---------------------------------------
  # Pages management
  Case CHGPAG
    When 3
      # Refreshing
      IFIL += 1
      WFIL(IFIL) += "&([F:VPTE]KEYCONCAT>=SBEGKEYCONCAT)"
    When 2
      # After
      IFIL += 1
      WFIL(IFIL) += "&([F:VPTE]KEYCONCAT>=SENDKEYCONCAT)"
    When -2
      # Return
      IFIL += 1
      WFIL(IFIL) += "&([F:VPTE]KEYCONCAT<=SBEGKEYCONCAT)"
  Endcase
  # ---------------------------------------
Return

###################################################################################
Subprog DISPLAY_WITH_STYLE()

Local Integer NI

  For NI = 0 To [M:PTE1]NBLIG-1
    # ----------------------------------
    Chgstl [M:PTE1]CSMQTY(NI) With ""
    Chgstl [M:PTE1]ASNCSM(NI) With ""
    # ----------------------------------
    If [M:PTE1]EXTQTY(NI) > [M:PTE1]CSMQTY(NI) Then
      Chgstl [M:PTE1]CSMQTY(NI) With "BACKGREEN"
    Elsif [M:PTE1]EXTQTY(NI) < [M:PTE1]CSMQTY(NI) Then
      Chgstl [M:PTE1]CSMQTY(NI) With "BACKRED"
    Endif
    # ----------------------------------
    If [M:PTE1]ASNPLN(NI) >= [M:PTE1]ASNCSM(NI) Then
      If [M:PTE1]ASNCSM(NI) > 0 Then
        Chgstl [M:PTE1]ASNCSM(NI) With "BACKGREEN"
      Endif
    Elsif [M:PTE1]ASNPLN(NI) < [M:PTE1]ASNCSM(NI) Then
      Chgstl [M:PTE1]ASNCSM(NI) With "BACKRED"
    Endif
  Next NI
  Affzo [M:PTE1]5
End


###############################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat and [F:ADS]MODULE(8) <> 2 Then
    End
  Endif
  Call VALGTC(APPLI,"PTE") From SUBGTC
End

