#<AdxTL>@(#)0.0.0.0 $Revision$Class Doc sequence numbers
# Supervisor
## CRUD-CLASSE ## ACODNUM
# 2018-11-06 07:00:51 837

Gosub TEST From WMCR_ACODNUM : End

############################################################################################
## R : Subprog AREAD(INSTANCE,CODNUM)
############################################################################################
# ACODNUM : ACODNUM
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet ACODNUM._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = ACODNUM.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(ACODNUM.ACTX.AFOLDER,nomap,"")>0
 Local File ACODNUM [ANM]
 Local File ACODNUM [AAA_]
 Local File ATEXTRA [AXX]
Else
 Local File =ACODNUM.ACTX.AFOLDER+".ACODNUM" [ANM]
 Local File =ACODNUM.ACTX.AFOLDER+".ACODNUM" [AAA_]
 Local File =ACODNUM.ACTX.AFOLDER+".ATEXTRA" [AXX]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet ACODNUM.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [ANM] With
& [AAA_]ANM0 = CODNUM
& As [LNK_]
Return



