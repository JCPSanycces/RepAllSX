#<AdxTL>@(#)9.0.0.0 $Revision$
Local Integer ASTATUS , VLR , DIME
ASTATUS = func ACTIVE_MODULE("1",VLR)
ASTATUS = func ACTIVE_CODE("ADBL","TEST2",DIME,VLR)
Infbox "astatus="+num$(ASTATUS)-"vlr="+num$(VLR)-"dime="+num$(DIME)
End

#---------------------------------------------------------------------#
# Status des paramètres de la solution provenant de la licence
# Si actif, retour de la valeur d'init
# Si inactf, le paramètre ne peut pas être activé
#---------------------------------------------------------------------#

Funprog ACTIVE_MODULE(COD,VLR)
Value    Char     COD
Variable Integer  VLR
Local Integer I , L , OK , ASTATUS
Local Char    TBLIV(GLONADLV)(1..10)
Local File =GDOSX3+".ADELIVER" [ADLV]
Raz VLR
If dim(GACTX._ASYRLIC)<=0 or GACTX._ASYRLIC=null
 ASTATUS = CST_ATRUE
 VLR = 2
Else
 ASTATUS = fmet GACTX.AGETLICMOD([L]COD)
 If ASTATUS=CST_ATRUE
  ASTATUS = func GETPOLICY([L]TBLIV)
  If ASTATUS=CST_ATRUE
   For L=1 To dim([L]TBLIV)
    If [L]TBLIV(L)<>""
     Read [ADLV]ADLV0=[L]TBLIV(L)
     If fstat
      VLR = 1
     Else
      I = find(val([L]COD),[F:ADLV]MODULE)
      If !I
       VLR = 1
      Elsif [F:ADLV]LICMODULE(I-1)=2
       VLR = 2
      Else
       VLR = [F:ADLV]MODENAFLG(I-1)
      Endif
     Endif
    Endif
   Next L
  Endif
 Endif
Endif
End ASTATUS

#---------------------------------#
Funprog ACTIVE_KIT(COD)
Value    Char     COD
Local Integer I , ASTATUS
If dim(GACTX._ASYRLIC)<=0 or GACTX._ASYRLIC=null
 ASTATUS = CST_ATRUE
Else
 ASTATUS = fmet GACTX.AGETLICKIT([L]COD)
Endif
End ASTATUS

#-----------------------------------------------------------------#
Funprog ACTIVE_CODE(COD,DOS,DML,VLR)
Value    Char     COD
Value    Char     DOS
Variable Integer  DML
Variable Integer  VLR
Local Integer I , L , OK , ASTATUS
Local Char    TBLIV(GLONADLV)(1..10)
Local File =GDOSX3+".ADELIVER" [ADLV] , =GDOSX3+".ADELIVERD" [ADLD] , ADOSLIV [ADK]
# Un code activité non référencé dans la licence n'est pas contrôlé
Raz VLR , DML
If dim(GACTX._ASYRLIC)<=0 or GACTX._ASYRLIC=null
 ASTATUS = CST_ATRUE
Else
 ASTATUS = fmet GACTX.AGETLICACV([L]COD)
 If ASTATUS=CST_ATRUE
  ASTATUS = func GETPOLICY([L]TBLIV)
  If ASTATUS=CST_ATRUE
   For L=1 To dim([L]TBLIV)
    If [L]TBLIV(L)<>""
     Read [ADLD]ADLD0=[L]TBLIV(L);[L]COD
     If !fstat
      DML = [F:ADLD]DIMACT
      VLR = [F:ADLD]FLGACT
      ASTATUS = CST_ATRUE
     Endif
    Endif
   Next L
   If clalev([M:ADS5])>0 : # Gestion des dossiers
    For I=1 To [M:ADS5]NBRKIT
     If [M:ADS5]ENAFLG=2
      OK = func ACTIVE_KIT([M:ADS5]CODKIT(I-1))
      If OK=CST_ATRUE
       Read [ADLD]ADLD0=[M:ADS5]CODKIT(I-1);[L]COD
       If !fstat
        DML = [F:ADLD]DIMACT
        VLR = [F:ADLD]FLGACT
       Endif
      Endif
     Endif
    Next I
   Elsif [L]DOS<>""
    For [ADK]ADK0 Where DOSSIER=[L]DOS
     OK = func ACTIVE_KIT([F:ADK]COD)
     If OK=CST_ATRUE
      Read [ADLD]ADLD0=[F:ADK]COD;[L]COD
      If !fstat
       DML = [F:ADLD]DIMACT
       VLR = [F:ADLD]FLGACT
      Endif
     Endif
    Next ADK
   Endif
  Endif
 Endif
Endif
End ASTATUS

