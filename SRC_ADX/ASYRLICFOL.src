#----------------------------------------------------#
Funprog ACTIVE_PARAMETER(COD,VLR)
Value    Char     COD
Variable Char     VLR
Local Integer I , ASTATUS
Raz VLR
If dim(GACTX._ASYRLIC)<=0 or GACTX._ASYRLIC=null
 ASTATUS = CST_ATRUE
Else
 ASTATUS = fmet GACTX.AGETLICPAR([L]COD,[L]VLR)
Endif
End ASTATUS

#--------------------------------------#
Funprog GETPOLICY(COD)
Variable Char COD()(1..)
Local Integer I , J , ASTATUS
Raz COD
#100520
#If dim(GACTX._ASYRLIC)<=0 or GACTX._ASYRLIC=null
If dim(GACTX._ASYRLIC)<=0 or GACTX._ASYRLIC=null or func ASYRLIC.CTLLIC=0
 ASTATUS = CST_ATRUE
Else
 J = 0
 For I=1 To maxtab(GACTX._ASYRLIC.LICENSES)
  If GACTX._ASYRLIC.LICENSES(I)<>null & GACTX._ASYRLIC.LICENSES(I).POLICYCODE<>"" & GACTX._ASYRLIC.LICENSES(I).PARTNERID=""
   J += 1
   COD(J) = GACTX._ASYRLIC.LICENSES(I).POLICYCODE
  Endif
 Next I
 If J=0
  ASTATUS = CST_AFALSE
 Else
  ASTATUS = CST_ATRUE
 Endif
Endif
End ASTATUS
