#<AdxTL>@(#)8.0.0.0 $Revision$
$ACTION
Return

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char VALEUR(10)

Local Integer TABUID(500), NB, LWRI
Local Char    LTMP(100)
Local Integer LPRONUM, LAFFDET
Local Char    CRIT(250)(3)
Local Integer ICRIT

If !clalev([F:IMP]) : Local File IMCDETPRT [IMP] : Endif
If !clalev([F:IMC]) : Local File ITCMATCH  [IMC] : Endif


VALEUR = num$(adxuid(1))
Call SETPARAM("pronum",NBPAR,PARAMETRE,VALEUR) From ETAT

VALEUR = num$([M:ICM0]UNTFLG)
Call SETPARAM("affuni",NBPAR,PARAMETRE,VALEUR) From ETAT

If clalev([M:ICMM])
    # Il faut faire "-1" car ces paramètres sont saisissables en comparaison simple
    # et dans ce cas le superviseur fait "-1"
    VALEUR = num$([M:ICMM]MATFLG-1)
    Call SETPARAM("affmat",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]MACFLG-1)
    Call SETPARAM("affmac",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]LABFLG-1)
    Call SETPARAM("afflab",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]SCOFLG-1)
    Call SETPARAM("affsco",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]OVEFLG-1)
    Call SETPARAM("affove",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]DETFLG-1)
    Call SETPARAM("affdet",NBPAR,PARAMETRE,VALEUR) From ETAT
Endif
    

Call GETPARAM("pronum",NBPAR,PARAMETRE,LTMP) From ETAT
LPRONUM = val(LTMP)

Call GETPARAM("affdet",NBPAR,PARAMETRE,LTMP) From ETAT
LAFFDET = val(LTMP)

# Remplissage de la table ITCDET

Call UIDADX(TABUID,NB) From TRTX3

Trbegin [IMP]

Delete [IMP] Where !find([F:IMP]CURUID,TABUID)
Delete [IMP] Where [F:IMP]CURUID=adxuid(1)

If LAFFDET | 1
    For [IMC] Where PRONUM=LPRONUM
        [F:IMP] = [F:IMC]
        [F:IMP]CURUID=adxuid(1)
        Raz [F:IMP]CST,[F:IMP]CST2
        For I=0 To max(GACTMAT,GACTMAC,GACTLAB)-1
            [F:IMP]BRDCOD=I+1
            If I<GACTMAT
                [F:IMP]CST = [F:IMC]MATCST(I)
                [F:IMP]CST2 = [F:IMC]MATCST2(I)
                [F:IMP]TYPCST = 1
                Write [IMP]
                If fstat
                    Call FSTA("IMP") From GLOCK
                    Break
                Endif
            Endif
            If I<GACTMAC
                [F:IMP]CST = [F:IMC]MACCST(I)
                [F:IMP]CST2 = [F:IMC]MACCST2(I)
                [F:IMP]TYPCST = 2
                Write [IMP]
                If fstat
                    Call FSTA("IMP") From GLOCK
                    Break
                Endif
            Endif
            If I<GACTLAB
                [F:IMP]CST = [F:IMC]LABCST(I)
                [F:IMP]CST2 = [F:IMC]LABCST2(I)
                [F:IMP]TYPCST = 3
                Write [IMP]
                If fstat
                    Call FSTA("IMP") From GLOCK
                    Break
                Endif
            Endif
        Next
    Next
Endif
Commit
End

