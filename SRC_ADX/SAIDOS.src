#<AdxTL>@(#)119.0.0.0 $Revision$
GDOSSIER = ""
Call SAIDOS(GDOSSIER,mess(117,124,1)) : # Changement de dossier

# Changement de dossier
If GDOSSIER<>""
 Local File ADOSSIER [ADS]
 Call LECTURE("ADS",GDOSSIER,"") From CONTOBJ
 If fstat : GDOSSIER = "" : Endif
Endif
If GDOSSIER<>""
 Reb =GDOSSIER
Endif
End

###############################################################################
# Saisie du dossier en changement de dossier...
###############################################################################

Subprog SAIDOS(DOS,TIT)
Variable Char    DOS()
Value    Char    TIT()
Local Char PARAM(30)(1..1)
PARAM(1) = TIT
Call SAISIE_CHAR(DOS,PARAM,"SAIDOS","SAIDOS","XWSAIDOS") From GSAISIE
End

###############################################################################
# Changement de dossier (appelé par l'action CHDOS)
###############################################################################

$ACTION
Case ACTION
 When "INIT"         : Gosub INIT
 When "EXEC"         : Gosub EXEC
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "TITRE"        : Gosub TITR
 When "OK"           : Gosub OK
 When "END"          : Gosub FIN
Endcase
Return

$INIT
If GBROWS<>0 : FIN=1 : Endif
PARAM(1) = mess(117,124,1) : # Changement de dossier
Return

$EXEC
If VALEUR<>""
 Local File ADOSSIER [ADS]
 Call LECTURE("ADS",VALEUR,"") From CONTOBJ
 If fstat : VALEUR = "" : Endif
Endif
If VALEUR<>""
 Reb =VALEUR
Endif
Return

$OUVRE
Local Integer OK
Local File ADOSSIER [ADS]
#94801 ajout adxtyp=25
#If !find(adxtyp,1,9) : # Session primaire client/serveur et web
If !find(adxtyp,1,9,25) : # Session primaire client/serveur, convergence et web
 Call ERREUR(mess(72,139,1)) From GESECRAN
 # Cette fonction n'est accessible qu'à partir d'une session primaire
 FIN = 1 : Return
Endif
Return

$DEBUT
Raz [M]
Return

$TITR
TIT = PARAM(1)
Return

$FIN
VALEUR = ""
Return

$OK
VALEUR = toupper([M]DOSSIER)
Return

###############################################################################
Subprog C_DOSSIER(VALEUR)
Variable Char    VALEUR()
Call C_DOSSIER(VALEUR) From DOSCONT
End
