#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des appels              Module CRM              10 janvier 2001
#
#   SETCCNINF       : Affiche les informations téléphonique de l'intercoteur dans le contexte du tiers
#   DISPBKGCCN      : Affichage du background de l'interlocuteur
#   MNGOMP          : Gère le nombre d'appel effectués restant à effectuer pour
#                            une opération marketing associée à un appel.
#   SETOPG          : Gère le nombre d'appel effectués et restant à effectuer pour une
#                            opération marketing associée à un appel.
#   DEFPIO          : Renvoi le code de Niveau de priorité défini par défaut.
#   DISPICON        : Affichage des icônes
#   SAVECLOB        : Enregistrement des CLOBs
#   DELCLOB         : Suppression des CLOBs
#   LOADCLOB        : Chargement du CLOB compte-rendu
#   SAVECLOB2       : Enregistrement des CLOBs
#   DELCLOB2        : Suppression des CLOBs
#   LOADCLOB2       : Chargement du CLOB compte-rendu
#   SHARECLOB2      : Gestion du partage des clobs avec le marketing
#   CTLASSTOOMP     : Contrôle de l'intégration de l'appel dans une opération marketing
#   PUTINOMP        : Ajout de l'appel dans le nombre des appels de la campagne d'appels
#   REMINOMP        : Retrait de l'appel dans le nombre des appels de la campagne d'appels
#   SELECTRIGHTTELE : Recherche d'un téléacteur qui a fini sa campagne le plus tôt
#   SELECTRIGHTDATE : Recherche de la date de fin d'appel d'un téléacteur pour une campagne d'appels
#   CHECKOMPREP     : Contrôle du représentant pour les appels associés à une campagne d'appels
#   CHECKFEAOMPCLL  : Contrôle de la conformité d'un appel créé depuis une campagne d'appel
#
#  DEFOBJORI        : Définition du type de pièce
#  VERIFCCNCOR      : Vérifie adéquation entre interlocuteur et correspondant
#  DEFCOR           : Affecte le correspondant par défaut
#  VERIFDATE        : Vérifie la validité de la date de l'appel
#  GERE_LCM_CREATION  : gere les données  pour la gestion des en cours en creation
#  GERE_LCM_MODIF     : gere les données  pour la gestion des en cours en modification
#  GERE_LCM_ANNULE    : gere les données  pour la gestion des en cours en annulation
##########################################################################################################
##########################################################################################################
Subprog AFFICHE_BCK_TIERS(SZBPRNUM)
Value Char SZBPRNUM

Local Char SZTYP(GLONDES)

  # FGR 05/04/2011 : X3SUIVI72615
  Call GETBPRTYP(SZBPRNUM, SZTYP, [M:CLL0]CLLCMPAOB) From CRM_UTIL
  Chgtzn [M:CLL0]CLLCMP With SZTYP
  [M:CLL0]CLLCMPLIB = SZTYP
End

##########################################################################################################
Funprog RETOUR_CHANGEABLE(SZICO, SZMSG)
Value Char SZICO
Variable Char SZMSG

Local Integer ICHANGEABLE
Local Integer ISNOCOMPTABLE

  # FGR 16/04/2009 : X3SUIVI54457
  Gosub ICONE_RETOUR
  ICHANGEABLE = 1
  SZMSG = ""
  # Contrôles communs aux deux cas
  If [M:CLL0]CLLDON = 2 Then
    SZMSG = mess(621,177,1)
    ICHANGEABLE = 0
  #Elsif [M:CLL1]CLLORI <> 3 Then
  Elsif [M:CLL1]CLLORIADI <> "MKT3" Then  # FGR 05/03/2010 : X3SUIVI62924
    SZMSG = mess(624,177,1)
    ICHANGEABLE = 0
  Elsif [M:CLL1]CLLCMGNUM = "" Then
    #Campagne marketing précisée
    SZMSG = mess(625,177,1)
    ICHANGEABLE = 0
  Elsif [M:CLL1]CLLOPGNUM = "" Then
    #Opération marketing précisée
    SZMSG = mess(626,177,1)
    ICHANGEABLE = 0
  Endif
  #
  If ICHANGEABLE = 1 Then
    If SZICO = SZICOCOMPTE Then
      # Contrôles pour compter
    Elsif SZICO = SZICONOCOMPTE Then
      # Contrôles pour ne pas compter
      If [M:CLL0]CLLTYP = 1 Then
        SZMSG = mess(622,177,1)
        ICHANGEABLE = 0
      Elsif [M:CLL1]CLLDAT = [00/00/00] Then
        SZMSG = mess(623,177,1)
        ICHANGEABLE = 0
      Endif
    Endif
  Endif
  #
  If ICHANGEABLE = 1 Then
    Read [CMG]CMG0=[M:CLL1]CLLCMGNUM
    If fstat Then
      SZMSG = mess(627,177,1)
      ICHANGEABLE = 0
    Else
      If [F:CMG]CLO = 2 Then
        #Campagne clôturée
        SZMSG = mess(628,177,1)
        ICHANGEABLE = 0
      Else
        Read [OMP]OMP0=[M:CLL1]CLLOPGNUM
        If fstat Then
          SZMSG = mess(629,177,1)
          ICHANGEABLE = 0
        Else
          If [F:OMP]CLO = 2 Then
            #Campagne clôturée
            SZMSG = mess(630,177,1)
            ICHANGEABLE = 0
          Endif
        Endif
      Endif
    Endif
  Endif
End ICHANGEABLE

##########################################################################################################
Subprog DISPICON_RETOUR
Local Integer ICHANGEABLE
Local Char SZMESSAGE(250)

  # FGR 16/04/2009 : X3SUIVI54457
  Gosub ICONE_RETOUR
  #If [M:CLL1]CLLORI <> 1 Then
  If left$([M:CLL1]CLLORIADI, 3) = "MKT" Then  # FGR 05/03/2010 : X3SUIVI62924
    # Si c'est une campagne ou opération marketing
    If [M:CLL1]CLLCMGFLG > 0 Then
      # Non compté dans les retours
      [M:CLL1]CLLORIICO = SZICONOCOMPTE
    Else
      # Compté dans les retours
      [M:CLL1]CLLORIICO = SZICOCOMPTE
    Endif
    If [M:CLL1]CLLORITYP = 2 Then
      # Si généré on peut pas changer
      Grizo [M:CLL1]CLLORIICO
    Else
      # Sinon on peut. C'est au clic sur l'icône qu'on vérifiera si les conditions sont remplies
      Actzo [M:CLL1]CLLORIICO
    Endif
  Else
    [M:CLL1]CLLORIICO = ""
    Grizo [M:CLL1]CLLORIICO
  Endif
  Call INIT_DECODE_ICON
End

##########################################################################################################
Subprog INIT_ICON_RETOUR(ICLLCMGFLG)
Value Integer ICLLCMGFLG

  Gosub ICONE_RETOUR From SUBCLLB
  If ICLLCMGFLG = 0 Then
    [M:CLL1]CLLORIICO = SZICOCOMPTE    # Appels non comptés dans les retours
  Else
    [M:CLL1]CLLORIICO = SZICONOCOMPTE  # Appels comptés dans les retours
  Endif
  Call INIT_DECODE_ICON
End

##########################################################################################################
Subprog INIT_DECODE_ICON

  Gosub ICONE_RETOUR From SUBCLLB
  If [M:CLL1]CLLORIICO = SZICOCOMPTE Then
    [M:CLL1]CLLORIICOD = mess(632,177,1)
  Elsif [M:CLL1]CLLORIICO = SZICONOCOMPTE Then
    [M:CLL1]CLLORIICOD = mess(633,177,1)
  Else
    [M:CLL1]CLLORIICOD = ""
  Endif
  Affzo [M:CLL1]CLLORIICOD
End

##########################################################################################################
$ICONE_RETOUR
Local Char SZICOCOMPTE(3)
Local Char SZICONOCOMPTE(3)

  # FGR 16/04/2009 : X3SUIVI54457
  SZICOCOMPTE = "138"     # Compté dans les retours
  SZICONOCOMPTE = "146"   # Non compté dans les retours
Return

##########################################################################################################
# Affiche les informations téléphonique de l'intercuteur dans le contexte du tiers
###########################################################
$SETCCNINF
  [M:CLL1]CLLCCNCRY = ""
  [M:CLL1]CLLETS = ""
  [M:CLL1]CLLMOB = ""
  [M:CLL0]CLLCCNCLA = ""
  [M:CLL0]CCNTYP = 1
  If [M:CLL0]CLLCMP = "" Then
    Read [AIN]AIN0=[M:CLL0]CLLCCN
    If fstat = 0 Then
      [M:CLL1]CLLCCNCRY = [F:AIN]CRY
      [M:CLL1]CLLETS = [F:AIN]CNTETS
      [M:CLL1]CLLMOB = [F:AIN]CNTMOB
      [M:CLL1]CLLEML = [F:AIN]CNTEMA
      [M:CLL0]CCNTYP = [F:AIN]CNTTYP
      Call BUILDFULNAM("AIN", [M:CLL0]CLLCCNCLA) From CRMUTIL140
    Endif
  Else
    Read [AIN]AIN0=[M:CLL0]CLLCCN
    If fstat = 0 Then
      [M:CLL1]CLLCCNCRY = [F:AIN]CRY
      [M:CLL0]CCNTYP= [F:AIN]CNTTYP
      Call BUILDFULNAM("AIN", [M:CLL0]CLLCCNCLA) From CRMUTIL140
      [M:CLL1]CLLMOB = [F:AIN]CNTMOB
      Filter [CNT] Where [F:CNT]CCNCRM = [M:CLL0]CLLCCN and [F:CNT]BPATYP = 1 and [F:CNT]BPANUM = [M:CLL0]CLLCMP
      For [CNT]
        [M:CLL1]CLLETS = [F:CNT]TEL
        [M:CLL1]CLLEML = [F:CNT]WEB
        Break
      Next
      Filter [CNT]
      If [M:CLL1]CLLETS = "" or [M:CLL1]CLLEML = "" Then
        Read [AIN]AIN0=[M:CLL0]CLLCCN
        If fstat = 0 Then
          If [M:CLL1]CLLETS = "" Then
            [M:CLL1]CLLETS = [F:AIN]CNTETS
          Endif
          If [M:CLL1]CLLEML = "" Then
            [M:CLL1]CLLEML = [F:AIN]CNTEMA
          Endif
        Endif
      Endif
    Endif
  Endif
  If [M:CLL0]CCNTYP <> 1 and [M:CLL0]CCNTYP <> 2 Then
    [M:CLL0]CCNTYP = 1
  Endif
  If [M:CLL0]CCNTYP = 1 Then
    [M:CLL0]CCNOBJ = "AIN"
  Else
    [M:CLL0]CCNOBJ = "LDS"
  Endif
Return

##########################################################################################################
#Affichage du background de l'interlocuteur
######################################################
$DISPBKGCCN
  If GIMPORT Then
    Return
  Endif
  If [M:CLL0]CCNTYP = 0 Then
    [M:CLL0]CCNTYP = 1
  Endif
  Chgtzn [M:CLL0]CLLCCN With mess([M:CLL0]CCNTYP,3038,1)
  # FGR 19/06/2014 : X3SUIVI100693 (début)
  If [M:CLL0]CCNTYP = 1 Then
    [M:CLL0]CCNOBJ = "AIN"
  Else
    [M:CLL0]CCNOBJ = "LDS"
  Endif
  # FGR 19/06/2014 : X3SUIVI100693 (fin)
Return

##########################################################################################################
# Gère le nombre d'appel effectués et restant à effectuer pour une opération marketing associée à un appel.
###########################################################
Subprog MNGOMP(SZTYP, SZNUM, SZSENS)
Value Char SZTYP
Value Char SZNUM
Value Char SZSENS

Local Integer IBUFF1
Local Integer IBUFF2
Local Integer IBDEBTRANSFLG

  IBUFF2 = 0
  IBUFF1 = 0
  #S'il manque des paramètres on ne fait rien.
  If SZTYP = "" or SZNUM = "" or SZSENS = "" Then
    End
  Endif
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If SZTYP = "OMP" Then
    If IBDEBTRANSFLG = 0 Then
      Call DEBTRANS From GLOCK
      Trbegin [OMP]
    Endif
    Readlock [OMP]OMP0=SZNUM
    If !fstat Then
      IBUFF1 = [F:OMP]NBRCLLPCD   #Appels traités
      IBUFF2 = [F:OMP]NBRCLLPCDX  #Appels non traités
      If SZSENS = "ADD" Then
        IBUFF1 += 1
        IBUFF2 -= 1
      Elsif SZSENS = "REMOVE" Then
        IBUFF1 -= 1
        IBUFF2 += 1
      Endif
      [F:OMP]NBRCLLPCD = IBUFF1
      [F:OMP]NBRCLLPCDX = IBUFF2
      Rewrite [OMP]
      If fstat Then
        GMESSAGE = mess(101,141,1)
        GERR = 1
        GOK=0
      Endif
    Endif
    If IBDEBTRANSFLG = 0 Then
      If GOK < 1 Then
        Rollback
      Else
        Commit
      Endif
    Endif
  Endif
End

##########################################################################################################
#Gère le nombre d'appel effectués et restant à effectuer pour une opération marketing associée à un appel.
$SETOPG
  If [M:CLL0]CLLDONINI <> [M:CLL0]CLLDON Then
    If [M:CLL0]CLLDON <> 2 Then
      Call MNGOMP([M:CLL1]CLLOPGTYP, [M:CLL1]CLLOPGNUM, "REMOVE") From SUBCLLB
    Elsif [M:CLL0]CLLDON = 2 Then
      Call MNGOMP([M:CLL1]CLLOPGTYP, [M:CLL1]CLLOPGNUM, "ADD") From SUBCLLB
    Endif
  Endif
Return

##########################################################################################################
#Programme de renvoi du code de niveau de priorité défini par défaut.        #
##############################################################################
Subprog DEFPIO(CODETAB, PIODEF)
Value Integer CODETAB
Variable Char PIODEF

  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  PIODEF = ""
  Filter [ADI] Where [F:ADI]NUMTAB = CODETAB Order By [F:ADI]CODE Asc
  For [ADI]
    If [F:ADI]DEFVAL = 2 Then
      PIODEF = [F:ADI]CODE
      Break
    Endif
  Next
  Filter [ADI]
End

##########################################################################################################
#Affichage des icônes
######################################################
$DISPICON
  Gosub DEFICONNUM From CRMUTIL150
  If len([M:CLL3]FULRPO) > GLONCLE Then
    If [M:CLL3]RPOFLG Then
      [M:CLL3]RPOICO = SZICOSYNDON
    Else
      [M:CLL3]RPOICO = SZICOSYN
    Endif
    Actzo [M:CLL3]RPOICO
  Else
    [M:CLL3]RPOICO = "-1"
    Grizo [M:CLL3]RPOICO
  Endif
  If len([M:CLL1]FULOBJ) > GLONCLE Then
    If [M:CLL1]OBJFLG Then
      [M:CLL1]OBJICO = SZICOSYNDON
    Else
      [M:CLL1]OBJICO = SZICOSYN
    Endif
    Actzo [M:CLL1]OBJICO
  Else
    [M:CLL1]OBJICO = "-1"
    Grizo [M:CLL1]OBJICO
  Endif
Return

##########################################################################################################
#Enregistrement des CLOBs
######################################################
$SAVECLOB
  Gosub DELCLOB
  If GOK < 1 Then
    Return
  Endif
  If [M:CLL3]FULRPO<> "" Then
    Raz [F:HD4]
    [F:HD4]NUM = [M:CLL3]NUMFULRPO
    [F:HD4]TYP = [M:CLL3]TYPFULRPO
    [F:HD4]CLOB = [M:CLL3]FULRPO
    Write [HD4]
    If fstat Then
      #Erreur lors de l'enregistrement du compte-rendu de l'appel. Transaction abandonnée.
      GMESSAGE = mess(871,182,1)
      GERR = 1
      Call FSTA("HD4") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB
  Delete [HD4] Where [F:HD4]NUM = [M:CLL3]NUMFULRPO and [F:HD4]TYP = [M:CLL3]TYPFULRPO
  If fstat Then
    #Erreur lors de la suppression du compte-rendu de l'appel. Transaction abandonnée.
    GMESSAGE = mess(873,182,1)
    GERR = 1
    Call FSTA("HD4") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB compte-rendu
######################################################
$LOADCLOB
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:CLL3]NUMFULRPO = "" Then
    Raz [M:CLL3]FULRPO
    ILOOKFORCLOB = 0
  Endif
  If [M:CLL3]TYPFULRPO = "" Then
    Raz [M:CLL3]FULRPO
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD4]HD40=[M:CLL3]NUMFULRPO;[M:CLL3]TYPFULRPO
    If fstat Then
      Raz [M:CLL3]FULRPO
    Else
      [M:CLL3]FULRPO = [F:HD4]CLOB
    Endif
  Endif
Return

##########################################################################################################
#Enregistrement des CLOBs
######################################################
$SAVECLOB2
  If [M:CLL1]TYPFULOBJ <> "CLLOBJ" Then
    Return
  Endif
  Gosub DELCLOB2
  If GOK < 1 Then
    Return
  Endif
  #Objet de l'action
  If [M:CLL1]FULOBJ <> "" Then
    Raz [F:HD5]
    [F:HD5]NUM = [M:CLL1]NUMFULOBJ
    [F:HD5]TYP = [M:CLL1]TYPFULOBJ
    [F:HD5]CLOB = [M:CLL1]FULOBJ
    Write [HD5]
    If fstat Then
      #Erreur lors de l'enregistrement de l'objet de l'appel. Transaction abandonnée.
      GMESSAGE = mess(872,182,1)
      GERR = 1
      Call FSTA("HD5") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB2
  If [M:CLL1]TYPFULOBJ <> "CLLOBJ" Then
    Return
  Endif
  Delete [HD5] Where [F:HD5]NUM = [M:CLL1]NUMFULOBJ and [F:HD5]TYP = [M:CLL1]TYPFULOBJ
  If fstat Then
    #Erreur lors de la suppression de l'objet de l'appel. Transaction abandonnée.
    GMESSAGE = mess(874,182,1)
    GERR = 1
    Call FSTA("HD5") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB compte-rendu
######################################################
$LOADCLOB2
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:CLL1]NUMFULOBJ = "" Then
    Raz [M:CLL1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If [M:CLL1]TYPFULOBJ = "" Then
    Raz [M:CLL1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD5]HD50=[M:CLL1]NUMFULOBJ;[M:CLL1]TYPFULOBJ
    If fstat Then
      Raz [M:CLL1]FULOBJ
    Else
      [M:CLL1]FULOBJ = [F:HD5]CLOB
    Endif
  Endif
Return

##########################################################################################################
#Gestion du partage des clobs avec le marketing
######################################################
$SHARECLOB2
  If [M:CLL1]TYPFULOBJ = "CLLOBJ" Then
    [M:CLL1]NUMFULOBJ = [M:CLL0]CLLNUM
    [M:CLL1]TYPFULOBJ = "CLLOBJ"
    [F:CLL]NUMFULOBJ = [M:CLL0]CLLNUM
    [F:CLL]TYPFULOBJ = "CLLOBJ"
  Else
    If [M:CLL1]TYPFULOBJ = "OMP" Then
      #Lu sur campagne d'appels
      Read [HD5]HD50=[M:CLL1]CLLOPGNUM;"OMP"
      If fstat Then
        [M:CLL1]NUMFULOBJ = [M:CLL0]CLLNUM
        [M:CLL1]TYPFULOBJ = "CLLOBJ"
        [F:CLL]NUMFULOBJ = [M:CLL0]CLLNUM
        [F:CLL]TYPFULOBJ = "CLLOBJ"
      Else
        If [M:CLL1]FULOBJ <> [F:HD5]CLOB Then
          [M:CLL1]NUMFULOBJ = [M:CLL0]CLLNUM
          [M:CLL1]TYPFULOBJ = "CLLOBJ"
          [F:CLL]NUMFULOBJ = [M:CLL0]CLLNUM
          [F:CLL]TYPFULOBJ = "CLLOBJ"
        Endif
      Endif
    Else
      #Lu sur campagne marketing
      Read [HD5]HD50=[M:CLL1]CLLCMGNUM;"CMG"
      If fstat Then
        [M:CLL1]NUMFULOBJ = [M:CLL0]CLLNUM
        [M:CLL1]TYPFULOBJ = "CLLOBJ"
        [F:CLL]NUMFULOBJ = [M:CLL0]CLLNUM
        [F:CLL]TYPFULOBJ = "CLLOBJ"
      Else
        If [M:CLL1]FULOBJ <> [F:HD5]CLOB Then
          [M:CLL1]NUMFULOBJ = [M:CLL0]CLLNUM
          [M:CLL1]TYPFULOBJ = "CLLOBJ"
          [F:CLL]NUMFULOBJ = [M:CLL0]CLLNUM
          [F:CLL]TYPFULOBJ = "CLLOBJ"
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Ajout de l'appel dans le nombre des appels de la campagne d'appels
####################################################################
Subprog PUTINOMP(SZCLLCMGNUM, SZCLLOPGNUM, SZCLLREP, ICLL3OMPFLG)
Value Char SZCLLCMGNUM
Value Char SZCLLOPGNUM
Value Char SZCLLREP
Variable Decimal ICLL3OMPFLG

  Readlock [OMP]OMP0=SZCLLOPGNUM
  If fstat Then
    #L'intégration de l'appel dans la campagne d'appels indiquée a échoué.
    GMESSAGE = mess(975,182,1)
    GERR = 1
    Call FSTA("OMP") From GLOCK
    GOK = 0
    End
  Endif
  [F:OMP]NBRCLLOMP += 1
  [F:OMP]NBRCLLPCDX += 1
  Rewrite [OMP]
  If fstat Then
    #L'intégration de l'appel dans la campagne d'appels indiquée a échoué.
    GMESSAGE = mess(975,182,1)
    GERR = 1
    Call FSTA("OMP") From GLOCK
    GOK = 0
    End
  Endif
  If ICLL3OMPFLG Then
    Raz [F:DVA]
    [F:DVA]OBC = "OMP"
    [F:DVA]PARAM = SZCLLOPGNUM + SZCLLREP
    [F:DVA]ALHX(0) = SZCLLOPGNUM
    [F:DVA]ALHX(1) = SZCLLREP
    [F:DVA]INTX(0) = 1
    Write [DVA]
    If fstat Then
      #L'intégration du représentant dans la campagne d'appels indiquée a échoué.
      GMESSAGE = mess(127,177,1)
      GERR = 1
      Call FSTA("DVA") From GLOCK
      GOK = 0
      End
    Endif
  Else
    Filter [DVA] Where [F:DVA]OBC = "OMP" and [F:DVA]ALHX(0) = SZCLLOPGNUM and [F:DVA]ALHX(1) = SZCLLREP
    For [DVA]
      [F:DVA]INTX(0) += 1
      Rewrite [DVA]
      If fstat Then
        #L'intégration de l'appel dans la campagne d'appels indiquée a échoué.
        GMESSAGE = mess(975,182,1)
        GERR = 1
        Call FSTA("DVA") From GLOCK
        GOK = 0
        Break
      Endif
    Next
    Filter [DVA]
    If GERR Then
      End
    Endif
  Endif
  ICLL3OMPFLG = 0
End

##########################################################################################################
#Retrait de l'appel dans le nombre des appels de la campagne d'appels
####################################################################
Subprog REMINOMP(SZCLLNUM, SZCLLCMGNUM, SZCLLOPGNUM, SZCLLREP)
Value Char SZCLLNUM
Value Char SZCLLCMGNUM
Value Char SZCLLOPGNUM
Value Char SZCLLREP

Local Integer INBOMPREP
Local Integer INBOMPCLL
Local Integer INBOMPDONCLL

  If !clalev([F:CLLW]) : Local File PHONECALL [CLLW] : Endif
  INBOMPDONCLL = 0
  INBOMPCLL = 0
  INBOMPREP = 0
  Filter [CLLW] Where [F:CLLW]CLLCMGNUM = SZCLLCMGNUM and [F:CLLW]CLLOPGNUM = SZCLLOPGNUM and [F:CLLW]CLLOPGTYP = "OMP" and [F:CLLW]CLLCMGFLG > 0
&                 and [F:CLLW]CLLNUM <> SZCLLNUM
  For [CLLW]CLL6
    If [F:CLLW]CLLREP = SZCLLREP Then
      INBOMPREP += 1
    Endif
    If [F:CLLW]CLLDON = 2 Then
      INBOMPDONCLL += 1
    Endif
    INBOMPCLL += 1
  Next
  Filter [CLLW]
  Readlock [OMP]OMP0=SZCLLOPGNUM
  If fstat Then
    #Le retrait de l'appel de la campagne d'appels a échoué.
    GMESSAGE = mess(976,182,1)
    GERR = 1
    Call FSTA("OMP") From GLOCK
    GOK = 0
    End
  Endif
  [F:OMP]NBRCLLOMP = INBOMPCLL
  [F:OMP]NBRCLLPCD = INBOMPDONCLL
  [F:OMP]NBRCLLPCDX = INBOMPCLL - INBOMPDONCLL
  Rewrite [OMP]
  If fstat Then
    #Le retrait de l'appel de la campagne d'appels a échoué.
    GMESSAGE = mess(976,182,1)
    GERR = 1
    Call FSTA("OMP") From GLOCK
    GOK = 0
    End
  Endif
  Filter [DVA] Where [F:DVA]OBC = "OMP" and [F:DVA]ALHX(0) = SZCLLOPGNUM and [F:DVA]ALHX(1) = SZCLLREP
  For [DVA]
    [F:DVA]INTX(0) = INBOMPREP
    Rewrite [DVA]
    If fstat Then
      #L'intégration de l'appel dans la campagne d'appels indiquée a échoué.
      GMESSAGE = mess(975,182,1)
      GERR = 1
      Call FSTA("DVA") From GLOCK
      GOK = 0
      Break
    Endif
  Next
  Filter [DVA]
End

##########################################################################################################
# Recherche d'un téléacteur qui a fini sa campagne le plus tôt
#########################################################################
Subprog SELECTRIGHTTELE(SZOPGNUM, SZRIGHTTELE, DRIGHTDATE)
Value Char SZOPGNUM
Variable Char SZRIGHTTELE
Variable Date DRIGHTDATE

Local Date DMINDATE
Local Char SZTLS(GLONREP)

  If SZOPGNUM = "" Then
    End
  Endif
  DMINDATE = [00/00/00]
  SZTLS = ""
  Filter [DVA] Where [F:DVA]OBC = "OMP" and [F:DVA]ALHX(0) = SZOPGNUM Order By [F:DVA]INTX(0) Asc
  For [DVA]
    If [F:DVA]ALHX(1) <> "" Then
      Filter [CLL] Where [F:CLL]CLLOPGTYP = "OMP" and [F:CLL]CLLOPGNUM = SZOPGNUM and [F:CLL]CLLCMGFLG > 0 and [F:CLL]CLLREP = [F:DVA]ALHX(1) and [F:CLL]CLLDON <> 2
&               Order By [F:CLL]CLLDAT Desc
      For [CLL] Hint Key CLL6
        If DMINDATE = [00/00/00] Then
          DMINDATE = [F:CLL]CLLDAT
          SZTLS = [F:CLL]CLLREP
        Else
          If [F:CLL]CLLDAT < DMINDATE Then
            DMINDATE = [F:CLL]CLLDAT
            SZTLS = [F:CLL]CLLREP
          Endif
        Endif
        Break
      Next
      Filter [CLL]
    Endif
  Next
  Filter [DVA]
  SZRIGHTTELE = SZTLS
  If dayn(DMINDATE) > 4 Then
    DRIGHTDATE = DMINDATE
  Else
    DRIGHTDATE = DMINDATE + 1
  Endif
End

##########################################################################################################
# Recherche de la date de fin d'appel d'un téléacteur pour une campagne d'appels
#########################################################################
Subprog SELECTRIGHTDATE(SZOPGNUM, SZRIGHTTELE, DRIGHTDATE)
Value Char SZOPGNUM
Value Char SZRIGHTTELE
Variable Date DRIGHTDATE

  DRIGHTDATE = date$
  If SZOPGNUM = "" Then
    End
  Endif
  If SZRIGHTTELE = "" Then
    End
  Endif
  Filter [CLL] Where [F:CLL]CLLOPGTYP = "OMP" and [F:CLL]CLLOPGNUM = SZOPGNUM and [F:CLL]CLLCMGFLG > 0 and [F:CLL]CLLREP = SZRIGHTTELE and [F:CLL]CLLDON <> 2
&           Order By [F:CLL]CLLDAT Desc
  For [CLL] Hint Key CLL6
    If dayn([F:CLL]CLLDAT) > 4 Then
      DRIGHTDATE = [F:CLL]CLLDAT
    Else
      DRIGHTDATE = [F:CLL]CLLDAT + 1
    Endif
    Break
  Next
  Filter [CLL]
End

##########################################################################################################
# Contrôle du représentant pour les appels associés à une campagne d'appels
#########################################################################
$CHECKOMPREP
Local Integer IREPCOMPLI
Local Char SZMESSCOMPLI(250)
Local Integer IREPCOMPLIANT
Local Char SZORIGINE

  # FGR 20/04/2009 : X3SUIVI54457 : On ne teste plus si on est venu de GESOMP. On propose d'ajouter le représentant
  SZMESSCOMPLI = ""
  IREPCOMPLI = 0
  Raz SZORIGINE
  If [M:CLL1]CLLCMGFLG = 1 Then  # FGR 20/04/2009 : X3SUIVI54457 : Et c'est "If [M:CLL1]CLLCMGFLG = 1 Then" et pas "If [M:CLL1]CLLCMGFLG = 0 Then"
    #Non généré par campagne
    If [M:CLL1]CLLCMGNUM <> "" Then
      #Campagne marketing précisée
      If [M:CLL1]CLLOPGNUM <> "" Then
        #Opération marketing précisée
        IREPCOMPLIANT = 0
        Filter [DVA] Where [F:DVA]OBC = "OMP" and [F:DVA]ALHX(0) = [M:CLL1]CLLOPGNUM and [F:DVA]ALHX(1) = [M:CLL1]CLLREP
        For [DVA]
          IREPCOMPLIANT = 1
          Break  : # FGR 20/04/2009 : X3SUIVI54457 : une fois suffit
        Next
        Filter [DVA]
        If IREPCOMPLIANT = 0 Then
          # Ce représentant ne participe pas à la campagne d'appels.
          # Souhaitez-vous l'intégrer à cette campagne ?
          SZMESSCOMPLI = mess(124,177,1) - mess(125,177,1)
          IREPCOMPLI = 0
          Call OUINON(SZMESSCOMPLI, IREPCOMPLI) From GESECRAN
          If IREPCOMPLI = 2 Then
            [M:CLL1]CLL3OMPFLG = 1
          Else
            #Ce représentant ne participera donc pas à la campagne d'appels.
            GMESSAGE = mess(126,177,1)
            GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
            OK = 0
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Contrôle de la conformité d'un appel créé depuis une campagne d'appel
############################################################
$CHECKFEAOMPCLL
Local Char SZCTL2CLOB(250)

  Raz SZCTL2CLOB
  Setlob SZCTL2CLOB With [M:CLL3]FULRPO
  If SZCTL2CLOB <> "" Then
    #L'appel ne doit pas comporter de compte-rendu. Création refusée.
    GMESSAGE = mess(132,177,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    Return
  Endif
  If [M:CLL0]CLLDON = 2 Then
    #L'appel ne doit pas être effectué. Création refusée.
    GMESSAGE = mess(130,177,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    Return
  Endif
  If [M:CLL0]CLLTYP <> 2 Then
    #L'appel doit être sortant. Création refusée.
    GMESSAGE = mess(131,177,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    Return
  Endif
Return

##########################################################################################################
#Définition de CLLDATX
$SETCLLDATX
  If [M:CLL1]CLLDAT <> [00/00/00] Then
    #date flou
    [M:CLL1]CLLDATX = [M:CLL1]CLLDAT
  Endif
Return

##########################################################################################################
#CHECK UNUSED_BEGIN
$DEFOBJORIOLD
  #Définition du type de pièce
  Case [M:CLL1]CLLORI
    When 0
      #[M:CLL1]CLLORIOBC = ""       # FGR 04/03/2010 : X3SUIVI62924
      [M:CLL1]CLLORIAVA = ""        # FGR 12/02/2009 : X3SUIVI52443
    When 1
      #[M:CLL1]CLLORIOBC = ""       # FGR 04/03/2010 : X3SUIVI62924
      [M:CLL1]CLLORIAVA = ""        # FGR 12/02/2009 : X3SUIVI52443
    When 2
      #[M:CLL1]CLLORIOBC = "OMM"    # FGR 04/03/2010 : X3SUIVI62924
      [M:CLL1]CLLORIAVA = "OMMNUM"  # FGR 12/02/2009 : X3SUIVI52443
    When 3
      #[M:CLL1]CLLORIOBC = "OMP"    # FGR 04/03/2010 : X3SUIVI62924
      [M:CLL1]CLLORIAVA = "OMPNUM"  # FGR 12/02/2009 : X3SUIVI52443
    When 4
      #[M:CLL1]CLLORIOBC = "OMT"    # FGR 04/03/2010 : X3SUIVI62924
      [M:CLL1]CLLORIAVA = "OMTNUM"  # FGR 12/02/2009 : X3SUIVI52443
    When 5
      #[M:CLL1]CLLORIOBC = "OMN"    # FGR 04/03/2010 : X3SUIVI62924
      [M:CLL1]CLLORIAVA = "OMNNUM"  # FGR 12/02/2009 : X3SUIVI52443
    When 6
      #[M:CLL1]CLLORIOBC = "CMG"    # FGR 04/03/2010 : X3SUIVI62924
      [M:CLL1]CLLORIAVA = "NUM"     # FGR 12/02/2009 : X3SUIVI52443
    When Default
  Endcase
Return
#CHECK UNUSED_END

##########################################################################################################
#Vérification cohérence entre origine et numéro de pièce
$VERIFORI
  # FGR 04/03/2010 : X3SUIVI62924
  If [M:CLL1]CLLORIAOB <> "" and [M:CLL1]CLLORIVCR = "" Then
    #Le numéro de pièce / ligne est obligtoire pour la liaison spécifiée.
    GMESSAGE = mess(442,177,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
  Endif
Return

#CHECK UNUSED_BEGIN
$VERIFORIOLD
Local Integer IBOBLOGATOIRE

  Case [M:CLL1]CLLORI
    When 2
      IBOBLOGATOIRE = 1
    When 3
      IBOBLOGATOIRE = 1
    When 4
      IBOBLOGATOIRE = 1
    When 5
      IBOBLOGATOIRE = 1
    When 6
      IBOBLOGATOIRE = 1
    When Default
      IBOBLOGATOIRE = 0
  Endcase
  If IBOBLOGATOIRE = 1 Then
    If [M:CLL1]CLLORIVCR = "" Then
      #Le numéro de pièce / ligne est obligtoire pour la liaison spécifiée.
      GMESSAGE = mess(442,177,1)
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
    Endif
  Endif
Return
#CHECK UNUSED_END

##########################################################################################################
# Vérifie adéquation entre interlocuteur et correspondant
$VERIFCCNCOR
  #Vérification interlocuteur/correspondant
  If [M:CLL0]CLLCCN <> "" Then
    If [M:CLL0]CLLCOR <> "" Then
      Read [COR]COR0=[M:CLL0]CLLCOR
      If fstat = 0 Then
        If [F:COR]CNTNUM <> [M:CLL0]CLLCCN Then
          [M:CLL0]CLLCOR = ""
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Affecte le correspondant par défaut
$DEFCOR
Local Integer IBFOUND

  IBFOUND = 0
  If [M:CLL0]CLLCOR = "" Then
    If [M:CLL0]CLLCCN <> "" Then
      If [M:CLL0]CLLCMP <> "" Then
        For [COR] Where [F:COR]CNTNUM = [M:CLL0]CLLCCN and [F:COR]BPRNUM = [M:CLL0]CLLCMP
          IBFOUND = 1
          Break
        Next
      Endif
      If IBFOUND = 0 Then
        For [COR] Where [F:COR]CNTNUM = [M:CLL0]CLLCCN and [F:COR]BPRNUM = ""
          IBFOUND = 1
          Break
        Next
      Endif
      If IBFOUND = 1 Then
        [M:CLL0]CLLCOR = [F:COR]CORNUM
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Vérifie la validité de la date de l'appel
$VERIFDATE
  If [M:CLL0]CLLDON = 2 Then
    If [M:CLL1]CLLDAT = [00/00/00] Then
      #La date de l'appel est obligatoire pour un appel effectué.
      GMESSAGE = mess(511,177,1)
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
    Endif
  Endif
Return

##########################################################################################################
# gere les données  pour la gestion des en cours en creation
$GERE_LCM_CREATION
  # FGR 12/08/2009 : X3SUIVI57005 : Revu toute cette partie pour laisser faire S/P qui vont bien
  Raz [BPR]
  If [M:CLL0]CLLCMP <> "" Then
    Read [BPR]BPR0=[M:CLL0]CLLCMP
    If fstat <> 0 Then
      #Erreur lors de la lecture du tiers + " : " +[M:CLL0]CLLCMP
      GMESSAGE = mess(445,177,1) - ":" - [M:CLL0]CLLCMP
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      GOK = 0
      Return
    Endif
    If [F:BPR]BPCFLG <> 2 and [F:BPR]PPTFLG <> 2 Then
      Return
    Endif
    # FGR 12/08/2009 : X3SUIVI57005 : Ce sont les S/P fais pour qui gèrent, on ne le fait pas directement par LCM_MAJINFO
    #                                 En plus directement ça ne tient pas compte de la priorité Appel/Tâche/RdV
    If [M:CLL0]CLLDON = 2 Then
      # Gestion premier contact
      Call LCM_BPRFIRSTCNT ([M:CLL0]CLLCMP, GSOCIETE, [M:CLL0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      # Gestion dernier contact
      Call LCM_BPRLASTCNT ([M:CLL0]CLLCMP, GSOCIETE, [M:CLL0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Else
      # Gestion prochain contact
      Call LCM_BPRNEXTCNT ([M:CLL0]CLLCMP, GSOCIETE, [M:CLL0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Endif
  Endif
Return

##########################################################################################################
# gere les données  pour la gestion des en cours en modification
$GERE_LCM_MODIF
Local Integer IBTRAITBPR
Local Integer IBTRAITBPRINI
Local Char SZSOCINI(GLONCPY)
Local Integer IBCHANGE_LCMKEY

  IBTRAITBPR = 0
  IBTRAITBPRINI = 0
  Raz SZSOCINI
  IBCHANGE_LCMKEY = 0
  Raz [BPR]
  If [M:CLL0]SALFCYINI = [M:CLL0]SALFCY and [M:CLL0]CLLCMPINI = [M:CLL0]CLLCMP and
&    [M:CLL0]CLLDONINI = [M:CLL0]CLLDON and [M:CLL1]CLLDATXINI = [M:CLL1]CLLDATX
& Then
    #Rien n'a été changé sur les données encours, on sort
    Return
  Endif
  If [M:CLL0]CLLCMP <> "" Then
    Read [BPR]BPR0=[M:CLL0]CLLCMP
    If fstat <> 0 Then
      #Erreur lors de la lecture du tiers + " : " +[M:CLL0]CLLCMP
      GMESSAGE = mess(445,177,1) - ":" - [M:CLL0]CLLCMP
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      GOK = 0
      Return
    Endif
    If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
      IBTRAITBPR = 1
    Endif
  Endif
  If [M:CLL0]SALFCYINI <> [M:CLL0]SALFCY Then
    #On recherche la société initiale
    If [M:CLL0]SALFCYINI <> "" Then
      Read [FCY]FCY0=[M:CLL0]SALFCYINI
      If fstat = 0 Then
        SZSOCINI = [F:FCY]LEGCPY
      Else
        #Erreur lors de la lecture de la table des sites
        GMESSAGE = mess(444,177,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Else
      SZSOCINI = ""
    Endif
    If SZSOCINI <> GSOCIETE Then
      IBCHANGE_LCMKEY = 1
    Endif
  Else
    SZSOCINI = GSOCIETE
  Endif
  If [M:CLL0]CLLCMPINI <> [M:CLL0]CLLCMP Then
    If [M:CLL0]CLLCMPINI <> "" Then
      IBCHANGE_LCMKEY = 1
      Read [BPR]BPR0=[M:CLL0]CLLCMPINI
      If fstat <> 0 Then
        #Erreur lors de la lecture du tiers - ":" -[M:CLL0]CLLCMP
        GMESSAGE = mess(445,177,1) - ":" - [M:CLL0]CLLCMPINI
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
        IBTRAITBPRINI = 1
      Endif
    Endif
  Else
    IBTRAITBPRINI = IBTRAITBPR
  Endif
  If IBCHANGE_LCMKEY = 1 and IBTRAITBPRINI = 1 Then
    # On a changé de société. On remet à jour les infos pour l'ancienne société
    If [M:CLL0]CLLDONINI = 2 Then
      # Gestion premier contact
      Call LCM_BPRFIRSTCNT ([M:CLL0]CLLCMPINI, SZSOCINI, [M:CLL0]SALFCYINI, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      # Gestion dernier contact
      Call LCM_BPRLASTCNT ([M:CLL0]CLLCMPINI, SZSOCINI, [M:CLL0]SALFCYINI, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Else
      # Gestion prochain contact
      Call LCM_BPRNEXTCNT ([M:CLL0]CLLCMPINI, SZSOCINI, [M:CLL0]SALFCYINI, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Endif
  Endif
  #
  If IBTRAITBPR = 1 Then
    # C'est un client ou un prospect
    If [M:CLL0]CLLDONINI = [M:CLL0]CLLDON Then
      # Le statut n'a pas changé : GERE_LCM_CREATION fait tout ce qu'il faut.
      Gosub GERE_LCM_CREATION
    Else
      # Le statut n'a pas changé : il faut refaire les trois étapes
      # Gestion premier contact
      Call LCM_BPRFIRSTCNT ([M:CLL0]CLLCMP, GSOCIETE, [M:CLL0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      # Gestion dernier contact
      Call LCM_BPRLASTCNT ([M:CLL0]CLLCMP, GSOCIETE, [M:CLL0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      # Gestion prochain contact
      Call LCM_BPRNEXTCNT ([M:CLL0]CLLCMP, GSOCIETE, [M:CLL0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Endif
  Endif
Return

##########################################################################################################
# gere les données pour la gestion des en cours en annulation
$GERE_LCM_ANNULE
Local Integer IBSUPR

  If [M:CLL0]CLLCMP = "" Then
    Return
  Endif
  Raz [BPR]
  Read [BPR]BPR0=[M:CLL0]CLLCMP
  If fstat <> 0 Then
    #Erreur lors de la lecture du tiers - ":" -[M:CLL0]CLLCMP
    GMESSAGE = mess(445,177,1) - ":" - [M:CLL0]CLLCMP
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    GOK = 0
    Return
  Endif
  If [F:BPR]BPCFLG <> 2 and [F:BPR]PPTFLG <> 2 Then
    Return
  Endif
  IBSUPR = 0
  #If faut supprimer les anciennes données
  Call LCM_DELKEY(14, [M:CLL0]CLLNUM, IBSUPR, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    GOK = 0
    Return
  Endif
  If IBSUPR = 1 Then
    # on a supprimé quelque chose : donc on refait la recherche
    If [M:CLL0]CLLDONINI = 2 Then
      Call LCM_BPRFIRSTCNT ([M:CLL0]CLLCMP, GSOCIETE, [M:CLL0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      Call LCM_BPRLASTCNT ([M:CLL0]CLLCMP, GSOCIETE, [M:CLL0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Else
      Call LCM_BPRNEXTCNT ([M:CLL0]CLLCMP, GSOCIETE, [M:CLL0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Endif
  Endif
Return
