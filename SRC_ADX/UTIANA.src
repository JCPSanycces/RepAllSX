#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTIANA   Mise à jour du code activité ANA                              #
#          Dimension MINI= 9                                             #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTIANA(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTIANA(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTIANA : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ACV])=0  : Local File =DOSSIER+".ACTIV"   [ACV]  : Endif
If clalev([F:ATZA])=0 : Local File =DOSSIER+".ATABZON" [ATZA] : Endif
If clalev([F:ATB])=0  : Local File =DOSSIER+".ATABLE"  [ATB]  : Endif
If clalev([F:ATZ])=0  : Local File =DOSSIER+".ATABZON" [ATZ]  : Endif
If clalev([F:ATI])=0  : Local File =DOSSIER+".ATABIND" [ATI]  : Endif
If clalev([F:ATY])=0  : Local File =DOSSIER+".ATYPE"   [ATY]  : Endif
If clalev([F:ANX])=0  : Local File =DOSSIER+".AINDEX"  [ANX]  : Endif

Local Char TABLE(GLONATB)

Raz COMPTEUR, TABLE
Call DEBTRANS From GLOCK

Trbegin [ACV]
Readlock [ACV]CODACT="ANA"
If !fstat
 [F:ACV]DIMFIL = 9
 Rewrite [ACV]
 If fstat
  GOK = 0 : Call FSTA("ACV") From GLOCK
 Endif
Else
 GOK=0 : Call RSTA("ACV","ANA") From GLOCK
Endif
If GOK=0
 Close Local File [ACV], [ATZA], [ATB], [ATZ], [ATI], [ATY], [ANX]
 Rollback : End
Endif
Commit

If dim(GCOEFTAB)<0
 Global Decimal GCOEFTAB
 GCOEFTAB = 0.5
Endif
Filter [ATZA] Where CODACT="ANA"
For [ATZA]
 If  TABLE <> [F:ATZA]CODFIC
  TABLE = [F:ATZA]CODFIC
  Call MAJTAB(TABLE,0) From DOSTAB
  COMPTEUR +=1
 Endif 
Next 
Filter [ATZA]

Close Local File [ACV], [ATZA], [ATB], [ATZ], [ATI], [ATY], [ANX]

Call ECR_TRACE("UTIANA : "+num$(COMPTEUR)+" tables revalidées",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
#If APPLI="PAIE" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : ENDIF
#If [F:ADS]MODULE(N)<>2 : End : Endif                                 : # N= no module
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= code table  
Call MAJ_UTIANA(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#If APPLI="PAIE" End : Endif
#If [F:ADS]MODULE(N)<>2 : End : Endif                                 : # N= no module
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= code table  
Call MAJ_UTIANA(APPLI)
End


