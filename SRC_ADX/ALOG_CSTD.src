# Classe ALOG

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#  When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
  When "ABEGINLOG"     : Gosub ABEGINLOG
  When "APPENDLOG"     : Gosub APPENDLOG
  When "APUTLINE"      : Gosub APUTLINE
  When "AENDLOG"       : Gosub AENDLOG
  When "APUTERRS"      : Gosub APUTERRS
  When "APUTINSTERRS"  : Gosub APUTINSTERRS
  When "AFLUSHLOG"     : Gosub AFLUSHLOG
  When "AGETNAME"      : Gosub AGETNAME
  When "ASETNAME"      : Gosub ASETNAME
Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return





###############################
$ABEGINLOG
this.TIT = [L]TIT
Return

###############################
$APPENDLOG
If [L]NAME<>"" : this.NAME = [L]NAME : Endif
If this.NAME<>"" & filinfo(filpath("TRA",this.NAME,"tra",0),0) > 0
 this.OPENFLG =2
Endif
Return

###############################
$APUTLINE
Local Integer PARAM_NBTRABUFF, NOTEX1
PARAM_NBTRABUFF = fmet this.ACTX.APARAM.AGETUSERVALNUM("NBTRABUFF")
Gosub _COUPE_TEXTE
For NOTEX1=1 To NTEX
  If this.NBALOGD>=PARAM_NBTRABUFF
   Gosub _FLUSHLOG
  Endif
  Gosub _ADDLINE
Next NOTEX1
Return

###############################
$AFLUSHLOG
Gosub _FLUSHLOG
Return

###############################
$AENDLOG
Gosub _FLUSHLOG
Return

$ERFIL
ER = errn
Resume

#---------------------------------------------------------------------------#
# Lock Whith lockwait=3 fait une première tentative (écriture) sur APLLCK
# attend 1 seconde, refait une autre tentative (3 au total) sur APLLCK, etc.
# Nombre maximum de tentatives = [s]lockwait * GROLLBACK
#---------------------------------------------------------------------------#

$INC_NUMIMP
Lock NUMIMP With lockwait=[S]lockwait
If fstat
 ROL += 1
 If ROL>GROLLBACK
  ER = 1 : Return
 Else
  Goto INC_NUMIMP
 Endif
Elsif !adxlog
 Gosub TR_NUMIMP
Else
 Gosub MAJ_NUMIMP
Endif
Unlock NUMIMP
Return

#-----------------#
$TR_NUMIMP
Trbegin ADOVAL
 Gosub MAJ_NUMIMP
Commit
Return

#-----------------#
$MAJ_NUMIMP
NUMIMP = [C]NUMIMP
[C]NUMIMP += 1
If fstat : ER = 2 : Endif
Return

###############################
$_GETNAME
Local Char WNAME(250)
If this.NAME=""
#Must find the file name
 Local Integer NUMIMP, ER, ROL, MAXROL, STA
 Onerrgo ERFIL
 Gosub INC_NUMIMP
 Onerrgo
 If ER
  Case ER
   When 1 : ASTATUS = [V]CST_AERROR
            # Compteur verrouillé
            STA = fmet this.ASETERROR("","NUMIMP :"-mess(135,133,1),[V]CST_AERROR)
   When 2 : ASTATUS = [V]CST_AERROR
            # Erreur d'écriture sur le fichier
            STA = fmet this.ASETERROR("",mess(13,100,1)-"APLCOM",[V]CST_AERROR)

  Endcase
  NUMIMP = 9999
 Endif
 this.NAME = "F"+num$(NUMIMP)
Endif
WNAME=this.NAME
Return
###############################
$AGETNAME
Gosub _GETNAME
[L]ARET_VALUE=WNAME
Return

###############################
$ASETNAME
If this.NAME<>""
  [L]ARET_VALUE=[V]CST_AERROR
Else
  this.NAME=[L]NAME
Endif
Return

###############################
$_GETFILPATH
Gosub _GETNAME
Local Char    WFICTRA(250)
WFICTRA = filpath("TRA",WNAME,"tra",0)
Return

###############################
$_FLUSHLOG
Gosub _GETFILPATH

Local Char    TEXTE(200) , SAVIFS(10) , SAVIRS(10)
Local Integer SAVIUM
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

If this.OPENFLG<>2
#first write for log
  Openo WFICTRA , 0 Using [ALOG]
  adxifs = ""
  adxirs = chr$(10)
  adxium = GUTF8
  #old TEXTE  = "#<AdxV"+GADOVERS+">@(#)%I%"-format$("D:"+GFMDAT,date$)-time$-"("+GUSER
  #TEXTE  = "#<AdxV"+GADOVERS+">@(#)%I%"-format$(GFMDAT,date$)-time$-"("+this.ACTX.USER
  If dim(this.ACTX.AINTL.SHORTDATE)>0 & left$(this.ACTX.AINTL.SHORTDATE,2)="D:"
  TEXTE  = "#<AdxV"+GADOVERS+">@(#)%I%"-format$(this.ACTX.AINTL.SHORTDATE,date$)-time$-"("+this.ACTX.USER
  Elsif left$(adxfmt(0),2)="D:"
  TEXTE  = "#<AdxV"+GADOVERS+">@(#)%I%"-format$(adxfmt(0),date$)-time$-"("+this.ACTX.USER
  Elsif dim(GFMDAT)>0 & left$(GFMDAT,2)="D:"
  TEXTE  = "#<AdxV"+GADOVERS+">@(#)%I%"-format$(GFMDAT,date$)-time$-"("+this.ACTX.USER
  Elsif dim(GFMDAT)>0
  TEXTE  = "#<AdxV"+GADOVERS+">@(#)%I%"-format$("D:"+GFMDAT,date$)-time$-"("+this.ACTX.USER
  Else
  TEXTE  = "#<AdxV"+GADOVERS+">@(#)%I%"-num$(date$)-time$-"("+this.ACTX.USER
  Endif
#  If GPRODUIT=1 & dim(GFCY)>0 & dim(GDEP)>0 : ## GEODE
#   TEXTE-=GFCY+"/"+GDEP
#  Endif
  TEXTE += ")"-this.TIT
  Wrseq TEXTE Using [ALOG]
  Openo Using [ALOG]
  this.OPENFLG = 2
Endif

#write all lines
Local Integer NOLIG,ERR
Openo WFICTRA, -1 Using [ALOG]: # Sécurité ?
For NOLIG=1 To this.NBALOGD
  If find(this.ALOGD(NOLIG).STA,[V]CST_AERROR,[V]CST_AFATAL) : ERR=1
  Elsif  this.ALOGD(NOLIG).STA=[V]CST_AWARNING : ERR=-1
  Else : ERR=0
  Endif
  If ERR<0
   Wrseq ">"+right$(num$(10000+mod(abs(ERR),10000)),2)+" "+this.ALOGD(NOLIG).LIN Using [ALOG]
  Elsif ERR
   Wrseq "<"+right$(num$(10000+mod(ERR,10000)),2)+" "+this.ALOGD(NOLIG).LIN Using [ALOG]
  Else
   Wrseq this.ALOGD(NOLIG).LIN Using [ALOG]
  Endif
Next NOLIG
Openo Using [ALOG]

#delete lines instances
For NOLIG=1 To this.NBALOGD
 # 118549 CCL
 If this.ALOGD(NOLIG)<>null   : FreeInstance this.ALOGD(NOLIG)   : this.ALOGD(NOLIG)   = null  : Endif
Next NOLIG
this.NBALOGD=0

adxifs    = SAVIFS
adxirs    = SAVIRS
adxium    = SAVIUM
Return

########################################################################
##  Caractères magiques
##  { \ } : Effectue un saut de ligne
##  { | } : Inhibe le découpage du texte jusqu'au prochaine { | }
##          Un seul { | } inhibe le découpage jusqu'à la fin du texte.
##
##  Remarque : L'impression du caractère { | } n'est donc pas prévu !
########################################################################
# !!!! identique à GESECRAN !!!!!
########################################################################
$_COUPE_TEXTE
Local Integer X, Y, Z
Local Integer NTEX, PTEX, LTEX, FTEX
Local Char    TEX1(250)(1..30)
Local Clbfile TEXC(2)
NTEX = 1
PTEX = 1
LTEX = 1

TEXC = TEX
If dim(TEX)>1
 For X=1 To dim(TEX)-1
  TEXC += "\"+TEX(X)
 Next X
Endif

Repeat
 FTEX = PTEX
 Repeat
  X = instr(FTEX,TEXC,"\")
  Y = instr(FTEX,TEXC,"|")
  If Y<>0 & ((X<>0 & Y<X) | X=0)
   Z = instr(Y+1,TEXC,"|")
   If Z=0
    X = 0
    TEXC = left$(TEXC,Y-1) + right$(TEXC,Y+1)
   Else
    TEXC  = left$(TEXC,Y-1) + seg$(TEXC,Y+1,Z-1) + right$(TEXC,Z+1)
    FTEX = Z-1
   Endif
  Endif
 Until (X<>0 & X<Y) | Y=0 | Z=0
 If X<>0
  TEX1(NTEX) = seg$(TEXC,PTEX,X-1)
  LTEX = max(LTEX,len(TEX1(NTEX)))
  NTEX += 1
  PTEX = X+1
 Else
  TEX1(NTEX) = right$(TEXC,PTEX)
  LTEX = max(LTEX,len(TEX1(NTEX)))
 Endif
Until X=0 | NTEX>=dim(TEX1)
For X=2 To NTEX
 TEX1(X) = TEX1(X)
Next X
Return

###############################
$_ADDLINE
Local Integer NOL
this.NBALOGD+=1
this.TOTLIG+=1
NOL=this.NBALOGD
#this.ALOGD(NOL) = NewInstance  =this.ALLOCGRP, C_ALOGD(this.ACTX,NullUuid,NOL,this,"ALOGD")
#this.ALOGD(NOL) = NewInstance  =this.AllocGrp, C_ALOGD
this.ALOGD(NOL) = NewInstance C_ALOGD AllocGroup this
this.ALOGD(NOL).STA=[L]STA
this.ALOGD(NOL).LIN=[L]TEX1(NOTEX1)
If [L]STA=[V]CST_AWARNING
  this.NBWARN+=1
Elsif find([L]STA,[V]CST_AERROR,[V]CST_AFATAL)
  this.NBERR+=1
Endif
Return

###############################
$APUTINSTERRS
Local Instance CTX Using =[V]CST_C_NAME_CLASS_CONTEXT
CTX=NewInstance [ALOG] With =[V]CST_C_NAME_CLASS_CONTEXT
[L]ARET_VALUE = fmet AINSTANCE._AERROR(CTX,0)
[L]ARET_VALUE = func _PUTERRORS(this,CTX.AERROR)
FreeInstance CTX
Return

###############################
$APUTERRS
[L]ARET_VALUE = func _PUTERRORS(this,AINSTERROR)
Return

###############################
Funprog _PUTERRORS(AINSTALOG,AINSTERROR)
Variable Instance AINSTALOG Using C_ALOG : # Instance
Variable Instance AINSTERROR(1..) Using C_AERROR : # Instance
Local Integer AI,STAT
Local Char MESSAGE(250)
For AI=1 To maxtab(AINSTERROR)
 If AINSTERROR(AI)<>null
  If AINSTERROR(AI).PRO<>"" : # 117029
   [L]MESSAGE = AINSTERROR(AI).PRO-": "
  Endif
  [L]MESSAGE += AINSTERROR(AI).MES
  STAT=fmet AINSTALOG.APUTLINE([L]MESSAGE,AINSTERROR(AI).STA)
 Endif
Next AI
End [L]STAT

#############################################################################
## Pour formatter 5 colonnes maxi
#############################################################################

Funprog FORMAT5(C1,C2,C3,C4,C5,L1,L2,L3,L4,L5)
Value Char    C1, C2, C3, C4, C5  : # Contenu des champs à formater en colonne
Value Integer L1, L2, L3, L4, L5  : # Nb de caractères par colonne
Local Char    MESSAGE(250), MOT(250)
If L1 | C1<>"" : MOT = C1 : Call _FORMAT(MOT,L1)  : MESSAGE =  MOT : Endif
If L2 | C2<>"" : MOT = C2 : Call _FORMAT(MOT,L2)  : MESSAGE += MOT : Endif
If L3 | C3<>"" : MOT = C3 : Call _FORMAT(MOT,L3)  : MESSAGE += MOT : Endif
If L4 | C4<>"" : MOT = C4 : Call _FORMAT(MOT,L4)  : MESSAGE += MOT : Endif
If L5 | C5<>"" : MOT = C5 : Call _FORMAT(MOT,L5)  : MESSAGE += MOT : Endif
End [L]MESSAGE

Subprog _FORMAT(MOT,LONG)
Variable    Char    MOT
Value       Integer LONG
MOT = format$("K:"+num$(LONG)+"X",MOT)
End

