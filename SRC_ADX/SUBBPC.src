#
#Return

########################################
$CHARGE_ZONE_BPAADD
Local Integer I

  [M:BPC4]FLMOD(NOL) = 1  # FGR 21/12/2010 : X3SUIVI70104
  [M:BPC4]RCPFCY(NOL) = ""
  [M:BPC4]UVYCOD(NOL) = ""
  #MAE, bg 82752 si la catégorie est renseignée, on ne remplit plus systématiquement les jours ouvrée
  If [M:BPC0]BCGCOD =""
    For I=0 To 6
      Assign "[M:BPC4]UVYDAY"+num$(I+1)+"(NOL)" With 2
    Next
  Endif
  If dim(WFCY)>0 & WFCY<>""
    If [F:FCY]FCY<>WFCY
      Read [FCY]FCY0=WFCY
      If fstat Raz [FCY] Endif
    Endif
    For I=0 To 6
      Assign "[M:BPC4]UVYDAY"+num$(I+1)+"(NOL)" With [F:FCY]UVYDAY(I)
    Next
    [M:BPC4]UVYCOD(NOL) = [F:FCY]UVYCOD
    # Si client inter-site, le site client peut initialiser le site réception s'il s'agit d'un dépôt
    If [M:BPRC]BETFCY=2 & [F:FCY]WRHFLG=2
      Local Char WRCPFCY(GLONFCY) : WRCPFCY=WFCY : Gosub CTR_RCPFCY
      If mkstat=0 [M:BPC4]RCPFCY(NOL)=WFCY Else Raz mkstat : Raz GMESSAGE : Endif
    Endif
  Endif
  [M:BPC4]ENAFLG(NOL)  = 2
  # Le régime de taxe ne doit pas être initialisé à partir du client
  #[M]VACBPD(NOL)  = [M:BPC3]VACBPR
  #116311.so - JOBRO
  #If dim([M:BPC4]SSTENTCOD) > 0
  #  #When ENTCOD field exists, hide it and ShortDescript if the country is unsupported by SST
  #  If !(func TRTADRLIB.CHKADR_CRY([M]BPDCRY(NOL)))
  #    Chgfmt [M:BPC4]XSSTENTCOD  With "-K:5B"    # Hide enterable
  #    Chgfmt [M:BPC4]ZXSSTENTCOD With "-KP:12X"
  #  Else
  #    Chgfmt [M:BPC4]XSSTENTCOD  With "K:5B"     # Show enterable
  #    Chgfmt [M:BPC4]ZXSSTENTCOD With "KP:12X"   # Protected
  #  Endif
  #Endif
  #116311.eo - JOBRO
  [M:BPC4]LAN(NOL)     = [M:BPRC]LAN
  [M:BPC4]NPRFLG(NOL)  = 2
  [M:BPC4]NDEFLG(NOL)  = 2
  [M:BPC4]DRN(NOL)     = 1
  [M:BPC4]DLVPIO(NOL)  = 1
  #
  [M:BPC4]PRPTEX(NOL)  = ""
  [M:BPC4]DLVTEX(NOL)  = ""
  If dim([M:BPC4]BPCLOC)>0 [M:BPC4]BPCLOC(NOL) = "" Endif
  If dim([M:BPC4]SCOLOC)>0 [M:BPC4]SCOLOC(NOL) = "" Endif
  [M:BPC4]MDL(NOL)    = ""
  [M:BPC4]EECICT(NOL) = ""
  If dim([M:BPC4]EECLOC)>0
    [M:BPC4]EECLOC(NOL) = 1
    [M:BPC4]EECINCRAT(NOL) = 0
  Endif
  [M:BPC4]DAYLTI(NOL) = 0
  # Le n°TVA ne doit pas être initialisé à partir du client
  #If dim([M]EECNUM(NOL))>0 [M]EECNUM(NOL)=[M:BPRC]EECNUM Endif
  If [M:BPC0]BCGCOD="" Return Endif
  If [M:BPC0]BCGCOD<>[F:BCG]BCGCOD
    Read [BCG]BCG0=[M:BPC0]BCGCOD
    If fstat Return Endif
  Endif
  If GREP <>"D"
    [M:BPC4]=[F:BCG]
  Endif
  # FGR 20/01/2014 : X3SUIVI95061 (début)
  Raz [M:BPC4]CREUSR(nolign-1)
  Raz [M:BPC4]CREDAT(nolign-1)
  Raz [M:BPC4]UPDUSR(nolign-1)
  Raz [M:BPC4]UPDDAT(nolign-1)
  # FGR 20/01/2014 : X3SUIVI95061 (fin)
  If func AFNC.ACTIV("RED")>0 : [M:BPC4]REP0(NOL)=[F:BCG]REPDLV(0) : Endif
  If func AFNC.ACTIV("RED")>1 : [M:BPC4]REP1(NOL)=[F:BCG]REPDLV(1) : Endif
Return
# FGR 03/11/2014 : X3SUIVI103732 : ajout de [M:BPC4] au lieu de [M] (fin)

