################################################
######################################################################################
# IRMUE 03.07.12 81574:AP/AR management
# If the 'Price /Amount type' in the customer category is not defined, PRITYP field
# is initialized with parameter SALPRITYP. If parameter SALPRITYP is not defined,
# PRITYP field is initialized with "Ex tax".
# If Parameter NOTATI ="No", 'Price /Amount type' by customer can't be changed.
######################################################################################
Subprog CHK_PRITYP(VALEUR)
Variable Char    VALEUR()
If [F:BCG]BCGCOD <> VALEUR
   Read [F:BCG]BCG0 = VALEUR
Endif

If (dim(GNOTATI)>0 & GNOTATI=2) | [M:BPC1]PRITYP = 0
 If [M:BPC1]PRITYP <> [F:BCG]PRITYP
    [M:BPC1]PRITYP = [F:BCG]PRITYP
 Endif
 If [M:BPC1]PRITYP = 0
    [M:BPC1]PRITYP = GPRITYP
 Endif
 If [M:BPC1]PRITYP = 0
    [M:BPC1]PRITYP =1
 Endif
 Affzo [M:BPC1]PRITYP
Endif

If dim(GNOTATI)>0 & GNOTATI=2
   Actzo [M:BPC1]PRITYP
Else
   Grizo [M:BPC1]PRITYP
Endif
End

######################################################################################
Subprog C_PTE(VALEUR)
Variable Char    VALEUR()

Local Integer IFLGSDD

  # FGR 22/07/2013 : X3SUIVI87923
  If func CTRL_PTE_SEPA(VALEUR) = 1 Then
    mkstat = 2
  Endif
End

######################################################################################
Funprog CTRL_PTE_SEPA(SPTE)
Value Char    SPTE

Local Integer IFLGSDD
Local Integer IERROR
Local Char SLEG(GLONADI)

  # FGR 22/07/2013 : X3SUIVI87923
  IERROR = 0
  If func AFNC.ACTIV("SDD") Then
    If [M:BPC2]BPCTYP = 2 Then
      # C'est un tiers divers : on contrôle la condition de paiement qui ne doit pas être SEPA
      If [M:BPRC]FCY = "" Then
        # Si on n'a pas de site (donc pas de société) aucun mode de règlement ne doit être SDD
        Local File TABPAYTERM [TPT]
        For [TPT] Where [F:TPT]PTE = SPTE
          If [F:TPT]SDDFLG = G_YES Then
            IFLGSDD = G_YES
            SLEG = [F:TPT]LEG
            Break
          Endif
        Next
      Else
        # Sinon le contexte est la société du site. Elle ne doit pas être SDD
        Local File COMPANY [CPY]
        # Issue 51708
        #Read [F:FCY]FCY0=[L]FCY
        Read [F:FCY]FCY0=[M:BPRC]FCY
        # End issue 51708
        If fstat Then
          Raz [F:FCY]
        Endif
        SLEG = [F:FCY]LEG
        IFLGSDD = func TRTVENSDD.IS_PTE_SDD(SPTE, [F:FCY]LEGCPY)
      Endif
      If IFLGSDD = G_YES Then
        # Une condition de paiement SEPA ne peut être utilisée pour un tiers divers
        If SLEG = "" Then
          GMESSAGE = mess(58,2289,1) - SPTE - "(" + mess(91,187,1) + ")" - ":" - mess(318,117,1)
        Else
          GMESSAGE = mess(58,2289,1) - SPTE - "(" + mess(218,107,1) - ":" - SLEG + ")" - ":" - mess(318,117,1)
        Endif
        IERROR = 1
      Endif
    Endif
  Endif
End IERROR
