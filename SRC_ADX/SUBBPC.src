#<AdxTL>@(#)3.0.0.0 $Revision$
Call OBJET ("BPC",GBIDC1,GBIDC2) From GOBJET
End
########################################################################
#    GESTION DES CLIENTS                                   SUBBPC      #
#                                                      eb octobre 1997 #
########################################################################
# Issue X3-51708 - 20180102 by LD : Payment terms SEPA checking in treatment SUBBPC

$ACTION
  # Pour gestion multi-société
  #Gosub ACTION From GSOCIETE
  Case ACTION
    When "OUVRE"         : Gosub OUVRE        From SUBBPCA
    When "AFFMASK"       : Gosub AFFMASK      From SUBBPCA
    When "FERME"         : Gosub FERME        From SUBBPCA
    When "SETBOUT"       : Gosub SETBOUT      From SUBBPCA
    When "AVANTBOUT"     : Gosub AVANTBOUT    From SUBBPCA
    When "EXEBOUT"       : Gosub EXEBOUT      From SUBBPCA
    When "STATUT"        : Gosub STATUT       From SUBBPCA
    When "LIENS"         : Gosub LIENS        From SUBBPCA
    When "RAZCRE"        : Gosub RAZCRE       From SUBBPCA
    When "RAZDUP"        : Gosub RAZDUP       From SUBBPCA : # cg le 20/08/98
    When "VERIF_CRE"     : Gosub VERIFCRE_MOD From SUBBPCA : # cg le 30/01/98
    When "INICRE"        : Gosub INICRE       From SUBBPCA
    When "CREATION"      : Gosub CREATION     From SUBBPCA
    When "VERIF_MOD"     : Gosub VERIFCRE_MOD From SUBBPCA : # cg le 30/01/98
    When "INIMOD"        : Gosub INIMOD       From SUBBPCA
    When "AVANT_MOD"     : Gosub AVANTMOD     From SUBBPCA
    When "AVANT_MODFIC"  : Gosub AVANT_MODFIC From SUBBPCA
    When "MODIF"         : Gosub MODIF        From SUBBPCA
    When "VERF_ANU"      : Gosub VERFANU      From SUBBPCA
    When "ANNULE"        : Gosub ANNULE       From SUBBPCA
    When "VERROU"        : Gosub VERROU       From SUBBPCA : # cg le 14/09/98
    When "FIN_MOD"       : Gosub FINMODIF     From SUBBPCA
    When "DEVERROU"      : Gosub DEVERROU     From SUBBPCA : # cg le 14/09/98
    When "ABANDON"       : Gosub ABANDON      From SUBBPCA
    When "FILTRE"        : Gosub FILTRE       From SUBBPCA : #Modif CRM 19 juillet 2000
    When "FILGAUCHE"     : Gosub FILGAUCHE    From SUBBPCA : #Modif CRM 19 juillet 2000
    When "APRES_CRE"     : Gosub APRES_CRE    From SUBBPCA : #Modif CRM 31 juillet 2000
    When "APRES_MOD"     : Gosub APRES_MOD    From SUBBPCA : #Modif CRM 31 juillet 2000
    When "AP_ANNULE"     : Gosub AP_ANNULE    From SUBBPCA : #Modif CRM 31 juillet 2000
    When "BOITE"         : Gosub BOITE        From SUBBPCA
    When "APRES_MODIF"   : Gosub APRES_MODIF  From SUBBPCA
    When "AVANT_CHOI"    : Gosub AVANT_CHOI   From SUBBPCA
    When "APRES_CHOI"    : Gosub APRES_CHOIX  From SUBBPCA   # FGR 16/02/2015 : X3SUIVI101747
    When "AB_CREATION"   : Gosub AB_CREATION  From SUBBPCA   #MAE, bg 67549
    When "SEL_TABLE"
      Case COUZON
        When "GRP"      : Gosub S_GRP
      Endcase
    When "BB3_NBDLV"     : Call BB3_NBDLV
    When "BB1_NBDLV"     : Call BB1_NBDLV                    # FGR 04/01/2016 : X3SUIVI112721
    When "BB2_NBDLV"     : Call BB2_NBDLV                    # FGR 04/01/2016 : X3SUIVI112721
    When Default
  Endcase
Return

