########################################
Subprog AM_XFFWNUM(VALEUR)
Variable Char    VALEUR()

#MAE bg 85225
If VALEUR=""
  [M]FFWNUM([M]XNUMLIG) = VALEUR
  Raz [M:BPC4]XFFWADD : Affzo [M]XFFWADD : Diszo [M]XFFWADD
  Raz [M:BPC4]FFWADD([M]XNUMLIG)
  [M:BPC4]FLMOD([M]XNUMLIG) = 1  # Issue 122518 - 2017-04-13 by MAE
  End
Endif

[M:BPC4]XFFWADD=[F:BPT]BPAADD
[M:BPC4]FFWADD([M]XNUMLIG) = [F:BPT]BPAADD
Affzo [M:BPC4]XFFWADD : Actzo [M:BPC4]XFFWADD

[M]FFWNUM([M]XNUMLIG) = VALEUR
[M:BPC4]FLMOD([M]XNUMLIG) = 1  # FGR 21/12/2010 : X3SUIVI70104
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran BPC4) 06/05/2005 11:31:01 (LD)
######################################################################################
Subprog IB_XFFWADD
If  [M:BPC4]XFFWNUM = [M:BPC0]BPCNUM  Raz GBOUT2 Else Raz GBOUT1 : Endif
End
########################################
Subprog C_XFFWADD(VALEUR)
Variable Char    VALEUR()
Local Integer MATCH_BPAADD

If [M:BPC4]XFFWNUM = [M:BPC0]BPCNUM
   # --- transitaire = client commande (on ne sait jamais)
   MATCH_BPAADD = find(VALEUR,[M:BPAC]CODADR(0..[M:BPAC]NBADR-1))
   If MATCH_BPAADD = 0 : GMESSAGE = mess(16,199,1) : mkstat = 2 : Endif
Else
   # --- client facture <> client commande
   Look [BPA]BPA0 = 1;[M:BPC4]XFFWNUM;VALEUR
   If   fstat : GMESSAGE = mess(16,199,1) : mkstat = 2 : Endif
Endif

End
########################################
Subprog AM_XFFWADD(VALEUR)
Variable Char    VALEUR()
[M]FFWADD([M]XNUMLIG) = VALEUR
[M:BPC4]FLMOD([M]XNUMLIG) = 1  # FGR 21/12/2010 : X3SUIVI70104
End

