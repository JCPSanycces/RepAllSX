  [M:BPC6]XITMREFBPC = [M:BPC6]ITMREFBPC(NOL)
  [M:BPC6]XITMDESBPC = [M:BPC6]ITMDESBPC(NOL)
  [M:BPC6]XSAU       = [M:BPC6]ISAU(NOL)
  [M:BPC6]XSAUSTUCOE = [M:BPC6]ISAUSTUCOE(NOL)
  [M:BPC6]XPCU1      = [M:BPC6]PCU1(NOL)
  [M:BPC6]XPCUSAUCO1 = [M:BPC6]PCUSAUCOE1(NOL)
  [M:BPC6]XPCU2      = [M:BPC6]PCU2(NOL)
  [M:BPC6]XPCUSAUCO2 = [M:BPC6]PCUSAUCOE2(NOL)
  [M:BPC6]XPCK       = [M:BPC6]PCK(NOL)
  [M:BPC6]XPCKCAP    = [M:BPC6]PCKCAP(NOL)
  [M:BPC6]XITSTEX    = [M:BPC6]ITSTEX(NOL)
  [M:BPC6]XITPTEX    = [M:BPC6]ITPTEX(NOL)
