$S_GRP
OBJET="FGP"
# si besoin, renseigner la variable CRITERE pour restreindre la sélection
Return

Subprog C_GRP(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 # on autorise les clients sans groupe
 # effacer et griser les champs
 Raz [M]FUPTYP, FUPMINAMT
 [M]FUPTYP=1
 Grizo [M]FUPTYP, FUPMINAMT
 Affzo [M]FUPTYP, FUPMINAMT
Else
 If  !clalev([F:FGP]) : Local File FUPGRP [FGP] : Endif
 Call CONTROLE("FGP","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : End : Endif
 # activer les champs
 Actzo [M]FUPTYP, FUPMINAMT
 Affzo [M]FUPTYP, FUPMINAMT
 # initialisation des champs du client avec les valeurs du groupe auquel il appartient si on est en création
 If find(GREP,"C","D")
  Read [FGP]FGP0=VALEUR
  [M]FUPTYP = [F:FGP]FUPTYP
  [M]FUPMINAMT = [F:FGP]FUPMINAMT
 Endif
Endif
End


## <PP ARG>
Subprog AM_AGTSATTAX(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR = 1
 Grizo [M:BPC3]NBPRV : Grizo [M:BPC3]SATTAX : Grizo [M:BPC3]DESSAT : Grizo [M:BPC3]TYPAPL : Grizo [M:BPC3]FLGSATTAX
 For I=0 To [M:BPC3]NBPRV
  [M:BPC3]FLGSATTAX(I) = 1 : Affzo [M:BPC3]FLGSATTAX
 Next
Else
 Actzo [M:BPC3]NBPRV : Actzo [M:BPC3]SATTAX : Actzo [M:BPC3]DESSAT : Actzo [M:BPC3]TYPAPL : Actzo [M:BPC3]FLGSATTAX
 For I=0 To [M:BPC3]NBPRV
  [M:BPC3]FLGSATTAX(I) = 2 : Affzo [M:BPC3]FLGSATTAX
 Next
Endif
End

Subprog AS_FLGSATTAX(VALEUR)
Variable Integer VALEUR
If [M]SATTAX(nolign-1) = "" : mkstat = 1 : End : Endif
End
