######################################################################################
Subprog C_CSHVATRGM(VALEUR)
Variable Integer VALEUR

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
If nolign-2>=0
  If [M:BPC3]CSHVATRGM(nolign-2)=VALEUR
    Call ECR_TRACE(mess(70,7711,1),1) From GESECRAN
    mkstat = 2 : End
  Endif

Endif
#94635 RICAR 2014/04/21 - CASH VAT - END

End
######################################################################################
######################################################################################
Subprog C_VATSTRDAT(VALEUR)
Variable Date    VALEUR

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
If clalev([F:PYH])=0 : Local File PAYMENTH [PYH] : Endif

#Start date cannot be greater than end date
If [M:BPC3]VATENDDAT(nolign-1) <> [0/0/0] & VALEUR > [M:BPC3]VATENDDAT(nolign-1)
  Call ECR_TRACE(mess(81,7711,1),1) From GESECRAN
  mkstat = 2 : End
Endif
If nolign-2>=0
  #End date cannot be empty
  Call CTLDATV( VALEUR - 1,[M:BPC3]VATSTRDAT(nolign-2)) From CONTDIV
  If mkstat = 2
    End
  Endif
  [M:BPC3]VATENDDAT(nolign-2) = VALEUR - 1
  Affzo [M:BPC3]VATENDDAT(nolign-2)

  If [M:BPC3]VATENDDAT(nolign-2)+1>VALEUR
    Call ECR_TRACE(mess(72,7711,1),1) From GESECRAN
    mkstat = 2 : End
  Endif
  #Regime flag is empty
  If [M:BPC3]CSHVATRGM(nolign-1)=0
    Call ECR_TRACE(mess(71,7711,1),1) From GESECRAN
    mkstat = 2 : End
  Endif

  Filter [PYH] Where [F:PYH]BPR=[M:BPC0]BPCNUM and [F:PYH]ACCDAT >= [M:BPC3]VATENDDAT(nolign-2) and [F:PYH]CSHVATRGM(nolign-2) = [M:BPC3]CSHVATRGM(nolign-2)

  Read [PYH] First
  If !fstat
    Call ECR_TRACE(func AFNC.MES1(mess(88,7711,1),[M:BPC0]BPCNUM),1) From GESECRAN
    mkstat = 2 : End
  Endif

  Filter [PYH]

  Close Local File [PYH]
Endif
#94635 RICAR 2014/04/21 - CASH VAT - END

End
######################################################################################
## Section automatically added (screen BPC1) 04/14/2016 13:07:59 (RICAR)
######################################################################################
Subprog AM_ELECTINV(VALEUR)
Variable Integer VALEUR

# Issue 110700 - 2016-04-14 by RICAR : Electronic invoices: connect with Sage component
# Issue 110700
If VALEUR = 2
  Gosub CHECK_TPMCOD
Else
  [M:BPC1]CNTEFAT = ""
  Affzo [M:BPC1]CNTEFAT
  Actzo [M:BPC1]CNTEFAT
  [M:BPC1]STRDATEFAT = [0/0/0]
  Affzo [M:BPC1]STRDATEFAT
  Actzo [M:BPC1]STRDATEFAT
Endif
# End issue 110700

End
######################################################################################
$CHECK_TPMCOD

If [M:BPC1]TPMCOD <> ''
  Read [F:TPM]TPM0 = [M:BPC1]TPMCOD
  If fstat = 0
    If [F:TPM]TRSEFAT = '' or [F:TPM]SALINV = '' or [F:TPM]SALCRE = ''
      GMESSAGE = mess(231,7711,1)
      mkstat = 2 : End
    Endif
  Endif
Else
  GMESSAGE = mess(232,7711,1)
  mkstat = 2 : End
Endif

Return
######################################################################################
## Section automatically added (screen BPC1) 04/14/2016 13:11:01 (RICAR)
######################################################################################
Subprog AP_CNTEFAT(VALEUR)
Variable Char    VALEUR()

# Issue 110700 - 2016-04-14 by RICAR : Electronic invoices: connect with Sage component
# Issue 110700
Local Integer I

For I = 0 To [M:CNTC]NBCNT -1
  If [M:CNTC]CCNCRM(I) = [F:CNT]CCNCRM
    If !([M:CNTC]CCNCRM(I) = [F:CNT]CCNCRM and [M:CNTC]CNTWEB (I) <> "") Then
      Call ECR_TRACE(mess(231,7711,1),1) From GESECRAN
      mkstat = 2 : End
    Endif
  Endif
Next
# End issue 110700

End

