    If [M:BPC6]XITPTEX = "" Then
       [M:BPC6]WITPTEX = 1
       GBOUT2 =""
    Else
       [M:BPC6]WITPTEX = 2
    Endif

  If !GIMPORT
    Affzo [M:BPC6]10
  Endif
Return




