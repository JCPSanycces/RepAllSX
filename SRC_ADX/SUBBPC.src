Subprog AS_BPCTYP(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1
GMENLOC(4)=1
End

# FGR 02/04/2015 : X3SUIVI109045 (début)
########################################
Subprog C_BPCTYP(VALEUR)
Variable Integer VALEUR

Local Integer IERR
Local Char SMESSAGE(type(GMESSAGE)-10)

  If VALEUR = 2 Then
    # Un tiers divers ne doit pas avoir de SEPA
    Local File BPARTNER [BPR1]
    Read [BPR1]BPR0=[M:BPC0]BPCNUM
    If !fstat Then
      Call CTRL_TRSF_BPR_BPEXCEPT([M:BPC0]BPCNUM, IERR, SMESSAGE) From TRTVENSDD
      If IERR <> 0 Then
        GMESSAGE = SMESSAGE
        mkstat = 2
        End
      Endif
    Endif
  Endif
End
# FGR 02/04/2015 : X3SUIVI109045 (fin)

