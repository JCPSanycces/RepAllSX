Funprog GET_FCY()

Local Char SFCY(GLONFCY)

  # FGR 20/02/2015 : X3SUIVI106383
  If dim([M:BPRC]FCY) >= 0 Then
    SFCY = [M:BPRC]FCY
  Else
    Raz SFCY
  Endif
End SFCY

