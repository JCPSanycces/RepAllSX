########################################
Subprog AS_NBDLV
  Gosub SETNOL
  [M:BPC4]XNUMLIG = nolign-1
  If !GWEBSERV Then          # FGR 05/05/2015 : X3SUIVI108031
    Gosub CHARGE_BPD
  Endif
End

########################################
Subprog C_NBDLV
Local Integer WRETOUR

Case status
  When 65 :     # suppression d'une ligne
       Gosub SETNOL
       Gosub CTRBPD
       If mkstat : End : Endif
       #----- Si fonction création et supp d'une ligne, supp du texte associé
       #If GREP = "C" & [M]PRPTEX(NOL) <> ""
       #   Call TEX(9,"BPD1","","","",[M]PRPTEX(NOL),"A",WRETOUR) From TRTX3TEX
       #Endif
       #If GREP = "C" & [M]DLVTEX(NOL) <> ""
       #   Call TEX(9,"BPD2","","","",[M]DLVTEX(NOL),"A",WRETOUR) From TRTX3TEX
       #Endif
  When 68, 83 : # suppression de plusieurs lignes
       For NOL = nolign-1 To nolign1-1
           Gosub CTRBPD
           If mkstat : Break : Endif
       Next NOL
       If mkstat : End : Endif
       #----- Si fonction création et supp des lignes OK, supp des textes associés
       #For NOL = nolign-1 To nolign1-1
       #   If GREP = "C" & [M]PRPTEX(NOL) <> ""
       #      Call TEX(9,"BPD1","","","",[M]PRPTEX(NOL),"A",WRETOUR) From TRTX3TEX
       #   Endif
       #   If GREP = "C" & [M]DLVTEX(NOL) <> ""
       #      Call TEX(9,"BPD2","","","",[M]DLVTEX(NOL),"A",WRETOUR) From TRTX3TEX
       #   Endif
       #Next NOL
Endcase
End
########################################
Subprog APRES_NBDLV
# Spécifique à l'import --> Recharger indice pour sortir de la boucle de saisie
#indice = [M]NBDLV -1
# Spécifique à l'import --> Recharger nolign pour sortir de la boucle de saisie
nolign = [M]NBDLV
End

########################################
Subprog C_BPAADD(VALEUR)
Variable Char    VALEUR()
Local Integer MATCH_BPAADD

Gosub SETNOL
VALEUR = vireblc(VALEUR, 2)
#----    vérif unicité du code adresse saisi dans le tableau
Call UNICITE(VALEUR,[M]BPAADD(0..[M]NBDLV-1)) From OBJDIV
If   mkstat : End : Endif

#----    verif code adresse existe pour ce client      #
MATCH_BPAADD = find(VALEUR,[M:BPAC]CODADR(0..[M:BPAC]NBADR-1))
If   MATCH_BPAADD = 0
     GMESSAGE = mess(16,199,1) : mkstat = 1 : End
Endif
#----    en cas de modif, vérif valeur précédente utilisée
If   [M]BPAADD(NOL) <> ""
     If   VALEUR <> [M]BPAADD(NOL) : Gosub CTRBPD : Endif
     If   mkstat : End : Endif
Endif
End
########################################
Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()

# Si modif penser à vérifier IMPBPC
#If [M]BPAADD(nolign-1) = ""
If [M]XBPAADD = ""
    #Modif CRM 4/02/2002######
    If GMODU(13) = 2
        Local Char SZCRMVAL(type(VALEUR)-10)                         # FGR 04/05/2015 : X3SUIVI108031 à jour de la longueur
        Local Integer ICRMNOL
        SZCRMVAL = VALEUR
        ICRMNOL = nolign - 1
#        Call LREPDLV(SZCRMVAL, ICRMNOL) From TRTMST4
        Call LREPDLV(SZCRMVAL, ICRMNOL) From SUBMSTB1

    Endif
    ##########################
    Local Char WFCY(type([M:BPRC]FCY)-10) : WFCY=[M:BPRC]FCY         # FGR 04/05/2015 : X3SUIVI108031 à jour de la longueur
    Local Char WBPAADD(GLONADR) : WBPAADD=VALEUR
    Gosub CHARGE_BPAADD
Endif
[M]XBPAADD = VALEUR
End
########################################
$SETNOL
Local Integer NOL
NOL = nolign-1
Return
# -------------------------------------- XENAFLG ------------------------
######################################################################################
## Etiquette ajoutée par le superviseur (écran BPC4) 07/11/2005 09:33:18 (LD)
######################################################################################
Subprog C_XENAFLG(VALEUR)
Variable Integer VALEUR

Local Integer NI # FGR 24/02/2015 : X3SUIVI92469

  If VALEUR=2 & [M]BPAADD="": mkstat=2: End: Endif # X3-103722 (LCC - 23/08/18) Creating a customer without ship to customer

  # Le client livré par défaut ne doit pas être inactif
  If VALEUR<>2 & [M]XBPDADDFLG=2 mkstat=2 : GMESSAGE=mess(511,199,1) : End : Endif
  # FGR 24/02/2015 : X3SUIVI92469 (début)
  #If VALEUR <> 2 Then
   If VALEUR <> 2 and [M]NBDLV > 0 Then # X3-103722 (LCC - 10/10/18) Creating a customer without ship to customer
    If [M]NBDLV = 1 Then
      mkstat = 2
      GMESSAGE = mess(636,199,1)
      End
    Else
      NI = 0
      If [M]XNUMLIG > 0 Then
        # On regarde dans les lignes qui précèdent la ligne courante...
        NI = find(2,[M]ENAFLG(0..[M]XNUMLIG-1))
      Endif
      If NI = 0 Then
        # ... S'il n'y en n'a pas on regarde dans celles qui suivent
        NI = find(2,[M]ENAFLG([M]XNUMLIG+1..[M]NBDLV-1))
      Endif
      If NI = 0 Then
        mkstat = 2
        GMESSAGE = mess(636,199,1)
        End
      Endif
    Endif
  Endif
  # FGR 24/02/2015 : X3SUIVI92469 (fin)
End
########################################
Subprog AM_XENAFLG(VALEUR)
Variable Integer VALEUR
[M]ENAFLG([M]XNUMLIG) = VALEUR
[M:BPC4]FLMOD([M]XNUMLIG) = 1  # FGR 21/12/2010 : X3SUIVI70104
End
# -------------------------------------- XBPAADDFLG ------------------------
Subprog C_XBPDADDFLG(VALEUR)
Variable Integer VALEUR
# Le client livré par défaut ne doit pas être inactif
If VALEUR=2 & [M]XENAFLG<>2 mkstat=2 : GMESSAGE=mess(511,199,1) : End : Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran BPC4) 02/08/2005 16:01:42 (LD)
######################################################################################
Subprog AM_XBPDADDFLG(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR = 2
 I = find (2,[M]BPDADDFLG (0..[M]NBDLV -1))
 If I : [M]BPDADDFLG(I-1) = 1 : Endif
Endif
[M]BPDADDFLG([M]XNUMLIG) = VALEUR
[M:BPC4]FLMOD([M]XNUMLIG) = 1  # FGR 21/12/2010 : X3SUIVI70104
End

