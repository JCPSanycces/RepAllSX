   Endif
Endif
If VALEUR = 4
   # FGR 06/08/2009 : X3SUIVI56985
   #If dim([M:BPC2]CNTLASTYP) > 0
   #   [M:BPC2]CNTLASTYP = 1
   #   [M:BPC2]CNTNEXTYP = 1
   #Endif
   If GACTFTC=2
      [M:BPC2]PPTFLG = 2
