########################################
Subprog C_BPCINV(VALEUR)
Variable Char    VALEUR()
Local Char       WTIE(GLONBPR)   : # contrôle validité tiers facture    hcb v6

If find(GREP,"C","D") & [M:BPC0]REFCOU<>"" & VALEUR=""
   End
Endif

WTIE = VALEUR : Gosub CONTIE
If mkstat=2 End Endif

If GACTFTC=2 & [M:BPRC]BETFCY=2 & [M:BPRC]FCY<>""
   # Le client est inter-site
   Local Char WFCY(GLONFCY)

   Local File BPARTNER [BPR]  # FGR 19/02/2010 : X3SUIVI62660 Sinon ça pollue en cas d'import
   If VALEUR <> [M:BPC0]BPCNUM
      # Le client facture doit aussi être inter-site
      If [F:BPR]BPRNUM<>VALEUR
         Read [BPR]BPR0 = VALEUR
         If fstat  GMESSAGE = mess(23,100,1) : mkstat = 2 : End : Endif
      Endif
      If [F:BPR]BETFCY<>2 | [F:BPR]FCY=""
         GMESSAGE = mess(408,199,1) : mkstat=2 : End
      Endif
      WFCY=[F:BPR]FCY
   Else
      WFCY=[M:BPRC]FCY
   Endif
   Gosub CTRL_BETCPY
Endif
End

########################################
Subprog AM_BPCINV(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char    WCODADR(GLONADR)

# --- Alimentation de l'adresse du client facture : Recherche du code adresse par défaut
If VALEUR = [M]BPCNUM
   # --- client facture = client
   For I = 0 To [M:BPAC]NBADR-1
      If [M:BPAC]BPAADDFLG(I)=2
         [M:BPC3]BPAINV=[M:BPAC]CODADR(I)
         Break
      Endif
   Next I
Else
   # --- client facture <> client
   # FGR 19/02/2010 : X3SUIVI62660 Ne pas utiliser [BPC], ça pollue en cas d'import
   #Read [BPC]BPC0 = VALEUR
   Read [BPC1]BPC0 = VALEUR
   #If fstat=0 [M:BPC3]BPAINV=[F:BPC]BPAADD Endif
   If fstat=0 [M:BPC3]BPAINV=[F:BPC1]BPAADD Endif
Endif
Affzo [M:BPC3]BPAINV
If GREP="C" & !find (GINIBPRRSK,2,3) [M:BPC3]BPCRSK=VALEUR : Affzo [M:BPC3]BPCRSK Endif
End
########################################
#Subprog IB_BPAINV
#MAE, le 28/01/09, les boutons de sélection sont supprimés, il ne reste plus qu'une sélection
#If  [M:BPC3]BPCINV = [M:BPC0]BPCNUM
#    Raz GBOUT2
#Else
#    Raz GBOUT1
#Endif
#End
########################################
Subprog AS_BPAINV(VALEUR)
Variable Char    VALEUR()
# --- En import : les adresses sont chargees après le client --> controle impossible
#If GIMPORT
#   If [M:BPC3]BPCINV=[M:BPC0]BPCNUM &[M:BPAC]CODADR(0)=""   : # si meme client et pas adresses saisies
#      mkstat=2 : End                                        : # pas de chargement du code adresse
#   Endif
#Endif

#LSE 05/02/2007 FQ39135
If [M:BPAC]NBADR=0
    #On n'a pas d'adresse
    mkstat=2
Endif

End
########################################
Subprog C_BPAINV(VALEUR)
Variable Char    VALEUR()
Local Integer MATCH_BPAADD

  If VALEUR <> "" Then  # FGR 20/02/2015 : X3SUIVI106383 : pas de contrôle si le champ est vide
    If [M:BPC3]BPCINV = [M:BPC0]BPCNUM
      If !GIMPORT
        # --- client facture = client
        MATCH_BPAADD = find(VALEUR,[M:BPAC]CODADR(0..[M:BPAC]NBADR-1))
        If MATCH_BPAADD = 0 : GMESSAGE = mess(16,199,1) : mkstat = 2 : Endif
      Endif
    Else
      # --- client facture <> client
      Look [BPA]BPA0 = 1;[M:BPC3]BPCINV;VALEUR
      If   fstat>1 : GMESSAGE = mess(16,199,1) : mkstat = 2 : Endif
    Endif
  Endif
End
########################################
Subprog C_BPCPYR(VALEUR)
Variable Char    VALEUR()
If find(GREP,"C","D") & [M:BPC0]REFCOU<>"" & VALEUR=""
   End
Elsif VALEUR=""
   mkstat=2 : End
Endif

Local File BPARTNER [BPR]  # FGR 19/02/2010 : X3SUIVI62660 Sinon ça pollue en cas d'import
# controle existence sur objet tiers
If VALEUR <> [M:BPC0]BPCNUM
   If [F:BPR]BPRNUM<>VALEUR
      Read [BPR]BPR0 = VALEUR
      If fstat  GMESSAGE = mess(23,100,1) : mkstat = 2 : End : Endif
      If [F:BPR]ENAFLG <> 2 GMESSAGE = mess(538,199,1) : mkstat = 2 : End : Endif
   Endif
   #--- Bug 63398
   Call CONTROLE("BPR","L",VALEUR,"",mkstat) From CONTOBJ
   If mkstat=2 End Endif
   #---
Endif
If GACTFTC=2 & [M:BPRC]BETFCY=2 & [M:BPRC]FCY<>""
   # Le client est inter-site
   Local Char WFCY(GLONFCY)
   If VALEUR <> [M:BPC0]BPCNUM
      # Le tiers payeur doit aussi être inter-site
      If [F:BPR]BETFCY<>2 | [F:BPR]FCY=""
         GMESSAGE = mess(408,199,1) : mkstat=2 : End
      Endif
      WFCY=[F:BPR]FCY
   Else
      WFCY=[M:BPRC]FCY
   Endif
   Gosub CTRL_BETCPY
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran BPC3) 19/07/2005 16:21:45 (LD)
######################################################################################
Subprog AM_BPCPYR(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char    WCODADR(GLONADR)

# --- Alimentation de l'adresse du tiers risque : Recherche du code adresse par défaut
If VALEUR = [M]BPCNUM
   # --- tiers risque = client
   For I = 0 To [M:BPAC]NBADR-1
      If [M:BPAC]BPAADDFLG(I)=2
         [M:BPC3]BPAPYR=[M:BPAC]CODADR(I)
         Break
      Endif
   Next I
Else
   # --- tiers risque <> client
   Local File BPCUSTOMER [BPC1]
   Read [BPC1]BPC0 = VALEUR
   If fstat=0 [M:BPC3]BPAPYR=[F:BPC1]BPAADD Endif
Endif
Affzo [M:BPC3]BPAPYR
If GREP="C" & GINIBPRRSK=2 [M:BPC3]BPCRSK=VALEUR : Affzo [M:BPC3]BPCRSK : Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran BPC3) 19/07/2005 15:20:12 (LD)
######################################################################################
#Subprog IB_BPAPYR
#MAE, le 28/01/09, les boutons de sélection sont supprimés, il ne reste plus qu'une sélection
#If  [M:BPC3]BPCPYR= [M:BPC0]BPCNUM
#    Raz GBOUT2
#Else
#    Raz GBOUT1
#Endif
#End
######################################################################################
## Etiquette ajoutée par le superviseur (écran BPC3) 22/12/2005 11:26:25 (JL)
######################################################################################
Subprog AS_BPAPYR(VALEUR)
Variable Char    VALEUR()
# --- En import : les adresses sont chargees après le client --> controle impossible
#If GIMPORT
#   If [M:BPC3]BPCPYR=[M:BPC0]BPCNUM &[M:BPAC]CODADR(0)=""   : # si meme client et pas adresses saisies
#      mkstat=2 : End                                        : # pas de chargement du code adresse
#   Endif
#Endif
End
########################################
Subprog C_BPAPYR(VALEUR)
Variable Char    VALEUR()
Local Integer MATCH_BPAADD

  If VALEUR <> "" Then  # FGR 20/02/2015 : X3SUIVI106383 : pas de contrôle si le champ est vide
    If [M:BPC3]BPCPYR = [M:BPC0]BPCNUM
      If !GIMPORT
        # --- tiers risque = client
        MATCH_BPAADD = find(VALEUR,[M:BPAC]CODADR(0..[M:BPAC]NBADR-1))
        If MATCH_BPAADD = 0 : GMESSAGE = mess(16,199,1) : mkstat = 2 : Endif
      Endif
    Else
      # --- tiers risque <> client
      Look [BPA]BPA0 = 1;[M:BPC3]BPCPYR;VALEUR
      If   fstat>1 : GMESSAGE = mess(16,199,1) : mkstat = 2 : Endif
    Endif
  Endif
End
########################################
Subprog C_BPCGRU(VALEUR)
Variable Char    VALEUR()

Local Char       WTIE(GLONBPR)   : # contrôle validité tiers facture   hcb V6

  WTIE = VALEUR
  If WTIE <> "" Then
    Gosub CONTIE
    # FGR 26/01/2014 : X3SUIVI105701 (début)
    If mkstat = 0 Then
      If WTIE <> [M:BPC0]BPCNUM Then
        If [F:BPC]BPCNUM <> WTIE Then
          Local File BPCUSTOMER [BPC]  # Issue SAM116107 - 2016-12-07 by FGR : Current imported [F:BPC] was corrupted
          Read [BPC]BPC0=WTIE
        Endif
        If [F:BPC]BPCTYP = 4 Then
          GMESSAGE = WTIE - ":" - mess(139,100,1)
          mkstat = 2
        Endif
      Endif
    Endif
    # FGR 26/01/2014 : X3SUIVI105701 (fin)
  Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran BPC3) 22/07/2005 08:03:58 (LD)
######################################################################################
Subprog AM_BPCGRU(VALEUR)
Variable Char    VALEUR()
If GREP="C" & GINIBPRRSK=3 [M:BPC3]BPCRSK=VALEUR : Affzo [M:BPC3]BPCRSK : Endif
End
########################################
Subprog C_BPCRSK(VALEUR)
Variable Char    VALEUR()
Local Char       WTIE(GLONBPR)   : # contrôle existance du tiers risque  hcb V6
WTIE = VALEUR : Gosub CONTIE
If mkstat=2 End Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran BPC3) 26/04/2006 16:43:24 (LD)
######################################################################################
Subprog AM_BPCRSK(VALEUR)
Variable Char    VALEUR()
# Activation/Désactivation des zones de l'encours
# Activation si le client est risque, Désactivation s'il n'est pas risque
If VALEUR=[M]BPCNUM
    # Le tiers risque du client est lui-même : Activation des champs
    Actzo [M:BPC2]10
Else
    # Le tiers risque du client est un autre tiers
    # Si le client était tiers risque, on vérifie s'il est risque d'un autre client
    If varmode ([M:BPC2]OSTCTL)=0
        If !clalev([F:BPC1]) : Local File BPCUSTOMER [BPC1] : Endif
        # Recherche si le client est un tiers risque
        Filter [BPC1] Where [F:BPC1]BPCRSK=[M]BPCNUM & [F:BPC1]BPCNUM<>[M]BPCNUM
        Look [BPC1]BPC0 First
        If fstat=0 Actzo [M:BPC2]10 Else Diszo [M:BPC2]10 Endif
        Filter [BPC1]
    Endif
Endif
End
########################################
Subprog AS_FUPTYP(VALEUR)
Variable Integer VALEUR
If GACTFTC<>2
   GMENLOC(2) = 1
   GMENLOC(4) = 1
   GMENLOC(5) = 1
Endif
End

# --------------------------------------------------------------------------------
#                     Etiquettes appelées depuis ecran BPC3
# --------------------------------------------------------------------------------
# -------------------------------------------------------- #
# Contrôle concernant client inter-site                    #
# Les sites doivent être sur la même société juridique     #
# Les sites doivent être financiers                        #
# -------------------------------------------------------- #
$CTRL_BETCPY
Local Char WLEGCPY(GLONCPY)

If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
If [F:FCY]FCY<> WFCY
    Read [FCY]FCY0=WFCY : If fstat Raz [FCY] Endif
Endif
#   Le site doit être sur la même société juridique que le site rattaché au client
If [F:FCY]LEGCPY<>[M:BPC3]LEGCPY GMESSAGE=mess(411,199,1) : mkstat=2 : Return : Endif
#   Le site doit être financier
If [F:FCY]FINFLG<>2 GMESSAGE=mess(410,199,1) : mkstat=2 : Return : Endif

Return

# FGR 03/11/2014 : X3SUIVI103732 : ajout de [M:BPC4] au lieu de [M] (début)
########################################
#$CHARGE_BPAADD
#Local Integer I
#Gosub SETNOL
#
## ---    init zone
#I=find(WBPAADD,[M:BPAC]CODADR(0..[M:BPAC]NBADR-1))
#If I<>0
#    [M]BPADES(NOL)=[M:BPAC]BPADES(I-1)
#    [M]BPDCRY(NOL)=[M:BPAC]BPACRY(I-1) : [M]BPDPOSCOD(NOL)=[M:BPAC]POSCOD(I-1)
#    If [M]BPAADDFLG(I-1)=2 & !find(2,[M:BPC4]BPDADDFLG(0..[M:BPC4]NBDLV-1))
#        [M]BPDADDFLG(NOL)=2
#    Else
#        [M]BPDADDFLG(NOL)=1
#    Endif
#Endif
#
#
#[M]BPDNAM0(NOL)    = [M:BPRC]BPRNAM(0)
#[M]BPDNAM1(NOL)    = [M:BPRC]BPRNAM(1)
#[M]STOFCY(NOL)     = GFCYDEF(7)
#If [M:BPC4]STOFCY(NOL)<>"" & [F:FCY]FCY<>[M:BPC4]STOFCY(NOL)
#   Read [FCY]FCY0=[M:BPC4]STOFCY(NOL)
#   If fstat Raz [FCY] Endif
#Endif
#[M]BPTNUM(NOL)     = [F:FCY]BPTNUM
#
#Gosub CHARGE_ZONE_BPAADD
#Gosub CHARGE_BPD
#Return
########################################
$CHARGE_BPAADD
Local Integer I

  Gosub SETNOL
  # ---    init zone
  I=find(WBPAADD,[M:BPAC]CODADR(0..[M:BPAC]NBADR-1))
  If I<>0
    #[M:BPC4]BPADES(NOL)=[M:BPAC]BPADES(I-1)  # Issue SAM119072 - 2016-12-06 by FGR : rename field BPADES in BPADESBPC4
    [M:BPC4]BPADESBPC4(NOL)=[M:BPAC]BPADES(I-1)  # Issue SAM119072 - 2016-12-06 by FGR : rename field BPADES in BPADESBPC4
    [M:BPC4]BPDCRY(NOL)=[M:BPAC]BPACRY(I-1) : [M]BPDPOSCOD(NOL)=[M:BPAC]POSCOD(I-1)
    If [M:BPAC]BPAADDFLG(I-1)=2 & !find(2,[M:BPC4]BPDADDFLG(0..[M:BPC4]NBDLV-1))
      [M:BPC4]BPDADDFLG(NOL)=2
    Else
      [M:BPC4]BPDADDFLG(NOL)=1
    Endif
  Endif
  [M:BPC4]BPDNAM0(NOL)    = [M:BPRC]BPRNAM(0)
  [M:BPC4]BPDNAM1(NOL)    = [M:BPRC]BPRNAM(1)
  [M:BPC4]STOFCY(NOL)     = GFCYDEF(7)
  If [M:BPC4]STOFCY(NOL)<>"" & [F:FCY]FCY<>[M:BPC4]STOFCY(NOL)
    Read [FCY]FCY0=[M:BPC4]STOFCY(NOL)
    If fstat Raz [FCY] Endif
  Endif
  [M:BPC4]BPTNUM(NOL)     = [F:FCY]BPTNUM
  Gosub CHARGE_ZONE_BPAADD
  Gosub CHARGE_BPD
Return
# FGR 03/11/2014 : X3SUIVI103732 : ajout de [M:BPC4] au lieu de [M] (fin)

