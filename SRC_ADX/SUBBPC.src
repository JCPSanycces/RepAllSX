######################################################################################
## Etiquette ajoutée par le superviseur (écran BPC4) 07/12/2005 09:02:06 (LD)
######################################################################################
Subprog C_XSTOFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" End Endif
If [M]XRCPFCY<>"" & VALEUR=[M]XRCPFCY mkstat=2 : GMESSAGE=mess(259,194,1) : End Endif
End
########################################
Subprog AM_XSTOFCY(VALEUR)
Variable Char    VALEUR()
[M]STOFCY([M]XNUMLIG) = VALEUR
If VALEUR=""
    If dim([M:BPC4]XBPCLOC)>0 : Raz [M:BPC4]XBPCLOC : Diszo [M:BPC4]XBPCLOC  : Endif
    If dim([M:BPC4]XSCOLOC)>0 : Raz [M:BPC4]XSCOLOC : Diszo [M:BPC4]XSCOLOC  : Endif
    If dim([M:BPC4]BPCLOC)>0 : Raz [M:BPC4]BPCLOC([M]XNUMLIG) : Endif
    If dim([M:BPC4]SCOLOC)>0 : Raz [M:BPC4]SCOLOC([M]XNUMLIG) : Endif
Else
    If dim([M:BPC4]XBPCLOC)>0 : Actzo [M:BPC4]XBPCLOC  : Endif
    If dim([M:BPC4]XSCOLOC)>0 : Actzo [M:BPC4]XSCOLOC  : Endif
Endif
[M:BPC4]FLMOD([M]XNUMLIG) = 1  # FGR 21/12/2010 : X3SUIVI70104
End

########################################
Subprog C_XRCPFCY(VALEUR)
Variable Char    VALEUR()
Local    Char    WLEGCPY(GLONCPY)

#MAE, bg 70408 : on ne contrôle le site que si l'adresse est active
If [M]XENAFLG = 2
    If GACTFTC=2
       If [M]FCY="" End Endif
       # Bug 33874
       If VALEUR="" mkstat=2 : GMESSAGE=mess(10,123,1) : End Endif
       If [M]XSTOFCY<>"" & VALEUR=[M]XSTOFCY mkstat=2 : GMESSAGE=mess(259,194,1) : End Endif
       Local Char WRCPFCY : WRCPFCY=VALEUR
       Gosub CTR_RCPFCY : If mkstat End : Endif
       If [M]FCY=VALEUR End Endif
       # Site de réception et Site rattaché au client (Site de commande)
       # doivent être sur la même société juridique
       WLEGCPY=[F:FCY]LEGCPY
       # Récup de la société juridique du site rattaché au client
       Read [FCY]FCY0=[M]FCY
       If fstat Raz [FCY] Endif
       If [F:FCY]LEGCPY<>WLEGCPY mkstat=2 : GMESSAGE=mess(401,199,1) : Endif
    Endif
Endif
End

$CTR_RCPFCY
# Issue 86974 GA 01/2013
#point d'entrée  pour éviter que ce ctrl d'unicité soit bloquant
GPE=0 : GPOINT = "CTLRCPFCY" : Gosub ENTREE From EXEFNC
If !GPE
  # Le site de réception peut être référencé sur un autre client mais
  # il ne doit pas être référencé sur une autre adresse de livraison de ce client
  nolign=[M]XNUMLIG+1
  Call UNICITE(WRCPFCY,[M]RCPFCY) From OBJDIV
  If mkstat
      Local Integer I : I=val(right$(vireblc(GMESSAGE,1),len(vireblc(GMESSAGE,1))))
      GMESSAGE = mess(350,198,1)-":"-mess(414,199,1)
      If I>0 & I<=[M]NBDLV GMESSAGE-=":"-[M:BPC0]BPCNUM-[M:BPC4]BPAADD(I-1) Endif
  Endif
Endif
Return
########################################
Subprog AM_XRCPFCY(VALEUR)
Variable Char    VALEUR()
[M]RCPFCY([M]XNUMLIG) = VALEUR
[M:BPC4]FLMOD([M]XNUMLIG) = 1  # FGR 21/12/2010 : X3SUIVI70104
End


########################################
Subprog AV_XBPCLOC(VALEUR)
Variable Char    VALEUR()
GLOCSEL = "[F:STC]LOCCAT=3"
End

Subprog AM_XBPCLOC(VALEUR)
Variable Char    VALEUR()
[M]BPCLOC([M]XNUMLIG) = VALEUR
[M:BPC4]FLMOD([M]XNUMLIG) = 1  # FGR 21/12/2010 : X3SUIVI70104
End

########################################
Subprog AV_XSCOLOC(VALEUR)
Variable Char    VALEUR()
GLOCSEL = "[F:STC]LOCCAT=4"
End

Subprog C_XSCOLOC(VALEUR)
Variable Char    VALEUR()
Local Integer OK

If VALEUR="" End Endif

Columns [BPD] (BPCNUM,BPAADD,BPDNAM,SCOLOC)
For [BPD] Where SCOLOC=VALEUR
   If [F:BPD]BPCNUM<>[M:BPC0]BPCNUM | [F:BPD]BPAADD<>[M]BPAADD([M]XNUMLIG)
      GMESSAGE=mess(470,199,1)-":"-[F:BPD]BPCNUM-[F:BPD]BPAADD-"-"-[F:BPD]BPDNAM
      Call AVERTIR(GMESSAGE,OK) From GESECRAN
      Raz GMESSAGE
      If OK=1
         OK=0 : mkstat=2 : Break
      Endif
   Endif
Next
Columns [BPD]

End

Subprog AM_XSCOLOC(VALEUR)
Variable Char    VALEUR()
[M]SCOLOC([M]XNUMLIG) = VALEUR
[M:BPC4]FLMOD([M]XNUMLIG) = 1  # FGR 21/12/2010 : X3SUIVI70104
End

