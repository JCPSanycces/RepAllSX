#######################################################
# Appelé en AM_BPCNUM et AM_SOC
#MAE, le 08/12/08, l'étiquette est passée en sous pro car pb en RAZDUP si [M:BPC0]BPCNUM est affecté avant
#$INIT_BPC

Subprog INIT_BPC(VALEUR)
Variable Char  VALEUR()
#MAE, bg 51584
Local Integer NBPOSTE

#--- Issue 106137
If GACTFTC=2
  Raz [M:BPC1]ORDTEX
  Raz [M:BPC1]INVTEX
#--- Issue 106137
Endif
# Pb en import
# Il ne faut pas écraser [F:BPR] qui peut être chargé avec des champs à importer (Ex import de la raison sociale)
# ==> Lecture du tiers sous une autre abréviation
If !clalev([F:BPR1]) : Local File BPARTNER [BPR1] : Endif
#Read [BPR1]BPR0 = [M:BPC0]BPCNUM
Read [BPR1]BPR0 = VALEUR
If fstat = 0
   # Le tiers existe : alimentation des zones venant de la fiche tiers
   [M:BPRC] = [F:BPR1]
   [M:BPC0]BPCNAM = [F:BPR1]BPRNAM
   Affzo [M:BPC0]BPCNAM
   Affzo [M:BPRC]1-99
   Default Mask [BPAC]
   #MAE,08/12/08
   #Call CHARG_BPA(1,[M:BPC0]BPCNUM,[F:BPR1]BPAADD) From TRTBPA
   Call CHARG_BPA(1,VALEUR,[F:BPR1]BPAADD) From TRTBPA
   Default Mask [BIDC]
   #MAE,08/12/08
   #Call CHARG_RIB(1,[M:BPC0]BPCNUM,"~") From TRTBPA
   Call CHARG_RIB(1,VALEUR,"~") From TRTBPA
   Default Mask [CNTC]
   #MAE,08/12/08
   #Call CHARG_CNT(1,[M:BPC0]BPCNUM,[F:BPR1]CNTNAM) From TRTBPA
   Call CHARG_CNT(1,VALEUR,[F:BPR1]CNTNAM) From TRTBPA
   Default Mask [BPC0]

   Affzo [M:BPAC]1-99
   Affzo [M:BIDC]1-99
   Affzo [M:CNTC]1-99
   GIBPCEXIST = 1

   # Le tiers n'existe pas en tant que client ou on a fait fichier nouveau ou transformation
   If [F:BPR1]BPCFLG <> 2 | GREP="C"
      If GACTFTC=2
         Local Char WFCY(GLONFCY) : WFCY=[M:BPRC]FCY
         # On peut alimenter l'adresse du 1er client livré avec l'adresse par défaut du tiers
         # --------------------------------------
         [M:BPC4]BPAADD(0)=[F:BPR1]BPAADD
         # --------------------------------------
         [M:BPC4]FLMOD(0) = 1  # FGR 21/12/2010 : X3SUIVI70104

         Local Char WBPAADD(GLONADR) : WBPAADD=[M:BPC4]BPAADD(0)

         [M:BPC4]NBDLV=1
         nolign = 1
         Gosub CHARGE_BPAADD
         Affzo [M:BPC4]5, 10
      Endif
      #-------------------------------------#
      # il faut verrouiller symbole BPR     #
      # si pas deja fait dans action verrou #
      #-------------------------------------#
      If GNAVIG(GPILNAV-1) <> "GESBPR" or (GNAVIG(GPILNAV-1) = "GESBPR" and [M:BPR0]BPRNUM <> VALEUR) Then # FGR 16/04/2012 : X3SUIVI81335
        #MAE, 08/12/08
        #SYMBOLE2 = "BPR"+num$([M:BPC0]BPCNUM)
        SYMBOLE2 = "BPR"+num$(VALEUR)
        Lock = SYMBOLE2 With lockwait = 0
        If fstat
          If GREP = "C" or GREP = "D"
            GERR=1 : GMESSAGE = mess(10,100,1)
            mkstat = 2 : End
          Endif
        Else
          # FGR 16/04/2012 : X3SUIVI81335
          Global Integer GILOCKBPR

          GILOCKBPR = 1
        Endif
      Endif
   Endif
Else
   # Le tiers n'existe pas
   # On a besoin de connaitre la devise pour charger les elements de facturation
   Raz [F:BPR1]
   If [M:BPRC]CUR ="" #MAE, bg82534
    If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
      If [F:TCY]CRY <> GPAYS
        Read [TCY]TCY0 = GPAYS
        If fstat Raz [F:TCY] Endif
        [M:BPRC]CUR = [F:TCY]CUR
      Endif
    Endif
   Endif
# Création d'un client : alimentation des zones
If [F:BPR1]BPCFLG <> 2 | GREP = "C"
   #MAE, 08/12/08
   #If [M:BPC3]BPCGRU="" [M:BPC3]BPCGRU = [M:BPC0]BPCNUM : Affzo [M:BPC3]BPCGRU : Endif
   If [M:BPC3]BPCGRU="" [M:BPC3]BPCGRU = VALEUR : Affzo [M:BPC3]BPCGRU : Endif
   If GACTFTC=2 & [M:BPRC]BETFCY=2 & [M:BPRC]FCY <> ""
      Local Char WFCY(GLONFCY) : WFCY=[M:BPRC]FCY
      #MAE, 08/12/08
      #Local Char WBPCNUM : WBPCNUM=[M:BPC0]BPCNUM
      Local Char WBPCNUM(GLONBPR) : WBPCNUM=VALEUR                             # FGR 11/04/2012 : X3SUIVI81394
      Local Char WBPAADD(GLONADR) : WBPAADD=[F:BPR1]BPAADD                     # FGR 11/04/2012 : X3SUIVI81394
      Gosub ALI_BETFCY
   Else
      #MAE, 08/12/08
      #If [M:BPC3]BPCINV="" [M:BPC3]BPCINV = [M:BPC0]BPCNUM : [M:BPC3]BPAINV=[F:BPR1]BPAADD : Endif
      If [M:BPC3]BPCINV="" [M:BPC3]BPCINV = VALEUR : [M:BPC3]BPAINV=[F:BPR1]BPAADD : Endif
      #MAE, 08/12/08
      #If [M:BPC3]BPCPYR="" [M:BPC3]BPCPYR = [M:BPC0]BPCNUM : [M:BPC3]BPAPYR=[F:BPR1]BPAADD : Endif
      If [M:BPC3]BPCPYR="" [M:BPC3]BPCPYR = VALEUR : [M:BPC3]BPAPYR=[F:BPR1]BPAADD : Endif
   Endif
   If [M:BPC3]BPCRSK=""
       Case GINIBPRRSK
           When 2       : [M:BPC3]BPCRSK=[M:BPC3]BPCPYR
           When 3       : [M:BPC3]BPCRSK=[M:BPC3]BPCGRU
           When Default : [M:BPC3]BPCRSK=[M:BPC3]BPCINV
       Endcase
   Endif
   Affzo [M:BPC3]BPCINV, BPAINV
   Affzo [M:BPC3]BPCPYR, BPAPYR, BPCRSK
   If GACTFTC=2
      #---- chargt tableau des elements de facturation pour CLIENT seulement #
      #MAE bug 105559
      #If [M:BPC1]NBFAC = 0 | GREP="C"
      If [M:BPC1]NBFAC = 0
         NBPOSTE = dim ([M:BPC1]INVDTA)
         Call  SAISFOOT (1,"BPC1",NBPOSTE,[M:BPC2]CHGTYP,GSYSCUR,[M:BPRC]CUR,"OUI") From SUBSFIT
         [M:BPC1]NBFAC = NBPOSTE
      Endif
      #---- chargement devise client sur ligne montant
      For nolign = 0 To [M:BPC1]NBFAC-1
         If [M:BPC1]AMTCOD(nolign) = 2
            [M:BPC1]WWCUR(nolign)  = [M:BPRC]CUR
         Endif
      Next
      Affzo [M:BPC1]30
   Endif
Endif
If GACTFTC=2
   If [M:BPRC]BETFCY = 2
      Actzo [M:BPRC]FCY
      Actzo [M:BPC4]XRCPFCY
   Else
      Grizo [M:BPRC]FCY
      Grizo [M:BPC4]XRCPFCY
   Endif
Endif
End
#Return

$ALI_BETFCY
If find (GREP,"C","D")  #MAE, bg 79523
  Raz [M:BPC3]BPCINV, BPCPYR, BPAINV
Endif
# Si client inter-site
If clalev([F:FCY])=0 Local File FACILITY [FCY]  : Endif
#   Lecture du site lié au client
If  [F:FCY]FCY<>WFCY
    Read [FCY]FCY0=WFCY : If fstat Raz [FCY] Endif
Endif
[M:BPC3]LEGCPY = [F:FCY]LEGCPY
#   => Init. client facture et tiers payeur avec le tiers lié au site financier du site client
If [F:FCY]FINFLG = 2
  If find (GREP,"C","D")  #MAE, bg 79523
    [M:BPC3]BPCPYR=WBPCNUM : [M:BPC3]BPAPYR=WBPAADD
    [M:BPC3]BPCINV=WBPCNUM : [M:BPC3]BPAINV=WBPAADD
  Endif
Elsif [F:FCY]FINRSPFCY <> ""
    Read [BPR]BPR2(2)=2;[F:FCY]FINRSPFCY
    If !fstat
        If find (GREP,"C","D")  #MAE, bg 79523
          [M:BPC3]BPCPYR=[F:BPR]BPRNUM : [M:BPC3]BPAPYR=[F:BPR]BPAADD
        Endif
        If [F:BPR]BPCFLG=2
           If find (GREP,"C","D")  #MAE, bg 79523
            [M:BPC3]BPCINV=[F:BPR]BPRNUM : [M:BPC3]BPAINV=[F:BPR]BPAADD
           Endif
        Endif
    Elsif (find (GREP,"C","D") & WFCY=[F:FCY]FINRSPFCY)
    Endif
#    [G:BPR]currind=1 : [G:BPR]currlen=0 : # Réinitialisation clé par défaut
Endif
Return

