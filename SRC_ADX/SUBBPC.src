Subprog C_COMCAT(VALEUR)
Variable Integer VALEUR
#---- élément non autorisé
If VALEUR > GCOMCAT
   GMESSAGE = mess(75,199,1) : mkstat = 2 : End : Endif
End

########################################
Subprog IB_REP

If GMODU(13) = 2
   GBOUT2 = mess(415, 196, 2) #Représentants secondaires.
Else
   Raz GBOUT2
Endif
End

########################################
Subprog C_REP(VALEUR)
Variable Char    VALEUR()
#---- erreur si rep1 saisi et rep0 non saisi
If indice = 1 & REP(0) = "" & VALEUR <> ""
   GMESSAGE = mess(6,199,1) : mkstat = 2 : End
Endif
End

######################################################################################
Subprog AM_REP(VALEUR)
Variable Char    VALEUR()

Local Integer NI

  # FGR 27/11/2013 : X3SUIVI94714
  If GMODU(13) <> 2 Then
    # S'il n'y a pas le module CRM ne rien faire
    End
  Endif
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    # S'il n'y a pas la synchro Outlook ou si les contacts ne sont pas synchronisés ne rien faire
    End
  Endif
  # ------------------------------------------------------
  # S'il y a une modification sur le représentant on force la modification sur les contacts
  # pour que la table des CORRESPONDANTS soit mise à jour
  For NI = 0 To [M:CNTC]NBCNT-1
    [M:CNTC]FLMOD(NI) = 1
  Next NI
End

