########################################
Subprog AM_XMDL(VALEUR)
Variable Char    VALEUR()
[M]MDL([M]XNUMLIG) = VALEUR

[M]XEECICT = [F:TMD]EECICT
[M]EECICT([M]XNUMLIG) = [F:TMD]EECICT
If dim([M]XEECLOC)>0
    [M]XEECLOC = [F:TMD]EECLOC
    [M]EECLOC([M]XNUMLIG) = [F:TMD]EECLOC
    Affzo [M]XEECLOC
Endif
Affzo [M]XEECICT
[M:BPC4]FLMOD([M]XNUMLIG) = 1  # FGR 21/12/2010 : X3SUIVI70104
End

