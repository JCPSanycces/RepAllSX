Subprog IB_NBDLV

#Modif CRM 05/02/2002
If GMODU(13) = 2
    Case GREP
        When ""
            If GMSTDLV <> 2
                Raz GBOUT3
            Endif
        When "M", "C", "D"
            Raz GBOUT3
        When Default
    Endcase
Else
    Raz GBOUT3
Endif

End

##########################################################################
Subprog C_COTCHX(VALEUR)
Variable Char    VALEUR()

  #Modif CRM 24/09/2003
  If VALEUR <> "" Then
    Read [COT]COT0=VALEUR
    If fstat Then
      #Valeur incorrecte
      GMESSAGE = mess(7,135,1)
      GERR = 1
      mkstat = 2
    Else
      If [F:COT]CONCAT <> 4 Then
        #La catégorie du modèle de contrat sélectionné est incorrecte.
        GMESSAGE = mess(469,182,1)
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran BPC2) 25/02/2009 15:15:03 (FGR)
######################################################################################
Subprog AM_COTCHX(VALEUR)
Variable Char    VALEUR()

  # FGR 25/02/2009 : X3SUIVI26307
  If VALEUR <> "" Then
    If [F:COT]CONNUM <> VALEUR Then
      Read [COT]COT0=VALEUR
    Endif
    If [M:BPC2]COTPITRQD = 0 and [F:COT]PITRQD <> 0 Then
      [M:BPC2]COTPITRQD = [F:COT]PITRQD
      Affzo [M:BPC2]COTPITRQD
    Endif
  Endif
End
