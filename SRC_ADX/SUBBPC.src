########################################
Subprog C_BCGCOD(VALEUR)
Variable Char    VALEUR()

# Catégorie obligatoire
# Issue 91498 - 2013-08-01 by MAE : Si on vient du prospect GREP=M et on crée un client donc la catégorie est obligatoire
##If find(GREP,"C","D") & VALEUR=""
If (find(GREP,"C","D") | (find(GREP,"M") & (GNAVIG(max(GPILNAV-1,1)) = "GESBPP"))) & VALEUR=""
   GMESSAGE = mess(10,123,1)
   mkstat=2
Endif
End

########################################
Subprog AM_BCGCOD(VALEUR)
Variable Char    VALEUR()

Local Char WBPAADD(GLONADR)              # FGR 26/07/2010 : X3SUIVI65907

#si le client n'est pas renseigné, la classe BPR1 ne doit pas être remplie,
#elle sera reseignée quant le client sera saisie
If [M:BPC0]BPCNUM=""
  Raz [F:BPR1]
Endif

#MAE, Bg 48117, 15/07/08
#If find(GREP,"C","D")
# Bug 68855 : GORITRFBPP<>"" : Transformation prospect en clt depuis le picking devis en gestion des cdes
#If find(GREP,"C","D") | (GREP = "M" & (GNAVIG(max(GPILNAV-1,1)) = "GESBPP"))                      : # Bug 68855
If find(GREP,"C","D") | (GREP = "M" & ((GNAVIG(max(GPILNAV-1,1)) = "GESBPP" | GORITRFBPP<>"")))    : # Bug 68855
   Call INI_BCGCATEG(VALEUR)
   # FGR 27/04/2016 : X3SUIVI116131 (début)
   Local Integer IGBCRMFLGNEW

   IGBCRMFLGNEW = GBCRMFLGNEW
   Gosub RAZCRE_CRM From TRTBPCRM
   # FGR 27/04/2016 : X3SUIVI116131 (fin)
   #--- Issue 106137
   If GORITRFBPP="" & GACTFTC=2
   #If GORITRFBPP=""                                                                                : # Bug 68855
   #---
       WBPAADD=[M:BPC4]BPAADD(0)             # FGR 26/07/2010 : X3SUIVI65907
       nolign = 1                            # FGR 26/07/2010 : X3SUIVI65907
       Gosub CHARGE_BPAADD From SUBBPC       # FGR 26/07/2010 : X3SUIVI65907
   Endif
   If VALEUR <> [F:BPR1]BRGCOD & VALEUR <>"" & [F:BPR1]BRGCOD <> ""
          Call MESSAGE(mess(104,187,1)+" "+[F:BPR1]BRGCOD) From GESECRAN
   Endif
   # IRMUE 03.07.12 81574:AP/AR management
   If GACTFTC=2 Call CHK_PRITYP(VALEUR) Endif    : # Issue 106137
   # IRMUE 03.07.12 81574:AP/AR management  end
                                                                                       : # Bug 68855
   Affzo [M:BPRC]1-99
   If GACTFTC=2 Affzo [M:BPC1]1-99 Endif    : # Issue 106137
   Affzo [M:BPC2]1-99
   Affzo [M:BPC3]1-99
   If GACTFTC=2 Affzo [M:BPC4]1-99 Endif    : # Issue 106137
Endif

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
Call VALIDATE_CSHVATRGM_CRY([M:BPRC]CRY) From PORLEGLIB
#94635 RICAR 2014/04/21 - CASH VAT - END
End

########################################
Subprog INI_BCGCATEG(COD)
Variable Char    COD
Local    Integer SPSTAT
Local Integer    I
Local Char SZREP(15) (0 ..1)
Local Char SZTSCCOD(5) (0..4)
Local Integer SZPRITYP            : # Bug 68855
Local Char    SZVACBPR(GLONTVB)   : # Bug 68855
Local Char    SZPTE(GLONPTE)      : # Bug 68855
Local Char    SZDEP(GLONTDA)      : # Bug 68855
#Local Char    SZACCCOD(GLONCAC)   : # Bug 68855
Local Integer ICOMCAT               # FGR 04/06/2014 : X3SUIVI100585

If COD="" End Endif
Read [BCG]BCG0=COD
If fstat  End Endif
#MAE/TS, bg 50894 init du nolign a 1 pour le transclasse d'un champ dimensionné (REP)
nolign = 1
[M:BPC0]=[F:BCG]
#MAE, le 05/05/09, bg 54932=>si on vient du prospect, les infos ne sont pas écrasées par celles de la catégorie.
#MAE, bg 76255
#If GNAVIG(max(GPILNAV-1,1)) <> "GESBPP"
If find(GNAVIG(max(GPILNAV-1,1)),"GESBPP","GESBPR")=0
    [M:BPRC]=[F:BCG]
Endif
If GNAVIG(max(GPILNAV-1,1)) = "GESBPP" | GORITRFBPP = "GESSOH"  #MAE, bg83554
    If dim([M:BPC1]REP)>0
     If REP(0)<>"":  SZREP(0) = REP(0) : Endif
    Endif
    If dim([M:BPC1]REP)>1
        If REP(1)<>"":   SZREP(1) = REP(1) : Endif
    Endif
    ICOMCAT = [M:BPC1]COMCAT   # FGR 04/06/2014 : X3SUIVI100585
    [M:BPC1]=[F:BCG]
    # FGR 04/06/2014 : X3SUIVI100585 (début)
    If ICOMCAT > 0 Then
      [M:BPC1]COMCAT = ICOMCAT
    Endif
    # FGR 04/06/2014 : X3SUIVI100585 (fin)
    If dim([M:BPC1]REP)>0
        If  SZREP(0)<>"" :   REP(0) = SZREP(0) : Endif
    Endif
    If dim([M:BPC1]REP)>1
        If SZREP(1)<>"" :  REP(1) = SZREP(1) : Endif
    Endif
    If dim([M:BPC2]TSCCOD) > 0
      For I = 0 To dim([M:BPC2]TSCCOD)-1
        If [M:BPC2]TSCCOD(I) <> ""
            SZTSCCOD(I) = TSCCOD(I)
        Endif
      Next I
    Endif
    [M:BPC2]=[F:BCG]
    If dim([M:BPC2]TSCCOD) > 0
      For I = 0 To dim([M:BPC2]TSCCOD)-1
        If SZTSCCOD(I) <> ""
            [M:BPC2]TSCCOD(I) = SZTSCCOD(I)
        Endif
      Next I
    Endif
    #MAE, bg 71250, vu avec LD, on récupére le code comptable de la catégorie
    #SZACCCOD=ACCCOD  : # Bug 68855
    [M:BPC3]=[F:BCG] : # Bug 68855
    #ACCCOD=SZACCCOD  : # Bug 68855
# Bug 68855 : Transf. prospect en client via picking des devis en gestion des commandes : Il ne faut pas écraser les données initialisées avec le devis
Elsif GORITRFBPP<>"" & GORITRFBPP<>"GESSOH"
    If dim([M:BPC1]REP)>0
     If REP(0)<>"":  SZREP(0) = REP(0) : Endif
    Endif
    If dim([M:BPC1]REP)>1
        If REP(1)<>"":   SZREP(1) = REP(1) : Endif
    Endif
    SZPRITYP=PRITYP
    ICOMCAT = [M:BPC1]COMCAT   # FGR 04/06/2014 : X3SUIVI100585
    [M:BPC1]=[F:BCG]
    # FGR 04/06/2014 : X3SUIVI100585 (début)
    If ICOMCAT > 0 Then
      [M:BPC1]COMCAT = ICOMCAT
    Endif
    # FGR 04/06/2014 : X3SUIVI100585 (fin)
    If dim([M:BPC1]REP)>0
        If  SZREP(0)<>"" :   REP(0) = SZREP(0) : Endif
    Endif
    If dim([M:BPC1]REP)>1
        If SZREP(1)<>"" :  REP(1) = SZREP(1) : Endif
    Endif
    PRITYP=SZPRITYP

    [M:BPC2]=[F:BCG]

    SZVACBPR=VACBPR
    SZPTE=PTE
    SZDEP=DEP
    #MAE, bg 71250, vu avec LD, on récupére le code comptable de la catégorie
    #SZACCCOD=ACCCOD
    [M:BPC3]=[F:BCG]
    VACBPR=SZVACBPR
    PTE=SZPTE
    DEP=SZDEP
    #ACCCOD=SZACCCOD
# Bug 68855
Else
    If GACTFTC=2 [M:BPC1]=[F:BCG] Endif   : # Issue 106137
    [M:BPC2]=[F:BCG]
    #MAE, bg 71250, vu avec LD, on récupére le code comptable de la catégorie
    #SZACCCOD=ACCCOD
    [M:BPC3]=[F:BCG] : # Bug 68855
    If GACTFTC=2 [M:BPC4]=[F:BCG] Endif   : # Issue 106137
    #ACCCOD=SZACCCOD  : # Bug 68855
Endif

#[M:BPC3]=[F:BCG]    : # Bug 68855

#si le tableau des axes est vide après le transclasse depuis les catégories, on recharge le tableau avec les axes par défaut
#-----------------------------#
# Chargement tableau des axes #
#-----------------------------#
If dim([M:BPC3]NBAXE)>0
    If [M:BPC3]DIE(0) = ""
      If dim([M:BPC0]SOC)>0 & [M:BPC0]SOC<>""
        Call CHARG_DIE(2,[M:BPC0]SOC,"BPC3","NBAXE") From TRTX3CPT
      Else
        Call CHARG_DIE(2,"","BPC3","NBAXE") From TRTX3CPT
      Endif
    Endif
Endif


If [F:BCG]CREMOD=2
   [M:BPC0]BPCSTA=1
Else
   [M:BPC0]BPCSTA=2
Endif

Gosub TRT_FOOT From SUBBPCA

[M:BPC2]XCUR = GCUR
If GACTFTC=2 [M:BPC1]XCUR = GCUR Endif

#--- conversion montants devise dossier en devise société
Local Decimal WMONTORG (0..2)
Local Decimal WMONTDES (0..2)
Local Decimal WDECIMAL
Read [TCU]TCU0=GCUR
If !fstat WDECIMAL = [F:TCU]CURRND Endif

If GACTFTC=2
   WMONTORG (0) = [F:BCG]ORDMINAMT
   Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG (0),WMONTDES (0),SPSTAT) From TRTDEV
   If SPSTAT = 0
      [M:BPC1]WORDMINAMT = arr(WMONTDES (0),WDECIMAL)
   Else
      [M:BPC1]WORDMINAMT = [F:BCG]ORDMINAMT
   Endif
Endif
WMONTORG (2) = [F:BCG]OSTAUZ
Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG (2),WMONTDES (2),SPSTAT) From TRTDEV
If SPSTAT = 0
    #MAE, bg 74262
   [M:BPC2]WOSTAUZ    = arr(WMONTDES (2),WDECIMAL)
Else
    #MAE, bg 74262
   [M:BPC2]WOSTAUZ    = [F:BCG]OSTAUZ
Endif
If dim([M:BPC3]FUPMINAMT) >0 : [M:BPC3]FUPMINAMT = [F:BCG]FUPMINAMT : Endif
If dim([M:BPC3]BELVATSUB)>0
 If find(GREP,"C","D") & [M:BPRC]CRY="BE" : [M:BPC3]BELVATSUB=2 : Else [M:BPC3]BELVATSUB=1 : Endif
Endif
End

########################################
Subprog AS_BPCNUM(VALEUR)
Variable Char    VALEUR()

# FGR 19/08/2011 : X3SUIVI75723 :
#                  Si on est en import ça devrait fonctionner comme si on était venu en tunnel.
#                  Reproduire le fonctionnement transactionnel :
#                     Si la référérence n'existe pas on ne peut pas importer le client (parce qu'on est sensé ne pas pouvoir saisir la référence).
#                     Si la référence existe l'import s'applique au tiers existant en conservant sa référence.
  #MAE, le 27/01/09, bg 49572
  #If [M:BPC0]REFCOU<>"" & find(GREP,"C","D")
  #If [M:BPC0]REFCOU<>"" & find(GREP,"C","D") & GFONC1<>"GESBPR" Then
  If [M:BPC0]REFCOU<>"" & find(GREP,"C","D") & GFONC1<>"GESBPR" and !GIMPORT Then
    mkstat = 2
  Endif
  If GNAVIG(max(GPILNAV-1,1)) = "GESBPR" & (GREP = "" | GREP="C") and !GIMPORT Then
    If [M:BPR0]BPRNUM <> "" & [M:BPC0]BPCNUM=""
      VALEUR = [M:BPR0]BPRNUM
    Endif
  Endif
End

########################################
Subprog C_BPCNUM(VALEUR)
Variable Char    VALEUR()
If [M:BPC0]REFCOU="" & VALEUR=""
   mkstat=2
Endif
End

########################################
Subprog AM_BPCNUM(VALEUR)
Variable Char VALEUR
#MAE, bg 51584
#Local Integer NBPOSTE
Local Integer IREP
Local Char SZNOMBPP(200)
SZNOMBPP = VALEUR + mess(259, 196, 2)
IREP = 0
GIBPCEXIST = 0
# En transformation prospect en client, la modification du code est impossible
If GORITRFBPP <> "" & VALEUR <> [M]BPCNUM GMESSAGE = mess(438,199,1) : mkstat=2 : End : Endif

# Il n'y aura pas de notion de société dans les rôles
Look [BPC]BPC0=VALEUR
If !fstat
    # Si le client existe, Vérification qu'il est bien autorisé par la gestion des rôles -----#
    # (S'il n'existe pas, il faut autoriser sa création)
    GBIDC2="" : Call FILROLE("BPC",GBIDC2) From SUBARL
    If GBIDC2<>""
        Filter [BPC] Where evalue(GBIDC2)
        Look [BPC] BPC0=VALEUR
        Filter [BPC]
        If fstat  End : Endif
    Endif
    #-----
Endif

  # FGR 19/08/2011 : X3SUIVI75723 (début)
  If [M:BPC0]REFCOU <> "" & find(GREP,"C","D") and GIMPORT Then
    If !clalev([F:BPR1]) : Local File BPARTNER [BPR1] : Endif
    Read [BPR1]BPR0=VALEUR
    If fstat Then
      GERR = 1
      GMESSAGE = mess(572,199,1)
      mkstat = 2
      End
    Endif
  Endif
 # FGR 19/08/2011 : X3SUIVI75723 (fin)

#[M:BPC0]BPCNUM=VALEUR
#Gosub INIT_BPC
Call INIT_BPC(VALEUR)

End

