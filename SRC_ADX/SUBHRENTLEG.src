############################################################
#
# Library of Legislation procedures for Arrival of employees
#
# Window  : OHRENT
# Screens : HRENT
#
############################################################

########################################
#Display\Hide fields based on legislation
########################################
Subprog DISPLAY_HIDE()

  Call HIDE_ACTIVITYFIELDS From WOHRENTHIDE
  Call SHOW_LEGACTCALLS From WOHRENTSHOW

  #show all SPECIFIC fields
  If clalev([F:AMKW])=0     : Local File AMSK [AMKW]       : Endif
  If clalev([F:AMZW])=0     : Local File AMSKZON [AMZW]    : Endif
  Local Char WSIGN(1)
  Local Char WSAV_LEG(5)
  WSAV_LEG= GCURLEG
  GCURLEG=""
  Gosub SHOW_ALL_SPECIFIC
  GCURLEG=WSAV_LEG
  WSIGN="-"
  Gosub HIDE_SPECIFIC
  #hide SPECIFIC fields

End

$SHOW_ALL_SPECIFIC
  # hide fields
  Gosub HIDE_SPECIFIC

  # restore title
  Read [F:AMKW]CODMSK = "ENTSAL3"
  WNUMLIBEL=[F:AMKW]TITBLOC(5)
  Chgtbk [M:ENT3]35         With func AFNC.TEXTE(WNUMLIBEL)
  Read [F:AMZW]CODE = "ENTSAL0";"NAM"
  WNUMLIBEL=[F:AMZW]INTIT
  Chgtzn [M:ENT0]NAM        With func AFNC.TEXTE(WNUMLIBEL)

Return


$HIDE_SPECIFIC
#JOJAC - 2016-07-12 - REQ114309 - START
#If func DIVPAYE.IS_ZA_DEV()>0
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#JOJAC - 2016-07-12 - REQ114309 - END

  Chgtbk [M:ENT3]35         With mess(1,10388,1)
  Chgtzn [M:ENT0]NAM        With mess(4,11738,1)
#JOJAC - 2016-07-12 - REQ114309 - START
#Endif
#If func DIVPAYE.IS_ZA_DEV()>0
#JOJAC - 2016-07-12 - REQ114309 - START
    Chgfmt [M:ENT3]WCATCSP    With WSIGN+"K:20X"
    Chgfmt [M:ENT3]WSTACAT    With WSIGN+"K:20X"
    Chgfmt [M:ENT3]WURS1      With WSIGN+"K:20X"
Endif
If !func DIVPAYE.IS_KFR_LEG(GCURLEG)
   Chgfmt [M:ENT1]CODSEE      With WSIGN+"K:5"
   #JOJAC - 2016-07-12 - REQ114309 - START
   #Chgfmt [M:ENT1]CTYBRN      With WSIGN+"K:20g"
   #JOJAC - 2016-07-12 - REQ114309 - END
   Chgfmt [M:ENT1]CTYBRNSEE   With WSIGN+"K:5"
   Chgfmt [M:ENT1]DEPBRN      With WSIGN+"K:#B"
Endif

#JOJAC - 2016-07-12 - REQ114309 - START
If !func DIVPAYE.IS_KZA(GCURLEG)
   Chgfmt [M:ENT1]CTYBRN      With WSIGN+"K:20g"
Endif
#JOJAC - 2016-07-12 - REQ114309 - END

#DEHEN - 2017-04-27 - X3-22269 - START
If !func DIVPAYE.IS_BRI_LEG(GCURLEG) Then
  Chgfmt [M:ENT2]WRITWRK        With WSIGN+"LA:1"
  Chgfmt [M:ENT2]WSTRDLC        With WSIGN+"LA:11816"
  Chgfmt [M:ENT2]WTAXCOD        With WSIGN+"K:50X"
  Chgfmt [M:ENT2]WK1MH1        With WSIGN+"LA:1"
  Chgfmt [M:ENT2]WNINNUM        With WSIGN+"K:9X"
  Chgfmt [M:ENT2]WNICAT         With WSIGN+"K:50X"
  #Chgfmt [M:ENT2]WSTULOA        With WSIGN+"LA:1"
  Chgfmt [M:ENT2]WSTULOATYP     With WSIGN+"LA:11806"
  Chgfmt [M:ENT2]WSTULOAPIO     With WSIGN+"Nz:2"
  Chgfmt [M:ENT2]WSTULOADAT     With WSIGN+"D:"+GFMDAT4
  Chgfmt [M:ENT2]WSTULOADATEND  With WSIGN+"D:"+GFMDAT4

Endif
#DEHEN - 2017-04-27 - X3-22269 - END
#MASHI - 2017-05-26 - JIRA X3-42004 - START
#MIPEA - 2017-07-07- US X3-47968- START
If func DIVPAYE.IS_BRI_LEG(GCURLEG) and func DIVPAYE.EXISTE_KXX("SUBHRENTUKI") Then
#If !func DIVPAYE.IS_BRI_LEG(GCURLEG) and func DIVPAYE.EXISTE_KXX("SUBHRENTUKI") Then
#MIPEA - 2017-07-07- US X3-47968- END
    Call C_PRVFRM([M:ENT6]PRVFRM) From SUBHRENTUKI

Endif
#MASHI - 2017-05-26 - JIRA X3-42004 - START

Return

Subprog DISPLAY_HIDE_OLD()
Local Char WSIGN(1)
#show name block
Local Integer WDISPBLCK
Local Char WNAMEBLCK,WNAMEBLCK1
If clalev([F:AMKW])=0 : Local File AMSK [AMKW] : Endif
If clalev([F:AWIN])=0 : Local File AWINDOW [AWIN] : Endif
Case GCURLEG
 When "FRA","" :
    WSIGN=""
    WDISPBLCK=1
When Default :
  WSIGN="-"
  WDISPBLCK=0
Endcase
#TABS ENTSAL3
Gosub BLOCKENTSAL3
Gosub BLOCKENTSAL2
Gosub FIELDENTSAL1
Gosub FIELDENTSAL2
Gosub FIELDENTSAL3
End

#$BLOCKENTSAL3
#Read [F:AWIN]AWI0 = "OHRENT"
#If(WDISPBLCK)
#  WNAMEBLCK=func AFNC.TEXTE([F:AWIN]INTMSK(2))
#Endif
#Chgtfd [M:ENT3] With WNAMEBLCK
#Return

$BLOCKENTSAL2
Read [F:AMKW]CODMSK = "ENTSAL2"
If WDISPBLCK=1
  WNAMEBLCK=func AFNC.TEXTE([F:AMKW]TITBLOC(3))
Endif
Chgtbk [M:ENT2]40  With WNAMEBLCK

Return


$BLOCKENTSAL3
Read [F:AMKW]CODMSK = "ENTSAL3"
If WDISPBLCK=1
  WNAMEBLCK=func AFNC.TEXTE([F:AMKW]TITBLOC(0))
  WNAMEBLCK1=func AFNC.TEXTE([F:AMKW]TITBLOC(4)) :#SEGAY 25/09/12 81084 US 860
Endif
Chgtbk [M:ENT3]10  With WNAMEBLCK
Chgtbk [M:ENT3]30  With WNAMEBLCK1 :#SEGAY 25/09/12 81084 US 860
Return


$FIELDENTSAL3
  Chgfmt [M:ENT3]WSTABEFETR    With WSIGN+"LA:10940"      #Coefficient
  Chgfmt [M:ENT3]WLEVFRT       With WSIGN+"K:3B"      #Index
  Chgfmt [M:ENT3]ZWLEVFRT      With WSIGN+"KP:30X"
  Chgfmt [M:ENT3]WURS1         With WSIGN+"K:10cX" :#SEGAY 25/09/12 81084 US 860
  Chgfmt [M:ENT3]ZWURS1        With WSIGN+"KP:30X" :#SEGAY 25/09/12 81084 US 860
  Chgfmt [M:ENT3]WMED1         With WSIGN+"K:10cX" :#SEGAY 25/09/12 81084 US 860
  Chgfmt [M:ENT3]ZWMED1        With WSIGN+"KP:30X" :#SEGAY 25/09/12 81084 US 860
  Chgfmt [M:ENT3]WSTACAT       With WSIGN+"K:30X" :#SEGAY 25/09/12 81084 US 860
  Chgfmt [M:ENT3]ZWSTACAT      With WSIGN+"KP:30X" :#SEGAY 25/09/12 81084 US 860
  Chgfmt [M:ENT3]WRSKWRK       With WSIGN+"K:10X"     #Risk AT
  Chgfmt [M:ENT3]ZWRSKWRK      With WSIGN+"KP:30X"    #Risk AT

  If WSIGN="-" Then
    Raz [M:ENT3]WSTABEFETR
    Raz [M:ENT3]WLEVFRT
    Raz [M:ENT3]WURS1
    Raz [M:ENT3]ZWURS1
    Raz [M:ENT3]WMED1
    Raz [M:ENT3]ZWMED1
    Raz [M:ENT3]WSTACAT
    Raz [M:ENT3]ZWSTACAT
    Raz [M:ENT3]WRSKWRK
    Raz [M:ENT3]ZWRSKWRK
  Endif
Return

$FIELDENTSAL2
  Chgfmt [M:ENT2]WCOE       With WSIGN+"K:9X"      #Coefficient
  Chgfmt [M:ENT2]WIND       With WSIGN+"K:9X"      #Index
  Chgfmt [M:ENT2]WGRA       With WSIGN+"K:5X"      #Rank
  Chgfmt [M:ENT2]WFLGDUE    With WSIGN+"LA:1"      #Extracted DUE

  If WSIGN="-" Then
    Raz [M:ENT2]WCOE
    Raz [M:ENT2]WIND
    Raz [M:ENT2]WGRA
    Raz [M:ENT2]WFLGDUE
  Endif
Return

$FIELDENTSAL1
  Chgfmt [M:ENT1]CTYBRN      With WSIGN+"K:20g"     #Commune
  Chgfmt [M:ENT1]CTYBRNSEE   With WSIGN+"K:5"       #Code INSEE
  Chgfmt [M:ENT1]DEPBRN       With WSIGN+"K:#B"     #Département
  Chgfmt [M:ENT1]CODSEE       With WSIGN+"K:5"      #Code INSEE
  If WSIGN="-" Then
    Raz [M:ENT1]CTYBRN
    Raz [M:ENT1]CTYBRNSEE
    Raz [M:ENT1]DEPBRN
    Raz [M:ENT1]CODSEE
  Endif
Return


