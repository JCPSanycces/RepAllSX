##########################################################################################################################
#####################################################################
$SEL_SELOMMRPT
  # FGR 18/12/2013 : X3SUIVI92373
  # Sélection d'un état mailing
Local Integer Z
Local Char SZLIBELLE (250)
Local Integer ITER
Local Integer ITYP

  If [M:MAY5]TYPMRGX = 3 or [M:MAY5]TYPMRGX = 4 Then
    Z = 0
    Local File MAILXML [MXL]
    SZLIBELLE = ""
    If GSZTYPSEA = "CCN" Then
      ITYP = 2
    Else
      ITYP = 1
    Endif
    For [MXL] Where [F:MXL]TYP = ITYP
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      Call LECTEXTRA(SZLIBELLE, "MAILXML", "MXLDESAX3", [F:MXL]NUM, "") From ATEXTRA
      TEX(Z) = [F:MXL]NUM
      TEXTE(Z) = [F:MXL]NUM - "-" - SZLIBELLE
    Next
    NBTEX = Z
    Call TEXTE(23535, SZLIBELLE) From OBJDIV     # Publipostage XML
    TIT = mess(8,31,1) - SZLIBELLE               # Sélection Publipostage XML
  Else
    Z = 0
    Local File OMMRPT [OMR]
    SZLIBELLE = ""
    For [OMR] Where [F:OMR]LAN = GLANGUE and [F:OMR]MAGTPLRPT <> "MAILINGX"
      # La sélection ne présente tous les états, mais ajoute un message pour ceux non utilisables
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      Call LECTEXTRA(SZLIBELLE, "OMMRPT", "OMRDESAX3", [F:OMR]LAN, [F:OMR]MAGTPL) From ATEXTRA
      TEX(Z) = [F:OMR]MAGTPL
      TEXTE(Z) = [F:OMR]MAGTPL - "-" - SZLIBELLE
      If filinfo(filpath("REPORT\" + [F:OMR]LAN, [F:OMR]MAGTPLRPT, "rpt", nomap(0), "", adxmac(0)), 7) <= 0 Then
        TEXTE(Z) -= "(" + mess(1144,196,1) + ")"
      Endif
    Next
    NBTEX = Z
    Call TEXTE(17419, SZLIBELLE) From OBJDIV     # Etat mailing
    TIT = mess(8,31,1) - SZLIBELLE               # Sélection Etat mailing
  Endif
Return

#####################################################################
$VERF_SELOMMRPT
  # FGR 18/12/2013 : X3SUIVI92373
  # Sélection d'un état mailing
Return

#####################################################################
$SEL_SELSET0ITM
  #Sélection d'une fiche parc pour une consommation modèle de demande
Local Integer Z
Local Char SZLIBELLE (250)
Local Integer ITER

  Z = 0
  SZLIBELLE =""
  For ITER = 0 To [M:SET4]NBMAC-1
    Read [ITM] ITM0 = [M:SET4]ITMREF(ITER)
    If !fstat Then
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      # FGR 05/10/2009 : X3SUIVI58372
      #Call GET_ATEXTRA("ITMMASTER","DES1AXX","",SZLIBELLE) From TRTX3TEX
      Call CHARGE_DEFITMDES("DES1AXX", GLANGUE, [F:ITM]ITMREF, SZLIBELLE, "[F:ITM]") From TRTX3
      TEX(Z) = [F:ITM]ITMREF
      TEXTE(Z) = [F:ITM]ITMREF - "-" - SZLIBELLE
    Endif
  Next
  NBTEX = Z
  TIT = mess(465,182,1) #Sélection d'un parc.
Return

#####################################################################
$VERF_SELSET0ITM
  #Sélection d'une fiche parc pour une consommation modèle de demande
Return

#####################################################################
$SEL_SELSET0CPN
  #Sélection d'un composant concerné
Local Integer Z
Local Integer ITERZ
Local Integer ITERCHECK
Local Integer IALREADYLOAD
Local Char SZCPNNAM(40)
Local Char SZSETNUM

  Z = 0
  ITERZ = 0
  SZCPNNAM = ""
  ITERCHECK = 0
  IALREADYLOAD = 0
  # Si aucun articel n'est renseignée
  If PARAM(3) = "" Then
    Return
  Endif
  # Si aucune demande de service n'est renseignée
  If GREP = "C" Then
    If PARAM(2) = "" Then
      Return
    Endif
    SZSETNUM = PARAM(2)
  Elsif GREP = "D" Then
    If PARAM(2) = "" Then
      Return
    Endif
    SZSETNUM = PARAM(2)
  Else
    If PARAM(1) = "" Then
      Return
    Endif
    SZSETNUM = PARAM(1)
  Endif
  If !clalev([F:SEN]) : Local File SETMACCPN [SEN] : Endif
  Filter [SEN] Where [F:SEN]SETNUM = SZSETNUM and [F:SEN]ITMREF = PARAM(3)
  For [SEN]
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    ITERCHECK = 1
    IALREADYLOAD = 0
    For ITERCHECK = 1 To dim(TEX)-1
      If TEX(ITERCHECK) <> "" Then
        If [F:SEN]CPNITM <> "" Then
          If [F:SEN]CPNITM = TEX(ITERCHECK) Then
            IALREADYLOAD = 1
            Break
          Endif
        Endif
      Endif
    Next
    If IALREADYLOAD = 0 Then
      TEX(Z) = [F:SEN]CPNITM
      #Call LECTEXTRA(SZCPNNAM, "ITMMASTER", "DES1AXX", [F:SEN]CPNITM, "") From ATEXTRA
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:SEN]CPNITM,SZCPNNAM, "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
      TEXTE(Z) = [F:SEN]CPNITM - "-" - SZCPNNAM
    Endif
  Next
  Filter [SEN]
  NBTEX = Z
  #Sélection du composant concerné
  TIT = mess(199,182,1)
Return

#####################################################################
$VERF_SELSET0CPN
  #Sélection d'un composant concerné
Return
