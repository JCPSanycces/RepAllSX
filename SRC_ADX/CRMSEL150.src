#############################################################################################
#  Traitement générale pour la gestion des fenêtres de sélection en version 150    Module CRM
#  Créé le 13 novembre 2002
############################################################################################
$ACTION
  Case ACTION
    When "SEL_TABLE"   : Gosub SEL_TABLE
    When "VERF_TABLE"  : Gosub VERF_TABLE
    When "SEL_LISTE"   : Gosub SEL_LISTE
    When "VERF_LISTE"  : Gosub VERF_LISTE
    When Default
  Endcase
Return

############################################################################################
$SEL_TABLE
  Case TABLE
    When Default
  Endcase
Return

############################################################################################
$VERF_TABLE
  Case TABLE
    When Default
  Endcase
Return

############################################################################################
$SEL_LISTE
  Case LISTE
    When "SELSET0ITM"     : Gosub SEL_SELSET0ITM
    When "SELSET0CPN"     : Gosub SEL_SELSET0CPN
    When "SELOMMRPT"      : Gosub SEL_SELOMMRPT      # FGR 18/12/2013 : X3SUIVI92373
    When Default
  Endcase
Return

############################################################################################
$VERF_LISTE
  Case LISTE
    When "SELSET0ITM"     : Gosub VERF_SELSET0ITM
    When "SELSET0CPN"     : Gosub VERF_SELSET0CPN
    When "SELOMMRPT"      : Gosub VERF_SELOMMRPT      # FGR 18/12/2013 : X3SUIVI92373
    When Default
  Endcase
Return

