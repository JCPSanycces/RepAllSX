#<AdxTL>@(#)9.0.0.0 $Revision$
######################################################################################################
# Project       : Bank statement import
# File          : BSIPAYREMBAN
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 2016-07-19
######################################################################################################
# Module        : ACCOUNTING
# Description   : - Bank posting during payment generation of bank statements
######################################################################################################
# Updates :
# Date          |Author  | Version | Description
# 2016-07-26    | Bader  | U11     | no longer call CONTROLE From PAYREMBAN but special CONTROLE_ where
#               |        |         | FIN ist passed to AVERTDGI instead of SAI (avoid endless loop)
######################################################################################################


######################################################################################################
$ACTION
Case ACTION
     When "INIT" : Gosub INIT_
     When "CONTROLE" : Gosub INIT_DIA_ : Gosub CONTROLE_
     When "EXEC" : Gosub EXEC_ : Gosub EXEC From PAYREMBAN
     When Default : Gosub ACTION From PAYREMBAN
Endcase
Return


######################################################################################################
$INIT_
Local Integer OK
Local Mask PAYREMBAN [DIA]
Default Mask [DIA]
Raz [DIA]
Return


#*****************************************************************************************************
#INIT_DIA_: initialization of screen fields for REMBAN
#*****************************************************************************************************
$INIT_DIA_
Local Integer OK
Gosub INIT_FIELDS
Return


######################################################################################################
$CONTROLE_
If GSERVEUR : [M:DIA]TRC=2 : Endif
TMP=1
If [M:DIA]PRO=2 : TIT="T" : # Opération en cours
Else            : TIT="R" : # Recherche
Endif
Return


######################################################################################################
$EXEC_
TRA = 2
Return



######################################################################################################
$INIT_FIELDS

[M:DIA]ALLCPY = 2    # All companies = "yes"

[M:DIA]ALLFCY = 2    # All sites = "yes"

[M:DIA]PAY5=2        # Remittances = "yes"
[M:DIA]PAY7=2        # Paying banks = "yes"
[M:DIA]PAY9=2        # Payments = "yes"

[M:DIA]ALLTYP = 1    # All transactions = "no"
[M:DIA]TYP = [F:BSIIP]PAYTYP  # Payment entry type of BSI settings

[M:DIA]ALLFRMTYP=2   # All types of discounts = "yes"
[M:DIA]FRMTYP=0      # Discount type

[M:DIA]BIDON="X"

[M:DIA]ALLLOT = 2    # all lots = "yes"

If [F:BSIIMP]BAN = ""
    [M:DIA]ALLBAN = 2    # all banks = "yes"
Else
    [M:DIA]ALLBAN = 1    # all banks = "no"
    [M:DIA]BAN = [F:BSIIMP]BAN  # bank of statement
Endif

[M:DIA]ALLUSR = 1    # All users = "no"
[M:DIA]USR= GUSER

[M:DIA]PRO=2         # Generate entries = "yes"
[M:DIA]TRC=2         # Log file = "yes"

[M:DIA]ACCDAT=date$  # Accounting date
[M:DIA]ACCSTA=9

GCURLEG = [F:BSIIP]LEG
Return

