#<AdxTL>@(#)6.0.0.0 $Revision$
###########################################################################################
#   Affectation des commerciaux secondaires                 Module CRM         21 juin 2000
###########################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

###########################################################################################
$OUVRE
Global Char SZBPCNUM(GLONBPR)                              # hcb V6
Global Char SZAOB(GLONAOB)                                 # FGR 08/08/2012 : X3SUIVI83983
Global Integer REPUPD
Global Integer ISDIRTY

  If !clalev([F:RSE]) : Local File REPSEC [RSE] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([F:RSER]) : Local File BPARTNER [RSER] : Endif
  If !clalev([F:MAR]) : Local File MARASSREP [MAR] : Endif
  REPUPD = 0
  ISDIRTY = 0
  SZBPCNUM = PARAM(1)
  SZAOB = PARAM(4)
Return

###########################################################################################
$DEFBOUT
Return

###########################################################################################
$SETBOUT
  If ISDIRTY Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

###########################################################################################
$OUVRE_BOITE
Return

###########################################################################################
$DEBUT
Local Integer I
Local Integer IADINUM

  I = 0
  IADINUM = 19 + GFAMCIA
  For [RSE] Where BPCNUM = SZBPCNUM
    [M:BPC5]REPNUM(I) = [F:RSE]REPNUM
    [M:BPC5]MSS(I) = [F:RSE]MSS
    [M:BPC5]GRPITM(I) = [F:RSE]GRPITM
    I += 1
  Next
  [M:BPC5]MAIREP = PARAM(2)
  Case SZAOB
    When "BPC"
      If dim([M:BPC1]REP) > 1 Then
        [M:BPC5]TLS = [M:BPC1]REP(1)
      Else
        [M:BPC5]TLS = ""
        Grizo [M:BPC5]TLS
      Endif
    When "BPP"
      If dim([M:BPP1]REP) > 1 Then
        [M:BPC5]TLS = [M:BPP1]REP(1)
      Else
        [M:BPC5]TLS = ""
        Grizo [M:BPC5]TLS
      Endif
    When "CON"
      If dim([M:CON1]SALREP) > 1 Then
        [M:BPC5]TLS = [M:CON1]SALREP(1)
      Else
        [M:BPC5]TLS = ""
        Grizo [M:BPC5]TLS
      Endif
  Endcase
  [M:BPC5]NBLIG = I
  Affzo [M:BPC5]
Return

###########################################################################################
$AV_CHOIX
Return

###########################################################################################
AP_CHOIX
Return

###########################################################################################
$AVANT_BOUTON
Return

###########################################################################################
$FINSAI
  # Met à jour le représentant principal 1 sur l'écran GESTION du client
  If REPUPD Then
    VALEUR = [M:BPC5]MAIREP
    Case SZAOB
      When "BPC"
        Affzo [M:BPC1]REP(0)
      When SZAOB = "BPP"
        Affzo [M:BPP1]REP(0)
      When SZAOB = "CON"
        Affzo [M:CON1]SALREP(0)
    Endcase
    mkstat = 4
  Endif
  Raz [M:BPC5]
  Kill ISDIRTY
  Kill SZBPCNUM
  Kill SZAOB
  Kill REPUPD
Return

###########################################################################################
$FIN
Return

###########################################################################################
$ABANDON
Return

###########################################################################################
$APRES_MODIF
Return

###########################################################################################
$BOUTON
Return

###########################################################################################
$ONOK
  Gosub ONSAVE
  FIN = 1                                                  # FGR 08/08/2012 : X3SUIVI83983
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################
# Traitement du bouton enregistrer
###########################################################################################
$ONSAVE
Local Integer Z
Local Shortint WI
Local Char SZADDRESS(GLONADR)                              # FGR 08/08/2012 : X3SUIVI83983
Local Integer IBERROR

  Z = 0
  Raz SZADDRESS                                            # FGR 08/08/2012 : X3SUIVI83983
  # Obtient l'adresse par défaut du Tiers
  Read [RSER]BPR0=SZBPCNUM
  If fstat Then
    If SZAOB = "BPC" and fstat = 5 Then                    # FGR 08/08/2012 : X3SUIVI83983
      If dim([M:BPC4]BPAADD) > 0 Then
        #SZADDRESS = [M:BPC4]BPAADD(0)
        WI = find (2, [M:BPAC]BPAADDFLG (0..[M:BPAC]NBADR-1))
        If WI <> 0 Then
          SZADDRESS = [M:BPAC]CODADR (WI-1)
        Endif
      Endif
    Endif
  Else
    SZADDRESS = [F:RSER]BPAADD                             # FGR 08/08/2012 : X3SUIVI83983
  Endif
  If SZADDRESS = "" Then
    # FGR 08/08/2012 : X3SUIVI83983
    GMESSAGE = mess(527,196,1) - "(a)" #Erreur lors de l'enregistrement des représentants secondaires.
    GERR = 1
    Return
  Endif
  #
  Call DEBTRANS From GLOCK
  Trbegin [RSE], [MAR]
  # On commence par effacer toutes les éventuelles affectations existantes
  Delete [RSE] Where [F:RSE]BPCNUM = SZBPCNUM
  If !fstat Then
    Delete [MAR] Where [F:MAR]RECORDNUM = SZBPCNUM and [F:MAR]RECORDADD = SZADDRESS and [F:MAR]RECORDTYP = "BPR" and [F:MAR]REPTYP = 0
  Endif
  If fstat Then
    GMESSAGE = mess(527,196,1) - "(b)" #Erreur lors de l'enregistrement des représentants secondaires.
    GERR = 1
    Rollback
  Endif
  If GERR Then
    End
  Endif
  For Z = 0 To ([M:BPC5]NBLIG-1)
    If [M:BPC5]REPNUM(Z) <> "" Then
      #Enregistrement dans la table des représentants secondaires
      Call WRITE_RSE(0, SZBPCNUM, [M:BPC5]REPNUM(Z), [M:BPC5]MSS(Z), [M:BPC5]GRPITM(Z), 0, IBERROR) From SUBMSTB1
      If IBERROR Then
        GMESSAGE = mess(527,196,1) - "(c)" #Erreur lors de l'enregistrement des représentants secondaires.
        GERR = 1
        Break
      Endif
      #Enregistrement dans la table des affectations des secteurs de marché
      Call WRITE_MAR(0, SZBPCNUM, SZADDRESS, "BPR", [M:BPC5]REPNUM(Z), 0, [M:BPC5]MSS(Z), [M:BPC5]GRPITM(Z), 1, IBERROR) From SUBMSTB1
      If IBERROR Then
        GMESSAGE = mess(527,196,1) - "(d)" #Erreur lors de l'enregistrement des représentants secondaires.
        GERR = 1
        Break
      Endif
    Endif
  Next
  If GERR Then
    Rollback
    Return
  Else
    Commit
  Endif
  ISDIRTY = 0
  ETABOU(GSPE1) = 0
Return
