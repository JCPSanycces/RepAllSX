#<AdxTL>@(#)1.0.0.0 $Revision$
############################################################################
# UTIGPA20   Table BOMD Initialisation par défaut des champs   Module GPAO #
#           LEVSET,ITMTOLPOS,ITMTOLNEG                                 #
############################################################################
# mm 05.10: évolution du % de tolérance (spec. 041)   #
############################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "X3INDV6" Then
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      Read [ADS]DOSSIER=[L]DOSSIER
      If fstat Then
        Raz [F:ADS]
      Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("UTIGPA20: Update fields of BOMD table") From LECFIC
      Call MAJ_UTIGPA20(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIGPA20: Update fields of BOMD table") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTIGPA20(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End
##########################################################################
Subprog MAJ_UTIGPA20(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTIGPA20: Process Start on : "+DOSSIER, 0) From GESECRAN


#----- Ouverture des fichiers -----#
If filinfo(filpath("FIL","HANDLING","fde",DOSSIER),0) <= 0     End Endif

If clalev([F:HSH])  =0  Local File =DOSSIER+".HANDLING"       [HSH] : Endif
If clalev([F:BOH])  =0  Local File =DOSSIER+".BOM"            [BOH] : Endif
If clalev([F:BOD])  =0  Local File =DOSSIER+".BOMD"           [BOD] : Endif
If clalev([F:ITF])  =0  Local File =DOSSIER+".ITMFACILIT"     [ITF] : Endif
If clalev([F:TBO])  =0  Local File =DOSSIER+".TABBOMALT"      [TBO] : Endif

If dim([F:BOD]LEVSET) >0
    Call DEBTRANS From GLOCK
    Trbegin [BOD]
    # Récupération des % de tolérance de la fiche ISM
    # nomenclature de production , type de composant = normal ou sous-produit
      For [BOD]BOD0 Where BOMALTTYP=2 & ( CPNTYP = 1 | CPNTYP= 4)
         If ([F:BOD]PKC >= 2 & [F:BOD]PKC <=7) | [F:BOD]PKC=10   # composant pesé
             Read [TBO]TBO0=[F:BOD]BOMALTTYP;[F:BOD]BOMALT
             If !fstat
               Read [ITF]ITF0=[F:BOD]CPNITMREF;[F:TBO]FCY
               If !fstat
                 Read [HSH]HSH0 = [F:ITF]ISM
                 If !fstat
                     [F:BOD]ITMTOLPOS=[F:HSH]ITMTOL
                     [F:BOD]ITMTOLNEG=[F:HSH]ITMTOLNEG
                     [F:BOD]LEVSET = 2     # niveau param. tolérance = fiche ISM
                     Rewrite [BOD]
                     If fstat
                        Call ECR_TRACE("File BOMD" +", ERROR ="-num$(fstat),1) From GESECRAN
                     Endif
                 Endif
               Endif
             Endif
         Endif
      Next
    Commit
Endif

Close Local File [HSH]
Close Local File [BOD]
Close Local File [ITF]
Close Local File [TBO]

Call ECR_TRACE("UTIGPA20 : End PROCESS",0) From GESECRAN

End
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIGPA20(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTIGPA20(APPLI)
End


