#<AdxTL>@(#)12.0.0.0 $Revision$
############################################################################
## COMPTA : Actions de sélection
############################################################################
# Issue X3-63065 - 2018-02-26 by MDJ : Make Tax Digital in the UK (MTD) - Form
$ACTION
Case ACTION
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "CHX_TABLE" : Gosub CHX_TABLE
 When "SEL_LISTE" : Gosub SEL_LISTE
Endcase
Return

$SEL_TABLE
Case TABLE
 When "SELSAC"    : Gosub S_SAC
 When "SELNOTSAC" : Gosub S_NOTSAC
 When "SELSACBPR" : Gosub S_SACBPR
 When "SELSACDIF" : Gosub S_SACDIF
 When "SELPYM"    : Gosub S_PYM
 When "SELCOATYP" : Gosub S_COATYP
 When "SELGSC"    : Gosub S_GSC
 When "SELGDE"    : Gosub S_GDE
 When "SELBPRSAC" : Gosub S_BPRSAC
 When "SELCOAFDR" : Gosub S_COAFDR
 When "SELMDT"    : Gosub S_MDT
 When "SELVATFRM" : Gosub S_VATFRM   #*X3-63065
Endcase
Return

$CHX_TABLE
Case TABLE
 When "SELSAC"    : Gosub C_SAC
 When "SELNOTSAC" : Gosub C_NOTSAC
 When "SELSACBPR" : Gosub C_SACBPR
 When "SELSACDIF" : Gosub C_SACDIF
Endcase
Return

$SEL_LISTE
Case LISTE
 When "SELCOATYP" : Gosub S_COATYP
 When "SELEXE"    : Gosub S_EXE
 When "SELDIE"    : Gosub S_DIE
 When "SELJOUGTE" : Gosub S_JOUGTE
 When "SELABTLEG" : Gosub S_ABTLEG
 When "SELLOTLEG" : Gosub S_LOTLEG
 When "SELAGFLEG" : Gosub S_AGFLEG
 When "SELCFYLEGJ": Gosub S_CFYLEGJOU
Endcase
Return


#############################################################################
# ACTIONS SEL_TABLE
#############################################################################
$S_SAC
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Default File [GAC]
CRITERE = "SAC=2"
If PARAM(1)<>""
 CRITERE += ' & COA="'+PARAM(1)+'"'
Endif
ORDRE   = "ACCSHO;ACC"
START   = "ACCSHO"
OBJET   = "GAC"
Return

#Modif Repartition Ana
$S_NOTSAC
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Default File [GAC]
CRITERE = "SAC<>2"
If PARAM(1)<>""
 CRITERE += ' & COA="'+PARAM(1)+'"'
Endif
ORDRE   = "ACC"
START   = "ACC"
OBJET   = "GAC"
Return

$S_SACBPR
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Default File [GAC]
CRITERE = "SAC=2 & AUZBPR(5)=2"
If PARAM(1)<>""
 CRITERE += ' & COA="'+PARAM(1)+'"'
Endif
ORDRE   = "ACCSHO;ACC"
START   = "ACCSHO"
OBJET   = "GAC"
Return

$S_SACDIF
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Default File [GAC]
CRITERE = "SAC=2"
If PARAM(1)<>""
 CRITERE += ' & COA="'+PARAM(1)+'"'
Endif
Case PARAM(2)
 When "2" :  CRITERE += ' & DIF='+PARAM(2)
 When "3" :  CRITERE += ' & DIF='+PARAM(2)
Endcase
ORDRE   = "ACCSHO;ACC"
START   = "ACCSHO"
OBJET   = "GAC"
Return


$S_BPRSAC
If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:GSC])=0 : Local File GRPSAC   [GSC] : Endif
Local Char COA(GLONCOA)
Local Integer NBRSAC : NBRSAC=0
If PARAM(1)<>"" : COA=PARAM(1) : Else : Return : Endif
If PARAM(3)<>""
 Filter [GSC] Where COA=[L]COA & GRU=PARAM(3)
 Local Char SAC(GLONSAC)(1..rowcount([GSC])+1)
 Filter [GSC]
Else
 Local Char SAC(GLONSAC)(1..1)
Endif
If PARAM(2)<>""
 NBRSAC+=1
 SAC(NBRSAC)=PARAM(2)
Endif
If PARAM(3)<>""
 Filter [GSC] Where COA=[L]COA & GRU=PARAM(3)
 For [GSC]GSC0
  NBRSAC+=1
  SAC(NBRSAC)=[F:GSC]SAC
 Next
 Filter [GSC]
Endif
Local Integer BPC, BPS, BPT, FCT, REP, DIV
BPC=0 : BPS=0 : BPT=0 : FCT=0 : REP=0 : DIV=0
For I=1 To NBRSAC
 Read [GAC]GAC1=[L]COA;SAC(I)
 If !fstat
  If [F:GAC]AUZBPR(0)=2 : BPC=1 : Endif
  If [F:GAC]AUZBPR(1)=2 : BPS=1 : Endif
  If [F:GAC]AUZBPR(2)=2 : BPT=1 : Endif
  If [F:GAC]AUZBPR(3)=2 : FCT=1 : Endif
  If [F:GAC]AUZBPR(4)=2 : REP=1 : Endif
  If [F:GAC]AUZBPR(5)=2 : DIV=1 : Endif
 Endif
Next
If BPC : CRITERE +='BPCFLG=2' : Endif
If BPS
 If CRITERE<>"" : CRITERE -='| BPSFLG=2' : Else : CRITERE ='BPSFLG=2' : Endif
Endif
If BPT
 If CRITERE<>"" : CRITERE -='| BPTFLG=2' : Else : CRITERE ='BPTFLG=2' : Endif
Endif
If FCT
 If CRITERE<>"" : CRITERE -='| FCTFLG=2' : Else : CRITERE ='FCTFLG=2' : Endif
Endif
If REP
 If CRITERE<>"" : CRITERE -='| REPFLG=2' : Else : CRITERE ='REPFLG=2' : Endif
Endif
If DIV
 If CRITERE<>"" : CRITERE -='| BPRACC=2' : Else : CRITERE ='BPRACC=2' : Endif
Endif
OBJET   = "BPR"
Return

$S_PYM
## Sélection pyramides comptes (si PARAM(1)=1) et pyramides sections (si PARAM(1)=2)
If clalev([F:GYM])=0 : Local File GACCPYM [GYM] : Endif
If clalev([F:CYM])=0 : Local File GCCEPYM [CYM] : Endif
Case PARAM(1)
 When "1" : # Sélection pyramides comptes
  OBJET   = "GYM"
  CRITERE = 'COA="'+PARAM(2)+'"'
 When "2" : # Sélection pyramides sections
  OBJET   = "CYM"
  CRITERE = 'DIE="'+PARAM(2)+'"'
Endcase
Return

$S_GSC
If clalev([F:GSC])=0 : Local File GRPSAC [GSC] : Endif
OBJET = "GSC"
CRITERE = 'COA="'+PARAM(1)+'"'
OPTIONS =+ "|"
Return

$S_GDE
If clalev([F:GDE])=0 : Local File GDIAENTRY [GDE] : Endif
Default File [GDE]
Local Integer NBLED
NBLED=dim([F:GDE]LEDTYP)-1
If PARAM(1)<>""
 CRITERE = 'find('+PARAM(1)+',[F:GDE]LEDTYP(0..'+num$(NBLED)+'))'
Endif
OBJET   = "GDE"
Return

$S_COAFDR
#To have the Chart of accounts' list for an other Folder (destination folder)instead of the current one
If PARAM(1)=nomap or PARAM(1)=""
 Local File GCOA [COA]
Else
 #Open these tables for the supervisor.
 Local File = PARAM(1)+".GCOA"   [COA]
 Local File = PARAM(1)+".ACCES"  [ACC]
 Local File = PARAM(1)+".ATEXTRA"[AXX1]
 Local File = PARAM(1)+".ATEXTRA"[AXX2]
 Local File = PARAM(1)+".ATEXTRA"[AX3]
Endif
Default File [COA]
OBJET="COA"
Return

$S_MDT
If clalev([F:MDT])=0 : Local File MANDATE [MDT] : Endif
Default File [MDT]
CRITERE = "1=1"
If PARAM(1)<>""
 CRITERE += ' & CPY="'+PARAM(1)+'"'
Endif
If PARAM(2)<>""
 CRITERE += ' & BPCNUM="'+PARAM(2)+'"'
Endif
If PARAM(3)<>"0"
 CRITERE += ' & STA='+PARAM(3)
Endif
ORDRE   = "CPY;UMRNUM"
START   = "UMRNUM"
OBJET   = "MD1"
Return

#*X3-63065
$S_VATFRM

  If clalev([F:VEF])=0 : Local File VATENTFRM [VEF] : Endif
  OBJET   = "VEF"
  CRITERE = "ENAFLG=2"
Return
#*X3-63065 END
#############################################################################
# ACTIONS CHX_TABLE
#############################################################################
$C_SAC
$C_NOTSAC
$C_SACBPR
$C_SACDIF
CRITCAR="1=1"
Return

#############################################################################
# ACTIONS SEL_LISTE
#############################################################################
$S_COATYP
## Sélection des plans de comptes associés à au moins un référentiel...
##    - flagué 'Général'               (si PARAM(2)=1)
##    - flagué 'Analytique'            (si PARAM(2)=3)
##    - flagué 'Budgets'               (si PARAM(2)=4)
##    - flagué 'Engagements'           (si PARAM(2)=5)
##    - Tous "types"                   (si PARAM(2)=0)
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM    [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED    [LED] : Endif
If clalev([F:COA])=0 : Local File GCOA    [COA] : Endif
Local Integer NLED
Local Integer TYPCOA : TYPCOA=val(PARAM(2))

Local Char TEXTE(30)(1..dim(TEXTE), 1..2)

Local Char DESTXTTRA(30)
TIT = mess(172,105,1) : # Choix du plan de comptes
TIT(1)=mess(134,107,1) :# Code plan
TIT(2)=mess(30,109,1) :# Intitulé
NBTEX = 0
If PARAM(1)<>""
 ## Société renseignée : on affiche tous les plans de compte associés à code référentiel de la société qui a le même "type"
 ## passé en paramètre
 ## le "type" passé en paramètres (PARAM(2)) flagué (=Oui)
 Call LEC_CPY(PARAM(1)) From CPTLEC
 If !fstat
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  If !fstat
   For NLED = 1 To len(mess(0,2644,1))
    Call LEC_LED([F:GCM]LED(NLED-1)) From CPTLEC
    If !fstat
     If TYPCOA=0 | (TYPCOA=1 & [F:LED]GEN=2) | (TYPCOA=3 & [F:LED]ANA=2)
&     | (TYPCOA=4 & [F:LED]BUD=2) | (TYPCOA=5 & [F:LED]CMM=2)
      Call LEC_COA([F:LED]COA) From CPTLEC
      If !find([F:LED]COA,TEX(1..NBTEX))
       NBTEX += 1
       TEX(NBTEX)    = [F:COA]COA
       TEXTE(NBTEX,1) = format$("K:5X",[F:COA]COA)
       Call LECTEXTRA(DESTXTTRA,"GCOA","DESTRA",[F:COA]COA,"") From ATEXTRA
       TEXTE(NBTEX,2) = DESTXTTRA
      Endif
     Endif
    Endif
   Next
  Endif
 Endif
Elsif PARAM(1)=""
 ## Pas de société renseignée : on affiche tous les plans de compte possibles par rapport à tous les référentiels qui ont
 ## le "type" passé en paramètres (PARAM(2)) flagué (=Oui)
 For [LED]LED0
  If TYPCOA=0 | (TYPCOA=1 & [F:LED]GEN=2) | (TYPCOA=3 & [F:LED]ANA=2)
&  | (TYPCOA=4 & [F:LED]BUD=2) | (TYPCOA=5 & [F:LED]CMM=2)
   Call LEC_COA([F:LED]COA) From CPTLEC
   If !find([F:LED]COA,TEX(1..NBTEX))
    NBTEX += 1
    TEX(NBTEX)    = [F:COA]COA
    TEXTE(NBTEX,1) = format$("K:5X",[F:COA]COA)
    Call LECTEXTRA(DESTXTTRA,"GCOA","DESTRA",[F:COA]COA,"") From ATEXTRA
    TEXTE(NBTEX,2) = DESTXTTRA
   Endif
  Endif
 Next
Endif
Return


$S_EXE
## Sélection n° exercice d'une société et d'un type de référentiel
Local Integer NB_EXE
If clalev([M:FIY1])=0
 Local Mask FIY1 [FIY1]
 NB_EXE = dim([M:FIY1]FIYNUM)
 Close Mask [FIY1]
Else
 NB_EXE = dim([M:FIY1]FIYNUM)
Endif
Local Char TEXTE(20)(1..NB_EXE,1..3)
Local Integer TYPLED : TYPLED=val(PARAM(2))
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
TIT = mess(23,101,1) : # Choix exercice
NBTEX = 0
For [FIY]FIY0 Where CPY=PARAM(1) & LEDTYP=TYPLED
 NBTEX += 1
 TEX  (NBTEX)  = num$([F:FIY]FIYNUM)
 TEXTE(NBTEX,1) = format$("N:3#",[F:FIY]FIYNUM)
 TEXTE(NBTEX,2) = "     "+format$("D:"+GFMDAT4,[F:FIY]FIYSTR)
 TEXTE(NBTEX,3) = "     "+format$("D:"+GFMDAT4,[F:FIY]FIYEND)
Next
TIT(1) = mess(5,159,1)  : # Numéro
TIT(2) = mess(64,147,1) : # Date début de période
TIT(3) = mess(65,147,1) : # Date fin de période
Return

$S_DIE
## Selection des axes d'un référentiel en fct de cpy & ledtyp
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM    [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED    [LED] : Endif
If clalev([F:DIE])=0 : Local File GDIE    [DIE] : Endif
Local Char DESTXTTRA(30)
Local Integer NUMLED
TIT = mess(175,105,1) : # Choix d'un axe
NBTEX = 0
If PARAM(1)<>"" & PARAM(2)<>""
 NUMLED=val(PARAM(2))-1
 Call LEC_CPY(PARAM(1)) From CPTLEC
 If !fstat
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  If !fstat
   Call LEC_LED([F:GCM]LED(NUMLED)) From CPTLEC
   For I=1 To [F:LED]DIENBR
    Call LEC_DIE([F:LED]DIE(I-1)) From CPTLEC
    If !fstat
     NBTEX += 1
     Call LECTEXTRA(DESTXTTRA,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
     TEXTE(NBTEX)  = format$("K:5X",[F:DIE]DIE)+" "+DESTXTTRA
     TEX  (NBTEX) = [F:DIE]DIE
    Endif
   Next
  Endif
 Endif
 ## Selection des axes d'un référentiel donné (en paramétre)
Elsif PARAM(3)<>""
 Call LEC_LED(PARAM(3)) From CPTLEC
 If !fstat
  For I=1 To [F:LED]DIENBR
    Call LEC_DIE([F:LED]DIE(I-1)) From CPTLEC
    If !fstat
     NBTEX += 1
     Call LECTEXTRA(DESTXTTRA,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
     TEXTE(NBTEX)  = format$("K:5X",[F:DIE]DIE)+" "+DESTXTTRA
     TEX  (NBTEX) = [F:DIE]DIE
    Endif
   Next
 Endif
Endif
Return


$S_JOUGTE
# Restreindre la sélection des journaux en fonction du type de piéce = PARAM(1) saisi.
If clalev([F:AXX])=0  :  Local File ATEXTRA    [AXX] : Endif
If clalev([F:GTE])=0  :  Local File GTYPACCENT [GTE] : Endif

Link [JOU] With [AXX]AXX0="GJOURNAL";"DESTRA";GLANGUE;[F:JOU]JOU;[F:JOU]LEG
& As [LJOU]
& Where (LEG=GCURLEG | LEG="")
& Order By Key CLE=JOU Asc ; LEG Desc

If rowcount([LJOU])=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=1
 Return
Endif

Local Char TEX(50)(1..rowcount([LJOU]))
Local Char TEXTE(30)(1..rowcount([LJOU]),1..4) , TIT(30)(0..4)

NBTEX = 0

If PARAM(1)<>""
 Call LEC_GTE_LEG(GCURLEG,PARAM(1)) From CPTLEC
 For [LJOU]CLE(1) Where ENAFLG=2
  If [F:GTE]AUZJOU([F:JOU]TYP-1)=2 or [F:GTE]AUZJOU([F:JOU]TYP-1)=3
   NBTEX += 1
   TEX(NBTEX)    = [F:JOU]JOU
   TEXTE(NBTEX,1) = TEX(NBTEX)
   TEXTE(NBTEX,2) = [AXX]TEXTE
   If [F:JOU]LEG<>""
    TEXTE(NBTEX,3) = [F:JOU]LEG
   Else
    TEXTE(NBTEX,3) = mess(91,187,1)
   Endif
   If [F:JOU]FCY<>""
    TEXTE(NBTEX,4) = [F:JOU]FCY
   Else
    TEXTE(NBTEX,4) = mess(220,117,1)
   Endif
  Endif
 Next
Else
 For [LJOU]CLE(1) Where ENAFLG=2
  NBTEX += 1
  TEX(NBTEX)    = [F:JOU]JOU
  TEXTE(NBTEX,1) = TEX(NBTEX)
  TEXTE(NBTEX,2) = [AXX]TEXTE
   If [F:JOU]LEG<>""
    TEXTE(NBTEX,3) = [F:JOU]LEG
   Else
    TEXTE(NBTEX,3) = mess(91,187,1)
   Endif
   If [F:JOU]FCY<>""
    TEXTE(NBTEX,4) = [F:JOU]FCY
   Else
    TEXTE(NBTEX,4) = mess(220,117,1)
   Endif
 Next
Endif

# Choix journaux comptables
TIT(0) = mess(184,107,1)
# Journal
TIT(1) = mess(13,105,1)
# Intitulé
TIT(2) = mess(3,113,1)
# Législation
TIT(3) = mess(218,107,1)
# Site/Groupe
TIT(4) = mess(131,104,1)

If NBTEX=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=1
Endif

Return


##############################################################################################
## Called from VALABT + SOLABT
$S_ABTLEG
# Sélection des abonnements dont la pièce (nun de pièce modèle) à une CPY de même LEG
# que celle saisie à l'écran.
If clalev([F:AXX])=0  :  Local File ATEXTRA   [AXX] : Endif
If clalev([F:HAE])=0  :  Local File GACCENTRY [HAE] : Endif
If clalev([F:CPY])=0  :  Local File COMPANY   [CPY] : Endif

NBTEX=0

Link [GAF] With [AXX]AXX0="GACCFIX";"DESTRA";GLANGUE;[F:GAF]COD;""
& As [LGAF]

If rowcount([LGAF])=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=1
 Return
Endif

Local Char TEX(50)(1..rowcount([LGAF]))
Local Char TEXTE(30)(1..rowcount([LGAF]),1..3) , TIT(30)(0..3)

For [LGAF]
 Read [HAE]HAE0=[F:GAF]REFTYP;[F:GAF]REFNUM
 If !fstat
  Call LEC_CPY([F:HAE]CPY) From CPTLEC
  If !fstat
   If [F:CPY]LEG = PARAM(1)
    NBTEX +=1
    TEX(NBTEX)     = [F:GAF]COD
    TEXTE(NBTEX,1) = TEX(NBTEX)
    TEXTE(NBTEX,2) = [AXX]TEXTE
    TEXTE(NBTEX,3) = [F:CPY]LEG
   Endif
  Endif
 Endif
Next

# Choix abonnements
TIT(0) = mess(220,107,1)
# Abonnements
TIT(1) = mess(111,116,1)
# Intitulé
TIT(2) = mess(3,113,1)
# Législation
TIT(3) = mess(218,107,1)

If NBTEX=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=1
Endif

Return


##############################################################################################
## Called from CPTLOT
$S_LOTLEG
# Sélection des lots dont ..... de même LEG
# que celle saisie à l'écran.
If clalev([F:AXX])=0  :  Local File ATEXTRA   [AXX] : Endif
If clalev([F:CPY])=0  :  Local File COMPANY [CPY]   : Endif

NBTEX=0

Link [LOT] With [AXX]AXX0="GENLOT";"DESTRA";GLANGUE;[F:LOT]LOT;""
& As [LLOT]

If rowcount([LLOT])=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=1
 Return
Endif

Local Char TEX(50)(1..rowcount([LLOT]))
Local Char TEXTE(30)(1..rowcount([LLOT]),1..3) , TIT(30)(0..3)

For [LLOT]
 Call LEC_CPY([F:LOT]CPY) From CPTLEC
 If !fstat
  If [F:CPY]LEG = PARAM(1)
   NBTEX +=1
   TEX(NBTEX)     = [F:LOT]LOT
   TEXTE(NBTEX,1) = TEX(NBTEX)
   TEXTE(NBTEX,2) = [AXX]TEXTE
   TEXTE(NBTEX,3) = [F:CPY]LEG
  Endif
 Endif
Next

# Choix lots
TIT(0) = mess(222,107,1)
# Lots
TIT(1) = mess(23,107,1)
# Intitulé
TIT(2) = mess(3,113,1)
# Législation
TIT(3) = mess(218,107,1)

If NBTEX=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=1
Endif
Return


$S_AGFLEG
If clalev([F:AXX])=0  :  Local File ATEXTRA  [AXX] : Endif
If clalev([F:AGF])=0  :  Local File AGRPFCY  [AGF] : Endif
If clalev([F:AMZZ])=0 :  Local File AMSKZON  [AMZZ] : Endif :#Pour déterminer les options de sélection

Local Shortint OK,OKC
Local Char MESSA(250)
Local Char OPTIONS(10)

Local Char CODMSK(GLONAMK),CHAMPCOD(10)
CODMSK=PARAM(2)
CHAMPCOD=PARAM(3)

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
 Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
 If fstat=0
  If [F:AMZZ]OPTOBJ<>""
   OPTIONS="!"+[F:AMZZ]OPTOBJ
  Endif
 Endif
Endif

Link [AGF] With [AXX]AXX0="AGRPFCY";"DESAXX";GLANGUE;[F:AGF]GRP;""
& As [LAGF]

If rowcount([LAGF])=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=1
 Return
Endif

Local Char TEX(50)(1..rowcount([AGF]))
Local Char TEXTE(30)(1..rowcount([AGF]),1..2) , TIT(30)(0..2)
NBTEX = 0

For [AGF]AGF0
 Call CNTCOHGRPLEG([F:AGF]GRP,PARAM(1),OK,MESSA) From CPTCNT
 Call CONTSEL("AGF",OPTIONS,[F:AGF]GRP,"",OKC) From CONTOBJ
 If OKC : OK=0 : Endif
 If OK
  NBTEX += 1
  TEX(NBTEX)    = [F:AGF]GRP
  TEXTE(NBTEX,1) = TEX(NBTEX)
  TEXTE(NBTEX,2) = [F:AGF]DES
 Endif
Next

# Sélection Groupes de sociétés
TIT(0) = mess(479,198,1)
# Groupe
TIT(1) = mess(100,102,1)
# Intitulé
TIT(2) = mess(3,113,1)

If NBTEX=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=1
Endif
Return

# Sélection des groupes de site pour les journaux avec cohérence législation et options de AGF
$S_CFYLEGJOU
If clalev([F:FCY])=0  :  Local File FACILITY  [FCY] : Endif
If clalev([F:AGF])=0  :  Local File AGRPFCY  [AGF] : Endif

Local Shortint OK,OKC
Local Char MESSA(250)
Local Char OPTIONS(10)
Local Integer TL : TL=rowcount([AGF])+rowcount([FCY])
Local Char TEX(50)(1..TL)
Local Char TEXTE(30)(1..TL,1..2) , TIT(30)(0..2)
NBTEX = 0

# Setups
NBRLEG=0

# Les sites
For [FCY]FCY0
 Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
 If PARAM(1)="" | [F:CPY]LEG=PARAM(1)
   NBTEX += 1
   TEX(NBTEX)    = [F:FCY]FCY
   TEXTE(NBTEX,1) = TEX(NBTEX)
   TEXTE(NBTEX,2) = [F:FCY]FCYNAM
 Endif
Next

# Les sociétés et groupe
For [AGF]AGF0
 Call CNTCOHGRPLEG([F:AGF]GRP,PARAM(1),OK,MESSA) From CPTCNT
 Call CONTSEL("AGF",OPTIONS,[F:AGF]GRP,"",OKC) From CONTOBJ
 If OKC : OK=0 : Endif
 If OK
  NBTEX += 1
  TEX(NBTEX)    = [F:AGF]GRP
  TEXTE(NBTEX,1) = TEX(NBTEX)
  TEXTE(NBTEX,2) = [F:AGF]DES
 Endif
Next

# Sélection
TIT(0) = mess(18,100,1)
# Site/Groupe
TIT(1) = mess(131,104,1)
# Intitulé
TIT(2) = mess(3,113,1)

If NBTEX=0
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=1
Endif
Return

##############################################################################################
## Called from GENBORREM PAYREMBAN PAYREMCPT
$SELBAN
If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Gosub OUVRE_LISTE From WOBAN
Call TITOBJ("BAN","!",TIT(0)) From CONTOBJ
TIT(0)  = mess(12,123,1)-TIT(0) : # Choix
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "[F:BAN]BAN" : TIT(NBCOL) = mess(37,100,1)
NBCOL += 1 : COL(NBCOL) = "[F:BAN]CPY" : TIT(NBCOL) = mess(26,113,1)
NBCOL += 1 : COL(NBCOL) = "[F:BAN]CUR" : TIT(NBCOL) = mess(18,105,1)
START  = "[F:BAN]BAN"
OBJET=""
If [M]ALLCPY<>2
 Link [BAN] With [CPY]CPY1=GCURLEG;[F:BAN]CPY As [BANA] Where CPY=[M]CPY
 Default File [BANA]
Else
 Link [BAN] With [CPY]CPY1 ~= GCURLEG;[F:BAN]CPY As [BANA]
 Default File [BANA]
Endif
DEFPAG = 1
Return

