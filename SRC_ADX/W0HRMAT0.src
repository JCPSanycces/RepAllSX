#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone REFNUM
mkstat = 0
zoncou = "REFNUM"
indice = 0
If varmode([M]REFNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "REFNUM" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_REFNUM([M]REFNUM) From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone FCYORI
mkstat = 0
zoncou = "FCYORI"
indice = 0
WCHAR = [M]FCYORI
If varmode([M]FCYORI,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_FCYORI([M]FCYORI) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz [M]FCYORI : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "FCYORI" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]FCYORI,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACONTFCY"
   Call CONTSITE([M]FCYORI) From SUBAGF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("FCY","",[M]FCYORI,"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_FCYORI([M]FCYORI) From SUBEML2
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "STD"
      Call AP_FCYORI([M]FCYORI) From SUBEML2
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
      If !mkstat
       If WCHAR<>[M]FCYORI or IMPMOD
        SAVACT = GACTION : GACTION = "STD"
        Call AM_FCYORI([M]FCYORI) From SUBEML2
        GACTION = SAVACT
        If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
        Gosub AFF From GSAISIE
        If mkstat : End : Endif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone CIVA
mkstat = 0
zoncou = "CIVA"
indice = 0
WCHAR = [M]CIVA
If varmode([M]CIVA,indice)=0
 SAVACT = GACTION : GACTION = "AFMTSAI"
 Call ASAISIE([M]CIVA,"M") From FMTVAR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CIVA : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CIVA" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]CIVA,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "AFMTCONT"
   Call CONTROLE([M]CIVA,"M",[M]NOLIB,15,[M]VALINT) From FMTVAR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "ACONTACL"
    Call CONTACL([M]VALINT,"M","","") From SUBACL
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]CIVA or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_CIVA([M]CIVA) From SUBEML2
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone PSD
mkstat = 0
zoncou = "PSD"
indice = 0
If varmode([M]PSD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PSD" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_PSD([M]PSD) From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PSD" : GZNUM = 46649 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone NAM
mkstat = 0
zoncou = "NAM"
indice = 0
WCHAR = [M]NAM
If varmode([M]NAM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NAM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]NAM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "NAM" : GZNUM = 55 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_NAM([M]NAM) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NAM" : GZNUM = 55 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]NAM or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_NAM([M]NAM) From SUBEML2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "NAM" : GZNUM = 55 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone SRN
mkstat = 0
zoncou = "SRN"
indice = 0
WCHAR = [M]SRN
If varmode([M]SRN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SRN" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]SRN,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SRN" : GZNUM = 1825 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_SRN([M]SRN) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SRN" : GZNUM = 1825 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]SRN or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_SRN([M]SRN) From SUBEML2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "SRN" : GZNUM = 1825 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone ENAFLG
mkstat = 0
zoncou = "ENAFLG"
indice = 0
IMPENT = [M]ENAFLG
WNUM = IMPENT
If varinit([M]ENAFLG,indice)=0
 IMPENT = 2
Endif
If varmode([M]ENAFLG,indice)=0
 [M]ENAFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENAFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENAFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_ENAFLG(IMPENT) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ENAFLG" : GZNUM = 188 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]ENAFLG = IMPENT

## Zone LEGORI
mkstat = 0
zoncou = "LEGORI"
indice = 0
If varinit([M]LEGORI,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEGORI,"909","") From SUBADI
 GACTION = SAVACT
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRMAT0"
Return

