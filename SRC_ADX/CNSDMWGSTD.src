#<AdxTL>@(#)0.0.0.0 $Revision$ Inquiry DMWG
######################################################################################################
# Project       : Waste disposal management
# File          : CNSDMWGSTD
# Version       : 1.0
# Authors       : U. Bader
# Creation Date : 2017-01-26
######################################################################################################
# Module        : Common data
# Description   : Waste disposal management: Grouped inquiry on waste disposal data
######################################################################################################
# Updates       :
# Date          | Author | Version | Description
# 2017-01-31    | Bader  | U11_03  | replace local menu 156 by 176, bug fixing after tests Volker Hornung
# 2017-02-03    | Bader  | U11_03  | Adaptions for Germany: hide fields PKGSIZ and TAFCAT
######################################################################################################

$ACTION
Case ACTION
    When "AUTORIS"    : Gosub AUTORIS
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "DEB_CRIT"   : Gosub DEB_CRIT
    When Default
Endcase
Return

############################################################
##
############################################################
$AUTORIS
Return


############################################################
##
############################################################
$DEB_CRIT
If [M:DMWCG]SCMCOD <> ""
    If [F:DMWSC]CRY = 1         # Germany -> hide fields PKGSIZ and TAFCAT
        Chgfmt [M:DMWCG]TAFCAT With "-K:30"
        Chgfmt [M:DMWCG]PKGSIZ With "-K:30"
    Else                        # Austria -> show fields PKGSIZ and TAFCAT
        Chgfmt [M:DMWCG]TAFCAT With "K:30"
        Chgfmt [M:DMWCG]PKGSIZ With "K:30"
    Endif
Endif
Return


############################################################
#
############################################################
$OUVRE
Local Char    FILTCPT(250)(1..4)
Local Integer IFILT : IFILT = 1
Local Char    LAST_PKGMAT(30)
Local Char    LAST_PKGSIZ(30)
Local Char    LAST_TAFCAT(30)
Local Char    LAST_ITMGRP(30)
Local Char    LAST_WEU(GLONUOM)
Local Decimal WEIGHTT, WEIGHTTSUM
Local Integer TTIND, TTINDCUR, IND
Local Decimal WEIGHTTOTALS(1..5)
Local Char    TAFTYPARR(30)(1..4)
Local Char    TTFMT(10)

If !clalev ([F:DMWSC])    : Local File DMWSCHEME [DMWSC]      : Endif
If !clalev ([F:DMWWEI])   : Local File DMWWEIGHT [DMWWEI]     : Endif
If !clalev ([F:DMWPAOR])  : Local File DMWPAORD  [DMWPAOR]    : Endif
If !clalev ([F:DMWQUOD])  : Local File DMWQUOTAD [DMWQUOD]    : Endif
If !clalev ([F:DMWQUOH])  : Local File DMWQUOTAH [DMWQUOH]    : Endif
Return

############################################################
## called when we have to search
############################################################
$LECTURE
  # disable "NEXT" and "BACK" Buttons. We do not have them here! We have no appropiate key for selecting part data
  SUITE   = 1
  RETOUR  = 1

  #delete all entries from the mask
  Raz [M:DMWG1]
  Raz WEIGHTTOTALS
  Raz TAFTYPARR
  NBLIG = 0
  NOL    = -1
  nolign = NOL+1
  LAST_PKGMAT = ""
  LAST_PKGSIZ = ""
  LAST_TAFCAT = ""
  LAST_ITMGRP = ""
  LAST_WEU    = ""
  TTINDCUR = 0

  # in this inquiry we need a scheme
  If [M:DMWG0]SCMCOD = "" : Return : Endif

  # create the filter ranges from the header data
  Gosub CREATE_FILTER

  Filter [F:DMWWEI] Where evalue(FILTCPT) Order By [F:DMWWEI]PKGMAT;[F:DMWWEI]PKGSIZ;[F:DMWWEI]TAFCAT;[F:DMWWEI]ITMGRP;[F:DMWWEI]WEU

  For [F:DMWWEI] With Nohint
    # fill data from file into mask in the right order (we may start from the last position or from the first one)
    Gosub FILL_CNS
  Next
  If NBLIG > 0 and [F:DMWSC]CRY = 2     # quota only exist for Austria
      Gosub CALC_TAFTYP_WEIGHT          # get last weights for tariff types
      Gosub CREATE_SUM_LINE             # create last line with totals
  Endif

  # set labels of tartype weight columns
  For TTIND = 1 To 4
    If TAFTYPARR(TTIND) <> ""       # valid tariff type
        TTFMT = "N:6.3"             # show column
    Else
        TTFMT = "-N:6.3"            # hide column
    Endif
    Case TTIND
        When 1 :  Chgfmt [M:DMWG1]ITMWEI1 With TTFMT
                  Titcol [M:DMWG1]NBLIG func GET_DES([M:DMWG0]SCMCOD, 4, TAFTYPARR(TTIND)) For ITMWEI1
        When 2 :  Chgfmt [M:DMWG1]ITMWEI2 With TTFMT
                  Titcol [M:DMWG1]NBLIG func GET_DES([M:DMWG0]SCMCOD, 4, TAFTYPARR(TTIND)) For ITMWEI2
        When 3 :  Chgfmt [M:DMWG1]ITMWEI3 With TTFMT
                  Titcol [M:DMWG1]NBLIG func GET_DES([M:DMWG0]SCMCOD, 4, TAFTYPARR(TTIND)) For ITMWEI3
        When 4 :  Chgfmt [M:DMWG1]ITMWEI4 With TTFM
                  Titcol [M:DMWG1]NBLIG func GET_DES([M:DMWG0]SCMCOD, 4, TAFTYPARR(TTIND)) For ITMWEI4
    Endcase
  Next TTIND
Return


########################################################################################################################
$CREATE_FILTER
  Raz FILTCPT, IFILT

  # waste management scheme
  If [M:DMWG0]SCMCOD <> ""
    Call ADDCRIT(FILTCPT,IFILT,"SCMCOD",'[F:DMWWEI]SCMCOD=[M:DMWG0]SCMCOD'," & ") From GOBJSUB
  Endif

  # date range
  If [M:DMWG0]STRDAT <> [0/0/0]
    Call ADDCRIT(FILTCPT,IFILT,"STRDAT",'[F:DMWWEI]IPTDAT>=[M:DMWG0]STRDAT'," & ") From GOBJSUB
  Endif
  If [M:DMWG0]ENDDAT <> [0/0/0]
    Call ADDCRIT(FILTCPT,IFILT,"ENDDAT",'[F:DMWWEI]IPTDAT<=[M:DMWG0]ENDDAT'," & ") From GOBJSUB
  Endif

  # product
  If [M:DMWG0]ITMREF <> ""
    Call ADDCRIT(FILTCPT,IFILT,"ITMREF",'[F:DMWWEI]ITMREF=[M:DMWG0]ITMREF'," & ") From GOBJSUB
  Endif

  # package material
  If [M:DMWG0]PKGMAT <> ""
    Call ADDCRIT(FILTCPT,IFILT,"PKGMAT",'[F:DMWWEI]PKGMAT=[M:DMWG0]PKGMAT'," & ") From GOBJSUB
  Endif

  # tariff category
  If [M:DMWG0]TAFCAT <> ""
    Call ADDCRIT(FILTCPT,IFILT,"TAFCAT",'[F:DMWWEI]TAFCAT=[M:DMWG0]TAFCAT'," & ") From GOBJSUB
  Endif

  # package size
  If [M:DMWG0]PKGSIZ <> ""
    Call ADDCRIT(FILTCPT,IFILT,"PKGSIZ",'[F:DMWWEI]PKGSIZ=[M:DMWG0]PKGSIZ'," & ") From GOBJSUB
  Endif

  # cutomer
  If [M:DMWG0]BPR <> ""
    Call ADDCRIT(FILTCPT,IFILT,"BPR",'[F:DMWWEI]BPR=[M:DMWG0]BPR'," & ") From GOBJSUB
  Endif

  # shipment
  If [M:DMWG0]VCRNUM <> ""
    Call ADDCRIT(FILTCPT,IFILT,"VCRNUM",'[F:DMWWEI]VCRNUM=[M:DMWG0]VCRNUM'," & ") From GOBJSUB
  Endif

  If FILTCPT = "" : FILTCPT = "1=1" : Endif
Return


############################################################
## Fill data from file into mask in the right order
############################################################
$FILL_CNS
  If NOL >= MAXLIG-1
    Call ERREND(mess(56,176,1)-num$(MAXLIG)) From GESECRAN
    Return
  Endif

  # check if something has changed. If yes > create new line
  If [F:DMWWEI]PKGMAT <> LAST_PKGMAT or [F:DMWWEI]PKGSIZ <> LAST_PKGSIZ or [F:DMWWEI]TAFCAT <> LAST_TAFCAT
&   or [F:DMWWEI]WEU <> LAST_WEU or [F:DMWWEI]ITMGRP <> LAST_ITMGRP
      # calculate sum for tariff type for existing line, but not when entering the first time
      If LAST_PKGMAT <> ""
          If [F:DMWSC]CRY = 2 : Gosub CALC_TAFTYP_WEIGHT : Endif # quota only exist for Austria
      Endif
      If [F:DMWWEI]PKGMAT <> LAST_PKGMAT and LAST_PKGMAT <> ""   # packing material changed > create sum line for packing material
          If [F:DMWSC]CRY = 2 : Gosub CREATE_SUM_LINE : Endif    # quota only exist for Austria
      Endif
      NOL    += 1
      nolign = NOL+1
      [M:DMWG1] = [F:DMWWEI]

      [M:DMWG1]PKGMATDES(nolign-1)  = func GET_DES([F:DMWWEI]SCMCOD, 2, [M:DMWG1]PKGMAT(nolign-1))
      [M:DMWG1]TAFCATDES(nolign-1)  = func GET_DES([F:DMWWEI]SCMCOD, 5, [M:DMWG1]TAFCAT(nolign-1))

      NBLIG=nolign

      LAST_PKGMAT = [F:DMWWEI]PKGMAT
      LAST_PKGSIZ = [F:DMWWEI]PKGSIZ
      LAST_TAFCAT = [F:DMWWEI]TAFCAT
      LAST_ITMGRP = [F:DMWWEI]ITMGRP
      LAST_WEU    = [F:DMWWEI]WEU
  Else # nothing changed > add weight to existing line
      [M:DMWG1]ITMWEI(nolign-1) += [F:DMWWEI]ITMWEI             # add weight
  Endif
Return



############################################################
$CALC_TAFTYP_WEIGHT
  Filter [F:DMWQUOH] Where SCMCOD = [F:DMWWEI]SCMCOD and ITMGRP = [F:DMWWEI]ITMGRP and STRDAT <= [M:DMWG0]STRDAT and (ENDDAT >= [M:DMWG0]ENDDAT
&  or ENDDAT = [0/0/0])
  Read [F:DMWQUOH] First
  If !fstat
      WEIGHTTSUM = 0
      For [F:DMWQUOD] Where [F:DMWQUOD]QUOTANUM = [F:DMWQUOH]QUOTANUM and [F:DMWQUOD]PKGMAT = [M:DMWG1]PKGMAT(nolign-1)
&       and [F:DMWQUOD]PKGSIZ = LAST_PKGSIZ

        # get index of tariff type field
        TTIND = 0
        If TTINDCUR > 0
            TTIND = find([F:DMWQUOD]TAFTYP,[L]TAFTYPARR(1..4))
        Endif
        If TTIND = 0 Then                            # not found or first time
          TTINDCUR += 1
          TTIND = TTINDCUR
          If TTIND <= 4
              TAFTYPARR(TTIND) = [F:DMWQUOD]TAFTYP
          Else
              Break
          Endif
        Endif

        [L]WEIGHTT = ([M:DMWG1]ITMWEI(nolign-1) / 100) * [F:DMWQUOD]QUOTA
        Call QTEARR([L]WEIGHTT, [M:DMWG1]WEU(nolign-1)) From TRTDIV
        WEIGHTTSUM += [L]WEIGHTT
        Assign "[M:DMWG1]ITMWEI" + num$(TTIND) + "(nolign-1)" With WEIGHTT
      Next
      If WEIGHTTSUM <> [M:DMWG1]ITMWEI(nolign-1)    # rounding difference
          WEIGHTT = [M:DMWG1]ITMWEI(nolign-1) - WEIGHTTSUM   # get difference
          If WEIGHTT > 0                            # add to first tariff type weight
              [M:DMWG1]ITMWEI1(nolign-1) += WEIGHTT
          Else                                      # subtract from first tariff type weight
              [M:DMWG1]ITMWEI1(nolign-1) -= WEIGHTT
          Endif
      Endif
      # add to totals
      WEIGHTTOTALS(1) += [M:DMWG1]ITMWEI1(nolign-1)
      WEIGHTTOTALS(2) += [M:DMWG1]ITMWEI2(nolign-1)
      WEIGHTTOTALS(3) += [M:DMWG1]ITMWEI3(nolign-1)
      WEIGHTTOTALS(4) += [M:DMWG1]ITMWEI4(nolign-1)
      WEIGHTTOTALS(5) += [M:DMWG1]ITMWEI(nolign-1)
  Endif
  Filter [F:DMWQUOH]

  # check if a line already exists with the same PKGMAT, TAFCAT and WEU. If yes, group the 2 lines
  For IND = 0 To NBLIG-1
      If [M:DMWG1]PKGMAT(IND) = [M:DMWG1]PKGMAT(nolign-1) and [M:DMWG1]TAFCAT(IND) = [M:DMWG1]TAFCAT(nolign-1)
&       and [M:DMWG1]WEU(IND) = [M:DMWG1]WEU(nolign-1) and IND <> nolign-1
          [M:DMWG1]ITMWEI(IND) += [M:DMWG1]ITMWEI(nolign-1)
          [M:DMWG1]ITMWEI1(IND) += [M:DMWG1]ITMWEI1(nolign-1)
          [M:DMWG1]ITMWEI2(IND) += [M:DMWG1]ITMWEI2(nolign-1)
          [M:DMWG1]ITMWEI3(IND) += [M:DMWG1]ITMWEI3(nolign-1)
          [M:DMWG1]ITMWEI4(IND) += [M:DMWG1]ITMWEI4(nolign-1)
          Raz [M:DMWG1]ITMWEI1(nolign-1),[M:DMWG1]ITMWEI2(nolign-1),[M:DMWG1]ITMWEI1(nolign-1),[M:DMWG1]ITMWEI1(nolign-1)
          Raz [M:DMWG1]PKGMAT(nolign-1),[M:DMWG1]PKGMATDES(nolign-1),[M:DMWG1]TAFCAT(nolign-1),[M:DMWG1]TAFCATDES(nolign-1)
          NOL-=1
          nolign = NOL+1
          Break
      Endif
  Next
Return


############################################################
$CREATE_SUM_LINE
TTIND = 0

If nolign <= 0 : Return : Endif
NOL +=1
nolign = NOL+1

[M:DMWG1]WEU(nolign-1) = LAST_WEU
[M:DMWG1]PKGMATDES(nolign-1) = mess(142,124,1) - [M:DMWG1]PKGMATDES(nolign-2)

NBLIG=nolign

# set total values for each tariff type
For TTIND = 1 To 4
  Assign "[M:DMWG1]ITMWEI" + num$(TTIND) + "(nolign-1)" With WEIGHTTOTALS(TTIND)
Next TTIND
# set total value for package material
[M:DMWG1]ITMWEI(nolign-1) = WEIGHTTOTALS(5)

# reset total values
Raz WEIGHTTOTALS

Return



############################################################
Funprog GET_DES(SCMCOD, CTYP, TYPID)
  Value Char SCMCOD
  Value Integer CTYP
  Value Char TYPID
  Local Char LDES(GLONAX3)
  If !clalev([F:DMWPAOR]) : Local File DMWPAORD [DMWPAOR] : Endif
  Read [F:DMWPAOR]DMWPAORD0 = SCMCOD;CTYP;TYPID
  If !fstat
      Call LECTEXTRA(LDES,"DMWPAORD","DES",SCMCOD,num$(CTYP) +"~"+ TYPID) From ATEXTRA
  Endif
End LDES



######################################################################################
## Section automatically added (screen DMWCRIDET) 01/26/2017 09:18:20 (UBA)
######################################################################################
Subprog D_STRDAT(VALEUR)
Variable Date    VALEUR
VALEUR = gdat$(1,month(date$),year(date$))
End

Subprog D_ENDDAT(VALEUR)
Variable Date    VALEUR
VALEUR = eomonth([M]STRDAT)
End



######################################################################################

######################################################################################
## Section automatically added (screen DMWGRP0) 02/03/2017 11:38:50 (UBA)
######################################################################################
Subprog AM_SCMCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR <> [M]SCMCOD
    Read [F:DMWSC]DMWSC0 = VALEUR   # read scheme
    If !fstat
        If [F:DMWSC]CRY = 1         # Germany -> hide fields PKGSIZ and TAFCAT
            Chgfmt [M:DMWG0]TAFCAT With "-K:30"
            Chgfmt [M:DMWG0]PKGSIZ With "-K:30"
            Chgfmt [M:DMWCG]TAFCAT With "-K:30"
            Chgfmt [M:DMWCG]PKGSIZ With "-K:30"
            Chgfmt [M:DMWG1]TAFCAT With "-K:30"
            Chgfmt [M:DMWG1]TAFCATDES With "-K:30"
            Chgfmt [M:DMWG1]PKGSIZ With "-K:30"
            Chgfmt [M:DMWG1]PKGSIZDES With "-K:30"
            Chgfmt [M:DMWG1]ITMWEI1 With "-K:30"
            Chgfmt [M:DMWG1]ITMWEI2 With "-K:30"
            Chgfmt [M:DMWG1]ITMWEI3 With "-K:30"
            Chgfmt [M:DMWG1]ITMWEI4 With "-K:30"
        Else                        # Austria -> show fields PKGSIZ and TAFCAT
            Chgfmt [M:DMWG0]TAFCAT With "K:30"
            Chgfmt [M:DMWG0]PKGSIZ With "K:30"
            Chgfmt [M:DMWCG]TAFCAT With "K:30"
            Chgfmt [M:DMWCG]PKGSIZ With "K:30"
            Chgfmt [M:DMWG1]TAFCAT With "K:30"
            Chgfmt [M:DMWG1]TAFCATDES With "K:30"
            Chgfmt [M:DMWG1]PKGSIZ With "K:30"
            Chgfmt [M:DMWG1]PKGSIZDES With "K:30"
            Chgfmt [M:DMWG1]ITMWEI1 With "K:30"
            Chgfmt [M:DMWG1]ITMWEI2 With "K:30"
            Chgfmt [M:DMWG1]ITMWEI3 With "K:30"
            Chgfmt [M:DMWG1]ITMWEI4 With "K:30"
        Endif
        Raz [M:DMWG1]
        Affzo [M:DMWG1]
    Endif
Endif
End


######################################################################################

