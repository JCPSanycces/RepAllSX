#<AdxTL>@(#)5.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "IMPORT"     : Gosub IMPORT
    When "AP_IMPORT"  : Gosub AP_IMPORT
  Endcase
Return


$IMPORT
  Gosub ALI_CLS
Return

$ALI_CLS
Local Integer I, IND

  For I=0 To dim([F:COA]CLS)-1
    If [F:COA]PFX(I)='' Then
      Break
    Endif
    If find( [F:COA]PFX(I), [M:COA1]PFX) Then
    Else
      IND = [M:COA1]PFXNBR+1

      [M:COA1]PFX(IND-1)    = [F:COA]PFX(I)
      [M:COA1]CLSCOD(IND-1) = [F:COA]CLSCOD(I)

      [M:COA1]PFXNBR +=1
    Endif
  Next I
Return

####################################################################
# Après l'import d'une ligne du fichier en entrée
#
$AP_IMPORT
  Case SEPNUM
    When 2 : 
      Gosub ALI_GCF
      OK = 0
    When 3 : 
      Gosub ALI_GCD
      OK = 0
    When Default
  Endcase
Return


$ALI_GCF
Local Integer I

  If [F:GCF]COADEN<>[M:COA6]COADEN Then
    If !clalev([F:GCF2]) Then Local File GACCDEF [GCF2] Endif
    Filter [GCF2] Where COAORI=[M:COA0]COA and COADEN=[F:GCF]COADEN
    Raz [M:COA6]NBLIG, NUMLIG, ACC
    Raz [M:COA6]ACCSTR
    [M:COA6]COADEN = [F:GCF]COADEN
    [M:COA6]NBLIG  = rowcount([F:GCF2])
    I=0
    For [GCF2]GCF0
      [M:COA6]ACCSTR(I) = [F:GCF2]COASTR
      [M:COA6]ACC(I)    = [F:GCF2]ACC
      I+=1
    Next
    Filter [GCF2]
    If clalev([F:GCF2]) Then Close Local File [GCF2] Endif
  Endif

  nolign = [M:COA6]NBLIG+1

  If find( [F:GCF]COASTR, [M:COA6]ACCSTR) Then
  Else
    [M:COA6]COADEN = [F:GCF]COADEN
    [M:COA6]ACCSTR(nolign-1) = [F:GCF]COASTR
    [M:COA6]ACC(nolign-1)    = [F:GCF]ACC

    [M:COA6]NBLIG +=1
  Endif
Return


$ALI_GCD
Local Integer I, FINDCODE

  nolign = [M:COA7]NBLIG+1

  FINDCODE=G_NON
  For I=0 To [M:COA7]NBLIG-1
    If [M:COA7]ACCSTR(I)=[F:GCD]ACCSTR & [M:COA7]DIE(I)=[F:GCD]DIE
      FINDCODE=G_OUI
      Break
    Endif
  Next I
  If FINDCODE=G_NON Then
    [M:COA7]ACCSTR(nolign-1) = [F:GCD]ACCSTR
    [M:COA7]DIE(nolign-1)    = [F:GCD]DIE
    [M:COA7]CCE(nolign-1)    = [F:GCD]CCE

    [M:COA7]NBLIG +=1
  Endif
Return
