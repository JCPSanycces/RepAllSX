#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
# UTIGPA30  Module GPAO     Table WEIGHING,  Initialisation du champ MLTITMFLG    #
###################################################################################
Local Char DOSSIER(30)

DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "X3INDV6" Then
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      Read [ADS]DOSSIER=[L]DOSSIER
      If fstat Then
        Raz [F:ADS]
      Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("UTIGPA30: Update field of WEIGHING table") From LECFIC
      Call MAJ_UTIGPA30(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
   If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIGPA30: Update field of WEIGHING table") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTIGPA30(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif


##########################################################################
# Initialisation du champ [F:WGG]ENGCOD
##########################################################################
Subprog MAJ_UTIGPA30(DOSSIER)
Value Char DOSSIER
Call ECR_TRACE("UTIGPA30: Process Start on : "+DOSSIER, 0) From GESECRAN

If filinfo(filpath("FIL","WEIGHING","fde",DOSSIER),0) <= 0     End Endif
#----- Ouverture des fichiers -----#
If clalev([F:WGG])  =0  Local File =DOSSIER+".WEIGHING"       [WGG] : Endif

Call DEBTRANS From GLOCK
Trbegin [WGG]
For [WGG]
   If [F:WGG]MLTITMFLG = 0 :[F:WGG]MLTITMFLG = 1 : Endif
   Rewrite [WGG]
   If fstat
      Call ECR_TRACE("File WEIGHING"-[F:WGG]MTLITMFLG+", ERROR ="-num$(fstat),1) From GESECRAN
   Endif
Next
Commit
Close Local File [WGG]

Call ECR_TRACE("UTIGPA30 : End Process",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIGPA30(APPLI)
End


#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTIGPA30(APPLI)
End
