#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTICPT61   UTI process                                    Module CPT   #
#            correction utility
#    XXX for module :  must be replaced (GPA ACH STO ...)
#    NN  number of sequence : must be replaced (01 02 ...)
##########################################################################

if clalev([F:ADS])=0
    local file ADOSSIER [ADS]
endif

local char WDOSSIER(30) : WDOSSIER = nomap
call SAIDOS(WDOSSIER,"") from SAIDOS

if WDOSSIER <> ""
  read [ADS]DOSSIER=WDOSSIER
  if fstat <> 0
        raz [F:ADS]
  endif
  call TEMPON("O") from GESECRAN
  call OUVRE_TRACE("Correction") from LECFIC
  call MAJ_UTICPT61(WDOSSIER)
  call TEMPOFF     from GESECRAN
  call FERME_TRACE from LECFIC
  call LEC_TRACE from LECFIC
endif

close local file
end

##########################################################################
subprog MAJ_UTICPT61(DOSSIER)
value char DOSSIER

call ECR_TRACE("UTICPT61 : Start of process on : "+DOSSIER,0) from GESECRAN

#----- Ouverture des fichiers -----#
if clalev([F:AXX])  =0  local file =DOSSIER+".ATEXTRA"   [AXX] : endif

call DEBTRANS from GLOCK

trbegin [AXX]
delete [AXX] where CODFIC="AOBJBURMOD" & ZONE="INTIT"
commit

close local file [AXX]

call ECR_TRACE("UTICPT61 : "+num$(adxdlrec)+" records processed",0) from GESECRAN

end

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT61 is in patch as EXE
########################################################################
subprog PATCH(APPLI)
value char    APPLI

if APPLI=GDOSX3 : end : endif
if clalev([F:ADS])=0  : local file ADOSSIER [ADS] : endif
read [ADS] DOSSIER=APPLI
if fstat : raz [F:ADS] : endif
if [F:ADS]MODULE(1)<>2 : end : endif                                 : # N= module

if filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : end : endif   : # XXXXXX= name of table

call MAJ_UTICPT61(APPLI)
end

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
subprog UTI_MOUL (APPLI)
value char    APPLI
if APPLI=GDOSX3: end : endif
if [F:ADS]MODULE(1)<>2 : end : endif                                 : # N= module
if filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : end : endif   : # XXXXXX= name of table

call MAJ_UTICPT61(APPLI)
end
