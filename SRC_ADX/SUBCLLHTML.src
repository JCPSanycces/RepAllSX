#<AdxTL>@(#)6.0.0.0 $Revision$
###############################################################################################################
#
#   Génération HTML d'un Appel                                                            Version 140
#   Module CRM                             
#   
###############################################################################################################
###############################################################################################################
Subprog CLLINHTML(SZRECNUM, IGENERICFILENAME, SZSCREENTYPE, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZSCREENTYPE
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If SZRECNUM = "" Then
    End
  Endif
  Gosub HTMLPART1 From CRMXML140
  Call TEXTE(13606, SZHTMLTITLE) From OBJDIV      #Appel
  SZSUBPROG = "CLLINHTML"
  SZAOBABREV = "CLL"
  Gosub HTMLPART2 From CRMXML140
  If IERRINF Then
    End 
 Endif
  Gosub DOCOREHTML
  Gosub HTMLPART3 From CRMXML140
End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREHTML
  Gosub SETCLLEXCEPT From CRMEXCEPT
  Gosub SETCTTEXCEPT From CRMEXCEPT
  #On extrait
  Filter [CLL] Where [F:CLL]CLLNUM = SZRECNUM
  For [CLL]
    Gosub HTMLCLL From CRMEXCEPT
    Filter [CTT] Where [F:CTT]CLLNUM = SZRECNUM
    For [CTT]
      Gosub HTMLCTT From CRMEXCEPT
    Next
    Filter [CTT]
  Next
  Filter [CLL]
Return
