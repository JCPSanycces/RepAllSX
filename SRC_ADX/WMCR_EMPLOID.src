#<AdxTL>@(#)0.0.0.0 $Revision$Class Employee
# Supervisor
## CRUD-CLASSE ## EMPLOID
# 2018-11-06 07:05:43 132


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EMPLOID [ID_]

If !SILENCE : Call TRACE("2 --> Local Instance C_EMPLOID") From ASYRCOM : Endif
Local Instance EMPLOID Using C_EMPLOID

If !SILENCE : Call TRACE("3 --> New Instance C_EMPLOID") From ASYRCOM : Endif
EMPLOID = NewInstance C_EMPLOID AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [ID_]ID0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EMPLOID") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.AREAD([ID_]REFNUM))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EMPLOID.REFNUM ="-num$(EMPLOID.REFNUM)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EMPLOID.AKEYS)
  Call TRACE("-"-num$(I)-":"-EMPLOID.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [ID_]
FreeGroup EMPLOID
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EMPLOID,ACLE,ASTATUS,_ETAG)
Variable Instance EMPLOID Using C_EMPLOID
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _REFNUM(15)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
Raz [L]_ETAG
Local File EMPLOID [ID]
Default File [F:ID]
Read [F:ID]ID0 = [L]_REFNUM
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:ID]UPDTICK)>0
 [L]_ETAG = num$([F:ID]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EMPLOID,ACLE,ASTATUS)
Variable Instance EMPLOID Using C_EMPLOID
Value Char ACLE
Variable Integer ASTATUS
Local Char _REFNUM(15)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.AREAD([L]_REFNUM))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EMPLOID,_REFNUM,ASTATUS)
Variable Instance EMPLOID Using C_EMPLOID
Value Char _REFNUM
Variable Integer ASTATUS

If EMPLOID = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOID
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EMPLOID.APARENT=null
 [L]A_I = EMPLOID.freeSnapshot
 EMPLOID.snapshotEnabled = 0
 EMPLOID.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EMPLOID.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EMPLOID.APARENT=null
 EMPLOID.snapshotEnabled = 1
 EMPLOID.setAccessorEnabled = 1
Endif
LogicClose File [ID] ,[ESA] ,[IDUKI] ,[RIB] ,[CHD] ,[JNT] ,[EXM] ,[TRY]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOID._ACTION_PARAM("AREAD_BEFORE",[L]_REFNUM))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:ID]
Read [F:ID]ID0 = [L]_REFNUM
If fstat
[L]A_ERROR = [L]_REFNUM
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EMPLOID,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:ID]AUUID)>0 & [F:ID]AUUID=NullUuid
 [F:ID]AUUID = getUuid
Endif
SetInstance EMPLOID With [F:ID]
EMPLOID.ASTALIN = [V]CST_ALL

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:ESA]
 [L]A_N2=1
 Read [F:ESA]ESA0 = [F:ID]REFNUM
 If !fstat
  EMPLOID.EMPLOIDSA(A_N2) = NewInstance  C_EMPLOIDSA(EMPLOID.ACTX,NullUuid,[L]A_N2,EMPLOID,"EMPLOIDSA") AllocGroup EMPLOID
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).ADDINSTANCE_BOUND)
  Callmet EMPLOID.EMPLOIDSA(A_N2).AREAD([F:ESA]REFNUM)
  EMPLOID.EMPLOIDSA(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).ASETATTRIBUTE("REFNUM","$namProParent","REFNUM"))
 Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:IDUKI]
 [L]A_N2=1
 Read [F:IDUKI]IDUKI0 = [F:ID]REFNUM
 If !fstat
  EMPLOID.EMPLOIDUKI(A_N2) = NewInstance  C_EMPLOIDUKI(EMPLOID.ACTX,NullUuid,[L]A_N2,EMPLOID,"EMPLOIDUKI") AllocGroup EMPLOID
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDUKI(A_N2).ADDINSTANCE_BOUND)
  Callmet EMPLOID.EMPLOIDUKI(A_N2).AREAD([F:IDUKI]REFNUM)
  EMPLOID.EMPLOIDUKI(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDUKI(A_N2).ASETATTRIBUTE("REFNUM","$isDisabled","true"))
 Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:RIB]
 [L]A_N2=0
 For [F:RIB]RIB0 Where REFNUM=[F:ID]REFNUM
  [L]A_N2 +=1
  EMPLOID.EMPLORIB(A_N2) = NewInstance  C_EMPLORIB(EMPLOID.ACTX,NullUuid,[L]A_N2,EMPLOID,"EMPLORIB") AllocGroup EMPLOID
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLORIB(A_N2).ADDINSTANCE_BOUND)
  Callmet EMPLOID.EMPLORIB(A_N2).AREAD([F:RIB]REFNUM,[F:RIB]NUMLIG)
  EMPLOID.EMPLORIB(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLORIB(A_N2).ASETATTRIBUTE("REFNUM","$namProParent","REFNUM"))
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLORIB(A_N2).ASETATTRIBUTE("NUMLIG","$isDisabled","true"))
 Next RIB
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:CHD]
 [L]A_N2=0
 For [F:CHD]CHD0 Where REFNUM=[F:ID]REFNUM
  [L]A_N2 +=1
  EMPLOID.EMPLOCHD(A_N2) = NewInstance  C_EMPLOCHD(EMPLOID.ACTX,NullUuid,[L]A_N2,EMPLOID,"EMPLOCHD") AllocGroup EMPLOID
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOCHD(A_N2).ADDINSTANCE_BOUND)
  Callmet EMPLOID.EMPLOCHD(A_N2).AREAD([F:CHD]REFNUM,[F:CHD]NUMLIG)
  EMPLOID.EMPLOCHD(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOCHD(A_N2).ASETATTRIBUTE("REFNUM","$namProParent","REFNUM"))
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOCHD(A_N2).ASETATTRIBUTE("NUMLIG","$isDisabled","true"))
 Next CHD
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:JNT]
 [L]A_N2=0
 For [F:JNT]JNT0 Where REFNUM=[F:ID]REFNUM
  [L]A_N2 +=1
  EMPLOID.EMPLOJNT(A_N2) = NewInstance  C_EMPLOJNT(EMPLOID.ACTX,NullUuid,[L]A_N2,EMPLOID,"EMPLOJNT") AllocGroup EMPLOID
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOJNT(A_N2).ADDINSTANCE_BOUND)
  Callmet EMPLOID.EMPLOJNT(A_N2).AREAD([F:JNT]REFNUM,[F:JNT]NUMLIG)
  EMPLOID.EMPLOJNT(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOJNT(A_N2).ASETATTRIBUTE("REFNUM","$namProParent","REFNUM"))
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOJNT(A_N2).ASETATTRIBUTE("NUMLIG","$isDisabled","true"))
 Next JNT
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:EXM]
 [L]A_N2=0
 For [F:EXM]EXM0 Where REFNUM=[F:ID]REFNUM
  [L]A_N2 +=1
  EMPLOID.EMPLOEXM(A_N2) = NewInstance  C_EMPLOEXM(EMPLOID.ACTX,NullUuid,[L]A_N2,EMPLOID,"EMPLOEXM") AllocGroup EMPLOID
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOEXM(A_N2).ADDINSTANCE_BOUND)
  Callmet EMPLOID.EMPLOEXM(A_N2).AREAD([F:EXM]REFNUM,[F:EXM]NUMLIG)
  EMPLOID.EMPLOEXM(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOEXM(A_N2).ASETATTRIBUTE("REFNUM","$namProParent","REFNUM"))
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOEXM(A_N2).ASETATTRIBUTE("NUMLIG","$isDisabled","true"))
 Next EXM
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:TRY]
 [L]A_N2=0
 For [F:TRY]TRY0 Where REFNUM=[F:ID]REFNUM
  [L]A_N2 +=1
  EMPLOID.EMPLOTRY(A_N2) = NewInstance  C_EMPLOTRY(EMPLOID.ACTX,NullUuid,[L]A_N2,EMPLOID,"EMPLOTRY") AllocGroup EMPLOID
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOTRY(A_N2).ADDINSTANCE_BOUND)
  Callmet EMPLOID.EMPLOTRY(A_N2).AREAD([F:TRY]REFNUM,[F:TRY]NUMLIG)
  EMPLOID.EMPLOTRY(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOTRY(A_N2).ASETATTRIBUTE("REFNUM","$namProParent","REFNUM"))
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOTRY(A_N2).ASETATTRIBUTE("NUMLIG","$isDisabled","true"))
 Next TRY
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

[L]A_NEWCOL = 0
For [L]A_I=1 To 3
 If ([F:ID]PASCRY([L]A_I-1)<>"" or [F:ID]PASNUM([L]A_I-1)<>"" or [F:ID]PASDTE([L]A_I-1)<>[00/00/0000] or [F:ID]PLCISS([L]A_I-1)<>""
& or [F:ID]ISSAUZ([L]A_I-1)<>"" or [F:ID]EXPDAT([L]A_I-1)<>[00/00/0000] or [F:ID]ETRPITTYP([L]A_I-1)<>""
& or [F:ID]ETRPITDAT([L]A_I-1)<>[00/00/0000] or [F:ID]ETRPITEXPDAT([L]A_I-1)<>[00/00/0000] or [F:ID]ESSUIDPAS([L]A_I-1)<>0
& or [F:ID]PASDATNEW([L]A_I-1)<>[00/00/0000] or [F:ID]PASDATAMD([L]A_I-1)<>[00/00/0000])
  [L]A_NEWCOL += 1
  EMPLOID.PASDET(A_NEWCOL) = NewInstance  C_EMPLOID_PASDET(EMPLOID.ACTX,NullUuid,[L]A_I,EMPLOID,"PASDET") AllocGroup EMPLOID
  EMPLOID.PASDET(A_NEWCOL).PASCRY = [F:ID]PASCRY([L]A_I-1)
  EMPLOID.PASDET(A_NEWCOL).PASNUM = [F:ID]PASNUM([L]A_I-1)
  EMPLOID.PASDET(A_NEWCOL).PASDTE = [F:ID]PASDTE([L]A_I-1)
  EMPLOID.PASDET(A_NEWCOL).PLCISS = [F:ID]PLCISS([L]A_I-1)
  EMPLOID.PASDET(A_NEWCOL).ISSAUZ = [F:ID]ISSAUZ([L]A_I-1)
  EMPLOID.PASDET(A_NEWCOL).EXPDAT = [F:ID]EXPDAT([L]A_I-1)
  EMPLOID.PASDET(A_NEWCOL).ETRPITTYP = [F:ID]ETRPITTYP([L]A_I-1)
  EMPLOID.PASDET(A_NEWCOL).ETRPITDAT = [F:ID]ETRPITDAT([L]A_I-1)
  EMPLOID.PASDET(A_NEWCOL).ETRPITEXPDAT = [F:ID]ETRPITEXPDAT([L]A_I-1)
  EMPLOID.PASDET(A_NEWCOL).ESSUIDPAS = [F:ID]ESSUIDPAS([L]A_I-1)
  EMPLOID.PASDET(A_NEWCOL).PASDATNEW = [F:ID]PASDATNEW([L]A_I-1)
  EMPLOID.PASDET(A_NEWCOL).PASDATAMD = [F:ID]PASDATAMD([L]A_I-1)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.PASDET(A_NEWCOL).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next
[L]A_NEWCOL = 0
For [L]A_I=1 To 3
 If ([F:ID]NAMCNT([L]A_I-1)<>"" or [F:ID]SRNCNT([L]A_I-1)<>"" or [F:ID]CRYCNT([L]A_I-1)<>"" or [F:ID]TELCNT([L]A_I-1)<>""
& or [F:ID]MOBCNT([L]A_I-1)<>"" or [F:ID]EMLCNT([L]A_I-1)<>"" or [F:ID]ESSUIDCNT([L]A_I-1)<>0)
  [L]A_NEWCOL += 1
  EMPLOID.PERCNT(A_NEWCOL) = NewInstance  C_EMPLOID_PERCNT(EMPLOID.ACTX,NullUuid,[L]A_I,EMPLOID,"PERCNT") AllocGroup EMPLOID
  EMPLOID.PERCNT(A_NEWCOL).NAMCNT = [F:ID]NAMCNT([L]A_I-1)
  EMPLOID.PERCNT(A_NEWCOL).SRNCNT = [F:ID]SRNCNT([L]A_I-1)
  EMPLOID.PERCNT(A_NEWCOL).CRYCNT = [F:ID]CRYCNT([L]A_I-1)
  EMPLOID.PERCNT(A_NEWCOL).TELCNT = [F:ID]TELCNT([L]A_I-1)
  EMPLOID.PERCNT(A_NEWCOL).MOBCNT = [F:ID]MOBCNT([L]A_I-1)
  EMPLOID.PERCNT(A_NEWCOL).EMLCNT = [F:ID]EMLCNT([L]A_I-1)
  EMPLOID.PERCNT(A_NEWCOL).ESSUIDCNT = [F:ID]ESSUIDCNT([L]A_I-1)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.PERCNT(A_NEWCOL).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



