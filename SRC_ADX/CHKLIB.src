# Called from ANUPYH - Verify CHEQUE Cancel during acounting cancellation
###############################################################################
$VERIF_ACCCAN

If func AFNC.PARAM("CHQCT",[M:PAY1]FCY)<>"2" | !func AFNC.ACTIV("CHQMG") : Return : Endif

Local Integer OK : OK=0

#CHECK IGNORE_BEGIN
# Accounting Cancellation
If [M:PAY1]CHQNUM<>""
    Call OUINON(func AFNC.MES2(mess(165,121,1),[M:PAY1]BAN,[M:PAY1]CHQNUM),OK) From GESECRAN
    If OK<>2 : GOK=0 : Return : Endif
Endif
#CHECK IGNORE_END

Return

# Called from ANUPYH - Execute CHEQUE cancel as a part of accounting cancellation
###############################################################################
$EXEC_ACCCAN

If func AFNC.PARAM("CHQCT",[M:PAY1]FCY)<>"2" | !func AFNC.ACTIV("CHQMG") : Return : Endif

Local Char BAN(GLONBAN),CHQNUM(GLONVCR)

#CHECK IGNORE_BEGIN
# Update Manual CHEQUE payment transaction - mandatory entry
If [M:PAY1]SAVCHQNUM<>""
    [L]BAN = [M:PAY1]SAVBAN
    [L]CHQNUM = [M:PAY1]SAVCHQNUM
    Gosub CHEQUE_VOID
    If !GOK : Return : Endif
    Raz [M:PAY1]SAVCHQNUM, [M:PAY1]CHQNUM, [F:PYH]CHQNUM
    Affzo [M:PAY1]CHQNUM
Endif
#CHECK IGNORE_END

Return

# Called from CHKLIB
###############################################################################
$CHEQUE_ASSIGN

If func AFNC.PARAM("CHQCT",[M:PAY1]FCY)<>"2" | !func AFNC.ACTIV("CHQMG") : Return : Endif

# Assign Check to Payment transaction - mandatory entry
If !func PAYTRS | [M]CHQNUM="" : Return : Endif

Readlock [CHN]CHN0 = [M]BAN;[M]CHQNUM
If  fstat=1
    GOK=-1 : GLOCK="$CHQNUM"-[M]BAN-[M]CHQNUM : Return
Elsif fstat
    GOK=0 : Call RSTA("CHN", num$([M]BAN)-num$([M]CHQNUM)) From GLOCK : Return
Endif

[F:CHN]STA    = 2            # Issued
[F:CHN]PAYNUM= [M:PAY0]NUM
[F:CHN]CHQTYP = 1
[F:CHN]UPDDAT = date$
[F:CHN]UPDUSR = GUSER
[F:CHN]CLODAT = [00/00/00]
[F:CHN]PRNFLG = 2
[F:CHN]PRNDAT = date$
Rewrite [CHN]
If  fstat
    GOK=0
    GMESSAGE = mess(27,125,1) - "[F:CHN]"
Endif

Return

###############################################################################
$CHEQUE_VOID

If func AFNC.PARAM("CHQCT",[F:PYH]FCY)<>"2" | !func AFNC.ACTIV("CHQMG") : Return : Endif
# FQ122247  ([L]CHQNUM holds the same value as [M:PAY1]CHQNUM but it seems more relevant.

If [F:TPY]SNS=2 | [L]CHQNUM="": Return : Endif  #X3-54939

# Cheque Void
Readlock [F:CHN]CHN0 = [L]BAN;[L]CHQNUM
If  fstat=1
    GOK=-1 : GLOCK="$CHQNUM"-[L]BAN-[L]CHQNUM : Return
Elsif fstat
    GOK=0 : Call RSTA("CHN", num$([L]BAN)-num$([L]CHQNUM)) From GLOCK : Return
Endif

[F:CHN]STA    = 3            # Voided
[F:CHN]CLODAT = date$
[F:CHN]UPDDAT = date$
[F:CHN]UPDUSR = GUSER
[F:CHN]PRNFLG = 1
Raz [F:CHN]PRNDAT
Raz [F:CHN]POSPAYSEQ                        # ROSCH: 80148 - Positive Pay
Raz [F:CHN]POSPAYCREDAT                     # ROSCH: 80148 - Positive Pay
Rewrite [F:CHN]
If  fstat
    GOK=0 : Call FSTA("CHN") From GLOCK : Return
Endif
If dim([F:PYH]EDTNUM)>0 : Raz [F:PYH]EDTNUM : Endif

Return

###############################################################################
$CHEQUE_UNISSUE

If func AFNC.PARAM("CHQCT",[M:PAY1]FCY)<>"2" | !func AFNC.ACTIV("CHQMG") : Return : Endif

If [F:TPY]SNS=2 | [L]CHQNUM="": Return : Endif

# Cheque Clear Issued Flag to Un-issued
Readlock [F:CHN]CHN0 = [L]BAN;[L]CHQNUM
If  fstat=1
    GOK=-1 : GLOCK="$CHQNUM"-[L]BAN-[L]CHQNUM : Return
Elsif fstat
    GOK=0 : Call RSTA("CHN", num$([L]BAN)-num$([L]CHQNUM)) From GLOCK : Return
Endif

[F:CHN]STA    = 1            # Unissued
Raz [F:CHN]CLODAT, [F:CHN]PAYNUM
[F:CHN]UPDDAT = date$
[F:CHN]UPDUSR = GUSER
[F:CHN]PRNFLG = 1
Raz [F:CHN]PRNDAT
Raz [F:CHN]POSPAYSEQ                        # ROSCH: 80148 - Positive Pay
Raz [F:CHN]POSPAYCREDAT                     # ROSCH: 80148 - Positive Pay
Rewrite [F:CHN]
If  fstat
    GOK=0 : Call FSTA("CHN") From GLOCK : Return
Endif
If dim([F:PYH]EDTNUM)>0 : Raz [F:PYH]EDTNUM : Endif

Return

# Action = CHQVOID
###############################################################################
$ACTION
Case ACTION
    When "AVANT_PAR" : Gosub AVANT_PAR
    When "EXEC"      : Gosub EXEC
    When Default:
Endcase

Return

###################
$AVANT_PAR
If dim(TIT)<1
    Local Char TIT(100)
Endif

TIT = func AFNC.MES2(mess(164,121,1),[M]BAN,[M]CHQNUM)
Return

###################
$EXEC
#CHECK IGNORE_BEGIN
Raz [M:PAY1]CHQNUM
Affzo [M:PAY1]CHQNUM
PARAM(1)="M"
PARAM(2)="M"
PARAM(3)="[M:PAY1]CHQNUM"
[M:PAY1]SAVCHQSTA = 2                # Set to check voided for posting on save
#CHECK IGNORE_END
Return


# Called from SUBCHK, SUBRAB
######################################################################################
$OUVRE_CHN

If func AFNC.ACTIV("CHQ")                                        #81259.n
    If !clalev([F:CHN]) : Local File CHQNUM    [CHN] : Endif
    If !clalev([F:PYH]) : Local File PAYMENTH  [PYH] : Endif
    If !clalev([F:PAN]) : Local File PAYACCNUM [PAN] : Endif
Endif                                                            #81259.n
Return


# Called from SUBCHK, SUBRAB, SUBBNR
######################################################################################
$CLEAR_CHN
If func AFNC.ACTIV("CHQ")                                        #81259.n
    Call UPD_CHN(5,date$)    # Cleared, today's date
Endif                                                            #81259.n
Return

# Called from DEPOINTAGE, SUBBNR
######################################################################################
$REVERSE_CHN
Call UPD_CHN(2,[0/0/0])  # Issued, blank date
Return


######################################################################################
Subprog UPD_CHN(STA,CLODAT)
Value Integer STA
Value Date    CLODAT

If func AFNC.PARAM("CHQCT",[F:DAE]CPY)<>"2" : End : Endif

# Read the Accounting payment entry to get the payment
Filter [PAN] Where TYPNUM=3 & ACCSTA=9 & ACCNUM=[F:DAE]ACCNUM
Read [PAN] First
Filter [PAN]
If !fstat
  # Read the payment & update the check
  Read [PYH]PYH0=[F:PAN]NUM
  If !fstat & [F:PYH]CHQNUM<>""
    GCLE = [F:PYH]BAN-[F:PYH]CHQNUM
    Readlock [CHN]CHN0=[F:PYH]BAN;[F:PYH]CHQNUM
    If fstat=1
      GOK = -1 : GLOCK = "$CHQNUM"-GCLE : End
    Elsif !fstat & find([F:CHN]STA,2,5)  # only update Issued or Cleared checks
      [F:CHN]STA = [L]STA
      If [L]STA<3
        Raz [F:CHN]CLODAT
      Else
        [F:CHN]CLODAT = [L]CLODAT        # Set "clear/void" date
      Endif
      [F:CHN]UPDUSR = GUSER
      [F:CHN]UPDDAT = date$
      Rewrite [CHN]
      If fstat
        GOK = 0 : Call FSTA("CHN") From GLOCK : End
      Endif
    Endif
  Endif
Endif

End


######################################################################################
Subprog BAN_AS_CHKFMT(VALEUR)
Value Integer VALEUR
If func AFNC.PARAM("USACHK",[M:BAN2]CPY)="2"
    GMENLOC(1)=1
Endif
End


# Payment transaction type
####################################################################################
#CHECK IGNORE_BEGIN
Funprog PAYTRS()

If [F:TPY]EDTFLG=2 | [F:TPY]PAYPPS=2 | [F:TPY]CODEDT<>"" | [F:TPY]SNS=2 : End 0 : Endif

End 1
#CHECK IGNORE_END

