# Called from SUBPAY3
###############################################################################
$SUBPAY_INIMOD
Local Char BAN(GLONBAN),CHQNUM(GLONVCR)

# Update Manual CHEQUE payment transaction - mandatory entry
If  func AFNC.ACTIV("CHQMG") & GREP="M"
    If  [M:PAY1]SAVBAN<>[M]BAN | [M:PAY1]SAVCHQNUM<>[M]CHQNUM
        [L]BAN = [M:PAY1]SAVBAN
        [L]CHQNUM = [M:PAY1]SAVCHQNUM
        If  [M:PAY1]SAVCHQSTA = 2
            Gosub CHEQUE_VOID
        Else
            Gosub CHEQUE_UNISSUE
        Endif
        If !GOK : Return : Endif
        If  vireblc([M]CHQNUM,2)<>""        # Assign new check if one has been entered
            Gosub CHEQUE_ASSIGN
        Endif
    Endif
Endif
Return


