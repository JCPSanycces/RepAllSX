Variable Decimal VALEUR()
If val([M:CHB1]CHQFIRNUM(nolign-1))+VALEUR>=2^31  # 2147483648
  GMESSAGE = mess(13,9014,1) : mkstat=2 : End
Endif
End
# 90545.en


# Called from SUBCHB
######################################################################################
Subprog CHB_AM_NBRCHQ(VALEUR)
Variable Decimal VALEUR()
Local Char    NUMCHE(15),PREV_NUMCHE(15)

For CHQ=0 To VALEUR-1
  If CHQ=0
    [L]NUMCHE = [M:CHB1]CHQFIRNUM(nolign-1)
  Else
    Call INCSERIE([L]NUMCHE,[L]PREV_NUMCHE,1)
  Endif
  For NOL=0 To [M:CHB1]NBBAN-1
    If NOL<>nolign-1 & func IN_CHQ_RNG([M:CHB1]CHQFIRNUM(NOL),[M:CHB1]NBRCHQ(NOL),NUMCHE)
      GMESSAGE = mess(158,121,1) - [M:CHB1]CHQFIRNUM(NOL) : mkstat=2 : Break
    Endif
  Next
  [L]PREV_NUMCHE = [L]NUMCHE
Next

End


