Subprog CHB_AM_CHQFIRNUM(VALEUR)
Variable Char    VALEUR()

For NOL=0 To [M:CHB1]NBBAN-1
  If NOL<>nolign-1 & func IN_CHQ_RNG([M:CHB1]CHQFIRNUM(NOL),[M:CHB1]NBRCHQ(NOL),VALEUR)
