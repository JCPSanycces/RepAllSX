# Called from MODCHQNUM
####################################################################################
Subprog AS_STA(VALEUR)
Variable Integer VALEUR

# cannot manually adjust check with a status of issued, posted or cleared
If find(VALEUR,2,4,5)
 mkstat = 2 : End
Else
 # Disable invalid menu options
 GMENLOC(2) = 1  # Issued
 GMENLOC(4) = 1  # Posted
 GMENLOC(5) = 1  # Cleared
Endif

End


# Called from MODCHQNUM
######################################################################################
Subprog AM_STA(VALEUR)
Variable Integer VALEUR

# Clear Payment if setting status to Unissued
If VALEUR=1
  Raz [M:CHN]PAYNUM(nolign-1)
  Raz [M:CHN]POSPAYSEQ(nolign-1)            # ROSCH: 80148 - Positive Pay
  Raz [M:CHN]POSPAYCREDAT(nolign-1)         # ROSCH: 80148 - Positive Pay
Endif

End


# Display all checks in range
####################################################################################
Subprog DISP_CHQ_RNG(DEB,FIN)
Value    Char    DEB,FIN

If DEB="" | FIN="" : End : Endif

Local Integer NOL

Raz nolign
For [CHN] Where BAN=[M:CHN]BAN &
& ((!instr(1,"0123456789",left$(CHQNUM,1)) & DEB<=CHQNUM & CHQNUM<=FIN) |
&  (instr(1,"0123456789",left$(CHQNUM,1)) & val(DEB)<=val(CHQNUM) & val(CHQNUM)<=val(FIN)))
  If nolign=dim([M:CHN]CHQNUM)
    GMESSAGE = mess(26,100,1)
    GERR=1 : Break
  Endif
  NOL=nolign : nolign += 1
  [M:CHN]CHQNUM(NOL) = [F:CHN]CHQNUM
  [M:CHN]STA(NOL)    = [F:CHN]STA
  [M:CHN]PAYNUM(NOL) = [F:CHN]PAYNUM
  [M:CHN]POSPAYCREDAT(NOL) = [F:CHN]POSPAYCREDAT        # RBU: 80148 - Positive Pay
  [M:CHN]POSPAYSEQ(NOL)    = [F:CHN]POSPAYSEQ           # RBU: 80148 - Positive Pay
Next
If nolign=0
  GMESSAGE = mess(161,121,1)
  GERR=1 : End
Endif

[M:CHN]NBRCHQ = nolign
Affzo [CHN]
MODIF = 0

End


####################################################################################
Funprog IN_CHQ_RNG(DEB,NBRCHQ,VALEUR)
Value    Char    DEB
Value    Decimal NBRCHQ
Value    Char    VALEUR

Local Char FIN : FIN = func CHQEND(DEB,NBRCHQ)
Local Integer TMP

If instr(1,"0123456789",left$(VALEUR,1))
  # 1st char numeric, check values
  TMP = val(DEB)<=val(VALEUR) & val(VALEUR)<=val(FIN)
Else
  # alpha check
  TMP = DEB<=VALEUR & VALEUR<=FIN
Endif

End TMP


# Return the upper range of the checkbook
####################################################################################
Funprog CHQEND(FIRST_CHQ,NBCHQ)
Value    Char    FIRST_CHQ
Value    Decimal NBCHQ

Local Char    NUMCHE(15)

Call INCSERIE(NUMCHE,FIRST_CHQ,NBCHQ-1)

End NUMCHE


# Copied from EDITCHE with added param for range (NBCHQ)
##############################################################################
Subprog INCSERIE(NEWCHE,OLDCHE,NBCHQ)
Variable Char    NEWCHE()
Value    Char    OLDCHE()
Value    Integer NBCHQ

Local Integer I,J,LG,NUMERO
Local Char NEWNUM(15)

I=len(OLDCHE)
While I>0 & !instr(1,"0123456789",mid$(OLDCHE,I,1))
 I-=1
Wend
If I=0 : NEWCHE=OLDCHE : End : Endif
J=I
While J>0 & instr(1,"0123456789",mid$(OLDCHE,J,1))
 J-=1
Wend
J+=1
#NUMERO=seg$(OLDCHE,J,I)                       # old NUMERO was a char
#LG = len(NUMERO)                              # old bug (should be NUMERO+1)
#NEWNUM=format$("N0:"+num$(LG),val(NUMERO)+1)  # old increment by 1
NUMERO=val(seg$(OLDCHE,J,I))                   # made NUMERO an integer (instead of string)
LG = max(log(NUMERO+NBCHQ),I-J)+1              # new use log to get length of NUMERO+NBCHQ or i-j for leading 0s, then add 1
NEWNUM=format$("N0:"+num$(LG),NUMERO+NBCHQ)    # new increment by NBCHQ
NEWCHE=left$(OLDCHE,J-1)+NEWNUM+right$(OLDCHE,I+1)
End


# Called from SUBPAY
###############################################################################
Subprog AM_CHQNUM(VALEUR)
Variable Char VALEUR

If func AFNC.PARAM("CHQCT",[M:PAY1]FCY)<>"2" | !func AFNC.ACTIV("CHQMG") : End : Endif

Local Integer OK

# Manual check payment transaction - mandatory entry
If !func PAYTRS : End : Endif

Read [F:CHN]CHN0 = [M]BAN;VALEUR
If  fstat
    GMESSAGE=[M]BAN-VALEUR-mess(77,289,1)-mess(42,9003,1)  : VALEUR=[M]CHQNUM : mkstat=2
    End
Endif
Case [F:CHN]STA
    When 2: GMESSAGE= func AFNC.MES2(mess(162,121,1),[M]BAN,VALEUR)
    When 4: GMESSAGE=mess(77,289,1)-mess(4,2658,1)
    When 5: GMESSAGE=func AFNC.MES2(mess(166,121,1),[M]BAN,VALEUR)
Endcase
If  GMESSAGE<>""
    VALEUR=[M]CHQNUM
    mkstat=2
    End
Endif
If  [F:CHN]STA = 3
    Call OUINON(func AFNC.MES2(mess(163,121,1),[M]BAN,VALEUR),OK) From GESECRAN
    If OK<>2 : VALEUR=[M]CHQNUM : mkstat=2 : End : Endif
Endif

End

# Called from SUBPAY
###############################################################################
Subprog AS_CHQNUM(VALEUR)
Variable Char    VALEUR()

If func AFNC.PARAM("CHQCT",[M]FCY)<>"2" | !func AFNC.ACTIV("CHQMG") : End : Endif

# Manual Check
If [F:TPY]EDTFLG=2 & [F:TPY]PAYPPS=2 & [F:TPY]CODEDT<>"" & ([F:TPY]DACCHQNUM=2 |[F:TPY]DACCHQNUM=1)
& & find([F:TPY]SNS,1,3) # Issue 80656
    mkstat=2
Endif

End

