#X3-54939: Fields aren't cleared of Positive Pay info after accounting cancellation
$LIENS_BAN
Call BAN_AM_CPY([M:BAN2]CPY)
Return


# Called from SUBBAN
####################################################################################
Subprog BAN_AM_CPY(VALEUR)
Variable Char     VALEUR
#Issue 106660 – 2018-09-06  by VAVIL - impossible to acces the function GESBAN (add func AFNC.ACTIV("CHQ"))
If !func AFNC.ACTIV("CHQMG") | !func AFNC.ACTIV("CHQ") : End : Endif

# RBU: 80148 - positive pay fields
If func AFNC.PARAM("CHQCT",VALEUR)<>"2"
  Raz [M:BAN3]NXTSEQ, BANTRA, CHKACC, POSPAYFIL
  Diszo [M:BAN3]NXTSEQ
  Grizo [M:BAN3]CHK_BTN,STA_BTN, BANTRA, CHKACC, POSPAYFIL
Else
  Actzo [M:BAN3]NXTSEQ,CHK_BTN,STA_BTN, POSPAYFIL
Endif

If func AFNC.PARAM("USACHK",VALEUR)<>"2"
  [M:BAN3]CHKFMT=1
  Diszo [M:BAN3]CHKFMT
  [M:BAN3]MCRPRT=1
  Diszo [M:BAN3]10
Else
  Actzo [M:BAN3]CHKFMT,MCRPRT
  If [M:BAN3]MCRPRT<>2
    Diszo [M:BAN3]BANTRA,CHKACC
  Else
    Actzo [M:BAN3]BANTRA,CHKACC
  Endif
Endif
Affzo [M:BAN3]

End


# Called from SUBBAN
####################################################################################
Subprog BAN_AM_MCRPRT(VALEUR)
Variable Integer VALEUR

If VALEUR<>2
  Diszo [M:BAN3]BANTRA,CHKACC
  Effzo [M:BAN3]BANTRA,CHKACC
Else
  Actzo [M:BAN3]BANTRA,CHKACC
Endif

End


# Called from SUBCHB
####################################################################################
$CHB_LIENS2

If [F:BAN]BAN<>[M:CHB1]BAN
  Read [BAN]BAN0=[M:CHB1]BAN
Endif

If ((func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGCHQ",[F:BAN]CPY)<>"2") or func AFNC.ACTIV("KAG") = 0) and
&  ((func AFNC.ACTIV("FEE") and func AFNC.PARAM("CHQCT",[F:BAN]CPY)<>"2")  or func AFNC.ACTIV("FEE") = 0)# Issue X3-107197
  Grizo [M:CHB1]
Else
  Actzo [M:CHB1]
Endif

Return


# Called from SUBCHB
####################################################################################
$DEBUT_MOD

For [CHB2] Where BAN=[M:CHB1]BAN & !find(CHQFIRNUM,[M:CHB1]CHQFIRNUM(0..[M:CHB1]NBBAN-1))
  Delete [CHN] Where BAN=[M:CHB1]BAN & [F:CHB2]CHQFIRNUM<=CHQNUM & CHQNUM<=func CHQEND([F:CHB2]CHQFIRNUM,[F:CHB2]NBRCHQ)
  If fstat : Raz GOK : Break : Endif
  Delete [CHB2] Curr
  If fstat : Raz GOK : Break : Endif
Next

Return


# Called from SUBCHB
######################################################################################
$VERF_ANU

For NOL=0 To [M:CHB1]NBBAN-1
  Gosub TEST_ANU
  If mkstat : GOK=0 : Break : Endif
Next NOL

Return


# Called from SUBCHB
######################################################################################
$ANNULE

# Delete check associated with Bank Checkbook
Delete [CHN] Where BAN=[M:CHB1]BAN

Return


# Called from SUBCHB
######################################################################################
Subprog CHB_C_NBBAN
Local Integer NOL

# --> line deletion control
If status = 65
  NOL=nolign-1
  Gosub TEST_ANU
Endif

# --> deletion control of several lines
If status = 68 | status = 83
  For NOL=nolign-1 To nolign1-1
    Gosub TEST_ANU
    If mkstat : Break : Endif
  Next NOL
Endif

End


######################################################################################
$TEST_ANU

If [M:CHB1]USE(NOL)=1
  GMESSAGE = mess(159,121,1) - [M:CHB1]CHQFIRNUM(NOL) : mkstat=2
Elsif [M:CHB1]USE(NOL)=2
  Local Integer OK : OK = 2
  Call AVERTIR(func AFNC.MES2(mess(161,121,1),[M:CHB1]BAN,[M:CHB1]CHQFIRNUM(NOL)),OK) From GESECRAN
  If OK<>2 : mkstat=2 : Endif
Endif

Return


