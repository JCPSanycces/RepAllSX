# Called from SUBPAY3
###############################################################################
$SUBPAY_AVANT_MODFIC

If func AFNC.PARAM("CHQCT",[M]CPY)="2" & [M]CHQNUM<>"" & [F:PYH]EDTNUM>0  # already printed
  GMESSAGE=mess(9,123,1) : GOK=0  : # Modification impossible
  Return
Endif

Return

# Called from SUBPAY3
###############################################################################
$SUBPAY_SETBOUT

#CHECK IGNORE_BEGIN
If func AFNC.PARAM("CHQCT",[M]CPY)="2" & instr(1,GUSRAUZ,"O") & !find(GREP,"C","D") & [M:PAY0]STA<>9 & [M]CHQNUM<>""
    CHMEN += "6"
Endif

If  [M:PAY0]STA=9
    Diszo [M:PAY1]CHQNUM
    Diszo [M:PAY1]BAN
    If [F:PYH]EDTNUM>0  # already printed
      Call VIREBOUT(CHAINE,"E") From GOBJET
    Endif
Else
    Actzo [M:PAY1]CHQNUM
    # SAM 81743: don't activate BAN if progressive balance control is enabled in parameter and transaction
    Local Char P_PROBALCTL(1) : P_PROBALCTL = ""
  #  If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif    #92953.o
  #  Call PARAM([F:TPY]LEG,"PROBALCTL",P_PROBALCTL) From ADOVAL  #92953.o
    Call PARAM([F:PYH]FCY,"PROBALCTL",P_PROBALCTL) From ADOVAL   #92953.n
    If (P_PROBALCTL <> '2' or [F:TPY]LOTPROBALCTL <> 2) & !FROM_GESBCREG
      Actzo [M:PAY1]BAN
    Endif
Endif
#CHECK IGNORE_END

Return


