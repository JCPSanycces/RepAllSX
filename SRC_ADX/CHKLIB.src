# Called from SUBPAY
###############################################################################
Subprog AM_BAN(VALEUR)
Variable Char    VALEUR()

If func AFNC.PARAM("CHQCT",[M]FCY)<>"2" | !func AFNC.ACTIV("CHQMG") : End : Endif

If func PAYTRS
    If  vireblc(VALEUR,2)=""
         mkstat = 1 : GMESSAGE = mess(10,123,1)
    Else
        Raz [M]CHQNUM
        Affzo [M]CHQNUM
    Endif
Endif

