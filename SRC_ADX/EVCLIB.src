#**
#* Purpose: Validation of an EU VAT ID
#*
#* @param JSFILNAM      Name of javascript without ending (e. g. DE for DE.js, AT for AT.js or EU for EU.js etc.
#* @param EVCNUMCPY     The company's EU VAT ID
#* @param EVCNUMBPR     The business partner's EU VAT ID
#* @param ADDRESSDATA   String containig a comma separated list of address data (in single quotes)
#* @param RESULT        String that contains the javascript result as a comma separated list of values
#* @param RESBODY       A clob file containing the result of the web service call
#* @return              Result of Webservice (0 = invalid, 1 = valid, 2 = qualified valid)
#*!
Funprog CHECK_EU_VAT_ID( RESHEAD, RESBODY, ERRMSG, EVCSERVICE, EVCNUMCPY, EVCNUMBPR, NAME, ADDRESSLINE, ZIPCODE, CITY, CONFIRMATION )
Variable Clbfile RESHEAD        # Stream that contains the javascript result header as a comma separated list of values
Variable Clbfile RESBODY        # Stream that contains the javascript result body as a comma separated list of values
Variable Clbfile ERRMSG         # Stream that contains the error mesage to be displayed.
Value     Integer EVCSERVICE    # Global parameter which web service to use
Value     Char EVCNUMCPY        # The company's EU VAT ID
Value     Char EVCNUMBPR        # The business partner's EU VAT ID
Value     Char NAME             # String containig the BP's name
Value     Char ADDRESSLINE      # String containig the BP's address line (e. g. street + no.)
Value     Char ZIPCODE          # String containig...
Value     Char CITY             # String containig...
Value     Integer CONFIRMATION  # Boolean (1 = true, 0 = false ) to tell the web service to order a confirmation (e. g. letter
                                # in case of the German web service or a memo in the post finance box for the Austrian web service)

    Local Integer STATUSCODE
    Local Integer EVCVALID : Raz EVCVALID # Validation status of web service (0 = invalid, 1 = valid, 2 = qualified valid)

    Raz ERRMSG

    Case EVCSERVICE
        When 2 # EU web service (VIES)
            STATUSCODE = func EUVATID_EU( RESHEAD, RESBODY, EVCNUMBPR )
            If STATUSCODE <> 200
                ERRMSG = num$( STATUSCODE ) - func AJSONLIB.GET_PROP( RESHEAD, "message" )
            Else
                Local Char VALID(255) : VALID = func GET_RESULT_VALUE( RESBODY, "valid" )

                If VALID = "true"
                    EVCVALID = 1
                    ERRMSG = func AFNC.MES1( mess(1,7706,1), EVCNUMBPR )
&                          + chr$(10) +  mess(4,7706,1) - mess(5,7706,1)
&                          + chr$(10) + mess(6,7706,1) - func GET_RESULT_VALUE( RESBODY, "name" )
&                          + chr$(10) + mess(7,7706,1) - func GET_RESULT_VALUE( RESBODY, "address" )
                Else
                    Local Char FAULTSTRING(255)

                    FAULTSTRING = func GET_RESULT_VALUE( RESBODY, "faultString" )
                    ERRMSG = func AFNC.MES1( mess(2,7706,1), EVCNUMBPR )
&                          + chr$(10) + mess(3,7706,1)
                    If FAULTSTRING = ""
                        ERRMSG += chr$(10) + "valid=" + func GET_RESULT_VALUE( RESBODY, "valid" )
                    Else
                        ERRMSG += chr$(10) + FAULTSTRING
&                               + chr$(10) + "faultMessage=" + func GET_RESULT_VALUE( RESBODY, "faultMessage" )
                    Endif
                Endif
            Endif
        When 3 # German web service
            If CONFIRMATION
                STATUSCODE = func EUVATID_DE( RESHEAD, RESBODY, EVCNUMCPY, EVCNUMBPR, NAME, ADDRESSLINE, ZIPCODE, CITY, "ja" )
            Else
                STATUSCODE = func EUVATID_DE( RESHEAD, RESBODY, EVCNUMCPY, EVCNUMBPR, NAME, ADDRESSLINE, ZIPCODE, CITY, "" )
            Endif
            If STATUSCODE <> 200 # Check if a web server error occured.
                ERRMSG = num$( STATUSCODE ) - func AJSONLIB.GET_PROP( RESHEAD, "message" ) # Generic web server message.
            Else
                # Get the web service's error code.
                Local Integer ERRORCODE : ERRORCODE = val( func GET_RESULT_VALUE( RESBODY, "ErrorCode" ) )
                Local Char FIRMENNAME(255), ERG_NAME(1), STRASSE(255), ERG_STR(1), PLZ(255), ERG_PLZ(1), ORT(255), ERG_ORT(1)

                Case ERRORCODE
                    When 200, 203, 204
                        EVCVALID = 1 # Valid.
                        FIRMENNAME  = func GET_RESULT_VALUE( RESBODY, "Firmenname" )
                        ERG_NAME    = toupper( func GET_RESULT_VALUE( RESBODY, "Erg_Name" ) )
                        STRASSE     = func GET_RESULT_VALUE( RESBODY, "Strasse" )
                        ERG_STR     = toupper( func GET_RESULT_VALUE( RESBODY, "Erg_Str" ) )
                        PLZ         = func GET_RESULT_VALUE( RESBODY, "PLZ=" )
                        ERG_PLZ     = toupper( func GET_RESULT_VALUE( RESBODY, "Erg_PLZ" ) )
                        ORT         = func GET_RESULT_VALUE( RESBODY, "Ort" )
                        ERG_ORT     = toupper(  func GET_RESULT_VALUE( RESBODY, "Erg_Ort" ) )

                        # Qualified check?
                        If ERRORCODE = 200 and ERG_NAME = "A" and ERG_STR = "A" and ERG_PLZ = "A" and ERG_ORT = "A"
                            EVCVALID = 2 # Valid and "qualified".
                            ERRMSG = func AFNC.MES1( mess(11,7706,1), EVCNUMBPR )
&                                  + chr$(10) + mess(3,7706,1)
&                                  + chr$(10) + mess(6,7706,1) - FIRMENNAME
&                                  + chr$(10) + mess(7,7706,1) - STRASSE - "/" -  PLZ - ORT
                        Else
                            # Give information on the status of the validation.
                            ERRMSG = func AFNC.MES2( func EVCERROR( EVCSERVICE, ERRORCODE ), func GET_RESULT_VALUE( RESBODY, "Gueltig_ab" ), func GET_RESULT_VALUE( RESBODY, "Gueltig_bis" ) )
&                                  + chr$(10) + mess(3,7706,1)
                            If ERG_NAME <> "A"
                                ERRMSG += chr$(10) + mess(6,7706,1) - FIRMENNAME - "(" + mess(3100 + ascii(ERG_NAME), 7706, 1 ) + ")"
                            Endif
                            If ERG_STR <> "A"
                                ERRMSG += chr$(10) + mess(12,7706,1) - STRASSE - "(" + mess(3100 + ascii(ERG_STR), 7706, 1 ) + ")"
                            Endif
                            If ERG_PLZ <> "A"
                                ERRMSG += chr$(10) + mess(13,7706,1) - PLZ - "(" + mess(3100 + ascii(ERG_PLZ), 7706, 1 ) + ")"
                            Endif
                            If ERG_ORT <> "A"
                                ERRMSG += chr$(10) + mess(14,7706,1) - ORT - "(" + mess(3100 + ascii(ERG_ORT), 7706, 1 ) + ")"
                            Endif
                        Endif
# ...
                    When Default
                        ERRMSG = num$(ERRORCODE) - func EVCERROR( EVCSERVICE, ERRORCODE )
                Endcase
            Endif
# TODO (DNE): Future enhencement: Implement Austrian web service call. Here.
#            When 4 : # ...
        When Default # Unknown web service.
            STATUSCODE = 999
            ERRMSG = num$( STATUSCODE ) - mess(8,7706,1) - func AFNC.MES1( mess(9,7706,1), "EVCSERVICE" )
    Endcase
End EVCVALID


#**
#* Purpose: Validation of the EU VAT ID of a business partner by calling EU (VIES) web service.
#*
#* @param RESHEAD     Stream that contains the javascript result header
#* @param RESBODY     Stream that contains the javascript result body
#* @param USTID1      Caller's own EU VAT ID to authorize validation
#* @param USTID2      BP's EU VAT ID to check
#* @param FIRMENNAME  BP's name line
#* @param ORT         BP's city/town
#* @param PLZ         Postal code
#* @param STRASSE     Address line 1
#* @param DRUCK       Set to "ja" if you want a written confirmation
#*!
# Note: We use the same parameter names used in the web service to make clear which parameter is
#       meant when we send it to web service.
#
Funprog EUVATID_DE( RESHEAD, RESBODY, USTID_1, USTID_2, FIRMENNAME, STRASSE, PLZ, ORT, DRUCK )
Variable Clbfile RESHEAD      # Stream that contains the javascript result header
Variable Clbfile RESBODY      # Stream that contains the javascript result body
Value Char USTID_1            # Caller's own EU VAT ID for authorization purpos
Value Char USTID_2            # BP's EU VAT ID to check
Value Char FIRMENNAME
Value Char ORT
Value Char PLZ
Value Char STRASSE
Value Char DRUCK
    Local Integer STATUSCODE
    Local Char PARAMS(255)

    PARAMS = '"' + USTID_1 + '","' + USTID_2 + '","' + FIRMENNAME + '","' + ORT + '","' + PLZ + '","' + STRASSE + '","' + DRUCK + '"'
    STATUSCODE = func ASYRWEBSER.EXEC_JS(
&        "bundle-sage-eu-vat-online-check/lib/euvatid_de",
&        "euvatid",
&        "wait",
&        PARAMS,
&        "",
&        0, "", "0", RESHEAD, RESBODY)
End STATUSCODE


#**
#* Purpose: Validation of the EU VAT ID of a business partner by calling EU (VIES) web service
#*
#* @param RESHEAD     Stream that contains the javascript result header
#* @param RESBODY     Stream that contains the javascript result body
#* @param USTID       EU VAT ID to check
#*!
# Note: We use the same parameter names used in the web service to make clear which parameter is
#       meant when we send it to web service.
#
Funprog EUVATID_EU( RESHEAD, RESBODY,  USTID )
Variable Clbfile RESHEAD      # Stream that contains the javascript result header
Variable Clbfile RESBODY      # Stream that contains the javascript result body
Value Char USTID              # EU VAT ID to check.
    Local Integer STATUSCODE
    Local Clbfile RESHEAD
    Local Char PARAMS(255)

    PARAMS = '"' + USTID + '"'
    STATUSCODE = func ASYRWEBSER.EXEC_JS(
&        "bundle-sage-eu-vat-online-check/lib/euvatid_eu",
&        "euvatid",
&        "wait",
&        PARAMS,
&        "",
&        0, "", "0", RESHEAD, RESBODY)
End STATUSCODE


#**
#* Purpose: Validation of the EU VAT ID of a business partner from GESBPR, GESBPC, GESBPS, GESBPP, GESREP, GESBPT, GESPRV
#*
#* @param TYP  1=Ship-to customer, 2=BP, 3=Prospect, 4=Customer, 5=Supplier, 6=Sales rep, 7=Carrier, 8=Service supplier
#*!
Subprog EVC_VALIDATE(TYP)
Value Integer TYP

    If !clalev([F:EVCR]) : Local File EVCRESULT [EVCR] : Endif
    If !clalev([F:BPA])  : Local File BPADDRESS [BPA]  : Endif

    Local Integer EVCSERVICE                        # Global parameter which web service to use
    Local Integer EVCCONFIRM                        # Global parameter "confirmation letter"
    Local Char EVCSENDER(GLONEEC)                   # EU VAT ID of sender company
    Local Char EVCTARGET(GLONEEC)                   # EU VAT ID to check
    Local Clbfile RESHEAD                           # Stream that contains the javascript result header as a comma separated list of values
    Local Clbfile RESBODY                           # Stream that contains the javascript result body as a comma separated list of values
    Local Clbfile ERRMSG                            # Stream that contains the error mesage to be displayed.
    Local Char BPR(GLONBPR)                         # Busines partner
    Local Char BPRNAM(GLONNAM)                      # Names of business partner
    Local Char CODADR(GLONADR)                      # Address code used for qualified validation
    Local Char BPAADDLIG(GLONADL)                   # Address line (street)
    Local Char ZIPCODE(GLONPOS)                     # Postal code
    Local Char CITY(GLONCTY)                        # City/Town
    Local Integer EVCORIGIN
    Local Integer EVCVALID                          # Validation status of web service (0 = invalid, 1 = valid, 2 = qualified valid)
    Local Libelle RETC                              # Return code for question box.

    Call PARAM( "", "EVCCOMPANY", EVCSENDER ) From ADOVAL
    If EVCSENDER = ""
        Wrnbox func AFNC.MES1( mess(16,7706,1), "EVCCOMPANY" ) # 'Parameter $1 not set. Validation is not possible.'
    Else
        EVCSERVICE= int(val(func AFNC.PARAM("EVCSERVICE", "")))
        EVCCONFIRM= int(val(func AFNC.PARAM("EVCCONFIRM", "")))
        If EVCCONFIRM = 2 : EVCCONFIRM = 1 : Else : EVCCONFIRM = 0 Endif

        Gosub GET_BP_INFOS # Read name and address of BP for qualified validation (for differenct X3 functions).

        # Call web service.
        Call TEMPON( "V" ) From GESECRAN
        EVCVALID = func CHECK_EU_VAT_ID( RESHEAD, RESBODY, ERRMSG, EVCSERVICE, EVCSENDER, EVCTARGET, BPRNAM, BPAADDLIG, ZIPCODE, CITY, EVCCONFIRM )
        Call TEMPOFF From GESECRAN

        If EVCVALID # Valid
            If EVCVALID > 1 # In case of qualified validation show message (if available), only.
                If ERRMSG <> ""
                    Infbox ERRMSG
                Endif
            Else # In case of non-qualified validation ask for acceptance.
                If ERRMSG = "" # Fallback to give at least some hint.
                    ERRMSG = mess(2,585,1) - EVCTARGET + "~" + BPR + "~" + CODADR + "~" + num$(EVCORIGIN)
                Endif
                Qstbox ERRMSG Titled mess(10,7706,1) Using RETC # 'Accept as valid?'
                If RETC = 2 : Raz EVCVALID : Endif
            Endif
            Gosub UPDATE_EVCRESULT # Write record to EVCRESULT table.
        Else
            # Invalid: Show error message.
            Errbox mess(20,2422,1) - EVCTARGET + "~" + BPR + "~" + CODADR + "~" + num$(EVCORIGIN)
&                  + chr$(10) + ERRMSG
        Endif

        # Update "Validated" checkbox.
        If EVCORIGIN = 3 # Ship-to-customer
            [M:BPC4]EVCVALDON2 = min( 2, EVCVALID + 1 )
            Affzo [M:BPC4]EVCVALDON2
        Else # Normal BP
            [M]EVCVALDON = min( 2, EVCVALID + 1 )
            Affzo EVCVALDON
        Endif
    Endif
End


##################################################
$GET_BP_INFOS
    Gosub GET_BPR_FROM_MASK

    If TYP = 1
        EVCORIGIN = 3                         # Ship to customer
        EVCTARGET = [M:BPC4]XEECNUM
        BPRNAM    = [M:BPC4]XBPDNAM0
        EVCTARGET = [M:BPC4]XEECNUM
        CODADR    = [M:BPC4]XBPAADD
        Read [F:BPA]BPA0 = 1;BPR;CODADR
        If !fstat
            BPAADDLIG = [F:BPA]BPAADDLIG(0)
            ZIPCODE   = [F:BPA]POSCOD
            CITY      = [F:BPA]CTY
        Endif
    Else
        EVCORIGIN = 1                         # Default = business partner
        EVCTARGET = [M]EECNUM
        BPRNAM    = [M]BPRNAM(0)
        Filter [F:BPA] Where BPATYP = 1 and BPANUM = BPR and BPAADDFLG = 2
        Read [F:BPA] First
        If !fstat
            CODADR    = [F:BPA]BPAADD
            BPAADDLIG = [F:BPA]BPAADDLIG(0)
            ZIPCODE   = [F:BPA]POSCOD
            CITY      = [F:BPA]CTY
        Endif
        Filter [F:BPA]
    Endif
Return


##################################################
$GET_BPR_FROM_MASK
    Case TYP
        When 1                            # Ship to customer
            BPR       = [M]BPCNUM
        When 2                            # BP
            BPR       = [M]BPRNUM
        When 3                            # Prospect
            BPR       = [M]BPCNUM
        When 4                            # Customer
            BPR       = [M]BPCNUM
        When 5                            # Supplier
            BPR       = [M]BPSNUM
        When 6                            # Sales rep
            BPR       = [M]REPNUM
        When 7                            # Carrier
            BPR       = [M]BPTNUM
        When 8                            # Service supplier
            BPR       = [M]PRVNUM
    Endcase
Return


##################################################
$UPDATE_EVCRESULT
    Local Integer EXIST

    If EVCVALID
        Raz [F:EVCR]

        Read [F:EVCR]EVCRESULT0 = EVCTARGET;BPR;CODADR;EVCORIGIN
        EXIST = !fstat

        [F:EVCR]EVCTARGET    = EVCTARGET
        [F:EVCR]EVCSERVICE   = EVCSERVICE
        [F:EVCR]EVCORIGIN    = EVCORIGIN
        [F:EVCR]BPR          = BPR
        [F:EVCR]BPRNAM       = BPRNAM
        [F:EVCR]CODADR       = CODADR
        [F:EVCR]BPAADDLIG    = BPAADDLIG
        [F:EVCR]POSCOD       = POSCOD
        [F:EVCR]CTY          = CTY
        [F:EVCR]CHKDAT       = date$
        [F:EVCR]EVCCOUNT    += 1
        [F:EVCR]EVCQUALIFIED = EVCVALID
        [F:EVCR]EVCRESPONSE  = RESBODY
        If EVCCONFIRM
            [F:EVCR]EVCCONREQ = date$
        Else
            [F:EVCR]EVCCONREQ = [0/0/0]
        Endif

        If EXIST
            Rewrite [F:EVCR]                # Do an update
        Else
            Write [F:EVCR]                  # Do an insert
        Endif
    Else
        DeleteByKey [F:EVCR]EVCRESULT0 = EVCTARGET;BPR;CODADR;EVCORIGIN # Remove record.
    Endif
    If fstat                                # Error writing/deleting record
        Errbox mess(118,7711,1) - EVCTARGET + "~" + BPR + "~" + CODADR + "~" + num$(EVCORIGIN)
    Endif
Return


##################################################
#**
#* Purpose: Output error messages from local menu 7706 in a generic way.
#*
#* @param EVCSERVICE  Number of the web service according to local menu 3685
#* @param CODERR      Error code returned from web service
#*!
Funprog EVCERROR( EVCSERVICE, CODERR )
Value Integer EVCSERVICE
Value Integer CODERR
End mess( EVCSERVICE * 1000 + mod (CODERR + 1000, 1000), 7706, 1 )


##################################################
#**
#* Purpose: Returns a value from the JavaScript's output (or "") for a given name.
#*
#* @param INSTREAM    Clob file containing the output
#* @param VARNAM      Name of the "variable"
#*!
Funprog GET_RESULT_VALUE( INSTREAM, VARNAM )
Variable Clbfile INSTREAM
Value Char VARNAM

    Local Integer STARTPOS, ENDPOS
    Local Clbfile STREAM : STREAM = "|" + INSTREAM

    STARTPOS = instr( 1, STREAM, "|" + VARNAM + "=" )
    If STARTPOS < 1
        End ""
    Else
        ENDPOS = instr( STARTPOS + 1, STREAM , "|" )
        If ENDPOS < 1
            End right$( STREAM, STARTPOS + 1)
        Else
            STARTPOS += len(VARNAM) + 2
            End mid$( STREAM, STARTPOS, ENDPOS - STARTPOS )
        Endif
    Endif
End ""


###################################################################################################################
# Enabling/disabling of validation icon depending on the value of EECNUM field
###################################################################################################################
Subprog AV_EVCVAL(TYP)
Value Integer TYP # 1=Ship-to customer, 2=BP, 3=Prospect, 4=Customer, 5=Supplier, 6=Sales rep, 7=Carrier, 8=Service supplier

    Case TYP
        When 1
            If [M:BPC4]XEECNUM <> ""
                Actzo [M:BPC4]EVCVAL2
            Else
                Grizo [M:BPC4]EVCVAL2
            Endif
        When Default
            If [M]EECNUM <> ""
                Actzo [M]EVCVAL
            Else
                Grizo [M]EVCVAL
            Endif
    Endcase
End


###################################################################################################################
# If the combination EU VAT ID, address key and customer type exists in table EVCRESULT,
# set value to "yes" (2), else to "no" (1)
###################################################################################################################
Subprog AV_EVCVALDON(VALEUR,TYP)
Variable Integer VALEUR
Value    Integer TYP # 1=Ship-to customer, 2=BP, 3=Prospect, 4=Customer, 5=Supplier, 6=Sales rep, 7=Carrier, 8=Service supplier

    If !clalev([F:BPA])  : Local File BPADDRESS [BPA]  : Endif
    If !clalev([F:EVCR]) : Local File EVCRESULT [EVCR] : Endif

    Local Char EVCTARGET(GLONEEC)                   # EU VAT ID to check
    Local Char BPR(GLONBPR)                         # busines partner
    Local Char CODADR(GLONADR)                      # address code used for qualified validation
    Local Integer EVCORIGIN

    Gosub GET_BPR_FROM_MASK

    # Get address code.
    If TYP = 1
        EVCORIGIN = 3              # Ship to customer
        EVCTARGET = [M:BPC4]XEECNUM
        CODADR = [M:BPC4]XBPAADD
    Else
        EVCORIGIN = 1              # Default = business partner
        EVCTARGET = [M]EECNUM
        Filter [F:BPA] Where BPATYP = 1 and BPANUM = BPR and BPAADDFLG = 2
        Read [F:BPA] First
        If !fstat
            CODADR = [F:BPA]BPAADD
        Endif
        Filter [F:BPA]
    Endif

    # Check in EVCRESULT table if the entry exists.
    Read [F:EVCR]EVCRESULT0 = EVCTARGET;BPR;CODADR;EVCORIGIN
    If !fstat
        VALEUR = 2 # Check "Validated".
    Else
        VALEUR = 1 # Uncheck "Validated".
    Endif
End


###################################################################################################################
# After modification of the EECNUM:
# Checks if the EECNUM contains still a valid number and sets the "Validated" flag accordingly.
###################################################################################################################
Subprog AM_EECNUM(VALEUR,TYP)
Variable Char VALEUR
Value Integer TYP # 1=Ship-to customer, 2=BP, 3=Prospect, 4=Customer, 5=Supplier, 6=Sales rep, 7=Carrier, 8=Service supplier

    Local Integer VALID

    If TYP = 1
        [M:BPC4]XEECNUM = VALEUR
    Else
        [M]EECNUM = VALEUR
    Endif
    Call AV_EVCVALDON(VALID, TYP)
    If TYP = 1
        [M:BPC4]EVCVALDON2 = VALID
        Affzo [M:BPC4]EVCVALDON2
    Else
        [M]EVCVALDON = VALID
        Affzo EVCVALDON
    Endif
End

