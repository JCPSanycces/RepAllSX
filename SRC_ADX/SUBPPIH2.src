######################################################################################
## Clic droit Pièce sur le retour
######################################################################################
Subprog IB_NBPNH

  # Issue 82703 - 2012-10-16 by MUARN : bouton tunnel retour que si le retour existe
  Raz GBOUT2
  If [M:PII2]PNHNUM(nolign-1)<>""
    GBOUT2 = mess(192,198,1)
    If GPILNAV>1 Then
      # Si on vient de la gestion des objets, on empêche la consultation de la pièce
      If find("GESPNH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
    Endif
  Endif
End

Subprog B2_NBPNH
Local Integer NOL

  Filter [F:PNH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PII2]PNHNUM(NOL)
  Call OBJET("PNH",[M:PII2]PNHNUM(NOL),"") From GOBJET
  [M:PII2]NUM(NOL) = SAV_VCRNUM

  GCONSULT = 0
End


