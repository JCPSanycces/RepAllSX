#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque PDSYPIH

######################################################################################
## Clic droit Pièce sur la réception
######################################################################################
Subprog IB_NBPTH

  GBOUT2 = mess(117,198,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESPTH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
  # Issue 82703 - 2012-10-16 by MUARN : bouton tunnel réception que si la réception existe
  If GACTION="VISUETAPIH"
    Raz GBOUT2
    If [M:PIH2]PTHNUM(nolign-1)<>""
      GBOUT2=mess(117,198,1)
    Endif
  Endif
End

Subprog B2_NBPTH
Local Integer NOL

  Filter [F:PTH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PIH2]PTHNUM(NOL)
  Call OBJET("PTH",[M:PIH2]PTHNUM(NOL),"") From GOBJET
  [M:PIH2]PTHNUM(NOL) = SAV_VCRNUM

  GCONSULT = 0
End

######################################################################################
## Clic droit Pièce sur la commande
######################################################################################
Subprog IB_NBPOH

  GBOUT2 = mess(191,198,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If [M:PIH2]POHTYP(nolign-1)<>2 Then
      If find("GESPOH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
    Else
      If find("GESPOC",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
    Endif
  Endif
  # Issue 82703 - 2012-10-16 by MUARN : bouton tunnel commande que si la réception existe
  If GACTION="VISUETAPIH"
    Raz GBOUT2
    If [M:PIH2]POHNUM(nolign-1)<>""
      GBOUT2=mess(191,198,1)
    Endif
  Endif
End

Subprog B2_NBPOH
Local Integer NOL

  Filter [F:POH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PIH2]POHNUM(NOL)
  If [M:PIH2]POHTYP(NOL)<>2 Then
    Call OBJET("POH",[M:PIH2]POHNUM(NOL),"") From GOBJET
  Else
    Call OBJET("POC",[M:PIH2]POHNUM(NOL),"") From GOBJET
  Endif
  [M:PIH2]POHNUM(NOL) = SAV_VCRNUM

  GCONSULT = 0
End

######################################################################################
## Clic droit Pièce sur la pièce d'origine
######################################################################################
Subprog IB_NBORI
Local Char NOM_FUNC

  Case [M]ORITYP(nolign-1)
    When 3 : GBOUT2=mess(192,198,1) : NOM_FUNC="GESPNH"
    When 4 : GBOUT2=mess(055,198,1) : NOM_FUNC="GESPIH"
  Endcase
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find(NOM_FUNC,GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBORI
Local Char    NOM_OBJET, SAV_VCRNUM
Local Integer NOL

  GCONSULT = 2
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M]ORINUM(NOL)

  If clalev([F:PNH])=0 : Local File PRETURN    [PNH] : Endif
  If clalev([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif

  Case [M]ORITYP(NOL)
    When 3 : Filter [F:PNH] : NOM_OBJET = "PNH"
    When 4 : Filter [F:PIH] : NOM_OBJET = "PIH"
  Endcase

  Call OBJET(NOM_OBJET,[M]ORINUM(NOL),"") From GOBJET
  [M]ORINUM(NOL) = SAV_VCRNUM
  GCONSULT = 0
End


######################################################################################
## Clic droit Pièce sur la facture
######################################################################################
Subprog IB_NBPIH

  GBOUT2 = mess(55,198,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESPIH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBPIH
Local Integer NOL

  Filter [F:PIH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PII2]NUM(NOL)
  Call OBJET("PIH",[M:PII2]NUM(NOL),"") From GOBJET
  [M:PII2]PNHNUM(NOL) = SAV_VCRNUM

  GCONSULT = 0
