#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGAFR 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:30"
A_USER  = "DOC"
A_STAMP = "20181109230330"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "ADDNBR"
  If [M]ADDNBR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CPYLEGAFR [CLAFR]
Gosub HORODAT
Local Inpbox "CPYLEGAFR" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLAFR] As [SIM_]
Grizo [CLAFR]5
Grizo [CLAFR]10
Grizo [CLAFR]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CLAFR]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=27 : X2(0)=56 : Y1(0)=3 : Y2(0)=26
X1(1)=57 : X2(1)=86 : Y1(1)=3 : Y2(1)=26
X1(2)=27 : X2(2)=56 : Y1(2)=27 : Y2(2)=26
Return

$ON_CPY
Return

$ON_TAXOFCTYP
Onevent INIT_AREA Call D_TAXOFCTYP(zc) From W1CPYLEGAFR
Onevent BEFORE_INPUT Call AS_TAXOFCTYP(zc) From W1CPYLEGAFR
Return

Subprog D_TAXOFCTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]TAXOFCTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TAXOFCTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Gosub CHG_STY From W2CPYLEGAFR
Return

$TIT_COL
Gosub TIT_COL From W2CPYLEGAFR
Return


