#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################################
# UTICPT93 : Removal of obsolete north american reports         #
#            Module =  Financials  (1)                          #
#            JIRA X3-58523                                      #
#################################################################
  Local Char WDOSSIER(30) : WDOSSIER = nomap

  Call SAIDOSHIS( WDOSSIER, "" ) From SAIDOSHIS
  If WDOSSIER <> ""
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE( "Delete obsolete north american reports" ) From LECFIC

    Call MAJ_UTICPT93(WDOSSIER)

    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif

  Close Local File
End

##########################################################################
Subprog MAJ_UTICPT93(DOSSIER)
Value Char DOSSIER

  Local Integer WCOUNT
  Raz WCOUNT

  If !clalev([F:ARP])  : Local File =DOSSIER+".AREPORT"    [ARP]  : Endif    # report dictionary
  If !clalev([F:ARD])  : Local File =DOSSIER+".AREPORTD"   [ARD]  : Endif    # report parameters
  If !clalev([F:ARM])  : Local File =DOSSIER+".AREPORTM"   [ARM]  : Endif    # report print keys
  If !clalev([F:ARO])  : Local File =DOSSIER+".AREPORTS"   [ARO]  : Endif    # report data sources
  If !clalev([F:ARV])  : Local File =DOSSIER+".AREPORTV"   [ARV]  : Endif    # report defaults
  If !clalev([F:ARX])  : Local File =DOSSIER+".AREPORTX"   [ARX]  : Endif    # report translations

  Call ECR_TRACE("UTICPT93 : Start of process on : "+DOSSIER,0) From GESECRAN

  Trbegin [ARP], [ARD], [ARM], [ARO], [ARV], [ARX]

  Call DELETE_RPTELEMENTS("NA-BPATB")
  If GOK<1
    Goto END_DELETE
  Else
    WCOUNT+=1
  Endif

  Call DELETE_RPTELEMENTS("NA-CINVAR")
  If GOK<1
    Goto END_DELETE
  Else
    WCOUNT+=1
  Endif

  Call DELETE_RPTELEMENTS("NA-CSHREQ")
  If GOK<1
    Goto END_DELETE
  Else
    WCOUNT+=1
  Endif

  Call DELETE_RPTELEMENTS("NA-CUSSTA")
  If GOK<1
    Goto END_DELETE
  Else
    WCOUNT+=1
  Endif

  Call DELETE_RPTELEMENTS("NA-GLBAL")
  If GOK<1
    Goto END_DELETE
  Else
    WCOUNT+=1
  Endif

  Call DELETE_RPTELEMENTS("NA-SPAYHIS")
  If GOK<1
    Goto END_DELETE
  Else
    WCOUNT+=1
  Endif

  Call DELETE_RPTELEMENTS("NA-TRLBAL")
  If GOK<1
    Goto END_DELETE
  Else
    WCOUNT+=1
  Endif

  Call DELETE_RPTFILE(DOSSIER, "NA-BPATB", "ENG")
  Call DELETE_RPTFILE(DOSSIER, "NA-CINVAR", "ENG")
  Call DELETE_RPTFILE(DOSSIER, "NA-CSHREQ", "ENG")
  Call DELETE_RPTFILE(DOSSIER, "NA-CUSSTA", "ENG")
  Call DELETE_RPTFILE(DOSSIER, "NA-GLBAL", "ENG")
  Call DELETE_RPTFILE(DOSSIER, "NA-SPAYHIS", "ENG")
  Call DELETE_RPTFILE(DOSSIER, "NA-TRLBAL", "ENG")

END_DELETE:
  If GOK<1
    Rollback
    WCOUNT=0
  Else
    Commit
  Endif

  Call ECR_TRACE("UTICPT93 : "+num$(WCOUNT)+ " reports deleted",0) From GESECRAN
  Call ECR_TRACE("UTICPT93 : End of process on : "+DOSSIER,0) From GESECRAN
End

##########################################################################
Subprog DELETE_RPTFILE(FOLDERNAME,RPTNAM,LAN)
Value Char FOLDERNAME()
Value Char RPTNAM()
Value Char LAN()

  Local Char FILPAT(255)
  Local Integer STA

  FILPAT = filpath( "REPORT/" + LAN, RPTNAM, "rpt", FOLDERNAME)
  STA = Delfile(FILPAT)
End

##########################################################################
Subprog DELETE_RPTELEMENTS(RPTNAM)
Value Char RPTNAM()

  For [ARP] Where RPTCOD=RPTNAM
    Delete [ARP] Curr
    If fstat : GOK=0 : Goto ERROR : Endif
  Next

  For [ARD] Where RPTCOD=RPTNAM
    Delete [ARD] Curr
    If fstat : GOK=0 : Goto ERROR : Endif
  Next

  For [ARM] Where RPTCOD=RPTNAM
    Delete [ARM] Curr
    If fstat : GOK=0 : Goto ERROR : Endif
  Next

  For [ARO] Where RPTCOD=RPTNAM
    Delete [ARO] Curr
    If fstat : GOK=0 : Goto ERROR : Endif
  Next

  For [ARV] Where ETAT=RPTNAM
    Delete [ARV] Curr
    If fstat : GOK=0 : Goto ERROR : Endif
  Next

  For [ARX] Where EXTCOD=RPTNAM
    Delete [ARX] Curr
  If fstat : GOK=0 : Goto ERROR : Endif
  Next

ERROR:
  If GOK<1 Then
    Call ECR_TRACE("UTICPT93 : ERROR while deleting report "+RPTNAME,1) From GESECRAN
  Endif
End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  #Run against X3 and child folders
  #If APPLI="X3": End : Endif

  If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

  #Check Financial module
  If [F:ADS]MODULE(1)<>2 : End : Endif
  Call MAJ_UTICPT93(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  #Run against X3 and child folders
  #If APPLI="X3": End : Endif

  #Check Financial module
  If [F:ADS]MODULE(1)<>2 : End : Endif
  Call MAJ_UTICPT93(APPLI)
End

