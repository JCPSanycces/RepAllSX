#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank accounts
# Supervisor
## ATY-ATYPE ## BANESS
# 2018-11-09 07:13:41 349

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,BAN,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char BAN
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File BANK [BAN]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".BANK" [BAN]
Endif

Default File [F:BAN]
Read [F:BAN]BAN0 = [L]BAN
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]BAN)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When "A"
  [L]ATSTFILTER = (BANCSH=1) : [L]AMESFILTER= func ASYRFNC.TEXTE(0)
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]BAN)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


