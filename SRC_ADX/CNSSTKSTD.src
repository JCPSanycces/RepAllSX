&                  TRSTYP <> 5             &
&                  TRSTYP <> 3             &
&                  IPTDAT >= [F:SKW]IPTDAT &
&                  evalue(WFIL2)           &
&                  evalue(WFILSPE)
&            Order By Key STR0 Desc
#--- Issue 110101 TS End Traca SST

