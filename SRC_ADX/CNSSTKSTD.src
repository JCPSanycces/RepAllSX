$SORTIE_EO_AVAL
Trbegin [SKW1]
Filter [STR] Where VCRTYP = [F:SKW]VCRTYP &
&                     VCRNUM = [F:SKW]VCRNUM &
&                     TRSTYP = 3             &
&                     VCRTYP = 36            &
&                     VCRNUMORI = [F:SKW]VCRNUMORI &
&                     evalue(WFIL2)          &
&                     evalue(WFILSPE)        &
&                     evalue(WFILLNK)
&               Order By Key STR1
Gosub ALI_SWK1
Filter [STR]
If fstat
  Rollback
Else
  Commit
Endif
Return
#--- Issue 110101 TS End Traca SST

############################################################
$ALI_SWK1
# hcb 66563 deb
Local Char    LSLO(GLONSLO)
Local Char    LSER(GLONSER)
Raz LSLO
Raz LSER
If dim([M:STK1]SLOSEL) > 0
   LSLO = [M:STK1]SLOSEL
Endif
If dim([M:STK1]SERSEL) > 0
   LSER = [M:STK1]SERSEL
Endif
# hcb 66563 fin

For [STR]
  Raz [F:SKW1]
  [F:SKW1]          = [F:STR]
  [F:SKW1]PRONUM    = WPRONUMSTK

  #--- Issue 116320
  #[F:SKW1]SEL       = mess([M:STK1]TRKSEL,334,1)
  #[F:SKW1]ITMREFSEL = [M:STK1]ITMREFSEL
  #[F:SKW1]ITMDESSEL = [M:STK1]ITMDESSEL
  #[F:SKW1]LOTSEL    = [M:STK1]ITMLOTSEL
  #[F:SKW1]SLOSEL    = LSLO                  # hcb 66563
  #[F:SKW1]SERNUMSEL = LSER                  # hcb 66563
  #[F:SKW1]LEVNUM    = INIV+1
  #---

  Gosub PLUS_UN
  [F:SKW1]LEV       = WLEV

  #--- Issue 116320
  #[F:SKW1]LEVALP    = ""
  #For WL = 0 To dim(TLEV)-1
  #  If mid$([F:SKW1]LEV,(WL*4)+1,4) = "0000"
  #    Break
  #  Endif
  #Next WL
  #[F:SKW1]LEVALP = string$(WL-1,"_")+num$(WL)
  #[F:SKW1]CREUSR = GUSER
  #[F:SKW1]CREDAT = date$
  #If !clalev([F:SKWT]) Then Local File STOTRKWRK [SKWT] Endif
  #Read [F:SKWT]SKW0=[F:SKW1]PRONUM;[F:SKW1]LEV
  Look [F:SKWT]SKW0=[F:SKW1]PRONUM;[F:SKW1]LEV
  #---

  # On ne fait le write que si l'enregistrement n'existe pas
  If fstat Then

    #--- Issue 116320
	  [F:SKW1]ITMREFSEL = [M:STK1]ITMREFSEL
	  [F:SKW1]ITMDESSEL = [M:STK1]ITMDESSEL
	  [F:SKW1]LOTSEL    = [M:STK1]ITMLOTSEL
	  [F:SKW1]SLOSEL    = LSLO                  # hcb 66563
	  [F:SKW1]SERNUMSEL = LSER                  # hcb 66563
	  [F:SKW1]LEVNUM    = INIV+1
	  [F:SKW1]SEL       = mess([M:STK1]TRKSEL,334,1)
	  [F:SKW1]LEVALP    = ""
	  For WL = 0 To dim(TLEV)-1
  		If mid$([F:SKW1]LEV,(WL*4)+1,4) = "0000"
	  	  Break
		  Endif
	  Next WL
	  [F:SKW1]LEVALP = string$(WL-1,"_")+num$(WL)
	  [F:SKW1]CREUSR = GUSER
	  [F:SKW1]CREDAT = date$
    #---

    Write [SKW1]
  Endif
  If fstat
    Call FSTA("SKW") From GLOCK
    Break
  Endif
  WK = 1
Next
Return

############################################################
$AFF_CLE
Local Char WMSG(250)
WMSG = WLEV+"\"+[F:STR]ITMREF+"\"+[F:STR]LOT+"\"+num$([F:STR]IPTDAT)+"\"+
&      num$([F:STR]MVTSEQ)+"\"+[F:STR]STOFCY+"\"+
&      num$([F:STR]VCRTYP)-[F:STR]VCRNUM
Call MESSAGE(WMSG) From GESECRAN
Return

############################################################
$PLUS_UN
WADD = val(mid$(WLEV,(INIV*4)+1,4))
WADD += 1
WLEV = left$(WLEV,INIV*4)+format$("N0:4",WADD)+right$(WLEV,((INIV+1)*4)+1)
Return

############################################################
$LOA_PAGE
NBLU = 2
WLIG = 0
If WSKIP <> 0
  If WSKIP < 0
    While WSKIP <> -1
      Read [SKW] Next
      If fstat
        Break
      Endif
      WSKIP += 1
    Wend
  Else
    While WSKIP <> 1
      Read [SKW] Prev
      If fstat
        Break
      Endif
      WSKIP -= 1
    Wend
  Endif
#--- Bug 82869
Elsif WREAD=1
  WSKWREAD=1
#---
Endif
# Test tableau plein
$LOA_PAGE1
If  nolign > MAXLIG | nolign < 1
  Goto LOA_PAGE_FIN
Endif
# Choix lecture
Case WREAD
  When 0 :
    WREAD = 1
    Read [SKW] First
    If fstat = 0
      WFIRLEV = [F:SKW]LEV
    Else
      WFIRLEV = ""
      SUITE   = 1
      RETOUR  = 1
      Goto LOA_PAGE_FIN
    Endif
  When 1 :
    Read [SKW] Next
    If fstat
      SUITE = 1
      Goto LOA_PAGE_FIN
    Endif
    #--- Bug 82869
    If WSKWREAD=1
      While left$([F:SKW]LEVALP,1)="_"
        Read [SKW] Prev
        If fstat Break Endif
      Wend
      WSKWREAD=0
    Endif
    #---
  When 2 :
    WREAD = 3
    Read [SKW] Last
  When 3 :
    Read [SKW] Prev
    If fstat
      RETOUR = 1
      Goto LOA_PAGE_FIN
    Endif
Endcase
# Test fin lecture
Gosub LOA_LIGNE
nolign += WINCR
NOL    += WINCR
WLIG   += WINCR
If [F:SKW]LEV = WFIRLEV
  RETOUR = 1
Endif
Goto LOA_PAGE1
#
$LOA_PAGE_FIN
If clalev([M:STK2]) and GACTION="VISUSTK"  Then
  [M:STK2]NBLIG = NOL
  Affzo [M:STK2]
Endif
If clalev([M:STK5]) and GACTION<>"VISUSTK" Then
  NOL+=1
  # On affecte le NBLIG pour afficher directement lorsqu'on clique droit sur Amont/Aval
  # Lorsqu'on affiche normalement, le NBLIG sera recalculé dans GCONSULT
  [M:STK5]NBLIG = NOL+1
Endif
Return
############################################################
$LOA_LIGNE
Read [STR]STR0=[F:SKW]ITMREF;[F:SKW]LOT;[F:SKW]SLO;[F:SKW]IPTDAT;[F:SKW]MVTSEQ;[F:SKW]STOFCY
If fstat
  Raz [STR]
Endif
If clalev([M:STK2]) or  GACTION="VISUSTK"  Then [M:STK2] = [F:STR] : Endif
If clalev([M:STK5]) and GACTION<>"VISUSTK" Then
  If NOL=-1 Then
    [M:STK5]ITMREF(0) = [F:SKW]ITMREF
    If dim([M:STK5]LOT) > 0
       [M:STK5]LOT(0)    = [F:SKW]LOT
    Endif
    If dim([M:STK5]SLO) > 0
      [M:STK5]SLO(0)    = [F:SKW]SLO
      #--- Dem 80759
      If GCONSULTSLO=1 [M:STK5]SLO(0)="" Endif
      #---
    Endif
    If dim([M:STK5]SERNUM) > 0
       [M:STK5]SERNUM(0) = [F:STR]SERNUM
      #--- Dem 80759 (suite)
      If GCONSULTSLO=1 [M:STK5]SERNUM(0)="" Endif
    Endif
    [M:STK5]VCRTYP(0) = 0
    [M:STK5]TRSTYP(0) = 0
    [M:STK5]PARKEY(0) = ""
    [M:STK5]KEYC(0)   = [F:STR]ITMREF
    [M:STK5]LIB(0)    = [F:STR]ITMREF
    nolign += 1
  Else
    [M:STK5] = [F:STR]
  Endif
Endif
If [F:ITM]ITMREF <> [F:STR]ITMREF
  Read [ITM]ITM0=[F:STR]ITMREF
  If fstat
    Raz [F:ITM]
  Endif
Endif
If clalev([M:STK2]) Then
  #[M:STK2]ITMDES1(nolign-1)   = [F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:STK2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
  [M:STK2]SERMGTCOD(nolign-1) = [F:ITM]SERMGTCOD
  [M:STK2]LEV(nolign-1)       = [F:SKW]LEVALP
  If [F:STR]UPDDAT = [0/0/0]
    [M:STK2]FLG(nolign-1) = 1
  Else
    [M:STK2]FLG(nolign-1) = 2
  Endif
Endif
If clalev([M:STK5]) and GACTION<>"VISUSTK" Then
  [M:STK5] = [F:STR]

  #[M:STK5]ITMDES1(nolign-1)   = [F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:STK5]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
  [M:STK5]SERMGTCOD(nolign-1) = [F:ITM]SERMGTCOD
  If [F:STR]BPRNUM<>"" Then
    If !clalev([F:BPR]) Then Local File BPARTNER [BPR] Endif
    Read [F:BPR]BPR0=[F:STR]BPRNUM
    If !fstat Then
      [M:STK5]BPRDES(nolign-1)= [F:BPR]BPRNAM
    Endif
   # Issue 117025 - 2016-06-23 by MAE :
  Else
    Raz [M:STK5]BPRDES(nolign-1)
  Endif

  If left$([F:SKW]LEVALP,1)='_' Then
#  If [F:SKW]LEVNUM>1 Then
    Local Integer I, NB_ : NB_ = 0
    Local Char    LEVALP : LEVALP=[F:SKW]LEVALP
    For I=1 To len([F:SKW]LEVALP)
      If left$(LEVALP,1)="_" Then
        LEVALP=mid$(LEVALP, 2, len(LEVALP)-1)
        NB_ += 1
      Else
        Break
      Endif
    Next I
    [M:STK5]LEV(nolign-1)       = LEVALP
#    [M:STK5]LEV(nolign-1)       = [F:SKW]LEVNUM
    I=1
    While [M:STK5]LEV(nolign-1-I)<>num$(NB_)
#    While [M:STK5]LEV(nolign-1-I)<>num$([F:SKW]LEVNUM)
      I += 1
    Wend
    [M:STK5]PARKEY(nolign-1)    = [M:STK5]KEYC(nolign-1-I)
  Else
    [M:STK5]LEV(nolign-1)       = [F:SKW]LEVALP
    [M:STK5]PARKEY(nolign-1)    = [M:STK5]KEYC(0)
  Endif
  #--- Bug 77228
  #[M:STK5]KEYC(nolign-1) = [F:STR]ITMREF+"-"+[F:STR]VCRNUM
  [M:STK5]KEYC(nolign-1) = [F:STR]ITMREF+"-"+[F:STR]VCRNUM+"-"+[F:STR]LOT+"-"+[F:STR]SLO+"-"+[F:STR]SERNUM
  #---

  #--- Bug 81200 : A chaque clé on ajoute le no de ligne pour avoir des
  # couples père/clé uniques sinon le cpsa graphique se mélange les pinceaux
  [M:STK5]KEYC(nolign-1) += "*"+num$(nolign-1)
  #---

  [M:STK5]LIB(nolign-1)  = [F:STR]ITMREF
Endif

If [F:STL]ITMREF <> [F:SKW]ITMREF | [F:STL]LOT <> [F:SKW]LOT | [F:STL]SLO <> [F:SKW]SLO
   Read [STL]STL0=[F:SKW]ITMREF;[F:SKW]LOT;[F:SKW]SLO
   If fstat
      Raz [STL]
   Endif
Endif

If clalev([M:STK2]) Then
  [M:STK2]USRFLD1(nolign-1)   = [F:STL]USRFLD1
  [M:STK2]USRFLD2(nolign-1)   = [F:STL]USRFLD2
  [M:STK2]USRFLD3(nolign-1)   = [F:STL]USRFLD3
  [M:STK2]USRFLD4(nolign-1)   = [F:STL]USRFLD4
  If dim([M:STK2]BPSLOT) > 0
    [M:STK2]BPSLOT(nolign-1)  = [F:STL]BPSLOT
  Endif
Endif

Return

############################################################
# Fenetre de sélection des pièces
$S_SELTRK
Local Char     WFIC(10)       : WFIC = "STOTRK"
Local Char     WFCY(GLONFCY)  : WFCY = PARAM(1)
Local Char     WITM(GLONITM)  : WITM = PARAM(2)
Local Decimal  WTYP           : WTYP = val(PARAM(3))
Local Char     WNUM(GLONVCR)  : WNUM = VALEUR
Local Char     WBPR(GLONBPR)  : WBPR = PARAM(4)
#
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:STR1]) = 0 : Local File STOTRK    [STR1] : Endif
#
TIT(0) = mess(18,100,1)
NBCOL  = 1 : COL(NBCOL) = "VCRTYP"
Call TEXTFIC(WFIC,"VCRTYP",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "VCRNUM"
Call TEXTFIC(WFIC,"VCRNUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ITMREF"
Call TEXTFIC(WFIC,"ITMREF",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOT"
Call TEXTFIC(WFIC,"LOT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:STR1]TRSTYP,704,1)"
Call TEXTFIC(WFIC,"TRSTYP",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "STOFCY"
Call TEXTFIC(WFIC,"STOFCY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "VCRLIN"
Call TEXTFIC(WFIC,"VCRLIN",2,TIT(NBCOL)) From OBJDIV
#
CRITERE = "1=1"
If WFCY <> ""
  CRITERE += "&[F:STR1]STOFCY=WFCY"
Endif
If WITM <> ""
  CRITERE += "&[F:STR1]ITMREF=WITM"
Endif
If WTYP <> 0
  CRITERE += "&[F:STR1]VCRTYP=WTYP"
Endif
#
ORDRE   = "VCRNUM"
START   = "VCRNUM"
SENS    = 1
VALEUR  = WNUM
SIZLIG  = 150
SIZCOL  = 280
Default File [STR1]
Return

############################################################
# Fenetre de sélection des lots  action : SELLOTSTK
############################################################
$S_SELLOT

Local Char    WFIC(10)        : WFIC = "STOTRK"
Local Char    WITM(GLONITM)   : WITM = PARAM(1)             # hcb 121825
Local Char    WLOT(GLONLOT)   : WLOT = VALEUR
#
Local Integer ISTL
Raz ISTL
If clalev([F:STR1]) = 0 : Local File STOTRK   [STR1] : ISTL = 1 : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif
#
Default File [STR1]


Local Char FILTRE1
Raz FILTRE1
If WLOT  <> ""
   FILTRE1 = "[F:STR1]LOT>=WLOT"
Endif
If FILTRE1 = ""
   FILTRE1 = "[F:STR1]LOT <> ''"
Endif

Local Char LOT_RUP(GLONLOT)
Local Integer Z
Local Char SZTIT
Z = 0
SZTIT = ""
Filter [STR1] Where [F:STR1]ITMREF=WITM & evalue(FILTRE1) Order By Key STR0

For [STR1] With Stability
    If LOT_RUP = [F:STR1]LOT
       Goto NEXTLIS
    Endif
    LOT_RUP = [F:STR1]LOT

    If Z >= dim(TEX) - 1 : Break : Endif
    Z += 1
    TEX(Z) = [F:STR1]LOT
    TEXTE(Z) = [F:STR1]LOT
$NEXTLIS
Next

Filter [STR1]
ORDRE   = "ITMREF;LOT"

NBTEX = Z
SZTIT = mess(43,197,1) #Lot
TIT = left$(SZTIT, 20)

Return

############################################################
# Fenetre de sélection des sous-lot action : SELSLOSTK
############################################################
$S_SELSLO
Local Char    WFIC(10)        : WFIC = "STOTRK"
Local Char    WLOT(GLONLOT)   : WLOT = PARAM(1)
Local Char    WITM(GLONITM)   : WITM = PARAM(2)    # hcb 121825
Local Char    WSLO(GLONSLO)   : WSLO = VALEUR
#
Local Integer ISTL
Raz ISTL
If clalev([F:STR1]) = 0 : Local File STOTRK   [STR1] : ISTL = 1 : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif
#
Default File [STR1]


Local Char FILTRE1
Raz FILTRE1
If WSLO  <> ""
   FILTRE1 = "[F:STR1]SLO>=WSLO"
Endif
If FILTRE1 = ""
   FILTRE1 = "[F:STR1]SLO <> ''"
Endif

Local Integer WLON
WLON = GLONLOT + GLONSLO

Local Char SLO_RUP(WLON)
Local Char SLO_RUPL(WLON)

Local Integer Z
Local Char SZTIT
Z = 0
SZTIT = ""
Filter [STR1] Where [F:STR1]ITMREF=WITM & [F:STR1]LOT=WLOT & evalue(FILTRE1) Order By Key STR0

For [STR1] With Stability
    SLO_RUPL = [F:STR1]LOT+[F:STR1]SLO
    If SLO_RUP = SLO_RUPL
       Goto NEXTLIS1
    Endif
    SLO_RUP = SLO_RUPL

    If Z >= dim(TEX) - 1 : Break : Endif
    Z += 1
    TEX(Z)   = [F:STR1]SLO
    TEXTE(Z) = [F:STR1]SLO
$NEXTLIS1
Next

Filter [STR1]
ORDRE   = "ITMREF;LOT;SLO"

NBTEX = Z
SZTIT = mess(456,197,1) #S/lot
TIT = left$(SZTIT, 20)

Return

############################################################
# Fenetre de sélection des sous-lot action : SELSERSTK
############################################################
$S_SELSER
Local Char    WFIC(10)        : WFIC = "STOTRK"
Local Char    WITM(GLONITM)   : WITM = PARAM(1)     # 121825
Local Char    WSER(GLONSER)   : WSER = VALEUR
Local Char    WLOT(GLONLOT)   : WLOT = PARAM(2)
Local Char    WSLO(GLONSLO)   : WSLO = PARAM(3)

If dim([M:STK1]SLOSEL)>0 Then
  WSLO = [M:STK1]SLOSEL
Endif

Local Integer ISTL
Raz ISTL
If clalev([F:STR1]) = 0 : Local File STOTRK   [STR1] : ISTL = 1 : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif

Default File [STR1]

Local Char FILTRE1
Local Char FILTRE2
Local Char FILTRE3
Raz FILTRE1
FILTRE2 = "1=1"
FILTRE3 = "1=1"

If WSER  <> ""
   FILTRE1 = "[F:STR1]SERNUM>=WSER"
Endif
If FILTRE1 = ""
   FILTRE1 = "[F:STR1]SERNUM <> ''"
Endif

If WLOT <> ""
   FILTRE2 = "[F:STR1]LOT=WLOT"
Endif
If WSLO <> ""
   FILTRE3 = "[F:STR1]SLO=WSLO"
Endif

Local Char SER_RUP(GLONSER)
Local Integer Z
Local Char SZTIT
Z = 0
SZTIT = ""
Filter [STR1] Where [F:STR1]ITMREF=WITM & evalue(FILTRE1)& evalue(FILTRE2)& evalue(FILTRE3) Order By Key STR2

For [STR1] With Stability
    If SER_RUP = [F:STR1]SERNUM
       Goto NEXTLIS2
    Endif
    SER_RUP = [F:STR1]SERNUM

    If Z >= dim(TEX) - 1 : Break : Endif
    Z += 1
    TEX(Z) = [F:STR1]SERNUM
    TEXTE(Z) = [F:STR1]SERNUM
$NEXTLIS2
Next

Filter [STR1]
ORDRE   = "ITMREF;SERNUM"

NBTEX = Z
SZTIT = mess(453,197,1) #Série
TIT = left$(SZTIT, 20)

Return

############################################################
$V_SELTRK
VALEUR = [F:STR1]VCRNUM
Return

############################################################
# On ne peut saisir que les articles gérés en série ou en lot
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

  If clalev([F:ITM]) Then
    Close Local File [ITM]
    Local File ITMMASTER [ITM]
  Endif
  Read [F:ITM]ITM0=VALEUR
  If !fstat Then
    If [F:ITM]LOTMGTCOD=1 and [F:ITM]SERMGTCOD=1 Then
      GMESSAGE=mess(328,184,1)
      mkstat=2
    Else
      [M:STK1]FLG       = 0
      [M:STK1]ITMREFSEL = ""
      [M:STK1]ITMDESSEL = ""
      [M:STK1]LOTSEL    = ""
      [M:STK1]ITMLOTSEL = ""
      If dim([M:STK1]SLOSEL) > 0
        [M:STK1]SLOSEL    = ""
      Endif
      If dim([M:STK1]SERSEL) > 0
        [M:STK1]SERSEL    = ""
      Endif
      [M:STK1]VCRTYPSEL = 1
      [M:STK1]VCRNUMSEL = ""
      [M:STK1]BPRNUMSEL = ""
      Affzo [M:STK1]

      Raz [M:STK5]NBLIG
    Endif
  Endif
End
############################################################
Subprog C_LOTSEL(VALEUR)
Variable Char     VALEUR
VALEUR = toupper(VALEUR)
End
############################################################
Subprog AM_LOTSEL(VALEUR)
Variable Char    VALEUR()
[M:STK1]FLG = 0
End
############################################################
Subprog AM_TRKSEL(VALEUR)
Variable Integer VALEUR
[M:STK1]FLG = 0
End
############################################################
Subprog AM_VCRTYPSEL(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  [M:STK1]VCRNUMSEL = ""
  Affzo [M:STK1]VCRNUMSEL
Endif
[M:STK1]FLG = 0
End
############################################################
Subprog C_VCRNUMSEL(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
End
############################################################
Subprog AM_VCRNUMSEL(VALEUR)
Variable Char    VALEUR()
[M:STK1]FLG = 0
End
############################################################
Subprog AM_SLOSEL(VALEUR)
Variable Char    VALEUR()
[M:STK1]FLG = 0

End
############################################################
Subprog AM_SERSEL(VALEUR)
Variable Char    VALEUR()
[M:STK1]FLG = 0

End

############################################################
Subprog AM_LEVMAX(VALEUR)
Variable Decimal VALEUR
[M:STK1]FLG = 0
End
############################################################
Subprog C_LEVMAX(VALEUR)
Variable Decimal VALEUR
If VALEUR < 2 | VALEUR > 15
  mkstat = 2
Endif
End
############################################################
Subprog AS_VCRNUMSEL(VALEUR)
Variable Char    VALEUR()
If [M:STK1]VCRTYPSEL = 1
  VALEUR = ""
  mkstat = 2
Endif
End
############################################################
Subprog AM_BPRNUMSEL(VALEUR)
Variable Char    VALEUR()
[M:STK1]FLG = 0
End
############################################################
Subprog AM_REGFLG(VALEUR)
Variable Integer VALEUR
[M:STK1]FLG = 0
End
############################################################
Subprog AM_ZERFLG(VALEUR)
Variable Integer VALEUR
[M:STK1]FLG = 0
End

############################################################
Subprog AV_LEV(VALEUR)
Variable Char    VALEUR()
If nolign > 0
  If [M]QTYSTU(nolign-1) < 0
    pcolor = GCOUL(1)
  Else
    pcolor = GCOUL(0)
  Endif
Endif
End

############################################################
$OUVRE_SEL
#--- Dem 80759
Global Integer GCONSULTSLO : GCONSULTSLO=0
GPOINT="CONSULT_SLO"
Gosub ENTREE From EXEFNC
#---
Local Integer NBSEL : NBSEL=0
Local Char    SERSEL(GLONSER)

  If clalev([M:STK2]) Then
    MAXLIG = dim([M:STK2]LEV)
  Endif
  If clalev([M:STK5]) Then
    MAXLIG = dim([M:STK5]LEV)
  Endif
  Local Char ITMREFLOT(60)  (MAXLIG)
  Local Char ITMREF(GLONITM)(MAXLIG)
  Local Char LOT(GLONLOT)   (MAXLIG)
  Local Char SERNUM(GLONSER)(MAXLIG)
  Local Char SLO(GLONSER)   (MAXLIG)
  Local Char ITMDES1(30)    (MAXLIG)

  If [M:STK1]ITMREF = ""
    Goto OUVRE_SEL_FIN
  Endif
  Raz SERSEL
  If dim([M:STK1]SERSEL) > 0
    SERSEL = [M:STK1]SERSEL
  Endif

  Filter [STR1]
  Filter [SKW]
  Filter [STR]

  If [M:STK1]LOTSEL = "" & [M:STK1]VCRTYPSEL = 1 & [M:STK1]BPRNUMSEL = "" & SERSEL = ""
    FIN  = 1
    GERR = 1
    GMESSAGE = mess(57,187,1)
    Goto OUVRE_SEL_FIN
  Endif
  If [M:STK1]FLG <> 0
    Goto OUVRE_SEL_FIN
  Else
# hcb 48586 deb
    WFILSPE="1=1"
    If GPROGSPESTK <>""
       ACTION = "FILTRE" : Gosub ACTION From =GPROGSPESTK
    Endif
# hcb 48586 fin
    [M:STK1]FLG = 1
    If clalev([M:STK2]) or  GACTION="VISUSTK"  Then Effzo [M:STK2] : Endif
    If clalev([M:STK5]) and GACTION<>"VISUSTK" Then Effzo [M:STK5] : Endif

    Call TEMPON(mess(58,187,1)-"1") From GESECRAN
    GSTOPRT += 1
    WPRONUMSTK = num$(adxuid(1))+"-"+num$(GSTOPRT)
    Gosub LOAD_FILTER
    Raz [M:STK1]ITMREFSEL
    Raz [M:STK1]ITMDESSEL
    Raz [M:STK1]ITMLOTSEL

# hcb 43280
# Ecriture premier niveau
    If [M:STK1]VCRTYPSEL <> 1 | [M:STK1]BPRNUMSEL <> ""
      Filter [STR1] Where evalue(WFIL1) & evalue(WFILS) &  evalue(WFILSPE)
&                   Order By Key STR0
      WNIV    = 1
      TLEV(1) = 1
      Trbegin [SKW]
      For [STR1]
        [F:STR] = [F:STR1]
        Gosub ECR_NIV1_NEW
        If fstat
          Break
        Endif
      Next
      Filter [STR1]
      If fstat
        Rollback
      Else
        Commit
      Endif
    Else
   # hcb 43280
      WNIV    = 1
      TLEV(1) = 1
      Trbegin [SKW]

      Local Integer WINOUT : WINOUT=0
      # Traçabilité Amont
      If [M:STK1]TRKSEL=1
         # Recherche s'il y a une traçabilité sur des sorties OF
         # --> dans ce cas on ne traite en 1er niveau que des sorties

         #--- Issue 110101 TS Traca SST : ajout TRSTYP=29
         #Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE) & TRSTYP=6
#&                     Order By Key STR0
         #For [STR]
         #   WINOUT = 1 : Break
         #Next
         #Filter [STR]
         # Il y a des sorties OF (on ne charge pas les entrées OF)
         #If WINOUT=1
         #   Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE) & TRSTYP<>5
#&                        Order By Key STR0
         #Else
         #   Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE)
#&                        Order By Key STR0
         #Endif
         Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE)
&                       & (TRSTYP=6  | TRSTYP=29)
&                     Order By Key STR0
         For [STR]
           Case [F:STR]TRSTYP
             When 29 : If WINOUT=0
                          WINOUT=1
                       Elsif WINOUT=2
                          WINOUT=4
                       Endif
             When  6 : If WINOUT=0
                          WINOUT=2
                       Elsif WINOUT=1
                          WINOUT=4
                       Endif
           Endcase
           If WINOUT=4 Break Endif
         Next
         Filter [STR]
         # Sorties OF         --> pas de chargement des entrées OF
         # Sorties EO         --> pas de chargement des réceptions EO
         Case WINOUT
           When 1       : Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE)
&                                          & TRSTYP<>3
&                                      Order By Key STR0
           When 2       : Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE)
&                                          & TRSTYP<>5
&                                      Order By Key STR0
           When 4       : Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE)
&                                          & TRSTYP<>3 & TRSTYP<>5
&                                      Order By Key STR0
           When Default : Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE)
&                                      Order By Key STR0
         Endcase
         #--- Issue 110101 TS End Traca SST

         For [STR]
            Gosub ECR_NIV1_NEW
            If fstat Break Endif
         Next
      # Traçabilité Aval
      Else
         # Recherche s'il y a une traçabilité sur des entrées OF
         # --> dans ce cas on ne traite en 1er niveau que des entrées

         #--- Issue 110101 TS Traca SST : ajout (TRSTYP=3 & VCRTYP=36)
         #Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE) & TRSTYP=5
#&                     Order By Key STR0
         #For [STR]
         #   WINOUT = 1 : Break
         #Next
         #Filter [STR]
         # Il y a des entrées OF (on ne charge pas les sorties OF)
         #If WINOUT=1
         #   Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE) & TRSTYP<>6
#&                        Order By Key STR0
         #Else
         #   Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE)
#&                        Order By Key STR0
         #Endif
         Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE)
&                         & (TRSTYP=5 | (TRSTYP=3 & VCRTYP=36))
&                     Order By Key STR0
         For [STR]
           Case [F:STR]TRSTYP
             When 3 : If WINOUT=0
                         WINOUT=1
                      Elsif WINOUT=2
                         WINOUT=4
                      Endif
             When 5 : If WINOUT=0
                         WINOUT=2
                      Elsif WINOUT=1
                         WINOUT=4
                      Endif
           Endcase
           If WINOUT=4 Break Endif
         Next
         Filter [STR]
         # Entrées OF         --> pas de chargement des sorties OF
         # Réceptions EO      --> pas de chargement des sorties EO
         Case WINOUT
           When 1       : Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE)
&                                          & TRSTYP<>29
&                                      Order By Key STR0
           When 2       : Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE)
&                                          & TRSTYP<>6
&                                      Order By Key STR0
           When 4       : Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE)
&                                          & TRSTYP<>29 & TRSTYP<>6
&                                      Order By Key STR0
           When Default : Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE)
&                                      Order By Key STR0
         Endcase
         #--- Issue 110101 TS End Traca SST

         For [STR]
            Gosub ECR_NIV1_NEW
            If fstat Break Endif
         Next
      Endif

      Filter [STR]
      If fstat
        Rollback
      Else
        Commit
      Endif
    Endif
    Call TEMPOFF From GESECRAN
    # Une fois tous les critères sélectionnés, on tente de voir s'il n'y a qu'un seul lot
    # correspondant aux critères : si oui, on l'affiche directement, sans avoir besoin de
    # passer par le bouton "Afficher sél."
    If NBSEL=1 Then
      Local Integer FLG_NBSEL1 : FLG_NBSEL1=G_OUI
      BOUT="a"
      Gosub BOUTON_SEL
#      Affzo [M:STK5]
      FIN=1
    #--- Dem 80759
    Elsif [F:ITM]LOTMGTCOD=4 & GCONSULTSLO=1
      If max(LOT(1..NBSEL))<>min(LOT(1..NBSEL))
        GCONSULTSLO=0
      Else
        Local Integer FLG_NBSEL1 : FLG_NBSEL1=G_OUI
        BOUT="a"
        Gosub BOUTON_SEL
        If dim([M:STK1]SLOSEL) > 0
          [M:STK1]SLOSEL = ""
          Affzo [M:STK1]SLOSEL
        Endif
        If dim([M:STK1]SERSEL) > 0  : # Suite
          [M:STK1]SERSEL = ""       : # Suite
          Affzo [M:STK1]SERSEL      : # Suite
        Endif                       : # Suite
        FIN=1
      Endif
    #---
    Endif
  Endif
$OUVRE_SEL_FIN
  If NBSEL=0 Then
    FIN=1
  Endif
Return

############################################################
$DEBUT_SEL_NEW
  If NBSEL=0 or NBSEL=1 Then Return Endif

  Raz [M:DIA]
  Raz [M:STK1]ITMREFSEL
  Raz [M:STK1]ITMDESSEL
  Raz [M:STK1]ITMLOTSEL

  Filter [SKW] Where PRONUM=WPRONUMSTK
  For [SKW]
    If [M:DIA]BASPAG < dim([M:DIA]ITMREF)-1
      If !find([F:SKW]ITMREF+[F:SKW]LOT+[F:SKW]SLO+[F:SKW]SERNUM,[M:DIA]ITMREFLOT(0..[M:DIA]BASPAG-1))  # hcb 29136
        [M:DIA]BASPAG += 1
        nolign = [M:DIA]BASPAG
        [M:DIA] = [F:SKW]
        Read [ITM1]ITM0= [F:SKW]ITMREF
        If fstat = 0
          #[M:DIA]ITMDES1(nolign-1) = [F:ITM1]ITMDES1
          Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:DIA]ITMDES1(nolign-1), "[F:ITM1]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
        Endif
        [M:DIA]ITMREFLOT(nolign-1) = [F:SKW]ITMREF+[F:SKW]LOT+[F:SKW]SLO+[F:SKW]SERNUM
      Endif
    Endif
  Next
  Filter [SKW]
  Call TEMPOFF From GESECRAN
  Affzo [M:DIA]
Return
############################################################
$DEBUT_SEL
If [M:STK1]ITMREF = ""
  Goto DEBUT_SEL_FIN
Endif
Local Char    SERSEL(GLONSER)
Raz SERSEL
If dim([M:STK1]SERSEL) > 0
   SERSEL = [M:STK1]SERSEL
Endif
# hcb 29136 fin

Filter [STR1]
Filter [SKW]
Filter [STR]

If [M:STK1]LOTSEL = "" & [M:STK1]VCRTYPSEL = 1 & [M:STK1]BPRNUMSEL = "" & SERSEL = ""
  FIN  = 1
  GERR = 1
  GMESSAGE = mess(57,187,1)
  Goto DEBUT_SEL_FIN
Endif
If [M:STK1]FLG <> 0
  Goto DEBUT_SEL_FIN
Else
# hcb 48586 deb
  WFILSPE="1=1"
  If GPROGSPESTK <>""
     ACTION = "FILTRE" : Gosub ACTION From =GPROGSPESTK
  Endif
# hcb 48586 fin
  [M:STK1]FLG = 1
  If clalev([M:STK2]) or  GACTION="VISUSTK"  Then Effzo [M:STK2] : Endif
  If clalev([M:STK5]) and GACTION<>"VISUSTK" Then Effzo [M:STK5] : Endif

  Call TEMPON(mess(58,187,1)-"1") From GESECRAN
  GSTOPRT += 1
  WPRONUMSTK = num$(adxuid(1))+"-"+num$(GSTOPRT)
  Gosub LOAD_FILTER
  Raz [M:DIA]
  Raz [M:STK1]ITMREFSEL
  Raz [M:STK1]ITMDESSEL
  Raz [M:STK1]ITMLOTSEL

# hcb 43280
# Ecriture premier niveau
  If [M:STK1]VCRTYPSEL <> 1 | [M:STK1]BPRNUMSEL <> ""
    Filter [STR1] Where evalue(WFIL1) & evalue(WFILS) &  evalue(WFILSPE)
&                 Order By Key STR0
    WNIV    = 1
    TLEV(1) = 1
    Trbegin [SKW]
    For [STR1]
      [F:STR] = [F:STR1]
      Gosub ECR_NIV1
      If fstat
        Break
      Endif
    Next
    Filter [STR1]
    If fstat
      Rollback
    Else
      Commit
    Endif
  Else
 # hcb 43280
    Filter [STR] Where evalue(WFIL) &  evalue(WFILSPE)
&                Order By Key STR0
    WNIV    = 1
    TLEV(1) = 1
    Trbegin [SKW]
    For [STR]
      Gosub ECR_NIV1
      If fstat
        Break
      Endif
    Next
    Filter [STR]
    If fstat
      Rollback
    Else
      Commit
    Endif
  Endif
  Call TEMPOFF From GESECRAN
  # Une fois tous les critères sélectionnés, on tente de voir s'il n'y a qu'un seul lot
  # correspondant aux critères : si oui, on l'affiche directement, sans avoir besoin de
  # passer par le bouton "Afficher sél."
  If [M:DIA]BASPAG=0 or [M:DIA]BASPAG>1 Then
    Affzo [M:DIA]
  Else
    BOUT="a"
    Gosub BOUTON_SEL
    FIN=1
  Endif
Endif
$DEBUT_SEL_FIN
Return
############################################################
$BOUTON_SEL
Case BOUT
  When "a" :
    If dim(FLG_NBSEL1)>0 and FLG_NBSEL1=G_OUI Then
      [M:STK1]LOTSEL    = LOT    (1)
      [M:STK1]ITMREFSEL = ITMREF (1)
      [M:STK1]ITMDESSEL = ITMDES1(1)
      [M:STK1]ITMLOTSEL = LOT    (1)

      If dim([M:STK1]SERSEL) > 0
        [M:STK1]SERSEL    = SERNUM (1)
        Affzo [M:STK1]SERSEL
      Endif
      If dim([M:STK1]SLOSEL) > 0
        [M:STK1]SLOSEL    = SLO (1)
        Affzo [M:STK1]SLOSEL
      Endif
      Affzo [M:STK1]LOTSEL
      FIN = 1
    Else
      If nolign > 0
        [M:STK1]LOTSEL    = [M:DIA]LOT    (nolign-1)
        [M:STK1]ITMREFSEL = [M:DIA]ITMREF (nolign-1)
        [M:STK1]ITMDESSEL = [M:DIA]ITMDES1(nolign-1)
        [M:STK1]ITMLOTSEL = [M:DIA]LOT    (nolign-1)

# hcb 29136 deb
        If dim([M:STK1]SERSEL) > 0
           [M:STK1]SERSEL    = [M:DIA]SERNUM (nolign-1)
           Affzo [M:STK1]SERSEL
        Endif
        If dim([M:STK1]SLOSEL) > 0
           [M:STK1]SLOSEL    = [M:DIA]SLO (nolign-1)
           Affzo [M:STK1]SLOSEL
        Endif
# hcb 29136 fin
        Affzo [M:STK1]LOTSEL
        FIN = 1
      Endif
    Endif
Endcase
Return

############################################################
$END_SEL
Raz [M:STK1]ITMREFSEL
Raz [M:STK1]ITMDESSEL
Raz [M:STK1]ITMLOTSEL
FIN = 1
Return

##########################################################################
## Etiquette ajoutée par le superviseur 29-11-2003 17:01:40 (MB)
##########################################################################
Subprog IB_NBLIG

  If nolign=1 Then
    GBOUT2=""
    GBOUT3=""
    GBOUT4=""
    GBOUT5=""
  Endif

  If !clalev([F:QLH]) Then Local File STOQLYH [QLH] Endif
  Read [F:QLH]QLH0=[M:STK5]VCRTYP(nolign-1);[M:STK5]VCRNUM(nolign-1)
  If !fstat Then
    If !clalev([F:SGD]) Then Local File SCHGD [SGD] Endif
    Read [F:SGD]SGD0=[F:QLH]VCRNUMORI
    If !fstat Then
      WCTLDEM=[F:SGD]VCRNUM
    Else
      GBOUT3=""
    Endif
  Else
    GBOUT3=""
  Endif
#MAE: bg 76607 : si on est en inventaire:pas de tunnel vers les inventaires
#MAE, bg 77811 :
#Pas de tunnel sur les modifications de lots car on ne sait pas quel objet utilisé : SMX ou SLM
If ([M:STK5]VCRTYP(nolign-1) = 9) |([M:STK5]VCRTYP(nolign-1) = 35)
  GBOUT2=""
Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 24/02/2004 17:24:09 (TS)
##########################################################################
Subprog AS_VCRTYPSEL(VALEUR)
Variable Integer VALEUR
#CCC (13/09/10) tout est désactivé par défaut
For I=1 To len(mess(0,725,1))
    If !find(I,1,5,6,7,9,10,11,13,14,16,19,20,21,27,29,30,32,33,34,35,36,37)
        GMENLOC(I) = 1
    Endif
Next
End


