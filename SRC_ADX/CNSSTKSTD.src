Filter [STR] Where ITMREF =  [F:SKW]ITMREF &
&                  LOT    =  [F:SKW]LOT    &
&                  SLO    =  [F:SKW]SLO    &
&                  SERNUM =  [F:SKW]SERNUM &
&                  TRSTYP <> 3             &
&                  TRSTYP <> 5             &
&                  IPTDAT >= [F:SKW]IPTDAT &
