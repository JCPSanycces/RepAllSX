######################################################################################
Subprog IB_LOTSEL
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSTK1) 19/12/2005  (HCB) # hcb 29136
######################################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If VALEUR <>[F:ITM]ITMREF
   Read [ITM]ITM0=VALEUR
   If fstat
      Raz [F:ITM]
   Endif
Endif
If dim([M:STK1]SERSEL) > 0
   #--- Bug 55665 (à activer ?)
   If [F:ITM]SERMGTCOD < 3
   #If [F:ITM]SERMGTCOD < 3 | (dim([F:ITM]TRKLEV)>0 & find([F:ITM]TRKLEV,2,3))
   #---
      Effzo  [M:STK1]SERSEL
      Diszo  [M:STK1]SERSEL
      Affzo  [M:STK1]SERSEL
   Else
      Actzo  [M:STK1]SERSEL
   Endif
Endif
If dim([M:STK1]SLOSEL) > 0
   #--- Bug 55665 (à activer ?)
   If [F:ITM]LOTMGTCOD < 4
   #If [F:ITM]LOTMGTCOD < 4 | (dim([F:ITM]TRKLEV)>0 & [F:ITM]TRKLEV=2)
   #---
      Effzo  [M:STK1]SLOSEL
      Diszo  [M:STK1]SLOSEL
      Affzo  [M:STK1]SLOSEL
   Else
      Actzo  [M:STK1]SLOSEL
   Endif
Endif
#--- Bug 55665
If dim([M:STK1]LOTSEL) > 0
   If [F:ITM]LOTMGTCOD < 2
      Effzo  [M:STK1]LOTSEL
      Diszo  [M:STK1]LOTSEL
      Affzo  [M:STK1]LOTSEL
   Else
      Actzo  [M:STK1]LOTSEL
   Endif
Endif
#---
End


######################################################################################
Subprog B2_NBLIG
Local Char    NOM_OBJET
Local Integer NOL

  NOL = nolign-1
  Case [M:STK5]VCRTYP(NOL)
    When 2       # commande vente
      NOM_OBJET = "SOH"
    When 3       # preparation
      NOM_OBJET = "PRH"
    When 4       # livraison
      NOM_OBJET = "SDH"
    When 5       # facture vente
      NOM_OBJET = "BIC"
    When 6       # reception
      NOM_OBJET = "PTH"
    When 8       # retours fournisseurs
      NOM_OBJET = "PNH"
    When 9       # inventaire
      #MAE, bg 76607, on enléve le tunnel sur les inventaires car on a pas le VCRNUMORI
      #NOM_OBJET = "SNL"
      End
    When 10      # ordre de fabrication
      NOM_OBJET = "MFG"
    When 12      # suivi matières
      NOM_OBJET = "MKM"
    When 13      # retour client
      NOM_OBJET = "SRH"
    When 14      # commande achat
      NOM_OBJET = "POH"
    When 15      # declaration de production
      NOM_OBJET = "MTK"
    When 17      # facture achat
      NOM_OBJET = "BIS"
    When 18      # avoir vente
      NOM_OBJET = "SIH"
    When 19      # entrée diverse
      NOM_OBJET = "SMR"
    When 20      # sortie diverse
      NOM_OBJET = "SMO"
    When 27      # plan de rangement
      NOM_OBJET = "SRG"
    When 28      # controle qualite
      NOM_OBJET = "STQ"
      Global Integer A_CONSST2
      A_CONSST2 = G_OUI
    When 29      # changement stock
      NOM_OBJET = "SCS"
    When 31      # assemblage
      NOM_OBJET = "BBY"
    When 32      # désassemblage
      NOM_OBJET = "DBY"
    When 33      # demande de service
      NOM_OBJET = "SRE"
    When 34      # plan réappro
      NOM_OBJET = "SRO"
    When 35      # modification des lots
      #MAE, bg 77811 : pas de tunnel sur modification de lot car on ne sait pas
      #quel objet utilisé : SMX ou SLM
      #NOM_OBJET = "SLM"
      End
    When 36      # ordre sous-traitance
      NOM_OBJET = "SCO"
  Endcase

  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  SAV_VCRNUM = [M:STK5]VCRNUM(NOL)
  Call OBJET(NOM_OBJET,[M:STK5]VCRNUM(NOL),num$([M:STK5]VCRTYP(NOL))) From GOBJET
  [M:STK5]VCRNUM(NOL) = SAV_VCRNUM
  Case [M:STK5]VCRTYP(NOL)
    When 28 : Kill A_CONSST2
  Endcase
  GCONSULT = 0
End

$OUVRE_VISU
Local Integer MAXLIG, NOL
Local Char    PRONUM_S(20)

  [M:STK1]FLG=1
  Gosub OUVRE

  MAXLIG=dim([M:STK2]LEV)
  Gosub LECTURE
Return

######################################################################################
# On n'affiche que les articles gérés en série ou en lot
Subprog S_ITMREF(VALEUR)
Variable Char VALEUR()
Local    Char PARMSK(250)(1..16)

  PARMSK(1) = "ITM"
  PARMSK(2) = "I"
  If clalev([F:ITM]) Then
    Close Local File [ITM]
    Local File ITMMASTER [ITM] Where (LOTMGTCOD<>1 or SERMGTCOD<>1) and TRKCOD>1
  Endif
  Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
End

######################################################################################
$TRAC_CLIC_DROIT
Local Integer NOL : NOL=-1

  #--- Issue X3-39096
  #[M:STK1]TRKSEL=1
  [M:STK1]FLG=0
  [M:STK1]ITMREF    = [M:STK5]ITMREF(nolign-1)
  [M:STK1]ITMREFSEL = [M:STK5]ITMREF(nolign-1)
  If dim([M:STK5]LOT) > 0 Then
    [M:STK1]LOTSEL    = [M:STK5]LOT(nolign-1)
  Endif
  If dim([M:STK1]SLOSEL) > 0 and dim([M:STK5]SLO) > 0
    [M:STK1]SLOSEL    = [M:STK5]SLO(nolign-1)
  Endif
  If dim([M:STK1]SERSEL) > 0 and dim([M:STK5]SERNUM) > 0
    [M:STK1]SERSEL    = [M:STK5]SERNUM(nolign-1)
  Endif

  Gosub OUVRE
  WFILS = "1=1"
  Gosub OUVRE_SEL
  Gosub LECTURE

  Affzo [M:STK1]
  Affzo [M:STK5]
Return

# Traçabilité amont affichée par clic droit
Subprog B4_NBLIG
Local Integer SENS : SENS=1
  #--- Issue X3-39096
  [M:STK1]TRKSEL=1
  Gosub TRAC_CLIC_DROIT
End

# Traçabilité aval affichée par clic droit
Subprog B5_NBLIG
Local Integer SENS : SENS=1
  #--- Issue X3-39096
  [M:STK1]TRKSEL=2
  Gosub TRAC_CLIC_DROIT

End
