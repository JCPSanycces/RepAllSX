#<AdxTL>@(#)0.0.0.0 $Revision$ Traçabilité
PARAM(3) = "AHCB_STLOPETI"
PARAM(4) = ""
PARAM(5) = "0"
PARAM(6) = ""
PARAM(7) = ""
Call GCONSULT("STK","",PARAM) From GCONSULT
End

$ACTION
Case GACTION
  When "CONSSTK"
    Case ACTION
      When "AUTORIS"    : Gosub AUTORIS
      When "FERME"      : Gosub FERME
      When "OUVRE"      : Gosub OUVRE
      When "LECTURE"    : Gosub LECTURE
      When "SETBOUT"    : Gosub SETBOUT
      When "EXEBOUT"    : Gosub EXEBOUT
      When "DEB_CRIT"   : Raz [M:CSTK] : Transmask [M:STK1] To [M:CSTK]# Issue 25606 [M:CSTK] = [M:STK1]
      When "FIN_CRIT"   : Gosub FIN_CRIT
      When "AV_MAGNETO" : Gosub AV_MAGNETO
      When "AP_MAGNETO" : Gosub AP_MAGNETO
      When "SEL_TABLE"  : Gosub SEL_TABLE
      When "VERF_TABLE" : Gosub VERF_TABLE
      When Default
    Endcase

  When "SAILOTSTK" :
    Case ACTION
      When "OUVRE"      : Gosub OUVRE_SEL
      When "DEBUT"      : Gosub DEBUT_SEL_NEW
      When "BOUTON"     : Gosub BOUTON_SEL
      When "END"        : Gosub END_SEL
    Endcase

  When "SELLOTSTK" :
    Case ACTION
      When "SEL_LISTE"  : Gosub SEL_LISTE
    Endcase

  When "SELSLOSTK" :
    Case ACTION
      When "SEL_LISTE"  : Gosub SEL_LISTE
    Endcase

  When "SELSERSTK" :
    Case ACTION
      When "SEL_LISTE"  : Gosub SEL_LISTE
    Endcase

  When "SELTRK" :
    Case ACTION
      When "SEL_TABLE"  : Gosub SEL_TABLE
    Endcase

  When "VISUSTK" :
    Case ACTION
      When "DEBUT"      : Gosub OUVRE_VISU
    Endcase

Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:STR])  = 0 : Local File STOTRK     [STR]  : Endif
If clalev([F:STR1]) = 0 : Local File STOTRK     [STR1] : Endif
If clalev([F:SKW])  = 0 : Local File STOTRKWRK  [SKW]  : Endif
If clalev([F:SKW1]) = 0 : Local File STOTRKWRK  [SKW1] : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:ITM1]) = 0 : Local File ITMMASTER  [ITM1] : Endif
#If clalev([F:STJ])  = 0 : Local File STOJOU     [STJ]  : Endif

# hcb 300305 19135
If clalev([F:STL])=0 Local File STOLOT     [STL]  Endif

#--- Issue 116320
If !clalev([F:SKWT]) Then Local File STOTRKWRK [SKWT] Endif

# Effacement anciens traitement
If GACTION<>"VISUSTK" Then
  Trbegin [SKW]
  #Delete [SKW] Where CREUSR = GUSER & CREDAT < date$
  Delete [SKW] Where CREUSR = GUSER
  If fstat
    Rollback
  Else
    Commit
  Endif
Endif
#
Global Char     WFIL(250) (2)
Global Char     WFIL1(250) (2)

Global Char     WFILSPE(250)
Global Char     GPROGSPESTK   # hcb 48586
Raz GPROGSPESTK               # hcb 48586
If GACTION<>"VISUSTK" Then
  Global Char   WFIL2(250)
Endif
#Global Char     WFILS(250)                  # hcb 87943
Global Char     WEVA(60)
Global Char     WSTR(60)
Global Integer  WNIV
Global Integer  TLEV(1..15)
If GACTION<>"VISUSTK" Then
  #MAE, bg 105176 : renommage de WPRONUM en WPRONUMSTK
  #Global Char   WPRONUM(20)
  Global Char   WPRONUMSTK(20)
  Global Char   WFILS(250)                  # hcb 87943

Endif
Global Integer  WI, WJ, WK, WL, VS
#
Local  Integer  WFSTAT, WREAD, WSKIP, WLIG, WCLA
Local  Decimal  WACT
Local  Shortint INIV
#
Local Char     WFIRLEV(60)
Local Char     WLEV(60)
Local Integer  WTIMD
Local Integer  WTIMO : WTIMO = 300
Local  Integer WGCONSULT : WGCONSULT = GCONSULT         # hcb 30488
Local  Char    WFILLNK(80)                            : #--- Dem 80222
Local Integer  WSKWREAD : WSKWREAD=0                  : #--- Bug 82869

Global Char WCTLDEM

Gosub LOAD_SCREEN
# Si Param(3) est renseigné, c'est que la traçabilité est appelée depuis un autre menu :
# on affiche donc directement le résultat
If GACTION<>"VISUSTK" Then
  If dim(PARAM)>0 and PARAM(3)<>"" Then
    NOL=-1
    Gosub OUVRE_SEL
    Gosub LECTURE

    Affzo [M:STK1]
    Affzo [M:STK5]
  Endif
Endif
#
NAVIG="CONSSTK"
SUITE  = 1
RETOUR = 1

#  Read [ACV] CODACT="SLO"                 : # Dossier avec Sous-lot
#  If fstat : Raz [F:ACV] : Endif
#  GSLO = [F:ACV]FLACT
#  If GSLO <> G_OUI : GSLO = G_NON : Endif
#
#  Read [ACV] CODACT="SER"                 : # Dossier avec Série
#  If fstat : Raz [F:ACV] : Endif
#  GSER = [F:ACV]FLACT
#  If GSER <> G_OUI : GSER = G_NON : Endif
Return

############################################################
$FIN_CRIT
[M:STK1]FLG = 0
[M:STK1] = [M:CSTK]
Return

############################################################
$AV_MAGNETO
  FILTRE = "(LOTMGTCOD<>1 or SERMGTCOD<>1) and TRKCOD>1"
Return

############################################################
$AP_MAGNETO
[M:STK1]FLG = 0
Call AM_ITMREF([M:STK1]ITMREF)
Return

############################################################
$SETBOUT
Local Char SLOSELP
If dim([M:STK1]SLOSEL) > 0
  SLOSELP = [M:STK1]SLOSEL
Endif
If [M:STK1]PRTFLG <> 1
  Call VIREBOUT(CHAINE,"a") From GOBJET
  Call VIREBOUT(CHAINE,"d") From GOBJET
Endif
If [M:STK1]ITMREFSEL = "" | [M:STK1]FLG = 0
  If !GINTRA
    Call VIREBOUT(CHAINE,"R") From GOBJET
  Endif
  Call VIREBOUT(CHAINE,"d") From GOBJET
Else
  Call VIREBOUT(CHAINE,"B") From GOBJET
Endif
If [M:STK1]ITMREFSEL<>'' Then
  If instr(1,CHAINE,'0')=0 Then
    CHAINE += '0'
  Endif
  If instr(1,CHAINE,'9')=0 Then
    CHAINE += '9'
  Endif
  If instr(1,CHAINE,'<')=0 Then
    CHAINE += '<'
  Endif
  If instr(1,CHAINE,'>')=0 Then
    CHAINE += '>'
  Endif
Endif
Return
############################################################
$EXEBOUT
Case BOUT
  When "a" :
    Local  Char    WETAT
    Local  Char    WETATP(10)(2)
    Local Char     WETATV(10)(2)
    WETAT     = "STOCK14"
    WETATP(0) = "User"
    WETATP(1) = "Process"
    WETATV(0) = GUSER
    WETATV(1) = WPRONUMSTK
    Call ETAT(WETAT,GFONCTION,WETATP,WETATV) From ETAT
  When "B" :
    OK = 2
Endcase
Return
############################################################
$FERME
Filter [SKW]
#GCONSULT = 0                                             # hcb 30488
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif      # hcb 30488
If dim(WFIL) > 0
  #MAE, bg 98838, on fait un Raz à la place d'un kill
  # Issue 116567 - 2016-05-13 by MAE : reinitialisation des WFIL en "1=1"
  WFIL = "1=1" : WFIL1 = "1=1" : WFILSPE = "1=1"
  If dim (WFIL2) > 0
    WFIL2 = "1=1" : WFILS = "1=1":
  Endif
  #Raz WFIL, WFIL1, WFIL2, WFILS, WEVA, WSTR, WNIV, TLEV, WPRONUMSTK, WI, WJ, WK, WL, VS,WFILSPE, WREAD, WTIMO, WCTLDEM
  Raz  WEVA, WSTR, WNIV, TLEV, WPRONUMSTK, WI, WJ, WK, WL, VS, WREAD, WTIMO, WCTLDEM
Endif
#MAE, bg 105176
If dim(WPRONUMSTK)>0
  Kill WPRONUMSTK
Endif

# Effacement anciens traitement      hcb 46580
Trbegin [SKW]
Delete [SKW] Where CREUSR = GUSER
If fstat
  Rollback
Else
  Commit
Endif

Return
###########################################################
$SEL_TABLE
Case TABLE
  When "SELTRK" : Gosub S_SELTRK
Endcase
Return
############################################################
$VERF_TABLE
Case TABLE
  When "SELTRK" : Gosub V_SELTRK
Endcase
Return
###########################################################
$SEL_LISTE
Case LISTE
  When "SELLOTSTK" : Gosub S_SELLOT
  When "SELSLOSTK" : Gosub S_SELSLO
  When "SELSERSTK" : Gosub S_SELSER
Endcase
Return
############################################################
$LOAD_SCREEN
If GACTION <>  "CONSSTK"
   Return
Endif


For WI = 1 To dim(PARAM)
  Case WI
    When 1 :
      GCONSULT = val(PARAM(WI))
    When 2 :
      If val(PARAM(WI)) <> 0
        [M:STK1]TRKSEL = val(PARAM(WI))
      Else
        [M:STK1]TRKSEL = 1
      Endif
    When 3 :
      If PARAM(WI) <> ""
        Call LECTURE("ITM",PARAM(WI),"") From CONTOBJ
        If !fstat
          [M:STK1]          = [F:ITM]
        Endif
      Endif
    When 4 :
      If PARAM(WI) <> "" & dim([M:STK1]LOTSEL) > 0
        [M:STK1]LOTSEL = PARAM(WI)
      Endif
    When 5 :
      If val(PARAM(WI)) <> 0
        [M:STK1]VCRTYPSEL = val(PARAM(WI))+1
      Else
        [M:STK1]VCRTYPSEL = 1
      Endif
    When 6 :
      If PARAM(WI) <> ""
        [M:STK1]VCRNUMSEL = PARAM(WI)
      Endif
    When 7 :
      If PARAM(WI) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(WI))
      Endif
  Endcase
Next WI
#
If clalev([M:CSTK]) <> 0 & [M:CSTK]MEMO = "STD"
  [M:STK1] = [M:CSTK]
Else
  [M:STK1]LEVMAX    = 15
  [M:STK1]TRSTYP001 = 2
  [M:STK1]TRSTYP002 = 2
  [M:STK1]TRSTYP003 = 2
  [M:STK1]TRSTYP004 = 2
  [M:STK1]TRSTYP005 = 2
  [M:STK1]TRSTYP006 = 2
  [M:STK1]TRSTYP007 = 2
  [M:STK1]TRSTYP008 = 2
  [M:STK1]TRSTYP009 = 2
  [M:STK1]TRSTYP010 = 2
  [M:STK1]TRSTYP011 = 2
  [M:STK1]TRSTYP012 = 2
  [M:STK1]TRSTYP013 = 2
  [M:STK1]TRSTYP014 = 2
  [M:STK1]TRSTYP015 = 2
  [M:STK1]TRSTYP016 = 2
  [M:STK1]TRSTYP017 = 2
  [M:STK1]TRSTYP018 = 2
  [M:STK1]TRSTYP019 = 2
  [M:STK1]TRSTYP020 = 2
  [M:STK1]TRSTYP021 = 2
  [M:STK1]TRSTYP022 = 2 : #--- Issue 110101 TS Traca SST
  [M:STK1]ZERFLG    = 2

Endif
Return
############################################################
$LECTURE

# hcb 43280 deb
WFILSPE="1=1"
#GPROGSPESTK = PROGSPE   # hcb 48586
If dim(PROGSPE)>0 and PROGSPE<>""
  GPROGSPESTK = PROGSPE   # hcb 48586
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
# hcb 43280 fin

If [M:STK1]ITMREFSEL = "" | [M:STK1]FLG = 0
  Goto LECTURE_FIN
Endif

#--- Dem 80222
WFILLNK="1=1"
GPOINT="LNK_SKW"
Gosub ENTREE From EXEFNC
#---

# Purge des lignes non sélectionnées
If WREAD = 0 | CHGPAG = 1                # hcb  31987
  If GACTION<>"VISUSTK" Then
    Gosub PUR_SELECTIONS
    [M:STK1]PRTFLG = 1
    WTIMD = time
#--

# hcb 43280 deb
#   WFILSPE="1=1"
#   If PROGSPE<>""
#      ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
#   Endif
# hcb 43280 deb
#--

    Case [M:STK1]TRKSEL
      When 1 : Gosub TRT_NIVEAUX_AMONT
      When 2 : Gosub TRT_NIVEAUX_AVAL
    Endcase
  Endif
#  [M:STK1]FLG = 0
   If VS = 1
      Gosub DEL_WRK
   Endif
   Filter [SKW] Where PRONUM = WPRONUMSTK
&               Order By Key SKW0
#
# Paramètres pour LOA_PAGE
# WINC      : Increment sur NOL et nolign
# WREAD = 0 : Read first
#         1 : Read next
#         2 : Read last
#         3 : read prev
# WSKIP     : Nombre de relectures avant / arrière
#

Endif                                    # hcb  31987

If WREAD = 0 | CHGPAG = 1
  nolign = 1
  WREAD  = 0
  WINCR  = 1
  SUITE  = 0
  RETOUR = 0
  Gosub LOA_PAGE
Else
  Case CHGPAG
    When 2  :
      If WINCR = -1
        WSKIP = WLIG
      Else
        WSKIP = 0
      Endif
      nolign = 1
      WREAD  = 1
      WINCR  = 1
      Gosub LOA_PAGE
      RETOUR = 0
    When -1 :
      nolign = MAXLIG
      WREAD  = 2
      WINCR  = -1
      WSKIP  = 0
      Gosub LOA_PAGE
      RETOUR = 0
      SUITE  = 1
    When -2 :
      If WINCR = 1
        WSKIP = WLIG
      Else
        WSKIP = 0
      Endif
      nolign = MAXLIG
      WINCR  = -1
      WREAD  = 3
      Gosub LOA_PAGE
      SUITE  = 0
  Endcase
Endif
$LECTURE_FIN
Return
############################################################
$ECR_NIV1
Raz [F:SKW]
[F:SKW]          = [F:STR]
[F:SKW]PRONUM    = WPRONUMSTK
[F:SKW]SEL       = mess([M:STK1]TRKSEL,334,1)
[F:SKW]LEVNUM    = WNIV
[F:SKW]LEVALP    = "1"
For WI = 1 To dim(TLEV)
  [F:SKW]LEV += format$("N0:4",TLEV(WI))
Next WI
TLEV(WNIV) += 1
[F:SKW]CREUSR = GUSER
[F:SKW]CREDAT = date$
Write [SKW]
If fstat
  Call FSTA("SKW") From GLOCK
Endif

 If [M:DIA]BASPAG < dim([M:DIA]ITMREF)-1
 #  If !find([F:STR]ITMREF+[F:STR]LOT,[M:DIA]ITMREFLOT(0..[M:DIA]BASPAG-1))                # hcb 29136
   If !find([F:STR]ITMREF+[F:STR]LOT+[F:STR]SLO+[F:STR]SERNUM,[M:DIA]ITMREFLOT(0..[M:DIA]BASPAG-1))  # hcb 29136
    [M:DIA]BASPAG += 1
    nolign = [M:DIA]BASPAG
    [M:DIA] = [F:STR]
    Read [ITM1]ITM0= [F:STR]ITMREF
    If fstat = 0
      #[M:DIA]ITMDES1(nolign-1) = [F:ITM1]ITMDES1
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:DIA]ITMDES1(nolign-1), "[F:ITM1]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Endif
#    [M:DIA]ITMREFLOT(nolign-1) = [F:STR]ITMREF+[F:STR]LOT    # hcb 29136
     [M:DIA]ITMREFLOT(nolign-1) = [F:STR]ITMREF+[F:STR]LOT+[F:STR]SLO+[F:STR]SERNUM  # hcb 29136
  Endif
 Endif

Return

############################################################
$ECR_NIV1_NEW

  Raz [F:SKW]
  [F:SKW]          = [F:STR]
  [F:SKW]PRONUM    = WPRONUMSTK
  [F:SKW]SEL       = mess([M:STK1]TRKSEL,334,1)
  [F:SKW]LEVNUM    = WNIV
  [F:SKW]LEVALP    = "1"
  For WI = 1 To dim(TLEV)
    [F:SKW]LEV += format$("N0:4",TLEV(WI))
  Next WI
  TLEV(WNIV) += 1
  [F:SKW]CREUSR = GUSER
  [F:SKW]CREDAT = date$
  Write [SKW]
  If fstat
    Call FSTA("SKW") From GLOCK
    # Issue 92193
    Return
  Endif

  If NBSEL < dim(ITMREFLOT)-1
    If !find([F:STR]ITMREF+[F:STR]LOT+[F:STR]SLO+[F:STR]SERNUM,ITMREFLOT) Then
      NBSEL += 1
      ITMREFLOT(NBSEL) = [F:STR]ITMREF+[F:STR]LOT+[F:STR]SLO+[F:STR]SERNUM
      ITMREF(NBSEL)    = [F:STR]ITMREF
      LOT(NBSEL)       = [F:STR]LOT
      SERNUM(NBSEL)    = [F:STR]SERNUM
      SLO(NBSEL)       = [F:STR]SLO
      Read [ITM1]ITM0= [F:STR]ITMREF
      If fstat = 0
        #ITMDES1(NBSEL) = [F:ITM1]ITMDES1
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,ITMDES1(NBSEL), "[F:ITM1]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
        # Issue 92193
        fstat=0
      Endif
    Endif
  Endif
Return
############################################################
$PUR_SELECTIONS
Local Char    LSLO(GLONSLO)
Local Char    LSER(GLONSER)
Raz LSLO
Raz LSER

If dim([M:STK1]SLOSEL) > 0
   LSLO = [M:STK1]SLOSEL
Endif
If dim([M:STK1]SERSEL) > 0
   LSER = [M:STK1]SERSEL
Endif
#--- Dem 80759
If GCONSULTSLO=1
   Return
Endif
#---

Trbegin [SKW]
Filter [SKW] Where PRONUM = WPRONUMSTK
&            Order By Key SKW0
For [SKW]
#  If !([F:SKW]ITMREF=[M:STK1]ITMREFSEL&[F:SKW]LOT=[M:STK1]ITMLOTSEL)  # hcb 29136
   If !([F:SKW]ITMREF=[M:STK1]ITMREFSEL&[F:SKW]LOT=[M:STK1]ITMLOTSEL&[F:SKW]SLO=LSLO&[F:SKW]SERNUM=LSER) # hcb 29136
    Delete [SKW]
    If fstat
      Call FSTA("SKW") From GLOCK
      Break
    Endif
  Else
    [F:SKW]ITMREFSEL = [M:STK1]ITMREFSEL
    [F:SKW]LOTSEL    = [M:STK1]ITMLOTSEL
    [F:SKW]ITMDESSEL = [M:STK1]ITMDESSEL
    [F:SKW]SLOSEL    = LSLO                  # hcb 66563
    [F:SKW]SERNUMSEL = LSER                  # hcb 66563
    Rewrite [SKW]
    If fstat
      Call FSTA("SKW") From GLOCK
      Break
    Endif

  Endif
Next
Filter [SKW]
If fstat
  Rollback
Else
  Commit
Endif
Return
############################################################
$LOAD_FILTER

Raz GBIDI1
Raz WFIL
Raz WFIL1
Call ADDCRIT(WFIL,GBIDI1,"WFIL","[F:STR]ITMREF=[M:STK1]ITMREF","&") From GOBJSUB
Call ADDCRIT(WFIL1,GBIDI1,"WFIL1","[F:STR1]ITMREF=[M:STK1]ITMREF","&") From GOBJSUB
#WFIL  = "[F:STR]ITMREF=[M:STK1]ITMREF"
#WFIL1 = "[F:STR1]ITMREF=[M:STK1]ITMREF"
#
If dim([M:STK1]LOTSEL) > 0 & [M:STK1]LOTSEL <> ""
   Call ADDCRIT(WFIL,GBIDI1,"WFIL","pat([F:STR]LOT,[M:STK1]LOTSEL)","&") From GOBJSUB
   Call ADDCRIT(WFIL1,GBIDI1,"WFIL1","pat([F:STR1]LOT,[M:STK1]LOTSEL)","&") From GOBJSUB
#  WFIL  += "&pat([F:STR]LOT,[M:STK1]LOTSEL)"
#  WFIL1 += "&pat([F:STR1]LOT,[M:STK1]LOTSEL)"
Endif

#  # hcb 29136 deb
If dim([M:STK1]SERSEL) > 0 & [M:STK1]SERSEL <> ""
   Call ADDCRIT(WFIL,GBIDI1,"WFIL","[F:STR]SERNUM=[M:STK1]SERSEL","&") From GOBJSUB
   Call ADDCRIT(WFIL1,GBIDI1,"WFIL1","[F:STR1]SERNUM=[M:STK1]SERSEL","&") From GOBJSUB
#   WFIL += "&[F:STR]SERNUM=[M:STK1]SERSEL"
#   WFIL1 += "&[F:STR1]SERNUM=[M:STK1]SERSEL"
Endif
If dim([M:STK1]SLOSEL) > 0 & [M:STK1]SLOSEL <> ""
   Call ADDCRIT(WFIL,GBIDI1,"WFIL","[F:STR]SLO=[M:STK1]SLOSEL","&") From GOBJSUB
   Call ADDCRIT(WFIL1,GBIDI1,"WFIL1","[F:STR1]SLO=[M:STK1]SLOSEL","&") From GOBJSUB
#   WFIL += "&[F:STR]SLO=[M:STK1]SLOSEL"
#   WFIL1 += "&[F:STR1]SLO=[M:STK1]SLOSEL"
Endif

# hcb 29136 fin

If [M:STK1]REGFLG <> 2                    # hcb 29983
   Call ADDCRIT(WFIL,GBIDI1,"WFIL","[F:STR]REGFLG<>2","&") From GOBJSUB
   Call ADDCRIT(WFIL1,GBIDI1,"WFIL1","[F:STR1]REGFLG<>2","&") From GOBJSUB
#   WFIL  += "&[F:STR]REGFLG<>2"           # hcb 29983
#   WFIL1 += "&[F:STR1]REGFLG<>2"           # hcb 29983
Endif                                     # hcb 29983
If [M:STK1]ZERFLG <> 2                    # hcb 29983
   Call ADDCRIT(WFIL,GBIDI1,"WFIL","[F:STR]QTYSTU<>0","&") From GOBJSUB
   Call ADDCRIT(WFIL1,GBIDI1,"WFIL1","[F:STR1]QTYSTU<>0","&") From GOBJSUB
#   WFIL  += "&[F:STR]QTYSTU<>0"           # hcb 29983
#   WFIL1 += "&[F:STR1]QTYSTU<>0"           # hcb 29983
Endif                                     # hcb 29983

#
If [M:STK1]VCRTYPSEL <> 1
   Call ADDCRIT(WFIL,GBIDI1,"WFIL","[F:STR]VCRTYP=[M:STK1]VCRTYPSEL-1","&") From GOBJSUB
   Call ADDCRIT(WFIL1,GBIDI1,"WFIL1","[F:STR1]VCRTYP=[M:STK1]VCRTYPSEL-1","&") From GOBJSUB
#  WFIL  += "&[F:STR]VCRTYP=[M:STK1]VCRTYPSEL-1"
#  WFIL1 += "&[F:STR1]VCRTYP=[M:STK1]VCRTYPSEL-1"
Endif
#
If [M:STK1]VCRNUMSEL <> ""
   Call ADDCRIT(WFIL,GBIDI1,"WFIL","pat([F:STR]VCRNUM,[M:STK1]VCRNUMSEL)","&") From GOBJSUB
   Call ADDCRIT(WFIL1,GBIDI1,"WFIL1","pat([F:STR1]VCRNUM,[M:STK1]VCRNUMSEL)","&") From GOBJSUB
#  WFIL  += "&pat([F:STR]VCRNUM,[M:STK1]VCRNUMSEL)"
#  WFIL1 += "&pat([F:STR1]VCRNUM,[M:STK1]VCRNUMSEL)"
Endif
#
If [M:STK1]BPRNUMSEL <> ""
   Call ADDCRIT(WFIL,GBIDI1,"WFIL","[F:STR]BPRNUM=[M:STK1]BPRNUMSEL","&") From GOBJSUB
   Call ADDCRIT(WFIL1,GBIDI1,"WFIL1","[F:STR1]BPRNUM=[M:STK1]BPRNUMSEL","&") From GOBJSUB
#  WFIL  += "&[F:STR]BPRNUM=[M:STK1]BPRNUMSEL"
#  WFIL1 += "&[F:STR1]BPRNUM=[M:STK1]BPRNUMSEL"
Endif
#

WSTR = ""
For WI = 1 To 22                : #--- Issue 110101 TS Traca SST : remplacement 21 par 22
  WEVA = "[M:STK1]TRSTYP"+format$("N0:3",WI)+"=2"
  If evalue(WEVA)
    If WI<10
      WSTR += ","+num$(WI)
    Elsif WI<14
      WSTR += ","+num$(WI+1)
    Elsif WI<20
      WSTR += ","+num$(WI+3)
    Elsif WI=22                 : #--- Issue 110101 TS Traca SST
      WSTR += ","+num$(WI+7)    : #--- Issue 110101 TS Traca SST
    Else
      WSTR += ","+num$(WI+4)
    Endif
  Endif
Next WI
If WSTR = ""
  WSTR = ",99"
Endif
#WFIL  += "&find([F:STR]TRSTYP"+WSTR+")"
Call ADDCRIT(WFIL,GBIDI1,"WFIL","find([F:STR]TRSTYP"+WSTR+")","&") From GOBJSUB
#WFIL1 += "&find([F:STR1]TRSTYP"+WSTR+")"
Call ADDCRIT(WFIL1,GBIDI1,"WFIL1","find([F:STR1]TRSTYP"+WSTR+")","&") From GOBJSUB
WFIL2  = "find([F:STR]TRSTYP"+WSTR+")"
#--- Bug 84668
If [M:STK1]REGFLG<>2 WFIL2+="&[F:STR]REGFLG<>2" Endif

Return
############################################################
$DEL_WRK
Trbegin [SKW]
Delete [SKW] Where PRONUM = WPRONUMSTK
If fstat
  Call FSTA("SKW") From GLOCK
  Rollback
Else
  Commit
Endif
Return
############################################################
$TRT_NIVEAUX_AMONT

For INIV = 1 To [M:STK1]LEVMAX-1
  Call TEMPON(mess(58,187,1)-num$(INIV+1)) From GESECRAN
  WK = 0
  Filter [SKW] Where PRONUM = WPRONUMSTK &
&                    LEVNUM =INIV
&              Order By Key SKW0
  For [SKW]
    WLEV = [F:SKW]LEV
    Case [F:SKW]TRSTYP
      When 5       : Gosub ENTREE_OF_AMONT
      When 6       : Gosub SORTIE_OF_AMONT
      When 3       : If [F:SKW]VCRTYP=36      : #--- Issue 110101 TS Traca SST
                        Gosub ENTREE_EO_AMONT : #--- Issue 110101 TS Traca SST
                     Endif                    : #--- Issue 110101 TS Traca SST
      When 29      : Gosub SORTIE_EO_AMONT    : #--- Issue 110101 TS Traca SST
    Endcase
  Next
  Filter [SKW]
# Test traitement long
  VS = 2
  If time-WTIMD > WTIMO
    Call AVERTIR(mess(205,100,1),VS) From GESECRAN
    If VS = 1
      WK = 0
    Else
      WTIMD = time
    Endif
  Endif
  If WK = 0
    Break
  Endif
Next INIV
Call TEMPOFF From GESECRAN
Return

############################################################
$ENTREE_OF_AMONT
# sr  14647 filtrer sur le numéro de ligne article lancé ou n° à 0
Trbegin [SKW1]

#--- Dem 80222
# Ajout de evalue(WFILLNK) dans le Filter (si OF)
# pour exploiter filtre alimenter dans PE 'LNK_SKW'
#---

#--- Bidouille pour traçabilité par suivi
If [F:SKW]VCRTYP=10
#---
   Filter [STR] Where VCRTYP    = [F:SKW]VCRTYP &
&                     VCRNUM    = [F:SKW]VCRNUM &
&                     (VCRLIN   = [F:SKW]VCRLIN | VCRLIN = 0) &
&                     TRSTYP = 6             &
&                     evalue(WFIL2)          &
&                     evalue(WFILSPE)        &
&                     evalue(WFILLNK)
&               Order By Key STR1
#--- Bidouille pour traçabilité par suivi
Else
#--- Issue 100526 by TS
   Filter [STR] Where VCRNUM    = [F:SKW]VCRNUM &
&                     VCRNUMORI=[F:SKW]VCRNUMORI &
&                     (VCRLINORI=[F:SKW]VCRLINORI | VCRLINORI=0) &
&                     TRSTYP = 6             &
&                     evalue(WFIL2)          &
&                     evalue(WFILSPE)
&               Order By Key STR1
#   Filter [STR] Where VCRNUM    = [F:SKW]VCRNUM &
#&                     TRSTYP = 6             &
#&                     evalue(WFIL2)          &
#&                     evalue(WFILSPE)
#&               Order By Key STR1
#---
Endif
#---

Gosub ALI_SWK1
Filter [STR]
If fstat
  Rollback
Else
  Commit
Endif
Return
############################################################
$SORTIE_OF_AMONT

Trbegin [SKW1]

#--- Issue 110101 TS Traca SST
#Filter [STR] Where ITMREF =  [F:SKW]ITMREF &
#&                  LOT    =  [F:SKW]LOT    &
#&                  SLO    =  [F:SKW]SLO    &
#&                  SERNUM =  [F:SKW]SERNUM &
#&                  TRSTYP<>6               &
#&                  evalue(WFIL2)           &
#&                  evalue(WFILSPE)
#&            Order By Key STR0
Filter [STR] Where ITMREF =  [F:SKW]ITMREF &
&                  LOT    =  [F:SKW]LOT    &
&                  SLO    =  [F:SKW]SLO    &
&                  SERNUM =  [F:SKW]SERNUM &
&                  TRSTYP <> 6             &
&                  TRSTYP <> 29            &
&                  IPTDAT <= [F:SKW]IPTDAT &
&                  evalue(WFIL2)           &
&                  evalue(WFILSPE)
&            Order By Key STR0
#--- Issue 110101 TS End Traca SST

Gosub ALI_SWK1
Filter [STR]
If fstat
  Rollback
Else
  Commit
Endif
Return

