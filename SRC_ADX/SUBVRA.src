Subprog AM_TIMCOD(VALEUR)
Variable Char    VALEUR()
If !GTPS : End : Endif
If VALEUR=""
 Actzo [M]NATCOD
Else
 Effzo [M]NATCOD : Grizo [M]NATCOD
Endif

#MIPEA - 2017-08-09- US X3-39538- START
If func AFNC.ACTIV("GLM")
  If clalev([TIM]) = 0      : Local File TIMCOD [TIM] Endif
  Filter [TIM] Where [TIM]COD=VALEUR and LEG=GCURLEG
  Read [TIM]Last

  If !fstat and ([TIM]LVEENHANCE=2 & ([TIM]CATTIM=3 |[TIM]CATTIM=2))  and [TIM]ENAFLG=2

    If clalev([HRLSTH]) = 0      : Local File HRLVESUBDET [HRLSTH] Endif

    Local Integer S, L
    Global Char LIS_HRLST(GLONHRLST)(0..100)

    For [TIM]
      For S=1 To dim([TIM]LVESUBTYP)
        If [TIM]LVESUBTYP(S-1) <> ""
          Read [HRLSTH]HRLST0 = GCURLEG;[TIM]LVESUBTYP(S-1)
          If [HRLSTH]LVEPAYDES(0)<>""
                If !find([TIM]LVESUBTYP(S-1),LIS_HRLST(0..100)) : LIS_HRLST(L) = [TIM]LVESUBTYP(S-1) : L+=1 : Endif
          Endif
        Endif
      Next
    Next
    Filter [TIM]

    If LIS_HRLST(0)<>""
      Actzo [M:VRA1]LVESUBTYP
      Actzo [M:VRA1]LVEPAYDES
    Else
      Effzo [M:VRA1]LVESUBTYP : Grizo [M:VRA1]LVESUBTYP
      Effzo [M:VRA1]LVEPAYDES : Grizo [M:VRA1]LVEPAYDES
    Endif
  Endif
  #MIPEA - 2017-08-09- US X3-39538- END

  #MIPEA - 2017-08-29- US X3-54056- START
  Effzo [M:VRA1]LVESUBTYP
  Effzo [M:VRA1]LVESUBRAT
  Effzo [M:VRA1]LVEPAYDES
Endif
#MIPEA - 2017-08-29- US X3-54056- END

End

Subprog AM_NATCOD(VALEUR)
Variable Char    VALEUR()
#MIPEA - 2017-08-06- US X3-39538- START
If func AFNC.ACTIV("GLM")
  If VALEUR=""
   Actzo [M]TIMCOD
   Actzo [M]LVESUBTYP
   Actzo [M]LVEPAYDES
  Else
   Effzo [M]TIMCOD    : Grizo [M]TIMCOD
   Effzo [M]LVESUBTYP : Grizo [M]LVESUBTYP
   Effzo [M]LVEPAYDES : Grizo [M]LVEPAYDES
  Endif
Else
If VALEUR=""
 Actzo [M]TIMCOD
Else
 Effzo [M]TIMCOD    : Grizo [M]TIMCOD
Endif
Endif
#If VALEUR=""
# Actzo [M]TIMCOD
#Else
# Effzo [M]TIMCOD : Grizo [M]TIMCOD
#Endif
#MIPEA - 2017-08-06- US X3-39538- END
End

Subprog C_TIMCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 If !GTPS | [M:VRA1]TYPVAL = 5 # WGA : W00001 Prolongation
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat=2 : End
 Else
  Actzo [M]NATCOD
 Endif
Else
 VALEUR=toupper(VALEUR)
 #LIPET - 2017-05-20 - START
 #** V7 : Waiting Time Mangement
 #**If !instr(1,VALEUR,"*") & !instr (1,VALEUR,"?") & !instr (1,VALEUR,"#") & !instr (1,VALEUR,"!")
 #** Call CONTROLE("TIM","!",VALEUR,"",mkstat) From CONTOBJ
 #** If mkstat : End : Endif
 #**Endif
 #**If [M:VRA1]TYPINI = 4 & [M:VRA1]TYPMAJ = 1 & [M:VRA1]TYPVAL = 5
 #**&  &  VALEUR <> func AFNC.PARAM("AT","")
 #**&  &  VALEUR <> func AFNC.PARAM("MALADIE","")
 #**&  &  VALEUR <> func AFNC.PARAM("MATERNITE","")
 #**&  &  VALEUR <> func AFNC.PARAM("ATTRAJET","")
 #**&  &  VALEUR <> func AFNC.PARAM("PATERNITE","")
 #**&  &  VALEUR <> func AFNC.PARAM("MALPROF","")
 #**&  &  VALEUR <> func AFNC.PARAM("PATHPOST","")
 #**&  &  VALEUR <> func AFNC.PARAM("PATHPREN","")
 #**     GMESSAGE = mess(187,10709,1) # L'évènement doit être une valeur des paramétres d'absence ( chapitre PAY / ATT )
 #**     mkstat=2
 #**     End
 #** Endif
 #*!

 If !instr(1,VALEUR,"*") & !instr (1,VALEUR,"?") & !instr (1,VALEUR,"#") & !instr (1,VALEUR,"!")
  Call CONTROLE("TIM","!",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : End : Endif
 Endif
If [M:VRA1]TYPINI = 4 & [M:VRA1]TYPMAJ = 1 & [M:VRA1]TYPVAL = 5
&  &  VALEUR <> func AFNC.PARAM("AT","")
&  &  VALEUR <> func AFNC.PARAM("MALADIE","")
&  &  VALEUR <> func AFNC.PARAM("MATERNITE","")
&  &  VALEUR <> func AFNC.PARAM("ATTRAJET","")
&  &  VALEUR <> func AFNC.PARAM("PATERNITE","")
&  &  VALEUR <> func AFNC.PARAM("MALPROF","")
&  &  VALEUR <> func AFNC.PARAM("PATHPOST","")
&  &  VALEUR <> func AFNC.PARAM("PATHPREN","")
     GMESSAGE = mess(187,10709,1) # L'évènement doit être une valeur des paramétres d'absence ( chapitre PAY / ATT )
     mkstat=2
     End
Endif
 #LIPET - 2017-05-20 - END
Endif
End

Subprog C_NATCOD(VALEUR)
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement
#**If !instr(1,VALEUR,"*") & !instr (1,VALEUR,"?") & !instr (1,VALEUR,"#") & !instr (1,VALEUR,"!")
#** Call CONTROLE("NAT","!",VALEUR,"",mkstat) From CONTOBJ
#** If mkstat : End : Endif
#**Endif
#*!
If !instr(1,VALEUR,"*") & !instr (1,VALEUR,"?") & !instr (1,VALEUR,"#") & !instr (1,VALEUR,"!")
 Call CONTROLE("NAT","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : End : Endif
Endif
#LIPET - 2017-05-20 - END
End

########################################
# Subprog appelé en fin de validation d'un dossier (Cf. SUBADSB)
# Mise à jour des variables si pas la gestion des temps
# On passe les variables de réinit 'Maj auto' et de type 'Synthèse'
# en réinit 'Annulation' + on passe les variables ayant pour type
# de valeur 'Qt1' ou 'Qt2' en type de valeur 'Jour'.
########################################

Subprog MAJTYPINI(APPLI)
Value Char APPLI
Local File =APPLI+".ACTIV" [ACV]
Local File =APPLI+".VARIA" [VRA]

# NTPS doit être actif
Read [F:ACV]CODACT="NTPS"
If !fstat & [F:ACV]FLACT=2
 Call DEBTRANS From GLOCK
 Gosub TR1
Endif

Close File [ACV],[VRA]
End

$TR1
GOK = 1
Trbegin [VRA]
For [F:VRA]VRA0 Where TYPINI=4    :#Maj auto
 If [F:VRA]TYPMAJ=2         :# Synthèse
  [F:VRA]TYPINI=2    :#Annulation
#MIPEA - 2017-08-06- US X3-39538- START
If func AFNC.ACTIV("GLM")
  Raz [F:VRA]TYPMAJ,TYPVAL,TIMCOD,TIMVAR,TIMCMT,CMTDET,NATCOD,LVESUBTYP,LVEPAYDES
Else
  Raz [F:VRA]TYPMAJ,TYPVAL,TIMCOD,TIMVAR,TIMCMT,CMTDET,NATCOD
Endif
#  Raz [F:VRA]TYPMAJ,TYPVAL,TIMCOD,TIMVAR,TIMCMT,CMTDET,NATCOD
#MIPEA - 2017-08-06- US X3-39538- END

  Rewrite [F:VRA]
 Elsif [F:VRA]TYPVAL>2 & [F:VRA]TYPVAL<5 :#Qt1 ou Qt2
  [F:VRA]TYPVAL=1    :#Jour
  Raz [F:VRA]TIMVAR,NATCOD
  Rewrite [F:VRA]
 Endif
 If fstat
  GOK = 0 : Call FSTA("VRA") From GLOCK : Break
 Endif
Next
If !GOK : Rollback : Else : Commit : Endif
Return

#JASMI - START
#Subprog CONTVRA(CODE,LEG)
#Variable Char CODE()
#Value    Char LEG()
Subprog CONTVRA(CODE)
Variable Char CODE()

If GFONCTION = "GESVRA" | CODE="" : End : Endif

#JASMI - END
#48648
If instr(1,CODE,"-")
 # Caractère interdit
 GMESSAGE = "- :"-mess(94,123,1)
 mkstat=2 : End
Endif
If instr(1,CODE,"/")
 # Caractère interdit
 GMESSAGE = "/ :"-mess(94,123,1)
 mkstat=2 : End
Endif

If CODE <> ""
  If num$(val(CODE))=CODE
  #JASMI - START
  #  If func DIVPAYE.IS_ZA_DEV() > 0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
  #    If dim([M:VEP0]TABCOD) > 0 Then
    If dim([M:VEP0]TABCOD) > 0 & func DIVPAYE.IS_ZA_DEV() > 0
  #JASMI - END
        If clalev([F:CVR])=0 : Local File CALVAR [CVR] : Endif
        Look [CVR]CVR2 = CODE
        If !fstat
          CODE = [F:CVR]COD
        Endif
  #JASMI - START
  #    Endif
  #JASMI - END
    Else
  #JASMI - START
  #   If clalev([F:VRA])=0 : Local File VARIA [VRA] : Endif
  #   Look [VRA]VRA0 = LEG;CODE
  #   If !fstat
  #     CODE = [F:VRA]COD
  #   Endif
      Filter [F:VRA] Where COD=[L]CODE
      Read [F:VRA] First
      If fstat
        GMESSAGE = CODE-":"-mess(23,100,1)
        mkstat = 2 : End
      Else
        Filter [F:VRA]
        Read [F:VRA]VRA0 = GCURLEG;[L]CODE
        If fstat
          Filter [F:VRA] Where COD=[L]CODE
          Read [F:VRA] First
          GMESSAGE = CODE-":"-mess(62,127,1)-":"-[F:VRA]LEG
          mkstat = 2 : End
        Endif
     Endif
     Filter [F:VRA]
  #JASMI - END
   Endif
  Else
    Filter [F:VRA] Where COD=[L]CODE
    Read [F:VRA] First
    If fstat
      GMESSAGE = CODE-":"-mess(23,100,1)
      mkstat = 2 : End
    Else
      Filter [F:VRA]
      Read [F:VRA]VRA0 = GCURLEG;[L]CODE
      If fstat
        Filter [F:VRA] Where COD=[L]CODE
        Read [F:VRA] First
        GMESSAGE = CODE-":"-mess(62,127,1)-":"-[F:VRA]LEG
        mkstat = 2 : End
      Endif
    Endif
    Filter [F:VRA]
  Endif
Endif

End

#JASMI - START
Subprog TUNVRA(COD)
Variable Char    COD()

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONVRA)
 TOKILL = 1
Endif

If clalev([F:VRA])=0 : Local File VARIA [VRA] : Endif

# To update the PRF code after the tunnel order
VCOD = COD

If VCOD="" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
  Filter [VRA] Where LEG=GCURLEG
  Read [F:VRA] First
  Filter [VRA]
  If !fstat : VCOD=[F:VRA]COD : Endif
Else
  Read [VRA]VRA0 = GCURLEG;VCOD
Endif

Call OBJET("VRA",VCOD,GCURLEG) From GOBJET

COD = VCOD

If TOKILL : Kill VCOD : Endif

End

$SEL_TABLE
Case TABLE
  When "SELVRA"
    If clalev ([F:VRA])=0 : Local File VARIA [VRA] : Endif
    Filter [F:VRA]
    OBJET     = "VRA"
    START     = "[F:VRA]COD"
    EXPSTART  = "[F:VRA]COD>='"+VALEUR+"'"
    #JASMI - START
#    OPTIONS = "|"
#    SUPP    = VALEUR
    #JASMI - END
    #Filter based on code legislation
    #JASMI - START
#    If PARAM(1)<>""
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:VRA]LEG="'+PARAM(1)+'" | [F:VRA]LEG="")',"&") From GOBJSUB
#    Endif
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:VRA]LEG="'+GCURLEG+'" | [F:VRA]LEG="")',"&") From GOBJSUB
    #JASMI - END
Endcase
Return
#JASMI - END

