#<AdxTL>@(#)11.0.0.0 $Revision$
#** V7 : Waiting Time Mangement **#
#*********************************#
Raz GPILOBJ
GACTION = "GESVRA"
Call OBJET("VRA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "VERIF_CRE"   : Gosub VERIF
 When "VERIF_MOD"   : Gosub VERIF
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "ANNULE"      : Gosub ANNULE
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "VERF_ANU"    : Gosub VERF_ANU
 When "SEL_LISTE"   : Gosub SEL_LISTE
#** V7 : Waiting Time Mangement
# When "FIN"         : If dim(GTPS)>-1 : Kill GTPS : Endif
 When "FERME"       : Gosub FERME
 When "AS_COD"      : Gosub AS_COD
 When "BS_COD"      : Gosub BS_COD
#JASMI - START
 When "SEL_TABLE"   : Gosub SEL_TABLE
#JASMI - END
Endcase

Return

$SEL_LISTE
Case LISTE
 When "SELTIMVAR"   : Gosub SELTIMVAR
Endcase
Return

###21279
$OUVRE
If clalev ([F:PRF])=0  : Local File PROFIL   [PRF]  : Endif
If clalev ([F:CVR])=0  : Local File CALVAR   [CVR]  : Endif
#** V7 : Waiting Time Mangement
#Global Integer GTPS : GTPS=1
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Return
###

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
# Obsolete since reverse order of main index
## To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONPRF) : Endif
VCOD = CLE1
Return


#Before selection on field COD
#############
$AS_COD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_COD
# To do nothing if the user doesn't select a record

If [F:VRA]COD<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:VRA0]LEG)>=0 : [M:VRA0]LEG=[F:VRA]LEG: Endif
 GCURLEG=[F:VRA]LEG
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:VRA0]LEG)>=0
  GCURLEG=[M:VRA0]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif

#MAPAD - 2016-02-25 - Req 114309 - START
  Call DISPLAY_HIDE() From SUBVRALEG
#MAPAD - 2016-02-25 - Req 114309 - END

Return


$SETBOUT
If REP="" & !GHISTO
 CHMEN = "12"
Else
 CHMEN = ""
Endif
If REP<>"" | !CLECUR | GHISTO=1
 Call VIREBOUT(CHAINE,"8") From GOBJET
Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

$RAZCRE
Raz GCURLEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Gosub INIPRF
[M]TYPINI=1
Gosub GEST_GRISE

#MAPAD - 2016-02-25 - Req 114309 - START
  Call DISPLAY_HIDE() From SUBVRALEG
#MAPAD - 2016-02-25 - Req 114309 - END

Return

$RAZDUP
Gosub INIPRF
Return

$APRES_MODIF
Gosub INIPRF
Return

$INIPRF
If zoncou='LEG'
 If [M:VRA2]FLGEMP=2
  Effzo [M:VRA3]
  Gosub CHARGE_PROFIL
  Affzo[M:VRA3]
 Endif
Endif
Return

$LIENS
GCURLEG = [F:VRA]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

Call LECTEXTRA([M]DES,"VARIA","DES",GCURLEG,[M]COD) From ATEXTRA
Call LECTEXTRA([M]DESSHO,"VARIA","DESSHO",GCURLEG,[M]COD) From ATEXTRA


Gosub GEST_GRISE

#If dim([M]FLGEXS)=1
# Call GRISE_FLGEXS([M]FLGEXS)
#Endif
#Call GRISE_FLGFDR([M]FLGFDR)
#Call GRISE_FLGCPY([M]FLGCPY)
#Call GRISE_FLGFCY([M]FLGFCY)
#Call GRISE_FLGEMP([M]FLGEMP)
#Call GRISE_TYPINI([M]TYPINI)
#If [M]TYPINI=4
# Call GRISE_TYPMAJ([M]TYPMAJ)
# Call GRISE_TYPVAL([M]TYPVAL)
#Endif

Call C_GNRFRC([M:VRA1]GNRFRC)
[M:VRA2]PRNFLG1 = [F:VRA]PRNFLG(0)
[M:VRA2]PRNFLG2 = [F:VRA]PRNFLG(1)
[M:VRA2]PRNFLG3 = [F:VRA]PRNFLG(2)

If [M:VRA2]FLGEMP=2
 Gosub CHARGE_PROFIL
Endif


#MAPAD - 2016-02-25 - Req 114309 - START
Call DISPLAY_HIDE() From SUBVRALEG
#MAPAD - 2016-02-25 - Req 114309 - END

#MIPEA - 2017-08-06- US X3-39538- START
If func AFNC.ACTIV("GLM")
  If !clalev([HRLSTH]) : Local File HRLVESUBHEA [HRLSTH] : Endif

  If [M:VRA1]LVESUBRAT<>0
    Read [HRLSTH]HRLST0 = GCURLEG;[M:VRA1]LVESUBTYP
    [M:VRA1]LVEPAYDES = [F:HRLSTH]LVEPAYDES([M:VRA1]LVESUBRAT-1)
  Endif
Endif
#MIPEA - 2017-08-06- US X3-39538- END

Return

$GEST_GRISE

If dim([M]FLGEXS)=1
 Call GRISE_FLGEXS([M]FLGEXS)
Endif
Call GRISE_FLGFDR([M]FLGFDR)
Call GRISE_FLGCPY([M]FLGCPY)
Call GRISE_FLGFCY([M]FLGFCY)
Call GRISE_FLGEMP([M]FLGEMP)
Call GRISE_TYPINI([M]TYPINI)
If [M]TYPINI=4
 Call GRISE_TYPMAJ([M]TYPMAJ)
 Call GRISE_TYPVAL([M]TYPVAL)
Endif
Return


$VERF_ANU
If clalev([F:LPA])=0 : Local File LIVREPAYE [LPA] : Endif
Local Integer K1
For [LPA]LPA0 Where LEG=GCURLEG
 K1 = find(CODE,[F:LPA]RUBCOD(0..[F:LPA]NBRCOL-1))
 If K1 & [F:LPA]TYPAMT(K1-1)=7
  GMESSAGE = mess(22,115,1)-"LIVREPAYE\"+mess(55,123,1)-":"-[F:LPA]COD+"\"+mess(1,115,1)
  OK = 0 : Break
 Endif
Next
Return

$AP_CHANGE
If clalev([F:LPA])=0 : Local File LIVREPAYE [LPA] : Endif
If clalev([F:BCB])=0  : Local File BCLOB     [BCB] : Endif
If clalev([F:BCB2])=0 : Local File BCLOB     [BCB2]: Endif

# To change translated texts (data type AX3 & AX1) when you change the main code
Call CHGTEXTRA("VARIA","DES",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("VARIA","DESSHO",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA

Local Integer K1 , RW
Call DEBTRANS From GLOCK
Gosub CHG_LPA
If GOK<1 : Return : Endif
Call DEBTRANS From GLOCK
Gosub CHG_BCB
If GOK<1 : Return : Endif
Call CHANGE(2,OCODE,NCODE) From CHGPLAN
Call SETPAR From GENPLAN
Return

$CHG_LPA
GOK = 1
Trbegin [LPA]
 For [LPA]LPA0 Where LEG=GCURLEG
  RW = 0
  For K1=1 To [F:LPA]NBRCOL
   If [F:LPA]TYPAMT(K1-1)=7 & [F:LPA]RUBCOD(K1-1)=OCODE
    [F:LPA]RUBCOD(K1-1) = NCODE
    RW = 1
   Endif
  Next K1
  If RW
   Rewrite [LPA]
   If fstat
    GOK = 0 : Call FSTA("LPA") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK<1 : Goto AB_LPA : Endif
Commit
Return

$AB_LPA
Rollback
Return

$CHG_BCB
GOK = 1
Trbegin [BCB],[BCB2]
 For [BCB]BCB0 Where CODBLB="VARTXT" & IDENT1=OCODE With Stability
  Raz [F:BCB2]
  [F:BCB2]=[F:BCB]
  [F:BCB2]IDENT1=NCODE
  Write [BCB2]
  If fstat
   GOK = 0 : Call FSTA("BCB2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_BCB : Endif
 Delete [BCB] Where CODBLB="VARTXT" & IDENT1=OCODE
Commit
Return

$AB_BCB
Rollback
Return

$VERIF
If [M]TYPINI=4 & [M]TYPMAJ=1
 If (!GTPS & [M:VRA1]TIMCOD="") | (GTPS & [M:VRA1]NATCOD="" & [M:VRA1]TIMCOD="" )
  GMESSAGE = mess(127,10709,1) #Il faut au moins saisir un évènement ou une nature d'activité
  OK=0 : Return
 Endif
Endif
Return

########################################
$CREATION
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("VARIA","DES",CLECUR1,"","VARIA","DES",GCURLEG,[F:VRA]COD) From ATEXTRA
 Call DUPTEXTRA("VARIA","DESSHO",CLECUR1,"","VARIA","DESSHO",GCURLEG,[F:VRA]COD) From ATEXTRA
Endif
Call MAJTEXTRA([M]DES,"VARIA","DES",GCURLEG,[F:VRA]COD) From ATEXTRA
Call MAJTEXTRA([M]DESSHO,"VARIA","DESSHO",GCURLEG,[F:VRA]COD) From ATEXTRA
Return

$INICRE
$INIMOD
[F:VRA]PRNFLG(0) = max(1,[M:VRA2]PRNFLG1)
[F:VRA]PRNFLG(1) = max(1,[M:VRA2]PRNFLG2)
[F:VRA]PRNFLG(2) = max(1,[M:VRA2]PRNFLG3)
If dim([M]FLGEXS)=-1 : [F:VRA]FLGEXS=1 : Elsif [M]FLGEXS=2 : [F:VRA]TYPINI=0 : Endif
Gosub SAUVE_PRF
Return

$APRES_CRE
$APRES_MOD
$AP_ANNULE
Call SETPAR From GENPLAN
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
Call SUPTEXTRA("VARIA","DES",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("VARIA","DESSHO",SUPP,[L]CODE) From ATEXTRA
Return

$SELTIMVAR
#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement
#**If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
#**If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
#**For [ATZ]CODZONE Where CODFIC="TIMRECAP" & CODTYP="CDY"
#** NBTEX += 1
#** TEX(NBTEX) = [F:ATZ]CODZONE
#** Call TEXTE([F:ATZ]NOLONG,TEXTE(NBTEX)) From OBJDIV
#**Next
#*!

If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
For [ATZ]CODZONE Where CODFIC="TIMRECAP" & CODTYP="CDY"
 NBTEX += 1
 TEX(NBTEX) = [F:ATZ]CODZONE
 Call TEXTE([F:ATZ]NOLONG,TEXTE(NBTEX)) From OBJDIV
Next
#LIPET - 2017-05-20 - END
Return

###21279
$CHARGE_PROFIL
nolign = 0
For [PRF]PRF0 Where LEG=GCURLEG
 nolign += 1
 [M:VRA3]PRFCOD(nolign-1) = [F:PRF]PRFCOD
 Call LECTEXTRA([M:VRA3]PRFLIB(nolign-1),"PROFIL","PRFDES",[F:PRF]LEG,[F:PRF]PRFCOD) From ATEXTRA
 Read[CVR]CVR1 = [F:PRF]PRFCOD;[F:PRF]LEG;[M:VRA0]COD
 If !fstat
  [M:VRA3]ENAFLG(nolign-1) = [F:CVR]ENAFLG
 Else
  [M:VRA3]ENAFLG(nolign-1) = 2
 Endif
Next
[M:VRA3]NBRPRF = nolign
Return
###

###21279
$SAUVE_PRF
If [M:VRA3]NBRPRF=0
 Delete [F:CVR]Where COD=[F:VRA]COD & LEG=[F:VRA]LEG
 Return
Endif
For nolign=1 To [M:VRA3]NBRPRF
 Read [CVR]CVR0 = [F:VRA]COD;[M:VRA3]PRFCOD(nolign-1);[F:VRA]LEG
 If !fstat
  [F:CVR]ENAFLG =[M:VRA3]ENAFLG(nolign-1)

#FRLAA  - 2015/04/29 - REQUIREMENT 108197 - US 3561 - START
  If func DIVPAYE.IS_ZA_DEV()>0 #& GCURLEG <> "FRA" & GCURLEG <> "POR"
    [F:CVR]FLGEMP =[M:VRA2]FLGEMP
    [F:CVR]PAGEMP =[M:VRA2]PAGEMP
    [F:CVR]DES =[M:VRA0]DES
#JASMI - 2016-07-22 - START
#    [F:CVR]FLGEXS =[M:VRA1]FLGEXS
    If dim([M:VRA1]FLGEXS)=1 : [F:CVR]FLGEXS =[M:VRA1]FLGEXS : Endif
#JASMI - 2016-07-22 - END
    [F:CVR]FLGRET =[M:VRA2]FLGRET
  Endif
  #FRLAA  - 2015/04/29 - REQUIREMENT 108197 - US 3561 - END

  Rewrite [CVR]
  If fstat : GOK = 0 : Call FSTA("CVR") From GLOCK : Break : Endif
 Else
  Raz[F:CVR]
  [F:CVR]COD=[F:VRA]COD
  [F:CVR]PRFCOD=[M:VRA3]PRFCOD(nolign-1)
  [F:CVR]ENAFLG =[M:VRA3]ENAFLG(nolign-1)
  [F:CVR]LEG=[F:VRA]LEG

 #FRLAA  - 2015/04/29 - REQUIREMENT 108197 - US 3561 - START
 # If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
  If func DIVPAYE.IS_ZA_DEV ()>0 #& GCURLEG <> "FRA" & GCURLEG <> "POR"
    [F:CVR]FLGEMP =[M:VRA2]FLGEMP
    [F:CVR]PAGEMP =[M:VRA2]PAGEMP
    [F:CVR]DES =[M:VRA0]DES
#JASMI - 2016-07-22 - START
#    [F:CVR]FLGEXS =[M:VRA1]FLGEXS
    If dim([M:VRA1]FLGEXS)=1 : [F:CVR]FLGEXS =[M:VRA1]FLGEXS : Endif
#JASMI - 2016-07-22 - END
    [F:CVR]FLGRET =[M:VRA2]FLGRET
  Endif
  #FRLAA  - 2015/04/29 - REQUIREMENT 108197 - US 3561 - END


  Write [CVR]
  If fstat : GOK = 0 : Call FSTA("CVR") From GLOCK : Break : Endif
 Endif
Next
Return
###

########################################
Subprog C_FLGFDR(VALEUR)
Variable Integer VALEUR
Call GRISE_FLGFDR(VALEUR)
End

Subprog GRISE_FLGFDR(VALEUR)
Value Integer VALEUR
If VALEUR=1
 Effzo [M:VRA2]PAGFDR,ROWFDR
 Grizo [M:VRA2]PAGFDR,ROWFDR
Else
 Actzo [M:VRA2]PAGFDR,ROWFDR
Endif
End

Subprog AS_PAGFDR(VALEUR)
Variable Char VALEUR()
If [M]FLGFDR<>2 : mkstat = 1 : End : Endif
End

Subprog AS_ROWFDR(VALEUR)
Variable Decimal VALEUR
If [M]FLGFDR<>2 : mkstat = 1 : End : Endif
End

Subprog C_FLGCPY(VALEUR)
Variable Integer VALEUR
Call GRISE_FLGCPY(VALEUR)
End

Subprog GRISE_FLGCPY(VALEUR)
Value Integer VALEUR
If VALEUR=1
 Effzo [M:VRA2]PAGCPY,ROWCPY
 Grizo [M:VRA2]PAGCPY,ROWCPY
Else
 Actzo [M:VRA2]PAGCPY,ROWCPY
Endif
End

Subprog AS_PAGCPY(VALEUR)
Variable Char VALEUR()
If [M]FLGCPY<>2 : mkstat = 1 : End : Endif
End

Subprog AS_ROWCPY(VALEUR)
Variable Decimal VALEUR
If [M]FLGCPY<>2 : mkstat = 1 : End : Endif
End

Subprog C_FLGFCY(VALEUR)
Variable Integer VALEUR
Call GRISE_FLGFCY(VALEUR)
End

Subprog GRISE_FLGFCY(VALEUR)
Value Integer VALEUR
If VALEUR=1
 Effzo [M:VRA2]PAGFCY,ROWFCY
 Grizo [M:VRA2]PAGFCY,ROWFCY
Else
 Actzo [M:VRA2]PAGFCY,ROWFCY
Endif
End

Subprog AS_PAGFCY(VALEUR)
Variable Char VALEUR()
If [M]FLGFCY<>2 : mkstat = 1 : End : Endif
End

Subprog AS_ROWFCY(VALEUR)
Variable Decimal VALEUR
If [M]FLGFCY<>2 : mkstat = 1 : End : Endif
End

Subprog C_FLGEMP(VALEUR)
Variable Integer VALEUR
Call GRISE_FLGEMP(VALEUR)
End

###21279
Subprog AM_FLGEMP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Gosub CHARGE_PROFIL
Else
 Raz [M:VRA3]
Endif
Affzo [M:VRA3]
End
###

Subprog GRISE_FLGEMP(VALEUR)
Value Integer VALEUR
If VALEUR<2
 Effzo [M:VRA2]PAGEMP,ROWEMP,PRNFLG3
 Grizo [M:VRA2]PAGEMP,ROWEMP,PRNFLG3
Else
 Actzo [M:VRA2]PAGEMP,ROWEMP,PRNFLG3
Endif
End

Subprog AS_PAGEMP(VALEUR)
Variable Char VALEUR()
If [M]FLGEMP<>2 : mkstat = 1 : End : Endif
End

Subprog AS_ROWEMP(VALEUR)
Variable Decimal VALEUR
If [M]FLGEMP<>2 : mkstat = 1 : End : Endif
End

###28109
Subprog AS_PRNFLG3(VALEUR)
Variable Integer VALEUR
If [M]FLGEMP<>2 : mkstat = 1 : End : Endif
End

Subprog C_GNRFRC(VALEUR)
Variable Integer VALEUR
If VALEUR=2 or [M]TYPINI=3
 Actzo [M:VRA1]VALSTD
Else
 Effzo [M:VRA1]VALSTD : Grizo [M:VRA1]VALSTD
Endif
End

Subprog AS_VALSTD(VALEUR)
Variable Decimal VALEUR
If [M]GNRFRC<>2 and [M]TYPINI<>3
 mkstat = 1
Endif
End

Subprog C_TYPINI(VALEUR)
Variable Integer VALEUR
If [M:VRA1]TYPINI <> VALEUR
 Call GRISE_TYPINI(VALEUR)
 #56557
 If VALEUR=4 : Call GRISE_TYPMAJ([M:VRA1]TYPMAJ) : Endif
Endif
End

Subprog GRISE_TYPINI(VALEUR)
Value Integer VALEUR
#MIPEA - 2017-08-06- US X3-39538- START
If VALEUR<>4
If func AFNC.ACTIV("GLM")
   Effzo [M:VRA1]TIMCOD,TIMCMT,CMTDET,FORVAR,LVESUBTYP,LVEPAYDES
Else
   Effzo [M:VRA1]TIMCOD,TIMCMT,CMTDET,FORVAR
Endif
 If GTPS : Effzo [M:VRA1]TIMVAR,NATCOD : Endif
 Grizo [M:VRA1]40
Else
 Actzo [M:VRA1]40
 If GTPS
  If [M:VRA1]TIMCOD<>"" & [M:VRA1]NATCOD=""
   Grizo [M:VRA1]NATCOD
   End
  Endif
  If func AFNC.ACTIV("GLM")
    If [M:VRA1]TIMCOD="" & [M:VRA1]NATCOD<>""
       Grizo [M:VRA1]TIMCOD
       Grizo [M:VRA1]LVESUBTYP
       Grizo [M:VRA1]LVEPAYDES
       Actzo [M:VRA1]NATCOD
    Endif
  Else
     If [M:VRA1]TIMCOD="" & [M:VRA1]NATCOD<>""
       Grizo [M:VRA1]TIMCOD
       Actzo [M:VRA1]NATCOD
    Endif
  Endif
 Endif
Endif
#If VALEUR<>4
# Effzo [M:VRA1]TIMCOD,TIMCMT,CMTDET,FORVAR
# If GTPS : Effzo [M:VRA1]TIMVAR,NATCOD : Endif
# Grizo [M:VRA1]40
#Else
# Actzo [M:VRA1]40
# If GTPS
#  If [M:VRA1]TIMCOD<>"" & [M:VRA1]NATCOD=""
#   Grizo [M:VRA1]NATCOD
#   End
#  Endif
#  If [M:VRA1]TIMCOD="" & [M:VRA1]NATCOD<>""
#   Grizo [M:VRA1]TIMCOD
#   Actzo [M:VRA1]NATCOD
#  Endif
# Endif
#Endif
#MIPEA - 2017-08-06- US X3-39538- END
End

Subprog C_TYPMAJ(VALEUR)
Variable Integer VALEUR
#56557
#If [M:VRA1]TYPMAJ <> [F:VRA]TYPMAJ
If [M:VRA1]TYPMAJ <> VALEUR
  Call GRISE_TYPMAJ(VALEUR)
Endif
End

Subprog GRISE_TYPMAJ(VALEUR)
Value Integer VALEUR
#MIPEA - 2017-08-06- US X3-39538- START
If VALEUR=1
If func AFNC.ACTIV("GLM")
 Actzo [M:VRA1]TYPVAL,TIMCOD,TIMCMT,CMTDET,LVESUBTYP,LVEPAYDES
 Effzo [M:VRA1]FORVAR
 Grizo [M:VRA1]FORVAR
Else
 Actzo [M:VRA1]TYPVAL,TIMCOD,TIMCMT,CMTDET
 Effzo [M:VRA1]FORVAR
 Grizo [M:VRA1]FORVAR
Endif
 If GTPS
  Actzo [M:VRA1]DAYTYP
If func AFNC.ACTIV("GLM")
  If [M:VRA1]TIMCOD="" & [M:VRA1]NATCOD<>""
   Actzo [M:VRA1]NATCOD
   Grizo [M:VRA1]TIMCOD
   Grizo [M:VRA1]LVESUBTYP
   Grizo [M:VRA1]LVEPAYDES
  Endif
Else
  If [M:VRA1]TIMCOD="" & [M:VRA1]NATCOD<>""
   Actzo [M:VRA1]NATCOD
   Grizo [M:VRA1]TIMCOD
  Endif
Endif
  Effzo [M:VRA1]TIMVAR
  Grizo [M:VRA1]TIMVAR
 Endif
Elsif VALEUR=2
If func AFNC.ACTIV("GLM")
 Effzo [M:VRA1]TIMCOD,TIMCMT,CMTDET,FORVAR,LVESUBTYP,LVEPAYDES
 Grizo [M:VRA1]TYPVAL,TIMCOD,TIMCMT,CMTDET,FORVAR,LVESUBTYP,LVEPAYDES
Else
 Effzo [M:VRA1]TIMCOD,TIMCMT,CMTDET,FORVAR
 Grizo [M:VRA1]TYPVAL,TIMCOD,TIMCMT,CMTDET,FORVAR
Endif
 If GTPS
  Actzo [M:VRA1]TIMVAR
