 Actzo [M:VRA1]FORVAR
If func AFNC.ACTIV("GLM")
 Effzo [M:VRA1]TIMCOD,TIMCMT,CMTDET,LVESUBTYP,LVEPAYDES
 Grizo [M:VRA1]TYPVAL,TIMCOD,TIMCMT,CMTDET,LVESUBTYP,LVEPAYDES
Else
 Effzo [M:VRA1]TIMCOD,TIMCMT,CMTDET
 Grizo [M:VRA1]TYPVAL,TIMCOD,TIMCMT,CMTDET
Endif
 If GTPS
  Effzo [M:VRA1]NATCOD,TIMVAR
  Grizo [M:VRA1]NATCOD,TIMVAR,DAYTYP
 Endif
Endif
