  Endif
Else
If func AFNC.ACTIV("GLM")
 Actzo [VRA1] TYPINI, GNRFRC, VALSTD, TYPVAL, TIMCOD, FORVAR, TIMCMT, CMTDET, LVESUBTYP, LVEPAYDES
