Subprog B2_RANG(VALEUR)
Variable Decimal VALEUR
If nolign=1
 VALEUR = 10
Else
 VALEUR = 10*int([M]RANG(nolign-2)/10+1)
Endif
[M]RANG(nolign-1) = VALEUR
For I=nolign To [M]NBVRA-1
 [M]RANG(I) = [M]RANG(I-1)+10
Next I
Affzo RANG
End

