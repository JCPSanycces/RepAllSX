#  If dim([M:DIA]LEG)>0
#
#  Endif
#
##  #JOJAC - 2016-03-08 REQ114309 US 62 - START
##  If clalev([VAR1])=0 : Local File VARIA [VAR1] : Endif
  If clalev([VRA0])=0 : Local Mask VRA0 [VRA0] : Endif
  If clalev([VRA1])=0 : Local Mask VRA1 [VRA1] : Endif
  If clalev([VRA2])=0 : Local Mask VRA2 [VRA2] : Endif
### Look [F:VRA]VRA0=VALEUR;[M:VRA0]COD
##  Read [VAR1]VRA0=VALEUR;[M:VRA0]COD
###JOJAC - 2016-03-08 REQ114309 US 62 - END
  If fstat>1
    Effzo [M:VRA1]VRATHM
###JOJAC - 2016-03-08 REQ114309 US 62 - START
###    Effzo [M:VRA2]50
###JOJAC - 2016-03-08 REQ114309 US 62 - END
    [M:VRA2]FLGFDR=1 : Call GRISE_FLGFDR([M:VRA2]FLGFDR)
    [M:VRA2]FLGCPY=1 : Call GRISE_FLGCPY([M:VRA2]FLGCPY)
    [M:VRA2]FLGFCY=1 : Call GRISE_FLGFCY([M:VRA2]FLGFCY)
    [M:VRA2]FLGEMP=1 : Call GRISE_FLGEMP([M:VRA2]FLGEMP)
  Endif
#Endif
#GCURLEG=VALEUR
#delete all lists from screens if we change the legislation
If VALEUR<>GCURLEG
  Look [VRA]VRA0=VALEUR;[M:VRA0]COD
  If fstat>1
    Effzo [M:VRA1]VRATHM
    Effzo [M:VRA2]50
    [M:VRA2]FLGFDR=1 : Call GRISE_FLGFDR([M:VRA2]FLGFDR)
    [M:VRA2]FLGCPY=1 : Call GRISE_FLGCPY([M:VRA2]FLGCPY)
    [M:VRA2]FLGFCY=1 : Call GRISE_FLGFCY([M:VRA2]FLGFCY)
    [M:VRA2]FLGEMP=1 : Call GRISE_FLGEMP([M:VRA2]FLGEMP)
  Endif
Endif
GCURLEG=VALEUR

#MAPAD - 2016-02-25 - Req 114309 - START
Call DISPLAY_HIDE() From SUBVRALEG
#MAPAD - 2016-02-25 - Req 114309 - END

End


