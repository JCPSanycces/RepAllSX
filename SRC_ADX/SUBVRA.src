######################################################################################
Subprog C_LVESUBTYP(VALEUR)
Variable Char    VALEUR()

#MIPEA - 2017-08-09- US X3-39538- START
If clalev([TIM]) = 0      : Local File TIMCOD [TIM] Endif
Filter [TIM] Where [TIM]COD=[M:VRA1]TIMCOD and LEG=GCURLEG
Read [TIM]Last
Filter [TIM]

If ([TIM]LVEENHANCE=2 & ([TIM]CATTIM=3 |[TIM]CATTIM=2))  and [TIM]ENAFLG=2
  Actzo [M:VRA1]LVESUBTYP
  Actzo [M:VRA1]LVEPAYDES
#MIPEA - 2017-08-17- US X3-39538- START
#  If VALEUR="" & [M:VRA1]TIMCOD<>""
#    GMESSAGE = mess(10,123,1)
#    mkstat=2
#  Endif
#MIPEA - 2017-08-17- US X3-39538- END
Else
  Effzo [M:VRA1]LVESUBTYP : Grizo [M:VRA1]LVESUBTYP
  Effzo [M:VRA1]LVEPAYDES : Grizo [M:VRA1]LVEPAYDES
Endif
#MIPEA - 2017-08-09- US X3-39538- END
End

Subprog C_LVEPAYDES(VALEUR)
Variable Char    VALEUR()

If VALEUR="" & [M:VRA1]LVESUBTYP<>""
  GMESSAGE = mess(10,123,1)
  mkstat=2
Endif
#MIPEA - 2017-08-28- US X3-39538- START
If [M:VRA1]LVESUBTYP=""
  Raz VALEUR
Endif
#MIPEA - 2017-08-28- US X3-39538- END

End
######################################################################################

######################################################################################
## Section automatically added (screen VRA1) 08/06/2017 13:01:02 (MIPEA)
######################################################################################
Subprog S_LVEPAYDES(VALEUR)
Variable Char VALEUR
Local Integer NBRATETYP
Local Integer RATETYP
Local Char LIBRATETYP(130)(0..100)
Local Char    TITLE(250) : TITLE = mess(8,11691,1)

If !clalev([HRLSTH]) : Local File HRLVESUBHEA [HRLSTH] : Endif

Filter [F:HRLSTH] Where LEG = GCURLEG & COD = [M:VRA1]LVESUBTYP
Read [HRLSTH] Last

If rowcount([HRLSTH]) = 0
  GERR = 2 : GMESSAGE = mess(99,100,1) #### MIPEA make better message here
Endif

For RT = 0 To dim([F:HRLSTH]LVEPAYDES)-1
  If [F:HRLSTH]LVEPAYDES(RT)="" : Break : Endif
  NBRATETYP+=1
  LIBRATETYP(NBRATETYP) = [F:HRLSTH]LVEPAYDES(RT)
Next

Call SAITEX(NBRATETYP,LIBRATETYP,RATETYP,TITLE) From GESECRAN # Choose rate types from leave sub type setup

If RATETYP>0
  [M:VRA1]LVESUBRAT = RATETYP
  VALEUR = [F:HRLSTH]LVEPAYDES(RATETYP-1)
Else
  VALEUR=""
Endif
Filter [F:HRLSTH]

End
######################################################################################
#MIPEA - 2017-08-06- US X3-39538- END

######################################################################################
## Section automatically added (screen VRA1) 08/28/2017 11:59:37 (SAVAN)
######################################################################################
Subprog AM_LVEPAYDES(VALEUR)
Variable Char    VALEUR()
Local Integer VALIDCHK

#MIPEA - 2017-08-28- US X3-39538- START
If !clalev([HRLSTH]) : Local File HRLVESUBHEA [HRLSTH] : Endif
VALIDCHK=-1
Read [HRLSTH]HRLST0 = GCURLEG;[M:VRA1]LVESUBTYP
For X = 0 To dim([F:HRLSTH]LVEPAYDES)-1
  If VALEUR = [F:HRLSTH]LVEPAYDES(X)
    VALIDCHK=X
    Break
  Endif
Next

If VALIDCHK >= 0
  [M:VRA1]LVESUBRAT=VALIDCHK+1
Else
  GERR=2
  GMESSAGE=mess(23,11691,1)+" - "+[M:VRA1]LVESUBTYP
  mkstat=2
  If !clalev([HRLSTH]) : Local File HRLVESUBHEA [HRLSTH] : Endif
  If [M:VRA1]LVESUBRAT<>0
    Read [HRLSTH]HRLST0 = GCURLEG;[M:VRA1]LVESUBTYP
    [M:VRA1]LVEPAYDES = [F:HRLSTH]LVEPAYDES([M:VRA1]LVESUBRAT-1)
    Raz VALEUR
    VALEUR = [M:VRA1]LVEPAYDES
  Endif
Endif
#MIPEA - 2017-08-28- US X3-39538- END

End


