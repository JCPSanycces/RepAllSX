######################################################################################
## Etiquette ajoutée par le superviseur (écran VRA1) 06/11/2008 12:44:37 (DBA)
######################################################################################
Subprog C_FORVAR(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End

Subprog CONTFRM(FORMULE)
Variable Char FORMULE
Local Integer I , J , T , OK
Local Char    OP2(2) , OP(3) , CODE(80)
FORMULE = vireblc(format$("KT:250X",FORMULE),2)
I = 0
GERR = 0

While I<=len(FORMULE)-1
 OP2 = mid$(FORMULE,I,2)
 T = 0
 If find(OP2,"E_")
  T = 1 : J = I+2 : I += 2 : OP = OP2
 Endif
 If T
  While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  If OP="E_"
   Read [ADI]CODE = 10606;CODE
   If fstat
    GERR = 1 : GMESSAGE = mess(302,197,1) :# Opération INEXISTANTE : Break
   Endif
  Endif
  I += 1
 Else
  I += 1
 Endif
Wend
If GERR
 GMESSAGE = CODE+"\"+GMESSAGE : mkstat = 2
Endif
End


