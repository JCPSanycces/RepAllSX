##########################################################################
## Etiquette ajoutée par le superviseur 24/06/2003 13:38:02 (SR)
##########################################################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Char    LSERF(GLONSER)
Local    Decimal LQTYF
Local Integer NOL : NOL = nolign-1
If VALEUR<>""
   # Alimentation de [M:ALP]
    Call ALI_ALP("MTK3",NOL) From SUBMTKB
   # Détermination no série fin
   Call CTLSORSER("MTK3",NOL,VALEUR,[M:MTK3]USEQTY(NOL),LSERF,LQTYF) From STKSOR
   If LQTYF=0
      Raz VALEUR, [M:MTK3]SERNUMF(NOL)
   Else
      [M:MTK3]SERNUMF(NOL)=LSERF
   Endif
Else
   Raz [M:MTK3]SERNUMF(NOL)
Endif
End




