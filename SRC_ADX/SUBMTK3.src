#<AdxTL>@(#)8.0.0.0 $Revision$
################################################################
# SUBMTK3
#Actions sur champs pour masques MTK3
#                                               sr Décembre 1998
################################################################
$ACTION
Case ACTION
     When "AAPRES_NBMAT" : Gosub AAPRES_NBMAT
     When "AB9_NBMAT"    : Gosub AB9_NBMAT
     When "BB9_NBMAT"    : Gosub BB9_NBMAT
     When "AB6_NBMAT"    : Gosub AB6_NBMAT
     When "BB6_NBMAT"    : Gosub BB6_NBMAT
     When "BB7_NBMAT"    : Gosub BB7_NBMAT
     When "AB8_NBMAT"    : Gosub AB8_NBMAT
     When "AB10_NBMAT"   : Gosub AB10_NBMAT
     When "AB12_NBMAT"   : Gosub AB12_NBMAT
Endcase
Return

################################################################
$AB9_NBMAT
#-- Habilitation Modification mvts stock si on trouve K dans la chaine des boutons autorisés
# hcb 27842
Raz GBIDI2
GFCY=[M:MTK0]MFGFCY
GBIDC2="K" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMESSAGE=mess(2,104,1)
   GOUVSOR=0
   Return
Else
   GOUVSOR = 1
Endif
# CCC (2010-04-28) Bug 54558 : Vérifier que l'OF n'est pas en cours de modif
If func MFGLIB.CHKMFGLOCK([M:MTK3]MFGNUMMA(nolign-1),1)
    Call ERREUR(mess(280,193,1)) From GESECRAN
    GOUVSOR = 0
    Return
Endif
GSAVMFGNUM = [M:MTK3]MFGNUMMA(nolign-1)

Return

$BB9_NBMAT
# Issue 90462 - 2013-06-13 by CCC
#Unlock ="MFG"+[M:MTK3]MFGNUMMA(nolign-1)
Unlock ="MFG"+GSAVMFGNUM

# GH 07/02/2014 bug 94071
If GRELITMTK=1
  mkstat = 4
Endif
Return

$AAPRES_NBMAT
Local Integer LRET, WAUTO
Local Integer I : I = nolign-1
Raz LRET
Raz GOUVSOR
# Si suppression ligne
If find(status,65,68,83) Return Endif
# Si sortie tableau non validante
If adxgtb=1 Return Endif
If [M:MTK3]CUMMATSUI(nolign-1) = 1 : Return : Endif
# Issue 79493 - 2012-02-09 by CCC
#If [M:MTK3]USEQTY(nolign-1) = 0    : Return : Endif
If [M:MTK3]USEQTY(nolign-1) = 0
    Call DELSTOSORW(nolign-1,nolign-1,"MTK3",[M:MTK0]MFGFCY,LRET) From STKSOR
    Return
Endif


Call ALI_ALP("MTK3",I) From SUBMTKB

If [F:MTS]STKFLG = 1 : WAUTO = 1
Else
    If [F:MTS]STOCODMAN = 2 & [M:MTK3]STOCODL(I) = 1 & [M:ALP]QTY <> 0
        WAUTO = 1
    Else
        WAUTO = 2
    Endif
Endif

Call OUVSOR("MTK3",I,[M:MTK3]NBMAT,[M:MTK3]WSTOSEQ(I),WAUTO,LRET) From STKSOR
# Si GOUVSOR = 1, la fenêtre détail va s'ouvrir

# 05.05 demande 30321
If GOUVSOR = 1 : [M:MTK3]WSTODET(I) = 2
Elsif [M:MTK3]USEQTY(I) <> 0
    Call AV_MATITMREF([M:MTK3]MATITMREF(I))
    Affzo [M:MTK3]MATITMREF(I)
Endif
Return

##############################################
# 05.05 demande 30321
$AB6_NBMAT
#------------------------------------------------------#
# Avant détail stock                                   #
#------------------------------------------------------#
Local Integer WNOLIGN : WNOLIGN = nolign
Return

##############################################
# 05.05 demande 30321
$BB6_NBMAT
#------------------------------------------------------#
# Après détail stock                                   #
#------------------------------------------------------#
# on revient de la fenêtre déatil donc à priori c'est ok
nolign = WNOLIGN
[M:MTK3]WSTODET(nolign-1) = 2
Call AV_MATITMREF([M:MTK3]MATITMREF(nolign-1))
Affzo [M:MTK3]MATITMREF(nolign-1)
Return

##############################################
$BB7_NBMAT
If mkstat=4 & GREP=""
   Trbegin [MKM]
   Call DEBTRANS From GLOCK
   Read [F:MKM]MKM0 = [M:MTK0]MFGTRKNUM;[M:MTK3]MATTRKLIN(nolign-1)
   If fstat : Raz [F:MKM] : Return : Endif
   Gosub UPDATE_TEXTE
   If GOK = 1 : Commit : Else : Rollback : Endif
   Raz mkstat
Endif

Return

########################################################################
$UPDATE_TEXTE
Local Integer WRET
# on a viré le texte en modif
If [M:MTK3]MKMTEX(nolign-1) = "" & [F:MKM]MKMTEX <> "" & left$([F:MKM]MKMTEX,3) = "MKM"
   Call SUP_CLOB([F:MKM]MKMTEX,WRET) From TRTX3TEX
Else
    If    [M:MTK3]MKMTEX(nolign-1) <> ""
          [F:MKM]MKMTEX  = [M:MTK3]MKMTEX(nolign-1)
           If left$([F:MKM]MKMTEX,3)="MKM"
                  Call CRE_CLOB([F:MKM]MKMTEX,GOK) From TRTX3TEX
                  If GOK<1 Return Endif
           Elsif  left$([F:MKM]MKMTEX,3) <> "BOD"
                  Call DUP_CLOB("MKM",[F:MKM]MKMTEX,GOK) From TRTX3TEX
                  If GOK<1 Return Endif
           Endif
    Endif
Endif
Readlock [F:MKM]MKM0 = [M:MTK0]MFGTRKNUM;[M:MTK3]MATTRKLIN(nolign-1)
If fstat=1  GOK=-1 : GLOCK="$MFGMATTRK"-[M:MTK0]MFGTRKNUM - num$([M:MTK3]MATTRKLIN(nolign-1)) :  Return
Elsif fstat GOK=0  : Call RSTA("MKM",[M:MTK0]MFGTRKNUM) From GLOCK :  Return
Endif
[F:MKM]MKMTEX = [M:MTK3]MKMTEX(nolign-1)
Rewrite [F:MKM]
If fstat
   GOK = 0 : Call FSTA("MKM") From GLOCK :  Return
Endif

Return


##############################################
$AB8_NBMAT
[M:MTK3]FLT  = "1=1"
Return

##############################################
$AB10_NBMAT
[M:MTK3]WMATTRKLIN = [M:MTK3]MATTRKLIN(nolign-1)
[M:MTK3]FLT = "[F:STJ]VCRLIN = [M:MTK3]WMATTRKLIN"
Return


##############################################
$AB12_NBMAT
Local Integer  NBTBO
Local Char     WCLE1(15)
Local Char     WCLE2(15)
#
If clalev([F:TBO]) <= 0 : Local File TABBOMALT [TBO] : Endif

WCLE1=[M:MTK3]BOMNUM(nolign-1)
#   sélectionner les alt. de nomenclature compatibles avec site de prod
Filter [TBO] Where ([F:TBO]FCY=[M:MTK0]MFGFCY | [F:TBO]FCY="") & [F:TBO]MFGUSE=2 & [F:TBO]BOMALTTYP=2
For [TBO]TBO0
     GBOMALT (NBTBO) = [F:TBO]BOMALT
     NBTBO += 1
Next
#
Filter [TBO]
#  FILTRE sur article parent
Local File BOM [BOH] Where find(BOMALT, GBOMALT) & ITMREF=WCLE1 & BOMALTTYP = 2
#
WCLE2 = num$([M:MTK3]BOMALT(nolign-1))
GFONBOD="BOMP"
GDATEREF=[M:MTK0]MFGTRKDAT
Return

#-------------------- Action sur écran MTK3 -------------------------------#
########################################
Subprog AV_FILTMAT(VALEUR)
Variable Integer VALEUR
If [M:MTK3]NBMAT = 0 : VALEUR = [F:MTS]FILTDEF : Endif
End

########################################
Subprog AP_FILTMAT(VALEUR)
Variable Integer VALEUR
Local Integer WVALEUR,WRET
Local Char WMFGNUM(GLONVCR)
WMFGNUM = [M:MTK0]MFGNUM
WVALEUR = VALEUR
If (GREP <> "C" | [M:MTK3]NBMAT <> 0) & VALEUR = [M:MTK3]FILTMAT : End : Endif
#Chargement de l'écran Mat selon sélection
Effzo [M:MTK3]15
Call DELSTOSORW(-1,0,"MTK3",[M:MTK0]MFGFCY,WRET) From STKSOR
Call CHARG_MAT([M:MTK0]MFGNUM,VALEUR,0,0) From SUBMTKB
[M:MTK3]FILTMAT = WVALEUR    # llc 10.00
Affzo [M:MTK3]
If [M:MTK3]NBMAT = 0 : Call MESSAGE(mess(99,100,1)) From GESECRAN
Endif
End

########################################
Subprog AS_QTESUIVMAT(VALEUR)
Variable Decimal VALEUR
If ([F:MTS]OPETRKFLG = 2 & [M:MTK0]OPETRKFLG = 2) | ([F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2)
    End
Endif
If [F:MFG]TRKFIRST = [0/0/0] & VALEUR = 0
    If [M:MTK3]FILTMAT <> 3
       Case [F:MFG]ITMLINNBR
            When 1       : VALEUR = [F:MFI]RMNEXTQTY / [F:MFI]UOMSTUCOE
                           Call QTEARR(VALEUR,[F:MFI]UOM) From TRTDIV
            When Default : VALEUR = [F:MFG]RMNEXTQTY
        Endcase
    Endif
Endif
End

########################################
Subprog AM_QTESUIVMAT(VALEUR)
Variable Decimal VALEUR
Local Decimal WCOEFF
If VALEUR <> 0
    Case [F:MFG]ITMLINNBR
        When 1       : # Issue 78551 - 2011-12-12 by CCC : [MFI] peut-être positionné sur le sous-produit
                       Filter [MFI] Where MFGNUM=[M:MTK0]MFGNUM
                       Read [MFI]MFI0 First
                       Filter [MFI]
                       WCOEFF = VALEUR / [F:MFI]UOMEXTQTY
        When Default : WCOEFF = VALEUR / [F:MFG]EXTQTY
    Endcase
# 04.02 demande 13793
Else
    WCOEFF = 0
Endif
    # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
    # Ce sont les quantités qui sont arrondies
    ## 01.02 demande 12597
    ## 02.03 demande 17092
    #WCOEFF = arr(WCOEFF,0.00000001)
    Gosub REAJUST_MAT From SUBMTKB
    Affzo [M:MTK3]15
# 04.02 demande 13793
#Endif
End

########################################
Subprog AV_UOM(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog C_NBMAT
Local Integer WRET
# pour bug moteur
If [M:MTK3]NBMAT > 0
  If [M:MTK3]MATITMREF([M:MTK3]NBMAT-1) = ""
    status=65 : nolign=[M:MTK3]NBMAT
    Dela [M:MTK3]NBMAT-1,1,[M:MTK3]NBMAT-1 [M:MTK3]NBMAT : [M:MTK3]NBMAT-=1
  Endif
Endif
GMODIF = 2
#si matière exclue on ne peut pas la suivre
If status = 75
   If [M:MTK3]MODIFLG(nolign-1) = 1 : GMESSAGE = mess(83,193,1)
      mkstat = 1
      GMODIF = 1
      End
   Endif
Endif
If status =  82 & GREP <> "C"
                  NOL=nolign-1                    # Reprise
                  GMODIF=1    # pour bug moteur
                  mkstat=2
Endif
End


########################################
Subprog B3_NBMAT
Local Char WMESS(80)
Local Char WVCRNUM(GLONVCR) : WVCRNUM = [M:MTK3]MFGNUMMA(nolign-1)
WMESS = ""
If !GIMPORT Inftxt WMESS At 2 : Endif

Call OBJET("MFG",WVCRNUM,"") From GOBJET
#----- Relecture transaction de saisie -----#
Read [MTS] MTS0=2;GMTSNUM : If fstat Raz [F:MTS] : Endif
Local Char WMESS(80)
WMESS = mess(77,190,1)+GMTSNUM
If !GIMPORT Inftxt WMESS At 2 : Endif
End

########################################
Subprog B4_NBMAT
#Activation,suppression matière
Local Integer WRET,WLIG, OK
Local Integer NOL : NOL = nolign-1
# si ligne non ajoutée au suivi on la désactive sinon on le supprime
If [M:MTK3]ADDTRK(NOL) <> 2
    Case[M:MTK3]MODIFLG(NOL)
        When 0 : [M:MTK3]USEQTY(NOL)  = 0
                 [M:MTK3]MODIFLG(NOL) = 1
                 Call DELSTOSORW(NOL,NOL,"MTK3",[M:MTK0]MFGFCY,WRET) From STKSOR
                 If WRET<>0 mkstat=2 : End Endif
        When 1 : [M:MTK3]USEQTY(NOL)  = [M:MTK3]WANCQTY(NOL)
                 [M:MTK3]MODIFLG(NOL) = 0
                 WLIG = NOL
                 Gosub TRT_STOCKLIGNE From SUBMTKB
    Endcase
Else
    Dela NOL,1,[M:MTK3]NBMAT-1 [M:MTK3]NBMAT : [M:MTK3]NBMAT-=1
    Call DELSTOSORW(NOL,NOL,"MTK3",[M:MTK0]MFGFCY,WRET) From STKSOR
Endif
Affzo [M:MTK3]15
#Call AS_NBMAT
mkstat = 4
End


########################################
Subprog AS_USEQTY(VALEUR)
Variable Decimal VALEUR
Local Integer NOL : NOL =nolign-1
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran MTK3) 20/10/2011 11:20:06 (CCC)
######################################################################################
Subprog C_USEQTY(VALEUR)
Variable Decimal VALEUR
Local Integer LRET, LTYPLOC, NOL
Local Decimal LDIS
If VALEUR=0
    End
Endif
NOL = nolign-1
If [M:MTK3]NEGSTO(NOL)<>2
    # Issue 78072 - 2011-11-28 by CCC : ITV nécessaire pour STODISTOT
    If [F:ITV]ITMREF<>[M:MTK3]MATITMREF(NOL) | [F:ITV]STOFCY<>[M:MTK0]MFGFCY
        Read [ITV]ITV0=[M:MTK3]MATITMREF(NOL);[M:MTK0]MFGFCY
    Endif
    Call LECSRU([M:MTK0]MFGFCY,[M:MTK3]TCLCOD(NOL),6,[F:MTS]TRSCODS,"",LRET) From STKLIB
    If LRET = 1
        LDIS = 0
    Else
        LTYPLOC = 0
        If [M:MTK3]CPLWST(NOL) <> ""
        If [F:MWS]WST <> [M:MTK3]CPLWST(NOL) | [F:MWS]WCRFCY <> [M:MTK0]MFGFCY
             Read [F:MWS]WST0 = [M:MTK3]CPLWST(NOL);[M:MTK0]MFGFCY
             If fstat : Raz [F:MWS] : Endif
         Endif
         If [F:MWS]WSTTYP = 3
            LTYPLOC = 4
         Endif
        Endif
        Call STODISTOT("",LTYPLOC,[F:SRU]AUZSTA,"",LDIS) From STKLIB
        # Issue 78334 - 2011-11-30 by CCC
        #LDIS+=[M:MTK3]ALLQTY(NOL)
        LDIS+=[M:MTK3]MFMALLQTY(NOL)
        If VALEUR > LDIS
              Call ERREUR(mess(86,193,1)) From GESECRAN
              Raz GMESSAGE
              mkstat = 1
              End
        Endif
    Endif
Endif
End

########################################
Subprog AM_USEQTY(VALEUR)
Variable Decimal VALEUR
Local Integer LOK,NOL,WRET,STA, I
# 08.02 USEQTY est la quantité en unité active (si matière titrée)
# 10.01 demande 11203
Local Decimal WUSEQTY,LDIS, WTOTUSEQTY
Raz LOK,WRET,LDIS,STA, I

NOL = nolign-1

# CCC (2009-12-07) Bug 60537 : La mise à jour de SOW se fait en fin de ligne
#If VALEUR = 0
#   Call DELSTOSORW(NOL,NOL,"MTK3",[M:MTK0]MFGFCY,WRET) From STKSOR
#   End
#Endif

# 10.01 la qté consommée à utiliser est la somme de ce qui a déjà été
# consommé et de ce qui va l'être demande 11203
WTOTUSEQTY = VALEUR + [M:MTK3]MFMUSEQTY(NOL)
Call CONT_SOLDE_MAT([M:MTK0]MFGFCY,[M:MTK3]MATITMREF(NOL),WTOTUSEQTY,[M:MTK3]MFMEXTQTY(NOL),WRET) From MFGLIBM
If WRET = 0 : [M:MTK3]CLEFLG(NOL) = 1
Else        : [M:MTK3]CLEFLG(NOL) = 2
Endif
Affzo [M:MTK3]CLEFLG(NOL)

End


########################################
Subprog AM_MATITMREF(VALEUR)
Variable Char    VALEUR()
If [F:ITF]ITMREF <> VALEUR | [F:ITF]STOFCY <> [M:MTK0]MFGFCY
    Read [F:ITF]ITF0 = VALEUR;[M:MTK0]MFGFCY
    If fstat : Call ERREUR(mess(2,196,1)) From GESECRAN
       mkstat = 1
       End
    Endif
Endif
[M:MTK3]STU(nolign-1)     = [F:ITM]STU
#[M:MTK3]ITMDES1(nolign-1) = [F:ITM]ITMDES1
# 119189 mm 11.2016
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,VALEUR,[M:MTK3]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:MTK3]STOCODL(nolign-1) = [F:ITF]STOCOD

Call INIZONSOR("MTK3",VALEUR,[M:MTK0]MFGFCY,nolign-1,6,[F:MTS]TRSCODS,"") From STKECR
# Issue 107513/8 - 2015-08-17 by JUSYN : Versions from components / material of a versioned product aren't allowed to be changed.
# Repeated here because of reset in INIZONSOR
If dim([M:MTK3]ECCVALMAJ(nolign-1))>0
    # versioned
    Local Integer LRET
    Affzo [M:MTK3]ECCVALMAJ(nolign-1)
    Affzo [M:MTK3]ECCVALMIN(nolign-1)

    LRET = func ECCLIB.NBRCPN([M:MTK3]BOMNUM(nolign-1))
    If LRET > 0
        Grizo [M:MTK3]ECCVALMAJ(nolign-1)
        Grizo [M:MTK3]ECCVALMIN(nolign-1)
    Else
        Actzo [M:MTK3]ECCVALMAJ(nolign-1)
        Actzo [M:MTK3]ECCVALMIN(nolign-1)
    Endif
Endif

End

########################################
Subprog C_OPENUM(VALEUR)
Variable Decimal VALEUR
#Contrôle opération si OF n'est pas matières seules demande 9507
If VALEUR <> 0 & [F:MFG]MFGMOD <> 2
   Filter [F:MFO]Where MFGNUM = [M:MTK0]MFGNUM & OPENUM = VALEUR
   Read [F:MFO]MFO0 First
   If fstat : GMESSAGE = mess(23,100,1)
              mkstat = 1
              Filter [F:MFO]
              End
   Endif
   Filter [F:MFO]
Endif
Filter [F:MFM] Where MFGNUM = [M:MTK0]MFGNUM & ITMREF = [M:MTK3]MATITMREF(nolign-1) &
&                            BOMOPE = VALEUR & CPNTYP <> 5
Read [F:MFM]MFM3 First                        # 10.02 Performances
If !fstat
   If [F:MFM]MATSTA = 4 : GMESSAGE = mess(83,193,1) : Filter [F:MFM] : End : Endif
   If [F:ITF]CUNFLG = 2 & [F:MFM]ALLSTA > 3
       Gosub REC_LOC From SUBMTKB
       If WCUNFLG = 2 : GMESSAGE = mess(185,199,1) : mkstat = 1 : End : Endif
   Endif
Endif
If fstat : Raz [F:MFM]
           [M:MTK3]MFMITMREF(nolign-1) = ""
Else     : [M:MTK3]MFMITMREF(nolign-1) = [F:MFM]ITMREF
Endif
Filter [F:MFM]
End

########################################
# 10.01 demande 11332 Tester la valeur de MATSTA dans le filtre surles matières
Subprog AP_OPENUM(VALEUR)
Variable Decimal VALEUR
# 05.07 Demande 41218
Local Integer I,J,OK,LOK
Local Char    WCCE(15)#If [M:MTK3]WINDIC(nolign-1) = 1 : End : Endif
If [M:MTK3]MFMITMREF(nolign-1) = ""
  # Issue 110979/1 - 2016-03-24 by ALSHE : Warning message when released product is versioned
  If [F:MFI]MFGNUM<>[M:MTK0]MFGNUM
    Read [F:MFI]MFI0(1) = [M:MTK0]MFGNUM
    [G:MFI]currlen=0
  Endif
  If [F:MFI]ECCVALMAJ <> ""
    OK=1
    Call AVERTIR(mess(347,193,1),OK) From GESECRAN
    If OK = 1 : mkstat = 1 : End : Endif # Cancel
  Else
    OK = 1
    Call AVERTIR(mess(117,190,1),OK) From GESECRAN
    If OK = 1 : mkstat = 1 : End : Endif # Cancel
  Endif
Endif
Read [F:ITM]ITM0 = [M:MTK3]MATITMREF(nolign-1)
If !fstat
   #[M:MTK3]ITMDES1(nolign-1)   = [F:ITM]ITMDES1
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MTK3]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
   [M:MTK3]SERMGTCOD(nolign-1) = [F:ITM]SERMGTCOD
#   [M:MTK3]STOMGTCOD(nolign-1) = [F:ITM]STOMGTCOD
   [M:MTK3]NEGSTO(nolign-1)    = [F:ITM]NEGSTO
   [M:MTK3]TCLCOD(nolign-1)    = [F:ITM]TCLCOD
Endif
Read [F:ITF]ITF0 = [M:MTK3]MATITMREF(nolign-1);[M:MTK0]MFGFCY
If !fstat
   [M:MTK3]STOCODL(nolign-1)    = [F:ITF]STOCOD
   [M:MTK3]STOMGTCOD(nolign-1)  = [F:ITF]STOMGTCOD

Endif
[M:MTK3]ADDTRK(nolign-1) = 2
If [M:MTK3]MFMITMREF(nolign-1) = ""
    If dim([M:MTK3]LOC)>0
       Call STKINIEMPS([M:MTK3]LOC(nolign-1)) From STKLOC
    Endif
    If [M:MTK3]MATTRKLIN(nolign-1) = 0
       [M:MTK3]MATTRKLIN(nolign-1) = [M:MTK3]NBMAT+1
    Endif
    # chargement des sections analytiques
    # 05.07 Demande 41218
    For J = 1 To GOPTCANA    :# (on ne vient pas d'une boucle affectant déjà J)
#       Call INISEC(WCCE,"MKM",num$(J)) From SUBCDE
        Call INISEC(WCCE,"MKM",J) From TRTX3CPT
        Assign "[M:MTK3]CCE"+num$(J)+"(nolign-1)" With WCCE
    Next
    End
Endif
[M:MTK3]          = [F:MFM]
If [M:MTK3]MATTRKLIN(nolign-1) = 0
    [M:MTK3]MATTRKLIN(nolign-1) = [M:MTK3]NBMAT+1
Endif
If dim([M:MTK3]LOT) > 0 :[M:MTK3]LOT(nolign-1)   = vireblc([F:MFM]LOT,1) : Endif
If dim([M:MTK3]LOC) > 0 :[M:MTK3]LOC(nolign-1)   = vireblc([F:MFM]LOC,1) : Endif
[M:MTK3]STA(nolign-1)   = "A"
[M:MTK3]USEQTY(nolign-1) = 0
If [F:MFM]MFGLIN <> 0
   Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
   If fstat : Raz [F:MFI] : Endif
Else
   Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
   Read [F:MFI]MFI0 First
   If fstat : Raz [F:MFI] : Endif
   Filter [F:MFI]
Endif
[M:MTK3]BOMNUM(nolign-1) = [F:MFI]ITMREF
Case [F:MTS]CONSMAT
     When 1       : [M:MTK3]RETQTY(nolign-1) = [F:MFM]RETQTY
     When Default : [M:MTK3]RETQTY(nolign-1) = [F:MFM]RETQTY - [F:MFM]USEQTY
                    # 76038
                    If [M:MTK3]RETQTY(nolign-1) < 0 : [M:MTK3]RETQTY(nolign-1) = 0 : Endif
Endcase
Filter [F:MFM]
#Si suivi sur OF et pas matières seules on récupère les postes demande 9507
If  [F:MFG]MFGMOD <> 2
    [M:MTK3]CPLWST(nolign-1)   = [F:MFO]EXTWST
    Read [F:MWS]WST0 = [F:MFO]EXTWST;[M:MTK0]MFGFCY
    #[M:MTK3]WSTSHO(nolign-1)   = [F:MWS]WSTSHO : # GH 28/02/2014 bug 95952
    Call LECTEXTRA([M:MTK3]WSTSHO(nolign-1),"WORKSTATIO","WSTSHOAXX",[F:MFO]EXTWST,[M:MTK0]MFGFCY) From ATEXTRA
    [M:MTK3]OPENUM(nolign-1)   = VALEUR
    Affzo [M:MTK3]15
Endif
# 05.05 demande 30321
[M:MTK3]WSTODET(nolign-1) = 1
If dim([M:MTK3]LOC)>0
   Call STKINIEMPS([M:MTK3]LOC(nolign-1)) From STKLOC
Endif
# chargement des sections analytiques
## 05.07 Demande 41218
## Dans le cas d'un suivi d'une matière non prévue, le buffer [MFM] est vide
For J = 1 To GOPTCANA    :# (on ne vient pas d'une boucle affectant déjà J)
    Call INISEC(WCCE,"MKM",J) From TRTX3CPT
    Assign "[M:MTK3]CCE"+num$(J)+"(nolign-1)" With WCCE
#  If evalue("[F:MFM]CCE"+num$(j)) <> ""
#      Assign "[M:MTK3]CCE"+num$(J)+"(nolign-1)" With evalue("[F:MFM]CCE"+num$(J))
#  Else
#      Call INISEC(WCCE,"MKM",num$(J)) From SUBCDE
#      Assign "[M:MTK3]CCE"+num$(J)+"(nolign-1)" With WCCE
#  Endif
Next

End


########################################
Subprog AM_WOPE1(VALEUR)
Variable Decimal VALEUR
Effzo [M:MTK3]15
End

########################################
Subprog AM_WOPE2(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M:MTK3]WOPE1
   Call ERREUR(mess(044,199,1)) From GESECRAN
   mkstat = 1
   End
Endif
Effzo [M:MTK3]15
End

########################################
Subprog AM_STOCOD(VALEUR)
Variable Integer VALEUR
Raz [M:MTK3]NBMAT
End

########################################
Subprog C_MATITMREF(VALEUR)
Variable Char    VALEUR()
# 107513
#Local Char     WFCY(GLONFCY) : WFCY = [M:MTK0]MFGFCY
#
#
##    Lecture article et article/site
#Read [ITM]ITM0=VALEUR
#If fstat
#  GMESSAGE = mess(134,100,1)
#  mkstat = 2
#  End
#Endif
##    Lecture article/site
#Read [ITF]ITF0=VALEUR;WFCY
# If fstat
#  GMESSAGE = mess(45,193,1)
#  mkstat = 2
#  End
#Endif
#
#Call CONTMATITM(WFCY, 1) From MFGLIB
Call CONTMATITM(VALEUR, [M:MTK0]MFGFCY, "MKM", GERR, GMESSAGE) From MFGLIB
If find(GERR,1,4)
    GERR = 1
    mkstat=2
    End
Endif

[M:MTK3]SERMGTCOD(nolign-1) = [F:ITM]SERMGTCOD
End


########################################
Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
Read [F:MFG]MFG0 = VALEUR
If fstat GMESSAGE = mess(23,100,1)
    mkstat = 1
    End
Else
    #L'OF doit être complet
    If [F:MFG]TYPMOD = 1    : GMESSAGE = mess(51,190,1) : mkstat = 1 : End : Endif
    #Le mode de lancement ne doit pas être "opérations seules"
    If [F:MFG]MFGMOD > 2    : GMESSAGE = mess(140,193,1) : mkstat = 1 : End : Endif
    #L'OF doit être ferme
    If [F:MFG]MFGSTA <> 1   : GMESSAGE = mess(19,190,1) : mkstat = 1 : End : Endif
    #Selon paramètre général l'OF doit être alloué complètement
    If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
         GMESSAGE = mess(18,190,1)
         mkstat = 1
         End
    Endif
    #Selon paramètre général, l'OF doit être édité
    If  [F:MFG]MFGTRKFLG < 3 & GDOSFAB = 2 : GMESSAGE = mess(20,190,1) : mkstat = 1 : End : Endif
    mkstat = 0
    # boucle d'analyse des matières bloquantes si rupture
    For [MFM] Where MFGNUM = [F:MFG]MFGNUM
        If [F:MFM]SHTQTY <> 0
           Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
           If !fstat & [F:ITF]MFGSHTCOD = 1
               GMESSAGE = mess(105,193,1)+" ("+[F:MFM]ITMREF+")"
               mkstat = 1
               Break
           Endif
        Endif
    Next
    If mkstat = 1 : End : Endif
Endif
End


##########################################################################
## Etiquette ajoutée par le superviseur 23/06/2003 13:44:56 (SR)
##########################################################################
Subprog IB_NBMAT
Local Integer NOL : NOL = nolign-1


# Pour autoriser la saisie du détail sortie
GOUVSOR = 1

If [M:MTK0]MFGNUM = "" & [M:MTK3]MATTYP(NOL) = 1
    Read [F:MFG]MFG0 = [M:MTK3]MFGNUMMA(NOL)
    If fstat : Raz [F:MFG] : Endif
Endif

If [M:MTK3]MATITMREF(NOL) = ""
   Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8, GBOUT9, GBOUT10, GBOUT12
   End
Endif

# FQ 60502 GA 11/2009 empêche l'accès au détail stock ???? à revérifier ???
#If GUNVERROU=0
#   Raz GBOUT6, GBOUT9
#Endif


# désactiver le bouton détail stock selon les cas
If GREP <> "C" | [M:MTK3]CUMMATSUI(NOL) = 1  | [M:MTK3]MODIFLG(NOL) = 1
    Raz GBOUT6
Endif

# Issue 83491 - 2012-08-21 by CCC
Call STKCTRIPT( [M:MTK0]MFGTRKDAT,[M:MTK0]MFGFCY, "1") From STKLIB
If find(GERR,1,2)
    Raz GBOUT6, GBOUT9
    Raz GERR, GMESSAGE, mkstat
Endif

If GREP = "C" : Raz GBOUT10, GBOUT12 : Endif

If [M:MTK3]MFMITMREF(NOL) = "" | find([M:MTK3]MATTYP(NOL),2,4)
        Raz GBOUT1, GBOUT2
Endif
# FQ 42748 GA 09/2007 laisser accès par tunnel à l'OF même si on est sur une matière non prévue
If [M:MTK3]MFGNUMMA(NOL) = "" | find([M:MTK3]MATTYP(NOL),2,4)
        Raz GBOUT3
Endif

If [M:MTK3]CUMMATSUI(NOL) = 1 : Raz GBOUT2  : Endif

#  Bouton Ne pas suivre et réactiver
If GREP = "C"
   Case [M:MTK3]MODIFLG(NOL)
         When 0 : GBOUT4 = mess(415,198,1)
         When 1 : GBOUT4 = mess(185,198,1)
   Endcase
Else
    Raz GBOUT4
Endif

#Bouton modif mvts de stock
Case [M:MTK3]MATTYP(NOL)
    When 1,2 :
        If [M:MTK3]MATITMREF(NOL) = "" | GREP = "C"  | [M:MTK3]USEQTY(NOL) = 0 |
&          ([M:MTK3]MATTYP(NOL) = 1 & [F:MFG]MFGSTA = 4)
            Raz GBOUT9, GBOUT10
        Endif
        If [M:MTK3]MATTYP(NOL) = 1 : Raz GBOUT12 : Endif
    When 3,4 :
        Raz GBOUT9
        If [M:MTK3]MATTYP(NOL) = 3 : Raz GBOUT12 : Endif
Endcase

#  Texte
If [M:MTK3]MATITMREF(NOL) <> "" : GBOUT7 = mess(38,198,1)
Else                            : Raz GBOUT7
Endif

#
Gosub CTR_WEIGHING From SUBMTKA            #47883 47884
If WPESE = "E"                             #47883 47884
   Raz GBOUT9                              #47883 47884
Endif                                      #47883 47884


If [F:ITM]ITMREF <> [M:MTK3]MATITMREF(NOL)
    Read [F:ITM]ITM0 = [M:MTK3]MATITMREF(NOL)
    If fstat : Raz [F:ITM] : Endif
Endif

If [F:ITF]STOFCY <> [M:MTK0]MFGFCY | [F:ITF]ITMREF <> [M:MTK3]MATITMREF(NOL)
   Read [F:ITF]ITF0 =[M:MTK3]MATITMREF(NOL);[M:MTK0]MFGFCY
   If fstat : Raz [F:ITF] : Endif
Endif

End

#####################################################"
Subprog AVANT_NBMAT
Default Mask [MTK3]
Call INIZONSOR("MTK3",[M:MTK3]MATITMREF(nolign-1),[M:MTK0]MFGFCY,nolign-1,6,[F:MTS]TRSCODS,"") From STKECR
# Issue 107513/8 - 2015-08-17 by JUSYN : Versions from components / material of a versioned product aren't allowed to be changed.
# Repeated here because of reset in INIZONSOR
If dim([M:MTK3]ECCVALMAJ(nolign-1))>0
    # versioned parent product
    Local Integer LRET
    Affzo [M:MTK3]ECCVALMAJ(nolign-1)
    Affzo [M:MTK3]ECCVALMIN(nolign-1)

    LRET = func ECCLIB.NBRCPN([M:MTK3]BOMNUM(nolign-1))
    If LRET > 0
        Grizo [M:MTK3]ECCVALMAJ(nolign-1)
        Grizo [M:MTK3]ECCVALMIN(nolign-1)
    Else
        Actzo [M:MTK3]ECCVALMAJ(nolign-1)
        Actzo [M:MTK3]ECCVALMIN(nolign-1)
    Endif
Endif

If dim([M:MTK3]LOC)>0
   Call STKINIEMPS([M:MTK3]LOC(nolign-1)) From STKLOC
Endif

End


