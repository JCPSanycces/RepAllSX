########################################
Subprog AM_LOCSTO(VALEUR)
Variable Char    VALEUR()
If [F:MTS]EMPFLG = 2 : Gosub UPD_EMPL_MAT From SUBMTKB : Endif
End

########################################
Subprog C_LOCSTO(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
    Read [F:STC]STC0 = [M:MTK0]MFGFCY;VALEUR
    If fstat : GMESSAGE = mess(23,100,1)
        mkstat = 1
        End
    Endif
   # Issue 87078 GA 02/2013 possibilité de vérifier si cet article est en inventaire plutôt que tout l'emplacement
    Local Char    WFILSTO(250)       : WFILSTO   = "1=1"    #  filtre sur STOCK
    GPOINT = "FILTRE_STO" : Gosub ENTREE From EXEFNC
   # 04.02 Problèmes Perf l'emplacement est-il bloqué pour inventaire ?
    Filter [F:STO] Where STOFCY = [M:MTK0]MFGFCY &
&                        LOC = VALEUR & CUNLOKFLG = 2 & evalue(WFILSTO)
&                  Order By Key STO4                            # 10.02 Performances
    Read [F:STO] First
    If !fstat : mkstat = 2 : GMESSAGE = mess(175,193,1)  : Endif
    Filter [F:STO]
Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 24/06/2003 11:29:58 (SR)
##########################################################################
Subprog AV_MATITMREF(VALEUR)
Variable Char    VALEUR()
Local    Decimal WQTY
Local    Integer J, NOL
NOL=nolign-1
pcolor=GCOUL(0)
If GREP <> "C" : End : Endif
# 05.05 demande 30321
If [M:MTK3]USEQTY(NOL) = 0  |
&  ([F:MTS]STOCODMAN = 2 & [M:MTK3]STOCODL(NOL) = 1 & [M:MTK3]WSTODET(NOL) <> 2)
    pcolor = GCOUL(1)
    End
Endif
If [M:MTK3]CUMMATSUI(NOL) = 1 : End : Endif
# Colorisation de l'article
# - si tout le stock à sortir n'a pas été renseigné
# - s'il y a une quantité en rupture
# Nouvelle ligne ou ligne modifiée
# 05.05 demande 30321
If [M:MTK3]CREFLG(NOL)=0 | ([M:MTK3]CREFLG(NOL)<>0 & [M:MTK3]UPDFLG(NOL)<>0)
         WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*([M:SOW]WSTOSEQ(J)=[M:MTK3]WSTOSEQ(NOL)))
         # Tout le stock à sortir n'a pas été renseigné
         If WQTY<>[M:MTK3]USEQTY(NOL)
            [M:MTK3]WSTODET(NOL) = 1
            pcolor=GCOUL(1)
         Else
            WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*
&                     ([M:SOW]WSTOSEQ(J)=[M:MTK3]WSTOSEQ(NOL)&[M:SOW]WSTOCOU(J)<>0))
            # Il y a une quantité en rupture
            If WQTY<>[M:MTK3]USEQTY(NOL)
               pcolor=GCOUL(2)
            Endif
         Endif
Elsif [M:MTK3]FLGRUP(NOL) = 1
      pcolor=GCOUL(2)
Endif
End


