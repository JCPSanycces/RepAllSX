######################################################################################
## Etiquette ajoutée par le superviseur (écran MTK3) 19/11/2004 15:19:11 (SR)
######################################################################################
Subprog AM_CLEFLG(VALEUR)
Variable Integer VALEUR
Local Integer NOL, OK
NOL = nolign-1
If VALEUR = 2
    #Proposition d'exclure la matière au suivi si en attente, non allouée et pas cumulée au suivi et pas suivie
    If [M:MTK3]MATSTA(NOL) = 1 & [M:MTK3]MFMITMREF(NOL) <> "" & [M:MTK3]ALLSTA(NOL) = 1 & [M:MTK3]CUMMATSUI(NOL) <> 1 &
&      [M:MTK3]USEQTY(NOL) = 0
        OK=1
        Call OUINON(mess(209,190,1),OK) From GESECRAN
        If OK=2
          [M:MTK3]WEXCMAT(NOL) = 2
        Endif
    Endif
Else
    Raz [M:MTK3]WEXCMAT(NOL)
Endif
End
