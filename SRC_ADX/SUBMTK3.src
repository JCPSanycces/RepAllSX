Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Date       NULLDAT
Local Integer    RETL # Local return code
Local Char       MESSAGEL(250) # Local Message

NULLDAT=[0/0/0]

Call CTRECC([M:MTK3]MATITMREF(nolign-1),"MTK3","ECCVALMAJ",VALEUR,[M:MTK3]ECCVALMIN(nolign-1),
&           NULLDAT,RETL,MESSAGEL) From ECCLIB

# Only Warning Message
If RETL>0
    GMESSAGE=MESSAGEL
    mkstat=1
Endif
End

