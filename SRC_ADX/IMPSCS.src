#<AdxTL>@(#)6.0.0.0 $Revision$
###########################################################################
# IMPSCS : Import/Export changement emplacements           HCB 16/03/2005 #
# ----------------------------------------------------------------------- #
# Traitements des actions spécifiques à l'import/export                   #
# ----------------------------------------------------------------------- #
###########################################################################


$ACTION
Case ACTION
  When "IMP_OUVRE"     : Gosub OUVRE
  When "IMPORT"        : Gosub IMPORT
  When "IMP_ZONE"      : Gosub IMP_ZONE
  When "IMP_TAB"       : Gosub IMP_TAB
  When "IMP_FERME"     : Gosub FERME
  #-----
  When "EXP_OUVRE"     : Gosub EXP_OUVRE  
  When "EXPORT"        : Gosub EXPORT 
  When "EXP_ZONE"      : Gosub EXP_ZONE
Endcase
Return



##########################################################################
#                              IMPORT / EXPORT                           #
##########################################################################


#-----------------------------------------------------------------#
# Début import/export, étiquette appelée depuis le traitement :   #
#   - IMPSCS ou IMPSCSS si import (G_IMPORT=1)                    #
#   - IMPSCS            si export (G_EXPORT=1)                    #
# --------------------------------------------------------------- #
# Entête *71 à *78  / Pied *81 à *88  / Ligne *91 à *98           #
#     les zones TSTCHAMP  1 à  8 déterminent l'entête             #
#     les zones TSTCHAMP 11 à 18 déterminent le pied              #
#     les zones TSTCHAMP 21 à 28 déterminent le détail            #
#-----------------------------------------------------------------#
# Aucun texte n'est géré pour l'instant dans les entrées diverses #
#-----------------------------------------------------------------#
$OUVRE_TEXTE
#----- Lignes texte entête  -----#
Raz GIMP(71), GIMP(72), GIMP(73), GIMP(74), GIMP(75), GIMP(76), GIMP(77), GIMP(78)
TSTCHAMP(1) ="SGH*71" : TSTCHAMP(2) ="SGH*72" : TSTCHAMP(3) ="SGH*73" : TSTCHAMP(4) ="SGH*74"
TSTCHAMP(5) ="SGH*75" : TSTCHAMP(6) ="SGH*76" : TSTCHAMP(7) ="SGH*77" : TSTCHAMP(8) ="SGH*78"
#----- Lignes texte pied -----#
Raz GIMP(81), GIMP(82), GIMP(83), GIMP(84), GIMP(85), GIMP(86), GIMP(87), GIMP(88)
TSTCHAMP(11)="SGH*81" : TSTCHAMP(12)="SGH*82" : TSTCHAMP(13)="SGH*83" : TSTCHAMP(14)="SGH*84"
TSTCHAMP(15)="SGH*85" : TSTCHAMP(16)="SGH*86" : TSTCHAMP(17)="SGH*87" : TSTCHAMP(18)="SGH*88"
#----- Lignes texte détail -----#
Raz GIMP(91), GIMP(92), GIMP(93), GIMP(94), GIMP(95), GIMP(96), GIMP(97), GIMP(98)
TSTCHAMP(21)="SGD*91" : TSTCHAMP(22)="SGD*92" : TSTCHAMP(23)="SGD*93" : TSTCHAMP(24)="SGD*94"
TSTCHAMP(25)="SGD*95" : TSTCHAMP(26)="SGD*96" : TSTCHAMP(27)="SGD*97" : TSTCHAMP(28)="SGD*98"
#-----
Gosub OUVRE_TEXTE From TRTX3IMP
Return



##########################################################################
#                                  IMPORT                                #
##########################################################################


#-------------------#
# Début de l'import #
#-------------------#
$OUVRE
Local Integer  OKCHAMP
Local Shortint WNOL
#----- Gestion des textes -----#
Gosub DECLARE_TEXTE From TRTX3IMP
G_IMPORT=1 : Gosub OUVRE_TEXTE
Return


#-----------------------------------------------------#
# Après lecture d'un enregistrement (entête ou ligne) #
#                                                     #
# IMPFIC : Abréviation du fichier en cours            #
#-----------------------------------------------------#
$IMPORT
Gosub IMPORT_TEXTE
Case IMPFIC
  When "SGH"
  When "SGD"
    Raz WNOL
    Gosub IMP_DECLARE From TRTX3IMP
    If GREP="M"
       ICLEPRIM(0)="VCRLIN"
       ICLEPRIM(1)="ITMREF"
       NBASTAB="NBLIG"
       Gosub RECHERCHE_LIGNE From TRTX3IMP
       WNOL=nolign
       #-------------------------------------------------#
       Call TST_CHAMP(IMPFIC,"QTYPCU",OKCHAMP) From SUBIMPOBJ
       If OKCHAMP & [F:SGD]QTYPCU=0 & nolign<>0
          status=65
          Call C_NBLIG     From SUBSCS : If mkstat Return : Endif
          Call AVANT_NBLIG From SUBSCS
          #Call APRES_NBLIG From SUBSCS  # FGR 15/01/2010 : X3SUIVI60986
       Endif
    Endif
Endcase
Return


#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
#                                         #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#-----------------------------------------#
$IMP_ZONE
If IMPZON="LOCDESH"  : # Dernier champ saisissable de l'entête
  Gosub IMP_ZONE_TEXTE : # Traitement des textes entête et pied
Endif
Return


#-------------------------------------------#
# Equivalent à la saisie d'un champ tableau #
#                                           #
# IMPFIC : Abréviation du fichier           #
# IMPMSK : Nom de l'écran en cours          #
# IMPZON : Nom du champ en cours            #
# IMPMOD : Déclenche l'Après_modif          #
# OK     : Conditionne IMP_ZONE standard    #
#-------------------------------------------#
$IMP_TAB
If IMPZON="LOCDES"    : # Dernier champ saisissable de la ligne
  Gosub IMP_ZONE_TEXTE : # Traitement des textes ligne
Endif
Return


#-----------------#
# Fin de l'import #
#-----------------#
$FERME
Return


#-------------------------------------------------------------------------------#
# Import d'un texte, étiquette appelée depuis les traitements IMPSCS et IMPSCSS #
# ----------------------------------------------------------------------------- #
#       Aucun texte n'est géré pour l'instant dans les sorties diverses !       #
#-------------------------------------------------------------------------------#
$IMPORT_TEXTE
Raz G_NLDET
Case IMPFIC
  When "SGH" : 
    If G_ENT     : # --- Texte entete ---
       Raz [M:ITC]T_CLE_CLOB(1) 
       Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(1)=G_CLE_CLOB
    Endif 
    If G_PIE     : # --- Texte pied --- 
       Raz [M:ITC]T_CLE_CLOB(2)
       Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(2)=G_CLE_CLOB
    Endif
  When "SGD"
    If G_DET     : # --- Texte detail ---
       Raz [M:ITC]T_CLE_CLOB(3)
       Gosub IMP_T3 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(3)=G_CLE_CLOB
    Endif
Endcase
Return

#CHECK IGNORE_BEGIN
#---------------------------------------------------------------------#
# Chargement de la clé du texte dans les classes             [M:SCS1] #
# ------------------------------------------------------------------- #
#  Aucun texte n'est géré pour l'instant dans les entrées diverses !  #
#---------------------------------------------------------------------#
$IMP_ZONE_TEXTE
Case IMPFIC
  When "SGH"
    If G_ENT & [M:ITC]T_CLE_CLOB(1)<>"" & GREP="C" : # --- Texte entête ---
      [M:SCS1]TEX1=[M:ITC]T_CLE_CLOB(1)
   Endif
    If G_PIE & [M:ITC]T_CLE_CLOB(2)<>"" & GREP="C" : # --- Texte pied ---
      [M:SCS0]TEX2=[M:ITC]T_CLE_CLOB(2)
    Endif
  When "SGD"
    If G_DET & [M:ITC]T_CLE_CLOB(3)<>"" & GREP="C" : # --- texte détail ligne ---
      [M:SCS1]LINTEX(nolign-1)=[M:ITC]T_CLE_CLOB(3)
    Endif 
Endcase
Return
#CHECK IGNORE_END


##########################################################################
#                                   EXPORT                               #
##########################################################################


#-----------------------------------------------------------------#
# Début export, étiquette appelée directement depuis le SUBEXPOBJ #
#-----------------------------------------------------------------#
$EXP_OUVRE
#----- Gestion dess textes -----#
Gosub DECLARE_TEXTE From TRTX3IMP
G_EXPORT=1 : Gosub OUVRE_TEXTE
#-----
Return


#---------------------------------------------------#
# Après lecture d'un enregistrement (entête, ligne) #
# ------------------------------------------------- #
# EXPFIC : Abréviation du fichier en cours          #
#---------------------------------------------------#
$EXPORT
Case EXPFIC
  When "SGH"
    If G_ENT 
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:SGH]TEX1)>0 & [F:SGH]TEX1<>"" 
          G_CLE_CLOB=[F:SGH]TEX1   : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP 
       Endif
    Endif 
    If G_PIE 
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:SGH]TEX2)>0 & [F:SGH]TEX2<>""
          G_CLE_CLOB=[F:SGH]TEX2   : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP 
       Endif
    Endif 
  When "SGD"
    If G_DET 
       Gosub EXP_RAZ_T3 From TRTX3IMP
       If dim([F:SGD]LINTEX)>0 & [F:SGD]LINTEX<>""
          G_CLE_CLOB=[F:SGD]LINTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T3 From TRTX3IMP 
       Endif
    Endif 
Endcase
Return


#------------------------------------------#
# Export d'un champ                        #
# ---------------------------------------- #
# EXPFIC : Abréviation du fichier en cours #
#------------------------------------------#
$EXP_ZONE
Return
