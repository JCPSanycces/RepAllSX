#<AdxTL>@(#)7.0.0.0 $Revision$
###########################################################################
# FUNCLEAR : Gestion des reliquats                            SR 10/02/98 #
#            Solde ou annulation de solde            Modifié MBT 02/04/99 #
#            des commandes standards                                      #
# ----------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais une fonction                      #
# ----------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                  #
#    - TRTFUNCLE : Gestion des reliquats (solde ou annulation de solde)   #
###########################################################################


$ACTION
#----------------------------------------------------------------------#
# Actions sur le traitement standard (GTRAITE)                         #
# TRTFUNCLE  : Gestion des reliquats (solde ou annulation de solde)    #
#----------------------------------------------------------------------#
Case ACTION
 When "INIT"         : Gosub INIT
 When "CONTROLE"     : Gosub CONTROLE
#----------------------------------------------------------------------#
# Actions sur la saisie fenêtre principale du traitement std (GSAISIE) #
# TRTFUNCLE  : Gestion des reliquats (solde ou annulation de solde)    #
#----------------------------------------------------------------------#
 When "OUVRE"        : If [M:DIA]CRITERE<>"" Gosub OUVRE       : Endif
 When "TITRE"        : If  clalev([M:CLE2])  Gosub TITRE_FEN   : Endif
 When "DEBUT"        : If  clalev([M:CLE2])  Gosub DEBUT
                                      Else   Grizo [DIA]TYPDEB, TYPFIN
                                             Affzo [DIA]1-99   : Endif
 When "SETBOUT"      : If GHISTO
                         Diszo [DIA]1-99
                         Call VIREBOUT(CHBOU,"O")   From GOBJET
                         Call VIREBOUT(CHMEN,"MRE") From GOBJET
                       Endif
 When "OK"           : If  clalev([M:CLE2])  Gosub OK
                                      Else   GOK=1             : Endif
 When "END"          : If !clalev([M:CLE2])  GOK=0             : Endif
 When "ABA"          : If  clalev([M:CLE2])  Gosub ABA         : Endif
 When "APRES_MODIF"  : If  clalev([M:CLE2])  Gosub APRES_MODIF : Endif
 When "FINSAI"       : If  clalev([M:CLE2])  Gosub FINSAI      : Endif
#----------------------------------------------------------------------#
# Actions sur la suite du traitement standard (GTRAITE)                #
# TRTFUNCLE  : Gestion des reliquats (solde ou annulation de solde)    #
#----------------------------------------------------------------------#
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When "SORTIE"       : Gosub SORTIE
Endcase
Return


########################################################################
# Actions sur le traitement standard (GTRAITE)                         #
# -------------------------------------------------------------------- #
# TRTFUNCLE  : Gestion des reliquats (solde ou annulation de solde)    #
########################################################################

#-----------------------------------------------#
# Initialisations avant exécution du traitement #
#-----------------------------------------------#
$INIT
#----- Ouverture fichiers -----#
# Issue 99005 - 2014-05-20 by SR : Ne pas soumettre l'ouverture de TABCOUAFF à la présence du module GPAO
Local File PORDER     [POH], PORDERQ   [POQ], PORDERP   [POP], ITMMASTER [ITM],
&          ITMFACILIT [ITF], ITMMVT    [ITV], ORDERS    [ORD], BPSUPPMVT [MVS],
&          PORDERC    [POC], TABCOEFF  [TCO], TABCUR    [TCU], PERIOD    [PER],
&          FACILITY   [FCY], CPTANALIN [CAL], TABCOUAFF [TCA]
If GMODU(2)=2 Local File BUDPAR [BUP] : Endif : # Si module compta présent
If GMODU(8)=2 : # Module GP présent
  Local Mask SBCK  [SBCK]
#  If !clalev([F:TCA])  Local File TABCOUAFF [TCA] : Endif
Endif
# sr 03.12 Demande 80380 ouvrir la table SORDERQ
If GMODU(5)=2 : # Module Vente présent
 Local File SORDERQ  [SOQ]
Endif

Default File [POQ]
#-----
Local Mask ORDK     [ORDK] : # Masque paramètres encours

# V6 Affectations
Gosub OPEN_MTO From MTOLINKLIB

Local Mask POHCLEAR [DIA]
Raz [M:DIA]
#----- Initialisation des sites par défaut -----#
[M:DIA]FCYDEB=GFCYDEF(6)
[M:DIA]FCYFIN=GFCYDEF(6)
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  If !find([M:DIA]FCYDEB,GUSRFCY(1..GNBAUZ))
    [M:DIA]FCYDEB=GUSRFCY(1)  : # On prend le premier site autorisé
    [M:DIA]FCYFIN=GUSRFCY(1)
  Endif
Endif
#----- Types de commande (un seul type est permis) -----#
[M:DIA]TYPDEB=1 : [M:DIA]TYPFIN=1
#----- Titre de la fenêtre de saisie des critères -----#
TIT=mess(37,195,1)
#-----
Call LECMEMO("STD","[M:DIA]","pm2") From GMEMO
Return

#--------------------------------------------------------#
# Contrôle et traitement avant saisie fenêtre principale #
#--------------------------------------------------------#
$CONTROLE
If GOK<1  FIN=1 : Endif
#----- Constitution des filtres -----#
[M:DIA]CRITERE="LINTYP<3"
[M:DIA]CRITSUP="1=1"
If [M:DIA]FCYDEB<>""
  [M:DIA]CRITERE += ' & POHFCY>="'+[M:DIA]FCYDEB+'"'
Endif
If [M:DIA]FCYFIN<>""
  [M:DIA]CRITERE += ' & POHFCY<="'+[M:DIA]FCYFIN+'"'
Endif
If [M:DIA]DATDEB<>[0/0/0]
  [M:DIA]CRITERE += ' & ORDDAT>=['+format$(GFMD,[M:DIA]DATDEB)+']'
Endif
If [M:DIA]DATFIN<>[0/0/0]
  [M:DIA]CRITERE += ' & ORDDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']'
Endif
[M:DIA]CRITERE += " & POHTYP>="+num$([M:DIA]TYPDEB)
[M:DIA]CRITERE += " & POHTYP<="+num$([M:DIA]TYPFIN)
If [M:DIA]CDEDEB<>""
  [M:DIA]CRITERE += ' & POHNUM>="'+[M:DIA]CDEDEB+'"'
Endif
If [M:DIA]CDEFIN<>""
  [M:DIA]CRITERE += ' & POHNUM<="'+[M:DIA]CDEFIN+'"'
Endif
If [M:DIA]FOUDEB<>""
  [M:DIA]CRITSUP += ' & BPSNUM>="'+[M:DIA]FOUDEB+'"'
Endif
If [M:DIA]FOUFIN<>""
  [M:DIA]CRITSUP += ' & BPSNUM<="'+[M:DIA]FOUFIN+'"'
Endif
If [M:DIA]ARTDEB<>""
  [M:DIA]CRITSUP += ' & ITMREF>="'+[M:DIA]ARTDEB+'"'
Endif
If [M:DIA]ARTFIN<>""
  [M:DIA]CRITSUP += ' & ITMREF<="'+[M:DIA]ARTFIN+'"'
Endif
If [M:DIA]CDETRT<>3
  [M:DIA]CRITSUP += " & LINCLEFLG="+num$([M:DIA]CDETRT)
Endif
Return


########################################################################
# Actions sur la saisie fenêtre principale du traitement std (GSAISIE) #
# -------------------------------------------------------------------- #
# TRTFUNCLE  : Gestion des reliquats (solde ou annulation de solde)    #
########################################################################

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE
Local Char    CRITERE(240) : CRITERE=[M:DIA]CRITERE
Local Char    CRITSUP(240) : CRITSUP=[M:DIA]CRITSUP
#----- Variables locales -----#
Local Char    WPOQNUM(GLONPOH)
Local Char    WPOQLNK(16)
Local Char    WVCRNUMORI(GLONVCR)
Local Integer WLINSOLD, WTRT, STA, SIGN
Local Decimal WQTYREST, WTOLDEB, WTOLFIN, WORDNOT, WORDATI
Local Char    SYMBOLE2(20), WPOHNUM(GLONPOH)
Local Integer I, J, K, NBLOCK
#----- Variables pour le point d'entrée POHCLE -----#
Local Libelle WCLEFLG, WTRAIT
#-----
Raz GCNTBUD
WTOLDEB=[M:DIA]TOLERANCE
Return

#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_FEN
Call TEXTE (54043, TIT) From OBJDIV # Close and re-open order sel. # 105537.n MJH 08/11/2015
#TIT=mess(36,198,1)-mess(37,195,1) .o
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEBUT
Local Char    TABLOCK(15)(0..dim([M:CLE2]PRO))
Local Char    POQFILTRE(250)
Local Char    POHFILTRE(250)
Local Decimal WQTE, WAMT
Local Char    WCPY   (GLONCPY)
Local Char    WBUDCOA(GLONCOA)
Local Char    WENVDIE(GLONDIE)
Local Char    WENTDIE(GLONDIE)
Local Libelle WTYPLEDGEN
Local Libelle WTYPLEDANA
Local Decimal WFIY
# Issue 116808 - 2016-05-26 by SR : Gestion du suivi de signatures
Local Char    WPARAME(10)
Local Integer WRET
Local  Char   WGRPDEB(GLONVCR)
# End issue 116808
#-----------------------------------------------------------------------------#
# Point d'entrée POQFILTRE pour ajouter un filtre supplémentaire              #
# --------------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                                 #
#                                                                             #
# CRITERE   : Filtre constitué par le traitement à partir de l'écran POHCLEAR #
# CRITSUP   : Filtre constitué par le traitement à partir de l'écran POHCLEAR #
# POQFILTRE : Filtre supplémentaire sur les lignes de commande                #
# POHFILTRE : Filtre supplémentaire sur les entêtes de commande               #
#-----------------------------------------------------------------------------#
Raz POQFILTRE, POHFILTRE
GPOINT="POQFILTRE" : Gosub ENTREE From EXEFNC
If POQFILTRE=""  POQFILTRE="1=1" : Endif
If POHFILTRE=""  POHFILTRE="1=1" : Endif
#-----
If parse(POQFILTRE)
  Call ERREUR("Filter error POQFILTRE") From GESECRAN : Return
Endif
If parse(POHFILTRE)
  Call ERREUR("Filter error POHFILTRE") From GESECRAN : Return
Endif
#-----
Raz [M:CLE2]
nolign=1
Call TEMPON("R") From GESECRAN
For [POQ] Where evalue(CRITERE) & evalue(CRITSUP) & evalue(POQFILTRE) With Nohint
  #----- Il ne faut proposer que les sites auxquels l'utilisateur a droit -----#
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    If !find(([F:POQ]POHFCY),GUSRFCY(1..GNBAUZ)) Goto SUIT : Endif
  Endif
  #-----
  If [F:POH]POHNUM<>[F:POQ]POHNUM
    Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
  Endif
  If !evalue(POHFILTRE)  Goto SUIT : Endif
  #----- On ne peut pas annuler le solde d'une ligne de sous-traitance -----#
  If [F:POQ]LINCLEFLG=2
    If [F:POQ]LINTYP>1  Goto SUIT : Endif
    If [F:ITM]ITMREF<>[F:POQ]ITMREF
      Read [ITM] ITM0=[F:POQ]ITMREF : If fstat Raz [F:ITM] : Endif
    Endif
    # Issue 112862 - 2015-12-04 by MUARN : se baser sur VCRTYPORI
    #If [F:ITM]SCSFLG=2 | [F:ITM]SCPFLG=2  Goto SUIT : Endif
    If [F:POQ]VCRTYPORI = 10 | [F:POQ]VCRTYPORI = 36 : Goto SUIT : Endif
  Endif
  #-----
  If [F:POQ]QTYPUU<>0
    WQTYREST=(([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU)*100)/[F:POQ]QTYPUU
  Else
    WQTYREST=0
  Endif
  If WQTYREST>WTOLDEB & [F:POQ]LINCLEFLG<2  Goto SUIT : Endif
  #----- Lock logique de l'entête de commande -----#
  J=find([F:POH]POHNUM,TABLOCK(0..K))
  If !J
    TABLOCK(K) = [F:POH]POHNUM
    K += 1
  Endif
  [M:CLE2]PRO(nolign-1)         = 1
  [M:CLE2]POHFCY(nolign-1)      = [F:POQ]POHFCY
  [M:CLE2]POHNUM(nolign-1)      = [F:POQ]POHNUM
  [M:CLE2]BPSNUM(nolign-1)      = [F:POQ]BPSNUM
  [M:CLE2]POPLIN(nolign-1)      = [F:POQ]POPLIN
  [M:CLE2]ITMREF(nolign-1)      = [F:POQ]ITMREF
  [M:CLE2]LINCLEFLG(nolign-1)   = [F:POQ]LINCLEFLG
  [M:CLE2]QTYPUU(nolign-1)      = [F:POQ]QTYPUU
  [M:CLE2]RCPQTYPUU(nolign-1)   = [F:POQ]RCPQTYPUU
  [M:CLE2]INVQTYPUU(nolign-1)   = [F:POQ]INVQTYPUU
  [M:CLE2]PUU(nolign-1)         = [F:POQ]PUU
  [M:CLE2]LINAMT(nolign-1)      = [F:POQ]LINAMT
  [M:CLE2]CMMNUM(nolign-1)      = [F:POQ]CMMNUM
  #----- Calcul du reliquat d'engagement -----#
  If [F:POQ]LINCLEFLG<>2 & [F:POQ]QTYPUU<>0
    WQTE=[F:POQ]QTYPUU-min([F:POQ]QTYPUU,max([F:POQ]RCPQTYPUU,[F:POQ]INVQTYPUU))
    WAMT=[F:POQ]LINAMT*WQTE/[F:POQ]QTYPUU
    Call ARRDEV(WAMT,[F:POH]CUR) From TRTDIV
    [M:CLE2]AMT(nolign-1)       = WAMT
  Else
    [M:CLE2]AMT(nolign-1)       = 0
  Endif
  #-----
  [M:CLE2]CUR(nolign-1)         = [F:POH]CUR
  #----- Enveloppe, entité et compte budgétaire -----#
  Read [CAL] CAL0="POP";0;[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ;"";1
  If !fstat
    If WCPY<>[F:POQ]CPY
      Call SETMAINREF([F:POQ]CPY,WTYPLEDGEN,WTYPLEDANA)     From CPTDIV
      Call GETEXE([F:POQ]CPY,WTYPLEDANA,[F:POQ]ORDDAT,WFIY) From CPTSUB
      Call RECH_BUDOPE([F:POQ]CPY,WBUDCOA,WENVDIE,WENTDIE)  From TRTX3CPT
      WCPY=[F:POQ]CPY
    Endif
    [M:CLE2]FIY(nolign-1)=WFIY
    If WBUDCOA<>""
      [M:CLE2]BUDCOA(nolign-1)=WBUDCOA
      I=find(WBUDCOA,[F:CAL]COA)
      If I  [M:CLE2]BUDACC(nolign-1)=[F:CAL]ACC(I-1) : Endif
    Endif
    If WENVDIE<>""
      [M:CLE2]ENVDIE(nolign-1)=WENVDIE
      I=find(WENVDIE,[F:CAL]DIE)
      If I  [M:CLE2]ENVCCE(nolign-1)=[F:CAL]CCE(I-1) : Endif
    Endif
    If WENTDIE<>""
      [M:CLE2]ENTDIE(nolign-1)=WENTDIE
      I=find(WENTDIE,[F:CAL]DIE)
      If I  [M:CLE2]ENTCCE(nolign-1)=[F:CAL]CCE(I-1) : Endif
    Endif
  Endif
  #-----
  [M:CLE2]BETFCY(nolign-1)      = [F:POH]BETFCY
  #----- Inter-sites avec automatisme (génération cde vente) -----#
  If [M:CLE2]BETFCY(nolign-1)=2 & [F:POH]SALFCY<>""
    [M:CLE2]LINOCNNUM(nolign-1) = [F:POQ]LINOCNNUM
    [M:CLE2]OCNLIN(nolign-1)    = [F:POQ]OCNLIN
    [M:CLE2]OCNSEQ(nolign-1)    = [F:POQ]OCNSEQ
  Endif
  #-----
  [M:CLE2]SOHNUM(nolign-1)      = [F:POQ]SOHNUM
  nolign += 1
# Issue 76621 - 2011-11-18 by MUARN : dimensionnement pour solde des commandes
#  If nolign>=dim([M:CLE2]PRO)
#    GMESSAGE=mess(26,100,1) : GERR=2 : nolign-=1 : Break
  If nolign>dim([M:CLE2]PRO)
      GMESSAGE=mess(26,100,1) : GERR=2 : Break
# fin 76621
  Endif
$SUIT
Next
Call TEMPOFF From GESECRAN
[M:CLE2]NBLIG = nolign-1
If [M:CLE2]NBLIG=0
  GMESSAGE=mess(99,100,1) : GERR=1 : FIN=1
Endif
Affzo [CLE2]1-99
Return

#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK
# Issue 82703 - 2013-03-28 by SR : Régul valo stock : Flag solde modifié #
If !GSERVEUR
# Ouverture de la trace
    Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call TEMPON("E") From GESECRAN
Sorta [M:CLE2]NBLIG [M:CLE2]NBLIG Order By [M:CLE2]POHNUM(indice),
&                                          [M:CLE2]POPLIN(indice)
Raz GFCY, WORDNOT, WORDATI, WLINSOLD, WPOHNUM
Call DEBTRANS From GLOCK
$TR_SOLDE
GOK=1
Trbegin [POQ],[POH],[ITV],[ORD],[MVS]
  For I=1 To [M:CLE2]NBLIG
    If [L]WPOHNUM<>"" & [M:CLE2]POHNUM(I-1)<>[L]WPOHNUM
      Gosub MAJ_ENTETE : If GOK<1  Break : Endif
    Endif
    #---------------------------------------------------------#
    # On ne fait rien si :                                    #
    # le code traitement est à AUCUN                          #
    # le code traitement est à SOLDE et ligne déjà soldée     #
    # le code traitement est à annulation et ligne non soldée #
    #---------------------------------------------------------#
    If [M:CLE2]PRO(I-1)=1                              Goto NEXTLIG : Endif
    If [M:CLE2]PRO(I-1)=2 & [M:CLE2]LINCLEFLG(I-1)=2 : Goto NEXTLIG : Endif
    If [M:CLE2]PRO(I-1)=3 & [M:CLE2]LINCLEFLG(I-1)=1 : Goto NEXTLIG : Endif
    Readlock [POQ] POQ0=[M:CLE2]POHNUM(I-1);[M:CLE2]POPLIN(I-1);1
    If fstat=1
      GOK=-1 : GLOCK="$PORDERQ" : Break
    Elsif fstat
      GOK= 0 : Call RSTA("POQ",[M:CLE2]POHNUM(I-1)-num$([M:CLE2]POPLIN(I-1))) From GLOCK : Break
    Endif
    # Issue 97517 - 2014-03-05 by MUARN : ne pas annuler un solde sur un article non réceptionnable
    If [F:ITM]ITMREF<>[F:POQ]ITMREF
      Read [ITM] ITM0=[F:POQ]ITMREF : If fstat Raz [F:ITM] : Endif
    Endif
    If [F:ITM]RCPFLG=1 & [M:CLE2]PRO(I-1)=3 : Goto NEXTLIG : Endif

    #----- Relire les paramètres budgets -----#
    If [F:POQ]POHFCY<>GFCY
      GFCY=[F:POQ]POHFCY
      # Issue 116808 - 2016-05-26 by SR : Suivi des signatures
      Call PARAML(GFCY,"APPPOH",[L]WPARAME) From ADOVAL
      GAPPPOH=val([L]WPARAME)
      # End issue 116808
      Call DEFRCPFCY(GFCY)    From TRTACHDEF1
      Call DEFSITE(GFCY)      From TRTACHDEF1
      Call DEFBUD("POH",GFCY) From TRTACHDEF1
      GCNTBUD=GCTLBUD
    Endif
    Gosub SOLDE : If GOK<1  Break : Endif
$NEXTLIG
  Next I
  If [L]WPOHNUM<>"" & GOK=1
    Gosub MAJ_ENTETE
  Endif
  If GOK=-1 Goto ROLL_SOLDE : Endif
  If GOK= 0 Goto AB_SOLDE   : Endif
Commit
# Issue 116808 - 2016-05-26 by SR : Suivi des signatures
#----- Envoi des messages groupe workflow signature -----#
If WGRPDEB<>""  Call ENVOI_GROUPE(WGRPDEB) From AWRK : WGRPDEB="" : Endif
# End issue 116808
Goto FIN_SOLDE
#----- Nouvel essai de transaction ou abandon suivant GROLL -----#
$ROLL_SOLDE
Rollback : Call ROLL From GLOCK
# Issue 116808 - 2016-05-26 by SR : Suivi des signatures
#----- Suppression des message groupe workflow signature -----#
If WGRPDEB<>""  Call VIRE_GROUPE(WGRPDEB)  From AWRK : WGRPDEB="" : Endif
# End issue 116808
If GROLL
  Goto FIN_SOLDE
Else
  Goto TR_SOLDE
Endif
#----- Abandon de la transaction -----#
$AB_SOLDE
Rollback
# Issue 116808 - 2016-05-26 by SR : Suivi des signatures
#----- Suppression des message groupe workflow signature -----#
If WGRPDEB<>""  Call VIRE_GROUPE(WGRPDEB)  From AWRK : WGRPDEB="" : Endif
# End issue 116808
#----- Fin de traitement du OK -----#
$FIN_SOLDE
FIN=1
Call TEMPOFF From GESECRAN
# Issue 82703 - 2013-03-28 by SR : Régul valo stock : Flag solde modifié #
If !GSERVEUR
    Call FERME_TRACE From LECFIC
Endif
Return

#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA
Raz REP
For I=0 To [M:CLE2]NBLIG-1
  [M:CLE2]PRO(I)=1
Next I
Affzo [CLE2]1-99
Return

#------------------------------------#
# Après chaque modification de champ #
#------------------------------------#
$APRES_MODIF
REP="M"
Return

#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI
For I=0 To K-1
  SYMBOLE2="POH"+TABLOCK(I)
  Unlock = SYMBOLE2 : # Déblocage logique de toutes les commandes
Next I
Return


########################################################################
# Suite des actions sur le traitement standard (GTRAITE)               #
# -------------------------------------------------------------------- #
# TRTFUNCLE  : Gestion des reliquats (solde ou annulation de solde)    #
########################################################################

#-------------------------#
# Exécution du traitement #
#-------------------------#
$EXEC
Return

#-----------------------------------#
# Fin après exécution du traitement #
#-----------------------------------#
$TERMINE
If GTRACE<>""  TRA=1 : Endif : # à supprimer !!
Return

#----------------------#
# Sortie du traitement #
#----------------------#
$SORTIE
Return


#####################################################################
# Solde d'une ligne ou d'un groupe de lignes (composé + composants) #
#####################################################################
$SOLDE
Gosub SOLDE_LIG : If GOK<1  Return : Endif
#-----
If [F:POQ]LINTYP=2 : # Ligne du composé (produit fini)
  [L]WPOQNUM   =[F:POQ]POHNUM
  [L]WPOQLNK   =[F:POQ]POQLNK
  [L]WVCRNUMORI=[F:POQ]VCRNUMORI
  #-----
  For [POQ] Where POHNUM=[L]WPOQNUM & POQLNK>[L]WPOQLNK & VCRNUMORI=[L]WVCRNUMORI & LINTYP>2
    If WTRT=2 & [F:POQ]LINCLEFLG<>2
      Readlock [POQ] Curr
      If fstat=1
        GOK=-1 : GLOCK="$PORDERQ" : Break
      Elsif fstat
        GOK= 0 : Call RSTA("POQ",[L]WPOQNUM-num$([F:POQ]POPLIN)) From GLOCK : Break
      Endif
      Gosub SOLDE_LIG : If GOK<1  Break : Endif
    Endif
  Next
  #-----
Endif
Return


############################################
# Solde ou désolde de la ligne de commande #
# ---------------------------------------- #
# WTRT = 2 --> Solde                       #
#      = 3 --> Annulation de solde         #
############################################
$SOLDE_LIG
WTRT=[M:CLE2]PRO(I-1)
Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;1
If fstat
  Raz [F:POP]
  Read [POC] POC0=[F:POQ]POHNUM;[F:POQ]POPLIN
  If fstat
    Raz [F:POC]
  Else
    [F:POP]ITMREF=[F:POC]ITMREF
    [F:POP]PRHFCY=[F:POC]PRHFCY
  Endif
Endif
If WTRT=2        : # Solde
  SIGN=-1 : Gosub CAL_MVS From SUBPOHA : # Calcul mts en commande HT et TTC
Else             : # Désolde
  SIGN=+1 : Gosub CAL_MVS From SUBPOHA : # Calcul mts en commande HT et TTC
Endif
#----- Maj qté en commande dans article-site -----#
If [F:POP]ITMREF<>"" & ([F:POQ]QTYSTU-[F:POQ]RCPQTYSTU)>0
  STA=0
  Call LECITV([F:POP]PRHFCY,[F:POP]ITMREF,"",STA) From STKLIB
  If STA>2
    Infbox("Erreur : Le site ou l'article ne sont pas alimenté")
    GOK=0
  Endif
  If GOK<>1
    #----- On continue quand même sans mettre à jour ITV -----#
    GOK=1
  Else
    If WTRT=2 : # Solde
      If STA=0
        Update [ITV] Where ITMREF=[F:POP]ITMREF & STOFCY=[F:POP]PRHFCY
&                    With ORDSTO-=([F:POQ]QTYSTU-[F:POQ]RCPQTYSTU)
      Endif
    Else      : # Désolde
      Update [ITV] Where ITMREF=[F:POP]ITMREF & STOFCY=[F:POP]PRHFCY
&                  With ORDSTO+=([F:POQ]QTYSTU-[F:POQ]RCPQTYSTU)
    Endif
    If fstat  GOK=0 : Call FSTA ("ITV") From GLOCK : Return : Endif
  Endif
Endif
#----- Maj du budget et de la ligne commande PORDERQ -----#
Read [POH] POH0=[F:POQ]POHNUM
If WTRT=2
  SIGN=-1 :           : # Solde
  [F:POQ]LINCLEFLG=2
Else
  SIGN=+1 :           : # Désolde
  [F:POQ]LINCLEFLG=1
Endif
[F:POQ]RCPCLEFLG=1
If [F:POQ]LINTYP<>2
  Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,SIGN,2,"POQ2",0,GBIDI1) From TRTACHDIV1
  If GOK<1  Return : Endif
Endif
#----- Relecture article si nécessaire -----#
If [F:ITM]ITMREF<>[F:POQ]ITMREF
  Read [ITM] ITM0=[F:POQ]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
#-----
Call GETDEV([F:POQ]POHFCY) From DEVSUB
#----- Mise à jour opération de sous-traitance -----#
# Issue 109433 by GA 09/2015 Subcontrated operation (WO) or Subcontracted product (EO)
If find([F:POQ]VCRTYPORI,10,36) & [F:POQ]LINTYP<=2 : # Si achat sous-traitance
  [M:SBCK]MAJCOD = "M"
  [M:SBCK]VCRNUM = [F:POQ]POHNUM
  [M:SBCK]VCRLIN = [F:POQ]POPLIN
  [M:SBCK]VCRSEQ = [F:POQ]POQSEQ
  [M:SBCK]ITMREF = [F:POQ]ITMREF                                 # Issue 109433 by GA 09/2015
  If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:POQ]LINTYP Endif  # Issue 109433 by GA 09/2015
  If [F:POQ]LINCLEFLG<>2
    [M:SBCK]ORDQTY=[F:POQ]QTYSTU
  Elsif [F:POQ]RCPQTYSTU<>0
    [M:SBCK]ORDQTY=[F:POQ]RCPQTYSTU
  Else
    [M:SBCK]ORDQTY=0 : [M:SBCK]MAJCOD="A"
  Endif
  [M:SBCK]ORDDAT = [F:POQ]EXTRCPDAT-[F:POQ]OFS
  [M:SBCK]RCPDAT = [F:POQ]EXTRCPDAT
  Call CONVERT2([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&               [F:POQ]LINAMT,[M:SBCK]EXTPRI,STA) From TRTDEV
  If [F:POQ]QTYSTU = 0
    [M:SBCK]EXTPRI = arr([M:SBCK]EXTPRI,10^-GDECPRI)
  Else
    [M:SBCK]EXTPRI = arr([M:SBCK]EXTPRI/[F:POQ]QTYSTU,10^-GDECPRI)
  Endif
  [M:SBCK]OFS    = [F:POQ]OFS
  [M:SBCK]MSGFLG = 1                        # llc 03.01 (inutile après tout)
  [M:SBCK]CLEFLG = [F:POQ]LINCLEFLG         # 03.02 13517
  #-----
  # Issue 109433 by GA 09/2015 only when MFG Module, see MFGAUTLIB
  #Call LECTCA(8,GBIDI3) From SUBTCA
  #If fstat | !GBIDI3
  #  GMESSAGE=mess(58,105,1)-mess(8,14,1)-mess(250,199,1) : GOK=0 : Return
  #Endif
  #GOPS=[F:TCA]CODNUM(4)
  #-----
  Call MAJ_SBC From SBCLIB
  If [M:SBCK]CODRET<>0
    # Issue 109433 by GA 09/2015
    # GMESSAGE=mess(96,193,1) : GERR=1 : GOK=0 : Return
      If [F:POQ]VCRTYPORI=10
        GMESSAGE=mess(96,193,1)-":"-GMESSAGE
      Elsif [F:POQ]VCRTYPORI=36
        GMESSAGE=mess(913,196,1)-":"-GMESSAGE
      Endif
      GERR=1 : GOK=0 : Return
  Endif
Endif
#----- Maj de l'encours ORDERS -----#
If [F:POQ]WIPNUM<>""
  #-----
  Call LECTCA(7,GBIDI3) From SUBTCA
  If fstat | !GBIDI3
    GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1) : GOK=0 : Return
  Endif
  GWIP=[F:TCA]CODNUM(8)
  #-----
  If WTRT=2          : # Solde
    # affectations
    Gosub SUP_MTO_POQ From PURMTOLIB

    [M:ORDK]MAJCOD    = "A"
    [M:ORDK]WIPTYP    = [F:POQ]WIPTYP
    [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
    [M:ORDK]ITMREF    = [F:POQ]ITMREF

  Else               : # Désolde
    [M:ORDK]MAJCOD    = "M"
    [M:ORDK]WIPTYP    = [F:POQ]WIPTYP
    [M:ORDK]WIPSTA    = [F:POQ]WIPSTA
    [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
    [M:ORDK]ITMREF    = [F:POQ]ITMREF
    [M:ORDK]ORIFCY    = [F:POQ]POHFCY
    [M:ORDK]STOFCY    = [F:POQ]PRHFCY
    [M:ORDK]PJT       = [F:POP]PJT
    [M:ORDK]BPRNUM    = [F:POQ]BPSNUM
    [M:ORDK]STRDAT    = [F:POQ]ORDDAT
    [M:ORDK]ENDDAT    = [F:POQ]EXTRCPDAT
    [M:ORDK]VCRTYP    = 14
    [M:ORDK]VCRNUM    = [F:POQ]POHNUM
    [M:ORDK]VCRLIN    = [F:POQ]POPLIN
    [M:ORDK]VCRSEQ    = [F:POQ]POQSEQ
    [M:ORDK]EXTQTY    = [F:POQ]QTYSTU
    [M:ORDK]CPLQTY    = [F:POQ]RCPQTYSTU
    [M:ORDK]ALLQTY    = 0
    [M:ORDK]SHTQTY    = 0
    [M:ORDK]FMI       = 1
    [M:ORDK]MRPMES    = 1
    [M:ORDK]VCRTYPORI = 0
    [M:ORDK]VCRNUMORI = ""
    [M:ORDK]VCRLINORI = 0
    [M:ORDK]VCRSEQORI = 0
    [M:ORDK]BOMALT    = 0
    [M:ORDK]ORI       = 1
    If [F:POH]POHTYP=2 [M:ORDK]ABBFIL="POC" Else [M:ORDK]ABBFIL="POQ" : Endif
  Endif
  Call WIP From TRTWIP : If GOK<1 Return : Endif

  # affectations
  If WTRT <> 2
    # affectations
    Gosub MAJ_MTO_POQ From PURMTOLIB
  Endif
Endif
#----- Appel du point d'entrée POHCLE solde/désolde ligne de commande -----#
WTRAIT=2
If WTRT=2  WCLEFLG=1  Else  WCLEFLG=2 : Endif
Gosub POINT_POHCLE From TRTACHCDE1
#-----
Rewrite [POQ]
If fstat GOK = 0 : Call FSTA("POQ") From GLOCK : Return : Endif
# Issue 82703 - 2013-03-28 by SR : Régul valo stock : Flag solde modifié #
# Pour chaque réception existante, il faudra faire ou défaire la PEC des FCC
If [F:POQ]RCPQTYSTU <> 0
   If [F:POQ]LINCLEFLG = 2
    Call REGPRIX_FCC(2,"",0) From TRTACHFAC1
   Else
    Call REGPRIX_FCC(3,"",0) From TRTACHFAC1
   Endif
Endif

[L]WPOHNUM=[F:POQ]POHNUM
If WTRT=2
  WLINSOLD+=1      : # Solde
Else
  WLINSOLD-=1      : # Désolde
Endif
If [M:CLE2]BETFCY(I-1)=2 & [M:CLE2]LINOCNNUM(I-1)<>""
  #--- Solde de ligne d'une commande de vente
  Call DIVCLESOQ([F:POQ]LINOCNNUM, [F:POQ]OCNLIN, [F:POQ]OCNSEQ, GBIDC1) From TRTVENCDE
  Default Mask [CLE2]
  If GOK<1  Return : Endif
Endif
Return

$MAJ_ENTETE
#----- Si rupture sur numéro de pièce Maj de l'entête cde PORDER -----#
Readlock [POH] POH0=[L]WPOHNUM
If fstat=1
  GOK=-1 : GLOCK = "$PORDER" : Return
Elsif fstat
  GOK= 0 : Call RSTA("POH",[L]WPOHNUM) From GLOCK : Return
Endif
[F:POH]CLELINNBR+=WLINSOLD
If [F:POH]CLELINNBR<0  [F:POH]CLELINNBR=0 : Endif
If [F:POH]CLELINNBR>[F:POH]LINNBR  [F:POH]CLELINNBR=[F:POH]LINNBR : Endif
If [F:POH]CLELINNBR=[F:POH]LINNBR
  [F:POH]CLEFLG=2
Else
  [F:POH]CLEFLG=1
Endif
Rewrite [POH]
If fstat  GOK=0 : Call FSTA("POH") From GLOCK : Return : Endif
#----- Maj en commande dans mouvements fournisseur -----#
Call MAJENC_BPS([F:POH]BPSNUM,3,[F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&               [F:POH]POHNUM,WORDNOT,WORDATI,[F:POH]TTVORD) From TRTBPMVT
If GOK<1  Return : Endif
# Issue 116808 - 2016-05-26 by SR : Suivi des signatures
#----- Positionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
If WTRT = 2 &  GAPPPOH>1 & [F:POH]CLEFLG=2 & [F:POH]APPFLG<3
  #----- Uniquement si appel hors évènement de Workflow ! -----#
  If [F:POH]POHTYP=1
    Call ANNULE_SUIVI("POH",mess(654,197,1),1,[L]WRET) From TRTACHDIV1
  Else
    Call ANNULE_SUIVI("POC",mess(654,197,1),1,[L]WRET) From TRTACHDIV1
  Endif
  If GOK<1  Return : Endif
Elsif WTRT = 3 & GAPPPOH > 1 & [F:POH]CLEFLG <> 2 & [F:POH]APPFLG<3
If [F:POH]POHTYP=1
    Call REACTIV_SUIVI("POH",[F:POH]POHNUM) From TRTACHDIV1
  Else
    Call REACTIV_SUIVI("POC",[F:POH]POHNUM) From TRTACHDIV1
  Endif
  If GOK<1  Return : Endif
Endif
# End issue 116808
Raz WORDNOT, WORDATI, WLINSOLD, WPOHNUM
Return

#############################################################
# Sous-Programmes des actions sur champ de l'écran POHCLEAR #
#############################################################

Subprog AV_FCYDEB(VALEUR)
#-----------------------------------------------#
# Avant zone site début pour grisage des champs #
#-----------------------------------------------#
Variable Char    VALEUR()
If FLAG<>1 : # Pour n'exécuter l'action qu'une seule fois au 1er affichage
  FLAG=1
  If GNBAUZ=1
    If [M:DIA]FCYDEB=""
      [M:DIA]FCYDEB=GUSRFCY(1) : [M:DIA]FCYFIN=GUSRFCY(1)
    Endif
    Diszo [DIA]FCYDEB, FCYFIN : # Saisie inutile si un seul site permis
  Else
    Actzo [DIA]FCYDEB, FCYFIN : # Activation saisie si plusieurs sites possibles
  Endif
  #----- Désactivation saisie types commande (un seul type est permis) -----#
  Grizo [DIA]TYPDEB, TYPFIN
Endif
End

Subprog AM_FCYDEB(VALEUR)
#------------------------#
# Après modif site début #
#------------------------#
Variable Char    VALEUR()
If VALEUR<>"" & ([M]FCYFIN="" | [M]FCYFIN<VALEUR)
  [M]FCYFIN=VALEUR : Affzo FCYFIN
Endif
End

Subprog C_FCYFIN(VALEUR)
#-------------------#
# Contrôle site fin #
#-------------------#
Variable Char    VALEUR()
If VALEUR<[M]FCYDEB
  GMESSAGE=mess(44,199,1) : mkstat=1
Endif
End

Subprog AM_DATDEB(VALEUR)
#------------------------#
# Après modif date début #
#------------------------#
Variable Date    VALEUR
If VALEUR<>[0/0/0] & ([M]DATFIN=[0/0/0] | [M]DATFIN<VALEUR)
  [M]DATFIN=VALEUR : Affzo DATFIN
Endif
End

Subprog C_DATFIN(VALEUR)
#-------------------------#
# Contrôle borne date fin #
#-------------------------#
Variable Date    VALEUR
If VALEUR<[M]DATDEB
  GMESSAGE=mess(44,199,1) : mkstat=1
Endif
End

Subprog AM_TYPDEB(VALEUR)
#------------------------------------#
# Après modif type de commande début #
#------------------------------------#
Variable Integer VALEUR
If VALEUR<>"" & ([M]TYPFIN="" | [M]TYPFIN<VALEUR)
  [M]TYPFIN=VALEUR : Affzo TYPFIN
Endif
End

Subprog C_TYPFIN(VALEUR)
#-------------------------------#
# Contrôle type de commande fin #
#-------------------------------#
Variable Integer VALEUR
If VALEUR<[M]TYPDEB
  GMESSAGE=mess(44,199,1) : mkstat=1
Endif
End

Subprog AM_CDEDEB(VALEUR)
#----------------------------#
# Après modif commande début #
#----------------------------#
Variable Char    VALEUR()
If VALEUR<>"" & ([M]CDEFIN="" | [M]CDEFIN<VALEUR)
  [M]CDEFIN=VALEUR : Affzo CDEFIN
Endif
End

Subprog C_CDEFIN(VALEUR)
#-----------------------#
# Contrôle commande fin #
#-----------------------#
Variable Char    VALEUR()
If VALEUR<[M]CDEDEB
  GMESSAGE=mess(44,199,1) : mkstat=1
Endif
End

Subprog AM_FOUDEB(VALEUR)
#----------------------------------#
# Après modif du fournisseur début #
#----------------------------------#
Variable Char    VALEUR()
If VALEUR<>"" & ([M]FOUFIN="" | [M]FOUFIN<VALEUR)
  [M]FOUFIN=VALEUR : Affzo FOUFIN
Endif
End

Subprog C_FOUFIN(VALEUR)
#-----------------------------#
# Contrôle du fournisseur fin #
#-----------------------------#
Variable Char    VALEUR()
If VALEUR<[M]FOUDEB
  GMESSAGE=mess(44,199,1) : mkstat=1
Endif
End

Subprog AM_ARTDEB(VALEUR)
#----------------------------#
# Après modif article début  #
#----------------------------#
Variable Char    VALEUR()
If VALEUR<>"" & ([M]ARTFIN="" | [M]ARTFIN<VALEUR)
  [M]ARTFIN=VALEUR : Affzo ARTFIN
Endif
End

Subprog C_ARTFIN(VALEUR)
#----------------------------#
# Contrôle borne article fin #
#----------------------------#
Variable Char    VALEUR()
If VALEUR<[M]ARTDEB
  GMESSAGE=mess(44,199,1) : mkstat=1
Endif
End

Subprog C_TOLERANCE(VALEUR)
#-------------------------------#
# Contrôle % tolérance quantité #
#-------------------------------#
Variable Decimal VALEUR
If VALEUR>100  mkstat=1 : Endif
End


#########################################################
# Sous-Programmes des actions sur champ de l'écran CLE2 #
#########################################################

Subprog C_NBLIG
#------------------------------#
# Contrôle sur numéro de ligne #
#------------------------------#

If status=7  End : Endif
# Issue 76621 - 2011-11-18 by MUARN : dimensionnement pour soldes des commandes
If nolign > dim([M:CLE2]PRO)
  nolign -=1
Endif
# fin 76621

If status>4 & [M:CLE2]POHNUM(nolign-1)=""
  mkstat=1 : End
Endif
End

Subprog IB_NBLIG
#----------------------------------------------------#
# Activation boutons "Détail" et "Traitement global" #
#----------------------------------------------------#
Raz GBOUT7, GBOUT8, GBOUT9, GBOUT10
GBOUT1=mess(65,198,1)  : # Détail
GBOUT2=mess(95,198,1)  : # Traitement global
If [M:CLE2]ENVCCE(nolign-1)<>""
  GBOUT7=mess(491,198,1)-[M:CLE2]ENVCCE(nolign-1) : # Enveloppe XXXXX
  GBOUT8=mess(494,198,1)                          : # Ligne budgétaire
Endif
If [M:CLE2]BUDACC(nolign-1)<>""
  GBOUT9=mess(493,198,1)-[M:CLE2]BUDACC(nolign-1) : # Compte XXXXXXXX
Endif
If [M:CLE2]CMMNUM(nolign-1)<>""
  GBOUT10=mess(160,198,1)-[M:CLE2]CMMNUM(nolign-1) : # Engagement XXXXX
Endif
End

Subprog B2_NBLIG
#------------------------------#
# Bouton 2 : Traitement global #
#------------------------------#
Local Shortint I
For I=0 To [M:CLE2]NBLIG-1
  Raz GBIDI1
  #---- Commande de contremarque, le besoin vente ne sera plus pris en compte -----#
  If [M:CLE2]SOHNUM(I)<>"" & [M:CLE2]PRO(I)=1 & [M:CLE2]LINCLEFLG<2
    Local Integer OK
    OK=1 : Call OUINON([M:CLE2]POHNUM(I)-mess(388,194,1),OK) From GESECRAN
    If OK=1  GBIDI1=1 : Endif
  #---- Autorisation du solde en inter-site ?
  Elsif [M:CLE2]BETFCY(I)=2 & [M:CLE2]LINOCNNUM(I)<>""
    Call CTLMAJSOP("S",[M:CLE2]LINOCNNUM(I),[M:CLE2]OCNLIN(I),[M:CLE2]OCNLIN(I),
&                  GBIDI1) From TRTVENISOC
  Endif
  If GBIDI1=0
    # Issue 97517 - 2014-03-05 by MUARN : ne pas annuler un solde sur un article non réceptionnable
    #If [M:CLE2]LINCLEFLG(I)<2 [M:CLE2]PRO(I)=2 Else [M:CLE2]PRO(I)=3 : Endif
    If [M:CLE2]LINCLEFLG(I)<2
      [M:CLE2]PRO(I)=2
    Else
      If [F:ITM]ITMREF<>[M:CLE2]ITMREF(I)
        Read [ITM] ITM0=[M:CLE2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
      Endif
      If [F:ITM]RCPFLG=2
        [M:CLE2]PRO(I)=3
      Endif
    Endif
  Endif
Next I
Affzo [CLE2]1-99
mkstat=4
End

Subprog B3_NBLIG
#------------------#
# Tri par commande #
#------------------#
Sorta [M:CLE2]NBLIG [M:CLE2]NBLIG Order By [M:CLE2]POHNUM(indice),
&                                          [M:CLE2]POPLIN(indice)
Affzo [CLE2]1-99
End

Subprog B4_NBLIG
#-------------------#
# Tri par enveloppe #
#-------------------#
Sorta [M:CLE2]NBLIG [M:CLE2]NBLIG Order By [M:CLE2]ENVCCE(indice),
&                                          [M:CLE2]POHNUM(indice),
&                                          [M:CLE2]POPLIN(indice)
Affzo [CLE2]1-99
End

Subprog B5_NBLIG
#----------------#
# Tri par entité #
#----------------#
Sorta [M:CLE2]NBLIG [M:CLE2]NBLIG Order By [M:CLE2]ENTCCE(indice),
&                                          [M:CLE2]POHNUM(indice),
&                                          [M:CLE2]POPLIN(indice)
Affzo [CLE2]1-99
End

Subprog B6_NBLIG
#---------------------------#
# Tri par compte budgétaire #
#---------------------------#
Sorta [M:CLE2]NBLIG [M:CLE2]NBLIG Order By [M:CLE2]BUDACC(indice),
&                                          [M:CLE2]POHNUM(indice),
&                                          [M:CLE2]POPLIN(indice)
Affzo [CLE2]1-99
End

Subprog IB_PRO
#---------------------------------------#
# Init bouton sur champ code traitement #
#---------------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8, GBOUT9, GBOUT10
GBOUT1=mess(65,198,1) : # Détail
End

Subprog C_PRO(VALEUR)
#--------------------------#
# Contrôle code traitement #
#--------------------------#
Variable Integer VALEUR
Local Shortint NOL : NOL=nolign-1
If VALEUR=2 & [M:CLE2]LINCLEFLG(NOL)=2
  GMESSAGE=mess(168,194,1) : mkstat=1 : VALEUR=1 : End : # Ligne déja soldée, ...
Endif
If VALEUR=3 & [M:CLE2]LINCLEFLG(NOL)=1
  GMESSAGE=mess(169,194,1) : mkstat=1 : VALEUR=1 : End : # Ligne non soldée, ...
Endif
# Issue 97517 - 2014-03-05 by MUARN : ne pas annuler un solde sur un article non réceptionnable
If VALEUR=3 & [M:CLE2]LINCLEFLG(NOL)=2
  If [F:ITM]ITMREF<>[M:CLE2]ITMREF(NOL)
    Read [ITM] ITM0=[M:CLE2]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
  Endif
  If [F:ITM]RCPFLG=1
    GMESSAGE=mess(471,194,1) : mkstat=1 : VALEUR=1 : End
  Endif
Endif
If VALEUR=1 : End : Endif
#---- Autorisation du solde en inter-site ?
If [M:CLE2]BETFCY(NOL)=2 & [M:CLE2]LINOCNNUM(NOL)<>""
  Raz GBIDI1
  # sr 03.12 Demande 80380 : On ne fait le controle que si demande de solde et ligne de commande de vente non soldée
  # ou demande de désolde et commande de vente soldée
  Read [SOQ]SOQ0=[M:CLE2]LINOCNNUM(NOL);[M:CLE2]OCNLIN(NOL);[M:CLE2]OCNLIN(NOL)
  If !fstat & ((VALEUR=2 & [F:SOQ]SOQSTA <> 3) |(VALEUR=3 & [F:SOQ]SOQSTA = 3))
      Call CTLMAJSOP("S",[M:CLE2]LINOCNNUM(NOL),[M:CLE2]OCNLIN(NOL),[M:CLE2]OCNLIN(NOL),
&                   GBIDI1) From TRTVENISOC
  Endif
  If GBIDI1<>0 : mkstat=1 : Endif
Endif
End

Subprog AM_PRO(VALEUR)
#------------------------------------#
# Après modification code traitement #
#------------------------------------#
Variable Integer VALEUR
If [M:CLE2]SOHNUM(nolign-1)<>"" & VALEUR=2
  Local Integer OK
  OK=1 : Call OUINON([M:CLE2]POHNUM(nolign-1)-mess(388,194,1),OK) From GESECRAN
  If OK=1  mkstat=1 : VALEUR=1 : End : Endif
Endif
End

