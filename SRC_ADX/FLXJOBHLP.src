#----------------------------------------------------
# FLXJOBHLP : Eléments liés à l'aide sur flux métier
#----------------------------------------------------

End

#-------------------------------------------------------------------------------------------
# AIDE_METIER : Appel de l'action d'affichage d'un document html xtend
#               avec détermination du bon code document en fonction des paramètres d'entrée
#-------------------------------------------------------------------------------------------
# MODE : 1 = aide sur variable métier
# ID1 / ID2 : Identifiants génériques
#             si mode = 1, ID1 = code liste variable, ID2 = code variable
#-------------------------------------------------------------------------------------------
Subprog AIDE_METIER(MODE, ID1, ID2)
Value Integer MODE
Value Char ID1(), ID2()

Case [L]MODE
    When 1
        Read [F:HRPVD]PVD1(2) = [L]ID1 ; [L]ID2
        If fstat = 0 & dim([F:HRPVD]DOCCOD) > 0 & [F:HRPVD]DOCCOD <> ""
            ## Action TRTDSPAYY
            Local Char    PARMSK(250)(1..20) , SAVACT(20), VALEUR(250)
            SAVACT = GACTION : GACTION = "TRTDSPAYY"
            PARMSK(1) = [F:HRPVD]DOCCOD
            PARMSK(2) = [V]GLANGUE
            Call SAISIE_CHAR(VALEUR,PARMSK,"TRTDSPAYY","TRTDSPAYY","") From GSAISIE
            GACTION = SAVACT
        Endif
Endcase

End

