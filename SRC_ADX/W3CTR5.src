$ON_SICSUBCLS
Onevent CONTROL Call C_SICSUBCLS(zc) From W3CTR5
Onevent BEFORE_INPUT Call AS_SICSUBCLS(zc) From W3CTR5
Onevent AFTER_CHANGE Gosub AMM_SICSUBCLS From W3CTR5
Return

Subprog AS_SICSUBCLS(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3623,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_SICSUBCLS(zc) From W3CTR5
Onkey   2 Titled GBOUTS Call S_SICSUBCLS(zc) From W3CTR5
Onkey 144 Titled GBOUTP Call P_SICSUBCLS(zc) From W3CTR5
Gosub _AFF
End

Subprog C_SICSUBCLS(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SICSUBCLS" : GZNUM = 55238 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTNUM("HRSIC","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "SICSUBCLS" : GZNUM = 55238 : Endif
Endif
Gosub _AFF
End

$AMM_SICSUBCLS
Call AM_SICSUBCLS(zc)
If !mkstat & GOBJET
 zoncou = "SICSUBCLS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SICSUBCLS(VALEUR)
Variable Decimal VALEUR
If !mkstat & evalue("dim("+clanam([M])+"ZSICSUBCLS)")>indice
 [M]SICSUBCLS(indice) = VALEUR
 Affzo ZSICSUBCLS(indice)
Endif
Gosub _AFF
End

Subprog S_SICSUBCLS(VALEUR)
Variable Decimal VALEUR
Local Char PARMSK(250)(1..16)
PARMSK(1) = "HRSIC"
PARMSK(2) = ""
Call S_TAB_NUM(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_SICSUBCLS(VALEUR)
Variable Decimal VALEUR
Local Char VALCHAR(20)
VALCHAR = num$(VALEUR)
Call OBJET("HRSIC",VALCHAR,"") From GOBJET
VALEUR = val(VALCHAR)
Gosub _AFF
End

Subprog P_SICSUBCLS(VALEUR)
Variable Decimal VALEUR
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRSIC",num$(VALEUR),PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZSICSUBCLS
Onevent BEFORE_AREA Gosub AV_ZSICSUBCLS From W3CTR5
Return

$AV_ZSICSUBCLS
If clalev([F:HRSIC])=0 : Local File HRSTDINDCLS [HRSIC] : Endif
Call LECTURE("HRSIC",num$([M]SICSUBCLS(indice)),"") From CONTOBJ
zc = [F:HRSIC]SICDES
Gosub _AFF
Return

$ON_SEZCOD
Onevent INIT_AREA Call D_SEZCOD(zc) From W3CTR5
Onevent CONTROL Call C_SEZCOD(zc) From W3CTR5
Onevent BEFORE_INPUT Call AS_SEZCOD(zc) From W3CTR5
Onevent AFTER_CHANGE Gosub AMM_SEZCOD From W3CTR5
Return

Subprog D_SEZCOD(VALEUR)
Variable Char    VALEUR()
If varinit([M]SEZCOD,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"11674","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_SEZCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"11674") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_SEZCOD(zc) From W3CTR5
Onkey   2 Titled GBOUTS Call S_SEZCOD(zc) From W3CTR5
Onkey 144 Titled GBOUTP Call P_SEZCOD(zc) From W3CTR5
Onkey 146 Titled GBOUTA Call SA_SEZCOD(zc) From W3CTR5
If VALEUR="" : Call INIADI(VALEUR,"11674") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_SEZCOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SEZCOD" : GZNUM = 55241 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"11674","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "SEZCOD" : GZNUM = 55241 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"11674",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "SEZCOD" : GZNUM = 55241 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_SEZCOD
Call AM_SEZCOD(zc)
If !mkstat & GOBJET
 zoncou = "SEZCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SEZCOD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZSEZCOD)")>indice
 [M]SEZCOD(indice) = VALEUR
 Affzo ZSEZCOD(indice)
Endif
Gosub _AFF
End

Subprog S_SEZCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "11674"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_SEZCOD(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"11674") From GOBJET
Gosub _AFF
End

Subprog SA_SEZCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "11674"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_SEZCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "11674"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZSEZCOD
Onevent BEFORE_AREA Gosub AV_ZSEZCOD From W3CTR5
Return

$AV_ZSEZCOD
Call LECTEXTRA(zc,"ATABDIV","LNGDES","11674",num$([M]SEZCOD(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_NSSCPY
Onevent CONTROL Call C_NSSCPY(zc) From W3CTR5
Onevent BEFORE_INPUT Call AS_NSSCPY(zc) From W3CTR5
Onevent AFTER_CHANGE Gosub AMM_NSSCPY From W3CTR5
Return

Subprog AS_NSSCPY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(46228,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NSSCPY(zc) From W3CTR5
Onkey   2 Titled GBOUTS Call S_NSSCPY(zc) From W3CTR5
Onkey 144 Titled GBOUTP Call P_NSSCPY(zc) From W3CTR5
Onkey 146 Titled GBOUTA Call SA_NSSCPY(zc) From W3CTR5
Gosub _AFF
End

Subprog C_NSSCPY(VALEUR)
Variable Char    VALEUR()
## Action CONTOBJN
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CONTOBJN"
Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "NSSCPY" : GZNUM = 34790 : Endif
If !mkstat
 ## Action CONTORG
 Call CONTORG(VALEUR) From SUBORG
 If mkstat : GERR = 1 : GZONE = "NSSCPY" : GZNUM = 34790 : Endif
Endif
Gosub _AFF
End

$AMM_NSSCPY
Call AM_NSSCPY(zc)
If !mkstat & GOBJET
 zoncou = "NSSCPY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NSSCPY(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZNSSCPY)")>indice
 [M]NSSCPY(indice) = VALEUR
 Affzo ZNSSCPY(indice)
Endif
Gosub _AFF
End

Subprog S_NSSCPY(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELORGLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELORGLEG"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELORGLEG","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_NSSCPY(VALEUR)
Variable Char    VALEUR()
Call OBJET("ORG",VALEUR,num$(GCURLEG)) From GOBJET
Gosub _AFF
End

Subprog SA_NSSCPY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ORG"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_NSSCPY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("ORG",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZNSSCPY
Onevent BEFORE_AREA Gosub AV_ZNSSCPY From W3CTR5
Return

$AV_ZNSSCPY
Call LECTEXTRA(zc,"ORGANISME","DES",num$(GCURLEG),num$([M]NSSCPY(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_SYNCOD
Onevent CONTROL Call C_SYNCOD(zc) From W3CTR5
Onevent BEFORE_INPUT Call AS_SYNCOD(zc) From W3CTR5
Onevent AFTER_CHANGE Gosub AMM_SYNCOD From W3CTR5
