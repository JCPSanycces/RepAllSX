#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR5 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_ZIRCTCOD
Onevent BEFORE_AREA Gosub AV_ZIRCTCOD From W3CTR5
Return

$AV_ZIRCTCOD
Call LECTEXTRA(zc,"ATABDIV","LNGDES","11557",num$([M]IRCTCOD(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_IRCTAPL
Onevent INIT_AREA Call D_IRCTAPL(zc) From W3CTR5
Onevent CONTROL Call C_IRCTAPL(zc) From W3CTR5
Onevent BEFORE_INPUT Call AS_IRCTAPL(zc) From W3CTR5
Onevent AFTER_CHANGE Gosub AMM_IRCTAPL From W3CTR5
Return

Subprog D_IRCTAPL(VALEUR)
Variable Char    VALEUR()
If varinit([M]IRCTAPL,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"11558","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_IRCTAPL(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"11558") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_IRCTAPL(VALEUR) From SUBCTR
If mkstat=2
 [M]IRCTAPL(INDIC) = VALEUR
 Affzo IRCTAPL(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_IRCTAPL(zc) From W3CTR5
Onkey   2 Titled GBOUTS Call S_IRCTAPL(zc) From W3CTR5
Onkey 144 Titled GBOUTP Call P_IRCTAPL(zc) From W3CTR5
Onkey 146 Titled GBOUTA Call SA_IRCTAPL(zc) From W3CTR5
Gosub _AFF
End

Subprog C_IRCTAPL(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"11558","") From SUBADI
If mkstat : GERR = 1 : GZONE = "IRCTAPL" : GZNUM = 55217 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"11558",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "IRCTAPL" : GZNUM = 55217 : Endif
 If !GWEBSERV
  If !mkstat
   ## Action STD
   Call C_IRCTAPL(VALEUR) From SUBCTR
   If mkstat : GERR = 1 : GZONE = "IRCTAPL" : GZNUM = 55217 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_IRCTAPL
Call AM_IRCTAPL(zc)
If !mkstat & GOBJET
 zoncou = "IRCTAPL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_IRCTAPL(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZIRCTAPL)")>indice
 [M]IRCTAPL(indice) = VALEUR
 Affzo ZIRCTAPL(indice)
Endif
Gosub _AFF
End

Subprog S_IRCTAPL(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "11558"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_IRCTAPL(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"11558") From GOBJET
Gosub _AFF
End

Subprog SA_IRCTAPL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "11558"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_IRCTAPL(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "11558"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZIRCTAPL
Onevent BEFORE_AREA Gosub AV_ZIRCTAPL From W3CTR5
Return

$AV_ZIRCTAPL
Call LECTEXTRA(zc,"ATABDIV","LNGDES","11558",num$([M]IRCTAPL(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_IRPSTRDAT
Onevent BEFORE_INPUT Call AS_IRPSTRDAT(zc) From W3CTR5
Onevent CONTROL Call C_IRPSTRDAT(zc) From W3CTR5
Return

Subprog AS_IRPSTRDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action SUBCTRLEG
Call BEFORE_ENTRY(VALEUR) From SUBCTRLEG
If mkstat=2
 [M]IRPSTRDAT(INDIC) = VALEUR
 Affzo IRPSTRDAT(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_IRPSTRDAT(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "IRPSTRDAT" : GZNUM = 55219 : Endif
If !mkstat
 ## Action STD
 Call C_IRPSTRDAT(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "IRPSTRDAT" : GZNUM = 55219 : Endif
Endif
Gosub _AFF
End

