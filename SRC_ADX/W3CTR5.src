Subprog C_IRPENDDAT(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "IRPENDDAT" : GZNUM = 55221 : Endif
If !mkstat
 ## Action STD
 Call C_IRPENDDAT(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "IRPENDDAT" : GZNUM = 55221 : Endif
Endif
Gosub _AFF
End

$ON_TAXSTA
Onevent BEFORE_INPUT Call AS_TAXSTA(zc) From W3CTR5
Onevent AFTER_CHANGE Gosub AMM_TAXSTA From W3CTR5
Onevent INIT_AREA Call D_TAXSTA(zc) From W3CTR5
Onevent CONTROL Call C_TAXSTA(zc) From W3CTR5
Return

Subprog D_TAXSTA(VALEUR)
Variable Integer VALEUR
If varinit([M]TAXSTA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TAXSTA(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(11659) From COMBOS
## Action STD
Call AS_TAXSTA(VALEUR) From SUBCTR
If mkstat=2
 [M]TAXSTA(INDIC) = VALEUR
 Affzo TAXSTA(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,11659,1))))
Endif
If !mkstat
 Discombo 0 From TAXSTA(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From TAXSTA(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_TAXSTA(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$AMM_TAXSTA
Call AM_TAXSTA(zc)
If !mkstat & GOBJET
 zoncou = "TAXSTA" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TAXSTA(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_TAXSTA(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "TAXSTA" : GZNUM = 56139 : Endif
Gosub _AFF
End

