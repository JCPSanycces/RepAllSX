$ON_TAXSTRDAT
Onevent BEFORE_INPUT Call AS_TAXSTRDAT(zc) From W3CTR5
Onevent CONTROL Call C_TAXSTRDAT(zc) From W3CTR5
Return

Subprog AS_TAXSTRDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_TAXSTRDAT(VALEUR) From SUBCTR
If mkstat=2
 [M]TAXSTRDAT(INDIC) = VALEUR
 Affzo TAXSTRDAT(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action SUBCTRLEG
 Call BEFORE_ENTRY(VALEUR) From SUBCTRLEG
 If mkstat=2
  [M]TAXSTRDAT(INDIC) = VALEUR
  Affzo TAXSTRDAT(INDIC) : mkstat = 2
 Endif
Endif
Gosub _AFF
End

Subprog C_TAXSTRDAT(VALEUR)
Variable Date    VALEUR
## Action STD
Call C_TAXSTRDAT(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "TAXSTRDAT" : GZNUM = 55173 : Endif
Gosub _AFF
End

$ON_TAXENDDAT
Onevent BEFORE_INPUT Call AS_TAXENDDAT(zc) From W3CTR5
Onevent CONTROL Call C_TAXENDDAT(zc) From W3CTR5
Return

Subprog AS_TAXENDDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_TAXENDDAT(VALEUR) From SUBCTR
If mkstat=2
 [M]TAXENDDAT(INDIC) = VALEUR
 Affzo TAXENDDAT(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action SUBCTRLEG
 Call BEFORE_ENTRY(VALEUR) From SUBCTRLEG
 If mkstat=2
  [M]TAXENDDAT(INDIC) = VALEUR
  Affzo TAXENDDAT(INDIC) : mkstat = 2
 Endif
Endif
Gosub _AFF
End

Subprog C_TAXENDDAT(VALEUR)
Variable Date    VALEUR
If !GWEBSERV
 ## Action STD
 Call C_TAXENDDAT(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "TAXENDDAT" : GZNUM = 55174 : Endif
Endif
Gosub _AFF
End

$TIT_COL
Gosub TIT_COL From W5CTR5
Return


