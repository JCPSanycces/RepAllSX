#########################################################################
#                                                                       #
#      TRAITEMENTS IMPRESSION dans les VENTES                           #
#                                                                       #
#########################################################################
#                                                                       #
# Subprog INIT_IMP (WABREV, WDEFDOC, WDEFIMP                            #
#      Recherche de l'imprimante et du nom de l'état par défaut         #
#                                                                       #
#                                                                       #
# Subprog INIT_ARP (WABREV, WDEFDOC)                                    #
#      Recherche du nom de l'état par défaut                            #
#                                                                       #
#########################################################################



#------------------------------------------------------------------#
#    N'est plus utilisé : A supprimer                              #
#------------------------------------------------------------------#
# Recherche de l imprimante par défaut                             #
# Recherche du nom de l'état par défaut                            #
#------------------------------------------------------------------#
# Entrée   WABREV  : Code objet                                    #
# Sortie   WDEFIMP : Imprimante par défaut                         #
#          WDEFDOC : Document par défaut                           #
#------------------------------------------------------------------#
Subprog INIT_IMP(WABREV, WDEFDOC, WDEFIMP)
Value    Char    WABREV
Variable Char    WDEFDOC
Variable Char    WDEFIMP

# On recherche s'il y a une imprimante par défaut
#If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif 
#Read [F:AUS]CODUSR = GUSER
#If fstat=0 WDEFIMP=[F:AUS]DEFIMP Endif

# On recherche les codes par défaut
If clalev([F:AOB])=0 : Local File AOBJET [AOB] : Endif 
Read [F:AOB]ABREV = WABREV 
If fstat=0 WDEFDOC=[F:AOB]RPT1 Endif

Local Integer WOBLIG
Local Char    WCOMPLEMENT(10)
Call DEFIMP(WDEFDOC,GUSER,WCOMPLEMENT,WDEFIMP,WOBLIG) From IMPRIME

End
#------------------------------------------------------------------#
#    N'est plus utilisé : A supprimer                              #
#------------------------------------------------------------------#
$CTL_DOCNAM
If !clalev([F:ARP]) : Local File AREPORT [ARP] : Endif   
Read [F:ARP]ARP0 = VALEUR
If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
#Call VERF_DROIT(VALEUR,GUSER,OK,AUTSIT) From ETAT    : # N'existe plus en V140
#If !OK 
#   GMESSAGE = mess(3,135,1)  : # Vous n'avez pas accès à cet état
#   mkstat = 1
#   End      
#Endif 
Return



#------------------------------------------------------------------#
# Recherche du nom de l'état par défaut                            #
#------------------------------------------------------------------#
# Entrée   WABREV  : Code objet                                    #
# Sortie   WDEFDOC : Document par défaut                           #
#------------------------------------------------------------------#
Subprog INIT_ARP(WABREV, WDEFDOC)
Value    Char    WABREV
Variable Char    WDEFDOC

# On recherche du nom de l'état par défaut
If clalev([F:AOB])=0 : Local File AOBJET [AOB] : Endif 
Read [F:AOB]ABREV = WABREV 
If fstat=0 WDEFDOC=[F:AOB]RPT1 Endif
End

#------------------------------------------------------------------#
# Recherche du nom de la liste par défaut                          #
#------------------------------------------------------------------#
# Entrée   WABREV  : Code objet                                    #
# Sortie   WDEFDOC : Document par défaut                           #
#------------------------------------------------------------------#
Subprog INIT_ARL(WABREV, WDEFDOC)
Value    Char    WABREV
Variable Char    WDEFDOC

# On recherche du nom de la liste par défaut
If clalev([F:AOB])=0 : Local File AOBJET [AOB] : Endif 
Read [F:AOB]ABREV = WABREV 
If fstat=0 WDEFDOC=[F:AOB]RPT2 Endif
End

#------------------------------------------------------------------#
# Recherche du serveur et imprimante                               #
#------------------------------------------------------------------#
# Entrée   WDEST    : Code objet                                   #
# Sortie   WSERVEUR : Serveur                                      #
# Sortie   WIMPRIM  : Imprimante                                   #
#------------------------------------------------------------------#
Subprog INIT_SRV(WDEST, WSERVEUR, WIMPRIM)
Value    Char    WDEST    
Variable Char    WSERVEUR
Variable Char    WIMPRIM

Raz WSERVEUR, WIMPRIM

If WDEST="" End Endif

# On recherche le serveur et la l'imprimante dans la destination
If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif 
Read [F:AIM]AIM0 = WDEST    
If fstat=0 
  WSERVEUR =[F:AIM]PRTSRV
  WIMPRIM  =[F:AIM]PRTNAM  
Endif
End

#------------------------------------------------------------------#
# Evaluation du complement                                         #
#------------------------------------------------------------------#
# E/S      COMPLEMENT  : formule pour le complement                #
#------------------------------------------------------------------#

Subprog COMPLEMENT(ETAT, COMPLEMENT)
Value    Char ETAT()
Variable Char COMPLEMENT()

Local Char    EXPRESSION(250) 

COMPLEMENT= ""
If clalev([F:ARP])=0 : Local File AREPORT  [ARP] : Endif
Read [F:ARP]ARP0 = ETAT 
If fstat            : End : Endif
If [F:ARP]PRTFRM="" : End : Endif
Call COMPLEMENT(COMPLEMENT) From AIMP1
End

Onerrgo RIEN
EXPRESSION = vireblc(format$("KT:250X",[F:ARP]PRTFRM),2)
COMPLEMENT = evalue(EXPRESSION)
Onerrgo
End

$RIEN
Resume

#################################################################################
$CTL_SRV
If GACTION="AFRQTPAR" & VALEUR="" mkstat=2 : GMESSAGE=mess(90,150,1) Endif
Return
#fq73266-Gbn
#**
#* Ce s/p retourne le nombre de copies paramétrées pour la destination
#* passée en paramètre.
#*
#* @param  PAIM     Destination
#* @return RNBRCPY  Nombre de copies défini pour la destination.
#*!
Funprog GET_NBRCPY_AIM(PAIM)
Value  Char    PAIM
Local  Integer RNBRCPY
 If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif 
 Read [F:AIM]AIM0 = PAIM    
 If fstat=0 : RNBRCPY =[F:AIM]NBRCPY : Endif
End RNBRCPY