#<AdxTL>@(#)0.0.0.0 $Revision$
Gosub TEST From ACLAVAL
End

#-------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$ADDCLB0
Append CLOB,LIGNE+chr$(10)
Return

#-------------------------------------------------------#
# Programme Read ETAG apellé par le superviseur
#-------------------------------------------------------#
$TRT_READ_ETAG
DIF = 0
NIVEAU = 1
PROGRAM = "_AREADETAG"
LIGNE = "" : Gosub ADDCLB
LIGNE = "############################################################################################"   : Gosub ADDCLB
LIGNE = "### Funprog "+PROGRAM  : Gosub ADDCLB
LIGNE = "############################################################################################"   : Gosub ADDCLB
LIGNE = "Funprog "+PROGRAM+"("+[L]ROOTNAM+',ACLE,ASTATUS,_ETAG)' : Gosub ADDCLB
LIGNE = "Variable Instance "+[L]ROOTNAM+" Using "+ACLA.ACLAV.NOMSTC : Gosub ADDCLB
LIGNE = "Value Char ACLE" : Gosub ADDCLB
LIGNE = "Variable Integer ASTATUS" : Gosub ADDCLB
LIGNE = "Variable Char _ETAG" : Gosub ADDCLB
LIGNE = "[L]ASTATUS = [V]CST_AOK" : Gosub ADDCLB
If ACLA.TYPCLA=5
 LIGNE = "Raz [L]_ETAG" :  Gosub ADDCLB
 LIGNE = "End [L]ASTATUS" : Gosub ADDCLB
 Return
Endif
For I=1 To ACLA.NBCLEREF
 J=find(ACLA.ACLAI(I).CLEREF ,ACLA.ACLAF(1..maxtab(ACLA.ACLAF)).FLDCLA)
 If J
  LIGNE = "Local"-func ACLAVALTRT.DECLARE_TYPTYP(ACLA.ACLAF(J).ATY.TYPTYP)-"_"+ACLA.ACLAI(I).CLEREF
  Case ACLA.ACLAF(J).ATY.TYPTYP
   When 7,4,5,6 : LIGNE + = "("+num$(ACLA.ACLAF(J).LON)+")"
  Endcase
  Gosub ADDCLB
 Endif
Next
LIGNE = "Gosub SET_CLE From ASYRSUB" : Gosub ADDCLB
For I=1 To ACLA.NBCLEREF
 LIGNE = "If [L]CLE("+num$(I)+')<>"" : [L]_'+ACLA.ACLAI(I).CLEREF+" = "
 J = find(ACLA.ACLAI(I).CLEREF,ACLA.ACLAF(1..maxtab(ACLA.ACLAF)).FLDCLA)
 If J
  Case ACLA.ACLAF(J).ATY.TYPTYP
   When 1,2,3     : LIGNE += "val(" : #"Integer"
   When 4,5,6     : LIGNE += "val(" : #"Decimal"
   When 7,11,12  : LIGNE += "num$(" : #"Char , UUid , DateTime
   When 8          : LIGNE += "func ASYRSUB.DATE_TO_ADX(" : #"Date"
   When 9,10      : LIGNE += "num$(" : #"Blbfile ,clob
  Endcase
 Else
  LIGNE += "num$("
 Endif
 LIGNE +=  "[L]CLE("+num$(I)+")) : Endif" : Gosub ADDCLB
 #104482
 If J
  If ACLA.ACLAF(J).ATY.TYPTYP=1 & (ACLA.ACLAF(J).ATY.NOLIB=1 | ACLA.ACLAF(J).NOLIB=1)
   LIGNE = "If [L]CLE("+num$(I)+')="false" : [L]_'+ACLA.ACLAI(I).CLEREF+" = 1 : Endif" : Gosub ADDCLB
   LIGNE = "If [L]CLE("+num$(I)+')="true" : [L]_'+ACLA.ACLAI(I).CLEREF+" = 2 : Endif" : Gosub ADDCLB
  Endif
 Endif
 #
Next
LIGNE = "Raz [L]_ETAG" :  Gosub ADDCLB
LIGNE = "Local File "+ACLA.ACLAK(NIVEAU).TABLNK-"["+ACLA.ACLAK(NIVEAU).ABRLNK+"]"  : Gosub ADDCLB
LIGNE = "Default File [F:"+ACLA.ACLAK( NIVEAU).ABRLNK+"]"  : Gosub ADDCLB
LIGNE = "Read [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).CLELNK-"= [L]_"+ACLA.ACLAK(NIVEAU).INDEX(1)
For I=2 To ACLA.ACLAK(NIVEAU).NBRIND
 LIGNE += ";[L]_"+ACLA.ACLAK(NIVEAU).INDEX(I)
Next I
Gosub ADDCLB
LIGNE = "If fstat" : Gosub ADDCLB
DIF += 1
LIGNE = "[L]ASTATUS = [V]CST_AERROR" : Gosub ADDCLB
DIF -= 1
LIGNE =  "Endif" : Gosub ADDCLB
LIGNE = "If [L]ASTATUS=[V]CST_AOK and dim([F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]UPDTICK)>0" : Gosub ADDCLB
DIF += 1
LIGNE = "[L]_ETAG = num$([F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]UPDTICK)": Gosub ADDCLB
DIF -= 1
LIGNE =  "Endif" : Gosub ADDCLB
LIGNE = "LogicClose File"-"["+ACLA.ACLAK(NIVEAU).ABRLNK+"]"
LIGNE = "End [L]ASTATUS" : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Programme Read apellé par le superviseur
#-------------------------------------------------------#
$TRT_READ_SUPER
DIF = 0
NIVEAU = 1
PROGRAM = "_AREADSUP"
LIGNE = "" : Gosub ADDCLB
LIGNE = "############################################################################################"   : Gosub ADDCLB
LIGNE = "### Subprog "+PROGRAM  : Gosub ADDCLB
LIGNE = "############################################################################################"   : Gosub ADDCLB
LIGNE = "Subprog "+PROGRAM+"("+[L]ROOTNAM+',ACLE,ASTATUS)' : Gosub ADDCLB
LIGNE = "Variable Instance "+[L]ROOTNAM+" Using "+ACLA.ACLAV.NOMSTC : Gosub ADDCLB
LIGNE = "Value Char ACLE" : Gosub ADDCLB
LIGNE = "Variable Integer ASTATUS" : Gosub ADDCLB
For I=1 To ACLA.NBCLEREF
 J=find(ACLA.ACLAI(I).CLEREF ,ACLA.ACLAF(1..maxtab(ACLA.ACLAF)).FLDCLA)
 If J
  LIGNE = "Local"-func ACLAVALTRT.DECLARE_TYPTYP(ACLA.ACLAF(J).ATY.TYPTYP)-"_"+ACLA.ACLAI(I).CLEREF
  Case ACLA.ACLAF(J).ATY.TYPTYP
   When 7,4,5,6 : LIGNE + = "("+num$(ACLA.ACLAF(J).LON)+")"
  Endcase
  Gosub ADDCLB
 Endif
Next
LIGNE = "Gosub SET_CLE From ASYRSUB" : Gosub ADDCLB
For I=1 To ACLA.NBCLEREF
 LIGNE = "If [L]CLE("+num$(I)+')<>"" : [L]_'+ACLA.ACLAI(I).CLEREF+" = "
 J = find(ACLA.ACLAI(I).CLEREF,ACLA.ACLAF(1..maxtab(ACLA.ACLAF)).FLDCLA)
 If J
  Case ACLA.ACLAF(J).ATY.TYPTYP
   When 1,2,3     : LIGNE += "val(" : #"Integer"
   When 4,5,6     : LIGNE += "val(" : #"Decimal"
   When 7,11,12  : LIGNE += "num$(" : #"Char , UUid , DateTime
   When 8          : LIGNE += "func ASYRSUB.DATE_TO_ADX(" : #"Date"
   When 9,10      : LIGNE += "num$(" : #"Blbfile ,clob
  Endcase
 Else
  LIGNE += "num$("
 Endif
 LIGNE +=  "[L]CLE("+num$(I)+")) : Endif" : Gosub ADDCLB
 #104482
 If J
  If ACLA.ACLAF(J).ATY.TYPTYP=1 & (ACLA.ACLAF(J).ATY.NOLIB=1 | ACLA.ACLAF(J).NOLIB=1)
   LIGNE = "If [L]CLE("+num$(I)+')="false" : [L]_'+ACLA.ACLAI(I).CLEREF+" = 1 : Endif" : Gosub ADDCLB
   LIGNE = "If [L]CLE("+num$(I)+')="true" : [L]_'+ACLA.ACLAI(I).CLEREF+" = 2 : Endif" : Gosub ADDCLB
  Endif
 Endif
 #
Next
LIGNE = '[L]ASTATUS = max([L]ASTATUS,fmet '+[L]ROOTNAM+'.'+[V]CST_APRGAREAD+'('+"[L]_"+ACLA.ACLAI(1).CLEREF
For I=2 To ACLA.NBCLEREF
 LIGNE += ",[L]_"+ACLA.ACLAI(I).CLEREF
Next
LIGNE += "))" : Gosub ADDCLB
LIGNE = "End" : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Programme d'entete du READ
#-------------------------------------------------------#
$START_READ
If ACLA.TEST : Call ECR_TRACE("- Create PRG : AREAD",0) From GESECRAN  : Endif
DIF = 0
NIVEAU = 1
PROGRAM = [V]CST_APRGAREAD : # Read
Gosub ENTETE_SUBPROG From ACLASUBCRUD
LIGNE = "If "+[L]ROOTNAM+".APARENT=null"   : Gosub ADDCLB
DIF += 1
LIGNE = "[L]A_I = "+[L]ROOTNAM+".freeSnapshot" : Gosub ADDCLB
LIGNE = [L]ROOTNAM+".snapshotEnabled = 0" : Gosub ADDCLB
LIGNE = [L]ROOTNAM+".setAccessorEnabled = 0" : Gosub ADDCLB
DIF -=1
LIGNE = "Endif"  : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Programme coeur du Read
#-------------------------------------------------------#
$TRT_READ
Gosub START_READ

LIGNE ="Gosub ATRT_AREAD" : Gosub ADDCLB
Gosub ERREUR_ACTION_GOTO From ACLASUBCRUD
LIGNE = "" : Gosub ADDCLB

Gosub END_READ

LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$ATRT_AREAD" : Gosub ADDCLB
If ACLA.TYPCLA=5
 For I=1 To ACLA.NBCLEREF
  LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAI(I).CLEREF-"= [L]_"+ACLA.ACLAI(I).CLEREF : Gosub ADDCLB
 Next
 LIGNE = "" : Gosub ADDCLB
Endif
LIGNE = "[L]ASTATUS = max([L]ASTATUS,fmet "+ACLA.ACLAK(NIVEAU).STRCUR+'._ACTION_PARAM("AREAD_BEFORE"'
For I=1 To ACLA.NBCLEREF
 LIGNE += ',[L]_'+ACLA.ACLAI(I).CLEREF
Next
LIGNE +='))' : Gosub ADDCLB
Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
LIGNE = "" : Gosub ADDCLB

If ACLA.TYPCLA=2 & ACLA.ACLAK(NIVEAU).FLGR = 2
 Gosub READ_TABLE_PRINCIPALE_PARAM From ACLASUBCRUD
 Gosub AJOUT_ACCES_SITE From ACLASUBCRUD
 Gosub ADD_UUID From ACLASUBCRUD
 For J=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
  If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY<>null
& & find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPTYP,9,10)>0

   #106394
   #If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBTAB=ACLA.ACLAK(NIVEAU).TABLNK
   #LIGNE = "Raz [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBFLD: Gosub ADDCLB
   #Endif
   LIGNE = "If dim([F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+")>0"
   LIGNE += ": Raz [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA
   LIGNE += ": Endif": Gosub ADDCLB

  Endif
 Next
 LIGNE = "SetInstance"-ACLA.ACLAK(NIVEAU).CLALNK-"With [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]" : Gosub ADDCLB
Else
 LIGNE = "[L]ASTATUS = max([L]ASTATUS,fmet "+ACLA.ACLAK(NIVEAU).STRCUR+'._ACTION_PARAM("AREAD"'
 For I=1 To ACLA.NBCLEREF
  LIGNE += ',[L]_'+ACLA.ACLAI(I).CLEREF
 Next
 LIGNE +='))' : Gosub ADDCLB
 #Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM,"","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Endif
LIGNE = ACLA.ACLAK(NIVEAU).CLALNK+".ASTALIN = [V]CST_ALL" : Gosub ADDCLB
If ACLA.TYPCLA=2
 Raz TABPARCOURS
 For I=2 To maxtab(ACLA.ACLAK)
  If !find(ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK-ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,TABPARCOURS)
   ATBDES    = ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK
   ATBORI    = ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI
   NIVPARCOURS = 2
   Call PRG_AREAD(ATBORI,ATBDES,ACLA,PROGRAM,I,NIVPARCOURS,TABPARCOURS,NBFOR,CLOB,DIF)
  Endif
 Next I
Endif

DIF = 0
NIVEAU = 1
LIGNE = "" : Gosub ADDCLB
If ACLA.TYPCLA=2
  #### Mise a jour Uuid des tableaaux de propriété
 Gosub MAJREADCOL
 # Action AFTER READ
 Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM+"_AFTER","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 LIGNE = ""  : Gosub ADDCLB
 ### Ajout lecture des champs AX*
 Gosub ATEXTRA From ACLATXTCRUD
 ### Ajout lecture des champs ATX
 Gosub ATEXTE From ACLATXTCRUD
 ### Ajout code d'accés
 #Gosub ADDACSFIELD
 LIGNE = "" : Gosub ADDCLB
Elsif ACLA.TYPCLA=5
  # Action AFTER READ
 Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM+"_AFTER","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 LIGNE = ""  : Gosub ADDCLB
Endif
LIGNE = "Return" : Gosub  ADDCLB
LIGNE = ""  : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Fin du read
#-------------------------------------------------------#
$END_READ
If ACLA.FLGBUFFER<>2
 LIGNE = "If [L]ASTATUS<[V]CST_AERROR & " + [L]ROOTNAM+".APARENT=null"   : Gosub ADDCLB
 DIF +=1
 LIGNE = "# Load Link"  : Gosub ADDCLB
 LIGNE = "[L]ASTATUS = max([L]ASTATUS,fmet "+[L]ROOTNAM+"."+ACLA.ACLAV.TBMET(11)+")" : Gosub ADDCLB :  # A_LNKPRO
 LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : Goto "+PROGRAM+"_END : Endif" : Gosub ADDCLB
 DIF -=1
 LIGNE = "Endif"  : Gosub ADDCLB
Endif
LIGNE = ""  : Gosub ADDCLB
LIGNE = "$"+PROGRAM+"_END" : Gosub ADDCLB
If ACLA.FLGBUFFER<>2
 LIGNE = "If "+[L]ROOTNAM+".APARENT=null"   : Gosub ADDCLB
 DIF += 1
 LIGNE = [L]ROOTNAM+".snapshotEnabled = 1" : Gosub ADDCLB
 LIGNE = [L]ROOTNAM+".setAccessorEnabled = 1" : Gosub ADDCLB
 DIF -= 1
 LIGNE = "Endif"   : Gosub ADDCLB
Endif
Gosub CLOSELOGICFILE From ACLASUBCRUD
LIGNE = "End"   : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#-------------------------------------------------------#
# New instance du READ
#-------------------------------------------------------#
$NEW_INSTANCE
If ACLA.ACLAK(NIVEAU).REFLNK<>""
 LIGNE = ACLA.ACLAK(NIVEAU).STRCUR-'= NewInstance  C_'+ACLA.ACLAK(NIVEAU).CLALNK+'('+ACLA.ACLAK(1).CLALNK+".ACTX,NullUuid,[L]A_N"+num$(NIVPARCOURS)+','
& +ACLA.ACLAK(NIVEAU).STRCURFAT+',"'
& +ACLA.ACLAK(NIVEAU).PTRLNK+'")'-[V]CST_ALLOCGROUP-ACLA.ACLAK(1).CLALNK
 Gosub ADDCLB
 LIGNE = "[L]ASTATUS = max([L]ASTATUS,fmet "+ACLA.ACLAK(NIVEAU).STRCUR+".ADDINSTANCE_BOUND)"  : Gosub ADDCLB
Endif
Return

#-------------------------------------------------------#
# Sous-programme recusive lecture
#-------------------------------------------------------#
Subprog PRG_AREAD(ATBORI,ATBDES,ACLA,PROGRAM,NIVEAU,NIVPARCOURS,TABPARCOURS,NBFOR,CLOB,DIF)
Value    Char     ATBORI
Value    Char     ATBDES
Value    Instance ACLA Using C_ACLA
Value    Char     PROGRAM
Value    Integer  NIVEAU
Variable Integer  NIVPARCOURS
Variable Char     TABPARCOURS
Variable Integer  NBFOR
Variable Clbfile  CLOB
Variable Integer DIF

Gosub PRG_DEB From ACLAVALCRUD

LIGNE = "If [L]A_LEVEL>="+num$(NIVPARCOURS) : Gosub ADDCLB
DIF += 1

LIGNE = "Default File [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]" : Gosub ADDCLB

If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4) : #  For
 ISFOR = 1 : NBFOR +=1
 If ACLA.ACLAK(NIVEAU).EXPSEL<>"" : LIGNE = "Filter [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"] Where"-ACLA.ACLAK(NIVEAU).EXPSEL : Gosub ADDCLB : Endif
 LIGNE = "[L]A_N"+num$(NIVPARCOURS)+"=0"  : Gosub ADDCLB
 LIGNE = "For [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"
 LIGNE += ACLA.ACLAK(NIVEAU).CLESORT-"Where"-ACLA.ACLAK(NIVEAU).FLDSORT(1)+"="+ACLA.ACLAK(NIVEAU).EXPR(1)
 If ACLA.ACLAK(NIVEAU).NBREXP> 1
  For I=2 To ACLA.ACLAK(NIVEAU).NBREXP
   LIGNE += " &"-ACLA.ACLAK(NIVEAU).FLDSORT(I)+"="+ACLA.ACLAK(NIVEAU).EXPR(I)
  Next I
 Endif
 Gosub ADDCLB
 DIF += 1
 LIGNE = "[L]A_N"+num$(NIVPARCOURS)-"+=1"   :  Gosub ADDCLB
 If ACLA.ACLAK(NIVEAU).STRCURDIM>0
  LIGNE = "If [L]A_N"+num$(NIVPARCOURS)+">="+num$(DIMCUR)+" : Break"-num$(NIVPARCOURS-1)-": Endif"  : Gosub ADDCLB
 Endif
Elsif find(ACLA.ACLAK(NIVEAU).TYPLNK,1,3) : # Read
 ISFOR = 0
 If ACLA.ACLAK(NIVEAU).EXPSEL<>"" : LIGNE = "Filter [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"] Where"-ACLA.ACLAK(NIVEAU).EXPSEL : Gosub ADDCLB : Endif
 LIGNE = "[L]A_N"+num$(NIVPARCOURS)+"="
 If ACLA.ACLAK(NIVEAU).DIMCLALNK=2
  LIGNE += "0"
 Else
  LIGNE += "1"
 Endif
 Gosub ADDCLB
 LIGNE = "Read [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).CLELNK-"="-ACLA.ACLAK(NIVEAU).EXPR(1)
 If ACLA.ACLAK(NIVEAU).NBREXP> 1
  For I=2 To ACLA.ACLAK(NIVEAU).NBREXP
   LIGNE += ";"+ACLA.ACLAK(NIVEAU).EXPR(I)
  Next I
 Endif
 Gosub ADDCLB
 LIGNE = "If !fstat"  : Gosub ADDCLB
 DIF += 1
Endif

If ACLA.ACLAK(NIVEAU).TYPLNK<>3
 Gosub NEW_INSTANCE
Endif

If ACLA.ACLAK(NIVEAU).FLGR = 2
 If ACLA.ACLAK(NIVEAU).FLGA=2
  LIGNE = "Callmet "+ACLA.ACLAK(NIVEAU).STRCUR+"."+PROGRAM+"([F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAI(1).CLEREF
  For I=2 To ACLA.ACLAK(NIVEAU).ACLALNK.NBCLEREF
   LIGNE += ",[F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAI(I).CLEREF
  Next I
  LIGNE += ")"  : Gosub ADDCLB
 Elsif ACLA.ACLAK(NIVEAU).FLGA<>2
  Gosub ADD_UUID From ACLASUBCRUD
  LIGNE = "SetInstance"-ACLA.ACLAK(NIVEAU).STRCUR-"With [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]": Gosub ADDCLB
 Else
  Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM,"","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
  Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 Endif
Else
 If ACLA.ACLAK(NIVEAU).REFLNK<>""
  Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM,"","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
  Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 Endif
Endif


If ACLA.ACLAK(NIVEAU).FLGR = 2 & ACLA.ACLAK(NIVEAU).FLGA <> 2
 #### Mise a jour Uuid des tableaaux de propriété
  Gosub MAJREADCOL
Endif

If   ACLA.ACLAK(NIVEAU).FLGR = 2 &  ACLA.ACLAK(NIVEAU).FLGA<>2 # & find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4) &
 Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM+"_AFTER","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Endif

LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN = [V]CST_ALL" : Gosub ADDCLB

### Boucle récusivre vers les sous-structures
For I=1 To maxtab(ACLA.ACLAK)
 If ACLA.ACLAK(I).TABORI=func ACLASUBCRUD.TABLE(ATBDES) & ACLA.ACLAK(I).ABRORI=func ACLASUBCRUD.ABREV(ATBDES)
  NIVPARCOURS +=1
  Call PRG_AREAD(ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK,ACLA,PROGRAM,I,NIVPARCOURS,TABPARCOURS,NBFOR,CLOB,DIF)
  NIVPARCOURS -=1
 Endif
Next I

If ACLA.ACLAK(NIVEAU).FLGR = 2 & ACLA.ACLAK(NIVEAU).FLGA <> 2
 ### Ajout lecture des champ AX*
 Gosub ATEXTRA From ACLATXTCRUD
 ### Ajout lecture des champ ATX
 Gosub ATEXTE From ACLATXTCRUD
 ##" ajout code d'accés
 Gosub ADDACSFIELD
Endif

For I=1 To 16
 If ACLA.ACLAK(NIVEAU).INDEX(I)<>""
  If ACLA.ACLAK(NIVEAU).PROMAP(I)<>""
   LIGNE = "[L]ASTATUS = max([L]ASTATUS,fmet "+ACLA.ACLAK(NIVEAU).STRCUR+'.ASETATTRIBUTE("'+ACLA.ACLAK(NIVEAU).INDEX(I)+'","$namProParent","'+ACLA.ACLAK(NIVEAU).PROMAP(I)+'"))' : Gosub ADDCLB
  Else : # 102158 CCL
   If ACLA.ACLAK(NIVEAU).FLGA=2 & ACLA.ACLAK(NIVEAU).FLGV<>2
    LIGNE = "[L]ASTATUS = max([L]ASTATUS,fmet "+ACLA.ACLAK(NIVEAU).STRCUR+'.ASETATTRIBUTE("'+ACLA.ACLAK(NIVEAU).INDEX(I)+'","$isDisabled","true"))' : Gosub ADDCLB
   Endif
  Endif
 Endif
Next

If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4)  : #  For mess(00112,00143,1) : Référence $1$ n'est pas valide
 DIF -= 1 : LIGNE = "Next"-ACLA.ACLAK(NIVEAU).ABRLNK : Gosub ADDCLB
 ISFOR = (find(ACLA.ACLAK(find(ACLA.ACLAK(NIVEAU).TABORI,ACLA.ACLAK(1..maxtab(ACLA.ACLAK)).TABLNK)).TYPLNK,2,4)) :  NBFOR -= 1
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Elsif find(ACLA.ACLAK(NIVEAU).TYPLNK,1,3) : # read
 If ACLA.ACLAK(NIVEAU).TYPLNK=3
  DIF -= 1
  LIGNE = "Elsif fstat" : Gosub ADDCLB
  DIF += 1
  LIGNE = '[L]ASTATUS = max([L]ASTATUS,fmet '+ACLA.ACLAK(NIVEAU).STRCUR+'.ASETERROR("",func ASYRFNC.MES1(mess(00112,00143,1),"'+ACLA.ACLAK(NIVEAU).REFLNK+'")+" : "+num$('+ACLA.ACLAK(NIVEAU).EXPR(1)+
& ")" : Gosub
& ADDCLB
  For I=2 To ACLA.ACLAK(NIVEAU).NBREXP
   LIGNE = '&'+space$(DIF)+'+"~"+num$('+ACLA.ACLAK(NIVEAU).EXPR(I)+")" : Gosub ADDCLB0
  Next I
  LIGNE =  '&'+space$(DIF)+'-":"-func ASYRFNC.MES1(mess(93,140,1),"'+ACLA.ACLAK(NIVEAU).TABLNK+'"),[V]CST_AWARNING))' : Gosub ADDCLB0
 Endif
 DIF -= 1 : LIGNE = "Endif" : Gosub ADDCLB
Endif

If ACLA.ACLAK(NIVEAU).EXPSEL<>"" :  LIGNE = "Filter [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]" : Gosub ADDCLB : Endif

DIF -=1 : LIGNE = "Endif" :  Gosub ADDCLB

If DIF=0
 LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
Else
 LIGNE = "#-----------------------#" : Gosub ADDCLB
Endif

End

#-------------------------------------------------------#
# Mise a jour des tableaaux de propriété
#-------------------------------------------------------#
$MAJREADCOL
Local Integer OKCOL
For I=1 To ACLA.ACLAK(NIVEAU).ACLALNK.NBRGRP
 If ACLA.ACLAK(NIVEAU).ACLALNK.CRECLAGRP(I)=2
  Raz OKCOL,LIGNE
  For M=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
   If  ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).LNKCLA="" & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDGRP=ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)
    Read [F:ATZ]CODZONE = ACLA.ACLAK(NIVEAU).TABLNK;ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDCLA
    If !fstat or  ACLA.ACLAK(NIVEAU).ACLALNK.MINGRP(I)=3
     LIGNE = "[L]A_NEWCOL = 0"  : Gosub ADDCLB
     LIGNE = "For [L]A_I=1 To "
     If ACLA.ACLAK(NIVEAU).ACLALNK.PROGRP(I)<>""
      If ACLA.ACLAK(NIVEAU).ACLALNK.MAXGRP(I)>0
       LIGNE += "min("+num$(ACLA.ACLAK(NIVEAU).ACLALNK.MAXGRP(I))+","+ ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.PROGRP(I)+")"
      Endif
     Elsif ACLA.ACLAK(NIVEAU).ACLALNK.MAXGRP(I)>0
      LIGNE += num$(ACLA.ACLAK(NIVEAU).ACLALNK.MAXGRP(I))
     Else
      LIGNE += "dim([F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDCLA+")"
     Endif
     Gosub ADDCLB
     OKCOL = 1
     Break
    Endif
   Endif
  Next
  DIF += 1
  Gosub MAJREADCOL_PRO
  DIF -= 1
  If OKCOL>0 : LIGNE = "Next" : Gosub ADDCLB : Endif
 Endif
Next
Return

#-------------------------------------------------------#
$MAJREADCOL_PRO
Local Integer J,M,K
LIGNE = ""
If ACLA.ACLAK(NIVEAU).ACLALNK.PROGRP(I)="" & ACLA.ACLAK(NIVEAU).ACLALNK.MINGRP(I)<>3
 For M=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
  If !find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).CODTYP,"AX1","AX2","AX3","AXX") & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).LNKCLA="" & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDGRP=ACLA.ACLAK(NIVEAU).ACLALNK
& .CODGRP(I) & !find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).ATY.TYPTYP,9,10,12)
   Read [F:ATZ]CODZONE = ACLA.ACLAK(NIVEAU).TABLNK;ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDCLA
   If !fstat
    OKCOL=1
    If len(LIGNE)>100
     If K=0
      Gosub ADDCLB
      K=1
     Else
      LIGNE = "&"-LIGNE
      Gosub ADDCLB0
     Endif
     Raz LIGNE
    Endif
    J+=1
    If J=1
     LIGNE += "If ("
    Elsif J>1
     LIGNE += " or "
    Endif
    LIGNE += "[F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDCLA+"([L]A_I-1)"
    LIGNE +="<>"
    Case ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).ATY.TYPTYP
     When 1   : # MENU Local
      LIGNE += "0"
     When 2   : # ENTIER COURT
      LIGNE += "0"
     When 3   : # ENTIER LONG
      LIGNE += "0"
     When 4   : # DÉCIMAL
      LIGNE += "0"
     When 5   : # FLOTTANT
      LIGNE += "0"
     When 6   : # Double
      LIGNE += "0"
     When 7   : # ALPHANUMÉRIQUE
      LIGNE += '""'
     When 8   : # Date
      LIGNE += "[00/00/0000]"
     When 9   : # BLOB
     When 10  : # CLOB
     When 11  : # Uuid
      LIGNE += "NullUuid"
     When 12  : # Datetime
    Endcase
   Endif
  Endif
 Next
Endif
If OKCOL>0
 If LIGNE<>""
  If J>0 :  LIGNE +=")" : Endif
  If K=0 or ACLA.ACLAK(NIVEAU).ACLALNK.PROGRP(I)<>""
   Gosub ADDCLB
  Else
   LIGNE = "&"-LIGNE
   Gosub ADDCLB0
  Endif
  DIF +=1
 Endif
 LIGNE = "[L]A_NEWCOL += 1" : Gosub ADDCLB
 LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"(A_NEWCOL)"
 LIGNE += ' = NewInstance  C_'+ACLA.ACLAK(NIVEAU).CLALNK+"_"+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)
& +'('+ACLA.ACLAK(1).CLALNK+".ACTX,NullUuid,[L]A_I"+','
& +ACLA.ACLAK(NIVEAU).STRCUR+',"'
& +ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+'")'-[V]CST_ALLOCGROUP-ACLA.ACLAK(1).CLALNK
 Gosub ADDCLB
 For M=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
  If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDGRP=ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)
   If  !find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).CODTYP,"AX1","AX2","AX3","AXX","ATX")
    Read [F:ATZ]CODZONE = ACLA.ACLAK(NIVEAU).TABLNK;ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDCLA
    If !fstat
     LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"(A_NEWCOL)"
     LIGNE += "."+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDCLA-"= [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDCLA+"([L]A_I-1)"
     Gosub ADDCLB
    Endif
   Endif
  Endif
 Next
 Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"(A_NEWCOL)",PROGRAM+"_AFTER","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 For M=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
  If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDGRP=ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)
   If find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).CODTYP,"AX1","AX2","AX3","AXX","ATX")
    Call ATEXTE_PROG( ACLA.ACLAK(NIVEAU).ABRLNK,NIVPARCOURS,ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"(A_NEWCOL)",PROGRAM,NIVEAU,ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M),ISFOR,
& NBFOR,LIGNE,CLOB,DIF) From ACLATXTCRUD
    Call ATEXTRA_PROG(NIVPARCOURS,ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"(A_NEWCOL)",PROGRAM,NIVEAU,ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M),ISFOR,
& NBFOR,ACLA.ACLAK(NIVEAU).ACLALNK,LIGNE,CLOB,DIF) From ACLATXTCRUD
   Endif
  Endif
 Next
 If J>0 : DIF -=1 : LIGNE = "Endif" : Gosub ADDCLB : Endif
Endif
Return

#-------------------------------------------------------#
# Ajout attributs co
#-------------------------------------------------------#
$ADDACSFIELD
Return
Local Char TABACS(GLONACS)(1..)
Raz I
For M=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
 If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).ACS<>"" & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).LNKCLA="" & !find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).ACS,TABACS)
  I +=1
  TABACS(I) = ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).ACS
 Endif
Next
For J=1 To I
 LIGNE = 'If fmet '+ACLA.ACLAK(NIVEAU).STRCUR+'.ACTX.AGETACSRIGHTC('+ACLA.ACLAK(NIVEAU).STRCUR+',"'+TABACS(J)+'",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
 DIF +=1
 For M=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
  If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).ACS=TABACS(J) & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).LNKCLA=""
   LIGNE = '[L]ASTATUS = max([L]ASTATUS,fmet '+ACLA.ACLAK(NIVEAU).STRCUR +'.ASETATTRIBUTE("'+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDCLA+'","$isHidden","true"))' : Gosub ADDCLB
  Endif
 Next
 DIF -=1
 LIGNE = 'Elsif fmet '+ACLA.ACLAK(NIVEAU).STRCUR+'.ACTX.AGETACSRIGHTM('+ACLA.ACLAK(NIVEAU).STRCUR+',"'+TABACS(J)+'",[V]CST_AFALSE)>=[V]CST_AERROR' : Gosub ADDCLB
 DIF +=1
 For M=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
  If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).ACS=TABACS(J) & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).LNKCLA=""
   LIGNE = '[L]ASTATUS = max([L]ASTATUS,fmet '+ACLA.ACLAK(NIVEAU).STRCUR +'.ASETATTRIBUTE("'+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDCLA+'","$isReadOnly","true"))' : Gosub ADDCLB
  Endif
 Next
 DIF -=1
 LIGNE = "Endif" : Gosub ADDCLB
Next
Return

