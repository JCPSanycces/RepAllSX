#<AdxTL>@(#)6.0.0.0 $Revision$
#<AdxTL>@(#)6.0.0.0 $Revision$
#----------------------------------------------------------------#
# Convert a query Instance to a JSON clob
#----------------------------------------------------------------#

Subprog QUERY_JSON(REP,WQRY,PQRY,PSYR,WCLOB)
Variable Instance  REP       Using C_AREPENT
Variable Instance  WQRY(1..) Using =func SUBASW.PREFIX_REP+REP.REP
Variable Instance  PQRY      Using C_AQUERY
Variable Instance  PSYR      Using C_ASYR
Variable Clbfile   WCLOB

Local Instance  JSO(1..) Using C_ASYRJSO

Local Integer I , J , K , D
Local Integer IND , TYP , MNL , REF , TIT , FIN
Local Char    VRA(250) , VRB(250) , VRC(250) , NAMTAB(250)
Local Integer VRI , LOU , NBK
Local Integer MAXKEY , MAXTAG , MAXPRO
MAXTAG = 30
MAXKEY = 20
MAXPRO = 250
Local Integer NBQT , NBPT , NBPR , TBPR(1..MAXPRO)
Local Char    TBQT(10)(1..MAXTAG) , TBPT(10)(1..MAXTAG)
Local Char    TBLOO(30)(1..MAXKEY) , CURPRO(30) , TBLNK(30)(1..MAXKEY)
Local Char    REPCUR(GLONASW) , INSPAR(250) , INSCLA(30)
Local Char    QPARAMS(250) , WCHAINE(250)

Gosub INIVAR From ASYRJSO
REPCUR = REP.REP

Gosub LOAD_JSON_CLASS

Call GENERATE_JSON(TBNIV(1),WCLOB) From ASYRJSO

End

#---------------------------------#
$LOAD_JSON_CLASS

# Params
For J=1 To maxtab(PQRY.QPARAMS)
 If PQRY.QPARAMS(J)="" : Break : Endif
 QPARAMS += "&" + PQRY.QPARAMS(J)
Next

# Tags on query

NBQT = 0
For J=1 To maxtab(PQRY.QTAGS)
 If PQRY.QTAGS(J)="" : Break : Endif
 NBQT += 1 : TBQT(NBQT) = PQRY.QTAGS(J)
Next

# Select properties

NBPR = 0
For P=1 To maxtab(REP.PRO)
 If REP.PRO(P).REP=REPCUR
&& ((REP.PRO(P).QRY=2 & REP.FCT="$query") or (REP.PRO(P).LOO=2 & REP.FCT="$lookup"))
  OK = 0
  If NBQT>1 & REP.PRO(P).TAG<>""
   WCHAINE = PQRY.TAGS
   NBPT = 0
   While WCHAINE<>""
    NBPT += 1
    K = instr(1,WCHAINE,",")
    If K
     TBPT(NBPT) = left$(WCHAINE,K-1)
     WCHAINE = right$(WCHAINE,K+1)
    Else
     TBPT(NBPT) = WCHAINE
     WCHAINE = ""
    Endif
   Wend
   For I=1 To NBQT
    If find(TBQT(I),TBPT(1..NBPT))
     OK = 1 : Break
    Endif
   Next I
  Else
   OK = 1
  Endif
  If OK
   NBPR += 1
   TBPR(NBPR) = P
  Endif
 Endif
Next P

# Header
NIV = 1
NODEPRO = '' : Gosub ADDOBJECT From ASYRJSO

# > SAM 97609  *************
# SAM 97609 : $totalResults has to be present in the query payload
# If and ONLY If ITS Value IS KNOWN
#If PQRY.QTOTAL<PQRY.QCOUNT : #it is the only case when the value is known
# NODEPRO = '"$totalResults"' :
# NODENVAL =  PQRY.QTOTAL
# Gosub ADDNUMBER From ASYRJSO
#Endif
# < SAM 97609  *************

NODEPRO = '"$itemsPerPage"'
NODENVAL =  PQRY.QCOUNT
Gosub ADDNUMBER From ASYRJSO

# Ressources

D = 0
INSCLA = REP.ICL

If PQRY.QASCEND=1 : # bacward
 #96897 IND = PQRY.QCOUNT+1:#maxtab(WQRY)+1
 IND = PQRY.QTOTAL+1:#maxtab(WQRY)+1
 FIN = 1
Else : # forward
 IND = 0
 #96897 FIN = PQRY.QCOUNT :#maxtab(WQRY)
 FIN = PQRY.QTOTAL :#maxtab(WQRY)
Endif

NODEPRO = '"$resources"'
Gosub ADDARRAY From ASYRJSO

While IND<>FIN

 If PQRY.QASCEND=1 : # Previous
  IND -= 1
 Else
  IND += 1
 Endif

 INSPAR = "WQRY("+num$(IND)+")"

 NODEPRO = "" : Gosub ADDOBJECT From ASYRJSO

 # Header

 Gosub HEADER From ASYRDATDET

 # Datas not reference

 For P=1 To NBPR
  VRI = TBPR(P)
  REF = (REP.PRO(VRI).PLK=2)
  If !REF
   TYP = REP.PRO(VRI).TYP
   VRB = INSPAR+"."+REP.PRO(VRI).PTH
   VRC = REP.PRO(VRI).PRO
   Gosub VALUES From ASYRDATDET
  Endif
 Next P

 # Datas reference

 For P=1 To NBPR
  VRI = TBPR(P)
  REF = (REP.PRO(VRI).PLK=2)
  If REF
   TYP = REP.PRO(VRI).TYP
   VRB = INSPAR+"."+REP.PRO(VRI).PTH
   VRC = REP.PRO(VRI).PRO
   Gosub PROPERTY From ASYRDATDET
  Endif
 Next P

 Gosub ENDNIV From ASYRJSO

Wend

Gosub ENDNIV From ASYRJSO

# Next
 Local Instance  JSOLINKS Using C_ASYRJSO : JSOLINKS = null

If maxtab(WQRY)>0 :#& (PQRY.QNEXTK<>"" or PQRY.QPREVIOUSK<>"")
 NODEPRO = '"$links"'
 Gosub ADDOBJECT From ASYRJSO

 JSOLINKS = PJSON

 If PQRY.QNEXTK<>""
  NODEPRO = '"$next"'
  Gosub ADDOBJECT From ASYRJSO

  NODEPRO = '"$url"'
  NODESVAL = '"' + baseUrl + '/' +REP.CLA+PSYR.URLREP+REP.REP+'.'+REP.FCT+QPARAMS+'&key='+ func ASYRJSO.ENCODE_URL(PQRY.QNEXTK):#SAM 118497
  If PQRY.QORDER<>""
   NODESVAL += "&orderBy="+PQRY.QORDER
  Endif
  If PQRY.QWHERE <> ""
   NODESVAL += "&where="+func ASYRJSO.ENCODE_URL(PQRY.QWHERE)
  Endif
  NODESVAL += '"'
  Gosub ADDSTRING From ASYRJSO
  NODEPRO = '"$type"'
  NODESVAL = '"'+PSYR.PRELNK+'"'
  Gosub ADDSTRING From ASYRJSO
  Gosub ENDNIV From ASYRJSO
 Endif
 If PQRY.QPREVIOUSK<>""
  NODEPRO = '"$previous"'
  Gosub ADDOBJECT From ASYRJSO

  NODEPRO = '"$url"'
  NODESVAL = '"' + baseUrl + '/' +REP.CLA+PSYR.URLREP+REP.REP+'.'+REP.FCT+QPARAMS+'&key='+ func ASYRJSO.ENCODE_URL(PQRY.QPREVIOUSK):#SAM 118497
  If PQRY.QORDER<>""
   NODESVAL += "&orderBy="+PQRY.QORDER
  Endif
  If PQRY.QWHERE <> ""
   NODESVAL += "&where="+func ASYRJSO.ENCODE_URL(PQRY.QWHERE)
  Endif
  If PQRY.QFILTER <> ""
   NODESVAL += "&filter="+PQRY.QFILTER
  Endif
  NODESVAL += '"'
  Gosub ADDSTRING From ASYRJSO
  NODEPRO = '"$type"'
  NODESVAL = '"'+PSYR.PRELNK+'"'
  Gosub ADDSTRING From ASYRJSO
  Gosub ENDNIV From ASYRJSO

  #First element:
  NODEPRO = '"$first"'
  Gosub ADDOBJECT From ASYRJSO

  NODEPRO = '"$url"'
  NODESVAL = '"' + baseUrl + '/' +REP.CLA+PSYR.URLREP+REP.REP+'.'+REP.FCT+QPARAMS
  If PQRY.QORDER<>""
   NODESVAL += "&orderBy="+PQRY.QORDER
  Endif
  If PQRY.QWHERE <> ""
   NODESVAL += "&where="+func ASYRJSO.ENCODE_URL(PQRY.QWHERE)
  Endif
   If PQRY.QFILTER <> ""
   NODESVAL += "&filter="+PQRY.QFILTER
  Endif
  NODESVAL += '"'
  Gosub ADDSTRING From ASYRJSO


  NODEPRO = '"$type"'
  NODESVAL = '"'+PSYR.PRELNK+'"'
  Gosub ADDSTRING From ASYRJSO
  Gosub ENDNIV From ASYRJSO
  #first
 Endif

 If PQRY.QLASTK<>""
  NODEPRO = '"$last"'
  Gosub ADDOBJECT From ASYRJSO

  #TODO
  NODEPRO = '"$url"'
  NODESVAL = '"' + baseUrl + '/' +REP.CLA+PSYR.URLREP+REP.REP+'.'+REP.FCT+QPARAMS+'&key='+ func ASYRJSO.ENCODE_URL(PQRY.QLASTK):#SAM 118497
  If PQRY.QORDER<>""
   NODESVAL += "&orderBy="+PQRY.QORDER
  Endif
  If PQRY.QWHERE <> ""
   NODESVAL += "&where="+func ASYRJSO.ENCODE_URL(PQRY.QWHERE)
  Endif
  If PQRY.QFILTER <> ""
   NODESVAL += "&filter="+PQRY.QFILTER
  Endif
  NODESVAL += '"'
  Gosub ADDSTRING From ASYRJSO
  NODEPRO = '"$type"'
  NODESVAL = '"'+PSYR.PRELNK+'"'
  Gosub ADDSTRING From ASYRJSO
  Gosub ENDNIV From ASYRJSO
 Endif

 Gosub ENDNIV From ASYRJSO
Endif

If JSOLINKS <> null & JSOLINKS.SUB = null
 Local Clbfile EMPTY :EMPTY='{}'
 Callmet JSOLINKS.ASETCNT(EMPTY)
Endif
# Prototype

If maxtab(WQRY)>0 & 1=0
 NODEPRO = '"$prototype"'
 Gosub ADDOBJECT From ASYRJSO

 NODEPRO = '"$title"'
 NODESVAL = '"Prototype"'
 Gosub ADDSTRING From ASYRJSO
 NODEPRO = '"$url"'
 NODESVAL = '"{$baseUrl}$prototypes('+"'"+REPCUR+".$query')"+'"'
 Gosub ADDSTRING From ASYRJSO
 NODEPRO = '"$type"'
 WCHAINE = "fmet "+INSPAR+".STAMP"
 Gosub EVAL_METHOD
 NODESVAL = '"{$baseType}.modified='+WCHAINE+'"'
 Gosub ADDSTRING From ASYRJSO
 Gosub ENDNIV From ASYRJSO
Endif

Return

#----------------------------#
$EVAL_METHOD
Onerrgo ERR
WCHAINE = num$(evalue(WCHAINE))
Onerrgo
Return

$ERR
WCHAINE = ""
Resume

