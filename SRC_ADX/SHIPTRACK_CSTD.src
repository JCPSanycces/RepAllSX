##########################################################################################
$TRKLIGSTAT_INIT
this.TRKLIGSTAT = 1
Return
##########################################################################################
$UPDATE_DEP
Local Integer WPOSITION
Local Integer WTRKSORT_CUR,  WTRKSORT_NEW
Local Char WTRKCOD(20)

For I=1 To maxtab(this.APARENT.SHIPT)
#mise à jour des dépendances
If this.APARENT.SHIPT(I).TRKDEPLIN <> AVOID.ADEC & this.APARENT.SHIPT(I).TRKDEPCOD<>AVOID.ACHAR
  WIND = find(this.APARENT.SHIPT(I).TRKDEPLIN, this.APARENT.SHIPT(1..maxtab(this.APARENT.SHIPT)).STLIN)
  If WIND <> 0
    WTRKSORT_NEW   = this.APARENT.SHIPT(WIND).TRKSORT
    WTRKDEPCOD = this.APARENT.SHIPT(I).TRKDEPCOD
    WPOSITION = instr(1,this.APARENT.SHIPT(I).TRKDEPCOD,"/")
    If WPOSITION > 0
      WTRKCOD = left$(this.APARENT.SHIPT(I).TRKDEPCOD,WPOSITION-1)
      WTRKSORT_CUR = val(right$(this.APARENT.SHIPT(I).TRKDEPCOD,WPOSITION +1))
    Endif
    If WTRKSORT_CUR <> WTRKSORT_NEW
      this.APARENT.SHIPT(I).TRKDEPCOD = WTRKCOD +"/"+num$(WTRKSORT_NEW)
    Endif
  Endif
Endif
Next
Return
##########################################################################################
# Issue 53814_2 - 2017-09-11 by MAE : controles déplacés
$CONTROLE_DEP
Local Integer WPOSITION, WTRKDEPCOD,I

For I=1 To maxtab(this.SHIPT)

If this.SHIPT(I).TRKDEPCOD<>AVOID.ACHAR
  WPOSITION = instr(1,this.SHIPT(I).TRKDEPCOD,"/")
  If WPOSITION > 0
    WTRKDEPCOD = val(right$(this.SHIPT(I).TRKDEPCOD,WPOSITION +1))
  Endif
  WIND = find(WTRKDEPCOD,this.SHIPT(1..maxtab(this.SHIPT)).TRKSORT)
  If WIND = AVOID.ADEC
    ASTATUS = fmet this.SHIPT(I).ASETERROR(CURPRO, mess(562,194,1), [V]CST_AERROR)
    Return
  Else
    If this.SHIPT(WIND).TRKMDY <> CST_AYES
     ASTATUS = fmet this.ASETERROR(CURPRO, mess(558,194,1), [V]CST_AERROR)
     Return
    Endif
    If this.SHIPT(WIND).TRKSORT >= this.SHIPT(I).TRKSORT
     ASTATUS = fmet this.ASETERROR(CURPRO, mess(563,194,1), [V]CST_AERROR)
     Return
    Endif
  Endif
Endif

Next I
Return
# End issue 53814_2

