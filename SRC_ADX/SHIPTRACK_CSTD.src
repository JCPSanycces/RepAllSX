#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SHIPTRACK


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
    When "AUPDATE_CONTROL_AFTER" Gosub AUPDATE_CONTROL_AFTER
    When "AINSERT_CONTROL_AFTER" Gosub AINSERT_CONTROL_AFTER
    When "ADELETE_CONTROL_AFTER" Gosub ADELETE_CONTROL_AFTER
    When "AUPDATE_BEFORE"        Gosub AUPDATE_BEFORE
    When "AINSERT_BEFORE"        Gosub AINSERT_BEFORE
    When "ADELETE_BEFORE"        Gosub ADELETE_BEFORE

    Endcase
Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "TRKDEPCOD"
   Case [L]ARULE
    When "PROPAGATE"      Gosub TRKDEPCOD_PROPAGATE
    # Issue 53814 - 2017-09-05 by MAE : controle sur les dépendances
    #When "CONTROL"        Gosub TRKDEPCOD_CONTROL
   Endcase
  When "TRKLIGSTAT"
   Case [L]ARULE
    When "INIT"           Gosub TRKLIGSTAT_INIT
   Endcase
Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
Endcase
Return
##########################################################################################
$AINSERT_BEFORE
Gosub UPDATE_DEP

Return
##########################################################################################
$AINSERT_CONTROL_AFTER
#contrôle sur les dépendances
WIND = find(this.TRKDEPLIN, this.APARENT.SHIPT(1..maxtab(this.APARENT.SHIPT)).STLIN)
If WIND <> 0
  If this.APARENT.SHIPT(WIND).TRKMDY<> CST_AYES
    WMESSAGE = mess(558,194,1)
    ASTATUS = fmet this.ASETERROR(CURPRO, WMESSAGE, [V]CST_AERROR)
    Return
  Endif
  If this.APARENT.SHIPT(WIND).TRKSORT >= this.TRKSORT
    WMESSAGE = mess(563,194,1)
    ASTATUS = fmet this.ASETERROR(CURPRO, WMESSAGE, [V]CST_AERROR)
    Return
  Endif
Endif

Return

##########################################################################################
$AUPDATE_CONTROL_AFTER
#contrôle sur les dépendances
WIND = find(this.TRKDEPLIN, this.APARENT.SHIPT(1..maxtab(this.APARENT.SHIPT)).STLIN)
If WIND <> 0
  If this.APARENT.SHIPT(WIND).TRKMDY<> CST_AYES
    WMESSAGE = mess(558,194,1)
    ASTATUS = fmet this.ASETERROR(CURPRO, WMESSAGE, [V]CST_AERROR)
    Return
  Endif
  If this.APARENT.SHIPT(WIND).TRKSORT >= this.TRKSORT
    WMESSAGE = mess(563,194,1)
    ASTATUS = fmet this.ASETERROR(CURPRO, WMESSAGE, [V]CST_AERROR)
    Return
  Endif
Endif
If this.TRKCOD<> this.snapshot.TRKCOD
  #the line is the mother of another one ?
     WIND = find(this.STLIN, this.APARENT.SHIPT(1..maxtab(this.APARENT.SHIPT)).TRKDEPLIN)
     If WIND <> 0
      WMESSAGE = mess(9,123,1) +" : "+ mess(559,194,1)
      ASTATUS = fmet this.ASETERROR(CURPRO, WMESSAGE, [V]CST_AERROR)
      Return
    Endif
Endif

Return
##########################################################################################
$AUPDATE_BEFORE
Gosub UPDATE_DEP

Return
##########################################################################################
$ADELETE_CONTROL_AFTER
Local Char WMESSAGE (250)
Local Integer WIND
#deletion is impossible if the line is competed
If this.TRKENDDAT <> AVOID.ADATE
  WMESSAGE = mess(1,115,1)+" : "+ mess(561,194,1)
  ASTATUS = fmet this.ASETERROR(CURPRO, WMESSAGE, [V]CST_AERROR)
  Return
Endif
#deletion is impossible if the line is a mother of another one
WIND = find(this.STLIN, this.APARENT.SHIPT(1..maxtab(this.APARENT.SHIPT)).TRKDEPLIN)
If WIND <> 0
  WMESSAGE = mess(1,115,1) +" : "+ mess(559,194,1)
  ASTATUS = fmet this.ASETERROR(CURPRO, WMESSAGE, [V]CST_AERROR)
  Return
Endif
Return
##########################################################################################
$ADELETE_BEFORE
Gosub UPDATE_DEP

Return
##########################################################################################
$TRKDEPCOD_PROPAGATE
Local Char WMESSAGE (250)
Local Integer WIND, WPOSITION
If this.TRKDEPCOD<>AVOID.ACHAR & this.TRKDEPCOD<>this.snapshot.TRKDEPCOD
    WPOSITION = instr(1,this.TRKDEPCOD,"~")
    If WPOSITION > 0
      WRET = fmet this.ADELETEERROR([V]CST_ALLERRORS)
      this.TRKDEPLIN = val(right$(this.TRKDEPCOD,WPOSITION + 1))
      this.TRKDEPCOD = left$(this.TRKDEPCOD,WPOSITION - 1)
    Else
      WMESSAGE = mess(564,194,1)
      ASTATUS = fmet this.ASETERROR("", WMESSAGE, [V]CST_AERROR)
      Return
    Endif
Elsif this.TRKDEPCOD = AVOID.ACHAR & this.TRKDEPCOD<>this.snapshot.TRKDEPCOD  # Issue 53814
    this.TRKDEPLIN = AVOID.ADEC   # Issue 53814
    this.TRKDEPCOD = AVOID.ACHAR  # Issue 53814
Endif
Return
##########################################################################################
