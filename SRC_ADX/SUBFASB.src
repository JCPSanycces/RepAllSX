########################################
Subprog AS_NB_PCPF
Local Integer I_PLN

# FQ88264 : les plans sont modifiables indépendamment
#  # FQ80825 Si législation Russe : seul le plan comptable est modifiable
#  If ([M:FPC]LEG = "RUS" )  Then
#    For I_PLN = 1 To NB_PCPF
#       Affzo [M:FASB]KSTPDEPSTAN(I_PLN)
#       Diszo [M:FASB]KSTPDEPSTAN(I_PLN)
#    Next
#  Endif
End

########################################
Subprog AS_KSTPDEPSTAN(VALEUR)
Variable Integer VALEUR
Local Integer I_PLN

#   GVML_SSNOSTP  PAS EN ARRET  (Default)
#   GVML_SSMODER  MODERNISATION (Russe)
#   GVML_SSCONSE  CONSERVATION (Russe)
#   GVML_SSMOSTP  ARRETE MODERNISATION (Russe)
#   GVML_SSCOSTP  ARRETE CONSERVATION (Russe)
#   GVML_SSMORST  REDEMARRER MODERNISATION (Russe)
#   GVML_SSCORST  REDEMARRER CONSERVATION (Russe)
#   GVML_SSMRSTR  REDEMARRE MODERNISATION avec rattrapage (Russe)
#   GVML_SSCRSTR  REDEMARRE CONSERVATION avec rattrapage (Russe)
#   GVML_SSTOSTP  SUSPENDRE (Roumain)
#   GVML_SSSTOPD  ARRETE (Roumain)
#   GVML_SSRSTPR  REDEMARRER PROLONGATION (Roumain)
#   GVML_SSRSTDI  REDEMARRER DUREE INITIALE (Roumain)
#   GVML_SSNSTPP  AMORTI PROLONGATION (Roumain)
#   GVML_SSTSTPP  SUSPENDRE PROLONGATION (Roumain)
#

    If ( 1 = 0 ) Then
      # Russie
      GMENLOC(GVML_SSNOSTP) = 1
      GMENLOC(GVML_SSMODER) = 1
      GMENLOC(GVML_SSCONSE) = 1
      GMENLOC(GVML_SSMOSTP) = 1
      GMENLOC(GVML_SSCOSTP) = 1
      GMENLOC(GVML_SSMORST) = 1
      GMENLOC(GVML_SSCORST) = 1
      # Roumanie
      GMENLOC(GVML_SSNOSTP) = 1
      GMENLOC(GVML_SSTOSTP) = 1
      GMENLOC(GVML_SSSTOPD) = 1
      GMENLOC(GVML_SSRSTPR) = 1
      GMENLOC(GVML_SSRSTDI) = 1
      GMENLOC(GVML_SSNSTPP) = 1
      GMENLOC(GVML_SSTSTPP) = 1
    Endif

    #- 1----------------------
    If ([M:FPC]LEG = "RUS" )  Then
      #  Si Législation Russe : on ne présente pas les postes réservés aux modes roumains
      GMENLOC(GVML_SSTOSTP) = 1   # SUSPENDRE (Roumain)
      GMENLOC(GVML_SSSTOPD) = 1   # ARRETé (Roumain)
      GMENLOC(GVML_SSRSTPR) = 1   # REDEMARRER PROLONGATION (Roumain)
      GMENLOC(GVML_SSRSTDI) = 1   # REDEMARRER DUREE INITIALE (Roumain)
      GMENLOC(GVML_SSTSTPP) = 1   # SUSPENDRE PROLONGATION (Roumain)
      GMENLOC(GVML_SSNSTPP) = 1   # AMORTI PROLONGATION (Roumain)
      GMENLOC(GVML_SSTSTPP) = 1   # SUSPENDRE PROLONGATION (Roumain)

      # FQ88264 : les plans sont modifiables indépendamment
#      #  Seul l'état du plan comptable est modifable
#      For I_PLN = 1 To NB_PCPF
#        Diszo [M:FASB]KSTPDEPSTAN(I_PLN)
#      Next
    Endif
    #- 1----------------------

    #- 1----------------------
    If ( G_ACTDRO = G_OUI and [M:FPC]LEG = "RUM" )  Then
      #  Si Législation Roumaine : on ne présente pas les postes réservés aux modes russes
      GMENLOC(GVML_SSMODER) = 1   #   MODERNISATION (Russe)
      GMENLOC(GVML_SSCONSE) = 1   #   CONSERVATION (Russe)
      GMENLOC(GVML_SSMOSTP) = 1   #   ARRETE MODERNISATION (Russe)
      GMENLOC(GVML_SSCOSTP) = 1   #   ARRETE CONSERVATION (Russe)
      GMENLOC(GVML_SSMORST) = 1   #   REDEMARRER MODERNISATION (Russe)
      GMENLOC(GVML_SSCORST) = 1   #   REDEMARRER CONSERVATION (Russe)
    Endif
    #- 1----------------------

    # "Pas en arrêt" Etat commun aux deux législations
    If ( VALEUR = GVML_SSNOSTP  ) Then
      # Si Pas en arrêt
      #GMENLOC(GVML_SSNOSTP) = 1
      If ([M:FPC]LEG = "RUS" )  Then
        # Valeurs possibles : Modernisation, Conservation
      GMENLOC(GVML_SSMOSTP) = 1
      GMENLOC(GVML_SSCOSTP) = 1
      GMENLOC(GVML_SSMORST) = 1
      GMENLOC(GVML_SSCORST) = 1
    Endif
      If ( G_ACTDRO = G_OUI and [M:FPC]LEG = "RUM" )  Then
        # Valeurs possibles : Suspendre
        GMENLOC(GVML_SSSTOPD) = 1
        GMENLOC(GVML_SSRSTPR) = 1
        GMENLOC(GVML_SSRSTDI) = 1
        GMENLOC(GVML_SSNSTPP) = 1
        GMENLOC(GVML_SSTSTPP) = 1
      Endif
    Endif

    #- 1------------------------------
    If ([M:FPC]LEG = "RUS" )  Then
      # Lesgislation russe
    If ( VALEUR  = GVML_SSMODER or VALEUR  = GVML_SSCONSE  ) Then
      # Si Modernisation ou Conservation : Pas en arrêt
      GMENLOC(GVML_SSMODER) = 1
      GMENLOC(GVML_SSCONSE) = 1
      GMENLOC(GVML_SSMOSTP) = 1
      GMENLOC(GVML_SSCOSTP) = 1
      GMENLOC(GVML_SSMORST) = 1
      GMENLOC(GVML_SSCORST) = 1
      Elsif ( VALEUR = GVML_SSMOSTP  ) Then
      # Si Arrêté modernisation : Redémarré Modernisation
      GMENLOC(GVML_SSNOSTP) = 1
      GMENLOC(GVML_SSMODER) = 1
      GMENLOC(GVML_SSCONSE) = 1
      GMENLOC(GVML_SSMOSTP) = 1
      GMENLOC(GVML_SSCOSTP) = 1
      GMENLOC(GVML_SSCORST) = 1
      Elsif ( VALEUR = GVML_SSCOSTP  ) Then
      # Si Arrêté Conservation : Redémarré Conservation
      GMENLOC(GVML_SSNOSTP) = 1
      GMENLOC(GVML_SSMODER) = 1
      GMENLOC(GVML_SSCONSE) = 1
      GMENLOC(GVML_SSMOSTP) = 1
      GMENLOC(GVML_SSCOSTP) = 1
      GMENLOC(GVML_SSMORST) = 1
      Elsif ( VALEUR = GVML_SSMORST  ) Then
      # Si Redémarré modernisation : Arrêté Modernisation
      GMENLOC(GVML_SSNOSTP) = 1
      GMENLOC(GVML_SSMODER) = 1
      GMENLOC(GVML_SSCONSE) = 1
      GMENLOC(GVML_SSCOSTP) = 1
      GMENLOC(GVML_SSMORST) = 1
      GMENLOC(GVML_SSCORST) = 1
      Elsif ( VALEUR = GVML_SSCORST  ) Then
      # Si Redémarré Conservation : Arrêté Conservation
      GMENLOC(GVML_SSNOSTP) = 1
      GMENLOC(GVML_SSMODER) = 1
      GMENLOC(GVML_SSCONSE) = 1
      GMENLOC(GVML_SSMOSTP) = 1
      GMENLOC(GVML_SSMORST) = 1
      GMENLOC(GVML_SSCORST) = 1
    Endif
    Endif
    #- 1------------------------------

    #- 1------------------------------
    If ( G_ACTDRO = G_OUI and [M:FPC]LEG = "RUM" )  Then
      # Législation roumaine
      If ( VALEUR = GVML_SSTOSTP ) Then
        # Si Suspendre : Pas en arrêt, inchangé
        GMENLOC(GVML_SSSTOPD) = 1
        GMENLOC(GVML_SSRSTPR) = 1
        GMENLOC(GVML_SSRSTDI) = 1
        GMENLOC(GVML_SSNSTPP) = 1
        GMENLOC(GVML_SSTSTPP) = 1
      Elsif ( VALEUR = GVML_SSSTOPD ) Then
        # Si Arrêté : Redémarrer, Redémarrer prolongation, inchangé

        # Une seule et même politique de redémarrage
        If !clalev([F:K32]) : Local File EFASRURST [K32] : Endif
        # Lecture EFASRURST pour l'exercice et la période correspondant au dernier mouvement
        Filter [K32] Where REF = [M:FAS0]AASREF and DPRPLN= [M:FASB]DPRPLN(nolign-1)
        Read [K32]EVE0 Last
        Filter [K32]
        If not(fstat) Then
          If ([F:K32]KSTPDEPSTA = GVML_SSRSTDI) Then
            GMENLOC(GVML_SSRSTPR) = 1
          Endif
          If ([F:K32]KSTPDEPSTA = GVML_SSRSTPR) Then
            GMENLOC(GVML_SSRSTDI) = 1
          Endif
        Endif

        GMENLOC(GVML_SSNOSTP) = 1
        GMENLOC(GVML_SSTOSTP) = 1
        GMENLOC(GVML_SSNSTPP) = 1
        GMENLOC(GVML_SSTSTPP) = 1
        Close File [K32]
      Elsif ( VALEUR = GVML_SSRSTDI or VALEUR = GVML_SSRSTPR ) Then
        # Si Redémarrer ou Redémarrer prolongation : Arrêté, Redémarrer, Redémarrer prolongation
        GMENLOC(GVML_SSNOSTP) = 1
        GMENLOC(GVML_SSTOSTP) = 1
        GMENLOC(GVML_SSNSTPP) = 1
        GMENLOC(GVML_SSTSTPP) = 1
      Elsif ( VALEUR = GVML_SSNSTPP ) Then
        # Si Amorti prolongation : Suspendre prolongation, inchangé
        GMENLOC(GVML_SSNOSTP) = 1
        GMENLOC(GVML_SSTOSTP) = 1
        GMENLOC(GVML_SSSTOPD) = 1
        GMENLOC(GVML_SSRSTPR) = 1
        GMENLOC(GVML_SSRSTDI) = 1
      Elsif ( VALEUR = GVML_SSTSTPP ) Then
        # Si Suspendre prolongation : Amorti prolongation, inchangé
        GMENLOC(GVML_SSNOSTP) = 1
        GMENLOC(GVML_SSTOSTP) = 1
        GMENLOC(GVML_SSSTOPD) = 1
        GMENLOC(GVML_SSRSTPR) = 1
        GMENLOC(GVML_SSRSTDI) = 1
      Endif
    Endif
    #- 1------------------------------
End

######################################################################################
Subprog AM_KSTPDEPSTAN(VALEUR)
Variable Integer VALEUR
Local Integer I_PLN, I

  # FQ88264 : les plans sont modifiables indépendamment
#  If ([M:FPC]LEG = "RUS") Then
#    # FQ80825 Report de la saisie sur les plans autres que le comptable
#    For  I = 1 To NB_PCPF
#      [M:FASB]KSTPDEPSTAN(I-1)  = VALEUR
#      Affzo [M:FASB]KSTPDEPSTAN(I-1)
#    Next
#  Endif
End

######################################################################################
