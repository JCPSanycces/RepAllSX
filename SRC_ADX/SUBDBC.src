######################################################################################################

$ACTION
    Case ACTION
        When "INIT"    : Gosub INIT
        When "DEBUT"   : Gosub DEBUT
        When "OK"      : Gosub OK
        When Default
    Endcase
Return
#########################################################################
# Initialize tables and variables
#########################################################################
$INIT
    If clalev([F:BPS]) = 0 Then : Local File BPSUPPLIER [BPS] : Endif
    If clalev([F:BPC]) = 0 Then : Local File BPCUSTOMER [BPC] : Endif
Return

#########################################################################
# Initialize mask
#########################################################################
$DEBUT
    [M:DBC]BPTYP = 1
    [M:DBC]CNT = rowcount([F:BPS]) + rowcount([F:BPC])
    Affzo [M:DBC]CNT
Return

##################################################################################################
# If button OK is clicked execute grabbing of the data depending on the builded criteria string
################################################################################################
$OK
    Local Integer I
    Local Char CRITERE(250)
    Local Tinyint CRITTYPE
    # build criteria string for filtering BP tables
    If [M:DBC]BPTYP = 1 Then
      Gosub SETCUSTOMER
      Gosub SETSUPPLIER
    Elsif [M:DBC]BPTYP = 2
        Gosub SETCUSTOMER
#
    Else
      Gosub SETSUPPLIER
#
    Endif
    #Read [F:DTB] Where 1 = 1
    Raz [M:DTB]
    [L]I = [M:DTB]NBLIG
    For [F:DTB]
      [M:DTB]BPRNUM([L]I) = [F:DTB]BPRNUM
      [M:DTB]ACCDATEV([L]I) = val([F:DTB]ACCDATEV)
      [M:DTB]NBLIG += 1
      I+=1
    Next
    Affzo [M:DTB]
Return

$SETCUSTOMER
  CRITTYPE = 1
  Gosub BUILD_CRITERIA
  Filter [F:BPC] Where evalue([L]CRITERE)
  For [F:BPC]BPC0
      Read [F:DTB]DTB0 = [F:BPC]BPCNUM
      If fstat = 0 Then
          # remove existing entries if flag DELASS is ticked
          If [M:DBC]DELASS = [V]CST_AYES Then
              Raz [F:DTB]ACCDATEV
              Trbegin [F:DTB]
              Rewrite [F:DTB]
              If fstat = 0 Then
                  Commit
              Else
                  Rollback
                  Break
              Endif
          Endif
      Else
          Raz [F:DTB]
          [F:DTB]BPRNUM  = [F:BPC]BPCNUM
          Trbegin [F:DTB]
          Write [F:DTB]
          If fstat = 0 Then
              Commit
          Else
              Rollback
              Break
          Endif
      Endif
  Next
  Filter [F:BPC]
Return
$SETSUPPLIER
  [L]CRITTYPE = 2
  Gosub BUILD_CRITERIA
  Filter [F:BPS] Where evalue([L]CRITERE)
  For [F:BPS]BPS0
      Read [F:DTB]DTB0 = [F:BPS]BPSNUM
      If fstat = 0 Then
          # remove existing entries if flag DELASS is ticked
          If [M:DBC]DELASS = [V]CST_AYES Then
              Raz [F:DTB]ACCDATEV
              Trbegin [F:DTB]
              Rewrite [F:DTB]
              If fstat = 0 Then
                  Commit
              Else
                  Rollback
                  Break
              Endif
          Endif
      Else
          # insert
          Raz [F:DTB]
          [F:DTB]BPRNUM = [F:BPS]BPSNUM
          Trbegin [F:DTB]
          Write [F:DTB]
          If fstat = 0 Then
              Commit
          Else
              Rollback
              Break
          Endif
      Endif
  Next
  Filter [F:BPS]
Return

##################################################################################################
# Build criteria string for filtering data depending on BP type
################################################################################################
$BUILD_CRITERIA
    [L]CRITERE = "1=1"
    If [L]CRITTYPE = 1
      If [M:DBC]BCGCAT <> ""
        [L]CRITERE -= "&[F:BPC]BCGCOD='" + [M:DBC]BCGCAT + "'"
      Endif
      If [M:DBC]BPRNUMSTR <> "" Then
          [L]CRITERE -= "& [F:BPC]BPCNUM>='" + [M:DBC]BPRNUMSTR + "'"
      Endif

      If [M:DBC]BPRNUMEND <> "" Then
          [L]CRITERE -= "& [F:BPC]BPCNUM<='" + [M:DBC]BPRNUMEND + "'"
      Endif
    Else
      If [M:DBC]BSGCAT <> ""
        [L]CRITERE -= "&[F:BPS]BSGCOD='" + [M:DBC]BSGCAT + "'"
      Endif
      If [M:DBC]BPRNUMSTR <> "" Then
          [L]CRITERE -= "& [F:BPS]BPSNUM>='" + [M:DBC]BPRNUMSTR + "'"
      Endif

      If [M:DBC]BPRNUMEND <> "" Then
          [L]CRITERE -= "& [F:BPS]BPSNUM<='" + [M:DBC]BPRNUMEND + "'"
      Endif
    Endif
Return

##################################################################################################
# Update the count of data records fo the actual criteria
################################################################################################
$UPDATE_COUNT
    Local Char CRITERE(250)
    Local Tinyint CRITTYPE

    If [M:DBC]BPTYP = 1
      [L]CRITTYPE = 1
      Gosub BUILD_CRITERIA
      Filter [F:BPC] Where evalue([L]CRITERE)
      [L]CRITTYPE = 2
      Gosub BUILD_CRITERIA
      Filter [F:BPS] Where evalue([L]CRITERE)
      [M:DBC]CNT = rowcount([F:BPC]) + rowcount([F:BPS])
    Elsif [M:DBC]BPTYP = 2
      [L]CRITTYPE = 1
      Gosub BUILD_CRITERIA
      Filter [F:BPC] Where evalue([L]CRITERE)
      [M:DBC]CNT = rowcount([F:BPC])
    Else
      [L]CRITTYPE = 2
      Gosub BUILD_CRITERIA
      Filter [F:BPS] Where evalue([L]CRITERE)
      [M:DBC]CNT = rowcount([F:BPS])
    Endif
    Filter [F:BPC]
    Filter [F:BPS]
    Affzo [M:DBC]CNT
Return

##################################################################################################
# Enable/disable BP category depending on selected BP type
################################################################################################
$SETCATVISIBILITY
  Raz [M:DBC]BCGCAT
  Raz [M:DBC]BSGCAT
  Affzo [M:DBC]BCGCAT
  Affzo [M:DBC]BSGCAT

  If [M:DBC]BPTYP = 1
#     Chgfmt [M:DBC]BSGCAT With "-K:30"
#     Chgfmt [M:DBC]BCGCAT With "K:30"
      Actzo [M:DBC]BCGCAT
      Actzo [M:DBC]BSGCAT

  Elsif [M:DBC]BPTYP = 2
      Actzo [M:DBC]BCGCAT
      Grizo [M:DBC]BSGCAT

  Else
      Actzo [M:DBC]BSGCAT
      Grizo [M:DBC]BCGCAT
  Endif
Return

########################################################################################################################

######################################################################################
## Section automatically added (screen DATEVBPOP) 08/16/2017 14:31:15 (ANGRE)
######################################################################################
Subprog AM_BPTYP(VALEUR)
Variable Integer VALEUR
    [M:DBC]BPTYP = VALEUR
    Gosub SETCATVISIBILITY
    Gosub UPDATE_COUNT
End

Subprog AM_BCGCAT(VALEUR)
Variable Char    VALEUR()
    [M:DBC]BCGCAT = VALEUR
    Gosub UPDATE_COUNT
End

Subprog AM_BSGCAT(VALEUR)
Variable Char    VALEUR()
    [M:DBC]BSGCAT = VALEUR
    Gosub UPDATE_COUNT
End

Subprog AM_BPRNUMSTR(VALEUR)
Variable Char    VALEUR()
    [M:DBC]BPRNUMSTR = VALEUR
    Gosub UPDATE_COUNT
End

Subprog AM_BPRNUMEND(VALEUR)
Variable Char    VALEUR()
    [M:DBC]BPRNUMEND = VALEUR
    Gosub UPDATE_COUNT
End


######################################################################################

