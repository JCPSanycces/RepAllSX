#<AdxTL>@(#)12.0.0.0 $Revision$
Close Local File
Raz GPILOBJ,GNBMASKOUV
GCONSULT = 0
GBIDC1 = "ZZMB"
#Call VALIDE(GBIDC1,nomap,0,0)
Call OBJET("ALH",GBIDC1,GBIDC2) From GOBJET
End

#########################################################
## Pour la copie des transactions
#########################################################
$TRTCOP
Gosub TRTCOP From SUBALH
Return

#########################################################
## Pour les patches des transactions
#########################################################
Subprog PATCH(APPLI)
Value Char APPLI
Call GENDOS(APPLI)
End

#########################################################
## Pg de mise à jour globale
#########################################################
Subprog GENDOS(APPLI)
Value Char APPLI

Local File =APPLI+".ALISTEH"  [ALH2]
Local File =APPLI+".ALISTEH"  [ALH]
Local File =APPLI+".ALISTED"  [ALD]
Local File =APPLI+".ALISTED"  [ALD2]
Local File =APPLI+".ALISTER"  [ALR]
If dim([F:ALH]TYPENV)>0 & filinfo(filpath("FIL","ALISTENV","fde",APPLI),0)>0
 Local File =APPLI+".ALISTENV" [ALV]
Endif
Local File =APPLI+".AMSK"     [AMK]
Local File =APPLI+".AMSKZON"  [AMZ]
Local File =APPLI+".AMSKACT"  [AMA]
Local File =APPLI+".AMSKACT"  [AMA2]
Local File =APPLI+".AMSKPAR"  [AMP]
Local File =APPLI+".AMSKPAR"  [AMP2]
Local File =APPLI+".AWINDOW"  [AWI]
Local File =APPLI+".AWINPAR"  [AWP]
Local File =APPLI+".AWINBRO"  [AWB]
Local File =APPLI+".AWINBOUT" [AWT]
Local File =APPLI+".ATYPE"    [ATY]
Local File =APPLI+".ATYPE"    [ATY2]
Local File =APPLI+".ACCES"    [ACC]
Local File =APPLI+".ATEXTE"   [ATX]
Local File =APPLI+".ACTIV"    [ACV]
Local File =APPLI+".AOBJET"   [AOB]
If filinfo(filpath("FIL","AVIEWTAB","fde",APPLI),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde",APPLI),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde",APPLI),0)<0
 Local File =APPLI+".ATABLE"  [AVWT]
 Local File =APPLI+".ATABZON" [AVWF]
 Local File =APPLI+".ATABIND" [AVWI]
Else
 Local File =APPLI+".AVIEWTAB" [AVWT]
 Local File =APPLI+".AVIEWFLD" [AVWF]
 Local File =APPLI+".AVIEWIND" [AVWI]
Endif

For [ALH2]ALH0 Where TYP=1 & ENAFLG=2
 Call ECR_TRACE([F:ALH2]COD,0) From GESECRAN
 Call VALIDE([F:ALH2]COD,APPLI,0,1)
# Call VALIDE([F:ALH2]COD,APPLI,0,1) From SUBALH11 // included in VALID call
Next
End

#######################################################
## Validation d'une liste
#######################################################
Subprog VALIDE(LISTE,APPLI,DEBUG,SILENCE)
Value Char    LISTE
Value Char    APPLI
Value Integer DEBUG
Value Integer SILENCE

Gosub VARIABLES

If clalev([F:AMA])=0  : Local File =APPLI+".AMSKACT"  [AMA]  : Endif
If clalev([F:AMA2])=0 : Local File =APPLI+".AMSKACT"  [AMA2] : Endif
If clalev([F:AMP])=0  : Local File =APPLI+".AMSKPAR"  [AMP]  : Endif
If clalev([F:AMP2])=0 : Local File =APPLI+".AMSKPAR"  [AMP2] : Endif
If clalev([F:ALD2])=0 : Local File =APPLI+".ALISTED"  [ALD2] : Endif
If clalev([F:AWI])=0  : Local File =APPLI+".AWINDOW"  [AWI]  : Endif
If clalev([F:AWP])=0  : Local File =APPLI+".AWINPAR"  [AWP]  : Endif
If clalev([F:AWB])=0  : Local File =APPLI+".AWINBRO"  [AWB]  : Endif
If clalev([F:AWT])=0  : Local File =APPLI+".AWINBOUT" [AWT]  : Endif
If clalev([F:ALH])=0  : Local File =APPLI+".ALISTEH"  [ALH]  : Endif
If clalev([F:ALD])=0  : Local File =APPLI+".ALISTED"  [ALD]  : Endif
If clalev([F:ALR])=0  : Local File =APPLI+".ALISTER"  [ALR]  : Endif
If dim([F:ALH]TYPENV)>0 & filinfo(filpath("FIL","ALISTENV","fde",APPLI),0)>0
 If clalev([F:ALV])=0 : Local File =APPLI+".ALISTENV" [ALV]  : Endif
Endif
If clalev([F:AMK])=0  : Local File =APPLI+".AMSK"     [AMK]  : Endif
If clalev([F:AMZ])=0  : Local File =APPLI+".AMSKZON"  [AMZ]  : Endif
If clalev([F:ATY])=0  : Local File =APPLI+".ATYPE"    [ATY]  : Endif
If clalev([F:ATY2])=0 : Local File =APPLI+".ATYPE"   [ATY2]  : Endif
If clalev([F:ACC])=0  : Local File =APPLI+".ACCES"    [ACC]  : Endif
If clalev([F:ATX])=0  : Local File =APPLI+".ATEXTE"   [ATX]  : Endif
If clalev([F:ACV])=0  : Local File =APPLI+".ACTIV"    [ACV]  : Endif
If clalev([F:AOB])=0  : Local File =APPLI+".AOBJET"   [AOB]  : Endif

If filinfo(filpath("FIL","AVIEWTAB","fde",APPLI),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde",APPLI),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde",APPLI),0)<0
 If clalev([F:AVWT])=0 : Local File =APPLI+".ATABLE"  [AVWT] : Endif
 If clalev([F:AVWF])=0 : Local File =APPLI+".ATABZON" [AVWF] : Endif
 If clalev([F:AVWI])=0 : Local File =APPLI+".ATABIND" [AVWI] : Endif
Else
 If clalev([F:AVWT])=0 : Local File =APPLI+".AVIEWTAB" [AVWT] : Endif
 If clalev([F:AVWF])=0 : Local File =APPLI+".AVIEWFLD" [AVWF] : Endif
 If clalev([F:AVWI])=0 : Local File =APPLI+".AVIEWIND" [AVWI] : Endif
Endif

OK = 1
INTRQT = mess(277,139,1)-LISTE : # Requête standard

Read [ALH]ALH0 = LISTE
If fstat
 OK = 0 : Call ECR_TRACE(INTRQT-":"-mess(23,100,1),1) From GESECRAN : # Fiche inexistante
 Goto FIN
Endif

Gosub LIENS
If !OK
 Gosub DESACTIVE
 Goto FIN
Endif

# Debug
If DEBUG
 Call OUVRE_TRACE("") From LECFIC
 Call ECR_TRACE(TBFIC(F),0) From GESECRAN
 For I=1 To NBFIC2
  If I<>F
   If LORG(I)<>0
    Call ECR_TRACE(TBFIC(I)-"<="-TBFIC(LORG(I))-LZON(I),0) From GESECRAN
   Else
    Call ECR_TRACE(TBFIC(I)-[F:ALH]LNK(LIND(I)),0) From GESECRAN
   Endif
  Endif
 Next I
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif

Gosub TRAITE
If !OK : Goto FIN : Endif

Gosub MASQUE
If !OK : Goto FIN : Endif

Gosub FENETRE
If !OK : Goto FIN : Endif

GOK = 1
Trbegin [ALR]
 Delete [ALR] Where COD=[L]LISTE
 If clalev([F:ALV]) : Delete [ALV] Where COD=[L]LISTE : Endif
Commit

$FIN
If !OK
 GERR = 1
Else
 Call VALIDE(LISTE,APPLI,DEBUG,SILENCE) From SUBALH11 : # ZDOM
Endif
End

$VARIABLES
Local Char     FENETRE(GLONFEN) , WINREF(GLONFEN)
Local Char     MASQUE(GLONAMK) , MSKREF(GLONAMK)
Local Char     LAN(GLONLAN)(1..10)
Local Integer  I , J , K , F , L , OK , DIME , STAT
Local Integer  II , JJ , KK
Local Shortint MAXFIC , MAXBOUT, MAXCOL
If !clalev([M:ALH1]) : Local Mask ALH1 [ALH1] : Endif
MAXFIC = 80
MAXBOUT = 16
MAXCOL  = max(16,dim([M:ALH1]FLD)-1)
Local Integer  NBFIC , NBFIC2 , NBLAN , PASSE , OKL , OKLIEN , NBFIC3
Local Integer  P , OKFLD , ERFLD
Local Schar    TBFIC(GLONATB)(1..MAXFIC) , ABFIC(GLONABR+2)(1..MAXFIC) , LZON(20)(1..MAXFIC)
Local Schar    TLIEN(250) , FLDVCR(20) , FLDLIG(250) , TTYPE(GLONATY) , TBCHP(30)(1..200) , CLE(20)(1..16)
Local Schar    TCOL(30)(1..MAXBOUT,1..MAXCOL) , TTYP(GLONATY)(1..MAXBOUT,1..MAXCOL) , TNIV(30)(1..MAXBOUT)
Local Schar    TOBJ(GLONAOB)(1..MAXBOUT),TBFIC3(GLONATB)(1..MAXFIC)
Local Decimal  TLNG(1..MAXBOUT,1..MAXCOL)
Local Integer  TMEN(1..MAXBOUT,1..MAXCOL) , THOM(1..MAXBOUT) , TINT(1..MAXBOUT)
Local Integer  LIEN(1..MAXFIC) , LORG(1..MAXFIC) , LNUM(1..MAXFIC) , LORD(1..MAXFIC)
Local Integer  LIMP(1..MAXFIC) , LIND(1..MAXFIC) , LIMO(1..MAXFIC,1..MAXBOUT) , RAZB(1..MAXBOUT)
Local Char     CHAINE(250) , ZONE(80)
Local Char     LNKFIC(GLONABR+2) , DESAX(GLONAX2)
Local Char     TRAITE(GLONADC) , FICTRT(GDIMFIC) , MAGIC(80)
Local Char     SAVIFS(5) , SAVIRS(5) , IDENT(20)
Local Char     ABREV(GLONABR+2)
Local Integer  SAVIUM
Local Integer  NBCHP , NBGRP , GROUPE , SPA , NBCLE , LONG , NBCOL
Local Integer  TRI(20) , CUM , NIVEAU
Local Integer  NBTXT , LIGTXT(1..20) , TYPTXT(1..20)
Local Schar    CHTXT(GLONAVA)(1..20) , ABTXT(GLONABR+2)(1..20) , TBTXT(GLONATB)(1..20)
Local Char     AOBSIT(GLONAVA) , AOBACC(GLONAVA) , AOBFIC(GLONAVA)
Local Integer  FLCLOB
Local Char     CH2(250) , CH3(250) , CH4(250) , WVALPAR(250) , INTRQT(40) , WOBJPAR(GLONAOB)
Local Integer  LIENCOMPO,ERVAL
Local Schar    ESC(5)
Local Char     LINES_LINK(200)(1..30)
Local Integer  LINES_NBR
Return

########################################################
## Désactivation d'une liste en erreur
########################################################

$DESACTIVE
If !adxlog
 Gosub TR_LISTE
Else
 Gosub MAJ_LISTE
Endif
If GOK=1
 Call ECR_TRACE(INTRQT-":"-mess(62,139,1),-1) From GESECRAN : # Fiche désactivée
Endif
Return

$TR_LISTE
GOK=1
Trbegin [ALH]
 Gosub MAJ_LISTE
 If GOK<0 : Goto AB_TR_LISTE : Endif
Commit
Return

$AB_TR_LISTE
Rollback
Return

$MAJ_LISTE
Readlock [ALH]ALH0 = LISTE
If fstat=1
 GOK = -1 : GLOCK = "$ALISTEH"
Else
 [F:ALH]ENAFLG = 1
 Rewrite [ALH]
 If fstat
  GOK = 0 : Call FSTA("ALH") From GLOCK
 Endif
Endif
Return

########################################################
## Etablissement des liens
########################################################

$LIENS

## Table des fichiers

Raz TBFIC , NBFIC
For [ALD]ALD0 Where COD=LISTE : # & STREND<=2
 If !find([F:ALD]TBL,TBFIC(1..NBFIC))
  Read [AVWT]CODFIC = [F:ALD]TBL
  If fstat
   OK = 0 : Call ECR_TRACE(INTRQT-":"-func AFNC.MES(mess(85,133,1),[F:ALD]TBL),-1) From GESECRAN : # Table # inexistante
  Else
   NBFIC += 1
   TBFIC(NBFIC) = [F:ALD]TBL
   ABFIC(NBFIC) = [F:AVWT]ABRFIC
  Endif
 Endif
Next ALD
If NBFIC=0
 Call ECR_TRACE(INTRQT-":"-mess(116,141,1),0) From GESECRAN : # Aucune table déclarée
 OK = 0 : Return
Endif
If !OK : Return : Endif

## Décodage liens imposés

Raz LIMP, LIMO
For I=0 To dim([F:ALH]LNK)-1
 If [F:ALH]LNK(I)<>""
  CHAINE = vireblc([F:ALH]LNK(I),4)
  J = instr(1,CHAINE,"=")
  If J
   ZONE   = left$(CHAINE,J-1)
   CHAINE = right$(CHAINE,J+1)
   J = instr(1,ZONE,"]")
   If J
    ZONE   = seg$(ZONE,2,J-1)
   Endif
   If left$(ZONE,2)="F:" : ZONE = right$(ZONE,3) : Endif
   K = find(ZONE,ABFIC(1..NBFIC))
   If K
    LIMP(K) = 1
    LIND(K) = I
    While CHAINE<>""
     J = instr(1,CHAINE,";")
     If J
      ZONE   = left$(CHAINE,J-1)
      CHAINE = right$(CHAINE,J+1)
     Else
      ZONE   = CHAINE
      CHAINE = ""
     Endif
     If left$(ZONE,1)="["
      J = instr(1,ZONE,"]")
      If J
       ZONE = seg$(ZONE,2,J-1)
       If left$(ZONE,2)="F:" : ZONE = right$(ZONE,3) : Endif
       J = find(ZONE,ABFIC(1..NBFIC))
       If J
        LIMO(K,LIMP(K)) = J
        LIMP(K) += 1
       Endif
      Endif
     Endif
    Wend
   Endif
  Endif
 Endif
Next I

## Boucle de recherche

F = 0
PASSE = 0

$LIENS0
F += 1
If F>NBFIC
 If PASSE=0
  PASSE = 1 : F = 1
 Else
  OK = 0 : Call ECR_TRACE(INTRQT-":"-mess(7,124,1),0) From GESECRAN : # Liens impossibles
  Return
 Endif
Endif

If LIMP(F) : Goto LIENS0 : Endif

Raz LIEN, LORG, LZON
LIEN(F) = 1

## Ajout de fichiers en 2ème passe

NBFIC2 = NBFIC
If PASSE=1
 For [AVWF]CODZONE Where CODFIC=TBFIC(F) & LIEN<>""
  If !find([F:AVWF]LIEN,TBFIC(1..NBFIC2))
   Read [AVWT]CODFIC = [F:AVWF]LIEN
   If fstat
    # Lien impossible\Table inexistante
    OK = 0 : Call ECR_TRACE(INTRQT-"->"-mess(45,105,1)-'"'-[F:AVWF]LIEN-'":'-TBFIC(F),-1) From GESECRAN
   Else
    NBFIC2 += 1
    TBFIC(NBFIC2) = [F:AVWF]LIEN
    LIEN(NBFIC2)  = 1
    LORG(NBFIC2)  = F
    LZON(NBFIC2)  = [F:AVWF]CODZONE
   Endif
  Endif
 Next FLD
Endif

## Etablissement des liens

$LIENS1
OKL = 0
For I=1 To NBFIC2
 If LIMP(I)
  LIEN(I) = 1
 Elsif !LIEN(I)
  For J=1 To NBFIC2
   If LIEN(J)
    For [AVWF]LIEN Where LIEN=TBFIC(I) & CODFIC=TBFIC(J)
     LIEN(I) = 1
     LORG(I) = J
     LZON(I) = [F:AVWF]CODZONE
     OKL = 1
     Break
    Next
   Endif
   If LIEN(I) : Break : Endif
  Next J
 Endif
Next I

If sum(LIEN(1..NBFIC))<>NBFIC
 If OKL : Goto LIENS1 : Else : Goto LIENS0 : Endif
Endif

## Suppression fichiers inutiles

I = NBFIC+1
While I<=NBFIC2
 If !find(I,LORG(1..NBFIC))
  Dela I  TBFIC, LIEN, LORG, LZON
  NBFIC2 -= 1
  For J=1 To NBFIC
   If LORG(J)>I : LORG(J) -= 1 : Endif
  Next J
 Else
  I += 1
 Endif
Wend

## Tri dans l'ordre de necessité et renumérotage

For I=1 To NBFIC2
 LNUM(I) = I
Next I

Raz LORD
LORD(F) = 1

For K=1 To NBFIC2
 For I=1 To NBFIC2
  If LIMP(I)
   If LORD(I)=0
    OKL = 1
    For J=1 To LIMP(I)-1
     If LORD(LIMO(I,J))=0 or LORD(LIMO(I,J))>K : OKL = 0 : Endif
    Next J
   Else
    OKL = 0
   Endif
  Else
   If LORG(I)>0 & LORD(LORG(I))=K
    OKL = 1
   Else
    OKL = 0
   Endif
  Endif
  If OKL : LORD(I) = K+1 : Endif
 Next I
Next K

If find(0,LORD(1..NBFIC2))
 Goto LIENS0
Endif

#119014
#Sorta NBFIC2 LORD, TBFIC, LIEN, LORG, LZON, LNUM, LIMP, LIND
Sorta NBFIC2 LORD, TBFIC, ABFIC, LIEN, LORG, LZON, LNUM, LIMP, LIND
F = 1

For I=1 To NBFIC2
 K = find(LORG(I),LNUM(1..NBFIC2))
 If K
  LORG(I) = K
 Endif
Next I

Return

########################################################
## Génération du traitement qui va bien
########################################################

$TRAITE

MAGIC  = mess(77,133,1) : # Superviseur Adonix
Gosub SETPRG From SUBALH
IDENT  = "## LISTE ##"
TRAITE = PREFPRG+LISTE
FICTRT = filpath("TRT",TRAITE,"src",APPLI)

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

If filinfo(FICTRT,0)>=0
 Openi FICTRT Using [SSS_]
 Raz I, OK
 Rdseq CHAINE Using [SSS_]
 While !fstat
  I += 1 : If I>5 : Break : Endif
  If left$(CHAINE,len(IDENT))=IDENT
   OK = 1 : Break
  Endif
  Rdseq CHAINE Using [SSS_]
 Wend
 Openi Using [SSS_]
 If !OK
  Call ECR_TRACE(INTRQT-"->"-TRAITE-":"-mess(13,123,1),1) From GESECRAN : # Traitement incorrect
  Return
 Endif
Endif

If !SILENCE
 Call TEMPON(mess(159,133,1)-TRAITE) From GESECRAN : # Validation du traitement
Endif
If GTRACE<>""
 Call ECR_TRACE(INTRQT-"->"-mess(159,133,1)-TRAITE,0) From GESECRAN
Endif

Gosub VERIF_ALD
Gosub TRT_DEB
Gosub ETIQUETTE
Gosub TRT_FIN

If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Return

#-------------------------------------------------------#
$TRT_DEB
Openo FICTRT , 0 Using [SSS_]
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$" Using [SSS_]
Wrseq "#"-MAGIC Using [SSS_]
Call LECTEXTRA(DESAX,"ALISTEH","INTIT",[F:ALH]COD,"") From ATEXTRA
Wrseq IDENT-LISTE-DESAX Using [SSS_]
Wrseq Using [SSS_]
Return

#-------------------------------------------------------#
$TRT_FIN
Wrseq Using [SSS_]
Openo Using [SSS_]
Call VALID("TRT",TRAITE,APPLI,STAT) From VALMSKSUB
Return

#-------------------------------------------------------#
$VERIF_ALD
NBTXT = 0
For [ALD]ALD0 Where COD=LISTE & STREND<=2
 Read [AVWT]CODFIC = [F:ALD]TBL
 If !fstat
  Case [ALD]CODTYP
   When "ATX"
    NBTXT += 1
    TBTXT(NBTXT)  = [F:ALD]TBL
    CHTXT(NBTXT)  = [F:ALD]FLD
    LIGTXT(NBTXT) = [F:ALD]LIG
    ABTXT(NBTXT)  = [F:AVWT]ABRFIC
    TYPTXT(NBTXT) = 1
   When "AXX","AX1","AX2","AX3"
    NBTXT += 1
    TBTXT(NBTXT)  = [F:ALD]TBL
    CHTXT(NBTXT)  = [F:ALD]FLD
    LIGTXT(NBTXT) = [F:ALD]LIG
    ABTXT(NBTXT)  = [F:AVWT]ABRFIC
    TYPTXT(NBTXT) = 2
    For GBIDC1="CLECUR1","CLECUR2"
     Read [AMP]CODPAR=2;TBTXT(NBTXT);CHTXT(NBTXT);GBIDC1
     If !fstat & instr(1,[AMP]VALPAR,"+")
      If GTRACE<>""
       Call ECR_TRACE([F:ALD]TBL-":"-[F:ALD]FLD-"("+[ALD]CODTYP+")"-mess(214,133,1),-1) From GESECRAN
      Endif
      TYPTXT(NBTXT) = 3 : Break
     Endif
    Next GBIDC1
  Endcase
 Endif
Next ALD
Return

#-------------------------------------------------------#
$ETIQUETTE
OK = 1

If [F:ALH]OBJLNK<>""
 Read [AOB]ABREV = [F:ALH]OBJLNK
 If !fstat
  If [F:AOB]ZSITE<>"" : AOBSIT = [F:AOB]ZSITE : Endif
  If [F:AOB]ZACC<>""  : AOBACC = [F:AOB]ZACC  : Endif
  Read [AVWT]CODFIC = [F:AOB]NOMFIC
  If !fstat
   AOBFIC = [F:AVWT]ABRFIC
  Endif
 Endif
Endif

Wrseq "$PARAM" Using [SSS_]
Wrseq 'Local Integer PARTYP(1..'+num$(MAXCOL)+')' Using [SSS_]
I = 0
For [ALD]ALD0 Where COD=LISTE & find(STREND,2,3)
 If I<MAXCOL
  I += 1
  Read [ATY]CODTYP=[F:ALD]CODTYP
  Wrseq 'PARTYP('+num$(I)+') = '+num$([F:ATY]TYPTYP) Using [SSS_]
 Endif
Next I
Wrseq 'Return' Using [SSS_]
Wrseq Using [SSS_]

Wrseq "$OUVRE" Using [SSS_]
For I=1 To NBFIC2
 Read [AVWT]CODFIC = TBFIC(I)
 If !fstat
  ABFIC(I) = [F:AVWT]ABRFIC
  Wrseq "If clalev([F:"+ABFIC(I)+"])=0 : Local File "+TBFIC(I)+" ["+ABFIC(I)+"] : Endif" Using [SSS_]
 Endif
Next I

If AOBACC<>""
 Wrseq "If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif" Using [SSS_]
Endif

For I=1 To NBTXT
 Case TYPTXT(I)
  When 1
   Wrseq "If clalev([F:AX"+num$(LIGTXT(I)+10)+"])=0 : Local File ATEXTE  [AX"+num$(LIGTXT(I)+10)+"] : Endif"  Using [SSS_]
  When 2,3
   Wrseq "If clalev([F:AY"+num$(LIGTXT(I)+10)+"])=0 : Local File ATEXTRA [AY"+num$(LIGTXT(I)+10)+"] : Endif" Using [SSS_]
 Endcase
Next I

### Cas des champ non transfére mais ou on souhaite ouvrir la table quand meme bug 61550
Raz TBFIC3,NBFIC3
For [ALD]ALD0 Where COD=LISTE & STREND=3
 If !find([F:ALD]TBL,TBFIC) & !find([F:ALD]TBL,TBFIC3)
  Read [AVWT]CODFIC = [F:ALD]TBL
  If !fstat
   NBFIC3 +=1
   TBFIC3(NBFIC3) = [F:ALD]TBL
   Wrseq "If clalev([F:"+[F:AVWT]ABRFIC+"])=0 : Local File "+[F:ALD]TBL+" ["+[F:AVWT]ABRFIC+"] : Endif" Using [SSS_]
  Endif
 Endif
Next
Wrseq Using [SSS_]

Wrseq 'Local Char AFILOPE(250)' Using [SSS_]
Wrseq 'AFILOPE = ""' Using [SSS_]
For I=1 To NBFIC2
 Wrseq 'If AFILOPE<>"" : AFILOPE += "," : Endif' Using [SSS_]
 Wrseq 'AFILOPE += "['+ABFIC(I)+']"' Using [SSS_]
Next I
For I=1 To NBFIC3
 Read [AVWT]CODFIC = TBFIC3(I)
 If !fstat     # Issue X3-44426 - 2017-06-14 by CCC : add test of fstat
    Wrseq 'If AFILOPE<>"" : AFILOPE += "," : Endif' Using [SSS_]
    Wrseq 'AFILOPE += "['+[F:AVWT]ABRFIC+']"' Using [SSS_]
 Endif
Next I
Wrseq Using [SSS_]

KK = 0
For JJ=0 To dim([F:ALH]SEL)-1
 CHAINE = format$("KTv2:255X",[F:ALH]SEL(JJ))
 If CHAINE<>""
  Gosub REC_CLOB
  If instr(1,CHAINE,"func ")=0 and !FLCLOB
   KK += 1
   Wrseq 'CRITSUP('+num$(KK)+') = '; Using [SSS_]
   If KK=1
    Wrseq '"('; Using [SSS_]
   Else
    Wrseq '" & ('; Using [SSS_]
   Endif
   Wrseq ctrans(CHAINE,'"','¨')+')"' Using [SSS_]
  Endif
 Endif
Next JJ
If KK=0
 Wrseq 'CRITSUP(1) = "(1=1)"' Using [SSS_]
Endif

Wrseq "Gosub REMPLACE_SUP From SUBALH9" Using [SSS_]
Wrseq Using [SSS_]

If ABFIC(F)<>"" & (NBFIC2>1 | (NBTXT>0 & (find(1,TYPTXT(1..NBTXT)) | find(2,TYPTXT(1..NBTXT)))) | AOBACC<>"")
 LNKFIC = ABFIC(F)
 OKL = 0
 LINES_NBR = 1
 LINES_LINK(LINES_NBR) = "Link ["+ABFIC(F)+"] With"
 For I=1 To NBFIC2
  If I<>F
   LINES_NBR += 1
   If OKL<>0
    #Wrseq "& , "; Using [SSS_]
   Else
    #Wrseq "&   "; Using [SSS_]
    OKL = 1
   Endif
   If LIMP(I)
    LINES_LINK(LINES_NBR) = [F:ALH]LNK(LIND(I))
    #Wrseq [F:ALH]LNK(LIND(I)) Using [SSS_]
   Else
    Read [AVWI]NUMLIG(2) = TBFIC(I);1
    If fstat     # Issue X3-44426 - 2017-06-14 by CCC : add test of fstat
        Call ECR_TRACE(mess(207,115,1)-TBFIC(I),1) From GESECRAN
    Else
        LINES_LINK(LINES_NBR) = "["+ABFIC(I)+"]"+[F:AVWI]CODIND+" = "
        #Wrseq "["+ABFIC(I)+"]"+[F:AVWI]CODIND+" = "; Using [SSS_]
        Read [AVWF]CODZONE = TBFIC(LORG(I));LZON(I)
        If fstat    # Issue X3-44426 - 2017-06-14 by CCC : add test of fstat
            Call ECR_TRACE(func AFNC.MES2(mess(222,115,1),LZON(I),TBFIC(LORG(I))),1) From GESECRAN
        Else
            If [F:AVWF]EXPLIEN=""
             LINES_LINK(LINES_NBR) += "[F:"+ABFIC(LORG(I))+"]"+[F:AVWF]CODZONE
             #Wrseq "[F:"+ABFIC(LORG(I))+"]"+[F:AVWF]CODZONE Using [SSS_]
            Else
             CHAINE = vireblc(format$("KT:120X",[F:AVWF]EXPLIEN),2)
             While CHAINE<>""
              K = instr(1,CHAINE,";")
              If K
               ZONE   = left$(CHAINE,K-1)
               CHAINE = right$(CHAINE,K+1)
              Else
               ZONE   = CHAINE
               CHAINE = ""
              Endif
              K = instr(1,ZONE,"indice")
              If K
               ZONE = left$(ZONE,K-1)+"0"+right$(ZONE,K+6)
              Endif
              If left$(ZONE,1)>="A" & left$(ZONE,1)<="Z"
               LINES_LINK(LINES_NBR) += "[F:"+ABFIC(LORG(I))+"]"+ZONE
               #Wrseq "[F:"+ABFIC(LORG(I))+"]"+ZONE; Using [SSS_]
              Else
               LINES_LINK(LINES_NBR) += ZONE
               #Wrseq ZONE; Using [SSS_]
              Endif
              #If CHAINE<>"" : Wrseq ";"; Using [SSS_] : Endif
              If CHAINE<>"" : LINES_LINK(LINES_NBR) += ";" : Endif
             Wend
             #Wrseq Using [SSS_]
            Endif
        Endif
    Endif
   Endif
  Endif
 Next I
 For I=1 To NBTXT
  If find(TYPTXT(I),1,2)
   LINES_NBR += 1
   If OKL<>0
    #Wrseq "& , "; Using [SSS_]
   Else
    #Wrseq "&   "; Using [SSS_]
    OKL = 1
   Endif
  Endif
  Case TYPTXT(I)
   When 1
    LINES_LINK(LINES_NBR) += "[AX"+num$(LIGTXT(I)+10)+"]NUMERO = GLANGUE;"
    #Wrseq "[AX"+num$(LIGTXT(I)+10)+"]NUMERO = GLANGUE;"; Using [SSS_]
    If CHTXT(I)<>""
     LINES_LINK(LINES_NBR) += "[F:"+ABTXT(I)+"]"+CHTXT(I)
     #Wrseq "[F:"+ABTXT(I)+"]"+CHTXT(I) Using [SSS_]
    Else
     Read [ALD]ALD0 = LISTE;LIGTXT(I)
     LINES_LINK(LINES_NBR) += vireblc(format$("KT:250X",[F:ALD]CLC),2)
     #Wrseq vireblc(format$("KT:250X",[F:ALD]CLC),2) Using [SSS_]
    Endif
   When 2
    LINES_LINK(LINES_NBR) = '[AY'+num$(LIGTXT(I)+10)+']AXX0   = "'+TBTXT(I)+'";"'+CHTXT(I)+'";GLANGUE'
    #Wrseq '[AY'+num$(LIGTXT(I)+10)+']AXX0   = "'+TBTXT(I)+'";"'+CHTXT(I)+'";GLANGUE'; Using [SSS_]
    For GBIDC1="CLECUR1","CLECUR2"
     Read [AMP]CODPAR=2;TBTXT(I);CHTXT(I);GBIDC1
     If !fstat
      Read [AVWF]CODZONE = TBTXT(I);vireblc(format$("KT:250X",[AMP]VALPAR),2)
      If !fstat
       CHAINE = "[F:"+ABTXT(I)+"]"+[AVWF]CODZONE
      Else
       CHAINE = [AMP]VALPAR
      Endif
     Else
      CHAINE = '""'
     Endif
     LINES_LINK(LINES_NBR) += ";"+CHAINE
     #Wrseq  ";"+CHAINE; Using [SSS_]
    Next GBIDC1
    #Wrseq Using [SSS_]
  Endcase
 Next I
 If AOBACC<>""
  If OKL<>0
   #Wrseq "& , "; Using [SSS_]
  Else
   #Wrseq "&   "; Using [SSS_]
   OKL = 1
  Endif
  LINES_NBR += 1
  LINES_LINK(LINES_NBR) = "[ACC]CODACC = GUSER ; [F:"+AOBFIC+"]"+AOBACC
  #Wrseq "[ACC]CODACC = GUSER ; [F:"+AOBFIC+"]"+AOBACC Using [SSS_]
 Endif
 Call LNK_SORT(LINES_LINK,OK) From SUBALT1
 Wrseq LINES_LINK(1) Using [SSS_]
 For I=2 To LINES_NBR
  If I>2
   Wrseq "& , "; Using [SSS_]
  Else
   Wrseq "&   "; Using [SSS_]
  Endif
  Wrseq LINES_LINK(I) Using [SSS_]
 Next I
 Wrseq "& As [LNK]" Using [SSS_]
Else : # Cas trivial où il n'y a qu'un seul fichier
 Wrseq 'Link ['+ABFIC(1)+'] With [ALH]ALH0="'+LISTE+'" As [LNK]' Using [SSS_]
 LNKFIC = ABFIC(1)
Endif
Wrseq "& Where "; Using [SSS_]

If dim([F:ALH]TYPENV)>0
 Local Libelle TYPENV
 Read [AVWI]NUMLIG(2) = TBFIC(F);1
 If !fstat     # Issue X3-44426 - 2017-06-14 by CCC : add test of fstat
     If left$([F:AVWI]DESCRIPT,8)="FCY+DEP+" : [L]TYPENV=2
     Elsif left$([F:AVWI]DESCRIPT,4)="FCY+"  : [L]TYPENV=1
     Endif
     If [L]TYPENV<>[F:ALH]TYPENV
      Trbegin [ALH]
       Update [ALH] Where COD=[L]LISTE With TYPENV=[L]TYPENV
       If fstat
        GOK=0 : Call FSTA("ALH") From GLOCK : [L]TYPENV=[F:ALH]TYPENV
       Endif
      Commit
     Endif
 Endif
 Wrseq "evalue(CRITENV) & "; Using [SSS_]
Endif

Wrseq "evalue(CRITERE) & evalue(CRITSUP)" Using [SSS_]
OKL = 0
# Issue X3-44426 - 2017-06-14 by CCC : Add instruction Order by only if possible
#Wrseq "& Order by Key CLE = "; Using [SSS_]
NBGRP = 0

Filter [ALD] Where COD=LISTE & STREND<=2 & SRT>1 & GRP=2 Order By Key CLE=COD;NIV;LIG
For [ALD]CLE
 NBGRP += 1
 If OKL<>0
  Wrseq ";"; Using [SSS_]
 Else
  OKL = 1
  Wrseq "& Order by Key CLE = "; Using [SSS_]   # Issue X3-44426 - 2017-06-14 by CCC : Add instruction Order by only if possible
 Endif
 If [F:ALD]CODTYP="ATX"
  Wrseq "[F:AX"+num$([F:ALD]LIG+10)+"]TEXTE"; Using [SSS_]
 Elsif find([F:ALD]CODTYP,"AXX","AX1","AX2","AX3")
  Wrseq "[F:AY"+num$([F:ALD]LIG+10)+"]TEXTE"; Using [SSS_]
 Else
  K = find([F:ALD]TBL,TBFIC(1..NBFIC2))
  Wrseq "[F:"+ABFIC(K)+"]"+[F:ALD]FLD; Using [SSS_]
 Endif
 If [F:ALD]SRT=3 : Wrseq " Desc"; Using [SSS_] : Endif
Next
Filter [ALD] Where COD=LISTE & STREND<=2 & SRT>1 & GRP<>2 Order By Key CLE=COD;NIV;LIG
For [ALD]CLE
 If OKL<>0
  Wrseq ";"; Using [SSS_]
 Else
  OKL = 1
  Wrseq "& Order by Key CLE = "; Using [SSS_]   # Issue X3-44426 - 2017-06-14 by CCC : Add instruction Order by only if possible
 Endif
 If [F:ALD]CODTYP="ATX"
  Wrseq "[F:AX"+num$([F:ALD]LIG+10)+"]TEXTE"; Using [SSS_]
 Elsif find([F:ALD]CODTYP,"AXX","AX1","AX2","AX3")
  Wrseq "[F:AY"+num$([F:ALD]LIG+10)+"]TEXTE"; Using [SSS_]
 Else
  K = find([F:ALD]TBL,TBFIC(1..NBFIC2))
  Wrseq "[F:"+ABFIC(K)+"]"+[F:ALD]FLD; Using [SSS_]
 Endif
 If [F:ALD]SRT=3 : Wrseq " Desc"; Using [SSS_] : Endif
Next
Filter [ALD]
If OKL=0
 For [ALD]ALD0 Where COD=LISTE & STREND<=2 & FLD<>""
  # Issue X3-44426 - 2017-06-14 by CCC : Add instruction Order by only if possible
  If OKL=0
    OKL=1
    Wrseq "& Order by Key CLE = "; Using [SSS_]
  Endif
  K = find([F:ALD]TBL,TBFIC(1..NBFIC2))
  Wrseq "[F:"+ABFIC(K)+"]"+[F:ALD]FLD; Using [SSS_]
  Break
 Next
Endif

# Issue X3-44426 - 2017-06-14 by CCC : If "Order by" has not been already added
#    => no key possible but CLE must exist because it's used in SUBALH9
If OKL=0
    Wrseq "& Order by Key CLE = 1"; Using [SSS_]
Endif
Wrseq Using [SSS_]

## Recherche des champs présents dans les formules
NBCHP = 0
NBCOL = 0
For [ALD] Where COD=LISTE & STREND<=2
 NBCOL += 1
 K = find([F:ALD]TBL,TBFIC(1..NBFIC2))
 If [F:ALD]FLD<>"" & find([F:ALD]CODTYP,"AXX","AX1","AX2","AX3")=0
  ZONE = [F:ALD]FLD
  I = instr(1,ZONE,"(")
  If I
   ZONE = left$(ZONE,I-1)
  Endif
  ZONE = "[F:"+ABFIC(K)+"]"+ZONE
  If !find(ZONE,TBCHP(1..NBCHP))
   NBCHP += 1
   TBCHP(NBCHP) = ZONE
  Endif
 Else
  CHAINE = vireblc(format$("KT:250X",[F:ALD]CLC),2)
  I = 0
  Repeat
   I = instr(I+1,CHAINE,"[")
   If I
    J = instr(I+1,CHAINE,"]")
    If J
     Repeat
      J += 1
     Until J>len(CHAINE) or !instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(CHAINE,J,1))
     ZONE = seg$(CHAINE,I,J-1)
     If !find(ZONE,TBCHP(1..NBCHP)) & !instr(1,ZONE,"\") &  !instr(1,ZONE,"/") : # 65035 Cas champ date[0/0/0] dnas la formule
      NBCHP += 1
      TBCHP(NBCHP) = ZONE
     Endif
    Endif
    I = J-1
   Endif
  Until I=0
 Endif
Next

## Recherche des champs présents dans les critères de sélection "func"
For KK=1 To dim([F:ALH]SEL)
 CHAINE = format$("KTv2:250X",[F:ALH]SEL(KK-1))
 Gosub REC_CLOB
 If instr(1,CHAINE,"func ") or FLCLOB
  I = 0
  Repeat
   I = instr(I+1,CHAINE,"[")
   If I
    J = instr(I+1,CHAINE,"]")
    If J
     Repeat
      J += 1
     Until J>len(CHAINE) or !instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(CHAINE,J,1))
     ZONE = seg$(CHAINE,I,J-1)
     If !find(ZONE,TBCHP(1..NBCHP))
      NBCHP += 1
      TBCHP(NBCHP) = ZONE
     Endif
    Endif
    I = J-1
   Endif
  Until I=0
 Endif
Next KK

## Ajout des champs de la clé primaire
Read [AVWI]NUMLIG(2) = TBFIC(F);1
NBCLE = 0
If !fstat     # Issue X3-44426 - 2017-06-14 by CCC : add test of fstat
    CHAINE = [F:AVWI]DESCRIPT
    While CHAINE<>""
     I = instr(1,CHAINE,"+")
     J = instr(1,CHAINE,"-")
     If    I & J  : I = min(I,J)
     Elsif J & !I : I = J
     Endif
     If I
      ZONE   = left$(CHAINE,I-1)
      CHAINE = right$(CHAINE,I+1)
     Else
      ZONE   = CHAINE
      CHAINE = ""
     Endif
     NBCLE += 1
     CLE(NBCLE) = ZONE
     ZONE = "[F:"+ABFIC(F)+"]"+ZONE
     If !find(ZONE,TBCHP(1..NBCHP))
      NBCHP += 1
      TBCHP(NBCHP) = ZONE
     Endif
    Wend
Endif

## Ajout des champs textes
For I=1 To NBTXT
 Case TYPTXT(I)
  When 1 : NBCHP += 1 : TBCHP(NBCHP) = "[F:AX"+num$(LIGTXT(I)+10)+"]TEXTE"
  When 2 : NBCHP += 1 : TBCHP(NBCHP) = "[F:AY"+num$(LIGTXT(I)+10)+"]TEXTE"
  When 3 : # bug 58058 CCL
   Read [AVWI]NUMLIG(2) = TBTXT(I);1
   If !fstat     # Issue X3-44426 - 2017-06-14 by CCC : add test of fstat
       CHAINE = [F:AVWI]DESCRIPT
       Gosub SETCLE From SUBALT1
       For J=1 To NBCLE
        ZONE = "[F:"+ABTXT(I)+"]"+CLE(J)
        If !find(ZONE,TBCHP(1..NBCHP))
         NBCHP += 1
         TBCHP(NBCHP) = ZONE
        Endif
       Next J
   Endif
 Endcase
Next I

Wrseq Using [SSS_]

# Génération d'un Column sauf en cas de présence d'un clob
FLCLOB = 0
For JJ=0 To dim([F:ALH]SEL)-1
 CHAINE = format$("KTv2:255X",[F:ALH]SEL(JJ))
 If CHAINE<>""
  Gosub REC_CLOB
  If FLCLOB : Break : Endif
 Endif
Next JJ
# Issue X3-44426 - 2017-06-14 by CCC : Add instruction Columns only if possible
If NBCHP>0
    If !FLCLOB or func AFNC.PARTSEP(ver$(0),2," ")>"16r.212"
     Wrseq "Columns [LNK] ("; Using [SSS_]
     L = 0
     For I=1 To NBCHP
      ZONE = TBCHP(I)
      J = instr(1,ZONE,":")
      K = instr(1,ZONE,"]")
      ABREV = seg$(ZONE,J+1,K-1)
      ZONE  = right$(ZONE,K+1)
      DIME  = 1
      Read [AVWT]CODFIC = func TABLE(LISTE,ABREV)
      If !fstat
       Read [AVWF]CODZONE = [F:AVWT]CODFIC;ZONE
       If !fstat
        DIME = [F:AVWF]DIME
        Call REPTAB([F:AVWF]CODACT,DIME) From DOSSUB
       Endif
      Endif
      DIME = abs(DIME)
      For J=1 To DIME
       L += 1
       If mod(L,5)=0
        Wrseq Using [SSS_]
        Wrseq "& "; Using [SSS_]
       Endif
       Wrseq TBCHP(I); Using [SSS_]
       If DIME>1
        Wrseq "(";num$(J-1);")"; Using [SSS_]
       Endif
       If I<>NBCHP or J<>DIME : Wrseq ","; Using [SSS_] : Endif
      Next J
     Next I
     Wrseq ")" Using [SSS_]
    Endif
Endif
Wrseq "Return" Using [SSS_]
Wrseq Using [SSS_]

Wrseq "$LIENS" Using [SSS_]
Wrseq 'If dim(AFILOPE)>0 & AFILOPE<>"" : Default File AFILOPE : Endif' Using [SSS_]
Wrseq 'Default [F],[L],[S],[V],[M]' Using [SSS_]
If find(3,TYPTXT(1..NBTXT))
 For I=1 To NBTXT
  Case TYPTXT(I)
   When 3
    Wrseq 'Read [AY'+num$(LIGTXT(I)+10)+']AXX0   = "'+TBTXT(I)+'";"'+CHTXT(I)+'";GLANGUE'; Using [SSS_]
    For GBIDC1="CLECUR1","CLECUR2"
     Read [AMP]CODPAR=2;TBTXT(I);CHTXT(I);GBIDC1
     If !fstat
      Read [AVWF]CODZONE = TBTXT(I);[AMP]VALPAR
      If !fstat
       CHAINE = "[F:"+ABTXT(I)+"]"+[AMP]VALPAR
      Else
       CHAINE = [AMP]VALPAR
      Endif
     Else
      CHAINE = '""'
     Endif
     Wrseq  ";"+CHAINE; Using [SSS_]
    Next GBIDC1
    Wrseq Using [SSS_]
  Endcase
 Next I
Endif
Wrseq 'Default [L],[S],[V],[M],[F]' Using [SSS_]
Wrseq "Return" Using [SSS_]
Wrseq Using [SSS_]

Wrseq "$CONT" Using [SSS_]
Wrseq "OKCONT = 1" Using [SSS_]
For II=1 To dim([F:ALH]SEL)
 CHAINE = format$("KTv2:255X",[F:ALH]SEL(II-1))
 Gosub REC_CLOB
 If instr(1,CHAINE,"func ") or FLCLOB
  Wrseq 'CRITNXT = "'+ctrans(CHAINE,'"','¨')+'"' Using [SSS_]
  Wrseq 'Gosub REMPLACE_NXT From SUBALH9' Using [SSS_]
  Wrseq 'OKCONT *= evalue(CRITNXT)' Using [SSS_]
 Endif
Next II
Wrseq "Return" Using [SSS_]
Wrseq Using [SSS_]

Wrseq "$DEFVAR" Using [SSS_]
Wrseq "[L]NBGRP = "+num$(NBGRP) Using [SSS_]
Wrseq "[L]NBCOL = "+num$(NBCOL) Using [SSS_]
If [F:ALH]NBRLIG=0
 Wrseq "[L]NBLIG = 100" Using [SSS_]
Else
 Wrseq "[L]NBLIG = "+num$([F:ALH]NBRLIG) Using [SSS_]
Endif
Raz TRI, GROUPE, CUM, NIVEAU
Filter [ALD] Where COD=LISTE & STREND<=2 Order By Key CLE=COD;NIV;LIG
For [ALD]CLE
 If [F:ALD]CUM=2
  Wrseq "[L]CUM("+num$([F:ALD]LIG)+") = 1" Using [SSS_]
  If CUM=0 : CUM = [F:ALD]LIG : Endif
 Endif
 If NIVEAU<[F:ALD]NIV : NIVEAU = [F:ALD]NIV : Endif
 Read [ATY]CODTYP = [F:ALD]CODTYP
 If [F:ATY]TYPTYP>1 & [F:ATY]TYPTYP<7 & find([F:ALD]CODTYP,"ATX","AXX","AX1","AX2","AX3")=0
  If TRI([F:ALD]NIV)=0 :  TRI([F:ALD]NIV) = [F:ALD]LIG : Endif
 Endif
 If [F:ALD]GRP=2
  GROUPE += 1
  Wrseq "[L]GRP("+num$([F:ALD]LIG)+") = "+num$(GROUPE) Using [SSS_]
  If GROUPE=1
   Wrseq "[L]COLGRP = "+num$([F:ALD]LIG) Using [SSS_]
   Wrseq "[L]SNSGRP = "+num$([F:ALD]SRT) Using [SSS_]
  Endif
 Endif
Next
Filter [ALD]
For I=1 To NIVEAU
 If TRI(I)=0 : TRI(I) = CUM : Endif
 Wrseq "[L]TRI("+num$(I)+") = "+num$(TRI(I)) Using [SSS_]
Next I
If dim([L]TYPENV)>0 & [L]TYPENV & 0
 Wrseq "Local libelle TYPENV : [L]TYPENV = "+num$([L]TYPENV) Using [SSS_]
Endif
Wrseq '[L]AOBSIT = "'+AOBSIT+'"' Using [SSS_]
Wrseq '[L]AOBACC = "'+AOBACC+'"' Using [SSS_]
Wrseq '[L]AOBFIC = "'+AOBFIC+'"' Using [SSS_]
If dim([F:ALH]TYPENV)>0
 Wrseq '[L]LNKFIC = "'+LNKFIC+'"' Using [SSS_]
Endif
Wrseq "Return" Using [SSS_]
Wrseq Using [SSS_]

### Verification tunnel bons

K = 0
GROUPE = 0
Filter [ALD]Where COD=LISTE & STREND<=2 Order By Key CLE=COD;NIV;LIG
For [ALD]CLE
 If [F:ALD]GRP = 2
  GROUPE += 1
 Endif
 If dim([F:ALD]TUN) <0 | (dim([F:ALD]TUN) > 0 & find([F:ALD]TUN,0,2))
  Read [ATY]CODTYP = [F:ALD]CODTYP
  If [F:ATY]OBJLIEN<>"" & [F:ATY]CODTYP <> "VCR"
   Read [AOB]ABREV = [F:ATY]OBJLIEN
   If instr(0,[F:ALD]FLD,"(")
    Read [AVWF]CODZONE = [F:ALD]TBL;left$([F:ALD]FLD,instr(0,[F:ALD]FLD,"(")-1)
   Else
    Read [AVWF]CODZONE = [F:ALD]TBL;[F:ALD]FLD
   Endif
   If !fstat &  vireblc([F:AVWF]EXPLIEN,2)<>""
    TLIEN =  vireblc([F:AVWF]EXPLIEN,2)
    Gosub CTLLIEN
    If OKFLD
     K += 1
     TLIEN = [F:AVWF]EXPLIEN
     Gosub TUNLIEN
     I = find([F:AOB]ABREV,TOBJ(1..K))
     If I
      If THOM(I)=0
       THOM(I) = 1
      Endif
      THOM(K) = 1
     Else
      THOM(K) = 0
     Endif
     TINT(K) = [F:ALD]LIG
     TOBJ(K) = [F:AOB]ABREV
     If [F:ALD]GRP = 2
      TNIV(K) = num$(GROUPE)
     Else
      TNIV(K) = ""
     Endif
    Endif
   Else
    K += 1
    TCOL(K,1) = format$("N0:##",[F:ALD]LIG)
    TTYP(K,1) = [F:ALD]CODTYP
    TLNG(K,1) = func LNG([F:ALD]CODTYP,[F:ALD]LNG)
    TMEN(K,1) = [F:ALD]NOLIB
    TOBJ(K)   = [F:AOB]ABREV
    If [F:ALD]GRP = 2
     TNIV(K) = num$(GROUPE)
    Else
     TNIV(K) = ""
    Endif
   Endif
  Elsif [F:ATY]CODTYP = "VCR"
   ERVAL = 0
   If instr(0,[F:ALD]FLD,"(")
    FLDVCR = left$([F:ALD]FLD,instr(0,[F:ALD]FLD,"(")-1)
   Else
    FLDVCR = [F:ALD]FLD
   Endif
   Read [F:AMP]CODPAR = 2;[F:ALD]TBL;FLDVCR ;"VCROBJ"
   If !fstat
    If left$([F:AMP]VALPAR,1)="'" or left$([F:AMP]VALPAR,1)='"'
     WOBJPAR = seg$([F:AMP]VALPAR,2,len([F:AMP]VALPAR)-1)
    Else
     WOBJPAR = [F:AMP]VALPAR
    Endif
    Read [F:AOB]ABREV  = WOBJPAR
    If !fstat
     Read [F:AMP]CODPAR = 2;[F:ALD]TBL;FLDVCR;"OBJZON"
     If !fstat & [F:AMP]VALPAR<>""
      WVALPAR = [F:AMP]VALPAR
     Else
      WVALPAR = '""'
     Endif
     TLIEN = WVALPAR +";"+FLDVCR
     Gosub CTLLIEN
     If OKFLD
      K += 1
      TLIEN = WVALPAR +";"+FLDVCR
      Gosub TUNLIEN
      I = find([F:AOB]ABREV,TOBJ(1..K))
      If I
       If THOM(I)=0
        THOM(I) = 1
       Endif
       THOM(K) = 1
      Else
       THOM(K) = 0
      Endif
      TINT(K) = [F:ALD]LIG
      TOBJ(K) = [F:AOB]ABREV
      If [F:ALD]GRP = 2
       TNIV(K) = num$(GROUPE)
      Else
       TNIV(K) = ""
      Endif
     Endif
    Endif
   Endif
  Endif
  If K>=MAXBOUT : Break : Endif
 Endif
Next ALD
Filter [ALD]

Wrseq "$TUNLIEN" Using [SSS_]
Wrseq "Local Char    TLIEN(30)(1.."+num$(MAXBOUT)+") , TTYP(GLONATY)(1.."+num$(MAXBOUT)+")" Using [SSS_]
Wrseq "Local Decimal TLONG(1.."+num$(MAXBOUT)+")" Using [SSS_]
Wrseq "Local Integer TMEN(1.."+num$(MAXBOUT)+")" Using [SSS_]
Wrseq "Case NOBOUT" Using [SSS_]
For I=1 To K
 Wrseq " When"-num$(I) Using [SSS_]
 For J=1 To dim(TCOL,2)
  If TCOL(I,J) = "" : Break : Endif
  Wrseq '  '; Using [SSS_]
  Wrseq 'TTYP('+num$(J)+')'+space$(max(0,1-int(J/10)))+' = "'+TTYP(I,J)+'"'; Using [SSS_]
  Wrseq space$(GLONATY-len(TTYP(I,J)))+' : '; Using [SSS_]
  Wrseq 'TLONG('+num$(J)+')'+space$(1-int(J/10))+' = '+num$(TLNG(I,J)); Using [SSS_]
  Wrseq space$(max(0,5-len(num$(TLNG(I,J)))))+' : '; Using [SSS_]
  Wrseq 'TMEN('+num$(J)+')'+space$(1-int(J/10))+' = '+num$(TMEN(I,J)); Using [SSS_]
  Wrseq space$(max(0,4-len(num$(TMEN(I,J)))))+' : '; Using [SSS_]
  Wrseq 'TLIEN('+num$(J)+')'+space$(1-int(J/10))+' = "'+TCOL(I,J)+'"' Using [SSS_]
 Next J
Next
Wrseq " When Default" Using [SSS_]
Wrseq "Endcase" Using [SSS_]
Wrseq "Return" Using [SSS_]
Wrseq Using [SSS_]

Wrseq "$BOUTONS" Using [SSS_]
Wrseq "Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8" Using [SSS_]
Wrseq "Raz GBOUT9, GBOUT10, GBOUT11, GBOUT12, GBOUT13, GBOUT14, GBOUT15, GBOUT16" Using [SSS_]
For I=1 To K
 M=0
 For J=1 To dim(TCOL,2)
  If TCOL(I,J) = "" : Break : Endif
  If TTYP(I,J) <> ""
   Call LECTURE("ATY",TTYP(I,J),"") From CONTOBJ
   If !M
    Wrseq "If "; Using [SSS_]
    M =1
   Else
    Wrseq "& | "; Using [SSS_]
   Endif
   If find([F:ATY]TYPTYP,1,2,3,4,5,6)
    Wrseq "[M:LST]C"+format$("N0:2",TCOL(I,J))+'(nolign-1) > 0 ' Using [SSS_]
   Elsif find([F:ATY]TYPTYP,8)
    Wrseq "[M:LST]C"+format$("N0:2",TCOL(I,J))+'(nolign-1) > [0/0/0] ' Using [SSS_]
   Else
    Wrseq "[M:LST]C"+format$("N0:2",TCOL(I,J))+'(nolign-1) <> "" ' Using [SSS_]
   Endif
  Endif
 Next
 If M
  ESC =" "
  If TNIV(I) <> ""
   Wrseq " If [M:LST]NIV >="-TNIV(I)  Using [SSS_]
   ESC +=" "
  Endif
  Read [AOB]ABREV=TOBJ(I)
  If THOM(I)
   Wrseq ESC+'GBOUT'+num$(I)+' = '; Using [SSS_]
   Wrseq ' func AFNC.TEXTRA("ALISTED","INTITLIG","'+LISTE+'","'+num$(TINT(I))+'")' Using [SSS_]
  Else
   Wrseq ESC+"Call TEXTE("+num$([F:AOB]LIBEL)+",GBOUT"+num$(I)+") From OBJDIV" Using [SSS_]
  Endif
  Wrseq ESC+'[M:LST]TUNNEL('+num$(I)+') = "'+[F:AOB]ABREV+'"' Using [SSS_]
  If TNIV(I) <> "" : Wrseq " Endif" Using [SSS_] : Endif
  Wrseq "Endif" Using [SSS_]
 Endif
Next
Wrseq "Return" Using [SSS_]
Wrseq Using [SSS_]

Wrseq "$LECTURE" Using [SSS_]
Filter [ALD] Where COD=LISTE & STREND<=2 & FLD="" & find(CODTYP,"ATX","AXX","AX1","AX2","AX3")=0
Read [ALD]ALD0 First
Filter [ALD]
If fstat=0
 K = 0
 For I=1 To NBFIC2
  Read [AVWT]CODFIC = TBFIC(I)
  If !fstat
   If K=0
    Wrseq 'If I=1' Using [SSS_]
    Wrseq ' Default File "'; Using [SSS_]
   Endif
   If K>0
    Wrseq ' , '; Using [SSS_]
   Endif
   K = 1
   Wrseq '['+ABFIC(I)+']'; Using [SSS_]
  Endif
 Next I
 If K>0
  Wrseq '"' Using [SSS_]
  Wrseq 'Endif' Using [SSS_]
 Endif
Endif

Wrseq "Case I" Using [SSS_]
J = 0
For [ALD]ALD0 Where COD=LISTE & STREND<=2
 J += 1
 K = find([F:ALD]TBL,TBFIC(1..NBFIC2))
 Read [ATY]CODTYP = [F:ALD]CODTYP
 Wrseq " When"-num$(J); Using [SSS_]
 If [F:ALD]CODTYP="ATX"
  Wrseq ": [F:ALR]TYP = 7 : [F:ALR]VLR = [F:AX"+num$([F:ALD]LIG+10)+"]TEXTE" Using [SSS_]
 Elsif find([F:ALD]CODTYP,"AXX","AX1","AX2","AX3")<>0
  Wrseq ": [F:ALR]TYP = 7 : [F:ALR]VLR = [F:AY"+num$([F:ALD]LIG+10)+"]TEXTE" Using [SSS_]
 Else
  Case [F:ATY]TYPTYP
   When 12   :  Wrseq ": [F:ALR]TYP =8"; Using [SSS_]
   When 11   :  Wrseq ": [F:ALR]TYP =7"; Using [SSS_]
   When Default   :  Wrseq ": [F:ALR]TYP ="-num$([F:ATY]TYPTYP); Using [SSS_]
  Endcase
  Case [F:ATY]TYPTYP
   When 7       : Wrseq " : [F:ALR]VLR = "; Using [SSS_]
   When 8,12    : Wrseq " : [F:ALR]DAT = "; Using [SSS_]
   When 11      : Wrseq " : [F:ALR]VLR = "; Using [SSS_]
   When Default : Wrseq " : [F:ALR]NUM = "; Using [SSS_]
  Endcase
  If [F:ALD]FLD<>""
   If [F:ATY]TYPTYP=12
    Wrseq "func ASYRFNC.DATE_FROM_DT([F:"+ABFIC(K)+"]"+[F:ALD]FLD+")" Using [SSS_]
   Elsif [F:ATY]TYPTYP=11
    Wrseq "num$([F:"+ABFIC(K)+"]"+[F:ALD]FLD+")" Using [SSS_]
   Else
    Wrseq "[F:"+ABFIC(K)+"]"+[F:ALD]FLD Using [SSS_]
   Endif
  Else
   Wrseq vireblc(format$("KT:250X",[F:ALD]CLC),2) Using [SSS_]
  Endif
 Endif
Next
Wrseq "Endcase" Using [SSS_]
Wrseq "Return" Using [SSS_]
Wrseq Using [SSS_]

Return

$ERR
ERVAL = errn
Resume

Funprog LNG(TYP,LONG)
Value Char    TYP
Value Decimal LONG
If !clalev([F:ATY2]) : Local File ATYPE [ATY2] : Endif
Read [F:ATY2]CODTYP = [L]TYP
If [F:ATY2]LNGTYP<>0
 If instr(1,[F:ATY]OPTION,"F")
  If !instr(1,num$([F:ATY]LNGTYP),".")
   End 0
  Else
   End [F:ATY]LNGTYP
  Endif
 Else
  End [F:ATY]LNGTYP
 Endif
Endif
End LONG



##############################
$REC_CLOB
FLCLOB = 0
CHAINE = vireblc(format$("KT:255X",CHAINE),2)
J = 0
Repeat
 J = instr(J+1,CHAINE,"[")
 If J
  K = instr(J+1,CHAINE,"]")
  If K & !instr(1,seg$(CHAINE,J+1,K-1),"/")
   Repeat
    K += 1
   Until K>len(CHAINE) or !instr(1,sigma(0,25,chr$(65+indcum))+sigma(0,9,chr$(48+indcum))+"_",mid$(CHAINE,K,1))
   CH2 = seg$(CHAINE,J,K-1)
   K = instr(1,CH2,"]")
   CH3 = seg$(CH2,2,K-1)
   CH4 = right$(CH2,K+1)
   If left$(CH3,2)="F:" : CH3 = right$(CH3,3) : Endif
   Read [AVWT]CODFIC = func TABLE(LISTE,CH3)
   If !fstat
    Read [AVWF]CODZONE = [F:AVWT]CODFIC;CH4
    If !fstat
     Read [ATY]CODTYP=[F:AVWF]CODTYP
     If !fstat & find([F:ATY]TYPTYP,9,10)
      FLCLOB = 1 : Break
     Endif
    Endif
   Endif
  Endif
 Endif
Until J=0
Return

########################################################
## Champ TUNLIEN pour la gestion des tunnels
########################################################
$CTLLIEN
OKLIEN = 1
LIENCOMPO = instr(1,TLIEN,";") : # CCL 44899
While TLIEN<>""
 P = instr(1,TLIEN,";")
 If P
  FLDLIG = left$(TLIEN,P-1)
  TLIEN = right$(TLIEN,P+1)
 Else
  If LIENCOMPO & [F:AOB]TYPGES = 3 : Break : Endif : # CCL 44899
  FLDLIG = TLIEN
  TLIEN = ""
 Endif
 FLDLIG = ctrans(FLDLIG,'"',"'")
 Gosub FIND_FLD
 If !OKFLD and ERFLD
  OKLIEN = 0
  Break
 Endif
Wend
Return

$TUNLIEN
I = 0
While TLIEN<>""
 P = instr(1,TLIEN,";")
 If P
  FLDLIG = left$(TLIEN,P-1)
  TLIEN = right$(TLIEN,P+1)
 Else
  FLDLIG = TLIEN
  TLIEN = ""
 Endif
 FLDLIG = ctrans(FLDLIG,'"',"'")
 If GPRODUIT<>1 or (!find(FLDLIG,"FCY","DEP") or (find(FLDLIG,"FCY","DEP") & FLDLIG=[F:AVWF]CODTYP))
  I += 1
  Gosub FIND_FLD
  If OKFLD
   TCOL(K,I) = format$("N0:##",[F:ALD2]LIG)
   TTYP(K,I) = [F:ALD2]CODTYP
   TLNG(K,I) = func LNG([F:ALD2]CODTYP,[F:ALD2]LNG)
   TMEN(K,I) = [F:ALD2]NOLIB
  Else
   P = instr(1,FLDLIG,"indice")
   If P
    TCOL(K,I) = left$(FLDLIG,P-1)+"0"+right$(FLDLIG,P+7)
   Else
    TCOL(K,I) = FLDLIG
   Endif
   TTYP(K,I) = ""
   TLNG(K,I) = 0
   TMEN(K,I) = 0
  Endif
 Endif
Wend
Return

$FIND_FLD
Raz OKFLD, ERFLD
Filter [ALD2] Where FLD=FLDLIG & COD=[F:ALD]COD & TBL=[F:ALD]TBL & STREND<=2
Read [ALD2]ALD0 First
Filter [ALD2]
If GPRODUIT=1 & find(FLDLIG,"FCY","DEP")
 OKFLD = 1
Elsif !fstat
 OKFLD = 1
Elsif instr(1,sigma(0,25,chr$(65+indcum)),left$(FLDLIG,1))
 ERFLD = 1
Endif
Return

########################################################
## Génération de l'écran qui va bien
########################################################

$MASQUE
NBLAN  = 1
LAN(1) = GLANGUE
Gosub SETMSK From SUBALH
MASQUE = PREFMSK+LISTE
MSKREF = "ALISTE"

Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1
 OK = 0 : Return
Endif
Call VALID(MASQUE,APPLI,NBLAN,LAN,SILENCE,STAT) From VALMSK
Return

$TR1
GOK = 1
Trbegin [AMK] , [AMZ]

# Effacement masques précédents
 Call DELMSK(MASQUE,APPLI) From MSKDIV
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 Read [AMK]CODMSK = MSKREF
 [F:AMK]CODMSK  = MASQUE
 BLKTAB = find(1,[F:AMK]TYPBLOC(0..[F:AMK]NBBLOC-1))-1
 If [F:ALH]NBRLIG<>0
  [F:AMK]NBLIGT(BLKTAB) = [F:ALH]NBRLIG
 Endif
 If [F:ALH]NBRCOL<>0
  For I=1 To 9
   J = instr(1,[F:AMK]OPTION(BLKTAB),num$(J))
   If J
    [F:AMK]OPTION(BLKTAB) = left$([F:AMK]OPTION(BLKTAB),J-1)+right$([F:AMK]OPTION(BLKTAB),K+1)
   Endif
  Next I
  [F:AMK]OPTION(BLKTAB) += num$([F:ALH]NBRCOL)
 Endif
 [F:AMK]MDL = 1
 [F:AMK]BLOCTYPT(BLKTAB) = [F:ALH]REPGRA
 [F:AMK]BLOCTYPG(BLKTAB) = [F:ALH]TYPGRA
 [F:AMK]BLOCPOSG(BLKTAB) = [F:ALH]POSGRA
 [F:AMK]BLOCGDEF(BLKTAB) = [F:ALH]DEFGRA
 [F:AMK]BLOCAFFD(BLKTAB) = [F:ALH]AFFGRA
 [F:AMK]BLOCREPD(BLKTAB) = [F:ALH]FSHGRA
 Write [AMK]
 If fstat
  GOK = 0 : Call FSTA("AMK") From GLOCK : Goto AB_TR1
 Endif
 For [AMZ]CODZON Where CODMSK=MSKREF
  [F:AMZ]CODMSK = MASQUE
  Write [AMZ]
  If fstat
   GOK = 0 : Call FSTA("AMZ") From GLOCK : Break
  Endif
  Call COPIE_ACTION(MSKREF,MASQUE,[F:AMZ]CODZON)
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 J = 0
 For [ALD]ALD0 Where COD=LISTE & STREND<=2
  J += 1
  Raz [F:AMZ]
  [F:AMZ]CODMSK  = MASQUE
  [F:AMZ]CODZON  = "C"+format$("N0:##",J)
  [F:AMZ]NUMBLOC = BLKTAB+1
  [F:AMZ]NOZONE  = 10+J
  Read [ATY]CODTYP = [F:ALD]CODTYP
  If find([F:ALD]CODTYP,"ATX","AXX")
   [F:AMZ]CODTYP = "A"
   [F:AMZ]LONG   = 30
  Elsif find([F:ALD]CODTYP,"AX1","AX2","AX3")
   [F:AMZ]CODTYP = "A"
   [F:AMZ]LONG   = [F:ATY]LNGTYP
  Else
   Case [F:ATY]TYPTYP
    When 1
     [F:AMZ]CODTYP = "M"
     [F:AMZ]NOLIB  = [F:ALD]NOLIB
     [F:AMZ]LONG   = func LNG([F:ALD]CODTYP,[F:ALD]LNG)
    When 7
     [F:AMZ]CODTYP = "A"
     [F:AMZ]LONG   = func LNG([F:ALD]CODTYP,[F:ALD]LNG)
    When 8,12
     [F:AMZ]CODTYP = "D"
    When 11
     [F:AMZ]CODTYP = "A"
     [F:AMZ]LONG   = 100
    When Default
     [F:AMZ]CODTYP = "DCB"
     [F:AMZ]LONG   = func LNG([F:ALD]CODTYP,[F:ALD]LNG)
     [F:AMZ]OPTSAI = "3z"
     If left$([F:ATY]FORTYP,1)="=" : [F:AMZ]LONG=15 : [F:AMZ]OPTSAI+="F" : Endif
   Endcase
  Endif
  [F:AMZ]INTEVAL = 'func AFNC.TEXTRA("ALISTED","INTITLIG","'+[F:ALD]COD+'","'+num$([F:ALD]LIG)+'")'
  [F:AMZ]DIME    = [F:AMK]NBLIGT(BLKTAB)
  [F:AMZ]NUMLIG  = 10+J
  [F:AMZ]SAIAFF  = 2
  [F:AMZ]MODE    = 1
  Case [F:ALD]GRA
   When 1       : [F:AMZ]CHPARG = "G01:VALUE"
   When 2       : [F:AMZ]CHPARG = "G02:DEF"
   When 3       : [F:AMZ]CHPARG = "G03:LIB"
   When Default : [F:AMZ]CHPARG = ""
  Endcase
 [F:AMZ]CHREPR = [F:ALD]REP
  Write [AMZ]
  If fstat
   GOK = 0 : Call FSTA("AMZ") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

########################################################
## Génération de la fenêtre qui va bien
########################################################

$FENETRE
Gosub SETMSK From SUBALH
FENETRE = PREFMSK+LISTE
WINREF  = "ALISTE"

Call DEBTRANS From GLOCK
Gosub TR2
If GOK<1
 OK = 0 : Return
Endif
Call VALID(FENETRE,APPLI,SILENCE,OK) From VALWIN
Return

$TR2
GOK = 1
Trbegin [AWI] , [AWP], [AWB], [AWT]
 Call DELWIN(FENETRE,APPLI) From MSKDIV
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Read [AWI]AWI0 = WINREF
 [F:AWI]WIN       = FENETRE
 [F:AWI]NOMMSK(0) = FENETRE
 [F:AWI]WINTYP    = 1
 [F:AWI]MDL       = 1
 Write [AWI]
 If fstat
  GOK = 0 : Call FSTA("AWI") From GLOCK : Goto AB_TR2
 Endif
 For [AWP]AWP0 Where WIN=WINREF
  [F:AWP]WIN = FENETRE
  Write [AWP]
  If fstat
   GOK = 0 : Call FSTA("AWP") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR2 : Endif
 For [AWB]AWB0 Where WIN=WINREF
  [F:AWB]WIN = FENETRE
  Write [AWB]
  If fstat
   GOK = 0 : Call FSTA("AWB") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR2 : Endif
 For [AWT]AWT0 Where WIN=WINREF
  [F:AWT]WIN = FENETRE
  Write [AWT]
  If fstat
   GOK = 0 : Call FSTA("AWT") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR2 : Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

#######################################################
Subprog COPIE_ACTION(MASKORG,MASKDES,ZONE)
Value Char MASKORG
Value Char MASKDES
Value Char ZONE
For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=MASKORG & CODZON=ZONE
 [F:AMA2] = [F:AMA]
 [F:AMA2]CODAFF = MASKDES
 Write [AMA2]
 If fstat
  GOK=0 : Call FSTA("AMA2") From GLOCK : Break
 Endif
Next
If GOK<1 : End : Endif
For [AMP]CODPAR Where TYPAFF=1 & CODAFF=MASKORG & CODZON=ZONE
 [F:AMP2] = [F:AMP]
 [F:AMP2]CODAFF = MASKDES
 Write [AMP2]
 If fstat
  GOK=0 : Call FSTA("AMP2") From GLOCK : Break
 Endif
Next
If GOK<1 : End : Endif
End

Funprog TABLE(COD,ABRFIC)
Value Char COD
Value Char ABRFIC
Local Char TABLE(GLONATB)
For [ALD]Where COD = [L]COD
 Read [AVWT]CODFIC = [F:ALD]TBL
 If !fstat & [F:AVWT]ABRFIC = [L]ABRFIC
  TABLE = [F:ALD]TBL : Break
 Endif
Next ALD
End TABLE

###########################################################
## Génération d'une liste depuis un objet (GEODE)
###########################################################
Subprog CRELIS(APPLI,OBJET,SILENCE,OK)
Value    Char    APPLI(), OBJET()
Value    Integer SILENCE
Variable Integer OK

Local Integer I , J , K , K1 , K2 , NBFIC , NBCLE , NBLAN, IITM
Local Char    ABFIC(GLONABR+2) , TBFIC(GLONATB)(1..100) , TBCLE(GLONAVA)(1..16)
Local Char    DESAX(80), SAVLAN(GLONLAN)
Local Char    OBJTUN(GLONAOB)

If APPLI="" : APPLI = nomap : Endif

GERREUR = 0
Onerrgo ERREUR From CONTROLE
Local File =APPLI+".AOBJET"   [AOB]
Local File =APPLI+".AOBJTAB"  [AOT]
Local File =APPLI+".AOBJLST"  [AOL]
Local File =APPLI+".ATYPE"    [ATY]
Local File =APPLI+".ATEXTE"   [ATX]
Local File =APPLI+".ATEXTRA"  [AXX]
Local File =APPLI+".ALISTEH"  [ALH]
Local File =APPLI+".ALISTED"  [ALD]
Local File =APPLI+".AMSK"     [AMK]
Local File =APPLI+".AMSKZON"  [AMZ]
Local File =APPLI+".AMSKACT"  [AMA]
Local File =APPLI+".AMSKACT"  [AMA2]
Local File =APPLI+".AMSKPAR"  [AMP]
Local File =APPLI+".AMSKPAR"  [AMP2]
Local File =APPLI+".AWINDOW"  [AWI]
Local File =APPLI+".AWINPAR"  [AWP]
Local File =APPLI+".ACTIV"    [ACV]
Local File =APPLI+".ATABLE"   [ATB]
Local File =APPLI+".ATABZON"  [ATZ]
Local File =APPLI+".ATABIND"  [ATI]
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Onerrgo
If GERREUR : GERREUR = 0 : OK = 0 : End : Endif

Local Char LAN(GLONLAN)(dim([F:ADS]LAN))
Read [ADS]DOSSIER = APPLI
If !fstat
 For I=1 To [F:ADS]NBRLAN
  NBLAN += 1
  LAN(NBLAN) = [F:ADS]LAN(I-1)
 Next I
Endif
If NBLAN<1 : NBLAN=1 : LAN(NBLAN)=GLANGUE : Endif

Read [AOB]ABREV = OBJET
If fstat : OK = 0 : End : Endif
Read [AOL]AOL0  = OBJET
If fstat : OK = 0 : End : Endif
Read [ALH]ALH0 = OBJET
If !fstat : OK = 0 : End : Endif
Call DEBTRANS From GLOCK
SAVLAN=GLANGUE
Gosub TR3
GLANGUE=SAVLAN

If GOK=1
 Call VALIDE(OBJET,APPLI,0,SILENCE)
 OK = 1
Else
 OK = 0
Endif
End

$TR3
GOK = 1
Trbegin [ALH]
 Raz [F:ALH]
 Read [ATI]NUMLIG(2) = [F:AOB]NOMFIC;1
 If left$([F:ATI]DESCRIPT,8)="FCY+DEP+" : [F:ALH]TYPENV = 2
 Elsif left$([F:ATI]DESCRIPT,4)="FCY+"  : [F:ALH]TYPENV = 1
 Else                                   : [F:ALH]TYPENV = 0
 Endif
 CHAINE = [F:ATI]DESCRIPT
 NBCLE  = 0
 While CHAINE<>""
  K1 = instr(1,CHAINE,"+")
  K2 = instr(1,CHAINE,"-")
  If    K1 & K2  : K1 = min(K1,K2)
  Elsif K2 & !K1 : K1 = K2
  Endif
  NBCLE += 1
  If K1
   TBCLE(NBCLE) = left$(CHAINE,K1-1)
   CHAINE       = right$(CHAINE,K1+1)
  Else
   TBCLE(NBCLE) = CHAINE
   CHAINE       = ""
  Endif
 Wend
 [F:ALH]COD = OBJET
 [F:ALH]TYP = 1
 For J=1 To NBLAN
  GLANGUE=LAN(J)
  Call TEXTE([F:AOB]LIBEL,DESAX) From OBJDIV
  Call MAJTEXTRA(DESAX,"ALISTEH","INTIT",[F:ALH]COD,"") From ATEXTRA
  Call TEXTE([F:AOB]LIBSHO,DESAX) From OBJDIV
  Call MAJTEXTRA(DESAX,"ALISTEH","INTITSHO",[F:ALH]COD,"") From ATEXTRA
 Next
 [F:ALH]REPGRA = 1
 [F:ALH]ENAFLG = 2
 [F:ALH]GRP = OBJET
 [F:ALH]ALLUSR = 2
 If dim([F:ALH]CREUSR)>0 : [F:ALH]CREUSR = GUSER     : Endif
 If dim([F:ALH]CREDAT)>0 : [F:ALH]CREDAT = date$     : Endif
 If dim([F:ALH]CRETIM)>0 : [F:ALH]CRETIM = time      : Endif
 If dim([F:ALH]EXPNUM)>0 : [F:ALH]EXPNUM = [C]EXPORT : Endif

 NBFIC=0 : K=0 : J=0 : IITM=0
 For I=0 To [F:AOL]NBSEL-1
  If [F:AOL]SELFIC(I)<>""
   If [F:AOL]SELFIC(I)="ATEXTRA" & [F:AOL]SELZON(I)="TEXTE" : # Requête ITC : ATEXTE TEXTE => CONTAINER CTRDESAXX
    Filter [AOT] Where find(TABABR,"","AXX")<>0
    Read [AOT]TABFIC(2) = [L]OBJET;[F:AOL]SELFIC(I)
    Filter [AOT]
    If fstat<=2
     K1=instr(1,[F:AOT]TABLIEN,";")
     If K1
      K2=instr(K1+1,[F:AOT]TABLIEN,";")
      If K2
       [F:AOL]SELFIC(I) = seg$([F:AOT]TABLIEN,2,K1-2)
       [F:AOL]SELZON(I) = seg$([F:AOT]TABLIEN,K1+2,K2-2)
      Endif
     Endif
    Endif
   Endif
   If !find([F:AOL]SELFIC(I),TBFIC(1..NBFIC))
    NBFIC += 1
    TBFIC(NBFIC) = [F:AOL]SELFIC(I)
   Endif
   If !J & [F:AOL]SELFIC(I)=[F:AOB]NOMFIC & [F:AOL]SELZON(I)="ITM" : J=I+1 : Endif
  Elsif instr(1,[F:AOL]SELEXP(I),"[F:ITM]")
   K=1
  Endif
 Next
 If !find("ITEM",TBFIC(1..NBFIC)) & K & J :  # Requête ITC : ITEMCTR ITM => ITEM ITM
  # si [F:ITM] dans une expression [AOL]SELEXP mais la table ITEM dans aucun [AOL]SELFIC, et s'il existe un lien
  # entre [AOB]NOMFIC et ITEM et si une ligne reprend ITM de la table  [AOB]NOMFIC,  alors on remplace
  # dans cette ligne la table [AOB]NOMFIC par ITEM
  Filter [AOT] Where find(TABABR,"","ITM")<>0
  Read [AOT]TABFIC(2)=[L]OBJET;"ITEM"
  Filter [AOT]
  If fstat<=2
   Read [ATB]CODFIC = [F:AOB]NOMFIC
   ABFIC = [F:ATB]ABRFIC
   If [F:AOT]TABLIEN="[F:"+ABFIC+"]FCY;[F:"+ABFIC+"]DEP;[F:"+ABFIC+"]ITM"
    [F:AOL]SELFIC(J-1) = "ITEM"
    NBFIC += 1
    TBFIC(NBFIC) = [F:AOL]SELFIC(J-1)
    IITM=J
   Endif
  Endif
 Endif

 For I=0 To [F:AOL]NBSEL-1
  Raz [F:ALD]
  [F:ALD]COD = OBJET
  [F:ALD]LIG = I+1
  If [F:AOL]SELFIC(I)<>""
   [F:ALD]TBL = [F:AOL]SELFIC(I)
   [F:ALD]FLD = [F:AOL]SELZON(I)
  Else
   K2 = 0
   Repeat
    K1 = instr(K2+1,[F:AOL]SELEXP(I),"[F:")
    If K1
     K2 = instr(K1+1,[F:AOL]SELEXP(I),"]")
     If K2
      ABFIC = seg$([F:AOL]SELEXP(I),K1+3,K2-1)
      Read [ATB]ABRFIC = ABFIC
      If !fstat
       [F:ALD]TBL = [F:ATB]CODFIC
      Elsif [F:AOL]SELEXP(I)="[F:"+ABFIC+"]TEXTE" : : # Requête FAM : [F:AT2]TEXTE => FAMILY FAMSHOAXX
       Filter [AOT] Where TABABR=[L]ABFIC
       Read [AOT]ABREV(1) = [L]OBJET
       Filter [AOT]
       If fstat<=2
        J=instr(1,[F:AOT]TABLIEN,";")
        If J
         K=instr(J+1,[F:AOT]TABLIEN,";")
         If K
          [F:ALD]FLD = seg$([F:AOT]TABLIEN,J+2,K-2)
          [F:ALD]TBL = seg$([F:AOT]TABLIEN,2,J-2)
         Endif
        Endif
       Endif
      Endif
     Endif
    Endif
   Until !K1 | !K2 | !find([F:ALD]TBL,TBFIC(1..NBFIC))
   If [F:ALD]TBL=""
    [F:ALD]TBL = [F:AOB]NOMFIC
   Endif
  Endif
  If !find([F:ALD]TBL,TBFIC(1..NBFIC))
   NBFIC += 1
   TBFIC(NBFIC) = [F:ALD]TBL
  Endif

  If [F:ALD]FLD<>""
   Read [ATZ]CODZONE = [F:ALD]TBL;[F:ALD]FLD
   [F:ALD]CODTYP = [F:ATZ]CODTYP
   [F:ALD]NOLIB  = [F:ATZ]NOLIB
   Read [ATY]CODTYP = [F:ALD]CODTYP
   If [F:ATY]LNGTYP=0
    If [F:ATZ]LONG<>0
     [F:ALD]LNG   = [F:ATZ]LONG
    Else
     [F:ALD]LNG   = [F:ATY]LNGTYP
    Endif
   Endif
  Else
   [F:ALD]CLC    = [F:AOL]SELEXP(I)
   [F:ALD]CODTYP = [F:AOL]SELTYP(I)
   Read [ATY]CODTYP = [F:ALD]CODTYP
   If [F:ATY]LNGTYP=0
    Case [F:ATY]TYPTYP
     When 1 :     [F:ALD]LNG = 15
     When 2 :     [F:ALD]LNG = 4
     When 3 :     [F:ALD]LNG = 8
     When 4,5,6 : [F:ALD]LNG = 11.2
     When 7 :     [F:ALD]LNG = 30
    Endcase
   Endif
  Endif
  If find([F:ATY]TYPTYP,2,3,4,5,6) & !find([F:ALD]CODTYP,"ATX","AXX","AX1","AX2","AX3")
   [F:ALD]CUM      = 1
  Endif
  If [F:ALD]FLD<>""
   [F:ALD]STREND   = 2
   [F:ALD]SRT      = 1
  Endif
  [F:ALD]NIV       = 1
  [F:ALD]FONT      = 1
  [F:ALD]BOLD      = 1
  [F:ALD]UNDERLINE = 1
  [F:ALD]ITALICS   = 1
  If ([F:AOL]SELFIC(I)=[F:AOB]NOMFIC | I+1=IITM) & find([F:ALD]FLD,TBCLE(1..NBCLE))
   [F:ALD]SRT = 2
   [F:ALD]GRP = 1
  Endif
  ## Tunnel ?
  If [F:ATY]CODTYP<>[F:ALD]CODTYP
   Read [ATY]CODTYP = [F:ALD]CODTYP
  Endif
  If find([F:ATY]OBJLIEN,"DEP","FCY","SIT") & [F:ATY]OBJLIEN<>OBJET & GPRODUIT=1 : ## GEODE
   [F:ALD]TUN = 1 : # pas de tunnel vers DEP, FCY ou SIT sauf si liste de l'objet lui-même
  Elsif [F:ATY]OBJLIEN<>""
   [F:ALD]TUN = 2
   If I<[F:AOL]NBSEL-1 & [F:AOL]SELFIC(I)<>"" & [F:AOL]SELFIC(I+1)=[F:AOL]SELFIC(I) & GPRODUIT=1 : ## GEODE
    Case [F:ATY]OBJLIEN
     When "STO"   : OBJTUN = "SLO"
     When "PRA"   : OBJTUN = "PTY"
     When Default : OBJTUN = ""
    Endcase
    If OBJTUN<>""
     Read [ATZ]CODZONE = [F:AOL]SELFIC(I+1);[F:AOL]SELZON(I+1)
     Read [ATY]CODTYP = [F:ATZ]CODTYP
     If [F:ATY]OBJLIEN=OBJTUN : [F:ALD]TUN = 1 : Endif
    Endif
   Endif
  Else
   [F:ALD]TUN = 0
  Endif
  Write [ALD]
  If fstat
   GOK = 0 : Call FSTA("ALD") From GLOCK : Break
  Endif

  For J=1 To NBLAN
   GLANGUE=LAN(J)
   If [F:AOL]SELINT(I)=0
    Call TEXTFIC([F:AOL]SELFIC(I),[F:AOL]SELZON(I),3,DESAX) From OBJDIV
   Else
    Call TEXTE([F:AOL]SELINT(I),DESAX) From OBJDIV
   Endif
   Call MAJTEXTRA(DESAX,"ALISTED","INTITLIG",[F:ALD]COD,num$([F:ALD]LIG)) From ATEXTRA
  Next
 Next I
 Raz [F:AOL]
 If GOK=0 : Goto AB_TR3 : Endif

 J = 0
 For [AOT]ABREV Where ABREV=[L]OBJET & TABLIEN<>""
  I=1
  If [F:AOT]TABACT<>""
   Read [ACV]CODACT = [F:AOT]TABACT
   If fstat or [F:ACV]FLACT<>2 : I = 0 : Endif
  Endif
  If I
   Read [ATB]CODFIC = [F:AOT]TABFIC
   If !find([F:AOT]TABABR,"",[F:ATB]ABRFIC)
    I=0
   Endif
  Endif
  If I & [F:AOT]TABFIC="ATEXTRA" & !find([F:AOT]TABFIC,TBFIC(1..NBFIC))
   I=0
  Endif
  If I
   If J>=dim([F:ALH]LNK) : Break : Endif
   Read [ATB]CODFIC    = [F:AOT]TABFIC
   Read [ATI]NUMLIG(2) = [F:AOT]TABFIC;1
   [F:ALH]LNK(J) = "["+[F:ATB]ABRFIC+"]"+[F:ATI]CODIND+" = "+[F:AOT]TABLIEN
   J += 1
  Endif
 Next

 Write [ALH]
 If fstat
  GOK=0 : Call FSTA("ALH") From GLOCK : Goto AB_TR3
 Endif
Commit
Return

$AB_TR3
Rollback
Return

