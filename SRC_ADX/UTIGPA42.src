#<AdxTL>@(#)4.0.0.0 $Revision$ [TMA]ENAFLG initialisation
##########################################################################
# UTIGPA42: Reinit de [F:TMA]ENAFLG                     Module GPAO      #
##########################################################################
# GH 21/11/13                                           Bug 94623        # 
##########################################################################

Call MAJ_UTIGPA42
End

##################################
Subprog MAJ_UTIGPA42
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER="" : End : Endif
Call OUVRE_TRACE("UTIGPA42: [TMA]ENAFLG initialisation") From LECFIC
Call EXE_UTIGPA42(DOSSIER)
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End

##################################
Subprog EXE_UTIGPA42(DOSSIER)
Value Char DOSSIER


If filinfo(filpath("FIL","TABMAT","fde",DOSSIER),0)  <= 0  : End : Endif

Call ECR_TRACE("UTIGPA42: Process Start on : "+DOSSIER,0) From GESECRAN

Local File =[L]DOSSIER+".TABMAT"  [TMA]
Local Integer MAJ

If dim([F:TMA]ENAFLG)>0
    Trbegin [TMA]
       Update [TMA] Where ENAFLG=0 With  ENAFLG=0
       MAJ = adxuprec
    Commit
Endif

If MAJ>0
   GMESSAGE=":"-num$(MAJ)-"Records updated"
Endif
Call ECR_TRACE("UTIGPA42 : Process End on : "+DOSSIER-GMESSAGE,0) From GESECRAN
GMESSAGE=""
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat : Raz [F:ADS] : Endif
Call EXE_UTIGPA42(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3
     End 
Endif
Call EXE_UTIGPA42(APPLI)
End



