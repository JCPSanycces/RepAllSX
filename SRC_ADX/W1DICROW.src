#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DICROW 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:55"
A_USER  = "DOC"
A_STAMP = "20181109230355"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRLIG"
  If [M]NBRLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask DICROW [DIA]
Gosub HORODAT
Local Inpbox "DICROW" From GFONCTION At A_STAMP With A_WINDPREV Mask [DIA] As [SIM_]
Grizo [DIA]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DIA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=1 : Y2(0)=28
Return

$ON_TBL
Return

$ON_WDES
Onevent AFTER_AREA Call AP_WDES(zc) From W1DICROW
Return

Subprog AP_WDES(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TXTCONT
 Call TXTCONT(VALEUR,[M]WDES,[M]DES,20,50,"DIC","DES") From OBJDIV
 If mkstat : GERR = 1 : GZONE = "WDES" : GZNUM = 8 : Endif
Endif
Gosub _AFF
End

$ON_ENAFLG
Onevent INIT_AREA Call D_ENAFLG(zc) From W1DICROW
Onevent BEFORE_INPUT Call AS_ENAFLG(zc) From W1DICROW
Return

Subprog D_ENAFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]ENAFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ENAFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_ENASEL
Onevent INIT_AREA Call D_ENASEL(zc) From W1DICROW
Onevent BEFORE_INPUT Call AS_ENASEL(zc) From W1DICROW
Return

Subprog D_ENASEL(VALEUR)
Variable Integer VALEUR
If varinit([M]ENASEL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ENASEL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_MSFLG
Onevent INIT_AREA Call D_MSFLG(zc) From W1DICROW
Onevent BEFORE_INPUT Call AS_MSFLG(zc) From W1DICROW
Return

Subprog D_MSFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]MSFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_MSFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_ROW
Onevent CONTROL Call C_ROW(zc) From W1DICROW
Return

Subprog C_ROW(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ROW" : GZNUM = 747 : Endif
Gosub _AFF
End

$ON_POTFLG
Onevent BEFORE_INPUT Call AS_POTFLG(zc) From W1DICROW
Onevent INIT_AREA Call D_POTFLG(zc) From W1DICROW
Return

Subprog D_POTFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]POTFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_POTFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1401,GBOUT1) From OBJDIV
## Action STD
Call AS_POTFLG(VALEUR) From DICROW
If mkstat=2
 [M]POTFLG(INDIC) = VALEUR
 Affzo POTFLG(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_POTFLG(zc) From W1DICROW
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog B1_POTFLG(VALEUR)
Variable Integer VALEUR
If !GWEBSERV
 ## Action STD
 Call B1_POTFLG(VALEUR) From DICROW
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_FLGRET
Onevent BEFORE_INPUT Call AS_FLGRET(zc) From W1DICROW
Onevent INIT_AREA Call D_FLGRET(zc) From W1DICROW
Return

Subprog D_FLGRET(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGRET,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLGRET(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1401,GBOUT1) From OBJDIV
## Action STD
Call AS_FLGRET(VALEUR) From DICROW
If mkstat=2
 [M]FLGRET(INDIC) = VALEUR
 Affzo FLGRET(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_FLGRET(zc) From W1DICROW
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog B1_FLGRET(VALEUR)
Variable Integer VALEUR
If !GWEBSERV
 ## Action STD
 Call B1_FLGRET(VALEUR) From DICROW
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


