#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################################
# UUMGCTLTRS00                                 Module A/P-A/R Accounting   #
#                Pre-migration                                             #
#                                                                          #
# Controls                                                                 #
#                                                                          #
############################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGCTLTRS00") From LECFIC
  Endif

  Call MAJ_UUMGCTLTRS00(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

###################################################################################
Subprog MAJ_UUMGCTLTRS00(DOSSIER)
Value Char DOSSIER
Local Integer NBLUS, COMPTEUR, ERR
Local Char REQSQL (250) (3)

If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif

Local Integer EXE_SQL :  EXE_SQL = 1

Call ECR_TIME("UUMGCTLTRS00 A/P-A/R Accounting Control Process") From DOSSUB
Call ECR_TRACE("UUMGCTLTRS00 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- n°version
Local Char VERSION
Call VERSION (DOSSIER,VERSION) From DOSSUB
If val(VERSION)=0
  Call ECR_TRACE("UUMGCTLTRS00 : Error on release number : "+VERSION,0) From GESECRAN
  End
Endif
Gosub DEF_VERSIONSX3 From TRTMIGTABX3
#

# Version V6
If val(VERSION)<GMIGX3VER60
 If EXE_SQL
  Gosub PINVOICE_LIN0_SQL
  Gosub BPSINVLIG_HEA0_SQL

  Gosub SINVOICE_LIN0_SQL
  Gosub BPCINVLIG_HEA0_SQL
 Else
  Gosub PINVOICE_LIN0_X3
  Gosub BPSINVLIG_HEA0_X3

  Gosub SINVOICE_LIN0_X3
  Gosub BPCINVLIG_HEA0_X3
 Endif
Endif

$FIN
Call ECR_TIME("UUMGCTLTRS00 : A/P-A/R Accounting Requests Process END.")  From DOSSUB
End

###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQSQL,1) From GESECRAN
ERR=1
Resume

###################################################################################
$PINVOICE_LIN0_SQL
Raz COMPTEUR,ERR

REQSQL(0)="SELECT PIH.NUM_0 FROM "-DOSSIER+".PINVOICE PIH "
REQSQL(1)="WHERE PIH.ORIMOD_0=3 AND NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".BPSINVLIG PIL WHERE PIL.NUM_0=PIH.NUM_0) "
REQSQL(2)="ORDER BY PIH.NUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PINVOICE without BPSINVLIG",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPSNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"NUM="-[BXX]VPSNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return

###################################################################################
$BPSINVLIG_HEA0_SQL
Raz COMPTEUR,ERR

REQSQL(0)="SELECT DISTINCT PIL.NUM_0 FROM "-DOSSIER+".BPSINVLIG PIL "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PINVOICE PIH WHERE PIH.NUM_0=PIL.NUM_0) "
REQSQL(2)="ORDER BY PIL.NUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("BPSINVLIG without PINVOICE",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPSNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"NUM="-[BXX]VPSNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return


###################################################################################
$SINVOICE_LIN0_SQL
Raz COMPTEUR,ERR

REQSQL(0)="SELECT SIH.NUM_0 FROM "-DOSSIER+".SINVOICE SIH "
REQSQL(1)="WHERE SIH.ORIMOD_0=3 AND NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".BPCINVLIG SIL WHERE SIL.NUM_0=SIH.NUM_0) "
REQSQL(2)="ORDER BY SIH.NUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("SINVOICE without BPCINVLIG",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPSNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"NUM="-[BXX]VPSNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return

###################################################################################
$BPCINVLIG_HEA0_SQL
Raz COMPTEUR,ERR

REQSQL(0)="SELECT DISTINCT SIL.NUM_0 FROM "-DOSSIER+".BPCINVLIG SIL "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".SINVOICE SIH WHERE SIH.NUM_0=SIL.NUM_0) "
REQSQL(2)="ORDER BY SIL.NUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("BPCINVLIG without SINVOICE",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPSNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"NUM="-[BXX]VPSNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return



###################################################################################
$PINVOICE_LIN0_X3
# Non-existent Line / Ligne inexistante
Call ECR_TIME("UUMGCTLTRS00 Control Process : PINVOICE"-mess(139,105,1)) From DOSSUB

If clalev([F:PIH]) = 0 :  Local File =DOSSIER+".PINVOICE"    [PIH]   : Endif      # Supliers BP Invoices
If clalev([F:PIL]) = 0 :  Local File =DOSSIER+".BPSINVLIG"   [PIL]   : Endif      # General  BP Invoices Lines

Raz NBLUS, COMPTEUR
# Problem - Invoice without line
Filter [PIH] Where ORIMOD=3
For [PIH]PIH0
 NBLUS+=1
 Look [PIL]PIL0(1) = [F:PIH]NUM
 If fstat
  Call ECR_TRACE("File PINVOICE(NUM)"-[F:PIH]NUM,0) From GESECRAN
  COMPTEUR+=1
 Endif
Next
Call ECR_TIME("UUMGCTLTRS00 : "+num$(NBLUS)+" records read,"-num$(COMPTEUR)+" records found.") From DOSSUB
Return

###################################################################################
$BPSINVLIG_HEA0_X3
# Line without Journal / Ligne sans pièce
Call ECR_TIME("UUMGCTLTRS00 Control Process : PINVOICE"-mess(9,116,1)) From DOSSUB

If clalev([F:PIH]) = 0 :  Local File =DOSSIER+".PINVOICE"    [PIH]   : Endif      # Supliers BP Invoices
If clalev([F:PIL]) = 0 :  Local File =DOSSIER+".BPSINVLIG"   [PIL]   : Endif      # General  BP Invoices Lines

Raz NBLUS, COMPTEUR
# Problem - Invoice without header
Filter [PIH] Where ORIMOD=3
For [PIL]PIL0(1)
 NBLUS+=1
 Look [PIH]PIH0 = [F:PIL]NUM
 If fstat
  Call ECR_TRACE("File PINVOICED(NUM)"-[F:PIL]NUM,0) From GESECRAN
  COMPTEUR+=1
 Endif
Next
Call ECR_TIME("UUMGCTLTRS00 : "+num$(NBLUS)+" records read,"-num$(COMPTEUR)+" records found.") From DOSSUB
Return



###################################################################################
$SINVOICE_LIN0_X3
# Non-existent Line / Ligne inexistante
Call ECR_TIME("UUMGCTLTRS00 Control Process : SINVOICE"-mess(139,105,1)) From DOSSUB

If clalev([F:SIH]) = 0 :  Local File =DOSSIER+".SINVOICE"    [SIH]   : Endif      # Customer BP Invoices
If clalev([F:SIL]) = 0 :  Local File =DOSSIER+".BPCINVLIG"   [SIL]   : Endif      # General  BP Invoices Lines

Raz NBLUS, COMPTEUR
# Problem - Invoice without line
Filter [SIH] Where ORIMOD=3
For [SIH]SIH0
 NBLUS+=1
 Look [SIL]SIL0(1) = [F:SIH]NUM
 If fstat
  Call ECR_TRACE("File SINVOICE(NUM)"-[F:SIH]NUM,0) From GESECRAN
  COMPTEUR+=1
 Endif
Next
Call ECR_TIME("UUMGCTLTRS00 : "+num$(NBLUS)+" records read,"-num$(COMPTEUR)+" records found.") From DOSSUB
Return


###################################################################################
$BPCINVLIG_HEA0_X3
# Line without Journal / Ligne sans pièce
Call ECR_TIME("UUMGCTLTRS00 Control Process : SINVOICE"-mess(9,116,1)) From DOSSUB


If clalev([F:SIH]) = 0 :  Local File =DOSSIER+".SINVOICE"    [SIH]   : Endif      # Customer BP Invoices
If clalev([F:SIL]) = 0 :  Local File =DOSSIER+".BPCINVLIG"   [SIL]   : Endif      # General  BP Invoices Lines

Raz NBLUS, COMPTEUR
# Problem - Invoice without line
Filter [SIH] Where ORIMOD=3
For [SIL]SIL0(1)
 NBLUS+=1
 Look [SIH]SIH0 = [F:SIL]NUM
 If fstat
  Call ECR_TRACE("File SINVOICED(NUM)"-[F:SIL]NUM,0) From GESECRAN
  COMPTEUR+=1
 Endif
Next
Call ECR_TIME("UUMGCTLTRS00 : "+num$(NBLUS)+" records read,"-num$(COMPTEUR)+" records found.") From DOSSUB
Return

