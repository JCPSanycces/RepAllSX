#<AdxTL>@(#)9.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# ACTX deferred validation
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("ACTX deferred validation") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Local Integer OK,STAT

 Call INVALID_STC("",DOSSIER,func SUBACLA.PREFIX_CLA+CST_NAME_CLASS_CONTEXT,STAT) From ORDSYS
 OK = pullObject("",DOSSIER,func SUBACLA.PREFIX_CLA+CST_NAME_CLASS_CONTEXT )

End
