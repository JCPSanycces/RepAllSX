#-----------------------------------------------------------------------#
# Moulinettes version GPAO en cours ...                                 #
#-----------------------------------------------------------------------#
$MFGMOULE
Gosub TRSLLC3
End 
 
############## 
$TRSSYL
Goto ROUTING
$ROUOPESTD
#Moulinette sur ROUOPESTD
Local File WORKSTATIO [MWS]
Local File ROUOPESTD  [ROT]
Call DEBTRANS From GLOCK
Trbegin [ROT]
For [F:ROT]
    Filter [F:MWS] Where WST = [F:ROT]WST
    Read [F:MWS]WST0 First
    If !fstat [F:ROT]FCY = [F:MWS]WCRFCY
        Rewrite [F:ROT]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINOPESTD
Close File [MWS]
Close File [ROT]
#
$ROUOPE
#Moulinette sur ROUOPE
Local File WORKSTATIO [MWS]
Local File ROUOPE     [ROO]
Call DEBTRANS From GLOCK
Trbegin [ROO]
For [F:ROO]
    Filter [F:MWS] Where WST = [F:ROO]WST
    Read [F:MWS]WST0 First
    If !fstat [F:ROO]FCY = [F:MWS]WCRFCY
        Rewrite [F:ROO]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINOPE
Close File [MWS]
Close File [ROO]
#
$ROUTING
#Moulinette sur ROUTING
Local File ROUOPE     [ROO]
Local File ROUTING    [ROH]
Call DEBTRANS From GLOCK
Trbegin [ROH]
For [F:ROH]
    Filter [F:ROO] Where ITMREF = [F:ROH]ITMREF & ROUALT = [F:ROO]ROUALT
    Read [F:ROO]ROO0 First
    If !fstat [F:ROH]FCY = [F:ROO]FCY
        Rewrite [F:ROH]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINROUTING
Close File [ROH]
Close File [ROO]
Return


########################################################################
$TRSSYL2
#-----------------------------------------------------------------------#
# Mise à jour de l'entete OF                                            #
#-----------------------------------------------------------------------#
$MAJMFG
Local Integer XTOT
Local Integer I, GOK
Local File MFGHEAD [MFG]
Local File MFGMAT  [MFM]
#
GTEST = 1
Call DEBTRANS From GLOCK
Trbegin [MFG]
Filter [F:MFG] Where OVRALLNBR < 0 | [F:MFG]DETALLNBR < 0 | [F:MFG]SHTMATNBR < 0
For [MFG] 
    Readlock [F:MFG]MFG0 Curr
    If fstat = 1
       GOK = -1 : GLOCK = "$MFGHEAD"+[F:MFG]MFGNUM 
       Gosub ROL_TRT : GOK = 0 : Break
    Elsif fstat
       GOK = 0  : Call RSTA("MFG",   [F:MFG]MFGNUM) From GLOCK
       Gosub AB_TRT : GOK = 0 
    Endif
    Raz [F:MFG]OVRALLNBR, DETALLNBR, SHTMATNBR
#
    Filter [F:MFM] Where MFGNUM = [F:MFG]MFGNUM
    For [F:MFM]
        Case [F:MFM]ALLSTA    # évaluation nouveaux totaux en fonction de l'évolution du statut
              When 2:  [F:MFG]OVRALLNBR += 1
                       [F:MFG]SHTMATNBR += 1 
              When 3:  [F:MFG]OVRALLNBR += 1
              When 4:  [F:MFG]DETALLNBR += 1
                       [F:MFG]SHTMATNBR += 1
              When 5:  [F:MFG]DETALLNBR += 1
        Endcase
    Next
#
    Gosub MAJSTATUT
#
    Rewrite [MFG]
    If fstat
       GOK = 0 : Call FSTA("MFG") From GLOCK
       Gosub AB_TRT : GOK = 0 : Break
    Endif
Next
If GOK = 0 : Rollback : Else : Commit : Endif
#
Return

#-----------------------------------------------------------------------#
# Recalcul statut allocation                                            #
#-----------------------------------------------------------------------#
$MAJSTATUT
Local Integer XTOT
# nouveau statut allocation (non alloué, partiel, complet)
XTOT = [F:MFG]OVRALLNBR + [F:MFG]DETALLNBR
If (XTOT = 0)                     
    [F:MFG]ALLSTA = 1 
Else 
    If (XTOT < [F:MFG]MATLINNBR)      
        [F:MFG]ALLSTA = 2 
    Else 
        If (XTOT = [F:MFG]MATLINNBR)         
            [F:MFG]ALLSTA = 3 
        Endif 
    Endif 
Endif

# si des ruptures existent, statut allocation + 2
If [F:MFG]SHTMATNBR <> 0 : [F:MFG]ALLSTA += 2 : Endif
# si toutes les matières sont soldées, on force le statut à "complet" ...
If [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
    [F:MFG]ALLSTA = 3
Endif
Return

########################################################
$ROL_TRT
Rollback
Call ROLL From GLOCK
Return

$AB_TRT
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

##########################################################
############## 
$TRSSYL3
#
Local Integer I : I = 1
While I < 1000
    Call TRTTST
    I+=1
Wend
Infbox num$(I)
Return

Subprog TRTTST
Local Char TIT (50)
If clalev([F:ATM])=0 : Local File ATEXMOD [ATM] : Endif
End

############## 
$TRSLLC1
$BOMD
#Moulinette sur BOMD (pour type composant)
Local File BOM   [BOH]
Local File BOMD  [BOD]
Call DEBTRANS From GLOCK
Trbegin [BOH]
Link [BOD] With [BOH]BOH0=[F:BOD]ITMREF;[F:BOD]BOMALT As [NOM] 
&            Where [F:BOH]BOMALTTYP = 2  
&            Order By Key BOD0  

For [NOM]
    Readlock [BOD] Curr    
    If !fstat 
        [F:BOD]CPNTYP = 1
        Rewrite [F:BOD]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINBOMD
Close File [BOH]
Close File [BOD]

############## 
$TRSLLC2
$BTRS
Local Integer CPT
#Moulinette sur BENCHTRS (pour paramétrage affichage)
Local File BENCHTRS   [BTS]
Call DEBTRANS From GLOCK
Trbegin [BTS]
For [BTS] Where BTSTYP = 51 & BTSNUM = "FMX"
    Readlock [BTS] Curr    
    If !fstat 
    # 1er bloc, les zones clés
       [F:BTS]WIPTYPSTA = 5
       [F:BTS]VCRNUM = 10
       [F:BTS]STOFCY = 15
       [F:BTS]ITMREF = 20
       [F:BTS]STRDAT = 25
       [F:BTS]ENDDAT = 30
       CPT = 35       
       If [F:BTS]MRPMES = 2         : [F:BTS]MRPMES = CPT     : CPT += 5 : Endif
       If [F:BTS]MRPDAT = 2         : [F:BTS]MRPDAT = CPT     : CPT += 5 : Endif            
       If [F:BTS]MRPQTY = 2         : [F:BTS]MRPQTY = CPT     : CPT += 5 : Endif
       If [F:BTS]EXTQTY = 2         : [F:BTS]EXTQTY = CPT     : CPT += 5 : Endif
       If [F:BTS]ALLQTY = 2         : [F:BTS]ALLQTY = CPT     : CPT += 5 : Endif
       If [F:BTS]SHTQTY = 2         : [F:BTS]SHTQTY = CPT     : CPT += 5 : Endif
       If [F:BTS]WORTIAQTY = 2      : [F:BTS]WORTIAQTY = CPT  : CPT += 5 : Endif
       If [F:BTS]CPLQTY = 2         : [F:BTS]CPLQTY = CPT     : CPT += 5 : Endif
       If [F:BTS]ITMDES1 = 2        : [F:BTS]ITMDES1 = CPT    : CPT += 5 : Endif
       If [F:BTS]ORIFCY = 2         : [F:BTS]ORIFCY = CPT     : CPT += 5 : Endif
       If [F:BTS]PJT = 2            : [F:BTS]PJT = CPT        : CPT += 5 : Endif
       If [F:BTS]BPRNUM = 2         : [F:BTS]BPRNUM = CPT     : CPT += 5 : Endif
       If [F:BTS]PIO = 2            : [F:BTS]PIO = CPT        : CPT += 5 : Endif
       If [F:BTS]FMI = 2            : [F:BTS]FMI = CPT        : CPT += 5 : Endif
       If [F:BTS]VCRTYPORI = 2      : [F:BTS]VCRTYPORI = CPT  : CPT += 5 : Endif
       If [F:BTS]VCRNUMORI = 2      : [F:BTS]VCRNUMORI = CPT  : CPT += 5 : Endif
       If [F:BTS]VCRLINORI = 2      : [F:BTS]VCRLINORI = CPT  : CPT += 5 : Endif
       If [F:BTS]VCRSEQORI = 2      : [F:BTS]VCRSEQORI = CPT  : CPT += 5 : Endif
       If [F:BTS]ITMREFORI = 2      : [F:BTS]ITMREFORI = CPT  : CPT += 5 : Endif
       If [F:BTS]BOMALT = 2         : [F:BTS]BOMALT = CPT     : CPT += 5 : Endif
       If [F:BTS]BOMOPE = 2         : [F:BTS]BOMOPE = CPT     : CPT += 5 : Endif
       If [F:BTS]BUY  = 2           : [F:BTS]BUY = CPT        : CPT += 5 : Endif

        Rewrite [F:BTS]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINBTRS
Close File [BTS]


############## 
$TRSLLC3
# moulinette initialisation nb poste = 1
$WORKSTATIO
Local File WORKSTATIO [MWS]
Call DEBTRANS From GLOCK
Trbegin [MWS]
For [MWS]
    Readlock [MWS]WST0 Curr
    If !fstat 
        [F:MWS]WSTNBR = 1
        Rewrite [MWS]
    Endif
Next    
If GOK < 1 : Rollback: Else : Commit : Endif
$FINWORKSTATION
Close File [MWS]
