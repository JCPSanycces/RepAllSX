$EMPLORIB_MODSTL_CONTROL
If this.MODSTL = AVOID.ACHAR
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00010,00123,1),[V]CST_AERROR)
Else
  If this.NUMLIG = 0 : Return : Endif
  Local File EMPLORIB [RIB1]
  Filter [RIB1] Where REFNUM=this.REFNUM & TYPPAY=this.TYPPAY & MODSTL=this.MODSTL & NUMLIG <> this.NUMLIG
  Read [RIB1]RIB0 First
  If fstat =[V]CST_AOK
   ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(24,701,1),[V]CST_AERROR)
  Endif

  LogicClose File [RIB1]
Endif
Return

$EMPLORIB_MODSTL_PROPAGATE
Local File ATABDIV [ADI1]
Read [ADI1]CODE=387;this.MODSTL
If fstat = [V]CST_AOK
 If [F:ADI1]N1=2 :#espèce
  this.TCH_BANCAI="CAI"
 Else
  this.TCH_BANCAI="BAN"
 Endif
Endif

LogicClose File [ADI1]
Return


$EMPLORIB_CPYBAN_INIT

If this.TCH_BANCAI="BAN"
  Local File EMPLOID [ID]
  Local File FACILITY [FCY]
  Filter [ID] Where REFNUM=this.REFNUM
  Read [ID]ID0 First
  If fstat = [V]CST_AOK
    Read [FCY]FCY0 = [F:ID]FCY
    If fstat = [V]CST_AOK
      this.CRYBAN = [F:FCY]PAYBAN
    Endif
  Endif
  LogicClose File [ID]
  LogicClose File [FCY]
Endif
Return

$EMPLORIB_CPYBAN_CONTROL

Return

$EMPLORIB_CPYBAN_PROPAGATE

Local File ATABDIV [ADI1]
Read [ADI1]CODE=387;this.MODSTL

If fstat = [V]CST_AOK
 If [F:ADI1]N1=2 :#espèce
  this.BANCAI="CAI"
 Else
   this.BANCAI="BAN"
 Endif
Endif

LogicClose File [ADI1]
Return



$EMPLORIB_BNF_INIT

If this.BNF=""
 Local File EMPLOID [ID]
 Filter [ID] Where REFNUM=this.REFNUM
 Read [ID]ID0 First
 this.BNF = [F:ID]NAM-[F:ID]SRN
 LogicClose File [ID]
Endif

Return

$EMPLORIB_BIDNUM_CONTROL

If this.BIDNUM<>AVOID.ACHAR
  Local File EMPLORIB [BID1]
  Filter [BID1] Where [BID1]BIDNUM=this.BIDNUM and [BID1]REFNUM<>this.REFNUM
  If rowcount([BID1])>0
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(48 ,11662,1),[V]CST_AERROR)
  Endif
  LogicClose File [BID1]
Endif

#Local File EMPLORIB [RIB1]
#
#Filter [RIB1] Where BIDNUM =this.BIDNUM and REFNUM <> this.REFNUM
#Read [RIB1]RIB0 First
#If fstat = [V]CST_AOK
#  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(48 ,11662,1),[V]CST_AERROR)
#Endif
#
#LogicClose File [RIB1]
Return

$EMPLORIB_BIDNUM_PROPAGATE
#This check is already performed for all legislations. The control can also not exist in PROPAGATE
#If func AFNC.ACTIV("KGZA")>0 Then
#  Gosub AM_BIDNUM From EMPLORIB_CSTD_PRO_KSA
#Endif
Return


$EMPLORIB_CUR_INIT

Local File EMPLOID [ID1]
Local File COMPANY [CPY]
Local File FACILITY [FCY]

Filter [ID1] Where REFNUM=this.REFNUM
Read [ID1]ID0 First
If fstat = [V]CST_AOK
  Filter [FCY] Where FCY=[F:ID1]FCY
  Read [FCY]FCY0 First
  If fstat = [V]CST_AOK
    Filter [CPY] Where CPY=[F:FCY]LEGCPY
    Read [CPY]CPY0 First
    If fstat = [V]CST_AOK
      this.CUR = [F:CPY]ACCCUR
    Endif
  Endif
Endif

LogicClose File [ID1]
LogicClose File [CPY]
LogicClose File [FCY]

Return

$EMPLORIB_CUR_CONTROL
#Mandatory check as field can be cleared on the basic class
If this.CUR = AVOID.ACHAR
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00010,00123,1),[V]CST_AERROR)
Endif
Return

$EMPLORIB_ACCNONREI_CONTROL
  #Mandatory check as field can be cleared on the basic class
  If this.ACCNONREI = AVOID.AINT
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00010,00123,1),[V]CST_AERROR)
  Endif
Return

$EMPLORIB_BANACCTYP_CONTROL
  #Mandatory check as field can be cleared on the basic class
  If this.BANACCTYP = AVOID.AINT
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00010,00123,1),[V]CST_AERROR)
  Endif
Return

$EMPLORIB_BNKACCNUM_CONTROL
  #Mandatory check as field can be cleared on the basic class
  If this.BNKACCNUM = AVOID.AINT
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00010,00123,1),[V]CST_AERROR)
  Endif
Return

$EMPLORIB_BNKACCREL_CONTROL
  #Mandatory check as field can be cleared on the basic class
  If this.BNKACCREL = AVOID.AINT
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00010,00123,1),[V]CST_AERROR)
  Endif
Return

$EMPLORIB_BANBRCNUM_CONTROL
  #Mandatory check as field can be cleared on the basic class
  If this.BANBRCNUM = AVOID.AINT
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00010,00123,1),[V]CST_AERROR)
  Endif
Return

$EMPLORIB_BNKACCNAM_INIT
 If func AFNC.ACTIV("KGZA")>0 Then
    If this.BNKACCNAM = ""
      this.BNKACCNAM = func EMPLORIB_CSTD_PRO_KSA.AV_BNKACCNAM(this.REFNUM)
    Endif
 Endif
Return

$EMPLORIB_PAYPCT_CONTROL
If this.PAYPCT > 100
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(23,701,1),[V]CST_AERROR)
Endif
#Mandatory check as field can be cleared on the basic class
If this.PAYPCT = AVOID.AINT
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00010,00123,1),[V]CST_AERROR)
Endif
Return

$EMPLORIB_PAYPCT_INIT
Local Integer PCT
Local File EMPLORIB [RIB1]
Filter [RIB1] Where TYPPAY = this.TYPPAY and REFNUM = this.REFNUM and NUMLIG <> this.NUMLIG
For [RIB1]RIB0
[L]PCT+=[F:RIB1]PAYPCT
Next
LogicClose File [RIB1]

this.PAYPCT = [L]PCT

If this.PAYPCT = AVOID.AINT
  this.PAYPCT = 100
Endif

Return






