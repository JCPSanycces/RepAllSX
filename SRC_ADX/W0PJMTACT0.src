#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTACT0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone ROODESAXX
mkstat = 0
zoncou = "ROODESAXX"
indice = 0
WCHAR = [M]ROODESAXX
If varinit([M]ROODESAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]ROODESAXX,"PJMTSKOPE","ROODESAXX",func SUBPJTAC.GET_KEYCONCAT_SCREEN_PJTAC0(),"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]ROODESAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ROODESAXX" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]ROODESAXX,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "ROODESAXX" : GZNUM = 8 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]ROODESAXX or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_ROODESAXX([M]ROODESAXX) From SUBPJTAC
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "ROODESAXX" : GZNUM = 8 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone OPESTA
mkstat = 0
zoncou = "OPESTA"
indice = 0
IMPENT = [M]OPESTA
If varinit([M]OPESTA,indice)=0
 IMPENT = 1
Endif
[M]OPESTA = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone OPESTR
mkstat = 0
zoncou = "OPESTR"
indice = 0
WDATE = [M]OPESTR
If varmode([M]OPESTR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_OPESTR([M]OPESTR) From SUBPJTAC
 GACTION = SAVACT
 If mkstat=1 : Raz [M]OPESTR : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPESTR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If WDATE<>[M]OPESTR or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_OPESTR([M]OPESTR) From SUBPJTAC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "OPESTR" : GZNUM = 1805 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone OPEEND
mkstat = 0
zoncou = "OPEEND"
indice = 0
WDATE = [M]OPEEND
If varmode([M]OPEEND,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_OPEEND([M]OPEEND) From SUBPJTAC
 GACTION = SAVACT
 If mkstat=1 : Raz [M]OPEEND : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPEEND" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If WDATE<>[M]OPEEND or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_OPEEND([M]OPEEND) From SUBPJTAC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "OPEEND" : GZNUM = 1806 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMTACT0"
Return

