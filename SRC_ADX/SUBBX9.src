######################################################################################
$ACTION
Case ACTION
  When default
Endcase
Return


#######################################################################################
#
# Screen Field Actions
#
######################################################################################
Subprog D_FRM1099(VALEUR)
Variable Integer VALEUR

If nolign > 1
    VALEUR = [M:BX91]FRM1099(nolign-2)    # the one before it
Else
    VALEUR = 2    # Miscellaneous
Endif

End


