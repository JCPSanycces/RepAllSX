#<AdxTL>@(#)0.0.0.0 $Revision$ Object management HRFCN
######################################################################################
## Etiquette ajoutée par le superviseur (Objet HRFCN) 14/08/2015 09:19:17 (JML)
######################################################################################
$ACTION
Case ACTION
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "LIENS"       : Gosub LIENS
 When "ANNULE"      : Gosub ANNULE
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "OUVRE"       : Gosub OUVRE
 When "FERME"       : Gosub FERME
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "RAZCRE"      : Gosub RAZCRE
 When Default
Endcase
Return

######################################################################################
$CREATION
$MODIF
Gosub TEXTRA
Return

######################################################################################
$LIENS
#LIPET - 2017-05-18 - X3-40059 - START
 GCURLEG = [F:HRFCN]LEG
#LIPET - 2017-05-18 - X3-40059 - END

#LIPET - 2017-11-02  - X3-40059 - START
#If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If dim([F:HRFCN]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]DES,"HRFISCALNAT","DES",GCURLEG,[M]FCNCOD) From ATEXTRA
#LIPET - 2017-11-02 - X3-40059 - START
Return
######################################################################################
$FERME
#LIPET - 2017-05-18 - X3-40059 - START
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#LIPET - 2017-05-18 - X3-40059 - END
  If TUNNEL<>1 : Return : Endif
  If dim(VCOD)<1 : Global Char VCOD(GLONHRFCN) : Endif
  VCOD = CLE1
Return

$RAZCRE
  GCURLEG=""
Return
######################################################################################
$ANNULE
Call SUPTEXTRA("HRFISCALNAT","DES",SUPP,[L]CODE) From ATEXTRA
Return
######################################################################################
$OUVRE
#LIPET - 2017-05-18 - X3-40059 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
 If dim([F:HRFCN]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
#LIPET - 2017-05-18 - X3-40059 - END
Return
#ADNGO - 2017-11-16 - START
$SEL_TABLE
  Case TABLE
  When "SELHRFCN"
    If clalev ([F:HRFCN])=0 : Local File HRFISCALNAT [HRFCN] : Endif
    Filter [F:HRFCN]
    OBJET="HRFCN"
    If GCURLEG<>""
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRFCN]LEG="'+GCURLEG+'" | [F:HRFCN]LEG="")',"&") From GOBJSUB
    Endif
  Endcase
Return
#ADNGO - 2017-11-16 - END
######################################################################################
# To manage translated texts (data type AX3 & AX1) in creation and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("HRFISCALNAT","DES",CLECUR1,"","HRFISCALNAT","DES",GCURLEG,[F:HRFCN]FCNCOD)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DES,"HRFISCALNAT","DES",GCURLEG,[F:HRFCN]FCNCOD) From ATEXTRA
Return

Subprog CONTHRFCN(COD)
Variable Char    COD()
  If GFONCTION = "GESHRFCN" | COD="" : End : Endif

  If clalev([F:HRFCN])=0 : Local File HRFISCALNAT [HRFCN] : Endif

  If COD <> ""
    Filter [F:HRFCN] Where FCNCOD=[L]COD
    Read [F:HRFCN] First
    Filter [F:HRFCN]
    If fstat
        GMESSAGE = COD-":"-mess(23,100,1)
        mkstat = 2 : End
    Else
        Read [F:HRFCN]HRFCN0 = GCURLEG;[L]COD
        If fstat
          Filter [F:HRFCN] Where FCNCOD=[L]COD & LEG=GCURLEG
          Read [F:HRFCN] First
          Filter [F:HRFCN]
          If [F:HRFCN]LEG<>"" & GCURLEG <> ""
            GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:HRFCN]LEG
            mkstat = 2 : End
          Endif
        Endif
    Endif
  Endif
  Filter [F:HRFCN]

End

Subprog TUNHRFCN(COD)
Variable Char    COD()

Local Integer TOKILL
  TOKILL = 0
  If dim(VCOD)<1
   Global Char VCOD(GLONHRFCN)
   TOKILL = 1
  Endif

  If clalev([F:HRFCN])=0 : Local File HRFISCALNAT [HRFCN] : Endif

  VCOD = COD

  If VCOD="" & GCURLEG <> "" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
  Filter [HRFCN] Where LEG=GCURLEG
  Read [F:HRFCN] First
  Filter [HRFCN]
  If !fstat : VCOD=[F:HRFCN]FCNCOD : Endif
  Else
   Read [HRFCN]HRFCN0 = GCURLEG;VCOD
  Endif
  If GCURLEG <> "" Then
    Call OBJET("HRFCN",VCOD,GCURLEG) From GOBJET
  Else
    Call OBJET("HRFCN",VCOD,"") From GOBJET
  Endif
  COD = VCOD

  If TOKILL : Kill VCOD : Endif
End

######################################################################################
$AP_CHANGE
Call CHGTEXTRA("HRFISCALNAT","DES",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Return
######################################################################################

