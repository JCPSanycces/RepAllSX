#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTITRS004                                                   Module TRS #
# Allows to fill in the new field FCY of table PAYLOT [PYL]              #
# It will take the value of field FCY of table PAYMENTH [PYH]. Exactly : #
# the payment with PAYLOT = [PYL]COD which has the same CREDAT / CREUSR  #
# and which has the lower NUM                                            #                    
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Fill in new field of PAYLOT") From LECFIC

  Call MAJ_UTITRS004(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTITRS004(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTITRS004 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:PYH]) =0  Local File =DOSSIER+".PAYMENTH" [PYH] : Endif
If clalev([F:PYL]) =0  Local File =DOSSIER+".PAYLOT"   [PYL] : Endif
If dim([F:PYL]FCY)<=0 : Goto FIN : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK


Trbegin [PYL]
For [PYL] Where [F:PYL]FCY=""
 Readlock [PYL] Curr    
 If !fstat | [F:PYL]COD <> ""
   # --- Field FCY filled in and rewrited table [PYL]
  Filter [PYH] Where PAYLOT =[F:PYL]COD & CREUSR=[F:PYL]CREUSR & CREDAT=[F:PYL]CREDAT
&              Order By Key CLE = NUM Asc
   If rowcount([PYH])>0
    Read [PYH]CLE First
    [F:PYL]FCY= [F:PYH]FCY
    Filter [PYH]
    Rewrite [F:PYL]
    If !fstat COMPTEUR += 1 Endif
    Else
     Filter [PYH]
   Endif
 Endif
Next
Commit

Close Local File [PYL]

$FIN
Call ECR_TRACE("UTITRS004 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif  
If filinfo(filpath("FIL","PAYLOT","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTITRS004(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif      # 2= Module Tiers
If filinfo(filpath("FIL","PAYLOT","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTITRS004(APPLI)
End
