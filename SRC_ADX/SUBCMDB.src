#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des transactions agenda support     Module CRM   octobre 2006
#
##########################################################################################################
# LOADDATA : traitement lors du chargement des données
# ONGLETS_INIT :  Traitement de gestion des onglets en initialisation
# ONGLETS_ENREG : Traitement de gestion des onglets en enregistrement
# ONGLETS_READ : Traitement de gestion des onglets lors de la lecture
# ONGLETS :  Traitement de gestion des onglets
# COLFIX_INIT :  Traitement de gestion des colonnes fixes en initialisation
# COLFIX_ENREG : Traitement de gestion des colonnes fixes lors de l'enregistrement
# COLFIX_READ : Traitement de gestion des colonnes fixes lors de la lecture
# COLFIX : Traitement de gestion des colonnes fixes
# CHAMPS_INIT : Traitement de gestion des champs en initialisation
# CHAMPS_ENREG : Traitement de gestion des champs lors de l'enregistrement
# CHAMPS_READ : Traitement de gestion des champs lors de la lecture
# CHAMPS : Traitement de gestion des champs
# TAB_NBLIGSRE : Traitement de gestion des colonnes du tableau de l'écran HDKAGD1 demande de service
# TAB_NBLIGITN : Traitement de gestion des colonnes du tableau de l'écran HDKAGD2 intervention
# TAB_NBLIGINF Traitement de gestion des colonnes du tableau de l'écran HDKAGD3 information
# AFF_FENETRE : Affichage de la fenetre
# REORGANISE : Traitement de réorganisation (tri) de tous les tableaux de la fenetre
# REORG_NBLIGSRE : Tri du tableau de l'écran HDKAGD1 demande de service
# REORG_NBLIGITN : Tri du tableau de l'écran HDKAGD2 Intervention
# REORG_NBLIGINF : Tri du tableau de l'écran HDKAGD3 Information
# VALINITIAL_INIT : Traitement de gestion valeurs initiales  en initialisation
# VALINITIAL_ENREG : Traitement de gestion valeurs initiales lors de l'enregistrement
# VALINITIAL_READ : Traitement de gestion valeurs initiales lors de la lecture
# VALINITIAL : Traitement de gestion valeurs initiales
##########################################################################################################
##########################################################################################################
#traitement lors du chargement des données
$LOADDATA
Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZLIBELLE (50)

  Read [HTV]HTV0=[F:HTR]HTRTYP;[F:HTR]HTRNUM
  If fstat <> 0 Then
    Raz [F:HTV]
  Endif
  Gosub ONGLETS_READ From SUBCMDB
  Gosub COLFIX_READ  From SUBCMDB
  Gosub CHAMPS_READ From SUBCMDB
  Gosub VALINITIAL_READ From SUBCMDB
  If [M:CMD4]ONGLETACT <> "" Then
    Call GETLIB_ONGLET("FHDKAGD", [M:CMD4]ONGLETACT, SZLIBELLE,SZMESSAGE, IBRETOUR) From CRMTRSUTI
    If IBRETOUR = 0 Then
      SZLIBELLE = ""
    Endif
  Else
    SZLIBELLE = ""
  Endif
  [M:CMD4]LIBONGLET = SZLIBELLE
  Gosub REORGANISE From SUBCMDB
  Gosub PE_HDKTRS From SUBHDKTRS
  Affzo [M:CMD4]LIBONGLET
  Gosub AFF_FENETRE From SUBCMDB
Return

##########################################################################################################
# Traitement de gestion des onglets en initialisation
$ONGLETS_INIT
Local Char SZTYP_ACTION

  SZTYP_ACTION = "INIT"
  Gosub ONGLETS
Return

##########################################################################################################
# Traitement de gestion des onglets en enregistrement
$ONGLETS_ENREG
Local Char SZTYP_ACTION

  SZTYP_ACTION = "ENREG"
  Gosub ONGLETS
Return

##########################################################################################################
# Traitement de gestion des onglets lors de la lecture
$ONGLETS_READ
Local Char SZTYP_ACTION

  SZTYP_ACTION = "READ"
  Gosub ONGLETS
Return

##########################################################################################################
# Traitement de gestion des onglets
$ONGLETS
Local Integer INBONGLET
Local Integer ITROUVE
Local Char SZREFERENCE
Local Integer ITROUVE

  INBONGLET = 0
  ITROUVE = 0
  Raz SZREFERENCE
  #If SZTYP_ACTION = "INIT" Then
  If SZTYP_ACTION = "INIT" or SZTYP_ACTION = "ENREG" Then
    # FGR 13/10/2009 : X3SUIVI57386 faut le réinitialiser avant parce que sinon on modif les valeurs qui y sont ne sont pas ecrasées
    Raz [F:HTR]ONGINVISI
    INBONGLET = 0
  Endif
  #CMD1 représente écran HDKAGD1
  SZREFERENCE = "HDKAGD1"
  If SZTYP_ACTION = "INIT" Then
    [M:CMD1]SREVISI = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMD1]SREVISI = 1 Then
      [F:HTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]ONGINVISI)
    If ITROUVE = 0 Then
      [M:CMD1]SREVISI = 2
    Else
      [M:CMD1]SREVISI = 1
    Endif
  Endif
  #CMD2 représente écran HDKAGD2
  SZREFERENCE = "HDKAGD2"
  If SZTYP_ACTION = "INIT" Then
    [M:CMD2]ITNVISI = 2
  Elsif SZTYP_ACTION = "ENREG"
    If [M:CMD2]ITNVISI = 1 Then
      [F:HTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]ONGINVISI)
    If ITROUVE = 0 Then
      [M:CMD2]ITNVISI = 2
    Else
      [M:CMD2]ITNVISI = 1
    Endif
  Endif
  #CMD3 représente écran HDKAGD3
  SZREFERENCE = "HDKAGD3"
  If SZTYP_ACTION = "INIT" Then
    [M:CMD3]INFVISI = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMD3]INFVISI = 1 Then
      [F:HTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]ONGINVISI)
    If ITROUVE = 0 Then
      [M:CMD3]INFVISI = 2
    Else
      [M:CMD3]INFVISI = 1
    Endif
  Endif
Return

##########################################################################################################
# Traitement de gestion des colonnes fixes en initialisation
$COLFIX_INIT
Local Char SZTYP_ACTION

  SZTYP_ACTION = "INIT"
  Gosub COLFIX
Return

##########################################################################################################
