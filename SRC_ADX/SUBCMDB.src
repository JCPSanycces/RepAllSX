  Endif
  If SZTYP_ACTION = "ENREG" Then
    If [M:CMD2]ITNTYP = 2 Then
      ISAISIE = 1
    Else
      ISAISIE = 3
    Endif
    [F:HTV]FIENAM(INBFIENAM) = "[HDKAGD2]HDKITNTYP"
    [F:HTV]FIEVAL(INBFIENAM) = num$(ISAISIE)
    INBFIENAM += 1
  Endif
  If SZTYP_ACTION = "READ" Then
    ITROUVE = find("[HDKAGD2]HDKITNTYP",  [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMD2]ITNTYP = 1
    Else
      If val([F:HTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CMD2]ITNTYP = IAFFICHE
    Endif
  Endif
  #Gestion du bloc [HDKAGD2]5
