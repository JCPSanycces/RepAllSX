##########################################################################################################
# Traitement de gestion des champs
$CHAMPS
Local Integer INBFIENAM
Local Integer INBBLOCINVI
Local Char SZTEXTE (100)
Local Char SZCHAMPS (50)
Local Integer ITROUVE
Local Integer IVISIBLE
Local Integer IPOSITION
Local Integer IMODE
Local Integer ISAISIE
Local Integer IAFFICHE

  INBFIENAM = 0
  INBBLOCINVI = 0
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:HTV]FIENAM
    Raz [F:HTV]FIEVAL
    Raz [F:HTR]BLOCINVI
    Gosub REORG_NBLIGSRE
    Gosub REORG_NBLIGITN
    Gosub REORG_NBLIGINF
  Endif
  #[HDKAGD0]
  #---------------------------------------------------#
  #[HDKAGD0]HDKCOL
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CMD4]HDKCOL = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = "[HDKAGD0]HDKCOL"
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMD4]HDKCOL)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[HDKAGD0]HDKCOL", [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMD4]HDKCOL = 1
    Else
      [M:CMD4]HDKCOL = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[HDKAGD0]DATMIN
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CMD4]DATMIN = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = "[HDKAGD0]DATMIN"
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMD4]DATMIN)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[HDKAGD0]DATMIN", [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMD4]DATMIN = 1
    Else
      [M:CMD4]DATMIN = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[HDKAGD0]DATMAX
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CMD4]DATMAX = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = "[HDKAGD0]DATMAX"
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMD4]DATMAX)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[HDKAGD0]DATMAX", [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMD4]DATMAX = 1
    Else
      [M:CMD4]DATMAX = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[HDKAGD1]
  #---------------------------------------------------#
  #[HDKAGD1]HDKSAT
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CMD1]HDKSAT = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMD1]HDKSAT = 2 Then
      ISAISIE = 1
    Else
      ISAISIE = 3
    Endif
    [F:HTV]FIENAM(INBFIENAM) = "[HDKAGD1]HDKSAT"
    [F:HTV]FIEVAL(INBFIENAM) = num$(ISAISIE)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[HDKAGD1]HDKSAT", [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMD1]HDKSAT = 1
    Else
      If val([F:HTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CMD1]HDKSAT = IAFFICHE
    Endif
  Endif
  #[HDKAGD1]HDKGRALEV
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CMD1]HDKGRALEV = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMD1]HDKGRALEV = 2 Then
      ISAISIE = 1
    Else
      ISAISIE = 3
    Endif
    [F:HTV]FIENAM(INBFIENAM) = "[HDKAGD1]HDKGRALEV"
    [F:HTV]FIEVAL(INBFIENAM) = num$(ISAISIE)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[HDKAGD1]HDKGRALEV",  [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMD1]HDKGRALEV = 1
    Else
      If val([F:HTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CMD1]HDKGRALEV = IAFFICHE
    Endif
  Endif
  #Gestion du bloc [HDKAGD1]5
  #---------------------#
  If SZTYP_ACTION = "ENREG" Then
    If [M:CMD1]HDKSAT <> 2 and [M:CMD1]HDKGRALEV <> 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = "[HDKAGD1]5"
      INBBLOCINVI += 1
    Endif
  Endif
  #[HDKAGD1]HDKQUEUE
  #---------------------#
  If SZTYP_ACTION = "INIT" Then
    [M:CMD1]HDKQUEUE = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMD1]HDKQUEUE = 2 Then
      ISAISIE = 1
    Else
      ISAISIE = 3
    Endif
    [F:HTV]FIENAM(INBFIENAM) = "[HDKAGD1]HDKQUEUE"
    [F:HTV]FIEVAL(INBFIENAM) = num$(ISAISIE)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find("[HDKAGD1]HDKQUEUE",  [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMD1]HDKQUEUE = 1
    Else
      If val([F:HTV]FIEVAL(ITROUVE-1)) = 1 Then
        IAFFICHE = 2
      Else
        IAFFICHE = 1
      Endif
      [M:CMD1]HDKQUEUE = IAFFICHE
    Endif
  Endif
  #Gestion du bloc [HDKAGD1]10
  #---------------------#
  If SZTYP_ACTION = "ENREG" Then
    If [M:CMD1]HDKQUEUE <> 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = "[HDKAGD1]10"
      INBBLOCINVI += 1
    Endif
  Endif
  #[HDKAGD1]SREASS
  #---------------------#
  SZCHAMP = "[HDKAGD1]SREASS"
  ILIGNE = 0
  #Type Affectation
  Call TEXTE(30511, SZTEXTE) From OBJDIV
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]SRETTR
  #---------------------#
  SZCHAMP = "[HDKAGD1]SRETTR"
  ILIGNE = 1
  #Titre
  Call TEXTE(35, SZTEXTE) From OBJDIV
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]SREBPCNAM
  #---------------------#
  SZCHAMP = "[HDKAGD1]SREBPCNAM"
  ILIGNE = 2
  #Client
  Call TEXTE(3662, SZTEXTE) From OBJDIV
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]SRECCNNAM
  #---------------------#
  SZCHAMP = "[HDKAGD1]SRECCNNAM"
  ILIGNE = 3
  #Interlocuteur
  Call TEXTE(10981, SZTEXTE) From OBJDIV
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]SREDATOPG
  #---------------------#
  SZCHAMP = "[HDKAGD1]SREDATOPG"
  ILIGNE = 4
  #Ouverture
  #Call TEXTE(14512, SZTEXTE) From OBJDIV
  #Date d'ouverture de la demande
  SZTEXTE = mess(468,183,1)
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]CREHOU
  #---------------------#
  SZCHAMP = "[HDKAGD1]CREHOU"
  ILIGNE = 5
  #Heure
  #Call TEXTE(847, SZTEXTE) From OBJDIV
  #Heure d'ouverture de la demande
  SZTEXTE = mess(469,183,1)
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]SRESATCLA
  #---------------------#
  SZCHAMP = "[HDKAGD1]SRESATCLA"
  ILIGNE = 6
  #Etat
  Call TEXTE(1179, SZTEXTE) From OBJDIV
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]GRALEVCLA
  #---------------------#
  SZCHAMP = "[HDKAGD1]GRALEVCLA"
  ILIGNE = 7
  #Niveau de gravité
  Call TEXTE(20698, SZTEXTE) From OBJDIV
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]SRERESDAT
  #---------------------#
  SZCHAMP = "[HDKAGD1]SRERESDAT"
  ILIGNE = 8
  #Résolution souhaitée
  #Call TEXTE(14521, SZTEXTE) From OBJDIV
  #Date de résolution souhaitée
  SZTEXTE = mess(107,183,1)
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]SRERESHOU
  #---------------------#
  SZCHAMP = "[HDKAGD1]SRERESHOU"
  ILIGNE = 9
  #Heure
  #Call TEXTE(847, SZTEXTE) From OBJDIV
  #Heure de résolution souhaitée
  SZTEXTE = mess(453,183,1)
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]SREMACDES
  #---------------------#
  SZCHAMP = "[HDKAGD1]SREMACDES"
  ILIGNE = 10
  #Parc par défaut
  Call TEXTE(22320, SZTEXTE) From OBJDIV
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]SREPBLGRP
  #---------------------#
  SZCHAMP = "[HDKAGD1]SREPBLGRP"
  ILIGNE = 11
  #Compétence globale
  Call TEXTE(22642, SZTEXTE) From OBJDIV
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]OVRCOV
  #---------------------#
  SZCHAMP = "[HDKAGD1]OVRCOV"
  ILIGNE = 12
  #Couverture globale
  Call TEXTE(22074, SZTEXTE) From OBJDIV
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]SREESC
  #---------------------#
  SZCHAMP = "[HDKAGD1]SREESC"
  ILIGNE = 13
  #Nb d'escalades
  #Call TEXTE(23989, SZTEXTE) From OBJDIV
  #Nombre d'escalades subies
  SZTEXTE = mess(450,183,1)
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]SREESCNUM
  #---------------------#
  SZCHAMP = "[HDKAGD1]SREESCNUM"
  ILIGNE = 14
  #Dernière escalade
  #Call TEXTE(23982, SZTEXTE) From OBJDIV
  #Dernière escalades subie
  SZTEXTE = mess(470,183,1)
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]ESCCATCLA
  #---------------------#
  SZCHAMP = "[HDKAGD1]ESCCATCLA"
  ILIGNE = 15
  #Catégorie escalade
  Call TEXTE(23990, SZTEXTE) From OBJDIV
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]SREESCDAT
  #---------------------#
  SZCHAMP = "[HDKAGD1]SREESCDAT"
  ILIGNE = 16
  #Date
  #Call TEXTE(212, SZTEXTE) From OBJDIV
  #Date escalade
  SZTEXTE = mess(471,183,1)
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]SREESCHOU
  #---------------------#
  SZCHAMP = "[HDKAGD1]SREESCHOU"
  ILIGNE = 17
  #Heure
  #Call TEXTE(847, SZTEXTE) From OBJDIV
  #Heure escalade
  SZTEXTE = mess(472,183,1)
  IVISIBLE = 2
  IMODE = 1
  IPOSITION = ILIGNE + 1
  Gosub TAB_NBLIGSRE
  #[HDKAGD1]ESCTYPCLA
