##########################################################################################################
# Affichage de la fenetre
$AFF_FENETRE
  Affzo [M:CMD0]1-99
  Affzo [M:CMD4]1-99
  Affzo [M:CMD1]1-99
  Affzo [M:CMD2]1-99
  Affzo [M:CMD3]1-99
Return

##########################################################################################################
#Traitement de réorganisation (tri) de tous les tableaux de la fenetre
$REORGANISE
  Gosub REORG_NBLIGSRE
  Gosub REORG_NBLIGITN
  Gosub REORG_NBLIGINF
Return

##########################################################################################################
# Tri du tableau de l'écran HDKAGD1 demande de service
$REORG_NBLIGSRE
  If dim(APPLI) >= 0 Then
    Local Mask =APPLI+".CMD1" [CMW1]
  Else
    Local Mask CMD1 [CMW1]
  Endif
  # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
  #[M:CMW1] = [M:CMD1]
  Raz [M:CMW1] : Transmask [M:CMD1] To [M:CMW1]
  # Issue X3-35454 - 2017-05-03 by FGR : END
  Sorta [M:CMW1]NBSRE [M:CMW1]NBSRE Order By [M:CMW1]SREFIEPOS(indice), [M:CMW1]SREFIECOD(indice)
  # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
  #[M:CMD1] = [M:CMW1]
  Raz [M:CMD1] : Transmask [M:CMW1] To [M:CMD1]
  # Issue X3-35454 - 2017-05-03 by FGR : END
Return

