##########################################################################################################
# Traitement de gestion des colonnes fixes lors de la lecture
$COLFIX_READ
Local Char SZTYP_ACTION

  SZTYP_ACTION = "READ"
  Gosub COLFIX
Return

##########################################################################################################
# Traitement de gestion des colonnes fixes
$COLFIX
Local Integer ITROUVE
Local Integer INBTABLEAU
Local Char SZREFERENCE

  Raz SZREFERENCE
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:HTR]COLFIXNAM
    Raz [F:HTR]COLFIXVAL
    INBTABLEAU = 0
  Endif
  #CMD1/0
  #CMD1 représente écran HDKAGD1
  SZREFERENCE = "[HDKAGD1]NBLIGSRE"
  If SZTYP_ACTION = "INIT" Then
    [M:CMD1]SRECOLFIX = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    Raz [F:HTR]COLFIXNAM # FGR 15/01/2009 cf. plus haut
    Raz [F:HTR]COLFIXVAL # FGR 15/01/2009 cf. plus haut
    If [M:CMD1]SRECOLFIX <> 0 Then
      [F:HTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:HTR]COLFIXVAL(INBTABLEAU) = [M:CMD1]SRECOLFIX
      INBTABLEAU += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CMD1]SRECOLFIX = 0
    Else
      [M:CMD1]SRECOLFIX = [F:HTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  #CMD2
  #CMD2 représente écran HDKAGD2
  SZREFERENCE = "[HDKAGD2]NBLIGITN"
  If SZTYP_ACTION = "INIT" Then
    [M:CMD2]ITNCOLFIX = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMD2]ITNCOLFIX <> 0 Then
      [F:HTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:HTR]COLFIXVAL(INBTABLEAU) = [M:CMD2]ITNCOLFIX
      INBTABLEAU += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CMD2]ITNCOLFIX = 0
    Else
      [M:CMD2]ITNCOLFIX = [F:HTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  #CMD3 représente écran HDKAGD3
  SZREFERENCE = "[HDKAGD3]NBLIGINF"
  If SZTYP_ACTION = "INIT" Then
    [M:CMD3]INFCOLFIX = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMD3]INFCOLFIX <> 0 Then
      [F:HTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:HTR]COLFIXVAL(INBTABLEAU) = [M:CMD3]INFCOLFIX
      INBTABLEAU += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CMD3]INFCOLFIX = 0
    Else
      [M:CMD3]INFCOLFIX = [F:HTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
Return

