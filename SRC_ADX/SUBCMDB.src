##########################################################################################################
# Traitement de gestion des colonnes du tableau de l'écran HDKAGD1 demande de service
$TAB_NBLIGSRE
Local Integer ILIGNETROUVE

  If SZTYP_ACTION = "INIT" Then
    [M:CMD1]SREFIECOD(ILIGNE) = SZCHAMP
    #Type Affectation
    [M:CMD1]SREFIENAM(ILIGNE) = SZTEXTE
    [M:CMD1]SREFIEAFF(ILIGNE) = IVISIBLE
    [M:CMD1]SREFIEPOS(ILIGNE) = IPOSITION
    [M:CMD1]SREFIEMOD(ILIGNE) = IMODE
  Elsif SZTYP_ACTION = "ENREG" Then
    ILIGNETROUVE = find(SZCHAMP, [M:CMD1]SREFIECOD)
    If ILIGNETROUVE <> 0 Then
      IVISIBLE = [M:CMD1]SREFIEAFF(ILIGNETROUVE-1)
      If IVISIBLE = 2 Then
        ISAISIE = 1
      Else
        ISAISIE = 3
      Endif
      IPOSITION = [M:CMD1]SREFIEPOS(ILIGNETROUVE-1)+1
      IMODE = [M:CMD1]SREFIEMOD(ILIGNETROUVE-1)
      [F:HTV]FIENAM(INBFIENAM) = SZCHAMP
      [F:HTV]FIEVAL(INBFIENAM) = num$(ISAISIE) + "/" + num$(IMODE) + "/" + num$(IPOSITION)
      INBFIENAM += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZCHAMP, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      ISAISIE = 1
      # FGR 22/10/2010 : X3SUIVI68490 : 1000 c'est trop grand
      #IPOSITION = 1000 + IPOSITION
      IPOSITION = 50 + IPOSITION
      IMODE = 1
    Else
      ISAISIE = val(left$([F:HTV]FIEVAL(ITROUVE-1),1))
      IPOSITION = val(right$([F:HTV]FIEVAL(ITROUVE-1),5))-1
      If IPOSITION >= 1000 Then
        IPOSITION = IPOSITION - 1000 + 50  # FGR 22/10/2010 : X3SUIVI68490 : 1000 c'est trop grand
      Endif
      IMODE = val(mid$([F:HTV]FIEVAL(ITROUVE-1),3,1))
    Endif
    [M:CMD1]SREFIECOD(ILIGNE) = SZCHAMP
    [M:CMD1]SREFIENAM(ILIGNE) = SZTEXTE
    If ISAISIE = 1 Then
      [M:CMD1]SREFIEAFF(ILIGNE) = 2
    Else
      [M:CMD1]SREFIEAFF(ILIGNE) = 1
    Endif
    [M:CMD1]SREFIEPOS(ILIGNE) = IPOSITION
    [M:CMD1]SREFIEMOD(ILIGNE) = IMODE
  Endif
  [M:CMD1]NBSRE = ILIGNE
Return

