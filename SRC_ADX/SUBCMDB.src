##########################################################################################################
# Traitement de gestion valeurs initiales
$VALINITIAL
Local Integer IINDICE
Local Integer IINDICETROUVE

  #Enregistrement des valeurs par defaut
  IINDICE = 0
  IINDICETROUVE = 0
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:HTV]ININAM
    Raz [F:HTV]INIVAL
  Endif
  #ITNSCO
  SZNAME = "N\[M:HDK2]ITNSCO"
  If SZTYP_ACTION = "INIT" Then
    [M:CMD2]VALITNSCO = 1
  Elsif SZTYP_ACTION = "READ" Then
    IINDICETROUVE = find(SZNAME,[F:HTV]ININAM)
    If IINDICETROUVE > 0 Then
      If [F:HTV]INIVAL(IINDICETROUVE-1) = "2" Then
        [M:CMD2]VALITNSCO = 2
      Endif
    Endif
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMD2]VALITNSCO = 2 Then
      [F:HTV]ININAM(IINDICE) = SZNAME
      [F:HTV]INIVAL(IINDICE) = "2"
      IINDICE += 1
    Endif
  Endif
Return

