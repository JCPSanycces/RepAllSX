  Local File ATEXTE [WATX]
  For [F:WATX] Where NUMERO=[F:WASW]INTREP & LAN=this.ACTX.LAN
   [L]ASTATUS = fmet this.ASETATTRIBUTE("REPCOD","$description",[WATX]TEXTE)
  Next WATX
  LogicClose File [WATX]
 Endif
 LogicClose File [WASW]
Endif
Return


