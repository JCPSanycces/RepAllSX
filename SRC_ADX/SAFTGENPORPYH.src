#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
#######################################################################################
$PAYMENT

Gosub GET_PAYSTRDAT #Get starting date for exporting all payments

Gosub PAYMENTS

If [L]PAYNUMENT > 0
  Wrseq '</Payments>' Using [SAFT]
  If [L]SAFTTYPE = 4
    Wrseq "</SourceDocuments>" Using [SAFT]
  Endif
Endif
If [L]SAFTTYPE <> 4
  Wrseq "</SourceDocuments>" Using [SAFT]
Endif

Return
#######################################################################################
#######################################################################################
$PAYMENTS

Raz [L]PAYNUMENT

#TotalControl
Filter [F:PYH]  Where [F:PYH]SNS=2 & [F:PYH]CPY=[L]SOC & find([F:PYH]STA,3,4,8,9,10,11) &
& ([F:PYH]ACCDAT>=[L]STRDATE & [F:PYH]ACCDAT<=[L]ENDDATE) &
& ([F:PYH]ACCDAT>[L]PAYSTRDAT | [F:PYH]CSHVATRGM=2) & [F:PYH]BPRTYP<>2
& Order By [F:PYH]NUM Asc

[L]STAT = 0

For [F:PYH]

  Raz [L]PAYTOTLIN
  Gosub CHECK_PAYMENT

  If [L]STAT <> 0
    Raz [L]PAYNUMENT
    Break
  Endif

    Filter [F:PYHV] Where [F:PYHV]PAYNUM=[F:PYH]NUM #& [F:PYHV]INVNUM=[F:PYD]VCRNUM
    For [F:PYHV]
      [L]PAYTOTLIN + = 1
      If [L]PAYTOTLIN = 1
        [L]PAYNUMENT + = 1
      Endif

      If [F:PYHV]SNS < 0
        For I=0 To dim([F:PYHV]BASTAX)-1
          [L]PAYTOTDEB +=  [F:PYHV]BASTAX(I)
        Next
      Else
        For I=0 To dim([F:PYHV]BASTAX)-1
          [L]PAYTOTCRE +=  [F:PYHV]BASTAX(I)
        Next
      Endif
    Next
    Filter [F:PYHV]

Next
Filter [F:PYH]

If [L]STAT <> 0 : Return : Endif

If [L]PAYNUMENT > 0
  If [L]SAFTTYPE = 4
    Wrseq '<SourceDocuments xmlns="urn:OECD:StandardAuditFile-Tax:PT_'+[L]SAFTVER+'">' Using [SAFT]
  Endif
  Wrseq '<Payments>' Using [SAFT]
  Gosub WRITE_TOTALCONT
Endif

Filter [F:PYH]  Where [F:PYH]SNS=2 & [F:PYH]CPY=[L]SOC & find([F:PYH]STA,3,4,8,9,10,11) &
& ([F:PYH]ACCDAT>=[L]STRDATE & [F:PYH]ACCDAT<=[L]ENDDATE) &
& ([F:PYH]ACCDAT>[L]PAYSTRDAT | [F:PYH]CSHVATRGM=2) & [F:PYH]BPRTYP<>2
& Order By [F:PYH]NUM;[F:PYH]CASHVATNUM Asc
For [F:PYH]
  Gosub RAZ_PYH From SAFTGENPOR

  #TransactionID
  Call TRANIDPYH(3,[F:PYH]NUM,[L]PAYTRAID) From SAFTGENPORAUX

  #TransactionDate
  [L]PAYTRDATE =  format$("D:YYYY[-]MM[-]DD", [F:PYH]ACCDAT)

  #PaymentMethod
  Call LEC_TAM_LEG([L]LEG,[F:PYH]PAM,[L]STAT) From TRTLECLEG
  PAYMECH = toupper([F:TAM]SFTPAYMET)
  PAYAMT  = [F:PYH]BANPAYTPY #sum([F:PYHV]AMTTAX(0..dim([F:PYHV]AMTTAX)-1)) + sum([F:PYHV]BASTAX(0..dim([F:PYHV]BASTAX)-1))
  PAYDATE = format$("D:YYYY[-]MM[-]DD", [F:PYH]ACCDAT)

  #PaymentStatus, PaymentStatusDate, SourceID
  If [F:PYH]CSHVATRGM=2
    #PaymentType
    [L]PAYTYPE = 'RC'
    Filter [F:PYHV] Where [F:PYHV]PAYNUM =[F:PYH]NUM
    Read [F:PYHV] Last
    If !fstat
      If [F:PYHV]PAYMENTSTA=2
        [L]PAYSTA = 2
        If [F:PYH]UPDDAT<>[0/0/0]
          # issue X3-90535 - 2018-05-29 by MANOW
          # Issue X3-101174 by MRDAB
          [L]PAYSTADAT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss", func PORLEGLIB.TRANSFORM_TO_LOCAL_TIME([F:PYH]UPDDATTIM))
#          [L]PAYSTADAT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss",[F:PYH]UPDDATTIM)
          # Issue end X3-101174
          # issue end
        Else
          # issue X3-90535 - 2018-05-29 by MANOW
          # Issue X3-101174 by MRDAB
          [L]PAYSTADAT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss", func PORLEGLIB.TRANSFORM_TO_LOCAL_TIME([F:PYH]CREDATTIM))
#          [L]PAYSTADAT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss",[F:PYH]CREDATTIM)
          # Issue end X3-101174
          # issue end
        Endif
        [L]PAYSRCID = [F:PYHV]CREUSR
      Else
        [L]PAYSTA = 1
         # issue X3-90535 - 2018-05-29 by MANOW
         # Issue X3-101174 by MRDAB
        [L]PAYSTADAT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss", func PORLEGLIB.TRANSFORM_TO_LOCAL_TIME([F:PYH]CREDATTIM))
#        [L]PAYSTADAT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss",[F:PYH]CREDATTIM)
        # Issue end X3-101174
        # issue end
        [L]PAYSRCID = [F:PYHV]CREUSR
      Endif
    Endif
    Filter [F:PYHV]
  Else
    #PaymentType
    [L]PAYTYPE = 'RG'
    If [F:PYH]STA=11
      [L]PAYSTA = 2
      If [F:PYH]UPDDAT<>[0/0/0]
        # issue X3-90535 - 2018-05-29 by MANOW
        # Issue X3-101174 by MRDAB
        [L]PAYSTADAT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss", func PORLEGLIB.TRANSFORM_TO_LOCAL_TIME([F:PYH]UPDDATTIM))
#        [L]PAYSTADAT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss",[F:PYH]UPDDATTIM)
        # Issue end X3-101174
        # issue end
      Else
        # issue X3-90535 - 2018-05-29 by MANOW
        # Issue X3-101174 by MRDAB
        [L]PAYSTADAT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss", func PORLEGLIB.TRANSFORM_TO_LOCAL_TIME([F:PYH]CREDATTIM))
#        [L]PAYSTADAT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss",[F:PYH]CREDATTIM)
        # Issue end X3-101174
        # issue end
      Endif
      [L]PAYSRCID = [F:PYH]CREUSR
    Else
      [L]PAYSTA = 1
      # issue X3-90535 - 2018-05-29 by MANOW
      # Issue X3-101174 by MRDAB
      [L]PAYSTADAT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss", func PORLEGLIB.TRANSFORM_TO_LOCAL_TIME([F:PYH]CREDATTIM))
#      [L]PAYSTADAT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss",[F:PYH]CREDATTIM)
      # Issue end X3-101174
      # issue end
      [L]PAYSRCID = [F:PYH]CREUSR
    Endif
  Endif
  #-
  #SourcePayment
  [L]PAYSRCPAY = 'P'
  #SourceID
  [L]PAYSRCID2 = [F:PYH]CREUSR
  #SystemEntryDate
  # issue X3-90535 - 2018-05-29 by MANOW
  # Issue X3-101174 by MRDAB
  [L]PAYSYSENT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss", func PORLEGLIB.TRANSFORM_TO_LOCAL_TIME([F:PYH]CREDATTIM))
#  [L]PAYSYSENT = format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss",[F:PYH]CREDATTIM)
  # Issue end X3-101174
  # issue end
  #CustomerID
  [L]PAYCUSTID = [F:PYH]BPR
  Gosub PAYMENT_LINES

  If [L]PAYLIN <> 0
    Gosub GET_CURINFO
    Gosub GET_WITHHOLDINGTAX
    Gosub WRITE_TOTAL
    Wrseq "</Payment>" Using [SAFT]
  Endif

Next
Filter [F:PYH]

Return
#######################################################################################
#######################################################################################
$PAYMENT_LINES

#Line
Local Integer PAYEXISTLIN : [L]PAYEXISTLIN = 0
Filter [F:PYHV] Where [F:PYHV]PAYNUM=[F:PYH]NUM
For [F:PYHV]

  [L]PAYEXISTLIN += 1
  Gosub RAZ_PID From SAFTGENPOR
  If [L]PAYEXISTLIN = 1
    #PaymentRefNo
    If [F:PYH]CSHVATRGM = 2
      [L]PAYNUM ='IVAC'-[F:PYH]CASHVATNUM
    Else
      [L]PAYNUM =[F:PYH]PAYTYP-[F:PYH]NUM
    Endif

    # Issue X3-31864 - 2017-05-03 by VAVIL: ATCUD
    [L]PAYATCUD = "0"
    # End issue X3-31864

    #Period
    [L]PAYPER  = func SAFTGENPOR.GET_PERIOD_NUMBER([F:PYH]CPY, [F:PYH]ACCDAT)

    Wrseq "<Payment>" Using [SAFT]
    Gosub WRITE_HEADER
  Endif

  #Sales invoice
  Read [F:SIH]SIH0 = [F:PYHV]INVNUM
  If !fstat
    Read [F:DKD]DKD0="SAFT-PT";[F:SIH]SIVTYP;[F:SIH]NUM
    If !fstat
      [L]PAYORIGON = [F:DKD]DKSDOCNUM
    Else
      [L]PAYORIGON = [F:PYHV]INVNUM
    Endif
    #InvoiceDate
    [L]PAYINVDAT = format$("D:YYYY[-]MM[-]DD", [F:SIH]ACCDAT)
  Else
    [L]PAYORIGON = [F:PYHV]INVNUM
    [L]PAYINVDAT = format$("D:YYYY[-]MM[-]DD", [F:SIH]ACCDAT)
  Endif

  If [F:PYH]CSHVATRGM=2
    For I=0 To dim([F:PYHV]BASTAX)-1
      If [F:PYHV]TAX(I) <> ''
        Raz [L]PAYDEBLIN, [L]PAYCRELIN
        Call GETTAX([L]SOC,[F:PYHV]TAX(I),[F:PYH]ACCDAT,[L]PAYTAXTYP,[L]PAYTAXCOU,[L]PAYTAXCOD,[L]PAYTAXPER,[L]PAYTAXAMO,[L]PAYTAXEXE,[L]PAYTAXEXAC,[L]VENEXEFLG) From SAFTGENPORVAT
        If [L]VENEXEFLG = 2 : [L]PAYTAXPER = 0.0 : Endif
        If [F:PYHV]SNS < 0
          [L]PAYDEBLIN =  [F:PYHV]BASTAX(I)
        Else
          [L]PAYCRELIN =  [F:PYHV]BASTAX(I)
        Endif
        [L]PAYTAXTOT += [F:PYHV]AMTTAX(I)
        [L]PAYNETTOT += [F:PYHV]BASTAX(I)
        [L]PAYGROTOT += ([F:PYHV]AMTTAX(I) + [F:PYHV]BASTAX(I))
        #[L]PAYLIN += 1000
        [L]PAYLIN += 1
        Gosub WRITE_LINE
      Endif
    Next
  Else
    For I=0 To dim([F:PYHV]BASTAX)-1
      If [F:PYHV]SNS < 0
        [L]PAYDEBLIN +=  [F:PYHV]BASTAX(I)
      Else
        [L]PAYCRELIN +=  [F:PYHV]BASTAX(I)
      Endif
      [L]PAYTAXTOT += [F:PYHV]AMTTAX(I)
      [L]PAYNETTOT += [F:PYHV]BASTAX(I)
      [L]PAYGROTOT += ([F:PYHV]AMTTAX(I) + [F:PYHV]BASTAX(I))
    Next
    #[L]PAYLIN += 1000
    [L]PAYLIN += 1
    Gosub WRITE_LINE
  Endif

Next
Filter [F:PYHV]

Return
#######################################################################################
#######################################################################################
$GET_WITHHOLDINGTAX

[L]ISWITHHOLDINGTAX     = 0
[L]WITHHOLDINGTAXAMOUNT = 0

For [F:PYD] Where [F:PYD]NUM=[F:PYH]NUM

  Call LEC_CDA_LEG([L]LEG,[F:PYD]DENCOD) From CPTLEC

  If !fstat

    If [F:CDA]ACCCOD<>""
      Read [F:CAC]CAC2 = [L]COA;14;[F:CDA]ACCCOD
      If !fstat
        For K = 0 To dim([F:CAC]ACC)-1
          If [F:CAC]ACC(K) <> "" & pat([F:CAC]ACC(K), ACCRET+"*") & ACCRET <> ""
            [L]ISWITHHOLDINGTAX = 1
            Break
          Endif
        Next
      Endif
    Endif

    If [L]ISWITHHOLDINGTAX
      [L]WITHHOLDINGTAXAMOUNT += [F:PYD]AMTLIN
    Elsif [F:CDA]ACCTYP <> 1
      [L]PAYSETAMO            += [F:PYD]AMTLIN
    Endif

  Endif

Next

[L]WITHHOLDINGTAXAMOUNT = abs([L]WITHHOLDINGTAXAMOUNT)
[L]PAYSETAMO            = abs([L]PAYSETAMO)

Return
#######################################################################################
#######################################################################################
$WRITE_TOTALCONT
AUXTAGNAM = 'NumberOfEntries'    : AUXTAGVAL = num$([L]PAYNUMENT)    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'TotalDebit'         : AUXTAGVAL = ctrans(vireblc(format$([L]SAFPRIFMT,arr([L]PAYTOTDEB,[L]SAFPRIRND)),4),",",".")
Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'TotalCredit'        : AUXTAGVAL = ctrans(vireblc(format$([L]SAFPRIFMT,arr([L]PAYTOTCRE,[L]SAFPRIRND)),4),",",".")
Gosub WRITETAG From SAFTGENPORTG
Return
#######################################################################################
#######################################################################################
$WRITE_HEADER
AUXTAGNAM = 'PaymentRefNo'     : AUXTAGVAL = [L]PAYNUM     : Gosub WRITETAG From SAFTGENPORTG
#Issue X3-31864 – 2017-04-11  by MANOW
AUXTAGNAM = 'ATCUD'            : AUXTAGVAL = [L]PAYATCUD          : Gosub WRITETAG From SAFTGENPORTG
#Issue X3-31864 end
AUXTAGNAM = 'Period'           : AUXTAGVAL = num$([L]PAYPER) : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'TransactionID'    : AUXTAGVAL = [L]PAYTRAID   : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'TransactionDate'  : AUXTAGVAL = [L]PAYTRDATE  : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'PaymentType'      : AUXTAGVAL = [L]PAYTYPE    : Gosub WRITETAG From SAFTGENPORTG
Wrseq '<DocumentStatus>' Using [SAFT]
If [L]PAYSTA = 2
  AUXTAGNAM = 'PaymentStatus'     : AUXTAGVAL = 'A'     : Gosub WRITETAG From SAFTGENPORTG
Else
  AUXTAGNAM = 'PaymentStatus'     : AUXTAGVAL = 'N'     : Gosub WRITETAG From SAFTGENPORTG
Endif
AUXTAGNAM = 'PaymentStatusDate' : AUXTAGVAL = [L]PAYSTADAT  : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'SourceID'          : AUXTAGVAL = [L]PAYSRCID   : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'SourcePayment'     : AUXTAGVAL = [L]PAYSRCPAY  : Gosub WRITETAG From SAFTGENPORTG
Wrseq '</DocumentStatus>' Using [SAFT]
If [L]PAYAMT <> 0
  Wrseq '<PaymentMethod>' Using [SAFT]
  AUXTAGNAM = 'PaymentMechanism' : AUXTAGVAL = [L]PAYMECH  : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = 'PaymentAmount'    : AUXTAGVAL = ctrans(vireblc(format$([L]SAFPRIFMT,arr([L]PAYAMT,[L]SAFPRIRND)),4),",",".") : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = 'PaymentDate'      : AUXTAGVAL = [L]PAYDATE  : Gosub WRITETAG From SAFTGENPORTG
  Wrseq '</PaymentMethod>' Using [SAFT]
Endif
AUXTAGNAM = 'SourceID'          : AUXTAGVAL = [L]PAYSRCID2   : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'SystemEntryDate'   : AUXTAGVAL = [L]PAYSYSENT   : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'CustomerID'        : AUXTAGVAL = [L]PAYCUSTID   : Gosub WRITETAG From SAFTGENPORTG

[L]RECSWRI += 1
Return
#######################################################################################
#######################################################################################
$WRITE_LINE
Wrseq "<Line>" Using [SAFT]
AUXTAGNAM = "LineNumber"        : AUXTAGVAL = num$([L]PAYLIN) : Gosub WRITETAG From SAFTGENPORTG
Wrseq "<SourceDocumentID>" Using [SAFT]
AUXTAGNAM = "OriginatingON"     : AUXTAGVAL = [L]PAYORIGON     : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = "InvoiceDate"       : AUXTAGVAL = [L]PAYINVDAT     : Gosub WRITETAG From SAFTGENPORTG
Wrseq "</SourceDocumentID>" Using [SAFT]
If [L]PAYCRELIN<>0
  AUXTAGNAM = "CreditAmount"    : AUXTAGVAL =ctrans(vireblc(format$([L]SAFPRIFMT,arr([L]PAYCRELIN,[L]SAFPRIRND)),4),",",".")
  Gosub WRITETAG From SAFTGENPORTG
Elsif [L]PAYDEBLIN<>0
  AUXTAGNAM = "DebitAmount"     : AUXTAGVAL =ctrans(vireblc(format$([L]SAFPRIFMT,arr([L]PAYDEBLIN,[L]SAFPRIRND)),4),",",".")
  Gosub WRITETAG From SAFTGENPORTG
Else
  AUXTAGNAM = "CreditAmount"    : AUXTAGVAL =ctrans(vireblc(format$([L]SAFPRIFMT,arr(0,[L]SAFPRIRND)),4),",",".")            : Gosub WRITETAG From SAFTGENPORTG
Endif

If [F:PYH]CSHVATRGM=2 & [L]PAYTAXTYP<>''
  Wrseq "<Tax>" Using [SAFT]
  AUXTAGNAM = "TaxType"           : AUXTAGVAL =   [L]PAYTAXTYP      : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = "TaxCountryRegion"  : AUXTAGVAL =   [L]PAYTAXCOU      : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = "TaxCode"           : AUXTAGVAL =   [L]PAYTAXCOD      : Gosub WRITETAG From SAFTGENPORTG
  If PAYTAXAMO = 0
    AUXTAGNAM = "TaxPercentage"   : AUXTAGVAL =  num$([L]PAYTAXPER) : Gosub WRITETAG From SAFTGENPORTG
  Else
    AUXTAGNAM = "TaxAmount"       : AUXTAGVAL =  num$([L]PAYTAXAMO) : Gosub WRITETAG From SAFTGENPORTG
  Endif
  Wrseq "</Tax>"  Using [SAFT]
  If [L]PAYTAXEXE<>"" : AUXTAGNAM =  "TaxExemptionReason"    : AUXTAGVAL =  [L]PAYTAXEXE : Gosub WRITETAG From SAFTGENPORTG: Endif
Endif

#Issue X3-31864 - 2017-04-26  by MANOW
If [L]ISSAFTVERCURRENT = 1
  If [L]PAYTAXEXAC <> ""
    AUXTAGNAM = 'TaxExemptionCode'    : AUXTAGVAL = [L]PAYTAXEXAC       : Gosub WRITETAG From SAFTGENPORTG
  Endif
Endif
#Issue X3-31864 end

Wrseq "</Line>" Using [SAFT]
Return
#######################################################################################
#######################################################################################
$WRITE_TOTAL

Wrseq "<DocumentTotals>" Using [SAFT]
AUXTAGNAM = "TaxPayable"   : AUXTAGVAL = ctrans(vireblc(format$("N20.2",[L]PAYTAXTOT),4),",",".")    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = "NetTotal"     : AUXTAGVAL = ctrans(vireblc(format$("N20.2",[L]PAYNETTOT-[L]PAYSETAMO),4),",",".")    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = "GrossTotal"   : AUXTAGVAL = ctrans(vireblc(format$("N20.2",[L]PAYGROTOT-[L]PAYSETAMO),4),",",".")    : Gosub WRITETAG From SAFTGENPORTG
If [L]PAYSETAMO <> 0
  Wrseq "<Settlement>" Using [SAFT]
  AUXTAGNAM = "SettlementAmount" : AUXTAGVAL = ctrans(vireblc(format$("N20.2",[L]PAYSETAMO),4),",",".")    : Gosub WRITETAG From SAFTGENPORTG
  Wrseq "</Settlement>" Using [SAFT]
Endif
If [L]PAYCURCOD <> ""
  Wrseq "<Currency>" Using [SAFT]
  AUXTAGNAM = "CurrencyCode"   : AUXTAGVAL = [L]PAYCURCOD                                                : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = "CurrencyAmount" : AUXTAGVAL = ctrans(vireblc(format$("N20.2",[L]PAYCURAMT),4),",",".")    : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = "ExchangeRate"   : AUXTAGVAL = ctrans(vireblc(format$("N20.2",[L]PAYRATCUR),4),",",".")    : Gosub WRITETAG From SAFTGENPORTG
  Wrseq "</Currency>" Using [SAFT]
Endif
Wrseq "</DocumentTotals>" Using [SAFT]
#ISSUE 92228 - MNO
If [L]WITHHOLDINGTAXAMOUNT <> 0
  Wrseq "<WithholdingTax>" Using [SAFT]
  AUXTAGNAM = "WithholdingTaxAmount"    : AUXTAGVAL = ctrans(vireblc(format$("N20.2", [L]WITHHOLDINGTAXAMOUNT),4),",",".") : Gosub WRITETAG From SAFTGENPORTG
  Wrseq "</WithholdingTax>" Using [SAFT]
Endif
Return
#######################################################################################
#######################################################################################
$CHECK_PAYMENT

[L]STAT = 0

If [F:PYH]CASHVATNUM = "" & [F:PYH]CSHVATRGM = 2
  COUNTER2 = "PTCSH"
  Call NUMERO (COUNTER2,[F:PYH]FCY ,date$,"",[L]COMPTEUR,[L]STAT) From SUBANM

  [F:PYH]CASHVATNUM = [L]COMPTEUR
  [F:PYH]VATSTA = 3
  [F:PYH]COMDAT = date$

  If STAT
    # Problem getting counter
    Gosub MESSAGE From SUBANM
    GMESSAGE = mess(60,199,1)-"("+COUNTER2+") : "+MESSA
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Return
  Else
    Rewrite [F:PYH]
  Endif
Elsif [F:PYH]CASHVATNUM <> "" & [F:PYH]CSHVATRGM = 2
  If ([F:PYH]VATSTA=2 | [F:PYH]STA=11)
    [F:PYH]VATSTA = 3
    [F:PYH]COMDAT = date$
    Rewrite [F:PYH]
  Endif
Endif

Look [F:PYHV]PYHV0(1)=[F:PYH]NUM
If fstat
  Call UPD_PYHV([F:PYH]NUM,1,[L]STAT) From SUBPAY3
  If [L]STAT = 0
    [L]STAT = 1
    Call ECR_TRACE(mess(66,7711,1),1) From GESECRAN
  Else
    [L]STAT = 0
  Endif
Endif

Return
#######################################################################################
#######################################################################################
$GET_PAYSTRDAT
Filter [F:DKK] Where [F:DKK]KEYCODE = "SAFT-PT" Order By STRDATPAY Desc; KEYVER Desc
Read [F:DKK] First
  If !fstat
    [L]PAYSTRDAT =[F:DKK]STRDATPAY
  Endif
Filter [F:DKK]
Return
#######################################################################################
#######################################################################################
$GET_CURINFO

If [F:PYH]CUR <> "EUR"
  If [F:PYH]BANPAYTPY <> 0 & [F:PYH]AMTCUR <> 0
    [L]PAYCURCOD = [F:PYH]CUR
    [L]PAYRATCUR = arr([F:PYH]BANPAYTPY/[F:PYH]AMTCUR,0.0001)
    [L]PAYCURAMT = [F:PYH]AMTCUR
  Endif
Endif

Return
#######################################################################################
#######################################################################################

