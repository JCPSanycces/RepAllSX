#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# CNSTRNSTD : Consultation des transports            MAE    19/05/15    #
# ECRAN 1   : CONSTRN1                                                  #
# ECRAN 2   : CONSTRN2                                                  #
# ECRAN CRIT: CRITTRN                                                   #
#########################################################################
Local Char PARAM(20)(1..2)
PARAM(1) = "2204"
PARAM(2) = "GAL"
Call GCONSULT("TRN","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When Default
Endcase
Return

############################################################
$AUTORIS
Return

############################################################
$SETBOUT
#Désactivation de la pagination si détail expédition ou conteneur demandé
If [M]SHIPFLG = 2 | [M]CTRFLG = 2
  Call VIREBOUT(CHAINE,".+D") From GOBJET
Endif
Return

###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
NAVIG="CONSTRN"
Local Char    WFIL(250),WFIL1(250),WFIL2(250),WFIL3(250),WFIL4(250)
Local Char    DEBNUM(GLONTRNP), FINNUM(GLONTRNP)
Local Char    SDEBNUM(GLONVCR), SFINNUM(GLONVCR)
Local Char    CDEBNUM(GLONVCR), CFINNUM(GLONVCR)
Local Char    CTRDNUMSAV(GLONVCR)
Local Date    DEBDAT, FINDAT
#Déclaration des variables pour les requetes
Local Char REQUETE(255)(3)
Local Char REQUETEPID(255)(2)
Local Char REQUETECPR(255)(3)
Local Integer BASE
Local Integer LRET

If !clalev([F:BPA]) Local File BPADDRESS  [BPA] Endif

Case GTYPDBA
    When 1 : BASE=3 : # Oracle
    When 2 : BASE=5 : # Sql
    When 3 : BASE=2 : # Cisam
    When 4 : BASE=4 : # DB2
  Endcase

Gosub DEFCRIT
Return

# --------------------------------------------------------------------------#
# Analyse paramètres, initialisations                                       #
# --------------------------------------------------------------------------#
$DEFCRIT
If GNBAUZ=1 : PARAM(1)=GUSRFCY(1) : Endif
For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [FCY] FCY0 = PARAM(I)
                                     If fstat  Raz [F:FCY], PARAM(I) : Endif
        Endif
        If (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
          [M:TRN1]FCY = PARAM(I)
          Call GETDEV([M:TRN1]FCY) From DEVSUB
          [M:TRN1]LEGCPY = GSOCIETE
        Endif
      Endif
    When 2 :    : # Parametre transport
      If PARAM(I) <> ""
        [M:TRN1]TRNNUMSTR = PARAM(I)
        [M:TRN1]TRNNUMEND = PARAM(I)
      Endif
    When 3 :    : # Parametre expédition
      If PARAM(I) <> ""
        [M:TRN1]SHIPNUMSTR = PARAM(I)
        [M:TRN1]SHIPNUMEND = PARAM(I)
      Endif
    When 4 :    : # Parametre conteneur
      If PARAM(I) <> ""
        [M:TRN1]CTRNUMSTR = PARAM(I)
        [M:TRN1]CTRNUMEND = PARAM(I)
      Endif
  Endcase
Next I

If !find([M:TRN1]TRNSTA,1,2) : [M:TRN1]TRNSTA= 1 : Endif
If !find([M:CTRN]TRI,1,2)     : [M:CTRN]TRI = 1   : Endif

#----- Copie du masque 1 (CPO1) vers l'écran critères (CCPO) -----#
Gosub CRITENT From =PROGCNS
Return

############################################################
$LECTURE

Local   Decimal  WMNTORG(0..1), WMNTDES(0..1)
Local   Integer  SPSTAT

If [M:TRN1]SHIPFLG <>2
  [M:TRN1]CTRFLG = 1
  Diszo [M:TRN1]CTRFLG
  #Le site est uniquement sur les expé
  [M:TRN1]FCY=AVOID.ACHAR
  Diszo [M:TRN1]FCY
  [M:TRN1]SHIPNUMSTR = AVOID.ACHAR
  [M:TRN1]SHIPNUMEND = AVOID.ACHAR
  Diszo [M:TRN1]SHIPNUMSTR
  Diszo [M:TRN1]SHIPNUMEND
Else
  Actzo [M:TRN1]CTRFLG
  Actzo [M:TRN1]SHIPNUMSTR
  Actzo [M:TRN1]SHIPNUMEND
  Actzo [M:TRN1]FCY
Endif
If [M:TRN1]CTRFLG <>2
  [M:TRN1]CTRNUMSTR = AVOID.ACHAR
  [M:TRN1]CTRNUMEND = AVOID.ACHAR
  Diszo [M:TRN1]CTRNUMSTR
  Diszo [M:TRN1]CTRNUMEND
 Else
  Actzo [M:TRN1]CTRNUMSTR
  Actzo [M:TRN1]CTRNUMEND
Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CTRN]TRI
        When 1 : # tri par numéro
          Filter [TRNP] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key TRNP0
        When 2 : # tri par date
          If [M:CTRN]CHXDAT = 1
            Filter [TRNP] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By DPEDAT
          Else
            Filter [TRNP] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By ARVEXPDAT
          Endif
      Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CTRN]TRI
      When 1 : # tri par numéro
        Filter [TRNP] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key TRNP0 Desc
      When 2 : # tri par date
        Filter [TRNP] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By Key TRNP1 Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:TRN2] : Endif

#-- lecture
$BOUCLE
For [TRNP]
  If [M:TRN1]SHIPFLG = 2
    Filter [SHH] Where evalue(WFIL3) & [F:SHH]TRNNUM = [F:TRNP]TRNNUM Order By Key SHH0
    For [SHH]
      If [M:TRN1]CTRFLG = 2 & [F:SHH]SHIPNUM <> ""
        CTRDNUMSAV = AVOID.ACHAR
        Filter [CTRD] Where evalue(WFIL4) & [F:CTRD]SHIPNUM = [F:SHH]SHIPNUM Order By Key CTRD0
        For [CTRD]
          If CTRDNUMSAV <> [F:CTRD]CTRNUM
            Gosub REMP_ECR
            CTRDNUMSAV = [F:CTRD]CTRNUM
          Endif
        Next
     Else
      Raz[F:CTRD]
      Gosub REMP_ECR
     Endif
    Next
  Else
    Raz [F:SHH]
    Raz [F:CTRD]
    Gosub REMP_ECR
  Endif

$SUIV
Next
Filter [TRNP]
Filter [SHH]
Filter [CTRD]

Return

$REMP_ECR
If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:TRN2] : Endif
     NBLU = 2
Endif
If CHGPAG > 0
  If NOL >= MAXLIG-1 : SUITE=2 : Return : Endif
  NOL    += 1
  If NOL=0
    DEBNUM = [F:TRNP]TRNNUM
    DEBDAT = [F:TRNP]ARVEXPDAT
    If [M:TRN1]SHIPFLG = 2
      SDEBNUM = [F:SHH]SHIPNUM
    Endif
    If [M:TRN1]CTRFLG = 2
      CDEBNUM = [F:CTRD]CTRNUM
    Endif
   Endif
   FINNUM = [F:TRNP]TRNNUM
   FINDAT = [F:TRNP]ARVEXPDAT
   If [M:TRN1]SHIPFLG = 2
     SFINNUM = [F:SHH]SHIPNUM
   Endif
   If [M:TRN1]CTRFLG = 2
     CFINNUM = [F:CTRD]CTRNUM
   Endif
Else
   If NOL <= 0 : RETOUR=2 : Return : Endif
   NOL    -= 1
   If NOL=MAXLIG-1
    FINNUM = [F:TRNP]TRNNUM
    FINDAT = [F:TRNP]ARVEXPDAT
    If [M:TRN1]SHIPFLG = 2
      SFINNUM = [F:SHH]SHIPNUM
    Endif
    If [M:TRN1]CTRFLG = 2
      CFINNUM = [F:CTRD]CTRNUM
    Endif
   Endif
   DEBNUM = [F:TRNP]TRNNUM
   DEBDAT = [F:TRNP]ARVEXPDAT
   If [M:TRN1]SHIPFLG = 2
    SDEBNUM = [F:SHH]SHIPNUM
   Endif
   If [M:TRN1]CTRFLG = 2
    CDEBNUM = [F:CTRD]CTRNUM
   Endif
 Endif
  nolign = NOL+1
  [M:TRN2] = [F:TRNP]
  If [M:TRN2]ARVDAT(NOL) <> AVOID.ADATE
    [M:TRN2]LTITPC(NOL) = [M:TRN2]ARVDAT(NOL) - [M:TRN2]DPEDAT(NOL)
  Elsif [M:TRN2]ARVEXPDAT(NOL) <> AVOID.ADATE
    [M:TRN2]LTITPC(NOL) = [M:TRN2]ARVEXPDAT(NOL) - [M:TRN2]DPEDAT(NOL)
  Else
    [M:TRN2]LTITPC(NOL)  = AVOID.ADEC
  Endif
  #--- Read the adress for the country
  If [M:TRN2]DPETPC(NOL) <> AVOID.ACHAR
    Filter [BPA] Where BPATYP=8 & BPANUM=[M:TRN2]DPETPC(NOL)
    Read [BPA] First
    If !fstat [M:TRN2]CRYDPE(NOL)=[BPA]CRY:  Endif
  Endif
  If [M:TRN2]ARVTPC(NOL) <> AVOID.ACHAR
    Filter [BPA] Where BPATYP=8 & BPANUM=[M:TRN2]ARVTPC(NOL)
    Read [BPA] First
    If !fstat [M:TRN2]CRYARV(NOL)=[BPA]CRY:  Endif
  Endif

  If [F:SHH]SHIPNUM <> AVOID.ACHAR
    [M:TRN2]SHIPNUM(NOL) = [F:SHH]SHIPNUM
    [M:TRN2]SHIPFCY(NOL) = [F:SHH]FCY
  Else
    [M:TRN2]SHIPNUM(NOL) = AVOID.ACHAR
    [M:TRN2]SHIPFCY(NOL) = AVOID.ACHAR
  Endif
  If [F:CTRD]CTRNUM <> AVOID.ACHAR
    [M:TRN2]CTRNUM(NOL) = [F:CTRD]CTRNUM
  Else
    [M:TRN2]CTRNUM(NOL) = AVOID.ACHAR
  Endif
##Calcul du nombre de conteneur dans le transport
If [M:TRN2]SHIPNUM(NOL) = AVOID.ACHAR
  REQUETE(0) = "SELECT COUNT(DISTINCT(CTRNUM_0))"
  REQUETE(1)=" From TRANSPORT TRNP, SHIPMENT SHIP, CONTAINERD CTRD"
  REQUETE(2)=" Where SHIP.TRNNUM_0 = TRNP.TRNNUM_0 and CTRD.SHIPNUM_0 = SHIP.SHIPNUM_0 and TRNP.TRNNUM_0='"+[M:TRN2]TRNNUM(NOL)+"'"
Elsif [M:TRN2]SHIPNUM(NOL)<> AVOID.ACHAR & [M:TRN2]CTRNUM(NOL) = AVOID.ACHAR
  REQUETE(0) = "SELECT COUNT(DISTINCT(CTRNUM_0))"
  REQUETE(1)=" From SHIPMENT SHIP, CONTAINERD CTRD"
  REQUETE(2)=" Where CTRD.SHIPNUM_0 = SHIP.SHIPNUM_0 and SHIP.SHIPNUM_0='"+[M:TRN2]SHIPNUM(NOL)+"'"
Else
  REQUETE(0) = "SELECT COUNT(DISTINCT(CTRNUM_0))"
  REQUETE(1)=" From CONTAINERD CTRD"
  REQUETE(2)=" Where CTRD.CTRNUM_0='"+[M:TRN2]CTRNUM(NOL)+"'"
Endif

For (Integer WNBCTRD) From num$(BASE) Sql REQUETE As [WTRN]
  [M:TRN2]NBCONTAINER(NOL) = [WTRN]WNBCTRD
Next

#lecture des désignations
Call LECTEXTRA([M:TRN2]DESAXX(NOL),"TRANSPORT","DESAXX",[M:TRN2]TRNNUM(NOL),"") From ATEXTRA
Call LECTEXTRA([M:TRN2]DESAXXDPE(NOL),"TABPLACE","DESAXX",[M:TRN2]DPETPC(NOL),"") From ATEXTRA
Call LECTEXTRA([M:TRN2]DESAXXARV(NOL),"TABPLACE","DESAXX",[M:TRN2]ARVTPC(NOL),"") From ATEXTRA


Return
############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER

WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"
WFIL3 = "1=1"
WFIL4 = "1=1"
# Site d'expédition
If [M:TRN1]FCY <> ""
   WFIL3 += "&[F:SHH]FCY=[M:TRN1]FCY"
Endif
## Autorisation site
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
   WFIL3 += "& find([F:SHH]FCY,GUSRFCY(1..GNBAUZ))"
Endif
# transport
If [M:TRN1]TRNNUMSTR <> ""
   WFIL1 += "&[F:TRNP]TRNNUM >=[M:TRN1]TRNNUMSTR"
Endif
If [M:TRN1]TRNNUMEND <> ""
   WFIL1 += "&[F:TRNP]TRNNUM <=[M:TRN1]TRNNUMEND"
Endif
# Expéditions
If [M:TRN1]SHIPNUMSTR <> ""
   WFIL3 += "&[F:SHH]SHIPNUM>=[M:TRN1]SHIPNUMSTR"
Endif
If [M:TRN1]SHIPNUMEND <> ""
   WFIL3 += "&[F:SHH]SHIPNUM<=[M:TRN1]SHIPNUMEND"
Endif
# Conteneurs
If [M:TRN1]CTRNUMSTR <> ""
   WFIL4 += "&[F:CTRD]CTRNUM>=[M:TRN1]CTRNUMSTR"
Endif
If [M:TRN1]CTRNUMEND <> ""
   WFIL4 += "&[F:CTRD]CTRNUM<=[M:TRN1]CTRNUMEND"
Endif
# Issue X3-4760
#statut du transport
#If [M:TRN1]TRNSTA <> 0
#   WFIL1 += "&[F:TRNP]TRNSTA=[M:TRN1]TRNSTA"
#Endif

WFIL2 = "1=2"
If [M:TRN1]CRETFLG = 2
  If WFIL2 = "1=2"
    WFIL2 = "find([F:TRNP]TRNSTA,1"
  Else
    WFIL2 += ",1"
  Endif
Endif
If [M:TRN1]INPFLG = 2
  If WFIL2 = "1=2"
    WFIL2 = "find([F:TRNP]TRNSTA,2"
  Else
    WFIL2 += ",2"
  Endif
Endif
If [M:TRN1]ARRFLG = 2
  If WFIL2 = "1=2"
    WFIL2 = "find([F:TRNP]TRNSTA,3"
  Else
    WFIL2 += ",3"
  Endif
Endif
If WFIL2 <> "1=2"
  WFIL2 += ")"
Endif

If [M:TRN1]TRNUID <> ""
  WFIL1 += "&[F:TRNP]TRNUID = [M:TRN1]TRNUID"
Endif

If [M:TRN1]BPTNUM <> ""
  WFIL1 += "&[F:TRNP]BPTNUM = [M:TRN1]BPTNUM"
Endif

If [M:TRN1]BPRNUM <> ""
  WFIL1 += "&[F:TRNP]BPRNUM = [M:TRN1]BPRNUM"
Endif

If [M:TRN1]DPETPC <> ""
  WFIL1 += "&[F:TRNP]DPETPC = [M:TRN1]DPETPC"
Endif

If [M:TRN1]ARVTPC <> ""
  WFIL1 += "&[F:TRNP]ARVTPC = [M:TRN1]ARVTPC"
Endif
# end Issue X3-4760

#MAE, bug 110684 + 111179
#If [M:TRN1]CHXDAT = 1
If [M:CTRN]CHXDAT <> 2
  If [M:TRN1]DATSTR <> [0/0/0]
     WFIL += "&[F:TRNP]DPEDAT>=[M:TRN1]DATSTR"
  Endif
  If [M:TRN1]DATEND <> [0/0/0]
     WFIL += "&[F:TRNP]DPEDAT<=[M:TRN1]DATEND"
  Endif
Else
  If [M:TRN1]DATSTR <> [0/0/0]
     WFIL += "&[F:TRNP]ARVEXPDAT>=[M:TRN1]DATSTR"
  Endif
  If [M:TRN1]DATEND <> [0/0/0]
     WFIL += "&[F:TRNP]ARVEXPDAT<=[M:TRN1]DATEND"
  Endif
Endif


Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CTRN]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:TRNP]TRNNUM>=DEBNUM"
           If [M:TRN1]SHIPFLG = 2
            WFIL3 += "&[F:SHH]SHIPNUM>=SDEBNUM"
           Endif
           If [M:TRN1]CTRFLG=2
            WFIL4 += "&[F:CTRD]CTRNUM>=CDEBNUM"
           Endif
       When 2 : # tri par date
           WFIL += "&([F:TRNP]ARVEXPDAT>DEBDAT | ([F:TRNP]ARVEXPDAT=DEBDAT & [F:TRNP]TRNNUM>=DEBNUM))"
           If [M:TRN1]SHIPFLG = 2
            WFIL3 += "&[F:SHH]SHIPNUM>=SDEBNUM"
           Endif
           If [M:TRN1]CTRFLG=2
            WFIL4 += "&[F:CTRD]CTRNUM>=CDEBNUM"
           Endif
     Endcase
   When 2 : # suite
     Case [M:CTRN]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:TRNP]TRNNUM>FINNUM"
           If [M:TRN1]SHIPFLG = 2
            WFIL3 += "&[F:SHH]SHIPNUM>=SFINNUM"
           Endif
           If [M:TRN1]CTRFLG=2
            WFIL4 += "&[F:CTRD]CTRNUM>=CFINNUM"
           Endif
       When 2 : # tri par date
           WFIL += "&([F:TRNP]ARVEXPDAT>FINDAT | ([F:TRNP]ARVEXPDAT=FINDAT & [F:TRNP]TRNNUM>FINNUM))"
           If [M:TRN1]SHIPFLG = 2
            WFIL3 += "&[F:SHH]SHIPNUM>=SFINNUM"
           Endif
           If [M:TRN1]CTRFLG=2
            WFIL4 += "&[F:CTRD]CTRNUM>=CFINNUM"
           Endif
     Endcase
   When -2 : # retour
     Case [M:CTRN]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:TRNP]TRNNUM<DEBNUM"
           If [M:TRN1]SHIPFLG = 2
            WFIL3 += "&[F:SHH]SHIPNUM<SDEBNUM"
           Endif
           If [M:TRN1]CTRFLG=2
            WFIL4 += "&[F:CTRD]CTRNUM<CDEBNUM"
           Endif
       When 2 : # tri par date
           WFIL += "&([F:TRNP]ARVEXPDAT<DEBDAT | ([F:TRNP]ARVEXPDAT=DEBDAT & [F:TRNP]TRNNUM<DEBNUM))"
           If [M:TRN1]SHIPFLG = 2
            WFIL3 += "&[F:SHH]SHIPNUM<SDEBNUM"
           Endif
           If [M:TRN1]CTRFLG=2
            WFIL4 += "&[F:CTRD]CTRNUM<CDEBNUM"
           Endif
     Endcase
Endcase

Return
############################################
#    Avant d'ouvrir la fenetre critère     #
############################################
$DEB_CRIT
If [M:CTRN]SHIPFLG <>2
  [M:CTRN]CTRFLG = 1
  Diszo [M:CTRN]CTRFLG
  [M:CTRN]SHIPNUMSTR = AVOID.ACHAR
  [M:CTRN]SHIPNUMEND = AVOID.ACHAR
  Diszo [M:CTRN]SHIPNUMSTR
  Diszo [M:CTRN]SHIPNUMEND
  [M:CTRN]FCY = AVOID.ACHAR
  Diszo [M:CTRN]FCY
 Else
  Actzo [M:CTRN]CTRFLG
  Actzo [M:CTRN]SHIPNUMSTR
  Actzo [M:CTRN]SHIPNUMEND
  Actzo [M:CTRN]FCY
Endif
If [M:CTRN]CTRFLG <>2
  [M:CTRN]CTRNUMSTR = AVOID.ACHAR
  [M:CTRN]CTRNUMEND = AVOID.ACHAR
  Diszo [M:CTRN]CTRNUMSTR
  Diszo [M:CTRN]CTRNUMEND
 Else
  Actzo [M:CTRN]CTRNUMSTR
  Actzo [M:CTRN]CTRNUMEND
Endif

Return
############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT

Return



#############################################################
##     Etiquettes masques CONSCPO1 & CONSCPO2 & CRITCPO    ##
#############################################################
Subprog AV_LEGCPY(VALEUR)
Variable Char     VALEUR
If GNBAUZ=1 : Diszo [M]LEGCPY : Endif
End

Subprog C_LEGCPY(VALEUR)
#-------------------------------#
# Contrôle de la société        #
#-------------------------------#
Variable Char     VALEUR
If VALEUR <> ""
    GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]FCY = ""
  GSOCIETE="" : GLOCALDEV=""
Endif
End

Subprog AM_LEGCPY(VALEUR)
#-------------------------------#
# Après modif de la société     #
#-------------------------------#
Variable Char     VALEUR
Affzo CUR                      : # Utilisé par 2 écrans
Raz [M]FCY
Affzo FCY
If VALEUR<>""  GSOCIETE=VALEUR : Endif
# Issue 93530 - 2013-10-16 by MUARN : mise à jour masque critère
If clalev([M:CTRN])  : [M:CTRN]CPY = VALEUR : Raz [M:CTRN]FCY : Endif
End

Subprog C_FCY(VALEUR)
#------------------------------------------------#
# Contrôle du site par defaut pour achat         #
# on regarde en fonction des autorisations sites #
# uniquement dans le cas site par defaut = ""    #
# complément de l'action VERIFCY en avant saisie #
#------------------------------------------------#
Variable Char    VALEUR()
If VALEUR <> ""
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]LEGCPY = GSOCIETE
Elsif [M]LEGCPY = ""
  # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
  # mkstat = 2
  GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]LEGCPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

#-------------------------------#
# Après modif du site           #
#-------------------------------#
Subprog AM_FCY(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
  Affzo LEGCPY
Endif
# Issue 93530 - 2013-10-16 by MUARN : mise à jour masque critère
If clalev([M:CTRN]) : [M:CTRN]FCY = VALEUR : Endif
End

#---------------------------------------------------#
#      Actions sur transport                        #
# ------------------------------------------------- #
Subprog AS_TRNNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]TRNNUMSTR
Endif
End
#---------------------------------------------------#
Subprog C_TRNNUMEND(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]TRNNUMSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End
#---------------------------------------------------#
#      Actions sur expédition                       #
# ------------------------------------------------- #
Subprog AS_SHIPNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]SHIPNUMSTR
Endif
End
#---------------------------------------------------#
Subprog C_SHIPNUMEND(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]SHIPNUMSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End
#---------------------------------------------------#
#      Actions sur conteneur                        #
# ------------------------------------------------- #
Subprog AS_CTRNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]CTRNUMSTR
Endif
End
#---------------------------------------------------#
Subprog C_CTRNUMEND(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]CTRNUMSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End


#########################################################################
# Pour exécution de la validation des consultations en gestion de patch #
#########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2 End : Endif
Call VALGTC(APPLI,"TRN") From SUBGTC
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSTRN1) 20/05/2015 11:07:40 (MAE)
######################################################################################
Subprog AM_SHIPFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Actzo [M]CTRFLG
  Actzo [M]SHIPNUMSTR
  Actzo [M]SHIPNUMEND
  Actzo [M]FCY

Else
  [M]CTRFLG = 1
  Diszo [M]CTRFLG
  [M]SHIPNUMSTR = AVOID.ACHAR
  [M]SHIPNUMEND = AVOID.ACHAR
  Diszo [M]SHIPNUMSTR
  Diszo [M]SHIPNUMEND
  [M]FCY = AVOID.ACHAR
  Diszo [M]FCY
Endif
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSTRN1) 22/05/2015 09:06:06 (MAE)
######################################################################################
Subprog AM_CTRFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Actzo [M]CTRNUMSTR
  Actzo [M]CTRNUMEND
Else
  [M]CTRNUMSTR = AVOID.ACHAR
  [M]CTRNUMEND = AVOID.ACHAR
  Diszo [M]CTRNUMSTR
  Diszo [M]CTRNUMEND
Endif
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSTRN2) 28/05/2015 11:03:48 (MAE)
######################################################################################
Subprog IB_NBLIG
Local Char WTEXTE(50)
Raz GBOUT1,GBOUT2, GBOUT3, GBOUT4, GBOUT5
If [M:TRN2]NBLIG<>0
    If [M:TRN2]TRNNUM(nolign-1)<> AVOID.ACHAR
    Call TEXTE(18603, WTEXTE) From OBJDIV
    GBOUT1=WTEXTE
   Endif
   If [M:TRN2]SHIPNUM(nolign-1)<> AVOID.ACHAR
    Call TEXTE(16408, WTEXTE) From OBJDIV
    GBOUT2=WTEXTE
   Endif
   If [M:TRN2]CTRNUM(nolign-1)<> AVOID.ACHAR
    Call TEXTE(52463, WTEXTE) From OBJDIV
    GBOUT3=WTEXTE
   Endif
   If [M:TRN2]BPRNUM(nolign-1)<> AVOID.ACHAR
    Call TEXTE(1500, WTEXTE) From OBJDIV
    GBOUT4=WTEXTE
   Endif
    If [M:TRN2]BPTNUM(nolign-1)<> AVOID.ACHAR
    Call TEXTE(1591, WTEXTE) From OBJDIV
    GBOUT5=WTEXTE
   Endif
Endif
End


