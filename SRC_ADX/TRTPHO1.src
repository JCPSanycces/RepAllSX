#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
# Etape 1 de la définition d'une campagne d'appels                  Module CRM          07 novembre 2000 #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer ISDIRTY

  ISDIRTY = 0
  If !clalev([F:HD5]) : Local File HD5CLOB [HD5] : Endif
  If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If ISDIRTY Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Raz [M:OMP0]
  Raz [M:OMP1]
  If GSZOPGNUM = "" Then
    Gosub SETOPGNUM
  Else
    Gosub LOADOPG
  Endif
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Raz [M:OMP0]
  Raz [M:OMP1]
  Kill ISDIRTY
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
  ISDIRTY = 1
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONOK
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZCPT(GLONANM)

  SZCPT = ""
  Gosub CHECKDATA From SUBOMPB
  If OK = 0 Then
    FIN = 0
    Return
  Endif
  # Récupération du compteur Activité commerciale
  If GSZOPGNUM = "" Then
    # ----------------------------------------------------------
    # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
    #    If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
    #    Read [TCA]TCA0=13
    #    If fstat Then
    #      GERR = 1
    #      GMESSAGE = mess(64,199,1)
    #    Endif
    #    GMANCOU = [F:TCA]MANCOU(2)
    #    SZCPT = [F:TCA]CODNUM(2)
    Call READ_COUNTER([M:OMP0]FCY, 13, 2, GSOCIETE, GCURLEG, SZCPT, GMANCOU) From CRM_UTIL
    # FGR 20/12/2012 : X3SUIVI71937 (fin)
    # ----------------------------------------------------------
    If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:OMP0]FCY, SZCPT, date$, "", [M:OMP0]OMPNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
      If IBRETOUR = 1 Then
        GSZOPGNUM = [M:OMP0]OMPNUM
      Else
        # problème lors de la récupération du compteur
        GERR = 1
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        Return
      Endif
    Else
      GSZOPGNUM = [M:OMP0]OMPNUM
    Endif
  Endif
  [M:OMP1]TYPFULOBJ = "OMP"
  [M:OMP1]NUMFULOBJ = [M:OMP0]OMPNUM
  #
  Call DEBTRANS From GLOCK
  Trbegin [OMP]
  Readlock [OMP]OMP0=[M:OMP0]OMPNUM
  If fstat Then
    #Il s'agit d'un nouvel enregistrement
    [F:OMP]OMPNUM = [M:OMP0]OMPNUM
    [F:OMP]FCY = [M:OMP0]FCY
    [F:OMP]SCPNUM = ""
    [F:OMP]CMGNUM = [M:CMG0]NUM
    [F:OMP]DES = [M:OMP1]DES
    [F:OMP]OBJ = [M:OMP1]OBJ
    [F:OMP]OMPSTR = [M:OMP1]OMPSTR
    [F:OMP]OMPEND = [M:OMP1]OMPEND
    [F:OMP]BUD = [M:OMP1]BUD
    [F:OMP]CUR = [M:OMP1]CUR
    [F:OMP]CLO = 1
    [F:OMP]CLODAT = [00/00/00]
    [F:OMP]CREDAT = date$
    [F:OMP]CREUSR = GUSER
    [F:OMP]UPDDAT = [00/00/00]
    [F:OMP]UPDUSR = ""
    [F:OMP]TYPFULOBJ = [M:OMP1]TYPFULOBJ
    [F:OMP]NUMFULOBJ = [M:OMP1]NUMFULOBJ
    [F:OMP]OBJFLG = [M:OMP1]OBJFLG
    Write [OMP]
    If fstat Then
      #L'enregistrement de la campagne d'appels a échoué.
      GMESSAGE = mess(887,182,1)
      GERR = 1
      Rollback
      Return
    Else
      Gosub SAVECLOB From SUBOMPB
      If GOK < 1 Then
        #L'enregistrement de la campagne d'appels a échoué.
        GMESSAGE = mess(887,182,1)
        GERR = 1
        Rollback
        Return
      Else
        Commit
      Endif
    Endif
  Else
    # Il s'agit d'une modification
    [F:OMP]OMPNUM = [M:OMP0]OMPNUM
    [F:OMP]FCY = [M:OMP0]FCY
    [F:OMP]CMGNUM = [M:CMG0]NUM
    [F:OMP]DES = [M:OMP1]DES
    [F:OMP]OBJ = [M:OMP1]OBJ
    [F:OMP]OMPSTR = [M:OMP1]OMPSTR
    [F:OMP]OMPEND = [M:OMP1]OMPEND
    [F:OMP]BUD = [M:OMP1]BUD
    [F:OMP]CUR = [M:OMP1]CUR
    [F:OMP]CLO = 1
    [F:OMP]CLODAT = [00/00/00]
    [F:OMP]UPDDAT = date$
    [F:OMP]UPDUSR = GUSER
    [F:OMP]TYPFULOBJ = [M:OMP1]TYPFULOBJ
    [F:OMP]NUMFULOBJ = [M:OMP1]NUMFULOBJ
    [F:OMP]OBJFLG = [M:OMP1]OBJFLG
    Rewrite [OMP]
    If fstat Then
      #L'enregistrement de la campagne d'appels a échoué.
      GMESSAGE = mess(887,182,1)
      GERR = 1
      Rollback
      Return
    Else
      Gosub SAVECLOB From SUBOMPB
      If GOK < 1 Then
        #L'enregistrement de la campagne d'appels a échoué.
        GMESSAGE = mess(887,182,1)
        GERR = 1
        Rollback
        Return
      Else
        Commit
      Endif
    Endif
  Endif
  GISTECPL(GICSTEP-1) = 1
  FIN = 1
  ISDIRTY = 0
Return

##########################################################################################################
$SETOPGNUM
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  [M:OMP0]CMGNUM = [M:CMG0]NUM
  [M:OMP0]CMGTTR = [M:CMG0]TTR
  #Définit la devise par défaut
  [M:OMP0]FCY = [M:CMG0]FCY
  [M:OMP1]CUR = GSYSCUR
  #Définit les dates par défaut
  Call CMGINIDATES([M:OMP0]CMGNUM, [M:OMP1]OMPSTR, [M:OMP1]OMPEND, IERRINF, ICHAPTER, IBRETOUR)  From SUBCMGB
  #
  Gosub DISPICON From SUBOMPB
  Affzo [M:OMP0]1-99
  Affzo [M:OMP1]1-99
Return

##########################################################################################################
$LOADOPG
  Read [OMP]OMP0=GSZOPGNUM
  If fstat Then
    Return
  Endif
  #
  Read [CMG]CMG0=[F:OMP]CMGNUM
  If fstat Then
    [M:OMP0]CMGTTR = ""
  Else
    [M:OMP0]CMGTTR = [F:CMG]TTR
  Endif
  [M:OMP0]CMGNUM = [F:OMP]CMGNUM
  [M:OMP0]OMPNUM = [F:OMP]OMPNUM
  [M:OMP0]FCY = [F:OMP]FCY
  [M:OMP1]DES = [F:OMP]DES
  [M:OMP1]OBJ = [F:OMP]OBJ
  [M:OMP1]OMPSTR = [F:OMP]OMPSTR
  [M:OMP1]OMPEND = [F:OMP]OMPEND
  [M:OMP1]BUD = [F:OMP]BUD
  [M:OMP1]CUR = [F:OMP]CUR
  [M:OMP1]TYPFULOBJ = [F:OMP]TYPFULOBJ
  [M:OMP1]NUMFULOBJ = [F:OMP]NUMFULOBJ
  [M:OMP1]OBJFLG = [F:OMP]OBJFLG
  #
  Read [HD5]HD50=[F:OMP]NUMFULOBJ;[F:OMP]TYPFULOBJ
  If fstat Then
    Raz [M:OMP1]FULOBJ
  Else
    [M:OMP1]FULOBJ = [F:HD5]CLOB
  Endif
  #
  Gosub DISPICON From SUBOMPB
  #
  Affzo [M:OMP0]1-99
  Affzo [M:OMP1]1-99
Return

##########################################################################################################
$CANCELSTEP
  Call DEBTRANS From GLOCK
  Trbegin [OMP]
  Readlock [OMP]OMP0=GSZOPGNUM
  If fstat Then
    Rollback
    Return
  Endif
  #
  Delete [HD5] Where [F:HD5]NUM = [F:OMP]NUMFULOBJ and [F:HD5]TYP = [F:OMP]TYPFULOBJ
  If fstat Then
    Rollback
    Return
  Endif
  #
  Delete [OMP]Curr
  If fstat Then
    Rollback
    Return
  Endif
  #
  Commit
Return
