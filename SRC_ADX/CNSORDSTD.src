##########################################################################
Subprog AS_VCRTYPSEL(VALEUR)
Variable Integer VALEUR
#CCC (13/09/10) tout est désactivé par défaut
For I=1 To len(mess(0,725,1))
    If !find(I,1,2,3,5,6,7,9,11,12,13,14,15,16,19,20,21,27,37, 40) #107498/9 - added 40 for project demand
        GMENLOC(I) = 1
    Endif
Next
End


