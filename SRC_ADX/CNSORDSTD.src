#<AdxTL>@(#)9.0.0.0 $Revision$ Consultation SMV
# Issue 107498/9 - 2016-03-03 by BAKHA : Include project demand transactions

Local Char PARAM(20)(1..14)
PARAM(1) = "0"
PARAM(2) = "GAL"
PARAM(3) = ""
PARAM(4) = "AB"
PARAM(5) = ""
PARAM(6) = ""
PARAM(7) = ""
PARAM(8) = ""
PARAM(9) = ""
PARAM(10) = "1"
PARAM(11) = ""
PARAM(15) = ""
Call GCONSULT("ORD","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case GACTION                                                 #  hcb deb  graph
    When "CONSORD"                                           #  hcb deb  graph
          Case ACTION
               When "AUTORIS"    : Gosub AUTORIS
               When "FERME"      : Gosub FERME
               When "OUVRE"      : Gosub OUVRE
               When "LECTURE"    : Gosub LECTURE
               When "SETBOUT"    : Gosub SETBOUT
               When "EXEBOUT"    : Gosub EXEBOUT
               When "DEB_CRIT"   : [M:CORD] = [M:ORD1]
               When "FIN_CRIT"   : Gosub FIN_CRIT
               When "AP_MAGNETO" : Gosub AP_MAGNETO
#                                                             hcb deb  graph
          Endcase

    When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:TUN]) = 0 : Local File TABUNIT    [TUN] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ORD]) = 0 : Local File ORDERS     [ORD] : Endif
#
# sr 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char    WFIL(80), WFIL1(250), WFIL2(250), WFILS(250), CUSFLT(255), WFILSPE(250)
Local Char    WFILS1(250), WFILS2(250), WFILS3(250), WFILS4(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I, J, K
#
Local Char    WMSG(120)
# Issue 107498/9 - WYPTYP array increased by 1 for project demand
Local Char    WTYP(2)(1..14)   : # GA 05/08/2005 ajout d'un type 13eme type d'encours EOx 12 => 13
Local Char    WSTA(1)(1..3)
Local Char    WEVA(60)
Local Char    WFLD(30)
Local Char    WASEL(80)
Local Char    TTS(03)(4*dim(WTYP))
Local Integer ITTS
Local Integer WANA
#
Local Integer WFIRTYP
Local Char    WFIRNUM
Local Char    WFIRITM
# Chargement codes types
For I = 1 To dim(WTYP)
  WTYP(I) = mess(I,341,1)
Next I
# Chargement codes statuts
For I = 1 To dim(WSTA)
  WSTA(I) = mess(I,342,1)
Next I
#
Gosub LOAD_SCREEN
#
SUITE  = 1
RETOUR = 1

# Mail TS du 18/03/08
NAVIG="CONSORD"
Return
############################################################
$FIN_CRIT
[M:ORD1]FLG = 0
[M:ORD1]    = [M:CORD]
Return
############################################################
$AP_MAGNETO
[M:ORD1]FLG = 0
Return
############################################################
$SETBOUT
If [M:ORD1]SELFLG = 0
  Call VIREBOUT(CHAINE,"a") From GOBJET
Endif
If [M:ORD1]ITMREFSTR <> "" & [M:ORD1]ITMREFSTR = [M:ORD1]ITMREFEND    # hcb graph
   CHMEN += "12"                                                      # hcb graph
Endif                                                                 # hcb graph

Return
############################################################
$EXEBOUT
Case BOUT
  When "a" :
    If nolign > 0
      PARAM(12)  = num$([M:ORD2]WIPTYP(nolign-1))
      PARAM(13)  = [M:ORD2]WIPNUM(nolign-1)
      PARAM(14)  = [M:ORD2]ITMREF(nolign-1)
      REPONSE = GSTAFIN
    Endif
Endcase
Return
############################################################
$FERME
If clalev([F:ORD]) <> 0 : Filter [ORD] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:ORD1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        # JPGA : "evalue" enlevé pour que le paramètre WIPORD soit déjà la concaténation du Type + Statut d'ordre
        # => plus simple pour la formule des actions de sélection
        [M:ORD1]TYPSTASEL = PARAM(I)
      Else
        [M:ORD1]TYPSTASEL = ""
      Endif
    When 4 :
     If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:ORD1]ITMREFSTR = [F:ITM]ITMREF
          [M:ORD1]ITMREFEND = [F:ITM]ITMREF
        Endif
      Endif
    When 5 :
      If PARAM(I) <> ""
        [M:ORD1]PJTSTR = PARAM(I)
        [M:ORD1]PJTEND = PARAM(I)
      Endif
    When 6 :
      If PARAM(I) <> ""
        [M:ORD1]ENDDATSTR = PARAM(I)
        [M:ORD1]ENDDATEND = PARAM(I)
      Endif
    When 7 :
      If PARAM(I) <> ""
        [M:ORD1]VCRTYPSEL = val(PARAM(I))
      Else
        [M:ORD1]VCRTYPSEL = 1
      Endif
    When 8 :
      If PARAM(I) <> ""
        [M:ORD1]VCRNUMSTR = PARAM(I)
        [M:ORD1]VCRNUMEND = PARAM(I)
      Endif
    When 9 :
      If PARAM(I) <> ""
        [M:ORD1]SRTCOD = val(PARAM(I))
      Else
        [M:ORD1]SRTCOD = 1
      Endif
    When 10 :
      If PARAM(I) <> ""
        [M:ORD1]SELFLG = val(PARAM(I))
      Else
        [M:ORD1]SELFLG = 0
      Endif
    When 11 :
     If PARAM(I) <> ""
       WFILS = PARAM(I)
     Endif
    When 15 :
      # appel depuis la consult des stock dispo
      If PARAM(I) <> ""
        WEVA =  "dim("+PARAM(I)+")"
        J = evalue(WEVA)
        Case J
          When 1 :
            WEVA   = PARAM(I)
            WFILS1 = evalue(WEVA)
          When 2 :
            WEVA   = PARAM(I)+"(0)"
            WFILS1 = evalue(WEVA)
            WEVA   = PARAM(I)+"(1)"
            WFILS2 = evalue(WEVA)
          When 3 :
            WEVA   = PARAM(I)+"(0)"
            WFILS1 = evalue(WEVA)
            WEVA   = PARAM(I)+"(1)"
            WFILS2 = evalue(WEVA)
            WEVA   = PARAM(I)+"(2)"
            WFILS3 = evalue(WEVA)
          When Default :
            WEVA   = PARAM(I)+"(0)"
            WFILS1 = evalue(WEVA)
            WEVA   = PARAM(I)+"(1)"
            WFILS2 = evalue(WEVA)
            WEVA   = PARAM(I)+"(2)"
            WFILS3 = evalue(WEVA)
            WEVA   = PARAM(I)+"(3)"
            WFILS4 = evalue(WEVA)
        Endcase
      Endif
  Endcase
Next I
If  WFILS = ""  WFILS = "1=1" Endif
If  WFILS1 =""  WFILS1 ="1=1" Endif
If  WFILS2 =""  WFILS2 ="2=1" Endif
If  WFILS3 =""  WFILS3 ="2=1" Endif
If  WFILS4 =""  WFILS4 ="2=1" Endif

If clalev([M:CORD]) <> 0 & [M:CORD]MEMO = "STD"  : # <MG> 26/04/00
  [M:ORD1] = [M:CORD]                            : # <MG> 26/04/00
Endif                                            : # <MG> 26/04/00
If [M:ORD1]TYPSTASEL <> ""
  Gosub MEI_FLG
Endif
Return
############################################################
# Positionnement selections par type d'ordre
$MEI_FLG
For I = 1 To dim(WTYP)
  For J = 1 To dim(WSTA)
    WFLD = "[M:ORD1]"+WTYP(I)+WSTA(J)+"FLG"
    WEVA = "dim("+WFLD+")>0"
    If evalue(WEVA)
      K = 0
      WASEL = [M:ORD1]TYPSTASEL
      While  WASEL <> ""
        If val(left$(WASEL,2)) = I & val(mid$(WASEL,3,1)) = J
          K = 1
          Break
        Endif
        WASEL = mid$(WASEL,4,len(WASEL))
      Wend
      If K = 1
        Assign WFLD With 2
      Else
        Assign WFLD With 1
      Endif
    Endif
  Next J
Next I
############################################################
$LECTURE
# si le tri est passé en paramètre, chargement automatique
If PARAM(9) <> "" : [M:ORD1]FLG = 0 : PARAM(9) = "" : Endif

If [M:ORD1]FLG = 2
  [M:ORD1]FLG = 0
  NBLU        = 0
  Goto LECTURE_FIN
Endif
If [M:ORD1]FLG = 0
  Gosub ANA_SAISIE
  If WANA <>  2
    NBLU        = 0
    Goto LECTURE_FIN
  Endif
Endif

Gosub TRT_FILTER
# Paramètres pour LOA_PAGE
# WINC      : Increment sur NOL et nolign
# WREAD = 0 : Read first
#         1 : Read next
#         2 : Read last
#         3 : read prev
# WSKIP     : Nombre de relectures avant / arrière
#
If WREAD = 0 | CHGPAG = 1
  nolign = 1
  WREAD  = 0
  WINCR  = 1
  SUITE  = 0
  RETOUR = 0
  Gosub LOA_PAGE
Else
  Case CHGPAG
    When 2  :
      If WINCR = -1
        WSKIP = WLIG
      Else
        WSKIP = 0
      Endif
      nolign = 1
      WREAD  = 1
      WINCR  = 1
      Gosub LOA_PAGE
      RETOUR = 0
    When -1 :
      nolign = MAXLIG
      WREAD  = 2
      WINCR  = -1
      WSKIP  = 0
      Gosub LOA_PAGE
      RETOUR = 0
      SUITE  = 1
    When -2 :
      If WINCR = 1
        WSKIP = WLIG
      Else
        WSKIP = 0
      Endif
      nolign = MAXLIG
      WINCR  = -1
      WREAD  = 3
      Gosub LOA_PAGE
      SUITE  = 0
  Endcase
Endif
$LECTURE_FIN
Return
############################################################
$TRT_FILTER
If [M:ORD1]FLG = 0
  [M:ORD1]FLG = 1
  Raz [M:ORD2]
  Gosub LOAD_FILTER
# sr 10.04 demande 26046
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
  Raz CUSFLT
  GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
  If CUSFLT = "" : CUSFLT = "1=1" : Endif
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
#
  Case [M:ORD1]SRTCOD
    When 1 :
      If [M:ORD1]FCY = ""
        Link [ORD] With [ITM]ITM0=[F:ORD]ITMREF As [LNK]
&                     Where evalue(WFIL1)   &
&                          evalue(WFIL2)   &
&                          evalue(WFILS)   &
&                          evalue(WFILSPE) &
&                          evalue(CUSFLT)  &
&       (evalue(WFILS1) or evalue(WFILS2) or evalue(WFILS3) or evalue(WFILS4))
&                    Order By Key ORD2
      Else
        Link [ORD] With [ITM]ITM0=[F:ORD]ITMREF As [LNK]
&                     Where evalue(WFIL1)   &
&                          evalue(WFIL2) &
&                          evalue(WFILS) &
&                          evalue(CUSFLT) &
&       (evalue(WFILS1) or evalue(WFILS2) or evalue(WFILS3) or evalue(WFILS4))
&                    Order By Key ORD1
      Endif
    When 2 :
      Link [ORD] With [ITM]ITM0=[F:ORD]ITMREF As [LNK]
&                     Where evalue(WFIL1)   &
&                        evalue(WFIL2) &
&                        evalue(WFILS) &
&                        evalue(CUSFLT) &
&       (evalue(WFILS1) or evalue(WFILS2) or evalue(WFILS3) or evalue(WFILS4))
&                  Order By Key ORD0
    When 3 :
      Link [ORD] With [ITM]ITM0=[F:ORD]ITMREF As [LNK]
&                     Where evalue(WFIL1)   &
&                        evalue(WFIL2) &
&                        evalue(WFILS) &
&                        evalue(CUSFLT) &
&       (evalue(WFILS1) or evalue(WFILS2) or evalue(WFILS3) or evalue(WFILS4))
&                 Order By Key ORD3
  Endcase
Endif
Return
############################################################
$LOAD_FILTER
Raz TTS, ITTS, WFIL1, WFIL2, WFIL
For I = 1 To dim(WTYP)
  For J = 1 To dim(WSTA)
    WFLD = "[M:ORD1]"+WTYP(I)+WSTA(J)+"FLG"
    WEVA = "dim("+WFLD+")>0&"+WFLD+"=2"
    If evalue(WEVA)
      TTS(ITTS) = num$(I)+num$(J)
      ITTS += 1
    Endif
  Next J
Next I
# Filtre site et type+statut
If [M:ORD1]FCY <> ""
  WFIL1  = "[F:ORD]STOFCY=[M:ORD1]FCY"+
&          "&find(num$([F:ORD]WIPTYP)+num$([F:ORD]WIPSTA),TTS(0..ITTS-1))"
Else
  WFIL1  = "find(num$([F:ORD]WIPTYP)+num$([F:ORD]WIPSTA),TTS(0..ITTS-1))"
Endif
# Filtre numéro article
If [M:ORD1]ITMREFSTR <> "" | [M:ORD1]ITMREFEND <> ""
  If [M:ORD1]ITMREFSTR = [M:ORD1]ITMREFEND
    WFIL = "[F:ORD]ITMREF=[M:ORD1]ITMREFSTR"
  Else
    WFIL = "([F:ORD]ITMREF>=[M:ORD1]ITMREFSTR&[F:ORD]ITMREF<=[M:ORD1]ITMREFEND)"
  Endif
  Gosub LOA_WFIL
Endif
# Filtre projet
If [M:ORD1]PJTSTR <> "" | [M:ORD1]PJTEND <> ""
  If [M:ORD1]PJTSTR = [M:ORD1]PJTEND
    WFIL = "[F:ORD]PJT=[M:ORD1]PJTSTR"
  Else
    WFIL = "([F:ORD]PJT>=[M:ORD1]PJTSTR&[F:ORD]PJT<=[M:ORD1]PJTEND)"
  Endif
  Gosub LOA_WFIL
Endif
# Filtre date fin
If [M:ORD1]ENDDATSTR <> [0/0/0]
  WFIL = "[F:ORD]ENDDAT>=[M:ORD1]ENDDATSTR"
  Gosub LOA_WFIL
Endif
If [M:ORD1]ENDDATEND <> [0/0/0]
  WFIL = "[F:ORD]ENDDAT<=[M:ORD1]ENDDATEND"
  Gosub LOA_WFIL
Endif
# Filtre type pièce
If [M:ORD1]VCRTYPSEL > 1
  WFIL = "[F:ORD]VCRTYP=[M:ORD1]VCRTYPSEL-1"
  Gosub LOA_WFIL
Endif
# Filtre numéro pièce
If [M:ORD1]VCRNUMSTR <> "" | [M:ORD1]VCRNUMEND <> ""
  If [M:ORD1]VCRNUMSTR = [M:ORD1]VCRNUMEND
    WFIL = "[F:ORD]VCRNUM=[M:ORD1]VCRNUMSTR"
  Else
    WFIL = "([F:ORD]VCRNUM>=[M:ORD1]VCRNUMSTR&[F:ORD]VCRNUM<=[M:ORD1]VCRNUMEND)"
  Endif
  Gosub LOA_WFIL
Endif
# Issue 120685 - 2017-01-04 by MAE : Modifs faites uniquement sur GX3APP
##Filtre clé de recherche
#If [M:ORD1]SEAKEYSTR <> "" | [M:ORD1]SEAKEYEND <> ""
#  WFIL += "[F:ITM]SEAKEY>=[M:ORD1]SEAKEYSTR&[F:ITM]SEAKEY<=[M:ORD1]SEAKEYEND"
#  Gosub LOA_WFIL
#Endif
If WFIL2 = ""
  WFIL2 = "1=1"
Endif
Return
############################################################
$LOA_WFIL
If len(WFIL1)+len(WFIL)+1 < 250
  WFIL1 += "&"
  WFIL1 += WFIL
Else
  If WFIL2 <> ""
    WFIL2 += "&"
  Endif
  WFIL2 += WFIL
Endif
Return
###########################################################
$ANA_SAISIE
WANA = 2
WMSG = ""
Case [M:ORD1]SRTCOD
  When 1 :
    If [M:ORD1]ITMREFSTR = "" & [M:ORD1]ITMREFEND = ""
      WMSG = mess(25,187,1)
    Endif
  When 2 :
    If clalev ([M:OPX1]) <= 0
        WMSG = mess(27,187,1)
    Endif
    For I = 1 To dim(WTYP)
      For J = 1 To dim(WSTA)
        WFLD = "[M:ORD1]"+WTYP(I)+WSTA(J)+"FLG"
        WEVA = "dim("+WFLD+")>0&"+WFLD+"=2"
        If evalue(WEVA)
          WMSG = ""
          Break 2
        Endif
      Next J
    Next I
  When 3 :
    If [M:ORD1]FCY = ""
      WMSG = mess(24,187,1)
    Else
      If [M:ORD1]VCRTYPSEL = 1
        WMSG = mess(26,187,1)
      Endif
    Endif
Endcase
If WMSG <> ""
  Call AVERTIR(WMSG,WANA) From GESECRAN
Endif
Return
############################################################
$LOA_PAGE

NBLU = 2
WLIG = 0
If WSKIP <> 0
  If WSKIP < 0
    While WSKIP <> -1
      Read [LNK] Next
      If fstat
        Break
      Endif
      WSKIP += 1
    Wend
  Else
    While WSKIP <> 1
      Read [LNK] Prev
      If fstat
        Break
      Endif
      WSKIP -= 1
    Wend
  Endif
Endif
# Test tableau plein
$LOA_PAGE1
If  nolign > MAXLIG | nolign < 1
  Goto LOA_PAGE_FIN
Endif
# Choix lecture
Case WREAD
  When 0 :
    WREAD = 1
    Read [LNK] First
    If fstat = 0
      WFIRTYP = [F:ORD]WIPTYP
      WFIRNUM = [F:ORD]WIPNUM
      WFIRITM = [F:ORD]ITMREF
    Else
      Raz WFIRTYP, WFIRNUM, WFIRITM
      SUITE   = 1
      RETOUR  = 1
      Goto LOA_PAGE_FIN
    Endif
  When 1 :
    Read [LNK] Next
    If fstat
      SUITE = 1
      Goto LOA_PAGE_FIN
    Endif
  When 2 :
    WREAD = 3
    Read [LNK] Last
  When 3 :
    Read [LNK] Prev
    If fstat
      RETOUR = 1
      Goto LOA_PAGE_FIN
    Endif
Endcase

# filtre origine des suggestions CBN/PDP (llc 10.00 demande 6454)
If [F:ORD]WIPTYP <> 1 & [F:ORD]WIPSTA = 3
    If [M:CORD]MRPFLG = 1 & [F:ORD]ORI <> 5 : Goto LOA_PAGE1 : Endif
    If [M:CORD]MRPFLG = 2 & [F:ORD]ORI <> 6 : Goto LOA_PAGE1 : Endif
Endif

# Test fin lecture
Gosub LOA_LIGNE
nolign += WINCR
NOL    += WINCR
WLIG   += WINCR
If [F:ORD]WIPTYP  = WFIRTYP &
&  [F:ORD]WIPNUM  = WFIRNUM &
&  [F:ORD]ITMREF  = WFIRITM
  RETOUR = 1
Endif
Goto LOA_PAGE1
#
$LOA_PAGE_FIN
# Issue 78760 - 2011-12-19 by VPO : il faut enlever le filter/order by
# sinon pb dans les fct appelées(ex: modif cde qui lit ORD)
# On doit aussi remettre [M:ORD1]FLG à 0
If clalev([F:ORD]) <> 0 : Filter [ORD] : Endif
[M:ORD1]FLG = 0
Return
############################################################
$LOA_LIGNE
Read [ITM]ITM0=[F:ORD]ITMREF
If fstat
  Raz [F:ITM]
Endif
# Correction quantité restante par % perte
If [F:ORD]WIPTYP = 5 & find([F:ORD]WIPSTA,1,2,3) & [M:ORD1]SHRFLG = 2
  If [F:ITF]STOFCY <> [F:ORD]STOFCY | [F:ITF]ITMREF <> [F:ORD]ITMREF
    Read [ITF]ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY
    If fstat
      Raz [F:ITF]
    Endif
    Read [TUN]TUN0=[F:ITM]STU
    If fstat
      Raz [F:TUN]
    Endif
  Endif
  If [F:ITF]SHR > 0
    [F:ORD]EXTQTY    = arr(([F:ORD]EXTQTY*100)/(100+[F:ITF]SHR),10^-[F:TUN]UOMDEC)
    [F:ORD]RMNEXTQTY = arr(([F:ORD]RMNEXTQTY*100)/(100+[F:ITF]SHR),10^-[F:TUN]UOMDEC)
  Endif
Endif
[M:ORD2] = [F:ORD]
[M:ORD2]WIPTYPSTA(nolign-1)=mess([F:ORD]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)
#
#[M:ORD2]ITMDES1(nolign-1) = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:ORD2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:ORD2]STU(nolign-1)     = [F:ITM]STU

Return




############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()

If GCONSULT <> 0
  mkstat = 2
Endif
#MAE, EVOL_ERGO
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM","GESITF")
        If find(GNAVIG(GPILNAV-1),"GESITM")
            Diszo [M:ORD1]ITMREFSTR
        Elsif find(GNAVIG(GPILNAV-1),"GESITF")
            Diszo [M:ORD1]FCY
            Diszo [M:ORD1]ITMREFSTR
        Endif
    Endif
Endif

End
############################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
VALEUR = vireblc(VALEUR,4)
If VALEUR <> ""
  Call VERFCY(VALEUR) From CONTX3
Endif
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:ORD1]FLG = 0
End
############################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
[M:ORD1]FLG  = 0
[M]ITMREFEND = VALEUR
End
############################################################
Subprog AM_ITMREFEND(VALEUR)
Variable Char    VALEUR()
[M:ORD1]FLG = 0
End
############################################################
Subprog AV_ITMREFEND(VALEUR)
Variable Char     VALEUR
If VALEUR = ""
  VALEUR = [M]ITMREFSTR
Endif
End
############################################################
Subprog AM_SRTCOD(VALEUR)
Variable Integer VALEUR
[M:ORD1]FLG = 0
End
############################################################
Subprog AV_VCRNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]VCRNUMSTR
Endif
End
############################################################
Subprog AV_PJTEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]PJTSTR
Endif
End

########################################
Subprog AM_ENDDATSTR(VALEUR)
Variable Date     VALEUR
If VALEUR > [M]ENDDATEND
  [M]ENDDATEND = VALEUR
Endif
End

########################################
