########################################
Subprog IB_NBLIG
#MAE, le 13/02/08, EVOL_ERGO
GBOUT3 = ""        : # Commandes client
GBOUT4 = ""        : # contrat ferme et planifiée
GBOUT5 = ""        : # commandes fournisseurs ferme
GBOUT6 = ""        : # commandes ouverte
GBOUT7 = ""        : # demande d'achat
GBOUT8 = ""        : # ordre de fabrication
GBOUT9 = ""        : # Ordre de sous traitance

If clalev ([M:OPX1]) > 0 | !find([M:ORD2]WIPTYP(nolign-1),4,5,6,9)
    GBOUT2 = ""
Endif
#MAE, le 13/02/08, EVOL_ERGO
If(([M:ORD2]WIPTYP(nolign-1) = 1)
&      &([M:ORD2]WIPSTA(nolign-1) < 3)
&      & ([M:ORD2]ABBFIL(nolign-1) = "SOQ"))     #commandes client ferme et planifiée
        GBOUT3 =  mess(1,306,1)
Else If (([M:ORD2]WIPTYP(nolign-1) = 1)
&      & ([M:ORD2]WIPSTA(nolign-1) < 3)
&      & ([M:ORD2]ABBFIL(nolign-1) = "SOC"))     #contrat ferme et planifiée
        GBOUT4 =  mess(92,198,1)
Else If (([M:ORD2]WIPTYP(nolign-1) = 8)
&      & ([M:ORD2]WIPSTA(nolign-1) = 1))         #demande inter site ferme
        GBOUT3 =  mess(8,306,1)
Else If (([M:ORD2]WIPTYP(nolign-1) = 2)
&      & ([M:ORD2]WIPSTA(nolign-1) = 1)
&      & ([M:ORD2]ABBFIL(nolign-1) = "POQ"))     #commandes fournisseurs ferme
        GBOUT5=  mess(2,306,1)
Else If (([M:ORD2]WIPTYP(nolign-1) = 2)
&      & ([M:ORD2]ABBFIL(nolign-1) = "POC"))     #commandes ouverte
        GBOUT6=  mess(2,506,1)
Else If (([M:ORD2]WIPTYP(nolign-1) = 2)
&      & ([M:ORD2]WIPSTA(nolign-1) = 2)
&      & ([M:ORD2]ABBFIL(nolign-1) = "POQ"))     #demande d'achat
        GBOUT7=  mess(2,517,1)
Else If (([M:ORD2]WIPTYP(nolign-1) = 7)
&      & ([M:ORD2]WIPSTA(nolign-1) = 1))         #ordre inter site ferme
        GBOUT5 =  mess(7,306,1)
Else If [M:ORD2]WIPTYP(nolign-1)= 5  & [M:ORD2]WIPSTA(nolign-1)<>3   #ordre de fabrication sauf si WOS Issue 83382
        GBOUT8=  mess(5,306,1)
Else If [M:ORD2]WIPTYP(nolign-1) = 13 & [M:ORD2]WIPSTA(nolign-1)<>3  #ordre de sous traitancesauf si EOS Issue 83382
        GBOUT9=  mess(13,306,1)
Else If [M:ORD2]WIPTYP(nolign-1) = 3            #ordre de sous traitance à partir des matiéres de sous traitance
        GBOUT9=  mess(13,306,1)
Endif

Endif
Endif
Endif
Endif
Endif
Endif
Endif
Endif
Endif

End

