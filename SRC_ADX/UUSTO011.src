#<AdxTL>@(#)3.0.0.0 $Revision$
# Moulinette pour Mise à jour tailles écrans stocks
Call MAJ_UTISTO011(nomap)
End

########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

Call MAJ_UTISTO011(APPLI)

End

########################################################################
Subprog MAJ_UTISTO011(DOSSIER)
Value Char DOSSIER

If DOSSIER=GDOSX3 End Endif

Call ECR_TRACE("--------------------------------------",0) From GESECRAN
Call ECR_TIME("DOSSIER : "+DOSSIER) From DOSSUB
Call ECR_TIME("Mise à jour tailles écrans stock (UTISTO011)") From DOSSUB
#------------------------------------------------------
Call MAJ_UTISTO011(DOSSIER) From UTISTO011
Call ECR_TIME("FIN => Mise à jour écrans stock (UTISTO011)") From DOSSUB

End
