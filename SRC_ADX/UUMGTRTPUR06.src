Raz [F:PTD]LINVOU
Raz [F:PTD]LINWEU
Raz [F:PTD]FCSCPR
Raz [F:PTD]FCSCSTPUR
Raz [F:PTD]FCSCPRCPT
Return
################################################
# Issue 112754 - 2016-12-19 by SR : Services en V12
$RAZV12_PTD
Raz [F:PTD]ITMKND
Return
################################################
$MAJV6_AVPTH
    Raz [F:PTH]TOTLINAMT, [F:PTH]TOTLINQTY, [F:PTH]TOTLINWEU, [F:PTH]TOTLINVOU
    Raz NBTAX, TAX, BASTAX, AMTTAX, DEDTAX, PURTYP
    Raz NBFAC, INVDTA, INVLINAMT, DEBCDT, INVDTAVAT, DTAAMTTAX, DTADEDTAX
    #----- Alimentation de la société sur l'entête de réception -----#
    Call PARAML([F:PTH]PRHFCY,"SALDSPWEU",[F:PTH]DSPWEU) From ADOVAL
    Call PARAML([F:PTH]PRHFCY,"SALDSPVOU",[F:PTH]DSPVOU) From ADOVAL
    [F:PTH]CPY=GSOCIETE

    #----- Alimentation code adresse fournisseur expéditeur -----#
    If [F:PTH]BPOADD=""  [F:PTH]BPOADD=[F:PTH]BPAADD : Endif
    #----- Alimentation code adresse transitaire -----#
    If [F:PTH]FFWNUM<>"" & [F:PTH]FFWADD=""
      Gosub LECT_BPRFFW
      [F:PTH]FFWADD=[F:BPR]BPAADD
    Endif
    #----- Alimentation code adresse fournisseur facturant -----#
    If [F:PTH]BPAINV=""
      Gosub LECT_BPSI
      [F:PTH]BPAINV=[F:BPS]BPAADD
    Endif
    #----- Alimentation tiers payé et code adresse tiers payé -----#
    If [F:PTH]BPRPAY=""
      Gosub LECT_BPSPTH
      [F:PTH]BPRPAY=[F:BPS]BPRPAY
      [F:PTH]BPAPAY=[F:BPS]BPAPAY
    Endif
    #----- Alimentation du régime de taxe et du type de régime -----#
    If [F:PTH]VACBPR=""
      Gosub LECT_BPSPTH
      [F:PTH]VACBPR=[F:BPS]VACBPR
      #----- Chargement du régime de taxe du fournisseur -----#
      #Call INIT_REGIME([F:PTH]BPSNUM,[F:PTH]PRHFCY,"F",[F:PTH]VACBPR) From CPTSUB
      #----- Chargement du type de régime taxe -----#
      If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[F:PTH]VACBPR
        Read [ADI] CODE=1;[F:PTH]VACBPR : If fstat Raz [F:ADI] : Endif
      Endif
      [F:PTH]VACTYP=[F:ADI]N1
      #-----
    Endif
    #----- Passage de la nature transaction CEE à 2 caractères -----#
    If len([F:PTH]EECNAT)>2 & left$([F:PTH]EECNAT,1)="0"
      [F:PTH]EECNAT=right$([F:PTH]EECNAT,2)
    Endif
    #----- Alimentation de l'identification CEE -----#
    If GACTDEB=2 & [F:PTH]EECNUM=""
      Gosub LECT_BPRI
      [F:PTH]EECNUM=[F:BPR]EECNUM
    Endif
    #----- Alimentation champs pour le multi-référentiels comptabilité -----#
    If dim([F:PTH]DIE)>0 & [F:PTH]DIE(0)=""
      For I=1 To max(GNBDIE,GOPTCANA)
        [F:PTH]DIE(I-1)=GDIE(I)
      Next I
    Endif
    #----- Alimentation éléments et taxes ligne tarif -----#
    Gosub LECT_BPSPTH
    #-----
    Call TYPREM(2,[F:BPS]PLISTC) From TRTPRICE
    #----- Chargement arrondi devise réception -----#
    Gosub LECT_TCUCUR
    #-----
    For I=0 To dim([F:PTH]INVDTAVAT1)-1
      If GINVDTALIN(I)<>0 & GNPRNOTFLG(I)=1
        [F:PTH]INVDTALIN1(I)=GINVDTALIN(I)
        If [F:PTH]INVDTAVAT1(I)=""
          WJ=find(GINVDTALIN(I),WPFINUM(0..WNBPFI))
          If WJ>0 & WPFIVATRUL(WJ-1)=2
            WJTVC=find([F:BPS]VACBPR+'/'+WPFIVACITM(WJ-1),WTVCCLE(0..NBTVC))
            If WJTVC>0
              [F:PTH]INVDTAVAT1(I)=WTVCVAT(WJTVC-1)
            Endif
          Endif
        Endif
      Endif
    Next I

Return

# Issue 88474 - 2013-05-07 by SR
################################################
$MAJV7_AVPTH
    Call PARAML([F:PTH]PRHFCY,"SALDSPWEU",WDSPWEU) From ADOVAL
    Call PARAML([F:PTH]PRHFCY,"SALDSPVOU",WDSPVOU) From ADOVAL
Return

########################################################################
$LECT_TCUCUR
    If [F:TCU]CUR<>[F:PTH]CUR
      Read [TCU] TCU0=[F:PTH]CUR
      If !fstat  WRND=[F:TCU]CURRND  Else  WRND=0.01 : Endif
    Else
      WRND=[F:TCU]CURRND
    Endif
Return
################################################
$LECT_BPSPTH
  If [F:BPS]BPSNUM<>[F:PTH]BPSNUM
    WBPS=[F:PTH]BPSNUM
    Gosub LECT_BPS
  Endif
Return

$LECT_BPSI
  If [F:BPS]BPSNUM<>[F:PTH]BPSINV
    WBPS=[F:PTH]BPSINV
    Gosub LECT_BPS
  Endif
Return

$LECT_BPS
    Read [BPS] BPS0=WBPS : If fstat  Raz [F:BPS] : Endif
Return
################################################
$LECT_BPRI
  If [F:BPR]BPRNUM<>[F:PTH]BPSINV
    WBPR=[F:PTH]BPSINV
    Gosub LECT_BPR
  Endif
Return

$LECT_BPRFFW
  If [F:BPR]BPRNUM<>[F:PTH]FFWNUM
    WBPR=[F:PTH]FFWNUM
    Gosub LECT_BPR
  Endif
Return

$LECT_BPR
    Read [BPR] BPR0=WBPR : If fstat  Raz [F:BPR] : Endif
Return
################################################
$MAJV6_PTD
  #----- Alimention prix de revient sans frais d'approche (arrondi mini à 4 décimales) -----#
  If [F:PTD]CPRPRI=0
    If [F:PTD]CPRCOE=0  [F:PTD]CPRCOE=1 : Endif
    [F:PTD]CPRPRI=arr([F:PTD]CPR/[F:PTD]CPRCOE,10^-max(GDECPRI,4))
  Endif
  #----- Alimentation société et adresse fourniss. facturant sur lignes réception -----#
  [F:PTD]CPY   =[F:PTH]CPY
  [F:PTD]BPAINV=[F:PTH]BPAINV
  #----- Mise à jour des quantités poids et volume -----#
  Gosub LECT_ITMPTD
  #----- Par sécurité, chargement des unités de l'article si nécessaire -----#
  If [F:PTH]DSPWEU=""  [F:PTH]DSPWEU=[F:ITM]WEU : Endif
  If [F:PTH]DSPVOU=""  [F:PTH]DSPVOU=[F:ITM]VOU : Endif
  #-----
  [F:PTD]QTYWEU=[F:ITM]ITMWEI*[F:PTD]QTYSTU
  [F:PTD]QTYVOU=[F:ITM]ITMVOU*[F:PTD]QTYSTU

  WUOM1=[F:ITM]WEU
  WUOM2=[F:PTH]DSPWEU
  WQTY=[F:PTD]QTYWEU
  Gosub CONVERT_QTY From UUMGTRTPUR00
  [F:PTD]QTYWEU=WQTY

  WUOM1=[F:ITM]VOU
  WUOM2=[F:PTH]DSPVOU
  WQTY=[F:PTD]QTYVOU
  Gosub CONVERT_QTY From UUMGTRTPUR00
  [F:PTD]QTYVOU=WQTY

  #----- Alimentation des bases spéciales 1-3 calcul taxe -----#
  If ([F:PTD]CLCAMT1<>0 | [F:PTD]CLCAMT2<>0)
&       & [F:PTD]CLCAMT3=0
&       & [F:PTD]CLCAMT4=0
&       & [F:PTD]CLCAMT5=0
&       & [F:PTD]CLCAMT6=0
&       & [F:PTD]CLCAMT7=0
    #-----
    Raz WCLCAMT, WCLCFLG
    WCLCAMT1=[F:PTD]CLCAMT1 : WCLCFLG1=0
    WCLCAMT2=[F:PTD]CLCAMT2 : WCLCFLG2=0
    For I=2 To 3
      Case I
        When 2 : WTAX=[F:PTD]VAT(I-1) : Gosub TRT_BASE
        When 3 : WTAX=[F:PTD]VAT(I-1) : Gosub TRT_BASE
      Endcase
    Next I
    If WCLCFLG1 | WCLCFLG2
      If WCLCFLG1  Raz [F:PTD]CLCAMT1 : Endif
      If WCLCFLG2  Raz [F:PTD]CLCAMT2 : Endif
      For I=2 To 3
        If WCLCFLG(I)=1
          ##Assign "[F:PTD]CLCAMT"+num$(I) With WCLCAMT(I)
          Case I
          When 2 : [F:PTD]CLCAMT2=WCLCAMT(I)
          When 3 : [F:PTD]CLCAMT3=WCLCAMT(I)
          When Default
          Endcase
        Endif
      Next I
    Endif
  Endif
  #----- Alimentation des nouveaux champs sous-traitance à partir des anciens -----#
  If dim([F:PTDM]MFGITM)>0    [F:PTD]ITMREFORI=[F:PTDM]MFGITM    : Endif
  If dim([F:PTDM]MFGNUM)>0    [F:PTD]VCRNUMORI=[F:PTDM]MFGNUM    : Endif
  If dim([F:PTDM]OPENUM)>0    [F:PTD]VCRLINORI=[F:PTDM]OPENUM    : Endif
  If dim([F:PTDM]OPESPLNUM)>0 [F:PTD]VCRSEQORI=[F:PTDM]OPESPLNUM : Endif
  If [F:PTD]VCRNUMORI<>"" & [F:PTD]VCRTYPORI=0
    [F:PTD]VCRTYPORI=10
  Endif
  #----- Alimentation de la province de sortie et du pays expéditeur -----#
  If (LACTPTX & [F:PTD]SATISS="") | [F:PTD]BPOCRY=""
    If [F:PTD]POHNUM<>""
      Gosub LECT_POHPTD
      If [F:POH]BPOSAT<>"" | [F:POH]BPOCRY<>""
        If LACTPTX & len([F:POH]BPOSAT)<=4 & toupper([F:POH]BPOSAT)=[F:POH]BPOSAT
          [F:PTD]SATISS=[F:POH]BPOSAT
        Endif
        [F:PTD]BPOCRY=[F:POH]BPOCRY
      Else
        #----- Lecture de l'adresse d'expédition si nécessaire -----#
        Gosub LECT_BPAPOH
        #-----
        If LACTPTX & len([F:BPA]SAT)<=4 & toupper([F:BPA]SAT)=[F:BPA]SAT
          [F:PTD]SATISS=[F:BPA]SAT
        Endif
        [F:PTD]BPOCRY=[F:BPA]CRY
      Endif
    Elsif [F:PTH]BETFCY=2 & [F:PTD]SDHNUM<>"" & [F:PTD]LINSTOFCY<>""
      #----- Lecture du site d'expédition si nécessaire -----#
      Gosub LECT_FCYSTO
      #----- Lecture de l'adresse d'expédition si nécessaire -----#
      Gosub LECT_BPASTO
      #-----
      If LACTPTX & len([F:BPA]SAT)<=4 & toupper([F:BPA]SAT)=[F:BPA]SAT
        [F:PTD]SATISS=[F:BPA]SAT
      Endif
      [F:PTD]BPOCRY=[F:BPA]CRY
    Else
      #----- Lecture fournisseur si nécessaire -----#
      Gosub LECT_BPSPTH
      #----- Lecture de l'adresse d'expédition si nécessaire -----#
      Gosub LECT_BPAPTH
      #-----
      If LACTPTX & len([F:BPA]SAT)<=4 & toupper([F:BPA]SAT)=[F:BPA]SAT
        [F:PTD]SATISS=[F:BPA]SAT
      Endif
      [F:PTD]BPOCRY=[F:BPA]CRY
    Endif
  Endif
  #----- Alimentation Type ligne et catégorie de mouvement -----#
  If [F:PTD]LINTYP=0  [F:PTD]LINTYP=1 : Endif
  If [F:PTD]LINCAT=0  [F:PTD]LINCAT=1 : Endif

  Gosub WRITE_CAL_PTD

  #----- Calcul bases et taxes de la ligne de réception -----#
  Gosub MAJ_CALTAX_LIG
  Gosub MAJ_BASTAX_LIG

  #----- Cumuls montants et qtés des lignes -----#
  [F:PTH]TOTLINAMT+=[F:PTD]LINAMT
  [F:PTH]TOTLINQTY+=[F:PTD]QTYPUU
  [F:PTH]TOTLINWEU+=[F:PTD]QTYWEU
  [F:PTH]TOTLINVOU+=[F:PTD]QTYVOU
Return

# Issue 88474 - 2013-05-07 by SR
################################################
$MAJV7_PTD
[F:PTD]LINVOU = WDSPVOU
[F:PTD]LINWEU = WDSPWEU
[F:PTD]CPRCUR = GLOCALDEV
Gosub CLC_PTD
Return

# Issue 112754 - 2016-12-19 by SR : Services en v12
########################################################################
$MAJV12_PTD
If    [F:PTD]LINTYP <> 3 & [F:PTD]VCRTYPORI <> 10  : [F:PTD]ITMKND = 1
Elsif [F:PTD]LINTYP = 1  & [F:PTD]VCRTYPORI  = 10  : [F:PTD]ITMKND = 2
Elsif [F:PTD]LINTYP = 3  : [F:PTD]ITMKND = 2
Endif
Return

#########################################################################
# MAJ_CALTAX_LIG : S/P de calcul des bases et des taxes    MBT 03/12/07 #
#                     de la ligne de réception                          #
#########################################################################
$MAJ_CALTAX_LIG
#-----
For I=1 To 3
  Case I
    When 1 : TAXE(1)=[F:PTD]VAT(0) : WCLCAMT(1)=[F:PTD]CLCAMT1
    When 2 : TAXE(2)=[F:PTD]VAT(1) : WCLCAMT(2)=[F:PTD]CLCAMT2
    When 3 : TAXE(3)=[F:PTD]VAT(2) : WCLCAMT(3)=[F:PTD]CLCAMT3
  Endcase
Next I
#-----
Raz MONTANT,MONTDED
Call CALTAXE2(GSOCIETE,[F:PTD]RCPDAT,[F:PTH]VACBPR,[F:PTH]CUR,3,TAXE,1,[F:PTD]LINAMT,WCLCAMT,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#-----
For I=1 To 3
  Case I
    When 1
      [F:PTD]BASTAXLIN1=[F:PTD]LINAMT
      [F:PTD]AMTTAXLIN1=MONTANT(1)
      [F:PTD]DEDTAXLIN1=MONTDED(1)
    When 2
      If [F:PTD]VAT(1)=""
        Raz [F:PTD]AMTTAXLIN2, [F:PTD]DEDTAXLIN2
      Else
        [F:PTD]AMTTAXLIN2=MONTANT(2)
        [F:PTD]DEDTAXLIN2=MONTDED(2)
        WJTVT=find([F:PTD]VAT(1),WTVTVAT(0..NBTVT))
        If WJTVT>0 & WTVTVATCHA(WJTVT-1)=2 [F:PTD]BASTAXLIN1+=[F:PTD]AMTTAXLIN2 : Endif
      Endif
    When 3
      If [F:PTD]VAT(2)=""
        Raz [F:PTD]AMTTAXLIN3, [F:PTD]DEDTAXLIN3
      Else
        [F:PTD]AMTTAXLIN3=MONTANT(3)
        [F:PTD]DEDTAXLIN3=MONTDED(3)
        WJTVT=find([F:PTD]VAT(2),WTVTVAT(0..NBTVT))
        If WJTVT>0 & WTVTVATCHA(WJTVT-1)=2 [F:PTD]BASTAXLIN1+=[F:PTD]AMTTAXLIN3 : Endif
      Endif
  Endcase
Next I
#-----
If [F:PTH]VACTYP<>4
  [F:PTD]LINATIAMT=[F:PTD]LINAMT
  For I=1 To 3
    Case I
      When 1 : [F:PTD]LINATIAMT+=[F:PTD]AMTTAXLIN1
      When 2 : [F:PTD]LINATIAMT+=[F:PTD]AMTTAXLIN2
      When 3 : [F:PTD]LINATIAMT+=[F:PTD]AMTTAXLIN3
    Endcase
  Next I
Else
  [F:PTD]LINATIAMT=[F:PTD]LINAMT
Endif
#----- Calcul de la taxe des montants remises/frais de la ligne tarif -----#
For I=1 To 9
  ##If evalue("dim([F:PTD]DISCRGVAL"+num$(I)+")")>0

    If GNPRNOTFLG(I-1)=1 & GINVDTALIN(I-1)<>0

    Case I
    When 1 : WDISCRGVAL=[F:PTD]DISCRGVAL1
    When 2 : WDISCRGVAL=[F:PTD]DISCRGVAL2
    When 3 : WDISCRGVAL=[F:PTD]DISCRGVAL3
    When 4 : WDISCRGVAL=[F:PTD]DISCRGVAL4
    When 5 : WDISCRGVAL=[F:PTD]DISCRGVAL5
    When 6 : WDISCRGVAL=[F:PTD]DISCRGVAL6
    When 7 : WDISCRGVAL=[F:PTD]DISCRGVAL7
    When 8 : WDISCRGVAL=[F:PTD]DISCRGVAL8
    When 9 : WDISCRGVAL=[F:PTD]DISCRGVAL9
    When Default
    Endcase


      #----- C'est un montant -----#
      If GDISCRGTYP(I-1)=1
        If GCLCRUL(I-1)=1 : # Par unité
          BASE=arr(WDISCRGVAL*[F:PTD]QTYUOM,WRND)
        Else              : # Par ligne
          BASE=WDISCRGVAL
        Endif
      #----- C'est un pourcentage -----#
      Else
        BASE=arr([F:PTD]LINAMT*WDISCRGVAL/100,WRND)
      Endif
      #----- Inversion du montant si minoration -----#
      If GINCDCR(I-1)=2  BASE=-BASE : Endif
      #----- Màj base et mt taxe ligne si taux produit -----#
      If [F:PTH]INVDTAVAT1(I-1)=""
        Raz TAXE : TAXE(1)=[F:PTD]VAT(0)
        If BASE<>0
          Call CALTAXE(GSOCIETE,[F:PTD]RCPDAT,[F:PTH]VACBPR,[F:PTH]CUR,1,TAXE,1,
&                      BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
          [F:PTD]BASTAXLIN1+=BASE
          [F:PTD]AMTTAXLIN1+=MONTANT(1)
          [F:PTD]DEDTAXLIN1+=MONTDED(1)
        Endif
      Endif
      #----- Recherche si élément déja existant -----#
      J=find(GINVDTALIN(I-1),INVDTA(0..NBFAC-1))
      If J=0
        #----- Le nombre maximum d'élément est dépassé ! (Impossible en théorie) ------#
        If NBFAC>=dim(INVDTA)  Goto MAJ_SUIT1 : Endif
        #-----
        J=NBFAC
        NBFAC+=1
        INVDTA   (J)=GINVDTALIN       (I-1)
        DEBCDT   (J)=GINCDCR          (I-1)
        INVDTAVAT(J)=[F:PTH]INVDTAVAT1(I-1)
      Else
        J-=1
      Endif
      INVLINAMT(J)+=BASE
    Endif
  ##Endif
$MAJ_SUIT1
Next I
#-----
Return


#########################################################################
# MAJ_BASTAX_LIG : S/P de mise à jour des bases et         MBT 03/12/07 #
#                     montants de taxe à partir des                     #
#                     valeurs de la ligne de réception                  #
#########################################################################
$MAJ_BASTAX_LIG
#----- Mise à jour des bases et des montants de taxe -----#
For I=1 To 3
  Case I
    When 1 : WTAX   =[F:PTD]VAT(0)     : WBASE  =[F:PTD]BASTAXLIN1
             WAMTTAX=[F:PTD]AMTTAXLIN1 : WDEDTAX=[F:PTD]DEDTAXLIN1
    When 2 : WTAX   =[F:PTD]VAT(1)     : WBASE  =[F:PTD]LINAMT
             WAMTTAX=[F:PTD]AMTTAXLIN2 : WDEDTAX=[F:PTD]DEDTAXLIN2
    When 3 : WTAX   =[F:PTD]VAT(2)     : WBASE  =[F:PTD]LINAMT
             WAMTTAX=[F:PTD]AMTTAXLIN3 : WDEDTAX=[F:PTD]DEDTAXLIN3
  Endcase
  If WTAX<>""
    WJTVT=find(WTAX,WTVTVAT(0..NBTVT))
    If I>1 & WJTVT>0
      Case WTVTVATBAS(WJTVT-1)
        When 2 : WBASE=[F:PTD]CLCAMT2 : # Base spéciale 1
        When 3 : WBASE=[F:PTD]CLCAMT3 : # Base spéciale 2
        # Issue 98865 - 2014-04-07 by MUARN : taxe spéciales dans CLCAMT2 et CLCAMT3 non 1 et 2
      Endcase
    Endif

    #----- Recherche si taxe déja existante -----#
    J=find(WTAX,TAX(0..NBTAX-1))
    If J<>0 & PURTYP(J-1)<>[F:PTD]LINPURTYP
      K=find(WTAX,TAX(J..NBTAX-1))
      If K<>0
        J+=K
        If PURTYP(J-1)<>[F:PTD]LINPURTYP
          K=find(WTAX,TAX(J..NBTAX-1))
          If K<>0 J+=K Else J=0 : Endif
        Endif
      Else
        J=0
      Endif
    Endif
    #----- Nouvelle taxe -----#
    If J=0
      #----- Le nombre maximum de taxe est dépassé ! (Impossible en théorie) ------#
      If NBTAX>=dim(TAX)  Goto MAJ_SUIT2 : Endif
      #-----
      J=NBTAX
      NBTAX+=1
      TAX   (J)=WTAX
      PURTYP(J)=[F:PTD]LINPURTYP
      VATTYP(J)=WTVTVATTYP(WJTVT-1)
    Else
      J-=1
    Endif
    #----- Mise à jour de la base et des montants de taxe -----#
    BASTAX(J)+=WBASE
    AMTTAX(J)+=WAMTTAX
    DEDTAX(J)+=WDEDTAX
  Endif
$MAJ_SUIT2
Next I
Return

# Issue 88474 - 2013-05-06 by SR
###############################################
$CLC_PTD
# Calcul du cout achat,mnt achat, mnt stock et du cout stock calculé CPRCLC (CPR existe déjà)
#-----
#----- Si SST (composé ou composant), pas de calcul  -----#
If [F:PTD]LINTYP>1 : Return : Endif
#-----
# WBASE,WMT pour le CPR calculé , WBASE1,WMT1 pour LINCSTPUR
If [F:PTD]QTYUOM<>0
  WBASE=[F:PTD]NETPRI*[F:PTD]QTYUOM : # Mt ligne avec précision maxi
Else
  WBASE=[F:PTD]LINAMT               : # Mt ligne arrondi suivant devise
Endif
WBASE1 = WBASE
#----- Eléments provenant du tarif -----#
For I=1 To 9
  If GINVDTALIN(I-1)<>0
    Read [PFI] PFI0=GINVDTALIN(I-1) : If fstat Raz [F:PFI] : Endif
    #----- C'est un montant -----#
    If GDISCRGTYP(I-1)=1
         If GCLCRUL(I-1)=1 : # Par unité
           WMT1=evalue("[F:PTD]DISCRGVAL"+num$(I))*[F:PTD]QTYUOM
           If [F:PFI]NPRVLT=2 & GNPRNOTFLG(I-1)=1: WMT=WMT1: Endif
         Else              : # Par ligne
           WMT1=evalue("[F:PTD]DISCRGVAL"+num$(I))
           If [F:PFI]NPRVLT=2 & GNPRNOTFLG(I-1)=1: WMT=WMT1 : Endif
         Endif
       #----- C'est un pourcentage -----#
       Else
          WMT1=arr([F:PTD]LINAMT*evalue("[F:PTD]DISCRGVAL"+num$(I))/100,WRND)
          If  [F:PFI]NPRVLT=2 & GNPRNOTFLG(I-1)=1 : WMT=WMT1 : Endif
       Endif
      If GINCDCR(I-1)=2  WBASE1-=WMT1  Else WBASE1+=WMT1 : Endif
      If [F:PFI]NPRVLT=2 & GNPRNOTFLG(I-1)=1
        If GINCDCR(I-1)=2  WBASE-=WMT  Else WBASE+=WMT : Endif
      Endif
  Endif
Next I
#----- Eléments provenant du pied de réception -----#
For I=1 To 9
  If [F:PTH]INVDTALIN2(I-1)<>0
    Read [PFI] PFI0=[F:PTH]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
    WBASE1+=evalue("[F:PTD]DISCRGAMT"+num$(I))
    If [F:PFI]NPRVLT=2
       WBASE+=evalue("[F:PTD]DISCRGAMT"+num$(I))
    Endif
  Endif
Next I
#----- Conversion si nécessaire du montant en devise société -----#
If [F:PTH]CUR<>GLOCALDEV
  WMT=WBASE
  Call CONVERT2([F:PTH]CUR, GLOCALDEV, GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                    WMT,WBASE,STAT) From TRTDEV
  WBASE=arr(WBASE,10^-GDECPRI)
  WMT=WBASE1
  Call CONVERT2([F:PTH]CUR, GLOCALDEV, GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                    WMT,WBASE1,STAT) From TRTDEV
  WBASE1=arr(WBASE1,10^-GDECPRI)
Endif
#----- Calcul prix unitaire d'achat en devise société et par unité de stock -----#
#----- Récupération prix d'achat sur commande -----#
WPRIPUR=[F:PTD]NETPRI

WUOM  =[F:PTD]UOM
WCUR  =[F:PTH]CUR
# Issue 99358 - 2014-04-17 by SR
If [F:PTD]QTYUOM <> 0
  WCOEFF = [F:PTD]QTYSTU / [F:PTD]QTYUOM
Else
  WCOEFF = 1
Endif

#----- Conversion si nécessaire du montant en devise société -----#
If WCUR<>GLOCALDEV
  Call CONVERT2(WCUR,GLOCALDEV, GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                    WPRIPUR,WPRIPUR,STAT) From TRTDEV
  WPRIPUR=arr(WPRIPUR,10^-GDECPRI)
Endif
#----- Le prix unitaire d'achat doit être par unité de stock -----#
If WUOM<>[F:PTD]STU
  If WCOEFF=0  WCOEFF=1 : Endif
  WPRIPUR=arr(WPRIPUR/WCOEFF,10^-GDECPRI)
Else
  WPRIPUR=arr(WPRIPUR,10^-GDECPRI)
Endif

# Issue 91687 - 2013-08-06 by SR : CPRAMT vaut 0 au moment de la migration donc pas besoin de le convertir
#Call PCAL_QTY([F:PTD]QTYPUU,[F:PTD]PUU,[F:PTD]QTYSTU,[F:PTD]STU,
#&             [F:PTD]ITMREF,[F:PTH]BPSNUM,1,WUOMSTUCOE) From TRTACHQTE1
#WCPRAMT = arr([F:PTD]CPRAMT/WUOMSTUCOE,10^-GDECPRI)

#----- Calcul du prix unitaire de revient théorique en US -----#
If [F:PTD]QTYSTU<>0
  [F:PTD]CPRPRI=arr(WBASE/[F:PTD]QTYSTU,10^-GDECPRI)
Else
  [F:PTD]CPRPRI=WBASE
Endif

#----- Taxes non déductible -----#
# Issue 93448 - 2013-10-18 by MUARN : wtaxe non réinitialisé
WTAXE=[F:PTD]AMTTAXLIN1-[F:PTD]DEDTAXLIN1
WTAXE+=[F:PTD]AMTTAXLIN2-[F:PTD]DEDTAXLIN2
WTAXE+=[F:PTD]AMTTAXLIN3-[F:PTD]DEDTAXLIN3
WTAXE+=[F:PTD]AMTTAXRCP -[F:PTD]DEDTAXRCP
WTAXE+=[F:PTD]AMTTAXISS -[F:PTD]DEDTAXISS
WTAXE+=[F:PTD]AMTTAXOTH1-[F:PTD]DEDTAXOTH1
WTAXE+=[F:PTD]AMTTAXOTH2-[F:PTD]DEDTAXOTH2
If [F:PTH]CUR<>GLOCALDEV
    WMT=WTAXE
    Call CONVERT2([F:PTH]CUR, GLOCALDEV, GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                    WMT,WTAXE,STAT) From TRTDEV
      WTAXE=arr(WTAXE,10^-GDECPRI)
Endif

#----- Calcul prix de revient calculé ----#
# Issue 91687 - 2013-08-06 by SR : CPRAMT vaut 0 au moment de la migration
#[F:PTD]CPRCLC   =[F:PTD]CPRPRI-WPRIPUR+(WPRIPUR*[F:PTD]CPRCOE)+WCPRAMT
[F:PTD]CPRCLC   =[F:PTD]CPRPRI-WPRIPUR+(WPRIPUR*[F:PTD]CPRCOE)
# Issue 92825 - 2013-09-20 by SR : CPRCLC et pas CPR
If [F:PTD]QTYSTU<>0
   If GNODVATSTO = 2
    [F:PTD]CPRCLC   += (WTAXE/[F:PTD]QTYSTU)
   Endif
Endif
[F:PTD]CPRCLC   =arr([F:PTD]CPRCLC,10^-GDECPRI)


#----- Calcul cout achat, montant stock et montant achat -----#
# Issue number 92804 - 2013-09-19 by SR : Pour coût achat WPRIPUR doit être un montant
If [F:PTD]QTYUOM<>0
  WPRIPUR=[F:PTD]NETPRI*[F:PTD]QTYUOM : # Mt ligne avec précision maxi
Else
  WPRIPUR=[F:PTD]LINAMT               : # Mt ligne arrondi suivant devise
Endif

# Issue 93448 - 2013-10-11 by MUARN : conversion en devise si nécessaire
#----- Conversion si nécessaire du montant en devise société -----#
If [F:PTH]CUR<>GLOCALDEV
  Call CONVERT2([F:PTH]CUR, GLOCALDEV, GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                    WPRIPUR,WPRIPUR,STAT) From TRTDEV
  WPRIPUR=arr(WPRIPUR,10^-GDECPRI)
Endif

WBASE1 += WTAXE
# Issue 91687 - 2013-08-06 by SR : CPRAMT vaut 0 au moment de la migration
#[F:PTD]LINCSTPUR= WBASE1-WPRIPUR+(WPRIPUR*evalue([F:PTD]CPRCOE))+WCPRAMT
# Issue 91723 by TS
#[F:PTD]LINCSTPUR= WBASE1-WPRIPUR+(WPRIPUR*evalue([F:PTD]CPRCOE))
[F:PTD]LINCSTPUR= WBASE1-WPRIPUR+(WPRIPUR*[F:PTD]CPRCOE)
[F:PTD]LINCSTPUR=arr([F:PTD]LINCSTPUR,10^-GDECPRI)
If [F:PTD]QTYSTU<>0
  [F:PTD]LINAMTCPR = arr([F:PTD]CPR*[F:PTD]QTYSTU,10^-GDECPRI)
  [F:PTD]CSTPUR=arr([F:PTD]LINCSTPUR/[F:PTD]QTYSTU,10^-GDECPRI)
Else
  [F:PTD]LINAMTCPR=[F:PTD]CPR
  [F:PTD]CSTPUR   =[F:PTD]LINCSTPUR
Endif
Return

################################################
$WRITE_CAL_PTD
Raz [F:CAL]
[F:CAL]ABRFIC="PTD"
[F:CAL]VCRNUM=[F:PTD]PTHNUM
[F:CAL]VCRLIN=[F:PTD]PTDLIN
[F:CAL]ANALIG=1
For I=1 To max(GNBCOA,2)
  [F:CAL]LED(I-1)=GLEDSOC(I)
  [F:CAL]COA(I-1)=GCOA(I)
Next I
[F:CAL]ACC(0)=[F:PTDM]LINACC
[F:CAL]ACC(1)=[F:PTDM]LINCNA
For I=1 To max(GNBDIE,GOPTCANA)
  [F:CAL]DIE(I-1)=GDIE(I)
  #If evalue("dim([F:PTDM]CCE"+num$(I)+")")>0
  #  [F:CAL]CCE(I-1)=evalue("[F:PTDM]CCE"+num$(I))
  #Endif
    Case I
    When 1 : [F:CAL]CCE(I-1)=[F:PTDM]CCE1
    When 2 : [F:CAL]CCE(I-1)=[F:PTDM]CCE2
    When 3 : [F:CAL]CCE(I-1)=[F:PTDM]CCE3
    When 4 : [F:CAL]CCE(I-1)=[F:PTDM]CCE4
    When 5 : [F:CAL]CCE(I-1)=[F:PTDM]CCE5
    When 6 : [F:CAL]CCE(I-1)=[F:PTDM]CCE6
    When 7 : [F:CAL]CCE(I-1)=[F:PTDM]CCE7
    When 8 : [F:CAL]CCE(I-1)=[F:PTDM]CCE8
    When 9 : [F:CAL]CCE(I-1)=[F:PTDM]CCE9
    When Default
    Endcase
Next I
# Issue 108760 - 2015-06-16 by SR : Adaptation
#If NEWMOTEUR
#  Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
#  WriteB [F:CAL]
#Else
#  Write [F:CAL]
#Endif
#If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
#      Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File CPTANALIN PTD 0"-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Return
#Endif
Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
WriteB [F:CAL]
If fstat
   Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
   Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
GOK=0 : Return
Endif
# End issue 108760

Return


################################################
$LECT_FCYSTO
  If [F:FCY]FCY<>[F:PTD]LINSTOFCY
    Read [FCY] FCY0=[F:PTD]LINSTOFCY : If fstat  Raz [F:FCY] : Endif
  Endif
Return

##################################
$LECT_POHPTD
  If [F:POH]POHNUM<>[F:PTD]POHNUM
    WPOH=[F:PTD]POHNUM
    Gosub LECT_POH
  Endif
Return

$LECT_POH
  Read [POH] POH0=WPOH : If fstat  Raz [F:POH] : Endif
Return


##################################
$LECT_ITMPTD
  If [F:ITM]ITMREF<>[F:PTD]ITMREF
    WITM=[F:PTD]ITMREF
    Gosub LECT_ITM
  Endif
Return

$LECT_ITM
    Read [ITM] ITM0=WITM : If fstat  Raz [F:ITM] : Endif
Return

##################################
$LECT_BPAPOH
  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPOADD
    Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD : If fstat  Raz [F:BPA] : Endif
  Endif
Return
$LECT_BPAPTH
  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:PTH]BPSNUM | [F:BPA]BPAADD<>[F:BPS]BPAADD
    Read [BPA] BPA0=1;[F:PTH]BPSNUM;[F:BPS]BPAADD : If fstat  Raz [F:BPA] : Endif
  Endif
Return
$LECT_BPASTO
  If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[F:PTD]LINSTOFCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
    Read [BPA] BPA0=3;[F:PTD]LINSTOFCY;[F:FCY]BPAADD : If fstat  Raz [F:BPA] : Endif
  Endif
Return

##################################
# Traitement des bases spéciales #
##################################
$TRT_BASE
If WTAX<>""
  WJTVT=find(WTAX,WTVTVAT(0..NBTVT))
  If WJTVT>0 & WTVTVATBAS(WJTVT-1)=2 & WCLCAMT1<>0
    WCLCFLG1=1 : WCLCAMT(I)=WCLCAMT1 : WCLCFLG(I)=1
  Endif
  If WJTVT>0 & WTVTVATBAS(WJTVT-1)=3 & WCLCAMT2<>0
    WCLCFLG2=1 : WCLCAMT(I)=WCLCAMT2 : WCLCFLG(I)=1
  Endif
Endif
Return


################################################
$MAJV6_PTH
  [F:PTH]TOTAMTNOT=[F:PTH]TOTLINAMT
  #----- Calcul taxes des éléments de facturation en pied -----#
  For I=0 To NBFAC-1
    [F:PTH]TOTAMTNOT+=INVLINAMT(I)
    If INVDTAVAT(I)<>""
      #-----
      Raz TAXE : TAXE(1)=INVDTAVAT(I)
      Call CALTAXE(GSOCIETE,[F:PTD]RCPDAT,[F:PTH]VACBPR,[F:PTH]CUR,1,TAXE,1,
&                      INVLINAMT(I),MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
      DTAAMTTAX(I)=MONTANT(1)
      DTADEDTAX(I)=MONTDED(1)
      #----- Recherche si taxe déja existante -----#
      J=find(INVDTAVAT(I),TAX(0..NBTAX-1))
      If J<>0 & PURTYP(J-1)<>1
        K=find(INVDTAVAT(I),TAX(J..NBTAX-1))
        If K<>0
          J+=K
          If PURTYP(J-1)<>1
            K=find(INVDTAVAT(I),TAX(J..NBTAX-1))
            If K<>0 J+=K Else J=0 : Endif
          Endif
        Else
          J=0
        Endif
      Endif
      #----- Nouvelle taxe -----#
      If J=0
        #----- Le nombre maximum de taxe est dépassé ! (Impossible en théorie) ------#
        If NBTAX>=dim(TAX)  Goto MAJ_SUIT0 : Endif
        #-----
        J=NBTAX
        NBTAX+=1
        TAX   (J)=INVDTAVAT(I)
        PURTYP(J)=1
        WJTVT=find([L]INVDTAVAT(I),WTVTVAT(0..NBTVT))
        If WJTVT>0
          [L]VATTYP(J)=WTVTVATTYP(WJTVT-1)
        Else
          [L]VATTYP(J)=0
        Endif
      Else
        J-=1
      Endif
      #----- Mise à jour de la base et des montants de taxe -----#
      BASTAX(J)+=INVLINAMT(I)
      AMTTAX(J)+=DTAAMTTAX(I)
      DEDTAX(J)+=DTADEDTAX(I)
    Endif
$MAJ_SUIT0
  Next I

  #----- Calcul total taxes -----#
  If [F:PTH]VACTYP<>4
    [F:PTH]TOTTAXAMT=sum([L]AMTTAX)
  Else
    [F:PTH]TOTTAXAMT=0
  Endif
  [F:PTH]TOTAMTATI=[F:PTH]TOTAMTNOT+[F:PTH]TOTTAXAMT

  #----- Ecriture du tableau des éléments dans la table PVCRFOOT -----#
  Gosub WRITE_PVF
  #----- Ecriture du tableau des taxes dans la table PVCRVAT -----#
  Gosub WRITE_PVV

  #----- Chargement HT et TTC réception en devise société -----#
  Call COURMNT([F:PTH]CUR,GLOCALDEV,GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,1,
&                [F:PTH]TOTAMTNOT,[F:PTH]TOTAMTNOTL,[F:PTH]CHGCOE,STAT) From TRTDEV
  If STAT <> 0 Then
      # FGR 12/01/2010 : X3SUIVI61184
      Call ECR_TRACE("     1-File PRECEIPT"-[F:PTH]PTHNUM+", Error ="-num$(STAT),-1) From GESECRAN
  Endif
  Call COURMNT([F:PTH]CUR,GLOCALDEV,GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,1,
&                [F:PTH]TOTAMTATI,[F:PTH]TOTAMTATIL,[F:PTH]CHGCOE,STAT) From TRTDEV
  If STAT <> 0 Then
      # FGR 12/01/2010 : X3SUIVI61184
      Call ECR_TRACE("     2-File PRECEIPT"-[F:PTH]PTHNUM+", Error ="-num$(STAT),-1) From GESECRAN
  Endif

Return
################################################
$MAJV7_PTH
Return

# Issue X3-102110 - 2018-08-31 by SR : Resynchronisation des montants entête si besoin
################################################
$MAJV12_PTH
# si les montants entête ne sont pas renseignés (pb corrigé par JIRA X3-38669)
If[F:PTH]TOTAMTNOT = 0
  # Issue X3-108336 - 2018-09-11 by SR : WTOTTAXAMT instead of WTATTAXAMT
  Raz WINVDTAAMT, WAMTTAX, WTOTAMTNOT, WTOTAMTNOTL, WTOTAMTATI, WTOTAMTATIL, WTOTTAXAMT
  For [PVF]PVF0  Where  VCRNUM=[F:PTH]PTHNUM & VCRTYP = 6
     WINVDTAAMT += [PVF]INVDTAAMT
  Next
  For [PVV]PVV0  Where VCRNUM=[F:PTH]PTHNUM & VCRTYP = 6
     WAMTTAX += [PVV]AMTTAX
  Next
  WTOTAMTNOT=WINVDTAAMT+[F:PTH]TOTLINAMT
  If [F:PTH]VACTYP<>4
      WTOTTAXAMT=WAMTTAX
      WTOTAMTATI=WINVDTAAMT+[F:PTH]TOTLINAMT+WAMTTAX
  Else
      WTOTTAXAMT=0
      WTOTAMTATI=WINVDTAAMT+[F:PTH]TOTLINAMT
  Endif
  Raz STAT
  Call COURMNT([F:PTH]CUR,GLOCALDEV,GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,1,
&            WTOTAMTNOT,WTOTAMTNOTL,[F:PTH]CHGCOE,STAT) From TRTDEV
  If STAT <> 0
    Call ECR_TRACE("     3-File PRECEIPT"-[F:PTH]PTHNUM+", Error ="-num$(STAT),-1) From GESECRAN
  Endif
  Raz STAT
  Call COURMNT([F:PTH]CUR,GLOCALDEV,GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,1,
&            WTOTAMTATI,WTOTAMTATIL,[F:PTH]CHGCOE,STAT) From TRTDEV
  If STAT <> 0
    Call ECR_TRACE("     4-File PRECEIPT"-[F:PTH]PTHNUM+", Error ="-num$(STAT),-1) From GESECRAN
  Endif
  #-----
  [F:PTH]TOTAMTNOT=WTOTAMTNOT
  [F:PTH]TOTAMTNOTL=WTOTAMTNOTL
  [F:PTH]TOTAMTATI=WTOTAMTATI
  [F:PTH]TOTAMTATIL=WTOTAMTATIL
  [F:PTH]TOTTAXAMT=WTOTTAXAMT
Endif
Return
# End issue X3-102110

################################################
$WRITE_PVF
  Raz [F:PVF]
  [F:PVF]VCRTYP=6
  [F:PVF]VCRNUM=[F:PTH]PTHNUM
  [F:PVF]PTHNUM=[F:PTH]PTHNUM
  [F:PVF]CREDAT=date$
  [F:PVF]CREUSR=GUSER
  For I=0 To NBFAC-1
    WJ=find([L]INVDTA(I),WPFINUM(0..WNBPFI))
    Gosub RECUP_PFI From UUMGTRTPUR00
    [F:PVF]INVDTA   =[L]INVDTA(I)
    [F:PVF]INVDTAAMT=[L]INVLINAMT(I)
    [F:PVF]INVLINAMT=[L]INVLINAMT(I)
    [F:PVF]INVDTAFLG=1
    [F:PVF]INVLINFLG=6
    [F:PVF]INVORDFLG=[F:PFI]DACORD
    [F:PVF]DEBCDT   =[L]DEBCDT(I)
    [F:PVF]INVDTAVAT=[L]INVDTAVAT(I)
    [F:PVF]DTAAMTTAX=[L]DTAAMTTAX(I)
    [F:PVF]DTADEDTAX=[L]DTADEDTAX(I)
    [F:PVF]AMTCOD   =2
    [F:PVF]CLCORD   =[F:PFI]CLCORD
    [F:PVF]CLCBAS   =[F:PFI]CLCBAS
    [F:PVF]IND=I+1

    # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#    If NEWMOTEUR
#        Gosub PVF_STK From UUMGTRTPUR00 : # pour stocker ref
#        WriteB [F:PVF]
#    Else
#        Write [F:PVF]
#    Endif
#    If fstat
#      If NEWMOTEUR & adxwrb>1
#        Call ECR_TRACE("File PVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
#        Gosub PVF_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
#      Else
#        Call ECR_TRACE("File PVCRFOOT 6"-[F:PTH]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
#      Endif
#      GOK=0 : Break
#    Endif
    Gosub PVF_STK From UUMGTRTPUR00 : # pour stocker ref
    WriteB [F:PVF]
    If fstat
       Call ECR_TRACE("File PVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
       Gosub PVF_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
       GOK=0 : Break
    Endif
    # End issue 108760
  Next I
Return
################################################
$WRITE_PVV
  Raz [F:PVV]
  [F:PVV]VCRTYP=6
  [F:PVV]VCRNUM=[F:PTH]PTHNUM
  [F:PVV]PTHNUM=[F:PTH]PTHNUM
  [F:PVV]CREDAT=date$
  [F:PVV]CREUSR=GUSER
  For I=0 To [L]NBTAX-1
    [F:PVV]TAX   =[L]TAX(I)
    [F:PVV]BASTAX=[L]BASTAX(I)
    [F:PVV]AMTTAX=[L]AMTTAX(I)
    [F:PVV]DEDTAX=[L]DEDTAX(I)
    [F:PVV]PURTYP=[L]PURTYP(I)
    [F:PVV]VATTYP=[L]VATTYP(I)
    #----- Chargement des taux de taxe -----#
    Filter [TRA] Where CPY=[F:PTH]CPY & VAT=[F:PVV]TAX & STRDAT<=[F:PTH]RCPDAT
    Read [TRA] TRA0 Last
    If fstat>2
      Filter [TRA] Where CPY="" & VAT=[F:PVV]TAX & STRDAT<=[F:PTH]RCPDAT
      Read [TRA]TRA0 Last
      If fstat>2  Raz [F:TRA] : Endif
    Endif
    [F:PVV]VATRAT=[F:TRA]VATRAT
    [F:PVV]DEDRAT=[F:TRA]DEDRAT
    #-----
    [F:PVV]IND=I+1

    # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#    If NEWMOTEUR
#        Gosub PVV_STK From UUMGTRTPUR00 : # pour stocker ref
#        WriteB [F:PVV]
#    Else
#        Write [F:PVV]
#    Endif
#    If fstat
#      If NEWMOTEUR & adxwrb>1
#        Call ECR_TRACE("File PVCRVAT, Error ="-num$(fstat),1) From GESECRAN
#        Gosub PVV_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
#      Else
#        Call ECR_TRACE("File PVCRVAT 6"-[F:PTH]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
#      Endif
#      GOK=0 : Break
#    Endif
     Gosub PVV_STK From UUMGTRTPUR00 : # pour stocker ref
     WriteB [F:PVV]
     If fstat
        Call ECR_TRACE("File PVCRVAT, Error ="-num$(fstat),1) From GESECRAN
        Gosub PVV_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
        GOK=0 : Break
    Endif
    # End issue 108760
  Next I
Return
################################################
$PTH_STK
Call STK (WTAB_PTH,WCPT_PTH,[F:PTH]PTHNUM) From TRTMIG
Return
$PTD_STK
Call STK (WTAB_PTD,WCPT_PTD,[F:PTD]PTHNUM-'/'-num$([F:PTD]PTDLIN)) From TRTMIG
Return
##############################################################################################
$PTH_ERRTRA
Call ERRTRA (WTAB_PTH,WCPT_PTH,"File PRECEIPT(PTHNUM)=") From TRTMIG
Return
$PTD_ERRTRA
Call ERRTRA (WTAB_PTD,WCPT_PTD,"File PRECEIPTD(PTHNUM/PTDLIN)=") From TRTMIG
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTPUR06(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTPUR06(APPLI)
End

