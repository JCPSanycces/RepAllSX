#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UUMGTRTPUR06   Migration des Réceptions                   Module Achats#
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR06") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR06(DOSSIER)
  Call MAJ_UUMGTRTPUR06(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTPUR06(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif
Local Char WNAMPTHM,WNAMPTDM
Call MIGTABNAME (DOSSIER,"PRECEIPT",WNAMPTHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PRECEIPTD",WNAMPTDM,ERR) From TRTMIG

If ERR
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPTHM,"fde",DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMPTDM,"fde",DOSSIER),0) < 0
  End
Endif

##2 - On vide les fichiers selon le cas
#######################################
Call MIGTABRAZ (DOSSIER,"PRECEIPT",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"PRECEIPTD",ERR) From TRTMIG

# Issue 101446 - 2014-07-11 by MUARN : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR06",7,ERR) From TRTMIG : #7=Erreur
  End
Endif
If val(VERSION)<GMIGX3VER60
  Local File =DOSSIER+".CPTANALIN"  [CAL]
  Trbegin [CAL]
  Delete [CAL] Where ABRFIC="PTD"
  Commit

  Local File =DOSSIER+".PVCRVAT"    [PVV]
  Trbegin [PVV]
  Delete [PVV] Where VCRTYP=6
  Commit

  Local File =DOSSIER+".PVCRFOOT"   [PVF]
  Trbegin [PVF]
  Delete [PVF] Where VCRTYP=6
  Commit
Endif

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR06",ERR) From TRTMIG

End

##########################################################################
Subprog MAJ_UUMGTRTPUR06(DOSSIER)
Value Char DOSSIER

# Issue 108760 - 2015-06-12 by SR : adaptation
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

# Issue 91782 - 2013-08-09 by SR
# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR06",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMPTHM,WNAMPTDM
Call MIGTABNAME (DOSSIER,"PRECEIPT",WNAMPTHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PRECEIPTD",WNAMPTDM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR06",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPTHM,"fde",DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPTDM,"fde",DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR06",2,ERR) From TRTMIG : #2=En cours
# Issue 108857 - 2015-06-15 by SR : Déplacé avant définition des variables qui utilisent adxwrb
Gosub MIG_OUVRE From TRTMIG

###################
Local Char WTAB_PTH (100) (adxwrb)
Local Char WTAB_PTD (100) (adxwrb)
Local Char WTAB_CAL (100) (adxwrb)
Local Char WTAB_PVV (100) (adxwrb)
Local Char WTAB_PVF (100) (adxwrb)
Local Shortint WCPT_PTH,WCPT_PTD,WCPT_CAL,WCPT_PVV,WCPT_PVF

Call ECR_TIME("UUMGTRTPUR06 Purchase Receipts Process : Update PRECEIPT-D") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR06 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#

Call MIGTABINIT (DOSSIER,"PRECEIPT",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"PRECEIPTD",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABINIT (DOSSIER,"CPTANALIN",ERR) From TRTMIG
#Call MIGTABINIT (DOSSIER,"PVCRVAT",ERR) From TRTMIG
#Call MIGTABINIT (DOSSIER,"PVCRFOOT",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:PTH])  = 0 : Local File =DOSSIER+".PRECEIPT"    [PTH]  : Endif   # Fichier X3 "Vide"
If clalev([F:PTD])  = 0 : Local File =DOSSIER+".PRECEIPTD"    [PTD]  : Endif   # Fichier X3 "Vide"

If clalev([F:PTHM]) = 0 : Local File =DOSSIER+"."+WNAMPTHM   [PTHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:PTDM]) = 0 : Local File =DOSSIER+"."+WNAMPTDM   [PTDM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

Gosub OUVRE_PUR From UUMGTRTPUR00
Gosub OUVRE_PUR04

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR06",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
Link [PTDM] With [PTHM]PTH0~=[F:PTDM]PTHNUM, [ITM]ITM0=[F:PTDM]ITMREF
&    As [LNK]
&    Order By Key CLE = [F:PTHM]PRHFCY;[F:PTHM]PTHNUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR06" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_PTH00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:PTHM]PRHFCY=TABMIGKEY(1) & [F:PTHM]PTHNUM>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:PTHM]PRHFCY>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [PTH],[PTD]
GOK = 1

For [LNK]CLE(2) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR06" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

#  version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
    Gosub RAZV6_PTH
  Endif
  # Issue 88474 - 2013-05-07 by SR
  #  version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
    Gosub RAZV7_PTH
  Endif

  [F:PTH] = [F:PTHM]

  If WSITE<>[F:PTH]PRHFCY
    #----- Alimentation de la société sur l'entête de demande d'achat -----#
      Call RECUP_GLOBAL_CPT(DOSSIER,[F:PTH]PRHFCY) From TRTX3CPT
      WSITE=[F:PTH]PRHFCY
  Endif

  #Appel proc de migration sur entete
  #  version < V6, traitement v6
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_AVPTH
  Endif
  # Issue 88474 - 2013-05-07 by SR
  #  version < V7, traitement v7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_AVPTH
  Endif
  If GOK<1 : Break : Endif


  ############################
  #-- Boucle sur les lignes
  ############################
  For [LNK]CLE
    #rupture par ligne de réception
    #  version < V6, raz des champs v6
    If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_PTD
    Endif
    # Issue 88474 - 2013-05-07 by SR
    #  version < V7, raz des champs v7
    If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_PTD
    Endif
    # Issue 112754 - 2016-12-19 by SR : Services en V12
    #  version < V12, raz des champs v12
    If val(VERSION)<GMIGX3VER120
      Gosub RAZV12_PTD
    Endif
    [F:PTD] = [F:PTDM]

    #Appel proc de migration sur detail
    #  version < V6, traitement v6
    If val(VERSION)<GMIGX3VER60
      Gosub MAJV6_PTD
      If GOK<1 : Break : Endif
    Endif
    # Issue 88474 - 2013-05-07 by SR
    #  version < V7, traitement v7
    If val(VERSION)<GMIGX3VER70
      Gosub MAJV7_PTD
      If GOK<1 : Break : Endif
    Endif
    # Issue 112754 - 2016-12-19 by SR : Services en V12
    #  version < V12, traitement v12
    If val(VERSION)<GMIGX3VER120
       Gosub MAJV12_PTD
       If GOK<1 : Break : Endif
    Endif
   # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#    If NEWMOTEUR
#        Gosub PTD_STK : # pour stocker ref
#        WriteB [PTD]
#    Else
#        Write [PTD]
#    Endif
#    If fstat
#        If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File PRECEIPTD, Error ="-num$(fstat),1) From GESECRAN
#          Gosub PTD_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File PRECEIPTD(PTHNUM/PTDLIN)"-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Break
#    Endif
     Gosub PTD_STK : # pour stocker ref
     WriteB [PTD]
     If fstat
        Call ECR_TRACE("File PRECEIPTD, Error ="-num$(fstat),1) From GESECRAN
        Gosub PTD_ERRTRA : # pour afficher les ref
        GOK=0 : Break
     Endif
     # End issue 108760
  Next
  If GOK<1 : Break : Endif

  #Appel proc de migration sur entete
  #  version < V6, traitement v6
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_PTH
    If GOK<1 : Break : Endif
  Endif
  # Issue 88474 - 2013-05-07 by SR
  #  version < V7, traitement v7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_PTH
    If GOK<1 : Break : Endif
  Endif
  # Issue X3-102110 - 2018-08-31 by SR
  #  version < V12, traitement v12
  If val(VERSION)<GMIGX3VER120
    Gosub MAJV12_PTH
  Endif
  # --- alimentation des champs et écriture enreg
  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
  # --- alimentation des champs et écriture enreg
#  If NEWMOTEUR
#      Gosub PTH_STK : # pour stocker ref
#      WriteB [F:PTH]
#  Else
#      Write [F:PTH]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File PRECEIPT, Error ="-num$(fstat),1) From GESECRAN
#      Gosub PTH_ERRTRA : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File PRECEIPT(PTHNUM)"-[F:PTH]PTHNUM+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
  Gosub PTH_STK : # pour stocker ref
  WriteB [F:PTH]
  If fstat
     Call ECR_TRACE("File PRECEIPT, Error ="-num$(fstat),1) From GESECRAN
     Gosub PTH_ERRTRA : # pour afficher les ref
     GOK=0 : Break
  Endif
  # End issue 108760

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:PTHM]PRHFCY
    TABMIGKEY(2) = [F:PTHM]PTHNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR06",7,ERR) From TRTMIG : #7=Erreur
Else
  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:PTH]
    If fstat
        Call ECR_TRACE("File PRECEIPT, Error ="-num$(fstat),1) From GESECRAN
        Gosub PTH_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:PTD]
    If fstat
        Call ECR_TRACE("File PRECEIPTD, Error ="-num$(fstat),1) From GESECRAN
        Gosub PTD_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:PVV]
    If fstat
        Call ECR_TRACE("File PVCRVAT, Error ="-num$(fstat),1) From GESECRAN
        Gosub PVV_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:PVF]
    If fstat
        Call ECR_TRACE("File PVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
        Gosub PVF_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
 # Endif
 # End issue 108760
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR06",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR06",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_PTH00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [PTH], [PTD]
Close Local File [PTHM], [PTDM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"PRECEIPT",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"PRECEIPTD",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABEND (DOSSIER,"CPTANALIN",ERR) From TRTMIG
#Call MIGTABEND (DOSSIER,"PVCRVAT",ERR) From TRTMIG
#Call MIGTABEND (DOSSIER,"PVCRFOOT",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTPUR06") From TRTMIG
Call ECR_TIME("UUMGTRTPUR06 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


################################################
$OUVRE_PUR04
Local File =DOSSIER+".PORDER"     [POH]

Local Char WBPS(GLONBPS),WBPR(GLONBPR),WPOH(GLONVCR),WITM(GLONITM)

#----- Variables locales pour calcul TVA -----#
Local Decimal  WCLCAMT1, WCLCAMT2, WCLCAMT(1..7)
Local Libelle  WCLCFLG1, WCLCFLG2, WCLCFLG(1..7)
Local Decimal  WBASE, WAMTTAX, WDEDTAX
Local Char     WTAX(GLONVAT)

#----- Tableau des taxes en mémoire (20 maxi) -----#
Local Integer  NBTAX
Local Char     TAX(GLONVAT)(20)
Local Decimal  BASTAX(20)
Local Decimal  AMTTAX(20)
Local Decimal  DEDTAX(20)
Local Libelle  PURTYP(20)
Local Libelle  VATTYP(20)
#----- Tableau des éléments de facturation en mémoire (10 maxi) -----#
Local Integer  NBFAC
Local Integer  INVDTA(10)
Local Decimal  INVLINAMT(10)
Local Libelle  DEBCDT(10)
Local Char     INVDTAVAT(GLONVAT)(10)
Local Decimal  DTAAMTTAX(10)
Local Decimal  DTADEDTAX(10)

# Issue 88474 - 2013-05-06 by SR
Local Char WDSPVOU(GLONUOM),WDSPWEU(GLONUOM)
Local   Decimal  WPRIPUR
Local   Decimal  WBASE, WMT, WRND, WTAXE, WMT1, WBASE1
Local   Integer  STAT, I, J
Local    Char    WUOM(GLONUOM)
Local    Char    WCUR(GLONCUR)
# Issue 91653 - 2013-08-05 by SR
# Issue 91687 - 2013-08-06 by SR : CPRAMT vaut 0 au moment de la migration donc pas besoin de le convertir
#Local    Decimal WCOEFF, WCPRAMT, WUOMSTUCOE
Local    Decimal WCOEFF
# Issue X3-102110 - 2018-08-31 by SR
Local Decimal  WINVDTAAMT, WTOTAMTNOT, WTOTAMTNOTL, WTOTAMTATI,WTOTAMTATIL, WTOTTAXAMT

Local Integer LACTPTX : LACTPTX=func AFNC.ACTIV("PTX")
Return

