#<AdxTL>@(#)3.0.0.0 $Revision$
##################################################################
# Outils utilisés dans les traitements CNSPIVSTD et CNSPIASTD
# pour la traçabilité des pièces de ventes et des pièces d'achats
#
# La variable local PROGSTD doit être déclarée et renseignée dans
# le traitement appelant
##################################################################
##################################################################
$AUTORIS
Return

############################################################
$EXEBOUT
  Case BOUT
    When "B"
      OK = 2
  Endcase
Return

############################################################
$TRT_NIVEAUX_AMONT
Local Char VCRNUM_S(GLONVCR)
Local Integer VCRTYP_S                           # VPO 11/02/11 71269
Local Char VCRNUMORI_S(GLONVCR)                  # FGR 07/12/2012 : X3SUIVI86461
Local Integer VCRTYPORI_S                        # FGR 07/12/2012 : X3SUIVI86461
Local Integer VCRLINORI_S                        # FGR 07/12/2012 : X3SUIVI86461

  For INIV = 1 To LEVMAX-1
    Call TEMPON(mess(58,187,1)-num$(INIV+1)) From GESECRAN
    WK = 0
    Filter [PKW] Where PRONUM = GCNSPIXUUID & LEVNUM =INIV Order By Key SKW0
    VCRNUM_S = ""
    VCRTYP_S = 0                                 # FGR 07/12/2012 : X3SUIVI86461
    VCRNUMORI_S = ""                             # FGR 07/12/2012 : X3SUIVI86461
    VCRTYPORI_S = 0                              # FGR 07/12/2012 : X3SUIVI86461
    VCRLINORI_S = 0                              # FGR 07/12/2012 : X3SUIVI86461
    For [PKW]
      #If VCRNUM_S <> [F:PKW]VCRNUM or VCRTYP_S <> [F:PKW]VCRTYP Then
      If VCRNUM_S <> [F:PKW]VCRNUM or VCRTYP_S <> [F:PKW]VCRTYP
&       or VCRTYPORI_S <> [F:PKW]VCRTYPORI or VCRNUMORI_S <> [F:PKW]VCRNUMORI or VCRLINORI_S <> [F:PKW]VCRLINORI
&     Then
        VCRNUM_S = [F:PKW]VCRNUM
        VCRTYP_S = [F:PKW]VCRTYP                 # VPO 11/02/11 71269
        VCRTYPORI_S = [F:PKW]VCRTYPORI           # FGR 07/12/2012 : X3SUIVI86461
        VCRLINORI_S = [F:PKW]VCRLINORI           # FGR 07/12/2012 : X3SUIVI86461
        VCRNUMORI_S = [F:PKW]VCRNUMORI           # FGR 07/12/2012 : X3SUIVI86461
        # ----------------------------
        WLEV = [F:PKW]LEV
        Gosub ENTREE_OF_AMONT From =PROGSTD
      Endif
    Next
    Filter [PKW]
    # Test traitement long
    VS = 2
    If time-WTIMD > WTIMO Then
      Call AVERTIR(mess(205,100,1),VS) From GESECRAN
      If VS = 1 Then
        WK = 0
      Else
        WTIMD = time
      Endif
    Endif
    If WK = 0 Then
      Break
    Endif
  Next INIV
  Call TEMPOFF From GESECRAN
Return

