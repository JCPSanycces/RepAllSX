############################################################
$FERME
  If clalev([F:PKW]) Then : Filter [PKW] : Endif  # FGR 17/03/2014 : X3SUIVI97889 : peut ne pas être ouvert
  If dim(WGCONSULT) > 0 Then
    GCONSULT = WGCONSULT
  Endif
  # Effacement anciens traitements
  Gosub DEL_ALL_WRK
  #
  Gosub KILL_GLOBALES From =PROGSTD
  # Raz de GSOCIETE
  Raz GSOCIETE
Return

############################################################
# Paramètres pour LOA_PAGE
# WINC      : Increment sur NOL et nolign
# WREAD = 0 : Read first
#         1 : Read next
#         2 : Read last
#         3 : read prev
# WSKIP     : Nombre de relectures avant / arrière
#
$CHARGE_PAG
  If WREAD = 0 or CHGPAG = 1 Then
    nolign = 1
    WREAD  = 0
    WINCR  = 1
    SUITE  = 0
    RETOUR = 0
    Gosub LOA_PAGE
  Else
    Case CHGPAG
      When 2
        If WINCR = -1 Then
          WSKIP = WLIG
        Else
          WSKIP = 0
        Endif
        nolign = 1
        WREAD  = 1
        WINCR  = 1
        Gosub LOA_PAGE
        RETOUR = 0
      When -1
        nolign = MAXLIG
        WREAD  = 2
        WINCR  = -1
        WSKIP  = 0
        Gosub LOA_PAGE
        RETOUR = 0
        SUITE  = 1
      When -2
        If WINCR = 1 Then
          WSKIP = WLIG
        Else
          WSKIP = 0
        Endif
        nolign = MAXLIG
        WINCR  = -1
        WREAD  = 3
        Gosub LOA_PAGE
        SUITE  = 0
    Endcase
  Endif
Return

############################################################
$LOA_PAGE
  NBLU = 2
  WLIG = 0
  If WSKIP <> 0 Then
    If WSKIP < 0 Then
      While WSKIP <> -1
        Read [PKW]Next
        If fstat Then
          Break
        Endif
        WSKIP += 1
      Wend
    Else
      While WSKIP <> 1
        Read [PKW]Prev
        If fstat Then
          Break
        Endif
        WSKIP -= 1
      Wend
    Endif
  Endif
  # Test tableau plein
  $LOA_PAGE1
  If  nolign > MAXLIG or nolign < 1 Then
    Goto LOA_PAGE_FIN
  Endif
  # Choix lecture
  Case WREAD
    When 0
      WREAD = 1
      Read [PKW]First
      If fstat = 0 Then
        WFIRLEV = [F:PKW]LEV
      Else
        WFIRLEV = ""
        SUITE   = 1
        RETOUR  = 1
        Goto LOA_PAGE_FIN
      Endif
    When 1
      Read [PKW]Next
      If fstat Then
        SUITE = 1
        Goto LOA_PAGE_FIN
      Endif
    When 2
      WREAD = 3
      Read [PKW]Last
    When 3
      Read [PKW]Prev
      If fstat Then
        RETOUR = 1
        Goto LOA_PAGE_FIN
      Endif
  Endcase
  # Test fin lecture
  Gosub LOA_LIGNE From =PROGSTD
  nolign += WINCR
  NOL    += WINCR
  WLIG   += WINCR
  If [F:PKW]LEV = WFIRLEV Then
    RETOUR = 1
  Endif
  Goto LOA_PAGE1
  #
$LOA_PAGE_FIN
  Gosub LOA_PAGE_FIN From =PROGSTD
Return

############################################################
$PLUS_UN
  WADD = val(mid$(WLEV,(INIV*4)+1,4))
  WADD += 1
  WLEV = left$(WLEV,INIV*4)+format$("N0:4",WADD)+right$(WLEV,((INIV+1)*4)+1)
Return

############################################################
$CALC_MNT
  # Issue 83475 - 2012-07-23 by MUARN : tracabilité piece achat conversion devise
  # la devise société est connue dans le module achat, il y avait double conversion de devise
  # separation en 2 sous programmes pour ne lancer que la conversion devise dossier sur achats
  Gosub CALC_MNT_SOC
  Gosub CALC_MNT_FOLDER
Return

############################################################
$CALC_MNT_SOC
  If !clalev([F:TCU]) Then Local File TABCUR [TCU] Endif
  # Calcul des montants en devise société
  If CURS <> GLOCALDEV Then
    Call CONVERT2(CURS, GLOCALDEV, GLOCALDEV, WCHGTYP, datesyst, WMNTORG(0), WMNTDES(0), SPSTAT) From TRTDEV
    Call CONVERT2(CURS, GLOCALDEV, GLOCALDEV, WCHGTYP, datesyst, WMNTORG(1), WMNTDES(1), SPSTAT) From TRTDEV
    If [F:TCU]CUR <> GLOCALDEV Then
      Read [F:TCU]TCU0=GLOCALDEV
      If fstat Then
        Raz [F:TCU]
      Endif
    Endif
    ORDNOTL_T  = arr(WMNTDES(0),[F:TCU]CURRND)
    ORDATIL_T  = arr(WMNTDES(1),[F:TCU]CURRND)
  Else
    ORDNOTL_T  = WMNTORG(0)
    ORDATIL_T  = WMNTORG(1)
  Endif
Return

############################################################
$CALC_MNT_FOLDER
  If !clalev([F:TCU]) Then Local File TABCUR [TCU] Endif
  # Calcul des montants en devise dossier
  If CURS <> GSYSCUR Then
    If GLOCALDEV <> GSYSCUR Then
      Call CONVERT2(CURS, GSYSCUR, GLOCALDEV, WCHGTYP, datesyst, ORDNOT_T, WMNTDES(0),SPSTAT) From TRTDEV
      Call CONVERT2(CURS, GSYSCUR, GLOCALDEV, WCHGTYP, datesyst, ORDATI_T, WMNTDES(1),SPSTAT) From TRTDEV
      If [F:TCU]CUR <> GSYSCUR Then
        Read [F:TCU]TCU0=GSYSCUR
        If fstat Then
          Raz [F:TCU]
        Endif
      Endif
      ORDNOTD_T  = arr(WMNTDES(0),[F:TCU]CURRND)
      ORDATID_T  = arr(WMNTDES(1),[F:TCU]CURRND)
    Else
      ORDNOTD_T = WMNTORG(0)
      ORDATID_T = WMNTORG(1)
    Endif
  Else
    ORDNOTD_T  = ORDNOT_T
    ORDATID_T  = ORDATI_T
  Endif
Return

############################################################
$DEL_ALL_WRK
  If clalev([F:PKW]) Then  # FGR 17/03/2014 : X3SUIVI97889 : peut ne pas être ouvert
    Trbegin [PKW]
    Delete [PKW] Where PROUID = adxuid(1)
    If fstat Then
      Call FSTA("PKW") From GLOCK
      Rollback
    Else
      Commit
    Endif
  Endif
Return

############################################################
$DEL_WRK
  If clalev([F:PKW]) Then  # FGR 17/03/2014 : X3SUIVI97889 : peut ne pas être ouvert
    Trbegin [PKW]
    Delete [PKW] Where PRONUM = GCNSPIXUUID
    If fstat Then
      Call FSTA("PKW") From GLOCK
      Rollback
    Else
      Commit
    Endif
  Endif
Return

############################################################
$DECLARE_VAR
Local Char     VCRNUM_T(GLONVCR*2), VCRNUMCALC_T(GLONVCR*2), VCRNUMORI_T(GLONVCR*2)
Local Char     SALFCY_T(GLONFCY), STOFCY_T(GLONFCY)
Local Char     BPRNUM_T(GLONBPR)
Local Char     JOU_T(GLONJOU), REP1_T(GLONREP), REP2_T(GLONREP)
Local Integer  ACCNUM_T,DUDLIG_T
Local Integer  VCRTYP_T, VCRTYPORI_T, VCRLIN_T, VCRLINORI_T
Local Char     STA_T
Local Decimal  ORDNOT_T, ORDATI_T, ORDNOTL_T, ORDATIL_T, ORDNOTD_T, ORDATID_T
Local Date     IPTDAT_T
Local Decimal  WMNTORG(0..5), WMNTDES(0..5)
Local Integer  SPSTAT, WCHGTYP
Local Char     STBVCRSTAT(GLONDCO)(0..4)          # FGR 20/01/2012 : X3SUIVI71278 FGR 03/02/2012 : X3SUIVI71269
Local Char     SCURVCR_T(GLONCUR)                 # FGR 20/01/2012 : X3SUIVI71278 FGR 03/02/2012 : X3SUIVI71269
Local Char     SCONTEXTE(GLONAOB)                 # FGR 07/02/2012 ! X3SUIVI71269

  Raz ACCNUM_T
  Raz DUDLIG_T
  Raz WMNTORG
  Raz WMNTDES
  Raz STBVCRSTAT
  Raz SCONTEXTE
Return

############################################################
$WRITE_PKW1
Local Integer WL

  If !clalev([F:PKWT]) Then Local File PIWRK [PKWT] Endif
  # ---------------------------
  [F:PKW1]VCRNUM     = VCRNUM_T
  [F:PKW1]VCRTYP     = VCRTYP_T
  [F:PKW1]VCRLIN     = VCRLIN_T
  [F:PKW1]VCRNUMCALC = VCRNUMCALC_T
  [F:PKW1]VCRNUMORI  = VCRNUMORI_T
  [F:PKW1]VCRLINORI  = VCRLINORI_T
  [F:PKW1]VCRTYPORI  = VCRTYPORI_T
  [F:PKW1]IPTDAT     = IPTDAT_T
  [F:PKW1]SALFCY     = SALFCY_T
  [F:PKW1]STOFCY     = STOFCY_T
  [F:PKW1]BPRNUM     = BPRNUM_T
  [F:PKW1]JOU        = JOU_T

  # FGR 20/01/2012 : X3SUIVI71278 (début)
  [F:PKW1]VCRSTAT1   = STBVCRSTAT(1)
  [F:PKW1]VCRSTAT2   = STBVCRSTAT(2)
  [F:PKW1]VCRSTAT3   = STBVCRSTAT(3)
  [F:PKW1]VCRSTAT4   = STBVCRSTAT(4)
  [F:PKW1]CURVCR     = SCURVCR_T
  # FGR 20/01/2012 : X3SUIVI71278 (fin)

  [F:PKW1]ACCNUM     = ACCNUM_T
  [F:PKW1]DUDLIG     = DUDLIG_T

  [F:PKW1]REP1       = REP1_T
  [F:PKW1]REP2       = REP2_T

  [F:PKW1]ORDNOT     = ORDNOT_T
  [F:PKW1]ORDATI     = ORDATI_T
  [F:PKW1]ORDNOTL    = ORDNOTL_T
  [F:PKW1]ORDATIL    = ORDATIL_T
  [F:PKW1]ORDNOTD    = ORDNOTD_T
  [F:PKW1]ORDATID    = ORDATID_T

  [F:PKW1]PRONUM     = GCNSPIXUUID
  [F:PKW1]PROUID     = adxuid(1)
  [F:PKW1]LEVNUM     = INIV + 1
  Gosub PLUS_UN
  [F:PKW1]LEV        = WLEV
  [F:PKW1]LEVALP     = ""
  For WL = 0 To dim(TLEV)-1
    If mid$([F:PKW1]LEV,(WL*4)+1,4) = "0000"
      Break
    Endif
  Next WL
  [F:PKW1]LEVALP     = string$(WL-1,"_")+num$(WL)
  [F:PKW1]CREUSR     = GUSER
  [F:PKW1]CREDAT     = date$
  #
  Read [F:PKWT]SKW0=[F:PKW1]PRONUM;[F:PKW1]LEV
  # On ne fait le write que si l'enregistrement n'existe pas déjà
  If fstat Then
    Write [PKW1]
  Endif
  If fstat Then
    GCOMMIT = G_NON
  Endif
Return

############################################################
$WRITE_PKW
  [F:PKW]VCRNUM     = VCRNUM_T
  [F:PKW]VCRTYP     = VCRTYP_T
  [F:PKW]VCRLIN     = VCRLIN_T
  [F:PKW]VCRNUMCALC = VCRNUMCALC_T
  [F:PKW]VCRNUMORI  = VCRNUMORI_T
  [F:PKW]VCRTYPORI  = VCRTYPORI_T
  [F:PKW]IPTDAT     = IPTDAT_T
  [F:PKW]SALFCY     = SALFCY_T
  [F:PKW]STOFCY     = STOFCY_T
  [F:PKW]BPRNUM     = BPRNUM_T
  [F:PKW]REP1       = REP1_T
  [F:PKW]REP2       = REP2_T
  [F:PKW]JOU        = JOU_T
  [F:PKW]ACCNUM     = ACCNUM_T
  [F:PKW]DUDLIG     = DUDLIG_T

  # FGR 03/02/2012 : X3SUIVI71269 (début)
  [F:PKW]VCRSTAT1   = STBVCRSTAT(1)
  [F:PKW]VCRSTAT2   = STBVCRSTAT(2)
  [F:PKW]VCRSTAT3   = STBVCRSTAT(3)
  [F:PKW]VCRSTAT4   = STBVCRSTAT(4)
  [F:PKW]CURVCR     = SCURVCR_T
  # FGR 03/02/2012 : X3SUIVI71269 (fin)

  [F:PKW]ORDNOT     = ORDNOT_T
  [F:PKW]ORDATI     = ORDATI_T
  [F:PKW]ORDNOTL    = ORDNOTL_T
  [F:PKW]ORDATIL    = ORDATIL_T
  [F:PKW]ORDNOTD    = ORDNOTD_T
  [F:PKW]ORDATID    = ORDATID_T

  [F:PKW]PRONUM     = GCNSPIXUUID
  [F:PKW]PROUID     = adxuid(1)
  [F:PKW]SEL        = mess(ITRKSEL,334,1)
  [F:PKW]LEVNUM     = WNIV
  [F:PKW]LEVALP     = "1"
  For WI = 1 To dim(TLEV)
    [F:PKW]LEV += format$("N0:4",TLEV(WI))
  Next WI
  TLEV(WNIV) += 1
  [F:PKW]CREUSR     = GUSER
  [F:PKW]CREDAT     = date$
  Write [PKW]
  If fstat Then
    Call FSTA("PKW") From GLOCK
  Endif
Return

############################################################
Subprog DISPLAY_TIERS(SMSK, PROGSTD)
Value Char SMSK
Value Char PROGSTD

  Gosub DECLARE_VAR From =PROGSTD
  If SMSK = "PIV1" Then
    If [M:PIV2]NBLIG > 0 Then
      If [M:PIV2]BPRNUM(0) <> "" Then
        Chgfmt [M:PIV1]BPRNUM With "KP:"+ num$(GLONBPR) + "X"
        Chgfmt [M:PIV1]ZBPRNUM With "KP:"+ num$(GLONNAM) + "X"
        Case SCONTEXTE
          When "PIA"
            Chgtzn [M:PIV1]BPRNUM With mess(2,277,1)
          When "PIV"
            Chgtzn [M:PIV1]BPRNUM With mess(1,277,1)
          When Default
            #Chgtzn [M:PIV1]BPRNUM With mess(1,277,1)
        Endcase
        [M:PIV1]BPRNUM = [M:PIV2]BPRNUM(0)
        Affzo [M:PIV1]BPRNUM
      Else
        Chgfmt [M:PIV1]BPRNUM With "-K:"+ num$(GLONBPR) + "X"
        Chgfmt [M:PIV1]ZBPRNUM With "-K:"+ num$(GLONNAM) + "X"
      Endif
    Else
      Chgfmt [M:PIV1]BPRNUM With "-K:"+ num$(GLONBPR) + "X"
      Chgfmt [M:PIV1]ZBPRNUM With "-K:"+ num$(GLONNAM) + "X"
    Endif
  Else
  Endif
End

############################################################
$PUR_SELECTIONS
  Trbegin [PKW]
  Filter [PKW] Where PRONUM = GCNSPIXUUID Order By Key SKW0
  For [PKW]
    If !([F:PKW]VCRNUM = VCRN and [F:PKW]VCRTYP=VCRT)
&     and !(pat([F:PKW]VCRNUM,VCRN+" /*") and [F:PKW]VCRTYP=VCRT and find(VCRT,11,13))
&     and !(pat([F:PKW]VCRNUM,VCRN+"/"+num$(VCRL)) and [F:PKW]VCRTYP=VCRT and find(VCRT,34))
&   Then
      Delete [PKW]
      If fstat Then
        Call FSTA("PKW") From GLOCK
        Break
      Endif
    Endif
  Next
  Filter [PKW]
  If fstat Then
    Rollback
  Else
    Commit
  Endif
Return

############################################################
# On vérifie que la ligne de la pièce est bien référencée dans la table de travail
Funprog VERIF_LINE(NUMLIN, NUMTYP)
Value Integer NUMLIN
Value Integer NUMTYP

Local Integer OK_LIN
Local Integer RC

  OK_LIN = G_NON
  If !clalev([F:PKW2]) : Local File PIWRK [PKW2] : Endif
  Filter [F:PKW2] Where PRONUM = GCNSPIXUUID and VCRTYP = NUMTYP and VCRNUM = [F:PKW]VCRNUM and VCRLIN = NUMLIN
  If rowcount([F:PKW2]) = 0 Then
    Filter [F:PKW2]
    Filter [F:PKW2] Where PRONUM = GCNSPIXUUID and VCRTYP = NUMTYP and VCRNUM = [F:PKW]VCRNUM
    If rowcount([F:PKW2]) = 1 Then
      Read [F:PKW2]First
      If [F:PKW2]VCRLIN = 0 Then
        OK_LIN = G_OUI
      Endif
    Else
      RC = rowcount([F:PKW2])
      Filter [F:PKW2]
      Filter [F:PKW2] Where PRONUM = GCNSPIXUUID and VCRTYP = NUMTYP and VCRNUM = [F:PKW]VCRNUM and VCRLIN = 0
      If rowcount([F:PKW2])= RC Then
        OK_LIN = G_OUI
      Endif
    Endif
  Else
    OK_LIN = G_OUI
  Endif
  Filter [F:PKW2]
End OK_LIN

############################################################
# Vérification des redondances dans l'arborescence
Subprog REMONTER_LIGNE(INDD, INDF)
Value Integer INDD
Value Integer INDF

  If clalev([M:PIV3]) and GACTION = "VISUPIV" Then
    [M:PIV3]LEV(INDD)     = [M:PIV3]LEV(INDF)
    [M:PIV3]LEVC(INDD)    = [M:PIV3]LEVC(INDF)
    [M:PIV3]VCRTYP(INDD)  = [M:PIV3]VCRTYP(INDF)
    [M:PIV3]VCRNUM(INDD)  = [M:PIV3]VCRNUM(INDF)
    [M:PIV3]IPTDAT(INDD)  = [M:PIV3]IPTDAT(INDF)
    [M:PIV3]SALFCY(INDD)  = [M:PIV3]SALFCY(INDF)
    [M:PIV3]STOFCY(INDD)  = [M:PIV3]STOFCY(INDF)
    [M:PIV3]BPRNUM(INDD)  = [M:PIV3]BPRNUM(INDF)
    [M:PIV3]BPRNAM(INDD)  = [M:PIV3]BPRNAM(INDF)
    [M:PIV3]JOU(INDD)     = [M:PIV3]JOU(INDF)
    [M:PIV3]PARKEY(INDD)  = [M:PIV3]PARKEY(INDF)
    [M:PIV3]KEYC(INDD)    = [M:PIV3]KEYC(INDF)
    If dim([M:PIV3]REP1) >= 0 Then
      [M:PIV3]REP1(INDD)  = [M:PIV3]REP1(INDF)
    Endif
    If dim([M:PIV3]REP2) >= 0 Then
      [M:PIV3]REP2(INDD)  = [M:PIV3]REP2(INDF)
    Endif
    [M:PIV3]ORDNOT(INDD)  = [M:PIV3]ORDNOT(INDF)
    [M:PIV3]ORDATI(INDD)  = [M:PIV3]ORDATI(INDF)
    [M:PIV3]ORDNOTL(INDD) = [M:PIV3]ORDNOTL(INDF)
    [M:PIV3]ORDATIL(INDD) = [M:PIV3]ORDATIL(INDF)
    [M:PIV3]ORDNOTD(INDD) = [M:PIV3]ORDNOTD(INDF)
    [M:PIV3]ORDATID(INDD) = [M:PIV3]ORDATID(INDF)
    # FGR 23/01/2011 : X3SUIVI71278
    [M:PIV3]VCRSTAT1(INDD)= [M:PIV3]VCRSTAT1(INDF)
    [M:PIV3]VCRSTAT2(INDD)= [M:PIV3]VCRSTAT2(INDF)
    [M:PIV3]VCRSTAT3(INDD)= [M:PIV3]VCRSTAT3(INDF)
    [M:PIV3]VCRSTAT4(INDD)= [M:PIV3]VCRSTAT4(INDF)
    [M:PIV3]CURVCR(INDD)  = [M:PIV3]CURVCR(INDF)
  Else
    [M:PIV2]LEV(INDD)     = [M:PIV2]LEV(INDF)
    [M:PIV2]VCRTYP(INDD)  = [M:PIV2]VCRTYP(INDF)
    [M:PIV2]VCRNUM(INDD)  = [M:PIV2]VCRNUM(INDF)
    [M:PIV2]IPTDAT(INDD)  = [M:PIV2]IPTDAT(INDF)
    [M:PIV2]SALFCY(INDD)  = [M:PIV2]SALFCY(INDF)
    [M:PIV2]BPRNUM(INDD)  = [M:PIV2]BPRNUM(INDF)
    [M:PIV2]BPRNAM(INDD)  = [M:PIV2]BPRNAM(INDF)
    [M:PIV2]JOU(INDD)     = [M:PIV2]JOU(INDF)
    [M:PIV2]PARKEY(INDD)  = [M:PIV2]PARKEY(INDF)
    [M:PIV2]KEYC(INDD)    = [M:PIV2]KEYC(INDF)
    [M:PIV2]LIB(INDD)     = [M:PIV2]LIB(INDF)
    [M:PIV2]LIBSH(INDD)   = [M:PIV2]LIBSH(INDF)
    [M:PIV2]LIGNE(INDD)   = [M:PIV2]LIGNE(INDF)
    [M:PIV2]PARLIN(INDD)  = [M:PIV2]PARLIN(INDF)
    # FGR 23/01/2011 : X3SUIVI71278
    [M:PIV2]VCRSTAT1(INDD)= [M:PIV2]VCRSTAT1(INDF)
    [M:PIV2]VCRSTAT2(INDD)= [M:PIV2]VCRSTAT2(INDF)
    [M:PIV2]VCRSTAT3(INDD)= [M:PIV2]VCRSTAT3(INDF)
    [M:PIV2]VCRSTAT4(INDD)= [M:PIV2]VCRSTAT4(INDF)
  Endif
End

############################################################
Subprog VIDER_LIGNE(IND)
Value Integer IND

  If clalev([M:PIV3]) and GACTION = "VISUPIV" Then
    Raz [M:PIV3]LEV(IND)
    Raz [M:PIV3]LEVC(IND)
    Raz [M:PIV3]VCRTYP(IND)
    Raz [M:PIV3]VCRNUM(IND)
    Raz [M:PIV3]IPTDAT(IND)
    Raz [M:PIV3]SALFCY(IND)
    Raz [M:PIV3]STOFCY(IND)
    Raz [M:PIV3]BPRNUM(IND)
    Raz [M:PIV3]BPRNAM(IND)
    Raz [M:PIV3]JOU(IND)
    Raz [M:PIV3]PARKEY(IND)
    Raz [M:PIV3]KEYC(IND)
    If dim([M:PIV3]REP1) >= 0 Then
      Raz [M:PIV3]REP1(IND)
    Endif
    If dim([M:PIV3]REP2) >= 0 Then
      Raz [M:PIV3]REP2(IND)
    Endif
    Raz [M:PIV3]ORDNOT(IND)
    Raz [M:PIV3]ORDATI(IND)
    Raz [M:PIV3]ORDNOTL(IND)
    Raz [M:PIV3]ORDATIL(IND)
    Raz [M:PIV3]ORDNOTD(IND)
    Raz [M:PIV3]ORDATID(IND)
    # FGR 23/01/2011 : X3SUIVI71278
    Raz [M:PIV3]VCRSTAT1(IND)
    Raz [M:PIV3]VCRSTAT2(IND)
    Raz [M:PIV3]VCRSTAT3(IND)
    Raz [M:PIV3]VCRSTAT4(IND)
    Raz [M:PIV3]CURVCR(IND)
  Else
    Raz [M:PIV2]LEV(IND)
    Raz [M:PIV2]VCRTYP(IND)
    Raz [M:PIV2]VCRNUM(IND)
    Raz [M:PIV2]IPTDAT(IND)
    Raz [M:PIV2]SALFCY(IND)
    Raz [M:PIV2]BPRNUM(IND)
    Raz [M:PIV2]BPRNAM(IND)
    Raz [M:PIV2]JOU(IND)
    Raz [M:PIV2]PARKEY(IND)
    Raz [M:PIV2]KEYC(IND)
    Raz [M:PIV2]LIB(IND)
    Raz [M:PIV2]LIBSH(IND)
    Raz [M:PIV2]ICO(IND)
    Raz [M:PIV2]EXPFLG(IND)
    Raz [M:PIV2]LIGNE(IND)
    Raz [M:PIV2]PARLIN(IND)
    # FGR 23/01/2011 : X3SUIVI71278
    Raz [M:PIV2]VCRSTAT1(IND)
    Raz [M:PIV2]VCRSTAT2(IND)
    Raz [M:PIV2]VCRSTAT3(IND)
    Raz [M:PIV2]VCRSTAT4(IND)
  Endif
End

############################################################
Funprog GET_MESSAGE(NUM_CHAP, NUM_CLE)
Value Integer NUM_CHAP
Value Integer NUM_CLE

Local Char SARENDRE(GLONDCO)

  Raz SARENDRE
  If NUM_CLE > 0 Then
    SARENDRE = mess(NUM_CLE,NUM_CHAP,1)
  Endif
End SARENDRE
