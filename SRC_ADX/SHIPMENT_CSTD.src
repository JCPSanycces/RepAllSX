#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SHIPMENT

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE     From SHIPMENT_CMET
        When "AINSERT_CONTROL_AFTER"   : Gosub AINSERT_CONTROL_AFTER      From SHIPMENT_CMET
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE     From SHIPMENT_CMET
        When "AUPDATE_CONTROL_AFTER"   : Gosub AUPDATE_CONTROL_AFTER      From SHIPMENT_CMET
        When "AINSERT_BEFORE"          : Gosub AINSERT_BEFORE             From SHIPMENT_CMET
        When "AUPDATE_BEFORE"          : Gosub AUPDATE_BEFORE             From SHIPMENT_CMET
        When "AUPDATE_AFTER"           : Gosub AUPDATE_AFTER              From SHIPMENT_CMET  # Issue 58314_2
        When "ADELETE_CONTROL_AFTER"   : Gosub ADELETE_CONTROL_AFTER      From SHIPMENT_CMET
      Endcase
    When "SHD"
      Case [L]AEVENT
        When "ADDLINE_AFTER"           : Gosub SHD_ADDLINE_AFTER          From SHIPMENT_CMET
        When "AINSERT_BEFORE"          : Gosub SHD_AINSERT_BEFORE         From SHIPMENT_CMET
        When "AINSERT_AFTER"           : Gosub SHD_AINSERT_AFTER          From SHIPMENT_CMET
        When "AUPDATE_AFTER"           : Gosub SHD_AUPDATE_AFTER          From SHIPMENT_CMET
        When "AUPDATE_CONTROL_AFTER"   : Gosub SHD_AUPDATE_CONTROL_AFTER  From SHIPMENT_CMET
        When "AINSERT_CONTROL_AFTER"   : Gosub SHD_AINSERT_CONTROL_AFTER  From SHIPMENT_CMET
        When "ADELETE_CONTROL_BEFORE"  : Gosub SHD_ADELETE_CONTROL_BEFORE From SHIPMENT_CMET #
        When "ADELETE_AFTER"           : Gosub SHD_ADELETE_AFTER          From SHIPMENT_CMET
      Endcase
    When "SHIPD"
      Case [L]AEVENT
        When "AINSERT_BEFORE"          : Gosub SHIPD_AINSERT_BEFORE       From SHIPMENT_CMET
      Endcase
    When "SHIPT"
      Case [L]AEVENT
        When "ADELLINE_AFTER"          : Gosub SHIPT_ADELLINE_AFTER       From SHIPMENT_CMET
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SHIPT_GET_INDEX"         : Gosub SHIPT_GET_INDEX                From SHIPMENT_CMET
    When "_UPD_QTY_STAT"           : Gosub _UPD_QTY_STAT              From SHIPMENT_CMET  # Issue 15350 - 2016-12-06 by MAE
    When "_UPD_STATUS"             : Gosub _UPD_STATUS                From SHIPMENT_CMET  # Issue 15350 - 2016-12-06 by MAE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
 Case CURPRO
    When "SHIPSTAT" :
      Case [L]ARULE
        When "INIT" : Gosub SHIPSTAT_INIT From SHIPMENT_CPRO
      Endcase
    When "SHIPDAT" :
      Case [L]ARULE
        When "INIT" : Gosub SHIPDAT_INIT From SHIPMENT_CPRO
      Endcase
    When "TRNNUM" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub TRNNUM_PROPAGATE From SHIPMENT_CPRO
      Endcase
    When "DPETPC" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub DPETPC_PROPAGATE From SHIPMENT_CPRO
      Endcase
    When "ARVTPC" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub ARVTPC_PROPAGATE From SHIPMENT_CPRO
      Endcase
      # Issue 111256 US3
    When "TCTRNUM" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub TCTRNUM_PROPAGATE From SHIPMENT_CPRO
      Endcase
    When "SHIPNBCTR" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub SHIPNBCTR_PROPAGATE From SHIPMENT_CPRO
      Endcase
      # End issue 111256 US3
  Endcase
Return

