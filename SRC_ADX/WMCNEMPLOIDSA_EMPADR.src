#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional RSA fields
# Supervisor
## ACLA-CLASSE ## EMPLOIDSA_EMPADR
# 2018-11-06 07:05:50 918

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EMPLOIDSA_EMPADR
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_ADDPRI From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDTYP From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDSRVTYP From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDPOSOTH From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDPOSNUM From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDPOSNAM From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDPOSAGN From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDPOSCOF From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDPOSINM From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDCPX From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDSTRNUM From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDSTRNAM From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDSUB From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDTWN From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDPOSCDE From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDCNTCDE From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDPRV From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDCOR From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub INIT_ADDSTA From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub AINIT From WMC0EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EMPLOIDSA_EMPADR
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EMPLOIDSA_EMPADR
Gosub LNKPRO_ADDCNTCDE From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Gosub LNKPRO_ADDPRV From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



