#<AdxTL>@(#)0.0.0.0 $Revision$
# TRAITEMENTS LIES AU PICKING DES AFFECTATIONS DE LPN                  #
#########################################################################

#########################################################################
# Actions de l'objet                                                    #
#########################################################################

#########################################################################
$TIROIR
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
WPICK=2
Gosub RAFFRAICHI

Return
#########################################################################
$FILGAUCHE
Local Integer W_I, W_J
Local Char    W_STA(GLONSTA)



If currbox<>GBOXSTO
  # Issue 106909 - 2018-09-20 by MAE : on ne selectionne que les opérations
  FILGAUCHE='[F:SGH]MODOPELPN = 4 '
  Return
Endif

Raz FILGAUSUP(1)
Raz FILGAUSUP(2)
Raz FILGAUSUP(3)
# Filtre article, site
If [M:LPNA]ITMREFSEL<>""
  If dim([M:LPNA]ECSSEL)>0 & [M:LPNA]ECSSEL<>""
    FILGAUSUP(0) = '[F:STO]ITMREF=[M:LPNA]ITMREFSEL&[F:STO]STOFCY=[M:LPNA]STOFCY'
    FILGAUSUP(0)+= '&[F:STO]ECCVALMAJ=[M:LPNA]ECSSEL'
  Else
    FILGAUSUP(0) = '[F:STO]ITMREF=[M:LPNA]ITMREFSEL&[F:STO]STOFCY=[M:LPNA]STOFCY'
  Endif
Else
  FILGAUSUP(0) = '[F:STO]STOFCY=[M:LPNA]STOFCY'
Endif

#--Emplacement
If [M:LPNA]LOCSTR <> AVOID.ACHAR
    FILGAUSUP(0) += '&[F:STO]LOC>=[M:LPNA]LOCSTR'
Endif
If [M:LPNA]LOCEND<>""
  FILGAUSUP(0) += '&[F:STO]LOC<=[M:LPNA]LOCEND'
Endif
#--Type Emplacement
If [M:LPNA]LOCTYPSTR <> AVOID.ACHAR
    FILGAUSUP(0) += '&[F:STO]LOCTYP>=[M:LPNA]LOCTYPSTR'
Endif
If [M:LPNA]LOCTYPEND<>""
  FILGAUSUP(0) += '&[F:STO]LOCTYP<=[M:LPNA]LOCTYPEND'
Endif


#--Lot
If dim([M:LPNA]LOTSTR)>0
  If [M:LPNA]LOTSTR <> AVOID.ACHAR
    FILGAUSUP(0) += '&[F:STO]LOT>=[M:LPNA]LOTSTR'
  Endif
  If [M:LPNA]LOTEND<>""
    FILGAUSUP(0) += '&[F:STO]LOT<=[M:LPNA]LOTEND'
  Endif
Endif
#--Sous-lot
If dim([M:LPNA]SLOSTR)>0
  If [M:LPNA]SLOSTR <>  AVOID.ACHAR
    FILGAUSUP(0) += '&[F:STO]SLO>=[M:LPNA]SLOSTR'
  Endif
  If [M:LPNA]SLOEND<>""
    FILGAUSUP(0) += '&[F:STO]SLO<=[M:LPNA]SLOEND'
  Endif
Endif
#--Dépôt
If dim([M:LPNA]WRHSTR)>0
  If [M:LPNA]WRHSTR <> AVOID.ACHAR
    FILGAUSUP(0) += '&[F:STO]WRH>=[M:LPNA]WRHSTR'
  Endif
  If [M:LPNA]WRHEND<>""
    FILGAUSUP(0) += '&[F:STO]WRH<=[M:LPNA]WRHEND'
  Endif
Endif
#pas de omptage en cours et qté >0
FILGAUSUP(1) += '&[F:STO]CUNLOKFLG<>2&[F:STO]QTYSTU>0'
#emplacement interne uniquement, pas de LPN
FILGAUSUP(1) += '&[F:STO]LOCCAT=1 & [F:STO]LPNNUM=""'

# Filtre statuts
If WCRITSTO4<>""
  FILGAUSUP(1) += '&('+WCRITSTO4+')'
Endif
If dim([M:LPNA]SERNUMSTR)>0
  If [M:LPNA]SERNUMSTR <> AVOID.ACHAR
    FILGAUSUP(1) += '&[F:STO]SERNUM>=[M:LPNA]SERNUMSTR'
  Endif
  If [M:LPNA]SERNUMEND<>""
    FILGAUSUP(1) += '&[F:STO]SERNUM<=[M:LPNA]SERNUMEND'
  Endif
Endif

#Filtres sur les allocations
If [M:LPNA]ALLSTO=2 & [M:LPNA]NOTALLSTO<>2
  FILGAUSUP(3) += '&[F:STO]CUMALLQTY<>0'
Elsif [M:LPNA]NOTALLSTO=2 & [M:LPNA]ALLSTO<>2
  FILGAUSUP(3) += '&[F:STO]QTYSTU-[F:STO]CUMALLQTY>0'
Elsif [M:LPNA]NOTALLSTO<>2 & [M:LPNA]ALLSTO<>2
  FILGAUSUP(3) += '&[F:STO]QTYSTU=0&[F:STO]CUMALLQTY=0'
Endif

Return

#########################################################################
$AP_FILGAUCHE
Case currbox
 When GBOXSTO    : WPICK=2 : Gosub RAFFRAICHI
 When Default
Endcase
Return

#########################################################################
$DEB_PICK

Return

#########################################################################
$PICKE

Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS, WTOTACTDIS, WDISPO, WQTYSTU
Local Integer LTYPLOC, LSTA, LRET
Local Char    PABR(GLONABR)
Local Integer PNOL
PABR = "LPNA"
#--- Issue 96990
Local Integer I
#hcb 33564 deb
If GREP = "M" | GREP = ""
   If dim(GCTRDATSCS) <= 0
      If [M:LPNA]IPTDAT < date$
         Global Integer GCTRDATSCS
         # Attention ! la date d imputation est antérieure à la date du jour
         Call MESSAGE(mess(162,184,1)) From GESECRAN
      Endif
   Endif
Endif
# hcb 33564 fin

If dim(LSAVNOL)<=0
    Local Integer LSAVNOL
    LSAVNOL=-1
Endif

If REP=""
   If !CLECUR | !VERROU | !ACTMOD
      OK=0 : Return
   Endif
Endif

If currbox<>GBOXSTO
    Return
Endif

Read [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
If fstat
   Call RSTA ("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
   OK=0 : Return
Endif
Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
If fstat
   Call RSTA ("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
   OK=0 : Return
Endif

#si pas de filtre article saisi, vérification que l'article gére les LPN
If [F:STO]ITMREF <> [F:ITF]ITMREF
  Read [ITF]ITF0 = [F:STO]ITMREF;[F:STO]STOFCY
Endif
If [F:ITF]LPNMGTCOD <> 2
  Call ERREUR(mess(531,184,1)) From GESECRAN
  OK=0: Return
Endif

#Vérification que les infos stocks sont bien renseignées
Call CTLPLFLOC([F:STO]ITMREF,"[F:STO]",LRET) From STKSOR
If LRET <> 0
  Call ERREUR(mess(177,184,1)) From GESECRAN
  OK=0: Return
Endif

# Si dépôt dépose renseigné
# Contrôle existence article dépôt
If dim([M:LPNA]WRHDESH)>0 & [M:LPNA]WRHDESH<>""
   Read [ITW]ITW0=[F:STO]ITMREF;[M:LPNA]WRHDESH
   If fstat
      Call ERREUR(mess(978,196,1)-[M:LPNA]WRHDESH) From GESECRAN
      OK=0: Return
   Endif
Endif
If [M:LPNA]MODAFFLPN = 1
  #controle avant picking
  If [M:LPNA]LPNDESH = AVOID.ACHAR
    GMESSAGE=mess(525,184,1)   # contenant obligatoire
    OK=0 : GERR=1 : Return
  Endif
  If [M:LPNA]LOCDESH = AVOID.ACHAR
    GMESSAGE=mess(536,184,1)   # emplacement obligatoire
    OK=0 : GERR=1 : Return
  Endif
Endif
#---
# Si changement de stock et pas de filtre article saisi,
# il faut lire articles et règle de gestion
If [F:STO]ITMREF <> [F:ITM]ITMREF                                             # hcb 116105
  Call LECITM2([M:LPNA]STOFCY,[F:STO]ITMREF,[F:STO]WRH,LRET) From STKLIB
  If LRET<>0
     If GMESSAGE<>"" Call ERREUR(GMESSAGE) From GESECRAN Endif
     OK=0 : Return
  Endif
  [F:ITFD] = [F:ITF]   # hcb 108849

  Call LECSRU([M:LPNA]STOFCY,[F:ITM]TCLCOD,26,"","",LRET) From STKLIB
  If LRET<>0
     OK=0 : Return
  Endif
  GSCSAUZSST = [F:SRU]AUZSST
Endif

Local Integer LRET
Local Integer LSEQ
Local Integer LNEW    # Indique s'il faut ajouter une ligne au document
Local Char    LSER(GLONSER)
Local Decimal LQTY
Local Decimal LSTOCOU

Raz WQTYSTU
# Ligne de stock avec demande d'analyse
If [F:STO]QLYCTLDEM<>""

  For [QLD]QLD1 Where ITMREF=[F:STO]ITMREF & STOFCY=[F:STO]STOFCY
&                       & VCRTYP=28 & VCRNUM=[F:STO]QLYCTLDEM

  If [F:QLD]LOT      =[F:STO]LOT
&         & [F:QLD]SLO      =[F:STO]SLO
&         & [F:QLD]SERNUM   =[F:STO]SERNUM
&         & [F:QLD]STA      =[F:STO]STA
&         & [F:QLD]LOC      =[F:STO]LOC
&         & [F:QLD]PCU      =[F:STO]PCU
&         & [F:QLD]PCUSTUCOE=[F:STO]PCUSTUCOE
&         & [F:QLD]PALNUM   =[F:STO]PALNUM
&         & [F:QLD]CTRNUM   =[F:STO]CTRNUM
&         & [F:QLD]OWNER    =[F:STO]OWNER
&         & [F:QLD]STOFLD1  =[F:STO]STOFLD1
&         & [F:QLD]STOFLD2  =[F:STO]STOFLD2

    WQTYSTU += [F:QLD]QTYSTU
  Endif
  Next

  If WQTYSTU<>[F:STO]QTYSTU
    GMESSAGE=mess(163,184,1)+"\"+mess(164,184,1)   # vous devez terminer le CQ pour acceder à ce stock
    OK=0: GERR=1 : Return
   Endif
#---
Endif

If !clalev([F:STA]) : Local File STOALL [STA] : Endif
Look [F:STA]STA0(3)=[F:STO]STOFCY;[F:STO]ITMREF;[F:STO]STOCOU
[G:STA]currlen=0
If !fstat
  If dim(GALLSTO)=0 : Global Integer GALLSTO : Endif
  GALLSTO = 1
Endif

# S'il y a des allocations sur la ligne de stock
# et que l'on fait un changement de stock interne
If dim(GALLSTO)>0 & GALLSTO=1
  # La ligne de stock est-elle en cours de pesée
  Call ALL_WEIGHING([F:STO]STOFCY,[F:STO]ITMREF,[F:STO]STOCOU,LRET) From STKALL
  If LRET<>0
    GMESSAGE=mess(402,184,1)
    Raz GALLSTO
    Return
  Endif
Endif
If dim([M:LPNA]LOCDESH)>0 & [M:LPNA]LOCDESH<>""
  #controle sur l'emplacement
  Call STKCTREMP([M:LPNA]WLOCSEQ,36,"",[M:LPNA]STOFCY,
&                          [F:STO]ITMREF,[F:STO]PCU,[F:STO]QTYPCU,
&                          [F:STO]STA,[M:LPNA]LOCTYPDESH,[M:LPNA]LOCDESH,"",
&                          0,mkstat,GBIDD1,"UQ",GFILLOCENT,[M:LPNA]WRHDESH) From STKLOC
  If mkstat<>0 : OK = 0 :GERR = 1 : Return : Endif
Endif
#---
If [F:STO]QTYSTU-[F:STO]CUMWIPQTY >0
  #remplissage de l'écran
  Gosub ALI_DOC From SUBLPNAFB
  Call STKWSTOSEQ ("LPNA", [M:LPNA]NBLIG-1, [M:LPNA]NBLIG, 2, LSEQ, LRET) From STKECR
  If LSAVNOL<0
    LSAVNOL = nolign-1
  Endif
   #---- FillCHGW utilise [F:STO] => il faut sauvegarder la position courante
  LSTOCOU = [F:STO]STOCOU
  Call FILLCHGW("LPNA", nolign-1, 1, [M:LPNA]WSTOSEQ(nolign-1), [M:LPNA]STOFCY, LRET, LQTY) From SUBSCSB
  Read [STO]STO0=[M:LPNA]STOFCY;LSTOCOU
  If [F:ITM]SERMGTCOD = 4
    PNOL = nolign - 1
    Gosub CTR_SERIES_GLOBALE From SUBSCSB
  Endif
Else
  GMESSAGE=mess(57,184,1)
  OK = 0
Endif

Return

#########################################################################
$DEPICK
Local Integer DP_LRET
Case currbox
 When GBOXSTO :
        Look [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
        If fstat
            Call RSTA ("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
            FOK=0 : Return
        Endif
        For I=0 To [M:LPNA]NBLIG-1
          Call DEPICK([F:STO]STOFCY, [F:STO]STOCOU, "LPNA", DP_LRET) From SUBLPNAFB
          If DP_LRET<>0 : OK = 1 : Break : Endif
        Next
        Affzo [M:LPNA]
 When Default
Endcase
Return
#########################################################################
$FIN_PICK
If REP=""
   If !VERROU
      GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return
   Elsif !CLECUR | !ACTMOD | GCONSULT
      GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return
   Endif
Endif

Local Integer LRET
Local Decimal LQTY
    If dim(GSCSPIC)>0
        Kill GSCSPIC
        Call FILLCHGW("LPNA", nolign-1, 1, [M:LPNA]WSTOSEQ(nolign-1), [M:LPNA]STOFCY, LRET, LQTY) From SUBSCSB
        Affzo [M:LPNA]10
    Endif

If dim(GALLSTO)>0
    If GALLSTO=1
        Call MESSAGE(mess(84,184,1)) From GESECRAN
    Endif
    Kill GALLSTO
Endif

Case currbox
 When GBOXSTO : Affzo [M:LPNA]1-99
 When Default
Endcase


If [M:LPNA]NBLIG>0 & dim(LSAVNOL)>0 & LSAVNOL>=0
    zonsui="NBLIG("+num$(LSAVNOL)+")"
    Kill LSAVNOL
Endif

Return

#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

$REMPBOX
#-----------------------------------------------------------------------#
# Remplissage des boites de picking                                     #
#-----------------------------------------------------------------------#
ILIS=val(right$(currbox,8))

Gosub REMP_LISGAU From GOBJSUB
WPICK=2
Gosub RAFFRAICHI


Return

#########################################################################
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement des listes de picking pour les lignes déjà saisies  #
#-----------------------------------------------------------------------#
For I=0 To [M:SGW]NBLIG-1
  If [M:SGW]WSTOSEQ(I) <> 0
         Case currbox
          When GBOXSTO :
                         Read [STO]STO0=[M:LPNA]STOFCY;[M:SGW]WSTOCOU(I)
          When Default
         Endcase
         If    WPICK=1 Gosub DEPICK From GOBJSUB
         Elsif WPICK=2 Gosub REPICK From GOBJSUB
         Endif
      Endif
   Next I
Return

