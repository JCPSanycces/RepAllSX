#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################
#
# Library of Legislation procedures for Individual Training Program screens
#
# Window  : OCSI
# Screens : CSI0, CSI1, CSI3, CSI4, CSI5, CSI6
#
############################################################


########################################
#18/06/12 - DKA - Display\Hide fields based on legislation
########################################
Subprog DISPLAY_HIDE()
  Case GCURLEG
   When "FRA", ""
     Chgfmt [M:CSI1]NBRHOUDIF    With "Nz+:4.2"   : #Training hours
     ##CSI2 - Show fields
     #ADNGO - 2017-11-22 - START
     #Chgfmt [M:CSI2]NATFIS       With "LA:10452"  : #Fiscal nature
     #Chgfmt [M:CSI2]CATACN       With "LA:10453"  : #Action category
     #Chgfmt [M:CSI2]TYPFRT       With "LA:10455"  : #Systems used
     Chgfmt [M:CSI2]NATFIS       With "K:5X"  : #Fiscal nature
     Chgfmt [M:CSI2]CATACN       With "K:5X"  : #Action category
     Chgfmt [M:CSI2]TYPFRT       With "K:5X"  : #Systems used
     #ADNGO - 2017-11-22 - END
     ##CSI5 - Show fields
     Chgfmt [M:CSI5]CATFRT       With "KP:10AX"   : #CATFRT=CATTRG in STG
     #ADNGO - 2017-11-22 - START
     #Chgfmt [M:CSI5]DESTYPFRT    With "LA:10455"  : #Systems used
     Chgfmt [M:CSI5]DESTYPFRT    With "K:5X"  : #Systems used
     #ADNGO - 2017-11-22 - END

   When Default
     Chgfmt [M:CSI1]NBRHOUDIF    With "-Nz+:4.2"  : Raz [M:CSI1]NBRHOUDIF : #Training hours
     ##CSI2 - Hide fields
     #ADNGO - 2017-11-22 - START
     #Chgfmt [M:CSI2]NATFIS       With "-LA:10452" : Raz [M:CSI2]NATFIS    : #Fiscal nature
     #Chgfmt [M:CSI2]CATACN       With "-LA:10453" : Raz [M:CSI2]CATACN    : #Action category
     #Chgfmt [M:CSI2]TYPFRT       With "-LA:10455" : Raz [M:CSI2]TYPFRT    : #Systems used
     Chgfmt [M:CSI2]NATFIS       With "-K:5X"  : #Fiscal nature
     Chgfmt [M:CSI2]CATACN       With "-K:5X"  : #Action category
     Chgfmt [M:CSI2]TYPFRT       With "-K:5X"  : #Systems used
     #ADNGO - 2017-11-22 - END
     ##CSI5 - Show fields
     Chgfmt [M:CSI5]CATFRT       With "-K:10AX"   : Raz [M:CSI5]CATFRT    : #CATFRT=CATTRG in STG
     #ADNGO - 2017-11-22 - START
     #Chgfmt [M:CSI5]DESTYPFRT    With "-LA:10455" : Raz [M:CSI5]DESTYPFRT : #Systems used
     Chgfmt [M:CSI5]DESTYPFRT    With "-K:5X"  : #Systems used
     #ADNGO - 2017-11-22 - END

Endcase
End

