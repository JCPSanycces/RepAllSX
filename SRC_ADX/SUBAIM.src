#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du fichier AIMPRIME
Raz GPILOBJ
Call OBJET("AIM",GBIDC1,GBIDC2) From GOBJET
End

#-----------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "SETBOUT"      : Gosub SETBOUT
 When "LIENS"        : Gosub LIENS
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INIMOD
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When Default
Endcase
Return

#------------------------------#
$LIENS
Raz [M]PRTDES,[M]PRTDESEX
For [AID]AID0 Where COD=[F:AIM]COD
 [M]PRTDES([F:AID]NUM-1)      = [F:AID]PRTDES
 [M]PRTDESEX([F:AID]NUM-1) = [F:AID]PRTDESEX
Next
Gosub GRISE_PRT
Gosub GRISE_SRV
Gosub GRISE_CPY
Return

#----------------------#
$GRISE_CPY
If [M]NBRCPY>1 & [M]PRT<>6
 Actzo [AIM1]ASSCPY
Else
 Effzo [AIM1]ASSCPY
 Grizo [AIM1]ASSCPY
Endif
Return

#----------------------#
$GRISE_PRT
Case [M]PRT
 When 1
  Effzo [AIM1]PRTNAM
  [M:AIM1]PRTNAT = 0
  [M:AIM1]NBRCPY = 0
  If [M:AIM1]PRTSRV=""
   [M:AIM1]PRTFMT = 0
   Affzo [AIM1]PRTFMT
   Grizo [AIM1]PRTFMT
  Else
   Actzo [AIM1]PRTFMT
  Endif
  Affzo [AIM1]PRTNAT,NBRCPY
  Grizo [AIM1]PRTNAM,NBRCPY,PRTNAT
  Raz [AIM1]PRTDRV , PRTPOR , PRTDES, PRTDESEX
  If dim([M:AIM1]PRTZPL)>0
   [M:AIM1]PRTZPL = ""
   Affzo [AIM1]PRTZPL
   Diszo [AIM1]PRTZPL
  Endif
 When 2
  [M:AIM1]PRTFMT = 0
  Affzo [AIM1]PRTFMT
  Grizo [AIM1]PRTFMT
  Actzo [AIM1]PRTNAM,NBRCPY,PRTNAT
  If dim([M:AIM1]PRTZPL)>0
   [M:AIM1]PRTZPL = ""
   Affzo [AIM1]PRTZPL
   Diszo [AIM1]PRTZPL
  Endif
 When 3,4
  Actzo [AIM1]PRTFMT
  Effzo [AIM1]PRTNAM
  [AIM1]PRTNAT = 0
  [AIM1]NBRCPY = 0
  Affzo [AIM1]PRTNAT,NBRCPY
  Grizo [AIM1]PRTNAM,NBRCPY,PRTNAT
  Raz [AIM1]PRTDRV , PRTPOR , PRTDES, PRTDESEX
  If dim([M:AIM1]PRTZPL)>0
   [M:AIM1]PRTZPL = ""
   Affzo [AIM1]PRTZPL
   Diszo [AIM1]PRTZPL
  Endif
 When 6 : # Zpl
  Actzo [AIM1]PRTNAM,PRTNAT,NBRCPY
  [AIM1]PRTFMT = 9 : # Ascii
  Affzo [AIM1]PRTFMT
  Diszo [AIM1]PRTFMT
  If dim([M:AIM1]PRTZPL)>0
   Actzo [AIM1]PRTZPL
  Endif
 When 7 : # Archive
  Actzo [AIM1]PRTFMT
  Effzo [AIM1]PRTNAM
  [AIM1]PRTNAT = 0
  [AIM1]NBRCPY = 0
  Affzo [AIM1]PRTNAT,NBRCPY
  Grizo [AIM1]PRTNAM,NBRCPY,PRTNAT
  Raz [AIM1]PRTDRV , PRTPOR , PRTDES, PRTDESEX
  If dim([M:AIM1]PRTZPL)>0
   [M:AIM1]PRTZPL = ""
   Affzo [AIM1]PRTZPL
   Diszo [AIM1]PRTZPL
  Endif
Endcase
Return

#----------------------#
$GRISE_SRV
If [M]PRT=1
 If [M]PRTSRV=""
  [M]PRTFMT = 0
  Affzo [AIM1]PRTFMT
  Grizo [AIM1]PRTFMT
 Else
  Actzo [AIM1]PRTFMT
 Endif
Endif
Return

#------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return

#------------------------------#
$INICRE
$INIMOD
Delete [AID] Where COD=[M]COD
For I=0 To dim([M]PRTDES)-1
 If [M]PRTDES(I)<>"" or [M]PRTDESEX(I)<>""      # 119066 - Printer properties - add PRTDESEX statement
  Raz [F:AID]
  [F:AID]COD = [M]COD
  [F:AID]NUM = I+1
  [F:AID]PRTDES = [M]PRTDES(I)
  [F:AID]PRTDESEX = [M]PRTDESEX(I)
  Write [AID]
  If fstat
   GOK = 0 : Call FSTA("AID") From GLOCK : Break
  Endif
 Endif
Next I
Return

#-----------------------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "ASELAIM" : OBJET = "AIM" : SIZCOL = 370 : SIZLIG = 100
Endcase
Return

#-----------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File APRINTER  [AIM1]
 Local File APRINTDES [AID1]
Else
 Local File =[M]DOSORG+".APRINTER"  [AIM1]
 Local File =[M]DOSORG+".APRINTDES" [AID1]
Endif
If [M]DOSDES=nomap
 Local File APRINTER  [AIM2]
 Local File APRINTDES [AID2]
Else
 Local File =[M]DOSDES+".APRINTER"  [AIM2]
 Local File =[M]DOSDES+".APRINTDES" [AID2]
Endif
OK = 1
If GTRACE=""
 Read [AIM2]AIM0 = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [AIM1], [AID1] , [AIM2] , [AID2]
Return

$TR_COP
GOK = 1
Trbegin [AIM2]
 Delete [AIM2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".APRINTER" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AIM2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AID2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".APRINTDES" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AID2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AIM1]AIM0 Where COD=TABLE
  [F:AIM2] = [F:AIM1]
  If dim([F:AIM2]UPDUSR)>0 : [F:AIM2]UPDUSR = GUSER : Endif
  If dim([F:AIM2]UPDDAT)>0 : [F:AIM2]UPDDAT = date$ : Endif
  Write [AIM2]
  If fstat
   GOK=0 : Call FSTA("AIM2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AID1]AID0 Where COD=TABLE
  [F:AID2] = [F:AID1]
  If dim([F:AID2]UPDUSR)>0 : [F:AID2]UPDUSR = GUSER : Endif
  If dim([F:AID2]UPDDAT)>0 : [F:AID2]UPDDAT = date$ : Endif
  Write [AID2]
  If fstat
   GOK=0 : Call FSTA("AID2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#-----------------------------------------------#
Funprog OKXLS(SRVIMP)
Value Char SRVIMP
Local Integer OKXLS
Local Char    VERSION(30) , SRV(250)
OKXLS = 1
If [L]SRVIMP<>""
 [L]SRV = [L]SRVIMP
 If right$([L]SRV,len([L]SRV))<>"@"
  [L]SRV = [L]SRV+"@"
 Endif
 Getui VERSION=[L]SRV With "SafeX3SrvImpFileVersion"
 If VERSION<="EDT.208"
  OKXLS = 0
 Endif
Elsif !GBROWS
 Getui VERSION="" With "SafeX3CltFileVersion"
 If VERSION<"CLI.114"
  OKXLS = 0
 Endif
Endif
End OKXLS

#-----------------------------------------------------------------------------#
Subprog C_PRTNAM(VALEUR)
Variable Char    VALEUR()
Local Integer I
If VALEUR=""
 If [M]PRT<>6 or dim([M]PRTZPL)<0 or [M]PRTZPL="" : # Imprimante ZPL
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat = 1 : End
 Endif
Endif
If VALEUR="" : End : Endif
Affzo [M]PRTSRV,  PRTPOR, PRTDRV, NBRCPY,  ASSCPY, PRTPAGDEB,  PRTPAGFIN
If val([M]PRTMODIFIED)=2 : mkstat = 4 : Endif
End

Subprog AS_PRT(VALEUR)
Variable Integer  VALEUR
GMENLOC(5) = 1 : # Imprimante/Fichier ne fonctionne + avec le dernier Crystal Report
GMENLOC(6) = !func AFNC.ACTIV("AZPL") : # Imprimante ZEBRA
GMENLOC(7) = !func AFNC.ACTIV("ARCH") : # Archivage
End

Subprog C_PRT(VALEUR)
Value Integer VALEUR
[M]PRT = VALEUR
Gosub GRISE_PRT
Gosub GRISE_CPY
End

Subprog C_PRTSRV(VALEUR)
Variable Char    VALEUR()
Local Integer MELWRK
MELWRK = (func AFNC.PARAM("ASAIDEST","")<>"2" & func AFNC.PARTSEP(ver$(0),2," ")>="16r.113")
If VALEUR="" & (([M]PRT=3 & MELWRK) or [M]PRT=7)
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 1 : End
Endif
[M]PRTSRV = VALEUR
Gosub GRISE_SRV
End

Subprog AM_PRTSRV(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & [M]PRTFMT<=1
 If find([M]PRT,1,7) : # Pré-visu/Archive
  [M]PRTFMT = 29 : # pdf
 Endif
Endif
End

Subprog AS_PRTFMT(VALEUR)
Variable Integer VALEUR
Local Integer I
Raz GMENLOC
GPE = 1
GPOINT = "PRTFMT" : Gosub ENTREE From EXEFNC
If GPE=1 & [M]PRTSRV<>"" & PRT=1 : # Prévisu
 GMENLOC(1) = 1 : # rpt
Endif
# Formats supprimés en V136
For I=1 To len(mess(0,91,1))
 If left$(mess(I,91,1),1)="?"
  GMENLOC(I) = 1
 Endif
Next I
If [M]PRT=1 : # mb 19.12.13 bug 91623
 # mb 22.12.14 demande 104958
 #GMENLOC(28) = 1 : # XLS données uniquement
Endif
If !func OKXLS([M]PRTSRV)
 GMENLOC(31) = 1 : # Microsoft Excel Workbook
Endif
End

Subprog C_NBRCPY(VALEUR)
Variable Decimal VALEUR
If [M]NBRCPY<=1 & VALEUR>1 : [M]ASSCPY = 2 : Endif
[M]NBRCPY = VALEUR
Gosub GRISE_CPY
End

Subprog AS_ASSCPY(VALEUR)
Variable Integer  VALEUR
If [M]NBRCPY<=1 : mkstat = 1 : Endif
End

