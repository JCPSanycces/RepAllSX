####################################
## Bloc tableau 3
####################################
Subprog SAI_NBLIG7(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG7
mkstat = 0
zoncou = "NBLIG7"
SAVACT = GACTION : GACTION = "STD"
Call C_NBLIG7 From SUBNCSH
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "NBLIG7" : GZNUM = 0 : Endif
Gosub AFF From GSAISIE
If mkstat : End : Endif

## Zone USER
mkstat = 0
zoncou = "USER"
WCHAR = [M]USER(indice)
If varmode([M]USER,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "USER" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]USER(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "USER" : GZNUM = 190 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("AUS","",[M]USER(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "USER" : GZNUM = 190 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_USER([M]USER(indice)) From SUBNCSH
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "USER" : GZNUM = 190 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]USER(indice) or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_USER([M]USER(indice)) From SUBNCSH
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "USER" : GZNUM = 190 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone NBLIG7
mkstat = 0
zoncou = "NBLIG7"

End

