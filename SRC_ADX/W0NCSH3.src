# Superviseur
# Gestion du masque NCSH3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLIG5
mkstat = 0
zoncou = "NBLIG5"
indice = 0
status = 1
zoncou = "NBLIG5"
If varmode([M]NBLIG5,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG5" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG5
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG5 = nolign
   status = 75
   Call SAI_NBLIG5(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBLIG5 From SUBNCSH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBLIG5" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBLIG6
mkstat = 0
zoncou = "NBLIG6"
indice = 0
status = 1
zoncou = "NBLIG6"
If varmode([M]NBLIG6,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG6" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG6
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG6 = nolign
   status = 75
   Call SAI_NBLIG6(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBLIG6 From SUBNCSH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBLIG6" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBLIG7
mkstat = 0
zoncou = "NBLIG7"
indice = 0
status = 1
zoncou = "NBLIG7"
If varmode([M]NBLIG7,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG7" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG7
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG7 = nolign
   status = 75
   Call SAI_NBLIG7(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBLIG7 From SUBNCSH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBLIG7" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc tableau 4
####################################
IMPTBL = 1

## Zone NBLIG8
mkstat = 0
zoncou = "NBLIG8"
indice = 0
status = 1
zoncou = "NBLIG8"
If varmode([M]NBLIG8,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG8" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG8
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG8 = nolign
   status = 75
   Call SAI_NBLIG8(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBLIG8 From SUBNCSH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBLIG8" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLIG5(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG5
mkstat = 0
zoncou = "NBLIG5"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBLIG5 From SUBNCSH
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBLIG5" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone BPSNUM
mkstat = 0
zoncou = "BPSNUM"
WCHAR = [M]BPSNUM(indice)
If varmode([M]BPSNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPSNUM" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("BPS","!",[M]BPSNUM(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_BPSNUM([M]BPSNUM(indice)) From SUBNCSH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]BPSNUM(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_BPSNUM([M]BPSNUM(indice)) From SUBNCSH
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone SUPPCONTACT
mkstat = 0
zoncou = "SUPPCONTACT"
WCHAR = [M]SUPPCONTACT(indice)
If varmode([M]SUPPCONTACT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_SUPPCONTACT([M]SUPPCONTACT(indice)) From SUBNCSH
 GACTION = SAVACT
 If mkstat=1 : Raz [M]SUPPCONTACT(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "SUPPCONTACT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  Call CONTROLE("AIN","!",[M]SUPPCONTACT(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "SUPPCONTACT" : GZNUM = 1824 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]SUPPCONTACT(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_SUPPCONTACT([M]SUPPCONTACT(indice)) From SUBNCSH
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "SUPPCONTACT" : GZNUM = 1824 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone NBLIG5
mkstat = 0
zoncou = "NBLIG5"

End

