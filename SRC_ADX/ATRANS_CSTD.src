# Classe ATRANS


##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD": Gosub AREAD
      When "ACREATE": Gosub AUPDATE
      When "AUPDATE": Gosub AUPDATE
      When "ADELETE": Gosub ADELETE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


$AREAD
Return

$AUPDATE
Call PUT_CLOBFILE(this,"CONTENTS",this.CONTENTS)
Return

$ADELETE
Call DEL_CLOBFILE(this,"CONTENTS", "", this.CHP1, this.CHP2, this.LAN)
#Call DEL_CLOBFILE(this,"CONTENTS", this.CONTENTS, this.CHP1, this.CHP2, this.LAN)
Return

#-------------------------------------------------------------#
Funprog PUT_CLOBFILE(AINSTANCE,APRONAME,AVALUE)
Variable Instance AINSTANCE Using OBJECT
Value Char     APRONAME
Value Clbfile     AVALUE
If len(AVALUE) > 0
 Call WRITE_MESS(AVALUE)
Endif
End 0

#-------------------------------------------------------------#
Funprog GET_CLOBFILE(AINSTANCE,APRONAME,AVALUE,CHP1,CHP2,LAN,STAMP,FOLDR)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable    Clbfile     AVALUE
Value Shortint CHP1
Value Shortint CHP2
Value Char LAN
Value Char STAMP
Value Char FOLDR

Raz AVALUE
Call GET_MESS(AVALUE, "", CHP1, CHP2, LAN, 1, STAMP)
End 0

#-------------------------------------------------------------#
Funprog GET_CLOBCNT(AINSTANCE,APRONAME,AVALCNT,CHP1,CHP2,LAN,STAMP,FOLDR)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALCNT
Value Shortint CHP1
Value Shortint CHP2
Value Char LAN
Value Char STAMP
Value Char FOLDR
AVALCNT=""
End 0
#-------------------------------------------------------------#
Funprog GET_CLOBEXIST(AINSTANCE,APRONAME,AEXIST,CHP1,CHP2,LAN,STAMP,FOLDR)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Tinyint     AEXIST
Value Shortint CHP1
Value Shortint CHP2
Value Char LAN
Value Char STAMP
Value Char FOLDR
[L]AEXIST=1
End 0
#-------------------------------------------------------------#
Funprog DEL_CLOBFILE(AINSTANCE,APRONAME,AVALUE,CHP1,CHP2,LAN)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Value Clbfile     AVALUE
Value Shortint CHP1
Value Shortint CHP2
Value Char LAN
If len(AVALUE) = 0
 Call DELETE_ALL_MESS(CHP1, CHP2, LAN)
Else
 Call DELETE_MESS(AVALUE)
Endif
End 0

Subprog GET_MESS(RES, FOLDR, CHAP1, CHAP2, LANG, NUM, STAMP)
 Variable Clbfile RES
 Value Char FOLDR
 Value Integer CHAP1, CHAP2, NUM
 Value Char LANG, STAMP

 Local Integer STA, CNT, I, MES_LENGTH
 Local Char FNAME(250), CRITERIA(250), C(1), MES(255)
 Local Datetime DTIME

# DTIME = gdatetime$(STAMP)
 FNAME = "APLSTD"
 If FOLDR <> ""
  # ex: aydaix06:17007@SUPERV7
  FNAME = FOLDR + "." + FNAME
 Endif
 Local File =FNAME [AST]

 If CHAP2 = 0 : CHAP2 = CHAP1 : Endif

 CRITERIA = "LANCHP>=" + num$(CHAP1) + " and LANCHP<=" + num$(CHAP2)
 If LANG <> ""
   CRITERIA += " and LAN='" + LANG + "'"
 Endif
 If NUM >= 0
   CRITERIA += " and LANNUM>=" + num$(NUM)
 Endif
 If STAMP <> ""
   CRITERIA += " and UPDDATTIM>= gdatetime$('" + STAMP + "')"
 Endif
 Filter [AST] Where evalue(CRITERIA)
 For [AST]CLE
     CNT += 1
     Append RES, [AST]LAN + chr$(9) + num$([AST]LANCHP) + chr$(9) + num$([AST]LANNUM) + chr$(9)
     Append RES, num$([AST]LANORI) + chr$(9)
     Append RES, num$([AST]UPDDATTIM) + chr$(9)
#     MES = ctrans([AST]LANMES, chr$(13), "")
     MES = [AST]LANMES
     If instr(1, MES, chr$(10))
       # Replace newline by "\n" only if the text contains some
       MES_LENGTH = len(MES)
       For I = 1 To MES_LENGTH
         C = xgetchar(MES, I)
         If C = chr$(10)
           Append RES, "\n"
         Else
           Append RES, C
         Endif
       Next I
     Else
       Append RES, MES
     Endif
     Append RES, chr$(10)
 Next
# Append RES, "count=" + num$(CNT) + chr$(10)
 Close File [AST]
End

Subprog WRITE_MESS(MESSAGES)
Value Clbfile MESSAGES

 Local Char TR_OP(30) : TR_OP = "MES_UPD"

 Gosub TR_MES
End

Subprog DELETE_ALL_MESS(CHAP1, CHAP2, LANG)
 Value Integer CHAP1, CHAP2
 Value Char LANG

 If CHAP2 = 0 or CHAP2 < CHAP1 : CHAP2 = CHAP1 : Endif
 # by security we allow only modification of syracuse chapters
 If CHAP1 < 10031 or CHAP1 > 10046 or CHAP2 < 10031 or CHAP2 > 10046
   End
 Endif

 Local File APLSTD [AST]

 Call DEBTRANS From GLOCK
 Trbegin [AST]
  If LANG <> ""
    Delete [AST] Where [AST]LANCHP>=CHAP1 and [AST]LANCHP<=CHAP2 and [AST]LANNUM<>0 and [AST]LAN=LANG
  Else
    Delete [AST] Where [AST]LANCHP>=CHAP1 and [AST]LANCHP<=CHAP2 and [AST]LANNUM<>0
  Endif
  If fstat=1
   GOK=0 : Call RSTA("AST","") From GLOCK : Goto AB_TR_MES
  Elsif fstat>5
   GOK=0 : Call RSTA("AST","") From GLOCK : Goto AB_TR_MES
  Endif
 Commit
 Close File [AST]
End

$AB_TR_MES
Rollback
Close File [AST]
Return

Subprog DELETE_MESS(MESSAGES)
Value Clbfile MESSAGES

 Local Char TR_OP(30) : TR_OP = "MES_DEL"

 Gosub TR_MES
End

$TR_MES
 Local Integer CHP, LANNUM, POS1, POS2, I1, I2, I, J, C
 Local Char LAN(3), LANORI(3)
 Local Char LINE(255)
 Local Char MSG(150)

 Local Integer VALID
 Local File APLSTD [AST]

 Local Integer L : L = len(MESSAGES)
 Local Integer L2
 Local Integer CNT : CNT = 0
 Local Integer STA

 Call DEBTRANS From GLOCK
 Trbegin [AST]

 POS1 = 1
 Repeat
   POS2 = instr(POS1, MESSAGES, chr$(10))
   If POS2 = 0
    POS2 = L+1
   Endif
   L2 = POS2 - POS1
   LINE = mid$(MESSAGES, POS1, L2)

   I1 = 1
   I = 1
   Repeat
     I2 = instr(I1, LINE, chr$(9))
     If I2 = 0 : I2 = L2+1 : Endif
     Case I
       When 1: LAN = mid$(LINE, I1, I2-I1)
       When 2: CHP = val(mid$(LINE, I1, I2-I1))
       When 3:
         LANNUM = val(mid$(LINE, I1, I2-I1))
       When 4:
         LANORI = mid$(LINE, I1, I2-I1)
         MSG = mid$(LINE, I2+1, L2-I2)
     Endcase
     I1 = I2 + 1
     I += 1
   Until I > 4 or I2 = 0 or I1 > L2
   POS1 = POS2 + 1

   # for security reason we allow only modification of syracuse chapters
   VALID = CHP > 10030 and CHP < 10047 and LANNUM > 0 and len(LAN) > 0
   If VALID
    For J= 1 To 3
      C = ascii(xgetchar(LAN, J))
      # char between "A" and "Z"
      If C < 65 or C > 90 : VALID = 0 : Break : Endif
    Next
   Endif
   If VALID
     STA = func =TR_OP With (CHP, LAN, LANNUM, LANORI, MSG)
     If STA > 0
       GOK=0 : Call FSTA("AST") From GLOCK : Break
     Elsif STA = 0
       CNT += 1
     Endif

     If mod(CNT, 2000) = 0
       Commit
       Call DEBTRANS From GLOCK
       Trbegin [AST]
     Endif
   Endif
 Until POS2 = 0 or POS1 > L

 Commit
 Close File [AST]
Return

Funprog MES_UPD(CHP, LAN, LANNUM, LANORI, MSG)
 Value Integer CHP, LANNUM
 Value Char LAN, LANORI
 Value Char MSG

 Local Integer STA : STA = 0

 Read [AST]CLE = CHP;LANNUM;LAN
 If fstat
   # new message
   Raz [F:AST]
   [F:AST]LAN = LAN
   [F:AST]LANCHP = CHP
   [F:AST]LANNUM = LANNUM
   [F:AST]LANMES = MSG
   [F:AST]LANORI= LANORI
   [F:AST]UPDDATTIM= datetime$
   Call FLDCRE("AST") From OBJDIV
   Write [AST]
   STA = fstat
 Else
   # existing message
   If [F:AST]LANMES<>MSG or [F:AST]LANORI <> LANORI or ((MSG = "===" or MSG = "--") and [F:AST]LANORI <> "")
     If len(MSG) = 0
      Delete [AST]
     Else
#      [F:AST]LANMES = num$(len(MSG)) +":"+ num$(ascii(left$(MSG, 1)))
      [F:AST]LANMES = MSG
       # message has changed, we set LANORI to indicate that it has to be translated again
      If MSG = "--"
       [F:AST]LANORI = ""
      Else
       [F:AST]LANORI = LANORI
      Endif
      [F:AST]UPDDATTIM= datetime$
      Call FLDUPD("AST") From OBJDIV
      Rewrite [AST]
     Endif
     STA = fstat
   Else
     STA = -1
   Endif
 Endif
End STA

Subprog MES_DEL(CHP, LAN, LANNUM, LANORI, MSG)
 Value Integer CHP, LANNUM
 Value Char LAN, LANORI
 Value Char MSG

 Local Integer STA

  Read [AST]CLE = CHP;LANNUM;LAN
  If fstat
    STA = -1
    # does not exist
  Else
    # existing message
    Delete [AST]
    STA = fstat
  Endif
End STA

