# Issue 71276 - 2015-03-20 by SR : Versions
######################################################################################
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Char    WECCVALMAJ(GLONECS)
Local Char    WECCVALMIN(GLONICVVAL)
Local Char    PITM(GLONITM)

# Issue 107513 by GA 08/2015: keep EO BOM version
If [M:POI1]VCRTYPORI(nolign-1)=36 End Endif

Raz WECCVALMAJ
Raz WECCVALMIN
Raz PITM
If [F:ITM]ITMREF <> [M:POI1]ITMREF(nolign-1)
 Read [F:ITM]ITM0 = [M:POI1]ITMREF(nolign-1)
 If fstat : Raz [F:ITM] : Endif
Endif
# si version majeure trouvée et si article gere la version mineure : recherche derniere version mineure
If VALEUR  <> "" & [F:ITM]ECCSTO = 3
   WECCVALMAJ = VALEUR
   PITM = [F:ITM]ITMREF
   Gosub READECCMIN From STKACT
   [M:POI1]ECCVALMIN(nolign-1) = WECCVALMIN
   Affzo [M:POI1]ECCVALMIN(nolign-1)
Elsif VALEUR = "" & [M:POI1]ECCVALMIN(nolign-1) <> ""
      Raz   [M:POI1]ECCVALMIN(nolign-1)
      Affzo [M:POI1]ECCVALMIN(nolign-1)
Endif
End

######################################################################################
#                                                         hcb 71276 deb
Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> [M]BPSNUM (nolign-1)
   If dim([M]ECCVALMAJ) > 0
      Raz [M]ECCVALMAJ(nolign-1)
      Raz [M]ECCVALMIN(nolign-1)
      Raz [M]ECCSAIFLG(nolign-1)
   Endif
Endif
End
#                                                         hcb 71276 fin

######################################################################################
Subprog AM_TCTRNUM(VALEUR)
Variable Char    VALEUR()
Call UPDATE_CONTAINER(VALEUR,[M:POI1]TCTRQTY) From SUBPOIA    # 106430.n
End

Subprog AM_TCTRQTY(VALEUR)
Variable Decimal VALEUR
Call UPDATE_CONTAINER([M:POI1]TCTRNUM,VALEUR) From SUBPOIA    # 106430.n
End

######################################################################################
Subprog AM_HBPSNUM(VALEUR)
Variable Char VALEUR()
Local Integer STAT

If VALEUR=""
  Raz   [M:POI1]ORDMINAMT, ORDFREFRT
  Actzo [M:POI1]ORDMINAMT, ORDFREFRT
Else
  If [F:BPS]BPSNUM<>VALEUR
    Read [BPS] BPS0=VALEUR : If fstat Raz [F:BPS] : Endif
  Endif

  If GSYSCUR <> GLOCALDEV
    Call CONVERT (GSYSCUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,[M:POI1]ORDDAT,[F:BPS]ORDMINAMT,[M:POI1]ORDMINAMT,STAT) From TRTDEV
    Call CONVERT (GSYSCUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,[M:POI1]ORDDAT,[F:BPS]ORDFREFRT,[M:POI1]ORDFREFRT,STAT) From TRTDEV
  Else
  	[M:POI1]ORDMINAMT=[F:BPS]ORDMINAMT
  	[M:POI1]ORDFREFRT=[F:BPS]ORDFREFRT
  Endif
  Diszo [M:POI1]ORDMINAMT, ORDFREFRT
Endif

Affzo [M:POI1]ORDMINAMT, ORDFREFRT

End

Subprog AM_WEICAP(VALEUR)
Variable Decimal VALEUR

# 106430 - Update available total
Raz [M:POI1]WEIAVL
If VALEUR > 0 : [M:POI1]WEIAVL = VALEUR - [M:POI1]WEITOT : Endif
Affzo [M:POI1]WEIAVL

End

Subprog AM_VOLCAP(VALEUR)
Variable Decimal VALEUR

# 106430 - Update available total
Raz [M:POI1]VOLAVL
If VALEUR > 0 : [M:POI1]VOLAVL = VALEUR - [M:POI1]VOLTOT : Endif
Affzo [M:POI1]VOLAVL

End
