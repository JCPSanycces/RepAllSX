# Issue 71069 - 2016-09-12 by MUARN : pjt
Subprog AM_PJTH(VALEUR)
Variable Char    VALEUR()
#Gosub AM_PJTH From SUBPOHD
If [M:POI1]NBLIG = 0

  [M:POI1]PJTH=VALEUR

  If dim([M:POI1]NBAXE)>0
    If [M:POI1]NBAXE>0
        For I=1 To [M:POI1]NBAXE Raz [M:POI1]CCE(I-1) : Next
    Endif
    Call INIT_CCEH("POI1","NBAXE","POI") From TRTX3CPT
    If !GIMPORT : Affzo [M:POI1]10 : Endif
  Endif

Endif

End

# Issue 112754 - 2016-10-19 by MUARN : Services
######################################################################################
Subprog IB_ITMKND
GBOUT2=mess(343,198,1)
End

######################################################################################
Subprog AS_ITMKND(VALEUR)
Variable Integer VALEUR
Local Integer NOL : NOL = nolign-1
If [F:ITM]ITMREF <> [M:POI1]ITMREF(nolign-1)
 Read [F:ITM]ITM0 = [M:POI1]ITMREF(nolign-1)
 If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]SCSFLG = 2 : GMENLOC(1) = 1 : Endif
If VALEUR = 1 : mkstat = 2 : Endif
If GMODIF<>2 | [M:POI1]LINFLG(nolign-1)<>0
  mkstat=2
Endif
End

######################################################################################
Subprog C_ITMKND(VALEUR)
Variable Integer VALEUR
Local Integer NOL : NOL = nolign-1
[M:POI1]ITMKND(NOL) = VALEUR
End

######################################################################################
Subprog AM_ITMKND(VALEUR)
Variable Integer VALEUR
Local Integer NOL : NOL = nolign-1
If VALEUR = 2
  Look [BPD] BPD0=[M:POI1]BPSNUM(NOL);[F:BPS]BPAADD
  If !fstat
    [M:POI1]SCOADD(NOL)=[F:BPS]BPAADD
  Else
    Raz [M:POI1]SCOADD(NOL)
  Endif
Else
  Raz [M:POI1]SCOADD(NOL)
Endif
End
#

######################################################################################
Subprog B2_ITMKND(VALEUR)
Variable Integer VALEUR
#--------------------------------------#
# Avant exécution du bouton PEC besoin #
#--------------------------------------#
GPECBOUT1 = 2
End
