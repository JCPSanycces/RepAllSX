    When  7 : Raz [M:POI1]LINACC7 (NOL)
    When  8 : Raz [M:POI1]LINACC8 (NOL)
    When  9 : Raz [M:POI1]LINACC9 (NOL)
    When 10 : Raz [M:POI1]LINACC10(NOL)
  Endcase
Next J
Return


