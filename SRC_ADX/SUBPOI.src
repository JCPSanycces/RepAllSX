$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE  Return : Endif
Call INIT_CCE(VALEUR,AXE,"POID","[M:POI1]LINACC",nolign-1) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
If GMODIF<>2  mkstat=2 : Return : Endif
Call SAIS_CCE(VALEUR,AXE,"[M:POI1]LINACC","") From TRTX3CPT
# Issue 116952 - 2016-06-10 by MUARN : pour l'alimentation avec sections précédentes
If !mkstat
   If VALEUR=""
      Call INIT_CCE(VALEUR,AXE,"POID","[M:POI1]LINACC",nolign-1) From TRTX3CPT
   Endif
Endif
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"[M:POI1]LINACC",GFINRSP,[M:POI1]ORDDAT) From TRTX3CPT
Return

Subprog AS_QUAFLG(VALEUR)
#--------------------------------#
# Avant saisie code ctrl qualité #
#--------------------------------#
Variable Integer VALEUR
If [F:ITP]ITMREF<>[M:POI1]ITMREF(nolign-1) | [F:ITP]BPSNUM<>[M:POI1]BPSNUM(nolign-1)
  Read [ITP] ITP0=[M:POI1]ITMREF(nolign-1);[M:POI1]BPSNUM(nolign-1)
  If fstat Raz [F:ITP]
    If [F:ITM]ITMREF<>[M:POI1]ITMREF(nolign-1)
      Read [ITM] ITM0=[M:POI1]ITMREF(nolign-1)
      If fstat  Raz [F:ITM] : Endif
    Endif
    If [F:ITF]ITMREF<>[M:POI1]ITMREF(nolign-1) | [F:ITF]STOFCY<>[M:POI1]PRHFCY(nolign-1)
      Read [ITF] ITF0=[M:POI1]ITMREF(nolign-1);[M:POI1]PRHFCY(nolign-1)
      If fstat  Raz [F:ITF] : Endif
    Endif
    [F:ITP]QUAFLG=[F:ITF]QUAFLG
  Endif
Endif
If [F:ITP]QUAFLG=2 mkstat=2 : Endif
If [M:POI1]STOMGTCOD(nolign-1)<2 VALEUR=1 : mkstat=2 : End : Endif
End

Subprog D_LINBUY(VALEUR)
#------------------------------------#
# Initialisation code acheteur ligne #
