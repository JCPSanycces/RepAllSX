#<AdxTL>@(#)1.0.0.0 $Revision$
########################################################################
# SUBPOI : Gestion des commandes d'achat par article      MBT 03/02/98 #
#          Modifié                                        HN Juil 2003 #
# -------------------------------------------------------------------- #
# Traitement sur champ "Call" de l'objet "POI"                         #
# Le traitement des actions "Gosub" se trouvent dans le SUBPOIA        #
########################################################################
$ACTION
#---------------------------------#
# Actions de l'objet POI (GOBJET) #
#---------------------------------#
Case ACTION
 When "DEFTRANS"    : Gosub DEFTRANS   From SUBPOIA
 When "VARIANTE"    : Gosub VARIANTE   From SUBPOIA
 When "SETTRANS"    : Gosub SETTRANS   From SUBPOIA
 When "FILTRE"      : Gosub FILTRE     From SUBPOIA
 When "BOITE"       : Gosub BOITE      From SUBPOIA
 When "AV_IMPRIME"  : Gosub AV_IMPRIME From SUBPOIA
 When "OUVRE"       : Gosub OUVRE      From SUBPOIA
 When "SETBOUT"     : Gosub SETBOUT    From SUBPOIA
 When "AVANTBOUT"   : Gosub AVANTBOUT  From SUBPOIA
 When "EXEBOUT"     : Gosub EXEBOUT    From SUBPOIA
 When "STATUT"      : Gosub STATUT     From SUBPOIA
 When "EXEACT"      : Gosub EXEACT     From SUBPOIA
 When "APRES_CHOI"  : Gosub APRES_CHOI From SUBPOIA
 When "RAZCRE"      : Gosub RAZCRE     From SUBPOIA
 When "INICRE"      : Gosub INICRE     From SUBPOIA
 When "APRES_CRE"   : Gosub APRES_CRE  From SUBPOIA
 When "LIENS"       : Gosub LIENS      From SUBPOIA
 When "LIENS2"      : Gosub LIENS2     From SUBPOIA
 When "VERIF_CRE"   : Gosub VERIF_CRE  From SUBPOIA
 When "VERIF_MOD"   : Gosub VERIF_MOD  From SUBPOIA
 When "AVANT_MOD"   : Gosub AVANT_MOD  From SUBPOIA
 When "DEBUT_MOD"   : Gosub DEBUT_MOD  From SUBPOIA
 When "APRES_MOD"   : Gosub APRES_MOD  From SUBPOIA
 When "ANNULE"      : Gosub ANNULE     From SUBPOIA
 When "ABANDON"     : Gosub ABANDON    From SUBPOIA
 When "FERME"       : Gosub FERME      From SUBPOIA
#---------------------------#
# Actions champs modèlisées #
#---------------------------#
 When "AB1_ITMDES"  : Gosub AB1_ITMDES
 When "BB1_ITMDES"  : Gosub BB1_ITMDES
 When "AB1_ITMDES1" : Gosub AB1_ITMDES
 When "BB1_ITMDES1" : Gosub BB1_ITMDES
 When "AAM_PRHFCY"  : Gosub AAM_PRHFCY
 When "BAM_PRHFCY"  : Gosub BAM_PRHFCY
 When "AB1_SCOADD"  : Gosub AB1_SCOADD
 When "BB1_SCOADD"  : Gosub BB1_SCOADD
 When Default
Endcase
Return


Subprog C_POHFCY(VALEUR)
#------------------------------------------------------------#
# Contrôle site de commande : vérif si enregistrement existe #
#------------------------------------------------------------#
Variable Char    VALEUR()
If GREP<>"C"
  Look [POI] POI0=[M:POI1]USR;1
  If fstat  GMESSAGE=mess(218,194,1) : mkstat=1 : End : Endif
Endif
End

Subprog AM_POHFCY(VALEUR)
#---------------------------------------------------#
#      Après modification du site de commande       #
# ------------------------------------------------- #
# Rechargement GSOCIETE : Société juridique         #
#              GLOCALDEV: Devise société juridique  #
#              GFINRSP  : Site financier            #
#              GFCY     : Site commande             #
#              GRCPFCY  : Site réception par défaut #
# Récupération des paramètres achats                #
# Rechargement code acheteur si filtre = oui        #
#---------------------------------------------------#
Variable Char     VALEUR
GFCY=VALEUR : Gosub CHARG_PARAM From SUBPOIA
[M:POI1]BUY=GUSER
If GPURGRUDIS=1 [M:POI1]TARGRP=1   Else [M:POI1]TARGRP=2   : Endif
If GPURGRUDIS=3 Actzo [POI1]TARGRP Else Diszo [POI1]TARGRP : Endif
If !GIMPORT
  Affzo [POI1]BUY, TARGRP
Endif
#----- Effacement tableau des sections entête -----#
If dim([M:POI1]NBAXE)>0 & [M:POI1]NBAXE>0
  [M:POI1]POHFCY=VALEUR
  Effzo [POI1]10 : Affzo [POI1]10 : Setmok [POI1] With 0
Endif
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL From SUBPOIA
#106430.n  Set the Currency based on the new site
[M:POI1]TOTCUR  = GLOCALDEV : Affzo [M:POI1]TOTCUR
If [M:POI1]HBPSNUM<>""
  If GSYSCUR <> GLOCALDEV
    Local Integer STAT
    Call CONVERT (GSYSCUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,[M:POI1]ORDDAT,[F:BPS]ORDMINAMT,[M:POI1]ORDMINAMT,STAT) From TRTDEV
    Call CONVERT (GSYSCUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,[M:POI1]ORDDAT,[F:BPS]ORDFREFRT,[M:POI1]ORDFREFRT,STAT) From TRTDEV
  Else
    [M:POI1]ORDMINAMT = [F:BPS]ORDMINAMT
    [M:POI1]ORDFREFRT = [F:BPS]ORDFREFRT
  Endif
Endif
Affzo [M:POI1]ORDMINAMT,ORDFREFRT

End

Subprog C_ORDDAT(VALEUR)
#---------------------------------------------------------#
# Contrôle date commande : vérif si enregistrement existe #
#---------------------------------------------------------#
Variable Date    VALEUR
If GREP<>"C"
  Look [POI] POI0=[M:POI1]USR;1
  If fstat  GMESSAGE=mess(218,194,1) : mkstat=1 : End : Endif
Endif
#-----
[M:POI1]ORDDAT=VALEUR : # à cause de l'action PAMPLIFLG
End

Subprog C_BUY(VALEUR)
#------------------------#
# Contrôle code acheteur #
#------------------------#
Variable Char     VALEUR
If GBUYFLT=2 & VALEUR="" mkstat=1 : Endif
End

Subprog C_NBAXE
#----------------#
# Contrôle NBAXE #
#----------------#
If GREP<>"C"  : # Vérif si enregistrement existe
  Look [POI] POI0=[M:POI1]USR;1
  If fstat  GMESSAGE=mess(218,194,1) : mkstat=1 : End : Endif
Endif
#----- Test si sortie du tableau -----#
If !find(status,1,4,5,20,21,26,92,93) | GIMPORT End : Endif
#----- Contrôle sections obligatoires -----#
If [M:POI1]NBAXE>0 & GHEADIE=1 : # Sections d'entête saisissables
  Local Integer I
  For I=1 To [M:POI1]NBAXE
    Call CTRL_CCEH([M:POI1]CCE(I-1),I,GFINRSP,date$) From TRTX3CPT
    If mkstat  Break : Endif
  Next I
Endif
End

Subprog AM_PRTFLG(VALEUR)
#-------------------------------------------------#
# Après modification de l'indicateur d'impression #
#-------------------------------------------------#
Variable Integer VALEUR
If VALEUR=2
  Actzo [POI1]DOCNAM, PRTCOD
Else
  #sr 08.11 Demande 74804
  Effzo [POI1]DOCNAM, PRTCOD, PRTSRV, PRTNAM, PRTCOP
  Diszo [POI1]DOCNAM, PRTCOD
Endif
End

Subprog C_DOCNAM(VALEUR)
#--------------------#
# Contrôle code état #
#--------------------#
Variable Char    VALEUR()
#----- Si impression à Oui, le code état par défaut est obligatoire -----#
If [M:POI1]PRTFLG=2 & VALEUR=""
  GMESSAGE=mess(10,123,1) : mkstat=1 : End
Endif
End

Subprog AM_DOCNAM(VALEUR)
#--------------------------#
# Après modif du code état #
#--------------------------#
Variable Char    VALEUR()
Call AIMDEF([M:POI1]PRTCOD,VALEUR,GBIDC1,GBIDC2)  From IMPRIME
Call CONTROLE("AIM","!A",[M:POI1]PRTCOD,"",mkstat) From CONTOBJ
If mkstat
  [M:POI1]PRTCOD="" : Raz mkstat, GMESSAGE, GERR
Else
  [M:POI1]PRTSRV=[F:AIM]PRTSRV
  [M:POI1]PRTNAM=[F:AIM]PRTNAM
  # sr 08.11 Demande 74804
  [M:POI1]PRTCOP=func TRTVENIMP.GET_NBRCPY_AIM([M:POI1]PRTCOD)
  Affzo [POI1]PRTCOD
  If dim([M:POI1]ZPRTCOD)>0  Affzo [POI1]ZPRTCOD : Endif
  Affzo [POI1]PRTSRV, PRTNAM
Endif
End

Subprog C_PRTCOD(VALEUR)
#-----------------------------------#
# Contrôle destination (imprimante) #
#-----------------------------------#
Variable Char    VALEUR()
#----- Si impression à Oui, la destination par défaut est obligatoire -----#
If [M:POI1]PRTFLG=2 & VALEUR=""
  GMESSAGE=mess(10,123,1) : mkstat=1 : End
Endif
End

Subprog AM_PRTCOD(VALEUR)
#--------------------------------------#
# Après modification de la destination #
#--------------------------------------#
Variable Char    VALEUR()
#----- Affichage du serveur et de l'imprimante -----#
[M:POI1]PRTSRV=[F:AIM]PRTSRV
[M:POI1]PRTNAM=[F:AIM]PRTNAM
# sr 08.11 Demande 74804
[M:POI1]PRTCOP=func TRTVENIMP.GET_NBRCPY_AIM(VALEUR)
Affzo [POI1]PRTSRV, PRTNAM
End

Subprog C_NBLIG
#--------------------------------------------------------#
# Contrôle sur numéro de ligne                           #
# Affichage des lignes créées par le picking des besoins #
#--------------------------------------------------------#
If GREP<>"C" : # Vérif si enregistrement exite
  Look [POI] POI0=[M:POI1]USR;1
  If fstat  GMESSAGE=mess(218,194,1) : mkstat=2 : End : Endif
Endif
If [M:POI1]NBCRELIG>0
  [M:POI1]NBLIG+=[M:POI1]NBCRELIG
  If sigma(I=0,[M:POI1]NBLIG-1,[M:POI1]LINTYP(I)>1)
    Raz GBIDI2
    Local Shortint NOL : NOL=max(nolign-2,0)
    For I=NOL To [M:POI1]NBCRELIG+NOL-1
      If [M:POI1]VCRTYPORI(I)=[M:POI1]VCRTYPORI(I+1) &
&        [M:POI1]VCRNUMORI(I)=[M:POI1]VCRNUMORI(I+1) &
&        [M:POI1]LINTYP(I)>=3 & [M:POI1]LINTYP(I+1)>=2
        GBIDI1=1
        GBIDI2=[M:POI1]SRTLIN(I)
        [M:POI1]SRTLIN(I)  =[M:POI1]SRTLIN(I+1)
        [M:POI1]SRTLIN(I+1)=GBIDI2
      Endif
    Next I
    If GBIDI1
      Sorta [M:POI1]NBLIG [M:POI1]NBLIG Order By [M:POI1]SRTLIN(indice),
&                                                [M:POI1]VCRTYPORI(indice),
&                                                [M:POI1]LINTYP(indice)
    Endif
  Endif
  Affzo [POI1]5-20 : Raz [M:POI1]NBCRELIG
Endif
GMODIF=2
Local Integer NOL
If status=65                : # Annulation simple
   NOL=nolign-1 : Gosub TEST_ANU
Elsif status=68 | status=83 : # Annulation multiple
   For NOL=nolign-1 To nolign1-1
       Gosub TEST_ANU
       If mkstat : Break : Endif
   Next NOL
Endif
If status=75             NOL=nolign-1 : Gosub TEST_MOD    : Endif
If status=73 | status=82 NOL=nolign-1 : Gosub TEST_INSERT : Endif
If find(status,1,4,5,20,21,26,92,93)    Gosub TEST_VALID  : Endif
End

$TEST_MOD
#------------------------------------#
# Test pour modification d'une ligne #
#------------------------------------#
GMODIF=2
Return

$TEST_ANU
#----------------------------------#
# Test pour annulation de la ligne #
#----------------------------------#
#----- Suppression ligne d'un service/composant interdite -----#
If [M:POI1]LINTYP(NOL)>2   # Issue 84500 GA 10/2012 avant  [M:POI1]LINTYP(NOL)=3
  GMESSAGE=mess(386,194,1) : mkstat=2 : GMODIF=2 : Return
Endif
Return

TEST_INSERT
#---------------------------------#
# Test pour insertion d'une ligne #
#---------------------------------#
If dim([M:POI1]ITMREF)<[M:POI1]NBLIG+2
  GMESSAGE=mess(122,199,1) : mkstat=2
Endif
#-----
If [M:POI1]LINTYP(NOL)>2
  GMESSAGE=mess(97,192,1) : mkstat=2 : GMODIF=1
Endif
Return

$TEST_VALID
#---------------------------------#
# Test à la validation des lignes #
#---------------------------------#
If [M:POI1]NBLIG>0
  Local Shortint I
  I=find("",[M:POI1]PRHFCY(0..[M:POI1]NBLIG-1)) : # Test ligne vide
  If I<>0
    Dela I-1,1,[M:POI1]NBLIG-1 [M:POI1]NBLIG : [M:POI1]NBLIG-=1
  Endif
Endif
Return

Subprog AS_NBLIG
#------------------#
# Avant zone NBLIG #
#------------------#
If [M:POI1]NBLIG=1
  If GNBAUZ>1 Diszo [POI1]POHFCY : Endif
  Diszo [POI1]BUY
Elsif [M:POI1]NBLIG=0
  If GNBAUZ>1 Actzo [POI1]POHFCY : Endif
  Actzo [POI1]BUY
Endif
#-----
If GREP<>"C" : # Vérif si enregistrement exite
  Look [POI] POI0=[M:POI1]USR;1
  If fstat  End : Endif
Endif
End

Subprog IB_NBLIG
#------------------------------------------#
# Init bouton: Activation bouton "Besoins" #
#------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
If [M:POI1]CUR(nolign-1)<>"" & [M:POI1]LINTYP(nolign-1)<>2
  GBOUT3=mess(386,198,1)  : # Explication du prix (sauf pour composé)
Endif
#----- Test maximum ligne atteint -----#
If dim([M:POI1]ITMREF)<nolign | dim([M:POI1]ITMREF)-1<=[M:POI1]NBLIG End : Endif
If [M:POI1]NBLIG=0 & [M:POI1]PCLFLG=2 & [M:POI1]POHFCY<>""
  [M:POI1]PCLFLG=1
  #----- Appel du préchargement automatique (supprimé !) -----#
  # Call B2_NBLIG           : # Appel préchargement si 1ère fois
Endif
If [M:POI1]POHFCY<>""
  [M:POI1]REFART="*****"
  GBOUT2=mess(343,198,1)
Endif
End

Subprog AVANT_NBLIG
#-------------------------------------------------------------#
# Avant ligne : Si suppression ligne, suppress. besoins ligne #
#-------------------------------------------------------------#
If [M:POI1]ITMREF(nolign-1)="" [M:POI1]LINFLG(nolign-1)=0 : Endif

# Issue 83041 - 2012-06-21 by MUARN : echap en saisie article après PEC
#CTLPOICOU permet de connaitre la saisie en cours de PEC si la ligne n'est pas validée en fin de PEC
#dans le cas par exemple ou des axes doivent être renseingés
If [M:POI1]ITMREF(nolign-1)="" Raz [M:POI1]CTLPOICOU Endif

If (status=65 | status=68 | status=83)
  Gosub EFFAC_LIG_PWRKORDERS From SUBPOIA : Raz [M:POI1]CTLPOICOU
Endif

# 106430 - Clear the line weight for this line
If [M:POI1]ITMREF(nolign-1)<>""
  # Subtract this line from the totals
  [M:POI1]TOTCOST -= [M:POI1]LINAMTHCUR(nolign-1)
  [M:POI1]WEITOT  -= [M:POI1]LINTCTRWEI(nolign-1)
  [M:POI1]VOLTOT  -= [M:POI1]LINTCTRVOL(nolign-1)
  If [M:POI1]WEICAP > 0 : [M:POI1]WEIAVL = [M:POI1]WEICAP - [M:POI1]WEITOT : Endif
  If [M:POI1]VOLCAP > 0 : [M:POI1]VOLAVL = [M:POI1]VOLCAP - [M:POI1]VOLTOT : Endif
  Affzo [M:POI1]WEITOT, VOLTOT, WEIAVL, VOLAVL, TOTCOST
  Raz [M:POI1]LINWEI(nolign-1), LINVOL(nolign-1), LINTCTRWEI(nolign-1), LINTCTRVOL(nolign-1)
Endif

End

Subprog APRES_NBLIG
#-------------#
# Après ligne #
#-------------#
Local Shortint NOL : NOL=nolign-1
#----- Si suppression ligne -----#
If status=65 | status=68 | status=83
  #----- Suppression des lignes liées au composé (produit fini) -----#
  If NOL<[M:POI1]NBLIG-1 & [M:POI1]LINTYP(NOL+1)>2
    Local Shortint I : I=NOL+1
    While [M:POI1]LINTYP(I)>2
      nolign=I+1 : Call AVANT_NBLIG From SUBPOI
      Dela I,1,[M:POI1]NBLIG-1 [M:POI1]NBLIG : [M:POI1]NBLIG-=1
    Wend
    Affzo [POI1]20
    nolign=NOL+1
  Endif
  #-----
  End
Endif
#----- Abandon de la saisie ligne par escape ou click sur listes de gauche -----#
If status=6 | status=7 | status=27 | status=28 | [M:POI1]ITMREF(NOL)=""
  If [M:POI1]POILIN(NOL)=0 & [M:POI1]CTLPOICOU<>0
    [M:POI1]POILIN(NOL)=[M:POI1]CTLPOICOU
    Gosub EFFAC_LIG_PWRKORDERS From SUBPOIA
    Raz [M:POI1]POILIN(NOL), [M:POI1]CTLPOICOU
  Endif
  End
Endif
#----- Si modif du composé, répercution sur les composants ? -----#
If [M:POI1]LINTYP(NOL)=2
  #----- Répercussion site réception, code adresse et date réception prévue -----#
  Local Integer I : I=NOL+1
  While [M:POI1]LINTYP(I)>2 & I<[M:POI1]NBLIG
    #-----
    If [M:POI1]PRHFCY(I)<>[M:POI1]PRHFCY(NOL) | [M:POI1]FCYADD(I)<>[M:POI1]FCYADD(NOL)
      [M:POI1]PRHFCY(I)=[M:POI1]PRHFCY(NOL)
      [M:POI1]FCYADD(I)=[M:POI1]FCYADD(NOL)
      [M:POI1]UPDFLG(I)=1
      #If func AFNC.ACTIV("PTX") # Issue 93038 GA 10/2013 ssi [M:POI1]LINTYP(I)<>2
        Call ALIVATCOD(2,[M:POI1]BPSNUM(I),[M:POI1]ITMREF(I),"POI1",I) From TRTX3
      #Endif
      If !GIMPORT  Affzo [POI1]PRHFCY(I), FCYADD(I) : Endif
    Endif
    #-----
    If [M:POI1]EXTRCPDAT(I)<>[M:POI1]EXTRCPDAT(NOL)
      [M:POI1]EXTRCPDAT(I)=[M:POI1]EXTRCPDAT(NOL)
      [M:POI1]UPDFLG(I)=1
      If !GIMPORT  Affzo [POI1]EXTRCPDAT(I) : Endif
    Endif
    #-----
    I+=1
  Wend
  #----- Si modif qté -----#
  If [M:POI1]PREQTYPUU(NOL)<>[M:POI1]QTYPUU(NOL)
    Local Integer OK : OK=2
    Call OUINON(mess(14,191,1),OK) From GESECRAN
    If OK=2
      Local Integer SAV_LINFLG
      Local Libelle WTARFLG
      Local Decimal WQTE
      Local Integer I : I=NOL+1
      While [M:POI1]LINTYP(I)>2 & I<[M:POI1]NBLIG
        If [M:POI1]LIKQTYCOE(I)<>0
          WQTE=[M:POI1]QTYSTU(NOL)*[M:POI1]LIKQTYCOE(I)
          Call QTEARR(WQTE,[M:POI1]STU(I)) From TRTDIV
          nolign=I+1
          Call AVANT_NBLIG     From SUBPOI
          SAV_LINFLG=[M:POI1]LINFLG(I)
          #----- Si autres lignes, calcul tarif en conséquence sans question -----#
          If I>NOL+1
            If WTARFLG=2  [M:POI1]LINFLG(I)=0  Else  [M:POI1]LINFLG(I)=3 : Endif
          Endif
          #-----
          Call AM_QTYSTU(WQTE) From SUBPOI
          [M:POI1]LINFLG(I)=SAV_LINFLG
          #----- Si 1ère ligne traitée, indicateur pour calcul tarif autres lignes -----#
          If I=NOL+1
            WTARFLG=[M:POI1]LINFLG(I) : # 2=INI_TARIF
          Endif
          #-----
          Call APRES_NBLIG     From SUBPOI
          [M:POI1]UPDFLG(I)=1
        Endif
        I+=1
      Wend
      Affzo [POI1]20
      nolign=NOL+1
    Endif
  Endif
  #-----
Endif
[M:POI1]PREQTYPUU(NOL)=[M:POI1]QTYPUU(NOL)
#-----
Raz [M:POI1]CTLPOICOU
#----- Calcul ligne -----#
If [M:POI1]LINTYP(NOL)<>2 : # Si ce n'est pas le composé (produit fini)
  Local Char     VAT(GLONVAT)(3)
  VAT(0)=VAT1(NOL) : VAT(1)=VAT2(NOL) : VAT(2)=VAT3(NOL)
  [M:POI1]LINAMT(NOL)=[M:POI1]NETPRI(NOL)*[M:POI1]QTYUOM(NOL)
  Call ARRDEV([M:POI1]LINAMT(NOL),[M:POI1]CUR(NOL)) From TRTDIV
  #------------------------------------------------------------------#
  # Point d'entrée CLCMNTPOH pour recalcul Montant HT ligne commande #
  # ---------------------------------------------------------------- #
  # Variables utilisables par le point d'entrée                      #
  #                                                                  #
  # WLINAMT : Montant HT ligne commande à recalculer                 #
  # WCUR    : Devise dans laquelle est exprimé le montant            #
  # WABRMSK : Abréviation du masque contenant les lignes de commande #
  # NOL     : Indice de la ligne courante                            #
  #------------------------------------------------------------------#
  Local Decimal  WLINAMT       : WLINAMT =[M:POI1]LINAMT(NOL)
  Local Char     WCUR(GLONCUR) : WCUR    =[M:POI1]CUR(NOL)
  Local Char     WABRMSK(4)    : WABRMSK ="POI1"
  Local Shortint SAVXZSNOL
  Local Decimal  WCLCAMT(1..7)
  SAVXZSNOL=NOL
  Gosub POINT_CLCMNTPOH From TRTACHCDE1
  NOL=SAVXZSNOL
  If [M:POI1]LINAMT(NOL)<>WLINAMT
    [M:POI1]LINAMT(NOL)=WLINAMT
    Call ARRDEV([M:POI1]LINAMT(NOL),[M:POI1]CUR(NOL)) From TRTDIV
  Endif
  #-----
  Call ALICLCAMT2([M:POI1]ITMREF(NOL),[M:POI1]QTYUOM(NOL),NOL,"POI1",WCLCAMT) From TRTX3
  [M:POI1]CLCAMT1(NOL)=WCLCAMT(1)
  [M:POI1]CLCAMT2(NOL)=WCLCAMT(2)
  [M:POI1]CLCAMT3(NOL)=WCLCAMT(3)
  If dim([M:POI1]CLCAMT4)>0  [M:POI1]CLCAMT4(NOL)=WCLCAMT(4) : Endif
  If dim([M:POI1]CLCAMT5)>0  [M:POI1]CLCAMT5(NOL)=WCLCAMT(5) : Endif
  If dim([M:POI1]CLCAMT6)>0  [M:POI1]CLCAMT6(NOL)=WCLCAMT(6) : Endif
  If dim([M:POI1]CLCAMT7)>0  [M:POI1]CLCAMT7(NOL)=WCLCAMT(7) : Endif
  Call CLCTAXEMNT2([M:POI1]LINAMT(NOL),VAT,1,GSOCIETE,[M:POI1]ORDDAT,WCLCAMT,
&                  [M:POI1]LINATIAMT(NOL)) From TRTX3
  Call ARRDEV([M:POI1]LINATIAMT(NOL),[M:POI1]CUR(NOL)) From TRTDIV
Endif

# 106430 - Add this line back into the totals
Call UPDATE_LINVOLWEI From SUBPOIA
[M:POI1]TOTCOST += [M:POI1]LINAMTHCUR(nolign-1)
[M:POI1]WEITOT  += [M:POI1]LINTCTRWEI(nolign-1)
[M:POI1]VOLTOT  += [M:POI1]LINTCTRVOL(nolign-1)
If [M:POI1]WEICAP > 0 : [M:POI1]WEIAVL = [M:POI1]WEICAP - [M:POI1]WEITOT : Endif
If [M:POI1]VOLCAP > 0 : [M:POI1]VOLAVL = [M:POI1]VOLCAP - [M:POI1]VOLTOT : Endif
Affzo [M:POI1]WEITOT, VOLTOT, WEIAVL, VOLAVL, TOTCOST

#----- Si nouvelle ligne +1 sur cteur et chargement dans la ligne -----#
If [M:POI1]LINFLG(NOL)=0 [M:POI1]POICOU+=1
                         [M:POI1]POILIN(NOL)=[M:POI1]POICOU : Endif
#-----
[M:POI1]UPDFLG(NOL)=1 : [M:POI1]LINFLG(NOL)=1
Affzo [POI1]EXTRCPDAT(NOL), LINAMT(NOL)
nolign=NOL+1 : # Le nolign peut être perdu à cause de l'Affzo !
End

# Issue 112754 - 2016-11-17 by SR : PEC du paramètre Ouverture automatque des besoins
######################################################################################
Subprog B2_NBLIG
#--------------------------------------#
# Avant exécution du bouton PEC besoin #
#--------------------------------------#
GPECBOUT1 = 2
End
# End issue 112754

Subprog IB_ITMREF
#-----------------------------#
# Activation bouton "Besoins" #
#-----------------------------#
Raz GBOUT3, GBOUT4, GBOUT5
GBOUT2=mess(343,198,1)
End

Subprog AS_ITMREF(VALEUR)
#--------------------------------------#
# Avant saisie de la référence article #
#--------------------------------------#
Variable Char    VALEUR()
If GMODIF<>2 | [M:POI1]LINFLG(nolign-1)<>0 mkstat=2 : End : Endif
Local Shortint I
Raz [M:POI1]ORICRY(nolign-1), [M:POI1]LINBUY(nolign-1)
If GACTDEB=2  Raz [M:POI1]EECINCRAT(nolign-1) : Endif
If dim([M:POI1]CCE1)>0
  For I=1 To GOPTCANA
    Case I
      When 1 : Raz [M:POI1]CCE1(nolign-1)
      When 2 : Raz [M:POI1]CCE2(nolign-1)
      When 3 : Raz [M:POI1]CCE3(nolign-1)
      When 4 : Raz [M:POI1]CCE4(nolign-1)
      When 5 : Raz [M:POI1]CCE5(nolign-1)
      When 6 : Raz [M:POI1]CCE6(nolign-1)
      When 7 : Raz [M:POI1]CCE7(nolign-1)
      When 8 : Raz [M:POI1]CCE8(nolign-1)
      When 9 : Raz [M:POI1]CCE9(nolign-1)
    Endcase
  Next I
Endif
End

Subprog C_ITMREF(VALEUR)
#-------------------------------------------------#
# Contrôle sur référence article :                #
# Article avec DA obligatoire                     #
# Existence article-site si article géré en stock #
# Code acheteur sur article ou article-site       #
#-------------------------------------------------#
Variable Char    VALEUR()
#----- Pas de contrôle si picking besoins depuis la sasie de la référence article -----#
If [M:POI1]NBCRELIG>0  End : Endif
#-----
If [F:ITM]PRQFLG=2 & [M:POI1]RETQTYSTU(nolign-1)=0
                   GMESSAGE=mess(164,194,1) : mkstat=1 : End : Endif : # DA obligatoire
If [M:POI1]PRHFCY(nolign-1)=""
  [M:POI1]PRHFCY(nolign-1)=GRCPFCY
Endif
#----- Chargement code adresse par défaut -----#
If [F:FCY]FCY<>[M:POI1]PRHFCY(nolign-1)
  Read [FCY] FCY0=[M:POI1]PRHFCY(nolign-1) : If fstat Raz [F:FCY] : Endif
Endif
[M:POI1]FCYADD(nolign-1)=[F:FCY]BPAADD
#-----
If [F:ITM]STOMGTCOD>1
  Call CTLITMFCY(VALEUR,[M:POI1]PRHFCY(nolign-1),mkstat) From TRTACHCTL1
  If mkstat<>0 End : Endif
  Elsif GRCPFCY="" [M:POI1]PRHFCY(nolign-1)=GFCY
Endif
Call CTLITMBUY(VALEUR,[M:POI1]BUY,mkstat) From TRTACHCTL1
End

Subprog AM_ITMREF(VALEUR)
#-------------------------------------------------------#
#   Contrôle sur référence article après modification   #
# Si ligne générée par le picking des besoins alors Fin #
#-------------------------------------------------------#
Variable Char    VALEUR()
Local Shortint   NOL : NOL=nolign-1
Local Char WITMREF(GLONITM) : WITMREF=VALEUR # Issue 112754 - 2016-10-20 by MUARN : service
# Issue X3-55891 - 2018-08-23 by SR : Données déclinées par site
Local Integer WITMBPS
Local Char    WBPSNUM(GLONBPS)

If VALEUR="" : End : Endif   # Issue 82533 GA 06/2012

If [M:POI1]RETQTYSTU(NOL)>0
  If [M:POI1]NBCRELIG>0  GMODIF=1 : Endif
  Affzo [POI1]ITMDES(NOL),PRHFCY(NOL),FCYADD(NOL),UOM(NOL),QTYUOM(NOL),UOMPUUCOE(NOL),
&       PUU(NOL),QTYPUU(NOL),STU(NOL),QTYSTU(NOL), ITMKND(NOL)
  End
Else
  #----- lecture article si nécessaire -----#
  If [F:ITM]ITMREF<>VALEUR
    Read [ITM] ITM0=VALEUR : If fstat  Raz [F:ITM] : Endif
  Endif
  # Issue 112754 - 2016-09-27 by SR : Services
  If [F:ITM]SCSFLG <> 2
    [M:POI1]ITMKND(NOL) = 1
  Else
    If dim(GDEFITMKND) > 0 & GDEFITMKND <> 0
       [M:POI1]ITMKND(NOL) = GDEFITMKND
    Else
      [M:POI1]ITMKND(NOL) = 2
    Endif
  Endif
  Affzo [M:POI1]ITMKND(NOL)
  #----- Des besoins doivent être pris en cpte pour un article sous-traitance -----#
#  If [F:ITM]SCSFLG=2
#      Local Integer WRET: WRET=2
#      Call AVERTIR(mess(121,194,1),WRET) From GESECRAN
#      If WRET=2  Goto CALL_SAIPECB2 : Endif  # Issue 84656 & 85565 GA 11/2012
#      If WRET=1 : GERR=1 : Goto RETOURITMREF : Endif
#  Endif
#  # Issue 82533 GA 06/2012 idem commande achat SUBPOH
#  If [F:ITM]SCPFLG=2
#     If [F:ITM]PURFLG<>2
#        #----- Des besoins doivent être pris en cpte pour un article sous-traité non acheté -----#
#        Call ERREUR(mess(354,194,1)) From GESECRAN : End
#     Else
#        Local Integer WRET: WRET=2
#        Call AVERTIR(mess(354,194,1),WRET) From GESECRAN
#        If WRET=2  Goto CALL_SAIPECB2 : Endif # Issue 84656 & 85565 GA 11/2012
#     Endif
#  Endif
# End issue 112754
Endif
#----- L'article fait-il l'objet d'une commande ouverte ? -----#
Local    Integer OK
Filter [POC] Where ITMREF=VALEUR & STRDAT<=date$ & ENDDAT>=date$
Look [POC] POC2 First
Filter [POC]
If fstat=0 OK=2 : Call AVERTIR(mess(1,194,1),OK) From GESECRAN
  If OK=1 Goto RETOURITMREF : Endif
Endif
#----- Lecture fichier article et article-site de commande si nécessaire -----#
If [F:ITM]ITMREF<>VALEUR
  Read [ITM] ITM0=VALEUR      : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>VALEUR | [F:ITF]STOFCY<>GFCY
  Read [ITF] ITF0=VALEUR;GFCY : If fstat Raz [F:ITF] : Endif
Endif
#----- Contrôle si article actif ? -----#
If [F:ITM]ITMSTA=3
  OK=2 : Call AVERTIR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")",OK) From GESECRAN
  If OK=1  Goto RETOURITMREF : Endif
Elsif [F:ITM]ITMSTA<>1
  Call ERREUR(mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")") From GESECRAN
  Goto RETOURITMREF
Endif
#----- Chargement valeurs ligne de commande -----#
If [F:ITM]BUY<>"" [M:POI1]LINBUY(NOL)=[F:ITM]BUY : Endif
If [F:ITF]BUY<>"" [M:POI1]LINBUY(NOL)=[F:ITF]BUY : Endif
Raz [M:POI1]RETQTYSTU(NOL),[M:POI1]PURMINQTY(NOL)
#----- Chargement de l'indicateur "Géré en stock" -----#
If [F:ITM]STOMGTCOD>1
  If [F:ITF]ITMREF<>VALEUR | [F:ITF]STOFCY<>[M:POI1]PRHFCY(NOL)
    Read [ITF] ITF0=VALEUR;[M:POI1]PRHFCY(NOL)
    If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
  Endif
  [M:POI1]STOMGTCOD(NOL)=[F:ITF]STOMGTCOD
Else
  [M:POI1]STOMGTCOD(NOL)=[F:ITM]STOMGTCOD
Endif
#-----
If [F:ITF]QUAFLG>1 [M:POI1]QUAFLG(NOL)=2 Else [M:POI1]QUAFLG(NOL)=1  : Endif
If dim([M:POI1]TSICOD1(NOL))>0 [M:POI1]TSICOD1(NOL)=[F:ITM]TSICOD(0) : Endif
If dim([M:POI1]TSICOD2(NOL))>0 [M:POI1]TSICOD2(NOL)=[F:ITM]TSICOD(1) : Endif
If dim([M:POI1]TSICOD3(NOL))>0 [M:POI1]TSICOD3(NOL)=[F:ITM]TSICOD(2) : Endif
If dim([M:POI1]TSICOD4(NOL))>0 [M:POI1]TSICOD4(NOL)=[F:ITM]TSICOD(3) : Endif
If dim([M:POI1]TSICOD5(NOL))>0 [M:POI1]TSICOD5(NOL)=[F:ITM]TSICOD(4) : Endif
[M:POI1]UOM(NOL)=[F:ITM]PUU
[M:POI1]PUU(NOL)=[F:ITM]PUU
[M:POI1]STU(NOL)=[F:ITM]STU
# 106430.sn - Purchase planning - use Supplier from header if there
If [M:POI1]HBPSNUM<>""
  Filter [ITP] Where ITMREF=VALEUR & BPSNUM=[M:POI1]HBPSNUM
  Read [ITP] ITP1 First
  Filter [ITP]
  If fstat : Raz [F:ITP] : Endif
Else
# 106430.en - If no supplier on header, follow old method
# Issue X3-55891 - 2018-08-21 by SR : Données déclinées par site
#	#----- Recherche de l'article-fournisseur ------#
#	Filter [ITP] Where ITMREF=VALEUR & DOUFLG<3
#	Read [ITP] ITP1 First : If fstat Raz [F:ITP] : Endif
#	Filter [ITP]
  Raz [F:ITP], [F:ITPF], WBPSNUM
  Call DEFBPSNUM(VALEUR,[M:POI1]POHFCY,[M:POI1]PRHFCY(NOL),[M:POI1]LINSTOFCY(NOL),1,WBPSNUM,WITMBPS) From TRTACHDEF1
	# Issue 86311 - 2012-11-30 by SR si pas d'article-site
	If [F:ITP]BPSNUM <> ""
	    #----- Lecture fournisseur si nécessaire -----#
	    If [F:BPS]BPSNUM<>[F:ITP]BPSNUM
	      Read [BPS] BPS0=[F:ITP]BPSNUM : If fstat  Raz [F:BPS] : Endif
	    Endif
	    # Issue X3-55891 - 2018-08-21 by SR : Fait pas le composant
	    #----- Effacement du fournisseur si non actif ou prospect -----#
#	    If [F:BPS]ENAFLG<>2 | [F:BPS]BPSTYP=2
#	      Raz [F:ITP]
#	    Endif
	    #----- Chargement PUU de l'art-fou si renseignés ------#
	    If [F:ITP]PUU<>""
	      [M:POI1]UOM(NOL)=[F:ITP]PUU
	      [M:POI1]PUU(NOL)=[F:ITP]PUU
	    Endif
	    #----- Lecture BPARTNER si nécessaire -----#
	    If [F:BPR]BPRNUM<>[F:ITP]BPSNUM
	      Read [BPR] BPR0=[F:ITP]BPSNUM
	      If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
	    Endif
	Else
	    Raz [F:BPS], [F:BPR]
	    [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE
	Endif
Endif
#----- Chargement des désignations article -----#
#Call CHARGE_ITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:POI1]ITMDES(NOL)) From TRTX3
#If [M:POI1]ITMDES(NOL)="" [M:POI1]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:POI1]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
#[M:POI1]ITMDES1(NOL)  =[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:POI1]ITMDES1(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
Affzo [POI1]ITMDES1(NOL)
#-----
# Issue X3-55891 - 2018-08-30 by SR : A faire après appel AM_BPSNUM si tout est OK
#If [F:ITP]BPSNUM <>""                   # 106430.n - Use BPSNUM from screen if [F:ITP]BPSNUM is blank
#  [M:POI1]BPSNUM(NOL) =[F:ITP]BPSNUM    # 106430.o
#Else
#  [M:POI1]BPSNUM(NOL) =[M:POI1]HBPSNUM  # 106430.n
#Endif
# End issue X3-55891
[M:POI1]QTYPUU(NOL)   =[F:ITP]PURMINQTY
[M:POI1]PURMINQTY(NOL)=[F:ITP]PURMINQTY
# Issue 71069 - 2016-04-12 by SR : PJT
[M:POI1]PJT(NOL)=[M:POI1]PJTH
#If NOL>0 : [M:POI1]PJT(NOL)=[M:POI1]PJT(NOL-1) : Endif
# End issue 71069
Call PCAL_QTY(QTYPUU(NOL),PUU(NOL),QTYUOM(NOL),UOM(NOL),
&             VALEUR,[F:ITP]BPSNUM,1,GBIDD1)  From TRTACHQTE1
#----- Appel du s/p pour chargement du coefficient avec précision maxi -----#
Call PCAL_QTY(QTYUOM(NOL),UOM(NOL),GBIDD1,PUU(NOL),
&             VALEUR,[F:ITP]BPSNUM,1,GCOEUOM) From TRTACHQTE1
[M:POI1]UOMPUUCOE(NOL)=GCOEUOM
#-----
Call PCAL_QTY(QTYPUU(NOL),PUU(NOL),QTYSTU(NOL),STU(NOL),
&             VALEUR,[F:ITP]BPSNUM,1,GBIDD1)  From TRTACHQTE1
If [M:POI1]UOM(NOL)=[M:POI1]PUU(NOL)
  [M:POI1]UOMFLG(NOL)=1
Else
  [M:POI1]UOMFLG(NOL)=2
Endif
If RETQTYSTU(NOL)=0
  If [F:ITF]ITMREF<>VALEUR | [F:ITF]STOFCY<>GFCY
    Read [ITF] ITF0=VALEUR;GFCY
    If fstat Raz [F:ITF] : [F:ITF]OFS=[F:ITM]OFS : Endif
  Endif
  If [F:ITF]OFS=0
    [M:POI1]RETRCPDAT(NOL)=[M:POI1]ORDDAT+[F:ITM]OFS
    If dim([M:POI1]OFS)>0 [M:POI1]OFS(NOL)=[F:ITM]OFS : Endif
  Else
    [M:POI1]RETRCPDAT(NOL)=[M:POI1]ORDDAT+[F:ITF]OFS
    If dim([M:POI1]OFS)>0 [M:POI1]OFS(NOL)=[F:ITF]OFS : Endif
  Endif
Endif
#---- Ajustement date théorique de réception en fonction des indisponibilités ----#
If [F:FCY]FCY<>[M:POI1]PRHFCY(NOL)
  Read [FCY] FCY0=[M:POI1]PRHFCY(NOL) : If fstat Raz [F:FCY] : Endif
Endif
Call CTL_JOU2([M:POI1]RETRCPDAT(NOL),[M:POI1]ORDDAT,[M:POI1]OFS(NOL)) From TRTACHCDE1
Raz mkstat, GMESSAGE
[M:POI1]EXTRCPDAT(NOL)=[M:POI1]RETRCPDAT(NOL)
#----- Chargement code adresse par défaut -----#
[M:POI1]FCYADD(NOL)=[F:FCY]BPAADD
#----- Chargement du type de ligne -----#
If [F:ITM]PURFLG=2 & [M:POI1]NBCRELIG=0 # Issue 85565 GA 10/2012 pas de pec de besoin, achat direct
  [M:POI1]LINTYP(NOL)=1
# Issue 112754 - 2016-11-28 by SR :Services
Elsif [M:POI1]ITMKND(NOL)=2
  [M:POI1]LINTYP(NOL)=3
Elsif [F:ITM]SCPFLG=2
  [M:POI1]LINTYP(NOL)=2
Else
  [M:POI1]LINTYP(NOL)=1
Endif
#-----
[M:POI1]ITMREF(NOL)=VALEUR : # à cause AM_BPSNUM et affzo PRHFCY qui appel C_PRHFCY
# Issue X3-55891 - 2018-08-23 by SR
# Call AM_BPSNUM ([M:POI1]BPSNUM(NOL))
#If mkstat
#    Raz mkstat, GERR, GMESSAGE, [M:POI1]BPSNUM(NOL), [M:POI1]LINSTOFCY(NOL)
#    [M:POI1]BETFCY(NOL)=1 : [M:POI1]BETCPY(NOL)=1
#Endif
If WBPSNUM = "" : WBPSNUM = [M:POI1]HBPSNUM : Endif
Raz mkstat
If WBPSNUM <> ""
 Call AM_BPSNUM(WBPSNUM)
Endif
If mkstat | WBPSNUM =""
    #Raz mkstat, GERR, GMESSAGE, [M:POI1]BPSNUM(NOL), [M:POI1]LINSTOFCY(NOL)
    Raz [M:POI1]BPSNUM(NOL), [M:POI1]LINSTOFCY(NOL)
    [M:POI1]BETFCY(NOL)=1 : [M:POI1]BETCPY(NOL)=1
Else
    [M:POI1]BPSNUM(NOL) = WBPSNUM
Endif
# End issue X3-55891
#----- Affichage site de réception, quantités, fournisseur et date réception -----#
# Issue 112754 - 2016-10-19 by MUARN : SERVICE
Affzo [POI1]ITMDES(NOL),PRHFCY(NOL),FCYADD(NOL),UOM(NOL),QTYUOM(NOL),UOMPUUCOE(NOL),
&     PUU(NOL),QTYPUU(NOL),STU(NOL),QTYSTU(NOL),BPSNUM(NOL),EXTRCPDAT(NOL),QUAFLG(NOL),
&     LINTYP(NOL), ITMKND(NOL)
#----- Chargement indicateur modif du coefficient -----#
Gosub CHARG_COEFLG
#----- Contrôle existence du site de réception si celui-ci n'est pas saisi -----#
If [F:PTR]PTRTYP<>3 | [F:PTR]PTRNUM<>GPTRNUM : # Relecture transaction si nécessaire
  Read [PTR] PTR0=3;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
If [F:PTR]RCPFCYCOD<>1 | [F:PTR]RCPFCYSCR=2
  If [F:FCY]FCY<>[M:POI1]PRHFCY(NOL)
    Read [FCY] FCY0=[M:POI1]PRHFCY(NOL)
    If fstat  Raz [F:FCY] : Endif
  Endif
  If [F:FCY]FCY=""  GMESSAGE=mess(80,194,1) : GERR=1 : Goto RETOURITMREF : Endif
Endif
#----- Si module Ventes présent -----#
If GMODU(5)=2  Raz [F:SOP] : Endif : # à cause de l'INISEC "POID"
#-----

# 106430 - Purchase planning
[M:POI1]ITMWEI(NOL)     = [F:ITM]ITMWEI
[M:POI1]LINWEU(NOL)     = [F:ITM]WEU
[M:POI1]ITMVOL(NOL)     = [F:ITM]ITMVOU
[M:POI1]LINVOU(NOL)     = [F:ITM]VOU

End
#----- retour à la saisie de la référence article -----#
$RETOURITMREF
Raz [M:POI1]LINTYP(nolign-1)
mkstat=1 : [M:POI1]ITMREF(nolign-1)=""
End

# Issue 112754 - 2016-11-15 by SR : appel directement depuis action écran
# Issue 84656 & 85565 GA 11/2012
#$CALL_SAIPECB2
#If !GWEBSERV
#  # Action SAIPECB2  # charger les paramètres
#  # NUMPRO  NUMÉRO PROCESS Integer
#  # CODFNC  CODE FONCTION  Char
#  # ITMREF  ARTICLE        Char
#  # BUY     CODE ACHETEUR  Char
#  # TRAIT   TRAITEMENT     Integer
#   If dim([L]PARAM_SAI)>1
#     Raz PARAM_SAI,VAL_SAI
#   Else
#     Local Char PARAM_SAI(15)(1..5)
#     Local Decimal VAL_SAI
#   Endif
#   SAVACT = GACTION : GACTION = "SAIPECB2"
#   PARAM_SAI(1) = num$([M:POI1]PRONUM)
#   PARAM_SAI(2) = "POI"
#   PARAM_SAI(3) = VALEUR # [M:POI1]ITMREF(nolign-1)
#   PARAM_SAI(4) = [M:POI1]BUY
#   PARAM_SAI(5) = "3"
#   Call SAISIE_NUM(VAL_SAI,PARAM_SAI,"IPPICORD2","SUBPOIA","SPEPOI") From GSAISIE
#   [M:POI1]REFART = PARAM_SAI(3)
#   GACTION = SAVACT
#Endif
#End

######################################################################################
Subprog B2_ITMREF(VALEUR)
Variable Char    VALEUR()
#--------------------------------------#
# Avant exécution du bouton PEC besoin #
#--------------------------------------#
GPECBOUT1 = 2
End
# End issue 112754

Subprog IB_ITMDES
#------------------------------#
# Activation bouton "Articles" #
#------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
GBOUT1=mess(22,198,1)
End

Subprog IB_ITMDES1
#------------------------------#
# Activation bouton "Articles" #
#------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
GBOUT1=mess(22,198,1)
End

$AB1_ITMDES
#------------------------------------#
# Avant exécution du tunnel Articles #
#------------------------------------#
Local Shortint NOL : NOL=nolign-1
Return

$BB1_ITMDES
#------------------------------------#
# Après exécution du tunnel Articles #
#------------------------------------#
#----- Relecture article si celui-ci a été changé par le tunnel -----#
If [F:ITM]ITMREF<>[M:POI1]ITMREF(NOL)
  Read [ITM] ITM0=[M:POI1]ITMREF(NOL)
  If fstat Raz [F:ITM] : Endif
Endif
Return

Subprog IB_PRHFCY
#-------------------------------------------------#
# Activation bouton "Int Stock" et "Article-site" #
#-------------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT4, GBOUT5 : # GBOUT3 est défini par l'action CONSSFC !
If [M:POI1]STOMGTCOD(nolign-1)<2 Raz GBOUT3 : Endif
GBOUT4=mess(4,198,1)
End

Subprog AS_PRHFCY(VALEUR)
#-----------------------------------#
# Avant saisie du site de réception #
#-----------------------------------#
Variable Char    VALEUR()
# Issue 94215 & 88046 GA 12/2013 pas de maj site/adresse de réception si sous-traitance
#----- Pas de saisie pour le service et matières fournies -----#
#If !GIMPORT & [M:POI1]LINTYP(nolign-1)>2  mkstat=2 : End : Endif
If !GIMPORT & find([M:POI1]VCRTYPORI(nolign-1),10,36)  mkstat=2 : End : Endif
End

Subprog C_PRHFCY(VALEUR)
#----------------------------------------------------------------------#
# Contrôle site de réception : même société juridique et si article    #
# géré en stock site de stockage + existence article-site de réception #
#----------------------------------------------------------------------#
Variable Char    VALEUR()
If clalev([F:PTR])<>0
  If [F:PTR]PTRTYP<>3 | [F:PTR]PTRNUM<>GPTRNUM : # Relecture transaction si nécessaire
    Read [PTR] PTR0=3;GPTRNUM : If fstat Raz [F:PTR] : Endif
  Endif
  If [F:PTR]RCPFCYCOD<>1 End : Endif
Endif
If [M:POI1]STOMGTCOD(nolign-1)>1
  Call CONTROLE("FCY","D",VALEUR,"",mkstat) From CONTOBJ
  If mkstat End : Endif
  If GIMPORT
    Read [ITF] ITF0=[M:POI1]ITMREF(nolign-1);VALEUR
    If fstat Raz [F:ITF] : GMESSAGE=mess(25,192,1) : mkstat=1 : End : Endif
  Endif
Else
  Call CONTROLE("FCY","", VALEUR,"",mkstat) From CONTOBJ
  If mkstat End : Endif
Endif
If [F:FCY]LEGCPY<>GSOCIETE  GMESSAGE=mess(2,194,1)  : mkstat=1 : End : Endif
End

$AAM_PRHFCY
#-------------------------------------------------------------#
# Avant exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
Local Shortint NOL             : NOL=nolign-1
Local Char     SITE  (GLONFCY) : SITE=VALEUR
Local Char     WOBJET(GLONAOB) : WOBJET="ITF"
#----- Restauration de l'ancienne valeur et blocage sur le champ -----#
If GBIDI1=1  VALEUR=[M:POI1]PRHFCY(NOL) : mkstat=1 : Endif
If GBIDI1<>2 WOBJET="" : Endif : # Pas d'exécution du tunnel
GFLTITM=[M:POI1]ITMREF(NOL)
Return

$BAM_PRHFCY
#-------------------------------------------------------------#
# Après exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
nolign=NOL+1 :  : # Restitution du nolign
Raz GFLTITM
If GBIDI1=0  Return : Endif
VALEUR=SITE
Read [ITF] ITF0=[M:POI1]ITMREF(NOL);VALEUR
If fstat Raz [F:ITF] : Endif
If [F:ITF]ITMREF="" mkstat=1 : Endif
Return

Subprog AM_PRHFCY(VALEUR)
#------------------------------------#
# Chargement code adresse par défaut #
#------------------------------------#
Variable Char     VALEUR
Local Shortint NOL : NOL=nolign-1
# Issue X3-55891 - 2018-08-21 by SR : Relancer la recherche fournisseur
Local Integer OK, WITMBPS, WRETOUR
Local Char    WBPSNUM(GLONBPS)
#--- Vérification que le site de réception correspond à une adresse client livré
#--- Uniquement si pendant vente
If [M:POI1]SALFCY(NOL)<>""
  Local Char BETRCPFCY(GLONFCY)
  Local Char BPCNUM   (GLONBPC)
  [L]BETRCPFCY=VALEUR
  [L]BPCNUM=[M:POI1]BPCORD(NOL)
  Gosub CTRL_BPRADD From TRTACHCTL1
  If [L]BETRCPFCY="" : GMESSAGE=mess(267,194,1) : mkstat=1 : End : Endif
Endif
If [F:FCY]FCY<>VALEUR
  Read [FCY] FCY0=VALEUR : If fstat Raz [F:FCY] : Endif
Endif
[M:POI1]FCYADD(NOL)=[F:FCY]BPAADD
#----- Alimentation codes taxe si nécessaire -----#
#If func AFNC.ACTIV("PTX") & [M:POI1]LINTYP(NOL)<>2 # Issue 93038 GA 10/2013
If [M:POI1]LINTYP(NOL)<>2
  [M:POI1]PRHFCY(NOL)=VALEUR
  Call ALIVATCOD(2,[M:POI1]BPSNUM(NOL),[M:POI1]ITMREF(NOL),"POI1",NOL) From TRTX3
Endif
#-----
# Issue X3-55891 - 2018-08-21 by SR : Relancer la recherche fournisseur ?
OK = 2
Call OUINON(mess(590,194,1),OK) From GESECRAN
If OK = 2
   Raz [F:ITP], [F:ITPF], WBPSNUM, WITMBPS
   # contremarque
   If [M:POI1]SOHNUM(NOL) <> "" & ([M:POI1]BETFCY(NOL)<>2 | [M:POI1]BETCPY(NOL)=2)
    Call DEFBPSNUM([M:POI1]ITMREF(NOL),[M:POI1]POHFCY,VALEUR,[M:POI1]LINSTOFCY(NOL),2,WBPSNUM,WITMBPS) From TRTACHDEF1
   Else
    Call DEFBPSNUM([M:POI1]ITMREF(NOL),[M:POI1]POHFCY,VALEUR,[M:POI1]LINSTOFCY(NOL),1,WBPSNUM,WITMBPS) From TRTACHDEF1
   Endif
   If WBPSNUM <> ""
      Raz mkstat
      Call AM_BPSNUM(WBPSNUM)
      If !mkstat : [M:POI1]BPSNUM(NOL) = WBPSNUM : Endif
      If !GIMPORT : Affzo [M:POI1]BPSNUM(NOL) : Endif
   Else
    # Intersite
    If [M:POI1]BETFCY(NOL)=2 & [M:POI1]BETCPY(NOL)<>2
      Call CTRL_DOUFLG(2,[M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),[M:POI1]PRHFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
    Else
      Call CTRL_DOUFLG(1,[M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),[M:POI1]PRHFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
    Endif
    If WRETOUR<>0
      Raz [M:POI1]BPSNUM(NOL),[M:POI1]LINSTOFCY(NOL)
      [M:POI1]BETFCY(NOL)=1 : [M:POI1]BETCPY(NOL)=1
      If !GIMPORT : Affzo [M:POI1]BPSNUM(NOL) : Endif
     Endif
   Endif
Elsif [M:POI1]BPSNUM(NOL)<>""
    # Intersite
    If [M:POI1]BETFCY(NOL)=2 & [M:POI1]BETCPY(NOL)<>2
      Call CTRL_DOUFLG(2,[M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),[M:POI1]PRHFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
    Else
      Call CTRL_DOUFLG(1,[M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),[M:POI1]PRHFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
    Endif
  If WRETOUR<>0
    Raz [M:POI1]BPSNUM(NOL),[M:POI1]LINSTOFCY(NOL)
    [M:POI1]BETFCY(NOL)=1 : [M:POI1]BETCPY(NOL)=1
    If !GIMPORT : Affzo [M:POI1]BPSNUM(NOL) : Endif
  Endif
Endif
# End issue X3-55891
End

Subprog IB_FCYADD
#-----------------------------------------------------------------------#
# Init bouton code adresse pour charger [F:FCY] avant sélection adresse #
#-----------------------------------------------------------------------#
If [F:FCY]FCY<>[M:POI1]PRHFCY(nolign-1)
  Read [FCY] FCY0=[M:POI1]PRHFCY(nolign-1) : If fstat Raz [F:FCY] : Endif
Endif
Raz GBIDC3 : # Utilisé par l'action SAISELADR pour le nom
End

Subprog AS_FCYADD(VALEUR)
#------------------------------#
# Avant saisie du code adresse #
#------------------------------#
Variable Char    VALEUR()
# Issue 94215 & 88046 GA 12/2013 pas de maj site/adresse de réception si sous-traitance
#----- Pas de saisie pour le service et matières fournies -----#
#If !GIMPORT & [M:POI1]LINTYP(nolign-1)>2  mkstat=2 : End : Endif
If !GIMPORT & find([M:POI1]VCRTYPORI(nolign-1),10,36)  mkstat=2 : End : Endif
End

Subprog C_FCYADD(VALEUR)
#--------------------------#
# Contrôle du code adresse #
#--------------------------#
Variable Char     VALEUR
Local    Shortint NOL : NOL=nolign-1
Read [BPA] BPA0=3;[M:POI1]PRHFCY(NOL);VALEUR
If fstat Raz [F:BPA] : mkstat=1 : Endif
End

Subprog AM_FCYADD(VALEUR)
#------------------------------#
# Après modif. du code adresse #
#------------------------------#
Variable Char     VALEUR()
Local Shortint NOL : NOL=nolign-1
#----- Alimentation codes taxe si nécessaire -----#
#If func AFNC.ACTIV("PTX") & [M:POI1]LINTYP(NOL)<>2 # Issue 93038 GA 10/2013
If [M:POI1]LINTYP(NOL)<>2
  [M:POI1]FCYADD(NOL)=VALEUR
  Call ALIVATCOD(2,[M:POI1]BPSNUM(NOL),[M:POI1]ITMREF(NOL),"POI1",NOL) From TRTX3
Endif
#-----
End

Subprog C_UOM(VALEUR)
#---------------------------------------#
# Contrôle de l'unité pour l'inter-site #
#---------------------------------------#
Variable Char    VALEUR()
Local    Shortint NOL : NOL=nolign-1
#----- Si inter-sites, contrôle que l'unité de commande convienne pour les ventes -----#
If [M:POI1]BETFCY(NOL)=2 & [M:POI1]BPCORD(NOL)<>""
  Local Char WUOM(GLONUOM) : WUOM=VALEUR
  Call CTLUOM([M:POI1]ITMREF(NOL),2,[M:POI1]BPCORD(NOL),WUOM,GBIDD2,
&             GBIDC2,GBIDC3,GBIDI2) From STKACT
  If mkstat  End : Endif
Endif
End

Subprog AM_UOM(VALEUR)
#-------------------------------------------#
# Après modification de l'unité de commande #
#-------------------------------------------#
Variable Char     VALEUR
Local    Char     SVGPUU(GLONUOM)
Local    Char     FOURN(GLONBPS)
Local    Decimal  SVGCOE
Local    Shortint NOL             : NOL=nolign-1
Local    Char     WUNIT1(GLONUOM) : WUNIT1=[M:POI1]UOM(NOL)
Local    Decimal  WCOEF1          : WCOEF1=[M:POI1]UOMPUUCOE(NOL)
#-----
If [M:POI1]BPSNUM(NOL)="" FOURN=[F:ITP]BPSNUM
                     Else FOURN=[M:POI1]BPSNUM(NOL) : Endif
Call PCAL_QTY(QTYPUU(NOL),PUU(NOL),QTYUOM(NOL),VALEUR,
&             ITMREF(NOL),FOURN,1,GBIDD1)  From TRTACHQTE1
#----- Appel du s/p pour chargement du coefficient avec précision maxi -----#
Call PCAL_QTY(QTYUOM(NOL),VALEUR,QTYPUU(NOL),PUU(NOL),
&             ITMREF(NOL),FOURN,1,GCOEUOM) From TRTACHQTE1
[M:POI1]UOMPUUCOE(NOL)=GCOEUOM
#-----
Call PCAL_QTY(QTYPUU(NOL),PUU(NOL),QTYSTU(NOL),STU(NOL),
&             ITMREF(NOL),FOURN,1,GBIDD1)  From TRTACHQTE1
If VALEUR=[M:POI1]PUU(NOL)
  [M:POI1]UOMFLG(NOL)=2
  SVGCOE=[M:POI1]UOMPUUCOE(NOL) : SVGPUU=[M:POI1]PUU(NOL)
  Effzo [POI1]UOMPUUCOE(NOL),PUU(NOL)
  [M:POI1]UOMPUUCOE(NOL)=SVGCOE : [M:POI1]PUU(NOL)=SVGPUU : [M:POI1]UOMFLG(NOL)=1
Else
  [M:POI1]UOMFLG(NOL)=2
  Affzo [POI1]UOMPUUCOE(NOL),PUU(NOL)
Endif
Affzo [POI1]STU(NOL),QTYSTU(NOL)
[M:POI1]UOM(NOL)=VALEUR : Affzo [POI1]QTYUOM(NOL)
Gosub CHARG_COEFLG : # Chargement indicateur modif du coefficient
#----- Recherche tarif ? après modif unité -----#
If find([M:POI1]LINFLG(NOL),1,2) & [M:POI1]LINTYP(NOL)<>2
  Local Integer OK
  OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
  If OK=2
    Call INI_TARIF(NOL)
  Else
    Call REAJUST_TARIF("POI1",NOL,WUNIT1,VALEUR,WCOEF1,[M:POI1]UOMPUUCOE(NOL)) From TRTACHPRI1
  Endif
Elsif [M:POI1]LINFLG(NOL)=0 & [M:POI1]LINTYP(NOL)<>2
  Call INI_TARIF(NOL)
Elsif [M:POI1]LINTYP(NOL)<>2
  Call REAJUST_TARIF("POI1",NOL,WUNIT1,VALEUR,WCOEF1,[M:POI1]UOMPUUCOE(NOL)) From TRTACHPRI1
Endif
#-----
#VPO 09/12/10 17667 maj qte sur une DA
#&  [M:POI1]QTYSTU(NOL)<[M:POI1]RETQTYSTU(NOL)
If [M:POI1]QTYPUU(NOL)<[M:POI1]PURMINQTY(NOL) |
&  [M:POI1]QTYSTU(NOL)<>[M:POI1]RETQTYSTU(NOL)
  GBIDD1=[M:POI1]QTYPUU(NOL) : GBIDD2=[M:POI1]QTYSTU(NOL)
  Call MESSAGE_QTE(1,NOL) From SUBPOI
  If mkstat  mkstat=0 : Endif
Endif
End

Subprog IB_QTYUOM
#-------------------------------#
# Activation bouton "Int Stock" #
#-------------------------------#
Raz GBOUT1, GBOUT2, GBOUT4, GBOUT5 : # GBOUT3 est défini par l'action CONSSFC !
If [M:POI1]STOMGTCOD(nolign-1)<2 Raz GBOUT3 : Endif
End

Subprog C_QTYUOM(VALEUR)
#----------------------------#
# Contrôle quantité commande #
#----------------------------#
Variable Decimal VALEUR
Gosub CTL_QTYUOM From SUBPOI : # La variable NOL est défini dans le Gosub
If [M:POI1]UOMFLG(NOL)=2
  If [F:PTR]PTRTYP<>3 | [F:PTR]PTRNUM<>GPTRNUM : # Relecture transaction si nécessaire
    Read [PTR] PTR0=3;GPTRNUM : If fstat Raz [F:PTR] : Endif
  Endif
  If [F:PTR]UOMCOECOD=1 & [M:POI1]COEFLG(NOL)=0
    Raz mkstat, GMESSAGE : # Le contrôle se fera sur le champ coefficient
  Endif
Endif
End

Subprog AM_QTYUOM(VALEUR)
#--------------------------------#
# Après modif de la qté commande #
#--------------------------------#
Variable Decimal  VALEUR
Local    Integer  OK
Gosub CTL_QTYUOM From SUBPOI : # La variable NOL est défini dans le Gosub
If VALEUR<>QTEUC
  Call MESSAGE (mess(42,194,1)-mess(240,194,1)) From GESECRAN
Endif
VALEUR=QTEUC
#----- Contrôle si multiple du conditionnement -----#
GBIDD1=QTEUA/WCOEF
Call QTEARR(GBIDD1,[M:POI1]UOM(NOL)) From TRTDIV
If GBIDD1<>VALEUR
  Call MESSAGE (mess(42,194,1)) From GESECRAN
Endif
If [M:POI1]UOMFLG(nolign-1)=2 & mkstat  mkstat=0 : Endif
If mkstat  GERR=1 : End : Endif
#----- Avertissement si commande de contremarque -----#
If [M:POI1]SOHNUM(NOL)<>"" & QTEUS<>[M:POI1]RETQTYSTU(NOL)
  #-----
  If [F:SOQ]SOHNUM<>[M:POI1]SOHNUM(NOL) |
&    [F:SOQ]SOPLIN<>[M:POI1]SOPLIN(NOL) |
&    [F:SOQ]SOQSEQ<>[M:POI1]SOQSEQ(NOL)
    Read [SOQ] SOQ0=[M:POI1]SOHNUM(NOL);[M:POI1]SOPLIN(NOL);[M:POI1]SOQSEQ(NOL)
    If fstat  Raz [F:SOQ] : Endif
  Endif
  #----- Contremarque directe -----#
  If [F:SOQ]FMI=2
    Call ERREUR(mess(396,194,1)) From GESECRAN : mkstat=1 : End
  #----- Autre -----#
  Else
    OK=2 : Call AVERTIR(mess(117,194,1),OK) From GESECRAN
    If OK=1  mkstat=1 : End : Endif
  Endif
Endif
#-----
[M:POI1]UOMPUUCOE(NOL)=WCOEF
[M:POI1]QTYPUU(NOL)=QTEUA
[M:POI1]QTYSTU(NOL)=QTEUS
Affzo [POI1]UOMPUUCOE(NOL), QTYPUU(NOL), QTYSTU(NOL)
#----- Recherche tarif ? après modif qté -----#
[M:POI1]QTYUOM(NOL)=VALEUR
If find([M:POI1]LINFLG(NOL),1,2) & [M:POI1]LINTYP(NOL)<>2
  Local Integer OK
  OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
  If OK=2
    Call INI_TARIF(NOL)
  Else
    Call REAJUST_TARIF("POI1",NOL,[M:POI1]UOM(NOL),[M:POI1]UOM(NOL),1,1) From TRTACHPRI1
  Endif
Elsif [M:POI1]LINFLG(NOL)=0 & [M:POI1]LINTYP(NOL)<>2
  Call INI_TARIF(NOL)
Elsif [M:POI1]LINTYP(NOL)<>2
  Call REAJUST_TARIF("POI1",NOL,[M:POI1]UOM(NOL),[M:POI1]UOM(NOL),1,1) From TRTACHPRI1
Endif
#----- Calcul et affichage du montant ligne si nécessaire -----#
If [M:POI1]NETPRI(NOL)<>0
  [M:POI1]LINAMT(NOL)=[M:POI1]NETPRI(NOL)*VALEUR
  Call ARRDEV([M:POI1]LINAMT(NOL),[M:POI1]CUR(NOL)) From TRTDIV
  Affzo [POI1]LINAMT(NOL)
Endif

End

Subprog AS_UOMPUUCOE(VALEUR)
#--------------------------#
# Avant saisie coefficient #
#--------------------------#
Variable Decimal VALEUR
If [M:POI1]UOMFLG(nolign-1)=1                     |
&  [M:POI1]UOM(nolign-1)   =[M:POI1]STU(nolign-1) |
&  [M:POI1]COEFLG(nolign-1)=1
  mkstat=2 : End
Endif
End

Subprog AM_UOMPUUCOE(VALEUR)
#------------------------------------#
# Après modif du coefficient UCde-UA #
#------------------------------------#
Variable Decimal VALEUR
Local Shortint NOL : NOL=nolign-1
Local Char     FOURN(GLONBPS)
Local Decimal  QTEUA, QTEUS
If [M:POI1]BPSNUM(NOL)="" FOURN=[F:ITP]BPSNUM
                     Else FOURN=[M:POI1]BPSNUM(NOL) : Endif
QTEUA=[M:POI1]QTYUOM(NOL)*VALEUR
Gosub POINT_PURQTYRND From SUBPOHB
If [M:POI1]UOM(NOL)=[M:POI1]STU(NOL)
  QTEUS=[M:POI1]QTYUOM(NOL)
Else
  Call PCAL_QTY(QTEUA,[M:POI1]PUU(NOL),QTEUS,[M:POI1]STU(NOL),
&               [M:POI1]ITMREF(NOL),FOURN,1,GBIDD1) From TRTACHQTE1
Endif
#VPO 09/12/10 17667 maj qte sur une DA
#If QTEUA<[M:POI1]PURMINQTY(NOL) | QTEUS<[M:POI1]RETQTYSTU(NOL)
If QTEUA<[M:POI1]PURMINQTY(NOL) | QTEUS<>[M:POI1]RETQTYSTU(NOL)
  GBIDD1=QTEUA : GBIDD2=QTEUS
  Call MESSAGE_QTE(1,NOL) From SUBPOI
Endif
If !mkstat
  [M:POI1]QTYPUU(NOL)=QTEUA : [M:POI1]QTYSTU(NOL)=QTEUS
  Affzo [POI1]QTYUOM(NOL),QTYPUU(NOL),QTYSTU(NOL)
  GCOEUOM=VALEUR
Endif
End

Subprog AS_PUU(VALEUR)
#----------------------------#
# Avant saisie unité d'achat #
#----------------------------#
Variable Char    VALEUR()
If [M:POI1]UOMFLG(nolign-1)=1  mkstat=2 : End : Endif
End

Subprog AS_QTYSTU(VALEUR)
#------------------------------#
# Avant saisie de la qté en US #
#------------------------------#
Variable Decimal VALEUR
If [M:POI1]COEFLG(nolign-1)=1  mkstat=2 : End : Endif
End

Subprog AM_QTYSTU(VALEUR)
#--------------------------#
# Après modif de la qté US #
#--------------------------#
Variable Decimal  VALEUR
Local Decimal  QTEUC, QTEUA, WCOEF
Local Char     WMESSAGE(160)
Local Shortint NOL : NOL=nolign-1
Local Integer  OK
Local Char     FOURN(GLONBPS)
If [M:POI1]BPSNUM(NOL)="" FOURN=[F:ITP]BPSNUM
                     Else FOURN=[M:POI1]BPSNUM(NOL) : Endif
Call PCAL_QTY(VALEUR,[M:POI1]STU(NOL),QTEUA,[M:POI1]PUU(NOL),
&             [M:POI1]ITMREF(NOL),FOURN,3,WCOEF) From TRTACHQTE1
QTEUA=VALEUR*WCOEF
Gosub POINT_PURQTYRND From SUBPOHB
#----- Contrôle si multiple de l'unité d'achat -----#
Raz WMESSAGE
Call PCAL_QTY(QTEUA,[M:POI1]PUU(NOL),GBIDD1,[M:POI1]STU(NOL),
&             [M:POI1]ITMREF(NOL),FOURN,1,GBIDD2) From TRTACHQTE1
If GBIDD1<>VALEUR  WMESSAGE=mess(302,194,1)+"\" : Endif
#-----
If [M:POI1]UOM(NOL)<>[M:POI1]STU(NOL)
  QTEUC=[M:POI1]QTYUOM(NOL)
  WCOEF=arr(QTEUA/QTEUC,0.000001)
  If WCOEF<>[M:POI1]UOMPUUCOE(NOL)  WMESSAGE-=mess(241,194,1) : Endif
Else
  QTEUC=VALEUR
  If QTEUC<>0
    WCOEF=arr(QTEUA/QTEUC,0.000001)
    If WCOEF=0  WCOEF=1 : Endif
  Endif
  If WCOEF<>[M:POI1]UOMPUUCOE(NOL)  WMESSAGE-=mess(241,194,1) : Endif
Endif
#-----
#VPO 09/12/10 17667 maj qte sur une DA
#If QTEUA<[M:POI1]PURMINQTY(NOL) | VALEUR<[M:POI1]RETQTYSTU(NOL)
If QTEUA<[M:POI1]PURMINQTY(NOL) | VALEUR<>[M:POI1]RETQTYSTU(NOL)
  GBIDD1=QTEUA : GBIDD2=VALEUR
  Call MESSAGE_QTE(1,NOL) From SUBPOI : If mkstat  End : Endif
Endif
#----- Avertissement si commande de contremarque -----#
If [M:POI1]SOHNUM(NOL)<>"" & VALEUR<>[M:POI1]RETQTYSTU(NOL)
  #-----
  If [F:SOQ]SOHNUM<>[M:POI1]SOHNUM(NOL) |
&    [F:SOQ]SOPLIN<>[M:POI1]SOPLIN(NOL) |
&    [F:SOQ]SOQSEQ<>[M:POI1]SOQSEQ(NOL)
    Read [SOQ] SOQ0=[M:POI1]SOHNUM(NOL);[M:POI1]SOPLIN(NOL);[M:POI1]SOQSEQ(NOL)
    If fstat  Raz [F:SOQ] : Endif
  Endif
  #----- Contremarque directe -----#
  If [F:SOQ]FMI=2
    Call ERREUR(mess(396,194,1)) From GESECRAN : mkstat=1 : End
  #----- Autre -----#
  Else
    OK=2 : Call AVERTIR(mess(117,194,1),OK) From GESECRAN
    If OK=1  mkstat=1 : End : Endif
  Endif
Endif
#-----
If WMESSAGE<>""  Call MESSAGE(WMESSAGE) From GESECRAN : Endif
#----- Affichage des quantités -----#
[M:POI1]QTYUOM(NOL)=QTEUC : [M:POI1]QTYPUU(NOL)=QTEUA
[M:POI1]UOMPUUCOE(NOL)=WCOEF
Affzo [POI1]QTYUOM(NOL),UOMPUUCOE(NOL),QTYPUU(NOL)
#----- Recherche tarif ? après modif qté -----#
[M:POI1]QTYSTU(NOL)=VALEUR
If find([M:POI1]LINFLG(NOL),1,2) & [M:POI1]LINTYP(NOL)<>2
  Local Integer OK
  OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
  If OK=2
    Call INI_TARIF(NOL)
  Else
    Call REAJUST_TARIF("POI1",NOL,[M:POI1]UOM(NOL),[M:POI1]UOM(NOL),1,1) From TRTACHPRI1
  Endif
Elsif [M:POI1]LINFLG(NOL)=0 & [M:POI1]LINTYP(NOL)<>2
  Call INI_TARIF(NOL)
Elsif [M:POI1]LINTYP(NOL)<>2
  Call REAJUST_TARIF("POI1",NOL,[M:POI1]UOM(NOL),[M:POI1]UOM(NOL),1,1) From TRTACHPRI1
Endif
#-----

End

Subprog AM_PJT(VALEUR)
#------------------------------------#
# Après modification du code affaire #
#------------------------------------#
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
#----- Recherche tarif ? après modif qté -----#
[M:POI1]PJT(NOL)=VALEUR
If find([M:POI1]LINFLG(NOL),1,2) & [M:POI1]LINTYP(NOL)<>2
  Local Integer OK
  OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
  If OK=2 Call INI_TARIF(NOL) : Endif
Elsif [M:POI1]LINTYP(NOL)<>2
  Call INI_TARIF(NOL)
Endif
End

Subprog IB_BPSNUM
#------------------------#
# Activation des boutons #
#------------------------#
Raz GBOUT5, GBOUT6
GBOUTS=mess(252,195,1)           : # Sélection générale fournisseurs
GBOUT1=mess(251,195,1)           : # Sélection fournisseurs article
If [M:POI1]SOHNUM(nolign-1)<>""
  GBOUT2=mess(253,195,1)         : # Sélection fournisseurs contremarque
Else
  Raz GBOUT2
Endif
GBOUT3=mess(457,198,1)           : # Fornisseurs
GBOUT4=mess(24,198,1)            : # Dernier prix
End

Subprog AM_BPSNUM(VALEUR)
#-------------------------#
# Après modif fournisseur #
#-------------------------#
Variable Char    VALEUR()
#----- Variables locales -----#
Local    Char     WPOHFCY(GLONFCY) : [L]WPOHFCY=[M:POI1]POHFCY
Local    Char     WBPSNUM(GLONBPS) : [L]WBPSNUM=VALEUR
Local    Libelle  WORI             : [L]WORI=2
Local    Char     WUOM(GLONUOM)
Local    Char     WPUU(GLONUOM)
Local    Decimal  WQTE
Local    Integer  I, OK, WFLG
Local    Shortint NOL : NOL=nolign-1
Local    Char     SAV_BPSNUM(GLONBPS) : [L]SAV_BPSNUM=[M:POI1]BPSNUM(NOL) # Issue 119084 - 2016-10-13 by MUARN : question init compte
# Issue X3-55891 - 2018-08-21 by SR : Données déclinées par société
Local Integer WITMBPS, WRETOUR
WITMBPS = 0
#----- Lecture BPARTNER si nécessaire pour chargement CUR -----#
If [F:BPR]BPRNUM<>VALEUR
  Read [BPR] BPR0=VALEUR
  If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
[M:POI1]ORICRY(NOL)=[F:BPR]CRY : Affzo [POI1]ORICRY(NOL)
#----- Lecture BPSUPPLIER si nécessaire pour chargement cours -----#
If [F:BPS]BPSNUM<>VALEUR
  Read [BPS] BPS0=VALEUR : If fstat Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
Endif
[M:POI1]CHGTYP(NOL)=[F:BPS]CHGTYP
#----- Chargement du cours devise -----#
Call COURSITE([F:BPS]CUR,GFCY,[F:BPS]CHGTYP,[M:POI1]ORDDAT,[M:POI1]CHGCOE(NOL),I) From TRTDEV
#----- Lecture ITMMASTER si nécessaire -----#
If [F:ITM]ITMREF<>[M:POI1]ITMREF(NOL)
  Read [ITM] ITM0=[M:POI1]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
Endif
# Issue X3-55891 - 2018-09-26 by SR : Déplacé avant contrôle flag douteux
#----- Contrôle et chargement des zones inter-sites -----#
Gosub CTRL_INTERSITE : If mkstat  End : Endif
#----- Article référencé chez le fournisseur -----#
Read [ITP] ITP0=[M:POI1]ITMREF(NOL);VALEUR
If !fstat
  # Issue X3-55891 - 2018-08-21 by SR : données déclinées par site
#  #----- Article douteux pour ce fournisseur -----#
#  If [F:ITP]DOUFLG=2
#    OK=2 : Call AVERTIR(mess(9,194,1),OK) From GESECRAN
#    If OK=1 Goto RETOURBPSNUM : Endif
#  Endif
#  #---- L'article est en litige -----#
#  If [F:ITP]DOUFLG=3
#    GMESSAGE=mess(9,194,1) : GERR=1 : Goto RETOURBPSNUM
#  #----- Le fournisseur n'est pas contremarque ! -----#
#  Elsif [M:POI1]SOHNUM(nolign-1)<>"" & [F:ITP]CTMBPSFLG<>2
#    OK=2 : Call AVERTIR(mess(352,194,1),OK) From GESECRAN
#    If OK=1 Goto RETOURBPSNUM : Endif
#  Endif
  # Intersite
  If [M:POI1]BETFCY(NOL)=2 & [M:POI1]BETCPY(NOL)<>2
    Call CTRL_DOUFLG(2,[M:POI1]ITMREF(NOL),VALEUR,[M:POI1]PRHFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
  Else
    Call CTRL_DOUFLG(1,[M:POI1]ITMREF(NOL),VALEUR,[M:POI1]PRHFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
  Endif
  If WRETOUR<>0
    VALEUR=[M:POI1]BPSNUM(NOL)
    Goto RETOURBPSNUM
  Endif
  WPUU=[F:ITP]PUU
Else
  Raz [F:ITP]
  # Issue 77999 - 2011-11-18 by VPO : référencement inutile si fournisseur de type Divers
  If [F:BPS]BPSNUM<>VALEUR
    Read [BPS] BPS0=VALEUR : If fstat Raz [F:BPS] : Endif
  Endif
  #----- Si fournisseur <> Divers -----#
  If [F:BPS]BPSTYP<>3
    #----- Si article non générique -----#
    If [F:ITM]GENFLG<>2
      # Issue X3-55891 - 2018-09-26 by SR : Déclinaison pas site
#      If GITMBPS=1
#        GMESSAGE=mess(8,194,1) : GERR=1
#        Goto RETOURBPSNUM
#      Elsif GITMBPS=2
#        OK=2 : Call AVERTIR(mess(8,194,1),OK) From GESECRAN
#        If OK=1  Goto RETOURBPSNUM : Endif
#      Endif
#    Endif
      # que si pas Intersite
      If [M:POI1]BETFCY(NOL)<>2 | [M:POI1]BETCPY(NOL)=2
        Call CTRL_ITMBPS([M:POI1]ITMREF(NOL),VALEUR,[M:POI1]PRHFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
        If WRETOUR <>0 : Goto RETOURBPSNUM : Endif
      Endif
      # End issue X3-55891
    Endif
  Endif
  WPUU=[F:ITM]PUU
Endif
# Issue X3-55891 - 2018-09-26 by SR : Déplacé avant contrôle flag douteux
##----- Contrôle et chargement des zones inter-sites -----#
#Gosub CTRL_INTERSITE : If mkstat  End : Endif
#----- Chargement des taxes -----#
[M:POI1]BPSNUM(NOL)=VALEUR
If [M:POI1]LINTYP(NOL)<>2
  Call ALIVATCOD(2,[M:POI1]BPSNUM(NOL),[M:POI1]ITMREF(NOL),"POI1",NOL) From TRTX3
Endif
# Issue 119084 - 2016-10-13 by MUARN : question init compte
If SAV_BPSNUM <> [M:POI1]BPSNUM(NOL) & [M:POI1]UPDFLG(NOL)=1
  OK=2 : Call OUINON(mess(340,194,1),OK) From GESECRAN
  If OK=2
    Local Char     SAV_LINACC1(GLONGAC) : SAV_LINACC1=[M:POI1]LINACC1(NOL)
    Local Char     SAV_LINACC2(GLONGAC) : SAV_LINACC2=[M:POI1]LINACC2(NOL)
    Call INIT_COMPTES_LIGNE (NOL) From SUBPOI
    Call D_LINPURTYP([M:POI1]LINPURTYP(NOL))
    GBIDI2=0 : Gosub PREP_INIT_CCE
    If !GIMPORT
      Gosub AFFICH_LINACC
      Gosub AFFICH_CCE
      Affzo [POI1]LINPURTYP(NOL)
    Endif
  Endif
Endif
#----- Chargement valeurs ligne avec l'article fournisseur -----#
If [F:ITP]ITMREF<>""
  If [F:ITP]QUAFLG>1
    [M:POI1]QUAFLG(NOL)=2
  Else
    [M:POI1]QUAFLG(NOL)=1
  Endif
  [M:POI1]PURMINQTY(NOL)=[F:ITP]PURMINQTY
Else
  If [F:ITF]ITMREF<>[M:POI1]ITMREF(NOL) | [F:ITF]STOFCY<>[M:POI1]PRHFCY(NOL)
    Read [ITF] ITF0=[M:POI1]ITMREF(NOL);[M:POI1]PRHFCY(NOL)
    If fstat  Raz [F:ITF] : Endif
  Endif
  If [F:ITF]QUAFLG>1
    [M:POI1]QUAFLG(NOL)=2
  Else
    [M:POI1]QUAFLG(NOL)=1
  Endif
  Raz [M:POI1]PURMINQTY(NOL)
Endif
#-----
If GACTDEB=2
  If [F:ITP]EECINCRAT<>0
    [M:POI1]EECINCRAT(NOL)=[F:ITP]EECINCRAT
  Else
    [M:POI1]EECINCRAT(NOL)=[F:BPS]EECINCRAT
  Endif
  Affzo [POI1]EECINCRAT(NOL)
Endif
#---- Conversion quantité dans la nouvelle unité d'achat a partir de l'US ----#
Raz WFLG
GBIDD2=[M:POI1]QTYPUU(NOL)
Call PCAL_QTY([M:POI1]QTYSTU(NOL),[M:POI1]STU(NOL),[M:POI1]QTYPUU(NOL),
&             WPUU,[M:POI1]ITMREF(NOL),VALEUR,1,GBIDD1)  From TRTACHQTE1
If WPUU<>[M:POI1]PUU(NOL) | GBIDD2<>[M:POI1]QTYPUU(NOL)  WFLG=1 : Endif
#-----
If !find([M:POI1]UOM(NOL),[F:ITM]PCU(0..dim([F:ITM]PCU)-1)) & [M:POI1]UOM(NOL)<>[F:ITP]PCU
  WUOM=WPUU
Else
  WUOM=[M:POI1]UOM(NOL)
Endif
#----- Appel du s/p pour chargement du coefficient avec précision maxi -----#
Call PCAL_QTY([M:POI1]QTYUOM(NOL),WUOM,GBIDD1,WPUU,
&             [M:POI1]ITMREF(NOL),VALEUR,1,GCOEUOM) From TRTACHQTE1
#----- Calcul si nécessaire de la nouvelle quantité en UC -----#
If WUOM<>[M:POI1]UOM(NOL) | WPUU<>[M:POI1]PUU(NOL) | GCOEUOM<>[M:POI1]UOMPUUCOE(NOL) | WFLG
  [M:POI1]UOM(NOL)      =WUOM
  [M:POI1]PUU(NOL)      =WPUU
  [M:POI1]UOMPUUCOE(NOL)=GCOEUOM
  Call PCAL_QTY([M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),[M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),
&               [M:POI1]ITMREF(NOL),VALEUR,1,GBIDD1) From TRTACHQTE1
  #----- Initialisation indicateur commande en UC e coefficient UC-UA -----#
  If WUOM=WPUU
    [M:POI1]UOMFLG(NOL)=2
    Raz [M:POI1]UOMPUUCOE(NOL), [M:POI1]PUU(NOL)
    Affzo [POI1]UOMPUUCOE(NOL), PUU(NOL)
    [M:POI1]UOMPUUCOE(NOL)=1 : [M:POI1]PUU(NOL)=WPUU : [M:POI1]UOMFLG(NOL)=1
  Else
    [M:POI1]UOMFLG(NOL)=2
  Endif
  #----- L'unité d'achat a changé -----#
  If WFLG
    #----- Recalcul de l'US à partir de l'UA pour test si écart -----#
    Call PCAL_QTY([M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),WQTE,[M:POI1]STU(NOL),
&                 [M:POI1]ITMREF(NOL),VALEUR,1,GBIDD1) From TRTACHQTE1
    #----- Il y a un écart, le conditionnement ou l'UA est différente -----#
    If WQTE<>[M:POI1]QTYSTU(NOL)
      GMESSAGE =mess(394,194,1)
      GMESSAGE-="("+[M:POI1]PUU(NOL)-"="-num$(GBIDD1)-[M:POI1]STU(NOL)+")"
      GMESSAGE-="\"+mess(395,194,1)
      OK=1 : Call OUINON(GMESSAGE,OK) From GESECRAN
      If OK=2
        #----- Quantité commandée en US -----#
        [M:POI1]UOM(NOL)   =[M:POI1]STU(NOL)
        [M:POI1]QTYUOM(NOL)=WQTE
        [M:POI1]QTYSTU(NOL)=WQTE
        #----- Appel du s/p pour chargement du coefficient avec précision maxi -----#
        Call PCAL_QTY([M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),GBIDD1,[M:POI1]PUU(NOL),
&                     [M:POI1]ITMREF(NOL),VALEUR,1,GCOEUOM) From TRTACHQTE1
        [M:POI1]UOMPUUCOE(NOL)=GCOEUOM
        #----- Ajustement à la hausse qtés UC, UA et US si prise en compte besoins -----#
        If WQTE<[M:POI1]RETQTYSTU(NOL)
          If clalev([F:TUN])=0  Local File TABUNIT [TUN] : Endif
          If [F:TUN]UOM<>[M:POI1]PUU(NOL)
            Read [TUN]TUN0=[M:POI1]PUU(NOL) : If fstat Raz [F:TUN] : Endif
          Endif
          [M:POI1]QTYPUU(NOL)+=10^-[F:TUN]UOMDEC
          Call PCAL_QTY([M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),WQTE,[M:POI1]STU(NOL),
&                       [M:POI1]ITMREF(NOL),VALEUR,1,GBIDD1) From TRTACHQTE1
          [M:POI1]QTYUOM(NOL)=WQTE
          [M:POI1]QTYSTU(NOL)=WQTE
        Endif
        #-----
      Else
        #----- Réajustement à la hausse de la quantité US -----#
        If WQTE>=[M:POI1]QTYSTU(NOL)
          [M:POI1]QTYSTU(NOL)=WQTE
        #----- Réajustement à la hausse des quantités UC, UA et US -----#
        Else
          If clalev([F:TUN])=0  Local File TABUNIT [TUN] : Endif
          If [F:TUN]UOM<>[M:POI1]UOM(NOL)
            Read [TUN]TUN0=[M:POI1]UOM(NOL) : If fstat Raz [F:TUN] : Endif
          Endif
          [M:POI1]QTYUOM(NOL)+=10^-[F:TUN]UOMDEC
          Call PCAL_QTY([M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),[M:POI1]QTYPUU(NOL),
&                 [M:POI1]PUU(NOL),[M:POI1]ITMREF(NOL),VALEUR,1,GBIDD1) From TRTACHQTE1
          Call PCAL_QTY([M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),[M:POI1]QTYSTU(NOL),
&                 [M:POI1]STU(NOL),[M:POI1]ITMREF(NOL),VALEUR,1,GBIDD1) From TRTACHQTE1
          Affzo
        Endif
      Endif
    Endif
  #----- L'unité de commande a changé -----#
  Else
    #----- Recalcul de l'UA à partir de l'UC pour test si écart -----#
    Call PCAL_QTY([M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),WQTE,[M:POI1]PUU(NOL),
&                 [M:POI1]ITMREF(NOL),VALEUR,1,GBIDD1) From TRTACHQTE1
    #----- Il y a un écart, le conditionnement ou l'UA est différente -----#
    If WQTE<>[M:POI1]QTYPUU(NOL)
      GMESSAGE =mess(394,194,1)
      GMESSAGE-="("+[M:POI1]PUU(NOL)-"="-num$(GBIDD1)-[M:POI1]STU(NOL)+")"
      GMESSAGE-="\"+mess(395,194,1)
      OK=1 : Call OUINON(GMESSAGE,OK) From GESECRAN
      If OK=2
        #----- Quantité commandée en US -----#
        [M:POI1]UOM(NOL)   =[M:POI1]STU(NOL)
        [M:POI1]QTYUOM(NOL)=[M:POI1]QTYSTU(NOL)
        #----- Appel du s/p pour chargement du coefficient avec précision maxi -----#
        Call PCAL_QTY([M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),GBIDD1,[M:POI1]PUU(NOL),
&                     [M:POI1]ITMREF(NOL),VALEUR,1,GCOEUOM) From TRTACHQTE1
        [M:POI1]UOMPUUCOE(NOL)=GCOEUOM
        #----- Ajustement à la hausse qtés UC, UA et US si prise en compte besoins -----#
        If [M:POI1]QTYSTU(NOL)<[M:POI1]RETQTYSTU(NOL)
          If clalev([F:TUN])=0  Local File TABUNIT [TUN] : Endif
          If [F:TUN]UOM<>[M:POI1]PUU(NOL)
            Read [TUN]TUN0=[M:POI1]PUU(NOL) : If fstat Raz [F:TUN] : Endif
          Endif
          [M:POI1]QTYPUU(NOL)+=10^-[F:TUN]UOMDEC
          Call PCAL_QTY([M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),WQTE,[M:POI1]STU(NOL),
&                       [M:POI1]ITMREF(NOL),VALEUR,1,GBIDD1) From TRTACHQTE1
          [M:POI1]QTYUOM(NOL)=WQTE
          [M:POI1]QTYSTU(NOL)=WQTE
        Endif
        #-----
      Else
        #----- Réajustement à la hausse des quantités UA et US -----#
        If WQTE>=[M:POI1]QTYPUU(NOL)
          [M:POI1]QTYPUU(NOL)=WQTE
          Call PCAL_QTY([M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),[M:POI1]QTYSTU(NOL),
&                 [M:POI1]STU(NOL),[M:POI1]ITMREF(NOL),VALEUR,1,GBIDD1) From TRTACHQTE1
        #----- Réajustement à la hausse des quantités UC, UA et US -----#
        Else
          If clalev([F:TUN])=0  Local File TABUNIT [TUN] : Endif
          If [F:TUN]UOM<>[M:POI1]UOM(NOL)
            Read [TUN]TUN0=[M:POI1]UOM(NOL) : If fstat Raz [F:TUN] : Endif
          Endif
          [M:POI1]QTYUOM(NOL)+=10^-[F:TUN]UOMDEC
          Call PCAL_QTY([M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),[M:POI1]QTYPUU(NOL),
&                 [M:POI1]PUU(NOL),[M:POI1]ITMREF(NOL),VALEUR,1,GBIDD1) From TRTACHQTE1
          Call PCAL_QTY([M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),[M:POI1]QTYSTU(NOL),
&                 [M:POI1]STU(NOL),[M:POI1]ITMREF(NOL),VALEUR,1,GBIDD1) From TRTACHQTE1
        Endif
      Endif
    Endif
  Endif
  #----- Chargement indicateur modif du coefficient -----#
  Gosub CHARG_COEFLG
Endif
#----- Si inter-sites, contrôle que l'unité de commande convienne pour les ventes -----#
If [M:POI1]BETFCY(NOL)=2 & [M:POI1]BPCORD(NOL)<>""
  WUOM=[M:POI1]UOM(NOL)
  Call CTLUOM([M:POI1]ITMREF(NOL),2,[M:POI1]BPCORD(NOL),WUOM,GBIDD2,
&             GBIDC2,GBIDC3,GBIDI2) From STKACT
  If mkstat
    If [F:ITM]PCU(0)<>""
      Raz mkstat, GMESSAGE : WUOM=[F:ITM]PCU(0)
      Call AM_UOM(WUOM) From SUBPOI : If mkstat  Goto RETOURBPSNUM : Endif
      [M:POI1]UOM(NOL)=WUOM
    Else
      Goto RETOURBPSNUM
    Endif
  Endif
Endif
#-----
If [M:POI1]QTYUOM(NOL)=0
  [M:POI1]QTYUOM(NOL)=1 : Call AM_QTYUOM([M:POI1]QTYUOM(NOL)) From SUBPOI
Endif
#-----
Affzo [POI1]QTYUOM(NOL),UOM(NOL),UOMPUUCOE(NOL),PUU(NOL),QTYPUU(NOL),STU(NOL),QTYSTU(NOL)
#----- Fin normal : Tests qté mini et passage au champ suivant -----#
$SUITEBPSNUM
#VPO 09/12/10 17667 maj qte sur une DA
#&  [M:POI1]QTYSTU(NOL)<[M:POI1]RETQTYSTU(NOL)
If [M:POI1]QTYPUU(NOL)<[M:POI1]PURMINQTY(NOL) |
&  [M:POI1]QTYSTU(NOL)<>[M:POI1]RETQTYSTU(NOL)
  GBIDD1=[M:POI1]QTYPUU(NOL) : GBIDD2=[M:POI1]QTYSTU(NOL)
  Call MESSAGE_QTE(1,NOL) From SUBPOI
  If mkstat  mkstat=0 : Endif
Endif
[M:POI1]CUR(NOL)=[F:BPS]CUR : Affzo [POI1]CUR(NOL)
If [M:POI1]LINTYP(NOL)<>2
  [M:POI1]BPSNUM(NOL)=VALEUR  : Call INI_TARIF(NOL)
Endif
# Issue 112754 - 2016-10-20 by MUARN : service
# Issue 103298 GA 10/2014 also for a WO
#If [M:POI1]SCOADD(NOL)="" & find([M:POI1]LINTYP(NOL),2,3)
#If [M:POI1]SCOADD(NOL)="" & (find([M:POI1]LINTYP(NOL),2,3) | [M:POI1]VCRTYPORI(NOL)=10)
If [M:POI1]SCOADD(NOL)="" & ( [M:POI1]ITMKND(NOL)=2 | [F:ITM]SCPFLG=2 )
  Look [BPD] BPD0=[M:POI1]BPSNUM(NOL);[F:BPS]BPAADD
  If !fstat
    [M:POI1]SCOADD(NOL)=[F:BPS]BPAADD
  Else
    Raz [M:POI1]SCOADD(NOL)
  Endif
Else
  Raz [M:POI1]SCOADD(NOL)
Endif
End
#----- Retour à la saisie du numéro fournisseur -----#
$RETOURBPSNUM
mkstat=1
End

Subprog AS_LINSTOFCY(VALEUR)
#--------------------------------#
# Avant saisie site d'expédition #
#--------------------------------#
Variable Char    VALEUR()
Local    Shortint NOL : NOL=nolign-1
If [M:POI1]BETFCY(NOL)<>2  mkstat=2 : End : Endif : # Uniquement pour inter-sites !
End

Subprog C_LINSTOFCY(VALEUR)
#----------------------------#
# Contrôle site d'expédition #
#----------------------------#
Variable Char    VALEUR()
Local    Shortint NOL : NOL=nolign-1
If [M:POI1]BETFCY(NOL)<>2 & VALEUR=""  End : Endif
If VALEUR="" & [M:POI1]BETFCY(NOL)=2  : mkstat=1 : End : Endif
If [F:FCY]LEGCPY<>GCPY GMESSAGE=mess(2,194,1) : mkstat=1 : Endif
If VALEUR=[M:POI1]PRHFCY(NOL)
  GMESSAGE=mess(259,194,1) : mkstat=2 : End
Endif
End

Subprog AM_LINSTOFCY(VALEUR)
Variable Char    VALEUR()  # FGR 19/01/2010 : X3SUIVI60986

#----------------------------#
# Apres-modif du site d'expé #
#----------------------------#
Local    Shortint NOL : NOL=nolign-1
If [M:POI1]BETFCY(NOL)<>2 & VALEUR=""  End : Endif
If [M:POI1]CREFLG(NOL)=0
  Local Char WITMREF(GLONITM) : WITMREF=[M:POI1]ITMREF(NOL)
  Local Char WSTOFCY(GLONFCY) : WSTOFCY=VALEUR
  Gosub CTRL_BETFCYITM
Endif
End

Subprog IB_SCOADD
#--------------------------------------#
# Initialisation bouton "Client livré" #
#--------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
GBOUT1=mess(42,191,1)-[M:POI1]BPSNUM(nolign-1)
End

Subprog AS_SCOADD(VALEUR)
#--------------------------------------------#
# Avant saisie du code adresse sous-traitant #
#--------------------------------------------#
Variable Char    VALEUR()
If [F:ITM]ITMREF<>[M:POI1]ITMREF(nolign-1)
  Read [ITM] ITM0=[M:POI1]ITMREF(nolign-1) : If fstat  Raz [F:ITM] : Endif
Endif
# Issue 112754 - 2016-11-28 by SR : Services
If [M:POI1]LINTYP(nolign-1)<2 & [M:POI1]ITMKND(nolign-1)<>2 & [F:ITM]SCPFLG<>2
  mkstat=2 : End
Endif
End

Subprog C_SCOADD(VALEUR)
#--------------------------------#
# Contrôle adresse sous-traitant #
#--------------------------------#
Variable Char    VALEUR()
If VALEUR=""  End : Endif
If [F:ITM]ITMREF<>[M:POI1]ITMREF(nolign-1)
  Read [ITM] ITM0=[M:POI1]ITMREF(nolign-1) : If fstat  Raz [F:ITM] : Endif
Endif
# Issue 112754 - 2016-11-28 by SR : Services
If [M:POI1]ITMKND(nolign-1)=2 | [F:ITM]SCPFLG=2
  Look [BPD] BPD0=[M:POI1]BPSNUM(nolign-1);VALEUR
  If fstat  GMESSAGE=mess(16,199,1) : mkstat=1 : Endif
Endif
End

$AB1_SCOADD
#------------------------------------------#
# Avant exécution du tunnel Clients livrés #
#------------------------------------------#
GBPCNUM=[M:POI1]BPSNUM(nolign-1)
Return

$BB1_SCOADD
#------------------------------------------#
# Après exécution du tunnel Clients livrés #
#------------------------------------------#
Raz GBPCNUM
If [F:BPD]BPCNUM=[M:POI1]BPSNUM(nolign-1) & [F:BPD]BPAADD<>""
  VALEUR=[F:BPD]BPAADD
Endif
Return

Subprog IB_EXTRCPDAT
#------------------------------#
# Gestion bouton "Stock Prév." #
#------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5 : # GBOUT1 chargé par l'action CONSSPR
If [M:POI1]STOMGTCOD(nolign-1)<2 Raz GBOUT1 : Endif
#----- Lecture du site de réception si nécessaire -----#
If [F:FCY]FCY<>[M:POI1]PRHFCY(nolign-1)
  Read [FCY] FCY0=[M:POI1]PRHFCY(nolign-1) : If fstat Raz [F:FCY] : Endif
Endif
End

Subprog AS_EXTRCPDAT(VALEUR)
#---------------------------------------------#
# Avant saisie de la date de réception prévue #
#---------------------------------------------#
Variable Date    VALEUR
#----- Pas de saisie pour le service et matières fournies -----#
If !GIMPORT & [M:POI1]LINTYP(nolign-1)>2  mkstat=2 : End : Endif
End

Subprog AM_EXTRCPDAT(VALEUR)
#-------------------------------------------------#
# Après modif : Contrôle date de réception prévue #
#-------------------------------------------------#
Variable Date    VALEUR
Local    Integer OK : OK=1
If [M:POI1]RETQTYSTU(nolign-1)<>0 & VALEUR>[M:POI1]RETRCPDAT(nolign-1)
  [M:POI1]EXTRCPDAT(nolign-1)=VALEUR : Affzo [POI1]EXTRCPDAT(nolign-1)
  Call AVERTIR(mess(95,194,1)-format$("DD2",[M:POI1]RETRCPDAT(nolign-1)),OK) From GESECRAN
  If OK=1 mkstat=1 : End : Endif
Endif
If [M:POI1]RETQTYSTU(nolign-1)=0  & VALEUR<[M:POI1]RETRCPDAT(nolign-1)
  If [F:FCY]FCY<>[M:POI1]PRHFCY(nolign-1)
    Read [FCY] FCY0=[M:POI1]PRHFCY(nolign-1) : If fstat Raz [F:FCY] : Endif
  Endif
  Call CTL_JOU2(VALEUR,[M:POI1]ORDDAT,[F:FCY]UVYDAY,[F:FCY]UVYCOD,0) From CONTX3
  Raz mkstat, GMESSAGE
  [M:POI1]EXTRCPDAT(nolign-1)=VALEUR : Affzo [POI1]EXTRCPDAT(nolign-1)
Endif
# Issue X3-68900 - 2018-01-24 by MUARN : modification dates sur EO
If [M:POI1]LINTYP(nolign-1) = 2
  # existance de commande sur EO
  If [F:SCI]SCONUM<>[M:POI1]VCRNUMORI(nolign-1) | [F:SCI]SCILIN<>[M:POI1]VCRLINORI(nolign-1)
    # lecture article ordre de sous-traitance
    Read [SCI]SCI0=[M:POI1]VCRNUMORI(nolign-1);[M:POI1]VCRLINORI(nolign-1)
    If fstat : LRET = 1 : End : Endif
  Endif
  # pas de commande sur EO, question pour répercusion date sur EO
  If [F:SCI]POHNUM = ""
    OK=1
    Call OUINON("Voulez-vous réajuster la date de début de l'ordre de sous-traitance avec la date de commande ?",OK) From GESECRAN
    If OK=2
      [M:POI1]UPDSCO(nolign-1)=2
    Else
      [M:POI1]UPDSCO(nolign-1)=1
    Endif
  Endif
Endif
End

Subprog AM_CUR(VALEUR)
#----------------------------------------------#
# Après modif devise : Chargement cours devise #
#----------------------------------------------#
Variable Char    VALEUR()
Local    Integer I
Local    Shortint NOL : NOL=nolign-1
Call COURSITE(VALEUR,GFCY,[M:POI1]CHGTYP,[M:POI1]ORDDAT,[M:POI1]CHGCOE,I) From TRTDEV
[M:POI1]CUR(NOL)=VALEUR
If [M:POI1]LINTYP(NOL)<>2  Call INI_TARIF(NOL) : Endif
End

Subprog IB_GROPRI
#--------------------------------------------------------------------------#
# Activation boutons "Tarifs", "Rem/Frs", "Réinit.Prix", "Explication Prix #
# Lecture fournisseur et chargement paramètres tarif si besoin             #
#--------------------------------------------------------------------------#
Local    Shortint NOL : NOL=nolign-1
GBOUT1=mess(42,198,1) : GBOUT3=mess(20,198,1) : GBOUT4=mess(52,198,1)
If [M:POI1]GROPRI(NOL)=0
  Raz GBOUT5 : # Pas de bouton "Explication du prix" si prix nul
Endif
#----- Lecture BPSUPPLIER si nécessaire pour nom & structure tarif -----#
If [F:BPS]BPSNUM<>[M:POI1]BPSNUM(NOL)
  Read [BPS] BPS0=[M:POI1]BPSNUM(NOL) : If fstat Raz [F:BPS] : Endif
Endif
#----- Chargement paramètres et libellés colonnes tarif -----#
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
Endif
End

Subprog B4_GROPRI(VALEUR)
#------------------------#
# Bouton : "Réinit.Prix" #
#------------------------#
Variable Decimal  VALEUR
Local    Shortint NOL : NOL=nolign-1
Call INI_TARIF(NOL)   : VALEUR=[M:POI1]GROPRI(NOL)
mkstat=99
End

Subprog AP_GROPRI(VALEUR)
#-----------------------------------------------------------------#
# Après saisie du prix brut : Test si prix nul (sauf inter-sites) #
#-----------------------------------------------------------------#
Variable Decimal  VALEUR
Local    Shortint NOL : NOL=nolign-1
#----- Initialisation des comptes et du type d'achat -----#
If !varinit([M:POI1]LINACC1,NOL) & [M:POI1]ITMREF(NOL)<>""
  Call INIT_COMPTES_LIGNE (NOL) From SUBPOI
  Call D_LINPURTYP([M:POI1]LINPURTYP(NOL)) : # Initialisation type d'achat
  GBIDI2=0 : Gosub PREP_INIT_CCE From SUBPOI
  If !GIMPORT
    Gosub AFFICH_LINACC
    Gosub AFFICH_CCE
  Endif
Endif
#-----
# Issue 59217 - 2014-10-17 by MUARN : obligation tarif achat
#----- Contrôle tarif à zéro pour commande de contremarque (sauf inter-sites) -----#
If [M:POI1]SOHNUM(NOL)<>"" & ([M:POI1]BETFCY(NOL)<>2 | [M:POI1]BETCPY(NOL)=2)
  If [M:POI1]GROPRI(NOL)=0 & [M:POI1]PRIREN(NOL)=0 & [M:POI1]NETPRI(NOL)=0 & GPURCTLPRI0 <> 2
   #----- Erreur si pas de tarif -----#
    GMESSAGE =[M:POI1]SOHNUM(NOL)+"/"+num$([M:POI1]SOPLIN(NOL))
    GMESSAGE+="/"+num$([M:POI1]SOQSEQ(NOL))-mess(67,197,1)-mess(84,197,1)
    OK=1
    GERR=1
    mkstat=1
    End
  Endif
Endif

If VALEUR=0 & ([M:POI1]BETFCY(NOL)<>2 | [M:POI1]BETCPY(NOL)=2)
  Local Integer OK
  OK=2 : Call AVERTIR(mess(62,194,1),OK) From GESECRAN
  If OK=1  mkstat=1 : End : Endif
Endif
End

Subprog PASLINPOI(DISCRGNUM)
#-----------------------------------------------------------#
# Avant saisie prix brut, remises/frais tarif et codes taxe #
#-----------------------------------------------------------#
Value Integer DISCRGNUM
If GMODIF<>2 | [M:POI1]LINTYP(nolign-1)=2  mkstat=2 : Endif
If DISCRGNUM<1 | DISCRGNUM>9 End : Endif
If GCOLREM(DISCRGNUM-1)="" mkstat=2 : Endif
End

