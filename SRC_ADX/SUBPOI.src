Variable Char    VALEUR()
Local    Integer PLAN : PLAN=10 : Gosub AM_LINACCX
End

$AS_LINACCX
#-------------------------------------#
# Avant saisie commune aux 10 comptes #
#-------------------------------------#
If GMODIF<>2  mkstat=2 : Return : Endif
#-----
Return

$C_LINACCX
#--------------------------------#
# Contrôle commun aux 10 comptes #
#--------------------------------#
Local    Shortint NOL : NOL=nolign-1
#-----
Call CTRL_ACC(VALEUR,PLAN,GFINRSP,[M:POI1]ORDDAT,[M:POI1]CUR(NOL),"[M:POI1]LINACC") From TRTX3CPT
#-----
Return

$AM_LINACCX
#------------------------------------#
# Après modif commune aux 10 comptes #
#------------------------------------#
Local    Shortint I
Local    Shortint NOL : NOL=nolign-1
If [F:GAC]COA<>GCOA(PLAN) | [F:GAC]ACC<>VALEUR
   Read [GAC] GAC0=GCOA(PLAN);VALEUR : If fstat Raz [F:GAC] : Endif
Endif
If PLAN=1
  [M:POI1]LINACC1(NOL)=VALEUR
  If !varinit([M:POI1]LINPURTYP,NOL)
    Call D_LINPURTYP ([M:POI1]LINPURTYP(NOL)) From SUBPOI  : # Chargement type d'achat
  Endif
Endif
Assign "[M:POI1]LINACC"+num$(PLAN)+"(NOL)" With VALEUR
GBIDI2=1 : Gosub PREP_INIT_CCE From SUBPOI
Return

Subprog D_LINPURTYP(VALEUR)
#--------------------------------------------------------------#
# Initialisation du type d'achat en fonction du compte général #
#--------------------------------------------------------------#
Variable Integer VALEUR
#----- Recherche compte général -----#
Local Char WACC(GLONGAC)
Call RECH_ACC(1,"[M:POI1]LINACC",nolign-1,WACC) From TRTX3CPT
If WACC<>""
  If [F:GAC]VATIPT=5
    VALEUR=3
  Elsif [F:GAC]VATIPT=4
    VALEUR=2
  Else
    VALEUR=1
  Endif
Else
  VALEUR=1
Endif
End

Subprog AM_LINPURTYP(VALEUR)
#------------------------------------#
# Après modification du type d'achat #
#------------------------------------#
Variable Integer VALEUR
Local Integer OK
OK=2 : Call OUINON(mess(340,194,1),OK) From GESECRAN
If OK=2
  Local Integer  I
  Local Shortint NOL                  : NOL=nolign-1
  Local Char     SAV_LINACC1(GLONGAC) : SAV_LINACC1=[M:POI1]LINACC1(NOL)
  Local Char     SAV_LINACC2(GLONGAC) : SAV_LINACC2=[M:POI1]LINACC2(NOL)
  [M:POI1]LINPURTYP(NOL)=VALEUR
  Call INIT_COMPTES_LIGNE (NOL) From SUBPOI
  [M:POI1]LINPURTYP(NOL)=VALEUR : # Modifié par le Call !
  If [M:POI1]LINACC1(NOL)<>SAV_LINACC1
    Call AM_LINACC1([M:POI1]LINACC1(NOL))
  Endif
  If [M:POI1]LINACC2(NOL)<>SAV_LINACC2
    Call AM_LINACC2([M:POI1]LINACC2(NOL))
  Endif
  If !GIMPORT  Gosub AFFICH_LINACC : Endif
Endif
End

