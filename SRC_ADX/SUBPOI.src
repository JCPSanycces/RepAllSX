VALEUR=[M:POI1]BUY
End

Subprog D_ORDFCY(VALEUR)
#------------------------------------------#
# Initialisation du site de commande ligne #
#------------------------------------------#
Variable Char    VALEUR()
VALEUR=[M:POI1]POHFCY
End

Subprog INI_TARIF(NOL)
#-------------------------#
# Initialisation du tarif #
#-------------------------#
Value  Shortint NOL
Local  Date     OLDRCPDAT
Local Integer   STAT
If [M:POI1]LINTYP(NOL)=2  End : Endif
OLDRCPDAT=[M:POI1]RETRCPDAT(NOL)
#----- Lecture BPSUPPLIER si nécessaire pour nom & structure tarif -----#
If [F:BPS]BPSNUM<>[M:POI1]BPSNUM(NOL)
  Read [BPS] BPS0=[M:POI1]BPSNUM(NOL) : If fstat Raz [F:BPS] : Endif
Endif
#----- Chargement paramètres et libellés colonnes tarif -----#
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
Endif
GPUU=[M:POI1]PUU(NOL) : Call RECH_TARIF ("POI",NOL) From TRTACHTAR1
If OLDRCPDAT<>[M:POI1]RETRCPDAT(NOL)
  [M:POI1]EXTRCPDAT(NOL)=[M:POI1]RETRCPDAT(NOL)
  Affzo [POI1]EXTRCPDAT(NOL)
Endif
Affzo [POI1]GROPRI(NOL)
Affzo [POI1]NETPRI(NOL)
[M:POI1]LINAMT(NOL)=[M:POI1]NETPRI(NOL)*[M:POI1]QTYUOM(NOL)
Call ARRDEV([M:POI1]LINAMT(NOL),[M:POI1]CUR(NOL)) From TRTDIV
Affzo [POI1]LINAMT(NOL)
If [M:POI1]LINFLG(NOL)=1 [M:POI1]LINFLG(NOL)=2 : Endif
End

$CTL_QTYUOM
#-----------------------------------------------------------------------#
# Contrôle sur quantité en UCde : Calcul et contrôle quantités UA et US #
#-----------------------------------------------------------------------#
Local Decimal  QTEUC, QTEUA, QTEUS, WCOEF, SAV_QTEUA
Local Shortint NOL : NOL=nolign-1
Local Char     FOURN(GLONBPS)
If [M:POI1]BPSNUM(NOL)=""
  FOURN=[F:ITP]BPSNUM
Else
  FOURN=[M:POI1]BPSNUM(NOL)
Endif
If [M:POI1]UOM(NOL)=[M:POI1]STU(NOL)
  Call PCAL_QTY(VALEUR,[M:POI1]UOM(NOL),GBIDD1,[M:POI1]PUU(NOL),
&              [M:POI1]ITMREF(NOL),FOURN,3,WCOEF) From TRTACHQTE1
  QTEUA=VALEUR*WCOEF
  WCOEF=arr(WCOEF,0.000001)
Else
  QTEUA=VALEUR*[M:POI1]UOMPUUCOE(NOL)
  WCOEF=[M:POI1]UOMPUUCOE(NOL)
Endif
SAV_QTEUA=QTEUA
Gosub POINT_PURQTYRND From SUBPOHB
Call PCAL_QTY(QTEUA,[M:POI1]PUU(NOL),QTEUS,[M:POI1]STU(NOL),
&             [M:POI1]ITMREF(NOL),FOURN,1,GBIDD1) From TRTACHQTE1
If [M:POI1]UOM(NOL)=[M:POI1]STU(NOL)
  If QTEUS<[M:POI1]RETQTYSTU(NOL)
    QTEARR=arr(SAV_QTEUA,10^-WNBDEC)
    If QTEARR>=SAV_QTEUA-10^-(WNBDEC+3)
      QTEUA=QTEARR
    Else
      QTEUA=QTEARR+10^-WNBDEC
    Endif
    Call PCAL_QTY(QTEUA,[M:POI1]PUU(NOL),QTEUS,[M:POI1]STU(NOL),
&                 [M:POI1]ITMREF(NOL),FOURN,1,GBIDD1) From TRTACHQTE1
  Endif
  QTEUC=QTEUS
  If [M:POI1]COEFLG(NOL)=0 & QTEUC<>0
    WCOEF=max(arr(QTEUA/QTEUC,0.000001),0.000001)
  Endif
Else
  QTEUC=VALEUR
  WCOEF=[M:POI1]UOMPUUCOE(NOL)
Endif
#VPO 09/12/10 17667 maj qte sur une DA
#If QTEUA<[M:POI1]PURMINQTY(NOL) | QTEUS<[M:POI1]RETQTYSTU(NOL)
If QTEUA<[M:POI1]PURMINQTY(NOL) | QTEUS<>[M:POI1]RETQTYSTU(NOL)
  GBIDD1=QTEUA : GBIDD2=QTEUS
  Call MESSAGE_QTE(2,NOL) From SUBPOI
Endif
If [M:POI1]SALFCY(NOL)<>"" & GMESSAGE=""
  Raz GBIDC3, GBIDI3
  #-- X3Suivi 77496 : Commandes achat/vente inter-sociétés désynchronisées --#
  Call C_QTY(1,[M:POI1]BPCORD(NOL), [M:POI1]ITMREF(NOL),[M:POI1]UOM(NOL),GBIDC3,
&            GBIDI3, GBIDI3, VALEUR) From TRTVENISOC
  If GMESSAGE<>""
    GMESSAGE=mess(74,187,1)-"\"-GMESSAGE
  Endif
Endif
Return

#-------------------------------------------------------------------#
# CONVERT_QTY : S/P de conversion de la quantité d'achat après un   #
#                     changement d'unité                            #
#-------------------------------------------------------------------#
# Subprog CONVERT_QTY (QTE1,UA1,QTE2,UA2)                           #
#    QTE1   : Quantité d'achat en unité d'origine                   #
#    UA1    : Unité d'achat d'origine                               #
#    QTE2   : Quantité d'achat en nouvelle unité                    #
#    UA2    : Nouvelle unité d'achat (destination)                  #
#                                                                   #
# En sortie : Chargement de QTE2                                    #
#-------------------------------------------------------------------#
Subprog CONVERT_QTY (QTE1,UA1,QTE2,UA2)
Value    Decimal  QTE1
Value    Char     UA1
Variable Decimal  QTE2
Value    Char     UA2
If UA1<>UA2
  Read [TCO] TCO0=UA1;UA2
  If fstat
    Read [TCO] TCO0=UA2;UA1 : If fstat Raz [F:TCO] : [F:TCO]COEUOM=1 : Endif
    QTE2=QTE1*(1/[F:TCO]COEUOM)
  Else
    QTE2=QTE1*[F:TCO]COEUOM
  Endif
Else
  QTE2=QTE1
Endif
Call QTEARR(QTE2,UA2) From TRTDIV
End

#--------------------------------------------------------------#
# MESSAGE_QTE : S/P d'avertissement sur contrôle des quantités #
#--------------------------------------------------------------#
# Subprog MESSAGE_QTE (CODE,NOL)                               #
#    CODE  : 1 = Affichage du message                          #
#            2 = Chargement de GMESSAGE car action de contrôle #
#    NOL   : Indice de la ligne en cours (nolign-1)            #
#                                                              #
# Remarque : GBIDD1 = Quantité en UA                           #
#            GBIDD2 = Quantité en US                           #
#--------------------------------------------------------------#
Subprog MESSAGE_QTE (CODE,NOL)
Value Integer  CODE
Value Shortint NOL
Local Integer WOK
Local Integer WNB : WNB=0 : #VPO 09/12/10 17667
Raz GMESSAGE, mkstat
#VPO 09/12/10 17667
[M:POI1]UPDPSDFLG(NOL)=1
#--- Test qté inférieure à qté initiale besoins pris en compte (sauf contremarque) ---#
#If GBIDD2<[M:POI1]RETQTYSTU(NOL) & [M:POI1]SOHNUM(NOL)=""
If GBIDD2<>[M:POI1]RETQTYSTU(NOL) & [M:POI1]SOHNUM(NOL)=""
  Filter [PWO] Where PRONUM=adxuid(2)
&                  & CODFNC="POI"
&                  & LINNUM=[M:POI1]POILIN(NOL)
&                  & (WIPTYP=2 | WIPTYP=7)
&                  & WIPSTA=2
#VPO 09/12/10 17667 si une seule ligne de DA, on autorise la modif
  #Read [PWO] PWO0 First
  For [PWO]PWO0
     If [F:PWO]WIPSTA=2 & [F:PWO]WIPTYP=2
      WNB+=1
     Else
      WNB+=2
     Endif
  Next
  Filter [PWO]
  #If !fstat
  #  GMESSAGE=mess(3,194,1)-format$("N:15F",[M:POI1]RETQTYSTU(NOL))-[M:POI1]STU(NOL)
  #Endif
  If WNB>1 & GBIDD2<[M:POI1]RETQTYSTU(NOL)
  GMESSAGE=mess(3,194,1)-format$("N:15F",[M:POI1]RETQTYSTU(NOL))-[M:POI1]STU(NOL)
  Elsif WNB=1
      #le flag va servir pour la mise à jour en modif sur vallig
      [M:POI1]UPDPSDFLG(NOL)=2
  Endif
Endif
#----- Positionnement mkstat et affichage si CODE=1 -----#
If GMESSAGE<>""
  mkstat=1
  If CODE=1  GERR=1 : Endif
  End
Endif
#VPO 15/10/10 17730/59532 contrôle selon paramètre
If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
#----- Test qté inférieure à qté minimum d'achat -----#
If GBIDD1<[M:POI1]PURMINQTY(NOL) & [M:POI1]SOHNUM(NOL)="" & [M:POI1]RETQTYSTU(NOL)=0 & GPOHMINQTY<3
  GMESSAGE=mess(14,194,1)-format$("N:15F",[M:POI1]PURMINQTY(NOL))-[M:POI1]PUU(NOL)
  If GPOHMINQTY=1
      mkstat=1
      If CODE=1  GERR=1 : Endif
      End
  Else : #GPOHMINQTY=2
      #pour ne pas afficher 2 fois le message sur C_QTYUOM et AM_QTYUOM
      If dim(GWPOHMINQTY)<0 : Global Char GWPOHMINQTY (200) : Endif
      If GWPOHMINQTY <> "POI"+num$(NOL)+[M:POI1]ITMREF(NOL)
          GWPOHMINQTY = "POI"+num$(NOL)+[M:POI1]ITMREF(NOL)
          WOK=2
          Call AVERTIR (GMESSAGE, WOK)From GESECRAN
          If WOK=1
              Raz GMESSAGE
              mkstat=1
              If CODE=1 GERR=1 : Endif
              End
          Endif
      Else
          Raz GWPOHMINQTY
      Endif
      Raz GMESSAGE
  Endif
Endif
End


$CHARG_COEFLG
#-----------------------------------------------------------#
# Chargement de l'indicateur de modification du coefficient #
#-----------------------------------------------------------#
If [M:POI1]UOM(NOL)=[M:POI1]PUU(NOL) | [M:POI1]UOM(NOL)=[M:POI1]STU(NOL)
  [M:POI1]COEFLG(NOL)=1
Else
  If [F:ITM]ITMREF<>[M:POI1]ITMREF(NOL)
    Read [ITM] ITM0=[M:POI1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
  Endif
  I=find([M:POI1]UOM(NOL),[F:ITM]PCU)
  If I
    If [F:ITM]DACPCUCOE(I-1)=2 [M:POI1]COEFLG(NOL)=0 Else [M:POI1]COEFLG(NOL)=1 : Endif
  Elsif [M:POI1]UOM(NOL)=[F:ITM]PUU
    If [F:ITM]DACPUUCOE=2      [M:POI1]COEFLG(NOL)=0 Else [M:POI1]COEFLG(NOL)=1 : Endif
  Else
    [M:POI1]COEFLG(NOL)=1
  Endif
Endif
Return


$CTRL_INTERSITE
#---------------------------------------------------------------#
# Contrôle et chargement des zones pour l'inter-sites           #
# ------------------------------------------------------------- #
# WPOHFCY : Site de commande                                    #
# WBPSNUM : Fournisseur de la commande                          #
# WORI    : Origine de l'appel (1=POHFCY, 2=BPSNUM, 3=Trt auto) #
#---------------------------------------------------------------#
If dim(WTRAITFLG)<1  Local Integer WTRAITFLG : Endif
If WORI=3  WTRAITFLG=1 Else  WTRAITFLG=2 : Endif
GRCPFCY=[M:POI1]PRHFCY(NOL)
Call CTRL_INTERSITE(WPOHFCY,WBPSNUM,WTRAITFLG,[M:POI1]BETFCY(NOL),[M:POI1]BETCPY(NOL),
&                   [M:POI1]SALFCY(NOL),[M:POI1]LINSTOFCY(NOL),
&                   [M:POI1]BPCORD(NOL),[M:POI1]INVFCY(NOL),
&                   [M:POI1]BPCINV(NOL),[M:POI1]DME(NOL)) From TRTACHCTL1
If mkstat  GERR=1 : Return : Endif
[M:POI1]SOHCAT(NOL)=0
#----- Si inter-sites et site d'expédition vide, il doit être saisissable -----#
If [M:POI1]BETFCY(NOL)=2
  If clalev([F:PTR])
    If [F:PTR]PTRTYP<>3 & [F:PTR]PTRNUM<>GPTRNUM
      Read [PTR] PTR0=3;GPTRNUM : If fstat  Raz [F:PTR] : Endif
    Endif
  Endif
  If  [M:POI1]LINSTOFCY(NOL)=""
    If clalev([F:PTR]) & [F:PTR]STOFCYCOD<>1
      GMESSAGE=mess(257,194,1) : GERR=1 : mkstat=1 : Return
    Elsif !clalev([F:PTR]) | WTRAITFLG=1
      GMESSAGE=mess(285,194,1) : GERR=1 : mkstat=1 : Return
    Endif
    If [M:POI1]INVFCY=""
      If [F:PTR]INVFCYCOD<>1
        #Inter-sites : Site financier lié au client non trouvé ou incorrect
        GMESSAGE=mess(299,194,1) : GERR=1 : mkstat=1 : Return
      Endif
    Endif
    Local Char WITMREF(GLONITM)
    WITMREF=[M:POI1]ITMREF(NOL)
    Gosub AM_BETITMREF From SUBPOI
    If mkstat  Return : Endif
  Else
    #----- Si article est renseigné vérifier que l'article site-exp existe
    Local Char WITMREF(GLONITM)
    Local Char WSTOFCY(GLONFCY)
    WITMREF=[M:POI1]ITMREF(NOL)
    WSTOFCY=[M:POI1]LINSTOFCY(NOL)
    Gosub CTRL_BETFCYITM From SUBPOI
    If mkstat  Return : Endif
    Gosub AM_BETITMREF From SUBPOI
    If mkstat  Return : Endif
  Endif
  [M:POI1]ORIFCY(NOL)=WPOHFCY
  If [M:POI1]PRHFCY(NOL)<>""
    #----- Vérification que le site de réception correspond à une adresse client livré
    Local Char BETRCPFCY(GLONFCY) : [L]BETRCPFCY=[M:POI1]PRHFCY(NOL)
    Local Char BPCNUM   (GLONBPC) : [L]BPCNUM   =[M:POI1]BPCORD(NOL)
    Gosub CTRL_BPRADD From TRTACHCTL1
    If [L]BETRCPFCY=""  [M:POI1]PRHFCY(NOL)=GRCPFCY : Endif
  Else
    [M:POI1]PRHFCY(NOL)=GRCPFCY
  Endif
  Call C_PRHFCY([M:POI1]PRHFCY(NOL)) From SUBPOI
  If mkstat  Return : Endif
Else
  Raz [M:POI1]ORIFCY(NOL)
Endif
Return


$CTRL_BETFCYITM
If [M:POI1]BETFCY(NOL)<>2 : Return : Endif
#--- Contrôle à faire sur l'article en inter-site
#--- Si géré en stock article-site expé existe ?
If [F:ITM]STOMGTCOD>1
  Look [ITF] ITF0=WITMREF;WSTOFCY
  If fstat
    GMESSAGE=WITMREF-mess(25,192,1)-WSTOFCY : mkstat=1 : Return
  Endif
Endif
Return


$AM_BETITMREF
If [M:POI1]SALFCY(NOL)=""  [M:POI1]SOHCAT(NOL)=0 : Return : Endif
#----- Contrats inter-site l'article-ventes doit exister -----#
Call CONTROLE("ITS","",[F:ITM]ITMREF,"",mkstat)   From CONTOBJ
If mkstat : Return : Endif
Raz GMESSAGE, GERR
#--- Appel au programme de contrôle des ventes
Call C_ITMREF(WITMREF,[M:POI1]ORDDAT,1) From TRTVENISOC
If GMESSAGE<>"" mkstat=1 : Return : Endif
#-- Définition du type de commande
If [F:ITM]RCPFLG=2
  [M:POI1]SOHCAT(NOL)=1 : # normale avec livraison
Else
  [M:POI1]SOHCAT(NOL)=3 : # facturation directe
Endif
Return


$RECH_BPRADD
Raz [L]BETRCPFCY
Filter [BPD] Where BPCNUM=[L]BPCNUM & ENAFLG=2
  For [BPD]BPD0
    #--- Vérification que le site apparatient à la meme société
    If [F:BPD]RCPFCY<>""
      Read [FCY]FCY0=[F:BPD]RCPFCY
      If !fstat & [F:FCY]LEGCPY = GSOCIETE
        [L]BETRCPFCY=[F:BPD]RCPFCY : Break
      Endif
    Endif
  Next
Filter [BPD]
Return


########################################################################
# INIT_COMPTES_LIGNE : S/P d'initialisation               MBT 05/09/06 #
#                des comptes d'une ligne de commande                   #
# -------------------------------------------------------------------- #
# Subprog INIT_COMPTES_LIGNE (NOL)                                     #
#   NOL    : Indice de la ligne de commande à traiter (nolign-1)       #
########################################################################
Subprog INIT_COMPTES_LIGNE (NOL)
Value    Shortint NOL
#-----
If GNBCOA=0 & max(GNBDIE,GOPTCANA)=0  End : Endif
#-----
Local    Shortint I
#----- Chargement de comptes avec "" pour désactiver l'action d'init -----#
For I=1 To 10
  If evalue("dim([M:POI1]LINACC"+num$(I)+")")>0
    Assign "[M:POI1]LINACC"+num$(I)+"(NOL)" With ""
  Endif
Next I
#----- Si ligne vide, pas la peine d'initialiser ! -----#
If [M:POI1]ITMREF(NOL)=""  End : Endif
#-----
Local    Char     ID1(20)(1..1), ID2(20)(1..3)
Local    Shortint J, LIG, SAVNOLIGN : SAVNOLIGN=nolign
Local    Integer  STA
Local    Char     TPLAN  (GLONCOA)(1..10)
Local    Char     TCOMPTE(GLONGAC)(1..10)
Local    Char     WMESSAGE(80)
#-----
If !clalev([F:GAD])  Local File GAUTACED [GAD] : Endif
Local File PORDER [TB0], PORDERQ [TB1], CPTANALIN [TB2]
nolign=NOL+1
#-----
If [F:BPR]BPRNUM<>[M:POI1]BPSNUM(NOL)
  Read [BPR] BPR0=[M:POI1]BPSNUM(NOL) : If fstat  Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:POI1]BPSNUM(NOL)
  Read [BPS] BPS0=[M:POI1]BPSNUM(NOL) : If fstat  Raz [F:BPS] : Endif
Endif
#-----
[F:TB0]=[F:BPR] : [F:TB0]=[F:BPS] : [F:TB0]=[M:POI1]
[F:TB1]=[F:BPR] : [F:TB1]=[F:BPS] : [F:TB1]=[M:POI1]
If [F:TB0]INVFCY=""
  [F:TB0]INVFCY=GFINRSP
Endif
If [F:TB1]LINPURTYP=0
  Case [M:POI1]LINTYP(NOL)
    When 3       : [F:TB1]LINPURTYP=3
    When Default : [F:TB1]LINPURTYP=1
  Endcase
Endif
#----- Chargement table liée PORDERP pour la pièce auto PORD -----#
If !GIMPORT : # La classe F est déjà alimentée dans le cas des imports
  [F:POP]=[M:POI1]
  If dim([M:POI1]TSICOD1(NOL))>0 [F:POP]TSICOD(0)=[M:POI1]TSICOD1(NOL) : Endif
  If dim([M:POI1]TSICOD2(NOL))>0 [F:POP]TSICOD(1)=[M:POI1]TSICOD2(NOL) : Endif
  If dim([M:POI1]TSICOD3(NOL))>0 [F:POP]TSICOD(2)=[M:POI1]TSICOD3(NOL) : Endif
  If dim([M:POI1]TSICOD4(NOL))>0 [F:POP]TSICOD(3)=[M:POI1]TSICOD4(NOL) : Endif
  If dim([M:POI1]TSICOD5(NOL))>0 [F:POP]TSICOD(4)=[M:POI1]TSICOD5(NOL) : Endif
  [F:POP]VAT(0)=[M:POI1]VAT1(NOL)
  [F:POP]VAT(1)=[M:POI1]VAT2(NOL)
  [F:POP]VAT(2)=[M:POI1]VAT3(NOL)
Endif
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="POP"
[F:TB2]VCRSEQ=1
[F:TB2]ANALIG=1
#-----
For I=1 To max(GNBCOA,2)
  J=GTYPLED(I)
  If J
    [F:TB2]LED(J-1)=GLEDSOC(I)
    [F:TB2]COA(J-1)=GCOA(I)
    [F:TB2]ACC(J-1)=evalue("[M:POI1]LINACC"+num$(I)+"(NOL)")
  Endif
Next I
#-----
For I=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(I-1)=GDIE(I)
  If evalue("dim([M:POI1]CCE"+num$(I)+")")>0
    [F:TB2]CCE(I-1)=evalue("[M:POI1]CCE"+num$(I)+"(NOL)")
  Endif
Next I
#-----
Raz ID1,ID2
#-----
Call COMPTE("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STA,WMESSAGE) From TRTACHCDE1
If STA
  Raz TPLAN, TCOMPTE
Else
  For I=1 To 10
    If TPLAN(I)<>""
     #J=find(TPLAN(I),GCOA(1..GNBCOA))
      J=find([F:GAD]LEDTYP(I-1),GTYPLED(1..GNBTYPLED))
      If J
        Assign "[M:POI1]LINACC"+num$(J)+"(NOL)" With TCOMPTE(I)
      Endif
    Endif
  Next I
Endif
#-----
Close Local File [TB0], [TB1], [TB2]
nolign=SAVNOLIGN
End


$PREP_INIT_CCE
#-----------------------------------------------------------------------------#
# Préparation des sections analytiques                                        #
# --------------------------------------------------------------------------- #
# Si l'axe est suivi en analytique et que la section correspondante est vide  #
#    il faut forcer l'initialisation grâce au Raz                             #
# Si l'axe n'est pas suivi en analytique                                      #
#    il faut "mettre  à blanc" la section correspondante                      #
# --------------------------------------------------------------------------- #
# NOL contient l'indice de la ligne en cours                                  #
# [M:POI1]LINACC1-10(NOL) contient les comptes                                #
# GBIDI2 : 0 = Pas d'affichage des sections analytiques                       #
#          1 = Affichage des sections analytiques                             #
#-----------------------------------------------------------------------------#
If dim(I)<1    Local Integer I             : Endif
If dim(WCCE)<1 Local Char    WCCE(GLONCCE) : Endif
#----- Pas de section si pas de suivi analytique sur l'axe concerné -----#
For I=1 To GNBDIE
  WCCE=evalue("[M:POI1]CCE"+num$(I)+"(NOL)")
  Raz mkstat
  Call SAIS_CCE(WCCE,I,"[M:POI1]LINACC","") From TRTX3CPT
  If mkstat
    Assign "[M:POI1]CCE"+num$(I)+"(NOL)" With ""
    Raz mkstat
  Elsif evalue("[M:POI1]CCE"+num$(I)+"(NOL)")=""
    #----- Raz pour forcer l'initialisation -----#
    Case I
      When  1 : Raz [M:POI1]CCE1 (NOL)
      When  2 : Raz [M:POI1]CCE2 (NOL)
      When  3 : Raz [M:POI1]CCE3 (NOL)
      When  4 : Raz [M:POI1]CCE4 (NOL)
      When  5 : Raz [M:POI1]CCE5 (NOL)
      When  6 : Raz [M:POI1]CCE6 (NOL)
      When  7 : Raz [M:POI1]CCE7 (NOL)
      When  8 : Raz [M:POI1]CCE8 (NOL)
      When  9 : Raz [M:POI1]CCE9 (NOL)
      When 10 : Raz [M:POI1]CCE10(NOL)
      When 11 : Raz [M:POI1]CCE11(NOL)
      When 12 : Raz [M:POI1]CCE12(NOL)
      When 13 : Raz [M:POI1]CCE13(NOL)
      When 14 : Raz [M:POI1]CCE14(NOL)
      When 15 : Raz [M:POI1]CCE15(NOL)
      When 16 : Raz [M:POI1]CCE16(NOL)
      When 17 : Raz [M:POI1]CCE17(NOL)
      When 18 : Raz [M:POI1]CCE18(NOL)
      When 19 : Raz [M:POI1]CCE19(NOL)
      When 20 : Raz [M:POI1]CCE20(NOL)
    Endcase
  Endif
Next I
#----- Affichage des sections analytiques -----#
If GBIDI2=1
  Gosub AFFICH_CCE
Endif
Return


$RAZ_LINACC
#---------------------------------------------#
# Effacement des comptes de la ligne commande #
#---------------------------------------------#
If dim(J)<1  Local Integer J : Endif
For J=1 To GNBCOA
  Case J
    When  1 : Raz [M:POI1]LINACC1 (NOL)
    When  2 : Raz [M:POI1]LINACC2 (NOL)
    When  3 : Raz [M:POI1]LINACC3 (NOL)
    When  4 : Raz [M:POI1]LINACC4 (NOL)
