#<AdxTL>@(#)2.0.0.0 $Revision$
Subprog GLOBVAR
If clalev([F:DIE]) = 0 : Local File GDIE [DIE] : Endif

Local Integer NBDIE
NBDIE = nbrecord([DIE])
If NBDIE > 0
 Global Integer GDIENBR
 Global Char    GDIECOD(GLONDIE)(1..NBDIE)
 Global Char    GDIEFMT(10)(1..NBDIE)
 Global Libelle GDIEPRJ(1..NBDIE)
Endif
Call INIGLBDIE
End


Subprog INIGLBDIE
If clalev([F:DIE]) = 0 : Local File GDIE [DIE] : Endif
GDIENBR = 0
For [DIE]DIE0
 GDIENBR += 1
 GDIECOD(GDIENBR) = [F:DIE]DIE
 GDIEFMT(GDIENBR) = [F:DIE]CCEFMT
 GDIEPRJ(GDIENBR) = [F:DIE]PRJMGT
Next
End


Subprog INICCEFMT(DIE)
Value    Char    DIE
Global Char    GCCEFMT(10)
# Issue X3-38496 - 2017-06-30 by CPO : 121098_PERF_Issue_in_Sales_Invoices (visualization of invoices with many lines)
If DIE="" : GCCEFMT = "15c" : End : Endif
# End issue X3-38496
Local Integer K
K = find(DIE,GDIECOD(1..GDIENBR))
If K<>0
 GCCEFMT = GDIEFMT(K)
Else
 GCCEFMT = "15c"
Endif
End

