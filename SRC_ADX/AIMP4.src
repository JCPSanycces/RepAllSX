#<AdxTL>@(#)2.0.0.0 $Revision$
###############################################################################
## Gestion des mémos états
###############################################################################
Close Local File
Local Char PARAM(10)(1..3) , VALEUR(10)
PARAM(1) = "" : #"ACTION"
Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "DEBUT"     : Gosub DEBUT
 When "TITRE"     : Gosub MEM_TITRE
 When "OK"        : Gosub OK
 When "SEL_LISTE" : Gosub SEL_LISTE
Endcase
Return

$MEM_TITRE
Case PARAM(1)
 When "1" : TIT = mess(110,126,1) : # Enregistrement mémo
 When "2" : TIT = mess(111,126,1) : # Rappel mémo
 When "3" : TIT = mess(112,126,1) : # Effacement mémo
Endcase
Return


$DEBUT
Local Integer I , MODE
Local Integer STAT  
Local Char    FICMEM(250) , SAVIFS(5) , SAVIRS(5) 
Local Char    ETAT(GLONARP) , EXT(3)
ETAT = [M:RPT]RPTCOD
MODE = val(PARAM(1))
EXT  = "rpt"
[M:MEM]TYP    = EXT
[M:MEM]MODE   = MODE
[M:MEM]ETAT   = ETAT
Return

$OK
If [M:MEM]CODE = "" : Return : Endif
Case MODE
 When 1
  SAVIFS = adxifs 
  SAVIRS = adxirs 
  FICMEM = filpath("ETM",GUSER+"_"+ETAT+"_"+[M:MEM]CODE,EXT,0)
  Openo FICMEM , 0 
  adxifs = tab$ 
  adxirs = chr$(10) 
  For I=0 To [M:RPT]NBRPAR-1 
   Wrseq [M:RPT]PARCOD(I), [M:RPT]VALEUR1(I) , [M:RPT]VALEUR2(I) ,"",""
  Next I 
  For I=0 To [M:RPT]NBSEG-1
   Wrseq "VALSEG",[M:RPT]VALSEG(I),"","",""
  Next I
  For I=0 To [M:RPT]NBPLAG-1
   Wrseq "PARPLAG", [M:RPT]PARPLAG(I) , num$([M:RPT]BORPLAG(I)),[M:RPT]VALPLAG1(I),[M:RPT]VALPLAG2(I)
  Next I
  Openo 
  Call MESSAGE(mess(1,139,1)) From GESECRAN : # Paramètres enregistrés 
  adxifs = SAVIFS 
  adxirs = SAVIRS 
 When 2
  Call LECMEMO(ETAT,EXT,[M:MEM]CODE)
  Local Char IACTION(20)
  Onerrgo RIEN
  IACTION = "MEMO" : Gosub ACTINI From AIMP1
  Onerrgo
  Affzo [RPT]
 When 3
  FICMEM = filpath("ETM",GUSER+"_"+ETAT+"_"+[M:MEM]CODE,EXT,0)
  If filinfo(FICMEM,0)>=0 
   Call  EFFACE(FICMEM,STAT) From ORDSYS 
   Call  MESSAGE(mess(2,139,1)) From GESECRAN : # Mémo effacé
  Endif 
Endcase
Return

$RIEN
ERR = errn
Resume  

$SEL_LISTE
Local Char CHAINE(250)
CHAINE = GUSER+'_'+[M:MEM]ETAT+'_*.'+[M:MEM]TYP
Call SYSTEME2(adxmac(0),'lsadx -a'-nomap(0)-'ETM "'+CHAINE+'"',"",NBTEX,TEX) From ORDSYS
NBTEX = min(NBTEX,dim(TEX)-1)  
For I=NBTEX To 1 Step-1
 TEX(I) = TEX(I-1)
 If TEX(I)<>""
  TEX(I) = right$(TEX(I),len(GUSER)+len([M:MEM]ETAT)+3)
  TEX(I) = left$(TEX(I),len(TEX(I))-1-len([M:MEM]TYP))
 Endif
Next I
Return

###########################################################################
Subprog LECMEMO(ETAT,EXT,MEMO) 
Value Char ETAT 
Value Char EXT 
Value Char MEMO
Local Integer I
Local Char    FICMEM(250)
Local Char    MEMCOD(250) , MEMVAL1(250) , MEMVAL2(250) , MEMVAL3(250), MEMVAL4(250)
Local Char    SAVIFS(5) , SAVIRS(5) 
SAVIFS = adxifs 
SAVIRS = adxirs 
FICMEM = filpath("ETM",GUSER+"_"+ETAT+"_"+MEMO,EXT,0)
If filinfo(FICMEM,0)>=0
 [M:RPT]NBSEG = 0
 [M:RPT]NBPLAG = 0
 Openi FICMEM 
 adxifs = tab$ 
 adxirs = chr$(10) 
 Rdseq MEMCOD , MEMVAL1 , MEMVAL2 , MEMVAL3 , MEMVAL4
 While fstat=0 
  If MEMCOD = "PARPLAG"
   [M:RPT]NBPLAG +=1
   [M:RPT]PARPLAG([M:RPT]NBPLAG-1)  = MEMVAL1 
   [M:RPT]BORPLAG([M:RPT]NBPLAG-1)  = val(MEMVAL2)
   [M:RPT]VALPLAG1([M:RPT]NBPLAG-1) = MEMVAL3 
   [M:RPT]VALPLAG2([M:RPT]NBPLAG-1) = MEMVAL4
  Else
   If MEMCOD="VALSEG"
    [M:RPT]NBSEG += 1
    [M:RPT]VALSEG([M:RPT]NBSEG-1) = MEMVAL1
   Endif
   I = find(MEMCOD,[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1)) 
   If I 
    [M:RPT]VALEUR1(I-1) = MEMVAL1 
    Call CONTROLE([M:RPT]VALEUR1(I-1),[M:RPT]PARTYP(I-1),[M:RPT]NOLIB(I-1),[M:RPT]LONG(I-1)
&   ,[M:RPT]VALINT1(I-1)) From FMTVAR
    If [M:RPT]DEBFIN(I-1)=2 
     [M:RPT]VALEUR2(I-1) = MEMVAL2 
     Call CONTROLE([M:RPT]VALEUR2(I-1),[M:RPT]PARTYP(I-1),[M:RPT]NOLIB(I-1),[M:RPT]LONG(I-1)
&    ,[M:RPT]VALINT2(I-1)) From FMTVAR
    Endif 
   Endif 
  Endif
  Rdseq MEMCOD , MEMVAL1 , MEMVAL2 , MEMVAL3 , MEMVAL4
 Wend 
 Openi 
Endif 
adxifs = SAVIFS 
adxirs = SAVIRS 
# Mise en forme des valeurs multiples.
Gosub REMPLIT_PLAG From AIMP1
End 

###########################################################################
Subprog LECMEMO_COD(ETAT,EXT,MEMO,COD,VAL1,VAL2) 
Value Char    ETAT 
Value Char    EXT 
Value Char    MEMO
Value Char    COD
Variable Char VAL1
Variable Char VAL2
Local Integer I
Local Char    FICMEM(250)
Local Char    MEMCOD(250) , MEMVAL1(250) , MEMVAL2(250)  , MEMVAL3(250), MEMVAL4(250)
Local Char    SAVIFS(5) , SAVIRS(5) 
SAVIFS = adxifs 
SAVIRS = adxirs 
FICMEM = filpath("ETM",GUSER+"_"+ETAT+"_"+MEMO,EXT,0)
If filinfo(FICMEM,0)>=0
 [M:RPT]NBSEG = 0
 Openi FICMEM 
 adxifs = tab$ 
 adxirs = chr$(10) 
 Rdseq MEMCOD , MEMVAL1 , MEMVAL2  , MEMVAL3 , MEMVAL4
 While fstat=0 
  If MEMCOD <> "PARPLAG"
   I = find(MEMCOD,[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1)) 
   If I & MEMCOD = COD
    VAL1 = MEMVAL1 
    If [M:RPT]DEBFIN(I-1)=2 
     VAL2 = MEMVAL2 
    Endif 
    Break
   Endif 
  Endif
  Rdseq MEMCOD , MEMVAL1 , MEMVAL2  , MEMVAL3 , MEMVAL4
 Wend 
 Openi 
Endif 
adxifs = SAVIFS 
adxirs = SAVIRS 
End

#################################################################
## Ecran AIMP4
#################################################################
Subprog C_CODE(VALEUR)
Variable Char VALEUR()
If find([M:MEM]MODE,2,3) : # Rappel, Effacement
 If filinfo(filpath("ETM",GUSER+"_"+[M:MEM]ETAT+"_"+VALEUR,[M:MEM]TYP,0),0)<0
  GMESSAGE = mess(113,126,1) : # Fichier mémo inexistant
  mkstat = 2 : End
 Endif
Endif
End


