#<AdxTL>@(#)9.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("AUS",GBIDC1,GBIDC2) From GOBJET
End
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "FERME"        : Gosub FERME
 When "RAZDUP"       : Gosub RAZDUP
 When "RAZCRE"       : Gosub RAZCRE
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "CREATION"     : Gosub CREATION
 When "MODIF"        : Gosub MODIF
 When "APRES_CRE"    : Gosub APRES_CRE
 When "APRES_MOD"    : Gosub APRES_MOD
 When "LIENS"        : Gosub LIENS
# When "ANNULE"       : Gosub ANNULE     # Issue X3-5418/119111 - 2016-10-17 by SINGO
 When "ANNULE"       : Gosub ANNULE      # Issue X3-47484 - 2017-10-03 by SINGC
 When "VERF_ANU"     : Gosub VERF_ANU    # FGR 20/04/2010 : X3SUIVI64106
 When "CHPDEF"       : Gosub CHPDEF
 When "FILTRE"       : Gosub FILTRE  :   # 80379
 When "SEL_TABLE"    : Gosub SEL_TABLE   # Issue X3-62786 - 2018-03-16 by JUSYN : User selections for NCS
Endcase
Return

$OUVRE

  If !clalev([F:REP])  : Local File SALESREP   [REP]  : Endif
  If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
  If !clalev([F:BPA2]) : Local File BPADDRESS  [BPA2] : Endif
  If !clalev([F:TCY])  : Local File TABCOUNTRY [TCY]  : Endif
  If !clalev([F:ADU2]) : Local File ADOVALAUS  [ADU2] : Endif
  If !clalev([F:CAC])  : Local File GACCCODE   [CAC]  : Endif
  # FGR 28/06/2016 : X3SUIVI117376 only if PJM activity code is active.
  If func ASYRFNC.ACTIV("PJM") = [V]CST_ATRUE  and (nomap(0) <> GDOSX3 | (nomap(0) = GDOSX3 & dim(GADONIX)>0 & GADONIX=2)) Then
    If !clalev([F:PAUS]) : Local File PJMAUS     [PAUS]  : Endif
    If !clalev([F:PAF])  : Local File PJMAFF     [PAF]   : Endif
    If !clalev([F:POA])  : Local File PJMOPEAFF  [POA]   : Endif
    If !clalev([F:PJCV]) : Local File PJMAUSCAVA [PJCV]  : Endif  # Issue X3-47484 - 2017-10-03 by SINGC
    #If !clalev([F:PTEH]) : Local File PJMTIMEMPH [PTEH]  : Endif # Issue X3-16743/120384 - 2016-12-14 by SINGC
  Endif

  Global Integer GCRMAUS7FLG
  Global Char GCRMAUS7REP
  Global Char GCRMAUS8REP
  Global Char GCRMBUT2TUN
  GCRMAUS7FLG = 0
  GCRMAUS7REP = ""
  GCRMAUS8REP = ""
  GCRMBUT2TUN = ""
  If clalev([F:CDI])=0 : Local File CADIEDEF   [CDI] : Endif
  Local Integer NUMDIE
  NUMDIE = 5 : # Rang dans le menu 2230
  Read [CDI]CDI0 = NUMDIE
Return

$FERME
  Kill GCRMAUS7FLG
  Kill GCRMAUS7REP
  Kill GCRMAUS8REP
  Kill GCRMBUT2TUN
  Return

$RAZDUP
  GCRMAUS7REP = ""
  GCRMAUS8REP = ""

# FGR 15/10/2015 : X3SUIVI111758 (début)
  Local Integer ITER

    For ITER = 0 To [M:AUS7]NBVAR - 1
      If [M:AUS7]CHAPITRE(ITER) = "CRM" Then
        If [M:AUS7]PARAM(ITER) = "AUSCRMF" Then
          Raz [M:AUS7]VALEUR(ITER)
          Break
        Endif
      Endif
    Next ITER
# FGR 15/10/2015 : X3SUIVI111758 (fin)

# SINGO 05/01/2016 : (start)
# FGR 28/06/2016 : X3SUIVI117376 only if PJM activity code is active.
If func ASYRFNC.ACTIV("PJM") = [V]CST_ATRUE  and (nomap(0) <> GDOSX3 | (nomap(0) = GDOSX3 & dim(GADONIX)>0 & GADONIX=2)) Then
# Issue X3-5416/119109 - 2016-10-13 by SINGO START
#  [M:PAUS]PAUS = [M:AUS0]USR
#  [M:PAUS]PAUSNAM = [M:AUS0]NOMUSR
# Issue X3-5416/119109 - 2016-10-13 by SINGO END
  [M:PAUS]PAUSROL = ""
  [M:PAUS]PAUSPA = [V]CST_ANO
  [M:PAUS]PAUSTT = [V]CST_ANO
  [M:PAUS]PAUSCST = 0
  [M:PAUS]PAUSCUR = ""
  [M:PAUS]PCCCOD = ""
  [M:PAUS]ENAFLGPJM = [V]CST_AYES
  [M:PAUS]TWD  = "" # Issue X3-47484 - 2017-10-03 by SINGC
  Effzo [M:PAUS]10  # Issue X3-47484 - 2017-10-03 by SINGC
  Affzo [M:PAUS]
Endif
# SINGO 05/01/2016 : (end)
Return

$RAZCRE
  GCRMAUS7REP = ""
  GCRMAUS8REP = ""
  Gosub INIDIE
  If dim([M:AUS4]DIE)>0 : Affzo [AUS4] : Endif
Return

$VERIF_CRE
  Call CHKCRMINFOS(OK) From SUBAUSCRM
  If OK = 0 : Return : Endif
  Call MANAGE_REP(OK) From SUBAUSCRM
Return

$VERIF_MOD
  Call CHKCRMINFOS(OK) From SUBAUSCRM
  If OK = 0 : Return : Endif
  Call MANAGE_REP(OK) From SUBAUSCRM
Return

$CREATION
# MABON 19/01/12 - Spécifique PAIE
  If REP="D" & clalev([M:AUS0])
   Read [F:ADU]ADU0=[M:AUS0]USR;"MOIPAY"
   If !fstat
    Delete [F:ADU] Curr
   Endif
  Endif
# Fin MABON
# ----------------------------------
# Siphelele Ngcobo
# FGR 28/06/2016 : X3SUIVI117376 only if PJM activity code is active.
If func ASYRFNC.ACTIV("PJM") = [V]CST_ATRUE  and (nomap(0) <> GDOSX3 | (nomap(0) = GDOSX3 & dim(GADONIX)>0 & GADONIX=2)) Then
  If [M:PAUS]PAUSROL <> AVOID.ACHAR or [M:PAUS]PAUSCST <> 0 or [M:PAUS]PAUSCUR <> AVOID.ACHAR or [M:PAUS]PCCCOD <> AVOID.ACHAR or
& [M:PAUS]ENAFLGPJM = [V]CST_AYES or [M:PAUS]PAUSTT = [V]CST_AYES or [M:PAUS]PAUSPA = [V]CST_AYES Then
    [F:PAUS] = [M:PAUS]
    [F:PAUS]PAUS = [M:AUS0]USR # Issue X3-5205/119116 - 2016-10-10 by SINGO
    [F:PAUS]ENAFLG = [M:PAUS]ENAFLGPJM
    # ----------------------------------
    If [M:PAUS]PAUSCST <> 0 Then
      # ----------------------------------
      If [M:PAUS]PAUSCUR = AVOID.ACHAR Then
        GMESSAGE = mess(327,2260,1)
        GOK = 0
        GERR = 1
      Endif
      # ----------------------------------
    Endif
    # ----------------------------------
    Write [PAUS]
    # ----------------------------------
    If fstat Then
      GOK = 0
      GERR = 1
    Endif
    # ----------------------------------
    # Issue X3-16743/120384 - 2016-12-14 by SINGC : START
    #[F:PTEH]CLB = [M:AUS0]USR
    #Write [PTEH]
    ## ----------------------------------
    #If fstat Then
    #  GOK = 0 : GERR = 1
    #Endif
    # Issue X3-16743/120384 - 2016-12-14 by SINGC : END
    # ----------------------------------
    Call UPDATE_CAPVAR() From SUBPAUS # Issue X3-47484 - 2017-10-03 by SINGC
  Endif
Endif
# End Siphelele Ngcobo
Return

$MODIF
# Siphelele Ngcobo
# FGR 28/06/2016 : X3SUIVI117376 only if PJM activity code is active.
If func ASYRFNC.ACTIV("PJM") = [V]CST_ATRUE  and (nomap(0) <> GDOSX3 | (nomap(0) = GDOSX3 & dim(GADONIX)>0 & GADONIX=2)) Then
  #Read [PAS]PAUS = [M:PAUS]PAUS
  Read [PAUS]PAUS = [M:AUS0]USR # Issue X3-5205/119116 - 2016-10-10 by SINGO
  If !fstat Then
    [F:PAUS] = [M:PAUS]
    [F:PAUS]ENAFLG = [M:PAUS]ENAFLGPJM
    # ----------------------------------
    If [M:PAUS]PAUSCST <> 0 Then
      # ----------------------------------
      If [M:PAUS]PAUSCUR = AVOID.ACHAR Then
        GMESSAGE = mess(327,2260,1)
        GOK = 0
        GERR = 1
      Endif
      # ----------------------------------
    Endif
    # ----------------------------------
    Rewrite [PAUS]
    # ----------------------------------
    If fstat Then
      GOK = 0
      GERR = 1
    Endif
    # ----------------------------------
  Else
    If [M:PAUS]PAUSROL <> AVOID.ACHAR or [M:PAUS]PAUSCST <> 0 or [M:PAUS]PAUSCUR <> AVOID.ACHAR or [M:PAUS]PCCCOD <> AVOID.ACHAR or
&   [M:PAUS]ENAFLGPJM = [V]CST_AYES or [M:PAUS]PAUSTT = [V]CST_AYES or [M:PAUS]PAUSPA = [V]CST_AYES Then
      [F:PAUS] = [M:PAUS]
      [F:PAUS]PAUS = [M:AUS0]USR # Issue X3-5205/119116 - 2016-10-10 by SINGO
      [F:PAUS]ENAFLG = [M:PAUS]ENAFLGPJM
      # ----------------------------------
      If [M:PAUS]PAUSCST <> 0 Then
        # ----------------------------------
        If [M:PAUS]PAUSCUR = AVOID.ACHAR Then
          GMESSAGE = mess(327,2260,1)
          GOK = 0
          GERR = 1
        Endif
        # ----------------------------------
      Endif
      # ----------------------------------
      Write [PAUS]
      # ----------------------------------
      If fstat Then
        GOK = 0
        GERR = 1
      Endif
      # ----------------------------------
    Endif
    # ----------------------------------
    # Issue X3-16743/120384 - 2016-12-14 by SINGC : START
    #Read [PTEH]PTEH0 = [M:AUS0]USR
    #If fstat Then
    #  [F:PTEH]CLB = [M:AUS0]USR
    #  Write [PTEH]
    #  # ----------------------------------
    #  If fstat Then
    #    GOK = 0
    #    GERR = 1
    #  Endif
    #  # ----------------------------------
    #Endif
    # Issue X3-16743/120384 - 2016-12-14 by SINGC : END
  Endif
  # ----------------------------------
  Call UPDATE_CAPVAR() From SUBPAUS # Issue X3-47484 - 2017-10-03 by SINGC
Endif
# End Siphelele Ngcobo
Return

$APRES_CRE
  Call CREREPFROMUSER From SUBAUSCRM
  #LSE 22/11/2006
  Gosub CHARGE_PARAM From SUBAUS
  Gosub CHARGE_GRP From SUBAUS
  Affzo [AUS7]1-99
  Call UPDALLFROMUSER From SUBAUSCRM
  # FGR 28/06/2016 : X3SUIVI117376 only if PJM activity code is active.
  If func ASYRFNC.ACTIV("PJM") = [V]CST_ATRUE  and (nomap(0) <> GDOSX3 | (nomap(0) = GDOSX3 & dim(GADONIX)>0 & GADONIX=2)) Then
    Gosub RELIT From GOBJSUB
    Affzo [M:PAUS]
  Endif
Return

$APRES_MOD
  Call CREREPFROMUSER From SUBAUSCRM
  #LSE 22/11/2006
  Gosub CHARGE_PARAM From SUBAUS
  Gosub CHARGE_GRP From SUBAUS
  Affzo [AUS7]1-99
  Call UPDALLFROMUSER From SUBAUSCRM
  # Mise à jour des accès dans la table des relevés de frais
  Call MODIF_ACS([M:AUS0]USR,[M:AUS1]ACSUSR) From SUBEXS
  # FGR 28/06/2016 : X3SUIVI117376 only if PJM activity code is active.
  If func ASYRFNC.ACTIV("PJM") = [V]CST_ATRUE  and (nomap(0) <> GDOSX3 | (nomap(0) = GDOSX3 & dim(GADONIX)>0 & GADONIX=2)) Then
    Gosub RELIT From GOBJSUB
    Affzo [M:PAUS]
  Endif
Return

$LIENS
  GCRMAUS8REP = ""
  GCRMAUS7REP = ""
  Gosub INIDIE


#Gbn-X3-3514
If func ASYRFNC.ACTIV("PJM") = [V]CST_ATRUE  and (nomap(0) = GDOSX3 & (dim(GADONIX)>0 & GADONIX<>2))
 Raz   [M:PAUS]
 Grizo [M:PAUS]
Endif

# Issue 71064 - 2015-12-03 by SINGO : Employee assignment
# FGR 28/06/2016 : X3SUIVI117376 only if PJM activity code is active.
If func ASYRFNC.ACTIV("PJM") = [V]CST_ATRUE  and (nomap(0) <> GDOSX3 | (nomap(0) = GDOSX3 & dim(GADONIX)>0 & GADONIX=2)) Then
  # ----------------------------------
  Read [PAUS]PAUS = [M:AUS0]USR
  If !fstat Then
    [M:PAUS] = [F:PAUS]
    [M:PAUS]ENAFLGPJM = [F:PAUS]ENAFLG
    # ----------------------------------
    # Issue X3-17872/121095 - 2017-01-23 by SINGC : START
    If [M:PAUS]PAUSPA = [V]CST_AYES Then
      Diszo [M:PAUS]PAUSTT
    Else
      Actzo [M:PAUS]PAUSTT
    Endif
    # Issue X3-17872/121095 - 2017-01-23 by SINGC : END
  Else
    [M:PAUS]ENAFLGPJM = [V]CST_ANO
  Endif
  # ----------------------------------
  If [M:PAUS]PAUSTT = 0 Then
    [M:PAUS]PAUSTT = [V]CST_ANO
  Endif
  # ----------------------------------
  If [M:PAUS]PAUSPA = 0 Then
    [M:PAUS]PAUSPA = [V]CST_ANO
  Endif
  # ----------------------------------
  # Issue X3-47484 - 2017-10-03 by SINGC : START
  Call RAZ_CLOB From ACLOB
  nolign = 0
  Filter [PJCV] Where PAUS = [M:AUS0]USR
  For [F:PJCV]
    nolign += 1
    [M:PAUS] = [F:PJCV]
  Next
  [M:PAUS]NBLIG = nolign
  Filter [PJCV]
  Sorta [M:PAUS]NBLIG [M:PAUS]NBLIG Order By [M:PAUS]STRDAT(indice)
  # Issue X3-47484 - 2017-10-03 by SINGC : END
  Affzo [M:PAUS]
Endif
# End issue 71064-3
Return

$INIDIE
  If dim([M:AUS4]DIE)<1 : Return : Endif
  Raz [M:AUS4]DIE
  Raz [M:AUS4]CCE
  [M:AUS4]NBSEC = [F:CDI]NBRDIE
  For I=0 To [F:CDI]NBRDIE-1
   [M:AUS4]DIE(I) = [F:CDI]DIE(I)
   For J=0 To dim([F:AUS]DIE)-1
    If [F:AUS]DIE(J)=[F:CDI]DIE(I)
     [M:AUS4]CCE(I) = [F:AUS]CCE(J)
     Break
    Endif
   Next J
  Next I
Return

$CHPDEF
  Case CHAPITRE
   When "SUP"       : [L]SITE =([F:AFT]FCYDEF(0))  : If GMODU(1)=2 & !GIMPORT  : OK=1 : Endif
   When "CPT","BUD" : [L]SITE =([F:AFT]FCYDEF(1))  : If GMODU(2)=2 & !GIMPORT  : OK=1 : Endif
   When "TRS"       : [L]SITE =([F:AFT]FCYDEF(2))  : If GMODU(3)=2 & !GIMPORT  : OK=1 : Endif
   When "IMM"       : [L]SITE =([F:AFT]FCYDEF(3))  : If GMODU(4)=2 & !GIMPORT  : OK=1 : Endif
   When "VEN"       : [L]SITE =([F:AFT]FCYDEF(4))  : If GMODU(5)=2 & !GIMPORT  : OK=1 : Endif
   When "ACH"       : [L]SITE =([F:AFT]FCYDEF(5))  : If GMODU(6)=2 & !GIMPORT  : OK=1 : Endif
   When "STO"       : [L]SITE =([F:AFT]FCYDEF(6))  : If GMODU(7)=2 & !GIMPORT  : OK=1 : Endif
   When "GPA"       : [L]SITE =([F:AFT]FCYDEF(7))  : If GMODU(8)=2 & !GIMPORT  : OK=1 : Endif
   When "TC"        : [L]SITE =([F:AFT]FCYDEF(8))  : If GMODU(9)=2 & !GIMPORT  : OK=1 : Endif
   When "ADX"       : [L]SITE =([F:AFT]FCYDEF(9))  : If GMODU(10)=2 & !GIMPORT : OK=1 : Endif
   When "HDK"       : [L]SITE =([F:AFT]FCYDEF(11)) : If GMODU(12)=2 & !GIMPORT : OK=1 : Endif
   When "CRM"       : [L]SITE =([F:AFT]FCYDEF(12)) : If GMODU(13)=2 & !GIMPORT : OK=1 : Endif
   When "TF"        : [L]SITE =([F:AFT]FCYDEF(13)) : If GMODU(14)=2 & !GIMPORT : OK=1 : Endif
  Endcase
Return

