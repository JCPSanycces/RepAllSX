# Issue X3-47484 - 2017-10-03 by SINGC : START
$ANNULE
Local Integer IRET

  If clalev([F:PJCV]) Then   # Issue X3-70629 - 2018-01-25 by ADMIN : was missing
    Filter [PJCV] Where PAUS = [M:AUS0]USR
    For [F:PJCV]
      Call SUP_CLOB([F:PJCV]VARTEX, IRET) From TRTX3TEX
    Next
    Filter [PJCV]
    Delete [PJCV] Where PAUS = [M:AUS0]USR
  Endif
Return
# Issue X3-47484 - 2017-10-03 by SINGC : END

# FGR 20/04/2010 : X3SUIVI64106 (début)
$VERF_ANU
  Call ANNUL_REP([M:AUS0]USR, OK)
Return

Subprog ANNUL_REP(SZAUSUSR, OK)
  Value Char SZAUSUSR
  Variable Integer OK

  Local Char SZMESS(250)
  Local Char SZNEWREP(GLONREP)
  Local Integer INBREPTODEL
  Local Integer ITERREP
  Local Integer IASKDEL

  Local Integer OKANU
  Local Char SCLEPRIM(GLONVCR), SCLESEC(GLONVCR)(0..1)
  Local Char SDOSSIER(GLONVCR)
  Local Char PARAM(250)(5)

  SDOSSIER = nomap
  INBREPTODEL = 0
  ITERREP = 0
  IASKDEL = 0
  Filter [REP] Where [F:REP]AUSNUM = SZAUSUSR
  For [REP] REP1
    INBREPTODEL += 1
  Next
  Filter [REP]
  If INBREPTODEL Then
    Local Char SZREPTODEL(GLONREP)(INBREPTODEL)

    ITERREP = 0
    Filter [REP] Where [F:REP]AUSNUM = SZAUSUSR
    For [REP]REP1
      SZREPTODEL(ITERREP) = [F:REP]REPNUM
      ITERREP += 1
    Next
    Filter [REP]
    If INBREPTODEL > 1 Then
      #Les représentants : XXX, XXX, XXX vont également être supprimés. Confirmez-vous la suppression ?
      SZMESS = mess(384,182,1) + " "
      For ITERREP = 0 To INBREPTODEL-1
        SZNEWREP = SZREPTODEL(ITERREP) +", "
        SZMESS += SZNEWREP
      Next
      SZMESS += mess(385,182,1)
      SZMESS += " "
      SZMESS += mess(386,182,1)
    Else
      #Le représentant : XXX va également être supprimé. Confirmez-vous la suppression ?
      SZMESS = mess(388,182,1) + " "
      SZNEWREP = SZREPTODEL(0) + " "
      SZMESS += SZNEWREP
      SZMESS += mess(389,182,1)
      SZMESS += " "
      SZMESS += mess(386,182,1)
    Endif
    Call OUINON(SZMESS, IASKDEL) From GESECRAN
    If IASKDEL <> 2 Then
      #La suppression de l'utilisateur a été abandonnée.
      GMESSAGE = mess(387,182,1)
      GERR = 2
      OK = 0
      End
    Endif
    #Suppression des fiches Adresses, Représentant et Tiers associées.
    Call DEBTRANS From GLOCK
    Trbegin [REP], [BPR], [BPA]
    For ITERREP = 0 To INBREPTODEL-1
      Call VERIF(SDOSSIER, "REP", SZREPTODEL(ITERREP), "", OKANU) From ANUCOD
      If !OKANU Then
        GMESSAGE = mess(386,196,1) - "(a :" - SZREPTODEL(ITERREP) + ")" #Erreur lors de la suppression de la fiche Représentant associée
        GERR = 1
        GOK = 0
        Break
      Else
        Call ANNULATION(SDOSSIER, "REP", SZREPTODEL(ITERREP), "") From ANUCOD
        If GOK < 1 Then
          If GMESSAGE = "" Then
            GMESSAGE = mess(386,196,1) - "(b :" - SZREPTODEL(ITERREP) + ")" #Erreur lors de la suppression de la fiche Représentant associée
            GERR = 1
          Endif
          Break
        Endif
      Endif
      #---------------------------------
      Read [BPR]BPR0=SZREPTODEL(ITERREP)
      If fstat Then
        GMESSAGE = mess(387,196,1) - "(a :" - SZREPTODEL(ITERREP) + ")" #Erreur lors de la suppression de la fiche Tiers associée
        GERR = 1
        GOK = 0
        Break
      Endif
      # Note : si on ne peut pas supprimer le tiers, ça n'est pas bloquant. c'est qu'il sert à autre chose que Représentant.
      If [F:BPR]BPCFLG <> 2 and [F:BPR]BPSFLG <> 2 and [F:BPR]CCNFLG <> 2 and [F:BPR]BPTFLG <> 2 and [F:BPR]FCTFLG <> 2 and [F:BPR]REPFLG <> 2 and
&        [F:BPR]BPRACC <> 2 and [F:BPR]PPTFLG <> 2 and [F:BPR]PRVFLG <> 2 and [F:BPR]DOOFLG <> 2 and [F:BPR]BPRFLG <> 2 and
&        (dim([F:BPR]PTHFLG) >= 0 and [F:BPR]PTHFLG <> 2) Then
        Call VERIF(SDOSSIER, "BPR", SZREPTODEL(ITERREP), "", OKANU) From ANUCOD
        If OKANU Then
          Call ANNULATION(SDOSSIER, "BPR", SZREPTODEL(ITERREP), "") From ANUCOD
          If GOK < 1 Then
            # Sauf dans ce cas parce qu'il y a quelque chose qui ne colle pas !
            If GMESSAGE = "" Then
              GMESSAGE = mess(387,196,1) - "(b :" - SZREPTODEL(ITERREP) + ")" #Erreur lors de la suppression de la fiche Tiers associée
              GERR = 1
            Endif
            Break
          Endif
        Endif
      Endif
    Next
    If GOK < 1 Then
      Rollback
      End
    Endif
    Commit
  Endif
End
# FGR 20/04/2010 : X3SUIVI64106 (fin)


########################################
Subprog IB_USR
  Local Integer ITER

  #Obtient le code représentant
  Raz GBOUT2
  Raz GCRMBUT2TUN
  ITER = 0
  For ITER = 0 To [M:AUS7]NBVAR - 1
      If [M:AUS7]CHAPITRE(ITER) = "CRM"
          If [M:AUS7]PARAM(ITER) = "AUSCRMF"
              If [M:AUS7]VALEUR(ITER) <> ""
                  GBOUT2 = mess(274,196,1) #Informations représentant.
                  GCRMBUT2TUN = [M:AUS7]VALEUR(ITER)
                  Break
              Endif
          Endif
      Endif
  Next
End

# FQ80379 - MABON 12/06/12 - Filtrer la liste gauche quand on vient de GESEML, pour n'avoir que les users
# dont REFNUM=<matricule>
$FILTRE
  Local Char CRIT(250)

#If GUSER='MABON' Dbgaff Endif
  If clalev([M:EMP0]) Then
    If clalev([F:ADU2])=0 : Local File ADOVALAUS [ADU2] : Endif
    Filter [F:ADU2] Where PARAM='REFNUM' & VALEUR=[M:EMP0]REFNUM Order By CODUSR
    If rowcount([F:ADU2])>0 Then
      For [F:ADU2]
        If CRIT<>"" Then CRIT += "," : Endif
        CRIT += "'"+[F:ADU2]CODUSR+"'"
      Next
      If CRITERE<>"" Then CRITERE += " & " : Endif
      CRITERE += "find([F:AUS]USR,"+CRIT+")>0"
    Endif
    Filter [F:ADU2]
    TUNCLE=""
  Endif
Return

# Issue X3-62786 - 2018-03-16 by JUSYN : Moved selections from SUBAUS
$SEL_TABLE
Case TABLE
 When "NCSAUSQA"
  # Issue X3-62786 - 2017-11-22 by JUSYN : Select only the NCS QA-Managers
  Gosub SEL_QAMANAGER
  # End issue X3-62786
 When "NCSAUSPL"
  # Issue X3-62786 - 2017-11-22 by JUSYN : Select only the NCS Planners
  Gosub SEL_PLANNER
  # End issue X3-62786
 When "NCSAUSAP"        # Issue X3-62810
  Gosub SEL_APPROVER    # Issue X3-62810
Endcase
Return

# Issue X3-62786 - 2017-11-22 by JUSYN : Select only the QA-Managers
$SEL_QAMANAGER
Local Integer I
Local Integer QUALITY_MANAGER_COUNT
Local Char NCSQAMAN(30)
Local Char QUALITY_MANAGER(10)(1..)

If clalev([F:AUSQA])=0 : Local File AUTILIS   [AUSQA] : Endif

# Count QA-Managers and fill array
QUALITY_MANAGER_COUNT = 0
For [AUSQA] Where ENAFLG = 2
    NCSQAMAN = ""
    Call PARAMUTIL("NCSQAMAN", NCSQAMAN, [F:AUSQA]USR, "") From SUBAUS
    If (NCSQAMAN = "2")
        QUALITY_MANAGER_COUNT += 1
        QUALITY_MANAGER(QUALITY_MANAGER_COUNT) = [F:AUSQA]USR
    Endif
Next

# Fill CRITERE for selection
If (QUALITY_MANAGER_COUNT = 0)
    CRITERE = "1 = 0"
Else
    For I = 1 To QUALITY_MANAGER_COUNT
        If (I = 1)
            CRITERE = 'find (USR,'+'"'+ QUALITY_MANAGER(I)+'"'
        Else
            CRITERE += ', "'+ QUALITY_MANAGER(I) +'"'
        Endif
    Next I
    CRITERE += ')'
Endif
OBJET = "NCSAUSQA"
Close Local File [AUSQA]
Return
# End issue X3-62786

