#<AdxTL>@(#)0.0.0.0 $Revision$Class ## ?IDENTQRY? SEARCH ##
# Supervisor
#WMSRHGRANTS GRANTS
# 2018-11-06 07:08:45 867

Funprog IS_IMPLEMENTED()
End 1
#---------------------------------------------------------------------------------------------------#
# List of tables to open
#---------------------------------------------------------------------------------------------------#
$ASEARCH_OPEN
If filinfo(filpath("FIL","GRANTS","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File GRANTS [GRT]
If filinfo(filpath("FIL","CASHING","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File CASHING [CAS]
Local File GRANTS [GRT_]
Local Char KEY_GRT(120)(1..3)
Local Char KEY_CAS(120)(1..3)
#Empty keys :
KEY_GRT(3) = ""
KEY_CAS(3) = "+0"
ACTION = "ASEARCH_OPEN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to close
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CLOSE
LogicClose File [GRT]
LogicClose File [CAS]
LogicClose File [GRT_]
ACTION = "ASEARCH_CLOSE_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN
Link [GRT] With
& [CAS]CAS0=GRAREF
& As [LNK_]
& Where (1=1
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN_INC
Link [GRT] With
& [CAS]CAS0=GRAREF
& As [LNK_]
& Where (UPDDATTIM > gdatetime$(QUPDDATTIM)
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Create an instance of
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CREATEINSTANCE
Local Integer ASTATUS
Local Integer FINS
Local Integer CI1
Local Integer CJ1
Local Char    SEPINS1(2) : SEPINS1=""
Local Char IS1(1)

Return

#---------------------------------------------------------------------------------------------------#
# Set an instance
#---------------------------------------------------------------------------------------------------#
$ASEARCH_SETINSTANCE
KEY_GRT(2) = [F:GRT]GRAREF
KEY_CAS(2) = [F:CAS]GRAREF+"+"+num$([F:CAS]CASHDAT)

If (KEY_GRT(2) <> KEY_GRT(3)) & (KEY_GRT(1) <> KEY_GRT(2))
 If INS <> null
  [L]ASTATUS = fmet INS.ACTION("ASEARCH_TRANS_AFTER")
  #serialize INS
  Gosub ASEARCH_TO_JSON
 Endif
#Create a new instance
INS = NewInstance C_GRANTS(GACTX,UIDINS,NUMLIN,null,"") AllocGroup null
INS.setaccessorEnabled = 0
SetInstance INS With [F:GRT]
FINS = 1
Local Integer CANA_MAXI:CANA_MAXI= 0
Local Integer CANA_MAXI:CANA_MAXI= 0
Local Integer CANA_MAX:CANA_MAX=0
If dim([F:GRT]CCE)>0
    If CANA_MAXI = 0
        CANA_MAXI = dim([F:GRT]CCE)
    Else
        CANA_MAXI = min(CANA_MAXI,dim([F:GRT]CCE))
    Endif
Endif
If dim([F:GRT]CCE)>0
    If CANA_MAXI = 0
        CANA_MAXI = dim([F:GRT]CCE)
    Else
        CANA_MAXI = min(CANA_MAXI,dim([F:GRT]CCE))
    Endif
Endif
CJ1=1
For CI1 = 0 To CANA_MAXI-1
 Break ([F:GRT]CCE(CI1)="")
 CANA_MAX+=1
 #Create a new instance
 INS.CANA(CJ1) = NewInstance C_GRANTS_CANA(GACTX,UIDINS,NUMLIN,INS,"") AllocGroup INS
 INS.CANA(CJ1).setaccessorEnabled = 0
 INS.CANA(CJ1).CCE=[F:GRT]CCE(CI1)
 CJ1+=1
Next CI1
 KEY_GRT(1) = KEY_GRT(2)
Endif : # KEY_GRT(1) <> KEY_GRT(2)

Return

#---------------------------------------------------------------------------------------------------#
# Serialize the entity in a JSON format
#---------------------------------------------------------------------------------------------------#
$ASEARCH_TO_JSON
If FINS=0 : Return : Endif
QCOUNT += 1
Onerrgo ERROR_VALUE
Append ASND.DATA ,SEPINS1
SEPINS1 = ','+chr$(10)
Append ASND.DATA ,'{'
Append ASND.DATA ,'"GRAREF":'          +'"'+escJson(INS.GRAREF)+'"'
Append ASND.DATA ,',"DES":'            +'"'+escJson(INS.DES)+'"'
Append ASND.DATA ,',"DES2":'           +'"'+escJson(INS.DES2)+'"'
IS1=""
CJ1=1
Append ASND.DATA ,',"CANA":['
For CI1=1 To CANA_MAX
 Append ASND.DATA ,IS1+'{'
 Append ASND.DATA ,'"CCE":'             +'"'+escJson(INS.CANA(CJ1).CCE)+'"'
 Append ASND.DATA ,'}'
 IS1=","
 CJ1+=1
Next CI1
Append ASND.DATA , "]"
Append ASND.DATA ,'}'
Onerrgo
Freegroup INS
INS = null
Raz KEY_GRT(1),KEY_CAS(1)
FINS = 0
Return

#---------------------------------------------------------------------------------------------------#
# Errors
#---------------------------------------------------------------------------------------------------#
$ERROR_VALUE
SVALUE ='"<error'-errmes$(errn)+'>"'
Resume
#---------------------------------------------------------------------------------------------------#
# Link standard key
#---------------------------------------------------------------------------------------------------#
$AQUERY_PRIMARYKEYS
Local Char ASTDKEY(250)
ASTDKEY = ""
ASTDKEY += "[F:GRT]GRAREF"
ACTION = "ASEARCH_PRIMARYKEYS_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Actions
#---------------------------------------------------------------------------------------------------#
$ASEARCH_ACTION
Local Char CURPRO(250),CURPTH(250),AMETHOD(50),AEVENT(50)
[L]AEVENT = [L]ACTION
 Gosub METHODS From GRANTS_CSTD
Gosub METHODS From GRANTS_CSTD
Return

#---------------------------------------------------------------------------------------------------#
# APPEND_PROTOTYPE
#---------------------------------------------------------------------------------------------------#
Funprog APPEND_PROTOTYPE(ACTX,WCLOB,PSYR)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Clbfile   WCLOB
Variable Instance  PSYR     Using C_ASYR
Local Integer ERROR : ERROR = 0
Local Integer IND   : IND = 0
Local Char TRTNAME(80)
Local Char REPRESENTATION(80)
Local File ASHW    [ASW]
Filter [ASW] Where CODCLA="GRANTS" & DEFREP=2
Read [ASW]ASW0 First
If !fstat
 If  [ASW]ENAFAC(0) = 2
  REPRESENTATION = [ASW]CODREP
 Else
  WCLOB ="{}"
  End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"GRANTS")) 
 Endif
Endif
Close Local File [ASW]
If len(REPRESENTATION)=0
 WCLOB ="{}"
 End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"GRANTS")) 
Endif
Append WCLOB,'{'
Append WCLOB,'"$baseUrl":"'+PSYR.PREFIX+'"'
Append WCLOB,',"$baseType":"'+PSYR.CNTPRE+"."+nomap+'"'
Append WCLOB,',"$classTitle":"'+func GET_RES_STRING(ACTX.LAN,33982)+'"'
Append WCLOB,',"$url":"{$baseUrl}/GRANTS'+PSYR.URLREP+''+REPRESENTATION+'.$search"'
Append WCLOB,',"$prototype":"{$baseUrl}/$prototypes('+"'"+'{$representation}.$thumb'+"'"+')"'
Append WCLOB,',"$type":"{$baseType}.'+REPRESENTATION+'.$search"'
Append WCLOB,',"$facility":"{FCY}"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"$resources":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$item":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,33982)+' {$key}"'
Append WCLOB,',"$key":"{GRAREF}"'
Append WCLOB,',"$url":"{$baseUrl}/GRANTS('+"'"+'{$key}'+"'"+')'+PSYR.URLREP+'GRANTS.searchItem"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"GRAREF":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,33983)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":20'
Append WCLOB,"}"
Append WCLOB,',"DES":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,282)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":60'
Append WCLOB,"}"
Append WCLOB,',"DES2":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,2064)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":60'
Append WCLOB,"}"
Append WCLOB,',"CANA":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$minItems":0'
Append WCLOB,',"$maxItems":20'
Append WCLOB,',"$item":{'
Append WCLOB,'"$type":"application/json"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"CCE":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,1688)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":15'
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,',"$links":{'
Append WCLOB,'"$search$details":{'
Append WCLOB,'"$title":"Detail"'
Append WCLOB,',"$default":true'
Append WCLOB,',"$url":"{$baseUrl}/GRANTS('+"'"+'{$key}'+"'"+')?representation=GRANTS.$details"'
Append WCLOB,',"$devices":"desktop"'
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
End ERROR
