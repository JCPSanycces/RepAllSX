#<AdxTL>@(#)12.0.0.0 $Revision$
# Gestion du masque MHT0
Raz GPILOBJ
Call OBJET("MHT",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "LIENS2"    : Gosub LIENS2
 When "SETBOUT"   : Gosub SETBOUT
 When "AP_CHANGE" : Gosub AP_CHANGE
 When "ANNULE"    : Gosub ANNULE
 When "MODIF"     : Gosub MODIF
 When "RAZDUP"    : [M:MHT0]FLGCLO=1 : Affzo [M:MHT0]FLGCLO
 When "INICRE"    : Gosub INICRE
 When "APRES_CRE" : Call GENHYPO(nomap,[F:MHT]COD) From SUBMHT
 When "APRES_MOD" : Call GENHYPO(nomap,[F:MHT]COD) From SUBMHT
 When "FERME"     : Gosub FERME
 When Default
Endcase
Return

#####################################
$OUVRE
If clalev ([F:MHT])=0 : Local File MSHYPTXAT [MHT] : Endif
If clalev ([F:BCB])=0 : Local File BCLOB     [BCB] : Endif
If clalev ([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif
If clalev ([F:MCL])=0 : Local File MSSCENAL  [MCL] : Endif
If clalev ([F:MCH])=0 : Local File MSSCENAH  [MCH] : Endif
If clalev ([F:CPY])=0 : Local File COMPANY   [CPY] : Endif

Local Char    COMPTEUR(GLONANM)
Local Integer STAT

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG = 'FRA' #Total Payroll is FRA only
Return

#####################################
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#####################################
$LIENS
# On décoche Définitif si l'hypothèse n'est stockée dans aucun scénario définitif
Link [MCL] With [MCH]MCH0=[MCL]COD
& As [LMC]
& Where [MCH]FLGCLO=2 & [MCL]TYPHYP=9 & [MCL]CODHYP=[F:MHT]COD
Read [LMC]MCL1 First
If fstat
 [M:MHT0]FLGCLO = 1
 Call DEBTRANS From GLOCK
 Gosub TR_LIEN
Endif
Return

$TR_LIEN
Trbegin [MHT]
 [F:MHT]FLGCLO = 1
 Rewrite[MHT]
 If fstat : Call FSTA("MHT") From GLOCK : Rollback : Return : Endif
Commit
Return

#####################################
$LIENS2
Gosub CHARGE_STYLE
#CMT commun à toutes les lignes
Default Mask [M:MHT0]
Call CHARGE_CMT ("SUBMHT",[F:MHT]COD,"","","")From SUBMSR
Return

#####################################
$CHARGE_STYLE
# Affzo avant le chgstl sinon ça marche pas !?!
Affzo [M:MHT0]20
For nolign=1 To [M:MHT0]NBLIG
 If [M:MHT0]ENAFLG1(nolign-1)=2
  Chgstl [M:MHT0]NBLIG(nolign-1) With "CONTRAT"
 Else
  Chgstl [M:MHT0]NBLIG(nolign-1) With ""
 Endif
Next
Return

#####################################
$SETBOUT
If GREP<>"" | !VERROU | [M:MHT0]FLGCLO=2
 Call VIREBOUT (CHAINE,"AH") From GOBJET
Endif
If [M:MHT0]FLGCLO=2
 Call VIREBOUT (CHAINE,"M") From GOBJET
Endif
Return

#####################################
## Changement de clé
$AP_CHANGE
Call APCHANGE(9,OCODE,NCODE) From SUBMHR
Return

#####################################
$ANNULE
#CMT commun à toutes les lignes
Call ANNULE_CMT ("SUBMHT",[F:MHT]COD,"","","")From SUBMSR
Return

####################################
$MODIF
#CMT commun à toutes les lignes
Default Mask [M:MHT0]
Call SAUVE_CMT ("SUBMHT",[F:MHT]COD,"","","")From SUBMSR
Return

#####################################
$INICRE
## Affectation du compteur
If [F:MHT]COD=""
 Call LECTCA(15,STAT) From SUBTCA
 If !STAT
  GMESSAGE = mess(51,10722,1) : # Compteur MSR non défini
  GOK = 0 : Return
 Else
  COMPTEUR= [F:TCA]CODNUM(15)
 Endif
 Call NUMERO(COMPTEUR,"",date$,"",[F:MHT]COD,STAT) From SUBANM
 If STAT
  # Erreur sur compteur
  GMESSAGE = mess(4,10702,1)-COMPTEUR
  GOK = 0 : Return
 Endif
 Call VERIF_CPT([F:MHT]COD,COMPTEUR)
 If GOK=0 : Return : Endif
 [M:MHT0]COD = [F:MHT]COD
 Affzo [M:MHT0]COD
Endif
Return

####################################
Subprog VERIF_CPT(NUM,COMPTEUR)
Variable Char NUM
Value    Char COMPTEUR
Local Integer STAT
If clalev([F:MHTZ])=0 : Local File MSHYPTXAT [MHTZ] : Endif
Read [MHTZ]MHT0(1)=NUM
If fstat : End : Endif
While !fstat
 Call NUMERO(COMPTEUR,"",date$,"",NUM,STAT) From SUBANM
 Read [MHTZ]MHT0(1)=NUM
Wend
If STAT
 # Erreur sur compteur
 GMESSAGE = mess(4,10702,1)-COMPTEUR
 GOK = 0 : End
Endif
End
###############################################################################################################
# Génération Traitement lié à l'hypothèse courante
# Ce traitement doit se nommer ainsi : "WPMS"+9+COD    (Chiffre 9 cause ML 485)
###############################################################################################################

Subprog GENHYPO(APPLI, CODHYP)
Value Char APPLI ()
Value Char CODHYP()

If clalev ([F:MHT2])=0 : Local File MSHYPTXAT  [MHT2] : Endif

Local Char    TETADO (50), PROG (30), FICSRC(250)
Local Integer OK
Local Char    SAVIFS(5) , SAVIRS(5)

SAVIFS = adxifs
SAVIRS = adxirs
adxifs = ""
adxirs = chr$(10)

TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
PROG = "WPMS9"+CODHYP
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-mess(4,10485,1)-CODHYP
Wrseq "###############################################"
Wrseq "##  Modification des taux AT"
Wrseq
Wrseq "$HYPOVAR"
Wrseq "Case CODRISK"
For [F:MHT2]MHT0 Where COD=CODHYP
 Wrseq space$(1)+'When "'+[F:MHT2]CODWAC+'" : TXRISK = '+num$([F:MHT2]RATWAC)
Next
Wrseq space$(1)+"When default"
Wrseq "Endcase"
Wrseq "Return"
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
adxirs = SAVIRS
adxifs = SAVIFS
End

######################################################################################
## Etiquette écran MHT0
######################################################################################

Subprog C_ENAFLG1(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Chgstl NBLIG(nolign-1) With "CONTRAT"
Else
 Chgstl NBLIG(nolign-1) With ""
Endif
End

######################################################################################

Subprog C_CODWAC(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:MHT0]CODWAC) From OBJDIV
If mkstat=2 : End : Endif
End
