#<AdxTL>@(#)4.0.0.0 $Revision$
##################################################################################
#   Import d'un fichier (modèle sans Objet)
##################################################################################

$INIVAR
Local Integer NBCLE, I, J
Local Char    CLE(GLONID1)(1..20)
Local Char    CHAINE(250), ABFIC(GLONABR)
Read [ATB_]CODFIC = [M:AOE1]FLGFIL(0)
ABFIC = [F:ATB_]ABRFIC
Read [ATI_]NUMLIG(2) = [M:AOE1]FLGFIL(0);1
CHAINE = [F:ATI_]DESCRIPT
While CHAINE<>""
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 NBCLE += 1
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
Local Char PROGIMP(GLONADC) , PROGIMS(GLONADC)
Local Integer OKTRT
PROGIMP = [M:AOE1]TRTIMP
Call EXISTE_ADX("","",PROGIMP,OKTRT) From ORDSYS
If !OKTRT : PROGIMP = "" : Endif
[M:IMP2]PROGIMP = PROGIMP
PROGIMS = [M:AOE1]SPEIMP
Call EXISTE_ADX("","",PROGIMS,OKTRT) From ORDSYS
If !OKTRT : PROGIMS = "" : Endif
[M:IMP2]PROGIMS = PROGIMS
If clalev([F:AAA_])=0 : Local File =[M:AOE1]FLGFIL(0) [AAA_] : Endif
Return

$VALID
GCLE = sigma(I=1,NBCLE," "+num$(evalue("[F:"+ABFIC+"]"+CLE(I))))
Gosub DEFAUT From =NOMTRT
Assign "[G:"+ABFIC+"]currind" With 1
Look =
If fstat
 If dim([M:AOE1]OPTCRE)<0 or [M:AOE1]OPTCRE=2
  GREP = "C"
  ACTION = "IMP_VERIF_CRE" : Gosub ACTION  From SUBIMPOBJ
  If GPRODUIT=1 & OK<0 : Return : Endif : ## GEODE GX
  If dim(ANOWRITE)>0 and ANOWRITE>0 : Return : Endif # CRUD done by class
  If !OK : GREP = "" : Return : Endif
  Gosub TR1
  If GOK<1
   Call TRACE2(2,mess(100,141,1)-GCLE,-1) From SUBIMPOBJ : # Erreur création
  Else
   Call TRACE2(0,GCLE,-1) From SUBIMPOBJ
  Endif
 Else
  Call TRACE2(1,GCLE-mess(105,141,1),-1) From SUBIMPOBJ : # Opération non effectuée
  GREP = ""
 Endif
Else
 If [M:AOE1]OPTUPD=2
  GREP = "M"
  ACTION = "IMP_VERIF_MOD" : Gosub ACTION From SUBIMPOBJ
  If GPRODUIT=1 & OK<0 : Return : Endif : ## GEODE GX
  If dim(ANOWRITE)>0 and ANOWRITE>0 : Return : Endif # CRUD done by class
  If !OK : GREP = "" : Return : Endif
  Gosub TR2
  If GOK<1
   Call TRACE2(2,mess(101,141,1)-GCLE,-1) From SUBIMPOBJ : # Erreur modification
  Else
   Call TRACE2(1,GCLE,-1) From SUBIMPOBJ
  Endif
 Else
  Call TRACE2(1,GCLE-mess(105,141,1),-1) From SUBIMPOBJ : # Opération non effectuée
  GREP = ""
 Endif
Endif
Return

$TR1
GOK = 1
Trbegin ADOVAL
 Gosub DEFAUT From =NOMTRT
 [F:AAA_] = [F]
 Gosub CHARGE_FIC
 Call INICRE
 Write
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK
  Goto AB_TR1
 Endif
 ACTION = "IMP_CREATION" : Gosub ACTION From SUBIMPOBJ
 If GOK=0 : Goto AB_TR1
 Elsif GOK<1 : Goto ROLL_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

Subprog INICRE
Onerrgo RIEN
If dim([F]CREDAT)>0 : [F]CREDAT = date$ : Endif
If dim([F]CREUSR)>0 : [F]CREUSR = GUSER : Endif
If dim([F]CRETIM)>0 : [F]CRETIM = time : Endif
Onerrgo
End

$RIEN
Resume

$TR2
GOK=1
Trbegin ADOVAL
 Gosub DEFAUT From =NOMTRT
 [F:AAA_] = [F]
 Readlock =
 If fstat=1
  GOK=-1 : Call FSTA(ABFIC) From GLOCK : Goto ROLL_TR2
 Elsif fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 Gosub CHARGE_FIC
 Call INIMOD
 Rewrite
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 ACTION = "IMP_MODIF" : Gosub ACTION From SUBIMPOBJ
 If GOK=0 : Goto AB_TR2
 Elsif GOK<1 : Goto ROLL_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

Subprog INIMOD
Onerrgo RIEN
If dim([F]UPDDAT)>0 : [F]UPDDAT = date$ : Endif
If dim([F]UPDUSR)>0 : [F]UPDUSR = GUSER : Endif
If dim([F]UPDTIM)>0 : [F]UPDTIM = time : Endif
Onerrgo
End

$CHARGE_FIC
For I=0 To [M:AOE2]NBRLIG-1
 If [M:AOE2]SEL(I)<>3
  WZON = [M:AOE2]FLD(I)
  If WZON<>"" & !find(left$(WZON,1),"#","=","'",'"',"*","/")
   K = instr(1,WZON,"(")
   If K
    WZON = left$(WZON,K-1)
   Endif
   Read [ATZ_]CODZONE = [M:AOE2]FIL(I);WZON
   If !fstat
    If find([F:ATZ_]CODTYP,"AXX","AX1","AX2","AX3")
     Raz J , PARAM
     For WCHAR="TABLE1","ZONE","CLECUR1","CLECUR2"
      J += 1
      Read [AMP_]CODPAR=2;[F:ATZ_]CODFIC;[F:ATZ_]CODZONE;WCHAR
      If !fstat
       If find(left$([F:AMP_]VALPAR,1),'"',"'") or left$([F:AMP_]VALPAR,4)="num$"
        PARAM(J) = num$(evalue([F:AMP_]VALPAR))
       Elsif instr(1,[F:AMP_]VALPAR,"+") or instr(1,[F:AMP_]VALPAR,"-")
        PARAM(J) = ""
       Else
        PARAM(J) = num$(evalue('[F:AAA_]'+[F:AMP_]VALPAR))
       Endif
      Else
       PARAM(J) = ""
      Endif
     Next WCHAR
     SAVACT = GLANGUE
     GLANGUE = "imp"
     Call LECTEXTRA(WCHAR,PARAM(1),PARAM(2),PARAM(3),PARAM(4)) From ATEXTRA
     Call SUPTEXLAN(PARAM(1),PARAM(2),GLANGUE,PARAM(3),PARAM(4)) From ATEXTRA
     If instr(1,WCHAR,"~~")
      GLANGUE = right$(WCHAR,instr(1,WCHAR,"~~")+2)
      WCHAR   = left$(WCHAR,instr(1,WCHAR,"~~")-1)
     Else
      GLANGUE = SAVACT
     Endif
     Call MAJTEXTRA(WCHAR,PARAM(1),PARAM(2),PARAM(3),PARAM(4)) From ATEXTRA
     GLANGUE = SAVACT
    Elsif GREP="M" & evalue("dim([F]"+[M:AOE2]FLD(I)+")")>0
     Assign "[F]"+[M:AOE2]FLD(I) With evalue("[F:AAA_]"+[M:AOE2]FLD(I))
    Endif
   Endif
  Endif
 Endif
Next I
Return
