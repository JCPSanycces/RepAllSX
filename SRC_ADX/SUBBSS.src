#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion objet BSS
########################################################################
#    GESTION DES FOURNISSEURS - EXPEDITEURS                            #
#----------------------------------------------------------------------#
#                                                    cg Janvier 2008   #
#                                                                      #
########################################################################
$ACTION
Case ACTION
  When "AFFMASK"            : Gosub AFFMASK
  When "FILTRE"             : Gosub FILTRE
  When "OUVRE"              : Gosub OUVRE
  When "LIENS"              : Gosub LIENS
  When "RAZCRE"             : Gosub RAZCRE 
  When "RAZDUP"             : Gosub RAZDUP 
  When "INICRE"             : Gosub INICRE 
  When "INIMOD"             : Gosub INIMOD 
  When "CREATION"           : Gosub CREATION 
  When "MODIF"              : Gosub MODIF
  When "APRES_MOD"          : Gosub APRES_MOD
  When "SETBOUT"            : Gosub SETBOUT
  When "ABANDON"            : Gosub ABANDON
  When "FERME"              : Gosub FERME
  When Default
Endcase
Return


#########################################################################
########### ACTIONS STANDARDS ###########################################
#########################################################################

#########################################################################
$AFFMASK
Global Integer GCREATIONLIEN
Global Integer GABANDON
Global Char    GBPSNUM
Global Char    GBSGCOD
Global Char    GBPSCPY
Global Char    GBPSSHI
Global Char    GBPSADD

  Raz GCREATIONLIEN, GABANDON, GBPSNUM, GBSGCOD, GBPSCPY, GBPSSHI, GBPSADD

  If  clalev([M:BPS0])  GBPSNUM = [M:BPS0]BPSNUM      : Endif
  If  clalev([M:BPS0])  GBSGCOD = [M:BPS0]BSGCOD      : Endif
  If  clalev([M:BPS5])  GBPSCPY = [M:BPS5]CPY         : Endif
  If  clalev([M:BPS5])  GBPSSHI = [M:BPS5]BPSSHI      : Endif
  If  clalev([M:BPS5])  GBPSADD = [M:BPS5]BPSADD      : Endif
Return

#########################################################################
$FILTRE
#  FILTSUP = "BPSNUM = 
Return

#########################################################################
$OUVRE
  If !clalev([F:BPA])   Local File BPADDRESS  [BPA]   : Endif
  If !clalev([F:BSG])   Local File BPSCATEG   [BSG]   : Endif
  If !clalev([F:BPS2])  Local File BPSUPPLIER [BPS2]  : Endif
  If !clalev([F:BPR2])  Local File BPARTNER   [BPR2]  : Endif
Return

#########################################################################
$LIENS
  If [V]GCREATIONLIEN & [V]GABANDON
    Raz [M:BPSS]BPSADD,[M:BPSS]BPSDES : Affzo [M:BPSS]10 
    Raz [V]GCREATIONLIEN, [V]GABANDON
  Endif
  Gosub INIT_BPSS
  Gosub LIENS_BPSNAM
  Gosub ALIM_ZONES_BPSS
  Gosub GRIZE_BPSS_TRANSPORTEUR
  Gosub ALIM_BPSS_FFWADDDES
  Affzo [M:BPSS]FFWADDDES
Return

#########################################################################
$RAZCRE
  Gosub INIT_BPSS
  Gosub RECH_BPSCATEG
  Gosub GRIZE_BPSS_TRANSPORTEUR
Return

#########################################################################
$RAZDUP
  Gosub INIT_BPSS
  Gosub GRIZE_BPSS_TRANSPORTEUR
Return

#########################################################################
$INICRE
  Gosub CRE_BPSNAM
Return

#########################################################################
$INIMOD
  Gosub CRE_BPSNAM
Return

#########################################################################
$CREATION
#-------- Après création de l'objet BSS : BPSHISUPP
  # Création du lien Société-Fournisseur-Expéditeur-Adresse dans BSL : BPSHISUPLN
  Gosub CREBSL
  If GOK < 1 : Return : Endif

  # MAJ de l'expéditeur par défaut s'il a changé !
  Gosub MAJBPS
  If GOK < 1 : Return : Endif
Return

#########################################################################
$MODIF
  # Création du lien Société-Fournisseur-Expéditeur-Adresse dans BSL : BPSHISUPLN
  Gosub CREBSL
  If GOK < 1 : Return : Endif

  # MAJ de l'expéditeur par défaut s'il a changé !
  Gosub MAJBPS
  If GOK < 1 : Return : Endif
Return

#########################################################################
$APRES_MOD
#  If [V]GCREATIONLIEN
#    Raz [V]GCREATIONLIEN, [V]GABANDON
#  Endif
Return

#########################################################################
$SETBOUT
  If [V]GCREATIONLIEN
    Grizo [M:BPSS]BPSSHI, BPSADD : Affzo [M:BPSS]10
    REP="M"  :  GREP="M" 
    Return
  Endif
Return

#########################################################################
$ABANDON
  If [V]GCREATIONLIEN
    [V]GABANDON = 1
  Endif
Return

#########################################################################
$FERME
  Kill GCREATIONLIEN, GBPSNUM, GBSGCOD, GBPSCPY, GBPSSHI, GBPSADD, GABANDON
Return


######################################################################################

# --------------------------------------------------------------------------------
#                                        Ecran BPSSHI                            
# --------------------------------------------------------------------------------

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran BPSSHI) 18/01/2008 10:04:34 (JPGA)
######################################################################################
Subprog C_BPSSHI(VALEUR)
Variable Char    VALEUR()
Local    Char    WBPSSHI
  # Contrôle existence Fournisseur et vérification Fournisseur Actif
  If VALEUR <> "" & VALEUR <> [V]GBPSNUM
    [L]WBPSSHI = VALEUR
    Gosub LECTURE_BPS2
    If mkstat = 2 
      End 
    Endif
  Endif
End

Subprog AM_BPSSHI(VALEUR)
Variable Char    VALEUR()
  [M:BPSS]BPSSHI = VALEUR

  # Alimentation du Code addresse et de sa désignation
  Gosub ALIM_BPSS_BPSADD

  # Alimentation de la Raison sociale
  Gosub ALIM_BPSS_BPSNAM
End

Subprog C_BPSADD(VALEUR)
Variable Char    VALEUR()
  # Contrôle existence Code adresse du Fournisseur
  If VALEUR <> ""
    Look [BPA] BPA0 = 1;[M:BPSS]BPSSHI;VALEUR
    If fstat 
      GMESSAGE = mess(16,199,1) : mkstat = 2 : End
    Endif
  Endif
End

Subprog AM_BPSADD(VALEUR)
Variable Char    VALEUR()
  # Recherche de l'intitulé du Code addresse de l'expéditeur
  [M:BPSS]BPSADD = VALEUR
  Gosub ALIM_ZONES_BPSS

  # Vérification qu'un couple Expéditeur-Adresse n'existe pas pour d'autres fournisseurs
  # Si c'est le cas : Affichage message d'information et bouton ENREGISTRER dégrisé !
  Gosub TEST_EXISTENCE_COUPLE
End

Subprog C_ENAFLG(VALEUR)
Variable Integer VALEUR
Local    Char    WBPSNUM : [L]WBPSNUM = ""

  # Contrôle que le couple Expéditeur-Adresse n'est pas par défaut d'un fournisseur
  If VALEUR <> 2
    If [M:BPSS]BPAADDFLG = 2                                      # L'expéditeur par défaut ne doit pas être inactif
      # Message créé par JPGA le 21/01/2008
      mkstat=2 : GMESSAGE=mess(532,199,1) : End 
    Endif

    For [BPS2] Where BPSSHI = [M:BPSS]BPSSHI and BPSADD = [M:BPSS]BPSADD and BPSNUM <> [M:BPSS]BPSNUM
      If [L]WBPSNUM = ""
        [L]WBPSNUM = [F:BPS2]BPSNUM
      Else
        [L]WBPSNUM = WBPSNUM-"-"-[F:BPS2]BPSNUM
      Endif
    Next

    If [L]WBPSNUM <> ""                                           # Fournisseur(s) trouvé(s)
      mkstat=2 : GMESSAGE=mess(375,194,1) - ":" - [L]WBPSNUM : End 
    Endif
  Endif
End

Subprog C_BPAADDFLG(VALEUR)
Variable Integer VALEUR
  # L'expéditeur par défaut ne doit pas être inactif
  If VALEUR = 2  & [M:BPSS]ENAFLG <> 2
    mkstat=2 : GMESSAGE=mess(532,199,1) : End 
  Endif
End

Subprog AM_FFWNUM(VALEUR)
Variable Char    VALEUR()
  If VALEUR <> ""                                                 # Transporteur vide : on grise le code adresse
    # Lecture du Partner transporteur   : BPR2
    If [F:BPR2]BPRNUM <> VALEUR
      Read [BPR2]BPR0 = VALEUR
      If fstat                                                    # Transporteur inexistant
        Raz [F:BPR2] : GMESSAGE = mess(138,100,1) : mkstat = 2 : End 
      Endif
    Endif
   
    [M:BPSS]FFWADD = [F:BPR2]BPAADD 
    Affzo [M:BPSS]FFWADD : Actzo [M:BPSS]FFWADD
    
    # Recherche de l'intitulé du Code addresse du transporteur
    [M:BPSS]FFWNUM = VALEUR
    Gosub ALIM_BPSS_FFWADDDES
  Else
    Raz [M:BPSS]FFWADD,[M:BPSS]FFWADDDES : Affzo [M:BPSS]FFWADD : Diszo [M:BPSS]FFWADD : End 
  Endif

  Affzo [M:BPSS]FFWADDDES
End

Subprog C_FFWADD(VALEUR)
Variable Char    VALEUR()
  # Vérification code adresse existe pour le transporteur sélectionné
  Look [BPA] BPA0 = 1;[M:BPSS]FFWNUM;VALEUR
  If fstat 
    GMESSAGE = mess(16,199,1) : mkstat = 2 : End
  Endif
End

Subprog AM_FFWADD(VALEUR)
Variable Char    VALEUR()
  # Recherche de l'intitulé du Code addresse du transporteur
  [M:BPSS]FFWADD = VALEUR
  Gosub ALIM_BPSS_FFWADDDES    
  Affzo [M:BPSS]FFWADDDES
End


######################################################################################
## Etiquettes utilisées pour le masque BPSS (écran BPSSHI) 18/01/2008 10:04:34 (JPGA)
######################################################################################

$CREBSL
####### Appelé depuis CREATION
  #--- Création du lien : Société-Fournisseur-Expéditeur-Adresse dans BPSHISUPLN
  Readlock [BSL]BSL0=[M:BPSS]CPY;[M:BPSS]BPSNUM;[M:BPSS]BPSSHI;[M:BPSS]BPSADD
  Case fstat
    When 1                                                      # Enregistrement Trouvé mais vérouillé
      Return
    When 0                                                      # Enregistrement     Trouvé OK
      Return
    When 5                                                      # Enregistrement Non Trouvé OK
      #--- Remplissage zones du masque
      [F:BSL] = [M:BPSS]

      #--- Remplissage Fournisseur courant
      [F:BSL]BPSNUM = [V]GBPSNUM

      #--- MAJ des zones systèmes
      [F:BSL]CREDAT = date$
      [F:BSL]CREUSR = GUSER

      Write [BSL]
      If fstat
        GOK = 0 : Call FSTA("BSL") From GLOCK : Return
      Endif
    When Default                                                # Enregistrement en erreur
      GOK = 0   : Call RSTA("BSL",[M:BPSS]CPY-[M:BPSS]BPSNUM-[M:BPSS]BPSSHI-[M:BPSS]BPSADD) From GLOCK : Return
  Endcase
Return

$MAJBPS
####### Appelé depuis CREATION et MODIF
  # Un nouveau couple Expéditeur-Adresse a été mis par défaut .
  # Si L'expéditeur ou l'addresse par défaut ont changé :
  #   On MAJ le fournisseur (Et dans l'objet BPS, on force le réaffichage du masque dans l'étiquette EXEBOUT)
  If [M:BPSS]BPAADDFLG = 2  &  ([M:BPSS]BPSSHI <> [V]GBPSSHI | [M:BPSS]BPSADD <> [V]GBPSADD)
    Update [BPS2] Where BPSNUM = [V]GBPSNUM  With BPSSHI = [M:BPSS]BPSSHI, BPSADD = [M:BPSS]BPSADD
    If fstat
      GOK = 0   : Call FSTA("BPS2") From GLOCK : Return
    Else
      [V]GBPSSHI = [M:BPSS]BPSSHI
      [V]GBPSADD = [M:BPSS]BPSADD
    Endif
  Endif
Return

$RECH_BPSCATEG
############## Appelé depuis RAZCRE
  # Recherche des informations par défaut dans la Catégorie Fournisseur
  If [V]GBSGCOD = ""
    Raz [F:BSG]
  Else
    If [F:BSG]BSGCOD <> [V]GBSGCOD
      Read [BSG]BSG0 = [V]GBSGCOD
      If fstat
        Raz [F:BSG]
      Endif
    Endif
  Endif

  [M:BPSS] = [F:BSG]
  [M:BPSS]EECICT    = [F:BSG]EECICT2
  [M:BPSS]EECINCRAT = [F:BSG]EECINCRAT2
  [M:BPSS]EECLOC    = [F:BSG]EECLOC2
  [M:BPSS]UVYCOD    = [F:BSG]UVYCOD2

  Affzo [M:BPSS]1-99
Return

$CRE_BPSNAM
########### Appelé depuis INICRE et INIMOD
  # MAJ Raison sociale
  [F:BSS]BPSNAM(0) = [M:BPSS]BPSNAM0
  [F:BSS]BPSNAM(1) = [M:BPSS]BPSNAM1
Return

$LIENS_BPSNAM
############# Appelé depuis LIENS
  [M:BPSS]BPSNAM0  = [F:BSS]BPSNAM(0)
  [M:BPSS]BPSNAM1  = [F:BSS]BPSNAM(1)
Return

$ALIM_BPSS_BPSNAM
################# appelé depuis AM_BPSSHI
  #--- Lecture du Partner expéditeur     : BPR2
  If [M:BPSS]BPSSHI <> [F:BPR2]BPRNUM 
    Read [BPR2]BPR0 = [M:BPSS]BPSSHI
    If fstat                                                        # Partner inexistant
      Raz [F:BPR2]
    Endif
  Endif

  [M:BPSS]BPSNAM0 = [F:BPR2]BPRNAM(0)
  [M:BPSS]BPSNAM1 = [F:BPR2]BPRNAM(1)
Return

$ALIM_BPSS_BPSADD
################# Appelé depuis AM_BPSSHI
Local    Char    WBPSSHI
Local Integer    I

  If [M:BPSS]BPSSHI = [V]GBPSSHI                                    # 1/ Expéditeur par défaut du masque par défaut
    [M:BPSS]BPSADD = [V]GBPSADD
  Else
    Filter [BSL] Where BPSNUM = [M:BPSS]BPSNUM and BPSSHI = [M:BPSS]BPSSHI and BPSSHI <> [V]GBPSSHI
    Read [BSL]BSL0 First
    If !fstat                                                       # 2/ Lien Fournisseur-Expéditeur trouvé dans BSL
      [M:BPSS]BPSADD = [F:BSL]BPSADD
    Else                                                            # 3/ Lecture fournisseur dans BPS2
      Raz [M:BPSS]BPSADD, [M:BPSS]BPSDES
    Endif
    Filter [BSL] 
  Endif

  Gosub ALIM_BPSS_BPSDES
Return

$TEST_EXISTENCE_COUPLE
###################### Appelé depuis AM_BPSADD
Local Char       WBPSNUM : [L]WBPSNUM = ""
Local Integer    OK      : [L]OK = 0

  Filter [BSL] Where BPSNUM = [M:BPSS]BPSNUM and BPSSHI = [M:BPSS]BPSSHI and BPSADD = [M:BPSS]BPSADD 
  Read [BSL]BSL0 First
  Filter [BSL] 
  If !fstat
    Return
  Else
    For [BSL] Where BPSSHI = [M:BPSS]BPSSHI and BPSADD = [M:BPSS]BPSADD and BPSNUM <> [M:BPSS]BPSNUM
      If WBPSNUM = ""
        WBPSNUM = [F:BSL]BPSNUM
      Else
        WBPSNUM = WBPSNUM-"-"-[F:BSL]BPSNUM
      Endif
    Next

    If WBPSNUM <> ""
      GMESSAGE=mess(374,194,1)-":"-WBPSNUM
      Call AVERTIR(GMESSAGE,OK) From GESECRAN
      Raz GMESSAGE
      Case [L]OK    
        When 1 
          [L]OK = 0 : Raz [M:BPSS]BPSADD,[M:BPSS]BPSDES : Affzo [M:BPSS]10 : mkstat = 2 : End
        When 2
          [L]OK = 0 : [V]GCREATIONLIEN = 1 : End
      Endcase 
    Endif
  Endif
Return

$LECTURE_BPS2
############# Appelé depuis C_BPSSHI
  #--- Lecture du Fournisseur expéditeur : F:BPS2
  If [L]WBPSSHI <> [F:BPS2]BPSNUM
    Read [BPS2]BPS0 = [L]WBPSSHI
    If fstat                                                   # Fournisseur inexistant
      Raz [F:BPS2] 
      GMESSAGE = mess(373,194,1) - ": [F:BPS2]BPS0=" + [L]WBPSSHI : mkstat = 2 : Return
    Elsif [F:BPS2]ENAFLG <> 2                                  # Fournisseur inactif
      GMESSAGE = mess(140,199,1) - ": [F:BPS2]BPS0=" + [L]WBPSSHI : mkstat = 2 : Return
    Endif
  Endif
Return

$GRIZE_BPSS_TRANSPORTEUR
######################## Appelé depuis  (par LIENS/RAZCRE/AM_BPSSH/AM_BPSADD)
  #--- Activation/Désactivation du cade addresse du transporteur
  If [M:BPSS]FFWNUM = "" 
    Diszo [M:BPSS]FFWADD 
  Else 
    Actzo [M:BPSS]FFWADD 
  Endif
Return

$INIT_BPSS
########## Appelé depuis LIENS et RAZCRE
  If [V]GBPSSHI = ""  |  [V]GBPSADD = "" 
    Raz [M:BPSS] : Affzo [M:BPSS]1-99
  Else
    [M:BPSS]BPSNUM = [V]GBPSNUM
    [M:BPSS]CPY    = [V]GBPSCPY

    Affzo [M:BPSS]10
  Endif
Return

$ALIM_ZONES_BPSS
################ Appelé depuis AM_BPSADD et LIENS
  If [M:BPSS]BPSSHI = [V]GBPSSHI  &  [M:BPSS]BPSADD = [V]GBPSADD
    [M:BPSS]BPAADDFLG = 2
  Else
    [M:BPSS]BPAADDFLG = 1
  Endif

  Gosub ALIM_BPSS_BPSDES
Return

$ALIM_BPSS_BPSDES
################# Appelé depuis ALIM_ZONES_BPSS ( par et AM_BPSADD et LIENS ) et ALIM_BPSS_BPSADD ( par AM_BPSSHI )
Local Integer I
  #--- Alimentation de l'addresse de l'expéditeur par défaut
  If [M:BPSS]BPSSHI <> "" and [M:BPSS]BPSADD <> ""
    Read [BPA] BPA0 = 1;[M:BPSS]BPSSHI;[M:BPSS]BPSADD
    If fstat
      Raz [F:BPA]
    Endif

    [M:BPSS]BPSDES      = [F:BPA]BPADES
    #--- Alimentation zones invisibles : Pays et Code postal pour les types de données :
    #      - CTY de la zone ICTCTY : Ville Incoterm
    #      - EEC de la zone EECNUM : Identification CEE
    [M:BPSS]BPSCRY      = [F:BPA]CRY
    [M:BPSS]BPSPOSCOD   = [F:BPA]POSCOD
    Affzo [M:BPSS]10, 20
  Endif
Return

$ALIM_BPSS_FFWADDDES
################# Appelé depuis AM_FFWNUM et AM_FFWADD et LIENS
  #--- Alimentation de l'addresse du transporteur courant de l'expéditeur par défaut
  If [M:BPSS]FFWNUM <> "" and [M:BPSS]FFWADD <> ""
    Read [BPA] BPA0 = 1;[M:BPSS]FFWNUM;[M:BPSS]FFWADD
    If fstat  
      Raz [F:BPA]
    Endif

    [M:BPSS]FFWADDDES = [F:BPA]BPADES
  Endif
Return
