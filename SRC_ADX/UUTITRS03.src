#<AdxTL>@(#)4.0.0.0 $Revision$
##################################################################################################################
# UUTITRS03   Utilitaire de suppression des doublons éventuels dans la table FUP                    Module Tiers #
##################################################################################################################

Local Char APPLI(30) : APPLI = nomap
Call SAIDOS(APPLI,"") From SAIDOS
If APPLI <> ""
 If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 Read [ADS]DOSSIER=[L]APPLI : If fstat Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UUTITRS03:"-"FUP table data updates") From LECFIC

 Call MAJ_UTITRS03(APPLI) 
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

# suppression des doublons éventuels dans la table FUP
Subprog MAJ_UTITRS03(APPLI)
Value Char APPLI


# test du code activité
If func AFNC.ACTIV("FUP")=0 : End : Endif

# test de présence des tables
If filinfo(filpath("FIL","FUP","fde",APPLI),0)<=0 : End : Endif

Local File =APPLI+".FUP" [FUP]
Local File =APPLI+".FUP" [FUP2]

# si la table FUP est vide, pas la peine d'exécuter le traitement
If nbrecord([FUP])=0 : End : Endif

Call ECR_TRACE("UUTITRS03: Process Start on : "+APPLI,0) From GESECRAN

Local Integer N
Trbegin [FUP2]
For [FUP]
 N=0
 For [FUP2] Where NUMEDT=[F:FUP]NUMEDT and ACCNUM=[F:FUP]ACCNUM and DUDLIG=[F:FUP]DUDLIG and NUMCOP=[F:FUP]NUMCOP
  N+=1
  If N>1 # nécessaire pour supprimer tous les doublons sauf le premier !
   Call ECR_TRACE("DATEDT = "+[F:FUP]DATEDT-"NUMEDT = "+[F:FUP]NUMEDT-"ACCNUM = "+num$([F:FUP]ACCNUM)-"DUDLIG = "+num$([F:FUP]DUDLIG)-"NUMCOP = "+num$([F:FUP]NUMCOP), 0) From GESECRAN
   Delete [FUP2] Curr
  Endif
 Next
Next
Commit # FUP2

Call ECR_TRACE("UUTITRS03: Process End on : "+APPLI,0) From GESECRAN
End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
# pas de modification dans le dossier mère
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS03(APPLI)
End

########################################################################
# Pour exécution depuis dosmaj (validation dossier)                    #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI
# pas de modification dans le dossier mère
If APPLI="X3" End : Endif
# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS03(APPLI)
End
