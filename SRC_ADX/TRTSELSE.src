#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
#
# TRTSELSE - Selections for Sage Exchange
#
################################################################################

$ACTION

  Case ACTION
    When "SEL_TABLE" : Gosub SEL_TABLE
    When "SEL_LISTE" : Gosub SEL_LISTE
  Endcase

Return

################################################################################
$SEL_TABLE

Case TABLE
    When "SELSEACC": Gosub SELSEACC
    When "SELSEPRC": Gosub SELSEPRC
Endcase

Return

################################################################################
$SELSEACC

# For  Selecting Account nicknames (credit cards)
If !clalev([BPC])  : Local File BPCUSTOMER [BPC]  : Endif

Read [BPC]BPC0=PARAM(1)
If fstat : Return : Endif

# Display the Sage exchange customer accounts table
OBJET = "SEB"
CRITERE = "BPCNUM=[F:BPC]BPCPYR & FLACT=2 & ONETIME<>2"
If PARAM(2)<>"" : CRITERE -= '& [F:SER]CPY="'+PARAM(2)+'"' : Endif

Return
################################################################################
$SELSEPRC

If clalev([F:SER])=0 : Local File SEPRC [SER] : Endif

# Active and Restricted to the Company
OBJET   = "SER"
CRITERE = "FLACT=2"
If PARAM(1)<>"" : CRITERE -= '& CPY="'+PARAM(1)+'"' : Endif

Return
################################################################################
$SEL_LISTE

Case LISTE

Endcase

Return
##################################################################
