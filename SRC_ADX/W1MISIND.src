#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque MISIND 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:14:24"
A_USER  = "DOC"
A_STAMP = "20181109231424"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask MISIND [MID]
Gosub HORODAT
Local Inpbox "MISIND" From GFONCTION At A_STAMP With A_WINDPREV Mask [MID] As [SIM_]
Grizo [MID]5
Grizo [MID]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [MID]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=91 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=91 : Y1(1)=4 : Y2(1)=28
Return

$ON_COD
Onevent CONTROL Call C_COD(zc) From W1MISIND
Return

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJW"
 PARMSK(1) = "MID"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
Endif
Gosub _AFF
End

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1MISIND
Onevent CONTROL Call C_LEG(zc) From W1MISIND
Onevent AFTER_CHANGE Gosub AMM_LEG From W1MISIND
Onevent BEFORE_INPUT Call AS_LEG(zc) From W1MISIND
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"909") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_LEG(zc) From W1MISIND
Onkey   2 Titled GBOUTS Call S_LEG(zc) From W1MISIND
Onkey 144 Titled GBOUTP Call P_LEG(zc) From W1MISIND
Onkey 146 Titled GBOUTA Call SA_LEG(zc) From W1MISIND
Gosub _AFF
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"909","") From SUBADI
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"909",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
Endif
Gosub _AFF
End

$AMM_LEG
Call AM_LEG(zc)
If !mkstat & GOBJET
 zoncou = "LEG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_LEG(VALEUR) From SUBMID
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZLEG)")>indice
 [M]LEG(indice) = VALEUR
 Affzo ZLEG(indice)
Endif
Gosub _AFF
End

Subprog S_LEG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "909"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_LEG(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"909") From GOBJET
Gosub _AFF
End

Subprog SA_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "909"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "909"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1MISIND
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","LNGDES","909",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_MIS
Onevent BEFORE_INPUT Call AS_MIS(zc) From W1MISIND
Onevent CONTROL Call C_MIS(zc) From W1MISIND
Onevent AFTER_CHANGE Gosub AMM_MIS From W1MISIND
Return

Subprog AS_MIS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(16225,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_MIS(zc) From W1MISIND
Onkey   2 Titled GBOUTS Call S_MIS(zc) From W1MISIND
Onkey 144 Titled GBOUTP Call P_MIS(zc) From W1MISIND
Onkey 146 Titled GBOUTA Call SA_MIS(zc) From W1MISIND
Gosub _AFF
End

Subprog C_MIS(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 1003340 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("MIS","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "MIS" : GZNUM = 1003340 : Endif
Endif
Gosub _AFF
End

$AMM_MIS
Call AM_MIS(zc)
If !mkstat & GOBJET
 zoncou = "MIS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_MIS(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZMIS)")>indice
 [M]MIS(indice) = VALEUR
 Affzo ZMIS(indice)
Endif
Gosub _AFF
End

Subprog S_MIS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELMISLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELMISLEG"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELMISLEG","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_MIS(VALEUR)
Variable Char    VALEUR()
Call OBJET("MIS",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_MIS(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "MIS"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_MIS(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("MIS",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZMIS
Onevent BEFORE_AREA Gosub AV_ZMIS From W1MISIND
Return

$AV_ZMIS
If clalev([F:MIS])=0 : Local File MISSION [MIS] : Endif
Call LECTURE("MIS",num$([M]MIS(indice)),"") From CONTOBJ
zc = [F:MIS]DES
Gosub _AFF
Return

$CHG_STY
Return


