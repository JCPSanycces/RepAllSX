#<AdxTL>@(#)4.0.0.0 $Revision$ Moulinettes de passage en rele
##################################################################################
# DOSMAJ50 : Mises à jour à effectuer lors du passage à la version AKIRA (Release 50)
# Moulinette avant la version 8 (AKIRA)
##################################################################################


#-------------------------------------#
#         Avant mise à jour           #
#-------------------------------------#

#######################################
Subprog AMAJ
Local Integer VERSION

Onerrgo ERREUR

# Issue 107012 - 2015-09-17 by BEEBE : Initialize ROUOPENUM = 0 for unexpected tracked OPs
# recovery of the last patch number to validate the file and folder X3
Local Char WVERSION (5)
Local Shortint WPATCH
WPATCH = 0
Raz WVERSION

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif

Filter [ZAP] Where TYP = "P"
Read [ZAP] Last
If fstat
  [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]

# recovery of the last patch number to validate the file and folder X3
WPATCH = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File

VERSION = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ50 - AMAJ - VERSION = "-num$(VERSION),-1) From GESECRAN

#----- Superviseur en premier
Call ECR_TRACE("************** AMAJ SUPMAJ50 ***************",-1) From GESECRAN
Call MAJDIC From SUPMAJ50
Call AMAJ From SUPMAJ50 : # Moulinettes superviseur

#GVALIDE(2) = 1 : # Ecrans
#GVALIDE(3) = 1 : # Objets
#GVALIDE(4) = 1 : # Fenêtres et TRT générés superviseur
#GVALIDE(5) = 1 : # Consultations

#----- Puis Tronc commun

#Call ECR_TRACE("************** AMAJ TRCMAJ50 ***************",-1) From GESECRAN
#Call AMAJ   From TRCMAJ50


#----- Puis Tronc commun
Call ECR_TRACE("************** ATRCMAJ50 TRCMAJ50 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  Call ATRCMAJ50   From TRCMAJ50 : # Moulinettes Tronc commun
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

#----- Ensuite les autres modules
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 ##YYFIN_107921_US1_in progress : Ajout Cdt
 Call ECR_TRACE("************** ATRCMAJ50 CPTMAJ50 ***************",-1) From GESECRAN
 Call ATRCMAJ50 From CPTMAJ50 : # Moulinettes Compta - Commun
Endif


Call ECR_TRACE("************** AFASMAJ50 FASMAJ50 ***************",-1) From GESECRAN
If [F:ADS]MODULE(13)=2
  Call AFASMAJ50 From FASMAJ50 : # Moulinettes Immobilisations
  GVALTRANS(14)=2              : # TRT générés Immobilisations
Endif

#Gbn-106788
#------ Entry transaction validation for the modules without migration process

If [F:ADS]MODULE(1)=2  : GVALTRANS(2)=2  : Endif # Accounting
If [F:ADS]MODULE(4)=2  : GVALTRANS(5)=2  : Endif # Sales
If [F:ADS]MODULE(5)=2  : GVALTRANS(6)=2  : Endif # Purchase
If [F:ADS]MODULE(6)=2  : GVALTRANS(7)=2  : Endif # Inventory
If [F:ADS]MODULE(7)=2  : GVALTRANS(8)=2  : Endif # Manufacturing
If [F:ADS]MODULE(11)=2 : GVALTRANS(12)=2 : Endif # CRM - Helpdesk
If [F:ADS]MODULE(12)=2 : GVALTRANS(13)=2 : Endif # CRM - Commercial action


Onerrgo
End


###################################################################################
###################################################################################
###################################################################################

#-------------------------------------#
#          Après mise à jour          #
#-------------------------------------#

Subprog MAJ
Local Integer VERSION

Onerrgo ERREUR
VERSION = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ50 - MAJ - VERSION = "-num$(VERSION),0) From GESECRAN

# Issue 107012 - 2015-09-17 by BEEBE : Initialize ROUOPENUM = 0 for unexpected tracked OPs
# recover latest version and patch from table APATCH
Local Char WVERSION(5)
Local Shortint WPATCH
WPATCH = 0
Raz WVERSION

If clalev([F:ZAP])=0 : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP] : Endif

Filter [ZAP] Where TYP = "P"
Read [ZAP] Last
If fstat
    [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]

# recovery of the last patch number to validate the file and folder X3
WPATCH   = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File

If left$(WVERSION,3) = "1.3"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.4"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.5"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.6"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.7"
    WPATCH =0
Endif

Call ECR_TRACE("************** MAJ SUPMAJ50 ***************",-1) From GESECRAN
Call MAJ      From SUPMAJ50                      # Moulinettes Superviseur

Call ECR_TRACE("************** MAJ TRCMAJ50 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  Call MAJ      From TRCMAJ50
  Call MAJ_UTITC70([F:ADS]DOSSIER) From UTITC70    # FGR 19/05/2015 : X3SUIVI108223
Else
  Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

Call ECR_TRACE("************** MAJ UTISTO23 ***************",-1) From GESECRAN
#Gbn-106947
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
  Call UTI_MOUL([F:ADS]DOSSIER) From UTISTO23      # Issue 100246 - 2015-03-05 by CCC : Valuation report with accounting date
Else
  Call ECR_TRACE("Historic folder migration => UTISTO23 not executed",0) From GESECRAN
Endif

If [F:ADS]MODULE(5)=2
    If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
        Call ECR_TRACE("************** MAJ UTIACH42 ***************",-1) From GESECRAN
        Call UTI_MOUL([F:ADS]DOSSIER) From UTIACH42  # Issue 114047 - 2016-03-10 by CCC : Change in overhead setting for products
    Else
        Call ECR_TRACE("Historic folder migration => UTIACH42 not executed",0) From GESECRAN
    Endif
Endif

###########################################
# MODUL Manufacturing
############################################

Call ECR_TRACE("************** MAJ UTIGPA47 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
    If left$(WVERSION,3) = "1.7" & WPATCH < 13
        Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA47  # Issue 107012 - 2015-09-17 by BEEBE : Initialize ROUOPENUM = 0 for unexpected tracked OPs
    Endif
Else
    Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

Onerrgo
End


###################################################################################
###################################################################################
###################################################################################

$ERREUR
GERRDOS = errn
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Resume

