#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTI2018R08 UTI process for 2018R8 of X3
#
# ---------------------------------------------------------------------- #
#      moulinettes à passer en fin du patch de la 2017RX - passage de RX-1 vers RX
#
#      correction utility to be done at the end of the patch - move from RX-1 to RX
#
##########################################################################

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI2018R08 Processing") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC


End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
# -----------------------------------------------------------------    #
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#-------------------------------------------------------------#
# le test du dossier mère doit etre fait dans chaque uti.. pas ici
# Test of the mother folder must be done in each utixxx.. not HERE
#-------------------------------------------------------------#
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTI2018R08 (APPLI)

End

###################################################
Subprog EXE_UTI2018R08(LDOSSIER)
Value Char LDOSSIER

Call ECR_TRACE("START : UTI2018R08-Phase for folder "+LDOSSIER,0) From GESECRAN

#-------------------------------------------------------------#
# implementer ici l'appel de chaque uti necessaire
# le test du dossier mère doit etre fait dans chaque uti..
#
# implement here the call of each necessary uti
# Test of the mother folder must be done in each utixxx..
#
#-------------------------------------------------------------#

  # Issue X3-59028 - 2018-09-24 by CBO : New Acc Task (Mindo)
  If [F:ADS]MODULE(1) = 2
    Call PATCH(LDOSSIER) From UTIFIN001    # Journal Entry Transaction validation
    Call PATCH(LDOSSIER) From UTICPT201808001    #  Initialization of VATID Sequence Number
  Endif

# Issue X3-107160 - 2018-09-26 by JUSYN : responsive design change for NCS - combine screens into one - delete obsolete screens
  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTINCS201809001

    # Issue X3-111831 - 2018-10-08 by BAKHA : delete obsolete function GESNCS record
    Call PATCH(LDOSSIER) From UTINCS201810001

    # Issue X3-80591 - 2018-10-16 by BAKHA : delete views not needed
    Call PATCH(LDOSSIER) From UTINCS201807001

    # Issue X3-111831 - 2018-10-16 by STWIL : delete obsolete representations for NCS
    Call PATCH(LDOSSIER) From UTINCS201810002

    # Issue X3-112819 - 2018-10-17 by BAKHA : delete obsolete class for NCS
    Call PATCH(LDOSSIER) From UTINCS201810003

    # Issue X3-80591 - 2018-10-17 by BAKHA : update object NCSA
    Call PATCH(LDOSSIER) From UTINCS201810004

  Endif
  # End issue X3-107160

  #X3-102843 2018-09-26 by MJH : Populate empty product-site valuation methods with value for product category
  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTICST201808001
	Call PATCH(LDOSSIER) From UTITC201808001 #auto-update default reorder supplier and default back-to-back supplier ISSUE X3-88081 - 2018-10-12 By APL
  Endif

  # Issue X3-113123 - 2018-10-19 by CATUA : 1099-DIV box definition data values for 2018
  If [F:ADS]MODULE(1) = 2 Then
    Call PATCH(LDOSSIER) From UTIBOX201808001
  Endif

  # Issue X3-109061 - 2018-09-18 by CATUA : Initialize new weighing parameters and fields
  If [F:ADS]MODULE(7) = 2 Then
    Call PATCH(LDOSSIER) From UTIGPA201808001
  Endif

  # #Issue 107878 - 2018-10-03 by RBA change due to sequence display
  If [F:ADS]MODULE(5)=2
    Call PATCH(LDOSSIER) From SUBPTF
  Endif

  If [F:ADS]MODULE(9) = 2 Then
    Call PATCH(LDOSSIER) From UTIPJM201808001    # Issue X3-107733 - 2018-10-09 by FGR
  Endif

  # X3-110657 UTI2018R8 script update for entry transaction validation (LCC- 09/10/18)
  If [F:ADS]MODULE(11)=2
    Call PATCH(LDOSSIER) From SUBCMS #GESSRE #Service request
  Endif
  If [F:ADS]MODULE(4)=2
    Call PATCH(LDOSSIER) From SUBSLQ #GESSQH #Quotes
    Call PATCH(LDOSSIER) From SUBSLC #GESSOH #Orders
    Call PATCH(LDOSSIER) From SUBSLD #GESSDH #Deliveries
    Call PATCH(LDOSSIER) From SUBSLI #GESSIH #Invoices
    Call PATCH(LDOSSIER) From SUBSLO #GESSOR #Open orders
    Call PATCH(LDOSSIER) From UTIVEN201808001# Issue X3-86334 - 2018-10-19 by APL
 	Call PATCH(LDOSSIER) From UTIVEN201808002   # Issue X3-86343 - 2018-04-12 by FGR
 Endif
  # End X3-110657 UTI2018R8 script update for entry transaction validation (LCC- 09/10/18)

  # Issue X3-113733 (epic: 55934) - 2018-10-17 by STLIG : Validate 'grouping' entry transactions
  If [F:ADS]MODULE(8) = 2
    Call PATCH(LDOSSIER) From SUBMRL
  Endif

#  Call PATCH  (LDOSSIER) From UTIXXX

Call ECR_TRACE("END : UTI2018R08-Phase for folder "+LDOSSIER,0) From GESECRAN
#----- Fin du traitement -----#
$FIN_UTI2018R08
End

