#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "OK"          : Gosub OK
Endcase
Return

$OUVRE
Local Char GLOBEML(GLONEML)
Global Integer GLOBILINE

#Disabling the classic CUD operation - Hybrid development (ANOWRITE)
ANOWRITE = 1

#Read the data from the class and transfer to the mask (Default Values)
Global Instance I_ESSPASDET Using C_ESSPASDET

GLOBEML=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
GCURLEG = func DIVPAYE_SOA.GET_LEG_EMP(GLOBEML, 1) #Site level

#Manage Localisations
Call MANAGE_LOCALISATION("ESSPASDET") From DIVPAYE
Return


$DEBUT
Local Char EMPCODE (GLONEML)
EMPCODE=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")

#Filter child table on EMCODE
Gosub CHARGE_ALL

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSPASDETHIDE
Call SHOW_LEGACTCALLS From WESSPASDETSHOW

Return


$OK
Local Integer WORKFLOWTRIGGER
Local Integer NI,MY_STATUS
Local Integer WRKFLOW_STAT_PASDET

[L]WRKFLOW_STAT_PASDET     = [V]CST_ANOTDEFINED

#Trigger workflow
[L]WRKFLOW_STAT_PASDET = fmet I_ESSPASDET.EMP_WRKREQ(I_ESSPASDET.REFNUM,"EMPLOID","ESSPASDET","T","EMPLOIDPAS","IDRT")
If [L]WRKFLOW_STAT_PASDET <> [V]CST_AOK and [L]WRKFLOW_STAT_PASDET <> [V]CST_ANOTDEFINED
  Call RECOVERS_ERROR_IN_CLASSIC(I_ESSPASDET) From ESS_WRKFLOW_FUNC_HYBRID
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]WRKFLOW_STAT_PASDET <> [V]CST_AWARNING and [L]WRKFLOW_STAT_PASDET <> [V]CST_AINFO Then
    OK = 0
    Return
  Endif
Endif

If [L]WRKFLOW_STAT_PASDET = [V]CST_ANOTDEFINED
  GMESSAGE = mess(0016,10727,1)
  GERR = 2
  Return
Endif

If GMESSAGE = AVOID.ACHAR Then
  GMESSAGE= mess(11,10727,1)
Else
  GMESSAGE= mess(11,10727,1)+":"-GMESSAGE
Endif
GERR = 2
Return



$CHARGE_ALL
Local Integer MY_STATUS

#-------------------------------Hybrid----------------------------------#
nolign = 0

I_ESSPASDET = NewInstance C_ESSPASDET AllocGroup null
[L]MY_STATUS = fmet I_ESSPASDET.AREAD(EMPCODE)
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_ESSPASDET) From ESS_WRKFLOW_FUNC_HYBRID
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    Return
  Endif
Endif
#Transfer class
Gosub SET_ALL

[M:ESPDT]NBRPAS = nolign
#-------------------------------Hybrid----------------------------------#

Affzo [M:ESPDT]1-99
Return

$SET_ALL
Local Integer NI
If I_ESSPASDET.PASDET <> null
  For NI = 1 To maxtab(I_ESSPASDET.PASDET)
    If I_ESSPASDET.PASDET(NI) <> null and find(I_ESSPASDET.PASDET(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      SetInstance [M:ESPDT]10 With I_ESSPASDET.PASDET(NI)
    Endif
  Next
Endif
Return

Subprog UPDATE_ESSPASDET_PASDET(VNLINE)
Value Integer VNLINE
SetInstance [M:ESPDT]10 With I_ESSPASDET.PASDET(VNLINE)
Affzo [M:ESPDT]10

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSPASDETHIDE
Call SHOW_LEGACTCALLS From WESSPASDETSHOW

End


Subprog SHOW_ESSPASDET_PASDET(VNLINE)
Value Integer VNLINE

SetInstance [M:ESPDT]10 With I_ESSPASDET.PASDET(VNLINE)
[M:ESPDT]TCH_NUMLIG(nolign-1) = VNLINE   # Line index in the collection
End


Subprog C_NBRPAS
Local Integer ILINE,IRET
If status = 82 or status = 73 Then
# Insert line
  ILINE = fmet I_ESSPASDET.ADDLINE("PASDET", [V]CST_ALASTPOS)
  If ILINE <> [V]CST_ANOTDEFINED Then
    Call AM_TCH_NUMLIG(ILINE)
    Call SHOW_ESSPASDET_PASDET(ILINE)
    GLOBILINE = ILINE
  Else
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(I_ESSPASDET)
    GERR = 4
    mkstat = 2
    GOK = 1
    End
  Endif
  Affzo [M:ESPDT]10

  #Manage localisations
  Call HIDE_ACTIVITYFIELDS From WESSPASDETHIDE
  Call SHOW_LEGACTCALLS From WESSPASDETSHOW
Elsif status = 65 #or status = 71 Then
  If status = 65
    ILINE = [M:ESPDT]TCH_NUMLIG(nolign-1)
  Elsif status = 71
    ILINE = maxtab(I_ESSPASDET.PASDET)
  Endif
  # Delete a line
  IRET = fmet I_ESSPASDET.ADELLINE("PASDET", I_ESSPASDET.PASDET(ILINE).AORDER)
  If IRET = [V]CST_ANOTDEFINED Then
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(I_ESSPASDET)
    GOK = 0
    GERR = 1
    mkstat = 2
  Endif
Elsif status = 71 Then
  If GLOBILINE <> AVOID.AINT and [M:ESPDT]PASNUM(nolign-1)=AVOID.ACHAR
    # Delete a line
    IRET = fmet I_ESSPASDET.ADELLINE("PASDET", I_ESSPASDET.PASDET(GLOBILINE).AORDER)
    Raz GLOBILINE
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(I_ESSPASDET)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
Endif
End

Subprog AM_TCH_NUMLIG(VALEUR)
Variable Integer VALEUR
I_ESSPASDET.PASDET(VALEUR).TCH_NUMLIG = VALEUR
Call RECOVERS_ERROR_IN_CLASSIC(I_ESSPASDET.PASDET(VALEUR)) From ESS_WRKFLOW_FUNC_HYBRID
If GERR = 1 Then
  I_ESSPASDET.PASDET(VALEUR).TCH_NUMLIG = I_ESSPASDET.PASDET(VALEUR).snapshot.TCH_NUMLIG
  GERR = 1
  mkstat = 2
  End
Else
  Call UPDATE_ESSPASDET_PASDET(VALEUR)
Endif
End

Subprog AM_PASCRY(VALEUR)
Variable Char    VALEUR()
I_ESSPASDET.PASDET([M:ESPDT]TCH_NUMLIG(nolign-1)).PASCRY = VALEUR
Call RECOVERS_ERROR_IN_CLASSIC(I_ESSPASDET.PASDET([M:ESPDT]TCH_NUMLIG(nolign-1))) From ESS_WRKFLOW_FUNC_HYBRID
If GERR = 1 Then
