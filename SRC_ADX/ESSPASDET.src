Subprog AS_PASAMD(VALEUR)
Variable Integer VALEUR
If GCURLEG <> "BRI"
  If dim([M:ESPDT]PASAMD)>0 : Chgfmt [M:ESPDT]PASAMD With '-LA:1' : Endif
  If dim([M:ESPDT]PASDATAMD)>0 : Chgfmt [M:ESPDT]PASDATAMD With '-D:MM[/]DD[/]YYYY' : Endif
  If dim([M:ESPDT]PASDATNEW)>0 : Chgfmt [M:ESPDT]PASDATNEW With '-D:MM[/]DD[/]YYYY' : Endif
Endif
End

Subprog AS_PASDATNEW(VALEUR)
Variable Date    VALEUR
If GCURLEG <> "BRI"
