#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################################################
#    Epuration des tables de Coûts                # Issue 90275 GA 07/2013      #
# Formule d'épuration MFG :      MFGSTA = 4 & MFGTRKFLG = 6                     #
# Formule d'épuration SCO :      SCOSTA = 4 & SCOTRKFLG = 6                     #
# ------------------------------------------------------------------------------#
#################################################################################

#-------------------------------------------------------------------------------#
#    Ouvertures des fichiers complémentaires                                    #
#-------------------------------------------------------------------------------#
$OUVRE_EPU_CST
If HISTO
    If OKEPU=0
      #-- Historisation
           If clalev([F:MWH])=0 : Local File =[L]APPLI+".MFGWIP"      [MWH] : Endif
           If clalev([F:MWI])=0 : Local File =[L]APPLI+".WIPCOST"     [MWI] : Endif
           If clalev([F:MFC])=0 : Local File =[L]APPLI+".MFGCOST"     [MFC] : Endif
           If clalev([F:MCN])=0 : Local File =[L]APPLI+".MFCNAT"      [MCN] : Endif
           If clalev([F:MCC])=0 : Local File =[L]APPLI+".MFCMAT"      [MCC] : Endif
           If clalev([F:MCW])=0 : Local File =[L]APPLI+".MFCWST"      [MCW] : Endif
           #-----------------------#
           # Fichier historisation #
           #-----------------------#
          #----- Issue 90275 GA 07/2013 Historiser MFGWIP
            If filinfo(filpath("FIL","MFGWIP","fde",HISAPL),0)<0
              OK=1
            Else
              Call VUE_OK("MFGWIP",HISAPL,"FIL",OK) From DOSVUE
            Endif
            If OK
              TABLE="MFGWIP"  : Gosub CRETAB_HISTO
              If OK=0 : OKHIS=0 : OKEPU=0 : Return : Endif
            Endif
            If clalev([F:MWH1])=0 : Local File =[L]HISAPL+".MFGWIP" [MWH1] : Endif
          #----- Issue 90275 GA 07/2013 Historiser MFGCOST
            If filinfo(filpath("FIL","WIPCOST","fde",HISAPL),0)<0
              OK=1
            Else
              Call VUE_OK("WIPCOST",HISAPL,"FIL",OK) From DOSVUE
            Endif
            If OK
              TABLE="WIPCOST"  : Gosub CRETAB_HISTO
              If OK=0 : OKHIS=0 : OKEPU=0 : Return : Endif
            Endif
            If clalev([F:MWI1])=0 : Local File =[L]HISAPL+".WIPCOST" [MWI1] : Endif
          #----- Issue 90275 GA 07/2013 Historiser MFGCOST
            If filinfo(filpath("FIL","MFGCOST","fde",HISAPL),0)<0
              OK=1
            Else
              Call VUE_OK("MFGCOST",HISAPL,"FIL",OK) From DOSVUE
            Endif
            If OK
              TABLE="MFGCOST"  : Gosub CRETAB_HISTO
              If OK=0 : OKHIS=0 : OKEPU=0 : Return : Endif
            Endif
            If clalev([F:MFC1])=0 : Local File =[L]HISAPL+".MFGCOST" [MFC1] : Endif
          #----- Issue 90275 GA 07/2013 Historiser MFCNAT
            If filinfo(filpath("FIL","MFCNAT","fde",HISAPL),0)<0
              OK=1
            Else
              Call VUE_OK("MFCNAT",HISAPL,"FIL",OK) From DOSVUE
            Endif
            If OK
              TABLE="MFCNAT"  : Gosub CRETAB_HISTO
              If OK=0 : OKHIS=0 : OKEPU=0 : Return : Endif
            Endif
            If clalev([F:MCN1])=0 : Local File =[L]HISAPL+".MFCNAT" [MCN1] : Endif
          #----- Issue 90275 GA 07/2013 Historiser MFCMAT
            If filinfo(filpath("FIL","MFCMAT","fde",HISAPL),0)<0
              OK=1
            Else
              Call VUE_OK("MFCMAT",HISAPL,"FIL",OK) From DOSVUE
            Endif
            If OK
              TABLE="MFCMAT"  : Gosub CRETAB_HISTO
              If OK=0 : OKHIS=0 : OKEPU=0 : Return : Endif
            Endif
            If clalev([F:MCC1])=0 : Local File =[L]HISAPL+".MFCMAT" [MCC1] : Endif
          #----- Issue 90275 GA 07/2013 Historiser MFCWST
            If filinfo(filpath("FIL","MFCWST","fde",HISAPL),0)<0
              OK=1
            Else
              Call VUE_OK("MFCWST",HISAPL,"FIL",OK) From DOSVUE
            Endif
            If OK
              TABLE="MFCWST"  : Gosub CRETAB_HISTO
              If OK=0 : OKHIS=0 : OKEPU=0 : Return : Endif
            Endif
            If clalev([F:MCW1])=0 : Local File =[L]HISAPL+".MFCWST" [MCW1] : Endif
    Else
     #-- Epuration après historisation
           If clalev([F:MWH])=0 : Local File =[L]HISAPL+".MFGWIP"      [MWH] : Endif
           If clalev([F:MWI])=0 : Local File =[L]HISAPL+".MFGCOST"     [MWI] : Endif
           If clalev([F:MFC])=0 : Local File =[L]HISAPL+".MFGCOST"     [MFC] : Endif
           If clalev([F:MCN])=0 : Local File =[L]HISAPL+".MFCNAT"      [MCN] : Endif
           If clalev([F:MCC])=0 : Local File =[L]HISAPL+".MFCMAT"      [MCC] : Endif
           If clalev([F:MCW])=0 : Local File =[L]HISAPL+".MFCWST"      [MCW] : Endif
    Endif
Else
   #-- Epuration seule
    If clalev([F:MWH])=0 : Local File =[L]APPLI+".MFGWIP"      [MWH] : Endif
    If clalev([F:MWI])=0 : Local File =[L]APPLI+".MFGCOST"     [MWI] : Endif
    If clalev([F:MFC])=0 : Local File =[L]APPLI+".MFGCOST"     [MFC] : Endif
    If clalev([F:MCN])=0 : Local File =[L]APPLI+".MFCNAT"      [MCN] : Endif
    If clalev([F:MCC])=0 : Local File =[L]APPLI+".MFCMAT"      [MCC] : Endif
    If clalev([F:MCW])=0 : Local File =[L]APPLI+".MFCWST"      [MCW] : Endif
Endif
Return

#-------------------------------------------------------------------------------#
#    Traitements liés à l'épuration des couts d'un OF ou d'un EO                #
#[L]WVCRTYP=10 : [L]WVCRNUM=[F:F1]MFGNUM appel depuis EPURGPA
#[L]WVCRTYP=36 : [L]WVCRNUM=[F:F1]SCONUM appel depuis EPURPEO
#-------------------------------------------------------------------------------#
$EPURE_CST
If dim(WVCRTYP)<=0 | dim(WVCRNUM)<=0       Return Endif
If !find([L]WVCRTYP,10,36) | [L]WVCRNUM="" Return Endif

Gosub EPURE_CST_MWI
If WOK=0 : Return : Endif
Gosub EPURE_CST_MWH
If WOK=0 : Return : Endif
Gosub EPURE_CST_MFC
If WOK=0 : Return : Endif
Gosub EPURE_CST_MCN
If WOK=0 : Return : Endif
Gosub EPURE_CST_MCC
If WOK=0 : Return : Endif
Gosub EPURE_CST_MCW
If WOK=0 : Return : Endif

Return

$FERME_EPU_CST
If clalev([F:MWH]) : Close Local File  [MWH] : Endif
If clalev([F:MWI]) : Close Local File  [MWI] : Endif
If clalev([F:MFC]) : Close Local File  [MFC] : Endif
If clalev([F:MCN]) : Close Local File  [MCN] : Endif
If clalev([F:MCC]) : Close Local File  [MCC] : Endif
If clalev([F:MCW]) : Close Local File  [MCW] : Endif
#
If clalev([F:MWH1]) : Close Local File  [MWH1] : Endif
If clalev([F:MWI1]) : Close Local File  [MWI1] : Endif
If clalev([F:MFC1]) : Close Local File  [MFC1] : Endif
If clalev([F:MCN1]) : Close Local File  [MCN1] : Endif
If clalev([F:MCC1]) : Close Local File  [MCC1] : Endif
If clalev([F:MCW1]) : Close Local File  [MCW1] : Endif
Return

#########################################################
$CRETAB_HISTO
#--- Création des tables non liées
NEWTAB = TABLE
Call CRETABLE(APPLI,HISAPL,TYPDBA,NEWTAB,COEFF,1) From CREHISTO
Return

#########################################################
$EPURE_CST_MWI
#----- Historisation MFGCOST -----#
Raz WNBLNK
If OKHIS
  Filter [MWI] Where VCRTYP=[L]WVCRTYP & VCRNUM=[L]WVCRNUM
  For [MWI]
    If ![L]SIMUL
      [F:MWI1]=[F:MWI]
      If dim([F:MWI1]CREHISDAT)>0  [F:MWI1]CREHISDAT=date$    : Endif
      If dim([F:MWI1]CREHISUSR)>0  [F:MWI1]CREHISUSR=[V]GUSER : Endif
      Write [MWI1]
      If fstat
        Call ECR_TRACE("$WIPCOST"-[L]WVCRNUM-mess(13,100,1),1) From GESECRAN
        WOK=0 #: Return
        Break
      Endif
    Endif
    WNBLNK += 1
  Next
  Filter [MWI]
Endif
If WOK=0 : Return : Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [MWI] Where VCRTYP=[L]WVCRTYP
&                  & VCRNUM=[L]WVCRNUM
  If fstat
    Call ECR_TRACE("$WIPCOST"-[L]WVCRNUM-mess(13,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- WIPCOST"-[L]WVCRNUM-"("+num$(WNBLNK)+")",0) From GESECRAN
Endif
#-----
Return
