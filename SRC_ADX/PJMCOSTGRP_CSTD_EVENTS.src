#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMCOSTGRP
# Issue X3-26712 - 2017-05-19 by ALMON/FGR
###################################################################################################
$ACONTROL
  [L]ASTATUS = [V]CST_AOK
  # ---------------------------------------
  Case this.PCGTYP
    When 1
      If this.PCGGRPMAT = 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPMAT", mess(546,2260,1), [V]CST_AERROR))
      Endif
      If this.PCGGRPLAB <> 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPLAB", mess(18,9804,1), [V]CST_AERROR))
      Endif
      If this.PCGGRPMAC <> 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPMAC", mess(18,9804,1), [V]CST_AERROR))
      Endif
    When 2
      If this.PCGGRPMAT <> 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPMAT", mess(18,9804,1), [V]CST_AERROR))
      Endif
      If this.PCGGRPLAB = 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPLAB", mess(546,2260,1), [V]CST_AERROR))
      Endif
      If this.PCGGRPMAC <> 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPMAC", mess(18,9804,1), [V]CST_AERROR))
      Endif
    When 3
      If this.PCGGRPMAT <> 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPMAT", mess(18,9804,1), [V]CST_AERROR))
      Endif
      If this.PCGGRPLAB <> 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPLAB", mess(18,9804,1), [V]CST_AERROR))
      Endif
      If this.PCGGRPMAC = 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPMAC", mess(546,2260,1), [V]CST_AERROR))
      Endif
  Endcase
Return

