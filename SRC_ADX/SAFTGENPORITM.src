#<AdxTL>@(#)0.0.0.0 $Revision$
$PRODUCTS
Local Integer EXCITM : [L]EXCITM=0

For [F:ITM]
   #Entry point used to exclude an item from export
   [L]EXCITM    = 0
   GPOINT  = "SAFTPTITM" : Gosub ENTREE From EXEFNC
   If [L]EXCITM = 1 : Goto NEXTITM : Endif

   Gosub RAZ_ITT From SAFTGENPOR

   #Issue X3-31864 QUESTION – 2017-04-06  by MANOW
   Case [F:ITM]ITMSFTTYP
     When 2
       [L]ITTITMTYPE = "P"
     When 3
       [L]ITTITMTYPE = "S"
     When 4
       [L]ITTITMTYPE = "O"
     When Default
       [L]ITTITMTYPE = "O"
   Endcase
   If [F:ITM]ITMREF = "IEC" : [L]ITTITMTYPE = "E" : Endif
   #Issue X3-31864 QUESTION end

   [L]ITTITMCODE = [F:ITM]ITMREF
   #Issue X3-31864 – 2017-04-25  by MANOW/MRDAB
   [L]ITTITMCNCODE = [F:ITM]CUSREF
   [L]ITTITMUNNUM  = [F:ITM]UNNBR
   #End issue X3-31864
   [L]ITTITMGROU = [F:ITM]TSICOD(val([L]SAFTPGROU)-1)

   #VAVIL
   # Issue X3-99026 by MRDAB
   Call LECTEXTRA_POR([L]ITTITMDESC,"ITMMASTER","DES1AXX", [F:ITM]ITMREF,"") From SAFTGENPOR
   # Issue X3-99026 end
   #[L]ITTITMDESC = [F:ITM]ITMDES1
   If [F:ITM]EANCOD<>""
     [L]ITTITMNUMC = [F:ITM]EANCOD
   Else
     [L]ITTITMNUMC = [F:ITM]ITMREF
   Endif

   Gosub WRITE_ITM

$NEXTITM
Next

Gosub ITM_DIV

Return
#######################################################################################
#######################################################################################
$ITM_DIV

[L]ITTITMTYPE = "O"
[L]ITTITMCODE = "TERC_OUTRO"
[L]ITTITMGROU = "Terceiros"
[L]ITTITMDESC = "Outros Diversos"
[L]ITTITMNUMC = "TERC_OUTRO"

Gosub WRITE_ITM

[L]ITTITMTYPE = "P"
[L]ITTITMCODE = "TERC_PROD"
[L]ITTITMGROU = "Terceiros"
[L]ITTITMDESC = "Productos Diversos"
[L]ITTITMNUMC = "TERC_PROD"

Gosub WRITE_ITM

[L]ITTITMTYPE = "S"
[L]ITTITMCODE = "TERC_SERV"
[L]ITTITMGROU = "Terceiros"
[L]ITTITMDESC = "Serviços Diversos"
[L]ITTITMNUMC = "TERC_SERV"

Gosub WRITE_ITM

[L]ITTITMTYPE = "O"
[L]ITTITMCODE = "ELEMFACT"
[L]ITTITMGROU = "Elementos de Facturação"
[L]ITTITMDESC = "Elementos de Facturação"
[L]ITTITMNUMC = "ELEMFACT"

Gosub WRITE_ITM

If [L]OTHIMP = 1
  [L]ITTITMTYPE = "I"
  [L]ITTITMCODE = "IMPOSTO"
  [L]ITTITMGROU = "Impostos, taxas e encargos parafiscais"
  [L]ITTITMDESC = "Impostos, taxas e encargos parafiscais"
  [L]ITTITMNUMC = "IMPOSTO"
  Gosub WRITE_ITM
Endif

#Issue 31864 – 2017-04-26  by MANOW
#IEC's
#If [L]ISSAFTVERCURRENT = 1
  If [L]OTHIMP = 1
    Look [F:ITM]ITM0 = "IEC"
    If fstat
      [L]ITTITMTYPE = "E"
      [L]ITTITMCODE = "IEC"
      [L]ITTITMGROU = "Impostos especiais de consumo"
      [L]ITTITMDESC = "Impostos especiais de consumo"
      [L]ITTITMNUMC = "IEC"
      Gosub WRITE_ITM
    Endif
  Endif
#Endif
#Issue 31864 end

Return
#######################################################################################
#######################################################################################
$WRITE_ITM

Wrseq '<Product>' Using [SAFT]
AUXTAGNAM = 'ProductType'           : AUXTAGVAL = [L]ITTITMTYPE : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'ProductCode'           : AUXTAGVAL = [L]ITTITMCODE : Gosub WRITETAG From SAFTGENPORTG
If ITTITMGROU<> ""
  AUXTAGNAM = 'ProductGroup' : AUXTAGVAL = [L]ITTITMGROU : Gosub WRITETAG From SAFTGENPORTG
Endif
AUXTAGNAM = 'ProductDescription'    : AUXTAGVAL = [L]ITTITMDESC : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'ProductNumberCode'     : AUXTAGVAL = [L]ITTITMNUMC : Gosub WRITETAG From SAFTGENPORTG

#Issue X3-31864 – 2017-04-06  by MANOW
If [L]ISSAFTVERCURRENT = 1
  Wrseq '<CustomsDetails>' Using [SAFT]
  If [L]ITTITMCNCODE <> ""
    AUXTAGNAM = 'CNCode'            : AUXTAGVAL = [L]ITTITMCNCODE   : Gosub WRITETAG From SAFTGENPORTG
  Endif
  If [L]ITTITMUNNUM <> ""
    AUXTAGNAM = 'UNNumber'              : AUXTAGVAL = [L]ITTITMUNNUM    : Gosub WRITETAG From SAFTGENPORTG
  Endif
  Wrseq '</CustomsDetails>' Using [SAFT]
Endif
#End issue X3-31864

Wrseq '</Product>' Using [SAFT]
[L]RECSWRI += 1
Return

