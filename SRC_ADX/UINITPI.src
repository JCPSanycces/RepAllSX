#<AdxTL>@(#)5.0.0.0 $Revision$
#################################################################
# Gbn - Initialisation de la table TYPACEINT.                   #
# 250608-Fq 48256                                               #
#################################################################
If 1=0
 Gosub GEN_UWINITPI
Endif

If 1=1
 Call OUVRE_TRACE("Test traitement d'initialisation de la table TYPACEINT") From LECFIC
 #Call PATCH("ABEIND150")
 Call PATCH(nomap)
 Call LEC_TRACE() From LECFIC
Endif

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PAPPLI)
Value Char    PAPPLI

If filinfo(filpath("FIL","TYPACE","fde",PAPPLI),0)<=0 |
&  filinfo(filpath("FIL","TYPACEINT","fde",PAPPLI),0)<=0
      End
Else
    Gosub INIT_TYPACEINT
Endif

End

#######################################################################

Subprog PATCH(PAPPLI)
Value Char PAPPLI

 If filinfo(filpath("FIL","TYPACE","fde",PAPPLI),0)<=0 |
&   filinfo(filpath("FIL","TYPACEINT","fde",PAPPLI),0)<=0
      End
 Else
     Gosub INIT_TYPACEINT
 Endif

End

#-------------------------------------------------
$INIT_TYPACEINT
 
 #> Réduction de la taille de l'écran TPE0 pour le transformer en écran en-tête

 If !clalev([F:AMK]) : Local File =PAPPLI+".AMSK"        [AMK] : Endif
 If !clalev([F:ADS]) : Local File =adxmother+".ADOSSIER" [ADS] : Endif
 Local Integer OK
 Trbegin [F:AMK]
 Read [F:AMK]CODMSK="TPE0"
 If fstat
  GOK=0
  Call ECR_TRACE("UINITPI Read [F:AMK] fstat"-num$(fstat),1) From GESECRAN  
 Else
  [F:AMK]NBRLIG=4
  Rewrite [F:AMK]
  If fstat
   GOK=0
   Call ECR_TRACE("UINITPI Rewrite [F:AMK] fstat"-num$(fstat),1) From GESECRAN  
  Else
   If [F:ADS]DOSSIER<>PAPPLI
    Read [F:ADS]DOSSIER=PAPPLI
   Endif
   Call VALID("TPE0",PAPPLI,[F:ADS]NBRLAN,[F:ADS]LAN,0,OK) From VALMSK
  Endif 
 Endif
 If GOK
  Commit
 Else
  Rollback
 Endif

 #> Initialisation de la table TYPACEINT

 Call ECR_TRACE("Init TYPACEINT Table (UINITPI / UWINITPI)",0) From GESECRAN
 If PAPPLI = adxmother 
  Gosub MAJDOS_RACINE 
 Endif
 If PAPPLI<> adxmother & nomap=adxmother 
  Gosub MAJDOS_AUTRE
 Endif

Return

#-------------------------------------------------
# Initialisation de la table TYPACEINT pour le
# dossier racine
#-------------------------------------------------
$MAJDOS_RACINE
 Local Char    LABUWINITPI
 Local Integer OK
 Gosub DEF_STDACETYP
 If !clalev([F:TPE]) : Local File =adxmother+".TYPACE"    [TPE] : Endif
 If !clalev([F:TPI]) : Local File =adxmother+".TYPACEINT" [TPI] : Endif
 If !clalev([M:TPE0]): Local Mask TPE0     [TPE0] : Endif
 If !clalev([M:TPE1]): Local Mask TPE1     [TPE1] : Endif
 If !clalev([M:TPE9]): Local Mask TPE9     [TPE9] : Endif
 Trbegin [F:TPE], [F:TPI] 
 For [F:TPE] 
  If find([F:TPE]ACETYP,STDTYPACE)
   Gosub TRT_STDTYPACE
   If !GOK : Break : Endif
  Endif
 Next 
 If GOK
  Commit
 Else
  Rollback
 Endif
Return

#-------------------------------------------------
# Initialisation de la table TYPACEINT pour un 
# dossier applicatif (autre que dossier racine)
#-------------------------------------------------
$MAJDOS_AUTRE
 If !clalev([F:TPE]) : Local File =PAPPLI+".TYPACE"      [TPE]  : Endif
 If !clalev([F:RTPE]): Local File =PAPPLI+".TYPACE"      [RTPE] : Endif
 If !clalev([F:MTPE]): Local File =adxmother+".TYPACE"   [MTPE] : Endif
 If !clalev([F:TPI]) : Local File =PAPPLI+".TYPACEINT"   [TPI]  : Endif
 If !clalev([M:TPE0]): Local Mask TPE0     [TPE0] : Endif
 If !clalev([M:TPE1]): Local Mask TPE1     [TPE1] : Endif
 If !clalev([M:TPE9]): Local Mask TPE9     [TPE9] : Endif
 Gosub DEF_STDACETYP
 Trbegin [F:TPE], [F:TPI] 
 For [F:TPE]
  If find([F:TPE]ACETYP,STDTYPACE)
   Gosub TRT_STDTYPACE
   If !GOK : Break : Endif
  Else
   Gosub TRT_SPETYPACE
   If !GOK : Break : Endif   
  Endif
 Next
 If GOK
  Commit
 Else
  Rollback
 Endif
Return

#-------------------------------------------------
$TRT_STDTYPACE
   [M:TPE0]=[F:TPE]
   [M:TPE1]=[F:TPE]
   Raz [M:TPE9]
   #> Alimentation du nom de traitement 
   Gosub SET_TPE9 From SUBTPE
   Case [F:TPE]ACETYP 
    When "CSAMT" : [M:TPE9]TRTINT="GWDEP0100001"  
    When "CSBVA" : [M:TPE9]TRTINT="GWE290100001"   
    When "CSDCP" : [M:TPE9]TRTINT="GWE010100001"   
    When "CSDPR" : [M:TPE9]TRTINT="GWE250100001"   
    When "CSDVA" : [M:TPE9]TRTINT="GWE020100001"   
    When "CSREV" : [M:TPE9]TRTINT="GWE280100001"   
    When "CSSOR" : [M:TPE9]TRTINT="GWE260100001"   
    When "CSVIR" : [M:TPE9]TRTINT="GWE230100001"   
    When "GSCRB" : [M:TPE9]TRTINT="GWE630100001"   
    When "GSCRT" : [M:TPE9]TRTINT="GWE620100001"   
    When "GSCSH" : [M:TPE9]TRTINT="GWE610100001"   
    When "LSPAY" : [M:TPE9]TRTINT="GWE440100001"   
    When "CCAMT" : [M:TPE9]TRTINT="GWDEP0600001"   
    When "CCBVA" : [M:TPE9]TRTINT="GWE290600001"   
    When "CCDCP" : [M:TPE9]TRTINT="GWE010600001"   
    When "CCDPR" : [M:TPE9]TRTINT="GWE250600001"   
    When "CCDVA" : [M:TPE9]TRTINT="GWE020600001"   
    When "CCREV" : [M:TPE9]TRTINT="GWE280600001"   
    When "CCSOR" : [M:TPE9]TRTINT="GWE260600001"   
    When "CCVIR" : [M:TPE9]TRTINT="GWE230600001"   
    When "GCCRB" : [M:TPE9]TRTINT="GWE630600001"   
    When "GCCRT" : [M:TPE9]TRTINT="GWE620600001"   
    When "GCCSH" : [M:TPE9]TRTINT="GWE610600001"   
    When "LCACT" : [M:TPE9]TRTINT="GWE410600001"   
    When "LCCRT" : [M:TPE9]TRTINT="GWE420600001"   
    When "LCPAY" : [M:TPE9]TRTINT="GWE440600001"   
    When "LCRPU" : [M:TPE9]TRTINT="GWE450600001"   
    When "LCTRM" : [M:TPE9]TRTINT="GWE460600001"   
    When Default   
   Endcase
   [F:TPE]TRTINT=[M:TPE9]TRTINT
   LABUWINITPI=[F:TPE]ACETYP
   Gosub AIGUILLAGE   From UWINITPI
   Gosub MAJ_TPI      From SUBTPE
   Gosub MAJ_TRTINT   From SUBTPE
   Gosub VALID_TRTINT From SUBTPE
   Rewrite [F:TPE] Curr
   If fstat
    GOK=0
    Call ECR_TRACE(space$(5)+[F:TPE]ACETYP-"UINITPI (I) Rewrite [F:TPE] fstat"-num$(fstat),1) From GESECRAN
   Else
    Call ECR_TRACE(space$(5)+[F:TPE]ACETYP-"update OK",0) From GESECRAN
   Endif
Return

#-------------------------------------------------
$TRT_SPETYPACE
  Local Integer OK      : OK=1
  Local Integer LSRCTYP : LSRCTYP=[F:TPE]SRCTYP
  Local Char    LTABCPT : LTABCPT=[F:TPE]TABCPT
  Local Integer LDPRPLN : LDPRPLN=[F:TPE]DPRPLN
  [M:TPE0]=[F:TPE]
  [M:TPE1]=[F:TPE]
  Raz [M:TPE9]
  Gosub SET_TPE9     From SUBTPE
  Gosub B1_NBLIG
  If !OK : Return : Endif
  Gosub MAJ_TPI      From SUBTPE
  If find([F:TPE]ACETYP,STDTYPACE)
   Read [F:MTPE]TPE0=[F:TPE]ACETYP
   [M:TPE9]TRTINT=[F:MTPE]TRTINT
  Else 
   Gosub DEF_TRTINT   From SUBTPE 
  Endif
  [F:TPE]TRTINT=[M:TPE9]TRTINT
  Gosub MAJ_TRTINT   From SUBTPE
  Gosub VALID_TRTINT From SUBTPE
  Rewrite [F:TPE] Curr
  If fstat
   GOK=0
   Call ECR_TRACE("UINITPI (II) Rewrite [F:TPE] fstat"-num$(fstat),1) From GESECRAN
  Else
   Call ECR_TRACE(space$(5)+[F:TPE]ACETYP-"update OK",0) From GESECRAN   
  Endif
Return

#-------------------------------------------------
B1_NBLIG
 Local Integer I_FLD
 Local Char ACETYPMOD, ACETYPEVT, ACETYPPREF, ACETYPREFER

 If [M:TPE1]SRCTYP=2
  If [M:TPE1]DPRPLN=G301CPT : ACETYPMOD="CSAMT" : Endif
  If [M:TPE1]DPRPLN=G301IAS : ACETYPMOD="CCAMT" : Endif
 Endif
 If [M:TPE1]SRCTYP=1
  Case [M:TPE1]EVTTYP 
   When "FASVATREG"  : ACETYPEVT="BVA" : ACETYPPREF="C"
   When "LOFCIM"     : ACETYPEVT="DCP" : ACETYPPREF="C"
   When "FASIML"     : ACETYPEVT="DPR" : ACETYPPREF="C"
   When "LOFVATREG"  : ACETYPEVT="DVA" : ACETYPPREF="C"
   When "FASREEVAL"  : ACETYPEVT="REV" : ACETYPPREF="C"
   When "FASISS"     : ACETYPEVT="SOR" : ACETYPPREF="C"
   When "FASCHGIMP"  : ACETYPEVT="VIR" : ACETYPPREF="C"
   When "GRTCRB"     : ACETYPEVT="CRB" : ACETYPPREF="G"
   When "GRTCRT"     : ACETYPEVT="CRT" : ACETYPPREF="G"
   When "GRTCASH"    : ACETYPEVT="CSH" : ACETYPPREF="G"
   When "LEAPAY"     : ACETYPEVT="DCP" : ACETYPPREF="L"
   When "LEAACTU"    : ACETYPEVT="ACT" : ACETYPPREF="L"
   When "LEACRT"     : ACETYPEVT="CRT" : ACETYPPREF="L"
   When "LEARPU"     : ACETYPEVT="RPU" : ACETYPPREF="L"
   When "LEATRM"     : ACETYPEVT="TRM" : ACETYPPREF="L"
  Endcase
  If [M:TPE1]DPRPLN=G301CPT
   ACETYPREFER="S"
   ACETYPMOD=ACETYPPREF+ACETYPREFER+ACETYPEVT
  Elsif [M:TPE1]DPRPLN=G301IAS
   ACETYPREFER="C"
   ACETYPMOD=ACETYPPREF+ACETYPREFER+ACETYPEVT
  Else
   ACETYPMOD=""
  Endif
 Endif

 If ACETYPMOD<>""
  If PAPPLI<>adxmother
   If !clalev([F:RTPI]) : Local File =adxmother+".TYPACEINT" [RTPI] : Endif
  Else
   If !clalev([F:RTPI]) : Local File TYPACEINT [RTPI] : Endif
  Endif
  For I_FLD=1 To [M:TPE9]NBLIG
   Read [F:RTPI]TPI0=ACETYPMOD;[M:TPE9]TMPFLD(I_FLD-1);[M:TPE9]TMPIND(I_FLD-1)
   If !fstat
    [M:TPE9]ENALIG(I_FLD-1)=[F:RTPI]ENALIG
    [M:TPE9]ORICND(I_FLD-1)=[F:RTPI]ORICND
    [M:TPE9]ORITAB(I_FLD-1)=[F:RTPI]ORITAB
    [M:TPE9]ORIFLD(I_FLD-1)=[F:RTPI]ORIFLD
    [M:TPE9]ORIEXP(I_FLD-1)=[F:RTPI]ORIEXP
   Endif
  Next I_FLD
  Affzo [M:TPE9]
 Else
  Call ECR_TRACE(space$(5)+[F:TPE]ACETYP-"No standard model found for the ACETYPINT table init.",1) From GESECRAN
  OK=0
 Endif

Return

#-------------------------------------------------
# Génération du traitement d'initialisation 
# de la table TYPACEINT pour les types d'écriture
# standards.
#-------------------------------------------------
$GEN_UWINITPI

 Gosub DEF_STDACETYP

 If !clalev([F:TPE]) : Local File TYPACE    [TPE] : Endif
 If !clalev([F:TPI]) : Local File TYPACEINT [TPI] : Endif
 If !clalev([M:TPE9]): Local Mask TPE9     [TPE9] : Endif 

 Local Char    NOMTRT
 Local Char    FICSRC(250)
 Local Integer I_FLD
 Local Char    LIGNE(110)
 Local Char    LDECAL

 NOMTRT = "UWINITPI"
 FICSRC = filpath("TRT",NOMTRT,"src",nomap)
 Openo FICSRC,0
 adxifs = ""
 adxirs = chr$(10)

 #> En-tête
 #  -------

 Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
 Wrseq '# MODIFIE PAR :'-GUSER
 Wrseq '# LE          :'-format$("DD4",date$)
 Wrseq ''
 Wrseq '$AIGUILLAGE'
 Wrseq ' Case LABUWINITPI'
 For [F:TPE]
  If find([F:TPE]ACETYP,STDTYPACE)
   Wrseq '  When "'+[F:TPE]ACETYP+'" : Gosub FILTPE9_'+[F:TPE]ACETYP
  Endif
 Next 
 Wrseq ' Endcase'
 Wrseq 'Return'
 Wrseq ''
 For [F:TPE]
  If find([F:TPE]ACETYP,STDTYPACE)
   Wrseq '$FILTPE9_'+[F:TPE]ACETYP
   Wrseq ' Local Integer I_FLD'
   Wrseq ' For I_FLD=1 To [M:TPE9]NBLIG'
   For [F:TPI] Where ACETYP=[F:TPE]ACETYP & ENALIG=G_OUI
    Wrseq '  If [M:TPE9]TMPFLD(I_FLD-1)="'+[F:TPI]TMPFLD+'" & [M:TPE9]TMPIND(I_FLD-1)='+num$([F:TPI]TMPIND)
    If [F:TPI]ORICND<>"" : Wrseq '   [M:TPE9]ORICND(I_FLD-1)="'+[F:TPI]ORICND+'"' : Endif
    If [F:TPI]ORITAB<>"" : Wrseq '   [M:TPE9]ORITAB(I_FLD-1)="'+[F:TPI]ORITAB+'"' : Endif
    If [F:TPI]ORIFLD<>"" : Wrseq '   [M:TPE9]ORIFLD(I_FLD-1)="'+[F:TPI]ORIFLD+'"' : Endif
    If [F:TPI]ORIEXP<>"" : Wrseq '   [M:TPE9]ORIEXP(I_FLD-1)="'+[F:TPI]ORIEXP+'"' : Endif
    Wrseq '   [M:TPE9]ENALIG(I_FLD-1)=G_OUI'
    Wrseq '  Endif' 
   Next
   Wrseq ' Next I_FLD'
   Wrseq 'Return'
   Wrseq ''
  Endif
 Next


 #> Fin de la génération du fichier source
 #  --------------------------------------

 Openo
 
Return

#-------------------------------------------------
# Liste des type d'écriture standards
#-------------------------------------------------
$DEF_STDACETYP
 Local Char STDTYPACE(15)(1..28)
  
 STDTYPACE(01)="CSAMT"
 STDTYPACE(02)="CSBVA"
 STDTYPACE(03)="CSDCP"
 STDTYPACE(04)="CSDPR"
 STDTYPACE(05)="CSDVA"
 STDTYPACE(06)="CSREV"
 STDTYPACE(07)="CSSOR"
 STDTYPACE(08)="CSVIR"
 STDTYPACE(09)="GSCRB"
 STDTYPACE(10)="GSCRT"
 STDTYPACE(11)="GSCSH"
 STDTYPACE(12)="LSPAY"
 STDTYPACE(13)="CCAMT"
 STDTYPACE(14)="CCBVA"
 STDTYPACE(15)="CCDCP"
 STDTYPACE(16)="CCDPR"
 STDTYPACE(17)="CCDVA"
 STDTYPACE(18)="CCREV"
 STDTYPACE(19)="CCSOR"
 STDTYPACE(20)="CCVIR"
 STDTYPACE(21)="GCCRB"
 STDTYPACE(22)="GCCRT"
 STDTYPACE(23)="GCCSH"
 STDTYPACE(24)="LCACT"
 STDTYPACE(25)="LCCRT"
 STDTYPACE(26)="LCPAY"
 STDTYPACE(27)="LCRPU"
 STDTYPACE(28)="LCTRM" 
Return



