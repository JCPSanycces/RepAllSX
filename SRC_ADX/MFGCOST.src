#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
    When "INIPAR" : Gosub INIPAR
    When "CONT1"  : Gosub CONT1
    When "CONT2"  : Gosub CONT2
Endcase
Return

$INIPAR
    If [M:RPT]PARCOD(nolign-1)="mfctypdeb" & dim([M:DIA]MFCTYP)>0
        VALEUR = [M:DIA]MFCTYP
        [M]VALEUR1(nolign-1) = VALEUR
        Call CHARGE([M]VALEUR1(nolign-1),[M]PARTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINT1(nolign-1)) From FMTVAR
        Affzo [M:RPT]
    Endif
    If [M:RPT]PARCOD(nolign-1)="mfctypfin" & dim([M:DIA]MFCTYP)>0
        VALEUR = [M:DIA]MFCTYP
        [M]VALEUR2(nolign-1) = VALEUR
        Call CHARGE([M]VALEUR2(nolign-1),[M]PARTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINT2(nolign-1)) From FMTVAR
        Affzo [M:RPT]
    Endif
Return


$CONT1
    If [M:RPT]PARCOD(nolign-1)="mfctypdeb" & dim([M:DIA]MFCTYP)>0 & sigma(1,dim(GMENLOC)-1,indcum*(VALEUR=mess(indcum,2355,1)))>3
        mkstat=2
        GMESSAGE = mess(2,79,1)
    Endif
Return


$CONT2
    If [M:RPT]PARCOD(nolign-1)="mfctypdeb" & dim([M:DIA]MFCTYP)>0 & sigma(1,dim(GMENLOC)-1,indcum*(VALEUR=mess(indcum,2355,1)))>3
        mkstat=2
        GMESSAGE = mess(2,79,1)
    Endif
Return

##################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char    VALEUR(250)
Local Integer TABUID(500), NB, LWRI
Local Char    LFCY(GLONFCY), LTMP(100), LTYPPRV(250)
Local Integer LUID, LPRNUID, LMFCTYPSTR, LMFCTYPEND, LTYP, LMFCTYP1, LMFCTYP2
Local Char    LNUMSTR(GLONVCR), LNUMEND(GLONVCR)
Local Char    CRIT(250)(3), CRIT2
Local Integer ICRIT

If !clalev([F:MCP]) : Local File MFCDETPRT [MCP] : Endif
If !clalev([F:MFC]) : Local File MFGCOST   [MFC] : Endif
If !clalev([F:MFC2]) : Local File MFGCOST  [MFC2] : Endif
If !clalev([F:MCC]) : Local File MFCMAT    [MCC] : Endif
If !clalev([F:MTR]) : Local File MFCTYPREL [MTR] : Endif

If GMODU(8)=2
    If !clalev([F:MCS]) : Local File MFCSCRAP  [MCS] : Endif
Endif

If clalev([M:ICMM])
    # Il faut faire "-1" car ces paramètres sont saisissables en comparaison simple
    # et dans ce cas le superviseur fait "-1"
    VALEUR = num$([M:ICMM]MATFLG-1)
    Call SETPARAM("affmat",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]MACFLG-1)
    Call SETPARAM("affmac",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]LABFLG-1)
    Call SETPARAM("afflab",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]SCOFLG-1)
    Call SETPARAM("affsco",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]OVEFLG-1)
    Call SETPARAM("affove",NBPAR,PARAMETRE,VALEUR) From ETAT

    VALEUR = num$([M:ICMM]DETFLG-1)
    Call SETPARAM("affdet",NBPAR,PARAMETRE,VALEUR) From ETAT
Endif


VALEUR = num$(adxuid(1))
Call SETPARAM("curuid",NBPAR,PARAMETRE,VALEUR) From ETAT

Call GETPARAM("site",NBPAR,PARAMETRE,LFCY) From ETAT
Call GETPARAM("mfctypdeb",NBPAR,PARAMETRE,LTMP) From ETAT
LMFCTYPSTR = val(LTMP)
Call GETPARAM("mfctypfin",NBPAR,PARAMETRE,LTMP) From ETAT
LMFCTYPEND = val(LTMP)
Call GETPARAM("vcrtyp",NBPAR,PARAMETRE,LTMP) From ETAT
LTYP = val(LTMP)
Call GETPARAM("vcrnumdeb",NBPAR,PARAMETRE,LNUMSTR) From ETAT
Call GETPARAM("vcrnumfin",NBPAR,PARAMETRE,LNUMEND) From ETAT
Call GETPARAM("mfctypprv",NBPAR,PARAMETRE,LTYPPRV) From ETAT
Call GETPARAM("uid",NBPAR,PARAMETRE,LTMP) From ETAT
LUID = val(LTMP)
Call GETPARAM("prnuid",NBPAR,PARAMETRE,LTMP) From ETAT
LPRNUID = val(LTMP)

If LTYP = 36 
    VALEUR = mess(19,2361,1)
    Call SETPARAM("X3TIT",NBPAR,PARAMETRE,VALEUR) From ETAT
Endif

# Remplissage de la table ITCDET

Call UIDADX(TABUID,NB) From TRTX3

Trbegin [MCP]

Delete [MCP] Where !find([F:MCP]CURUID,TABUID)
Delete [MCP] Where [F:MCP]CURUID=adxuid(1)

Delete [MTR] Where !find([F:MTR]UID,TABUID)
Delete [MTR] Where [F:MTR]UID=adxuid(1)
Commit

Trbegin [MCP]

For I=1 To len(mess(0,2355,1))
    Raz [F:MTR]
    [F:MTR]UID=adxuid(1)
    [F:MTR]MFCTYP=I
    GBIDI1=instr(1,LTYPPRV,num$(I)+":")
    If GBIDI1>0
        [F:MTR]MFCTYP1=val(mid$(LTYPPRV,GBIDI1+2,1))
        [F:MTR]MFCTYP2=val(mid$(LTYPPRV,GBIDI1+4,1))
    Else
        [F:MTR]MFCTYP1=I
    Endif
    Write [MTR]
Next

Raz CRIT, ICRIT
Call ADDCRIT(CRIT,ICRIT,"","STOFCY = LFCY","&") From GOBJSUB
Call ADDCRIT(CRIT,ICRIT,"","VCRTYP = LTYP","&") From GOBJSUB
Call ADDCRIT(CRIT,ICRIT,"","LNUMSTR<=VCRNUM & VCRNUM<=LNUMEND","&") From GOBJSUB
Call ADDCRIT(CRIT,ICRIT,"","UID    = LUID","&") From GOBJSUB

Raz [F:MFC2]
If clalev([F:MCS])
    Raz [F:MCS]
Endif

For [MTR] Where UID = adxuid(1)
&             & LMFCTYPSTR<=[F:MTR]MFCTYP & [F:MTR]MFCTYP<=LMFCTYPEND
    CRIT2="1=1"
    If LPRNUID<>0 & [F:MTR]MFCTYP2=0
        CRIT2="PRNUID=LPRNUID"
    Endif

    For [MFC] Where evalue(CRIT)
&                 & evalue(CRIT2)
&                 & MFCTYP=[F:MTR]MFCTYP1
        [F:MCP] = [F:MFC]
        [F:MCP]CURUID=adxuid(1)
        Raz [F:MFC2]
        If [F:MTR]MFCTYP2
            Read [MFC2]MFC0=[F:MFC]STOFCY;[F:MFC]ITMREF;[F:MFC]VCRTYP;[F:MFC]VCRNUM;[F:MFC]VCRLIN;[F:MTR]MFCTYP2;[F:MFC]UID
        Endif
        If ![F:MTR]MFCTYP2 | [F:MFC]PRNUID=LPRNUID | [F:MFC2]PRNUID=LPRNUID
            If clalev([F:MCS])
                Raz [F:MCS]
                # Il n'y a du rebut que pour le PRF
                If find(4,[F:MTR]MFCTYP1,[F:MTR]MFCTYP2)
                    Read [MCS]MCS0=[F:MFC]STOFCY;[F:MFC]ITMREF;[F:MFC]VCRTYP;[F:MFC]VCRNUM;[F:MFC]VCRLIN;4;[F:MFC]UID
                Endif
            Endif
            Call WRIMCP
        Endif
    Next

    Raz [F:MFC]

    For [MFC2] Where evalue(CRIT)
&                  & MFCTYP=[F:MTR]MFCTYP2
        Look [MCP]MCP0(9)=[F:MFC2]STOFCY;[F:MFC2]ITMREF;[F:MFC2]VCRTYP;[F:MFC2]VCRNUM;[F:MFC2]VCRLIN;[F:MTR]MFCTYP1;[F:MTR]MFCTYP2;[F:MFC2]UID;adxuid(1)
        If fstat
            [F:MCP] = [F:MFC2]
            [F:MCP]CURUID=adxuid(1)
            If clalev([F:MCS])
                Raz [F:MCS]
                # Il n'y a du rebut que pour le PRF
                If find(4,[F:MTR]MFCTYP1,[F:MTR]MFCTYP2)
                    Read [MCS]MCS0=[F:MFC]STOFCY;[F:MFC]ITMREF;[F:MFC]VCRTYP;[F:MFC]VCRNUM;[F:MFC]VCRLIN;4;[F:MFC]UID
                Endif
            Endif
            Call WRIMCP
        Endif
    Next
Next
Commit
End

###############################################################
# WRIMCP : Ecrit l'enregistrement MCP
###############################################################
# Les fichiers suivants doivent être chargés:
#    - [MCP]  = éléments de clé chargés
#    - [MFC]  = 1er coût (prévu)
#    - [MFC2] = 2ème coût (réalisé)
#    - [MCS]  = Coût de rebut
###############################################################
Subprog WRIMCP
Local Integer I

[F:MCP]MFCTYP1 = [F:MTR]MFCTYP1
[F:MCP]MFCTYP2 = [F:MTR]MFCTYP2
For I=0 To max(GACTMAT,GACTMAC,GACTLAB)-1
    Raz [F:MCP]CST
    [F:MCP]BRDCOD=I+1
    If I<GACTMAT & ([F:MFC]MATCST(I)<>0 | [F:MFC2]MATCST(I)<>0)
        [F:MCP]CST     = [F:MFC]MATCST(I) * [F:MFC]QTYSTU
        [F:MCP]CST2    = [F:MFC2]MATCST(I) * [F:MFC2]QTYSTU
        If clalev([F:MCS])
            # Issue 78143 - 2011-11-23 by CCC
            #[F:MCP]SCPCST  = [F:MCS]MATCST(I) * (([F:MFC]MFCTYP=4)*[F:MFC]QTYSTU + ([F:MFC2]MFCTYP=4&[F:MFC]MFCTYP<>4)*[F:MFC2]QTYSTU)
            [F:MCP]SCPCST  = [F:MCS]MATCST(I) * (([F:MFC]MFCTYP=4) + ([F:MFC2]MFCTYP=4&[F:MFC]MFCTYP<>4))
        Else
            [F:MCP]SCPCST = 0
        Endif
        [F:MCP]TYPCST=1
        Write [MCP]
        If fstat
            Call FSTA("MCP") From GLOCK
            Break
        Endif
    Endif
    If I<GACTMAC & ([F:MFC]MACCST(I)<>0 | [F:MFC2]MACCST(I)<>0)
        [F:MCP]CST = [F:MFC]MACCST(I) * [F:MFC]QTYSTU
        [F:MCP]CST2    = [F:MFC2]MACCST(I) * [F:MFC2]QTYSTU
        If clalev([F:MCS])
            # Issue 78143 - 2011-11-23 by CCC
            #[F:MCP]SCPCST  = [F:MCS]MACCST(I) * (([F:MFC]MFCTYP=4)*[F:MFC]QTYSTU + ([F:MFC2]MFCTYP=4&[F:MFC]MFCTYP<>4)*[F:MFC2]QTYSTU)
            [F:MCP]SCPCST  = [F:MCS]MACCST(I) * (([F:MFC]MFCTYP=4) + ([F:MFC2]MFCTYP=4&[F:MFC]MFCTYP<>4))
        Else
            [F:MCP]SCPCST = 0
        Endif
        [F:MCP]TYPCST=2
        Write [MCP]
        If fstat
            Call FSTA("MCP") From GLOCK
            Break
        Endif
    Endif
    If I<GACTLAB & ([F:MFC]LABCST(I)<>0 | [F:MFC2]LABCST(I)<>0)
        [F:MCP]CST = [F:MFC]LABCST(I) * [F:MFC]QTYSTU
        [F:MCP]CST2    = [F:MFC2]LABCST(I) * [F:MFC2]QTYSTU
        If clalev([F:MCS])
            # Issue 78143 - 2011-11-23 by CCC
            #[F:MCP]SCPCST  = [F:MCS]LABCST(I) * (([F:MFC]MFCTYP=4)*[F:MFC]QTYSTU + ([F:MFC2]MFCTYP=4&[F:MFC]MFCTYP<>4)*[F:MFC2]QTYSTU)
            [F:MCP]SCPCST  = [F:MCS]LABCST(I) * (([F:MFC]MFCTYP=4) + ([F:MFC2]MFCTYP=4&[F:MFC]MFCTYP<>4))
        Else
            [F:MCP]SCPCST = 0
        Endif
        [F:MCP]TYPCST=3
        Write [MCP]
        If fstat
            Call FSTA("MCP") From GLOCK
            Break
        Endif
    Endif
Next
End
