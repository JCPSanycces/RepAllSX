If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_SEQABR From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_SEQNBR From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_LEG From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_UPDDAT From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_CREDAT From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_UPDUSR From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_CREUSR From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_CREDATTIM From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_UPDDATTIM From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_AUUID From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
Return

####################################################################
# OTHERS
####################################################################

$_AOTHERS
Gosub DECLARE_VAR From WMC0ACODNUM
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CODNUM From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CODNUM From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_DES From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_DES From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_LNG From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_LNG From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_NIVDEF From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_NIVDEF From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_NIVRAZ From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_NIVRAZ From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_TYP From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_TYP From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_NBPOS From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_NBPOS From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To 10
 If this.NBCOMPONENT(AINDCLA)<>null& find(this.NBCOMPONENT(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.NBCOMPONENT(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CTLCHR From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CTLCHR From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ZERO From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ZERO From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SEQ From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SEQ From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SEQTBL From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SEQTBL From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SEQABR From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SEQABR From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SEQNBR From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SEQNBR From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_LEG From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_LEG From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDDAT From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDDAT From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREDAT From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREDAT From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDUSR From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDUSR From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREUSR From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREUSR From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREDATTIM From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREDATTIM From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDDATTIM From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDDATTIM From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_AUUID From WMC1ACODNUM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_AUUID From WMC1ACODNUM : Gosub TESTALLSTAT :  Endif
[L]ASTATUS = fmet this.ACONTROL
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



