#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TCY1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_SOCNUMFMT
Onevent CONTROL Call C_SOCNUMFMT(zc) From W2TCY1
Return

Subprog C_SOCNUMFMT(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SOCNUMFMT" : GZNUM = 49881 : Endif
If !mkstat
 ## Action STD
 Call C_SOCNUMFMT(VALEUR) From SUBTCY
 If mkstat : GERR = 1 : GZONE = "SOCNUMFMT" : GZNUM = 49881 : Endif
Endif
Gosub _AFF
End

$ON_SOCNUMFLG2
Onevent CONTROL Call C_SOCNUMFLG2(zc) From W2TCY1
Onevent INIT_AREA Call D_SOCNUMFLG2(zc) From W2TCY1
Onevent BEFORE_INPUT Call AS_SOCNUMFLG2(zc) From W2TCY1
Return

Subprog D_SOCNUMFLG2(VALEUR)
Variable Integer VALEUR
If varinit([M]SOCNUMFLG2,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SOCNUMFLG2(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_SOCNUMFLG2(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_SOCNUMFLG2(VALEUR) From SUBTCY
If mkstat : GERR = 1 : GZONE = "SOCNUMFLG2" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_SOCNUMFMT2
Onevent CONTROL Call C_SOCNUMFMT2(zc) From W2TCY1
Return

Subprog C_SOCNUMFMT2(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SOCNUMFMT2" : GZNUM = 49880 : Endif
Gosub _AFF
End

$CHG_STY
Return


