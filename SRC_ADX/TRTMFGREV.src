#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-47100 - WO material audit enquiry. This shows material line revisions

# Standard actions used,
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "TITRE"      : Gosub LETITRE
 When "DEBUT"      : Gosub DEBUT
 When "FINSAI"     : Gosub FINSAI
Endcase
Return

$OUVRE
Case GACTION
 When "MFGMATREV"  : Gosub OUV_MFGMATREV
Endcase
Return

# Set title of enquiry window
$LETITRE
Case GACTION
 When "MFGMATREV"  : TIT=mess(174,195,1)
Endcase
Return

$DEBUT
Case GACTION
 When "MFGMATREV"  : Gosub DEB_MFGMATREV
Endcase
Return

$FINSAI
Case GACTION
 When "MFGMATREV"  : Gosub FINSAI_MFGMATREV
Endcase
Return


#########################################################################
$OUV_MFGMATREV
Local Char     ORDNO  : ORDNO = PARAM(1)
Local Integer  ORDLIN  : ORDLIN = val(PARAM(2))
Local Integer  SEQNO  : SEQNO = val(PARAM(3))
Local Char     PROD  : PROD = PARAM(4)
Local Shortint NOL     : NOL    = val(PARAM(5))
Local Shortint SAVGNOLIGN
SAVNOLIGN=nolign
#If evalue("[M:"+WABMSK+"]REVNUM(NOL)=0") |
If  evalue("[M:MFG2]ITMREF(NOL)=''") | GREP="C" | GREP="D"
  FIN=1
Endif
Return



#########################################################################
# Read through audit table for all the changes, and display in reverse order
$DEB_MFGMATREV
Raz [M:MFGMR]
Call TEMPON("O") From GESECRAN

# Read in material line, and display this at the top of list

If [F:MFM]MFGNUM<>ORDNO | [F:MFM]MFGLIN<>ORDLIN | [F:MFM]BOMSEQ<>SEQNO | [F:MFM]ITMREF<>PROD
  Read [MFM] MFM0=ORDNO;ORDLIN;SEQNO;PROD
  If fstat
    Raz [F:MFM]
  Endif
Endif

nolign=1
[M:MFGMR]ITMREF(nolign-1) = [F:MFM]ITMREF
[M:MFGMR]ECCVALMAJ(nolign-1) = [F:MFM]ECCVALMAJ
[M:MFGMR]ECCVALMIN(nolign-1) = [F:MFM]ECCVALMIN
[M:MFGMR]REVNUM(nolign-1) = 0
[M:MFGMR]MATSTA(nolign-1) = [F:MFM]MATSTA
[M:MFGMR]RETQTY(nolign-1) = [F:MFM]RETQTY
[M:MFGMR]STU(nolign-1) = [F:MFM]STU
[M:MFGMR]ALLQTY(nolign-1) = [F:MFM]ALLQTY
[M:MFGMR]SHTQTY(nolign-1) = [F:MFM]SHTQTY
[M:MFGMR]USEQTY(nolign-1) = [F:MFM]USEQTY
[M:MFGMR]ALLSTA(nolign-1) = [F:MFM]ALLSTA
[M:MFGMR]RETDAT(nolign-1) = [F:MFM]RETDAT
[M:MFGMR]BOMOPE(nolign-1) = [F:MFM]BOMOPE
[M:MFGMR]SCA(nolign-1) = [F:MFM]SCA
[M:MFGMR]CPNTYP(nolign-1) = [F:MFM]CPNTYP
[M:MFGMR]RELSCATIA(nolign-1) = [F:MFM]RELSCATIA
[M:MFGMR]BOMSEQ(nolign-1) = [F:MFM]BOMSEQ
[M:MFGMR]MFGLIN(nolign-1) = [F:MFM]MFGLIN
[M:MFGMR]PLANNER(nolign-1) = [F:MFM]PLANNER
[M:MFGMR]CUMFLG(nolign-1) = [F:MFM]CUMFLG
[M:MFGMR]PICPRN(nolign-1) = [F:MFM]PICPRN
[M:MFGMR]SCOFLG(nolign-1) = [F:MFM]SCOFLG
[M:MFGMR]PKC(nolign-1) = [F:MFM]PKC
[M:MFGMR]REVCOD(nolign-1) = 0
[M:MFGMR]CREUSR(nolign-1) = [F:MFM]UPDUSR
# use either CREDAT or UPDDAT
If [F:MFM]UPDDAT = [00/00/00]
  [M:MFGMR]CREDAT(nolign-1) = [F:MFM]CREDAT
Else
  [M:MFGMR]CREDAT(nolign-1) = [F:MFM]UPDDAT
Endif
[M:MFGMR]CRETIM(nolign-1) = mid$(num$([F:MFM]UPDDATTIM),12,8)

# open material audit file
If clalev([F:MMR])<=0 Local File MFGMATREV [MMR] : Endif

# read in all the audit lines for this material, and display on enquiry screen
Filter [MMR] Where [MMR]MFGNUM=ORDNO & [MMR]MFGLIN=ORDLIN & [MMR]BOMSEQ=SEQNO & [MMR]ITMREF=PROD Order By Key MFM0 Desc
For [MMR]
  nolign+=1

  [M:MFGMR]ITMREF(nolign-1) = [F:MMR]ITMREF
  [M:MFGMR]ECCVALMAJ(nolign-1) = [F:MMR]ECCVALMAJ
  [M:MFGMR]ECCVALMIN(nolign-1) = [F:MMR]ECCVALMIN
  [M:MFGMR]REVNUM(nolign-1) = [F:MMR]REVNUM
  [M:MFGMR]MATSTA(nolign-1) = [F:MMR]MATSTA
  [M:MFGMR]RETQTY(nolign-1) = [F:MMR]RETQTY
  [M:MFGMR]STU(nolign-1) = [F:MMR]STU
  [M:MFGMR]ALLQTY(nolign-1) = [F:MMR]ALLQTY
  [M:MFGMR]SHTQTY(nolign-1) = [F:MMR]SHTQTY
  [M:MFGMR]USEQTY(nolign-1) = [F:MMR]USEQTY
  [M:MFGMR]ALLSTA(nolign-1) = [F:MMR]ALLSTA
  [M:MFGMR]RETDAT(nolign-1) = [F:MMR]RETDAT
  [M:MFGMR]BOMOPE(nolign-1) = [F:MMR]BOMOPE
  [M:MFGMR]SCA(nolign-1) = [F:MMR]SCA
  [M:MFGMR]CPNTYP(nolign-1) = [F:MMR]CPNTYP
  [M:MFGMR]RELSCATIA(nolign-1) = [F:MMR]RELSCATIA
  [M:MFGMR]BOMSEQ(nolign-1) = [F:MMR]BOMSEQ
  [M:MFGMR]MFGLIN(nolign-1) = [F:MMR]MFGLIN
  [M:MFGMR]PLANNER(nolign-1) = [F:MMR]PLANNER
  [M:MFGMR]CUMFLG(nolign-1) = [F:MMR]CUMFLG
  [M:MFGMR]PICPRN(nolign-1) = [F:MMR]PICPRN
  [M:MFGMR]SCOFLG(nolign-1) = [F:MMR]SCOFLG
  [M:MFGMR]PKC(nolign-1) = [F:MMR]PKC
  [M:MFGMR]REVREASON(nolign-1) = [F:MMR]REVREASON
  [M:MFGMR]REVCOD(nolign-1) = [F:MMR]REVCOD
  [M:MFGMR]CREUSR(nolign-1) = [F:MMR]CREUSR
  [M:MFGMR]CREDAT(nolign-1) = [F:MMR]CREDAT
  [M:MFGMR]CRETIM(nolign-1) = mid$(num$([F:MMR]CREDATTIM),12,8)

Next

[M:MFGMR]REVNUM(0) = nolign
[M:MFGMR]NBLIG = nolign
# clear filter, and screen
Filter [MMR]
Affzo [M:MFGMR]
Call TEMPOFF From GESECRAN

Return

#########################################################################
$FINSAI_MFGMATREV
nolign=SAVNOLIGN
Close Local File [F:MMR]
Return

######################################################################################

