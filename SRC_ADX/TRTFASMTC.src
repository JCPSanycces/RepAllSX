#==============================================================#
#            Gestion de l'action métier FASMTC                 #
#==============================================================#
######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
$ACTION

  If dim(ORIACT)>0 & ORIACT<>""
    Case ORIACT
     When "TRTOBJ"
      Case ACTION
       When Default
      Endcase
     When Default
    Endcase
  Else
   Case ACTION
     When "OUVRE_BATCH"  : Gosub OUVRE_BATCH
     When "INIT_DIA"     : Gosub INIT_DIA
     When "INIT"         : Gosub INIT
     When "AVANT_PAR"    : Gosub AVANT_PAR
     When "OUVRE"        : Gosub OUVRE
     When "DEBUT"        : Gosub DEBUT
     When "CONTROLE"     : Gosub CONTROLE
     When "APRES_MODIF"  : Gosub APRES_MODIF
     When "SETBOUT"      : Gosub SETBOUT
     When "AP_CHOIX"     : Gosub AP_CHOIX
     When "BOUTON"       : Gosub BOUTON
     When "END"          : Gosub END_BOITE
     When "OK"           : Gosub OK
     When "ABA"          : Gosub ABA
     When "EXEC"         : Gosub EXEC
     When "FIN"          : Gosub FIN
     When "TERMINE"      : Gosub TERMINE
     When "SORTIE"       : Gosub SORTIE
     When Default
   Endcase
  Endif
Return
#=====================================================================
$OUVRE_BATCH             # (Massif uniquement - Soumission batch uniquement)
  Gosub OUVRE_TABLES
Return
#=====================================================================
$INIT_DIA                    # (Massif - Saisie des paramètres)
 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$INIT                    # (Massif uniquement - interactif et exécution batch)
  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT
  If GSERVEUR
   Gosub CREE_GLOBTRT
  Endif
Return
#=====================================================================
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)
  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

  # Ouverture des masques de la fenêtre de l'action massive pour pouvoir les garder jusqu'à
  # EXEC - Ouverture manuelle des masques de la fenêtre.
  Local Char WINACT : WINACT=ACTMETNAM+"M"
  Local Integer I_MSK
  If !clalev([F:AWI]) : Local File AWINDOW : Endif
  If !clalev([F:AMK]) : Local File AMSK    : Endif
  Read [AWI]AWI0=WINACT
  If not (fstat)
    Local Mask =[F:AWI]MSKENT
    For I_MSK=0 To [F:AWI]NBMSK
      Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
      Local Mask =[F:AMK]CODMSK
    Next I_MSK
  Endif

  If ACTSILENCE=G_OUI
   Gosub CREE_GLOBTRT
  Endif
  If ACTSILENCE=G_OUI & TRTFILMSK <>""
   TYPPRG=0

   #69691 ajout pour import des mvts
   # en chgt d'imput, on irait 2 fois : 1 par TRFASTRFC et 1 ici
   If dim(GFXIMPUT) > 0
    Return
   Endif

   Gosub INIT_WIN  From TRMPROACT
   Gosub ALIM_MASK From =TRTFILMSK
  Endif

Return
#=====================================================================
$OUVRE                   # (Massif interactif et Unitaire)

  If dim(TRTMODACT)<0
    Global Char TRTMODACT
    TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Endif
  Gosub ACTION From =TRTMODACT
  Gosub OUVRE_TABLES

  If !GSERVEUR        # - Rétablissement de la création des globales ici sinon marche pas en unitaire
   Gosub CREE_GLOBTRT # - Déplacé dans $INIT pour compatibilité avec l'exécution Batch
  Endif

  If ( ACTTYPGES = GTAMMAS )
    Global Integer  G_DEFORCE
  Endif
  G_TRACE = G_NON

  Local Char OLDCPY(GLONCPY)

Return
#=====================================================================
$CREE_GLOBTRT
  Global Char     G_PARM(2)(1..5)
  Global Char     GMD1, GQTY
  Global Integer  G_REPORT, G_TRACE, G_INCR
  Global Char     GFAS, GDPO, GDPN
  Global Date     GDATREF
  Global Integer  GFRADGI       #*FQ87928 indicateur "Règlementation DGI N° 13L-1-06" de la société

  #FQ80039
  If dim(GPRVSITUPD) < 0
    Global Integer  GPRVSITUPD
  Endif
  Raz GPRVSITUPD

Return
#=====================================================================
$DEBUT # (Massif et Unitaire)
Local Integer LCDRET
Local Char LMESSAGE
Local Date LDATE

  # Spécifique
  If ( ACTTYPGES=GTAMUNI )
    # Le type de détention du bien est "En modèle".
    If ( [M:FAS1]OWNTYP = GVML_TDMODEL )
      GERR= 1: GMESSAGE = mess(65,GML_MSGFAS,1) : FIN=1 : Return
    Endif
    # Le bien a fait l'objet d'une sortie réelle.
    If ( [M:FAS4]ISSDAT <> [0/0/0] and [M:FAS4]EXTISSFLG <> G_OUI )
      GERR= 1: GMESSAGE = mess(66,GML_MSGFAS,1) : FIN=1 : Return
    Endif
    # Le bien a fait l'objet d'un classement pour vente. FQ95754_3
    If ( [M:FAS4]SALCLSDAT <> [0/0/0] )
      GERR= 1: GMESSAGE = mess(931,GML_MSGFAS,1) : FIN=1 : Return
    Endif
  Endif
  # Standard
  If ( ACTTYPGES=GTAMUNI )
    # En unitaire la société est la société du bien
    [M:FASM]CPY1 = [M:FAS0]CPY
    Call INIT_PLAN_AMT([M:FAS0]CPY)
  Endif

  Gosub ACTION From =TRTMODACT

  If ACTSILENCE=G_OUI & TRTFILMSK<>""
   TYPPRG=0
   Gosub ALIM_MASK From =TRTFILMSK
  Endif

Return


$CONTROLE

Return

#=====================================================================
$APRES_MODIF

  Gosub ACTION From =TRTMODACT
  Case COUZON
    When "FLGCPY"
      If ( val(CZ) = G_OUI )
        Call INIT_PLAN_AMT([M:MHC]CPY(COUIND))
        [M:FASM]CPY1 = [M:MHC]CPY(COUIND)
      Else
        [M:FASM]NBLIG1 = 0
        Affzo [M:FASM]NBLIG1
      Endif
    When "FLGFCY"
      If ( val(CZ) = G_OUI )
        If ( val(CZ) = G_OUI and OLDCPY <> [M:MHC]FCYCPY(COUIND) )
          OLDCPY = [M:MHC]FCYCPY(COUIND)
          Call INIT_PLAN_AMT([M:MHC]FCYCPY(COUIND))
          [M:FASM]CPY1 = [M:MHC]FCYCPY(COUIND)
        Endif
      Else
        If ( find(G_OUI,[M:MHC]FLGCPY) = 0 )
          [M:FASM]NBLIG1 = 0
          Affzo [M:FASM]NBLIG1
        Endif
      Endif
    When Default
  Endcase

Return
#=====================================================================
$SETBOUT                 # (Massif interactif et unitaire : )

Gosub ACTION From =TRTMODACT
Local Integer IL, VIREOK, VIREAB

  VIREOK = 0
  VIREAB = 0
  If ( ACTSTATUS <> 8 and ACTTYPGES = GTAMUNI and find(G_OUI, [M:FASM]MTCFLG) = 0)
    VIREOK = 1
    VIREAB = 1
  Endif

  If ( ACTSTATUS <> 8 and ACTTYPGES = GTAMMAS)
    If (find(G_OUI, [M:FASM]MTCFLG) = 0 )
      VIREOK = 1
      VIREAB = 1
    Else
      For IL = 1 To [M:FASM]NBLIG1
        If ( [M:FASM]MTCFLG (IL-1) = G_OUI )
          Break 1
        Else
          If (IL = [M:FASM]NBLIG1 )
            VIREOK = 1
            VIREAB = 1
          Endif
        Endif
      Next IL
      If !VIREOK
        For IL = 1 To [M:FASM]NBLIG1
          If ( [M:FASM]RSDFLG(IL-1) = G_OUI or [M:FASM]DPMD(IL-1) = G_DPMUO )
            VIREOK = 1
            Break 1
          Endif
        Next IL
      Endif
    Endif
  Endif

  If ( dim(CHBOU)>0 and VIREOK)   : Call VIREBOUT (CHBOU,"O") From GOBJET : Endif
  If ( dim(CHMEN)>0 and VIREAB)   : Call VIREBOUT (CHMEN,"D") From GOBJET : Endif

Return
#=====================================================================
$AP_CHOIX                 # (Unitaire : )
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$BOUTON                  # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$END_BOITE               # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$OK                      # (Massif intéractif et unitaire)
 Gosub ACTION From =TRTMODACT
 #If (G_REPORT = G_NON and ACTTYPGES = GTAMUNI )
 #  ACTMODIF = 0
 # Endif
Return
#=====================================================================
$ABA
  If ( dim(GABAERR) > 0)
    Kill GABAERR
  Else
    # Réinitialisation du tableau des paramètres par plan d'amortissement
    If ( ACTTYPGES=GTAMUNI )
      # En unitaire la société est la société du bien
      [M:FASM]CPY1 = [M:FAS0]CPY
      Call INIT_PLAN_AMT([M:FAS0]CPY)
    Endif
  Endif
  Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$EXEC                    # (Massif intéractif et batch)
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$FIN                     # ()
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$TERMINE                  # ()
  Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$SORTIE                   # ()
 Gosub ACTION From =TRTMODACT
Return
######################################################################
# Points d'entrée de l'action métier communs unitaire / massif
######################################################################
$ACTMET

 Case ACTMET
  When "CRITMEN"            :   Gosub CRITMEN         From TRTFASMTC2      # U  - Activation menu ou bouton
  When "SET_PRECHARGE"      :   Gosub SET_PRECHARGE   From TRTFASMTC2      # U  - A positionner à G_OUI s'il n'y a pas de bouton sélectionner
  When "SET_CRITACT"        :   Gosub SET_CRITACT     From TRTFASMTC2      # UM - CRITACT critère de sélection particulier à l'action métier
  When "FILL_HEA"           :   Gosub FILL_HEA        From TRTFASMTC2      # U  - Alimentation partie spécifique en-tête

# Locker
  When "OUVR_LOCK"          :   Gosub OUVR_LOCK            From TRTFASMTC2   # UM - Ouverture de tables annexes pour les lock
  When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        From TRTFASMTC2   # UM  - Exclusion élément de la population à sélectionner
  When "MAS1_LOCK_AUTRE"    :   Gosub MAS1_LOCK_AUTRE      From TRTFASMTC2   # UM - Lock objet lié à l'enr en ligne de la population

# Charger
  When "OUVR_ALIM_TMP1"     :   Gosub OUVR_ALIM_TMP1       From TRTFASMTC2   # UM - Ouverture de tables annexes pour l'alim des table tmp.
  When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       From TRTFASMTC2   # UM - Transfert zones tables de données -> tables tempo

# Applique_temp
  When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       From TRTFASMTC2   # UM - Ouverture de tables annexes
  When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       From TRTFASMTC2   # UM - Application des paramètres de l'action aux enr de la table temporaire principale
  When "TPF1_APPL_TPF1"     :   Gosub TPF1_APPL_TPF1       From TRTFASMTC2   # UM - Application des paramètres de l'action aux enr de la table temporaire annexe

# Report_mask Report objet principal dans les masques (unitaire uniquement)
  When "TMP1_ALIM_MASK"     :   Gosub TMP1_ALIM_MASK       From TRTFASMTC2   # U  - Tansfert table temporaire principale -> masques de l'écran
  When "TPF1_ALIM_MASK"     :   Gosub TPF1_ALIM_MASK       From TRTFASMTC2   # U  - Tansfert table temporaire annexe     -> masques de l'écran
  When "REAF_ALIM_MASK"     :   Gosub REAF_ALIM_MASK       From TRTFASMTC2   # U  - Tansfert tables temporaires -> masques de l'écran (pour réaffichage)

# Applique_dirt Mise à jour directe (massif uniquement)
  When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       From TRTFASMTC2   # M  - Ouverture de tables annexes pour la maj directe en massif
  When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       From TRTFASMTC2   # M  - Mise à jour directe des tables de données avec les paramètres de l'action

# reporter
  When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      From TRTFASMTC2   # UM - Ouverture tables annexes avant report tables tempo -> tables de données
  When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      From TRTFASMTC2   # UM - Report table temporaire principale -> table de données
  When "TPF1_ALIM_TABLE"    :   Gosub TPF1_ALIM_TABLE      From TRTFASMTC2   # UM - Report table temporaire par plan   -> table de données par plan

# Fin traitement
  When "END_ALIM_TABLE"     :   Gosub END_ALIM_TABLE       From TRTFASMTC2   # UM - Traitement de fin unitaire ou de MAJ indirecte
  When "END_APPL_DIRT"      :   Gosub END_APPL_DIRT        From TRTFASMTC2   # M  - Traitement de fin de MAJ directe

  When Default

 Endcase

Return
#=====================================================================
$BEFORE_REWRITE_DEP

   # Pour ce mode, le Taux ne doit pas être renseigné. FQ77877 FQ84283 FQ84281 FQ105809
   If find([F:DEP]DPM,  G_DPMUL, G_DPMCA, G_DPMDA, G_DPMUD, G_DPMTD, G_DPMDE, G_DPMDF, G_DPMDX, G_DPMDP,
&                       G_DPMDI, G_DPMRE, G_DPMFM, G_DPMLG, G_DPMPR, G_DPMSA, G_DPMSY, G_DPMUO,
&                       G_DPMDV, G_DPMRA, G_DPMDM, G_DPMRX, G_DPMRD, G_DPMAL, G_DPMAD, G_DPMHL )  &
&           [F:DEP]DPRRATFLG=G_OUI
      [F:DEP]DPRRATFLG = G_NON
      [F:DEP]DPRRAT    = 0 #Fq-74308
   Endif


#Fq-84623    If [F:DEP]ALWAMT <> [M:FASM]ALWAMT(I_PLN-1)
#Fq-84623       [F:DEP]ALWAMTFLG = G_OUI
#Fq-84623    Endif
  If [F:DEP]ALWAMT <> [F:DEPW]ALWAMT
    [F:DEP]ALWAMTFLG = G_OUI
  Endif
Return
#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP
# Traitement du ou des masques de paramètres de l'action massive               #
# -----> PARAMETRES  FASMTC                                                    #
#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP
#=====================================#
# Actions de contrôle sur champ       #
#=====================================#
######################################################################################
Subprog AS_MTCTIATYP(VALEUR)
Variable Integer VALEUR

 # Si la date de début d'amortissement est > à la date de fin de la période courante
 # ==> la prise d'effet ne sera jamais "Début d'exercice" "Début de période".
 If [M:FASM]STRDPRDAT(nolign-1) > [M:FASM]PERENDDAT(nolign-1)
    GMENLOC(GVML_PEDBEX) = 1
    GMENLOC(GVML_PEDBPE) = 1
 Endif

 # Si la Période courante est la première de l'exercice
# ==> la Prise d'effet ne sera jamais "Début de période".
If [M:FASM]PERSTRDAT(nolign-1) =  [M:FASM]FIYSTRDAT(nolign-1)
   GMENLOC(GVML_PEDBPE) = 1
     # Si la Date de début d'amortissement se situe dans la période courante
     # ==> la prise d'effet ne sera jamais "Début d'exercice"
    If [M:FASM]STRDPRDAT(nolign-1)  >=   [M:FASM]FIYSTRDAT(nolign-1) and
&      [M:FASM]STRDPRDAT(nolign-1)  <=   [M:FASM]PERENDDAT(nolign-1)
       GMENLOC(GVML_PEDBEX) = 1
   Endif
Endif

# Si la Période courante n'est pas la première de l'exercice
If [M:FASM]PERSTRDAT(nolign-1) >  [M:FASM]FIYSTRDAT(nolign-1)
    # Si la date de début  d'amortissement se situe dans la période courante
    #  ==> La prise d'effet ne sera jamais "Début d'exercice" "Début de période".
   If [M:FASM]STRDPRDAT(nolign-1) >=  [M:FASM]PERSTRDAT(nolign-1) and
&     [M:FASM]STRDPRDAT(nolign-1) <=  [M:FASM]PERENDDAT(nolign-1)
      GMENLOC(GVML_PEDBEX) = 1
      GMENLOC(GVML_PEDBPE) = 1
   Else
     # Si la date de début  d'amortissement se situe dans la 1ère période de l'exercice
 # ==> la prise d'effet ne sera jamais "Début d'exercice".
      If [M:FASM]STRDPRDAT(nolign-1) >=   [M:FASM]FIYSTRDAT(nolign-1) and
&        [M:FASM]STRDPRDAT(nolign-1) <=   [M:FASM]PERENDDAT(nolign-1)
         GMENLOC(GVML_PEDBEX) = 1
      Endif
   Endif
 Endif

 Affzo [M:FASM]MTCTIATYP(nolign-1)

End
#=====================================================================
Subprog C_MTCTIATYP(VALEUR)
Variable Integer VALEUR

 If  ([M:FASM]STRDPRDAT(nolign-1) >= [M:FASM]PERSTRDAT(nolign-1) or
&        ACTMETNAM = "FASTRFC" )  and
&      ( VALEUR <>  GVML_PEDBAM )
       GERR=1
       #GMESSAGE ="prise d'effet incorrecte"
       GMESSAGE=mess(902,GML_MSGFAS,1) : # FQ89367 "Prise d'effet incorrecte"
       mkstat=2
       End
 Endif

End
#==============================
Subprog AM_MTCTIATYP(VALEUR)
Variable Integer VALEUR

  Call DETERM_MTCTIADAT(VALEUR,
&      [M:FASM]FIYSTRDAT(nolign-1), [M:FASM]PERSTRDAT(nolign-1), [M:FASM]STRDPRDAT(nolign-1),
&      [M:FASM]MTCTIADAT(nolign-1) ) From TRTFASMTC

If ( VALEUR <>  GVML_PEDBAM )
  [M:FASM]ECTFLG(nolign-1) = G_NON : Diszo [M:FASM]ECTFLG(nolign-1)
  # Issue 113764
  #[M:FASM]MTCDEVADJ(nolign-1) = 0  : Diszo [M:FASM]MTCDEVADJ(nolign-1)
  Diszo [M:FASM]MTCDEVADJ(nolign-1)
Else
  [M:FASM]ECTFLG(nolign-1) = G_OUI
  # Issue 113764
  # [M:FASM]MTCDEVADJ(nolign-1) = 0
  [M:FASM]MTCDEVADJ(nolign-1) = GVML_RDOTPER
  Actzo [M:FASM]MTCDEVADJ(nolign-1)
Endif

[M:FASM]MTCTIATYP(nolign-1)= VALEUR
Affzo [M:FASM]MTCTIATYP(nolign-1)
Affzo [M:FASM]ECTFLG(nolign-1)
Affzo [M:FASM]MTCDEVADJ(nolign-1)
Affzo [M:FASM]MTCTIADAT(nolign-1)

End
##########################################################################
Subprog AV_RSDFLG(VALEUR)
Variable Integer VALEUR

 If (ACTTYPGES = GTAMUNI or  ACTMETNAM = "FASTRFC")
    Chgfmt [M:FASM]RSDFLG(nolign-1) With "-LO:1X"
 Endif
 If  ACTMETNAM = "FASMTC"
    If   [M:FASM]DPRPLND = G301SUB
       [M:FASM]RSDFLG(nolign-1)= G_NON   :   Diszo [M:FASM]RSDFLG(nolign-1)
    Endif
 Endif

End
#=============================
Subprog AM_RSDFLG(VALEUR)
Variable Integer VALEUR


 [M:FASM]MTCFLG(nolign-1) =
&   func TRTFASMTC.DETERM_MTCFLG
&    ( [M:FASM]DPMD(nolign-1),       VALEUR,                       [M:FASM]DURFLG(nolign-1),
&      [M:FASM]DPRRATFLGD(nolign-1), [M:FASM]DPRRA2FLGD(nolign-1), [M:FASM]STRFLG(nolign-1),
&      [M:FASM]RSDVALFLG(nolign-1),  [M:FASM]ALWFLG(nolign-1),     [M:FASM]VEHFLG(nolign-1),
&      [M:FASM]PRATYPFLG(nolign-1),  [M:FASM]ACLCOEFLG(nolign-1),  nolign )

   Gosub COND_GESTION_ECART

# Nécessaire pour le test dans l'action setbout
[M:FASM]RSDFLG(nolign-1) = VALEUR

End


##########################################################################
Subprog AM_STRFLG(VALEUR)
Variable Integer VALEUR

  If ( VALEUR <> G_OUI )
    Effzo[M:FASM]STRDPRDATD(nolign-1)
  Endif

 [M:FASM]MTCFLG(nolign-1) =
&   func TRTFASMTC.DETERM_MTCFLG
&    ( [M:FASM]DPMD(nolign-1),       [M:FASM]RSDFLG(nolign-1),     [M:FASM]DURFLG(nolign-1),
&      [M:FASM]DPRRATFLGD(nolign-1), [M:FASM]DPRRA2FLGD(nolign-1),  VALEUR,
&      [M:FASM]RSDVALFLG(nolign-1),  [M:FASM]ALWFLG(nolign-1),     [M:FASM]VEHFLG(nolign-1),
&      [M:FASM]PRATYPFLG(nolign-1),  [M:FASM]ACLCOEFLG(nolign-1),  nolign )
   Gosub COND_GESTION_ECART

   #FQ84741
   If dim(GFXDNBERR) > 0
     If ACTMETNAM = "FASTRFC" and VALEUR = G_OUI
       # FQ90828 : ajout de l'indice
       Actzo [M:FASM]STRDPRDATD(nolign - 1)
     Endif
   Endif
End
##########################################################################
Subprog C_STRDPRDATD(VALEUR)
Variable Date    VALEUR

 If VALEUR>=[01/01/2200]
  GERR= 1: GMESSAGE = mess(537,GML_MSGFAS,1)-format$("D:" + GFMDAT4,[01/01/2200])
  mkstat = 2 : End
 Endif
End
##########################################################################
Subprog AM_STRDPRDATD(VALEUR)
Variable Date    VALEUR

#Fq-78438  If (VALEUR < [M:FASM]FIYSTRDAT(nolign-1) )
#Fq-78438    # la date de début d'amortissement doit être > = à la date de début de l'exercice courant
#Fq-78438    GMESSAGE = mess(77,GML_MSGFAS,1)
#Fq-78438    GERR=1: mkstat = 2: End
#Fq-78438  Endif

Local Integer    OK
Local Char  LPARM
 If (ACTTYPGES = GTAMUNI or  ACTMETNAM = "FASTRFC") #Fq-84623
  #Fq-78438 Attention, date de début d'amortissement < au début d'exercice courant,
  # veuillez confirmer cette action
  If (VALEUR < [M:FASM]FIYSTRDAT(nolign-1) )
     Call AVERTIR(mess(860,GML_MSGFAS,1),OK) From GESECRAN
     If OK=1   # Annuler
        mkstat=2 : End
     Else
       # Remise en cause de la situation après clôture
       Call PARAM([M:FASM]CPY1(nolign-1),"PRVSITUPD",LPARM) From ADOVAL
       LPRVSITUPD = val(LPARM)
       # Remise en cause non-autorisée
       If LPRVSITUPD <> G_OUI
          [M:FASM]MTCDEVADJ(nolign-1) = GVML_RDOTPER
          [M:FASM]DPRCUMFLG(nolign-1) = G_OUI
          [M:FASM]ECTFLG(nolign-1)  = G_OUI
            #FQ-80039
          Actzo [M:FASM]MTCDEVADJ(nolign-1)
       Else
          # Remise en cause autorisée
         [M:FASM]DPRCUMFLG(nolign-1) = G_NON
         [M:FASM]ECTFLG(nolign-1)    = G_NON
         # Issue 113764 [M:FASM]MTCDEVADJ(nolign-1) = 0
           #FQ-80039
          Diszo [M:FASM]MTCDEVADJ(nolign-1)
       Endif
       [M:FASM]STRDPRDATD(nolign-1) = VALEUR
       Affzo [M:FASM]STRDPRDATD(nolign-1)
       Affzo [M:FASM]MTCDEVADJ(nolign-1)
       Affzo [M:FASM]DPRCUMFLG(nolign-1)
       Affzo [M:FASM]ECTFLG(nolign-1)
     Endif
  Endif
 Endif  #Fq-84623

End
##########################################################################
Subprog AM_DPMD(VALEUR)
Variable Char    VALEUR()
Local Integer LERROR
Local Integer  WRSD
Local Date RDATE
Local Integer WPRATYP

   Call DETERM_MTCTIADAT([M:FASM]MTCTIATYP(nolign-1),
&      [M:FASM]FIYSTRDAT(nolign-1), [M:FASM]PERSTRDAT(nolign-1), [M:FASM]STRDPRDAT(nolign-1),
&     RDATE ) From TRTFASMTC
   [M:FASM]MTCTIADAT(nolign-1)=RDATE
   Affzo [M:FASM]MTCTIADAT(nolign-1)

If  ( ACTMETNAM = "FASMTC" )
   If ( VALEUR <>  "" ) &  ( ACTTYPGES <>  GTAMMAS ) & ( VALEUR <> [M:FASM]DPMO(nolign-1) )
      # Mode initial résiduel et mode destinataire non-résiduel
      If clalev([F:DPM])=0 : Local File DPRMOD   [DPM] :  Endif
      # Un mode est résiduel s'il est résiduel de lui-même
      Filter [DPM] Where  ( RSDDPMTGR = [M:FASM]DPMO(nolign-1)) &  ( DPM = [M:FASM]DPMO(nolign-1))
         Read[DPM] First
         If ( fstat )
            WRSD = 0
         Else    # mode résiduel
            WRSD = 1
         Endif
      Filter [DPM]

      If (!WRSD) and  ( [M:FASM]STRDPRDAT(nolign-1) < [M:FASM]MTCTIADAT(nolign-1) ) and
&                     ( [M:FASM]DPMO(nolign-1) <> G_DPMSA  )
         Filter [DPM] Where DPM= [M:FASM]DPMO(nolign-1)
         Read[DPM] First
         If ( [F:DPM]RSDDPMTGR <> VALEUR ) & ( VALEUR <> G_DPMSA )
            ## La date de prise d'effet du changement vous impose de saisir un mode résiduel pour ce plan.
            GMESSAGE = mess(622,GML_MSGFAS,1)
            GERR=1: mkstat = 2: End
         Endif
      Endif
   Endif
Endif # si "FASMTC" uniquement

  # FQ84281
  If  ( ACTMETNAM = "FASTRFC" and  G_DPMHL <> "" and VALEUR = G_DPMHL ) Then
    # Si mode d'amort = "HL" alors taux d'amort = 0 et non saisissables
    [M:FASM]DPRRATFLGD(nolign-1) = G_OUI
    [M:FASM]DPRRATD(nolign-1)    = 0
    Diszo [M:FASM]DPRRATFLGD(nolign-1)
  Endif

  # Contrôles sur le mode d'amortissement
  # Alimentation du type de détention en unitaire (auparavant toujours = 1)
  # En massif impossible de contrôler ici le mode par rapport au type de détention de chaque bien ==> on passe 0 pour le type de
  # ==> on passe 0 pour le type de détention + ajout test si zéro dans le TRTFAS
  # En massif impossible de contrôler ici le plan de production de chaque bien ==> on passe à ""
  If (VALEUR <> "" )
    If ( ACTTYPGES = GTAMMAS )
      Call CTRL_DPM (VALEUR, [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1), [M:FASM]CNX(nolign-1), [M:FASM]DPRPLND(nolign-1),
&                    GVML_TICORPO,  0, "", G_NON,
&                    LERROR) From TRTFAS  : # FQ64478
    Else
      Call CTRL_DPM (VALEUR, [M:OAC0]OBJCPY,  [M:FASM]CNX(nolign-1),[M:FASM]DPRPLND(nolign-1),
&                    GVML_TICORPO, [M:FAS1]OWNTYP, [M:FAS2]PROPLN, G_OUI,
&                    LERROR) From TRTFAS

    Endif
    # Pour le plan de subvention le  mode d'amortissements "RA" et "CA" sont interdit
    If ( [M:FASM]DPRPLND(nolign-1) = G301SUB and find(VALEUR, G_DPMRA, G_DPMCA) <> 0 )
       LERROR = 126
    Endif
    If (LERROR)
      GMESSAGE = mess(LERROR,GML_MSGFAS,1)
      GERR=1: mkstat = 2: End
    Endif
  Endif

 If  ( ACTMETNAM = "FASMTC" )  : WPRATYP =  [M:FASM]PRATYPO(nolign-1) : Endif
 If  ( ACTMETNAM = "FASTRFC" ) : WPRATYP =  [M:FASM]PRATYPD(nolign-1) : Endif

 # Conditionnement maj Fin amort
    # Si mode RE/prorata jour ou RA prorata jour ==> date de fin d'amortissement peut être forcée
 # Issue 116168 - POR-idem for methods PC and PC
 If  ( G_DPMRE <> "" and VALEUR = G_DPMRE and WPRATYP=GVML_TPJOUR  ) or
&    ( G_DPMRA <> "" and VALEUR = G_DPMRA and WPRATYP=GVML_TPJOUR ) or
&    ( G_DPMPC <> "" and VALEUR = G_DPMPC ) or
&    ( G_DPMPD <> "" and VALEUR = G_DPMPD )
    #[M:FASM]ENDDPRFLG(nolign-1)  = G_NON # FQ82178
    Actzo [M:FASM]ENDDPRFLG(nolign-1)
 Else
    [M:FASM]ENDDPRFLG(nolign-1)  = G_NON
    Diszo [M:FASM]ENDDPRFLG(nolign-1)
    Diszo [M:FASM]ENDDPRDATD(nolign-1)
    Chgstl [M:FASM]ENDDPRDATD(nolign-1) With ""
 Endif

  # Conditionnement durée taux via les flags associés (durflg)
  Actzo [M:FASM]DURFLG(nolign-1)
  Actzo [M:FASM]DPRRATFLGD(nolign-1)
  If ( ( G_DPMSA <> "" and [M:FASM]DPMD(nolign-1) = G_DPMSA and VALEUR <> G_DPMSA)
&   or ( G_DPMUO <> "" and [M:FASM]DPMD(nolign-1) = G_DPMUO and VALEUR <> G_DPMUO) )
    # Si mode d'amort passe de "SA" ou "UO" à une autre valeur alors durée et taux d'amort saisissables
    [M:FASM]DURFLG(nolign-1)     = G_NON
    [M:FASM]DPRRATFLGD(nolign-1) = G_NON
  Endif

  If ( ( G_DPMSA <> "" and VALEUR = G_DPMSA )
&   or ( G_DPMUO <> "" and VALEUR = G_DPMUO ) )
    # Si mode d'amort = "SA" ou "UO" alors durée et taux d'amort = 0 et non saisissables
    [M:FASM]DURFLG(nolign-1)     = G_OUI
    [M:FASM]DPRDURD(nolign-1)    = 0
    [M:FASM]DPRRATFLGD(nolign-1) = G_OUI
    [M:FASM]DPRRATD(nolign-1)    = 0
    Diszo [M:FASM]DURFLG(nolign-1)
    Diszo [M:FASM]DPRRATFLGD(nolign-1)
  Endif

 # Conditionnement DUREE
 If (   ( G_DPMSA <> "" and VALEUR = G_DPMSA )
&    or ( G_DPMLV <> "" and VALEUR = G_DPMLV )
&    or ( G_DPMIT <> "" and VALEUR = G_DPMIT ) )
     # Pour ces modes la durée est toujours à 0
     [M:FASM]DURFLG(nolign-1)     = G_OUI
     [M:FASM]DPRDURD(nolign-1)    = 0
     Diszo [M:FASM]DURFLG(nolign-1)
 Endif

 If ( G_DPMFM <> "" and VALEUR = G_DPMFM )
    # Pour "Formes & Moules", la durée est de 3 ans
     [M:FASM]DURFLG(nolign-1)     = G_OUI
     [M:FASM]DPRDURD(nolign-1)    = 3
     Diszo [M:FASM]DURFLG(nolign-1)
 Endif

 If ( G_DPMLG <> "" and VALEUR = G_DPMLG )
    # Pour "Linge", la durée est de 18 mois
     [M:FASM]DURFLG(nolign-1)     = G_OUI
     [M:FASM]DPRDURD(nolign-1)    = 1.5
     Diszo [M:FASM]DURFLG(nolign-1)
  Endif

 If ( G_DPMLP <> "" and VALEUR = G_DPMLP and [M:FASM]ALWCODD(nolign-1)= GVML_RPALOGI )
    # Pour "Logiciel", la durée est de 12 mois
     [M:FASM]DURFLG(nolign-1)     = G_OUI
     [M:FASM]DPRDURD(nolign-1)    = 1.
     Diszo [M:FASM]DURFLG(nolign-1)
  Endif

  # -- Taux 1 FQ77877 FQ84283 FQ84281 FQ105809
  If ( ACTMETNAM = "FASMTC" )
     If ( func TRTFAS.GET_MODE_DPM ([M:FASM]CPY1, VALEUR) = GVML_TMLIBRE or
&         find( VALEUR,  G_DPMUL, G_DPMCA, G_DPMDA, G_DPMUD, G_DPMTD, G_DPMDE, G_DPMDF, G_DPMDX,
&                        G_DPMDP, G_DPMDI, G_DPMRE, G_DPMFM, G_DPMLG, G_DPMPR, G_DPMSA,
&                        G_DPMRX, G_DPMRD, G_DPMAL, G_DPMAD, G_DPMHL,
&                        G_DPMSY, G_DPMUO, G_DPMDV,G_DPMRA, G_DPMDM ) <> 0 )
       #-- Pour les modes libres, le taux est déterminé par le calcul.
       #-- Pour ces modes standards, le taux est déterminé par le calcul.
        [M:FASM]DPRRATFLGD(nolign-1)  = G_NON
        [M:FASM]DPRRATD(nolign-1)     = 0
        Diszo [M:FASM]DPRRATFLGD(nolign-1)
     Endif
   Endif
  If ( VALEUR = G_DPMLP and [M:FASM]ALWCODD(nolign-1) = GVML_RPALOGI )
    #-- Pour le logiciel, le taux est toujours à 100 %
     [M:FASM]DPRRATFLGD(nolign-1)     = G_OUI
     [M:FASM]DPRRATD(nolign-1)        = 1.
     Diszo [M:FASM]DPRRATFLGD(nolign-1)
  Endif

  #-Si mode différent de IT, AD, AL alors le deuxième taux n'est pas saisissable FQ84283
  If ( G_DPMIT <> "" and VALEUR <> G_DPMIT ) and
&    ( G_DPMAL <> "" and VALEUR <> G_DPMAL ) and
&    ( G_DPMAL <> "" and VALEUR <> G_DPMAD ) Then
     [M:FASM]DPRRA2FLGD(nolign-1)     = G_NON
     [M:FASM]DPRRAT2D(nolign-1)       = 0
     Diszo [M:FASM]DPRRA2FLGD(nolign-1)
  Else
     Actzo [M:FASM]DPRRA2FLGD(nolign-1)
  Endif
    If ( G_DPMSA <> "") and ( VALEUR = G_DPMSA )
         [M:FASM]DPRRATFLGD(nolign-1)     = G_NON
         [M:FASM]DPRRATD(nolign-1)       = 0
         Diszo [M:FASM]DPRRATFLGD(nolign-1)
    Endif

  # -- Coef accél.
  If ( G_DPMUD <> "" and VALEUR = G_DPMUD )  or
&    ( G_DPMTD <> "" and VALEUR = G_DPMTD )  or
&    ( G_DPMDB <> "" and VALEUR = G_DPMDB )  or
&    ( G_DPMLR <> "" and VALEUR = G_DPMLR )  or
&    ( G_DPMDR <> "" and VALEUR = G_DPMDR )  or
&    ( G_DPMCR <> "" and VALEUR = G_DPMCR )
    # Le coefficient d'accélération ne concerne que "Declining Balance", "Linéaire russe", " Dégressif russe"
    # "Constant russe", "Dégressif belge" ou le "Dégressif turque" FQ105809
     Actzo [M:FASM]ACLCOEFLG(nolign-1)
  Endif
  # -- Prorata FQ84281 FQ105809
  If ( G_DPMUL <> "" and VALEUR = G_DPMUL  )  or
&    ( G_DPMUD <> "" and VALEUR = G_DPMUD  )  or
&    ( G_DPMTD <> "" and VALEUR = G_DPMTD  )  or
&    ( G_DPMHL <> "" and VALEUR = G_DPMHL  )  or
&    ( G_DPMHD <> "" and VALEUR = G_DPMHD  )  or
&    ( G_DPMTL <> "" and VALEUR = G_DPMTL  )  or
&    ( G_DPMRE <> "" and VALEUR = G_DPMRE  )
    # Le type de prorata n'est significatif que pour les modes ci-dessus
     [M:FASM]PRATYPD(nolign-1) = [M:FASM]PRATYPO(nolign-1)
     [M:FASM]PRATYPFLG(nolign-1)  = G_OUI
     # FQ89488 FQ105809
     If ( (find (VALEUR, G_DPMUL,G_DPMUD,G_DPMTD) >0) and
&         find([M:FASM]PRATYPD(nolign-1), GVML_TPMOIS, GVML_TPHLFY, GVML_TPHLFM, GVML_TPHLFQ) = 0 ) Then
       [M:FASM]PRATYPD(nolign-1) = GVML_TPMOIS
       Affzo [M:FASM]PRATYPD(nolign-1)
     Endif
     Affzo [M:FASM]PRATYPFLG(nolign-1)
     Actzo [M:FASM]PRATYPD(nolign-1)
  Else
      [M:FASM]PRATYPFLG(nolign-1)  = G_NON
      [M:FASM]PRATYPD(nolign-1) = 0
      Diszo [M:FASM]PRATYPD(nolign-1)
      Diszo [M:FASM]PRATYPFLG(nolign-1)
  Endif

  # -- Règle paticulière
  # FQ82075 G_DPMSL
  If ( ( VALEUR = G_DPMLP or VALEUR = G_DPMDF or VALEUR = G_DPMSL ) and
&      ( find([M:FASM]ALWCODD(nolign-1), GVML_RPAID25, GVML_RPAID50, GVML_RPPR39B) <> 0 ) )
       # Règle inchangée si mode "LP" ou "DF" et règle correspond à une des règles ci-desssus (règles communes)
  Elsif ( ( VALEUR = G_DPMPC and [M:FASM]DPMD(nolign-1) <> G_DPMPD ) or
&         ( VALEUR = G_DPMPD and [M:FASM]DPMD(nolign-1) <> G_DPMPC )    )
     # "Basé sur période" règle par défaut pour les modes "PC" et "PD"
     [M:FASM]ALWCODD(nolign-1) = GVML_RPPERIO : Affzo [M:FASM]ALWCODD(nolign-1)
     [M:FASM]ALWFLG(nolign-1)  = G_OUI
  Else
    # Dans tous les autres cas, la règle passe à "Aucune"
    If ( [M:FASM]ALWCODD(nolign-1) <>  GVML_RPAUCUN ) & ( [M:FASM]ALWCODD(nolign-1) <> 0 )
       [M:FASM]ALWCODD(nolign-1) = GVML_RPAUCUN : Affzo [M:FASM]ALWCODD(nolign-1)
       [M:FASM]ALWFLG(nolign-1)  = G_OUI
    Endif
  Endif

  If ( ACTMETNAM = "FASTRFC" ) & [M:FASC]ITSDATD  <> [0/0/0]
    # Date de début d'amortissement renseignée avec la date de mise en service
    Case func TRTFAS.GET_DPRSTRDAT_TYP(VALEUR, [M:FASC]CPY2)
      When GVML_TITSDAT : [M:FASM]STRDPRDAT(nolign-1) = [M:FASC]ITSDATD
      When Default
    Endcase
    Affzo [M:FASM]STRDPRDAT(nolign-1)
  Endif

 #<<<<<<Fq-89463 Cas du changement de méthode unitaire
 If ( ACTTYPGES <>  GTAMMAS )
    Local Integer  I_FIS :  I_FIS=find(G301FIS,[M:FASM]DPRPLND)
    Local Integer  I_SUB :  I_SUB=find(G301SUB,[M:FASM]DPRPLND)
     # Pour le plan de subvention la durée doit être égale à celle du plan fiscal
     # si le paramètre FRADGI = "oui"
    If ( [M:FASM]DPRPLND(nolign-1) = G301SUB ) and ( GFRADGI=G_OUI ) and ( I_FIS > 0 )
       If ( [M:FASM]DPMO(nolign-1) = G_DPMSA  and VALEUR <> G_DPMSA )
          If [M:FASM]DPRDURD(I_FIS-1) > 0 and
&            [M:FASM]DPMO(I_FIS-1) <> G_DPMSA or ([M:FASM]DPMD(I_FIS-1) <> G_DPMSA and [M:FASM]DPMD(I_FIS-1) <> "")
              GERR= 1: GMESSAGE = mess(819,GML_MSGFAS,1)
          Endif
       Endif
    Endif
    # Pour le plan fiscal la durée doit être égale à celle du plan de subvention
    If ( [M:FASM]DPRPLND(nolign-1) = G301FIS ) and ( GFRADGI=G_OUI ) and ( I_SUB > 0 )
       If ( [M:FASM]DPMO(nolign-1) = G_DPMSA  and VALEUR <> G_DPMSA )
          If [M:FASM]DPRDURD(I_SUB-1) > 0 and
&            [M:FASM]DPMO(I_SUB-1) <> G_DPMSA or ([M:FASM]DPMD(I_SUB-1) <> G_DPMSA and [M:FASM]DPMD(I_SUB-1) <> "")
             GERR= 1: GMESSAGE = mess(819,GML_MSGFAS,1)
          Endif
       Endif
    Endif
 Endif
 #Fq-89463>>>>>> Cas du changement de méthode unitaire

 [M:FASM]MTCFLG(nolign-1) =
&   func TRTFASMTC.DETERM_MTCFLG
&    (  VALEUR,                      [M:FASM]RSDFLG(nolign-1),     [M:FASM]DURFLG(nolign-1),
&      [M:FASM]DPRRATFLGD(nolign-1), [M:FASM]DPRRA2FLGD(nolign-1), [M:FASM]STRFLG(nolign-1),
&      [M:FASM]RSDVALFLG(nolign-1),  [M:FASM]ALWFLG(nolign-1),     [M:FASM]VEHFLG(nolign-1),
&      [M:FASM]PRATYPFLG(nolign-1),  [M:FASM]ACLCOEFLG(nolign-1),  nolign )
   Gosub COND_GESTION_ECART
  # Nécessaire pour le test dans l'action setbout

 [M:FASM]DPMD(nolign-1) = VALEUR
End
#########################################################################
Subprog AS_ENDDPRFLG(VALEUR)
Variable Integer VALEUR

  If ( ACTTYPGES=GTAMUNI )
     # Si mode RE/prorata jour ou RA prorata jour ==> date de fin d'amortissement peut être forcée
     # -- Fin d'amortissement  FQ89194
#     If  ( [M:FASM]PRATYPD(nolign-1)=GVML_TPJOUR) or
#&         ([M:FASM]PRATYPD(nolign-1)=0 and [M:FASM]PRATYPO(nolign-1)=GVML_TPJOUR )  and
#&        (([M:FASM]DPMD(nolign-1) <> "" )  and  ( [M:FASM]DPMD(nolign-1)= G_DPMRE  or [M:FASM]DPMD(nolign-1)= G_DPMRA )  or
#&         ([M:FASM]DPMD(nolign-1) = ""  )  and  ( [M:FASM]DPMO(nolign-1)= G_DPMRE  or [M:FASM]DPMO(nolign-1)= G_DPMRA ) )
     # Issue 116168 - POR-idem for methods PC and PC
     If  ( ([M:FASM]PRATYPD(nolign-1)=GVML_TPJOUR or ([M:FASM]PRATYPD(nolign-1)=0 and [M:FASM]PRATYPO(nolign-1)=GVML_TPJOUR) )  and
&     (  ([M:FASM]DPMD(nolign-1) <> "" )  and  ( [M:FASM]DPMD(nolign-1)= G_DPMRE  or [M:FASM]DPMD(nolign-1)= G_DPMRA )  or
&        ([M:FASM]DPMD(nolign-1) = ""  )  and  ( [M:FASM]DPMO(nolign-1)= G_DPMRE  or [M:FASM]DPMO(nolign-1)= G_DPMRA )  )   or
&     (  ([M:FASM]DPMD(nolign-1) <> "" )  and  ( [M:FASM]DPMD(nolign-1)= G_DPMPC  or [M:FASM]DPMD(nolign-1)= G_DPMPD )  or
&        ([M:FASM]DPMD(nolign-1) = ""  )  and  ( [M:FASM]DPMO(nolign-1)= G_DPMPC  or [M:FASM]DPMO(nolign-1)= G_DPMPD )  )    )
         Actzo [M:FASM]ENDDPRFLG(nolign-1)
     Else
        [M:FASM]ENDDPRFLG(nolign-1)  = G_NON
        Diszo [M:FASM]ENDDPRDATD(nolign-1)
        Diszo [M:FASM]ENDDPRFLG(nolign-1)
     Endif
     Affzo [M:FASM]ENDDPRDATD(nolign-1)
  Else
    # FQ82178
    Actzo [M:FASM]ENDDPRFLG(nolign-1)
#   [M:FASM]ENDDPRFLG(nolign-1)  = G_NON
#   Effzo [M:FASM]ENDDPRDATD(nolign-1)
#   Diszo [M:FASM]ENDDPRFLG(nolign-1)
   Endif

End
######################################################################################
Subprog AM_ENDDPRFLG(VALEUR)
Variable Integer VALEUR

  If ( VALEUR <> G_OUI )
    Effzo [M:FASM]ENDDPRDATD(nolign-1)
    Actzo [M:FASM]DURFLG(nolign-1)
  Endif

  [M:FASM]ENDDPRFLG(nolign-1) = VALEUR

  #FQ84741
  If dim(GFXDNBERR) > 0
    If ACTMETNAM = "FASTRFC" and VALEUR = G_OUI
      # FQ90828 : ajout de l'indice
      Actzo [M:FASM]ENDDPRDATD(nolign - 1)
    Endif
  Endif

End
######################################################################################
Subprog C_ENDDPRDATD(VALEUR)
Variable Date    VALEUR

 If VALEUR >= [01/01/2200]
  GERR= 1: GMESSAGE = mess(537,GML_MSGFAS,1)-format$("D:" + GFMDAT4,[01/01/2200])
  mkstat = 2 : End
 Endif

End
#########################################################################
Subprog AM_ENDDPRDATD(VALEUR)
Variable Date    VALEUR
  If ( VALEUR < [M:FASM]FIYSTRDAT(nolign-1) )
    # La date de fin d'amortissement saisie ne peut pas être antérieure à la date de début d'exercice courant
    GMESSAGE = mess(695,GML_MSGFAS,1)
    GERR=1: mkstat = 2: End
  Endif

  If ( ACTTYPGES=GTAMUNI ) # Issue 116168
    # FQ82178
    If VALEUR <> [M:FASM]ENDDPRDAT(nolign-1)
      # Issue 116168 - not for methods PC and PC
      If (find([M:FASM]DPMO(nolign-1), G_DPMPC, G_DPMPD) = 0 ) or
&        ( ( find([M:FASM]DPMO(nolign-1), G_DPMPC, G_DPMPD) > 0  ) and
&          ( find([M:FASM]DPMD(nolign-1), "", G_DPMPC, G_DPMPD) =  0 ) )
        [M:FASM]DURFLG(nolign-1)= G_OUI
        Diszo [M:FASM]DURFLG(nolign-1)
        [M:FASM]DPRDURD(nolign-1)= 0
        Diszo [M:FASM]DPRDURD(nolign-1)
        Diszo [M:FASM]PRATYPFLG(nolign-1)
      Endif
   Else
     [M:FASM]DURFLG(nolign-1)= G_NON
     Actzo [M:FASM]DURFLG(nolign-1)
     Actzo [M:FASM]DPRDURD(nolign-1)
     [M:FASM]PRATYPFLG(nolign-1)= G_NON
     Actzo [M:FASM]PRATYPFLG(nolign-1)
   Endif
  Endif

  # Nécessaire pour le test dans l'action setbout
  [M:FASM]ENDDPRDATD(nolign-1)  = VALEUR
  [M:FASM]MTCFLG(nolign-1)      = G_OUI

End
##########################################################################
Subprog AM_DURFLG(VALEUR)
Variable Integer VALEUR

  If ( ACTMETNAM = "FASMTC"  )
     If ( VALEUR <> G_OUI  )
       Diszo [M:FASM]DPRDURD(nolign-1)
     Else
        Actzo [M:FASM]DPRDURD(nolign-1)
     Endif
  Endif
  #
  If dim(GFXDNBERR) > 0
    If ACTMETNAM = "FASTRFC" and VALEUR = G_OUI
      # FQ90828 : ajout de l'indice
      Actzo [M:FASM]DPRDURD(nolign-1)
    Endif
  Endif
Affzo [M:FASM]DPRDURD(nolign-1)

 [M:FASM]MTCFLG(nolign-1) =
&   func TRTFASMTC.DETERM_MTCFLG
&    ( [M:FASM]DPMD(nolign-1),       [M:FASM]RSDFLG(nolign-1),     VALEUR,
&      [M:FASM]DPRRATFLGD(nolign-1), [M:FASM]DPRRA2FLGD(nolign-1), [M:FASM]STRFLG(nolign-1),
&      [M:FASM]RSDVALFLG(nolign-1),  [M:FASM]ALWFLG(nolign-1),     [M:FASM]VEHFLG(nolign-1),
&      [M:FASM]PRATYPFLG(nolign-1),  [M:FASM]ACLCOEFLG(nolign-1),  nolign )
   Gosub COND_GESTION_ECART

End
#########################################################################
Subprog C_DPRDURD(VALEUR)
Variable Decimal VALEUR

 Local Integer LERROR
 # Détermination de la société
 Local Char L_CPY
 If ACTTYPGES=GTAMMAS
   L_CPY = [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)
 Else
   L_CPY = [M:FAS0]CPY
 Endif

  #Fq-87928
  GFRADGI = G_NON
  If func AFNC.PARAM("FRADGI", L_CPY) = num$(G_OUI)
     GFRADGI = G_OUI
  Endif

  #Fq-87928  If ( ACTMETNAM = "FASMTC" and  ACTTYPGES <> GTAMMAS) and  (func GLOFCYCPY.GET_SOC_LEG(L_CPY) = "FRA")
  If  (ACTTYPGES <> GTAMMAS) and ( GFRADGI=G_OUI )
     Local Integer  I_SUB :  I_SUB=find(G301SUB,[M:FASM]DPRPLND)
     Local Integer  I_FIS :  I_FIS=find(G301FIS,[M:FASM]DPRPLND)
     If ( ACTMETNAM = "FASMTC" )
       If  ( [M:FASM]DPRPLND(nolign-1) = G301FIS )
          If I_SUB > 0
             If ( [M:FASM]DPRDURD(I_SUB-1)<> 0 and [M:FASM]DPRDURD(I_SUB-1) <> [M:FASM]DPRDURO(I_SUB-1) and  [M:FASM]DPRDURD(I_SUB-1) <> VALEUR ) or
&                ( [M:FASM]DPRDURD(I_SUB-1)= 0 and   VALEUR <> [M:FASM]DPRDURO(I_SUB-1) ) and
&                ( ( [M:FASM]DPMD(I_SUB-1) <> G_DPMSA and [M:FASM]DPMD(I_SUB-1) <> "") or  ([M:FASM]DPMO(I_SUB-1) <> G_DPMSA))
                GERR= 1: GMESSAGE = mess(819,GML_MSGFAS,1)
                [M:FASM]DPRDURD(nolign-1) = VALEUR
                [M:FASM]MTCFLG(nolign-1) =  G_NON
                [M:FASM]MTCFLG(I_SUB-1)  =  G_NON
             Else
                [M:FASM]MTCFLG(nolign-1) =  G_OUI
                [M:FASM]MTCFLG(I_SUB-1)  =  G_OUI
             Endif
          Endif
       Else
       If  ( [M:FASM]DPRPLND(nolign-1) = G301SUB )
          If I_FIS > 0
             If  [M:FASM]DPMO(I_FIS-1) <> G_DPMSA or ([M:FASM]DPMD(I_FIS-1) <> G_DPMSA and [M:FASM]DPMD(I_FIS-1) <> "")
                If ([M:FASM]DPRDURD(I_FIS-1)<> 0  and [M:FASM]DPRDURD(I_FIS-1) <> [M:FASM]DPRDURO(I_FIS-1) and  [M:FASM]DPRDURD(I_FIS-1) <> VALEUR ) or
&                      ( [M:FASM]DPRDURD(I_FIS-1)= 0 and   VALEUR <> [M:FASM]DPRDURO(I_FIS-1) ) and
&                      ( ( [M:FASM]DPMD(I_FIS-1) <> G_DPMSA and [M:FASM]DPMD(I_FIS-1) <> "") or  ([M:FASM]DPMO(I_FIS-1) <> G_DPMSA))
                   GERR= 1 : GMESSAGE = mess(819,GML_MSGFAS,1)
                   [M:FASM]DPRDURD(nolign-1) = VALEUR
                   [M:FASM]MTCFLG(nolign-1) =  G_NON
                   [M:FASM]MTCFLG(I_FIS-1)  =  G_NON
                Else
                   [M:FASM]MTCFLG(nolign-1) =  G_OUI
                   [M:FASM]MTCFLG(I_FIS-1)  =  G_OUI
                Endif
             Endif
          Endif
        Endif
       Endif
     Endif
     #-----------------------------------------------------------------
     #Fq-87928 : contrôle si l'on vient du Chgt d'imputation comptable
     If ( ACTMETNAM = "FASTRFC" )
        If  ( [M:FASM]DPRPLND(nolign-1) = G301FIS )
           If I_SUB > 0
              If ( [M:FASM]DPRDURD(I_SUB-1)<> 0 and  [M:FASM]DPRDURD(I_SUB-1) <> VALEUR )
                 GERR= 1: GMESSAGE = mess(819,GML_MSGFAS,1)
                 mkstat=2
                 [M:FASM]DPRDURD(nolign-1) = VALEUR
                 [M:FASM]MTCFLG(nolign-1) =  G_NON
                 [M:FASM]MTCFLG(I_SUB-1)  =  G_NON
              Else
                 [M:FASM]MTCFLG(nolign-1) =  G_OUI
                 [M:FASM]MTCFLG(I_SUB-1)  =  G_OUI
              Endif
           Endif
        Else
           If  ( [M:FASM]DPRPLND(nolign-1) = G301SUB )
              If I_FIS > 0
                 If ([M:FASM]DPRDURD(I_FIS-1)<> 0   and  [M:FASM]DPRDURD(I_FIS-1) <> VALEUR )
                    GERR= 1 : GMESSAGE = mess(819,GML_MSGFAS,1)
                    mkstat=2
                    [M:FASM]DPRDURD(nolign-1) = VALEUR
                    [M:FASM]MTCFLG(nolign-1) =  G_NON
                    [M:FASM]MTCFLG(I_FIS-1)  =  G_NON
                 Else
                    [M:FASM]MTCFLG(nolign-1) =  G_OUI
                    [M:FASM]MTCFLG(I_FIS-1)  =  G_OUI
                 Endif
              Endif
           Endif
        Endif
     Endif #Fq-87928
  Endif

End
#=============================
Subprog AM_DPRDURD(VALEUR)
Variable Decimal VALEUR
Local Integer OK

  #*FQ-76303
  If VALEUR <>  [M:FASM]DPRDURD(nolign-1)
     If [M:FASM]DPRRATFLGO(nolign-1)= G_OUI
        # Le taux est forcé. Recalcul du taux pour la nouvelle durée ?
        Call OUINON(mess(843,GML_MSGFAS,1), OK) From GESECRAN
        If ( OK <>  1 )  # oui=recalcul
           [M:FASM]DEFORCERAT(nolign-1)= G_OUI # FQ94929
           [M:FASM]DPRRATD(nolign-1)= 0
           [M:FASM]DPRRATFLGD(nolign-1)= G_NON
           Affzo [M:FASM]DPRRATD(nolign-1)
           Affzo [M:FASM]DPRRATFLGD(nolign-1)
        Else # non= le taux garde l'ancienne valeur
           # FQ94929
           # [M:FASM]DPRRATD(nolign-1)   =  [M:FASM]DPRRATFLGO(nolign-1)
           [M:FASM]DPRRATD(nolign-1)   =  [M:FASM]DPRRATO(nolign-1)
           Affzo [M:FASM]DPRRATD(nolign-1)
           [M:FASM]DPRRATFLGD(nolign-1)= [M:FASM]DPRRATFLGO(nolign-1)
           Affzo [M:FASM]DPRRATFLGD(nolign-1)
        Endif
     Else
        # Si modif de la durée, le taux est remis à zéro : sera recalculé ?
        [M:FASM]DPRRATD(nolign-1)= 0
        Affzo [M:FASM]DPRRATD(nolign-1)
     Endif
  Endif

  # Nécessaire pour le test dans l'action setbout
  [M:FASM]DPRDURD(nolign-1) = VALEUR

End
##########################################################################
Subprog AM_DPRRATFLGD(VALEUR)
Variable Integer VALEUR

If ( ACTMETNAM = "FASMTC" )
  If ( VALEUR <> G_OUI )
    Effzo [M:FASM]DPRRATD(nolign-1)
  Else
    Actzo [M:FASM]DPRRATD(nolign-1)
  Endif
Endif

  #FQ84741
  If dim(GFXDNBERR) > 0
    If ACTMETNAM = "FASTRFC" and VALEUR = G_OUI
      # FQ90828 : ajout de l'indice
      Actzo [M:FASM]DPRRATD(nolign - 1)
    Endif
  Endif

 [M:FASM]MTCFLG(nolign-1) =
&   func TRTFASMTC.DETERM_MTCFLG
&    ( [M:FASM]DPMD(nolign-1),      [M:FASM]RSDFLG(nolign-1),     [M:FASM]DURFLG(nolign-1),
&       VALEUR,                     [M:FASM]DPRRA2FLGD(nolign-1), [M:FASM]STRFLG(nolign-1),
&      [M:FASM]RSDVALFLG(nolign-1), [M:FASM]ALWFLG(nolign-1),     [M:FASM]VEHFLG(nolign-1),
&      [M:FASM]PRATYPFLG(nolign-1), [M:FASM]ACLCOEFLG(nolign-1),  nolign )
   Gosub COND_GESTION_ECART

End
######################################################################################
Subprog C_DPRRATD(VALEUR)
Variable Decimal VALEUR

If ( ACTMETNAM = "FASTRFC"   and [M:FASM]DPMD(nolign-1)<> "" ) or
&  ( ACTMETNAM = "FASMTC"    and ([M:FASM]DPMD(nolign-1)<> "" ) and
&                                ([M:FASM]DPMD(nolign-1)<> [M:FASM]DPMO(nolign-1)) )
   If (find ([M:FASM]DPMD(nolign-1),  G_DPMUL, G_DPMCA, G_DPMDA, G_DPMUD, G_DPMTD, G_DPMDE, G_DPMDF, G_DPMDX, G_DPMDP,
&                                     G_DPMDI, G_DPMRE, G_DPMFM, G_DPMLG, G_DPMPR, G_DPMSA, G_DPMSY, G_DPMUO,
&                                     G_DPMRX, G_DPMRD, G_DPMAL, G_DPMAD, G_DPMHL,
&                                     G_DPMDV, G_DPMRA, G_DPMDM, G_DPMML, G_DPMMD) <> 0   and   VALEUR <> 0  )
      # Pour ce mode, le taux ne doit pas être renseigné.  FQ72372 FQ76303 FQ77877 FQ84283 FQ84281 FQ105809
      VALEUR = 0
      [M:FASM]DPRRATFLGD(nolign-1) = G_NON    : Affzo [M:FASM]DPRRATFLGD(nolign-1)
      GERR=1: GMESSAGE = mess(121,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif
Endif

End
#=============================
Subprog AM_DPRRATD(VALEUR)
Variable Decimal VALEUR

  If ( VALEUR > 1 or VALEUR < 0 )
    GERR= 1: GMESSAGE = mess(83,123,1)
    mkstat = 2 : End
  Endif

  #- Mise à jour auto de l'anticipato ou message ?
  If varmode([M:FASM]DPRRA2FLGD)=0
   If [M:FASM]DPRRAT2D(nolign-1)>VALEUR
    [M:FASM]DPRRAT2D(nolign-1)=VALEUR
    Affzo [M:FASM]DPRRAT2D(nolign-1)
   Endif
  Endif

  # Nécessaire pour le test dans l'action setbout
  [M:FASM]DPRRATD(nolign-1) = VALEUR

End

######################################################################################
Subprog AV_DPRRA2FLGD(VALEUR)
Variable Integer VALEUR

   # Si on ne trouve pas de société sélectionnée, on sort
   If ACTTYPGES=GTAMMAS & find(G_OUI,[M:MHC]FLGCPY)=0
     End
   Endif

   # Détermination de la société
   Local Char L_CPY
   If ACTTYPGES=GTAMMAS
     L_CPY = [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)
   Else
     L_CPY = [M:FAS0]CPY
   Endif

   # FQ84281
   Local Char PAYSIT(GLONCRY)
   Local Char PAYSLR(GLONCRY)
   Local Char PAYSDR(GLONCRY)
   Local Char PAYSCR(GLONCRY)
   Local Char PAYSAL(GLONCRY)
   Local Char PAYSAD(GLONCRY)
   PAYSIT = func TRTFAS.GET_MODE_PAYS( "", "IT" )
   PAYSLR = func TRTFAS.GET_MODE_PAYS( "", "LR" )
   PAYSDR = func TRTFAS.GET_MODE_PAYS( "", "DR" )
   PAYSCR = func TRTFAS.GET_MODE_PAYS( "", "CR" )
   PAYSAL = func TRTFAS.GET_MODE_PAYS( "", "AL" )
   PAYSAD = func TRTFAS.GET_MODE_PAYS( "", "AD" )

   Local Char LEGIT
   Local Char LEGLR
   Local Char LEGDR
   Local Char LEGCR
   Local Char LEGAL
   Local Char LEGAD
   LEGIT = func TRTFAS.GET_MODE_LEGISLATION( "", "IT" )
   LEGLR = func TRTFAS.GET_MODE_LEGISLATION( "", "LR" )
   LEGDR = func TRTFAS.GET_MODE_LEGISLATION( "", "DR" )
   LEGCR = func TRTFAS.GET_MODE_LEGISLATION( "", "CR" )
   LEGAL = func TRTFAS.GET_MODE_LEGISLATION( "", "AL" )
   LEGAD = func TRTFAS.GET_MODE_LEGISLATION( "", "AD" )

   If (
&     (  (PAYSIT = "" or ( PAYSIT <> "" and func GLOFCYCPY.GET_SOC_PAYS(L_CPY) = PAYSIT )) and
&        (LEGIT  = "" or ( LEGIT  <> "" and func GLOFCYCPY.GET_SOC_LEG (L_CPY) = LEGIT  )) )
&  or (  (PAYSLR = "" or ( PAYSLR <> "" and func GLOFCYCPY.GET_SOC_PAYS(L_CPY) = PAYSLR )) and
&        (LEGLR  = "" or ( LEGLR  <> "" and func GLOFCYCPY.GET_SOC_LEG (L_CPY) = LEGLR  )) )
&  or (  (PAYSDR = "" or ( PAYSDR <> "" and func GLOFCYCPY.GET_SOC_PAYS(L_CPY) = PAYSDR )) and
&        (LEGDR  = "" or ( LEGDR  <> "" and func GLOFCYCPY.GET_SOC_LEG (L_CPY) = LEGDR  )) )
&  or (  (PAYSCR = "" or ( PAYSCR <> "" and func GLOFCYCPY.GET_SOC_PAYS(L_CPY) = PAYSCR )) and
&        (LEGCR  = "" or ( LEGCR  <> "" and func GLOFCYCPY.GET_SOC_LEG (L_CPY) = LEGCR  )) )
&  or (  (PAYSAL = "" or ( PAYSAL <> "" and func GLOFCYCPY.GET_SOC_PAYS(L_CPY) = PAYSAL )) and
&        (LEGAL  = "" or ( LEGAL  <> "" and func GLOFCYCPY.GET_SOC_LEG (L_CPY) = LEGAL  )) )
&  or (  (PAYSAD = "" or ( PAYSAD <> "" and func GLOFCYCPY.GET_SOC_PAYS(L_CPY) = PAYSAD )) and
&        (LEGAD  = "" or ( LEGAD  <> "" and func GLOFCYCPY.GET_SOC_LEG (L_CPY) = LEGAD  )) )
& ) Then
   Chgfmt [M:FASM]DPRRAT2D   With "N:3.6#"
   Chgfmt [M:FASM]DPRRA2FLGD With "LO:1X"
 Else
    Chgfmt [M:FASM]DPRRAT2D   With "-N:3.6#"
    Chgfmt [M:FASM]DPRRA2FLGD With "-LO:1X"
 Endif

End
#=============================
Subprog AM_DPRRA2FLGD(VALEUR)
Variable Integer VALEUR

  If ( ACTMETNAM = "FASMTC" )
    If ( VALEUR <> G_OUI  )
      Effzo [M:FASM]DPRRAT2D(nolign-1)
    Else
      Actzo [M:FASM]DPRRAT2D(nolign-1)
    Endif
  Endif

  #FQ84741
  If dim(GFXDNBERR) > 0
    If ACTMETNAM = "FASTRFC" and VALEUR = G_OUI
      # FQ90828 : ajout de l'indice
      Actzo [M:FASM]DPRRAT2D(nolign - 1)
    Endif
  Endif

 [M:FASM]MTCFLG(nolign-1) =
&   func TRTFASMTC.DETERM_MTCFLG
&    ( [M:FASM]DPMD(nolign-1),       [M:FASM]RSDFLG(nolign-1),    [M:FASM]DURFLG(nolign-1),
&      [M:FASM]DPRRATFLGD(nolign-1), VALEUR,                      [M:FASM]STRFLG(nolign-1),
&      [M:FASM]RSDVALFLG(nolign-1),  [M:FASM]ALWFLG(nolign-1),    [M:FASM]VEHFLG(nolign-1),
&      [M:FASM]PRATYPFLG(nolign-1),  [M:FASM]ACLCOEFLG(nolign-1), nolign )
   Gosub COND_GESTION_ECART

End
######################################################################################
Subprog AV_DPRRAT2D(VALEUR)
Variable Decimal VALEUR

 # Si on ne trouve pas de société sélectionnée, on sort
 If ACTTYPGES=GTAMMAS & find(G_OUI,[M:MHC]FLGCPY)=0
  End
 Endif

 # Détermination de la société
 Local Char L_CPY
 If ACTTYPGES=GTAMMAS
  L_CPY = [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)
 Else
  L_CPY = [M:FAS0]CPY
 Endif


 # Affichage ou effacement de la colonne en fonction de la société sélectionnée
   # FQ84281
   Local Char PAYSIT(GLONCRY)
   Local Char PAYSLR(GLONCRY)
   Local Char PAYSDR(GLONCRY)
   Local Char PAYSCR(GLONCRY)
   Local Char PAYSAL(GLONCRY)
   Local Char PAYSAD(GLONCRY)
   PAYSIT = func TRTFAS.GET_MODE_PAYS( "", "IT" )
   PAYSLR = func TRTFAS.GET_MODE_PAYS( "", "LR" )
   PAYSDR = func TRTFAS.GET_MODE_PAYS( "", "DR" )
   PAYSCR = func TRTFAS.GET_MODE_PAYS( "", "CR" )
   PAYSAL = func TRTFAS.GET_MODE_PAYS( "", "AL" )
   PAYSAD = func TRTFAS.GET_MODE_PAYS( "", "AD" )

   Local Char LEGIT
   Local Char LEGLR
   Local Char LEGDR
   Local Char LEGCR
   Local Char LEGAL
   Local Char LEGAD
   LEGIT = func TRTFAS.GET_MODE_LEGISLATION( "", "IT" )
   LEGLR = func TRTFAS.GET_MODE_LEGISLATION( "", "LR" )
   LEGDR = func TRTFAS.GET_MODE_LEGISLATION( "", "DR" )
   LEGCR = func TRTFAS.GET_MODE_LEGISLATION( "", "CR" )
   LEGAL = func TRTFAS.GET_MODE_LEGISLATION( "", "AL" )
   LEGAD = func TRTFAS.GET_MODE_LEGISLATION( "", "AD" )

   If (
&     (  (PAYSIT = "" or ( PAYSIT <> "" and func GLOFCYCPY.GET_SOC_PAYS(L_CPY) = PAYSIT )) and
&        (LEGIT  = "" or ( LEGIT  <> "" and func GLOFCYCPY.GET_SOC_LEG (L_CPY) = LEGIT  )) )
&  or (  (PAYSLR = "" or ( PAYSLR <> "" and func GLOFCYCPY.GET_SOC_PAYS(L_CPY) = PAYSLR )) and
&        (LEGLR  = "" or ( LEGLR  <> "" and func GLOFCYCPY.GET_SOC_LEG (L_CPY) = LEGLR  )) )
&  or (  (PAYSDR = "" or ( PAYSDR <> "" and func GLOFCYCPY.GET_SOC_PAYS(L_CPY) = PAYSDR )) and
&        (LEGDR  = "" or ( LEGDR  <> "" and func GLOFCYCPY.GET_SOC_LEG (L_CPY) = LEGDR  )) )
&  or (  (PAYSCR = "" or ( PAYSCR <> "" and func GLOFCYCPY.GET_SOC_PAYS(L_CPY) = PAYSCR )) and
&        (LEGCR  = "" or ( LEGCR  <> "" and func GLOFCYCPY.GET_SOC_LEG (L_CPY) = LEGCR  )) )
&  or (  (PAYSAL = "" or ( PAYSAL <> "" and func GLOFCYCPY.GET_SOC_PAYS(L_CPY) = PAYSAL )) and
&        (LEGAL  = "" or ( LEGAL  <> "" and func GLOFCYCPY.GET_SOC_LEG (L_CPY) = LEGAL  )) )
&  or (  (PAYSAD = "" or ( PAYSAD <> "" and func GLOFCYCPY.GET_SOC_PAYS(L_CPY) = PAYSAD )) and
&        (LEGAD  = "" or ( LEGAD  <> "" and func GLOFCYCPY.GET_SOC_LEG (L_CPY) = LEGAD  )) )
& ) Then
    Chgfmt [M:FASM]DPRRAT2D With "N:3.6#"
    Chgfmt [M:FASM]DPRRA2FLGD With "LO:1X"
    If  [M:FASM]DPMD(nolign-1) = G_DPMSA
        [M:FASM]DPRRAT2D(nolign-1) = 0
        [M:FASM]DPRRA2FLGD(nolign-1) = G_NON
    Endif
 Else
   Chgfmt [M:FASM]DPRRAT2D With "-N:3.6#"
   Chgfmt [M:FASM]DPRRA2FLGD With "-LO:1X"
 Endif

End
#=============================
Subprog C_DPRRAT2D(VALEUR)
Variable Decimal VALEUR

  # Taux ne peut être ni supérieur à 1 ni négatif
  If ( VALEUR > 1 or VALEUR < 0 )
    GERR= 1: GMESSAGE = mess(83,123,1)
    mkstat = 2 : End
  Endif

  # Taux Anticipato ne peut être supérieur au taux Ordinario
  If ( (VALEUR<>0) & ([M:FASM]DPRRATD(nolign-1)<>0) & (VALEUR > ([M:FASM]DPRRATD(nolign-1))) )
     # "Le taux anticipato ne peut être supérieur au taux ordinario"
     GERR=1: GMESSAGE = mess(483,GML_MSGFAS,1)
     mkstat = 2 : End
  Endif

End
##########################################################################
Subprog AV_RSDVALFLG(VALEUR)
Variable Integer VALEUR
  If (ACTTYPGES = GTAMMAS )
    VALEUR = G_NON
    Chgfmt [M:FASM]RSDVALFLG(nolign-1) With "-LO:1X"
  Endif
End
#=============================
Subprog AM_RSDVALFLG(VALEUR)
Variable Integer VALEUR

  If (VALEUR <> G_OUI )
    Effzo [M:FASM]RSDVALD(nolign-1)
  Else
    Actzo [M:FASM]RSDVALD(nolign-1)
  Endif

  #FQ84741
  If dim(GFXDNBERR) > 0
    If ACTMETNAM = "FASTRFC" and VALEUR = G_OUI
      # FQ90828 : ajout de l'indice
      Actzo [M:FASM]RSDVALD(nolign - 1)
    Endif
  Endif

 [M:FASM]MTCFLG(nolign-1) =
&   func TRTFASMTC.DETERM_MTCFLG
&    ( [M:FASM]DPMD(nolign-1),       [M:FASM]RSDFLG(nolign-1),    [M:FASM]DURFLG(nolign-1),
&      [M:FASM]DPRRATFLGD(nolign-1), [M:FASM]DPRRA2FLGD(nolign-1),[M:FASM]STRFLG(nolign-1),
&       VALEUR,                      [M:FASM]ALWFLG(nolign-1),    [M:FASM]VEHFLG(nolign-1),
&      [M:FASM]PRATYPFLG(nolign-1),  [M:FASM]ACLCOEFLG(nolign-1), nolign )
   Gosub COND_GESTION_ECART

End
##########################################################################
Subprog AV_RSDVALD(VALEUR)
Variable Decimal VALEUR

  If (ACTTYPGES = GTAMMAS )
    VALEUR = 0
    GMD1 = "-Nz3:"+GDEVFMT1(max(find([M]CURD(nolign-1),GDEVISE(1..GNBDEV)),1))
  Else
    GMD1 = "Nz3:"+GDEVFMT1(max(find([M]CURD(nolign-1),GDEVISE(1..GNBDEV)),1))
  Endif
End
#=============================
Subprog AM_RSDVALD(VALEUR)
Variable Decimal VALEUR
End
#=============================
Subprog AS_VEHFLG(VALEUR)
Variable Integer VALEUR

  If [M:FASM]DPRPLND(nolign-1) <> G301FIS
     VALEUR = G_NON
     GMENLOC(2) = 1
  Endif
End
##########################################################################
Subprog AM_VEHFLG(VALEUR)
Variable Integer VALEUR

If ( ACTMETNAM = "FASMTC" )
  If ( VALEUR <> G_OUI  )
     Effzo [M:FASM]CRBVEHCODD(nolign-1)
  Else
     Actzo [M:FASM]CRBVEHCODD(nolign-1)
  Endif
Endif

  #FQ84741
  If dim(GFXDNBERR) > 0
    If ACTMETNAM = "FASTRFC" and VALEUR = G_OUI
      # FQ90828 : ajout de l'indice
      Actzo [M:FASM]CRBVEHCODD(nolign - 1)
    Endif
  Endif

 [M:FASM]MTCFLG(nolign-1) =
&   func TRTFASMTC.DETERM_MTCFLG
&    ( [M:FASM]DPMD(nolign-1),       [M:FASM]RSDFLG(nolign-1),    [M:FASM]DURFLG(nolign-1),
&      [M:FASM]DPRRATFLGD(nolign-1), [M:FASM]DPRRA2FLGD(nolign-1),[M:FASM]STRFLG(nolign-1),
&      [M:FASM]RSDVALFLG(nolign-1),  [M:FASM]ALWFLG(nolign-1),    VALEUR,
&      [M:FASM]PRATYPFLG(nolign-1),  [M:FASM]ACLCOEFLG(nolign-1), nolign )
   Gosub COND_GESTION_ECART

End
##########################################################################
Subprog AM_ALWFLG(VALEUR)
Variable Integer VALEUR

If ( ACTMETNAM = "FASMTC" )
  If ( VALEUR <> G_OUI  )
     Effzo [M:FASM]ALWCODD(nolign-1)
  Else
     Actzo [M:FASM]ALWCODD(nolign-1)
     Diszo [M:FASM]ALWAMT(nolign-1)
  Endif
Affzo  [M:FASM]ALWCODD(nolign-1)
Endif

  #FQ84741
  If dim(GFXDNBERR) > 0
    If ACTMETNAM = "FASTRFC" and VALEUR = G_OUI
      # FQ90828 : ajout de l'indice
      Actzo [M:FASM]ALWCODD(nolign - 1)
    Endif
  Endif

 [M:FASM]MTCFLG(nolign-1) =
&   func TRTFASMTC.DETERM_MTCFLG
&    ( [M:FASM]DPMD(nolign-1),       [M:FASM]RSDFLG(nolign-1),     [M:FASM]DURFLG(nolign-1),
&      [M:FASM]DPRRATFLGD(nolign-1), [M:FASM]DPRRA2FLGD(nolign-1), [M:FASM]STRFLG(nolign-1),
&      [M:FASM]RSDVALFLG(nolign-1),  VALEUR,                       [M:FASM]VEHFLG(nolign-1),
&      [M:FASM]PRATYPFLG(nolign-1),  [M:FASM]ACLCOEFLG(nolign-1),  nolign )
   Gosub COND_GESTION_ECART

End
##########################################################################
Subprog AS_ALWCODD(VALEUR)
Variable Integer VALEUR

  Local  Char PCLASSE
  Local  Char PNOMVAR, PNOMVAR2
  Global Char G_COURDPM, G_COURPLN
  #FQ82523
  Local Integer WB_MODE_RENSEIGNE
  WB_MODE_RENSEIGNE = 0

  G_COURDPM = ""
  G_COURPLN = ""

  PCLASSE    =  "[M:FASM]"
  PNOMVAR    =  "DPMD(nolign-1)"
  G_COURDPM  =   PCLASSE+PNOMVAR

  PNOMVAR2   =  "DPRPLND(nolign-1)"
  G_COURPLN  =   PCLASSE+PNOMVAR2

  #FQ82523
  If [M:FASM]DPMD(nolign-1) = ""
    If dim([M:FASM]DPMO) >= 0
      If [M:FASM]DPMO(nolign-1) <> ""
        PCLASSE    =  "[M:FASM]"
        PNOMVAR    =  "DPMO(nolign-1)"
        G_COURDPM  =   PCLASSE+PNOMVAR
        WB_MODE_RENSEIGNE = 1
      Endif
    Endif
  Else
    WB_MODE_RENSEIGNE = 1
  Endif

#  If ( [M:FASM]DPMD(nolign-1) <> "" )  or ( [M:FASM]DPRPLND(nolign-1) <> G301FIS )
  If ( WB_MODE_RENSEIGNE or [M:FASM]DPRPLND(nolign-1) <> G301FIS )
    Gosub COMMUN_AS_ALWCOD From TRTFAS
  Endif

  # FQ107988
  If ( [M:FASM]DPRPLND(nolign-1) <> G301FIS or func GLOFCYCPY.GET_SOC_LEG([M:FASM]CPY1(nolign-1)) <> "FRA")
    GMENLOC(GVML_RPDED40) = 1   : # Déduction 40 %
  Endif

  G_COURDPM = ""
  G_COURPLN = ""

End
######################################################################################
Subprog AM_ALWCODD(VALEUR)
Variable Integer VALEUR

   If VALEUR = GVML_RPLBABA
      [M:FASM]MTCTIATYP(nolign-1) = GVML_PEDBEX
      Affzo [M:FASM]MTCTIATYP(nolign-1)
      Diszo [M:FASM]MTCTIATYP(nolign-1)
   Endif

   #*X3-61112
  If ( ACTTYPGES=GTAMUNI and  VALEUR = GVML_RPDED40  and [M:FAS1]PURDAT>= [15/04/2017] ) or
&    ( ACTTYPGES=GTAMMAS and  VALEUR = GVML_RPDED40 )
       Local Integer ROK
       # Si la date d'achat est > à la date de fin d'application de la règle particulière,
       # assurez-vous de votre droit à l'appliquer. Confirmez-vous?
       Call OUINON(mess(942,GML_MSGFAS,1)-" "-mess(943,GML_MSGFAS,1),ROK) From GESECRAN
       If (ROK = G_NON)
         zonsui = "[M:FASM]ALWCODD(nolign-1)"
         GERR=1
        mkstat=2 : End
      Endif
     Endif #*X3-61112 End

   [M:FASM]ALWCODD(nolign-1)= VALEUR : Affzo  [M:FASM]ALWCODD(nolign-1)
   If VALEUR <> GVML_RPAUCUN
      # Si une règle fiscale a été précisée, l'aide fiscale va être recalculée donc on la remet à 0.
     [M:FASM]ALWAMT(nolign-1)  = 0      :  Affzo [M:FASM]ALWAMT(nolign-1)
     Diszo[M:FASM]ALWAMT(nolign-1)
   Else
     # Si aucune règle fiscale n'est précisée, l'aide fiscale peut être saisie, après avoir été remise à 0.
     [M:FASM]ALWAMT(nolign-1)  = 0      :  Affzo [M:FASM]ALWAMT(nolign-1)
      Actzo[M:FASM]ALWAMT(nolign-1)
      zonsui = "[M:FASM]ALWAMT(nolign-1)"
   Endif

End
#############################################################################################
Subprog AS_ALWAMT(VALEUR)
Variable Decimal VALEUR

  If (ACTTYPGES <>  GTAMUNI )
    Chgfmt [M:FASM]ALWAMT(nolign-1) With "-LO:1X"
  Else #*X3-61112 +GVML_RPDED40
     If find([M:FASM]ALWCODD(nolign-1), GVML_RPAID25,GVML_RPAID50,GVML_RPAID30,GVML_RPBOI30,
&                                       GVML_RPENERG,GVML_RPMAJ10,GVML_RPDRECH,GVML_RPPR39B,GVML_RPDED40 )
        Effzo [M:FASM]ALWAMT(nolign-1) :  Diszo [M:FASM]ALWAMT(nolign-1)
     Else
        #FQ-61173
        If [M:FASM]ALWFLG(nolign-1) = G_OUI
           Actzo [M:FASM]ALWAMT(nolign-1)
        Else
           Effzo [M:FASM]ALWAMT(nolign-1) :  Diszo [M:FASM]ALWAMT(nolign-1)
        Endif
     Endif
     Affzo [M:FASM]ALWAMT(nolign-1)
  Endif

End

#############################################################################################
Subprog AM_ALWAMT(VALEUR)
Variable Decimal VALEUR

If ( ACTTYPGES =  GTAMUNI )
   If  ( VALEUR <> 0 ) and (VALEUR <> [M:FASM]ALWAMT(nolign-1))
      [M:FASM]ALWAMTFLG(nolign-1)= G_OUI
   Endif
Endif

End
#===========================
Subprog C_ALWAMT(VALEUR)
Variable Decimal VALEUR

Local Char    AASREF
Local Decimal S01VALNET

If ( VALEUR <> 0 ) & ( ACTTYPGES =  GTAMUNI )
   If [M:FASM]ALWCODD(nolign-1) <> GVML_RPAUCUN
      # "Si une règle particulière est définie, il ne peut y avoir de montant d'aide fiscale"
      GERR=1 : GMESSAGE = mess(799,GML_MSGFAS,1)
      mkstat = 2 : End
   Endif
   If !clalev([F:DEPC]) : Local File DEPREC [DEPC] : Endif
   # Lecture DEPREC pour l'exercice et la période courante
      Read [DEPC] DEP0=[M:FAS0]AASREF;[M:FASM]DPRPLND(nolign-1);
&                      [M:FASM]FIYENDDAT(nolign-1); [M:FASM]PERENDDAT(nolign-1)
   If fstat = 0
      Call CAL_VALEUR_NETTE ("RDP",[F:DEPC]DPRBAS, 3, 0, S01VALNET  ) From GLOBB4
      If VALEUR >= S01VALNET
         # "le montant saisi doit être < à la valeur nette début période"
         GERR=1 : GMESSAGE = mess(629,GML_MSGFAS,1)
         mkstat = 2 : End
      Endif
   Endif
Endif

End
######################################################################################
Subprog AM_ACLCOEFLG(VALEUR)
Variable Integer VALEUR

If ( ACTMETNAM = "FASMTC" )
  If ( VALEUR <> G_OUI  )
     Effzo [M:FASM]ACLCOED(nolign-1)
  Else
     Actzo [M:FASM]ACLCOED(nolign-1)
     Affzo [M:FASM]ACLCOED(nolign-1)
  Endif
Endif

  #FQ84741
  If dim(GFXDNBERR) > 0
    If ACTMETNAM = "FASTRFC" and VALEUR = G_OUI
      # FQ90828 : ajout de l'indice
      Actzo [M:FASM]ACLCOED(nolign - 1)
    Endif
  Endif

 [M:FASM]MTCFLG(nolign-1) =
&   func TRTFASMTC.DETERM_MTCFLG
&    ( [M:FASM]DPMD(nolign-1),       [M:FASM]RSDFLG(nolign-1),     [M:FASM]DURFLG(nolign-1),
&      [M:FASM]DPRRATFLGD(nolign-1), [M:FASM]DPRRA2FLGD(nolign-1), [M:FASM]STRFLG(nolign-1),
&      [M:FASM]RSDVALFLG(nolign-1),  [M:FASM]ALWFLG(nolign-1),     [M:FASM]VEHFLG(nolign-1),
&      [M:FASM]PRATYPFLG(nolign-1),   VALEUR,                      nolign )
   Gosub COND_GESTION_ECART

End
##########################################################################
Subprog AS_ACLCOED(VALEUR)
Variable Decimal VALEUR

End
#######################################################################
Subprog AV_ACLCOED(VALEUR)
Variable Decimal VALEUR

  If ( ACTMETNAM = "FASMTC" )
    Local Char PAYSS(GLONCRY)
    PAYSS  = func GLOFCYCPY.GET_SOC_PAYS([M:FASM]CPY1)
    Local Char PAYS1(GLONCRY)
    Local Char PAYS2(GLONCRY)
     Local Char PAYS3(GLONCRY)
    PAYS1 = func TRTFAS.GET_MODE_PAYS( "", "UD" )
    PAYS2 = func TRTFAS.GET_MODE_PAYS( "", "DB" )
    PAYS3 = func TRTFAS.GET_MODE_PAYS( "", "LR" )
    Local Char LEGIS
    LEGIS  = GLEGSOC(find([M:FASM]CPY1,GSOC))
    Local Char LEGI1
    Local Char LEGI2
    Local Char LEGI3
    LEGI1 = func TRTFAS.GET_MODE_LEGISLATION( "", "UD" )
    LEGI2 = func TRTFAS.GET_MODE_LEGISLATION( "", "DB" )
    LEGI3 = func TRTFAS.GET_MODE_LEGISLATION( "", "LR" )

  If ( ( PAYS1 = "" and LEGI1 = "" ) or ( PAYS2 = "" and LEGI2 ="" ) or ( PAYS3 = "" and LEGI3 ="" ) or
&     ( PAYS1 <> "" and PAYSS = PAYS1 and LEGI1 <> "" and LEGIS = LEGI1 ) or
&     ( PAYS2 <> "" and PAYSS = PAYS2 and LEGI2 <> "" and LEGIS = LEGI2 ) or
&     ( PAYS3 <> "" and PAYSS = PAYS3 and LEGI3 <> "" and LEGIS = LEGI3 )     )
    Chgfmt [M:FASM]ACLCOED With "N:3.6#"
    Chgfmt [M:FASM]ACLCOEFLG With "LO:1X"
  Else
    Chgfmt [M:FASM]ACLCOED   With "-N:3.6#"
    Chgfmt [M:FASM]ACLCOEFLG With "-LO:1X"
  Endif
 Endif

End
##########################################################################
Subprog AM_ACLCOED(VALEUR)
Variable Decimal VALEUR

End
##########################################################################
Subprog AS_PRATYPFLG(VALEUR)
Variable Integer VALEUR

  # -- Prorata FQ84281 FQ105809
If  ( [M:FASM]ENDDPRDATD(nolign-1) = [M:FASM]ENDDPRDAT(nolign-1) and
&   ( ([M:FASM]DPMD(nolign-1) <> "" )  and  (find([M:FASM]DPMD(nolign-1), G_DPMUL,G_DPMUD,G_DPMTD,G_DPMRE, G_DPMRA ) ) or
&      ([M:FASM]DPMD(nolign-1) = "" )  and  (find([M:FASM]DPMO(nolign-1), G_DPMUL,G_DPMUD,G_DPMTD,G_DPMRE, G_DPMRA)) ) ) or
&     (([M:FASM]DPMD(nolign-1) <> "")  and  (find([M:FASM]DPMD(nolign-1), G_DPMHL, G_DPMHD, G_DPMTL)) or
&      ([M:FASM]DPMD(nolign-1) = "" )  and  (find([M:FASM]DPMO(nolign-1), G_DPMHL, G_DPMHD, G_DPMTL)))
    # Le type de prorata n'est significatif que pour les modes ci-dessus
     [M:FASM]PRATYPFLG(nolign-1)  = G_OUI
     Actzo [M:FASM]PRATYPFLG(nolign-1)
     Actzo [M:FASM]PRATYPD(nolign-1)
  Else
      [M:FASM]PRATYPFLG(nolign-1)  = G_NON
      [M:FASM]PRATYPD(nolign-1) = 0
      Diszo [M:FASM]PRATYPD(nolign-1)
      Diszo [M:FASM]PRATYPFLG(nolign-1)
  Endif

  If [M:FASM]ENDDPRFLGO(nolign-1)= G_OUI
      [M:FASM]PRATYPFLG(nolign-1)  = G_NON
      Diszo [M:FASM]PRATYPD(nolign-1)
      Diszo [M:FASM]PRATYPFLG(nolign-1)
   Endif
   Affzo [M:FASM]PRATYPD(nolign-1)
End
##########################################################################
Subprog AM_PRATYPFLG(VALEUR)
Variable Integer VALEUR

If ( VALEUR <> G_OUI )
  [M:FASM]PRATYPD(nolign-1) = [M:FASM]PRATYPO(nolign-1) #Fq-71335
   Affzo [M:FASM]PRATYPD(nolign-1)
   Diszo [M:FASM]PRATYPD(nolign-1)
Else
   Actzo [M:FASM]PRATYPD(nolign-1)
Endif

  #FQ84741
  If dim(GFXDNBERR) > 0
    If ACTMETNAM = "FASTRFC" and VALEUR = G_OUI
      # FQ90828 : ajout de l'indice
      Actzo [M:FASM]PRATYPD(nolign - 1)
    Endif
  Endif

 [M:FASM]MTCFLG(nolign-1) =
&   func TRTFASMTC.DETERM_MTCFLG
&    ( [M:FASM]DPMD(nolign-1),       [M:FASM]RSDFLG(nolign-1),     [M:FASM]DURFLG(nolign-1),
&      [M:FASM]DPRRATFLGD(nolign-1), [M:FASM]DPRRA2FLGD(nolign-1), [M:FASM]STRFLG(nolign-1),
&      [M:FASM]RSDVALFLG(nolign-1),  [M:FASM]ALWFLG(nolign-1),     [M:FASM]VEHFLG(nolign-1),
&      VALEUR,                       [M:FASM]ACLCOEFLG(nolign-1),  nolign )
   Gosub COND_GESTION_ECART

End
#=============================
Subprog AS_PRATYPD(VALEUR)
Variable Integer VALEUR

If [M:FASM]PRATYPFLG(nolign-1) = G_OUI
   Actzo [M:FASM]PRATYPD(nolign-1)
Else
   Diszo [M:FASM]PRATYPD(nolign-1)
Endif

If ( find([M:FASM]DPMD(nolign-1), G_DPMUD,G_DPMUL,G_DPMTD) >0 ) or
&    ([M:FASM]DPMD(nolign-1) = "" and ( find([M:FASM]DPMO(nolign-1), G_DPMUD,G_DPMUL,G_DPMTD) >0) )
  # Si le type de prorata est "Declining Balance", "Straight line", "Dégressif turque"
  # le prorata ne peut pas être "Jour" ni "Semaine" FQ89488 FQ105809.
  GMENLOC(GVML_TPSEMA) = 1
  GMENLOC(GVML_TPJOUR) = 1
Endif

If ( ACTMETNAM = "FASMTC" or  ACTMETNAM = "FASTRFC") Then
  If ( find([M:FASM]DPMD(nolign-1), G_DPMHL, G_DPMHD, G_DPMTL) > 0) or
&    ([M:FASM]DPMD(nolign-1) = "" and ( find( [M:FASM]DPMO(nolign-1), G_DPMHL, G_DPMHD, G_DPMTL) > 0) )
    # Si le type de prorata est "Linéaire suisse, Dégressif suisse" ou "Linéaire turque"
    # le prorata ne peut être que "Jour" ou "Mois". FQ84281 FQ105809
    GMENLOC(GVML_TPSEMA) = 1
    GMENLOC(GVML_TPHLFY) = 1
    GMENLOC(GVML_TPHLFM) = 1
    GMENLOC(GVML_TPHLFQ) = 1
  Endif
Else
  If ( find ([M:FASM]DPMD(nolign-1), G_DPMHL, G_DPMHD, G_DPMTL) > 0 )
    # Si le type de prorata est "Linéaire suisse, Dégressif suisse" ou "Linéaire turque"
    # le prorata ne peut être que "Jour" ou "Mois". FQ84281 105809
    GMENLOC(GVML_TPSEMA) = 1
    GMENLOC(GVML_TPHLFY) = 1
    GMENLOC(GVML_TPHLFM) = 1
    GMENLOC(GVML_TPHLFQ) = 1
  Endif
Endif

Affzo [M:FASM]PRATYPD(nolign-1)

End
#=============================
Subprog AM_PRATYPD(VALEUR)
Variable Integer VALEUR
End
#=============================
Subprog C_PRATYPD(VALEUR)
Variable Integer VALEUR

 If ( [M:FASM]PRATYPFLG(nolign-1) = G_OUI ) and ( VALEUR = 0 ) and ( [M:FASM]PRATYPO(nolign-1)= 0 )
    #  Le type de prorata doit être saisi pour ce mode
    GERR=1 : GMESSAGE = mess(571,GML_MSGFAS,1)
    mkstat = 2 : End
 Endif

End
######################################################################################
Subprog AS_MTCDEVADJ(VALEUR)
Variable Integer VALEUR

Local Char  LPARM
[M:FASM]MTCDEVADJ(nolign-1) = GVML_REXCPER
Affzo  [M:FASM]MTCDEVADJ(nolign-1)

If ( ACTTYPGES=GTAMUNI )
   # Si taux anticipato alimenté ==> pas de gestion d'écart en dotation exceptionnelle
   If ( [M:FASM]DPRRA2FLGD(nolign-1)  = G_OUI )  or ( [M:FASM]DPRRAT2D(nolign-1) > 0 )
      GMENLOC(GVML_REXCEXE) = 1
      GMENLOC(GVML_REXCPER) = 1
   Endif
   # Gestion écart = "Dotation période" si mise en service
   # si PRVSITUPD = "Non" et date début d'amort ant début exercice et cumul exercice forcé à 0

   #FQ80039
   Call PARAM([M:FASM]CPY1(nolign-1),"PRVSITUPD",LPARM) From ADOVAL
   GPRVSITUPD = val(LPARM)
   If ( [M:FASM]STRDPRDATD(nolign-1)  <> [0/0/0] ) and
&     ( [M:FASM]STRDPRDATD(nolign-1)  < [M:FASM]FIYSTRDAT(nolign-1) )
      If  ( (ACTMETNAM = "FASTRFC" )  and  [M:FASC]ITSDATD  <> [0/0/0])   or
&         (  GPRVSITUPD <> G_OUI    and [M:FASM]DPRCUM(nolign-1) = 0 and [M:FASM]DPRCUMFLG(nolign-1) = G_OUI )
         [M:FASM]MTCDEVADJ(nolign-1) =  GVML_RDOTPER
         [M:FASM]ECTFLG(nolign-1)    =  G_OUI
         #FQ80039 inutile d'interdire
#         GMENLOC(GVML_RREPAN)   = 1
#         GMENLOC(GVML_REXCEXE)  = 1
#         GMENLOC(GVML_REXCPER)  = 1
#         GMENLOC(GVML_RDOTEXE)  = 1
      Else
         If  [M:FASM]MTCTIATYP(nolign-1)  = GVML_PEDBAM
            # Gestion écart = "Dotation EXCEPTIONNEL PERIODE" si date de début amort < début d'exercice courant
            [M:FASM]MTCDEVADJ(nolign-1) = GVML_REXCPER
            [M:FASM]ECTFLG(nolign-1)    =  G_OUI
            Actzo[M:FASM]MTCDEVADJ(nolign-1)
         Else
            [M:FASM]ECTFLG(nolign-1) = G_NON :  Diszo [M:FASM]ECTFLG(nolign-1)
            # Issue 113764 [M:FASM]MTCDEVADJ(nolign-1) = 0
         Endif
      Endif
   Else
    #*Si date de début amort > = début d'exercice courant ==> pas de gestion d'écart
      [M:FASM]ECTFLG(nolign-1) = G_NON
      # Issue 113764 [M:FASM]MTCDEVADJ(nolign-1) = 0 :  Diszo [M:FASM]MTCDEVADJ(nolign-1)
      Diszo [M:FASM]MTCDEVADJ(nolign-1)
   Endif

   Affzo  [M:FASM]MTCDEVADJ(nolign-1)
   # Issue 113764
   #Affzo  [M:FASM]ECTFLG(nolign-1)

Endif

End
#=============================
Subprog C_MTCDEVADJ(VALEUR)
Variable Integer VALEUR

# Issue 113764 - 2016-02-08 by MDJ, MWA : Avertissement  si Rattrapage écart ="Report à nouveau"
Local Integer OK
If VALEUR=GVML_RREPAN
  Call AVERTIR(mess(938,GML_MSGFAS,1),OK) From GESECRAN
  If OK=1   # Annuler
    mkstat=2 : End
  Endif
Endif

End
#=============================
Subprog AM_MTCDEVADJ(VALEUR)
Variable Integer VALEUR

End
#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#
#
#===================
$OUVRE_TABLES
#===================
  # Ouverture de tables liées à explorer ou à mettre à jour  par l'action massive
  If !(clalev([F:CNX]))   : Local File CONTEXT   [CNX]   : Endif
  If !(clalev([F:FIS]))   : Local File FISCYEAR  [FIS]   : Endif
  If !(clalev([F:DEP]))   : Local File DEPREC    [DEP]   : Endif
  If !(clalev([F:DEPW]))  : Local File DEPREC    [DEPW]  : Endif
  If !(clalev([F:ADW]))   : Local File ADOVAL    [ADW]   : Endif
  If !(clalev([F:LOF]))   : Local File LAYOUTFAS [LOF]   : Endif
  # --------------------------------
  # Ouverture de l'écran pour contrôler la méthode dans TRTFAS
  Local Mask METH [METH]
  Local Mask METH [MET2] #Fq-87928 pour contrôler 2 plans dans CONTROLE_METHODE
Return
#==============================
$GESTRACE
Local Char LDES(GLONDES)
Local Integer I, J, LERROR

  Case TRTYP
    When 1
      # Ouverture
      Call OUVRE_TRACE (mess(208,GML_MSGFAS,1),1) From TRACEABX3
    When 20
      # Paramètres à appliquer

      For I = 1 To [M:FASM]NBLIG1
        If ([M:FASM]MTCFLG(I-1) = G_OUI)
          Gosub ECR_PARM_PLN From TRTFASMTC2
        Endif
      Next I
    When Default
  Endcase
Return
#==============
Subprog INIT_PLAN_AMT(PCPY)
#==============
Value Char    PCPY
Local Integer ORIBAS, I, LOK
Local Date    FIYSTRC,  FIYENDC,  PERSTRC,  PERENDC
Local Date    FIYSTRS,  FIYENDS,  PERSTRS,  PERENDS

  # Le tableau est préchargé à partir des contextes pour que l'on ait pour chaque plan géré
  # la date de début de l'exercice courant et de la période courante
  # Ces dates peuvent différer selon la date de clôture de chacun des contextes.
  nolign = 1
  For [CNX] Where CPY =PCPY
    #---------------------------
    # Lecture exercice courant
    Filter [FIS] Where CPY=PCPY and CNX = [F:CNX]CNX and STAFIY = GVML_TECOURA
       Read [FIS]First
       If (fstat)   : Raz [F:FIS] : Endif
    Filter [FIS]
    FIYSTRC =[F:FIS]DATSTRFIY
    FIYENDC =[F:FIS]DATENDFIY
    PERSTRC =[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
    PERENDC =[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
    #---------------------------
    # Lecture exercice suivant
    Filter [FIS] Where CPY=PCPY and CNX = G300CPFI and STAFIY = GVML_TESUIV
       Read [FIS]First
       If (fstat)   : Raz [F:FIS] : Endif
    Filter [FIS]
    FIYSTRS =[F:FIS]DATSTRFIY
    FIYENDS =[F:FIS]DATENDFIY
    PERSTRS =[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
    PERENDS =[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
    #---------------------------
    For I = 0 To [F:CNX]NBPLC-1
        # Le code véhicule n'est saisissable que pour le plan fiscal
        If ( [F:CNX]PLNCAA(I) <> G301FIS )
          Diszo [M:FASM]VEHFLG(nolign-1)
        Endif
      [M:FASM]DPRPLND(nolign-1)    = [F:CNX]PLNCAA(I)
      [M:FASM]ORIBAS(nolign-1)     = [F:CNX]ORIBASDPR(I)
      [M:FASM]CURD(nolign-1)       = [F:CNX]CUR
      [M:FASM]CPY1(nolign-1)       = [F:CNX]CPY
      [M:FASM]FIYSTRDAT(nolign-1)  = FIYSTRC
      [M:FASM]FIYENDDAT(nolign-1)  = FIYENDC
      [M:FASM]PERSTRDAT(nolign-1)  = PERSTRC
      [M:FASM]PERENDDAT(nolign-1)  = PERENDC

      If  (ACTTYPGES=GTAMUNI)
           Read[DEP]DEP0=[M:FAS0]AASREF;[M:FASM]DPRPLND(nolign-1);
&                        [M:FASM]FIYENDDAT(nolign-1);[M:FASM]PERENDDAT(nolign-1)
         If fstat=0
           [M:FASM]STRDPRDAT(nolign-1)  = [F:DEP]STRDPRDAT
           [M:FASM]STRDPRDATD(nolign-1) = [F:DEP]STRDPRDAT
           [M:FASM]ENDDPRDAT(nolign-1)  = [F:DEP]ENDDPRDAT
           [M:FASM]ENDDPRDATD(nolign-1) = [F:DEP]ENDDPRDAT
           [M:FASM]DPMO(nolign-1)       = [F:DEP]DPM
           [M:FASM]DPRDURO(nolign-1)    = [F:DEP]DPRDUR
           [M:FASM]DPRRATO(nolign-1)    = [F:DEP]DPRRAT         #Fq-76303
           [M:FASM]DPRRATFLGO(nolign-1) = [F:DEP]DPRRATFLG      #Fq-76303
           [M:FASM]DPRCUMFLG(nolign-1)  = [F:DEP]DPRCUMFLG      #Fq-82531
           [M:FASM]PRATYPO(nolign-1)    = [F:DEP]PRATYP
           [M:FASM]ENDDPRFLGO(nolign-1) = [F:DEP]ENDDPRFLG
         Endif
      Else
         [M:FASM]DPMO(nolign-1) = ""    #FQ-70482
      Endif

      [M:FASM]TRTFLG(nolign-1)      = G_NON
      [M:FASM]MTCFLG(nolign-1)      = G_NON
      [M:FASM]STRFLG(nolign-1)      = G_NON
      Raz [M:FASM]DPMD(nolign-1)
      [M:FASM]DURFLG(nolign-1)      = G_NON
      Raz [M:FASM]DPRDURD(nolign-1)
      [M:FASM]DPRRATFLGD(nolign-1)  = G_NON
      Raz [M:FASM]DPRRATD(nolign-1)
      [M:FASM]DPRRA2FLGD(nolign-1)  = G_NON
      Raz [M:FASM]DPRRAT2D(nolign-1)
      [M:FASM]RSDVALFLG(nolign-1)   = G_NON
      Raz [M:FASM]RSDVALD(nolign-1)
      [M:FASM]VEHFLG(nolign-1)      = G_NON
      Raz [M:FASM]CRBVEHCODD(nolign-1)
      [M:FASM]ALWFLG(nolign-1)      = G_NON
      [M:FASM]ALWCODD(nolign-1)     = 0
      [M:FASM]ACLCOEFLG(nolign-1)      = G_NON
      [M:FASM]ALWAMT(nolign-1)      = [F:DEP]ALWAMT      #FQ-61173
      [M:FASM]PRATYPFLG(nolign-1)      = G_NON
      [M:FASM]PRATYPD(nolign-1)     = [M:FASM]PRATYPO(nolign-1)
      [M:FASM]MTCDEVADJ(nolign-1)   = 0
        Diszo [M:FASM]MTCDEVADJ(nolign-1)
      [M:FASM]PLNSTD(nolign-1)= func GLOBIENS.GET_NORME_PLAN( PCPY, [M:FASM]DPRPLND(nolign-1) )
      # FQ94929
      [M:FASM]DEFORCERAT(nolign-1)  = G_NON
      nolign += 1
    Next I
  Next

  [M:FASM]NBLIG1 = nolign-1

 Affzo [M:FASM]NBLIG1

  # Conditionnement Plan d'amortissement
  For I = 1 To [M:FASM]NBLIG1
    # Conditionnement Fin amort
    # Si mode RE/prorata jour ou RA ==> Date de fin d'amortissement peut être forcée
    # Issue 116168 - POR-idem for methods PC and PC
    If   ( G_DPMRE <> "" and [M:FASM]DPMO(I-1) = G_DPMRE and [M:FASM]PRATYPO(I-1)= GVML_TPJOUR )  or
&        ( G_DPMRA <> "" and [M:FASM]DPMO(I-1) = G_DPMRA and [M:FASM]PRATYPO(I-1)= GVML_TPJOUR ) or
&        ( G_DPMPC <> "" and [M:FASM]DPMO(I-1) = G_DPMPC ) or
&        ( G_DPMPD <> "" and [M:FASM]DPMO(I-1) = G_DPMPD )
       Actzo [M:FASM]ENDDPRFLG(I-1)
    Else
      [M:FASM]ENDDPRFLG(I-1)= G_NON
      # FQ82178
      #  Diszo [M:FASM]ENDDPRFLG(I-1)
      If (ACTTYPGES = GTAMUNI )
        # En massif Date de fin d'amortissement peut tours être forcée
        Diszo [M:FASM]ENDDPRFLG(I-1)
      Endif

      Diszo [M:FASM]ENDDPRDATD(I-1)
    Endif
 Next I
 Affzo [M:FASM]NBLIG1

  # - Conditionnement de l'affichage des colonnes liées à l'amt IT en fonction du pays de PCPY
  If (func GLOFCYCPY.GET_SOC_PAYS(PCPY)="IT")
    Chgfmt [M:FASM]DPRRA2FLGD With "LO:1X"
    Chgfmt [M:FASM]DPRRAT2D   With "N:3.6#"
  Else
    Chgfmt [M:FASM]DPRRA2FLGD With "-LO:1X"
    Chgfmt [M:FASM]DPRRAT2D   With "-N:3.6#"
  Endif

 # Affichage (unitaire) ou effacement (massif) de la colonne ancien mode
 If (ACTTYPGES = GTAMMAS )
   # Issue 114266  Chgfmt [M:FASM]DPMO   With "-K:3X"
   Raz [M:FASM]DPMO
   Chgfmt [M:FASM]ENDDPRDATD   With "-D:DD[/]MM[/]YY"
   Chgfmt [M:FASM]STRDPRDATD   With "-D:DD[/]MM[/]YY"
     Else
   # Issue 114266   Chgfmt [M:FASM]DPMO   With "K:3X"
    Diszo  [M:FASM]DPMO
    Chgfmt [M:FASM]ENDDPRDATD   With "D:DD[/]MM[/]YY"
    Chgfmt [M:FASM]STRDPRDATD   With "D:DD[/]MM[/]YY"
     Endif

  # Conditionnement en fonction de la date de changement de méthode
  Call COND_PLN_PARM(  [M:FASM]MTCTIADAT, LOK)
  Call ACTION_BLOCK (ACB_AFFZO, "FASMTC", "NBLIG1") From GLOBIENS

End
#=========================
Subprog COND_PLN_PARM(PTIADAT, ROK)
Value Date PTIADAT
Variable Integer ROK

  # Issue 113764
  Local Integer COND_PLN_PARM

  ROK = G_NON
  # Conditionnement en fonction de la date de changement de méthode
  For nolign = 1 To [M:FASM]NBLIG1
     ROK = G_OUI
     Actzo [M:FASM]RSDFLG(nolign-1)
     Actzo [M:FASM]STRFLG(nolign-1)
     Actzo [M:FASM]DPMD(nolign-1)
        Actzo [M:FASM]DURFLG(nolign-1)
     Actzo [M:FASM]DPRRATFLGD(nolign-1)
     Actzo [M:FASM]RSDVALFLG(nolign-1)
     If ( [M:FASM]DPRPLND(nolign-1) = G301FIS )
        Actzo [M:FASM]VEHFLG(nolign-1)
     Else
        Diszo [M:FASM]VEHFLG(nolign-1)
     Endif
     Actzo [M:FASM]ALWFLG(nolign-1)
     Actzo [M:FASM]PRATYPFLG(nolign-1)
     Actzo [M:FASM]ACLCOEFLG(nolign-1)
     Gosub COND_GESTION_ECART
  Next nolign

  Call ACTION_BLOCK (ACB_AFFZO, "FASMTC", "NBLIG1") From GLOBIENS


End
#=========================================================================
Funprog DETERM_MTCFLG
&       (IDPM,       IRSDFLG,     IDURFLG,
&        IRATFLG,    IRAT2FLG,    ISTRFLG,
&        IRSDVALFLG, IALWFLG,     IVEHFLG,
&        IPRATYPFLG, IACLCOEFLG,  IL )

Value Char    IDPM
Value Integer IRSDFLG, IDURFLG, IRATFLG, IRAT2FLG, ISTRFLG, IRSDVALFLG
Value Integer IVEHFLG, IALWFLG, IPRATYPFLG, IACLCOEFLG, IL

  Local Integer OMTCFLG
  Local Integer OLDMTCFLG

  OLDMTCFLG = [M:FASM]MTCFLG(IL-1)
  If ( IDPM       = ""       &     IRSDFLG   <> G_OUI   & IDURFLG    <> G_OUI   and
&      IRATFLG    <> G_OUI   &    IRAT2FLG   <> G_OUI   & ISTRFLG    <> G_OUI   and
&      IRSDVALFLG <> G_OUI   &    IALWFLG    <> G_OUI   & IVEHFLG    <> G_OUI   and
&      IPRATYPFLG <> G_OUI   &    IACLCOEFLG <> G_OUI   )
    OMTCFLG = G_NON
  Else
    OMTCFLG = G_OUI
  Endif

  If OMTCFLG <> G_OUI  or
&     [M:FASM]STRDPRDAT(nolign-1) >= [M:FASM]FIYSTRDAT(nolign-1)
      [M:FASM]ECTFLG(nolign-1) = G_NON
      # Issue 113764
      #[M:FASM]MTCDEVADJ(nolign-1) = 0 : Diszo [M:FASM]MTCDEVADJ(nolign-1)
      Diszo [M:FASM]MTCDEVADJ(nolign-1)
  Else
     If [M:FASM]MTCTIATYP(nolign-1)  = GVML_PEDBAM
        [M:FASM]ECTFLG(nolign-1) = G_OUI
     Endif
  Endif

  If ( ACTTYPGES = GTAMMAS and ACTSTATUS = 8 and OLDMTCFLG <> OMTCFLG  )
    Call ACTCHGCRIT From TRCPROCOM
    # Si abandon sur ACTCHGCRIT mkstat= 2 mais pas de return. Il faut donc le gérer.
    If ( mkstat <> 0 )   : End : Endif
  Endif

End OMTCFLG

#==================
$COND_GESTION_ECART
#==================
If (ACTTYPGES <> GTAMMAS )
   # Si flag gestion écart = "oui" et date de début d'amortissement < début exercice courant
   # on active le type de gestion d'écart
   #FQ102944 On teste aussi la date de début d'amortissement éventuellement mise à jour lors d'une MES
   #FQ102944 If ( [M:FASM]ECTFLG(nolign-1)  = G_OUI  & [M:FASM]STRDPRDAT(nolign-1) < [M:FASM]FIYSTRDAT(nolign-1) )
   If  ([M:FASM]STRDPRDATD(nolign-1) <> [0/0/0] and
&     ([M:FASM]STRDPRDATD(nolign-1) < [M:FASM]FIYSTRDAT(nolign-1) )) or
&     ([M:FASM]STRDPRDATD(nolign-1) = [0/0/0] and
&     ( [M:FASM]ECTFLG(nolign-1)  = G_OUI  & [M:FASM]STRDPRDAT(nolign-1) < [M:FASM]FIYSTRDAT(nolign-1) ))
#FQ-80039
#      [M:FASM]MTCDEVADJ(nolign-1) =  GVML_REXCPER
      If  [M:FASM]MTCDEVADJ(nolign-1) = 0 # issue 113764
      [M:FASM]MTCDEVADJ(nolign-1) =  GVML_RDOTPER
      Endif
      [M:FASM]ECTFLG(nolign-1) = G_OUI
      Actzo [M:FASM]MTCDEVADJ(nolign-1)
   Else
     [M:FASM]ECTFLG(nolign-1) = G_NON
     [M:FASM]MTCDEVADJ(nolign-1)= 0    :   Diszo [M:FASM]MTCDEVADJ(nolign-1)
     Diszo [M:FASM]MTCDEVADJ(nolign-1)
   Endif
   # Issue 113764 MWA
   #Affzo [M:FASM]ECTFLG(nolign-1)
   #Affzo [M:FASM]MTCDEVADJ(nolign-1)
   If (dim(COND_PLN_PARM) < 0) Then
     Affzo [M:FASM]MTCDEVADJ(nolign-1)
   Endif
   # End issue 113764 MWA

Else #FQ102511 Activation type de rattrapage en Massif aussi
   #If ( [M:FASM]MTCDEVADJ(nolign-1) = 0 and dim(COND_PLN_PARM) < 0) # issue 113764 MWA
     [M:FASM]MTCDEVADJ(nolign-1) =  GVML_RDOTPER
   #Endif
   Actzo [M:FASM]MTCDEVADJ(nolign-1)
   Affzo [M:FASM]MTCDEVADJ(nolign-1)
Endif
Return
#==================
$ALIM_ENR_PLN
#==================
  # [F:DEP] <- [M:FASM]
  # -------------------------------
# DEB FQ90932
#  If ( [M:FASM]STRFLG(I_PLN-1) = G_OUI and [F:DEP]STRDPRDAT <> [M:FASM]STRDPRDATD(I_PLN-1) )
#    [F:DEP]STRDPRDAT = [M:FASM]STRDPRDATD(I_PLN-1)
#    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
#  Endif
  If ( ACTTYPGES = GTAMMAS  and ACTMETNAM = "FASTRFC" ) Then
    If ( [M:FASM]STRFLG(I_PLN-1) = G_OUI and [M:FASC]ITSDATD <> [0/0/0] and [F:DEP]STRDPRDAT <> [M:FASC]ITSDATD )
      [F:DEP]STRDPRDAT = [M:FASC]ITSDATD
      If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
    Endif
  Else
    If ( [M:FASM]STRFLG(I_PLN-1) = G_OUI and [F:DEP]STRDPRDAT <> [M:FASM]STRDPRDATD(I_PLN-1) )
      [F:DEP]STRDPRDAT = [M:FASM]STRDPRDATD(I_PLN-1)
      If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
    Endif
  Endif
# FIN FQ90932

  If ( [M:FASM]DPMD(I_PLN-1) <> "" and [F:DEP]DPM <> [M:FASM]DPMD(I_PLN-1) )
    [F:DEP]DPM  = [M:FASM]DPMD(I_PLN-1)
    [F:DEP]DPMI = [M:FASM]DPMD(I_PLN-1)
    [F:DEP]DPMT = [M:FASM]DPMD(I_PLN-1)
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

  If ( [M:FASM]ENDDPRFLG(I_PLN-1) = G_OUI and [F:DEP]ENDDPRDAT <> [M:FASM]ENDDPRDATD (I_PLN-1) )
    [F:DEP]ENDDPRFLG = [M:FASM]ENDDPRFLG (I_PLN-1)
    [F:DEP]ENDDPRDAT = [M:FASM]ENDDPRDATD (I_PLN-1)
  Else
    [F:DEP]ENDDPRFLG = G_NON
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

  If ( [M:FASM]DURFLG(I_PLN-1) = G_OUI and [F:DEP]DPRDUR <> [M:FASM]DPRDURD(I_PLN-1) )
    [F:DEP]DPRDUR = [M:FASM]DPRDURD(I_PLN-1)
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

  If ( [M:FASM]DPRRATFLGD(I_PLN-1) = G_OUI and [F:DEP]DPRRAT <> [M:FASM]DPRRATD(I_PLN-1) )
    [F:DEP]DPRRATFLG = [M:FASM]DPRRATFLGD(I_PLN-1)
    [F:DEP]DPRRAT    = [M:FASM]DPRRATD(I_PLN-1)
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

  # FQ94929
  If ( ACTTYPGES = GTAMUNI)
    If ( [M:FASM]DEFORCERAT(I_PLN-1) = G_OUI )
      [F:DEP]DPRRATFLG = [M:FASM]DPRRATFLGD(I_PLN-1)
      [F:DEP]DPRRAT    = [M:FASM]DPRRATD(I_PLN-1)
      If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
    Endif
  Endif

  # FQ84283
  If ( [M:FASM]DPRRA2FLGD(I_PLN-1) = G_OUI   and
&      ( ([F:DEP]DPM=G_DPMIT and G_DPMIT <>"") or
&        ([F:DEP]DPM=G_DPMAL and G_DPMAL <>"") or
&        ([F:DEP]DPM=G_DPMAD and G_DPMAD <>"") )  and
&      [F:DEP]DPRRAT2 <> [M:FASM]DPRRAT2D(I_PLN-1) ) Then
       [F:DEP]DPRRAT2   = [M:FASM]DPRRAT2D(I_PLN-1)
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

  If ( [M:FASM]RSDVALFLG(I_PLN-1) = G_OUI and [F:DEP]RSDVAL <> [M:FASM]RSDVALD(I_PLN-1) )
       [F:DEP]RSDVAL = [M:FASM]RSDVALD(I_PLN-1)
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

  If ( [M:FASM]VEHFLG(I_PLN-1) = G_OUI and [F:DEP]CRBVEHCOD <> [M:FASM]CRBVEHCODD(I_PLN-1) )
       [F:DEP]CRBVEHCOD = [M:FASM]CRBVEHCODD(I_PLN-1)
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

  If ( [M:FASM]ALWFLG(I_PLN-1) = G_OUI  and  [F:DEP]ALWCOD <> [M:FASM]ALWCODD(I_PLN-1) )
       [F:DEP]ALWCOD = [M:FASM]ALWCODD(I_PLN-1)
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif
  If ( [M:FASM]PRATYPFLG(I_PLN-1) = G_OUI and   [F:DEP]PRATYP <>  [M:FASM]PRATYPD(I_PLN-1) )
       [F:DEP]PRATYP = [M:FASM]PRATYPD(I_PLN-1)
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

  If ( [M:FASM]ACLCOEFLG(I_PLN-1) = G_OUI and  [F:DEP]ACLCOE <>  [M:FASM]ACLCOED(I_PLN-1) )
       [F:DEP]ACLCOE = [M:FASM]ACLCOED(I_PLN-1)
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

  If ( [F:DEP]ALWAMT <>  [M:FASM]ALWAMT(I_PLN-1) )
       #[F:DEP]ALWAMT = [M:FASM]ALWAMT(I_PLN-1) FQ113533
       If  [M:FASM]ALWAMT(I_PLN-1) <> 0   #*FQ-61173
          [F:DEP]ALWAMT = [M:FASM]ALWAMT(I_PLN-1)  : # FQ113533
          [F:DEP]ALWAMTFLG = G_OUI
       Else
          [F:DEP]ALWAMT = [M:FASM]ALWAMT(I_PLN-1)  : #*X3-61112
          [F:DEP]ALWAMTFLG = G_NON
       Endif
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

  If ( [M:FASM]MTCTIATYP(I_PLN-1) <> [F:DEP]MTCTIATYP )
     [F:DEP]MTCTIATYP= [M:FASM]MTCTIATYP(I_PLN-1)
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

  If ( [M:FASM]MTCDEVADJ(I_PLN-1) <> [F:DEP]MTCDEVADJ  )
       [F:DEP]MTCDEVADJ = [M:FASM]MTCDEVADJ(I_PLN-1)
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

   #Fq-78438
#Fq-84037    If ( [M:FASM]DPRCUMFLG(I_PLN-1) <> [F:DEP]DPRCUMFLG  )
#Fq-84037        [F:DEP]DPRCUMFLG = [M:FASM]DPRCUMFLG(I_PLN-1)
#Fq-84037      If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
#Fq-84037   Endif


Return
######################################################################
# Points d'entrée objet de reprise
######################################################################

#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.
#=====================================================================

#==============================================================#
# Cette action est appelée pour chaque enregistrement lu dans  #
# la table temporaire par plan pour l'objet métier sur lequel  #
# on vient de cliquer.                                         #
# Alimenter ici les zones du tableau par plan spécifique à l'  #
# action                                                       #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#
$LOADPLN

If !GSERVEUR
 #If ( G_TRACE = G_OUI)   : Infbox "LOADPLN" : Endif
Endif

  # Chargement du masque tableau des infos "spécifiques" par plan suite à clique sur bien
  # Appelée pour chaque enreg de la table temporaire
  # Masque: [M:MFS0]   Table: [F:TPF]   Ligne courante: nolign
  [M:MFS0]MSGERRPLN(nolign-1)  = [F:TPF]MSGERR
  [M:MFS0]STRDPRDAT(nolign-1)  = [F:TPF]STRDPRDAT
  [M:MFS0]ENDDPRFLG(nolign-1)  = [F:TPF]ENDDPRFLG
  [M:MFS0]ENDDPRDAT(nolign-1)  = [F:TPF]ENDDPRDAT
#FQ-80039
# rmq :
# il y a DPM et DPMO
# on affecte DPM : donc destination
# on affecte DPMIO et DPMTO : donc origine
# un peut plus loin on affecte DPMO

  [M:MFS0]DPM(nolign-1)        = [F:TPF]DPM
  [M:MFS0]DPMIO(nolign-1)      = [F:TPF]DPMI
  [M:MFS0]DPMTO(nolign-1)      = [F:TPF]DPMT
  [M:MFS0]DPRDUR(nolign-1)     = [F:TPF]DPRDUR
  [M:MFS0]DPRRATFLG(nolign-1)  = [F:TPF]DPRRATFLG
  [M:MFS0]DPRRAT(nolign-1)     = [F:TPF]DPRRAT
  [M:MFS0]DPRRAT2(nolign-1)    = [F:TPF]DPRRAT2
  [M:MFS0]RATCUR(nolign-1)     = [F:TPF]RATCUR
  [M:MFS0]UOM(nolign-1)        = [F:TPF]UOM
  [M:MFS0]RSDVAL(nolign-1)     = [F:TPF]RSDVAL
  [M:MFS0]DPRBAS(nolign-1)     = [F:TPF]DPRBAS
  [M:MFS0]DPRCUM(nolign-1)     = [F:TPF]DPRCUM
  [M:MFS0]PERCLOCUM(nolign-1)  = [F:TPF]PERCLOCUM
  [M:MFS0]FIYSTRDAT(nolign-1)  = [F:TPF]FIYSTRDAT
  [M:MFS0]PERSTRDAT(nolign-1)  = [F:TPF]PERSTRDAT
  [M:MFS0]MTCTIATYP(nolign-1)  = [F:TPF]MTCTIATYP
  [M:MFS0]CRBVEHCOD(nolign-1)  = [F:TPF]CRBVEHCOD
  [M:MFS0]ALWCOD(nolign-1)     = [F:TPF]ALWCOD
  [M:MFS0]ALWAMT(nolign-1)     = [F:TPF]ALWAMT
  [M:MFS0]PRATYP(nolign-1)     = [F:TPF]PRATYP
  [M:MFS0]ACLCOE(nolign-1)     = [F:TPF]ACLCOE  # FQ89488
  [M:MFS0]MTCDEVADJ(nolign-1)  = [F:TPF]MTCDEVADJ
  If  [M:MFS0]STRDPRDAT(nolign-1) >=  [M:MFS0]FIYSTRDAT(nolign-1)
      # Issue 113764
      #[M:MFS0]MTCDEVADJ(nolign-1) = 0
      Diszo [M:MFS0]MTCDEVADJ(nolign-1)
   Endif
  [M:MFS0]STRDPRDATO(nolign-1) = [F:TPF]STRDPRDATO
  [M:MFS0]ENDDPRFLGO(nolign-1) = [F:TPF]ENDDPRFLGO
  [M:MFS0]ENDDPRDATO(nolign-1) = [F:TPF]ENDDPRDATO
  [M:MFS0]DPMO(nolign-1)       = [F:TPF]DPMO
  [M:MFS0]DPRDURO(nolign-1)    = [F:TPF]DPRDURO
  [M:MFS0]DPRRATFLGO(nolign-1) = [F:TPF]DPRRATFLGO
  [M:MFS0]DPRRATO(nolign-1)    = [F:TPF]DPRRATO
  [M:MFS0]RSDVALO(nolign-1)    = [F:TPF]RSDVALO
  [M:MFS0]CRBVEHCODO(nolign-1) = [F:TPF]CRBVEHCODO
  [M:MFS0]ALWCODO(nolign-1)    = [F:TPF]ALWCODO
  [M:MFS0]ACLCOEO(nolign-1)    = [F:TPF]ACLCOEO
  [M:MFS0]ALWAMTO(nolign-1)    = [F:TPF]ALWAMTO
  [M:MFS0]PRATYPO(nolign-1)    = [F:TPF]PRATYPO
  #FQ-80039
  [M:MFS0]DPRCUMFLG(nolign-1)    = [F:TPF]DPRCUMFLG
  If [F:TPF]ALWCOD <> [F:TPF]ALWCODO and  [F:TPF]ALWCOD=GVML_RPAUCUN
      [M:MFS0]ALWAMT(nolign-1)=0
  Endif

  If [F:TPF]DPMO <> "" and [F:TPF]DPMIO = ""
    [F:TPF]DPMIO = [F:TPF]DPMO
  Endif
  If [F:TPF]DPMO <> "" and [F:TPF]DPMTO = ""
    [F:TPF]DPMTO = [F:TPF]DPMO
  Endif
  [F:TPF]DPMI = [F:TPF]DPM
  [F:TPF]DPMT = [F:TPF]DPM

  [M:MFS0]DPM(nolign-1)        = [F:TPF]DPM
  [M:MFS0]DPMO(nolign-1)       = [F:TPF]DPMO
  [M:MFS0]DPMI(nolign-1)      = [F:TPF]DPMI
  [M:MFS0]DPMIO(nolign-1)      = [F:TPF]DPMIO
  [M:MFS0]DPMT(nolign-1)      = [F:TPF]DPMT
  [M:MFS0]DPMTO(nolign-1)      = [F:TPF]DPMTO

 Local Integer LIG_CHG, NOL
  NOL = nolign
  LIG_CHG = func TRTFASMTC2.DETECTE_CHG_LIG(NOL)
 If ( ACTMETNAM <> "FASTRFC" )
  Gosub GESTION_ECART From TRTFASMTC2
 Endif

Return
#==============================================================#
# Cette action est appelée pour chaque enregistrement de la    #
# table temporaire à mettre à jour.                            #
# Alimenter ici les zones spécifiques à l'action de la table   #
# temporaire par plan à partir des zones du tableau par plan   #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#
$SAVEPLN

If !GSERVEUR
 #If ( G_TRACE = G_OUI)   : Infbox "SAVPLN" : Endif
Endif

  # MAJ table temporaire avec les infos "spécifiques" du masque tableau des infos par plan
  # Appelée pour chaque enreg de la table temporaire
  # Table: [F:TPF]   Masque: [M:MFS0]   Ligne courante: nolign

  [F:TPF]MSGERR    = [M:MFS0]MSGERRPLN(nolign-1)
  [F:TPF]STRDPRDAT = [M:MFS0]STRDPRDAT(nolign-1)
  [F:TPF]ENDDPRFLG = [M:MFS0]ENDDPRFLG(nolign-1)
  [F:TPF]ENDDPRDAT = [M:MFS0]ENDDPRDAT(nolign-1)
  [F:TPF]DPM       = [M:MFS0]DPM(nolign-1)
  #FQ-80039
  [F:TPF]DPMI      = [M:MFS0]DPMI(nolign-1)
  [F:TPF]DPMT      = [M:MFS0]DPMT(nolign-1)
  [F:TPF]DPMIO      = [M:MFS0]DPMIO(nolign-1)
  [F:TPF]DPMTO      = [M:MFS0]DPMTO(nolign-1)

  [F:TPF]DPRDUR    = [M:MFS0]DPRDUR(nolign-1)
  [F:TPF]DPRRATFLG = [M:MFS0]DPRRATFLG(nolign-1)
  [F:TPF]DPRRAT    = [M:MFS0]DPRRAT(nolign-1)
  [F:TPF]DPRRAT2   = [M:MFS0]DPRRAT2(nolign-1)
  [F:TPF]UOM       = [M:MFS0]UOM(nolign-1)
  [F:TPF]RSDVAL    = [M:MFS0]RSDVAL(nolign-1)
  [F:TPF]CRBVEHCOD = [M:MFS0]CRBVEHCOD(nolign-1)
  [F:TPF]ALWCOD    = [M:MFS0]ALWCOD(nolign-1)
  [F:TPF]ACLCOE    = [M:MFS0]ACLCOE(nolign-1)
  #FQ84037
  If [M:MFS0]PRATYP(nolign-1) > 0
    [F:TPF]PRATYP    = [M:MFS0]PRATYP(nolign-1)
  Endif
  [F:TPF]ALWAMT    = [M:MFS0]ALWAMT(nolign-1)
  [F:TPF]MTCTIATYP = [M:MFS0]MTCTIATYP(nolign-1)
  [F:TPF]MTCDEVADJ = [M:MFS0]MTCDEVADJ(nolign-1)
  #FQ-80039
  [F:TPF]DPRCUMFLG = [M:MFS0]DPRCUMFLG(nolign-1)

Return
#=====================================================================
Subprog DETERM_MVTDAT( PTYPE, PFIYSTRDAT, PPERSTRDAT, PSTRDPRDAT, RDATE)
Value Integer    PTYPE
Value    Date    PFIYSTRDAT, PPERSTRDAT, PSTRDPRDAT
Variable Date    RDATE
  If (PTYPE = GVML_NPSTD)
    RDATE = max(PSTRDPRDAT, PFIYSTRDAT)
  Else
    RDATE = max(PSTRDPRDAT, PPERSTRDAT)
  Endif

End
#=====================================================================
Subprog DETERM_MTCTIADAT( PTIATYP, PFIYSTRDAT, PPERSTRDAT, PSTRDPRDAT, RDATE)
Value Integer    PTIATYP
Value    Date    PFIYSTRDAT, PPERSTRDAT, PSTRDPRDAT
Variable Date    RDATE

Case PTIATYP
   When GVML_PEDBAM : RDATE =  PSTRDPRDAT
   When GVML_PEDBEX : RDATE =  max(PSTRDPRDAT, PFIYSTRDAT)
   When GVML_PEDBPE : RDATE =  max(PSTRDPRDAT, PPERSTRDAT)
   When Default
Endcase

End
################################################################################
# Traitement du masque de reprise de l'action massive                          #
# -----> MFASMTCR                                                              #
################################################################################

#==============================================================#
# Actions de contrôle sur champ                                #
#==============================================================#
######################################################################################
Subprog AS_MTCTIATYP_MFS(VALEUR)
Variable Integer VALEUR

  Local Integer  I_PLN
  I_PLN=find([M:MFS0]DPRPLN(nolign-1),[M:FASM]DPRPLND)
  [M:MFS0]MTCTIATYP(nolign-1) = [M:FASM]MTCTIATYP(I_PLN-1)
  Affzo [M:MFS0]MTCTIATYP(nolign-1)

End
#=====================================================================
Subprog C_MTCTIATYP_MFS(VALEUR)
Variable Integer VALEUR

End
#=====================================================================
Subprog AM_MTCTIATYP_MFS(VALEUR)
Variable Integer VALEUR

End
######################################################################################
Subprog AM_STRDPRDAT(VALEUR)
Variable Date    VALEUR

Local Integer  I_PLN, OK
  I_PLN=find([M:MFS0]DPRPLN(nolign-1),[M:FASM]DPRPLND)

  If (VALEUR < [M:FASM]FIYSTRDAT(I_PLN-1) )
    # la date de début d'amortissement doit être > = à la date de début de l'exercice courant
    GERR=1 : GMESSAGE = mess(77,GML_MSGFAS,1)
    mkstat = 2: End
  Endif

  If ( [M:MFS0]AASIPTDAT <> [0/0/0] and VALEUR < [M:MFS0]AASIPTDAT)
    # Demande de confirmation  lorsque date de début d'amortissement est < à la date de comptabilisation du bien
    Call OUINON(mess(1,GML_MSGFAS,1), OK) From GESECRAN
    If ( OK = 1)   : mkstat = 2 : End : Endif
  Endif

  Local Integer LIG_CHG, NOL
  LIG_CHG = G_OUI :  NOL = nolign
  If ( VALEUR = [M:MFS0]STRDPRDATO(nolign-1) )
    [M:MFS0]STRDPRDAT(nolign-1) = VALEUR : Affzo [M:MFS0]STRDPRDAT(nolign-1)
    LIG_CHG = func TRTFASMTC2.DETECTE_CHG_LIG(NOL)
  Endif
  Gosub GESTION_ECART    From TRTFASMTC2
  Gosub GESTION_FLGERR   From TRTFASMTC2

End
######################################################################################
Subprog AV_DPM(VALEUR)
Variable Char    VALEUR()

Local Integer LACTZO, NL

  NL = find( [M:MFS0]OBJREFDSP(0), [M:MFS0]OBJREF )

  If ( [M:MFS0]FLGMOD(NL-1) <>  G_OUI  or [M:MFS0]FLGMODPLN(nolign-1) =  G_OUI )
    LACTZO = G_NON
  Else
    LACTZO = G_OUI
  Endif

  Call COND_DPRDUR ("DPRDUR", VALEUR, "[M:MFS0]","", LACTZO ) From TRTFAS
  Call COND_DPRRATFLG (VALEUR, "[M:MFS0]","", LACTZO, G_NON ) From TRTFAS
  Call COND_CRBVEHCOD (DPRPLN(nolign-1), "[M:MFS0]","", LACTZO ) From TRTFAS

End
#===========================
Subprog C_DPM(VALEUR)
Variable Char    VALEUR()

End
#===========================
Subprog AM_DPM(VALEUR)
Variable Char VALEUR()
Local Integer LERROR
Local Integer I_PLN, NL, LACTZO
Local Integer WRSD

  I_PLN = find( [M:MFS0]DPRPLN(nolign-1), [M:FASM]DPRPLND)
  NL    = find( [M:MFS0]OBJREFDSP(0), [M:MFS0]OBJREF )

    Call DETERM_MTCTIADAT([M:MFS0]MTCTIATYP(I_PLN-1),
&      [M:MFS0]FIYSTRDAT(I_PLN-1), [M:MFS0]PERSTRDAT(I_PLN-1), [M:MFS0]STRDPRDAT(I_PLN-1),
&      [M:MFS0]MTCTIADAT(I_PLN-1) ) From TRTFASMTC
   Affzo [M:MFS0]MTCTIADAT(I_PLN-1)

 # Mode initial résiduel et mode destinataire non-résiduel
 If clalev([F:DPM])=0 : Local File DPRMOD   [DPM] :  Endif
  # FQ73032 : un mode est résiduel s'il est résiduel de lui-même
  #Filter [DPM] Where  ( RSDDPMTGR = [M:MFS0]DPMO(I_PLN-1))   &  ( DPM <> [M:MFS0]DPMO(I_PLN-1))
 Filter [DPM] Where  ( RSDDPMTGR = [M:MFS0]DPMO(I_PLN-1))   &  ( DPM = [M:MFS0]DPMO(I_PLN-1))
 Read[DPM] First
 If ( fstat )
   WRSD = 0
 Else    # mode résiduel
   WRSD = 1
 Endif
 Filter [DPM]

 If ( WRSD  ) & ( [M:MFS0]DPMO(I_PLN-1) <> G_DPMSA ) & ( VALEUR <>  [M:MFS0]DPMO(I_PLN-1) )
   # "Mode actuel résiduel ; Vous ne pouvez le changer par un mode non-résiduel"
   GERR= 1 : mkstat = 2
   GMESSAGE = mess(598,GML_MSGFAS,1)
   OK = 0
   zonsui = "[M:MFS0]DPM(I_PLN-1)"
   End
 Endif

 If (!WRSD) and  ( [M:MFS0]STRDPRDAT(I_PLN-1) < [M:MFS0]MTCTIADAT(I_PLN-1) )
    Filter [DPM] Where DPM= [M:MFS0]DPMO(I_PLN-1)
       Read[DPM] First
       If ( [F:DPM]RSDDPMTGR <> VALEUR ) & ( VALEUR <> G_DPMSA )
          ## La date de prise d'effet du changement vous impose de saisir un mode résiduel pour ce plan.
          GMESSAGE = mess(622,GML_MSGFAS,1)
          GERR=1: mkstat = 2: End
      Endif
    Filter [DPM]
 Endif

 Call CTRL_DPM (VALEUR,[M:MFS0]CPY(NL-1), [M:MFS0]CNX(I_PLN-1), [M:MFS0]DPRPLN(I_PLN-1),
&                      [M:MFS0]AASTYP(NL-1), [M:MFS0]OWNTYP(NL-1),  "", G_NON,
&                      LERROR) From TRTFAS

  # FQ91944 [F:DEP]CPY au lieu de [[M:MFS0]CNX(I_PLN-1)
  Read [CNX]CNX0 = [F:DEP]CPY; [M:MFS0]CNX(I_PLN-1)
  # FQ82075 FQ105809
  If  ( VALEUR = G_DPMLP or VALEUR = G_DPMSL or VALEUR = G_DPMTL )  and
&     ( VALEUR <> [M:MFS0]DPMO(I_PLN-1) ) and
&     ( [M:MFS0]STRDPRDATO(I_PLN-1) < [M:FASM]FIYSTRDAT(I_PLN-1) )  and
&     ( [M:MFS0]DPRCUM(I_PLN-1)  <> 0  or  [F:CNX]FLUTRAACC (I_PLN-1) = G_OUI or  [F:CNX]FLUTRATXS (I_PLN-1)<> ""  )

    # Si changement du mode d'amortissement
    # Le nouveau mode ne peut pas être LP s'il existe un cumul d'amortissement pour le plan.
    GMESSAGE = mess(606,GML_MSGFAS,1)
    GERR=1: mkstat = 2: End
  Endif

 # Pour le plan de subvention le  mode d'amortissements "RA" et "CA" sont interdit
 If ( [M:MFS0]DPRPLN(I_PLN-1) = G301SUB and find(VALEUR, G_DPMRA, G_DPMCA) <> 0 )
    GMESSAGE = mess(126,GML_MSGFAS,1)
    GERR=1: mkstat = 2: End
 Endif

If VALEUR <> [M:MFS0]DPMO(I_PLN-1)
   If (  [M:MFS0]STRDPRDATO(I_PLN-1) < [M:FASM]FIYSTRDAT(I_PLN-1) )  and
&     (  VALEUR = G_DPMLP or VALEUR = G_DPMDF or VALEUR = G_DPMSL or VALEUR = G_DPMTL)
    # Mode d'amortissement invalide FQ105809
    GMESSAGE = mess(18,GML_MSGFASPR,1)
    GERR=1: mkstat = 2: End
   Endif
Endif

  LACTZO = G_OUI

  Call COND_DPRDUR ("DPRDUR", VALEUR, "[M:MFS0]","", LACTZO  ) From TRTFAS
  Call COND_DPRRATFLG (VALEUR, "[M:MFS0]","", LACTZO, G_OUI ) From TRTFAS
  Call COND_ENDDPRFLG (VALEUR, "[M:MFS0]","", LACTZO, G_NON ) From TRTFAS   #Fq-54343

  Local Integer LIG_CHG, NOL
  LIG_CHG = G_OUI :  NOL = nolign
  If ( VALEUR = [M:MFS0]DPMO(nolign-1) )
    [M:MFS0]DPM(nolign-1) = VALEUR : Affzo [M:MFS0]DPM(nolign-1)
    LIG_CHG = func TRTFASMTC2.DETECTE_CHG_LIG(NOL)
  Endif
  Gosub GESTION_ECART    From TRTFASMTC2
  Gosub GESTION_FLGERR   From TRTFASMTC2
End
#####################################################################################
Subprog AV_ENDDPRDAT(VALEUR)
Variable Date    VALEUR

If ( [M:MFS0]ENDDPRFLG(nolign-1) = G_OUI  and  [M:MFS0]ENDDPRDAT(nolign-1)<>[M:MFS0]ENDDPRDATO(nolign-1) )
 Chgstl [M:MFS0]ENDDPRDAT(nolign-1) With "TFORCAGE"
Else
 Chgstl [M:MFS0]ENDDPRDAT(nolign-1) With ""
Endif

End
#####################################################################################
Subprog C_ENDDPRDAT(VALEUR)
Variable Date    VALEUR

 If VALEUR >= [01/01/2200]
  GERR= 1: GMESSAGE = mess(537,GML_MSGFAS,1)-format$("D:" + GFMDAT4,[01/01/2200])
  mkstat = 2 : End
 Endif

End
#########################################################################
Subprog AM_ENDDPRDAT(VALEUR)
Variable Date    VALEUR

Local Integer  I_PLN, NL

  I_PLN=find([M:MFS0]DPRPLN(nolign-1),[M:FASM]DPRPLND)
  NL    = find( [M:MFS0]OBJREFDSP(0), [M:MFS0]OBJREF )

  If ( VALEUR < [M:FASM]FIYSTRDAT(I_PLN-1) )
    # La date de fin d'amortissement saisie ne peut pas être antérieure à la date de début d'exercice courant
    GERR=1 : GMESSAGE = mess(695,GML_MSGFAS,1)
    mkstat = 2: End
  Endif

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") )
    G_DEFORCE = 0
  Else
    If (VALEUR <> [0/0/0]  and VALEUR <> [M:MFS0]ENDDPRDATO(nolign-1))
      [M:MFS0]ENDDPRFLG(nolign-1) = G_OUI :  Affzo [M:MFS0]ENDDPRFLG(nolign-1)
       Chgstl [M:MFS0]ENDDPRDAT(nolign-1) With "TFORCAGE"
    Else
      [M:MFS0]ENDDPRFLG(nolign-1) = G_NON :  Affzo [M:MFS0]ENDDPRFLG(nolign-1)
      Chgstl [M:MFS0]ENDDPRDAT(nolign-1) With ""
    Endif
  Endif

End
#===========================
Subprog B1_ENDDPRDAT(VALEUR)
Variable Date VALEUR

  # Gestion du code forçage
  [M:MFS0]ENDDPRFLG(nolign-1) = G_NON : Affzo [M:MFS0]ENDDPRFLG(nolign-1)

  Raz [M:MFS0]ENDDPRDAT(nolign-1)
  Raz VALEUR

  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:MFS0]ENDDPRDAT(nolign-1)  With ""
  Affzo [M:MFS0]ENDDPRDAT(nolign-1)

  Local Integer LIG_CHG, NOL
  LIG_CHG = G_OUI :  NOL = nolign
  If ( [M:MFS0]ENDDPRFLG(nolign-1) = [M:MFS0]ENDDPRFLGO(nolign-1) )
    LIG_CHG = func TRTFASMTC2.DETECTE_CHG_LIG(NOL)
  Endif
  Gosub GESTION_ECART      From TRTFASMTC2
  Gosub GESTION_FLGERR     From TRTFASMTC2

  mkstat = 99

End
######################################################################################
Subprog C_DPRDUR(VALEUR)
Variable Decimal VALEUR

Local Integer NL, LERROR

  NL = find( [M:MFS0]OBJREFDSP(0), [M:MFS0]OBJREF )
  # Contrôles de la durée par rapport au mode d'amortissement
  [M:METH] = [M:MFS0]
  [M:METH]DPRDUR = VALEUR
  # Contrôle au niveau de la DUREE
  Call CTRL_DPRDUR ([M:METH]DPRDUR, [M:METH]DPM, [M:METH]CPY, [M:METH]ALWCOD, [M:METH]ENDDPRFLG, LERROR ) From TRTFAS : # FQ64478
  [M:METH]MSGERR = LERROR
  If ([M:METH]MSGERR)
    GMESSAGE = mess(LERROR,GML_MSGFAS,1)
    GERR=1: mkstat = 2: End
  Endif
End
#===========================
Subprog AM_DPRDUR(VALEUR)
Variable Decimal VALEUR

  Local Integer LIG_CHG, NOL
  LIG_CHG = G_OUI :  NOL = nolign
  If ( VALEUR = [M:MFS0]DPRDURO(nolign-1) )
    [M:MFS0]DPRDUR(nolign-1) = VALEUR : Affzo [M:MFS0]DPRDUR(nolign-1)
    LIG_CHG = func TRTFASMTC2.DETECTE_CHG_LIG(NOL)
  Endif

  Gosub GESTION_ECART      From TRTFASMTC2
  Gosub GESTION_FLGERR     From TRTFASMTC2

End
######################################################################################
Subprog AV_DPRRAT(VALEUR)
Variable Decimal VALEUR
  If ( [M:MFS0]DPRRATFLG(nolign-1) = G_OUI )
    Chgstl [M:MFS0]DPRRAT(nolign-1) With "TFORCAGE"
  Else
    Chgstl [M:MFS0]DPRRAT(nolign-1) With ""
  Endif
End

#===========================
Subprog AS_DPRRAT(VALEUR)
Variable Decimal VALEUR
  # Pour PI, AN, OR le taux ne peut être que forcé
  If ( ([M:MFS0]DPRRATFLG(nolign-1) <> G_OUI) or
&       func GLOBIENS.IS_CHAMP_ENABLE ("[M:MFS0]DPRRAT", nolign-1) <> G_OUI or
&       find([M:MFS0]DPM(nolign-1), G_DPMPI,G_DPMAN,G_DPMOR ) )
    GBOUT1 = ""
  Endif
End

#===========================
Subprog AM_DPRRAT(VALEUR)
Variable Decimal VALEUR

  If ( VALEUR > 1 or VALEUR < 0 )
    GERR= 1: GMESSAGE = mess(83,123,1)
    mkstat = 2 : End
  Endif

  If ( [M:MFS0]DPRCUM(nolign-1)  <> 0 and
&      [M:MFS0]DPRRATO(nolign-1) <> VALEUR )
     # Si changement taux d'amortissement
     # FQ82075 FQ105809
     If (( [M:MFS0]DPMO(nolign-1) = G_DPMLP or [M:MFS0]DPMO(nolign-1) = G_DPMSL or [M:MFS0]DPMO(nolign-1) = G_DPMTL) and
&          [M:MFS0]DPM(nolign-1) <> G_DPMRE )
       # Ce mode ne permet pas d'amortir à partir de la valeur nette.
       GERR=1:  GMESSAGE = mess(225,GML_MSGFAS,1)
       mkstat = 2: End
     Endif
  Endif

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") )
    G_DEFORCE = 0
  Else
    If (VALEUR <> 0 )
      [M:MFS0]DPRRATFLG(nolign-1) = G_OUI:  Affzo [M:MFS0]DPRRATFLG(nolign-1)
       Chgstl [M:MFS0]DPRRAT(nolign-1) With "TFORCAGE"
    Else
      [M:MFS0]DPRRATFLG(nolign-1) = G_NON:  Affzo [M:MFS0]DPRRATFLG(nolign-1)
      Chgstl [M:MFS0]DPRRAT(nolign-1) With ""
    Endif
  Endif

  Local Integer LIG_CHG, NOL
  LIG_CHG = G_OUI :  NOL = nolign
  If ( VALEUR = [M:MFS0]DPRRATO(nolign-1) )
    [M:MFS0]DPRRAT(nolign-1) = VALEUR : Affzo [M:MFS0]DPRRAT(nolign-1)
    LIG_CHG = func TRTFASMTC2.DETECTE_CHG_LIG(NOL)
  Endif
  Gosub GESTION_ECART      From TRTFASMTC2
  Gosub GESTION_FLGERR     From TRTFASMTC2

End
#===========================
Subprog B1_DPRRAT(VALEUR)
Variable Decimal VALEUR

  # Gestion du code forçage
  [M:MFS0]DPRRATFLG(nolign-1) = G_NON : Affzo [M:MFS0]DPRRATFLG(nolign-1)

  Raz [M:MFS0]DPRRAT(nolign-1)
  Raz VALEUR

  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:MFS0]DPRRAT(nolign-1)  With ""
  Affzo [M:MFS0]DPRRAT(nolign-1)

  Local Integer LIG_CHG, NOL
  LIG_CHG = G_OUI :  NOL = nolign
  If ( [M:MFS0]DPRRATFLG(nolign-1) = [M:MFS0]DPRRATFLGO(nolign-1) )
    LIG_CHG = func TRTFASMTC2.DETECTE_CHG_LIG(NOL)
  Endif
  Gosub GESTION_ECART      From TRTFASMTC2
  Gosub GESTION_FLGERR     From TRTFASMTC2

  mkstat = 99

End
######################################################################################
Subprog AV_DPRRAT2(VALEUR)
Variable Decimal VALEUR

 Local Char PAYS(GLONCRY)
 PAYS = func TRTFAS.GET_MODE_PAYS( "", "IT" )
 Local Char LEGI
 LEGI = func TRTFAS.GET_MODE_LEGISLATION( "", "IT" )


 # Affichage ou effacement de la colonne en fonction de la société sélectionnée
 If !( (PAYS = "" or ( PAYS <> "" and func GLOFCYCPY.GET_SOC_PAYS([M:MFS0]CPY(0)) = PAYS )) and
&      (LEGI = "" or ( LEGI <> "" and func GLOFCYCPY.GET_SOC_LEG ([M:MFS0]CPY(0)) = LEGI )) )
   Chgfmt [M:MFS0]DPRRAT2(nolign-1) With "-N:3.6#"
 Else
   Chgfmt [M:MFS0]DPRRAT2(nolign-1) With "N:3.6#"
 Endif

 # Désactivation de la zone si le mode est différent de IT. FQ84283
 If [M:MFS0]DPM<>G_DPMIT & G_DPMIT<>"" & [M:MFS0]DPM<>G_DPMAL & G_DPMAL<>""  & [M:MFS0]DPM<>G_DPMAD & G_DPMAD<>""
  Diszo [M:MFS0]DPRRAT2(nolign-1)
 Else
  Actzo [M:MFS0]DPRRAT2(nolign-1)
 Endif

End
#===========================
Subprog AM_DPRRAT2(VALEUR)
Variable Decimal VALEUR

  # Contrôle de la valeur du taux anticipato saisi
  If ( VALEUR > 1 or VALEUR < 0 )
    GERR= 1: GMESSAGE = mess(83,123,1)
    mkstat = 2 : End
  Endif

  #---------------------------------------------
  If ( [M:MFS0]DPM=G_DPMIT & G_DPMIT<>""  ) Then : # FQ84283
    # Contrôle de la valeur du taux saisi en fonction du taux ordinario
    If VALEUR>[M:MFS0]DPRRAT(nolign-1)
      GERR=1 : GMESSAGE = mess(483,GML_MSGFAS,1)
      mkstat = 2: End
    Endif

    # Contrôle si le taux anticipato est saisissable en fonction du numéro d'annuité
    If !clalev([F:MAS1]) : Local File FXDASSETS  [MAS1] : Endif
    Local Integer L_NUMANNUITE
    Local Integer L_NBANNMAX
    Read [F:MAS1]FAS0=[M:MFS0]OBJREFDSP(0)

    Case [F:MAS1]PURNAT
      When GVML_NANEUF
        L_NBANNMAX = 3
      When GVML_NAOCCAS
        L_NBANNMAX = 1
    Endcase

    L_NUMANNUITE = func GLOBB8.TX_ANTICIPATO_PERMIS([M:MFS0]CPY(0), [M:MFS0]CNX(nolign-1), [F:MAS1]PURNAT,
&                              [M:MFS0]STRDPRDAT(nolign-1), [M:FASM]FIYSTRDAT(nolign-1), [M:FASM]FIYENDDAT(nolign-1))
    If ( L_NUMANNUITE > L_NBANNMAX ) Then
      If ( L_NBANNMAX=1 ) Then
        GMESSAGE = mess(489,GML_MSGFAS,1)
      Elsif ( L_NBANNMAX=3 ) Then
        GMESSAGE = mess(490,GML_MSGFAS,1)
      Endif
      GERR=1: mkstat = 2: End
    Endif
  Endif
  #---------------------------------------------

  # Changement de valeur de DPRRAT2

  Local Integer LIG_CHG, NOL
  LIG_CHG = G_OUI :  NOL = nolign
  If ( VALEUR = [M:MFS0]DPRRAT2O(nolign-1) )
    [M:MFS0]DPRRAT2(nolign-1) = VALEUR : Affzo [M:MFS0]DPRRAT2(nolign-1)
    LIG_CHG = func TRTFASMTC2.DETECTE_CHG_LIG(NOL)
  Endif

  Gosub GESTION_ECART      From TRTFASMTC2
  Gosub GESTION_FLGERR     From TRTFASMTC2

End
######################################################################################
Subprog AM_RSDVAL(VALEUR)
Variable Decimal VALEUR

Local Integer LERROR, I_PLN, J, I_TPF

  I_PLN=find([M:MFS0]DPRPLN(nolign-1),[M:FASM]DPRPLND)

  If ( VALEUR > [M:MFS0]RSDVAL(nolign-1) )
    Call CTRL_RSDVAL (VALEUR, [M:MFS0]OBJREFDSP(0),
&                    [M:MFS0]DPRPLN(nolign-1),[M:FASM]FIYENDDAT(I_PLN-1), [M:FASM]PERENDDAT(I_PLN-1),
&                    LERROR) From TRTFAS
    If (LERROR)
      GERR=1 :  GMESSAGE = mess(LERROR,GML_MSGFAS,1)
      mkstat = 2: End
    Endif

  Endif

  If  ( [M:MFS0]DPRCUM(nolign-1)    <> 0  and
&       [M:MFS0]RSDVALO(nolign-1)   <> VALEUR )
    # Si changement valeur résiduelle
    # FQ82075 FQ105809
    If (( find([M:MFS0]DPMO(nolign-1), G_DPMLP, G_DPMSL, G_DPMTL) > 0) and
&     [M:MFS0]DPM(nolign-1) <> G_DPMRE )
      # Ce mode ne permet pas d'amortir à partir de la valeur nette.
      GERR=1 : GMESSAGE = mess(225,GML_MSGFAS,1)
      mkstat = 2: End
    Endif
  Endif

  Local Integer LIG_CHG, NOL
  LIG_CHG = G_OUI :  NOL = nolign
  If ( VALEUR = [M:MFS0]RSDVALO(nolign-1) )
    [M:MFS0]RSDVAL(nolign-1) = VALEUR : Affzo [M:MFS0]RSDVAL(nolign-1)
    LIG_CHG = func TRTFASMTC2.DETECTE_CHG_LIG(NOL)
  Endif
  Gosub GESTION_ECART      From TRTFASMTC2
  Gosub GESTION_FLGERR     From TRTFASMTC2

  # Report valeur résiduel sur plans selon indicateur "Modif VR"
  Local Decimal MTDES
  Local Integer STAT
  For J = 1 To [M:FASM]NBLIG1
    If (J <> I_PLN and [M:FASM]RSDFLG(J-1) = G_OUI )
      I_TPF=find([M:FASM]DPRPLND(J-1),[M:MFS0]DPRPLN)
      # Conversion en devise plan ( devise origine, devise destination,,,,)
      MTDES = VALEUR
      If ( [M:FASM]CURD(I_PLN-1) <> [M:FASM]CURD(J-1) )
        Call CONVERT3([M:FASM]CURD(I_PLN-1), [M:FASM]CURD(J-1), GCOUDEV, 0, [0/0/0],
&                      MTDES, MTDES, [M:MFS0]RATCUR(I_TPF-1), STAT) From CPTSUB
        If ( STAT = 0 )
           Call GET_MNT_ARRONDI (MTDES, [M:FASM]CURD(J-1), MTDES) From GLOBIENS
        Endif
      Endif

      Call CTRL_RSDVAL (MTDES, [M:MFS0]OBJREFDSP(0),
&        [M:FASM]DPRPLND(J-1),[M:FASM]FIYENDDAT(J-1), [M:FASM]PERENDDAT(J-1),
&        LERROR) From TRTFAS
      #---------------------
      If not (LERROR)
        [M:MFS0]RSDVAL(I_TPF-1) = MTDES : Affzo [M:MFS0]RSDVAL(I_TPF-1)
        LIG_CHG = G_OUI :  NOL = I_TPF
        If ( [M:MFS0]RSDVAL(I_TPF-1) = [M:MFS0]RSDVALO(I_TPF-1) )
          LIG_CHG = func TRTFASMTC2.DETECTE_CHG_LIG(NOL)
        Endif
        Gosub GESTION_ECART      From TRTFASMTC2
        Gosub GESTION_FLGERR     From TRTFASMTC2
      Endif
    Endif
  Next J

End
######################################################################################
Subprog AM_CRBVEHCOD(VALEUR)
Variable Char    VALEUR()

  Local Integer LIG_CHG, NOL
  LIG_CHG = G_OUI :  NOL = nolign
  If ( VALEUR = [M:MFS0]CRBVEHCODO(nolign-1) )
    [M:MFS0]CRBVEHCOD(nolign-1) = VALEUR : Affzo [M:MFS0]CRBVEHCOD(nolign-1)
    LIG_CHG = func TRTFASMTC2.DETECTE_CHG_LIG(NOL)
  Endif
  Gosub GESTION_ECART      From TRTFASMTC2
  Gosub GESTION_FLGERR     From TRTFASMTC2

End
######################################################################################
Subprog AS_ALWCOD(VALEUR)
Variable Integer VALEUR

  Local  Char PCLASSE
  Local  Char PNOMVAR, PNOMVAR2
  Global Char G_COURDPM, G_COURPLN

  G_COURDPM = ""
  G_COURPLN = ""

  PCLASSE    = "[M:MFS0]"
  PNOMVAR    = "DPM(nolign-1)"
  G_COURDPM  =  PCLASSE+PNOMVAR

  PNOMVAR2    = "DPRPLN(nolign-1)"
  G_COURPLN  =   PCLASSE+PNOMVAR2

  If ( [M:MFS0]DPM(nolign-1) <> "" )  or ( [M:MFS0]DPRPLN(nolign-1) <> G301FIS )   : # FQ64478
    Gosub COMMUN_AS_ALWCOD From TRTFAS
  Endif

  G_COURDPM = ""
  G_COURPLN = ""

End
#===========================
Subprog AM_ALWCOD(VALEUR)
Variable Integer VALEUR

  If  ( [M:MFS0]DPRCUM(nolign-1)    <> 0 and
&       [M:MFS0]ALWCODO(nolign-1)   <> VALEUR )
    # Si changement règle particulière
    # FQ82075 FQ105809
    If (( find([M:MFS0]DPMO(nolign-1), G_DPMLP, G_DPMSL, G_DPMTL) > 0) and
&         [M:MFS0]DPM(nolign-1) <> G_DPMRE )
      # Ce mode ne permet pas d'amortir à partir de la valeur nette.
      GERR=1 : GMESSAGE = mess(225,GML_MSGFAS,1)
      mkstat = 2: End
    Endif
  Endif

   #*X3-61112
   If VALEUR = GVML_RPDED40
     Local Integer ROK
     # Si la date d'achat est > à la date de fin d'application de la règle particulière,
     # assurez-vous de votre droit à l'appliquer. Confirmez-vous?
     Call OUINON(mess(942,GML_MSGFAS,1)-" "-mess(943,GML_MSGFAS,1),ROK) From GESECRAN
     If (ROK = G_NON)
       zonsui = "[M:MFS0]ALWCODD(nolign-1)"
       GERR=1
       mkstat = 2 : End
     Endif
   Endif #*X3-61112 End

  Local Integer LIG_CHG, NOL
  LIG_CHG = G_OUI :  NOL = nolign
  If ( VALEUR = [M:MFS0]ALWCODO(nolign-1) )
    [M:MFS0]ALWCOD(nolign-1) = VALEUR : Affzo [M:MFS0]ALWCOD(nolign-1)
    LIG_CHG = func TRTFASMTC2.DETECTE_CHG_LIG(NOL)
  Endif
  Gosub GESTION_ECART      From TRTFASMTC2
  Gosub GESTION_FLGERR     From TRTFASMTC2

End
######################################################################################
Subprog AS_ALWAMT_MFS(VALEUR)
Variable Decimal VALEUR

 #*X3-61112 +GVML_RPDED40
 If (find([M:MFS0]ALWCOD(nolign-1), GVML_RPAID25, GVML_RPAID50, GVML_RPAID30, GVML_RPBOI30,
&                                   GVML_RPENERG, GVML_RPMAJ10, GVML_RPDRECH, GVML_RPPR39B, GVML_RPDED40  ) )
   Effzo [M:MFS0]ALWAMT(nolign-1)
Else
   Actzo [M:MFS0]ALWAMT(nolign-1)
Endif

End
#===========================
Subprog C_ALWAMT_MFS(VALEUR)
Variable Decimal VALEUR

If VALEUR <> 0
   If !clalev([F:DEPC]) : Local File DEPREC [DEPC] : Endif
   # Lecture DEPREC pour l'exercice et la période courante
   Read [DEPC] DEP0=[M:MFS0]OBJREF;[M:MFS0]DPRPLN(nolign-1);
&                   [M:MFS0]FIYENDDAT(nolign-1); [M:MFS0]PERENDDAT(nolign-1)  : # FQ64478
   If fstat= 0
      Call CAL_VALEUR_NETTE ("RDP",[F:DEPC]DPRBAS, 3, 0, S01VALNET  ) From GLOBB4
      If VALEUR >= S01VALNET
         # "le montant saisi doit être < à la valeur nette début période"
         GERR=1 : GMESSAGE = mess(629,GML_MSGFAS,1)
         mkstat = 2
         End
      Endif
   Endif
Endif

End
######################################################################################
Subprog AV_ACLCOE(VALEUR)
Variable Decimal VALEUR
End
#===========================
Subprog AM_ACLCOE(VALEUR)
Variable Decimal VALEUR
End
######################################################################################
Subprog AV_PRATYP(VALEUR)
Variable Integer VALEUR

  If ( [M:MFS0]PRATYPFLG(nolign-1) = G_OUI )
       Actzo [M:MFS0]PRATYP(nolign-1)
  Else
     Diszo [M:MFS0]PRATYP(nolign-1)
  Endif

End
######################################################################################
Subprog AS_PRATYP(VALEUR)
Variable Integer VALEUR

If [M:MFS0]PRATYPFLG(nolign-1) = G_OUI
  Actzo [M:MFS0]PRATYP(nolign-1)
Else
   Affzo [M:MFS0]PRATYP(nolign-1)
   Diszo [M:MFS0]PRATYP(nolign-1)
Endif

If [M:MFS0]ENDDPRFLGO(nolign-1)= G_OUI   #*Fq1-524
   Diszo [M:MFS0]PRATYP(nolign-1)  :     # FQ64478
Endif

If ( find([M:MFS0]DPM(nolign-1), G_DPMUD,G_DPMUL,G_DPMTD) >0)
  # Si le type de prorata est "Declining Balance", "Straight line", "Dégressif turque"
  # le prorata ne peut pas être "Jour" ni "Semaine" FQ89488 FQ105809.
  GMENLOC(GVML_TPJOUR) = 1
  GMENLOC(GVML_TPSEMA) = 1
Endif
If ( find([M:MFS0]DPM(nolign-1), G_DPMHL, G_DPMHD, G_DPMTL) > 0 )
  # Si le type de prorata est "Linéaire suisse, Dégressif suisse" ou Linéaire turque
  # le prorata ne peut être que "Jour" ou "Mois". FQ84281 FQ105809
  GMENLOC(GVML_TPSEMA) = 1
  GMENLOC(GVML_TPHLFY) = 1
  GMENLOC(GVML_TPHLFM) = 1
  GMENLOC(GVML_TPHLFQ) = 1
Endif


End
#===========================
Subprog AM_PRATYP(VALEUR)
Variable Integer VALEUR

End
#=============================
Subprog C_PRATYP(VALEUR)
Variable Integer VALEUR

If ( ACTMETNAM = "FASMTC" )
 If ( [M:MFS0]PRATYPFLG(nolign-1) = G_OUI) and ( VALEUR = 0  and [M:MFS0]PRATYPO(nolign-1) = 0)
    #  Le type de prorata doit être saisi pour ce mode
     GERR=1 : GMESSAGE = mess(571,GML_MSGFAS,1)
    mkstat = 2 : End
 Endif
Endif

End
######################################################################################
Subprog AS_ITSDAT_MFS(VALEUR)
Variable Date VALEUR

  #-1 ---------------------------
  If  (ACTTYPGES = GTAMUNI)
      [M:MFS0]ITSDAT(nolign-1) = [M:FASC]ITSDATD
      Diszo [M:MFS0]ITSDAT(nolign-1)
  Else
     If ( ACTMETNAM = "FASTRFC" )
        Actzo [M:MFS0]ITSDAT(nolign-1)
     Endif
  Endif

End
#===========================
Subprog AM_ITSDAT_MFS(VALEUR)
Variable Date  VALEUR

 If ( ACTMETNAM = "FASTRFC" )
    If VALEUR <> [M:MFS0]ITSDAT(nolign-1)
       [M:MFS0]ITSDAT(nolign-1) = VALEUR :  Affzo  [M:MFS0]ITSDAT(nolign-1)
       For I_PLN=1 To [M:MFS0]NBPLN
          # actualisation de la date de début d'amortissement avec la date de mise en service modifiée
          # si mode à pour pt de départ la date de mise en service
          Case func TRTFAS.GET_DPRSTRDAT_TYP([M:MFS0]DPM(I_PLN-1), [M:FASC]CPY2)
             When GVML_TITSDAT :  [M:MFS0]STRDPRDAT(I_PLN-1) = VALEUR
             When Default
          Endcase
          Affzo [M:MFS0]STRDPRDAT(I_PLN-1)
       Next I_PLN
    Endif
 Endif

End
##############################################################
Subprog AS_MTCDEVADJ_MFS(VALEUR)
Variable Integer VALEUR

Local Char  LPARM
   #* Gestion écart = "Dotation période" si mise en service
   # Si PRVSITUPD = "Non" et date début d'amort ant début exercice et cumul exercice forcé à 0
   #FQ80039
   Call PARAM([M:FASM]CPY1(nolign-1),"PRVSITUPD",LPARM) From ADOVAL
   GPRVSITUPD = val(LPARM)
   If ( [M:MFS0]STRDPRDAT(nolign-1)  < [M:MFS0]FIYSTRDAT(nolign-1) )
     If  ( (ACTMETNAM = "FASTRFC" )  and  [M:MFS0]MTCTIATYP(nolign-1) <>  GVML_PEDBAM )   or
&        (  GPRVSITUPD <> G_OUI    and [M:MFS0]DPRCUM(nolign-1) = 0 and [M:MFS0]DPRCUMFLG(nolign-1) = G_OUI )
        [M:MFS0]MTCDEVADJ(nolign-1) = GVML_RDOTPER
         #FQ80039 inutile d'interdire
#         GMENLOC(GVML_RREPAN)   = 1
#         GMENLOC(GVML_REXCEXE)  = 1
#         GMENLOC(GVML_REXCPER)  = 1
#         GMENLOC(GVML_RDOTEXE)  = 1
     Else
        # Gestion écart = "Dotation EXCEPTIONNEL PERIODE" si date de début amort< début d'exercice courant
        [M:MFS0]MTCDEVADJ(nolign-1)=GVML_REXCPER
     Endif
   Else
      # Si date de début amort > = début d'exercice courant ==> pas de gestion d'écart
      # Issue 113764
      #[M:MFS0]MTCDEVADJ(nolign-1) = 0
      Diszo [M:MFS0]MTCDEVADJ(nolign-1)
   Endif
   Affzo  [M:MFS0]MTCDEVADJ(nolign-1)

End
##########################################################################
Subprog C_MTCDEVADJ_MFS(VALEUR)
Variable Integer VALEUR

If (VALEUR = 0)  & ( [M:MFS0]STRDPRDAT (nolign-1)  < [M:MFS0]FIYSTRDAT(nolign-1) )
   GERR=1
   #GMESSAGE = "Vous devez mentionner le type de gestion d'écart"
   GMESSAGE = mess(903,GML_MSGFAS,1) : # FQ89367 "Vous devez mentionner le type de gestion d'écart"
   mkstat = 2
   End
Endif

End
###############################
Subprog AM_MTCDEVADJ_MFS(VALEUR)
Variable Integer VALEUR

End
