$ON_MIDPAB1
Onevent BEFORE_AREA Gosub AV_MIDPAB1 From W2HRMAT7
Return

$AV_MIDPAB1
## Action FMTPABPAY
Call FMTPABPAY("") From TRTDIV
If GFMT<>""
 Chgfmt [M]MIDPAB1(indice) With "K:"+GFMT
Else
 Chgfmt [M]MIDPAB1(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_MIDPAB2
Onevent BEFORE_AREA Gosub AV_MIDPAB2 From W2HRMAT7
Return

$AV_MIDPAB2
## Action FMTPABPAY
Call FMTPABPAY("") From TRTDIV
If GFMT<>""
 Chgfmt [M]MIDPAB2(indice) With "K:"+GFMT
Else
 Chgfmt [M]MIDPAB2(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_MIDCRY
Onevent CONTROL Call C_MIDCRY(zc) From W2HRMAT7
Onevent BEFORE_INPUT Call AS_MIDCRY(zc) From W2HRMAT7
Onevent INIT_AREA Call D_MIDCRY(zc) From W2HRMAT7
Return

Subprog D_MIDCRY(VALEUR)
Variable Char    VALEUR()
If varinit([M]MIDCRY,indice)=0
 VALEUR = [F:CPY]CRY
Endif
Gosub _AFF
End

Subprog AS_MIDCRY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(53316,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_MIDCRY(zc) From W2HRMAT7
Onkey   2 Titled GBOUTS Call S_MIDCRY(zc) From W2HRMAT7
Onkey 144 Titled GBOUTP Call P_MIDCRY(zc) From W2HRMAT7
Onkey 146 Titled GBOUTA Call SA_MIDCRY(zc) From W2HRMAT7
Gosub _AFF
End

Subprog C_MIDCRY(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCY","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "MIDCRY" : GZNUM = 235 : Endif
Gosub _AFF
End

Subprog S_MIDCRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_MIDCRY(VALEUR)
Variable Char    VALEUR()
Call OBJET("TCY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_MIDCRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_MIDCRY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_BANCAI
Onevent INIT_AREA Call D_BANCAI(zc) From W2HRMAT7
Return

Subprog D_BANCAI(VALEUR)
Variable Char    VALEUR()
If varinit([M]BANCAI,indice)=0
 VALEUR = "HRBAN"
Endif
Gosub _AFF
End

$ON_BNKDEF
Onevent CONTROL Call C_BNKDEF(zc) From W2HRMAT7
Onevent INIT_AREA Call D_BNKDEF(zc) From W2HRMAT7
Onevent BEFORE_INPUT Call AS_BNKDEF(zc) From W2HRMAT7
Return

Subprog D_BNKDEF(VALEUR)
Variable Integer VALEUR
If varinit([M]BNKDEF,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_BNKDEF(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_BNKDEF(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_BNKDEF(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "BNKDEF" : GZNUM = 4295 : Endif
Gosub _AFF
End

$ON_BDFECOCOD
Onevent INIT_AREA Call D_BDFECOCOD(zc) From W2HRMAT7
Onevent CONTROL Call C_BDFECOCOD(zc) From W2HRMAT7
Onevent BEFORE_INPUT Call AS_BDFECOCOD(zc) From W2HRMAT7
Onevent AFTER_CHANGE Gosub AMM_BDFECOCOD From W2HRMAT7
Return

Subprog D_BDFECOCOD(VALEUR)
Variable Char    VALEUR()
If varinit([M]BDFECOCOD,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10309","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_BDFECOCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10309") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_BDFECOCOD(zc) From W2HRMAT7
Onkey   2 Titled GBOUTS Call S_BDFECOCOD(zc) From W2HRMAT7
Onkey 144 Titled GBOUTP Call P_BDFECOCOD(zc) From W2HRMAT7
Onkey 146 Titled GBOUTA Call SA_BDFECOCOD(zc) From W2HRMAT7
Gosub _AFF
End

Subprog C_BDFECOCOD(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10309","") From SUBADI
If mkstat : GERR = 1 : GZONE = "BDFECOCOD" : GZNUM = 7511 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10309",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "BDFECOCOD" : GZNUM = 7511 : Endif
Endif
Gosub _AFF
End

$AMM_BDFECOCOD
Call AM_BDFECOCOD(zc)
If !mkstat & GOBJET
 zoncou = "BDFECOCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_BDFECOCOD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZBDFECOCOD)")>indice
 [M]BDFECOCOD(indice) = VALEUR
 Affzo ZBDFECOCOD(indice)
Endif
Gosub _AFF
End

Subprog S_BDFECOCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10309"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_BDFECOCOD(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10309") From GOBJET
Gosub _AFF
End

Subprog SA_BDFECOCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10309"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_BDFECOCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10309"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZBDFECOCOD
Onevent BEFORE_AREA Gosub AV_ZBDFECOCOD From W2HRMAT7
Return

$AV_ZBDFECOCOD
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10309",num$([M]BDFECOCOD(indice))) From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


