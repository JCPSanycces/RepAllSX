Call FMTPABPAY([M]BIDCRY) From TRTDIV
If GFMT<>""
 Chgfmt [M]PAB2(indice) With "K:"+GFMT
Else
 Chgfmt [M]PAB2(indice) With "-K:1X"
Endif
Gosub _AFF
