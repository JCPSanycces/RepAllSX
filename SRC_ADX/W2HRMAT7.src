#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT7 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_BNKACCNAM
Onevent BEFORE_AREA Gosub AV_BNKACCNAM From W2HRMAT7
Return

$AV_BNKACCNAM
## Action STD
Call AV_BNKACCNAM(zc) From SUBEML2
Gosub _AFF
Return

$ON_PAYSPT
Onevent CONTROL Call C_PAYSPT(zc) From W2HRMAT7
Onevent INIT_AREA Call D_PAYSPT(zc) From W2HRMAT7
Onevent BEFORE_INPUT Call AS_PAYSPT(zc) From W2HRMAT7
Return

Subprog D_PAYSPT(VALEUR)
Variable Integer VALEUR
If varinit([M]PAYSPT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PAYSPT(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_PAYSPT(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_PAYSPT(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "PAYSPT" : GZNUM = 1001604 : Endif
Gosub _AFF
End

$ON_PAYPCT
Onevent BEFORE_INPUT Call AS_PAYPCT(zc) From W2HRMAT7
Onevent CONTROL Call C_PAYPCT(zc) From W2HRMAT7
Return

Subprog AS_PAYPCT(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_PAYPCT(VALEUR) From SUBEML2
If mkstat=2
 [M]PAYPCT(INDIC) = VALEUR
 Affzo PAYPCT(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_PAYPCT(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PAYPCT" : GZNUM = 5188 : Endif
If !mkstat
 ## Action STD
 Call C_PAYPCT(VALEUR) From SUBEML2
 If mkstat : GERR = 1 : GZONE = "PAYPCT" : GZNUM = 5188 : Endif
Endif
Gosub _AFF
End

$ON_PAYAMT
Onevent CONTROL Call C_PAYAMT(zc) From W2HRMAT7
Return

Subprog C_PAYAMT(VALEUR)
Variable Decimal VALEUR
## Action STD
Call C_PAYAMT(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "PAYAMT" : GZNUM = 3603 : Endif
Gosub _AFF
End

$ON_PAB1
Onevent BEFORE_AREA Gosub AV_PAB1 From W2HRMAT7
Onevent CONTROL Call C_PAB1(zc) From W2HRMAT7
Return

$AV_PAB1
## Action FMTPABPAY
Call FMTPABPAY([M]BIDCRY) From TRTDIV
If GFMT<>""
 Chgfmt [M]PAB1(indice) With "K:"+GFMT
Else
 Chgfmt [M]PAB1(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog C_PAB1(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_PAB1(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "PAB1" : GZNUM = 1496 : Endif
Gosub _AFF
End

