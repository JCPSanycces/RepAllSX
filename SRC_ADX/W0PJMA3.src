#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMA3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBPJM3
mkstat = 0
zoncou = "NBPJM3"
indice = 0
status = 1
zoncou = "NBPJM3"
If varmode([M]NBPJM3,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBPJM3" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBPJM3
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBPJM3 = nolign
   status = 75
   Call SAI_NBPJM3(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBPJM3 From SUBPJM
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBPJM3" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBPJM3(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBPJM3
mkstat = 0
zoncou = "NBPJM3"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBPJM3 From SUBPJM
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBPJM3" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone SBBPJT
mkstat = 0
zoncou = "SBBPJT"
WCHAR = [M]SBBPJT(indice)
If varmode([M]SBBPJT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SBBPJT" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]SBBPJT(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SBBPJT" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("PIM","E",[M]SBBPJT(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "SBBPJT" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]SBBPJT(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_SBBPJT([M]SBBPJT(indice)) From SUBPJM
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "SBBPJT" : GZNUM = 5296 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone CONSFLG
mkstat = 0
zoncou = "CONSFLG"
IMPENT = [M]CONSFLG(indice)
WNUM = IMPENT
If varinit([M]CONSFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]CONSFLG,indice)=0
 [M]CONSFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CONSFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CONSFLG(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CONSFLG" : GZNUM = 4019 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_CONSFLG(IMPENT) From SUBPJM
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CONSFLG" : GZNUM = 4019 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]CONSFLG(indice) = IMPENT

## Zone NBPJM3
mkstat = 0
zoncou = "NBPJM3"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMA3"
Return

