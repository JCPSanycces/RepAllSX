$ON_OPPNUM
Onevent BEFORE_INPUT Call AS_OPPNUM(zc) From W1PTEVAL0
Onevent CONTROL Call C_OPPNUM(zc) From W1PTEVAL0
Onevent AFTER_CHANGE Gosub AMM_OPPNUM From W1PTEVAL0
Return

Subprog IB_OPPNUM(VALEUR)
Variable Char    VALEUR()
## Action IBUPJMPIM
Call IBUPIM(VALEUR) From PJMSELECT
Gosub _AFF
End

Subprog AS_OPPNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(14664,GBOUT1) From OBJDIV
Call TEXTE(14664,GBOUT2) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Call IB_OPPNUM(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_OPPNUM(zc) From W1PTEVAL0
Onkey 130 Titled GBOUT2 Call B2_OPPNUM(zc) From W1PTEVAL0
Onkey   2 Titled GBOUTS Call S_OPPNUM(zc) From W1PTEVAL0
Onkey 144 Titled GBOUTP Call P_OPPNUM(zc) From W1PTEVAL0
Onkey 146 Titled GBOUTA Call SA_OPPNUM(zc) From W1PTEVAL0
Gosub _AFF
End

Subprog C_OPPNUM(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("PIM","!A",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 18260 : Endif
Gosub _AFF
End

$AMM_OPPNUM
Call AM_OPPNUM(zc)
If !mkstat & GOBJET
 zoncou = "OPPNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZOPPNUM)")>indice
 [M]OPPNUM(indice) = VALEUR
 Affzo ZOPPNUM(indice)
Endif
Gosub _AFF
End

Subprog S_OPPNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPJMOPP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPJMOPP"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = [M:PJT0]CLB
 PARMSK(4) = num$([V]CST_ANO)
 PARMSK(5) = ""
 PARMSK(6) = "[F:PIM]PIMNUM desc"
 PARMSK(7) = ""
 PARMSK(8) = ""
 PARMSK(9) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPJMOPP","PJMSELECT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_OPPNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPJMPIM
 Call TUNPIM(VALEUR) From PJMSELECT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_OPPNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPJMOPP
 Call TUNCRM(VALEUR) From PJMSELECT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_OPPNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "PIM"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_OPPNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("PIM",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZOPPNUM
Onevent BEFORE_AREA Gosub AV_ZOPPNUM From W1PTEVAL0
Return

$AV_ZOPPNUM
Call LECTEXTRA(zc,"PIMPL","PIMDESAXX",num$([M]OPPNUM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_TSDATE
Onevent BEFORE_AREA Gosub AV_TSDATE From W1PTEVAL0
Return

$AV_TSDATE
Chgfmt [M]TSDATE(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_TEDATE
Onevent CONTROL Call C_TEDATE(zc) From W1PTEVAL0
Onevent BEFORE_AREA Gosub AV_TEDATE From W1PTEVAL0
Return

$AV_TEDATE
Chgfmt [M]TEDATE(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog C_TEDATE(VALEUR)
Variable Date    VALEUR
## Action STD
Call C_TEDATE(VALEUR) From SUBPTEVAL
If mkstat : GERR = 1 : GZONE = "TEDATE" : GZNUM = 1806 : Endif
Gosub _AFF
End

$ON_PTESTA
Onevent BEFORE_INPUT Call AS_PTESTA(zc) From W1PTEVAL0
Onevent INIT_AREA Call D_PTESTA(zc) From W1PTEVAL0
Onevent CONTROL Call C_PTESTA(zc) From W1PTEVAL0
Return

Subprog D_PTESTA(VALEUR)
Variable Integer VALEUR
If varinit([M]PTESTA,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_PTESTA(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(2074) From COMBOS
## Action STD
Call AS_PTESTA(VALEUR) From SUBPTEVAL
If mkstat=2
 [M]PTESTA(INDIC) = VALEUR
 Affzo PTESTA(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,2074,1))))
Endif
If !mkstat
 Discombo 0 From PTESTA(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From PTESTA(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_PTESTA(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PTESTA" : GZNUM = 1179 : Endif
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$CHG_STY
Return


