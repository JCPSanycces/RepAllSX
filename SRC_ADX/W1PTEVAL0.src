Call CONTSEL("PAUS","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "CLB" : GZNUM = 16058 : Endif
Gosub _AFF
End

$AMM_CLB
Call AM_CLB(zc)
If !mkstat & GOBJET
 zoncou = "CLB" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

