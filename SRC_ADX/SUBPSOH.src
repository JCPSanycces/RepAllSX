#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
Funprog UPDATE_PSPLD(IACTION)
Value Integer IACTION

Local Integer MY_STATUS

  [L]MY_STATUS = func DO_UPDATE_PSPLD(IACTION, [M:PSO0]OPPNUM, [M:PSO0]PSONUM)
End MY_STATUS

###################################################################################################
Funprog DO_UPDATE_PSPLD(IACTION, SOPPNUM, SPSONUM)
Value Integer IACTION
Value Char SOPPNUM
Value Char SPSONUM

Local Integer MY_STATUS
Local Instance INSOPP Using C_OPPOR
Local Instance TECSPLDSOLD Using C_TECSPLDSOLD

  INSOPP = NewInstance C_OPPOR AllocGroup null
  TECSPLDSOLD = NewInstance C_TECSPLDSOLD AllocGroup null
  # -----------------------------
  [L]MY_STATUS = fmet INSOPP.PJM_SPLD_SOLD(SOPPNUM, SPSONUM, IACTION, TECSPLDSOLD)
  If [L]MY_STATUS <> [V]CST_AOK Then
    # -----------------------------
    Call RECOVERS_ERROR_IN_CLASSIC(INSOPP) From SUBPJMA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(362,2260,1)
    Endif
    If [L]MY_STATUS = [V]CST_AWARNING Then
      GERR = 2
    Else
      GERR = 1
      GOK = 0
    Endif
  Endif
  FreeGroup INSOPP
  FreeGroup TECSPLDSOLD
  Raz INSOPP
  Raz TECSPLDSOLD
End MY_STATUS

###################################################################################################
Funprog SALES_DOC_DELETE_LINE(ZTECPSO)
Variable Instance ZTECPSO Using C_TECPSO

Local Integer IARENDRE
Local Integer ICOUNT
Local Integer NI
Local Char SOPPNUM(GLONOPP)
Local Char SPSONUM(GLONPSO)
Local Integer ISEQNUM
Local Integer ICASE
Local Integer ICOUNTPSO
Local Integer ICOUNTPSOD
Local Integer IADXLOG

  IARENDRE = [V]CST_AOK
  If ZTECPSO <> null Then
    IADXLOG = (adxlog = 1)
    Local File PJMSOLITMH [PSOH]
    Local File PJMSOLITMD [PSOD]
    Local File PJMSOLITMO [PSOO]
    # -----------------------------
    ICOUNTPSO = 0
    For NI = 1 To maxtab(ZTECPSO.PSO)
      If ZTECPSO.PSO(NI) <> null and find(ZTECPSO.PSO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        ICOUNTPSO += 1
        SPSONUM = ZTECPSO.PSO(NI).PSONUM
      Endif
    Next NI
    If ICOUNTPSO > 0 Then
      If IADXLOG = [V]CST_AFALSE Then
        Trbegin [PSOH]
      Endif
      Read [PSOH]PSOH0=SPSONUM
      SOPPNUM = [F:PSOH]OPPNUM
      Filter [F:PSOD] Where PSONUM = SPSONUM
      ICOUNTPSOD = rowcount([F:PSOD])
      Filter [F:PSOD]
      # -----------------------------
      If ICOUNTPSO = ICOUNTPSOD Then
        # We will have to delete PSO...
        IARENDRE = func DO_UPDATE_PSPLD([V]CST_ADEL, SOPPNUM, SPSONUM)
      Endif
      # -----------------------------
      If IARENDRE <= [V]CST_AERROR Then
        For NI = 1 To maxtab(ZTECPSO.PSO)
          If ZTECPSO.PSO(NI) <> null and find(ZTECPSO.PSO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            SPSONUM = ZTECPSO.PSO(NI).PSONUM
            ISEQNUM = ZTECPSO.PSO(NI).SEQNUM
            Filter [F:PSOD] Where PSONUM = SPSONUM
            ICOUNT = rowcount([F:PSOD])
            If ICOUNT > 1 Then
              # Delete the given line
              ICASE = 1
              Readlock [PSOH]PSOH0=SPSONUM
              If !fstat Then
                SOPPNUM = [F:PSOH]OPPNUM
                Read [PSOD]PSOD0=SPSONUM;ISEQNUM
                If !fstat Then
                  Delete [F:PSOO] Where [F:PSOO]PSONUM = SPSONUM and [F:PSOO]PSOLIN = [F:PSOD]SEQNUM
                  If !fstat Then
                    Delete [PSOD]Curr
                    If fstat Then
                      GMESSAGE = mess(385,2260,1)
                      GERR = 1
                      GOK = 0
                      IARENDRE = [V]CST_AERROR
                      Break
                    Endif
                  Else
                    GMESSAGE = mess(385,2260,1)
                    GERR = 1
                    GOK = 0
                    IARENDRE = [V]CST_AERROR
                    Break
                  Endif
                Else
                  GMESSAGE = mess(385,2260,1)
                  GERR = 1
                  GOK = 0
                  IARENDRE = [V]CST_AERROR
                  Break
                Endif
              Else
                GMESSAGE = mess(385,2260,1)
                GERR = 1
                GOK = 0
                IARENDRE = [V]CST_AERROR
                Break
              Endif
            Else
              # Delete the PSO object
              ICASE = 2
              Readlock [PSOH]PSOH0=SPSONUM
              If !fstat Then
                SOPPNUM = [F:PSOH]OPPNUM
                Delete [F:PSOH]Curr
                If !fstat Then
                  Delete [F:PSOD] Where [F:PSOD]PSONUM = SPSONUM
                  If !fstat Then
                    Delete [F:PSOO] Where [F:PSOO]PSONUM = SPSONUM
                    If fstat Then
                      GMESSAGE = mess(385,2260,1)
                      GERR = 1
                      GOK = 0
                      IARENDRE = [V]CST_AERROR
                      Break
                    Endif
                  Else
                    GMESSAGE = mess(385,2260,1)
                    GERR = 1
                    GOK = 0
                    IARENDRE = [V]CST_AERROR
                    Break
                  Endif
                Else
                  GMESSAGE = mess(385,2260,1)
                  GERR = 1
                  GOK = 0
                  IARENDRE = [V]CST_AERROR
                  Break
                Endif
              Else
                GMESSAGE = mess(385,2260,1)
                GERR = 1
                GOK = 0
                IARENDRE = [V]CST_AERROR
                Break
              Endif
            Endif
            Filter [F:PSOD]
          Endif
        Next NI
      Endif
      If IARENDRE < [V]CST_AERROR Then
        If ICASE = 1 Then
          IARENDRE = func DO_UPDATE_PSPLD([V]CST_AUPD, SOPPNUM, SPSONUM)
        Elsif ICASE = 2 Then
          # Warning to the user
          GMESSAGE = func AFNC.MES1(mess(502,2260,1), SPSONUM)
          GERR = 2
        Endif
      Endif
      If IADXLOG = [V]CST_AFALSE Then
        If IARENDRE < [V]CST_AERROR Then
          Commit
        Else
          Rollback
        Endif
      Endif
    Endif
  Endif
End IARENDRE

