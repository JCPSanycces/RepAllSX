#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ACT",GBIDC1,GBIDC2) From GOBJET
End

#######################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "ANNULE"      : Gosub ANNULE
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "AP_ANNULE"   : Gosub AP_ANNULE
Endcase
Return

#######################################################
$OUVRE
Local Integer TPACT , TPTRT , MESPAR
If clalev([F:AMA])=0 : Local File AMSKACT [AMA] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
Return

#######################################################
$LIENS
nolign = 0
Call TEXTE([M]INTITA,[M]ZINTITA) From OBJDIV
Call TEXTE([M]INTITC,[M]ZINTITC) From OBJDIV
For [ATR]NOPAR Where ACTION=[F:ACT]ACTION
 Read [AAR]CODPAR = [F:ATR]CODPAR
 nolign += 1
 [M:ACT2] = [F:ATR]
 [M:ACT2] = [F:AAR]
Next
[M:ACT2]NBPAR = nolign
TPACT = [F:ACT]TYP
TPTRT = [F:ACT]PARAM3
Gosub GRISE_PAR
Call LECTURE_DOC("ACT",[M]ACTION,[M]TEXTE,K) From SUBADO
Return

#######################################################
$AP_ANNULE
# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("ACT",[L]CODE,"A") From AGENLIBA

Return

#######################################################
$VERIF_CRE
Gosub VERIF
Return

#######################################
$VERIF_MOD
Gosub VERIF
MESPAR = 0
If OK
 K = 0
 For [AMA] Where ACTION=[M]ACTION
  K = 1 : Break
 Next AMA
 If !K
  For [ATY]
   K = find([M]ACTION,[F]ACTION)
   If K : Break : Endif
  Next ATY
 Endif
 If K
  For I=1 To [M]NBPAR
   If (I=1 & [M]TYPACT<>2) or I>1
    K = 0
    For [ATR] Where ACTION=[M]ACTION
     If [F:ATR]CODPAR=[M]CODPAR(I-1)
      K = 1 : Break
     Endif
    Next ATR
    If !K
     MESPAR = 1 : Break
    Endif
   Endif
  Next I
 Endif
Endif
Return

#######################################
$VERIF
If [M]TYP<>8
 K = 0
 For I=1 To [M]NBPAR
  If [M]TYPPAR(I-1)>=6
   If I=1 & [M]TYPACT<>2
    K = I : Break
   Elsif I>1
    K = I : Break
   Endif
  Endif
 Next I
 If K
  # Pour ce type d'action, ce paramètre ne peut être utilisé que sur la zone courante
  GMESSAGE = [M]CODPAR(K-1)-":"-mess(214,139,1)
  OK = 0 : zonsui = "NBPAR" : Return
 Endif
Endif
Return

#######################################################
$CREATION
For nolign=1 To [M]NBPAR
 Raz [F:ATR]
 [F:ATR] = [M:ACT0]
 [F:ATR] = [M:ACT2]
 [F:ATR]NOPAR = nolign
 Write [ATR]
 If fstat
  GOK=0 : Call FSTA("ATR") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
# JPGA 27-27-2010 BUG-66277 : ECRIRE_DOC 2 parametres ajoutes : Module et Code activité
Call ECRIRE_DOC("ACT",[M]ACTION,[M]TEXTE,[M]ZINTITA,[M]MODULE,[M]CODACT) From SUBADO
Return

#######################################################
$ANNULE
Call EFFACE_DOC("ACT",[L]CODE) From SUBADO
Return

#######################################################
$MODIF
Delete [ATR] Where ACTION=CLECUR1
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("ATR",CLECUR1) From GLOCK : Return
Endif
Gosub CREATION
Return

#######################################################
$SETBOUT
If CLECUR=0 | REP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return

###################################
$APRES_CRE
# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("ACT",[M]ACTION,"C") From AGENLIBA

Gosub VALTRT

Return

###################################
$APRES_MOD
# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("ACT",[M]ACTION,"M") From AGENLIBA

Gosub VALTRT
If MESPAR
 # Après l'ajout d'un paramètre, il faut renseigner les paramètres dans le dictionnaire écran
 # Le menu "Contrôle" dans le dictionnaire des écrans permet d'avoir la liste des écrans impactés par cette modification
 Call MESSAGE(mess(339,115,1)+"\"+mess(338,115,1)) From GESECRAN
Endif
Return

#######################################################
$VALTRT
If [F:ACT]TYP<>len(mess(0,81,1)) : Return : Endif
Local Char    FICSRC(250) , FICNEW(250) , LIGNE(250)
Local Integer K , STAT , OKTRT
If [M]CODTRT="" : Return : Endif
FICSRC = filpath("TRT",[M]CODTRT,"src",0)
Call EXISTE_ADX("","",[M]CODTRT,OKTRT) From ORDSYS
If OKTRT>0 & filinfo(FICSRC,0)<0 : Return : Endif
adxifs = "" : adxirs = chr$(10)
If filinfo(FICSRC,0)>=0
 OK = 0
 Openi FICSRC
 Rdseq LIGNE
 While fstat=0
  LIGNE = toupper(vireblc(LIGNE,2))
  If left$(LIGNE,7)="SUBPROG"
   LIGNE = vireblc(right$(LIGNE,8),2)
   K = instr(1,LIGNE,"(")
   If K=0 : K = instr(1,LIGNE," ") : Endif
   If K=0 : K = instr(1,LIGNE,":") : Endif
   If K : LIGNE = vireblc(left$(LIGNE,K-1),2) : Endif
   If LIGNE = [M]SUBPRG : OK = 1 : Break : Endif
  Endif
  Rdseq LIGNE
 Wend
 Openi
 If OK : Return : Endif
Endif
FICNEW = filpath("TRT",[M]CODTRT,"new",0)
Openo FICNEW, 0
If filinfo(FICSRC,0)>=0
 Openi FICSRC
 Rdseq LIGNE
 While fstat=0
  Wrseq LIGNE
  Rdseq LIGNE
 Wend
 Openi
Else
 Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"-[M]CODACT
Endif
Wrseq
Wrseq string$(50,"#")
Wrseq "Subprog "+[M]SUBPRG;
If [M]NBPAR<>0
 Wrseq "(";
 For I=0 To [M]NBPAR-1
  If I>0 : Wrseq ","; : Endif
  Wrseq [M]CODPAR(I);
 Next I
 Wrseq ")";
Endif
Wrseq
For I=0 To [M]NBPAR-1
 Case [M]ADRVAL(I)
  When 1 : Wrseq "Variable ";
  When 2 : Wrseq "Value    ";
 Endcase
 Case [M]TYPPAR(I)
  When 1 : Wrseq "Char    ";
  When 2 : Wrseq "Integer ";
  When 3 : Wrseq "Decimal ";
  When 4 : Wrseq "Date    ";
  When 5 : Wrseq "Libelle ";
  When 6 : Wrseq "Clbfile ";
  When 7 : Wrseq "Blbfile ";
 Endcase
 Wrseq [M]CODPAR(I);
 If [M]TYPPAR(I)=1 & [M]ADRVAL(I)=1
  Wrseq "()";
 Endif
 Wrseq
Next I
Wrseq "End"
Wrseq
Openo
FICSRC = filpath("TRT",[M]CODTRT,"src",0)
Call MOVE(FICNEW,FICSRC,STAT) From ORDSYS
Call VALID("TRT",[M]CODTRT,nomap,STAT) From VALMSKSUB
Return

################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File ACTION    [ACT1]
 Local File ACTPAR    [ATR1]
 Local File ACTCODPAR [AAR1]
 Local File ATEXTE    [ATX1]
 Local File ADOCUMENT [ADO1]
 Local File ADOCCLB   [ADH1]
Else
 Local File =[M]DOSORG+".ACTION"    [ACT1]
 Local File =[M]DOSORG+".ACTPAR"    [ATR1]
 Local File =[M]DOSORG+".ACTCODPAR" [AAR1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
 Local File =[M]DOSORG+".ADOCUMENT" [ADO1]
 Local File =[M]DOSORG+".ADOCCLB"   [ADH1]
Endif
If [M]DOSDES=nomap
 Local File ACTION    [ACT2]
 Local File ACTPAR    [ATR2]
 Local File ACTCODPAR [AAR2]
 Local File ATEXTE    [ATX2]
 Local File ADOCUMENT [ADO2]
 Local File ADOCCLB   [ADH2]
Else
 Local File =[M]DOSDES+".ACTION"    [ACT2]
 Local File =[M]DOSDES+".ACTPAR"    [ATR2]
 Local File =[M]DOSDES+".ACTCODPAR" [AAR2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
 Local File =[M]DOSDES+".ADOCUMENT" [ADO2]
 Local File =[M]DOSDES+".ADOCCLB"   [ADH2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ACT1], [ATR1], [AAR1], [ATX1], [ACT2], [ATR2], [AAR2], [ATX2]
Close Local File [ADO1], [ADH1], [ADO2], [ADH2]
Return

$TR_COP
GOK = 1
Trbegin [ACT2] , [ATR2] , [AAR2] , [ATX2]
 Delete [ACT2] Where ACTION=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACTION" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ATR2] Where ACTION=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACTPAR" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ATR2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ACT1]ACTION Where ACTION=TABLE
  [F:ACT2] = [F:ACT1]
  Call COPTEXTE([F:ACT1]INTITA,[F:ACT2]INTITA) From OBJDIV
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:ACT1]INTITC,[F:ACT2]INTITC) From OBJDIV
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:ACT1]INTITL,[F:ACT2]INTITL) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:ACT2]UPDUSR)>0 : [F:ACT2]UPDUSR = GUSER : Endif
  If dim([F:ACT2]UPDDAT)>0 : [F:ACT2]UPDDAT = date$ : Endif
  If dim([F:ACT2]UPDTIM)>0 : [F:ACT2]UPDTIM = time : Endif
  Write [ACT2]
  If fstat
   GOK=0 : Call FSTA("ACT2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ATR1]NOPAR Where ACTION=TABLE
  [F:ATR2] = [F:ATR1]
  Call COPTEXTE([F:ATR1]INTITPAR,[F:ATR2]INTITPAR) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ATR2]
  If fstat
   GOK=0 : Call FSTA("ATR2") From GLOCK : Break
  Endif
  Read [AAR1]CODPAR = [F:ATR1]CODPAR
  If !fstat
   Readlock [AAR2]CODPAR = [F:ATR1]CODPAR
   If fstat=1
    GOK=-1 : GLOCK = "$ACTCODPAR"-[F:ATR]CODPAR : Break
   Elsif fstat
    [F:AAR2] = [F:AAR1]
    Call COPTEXTE([F:AAR1]INTITPAR,[F:AAR2]INTITPAR) From OBJDIV
    Write [AAR2]
   Else
    [F:AAR2] = [F:AAR1]
    Call COPTEXTE([F:AAR1]INTITPAR,[F:AAR2]INTITPAR) From OBJDIV
    Rewrite [AAR2]
   Endif
   If fstat
    GOK=0 : Call FSTA("AAR2") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Call COPIE_DOC("ACT",TABLE,[M]DOSORG,[M]DOSDES) From SUBADO
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#################################################################
## Recherche nom du traitement spécifiques d'une action
#################################################################
Subprog TRTSPE(APPLI,ACTION,NOMSPE)
Value Char APPLI
Value Char ACTION
Variable Char NOMSPE
If APPLI=nomap or APPLI=""
 Local File ACTION [A___]
Else
 Local File =APPLI+".ACTION" [A___]
Endif
Read [A___]ACTION = ACTION
If !fstat
 NOMSPE = [F:A___]SPETRT
Else
 NOMSPE = ""
Endif
Close Local File [A___]
End

##########################################################################
# Etiquettes du masque ACT1
##########################################################################

Subprog AS_SUBPRG(VALEUR)
Variable Char VALEUR()
If [M]CODTRT="" : VALEUR = "" : mkstat=1 : End : Endif
End

###########################################################
## Valeurs de la zone options
##
## A (en valeur par défaut) => Pas de saisie si mkstat
## * (en valeur par défaut) => * adonix
## # (en contrôle)          => Contrôle si chgt de valeur
##
###########################################################

Subprog C_OPTION(VALEUR)
Variable Char    VALEUR()
Local Integer I
For I=1 To len(VALEUR)
 If !instr(1,"A#*",mid$(VALEUR,I,1))
  GMESSAGE = mid$(VALEUR,I,1)-mess(99,123,1)
# Option incorrecte
  mkstat=2 : Break
 Endif
Next I
End

Subprog S_OPTION(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEX , NUM
Local Char    TEX(50)(15)
NBTEX += 1 : TEX(NBTEX) = mess(26,124,1)
# * Toujours effectué
NBTEX += 1 : TEX(NBTEX) = mess(27,124,1)
# A Affichage zone si mkstat=2
NBTEX += 1 : TEX(NBTEX) = mess(28,124,1)
# # Contrôle si changement de valeur
Call SAITEX(NBTEX,TEX,NUM,mess(100,123,1)) From GESECRAN
# Choix options
If NUM<>0 & status<>7
 If !instr(1,VALEUR,left$(TEX(NUM),1))
  VALEUR += left$(TEX(NUM),1)
 Endif
Endif
End

Subprog C_TYP(VALEUR)
Variable Integer VALEUR
Local Integer TPACT , TPTRT
TPACT = VALEUR
TPTRT = [M]PARAM3
Gosub GRISE_PAR
End

Subprog C_CODTRT(VALEUR)
Variable Char VALEUR
Local Integer OK , OKTRT
VALEUR = toupper(VALEUR)
Call EXISTE_ADX("","",VALEUR,OKTRT) From ORDSYS
If !OKTRT
 If !GIMPORT
  OK = 2 : Call AVERTIR(mess(90,123,1),OK) From GESECRAN : # Traitement inexistant
  If OK<>2 : mkstat = 2 : End : Endif
 Endif
Endif
End

Subprog D_SPETRT(VALEUR)
Variable Char VALEUR
If [M]CODTRT<>"" & len([M]CODTRT)<=10 & GADONIX<>2
 Case [M]TYP
  When 3 : # Gtraite
   If [M]CODTRT<>"" : VALEUR = "XY"+[M]CODTRT : Endif
  When 4 : # Gsaisie
   If left$([M]CODTRT,3)="SUB"
    VALEUR = "SPE"+right$([M]CODTRT,4)
   Elsif [M]PARAM2<>""
    Call NOMSPEWIN([M]PARAM2,VALEUR) From MSKDIV
   Endif
 Endcase
Endif
End

Subprog C_SPETRT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR=[M]CODTRT
 GMESSAGE = mess(13,123,1) : # Traitement incorrect
 mkstat = 1 : End
Endif
End

Subprog AS_INSTRU(VALEUR)
Variable Char    VALEUR()
If [M]TYP<>len(mess(0,81,1)) & [M]TYP<>8 : mkstat = 1 : End : Endif
End

Subprog C_PARAM2(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]TYP=4 : # Saisie de fenêtre
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Endif
If VALEUR<>""
 VALEUR = toupper(VALEUR)
 Call CONTROLE("AWI","",VALEUR,"",mkstat) From CONTOBJ
Endif
End

Subprog C_PARAM3(VALEUR)
Variable Integer VALEUR()
Local Integer TPACT , TPTRT
TPACT = [M]TYP
TPTRT = VALEUR
Gosub GRISE_PAR
End

Subprog C_PARAM4(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 VALEUR = toupper(VALEUR)
 Call CONTROLE("AWI","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : End : Endif
Endif
End

$GRISE_PAR
If TPACT=8 or TPACT=len(mess(0,81,1))
 Actzo [ACT1]CODTRT, SUBPRG , INSTRU , SPETRT , AMSFLG
 [M:ACT1]PARAM1 = ""
 [M:ACT1]PARAM2 = ""
 [M:ACT1]PARAM3 = 1
 [M:ACT1]PARAM4 = ""
 [M:ACT1]PARAM5 = ""
 [M:ACT1]ABTFLG = 1
 [M:ACT2]PARAM6 = 0
 Grizo [ACT1]PARAM1, PARAM2, PARAM3, PARAM4, PARAM5, ABTFLG , NOWEB
 Grizo [ACT2]PARAM6
Else
 Local Integer NBP
 [M:ACT1]SUBPRG = ""
 [M:ACT1]INSTRU = ""
 [M:ACT1]AMSFLG = 1
 Grizo [ACT1]SUBPRG , INSTRU , AMSFLG
 Case TPACT
  When 1 : # Objet
   Actzo [ACT2]PARAM6
   [M:ACT1]SPETRT = ""
   [M:ACT1]CODTRT = ""
   [M:ACT1]PARAM1 = ""
   [M:ACT1]PARAM2 = ""
   [M:ACT1]PARAM3 = 1
   [M:ACT1]PARAM4 = ""
   [M:ACT1]PARAM5 = ""
   [M:ACT1]ABTFLG = 1
   Grizo [ACT1]CODTRT , PARAM1, PARAM2 , PARAM3, PARAM4, PARAM5, SPETRT, ABTFLG , NOWEB
  When 2 : # Consultation
   Actzo [ACT1]PARAM1 : Actzo [ACT2]PARAM6
   [M:ACT1]SPETRT = ""
   [M:ACT1]CODTRT = ""
   [M:ACT1]PARAM2 = ""
   [M:ACT1]PARAM3 = 1
   [M:ACT1]PARAM4 = ""
   [M:ACT1]PARAM5 = ""
   [M:ACT1]ABTFLG = 1
   Grizo [ACT1]CODTRT, PARAM2, PARAM3, PARAM4, PARAM5, SPETRT, ABTFLG , NOWEB
  When 3 : # Traitement GTRAITE
   Actzo [ACT1]CODTRT, PARAM2, PARAM3, SPETRT, ABTFLG , NOWEB
   Actzo [ACT2]PARAM6
   [M:ACT1]PARAM1 = ""
   Grizo [ACT1]PARAM1
   If TPTRT>=5
    Actzo [ACT1]PARAM5
    [M:ACT1]PARAM4 = ""
    Grizo [ACT1]PARAM4
   Elsif TPTRT>=3
    Actzo [ACT1]PARAM4
    [M:ACT1]PARAM5 = ""
    Grizo [ACT1]PARAM5
   Else
    [M:ACT1]PARAM4 = ""
    [M:ACT1]PARAM5 = ""
    Grizo [ACT1]PARAM4, PARAM5
   Endif
  When 4 : # Fenêtre GSAISIE
   Actzo [ACT1]CODTRT, PARAM2, SPETRT
   Actzo [ACT2]PARAM6
   [M:ACT1]PARAM1 = ""
   [M:ACT1]PARAM3 = 1
   [M:ACT1]PARAM4 = ""
   [M:ACT1]PARAM5 = ""
   [M:ACT1]ABTFLG = 1
   Grizo [ACT1]PARAM1, PARAM3, PARAM4, PARAM5, ABTFLG , NOWEB
  When 5 : # Sélection liste
   Actzo [ACT1]CODTRT, PARAM5, SPETRT
   [M:ACT1]PARAM1 = ""
   [M:ACT1]PARAM2 = ""
   [M:ACT1]PARAM3 = 1
   [M:ACT1]PARAM4 = ""
   [M:ACT1]ABTFLG = 1
   Grizo [ACT1]PARAM1, PARAM2, PARAM3, PARAM4, ABTFLG , NOWEB
   Actzo [ACT2]PARAM6
  When 6 : # Sélection table
   Actzo [ACT1]CODTRT, PARAM5, SPETRT
   [M:ACT1]PARAM1 = ""
   [M:ACT1]PARAM2 = ""
   [M:ACT1]PARAM3 = 1
   [M:ACT1]PARAM4 = ""
   [M:ACT1]ABTFLG = 1
   Actzo [ACT2]PARAM6
   Grizo [ACT1]PARAM1, PARAM2, PARAM3, PARAM4, ABTFLG , NOWEB
  When 7 : # Affichage
   Actzo [ACT1]CODTRT, PARAM5, SPETRT
   [M:ACT1]PARAM1 = ""
   [M:ACT1]PARAM2 = ""
   [M:ACT1]PARAM3 = 1
   [M:ACT1]PARAM4 = ""
   [M:ACT1]ABTFLG = 1
   [M:ACT2]PARAM6 = 0
   Grizo [ACT2]PARAM6
   Grizo [ACT1]PARAM1, PARAM2, PARAM3, PARAM4, ABTFLG , NOWEB
  When Default
 Endcase
Endif
Return

Subprog C_ACTSUI(VALEUR)
Variable Char     VALEUR
If VALEUR=[M]ACTION : mkstat = 2 : Endif
End

Subprog C_NOWEB(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & [M]ABTFLG<>2
 # Cette action ne peut pas être lancée en batch
 Call ERREUR(mess(266,139,1)) From GESECRAN
 mkstat = 1 : End
Endif
End

Subprog AM_TEXTE(VALEUR)
Variable Clbfile VALEUR
Local Integer OK
Call MODIF_DOC("ACT",[M]ACTION,OK) From SUBADO
If !OK : VALEUR = [M]TEXTE : Affzo TEXTE : Endif
End

##########################################################################
# Etiquettes du masque ACT2
##########################################################################

Subprog C_CODPAR(VALEUR)
Variable Char    VALEUR()
Local Integer OK , NOL
NOL = nolign
Call UNICITE(VALEUR,[M]CODPAR) From OBJDIV
If !mkstat & [M]TYP<>8
 Read [AAR]CODPAR=VALEUR
 If [F:AAR]TYPPAR>=6
  OK = 1
  If NOL=1 & [M]TYPACT<>2
   OK = 0
  Elsif NOL>1
   OK = 0
  Endif
  If !OK
   # Pour ce type d'action, ce paramètre ne peut être utilisé que sur la zone courante
   Call ERREUR(VALEUR-":"-mess(214,139,1)) From GESECRAN
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog AV_TYPPAR(VALEUR)
Variable Integer VALEUR()
If [M]CODPAR(nolign-1)<>""
 Call LECTURE("AAR",[M]CODPAR(nolign-1),"") From CONTOBJ
 VALEUR = [F:AAR]TYPPAR
Endif
End

Subprog AS_ADRVAL(VALEUR)
Variable Integer  VALEUR
GMENLOC(3) = 1
End

