#<AdxTL>@(#)12.0.0.0 $Revision$
####################################################################################################################
# dans le cas d une migration 130-V6  le passage peut se faire en 2 etapes
# 130 - V5
# V5  - V6
# dans ce cas la validation des fenêtres et écrans du contrôle qualité du stomaj14 peut etre désactivée
# pour se faire il faut mettre en commentaire les lignes suivantes :   (vers les lignes  243 ..)

#---- Génération des fiches qualité ------#
#NUMPROC += 1
#Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Generate QLYCRD windows") From DOSSUB
#Call STKGENCRD
#If GOK<>1 : Onerrgo : End : Endif
####################################################################################################################


Local File STOJOU  [STJ]
Local File XTJ     [XTJ]

Local Char    CLE1(GLONFCY), CLE3(GLONITM)
Local Date    CLE4
Local Integer CLE2, CLE5, CLE6
Local Integer STOP,NB,NBC,LREW
Local Char    CRITERE(250)

Local Integer WNUM
WNUM = 0

Call OUVRE_TRACE("--- STOJOU ---") From LECFIC

Raz STOP, NBC
$LOOP
Raz NB
If STOP = 1
  STOP = 2
  CRITERE = "STOFCY=CLE1 & UPDCOD=CLE2 & ITMREF=CLE3 & IPTDAT=CLE4 & MVTSEQ=CLE5 & MVTIND>CLE6"
Elsif STOP = 2
  STOP = 3
  CRITERE = "STOFCY=CLE1 & UPDCOD=CLE2 & ITMREF=CLE3 & IPTDAT=CLE4 & MVTSEQ>CLE5"
Elsif STOP = 3
  STOP = 4
  CRITERE = "STOFCY=CLE1 & UPDCOD=CLE2 & ITMREF=CLE3 & IPTDAT<CLE4"     # attention sens clé (-) !?
Elsif STOP = 4
  STOP = 5
  CRITERE = "STOFCY=CLE1 & UPDCOD=CLE2 & ITMREF>CLE3"
Elsif STOP = 5
  STOP = 6
  CRITERE = "STOFCY=CLE1 & UPDCOD>CLE2"
Elsif STOP = 6
  STOP = 0
  CRITERE = "STOFCY>CLE1"
Else
  CRITERE = "1=1"
Endif

Trbegin [STJ]

#--- Pour test ---#
[L]WNUM += 1
[F:XTJ]NUM    = [L]WNUM
[F:XTJ]STOFCY = CLE1
[F:XTJ]UPDCOD = CLE2
[F:XTJ]ITMREF = CLE3
[F:XTJ]IPTDAT = CLE4
[F:XTJ]MVTSEQ = CLE5
[F:XTJ]MVTIND = CLE6
[F:XTJ]STOP   = [L]STOP
[F:XTJ]CREDAT = date$
[F:XTJ]CRETIM = mid$(time$,1,2)+mid$(time$,4,2)
Write [XTJ]
#-----------------#

For [STJ]STJ0 Where evalue(CRITERE)
    Raz LREW
    If [F:STJ]ACTQTY>1
       LREW=1
    Endif
    If LREW
       NB+=1
       If NB>GMAXUPDTRS
          CLE1 = [F:STJ]STOFCY
          CLE2 = [F:STJ]UPDCOD
          CLE3 = [F:STJ]ITMREF
          CLE4 = [F:STJ]IPTDAT
          CLE5 = [F:STJ]MVTSEQ
          CLE6 = [F:STJ]MVTIND
          STOP=1
          Break
       Endif
    Endif
Next
Commit
NBC+=1
Call ECR_TIME("STOP="+num$(STOP)-"Commit no"-num$(NBC)-"STJ0 ="-CLE1-num$(CLE2)-CLE3-format$('D:DDMMYYYY',CLE4)-num$(CLE5)-num$(CLE6)) From DOSSUB
If STOP
    Goto LOOP
Endif

Call ECR_TIME("--- End STOJOU ---") From DOSSUB

Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End


#################################################################################
# Ce traitement n'est pas à jour (migration 130-140)                            # 
#################################################################################
# Avant mise à jour                 ASTOMAJ14                                   #
# ----------------------------------------------------------------------------- #
#   - STKCVEMP  : Conversion tables TABLOCTYP et STOLOC                         #
#   - STKCVSTO  : Conversion table  STOCK                                       #
#       Initialisation des champs : SERNUM - RCPDAT - LOCCAT - LOCTYP           #
#                                   QTYSTUACT - PCUORI - QTYPCUORI - QTYSTUORI  #
#       Agrégation des lignes de stock                                          #
#       Eclatement des lignes de stock ayant des n° de série                    #
#   - STKCVSTE  :  Conversion table STOPAR                                      #
#       Initialisation des champs SHTCAT                                        #
#       Réordonnancement des champs SHTPAR                                      #
#                                                                               #
#   - STKCVSTP  :  Met CREDAT dans CSTDAT                                       #
#   - STKCVITV  :  Recalcul cumuls mouvements articles                          #
#   - STKCVITH  :  Modif champs pour clé principale                             #
#   - STKCVSTJ  :  calcul quantité active des mouvements en attente             #
#   - STKCVCRD  : Conversion table QLYCRD (Fiches Contrôles qualité)            #
#   - STKCVQLY  : Conversion table STOQUAL (Contrôles qualité)                  #
#                                                                               #
#  STKBENCHTRS  : Mise à jour  table  BENCHTRS pour zones stock 140             #
# ----------------------------------------------------------------------------- #
# Après mise à jour                 STOMAJ14                                    #
# ----------------------------------------------------------------------------- #
#   - STKGENCRD : Génération des écrans et fenêtre des fiches qualité           #
#                                                                               #
#   - STKCVQLA : Duplique les réponses aux fiches qualité                       #
#                autant de fois qu'il y a de lignes dans le contrôle qualité    #
#################################################################################
Subprog ASTOMAJ14
Local Integer NUMPROC
Raz NUMPROC

Onerrgo TRT_ERR
#---- MAJ des tables TABLOCTYP & STOLOC ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Update TABLOCTYP & STOLOC") From DOSSUB
Call STKCVEMP([F:ADS]DOSSIER,"",1)
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table STOCK ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Update STOCK") From DOSSUB
Call STKCVSTO([F:ADS]DOSSIER,"",1)
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table STOALL ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Update STOALL") From DOSSUB
Call STKCVALL([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table STOCOST ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Update STOCOST") From DOSSUB
Call STKCVSTP([F:ADS]DOSSIER,"",1)
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table STOPAR ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Update STOPAR") From DOSSUB
Call STKCVSTE([F:ADS]DOSSIER,"",1)
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table ITMMVT ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Update ITMMVT") From DOSSUB
Call STKCVITV
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table ITMMVTHIS ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Update ITMMVTHIS") From DOSSUB
Call STKCVITH
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table STOJOU ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Update STOJOU") From DOSSUB
Call STKCVSTJ
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table QLYCRD ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Update QLYCRD") From DOSSUB
Call STKCVCRD
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table STOQLYD ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Fill STOQLYH/D") From DOSSUB
Call STKCVQLY
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table CUNLISDET ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Update CUNLISDET") From DOSSUB
Call STKCVCUD([F:ADS]DOSSIER,"",1)
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table STOJOU ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Delete empty inventory session ") From DOSSUB
Call STKCVCUD1([F:ADS]DOSSIER,"",1)
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table STOJOU ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Update CUNSESSION & CUNLISTE") From DOSSUB
Call STKCVCUNCUL([F:ADS]DOSSIER,"",1)
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table BENCHTRS ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Work benches Transactions Process "+num$(NUMPROC)+": Update BENCHTRS") From DOSSUB
Call STKBENCHTRS
If GOK<>1 : Onerrgo : End : Endif

#---- MAJ de la table PARMRP ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 MRP setup Process "+num$(NUMPROC)+": Update PARMRP") From DOSSUB
Call STKPARMRP
If GOK<>1 : Onerrgo : End : Endif
Onerrgo

End

############################################################
Subprog STOMAJ14
Local Integer NUMPROC
Raz NUMPROC

Onerrgo TRT_ERR

#---- Génération des fiches qualité ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Generate QLYCRD windows") From DOSSUB
Call STKGENCRD
If GOK<>1 : Onerrgo : End : Endif

#---- Duplique les réponses aux fiches qualité -----#

NUMPROC += 1
Call ECR_TIME("DOSMAJ14 Stocks Transactions Process "+num$(NUMPROC)+": Update QLYCRDASW") From DOSSUB
Call STKCVQLA
If GOK<>1 : Onerrgo : End : Endif

Onerrgo

End

############################################################
# STKCVEMP  : Conversion tables TABLOCTYP et STOLOC 
# LDOS   = Dossier
# LFCY   = Site ou rien si tous sites
# LPAR   = paramètre 0 = Première fois
#                    1 = On refait le traitement
############################################################ 
Subprog STKCVEMP(LDOS,LFCY,LPAR)
Value Char    LDOS
Value Char    LFCY
Value Integer LPAR
#
Local File =LDOS+".ITMMASTER" [ITM]
Local File =LDOS+".TABLOCTYP" [TLO]
Local File =LDOS+".STOCK"     [STO]
Local File =LDOS+".STOLOC"    [STC]
Local File =LDOS+".STOLOCAFF" [STF]
#
If LFCY = ""
  Filter [TLO]
Else 
  Filter [TLO] Where STOFCY = LFCY
Endif
For [TLO]
  If [F:TLO]MONITMFLG = 0 | LPAR = 1
    Trbegin [TLO]
    GOK = 1
    #Readlock [TLO]Curr    # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #Case fstat
    #  When 1 :
    #    GOK = -1
    #  When 0 
        Gosub MAJ_TLO
        Case fstat
          When 0 :
            Gosub MAJ_LOC
          When Default :
            GOK = 0
            Call FSTA("TLO") From GLOCK
        Endcase
    #  When Default :
    #    GOK = 0
    #    Call FSTA("TLO") From GLOCK
    #Endcase
    Case GOK
      When 1 :
        Rewrite [TLO]
        Commit
        #Call ECR_TRACE([F:TLO]LOCTYP-[F:TLO]TYPDES-"Ok",0) From GESECRAN
      When -1 :
        Rollback
        Call ECR_TRACE(mess(20,100,1)-[F:TLO]LOCTYP-[F:TLO]TYPDES,1) From GESECRAN
      When Default :
        Rollback
        Call ECR_TRACE(mess(12,100,1)-[F:TLO]LOCTYP-[F:TLO]TYPDES,1) From GESECRAN
    Endcase
  Endif
Next
#
Close Local File [TLO]
Close Local File [STC]
#
End
############################################################
$MAJ_TLO
Case [F:TLO]SRGTYP
  When 1 :
    [F:TLO]LOCCAT    = 1
    [F:TLO]MONITMFLG = 1
    [F:TLO]DEDFLG    = 2
    [F:TLO]REAFLG    = 1
    [F:TLO]FILMGTFLG = 1
  When 2 :
    [F:TLO]LOCCAT    = 1
    [F:TLO]MONITMFLG = 1
    [F:TLO]DEDFLG    = 2
    [F:TLO]REAFLG    = 1
    [F:TLO]FILMGTFLG = 1
  When 3 :
    [F:TLO]LOCCAT    = 1
    [F:TLO]MONITMFLG = 2
    [F:TLO]DEDFLG    = 1
    [F:TLO]REAFLG    = 1
    If [F:TLO]PCUNBR > 0 
      [F:TLO]FILMGTFLG = 2
    Else
      [F:TLO]FILMGTFLG = 1
    Endif 
  When 4 :
    [F:TLO]LOCCAT    = 1
    [F:TLO]MONITMFLG = 1
    [F:TLO]DEDFLG    = 1
    [F:TLO]REAFLG    = 1
    If [F:TLO]PCUNBR > 0 
      [F:TLO]FILMGTFLG = 2
    Else
      [F:TLO]FILMGTFLG = 1
    Endif 
  When 5 :
    [F:TLO]LOCCAT    = 1
    [F:TLO]MONITMFLG = 1
    [F:TLO]DEDFLG    = 1
    [F:TLO]REAFLG    = 1
    [F:TLO]FILMGTFLG = 1
  When 6 :
    [F:TLO]LOCCAT    = 3
    [F:TLO]MONITMFLG = 1
    [F:TLO]DEDFLG    = 1
    [F:TLO]REAFLG    = 1
    [F:TLO]FILMGTFLG = 1
  When 7 :
    [F:TLO]LOCCAT    = 4
    [F:TLO]MONITMFLG = 1
    [F:TLO]DEDFLG    = 1
    [F:TLO]REAFLG    = 1
    [F:TLO]FILMGTFLG = 1
Endcase
# Mise en forme champ statuts autorisés
[F:TLO]AUZSST = ""
If [F:TLO]AAAFLG = 2
  [F:TLO]AUZSST += "A*,"
Endif
If [F:TLO]QQQFLG = 2
  [F:TLO]AUZSST += "Q*,"
Endif
If [F:TLO]RRRFLG = 2
  [F:TLO]AUZSST += "R*,"
Endif
If [F:TLO]AUZSST <> ""
  [F:TLO]AUZSST = left$([F:TLO]AUZSST,len([F:TLO]AUZSST)-1) 
Endif
Return
############################################################
# Mise à jour table STOLOC à partir de TABLOCTYP
$MAJ_LOC
Local Char    WPCU
Local Decimal WCOE
Local Decimal WQTYPCU
Local Char    WLOC    : Raz WLOC
Local Integer WCPT

$FORSTC
Filter [STC] Where STOFCY = [F:TLO]STOFCY
&                & LOCTYP = [F:TLO]LOCTYP
&                & LOC    > WLOC
&            Order By Key STC3
For [STC]
  WLOC = [F:STC]LOC
  #Readlock [STC]Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
  #Case fstat
  #  When 1 :
  #    GOK = -1
  #    Break
  #  When 0 :
      [F:STC]MAXAUZWEI = [F:TLO]MAXAUZWEI
      [F:STC]WID       = [F:TLO]WID
      [F:STC]HEI       = [F:TLO]HEI
      [F:STC]DTH       = [F:TLO]DTH
      [F:STC]LOCCAT    = [F:TLO]LOCCAT 
      [F:STC]MONITMFLG = [F:TLO]MONITMFLG
      [F:STC]DEDFLG    = [F:TLO]DEDFLG
      [F:STC]REAFLG    = [F:TLO]REAFLG
      [F:STC]FILMGTFLG = [F:TLO]FILMGTFLG
      [F:STC]AUZSST    = [F:TLO]AUZSST
      [F:STC]CUNLOKFLG = 1
      [F:STC]OCPCOD    = 1
      Raz [F:STC]QTYPCU,[F:STC]PCU,[F:STC]PCUSTUCOE
      Filter [STO] Where STOFCY    = [F:STC]STOFCY
&                      & LOC       = [F:STC]LOC
      #------- L'emplacement est-il occupé ------#
      Look [STO]STO4 First
      If !fstat
        #--- Si l'emplacement n'est pas géré en remplissage ou qu'il n'a pas de quantité maxi ----#
        If !([F:STC]FILMGTFLG=2 & [F:TLO]PCUNBR>0)
          [F:STC]OCPCOD = 2
          #Call ECR_TRACE([F:STC]STOFCY+" - "+[F:STC]LOC-"-->"-mess([F:STC]OCPCOD,757,1),0) From GESECRAN
        Else 
          #------- L'emplacement est occupé ------#
          Read [STO] Curr
          #For [STO] Hint Key STO4
          #  Break
          #Next
          #------ Est-ce que l'unité est permise dans l'emplacement ----#
          If find([F:STO]PCU,[F:TLO]PCU)
            Columns [STO] (PCU,PCUSTUCOE)
            For [STO] Hint Key STO4
              WPCU=[F:STO]PCU
              WCOE=[F:STO]PCUSTUCOE
              Break
            Next
            Columns [STO]
            [F:STC]OCPCOD = 2
            Filter [STO]
            Filter [STO] Where STOFCY    = [F:STC]STOFCY
&                            & LOC       = [F:STC]LOC   
&                            & (PCU<>WPCU | PCUSTUCOE<>WCOE)
            #----- S'il y a des UC ou des coef différents => plein -----#
            Look [STO]STO4 First
            If !fstat
              [F:STC]OCPCOD=3
              Call ECR_TRACE([F:STC]STOFCY-"-"-[F:STC]LOC-"-->"-mess([F:STC]OCPCOD,757,0)-":"-mess(848,196,1),1)
&                  From GESECRAN
            Else
              Filter [STO]
              Filter [STO] Where STOFCY    = [F:STC]STOFCY &
&                                LOC       = [F:STC]LOC
&                                Order By Key STO4
              Raz WQTYPCU
              Columns [STO] (QTYPCU)
              For [STO]
                WQTYPCU += [F:STO]QTYPCU
              Next
              Columns [STO]
              [F:STC]QTYPCU    = WQTYPCU
              [F:STC]PCU       = WPCU
              [F:STC]PCUSTUCOE = WCOE
              #---- Si qté maxi atteinte -----#
              If WQTYPCU>=[F:TLO]MAXQTYPCU(find(WPCU,[F:TLO]PCU)-1)
                [F:STC]OCPCOD = 3
                #Call ECR_TRACE([F:STC]STOFCY-"-"-[F:STC]LOC-num$(WQTYPCU)+">="+num$([F:TLO]MAXQTYPCU(find(WPCU,[F:TLO]PCU)
#&                              -1))-"-->"-mess([F:STC]OCPCOD,757,1),0) From GESECRAN
              Else
                #Call ECR_TRACE([F:STC]STOFCY-"-"-[F:STC]LOC-"-->"-mess([F:STC]OCPCOD,757,1)-"("+num$(WQTYPCU)-WPCU+")",0)
#&                    From GESECRAN
              Endif
            Endif
          #----- L'unité n'est pas autorisée sur l'emplacement => plein -------#
          Else
            [F:STC]OCPCOD = 3
            Call ECR_TRACE([F:STC]STOFCY-"-"-[F:STC]LOC-"-->"-mess([F:STC]OCPCOD,757,1)-":"-[F:STO]PCU-mess(847,196,1),0)
&                From GESECRAN
          Endif
        Endif
      Else
        #Call ECR_TRACE([F:STC]STOFCY-"-"-[F:STC]LOC-"-->"-mess([F:STC]OCPCOD,757,1),0) From GESECRAN
      Endif
      Filter [STO]
      Rewrite [STC]
      If fstat
        GOK = 0
        Call FSTA("STC") From GLOCK
        Break
      Endif  
      If [F:STC]DEDFLG = 2 & [F:STC]LOCITMREF <> ""
        Gosub MAJ_AFF
        If GOK <> 1
          Break
        Endif
      Endif
      Case [F:STC]OCPCOD
        When 1: [F:TLO]FRGLOC += 1
        When 2: [F:TLO]OCPLOC += 1
                [F:TLO]PERLOA = ([F:TLO]OCPLOC+[F:TLO]FULLOC)/([F:TLO]FRGLOC+[F:TLO]OCPLOC+[F:TLO]FULLOC)
        When 3: [F:TLO]FULLOC += 1
                [F:TLO]PERLOA = ([F:TLO]OCPLOC+[F:TLO]FULLOC)/([F:TLO]FRGLOC+[F:TLO]OCPLOC+[F:TLO]FULLOC)
      Endcase
      [F:TLO]LOKLOC += ([F:STC]LOKSTA=2)
      WCPT += 1
      If WCPT>GMAXUPDTRS
        Break
      Endif
  #  When Default :
  #    GOK = 0 
  #    Call FSTA("STC") From GLOCK
  #    Break
  #Endcase
Next
If WCPT>GMAXUPDTRS
  Raz WCPT
  Commit
  Trbegin [STC]
  Goto $FORSTC
Endif
Filter [STC]

Return

############################################################
# Mise à jour table STOLOCAFF à partir de stoloc
$MAJ_AFF
Read [ITM]ITM0=[F:STC]LOCITMREF
If fstat = 0
  Raz [F:STF]
  [F:STF]STOFCY = [F:STC]STOFCY
  [F:STF]LOC    = [F:STC]LOC
  [F:STF]ITMREF = [F:ITM]ITMREF
  [F:STF]REOTSD = 0
  [F:STF]MAXSTO = 0
  [F:STF]EXPNUM = [C]EXPORT
  [F:STF]CREUSR = GUSER
  [F:STF]CREDAT = date$
  Write [STF]
  Case fstat
    When 0 :
    When 3 :
    When Default :
      GOK = 0 
      Call FSTA("STC") From GLOCK
  Endcase
Endif
Return

#########################################################################
#    STKCVSTO  : Conversion table  STOCK
#       Initialisation des champs : SERNUM - RCPDAT - LOCCAT - LOCTYP 
#                                   QTYSTUACT - PCUORI - QTYPCUORI - QTYSTUORI
#       Eclatement des lignes de stock ayant des n° de série         
#       Les lignes de stock nulles sont supprimées sauf si elles sont
#       liées à des n° de série (existant ou non)
#             => modification de la table STOALL
#             => modif des controles qualité ?
#
#       Agrégation des lignes de stock
#             => modification de la table STOALL
#             => reprise des controles qualité
#
#########################################################################
# Paramètres E : LDOS   = Dossier
#                LFCY   = Site ou rien si tous sites
#                LPAR   = paramètre 0 = Première fois
#                                   1 = On refait le traitement
#########################################################################
Subprog STKCVSTO(LDOS,LFCY,LPAR)
Value Char    LDOS
Value Char    LFCY
Value Integer LPAR
#
Local File =LDOS+".FACILITY"  [FCY]
Local File =LDOS+".ITMMASTER" [ITM]
Local File =LDOS+".TABLOCTYP" [TLO]
Local File =LDOS+".STOCK"     [STO]    # Pour l'écriture
Local File =LDOS+".STOCK"     [STO1]   # Pour la lecture
Local File =LDOS+".STOCK"     [STO2]   # Pour la vérification
Local File =LDOS+".STOLOC"    [STC]
Local File =LDOS+".STOLOT"    [STL]
Local File =LDOS+".STOSER"    [STS]
Local File =LDOS+".STOALL"    [STA]
Local File =LDOS+".STOALL"    [STA1]
Local File =LDOS+".AVALNUM"   [AVN]
Local File =LDOS+".ACODNUM"   [ANM]
#
Local Integer LRET
Local Char    LCSTOCOU(11)
Local Decimal LSTOCOU1    #Mémorise le 1er STOCOU créé : Cela permet de ne pas faire la 2ème passe à partir de ce n°
Local Integer LCPT
Local Integer LMAX          : LMAX = GMAXUPDTRS 
Local Integer LTRBEGIN
Local Integer I
Local Decimal NBR, NBSTO : # NBSTO=nbrecord([STO])
Local Decimal LPOT
Local Char    LBADITM(GLONITM)

Trbegin [STO]

GOK=1
Raz LCPT
#------- Eclatement des lignes de stock avec n° de série ------------#
Call ECR_TRACE(mess(41,184,1),0) From GESECRAN #"Articles gérés en n° de série"
Raz NBR
#NBR = nbrecord([STS])
#Raz NBR
LPOT = 1
#Filter [STS] Where ISSDAT=[0/0/0]
For [STS]
    If [F:STS]ISSDAT<>[0/0/0]
        Goto $STS_NEXT
    Endif
    If [F:STS]ITMREF<>LBADITM & [F:ITM]ITMREF <> [F:STS]ITMREF
        Read [ITM]ITM0=[F:STS]ITMREF
    Endif
    NBR+=1
#    Call AFF_BOITE([F:STS]SERNUM,NBR,I) From GESECRAN
    If [F:ITM]ITMREF=[F:STS]ITMREF & [F:STS]STOCOU>0
        #Readlock [STO1]STO0=[F:STS]STOFCY;[F:STS]STOCOU  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
        Read [STO1]STO0=[F:STS]STOFCY;[F:STS]STOCOU  # FGR 12/03/2010 : X3SUIVI63191
        If fstat>1    # Au cas où le site ne serait pas renseigné dans STS
            Read [F:STO1]STO0 = [F:STS]STOFCY;[F:STS]STOCOU
        Endif
        Case fstat
            When 0:    # La ligne de stock existe => l'éclater si besoin
                If [F:STO1]QTYSTU>=1
                    [F:STO] = [F:STO1]
                    #Readlock [STO]STO0 =  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
                    Read [STO]STO0 =  # FGR 12/03/2010 : X3SUIVI63191
                    If [F:STO]QTYSTU>1
                        [F:STO]QTYPCU -= 1
                        [F:STO]QTYSTU -= 1
                        Gosub MAJQTYSTO
                        If [F:STO]LOCCAT=0
                            Gosub MAJLOCSTO
                        Endif
                        Rewrite [STO]
                        #---
                        $NEW_NUMSTO
                        Call NUMERO("STO",[F:STO1]STOFCY,date$,"",LCSTOCOU,LRET) From SUBANM
                        If LRET
                            GOK=0
                            Break
                        Endif
                        # Vérification que ce chrono stock n'existe pas déjà 
                        Look [STO2]STO0=[F:STO1]STOFCY;val(LCSTOCOU)
                        If !fstat Goto NEW_NUMSTO Endif
                        #--- 
                        If LSTOCOU1=0
                            LSTOCOU1 = val(LCSTOCOU)
                        Endif
                        [F:STO]STOCOU = val(LCSTOCOU)
                        [F:STO]SERNUM = [F:STS]SERNUM
                        [F:STO]RCPDAT = [F:STS]RCPDAT
                        [F:STO]QTYPCU = 1
                        [F:STO]QTYSTU = 1
                        Gosub MAJQTYSTO
                        Write [STO]
                        If !fstat
                            #------------- Mise à jour des allocations -----------#
                            #Readlock [STA]STA0(3)=[F:STS]STOFCY;[F:STS]ITMREF;[F:STO1]STOCOU  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
                            Read [STA]STA0(3)=[F:STS]STOFCY;[F:STS]ITMREF;[F:STO1]STOCOU  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
                            [G:STA]currlen=0
                            # Allocation trouvée, le n° série en cours est à allouer
                            If !fstat
                                Filter [STA1] Where STOFCY=[F:STS]STOFCY & ITMREF=[F:STS]ITMREF & STOCOU=[F:STO]STOCOU
&                                             Order By Key STA0
                                Read [STA1] First
                                #Read [STA1]STA0(3)=[F:STS]STOFCY;[F:STS]ITMREF;[F:STO]STOCOU
                                [G:STA]currlen=0
                                [F:STA1] = [F:STA]
                                [F:STA1]STOCOU = [F:STO]STOCOU
                                [F:STA1]QTYSTU = 1
                                [F:STA1]QTYSTUACT = 1
                                If fstat = 0  [F:STA1]SEQ =[F:STA1]SEQ-1
                                Else          [F:STA1]SEQ = 99999999
                                Endif                 
                                Write [STA1]
                                If !fstat
                                    If [F:STA]QTYSTU>1
                                        [F:STA]QTYSTU-=1
                                        Rewrite [F:STA]
                                        If fstat
                                            Call ECR_TRACE(mess(13,100,1)-"[STA]"-[F:STA]STOFCY-[F:STA]ITMREF-num$([F:STA]STOCOU)-num$([F:STA]SEQ),1) From GESECRAN #"ERREUR d'ecriture"
                                        Endif
                                    Else
                                        Delete [STA] Curr
                                    Endif
                                Endif
                                Filter [STA1]
                            Endif
                            fstat = 0
                        Endif
                    Else
                        Gosub MAJQTYSTO
                        [F:STO]SERNUM = [F:STS]SERNUM
                        [F:STO]RCPDAT = [F:STS]RCPDAT
                        If [F:STO1]LOCCAT=0
                            Gosub MAJLOCSTO
                        Endif
                        Rewrite [STO]
                    Endif
                    If fstat
                        GOK = 0
                        Call ECR_TRACE(mess(13,100,1)-"[STO]"-[F:STO]STOFCY-num$([F:STO]STOCOU),1) From GESECRAN #"ERREUR d'ecriture"
                        Break
                    Else
                        #Readlock [STS]STS0 Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
                        Read [STS]STS0 Curr  # FGR 12/03/2010 : X3SUIVI63191
                        [F:STS]STOCOU = 0
                        Rewrite [STS]
                        LCPT += 1
                        If LCPT>=LMAX
                            Raz LCPT
                            Commit
                            Trbegin [STO]
                        Endif
                    Endif
                Else    # Qté <1
                    Call ECR_TRACE([F:STS]ITMREF-[F:STS]SERNUM-num$([F:STS]STOCOU)-":"-mess(135,190,1)-"[STO]",1) From GESECRAN #Stock nul
                Endif
            When 1:
                GOK = -1
                Break
            When Default:    # Ligne non trouvée : erreur dans trace
                If [F:ITM]SERMGTCOD=3
                    # On vérifie s'il y a une allocation
                    Filter [STA] Where VCRTYP=[F:STS]VCRTYP & VCRNUM=[F:STS]VCRNUM & VCRLIN=[F:STS]VCRLIN & STOCOU=[F:STS]STOCOU
                    Look [STA] First
                    Filter [STA]
                    If !fstat
                        Call ECR_TRACE("STOCK"-mess(12,100,1)-"SERNUM="+[F:STS]SERNUM-"STOCOU="+num$([F:STS]STOCOU),1) From GESECRAN #"ERREUR d'accès sur le fichier"
                    Endif
                Endif
        Endcase
    Elsif [F:ITM]ITMREF <> [F:STS]ITMREF
        If [F:STS]ITMREF<>LBADITM
            LBADITM = [F:STS]ITMREF
            Call ECR_TRACE(mess(134,100,1)-":"-[F:STS]ITMREF,1) From GESECRAN #"Code article inexistant"
        Endif
    Else    # STOCOU=0
        #Readlock [STO]STO5=[F:STS]ITMREF;[F:STS]SERNUM  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
        Read [STO]STO5=[F:STS]ITMREF;[F:STS]SERNUM  # FGR 12/03/2010 : X3SUIVI63191
        If fstat
            Call ECR_TRACE("STOCK"-"STOCOU="+num$([F:STS]STOCOU)-mess(12,100,1)-"ITMREF="+[F:STS]ITMREF-"SERNUM="+[F:STS]SERNUM,1) From GESECRAN #"ERREUR d'accès sur le fichier"
        Else
            Gosub MAJQTYSTO
            [F:STO]RCPDAT = [F:STS]RCPDAT
            Rewrite [STO]
        Endif
    Endif
    $STS_NEXT
Next
Filter [STO1]
Filter [STS]
Commit
#Call FERME_BOITE From GESECRAN


Trbegin [STO]

#------ Agrégation des lignes de stock -------------#
Call ECR_TRACE(mess(42,184,1),0) From GESECRAN #"Autres articles"
If GOK=1
    Raz NBR
    If LSTOCOU1>0
        Filter [STO1] Where STOCOU<LSTOCOU1
    Endif
    For [STO1] With Nohint
        NBR+=1
#        Call AFF_BOITE(num$([F:STO1]STOCOU),NBR,I) From GESECRAN
        #-------- Si la ligne possède un n° de série, elle a déjà été traitée --------#
        If [F:STO1]QTYSTU>0
            If [F:STO1]SERNUM=""
                LPOT = 1
                #----- Si l'article a un titre, il faut le récupérer pour le calcul de QTYSTUACT
                Read [ITM]ITM0=[F:STO1]ITMREF
                If fstat
                    Call ECR_TRACE([F:STO1]ITMREF-mess(134,100,1),1) From GESECRAN    # "Code article inexistant"
                Elsif [F:ITM]STOMGTCOD>2
                    Read [STL]STL0=[F:STO1]ITMREF;[F:STO1]LOT #;[F:STO1]SLO le /s-lot n'est pas encore dans la clé
                    If fstat
                        Call ECR_TRACE([F:STO1]ITMREF-[F:STO1]LOT-mess(123,199,1),1) From GESECRAN #"Lot inexistant pour l'article"
                    Else
                        LPOT=([F:ITM]LOTMGTCOD=3)*[F:STL]POT/100+([F:ITM]LOTMGTCOD=4)*[F:STL]ACT
                    Endif
                Endif
                # Positionnement sur une ligne de stock précédente identique
                Gosub CLE_STO
                If [F:STO]STOCOU>0
                    #Readlock [STO] Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
                    Read [STO] Curr  # FGR 12/03/2010 : X3SUIVI63191
                    [F:STO]QTYPCU    += [F:STO1]QTYPCU
                    [F:STO]QTYSTU    += [F:STO1]QTYSTU
                    Gosub MAJQTYSTO
                    Rewrite [STO]
                    For [STA] Where STOCOU=[F:STO1]STOCOU With Nohint 
                        LCPT += 1
                        Read [STA] =
                        [F:STA]STOCOU = [F:STO]STOCOU
                        Filter [STA1] Where STOFCY=[F:STA]STOFCY & ITMREF=[F:STA]ITMREF & STOCOU=[F:STA]STOCOU      
&                                     Order By Key STA0
                        Read [STA1] First
                        If fstat = 0  [F:STA]SEQ =[F:STA1]SEQ-1
                        Else          [F:STA]SEQ = 99999999
                        Endif                 
                        Filter [STA1]
                        [F:STA1] = [F:STA]
                        Write [STA1]
                        #Readlock [STA] Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
                        Read [STA] Curr  # FGR 12/03/2010 : X3SUIVI63191
                        Delete [STA] Curr
                    Next
                    Delete [STO1] Curr
                Else
                    [F:STO] = [F:STO1]
                    #Readlock [STO] =  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
                    Read [STO] =  # FGR 12/03/2010 : X3SUIVI63191
                    If [F:STO]QTYSTU>0
                        Gosub MAJLOCSTO
                        Gosub MAJQTYSTO
                        Rewrite [STO]
                    Else
                        Call ECR_TRACE("STOCOU="+num$([F:STO1]STOCOU)-":"-mess(32,196,1),0) From GESECRAN
                        Delete [STO] Curr
                    Endif
                Endif
                LCPT += 1
                If LCPT>=LMAX
                    Raz LCPT
                    Commit
                    Trbegin [STO]
                Endif
            Else
                Look [STS]STS0=[F:STO1]ITMREF;[STO1]SERNUM
                If fstat
                    Call ECR_TRACE([F:STO1]ITMREF-num$([F:STO1]SERNUM)-":"-mess(43,196,1),1) From GESECRAN    #"Numéro de série inexistant"
                Endif
            Endif
        Else
            Call ECR_TRACE("STOCOU="+num$([F:STO1]STOCOU)-":"-mess(135,190,1)-"=>"-mess(43,184,1),0) From GESECRAN    #"STOCK nul"
            Delete [STO1] Curr
        Endif
    Next
Endif
Filter [STO1]
#Call FERME_BOITE From GESECRAN
Case GOK
  When 1 :
    Commit
    #Call ECR_TRACE([F:FCY]FCY-[F:FCY]FCYNAM-"Ok",0) From GESECRAN
  When -1 :
    Rollback
    Call ECR_TRACE(mess(20,100,1)-"[STO]STOCOU="+num$([F:STS]STOCOU),1) From GESECRAN
  When Default :
    Rollback
    Call ECR_TRACE(mess(12,100,1)-[F:FCY]FCY-[F:FCY]FCYNAM,1) From GESECRAN
Endcase

End


###############################################################################
# MAJQTYSTO : Met à jour les zones quantités et le champ CUNLOKFLG
###############################################################################
$MAJQTYSTO
    [F:STO]PCUORI    = [F:STO]PCU
    [F:STO]QTYPCUORI = [F:STO]QTYPCU
    [F:STO]QTYSTUORI = [F:STO]QTYSTU
    [F:STO]QTYSTUACT = [F:STO]QTYSTU*LPOT
    [F:STO]CUMWIPQTY = 0
    [F:STO]CUMWIPQTA = 0
    [F:STO]CUMALLQTY = 0
    [F:STO]CUMALLQTA = 0
    [F:STO]CUNLOKFLG = 1
    If left$([F:STO]STA,1) = "A" &  [F:STO]QLYCTLDEM <> ""   # hcb 38149
       Raz [F:STO]QLYCTLDEM                                  # hcb 38149   
    Endif                                                    # hcb 38149
    If left$([F:STO]STA,1) = "R" &  [F:STO]QLYCTLDEM <> ""   # hcb 52634
       Raz [F:STO]QLYCTLDEM                                  # hcb 52634   
    Endif                                                    # hcb 52634

Return
###############################################################################
# MAJLOCSTO : Màj des nouveaux champs Qté (PCUORI, QTYPCUORI, QTYSTUORI)
#                                    Emplacement (
###############################################################################
$MAJLOCSTO
      Read [STC]STC0=[F:STO]STOFCY;[F:STO]LOC
      If fstat = 0
        [F:STO]LOCCAT = [F:STC]LOCCAT
        [F:STO]LOCTYP = [F:STC]LOCTYP
        If dim([F:STO]MONITMFLG) > 0
          [F:STO]MONITMFLG = [F:STC]MONITMFLG
        Endif
        If dim([F:STO]DEDFLG) > 0
          [F:STO]DEDFLG = [F:STC]DEDFLG
        Endif
        If dim([F:STO]REAFLG) > 0
          [F:STO]REAFLG = [F:STC]REAFLG
        Endif
        If dim([F:STO]FILMGTFLG) > 0
          [F:STO]FILMGTFLG = [F:STC]FILMGTFLG
        Endif
      Else
        [F:STO]LOCCAT = 1
        [F:STO]LOCTYP = ""
        If dim([F:STO]MONITMFLG) > 0
          [F:STO]MONITMFLG = 0
        Endif
        If dim([F:STO]DEDFLG) > 0
          [F:STO]DEDFLG = 0
        Endif
        If dim([F:STO]REAFLG) > 0
          [F:STO]REAFLG = 0
        Endif
        If dim([F:STO]FILMGTFLG) > 0
          [F:STO]FILMGTFLG = 0
        Endif
      Endif
Return


###############################################################################
# STKCVALL: Mise à jour des cumuls alloués dans STOCK à partir de STOALL
###############################################################################
# Paramètres E : LDOS   = Dossier
#                LFCY   = Site ou rien si tous sites
#                LPAR   = paramètre 0 = Première fois
#                                   1 = On refait le traitement
###############################################################################
Subprog STKCVALL(LDOS)
Value Char LDOS  # FGR 18/01/2010 : X3SUIVI60986

Local File =LDOS+".STOALL"    [STA]
Local File =LDOS+".STOCK"     [STO]
Local Integer LCPT
Local Integer LMAX          : LMAX = GMAXUPDTRS 

Local Char LFCY(GLONFCY) : Raz LFCY
Local Char LITM(GLONITM) : Raz LITM
Local Decimal LSTOCOU    : Raz LSTOCOU
Local Integer LSEQ       : Raz LSEQ
Local Char    CRITERE(240)
Local Char    CLE1, CLE2
Local Decimal CLE3
Local Integer CLE4, STOP

$BOUCLE_ALL
If STOP=1
   CRITERE = 'STOFCY="'+CLE1+'"&ITMREF="'+CLE2+'"&STOCOU='+num$(CLE3)+'&SEQ>'+num$(CLE4)
   STOP=2
Elsif STOP=2
   CRITERE = 'STOFCY="'+CLE1+'"&ITMREF="'+CLE2+'"&STOCOU>'+num$(CLE3)
   STOP=3
Elsif STOP=3
   CRITERE = 'STOFCY="'+CLE1+'"&ITMREF>"'+CLE2+'"'
   STOP=4
Elsif STOP=4
   CRITERE = 'STOFCY>"'+CLE1+'"'
   STOP=0
Else
   CRITERE = "1=1"
Endif

Raz LCPT
Trbegin [STO]
   For [STA] Where evalue(CRITERE)
      If [F:STA]STOCOU>0
         #Readlock [STO]STO0=[STA]STOFCY;[STA]STOCOU  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
         Read [STO]STO0=[STA]STOFCY;[STA]STOCOU  # FGR 12/03/2010 : X3SUIVI63191
         If !fstat
            If [F:STO]QTYSTU-[F:STO]CUMALLQTY>=[F:STA]QTYSTU
               [F:STO]CUMALLQTY += [F:STA]QTYSTU
               [F:STO]CUMALLQTA += [F:STA]QTYSTUACT
               Rewrite [STO]
               LCPT+=1
               If LCPT>LMAX
                  CLE1=[F:STA]STOFCY : CLE2=[F:STA]ITMREF : CLE3=[F:STA]STOCOU : CLE4=[F:STA]SEQ
                  STOP=1 : Break
               Endif
            Else
               # "Allocation impossible"
               # FGR 15/01/2010 : X3SUIVI60986
               #Call ECR_TRACE ([F:STA]STOFCY-[F:STA]ITMREF-num$([F:STA]STOCOU)-num$([F:STA]SEQ)-[F:STA]CREDAT-mess(103,197,1), 1) From GESECRAN
               Call ECR_TRACE ([F:STA]STOFCY-[F:STA]ITMREF-num$([F:STA]STOCOU)-num$([F:STA]SEQ)-num$([F:STA]CREDAT)-mess(103,197,1), 1) From GESECRAN
               Unlock [STO]
            Endif
         Else
            # "Allocation incorrecte"
            Call ECR_TRACE ([F:STA]STOFCY-[F:STA]ITMREF-num$([F:STA]STOCOU)-num$([F:STA]SEQ)-mess(39,184,1), 1) From GESECRAN
         Endif
      Endif
   Next
Commit
If STOP Goto BOUCLE_ALL Endif

End

###############################################################################
# Recherche toutes les lignes de stock respectant les caractéristiques stock
# en cours dans [F:STO1] et dont STOCOU est inférieur à celui de [F:STJ1]
$CLE_STO
Filter [STO] Where STOCOU   <[F:STO1]STOCOU
&                & ITMREF   =[F:STO1]ITMREF
&                & STOFCY   =[F:STO1]STOFCY
&                & LOT      =[F:STO1]LOT
&                & SLO      =[F:STO1]SLO
&                & PALNUM   =[F:STO1]PALNUM
&                & CTRNUM   =[F:STO1]CTRNUM
&                & STA      =[F:STO1]STA
&                & LOC      =[F:STO1]LOC
&                & PCU      =[F:STO1]PCU
&                & PCUSTUCOE=[F:STO1]PCUSTUCOE
&                & SERNUM   =[F:STO1]SERNUM
&                & QLYCTLDEM=[F:STO1]QLYCTLDEM
Read [STO] STO0 First
If fstat
    Raz [F:STO]
Endif
Filter [STO]
Return


###############################################################################
# Recherche toutes les lignes de stock respectant les caractéristiques stock
# en cours dans [F:STO1] et dont STOCOU est supérieur à celui de [F:STJ1]
$CLE_STO2
Filter [STO] Where STOCOU   >[F:STO1]STOCOU
&                & ITMREF   =[F:STO1]ITMREF
&                & STOFCY   =[F:STO1]STOFCY
&                & LOT      =[F:STO1]LOT
&                & SLO      =[F:STO1]SLO
&                & PALNUM   =[F:STO1]PALNUM
&                & CTRNUM   =[F:STO1]CTRNUM
&                & STA      =[F:STO1]STA
&                & LOC      =[F:STO1]LOC
&                & PCU      =[F:STO1]PCU
&                & PCUSTUCOE=[F:STO1]PCUSTUCOE
&                & SERNUM   =[F:STO1]SERNUM
&                & QLYCTLDEM=[F:STO1]QLYCTLDEM
Read [STO] STO0 First
If fstat
    Raz [F:STO]
Endif
Filter [STO]
Return

###############################################################################
# STKCVSTE : Mise à jour de la table STOPAR pour V140
#       Initialisation des champs SHTCAT
#       Si SHTPAR3>1 et SHTPAR2=1 --> SHTPAR2 = SHTPAR3
#                                     SHTPAR3 = 1
###############################################################################
# Paramètres E : LDOS   = Dossier
#                LFCY   = Site ou rien si tous sites
#                LPAR   = paramètre 0 = Première fois
#                                   1 = On refait le traitement
###############################################################################
Subprog STKCVSTE(LDOS,LFCY,LPAR)
Value Char    LDOS
Value Char    LFCY
Value Integer LPAR

If filinfo(filpath("FIL","STOPAR", "fde",[F:ADS]DOSSIER),0) < 0  End : Endif

Local File =LDOS+".STOPAR" [STE]

Trbegin [STE]
  For [STE]
    #Readlock [STE] Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici

    If [F:STE]SHTCAT1  = 0 :    [F:STE]SHTCAT1    = 2       : Endif
    If [F:STE]SHTCAT2  = 0 :    [F:STE]SHTCAT2    = 3       : Endif
    If [F:STE]SHTCAT3  = 0 :    [F:STE]SHTCAT3    = 4       : Endif

    If [F:STE]SHTPAR1<2
        If [F:STE]SHTPAR2>1
            [F:STE]SHTPAR1=[F:STE]SHTPAR2
            [F:STE]SHTPAR2=1
        Elsif [F:STE]SHTPAR3>1
                [F:STE]SHTPAR1=[F:STE]SHTPAR3
                [F:STE]SHTPAR3=1
        Else
            [F:STE]SHTPAR1=1
        Endif
        [F:STE]SHTPAR2=1
    Endif
    If [F:STE]SHTPAR2<2
        If [F:STE]SHTPAR3>1
            [F:STE]SHTPAR2=[F:STE]SHTPAR3
        Else
            [F:STE]SHTPAR2 = 1
        Endif
        [F:STE]SHTPAR3=1
    Endif
    If [F:STE]SHTPAR3<1
        [F:STE]SHTPAR3=1
    Endif

    Rewrite [STE]
    If fstat
      Call ECR_TRACE("File STOPAR, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Next
  If fstat
    Call ECR_TRACE("File STOPAR, Error ="-num$(fstat),1) From GESECRAN
  Endif
Commit
Close Local File [STE]

End

###############################################################################
# STKCVSTP : Mise à jour de la table STOCOST pour V140
#            Initialisation du champs CSTDAT (=CREDAT)
#            (c'est difficile de mieux faire)
###############################################################################
# Paramètres E : LDOS   = Dossier
#                LFCY   = Site ou rien si tous sites
#                LPAR   = paramètre 0 = Première fois
#                                   1 = On refait le traitement
###############################################################################
Subprog STKCVSTP(LDOS,LFCY,LPAR)
Value Char    LDOS
Value Char    LFCY
Value Integer LPAR
#
Local Integer LCPT
Local Integer LMAX          : LMAX = GMAXUPDTRS 

If filinfo(filpath("FIL","STOCOST", "fde",[F:ADS]DOSSIER),0) < 0  End : Endif

Local File =LDOS+".STOCOST" [STP]

Trbegin [STP]
Raz LCPT
For [STP] With Stability
    LCPT +=1
    #Readlock [STP] Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    [F:STP]CSTDAT = [F:STP]CREDAT
    Rewrite [STP]
    If LCPT>=LMAX
        Commit
        Trbegin [STP]
    Endif
Next

Commit
Close Local File [STP]

End


############################################################
# STKCVITV  : Conversion table ITMMVT (cumuls article-site)
#-----------------------------------------------------------
# Attention : La table STOCK doit avoir été maj (zone QTYSTUACT)
#-----------------------------------------------------------
# A faire   : Que fait on des zones TRFSTO, TRASTO
#-----------------------------------------------------------
# Remarque  : Pas de maj des zones ORDSTO, WAISTO
############################################################ 
Subprog STKCVITV

If filinfo(filpath("FIL","STOCK","fde",[F:ADS]DOSSIER),0) < 0  End  Endif

Local Char     CLE1(20),      CLE2(3)
Local Char     WITM(GLONITM), WFCY(GLONFCY)
Local Char     CRITERE(100)
Local Shortint STOP
Local Integer  COMPTEUR

Local File =[F:ADS]DOSSIER+".ITMMVT"     [ITV]
Local File =[F:ADS]DOSSIER+".STOCK"      [STO]
Local File =[F:ADS]DOSSIER+".STOALL"     [STA]
Local File =[F:ADS]DOSSIER+".ORDERS"     [ORD]

Raz CLE1, CLE2, STOP

Trbegin [ITV]

$BOUCLE_ITV
If STOP=1
   STOP=2 : CRITERE='ITMREF="'+CLE1+'"'+' & STOFCY>"'+CLE2+'"'
Elsif STOP=2
   STOP=0 : CRITERE='ITMREF>"'+CLE1+'"'
Else
   CRITERE="1=1"
Endif
Raz COMPTEUR

For [ITV]ITV0 Where evalue(CRITERE)

   WITM=[F:ITV]ITMREF
   WFCY=[F:ITV]STOFCY

   Raz [F:ITV]PHYSTO,    [F:ITV]CTLSTO,    [F:ITV]REJSTO
   Raz [F:ITV]PLFPHYSTO, [F:ITV]PLFCTLSTO, [F:ITV]PLFREJSTO
   Raz [F:ITV]BPRPHYSTO, [F:ITV]BPRCTLSTO, [F:ITV]BPRREJSTO
   Raz [F:ITV]SCOPHYSTO, [F:ITV]SCOCTLSTO, [F:ITV]SCOREJSTO
   Raz [F:ITV]AVCBASQTY, [F:ITV]SALSTO
   Raz [F:ITV]PHYALL,    [F:ITV]CTLALL,    [F:ITV]REJALL
   Raz [F:ITV]SCOPHYALL, [F:ITV]SCOCTLALL, [F:ITV]SCOREJALL
   Raz [F:ITV]GLOALL,    [F:ITV]GLOSHT,    [F:ITV]DETSHT

   For [STO]STO3 Where ITMREF=[F:ITV]ITMREF & STOFCY=[F:ITV]STOFCY
      Case left$([F:STO]STA,1)
       When "A" : Case [F:STO]LOCCAT
                   When 1 : [F:ITV]PHYSTO    += [F:STO]QTYSTUACT 
                   When 2 : [F:ITV]PLFPHYSTO += [F:STO]QTYSTUACT 
                   When 3 : [F:ITV]BPRPHYSTO += [F:STO]QTYSTUACT 
                   When 4 : [F:ITV]SCOPHYSTO += [F:STO]QTYSTUACT 
                  Endcase
       When "Q" : Case [F:STO]LOCCAT
                   When 1 : [F:ITV]CTLSTO    += [F:STO]QTYSTUACT 
                   When 2 : [F:ITV]PLFCTLSTO += [F:STO]QTYSTUACT 
                   When 3 : [F:ITV]BPRCTLSTO += [F:STO]QTYSTUACT 
                   When 4 : [F:ITV]SCOCTLSTO += [F:STO]QTYSTUACT 
                  Endcase
       When "R" : Case [F:STO]LOCCAT
                   When 1 : [F:ITV]REJSTO    += [F:STO]QTYSTUACT 
                   When 2 : [F:ITV]PLFREJSTO += [F:STO]QTYSTUACT 
                   When 3 : [F:ITV]BPRREJSTO += [F:STO]QTYSTUACT 
                   When 4 : [F:ITV]SCOREJSTO += [F:STO]QTYSTUACT 
                  Endcase
      Endcase
      [F:ITV]AVCBASQTY += [F:STO]QTYSTUACT    # CCC (29/11/05) QTYSTU --> QTYSTUACT
   Next
   [F:ITV]AVCBASAMT = [F:ITV]AVC * [F:ITV]AVCBASQTY    # CCC (29/11/05) Recalculer la base montant, car celle-ci peut être fausse

   For [STA]STA0 Where STOFCY=[F:ITV]STOFCY & ITMREF=[F:ITV]ITMREF
      Case [F:STA]ALLTYP
       When 1 : [F:ITV]GLOALL += [F:STA]QTYSTUACT
       When 2 : Read [STO]STO0=[F:STA]STOFCY;[F:STA]STOCOU
                If !fstat
                   If [F:STO]LOCCAT=4
                      Case left$([F:STO]STA,1)
                       When "A" : [F:ITV]SCOPHYALL += [F:STA]QTYSTUACT
                       When "Q" : [F:ITV]SCOCTLALL += [F:STA]QTYSTUACT
                       When "R" : [F:ITV]SCOREJALL += [F:STA]QTYSTUACT
                      Endcase
                   Else
                      Case left$([F:STO]STA,1)
                       When "A" : [F:ITV]PHYALL    += [F:STA]QTYSTUACT
                       When "Q" : [F:ITV]CTLALL    += [F:STA]QTYSTUACT
                       When "R" : [F:ITV]REJALL    += [F:STA]QTYSTUACT
                      Endcase
                   Endif
                Endif
       When 4 : [F:ITV]DETSHT += [F:STA]QTYSTUACT
       When 5 : [F:ITV]GLOSHT += [F:STA]QTYSTUACT
      Endcase
   Next

   For [ORD]ORD1 Where STOFCY=[F:ITV]STOFCY & ITMREF=[F:ITV]ITMREF &
&                      WIPTYP=1 & WIPSTA=1 & VCRTYP=2
       [F:ITV]SALSTO += [F:ORD]RMNEXTQTY
   Next

   Rewrite [ITV]
   If fstat
      Call ECR_TRACE("File ITMMVT :"-WITM-WFCY-", ERROR ="-num$(fstat),1) From GESECRAN
   Else
      COMPTEUR+=1
   Endif

   If COMPTEUR>GMAXUPDTRS 
      Commit
      Trbegin [ITV]
      CLE1=[F:ITV]ITMREF : CLE2=[F:ITV]STOFCY
      STOP=1 : Break 
   Endif
Next
If STOP Goto BOUCLE_ITV Endif
Commit

End

############################################################
# STKCVITH  : Conversion table ITMMVTHIS (cumuls article-site/période)
#-----------------------------------------------------------
# Alimente les nouveaux champs PERSTR et PEREND
# Modifie la valeur des champs YEA et MON
############################################################ 
Subprog STKCVITH

If filinfo(filpath("FIL","ITMMVTHIS","fde",[F:ADS]DOSSIER),0) < 0  End  Endif

Local Char     CLE1(20), CLE2(3), CRITERE(240)
Local Integer  CLE3, CLE4
Local Integer  COMPTEUR, STOP
Local Date     LMIDDAT

Local File =[F:ADS]DOSSIER+".ITMMVTHIS"  [ITH]
Local File =[F:ADS]DOSSIER+".ITMMVTHIS"  [ITH1]
Local File =[F:ADS]DOSSIER+".FACILITY"   [FCY]
Local File =[F:ADS]DOSSIER+".PERIOD"     [PER]


Raz CLE1,CLE2
Raz CLE3,CLE4,STOP

$BOUCLE_ITH
If STOP=1
   CRITERE = 'ITMREF="'+CLE1+'"&STOFCY="'+CLE2+'"&YEA='+num$(CLE3)+'&MON>'+num$(CLE4)
   STOP=2
Elsif STOP=2
   CRITERE = 'ITMREF="'+CLE1+'"&STOFCY="'+CLE2+'"&YEA>'+num$(CLE3)
   STOP=3
Elsif STOP=3
   CRITERE = 'ITMREF="'+CLE1+'"&STOFCY>"'+CLE2+'"'
   STOP=4
Elsif STOP=4
   CRITERE = 'ITMREF>"'+CLE1+'"'
   STOP=0
Else
   CRITERE = "1=1"
Endif

Raz COMPTEUR
Trbegin [ITH]

For [ITH]ITH0 Where evalue(CRITERE)
    COMPTEUR += 1
    Call ECR_TRACE(num$(COMPTEUR)-[F:ITH]ITMREF-[F:ITH]STOFCY-num$([ITH]YEA)-num$([F:ITH]MON),0) From GESECRAN
    If [F:ITH]MON<=0 | [F:ITH]YEA<=0
        Call ECR_TRACE(mess(1,104,1),1) From GESECRAN
    Else
        If [F:FCY]FCY<>[F:ITH]STOFCY
            Read [FCY]FCY0=[F:ITH]STOFCY
            If fstat Raz [F:FCY] Endif
        Endif
        [F:ITH]PERSTR = gdat$(1,[F:ITH]MON,[F:ITH]YEA)
        [F:ITH]PEREND = eomonth([F:ITH]PERSTR)
        LMIDDAT = gdat$(14,[ITH]MON,[F:ITH]YEA)
        Filter [PER] Where CPY = [FCY]LEGCPY
&                        & PERSTR <= LMIDDAT & LMIDDAT <= PEREND 
        For [PER]
            [F:ITH]FIYNUM = [F:PER]FIYNUM
            [F:ITH]PERNUM = [F:PER]PERNUM
            Break
        Next
        If [F:ITH]PERSTR=[0/0/0]
            Call ECR_TRACE(" Date nulle "-num$([F:ITH]PERSTR)+"-"+num$([F:ITH]PEREND)
&                         -num$([F:PER]PERSTR)+"-"+num$([F:PER]PEREND)
&                         -num$([F:PER]FIYNUM)+"-"+num$([F:PER]PERNUM),1) From GESECRAN
        Endif
        Filter [PER]
        Rewrite [ITH]
        If COMPTEUR>GMAXUPDTRS
            CLE1=[F:ITH]ITMREF
            CLE2=[F:ITH]STOFCY
            CLE3=[F:ITH]YEA
            CLE4=[F:ITH]MON
            STOP=1 : Break 
        Endif
    Endif
Next
Commit
If STOP Goto BOUCLE_ITH Endif
Call ECR_TRACE(mess(63,184,1),0) From GESECRAN

Raz CLE1, CLE2
Raz CLE3, CLE4, STOP

$BOUCLE_DOUBLON
If STOP=1
   CRITERE = 'ITMREF="'+CLE1+'"&STOFCY="'+CLE2+'"&YEA='+num$(CLE3)+'&MON>'+num$(CLE4)
   STOP=2
Elsif STOP=2
   CRITERE = 'ITMREF="'+CLE1+'"&STOFCY="'+CLE2+'"&YEA>'+num$(CLE3)
   STOP=3
Elsif STOP=3
   CRITERE = 'ITMREF="'+CLE1+'"&STOFCY>"'+CLE2+'"'
   STOP=4
Elsif STOP=4
   CRITERE = 'ITMREF>"'+CLE1+'"'
   STOP=0
Else
   CRITERE = "1=1"
Endif

Raz COMPTEUR
Trbegin [ITH]
For [ITH1] Where evalue(CRITERE) With Stability
    For [ITH]ITH0 Where ITMREF=[ITH1]ITMREF & STOFCY=[ITH1]STOFCY & PERSTR=[ITH1]PERSTR & (YEA<>[ITH1]YEA | MON<>[ITH1]MON)
        [ITH1]LASREODAT = max([ITH]LASREODAT,[ITH1]LASREODAT)
        If [ITH1]LASPURDAT<[ITH]LASPURDAT
            [ITH1]LASPURPRI = [ITH]LASPURPRI
            [ITH1]LASPURDAT = [ITH]LASPURDAT
        Endif
        If [ITH1]LASRCPDAT<[ITH]LASRCPDAT
            [ITH1]LASRCPPRI = [ITH]LASRCPPRI
            [ITH1]LASRCPDAT = [ITH]LASRCPDAT
        Endif
        [ITH1]MONRCPQTY += [ITH1]MONRCPQTY
        [ITH1]YEARCPQTY += [ITH]YEARCPQTY 
        [ITH1]MONRCPAMT += [ITH]MONRCPAMT 
        [ITH1]YEARCPAMT += [ITH]YEARCPAMT 
        [ITH1]MONRCPMVT += [ITH]MONRCPMVT 
        [ITH1]YEARCPMVT += [ITH]YEARCPMVT 
        [ITH1]LASISSDAT  = max([ITH]LASISSDAT ,[ITH1]LASISSDAT)
        [ITH1]MONISSQTY += [ITH]MONISSQTY 
        [ITH1]YEAISSQTY += [ITH]YEAISSQTY 
        [ITH1]MONISSAMT += [ITH]MONISSAMT 
        [ITH1]YEAISSAMT += [ITH]YEAISSAMT 
        [ITH1]MONISSMVT += [ITH]MONISSMVT 
        [ITH1]YEAISSMVT += [ITH]YEAISSMVT 
        Rewrite [ITH1]
        Delete [ITH]ITH0 Curr
        STOP=1
    Next
    If STOP
        CLE1=[F:ITH1]ITMREF
        CLE2=[F:ITH1]STOFCY
        CLE3=[F:ITH1]YEA
        CLE4=[F:ITH1]MON
        Break
    Endif
Next
Commit
If STOP
    Goto BOUCLE_DOUBLON
Endif

End

$ERR
    Call ECR_TRACE("ERREUR ligne "+num$(errl)-errp+chr$(13)-errmes$(errn),1) From GESECRAN
    Rollback
End


############################################################
# STKCVSTJ  : Conversion table STOJOU (Mouvements stock)
#-----------------------------------------------------------
# Met à jour le champ ACTQTY pour les mouvements en attente
############################################################ 
Subprog STKCVSTJ

If filinfo(filpath("FIL","STOJOU","fde",[F:ADS]DOSSIER),0) < 0  End  Endif

Local File =[F:ADS]DOSSIER+".STOLOT"     [STL]
Local File =[F:ADS]DOSSIER+".STOJOU"     [STJ]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]

Local Char    CLE1(GLONFCY), CLE3(GLONITM)
Local Date    CLE4
Local Integer CLE2, CLE5     # pour se repositionner après une boucle
Local Integer STOP,NB, LREW
Local Char    CRITERE(250)

# CCC (06/07/06) Bug 36497
Raz STOP
$LOOP_STJ
Raz NB
If STOP = 1
  STOP = 2
  CRITERE = "STOFCY=CLE1 & UPDCOD=CLE2 & ITMREF=CLE3 & IPTDAT=CLE4 & MVTSEQ>CLE5"
Elsif STOP = 2
  STOP = 3
  CRITERE = "STOFCY=CLE1 & UPDCOD=CLE2 & ITMREF=CLE3 & IPTDAT<CLE4"     # attention sens clé (-) !?
Elsif STOP = 3
  STOP = 4
  CRITERE = "STOFCY=CLE1 & UPDCOD=CLE2 & ITMREF>CLE3"
Elsif STOP = 4
  STOP = 5
  CRITERE = "STOFCY=CLE1 & UPDCOD>CLE2"
Elsif STOP=5
  STOP = 0
  CRITERE = "STOFCY>CLE1"
Else
  CRITERE = "1=1"
Endif

Trbegin [STJ]
For [STJ]STJ0 Where evalue(CRITERE)
    Raz LREW
    If [F:STJ]ACTQTY=0 & [F:STJ]QTYSTU<>0
        LREW=1
        #Readlock [STJ] Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici

        If [F:ITM]ITMREF<>[F:STJ]ITMREF
            Raz [F:ITM]
            Read [ITM]ITM0=[F:STJ]ITMREF
        Endif
        If !fstat
            Case [F:ITM]STOMGTCOD
                When 3 :
                    If [F:STJ]POT<>0
                        [F:STJ]ACTQTY = [F:STJ]QTYSTU * [F:STJ]POT/100
                    Else
                        If [F:STL]ITMREF<>[F:STJ]ITMREF | [F:STL]LOT<>[F:STJ]LOT
                            Read [STL]STL0=[F:STJ]ITMREF;[F:STJ]LOT
                            If !fstat & [F:STL]POT<>0
                                [F:STJ]ACTQTY = [F:STJ]QTYSTU * [F:STL]POT/100
                            Endif
                        Endif
                    Endif

                When 4 :
                    If [F:STJ]ACT<>0
                        [F:STJ]ACTQTY = [F:STJ]QTYSTU * [F:STJ]ACT/100
                    Else
                        If [F:STL]ITMREF<>[F:STJ]ITMREF | [F:STL]LOT<>[F:STJ]LOT
                            Read [STL]STL0=[F:STJ]ITMREF;[F:STJ]LOT
                            If !fstat & [F:STL]ACT<>0
                                [F:STJ]ACTQTY = [F:STJ]QTYSTU * [F:STL]ACT/100
                            Endif
                        Endif
                    Endif
            Endcase
        Endif
        If [F:STJ]ACTQTY=0
            [F:STJ]ACTQTY = [F:STJ]QTYSTU
        Endif
    Endif
    If sgn([F:STJ]ACTQTY)<>sgn([F:STJ]QTYSTU)
        If !LREW
            LREW=1
            #Readlock [STJ] Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
            Read [STJ] Curr  # FGR 12/03/2010 : X3SUIVI63191
        Endif
        [F:STJ]ACTQTY *= -1
    Endif
    If [F:STJ]UPDCOD=2
        If !LREW
            LREW=1
            #Readlock [STJ] Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
            Read [STJ] Curr  # FGR 12/03/2010 : X3SUIVI63191
        Endif
        [F:STJ]PRIORD=[F:STJ]PRIREG
        [F:STJ]PRIVAL=[F:STJ]PRIREG
        [F:STJ]AMTORD=[F:STJ]PRIREG*[F:STJ]QTYSTU
        [F:STJ]AMTVAL=[F:STJ]PRIREG*[F:STJ]QTYSTU
        [F:STJ]VARORD=[F:STJ]PRIREG*[F:STJ]QTYSTU
        [F:STJ]VARVAL=[F:STJ]PRIREG*[F:STJ]QTYSTU
    Endif

    If LREW
        Rewrite [STJ]
        NB+=1
        If NB>GMAXUPDTRS
            CLE1 = [F:STJ]STOFCY
            CLE2 = [F:STJ]UPDCOD
            CLE3 = [F:STJ]ITMREF
            CLE4 = [F:STJ]IPTDAT
            CLE5 = [F:STJ]MVTSEQ
            STOP=1
            Break
        Endif
    Endif
Next
Commit
If STOP
    Goto LOOP_STJ
Endif
End

############################################################
# STKCVCRD  : Conversion table QLYCRD (Fiches Contrôles qualité)
#-----------------------------------------------------------
# - Alimente le nouveau champ SEQ de QLYCRD [QLC]
# - Alimente les nouveaux champs de QLYCRDASW [QLA]:
#    * CRDSEQ avec l'ancien MVTSEQ 
#    * VCRLIN avec 1000 (premier n° de ligne de DA) Cf. STKCVQLY
############################################################ 
Subprog STKCVCRD

If filinfo(filpath("FIL","QLYCRD","fde",[F:ADS]DOSSIER),0) < 0  End  Endif
Local File =[F:ADS]DOSSIER+".QLYCRD" [QLC]
Local File =[F:ADS]DOSSIER+".QLYCRDASW" [QLA]
Local Integer I
Local Integer COMPTEUR
Local Char LQLYCRD
Local Integer LNUMLIN
Local Char LDEM(GLONVCR)
Local Integer LSEQ
Local Char LQST(GLONQST)
Local Integer STOP : Raz STOP
Local Char CRIT(250)

I=1
$BOUCLE_QLC
If STOP=1
    CRIT = "QLYCRD=LQLYCRD & NUMLIN>LNUMLIN"
    STOP = 2
Elsif STOP=2
    CRIT = "QLYCRD>LQLYCRD"
    STOP = 0
Else
    CRIT = "1=1"
Endif
Trbegin [QLC]
Raz COMPTEUR
For [QLC] Where evalue(CRIT)

    [QLC]SEQ = I    # n° utilisé pour la génération des écrans et fenêtres
    I+=1
    Rewrite [QLC]

    COMPTEUR +=1
    If COMPTEUR>GMAXUPDTRS
        LQLYCRD = [QLC]QLYCRD
        LNUMLIN = [QLC]NUMLIN
        STOP = 1
        Break
    Endif
Next
Commit
If STOP
    Goto $BOUCLE_QLC
Endif

$BOUCLE_QLA
If STOP=1
    CRIT = "QLYCTLDEM=LDEM & MVTSEQ=LSEQ & QSTNUM>LQST"
    STOP = 2
Elsif STOP=2
    CRIT = "QLYCTLDEM=LDEM & MVTSEQ>LSEQ"
    STOP = 3
Elsif STOP=3
    CRIT = "QLYCTLDEM>LDEM"
    STOP = 0
Else
    CRIT = "1=1"
Endif
Raz COMPTEUR
Trbegin [QLA]
For [QLA] Where evalue(CRIT) With Stability
    [F:QLA]CRDSEQ = [F:QLA]MVTSEQ
    [F:QLA]VCRLIN = 1000
    Rewrite [QLA]
    COMPTEUR+=1
    If COMPTEUR>GMAXUPDTRS
        LDEM = [QLA]QLYCTLDEM
        LSEQ = [QLA]MVTSEQ
        LQST = [QLA]QSTNUM
        STOP = 1
        Break
    Endif
Next
Commit
If STOP
    Goto $BOUCLE_QLA
Endif

End

############################################################
# STKCVQLY  : Conversion table STOQUAL (Contrôles qualité)
#-----------------------------------------------------------
# Met les enregistrements STOQUAL dans les tables STOQLYH/D
############################################################ 
Subprog STKCVQLY

If filinfo(filpath("FIL","STOQUAL","fde",[F:ADS]DOSSIER),0) < 0  End  Endif

Local File =[F:ADS]DOSSIER+".STOQUAL" [STQ]
Local File =[F:ADS]DOSSIER+".STOQLYH" [QLH]
Local File =[F:ADS]DOSSIER+".STOQLYD" [QLD]
Local File =[F:ADS]DOSSIER+".STOCK"   [STO]
Local File =[F:ADS]DOSSIER+".QLYCRDASW" [QLA]
Local Integer LLIN
Local Char    LQLYCTLDEM : Raz LQLYCTLDEM
Local Integer COMPTEUR

Local Decimal WQTYSTU                               # hcb 39051
Local Char    WSTA                                  # hcb 39051
Local Char    WLOT(GLONLOT)                         # hcb 50924
Local File =[F:ADS]DOSSIER+".ITMMASTER"   [ITM]     # hcb 39051

$BOUCLE_STQ
Trbegin [QLH]
Raz COMPTEUR
For [STQ] Where QLYCTLDEM>LQLYCTLDEM
    #------ Vérifie qu'il y a du stock en statut Q => à contrôler ----#
    LLIN = 1000    # On commence par la ligne 1000 comme dans STKCVCRD
    Raz [F:QLH]

    If  [F:STQ]STAFLG = 1                           # hcb 39051
#######  fin demande 39051

        Filter [STO] Where ITMREF    = [STQ]ITMREF &
&                    STOFCY    = [STQ]STOFCY &
&                    LOT       = [STQ]LOT    &
&                    QTYSTU   <> 0           &
&                    QLYCTLDEM = [STQ]QLYCTLDEM &
&                    left$(STA,1) = "Q"
&               Order By Key STO3
        For [STO] Hint Key STO3
            Raz [F:QLD]
        #----- En-tête de la demande d'analyse ----#
            Gosub ALIM_QLH    # Crée ou se positionne sur l'en-tête de QC
        #----- Ligne de la demande d'analyse -----#
            [F:QLD]=[F:STO]
            [F:QLD]=[F:QLH]
            [F:QLD]VCRLIN    = LLIN
            [F:QLD]VCRLINORI = [F:STQ]VCRLIN              # hcb 44605

            Columns [QLA] (CRDSEQ)
            Filter [QLA] Where QLYCTLDEM = [F:QLD]VCRNUM
&                        Order By CRDSEQ
            For [QLA]
                [F:QLD]CRDSEQ = [F:QLA]CRDSEQ
                Break
            Next
            Filter [QLA]
            Columns [QLA]
            [F:QLD]CRDFLG = [F:STQ]CRDFLG

            Write [QLD]
            LLIN += 1000
            COMPTEUR+=1
        Next
        Filter [STO]
    Endif                              # hcb 39051         
#######  deb demande 39051
    Raz WQTYSTU
    Raz WSTA
    If  [F:STQ]STAFLG = 2
        If [F:STQ]QQQQTY <> 0
           WQTYSTU =  [F:STQ]QQQQTY 
           WSTA    =  "Q"  
           WLOT    =  [F:STQ]LOT       # hcb 50924    
           Gosub ECR_CQ
        Endif 
    Endif
    If [F:STQ]AAAQTY <> 0
        WQTYSTU =  [F:STQ]AAAQTY 
        WSTA    =  "A"  
        WLOT    =  [F:STQ]LOT       # hcb 50924    
        Gosub ECR_CQ
    Endif 
    If [F:STQ]RRRQTY <> 0
        WQTYSTU =  [F:STQ]RRRQTY 
        WSTA    =  "R"  
        WLOT    =  [F:STQ]LOT       # hcb 50924    
        Gosub ECR_CQ
    Endif 
    If COMPTEUR > GMAXUPDTRS
        LQLYCTLDEM = [F:STQ]QLYCTLDEM
        Break
    Endif
#######  fin demande 39051
Next
Commit
If COMPTEUR > GMAXUPDTRS
    Goto BOUCLE_STQ
Endif

End

#######  deb demande 39051
$ECR_CQ
Raz [F:QLD]
#----- En-tête de la demande d'analyse ----#
Gosub ALIM_QLH    # Crée ou se positionne sur l'en-tête de QC
        #----- Ligne de la demande d'analyse -----#
[F:QLD]=[F:QLH]
[F:QLD]VCRLIN    =  LLIN
Columns [QLA] (CRDSEQ)
Filter [QLA] Where QLYCTLDEM = [F:QLD]VCRNUM
&      Order By CRDSEQ
For [QLA]
    [F:QLD]CRDSEQ = [F:QLA]CRDSEQ
    Break
Next
Filter [QLA]
Columns [QLA]
If [F:ITM]ITMREF <> [F:STQ]ITMREF
   Read [ITM]ITM0=[F:STQ]ITMREF
   If fstat
      Raz [F:ITM]
   Endif
Endif
[F:QLD]VCRLINORI = [F:STQ]VCRLIN              # hcb 44605
[F:QLD]PCU       = [F:ITM]STU
[F:QLD]CRDFLG    = [F:STQ]CRDFLG
[F:QLD]QTYSTU    = WQTYSTU
[F:QLD]QTYPCU    = WQTYSTU
[F:QLD]STA       = WSTA
[F:QLD]LOT       = WLOT                       # hcb 50924    
[F:QLD]PCUSTUCOE = 1

Write [QLD]
LLIN += 1000
COMPTEUR+=1
Return
#######  fin demande 39051


#################################
$ALIM_QLH
If [F:QLH]VCRNUM <> [F:STQ]QLYCTLDEM
    Read [QLH]QLH0=28;[F:STQ]QLYCTLDEM
    If fstat
        Raz [F:QLH]
        [F:QLH]VCRTYP    = 28
        [F:QLH]VCRNUM    = [F:STQ]QLYCTLDEM
        [F:QLH]STOFCY    = [F:STQ]STOFCY
        [F:QLH]ITMREF    = [F:STQ]ITMREF
        [F:QLH]VCRTYPORI = [F:STQ]VCRTYP
        [F:QLH]VCRNUMORI = [F:STQ]VCRNUM
        [F:QLH]PJT       = [F:STQ]PJT
        [F:QLH]TRSCOD    = ""
        [F:QLH]ENDCTLDAT = [F:STQ]ENDCTLDAT
        [F:QLH]QLYCRD    = [F:STQ]QLYCRD
#       [F:QLH]VALFLG    = 1                      # hcb 39051
        [F:QLH]VALFLG    = [F:STQ]STAFLG          # hcb 39051
        [F:QLH]EXPNUM    = 0
        [F:QLH]CREDAT    = [F:STQ]CREDAT
        [F:QLH]CREUSR    = [F:STQ]CREUSR
        Write [QLH]
    Endif
Endif
Return

############################################################
# STKGENCRD : Génération des écrans et fenêtre des fiches qualité
############################################################ 
Subprog STKGENCRD
If filinfo(filpath("FIL","QLYCRD","fde",[F:ADS]DOSSIER),0) < 0  End  Endif

Local File =[F:ADS]DOSSIER+".QLYCRD" [QLC1]    # Utilisation de QLC1 car QLC est utilisé dans GENCRD

# hcb 72510 deb
If clalev([F:ADS1])= 0 : Local File ADOSSIER                     [ADS1]  : Endif
If clalev([F:QLC]) = 0 : Local File =[F:ADS]DOSSIER+".QLYCRD"    [QLC]   : Endif
If clalev([F:QLQ]) = 0 : Local File =[F:ADS]DOSSIER+".QLYCRDQST" [QLQ]   : Endif
If clalev([F:TCT]) = 0 : Local File =[F:ADS]DOSSIER+".TABCTL"    [TCT]   : Endif
If clalev([F:AMK1])= 0 : Local File =[F:ADS]DOSSIER+".AMSK"      [AMK1]  : Endif
If clalev([F:AMK2])= 0 : Local File =[F:ADS]DOSSIER+".AMSK"      [AMK2]  : Endif
If clalev([F:AMZ1])= 0 : Local File =[F:ADS]DOSSIER+".AMSKZON"   [AMZ1]  : Endif
If clalev([F:AMZ2])= 0 : Local File =[F:ADS]DOSSIER+".AMSKZON"   [AMZ2]  : Endif
If clalev([F:AMA1])= 0 : Local File =[F:ADS]DOSSIER+".AMSKACT"   [AMA1]  : Endif
If clalev([F:AMA2])= 0 : Local File =[F:ADS]DOSSIER+".AMSKACT"   [AMA2]  : Endif
If clalev([F:AMP1])= 0 : Local File =[F:ADS]DOSSIER+".AMSKPAR"   [AMP1]  : Endif
If clalev([F:AMP2])= 0 : Local File =[F:ADS]DOSSIER+".AMSKPAR"   [AMP2]  : Endif
If clalev([F:AWI1])= 0 : Local File =[F:ADS]DOSSIER+".AWINDOW"   [AWI1]  : Endif
If clalev([F:AWI2])= 0 : Local File =[F:ADS]DOSSIER+".AWINDOW"   [AWI2]  : Endif
If clalev([F:AWP1])= 0 : Local File =[F:ADS]DOSSIER+".AWINPAR"   [AWP1]  : Endif
If clalev([F:AWP2])= 0 : Local File =[F:ADS]DOSSIER+".AWINPAR"   [AWP2]  : Endif
If clalev([F:AWT1])= 0 : Local File =[F:ADS]DOSSIER+".AWINBOUT"  [AWT1]  : Endif
If clalev([F:AWT2])= 0 : Local File =[F:ADS]DOSSIER+".AWINBOUT"  [AWT2]  : Endif
If clalev([F:AWB1])= 0 : Local File =[F:ADS]DOSSIER+".AWINBRO"   [AWB1]  : Endif
If clalev([F:AWB2])= 0 : Local File =[F:ADS]DOSSIER+".AWINBRO"   [AWB2]  : Endif
If clalev([F:AWI1])= 0 : Local File =[F:ADS]DOSSIER+".AWINDOW"   [AWI1]  : Endif
# hcb 72510 end




Local Integer COMPTEUR
Local Char LQLYCRD
Local Char LQLYCRD1

$BOUCLE_QLC2
Trbegin [QLC1]
Raz COMPTEUR
For [QLC1] Where QLYCRD>LQLYCRD1 & NUMLIN = 1                           # hcb 72510
    Call GENCRD([F:ADS]DOSSIER,"QLYCRD1","IQLYCRD",[F:QLC1]QLYCRD) From CRDLIB
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS
       LQLYCRD1 = [F:QLC1]QLYCRD
       Commit
       Break
    Endif
Next
If COMPTEUR > GMAXUPDTRS
    Goto BOUCLE_QLC2
Endif
Commit
End

############################################################
# STKCVQLA : Duplique les réponses aux fiches qualité
#            autant de fois qu'il y a de lignes dans le contrôle qualité
#-----------------------------------------------------------
# Ceci ne peut être fait qu'après la modification de la clé primaire
############################################################ 
Subprog STKCVQLA
If filinfo(filpath("FIL","QLYCRDASW","fde",[F:ADS]DOSSIER),0) < 0  End  Endif

Local File =[F:ADS]DOSSIER+".QLYCRDASW" [QLA]
Local File =[F:ADS]DOSSIER+".QLYCRDASW" [QLA1]
Local File =[F:ADS]DOSSIER+".STOQLYD"   [QLD]
Local Char    LDEM(GLONVCR)
Local Integer LSEQ
Local Integer COMPTEUR
Local Char    LQST(GLONQST)
Local Integer STOP : Raz STOP
Local Char    CRIT(250)

$BOUCLE_QLA2
If STOP=1
    CRIT = "QLYCTLDEM=LDEM & CRDSEQ=LSEQ & QSTNUM>LQST"
    STOP=2
Elsif STOP=2
    CRIT = "QLYCTLDEM=LDEM & CRDSEQ>LSEQ"
    STOP = 3
Elsif STOP=3
    CRIT = "QLYCTLDEM>LDEM"
    STOP=0
Else
    CRIT="1=1"
Endif
Trbegin [QLA1]
Raz COMPTEUR
For [QLA] Where evalue (CRIT) With Stability
    For [QLD] Where VCRNUM=[QLA]QLYCTLDEM
&                 & VCRLIN > 1000
        [F:QLA1] = [F:QLA]
        [F:QLA1]VCRLIN = [F:QLD]VCRLIN
        Write [QLA1]
        COMPTEUR += 1
    Next
    If COMPTEUR > GMAXUPDTRS
        LDEM = [F:QLA]QLYCTLDEM
        LSEQ = [F:QLA]CRDSEQ
        LQST = [F:QLA]QSTNUM
        STOP = 1
        Break
    Endif
Next
Commit
If STOP
    Goto BOUCLE_QLA2
Endif
End


$TRT_ERR
    Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
Resume

########################################################################################
# INVENTAIRES

#########################################################################
#  STKCVCUD  : Conversion table  CUNLISDET
# Paramètres E : LDOS   = Dossier
#                LFCY   = Site ou rien si tous sites
#                LPAR   = paramètre 0 = Première fois
#                                   1 = On refait le traitement
#########################################################################
Subprog STKCVCUD(LDOS,LFCY,LPAR)
Value Char    LDOS
Value Char    LFCY
Value Integer LPAR
#
Local File =LDOS+".CUNLISDET"     [CUD]    # Pour la lecture
Local File =LDOS+".CUNLISDET"     [CUD1]   # Pour l ecriture 
#
Local Integer LRET
Local Integer C
Local Integer I
Local Integer WITMLISNUM

If clalev([F:CUH]) = 0 : Local File =LDOS+".CUNLISHEA"   [CUH] : Endif
If clalev([F:CUS]) = 0 : Local File =LDOS+".CUNLISSER"   [CUS] : Endif
If clalev([F:ITM]) = 0 : Local File =LDOS+".ITMMASTER"   [ITM] : Endif


Call DEBTRANS From GLOCK
Trbegin [CUD1]

#Call OUVRE_BOITE("Trt table:  CUNLISDET Phase 1 ("+num$(nbrecord([CUD]))+")",nbrecord([CUD])) From GESECRAN
Raz C
GOK=1
Local Integer WI
Raz WI
For [CUD]
    C+=1
#    Call AFF_BOITE(num$(C),C,I) From GESECRAN

    If [F:CUD]CUNSSSNUM <> "" 
        Goto $CUD_NEXT
    Endif
    If [F:CUD]LINUPDFLG  <> 2
        If WI = 0
          Call ECR_TRACE(mess(52,184,1),1) From GESECRAN
          WI = 1
        Endif
       GMESSAGE=mess(18,7,1)-[F:CUD]ITMREF-mess(23,107,1)-[F:CUD]LOT-mess(44,197,1)-[F:CUD]LOC-mess(33,105,1)-num$([F:CUD]QTYSTU)-mess(137,124,1)-[F:CUD]CUNLISNUM
       Call ECR_TRACE(GMESSAGE,1) From GESECRAN
       Raz GMESSAGE
       Goto  $CUD_NEXT
    Endif

    Read [CUH]CUH0=[F:CUD]CUNLISNUM 
    If fstat 
       Raz [F:CUH] 
    Endif
    [F:CUD1]             = [F:CUD]
    [F:CUD1]CUNLOKFLG    = 2
    [F:CUD1]CUNSSSNUM    = [F:CUD]CUNLISNUM  
    [F:CUD1]IPTDAT       = [F:CUH]IPTDAT  
    If [F:CUD]LINUPDFLG  = 2
       [F:CUD1]CUNLISSTA = 4
       [F:CUD1]CUNLOKFLG = 1
    Endif  

    Write [CUD1]
$CUD_NEXT
Next
#Call FERME_BOITE From GESECRAN

Commit
End


#########################################################################
#  STKCVCUD1  : Suppression session à spaces table  CUNLISDET
# Paramètres E : LDOS   = Dossier
#                LFCY   = Site ou rien si tous sites
#                LPAR   = paramètre 0 = Première fois
#                                   1 = On refait le traitement
#########################################################################

Subprog STKCVCUD1(LDOS,LFCY,LPAR)
Value Char    LDOS
Value Char    LFCY
Value Integer LPAR
#
Local File =LDOS+".CUNLISDET"     [CUD]  
#
Local Integer LRET



Call DEBTRANS From GLOCK
Trbegin [CUD]

#Call OUVRE_BOITE("Trt table:  CUNLISDET Phase 2 ("+num$(nbrecord([CUD]))+")",nbrecord([CUD])) From GESECRAN
Delete [F:CUD] Where CUNSSSNUM  = "" 

#Call FERME_BOITE From GESECRAN

Commit

End




#########################################################################
#  STKCVCUNCUL  : Creation  table  CUNSESSION CUNLISTE
# Paramètres E : LDOS   = Dossier
#                LFCY   = Site ou rien si tous sites
#                LPAR   = paramètre 0 = Première fois
#                                   1 = On refait le traitement
#########################################################################
Subprog STKCVCUNCUL(LDOS,LFCY,LPAR)
Value Char    LDOS
Value Char    LFCY
Value Integer LPAR
#
If clalev([F:CUH]) = 0 : Local File =LDOS+".CUNLISHEA"   [CUH] : Endif
Local File =LDOS+".CUNSESSION"     [CUN]  
Local File =LDOS+".CUNLISTE"       [CUL]  
#
Local Integer LRET
Local Integer C
Local Integer I

Call DEBTRANS From GLOCK
Trbegin [CUN]

#Call OUVRE_BOITE("Trt table:  CUNSESSION  ("+num$(nbrecord([CUH]))+")",nbrecord([CUH])) From GESECRAN
Raz C
GOK=1
For [CUH]
    C+=1
#    Call AFF_BOITE(num$(C),C,I) From GESECRAN

    [F:CUN]             = [F:CUH]
    [F:CUL]             = [F:CUH]

##############################
#rubriques par trans-classe              
##############################
#Site de stockage               
#Classe A/B/C
#Comptage Article A/B/C
#Comptage Demandes A/B/C
#Emplacement reception   
#Emplacement Stochage    
#Emplacement Picking     
#Derniere imputation                

##############################
#rubriques par correspondance            
##############################
#Session                        
    [F:CUN]CUNSSSNUM    = [F:CUH]CUNLISNUM  
    [F:CUL]CUNSSSNUM    = [F:CUH]CUNLISNUM  
#Liste                        
    [F:CUL]CUNLISNUM    = [F:CUH]CUNLISNUM  

#Intitule                      
    [F:CUN]CUNSSSDES    = [F:CUH]CUNLISDES  
    [F:CUL]CUNLISDES    = [F:CUH]CUNLISDES  
#Choix traitement               
    [F:CUN]CUNSSSMOD    = [F:CUH]CUNLISTYP
    If [F:CUN]CUNSSSMOD = 4
       [F:CUN]CUNSSSMOD = 1
    Endif  
     
#Statut                       
     If [F:CUH]UPDFLG    = 2
       [F:CUN]CUNSSSSTA = 3
       [F:CUL]CUNLISSTA = 6
    Else
       [F:CUN]CUNSSSSTA = 2
       [F:CUL]CUNLISSTA = 1
    Endif  
#Date inventaire                
    [F:CUN]CUNSSSDAT    = [F:CUH]CUNLISDAT
    [F:CUL]CUNLISDAT    = [F:CUH]CUNLISDAT
#Date statut                
    [F:CUL]CUNSTADAT    = [F:CUH]UPDDAT
#Operateur                
    [F:CUL]USR          = [F:CUH]UPDUSR

##############################
#rubriques nouvelles 
##############################
# Type inventaire
    [F:CUN]CUNSSSTYP    = 1  
# Maximum lignes
    [F:CUN]MAXLIG       = 9999
#  % limite      
    [F:CUN]PRCLIG       = 100
# Nombre article 
    [F:CUN]ITMNBR       = 9999
# Position emplacement
    [F:CUN]LOCPOS       = 10
# Classe D            
    [F:CUN]ABCCLSD      = 1
#Emplacement Poste W
    [F:CUN]TRALOCFLG    = 1
#Emplacement Quai    
    [F:CUN]QUALOCFLG    = 1
#Emplacement Magasin
    [F:CUN]MAGLOCFLG    = 1
#Emplacement Retour 
    [F:CUN]RETLOCFLG    = 1
#Maj Der inventaire
    [F:CUN]CUNLASFLG    = 2
#Stock verrouillé
    [F:CUL]CUNLOKFLG    = 2
    If [F:CUH]UPDFLG    = 2
       [F:CUL]CUNLOKFLG = 1
    Endif

##############################
#rubriques nouvelles à spaces 
##############################
# Formule        
# Article debut / fin
# Type emp debut /fin
# Emplacement debut / fin
# Categorie debut / fin
# Tiers debut / fin
# Acheteur debut / fin
# Famille stat debut / fin
# Lot debut / fin

##############################
#rubriques nouvelles à 0 
##############################
# Comptage article D
# Comptage demande D
# nbrlig
##############################
#rubriques ne pouvant pas etre recuperées
##############################
# tri inventaire
    [F:CUN]CUNSRTCOD    = 1  

    Write [CUN]
    Write [CUL]
Next
#Call FERME_BOITE From GESECRAN

Commit

End

#########################################################################
#  STKBENCHTRS  : Mise à jour  table  BENCHTRS
#########################################################################
Subprog STKBENCHTRS
Local Integer K
Local Integer INDIC
If filinfo (filpath ("FIL", "BENCHTRS"   , "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif

Local File =[F:ADS]DOSSIER+".BENCHTRS"   [BTS]

Trbegin [BTS]
For [BTS]BTS0
    #Readlock [BTS] Curr      # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat
    #    Call ECR_TRACE("File BENCHTRS, Error ="-num$(fstat),1) From GESECRAN
    #Else
        Case [F:BTS]BTSTYP
            When 52:     Raz INDIC
                         K = sigma(0,8,[F:BTS]SUG(indcum)) + sigma(0,8,[F:BTS]PLN(indcum)) + sigma(0,8,[F:BTS]LAN(indcum))
                         If K < 26
                            INDIC = 1
                            [F:BTS]SUG(0) = 2
                            [F:BTS]SUG(1) = 2
                            [F:BTS]SUG(2) = 2
                            [F:BTS]SUG(3) = 2
                            [F:BTS]SUG(4) = 2
                            [F:BTS]SUG(5) = 2
                            [F:BTS]SUG(6) = 2
                            [F:BTS]SUG(7) = 2
                            [F:BTS]PLN(0) = 2
                            [F:BTS]PLN(1) = 2
                            [F:BTS]PLN(2) = 2
                            [F:BTS]PLN(3) = 2
                            [F:BTS]PLN(4) = 2
                            [F:BTS]PLN(5) = 2
                            [F:BTS]PLN(6) = 2
                            [F:BTS]PLN(7) = 2
                            [F:BTS]LAN(0) = 2
                            [F:BTS]LAN(1) = 2
                            [F:BTS]LAN(2) = 2
                            [F:BTS]LAN(3) = 2
                            [F:BTS]LAN(4) = 2
                            [F:BTS]LAN(5) = 2
                            [F:BTS]LAN(6) = 2
                            [F:BTS]LAN(7) = 2
                            [F:BTS]LAN(8) = 2
                         Endif
            When 53:     Raz INDIC 
                         If [F:BTS]TRSCNL = 0 : INDIC = 1 : [F:BTS]TRSCNL = 1 : Endif
                         If [F:BTS]APPINT = 0 : INDIC = 1 : [F:BTS]APPINT = 1 : Endif
            When 62,63 : Raz INDIC
                         Gosub  TXNSTOCK
       Endcase
       If !find([F:BTS]ICPYFLG,1,2,3) : INDIC = 1 : [F:BTS]ICPYFLG = 1 : Endif
       If INDIC = 1 
            Rewrite [F:BTS]
       Endif 
    #Endif
  Next
Commit
Close Local File [BTS]

End

######################################################################################
$TXNSTOCK
#   Init nouveaux champs stock : STOETR2
If [F:BTS]SRGWAIFLG=0  [F:BTS]SRGWAIFLG=1  : Endif   : # A quai  (non)

#   Bloc document
If [F:BTS]UOMSAIFLG=0 [F:BTS]UOMSAIFLG=1 : Endif                         : # Saisie UC     (non)
If !find([F:BTS]LOTCOD,1,2,3)    INDIC=1 : [F:BTS]LOTCOD=1 : Endif       : # Num.lot       (saisie)
If [F:BTS]LOTCOD<>0  & [F:BTS]LOTSCR=0 INDIC=1 : [F:BTS]LOTSCR=1  : Endif
If !find([F:BTS]SLOCOD,1,2,3)    INDIC=1 : [F:BTS]SLOCOD=3 : Endif       : # Num.sous-lot  (invisible)
If [F:BTS]SLOCOD<>0  & [F:BTS]SLOSCR=0 INDIC=1 : [F:BTS]SLOSCR=1  : Endif
If [F:BTS]NBSLOFLG=0  [F:BTS]NBSLOFLG=1 : Endif                          : # Nbr s-lot     (invisible)
If !find([F:BTS]LOCCOD,1,2,3)    INDIC=1 : [F:BTS]LOCCOD=3 : Endif       : # Emplacement   (invisible)
If [F:BTS]LOCCOD<>0  & [F:BTS]LOCSCR=0 INDIC=1 : [F:BTS]LOCSCR=1  : Endif
If !find([F:BTS]SERCOD,1,2,3)    INDIC=1 : [F:BTS]SERCOD=3    : Endif    : # Num série     (invisible)
If [F:BTS]SERCOD<>0  & [F:BTS]SERSCR=0 INDIC=1 : [F:BTS]SERSCR=1  : Endif
If !find([F:BTS]SERECOD,1,2)     INDIC=1 : [F:BTS]SERECOD=2   : Endif    : # Num série     (invisible)
If [F:BTS]SERECOD<>0 & [F:BTS]SERESCR=0 INDIC=1 : [F:BTS]SERESCR=1  : Endif
If !find([F:BTS]MVTDESCOD,1,2,3) INDIC=1 : [F:BTS]MVTDESCOD=3 : Endif    : # Dési.mvt      (invisible)
If [F:BTS]MVTDESCOD<>0  & [F:BTS]MVTDESSCR=0 INDIC=1 : [F:BTS]MVTDESSCR=1  : Endif
#   Bloc détail
If [F:BTS]UOMSAIFLG1=0 [F:BTS]UOMSAIFLG1=1 : Endif                       : # Saisie UC     (non)
If !find([F:BTS]IDECOD1,1,2,3)     INDIC=1 : [F:BTS]IDECOD1=3 : Endif    : # Identifiant 1 (invisible)
If [F:BTS]IDECOD1<>0  & [F:BTS]IDESCR1=0 INDIC=1 : [F:BTS]IDESCR1=1  : Endif
If !find([F:BTS]IDECOD2,1,2,3)     INDIC=1 : [F:BTS]IDECOD2=3 : Endif    : # Identifiant 2 (invisible)
If [F:BTS]IDECOD2<>0  & [F:BTS]IDESCR2=0 INDIC=1 : [F:BTS]IDESCR2=1  : Endif
If !find([F:BTS]PRNCOD1,1,2,3,4,5) INDIC=1 : [F:BTS]PRNCOD1=1 : Endif    : # Impression    (pas impre)
If [F:BTS]PRNSCR1=0   INDIC=1 : [F:BTS]PRNSCR1=1  : Endif
If [F:BTS]PRNNBFLG1=0 INDIC=1 : [F:BTS]PRNNBFLG1=1 : Endif               : # Nbr document  (non)
If [F:BTS]PRNNBFLG1<>0 & [F:BTS]PRNNBSCR1=0 INDIC=1 : [F:BTS]PRNNBSCR1=1 : Endif
If !find([F:BTS]SERECOD1,1,2)      INDIC=1 : [F:BTS]SERECOD1=2 : Endif   : # Num série     (invisible)
If [F:BTS]SERECOD1<>0 & [F:BTS]SERESCR1=0 INDIC=1 : [F:BTS]SERESCR1=1  : Endif
If !find([F:BTS]MVTDESCOD1,1,2,3)  INDIC=1 : [F:BTS]MVTDESCOD1=3 : Endif : # Dési.mvt     (invisible)
If !find([F:BTS]AVSTOCOD1,1,2)     INDIC=1 : [F:BTS]AVSTOCOD1=2  : Endif : # Stock dispo  (invisible)
If [F:BTS]AVSTOCOD1<>0 & [F:BTS]AVSTOSCR1=0 INDIC=1 : [F:BTS]AVSTOSCR1=1  : Endif
If !find([F:BTS]SPERFLG,1,2)       INDIC=1 : [F:BTS]SPERFLG=2  : Endif   : # Péremption   (oui)
If !find([F:BTS]SPOTFLG,1,2)       INDIC=1 : [F:BTS]SPOTFLG=2  : Endif   : # Titre        (oui)
If !find([F:BTS]SRUB1FLG,1,2)      INDIC=1 : [F:BTS]SRUB1FLG=1 : Endif   : # Rub 1        (non)
If !find([F:BTS]SRUB2FLG,1,2)      INDIC=1 : [F:BTS]SRUB2FLG=1 : Endif   : # Rub 2        (non)
If !find([F:BTS]SRUB3FLG,1,2)      INDIC=1 : [F:BTS]SRUB3FLG=1 : Endif   : # Rub 3        (non)
If !find([F:BTS]SRUB4FLG,1,2)      INDIC=1 : [F:BTS]SRUB4FLG=1 : Endif   : # Rub 4        (non)

If !find([F:BTS]CCECODS,1,2,3)  INDIC=1 : [F:BTS]CCECODS = 1    : Endif

Return

#########################################################################
#  STKPARMRP : mise à jour  table  PARMRP
#########################################################################
Subprog STKPARMRP

If filinfo(filpath("FIL","PARMRP","fde",[F:ADS]DOSSIER),0) < 0  : End : Endif

Local File =[F:ADS]DOSSIER+".PARMRP"       [PCB]

Trbegin [PCB]
For [PCB]
    GOK = 1  
    #Readlock [PCB]PCB0 Curr  # FGR 12/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat
    #    Call ECR_TRACE("File PARMRP, Error ="-num$(fstat),1) From GESECRAN
    #Else
        #------------------- MRP
        If !find([F:PCB]RPLTYP(0),1,2,3,4)
            [F:PCB]RPLTYP(0)       = 1
            If dim([F:PCB]MRPWOFRPL) > 0 & dim([F:PCB]MRPWOFLTI) > 0
                [F:PCB]RPLMOD(0)       = [F:PCB]MRPWOFRPL
                [F:PCB]RPLBWDLTI(0)    = [F:PCB]MRPWOFLTI
                [F:PCB]RPLFRWLTI(0)    = int([F:PCB]MRPWOFLTI / 4)
                If [F:PCB]MRPWOFRPL > 1
                    [F:PCB]RPLUPDQTY(0)    = 4
                    [F:PCB]RPLUPDDAT(0)    = 4
                Else
                    [F:PCB]RPLUPDQTY(0)    = 1
                    [F:PCB]RPLUPDDAT(0)    = 1
                Endif
            Else
                [F:PCB]RPLUPDQTY(0)    = 1
                [F:PCB]RPLUPDDAT(0)    = 1
            Endif
        Endif
        If !find([F:PCB]RPLTYP(1),1,2,3,4)
            [F:PCB]RPLTYP(1)       = 2
            If dim([F:PCB]MRPWOPRPL) > 0 & dim([F:PCB]MRPWOPLTI) > 0
                [F:PCB]RPLMOD(1)       = [F:PCB]MRPWOPRPL
                [F:PCB]RPLBWDLTI(1)    = [F:PCB]MRPWOPLTI
                [F:PCB]RPLFRWLTI(1)    = int([F:PCB]MRPWOPLTI / 4)
                If [F:PCB]MRPWOPRPL > 1
                    [F:PCB]RPLUPDQTY(1)    = 4
                    [F:PCB]RPLUPDDAT(1)    = 4
                Else
                    [F:PCB]RPLUPDQTY(1)    = 1
                    [F:PCB]RPLUPDDAT(1)    = 1
                Endif
            Else
                [F:PCB]RPLUPDQTY(1)    = 1
                [F:PCB]RPLUPDDAT(1)    = 1
            Endif
        Endif
        If !find([F:PCB]RPLTYP(2),1,2,3,4)
            [F:PCB]RPLTYP(2)       = 3
            If dim([F:PCB]MRPPOFRPL) > 0 & dim([F:PCB]MRPPOFLTI) > 0
                [F:PCB]RPLMOD(2)       = [F:PCB]MRPPOFRPL
                [F:PCB]RPLBWDLTI(2)    = [F:PCB]MRPPOFLTI
                [F:PCB]RPLFRWLTI(2)    = int([F:PCB]MRPPOFLTI / 4)
                If [F:PCB]MRPPOFRPL > 1
                    [F:PCB]RPLUPDQTY(2)    = 4
                    [F:PCB]RPLUPDDAT(2)    = 4
                Else
                    [F:PCB]RPLUPDQTY(2)    = 1
                    [F:PCB]RPLUPDDAT(2)    = 1
                Endif
            Else
                [F:PCB]RPLUPDQTY(2)    = 1
                [F:PCB]RPLUPDDAT(2)    = 1
            Endif
        Endif
        If !find([F:PCB]RPLTYP(3),1,2,3,4)
            [F:PCB]RPLTYP(3)       = 4
            If dim([F:PCB]MRPPOPRPL) > 0 & dim([F:PCB]MRPPOPLTI) > 0
                [F:PCB]RPLMOD(3)       = [F:PCB]MRPPOPRPL
                [F:PCB]RPLBWDLTI(3)    = [F:PCB]MRPPOPLTI
                [F:PCB]RPLFRWLTI(3)    = int([F:PCB]MRPPOPLTI / 4)
                If [F:PCB]MRPPOPRPL > 1
                    [F:PCB]RPLUPDQTY(3)    = 4
                    [F:PCB]RPLUPDDAT(3)    = 4
                Else
                    [F:PCB]RPLUPDQTY(3)    = 1
                    [F:PCB]RPLUPDDAT(3)    = 1
                Endif
            Else
                [F:PCB]RPLUPDQTY(3)    = 4
                [F:PCB]RPLUPDDAT(3)    = 4
            Endif
        Endif               
        If !find([F:PCB]WIPPRO,1,2,3)   : [F:PCB]WIPPRO = 1 : Endif
        If !find([F:PCB]RESBLWLOT,1,2)  : [F:PCB]RESBLWLOT = 1 : Endif
        If !find([F:PCB]REOPOLDIS,1,2,3): [F:PCB]REOPOLDIS = 1 : Endif
        #------------------- MPS
        If !find([F:PCB]RPLTYPS(0),1,2,3,4)
            If dim([F:PCB]MPSWOFRPL) > 0 & dim([F:PCB]MPSWOFLTI) > 0
                [F:PCB]RPLTYPS(0)       = 1
                [F:PCB]RPLMODS(0)       = [F:PCB]MPSWOFRPL
                [F:PCB]RPLBWDLTIS(0)    = [F:PCB]MPSWOFLTI
                [F:PCB]RPLFRWLTIS(0)    = int([F:PCB]MPSWOFLTI / 4)
                If [F:PCB]MPSWOFRPL > 1
                    [F:PCB]RPLUPDQTYS(0)    = 4
                    [F:PCB]RPLUPDDATS(0)    = 4
                Else
                    [F:PCB]RPLUPDQTYS(0)    = 1
                    [F:PCB]RPLUPDDATS(0)    = 1
                Endif
            Else
                [F:PCB]RPLUPDQTYS(0)    = 1
                [F:PCB]RPLUPDDATS(0)    = 1
            Endif
        Endif
        If !find([F:PCB]RPLTYPS(1),1,2,3,4)
            [F:PCB]RPLTYPS(1)       = 2
            If dim([F:PCB]MPSWOPRPL) > 0 & dim([F:PCB]MPSWOPLTI) > 0
                [F:PCB]RPLMODS(1)       = [F:PCB]MPSWOPRPL
                [F:PCB]RPLBWDLTIS(1)    = [F:PCB]MPSWOPLTI
                [F:PCB]RPLFRWLTIS(1)    = int([F:PCB]MPSWOPLTI / 4)
                If [F:PCB]MPSWOPRPL > 1
                    [F:PCB]RPLUPDQTYS(1)    = 4
                    [F:PCB]RPLUPDDATS(1)    = 4
                Else
                    [F:PCB]RPLUPDQTYS(1)    = 1
                    [F:PCB]RPLUPDDATS(1)    = 1
                Endif
            Else
                [F:PCB]RPLUPDQTYS(1)    = 1
                [F:PCB]RPLUPDDATS(1)    = 1
            Endif
        Endif
        If !find([F:PCB]RPLTYPS(2),1,2,3,4)
            [F:PCB]RPLTYPS(2)       = 3
            If dim([F:PCB]MPSPOFRPL) > 0 & dim([F:PCB]MPSPOFLTI) > 0
                [F:PCB]RPLMODS(2)       = [F:PCB]MPSPOFRPL
                [F:PCB]RPLBWDLTIS(2)    = [F:PCB]MPSPOFLTI
                [F:PCB]RPLFRWLTIS(2)    = int([F:PCB]MPSPOFLTI / 4)
                If [F:PCB]MPSPOFRPL > 1
                    [F:PCB]RPLUPDQTYS(2)    = 4
                    [F:PCB]RPLUPDDATS(2)    = 4
                Else
                    [F:PCB]RPLUPDQTYS(2)    = 1
                    [F:PCB]RPLUPDDATS(2)    = 1
                Endif
            Else
                [F:PCB]RPLUPDQTYS(2)    = 1
                [F:PCB]RPLUPDDATS(2)    = 1
            Endif
        Endif
        If !find([F:PCB]RPLTYPS(3),1,2,3,4)
            [F:PCB]RPLTYPS(3)       = 4
            If dim([F:PCB]MPSPOPRPL) > 0 & dim([F:PCB]MPSPOPLTI) > 0
                [F:PCB]RPLMODS(3)       = [F:PCB]MPSPOPRPL
                [F:PCB]RPLBWDLTIS(3)    = [F:PCB]MPSPOPLTI
                [F:PCB]RPLFRWLTIS(3)    = int([F:PCB]MPSPOPLTI / 4)
                If [F:PCB]MPSPOPRPL > 1
                    [F:PCB]RPLUPDQTYS(3)    = 4
                    [F:PCB]RPLUPDDATS(3)    = 4
                Else
                    [F:PCB]RPLUPDQTYS(3)    = 1
                    [F:PCB]RPLUPDDATS(3)    = 1
                Endif
            Else
                [F:PCB]RPLUPDQTYS(3)    = 1
                [F:PCB]RPLUPDDATS(3)    = 1
            Endif
        Endif                   
        If !find([F:PCB]WIPPROS,1,2,3)   : [F:PCB]WIPPROS = 1 : Endif
        If !find([F:PCB]RESBLWLOTS,1,2)  : [F:PCB]RESBLWLOTS = 1 : Endif
        If !find([F:PCB]REOPOLDISS,1,2,3): [F:PCB]REOPOLDISS = 1 : Endif
        Rewrite [PCB]        
    #Endif
Next

Commit
Close Local File [PCB]
End
