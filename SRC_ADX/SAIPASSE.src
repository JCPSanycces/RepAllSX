#<AdxTL>@(#)5.0.0.0 $Revision$
Call PASSE
Infbox num$(mkstat)
End

#-----------------------------------#
Subprog PASSE
Local Integer OK
Local Char TIT(30)
If !GSERVEUR
 Call TITAWI("SAIPASSE",TIT) From OBJDIV
 Call DIALWIN(OK,TIT,"SAIPASSE") From GESECRAN
 If OK<>2 : mkstat = 1 : Endif
Endif
End

#-----------------------------------#
Subprog C_PASSE(VALEUR)
Variable Char    VALEUR()
Local Char    MOTPASSE(24)
Local Integer OK
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
Read [AUS]CODUSR = GUSER
MOTPASSE = VALEUR
Call CTLPAS(MOTPASSE,OK) From GESUSER
If !OK
 GMESSAGE = mess(25,100,1) : # Mot de passe incorrect
 mkstat  = 2 : End
Endif
End

Subprog AV_USER(VALEUR)
Variable Char     VALEUR
VALEUR = GUSER
End
