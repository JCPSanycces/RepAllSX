#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################################
# UUMGPRETRC04                                         Module Common Data  #
#                Pre-migration of Open item                                #
#                                                                          #
# Management of Addresses : BPAPAY Field                                   #
#                                                                          #
############################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPRETRC04") From LECFIC
  Endif

  Call MAJ_UUMGPRETRC04(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

###################################################################################
Subprog MAJ_UUMGPRETRC04(DOSSIER)
Value Char DOSSIER
Local Integer ERR

If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif
If [F:ADS]MODULE(8)<>2 : End : Endif

Local Integer EXE_SQL : EXE_SQL = 1

Call ECR_TIME("UUMGPRETRC04 Open items Process : Update GACCDUDATE") From DOSSUB
Call ECR_TRACE("UUMGPRETRC04 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- n°version
Local Char VERSION
Call VERSION (DOSSIER,VERSION) From DOSSUB
If val(VERSION)=0
  Call ECR_TRACE("UUMGPRETRC04 : Error on release number : "+VERSION,0) From GESECRAN
  End
Endif
Gosub DEF_VERSIONSX3 From TRTMIGTABX3
#


# Version V6
If val(VERSION)<GMIGX3VER60

 If EXE_SQL

  #--------------- Field Addition  ----------#
  Call MIGINDCRE (DOSSIER,"GACCDUDATE","","BPAPAY","A",5,ERR) From TRTMIG
  If ERR : Goto FIN : Endif

  Gosub TRT_SQL

 Else

  #--------------- Field & Index Addition  ----------#
  Call MIGINDCRE (DOSSIER,"GACCDUDATE","BPR+NUMDUD","BPAPAY","A",5,ERR) From TRTMIG
  If ERR : Goto FIN : Endif

  Gosub TRT_X3

  #--------------- Deleting an index ----------#
  Call MIGINDDEL (DOSSIER,"GACCDUDATE",ERR) From TRTMIG
  If ERR : Goto FIN : Endif

 Endif
Endif


$FIN
Call ECR_TIME("UUMGPRETRC04 Open items Process END.")  From DOSSUB
End


###################################################################################
$TRT_SQL

#--------------- Opening of files  ----------#
If clalev([F:DUD]) : Close File [DUD] : Endif
If clalev([F:DUD])  = 0 : Local File =DOSSIER+".GACCDUDATE"  [DUD]  : Endif    # Open item


Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [DUD]
GOK = 1

Gosub TRT_SQL1
Gosub TRT_SQL2
Gosub TRT_SQL3
Gosub TRT_SQL4
Gosub TRT_SQL5

If GOK<1
 Rollback
Else
 Commit
Endif

Gosub UNSET_FIRST From TRTFIRST
Close Local File [DUD]

Return

###################################################################################
$TRT_X3
Local Integer NBLUS, NBCOMMIT


#--------------- Opening of files  ----------#
If clalev([F:DUD]) : Close File [DUD] : Endif
If clalev([F:DUD])  = 0 : Local File =DOSSIER+".GACCDUDATE"  [DUD]  : Endif    # Open item

If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif    # BP
If clalev([F:BPC])  = 0 : Local File =DOSSIER+".BPCUSTOMER"  [BPC]  : Endif    # Customer
If clalev([F:BPS])  = 0 : Local File =DOSSIER+".BPSUPPLIER"  [BPS]  : Endif    # Supplier

#-----  Declaration of Variables
# Variables to Handle Loops Ruptures
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1, ACLE2

Raz NBLUS, NBCOMMIT, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Filter [DUD] Order By Key CLE=[F:DUD]BPAPAY;[F:DUD]BPR;[F:DUD]NUMDUD

$LOOP_TRC04
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:DUD]BPAPAY='' & [F:DUD]BPR=ACLE1 & [F:DUD]NUMDUD>ACLE2"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:DUD]BPAPAY='' & [F:DUD]BPR>ACLE1"
Else
 CRITERE = "[F:DUD]BPAPAY='' & 1=1"
Endif

Trbegin [DUD]
GOK = 1

For [DUD]CLE Where evalue(CRITERE)

 NBLUS+=1

 #--- New field assignation
 Gosub RECUP_BPR

 Rewrite [F:DUD]
 If fstat
  Call ECR_TRACE("File GACCDUDATE(NUMDUD)"-[F:DUD]NUMDUD+", Error ="-num$(fstat),1) From GESECRAN
  GOK=0 : Break
 Endif

 NB+=1
 If NB>GMAXUPDTRS
  ACLE1 = [F:DUD]BPR
  ACLE2 = [F:DUD]NUMDUD
  STOP=1
  Break
 Endif
Next

If GOK<1
 Rollback
Else
 Commit
 If STOP
  Goto LOOP_TRC04
 Endif
Endif


Filter [DUD]
Gosub UNSET_FIRST From TRTFIRST
Close Local File [DUD]

Call ECR_TIME("UUMGPRETRC04 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
Return

##############################################################################################
$RECUP_BPR

If [F:DUD]BPAPAY=""
 If [F:DUD]BPRTYP=1 # Customer
  If [F:BPC]BPCNUM<>[F:DUD]BPR
   Read [BPC]BPC0=[F:DUD]BPR : If fstat Raz [F:BPC] Endif
  Endif
  If [F:DUD]BPRPAY=[F:BPC]BPCPYR # same Pay-by / Tiers Payeur identique
   If dim([F:BPC]BPAPYR)>0 & [F:BPC]BPAPYR<>""
    [F:DUD]BPAPAY=[F:BPC]BPAPYR
   Else
    If [F:BPC]BPCPYR<>""
     If [F:BPR]BPRNUM<>[F:BPC]BPCPYR
      Read [BPR]BPR0=[F:BPC]BPCPYR : If fstat Raz [F:BPR] Endif
     Endif
     [F:DUD]BPAPAY=[F:BPR]BPAADD
    Endif
   Endif
  Endif
 Elsif [F:DUD]BPRTYP=2 # Suppliers
  If [F:BPS]BPSNUM<>[F:DUD]BPR
   Read [BPS]BPS0=[F:DUD]BPR : If fstat Raz [F:BPS] Endif
  Endif
  If [F:DUD]BPRPAY=[F:BPS]BPRPAY # same Pay-by / Tiers Payeur identique
   If dim([F:BPS]BPAPAY)>0 & [F:BPS]BPAPAY<>""
    [F:DUD]BPAPAY=[F:BPS]BPAPAY
   Else
    If [F:BPS]BPRPAY<>""
     If [F:BPR]BPRNUM<>[F:BPS]BPRPAY
      Read [BPR]BPR0=[F:BPS]BPRPAY : If fstat Raz [F:BPR] Endif
     Endif
     [F:DUD]BPAPAY=[F:BPR]BPAADD
    Endif
   Endif
  Endif
 Endif
Endif

# Still not initialization => Bpartner
If [F:DUD]BPAPAY=""
 If [BPR]BPRNUM<>[F:DUD]BPRPAY
  Read [BPR]BPR0=[F:DUD]BPRPAY : If fstat Raz [F:BPR] Endif
 Endif
 [F:DUD]BPAPAY=[F:BPR]BPAADD
Endif
Return


###################################################################################################
$TRT_SQL1
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".GACCDUDATE SET BPAPAY_0="
REQSQL(1)="COALESCE((SELECT BPR.BPAADD_0 FROM"-DOSSIER+".BPARTNER BPR,"-DOSSIER+".BPCUSTOMER BPC WHERE BPC.BPCPYR_0=BPR.BPRNUM_0 AND BPC.BPCNUM_0=GACCDUDATE.BPR_0),' ')"
REQSQL(2)=" WHERE BPRTYP_0=1 AND EXISTS (SELECT 'X' FROM"-DOSSIER+".BPCUSTOMER BPC WHERE BPC.BPCNUM_0=GACCDUDATE.BPR_0 AND GACCDUDATE.BPRPAY_0=BPC.BPCPYR_0) AND BPAPAY_0=' ' "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

###################################################################################################
$TRT_SQL2
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".GACCDUDATE SET BPAPAY_0="
REQSQL(1)="COALESCE((SELECT BPR.BPAADD_0 FROM"-DOSSIER+".BPARTNER BPR WHERE BPR.BPRNUM_0=GACCDUDATE.BPRPAY_0),' ')"
REQSQL(2)=" WHERE BPRTYP_0=1 AND NOT EXISTS (SELECT 'X' FROM"-DOSSIER+".BPCUSTOMER BPC WHERE BPC.BPCNUM_0=GACCDUDATE.BPR_0 AND GACCDUDATE.BPRPAY_0=BPC.BPCPYR_0) AND BPAPAY_0=' ' "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

###################################################################################################
$TRT_SQL3
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".GACCDUDATE SET BPAPAY_0="
REQSQL(1)="COALESCE((SELECT BPR.BPAADD_0 FROM"-DOSSIER+".BPARTNER BPR,"-DOSSIER+".BPSUPPLIER BPS WHERE BPS.BPRPAY_0=BPR.BPRNUM_0 AND BPS.BPSNUM_0=GACCDUDATE.BPR_0),' ')"
REQSQL(2)=" WHERE BPRTYP_0=2 AND EXISTS (SELECT 'X' FROM"-DOSSIER+".BPSUPPLIER BPS WHERE BPS.BPSNUM_0=GACCDUDATE.BPR_0 AND GACCDUDATE.BPRPAY_0=BPS.BPRPAY_0) AND BPAPAY_0=' ' "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

###################################################################################################
$TRT_SQL4
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".GACCDUDATE SET BPAPAY_0="
REQSQL(1)="COALESCE((SELECT BPR.BPAADD_0 FROM"-DOSSIER+".BPARTNER BPR WHERE BPR.BPRNUM_0=GACCDUDATE.BPRPAY_0),' ')"
REQSQL(2)=" WHERE BPRTYP_0=2 AND NOT EXISTS (SELECT 'X' FROM"-DOSSIER+".BPSUPPLIER BPS WHERE BPS.BPSNUM_0=GACCDUDATE.BPR_0 AND GACCDUDATE.BPRPAY_0=BPS.BPRPAY_0) AND BPAPAY_0=' ' "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

###################################################################################################
$TRT_SQL5
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".GACCDUDATE SET BPAPAY_0="
REQSQL(1)="COALESCE((SELECT BPR.BPAADD_0 FROM"-DOSSIER+".BPARTNER BPR WHERE BPR.BPRNUM_0=GACCDUDATE.BPRPAY_0),' ')"
REQSQL(2)=" WHERE BPAPAY_0=' ' "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GOK=0
Resume

