# Classe FISCALYEAR

###############
# CLASS FINALXFLD
###############
$ACTION
Case ACTION
When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
When Default
Case CURPRO
    When ""         : Gosub METHODS    : # If CURPRO is empty, we are on class methods
    When Default    : Gosub PROPERTIES : # Otherwise it is an event called on properties
Endcase
Endcase
Return


###############
# EVENTS
###############
$AQUERY_TRANS_AFTER
If this.PER.PEREND<>AVOID.ADATE
  this.FIYENDYEA = year(this.PER.PEREND)
Endif
Return

###############
# METHODS
###############
$METHODS
Return

#############
# PROPERTIES
#############
$PROPERTIES
Case CURPRO

Endcase
Return
