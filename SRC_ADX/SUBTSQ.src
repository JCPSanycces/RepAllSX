End
########################################################################
# SUBTSQ                                                 Février 2015  #
#    TYPES DE DEVIS VENTES                              X3SUIVI104383  #
########################################################################
$ACTION
  Case ACTION
    When "OUVRE"         : Gosub OUVRE
    When "AFFMASK"       : Gosub AFFMASK
    When "RAZCRE"        : Gosub RAZCRE
    When "INICRE"        : Gosub INICRE
    When "INIMOD"        : Gosub INICRE
    When "ANNULE"        : Gosub ANNULE
    When "AP_CHANGE"     : Gosub AP_CHANGE
    When "LIENS"         : Gosub LIENS
    When "FERME"         : Gosub FERME
    When "SEL_TABLE"
      Case TABLE
        When "SELTSQ"    : Gosub SELTSQ
      Endcase
    When "CHGCOD"        : Gosub CHGCOD
    When "SETBOUT"       : Gosub SETBOUT
    When Default
  Endcase
Return

######################################################################################
$OUVRE
  #-----------------------------------#
  # Sauvegarde des variables globales #
  #-----------------------------------#
  Gosub SAUV_GLOB From TRTX3GLOB
  #--Lors d'un tunnel depuis un document
  Raz GCURFCY  #--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
  Raz GSOCIETE #--Ici pas de contexte et on veut éviter le filtrage des groupes de societes
Return

######################################################################################
$INICRE
  Gosub MAJ_ATEXTRA

  Gosub CONTROLE_COHERENCE # Issue 110351 - 2015-08-14 by CPO : Contrôle global de cohérence avant enregistrement

Return

######################################################################################
$MAJ_ATEXTRA
  If GREP = "D" Then
    ## En duplication, on veut récupérer tous les intitulés traduisibles...
    Call DUPTEXTRA("TABSQHTYP", "DESAXX", CLECUR1, "", "TABSQHTYP", "SHOAXX", [F:TSQ]SQHTYP, [F:TSQ]LEG)  From ATEXTRA
    Call DUPTEXTRA("TABSQHTYP", "SHOAXX", CLECUR1, "", "TABSQHTYP", "SHOAXX", [F:TSQ]SQHTYP, [F:TSQ]LEG)  From ATEXTRA
  Endif
  #--- Creation / Modif de ATEXTRA
  Call MAJTEXTRA([M:TSQ1]DESAXX, "TABSQHTYP", "DESAXX", [M:TSQ1]SQHTYP, [M:TSQ1]LEG) From ATEXTRA
  Call MAJTEXTRA([M:TSQ1]SHOAXX, "TABSQHTYP", "SHOAXX", [M:TSQ1]SQHTYP, [M:TSQ1]LEG) From ATEXTRA
Return

######################################################################################
$AFFMASK
  Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
  Gosub GRILEG
Return

######################################################################################
$CHGCOD
  Call CHGCOD(ABREV, CLECUR1, CLECUR2, OK) From CHGCLELEG
Return

######################################################################################
$RAZCRE
  Gosub GRILEG
Return

######################################################################################
$LIENS
  GCURLEG = [F:TSQ]LEG
  If GNBLEG = 1 Then
    GCURLEG = GDOSLEG
  Endif
  GGRPFCY = [F:TSQ]GFY
Return

######################################################################################
$SETBOUT
  If CLECUR = 0 | GREP <> "" Then
    Call VIREBOUT(CHAINE,"1") From GOBJET
  Endif
Return

######################################################################################
$GRILEG
  If func AFNC.ACTIV("LEG") = 0 Then
    # Dossier mono-législation
    Diszo [M:TSQ1]LEG
    [M:TSQ1]LEG = GDOSLEG(1)
    Affzo [M:TSQ1]LEG
    If dim([M:TSQ1]ZLEG) > 0 Then
      Affzo [TSQ1]ZLEG
    Endif
  Endif
Return

######################################################################################
$ANNULE
  Delete [AXX] Where CODFIC="TABSQHTYP" & IDENT1=[F:TSQ]SQHTYP & IDENT2=[F:TSQ]LEG
Return

######################################################################################
$FERME
  #------------------------------------#
  # Restitution des variables globales #
  #------------------------------------#
  Gosub REST_GLOB From TRTX3GLOB
  # To manage the button Tunnel
  If TUNNEL <> 1 Then
    Return
  Endif
  If dim(VCOD) < 1 Then
    Global Char VCOD(GLONTSQ)
  Endif
  VCOD = CLE2
Return

######################################################################################
$AP_CHANGE
  Call CHGTEXTRA("TABSQHTYP", "DESAXX", [L]OCODE, SUPP, [L]NCODE, SUPP) From ATEXTRA
  Call CHGTEXTRA("TABSQHTYP", "SHOAXX", [L]OCODE, SUPP, [L]NCODE, SUPP) From ATEXTRA
Return

######################################################################################
#    Détail des actions sur champs                                                   #
######################################################################################
######################################################################################
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()

GCURLEG = VALEUR

#Issue X3-85504 - 2018-04-12 by VAVIL : Sequence number control
If func AFNC.ACTIV("KPO")>0 & find(VALEUR,"POR","")
  Local Char WMESS(100) : WMESS = ""
  Call CTL_CODNUM_LEG(VALEUR,[M:TSQ1]SQHTYP,"TSQ",WMESS)    From PORLEGLIB
  If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
Endif
# Issue End

End

######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
End

######################################################################################
Subprog C_GFY(VALEUR)
Variable Char    VALEUR()

  GGRPFCY = VALEUR
End

######################################################################################
Subprog AM_GFY(VALEUR)
Variable Char    VALEUR()

  GGRPFCY = VALEUR
End

######################################################################################
Subprog C_CODNUM(VALEUR)
Variable Char    VALEUR()

  If [F:ANM]CODNUM <> VALEUR
    Read [ANM]ANM0=VALEUR
    If fstat Raz [F:ANM] Endif
  Endif
#  # Contrôle de la cohérence de la législation entre le type de devis et le compteur
## SAM 121563 JUCON 20/02/2017) wrong control by legislation
#  If [F:ANM]LEG <> "" & [F:ANM]LEG <> [M:TSQ1]LEG Then
#    GMESSAGE = mess(184,100,1) - VALEUR - mess(74,127,1) - "("
#    If [M:TSQ1]LEG <> ""
#      GMESSAGE += [F:ANM]LEG - "<>" - [M:TSQ1]LEG + ")"
#    Else
#      GMESSAGE += [F:ANM]LEG - "<>" - mess(91,187,1) + ")"
#    Endif
#    mkstat = 1
#    End
#  Endif
  If sum([F:ANM]POSLNG(0..dim([F:ANM]POSLNG)-1)) > GLONVCR Then
    GERR = 1
    GMESSAGE = mess(223,199,1)
    mkstat = 1
    End
  Endif

#Issue X3-85504 - 2018-04-12 by VAVIL : Sequence number control
If VALEUR<>''
  If func AFNC.ACTIV("KPO")>0 & find([M:TSQ1]LEG,"POR","")
    Local Char WMESS(100) : WMESS = ""
    Call CTL_CODNUM_FINAL(VALEUR,[M:TSQ1]LEG,[M:TSQ1]SQHTYP,"TSQ",WMESS) From PORLEGLIB
    If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
  Endif
Endif
# Issue End

End

######################################################################################
##  Copie                                                                            #
######################################################################################
$TRTCOP
  If [M]DOSORG = nomap Then
    Local File TABSQHTYP [TSQ1]
    Local File ATEXTRA   [AXX1]
  Else
    Local File =[M]DOSORG+".TABSQHTYP" [TSQ1]
    Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
  Endif
  If [M]DOSDES = nomap Then
    Local File TABSQHTYP [TSQ2]
    Local File ATEXTRA   [AXX2]
    Local File ACTIV     [ACV2]
  Else
    Local File =[M]DOSDES+".TABSQHTYP" [TSQ2]
    Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
    Local File =[M]DOSDES+".ATABDIV"   [ADI2]
    Local File =[M]DOSDES+".ACTIV"     [ACV2]
    Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2]
  Endif
  Gosub OUVDOS From ATEXTRA
  # -----------------------
  Call DEBTRANS From GLOCK
  Gosub TR_COP
  # -----------------------
  Close Local File [TSQ1], [TSQ2]
  Close Local File [AXX1], [AXX2]
  If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
  If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
  If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
  If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif
Return

######################################################################################
$TR_COP
  #--------------------------------------------------#
  # Transaction de copie d'un type de devis          #
  #--------------------------------------------------#
Local Char LEGDES(type(TABLE2)-10)
Local Integer WMONOLEGDES
Local Char SZDOSSIER(GLONADS)
Local Integer LG
Local Integer ILIG

  # Par défaut : Leg destination=leg de l'enregistrement à copier
  LEGDES = TABLE2
  GOK = 1
  #
  If [M]DOSDES <> nomap Then
    # Le dossier destination est-il mono-leg ?
    If [F:ACV2]CODACT <> "LEG" Then
      Read [ACV2]CODACT="LEG"
      If fstat Raz [F:ACV2] : Endif
    Endif
    If [F:ACV2]FLACT <> 2 Then
      WMONOLEGDES = 0
    Else
      WMONOLEGDES = 1
    Endif
    If WMONOLEGDES = 0 Then
      # Dossier destination mono-leg
      LG = instr(1,[M]DOSDES,"@")
      If LG = 0 Then
        SZDOSSIER = [M]DOSDES
      Else
        SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
      Endif
      Read [ADS2]DOSSIER=SZDOSSIER
      If fstat Then
        # Pb lecture dossier
        Call MESSAGE(SZDOSSIER - ":" - mess(78,133,1)) From GESECRAN  #-- Dossier inexistant --#
        Return
      Endif
      If [F:ADS2]DOSLEG(0) = "" Then
        # Pas de législation pour le dossier
        Call MESSAGE(SZDOSSIER - ":" - mess(241,133,1)) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
        Return
      Endif
      If TABLE2 <> [F:ADS2]DOSLEG(0) & TABLE2 <> '' Then
        # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
        # Pas de copie
        Call MESSAGE(mess(617,199,1) - "(" - [F:ADS2]DOSLEG(0) - ") :" - mess(618,199,1)) From GESECRAN
        Return
      Elsif TABLE2 = '' Then
        # La leg de l'enreg. à copier est toute leg
        # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
        LEGDES = [F:ADS2]DOSLEG(0)
      Endif
    Else
      # Dossier destination multi-leg
      If TABLE2 <> '' Then
        # Enregistrement à copier avec leg<>""
        Read [ADI2]CODE=909;TABLE2
        If fstat Then
          Call MESSAGE (TABLE2 - ':'- mess(173,187,1)) From GESECRAN : #-- Législation inexistante sur ce dossier --#
          Return
        Endif
        LG = instr(1, [M]DOSDES, "@")
        If LG = 0 Then
          SZDOSSIER = [M]DOSDES
        Else
          SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
        Endif
        Read [ADS2]DOSSIER=SZDOSSIER
        If !fstat Then
          If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
            Call MESSAGE(TABLE2 - ':' - mess(249,133,1)) From GESECRAN  #-- Législation non gérée par ce dossier --#
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
  #
  Read [TSQ2]TSQ0=TABLE;LEGDES
  If !fstat Then
# Issue X3-X3-58691 by MGO: Copy Sales Quote type function does not have override option  BEGIN
# WOK=2 the answer is YES; WOK=1 the answer is CANCEL
    Local Integer WOK : [L]WOK=1
    Call AVERTIR (mess(197,133,1), [L]WOK) From GESECRAN
    If [L]WOK=1 Return : Endif
# Issue X3-X3-58691 by MGO: Copy Sales Quote type function does not have override option  END
  Endif
  #--/vérifications
  Trbegin [TSQ2]
  Delete [TSQ2] Where SQHTYP=TABLE & LEG=LEGDES
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$" + [M]DOSDES+".TABSQHTYP" - TABLE
    Goto ROLL_TR_COP
  Elsif fstat Then
    GOK = 0
    Call RSTA("TSQ2", TABLE) From GLOCK
    Goto AB_TR_COP
  Endif
  For [TSQ1]TSQ0 Where SQHTYP=TABLE & LEG=TABLE2
    [F:TSQ2] = [F:TSQ1]
    [F:TSQ2]LEG = LEGDES
    If TABLE2 = LEGDES Then
      Call COPTEXTRA("TABSQHTYP", "DESAXX", TABLE, TABLE2) From ATEXTRA
      Call COPTEXTRA("TABSQHTYP", "SHOAXX", TABLE, TABLE2) From ATEXTRA
    Else
      Call COPTEXTRA1("TABSQHTYP", "DESAXX", TABLE, TABLE2, LEGDES) From TRTX3TEX
      Call COPTEXTRA1("TABSQHTYP", "SHOAXX", TABLE, TABLE2, LEGDES) From TRTX3TEX
    Endif
    If GOK = 0 Then
      Goto AB_TR_COP
    Elsif GOK < 0 Then
      Goto ROLL_TR_COP
    Endif
    If dim([F:TSQ2]UPDUSR) > 0 Then
      [F:TSQ2]UPDUSR = GUSER
    Endif
    If dim([F:TSQ2]UPDDAT) > 0 Then
      [F:TSQ2]UPDDAT = date$
    Endif
    Write [TSQ2]
    If fstat Then
      GOK = 0
      Call FSTA("TSQ2") From GLOCK
      Break
    Endif
  Next
  If   GOK < 0 Then
    Goto ROLL_TR_COP
  Elsif !GOK Then
    Goto AB_TR_COP
  Endif
  Commit
Return

######################################################################################
$AB_TR_COP
  Rollback
Return

######################################################################################
$ROLL_TR_COP
  Rollback
  Call ROLL From GLOCK
  If GROLL Then
    Return
  Else
    Goto TR_COP
  Endif
Return

######################################################################################
##  Actions / S/P                                                                    #
######################################################################################
Subprog VERF_PARAM(PPARAM, PVALEUR, POK)
Value Char PPARAM     # Nom du paramètre en cours de saisie
Value Char PVALEUR    # Valeur saisie à contrôler
Variable Integer POK  # 1 si contrôle satisfait, 0 si saisie incorrecte

  If PVALEUR = "" Then
    End
  Endif

Local Char FCY(GLONFCY)
Local Char SAVE_GCURFCY( GLONFCY)
Local Char CPY(GLONCPY)
Local Char SAVE_GSOCIETE(GLONCPY)
Local Char LEG(GLONADI)
Local Integer WNOL
Local Integer ERR

  Local File TABSQHTYP [TSQ]
  #-------------------------
  [L]SAVE_GCURFCY = GCURFCY
  [L]SAVE_GSOCIETE = GSOCIETE
  If GFONCTION = "ADPVAL" Then
    # Saisie valeurs paramètres. Type de données = PGT
    FCY = [M:ADWP]FCY
    GCURFCY = FCY
    CPY = [M:ADWP]CMP
    GSOCIETE = CPY
    If dim([M:ADWP]LEG) > 0 Then
      LEG = [M:ADWP]LEG
    Else
      LEG = GDOSLEG
    Endif
    WNOL = nolign-1
    #--Initialisation de législation
    If [L]LEG = "" Then
      If [L]FCY <> "" Then
        Call LEC_FCY([L]FCY) From CPTLEC
        Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
        GSOCIETE = [F:FCY]LEGCPY
        [L]LEG = [F:CPY]LEG
      Elsif [L]CPY <> "" Then
        Call LEC_CPY([L]CPY) From CPTLEC
        [L]LEG = [F:CPY]LEG
      Endif
    Endif
    If [L]LEG = "" Then
      [L]LEG = GCURLEG
    Endif
    Call CONTTSQ(PVALEUR, LEG, "MULTILEGADP", PPARAM, FCY, "", CPY)
    If mkstat Then
      POK = 0
    Endif
  Endif
  GCURFCY = [L]SAVE_GCURFCY
  GSOCIETE = [L]SAVE_GSOCIETE
End

######################################################################################
Subprog CONTTSQ(COD,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY)
Variable Char    COD()
Value    Char    LEG
Value    Char    CODMSK
Value    Char    CHAMPCOD
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

Local Integer CAS
Local Char OPTIONS(30)
  If GFONCTION = "GESTSQ" | COD="" Then
    End
  Endif
  If clalev([F:TSQ])  = 0 : Local File TABSQHTYP [TSQ] : Endif
  Local File AMSKZON   [AMZZ] #--for the selection options of the object
  Local File COMPANY   [CPY]
  Local File FACILITY  [FCY]
  Local File AGRPFCY   [AGF]
  Local File AGRPCPY   [AGC]
  #
  If func AFNC.ACTIV("LEG") = 0 Then
    LEG = GDOSLEG
  Elsif LEG = "" & GCURLEG <> "" Then
    #--GCURLEG online
    LEG = GCURLEG
  Endif
  #
  #--Legislation is empty
  CAS = 1
  #--Cas particulier : pas de GCURLEG mais société ou site en ligne
  If [L]LEG = "" and ([L]CPY <> "" | [L]FCY <> "") Then
    If [L]FCY <> "" Then
      Read [F:FCY]FCY0=[L]FCY
      If fstat : Raz [F:FCY] Endif
      If [L]CPY = "" Then
        [L]CPY = [F:FCY]LEGCPY
      Endif
    Endif
    If [F:CPY]CPY<>[L]CPY
      Read [F:CPY]CPY0=[L]CPY
      If fstat : Raz [F:CPY] Endif
    Endif
    [L]LEG = [F:CPY]LEG
  Endif
  #
  If [L]LEG <> "" Then
    Read [TSQ]TSQ0=[L]COD;[L]LEG
    If fstat Then
      Read [TSQ]TSQ0=[L]COD;""
    Else
      CAS = 2 : #--Legislation isn't empty
    Endif
  Else
    Read [TSQ]TSQ0(1)=[L]COD
    If !fstat Then
      [L]LEG = [F:TSQ]LEG
      CAS = 2
    Endif
  Endif
  If fstat Then
    Filter [TSQ] Where SQHTYP=[L]COD
    Look [TSQ]TSQ0 First
    If !fstat Then
      # "Fiche inexistante pour la législation courante"
      # "No existing record for the curent legislation"
      GMESSAGE = [L]COD - ":" - mess(232,107,1) - "[" + [L]LEG + "]"
    Else
      # "Fiche inexistante"
      # "Record does not exist"
      GMESSAGE = [L]COD - ":" - mess(23,100,1)
    Endif
    Filter [TSQ]
    mkstat = 2
    End
  Endif
  #
  #--Filtrage par groupe de société
  #--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
  #--Du fait du type de donné AGF sur le champ GFY de TABSQHTYP, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
  If [L]CPY <> "" and [L]FCY = "" Then
    If [F:TSQ]GFY <> "" Then
      Read [AGF]AGF0=[F:TSQ]GFY
      If !fstat Then
        If [F:AGF]FLGLEG = 2 Then
          #--Société
          If [F:TSQ]GFY <> [L]CPY Then
            GMESSAGE += COD + "\" + mess(63,127,1) - ":" - [F:TSQ]GFY : # Réservé au groupe de société
            mkstat = 2
            End
          Endif
        Elsif [F:AGF]FLGCPY = 2 Then
          Look [AGC]AGC0=[F:TSQ]GFY;[L]CPY
          If fstat Then
            GMESSAGE += COD + "\" + mess(63,127,1) - ":" - [F:TSQ]GFY : # Réservé au groupe de société
            mkstat = 2
            End
          Endif
        Endif
      Endif
    Endif
  Endif
  #
  #--Contrôle de cohérence entre le groupe du type de devis et la législation
  If [F:TSQ]GFY <> "" and [L]LEG <> "" Then
    Call CTLGFYLEG([F:TSQ]GFY, [L]LEG, "", "") From TRTVENCTL
    If mkstat Then
      End
    Endif
  Endif
  #--Contrôle de cohérence entre le groupe passé en paramètre et la législation du type de devis à contrôler
  If GROUPE <> "" and [F:TSQ]LEG <> "" Then
    Call CTLGFYLEG(GROUPE, [F:TSQ]LEG, "", "") From TRTVENCTL
    If mkstat Then
      End
    Endif
  Endif
  #--Contrôle de la cohérence entre le groupe passé en param et celui du type de devis courant
  #--uniquement si le groupe passé est renseigné
  #--uniquement si pas de contexte site ou société !
  #--Il faut que le groupe du type de devis et celui du paramétrage aient au moins une soc en commun
  If GROUPE <> "" Then
    If [L]CPY = "" & [L]FCY = "" & [F:TSQ]GFY <> "" & [F:TSQ]GFY <> GROUPE Then
      #--Les groupes doivent avoir au moins une société en commun
      Gosub CTLGFYGRP
      If mkstat Then
        End
      Endif
    Endif
  Endif
  #--On charge les options définies sur le type de données du champ du masque
  #--Findig Object options defined on the data type of the field in the screen
  OPTIONS = ""
  If CODMSK <> "" & CHAMPCOD <> "" Then
    Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
    If fstat=0 Then
      OPTIONS=[F:AMZZ]OPTOBJ
    Endif
  Endif
  If CAS = 2 Then
    Call CONTROLE("TSQ", OPTIONS, [L]LEG, [L]COD, mkstat) From CONTOBJ
  Else
    Call CONTROLE("TSQ", OPTIONS, "", [L]COD, mkstat) From CONTOBJ
  Endif

  # Issue 110351 - 2015-08-14 by CPO : Contrôle global de cohérence avant enregistrement
  #--Cohérence [TSQ]SOHTYP et paramètres
  If mkstat > 0 : End : Endif

	If [F:TSQ]SOHTYP<>""
  	If clalev([F:TSO])=0 : Local File TABSOHTYP [TSO] : Endif

  	Call CONTTSO([TSQ]SOHTYP,[L]LEG,"","",[L]FCY,GROUPE,[L]CPY) From SUBTSO
  	If mkstat
  		If [L]LEG=""
  			GMESSAGE = [L]COD-":"-mess(226,200,1)-GMESSAGE
  		Else
  			GMESSAGE = [L]COD-"["+[L]LEG+"]"-":"-mess(226,200,1)-GMESSAGE
  		Endif
  		End
  	Endif
	Endif
	# End issue 110351

End

######################################################################################
$CTLGFYGRP
Local Integer ERR
Local Char SZVIEW(GLONAVW)

  If [F:TSQ]LEG = "" Then
    #--------------------------------------------------------------------------------------------------
    ## Appel à la vue
    #--------------------------------------------------------------------------------------------------
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSQZGRP"
      Local File =SZVIEW [TSQZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, pas de contrôle
      Return
    Endif
    Read [F:TSQZ]TSQZ0=[L]GROUPE;[F:TSQ]SQHTYP;[F:TSQ]GFY;[F:TSQ]LEG
    If fstat Then
      GMESSAGE = mess(177,187,1) - ":" - [L]GROUPE - "-" - [F:TSQ]GFY - ":" - mess(178,187,1)
      mkstat = 1
      Return
    Endif
  Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSQYGRP"
      Local File =SZVIEW [TSQY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, pas de contrôle
      Return
    Endif
    Read [F:TSQY]TSQY0=[L]GROUPE;[F:TSQ]SQHTYP;[F:TSQ]GFY;[F:TSQ]LEG
    If fstat Then
      GMESSAGE = mess(177,187,1) - ":" - [L]GROUPE - "-" - [F:TSQ]GFY - ":" - mess(178,187,1)
      mkstat = 1
      Return
    Endif
  Endif
Return

######################################################################################
$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume

######################################################################################
#--------------------------------------------------------------------------------
#Called from Action "TUNTSQ"
#IMPORTANT : in order to pass here, one must set to "No"
#            the value in the Tunnel column for this field in the screen definition
#            il faut mettre à "Non" le tunnel dans la définition de l'écran pour ce champ
#--------------------------------------------------------------------------------
Subprog TUNTSQ(COD,LEG)
Variable Char    COD()
Value    Char    LEG

Local Integer TOKILL

  TOKILL = 0
  If dim(VCOD) < 1 Then
    Global Char VCOD(GLONTSQ)
    TOKILL = 1
  Endif
  Local File TABSQHTYP [TSQ]
  VCOD = COD
  If GNBLEG = 1 Then
    LEG = GDOSLEG
  Elsif LEG = "" & GCURLEG <> "" Then
    LEG = GCURLEG
  Elsif LEG = "" Then
    #--If LEG="" then firstly we search a TSQ record with LEG="" secondly a TSQ record with TSQ<>""
    Read [TSQ]TSQ0=VCOD;LEG
    If fstat Then
      Read [TSQ]TSQ0(1)=VCOD
      If !fstat Then
        LEG = [F:TSQ]LEG
      Endif
    Endif
  Endif
  Read [TSQ]TSQ0=COD;LEG
  If fstat Then
    LEG = ""
  Endif
  Call OBJET("TSQ", LEG, VCOD) From GOBJET
  COD = VCOD
  If TOKILL Then
    Kill VCOD
  Endif
End

######################################################################################
#--------------------------------------------------------------------------------
#--Called from ADPVAL fonction "Parameter values"
#--Also called from the SELTRE selection action (Throughout the SELTREA subprog)
#--------------------------------------------------------------------------------
$SELTSQ
Local Char FCY(GLONFCY)
Local Char CPY(GLONCPY)
Local Char LEG(GLONADI)
Local Char GRP(GLONAGF)
Local Integer WNOL
Local Integer ERR
Local Char SZVIEW(GLONAVW)
Local Char CODMSK (GLONAMK)
Local Char CHAMPCOD(GLONAVA)
Local Integer I
  If dim(OPTIONS) < 0 Then
    Local Char OPTIONS(30)
  Endif
  #
  If clalev([F:TSQ])=0  : Local File TABSQHTYP  [TSQ] : Endif
  If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
  If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
  If clalev([F:FGR])=0  : Local File FACGROUP   [FGR] : Endif
  If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX] : Endif
  If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif
  If clalev([F:AGF])=0  : Local File AGRPFCY    [AGF] : Endif
  #
  CODMSK = PARAM(6)
  CHAMPCOD = PARAM(7)
  #--On charge les options définies sur le type de données du champ du masque
  OPTIONS = ""
  If CODMSK <> "" & CHAMPCOD <> "" Then
    Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
    If fstat=0 Then
      OPTIONS = [F:AMZZ]OPTOBJ
    Endif
  Endif

  #--------------------------------------------------------------------------------------------------
  If GFONCTION = "GESTSQ" Then
#    # Si on est sur l'objet de paramétrage, pas de filtre on part sur la sélection standard
   OBJET = "TSQ"
   Return
  Endif

  #--------------------------------------------------------------------------------------------------
  # Identifying the parameters
  #--------------------------------------------------------------------------------------------------
  If GFONCTION = "ADPVAL" Then
    #--"Parameter values". Data type = ???
    FCY = [M:ADWP]FCY
    CPY = [M:ADWP]CMP
    If dim([M:ADWP]LEG) > 0 Then
      LEG = [M:ADWP]LEG
    Endif
    #--Sales Return categories from parameter's name
    WNOL = nolign-1
  Else
    LEG = PARAM(1)
    FCY = PARAM(2)
    GRP = PARAM(3)
    CPY = PARAM(4)
  Endif
  #--Init. of legislation
  If func AFNC.ACTIV("LEG") = 0 Then
    [L]LEG = GDOSLEG
  Endif
  #
  If [L]LEG = "" Then
    If [L]FCY <> "" Then
      Call LEC_FCY([L]FCY) From CPTLEC
      Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
      [L]LEG = [F:CPY]LEG
    Elsif [L]CPY <> "" Then
      Call LEC_CPY([L]CPY) From CPTLEC
      [L]LEG = [F:CPY]LEG
    Endif
  Endif
  If [L]LEG = "" Then
    [L]LEG = GCURLEG
  Endif
  #--------------------------------------------------------------------------------------------------
  ## Position and dimension of the window
  #--------------------------------------------------------------------------------------------------
  Gosub OUVRE_LISTE From WOTSQ
  For I = 1 To NBSEL
    If SELEXP(I) <> "" Then
      COL(I) = SELEXP(I)
    Else
      COL(I) = SELZON(I)
    Endif
    TIT(I)  = SELLIB(I)
    If left$(SELFMT(I),2) = "LA" Then
      COL(I) = "mess(" + COL(I) + "," + num$(val(right$(SELFMT(I),3))) + ",1)"
    Endif
  Next I
  NBCOL = NBSEL
  SIZCOL = 240
  SIZLIG = 100
  TIT(0) = mess(12,123,1)
  Call TITOBJ("TSQ", "", TIT(1)) From CONTOBJ
  TIT(0) -= TIT(1)
  START = "[F:TSQ]SQHTYP"
  ORDRE = "[F:TSQ]SQHTYP;[F:TSQ]LEG"
  OBJET = ""

  #--------------------------------------------------------------------------------------------------
  ## Standard selection criteria
  #--------------------------------------------------------------------------------------------------
  CRITERE(1) = '1=1'
  #--Groupe de soc/sites
  If [L]FCY = "" & [L]CPY = "" & [L]GRP <> "" Then
    #--Cas du groupe étant une société
    Read [F:AGF]AGF0=[L]GRP
    If !fstat Then
      If [F:AGF]FLGLEG=2 Then
        [L]CPY=[L]GRP
      Endif
    Endif
    #--Le filtrage sur les groupes sites/sociétés sont fait dans le link directement
  Endif
  If [L]FCY <> "" Then
    #--Facility
    CRITERE(1) -= '& ([F:TSQ]GFY="" | ([F:TSQ]GFY<>"" & [F:FGR]FCY="' + [L]FCY + '"))'
  Elsif [L]CPY <> "" Then
    #--Company
    #CRITERE(1) -= '& ([F:TSQ]GFY="" | ([F:TSQ]GFY<>"" & [F:TSQ]LEGCPY="' + [L]CPY + '"))'    # FGR 27/07/2015 : X3SUIVI109821
    CRITERE(1) -= '& ([F:TSQ]GFY="" | ([F:TSQ]GFY<>"" & [F:TSQ]LEG="' + [L]CPY + '"))'        # FGR 27/07/2015 : X3SUIVI109821
  Endif
  If [L]LEG <> "" Then
    #--Legislation
    CRITERE(2) -= '& ([F:TSQ]LEG="' + [L]LEG + '" | [F:TSQ]LEG="")'
  Endif
  #--First selection character
  If dim(SELCAR) > 0 & SELCAR <> 0 Then
    CRITERE(2) -= '& left$([F:TSQ]SQHTYP,' + num$(SELCAR)+')>="' + left$(VALEUR,SELCAR) + '"'
  Endif
  ICRITERE = 3

##MGG X3-38593 Row level permission
  #Call FILROLE(OBJET, FILROLE) From SUBARL
  Call FILROLE("TSQ", FILROLE) From SUBARL
##END MGG X3-38593 Row level permission
  If FILROLE <> "" & FILROLE <> "1=1" Then
    For I = 0 To dim(FILROLE)-1
      Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", FILROLE(I), "&") From GOBJSUB
    Next I
  Endif
  #--------------------------------------------------------------------------------------------------
  #--Views calls
  #--------------------------------------------------------------------------------------------------
  If ([L]CPY = "" and [L]FCY = "" and [L]GRP <> "") Then
    If [L]LEG <> "" Then
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTSQYGRP"
        Local File =SZVIEW [TSQY]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TSQ"
        Return
      Endif
    Else
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTSQZGRP"
        Local File =SZVIEW [TSQZ]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TSQ"
        Return
      Endif
    Endif
  Endif
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTSQCPY"
    Local File =SZVIEW [TSQC]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, on se déroute sur le select standard
    OBJET = "TSQ"
    Return
  Endif
  If [L]LEG <> "" Then
    #--------------------------------------------------------------------------------------------------
    ## Appel à la vue
    #--------------------------------------------------------------------------------------------------
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSQSEL"
      Local File =SZVIEW [TSQS]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TSQ"
      Return
    Endif
    If ([L]CPY = "" and [L]FCY = "" and [L]GRP <> "") Then
      Link [TSQ] With [F:AXX]AXX0    = "TABSQHTYP";"DESAXX";GLANGUE;[F:TSQ]SQHTYP;[F:TSQ]LEG,
&                     [F:TSQY]TSQY0 ~= [L]GRP;[F:TSQ]SQHTYP;[F:TSQ]GFY;[F:TSQ]LEG,
&                     [F:TSQS]TSQ0  ~= [F:TSQ]SQHTYP;[F:TSQ]LEG;[L]LEG
&                  As [LTSQ]
    Else
      Link [TSQ] With [F:AXX]AXX0    = "TABSQHTYP";"DESAXX";GLANGUE;[F:TSQ]SQHTYP;[F:TSQ]LEG,
&                     [F:FGR]FGR1    = [L]FCY;[F:TSQ]GFY,
&                     [F:TSQC]TSQ0   = [F:TSQ]SQHTYP;[F:TSQ]LEG;[F:TSQ]GFY;[L]CPY,
&                     [F:TSQS]TSQ0  ~= [F:TSQ]SQHTYP;[F:TSQ]LEG;[L]LEG
&                  As [LTSQ]
    Endif
  Else
    #--View without legislation
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSQPAR"
      Local File =SZVIEW [TSQP]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TSQ"
      Return
    Endif
    If ([L]CPY = "" and [L]FCY = "" and [L]GRP <> "") Then
      Link [TSQ] With [F:AXX]AXX0    = "TABSQHTYP";"DESAXX";GLANGUE;[F:TSQ]SQHTYP;[F:TSQ]LEG,
&                     [F:TSQY]TSQY0 ~= [L]GRP;[F:TSQ]SQHTYP;[F:TSQ]GFY;[F:TSQ]LEG
&                  As [LTSQ]
    Else
      Link [TSQ] With [F:AXX]AXX0    = "TABSQHTYP";"DESAXX";GLANGUE;[F:TSQ]SQHTYP;[F:TSQ]LEG,
&                     [F:FGR]FGR1    = [L]FCY;[F:TSQ]GFY,
&                     [F:TSQC]TSQ0   = [F:TSQ]SQHTYP;[F:TSQ]LEG;[F:TSQ]GFY;[L]CPY,
&                     [F:TSQP]TSQ0  ~= [F:TSQ]SQHTYP;[F:TSQ]LEG
&                  As [LTSQ]
    Endif
  Endif


  # Options de sélection
  If OPTIONS <> "" Then
    Gosub OPTIONS From WOTSQ
    ICRITERE = 2
    For I = 1 To NBCOND
      If instr(1,OPTIONS,OPT(I)) Then
        Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", "(" + CONDIT(I) + ")", "&") From GOBJSUB
      Endif
    Next I
  Endif
  Default File [LTSQ]
  DEFPAG = 1
Return
######################################################################################
# Issue 110351 - 2015-08-14 by CPO : Contrôle global de cohérence avant enregistrement
$CONTROLE_COHERENCE

  Local Integer WSTAT
  Local Char    WMESSA(250)
  Local Char  	WCODE
  Local Char    WLEG
  Local Char    WCTX_CPY
  Local Char    WCTX_FCY
  Local Char    WCTX_LEG

	WCODE=[M:TSQ1]SQHTYP
	WLEG =[M:TSQ1]LEG

  Call CTL_ML_CONSISTENCY("TSQ", "NON", WCODE, WLEG , WCTX_CPY, WCTX_FCY, WCTX_LEG, WSTAT, WMESSA) From TRTVENCTL
  If WSTAT>0 or WMESSA<>""
  	GMESSAGE = WMESSA : GOK=0 : GERR=1 #--Si on ne veux pas bloquer..GERR=2
  Endif

Return

$CHECK_CONSISTENCY
	Local Integer WRET

	If clalev([F:TSQ])=0 : Local File TABSQHTYP [TSQ] : Endif

  #--Vérification de la compatibilité des sous-données déclinées elles aussi

	#--  P_CODE<>"" and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

  #--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
  If P_LEG<>"" and PACTUAL_LEG<>"" and P_LEG<>PACTUAL_LEG
		VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-PACTUAL_LEG :# "Législations différentes"
		Return
	Endif

	#--Lecture du [F]
	#--Seulement si besoin
	#--De plus si on est dans GESTSO il ne faut pas relire car
	#--Si Création => pas dans la BD (mais comme appel depuis ACTION="INICRE" [F] est chargé
	#--Si Modification => idem
	If GFONCTION<>"GESTSQ"
  	#--Cohérence [TSQ]SQHTYP et paramètres
  	Call CONTTSQ(P_CODE,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTSQ
  	If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif
  #--CPO 96248 Lors du ttt de cette fiche => il ne faut plus appeler le sous-contrôles car appelés lors du CONT principal
  Else #Endif
    #--Cohérence [TSQ]SOHTYP et paramètres
    Call CONTTSO([TSQ]SOHTYP,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTSO
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=mess(226,200,1)-GMESSAGE : Raz GMESSAGE : Return : Endif
  Endif

Return
#-----------------------------------------------------------------------------------------
$FIND_CONTEXT
	Local Integer I,IJ
	Local Integer RET,I
	Local Integer CAS
	Local Char    LEGS(GLONADI)(1..)
	Local Integer COHERENCE_OK

	If clalev([F:TSQ])=0 : Local File TABSQHTYP [TSQ] : Endif
	If clalev([F:TSO])=0 : Local File TABSOHTYP [TSO] : Endif

  Local Instance GROUPES Using C_GRPCOLL

	#--On connait la détermination
	#--On cherche un contexte compatible
	#--Si pas de contexte compatible, alors la donnée multi-lég est mal paramétrée

	#-- P_CODE<>"" and (PACTUAL_CPY="" and PACTUAL_FCY=""and PACTUAL_LEG="")

	#--Lecture du [F]
	#--Seulement si besoin
	#--De plus si on est dans GESTSO il ne faut pas relire car
	#--Si Création => pas dans la BD (mais comme appel depuis ACTION="INICRE" [F] est chargé
	#--Si Modification => idem
	If GFONCTION<>"GESTSQ" and ( [F:TSQ]SQHTYP<>P_CODE | find([F:TSQ]LEG,P_LEG,"")=0 )
    If P_LEG<>""
     Read [TSQ]TSQ0=P_CODE;P_LEG
     If fstat
      Read [TSQ]TSQ0=P_CODE;""
     Else
      #CAS = 2 : # P_LEGislation isn't empty
     Endif
    Else
     Read [TSQ]TSQ0(1)=P_CODE
     If !fstat
      P_LEG = [F:TSQ]LEG
      #CAS = 2
     Endif
    Endif
    If fstat
     Filter [TSQ] Where SQHTYP=P_CODE
     Look [TSQ]TSQ0 First
     If !fstat
      # Fiche inexistante pour la législation courante
      VMESSAGE = P_CODE-":"-mess(232,107,1)-"["+P_LEG+"]"
     Else
      # Fiche inexistante
      VMESSAGE = P_CODE-":"-mess(23,100,1)
     Endif
     Filter [TSQ]
     VSTATUS=99 : Return
    Endif
	Endif

  #--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
  If P_LEG<>"" and [F:TSQ]LEG<>"" and P_LEG<>[F:TSQ]LEG
		VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-[F:TSQ]LEG :# "Législations différentes"
		Return
	Endif

  P_LEG=[F:TSQ]LEG
  LEGS(1)=P_LEG

  If P_LEG=""
		#--Le code retenu est toutes législations
		#--Il faut d'abord trouver une législation commune
		#--Puis pour cette législation, il faut déterminer une société commune aux groupes, sinon on renvoye ""
		I = 2

		If [F:TSQ]SOHTYP<>""
  		For [TSO] Where SOHTYP=[F:TSQ]SOHTYP
  			If [F:TSO]LEG<>"" and find([F:TSO]LEG,LEGS)=0
  				LEGS(I) = [F:TSO]LEG
  				I += 1
  			Endif
  		Next
		Endif

	Endif

	For I=1 To maxtab(LEGS)

  	#--Le code retenu contient une législation en particulier
  	#--Cette législation sera renvoyée
  	#--Reste à déterminer une société commune aux groupes, sinon on renvoye ""

  	#--On commence par lire les sous-données déclinées

  	#--Lecture du type de livraison
  	If [F:TSQ]SOHTYP<>""
    	Call LEC_TSO_LEG(LEGS(I),[F:TSQ]SOHTYP,RET) From TRTLECLEG
    	If RET
    		#--On passe à la lég suivante
  			Goto NEXT_LEGS
    	Endif
    Else
    	Raz [F:TSO]
    Endif

  	#--Il reste à trouver une société commune aux différents groupes
  	#--La société doit être de la législation retenue

		If [F:TSQ]GFY<>"" or [F:TSO]GFY<>""

      GROUPES = NewInstance [GRPTSQ] With C_GRPCOLL

      RET= fmet GROUPES.GROUPADD([F:TSQ]GFY)
      RET= fmet GROUPES.GROUPADD([F:TSO]GFY)

    	For IJ = 1 To maxtab(GROUPES.L_FCY)
      	If GROUPES.L_FCY(IJ)<>null and find(GROUPES.L_FCY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      	  If LEGS(I)="" | GROUPES.L_FCY(IJ).FCYCPYLEG = LEGS(I)

        		PACTUAL_FCY = GROUPES.L_FCY(IJ).FCY
        		PACTUAL_CPY = GROUPES.L_FCY(IJ).FCYCPY
        		PACTUAL_LEG = GROUPES.L_FCY(IJ).FCYCPYLEG

        		FreeInstance =GROUPES.AllocGrp

        		COHERENCE_OK = 1
        		Break 2

      		Endif
      	Endif
    	Next IJ

      #--On libère proprement...
      FreeInstance =GROUPES.AllocGrp

		Else
			#--On a trouvé une lég, et il n'y a pas de groupes
			#--C'est bon...
    	#--Les lectures ont abouti
    	#--On peut renvoyer le legs(i) comme législation du contexte
    	PACTUAL_LEG = LEGS(I)
    	COHERENCE_OK = 1
    	Break

		Endif

   	$NEXT_LEGS
	Next I

	#--On positionne le VSTATUS si rien trouvé
  If COHERENCE_OK <>1
  	VMESSAGE = mess(799,197,1)
  	VSTATUS  = 1 : Return
  Endif

Return
#-----------------------------------------------------------------------------------------
$FIND_CODE
	If clalev([F:TSQ])=0 : Local File TABSQHTYP [TSQ] : Endif
  #--On connait le contexte
  #--On cherche une détermination compatible

  #--  P_CODE=""  and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

	#--Filtre sur la législation ou "toutes législations"
  Filter [F:TSQ] Where find(LEG,"",PACTUAL_LEG)>0

	For [F:TSQ]

		Raz VSTATUS : Raz VMESSAGE

    #--Cohérence [TSQ]SQHTYP et paramètres
    Call CONTTSQ([TSQ]SQHTYP,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTSQ
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif

    #--CPO 96248 Lors du ttt de cette fiche => il ne faut plus appeler le sous-contrôles car appelés lors du CONT principal
    #  	If VSTATUS=0
    #      #--Cohérence [TSQ]SOHTYP et paramètres
    #      Call CONTTSQ([TSQ]SOHTYP,PACTUAL_LEG,"","",PACTUAL_FCY,"",(([F:TSQ]SOHCAT=2)+1),PACTUAL_CPY) From SUBTSO
    #      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=mess(226,200,1)-GMESSAGE : Raz GMESSAGE : Endif
    #  	Endif

    If VSTATUS=0
    	#--Le code trouvé est cohérent avec le contexte
    	P_CODE=[F:TSQ]SQHTYP
			P_LEG =[F:TSQ]LEG
			Break
		Endif

	Next

	Filter [F:TSQ]

	If VSTATUS>0 | P_CODE=""
		VMESSAGE = mess(798,197,1)-":"-mess(218,107,1)-PACTUAL_LEG+","-mess(2,45,1)-PACTUAL_CPY
	Endif

Return
# End issue 110351

