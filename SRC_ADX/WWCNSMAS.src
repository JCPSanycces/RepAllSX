Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(44885,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSMASSTD"
PROGSPE    = "CNSMASSPE"
CBOITE     = "DCNSMAS"
BOITE      = "FCNSMAS"
NOMMSK(0)  = "CONSMAS1"
ABMSK(0)   = "MAS1"
NOMMSK(1)  = "CONSMAS2"
ABMSK(1)   = "MAS2"
NOMMSK(2)  = "CONSMAS3"
ABMSK(2)   = "MAS3"
NOMMSK(3)  = "CONSMAS4"
ABMSK(3)   = "MAS4"
CMEMO      = "ctp"
CNOMMSK    = "CRITMAS"
CABMSK     = "CMAS"
NOMFIC     = "MSHISTO"
ABFIC      = "MHS"
MAGNETO    = 2
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..1), CLEMSK(10)(0..1)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = "MHS3"
NBCMP = 2
CLECMP(0) = "COD"
CLEMSK(0) = "COD"
CLECMP(1) = "DAT"
CLEMSK(1) = "DAT"
Return

$OUVRE
If clalev([F:MHS])=0 : Local File MSHISTO      [MHS] : Endif
If clalev([F:MHS])=0 : Local File MSHISTO      [MHS] : Endif
If clalev([F:MCH])=0 : Local File MSSCENAH     [MCH] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CMAS]
 When  0 : Local Mask =NOMMSK(0) [MAS1]
 When  1 : Local Mask =NOMMSK(1) [MAS2]
 When  2 : Local Mask =NOMMSK(2) [MAS3]
 When  3 : Local Mask =NOMMSK(3) [MAS4]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CMAS]
 When  0 : Grizo [MAS1]
 When  1 : Grizo [MAS2]
 When  2 : Grizo [MAS3]
 When  3 : Grizo [MAS4]
Endcase
Return

$GRISE_CLE
Case MA
 When -1 : If dim([M:CMAS]COD)>0 : Grizo [CMAS]COD : Endif
           If dim([M:CMAS]DAT)>0 : Grizo [CMAS]DAT : Endif
 When  0 : If dim([M:MAS1]COD)>0 : Grizo [MAS1]COD : Endif
           If dim([M:MAS1]DAT)>0 : Grizo [MAS1]DAT : Endif
Endcase
Return

$GRISE_CRIT
