Endif
If dim([M:CMAS]POT)>0
 Grizo [CMAS]POT
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CMAS])>0 : Close Local Mask [CMAS] : Endif
 When  0 : If clalev([M:MAS1])>0 : Close Local Mask [MAS1] : Endif
 When  1 : If clalev([M:MAS2])>0 : Close Local Mask [MAS2] : Endif
 When  2 : If clalev([M:MAS3])>0 : Close Local Mask [MAS3] : Endif
 When  3 : If clalev([M:MAS4])>0 : Close Local Mask [MAS4] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CMAS]
 When  0 : Default Mask [MAS1]
 When  1 : Default Mask [MAS2]
 When  2 : Default Mask [MAS3]
 When  3 : Default Mask [MAS4]
Endcase
Return

$RAZMASK
