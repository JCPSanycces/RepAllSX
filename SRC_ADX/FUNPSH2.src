#<AdxTL>@(#)4.0.0.0 $Revision$
###########################################################################
# FUNPSH2 :      Solde manuel des demandes d'achat         MBT 21/04/2010 #
# ----------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais une fonction                      #
# ----------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                  #
#   - TRTFUNPSH2 : Fonction de solde manuel des demandes d'achat          #
###########################################################################


$ACTION
#-----------------------------------------------------#
# Actions sur le traitement standard (GTRAITE)        #
# TRTFUNPSH2 : Fonction de solde des demandes d'achat #
#-----------------------------------------------------#
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
#----------------------------------------------------------------------#
# Actions sur la saisie fenêtre principale du traitement std (GSAISIE) #
# TRTFUNPSH2 : Gestion des reliquats (solde des demandes d'achat)      #
#----------------------------------------------------------------------#
 When "OUVRE"       : If [M:DIA]CRITERE<>"" Gosub OUVRE       : Endif
 When "TITRE"       : If  clalev([M:CLE1])  Gosub TITRE_FEN
                                       Else Gosub TITRE_INI   : Endif   # MH - 105537 v8 UI Text Review
 When "DEBUT"       : If  clalev([M:CLE1])  Gosub DEBUT
                                       Else Affzo [DIA]1-99
                                            Gosub GRISAGE     : Endif
 When "SETBOUT"     : If GHISTO
                        Diszo [DIA]1-99
                        Call VIREBOUT(CHBOU,"O")   From GOBJET
                        Call VIREBOUT(CHMEN,"MRE") From GOBJET
                      Endif
 When "BOUTON"      : If BOUT="R"  Gosub GRISAGE              : Endif
 When "OK"          : If  clalev([M:CLE1])  Gosub OK
                                     Else   GOK=1             : Endif
 When "END"         : If !clalev([M:CLE1])  GOK=0             : Endif
 When "ABA"         : If  clalev([M:CLE1])  Gosub ABA         : Endif
 When "APRES_MODIF" : If  clalev([M:CLE1])  Gosub APRES_MODIF : Endif
 When "FINSAI"      : If  clalev([M:CLE1])  Gosub FINSAI      : Endif
#-------------------------------------------------------#
# Actions sur la suite du traitement standard (GTRAITE) #
# TRTFUNPSH2 : Solde des lignes de demande d'achat      #
#-------------------------------------------------------#
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "SORTIE"      : Gosub SORTIE
Endcase
Return


###################################################################
# Actions sur le traitement standard (GTRAITE)                    #
# --------------------------------------------------------------- #
# TRTFUNPSH2 : Gestion des reliquats (solde des demandes d'achat) #
###################################################################

#-----------------------------------------------#
# Initialisations avant exécution du traitement #
#-----------------------------------------------#
$INIT
#----- Ouverture fichiers -----#
If !clalev([F:PSH])    Local File PREQUIS     [PSH] : Endif
If !clalev([F:PSD])    Local File PREQUISD    [PSD] : Endif
If !clalev([F:CAL])    Local File CPTANALIN   [CAL] : Endif
If !clalev([F:ORD])    Local File ORDERS      [ORD] : Endif
If !clalev([F:CPY])    Local File COMPANY     [CPY] : Endif
If !clalev([F:AUS])    Local File AUTILIS     [AUS] : Endif
If !clalev([F:TCO])    Local File TABCOEFF    [TCO] : Endif
If !clalev([F:BPR])    Local File BPARTNER    [BPR] : Endif
If !clalev([F:BPS])    Local File BPSUPPLIER  [BPS] : Endif
#----- Ouverture fichiers BUD, BUDPAR ...etc, si module Compta à "Oui" -----#
If GMODU(2)=2  : # Compta
  If !clalev([F:BUD])  Local File BUD         [BUD] : Endif
  If !clalev([F:BUP])  Local File BUDPAR      [BUP] : Endif
  If !clalev([F:BLA])  Local File BALANA      [BLA] : Endif
Endif
#-----
If !clalev([F:FCY])    Local File FACILITY    [FCY] : Endif
If !clalev([F:FIY])    Local File FISCALYEAR  [FIY] : Endif
If !clalev([F:PER])    Local File PERIOD      [PER] : Endif
If !clalev([F:TCU])    Local File TABCUR      [TCU] : Endif
If !clalev([F:TCH])    Local File TABCHANGE   [TCH] : Endif
#-----
Local Mask PSHCLEAR [DIA]
Raz [M:DIA]
[M:DIA]XFCYFLG = 2
[M:DIA]XUSRFLG = 1
[M:DIA]USR     = GUSER
[M:DIA]TRACE   = 2
#----- Titre de la fenêtre de saisie des critères -----#
TIT=mess(104,195,1)
#-----
Call LECMEMO("STD","[M:DIA]","pm1") From GMEMO
Return

#--------------------------------------------------------#
# Contrôle et traitement avant saisie fenêtre principale #
#--------------------------------------------------------#
$CONTROLE
If GOK<1  FIN=1 : Endif
#----- Constitution du filtre entête pour table PREQUIS -----#
[M:DIA]CRITERE = "CLEFLG<>2" : # On traite les DA non soldées !
#-----
If [M:DIA]XFCYFLG<>2
  [M:DIA]CRITERE -= '& PSHFCY="'+[M:DIA]FCY+'"'
Endif
#----- Attention c'est le demandeur et non l'utilisateur -----#
If [M:DIA]XUSRFLG<>2
  [M:DIA]CRITERE -= '& REQUSR="'+[M:DIA]USR+'"'
Endif
#-----
If [M:DIA]STRDAT<>[0/0/0]
  [M:DIA]CRITERE -= "& PRQDAT>=["+format$(GFMD,[M:DIA]STRDAT)+"]"
Endif
If [M:DIA]ENDDAT<>[0/0/0]
  [M:DIA]CRITERE -= "& PRQDAT<=["+format$(GFMD,[M:DIA]ENDDAT)+"]"
Endif
If [M:DIA]VCRDEB<>""
  [M:DIA]CRITERE -= '& PSHNUM>="'+[M:DIA]VCRDEB+'"'
Endif
If [M:DIA]VCRFIN<>""
  [M:DIA]CRITERE -= '& PSHNUM<="'+[M:DIA]VCRFIN+'"'
Endif
#----- Constitution du filtre ligne pour PREQUISD -----#
If [M:DIA]ARTDEB<>""
  [M:DIA]CRITLIG -= 'ITMREF>="'+[M:DIA]ARTDEB+'"'
Endif
If [M:DIA]ARTFIN<>""
  [M:DIA]CRITLIG -= '& ITMREF<="'+[M:DIA]ARTFIN+'"'
Endif
If [M:DIA]CRITLIG=""  [M:DIA]CRITLIG="1=1" : Endif
Return


########################################################################
# Actions sur la saisie fenêtre principale du traitement std (GSAISIE) #
# -------------------------------------------------------------------- #
# TRTFUNPSH2 : Gestion des reliquats (solde des demandes d'achat)      #
########################################################################

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE
Local Mask ORDK   [ORDK]
#-----
Local Char    CRITERE(250) : CRITERE=[M:DIA]CRITERE
Local Char    CRITLIG(250) : CRITLIG=[M:DIA]CRITLIG
#-----
Local Char    WMSG(80)
Local Integer WNBR, WMSGFLG, WRET
Local Char    WPSHNUM(GLONPSH)
Local Integer I
#-----
Return

#########################################
# Initial title for the criteria screen #
#########################################

# MH - 105537 UI Text Review
$TITRE_INI
Call TEXTE (54202, TIT) From OBJDIV   #Pur. request manual close
Return
#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_FEN
TIT=mess(104,195,1)-tolower(mess(10,16,1))    #MH - 10537 v8 UI Text Review
#TIT=mess(36,198,1)-mess(104,195,1)
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEBUT
Local Decimal WQTE, WAMT
Local Char    WCPY   (GLONCPY)
Local Char    WBUDCOA(GLONCOA)
Local Char    WENVDIE(GLONDIE)
Local Char    WENTDIE(GLONDIE)
Local Libelle WTYPLEDGEN
Local Libelle WTYPLEDANA
Local Decimal WFIY
#-----
Raz [M:CLE1]
nolign=1
Call TEMPON("R") From GESECRAN
For [PSH] Where evalue(CRITERE) With Nohint
  #----- Vérifier que le site est sur une société autorisée -----#
  If [M:DIA]XCPYFLG=1 & [M:DIA]XFCYFLG=2
    If [F:FCY]FCY<>[F:PSH]PSHFCY
      Read [FCY] FCY0=[F:PSH]PSHFCY : If fstat  Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY<>[M:DIA]CPY  Goto SUIT : Endif
  Endif
  #----- Il ne faut proposer que les sites auxquels l'utilisateur a droit -----#
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    If !find(([F:PSH]PSHFCY),GUSRFCY(1..GNBAUZ))  Goto SUIT : Endif
  Endif
  #-----
  For [PSD] PSD0 Where PSHNUM=[F:PSH]PSHNUM & LINCLEFLG<>2 & evalue(CRITLIG)
    [M:CLE1]PRO(nolign-1)         = 1
    [M:CLE1]PSHFCY(nolign-1)      = [F:PSD]PSHFCY
    [M:CLE1]PSHNUM(nolign-1)      = [F:PSD]PSHNUM
    [M:CLE1]PSDLIN(nolign-1)      = [F:PSD]PSDLIN
    [M:CLE1]REQUSR(nolign-1)      = [F:PSH]REQUSR
    [M:CLE1]ITMREF(nolign-1)      = [F:PSD]ITMREF
    [M:CLE1]BPSNUM(nolign-1)      = [F:PSD]BPSNUM
    [M:CLE1]LINAPPFLG(nolign-1)   = [F:PSD]LINAPPFLG
    [M:CLE1]LINORDFLG(nolign-1)   = [F:PSD]LINORDFLG
    [M:CLE1]LINCLEFLG(nolign-1)   = [F:PSD]LINCLEFLG
    [M:CLE1]QTYPUU(nolign-1)      = [F:PSD]QTYPUU
    [M:CLE1]ORDQTYPUU(nolign-1)   = [F:PSD]ORDQTYPUU
    [M:CLE1]PUU(nolign-1)         = [F:PSD]PUU
    [M:CLE1]LINAMT(nolign-1)      = [F:PSD]LINAMT
    [M:CLE1]CMMPRPNUM(nolign-1)   = [F:PSD]CMMPRPNUM
    #----- Calcul du reliquat d'engagement -----#
    If [F:PSD]LINCLEFLG<>2 & [F:PSD]QTYPUU<>0
      WQTE=[F:PSD]QTYPUU-min([F:PSD]QTYPUU,[F:PSD]ORDQTYPUU)
      WAMT=[F:PSD]LINAMT*WQTE/[F:PSD]QTYPUU
      Call ARRDEV(WAMT,[F:PSD]CUR) From TRTDIV
      [M:CLE1]AMT(nolign-1)       = WAMT
    Else
      [M:CLE1]AMT(nolign-1)       = 0
    Endif
    #-----
    [M:CLE1]CUR(nolign-1)         = [F:PSD]CUR
    #----- Enveloppe, entité et compte budgétaire -----#
    Read [CAL] CAL0="PSD";0;[F:PSD]PSHNUM;[F:PSD]PSDLIN;0;"";1
    If !fstat
      If WCPY<>[F:PSD]CPY
        Call SETMAINREF([F:PSD]CPY,WTYPLEDGEN,WTYPLEDANA)     From CPTDIV
        Call GETEXE([F:PSD]CPY,WTYPLEDANA,[F:PSH]PRQDAT,WFIY) From CPTSUB
        Call RECH_BUDOPE([F:PSD]CPY,WBUDCOA,WENVDIE,WENTDIE)  From TRTX3CPT
        WCPY=[F:PSD]CPY
      Endif
      [M:CLE1]FIY(nolign-1)=WFIY
      If WBUDCOA<>""
        [M:CLE1]BUDCOA(nolign-1)=WBUDCOA
        I=find(WBUDCOA,[F:CAL]COA)
        If I  [M:CLE1]BUDACC(nolign-1)=[F:CAL]ACC(I-1) : Endif
      Endif
      If WENVDIE<>""
        [M:CLE1]ENVDIE(nolign-1)=WENVDIE
        I=find(WENVDIE,[F:CAL]DIE)
        If I  [M:CLE1]ENVCCE(nolign-1)=[F:CAL]CCE(I-1) : Endif
      Endif
      If WENTDIE<>""
        [M:CLE1]ENTDIE(nolign-1)=WENTDIE
        I=find(WENTDIE,[F:CAL]DIE)
        If I  [M:CLE1]ENTCCE(nolign-1)=[F:CAL]CCE(I-1) : Endif
      Endif
    Endif
    #-----
    nolign += 1
# Issue 76621 - 2011-11-18 by MUARN : Dimensionnement solde des demandes achats
#    If nolign>=dim([M:CLE1]PRO)
#      GMESSAGE=mess(26,100,1) : GERR=2 : nolign-=1 : Break
    If nolign>dim([M:CLE1]PRO)
      GMESSAGE=mess(26,100,1) : GERR=2 : Break 2
    Endif
# fin 76621
  Next
$SUIT
Next
Call TEMPOFF From GESECRAN
[M:CLE1]NBLIG = nolign-1
If [M:CLE1]NBLIG=0
  GMESSAGE=mess(99,100,1) : GERR=1 : FIN=1
Endif
Affzo [CLE1]1-99
Return

#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK
Call TEMPON("E") From GESECRAN
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
If [M:DIA]TRACE=2
  #----- Ouverture fichier trace et écriture des sélections -----#
  Call OUVRE_TRACE(mess(104,195,1))    From LECFIC
  Call ECR_TRACE(" ",0)                From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0)    From GESECRAN
  Call PRTSCR("PSHCLEAR","DIA","",0,1) From ATRTX3
  Call ECR_TRACE(string$(70,"-"),0)    From GESECRAN
  Call ECR_TRACE(" ",0)                From GESECRAN
  WMSGFLG=3
Else
  WMSGFLG=0
Endif
Sorta [M:CLE1]NBLIG [M:CLE1]NBLIG Order By [M:CLE1]PSHNUM(indice),
&                                          [M:CLE1]PSDLIN(indice)
Raz WNBR, WPSHNUM, GFCY
Call DEBTRANS From GLOCK
$TR_SOLDE
GOK=1
Trbegin [PSD],[PSH],[ORD]
  For I=0 To [M:CLE1]NBLIG-1
    If [M:CLE1]PRO(I)=2
      Call TRTPSDCLE([M:CLE1]PSHNUM(I),[M:CLE1]PSDLIN(I),WMSGFLG,WRET) From TRTACHDIV1
      If WRET=12
        GOK=1
      Elsif GOK<1
        Break
      Else
        WNBR+=1
        If [M:DIA]TRACE=2
          WMSG=mess(222,197,1)-[M:CLE1]PSHNUM(I)-num$([M:CLE1]PSDLIN(I))-mess(282,197,1)
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
      Endif
    Endif
  Next I
  If GOK=-1 Goto ROLL_SOLDE : Endif
  If GOK= 0 Goto AB_SOLDE   : Endif
Commit
Goto FIN_SOLDE
#----- Nouvel essai de transaction ou abandon suivant GROLL -----#
$ROLL_SOLDE
Rollback : Call ROLL From GLOCK
If GROLL
  Goto FIN_SOLDE
Else
  Goto TR_SOLDE
Endif
#----- Abandon de la transaction -----#
$AB_SOLDE
Rollback
#----- Fin de traitement du OK -----#
$FIN_SOLDE
If [M:DIA]TRACE=2 & WNBR=0
  Call ECR_TRACE(mess(8,107,1),0) From GESECRAN : # Aucune pièce à traiter !
Endif
FIN=1
#----- Restitution des variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
Call TEMPOFF From GESECRAN
Return

#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA
Raz REP
For I=0 To [M:CLE1]NBLIG-1
  [M:CLE1]PRO(I)=1
Next I
Affzo [CLE1]1-99
Return

#------------------------------------#
# Après chaque modification de champ #
#------------------------------------#
$APRES_MODIF
REP="M"
Return

#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI
Return


########################################################################
# Suite des actions sur le traitement standard (GTRAITE)               #
# -------------------------------------------------------------------- #
# TRTFUNCLE  : Gestion des reliquats (solde ou annulation de solde)    #
########################################################################

#-------------------------#
# Exécution du traitement #
#-------------------------#
$EXEC
Return

#-----------------------------------#
# Fin après exécution du traitement #
#-----------------------------------#
$TERMINE
If [M:DIA]TRACE=2
  Call FERME_TRACE From LECFIC
  TRA=1
Else
  TRA=0
Endif
FIN=1
Return

#----------------------#
# Sortie du traitement #
#----------------------#
$SORTIE
Return


#######################################################
# Traitement du grisage et dégrisage des champs écran #
#######################################################
$GRISAGE
If [M:DIA]XCPYFLG=2 Diszo [DIA]CPY, XFCYFLG Else Actzo [DIA]CPY, XFCYFLG : Endif
If [M:DIA]XFCYFLG=2 Diszo [DIA]FCY          Else Actzo [DIA]FCY          : Endif
If [M:DIA]XUSRFLG=2 Diszo [DIA]USR          Else Actzo [DIA]USR          : Endif
Return


#########################################################
# Sous-Programmes des actions sur champ de l'écran CLE1 #
#########################################################

Subprog C_NBLIG
#------------------------------#
# Contrôle sur numéro de ligne #
#------------------------------#
If status=7  End : Endif

# Issue 76621 - 2011-11-18 by MUARN : dimensionnement pour soldes des demandes d'achat
If nolign > dim([M:CLE1]PRO)
  nolign -=1
Endif
# fin 76621

If status>4 & [M:CLE1]PSHNUM(nolign-1)=""
  mkstat=1 : End
Endif
End

Subprog IB_NBLIG
#----------------------------------------------------#
# Activation boutons "Détail" et "Traitement global" #
#----------------------------------------------------#
Raz GBOUT7, GBOUT8, GBOUT9, GBOUT10
GBOUT1=mess(65,198,1)  : # Détail
GBOUT2=mess(95,198,1)  : # Traitement global
If [M:CLE1]ENVCCE(nolign-1)<>""
  GBOUT7=mess(491,198,1)-[M:CLE1]ENVCCE(nolign-1) : # Enveloppe XXXXX
  GBOUT8=mess(494,198,1)                          : # Ligne budgétaire
Endif
If [M:CLE1]BUDACC(nolign-1)<>""
  GBOUT9=mess(493,198,1)-[M:CLE1]BUDACC(nolign-1) : # Compte XXXXXXXX
Endif
If [M:CLE1]CMMPRPNUM(nolign-1)<>""
  GBOUT10=mess(327,198,1)-[M:CLE1]CMMPRPNUM(nolign-1) : # Pré-engagement XXXXX
Endif
End

Subprog B2_NBLIG
#------------------------------#
# Bouton 2 : Traitement global #
#------------------------------#
Local Shortint I
For I=0 To [M:CLE1]NBLIG-1
  If [M:CLE1]LINCLEFLG(I)<2 [M:CLE1]PRO(I)=2 Else [M:CLE1]PRO(I)=1 : Endif
Next I
Affzo [CLE1]1-99
mkstat=4
End

Subprog B3_NBLIG
#-----------------#
# Tri par demande #
#-----------------#
Sorta [M:CLE1]NBLIG [M:CLE1]NBLIG Order By [M:CLE1]PSHNUM(indice),
&                                          [M:CLE1]PSDLIN(indice)
Affzo [CLE1]1-99
End

Subprog B4_NBLIG
#-------------------#
# Tri par enveloppe #
#-------------------#
Sorta [M:CLE1]NBLIG [M:CLE1]NBLIG Order By [M:CLE1]ENVCCE(indice),
&                                          [M:CLE1]PSHNUM(indice),
&                                          [M:CLE1]PSDLIN(indice)
Affzo [CLE1]1-99
End

Subprog B5_NBLIG
#----------------#
# Tri par entité #
#----------------#
Sorta [M:CLE1]NBLIG [M:CLE1]NBLIG Order By [M:CLE1]ENTCCE(indice),
&                                          [M:CLE1]PSHNUM(indice),
&                                          [M:CLE1]PSDLIN(indice)
Affzo [CLE1]1-99
End

Subprog B6_NBLIG
#---------------------------#
# Tri par compte budgétaire #
#---------------------------#
Sorta [M:CLE1]NBLIG [M:CLE1]NBLIG Order By [M:CLE1]BUDACC(indice),
&                                          [M:CLE1]PSHNUM(indice),
&                                          [M:CLE1]PSDLIN(indice)
Affzo [CLE1]1-99
End

Subprog IB_PRO
#---------------------------------------#
# Init bouton sur champ code traitement #
#---------------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8, GBOUT9, GBOUT10
GBOUT1=mess(65,198,1) : # Détail
End

Subprog C_PRO(VALEUR)
#--------------------------#
# Contrôle code traitement #
#--------------------------#
Variable Integer VALEUR
Local Shortint NOL : NOL=nolign-1
If VALEUR=2 & [M:CLE1]LINCLEFLG(NOL)=2
  GMESSAGE=mess(168,194,1) : mkstat=1 : VALEUR=1 : End : # Ligne déja soldée, ...
Endif
If VALEUR=3 & [M:CLE1]LINCLEFLG(NOL)=1
  GMESSAGE=mess(169,194,1) : mkstat=1 : VALEUR=1 : End : # Ligne non soldée, ...
Endif
End

Subprog AM_PRO(VALEUR)
#------------------------------------#
# Après modification code traitement #
#------------------------------------#
Variable Integer VALEUR
End

