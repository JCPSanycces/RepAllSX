#<AdxTL>@(#)8.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Initialisation champ LEG Société dans les dossiers mono
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update LEG in COMPANY & FACILITY Tables for mono legislation folders") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJCPY
End

#-------------------#
$MAJCPY

If DOSSIER=GDOSX3
 Return
Endif

Local Integer MONO , UPD

Local File ADOSSIER [ADS_U] , ADOSACT [ADA_U]
Read [ADS_U]DOSSIER = [L]DOSSIER
Read [ADA_U]ADA0 = [L]DOSSIER;"LEG"
If fstat or [F:ADA_U]FLACT<>2
 MONO = 1
Endif
If !MONO : Goto FIN : Endif

# Mise à jour de la table COMPANY & FACILITY

Call ECR_TRACE(mess(81,125,1)-"COMPANY & FACILITY :"-time$,0) From GESECRAN

Local File =DOSSIER+".COMPANY" [CPY] , =DOSSIER+".FACILITY" [FCY]

Trbegin [CPY]

 For [CPY]
  UPD = 0
  If [F:CPY]CPYLEGFLG<>2
   If [F:CPY]LEG<>""
    [F:CPY]LEG = ""
    UPD = 1
   Endif
  Elsif [F:CPY]LEG=""
   [F:CPY]LEG = [F:ADS_U]DOSLEG
   UPD = 1
  Endif
  If UPD
   Rewrite [CPY]
   If fstat
    Call ERREUR("COMPANY"-[F:CPY]CPY,2) From DOSDIC
   Endif
  Endif
  Update [FCY] Where LEGCPY=[F:CPY]CPY & LEG<>[F:CPY]LEG With LEG=[F:CPY]LEG
 Next CPY

Commit

#-----------------------#
$FIN

Close Local File

Return

