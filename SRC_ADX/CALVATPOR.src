#<AdxTL>@(#)5.0.0.0 $Revision$
####################################################################################
####################################################################################
$ACTION

Case ACTION
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "SORTIE"      : Gosub SORTIE
  When "SEL_LISTE"   : Gosub SEL_LISTE
  When "FIN_LISTE"   : Gosub FIN_LISTE
  When "SEL_TABLE"   : Gosub SEL_TABLE
  When "FIN_TABLE"   : Gosub FIN_TABLE
Endcase

Return
####################################################################################
####################################################################################
$CONTROLE

If val(PARAM(1)) = 0 | PARAM(2) = "" | PARAM(3) = "" | val(PARAM(4)) = 0 | val(PARAM(5)) = 0
  FIN      = 1
  GERR     = 1
  GMESSAGE = mess(9,135,1)
Endif

Return
####################################################################################
####################################################################################
$EXEC

Gosub OPEN_TABLES

Gosub DECLARE_VAR

Gosub SET_CONTEXT

Call OUVRE_TRACE(mess([L]DCLTYP,2643,1)) From LECFIC

Call ECR_TRACE  (mess(2443,200,1) + ":" - mess([L]DCLTYP,2643,1), 0)   From GESECRAN
Call ECR_TRACE  (mess(1,3614,1)   + ":" - [L]DCLNUM,              0)   From GESECRAN
Call ECR_TRACE  (mess(2,45,1)     + ":" - [L]CPY,                 0)   From GESECRAN
Call ECR_TRACE  (mess(1,366,1)    + ":" - [L]STRDAT,              0)   From GESECRAN
Call ECR_TRACE  (mess(3,138,1)    + ":" - [L]ENDDAT,              0)   From GESECRAN

If [L]OK
  Gosub MAIN
Endif

Call LEC_TRACE                           From LECFIC
Call FERME_TRACE                         From LECFIC

Return
####################################################################################
####################################################################################
$SORTIE

If dim ([L]CALVATTRTNAM) > 0
  If [L]CALVATTRTNAM <> ""
    Gosub KILL_CONTEXT From =[L]CALVATTRTNAM
  Endif
Endif

Return
####################################################################################
####################################################################################
$OPEN_TABLES

If !clalev([F:BAL])   : Local File BALANCE     [BAL]   : Endif
If !clalev([F:BPC])   : Local File BPCUSTOMER  [BPC]   : Endif
If !clalev([F:BPR])   : Local File BPARTNER    [BPR]   : Endif
If !clalev([F:BPS])   : Local File BPSUPPLIER  [BPS]   : Endif
If !clalev([F:CPY])   : Local File COMPANY     [CPY]   : Endif
If !clalev([F:DAE2])  : Local File GACCENTRYD  [DAE2]  : Endif
If !clalev([F:DAEP])  : Local File GACCENTRYD  [DAEP]  : Endif
If !clalev([F:DAER])  : Local File GACCENTRYD  [DAER]  : Endif
If !clalev([F:DVPB])  : Local File DCLVATPORB  [DVPB]  : Endif
If !clalev([F:DVPB2]) : Local File DCLVATPORB  [DVPB2] : Endif
If !clalev([F:DVPH2]) : Local File DCLVATPORH  [DVPH2] : Endif
If !clalev([F:DVPP])  : Local File DCLVATPORP  [DVPP]  : Endif
If !clalev([F:DVPT])  : Local File DCLVATPORT  [DVPT]  : Endif
If !clalev([F:GAC2])  : Local File GACCOUNT    [GAC2]  : Endif
If !clalev([F:GACP])  : Local File GACCOUNT    [GACP]  : Endif
If !clalev([F:GACR])  : Local File GACCOUNT    [GACR]  : Endif
If !clalev([F:GCM])   : Local File GACM        [GCM]   : Endif
If !clalev([F:GTE])   : Local File GTYPACCENT  [GTE]   : Endif
If !clalev([F:HAE])   : Local File GACCENTRY   [HAE]   : Endif
If !clalev([F:JOU])   : Local File GJOURNAL    [JOU]   : Endif
If !clalev([F:LED])   : Local File GLED        [LED]   : Endif
If !clalev([F:PER])   : Local File PERIOD      [PER]   : Endif
If !clalev([F:PIH])   : Local File PINVOICE    [PIH]   : Endif
If !clalev([F:PYH])   : Local File PAYMENTH    [PYH]   : Endif
If !clalev([F:SID2])  : Local File SINVOICED   [SID2]  : Endif
If !clalev([F:SIH])   : Local File SINVOICE    [SIH]   : Endif
If !clalev([F:SIH2])  : Local File SINVOICE    [SIH2]  : Endif
If !clalev([F:SIV])   : Local File SINVOICEV   [SIV]   : Endif
If !clalev([F:TCY])   : Local File TABCOUNTRY  [TCY]   : Endif
If !clalev([F:TRA])   : Local File TABRATVAT   [TRA]   : Endif
If !clalev([F:TVT])   : Local File TABVAT      [TVT]   : Endif
If !clalev([F:TVB])   : Local File TABVACBPR   [TVB]   : Endif

Return
####################################################################################
####################################################################################
$DECLARE_VAR

#-- parameter related variables
Local Char     CPY(GLONCPY)
Local Integer  DCLTYP
Local Date     STRDAT
Local Date     ENDDAT

#-- other declaration related variables
Local Char     LED(GLONLED)
Local Char     COA(GLONCOA)
Local Char     BPRNUM(GLONBPR)
Local Char     EECNUM(GLONEEC)
Local Char     DCLFLD(3)
Local Char     BPRVCR(GLONVCR)
Local Char     PFX(2)
Local Integer  DCLPAG
Local Integer  RECTYP
Local Integer  LINTYP
Local Integer  OPETYP
Local Decimal  AMTVAT
Local Decimal  MINVAL    #backward compatibility for annual and international. periodic is using below variables
Local Decimal  MINLINVAL #minimum value for an aneex line to be consider. Below limit we can exclude line
Local Decimal  MAXANEVAL #maximum value for all excluded lines. All exclusions cannot go above this limit
Local Decimal  CURANEVAL #current value for excluded lines on the annex (lines below MINLINVAL being excluded will sum up to this current value until MAXANEVAL is reached)
Local Decimal  AMTBAS
Local Integer  MON
Local Char     EXPIMPVCR(GLONVCR)
Local Char     FLD40REN(5)
Local Char     FLD41REN(5)
Local Char     CRY(GLONCRY)
Local Integer  YEA # Issue X3-35754 - 2017-05-04 by VAVIL - Periodic VAT declaration - wrong year on supplier doc list
Local Tinyint  BORI #Flag to set if we are coming from WRITE_DVPB or from WRITE_DVPB2
Local Tinyint  ACCVATIPT
Local Tinyint  BPSORI     #flag to check if it's a supplier invoice

#-- auxiliar variables
Local Char     SUF(1)
Local Char     CRIT(250)
Local Char     HAE_CRIT(250)
Local Char     CALVATTRTNAM(10)
Local Integer  RCOUNT, I, II, RMAX
Local Integer  SNS
Local Integer  DAELIN(0..3, 1..106,1.. min(func AFNC.ACTIV("GAS"),2700))
Local Shortint AMTTYP #1 base amount, 2 vat amount
Local Shortint INVAMTTYP #invert amttyp
Local Char     LASSIH(GLONVCR)
Local Char     LASNUM(GLONVCR)
Local Char     LASTYP(GLONGTE)
Local Shortint MULEECNUMFLG # 0 - No, 1 - PID, 2 - PIL
Local Shortint EXCACCFLG
Local Shortint ADDLIN       # 1 - Adds line to DAELIN array; 0 Does not
Local Integer  CEEFLG       # Gestível provides services in spain on a portuguese customer. Tax rate is the spanish one, but the customer is portuguese, not spanish. It should be considered on field 8
# and not on field 7.
Local Shortint INVFLD07     # Flag to implement the control above
Local Char     TAXIGNORE(10)(1..50) #List of Tax codes to ignore on Anual recap
Local Shortint SPEOPETYP    #Possibility to define different criteria on the services declaration for the operation type
Local Integer  CTLORIMOD(2)
Local Integer  ICFLG        # Flag to set the second loop, just for intra-comunitaria

Gosub DEC_COM_VARS

Return
####################################################################################
####################################################################################
$DEC_COM_VARS

Local Char     DCLNUM(GLONVCR)
Local Integer  FLDLST(1..3, 1..106)
Local Decimal  FLDARR(1..3, 1..106)
Local Decimal  DEBAMT
Local Decimal  CDTAMT
Local Shortint EMPTYDCLFLG  # 0 - No, 1 - Yes (empty declaration)
Local Tinyint  DCLFMTVER    #declaration format management
Local Tinyint  TOTQ06A      #Name of the field that sums Q06-A main declaration (105 or 106)
Local Tinyint  TOTQ06AR     #Name of the field that sums Q06-A annex R1\R2 (73 or 74)

Return
####################################################################################
####################################################################################
$SET_CONTEXT

[L]DCLTYP = val(PARAM(1))
[L]DCLNUM = PARAM(2)
[L]CPY    = PARAM(3)
[L]STRDAT = PARAM(4)
[L]ENDDAT = PARAM(5)

Read [F:CPY]CPY0 = [L]CPY
If fstat : Raz [F:CPY] : Endif

Read [F:GCM]GCM0=[F:CPY]ACM
If fstat : Raz [F:GCM] : Endif

Read [F:DVPP]DVPP0=[L]CPY;year([L]STRDAT)
If fstat
  Raz [F:DVPP]
  [L]OK = 0
  Call ECR_TRACE(mess(13,7710,1),1) From GESECRAN
  Return
Endif

[L]LED = [F:GCM]LED([F:DVPP]LEDTYP-1)

Read [F:LED]LED0 = [L]LED
If fstat : Raz [F:LED] : Endif

[L]COA = [F:LED]COA

Case [L]DCLTYP
  When 1
    [L]CALVATTRTNAM = "CALVATPORP"
    Call SET_DCLFMTVER([L]ENDDAT, [L]DCLFMTVER, [L]TOTQ06A, [L]TOTQ06AR ) From CALVATPOR
  When 2
    [L]CALVATTRTNAM = "CALVATPORA"
  When 4
    [L]CALVATTRTNAM = "CALVATPORE"
Endcase

Gosub SET_CONTEXT From = [L]CALVATTRTNAM

Return
####################################################################################
####################################################################################
Subprog SET_DCLFMTVER(P_ENDDAT, P_DCLFMTVER, P_TOTQ06A, P_TOTQ06AR)
Value    Date    P_ENDDAT
Variable Tinyint P_DCLFMTVER
Variable Tinyint P_TOTQ06A
Variable Tinyint P_TOTQ06AR

If P_ENDDAT < gdat$(1,9,2017)
  P_DCLFMTVER = 0
  P_TOTQ06A   = 105
  P_TOTQ06AR  = 73
Else
  P_DCLFMTVER = 1
  P_TOTQ06A   = 106
  P_TOTQ06AR  = 74
Endif

End
####################################################################################
####################################################################################
$MAIN

Gosub MAIN From = CALVATTRTNAM

Return
####################################################################################
####################################################################################
$GETMAXDIM

[L]RCOUNT = 0

Filter [F:DVPT] Where [F:DVPT]DCLTYP=[L]DCLTYP & val([F:DVPT]DCLFLD) = val([L]DCLFLD) & [F:DVPT]DCLPAG = 1 & ([F:DVPT]CPY = [L]CPY | [F:DVPT]CPY = "") & evalue ([L]CRIT)
[L]RCOUNT = rowcount([F:DVPT])

Filter [F:DVPT] Where [F:DVPT]DCLTYP=[L]DCLTYP & val([F:DVPT]DCLFLD) = val([L]DCLFLD) & [F:DVPT]DCLPAG = 2 & ([F:DVPT]CPY = [L]CPY | [F:DVPT]CPY = "") & evalue ([L]CRIT)
[L]RCOUNT = max([L]RCOUNT, rowcount([F:DVPT]))

Filter [F:DVPT] Where [F:DVPT]DCLTYP=[L]DCLTYP & val([F:DVPT]DCLFLD) = val([L]DCLFLD) & [F:DVPT]DCLPAG = 3 & ([F:DVPT]CPY = [L]CPY | [F:DVPT]CPY = "") & evalue ([L]CRIT)
[L]RCOUNT = max([L]RCOUNT, rowcount([F:DVPT]))

Filter [F:DVPT]

If [L]RCOUNT = 0 : [L]RCOUNT = 1 : Endif

Return
######################################################################################
######################################################################################
$FEEDVATVAR

Filter [F:DVPT] Where [F:DVPT]DCLTYP=[L]DCLTYP & val([F:DVPT]DCLFLD)=val([L]DCLFLD) & [F:DVPT]DCLPAG = 1 & ([F:DVPT]CPY = [L]CPY | [F:DVPT]CPY = "") & evalue ([L]CRIT)
[L]RCOUNT = 1
For [F:DVPT]
   Assign "VAT"+format$("N0:3",[L]DCLFLD)+[L]SUF+"(1,"+num$([L]RCOUNT)+")" With [F:DVPT]VAT
   [L]RCOUNT += 1
Next
#Filter [F:DVPT] Where [F:DVPT]DCLTYP=[L]DCLTYP & val([F:DVPT]DCLFLD)=val([L]DCLFLD) & [F:DVPT]CPY = ""
#[L]RCOUNT = 1
#For [F:DVPT]
#   Assign "VAT"+format$("N0:3",[L]DCLFLD)+[L]SUF+"(1,"+num$([L]RCOUNT)+")" With [F:DVPT]VAT
#   [L]RCOUNT += 1
#Next

Filter [F:DVPT] Where [F:DVPT]DCLTYP=[L]DCLTYP & val([F:DVPT]DCLFLD)=val([L]DCLFLD) & [F:DVPT]DCLPAG = 2 & ([F:DVPT]CPY = [L]CPY | [F:DVPT]CPY = "") & evalue ([L]CRIT)
[L]RCOUNT = 1
For [F:DVPT]
   Assign "VAT"+format$("N0:3",[L]DCLFLD)+[L]SUF+"(2,"+num$([L]RCOUNT)+")" With [F:DVPT]VAT
   [L]RCOUNT += 1
Next
#Filter [F:DVPT] Where [F:DVPT]DCLTYP=[L]DCLTYP & val([F:DVPT]DCLFLD)=val([L]DCLFLD) & [F:DVPT]CPY = ""
#[L]RCOUNT = 1
#For [F:DVPT]
#   Assign "VAT"+format$("N0:3",[L]DCLFLD)+[L]SUF+"(2,"+num$([L]RCOUNT)+")" With [F:DVPT]VAT
#   [L]RCOUNT += 1
#Next

Filter [F:DVPT] Where [F:DVPT]DCLTYP=[L]DCLTYP & val([F:DVPT]DCLFLD)=val([L]DCLFLD) & [F:DVPT]DCLPAG = 3 & ([F:DVPT]CPY = [L]CPY | [F:DVPT]CPY = "") & evalue ([L]CRIT)
[L]RCOUNT = 1
For [F:DVPT]
   Assign "VAT"+format$("N0:3",[L]DCLFLD)+[L]SUF+"(3,"+num$([L]RCOUNT)+")" With [F:DVPT]VAT
   [L]RCOUNT += 1
Next
#Filter [F:DVPT] Where [F:DVPT]DCLTYP=[L]DCLTYP & val([F:DVPT]DCLFLD)=val([L]DCLFLD) & [F:DVPT]CPY = ""
#[L]RCOUNT = 1
#For [F:DVPT]
#   Assign "VAT"+format$("N0:3",[L]DCLFLD)+[L]SUF+"(3,"+num$([L]RCOUNT)+")" With [F:DVPT]VAT
#   [L]RCOUNT += 1
#Next
Filter [F:DVPT]

Return
######################################################################################
######################################################################################
$GETDOCBPR

Filter [F:DAE2] Where [F:DAE2]TYP=[F:HAE]TYP & [F:DAE2]NUM=[F:HAE]NUM & [F:DAE2]LEDTYP=[F:DVPP]LEDTYP & [F:DAE2]BPR<>""
Read Last
If fstat
  [L]BPR = ""
Else
  [L]BPR = [F:DAE2]BPR
Endif
Filter [F:DAE2]

Return
######################################################################################
######################################################################################
$GET_EECNUM

[L]EECNUM = ""
Raz [L]CRY, [L]CEEFLG

Read [F:PYH]PYH0 = [F:HAE]NUM
If !fstat

  Filter [F:DAE2]
&      Where [F:DAE2]TYP=[F:HAE]TYP & [F:DAE2]NUM=[F:HAE]NUM & [F:DAE2]LEDTYP = [F:DVPP]LEDTYP
&      & (pat([F:DAE2]ACC, [F:DVPP]BPCDISROT+"*") | pat([F:DAE2]ACC, [F:DVPP]BPSDISROT+"*"))

  Read [LDAE2] First
  If !fstat # discounts, eecnum from bpr
    Filter [F:DAE2]
    Gosub GETEECBPR
  Else      # not discounts, eecnum from ban
    Filter [F:DAE2]
    Gosub GETEECBAN
  Endif

Else

  Gosub GETEECINV
  If [L]EECNUM =""
    Link [F:DAE2] With [F:GAC2]GAC0=[L]COA;[F:DAE2]ACC, [F:BPR]BPR0= [F:DAE2]BPR As [LDAE2]
&        Where [F:DAE2]TYP=[F:HAE]TYP & [F:DAE2]NUM=[F:HAE]NUM & [F:DAE2]LEDTYP = [F:DVPP]LEDTYP
&        & [F:GAC2]FLGVAT=1 & [F:DAE2]BPR <> ""
    Read [LDAE2]First
    If !fstat
      [L]EECNUM=[F:BPR]EECNUM
    Endif
    Close File [LDAE2]
  Endif

  #X3-91707 - BPR account is also a base account so no filter on FLGVAT
  If [L]EECNUM =""
    Link [F:DAE2] With [F:GAC2]GAC0=[L]COA;[F:DAE2]ACC, [F:BPR]BPR0= [F:DAE2]BPR As [LDAE2]
&        Where [F:DAE2]TYP=[F:HAE]TYP & [F:DAE2]NUM=[F:HAE]NUM & [F:DAE2]LEDTYP = [F:DVPP]LEDTYP
&        & [F:DAE2]BPR <> ""
    Read [LDAE2]First
    If !fstat
      [L]EECNUM=[F:BPR]EECNUM
    Endif
    Close File [LDAE2]
  Endif

Endif

Return
####################################################################################
####################################################################################
$GETEECBAN

Filter [F:DAE2] Where [F:DAE2]TYP=[F:HAE]TYP & [F:DAE2]NUM=[F:HAE]NUM & [F:DAE2]LEDTYP = [F:DVPP]LEDTYP & pat([F:DAE2]ACC,[F:DVPP]BANACCROT+"*")
Read [F:DAE2] First
If !fstat
  Filter [F:BAN] Where [F:BAN]BANACC=[F:DAE2]ACC
  Read  [BAN] First
  If !fstat
    If [F:BAN]BANBPR <> ""
      Read [F:BPR]BPR0 = [F:BAN]BANBPR
      If !fstat
        [L]EECNUM=[F:BPR]EECNUM
      Endif
    Endif
  Endif
  Filter [F:BAN]
Endif
Filter [F:DAE2]

Return
####################################################################################
####################################################################################
$GETEECBPR

Link [F:DAE2] With [F:BPR]BPR0 = [F:DAE2]BPR As [LDAE2]
&    Where [F:DAE2]TYP=[F:HAE]TYP & [F:DAE2]NUM=[F:HAE]NUM & [F:DAE2]LEDTYP = [F:DVPP]LEDTYP & [F:DAE2]BPR <> ""
Read [LDAE2] First
If !fstat
  [L]EECNUM = [F:BPR]EECNUM
Endif
Close File [LDAE2]

Return
####################################################################################
####################################################################################
$GETEECINV

Raz [L]CRY, [L]CEEFLG

If [F:SIH]NUM <> [F:HAE]NUM
  Read [F:SIH]SIH0 = [F:HAE]NUM
  If fstat : Raz [F:SIH] : Endif
Endif

If [F:SIH]NUM = [F:HAE]NUM
  If [F:BPR]BPRNUM <> [F:SIH]BPR
    Read [F:BPR]BPR0 = [F:SIH]BPR
    If fstat : Raz [F:BPR] : Endif
  Endif
  If [F:SIH]DCLEECNUM <> ""
    [L]EECNUM = [F:SIH]DCLEECNUM
  Else
    If [F:SIV]NUM <> [F:HAE]NUM
      Read [F:SIV]SIV0 = [F:HAE]NUM
      If fstat : Raz [F:SIV] : Endif
    Endif
    If [F:SIV]NUM = [F:HAE]NUM & [F:SIV]BPIEECNUM <> ""
      [L]EECNUM = [F:SIV]BPIEECNUM
    Else
      [L]EECNUM = [F:BPR]EECNUM
    Endif
  Endif
Else
  If [F:PIH]NUM <> [F:HAE]NUM
    Read [F:PIH]PIH0=[F:HAE]NUM
    If fstat : Raz [F:PIH] : Endif
  Endif
  If [F:PIH]NUM = [F:HAE]NUM
    If [F:BPR]BPRNUM <> [F:PIH]BPR
      Read [F:BPR]BPR0 = [F:PIH]BPR
      If fstat : Raz [F:BPR] : Endif
    Endif
    If [F:PIH]EECNUM <> ""
      [L]EECNUM = [F:PIH]EECNUM
    Else
      [L]EECNUM = [F:BPR]EECNUM
    Endif
  Endif
Endif

If [F:SIH]NUM = [F:HAE]NUM | [F:PIH]NUM = [F:HAE]NUM
  If [F:TCY]CRY <> [F:BPR]CRY
    Read [F:TCY]TCY0 = [F:BPR]CRY
    If fstat : Raz [F:TCY] : Endif
  Endif
  [L]CRY = [F:BPR]CRY
  [L]CEEFLG = [F:TCY]EECFLG
Endif

Return
####################################################################################
####################################################################################
$GETGTE

If [F:GTE]TYP <> [F:HAE]TYP | [F:GTE]LEG <> [F:CPY]LEG
  Read [F:GTE]GTE0 = [F:HAE]TYP;[F:CPY]LEG
  If fstat
    Read [F:GTE]GTE0 = [F:HAE]TYP;""
    If fstat : Raz [F:GTE] : Endif
  Endif
Endif

Return
####################################################################################
####################################################################################
$WRITE_FROM_PIH

Case [L]MULEECNUMFLG
  When 1
    For [F:PID] Where [F:PID]NUM = [F:HAE]NUM

      Raz [F:DVPB]

      [F:DVPB]DCLTYP    = [L]DCLTYP
      [F:DVPB]DCLPAG    = [L]DCLPAG
      [F:DVPB]DCLNUM    = [L]DCLNUM
      [F:DVPB]NUM       = [F:PID]NUM
      [F:DVPB]LIN       = [F:PID]PIDLIN
      [F:DVPB]DCLFLD    = format$("N0:3",[L]DCLFLD)
      [F:DVPB]AMTBAS    = [F:PID]AMTNOTLIN*[L]SNS
      [F:DVPB]AMTVAT    = [F:PID]AMTTAXLIN1*[L]SNS
      If [F:HAE]BPRDATVCR <> [0/0/0]
        [F:DVPB]ACCDAT    = [F:HAE]BPRDATVCR
      Else
        [F:DVPB]ACCDAT    = [F:HAE]ACCDAT
      Endif
      [F:DVPB]VAT       = [F:PID]VAT(0)
      [F:DVPB]DCLFLDTYP = [L]AMTTYP
      [F:DVPB]EXPIMPVCR = [L]EXPIMPVCR
      [F:DVPB]RECTYP    = [L]RECTYP    #recap type, 2-customers, 3- suppliers
      If [F:PID]DCLEECNUM <> ""
        [F:DVPB]EECNUM    = [F:PID]DCLEECNUM
      Else
        [F:DVPB]EECNUM    = [L]EECNUM
      Endif
      If len([F:DVPB]EECNUM)>=2
        [F:DVPB]CRY = left$([L]EECNUM, 2)
      Endif

      Write [F:DVPB]

    Next

  When 2
    For [F:PIL] Where [F:PIL]NUM = [F:HAE]NUM

      Raz [F:DVPB]

      [F:DVPB]DCLTYP    = [L]DCLTYP
      [F:DVPB]DCLPAG    = [L]DCLPAG
      [F:DVPB]DCLNUM    = [L]DCLNUM
      [F:DVPB]NUM       = [F:PIL]NUM
      [F:DVPB]LIN       = [F:PIL]LIG
      [F:DVPB]DCLFLD    = format$("N0:3",[L]DCLFLD)
      [F:DVPB]AMTBAS    = [F:PIL]AMTNOTLIN*[L]SNS
      [F:DVPB]AMTVAT    = [F:PIL]AMTVAT*[L]SNS
      If [F:HAE]BPRDATVCR <> [0/0/0]
        [F:DVPB]ACCDAT    = [F:HAE]BPRDATVCR
      Else
        [F:DVPB]ACCDAT    = [F:HAE]ACCDAT
      Endif
      [F:DVPB]VAT       = [F:PIL]VAT(0)
      [F:DVPB]DCLFLDTYP = [L]AMTTYP
      [F:DVPB]EXPIMPVCR = [L]EXPIMPVCR
      [F:DVPB]RECTYP    = [L]RECTYP    #recap type, 2-clients, 3- suppliers
      If [F:PIL]DCLEECNUM <> ""
        [F:DVPB]EECNUM    = [F:PIL]DCLEECNUM
      Else
        [F:DVPB]EECNUM    = [L]EECNUM
      Endif
      If len([F:DVPB]EECNUM)>=2
        [F:DVPB]CRY = left$([L]EECNUM, 2)
      Endif

      Write [F:DVPB]

    Next
Endcase

Return
######################################################################################
######################################################################################
$GETJOU

If [F:JOU]JOU <> [F:HAE]JOU | [F:JOU]LEG <> [F:CPY]LEG
  Read [F:JOU]JOU0 = [F:HAE]JOU;[F:CPY]LEG
  If fstat & [F:CPY]LEG <> ""
    Read [F:JOU]JOU0 = [F:HAE]JOU;""
    If fstat : Raz [F:JOU] : Endif
  Endif
Endif

Return
######################################################################################
######################################################################################
$CHECK_MULEECNUM

Read [F:PIH]PIH0 = [F:HAE]NUM
If !fstat
  Local Char LASEECNUM(GLONEEC)
  If    [F:PIH]ORIMOD = 3
    If !clalev([F:PIL]) : Local File BPSINVLIG [PIL] : Endif
    For [F:PIL] Where [F:PIL]NUM = [F:PIH]NUM
      If [F:PIL]DCLEECNUM <> [L]LASEECNUM & [L]LASEECNUM <> "" & [F:PIL]VAT(0) = [F:DAEP]TAX
        [L]MULEECNUMFLG = 2
      Endif
      [L]LASEECNUM = [F:PIL]DCLEECNUM
    Next
  Elsif [F:PIH]ORIMOD = 6
    If !clalev([F:PID]) : Local File PINVOICED [PID] : Endif
    For [F:PID] Where [F:PID]NUM = [F:PIH]NUM
      If [F:PID]DCLEECNUM <> [L]LASEECNUM & [L]LASEECNUM <> "" & [F:PID]VAT(0) = [F:DAEP]TAX
        [L]MULEECNUMFLG = 1
      Endif
      [L]LASEECNUM = [F:PID]DCLEECNUM
    Next
  Endif
Endif

Return
######################################################################################
######################################################################################
$SEL_LISTE

Case LISTE
    When "CPYPORVAT": Gosub SELCPYPORVAT
Endcase

Return
######################################################################################
######################################################################################
$FIN_LISTE

Case LISTE
    When "CPYPORVAT": Gosub FINCPYPORVAT
Endcase

Return
######################################################################################
######################################################################################
$SELCPYPORVAT

Local Integer NBTEX
#Local Char    TEX(80)(1..1000)
Local Char    TEXTE(80)(1..200,1..3)

NBTEX = 0

TIT(0) = mess( 2, 45,1)                  : # Company
TIT(1) = mess( 2, 45,1)                  : # Company
TIT(2) = mess(38,100,1)                  : # Name
TIT(3) = mess( 3,675,1)                  : # Short name

If clalev([F:CPYSL])=0 : Local File COMPANY  [CPYSL] : Endif

For [F:CPYSL]

  If func AFNC.PARAM("PORVAT",[F:CPYSL]CPY) = "2"
    NBTEX         += 1
    TEX(NBTEX)     = [F:CPYSL]CPY
    TEXTE(NBTEX,1) = [F:CPYSL]CPY
    TEXTE(NBTEX,2) = [F:CPYSL]CPYNAM
    TEXTE(NBTEX,3) = [F:CPYSL]CPYSHO
  Endif

Next

If NBTEX = 0
   GERR     = 2
   GMESSAGE = mess(231,111,1)
   mkstat   = 2
Endif

Return
######################################################################################
######################################################################################
$FINCPYPORVAT

If clalev([F:CPYSL])>0 : Close File [CPYSL] : Endif

Return
######################################################################################
######################################################################################
$SEL_TABLE

Case TABLE
  When "VCRPORVAT" : Gosub SELVCRPORVAT
  When "DCLVAT"    : Gosub SELDCLVAT
Endcase

Return
######################################################################################
######################################################################################
$FIN_TABLE

Return
######################################################################################
######################################################################################
$SELVCRPORVAT

DEFPAG  = 1
OPTIONS = "#"
CRITERE = "1=1"

Local Date DATAUX

If PARAM(1) = "1"

  OBJET   = "PIH"
  If PARAM(2)<>""
    CRITERE -= "& [F:PIH]CPY='"+PARAM(2)+"'"
  Endif
  If val(PARAM(3)) <> 0
    DATAUX = PARAM(3)
    CRITERE -= "& [F:PIH]ACCDAT >= [" + format$(GFMD,DATAUX) + "]"
  Endif
  If val(PARAM(4)) <> 0
    DATAUX = PARAM(4)
    CRITERE -= "& [F:PIH]ACCDAT <= [" + format$(GFMD,DATAUX) + "]"
  Endif

Elsif PARAM(1) = "2"

  OBJET   = "BIC"
  If PARAM(2)<>""
    CRITERE -= "& [F:SIH]CPY='"+PARAM(2)+"'"
  Endif
  If val(PARAM(3)) <> 0
    DATAUX = PARAM(3)
    CRITERE -= "& [F:SIH]ACCDAT >= [" + format$(GFMD,DATAUX) + "]"
  Endif
  If val(PARAM(4)) <> 0
    DATAUX = PARAM(4)
    CRITERE -= "& [F:SIH]ACCDAT <= [" + format$(GFMD,DATAUX) + "]"
  Endif

Endif

Return
######################################################################################
######################################################################################
$SELDCLVAT

Local Integer PASPER
Local Date    DATAUX
Local Char    DCLCPY(GLONCPY)
Local Integer MONCUR
Local Char PDCLTYP

DCLCPY  = PARAM(3)
PDCLTYP = num$(PARAM(5))

Case PARAM(1)
  When "ANXPER1" : PASPER = 1
  When "ANXPER2" : PASPER = 2
  When "ANXPER3" : PASPER = 3
  When "ANXI"    :
Endcase

#monthly or quarterly
If PARAM(4) = "0" : PASPER *= 3 : Endif

DATAUX = PARAM(2)
MONCUR = month(DATAUX)

DATAUX = gdat$(01,((PASPER>=MONCUR)*12)+(MONCUR-PASPER),year(DATAUX) + ((-1)*(PASPER>=MONCUR)))

Case PARAM(1)
  When "ANXPER1", "ANXPER2", "ANXPER3" : Gosub SEL_ANXPER
  When "ANXI"                          : Gosub SEL_ANXI
Endcase

Kill PASPER

Return
######################################################################################
######################################################################################
SEL_ANXPER

DEFPAG  = 1
OPTIONS = "#"
OBJET   = "DVPHP"

CRITERE = "[F:DVPH]CPY = '" + DCLCPY + "' & [F:DVPH]STRDAT = [" + format$(GFMD,DATAUX) + "] & [F:DVPH]DCLTYP = " + num$(PDCLTYP)

Return
######################################################################################
######################################################################################
SEL_ANXI

DEFPAG  = 1
OPTIONS = "#"
OBJET   = "DVPHE"

CRITERE -= "[F:DVPH]CPY = '" + DCLCPY + "' & [F:DVPH]STRDAT = [" + format$(GFMD,DATAUX) + "] & DCLTYP = 4"

Return
######################################################################################
######################################################################################

