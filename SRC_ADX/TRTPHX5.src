##########################################################################################################
# Renvoi le numéro de ligne d'un représentant dans le masque PHX5
##################################################################
Subprog GETREPNOL(SZREPCOD, IREPNOL)
Value Char SZREPCOD
Variable Integer IREPNOL

Local Integer IG

  # FGR 13/10/2015 : X3SUIVI111690 (début)
  #IREPNOL = 0
  #For IG = 0 To dim([M:PHX5]REP)-1
  #  If [M:PHX5]REP(IG) = SZREPCOD Then
  #    Break
  #  Endif
  #  IREPNOL += 1
  #Next
  #If IREPNOL = dim([M:PHX5]REP)-1 Then
  #  IREPNOL = -1
  #Endif
  IREPNOL = -1
  For IG = 0 To dim([M:PHX5]REP)-1
    If [M:PHX5]REP(IG) = "" Then
      Break
    Endif
    If [M:PHX5]REP(IG) = SZREPCOD Then
      IREPNOL = IG
      Break
    Endif
  Next
  # FGR 13/10/2015 : X3SUIVI111690 (fin)
End

##########################################################################################################
# Calcul la prochaine date et heure d'appel pour un téléacteur.
##################################################################
Subprog SETASSDAT(IREPNOL, DASSDAT, SZASSHOU, IOK)
Value Integer IREPNOL
Variable Date DASSDAT
Variable Char SZASSHOU
Variable Integer IOK

  Read [REP]REP0=[M:PHX5]REP(IREPNOL)
  If fstat Then
    IOK = 0
    End
  Endif
  Read [AUS]CODUSR=[F:REP]AUSNUM
  If fstat Then
    IOK = 0
    End
  Endif
  # A compléter ou supprimer.
End

##########################################################################################################
# Calcul le nombre d'appels à affecter à chaque téléacteur.
##################################################################################
Subprog SETASSCLL(ITYPVEN)
Value Integer ITYPVEN
  #Valeurs de ITYPVEN
  # 1 = Ventilation manuelle
  # 2 = Ventilation automatique
  # 3 = Ventilation selon attribution de compte

Local Integer IG
Local Integer OPGPAR([M:PHX5]NBVEN)
Local Integer OPGPARPRC([M:PHX5]NBVEN)
Local Integer TOTOPGPAR
Local Integer ITOTCLLTOASS
Local Integer TOTDAYCLLASS
Local Integer INBVENASSCLL
Local Integer INEWLASASS
Local Integer ITAKENEG

  INBVENASSCLL = 0
  INEWLASASS = 0
  TOTOPGPAR = 0
  ITOTCLLTOASS  = 0
  TOTDAYCLLASS = 0
  ITAKENEG = 0
  Raz OPGPAR
  Raz OPGPARPRC
  #Calcul le total de la moyenne des appels affectables par jours
  If ITYPVEN = 2 Then
    For IG = 0 To dim([M:PHX5]REP)-1
      If [M:PHX5]REPNUM(IG) = "" Then
        Break
      Endif
      If [M:PHX5]DAYCLLASS(IG) >= 0 Then
        TOTDAYCLLASS += [M:PHX5]DAYCLLASS(IG)
      Endif
    Next
  Endif
  #Calcul la part brute de chaque téléacteur dans la campagne
  For IG = 0 To dim([M:PHX5]REP)-1
    If [M:PHX5]REPNUM(IG) = "" Then
      Break
    Endif
    If ITYPVEN = 1 Then
      #Ventilation manuelle
      OPGPAR(IG) = [M:PHX5]MANBRD(IG) * [M:PHX5]NBQWKDHOU(IG)
    Elsif ITYPVEN = 2 Then
      #Ventilation automatique
      If TOTDAYCLLASS = 0 Then
        ITAKENEG = 1
        Break
      Else
        If [M:PHX5]DAYCLLASS(IG) >= 0 Then
          OPGPAR(IG) = fix(([M:PHX5]DAYCLLASS(IG) / TOTDAYCLLASS) * 100) * [M:PHX5]NBQWKDHOU(IG)
        Else
          OPGPAR(IG) = 0
        Endif
      Endif
    Endif
  Next
  If ITAKENEG Then
    #Réinitialise les variables
    Raz OPGPAR
    Raz OPGPARPRC
    INBVENASSCLL = 0
    INEWLASASS = 0
    TOTOPGPAR = 0
    ITOTCLLTOASS  = 0
    TOTDAYCLLASS = 0
    #Calcul le total de la moyenne des appels affectables par jours
    If ITYPVEN = 2 Then
      For IG = 0 To dim([M:PHX5]REP)-1
        If [M:PHX5]REPNUM(IG) = "" Then
          Break
        Endif
        TOTDAYCLLASS += abs([M:PHX5]DAYCLLASS(IG))
      Next
    Endif
    #Calcul la part brute de chaque téléacteur dans la campagne
    For IG = 0 To dim([M:PHX5]REP)-1
      If [M:PHX5]REPNUM(IG) = "" Then
        Break
      Endif
      If ITYPVEN = 1 Then
        #Ventilation manuelle
        OPGPAR(IG) = [M:PHX5]MANBRD(IG) * [M:PHX5]NBQWKDHOU(IG)
      Elsif ITYPVEN = 2 Then
        #Ventilation automatique
        If TOTDAYCLLASS = 0 Then
          OPGPAR(IG) = [M:PHX5]NBQWKDHOU(IG)
        Else
          OPGPAR(IG) = fix((abs([M:PHX5]DAYCLLASS(IG)) / TOTDAYCLLASS) * 100) * [M:PHX5]NBQWKDHOU(IG)
        Endif
      Endif
    Next
  Endif
  #Calcul la part totale de la campagne
  For IG = 0 To dim(OPGPAR)-1
    TOTOPGPAR += OPGPAR(IG)
  Next
  #Calcul la part en pourcentage de chaque téléacteur dans la campagne
  For IG = 0 To dim(OPGPAR)-1
    If TOTOPGPAR = 0 Then
      OPGPARPRC(IG) = 0
    Else
      OPGPARPRC(IG) = fix((OPGPAR(IG) / TOTOPGPAR) * 100)
      If OPGPAR(IG) > 0 Then
        If OPGPARPRC(IG) = 0 Then
          OPGPARPRC(IG) = 1
        Endif
      Endif
    Endif
  Next
  #Calcul le nombre d'appels à affecter à chaque téléacteur.
  For IG = 0 To dim([M:PHX5]REP)-1
    If [M:PHX5]REPNUM(IG) = "" Then
      Break
    Endif
    [M:PHX5]ASSCLL(IG) = fix([M:PHX5]NBQCLLASS * (OPGPARPRC(IG) / 100))
  Next
  #Calcul la somme d'appels affectés
  For IG = 0 To dim([M:PHX5]REP)-1
    If [M:PHX5]REPNUM(IG) = "" Then
      Break
    Endif
    ITOTCLLTOASS += [M:PHX5]ASSCLL(IG)
  Next
  #Vérifie si tous les appels ont été affectés.
  If ITOTCLLTOASS < [M:PHX5]NBQCLLASS Then
    #Calcul le nombre de téléacteurs avec au moins un appel affecté
    For IG = 0 To dim([M:PHX5]REP)-1
      If [M:PHX5]REPNUM(IG) = "" Then
        Break
      Endif
      If [M:PHX5]ASSCLL(IG) > 0 Then
        INBVENASSCLL += 1
      Endif
    Next
    #Calcul le surplus à affecter à chaque téléacteur.
    If INBVENASSCLL = 0 Then
      End
    Else
      INEWLASASS = fix(([M:PHX5]NBQCLLASS - ITOTCLLTOASS) / INBVENASSCLL)
      If INEWLASASS = 0 Then
        INEWLASASS = 1
      Endif
    Endif
    While 1
      #Affecte le surplus à chaque téléacteur concerné.
      For IG = 0 To dim([M:PHX5]REP)-1
        If [M:PHX5]REPNUM(IG) = "" Then
          Break
        Endif
        If [M:PHX5]ASSCLL(IG) > 0 Then
          [M:PHX5]ASSCLL(IG) = [M:PHX5]ASSCLL(IG) + INEWLASASS
          ITOTCLLTOASS += INEWLASASS
        Endif
        If ITOTCLLTOASS >= [M:PHX5]NBQCLLASS Then
          [M:PHX5]ASSCLL(IG) = [M:PHX5]ASSCLL(IG) - (ITOTCLLTOASS - [M:PHX5]NBQCLLASS)
          Break
        Endif
      Next
      If ITOTCLLTOASS >= [M:PHX5]NBQCLLASS Then
        Break
      Endif
    Wend
  Endif
End

##########################################################################################################
# Execution de la ventilation automatique.
###########################################################################
$VENTCAL
Local Integer IOPGSTR
Local Integer IOPGEND
Local Integer IQ
Local Integer ISOK
Local Integer INBDAYREP               #Nombre d'appel à affecter par jour travaillé pour chaque téléacteur.
Local Integer ISVNBDAYREP             #Mémoire du nombre d'appels à affecter par jour travaillé pour chaque téléacteur.
Local Integer IASSCLLDON              #Nombre d'appel restant a affecter
Local Integer IASSREPDON              #Nombre d'appels créés pour un téléacteur.
Local Integer IASSDAYDON              #Nombre d'appels créés pour une journée de téléacteur.
Local Date DNEXASSDAY
Local Date DASSDAY                    #Date de l'appel à créer
Local Char SZASSHOU(30)               #Heure de l'appel à créer
Local Integer INBRECPRO               #Nombre de destinataires traités.
Local Integer INBCLLDAY               #Nombre d'appels déjà programmés dans l'agenda d'un téléacteur pour une journée.
Local Integer INBDAYDISP
Local Integer INBHOUDISP
Local Integer DISPISOK
Local Integer INCMGDAT

  INBCLLDAY = 0
  INBRECPRO = 0
  IOPGSTR = nday([M:PHX5]OPGSTR)
  IOPGEND = nday([M:PHX5]OPGCMGEND)
  IQ = 0
  ISOK = 1
  INBDAYREP = 0
  DNEXASSDAY = [00/00/00]
  SZASSHOU = "0900"
  INBDAYDISP = 0
  INBHOUDISP = 0
  DISPISOK = 1
  INCMGDAT = 0
  IASSREPDON = 0               #Nombre d'appels créés pour un téléacteur.
  IASSDAYDON = 0               #Nombre d'appels créés pour une journée de téléacteur.
  #Initialise DASSDAY avec un jour travaillé
  If [M:PHX5]NBVEN > 0 Then
    ISOK = 1
    Read [REP]REP0=[M:PHX5]REPNUM(IQ)
    If fstat Then
      DASSDAY = [M:PHX5]OPGSTR
    Else
      Call GETNEXTWDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR-1, DNEXASSDAY, ISOK) From CRM_UTIL
      If ISOK Then
        DASSDAY = DNEXASSDAY
      Else
        DASSDAY = [M:PHX5]OPGSTR
      Endif
    Endif
  Else
    DASSDAY = [M:PHX5]OPGSTR
  Endif
  If GSZTYPSEA = "CCN" Then
    Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = "CCN"
  Else
    Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN"
  Endif
  Read [SCL]First
  If fstat Then
    Filter [SCL]
    End
  Endif
  IQ = 0
  While 1
    If IQ >= dim([M:PHX5]REP)-1 Then
      Break
    Endif
    If [M:PHX5]ASSCLL(IQ) > 0 Then
      If INBRECPRO >= [M:PHX5]NBQCLLASS Then
        Break
      Endif
      If IASSREPDON = [M:PHX5]ASSCLL(IQ) Then
        #Définit la date de fin de campagne pour le téléacteur.
        [M:PHX5]OPGEND(IQ) = DASSDAY
        #Définit la moyenne d'appels affectés quotidiennement.
        If IVENTDISP Then
          Read [REP]REP0=[M:PHX5]REPNUM(IQ)
          If fstat Then
            INBDAYDISP = (nday(DASSDAY) + 1) - nday([M:PHX5]OPGSTR)
          Else
            DISPISOK = 1
            Call GETWORKDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR, [M:PHX5]OPGEND(IQ), INBDAYDISP, INBHOUDISP, DISPISOK) From CRM_UTIL
            If !DISPISOK Then
              INBDAYDISP = (nday(DASSDAY) + 1) - nday([M:PHX5]OPGSTR)
            Endif
          Endif
          If INBDAYDISP <= 0 Then
            INBDAYDISP = 1
          Endif
          [M:PHX5]DAYAVEASS(IQ) = [M:PHX5]ASSCLL(IQ) / INBDAYDISP
        Else
          [M:PHX5]DAYAVEASS(IQ) = INBDAYREP
        Endif
        #Définit les propriétés du téléacteur suivant
        IQ += 1
        ISOK = 1
        Read [REP]REP0=[M:PHX5]REPNUM(IQ)
        If fstat Then
          DASSDAY = [M:PHX5]OPGSTR
        Else
          Call GETNEXTWDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR-1, DNEXASSDAY, ISOK) From CRM_UTIL
          If ISOK Then
            DASSDAY = DNEXASSDAY
          Else
            DASSDAY = [M:PHX5]OPGSTR
          Endif
        Endif
        IASSREPDON = 0
        IASSDAYDON = 0
      Endif
      If [M:PHX5]NBQWKDDAY(IQ) = 0 Then
        INBDAYREP = 0
      Else
        If [M:PHX5]ASSCLL(IQ) = 0 Then
          INBDAYREP = 0
        Else
          INBDAYREP = fix([M:PHX5]ASSCLL(IQ) / [M:PHX5]NBQWKDDAY(IQ)) + 1
          If IVENTDISP Then
            #Ventilation selon disponibilité
            INBCLLDAY = 0
            Call GETNBCLLDAY([M:PHX5]REPNUM(IQ), DASSDAY, INBCLLDAY) From CRM_UTIL
            If [M:PHX5]CLLOBJ(IQ) = 0 Then
              Call GINCMGDAT(DASSDAY, INCMGDAT)
              If INCMGDAT Then
                If IASSDAYDON <= [M:PHX5]DAYCLLASS(IQ) Then
                  If IASSDAYDON <= INBDAYREP Then
                    IGONEXDAY = 0
                  Else
                    IGONEXDAY = 1
                  Endif
                Else
                  IGONEXDAY = 1
                Endif
              Else
                If !IPOURDEVRAI Then
                  INBCLLDAY += IASSDAYDON
                Endif
                If INBCLLDAY + INBDAYREP > [M:PHX5]REPOBJCLL Then
                  INBDAYREP = [M:PHX5]REPOBJCLL - INBCLLDAY
                Endif
                If INBDAYREP <= 0 Then
                  IGONEXDAY = 1
                Else
                  IGONEXDAY = 0
                Endif
              Endif
            Else
              Call GINCMGDAT(DASSDAY, INCMGDAT)
              If INCMGDAT Then
                If IASSDAYDON <= [M:PHX5]DAYCLLASS(IQ) Then
                  If IASSDAYDON <= INBDAYREP Then
                    IGONEXDAY = 0
                  Else
                    IGONEXDAY = 1
                  Endif
                Else
                  IGONEXDAY = 1
                Endif
              Else
                If !IPOURDEVRAI Then
                  INBCLLDAY += IASSDAYDON
                Endif
                If INBCLLDAY + INBDAYREP > [M:PHX5]CLLOBJ(IQ) Then
                  INBDAYREP = [M:PHX5]CLLOBJ(IQ) - INBCLLDAY
                Endif
                If INBDAYREP <= 0 Then
                  IGONEXDAY = 1
                Else
                  IGONEXDAY = 0
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
      If !IVENTDISP Then
        If IASSDAYDON = INBDAYREP Then
          Read [REP]REP0=[M:PHX5]REPNUM(IQ)
          If !fstat Then
            ISOK = 1
            Call GETNEXTWDAY([F:REP]REPNUM, [F:REP]AUSNUM, DASSDAY, DNEXASSDAY, ISOK) From CRM_UTIL
            If ISOK Then
              DASSDAY = DNEXASSDAY
            Endif
          Else
            DASSDAY = DASSDAY + 1
          Endif
          IASSDAYDON = 0
        Endif
      Endif
      If IVENTDISP Then
        If IGONEXDAY Then
          Read [REP]REP0=[M:PHX5]REPNUM(IQ)
          If !fstat Then
            ISOK = 1
            Call GETNEXTWDAY([F:REP]REPNUM, [F:REP]AUSNUM, DASSDAY, DNEXASSDAY, ISOK) From CRM_UTIL
            If ISOK Then
              DASSDAY = DNEXASSDAY
            Endif
          Else
            DASSDAY += 1
          Endif
          IASSDAYDON = 0
          IGONEXDAY = 0
        Else
          IASSREPDON += 1
          IASSDAYDON += 1
          If IPOURDEVRAI Then
            If GSZTYPSEA = "CCN" Then
              Call CRECLLOPG([F:SCL]BPRNUM, [F:SCL]RECNUM, [M:PHX5]REPNUM(IQ), DASSDAY, SZASSHOU, ISOK)
            Else
              Call CRECLLOPG([F:SCL]RECNUM, "", [M:PHX5]REPNUM(IQ), DASSDAY, SZASSHOU, ISOK)
            Endif
          Endif
          INBRECPRO += 1
          Read [SCL]Next
          If fstat Then
            Break
          Endif
        Endif
      Else
        If INBDAYREP = 0 Then
          IASSREPDON = 0
          IASSDAYDON = 0
        Else
          IASSREPDON += 1
          IASSDAYDON += 1
          If IPOURDEVRAI Then
            If GSZTYPSEA = "CCN" Then
              Call CRECLLOPG([F:SCL]BPRNUM, [F:SCL]RECNUM, [M:PHX5]REPNUM(IQ), DASSDAY, SZASSHOU, ISOK)
            Else
              Call CRECLLOPG([F:SCL]RECNUM, "", [M:PHX5]REPNUM(IQ), DASSDAY, SZASSHOU, ISOK)
            Endif
          Endif
          INBRECPRO += 1
          Read [SCL]Next
          If fstat Then
            Break
          Endif
        Endif
      Endif
    Else
      [M:PHX5]OPGEND(IQ) = [M:PHX5]OPGSTR
      IQ += 1
    Endif
  Wend
  #Définit la date de fin de campagne pour le dernier téléacteur.
  [M:PHX5]OPGEND(IQ) = DASSDAY
  #Définit la moyenne d'appels affectés quotidiennement pour le dernier téléacteur
  If IVENTDISP Then
    Read [REP]REP0=[M:PHX5]REPNUM(IQ)
    If fstat Then
      INBDAYDISP = (nday(DASSDAY) + 1) - nday([M:PHX5]OPGSTR)
    Else
      DISPISOK = 1
      Call GETWORKDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR, [M:PHX5]OPGEND(IQ), INBDAYDISP, INBHOUDISP, DISPISOK) From CRM_UTIL
      If !DISPISOK Then
        INBDAYDISP = (nday(DASSDAY) + 1) - nday([M:PHX5]OPGSTR)
      Endif
    Endif
    If INBDAYDISP <= 0 Then
      INBDAYDISP = 1
    Endif
    [M:PHX5]DAYAVEASS(IQ) = [M:PHX5]ASSCLL(IQ) / INBDAYDISP
  Else
    [M:PHX5]DAYAVEASS(IQ) = INBDAYREP
  Endif
  Filter [SCL]
  #Dernier contrôle au cas où il reste des Termes d'opérations non renseignés
  For IQ = 0 To [M:PHX5]NBVEN-1
    If [M:PHX5]REP(IQ) = "" Then       # FGR 13/10/2015 : X3SUIVI111690
      Break                            # FGR 13/10/2015 : X3SUIVI111690
    Else                               # FGR 13/10/2015 : X3SUIVI111690
      If [M:PHX5]OPGEND(IQ) = [00/00/00] Then
        [M:PHX5]OPGEND(IQ) = [M:PHX5]OPGSTR
      Endif
    Endif                              # FGR 13/10/2015 : X3SUIVI111690
  Next
Return

##########################################################################################################
# Calcul le nombre de destinataires associés affectés à un téléacteur.
#########################################################################
Subprog GETREPBPR(SZREPCOD, INBBPR, IOK)
Value Char SZREPCOD
Variable Integer INBBPR
Variable Integer IOK

Local Integer IBPRDEFINED
Local Integer INBREPSPE          # FGR 19/11/2012 : X3SUIVI84278
Local Char SFIEREPSPE(250)(0..)  # FGR 19/11/2012 : X3SUIVI84278
Local Integer NI                 # FGR 19/11/2012 : X3SUIVI84278

  # -----------------------------------
  # FGR 19/11/2012 : X3SUIVI84278 (début)
  INBREPSPE = -1
  Raz SFIEREPSPE  # FGR 18/01/2013 : X3SUIVI87382 : mauvais nom de variable SREPSPE
  Gosub PE_GETREPBPR From TRTCRMPE
  # FGR 19/11/2012 : X3SUIVI84278 (fin)
  # -----------------------------------
  IBPRDEFINED = 0
  INBBPR = 0
  If GSZTYPSEA = "CCN" Then
    Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = "CCN" and [F:SCL]REPNUM = ""
  Else
    Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN" and [F:SCL]REPNUM = ""
  Endif
  For [SCL]
    IBPRDEFINED = 0
    If GSZTYPSEA = "CCN" Then
      Read [BPC]BPC0=[F:SCL]BPRNUM
      If !fstat Then
        If [F:BPC]REP(0) = SZREPCOD Then
          INBBPR += 1
          IBPRDEFINED = 1
          Gosub MARKSCL
        Endif
        If [F:BPC]REP(1) = SZREPCOD Then
          If !IBPRDEFINED Then
            INBBPR += 1
            IBPRDEFINED = 1 # FGR 19/11/2012 : X3SUIVI84278
            Gosub MARKSCL
          Endif
        Endif
        Gosub GERE_REP_SPE # FGR 19/11/2012 : X3SUIVI84278
      Endif
    Else
      # FGR 29/03/2013 : X3SUIVI88351
      #If [F:SCL]RECTYP = "BPC" Then
      If [F:SCL]RECTYP = "BPC" or [F:SCL]RECTYP = "BPR" Then
        Read [BPC]BPC0=[F:SCL]RECNUM
        If !fstat Then
          If [F:BPC]REP(0) = SZREPCOD Then
            INBBPR += 1
            IBPRDEFINED = 1
            Gosub MARKSCL
          Endif
          If [F:BPC]REP(1) = SZREPCOD Then
            If !IBPRDEFINED Then
              INBBPR += 1
              IBPRDEFINED = 1 # FGR 19/11/2012 : X3SUIVI84278
              Gosub MARKSCL
            Endif
          Endif
          Gosub GERE_REP_SPE # FGR 19/11/2012 : X3SUIVI84278
        Endif
      Endif
    Endif
  Next
  Filter [SCL]
End

##########################################################################################################
$GERE_REP_SPE
  # FGR 19/11/2012 : X3SUIVI84278
  If !IBPRDEFINED Then
    If INBREPSPE > -1 Then
      For NI = 0 To INBREPSPE
        If SFIEREPSPE(NI) <> "" Then
          If evalue(SFIEREPSPE(NI)) = SZREPCOD Then
            If !IBPRDEFINED Then
              INBBPR += 1
              IBPRDEFINED = 1
              Gosub MARKSCL
              Break
            Endif
          Endif
        Endif
      Next NI
    Endif
  Endif
Return

##########################################################################################################
# Mémorisation du représentant en charge du compte
#####################################################
$MARKSCL
  Call DEBTRANS From GLOCK
  Trbegin [SCL]
  [F:SCL]REPNUM = SZREPCOD
  Rewrite [SCL]
  If fstat Then
    GMESSAGE = mess(101,141,1) #Erreur modification
    GERR = 1
    Rollback
  Else
    Commit
  Endif
Return

##########################################################################################################
# Mémorisation du représentant en charge du compte
#####################################################
$UNMARKSCL
  If !GINTRA Then
    Call OUVRE_BOITE(mess(365,196,1), [M:PHX5]NBQCLLASS) From GESECRAN   #Préparation du traitement.
  Endif
  CCOUNT = 0
  If GSZTYPSEA = "CCN" Then
    Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = "CCN" and [F:SCL]REPNUM <> ""
  Else
    Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN" and [F:SCL]REPNUM <> ""
  Endif
  For [SCL]
    Call DEBTRANS From GLOCK
    Trbegin [SCL]
    [F:SCL]REPNUM = ""
    Rewrite [SCL]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Rollback
    Else
      Commit
    Endif
    CCOUNT += 1
    If !GINTRA Then
      Call AFF_BOITE (mess(365,196,1), CCOUNT, COK) From GESECRAN   #Préparation du traitement.
    Endif
  Next
  Filter [SCL]
  If !GINTRA Then
    Call FERME_BOITE From GESECRAN
  Endif
Return

##########################################################################################################
# Calcul le nombre d'appels à affecter à chaque téléacteur pour les residus d'une ventilation selon compte.
##################################################################################
Subprog SETASSCLLX(ITYPVEN, IREMCLL)
Value Integer ITYPVEN
Value Integer IREMCLL
  #Valeurs de ITYPVEN
  # 1 = Ventilation manuelle
  # 2 = Ventilation automatique
  # 3 = Ventilation selon attribution de compte

Local Integer IG
Local Integer OPGPAR(dim([M:PHX5]REP))
Local Integer OPGPARPRC(dim([M:PHX5]REP))
Local Integer TOTOPGPAR
Local Integer ITOTCLLTOASS
Local Integer TOTDAYCLLASS
Local Integer INBVENASSCLL
Local Integer INEWLASASS
Local Integer ITAKENEG

  INBVENASSCLL = 0
  INEWLASASS = 0
  TOTOPGPAR = 0
  ITOTCLLTOASS  = 0
  TOTDAYCLLASS = 0
  ITAKENEG = 0
  #Initialise les variables
  Raz OPGPAR                           # FGR 13/10/2015 : X3SUIVI111690
  Raz OPGPARPRC                        # FGR 13/10/2015 : X3SUIVI111690
#  For IG = 0 To dim(OPGPAR)-1         # FGR 13/10/2015 : X3SUIVI111690
#    OPGPAR(IG) = 0                    # FGR 13/10/2015 : X3SUIVI111690
#    OPGPARPRC(IG) = 0                 # FGR 13/10/2015 : X3SUIVI111690
#  Next                                # FGR 13/10/2015 : X3SUIVI111690
  #Calcul le total de la moyenne des appels affectables par jours
  If ITYPVEN = 2 Then
    For IG = 0 To dim([M:PHX5]REP)-1
      If [M:PHX5]DAYCLLASSX(IG) >= 0 Then
        TOTDAYCLLASS += [M:PHX5]DAYCLLASSX(IG)
      Endif
    Next
  Endif
  #Calcul la part brute de chaque téléacteur dans la campagne
  For IG = 0 To dim([M:PHX5]REP)-1
    If [M:PHX5]REP(IG) = "" Then     # FGR 13/10/2015 : X3SUIVI111690
      Break                          # FGR 13/10/2015 : X3SUIVI111690
    Else                             # FGR 13/10/2015 : X3SUIVI111690
      If ITYPVEN = 1 Then
        #Ventilation manuelle
        OPGPAR(IG) = [M:PHX5]MANBRD(IG) * [M:PHX5]NBQWKDHOU(IG)
      Elsif ITYPVEN = 2 Then
        #Ventilation automatique
        If TOTDAYCLLASS <> 0 Then
          If [M:PHX5]DAYCLLASSX(IG) >= 0 Then
            OPGPAR(IG) = fix(([M:PHX5]DAYCLLASSX(IG) / TOTDAYCLLASS) * 100) * [M:PHX5]NBQWKDHOU(IG)
          Else
            OPGPAR(IG) = 0
          Endif
        Else
          ITAKENEG = 1
          Break
        Endif
      Endif                          # FGR 13/10/2015 : X3SUIVI111690
    Endif
  Next
  If ITAKENEG Then
    INBVENASSCLL = 0
    INEWLASASS = 0
    TOTOPGPAR = 0
    ITOTCLLTOASS  = 0
    TOTDAYCLLASS = 0
    #Initialise les variables
    Raz OPGPAR                           # FGR 13/10/2015 : X3SUIVI111690
    Raz OPGPARPRC                        # FGR 13/10/2015 : X3SUIVI111690
#    For IG = 0 To dim(OPGPAR)-1         # FGR 13/10/2015 : X3SUIVI111690
#      OPGPAR(IG) = 0                    # FGR 13/10/2015 : X3SUIVI111690
#      OPGPARPRC(IG) = 0                 # FGR 13/10/2015 : X3SUIVI111690
#    Next                                # FGR 13/10/2015 : X3SUIVI111690
    #Calcul le total de la moyenne des appels affectables par jours
    If ITYPVEN = 2 Then
      For IG = 0 To dim([M:PHX5]REP)-1
        TOTDAYCLLASS += abs([M:PHX5]DAYCLLASSX(IG))
      Next
    Endif
    #Calcul la part brute de chaque téléacteur dans la campagne
    For IG = 0 To dim([M:PHX5]REP)-1
      If [M:PHX5]REP(IG) = "" Then     # FGR 13/10/2015 : X3SUIVI111690
        Break                          # FGR 13/10/2015 : X3SUIVI111690
      Else                             # FGR 13/10/2015 : X3SUIVI111690
        If ITYPVEN = 1 Then
          #Ventilation manuelle
          OPGPAR(IG) = [M:PHX5]MANBRD(IG) * [M:PHX5]NBQWKDHOU(IG)
        Elsif ITYPVEN = 2 Then
          #Ventilation automatique
          If TOTDAYCLLASS <> 0 Then
            OPGPAR(IG) = fix((abs([M:PHX5]DAYCLLASSX(IG)) / TOTDAYCLLASS) * 100) * [M:PHX5]NBQWKDHOU(IG)
          Else
            OPGPAR(IG) = 0
          Endif
        Endif
      Endif                          # FGR 13/10/2015 : X3SUIVI111690
    Next
  Endif
  #Calcul la part totale de la campagne
  For IG = 0 To dim(OPGPAR)-1
    If [M:PHX5]REP(IG) = "" Then     # FGR 13/10/2015 : X3SUIVI111690
      Break                          # FGR 13/10/2015 : X3SUIVI111690
    Else                             # FGR 13/10/2015 : X3SUIVI111690
      TOTOPGPAR += OPGPAR(IG)
    Endif                            # FGR 13/10/2015 : X3SUIVI111690
  Next
  #Calcul la part en pourcentage de chaque téléacteur dans la campagne
  For IG = 0 To dim(OPGPAR)-1
    If [M:PHX5]REP(IG) = "" Then     # FGR 13/10/2015 : X3SUIVI111690
      Break                          # FGR 13/10/2015 : X3SUIVI111690
    Else                             # FGR 13/10/2015 : X3SUIVI111690
      If TOTOPGPAR = 0 Then
        OPGPARPRC(IG) = 0
      Else
        OPGPARPRC(IG) = fix((OPGPAR(IG) / TOTOPGPAR) * 100)
        If OPGPAR(IG) > 0 Then
          If OPGPARPRC(IG) = 0 Then
            OPGPARPRC(IG) = 1
          Endif
        Endif
      Endif
    Endif                            # FGR 13/10/2015 : X3SUIVI111690
  Next
  #Calcul le nombre d'appels à affecter à chaque téléacteur.
  For IG = 0 To dim([M:PHX5]REP)-1
    If [M:PHX5]REP(IG) = "" Then     # FGR 13/10/2015 : X3SUIVI111690
      Break                          # FGR 13/10/2015 : X3SUIVI111690
    Else                             # FGR 13/10/2015 : X3SUIVI111690
      [M:PHX5]ASSCLLX(IG) = fix(IREMCLL * (OPGPARPRC(IG) / 100))
    Endif                            # FGR 13/10/2015 : X3SUIVI111690
  Next
  #Calcul la somme d'appels affectés
  For IG = 0 To dim([M:PHX5]REP)-1
    If [M:PHX5]REP(IG) = "" Then     # FGR 13/10/2015 : X3SUIVI111690
      Break                          # FGR 13/10/2015 : X3SUIVI111690
    Else                             # FGR 13/10/2015 : X3SUIVI111690
      ITOTCLLTOASS += [M:PHX5]ASSCLLX(IG)
    Endif                            # FGR 13/10/2015 : X3SUIVI111690
  Next
  #Vérifie si tous les appels ont été affectés.
  If ITOTCLLTOASS < IREMCLL Then
    #Calcul le nombre de téléacteurs avec au moins un appel affecté
    For IG = 0 To dim([M:PHX5]REP)-1
      If [M:PHX5]REP(IG) = "" Then     # FGR 13/10/2015 : X3SUIVI111690
        Break                          # FGR 13/10/2015 : X3SUIVI111690
      Else                             # FGR 13/10/2015 : X3SUIVI111690
        If [M:PHX5]ASSCLLX(IG) > 0 Then
          INBVENASSCLL += 1
        Endif
      Endif                            # FGR 13/10/2015 : X3SUIVI111690
    Next
    #Calcul le surplus à affecter à chaque téléacteur.
    If INBVENASSCLL = 0 Then
      End
    Else
      INEWLASASS = fix((IREMCLL - ITOTCLLTOASS) / INBVENASSCLL)
      If INEWLASASS = 0 Then
        INEWLASASS = 1
      Endif
    Endif
    While 1
      #Affecte le surplus à chaque téléacteur concerné.
      For IG = 0 To dim([M:PHX5]REP)-1
        If [M:PHX5]REP(IG) = "" Then     # FGR 13/10/2015 : X3SUIVI111690
          Break                          # FGR 13/10/2015 : X3SUIVI111690
        Else                             # FGR 13/10/2015 : X3SUIVI111690
          If [M:PHX5]ASSCLLX(IG) > 0 Then
            [M:PHX5]ASSCLLX(IG) = [M:PHX5]ASSCLLX(IG) + INEWLASASS
            ITOTCLLTOASS += INEWLASASS
          Endif
          If ITOTCLLTOASS >= IREMCLL Then
            [M:PHX5]ASSCLLX(IG) = [M:PHX5]ASSCLLX(IG) - (ITOTCLLTOASS - IREMCLL)
            Break
          Endif
        Endif                            # FGR 13/10/2015 : X3SUIVI111690
      Next
      If ITOTCLLTOASS >= IREMCLL Then
        Break
      Endif
    Wend
  Endif
End

##########################################################################################################
# Renseigne le nombre d'appels à effectuer sur l'opération
##################################################################################
Subprog SETOMPINF(INBCLL)
Value Integer INBCLL

Local Integer ITERPHX5
Local Integer IDVAERR

  IDVAERR = 0
  ITERPHX5 = 0
  Call DEBTRANS From GLOCK
  Trbegin [OMP], [DVA]
  Readlock [OMP]OMP0=GSZOPGNUM
  #Il s'agit d'un nouvel enregistrement
  If !fstat Then
    [F:OMP]NBRCLLOMP = INBCLL
    [F:OMP]NBRCLLPCD = 0
    [F:OMP]NBRCLLPCDX = INBCLL
    Rewrite [OMP]
    If fstat Then
      GMESSAGE = mess(101,141,1)
      GERR = 1
      Unlock [OMP]
      Rollback
      End
    Endif
  Endif
  #Enregistrement des téléacteurs participants
  Delete [DVA] Where [F:DVA]OBC = "OMP" and [F:DVA]ALHX(0) = GSZOPGNUM
  If fstat Then
    #Erreur lors de l'enregistrement des téléacteurs participants.
    GMESSAGE = mess(123,177,1)
    GERR = 1
    Rollback
    End
  Endif
  For ITERPHX5 = 0 To [M:PHX5]NBVEN-1
    Raz [F:DVA]
    [F:DVA]OBC = "OMP"
    [F:DVA]PARAM = GSZOPGNUM + [M:PHX5]REPNUM(ITERPHX5)
    [F:DVA]ALHX(0) = GSZOPGNUM
    [F:DVA]ALHX(1) = [M:PHX5]REPNUM(ITERPHX5)
    [F:DVA]INTX(0) = [M:PHX5]ASSCLL(ITERPHX5)
    Write [DVA]
    If fstat Then
      IDVAERR = 1
      Break
    Endif
  Next
  If IDVAERR Then
    #Erreur lors de l'enregistrement des téléacteurs participants.
    GMESSAGE = mess(123,177,1)
    GERR = 1
    Rollback
    End
  Endif
  Commit
End

##########################################################################################################
# Détermine si la date est comprise dans le créneau de date d'une campagne d'appel
##################################################################################
Subprog GINCMGDAT(DDAY, INCMG)
Value Date DDAY
Variable Integer INCMG

Local Integer IMINDAT
Local Integer IMAXDAT

  IMINDAT = nday([M:PHX5]OPGSTR)
  IMAXDAT = nday([M:PHX5]OPGCMGEND)
  If nday(DDAY) >= IMINDAT and nday(DDAY) <= IMAXDAT Then
    INCMG = 1
  Else
    INCMG = 0
  Endif
End

