#      If !fstat Then
#        [F:CLL]CLLOBJ = [F:CMG]DES
#      Endif
#    Endif
#  Endif
#  [F:CLL]CLLTNTPRE = 0
#  [F:CLL]CLLDUR = 0
#  [F:CLL]CLLREP = SZREPNUM
#  Call DEFPIO(405, [F:CLL]CLLPIOLEV) From SUBCLLB
