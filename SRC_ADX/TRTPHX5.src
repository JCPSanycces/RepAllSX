#  #Origine
#  #[F:CLL]CLLORI = 3
#  [F:CLL]CLLORIADI = "MKT3"  # FGR 05/03/2010 : X3SUIVI62924
#  #[F:CLL]CLLORITYP = mess(3,2993,1)  # FGR 10/03/2010 : X3SUIVI62924
