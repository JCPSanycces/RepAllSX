##########################################################################################################
# Création d'un appel d'opération marketing
##########################################################
Subprog CRECLLOPG(SZBPRNUM, SZCCNNUM, SZREPNUM, DDATE, SZHOU, IOK)
Value Char SZBPRNUM
Value Char SZCCNNUM
Value Char SZREPNUM
Value Date DDATE
Value Char SZHOU
Variable Integer IOK

Local Char SZPHX5PECODE(GLONADI)
Local Integer ICHAR
Local Integer IINT
Local Integer IDEC
Local Integer IDATE
Local Integer ICLOB
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer LERRCOD
Local Char SZCLLNUM(GLONVCR)

  SZPHX5PECODE = [M:PHX5]PITRCPOBJ
  IOK = 1
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #Tableau de char
  Raz GTBKCHR
  Raz GTBVCHR
  #Tableau entiers
  Raz GTBKINT
  Raz GTBVINT
  #Tableau decimal
  Raz GTBKDEC
  Raz GTBVDEC
  #tableau date
  Raz GTBKDATETIME
  Raz GTBVDATETIME
  #tableau clob
  Raz GTBKCLOB
  Raz GTBVCLOB
  #
  ICHAR = 1
  IINT = 1
  IDEC = 1
  IDATE = 1
  ICLOB = 1
  LERRCOD = 0
  Raz SZCLLNUM
  GTBKCHR(ICHAR) = "SALFCY"
  GTBVCHR(ICHAR) = [M:PHX5]FCY
  ICHAR += 1
  #[F:CLL]CLLCMP = SZBPRNUM
  GTBKCHR(ICHAR) = "CLLCMP"
  GTBVCHR(ICHAR) = SZBPRNUM
  ICHAR += 1
  #[F:CLL]CLLOPP = ""
  GTBKCHR(ICHAR) = "CLLOPP"
  GTBVCHR(ICHAR) = ""
  ICHAR += 1
  #[F:CLL]CLLDAT = DDATE
  GTBKDATETIME(IDATE) = "CLLDAT"
  GTBVDATETIME(IDATE) = DDATE
  IDATE += 1
  #[F:CLL]CLLHOU = SZHOU
  GTBKCHR(ICHAR) = "CLLHOU"
  GTBVCHR(ICHAR) = SZHOU
  ICHAR += 1
  #[F:CLL]CLLTYP = 2
  GTBKINT(IINT) = "CLLTYP"
  GTBVINT(IINT) = 2
  IINT += 1
  #[F:CLL]CLLSCP=[M:PHX5]SCPNUM
  GTBKCHR(ICHAR) = "CLLSCP"
  GTBVCHR(ICHAR) = [M:PHX5]SCPNUM
  ICHAR += 1
  GTBKCHR(ICHAR) = "CLLCCN"
  GTBVCHR(ICHAR) = SZCCNNUM
  ICHAR += 1

#Dimensionnement du clob
Local Integer ILNGCLOB

  ILNGCLOB = 0
  Read [ATY]CODTYP="HD5"
  If fstat Then
    ILNGCLOB = 5
  Else
    ILNGCLOB = [F:ATY]LNGTYP
  Endif
  If ILNGCLOB = 0 Then
    ILNGCLOB = 5
  Endif

Local Integer IFULOBJBYPE
Local Char SZCTLCLOB5(250)
Local Char SZSUMUP(235)
Local Clbfile CLBCLLFULOBJ(ILNGCLOB)

  IFULOBJBYPE = 0
  SZSUMUP = ""
  Raz SZCTLCLOB5
  If SZPHX5PECODE <> "" Then
    #Définitoon de l'objet de l'appel
    Gosub PE_CLLOBJ From TRTCRMPE
  Endif
  If IFULOBJBYPE and CLBCLLFULOBJ = "" Then
    # FGR 15/03/2010 : X3SUIVI63177 : C'était déjà comme ça, mais de cette façon c'est plus simple.
    # Si le PE dit qu'on affecte en spécifique, mais qu'il n'y a pas de texte,
    # on rebascule dans le mode standard et on ignore la valeur du PE.
    IFULOBJBYPE = 0
  Endif
  If IFULOBJBYPE Then
    # FGR 15/03/2010 : X3SUIVI63177 (début)
    #Setlob SZCTLCLOB5 With CLBCLLFULOBJ
    ##[F:CLL]TYPFULOBJ = "CLLOBJ"
    #GTBKCHR(ICHAR) = "TYPFULOBJ"
    #GTBVCHR(ICHAR) = "CLLOBJ"
    #ICHAR += 1
    ##[F:CLL]NUMFULOBJ = SZCLLNUM
    #GTBKCHR(ICHAR) = "NUMFULOBJ"
    #GTBVCHR(ICHAR) = SZCLLNUM
    #ICHAR += 1
    ##[F:CLL]OBJFLG = 1
    #GTBKINT(IINT) = "OBJFLG"
    #GTBVINT(IINT) = 1
    #IINT += 1
    ##[F:CLL]CLLOBJ = SZSUMUP
    #GTBKCHR(ICHAR) = "CLLOBJ"
    #GTBVCHR(ICHAR) = SZSUMUP
    #ICHAR += 1
    # FGR 15/03/2010 : X3SUIVI63177 (fin)
    If SZSUMUP <> "" Then
      GTBKCHR(ICHAR) = "CLLOBJ"
      GTBVCHR(ICHAR) = SZSUMUP
      ICHAR += 1
      GTBKINT(IINT) = "OBJFLG"
      GTBVINT(IINT) = 1
      IINT += 1
    Endif
    GTBKCLOB(ICLOB) = "FULOBJ"
    GTBVCLOB(ICLOB) = CLBCLLFULOBJ
    ICLOB += 1
  Else
    # FGR 15/03/2010 : X3SUIVI63177 (début)
    #If GCLLCMGOMP = 2 Then
    #  #[F:CLL]TYPFULOBJ = "OMP"
    #  GTBKCHR(ICHAR) = "TYPFULOBJ"
    #  GTBVCHR(ICHAR) = "OMP"
    #  ICHAR += 1
    #  #[F:CLL]NUMFULOBJ = GSZOPGNUM
    #  GTBKCHR(ICHAR) = "NUMFULOBJ"
    #  GTBVCHR(ICHAR) = GSZOPGNUM
    #  ICHAR += 1
    #  #[F:CLL]OBJFLG = 1
    #  GTBKINT(IINT) = "OBJFLG"
    #  GTBVINT(IINT) = 1
    #  IINT += 1
    #  Read [OMP]OMP0=GSZOPGNUM
    #  If !fstat Then
    #    #[F:CLL]CLLOBJ = [F:OMP]OBJ
    #    GTBKCHR(ICHAR) = "CLLOBJ"
    #    GTBVCHR(ICHAR) = [F:OMP]OBJ
    #    ICHAR += 1
    #  Endif
    #Else
    #  #[F:CLL]TYPFULOBJ = "CMG"
    #  GTBKCHR(ICHAR) = "TYPFULOBJ"
    #  GTBVCHR(ICHAR) = "CMG"
    #  ICHAR += 1
    #  #[F:CLL]NUMFULOBJ = GSZCMGNUM
    #  GTBKCHR(ICHAR) = "NUMFULOBJ"
    #  GTBVCHR(ICHAR) = GSZCMGNUM
    #  ICHAR += 1
    #  #[F:CLL]OBJFLG = 1
    #  GTBKINT(IINT) = "OBJFLG"
    #  GTBVINT(IINT) = 1
    #  IINT += 1
    #  Read [CMG]CMG0=GSZCMGNUM
    #  If !fstat Then
    #    #[F:CLL]CLLOBJ = [F:CMG]DES
    #    GTBKCHR(ICHAR) = "CLLOBJ"
    #    GTBVCHR(ICHAR) = [F:CMG]DES
    #    ICHAR += 1
    #  Endif
    #Endif
    # FGR 15/03/2010 : X3SUIVI63177 (fin)
    Raz CLBCLLFULOBJ
    Raz SZSUMUP
    If GCLLCMGOMP = 2 Then
      Read [OMP]OMP0=GSZOPGNUM
      If !fstat Then
        Read [HD5]HD50=GSZOPGNUM;"OMP"
        If fstat Then
          If [F:OMP]OBJ <> "" Then
            CLBCLLFULOBJ = [F:OMP]OBJ
          Else
            CLBCLLFULOBJ = [F:OMP]DES
          Endif
        Else
          CLBCLLFULOBJ = [F:HD5]CLOB
          If [F:HD5]CLOB <> [F:OMP]OBJ Then
            SZSUMUP = [F:OMP]OBJ
          Endif
        Endif
      Endif
    Else
      Read [CMG]CMG0=GSZCMGNUM
      If !fstat Then
        Read [HD5]HD50=GSZOPGNUM;"CMG"
        If fstat Then
          If [F:CMG]DES <> "" Then
            CLBCLLFULOBJ = [F:CMG]DES
          Else
            CLBCLLFULOBJ = [F:CMG]TTR
          Endif
        Else
          CLBCLLFULOBJ = [F:HD5]CLOB
          If [F:HD5]CLOB <> [F:CMG]DES Then
            SZSUMUP = [F:CMG]DES
          Endif
        Endif
      Endif
    Endif
    If SZSUMUP <> "" Then
      GTBKCHR(ICHAR) = "CLLOBJ"
      GTBVCHR(ICHAR) = SZSUMUP
      ICHAR += 1
      GTBKINT(IINT) = "OBJFLG"
      GTBVINT(IINT) = 1
      IINT += 1
    Endif
    GTBKCLOB(ICLOB) = "FULOBJ"
    GTBVCLOB(ICLOB) = CLBCLLFULOBJ
    ICLOB += 1
  Endif
  #[F:CLL]CLLTNTPRE = 0
  GTBKINT(IINT) = "CLLTNTPRE"
  GTBVINT(IINT) = 0
  IINT += 1
  #F:CLL]CLLDUR = 0
  GTBKINT(IINT) = "CLLDUR"
  GTBVINT(IINT) = 0
  IINT += 1
  #[F:CLL]CLLREP = SZREPNUM
  GTBKCHR(ICHAR) = "CLLREP"
  GTBVCHR(ICHAR) = SZREPNUM
  ICHAR += 1
  GTBKCHR(ICHAR) = "CLLPIOLEV"
  Call DEFPIO(405, GTBVCHR(ICHAR)) From SUBCLLB
  ICHAR += 1
  #[F:CLL]CLLCMGNUM = GSZCMGNUM
  GTBKCHR(ICHAR) = "CLLCMGNUM"
  GTBVCHR(ICHAR) = GSZCMGNUM
  ICHAR += 1
  #[F:CLL]CLLOPGNUM = GSZOPGNUM
  GTBKCHR(ICHAR) = "CLLOPGNUM"
  GTBVCHR(ICHAR) = GSZOPGNUM
  ICHAR += 1
  #[F:CLL]CLLOPGTYP = "OMP"
  GTBKCHR(ICHAR) = "CLLOPGTYP"
  GTBVCHR(ICHAR) = "OMP"
  ICHAR += 1
  #F:CLL]CLLCMGFLG = 1
  GTBKINT(IINT) = "CLLCMGFLG"
  GTBVINT(IINT) = 1
  IINT += 1
  #Origine
  #[F:CLL]CLLORI = 3
  # FGR 05/03/2010 : X3SUIVI62924 (début)
  #GTBKINT(IINT) = "CLLORI"
  #GTBVINT(IINT) = 3
  #IINT += 1
  GTBKCHR(ICHAR) = "CLLORIADI"
  GTBVCHR(ICHAR) = "MKT3"
  ICHAR += 1
  # FGR 05/03/2010 : X3SUIVI62924 (fin)
  #[F:CLL]CLLORITYP = mess(3,2993,1)
  #GTBKCHR(ICHAR) = "CLLORITYP"        # FGR 10/03/2010 : X3SUIVI62924
  #GTBVCHR(ICHAR) = mess(3,2993,1)     # FGR 10/03/2010 : X3SUIVI62924
  #ICHAR += 1
  #[F:CLL]CLLORIVCR = GSZOPGNUM
  GTBKCHR(ICHAR) = "CLLORIVCR"
  GTBVCHR(ICHAR) = GSZOPGNUM
  ICHAR += 1
  #[F:CLL]CLLORIVCRL = 0
  GTBKINT(IINT) = "CLLORIVCRL"
  GTBVINT(IINT) = 0
  IINT += 1
  #[F:CLL]CLLDON = 1
  GTBKINT(IINT) = "CLLDON"
  GTBVINT(IINT) = 1
  IINT += 1
  #[F:CLL]CLLRPO = ""
  GTBKCHR(ICHAR) = "CLLRPO"
  GTBVCHR(ICHAR) = ""
  ICHAR += 1
  Call CRECLL("TRTPHX5", 0, 0, SZCLLNUM, LERRCOD) From SUBCLLCC
  If LERRCOD <> 0 Then
    #Erreur lors de la génération de l'appel n°
    GMESSAGE = mess(890,182,1) - ':' - SZCLLNUM
    GERR = 1
    IOK = 0
  Else
    IOK = 1
  Endif
End

##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'un appel. (exemple)
#############################################################################
$CLL_SET_HEA_INFO
Local Integer INDEXE

  INDEXE = 0
  Case IMPZON
    When "CLLNUM"
      #Numéro de appel
    When "SALFCY"
      #Site
      INDEXE = find( "SALFCY", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL0]SALFCY = GTBVCHR(INDEXE)
      Endif
    When "CLLCMP"
      #Tiers
      INDEXE = find( "CLLCMP", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL0]CLLCMP = GTBVCHR(INDEXE)
      Endif
    #CHECK UNUSED_BEGIN
    When "CLLTYPCCN"
      #type personne
      [M:CLL0]CLLTYPCCN = "CCN"
    #CHECK UNUSED_END
    When "CLLCCN"
      #Interlocuteur
      INDEXE = find( "CLLCCN", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL0]CLLCCN = GTBVCHR(INDEXE)
      Endif
    When "CLLCOR"
      #Interlocuteur
      INDEXE = find( "CLLCOR", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL0]CLLCOR = GTBVCHR(INDEXE)
      Endif
    When "CLLOPP"
      #Affaire
      INDEXE = find( "CLLOPP", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL0]CLLOPP = GTBVCHR(INDEXE)
       Endif
    When "CLLDAT"
      #Date
      INDEXE = find("CLLDAT", GTBKDATETIME)
      If INDEXE <> 0 Then
        [M:CLL1]CLLDAT = GTBVDATETIME(INDEXE)
      Endif
      INDEXE = find( "CLLORITYP", GTBKINT)
      If INDEXE <> 0 Then
        [M:CLL1]CLLORITYP = GTBVINT(INDEXE)
      Endif
      # FGR 05/03/2010 : X3SUIVI62924 (début)
      INDEXE = find( "CLLORIADI", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL1]CLLORIADI = GTBVCHR(INDEXE)
        [M:CLL1]CLLORIAOB = func CRMUTIL150.GET_AOB_FROM_ORI([M:CLL1]CLLORIADI)
        Call DEFOBJORI([M:CLL1]CLLORIAOB, [M:CLL1]CLLORIAVA) From CRMUTIL150
      Endif
      #INDEXE = find( "CLLORI", GTBKINT)
      #If INDEXE <> 0 Then
      #  [M:CLL1]CLLORI = GTBVINT(INDEXE)
      #  Gosub DEFOBJORI From SUBCLLB
      #Endif
      # FGR 05/03/2010 : X3SUIVI62924 (début)
      INDEXE = find( "CLLORIVCR", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL1]CLLORIVCR = GTBVCHR(INDEXE)
      Endif
      INDEXE = find( "CLLORIVCRL", GTBKINT)
      If INDEXE <> 0 Then
        [M:CLL1]CLLORIVCRL = GTBVINT(INDEXE)
      Endif
      INDEXE = find( "CLLCMGNUM", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL1]CLLCMGNUM = GTBVCHR(INDEXE)
      Endif
      INDEXE = find( "CLLOPGNUM", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL1]CLLOPGNUM = GTBVCHR(INDEXE)
      Endif
      INDEXE = find( "CLLOPGTYP", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL1]CLLOPGTYP = GTBVCHR(INDEXE)
      Endif
      INDEXE = find( "CLLCMGFLG", GTBKINT)
      If INDEXE <> 0 Then
        [M:CLL1]CLLCMGFLG = GTBVINT(INDEXE)
      Endif
    When "CLLHOU"
      #Heure
      INDEXE = find( "CLLHOU", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL1]CLLHOU = GTBVCHR(INDEXE)
      Endif
    When "CLLTYP"
      #Type de l'appel
      INDEXE = find( "CLLTYP", GTBKINT)
      If INDEXE <> 0 Then
        [M:CLL0]CLLTYP = GTBVINT(INDEXE)
      Endif
    When "CLLSCP"
      #Script appel
      INDEXE = find( "CLLSCP", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL1]CLLSCP = GTBVCHR(INDEXE)
      Endif
    # FGR 15/03/2010 : X3SUIVI63177 (début)
    #When "FULOBJ"
    #  #Type Clob
    #  INDEXE = find( "TYPFULOBJ", GTBKCHR)
    #  If INDEXE <> 0 Then
    #    [M:CLL1]TYPFULOBJ = GTBVCHR(INDEXE)
    #  Endif
    #  #Chrono Clob
    #  INDEXE = find( "NUMFULOBJ", GTBKCHR)
    #  If INDEXE <> 0 Then
    #    [M:CLL1]NUMFULOBJ = GTBVCHR(INDEXE)
    #  Endif
    #  #Flag Clob
    #  INDEXE = find( "OBJFLG", GTBKINT)
    #  If INDEXE <> 0 Then
    #    [M:CLL1]OBJFLG = GTBVINT(INDEXE)
    #  Endif
    #  #synthese
    #  INDEXE = find( "CLLOBJ", GTBKCHR)
    #  If INDEXE <> 0 Then
    #    [M:CLL1]CLLOBJ = GTBVCHR(INDEXE)
    #  Endif
    When "FULOBJ"
      INDEXE = find("FULOBJ", GTBKCLOB)
      If INDEXE <> 0 Then
        [M:CLL1]FULOBJ = GTBVCLOB(INDEXE)
      Endif
      #Flag Clob
      INDEXE = find( "OBJFLG", GTBKINT)
      If INDEXE <> 0 Then
        [M:CLL1]OBJFLG = GTBVINT(INDEXE)
      Endif
      #synthese
      INDEXE = find( "CLLOBJ", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL1]CLLOBJ = GTBVCHR(INDEXE)
      Endif
    # FGR 15/03/2010 : X3SUIVI63177 (fin)
    When "CLLDUR"
      #Durée de l'appel
      INDEXE = find( "CLLDUR", GTBKINT)
      If INDEXE <> 0 Then
        [M:CLL3]CLLDUR = GTBVINT(INDEXE)
      Endif
      #Nb tentatives précédentes
      INDEXE = find( "CLLTNTPRE", GTBKINT)
      If INDEXE <> 0 Then
        [M:CLL3]CLLTNTPRE = GTBVINT(INDEXE)
      Endif
     When "CLLREP"
      #Représentant
      INDEXE = find( "CLLREP", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL1]CLLREP = GTBVCHR(INDEXE)
      Endif
      # --------------------------------------
      # FGR 26/08/2016 : X3SUIVI117877 (début)
      If [M:CLL0]CLLCCN = "" Then
        # Si pas d'interlocuteur : on prend les téléphones de l'adresse par défaut du client
        Read [BPC]BPC0=[M:CLL0]CLLCMP
        If !fstat Then
          Read [BPA]BPA0=1;[M:CLL0]CLLCMP;[F:BPC]BPAADD
          If !fstat Then
            [M:CLL1]CLLETS = [F:BPA]TEL(0) # Fixe
            [M:CLL1]CLLMOB = [F:BPA]TEL(4) # Portable
            [M:CLL1]CLLCCNCRY = [F:BPA]CRY
            [M:CLL1]CLLEML = [F:BPA]WEB(0)
          Endif
        Endif
      Endif
      # FGR 26/08/2016 : X3SUIVI117877 (fin)
      # --------------------------------------
     When "CLLPIOLEV"
      #Niveau de priorité
      INDEXE = find( "CLLPIOLEV", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL1]CLLPIOLEV = GTBVCHR(INDEXE)
      Endif
     When "CLLDON"
      #Effectué
      INDEXE = find( "CLLDON", GTBKINT)
      If INDEXE <> 0 Then
        [M:CLL0]CLLDON = GTBVINT(INDEXE)
      Endif
  Endcase
Return

