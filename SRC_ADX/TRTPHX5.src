#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
# Etape 5 de la définition d'une campagne d'appels                  Module CRM           6 décembre 2000 #
##########################################################################################################
# Ventilation de la campagne
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GITYPVEN
Global Integer GIVENAUTO
Global Date GDOPGSTR
Global Date GDOPGEND
Global Char GTBKCHR(50)(1..50)       # Paramètres caractères
Global Char GTBVCHR(250)(1..50)
Global Char GTBKINT(50)(1..50)       # Paramètres entiers
Global Integer GTBVINT(1..50)
Global Char GTBKDEC(50)(1..50)       # Paramètres décimaux
Global Decimal GTBVDEC(1..50)
Global Char GTBKDATETIME(50)(1..50)  # Paramètres Dates AAAAMMJJHHMMSS
Global Date GTBVDATETIME(1..50)
Global Char GTBKCLOB(50)(1..50)      # Paramètres Textes riches
Global Clbfile GTBVCLOB (5)(1..50)

  GITYPVEN = 0
  GIVENAUTO = 1
  GDOPGSTR = [00/00/00]
  GDOPGEND = [00/00/00]
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
  If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
  If !clalev([F:SEC]) : Local File SELCMG [SEC] : Endif
  If !clalev([F:SCL]) : Local File SELCMGLIS [SCL] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:DIH]) : Local File DIAHOU [DIH] : Endif
  If !clalev([F:TWD]) : Local File TABWEEDIA [TWD] : Endif
  If !clalev([F:HD5]) : Local File HD5CLOB [HD5] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If GITYPVEN Then
    ETABOU(GSPE4) = 1
  Else
    ETABOU(GSPE4) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Char SZBPTYP(GLONABR)
Local Char SZROBJCLL(30)
Local Integer IROBLCLL

  [M:PHX5]ASKDON = 0
  [M:PHX5]PUTREPOBJ = 0
  SZBPTYP = ""
  GISTECPL(GICSTEP-1) = 0
  #Commence d'abord par supprimer tous les appels déjà générés pour cette campagne
  If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
  Call DEBTRANS From GLOCK
  Trbegin [CLL]
  Delete [CLL] Where [F:CLL]CLLOPGTYP = "OMP" and [F:CLL]CLLOPGNUM = GSZOPGNUM and [F:CLL]CLLCMGFLG > 0
  If fstat Then
    Rollback
  Else
    Commit
  Endif
  #Affiche l'objectif quotidien d'appels hors téléacteurs
  #Obtient le paramètre.
  Call PARAML("", "ROBJCLL", SZROBJCLL) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  IROBJCLL = val(SZROBJCLL)
  [M:PHX5]REPOBJCLL = IROBJCLL
  #Affiche le titre de l'opération campagne d'appel
  Read [OMP]OMP0=GSZOPGNUM
  If !fstat Then
    [M:PHX5]FCY = [F:OMP]FCY
    [M:PHX5]OPGDES = [F:OMP]DES
    [M:PHX5]OPGSTR = [F:OMP]OMPSTR
    [M:PHX5]OPGCMGEND = [F:OMP]OMPEND
    GDOPGSTR = [F:OMP]OMPSTR
    GDOPGEND = [F:OMP]OMPEND
    [M:PHX5]OPGDUR = nday([F:OMP]OMPEND) - nday([F:OMP]OMPSTR)
    [M:PHX5]OPGDUR += 1
    [M:PHX5]OPGDURBAS = mess(2,976,1) #jours
    [M:PHX5]SCPNUM = [F:OMP]SCPNUM
  Endif
  #Affiche le nombre d'appels à affecter
  Read [SEC]SEC0=GSZOPGNUM;"CCN"
  If !fstat Then
    If [F:SEC]USEQUR = 2 Then
      [M:PHX5]NBQCLLASS = [F:SEC]SELREC
    Else
      Filter [SEC] Where [F:SEC]OPGNUM = GSZOPGNUM and [F:SEC]SELTBL <> "CCN"
      For [SEC]
        SZBPTYP = [F:SEC]SELTBL
        Break
      Next
      Filter [SEC]
      Read [SEC]SEC0=GSZOPGNUM;SZBPTYP
      If !fstat Then
        [M:PHX5]NBQCLLASS = [F:SEC]SELREC
      Endif
    Endif
  Endif
  #S'il n'y a aucune sélection, on ne fait rien.
  If [M:PHX5]NBQCLLASS <= 0 Then
    GMESSAGE = mess(430,196,1) #Il n'y a aucun appel à ventiler. Fonction inaccessible.
    GERR = 2
    FIN = 1
    Return
  Endif
  #Remplit le tableau des téléacteurs.
  Call TEMPON("L") From GESECRAN
  If GIALL = 2 Then
    Gosub LOADTELE
  Elsif GIALL = 1 Then
    Gosub LOADALL
  Elsif GIALL = 0 Then
    Gosub LOADREP
  Endif
  Call TEMPOFF From GESECRAN
  #Affiche le nombre de téléacteurs sélectionnés.
  [M:PHX5]NBQREP = [M:PHX5]NBVEN
  Affzo [M:PHX5]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:PHX5]
  Kill GITYPVEN
  Kill GIVENAUTO
  Kill GDOPGSTR
  Kill GDOPGEND
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub ONDISPO
    When "B"
      Gosub ONCAL
    When "C"
      Gosub ONACCOUNT
    When "D"
      Gosub ONCONFIRM
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONDISPO
  GITYPVEN = 1
  Call DOVENT(0)
Return

##########################################################################################################
$ONCAL
  GITYPVEN = 2
  Call DOVENT(0)
Return

##########################################################################################################
$ONACCOUNT
  GITYPVEN = 3
  Call DOVENT(0)
Return

##########################################################################################################
$ONCONFIRM
  If !GITYPVEN Then
    Return
  Endif
  Call DOVENT(1)
  Call SETOMPINF([M:PHX5]NBQCLLASS)
  GISTECPL(GICSTEP-1) = 1
  FIN = 1
Return

##########################################################################################################
$LOADTELE
Local Char SZMSNEND(30)
Local Date DMSNEND
Local Char SZFNC(30)
Local Integer IFNC
Local Char SZSTA(30)
Local Integer ISTA
Local Integer IT
Local Integer ISOK
Local Integer ILCLLDEL
Local Integer ILDAYASS
Local Integer INBWDAY
Local Integer INBWHOU

  SZMSNEND = ""
  DMSNEND = [00/00/00]
  SZFNC = ""
  IFNC = 0
  SZSTA = ""
  ISTA = 0
  IT = 0
  ILCLLDEL = 0
  ILDAYASS = 0
  INBWDAY = 0
  INBWHOU = 0
  ISOK = 1
  Filter [REP] Where [F:REP]AUSNUM <> ""
  For [REP]REP1
    If IT >= dim([M:PHX5]REP)-1 Then
      Break
    Endif
    If [F:REP]REPNUM <> "" Then
      Read [AUS]CODUSR=[F:REP]AUSNUM
      If !fstat Then
        Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
        If SZFNC = "" Then
          IFNC = 1
        Else
          IFNC = val(SZFNC)
        Endif
        Call PARAMUTIL("AUSCRMB", SZSTA, [F:REP]AUSNUM, "") From SUBAUS
        If SZSTA = "" Then
          ISTA = 1
        Else
          ISTA = val(SZSTA)
        Endif
        Call PARAMUTIL("AUSCRMD", SZMSNEND, [F:REP]AUSNUM, "") From SUBAUS
        If SZMSNEND = "" Then
          DMSNEND = [00/00/00]
        Else
          DMSNEND = gdat$(val(right$(SZMSNEND,7)), val(seg$(SZMSNEND,5,6)),val(left$(SZMSNEND,4)))
        Endif
        If IFNC = 3 Then
          If ISTA = 1 Then
            #Téléacteur permanent
            [M:PHX5]REPNUM(IT) = [F:REP]REPNUM
            If [F:REP]REPNAM = "" Then
              [M:PHX5]REP(IT) = [F:REP]REPNUM
            Else
              [M:PHX5]REP(IT) = [F:REP]REPNAM
            Endif
            [M:PHX5]CLLOBJ(IT) = [F:REP]OBJCLL
            Call CPTCLLDEL([M:PHX5]REPNUM(IT), ILCLLDEL)
            [M:PHX5]CLLDEL(IT) = ILCLLDEL
            Call CPTDAYASS([M:PHX5]REPNUM(IT), 0, ILDAYASS)
            [M:PHX5]DAYCLLASS(IT) = ILDAYASS
            Call GETWORKDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR, [M:PHX5]OPGCMGEND, INBWDAY, INBWHOU, ISOK) From CRM_UTIL
            If ISOK Then
              [M:PHX5]NBQWKDDAY(IT) = INBWDAY
              [M:PHX5]NBQWKDHOU(IT) = INBWHOU
            Endif
            IT += 1
          Else
            If DMSNEND >= [M:PHX5]OPGCMGEND Then
              [M:PHX5]REPNUM(IT) = [F:REP]REPNUM
              [M:PHX5]REP(IT) = [F:REP]REPNAM
              [M:PHX5]CLLOBJ(IT) = [F:REP]OBJCLL
              Call CPTCLLDEL([M:PHX5]REPNUM(IT), ILCLLDEL)
              [M:PHX5]CLLDEL(IT) = ILCLLDEL
              Call CPTDAYASS([M:PHX5]REPNUM(IT), 0, ILDAYASS)
              [M:PHX5]DAYCLLASS(IT) = ILDAYASS
              Call GETWORKDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR, [M:PHX5]OPGCMGEND, INBWDAY, INBWHOU, ISOK) From CRM_UTIL
              If ISOK Then
                [M:PHX5]NBQWKDDAY(IT) = INBWDAY
                [M:PHX5]NBQWKDHOU(IT) = INBWHOU
              Endif
              IT += 1
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [REP]
  [M:PHX5]NBVEN = IT
  Affzo [M:PHX5]1-99
Return

##########################################################################################################
$LOADALL
Local Char SZMSNEND(30)
Local Date DMSNEND
Local Char SZFNC(30)
Local Integer IFNC
Local Char SZSTA(30)
Local Integer ISTA
Local Integer IT
Local Integer ISOK
Local Integer ILCLLDEL
Local Integer ILDAYASS
Local Integer INBWDAY
Local Integer INBWHOU

  SZMSNEND = ""
  DMSNEND = [00/00/00]
  SZFNC = ""
  IFNC = 0
  SZSTA = ""
  ISTA = 0
  IT = 0
  ILCLLDEL = 0
  ILDAYASS = 0
  INBWDAY = 0
  INBWHOU = 0
  ISOK = 1
  Filter [REP] Where [F:REP]AUSNUM <> ""
  For [REP] REP1
    If IT >= dim([M:PHX5]REP)-1 Then
      Break
    Endif
    If [F:REP]REPNUM <> "" Then
      Read [AUS]CODUSR=[F:REP]AUSNUM
      If !fstat Then
        Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
        If SZFNC = "" Then
          IFNC = 1
        Else
          IFNC = val(SZFNC)
        Endif
        Call PARAMUTIL("AUSCRMB", SZSTA, [F:REP]AUSNUM, "") From SUBAUS
        If SZSTA = "" Then
          ISTA = 1
        Else
          ISTA = val(SZSTA)
        Endif
        Call PARAMUTIL("AUSCRMD", SZMSNEND, [F:REP]AUSNUM, "") From SUBAUS
        If SZMSNEND = "" Then
          DMDNEND = [00/00/00]
        Else
          DMSNEND = gdat$(val(right$(SZMSNEND,7)), val(seg$(SZMSNEND,5,6)),val(left$(SZMSNEND,4)))
        Endif
        If IFNC = 3 Then
          If ISTA = 1 Then
            #Téléacteur permanent
            [M:PHX5]REPNUM(IT) = [F:REP]REPNUM
            If [F:REP]REPNAM = "" Then
              [M:PHX5]REP(IT) = [F:REP]REPNUM
            Else
              [M:PHX5]REP(IT) = [F:REP]REPNAM
            Endif
            [M:PHX5]CLLOBJ(IT) = [F:REP]OBJCLL
            Call CPTCLLDEL([M:PHX5]REPNUM(IT), ILCLLDEL)
            [M:PHX5]CLLDEL(IT) = ILCLLDEL
            Call CPTDAYASS([M:PHX5]REPNUM(IT), 0, ILDAYASS)
            [M:PHX5]DAYCLLASS(IT) = ILDAYASS
            Call GETWORKDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR, [M:PHX5]OPGCMGEND, INBWDAY, INBWHOU, ISOK) From CRM_UTIL
            If ISOK Then
              [M:PHX5]NBQWKDDAY(IT) = INBWDAY
              [M:PHX5]NBQWKDHOU(IT) = INBWHOU
            Endif
            IT += 1
          Else
            If DMSNEND >= [M:PHX5]OPGCMGEND Then
              [M:PHX5]REPNUM(IT) = [F:REP]REPNUM
              If [F:REP]REPNAM = "" Then
                [M:PHX5]REP(IT) = [F:REP]REPNUM
              Else
                [M:PHX5]REP(IT) = [F:REP]REPNAM
              Endif
              [M:PHX5]CLLOBJ(IT) = [F:REP]OBJCLL
              Call CPTCLLDEL([M:PHX5]REPNUM(IT), ILCLLDEL)
              [M:PHX5]CLLDEL(IT) = ILCLLDEL
              Call CPTDAYASS([M:PHX5]REPNUM(IT), 0, ILDAYASS)
              [M:PHX5]DAYCLLASS(IT) = ILDAYASS
              Call GETWORKDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR, [M:PHX5]OPGCMGEND, INBWDAY, INBWHOU, ISOK) From CRM_UTIL
              If ISOK Then
                [M:PHX5]NBQWKDDAY(IT) = INBWDAY
                [M:PHX5]NBQWKDHOU(IT) = INBWHOU
              Endif
              IT += 1
            Endif
          Endif
        Else
          [M:PHX5]REPNUM(IT) = [F:REP]REPNUM
          If [F:REP]REPNAM = "" Then
            [M:PHX5]REP(IT) = [F:REP]REPNUM
          Else
            [M:PHX5]REP(IT) = [F:REP]REPNAM
          Endif
          [M:PHX5]CLLOBJ(IT) = [F:REP]OBJCLL
          Call CPTCLLDEL([M:PHX5]REPNUM(IT), ILCLLDEL)
          [M:PHX5]CLLDEL(IT) = ILCLLDEL
          Call CPTDAYASS([M:PHX5]REPNUM(IT), 0, ILDAYASS)
          [M:PHX5]DAYCLLASS(IT) = ILDAYASS
          Call GETWORKDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR, [M:PHX5]OPGCMGEND, INBWDAY, INBWHOU, ISOK) From CRM_UTIL
          If ISOK Then
            [M:PHX5]NBQWKDDAY(IT) = INBWDAY
            [M:PHX5]NBQWKDHOU(IT) = INBWHOU
          Endif
          IT += 1
        Endif
      Endif
    Endif
  Next
  Filter [REP]
  [M:PHX5]NBVEN = IT
  Affzo [M:PHX5]1-99
Return

##########################################################################################################
$LOADREP
Local Integer IT
Local Integer ILCLLDEL
Local Integer ILDAYASS
Local Integer INBWDAY
Local Integer INBWHOU
Local Integer ISOK

  ILCLLDEL = 0
  ILDAYASS = 0
  INBWDAY = 0
  INBWHOU = 0
  ISOK = 1
  For IT = 0 To dim([M:PHO5]REP)-1
    If [M:PHO5]REP(IT) = "" Then
      Break
    Endif
    [M:PHX5]REPNUM(IT) = [M:PHO5]REP(IT)
    Read [REP]REP0=[M:PHX5]REPNUM(IT)
    If !fstat Then
      If [F:REP]REPNAM = "" Then
        [M:PHX5]REP(IT) = [F:REP]REPNUM
      Else
        [M:PHX5]REP(IT) = [F:REP]REPNAM
      Endif
      [M:PHX5]CLLOBJ(IT) = [F:REP]OBJCLL
      Call CPTCLLDEL([M:PHX5]REPNUM(IT), ILCLLDEL)
      [M:PHX5]CLLDEL(IT) = ILCLLDEL
      Call CPTDAYASS([M:PHX5]REPNUM(IT), 0, ILDAYASS)
      [M:PHX5]DAYCLLASS(IT) = ILDAYASS
      Call GETWORKDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR, [M:PHX5]OPGCMGEND, INBWDAY, INBWHOU, ISOK) From CRM_UTIL
      If ISOK Then
        [M:PHX5]NBQWKDDAY(IT) = INBWDAY
        [M:PHX5]NBQWKDHOU(IT) = INBWHOU
      Endif
    Endif
  Next
  [M:PHX5]NBVEN = IT
  Affzo [M:PHX5]1-99
Return

##########################################################################################################
Subprog CPTCLLDEL(SZREPNUM, ICLLDEL)
Value Char SZREPNUM
Variable Integer ICLLDEL

  ICLLDEL = 0
  Filter [CLL] Where [F:CLL]CLLREP = SZREPNUM and [F:CLL]CLLDON <> 2 and [F:CLL]CLLTYP = 2 and [F:CLL]CLLDATX < date$
  #For [CLL]CLL4                       # FGR 13/10/2015 : X3SUIVI111690
  #  ICLLDEL += 1                      # FGR 13/10/2015 : X3SUIVI111690
  #Next                                # FGR 13/10/2015 : X3SUIVI111690
  ICLLDEL = rowcount([F:CLL])          # FGR 13/10/2015 : X3SUIVI111690
  Filter [CLL]
End

##########################################################################################################
Subprog CPTDAYASS(SZREPNUM, ICLLMORE, IDAYASS)
Value Char SZREPNUM
Value Integer ICLLMORE
Variable Integer IDAYASS

Local Char SZFNC(30)
Local Integer IFNC
Local Integer IOKFLG
Local Integer IWORKDAY
Local Integer INBWORKDAY
Local Integer INBWORKHOU
Local Integer IDAYWEE
Local Integer IOBJCLL
Local Integer INBCLL
Local Integer GIOPGSTR
Local Integer GIOPGEND
Local Integer ID
Local Date DCURDAT
Local Integer IMESSREP

  SZFNC = ""
  IFNC = 0
  IOKFLG = 1
  IMESSREP = 0
  IWORKDAY = 0
  INBWORKDAY = 0
  INBWORKHOU = 0
  IDAYWEE = 0
  IOBJCLL = 0
  INBCLL = 0
  GIOPGSTR = nday(GDOPGSTR)
  GIOPGEND = nday(GDOPGEND)
  ID = 0
  DCURDAT = GDOPGSTR
  #Lecture de l'objectif d'appels.
  Read [REP]REP0=SZREPNUM
  If fstat Then
    IDAYASS = 0
    End
  Else
    Read [AUS]CODUSR=[F:REP]AUSNUM
    If fstat Then
      IDAYASS = 0
      End
    Else
      Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
      If SZFNC = "" Then
        IFNC = 1
      Else
        IFNC = val(SZFNC)
      Endif
      If IFNC <> 3 Then
        IOBJCLL = [M:PHX5]REPOBJCLL
      Else
        If [F:REP]OBJCLL = 0 Then
          If [M:PHX5]ASKDON Then
            If [M:PHX5]PUTREPOBJ Then
              IOBJCLL = [M:PHX5]REPOBJCLL
            Else
              IOBJCLL = 0
            Endif
          Else
            #Certains téléacteurs ne disposent pas d'objectif d'appels.
            # Souhaitez-vous leur affecter l'objectif d'appels hors téléacteurs.
            Call OUINON(mess(705,182,1), IMESSREP) From GESECRAN
            If IMESSREP = 2 Then
              [M:PHX5]PUTREPOBJ = 1
              IOBJCLL = [M:PHX5]REPOBJCLL
            Else
              [M:PHX5]PUTREPOBJ = 0
              IOBJCLL = 0
            Endif
            [M:PHX5]ASKDON = 1
          Endif
        Else
          IOBJCLL = [F:REP]OBJCLL
        Endif
      Endif
    Endif
  Endif
  #Calcul du nombre d'appels déjà programmés pour ce téléacteur
  Filter [CLL] Where [F:CLL]CLLREP = SZREPNUM and [F:CLL]CLLDON <> 2 and [F:CLL]CLLTYP = 2 and [F:CLL]CLLDATX >= GDOPGSTR and [F:CLL]CLLDATX <= GDOPGEND
#  For [CLL]CLL4               # FGR 13/10/2015 : X3SUIVI111690
#    INBCLL += 1               # FGR 13/10/2015 : X3SUIVI111690
#  Next                        # FGR 13/10/2015 : X3SUIVI111690
  INBCLL = rowcount([F:CLL])   # FGR 13/10/2015 : X3SUIVI111690
  Filter [CLL]
  #Calcul du nombre de jours travaillés pendant l'opération.
  Call GETWORKDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR, [M:PHX5]OPGCMGEND, INBWORKDAY, INBWORKHOU, IOKFLG) From CRM_UTIL
  #Calcul de la moyenne des appels affectables par jour.
  If INBWORKDAY = 0 Then
    IDAYASS = 0
  Else
    If ICLLMORE > 0 Then
      IDAYASS = IOBJCLL - (INBCLL / INBWORKDAY) - (ICLLMORE / INBWORKDAY)
    Else
      IDAYASS = IOBJCLL - (INBCLL / INBWORKDAY)
    Endif
  Endif
End

##########################################################################################################
Subprog ISWORKED(SZREPNUM, IDAY, IWORKED)
Value Char SZREPNUM
Value Integer IDAY
Variable Integer IWORKED

Local Char SZFULTIM(30)
Local Integer IFULTIM
Local Char SZDIAHOU(30)
Local Integer IK

  IK = 0
  IWORKED = 0
  Read [REP]REP0=SZREPNUM
  If fstat Then
    End
  Else
    Read [AUS]CODUSR=[F:REP]AUSNUM
    If fstat Then
      End
    Else
      Call PARAMUTIL("AUSCRMG", SZFULTIM, [F:REP]AUSNUM, "") From SUBAUS
      If SZFULTIM = "" Then
        IFULTIM = 1
      Else
        IFULTIM = val(SZFULTIM)
      Endif
      Call PARAMUTIL("AUSCRMH", SZDIAHOU, [F:REP]AUSNUM, "") From SUBAUS
      If IFULTIM = 2 Then
        If IDAY < 6 Then
          If IDAY > 0 Then
            IWORKED = 1
          Endif
        Endif
      Else
        If SZDIAHOU = "" Then
          If IDAY < 6 Then
            If IDAY > 0 Then
              IWORKED = 1
             Endif
          Endif
        Else
          Read [TWD]TWD0=SZDIAHOU
          If fstat Then
            If IDAY < 6 Then
              If IDAY > 0
                IWORKED = 1
              Endif
            Endif
          Else
            If [F:TWD]DAYCAP(IDAY-1) > 0 Then
              IWORKED = 1
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog DOVENT(IPOURDEVRAI)
Value Integer IPOURDEVRAI

Local Integer IY
Local Integer ITOTPRC
Local Integer IVENTDISP

  ITOTPRC = 0
  IVENTDISP = 0
  If GITYPVEN <> 3 Then
    If IPOURDEVRAI Then
      Call TEMPON("E") From GESECRAN
    Else
      Call TEMPON("C") From GESECRAN
    Endif
  Else
    If GINTRA Then
      If IPOURDEVRAI Then
        Call TEMPON("E") From GESECRAN
      Else
        Call TEMPON("C") From GESECRAN
      Endif
    Endif
  Endif
  #Si le total des pourcentages de ventilation manuelle n'est pas égal à 100, on repasse en ventilation auto.
  For IY = 0 To dim([M:PHX5]REP)-1
    If [M:PHX5]REPNUM(IY) = "" Then
      Break
    Endif
    ITOTPRC += [M:PHX5]MANBRD(IY)
  Next
  If !GIVENAUTO Then
    If ITOTPRC < 100 Then
      GIVENAUTO = 1
      #Remise à zéro des pourcentages
      For IY = 0 To dim([M:PHX5]REP)-1
        If [M:PHX5]REPNUM(IY) = "" Then
          Break
        Endif
        [M:PHX5]MANBRD(IY) = 0
      Next
    Endif
  Endif
  If GITYPVEN = 1 Then
    #Selon disponibilité
    If GIVENAUTO Then
      #Automatique
      Gosub AUTODISP
    Else
      #Manuelle
      Gosub MANUDISP
    Endif
  Elsif GITYPVEN = 2 Then
    #Selon calendrier
    If GIVENAUTO Then
      #Automatique
      Gosub AUTOCAL
    Else
      #Manuelle
      Gosub MANUCAL
    Endif
  Elsif GITYPVEN = 3 Then
    #Selon attribution de compte
    Gosub ACCOUNT
  Endif
  If GITYPVEN <> 3 Then
     Call TEMPOFF From GESECRAN
  Else
    If GINTRA Then
      Call TEMPOFF From GESECRAN
    Endif
  Endif
End

##########################################################################################################
# Ventilation selon disponibilité automatique
##########################################################
$AUTODISP
  IVENTDISP = 1
  Call SETASSCLL(2)
  Gosub VENTCAL
  Affzo [M:PHX5]1-99
Return

##########################################################################################################
# Ventilation selon disponibilité manuelle
##########################################################
$MANUDISP
  IVENTDISP = 1
  Call SETASSCLL(1)
  Gosub VENTCAL
  Affzo [M:PHX5]1-99
Return

##########################################################################################################
# Ventilation selon calendrier automatique
##########################################################
$AUTOCAL
  IVENTDISP = 0
  Call SETASSCLL(2)
  Gosub VENTCAL
  Affzo [M:PHX5]1-99
Return

##########################################################################################################
# Ventilation selon calendrier manuelle
##########################################################
$MANUCAL
  IVENTDISP = 0
  Call SETASSCLL(1)
  Gosub VENTCAL
  Affzo [M:PHX5]1-99
Return

##########################################################################################################
# Ventilation selon attribution de compte
##########################################################
$ACCOUNT
Local Integer ISOK
Local Integer IFOUND
Local Integer IH
Local Integer ITOTBPRASS
Local Integer IREMBPRASS
Local Integer IOPGSTR
Local Integer IOPGEND
Local Integer ISOK
Local Integer INBDAYREP               #Nombre d'appel à affecter par jour travaillé pour chaque téléacteur.
Local Integer ISVNBDAYREP             #Mémoire du nombre d'appels à affecter par jour travaillé pour chaque téléacteur.
Local Integer IASSCLLDON              #Nombre d'appel restant a affecter
Local Integer IASSREPDON              #Nombre d'appels créés pour un téléacteur.
Local Integer IASSDAYDON              #Nombre d'appels créés pour une journée de téléacteur.
Local Date DNEXASSDAY
Local Date DASSDAY                    #Date de l'appel à créer
Local Char SZASSHOU(30)               #Heure de l'appel à créer
Local Integer INBRECPRO               #Nombre de destinataires traités.
Local Integer INBCLLDAY               #Nombre d'appels déjà programmés dans l'agenda d'un téléacteur pour une journée.
Local Integer INBQBPRASS              #Nombre de destinataires affectables pour un téléacteur
Local Integer IDAYCLLASSX             #Moyenne d'appels affectables par jour ventilation selon compte comprise.
Local Integer COK
Local Integer CCOUNT
Local Char SZCURREP(GLONREP)          #teleacteur courant

  COK = 0
  CCOUNT = 0
  IFOUND = 0
  IDAYCLLASSX = 0
  INBQBPRASS = 0
  INBCLLDAY = 0
  INBRECPRO = 0
  IOPGSTR = nday([M:PHX5]OPGSTR)
  IOPGEND = nday([M:PHX5]OPGCMGEND)
  ISOK = 1
  INBDAYREP = 0
  DNEXASSDAY = [00/00/00]
  SZASSHOU = "0900"
  IASSREPDON = 0               #Nombre d'appels créés pour un téléacteur.
  IASSDAYDON = 0               #Nombre d'appels créés pour une journée de téléacteur.
  ISOK = 1
  IH = 0
  ITOTBPRASS = 0
  IREMBPRASS = 0
  SZCURREP = ""
  #Initialise DASSDAY avec un jour travaillé
  If [M:PHX5]NBVEN > 0 Then
    ISOK = 1
    Read [REP]REP0=[M:PHX5]REPNUM(IH)
    If fstat Then
      DASSDAY = [M:PHX5]OPGSTR
    Else
      Call GETNEXTWDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR-1, DNEXASSDAY, ISOK) From CRM_UTIL
      If ISOK Then
        DASSDAY = DNEXASSDAY
      Else
        DASSDAY = [M:PHX5]OPGSTR
      Endif
    Endif
  Else
    DASSDAY = [M:PHX5]OPGSTR
  Endif
  Gosub UNMARKSCL
  If !GINTRA Then
    Call OUVRE_BOITE(mess(366,196,1), [M:PHX5]NBVEN) From GESECRAN   #Calcul des attributions de compte.
  Endif
  CCOUNT = 0
  For IH = 0 To [M:PHX5]NBVEN-1
    If [M:PHX5]REP(IH) = "" Then       # FGR 13/10/2015 : X3SUIVI111690
      Break                            # FGR 13/10/2015 : X3SUIVI111690
    Else                               # FGR 13/10/2015 : X3SUIVI111690
      ISOK = 0
      Call GETREPBPR([M:PHX5]REPNUM(IH), INBQBPRASS, ISOK)
      [M:PHX5]NBQBPRASS(IH) = INBQBPRASS
      Call CPTDAYASS([M:PHX5]REPNUM(IH), [M:PHX5]NBQBPRASS(IH), IDAYCLLASSX)
      [M:PHX5]DAYCLLASSX(IH) = IDAYCLLASSX
      ITOTBPRASS += [M:PHX5]NBQBPRASS(IH)
      CCOUNT += 1
      If !GINTRA Then
        Call AFF_BOITE ([M:PHX5]REP(IH), CCOUNT, COK) From GESECRAN
      Endif
    Endif                              # FGR 13/10/2015 : X3SUIVI111690
  Next
  IREMBPRASS = [M:PHX5]NBQCLLASS - ITOTBPRASS
  If GIVENAUTO Then
    Call SETASSCLLX(2, IREMBPRASS)
  Else
    Call SETASSCLLX(1, IREMBPRASS)
  Endif
  If !GINTRA Then
    Call FERME_BOITE From GESECRAN
  Endif
  #Premier round : Ventilation selon compte pure.
  If !GINTRA Then
    Call OUVRE_BOITE(mess(367,196,1), [M:PHX5]NBVEN) From GESECRAN   #Programmation des appels nominatifs.
  Endif
  CCOUNT = 0
  IASSREPDON = 0               #Nombre d'appels créés pour un téléacteur.
  IASSDAYDON = 0               #Nombre d'appels créés pour une journée de téléacteur.
  For IH = 0 To [M:PHX5]NBVEN-1
    [M:PHX5]ASSCLL(IH) = 0
  Next
  #Etape 2
  IH = 0
  While IH < [M:PHX5]NBVEN
    If [M:PHX5]REP(IH) = "" Then       # FGR 13/10/2015 : X3SUIVI111690
      Break                            # FGR 13/10/2015 : X3SUIVI111690
    Else                               # FGR 13/10/2015 : X3SUIVI111690
      # --------------------------------------------------------------
      # FGR 03/11/2015 : X3SUIVI111690 (début) à réinitialiser quand on change de téléacteur
      IASSREPDON = 0               # Nombre d'appels créés pour un téléacteur.
      IASSDAYDON = 0               # Nombre d'appels créés pour une journée de téléacteur.
      # FGR 03/11/2015 : X3SUIVI111690 (fin)
      # --------------------------------------------------------------
      If [M:PHX5]NBQBPRASS(IH) > 0 Then
        IFOUND = 0
        If GSZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = "CCN" and [F:SCL]REPNUM = [M:PHX5]REPNUM(IH)
        Else
          Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN" and [F:SCL]REPNUM = [M:PHX5]REPNUM(IH)
        Endif
        For [SCL]
          If INBRECPRO >= [M:PHX5]NBQCLLASS Then
            Break
          Endif
          IFOUND = 1
          #If IASSREPDON = [M:PHX5]NBQBPRASS(IH) Then  # FGR 04/04/2013 : X3SUIVI88351
          If IASSREPDON > [M:PHX5]NBQBPRASS(IH) Then   # FGR 04/04/2013 : X3SUIVI88351
            #Définit la date de fin de campagne pour le téléacteur.
            [M:PHX5]OPGEND(IH) = DASSDAY
            [M:PHX5]DAYAVEASS(IH) = INBDAYREP
            [M:PHX5]ASSCLL(IH) += [M:PHX5]NBQBPRASS(IH)    # FGR 13/10/2015 : X3SUIVI111690
            #Définit les propriétés du téléacteur suivant
            IH += 1
            ISOK = 1
            Read [REP]REP0=[M:PHX5]REPNUM(IH)
            If fstat Then
              DASSDAY = [M:PHX5]OPGSTR
            Else
              Call GETNEXTWDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR - 1, DNEXASSDAY, ISOK) From CRM_UTIL
              If ISOK Then
                DASSDAY = DNEXASSDAY
              Else
                DASSDAY = [M:PHX5]OPGSTR
              Endif
            Endif
            IASSREPDON = 0
            IASSDAYDON = 0
          Endif
          If [M:PHX5]NBQWKDDAY(IH) = 0 Then
            INBDAYREP = 0
          Else
            If [M:PHX5]NBQBPRASS(IH) = 0 Then
              INBDAYREP = 0
            Else
              INBDAYREP = fix([M:PHX5]NBQBPRASS(IH) / [M:PHX5]NBQWKDDAY(IH)) + 1
            Endif
          Endif
          If IASSDAYDON = INBDAYREP Then
            Read [REP]REP0=[M:PHX5]REPNUM(IH)
            If !fstat Then
              ISOK = 1
              Call GETNEXTWDAY([F:REP]REPNUM, [F:REP]AUSNUM, DASSDAY, DNEXASSDAY, ISOK) From CRM_UTIL
              If ISOK Then
                DASSDAY = DNEXASSDAY
              Endif
            Else
              DASSDAY += 1
            Endif
            IASSDAYDON = 0
          Endif
          If INBDAYREP = 0 Then
            IASSREPDON = 0
            IASSDAYDON = 0
          Else
            IASSREPDON += 1
            IASSDAYDON += 1
            [M:PHX5]ASSCLL(IH) += 1
            If IPOURDEVRAI Then
              If GSZTYPSEA = "CCN" Then
                Call CRECLLOPG([F:SCL]BPRNUM, [F:SCL]RECNUM, [M:PHX5]REPNUM(IH), DASSDAY, SZASSHOU, ISOK)
              Else
                Call CRECLLOPG([F:SCL]RECNUM, "", [M:PHX5]REPNUM(IH), DASSDAY, SZASSHOU, ISOK)
              Endif
            Endif
            INBRECPRO += 1
          Endif
        Next
        Filter [SCL]
        #Définit la date de fin de campagne pour le dernier téléacteur.
        [M:PHX5]OPGEND(IH) = DASSDAY
        [M:PHX5]DAYAVEASS(IH) = INBDAYREP
        #If !IFOUND Then                                          # FGR 04/04/2013 : X3SUIVI88351
        If !IFOUND or (IASSREPDON >= [M:PHX5]NBQBPRASS(IH)) Then  # FGR 04/04/2013 : X3SUIVI88351
          IH += 1
        Endif
      Else
        [M:PHX5]OPGEND(IH) = [M:PHX5]OPGSTR
        IH += 1
      Endif
      CCOUNT += 1
      If !GINTRA Then
        Call AFF_BOITE ([M:PHX5]REP(IH), CCOUNT, COK) From GESECRAN
      Endif
    Endif                              # FGR 13/10/2015 : X3SUIVI111690
  Wend
  If !GINTRA Then
    Call FERME_BOITE From GESECRAN
  Endif
  #Deuxième round : Ventilation selon calendrier pour les appels non affectés.
  If !GINTRA Then
    Call OUVRE_BOITE(mess(368,196,1), [M:PHX5]NBQCLLASS - INBRECPRO) From GESECRAN   #Programmation des appels résiduels.
  Endif
  CCOUNT = 0
  IASSREPDON = 0               #Nombre d'appels créés pour un téléacteur.
  IASSDAYDON = 0               #Nombre d'appels créés pour une journée de téléacteur.
  #Etape 3
  #Réinitialise DASSDAY avec un jour travaillé
  If [M:PHX5]NBVEN > 0 Then
    ISOK = 1
    Read [REP]REP0=[M:PHX5]REPNUM(IH)
    If fstat Then
      DASSDAY = [M:PHX5]OPGSTR
    Else
      Call GETNEXTWDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR-1, DNEXASSDAY, ISOK) From CRM_UTIL
      If ISOK Then
        DASSDAY = DNEXASSDAY
      Else
        DASSDAY = [M:PHX5]OPGSTR
      Endif
    Endif
  Else
    DASSDAY = [M:PHX5]OPGSTR
  Endif
  If GSZTYPSEA = "CCN" Then
    Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = "CCN" and [F:SCL]REPNUM = ""
  Else
    Filter [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN" and [F:SCL]REPNUM = ""
  Endif
  IH = 0
  SZCURREP = ""
  For [SCL]
    While 1
      #If IH >= dim([M:PHX5]REP)-1 Then          # FGR 13/10/2015 : X3SUIVI111690
      If [M:PHX5]REP(IH) = "" Then                # FGR 13/10/2015 : X3SUIVI111690
        Break
      Endif
      If INBRECPRO >= [M:PHX5]NBQCLLASS Then
        Break
      Endif
      If SZCURREP <> [M:PHX5]REPNUM(IH) Then
        ISOK = 1
        Read [REP]REP0=[M:PHX5]REPNUM(IH)
        If fstat Then
          DASSDAY = [M:PHX5]OPGSTR
        Else
          Call GETNEXTWDAY([F:REP]REPNUM, [F:REP]AUSNUM, [M:PHX5]OPGSTR - 1, DNEXASSDAY, ISOK) From CRM_UTIL
          If ISOK Then
            DASSDAY = DNEXASSDAY
          Else
            DASSDAY = [M:PHX5]OPGSTR
          Endif
        Endif
        SZCURREP =  [M:PHX5]REPNUM(IH)
        IASSREPDON = 0
        IASSDAYDON = 0
        If [M:PHX5]NBQWKDDAY(IH) = 0 Then
          INBDAYREP = 0
        Else
          If [M:PHX5]ASSCLLX(IH) = 0 Then
            INBDAYREP = 0
          Else
            INBDAYREP = fix([M:PHX5]ASSCLLX(IH) / [M:PHX5]NBQWKDDAY(IH)) + 1
          Endif
        Endif
      Endif
      If [M:PHX5]ASSCLLX(IH) > 0 Then
        If IASSDAYDON = INBDAYREP Then
          Read [REP]REP0=[M:PHX5]REPNUM(IH)
          If !fstat Then
            ISOK = 1
            Call GETNEXTWDAY([F:REP]REPNUM, [F:REP]AUSNUM, DASSDAY, DNEXASSDAY, ISOK) From CRM_UTIL
            If ISOK Then
              DASSDAY = DNEXASSDAY
            Endif
          Else
            DASSDAY = DASSDAY + 1
          Endif
          IASSDAYDON = 0
        Endif
        If INBDAYREP = 0 Then
          IASSREPDON = 0
          IASSDAYDON = 0
        Else
          IASSREPDON += 1
          IASSDAYDON += 1
          [M:PHX5]ASSCLL(IH) += 1
        Endif
        If IASSREPDON = [M:PHX5]ASSCLLX(IH) Then
          #Définit la date de fin de campagne pour le téléacteur.
          [M:PHX5]OPGEND(IH) = DASSDAY
          [M:PHX5]DAYAVEASS(IH) = [M:PHX5]DAYAVEASS(IH) + INBDAYREP
        Endif
        If IPOURDEVRAI Then
          If GSZTYPSEA = "CCN" Then
            Call CRECLLOPG([F:SCL]BPRNUM, [F:SCL]RECNUM, [M:PHX5]REPNUM(IH), DASSDAY, SZASSHOU, ISOK)
          Else
            Call CRECLLOPG([F:SCL]RECNUM, "", [M:PHX5]REPNUM(IH), DASSDAY, SZASSHOU, ISOK)
          Endif
        Endif
        INBRECPRO += 1
        If INBRECPRO = [M:PHX5]NBQCLLASS Then
          #Définit la date de fin de campagne pour le dernier téléacteur.
          [M:PHX5]OPGEND(IH) = DASSDAY
          [M:PHX5]DAYAVEASS(IH) = [M:PHX5]DAYAVEASS(IH) + INBDAYREP
        Endif
        If IASSREPDON = [M:PHX5]ASSCLLX(IH) Then
          IH += 1
        Endif
        Break
      Else
        IH += 1
      Endif
      If !GINTRA Then
        If IH >= dim([M:PHX5]REP) Then
          Call AFF_BOITE([M:PHX5]REP(dim([M:PHX5]REP)-1), CCOUNT, COK) From GESECRAN
        Else
          Call AFF_BOITE([M:PHX5]REP(IH), CCOUNT, COK) From GESECRAN
        Endif
      Endif
      CCOUNT += 1
    Wend
  Next
  Filter [SCL]
  If !GINTRA Then
    Call FERME_BOITE From GESECRAN
  Endif
  Affzo [M:PHX5]1-99
Return

