#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Class EDIDOSSIER                                                            #
# Author : RBA                                                                #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
        When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
        When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
        When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
        When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
  Endcase
Return

####################################################################

$AQUERY_TRANS_AFTER
  this.EDO.DOSSIER = [LNK_]DOSSIER
  this.EDO.DOSLEG  = [LNK_]DOSLEG
Return

####################################################################

$AQUERY_CLOSE_AFTER
  Close Local File [LNK_]
Return

####################################################################

$AQUERY_DECODE_CRITERIA_AFTER
  NBPRO += 1
  TBPRO(NBPRO) = "EDO_DOSSIER"
  TBTYP(NBPRO) = 7
  TBPTH(NBPRO) = "EDO.DOSSIER"
  TBFIL(NBPRO) = "[LNK_]DOSSIER"
  NBPRO += 1
  TBPRO(NBPRO) = "EDO_DOSLEG"
  TBTYP(NBPRO) = 7
  TBPTH(NBPRO) = "EDO.DOSLEG"
  TBFIL(NBPRO) = "[LNK_]DOSLEG"
Return

####################################################################

$AQUERY_PRIMARYKEYS_AFTER
  ASTDKEY = "[LNK_]DOSSIER;[LNK_]DOSLEG"
Return

####################################################################

$AQUERY_OPEN_AFTER
  Local Char WDOSSIER(40)(1..)
  Local Char WDOSLEG(3)(1..)
  Local Integer I, J
  Local File ADOSSIER [ADS]
  J = 1
  Filter [ADS]
  For [ADS]
    For I = 0 To [ADS]NBLEG-1
      If [ADS]DOSLEG(I) <> ""
        WDOSSIER(J) = [ADS]DOSSIER
        WDOSLEG(J)  = [ADS]DOSLEG(I)
        J = J + 1
      Endif
    Next I
  Next
  Filter [ADS]
  LogicClose File [ADS]

  Local File   (
&               Char DOSSIER(40),
&               Char DOSLEG(3)
& ) From Variable WDOSSIER, WDOSLEG As [LNK_]

Return

