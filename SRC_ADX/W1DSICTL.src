#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DSICTL 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:02"
A_USER  = "DOC"
A_STAMP = "20181109230402"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask DSICTL [DIA]
Gosub HORODAT
Local Inpbox "DSICTL" From GFONCTION At A_STAMP With A_WINDPREV Mask [DIA] As [SIM_]
Grizo [DIA]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DIA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=23 : X2(0)=89 : Y1(0)=10 : Y2(0)=19
Return

$ON_CPY
Onevent CONTROL Call C_CPY(zc) From W1DSICTL
Onevent BEFORE_INPUT Call AS_CPY(zc) From W1DSICTL
Onevent AFTER_CHANGE Gosub AMM_CPY From W1DSICTL
Return

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CPY(zc) From W1DSICTL
Onkey 144 Titled GBOUTP Call P_CPY(zc) From W1DSICTL
Onkey 146 Titled GBOUTA Call SA_CPY(zc) From W1DSICTL
Gosub _AFF
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
If !mkstat
 ## Action ACONTCPY
 Call CONTSOC(VALEUR) From SUBAGF
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("CPY","A",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CPY
Call AM_CPY(zc)
If !mkstat & GOBJET
 zoncou = "CPY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCPY)")>indice
 [M]CPY(indice) = VALEUR
 Affzo ZCPY(indice)
Endif
Gosub _AFF
End

Subprog S_CPY(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJCRIT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJCRIT"
 PARMSK(1) = "CPY"
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = "[F]LEG = 'FRA'"
 PARMSK(5) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJCRIT","SELOBJ","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CPY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CPY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCPY
Onevent BEFORE_AREA Gosub AV_ZCPY From W1DSICTL
Return

$AV_ZCPY
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",num$([M]CPY(indice)),"") From CONTOBJ
zc = [F:CPY]CPYNAM
Gosub _AFF
Return

$ON_STRDAT
Onevent BEFORE_AREA Gosub AV_STRDAT From W1DSICTL
Onevent AFTER_CHANGE Gosub AMM_STRDAT From W1DSICTL
Onevent BEFORE_INPUT Call AS_STRDAT(zc) From W1DSICTL
Return

$AV_STRDAT
## Action ADATRELI
Call INIDAT(zc,[M]STRDATF) From ADATREL
Chgfmt [M]STRDAT(indice) With "DzZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(32514,GBOUT1) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_STRDAT(zc) From W1DSICTL
Gosub _AFF
End

$AMM_STRDAT
Call AM_STRDAT(zc)
If !mkstat & GOBJET
 zoncou = "STRDAT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
## Action ADATRELM
Call MODIFDAT(VALEUR,[M]STRDATF) From ADATREL
If mkstat : GERR = 1 : GZONE = "STRDAT" : GZNUM = 1805 : Endif
If !mkstat
 ## Action STD
 Call AM_STRDAT(VALEUR) From FUNDSICTL
 If mkstat : GERR = 1 : GZONE = "STRDAT" : GZNUM = 1805 : Endif
Endif
Gosub _AFF
End

Subprog B1_STRDAT(VALEUR)
Variable Date    VALEUR
If !GWEBSERV
 ## Action ADATREL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ADATREL"
 PARMSK(1) = [M]STRDATF
 Call TRAITE_DAT(VALEUR,PARMSK,"","ADATREL","ADATREL",3,"") From GTRAITE
 [M]STRDATF = PARMSK(1)
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_ENDDAT
Onevent BEFORE_AREA Gosub AV_ENDDAT From W1DSICTL
Onevent AFTER_CHANGE Gosub AMM_ENDDAT From W1DSICTL
Onevent CONTROL Call C_ENDDAT(zc) From W1DSICTL
Onevent BEFORE_INPUT Call AS_ENDDAT(zc) From W1DSICTL
Return

$AV_ENDDAT
## Action ADATRELI
Call INIDAT(zc,[M]ENDDATF) From ADATREL
Chgfmt [M]ENDDAT(indice) With "DzZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(32514,GBOUT1) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_ENDDAT(zc) From W1DSICTL
Gosub _AFF
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
## Action DATDEBFIN
Call DATDEBFIN(VALEUR,[M]STRDAT) From EXEFNC
If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
Gosub _AFF
End

$AMM_ENDDAT
Call AM_ENDDAT(zc)
If !mkstat & GOBJET
 zoncou = "ENDDAT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
## Action ADATRELM
Call MODIFDAT(VALEUR,[M]ENDDATF) From ADATREL
If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
Gosub _AFF
End

Subprog B1_ENDDAT(VALEUR)
Variable Date    VALEUR
If !GWEBSERV
 ## Action ADATREL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ADATREL"
 PARMSK(1) = [M]ENDDATF
 Call TRAITE_DAT(VALEUR,PARMSK,"","ADATREL","ADATREL",3,"") From GTRAITE
 [M]ENDDATF = PARMSK(1)
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_ALLTYP
Onevent INIT_AREA Call D_ALLTYP(zc) From W1DSICTL
Onevent CONTROL Call C_ALLTYP(zc) From W1DSICTL
Onevent BEFORE_INPUT Call AS_ALLTYP(zc) From W1DSICTL
Return

Subprog D_ALLTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]ALLTYP,indice)=0
 VALEUR = 2
 ## Action STD
 Call D_ALLTYP(VALEUR) From FUNDSICTL
Endif
Gosub _AFF
End

Subprog AS_ALLTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_ALLTYP(VALEUR) From FUNDSICTL
If mkstat : GERR = 1 : GZONE = "ALLTYP" : GZNUM = 10412 : Endif
Gosub _AFF
End

$ON_DOCTYP
Onevent BEFORE_INPUT Call AS_DOCTYP(zc) From W1DSICTL
Onevent INIT_AREA Call D_DOCTYP(zc) From W1DSICTL
Return

Subprog D_DOCTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]DOCTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_DOCTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_DOCTYP(VALEUR) From FUNDSICTL
If mkstat=2
 [M]DOCTYP(INDIC) = VALEUR
 Affzo DOCTYP(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_ALLBP
Onevent INIT_AREA Call D_ALLBP(zc) From W1DSICTL
Onevent CONTROL Call C_ALLBP(zc) From W1DSICTL
Onevent BEFORE_INPUT Call AS_ALLBP(zc) From W1DSICTL
Return

Subprog D_ALLBP(VALEUR)
Variable Integer VALEUR
If varinit([M]ALLBP,indice)=0
 VALEUR = 2
 ## Action STD
 Call D_ALLBP(VALEUR) From FUNDSICTL
Endif
Gosub _AFF
End

Subprog AS_ALLBP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_ALLBP(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_ALLBP(VALEUR) From FUNDSICTL
If mkstat : GERR = 1 : GZONE = "ALLBP" : GZNUM = 8376 : Endif
Gosub _AFF
End

$ON_BPRNUM
Onevent CONTROL Call C_BPRNUM(zc) From W1DSICTL
Onevent BEFORE_INPUT Call AS_BPRNUM(zc) From W1DSICTL
Onevent AFTER_CHANGE Gosub AMM_BPRNUM From W1DSICTL
Return

Subprog AS_BPRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1500,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_BPRNUM(VALEUR) From FUNDSICTL
If mkstat=2
 [M]BPRNUM(INDIC) = VALEUR
 Affzo BPRNUM(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_BPRNUM(zc) From W1DSICTL
Onkey   2 Titled GBOUTS Call S_BPRNUM(zc) From W1DSICTL
Onkey 144 Titled GBOUTP Call P_BPRNUM(zc) From W1DSICTL
Onkey 146 Titled GBOUTA Call SA_BPRNUM(zc) From W1DSICTL
Gosub _AFF
End

Subprog C_BPRNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BPRCHOICE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BPRCHOICE"
 Call S_TAB_CHAR(VALEUR,PARMSK,"BPRCHOICE","TRTSEL","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "BPRNUM" : GZNUM = 19569 : Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("BPR","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "BPRNUM" : GZNUM = 19569 : Endif
Endif
Gosub _AFF
End

$AMM_BPRNUM
Call AM_BPRNUM(zc)
If !mkstat & GOBJET
 zoncou = "BPRNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_BPRNUM(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZBPRNUM)")>indice
 [M]BPRNUM(indice) = VALEUR
 Affzo ZBPRNUM(indice)
Endif
Gosub _AFF
End

Subprog S_BPRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "BPR"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_BPRNUM(VALEUR)
Variable Char    VALEUR()
Call OBJET("BPR",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_BPRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "BPR"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_BPRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("BPR",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZBPRNUM
Onevent BEFORE_AREA Gosub AV_ZBPRNUM From W1DSICTL
Return

$AV_ZBPRNUM
If clalev([F:BPR])=0
 If dim(GTABCPT)>0 & GTABCPT<>"" & find("BPR",GABRCPT(1..GNBTABCPT))
  Local File =GTABCPT+"BPARTNER" [BPR]
 Else 
  Local File BPARTNER [BPR]
 Endif
Endif
Call LECTURE("BPR",num$([M]BPRNUM(indice)),"") From CONTOBJ
zc = [F:BPR]BPRNAM
Gosub _AFF
Return

$CHG_STY
Return


