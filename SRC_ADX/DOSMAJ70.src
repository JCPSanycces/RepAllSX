Endif

#----- Puis Tronc commun

Call EXISTE_ADX("","","TRCMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ TRCMAJ70 ***************",-1) From GESECRAN
