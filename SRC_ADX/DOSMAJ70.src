Call EXISTE_ADX("","","TRSMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ TRSMAJ70 ***************",-1) From GESECRAN
  Call MAJ From TRSMAJ70 : # Moulinettes Tiers
Endif

Call EXISTE_ADX("","","VENMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ VENMAJ70 ***************",-1) From GESECRAN
  Call MAJ From VENMAJ70 : # Moulinettes Ventes
Endif

Call EXISTE_ADX("","","ACHMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ ACHMAJ70 ***************",-1) From GESECRAN
  Call MAJ From ACHMAJ70 : # Moulinettes Achats
Endif

Call EXISTE_ADX("","","STOMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ STOMAJ70 ***************",-1) From GESECRAN
  Call MAJ From STOMAJ70 : # Moulinettes Stocks
Endif

Call EXISTE_ADX("","","GPAMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ GPAMAJ70 ***************",-1) From GESECRAN
  Call MAJ From GPAMAJ70 : # Moulinettes GPAO
Endif

Call EXISTE_ADX("","","CRMMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ CRMMAJ70 ***************",-1) From GESECRAN
  Call MAJ From CRMMAJ70 : # Moulinettes HDK (support client)
Endif

Call EXISTE_ADX("","","FASMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ FASMAJ70 ***************",-1) From GESECRAN
  Call MAJ From FASMAJ70 : # Moulinettes Immobilisations
Endif

Onerrgo
End

###################################################################################
###################################################################################
###################################################################################

$ERREUR
GERRDOS = errn
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Resume

