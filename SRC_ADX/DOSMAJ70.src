#<AdxTL>@(#)0.0.0.0 $Revision$
##################################################################################
# DOSMAJ70 : Mises à jour à effectuer lors du passage à la version 10 (Release 70)
# Moulinette avant la version 10 (AVENGER)
#
# Pour obtenir le script de la version suivante, il suffit de remplacer la chaine
# MAJ70 par MAJnn où nn est le N° de release de la version suivante et d'aménager
# les 2 lignes de commentaire du début du script
##################################################################################


#-------------------------------------#
#         Avant mise à jour           #
#-------------------------------------#

#######################################
Subprog AMAJ
Local Integer RELEASE
Local Integer OKTRT

Onerrgo ERREUR

RELEASE = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ70 - AMAJ - RELEASE = "-num$(RELEASE),-1) From GESECRAN

#----- Superviseur en premier
Call EXISTE_ADX("","","SUPMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJDIC SUPMAJ70 *************",-1) From GESECRAN
#----- Préparation Superviseur :
# Rajout des types de données
# Rajout des codes activités
# Rajout des nouveaux champs
  Call MAJDIC From SUPMAJ70

  Call ECR_TRACE("************** AMAJ SUPMAJ70 ***************",-1) From GESECRAN
  Call AMAJ From SUPMAJ70 : # Moulinettes Superviseur
Endif


#----- Puis Tronc commun

Call EXISTE_ADX("","","TRCMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ TRCMAJ70 ***************",-1) From GESECRAN
  Call AMAJ From TRCMAJ70
Endif

#----- Ensuite les autres modules

Call EXISTE_ADX("","","CPTMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ CPTMAJ70 ***************",-1) From GESECRAN
  Call AMAJ From CPTMAJ70 : # Moulinettes Compta
Endif

Call EXISTE_ADX("","","TRSMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ TRSMAJ70 ***************",-1) From GESECRAN
  Call AMAJ From TRSMAJ70 : # Moulinettes Tiers
Endif

Call EXISTE_ADX("","","VENMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ VENMAJ70 ***************",-1) From GESECRAN
  Call AMAJ From VENMAJ70 : # Moulinettes Ventes
Endif

Call EXISTE_ADX("","","ACHMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ ACHMAJ70 ***************",-1) From GESECRAN
  Call AMAJ From ACHMAJ70 : # Moulinettes Achats
Endif

Call EXISTE_ADX("","","STOMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ STOMAJ70 ***************",-1) From GESECRAN
  Call AMAJ From STOMAJ70 : # Moulinettes Stocks
Endif

Call EXISTE_ADX("","","GPAMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ GPAMAJ70 ***************",-1) From GESECRAN
  Call AMAJ From GPAMAJ70 : # Moulinettes GPAO
Endif

Call EXISTE_ADX("","","CRMMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ CRMMAJ70 ***************",-1) From GESECRAN
  Call AMAJ From CRMMAJ70 : # Moulinettes HDK (support client)
Endif

Call EXISTE_ADX("","","FASMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** AMAJ FASMAJ70 ***************",-1) From GESECRAN
  Call AMAJ From FASMAJ70 : # Moulinettes Immobilisations
Endif

Call EXISTE_ADX("","","UTIEDI70",OKTRT) From ORDSYS   #X3-46906 EDI migration tool (JUCON 29/06/17)
If OKTRT
  Call ECR_TRACE("************** AMAJ UTIEDI70 ***************",-1) From GESECRAN
  Call AMAJ From UTIEDI70 : # Moulinettes EDI
Endif

Onerrgo
End



#-------------------------------------#
#          Après mise à jour          #
#-------------------------------------#

#######################################
Subprog MAJ
Local Integer RELEASE
Local Integer OKTRT

Onerrgo ERREUR

RELEASE = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ70 - MAJ - RELEASE = "-num$(RELEASE),-1) From GESECRAN

#----- Superviseur en premier

Call EXISTE_ADX("","","SUPMAJ70",OKTRT) From ORDSYS
If OKTRT
  Call ECR_TRACE("************** MAJ SUPMAJ70 ***************",-1) From GESECRAN
