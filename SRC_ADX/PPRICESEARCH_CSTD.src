#<AdxTL>@(#)5.0.0.0 $Revision$
# Data class PPRICESEARCH from SPRICESEARCH  12/4/2013

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINIT"           :  Gosub AINIT
        When "AREAD"           :  Gosub AINIT
        When "ACONTROL"        :  Gosub ACONTROL
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
     When "PRICESEARCH_MET"          : Gosub PRICESEARCH_MET
     When "PRICELIST_MET"            : Gosub PRICELIST_MET
     When "LOADPARAMFROMDOC"         : Gosub LOADPARAMFROMDOC
     When "LOADDOCFROMRESULT"        : Gosub LOADDOCFROMRESULT
     When "LOADVATPARAMFROMDOC"      : Gosub LOADVATPARAMFROMDOC
     When "LOADVATRESULTFROMFINDVAT" : Gosub LOADVATRESULTFROMFINDVAT
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "PURSALFCY" :
      Case [L]ARULE
        When "CONTROL"   : Gosub PURSALFCY_CONTROL
        When "PROPAGATE" : Gosub PURSALFCY_PROPAGATE
      Endcase
    When "FCY" :
      Case [L]ARULE
        When "CONTROL"   : Gosub FCY_CONTROL
        When "PROPAGATE" : Gosub FCY_PROPAGATE
      Endcase
    When "BPSNUM" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub BPSNUM_PROPAGATE
      Endcase
    When "ITMREF" :
      Case [L]ARULE
        When "CONTROL"   : Gosub ITMREF_CONTROL
        When "PROPAGATE" : Gosub ITMREF_PROPAGATE
      Endcase
    When "DATEREF" :
      Case [L]ARULE
        When "INIT"      : Gosub DATEREF_INIT
      Endcase
    When "CURREF" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub CURREF_PROPAGATE
      Endcase
    When "PRITYP" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub PRITYP_PROPAGATE
      Endcase
    When "QTYREF" :
      Case [L]ARULE
        When "CONTROL"   : Gosub QTYREF_CONTROL
        When "PROPAGATE" : Gosub QTYREF_PROPAGATE
      Endcase
    When "PTE" :
      Case [L]ARULE
        When "CONTROL"   : Gosub PTE_CONTROL
        When "PROPAGATE" : Gosub PTE_PROPAGATE
      Endcase
    When "VACBPR" :
      Case [L]ARULE
        When "CONTROL"   : Gosub VACBPR_CONTROL
        When "PROPAGATE" : Gosub VACBPR_PROPAGATE
      Endcase
    When "PUUREF" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub PUUREF_PROPAGATE
      Endcase
    When "PRICEPARAM.C_PPKH.VACBPR" :
      Case [L]ARULE
        When "CONTROL"   : #Gosub PRICEPARAM_C_PPKH_VACBPR_CONTROL
        When "PROPAGATE" : #Gosub PRICEPARAM_C_PPKH_VACBPR_PROPAGATE
      Endcase
    When "PRICEPARAM.VACBPR" :
      Case [L]ARULE
        When "CONTROL"   : #Gosub PRICEPARAM_VACBPR_CONTROL
        When "PROPAGATE" : #Gosub PRICEPARAM_VACBPR_PROPAGATE
      Endcase
    When "PRICEPARAM.C_PPKH.PTE" :
      Case [L]ARULE
        When "CONTROL"   : #Gosub PRICEPARAM_C_PPKH_PTE_CONTROL
        When "PROPAGATE" : #Gosub PRICEPARAM_C_PPKH_PTE_PROPAGATE
      Endcase
    When "PRICEPARAM.C_LINE.C_VAT.VAT" :
      Case [L]ARULE
        When "CONTROL"   : #Gosub PRICEPARAM_C_LINE_C_VAT_VAT_CONTROL
        When "PROPAGATE" : #Gosub PPRICEPARAM_C_LINE_C_VAT_VAT_PROPAGATE
      Endcase
  Endcase
Return



#############################################################################################
$PURSALFCY_CONTROL
  # 99095.sn
  Local File FACILITY [PURSAFCY]

  If this.PURSALFCY<>""
      Read [F:PURSAFCY]FCY0=this.PURSALFCY
      If fstat : Raz [F:FCY] : [L]ASTATUS = fmet this.ASETERROR ("PURSALFCY", mess(10,123,1), [V]CST_AERROR)
      LogicClose File [PURSAFCY] : Return : Endif
  Endif

  LogicClose File [PURSAFCY]
  # 99095.en
Return

#############################################################################################
$PURSALFCY_PROPAGATE
  # this.FCY=""
Return

#############################################################################################
$FCY_CONTROL

  If this.FCY = ""
    Return
  Endif

  Local File FACILITY [PURSAFCY]
  Local File FACILITY [FCY]

  If this.PURSALFCY<>""
    Read [F:PURSAFCY]FCY0=this.PURSALFCY
    If fstat : Raz [F:PURSAFCY] : LogicClose File [PURSAFCY] : Return : Endif
  Endif

#  If this.FCY<>"" # 99529.so
#    Read [F:FCY]FCY0=this.FCY
#    If fstat : Raz [F:FCY] : LogicClose File [FCY] : Return : Endif
#  Endif           # 99529.eo

  If this.FCY<>"" # 99529.sn
    Read [F:FCY]FCY0=this.FCY
    If fstat : Raz [F:FCY]
      [L]ASTATUS = fmet this.ASETERROR ("FCY", mess(10,123,1), [V]CST_AERROR)
      LogicClose File [FCY] : Return : Endif
  Endif           # 99529.en

  # --- le site doit être sur la même société juridique que site de vente
  #If [F:FCY]LEGCPY<>[F:PURSAFCY]LEGCPY
  If [F:PURSAFCY]FCY<> "" & [F:FCY]LEGCPY<>[F:PURSAFCY]LEGCPY
    [L]ASTATUS = fmet this.ASETERROR ("FCY", mess(2,194,1), [V]CST_AERROR)
    Return
  Endif

  LogicClose File [PURSAFCY]
  LogicClose File [FCY]
Return

#############################################################################################
$FCY_PROPAGATE

  If this.FCY = ""
      this.CPY    = ""
      this.PLISTC = ""
      this.LEG    = ""
      Return
  Endif

  Local File FACILITY [FCY]
  Local File COMPANY  [CPY]
  Local File BPSUPPLIER [BPS]

  If this.PURSALFCY<>""
    Read [F:FCY]FCY0=this.PURSALFCY
    If fstat : Raz [F:FCY] : Endif
    this.CPY=[F:FCY]LEGCPY
  Endif

  Read [F:CPY]CPY0=[F:FCY]LEGCPY
  If fstat : Raz [F:CPY] : Endif

  Read [BPS] BPS0=this.BPSNUM
    If fstat Raz [F:BPS] Endif

  this.PLISTC = [F:BPS]PLISTC
  this.LEG    = [F:CPY]LEG

    LogicClose File [FCY]
    LogicClose File [CPY]
Return

#############################################################################################
$BPSNUM_PROPAGATE

If this.BPSNUM="" Return Endif

Local Char    WANCCUR(GLONCUR) : WANCCUR    = this.CURREF
Local Integer WRET
Local Char    WMESSAGE(250)

Local File BPSUPPLIER  [BPS]
Local File TABPAYTERM [TPT]

  Read [BPS] BPS0=this.BPSNUM
  If fstat Raz [F:BPS] Endif

If [F:BPS]BPSREM<>""
  [L]ASTATUS = fmet this.ASETERROR ("", [F:BPS]BPSREM, [V]CST_AINFO) # No erro, just informational
Endif

WRET = fmet this.PRICEPARAM(1).INITPARAM()
  If WRET>=[V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR ("ITMREF", mess(68,123,1)-":"-mess(1,7845,1)-"INITPARAM", [V]CST_AERROR)
    Return
  Endif

 this.PRICEPARAM(1).BPAADD = "" #AVOID.ACHAR

  Call ALICLIBPS (1,"S",this.BPSNUM, this.PRICEPARAM(1), WRET) From FINDPRICE_SYRA
  #--Test if errors
  If WRET>=[V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR ("BPSNUM", mess(68,123,1)-":"-mess(3,7845,1)-"ALICLIBPS", [V]CST_AERROR)
    Return
  Endif
  #If this.EECICT ='' : this.EECICT = [F:BPS]EECICT : this.PRICEPARAM(1).C_PPKH.EECICT = [F:BPS]EECICT : Endif #########
  If this.PRICEPARAM(1)<>null and this.PRICEPARAM(1).C_PPKH(1)<>null
    this.EECICT  = this.PRICEPARAM(1).C_PPKH(1).EECICT  # 98525.n
    #--Because of the Control action of the PTE field, and to avoid blocking situations
    #--This will trigger Propagate of PTE
    this.PTE     = this.PRICEPARAM(1).C_PPKH(1).PTE

    #--This will trigger Propagate of PTE
    this.VACBPR  = this.PRICEPARAM(1).VACBPR
    this.CURREF  = this.PRICEPARAM(1).CUR
    this.PRITYP  = this.PRICEPARAM(1).PRITYP

  Endif
  If this.EECICT ='' : this.EECICT = [F:BPS]EECICT : this.PRICEPARAM(1).C_PPKH.EECICT = [F:BPS]EECICT : Endif

  If WANCCUR<>this.CURREF and this.PRICEPARAM(1)<>null # 2/28/2014 OPENED BACK UP and 1<0
    # Alimentation du format des colonnes frais/remise
    WRET = func TRTPRICE_SYRA.ALIFORREM (this, 0, this.CURREF, this.PRICEPARAM(1).FMTCOLREM, WMESSAGE) #From
    #--Test if errors
    If WRET=[V]CST_AOK : WRET = fmet this.AGETMAXERROR("") : Endif
    If WRET >=[V]CST_AERROR
      If WMESSAGE=""
        WMESSAGE = mess(68,123,1)-":"-mess(2,7845,1)-"ALIFORREM"
      Endif
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("BPSNUM", WMESSAGE, WRET)
      Return
    Endif
  Endif

LogicClose File [BPS]

Return

#############################################################################################
$ITMREF_CONTROL

  If this.ITMREF = "" : Return : Endif

#  Local File ITMBPS    [ITP]

#  Read [F:ITP]ITP0=this.ITMREF
#  If fstat
#      [L]ASTATUS = fmet this.ASETERROR("ITMREF", " ", [V]CST_AERROR)
#     Return
#  Endif   99095.O

  Local File ITMMASTER [ITM]
  Read [F:ITM]ITM0=this.ITMREF
  If fstat
    [L]ASTATUS = fmet this.ASETERROR("ITMREF", mess(5,194,1), [V]CST_AERROR)
    Return
  Endif

  # LogicClose File [ITP]
  LogicClose File [ITM]

Return

#############################################################################################
$ITMREF_PROPAGATE

If this.ITMREF="" : Return : Endif

Local File ITMMASTER [ITM]
Local File ITMBPS    [ITP]

If [F:ITM]ITMREF<>this.ITMREF
  Read [ITM] ITM0=this.ITMREF : If fstat Raz [F:ITM] : Endif
Endif

If [F:ITP]ITMREF<>this.ITMREF | [F:ITP]BPSNUM<>this.BPSNUM
  Read [ITP] ITP0=this.ITMREF;this.BPSNUM : If fstat Raz [F:ITP] : Endif
Endif

this.PUUREF=[F:ITM]PUU

If [F:ITP]PUU<>"" this.PUUREF=[F:ITP]PUU : Endif

  LogicClose File [ITP]
  LogicClose File [ITM]

Return

#############################################################################################
$DATEREF_INIT
  this.DATEREF = date$
Return


#############################################################################################
$CURREF_PROPAGATE
  Local Integer WRET

Return

#############################################################################################
$PRITYP_PROPAGATE

Return

#############################################################################################
$QTYREF_CONTROL

 Call QTEARR(this.QTYREF,this.PUUREF) From TRTDIV_SYRA

Return

#############################################################################################
$QTYREF_PROPAGATE

Return

#############################################################################################
$PTE_CONTROL

  If this.PTE="" : Return : Endif

  Local Integer WRET
  Local Char    VMESSA(250)

  WRET = func FINDVAT_SYRA.CONTTPT(this.ACTX, this.PTE, this.LEG, this.FCY, "", this.CPY, VMESSA)
  If WRET>=[V]CST_AERROR | VMESSA<>""
    If VMESSA=""
      VMESSA = mess(68,123,1)
    Endif
    [L]ASTATUS = fmet this.ASETERROR("PTE",VMESSA,WRET)
    Return
  Endif

Return

#############################################################################################
$PTE_PROPAGATE

  Local File TABPAYTERM [TPT]

  If this.PTE=""
    this.PTE_LEG=""
  Else

    Local Integer WRET

    this.PTE_LEG = "" :#AVOID.ACHAR
    Call LEC_TPT_LEG(this.ACTX, this.LEG, this.PTE, 1, WRET) From TRTLECLEG_SYRA
    If WRET<[V]CST_AERROR
        this.PTE_LEG = [F:TPT]LEG
    Endif
  Endif

  If this.PRICEPARAM(1)<>null and this.PRICEPARAM(1).C_PPKH(1)<>null
    this.PRICEPARAM(1).C_PPKH(1).PTE     = this.PTE
    this.PRICEPARAM(1).C_PPKH(1).PTE_LEG = this.PTE_LEG
  Endif

  LogicClose File [TPT]

Return

#############################################################################################
$VACBPR_CONTROL

  If this.VACBPR="" : Return : Endif

  Local Integer WRET
  Local Char    VMESSA(250)

  WRET = func FINDVAT_SYRA.CONTTVB(this.ACTX, this.VACBPR, this.LEG, this.FCY, "", this.CPY, VMESSA)
  If WRET>=[V]CST_AERROR | VMESSA<>""
    If VMESSA=""
      VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"CONTTVB"
    Endif
    [L]ASTATUS = fmet this.ASETERROR("VACBPR",VMESSA,WRET)
    Return
  Endif

Return

#############################################################################################
$VACBPR_PROPAGATE
Local Integer WLEG
Local File TABVACBPR [TVB]

  If this.VACBPR=""
    this.VACBPR_LEG=""
  Else

    Local Integer WRET

    this.VACBPR_LEG = "" :#AVOID.ACHAR
    Call LEC_TVB_LEG(this.ACTX, this.LEG, this.VACBPR, WRET) From TRTLECLEG_SYRA
    If WRET<[V]CST_AERROR
        this.VACBPR_LEG = [F:TVB]LEG
    Endif
  Endif

  If this.PRICEPARAM(1)<>null

      this.PRICEPARAM(1).VACBPR     = this.VACBPR
      this.PRICEPARAM(1).VACBPR_LEG = this.VACBPR_LEG

    If this.PRICEPARAM(1).C_PPKH(1)<>null

      this.PRICEPARAM(1).C_PPKH(1).VACBPR     = this.VACBPR
      this.PRICEPARAM(1).C_PPKH(1).VACBPR_LEG = this.VACBPR_LEG

    Endif

  Endif

  LogicClose File [TVB]

Return

#############################################################################################
$PRICEPARAM_VACBPR_CONTROL

  If this.VACBPR="" : Return : Endif

  Local Integer WRET
  Local Char    VMESSA(250)

  WRET = func FINDVAT_SYRA.CONTTVB(this.ACTX, this.VACBPR, this.APARENT.LEG, this.APARENT.FCY, "", "", VMESSA)
  If WRET>=[V]CST_AERROR | VMESSA<>""
    If VMESSA=""
      VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"CONTTVB"
    Endif
    [L]ASTATUS = fmet this.ASETERROR("VACBPR",VMESSA,[V]CST_AWARNING)
    Return
  Endif

Return

#############################################################################################
$PRICEPARAM_VACBPRV

  If this.VACBPR="" : this.VACBPR_LEG="" : Return : Endif

  Local File TABVACBPR [TVB]

  Local Integer WRET

  this.VACBPR_LEG = "" :#AVOID.ACHAR
  Call LEC_TVB_LEG(this.ACTX, this.APARENT.LEG, this.VACBPR, WRET) From TRTLECLEG_SYRA
  If WRET<[V]CST_AERROR
      this.VACBPR_LEG = [F:TVB]LEG
  Endif

  LogicClose File [TVB]
Return

#############################################################################################
$PRICEPARAM_C_PPKH_VACBPR_CONTROL

  If this.VACBPR="" : Return : Endif

  Local Integer WRET
  Local Char    VMESSA(250)

  WRET = func FINDVAT_SYRA.CONTTVB(this.ACTX, this.VACBPR, this.APARENT.APARENT.LEG, this.APARENT.APARENT.FCY, "", "", VMESSA)
  If WRET>=[V]CST_AERROR | VMESSA<>""
    If VMESSA=""
      VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"CONTTVB"
    Endif
    [L]ASTATUS = fmet this.ASETERROR("VACBPR",VMESSA,WRET)
    Return
  Endif

Return

#############################################################################################
$PRICEPARAM_C_PPKH_VACBPR_PROPAGATE

  If this.VACBPR="" : this.VACBPR_LEG="" : Return : Endif

  Local File TABVACBPR [TVB]

  Local Integer WRET

  this.VACBPR_LEG = "" :#AVOID.ACHAR
  Call LEC_TVB_LEG(this.ACTX, this.APARENT.APARENT.LEG, this.VACBPR, WRET) From TRTLECLEG_SYRA
  If WRET<[V]CST_AERROR
      this.VACBPR_LEG = [F:TVB]LEG
  Endif

  LogicClose File [TVB]

Return

#############################################################################################
$PRICEPARAM_C_PPKH_PTE_CONTROL

  If this.PTE="" : Return : Endif

  Local Integer WRET
  Local Char    VMESSA(250)

  WRET = func FINDVAT_SYRA.CONTTPT(this.ACTX, this.PTE, this.APARENT.APARENT.LEG, this.APARENT.APARENT.STOFCY, "", this.APARENT.APARENT.CPY, VMESSA)
  If WRET>=[V]CST_AERROR | VMESSA<>""
    If VMESSA=""
      VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"CONTTPT"
    Endif
    [L]ASTATUS = fmet this.ASETERROR("PTE",VMESSA,WRET)
    Return
  Endif

Return

#############################################################################################
$PRICEPARAM_C_PPKH_PTE_PROPAGATE

  If this.PTE="" : this.PTE_LEG="" : Return : Endif

  Local File TABPAYTERM [TPT]

  Local Integer WRET

  this.PTE_LEG = "" :#AVOID.ACHAR
  Call LEC_TPT_LEG(this.ACTX, this.APARENT.APARENT.LEG, this.PTE, 1, WRET) From TRTLECLEG_SYRA
  If WRET<=[V]CST_ASUCCESS
      this.PTE_LEG = [F:TPT]LEG
  Endif

  LogicClose File [TPT]

Return

#############################################################################################
$PUUREF_PROPAGATE
  Local    Decimal QTYDST
  Local    Decimal COEF

  Gosub ITMREF_PROPAGATE # PRD calls for no change permitted.
Return


#############################################################################################
$AINIT
  this.PRITYP=1

  Local Char WGFCY(GLONFCY)
  Local Char WGCUR(GLONCUR)
  Local Char WGCPY(GLONCPY)

  this.FCY= func CPTDIV_SYRA.FINDAFTSITE(this.ACTX.USER,5,WGFCY) #6 for GX3

  this.PURSALFCY= this.FCY
  WGFCY= this.FCY

  Gosub BPSNUM_PROPAGATE

  Gosub FCY_PROPAGATE

  this.DATEREF = date$
  this.QTYREF  = 1
  this.PUUREF  = ""
  this.ITMREF  = ""

  Gosub ITMREF_PROPAGATE

Return


#############################################################################################
$ACONTROL
 Local Integer VRET
  Local Char    VMESSA(250)

  #--Because we are still on Edit mode, the global _ACONTROL of the class is not executed
  #--It meens that controls such as mandatory fields are not done (tha _aformat and _aothers control actions are executed, but not _amandatory)
  #--All those have to be done manually

  If this.FCY=""
    [L]ASTATUS = fmet this.ASETERROR("FCY",mess(10,123,1),[V]CST_AERROR)
  Endif
  # 99095.sn
  If this.PURSALFCY=""
    [L]ASTATUS = fmet this.ASETERROR("PURSALFCY",mess(10,123,1),[V]CST_AERROR)
  Endif
  # 99095.en
  If this.BPSNUM=""
    [L]ASTATUS = fmet this.ASETERROR("BPSNUM",mess(10,123,1),[V]CST_AERROR)
  Endif

  If this.ITMREF=""
    [L]ASTATUS = fmet this.ASETERROR("ITMREF",mess(10,123,1),[V]CST_AERROR)
  Endif

  If this.DATEREF=AVOID.ADATE
    [L]ASTATUS = fmet this.ASETERROR("DATEREF",mess(10,123,1),[V]CST_AERROR)
  Endif

  If this.CURREF=""
    [L]ASTATUS = fmet this.ASETERROR("CURREF",mess(10,123,1),[V]CST_AERROR)
  Endif

  If this.QTYREF=0
    [L]ASTATUS = fmet this.ASETERROR("QTYREF",mess(10,123,1),[V]CST_AERROR)
  Endif

  # 99095.so
  #If this.PUUREF=""
  #  [L]ASTATUS = fmet this.ASETERROR("PUUREF",mess(10,123,1),[V]CST_AERROR)
  #Endif
  # 99095.

  Gosub FCY_CONTROL
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

  Gosub PURSALFCY_CONTROL # 99095.n
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

  Gosub ITMREF_CONTROL
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

  Gosub PTE_CONTROL
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

  Gosub VACBPR_CONTROL
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

  If this.PRICEPARAM(1)<>null and this.PRICEPARAM(1).C_PPKH(1)<>null

    #--Controlling multiple leg type properties
    If this.PRICEPARAM(1).C_PPKH(1).VACBPR<>""
      Local File TABVACBPR [TVB]

      this.PRICEPARAM(1).C_PPKH(1).VACBPR_LEG = "" :#AVOID.ACHAR
      Call LEC_TVB_LEG(this.ACTX, this.LEG, this.PRICEPARAM(1).C_PPKH(1).VACBPR, [L]VRET) From TRTLECLEG_SYRA
      If [L]VRET<[V]CST_AERROR
        this.PRICEPARAM(1).C_PPKH(1).VACBPR_LEG = [F:TVB]LEG
      Endif

      [L]VRET = func FINDVAT_SYRA.CONTTVB(this.ACTX, this.PRICEPARAM(1).C_PPKH(1).VACBPR, this.LEG, this.FCY, "", "", VMESSA)
      If [L]VRET>=[V]CST_AERROR | VMESSA<>""
        If VMESSA=""
          VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"CONTTVB"
        Endif
          [L]ASTATUS = fmet this.ASETERROR("VACBPR",VMESSA,[V]CST_AERROR)
        Return
      Endif

    LogicClose File [TVB]
    Endif

    If this.PRICEPARAM(1).C_PPKH(1).PTE<>""
      Local File TABPAYTERM [TPT]

      this.PRICEPARAM(1).C_PPKH(1).PTE_LEG = "" :#AVOID.ACHAR
      Call LEC_TPT_LEG(this.ACTX, this.LEG, this.PRICEPARAM(1).C_PPKH(1).PTE, 1, [L]VRET) From TRTLECLEG_SYRA
      If [L]VRET<[V]CST_AERROR
        this.PRICEPARAM(1).C_PPKH(1).PTE_LEG = [F:TPT]LEG
      Endif

      [L]VRET = func FINDVAT_SYRA.CONTTPT(this.ACTX, this.PRICEPARAM(1).C_PPKH(1).PTE, this.LEG, this.FCY, "", "", VMESSA)
      If [L]VRET>=[V]CST_AERROR | VMESSA<>""
        If VMESSA=""
          VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"CONTTPT"
        Endif
        [L]ASTATUS = fmet this.ASETERROR("PTE",VMESSA,[V]CST_AERROR)
        Return
      Endif
       LogicClose File [TPT]
    Endif
  Endif
Return

#############################################################################################
$DELETE_ERRORS

Return

#############################################################################################
$PRICESEARCH_MET
  #--Nothing done if already existing errors !!!
  #--Call to global control method before doing price search
  [L]ASTATUS = fmet this.ACONTROL()
  If [L]ASTATUS >=[V]CST_AERROR
  #--Emptying existing results
    Gosub RAZ_EXISTING
    [L]ARET_VALUE = [L]ASTATUS
    Return
  Endif
  Gosub FINDPRICE
Return

#############################################################################################
$PRICELIST_MET
  #--Nothing done if already existing errors !!!
  #--Call to global control method before doing price search
  [L]ASTATUS = fmet this.ACONTROL()
    If [L]ASTATUS >=[V]CST_AERROR
    #--Emptying existing results
    Gosub RAZ_EXISTING
    [L]ARET_VALUE = [L]ASTATUS
    Return
  Endif
  Gosub FINDPRICELIST
Return

#############################################################################################
$FINDPRICE
    Local Decimal H1,H2

    this.setAccessorEnabled = 0
    #--Emptying existing results
    Gosub RAZ_EXISTING

    If this.PRICEPARAM(1)=null
      WRET = fmet this.ADDLINE("PRICEPARAM",1)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"PRICEPARAM","PPRICESEARCH"), [V]CST_AERROR)
        [L]ARET_VALUE = [L]ASTATUS
        Return
      Endif
      WRET = fmet this.PRICEPARAM(1).INITPARAM()
      If WRET>=[V]CST_AERROR
        [L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(1,7845,1)-"INITPARAM", [V]CST_AERROR)
        [L]ARET_VALUE = [L]ASTATUS
        Return
      Endif
    Endif

    this.PRICEPARAM(1).setAccessorEnabled = 0
    #--Call to PFINDPRICE method
    #--We pass a pointer to the local document

    WRET = fmet this.PRICEPARAM(1).FINDPRICE(this,1)
    If WRET>=[V]CST_AERROR
      #[L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(2,7845,1)-"FINDPRICE", [V]CST_AERROR) # 98394.o
      [L]ASTATUS = fmet this.ASETERROR ("", "", [V]CST_AERROR) # 98394.n
      Goto END_FINDPRICE
    Endif

    $END_FINDPRICE
    #--We must free the instance (not anymore => use of pointer from PPRICESEARCH : PARAMPRICE(1)
    # FreeGroup MYPARAM
    this.setAccessorEnabled = 1
    this.PRICEPARAM(1).setAccessorEnabled = 1
    [L]ARET_VALUE = [L]ASTATUS

Return

############################################################################################
$FINDPRICELIST
##--- Consultation des tarifs

  Local Integer WRET,JLT,J
  Local Char    WMESSAGE(250)

  Local File PPRICCONF  [PPC]
  Local File ITMMASTER  [ITM]  :#--Pour le call TARIF() From WBTxxxx_SY
  Local File BPCUSTOMER [BPC]
  Local File BPSUPPLIER [BPS]
  Local File TABVACBPR  [TVB]
  Local File TABPAYTERM [TPT]

  Read [F:BPS]BPS0=this.BPSNUM
  If fstat : Raz [F:BPS] : Endif


  Local Instance MYPARAM  Using C_PFINDPRICE
  Local Instance MYRESULT Using C_RESULTPRICE

  MYPARAM  = NewInstance C_PFINDPRICE   AllocGroup null
  MYRESULT = NewInstance C_RESULTPRICE  AllocGroup MYPARAM

  MYPARAM.setAccessorEnabled  = 0
  MYRESULT.setAccessorEnabled = 0

  WRET =fmet MYPARAM.INITPARAM()
  If WRET >= [V]CST_AERROR
    FreeGroup MYPARAM
    Return
  Endif
############################################ Start here
  MYPARAM.MODULE = 6
  MYPARAM.PLITYP = 1
  MYPARAM.DOCDAT = this.DATEREF
  MYPARAM.CUR    = this.CURREF
  MYPARAM.PRITYP = this.PRITYP
  MYPARAM.BPSNUM = this.BPSNUM

  MYPARAM.C_LINE(1).QTY   =this.QTYREF
  MYPARAM.C_LINE(1).PUU   =this.PUUREF

  MYPARAM.VACBPR     = this.PRICEPARAM(1).VACBPR
  MYPARAM.VACBPR_LEG = ""
  MYPARAM.VACBPR_LEG = "" #AVOID.ACHAR

    Call LEC_TVB_LEG(this.ACTX, this.LEG, MYPARAM.VACBPR, WRET) From TRTLECLEG_SYRA
    If WRET=0
      MYPARAM.VACBPR_LEG = [F:TVB]LEG
      this.VACBPR_LEG     = [F:TVB]LEG
    Endif

  MYPARAM.C_PPKH(1).PTE      = this.PTE
  MYPARAM.C_PPKH(1).PTE_LEG  = "" #AVOID.ACHAR
  Call LEC_TPT_LEG(this.ACTX, this.LEG, MYPARAM.C_PPKH(1).PTE, 1, WRET) From TRTLECLEG_SYRA
  If WRET=0
    MYPARAM.C_PPKH(1).PTE_LEG  = [F:TPT]LEG
    this.PTE_LEG               = [F:TPT]LEG
  Endif

  For WLINE=1 To maxtab(this.PRICEPARAM(1).C_LINE(1).C_VAT) # 3
   If this.PRICEPARAM(1).C_LINE(1).C_VAT(WLINE) <> null
    If MYPARAM.C_LINE(1).C_VAT(WLINE) = null
      WRET = fmet MYPARAM.C_LINE(1).ADDLINE("C_VAT",WLINE)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_VAT","PFINDPRICE.C_LINE(1)"), [V]CST_AERROR)
        [L]ARET_VALUE = [L]ASTATUS
        FreeGroup MYPARAM
        Return
      Endif
    Endif
    MYPARAM.C_LINE(1).C_VAT(WLINE).VAT     = this.PRICEPARAM(1).C_LINE(1).C_VAT(WLINE).VAT
    MYPARAM.C_LINE(1).C_VAT(WLINE).VAT_LEG = this.PRICEPARAM(1).C_LINE(1).C_VAT(WLINE).VAT_LEG
   Endif
  Next WLINE

#--Trouver le GPLISTC...  2 for Supplier
  WRET = func TRTPRICE_SYRA.ALICOLREM (2, this.CURREF, 2, this, MYPARAM.PLI(1), MYPARAM.FMTCOLREM(1), this.PLISTC, WMESSAGE) #From TRTPRICE_SYRA
  If WRET >=[V]CST_AERROR
    If WMESSAGE=""
      WMESSAGE = mess(68,123,1)-":"-mess(2,7845,1)-"ALICOLREM"
    Endif
    [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, WRET)
    [L]ARET_VALUE = [L]ASTATUS
    FreeGroup MYPARAM
    Return
  Endif

  Filter [PPC] Where PLIENAFLG=[V]CST_AYES & PLITYP=1 & PLISTC=this.PLISTC #& find(PLICPY,"",this.CPY)

  If rowcount([F:PPC])<1 : FreeGroup MYPARAM : Filter [F:PPC] : Return : Endif

  Local Char    WTARNORACT(GLONPPC)(1..rowcount([F:PPC]))
  Local Integer WTARPIO            (1..rowcount([F:PPC]))

  JLT = 1
  For [PPC]PPC1
    WTARNORACT(JLT)=[F:PPC]PLI
    WTARPIO(JLT)   =[F:PPC]PIO
    JLT += 1
    If JLT>dim(WTARNORACT) : Break : Endif
  Next

  Filter [F:PPC]

  If MYPARAM.PLI(1)=null
    I = MYPARAM.ADDLINE('PLI',1)
    If I=[V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"PLI","PFINDPRICE"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      FreeGroup MYPARAM
      Return
    Endif
  Endif

  If MYPARAM.C_LINE(1)=null
    I = MYPARAM.ADDLINE('C_LINE',1)
    If I=[V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_LINE","PFINDPRICE"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      FreeGroup MYPARAM
      Return
    Endif
  Endif

  MYPARAM.PLI(1).PLI       = "*SIMU*"
  MYPARAM.C_LINE(1).FCY    = this.FCY :#--CPO 98402.N La lecture de ITF se fait selon le C_LINE().STOFCY => il faut l'alimenter
  MYPARAM.C_LINE(1).ITMREF = this.ITMREF
  MYPARAM.BPSNUM           = this.BPSNUM


  For I=1 To dim(WTARNORACT)

    If WTARNORACT(I)="" : Break : Endif

    MYPARAM.PIO     = WTARPIO(I)
    MYPARAM.C_PPKH(1).EECICT     = this.EECICT # 99354
   # If filinfo(filpath("TRT","WAT"+WTARNORACT(I)+"_SY","adx",nomap,"",""),0)>0
      Call TARIF(MYPARAM, 1, MYRESULT, WRET, WMESSAGE) From ="WAT"+WTARNORACT(I)+"_SY"

      If fmet MYRESULT.AGETMAXERROR("")>=[V]CST_AERROR or WRET>=[V]CST_AERROR
        If WMESSAGE="" #AVOID.ACHAR
           WMESSAGE = mess(68,123,1)-":"-mess(2,7845,1)-"TARIF"
        Endif
        [L]ASTATUS = fmet this.ASETERROR ("",WMESSAGE , [V]CST_AERROR)
        Break
      Endif

  Next I

  #--Reprise des résultats
  If maxtab(MYRESULT.C_PRICEINQ)>0
    For I=1 To maxtab(MYRESULT.C_PRICEINQ)
      If this.RESPRICEINQ(I)=null
        WRET = fmet this.ADDLINE("RESPRICEINQ",I)
        If WRET = [V]CST_ANOTDEFINED
          #--The insertion was not possible
          [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"RESPRICEINQ","PPRICESEARCH"), [V]CST_AERROR)
          Break
        Endif
      Endif
      this.RESPRICEINQ(I).DATDEB    = MYRESULT.C_PRICEINQ(I).DATDEB
      this.RESPRICEINQ(I).DATFIN    = MYRESULT.C_PRICEINQ(I).DATFIN
      this.RESPRICEINQ(I).CUR       = MYRESULT.C_PRICEINQ(I).CUR
      this.RESPRICEINQ(I).UOM       = MYRESULT.C_PRICEINQ(I).UOM
      this.RESPRICEINQ(I).MINQTY    = MYRESULT.C_PRICEINQ(I).MINQTY
      this.RESPRICEINQ(I).MAXQTY    = MYRESULT.C_PRICEINQ(I).MAXQTY
      this.RESPRICEINQ(I).MINAMT    = MYRESULT.C_PRICEINQ(I).MINAMT
      this.RESPRICEINQ(I).MAXAMT    = MYRESULT.C_PRICEINQ(I).MAXAMT
      this.RESPRICEINQ(I).LTI       = MYRESULT.C_PRICEINQ(I).LTI
      this.RESPRICEINQ(I).PRIDIV    = MYRESULT.C_PRICEINQ(I).PRIDIV
      this.RESPRICEINQ(I).PRI       = MYRESULT.C_PRICEINQ(I).PRI
      this.RESPRICEINQ(I).COE       = MYRESULT.C_PRICEINQ(I).COE
      this.RESPRICEINQ(I).FOCQTYMIN = MYRESULT.C_PRICEINQ(I).FOCQTYMIN
      this.RESPRICEINQ(I).FOCQTYBKT = MYRESULT.C_PRICEINQ(I).FOCQTYBKT
      this.RESPRICEINQ(I).FOCUOM    = MYRESULT.C_PRICEINQ(I).FOCUOM
      this.RESPRICEINQ(I).FOCQTY    = MYRESULT.C_PRICEINQ(I).FOCQTY
      this.RESPRICEINQ(I).PLISEA    = MYRESULT.C_PRICEINQ(I).PLISEA
      this.RESPRICEINQ(I).PLI       = MYRESULT.C_PRICEINQ(I).PLI
      this.RESPRICEINQ(I).PLICRD    = MYRESULT.C_PRICEINQ(I).PLICRD
      this.RESPRICEINQ(I).PLILIN    = MYRESULT.C_PRICEINQ(I).PLILIN

      If maxtab(MYRESULT.C_PRICEINQ(I).C_FRAREM)>0
        For J=1 To maxtab(MYRESULT.C_PRICEINQ(I).C_FRAREM)
          If this.RESPRICEINQ(I).C_FRAREM(J)=null
            WRET = fmet this.RESPRICEINQ(I).ADDLINE("C_FRAREM",J)
            If WRET = [V]CST_ANOTDEFINED
              #--The insertion was not possible
              [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_FRAREM","PPRICESEARCH.RESPRICEINQ"), [V]CST_AERROR)
              Break
            Endif
          Endif
          If MYPARAM.FMTCOLREM(1).C_FMTCOL(J).GCOLREM = '' : Break : Endif
          this.RESPRICEINQ(I).C_FRAREM(J).FRAREM    = MYRESULT.C_PRICEINQ(I).C_FRAREM(J).FRAREM
         # this.RESPRICEINQ(I).C_FRAREM(J).COLFRAREM = MYRESULT.C_PRICEINQ(I).C_FRAREM(J).COLFRAREM
          this.RESPRICEINQ(I).C_FRAREM(J).COLFRAREM = MYPARAM.FMTCOLREM(1).C_FMTCOL(J).GCOLREM
        Next J
      Endif
    Next I
  Endif

FreeGroup MYPARAM
[L]ARET_VALUE = [L]ASTATUS

Return

##############################################################################################################
$LOADPARAMFROMDOC
#--MYPARAM => pointer to the class parameters
#Variable Instance MYPARAM Using C_PFINDPRICE
  Local Integer WRET
  Local Integer WLINE : Raz WLINE

  Local Char WBID(30), WMESSAGE(250)
  Local Char WBIDC1(GLONFCY), WBIDC2(GLONBPR), WBIDC3(GLONBPA)

  Local File COMPANY    [CPY]
  Local File BPSUPPLIER [BPS]
  Local File BPADDRESS  [BPA]
  Local File ITMMASTER  [ITM]
  Local File ITMBPS     [ITP]
  Local File ITMFACILIT [ITF]
  Local File TABVACBPR  [TVB]
  Local File TABPAYTERM [TPT]
  Local File ACTIV      [ACV]


  Read [F:CPY]CPY0=this.CPY
  If fstat : Raz [F:CPY] : Endif

  Read [F:BPS]BPS0=this.BPSNUM
  If fstat : Raz [F:BPS] : Endif

  MYPARAM.setAccessorEnabled = 0

  If MYPARAM.PLI(1)=null
    WRET = fmet MYPARAM.ADDLINE("PLI",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"PLI","PFINDPRICE"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif
  If MYPARAM.FMTCOLREM(1)=null
    WRET = fmet MYPARAM.ADDLINE("FMTCOLREM",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"FMTCOLREM","PFINDPRICE"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif
  MYPARAM.FMTCOLREM(1).BPCBPS = 2 # For supplier price lists, 1 for Customer.
  MYPARAM.FMTCOLREM(1).PLISTC = this.PLISTC

  #--Initialising flags between BETCPY / BETFCY
  If MYPARAM.C_PPKH(1) = null
    WRET = fmet MYPARAM.ADDLINE("C_PPKH",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PPKH","PFINDPRICE"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif

  If MYPARAM.C_LINE(1) = null
    WRET = fmet MYPARAM.ADDLINE("C_LINE",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_LINE","PFINDPRICE"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif

  For WLINE=1 To 3
    If MYPARAM.C_LINE(1).C_VAT(WLINE) = null
      WRET = fmet MYPARAM.C_LINE(1).ADDLINE("C_VAT",WLINE)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_VAT","PFINDPRICE.C_LINE(1)"), [V]CST_AERROR)
        [L]ARET_VALUE = [L]ASTATUS
        Return
      Endif
    Endif
  Next WLINE

  If MYPARAM.C_LINE(1).C_PPKD(1) = null
    WRET = fmet MYPARAM.C_LINE(1).ADDLINE("C_PPKD",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PPKD","PFINDPRICE.C_LINE(1)"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif


# Loading header properties

  MYPARAM.MODULE = 6 :#--Purchasing
  If MYPARAM.TYPRECH = 0   #--Doublon avec PLITYP ????
     MYPARAM.TYPRECH = 1   #--Tarif normal
  Endif
  MYPARAM.PRITYP = this.PRITYP
  If MYPARAM.PRITYP = 0
     MYPARAM.PRITYP = 1
  Endif
  MYPARAM.CUR      = this.CURREF
  MYPARAM.PIO      = 0  #AVOID.AINT
  MYPARAM.BPSNUM    = this.BPSNUM
  MYPARAM.CHGTYP    = [F:BPS]CHGTYP
  MYPARAM.PLITYP = 1 :#--Tarif normal  LM 241
  MYPARAM.PURSALFCY = this.PURSALFCY
  MYPARAM.VACBPR = this.VACBPR
  MYPARAM.VACBPR_LEG = "" #AVOID.ACHAR
    Call LEC_TVB_LEG(this.ACTX, this.LEG, MYPARAM.VACBPR, WRET) From TRTLECLEG_SYRA
    If WRET=0
      MYPARAM.VACBPR_LEG = [F:TVB]LEG
    Endif
  MYPARAM.DOCDAT    = this.DATEREF
  If MYPARAM.DOCDAT = [0/0/0] #AVOID.ADATE
     MYPARAM.DOCDAT  = date$
  Endif

  MYPARAM.FCY       = this.FCY
  MYPARAM.PURSALFCY = this.PURSALFCY
  MYPARAM.CPY       = this.CPY
  MYPARAM.CUR       = this.CURREF
  MYPARAM.CPY       = this.CPY
  MYPARAM.MLTDIVCOE = 1       #AVOID.ADEC
  MYPARAM.VATCLCDAT = [0/0/0] #AVOID.ADATE
  MYPARAM.MOIS      = 1       #AVOID.AINT

  MYPARAM.GLOCALDEV = [F:CPY]ACCCUR
  MYPARAM.GSYSCUR   = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"SYSCUR")
  MYPARAM.GDECPRI = func SREPLACEGLOB_SYRA.GET_GDECPRI()

   WRET = func TRTPRICE_SYRA.ALICOLREM (MYPARAM.FMTCOLREM(1).BPCBPS, this.CURREF, 2, this, MYPARAM.PLI(1), MYPARAM.FMTCOLREM(1), this.PLISTC, WMESSAGE) #From TRTPRICE_SYRA
    #--Test if errors
    If WRET=[V]CST_AOK : WRET = fmet MYPARAM.AGETMAXERROR("") : Endif
    If WRET >=[V]CST_AERROR
      If WMESSAGE=""
        WMESSAGE = mess(68,123,1)-":"-mess(2,7845,1)-"ALICOLREM"
      Endif
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, WRET)
      [L]ARET_VALUE = [L]ASTATUS # 98349.n
      Return
    Endif

  MYPARAM.GPLINBR = maxtab(MYPARAM.PLI)
   #---"Header" the former Global variables (replaced by properties with same name => to pinpoint their use)
   #MYPARAM.GTYPGEN          #--uniquement pour les fact.
    MYPARAM.GSPLXGRP   = 0  #AVOID.AINT
    MYPARAM.GDECRCU    = fmet this.ACTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"DECRCU")
    MYPARAM.GSYSCUR    = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"SYSCUR")
    MYPARAM.GLOCALDEV  = [F:CPY]ACCCUR
    MYPARAM.GUPDPRISAL = fmet this.ACTX.APARAM.AGETVALNUM ([V]CST_ALEVFCY,this.FCY,"UPDPRISAL")
    MYPARAM.GPNTITMREF = "" #AVOID.ACHAR
    MYPARAM.GDECPRI    = func SREPLACEGLOB_SYRA.GET_GDECPRI()
    #--- Recherche du nombre de colonnes actives dans le code activite SPR
    Read [ACV]CODACT="PPR"
    If fstat or [F:ACV]FLACT<>[V]CST_AYES  : Raz [F:ACV] : Endif
    MYPARAM.GDISCRG=[F:ACV]DIMMAX

#--2) Loading the "header" part of the working table PPRICLINK

  MYPARAM.C_PPKH(1).POHTYP     = AVOID.AINT
  MYPARAM.C_PPKH(1).POHTYP_LEG = "" #AVOID.ACHAR
  MYPARAM.C_PPKH(1).PURTYP     = AVOID.AINT
  MYPARAM.C_PPKH(1).CPY        = this.CPY
  MYPARAM.C_PPKH(1).SALFCY     = this.PURSALFCY
  MYPARAM.C_PPKH(1).POHFCY     = this.FCY
  MYPARAM.C_PPKH(1).BPSNUM     = [F:BPS]BPSNUM
  MYPARAM.C_PPKH(1).BPSINV     = [F:BPS]BPSINV
  MYPARAM.C_PPKH(1).PJT        = this.PJT
  If filinfo(filpath("FIL","PIMPL","fde",nomap),0)>0
    MYPARAM.C_PPKH(1).PJTNUM     = func TRTPJT.GET_OPPNUM_FROM_PIMNUM(this.PJT)
  Endif
  MYPARAM.C_PPKH(1).EECICT     = this.EECICT
  MYPARAM.C_PPKH(1).PTE        = this.PTE
  MYPARAM.C_PPKH(1).PTE_LEG    = "" #AVOID.ACHAR
    Call LEC_TPT_LEG(this.ACTX, this.LEG, MYPARAM.C_PPKH(1).PTE, 1, WRET) From TRTLECLEG_SYRA
    If WRET=0
      MYPARAM.C_PPKH(1).PTE_LEG  = [F:TPT]LEG
      this.PTE_LEG               = [F:TPT]LEG
    Endif

    If this.MDL<>""
      MYPARAM.C_PPKH(1).MDL      = this.MDL
    Endif

    MYPARAM.C_PPKH(1).VACBPR     = MYPARAM.VACBPR
    MYPARAM.C_PPKH(1).VACBPR_LEG = MYPARAM.VACBPR_LEG
    MYPARAM.C_PPKH(1).PLIBPRCNR  = 0 #AVOID.AINT => même dans vintage il n'est pas initialsé


  #----- Loading currency -----#
Local Instance CTX Using C_WMACONTEXT
CTX = NewInstance C_WMACONTEXT AllocGroup null
Local Integer WTEMPINT
Local Decimal WCOEFDEVISE

Call COURSITE(MYPARAM.ACTX,MYPARAM.GSYSCUR,MYPARAM.PURSALFCY,1,this.DATEREF,WCOEFDEVISE,WTEMPINT) From TRTDEV_SYRA
#--Test if errors
    WRET = fmet MYPARAM.AGETMAXERROR("")
    If WRET >=[V]CST_AERROR
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(3,7845,1)-"COURSITE", WRET)
      [L]ARET_VALUE = [L]ASTATUS # 98349.n
      Return
    Endif
If WTEMPINT=0 & WCOEFDEVISE<>1 WCOEFDEVISE=WCOEFDEVISE/1000000000000.00 Else WCOEFDEVISE=1 Endif

#----- Loading fresh discount formats -----#
Local Char CTX_SYSCUR(8), GFCY(8)
CTX_SYSCUR = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"SYSCUR")
If CTX_SYSCUR <> this.CURREF  #GCUR
   Call CONVERT(MYPARAM.ACTX,CTX_SYSCUR,MYPARAM.GSYSCUR,MYPARAM.GLOCALDEV,1,MYPARAM.DOCDAT,
&               [F:BPS]OSTAUZAMT,WCOEFDEVISE,WTEMPINT) From TRTDEV_SYRA
#--Test if errors
    WRET = fmet MYPARAM.AGETMAXERROR("")
    If WRET >=[V]CST_AERROR
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(3,7845,1)-"CONVERT", WRET)
      [L]ARET_VALUE = [L]ASTATUS # 98349.n
      Return
    Endif
If WTEMPINT=0 & WCOEFDEVISE<>1 WCOEFDEVISE=WCOEFDEVISE/1000000000000.00 Else WCOEFDEVISE=1 Endif
Else

Endif

#------ Loading billing items - not needed on Purch Price Search function

WGFCY = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.CPY, "MAIFCY")

If [F:ITM]ITMREF<>this.ITMREF
  Read [ITM] ITM0=this.ITMREF : If fstat Raz [F:ITM] : Endif
Endif

If [F:ITF]ITMREF<>this.ITMREF | [F:ITF]STOFCY<>WGFCY
  Read [ITF] ITF0=this.ITMREF;WGFCY : If fstat Raz [F:ITF] : Endif
Endif

If [F:ITP]ITMREF<>this.ITMREF | [F:ITP]BPSNUM<>this.BPSNUM
  Read [ITP] ITP0=this.ITMREF;this.BPSNUM : If fstat Raz [F:ITP] : Endif
Endif

If [F:ITF]ITMREF<>this.ITMREF | [F:ITF]STOFCY<>this.FCY
  Read [ITF] ITF0=this.ITMREF;this.FCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif

If [L]ASTATUS = [V]CST_AOK

Local Char  WSALFCY(GLONFCY), WSTOFCY(GLONFCY) # Blank placeholders
Call CTRL_INTERSITE("PSI",this.CPY,this.PURSALFCY,this.BPSNUM,2,MYPARAM.C_PPKH(1).BETFCY,MYPARAM.C_PPKH(1).BETCPY,
&                   WSALFCY,WSTOFCY,AVOID.ACHAR,AVOID.ACHAR,
&                   AVOID.ACHAR,MYPARAM,1,WRET) From TRTACHCTL1_SYRA # From FUNACHPPSI

If fmet MYPARAM.AGETMAXERROR("")>=[V]CST_AERROR or WRET>=[V]CST_AERROR
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, WRET)
      [L]ARET_VALUE = [L]ASTATUS # 98349.n
      Return
Endif

Endif

  #--3) Loading the "line" properties => those that normaly comes from a document line

  MYPARAM.NBLIG           = maxtab(MYPARAM.C_LINE)
  MYPARAM.C_LINE(1).ITMREF=this.ITMREF
  MYPARAM.C_LINE(1).QTY   =this.QTYREF
  MYPARAM.C_LINE(1).FCY   =this.PURSALFCY
  MYPARAM.C_LINE(1).PUU   =this.PUUREF
  MYPARAM.C_LINE().CUR    = this.CURREF
  MYPARAM.C_LINE(1).PUUSTUCOE = 1  #AVOID.ADEC
  MYPARAM.C_LINE(1).GROPRI    = 0  #AVOID.ADEC
  MYPARAM.C_LINE(1).NETPRI    = 0  #AVOID.ADEC

    Local Instance MYVATPARAM Using C_FINDVAT
    MYVATPARAM = NewInstance C_FINDVAT AllocGroup null

    MYVATPARAM.setAccessorEnabled = 0
  #--Initializing taxes using the RECHVATCOD subroutine
    MYVATPARAM.TRAIT = 1
    WRET = fmet MYVATPARAM.FINDVAT(this)
    If fmet MYVATPARAM.AGETMAXERROR("")>=[V]CST_AERROR or WRET>=[V]CST_AERROR
      [L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(1,7845,1)-"FINDVAT", [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif

    FreeGroup MYVATPARAM

   MYPARAM.C_LINE(1).CLCAMT1  = 0  #AVOID.ADEC
   MYPARAM.C_LINE(1).CLCAMT2  = 0  #AVOID.ADEC
   MYPARAM.C_LINE(1).CLCAMT3  = 0  #AVOID.ADEC
   For WLINE = 1 To maxtab(MYPARAM.C_LINE(1).C_DISCRG)
      If MYPARAM.C_LINE(1).C_DISCRG(WLINE)<>null
         MYPARAM.C_LINE(1).C_DISCRG(WLINE).DISCRGVAL  = 0  #AVOID.ADEC
         MYPARAM.C_LINE(1).C_DISCRG(WLINE).DISCRGREN  = 0  #AVOID.AINT
      Endif
    Next WLINE

    MYPARAM.C_LINE(1).PRIREN = 0  #AVODI.AINT
    MYPARAM.C_LINE(1).GRPFLG = 0  #AVOID.AINT
    MYPARAM.C_LINE(1).CUR = this.CURREF
 #--2) Loading the "line" part of the working table pPRICLINK
    MYPARAM.C_LINE(1).C_PPKD(1).FCY     = this.FCY
    MYPARAM.C_LINE(1).C_PPKD(1).PRHFCY  = this.FCY
    MYPARAM.C_LINE(1).C_PPKD(1).PJT     = this.PJT
    If filinfo(filpath("FIL","PIMPL","fde",nomap),0)>0
      MYPARAM.C_LINE(1).C_PPKD(1).PJTNUM  = func TRTPJT.GET_OPPNUM_FROM_PIMNUM(this.PJT)
    Endif

   Read [F:ITM]ITM0=this.ITMREF
   If fstat : Raz [F:ITM] : Endif

   For I = 1 To dim([F:ITM]TSICOD)

     If MYPARAM.C_LINE(1).C_PPKD(1).C_TSICOD(I) = null
       WRET = fmet MYPARAM.C_LINE(1).C_PPKD(1).ADDLINE("C_TSICOD",I)
       If WRET = [V]CST_ANOTDEFINED
         #--The insertion was not possible
         [L]ASTATUS = fmet MYPARAM.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_TSICOD","PFINDPRICE.C_LINE(1).C_PPKD(1)"), [V]CST_AERROR)
         Break
       Endif
     Endif
     MYPARAM.C_LINE(1).C_PPKD(1).C_TSICOD(I).TSICOD = [F:ITM]TSICOD(I-1)
   Next I

# C_LINE collection from PFNDPRICED class
Local Decimal WCOESTU
Call PCAL_QTY(this.QTYREF(0),this.PUUREF(0),this.QTYREF(0),this.PUUREF,
&             this.ITMREF(0),this.BPSNUM,1,WCOESTU) From TRTACHQTE1_SYRA

 MYPARAM.C_LINE(1).PUUSTUCOE = WCOESTU
 MYPARAM.C_LINE(1).C_PPKD(1).FCY=this.PURSALFCY
 MYPARAM.C_LINE(1).C_PPKD(1).ITMREFORI  = "" #AVOID.ACHAR
 MYPARAM.C_LINE(1).C_PPKD(1).CLCAMT1    = MYPARAM.C_LINE(1).CLCAMT1 #0  #AVOID.ADEC
 MYPARAM.C_LINE(1).C_PPKD(1).CLCAMT2    = MYPARAM.C_LINE(1).CLCAMT2 #0  #AVOID.ADEC
 MYPARAM.C_LINE(1).C_PPKD(1).CLCAMT3    = MYPARAM.C_LINE(1).CLCAMT3 #0  #AVOID.ADEC
 #MYPARAM.C_LINE(1).C_PPKD(1).LINTYP     = 0  #AVOID.AINT
 MYPARAM.C_LINE(1).C_PPKD(1).CSTTYP     = 1  #Prix standard par defaut
 MYPARAM.C_LINE(1).C_PPKD(1).CUR        = MYPARAM.C_LINE(1).CUR #this.CURREF
 MYPARAM.C_LINE(1).C_PPKD(1).PJT        = this.PJT
 If filinfo(filpath("FIL","PIMPL","fde",nomap),0)>0
   MYPARAM.C_LINE(1).C_PPKD(1).PJTNUM     = func TRTPJT.GET_OPPNUM_FROM_PIMNUM(this.PJT) : # Code affaire seul
 Endif

this.setAccessorEnabled = 1
[L]ARET_VALUE = [L]ASTATUS

Return

##############################################################################################################
$LOADDOCFROMRESULT
  If fmet this.AGETMAXERROR("")>=[V]CST_AERROR : Return : Endif

#--MYRESULT => pointer to the Result instance
#--MYPARAM  => pointer to the Parameters instance

Local Char WMESSAGE(250)
  If MYRESULT = null
    [L]ASTATUS = fmet this.ASETERROR ("", "MYRESULT :"-mess(18,9137,1), [V]CST_AERROR)
    [L]ARET_VALUE = [L]ASTATUS
  Endif

  Gosub RAZ_EXISTING

  Local Integer LIN_PRICEDET,WLINERET, WNBLINE

  Raz LIN_PRICEDET,WLINERET, WNBLINE

  For LIN_PRICEDET = maxtab(this.C_PRICEDET2) To 1 Step -1
   #--Use of freeinstance and =null instead of ADELLINE
   #--Staying in "Create" mode, the "deleted" lines are not freed and stay with ASTALIN = ADEL !!
   #--This induce the articfical growth of the C_PRICEDET2 collection
    If this.C_PRICEDET2(LIN_PRICEDET) <> null
       FreeInstance this.C_PRICEDET2(LIN_PRICEDET)
       this.C_PRICEDET2(LIN_PRICEDET) = null
     Endif
     #WLINERET = fmet this.ADELLINE("C_PRICEDET2",LIN_PRICEDET)
#    If WLINERET = [V]CST_ANOTDEFINED
#      #--The deletion was not possible
#      [L]ASTATUS = fmet this.ASETERROR ("", "Data class SPRICESEARCH : Call LOAD_C_PRICEDET result error for this.ADELLINE 'C_PRICEDET'"-num$(LIN_PRICEDET), [V]CST_AERROR)
#      Return
#    Endif
   Next LIN_PRICEDET

  Local Integer WLINE,WRET
  Local Integer WSETACCESSORENABLED : WSETACCESSORENABLED = this.setAccessorEnabled
  this.setAccessorEnabled = 0

  Local File TABCUR      [TCU]
  Local File PFOOTINV    [PFI]
  Local File PRICSTRUCT  [PRS]

  Local Integer WDIMPRD
  WDIMPRS = min( dim([F:PRS]NPRNOTFLG), dim([F:PRS]INCDCR), dim([F:PRS]INVDTA), dim([F:PRS]CLCRUL))

  Read [TCU]TCU0=this.CURREF
  If fstat : Raz [F:TCU] : Endif

  Read [PRS]PRS0=2;this.PLISTC
  If fstat : Raz [F:PRS] : Endif

If this.C_PRICE(1)=null
    WRET = fmet this.ADDLINE("C_PRICE",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICE","PPRICESEARCH"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif

  If this.C_PRICE(2)=null
    WRET = fmet this.ADDLINE("C_PRICE",2)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICE","PPRICESEARCH"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif

  If MYRESULT.C_PRICE(1) <> null
    this.C_PRICE(1).GROPRI = arr(MYRESULT.C_PRICE(1).MONTANT,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())

    this.C_PRICE(2).GROPRI = arr(MYRESULT.C_PRICE(1).MONTANT*this.QTYREF,[F:TCU]CURRND)

    #--Pour l'appel à CALCNETPRI
    For WLINE=1 To maxtab(MYRESULT.C_DISCRG)

      If WLINE<= WDIMPRS-1 and MYRESULT.C_DISCRG(WLINE)<>null

        If this.C_DISCRG(WLINE)=null
          WRET = fmet this.ADDLINE("C_DISCRG",WLINE)
          If WRET = [V]CST_ANOTDEFINED
            #--The insertion was not possible
            [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_DISCRG","PPRICESEARCH"), [V]CST_AERROR)
            [L]ARET_VALUE = [L]ASTATUS
            Return
          Endif
        Endif

        this.C_DISCRG(WLINE).DISCRGVAL = MYRESULT.C_DISCRG(WLINE).MONTANT
        this.C_DISCRG(WLINE).DISCRGREN = MYRESULT.C_DISCRG(WLINE).MOTIF

      Endif

    Next WLINE

    #--Appel au sous-pro de calcul du prix net
    Local Decimal WAMTDISCRG(1..) #  2/18/2014
    WRET = func TRTACHPRI_SYRA.CALCNETPRI_DETAILS(this.QTYREF,this.CURREF,this,this.C_PRICE(1),WAMTDISCRG,WMESSAGE)
    If WRET >=[V]CST_AERROR
      If WMESSAGE=""
        WMESSAGE = mess(68,123,1)-":"-mess(2,7845,1)-"CALCNETPRI_DETAILS"
      Endif
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS # 98349.n
      Return
    Endif
    #this.C_PRICE(1).NETPRI      = arr(this.C_PRICE(1).NETPRI,.01)
    this.C_PRICE(1).NETPRI      = arr(this.C_PRICE(1).NETPRI,10^-func SREPLACEGLOB_SYRA.GET_GDECPRI())
    this.C_PRICE(2).NETPRI      = arr(this.C_PRICE(1).NETPRI*this.QTYREF,[F:TCU]CURRND)
    this.C_PRICE(1).LIBPRIX     = tolower(mess(269,198,1)) # Unit
    this.C_PRICE(2).LIBPRIX     = "* "+num$(this.QTYREF)
 # Endif
    #--Gross price => 1st
    #If this.C_PRICE(1)<>null
      WLINERET = 1
      If this.C_PRICEDET2(1) = null or find(this.C_PRICEDET2(1).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
        WLINERET = fmet this.ADDLINE("C_PRICEDET2",WLINERET)
        If WLINERET = [V]CST_ANOTDEFINED
          #--The insertion was not possible
          [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET2","PPRICESEARCH"), [V]CST_AERROR)
          [L]ARET_VALUE = [L]ASTATUS
          Return
        Endif
      Endif
      this.C_PRICEDET2(WLINERET).PCOLDES2 = mess(294,197,1) #"Prix brut"
      this.C_PRICEDET2(WLINERET).PVALUE2  = ""
      #this.C_PRICEDET2(WLINERET).PAMOUNT = arr(this.C_PRICE(1).GROPRI,.01)

      #this.C_PRICEDET2(WLINERET).PAMOUNT = this.C_PRICE(1).GROPRI  98623.o
      this.C_PRICEDET2(WLINERET).PAMOUNT = arr(this.C_PRICE(1).GROPRI,[F:TCU]CURRND) :#--CPO 98623.n
      WNBLINE = WLINERET
    Endif

  For WLINE=1 To maxtab(MYRESULT.C_DISCRG)
    If MYRESULT.C_DISCRG(WLINE)<>null and WLINE <= WDIMPRS#-1  -1 REMOVED 3/4/2014
      WSENS=1
      #--#--Discounts/Charges not included in the net unit price
      If [F:PRS]NPRNOTFLG(WLINE-1)<>2  #=1                       : # si valeur colonne hors prix net

        WXAUTRE=MYRESULT.C_DISCRG(WLINE).MONTANT

        If [F:PRS]INCDCR(WLINE-1)=2 : WSENS=-1 : Endif

# 98600.so
#        If [F:PRS]INVDTA(WLINE-1)<>0
#
#          Read [PFI]PFI0=[F:PRS]INVDTA(WLINE-1)
#          If !fstat
#            If [F:PFI]AMTCOD=1 : WXAUTRE=(this.C_PRICE(1).NETPRI*WXAUTRE)/100 : Endif
#          Endif
#
#        Endif 98600.eo

# 98600.sn
        If [F:PRS]VALTYP(WLINE-1)=2         # Percentage %
          If [F:PRS]CLCRUL(WLINE-1)=1       # Unit
            WXAUTRE=(this.C_PRICE(1).NETPRI*WXAUTRE)/100
          Endif
        Endif
# 98600.en
        WXAUTRE=WXAUTRE*WSENS

        If [F:PRS]CLCRUL(WLINE-1)=1                            : # si valeur colonne par unité
          this.C_PRICE(1).AUTRE += arr(WXAUTRE,[F:TCU]CURRND)
          this.C_PRICE(2).AUTRE += arr(WXAUTRE*this.QTYREF,[F:TCU]CURRND)
        Endif

        If [F:PRS]CLCRUL(WLINE-1)=2                            : # si valeur colonne par ligne
          this.C_PRICE(2).AUTRE += WXAUTRE
        Endif
      Endif
    Endif
  Next WLINE

  For WLINE=1 To maxtab(MYRESULT.C_DISCRG)
    If MYRESULT.C_DISCRG(WLINE)<>null and WLINE <= WDIMPRS#-1

      If this.C_FRAISREM(WLINE)=null
        WRET = fmet this.ADDLINE("C_FRAISREM",WLINE)
        If WRET = [V]CST_ANOTDEFINED
          #--The insertion was not possible
            [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_FRAISREM","PPRICESEARCH"), [V]CST_AERROR)
            [L]ARET_VALUE = [L]ASTATUS
          Return
        Endif
      Endif
     #  Discounts ......
       If MYPARAM.FMTCOLREM(1)<>null and MYPARAM.FMTCOLREM(1).C_FMTCOL(WLINE)<>null

          this.C_FRAISREM(WLINE).COLDES = MYPARAM.FMTCOLREM(1).C_FMTCOL(WLINE).GCOLREM

          If [F:PRS]VALTYP(WLINE-1)=1
              this.C_FRAISREM(WLINE).AMT = format$(MYPARAM.FMTCOLREM(1).C_FMTCOL(WLINE).GFORREM, MYRESULT.C_DISCRG(WLINE).MONTANT)
          Else
              this.C_FRAISREM(WLINE).RAT = format$(MYPARAM.FMTCOLREM(1).C_FMTCOL(WLINE).GFORREM, MYRESULT.C_DISCRG(WLINE).MONTANT)
          Endif
        Endif

      #--#--Discounts/Charges in the net unit price  # Not removed
      If [F:PRS]NPRNOTFLG(WLINE-1)=2 #<>1
        WLINERET = WNBLINE+1
        If this.C_PRICEDET2(WLINERET) = null or find(this.C_PRICEDET2(WLINERET).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
          WLINERET = fmet this.ADDLINE("C_PRICEDET2",WLINERET)
          If WLINERET = [V]CST_ANOTDEFINED
            #--The insertion was not possible
            [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET2","PPRICESEARCH"), [V]CST_AERROR)
            [L]ARET_VALUE = [L]ASTATUS
            Return
          Endif
        Endif

        If this.C_FRAISREM(WLINE)<>null
          this.C_PRICEDET2(WLINERET).PCOLDES2 = this.C_FRAISREM(WLINE).COLDES
          If [F:PRS]VALTYP(WLINE-1)=1
            this.C_PRICEDET2(WLINERET).PVALUE2  = this.C_FRAISREM(WLINE).AMT
          Else
            this.C_PRICEDET2(WLINERET).PVALUE2  = this.C_FRAISREM(WLINE).RAT
          Endif
        Else
          this.C_PRICEDET2(WLINERET).PCOLDES2 = ""
        Endif

        If dim(WAMTDISCRG(LIN_PRICEDET))>0
         # this.C_PRICEDET2(WLINERET).PAMOUNT  = arr(WAMTDISCRG(WLINE),.01)
          #this.C_PRICEDET2(WLINERET).PAMOUNT  = WAMTDISCRG(WLINE) 98623.o
          this.C_PRICEDET2(WLINERET).PAMOUNT  = arr(WAMTDISCRG(WLINE),[F:TCU]CURRND) :#--CPO 98623.n
        Else
          this.C_PRICEDET2(WLINERET).PAMOUNT  = 0
        Endif
        WNBLINE = WLINERET
      Endif
    Endif

  Next WLINE

  this.C_PRICE(1).TOTAL  = arr(this.C_PRICE(1).NETPRI + this.C_PRICE(1).AUTRE,.01) # 2/28/2014
  this.C_PRICE(2).TOTAL  = this.C_PRICE(2).NETPRI + this.C_PRICE(2).AUTRE

  If this.C_PRICE(1)<>null
    #--Unit net price
    If this.C_PRICE(1).NETPRI<>0
      WLINERET = WNBLINE+1
      If this.C_PRICEDET2(WLINERET) = null or find(this.C_PRICEDET2(WLINERET).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
        WLINERET = fmet this.ADDLINE("C_PRICEDET2",WLINERET)
        If WLINERET = [V]CST_ANOTDEFINED
          #--The insertion was not possible
          [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET2","PPRICESEARCH"), [V]CST_AERROR)
          [L]ARET_VALUE = [L]ASTATUS
          Return
        Endif
      Endif

      this.C_PRICEDET2(WLINERET).PCOLDES2 = mess(295,197,1)-"("+mess(269,198,1)+")" #"Prix net (Unitaire)"
      this.C_PRICEDET2(WLINERET).PVALUE2  = ""
      #this.C_PRICEDET2(WLINERET).PAMOUNT = arr(this.C_PRICE(1).NETPRI,.01)
      #this.C_PRICEDET2(WLINERET).PAMOUNT = this.C_PRICE(1).NETPRI 98623.o
      this.C_PRICEDET2(WLINERET).PAMOUNT = arr(this.C_PRICE(1).NETPRI,[F:TCU]CURRND) :#--CPO 98623.n
      WNBLINE = WLINERET
    Endif

    #--Unit Other
    If this.C_PRICE(1).AUTRE<>0
      WLINERET = WNBLINE+1
      If this.C_PRICEDET2(WLINERET) = null or find(this.C_PRICEDET2(WLINERET).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
        WLINERET = fmet this.ADDLINE("C_PRICEDET2",WLINERET)
        If WLINERET = [V]CST_ANOTDEFINED
          #--The insertion was not possible
          [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET2","PPRICESEARCH"), [V]CST_AERROR)
          [L]ARET_VALUE = [L]ASTATUS
          Return
        Endif
      Endif

      this.C_PRICEDET2(WLINERET).PCOLDES2 = mess(167,123,1)-"("+mess(269,198,1)+")" #"Divers (Unitaire)"
      this.C_PRICEDET2(WLINERET).PVALUE2  = ""
      # this.C_PRICEDET2(WLINERET).PAMOUNT = arr(this.C_PRICE(1).AUTRE,.01)
        #this.C_PRICEDET2(WLINERET).PAMOUNT = this.C_PRICE(1).AUTRE 98623.o
        this.C_PRICEDET2(WLINERET).PAMOUNT = arr(this.C_PRICE(1).AUTRE,[F:TCU]CURRND) :#--CPO 98623.n
      WNBLINE = WLINERET
    Endif

    #--Total unit price
    If this.C_PRICE(1).NETPRI<>0 or this.C_PRICE(1).AUTRE<>0
      WLINERET = WNBLINE+1
      If this.C_PRICEDET2(WLINERET) = null or find(this.C_PRICEDET2(WLINERET).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
        WLINERET = fmet this.ADDLINE("C_PRICEDET2",WLINERET)
        If WLINERET = [V]CST_ANOTDEFINED
          #--The insertion was not possible
          [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET2","PPRICESEARCH"), [V]CST_AERROR)
          [L]ARET_VALUE = [L]ASTATUS
          Return
        Endif
      Endif

      this.C_PRICEDET2(WLINERET).PCOLDES2 = mess(155,121,1)-"("+mess(269,198,1)+")" #"Total (Unitaire)"
      this.C_PRICEDET2(WLINERET).PVALUE2  = ""
      #this.C_PRICEDET2(WLINERET).PAMOUNT = this.C_PRICE(1).NETPRI+this.C_PRICE(1).AUTRE 98623.o
      this.C_PRICEDET2(WLINERET).PAMOUNT = arr(this.C_PRICE(1).NETPRI+this.C_PRICE(1).AUTRE,[F:TCU]CURRND) :#--CPO 98623.n
      WNBLINE = WLINERET
    Endif

  Endif

  If this.C_PRICE(2)<>null
    #--Total net price
    If this.C_PRICE(1).NETPRI<>0
      WLINERET = WNBLINE+1
      If this.C_PRICEDET2(WLINERET) = null or find(this.C_PRICEDET2(WLINERET).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
        WLINERET = fmet this.ADDLINE("C_PRICEDET2",WLINERET)
        If WLINERET = [V]CST_ANOTDEFINED
          #--The insertion was not possible
          [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET2","PPRICESEARCH"), [V]CST_AERROR)
          [L]ARET_VALUE = [L]ASTATUS
          Return
        Endif
      Endif

      this.C_PRICEDET2(WLINERET).PCOLDES2 = this.C_PRICE(2).LIBPRIX
      this.C_PRICEDET2(WLINERET).PVALUE2  = ""
      #this.C_PRICEDET2(WLINERET).PAMOUNT = arr(this.C_PRICE(2).NETPRI,.01)
      #this.C_PRICEDET2(WLINERET).PAMOUNT = this.C_PRICE(2).NETPRI 98623.o
      this.C_PRICEDET2(WLINERET).PAMOUNT = arr(this.C_PRICE(2).NETPRI,[F:TCU]CURRND) :#--CPO 98623.n
      WNBLINE = WLINERET
    Endif
  Endif
  ##############################################
  #--Discounts/Charges not included in the net unit price
  For LIN_PRICEDET = 1 To maxtab(MYRESULT.C_DISCRG)
    If LIN_PRICEDET <= WDIMPRS and MYRESULT.C_DISCRG(LIN_PRICEDET)<>null and this.C_FRAISREM(LIN_PRICEDET)<>null and this.C_FRAISREM(LIN_PRICEDET).COLDES<>"" and WAMTDISCRG(LIN_PRICEDET)<>0
      If [F:PRS]NPRNOTFLG(LIN_PRICEDET-1)=1 #--Discounts/Charges not included in the net unit price
        WLINERET = WNBLINE+1
        If this.C_PRICEDET2(WLINERET) = null or find(this.C_PRICEDET2(WLINERET).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
          WLINERET = fmet this.ADDLINE("C_PRICEDET2",WLINERET)
          If WLINERET = [V]CST_ANOTDEFINED
            #--The insertion was not possible
            [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET2","PPRICESEARCH"), [V]CST_AERROR)
            [L]ARET_VALUE = [L]ASTATUS
            Return
          Endif
        Endif

        If this.C_FRAISREM(LIN_PRICEDET)<>null
          this.C_PRICEDET2(WLINERET).PCOLDES2 = this.C_FRAISREM(LIN_PRICEDET).COLDES
          If [F:PRS]VALTYP(LIN_PRICEDET-1)=1
           #this.C_PRICEDET2(WLINERET).PVALUE2  = arr(this.C_FRAISREM(LIN_PRICEDET).AMT,.01)
           this.C_PRICEDET2(WLINERET).PVALUE2  = this.C_FRAISREM(LIN_PRICEDET).AMT
          Else
            this.C_PRICEDET2(WLINERET).PVALUE2  = this.C_FRAISREM(LIN_PRICEDET).RAT
          Endif
        Else
          this.C_PRICEDET2(WLINERET).PCOLDES2 = ""
        Endif

        If dim(WAMTDISCRG(LIN_PRICEDET))>0
          #this.C_PRICEDET2(WLINERET).PAMOUNT  = WAMTDISCRG(LIN_PRICEDET) 98623.O
          this.C_PRICEDET2(WLINERET).PAMOUNT  = arr(WAMTDISCRG(LIN_PRICEDET),[F:TCU]CURRND) :#--CPO 98623.n
        Else
          this.C_PRICEDET2(WLINERET).PAMOUNT  = 0
        Endif
        WNBLINE = WLINERET
      Endif
    Endif
  Next LIN_PRICEDET

  If this.C_PRICE(2)<>null
    #--Total miscellaneous price
    If this.C_PRICE(2).AUTRE<>0
      WLINERET = WNBLINE+1
      If this.C_PRICEDET2(WLINERET) = null or find(this.C_PRICEDET2(WLINERET).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
        WLINERET = fmet this.ADDLINE("C_PRICEDET2",WLINERET)
        If WLINERET = [V]CST_ANOTDEFINED
          #--The insertion was not possible
          [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET2","PPRICESEARCH"), [V]CST_AERROR)
          [L]ARET_VALUE = [L]ASTATUS
          Return
        Endif
      Endif

      this.C_PRICEDET2(WLINERET).PCOLDES2 = mess(167,123,1)-"("+mess(155,121,1)+")" #"Divers total"
      this.C_PRICEDET2(WLINERET).PVALUE2  = ""
      #this.C_PRICEDET2(WLINERET).PAMOUNT = arr(this.C_PRICE(2).AUTRE,.01)
      #this.C_PRICEDET2(WLINERET).PAMOUNT = this.C_PRICE(2).AUTRE 98623.o
      this.C_PRICEDET2(WLINERET).PAMOUNT = arr(this.C_PRICE(2).AUTRE,[F:TCU]CURRND) :#--CPO 98623.n
      WNBLINE = WLINERET
    Endif

    #--Total price
    If this.C_PRICE(2).NETPRI<>0 or this.C_PRICE(2).AUTRE<>0
      WLINERET = WNBLINE+1
      If this.C_PRICEDET2(WLINERET) = null or find(this.C_PRICEDET2(WLINERET).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
        WLINERET = fmet this.ADDLINE("C_PRICEDET2",WLINERET)
        If WLINERET = [V]CST_ANOTDEFINED
          #--The insertion was not possible
          [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET2","PPRICESEARCH"), [V]CST_AERROR)
          [L]ARET_VALUE = [L]ASTATUS
          Return
        Endif
      Endif

      this.C_PRICEDET2(WLINERET).PCOLDES2 = mess(155,121,1) #"Total"
      this.C_PRICEDET2(WLINERET).PVALUE2  = ""
      #this.C_PRICEDET2(WLINERET).PAMOUNT = arr(this.C_PRICE(2).NETPRI+this.C_PRICE(2).AUTRE,.01) 98623.o
      this.C_PRICEDET2(WLINERET).PAMOUNT = arr(this.C_PRICE(2).NETPRI+this.C_PRICE(2).AUTRE,[F:TCU]CURRND) :#--CPO 98623.n
      WNBLINE = WLINERET
    Endif

  Endif

  For LIN_PRICEDET = maxtab(this.C_PRICEDET2) To 1 Step -1
    If this.C_PRICEDET2(LIN_PRICEDET)<>null
    If MYRESULT.C_PRICE.MONTANT = 0 : Break : Endif
      If this.C_PRICEDET2(LIN_PRICEDET).PAMOUNT=0 and !find(this.C_PRICEDET2(LIN_PRICEDET).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
        WLINERET = fmet this.ADELLINE("C_PRICEDET2",LIN_PRICEDET)
        If WLINERET = [V]CST_ANOTDEFINED
          #--The deletion was not possible
          [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET2","PPRICESEARCH"), [V]CST_AERROR)
          [L]ARET_VALUE = [L]ASTATUS
          Return
        Endif
      Endif

    Endif
  Next LIN_PRICEDET

    Gosub LOAD_C_PRICEDET

  this.setAccessorEnabled = WSETACCESSORENABLED

Return

##############################################################################################################
$LOAD_C_PRICEDET
#WAMTDISCRG => contains the amount of the discount
  Local Integer LIN_PRICEDET,WLINERET, WNBLINE

  Raz LIN_PRICEDET,WLINERET, WNBLINE

  For LIN_PRICEDET = maxtab(this.C_PRICEDET) To 1 Step -1
    WLINERET = fmet this.ADELLINE("C_PRICEDET",LIN_PRICEDET)
#    If WLINERET = [V]CST_ANOTDEFINED
#      #--The deletion was not possible
#      [L]ASTATUS = fmet this.ASETERROR ("", "Data class SPRICESEARCH : Call LOAD_C_PRICEDET result error for this.ADELLINE 'C_PRICEDET'"-num$(LIN_PRICEDET), [V]CST_AERROR)
#      Return
#    Endif
  Next LIN_PRICEDET

  #--Gross price => 1st
  If this.C_PRICE(1)<>null
    WLINERET = 1
    If this.C_PRICEDET(1) = null or find(this.C_PRICEDET(1).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
      WLINERET = fmet this.ADDLINE("C_PRICEDET",WLINERET)  #[V]CST_ALASTPOS)
      If WLINERET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET","PPRICESEARCH"), [V]CST_AERROR)
        Return
      Endif
    Endif
    this.C_PRICEDET(WLINERET).PCOLDES =  mess(294,197,1) #"Gross price"
    this.C_PRICEDET(WLINERET).PVALUE  = this.C_PRICE(1).GROPRI
    #this.C_PRICEDET(WLINERET).PVALUE  = arr(this.C_PRICE(1).GROPRI,.01)
    WNBLINE = WLINERET
  Endif

  #--Discounts/Charges
  For LIN_PRICEDET = 1 To maxtab(this.C_DISCRG)
    If this.C_DISCRG(LIN_PRICEDET)<>null and this.C_DISCRG(LIN_PRICEDET).DISCRGVAL<>0
      WLINERET = WNBLINE+1
      If this.C_PRICEDET(WLINERET) = null or find(this.C_PRICEDET(WLINERET).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
        WLINERET = fmet this.ADDLINE("C_PRICEDET",WLINERET)  #[V]CST_ALASTPOS)
        If WLINERET = [V]CST_ANOTDEFINED
          #--The insertion was not possible
            [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET","PPRICESEARCH"), [V]CST_AERROR)
          Return
        Endif
      Endif

      If this.C_FRAISREM(LIN_PRICEDET)<>null
        this.C_PRICEDET(WLINERET).PCOLDES = this.C_FRAISREM(LIN_PRICEDET).COLDES
      Else
        this.C_PRICEDET(WLINERET).PCOLDES = ""
      Endif

      If dim(WAMTDISCRG(LIN_PRICEDET))>0
         #this.C_PRICEDET(WLINERET).PVALUE  = WAMTDISCRG(LIN_PRICEDET) : 98623.o
         this.C_PRICEDET(WLINERET).PVALUE  = arr(WAMTDISCRG(LIN_PRICEDET),[F:TCU]CURRND) :#--CPO 98623n
         #this.C_PRICEDET(WLINERET).PVALUE  = arr(WAMTDISCRG(LIN_PRICEDET),.01)
      Else
        this.C_PRICEDET(WLINERET).PVALUE  = 0
      Endif
      WNBLINE = WLINERET
    Endif

  Next LIN_PRICEDET
  #--Net price => last

  If this.C_PRICE(1)<>null
    WLINERET = WNBLINE+1
    If this.C_PRICEDET(WLINERET) = null or find(this.C_PRICEDET(WLINERET).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
      WLINERET = fmet this.ADDLINE("C_PRICEDET",WLINERET)  #[V]CST_ALASTPOS)
      If WLINERET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET","PPRICESEARCH"), [V]CST_AERROR)
        Return
      Endif
    Endif

    this.C_PRICEDET(WLINERET).PCOLDES = mess(295,197,1) #"Price net"
    this.C_PRICEDET(WLINERET).PVALUE  = this.C_PRICE(1).NETPRI
    # this.C_PRICEDET(WLINERET).PVALUE  = arr(this.C_PRICE(1).NETPRI,.01)
    WNBLINE = WLINERET
  Endif

  For LIN_PRICEDET = maxtab(this.C_PRICEDET) To 1 Step -1
    If this.C_PRICEDET(LIN_PRICEDET)<>null
   If MYRESULT.C_PRICE.MONTANT = 0 : Break : Endif
      If this.C_PRICEDET(LIN_PRICEDET).PVALUE=0
        WLINERET = fmet this.ADELLINE("C_PRICEDET",LIN_PRICEDET)
        If WLINERET = [V]CST_ANOTDEFINED
          #--The deletion was not possible
          [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PRICEDET","PPRICESEARCH"), [V]CST_AERROR)
          Return
        Endif
      Endif

    Endif
  Next LIN_PRICEDET

Return

###################################################################################################
#--Emptying existing results
$RAZ_EXISTING
Local Integer IJRAZ
#Raz this.NBPRICE
Local Integer WACCESSORENABLED : WACCESSORENABLED = this.setAccessorEnabled
this.setAccessorEnabled = 0


################
For IJRAZ = 1 To maxtab(this.C_PRICEDET2)
  If this.C_PRICEDET2(IJRAZ)<>null
    this.C_PRICEDET2(IJRAZ).PCOLDES2 = "" #AVOID.ACHAR
    this.C_PRICEDET2(IJRAZ).PVALUE2  = ""  #AVOID.ADEC
    this.C_PRICEDET2(IJRAZ).PAMOUNT  = 0  #AVOID.ADEC
  Endif
Next IJRAZ
###############

this.NBPRICE = 0 #this.NBPRICE = AVOID.AINT

For IJRAZ = 1 To maxtab(this.C_PRICE)
  If this.C_PRICE(IJRAZ)<>null

    this.C_PRICE(IJRAZ).LIBPRIX = "" #AVOID.ACHAR
    this.C_PRICE(IJRAZ).GROPRI  = 0  #AVOID.ADEC
    this.C_PRICE(IJRAZ).NETPRI  = 0  #AVOID.ADEC
    this.C_PRICE(IJRAZ).AUTRE   = 0  #AVOID.ADEC
    this.C_PRICE(IJRAZ).TOTAL   = 0  #AVOID.ADEC

  Endif
Next IJRAZ

this.NBFRAISREM = 0 #AVOID.AINT

For IJRAZ = 1 To maxtab(this.C_FRAISREM)
  If this.C_FRAISREM(IJRAZ)<>null
    this.C_FRAISREM(IJRAZ).COLDES = "" #AVOID.ACHAR
    this.C_FRAISREM(IJRAZ).RAT    = "" #AVOID.ACHAR
    this.C_FRAISREM(IJRAZ).AMT    = "" #AVOID.ACHAR

  Endif
Next IJRAZ

this.NBTAR = 0  #AVOID.AINT

For IJRAZ = 1 To maxtab(this.RESPRICEINQ)
  If this.RESPRICEINQ(IJRAZ)<>null

    this.RESPRICEINQ(IJRAZ).DATDEB    = [0/0/0] #AVOID.ADATE
    this.RESPRICEINQ(IJRAZ).DATFIN    = [0/0/0] #AVOID.ADATE
    this.RESPRICEINQ(IJRAZ).CUR       = "" #AVOID.ACHAR
    this.RESPRICEINQ(IJRAZ).UOM       = "" #AVOID.ACHAR
    this.RESPRICEINQ(IJRAZ).MINQTY    = 0  #AVOID.ADEC
    this.RESPRICEINQ(IJRAZ).MAXQTY    = 0  #AVOID.ADEC
    this.RESPRICEINQ(IJRAZ).MINAMT    = 0  #AVOID.ADEC
    this.RESPRICEINQ(IJRAZ).MAXAMT    = 0  #AVOID.ADEC
    this.RESPRICEINQ(IJRAZ).LTI       = 0  #AVOID.ADEC
    this.RESPRICEINQ(IJRAZ).PRIDIV    = 0  #AVOID.ADEC
    this.RESPRICEINQ(IJRAZ).PRI       = 0  #AVOID.ADEC
    this.RESPRICEINQ(IJRAZ).COE       = 0  #AVOID.ADEC
    this.RESPRICEINQ(IJRAZ).FOCQTYMIN = 0  #AVOID.ADEC
    this.RESPRICEINQ(IJRAZ).FOCQTYBKT = 0  #AVOID.ADEC
    this.RESPRICEINQ(IJRAZ).FOCUOM    = "" #AVOID.ACHAR
    this.RESPRICEINQ(IJRAZ).FOCQTY    = 0  #AVOID.ADEC
    this.RESPRICEINQ(IJRAZ).PLISEA    = 0  #AVOID.AINT
    this.RESPRICEINQ(IJRAZ).PLI       = "" #AVOID.ACHAR
    this.RESPRICEINQ(IJRAZ).PLICRD    = "" #AVOID.ACHAR
    this.RESPRICEINQ(IJRAZ).PLILIN    = 0  #AVOID.AINT

    For J=1 To maxtab(this.RESPRICEINQ(IJRAZ).C_FRAREM)
      this.RESPRICEINQ(IJRAZ).C_FRAREM(J).FRAREM    = 0  #AVOID.ADEC
      this.RESPRICEINQ(IJRAZ).C_FRAREM(J).COLFRAREM = "" #AVOID.ACHAR
    Next J
  Endif
Next IJRAZ

this.setAccessorEnabled = WACCESSORENABLED

Return

##############################################################################################################
$LOADVATPARAMFROMDOC
If fmet this.AGETMAXERROR("")>=[V]CST_AERROR : Return : Endif

Local Date    WDAT
Local Char    WCUR(GLONCUR)
Local Integer WCHGTYP
Local Decimal WCOEFDEVISE
Local Integer WSTAT:#--CPO 71937 19.04.2013
Local Integer WRET, WLINE, WI
#-----
Local File COMPANY    [CPY]
Local File FACILITY   [FCY]
Local File TAXLINK    [TLK] : # Table Calcul base calcul taxe (link)
Local File AGRPCPY    [AGC] : # Table Groupes de sociétés

Local File BPARTNER   [BPR]
Local File BPCUSTOMER [BPC]
Local File ITMMASTER  [ITM]
Local File TABVACITM  [TVI]

WCOEFDEVISE=1

MYPARAM.setAccessorEnabled = 0
# -----
# Alimentation des propriétés de la classe de données paramètres FINDVAT : MYPARAM
# -----

If MYPARAM.TRAIT = 0
  MYPARAM.TRAIT  = 1  : # Code traitement 1=Taxes classiques (TVA+parafiscales+spéciales)
Endif
  MYPARAM.BPCBPS = 2  : # Type de tiers   2=Fournisseur
  MYPARAM.TIERS  = this.BPSNUM
  MYPARAM.ITMREF = this.ITMREF
  MYPARAM.GSOCIETE  = this.CPY

Read [CPY] CPY0=this.CPY        : If fstat  Raz [F:CPY] : Endif
MYPARAM.GLOCALDEV = [F:CPY]ACCCUR

Read [FCY] FCY0=this.FCY     : If fstat  Raz [F:FCY] : Endif

MYPARAM.GFINRSP   = [F:FCY]FINRSPFCY
MYPARAM.GSYSCUR   = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"SYSCUR")

Read [BPR] BPR0=MYPARAM.TIERS   : If fstat  Raz [F:BPR] : Endif

Read [BPS] BPS0=MYPARAM.TIERS : If fstat  Raz [F:BPS] : Endif

Read [ITM] ITM0=MYPARAM.ITMREF  : If fstat  Raz [F:ITM] : Endif

# -----
# Alimentation des propriétés de la classe de données paramètre TAXLINK
# C'est une propriété de la classe de données paramètre FINDVAT faisant partie de la collection C_TLK
# -----
If MYPARAM.C_TLK(1) = null
  WRET = fmet MYPARAM.ADDLINE("C_TLK",1)
  If WRET = [V]CST_ANOTDEFINED
    #--The insertion was not possible
    [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_TLK","FINDVAT"), [V]CST_AERROR)
    [L]ARET_VALUE = [L]ASTATUS
    Return
  Endif
Endif

SetInstance MYPARAM.C_TLK(1) With [F:CPY]
SetInstance MYPARAM.C_TLK(1) With [F:BPR]

If MYPARAM.BPCBPS=2
  MYPARAM.C_TLK(1).MODULE=6     : # Bug 74842 ACH
  #[F:TLK]=[F:BPC]
  SetInstance MYPARAM.C_TLK(1) With [F:BPS]

  If dim([F:BPC]AGTPCP)>0
    MYPARAM.C_TLK(1).AGTPCPBPR=[F:BPS]AGTPCP
  Else
    MYPARAM.C_TLK(1).AGTPCPBPR=2
  Endif
Endif

# Alimentations à partir de l'article
If MYPARAM.ITMREF<>""
  SetInstance MYPARAM.C_TLK(1) With [F:ITM]   : # Equivalent du transclasse

  # Alimentation des 3 niveaux de taxe
  For WLINE=1 To 3
    If MYPARAM.C_VAT(WLINE) = null
      WRET = fmet MYPARAM.ADDLINE("C_VAT",WLINE)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_VAT","FINDVAT"), [V]CST_AERROR)
        [L]ARET_VALUE = [L]ASTATUS
        Return
      Endif
    Endif
    MYPARAM.C_VAT(WLINE).VACITM=[F:ITM]VACITM(WLINE-1)
    If MYPARAM.C_VAT(WLINE).VACITM <> ""
        MYPARAM.C_VAT(WLINE).VACITM_LEG = AVOID.ACHAR
        Call LEC_TVI_LEG(this.ACTX, [F:CPY]LEG, MYPARAM.C_VAT(WLINE).VACITM, WRET) From TRTLECLEG_SYRA
        If WRET=0
            MYPARAM.C_VAT(WLINE).VACITM_LEG = [F:TVI]LEG
        Endif
    Endif
  Next WLINE

  If MYPARAM.C_VAT(1) <> null
    MYPARAM.C_TLK(1).VACITM     = MYPARAM.C_VAT(1).VACITM
    MYPARAM.C_TLK(1).VACITM_LEG = MYPARAM.C_VAT(1).VACITM_LEG
  Endif

# Alimentation depuis SFINDPRICE c'est mieux
#  MYPARAM.C_TLK(1).TSICOD = [F:ITM]TSICOD
Endif


MYPARAM.C_TLK(1).FCY      = MYPARAM.GFINRSP
MYPARAM.C_TLK(1).AGTPCPCPY= [F:CPY]AGTPCP
#-----
MYPARAM.C_TLK(1).NBGRP=0

WI=1
For [AGC] AGC1 Where CPY=MYPARAM.GSOCIETE

  If MYPARAM.C_TLK(1).C_GRP(WI) = null
    WRET = fmet MYPARAM.C_TLK(1).ADDLINE("C_GRP",WI)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet MYPARAM.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_GRP","FINDVAT.C_TLK(1)"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif

  MYPARAM.C_TLK(1).C_GRP(WI).GRP =[F:AGC]GRP
  WI+=1
  If WI>99  Break : Endif
Next
MYPARAM.C_TLK(1).NBGRP=WI-1
MYPARAM.C_TLK(1).PURFCY     = this.FCY
MYPARAM.C_TLK(1).CUR        = this.CURREF
MYPARAM.C_TLK(1).VACBPR     = this.PRICEPARAM(1).VACBPR
MYPARAM.C_TLK(1).VACBPR_LEG = this.PRICEPARAM(1).VACBPR_LEG

# Alimentation des familles statistiques article depuis SPRICESEARCH --> SFINDPRICE --> SFINDPRICED --> SPRICLINKD
For WLINE = 1 To maxtab(this.PRICEPARAM(1).C_LINE(1).C_PPKD(1).C_TSICOD)
  If this.PRICEPARAM(1).C_LINE(1).C_PPKD(1).C_TSICOD(WLINE)<>null
    If MYPARAM.C_TLK(1).C_TSICOD(WLINE) = null
      WRET = fmet MYPARAM.C_TLK(1).ADDLINE("C_TSICOD",WLINE)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet MYPARAM.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_TSICOD","FINDVAT.C_TLK(1)"), [V]CST_AERROR)
        [L]ARET_VALUE = [L]ASTATUS
        Return
      Endif
    Endif
    If dim([F:ITM]TSICOD) >= WLINE and dim(this.PRICEPARAM(1).C_LINE(1).C_PPKD(1).C_TSICOD(WLINE).TSICOD)>0
      MYPARAM.C_TLK(1).C_TSICOD(WLINE).TSICOD =  this.PRICEPARAM(1).C_LINE(1).C_PPKD(1).C_TSICOD(WLINE).TSICOD
    Else
      Break
    Endif
  Endif
Next WLINE

MYPARAM.C_TLK(1).QTY = this.QTYREF

WDAT = this.DATEREF : WCUR = this.CURREF : WCHGTYP = [F:BPS]CHGTYP
Gosub CHARG_RATRPT


MYPARAM.setAccessorEnabled = 1

Return

##########################################################################################
$CHARG_RATRPT
If WCUR <> MYPARAM.GSYSCUR
    Call CONVERT(MYPARAM.ACTX, MYPARAM.GSYSCUR,WCUR,MYPARAM.GLOCALDEV,WCHGTYP,WDAT,1000000.00,WCOEFDEVISE,WSTAT) From TRTDEV_SYRA
    If WSTAT=0 & WCOEFDEVISE<>0 WCOEFDEVISE=WCOEFDEVISE/1000000.00 Else WCOEFDEVISE=1 Endif
Endif
MYPARAM.C_TLK(1).RATRPT = WCOEFDEVISE
Return

##########################################################################################
$LOADVATRESULTFROMFINDVAT
If fmet this.AGETMAXERROR("")>=[V]CST_AERROR : Return : Endif

Local Integer WLINE, WRET

    For WLINE=1 To maxtab(MYPARAM.C_VAT)

      If MYPARAM.C_VAT(WLINE)<>null
        If this.PRICEPARAM(1).C_LINE(1).C_VAT(WLINE)=null
          WRET = fmet this.PRICEPARAM(1).C_LINE(1).ADDLINE("C_VAT",WLINE)
          If WRET = [V]CST_ANOTDEFINED
            #--The insertion was not possible
            [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_VAT","PPRICESEARCH.PRICEPARAM(1).C_LINE(1)"), [V]CST_AERROR)
            [L]ARET_VALUE = [L]ASTATUS
            Return
          Endif
        Endif

        this.PRICEPARAM(1).C_LINE(1).C_VAT(WLINE).VAT     = MYPARAM.C_VAT(WLINE).VAT
        this.PRICEPARAM(1).C_LINE(1).C_VAT(WLINE).VAT_LEG = MYPARAM.C_VAT(WLINE).VAT_LEG

      Endif

    Next WLINE

Return

