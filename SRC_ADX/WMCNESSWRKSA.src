####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0ESSWRKSA
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_REFNUM From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_SECNAM From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_MADNAM From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_DISRSN From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_NBRADD From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDPRI From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDTYP From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDSRVTYP From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDPOSOTH From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDPOSNUM From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDPOSNAM From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDPOSAGN From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDPOSCOF From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDPOSINM From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDCPX From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDSTRNUM From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDSTRNAM From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDSUB From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDTWN From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDPOSCDE From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDCNTCDE From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDPRV From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDCOR From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ADDSTA From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_NBRPAS From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_PASCRY From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_PASNUM From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_PASDTE From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ESSUIDPAS From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_BUSTEL From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_FINTAXCLC From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_RSAID From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ETHGRP From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_RCEGRP From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_EMPTAXNR From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_LNRSKL From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_CNTTYP From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_ESSUIDCNT From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_UID From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_CHRONO From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_CHRONO2 From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_LNK From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_WRK From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub AINIT From WMC0ESSWRKSA : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0ESSWRKSA
Gosub _ALOADATTRIBUTE_UID From WMC2ESSWRKSA : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0ESSWRKSA
Gosub LNKPRO_REFNUM From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub LNKPRO_DISRSN From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub LNKPRO_ADDCNTCDE From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub LNKPRO_ADDPRV From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub LNKPRO_PASCRY From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub LNKPRO_BUSTEL From WMC1ESSWRKSA : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC2ESSWRKSA : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC2ESSWRKSA : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



