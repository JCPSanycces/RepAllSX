#<AdxTL>@(#)5.0.0.0 $Revision$

##################################################################################
# UCCNACT 01/10/2008 FQ49477                                                                      
# MWA - Mise à jour du code activité CCN
#
# Le code activité CCN est mis à OUI si le dossier gère des concessions, à NON sinon.
#
# MWA FQ64987 09/06/2010  Le flag actif du code activité RNW hérite de celui de CCN
# GLE         06/05/2010  Mise à jour explicite à 1 ou 2 du code activité CCN
#       
##################################################################################

 Call OUVRE_TRACE("CONCESSION Upgrade") From LECFIC
 Call PATCH(nomap)
 Call LEC_TRACE() From LECFIC
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PAPPLI)
  Value Char    PAPPLI
  Gosub UPGRADE_ACT
End
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(PAPPLI)
  Value Char PAPPLI
  Gosub UPGRADE_ACT
End
########################################################################

#==
$UPGRADE_ACT

  # A ne pas faire sur le dossier racine.
  If ( PAPPLI = GDOSX3 ) Then : Return : Endif

  If filinfo(filpath("FIL","ADOSACT"   ,"fde",GDOSX3),0)<=0
     # Table n'existe pas 
     Call ECR_TRACE("UCCNACT: ADOSACT table not found in folder "+GDOSX3,0) From GESECRAN
     Return
  Endif
  If filinfo(filpath("FIL","ACTIV"     ,"fde",PAPPLI),0)<=0
     # Table n'existe pas 
     Call ECR_TRACE("UCCNACT: ACTIV table not found for folder "+PAPPLI,0) From GESECRAN
     Return
  Endif
  If filinfo(filpath("FIL","CONCESSION","fde",PAPPLI),0)<=0
     # Table n'existe pas 
     Call ECR_TRACE("UCCNACT: CONCESSION table not found for folder "+PAPPLI,0) From GESECRAN
     Return
  Endif

  #-----
  Call ECR_TRACE("UCCNACT: Upgrade Activity Codes CCN & RNW for folder "+PAPPLI,0) From GESECRAN

  Local File =PAPPLI+".ACTIV"      [ACV]  
  Local File =PAPPLI+".CONCESSION" [CCN]  
  Local File =GDOSX3+".ADOSACT"    [ADA]  

  Local Integer BERROR     : BERROR  = 0
  Local Integer BACTCCN    : BACTCCN = 0

  Trbegin [CCN]
  #====================
    # Mise à jour Code activité CCN
    Gosub UPG_ACTCCN

  If (BERROR) Then
    Rollback
  Else
    Commit
  Endif
  
Return

########################################################################


#===============================
$UPG_ACTCCN

  # Ce traitement positionne le code activité CCN
  # pour chaque dossier autre que le dossier mère
  # à Non si pas de contrat de concession sur le dossier
  # et à Oui si au moins une concession existe
  #

  # CONCESSION
  If ( rowcount([F:CCN]) > 0 ) Then
    BACTCCN = 2
  Else
    BACTCCN = 1
  Endif

  Read [ACV] CODACT="CCN" 
  If (fstat) Then
    Call ECR_TRACE("UCCNACT - "-" Activity code CCN not found in table ACTIV ", 1) From GESECRAN
    BERROR = 1
  Else
    [F:ACV]FLACT  = BACTCCN
    Rewrite [ACV]
    If (fstat) Then
      BERROR = 1
      Call ECR_TRACE("UCCNACT - "-" ACTIV table ====> I/O Error - FSTAT="-num$(fstat), 1) From GESECRAN
    Endif
  Endif
  
  Read [ADA]ADA0=PAPPLI;"CCN"
  If (fstat) Then
    BERROR = 1
    Call ECR_TRACE("UCCNACT - "-" Activity code CCN not found in table ADOSACT ", 1) From GESECRAN
  Else
    [F:ADA]FLACT = BACTCCN
    Rewrite [ADA]
    If (fstat) Then
      BERROR = 1
      Call ECR_TRACE("UCCNACT - "-" ADOSACT table ====> I/O Error - FSTAT="-num$(fstat), 1) From GESECRAN
    Endif
  Endif
  
  # FQ64987

  Read [ACV] CODACT="RNW" 
  If (fstat) Then
    Call ECR_TRACE("UCCNACT - "-" Activity code RNW not found in table ACTIV ", 1) From GESECRAN
    BERROR = 1
  Else
    [F:ACV]FLACT  = BACTCCN
    Rewrite [ACV]
    If (fstat) Then
      BERROR = 1
      Call ECR_TRACE("UCCNACT - "-" ACTIV table ====> I/O Error - FSTAT="-num$(fstat), 1) From GESECRAN
    Endif
  Endif
  
  Read [ADA]ADA0=PAPPLI;"RNW"
  If (fstat) Then
    BERROR = 1
    Call ECR_TRACE("UCCNACT - "-" Activity code RNW not found in table ADOSACT ", 1) From GESECRAN
  Else
    [F:ADA]FLACT = BACTCCN
    Rewrite [ADA]
    If (fstat) Then
      BERROR = 1
      Call ECR_TRACE("UCCNACT - "-" ADOSACT table ====> I/O Error - FSTAT="-num$(fstat), 1) From GESECRAN
    Endif
  Endif
  Call ECR_TRACE("UCCNACT - 01 - Activity code CCN & RNW have been set to"-num$(BACTCCN)-"for folder "-PAPPLI, 0) From GESECRAN
  
Return
