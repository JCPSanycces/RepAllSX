#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe ALEGIS

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
      When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
      When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
      When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
      When "AREAD_AFTER"                  : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return





##############################################################################################
$AREAD_AFTER

Return




##############################################################################################
$AQUERY_DECODE_CRITERIA_AFTER
NBPRO = 0
NBPRO += 1 : TBPRO(NBPRO) = "CODE" : TBFIL(NBPRO) = "[F:LNK_]TCODE"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ALEG.CODE"
NBPRO += 1 : TBPRO(NBPRO) = "LNGDES" : TBFIL(NBPRO) = "[F:LNK_]TLNGDES"
           : TBTYP(NBPRO) = 26 : TBPTH(NBPRO) = "ALEG.LNGDES"
NBPRO += 1 : TBPRO(NBPRO) = "SHODES" : TBFIL(NBPRO) = "[F:LNK_]TSHODES"
           : TBTYP(NBPRO) = 26 : TBPTH(NBPRO) = "ALEG.SHODES"
NBPRO += 1 : TBPRO(NBPRO) = "ENAFLG" : TBFIL(NBPRO) = "[F:LNK_]TENAFLG"
           : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "ALEG.ENAFLG"
NBPRO += 1 : TBPRO(NBPRO) = "DEFVAL" : TBFIL(NBPRO) = "[F:LNK_]TDEFVAL"
           : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "ALEG.DEFVAL"
Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[F:LNK_]TCODE"
Return

$AQUERY_OPEN_AFTER
Local File ATABDIV [QRY_ADI]
Local File ATEXTRA [WAXX1]
Local File ATEXTRA [WAXX2]
Local Integer I : I=0
Local Char TCODE(12)(1..)
Local Char TLNGDES(60)(1..)
Local Char TSHODES(60)(1..)
Local Tinyint TENAFLG(1..)
Local Tinyint TDEFVAL(1..)

Link [QRY_ADI] With
& [F:WAXX1]AXX0 = "ATABDIV";"LNGDES";GACTX.LAN;num$([F:QRY_ADI]NUMTAB);[F:QRY_ADI]CODE,
& [F:WAXX2]AXX0 = "ATABDIV";"SHODES";GACTX.LAN;num$([F:QRY_ADI]NUMTAB);[F:QRY_ADI]CODE
& As [LNK_ADI]
& Where ( (1=1)
&  )

For [LNK_ADI]CODE Where NUMTAB=909
 I+=1
  TCODE(I)=[F:QRY_ADI]CODE
  TLNGDES(I)=[F:WAXX1]TEXTE
  TSHODES(I)=[F:WAXX2]TEXTE
  TENAFLG(I)=[F:QRY_ADI]ENAFLG
  TDEFVAL(I)=[F:QRY_ADI]DEFVAL
Next
If I=0
  Local File ATABDIV [LNK_]
Else
  Local File ( Char TCODE(12),
& Char TLNGDES(60),
& Char TSHODES(60),
& Tinyint TENAFLG,
& Tinyint TDEFVAL
& ) From Variable TCODE, TLNGDES, TSHODES, TENAFLG, TDEFVAL As [LNK_]
Endif
Return

$AQUERY_TRANS_AFTER
this.ALEG.CODE = [LNK_]TCODE
Call ASETTEXTRA(this.ALEG.AXX,"QRY","LNGDES",[LNK_]TLNGDES,GACTX.LAN) From ASYRSUB
Call ASETTEXTRA(this.ALEG.AXX,"QRY","SHODES",[LNK_]TSHODES,GACTX.LAN) From ASYRSUB
this.ALEG.ENAFLG = [LNK_]TENAFLG
this.ALEG.DEFVAL = [LNK_]TDEFVAL
Return

$AQUERY_CLOSE_AFTER
Close Local File [LNK_]
LogicClose File [QRY_ADI]
LogicClose File [WAXX1]
LogicClose File [WAXX2]

Return

