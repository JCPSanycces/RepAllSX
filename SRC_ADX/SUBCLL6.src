#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
Subprog AM_DEY1(VALEUR)
Variable Integer VALEUR

  If VALEUR = 6 Then
    Actzo [M:CLL6]DEYDAT
    Actzo [M:CLL6]DEYHOU
    # FGR 13/05/2008 : X3SUIVI47211 : La variable DRDAT n'existe plus à ce niveau.
    #If DRDAT < date$ Then
    If [M:CLL6]TECDRDAT < date$ Then
      [M:CLL6]DEYDAT = date$
    Else
      # FGR 13/05/2008 : X3SUIVI47211 : La variable DRDAT n'existe plus à ce niveau.
      #[M:CLL6]DEYDAT = DRDAT
      [M:CLL6]DEYDAT = [M:CLL6]TECDRDAT
    Endif
    # FGR 13/05/2008 : X3SUIVI47211 : La variable SZRHOU n'existe plus à ce niveau.
    #[M:CLL6]DEYHOU = SZRHOU
    [M:CLL6]DEYHOU = [M:CLL6]TECHRHOU
  Else
    Grizo [M:CLL6]DEYDAT
    Grizo [M:CLL6]DEYHOU
    [M:CLL6]DEYDAT = [00/00/00]
    [M:CLL6]DEYHOU = ""
  Endif
  [M:CLL6]DEY1 = VALEUR
  Affzo [M:CLL6]
End

