#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT6 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_XITDAT
Onevent BEFORE_AREA Gosub AV_XITDAT From W2HRMAT6
Return

$AV_XITDAT
Chgfmt [M]XITDAT(indice) With "DPzZ:"+GFMDAT4
Gosub _AFF
Return

$ON_XITFNL
Onevent INIT_AREA Call D_XITFNL(zc) From W2HRMAT6
Return

Subprog D_XITFNL(VALEUR)
Variable Integer VALEUR
If varinit([M]XITFNL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_XITGRD
Return

$ON_ZXITGRD
Onevent BEFORE_AREA Gosub AV_ZXITGRD From W2HRMAT6
Return

$AV_ZXITGRD
Call LECTEXTRA(zc,"HRXITGRD","DESAXX",num$([M]XITGRD(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_XITLEA
Onevent INIT_AREA Call D_XITLEA(zc) From W2HRMAT6
Return

Subprog D_XITLEA(VALEUR)
Variable Char    VALEUR()
If varinit([M]XITLEA,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10379","") From SUBADI
Endif
Gosub _AFF
End

$ON_ZXITLEA
Onevent BEFORE_AREA Gosub AV_ZXITLEA From W2HRMAT6
Return

$AV_ZXITLEA
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10379",num$([M]XITLEA(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_FLGCRECTR
Onevent INIT_AREA Call D_FLGCRECTR(zc) From W2HRMAT6
Return

Subprog D_FLGCRECTR(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGCRECTR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_FLGCRELET
Onevent INIT_AREA Call D_FLGCRELET(zc) From W2HRMAT6
Return

Subprog D_FLGCRELET(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGCRELET,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_FLGCREAVN
Onevent INIT_AREA Call D_FLGCREAVN(zc) From W2HRMAT6
Return

Subprog D_FLGCREAVN(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGCREAVN,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


