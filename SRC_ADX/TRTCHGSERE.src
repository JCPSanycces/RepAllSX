#<AdxTL>@(#)0.0.0.0 $Revision$

# Gestion du masque STOCHGSERE
##################################################################################
# Traitement TRTCHGSERE - Saisie des numéros de série globale                    #
#                         Depuis les documents correspondant au parametre LABR   #
#                         l enregistrement des données saisies dans cette fenetre#
#                         est fait dans l'ecran de travail STOCHGW ou dans la    #
#                         ligne du document origine. Ce  stockage est defini     #
#                         par la rubrique WSTOCKAGE renseignée dans l étiquette  #
#                         CHARG_BC1_CHGS (chargement du bloc 1)                  #
##################################################################################
# Action SAICHGSERE
# Paramètres - LABR Abréviation masque
#                   "STQ1/STQ1" "STOQUA/SQD" Controle qualité                             stockage STOCHGW
#                   "STOSMP/SMP"             Controle qualité échantillonnage             stockage STOCHGW
#                   "SCS1/SCS1" "STOCHG/SCD  Changement de stock / Transfert inter-sites  stockage STOCHGW
#                                            Changement statut lots Périmés               stockage STOCHGW
#                                            Changement statut lots re-controle           stockage STOCHGW
#                   "QCR1/QCR1"              Demande analyse                              stockage document origine
#                   "SLM1/SLM1"              Renumérotation/mélange                       stockage document origine
#            - LNOL No ligne écran (nolign-1)
#
########################################################################
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "AVANT_ENR"     : Gosub AVANT_ENR
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "FIN"           : Gosub FIN
 When "FINSAI"        : Gosub FINSAI
Endcase

Return

#########################################################################
$OUVRE
Global Char    PABR            : # Abréviation masque origine
Global Integer PNOL            : # No ligne courante (nolign-1) masque origine
Local Integer I, OK
Local Decimal WDISPO
# Récupération des paramètres
PABR    = PARAM(1)
PNOL    = val(PARAM(2))
# gouvchgs = 2 clic droit comtage sur ligne
#si variable globale GOUVCHGS <= 1 on sort
If GOUVCHGS < 1
  FIN = 1
  Return
Endif
If clalev([F:STS])=0    Local File STOSER       [STS]    Endif
If clalev([M:CHGS1])=0  Local Mask STOCHGSERE   [CHGS1]  Endif

Return

#########################################################################
$DEBUT
Local Integer WLIGNE
Raz WLIGNE
Raz I
Gosub CHARG_BC1_CHGS From TRTCHGSERE
Gosub CHARG_TAB_CHGS From TRTCHGSERE
[M:CHGS]NBLIG = I+1
Affzo [M:CHGS]
If GOUVCHGS = 9
   Diszo [M:CHGS]
Endif

Return

####################################################################  #####
$SETBOUT
If WLIGNE = 9 | GOUVCHGS = 9
   Call VIREBOUT(CHBOU,"EA")From GOBJET
   Return
Endif
If !find("A",CHBOU) CHBOU+="A" Endif
If !find("E",CHBOU) CHBOU+="E" Endif

Return

###########################################################################
# CHARG_BC1_CHGS : chargement  masque SAICHGSERE partie bloc 1
###########################################################################
$CHARG_BC1_CHGS
Raz [M:CHGS]
[M:CHGS]STOFCY     = evalue("[M:"+PABR+"]STOFCY")
[M:CHGS]WSTOCKAGE  = 1    # (1 = STOCHGW  par defaut le stockage est STOCHGW)

Raz [M:CHGS]MODFLG(PNOL)

Case PABR
     When "STQ1" : [M:CHGS]ITMREF       = [M:STQ1]ITMREF
                   [M:CHGS]QTYSTU       = [M:STQ1]QTYSTUDES(PNOL)
                   [M:CHGS]STU          = [M:STQ1]STU
                   [M:CHGS]STOCOU       = [M:STQ1]WSTOCOU  (PNOL)
                   If dim([M:CHGS]LPNNUM) > 0                                           # hcb X3-77043
                      [M:CHGS]LPNNUM    = [M:STQ1]LPNNUM
                   Endif
                   If dim([M:CHGS]LOC) > 0
                      [M:CHGS]LOC       = [M:STQ1]LOC      (PNOL)
                   Endif
                   [M:CHGS]WSTOSEQ      = [M:STQ1]WSTOSEQ  (PNOL)
                   If dim([M:CHGS]LOT) > 0
                      [M:CHGS]LOT       = [M:STQ1]LOT      (PNOL)
                   Endif
                   If dim([M:CHGS]SLO) > 0
                      [M:CHGS]SLO       = [M:STQ1]SLO      (PNOL)
                   Endif

     When "SQD"  : [M:CHGS]ITMREF       = [M:SQD]ITMREF
                   [M:CHGS]QTYSTU       = [M:SQD]QTYSTUDES(PNOL)
                   [M:CHGS]STU          = [M:SQD]STU
                   [M:CHGS]STOCOU       = [M:SQD]WSTOCOU1
                   If dim([M:CHGS]LPNNUM) > 0                                           # hcb X3-77043
                      [M:CHGS]LPNNUM    = [M:SQD]LPNNUM
                   Endif
                   If dim([M:CHGS]LOC) > 0
                      [M:CHGS]LOC       = [M:SQD]LOC
                   Endif
                   [M:CHGS]WSTOSEQ      = [M:SQD]WSTOSEQ
                   If dim([M:CHGS]LOT) > 0
                      [M:CHGS]LOT       = [M:SQD]LOT
                   Endif
                   If dim([M:CHGS]SLO) > 0
                      [M:CHGS]SLO       = [M:SQD]SLO
                   Endif

     When "SCD"  : [M:CHGS]ITMREF       = [M:SCD]ITMREF
                   [M:CHGS]QTYSTU       = [M:SCD]QTYSTUDES(PNOL)
                   [M:CHGS]STU          = [M:SCD]STU
                   [M:CHGS]STOCOU       = [M:SCD]WSTOCOU1
                   If dim([M:CHGS]LPNNUM) > 0                                           # hcb X3-67989
                      [M:CHGS]LPNNUM    = [M:SCD]LPNNUM
                   Endif
                   If dim([M:CHGS]LOC) > 0
                      [M:CHGS]LOC       = [M:SCD]LOC
                   Endif
                   [M:CHGS]WSTOSEQ      = [M:SCD]WSTOSEQ
                   If dim([M:CHGS]LOT) > 0
                      [M:CHGS]LOT       = [M:SCD]LOT
                   Endif
                   If dim([M:CHGS]SLO) > 0
                      [M:CHGS]SLO       = [M:SCD]SLO
                   Endif

     When "SMP"  : [M:CHGS]ITMREF       = [M:SMP]ITMREF
                   [M:CHGS]QTYSTU       = [M:SMP]QTYSTUDES(PNOL)
                   [M:CHGS]STU          = [M:SMP]STU
                   [M:CHGS]STOCOU       = [M:SMP]WSTOCOU   (PNOL)
                   If dim([M:CHGS]LPNNUM) > 0                                           # hcb X3-67989
                      [M:CHGS]LPNNUM    = [M:SMP]LPNNUMDES   (PNOL)
                   Endif
                   If dim([M:CHGS]LOC) > 0
                      [M:CHGS]LOC       = [M:SMP]LOC       (PNOL)
                   Endif
                   [M:CHGS]WSTOSEQ      = [M:SMP]WSTOSEQ
                   If dim([M:CHGS]LOT) > 0
                      [M:CHGS]LOT       = [M:SMP]LOT       (PNOL)
                   Endif
                   If dim([M:CHGS]SLO) > 0
                      [M:CHGS]SLO       = [M:SMP]SLO       (PNOL)
                   Endif
                   [M:CHGS]VCRLIN       = [M:SMP]VCRLIN    (PNOL)

     When "SMP1" : [M:CHGS]ITMREF       = [M:SMP1]ITMREF
                   [M:CHGS]QTYSTU       = [M:SMP1]QTYSTUDES(PNOL)
                   [M:CHGS]STU          = [M:SMP1]STU
                   [M:CHGS]STOCOU       = [M:SMP1]WSTOCOU
                   If dim([M:CHGS]LPNNUM) > 0                                           # hcb X3-67989
                      [M:CHGS]LPNNUM    = [M:SMP1]LPNNUMDES  (PNOL)
                   Endif
                   If dim([M:CHGS]LOC) > 0
                      [M:CHGS]LOC       = [M:SMP1]LOCDES     (PNOL)
                   Endif
                   [M:CHGS]WSTOSEQ      = [M:SMP1]WSTOSEQ
                   If dim([M:CHGS]LOT) > 0
                      [M:CHGS]LOT       = [M:SMP1]LOT
                   Endif
                   If dim([M:CHGS]SLO) > 0
                      [M:CHGS]SLO       = [M:SMP1]SLO
                   Endif
                   [M:CHGS]VCRLIN       = [M:SMP1]VCRLIN

     When "SCS1" : [M:CHGS]ITMREF       = [M:SCS1]ITMREF   (PNOL)
                   [M:CHGS]QTYSTU       = [M:SCS1]QTYSTUDES(PNOL)
                   [M:CHGS]STU          = [M:SCS1]STU      (PNOL)
                   [M:CHGS]STOCOU       = [M:SCS1]WSTOCOU  (PNOL)
                   If dim([M:CHGS]LPNNUM) > 0                                           # hcb X3-67989
                      [M:CHGS]LPNNUM    = [M:SCS1]LPNNUMDES   (PNOL)
                   Endif
                   If dim([M:CHGS]LOC) > 0
                      [M:CHGS]LOC       = [M:SCS1]LOC      (PNOL)
                   Endif
                   [M:CHGS]WSTOSEQ      = [M:SCS1]WSTOSEQ  (PNOL)
                   If dim([M:CHGS]LOT) > 0
                      [M:CHGS]LOT       = [M:SCS1]LOT      (PNOL)
                   Endif
                   If dim([M:CHGS]SLO) > 0
                      [M:CHGS]SLO       = [M:SCS1]SLO      (PNOL)
                   Endif
     When "QCR1" : [M:CHGS]WSTOCKAGE    = 2    # (tableau de l ecran origine)
                   [M:CHGS]ITMREF       = [F:STO]ITMREF
                   [M:CHGS]QTYSTU       = [M:QCR1]QTYSTUDES(PNOL)
                   [M:CHGS]STU          = [F:ITM]STU
                   [M:CHGS]STOCOU       = [F:STO]STOCOU
                   If dim([M:CHGS]LPNNUM) > 0                                           # hcb X3-77048
                      [M:CHGS]LPNNUM    = [F:STO]LPNNUM
                   Endif
                   If dim([M:CHGS]LOC) > 0
                      [M:CHGS]LOC       = [F:STO]LOC
                   Endif
                   If dim([M:CHGS]LOT) > 0
                      [M:CHGS]LOT       = [F:STO]LOT
                   Endif
                   If dim([M:CHGS]SLO) > 0
                      [M:CHGS]SLO       = [F:STO]SLO
                   Endif
     When "SLM1" : [M:CHGS]WSTOCKAGE    = 2    # (tableau de l ecran origine)
                   [M:CHGS]ITMREF       = [M:SLM1]ITMREF
                   [M:CHGS]QTYSTU       = [M:SLM1]QTYSTU   (PNOL)
                   [M:CHGS]STU          = [M:SLM1]STU      (PNOL)
                   [M:CHGS]STOCOU       = [M:SLM1]WSTOCOU  (PNOL)
                   If dim([M:CHGS]LOC) > 0
                      [M:CHGS]LOC       = [M:SLM1]LOC      (PNOL)
                   Endif
                   If dim([M:CHGS]LOT) > 0
                      [M:CHGS]LOT       = [M:SLM1]LOT
                   Endif
                   If dim([M:CHGS]SLO) > 0
                      [M:CHGS]SLO       = [M:SLM1]SLO
                   Endif
    # Issue 110327 - 2016-09-12 by MAE : depuis l'écran de changement de stock en VT
    When "XASC" :  [M:CHGS]ITMREF       = [M:XASC]ITMREF
                   [M:CHGS]QTYSTU       = [M:XASC]QTYSTUDES
                   [M:CHGS]STU          = [M:XASC]STU
                   [M:CHGS]STOCOU       = [F:STS]STOCOU
                   If dim([M:CHGS]LOC) > 0
                      [M:CHGS]LOC       = [M:XASC]LOC
                   Endif
                   [M:CHGS]WSTOSEQ      = [M:XASC]WSTOSEQ
                   If dim([M:CHGS]LOT) > 0
                      [M:CHGS]LOT       = [M:XASC]LOT
                   Endif
                   If dim([M:CHGS]SLO) > 0
                      [M:CHGS]SLO       = [M:XASC]SLO
                   Endif
      # End issue 110327
      # Issue X3-67963 - 2017-12-19 by MAE : ajout de l'écran affectation des LPN
       When "LPNA" :
                   [M:CHGS]ITMREF       = [M:LPNA]ITMREF   (PNOL)
                   [M:CHGS]QTYSTU       = [M:LPNA]QTYSTUDES(PNOL)
                   [M:CHGS]STU          = [M:LPNA]STU      (PNOL)
                   [M:CHGS]STOCOU       = [M:LPNA]WSTOCOU  (PNOL)
                   If dim([M:CHGS]LOC) > 0
                      [M:CHGS]LOC       = [M:LPNA]LOC      (PNOL)
                   Endif
                   [M:CHGS]WSTOSEQ      = [M:LPNA]WSTOSEQ  (PNOL)
                   If dim([M:CHGS]LOT) > 0
                      [M:CHGS]LOT       = [M:LPNA]LOT      (PNOL)
                   Endif
                   If dim([M:CHGS]SLO) > 0
                      [M:CHGS]SLO       = [M:LPNA]SLO      (PNOL)
                   Endif
                   If dim([M:CHGS]LPNNUMDES) > 0
                      [M:CHGS]LPNNUMDES       = [M:LPNA]LPNNUMDES      (PNOL)
                   Endif
                   If dim([M:CHGS]LOCDES) > 0
                      [M:CHGS]LOCDES       = [M:LPNA]LOCDES      (PNOL)
                   Endif
                   If dim([M:CHGS]LOCTYPDES) > 0
                      [M:CHGS]LOCTYPDES       = [M:LPNA]LOCTYPDES      (PNOL)
                   Endif

       # End issue X3-67963
       # Issue X3-68496 - 2018-03-12 by MAE : LPN : opérations
        When "LPNO" :
                   [M:CHGS]ITMREF       = [M:LPNO]ITMREF   (PNOL)
                   [M:CHGS]QTYSTU       = [M:LPNO]QTYSTUDES(PNOL)
                   [M:CHGS]STU          = [M:LPNO]STU      (PNOL)
                   [M:CHGS]STOCOU       = [M:LPNO]WSTOCOU  (PNOL)
                   If dim([M:CHGS]LOC) > 0
                      [M:CHGS]LOC       = [M:LPNO]LOC      (PNOL)
                   Endif
                   [M:CHGS]WSTOSEQ      = [M:LPNO]WSTOSEQ  (PNOL)
                   If dim([M:CHGS]LOT) > 0
                      [M:CHGS]LOT       = [M:LPNO]LOT      (PNOL)
                   Endif
                   If dim([M:CHGS]SLO) > 0
                      [M:CHGS]SLO       = [M:LPNO]SLO      (PNOL)
                   Endif
                   If dim([M:CHGS]LPNNUMDES) > 0
                      [M:CHGS]LPNNUMDES       = [M:LPNO]LPNNUMDES      (PNOL)
                   Endif
                   If dim([M:CHGS]LOCDES) > 0
                      [M:CHGS]LOCDES       = [M:LPNO]LOCDES      (PNOL)
                   Endif
                   If dim([M:CHGS]LOCTYPDES) > 0
                      [M:CHGS]LOCTYPDES       = [M:LPNO]LOCTYPDES      (PNOL)
                   Endif

       # End issue X3-68496
        When "LPNC" :
                   [M:CHGS]ITMREF       = [M:LPNC]ITMREF
                   [M:CHGS]QTYSTU       = [M:LPNC]QTYSTUDES(PNOL)
                   [M:CHGS]STU          = [M:LPNC]STU
                   [M:CHGS]STOCOU       = [M:LPNC]STOCOU
                   If dim([M:CHGS]LOC) > 0
                      [M:CHGS]LOC       = [M:LPNC]LOC      (PNOL)
                   Endif
                   [M:CHGS]WSTOSEQ      = [M:LPNC]WSTOSEQ
                   If dim([M:CHGS]LOT) > 0
                      [M:CHGS]LOT       = [M:LPNC]LOT
                   Endif
                   If dim([M:CHGS]SLO) > 0
                      [M:CHGS]SLO       = [M:LPNC]SLO
                   Endif
                   If dim([M:CHGS]LPNNUMDES) > 0
                      [M:CHGS]LPNNUMDES       = [M:LPNC]LPNNUMDES     (PNOL)
                   Endif
                   If dim([M:CHGS]LOCDES) > 0
                      [M:CHGS]LOCDES       = [M:LPNC]LOCDES      (PNOL)
                   Endif
                   If dim([M:CHGS]LOCTYPDES) > 0
                      [M:CHGS]LOCTYPDES       = [M:LPNC]LOCTYPDES      (PNOL)
                   Endif

       # End issue X3-68496
      When Default:
Endcase

Return

###########################################################################
# CHARG_TAB_CHGS chargement  masque SAICHGSERE partie tableau
###########################################################################
$CHARG_TAB_CHGS
If !find(PABR,"QCR1","SLM1","LPNA", "LPNO", "LPNC")
   [M:CHGS]PCUDES       (I) = evalue("[M:"+PABR+"]PCUDES   (PNOL)")
   [M:CHGS]COEDES       (I) = evalue("[M:"+PABR+"]COEDES   (PNOL)")
   [M:CHGS]STADES       (I) = evalue("[M:"+PABR+"]STADES   (PNOL)")
   If dim([M:CHGS]WRHDES) > 0
      [M:CHGS]WRHDES    (I) = evalue("[M:"+PABR+"]WRHDES   (PNOL)")
   Endif
   If dim([M:CHGS]LOCTYPDES) > 0
      [M:CHGS]LOCTYPDES (I) = evalue("[M:"+PABR+"]LOCTYPDES(PNOL)")
   Endif
   If dim([M:CHGS]LOCDES) > 0
      [M:CHGS]LOCDES    (I) = evalue("[M:"+PABR+"]LOCDES   (PNOL)")
   Endif
   [M:CHGS]WLOCSEQ      (I) = evalue("[M:"+PABR+"]WLOCSEQ  (PNOL)")
Endif
Case PABR
     When "STQ1" : If dim([M:CHGS]PALNUMDES) > 0
                      [M:CHGS]PALNUMDES (I) = [M:STQ1]PALNUM    (PNOL)
                   Endif
                   If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]CTRNUMDES (I) = [M:STQ1]CTRNUM    (PNOL)
                   Endif
                   If dim([M:CHGS]LPNNUMDES) > 0                                       # HCB x3-67989
                      [M:CHGS]LPNNUMDES (I) = [M:STQ1]LPNNUMDES (PNOL)
                   Endif
                   [M:CHGS]LBEFMT       (I) = [M:STQ1]LBEFMT    (PNOL)
                   [M:CHGS]LBENBR       (I) = [M:STQ1]LBENBR    (PNOL)
                   [M:CHGS]QTYSTUDES    (I) = [M:STQ1]QTYSTUDES (PNOL)
                   [M:CHGS]WSTOSEQIND   (I) = [M:STQ1]WSTOSEQIND(PNOL)
                   # mémorisation de la tranche de série deja saisie pour controler les nouveaux numeros de serie qui seront saisies
                   [M:CHGS]WSERNUM          = [M:CHGS]SERNUM    (I)
                   [M:CHGS]WSERNUMF         = [M:CHGS]SERNUMF   (I)
                   Sorta [M:SGW]NBLIG [M:SGW]NBLIG Order By [M:SGW]WSTOSEQ(indice),[M:SGW]WSTOSEQIND(indice),[M:SGW]WSERNUM(indice)

                   Y = find([M:CHGS]WSTOSEQ , [M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
                   If Y >= 0
                      While Y<[M:SGW]NBLIG & [M:CHGS]WSTOSEQ=[M:SGW]WSTOSEQ(Y)
                            [M:CHGS]QTYSTUDES    (I) = [M:SGW]WQTYSTUDES (Y)
                            [M:CHGS]SERNUM       (I) = [M:SGW]WSERNUM    (Y)
                            [M:CHGS]SERNUMF      (I) = [M:SGW]WSERNUMF   (Y)
                            [M:CHGS]WSTOSEQIND   (I) = [M:SGW]WSTOSEQIND (Y)
                            If dim([M:CHGS]PALNUMDES) > 0
                               [M:CHGS]PALNUMDES (I) = [M:STQ1]PALNUM   (PNOL)
                            Endif
                            If dim([M:CHGS]CTRNUMDES) > 0
                               [M:CHGS]CTRNUMDES (I) = [M:STQ1]CTRNUM   (PNOL)
                            Endif
                            If dim([M:CHGS]LPNNUMDES) > 0                                       # HCB x3-67989
                               [M:CHGS]LPNNUMDES (I) = [M:STQ1]LPNNUMDES (PNOL)
                            Endif
                            [M:CHGS]LBEFMT       (I) = [M:STQ1]LBEFMT   (PNOL)
                            [M:CHGS]LBENBR       (I) = [M:STQ1]LBENBR   (PNOL)
                            Y+=1
                            I +=1
                      Wend
                   Endif
                   [M:CHGS]NBLIG = I
                   If [M:CHGS]NBLIG > 1 & WLIGNE = 0
                      Diszo [M:CHGS]
                      WLIGNE = 9
                   Endif

     When "SQD"  : If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]PALNUMDES (I) = [M:SQD]PALNUM
                   Endif
                   If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]CTRNUMDES (I) = [M:SQD]CTRNUM
                   Endif
                   If dim([M:CHGS]LPNNUMDES) > 0                                       # HCB x3-67989
                      [M:CHGS]LPNNUMDES (I) = [M:SQD]LPNNUMDES (PNOL)
                   Endif
                   [M:CHGS]LBEFMT       (I) = [M:SQD]LBEFMT    (PNOL)
                   [M:CHGS]LBENBR       (I) = [M:SQD]LBENBR    (PNOL)
                   [M:CHGS]QTYSTUDES    (I) = [M:SQD]QTYSTUDES (PNOL)
                   [M:CHGS]SERNUM       (I) = [M:SQD]SERNUM    (PNOL)
                   [M:CHGS]SERNUMF      (I) = [M:SQD]SERNUMF   (PNOL)
                   [M:CHGS]WSTOSEQIND   (I) = [M:SQD]WSTOSEQIND(PNOL)
                   # mémorisation de la tranche de série deja saisie pour controler les nouveaux numeros de serie qui seront saisies
                   [M:CHGS]WSERNUM          = [M:CHGS]SERNUM    (I)
                   [M:CHGS]WSERNUMF         = [M:CHGS]SERNUMF   (I)

     When "SCD"  : If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]PALNUMDES (I) = [M:SCD]PALNUMDES (PNOL)
                   Endif
                   If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]CTRNUMDES (I) = [M:SCD]CTRNUMDES (PNOL)
                   Endif
                   If dim([M:CHGS]LPNNUMDES) > 0                                       # HCB x3-67989
                      [M:CHGS]LPNNUMDES (I) = [M:SCD]LPNNUM
                   Endif
                   [M:CHGS]LBEFMT       (I) = [M:SCD]LBEFMT    (PNOL)
                   [M:CHGS]LBENBR       (I) = [M:SCD]LBENBR    (PNOL)
                   [M:CHGS]QLYCTLFLG    (I) = [M:SCD]QLYCTLFLG (PNOL)
                   If dim([M:CHGS]CCE) > 0
                      For J=1 To GNBDIE
                          Assign "[M:CHGS]CCE"+num$(J-1)+"(I)" With [M:SCD]CCE (J-1)
                          Assign "[M:CHGS]CCS"+num$(J-1)+"(I)" With [M:SCD]CCS (J-1)
                      Next
                      [M:CHGS]CCECODS   (I) = [M:SCD]CCECODS   (PNOL)
                   Endif
                   [M:CHGS]QTYSTUDES    (I) = [M:SCD]QTYSTUDES (PNOL)
                   [M:CHGS]SERNUM       (I) = [M:SCD]SERNUM    (PNOL)
                   [M:CHGS]SERNUMF      (I) = [M:SCD]SERNUMF   (PNOL)
                   [M:CHGS]WSTOSEQIND   (I) = [M:SCD]WSTOSEQIND(PNOL)
                   # mémorisation de la tranche de série deja saisie pour controler les nouveaux numeros de serie qui seront saisies
                   [M:CHGS]WSERNUM          = [M:CHGS]SERNUM    (I)
                   [M:CHGS]WSERNUMF         = [M:CHGS]SERNUMF   (I)

     When "SMP"  : If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]PALNUMDES (I) = [M:SMP]PALNUMDES (PNOL)
                   Endif
                   If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]CTRNUMDES (I) = [M:SMP]CTRNUMDES (PNOL)
                   Endif
                   If dim([M:CHGS]LPNNUMDES) > 0                                       # HCB x3-77043
                      [M:CHGS]LPNNUMDES (I) = [M:SMP]LPNNUMDES (PNOL)
                   Endif
                   [M:CHGS]LBEFMT       (I) = [M:SMP]LBEFMT    (PNOL)
                   [M:CHGS]LBENBR       (I) = [M:SMP]LBENBR    (PNOL)
                   [M:CHGS]QTYSTUDES    (I) = [M:SMP]QTYSTU    (PNOL)
                   [M:CHGS]WSTOSEQIND   (I) = [M:SMP]WSTOSEQIND(PNOL)
                   # mémorisation de la tranche de série deja saisie pour controler les nouveaux numeros de serie qui seront saisies
                   [M:CHGS]WSERNUM          = [M:CHGS]SERNUM    (I)
                   [M:CHGS]WSERNUMF         = [M:CHGS]SERNUMF   (I)

                   Sorta [M:SGW]NBLIG [M:SGW]NBLIG Order By [M:SGW]WSTOSEQ(indice),[M:SGW]WSTOSEQIND(indice),[M:SGW]WSERNUM(indice)
                   Y = find([M:CHGS]WSTOSEQ , [M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
                   If Y >= 0
                      While Y< [M:SGW]NBLIG & [M:CHGS]WSTOSEQ=[M:SGW]WSTOSEQ(Y) & [M:SGW]WSTOSEQIND (Y) <> 0
                            If [M:CHGS]STOCOU           = [M:SGW]WSTOCOU    (Y)
                               [M:CHGS]QTYSTUDES    (I) = [M:SGW]WQTYSTUDES (Y)
                               [M:CHGS]SERNUM       (I) = [M:SGW]WSERNUM    (Y)
                               [M:CHGS]SERNUMF      (I) = [M:SGW]WSERNUMF   (Y)
                               [M:CHGS]WSTOSEQIND   (I) = [M:SGW]WSTOSEQIND (Y)
                               If dim([M:CHGS]PALNUMDES) > 0
                                  [M:CHGS]PALNUMDES (I) = [M:SMP]PALNUM   (PNOL)
                               Endif
                               If dim([M:CHGS]CTRNUMDES) > 0
                                  [M:CHGS]CTRNUMDES (I) = [M:SMP]CTRNUM   (PNOL)
                               Endif
                               If dim([M:CHGS]LPNNUMDES) > 0                                       # HCB x3-77043
                                  [M:CHGS]LPNNUMDES (I) = [M:SMP]LPNNUMDES (PNOL)
                               Endif
                               I +=1
                           Endif
                           Y+=1
                      Wend
                      If I > 0    # hcb X3-66785
                         I -=1    # hcb X3-66785
                      Endif       # hcb X3-66785
                   Endif
                   [M:CHGS]NBLIG = I
                   If [M:CHGS]NBLIG > 1 & WLIGNE = 0
                      Diszo [M:CHGS]
                      WLIGNE = 9
                   Endif

     When "SMP1"  : If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]PALNUMDES (I) = [M:SMP1]PALNUM
                   Endif
                   If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]CTRNUMDES (I) = [M:SMP1]CTRNUM
                   Endif
                   If dim([M:CHGS]LPNNUMDES) > 0                                       # HCB x3-77043
                      [M:CHGS]LPNNUMDES (I) = [M:SMP1]LPNNUMDES (PNOL)
                   Endif
                   [M:CHGS]LBEFMT       (I) = [M:SMP1]LBEFMT    (PNOL)
                   [M:CHGS]LBENBR       (I) = [M:SMP1]LBENBR    (PNOL)
                   [M:CHGS]QTYSTUDES    (I) = [M:SMP1]QTYSTUDES (PNOL)
                   [M:CHGS]SERNUM       (I) = [M:SMP1]SERNUM    (PNOL)
                   [M:CHGS]SERNUMF      (I) = [M:SMP1]SERNUMF   (PNOL)
                   [M:CHGS]WSTOSEQIND   (I) = [M:SMP1]WSTOSEQIND(PNOL)
                   # mémorisation de la tranche de série deja saisie pour controler les nouveaux numeros de serie qui seront saisies
                   [M:CHGS]WSERNUM          = [M:CHGS]SERNUM    (I)
                   [M:CHGS]WSERNUMF         = [M:CHGS]SERNUMF   (I)

     When "SCS1" : If dim([M:CHGS]PALNUMDES) > 0
                      [M:CHGS]PALNUMDES (I) = [M:SCS1]PALNUM    (PNOL)
                   Endif
                   If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]CTRNUMDES (I) = [M:SCS1]CTRNUM    (PNOL)
                   Endif
                  If dim([M:CHGS]LPNNUMDES) > 0                                       # HCB x3-67989
                      [M:CHGS]LPNNUMDES (I) = [M:SCS1]LPNNUMDES (PNOL)
                   Endif
                   [M:CHGS]QLYCTLFLG    (I) = [M:SCS1]QLYCTLFLG (PNOL)
                   [M:CHGS]QTYSTUDES    (I) = [M:SCS1]QTYSTUDES (PNOL)
                   [M:CHGS]SERNUM       (I) = [M:SCS1]SERNUM    (PNOL)
                   [M:CHGS]SERNUMF      (I) = [M:SCS1]SERNUMF   (PNOL)
                   [M:CHGS]WSTOSEQIND   (I) = [M:SCS1]WSTOSEQIND(PNOL)
                   # mémorisation de la tranche de série deja saisie pour controler les nouveaux numeros de serie qui seront saisies
                   [M:CHGS]WSERNUM          = [M:CHGS]SERNUM    (I)
                   [M:CHGS]WSERNUMF         = [M:CHGS]SERNUMF   (I)
                   If WLIGNE <> 2                                         # hcb 62634
                       Sorta [M:SGW]NBLIG [M:SGW]NBLIG Order By [M:SGW]WSTOSEQ(indice),[M:SGW]WSTOSEQIND(indice),[M:SGW]WSERNUM(indice)

                       Y = find([M:CHGS]WSTOSEQ , [M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
                       If Y >= 0
                          While Y<[M:SGW]NBLIG & [M:CHGS]WSTOSEQ=[M:SGW]WSTOSEQ(Y)
                                [M:CHGS]QTYSTUDES    (I) = [M:SGW]WQTYSTUDES (Y)
                                [M:CHGS]SERNUM       (I) = [M:SGW]WSERNUM    (Y)
                                [M:CHGS]SERNUMF      (I) = [M:SGW]WSERNUMF   (Y)
                                [M:CHGS]WSTOSEQIND   (I) = [M:SGW]WSTOSEQIND (Y)
                                If dim([M:CHGS]PALNUMDES) > 0
                                   [M:CHGS]PALNUMDES (I) = [M:SCS1]PALNUM   (PNOL)
                                Endif
                                If dim([M:CHGS]CTRNUMDES) > 0
                                   [M:CHGS]CTRNUMDES (I) = [M:SCS1]CTRNUM   (PNOL)
                                Endif
                                If dim([M:CHGS]LPNNUMDES) > 0                                       # HCB x3-67989
                                   [M:CHGS]LPNNUMDES (I) = [M:SCS1]LPNNUMDES (PNOL)
                                Endif
                                Y+=1
                                I +=1
                          Wend
                          If I > 0    # hcb X3-66785
                             I -=1    # hcb X3-66785
                          Endif       # hcb X3-66785
                       Endif
                       [M:CHGS]NBLIG = I

                       If [M:CHGS]NBLIG > 1 & WLIGNE = 0
                          Diszo [M:CHGS]
                          WLIGNE = 9
                       Endif
                   Endif                                               # hcb 62634
     When "QCR1" : [M:CHGS]PCUDES       (I) = [M:QCR1]PCU       (PNOL)
                   [M:CHGS]COEDES       (I) = [M:QCR1]PCUSTUCOE (PNOL)
                   [M:CHGS]STADES       (I) = [M:QCR1]STADES    (PNOL)
                   If dim([M:CHGS]LPNNUMDES) > 0                                           # hcb X3-77048
                      [M:CHGS]LPNNUMDES (I) = [M:QCR1]LPNNUM    (PNOL)
                   Endif
                   If dim([M:CHGS]LOCTYPDES) > 0
                      [M:CHGS]LOCTYPDES (I) = [M:QCR1]LOCTYP    (PNOL)
                   Endif
                   If dim([M:CHGS]LOCDES) > 0
                      [M:CHGS]LOCDES    (I) = [M:QCR1]LOC       (PNOL)
                   Endif
                   [M:CHGS]WLOCSEQ      (I) = [M:QCR1]WLOCSEQ   (PNOL)

                   If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]PALNUMDES (I) = [M:QCR1]PALNUM    (PNOL)
                   Endif
                   If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]CTRNUMDES (I) = [M:QCR1]CTRNUM    (PNOL)
                   Endif
                   [M:CHGS]QTYSTUDES    (I) = [M:QCR1]QTYSTUDES (PNOL)
                   [M:CHGS]STUDIS       (I) = [M:QCR1]STUDIS    (PNOL)
                   [M:CHGS]SERNUM       (I) = [M:QCR1]SERNUM    (PNOL)
                   [M:CHGS]SERNUMF      (I) = [M:QCR1]SERNUMF   (PNOL)
                   # mémorisation de la tranche de série deja saisie pour controler les nouveaux numeros de serie qui seront saisies
                   [M:CHGS]WSERNUM          = [M:CHGS]SERNUM    (I)
                   [M:CHGS]WSERNUMF         = [M:CHGS]SERNUMF   (I)

     When "SLM1" : [M:CHGS]PCUDES       (I) = [M:SLM1]PCU       (PNOL)
                   [M:CHGS]COEDES       (I) = [M:SLM1]PCUSTUCOE (PNOL)
                   [M:CHGS]STADES       (I) = [M:SLM1]STA       (PNOL)
                   If dim([M:CHGS]LOCTYPDES) > 0
                      [M:CHGS]LOCTYPDES (I) = [M:SLM1]LOCTYP    (PNOL)
                   Endif
                   If dim([M:CHGS]LOCDES) > 0
                      [M:CHGS]LOCDES    (I) = [M:SLM1]LOC       (PNOL)
                   Endif
                   If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]PALNUMDES (I) = [M:SLM1]PALNUM    (PNOL)
                   Endif
                   If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]CTRNUMDES (I) = [M:SLM1]CTRNUM    (PNOL)
                   Endif
                   [M:CHGS]LBEFMT       (I) = [M:SLM1]LBEFMT    (PNOL)
                   [M:CHGS]LBENBR       (I) = [M:SLM1]LBENBR    (PNOL)
                   [M:CHGS]QTYSTUDES    (I) = [M:SLM1]QTYSTU    (PNOL)
                   [M:CHGS]SERNUM       (I) = [M:SLM1]SERNUM    (PNOL)
                   [M:CHGS]SERNUMF      (I) = [M:SLM1]SERNUMF   (PNOL)
                   # mémorisation de la tranche de série deja saisie pour controler les nouveaux numeros de serie qui seront saisies
                   [M:CHGS]WSERNUM          = [M:CHGS]SERNUM    (I)
                   [M:CHGS]WSERNUMF         = [M:CHGS]SERNUMF   (I)
      # Issue X3-67963 - 2017-12-19 by MAE : Ajout de l'écran d'affectation des LPN
      When "LPNA" :
                   If dim([M:CHGS]PALNUMDES) > 0
                      [M:CHGS]PALNUMDES (I) = [M:LPNA]PALNUMDES    (PNOL)
                   Endif
                   If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]CTRNUMDES (I) = [M:LPNA]CTRNUMDES    (PNOL)
                   Endif
                   If dim([M:CHGS]LOCTYPDES) > 0
                      [M:CHGS]LOCTYPDES (I) = [M:LPNA]LOCTYPDES (PNOL)
                   Endif
                   If dim([M:CHGS]LOCDES) > 0
                      [M:CHGS]LOCDES    (I) = [M:LPNA]LOCDES    (PNOL)
                   Endif
                   [M:CHGS]WLOCSEQ      (I) = [M:LPNA]WLOCSEQ   (PNOL)
                   [M:CHGS]SERNUM       (I) = [M:LPNA]SERNUM    (PNOL)
                   [M:CHGS]SERNUMF      (I) = [M:LPNA]SERNUMF   (PNOL)
                   [M:CHGS]WSTOSEQIND   (I) = [M:LPNA]WSTOSEQIND(PNOL)
                   If dim ([M:CHGS]LPNNUMDES(I)) > 0
                    [M:CHGS]LPNNUMDES       (I) = [M:LPNA]LPNNUMDES    (PNOL)
                   Endif
                   # mémorisation de la tranche de série deja saisie pour controler les nouveaux numeros de serie qui seront saisies
                   [M:CHGS]WSERNUM          = [M:CHGS]SERNUM    (I)
                   [M:CHGS]WSERNUMF         = [M:CHGS]SERNUMF   (I)
                   If WLIGNE <> 2                                         # hcb 62634
                       Sorta [M:SGW]NBLIG [M:SGW]NBLIG Order By [M:SGW]WSTOSEQ(indice),[M:SGW]WSTOSEQIND(indice),[M:SGW]WSERNUM(indice)

                       Y = find([M:CHGS]WSTOSEQ , [M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
                       If Y >= 0
                          While Y<[M:SGW]NBLIG & [M:CHGS]WSTOSEQ=[M:SGW]WSTOSEQ(Y)
                                [M:CHGS]QTYSTUDES    (I) = [M:SGW]WQTYSTUDES (Y)
                                [M:CHGS]SERNUM       (I) = [M:SGW]WSERNUM    (Y)
                                [M:CHGS]SERNUMF      (I) = [M:SGW]WSERNUMF   (Y)
                                [M:CHGS]WSTOSEQIND   (I) = [M:SGW]WSTOSEQIND (Y)
                                If dim([M:CHGS]LOCTYPDES) > 0
                                    [M:CHGS]LOCTYPDES (I) = [M:SGW]WLOCTYPDES (Y)
                                Endif
                                If dim([M:CHGS]LOCDES) > 0
                                    [M:CHGS]LOCDES    (I) = [M:SGW]WLOCDES    (Y)
                                Endif
                                If dim ([M:CHGS]LPNNUMDES(I)) > 0
                                    [M:CHGS]LPNNUMDES  (I) = [M:SGW]WLPNNUMDES (Y)
                                Endif
                                 If dim([M:CHGS]PALNUMDES) > 0
                                   [M:CHGS]PALNUMDES (I) = [M:SGW]WPALNUMDES   (Y)
                                Endif
                                If dim([M:CHGS]CTRNUMDES) > 0
                                   [M:CHGS]CTRNUMDES (I) = [M:SGW]WCTRNUMDES   (Y)
                                Endif
                                Y+=1
                                I +=1
                          Wend
                          If I > 0 : I -=1 : Endif
                       Endif
                       [M:CHGS]NBLIG = I

                       If [M:CHGS]NBLIG > 1 & WLIGNE = 0
                          Diszo [M:CHGS]
                          WLIGNE = 9
                       Endif
                   Endif
         # End issue X3-67963
          # Issue X3-67963 - 2017-12-19 by MAE : Ajout de l'écran d'affectation des LPN
      When "LPNO" :
                    If dim([M:CHGS]PALNUMDES) > 0
                      [M:CHGS]PALNUMDES (I) = [M:LPNO]PALNUMDES    (PNOL)
                   Endif
                   If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]CTRNUMDES (I) = [M:LPNO]CTRNUMDES    (PNOL)
                   Endif
                   If dim([M:CHGS]LOCTYPDES) > 0
                      [M:CHGS]LOCTYPDES (I) = [M:LPNO]LOCTYPDES (PNOL)
                   Endif
                   If dim([M:CHGS]LOCDES) > 0
                      [M:CHGS]LOCDES    (I) = [M:LPNO]LOCDES    (PNOL)
                   Endif
                   [M:CHGS]WLOCSEQ      (I) = [M:LPNO]WLOCSEQ   (PNOL)
                   [M:CHGS]SERNUM       (I) = [M:LPNO]SERNUM    (PNOL)
                   [M:CHGS]SERNUMF      (I) = [M:LPNO]SERNUMF   (PNOL)
                   [M:CHGS]WSTOSEQIND   (I) = [M:LPNO]WSTOSEQIND(PNOL)
                   If dim ([M:CHGS]LPNNUMDES(I)) > 0
                    [M:CHGS]LPNNUMDES       (I) = [M:LPNO]LPNNUMDES    (PNOL)
                   Endif
                   # mémorisation de la tranche de série deja saisie pour controler les nouveaux numeros de serie qui seront saisies
                   [M:CHGS]WSERNUM          = [M:CHGS]SERNUM    (I)
                   [M:CHGS]WSERNUMF         = [M:CHGS]SERNUMF   (I)
                   If WLIGNE <> 2                                         # hcb 62634
                       Sorta [M:SGW]NBLIG [M:SGW]NBLIG Order By [M:SGW]WSTOSEQ(indice),[M:SGW]WSTOSEQIND(indice),[M:SGW]WSERNUM(indice)

                       Y = find([M:CHGS]WSTOSEQ , [M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
                       If Y >= 0
                          While Y<[M:SGW]NBLIG & [M:CHGS]WSTOSEQ=[M:SGW]WSTOSEQ(Y)
                                [M:CHGS]QTYSTUDES    (I) = [M:SGW]WQTYSTUDES (Y)
                                [M:CHGS]SERNUM       (I) = [M:SGW]WSERNUM    (Y)
                                [M:CHGS]SERNUMF      (I) = [M:SGW]WSERNUMF   (Y)
                                [M:CHGS]WSTOSEQIND   (I) = [M:SGW]WSTOSEQIND (Y)
                                If dim([M:CHGS]LOCTYPDES) > 0
                                    [M:CHGS]LOCTYPDES (I) = [M:SGW]WLOCTYPDES (Y)
                                Endif
                                If dim([M:CHGS]LOCDES) > 0
                                    [M:CHGS]LOCDES    (I) = [M:SGW]WLOCDES    (Y)
                                Endif
                                If dim ([M:CHGS]LPNNUMDES(I)) > 0
                                    [M:CHGS]LPNNUMDES  (I) = [M:SGW]WLPNNUMDES (Y)
                                Endif
                                 If dim([M:CHGS]PALNUMDES) > 0
                                   [M:CHGS]PALNUMDES (I) = [M:SGW]WPALNUMDES   (Y)
                                Endif
                                If dim([M:CHGS]CTRNUMDES) > 0
                                   [M:CHGS]CTRNUMDES (I) = [M:SGW]WCTRNUMDES   (Y)
                                Endif
                                Y+=1
                                I +=1
                          Wend
                          If I > 0 : I -=1 : Endif
                       Endif
                       [M:CHGS]NBLIG = I

                       If [M:CHGS]NBLIG > 1 & WLIGNE = 0
                          Diszo [M:CHGS]
                          WLIGNE = 9
                       Endif
                   Endif
         # End issue X3-67963
          When "LPNC" :
                  If dim([M:CHGS]PALNUMDES) > 0
                      [M:CHGS]PALNUMDES (I) = [M:LPNC]PALNUMDES    (PNOL)
                   Endif
                   If dim([M:CHGS]CTRNUMDES) > 0
                      [M:CHGS]CTRNUMDES (I) = [M:LPNC]CTRNUMDES    (PNOL)
                   Endif
                   If dim([M:CHGS]LOCTYPDES) > 0
                      [M:CHGS]LOCTYPDES (I) = [M:LPNC]LOCTYPDES (PNOL)
                   Endif
                   If dim([M:CHGS]LOCDES) > 0
                      [M:CHGS]LOCDES    (I) = [M:LPNC]LOCDES    (PNOL)
                   Endif
                   [M:CHGS]WLOCSEQ      (I) = [M:LPNC]WLOCSEQ   (PNOL)
                   [M:CHGS]SERNUM       (I) = [M:LPNC]SERNUM    (PNOL)
                   [M:CHGS]SERNUMF      (I) = [M:LPNC]SERNUMF   (PNOL)
                   [M:CHGS]WSTOSEQIND   (I) = [M:LPNC]WSTOSEQIND(PNOL)
                   If dim ([M:CHGS]LPNNUMDES(I)) > 0
                    [M:CHGS]LPNNUMDES       (I) = [M:LPNC]LPNNUMDES    (PNOL)
                   Endif
                   [M:CHGS]QTYSTUDES    (I) = [M:LPNC]QTYSTUDES (PNOL)
                   # mémorisation de la tranche de série deja saisie pour controler les nouveaux numeros de serie qui seront saisies
                   [M:CHGS]WSERNUM          = [M:CHGS]SERNUM    (I)
                   [M:CHGS]WSERNUMF         = [M:CHGS]SERNUMF   (I)
#                   If WLIGNE <> 2                                         # hcb 62634
#                       Sorta [M:SGW]NBLIG [M:SGW]NBLIG Order By [M:SGW]WSTOSEQ(indice),[M:SGW]WSTOSEQIND(indice),[M:SGW]WSERNUM(indice)
#
#                       Y = find([M:CHGS]WSTOSEQ , [M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
#                       If Y >= 0
#                          While Y<[M:SGW]NBLIG & [M:CHGS]WSTOSEQ=[M:SGW]WSTOSEQ(Y)
#                                [M:CHGS]QTYSTUDES    (I) = [M:SGW]WQTYSTUDES (Y)
#                                [M:CHGS]SERNUM       (I) = [M:SGW]WSERNUM    (Y)
#                                [M:CHGS]SERNUMF      (I) = [M:SGW]WSERNUMF   (Y)
#                                [M:CHGS]WSTOSEQIND   (I) = [M:SGW]WSTOSEQIND (Y)
#                                If dim([M:CHGS]LOCTYPDES) > 0
#                                    [M:CHGS]LOCTYPDES (I) = [M:SGW]WLOCTYPDES (Y)
#                                Endif
#                                If dim([M:CHGS]LOCDES) > 0
#                                    [M:CHGS]LOCDES    (I) = [M:SGW]WLOCDES    (Y)
#                                Endif
#                                If dim ([M:CHGS]LPNNUMDES(I)) > 0
#                                    [M:CHGS]LPNNUMDES  (I) = [M:SGW]WLPNNUMDES (Y)
#                                Endif
#                                If dim([M:CHGS]PALNUMDES) > 0
#                                    [M:CHGS]PALNUMDES (I) = [M:SGW]WPALNUMDES    (Y)
#                                Endif
#                                If dim([M:CHGS]CTRNUMDES) > 0
#                                    [M:CHGS]CTRNUMDES (I) = [M:SGW]WCTRNUMDES    (Y)
#                                Endif
#                                Y+=1
#                                I +=1
#                          Wend
#                          If I > 0 : I -=1 : Endif
#                       Endif
#                       [M:CHGS]NBLIG = I
#
#                       If [M:CHGS]NBLIG > 1 & WLIGNE = 0
#                          Diszo [M:CHGS]
#                          WLIGNE = 9
#                       Endif
#                   Endif
         # End issue X3-67963
      When Default:
Endcase

Return

###############################################################################
# DELSTOCHGW_IND : Efface le détail de N lignes de document changement stock
###############################################################################
# Paramètres E : PFCY   = Site de départ
#                PSEQ   = Séquence
#                PCOU   = Stocou
#                PSEQINS= Indice
#                PDELLOC= Indique s'il faut supprimer les réservations d'emplacement
#
#            S : PRET   = Code retour (0=OK, 1=Erreur)
#
# Appelé dans le cadre de la suppression d'un bloc de ligne
###############################################################################
Subprog DELSTOCHGW_IND(PFCY, PSEQ, PCOU, PSEQIND, PDELLOC, PRET )
Value    Char    PFCY
Value    Integer PSEQ
Value    Decimal PCOU
Value    Integer PSEQIND
Value    Integer PDELLOC
Variable Integer PRET

Local Integer WTRBEGIN, I, IND
Local Decimal LSTOCOU
Local Decimal LWIPQTY, LWIPQTA

Raz WTRBEGIN

If clalev([F:STO1])=0  Local File STOCK   [STO1]  Endif
If clalev([F:SWW]) =0  Local File STOWIPW [SWW]   Endif

# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [STO1]
   WTRBEGIN=1
Endif


For I=0 To [M:SGW]NBLIG-1
    If [M:SGW]WSTOSEQ(I)>0 & PSEQ = [M:SGW]WSTOSEQ(I) & PCOU = [M:SGW]WSTOCOU(I) & PSEQIND = [M:SGW]WSTOSEQIND(I)
        Readlock [STO1]STO0=PFCY;[M:SGW]WSTOCOU(I)
        If fstat
            If fstat=1
                GOK=0
                Call RSTA("STO1",PFCY-num$([M:SGW]WSTOCOU(I))) From GLOCK
                LRET=1 : Break
            Endif
        Else
            LWIPQTY = [M:SGW]WWIPQTY(I)
            LWIPQTA = [M:SGW]WWIPQTA(I)
            [F:STO1]CUMWIPQTY  = max(0,[F:STO1]CUMWIPQTY-LWIPQTY)
            [F:STO1]CUMWIPQTA  = max(0,[F:STO1]CUMWIPQTA-LWIPQTA)

            # Suppression qté en cours de traitement
            LSTOCOU = [F:STO1]STOCOU
            Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB
            Rewrite [STO1]
            If fstat
                GOK=0  : Call FSTA("STO1") From GLOCK
                LRET=1 : Break
            Endif
            # Suppression série en cours de traitement
            If [M:SGW]WSERNUM(I) <> ""
                Call DEL_STOSERW([F:STO]ITMREF,[M:SGW]WSERNUM(I),[M:SGW]WQTYSTUDES(I),PRET) From STKLIB
            Endif
            If PRET <>0
               Break
            Endif
            [M:SGW]WSTOCOU   (I) = 0
            [M:SGW]WSTOSEQ   (I) = 0
            [M:SGW]WSTOSEQIND(I) = 0
            IND+=1
        Endif
    Endif
Next I

# Si on a ouvert une transaction
If WTRBEGIN=1
    If GOK=0
        Rollback
        End
    Else
        Commit
        Raz WTRBEGIN
    Endif
Endif


End

# chargement du tableau de l ecran origine depuis un picking
$CHARG_TABLEAU
Local Decimal WQTY
Local Decimal LSTOCOU
Local Char    LSER(GLONSER)
Local Char    LITM
Local Integer PRET
Local Integer NOL
Local Integer WTRBEGIN
Raz   PRET
Raz   WTRBEGIN
LITM    =  [M:CHGS]ITMREF
LSTOCOU =  [M:CHGS]STOCOU
For I=0 To [M:CHGS]NBLIG-1
    If [M:CHGS]QTYSTUDES (I) <> 0
       Case PABR
            When "QCR1" : If [M:QCR1]NBLIG + 1 >  dim([M:QCR1]ITMREF)
                             Return
                          Endif
                          LQTY = [M:CHGS]QTYSTUDES(I)
                          LSER = [M:CHGS]SERNUM   (I)
                          WQTY = LQTY
                          NOL  = [M:QCR1]NBLIG
                          [M:QCR1]WWIPQTY          ([M:QCR1]NBLIG)     = LQTY
                          [M:QCR1]WWIPQTA          ([M:QCR1]NBLIG)     = LQTY
                          [M:QCR1]POT              ([M:QCR1]NBLIG)     = 1
                          Gosub CRERESSTO   From SUBQCRB  # --> Modifie LQTY, calcule LQTYRES et LPOT
                          If  WQTY <> LQTY & LSER <> ""
                              GMESSAGE = mess(302,199,1)   # Désynchronisation des numéros de série (Stock / Séries)
                              If GACTION <> "SAICHGSERE"
                                 Return
                              Endif
                          Else
                             # Création série en cours de traitement
                             If LSER <> ""
                                Call CRE_STOSERW(LITM,LSER,LQTY,PRET) From STKLIB
                                If PRET <>0
                                   Break
                                Endif
                             Endif
                          Endif
                          If GACTION <> "SAICHGSERE"
                             [M:QCR1]ITMREF           ([M:QCR1]NBLIG)     = [F:STO]ITMREF
                             [M:QCR1]ITMDES1          ([M:QCR1]NBLIG)     = [F:ITM]ITMDES1
                             If dim([M:QCR1]LOT)>0
                                [M:QCR1]LOT           ([M:QCR1]NBLIG)     = [F:STO]LOT
                             Endif
                             If dim([M:QCR1]SLO)>0
                                [M:QCR1]SLO           ([M:QCR1]NBLIG)     = [F:STO]SLO
                             Endif
                             If dim([M:QCR1]PALNUM)>0
                                [M:QCR1]PALNUM        ([M:QCR1]NBLIG)     = [F:STO]PALNUM
                             Endif
                             If dim([M:QCR1]CTRNUM)>0
                                [M:QCR1]CTRNUM        ([M:QCR1]NBLIG)     = [F:STO]CTRNUM
                             Endif
                             If dim([M:QCR1]LPNNUM) > 0                                           # hcb X3-77048
                                [M:QCR1]LPNNUM        ([M:QCR1]NBLIG)     = [F:STO]LPNNUM
                             Endif
                             If dim([M:QCR1]LOC)>0
                                [M:QCR1]LOC           ([M:QCR1]NBLIG)     = [F:STO]LOC
                             Endif
                             If dim([M:QCR1]LOCTYP)>0
                                [M:QCR1]LOCTYP        ([M:QCR1]NBLIG)     = [F:STO]LOCTYP
                             Endif
                             If dim([M:QCR1]WRH)>0
                                [M:QCR1]WRH           ([M:QCR1]NBLIG)     = [F:STO]WRH
                             Endif
                             [M:QCR1]STA              ([M:QCR1]NBLIG)     = [F:STO]STA
                             [M:QCR1]OWNER            ([M:QCR1]NBLIG)     = [F:STO]OWNER
                             [M:QCR1]PCU              ([M:QCR1]NBLIG)     = [F:STO]PCU
                             [M:QCR1]PCUSTUCOE        ([M:QCR1]NBLIG)     = [F:STO]PCUSTUCOE
                             [M:QCR1]WSTOCOU          ([M:QCR1]NBLIG)     = [F:STO]STOCOU
                             [M:QCR1]STU              ([M:QCR1]NBLIG)     = [F:ITM]STU
                             [M:QCR1]STADES           ([M:QCR1]NBLIG)     = [M:CHGS]STADES (I)
                             [M:QCR1]QTYPCU           ([M:QCR1]NBLIG)     = LQTY
                             [M:QCR1]QTYSTUDES        ([M:QCR1]NBLIG)     = LQTY
                             [M:QCR1]STUDIS           ([M:QCR1]NBLIG)     = [M:CHGS]STUDIS (I)
                             If dim([M:QCR1]SERNUM)>0
                                [M:QCR1]SERNUM        ([M:QCR1]NBLIG)     = [M:CHGS]SERNUM (I)
                             Endif
                             If dim([M:QCR1]SERNUMF)>0
                                [M:QCR1]SERNUMF       ([M:QCR1]NBLIG)     = [M:CHGS]SERNUMF(I)
                             Endif
                             Actzo [M:QCR1]QTYSTUDES  ([M:QCR1]NBLIG)
                             Actzo [M:QCR1]STADES     ([M:QCR1]NBLIG)
                             If dim([M:QCR1]MVTDES)>0
                                Actzo [M:QCR1]MVTDES  ([M:QCR1]NBLIG)
                             Endif
                             Diszo [M:QCR1]QTYPCU     ([M:QCR1]NBLIG)
                             [M:QCR1]NBLIG += 1
                          Endif
            When "SLM1" : If [M:SLM1]NBLIG + 1 >  dim([M:SLM1]STA)
                             Return
                          Endif
                          LQTY = [M:CHGS]QTYSTUDES(I)
                          LSER = [M:CHGS]SERNUM   (I)
                          WQTY = LQTY
                          NOL  = [M:SLM1]NBLIG

                          # Si pas de transaction en cours
                          If adxlog<>1
                             GOK=1
                             Trbegin [STO2]
                             WTRBEGIN=1
                          Endif

                          Readlock [STO2]STO0=[M:SLM1]STOFCY;LSTOCOU
                          If !fstat
                             LQTY = max(0, min(LQTY, [F:STO2]QTYSTU-[F:STO2]CUMWIPQTY))
                             LQTYRES = min(LQTY,[F:STO2]QTYSTU-[F:STO2]CUMWIPQTY-[F:STO2]CUMALLQTY)
                             If LQTY>0
                                [F:STO2]CUMWIPQTY += LQTYRES
                                [F:STO2]CUMWIPQTA += LQTYRES
                                Rewrite [STO2]
                                # Création quantité en cours de traitement
                                Call CRE_STOWIPW([F:STO2]STOCOU,LQTYRES,LQTYRES) From STKLIB
                             Else
                                Unlock [STO2]
                             Endif
                          Endif
                          If  WQTY <> LQTY & LSER <> ""
                              GMESSAGE = mess(302,199,1)   # Désynchronisation des numéros de série (Stock / Séries)
                              If GACTION <> "SAICHGSERE"
                                 Return
                              Endif
                          Else
                             # Création série en cours de traitement
                             If LSER <> ""
                                Call CRE_STOSERW(LITM,LSER,LQTY,PRET) From STKLIB
                                If PRET <>0
                                   Break
                                Endif
                             Endif
                          Endif
                          # Si on a ouvert une transaction
                          If WTRBEGIN=1
                             Commit
                             Raz WTRBEGIN
                          Endif
                          If GACTION <> "SAICHGSERE"
                             [M:SLM1]WSTOCOU          ([M:SLM1]NBLIG)     = [M:CHGS]STOCOU
                             [M:SLM1]STA              ([M:SLM1]NBLIG)     = [M:CHGS]STADES    (I)
                             If dim([M:SLM1]LOCTYP)>0
                                [M:SLM1]LOCTYP        ([M:SLM1]NBLIG)     = [M:CHGS]LOCTYPDES (I)
                             Endif
                             If dim([M:SLM1]LOC)>0
                                [M:SLM1]LOC           ([M:SLM1]NBLIG)     = [M:CHGS]LOCDES    (I)
                             Endif
                             [M:SLM1]PCU              ([M:SLM1]NBLIG)     = [M:CHGS]PCUDES    (I)
                             [M:SLM1]QTYPCU           ([M:SLM1]NBLIG)     = LQTY
                             [M:SLM1]PCUSTUCOE        ([M:SLM1]NBLIG)     = [M:CHGS]COEDES    (I)
                             [M:SLM1]STU              ([M:SLM1]NBLIG)     = [F:ITM]STU
                             [M:SLM1]QTYSTU           ([M:SLM1]NBLIG)     = LQTY
                             If dim([M:SLM1]SERNUM)>0
                                [M:SLM1]SERNUM        ([M:SLM1]NBLIG)     = [M:CHGS]SERNUM    (I)
                             Endif
                             If dim([M:SLM1]SERNUMF)>0
                                [M:SLM1]SERNUMF       ([M:SLM1]NBLIG)     = [M:CHGS]SERNUMF   (I)
                             Endif
                             If dim([M:SLM1]PALNUM)>0
                                [M:SLM1]PALNUM        ([M:SLM1]NBLIG)     = [M:CHGS]PALNUMDES (I)
                             Endif
                             If dim([M:SLM1]CTRNUM)>0
                                [M:SLM1]CTRNUM        ([M:SLM1]NBLIG)     = [M:CHGS]CTRNUMDES (I)
                             Endif
                             [M:SLM1]LBENBR           ([M:SLM1]NBLIG)     = [M:CHGS]LBENBR    (I)
                             [M:SLM1]LBEFMT           ([M:SLM1]NBLIG)     = [M:CHGS]LBEFMT    (I)
                             Actzo [M:SLM1]QTYPCU     ([M:SLM1]NBLIG)
                             Actzo [M:SLM1]QTYSTU     ([M:SLM1]NBLIG)
                             Actzo [M:SLM1]LBENBR     ([M:SLM1]NBLIG)
                             Actzo [M:SLM1]LBEFMT     ([M:SLM1]NBLIG)
                            [M:SLM1]NBLIG += 1
                         Endif
            When Default:
       Endcase
    Endif
Next I

Return


# chargement du tableau de l ecran origine depuis la fenetre
$CHARG_TABLEAU_CHGS
Local Decimal WQTY
Local Decimal LSTOCOU
Local Char    LSER(GLONSER)
Local Char    LITM
Local Integer PRET
Local Integer NOL
Local Integer WTRBEGIN
Raz   PRET
Raz   WTRBEGIN
LITM    =  [M:CHGS]ITMREF
LSTOCOU =  [M:CHGS]STOCOU
For I=0 To [M:CHGS]NBLIG-1
    If [M:CHGS]QTYSTUDES (I) <> 0
       Case PABR
            When "QCR1" : If [M:QCR1]NBLIG + 1 >  dim([M:QCR1]ITMREF)
                             Return
                          Endif
                          LQTY = [M:CHGS]QTYSTUDES(I)
                          LSER = [M:CHGS]SERNUM   (I)
                          [M:QCR1]WWIPQTY          ([M:QCR1]NBLIG)     = LQTY
                          [M:QCR1]WWIPQTA          ([M:QCR1]NBLIG)     = LQTY
                          [M:QCR1]POT              ([M:QCR1]NBLIG)     = 1
                          [M:QCR1]ITMREF           ([M:QCR1]NBLIG)     = [F:STO]ITMREF
                          [M:QCR1]ITMDES1          ([M:QCR1]NBLIG)     = [F:ITM]ITMDES1
                          If dim([M:QCR1]LOT)>0
                             [M:QCR1]LOT           ([M:QCR1]NBLIG)     = [F:STO]LOT
                          Endif
                          If dim([M:QCR1]SLO)>0
                             [M:QCR1]SLO           ([M:QCR1]NBLIG)     = [F:STO]SLO
                          Endif
                          If dim([M:QCR1]PALNUM)>0
                             [M:QCR1]PALNUM        ([M:QCR1]NBLIG)     = [F:STO]PALNUM
                          Endif
                          If dim([M:QCR1]CTRNUM)>0
                             [M:QCR1]CTRNUM        ([M:QCR1]NBLIG)     = [F:STO]CTRNUM
                          Endif
                          If dim([M:QCR1]LPNNUM) > 0                                           # hcb X3-77048
                             [M:QCR1]LPNNUM        ([M:QCR1]NBLIG)     = [F:STO]LPNNUM
                          Endif
                          If dim([M:QCR1]LOC)>0
                             [M:QCR1]LOC           ([M:QCR1]NBLIG)     = [F:STO]LOC
                          Endif
                          If dim([M:QCR1]LOCTYP)>0
                             [M:QCR1]LOCTYP        ([M:QCR1]NBLIG)     = [F:STO]LOCTYP
                          Endif
                          If dim([M:QCR1]WRH)>0
                             [M:QCR1]WRH           ([M:QCR1]NBLIG)     = [F:STO]WRH
                          Endif
                          [M:QCR1]STA              ([M:QCR1]NBLIG)     = [F:STO]STA
                          [M:QCR1]OWNER            ([M:QCR1]NBLIG)     = [F:STO]OWNER
                          [M:QCR1]PCU              ([M:QCR1]NBLIG)     = [F:STO]PCU
                          [M:QCR1]PCUSTUCOE        ([M:QCR1]NBLIG)     = [F:STO]PCUSTUCOE
                          [M:QCR1]WSTOCOU          ([M:QCR1]NBLIG)     = [F:STO]STOCOU
                          [M:QCR1]STU              ([M:QCR1]NBLIG)     = [F:ITM]STU
                          [M:QCR1]STADES           ([M:QCR1]NBLIG)     = [M:CHGS]STADES (I)
                          [M:QCR1]QTYPCU           ([M:QCR1]NBLIG)     = LQTY
                          [M:QCR1]QTYSTUDES        ([M:QCR1]NBLIG)     = LQTY
                          [M:QCR1]STUDIS           ([M:QCR1]NBLIG)     = [M:CHGS]STUDIS (I)
                          If dim([M:QCR1]SERNUM)>0
                             [M:QCR1]SERNUM        ([M:QCR1]NBLIG)     = [M:CHGS]SERNUM (I)
                          Endif
                          If dim([M:QCR1]SERNUMF)>0
                             [M:QCR1]SERNUMF       ([M:QCR1]NBLIG)     = [M:CHGS]SERNUMF(I)
                          Endif
                          Actzo [M:QCR1]QTYSTUDES  ([M:QCR1]NBLIG)
                          Actzo [M:QCR1]STADES     ([M:QCR1]NBLIG)
                          If dim([M:QCR1]MVTDES)>0
                             Actzo [M:QCR1]MVTDES  ([M:QCR1]NBLIG)
                          Endif
                          Diszo [M:QCR1]QTYPCU     ([M:QCR1]NBLIG)
                          [M:QCR1]NBLIG += 1
            When "SLM1" : If [M:SLM1]NBLIG + 1 >  dim([M:SLM1]STA)
                             Return
                          Endif
                          LQTY = [M:CHGS]QTYSTUDES(I)
                          LSER = [M:CHGS]SERNUM   (I)
                          [M:SLM1]WSTOCOU          ([M:SLM1]NBLIG)     = [M:CHGS]STOCOU
                          [M:SLM1]STA              ([M:SLM1]NBLIG)     = [M:CHGS]STADES    (I)
                          If dim([M:SLM1]LOCTYP)>0
                             [M:SLM1]LOCTYP        ([M:SLM1]NBLIG)     = [M:CHGS]LOCTYPDES (I)
                          Endif
                          If dim([M:SLM1]LOC)>0
                             [M:SLM1]LOC           ([M:SLM1]NBLIG)     = [M:CHGS]LOCDES    (I)
                          Endif
                          [M:SLM1]PCU              ([M:SLM1]NBLIG)     = [M:CHGS]PCUDES    (I)
                          [M:SLM1]QTYPCU           ([M:SLM1]NBLIG)     = LQTY
                          [M:SLM1]PCUSTUCOE        ([M:SLM1]NBLIG)     = [M:CHGS]COEDES    (I)
                          [M:SLM1]STU              ([M:SLM1]NBLIG)     = [F:ITM]STU
                          [M:SLM1]QTYSTU           ([M:SLM1]NBLIG)     = LQTY
                          If dim([M:SLM1]SERNUM)>0
                             [M:SLM1]SERNUM        ([M:SLM1]NBLIG)     = [M:CHGS]SERNUM    (I)
                          Endif
                         If dim([M:SLM1]SERNUMF)>0
                             [M:SLM1]SERNUMF       ([M:SLM1]NBLIG)     = [M:CHGS]SERNUMF   (I)
                          Endif
                          If dim([M:SLM1]PALNUM)>0
                             [M:SLM1]PALNUM        ([M:SLM1]NBLIG)     = [M:CHGS]PALNUMDES (I)
                          Endif
                          If dim([M:SLM1]CTRNUM)>0
                             [M:SLM1]CTRNUM        ([M:SLM1]NBLIG)     = [M:CHGS]CTRNUMDES (I)
                          Endif
                          If [F:SRT]PRNCOD1 = 2
                             [M:SLM1]LBENBR([M:SLM1]NBLIG)             = [M:SLM1]QTYPCU    ([M:SLM1]NBLIG)
                             [M:SLM1]LBEFMT([M:SLM1]NBLIG)             = [M:CHGS]LBEFMT    (I)
                          Endif
                          [M:SLM1]LBENBR           ([M:SLM1]NBLIG)     = [M:CHGS]LBENBR    (I)
                          [M:SLM1]LBEFMT           ([M:SLM1]NBLIG)     = [M:CHGS]LBEFMT    (I)
                          Actzo [M:SLM1]QTYPCU     ([M:SLM1]NBLIG)
                          Actzo [M:SLM1]QTYSTU     ([M:SLM1]NBLIG)
                          Actzo [M:SLM1]LBENBR     ([M:SLM1]NBLIG)
                          Actzo [M:SLM1]LBEFMT     ([M:SLM1]NBLIG)

                          [M:SLM1]NBLIG += 1

            When Default:
       Endcase
    Endif
Next I

Return





#########################################################################
$AVANT_ENR

If [M:CHGS]NBLIG=0 |
& ([M:CHGS]NBLIG<>0 & sigma(I=0,[M:CHGS]NBLIG-1,[M:CHGS]QTYSTUDES(I))>[M:CHGS]QTYSTU)
   # Le nb de no série ne correspond pas à la qté à traiter
   GMESSAGE = mess(246,199,1)
   GERR=1
   FOK=0
   Return
Endif
Raz [M:CHGS1]
If [M:CHGS]NBLIG>1
   [M:CHGS1] = [M:CHGS]
   # Vérification que les plages de no série sont bien croissantes
   Sorta [M:CHGS1]NBLIG [M:CHGS1]NBLIG Order By [M:CHGS1]SERNUM([S]indice)
   For I=1 To [M:CHGS1]NBLIG-1
      If [M:CHGS1]SERNUM(I) <= [M:CHGS1]SERNUMF(I-1)
         GMESSAGE = mess(464,199,1)
         GERR=1
         FOK=0
         Break
      Endif
   Next I
Endif
Default Mask [M:CHGS]
Return

#########################################################################
$ENR
Local Integer WNBLIG, LRET
Local Decimal LQTYSTU
Local Integer LSEQ
Local Integer I
Local Integer WTRBEGIN
Raz LQTYSTU
Raz LSEQ
Raz I
Raz WTRBEGIN
# Contrôle de l'insertion
WNBLIG = [M:CHGS]NBLIG
If [M:CHGS]WSTOCKAGE = 1
#---
   If [M:SGW]NBLIG+WNBLIG >= dim([M:SGW]WSTOSEQ)-1
      FOK=0
      GERR=1
      GMESSAGE=mess(122,199,1)   # insertion impossible
      Return
   Endif
   For I=0 To [M:CHGS]NBLIG-1
       Call DELSTOCHGW_IND([M:CHGS]STOFCY, [M:CHGS]WSTOSEQ,[M:CHGS]STOCOU,[M:CHGS]WSTOSEQIND(I),0, LRET)
   Next I

   LSEQ = [M:CHGS]WSTOSEQ
   Call FILLCHGW("CHGS", 0, [M:CHGS]NBLIG, LSEQ, [M:CHGS]STOFCY, LRET, LQTYSTU) From SUBSCSB
   If LRET<>0 | GERR=2
      LRET=99
   Endif
   If LQTYSTU=0
      Call ERREUR(mess(367,199,1)) From GESECRAN    # Pas de stock disponible
   Endif
Else
   Case PABR
        When "QCR1"  : Call DELSTO([M:CHGS]STOFCY, PNOL, PNOL, LRET) From SUBQCRB
        When "SLM1"  : If adxlog<>1
                          GOK=1
                          Trbegin [STO]
                          WTRBEGIN=1
                       Endif
                       Readlock [STO]STO0=[M:CHGS]STOFCY;[M:SLM1]WSTOCOU(PNOL)
                       If !fstat
                          [F:STO]CUMWIPQTY = max(0,[F:STO]CUMWIPQTY-[M:SLM1]QTYSTU(PNOL))
                          [F:STO]CUMWIPQTA = max(0,[F:STO]CUMWIPQTA-[M:SLM1]QTYSTU(PNOL))
                          Call DEL_STOWIPW([F:STO]STOCOU,[M:SLM1]QTYSTU(PNOL)) From STKLIB
                          Rewrite [STO]
                          If fstat
                             GOK=0 : Call FSTA("STO") From GLOCK
                          Endif
                       Else
                          GOK=0
                       Endif
                       # Suppression série en cours de traitement
                       If [M:SLM1]SERNUM(PNOL) <> ""
                          Call DEL_STOSERW([F:STO]ITMREF,[M:SLM1]SERNUM(PNOL),[M:SLM1]QTYSTU(PNOL),LRET) From STKLIB
                       Endif

                       If WTRBEGIN=1
                          If GOK : Commit : Else : Rollback : Endif
                          Raz WTRBEGIN
                       Endif
        When Default:
   Endcase
   Gosub CHARG_TABLEAU From TRTCHGSERE
Endif
FIN = 1
Return

#########################################################################
$ABA

Gosub DEBUT

Return

#########################################################################
$FIN
Local Integer WI
WI = find(2,[M:CHGS]MODFLG(0..[M:CHGS]NBLIG-1))
If WI > 0
   Case PABR
        When "SQD"  : Effzo [M:SQD]20
                      Raz   [M:SQD]NBLIG
                      Affzo [M:SQD]20
                      Gosub LOAD_FROM_STJ From TRTSTOQUAB
                      If [M:SQD]NBLIG > 1
                         [M:SQD]NBLIG = [M:SQD]NBLIG -1
                      Endif
                      Sorta [M:SGW]NBLIG [M:SGW]NBLIG Order By [M:SGW]WSTOSEQ(indice),[M:SGW]WSTOSEQIND(indice),[M:SGW]WSERNUM(indice)
                      Gosub LOAD_FROM_SGW From TRTSTOQUAB
                      Gosub MAJ_PECQTY    From TRTSTOQUAB
                      GPOINT="MAJ_SQD" : Gosub ENTREE From EXEFNC
        When "SCD"  : Effzo [M:SCD]20
                      Raz   [M:SCD]NBLIG
                      Affzo [M:SCD]20
                      Sorta [M:SGW]NBLIG [M:SGW]NBLIG Order By [M:SGW]WSTOSEQ(indice),[M:SGW]WSTOSEQIND(indice),[M:SGW]WSERNUM(indice)
                      Gosub LOAD_FROM_SGW From TRTSTOCHGB
                      Gosub MAJ_PECQTY    From TRTSTOCHGB
        When "SMP1" : Effzo [M:SMP1]20
                      Raz   [M:SMP1]NBLIG
                      Affzo [M:SMP1]20
                      Sorta [M:SGW]NBLIG [M:SGW]NBLIG Order By [M:SGW]WSTOSEQ(indice),[M:SGW]WSTOSEQIND(indice),[M:SGW]WSERNUM(indice)
                      Gosub LOAD_FROM_STJ_SMP1 From TRTSTOSMPB
                      # chargement du tableau  par les details deja saisis
                      Gosub LOAD_FROM_SGW_SMP1 From TRTSTOSMPB
                      [M:SMP1]WSTOFLG = 1
                      Affzo [M:SMP1]20
                      GPOINT="MAJ_SMP1" : Gosub ENTREE From EXEFNC
        When "QCR1" : Dela PNOL,1,[M:QCR1]NBLIG-1 [M:QCR1]NBLIG
                      [M:QCR1]NBLIG -= 1
                      Gosub CHARG_TABLEAU_CHGS  From TRTCHGSERE
        When "SLM1" : Dela PNOL,1,[M:SLM1]NBLIG-1 [M:SLM1]NBLIG
                      [M:SLM1]NBLIG -= 1
                      Gosub CHARG_TABLEAU_CHGS  From TRTCHGSERE
        When "LPNA", "LPNO" :
                      Gosub CHARG_TABLEAU_CHGS  From TRTCHGSERE
        When  "LPNC" :
                      Effzo [M:LPNC]10
                      Raz   [M:LPNC]NBLIG
                      Affzo [M:LPNC]10
                      Sorta [M:SGW]NBLIG [M:SGW]NBLIG Order By [M:SGW]WSTOSEQ(indice),[M:SGW]WSTOSEQIND(indice),[M:SGW]WSERNUM(indice)
                      Gosub LOAD_FROM_SGW From TRTLPNCHG

        When Default:
   Endcase
Endif
Return

#########################################################################
$FINSAI
Default Mask "["+PABR+"]"

Affzo [M]
mkstat=4

Return

###########################################################################
$ALI_STOCHG

nolign += 1
NOL = nolign-1


Return

###########################################################################

Subprog AVANT_NBLIG
Local Integer I
Local Integer J
Local Integer WLIGNE
WLIGNE = 2
I =nolign-1
# on ne copie juste sur les nouvelles lignes
If find(status,73,82)
   Gosub CHARG_TAB_CHGS From TRTCHGSERE
   Raz   [M:CHGS]QTYSTUDES    (I)
   Raz   [M:CHGS]SERNUM       (I)
   Raz   [M:CHGS]SERNUMF      (I)
Endif
If [M:CHGS]QTYSTUDES       (I) = 0
   [M:CHGS]QTYSTUDES       (I) = abs([M:CHGS]QTYSTU) - sum([M:CHGS]QTYSTUDES(0..[M:CHGS]NBLIG-1))
   If [M:CHGS]QTYSTUDES    (I) < 0
      [M:CHGS]QTYSTUDES    (I) = 0
   Endif
   Affzo [M:CHGS]QTYSTUDES (I)
Endif
End

Subprog C_NBLIG
Local Integer LRET
End
Case status
     When 65     :                       # Suppression d'une ligne
          If [M:CHGS]QTYSTUDES(nolign-1) <> 0 & [M:CHGS]WENR      (nolign-1) = 2
             Call DEL_STOSERW([M:CHGS]ITMREF,[M:CHGS]SERNUM(nolign-1),[M:CHGS]QTYSTUDES(nolign-1),LRET) From STKLIB
           Else
             mkstat = 2
          Endif

     When 68, 83 :                       # Suppression d'un groupe de lignes
          For I=nolign-1 To nolign1-1
              If [M:CHGS]QTYSTUDES(nolign-1) <> 0 & [M:CHGS]WENR      (nolign-1) = 2
                 Call DEL_STOSERW([M:CHGS]ITMREF,[M:CHGS]SERNUM(nolign-1),[M:CHGS]QTYSTUDES(nolign-1),LRET) From STKLIB
              Endif
          Next
     Endcase
     If LRET
        mkstat=2
     Endif

End


###########################################################################
Subprog C_QTYSTUDES(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL

NOL=nolign-1

# Le nb de no série ne correspond pas à la qté à traiter
If sum([M:CHGS]QTYSTUDES(0..[M:CHGS]NBLIG-1))-[M:CHGS]QTYSTUDES(NOL)+VALEUR > [M:CHGS]QTYSTU
   GMESSAGE = mess(246,199,1)
   mkstat=2 : End
Endif

End

##########################################################################
Subprog AM_QTYSTUDES(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL, WRET, WNBSER
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer LTYPLOC, LSTA
Local    Decimal WPCUDIS, WSTUDIS, WSTUACTDIS, WTOTACTDIS, WDISPO

NOL                  = nolign-1
[M:CHGS]MODFLG (NOL) = 2

# Il n'y a pas encore de no série saisi
If [M:CHGS]SERNUM(NOL)="" End Endif

# La quantité a diminué
If VALEUR < [M:CHGS]QTYSTUDES(NOL)
   WNBSER  = VALEUR
   WNUMDEB = [M:CHGS]SERNUM(NOL)
   If WNBSER=1
      [M:CHGS]SERNUMF(NOL) = WNUMDEB
   Else
      Call PLUS_NB(WNUMDEB,WNBSER,WNUMFIN,WRET) From STKLIB
      If WRET=0
         [M:CHGS]SERNUMF(NOL) = WNUMFIN
      Else
         mkstat=2
         GMESSAGE=WNUMDEB-":"-mess(476,197,1) # erreur sur incrementation des numeros de series
         End
      Endif
   Endif
   Affzo [M:CHGS]SERNUM(NOL), SERNUMF(NOL)
   End
Endif
# La quantité a augmentée
If VALEUR > [M:CHGS]QTYSTUDES(NOL)
   # Vérification que les no série existent et sont disponibles
   # pour le surplus et alimentation du no série fin
   WNBSER  = VALEUR-[M:CHGS]QTYSTUDES(NOL)
   WNUMDEB = [M:CHGS]SERNUMF(NOL)
   For J=1 To WNBSER
       Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
       If WRET=0
          Read [STS]STS0=[M:CHGS]ITMREF;WNUMFIN
          If fstat
             GMESSAGE=WNUMFIN-":"-mess(43,196,1) # numéro de série inexistant
             mkstat = 2
             Break
          Endif
          If [F:STS]ISSDAT<>[0/0/0]
             GMESSAGE=WNUMFIN-":"-mess(37,184,1)  # numéro de série sorti par une autre piece
             mkstat=2
             Break
          Endif
          If [F:STS]SDHNUM<>""
             GMESSAGE=WNUMFIN-":"-mess(443,184,1)  # numero de série alloué par une autre piece
             mkstat=2
             Break
          Endif
          If [F:STS]STOCOU<>[M:CHGS]STOCOU
             GMESSAGE=VALEUR-":"-mess(447,184,1) # numéro de série lié à une autre ligne de stock
             mkstat=2
             End
          Endif
          Gosub VERIF_STOCK
          If mkstat=2
             Break
          Endif
          WRET = func STKLIB.REC_STOSERW([M:CHGS]ITMREF,WNUMFIN)
          If WRET = 1
             GMESSAGE=WNUMFIN-":"-mess(449,184,1)  # numero de série en cours de traitement
             mkstat=2
             Break
          Endif
          WNUMDEB = WNUMFIN
       Else
          GMESSAGE=WNUMDEB-":"-mess(476,197,1) # erreur sur incrementation des numéros de serie
          mkstat=2
          Break
       Endif
   Next J
   If mkstat=2
      End
   Endif
   [M:CHGS]SERNUMF(NOL) = WNUMFIN
   Affzo [M:CHGS]SERNUM(NOL), SERNUMF(NOL)
Endif

End

##########################################################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL, J, WRET, WNBSERIE
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer LTYPLOC, LSTA
Local    Decimal WPCUDIS, WSTUDIS, WSTUACTDIS, WTOTACTDIS, WDISPO

NOL = nolign-1
WNUMDEB = VALEUR
WNUMFIN = VALEUR
      #--- Si le no série n'a pas déjà été saisi--- > controle
If VALEUR < [M:CHGS]WSERNUM | VALEUR > [M:CHGS]WSERNUMF
   Read [STS]STS0=[M:CHGS]ITMREF;WNUMFIN
   If fstat
      GMESSAGE=WNUMFIN-":"-mess(43,196,1) # numéro de série inexistant
      mkstat = 2
      End
   Endif
   If [F:STS]ISSDAT<>[0/0/0]
      GMESSAGE=VALEUR-":"-mess(37,184,1)  # numéro de série sorti par une autre piece
      mkstat=2
      End
   Endif
   If [F:STS]SDHNUM<>""
      GMESSAGE=VALEUR-":"-mess(443,184,1) # numero de série alloué par une autre piece
      mkstat=2
      End
   Endif
   If [F:STS]STOCOU<>[M:CHGS]STOCOU
      GMESSAGE=VALEUR-":"-mess(447,184,1) # numéro de série lié à une autre ligne de stock
      mkstat=2
      End
   Endif

   WRET = func STKLIB.REC_STOSERW([M:CHGS]ITMREF,WNUMFIN)
   If WRET = 1
      GMESSAGE=WNUMFIN-":"-mess(449,184,1)  # numero de série en cours de traitement
      mkstat=2
      End
   Endif
Endif

If [M:CHGS]QTYSTUDES(NOL)=1
   [M:CHGS]SERNUMF(NOL) = VALEUR
   [M:CHGS]MODFLG (NOL) = 2
Else
   # Vérification que les no série existent et sont disponibles
   # et alimentation du no série fin
   WNBSERIE = [M:CHGS]QTYSTUDES(NOL)
   WNUMDEB  = VALEUR
   For J=2 To WNBSERIE
       Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
       If WRET=0

      #--- Si le no série n'a pas déjà été saisi--- > controle
          If WNUMFIN < [M:CHGS]WSERNUM | WNUMFIN > [M:CHGS]WSERNUMF
             Read [STS]STS0=[M:CHGS]ITMREF;WNUMFIN
             If fstat
                GMESSAGE=WNUMFIN-":"-mess(43,196,1) # numéro de série inexistant
                mkstat = 2
                End
             Endif
             If [F:STS]ISSDAT<>[0/0/0]
                GMESSAGE=VALEUR-":"-mess(37,184,1)  # numéro de série sorti par une autre piece
                mkstat=2
             End
             Endif
             If [F:STS]SDHNUM<>""
                GMESSAGE=VALEUR-":"-mess(443,184,1) # numero de série alloué par une autre piece
                mkstat=2
                End
             Endif
             If [F:STS]STOCOU<>[M:CHGS]STOCOU
                GMESSAGE=VALEUR-":"-mess(447,184,1) # numéro de série lié à une autre ligne de stock
                mkstat=2
                End
             Endif
             Gosub VERIF_STOCK
             If mkstat=2
                Break
             Endif
             WRET = func STKLIB.REC_STOSERW([M:CHGS]ITMREF,WNUMFIN)
             If WRET = 1
                GMESSAGE=WNUMFIN-":"-mess(449,184,1)  # numero de série en cours de traitement
                mkstat=2
                Break
             Endif
          Endif
          WNUMDEB = WNUMFIN
       Else
          GMESSAGE=WNUMDEB-":"-mess(476,197,1) # erreur sur incrementation des numéros de serie
          mkstat=2
          Break
       Endif
   Next J
   If mkstat=2
      End
   Endif
   [M:CHGS]SERNUMF(NOL) = WNUMFIN
   [M:CHGS]MODFLG (NOL) = 2
Endif
Affzo [M:CHGS]SERNUMF(NOL)

End

$VERIF_STOCK

Return

