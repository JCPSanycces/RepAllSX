#<AdxTL>@(#)7.0.0.0 $Revision$
Infbox func PROX3("TCY","TCY.EECFLG")
End

Local Char WINS , WINF
WINS = "WREP"
WINF = "WREP.TCY"
GBIDC1 = func ASYRDELCLI.PATH_PROCOL(WINS,WINF)
Infbox GBIDC1
End

#---------------------------------------------------------------------------#
# Set classe representation with a delta from syracuse (classe ADELTA)
#---------------------------------------------------------------------------#

Subprog SET_REPRESENTATION(REP,WREP,UPD,ULN)
Variable Instance  REP      Using C_AREPENT
Variable Instance  WREP     Using OBJECT
Variable Instance  UPD(1..) Using C_ADELTA
Variable Instance  ULN(1..) Using C_ADELTALIN

Local Integer I , J , K , C , L , M , N, P , NUM
Local Integer ASTATUS , ERRSTA
Local Char    TEXTE(250) , CHAINE(250) , ERRMES(250)
Local Char    WINS(250) , WPRO(250) , WINF(250) , WRAC(250) , WFLD(50),INSPATH(250)
Local Clbfile CLOB
Local Blbfile  BLOB
Local Integer COUNT
Local Char    WVALUE(255) , TBLOO(30)(1..20) , CURPRO(250) , NAMCOL(250)
Local Integer ORD(1..) , UIDPOS(1..) , POS(1..) , NBO , NOL , NBK , NBR
Local Char    TBCOL(80)(1..30) , TBREF(30)(1..30) , TBPRO(30)(1..30)
Local Integer MAXGRI
MAXGRI = maxtab(REP.COL)+1
Local Char    TBGRI(80)(1..MAXGRI)
Local Integer TBONE(1..MAXGRI)
Local Integer NBR(1..30)
Local Uuident UIDREF , UIDCOL
Local Uuident UIDINS(1..) , UIDPAR(1..) , UUID
Local Integer COLIND(1..) , UIDIND(1..) , COLSYR(1..) , ORDINS(1..) , UIDORD(1..)
Local Char    COLNAM(30)(1..) , GRINAM(50)(1..)
Local Integer NBRUIDPAR , NBRCOLNAM , NBRUIDINS
Local Integer INDEX , NUMINS , NEWIND , REFIND
Local Char    REFCOL(50)
Local Char    ONEINS(80) , ONECOL(30)

Local  Char IDXUUID(250)(1..)
Local  Char IDXINS(250)(1..)
Local Integer IDXCOUNT

Gosub FIND_COLLECTION
Gosub FIND_REFERENCE
Gosub SORT_MODIF_UPD

Local Integer IATT
Local Char   ATTRIBUTE(250)

If GTRASYR : Gosub TRACE_RECEIVE_DELTA : Endif

# First loop for find instances in refreshed collection by Syracuse
For I=1 To NBO
 If UPD(POS(I))<>null & UPD(POS(I)).PRO<>func ASYRSUB.KILCOL & UPD(POS(I)).IND<0
  Gosub MEM_DELTA
 Endif
Next I



# Delete obsoletes instances in class collection refreshed

Gosub KIL_DELTA

# Insert & update instances

For I=1 To NBO
 If UPD(POS(I))<>null
  If UPD(POS(I)).PRO=func ASYRSUB.KILCOL
   # Delete all instances of collection
   Gosub DEL_DELTA
  Elsif UPD(POS(I)).IND>=0
   # Only one modifed instance
   INDEX = UPD(POS(I)).IND+1
   Gosub UPD_DELTA
  Else
   # All instances returned & inserted in order at the bottom
   INDEX = [V]CST_ALASTPOS
   Gosub SEA_DELTA
   Gosub UPD_DELTA
  Endif
 Endif
Next I

End

#------------------------------------------#
# Search order uuid
#------------------------------------------#

$SEA_DELTA
NEWIND = 0
If UPD(POS(I)).UIDPAR=NullUuid & UPD(POS(I)).COL=""
 Return
Endif
M = find(UPD(POS(I)).UID,UIDINS(1..NBRUIDINS))
If M
 NEWIND = UIDORD(M)
Endif
If GTRASYR : Call TRACE("sea delta uuid="+num$(UPD(POS(I)).UID)-"newind="+num$(NEWIND)) From ASYRCOM : Endif
Return

#-----------------------------------------------------#
# List of uuid by refreshed collection by Syracuse
#-----------------------------------------------------#

$MEM_DELTA
If UPD(POS(I)).UIDPAR=NullUuid & UPD(POS(I)).COL=""
 Return
Endif
P = find(UPD(POS(I)).UIDPAR,UIDPAR(1..NBRUIDPAR))
If !P
 NBRUIDPAR += 1
 P = NBRUIDPAR
 UIDPAR(P) = UPD(POS(I)).UIDPAR
Endif
L = 0
For J=1 To NBRCOLNAM
 If COLIND(J)=P & GRINAM(J)=UPD(POS(I)).COL
  #SAM 120089 ORDINS (J) += 1
  L = J : Break
 Endif
Next J
If !L
 NBRCOLNAM += 1
 L = NBRCOLNAM
 COLIND(L) = P
 COLSYR(L) = POS(I)
 Call COL_DELTA(WREP,REP,UPD(POS(I)).UIDPAR,UPD(POS(I)).COL,WINF,NAMCOL,IDXUUID,IDXINS,IDXCOUNT)
 COLNAM(L) = NAMCOL
 GRINAM(L) = UPD(POS(I)).COL
 #{SAM 120089 ORDINS(L) = 1
 ORDINS(L) = 0 :#SAM 120089}
Endif
M = 0
For J=1 To NBRUIDINS
 If UIDIND(J)=L & UIDINS(J)=UPD(POS(I)).UID
  M = J : Break
 Endif
Next J
If !M
 NBRUIDINS += 1
 M = NBRUIDINS
 UIDIND(M) = L
 ORDINS(L) += 1 #:SAM 120089
 UIDORD(M) = ORDINS(L)
 UIDINS(M) = UPD(POS(I)).UID
Endif
If GTRASYR : Call TRACE("mem-delta uidpar="+num$(UIDPAR(P))-"uid="+num$(UIDINS(M))-"ord="+num$(ORDINS(L))) From ASYRCOM : Endif
Return

#---------------------------------------------------------------------#
# Search collection with one property not reference (without $uuid)
#---------------------------------------------------------------------#

$FIND_COLLECTION
J = 0
For I=1 To MAXGRI
 If REP.COL(I)<>null
  J += 1
  TBGRI(J) = ctrans(REP.COL(I).GRI,".","")
  If REP.COL(I).NBR=1
   K = find(REP.COL(I).GRI,REP.PRO(1..maxtab(REP.PRO)).GRI)
   If K & REP.PRO(K).PLK<>2
    TBONE(J) = 2
   Endif
  Endif
 Endif
Next I
Return

#----------------------------------------#
# List of properties reference
#----------------------------------------#

$FIND_REFERENCE
NBR = 0
For I=1 To maxtab(REP.PRO)
 K = 0
 If REP.PRO(I)<>null & REP.PRO(I).PLK=2
  If REP.PRO(I).GRI<>""
   J = find(REP.PRO(I).GRI,REP.COL(1..maxtab(REP.COL)).GRI)
   If J & REP.COL(J).NBR=1
    K = 1
   Endif
  Endif
 Endif
 If K
  NBR += 1
  TBCOL(NBR) = ctrans(REP.PRO(I).GRI,".","")
  TBPRO(NBR) = REP.PRO(I).PRO
  L = find("$lookup",REP.PRO(I).LNK(1..maxtab(REP.PRO(I).LNK)).COD)
  If L
   Gosub LOOKUP_KEYS
   If CURPRO<>""
    TBREF(NBR) = CURPRO
   Else
    TBREF(NBR) = REP.PRO(I).PRO
   Endif
  Else
   TBREF(NBR) = REP.PRO(I).PRO
  Endif
 Endif
Next I
Return

#------------------------#
$LOOKUP_KEYS
NBK = 0
CURPRO = ""
For H=1 To maxtab(REP.PRO(I).LNK(L).CLE)
 If REP.PRO(I).LNK(L).CLE(H)<>null
  NBK += 1
  If REP.PRO(I).LNK(L).CLE(H).LOO<>""
   TBLOO(NBK) = REP.PRO(I).LNK(L).CLE(H).LOO
  Else
   TBLOO(NBK) = REP.PRO(I).LNK(L).CLE(H).PAR
  Endif
  If REP.PRO(I).LNK(L).CLE(H).PRO=REP.PRO(I).PRO
   CURPRO = TBLOO(NBK)
  Endif
 Endif
Next C
Return

#---------------------------------------------------------------------#
# Sort update by order of properties in representation class
#---------------------------------------------------------------------#

$SORT_MODIF_UPD
NBO = 0
For I=1 To maxtab(UPD)
 If UPD(I)<>null
  K = 0
  If UPD(I).PRO=func ASYRSUB.KILCOL : # Kill Collection
   For J=1 To maxtab(REP.PRO)
    If ctrans(REP.PRO(J).GRI,".","")=UPD(I).COL
     K = J : Break
    Endif
   Next J
  Elsif UPD(I).PRO="" & UPD(I).COL<>""
   For J=1 To maxtab(REP.PRO)
    If ctrans(REP.PRO(J).GRI,".","")=UPD(I).COL
     K = J : Break
    Endif
   Next J
  Elsif UPD(I).COL<>"" & UPD(I).PRO<>""
   If instr(1,UPD(I).COL,func ASYRJSO.REF)
    UPD(I).COL = REFCOL
    UPD(I).IND = REFIND
   Endif
   For J=1 To NBR
    If UPD(I).COL=TBCOL(J) & UPD(I).PRO=TBREF(J)
     UPD(I).PRO = TBPRO(J)
     If UPD(I).UIDPAR=NullUuid
      UPD(I).UIDPAR = UPD(I).UID
      UPD(I).UID = getUuid
     Endif
     Break
    Endif
   Next J
   K = find(UPD(I).PRO,REP.PRO(1..maxtab(REP.PRO)).PRO)
   If !K & UPD(I).PRO=UPD(I).COL
    For J=1 To maxtab(REP.PRO)
     If ctrans(REP.PRO(J).GRI,".","")=UPD(I).COL
      K = J
      UPD(I).PRO = REP.PRO(J).PRO
      UPD(I).IND = [V]CST_ALASTPOS
      UPD(I).UIDPAR = UPD(I).UID
      UPD(I).UID = getUuid
      Break
     Endif
    Next J
   Endif
   If !instr(1,UPD(I).COL,func ASYRJSO.REF)
    REFCOL = UPD(I).COL
    REFIND = UPD(I).IND
   Endif
  Elsif UPD(I).COL="" & UPD(I).PRO<>""
   For J=1 To NBR
    If UPD(I).COL=TBCOL(J) & UPD(I).PRO=TBREF(J)
     UPD(I).PRO = TBPRO(J)
     Break
    Endif
   Next J
   K = find(UPD(I).PRO,REP.PRO(1..maxtab(REP.PRO)).PRO)
  Endif
  If K
   NBO += 1
   POS(NBO) = I
   ORD(NBO) = K
   UIDPOS(NBO) = find(UPD(I).UID,UPD(1..maxtab(UPD)).UID)
  Endif
 Endif
Next I
Sorta NBO UIDPOS,ORD,POS Order By UIDPOS(indice+1),ORD(indice+1),POS(indice+1)
Return

#-------------------------------------------------#
# Kill obsolètes instances (not in delta)
#-------------------------------------------------#

$KIL_DELTA
Local Char WINS_NULL(250)(1..)
Local Integer WNC
Raz WINS_NULL

For I=1 To NBRUIDPAR
 For J=1 To NBRCOLNAM
  If COLIND(J)=I
   Call COL_DELTA(WREP,REP,UIDPAR(I),GRINAM(J),WINS,NAMCOL,IDXUUID,IDXINS,IDXCOUNT)
   If NAMCOL<>""
    If WINS=""
     WINS = "WREP"
    Endif
    If !find(WINS,WINS_NULL)
     If null = evalue(WINS) or null = evalue(WINS+"."+NAMCOL)
      WNC += 1 : WINS_NULL(WNC) = WINS+"."+NAMCOL
     Else
      For K=1 To evalue("maxtab("+WINS+"."+NAMCOL+")")
       If evalue(WINS+"."+NAMCOL+"("+num$(K)+")")<>null & !find(evalue(WINS+"."+NAMCOL+"("+num$(K)+").ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL)
        UUID = evalue(WINS+"."+NAMCOL+"("+num$(K)+").AUUID")
        If !find(UUID,UIDINS(1..NBRUIDINS))
         NUMINS = evalue(WINS+"."+NAMCOL+'('+num$(K)+').AORDER')
         CHAINE = 'fmet'-WINS+'.ADELLINE("'+NAMCOL+'",'+num$(NUMINS)+')'
         ASTATUS = evalue(CHAINE)
         If ASTATUS<[V]CST_AOK
          # Error delete
          NUMINS -= 1
          Call COM_DELTA(ULN,NAMCOL,UIDPAR(I),UUID,NUMINS,[V]CST_ADEL)
         Endif
        Endif
       Endif
      Next K
     Endif
     Endif
   Endif
  Endif
 Next J
Next I
Return

#---------------------------------------------------#
# Delete all instances of collection
#---------------------------------------------------#

$DEL_DELTA
Local Uuident UID

#TODO Call FIND_UUID_INSTANCE(WREP,UPD(POS(I)).UID,"",WINS) From ASYRUID
Call FIND_UUID_INSTANCE_EX2(WREP,REP,null,UPD(POS(I)).UID,"WREP",WINS,IDXUUID,IDXINS,IDXCOUNT) From ASYRUID
If len(WINS)
 Raz NAMCOL , WINF
 For J=1 To maxtab(REP.COL)
  If ctrans(REP.COL(J).GRI,".","")=UPD(POS(I)).COL
   NAMCOL = REP.COL(J).GRI
   For L=len(NAMCOL) To 1 Step -1
    If mid$(NAMCOL,L,1)="."
     WINF   = left$(NAMCOL,L-1)
     NAMCOL = right$(NAMCOL,L+1)
     Break
    Endif
   Next L
   Break
  Endif
 Next J
 If NAMCOL<>""
  WINF = func PATH_PROCOL(WINS,WINF)

  For J=1 To evalue("maxtab("+WINF+"."+NAMCOL+")")
   WINS = WINF+"."+NAMCOL+"("+num$(J)+")"
   If evalue(WINS)<>null & !find(evalue(WINS+".ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL)
    NUMINS = evalue(WINS+".AORDER")
    CHAINE = 'fmet'-WINF+'.ADELLINE("'+NAMCOL+'",'+num$(NUMINS)+')'
    ASTATUS = evalue(CHAINE)
    If ASTATUS<[V]CST_AOK
     # Not possible to delete
     NUMINS -= 1
     UID = evalue(WINS+".AUUID")
     Call COM_DELTA(ULN,UPD(POS(I)).COL,UPD(POS(I)).UID,UID,NUMINS,[V]CST_ADEL)
    Endif
   Endif
  Next J
 Endif
Endif
Return

#----------------------------------------------------------#
# Raz instance collection with one property not référence
#----------------------------------------------------------#

$RAZ_DELTA
K = 0
For J=1 To evalue("maxtab("+WINF+"."+NAMCOL+")")
 CHAINE = WINF+"."+NAMCOL+"("+num$(J)+")"
 If evalue(CHAINE)<>null & !find(evalue(CHAINE+".ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL)
  NUMINS = evalue(CHAINE+".AORDER")
  CHAINE = 'fmet'-WINF+'.ADELLINE("'+NAMCOL+'",'+num$(NUMINS)+')'
  ASTATUS = evalue(CHAINE)
  K += 1
 Endif
Next J
Return

#-----------------------------------#
# create/delete/update instances
#-----------------------------------#

$UPD_DELTA
Call COL_DELTA(WREP,REP,UPD(POS(I)).UIDPAR,UPD(POS(I)).COL,WINF,NAMCOL,IDXUUID,IDXINS,IDXCOUNT)
If len(WINF) & evalue(WINF)=null
 Gosub ONE_DELTA : # Create instance of classe 0,1
 If NUMINS<0
  # Not possible to insert
  Call COM_DELTA(ULN,UPD(POS(I)).COL,UPD(POS(I)).UIDPAR,UPD(POS(I)).UID,UPD(POS(I)).IND,[V]CST_ANEW)
  Return
 Endif
Endif
#TODO Call FIND_UUID_INSTANCE(WREP,UPD(POS(I)).UID,"",WINS) From ASYRUID
Call FIND_UUID_INSTANCE_EX2(WREP,REP,null,UPD(POS(I)).UID,"WREP",INSPATH,IDXUUID,IDXINS,IDXCOUNT) From ASYRUID

WINS = INSPATH
If WINS="WREP."+REP.ICL
 WINS = "WREP"
Endif
Call TRACE("upd_delta uid="+num$(UPD(POS(I)).UID)-"wins="+WINS-"uif="+num$(UPD(POS(I)).UIDPAR)-"winf="+WINF) From ASYRCOM
If NAMCOL<>""
 If WINS="" : # not found
  CHAINE = 'fmet'-WINF+'.ADDLINE("'+NAMCOL+'",'+num$(INDEX)+')'
  If GTRASYR : Call TRACE("asyrdelcli - create instance"-CHAINE) From ASYRCOM : Endif
  NUMINS = evalue(CHAINE)
  If NUMINS<0
   # Not possible to insert
   Call COM_DELTA(ULN,UPD(POS(I)).COL,UPD(POS(I)).UIDPAR,UPD(POS(I)).UID,UPD(POS(I)).IND,[V]CST_ANEW)
   Return
  Else
   WINS = WINF+"."+NAMCOL+"("+num$(NUMINS)+")"
   Assign WINS+".AUUID" With UPD(POS(I)).UID
  Endif
 Elsif func ATTRIBUTE(UPD(POS(I)).ATT,func ASYRSUB.CODATT("s"))=func ASYRSUB.BOOLEAN_TO_SYR(2) : # isDeleted=true
  NUMINS = evalue(WINS+".AORDER")
  CHAINE = 'fmet'-WINF+'.ADELLINE("'+NAMCOL+'",'+num$(NUMINS)+')'
  ASTATUS = evalue(CHAINE)
  If ASTATUS<[V]CST_AOK
   # Not possible to delete
   Call COM_DELTA(ULN,UPD(POS(I)).COL,UPD(POS(I)).UIDPAR,UPD(POS(I)).UID,UPD(POS(I)).IND,[V]CST_ADEL)
  Endif
  Return
 Endif
Endif
If WINS=""
 Return
Endif
# Update order
If INDEX>0 & evalue(WINS+".AORDER")<>INDEX
 If GTRASYR : Call TRACE("update order="+num$(INDEX)-"wins="+WINS-"uuid="+num$(evalue(WINS+".AUUID"))) From ASYRCOM : Endif
 Assign WINS+".AORDER" With INDEX
Elsif NEWIND>0 & evalue(WINS+".AORDER")<>NEWIND
 If GTRASYR : Call TRACE("update new order="+num$(NEWIND)-"wins="+WINS-"uuid="+num$(evalue(WINS+".AUUID"))) From ASYRCOM : Endif
 Assign WINS+".AORDER" With NEWIND
Endif
# Update property
If UPD(POS(I)).PRO<>""
 WPRO = func PATH_PROCOL(WINS,REP.PRO(ORD(I)).PTH)
 If evalue("dim("+WPRO+")")>0
  ERRMES = ""
  ERRSTA = CST_AOK

  Case REP.PRO(ORD(I)).TYP
   When 9 : # Blob is in easyloading

    CLOB   = func ASYRSUB.AGETCHR(UPD(POS(I)).CHR)
    If CLOB <> "null"
     CLOB   = seg$(CLOB,2,len(CLOB)-1)
     COUNT = b64Decode(CLOB, BLOB)
    Else
     Raz BLOB
    Endif
    Assign WPRO With BLOB

    # set attributes :
    For IATT=1 To maxtab(UPD(POS(I)).ATT)
     ATTRIBUTE = seg$(UPD(POS(I)).ATT(IATT).ATT,2,len(UPD(POS(I)).ATT(IATT).ATT)-1)
     ASTATUS   = evalue( 'fmet '+INSPATH+'.ASETATTRIBUTE("'+UPD(POS(I)).PRO+'","'+UPD(POS(I)).ATT(IATT).COD + '","'+ATTRIBUTE + '" )')
    Next IATT
   When Default
    CLOB = func ASYRSUB.AGETCHR(UPD(POS(I)).CHR)
    If (left$(CLOB,1)='"' & right$(CLOB,len(CLOB))='"') or (left$(CLOB,1)="'" & right$(CLOB,len(CLOB))="'")
     WVALUE = seg$(CLOB,2,len(CLOB)-1)
    Else
     WVALUE = CLOB
    Endif
    # Control internal type of data from json
    ERRSTA = func ASYRSUB.CONTROL_TYP(evalue("type("+WPRO+")"),REP.PRO(ORD(I)).TYP,REP.PRO(ORD(I)).LNG,WVALUE,ERRMES)
    If ERRSTA<>CST_AOK
     # Return the same value before update
     Assign WPRO With evalue(WPRO)
    Else
     Case REP.PRO(ORD(I)).TYP
      When 1     : Assign WPRO With func ASYRSUB.BOOLEAN_TO_ADX(WVALUE)
      When 2,3,4 : Assign WPRO With val(WVALUE)
      When 5     : Assign WPRO With func ASYRSUB.DATE_TO_ADX(WVALUE)
      When 6     : Assign WPRO With func ASYRSUB.TIME_TO_ADX(WVALUE)
      When 7     : Case evalue("type("+WPRO+")")
                    When 525
                     Assign WPRO With func ASYRSUB.UUID_TO_ADX(WVALUE)
                    When Default
                     #TEXTE = func ASYRSUB.STRING_TO_ADX(WVALUE)
                     If WVALUE=func ASYRSUB.SYR_NULL
                      TEXTE = ""
                     Else
                      TEXTE = WVALUE
                     Endif
                     Assign WPRO With TEXTE
                   Endcase
      When 8     : # Clob if in the data json (todo)
      When 10    : Assign WPRO With val(WVALUE)
      When 11    : Assign WPRO With func ASYRSUB.DATETIME_TO_ADX(WVALUE)
      When 25    : If WVALUE=func ASYRSUB.SYR_NULL
                    TEXTE = ""
                    NUM = 0
                   Else
                    K = instr(1,WVALUE,"~")
                    If K
                     #TEXTE = func ASYRSUB.STRING_TO_ADX(left$(WVALUE,K-1))
                     TEXTE = left$(WVALUE,K-1)
                     NUM   = val(right$(WVALUE,K+1))
                    Else
                     #TEXTE = func ASYRSUB.STRING_TO_ADX(WVALUE)
                     TEXTE = WVALUE
                     NUM   = func NUMERO(TEXTE)
                    Endif
                   Endif
                   WRAC = func ASYRDATDET.PREFIX_INSTANCE(WPRO)
                   WFLD = func ASYRDATDET.FINAL_INSTANCE(WPRO)
                   CHAINE = 'fmet'-WRAC+'.ASETTEXT("'+WFLD+'",TEXTE,'+num$(NUM)+')'
                   ASTATUS = evalue(CHAINE)
                   Assign WPRO With NUM : # For active event
      When 26    : If WVALUE=func ASYRSUB.SYR_NULL
                    TEXTE = ""
                   Else
                    #TEXTE = func ASYRSUB.STRING_TO_ADX(WVALUE)
                    TEXTE = WVALUE
                   Endif
                   WRAC = func ASYRDATDET.PREFIX_INSTANCE(WPRO)
                   WFLD = func ASYRDATDET.FINAL_INSTANCE(WPRO)
                   CHAINE = 'fmet'-WRAC+'.ASETTEXTRA("'+WFLD+'",TEXTE)'
                   ASTATUS = evalue(CHAINE)
                   Assign WPRO With TEXTE : # For active event
     Endcase
    Endif
  Endcase
  If ERRSTA<>CST_AOK
   WRAC = func ASYRDATDET.PREFIX_INSTANCE(WPRO)
   WFLD = func ASYRDATDET.FINAL_INSTANCE(WPRO)
   CHAINE = 'fmet '+WRAC+'.ASETERROR("'+WFLD+'","'+func ASYRSUB.STRING_TO_SYR(ERRMES)+'",'+num$(ERRSTA)+')'
   If GTRASYR : Call TRACE("chaine="+CHAINE) From ASYRCOM : Endif
   ASTATUS = evalue(CHAINE)
  Endif
 Endif
Endif
Return

#-------------------------------------#
# Create instance of class 0,1
#-------------------------------------#

$ONE_DELTA
Raz ONEINS , ONECOL
NUMINS = -1
If right$(WINF,len(WINF))<>")"
 For J=len(WINF) To 1 Step -1
  If mid$(WINF,J,1)="."
   ONEINS = left$(WINF,J-1)
   ONECOL = right$(WINF,J+1)
   Break
  Endif
 Next J
Endif
If ONEINS<>"" & ONECOL<>""
 NUMINS = evalue('fmet'-ONEINS+'.ADDLINE("'+ONECOL+'",'+num$([V]CST_ALASTPOS)+')')
Endif
Return

#----------------------------------------------#
# Uncommitted lines of collection
#----------------------------------------------#

Subprog COM_DELTA(ULN,COL,UIDPAR,UID,IND,EVT)
Variable Instance ULN(1..) Using C_ADELTALIN
Value    Char     COL
Value    Uuident  UIDPAR
Value    Uuident  UID
Value    Integer  IND
Value Integer EVT
Local Integer I
I = maxtab(ULN)+1
ULN(I) = NewInstance [ULN] With C_ADELTALIN
ULN(I).COL    = COL
ULN(I).UIDPAR = UIDPAR
ULN(I).UID    = UID
ULN(I).IND    = IND
ULN(I).EVT    = [L]EVT
If GTRASYR : Call TRACE("uncommit col="+COL-"uid="+num$(UID)-"uif="+num$(UIDPAR)-"ind="+num$(IND)-"evt="+num$(EVT)) From ASYRCOM : Endif
End

#--------------------------------------------------#
# uuid -> name of instance parent & name collection
#--------------------------------------------------#

Subprog COL_DELTA(WREP,REP,UIF,COL,WINF,NAMCOL,IDXUUID,IDXINS,IDXCOUNT)
Variable Instance WREP Using OBJECT
Variable Instance REP  Using C_AREPENT
Value    Uuident  UIF
Value    Char     COL
Variable Char     WINF
Variable Char     NAMCOL
Variable Char IDXUUID()
Variable Char IDXINS()
Value Integer IDXCOUNT

Local Char    TBINS(30)(1..10) , TBCOL(30)(1..30)
Local Integer NBINS , NBCOL
Local Char    CHAINE(250)
Local Integer I , J , K
If UIF=NullUuid
 WINF = "WREP"
Else
 #Call FIND_UUID_INSTANCE(WREP,UIF,"",WINF) From ASYRUID
 Call FIND_UUID_INSTANCE_EX2(WREP,REP,null,UIF,"WREP",WINF,IDXUUID,IDXINS,IDXCOUNT) From ASYRUID

 If WINF="" : NAMCOL = "" : End : Endif : # mb 13.11.13 bug mobile 93366
 If WINF="WREP."+REP.ICL
  WINF = "WREP"
 Endif
Endif
If COL<>""
 K = 0
 For I=1 To maxtab(REP.COL)
  If REP.COL(I)<>null & ctrans(REP.COL(I).GRI,".","")=COL
   K = I : Break
  Endif
 Next I
 If K
  Call DEC_DELTA(REP.COL(K).GRI,TBCOL,NBCOL)
  CHAINE = WINF
  If left$(CHAINE,5)="WREP."
   CHAINE = right$(CHAINE,6)
  Elsif CHAINE="WREP"
   CHAINE = ""
  Endif
  Call DEC_DELTA(CHAINE,TBINS,NBINS)
  K = 0
  For J=1 To max(NBCOL,NBINS)
   If TBINS(J)="" or TBCOL(J)=""
    Break
   Elsif TBINS(J)<>TBCOL(J)
    Break
   Endif
   K = J
  Next J
  For J=1+K To NBCOL-1
   WINF += "."+TBCOL(J)
  Next J
  NAMCOL = TBCOL(NBCOL)
 Endif
Endif
End

#-------------------------------#
Subprog DEC_DELTA(PATH,INS,NB)
Value    Char    PATH
Variable Char    INS()(1..)
Variable Integer NB
Local Char CHAINE(250) , CHAINE2(250)
Local Integer K
CHAINE = PATH
NB = 0
While CHAINE<>""
 K = instr(1,CHAINE,".")
 If K
  CHAINE2 = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  CHAINE2 = CHAINE
  CHAINE = ""
 Endif
 K = instr(1,CHAINE2,"(")
 If K
  CHAINE2 = left$(CHAINE2,K-1)
 Endif
 NB += 1
 INS(NB) = CHAINE2
Wend
End

#---------------------------------#
# Search attribute
#---------------------------------#

Funprog ATTRIBUTE(ATT,COD)
Variable Instance ATT(1..) Using C_ADELTAATT
Value Char    COD
Local Integer A
Local Char    VALATT(80)
VALATT = ""
For A=1 To maxtab(ATT)
 If ATT(A)<>null
  If ATT(A).COD=[L]COD
   VALATT = ATT(A).ATT : Break
  Endif
 Endif
Next A
End VALATT

#------------------------------------------------------------------------------------------#
# Find a number of text (for avoid duplication - to wait for pop-up syracuse)
#------------------------------------------------------------------------------------------#

Funprog NUMERO(TEXTE)
Value Char TEXTE
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
Read [ATX]TEXTE = GACTX.LAN;TEXTE
If !fstat
 End [F:ATX]NUMERO
Else
 Read [ATX]NUMERO = GACTX.AFOLD.ALANGDEF;TEXTE
 If !fstat
  End [F:ATX]NUMERO
 Endif
Endif
End 0

#---------------------------------------------------------------#
# Instance by uid Syracuse + path metadata -> path of instance
#---------------------------------------------------------------#

Funprog PATH_PROCOL(INS,PTH)
Value Char INS , PTH
Local Char    WPRO(250) , WINS(250) , WRAC(50)
Local Char    CHAINE(250)
Local Char    TBINS(30)(1..20)
Local Integer TBIND(1..20)
Local Integer I , J , K
If INS="WREP"
 WRAC = "WREP"
 WINS = INS
Elsif left$(INS,5)="WREP."
 WRAC = "WREP"
 WINS = right$(INS,6)
Endif
I = 0
While WINS<>""
 K = instr(1,WINS,".")
 If K
  CHAINE = left$(WINS,K-1)
  WINS = right$(WINS,K+1)
 Else
  CHAINE = WINS
  WINS = ""
 Endif
 I += 1
 K = instr(1,CHAINE,"(")
 If K
  TBIND(I) = val(right$(CHAINE,K+1))
  TBINS(I) = left$(CHAINE,K-1)
 Else
  TBIND(I) = -1
  TBINS(I) = CHAINE
 Endif
Wend
WPRO = PTH
K = 1
For J=1 To I
 K = instr(K,WPRO,".")
 If TBIND(J)>=0 & K
  CHAINE = '('+num$(TBIND(J))+')'
  WPRO = left$(WPRO,K-1)+CHAINE+right$(WPRO,K)
  K += len(CHAINE)
 Endif
 K += 1
Next J
If WRAC<>"" & WRAC<>WPRO & left$(WPRO,len(WRAC)+1)<>WRAC+"."
 If WPRO<>""
  WPRO = WRAC+"."+WPRO
 Else
  WPRO = WRAC
 Endif
Endif
End WPRO

#--------------------------------------------------------------------------#
# Miscellaneous programs
#--------------------------------------------------------------------------#

$TRACE_RECEIVE_DELTA
Call TRACE("asyrdelcli-receive-delta"-"MAXTAB(upd)="+num$(maxtab(UPD))) From ASYRCOM

$TRACE
For I=1 To maxtab(UPD)
 WCHAINE = "col="+UPD(I).COL-"cat="+num$(UPD(I).CAT)-"pro="+UPD(I).PRO-"ind="+num$(UPD(I).IND)
 WCHAINE -= "uuid="+num$(UPD(I).UID)-"uuif="+num$(UPD(I).UIDPAR)
 If UPD(I).CHR<>null
  If len(func ASYRSUB.AGETCHR(UPD(I).CHR))>30
   Call TRACE(WCHAINE) From ASYRCOM
   WCHAINE = "value="+func ASYRSUB.AGETCHR(UPD(I).CHR)
  Else
   WCHAINE -= "value="+func ASYRSUB.AGETCHR(UPD(I).CHR)
  Endif
 Endif
 Call TRACE(WCHAINE) From ASYRCOM
 For J=1 To maxtab(UPD(I).ATT)
  Call TRACE("att"-UPD(I).ATT(J).COD-"value="+UPD(I).ATT(J).ATT) From ASYRCOM
 Next J
 For J=1 To maxtab(UPD(I).ERR)
  Call TRACE("err"-UPD(I).ERR(J).MES-"sta="+num$(UPD(I).ERR(J).STA)-"num="+num$(UPD(I).ERR(J).NUM)) From ASYRCOM
 Next J
Next I
Call TRACE("end data") From ASYRCOM
Return

