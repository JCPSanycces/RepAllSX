#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
# UTIGPA22  Module GPAO     Table MFGMAT,  Initialisation du champ WGGBOX         #
# soumis au code activité MWM ( centrale de pesée)                                #
###################################################################################
# mm 10.10: évolution pesée par matière (spec. 001)                               #
###################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "X3INDV6" Then
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      Read [ADS]DOSSIER=[L]DOSSIER
      If fstat Then
        Raz [F:ADS]
      Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("UTIGPA22: Update field of MFGMAT table") From LECFIC
      Call MAJ_UTIGPA22(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
 Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIGPA22: Update fields of MFGMAT table") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTIGPA22(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
# Initialisation du champ [F:MFM]WGGBOX, ce champ est soumis
# à code activité
##########################################################################
Subprog MAJ_UTIGPA22(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTIGPA22: Process Start on : "+DOSSIER, 0) From GESECRAN

If filinfo(filpath("FIL","MFGMAT","fde",DOSSIER),0) <= 0     End Endif
#----- Ouverture des fichiers -----#
If clalev([F:HSH])  =0  Local File =DOSSIER+".MFGMAT"       [MFM] : Endif

If dim ([F:MFM]WGGBOX) >0
  Call DEBTRANS From GLOCK
  Trbegin [MFM]
  Update [MFM] Where WGGBOX = 0  With WGGBOX = 1         # & PKC >1 & PKC <4  : à tester une fois la démo passée, voir gestion WGGSTA
  Commit
Endif

Close Local File [MFM]


End
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIGPA22(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTIGPA22(APPLI)
End
