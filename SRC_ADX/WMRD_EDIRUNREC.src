#<AdxTL>@(#)0.0.0.0 $Revision$Class EDI inbound msg. generation
# Supervisor
## CRUD-CLASSE ## EDIRUNREC
# 2018-10-17 07:54:26 798


############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EDIRUNREC,ASTATUS)
Variable Instance EDIRUNREC Using R_EDIRUNREC
Variable Integer ASTATUS

If EDIRUNREC = null : End : Endif

Gosub AVARIABLES From WMR00EDIRUNREC
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

If fmet EDIRUNREC.ACTX.AGETAFCRIGHT(EDIRUNREC,"EDIRUNREC",[V]CST_ATRUE)>=[V]CST_AERROR : [L]ASTATUS=[V]CST_AERROR : Goto ADELETE_END : Endif
If fmet EDIRUNREC.ACTX.AGETAFCRIGHTD(EDIRUNREC,"EDIRUNREC",[L]A_STRSITE,[V]CST_ATRUE)>=[V]CST_AERROR
 [L]ASTATUS=[V]CST_AERROR : Goto ADELETE_END
Endif

Gosub AREPCONTROL_ADELETE
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EDIRUNREC
Else
 Gosub ADELETE_EDIRUNREC
Endif
If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_END : Return : Endif

$ADELETE_END
End

#-----------------------------------------------------#
$AREPCONTROL_ADELETE
EDIRUNREC.ASTALIN = [V]CST_ADEL
EDIRUNREC.EDR.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EDIRUNREC.EDR,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EDIRUNREC.EDR.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDIRUNREC.EDR.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIRUNREC.EDR.EDRD) : # EDIRUND -- 2
 If EDIRUNREC.EDR.EDRD(A_N2) <> null
& and EDIRUNREC.EDR.EDRD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIRUNREC.EDR.EDRD(A_N2).ASTALIN<>[V]CST_ANEW
   EDIRUNREC.EDR.EDRD(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR.EDRD(A_N2).ACTION("ADELETE_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER
For A_N2=1 To maxtab(EDIRUNREC.EDR.EDRD) : # EDIRUND -- 2
 If EDIRUNREC.EDR.EDRD(A_N2) <> null
& and EDIRUNREC.EDR.EDRD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR.EDRD(A_N2).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EDIRUNREC
Trbegin [F:EDR]
 Gosub ADELETE_EDIRUNREC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
$_ADELETE_AFTER
Return

#-----------------------------------------------------#
$ADELETE_EDIRUNREC
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR._ADELETE)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EDIRUNREC.snapshotEnabled=1
 [L]A_RETIK = EDIRUNREC.revertUpdTick
Endif
[L]ASTATUS = max(fmet EDIRUNREC.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#



