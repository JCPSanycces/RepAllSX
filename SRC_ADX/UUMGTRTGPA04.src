#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UUMGTRTGPA04   Squelette pour Moulinette de Migration      Module GPAO #
#                                                                        #
#          Update of field CCE stored in [F:CAL]                         #
#                                                                        #
##########################################################################
# Extrait de GPAMAJ30                                                    #
#   - $MTK   : Update of MTK tables  Insert rows into CPTANALIN          #
#              MFGHEADTRK [F:MTK]                                        #
#              MFGITMTRK  [F:MKI]                                        #
#              MFGMATTRK  [F:MKM]                                        #
#              MFGOPETRK  [F:MKO]                                        #
##########################################################################
# Issues 80101 & 80102 & get VERSION number - GA 02/2012
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(WDOSSIER,"") From SAIDOS
Endif
If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=[L]WDOSSIER : If fstat Raz [F:ADS] : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTGPA04") From LECFIC
  Endif

  #Call RAZ_UUMGTRTGPA04(WDOSSIER)
  Call MAJ_UUMGTRTGPA04(WDOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(WDOSSIER)
Value Char    WDOSSIER
If WDOSSIER=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=WDOSSIER : If fstat Raz [F:ADS] : Endif
Call MAJ_UUMGTRTGPA04(WDOSSIER)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (WDOSSIER)
Value Char    WDOSSIER
If WDOSSIER=GDOSX3 End : Endif
Call MAJ_UUMGTRTGPA04(WDOSSIER)
End

##########################################################################
Subprog MAJ_UUMGTRTGPA04(WDOSSIER)
Value Char WDOSSIER

GOK=1
Gosub UPDMTK
If GOK<=0
    Call ECR_TRACE("UUMGTRTGPA04 table MFGHEADTRK Incorrectly Processed : Update MTK"-WDOSSIER,1) From GESECRAN
Endif

End


##########################################################################
Subprog RAZ_UUMGTRTGPA04(WDOSSIER)
Value Char WDOSSIER

#Local Integer ERR
  Call RAZ_UUMGTRTGPA04_FIC(WDOSSIER,"MFGITMTRK" ,"MKI")
  Call RAZ_UUMGTRTGPA04_FIC(WDOSSIER,"MFGMATTRK" ,"MKM")
  Call RAZ_UUMGTRTGPA04_FIC(WDOSSIER,"MFGOPETRK" ,"MKO")

  Call RAZ_UUMGTRTGPA04_FIC(WDOSSIER,"MFGHEADTRK","MTK")
End

##########################################################################
$UPDMTK
Local Integer ERR

GOK=1
##1 - verifications
####################

If [F:ADS]MODULE(7)<>2    # N= no module - 1    7=>GPAO
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA04",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

#----- Is new file ok ? ...  -----#
If  filinfo(filpath("FIL","MFGHEADTRK","fde",WDOSSIER),0) <=0
& | filinfo(filpath("FIL","MFGITMTRK" ,"fde",WDOSSIER),0) <=0
& | filinfo(filpath("FIL","MFGMATTRK" ,"fde",WDOSSIER),0) <=0
& | filinfo(filpath("FIL","MFGOPETRK" ,"fde",WDOSSIER),0) <=0
& | filinfo(filpath("FIL","CPTANALIN" ,"fde",WDOSSIER),0) <=0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA04",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

Local Char WNAMFICM,WNAMFICM_I,WNAMFICM_M,WNAMFICM_O
Call MIGTABNAME (WDOSSIER,"MFGHEADTRK",WNAMFICM  ,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA04",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif
Call MIGTABNAME (WDOSSIER,"MFGITMTRK" ,WNAMFICM_I,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA04",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif
Call MIGTABNAME (WDOSSIER,"MFGMATTRK" ,WNAMFICM_M,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA04",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif
Call MIGTABNAME (WDOSSIER,"MFGOPETRK" ,WNAMFICM_O,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA04",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif

#----- Is old renamed file ok ?...  -----#
If  filinfo(filpath("FIL",WNAMFICM  ,"fde",WDOSSIER),0) < 0
& | filinfo(filpath("FIL",WNAMFICM_I,"fde",WDOSSIER),0) < 0
& | filinfo(filpath("FIL",WNAMFICM_M,"fde",WDOSSIER),0) < 0
& | filinfo(filpath("FIL",WNAMFICM_O,"fde",WDOSSIER),0) < 0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA04",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA04",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (WDOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrect
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA04",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

###################
Call ECR_TIME("UUMGTRTGPA04 table MFGHEADTRK Process : Update MTK") From DOSSUB
Call ECR_TRACE("UUMGTRTGPA04 : Process Start on : "+WDOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (WDOSSIER,"MFGHEADTRK",ERR) From TRTMIG
Call MIGTABINIT (WDOSSIER,"MFGITMTRK" ,ERR) From TRTMIG
Call MIGTABINIT (WDOSSIER,"MFGMATTRK" ,ERR) From TRTMIG
Call MIGTABINIT (WDOSSIER,"MFGOPETRK" ,ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABINIT (WDOSSIER,"CPTANALIN" ,ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:MTK])  = 0 : Local File =WDOSSIER+".MFGHEADTRK"   [MTK]  : Endif   # Fichier X3 "Vide"
If clalev([F:MKI])  = 0 : Local File =WDOSSIER+".MFGITMTRK"    [MKI]  : Endif   # Fichier X3 "Vide"
If clalev([F:MKM])  = 0 : Local File =WDOSSIER+".MFGMATTRK"    [MKM]  : Endif   # Fichier X3 "Vide"
If clalev([F:MKO])  = 0 : Local File =WDOSSIER+".MFGOPETRK"    [MKO]  : Endif   # Fichier X3 "Vide"
If clalev([F:CAL])  = 0 : Local File =WDOSSIER+".CPTANALIN"    [CAL]  : Endif   # Fichier X3 V6 à compléter

If clalev([F:MTKM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM    [MTKM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:MKIM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM_I  [MKIM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:MKMM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM_M  [MKMM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:MKOM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM_O  [MKOM] : Endif   # Fichier X3 renommé Avant Migration
Local Char WMFGFCY(GLONFCY) : WMFGFCY=""

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, NBCOMMIT, ISVALID, NBLUS, NBTOT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30) # Issue 80101 ajout HINTSPE
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, NBTOT, STOP, CRITERE

# Déclaration des variables communes de travail
Local Integer I, J
Local Integer NB_MKI,NB_MKM,NB_MKO
Local Char WCRIT_MKI(250) : WCRIT_MKI="1=1"
Local Char WCRIT_MKM(250) : WCRIT_MKM="1=1"
Local Char WCRIT_MKO(250) : WCRIT_MKO="1=1"
# pour les WriteB des tables détails (!! adxwrb is initialized in TRTMIG.MIG_OUVRE)
Local Char WTAB_MTK (100) (adxwrb)
Local Shortint WCPT_MTK
Local Char WTAB_MKI (100) (adxwrb)
Local Char WTAB_MKM (100) (adxwrb)
Local Char WTAB_MKO (100) (adxwrb)
Local Char WTAB_CAL (100) (adxwrb)
Local Shortint WCPT_MKI, WCPT_MKM, WCPT_MKO, WCPT_CAL

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (WDOSSIER,"UUMGTRTGPA04",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

# PE pour ajout clause where
# ATTENTION: en dernier la clause sur MTK réutilisée juste après
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTGPA04" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

# Issue 80145 Key=MFGFCY+MFGTRKNUM
Filter [F:MTKM] Order By Key CLE=[F:MTKM]MFGFCY;[F:MTKM]MFGTRKNUM

$LOOP_MTK00
Raz NB
# Clé optimisée migration: MFGFCY/MFGTRKNUM
If STOP = 1
 STOP = 2
 CRITERE = "[F:MTKM]MFGFCY=TABMIGKEY(1) & [F:MTKM]MFGTRKNUM>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:MTKM]MFGFCY>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [MTK],[MKI],[MKO],[MKM],[CAL]
GOK = 1

# Issue 80145 Key=MFGFCY+MFGTRKNUM instead of MTK0
For [MTKM]CLE Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS += 1

  If [F:MTKM]MFGFCY<>WMFGFCY
     WMFGFCY=[F:MTKM]MFGFCY
     Gosub CHARGE_PARAM
  Endif
  Raz NB_MKI,NB_MKM,NB_MKO

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTGPA04" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_MTK : Endif
  Endif

  #Raz [F:MTK]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_MTK
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_MTK
  Endif

  [F:MTK] = [F:MTKM]

  If val(VERSION)<GMIGX3VER60  #Appel proc de migration sur entete
    Gosub MAJV6_MTK
    If GOK<1 : Break : Endif
  Endif

  If val(VERSION)<GMIGX3VER60 | val(VERSION)<GMIGX3VER70  #Appel proc de migration V6 et V7 sur tables détails
  # 1er détail: MKI+CAL
    Gosub UPDMTK_MKI
    If GOK<1 : Break : Endif

  # 2eme détail: MKM+CAL
    Gosub UPDMTK_MKM
    If GOK<1 : Break : Endif

  # 3eme détail: MKO+CAL
    Gosub UPDMTK_MKO
    If GOK<1 : Break : Endif
  Endif

  # --- alimentation des champs et écriture enreg
  Gosub MTK_STK : # pour stocker ref
  WriteB [F:MTK]
  If fstat
      Call ECR_TRACE("File MFGHEADTRK, Error ="-num$(fstat),1) From GESECRAN
      Gosub MTK_ERRTRA : # pour afficher les ref
      GOK=0 : Break
  Endif

  NB+=1
  NBTOT+=(1+NB_MKI+NB_MKM+NB_MKO)    # Comptage des lignes détail
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:MTKM]MFGFCY
    TABMIGKEY(2) = [F:MTKM]MFGTRKNUM
    STOP=1
    Break
  Endif
$NEXT_MTK
Next

$END_MTK
If GOK<1
  Rollback
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA04",7,ERR) From TRTMIG : #7=Erreur
Else
    Flush [F:MTK]
    If fstat
        Call ECR_TRACE("File MFGHEADTRK, Error ="-num$(fstat),1) From GESECRAN
        Gosub MTK_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_MTK : #on part sur rollback
    Endif
    Flush [F:MKI]
    If fstat
        Call ECR_TRACE("File MFGITMTRK, Error ="-num$(fstat),1) From GESECRAN
        Gosub MKI_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_MTK : #on part sur rollback
    Endif
    Flush [F:MKM]
    If fstat
        Call ECR_TRACE("File MFGMATTRK, Error ="-num$(fstat),1) From GESECRAN
        Gosub MKM_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_MTK : #on part sur rollback
    Endif
    Flush [F:MKO]
    If fstat
        Call ECR_TRACE("File MFGOPETRK, Error ="-num$(fstat),1) From GESECRAN
        Gosub MKO_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_MTK : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
        GOK=0 : Goto END_MTK : #on part sur rollback
    Endif
    If STOP
      TABMIGKEY(NBMIGKEY)=num$(STOP)
    Else
      Raz TABMIGKEY
    Endif
    # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
    Call MIGSTKKEY (WDOSSIER,"UUMGTRTGPA04",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
    If ERR
     GOK=-1 : Goto END_MTK
    Endif
    Commit
    NBCOMMIT+=NB
    Call MIGSTKPROGRESS (WDOSSIER,"UUMGTRTGPA04",STOP,ERR) From TRTMIG
    If STOP
      Goto LOOP_MTK00
    Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [MTK]
Close Local File [MKI]
Close Local File [MKM]
Close Local File [MKO]
Close Local File [MTKM]
Close Local File [MKIM]
Close Local File [MKMM]
Close Local File [MKOM]
Close Local File [CAL]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (WDOSSIER,"MFGHEADTRK",ERR) From TRTMIG
Call MIGTABEND (WDOSSIER,"MFGITMTRK" ,ERR) From TRTMIG
Call MIGTABEND (WDOSSIER,"MFGMATTRK" ,ERR) From TRTMIG
Call MIGTABEND (WDOSSIER,"MFGOPETRK" ,ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABEND (WDOSSIER,"CPTANALIN" ,ERR) From TRTMIG
Call MIGTRTEND (WDOSSIER,"UUMGTRTGPA04") From TRTMIG
Call ECR_TIME("UUMGTRTGPA04:"+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

##########################################################################
$RAZV6_MTK
  Raz [F:MTK]WRHE      # V6 new Field
Return
$RAZV6_MKI
  Raz [F:MKI]WRH       # V6 new Field
Return
$RAZV6_MKM
  #Raz [F:MKM]CPNTYP    # V6 new Field
  Raz [F:MKM]PJT       # V6 new Field
  Raz [F:MKM]WRH       # V6 new Field
Return
$RAZV6_MKO
  Raz [F:MKO]IPTDAT    # V6 new Field
  Raz [F:MKO]STDOPENUM # V6 new Field
  Raz [F:MKO]PJT       # V6 new Field
Return

##########################################################################
$RAZV7_MTK
Return
$RAZV7_MKI
Return
$RAZV7_MKM
Return
$RAZV7_MKO
Return

##########################################################################
$UPDMTK_MKI

# Transaction déjà démarrée
GOK = 1
For [MKIM]MKI0 Where MFGFCY=[F:MTK]MFGFCY & MFGTRKNUM=[F:MTK]MFGTRKNUM
&                    & evalue(WCRIT_MKI)

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTGPA04/MKI" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_MKI : Endif
  Endif
  #Raz [F:MKI]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_MKI
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_MKI
  Endif

  [F:MKI] = [F:MKIM]

  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_MKI
    If GOK<1 : Break : Endif

    Gosub MAJV6_MKI_CAL
    If GOK<1 : Break : Endif
  Endif

  NB_MKI+=2

$NEXT_MKI
Next

Return

##########################################################################
$UPDMTK_MKM

# Transaction déjà démarrée
GOK = 1
For [MKMM]MKM0 Where MFGFCY=[F:MTK]MFGFCY & MFGTRKNUM=[F:MTK]MFGTRKNUM
&                    & evalue(WCRIT_MKM)

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTGPA04/MKM" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_MKI : Endif
  Endif
  #Raz [F:MKM]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_MKM
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_MKM
  Endif

  [F:MKM] = [F:MKMM]

  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_MKM
    If GOK<1 : Break : Endif

    Gosub MAJV6_MKM_CAL
    If GOK<1 : Break : Endif
  Endif

  NB_MKM+=2

$NEXT_MKM
Next

Return

##########################################################################
$UPDMTK_MKO

# Transaction déjà démarrée
GOK = 1
For [MKOM]MKO0 Where MFGFCY=[F:MTK]MFGFCY & MFGTRKNUM=[F:MTK]MFGTRKNUM
&                    & evalue(WCRIT_MKO)

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTGPA04/MKO" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_MKO : Endif
  Endif
  #Raz [F:MKO]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_MKO
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_MKO
  Endif

  [F:MKO] = [F:MKOM]

  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_MKO
    If GOK<1 : Break : Endif
    NB_MKO+=1

    Gosub MAJV6_MKO_CAL
    If GOK<1 : Break : Endif
  Endif

  NB_MKO+=1
  If [F:MKO]CPLLAB <> "" & [F:MKO]CPLLAB<>[F:MKO]CPLWST NB_MKO+=1 Endif # 2eme ligne insérée dans [F:CAL]

$NEXT_MKO
Next

Return


#######################################################################
# Code extrait de GPAMAJ30 - table MFGHEADTRK
#######################################################################
$MAJV6_MTK
[F:MTK]UPDUSR=GUSER
[F:MTK]UPDDAT=date$
Return
#######################################################################
$MTK_STK
Call STK (WTAB_MTK,WCPT_MTK,[F:MTK]MFGTRKNUM) From TRTMIG
Return
#######################################################################
$MTK_ERRTRA
Call ERRTRA (WTAB_MTK,WCPT_MTK,"File MFGHEADTRK(MFGTRKNUM)=") From TRTMIG
Return


#######################################################################
# Code extrait de GPAMAJ30 - table MFGITMTRK
#######################################################################
$MAJV6_MKI
  [F:MKI]UPDUSR=GUSER
  [F:MKI]UPDDAT=date$
  # --- alimentation des champs et écriture enreg
  Gosub MKI_STK : # pour stocker ref MKI
  WriteB [F:MKI]
  If fstat
      Call ECR_TRACE("MAJ_UUMGTRTGPA04: File MFGITMTRK MKI, Error ="-num$(fstat),1) From GESECRAN
      Gosub MKI_ERRTRA : # pour afficher les ref
      GOK=0 : Return
  Else
      Call ECR_DEBUG("File MFGITMTRK(MFGFCY/MFGTRKNUM/ITMTRKLIN)"-[F:MKI]MFGFCY+"/"+[F:MKI]MFGTRKNUM+"/"+num$([F:MKI]ITMTRKLIN))
  Endif
Return

$MAJV6_MKI_CAL
# Raz [F:CAL]
  [F:CAL]ABRFIC="MKI"
  [F:CAL]VCRNUM=[F:MKI]MFGTRKNUM
  [F:CAL]VCRLIN=[F:MKI]ITMTRKLIN
  [F:CAL]VCRSEQ=0
  [F:CAL]CPLCLE=""
  [F:CAL]ANALIG=1
  For J=1 To max(GNBCOA,2)
    [F:CAL]LED(J-1)=GLEDSOC(J)
    [F:CAL]COA(J-1)=GCOA(J)
  Next J
  For J=1 To max(GNBDIE,GOPTCANA)
    [F:CAL]DIE(J-1)=GDIE(J)
    If evalue("dim([F:MKIM]CCE"+num$(J)+")")>0
       [F:CAL]CCE(J-1)=evalue("[F:MKIM]CCE"+num$(J))
    Endif
  Next J
  # --- alimentation des champs et écriture enreg
  Gosub CAL_STK From UUMGTRTGPA00 # pour stocker ref CAL
  WriteB [F:CAL]
  If fstat
      Call ECR_TRACE("File CPTANALIN MKI, Error ="-num$(fstat),1) From GESECRAN
      Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
      GOK=0 : Return
  Else
      Call ECR_DEBUG("File CPTANALIN MKI (MFGFCY/MFGTRKNUM/ITMTRKLIN)"-[F:MTK]MFGFCY+"/"+[F:MKI]MFGTRKNUM+"/"+num$([F:MKI]ITMTRKLIN))
  Endif
Return

#######################################################################
$MKI_STK
Call STK (WTAB_MKI,WCPT_MKI,[F:MKI]MFGTRKNUM) From TRTMIG
Return
#######################################################################
$MKI_ERRTRA
Call ERRTRA (WTAB_MKI,WCPT_MKI,"File MFGITMTRK(MFGTRKNUM)=") From TRTMIG
Return


#######################################################################
# Code extrait de GPAMAJ30 - table MFGMATTRK
#######################################################################
$MAJV6_MKM
  [F:MKM]CPNTYP = 1   # V6 new Field
  [F:MKM]UPDUSR=GUSER
  [F:MKM]UPDDAT=date$
  # --- alimentation des champs et écriture enreg
  Gosub MKM_STK : # pour stocker ref MKM
  WriteB [F:MKM]
  If fstat
      Call ECR_TRACE("MAJ_UUMGTRTGPA04: File MFGMATTRK MKM, Error ="-num$(fstat),1) From GESECRAN
      Gosub MKM_ERRTRA : # pour afficher les ref
      GOK=0 : Return
  Else
    Call ECR_DEBUG("File MFGMATTRK(MFGFCY/MFGTRKNUM/MATTRKLIN)"-[F:MTK]MFGFCY+"/"+[F:MKM]MFGTRKNUM+"/"+num$([F:MKM]MATTRKLIN))
  Endif
Return

$MAJV6_MKM_CAL
 # Raz [F:CAL]
  [F:CAL]ABRFIC="MKM"
  [F:CAL]VCRNUM=[F:MKM]MFGTRKNUM
  [F:CAL]VCRLIN=[F:MKM]MATTRKLIN
  [F:CAL]VCRSEQ=0
  [F:CAL]CPLCLE=""
  [F:CAL]ANALIG=1
  For J=1 To max(GNBCOA,2)
    [F:CAL]LED(J-1)=GLEDSOC(J)
    [F:CAL]COA(J-1)=GCOA(J)
  Next J
  For J=1 To max(GNBDIE,GOPTCANA)
    [F:CAL]DIE(J-1)=GDIE(J)
    If evalue("dim([F:MKMM]CCE"+num$(J)+")")>0
       [F:CAL]CCE(J-1)=evalue("[F:MKMM]CCE"+num$(J))
    Endif
  Next J
  # --- alimentation des champs et écriture enreg
  Gosub CAL_STK From UUMGTRTGPA00 : # pour stocker ref CAL
  WriteB [F:CAL]
  If fstat
      Call ECR_TRACE("File CPTANALIN MKM, Error ="-num$(fstat),1) From GESECRAN
      Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
      GOK=0 : Return
  Else
      Call ECR_DEBUG("File CPTANALIN MKM (MFGFCY/MFGTRKNUM/MATTRKLIN)"-[F:MTK]MFGFCY+"/"+[F:MKM]MFGTRKNUM+"/"+num$([F:MKM]MATTRKLIN))
  Endif
Return
#######################################################################
$MKM_STK
Call STK (WTAB_MKM,WCPT_MKM,[F:MKM]MFGTRKNUM) From TRTMIG
Return
#######################################################################
$MKM_ERRTRA
Call ERRTRA (WTAB_MKM,WCPT_MKM,"File MFGMATTRK(MFGTRKNUM)=") From TRTMIG
Return


#######################################################################
# Code extrait de GPAMAJ30 - table MFGOPETRK
#######################################################################
$MAJV6_MKO
  If [F:MTK]MFGTRKNUM=[F:MKO]MFGTRKNUM
     [F:MKO]IPTDAT = [F:MTK]MFGTRKDAT
  Endif
  [F:MKO]UPDUSR=GUSER
  [F:MKO]UPDDAT=date$

  Gosub MKO_STK : # pour stocker ref MKM
  WriteB [F:MKO]
  If fstat
      Call ECR_TRACE("MAJ_UUMGTRTGPA04: File MFGOPETRK MKO, Error ="-num$(fstat),1) From GESECRAN
      Gosub MKO_ERRTRA : # pour afficher les ref
      GOK=0 : Return
  Else
      Call ECR_DEBUG("File MFGOPETRK(MFGFCY/MFGTRKNUM/OPETRKLIN)"-[F:MTK]MFGFCY+"/"+[F:MKO]MFGTRKNUM+"/"+num$([F:MKO]OPETRKLIN))
  Endif
Return

#######################################################################
$MAJV6_MKO_CAL
 # Raz [F:CAL]
  [F:CAL]ABRFIC="MKO"
  [F:CAL]VCRNUM=[F:MKO]MFGTRKNUM
  [F:CAL]VCRLIN=[F:MKO]OPETRKLIN
  [F:CAL]VCRSEQ=0
  [F:CAL]CPLCLE=[F:MKO]CPLWST
  [F:CAL]ANALIG=1
  For J=1 To max(GNBCOA,2)
    [F:CAL]LED(J-1)=GLEDSOC(J)
    [F:CAL]COA(J-1)=GCOA(J)
  Next J
  For J=1 To max(GNBDIE,GOPTCANA)
    [F:CAL]DIE(J-1)=GDIE(J)
    If evalue("dim([F:MKOM]CCE"+num$(J)+")")>0
       [F:CAL]CCE(J-1)=evalue("[F:MKOM]CCE"+num$(J))
    Endif
  Next J
  # --- alimentation des champs et écriture enreg
  Gosub CAL_STK From UUMGTRTGPA00 : # pour stocker ref CAL
  WriteB [F:CAL]
  If fstat
    Call ECR_TRACE("File CPTANALIN MKO CPLWST, Error ="-num$(fstat),1) From GESECRAN
    Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
    GOK=0 : Return
  Else
    Call ECR_DEBUG("File CPTANALIN MKO CPLWST (MFGFCY/MFGTRKNUM/OPETRKLIN)"-[F:MTK]MFGFCY+"/"+[F:MKO]MFGTRKNUM+"/"+num$([F:MKO]OPETRKLIN))
  Endif

  If [F:MKO]CPLLAB <> "" & [F:MKO]CPLLAB<>[F:MKO]CPLWST
      Raz [F:CAL]
      [F:CAL]ABRFIC="MKO"
      [F:CAL]VCRNUM=[F:MKO]MFGTRKNUM
      [F:CAL]VCRLIN=[F:MKO]OPETRKLIN
      [F:CAL]CPLCLE=[F:MKO]CPLLAB
      [F:CAL]ANALIG=1
      For J=1 To max(GNBCOA,2)
        [F:CAL]LED(J-1)=GLEDSOC(J)
        [F:CAL]COA(J-1)=GCOA(J)
      Next J
      For J=1 To max(GNBDIE,GOPTCANA)
        [F:CAL]DIE(J-1)=GDIE(J)
        If evalue("dim([F:MKOM]LABCCE"+num$(J)+")")>0
           [F:CAL]CCE(J-1)=evalue("[F:MKOM]LABCCE"+num$(J))
        Endif
      Next J
      # --- alimentation des champs et écriture enreg
      Gosub CAL_STK From UUMGTRTGPA00 : # pour stocker ref CAL
      WriteB [F:CAL]
      If fstat
          Call ECR_TRACE("File CPTANALIN MKO CPLLAB, Error ="-num$(fstat),1) From GESECRAN
          Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
          GOK=0 : Return
      Else
        Call ECR_DEBUG("File CPTANALIN MKO CPLLAB (MFGFCY/MFGTRKNUM/OPETRKLIN)"-[F:MTK]MFGFCY+"/"+[F:MKO]MFGTRKNUM+"/"+num$([F:MKO]OPETRKLIN))
      Endif
  Endif

Return
#######################################################################
$MKO_STK
Call STK (WTAB_MKO,WCPT_MKO,[F:MKO]MFGTRKNUM) From TRTMIG
Return
#######################################################################
$MKO_ERRTRA
Call ERRTRA (WTAB_MKO,WCPT_MKO,"File MFGOPETRK(MFGTRKNUM)=") From TRTMIG
Return

#######################################################################
$CHARGE_PARAM
#----- Alimentation champs pour le multi-référenciels comptabilité -----#
Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,WMFGFCY) From TRTX3CPT
Return

#######################################################################
Subprog ECR_DEBUG(LMESS)
Value Char LMESS
If GUSER="ZGA" & 1=2
   Call ECR_TRACE(LMESS,0) From GESECRAN
Endif

End

#######################################################################
Subprog RAZ_UUMGTRTGPA04_FIC(WDOSSIER,LNOMFIC,LABRFIC)
Value Char WDOSSIER
Value Char LNOMFIC
Value Char LABRFIC

Local Integer ERR

If filinfo(filpath("FIL",LNOMFIC,"fde",WDOSSIER),0)<=0 : GOK=0 : End :  Endif

# Issue 80145 Vérifier là aussi que le fichier renommé soit dispo
Local Char WNAMFICM
Call MIGTABNAME (WDOSSIER,LNOMFIC,WNAMFICM,ERR) From TRTMIG
If ERR : End : Endif
#----- Présence des fichiers renommés...  -----#
If filinfo(filpath("FIL",WNAMFICM,"fde",WDOSSIER),0) < 0 :  End : Endif

#Call ECR_TRACE("RAZ_UUMGTRTGPA04 Raz table"-WDOSSIER-LNOMFIC,0) From GESECRAN
Call MIGTABRAZ (WDOSSIER,LNOMFIC,ERR) From TRTMIG
If LABRFIC="MTK"
   Call MIGRAZKEY (WDOSSIER,"UUMGTRTGPA04",ERR) From TRTMIG
Endif

Local File =WDOSSIER+".CPTANALIN"  [CALW]
Trbegin [CALW]
Delete [CALW] Where ABRFIC=LABRFIC
Commit
Close Local File [CALW]

End

