#<AdxTL>@(#)10.0.0.0 $Revision$
Local Date    LDAT(20)
Local Decimal LVAL(3,dim(LDAT))
Local Integer LRET, LNB
Local Integer I,J
Local Char    LMES(250), LMES2(250)
Raz I
LDAT(I) = date$
I+=1 : LDAT(I) = addmonth(LDAT(I-1),1)
I+=1 : LDAT(I) = addmonth(LDAT(I-1),2)
I+=1 : LDAT(I) = addmonth(LDAT(I-1),0)
I+=1 : LDAT(I) = addmonth(LDAT(I-1),0)
I+=1 : LDAT(I) = addmonth(LDAT(I-1),1)
LVAL(0,0) = 1
LVAL(0,1) = 2
LVAL(0,2) = -1
LVAL(0,3) = 3
LVAL(0,4) = -3
LVAL(0,5) = 4
LVAL(2,3) = 6
LNB = I+1
Call OUVRE_TRACE("CCC") From LECFIC
Raz LMES
For I=0 To LNB-1
    LMES=num$(LDAT(I))+" > "
    For J=0 To dim(LVAL,1)-1
        LMES+=num$(LVAL(J,I))+"  "
    Next
    Call ECR_TRACE(LMES,0) From GESECRAN
Next
Call GENDATPOINT(LNB, LDAT, LVAL, 5, LRET) From TRTX3
LMES ="--------"
Call ECR_TRACE(LMES,0) From GESECRAN
For I=0 To LNB-1
    LMES2=num$(LDAT(I))+" > "
    For J=0 To dim(LVAL,1)-1
        LMES2+=num$(LVAL(J,I))+"  "
    Next
    Call ECR_TRACE(LMES2,0) From GESECRAN
Next
Call SUPP_TRACE From LECFIC
End

Sorta LDAT,LVAL # Order By LVAL Asc

Infbox num$(LDAT(0))+";"+num$(LDAT(1))+";"+num$(LDAT(2))+";"


End
# Gestion du masque HISCOST2

#
$CHARG_GRAPHE
If [M:HIC1]NBLIG=0
    Return
Endif
If !clalev([F:ITC2]) : Local File ITMCOST [ITC2] : Endif
[M:HIC2]STRDAT = min([M:HIC1]ITCSTRDAT(0..[M:HIC1]NBLIG-1))
If [M:HIC2]STRDAT=[0/0/0]
    [M:HIC2]STRDAT=max([M:HIC1]ITCENDDAT)    # 'max' Pour éviter la date [0/0/0]
    For I=0 To [M:HIC1]NBLIG-1
        If [M:HIC2]STRDAT>[M:HIC1]ITCENDDAT(I) & [M:HIC1]ITCENDDAT(I)<>[0/0/0]
            [M:HIC2]STRDAT=[M:HIC1]ITCENDDAT(I)
        Endif
    Next
Endif
If [M:HIC2]STRDAT=[0/0/0]
    [M:HIC2]STRDAT = addmonth(date$,-1)
Endif
[M:HIC2]ENDDAT=max([M:HIC1]ITCENDDAT(0..[M:HIC1]NBLIG-1))
If [M:HIC2]ENDDAT<=[M:HIC2]STRDAT
    [M:HIC2]ENDDAT=addmonth([M:HIC2]STRDAT,1)
Endif
[M:HIC2]ECH = 4    # Mois
If [M:HIC2]ENDDAT<>[0/0/0]
    Gosub ALIM_TAB
Endif
Affzo [M:HIC2]
Return

$ALIM_TAB

Local Date    LTABDAT(dim([M:HIC2]ADAT))
Local Decimal LTABVAL(6,dim([M:HIC2]ADAT))
Local Decimal LPRI
Local Integer I, J, LNB, LRET
# On regarde s'il existe un coût pour la date de début de période...
Filter [ITC2] Where ITMREF = [M:HIC0]ITMREF
&                 & STOFCY = [M:HIC0]STOFCY
&                 & UID    = 0
&                 & CSTTYP = [M:HIC0]CSTTYP
&                 & ITCSTRDAT<=[M:HIC2]STRDAT
&                 & ITCENDDAT>=[M:HIC2]STRDAT
Look [ITC2]ITC0 First
Raz I,LNB, LTABDAT, LTABVAL, [M:HIC3]NBLIG
If fstat
    # ... sinon on récupère le dernier valable pour cette date
    If find([M:HIC0]CSTTYP,3,4)
        Call GETPRI([M:HIC0]ITMREF,"","",[M:HIC0]STOFCY,[M:HIC2]STRDAT,1,"","",-[M:HIC0]CSTTYP,LPRI,LRET) From STKVAL
    Else
        Call GETPRI([M:HIC0]ITMREF,"","",[M:HIC0]STOFCY,[M:HIC2]STRDAT,1,"","",[M:HIC0]CSTTYP,LPRI,LRET) From STKVAL
    Endif
    [F:ITC2] = [F:ITC]
    LTABDAT(I) = [M:HIC2]STRDAT
    Call ALIM_VARTAB(I,LTABVAL)

#    Call ALIM_GANTT

    I+=1
Endif

# On regarde s'il existe un coût pour la date de fin de période...
Filter [ITC2] Where ITMREF = [M:HIC0]ITMREF
&                 & STOFCY = [M:HIC0]STOFCY
&                 & UID    = 0
&                 & CSTTYP = [M:HIC0]CSTTYP
&                 & ITCSTRDAT<=[M:HIC2]ENDDAT
&                 & ITCENDDAT>=[M:HIC2]ENDDAT
Look [ITC2]ITC0 First
Raz I,LNB, LTABDAT, LTABVAL
If fstat
    # ... sinon on récupère le dernier valable pour cette date
    If find([M:HIC0]CSTTYP,3,4)
        Call GETPRI([M:HIC0]ITMREF,"","",[M:HIC0]STOFCY,[M:HIC2]ENDDAT,1,"","",-[M:HIC0]CSTTYP,LPRI,LRET) From STKVAL
    Else
        Call GETPRI([M:HIC0]ITMREF,"","",[M:HIC0]STOFCY,[M:HIC2]ENDDAT,1,"","",[M:HIC0]CSTTYP,LPRI,LRET) From STKVAL
    Endif
    [F:ITC2] = [F:ITC]
    LTABDAT(dim(LTABDAT)-1) = [M:HIC2]ENDDAT
    Call ALIM_VARTAB(dim(LTABDAT)-1,LTABVAL)

#    Call ALIM_GANTT
Endif

Filter [ITC2] Where ITMREF = [M:HIC0]ITMREF
&                 & STOFCY = [M:HIC0]STOFCY
&                 & UID    = 0
&                 & CSTTYP = [M:HIC0]CSTTYP
&                 & ITCENDDAT>=[M:HIC2]STRDAT
&                 & ITCSTRDAT<=[M:HIC2]ENDDAT
&             Order By Key ITC1

For [ITC2]
    If [F:ITC2]ITCSTRDAT<[M:HIC2]STRDAT
        LTABDAT(I) = [M:HIC2]STRDAT
    Else
        LTABDAT(I) = [F:ITC2]ITCSTRDAT
    Endif
    Call ALIM_VARTAB(I,LTABVAL)

#    Call ALIM_GANTT

    I+=1
    If I>=dim(LTABDAT)-1
        Break
    Endif
Next
Filter [ITC2]

LNB=I+1
If find([M:HIC0]CSTTYP,3,4)
    Call GETPRI([M:HIC0]ITMREF,"","",[M:HIC0]STOFCY,[M:HIC2]ENDDAT,1,"","",-[M:HIC0]CSTTYP,LPRI,LRET) From STKVAL
Else
    Call GETPRI([M:HIC0]ITMREF,"","",[M:HIC0]STOFCY,[M:HIC2]ENDDAT,1,"","",[M:HIC0]CSTTYP,LPRI,LRET) From STKVAL
Endif
[F:ITC2] = [F:ITC]

LTABDAT(I) = [M:HIC2]ENDDAT
Call ALIM_VARTAB(I,LTABVAL)

If LNB<=0
    End
Endif

Call GENDATPOINT(LNB, LTABDAT, LTABVAL, [M:HIC2]ECH, LRET) From TRTX3

If !LRET
    Call ALIM_MSK(LNB, LTABDAT, LTABVAL)
Endif

Affzo [M:HIC2]
Affzo [M:HIC3]
Return

######################################################################################
Subprog ALIM_VARTAB(PIND,PVAL)
Value    Integer PIND
Variable Decimal PVAL(,)
Local Integer I

    Raz I
    PVAL(I,PIND) = [F:ITC2]VLTTOT : I+= 1
    PVAL(I,PIND) = [F:ITC2]CSTTOT : I+= 1
    PVAL(I,PIND) = [F:ITC2]MATTOT : I+= 1
    PVAL(I,PIND) = [F:ITC2]MACTOT : I+= 1
    PVAL(I,PIND) = [F:ITC2]LABTOT : I+= 1
    PVAL(I,PIND) = [F:ITC2]OVETOT : I+= 1

End


######################################################################################
Subprog ALIM_GANTT
If 0
    [M:HIC3]ITCSEQ([M:HIC3]NBLIG) = [F:ITC2]ITCSEQ
    [M:HIC3]VLT([M:HIC3]NBLIG)    = num$([F:ITC2]VLTTOT)
    [M:HIC3]NBLIG += 1
    [M:HIC3]ITCSEQ([M:HIC3]NBLIG) = [F:ITC2]ITCSEQ
#    [M:HIC3]VLT([M:HIC3]NBLIG)    = num$([F:ITC2]VLTTOT)
    [M:HIC3]ADAT([M:HIC3]NBLIG)   = num$([F:ITC2]ITCSTRDAT)
    [M:HIC3]LTI([M:HIC3]NBLIG)    = [F:ITC2]ITCENDDAT-[F:ITC2]ITCSTRDAT
    [M:HIC3]LTIAFF([M:HIC3]NBLIG) = [M:HIC3]LTI([M:HIC3]NBLIG)
    [M:HIC3]TYP([M:HIC3]NBLIG)    = "Valide"
    [M:HIC3]NBLIG += 1
Endif
End

######################################################################################
Subprog ALIM_MSK(PNB, PDAT, PVAL)
Value Integer PNB
Value Date    PDAT()
Value Decimal PVAL(,)

Local Integer I,J

    Raz [M:HIC2]NBLIG
    For I=0 To PNB-1
        Raz J
        [M:HIC2]ADAT([M:HIC2]NBLIG)   = num$(PDAT(I))
        [M:HIC2]DAT([M:HIC2]NBLIG)    = PDAT(I)
        [M:HIC2]VLTTOT([M:HIC2]NBLIG) = PVAL(J,I) : J+=1
        [M:HIC2]CSTTOT([M:HIC2]NBLIG) = PVAL(J,I) : J+=1
        [M:HIC2]MATTOT([M:HIC2]NBLIG) = PVAL(J,I) : J+=1
        [M:HIC2]MACTOT([M:HIC2]NBLIG) = PVAL(J,I) : J+=1
        [M:HIC2]LABTOT([M:HIC2]NBLIG) = PVAL(J,I) : J+=1
        [M:HIC2]OVETOT([M:HIC2]NBLIG) = PVAL(J,I) : J+=1
        [M:HIC2]NBLIG += 1
    Next
End


######################################################################################
Subprog B2_NBLIG
Raz [F:ITC]
Filter [ITC] Where STOFCY=[M:HIC0]STOFCY
&                & ITMREF=[M:HIC0]ITMREF
&                & CSTTYP=[M:HIC0]CSTTYP
&                & UID=0
&                & ITCSTRDAT<=[M:HIC2]DAT(nolign-1)
&                & ITCENDDAT>=[M:HIC2]DAT(nolign-1)
Read [ITC]ITC0 First
Filter [ITC]

If fstat
    Filter [ITC] Where STOFCY=[M:HIC0]STOFCY
&                    & ITMREF=[M:HIC0]ITMREF
&                    & CSTTYP=[M:HIC0]CSTTYP
&                    & UID=0
&                    & ITCSTRDAT<=[M:HIC2]DAT(nolign-1)
&                Order By ITCENDDAT;ITCSEQ Desc
    Read [ITC] First
    Filter [ITC]
Endif
End

######################################################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
    [M:HIC2]STRDAT = VALEUR
    Gosub ALIM_TAB
End

Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
    [M:HIC2]ENDDAT = VALEUR
    Gosub ALIM_TAB
End

Subprog AM_ECH(VALEUR)
Variable Integer VALEUR
    [M:HIC2]ECH = VALEUR
    Gosub ALIM_TAB
End

