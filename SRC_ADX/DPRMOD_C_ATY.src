# >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
#       D A T A    T Y P E    DPM  Depreciation mode
# >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>

#**
#* Function :
#*
#* This fonction controls the depreciation mode when used through DPM data type.
#* The depreciation must be defined in DPRMOD table
#* It can be defined either for a company or for all company
#* In this last case, company is blank.
#*
#* Input parametres
#* @param           Instance
#* @param APRONAME  Property name
#* @param PDPM      Depreciation mode
#* @param PCPY      Company
#* @param AENABLE   Enable flag
#* @param AFILTER   Filter
#*
#* Output parametre
#* @param ASTATUS   Error message
#* @param RRET
#*#*
#*
#*!
#----------------------------------------------------------------
Funprog _CTRLREF(AINSTANCE,APRONAME,AVALUE,DPM,CPY,AENABLE,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char DPM
Value Char CPY
Value Tinyint AENABLE
Value Char AFILTER

Local Integer ASTATUS
Local Integer RET

  [L]RET = func WMTYPDPM.ACTRLREF(AINSTANCE,APRONAME,AVALUE,DPM,CPY,AENABLE,AFILTER)
  If CPY <> AVOID.ACHAR and [L]ASTATUS <> [V]CST_AOK
    [L]ASTATUS = [V]CST_AOK
    [L]RET = func WMTYPDPM.ACTRLREF(AINSTANCE,APRONAME,AVALUE,DPM,"",AENABLE,AFILTER)
  Endif

End [V]CST_AOK

