#<AdxTL>@(#)5.0.0.0 $Revision$
# Affectation de la valeur 4 "Interdite dans tous les cas" au champ NAVIG des fonctions
# GESGVD, GESDER, GESMPY, FASCLOTURB, GESRC1, GESTSI et FASSPL
  Call OUVRE_TRACE("UTIIMM013 - Field NAVIG of AFONCTION table initialization for Fixed Assets objects") From LECFIC
  Call PATCH(nomap)
  Call LEC_TRACE() From LECFIC
End
#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog EXE_UTIIMM013(APPLI)
Value Char APPLI

  If clalev([F:WAFC]) : Close Local File [WAFC] : Endif
  Local File =APPLI+".AFONCTION" [WAFC]

  Call ECR_TRACE("UTIIMM013: Process Start on : "+APPLI,0) From GESECRAN

  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM013

  Call ECR_TRACE("UTIIMM013: Process End on : "+APPLI,0) From GESECRAN

  If clalev([F:WAFC]) : Close Local File [WAFC] : Endif
End


#### Corps de la moulinette - début
$TR_UTIIMM013
  Trbegin [WAFC]

  Update [F:WAFC]
& Where MODULE=14 and find(CODINT,"GESGVD","GESDER","GESMPY","FASCLOTURB","GESRC1","GESTSI","FASSPL")<>0
& With NAVIG = 4

  If fstat
    Call ECR_TRACE(mess(13,100,1)-"AFONCTION"-num$(fstat),1) From GESECRAN
  Else
    Call ECR_TRACE(mess(192,124,1)-":"-num$(adxuprec),0) From GESECRAN
  Endif

  If !GOK Then
    Goto AB_UTIIMM013
  Else
    Commit
  Endif
Return

$AB_UTIIMM013
  Rollback
Return
#### Corps de la moulinette - fin


Subprog PATCH(APPLI)
Value Char    APPLI
  If filinfo(filpath("FIL","AFONCTION","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM013(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj7 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
  If filinfo(filpath("FIL","AFONCTION","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM013(APPLI)
End
