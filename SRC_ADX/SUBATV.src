#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet ATV
Raz GPILOBJ,GNBMASKOUV
GBIDC1=""
Call OBJET("ATV",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"           : Gosub OUVRE
 When "LIENS"           : Gosub LIENS
 When "INIMOD"          : Gosub INIMOD
 When "FILGAUCHE"       : Gosub FILGAUCHE
 When "SETBOUT"         : Gosub SETBOUT
 When "STATUT"          : Gosub STATUT
 When "EXEBOUT"         : Gosub EXEBOUT
 When "FIN_MOD"         : Gosub FIN_MOD
Endcase
Return

#################################################################################################
$OUVRE
If !clalev([F:ATX2]) : Local File  ATEXTE [ATX2] : Endif
If !clalev([F:ATX])  : Local File  ATEXTE [ATX]  : Endif
Return

$LIENS
Gosub GRISE
Return

$FIN_MOD
[M] = [F]
Gosub GRISE
Affzo [M]
Return

$GRISE
Grizo [M:ATV1]
Case [M:ATV1]TYPERR
 When 1 : # Texte manquant
  Actzo [M:ATV1]TRA
 When 2
  Read [ATX]TEXTE = [M:ATV1]LANREF;[M:ATV1]TEXTE
  If fstat=0
   [M]TXTREF = [F:ATX]NUMERO
  Endif
  Actzo [M:ATV1]TXTTRA
 When  3
  Actzo [M:ATV1]TXTTRA
 When 4
  If [M:ATV1]TYPERR = 4 & [M:ATV1]STA = 2
   Actzo [M]TXTTRA
  Endif
  Read [ATX]NUMERO = [M]LANTRA;[M]TXTREF
  If fstat=0
   [M]TXTTRA= [F:ATX]TEXTE
  Endif
Endcase
Return

$INIMOD
Local Char MESSAGE(250)
Local Integer ASTATUS
Local Integer NUM
Case [M]TYPERR
 When 1

   Call NUMERO([M]TEXTE,NUM) From OBJDIV
   # on passe par un sous prog commun pour ne pas crer des mauvais textes et prendre en cmpte le lanori.
   Call TXTCONT([M]TEXTE,[M]TEXTE,NUM,30,25,[M]TEXTE,"TEXTE") From OBJDIV
   If NUM = 0
    GOK = 0
    Return
   Endif

   [F:ATV]TXTREF  = NUM
   [M]TXTREF = [F:ATV]TXTREF
   If [M]LANREF = [M]LANTRA
    Read [ATX]NUMERO = [M]LANTRA;[M]TXTREF
    If !fstat
     [F:ATV]TXTTRA = [F:ATX]TEXTE
     [F:ATV]TYPERR = 4
    Else
     [F:ATV]TYPERR = 2
    Endif
   Else
    Read [ATX]NUMERO = [M]LANTRA;[M]TXTREF
    If !fstat
     [F:ATX]TEXTE = [M]TXTTRA
     [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
     Call FLDUPD("ATX") From OBJDIV
     Rewrite [ATX]
     #115210
     If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" & ([F:ATX]NUMERO<GMAXTXTSTD | [F:ATX]NUMERO>GNEWTXTSTD)
       ASTATUS = func ATXTSVC.UPDATE_ONETEXT_CHAR(GPRODUIT, [F:ATX]NUMERO, [F:ATX]LAN, [F:ATX]TEXTE,[F:ATX]COMMENT,[F:ATX]LANORI,MESSAGE)
       If ASTATUS<>[V]CST_AOK
        GMESSAGE=MESSAGE : GOK=0
       Endif
     Endif

     [F:ATV]TXTTRA = [F:ATX]TEXTE
     [F:ATV]TYPERR = 4
     Return
    Else
#     If [M]TXTTRA<>""
#      Gosub CRE_ATX_LAN
#      [F:ATV]TYPERR = 4
#     Else
      [F:ATV]TYPERR = 2
 #    Endif
    Endif
   Endif

 When 2
  If [M]TXTTRA <> ""
   Read [ATX]NUMERO = [M]LANTRA;[M]TXTREF
   If !fstat
    [F:ATV]TXTTRA = [F:ATX]TEXTE
    [F:ATV]TYPERR = 4
#   Else
#    Gosub CRE_ATX_LAN
#    [F:ATV]TYPERR = 4
   Endif
  Endif
 When 3
  [F:ATV]TYPERR = 4
  [F:ATV]STA = 2
Endcase
Return


$CRE_ATX_LAN
Local Char MESSAGE(250)
Local Integer ASTATUS
Raz [F:ATX]
[F:ATX]NUMERO = [M]TXTREF
[F:ATX]TEXTE  = [M]TXTTRA
[F:ATX]LONG   = 30
[F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
[F:ATX]LAN = [M]LANTRA
[F:ATX]TYPOBJ = 25
If dim([F:ATX]UPDDAT)>0 : [F:ATX]UPDDAT = date$ : Endif
Write [ATX]
If fstat
 GOK=0 : Call FSTA("ATX") From GLOCK
Endif
#115210
If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" & ([F:ATX]NUMERO<GMAXTXTSTD | [F:ATX]NUMERO>GNEWTXTSTD)
  ASTATUS = func ATXTSVC.UPDATE_ONETEXT_CHAR(GPRODUIT, [F:ATX]NUMERO, [F:ATX]LAN, [F:ATX]TEXTE,[F:ATX]COMMENT,[F:ATX]LANORI,MESSAGE)
  If ASTATUS<>[V]CST_AOK
   GMESSAGE=MESSAGE : GOK=0
  Endif
Endif
Return

$EXEBOUT
Case BOUT
 When "r"
  Filter [F:ATV] Where LANTRA = GBIDC1
  Gosub RAF
  Filter [F:ATV]
Endcase
Return

$STATUT
Case BOUT
 When "1"    :  Gosub SUPP_ETAT
 When "2"    :  Gosub SUPP_LANGUE
Endcase
Return

$SUPP_ETAT
Call OUINON(mess(48,127,1)-":"-[M:ATV1]RAPORT,OK) From GESECRAN
If OK=2
 GOK =1
 Call DEBTRANS From GLOCK
 Trbegin [ATV]
  Delete [ATV] Where RAPORT=[M:ATV1]RAPORT
  If fstat
   GOK = 0 : Call FSTA("ATV") From GLOCK : Goto AB_SUP
  Endif
 Commit
 Gosub RAF
 Filter [F:ATV]
Endif
Return

$AB_SUP
Rollback
Return

$SUPP_LANGUE
Call OUINON(mess(49,127,1)-":"-[M:ATV1]LANTRA,OK) From GESECRAN
If OK=2
 GOK =1
 Call DEBTRANS From GLOCK
 Trbegin [ATV]
  Delete [ATV] Where RAPORT=[M:ATV1]RAPORT & LANTRA = [M:ATV1]LANTRA
  If fstat
   GOK = 0 : Call FSTA("ATV") From GLOCK : Goto AB_SUP
  Endif
 Commit
 Filter [F:ATV] Where RAPORT = [M:ATV1]RAPORT
 Gosub RAF
 Filter [F:ATV]
Endif
Return

$RAF
Effzo [M:ATV1]
Read [ATV]ATV1 Last
If !fstat
 [M:ATV1] = [F:ATV]
Endif
Case currbox
 When "GAU_CHE"  :
  Fillbox [ATV1] GAU_CHE Hint Key = "ATV1"
  Setlbox [ATV1] GAU_CHE
 When "GAU_CHE1" :
  Fillbox [ATV1] GAU_CHE1 Hint Key = "ATV1"
  Setlbox [ATV1] GAU_CHE1
 When "GAU_CHE2" :
  Fillbox [ATV1] GAU_CHE2 Hint Key = "ATV1"
  Setlbox [ATV1] GAU_CHE2
 When "GAU_CHE3" :
  Fillbox [ATV1] GAU_CHE3 Hint Key = "ATV1"
  Setlbox [ATV1] GAU_CHE3
Endcase
Affzo [M:ATV1]
Return

$SETBOUT
Call VIREBOUT(CHAINE,"HDC") From GOBJET
CHAINE += "A"
If [M:ATV1]TEXTE <> ""
 CHMEN = "123"
Endif
CHMEN += "3"
Return

$FILGAUCHE
Case currbox
 When "GAU_CHE2"
  FILGAUSUP = '[F:ATV]TYPERR = 4 & [F:ATV]STA = 2 '
 When "GAU_CHE3"
  FILGAUSUP = '[F:ATV]TYPERR =4 '
Endcase
Return

######################################################################################
Subprog CL_TRA(VALEUR)
Variable Char    VALEUR()
Local Integer NUM, PREM , DERN
Local File ATEXTE [ATXX]

Call RECHERCHE_TEXTE([M]TEXTE,NUM)

If NUM>0 : End : Endif

Read [ATXX]TEXTE = [M]LANREF;[M:ATV1]TEXTE
If fstat=0
 [M]TXTREF = [F:ATX]NUMERO
 Grizo [M:ATV1]5 : Affzo [M:ATV1]10 : Actzo [M:ATV1]10
 mkstat = 4
 End
Endif


If [M]LANREF = [M]LANTRA : [M]TXTTRA = [M:ATV1]TEXTE : Endif
Grizo [M:ATV1]5 : Affzo [M:ATV1]10 : Actzo [M:ATV1]10
mkstat = 4

End

####################################
Subprog C_TXTTRA(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If [M]TYPERR = 3  | ([M]TYPERR = 4 & [M:ATV1]STA=2)
 Local Integer NBTEX,NUM
 Local Char    TEX(80)(0..60)
 Local Char    RESULT(80)(0..60)
 OK =0
 For [ATX]TEXTE Where LAN=[M]LANREF & TEXTE=[M:ATV1]TEXTE
  For [ATX2] Where NUMERO = [ATX]NUMERO & LAN = [M:ATV1]LANTRA
   NBTEX += 1
   TEX(NBTEX) = format$("N:7#",[F:ATX2]NUMERO)
   TEX(NBTEX) -= [ATX2]TEXTE
   RESULT(NBTEX) = [ATX2]TEXTE+"~&"+num$([ATX2]NUMERO)
   If dim([F:ATX2]COMMENT)>0 :TEX(NBTEX) -= "("+[F:ATX2]COMMENT+")" : Endif
  Next
 Next
 For I=1 To NBTEX
  If VALEUR = left$(RESULT(I),instr(0,RESULT(I),"~&")-1) & [M]TXTREF = val(right$(RESULT(I),instr(0,RESULT(I),"~&")+2))
   [M]TXTREF = val(right$(RESULT(I),instr(0,RESULT(I),"~&")+2))
   Affzo [M]TXTREF
   OK =1 : Break
  Endif
 Next I
 If OK =0
  GMESSAGE = mess(83,123,1) : # Valeur incorrecte
  mkstat =2 : End
 Endif
Endif
End


####################################
Subprog S_TXTTRA(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEX,NUM
Local Char    TEX(80)(0..60)
Local Char    RESULT(80)(0..60)

For [ATX]TEXTE Where LAN=[M]LANREF & TEXTE=[M:ATV1]TEXTE
 For [ATX2] Where NUMERO = [ATX]NUMERO & LAN = [M:ATV1]LANTRA
  NBTEX += 1
  TEX(NBTEX) = format$("N:7#",[F:ATX2]NUMERO)
  TEX(NBTEX) -= [ATX2]TEXTE
  RESULT(NBTEX) = [ATX2]TEXTE+"~&"+num$([ATX2]NUMERO)
  If dim([F:ATX2]COMMENT)>0 :TEX(NBTEX) -= "("+[F:ATX2]COMMENT+")" : Endif
 Next
Next

If NBTEX >= 1
 Call SAITEX(NBTEX,TEX,NUM,[M:ATV1]TEXTE) From GESECRAN
 If NUM > 0
  VALEUR = left$(RESULT(NUM),instr(0,RESULT(NUM),"~&")-1)
  [M]TXTREF = val(right$(RESULT(NUM),instr(0,RESULT(NUM),"~&")+2))
  Affzo [M]TXTREF
  mkstat = 4
 Endif
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ATV1) 11/07/2007 11:52:59 (CCL)
######################################################################################
Subprog B1_TEXTE(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEXTES
Call RECHERCHE_TEXTE(VALEUR,NBTEXTES)
End

Subprog RECHERCHE_TEXTE(VALEUR,NUM)
Variable Char    VALEUR()
Variable Integer NUM
Local Integer NBTEX
Local Char    TEX(80)(0..60)
Local Char    RESULT(80)(0..60)
Local Char    CHAINE(250)

CHAINE = VALEUR

For [ATX]TEXTE Where [F:ATX]LAN=[M:ATV1]LANREF &  pat(toupper([F:ATX]TEXTE),"*"+toupper(CHAINE)+"*")
 If NBTEX = 60 : Break : Endif
 NBTEX += 1
 TEX(NBTEX) = format$("N:7#",[F:ATX]NUMERO)
 TEX(NBTEX) -= [ATX]TEXTE
 RESULT(NBTEX) = [ATX]TEXTE+"~&"+num$([ATX]NUMERO)
 If dim([F:ATX]COMMENT)>0 :TEX(NBTEX) -= "("+[F:ATX]COMMENT+")" : Endif
Next

If !NBTEX & instr(1,VALEUR," ")
 CHAINE = left$(VALEUR,instr(1,VALEUR," "))
 For [ATX]TEXTE Where [F:ATX]LAN=[M:ATV1]LANREF &  pat(toupper([F:ATX]TEXTE),"*"+toupper(CHAINE)+"*")
  If NBTEX = 60 : Break : Endif
  NBTEX += 1
  TEX(NBTEX) = format$("N:7#",[F:ATX]NUMERO)
  TEX(NBTEX) -= [ATX]TEXTE
  RESULT(NBTEX) = [ATX]TEXTE+"~&"+num$([ATX]NUMERO)
  If dim([F:ATX]COMMENT)>0 :TEX(NBTEX) -= "("+[F:ATX]COMMENT+")" : Endif
 Next
Endif

If !NBTEX & instr(1,VALEUR," ")
 CHAINE = right$(VALEUR,instr(1,VALEUR," "))
 For [ATX]TEXTE Where [F:ATX]LAN=[M:ATV1]LANREF &  pat(toupper([F:ATX]TEXTE),"*"+toupper(CHAINE)+"*")
  If NBTEX = 60 : Break : Endif
  NBTEX += 1
  TEX(NBTEX) = format$("N:7#",[F:ATX]NUMERO)
  TEX(NBTEX) -= [ATX]TEXTE
  RESULT(NBTEX) = [ATX]TEXTE+"~&"+num$([ATX]NUMERO)
  If dim([F:ATX]COMMENT)>0 :TEX(NBTEX) -= "("+[F:ATX]COMMENT+")" : Endif
 Next
Endif
If NBTEX >= 1
 Call SAITEX(NBTEX,TEX,NUM,[M:ATV1]TEXTE) From GESECRAN
 If status = 7 : NUM = 1 : Endif
Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ATV1) 20/07/2007 12:24:34 (CCL)
######################################################################################
Subprog AV_TEXTE(VALEUR)
Variable Char    VALEUR()
Diszo [M]TEXTE
End

