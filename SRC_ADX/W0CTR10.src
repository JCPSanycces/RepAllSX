#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR10 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone FLGRET
mkstat = 0
zoncou = "FLGRET"
indice = 0
IMPENT = [M]FLGRET
If varinit([M]FLGRET,indice)=0
 IMPENT = 1
Endif
[M]FLGRET = IMPENT

## Zone RETTYP
mkstat = 0
zoncou = "RETTYP"
indice = 0
IMPENT = [M]RETTYP
If varinit([M]RETTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]RETTYP,indice)=0
 Call INICOMBO(10644) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_RETTYP(IMPENT) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,10644,1))))
 Endif
 [M]RETTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "RETTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]RETTYP(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "RETTYP" : GZNUM = 680 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]RETTYP = IMPENT

## Zone RETSTATUT
mkstat = 0
zoncou = "RETSTATUT"
indice = 0
IMPENT = [M]RETSTATUT
If varinit([M]RETSTATUT,indice)=0
 IMPENT = 1
Endif
If varmode([M]RETSTATUT,indice)=0
 [M]RETSTATUT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "RETSTATUT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]RETSTATUT(indice)
 Endif
Endif
[M]RETSTATUT = IMPENT

## Zone RETNUMICO
mkstat = 0
zoncou = "RETNUMICO"
indice = 0
If varinit([M]RETNUMICO,indice)=0
 [M]RETNUMICO = "21"
Endif
If varmode([M]RETNUMICO,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RETNUMICO" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone RETDATEFF
mkstat = 0
zoncou = "RETDATEFF"
indice = 0
If varmode([M]RETDATEFF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RETDATEFF" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_RETDATEFF([M]RETDATEFF) From SUBCTR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "RETDATEFF" : GZNUM = 34421 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone RETGRD
mkstat = 0
zoncou = "RETGRD"
indice = 0
If varinit([M]RETGRD,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]RETGRD,"443","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]RETGRD,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "RETGRD" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]RETGRD,"443","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "RETGRD" : GZNUM = 2675 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]RETGRD,"443",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "RETGRD" : GZNUM = 2675 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone LOAD
mkstat = 0
zoncou = "LOAD"
indice = 0
If varinit([M]LOAD,indice)=0
 [M]LOAD = "1"
Endif
If varmode([M]LOAD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LOAD" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRRCR
mkstat = 0
zoncou = "NBRRCR"
indice = 0
status = 1
zoncou = "NBRRCR"
If varmode([M]NBRRCR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRRCR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRRCR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRRCR = nolign
   status = 75
   Call SAI_NBRRCR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBRRCR From SUBCTR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBRRCR" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone LEACYCTYP
mkstat = 0
zoncou = "LEACYCTYP"
indice = 0
IMPENT = [M]LEACYCTYP
If varinit([M]LEACYCTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]LEACYCTYP,indice)=0
 [M]LEACYCTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "LEACYCTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]LEACYCTYP(indice)
 Endif
Endif
[M]LEACYCTYP = IMPENT

## Zone LEARSMDAT
mkstat = 0
zoncou = "LEARSMDAT"
indice = 0
If varmode([M]LEARSMDAT,indice)=0
 SAVACT = GACTION : GACTION = "SUBCTRLEG"
 Call BEFORE_ENTRY([M]LEARSMDAT) From SUBCTRLEG
 GACTION = SAVACT
 If mkstat=1 : Raz [M]LEARSMDAT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "LEARSMDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRRCR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRRCR
mkstat = 0
zoncou = "NBRRCR"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBRRCR From SUBCTR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBRRCR" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone FLD
mkstat = 0
zoncou = "FLD"
If varmode([M]FLD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]FLD(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "FLD" : GZNUM = 1261 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_FLD([M]FLD(indice)) From SUBCTR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "FLD" : GZNUM = 1261 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone TBL
mkstat = 0
zoncou = "TBL"
If varmode([M]TBL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TBL" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]TBL(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TBL" : GZNUM = 1176 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("ATB","",[M]TBL(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "TBL" : GZNUM = 1176 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone STRDAT
mkstat = 0
zoncou = "STRDAT"
WDATE = [M]STRDAT(indice)
If varmode([M]STRDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "STRDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_STRDAT([M]STRDAT(indice)) From SUBCTR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "STRDAT" : GZNUM = 14685 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WDATE<>[M]STRDAT(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_STRDAT([M]STRDAT(indice)) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "STRDAT" : GZNUM = 14685 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone TYP
mkstat = 0
zoncou = "TYP"
IMPENT = [M]TYP(indice)
If varinit([M]TYP,indice)=0
 IMPENT = 1
Endif
[M]TYP(indice) = IMPENT

## Zone STRPAY
mkstat = 0
zoncou = "STRPAY"
If varmode([M]STRPAY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_STRPAY([M]STRPAY(indice)) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]STRPAY(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "STRPAY" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]STRPAY(indice)=[0/0/0]
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "STRPAY" : GZNUM = 47958 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_STRPAY([M]STRPAY(indice)) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "STRPAY" : GZNUM = 47958 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone ENDPAY
mkstat = 0
zoncou = "ENDPAY"
If varmode([M]ENDPAY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_ENDPAY([M]ENDPAY(indice)) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]ENDPAY(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENDPAY" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]ENDPAY(indice)=[0/0/0]
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "ENDPAY" : GZNUM = 4024 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_ENDPAY([M]ENDPAY(indice)) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "ENDPAY" : GZNUM = 4024 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CTLDATV"
    Call CTLDATV([M]ENDPAY(indice),[M:CTRA]STRPAY(nolign-1)) From CONTDIV
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "ENDPAY" : GZNUM = 4024 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone VALORI
mkstat = 0
zoncou = "VALORI"
SAVACT = GACTION : GACTION = "STD"
Call AV_VALORI([M]VALORI(indice)) From SUBCTR
GACTION = SAVACT
If mkstat=1 : Raz [M]VALORI(indice) : Endif

## Zone VALDEN
mkstat = 0
zoncou = "VALDEN"
If varmode([M]VALDEN,indice)=0
 SAVACT = GACTION : GACTION = "AFMTSAI"
 Call ASAISIE([M]VALDEN(indice),[M]CODTYP(nolign-1)) From FMTVAR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]VALDEN(indice) : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call AS_VALDEN([M]VALDEN(indice)) From SUBCTR
  GACTION = SAVACT
  If mkstat=1 : Raz [M]VALDEN(indice) : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "VALDEN" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   If vireblc([M]VALDEN(indice),2)=""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "VALDEN" : GZNUM = 5231 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "AFMTCONT"
    Call CONTROLE([M]VALDEN(indice),[M]CODTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINTDEN(nolign-1)) From FMTVAR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "VALDEN" : GZNUM = 5231 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "ACONTACL"
     Call CONTACL([M]VALINTDEN(nolign-1),[M]CODTYP(nolign-1),"","") From SUBACL
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "VALDEN" : GZNUM = 5231 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "STD"
      Call C_VALDEN([M]VALDEN(indice)) From SUBCTR
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "VALDEN" : GZNUM = 5231 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone NBRRCR
mkstat = 0
zoncou = "NBRRCR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CTR10"
Return

