#<AdxTL>@(#)3.0.0.0 $Revision$

##################################################################################
# UCCNUPG 01/10/2008 FQ49477                                                                      
# MWA - Mise à jour de la table CCN Concession
#
# Alimentation du nouveau champ site FCY de la concession en fonction du site du 1er bien
# rattaché à la concession ( Si la concession ne possède aucun bien rattaché, elle est rattaché au site financier de la société).
#       
#
##################################################################################

 If (1=1) Then
 # Passage en test
 Call OUVRE_TRACE("CONCESSION Upgrade") From LECFIC
 Call PATCH(nomap)
 Call LEC_TRACE() From LECFIC
 Else
 # Passage en réel
 Call PATCH(nomap)
 Endif

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PAPPLI)
  Value Char    PAPPLI
  Gosub UPGRADE_CCN
End
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(PAPPLI)
  Value Char PAPPLI
  Gosub UPGRADE_CCN
End
########################################################################

#==
$UPGRADE_CCN

  # A ne pas faire sur le dossier racine.
  If ( PAPPLI = GDOSX3 ) Then : Return : Endif

  If filinfo(filpath("FIL","FACILITY"  ,"fde",PAPPLI),0)<=0 or
&    filinfo(filpath("FIL","BPARTNER"  ,"fde",PAPPLI),0)<=0 or
&    filinfo(filpath("FIL","ACTIV"     ,"fde",PAPPLI),0)<=0 or
&    filinfo(filpath("FIL","CONTEXT"   ,"fde",PAPPLI),0)<=0 or
&    filinfo(filpath("FIL","CONCESSION","fde",PAPPLI),0)<=0 or
&    filinfo(filpath("FIL","FXDASSETS" ,"fde",PAPPLI),0)<=0 
     # Tables n'existent pas 
     Return
  Endif

  #-----
  Call ECR_TRACE("UCCNUPG: Upgrade CONCESSION for Folder "+PAPPLI,0) From GESECRAN

  Local File =PAPPLI+".FACILITY"   [FCY]
  Local File =PAPPLI+".BPARTNER"   [BPR]
  Local File =PAPPLI+".ACTIV"      [ACV]  
  Local File =PAPPLI+".CONTEXT"    [CNX]
  Local File =PAPPLI+".CONCESSION" [CCN]
  Local File =PAPPLI+".CONCESSION" [CCN2]
  Local File =PAPPLI+".FXDASSETS"  [FAS]

  Local Integer BERROR     : BERROR  = 0
  Local Integer BACTCCN    : BACTCCN = 0
  Local Char LCPY(GLONCPY) : LCPY    = ""
  Local Char LCPY(GLONFCY) : LFCY    = ""

  Read [ACV] CODACT="CCN" 
  If (fstat) Then
    Call ECR_TRACE("UCCNACT - "-" Activity code CCN not found", 1) From GESECRAN
    BERROR = 1
  Else
    If ( [F:ACV]FLACT = 2 ) Then
      BACTCCN = 1
    Else
      BACTCCN = 0
    Endif
  Endif


  Trbegin [CCN]
  #====================
    # LDE Ne pas exécuter la moulinette s'il existe une concession dont le site est renseignée.
    Local Integer B_LDE : B_LDE = 0
    If ( BACTCCN ) Then
      Filter [CCN] Where FCY <> ""
      If ( rowcount([CCN]) > 0 ) Then : B_LDE = 1 : Endif
      Filter [CCN]
    Endif 
    If (!B_LDE and BACTCCN) Then 
      # Mise à jour BPARTNER
      If (!BERROR) Then : Gosub UPG_BPARTNER    : Endif
      # Mise à jour CONTEXTE
      If (!BERROR) Then : Gosub UPG_CONTEXTE    : Endif
      # Mise à jour CONCESSION & éventuellement CCNREF de FXDASSETS
      If (!BERROR) Then : Gosub UPG_CONCESSION  : Endif
      # Mise à jour FXDASSETS
      If (!BERROR) Then : Gosub UPG_FXDASSETS   : Endif
    Endif

  If (BERROR) Then
    Rollback
  Else
    Commit
  Endif
  
Return

########################################################################


#===============================
$UPG_BPARTNER

  # Ce traitement met à jour la table BPARTNER en y intégrant
  # les concédants des concessions
  # 
  If (!BACTCCN) Then : Return : Endif
  Local Integer ICPT : ICPT = 0

  # >>>>>>>>>>>>>>>>
  For [CCN]CCN0 

    Filter [BPR] Where BPRNAM(0) = [F:CCN]CCNUSR and CCNFLG = 2
    Read [BPR] First
    Filter [BPR] 
    If (fstat) Then
      Raz [F:BPR]     
      [F:BPR]BPRNUM    = "CCN"+num$(ICPT)
      [F:BPR]BPRNAM(0) = [F:CCN]CCNUSR
      [F:BPR]CUR       = "EUR"
      [F:BPR]BPCFLG    = 1
      [F:BPR]BPSFLG    = 1
      [F:BPR]CCNFLG    = 2
      Call ECR_TRACE("UCCNUPG - "-" ====> New partner"-"CCN"+num$(ICPT)-[F:BPR]BPRNAM(0), 0) From GESECRAN
      Write [BPR]
      If (fstat) Then
        BERROR = 1
        Call ECR_TRACE("UCCNUPG - "-" ====> I/O Error - FSTAT="-num$(fstat), 0) From GESECRAN
        Break 1
      Endif
      ICPT += 1 
    Endif

    Call ECR_TRACE("UCCNUPG - Partner"-[F:BPR]BPRNUM-"for CONCESSION reference"-[F:CCN]CCNREF, 0) From GESECRAN
    [F:CCN]CCNUSR = [F:BPR]BPRNUM 
    Rewrite [CCN]
    If (fstat) Then
      BERROR = 1
      Call ECR_TRACE("UCCNUPG - "-" ====> I/O Error - [CCN] Rewrite CCNREF="-[F:CCN]CCNREF-"fstat="-num$(fstat), 1) From GESECRAN
      Break 2    
    Endif

  Next
  # <<<<<<<<<<<<<<<<<

  Call ECR_TRACE("UCCNUPG - 01 - BPARTNER table has been checked", 0) From GESECRAN


Return


#===============================
$UPG_CONTEXTE

  # Ce traitement met à jour les champs de la table CONTEXT si le code activité CCN a été créé.

  # Si le code activité CCN a été créé
  #   Pour chaque contexte
  #     Initialisation des champs gérant les concession dans la table des contextes.
  #     Si contexte fiscale & comptable  
  #       Si la société possède au moins une concession 
  #          Concession géré à "Oui" et le mode de gestion "1er bien de la concession"
  #       Si la société ne possède pas de concession 
  #          Concession géré à "Non" et le mode de gestion = 0
  #      
  #   

  Local Integer BFIRST
  Local Integer BCCNFND
  BFIRST  = 1 
  LCPY    = ""
  # >>>>>>>>>>>>>>>>
  For [CNX]CNX0
    
    [F:CNX]CCNFLG      = 0
    [F:CNX]CCNMOD      = 0
    [F:CNX]CCNGRTFLG   = 0
    [F:CNX]CCNRPRTYP   = 0
    [F:CNX]CCNINDPLN   = 0
    [F:CNX]CCNGRTPLN   = 0
    [F:CNX]CCNCADPLN   = 0
     
    If ( [F:CNX]CPY <> LCPY  or BFIRST ) Then  
      BFIRST = 0 : LCPY = [F:CNX]CPY
      Filter [CCN] Where CPY = [F:CNX]CPY 
      If ( rowcount([CCN]) > 0 ) Then :   BCCNFND = 1 : Else : BCCNFND = 0 : Endif
      Filter [CCN]
    Endif

    If ([F:CNX]CNX = G300CPFI) Then
      If (BCCNFND) Then
        [F:CNX]CCNFLG      = G_OUI
        [F:CNX]CCNMOD      = 1
        BCCNFND = 0
      Else
        [F:CNX]CCNFLG      = G_NON
      Endif
    Endif

    Rewrite [CNX]
    If (fstat) Then
      BERROR = 1
      Call ECR_TRACE("UCCNUPG ====> I/O ERROR  CONTEXT Company"-[F:CNX]CPY-"Context"-[F:CNX]CNX-"fstat="-num$(fstat), 1) From GESECRAN
      Break 1    
    Endif

  Next
  # <<<<<<<<<<<<<<<<<

  Call ECR_TRACE("UCCNUPG - 02 - CONTEXT table has been updated", 0) From GESECRAN

Return
#######################################################################

#===============================
$UPG_CONCESSION

  # Ce traitement met à jour le champ FCY - établissement de la table CONCESSION
  # Pour chaque concession
  #   Le traitement vérifie si la concession est utilisée par au moins un bien
  #   Il vérifie ensuite si la concession est utilisée par un bien d'une autre société
  #
   
  Local Char    LFCY(GLONFCY)
  Local Integer B1FCY 
  # >>>>>>>>>>>>>>>>
  For [CCN]CCN1 With Stability
    LFCY    = ""
    BFASFND = 0
    Call ECR_TRACE("UCCNUPG - Concession"-[F:CCN]CCNREF - "Company"- [F:CCN]CPY , 0) From GESECRAN
    # 
    Filter [FAS] Where CCNREF=[F:CCN]CCNREF
    Read [FAS] First
    Filter [FAS]
    If !(fstat) Then
      BFASFND = 1     
      Local Char WFCY : WFCY = [F:FAS]FCY
      Filter [FAS] Where CCNREF =[F:CCN]CCNREF and FCY <> WFCY
      Read [FAS] First
      Filter [FAS]
      If (fstat) Then
        LFCY = WFCY
      Else     
        Call ECR_TRACE("UCCNUPG - "-[F:CCN]CCNREF - " Concession to split", 0) From GESECRAN
      Endif
    Endif

    If (LFCY = "" and !BFASFND) Then
      Filter [FCY] Where LEGCPY=[F:CCN]CPY and FINFLG = 2
      Read [FCY] First
      If !(fstat) Then
        LFCY = [F:FCY]FCY
      Endif
    Endif

    If (LFCY <> "") Then
      Call ECR_TRACE("UCCNUPG - "-[F:CCN]CCNREF - " ====> Facility"-LFCY, 0) From GESECRAN    
      [F:CCN]FCY       = LFCY
      [F:CCN]CCNSTA    = 2
      [F:CCN]DFTCCNFLG = 1
      Rewrite [CCN]
      If (fstat) Then
        BERROR = 1
        Call ECR_TRACE("UCCNUPG - "-[F:CCN]CCNREF - " ====> I/O Error - FSTAT="-num$(fstat), 0) From GESECRAN
        Break 1    
      Endif
    Endif
  Next
  # <<<<<<<<<<<<<<<<<

  Local Char WCCNREFO(GLONCCN)
  Local Char WCCNREFN(GLONCCN)
  # >>>>>>>>>>>>>>>>
  For [CCN]CCN1 Where FCY = "" With Stability
    BFIRST = 1
    LFCY   = ""
    WCCNREFO = [F:CCN]CCNREF
    Call ECR_TRACE("UCCNUPG - Concession"- WCCNREFO - "Company"-[F:CCN]CPY- "Splitting" , 0) From GESECRAN
    Filter [FAS] Where CCNREF = WCCNREFO
    # >>>>>>>>>>>>>>>>
    For [FAS]FAS2 With Stability

      If (BFIRST or LFCY <> [F:FAS]FCY) Then
        LFCY   = [F:FAS]FCY
        BFIRST = 0
        #==
        Gosub CCNREF_RECODIF
        #==
        [F:CCN2] = [F:CCN]
        [F:CCN2]CCNREF    = WCCNREFN
        [F:CCN2]FCY       = [F:FAS]FCY
        [F:CCN2]CCNSTA    = 2
        [F:CCN2]DFTCCNFLG = 1
        Write [CCN2]
        If !(fstat) Then
          Call ECR_TRACE("UCCNUPG - New Concession"-WCCNREFN-"Facility"-[F:FAS]FCY, 0) From GESECRAN
        Else
          BERROR = 1
          Call ECR_TRACE("UCCNUPG - "-" ====> I/O Error - [CCN] Write CCNREF="-WCCNREFN-"fstat="-num$(fstat), 1) From GESECRAN
          Break 2    
        Endif
      Endif

      [F:FAS]CCNREF = WCCNREFN
      Call ECR_TRACE("UCCNUPG - New Concession"-WCCNREFN-"for FXDASSETS reference"-[F:FAS]AASREF, 0) From GESECRAN
      Rewrite [FAS]
      If (fstat) Then
        BERROR = 1
        Call ECR_TRACE("UCCNUPG - "-" ====> I/O Error - [FAS] Rewrite AASREF="-[F:FAS]AASREF-"fstat="-num$(fstat), 1) From GESECRAN
        Break 2    
      Endif
    Next
    # >>>>>>>>>>>>>>>>
    Filter [FAS]

    If (!BFIRST) Then
      Call ECR_TRACE("UCCNUPG - Delete Concession"-WCCNREFO, 0) From GESECRAN
      Delete [CCN] Where CCNREF = WCCNREFO
      If (fstat) Then
        BERROR = 1
        Call ECR_TRACE("UCCNUPG - "-" ====> I/O Error - [CCN] Delete  CCNREF="-WCCNREFO-"fstat="-num$(fstat), 1) From GESECRAN
        Break 1    
      Endif
    Endif
  Next
  # <<<<<<<<<<<<<<<<<

  Call ECR_TRACE("UCCNUPG - 03 - CONCESSION table has been checked", 0) From GESECRAN
Return

$CCNREF_RECODIF
  Local Char  WCCNREF(GLONCCN)
  Local Char  WFCY(GLONFCY)
  WCCNREF = WCCNREFO
  WFCY    = [F:FAS]FCY
  If ( len(WCCNREF)+len(WFCY) < GLONCCN ) Then
    WCCNREFN = WCCNREF+"_"+WFCY
  Else
    Local Integer IT
    IT = (len(WCCNREF)+len(WFCY)+1)- GLONCCN
    WCCNREFN = left$(WCCNREF,(len(WCCNREF)-IT))+"_"+WFCY
  Endif
Return
#######################################################################

#===============================
$UPG_FXDASSETS

  # Ce traitement met à jour les biens dont le type de détention est "En concession"
  #   
  # Pour chaque bien "En concession"
  #   CCNETRNAT "Origine apport" = Concessionnaire
  #   CCNETRTYP "Type    apport" = Renouvellement

  Local Char    LFCY(GLONFCY)
  Local Integer B1FCY 

  # >>>>>>>>>>>>>>>>
  For [FAS]FAS2 Where OWNTYP = 5

    [F:FAS]CCNETRNAT = 2
    [F:FAS]CCNETRTYP = 2
    Rewrite [FAS]
    If (fstat) Then
      BERROR = 1
      Call ECR_TRACE("UCCNUPG - "-" ====> I/O Error - [FAS] Rewrite AASREF="-[F:FAS]AASREF-"fstat="-num$(fstat), 1) From GESECRAN
      Break 2    
    Endif
  Next
  # >>>>>>>>>>>>>>>>

  Call ECR_TRACE("UCCNUPG - 04 - FXDASSETS table has been checked", 0) From GESECRAN
Return

#######################################################################




