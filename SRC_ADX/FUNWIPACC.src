#<AdxTL>@(#)1.0.0.0 $Revision$
# Gestion du masque MWIPACC        T. Blanc 2003
# Comptabilisation d'en-cours OF à partir de la table WIPCOST
##########################################################################
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
$ACTION
Case ACTION
 When "INIT"         Gosub INIT
 When "OUVRE_BATCH"  Gosub INIT
 When "CONTROLE"     Gosub CONTROLE
 When "EXEC"         Gosub EXEC
 When "TERMINE"      Gosub TERMINE

 When "SEL_LISTE"
    If GACTION="SELVCRACC"
        Gosub SELVCRACC
    Endif
Endcase
Return

$INIT
If GMODU(2) <> 2
# "Le module Compta n'est pas présent"
   GMESSAGE = mess(174,196,1)
   GERR = 1
   Return
Endif
# paramètre code pièce automatique
If GACCWIPENT =""
   #"Paramètre non renseigné : ACCWIPENT"
   GMESSAGE = mess(136,199,1)-"ACCWIPENT"
   GERR = 1
   Return
Endif

Local Char ERR_TRA(132)
Local Integer LRET
Local Char    TZONE(10)(1..10)   : # Table des zones à forcer (Ex:réference simulation)
Local Char    TVAL(20)(1..10)    : # Table des valeurs des zones à forcer

If GMODU(8)=2
    If clalev([F:MFG])=0 : Local File MFGHEAD    [MFG] : Endif
    If clalev([F:MFO])=0 : Local File MFGOPE     [MFO] : Endif
    If clalev([F:MKM])=0 : Local File MFGMATTRK  [MKM] : Endif
    If clalev([F:MKO])=0 : Local File MFGOPETRK  [MKO] : Endif
    If clalev([F:MKI])=0 : Local File MFGITMTRK  [MKI] : Endif
Endif
If clalev([F:MWH])=0 : Local File MFGWIP     [MWH] : Endif
If clalev([F:MWI])=0 : Local File WIPCOST    [MWI] : Endif
If clalev([F:MWI2])=0 : Local File WIPCOST   [MWI2] : Endif
If clalev([F:MWT])=0 : Local File WIPTMP     [MWT] : Endif
If clalev([F:MWT1])=0 : Local File WIPTMP    [MWT1] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:STJ])=0 : Local File STOJOU     [STJ] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If GMODU(6)=2
    If clalev([F:SCO])=0 : Local File SCOHEAD    [SCO] : Endif
    If clalev([F:PTH])=0 : Local File PRECEIPT   [PTH] : Endif
    If clalev([F:PTD])=0 : Local File PRECEIPTD  [PTD] : Endif
Endif

Return

$CONTROLE
Local Char LEG(GLONADI)
If [M:MWIA]MFGFCY <> ""
    Call GETSOC([M:MWIA]MFGFCY) From DEVSUB
    LEG=GCURLEG
Endif
If GTRACE<>""
    Call ECR_TRACE(mess(97,187,1),0) From GESECRAN
Endif
If func FUNWIPACC.CTRVALPWA(nomap,LEG)
    FIN=1
    Return
Endif
If GTRACE<>""
    Call ECR_TRACE(mess(98,187,1),0) From GESECRAN
Endif
If func FUNWIPACC.CTRVALSWA(nomap,LEG)
    FIN=1
    Return
Endif
Return

$EXEC
If !GSERVEUR
   Call OUVRE_TRACE(mess(218,195,1)) From LECFIC
Endif
Lock WIPACC With lockwait=0  # à faire avant la génération du trt (eventuellmt lu par qq'un)
 ## ou locker par société à partir d'un code site saisi MAIS le trt généré ne doit pas être touché !
 # Lock identique dans l'objet PWA (paramétrage agrégation) avant de générer le trt
If fstat
  # Afficher un message d'erreur, car quelqu'un est déjà en train de comptabiliser les encours d'OF
   If GSERVEUR
      ERR_TRA = mess(270,197,1) # "Interface comptable deja en cours"
      Call ECR_TRACE(ERR_TRA,1) From GESECRAN
   Else
      GMESSAGE = mess(270,197,1)
      GERR = 1
   Endif
Else
  Call GENTRT(nomap,LRET)   # (sortir si il y a eu erreur)
  If LRET = 0
    Gosub CPTWIP
  Else
      If !GSERVEUR
          Call FERME_TRACE From LECFIC
          Call LEC_TRACE From LECFIC
      Endif
  Endif
Endif
Return

##########################################################################
## Etiquette utilisée par le générateur de pièce automatique (TB)
##########################################################################
$LIENDECL
Local Integer I

If dim(GLASTMWI)<=0 : Global Char GLASTMWI(250) : Endif
GLASTMWI = "VCRTYP="+num$([F:TB0]VCRTYP)-"VCRNUM="+[F:TB0]VCRNUM-"WIPSEQ="+num$([F:TB0]WIPSEQ)

#lien à établir à partir de la table déclenchante [MWT] (ouverte sous TB0 par le générateur)
Read [MWI]MWI5(3) = [F:TB0]VCRTYP;[F:TB0]VCRNUM;[F:TB0]WIPSEQ # identifiant suffisant
If fstat
    Raz [F:MWI]
Else
   GLASTMWI -= "TXNTYP="+num$([F:MWI]TXNTYP)-"MFGTRKNUM="+[F:MWI]MFGTRKNUM-"MFGTRKLIN="+num$([F:MWI]MFGTRKLIN)
   Read [MWH]MWH0=[F:MWI]VCRTYP;[F:MWI]VCRNUM
   If !fstat & [F:MWH]TRKTYP = 1
     Read [MFG]MFG0=[F:MWI]VCRNUM # pour les suivis sur OF
   Endif

   Case [F:MWI]VCRTYP
      When 10,37 :  # Issue 97537 - 2014-03-06 by CCC : add 37
         # lecture des lignes de suivi selon type de wipcost >> lire aussi les tables d'OF ??
         If [F:MWI]TXNTYP = 1 | ([F:MWI]TXNTYP = 5 & [F:MWI]MATOVETYP=2)
           Read [MKM]MKM0=[F:MWI]MFGTRKNUM;[F:MWI]MFGTRKLIN
           If [F:MWI]TXNTYP = 1
              # mettre en ligne un mouvement de stock pour pouvoir récupérer les CCE ...
              # Filter [STJ] Where STOFCY=[F:MWI]MFGFCY & VCRTYP=12 & VCRNUM=[F:MWI]MFGTRKNUM & VCRLIN=[F:MWI]MFGTRKLIN
              # lire directement le premier
              Read [STJ]STJ1=[F:MWI]MFGFCY;12;[F:MWI]MFGTRKNUM;[F:MWI]MFGTRKLIN
              If fstat Raz [F:STJ] Endif
           Endif
         Elsif find ([F:MWI]TXNTYP,2,3,4,6,7,8)
           Read [MKO]MKO0=[F:MWI]MFGTRKNUM;[F:MWI]MFGTRKLIN
         Elsif [F:MWI]TXNTYP = 14 | ([F:MWI]TXNTYP = 5 & [F:MWI]MATOVETYP=1)
           Read [MKI]MKI0=[F:MWI]MFGTRKNUM;[F:MWI]MFGTRKLIN # déclaration ou frais entrée produit

           If [F:MWI]TXNTYP=14
              Read [STJ]STJ1=[F:MWI]MFGFCY;15;[F:MWI]MFGTRKNUM;[F:MWI]MFGTRKLIN
              If fstat Raz [F:STJ] Endif
           Endif
           If [F:MWI]VCRTYP=10
               # CCC (22/11/05) DM 33294
               Read [MFO]MFO0(1)=[F:MWI]VCRNUM
               [G:MFO]currlen = 0
               If fstat
                 Raz [F:MFO]
               Endif
           Endif
         Endif
      When 36 :
          Raz [F:PTH], [F:PTD]
          Read [F:PTH]PTH0=[F:MWI]MFGTRKNUM
          Read [F:PTD]PTD0=[F:MWI]MFGTRKNUM;[F:MWI]MFGTRKLIN
          # Issue 66503 - 2010-09-03 by CCC : Lecture du STJ associé au txntyp=14
          If find([F:MWI]TXNTYP,1,14)
              # mettre en ligne un mouvement de stock pour pouvoir récupérer les CCE ...
              # Filter [STJ] Where STOFCY=[F:MWI]MFGFCY & VCRTYP=5 & VCRNUM=[F:MWI]MFGTRKNUM & VCRLIN=[F:MWI]MFGTRKLIN
              # lire directement le premier
              Read [STJ]STJ1=[F:MWI]MFGFCY;6;[F:MWI]MFGTRKNUM;[F:MWI]MFGTRKLIN
              If fstat : Raz [F:STJ] : Endif
          Endif
   Endcase
 # CCC (01/08/05) Bug 31549
 If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
 Call GETDEV([MWI]MFGFCY) From DEVSUB
 [F:MWI]AMOUNT = arr([F:MWI]AMOUNT,[F:TCU]CURRND)
 For I=0 To dim([F:MWI]CSTELM)-1
    [F:MWI]CSTELM(I) = arr([F:MWI]CSTELM(I),[F:TCU]CURRND)
 Next
Endif

# CCC (08/03/06) DM 35203
GPOINT="LNKWIPACC"
Gosub ENTREE From EXEFNC

Return

############################################################################################
Subprog CHECK_CLOSEDTE(CLOSEDTE,MFGNUM,OK)
Value    Integer    CLOSEDTE
Value    Char       MFGNUM
Variable Integer    OK : Raz OK
#-----------------------------------------------------------------------------
#    CLOSEDTE - contains the type of the date range criteria to check
#               Possible values are 1,2,or 3
#               CLOSEDTE = 1 :  Check against starting close date only
#               CLOSEDTE = 2 :  Check against ending close date only
#               CLOSEDTE = 3 :  Check against both start and end close date
#-----------------------------------------------------------------------------
#    MFGNUM - contains the work order number used to look up MFGHEAD
#-----------------------------------------------------------------------------
#    OK - is the returned status. If OK = 1 close date is ok
#                                 If OK = 0 close date is not ok
#-----------------------------------------------------------------------------

Local    Char    MSG(250)
Local    Date    CLO_DAT

# Issue X3-55305 - 2017-11-03 by ERMIL : Performance: Remove reads and move to link on main loop
#Read [MWH]MWH0=[F:MWI]VCRTYP;[F:MWI]VCRNUM    # lecture entete Wip MWH

If [F:MWH]TRKTYP > 1
  CLO_DAT = [F:MWH]ENDDAT # suivis sans OF
Else
  Case [F:MWI]VCRTYP
    When 10 :
      #Read [MFG]MFG0 = [F:MWI]VCRNUM  # X3-55305.o
      #If fstat
      If [F:MFG]MFGNUM<>[F:MWI]VCRNUM  # X3-55305.n
        MSG = mess(12,100,1)-"MFGHEAD"-[F:MWI]VCRNUM  # Erreur d'accès sur le fichier MFGHEAD...
        Call ECR_TRACE(MSG,1) From GESECRAN
        End
      Else
        CLO_DAT = [F:MFG]CLODAT
      Endif
    When 36 :
			#Read [SCO]SCO0 = [F:MWI]VCRNUM  # X3-55305.o
			#If fstat
      If [F:SCO]SCONUM<>[F:MWI]VCRNUM  # X3-55305.n
        MSG = mess(12,100,1)-"SCOHEAD"-[F:MWI]VCRNUM  # Erreur d'accès sur le fichier MFGHEAD...
        Call ECR_TRACE(MSG,1) From GESECRAN
        End
      Else
        CLO_DAT = [F:SCO]CLODAT
      Endif
  Endcase
Endif

Case CLOSEDTE
   When 0 : OK = 1 # autoriser sélection date vide
   When 1 : # Only starting date
            If CLO_DAT >= [M:MWIA]CLODATDEB : OK = 1 : Endif
   When 2 : # Only ending date
            If CLO_DAT <= [M:MWIA]CLODATFIN : OK = 1 : Endif
   When 3 : # Both start and end date
            If (CLO_DAT >= [M:MWIA]CLODATDEB & CLO_DAT <= [M:MWIA]CLODATFIN) : OK = 1 : Endif
Endcase
End

##########################################################################
Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Effzo [M]MFGFCY
  Grizo [M:MWIA]MFGFCY
Else
  Actzo [M:MWIA]MFGFCY
Endif
End
############################################################################################

Subprog D_MFGFCY(VALEUR)
Variable Char    VALEUR()
Local Char LOPEIFA(10), LSCOIFA(10)
If [M:MWIA]ALLFCY<>2
    Case [M:MWIA]VCRTYP
     When 36
       Call FIND_GFCYDEF(6) From TRTX3  # FQ 54218
     When 10, 37
       Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
    Endcase
    Call PARAM([M:MWIA]MFGFCY, "OPEIFA", LOPEIFA) From ADOVAL
    Call PARAM([M:MWIA]MFGFCY, "SCOIFA", LSCOIFA) From ADOVAL
    If (val(LOPEIFA)<2) & (val(LSCOIFA)<2)
        Raz GFCY
    Endif
    VALEUR = GFCY
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran MWIPACC) 21/05/2010 10:14:28 (CCC)
######################################################################################
Subprog C_MFGFCY(VALEUR)
Variable Char    VALEUR()
Local Char LOPEIFA(10), LSCOIFA(10)
    Call PARAM(VALEUR, "OPEIFA", LOPEIFA) From ADOVAL
    Call PARAM(VALEUR, "SCOIFA", LSCOIFA) From ADOVAL
    If val(LOPEIFA)<2 & val(LSCOIFA)<2
        GMESSAGE=mess(99,187,1)
        mkstat=2
    Endif
End


######################################################################################
Subprog AM_ALLTXN(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Grizo TXNTYP
Else
  Actzo TXNTYP
Endif
End

##########################################################################
Subprog C_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()

Filter [MWH] # pour 'défiltrer' après la sélection

If VALEUR = ""
  If dim(SELVCR) > 0 and SELVCR <> 0
    mkstat=2 : Kill SELVCR
  Endif
  End
Endif

# Controler que l'entete WIP est bien du site choisi
Read [MWH]MWH0=[M:MWIA]VCRTYP;VALEUR
If fstat
  mkstat=2
  GMESSAGE = mess(23,100,1)     # Record does not exist
Elsif [M]MFGFCY<>"" & [F:MWH]MFGFCY <> [M]MFGFCY
  mkstat=2
  GMESSAGE = mess(82,116,1)     # Site incorrect
Endif

If dim(SELVCR) > 0 : Kill SELVCR : Endif

End

######################################################################################
Subprog AM_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
    If [M:MWIA]VCRNUMFIN="" | [M:MWIA]VCRNUMFIN=[M:MWIA]VCRNUMDEB
        [M:MWIA]VCRNUMFIN=VALEUR
    Endif
End

##########################################################################
Subprog C_MFGNUMFIN(VALEUR)
Variable Char    VALEUR()
Call C_VCRNUMDEB(VALEUR)
End



#####################################################################################
# Génération du traitement automatique à partir des paramètres de la table PARWIPACC
#       appelée aussi à la création/modif des paramètres
Subprog GENTRT(PDOS,PRET)
Value Char PDOS
Variable Integer PRET

Raz PRET

If clalev([F:PWA])=0 : Local File =PDOS+".PARWIPACC"  [PWA] Endif
If clalev([F:SWA])=0 : Local File =PDOS+".PARWIPACCS" [SWA] Endif # CCC (2009-09-24) Bug 57871 : Ouvrir SWA si nécessaire
Local Integer I,STAT, VALOK
Local Char TRTGEN(20),FICTRT(250)
Local Char SAV_IFS(10), SAV_IRS(10)

TRTGEN='WRWIPACC'
FICTRT=filpath('TRT',TRTGEN,'src',PDOS)

SAV_IFS = adxifs # sauvegarde des variables systèmes séparateurs
SAV_IRS = adxirs
adxifs = ""
adxirs = chr$(10)  # ou utiliser Iomode

Openo FICTRT , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision:   1.0  $"-"Alimentation du fichier temporaire d'agrégation"
Wrseq
Wrseq "$LOAD_MWT"
Wrseq " [F:MWT]=[F:MWI]" : # La table temporaire de clés a comme abréviation [MWT]

Wrseq " If [F:FCY]FCY<>[F:MWI]MFGFCY"
Wrseq "      Read [FCY]FCY0=[F:MWI]MFGFCY"
Wrseq " Endif"
Wrseq " [F:MWT]CPY=[FCY]LEGCPY"
Wrseq " If [F:CPY]CPY<>[F:MWT]CPY"
Wrseq "    Read [CPY]CPY0=[F:MWT]CPY"
Wrseq " Endif"

Wrseq "If find([F:MWT]VCRTYP,10,37)"    # Issue 97537 - 2014-03-06 by CCC : add 37
Filter [PWA] Order By Key PWA0 Desc
Wrseq " Case [F:CPY]LEG"
For [PWA]PWA0(1)
    If [PWA]LEG<>""
        Wrseq "     When '"+num$([F:PWA]LEG)+"'"
    Else
        Wrseq "     When Default"
    Endif
    Wrseq "         Case [F:MWT]CPY"
    For [PWA]PWA0(2)
        If [PWA]CPY<>""
            Wrseq "             When '"+num$([F:PWA]CPY)+"'"
        Else
            Wrseq "             When Default"
        Endif
        Wrseq "                 Case [F:MWI]TXNTYP"

        For [PWA]PWA0
            Wrseq "                     When "+num$([PWA]TXNTYP)
            For I=1 To 5
                If evalue("[F:PWA]KEY"+num$(I))<>""
                    Wrseq "                         [F:MWT]KEY"+num$(I)+"="+evalue("[F:PWA]KEY"+num$(I))
                    # Issue 87615 - 2013-01-29 by CCC
                    Wrseq "                         [F:MWT]KEY"+num$(I)+"+= string$([MWT]KEY"+num$(I)+"='','#')"
                Else
                   # faire comme pour les stocks pour éviter un mauvais filtre par le trt compta :
                    Wrseq "                         [F:MWT]KEY"+num$(I)+"='~'"
                Endif
            Next
        Next
        Wrseq "                 Endcase"
    Next
    Wrseq "          Endcase"
Next
Wrseq " Endcase"
Filter [PWA]
Wrseq "Elsif [F:MWT]VCRTYP=36"
Wrseq " Case [F:CPY]LEG"
Filter [SWA] Order By Key SWA0 Desc
For [SWA]SWA0(1)
    If [SWA]LEG<>""
        Wrseq "     When '"+num$([F:SWA]LEG)+"'"
    Else
        Wrseq "     When Default"
    Endif
    Wrseq "         Case [F:MWT]CPY"
    For [SWA]SWA0(2)
        If [SWA]CPY<>""
            Wrseq "             When '"+num$([F:SWA]CPY)+"'"
        Else
            Wrseq "             When Default"
        Endif
        Wrseq "                 Case [F:MWI]TXNTYP"

        For [SWA]SWA0
            Wrseq "                     When "+num$([SWA]TXNTYP)
            For I=1 To 5
                If evalue("[F:SWA]KEY"+num$(I))<>""
                    Wrseq "                         [F:MWT]KEY"+num$(I)+"="+evalue("[F:SWA]KEY"+num$(I))
                    # Issue 87615 - 2013-01-29 by CCC
                    Wrseq "                         [F:MWT]KEY"+num$(I)+"+= string$([MWT]KEY"+num$(I)+"='','#')"
                Else
                   # faire comme pour les stocks pour éviter un mauvais filtre par le trt compta :
                    Wrseq "                         [F:MWT]KEY"+num$(I)+"='~'"
                Endif
            Next
        Next
        Wrseq "                 Endcase"
    Next
    Wrseq "          Endcase"
Next
Wrseq " Endcase"
Filter [SWA]
Wrseq "Endif"
Wrseq "Return"

Openo

adxifs = SAV_IFS
adxirs = SAV_IRS
Call VALID("TRT",TRTGEN,PDOS,PRET) From VALMSKSUB
If PRET = 0
    PRET=2
    Call ECR_TRACE(mess(20,123,1),1) From GESECRAN    #"Erreur en validation du traitement
Else
    Raz PRET
Endif
End

######################################################
Funprog CTRVALPWA(PDOS,PLEG)
Value Char PDOS
Value Char PLEG

If clalev([F:PWA])=0 : Local File =PDOS+".PARWIPACC"  [PWA] Endif
Local Integer LRET
Local Integer LNB, LTYPERR

If PLEG=""
    # Issue 94243 - 2014-11-24 by CCC
    #CRITERE = "1=1"
    CRITERE = "find(LEG,GDOSLEG)<>0 & LEG<>''"
Else
    CRITERE = "LEG='"+PLEG+"'"
Endif
For [PWA]PWA0(1) Where evalue(CRITERE)
    For [PWA]PWA0(2)
        Raz LNB, LTYPERR
        For [PWA]PWA0
            LNB +=1
            If [F:PWA]TXNTYP<>LNB
                LTYPERR=LNB
                Break
            Endif
        Next
        If LTYPERR=0 & [F:PWA]TXNTYP<>len(mess(0,2358,1))
            LTYPERR=len(mess(0,2358,1))
        Endif
        If LNB<>len(mess(0,2358,1))
            LRET=1
            If GTRACE<>""
                # En validation de dossier on fait juste un warning
                Call ECR_TRACE(mess(238,133,1)+":"+[F:PWA]LEG-mess(2,45,1)+":"+[F:PWA]CPY-mess(161,7770,1)-mess(LTYPERR,2358,1),-1) From GESECRAN
            Else
                Call ERREUR(mess(97,187,1)+"\"+mess(238,133,1)+":"+[F:PWA]LEG-mess(2,45,1)+":"+[F:PWA]CPY-mess(161,7770,1)-mess(LTYPERR,2358,1)) From GESECRAN
                Break 2
            Endif
        Endif
    Next
Next

For I=1 To GNBLEG
    If PLEG="" | GDOSLEG(I)=PLEG
        Filter [PWA] Where LEG=GDOSLEG(I)
        Look [PWA] First
        Filter [PWA]
        If fstat
            LRET=2
            # Paramétrage incomplet
            If GTRACE<>""
                Call ECR_TRACE(mess(161,7770,1)-":"-mess(238,133,1)+"="+GDOSLEG(I),1) From GESECRAN
            Else
                Call ERREUR(mess(97,187,1)+"\"+mess(161,7770,1)-":"-mess(238,133,1)+"="+GDOSLEG(I)) From GESECRAN
                Break
            Endif
        Endif
    Endif
Next

End LRET

#########################################################
Funprog CTRVALSWA(PDOS,PLEG)
Value Char PDOS
Value Char PLEG

If clalev([F:SWA])=0 : Local File =PDOS+".PARWIPACCS" [SWA] Endif # CCC (2009-09-24) Bug 57871 : Ouvrir SWA si nécessaire

Local Char CRITERE(250)
Local Integer LRET
Local Integer LNB, LTYPERR
Local Integer LTABTYPS(8)
LTABTYPS(0)=2
LTABTYPS(1)=3
LTABTYPS(2)=6
LTABTYPS(3)=7
LTABTYPS(4)=10
LTABTYPS(5)=11
LTABTYPS(6)=16
LTABTYPS(7)=18

If PLEG=""
    # Issue 94243 - 2014-11-24 by CCC
    #CRITERE = "1=1"
    CRITERE = "find(LEG,GDOSLEG)<>0 & LEG<>''"
Else
    CRITERE = "LEG='"+PLEG+"'"
Endif

For [SWA]SWA0(1) Where evalue(CRITERE)
    For [SWA]SWA0(2)
        Raz LNB
        For [SWA]SWA0
            LNB +=1
            While find(LNB,LTABTYPS)
                LNB+=1
            Wend
            If [F:SWA]TXNTYP<>LNB
                LTYPERR=LNB
                Break
            Endif
        Next
        If LTYPERR=0 & [F:SWA]TXNTYP<>len(mess(0,2358,1))
            LTYPERR=len(mess(0,2358,1))
        Endif
        If LNB<>len(mess(0,2358,1))
            LRET=1
            If GTRACE<>""
                # En validation de dossier on fait juste un warning
                Call ECR_TRACE(mess(238,133,1)+":"+[F:SWA]LEG-mess(2,45,1)+":"+[F:SWA]CPY-mess(161,7770,1)-mess(LTYPERR,2358,1),-1) From GESECRAN
            Else
                Call ERREUR(mess(98,187,1)+"\"+mess(238,133,1)+":"+[F:SWA]LEG-mess(2,45,1)+":"+[F:SWA]CPY-mess(161,7770,1)-mess(LTYPERR,2358,1)) From GESECRAN
                Break 2
            Endif
        Endif
    Next
Next
For I=1 To GNBLEG
    If PLEG="" | GDOSLEG(I)=PLEG
        Filter [SWA] Where LEG=GDOSLEG(I)
        Look [SWA] First
        Filter [SWA]
        If fstat
            LRET=2
            # Paramétrage incomplet
            If GTRACE<>""
                Call ECR_TRACE(mess(161,7770,1)-":"-mess(238,133,1)+"="+GDOSLEG(I),1) From GESECRAN
            Else
                Call ERREUR(mess(98,187,1)+"\"+mess(161,7770,1)-":"-mess(238,133,1)+"="+GDOSLEG(I)) From GESECRAN
                Break
            Endif
        Endif
    Endif
Next
End LRET

#
# Sous-programme de comptabilisation exploitant WIPCOST
#
$CPTWIP
Local Integer CLOSEDTE, OK, NBWIPTRT, STAT, STOP, ICRIT
Local Char    MESSA(250), CRITERE(80), CRITSEL(250)(2)
Local Char    IDENT(30)(1..10)
Local Char    CLE1(GLONVCR)
Local Integer CLE2, CLE3          # pour se repositionner après une boucle
Local Char    PCEDEB(GLONVCR)
Local Char    LOPEIFA(10), LSCOIFA(10), LACCIFA(10), LFCY(GLONFCY), LLEG(GLONADI), LNULIFA(10)
Local Decimal LARR : LARR=0 # Issue 91861 - 2014-11-21 by CCC

#----------------------------------------------------
#   Criteres pour le filtre sur WIPCOST
#----------------------------------------------------
Raz CRITSEL
# Select only records that have not been posted.
Call ADDCRIT(CRITSEL,ICRIT,"","[F:MWI]GLPSTA<>2","&") From GOBJSUB

# If not all sites selected, filter on the site entered
If [M:MWIA]ALLFCY <> 2
    Call ADDCRIT(CRITSEL,ICRIT,"","[F:MWI]MFGFCY='"+[M:MWIA]MFGFCY+"'","&") From GOBJSUB
Endif

Call ADDCRIT(CRITSEL,ICRIT,"","[F:MWI]VCRTYP="+num$([M:MWIA]VCRTYP),"&") From GOBJSUB

# If not all transactions selected, filter on the transaction entered
If [M:MWIA]ALLTXN<>2
    Call ADDCRIT(CRITSEL,ICRIT,"","[F:MWI]TXNTYP="+num$([M:MWIA]TXNTYP),"&") From GOBJSUB
Endif

# Borne d'OF
If [M:MWIA]VCRNUMDEB<>""
    Call ADDCRIT(CRITSEL,ICRIT,"","[F:MWI]VCRNUM>='"+[M:MWIA]VCRNUMDEB+"'","&") From GOBJSUB
Endif
If [M:MWIA]VCRNUMFIN<>""
    Call ADDCRIT(CRITSEL,ICRIT,"","[F:MWI]VCRNUM<='"+[M:MWIA]VCRNUMFIN+"'","&") From GOBJSUB
Endif

If [M:MWIA]PRODAT<>[0/0/0]
    Call ADDCRIT(CRITSEL,ICRIT,"","[F:MWI]TXNDAT<=[M:MWIA]PRODAT","&") From GOBJSUB
Endif


# DATE de cloture OF (ou de fin pour un entete Wip sans OF)
#---------------------------------------------------------------
#    CLOSEDTE = 0 :  Open close date range, (no restriction)
#    CLOSEDTE = 1 :  Only starting close date
#    CLOSEDTE = 2 :  Only ending close date
#    CLOSEDTE = 3 :  Both start and end close date
#---------------------------------------------------------------
Raz CLOSEDTE
If [M:MWIA]CLODATDEB <> [0/0/0]
   CLOSEDTE = 1
Endif
If [M:MWIA]CLODATFIN <> [0/0/0]
   CLOSEDTE += 2
Endif


# On efface tout ce qui se trouve dans le fichier temporaire de clés
Trbegin [MWT]
   Delete [MWT] Where 1=1
Commit

# Issue 89393 - 2013-04-18 by CCC
Local Integer FILACCNUL     # Mettre une valeur <>0 pour déclencher le PE FILACCNUL
FILACCNUL=0
GPOINT = "FILACC"
Gosub ENTREE From EXEFNC

# Remplissage de la table de clés
Raz STOP
$DEBTRANS
If STOP = 1
  STOP = 2
  CRITERE = "[F:MWI]VCRTYP=CLE3 & [F:MWI]VCRNUM=CLE1 & [F:MWI]WIPSEQ>CLE2"
Elsif STOP = 2
  STOP = 3
  CRITERE = "[F:MWI]VCRTYP=CLE3 & [F:MWI]VCRNUM>CLE1"
Elsif STOP = 3
  STOP = 0
  CRITERE = "[F:MWI]VCRTYP>CLE3"
Else
  CRITERE = "1=1"
Endif

NBWIPTRT=0
Call DEBTRANS From GLOCK
Trbegin [MWT]

Onerrgo ERR_KEY

# Parcours des wipcost non comptabilisés ! ATTENTION la clé primaire comprend MFGNUM et TXNTYP
# Cas possible de (MFGNUM,WIPSEQ) identiques (FG avec incrément, concurrent avec autre suivi)?!
# auquel cas il faudrait inclure TXNTYP dans le repositionnement
# Issue X3-55305 - 2017-11-03 by ERMIL : Performance - link to MFG, MWH and SCO to reduce database reads in CHECK_CLOSEDATE
Link [MWI] With [MWH]MWH0~=[F:MWI]VCRTYP;[F:MWI]VCRNUM, [MFG]MFG0=[F:MWI]VCRNUM, [SCO]SCO0=[F:MWI]VCRNUM As [WIPLNK]
& Where [MWI]ENTCOD<>"" & evalue(CRITERE) & evalue(CRITSEL)

#For [MWI]MWI5 Where ENTCOD<>"" & evalue(CRITERE) & evalue(CRITSEL)  # X3-55305.o
For [WIPLNK]MWI5
    If LFCY<>[F:MWI]MFGFCY
        LFCY=[F:MWI]MFGFCY
        Call PARAM([F:MWI]MFGFCY,"OPEIFA",LOPEIFA) From ADOVAL
        LLEG = func TRTX3FNC.GETLEG([F:MWI]MFGFCY)    # Se positionne sur [F:CPY]
        Call PARAM([F:MWI]MFGFCY,"NULAMTIFA",LNULIFA) From ADOVAL
        Call PARAM([F:MWI]MFGFCY,"SCOIFA",LSCOIFA) From ADOVAL

        # Issue 91861 - 2014-11-21 by CCC : get currency rounding
        Call GETDEV([F:MWI]MFGFCY) From DEVSUB  # read TCU
        LARR = [F:TCU]CURRND
    Endif
    # Issue 97537 - 2014-03-06 by CCC : add 37
    If find([F:MWI]VCRTYP,10,37) & val(LOPEIFA)<2
&    | [F:MWI]VCRTYP=36 & val(LSCOIFA)<2
        # conserver la clé courante
        CLE3 = [F:MWI]VCRTYP
        CLE1 = [F:MWI]VCRNUM
        CLE2 = [F:MWI]WIPSEQ
        # Issue 99004 - 2015-02-13 by CCC
        #Update [MWI] Where MFGFCY=LFCY & GLPSTA<>2 With GLPSTA=2
        Update [MWI2] Where MFGFCY=LFCY & GLPSTA<>2 & VCRTYP=[F:MWI]VCRTYP With GLPSTA=2
        # Si on ne comptabilise pas non plus via l'interface stock, on en profite pour mettre à jour les STJ
        Call PARAM([F:MWI]MFGFCY,"ACCIFA",LACCIFA) From ADOVAL
        If val(LACCIFA)<2
            Update [STJ] Where STOFCY=LFCY & AGGIFAFLG<>2 With AGGIFAFLG=2
        Endif
        STOP=2  # On passe directement au document suivant
        Break
    Endif

    # Issue 89393 - 2013-04-18 by CCC
    #   Positionner GPE à 1 pour forcer la comptabilisation
    #   Positionner GPE à 2 pour forcer la non comptabilisation
    GPE=0
    If FILACCNUL<>0
        GPOINT="FILACCNUL"
        Gosub ENTREE From EXEFNC
    Endif

#    If LNULIFA<>"2" & [F:MWI]AMOUNT=0 & GPE=0 | GPE=2
    If GPE=2
&    | GPE=0
&    & LNULIFA<>"2"
&    & ( [F:MWI]TXNTYP<>17 & arr([F:MWI]AMOUNT,LARR)=0
&      | [F:MWI]TXNTYP=17 & arr([F:MWI]CSTELM(9),LARR)=0 & arr([F:MWI]CSTELM(10),LARR)=0 )        # Issue 91861 - 2014-11-21 by CCC : use currency rounding to test null value
        # conserver la clé courante
        CLE3 = [F:MWI]VCRTYP
        CLE1 = [F:MWI]VCRNUM
        CLE2 = [F:MWI]WIPSEQ
        [F:MWI]GLPSTA=2
        Rewrite [MWI]
        If !fstat & find([F:MWI]TXNTYP,1,14)
         # pour sortie matière et entrée de produit : màj les mvts stocks correspondants
            If [F:MWI]TXNTYP=1
                Update [STJ] Where STOFCY=[F:MWI]MFGFCY
&                          & VCRTYP=12
&                          & VCRNUM=[F:MWI]MFGTRKNUM
&                          & VCRLIN=[F:MWI]MFGTRKLIN
&                          & AGGIFAFLG<>2
&                    With AGGIFAFLG=2
                # Call the Point in time valuation routine
                Call PITWIPUPD([F:MWI]ITMREF, [F:MWI]MFGFCY, 12, [F:MWI]MFGTRKNUM, [F:MWI]MFGTRKLIN) From STKPITLIB
            Elsif [F:MWI]TXNTYP=14
                Update [STJ] Where STOFCY=[F:MWI]MFGFCY
&                          & VCRTYP=15
&                          & VCRNUM=[F:MWI]MFGTRKNUM
&                          & VCRLIN=[F:MWI]MFGTRKLIN
&                          & AGGIFAFLG<>2
&                    With AGGIFAFLG=2
                # Call the Point in time valuation routine
                Call PITWIPUPD([F:MWI]ITMREF, [F:MWI]MFGFCY, 15, [F:MWI]MFGTRKNUM, [F:MWI]MFGTRKLIN) From STKPITLIB
            Endif
        Endif
    Else
        # si l'enreg porte sur un OF vérifier la date par rapport à la sélection
        Call CHECK_CLOSEDTE(CLOSEDTE,[F:MWI]VCRNUM,OK)
        If OK
            Gosub LOAD_MWT From WRWIPACC : # chargement de MWT par le traitement généré
            If GOK = 0
                Break  # en cas d'erreur d'évaluation des KEYx
            Endif
            Write [MWT]
            If fstat
                ERR_TRA = mess(22,2363,1)-"WIPTMP" #"ERREUR à la génération de la table temporaire"
                Call ECR_TRACE(ERR_TRA,1) From GESECRAN
                GOK = 0
                Break
            Endif
            NBWIPTRT+=1
            If NBWIPTRT>GMAXUPDTRS
                # conserver la clé courante
                CLE3 = [F:MWI]VCRTYP
                CLE1 = [F:MWI]VCRNUM
                CLE2 = [F:MWI]WIPSEQ
                STOP = 1
                Break
            Endif
        Endif
    Endif
Next

Onerrgo
If GOK
    Commit
# Issue 80331 - 2012-02-23 by CCC
#    If NBWIPTRT>1000 | STOP  # retraiter la table à partir du repositionnement
    If STOP  # reparcourir la table à partir du repositionnement
        Goto DEBTRANS
    Endif
Else
    Rollback
    Return
Endif

# Exploitation de la table de clés pour passer les écritures
# On ouvre le masque d'en-tête de pièce pour récupérer la pièce passée
Local Mask GACCENT0 [HAE0]
For [MWT1]MWT0(2) :  # Pour chaque modèle de pièce automatique à générer, et chaque société
  IDENT(1)=[MWT1]ENTCOD
  IDENT(2)=[MWT1]CPY
  # charger GCUR (devise de la société utilisée dans les pièces)
  GISOC = find([F:MWT1]CPY,GSOC(1..GNBSOC))
  If GISOC=0
      ERR_TRA = mess(16,104,1) - [F:MWT1]CPY-[F:MWT1]VCRNUM-num$([F:MWI]WIPSEQ)-mess([F:MWI]TXNTYP,2358,1)
      Call ECR_TRACE(ERR_TRA,1) From GESECRAN
      Goto NEXT_MWT
  Endif
  GCUR  = GDEVSOC(GISOC)

  Raz PCEDEB
  For [MWT1]MWT0(7) : # On regroupe par critères d'agrégation
    IDENT(3)=[MWT1]KEY1
    IDENT(4)=[MWT1]KEY2
    IDENT(5)=[MWT1]KEY3
    IDENT(6)=[MWT1]KEY4
    IDENT(7)=[MWT1]KEY5  # toute la clé sauf l'identifiant de l'enreg wipcost
    IDENT(8)=""
    IDENT(9)=""
    IDENT(10)=""

    Call DEBTRANS From GLOCK
    Trbegin [MWI]
    TZONE(5)= "ORIGIN" : TVAL(5)= "2"             : # X3-39795 Automatic loading
    TZONE(6)= "ORICOD" : TVAL(6)= [MWT1]ENTCOD    : # X3-39795
#---
    # X3-39795  Call VALPCE([MWT1]ENTCOD,IDENT,STAT,MESSA) From CPTAUTO
    Call VALPCE3([MWT1]ENTCOD,IDENT,STAT,MESSA,TZONE,TVAL) From CPTAUTO : # Pièce auto basée sur [MWT] lié à [MWI]
    If STAT=0 : # La pièce a été créée, on va mettre à jour le numéro de pièce dans WIPCOST
                # il y a 1 MWI pour 1 MWT. Une pièce créée par n-uplets key1...key5
      For [MWT1]MWT0
        Readlock [MWI]MWI5(3)=[F:MWT1]VCRTYP;[F:MWT1]VCRNUM;[F:MWT1]WIPSEQ
        [F:MWI]JOUTYP = [M:HAE0]TYP
        [F:MWI]JOUNUM = [M:HAE0]NUM
        [F:MWI]GLPSTA = 2
        [F:MWI]GLPDAT = date$
        Rewrite [MWI]
        If !fstat & find([F:MWI]TXNTYP,1,14,17,9)
         # pour sortie matière et entrée de produit : màj les mvts stocks correspondants
         If [F:MWI]TXNTYP=1
          # Issue 97371 - 2014-11-26 by CCC : Add test on NUMVCR
          Update [STJ] Where STOFCY=[F:MWI]MFGFCY
&                          & VCRTYP=12
&                          & VCRNUM=[F:MWI]MFGTRKNUM
&                          & VCRLIN=[F:MWI]MFGTRKLIN
&                          & (AGGIFAFLG<>2 | NUMVCR="")
&                With GTE=[M:HAE0]TYP,NUMVCR=[M:HAE0]NUM,AGGIFAFLG=2, ACCDAT=[M:HAE0]ACCDAT
                # Call the Point in time valuation routine
                Call PITWIPUPD([F:MWI]ITMREF, [F:MWI]MFGFCY, 12, [F:MWI]MFGTRKNUM, [F:MWI]MFGTRKLIN) From STKPITLIB
         Elsif [F:MWI]TXNTYP=14
          # Issue 97371 - 2014-11-26 by CCC : Add test on NUMVCR
          # Issue X3-31259/106099 - 2017-04-24 by ERMIL : Add VCRTYP 6 to the VCRTYP check (Receipt for SUB WO)
          Update [STJ] Where STOFCY=[F:MWI]MFGFCY
&                          & find(VCRTYP,15,6)
&                          & VCRNUM=[F:MWI]MFGTRKNUM
&                          & VCRLIN=[F:MWI]MFGTRKLIN
&                          & (AGGIFAFLG<>2 | NUMVCR="")
&                With GTE=[M:HAE0]TYP,NUMVCR=[M:HAE0]NUM,AGGIFAFLG=2, ACCDAT=[M:HAE0]ACCDAT
                # Call the Point in time valuation routine
                Call PITWIPUPD([F:MWI]ITMREF, [F:MWI]MFGFCY, 15, [F:MWI]MFGTRKNUM, [F:MWI]MFGTRKLIN) From STKPITLIB
                Call PITWIPUPD([F:MWI]ITMREF, [F:MWI]MFGFCY, 6,  [F:MWI]MFGTRKNUM, [F:MWI]MFGTRKLIN) From STKPITLIB
         Elsif find([F:MWI]TXNTYP,17,9)
          # Issue 97371 - 2014-11-26 by CCC : Add test on NUMVCR
          Update [STJ] Where STOFCY=[F:MWI]MFGFCY
&                          & ITMREF=[F:MWI]ITMREF
&                          & VCRTYPORI=[F:MWI]VCRTYP
&                          & VCRNUMORI=[F:MWI]VCRNUM
&                          & (AGGIFAFLG<>2 | NUMVCR="")
&                With GTE=[M:HAE0]TYP,NUMVCR=[M:HAE0]NUM,AGGIFAFLG=2, ACCDAT=[M:HAE0]ACCDAT
                # Call the Point in time valuation routine
                Call PITWIPUPD([F:MWI]ITMREF, [F:MWI]MFGFCY, 0, [F:MWI]MFGTRKNUM, [F:MWI]MFGTRKLIN) From STKPITLIB
         Endif
         If fstat
          ERR_TRA = mess(89,197,1) +":"# "Problème en mise à jour des stocks"
          If [F:MWI]TXNTYP=1
            ERR_TRA-= mess(12,701,1) # "suivi matière"
          Elsif [F:MWI]TXNTYP=14
            ERR_TRA-= mess(15,701,1) # "Déclaration de production"
          Endif
          ERR_TRA -= [F:MWI]MFGTRKNUM-num$([F:MWI]MFGTRKLIN)
          Call ECR_TRACE(ERR_TRA,1) From GESECRAN
          GOK = 0
          Break
         Endif
        Endif
        If fstat
          # "erreur à la mise à jour des encours d'OF (WIPCOST): xxxxx #### type transaction
          ERR_TRA = mess(20,2363,1) - [F:MWI]VCRNUM-num$([F:MWI]WIPSEQ)-mess([F:MWI]TXNTYP,2358,1)
          Call ECR_TRACE(ERR_TRA,1) From GESECRAN
          GOK = 0
          Break
        Endif
      Next

      If GOK
        Commit
        If PCEDEB = "" PCEDEB = MESSA Endif # n° de pièce en retour (la première du groupe)
      Else
        Rollback  # mais on continue la boucle
      Endif
    Else
      MESSA += "\"+"KEY1="+[MWT1]KEY1-"KEY2="+[MWT1]KEY2-"KEY3="+[MWT1]KEY3-"KEY4="+[MWT1]KEY4-"KEY5="+[MWT1]KEY5
      Call ECR_TRACE(MESSA,1) From GESECRAN # préciser la clé de la table temp
      If dim(GLASTMWI)>0 & GLASTMWI<>""
          MESSA = mess(247,190,1)-":"-GLASTMWI
          Call ECR_TRACE(MESSA,0) From GESECRAN
          Raz GLASTMWI
      Endif
      Rollback
    Endif
  Next

  If PCEDEB <> ""
   # "Pièces automatiques terminées : numéros de pièces #### -> #### (>> attention si la dernière a échoué:MESSAx2 !!)
   ERR_TRA = mess(284,197,1)+"."- mess(169,100,1)-":"-PCEDEB-"-"-MESSA # (GNUMPCE est incorrect après une erreur)
   Call ECR_TRACE(ERR_TRA,0) From GESECRAN
  Endif

  $NEXT_MWT
Next

# Pour finir, on met à jour les flags de toutes les lignes non comptabilisables, pour ne plus jamais les voir
Trbegin [MWI]
Update [MWI] Where GLPSTA=1 & ENTCOD="" With GLPSTA=2
Commit

# Et enfin, on purge et on déverrouille
If !GTEST
 Trbegin [MWT]
 Delete [MWT] Where 1=1
 Commit
Endif

Unlock WIPACC
Return

$TERMINE
If !GSERVEUR
   Call FERME_TRACE From LECFIC
   TRA = 1
Endif

Return

$ERR_KEY
# erreur de parametrage des agrégations d'en-cours (PARWIPACC)
ERR_TRA = errmes$(errn)+"\|"+ errm +"|"+errp +"|"+num$(errl)
ERR_TRA += "\"+mess(228,193,1)- "("+ num$([F:MWI]VCRTYP)-[F:MWI]VCRNUM + ")"
Call ECR_TRACE(ERR_TRA,1) From GESECRAN
GOK = 0 : # erreur de formule bloquante
Resume

##########################################################################
Subprog IB_VCRNUMFIN
End

##########################################################################
Subprog C_VCRNUMFIN(VALEUR)
Variable Char    VALEUR()
Call C_VCRNUMDEB(VALEUR)
End


######################################################################################
Subprog AS_VCRTYP(VALEUR)
Variable Integer VALEUR
Local Integer I, LMEN10, LMEN36
Local Char LOPEIFA(10), LSCOIFA(10)
If GMODU(8)<>2 : VALEUR=36 : mkstat=2 : Endif
If GMODU(6)<>2 : VALEUR=10 : GMENLOC(36)=1 : Endif

If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
For I=1 To len(mess(0,701,1))
    If !find(I,10,36,37)
        GMENLOC(I)=1
    Endif
Next
If [M:MWIA]ALLFCY<>2
    Call PARAM([M:MWIA]MFGFCY, "OPEIFA", LOPEIFA) From ADOVAL
    GMENLOC(10) = (val(LOPEIFA)<2)
    GMENLOC(37) = (val(LOPEIFA)<2)
    Call PARAM([M:MWIA]MFGFCY, "SCOIFA", LSCOIFA) From ADOVAL
    GMENLOC(36) = (val(LSCOIFA)<2)
Else
    LMEN10 = 1
    LMEN36 = 1
    For [FCY] Where MFGFLG=2 | PURFLG=2
        If LMEN10
            Call PARAM([F:FCY]FCY, "OPEIFA", LOPEIFA) From ADOVAL
            LMEN10 = (val(LOPEIFA)<2)
        Endif
        If LMEN36
            Call PARAM([F:FCY]FCY, "SCOIFA", LSCOIFA) From ADOVAL
            LMEN36 = (val(LSCOIFA)<2)
        Endif
        If !LMEN10 & !LMEN36
            Break
        Endif
    Next
    GMENLOC(10) = LMEN10
    GMENLOC(36) = LMEN36
    GMENLOC(37) = LMEN10  # Idem suivi avec OF
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran MWIPACC) 24/09/2008 09:57:52 (CCC)
######################################################################################
Subprog AS_TXNTYP(VALEUR)
Variable Integer VALEUR
Local Integer I
Case [M:MWIA]VCRTYP
    When 10, 37 :
        For I=1 To len(mess(0,2358,1))
            If find(I,19)
                GMENLOC(I)=1
            Endif
        Next
    When 36 :
        For I=1 To len(mess(0,2358,1))
            If find(I,2,3,6,7,10,11,16,18)
                GMENLOC(I)=1
            Endif
        Next
Endcase
End


######################################################################################

$SELVCRACC
If clalev ([F:MWH])=0 : Local File MFGWIP     : Endif
If clalev ([F:MWI])=0 : Local File WIPCOST    : Endif

Local Char    LVCRNUM(GLONVCR)  : LVCRNUM    = VALEUR
Local Integer LVCRTYP           : LVCRTYP    = val(PARAM(1))
Local Char    LFCY(GLONFCY)     : LFCY       = PARAM(2)
Local Char    LCRIT(250), REQ(250)(2)
Local Integer LNB
Global Integer SELVCR

SELVCR = 1

REQ(0) ="SELECT COUNT(DISTINCT WIPCOST.VCRNUM_0)"
REQ(0)+=" From WIPCOST"
REQ(1)+=" Where WIPCOST.GLPSTA_0<>2"
REQ(1)+=  " and WIPCOST.VCRTYP_0="+num$(LVCRTYP)
If LVCRNUM<>""
    REQ(1)+=  " and WIPCOST.VCRNUM_0>='"+LVCRNUM+"'"
Endif
If LFCY<>""
    REQ(1)+=  " and WIPCOST.MFGFCY_0='"+LFCY+"'"
Endif
For (Integer NB) From num$(GTYPDBA*2+1) Sql REQ As [XXX]
    LNB = [F:XXX]NB
Next
If LNB=0
  Return
Endif

Local Char TEXTE(80)(1..min(LNB,200),1..2)

Raz GBIDI1, LCRIT
Call ADDCRIT(LCRIT,GBIDI1,"","[MWI]GLPSTA<>2","&") From GOBJSUB
Call ADDCRIT(LCRIT,GBIDI1,"","[MWI]VCRTYP="+num$(LVCRTYP),"&") From GOBJSUB
If LVCRNUM<>""
    Call ADDCRIT(LCRIT,GBIDI1,"","[MWI]VCRNUM>='"+LVCRNUM+"'","&") From GOBJSUB
Endif
If LFCY<>""
    Call ADDCRIT(LCRIT,GBIDI1,"","[MWI]MFGFCY='"+LFCY+"'","&") From GOBJSUB
Endif
Link [MWI] With [MWH]MWH0~=[F:MWI]VCRTYP;[F:MWI]VCRNUM
&          As [LNK]
&          Where evalue(LCRIT)
&          Order By Key K=[MWI]VCRTYP;[MWI]VCRNUM

TIT(0) = mess(LVCRTYP,701,1)
TIT(1) = mess(2,793,1)
TIT(2) = mess(3,45,1)
For [LNK]K(2)
    NBTEX += 1
    TEX(NBTEX)   = [F:MWI]VCRNUM
    TEXTE(NBTEX,1) = [F:MWI]VCRNUM
    TEXTE(NBTEX,2) = [F:MWI]MFGFCY
    If NBTEX>=dim(TEX)-1
        Break
    Endif
Next

Return

######################################################################################


######################################################################################

