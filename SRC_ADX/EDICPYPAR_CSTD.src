#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDICPYPAR                                                        #
# Manages main class EDICPYPAR (this) and no child class                      #
# Author : RBA +JUCON                                                         #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
        When "AREAD_AFTER"              : Gosub AREAD_AFTER  #SAM 110811
        When "AINSERT_CONTROL_AFTER"    : Gosub AINSERT_CONTROL_AFTER
        When "AUPDATE_CONTROL_AFTER"    : Gosub AUPDATE_CONTROL_AFTER
      Endcase
    When "ECPD"       #Init SAM 112148 XML signature
      Case [L]AEVENT
        When "ADDLINE_BEFORE"           : Gosub ECPD_ADDLINE_BEFORE
        When "ADDLINE_AFTER"            : Gosub ECPD_ADDLINE_AFTER
        When "ADELLINE_BEFORE"          : Gosub ECPD_ADELLINE_BEFORE
    Endcase
    When "ECPDF"
      Case [L]AEVENT
        When "ADDLINE_BEFORE"           : Gosub ECPDF_ADDLINE_BEFORE
        When "ADDLINE_AFTER"            : Gosub ECPDF_ADDLINE_AFTER
        When "ADELLINE_BEFORE"          : Gosub ECPDF_ADELLINE_BEFORE
    Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_VALIDATE"             : Gosub MET_VALIDATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "CPY"
      Case [L]ARULE
        When "CONTROL"   : Gosub CPY_CONTROL
        When "PROPAGATE" : Gosub CPY_PROPAGATE
      Endcase
    When "PARCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PARCOD_PROPAGATE
      Endcase
    When "PARTYP"
      Case [L]ARULE
        When "INIT"      : Gosub PARTYP_INIT
        When "CONTROL"   : Gosub PARTYP_CONTROL  #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
        When "PROPAGATE" : Gosub PARTYP_PROPAGATE
      Endcase
    When "DUNS" #SAM 110811
      Case [L]ARULE
        When "PROPAGATE" : Gosub DUNS_PROPAGATE
      Endcase
    When "IDTYPE" #SAM 110811
      Case [L]ARULE
        When "INIT"      : Gosub IDTYPE_INIT
        When "CONTROL"   : Gosub IDTYPE_CONTROL
        When "PROPAGATE" : Gosub IDTYPE_PROPAGATE
    Endcase
    When "EXCEDICOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EXCEDICOD_PROPAGATE
      Endcase
    When "SIGNATURE" #SAM 112148
      Case [L]ARULE
        When "INIT"      : Gosub SIGNATURE_INIT
        When "PROPAGATE" : Gosub SIGNATURE_PROPAGATE
      Endcase
    When "STA"
      Case [L]ARULE
        When "INIT"      : Gosub STA_INIT
      Endcase
    When "ECPD.USER"
      Case [L]ARULE
        When "CONTROL"   : Gosub ECPD_USER_CONTROL
      Endcase
    When "ECPD.CERTIFICATE"
      Case [L]ARULE
        When "CONTROL"   : Gosub ECPD_CERTIFICATE_CONTROL
      Endcase

    When "ECPDF.CATCOD" #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
      Case [L]ARULE
        When "INIT"      : Gosub ECPDF_CATCOD_INIT
        When "CONTROL"   : Gosub ECPDF_CATCOD_CONTROL
        When "PROPAGATE" : Gosub ECPDF_CATCOD_PROPAGATE
      Endcase

    When "ECPDF.CATTYP" #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
      Case [L]ARULE
        When "INIT"      : Gosub ECPDF_CATTYP_INIT
      Endcase

    When "ECPDF.CATACT" #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
      Case [L]ARULE
        When "INIT"      : Gosub ECPDF_CATACT_INIT
        When "PROPAGATE" : Gosub ECPDF_CATACT_PROPAGATE
      Endcase

    When "ECPDF.FLOCOD" #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
      Case [L]ARULE
        When "CONTROL"   : Gosub ECPDF_FLOCOD_CONTROL
        When "PROPAGATE" : Gosub ECPDF_FLOCOD_PROPAGATE
      Endcase

    When "ECPDF.FLOREL" #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
      Case [L]ARULE
        When "CONTROL"   : Gosub ECPDF_FLOREL_CONTROL
        When "PROPAGATE" : Gosub ECPDF_FLOREL_PROPAGATE
      Endcase

  Endcase
Return

###################################################################

$STA_INIT
  this.STA = 1
Return

###################################################################

$CPY_CONTROL
  If this.CPY <> ""
    this.CPY = func EDILIBA.FORMATVAL("CPY", this.CPY)
  Endif
Return

$CPY_PROPAGATE
  Local Integer WOK
  Local Char WERR (250)

  this.VALID  = [V]CST_ANO
  this.CPYNAM = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.CPY,"CPYNAM")
  this.EXCEDICOD=""

  If this.CPY<>""
    Local File COMPANY [CPY]
    Read[CPY]CPY0=this.CPY
    If !fstat
      this.FISCODE=[F:CPY]CRN
      this.VATNUM= [F:CPY]EECNUM
    Endif
    LogicClose File [CPY]
  Endif

  ASTATUS = fmet this.ADELETEERROR("PARCOD")
  WOK = func CONTROL_EXIST(this)
  If WOK = [V]CST_ATRUE
    WERR = mess(7,123,1)+"."-mess(22,100,1)  ## Creation not possible. Record already exists
    ASTATUS = fmet this.ASETERROR("CPY",WERR,[V]CST_AERROR)
  Endif
Return

####################################################################

$PARCOD_PROPAGATE
  Local Integer WOK
  Local Char WERR (250)

  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.PARCOD,"PARDES")
  this.PARTYP = fmet this.ACTX.ACACHE.EPR.AGETVALNUM(this.PARCOD,"PARTYP")
  this.VALID = [V]CST_ANO
  this.EXCEDICOD = ""

  ASTATUS = fmet this.ADELETEERROR("CPY")
  WOK = func CONTROL_EXIST(this)
  If WOK = [V]CST_ATRUE
    WERR = mess(7,123,1)+"."-mess(22,100,1)  ## Creation not possible. Record already exists
    ASTATUS = fmet this.ASETERROR("PARCOD",WERR,[V]CST_AERROR)
  Endif
Return

####################################################################

$PARTYP_INIT
  this.PARTYP = 2
Return

$PARTYP_CONTROL #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
#  WERR = "Type de partenaire interdit"
  WERR = mess(216,2006,1)
  If this.PARTYP = 3 #sans controle
    ASTATUS = fmet this.ASETERROR("PARCOD",WERR,[V]CST_AERROR)
  Endif
Return

$PARTYP_PROPAGATE
Return

####################################################################

#Init SAM 110811 - Control for idenfification ID type
$DUNS_PROPAGATE
  If this.DUNS<>"" and this.IDTYPE=4 # and this.EXCEDICOD="" #110811 US6
    this.EXCEDICOD = this.DUNS
  Endif
Return

####################################################################

$IDTYPE_INIT
  this.IDTYPE=6

Return

$IDTYPE_CONTROL
  Local Char WERR(250)
  Case this.IDTYPE
    When 2,3: WERR=mess(25,188,1)  # "Type not allowed"
  Endcase

  If WERR<>""
    ASTATUS = fmet this.ASETERROR("IDTYPE",WERR,[V]CST_AERROR)
  Endif
Return

$IDTYPE_PROPAGATE
  Local Char WERR(250)
  Local File COMPANY [CPY]
  this.EXCEDICOD=""
  Read[CPY]CPY0=this.CPY
  If !fstat
    Case this.IDTYPE
      When 1: #Fiscal code is the CRN of the Company
              this.EXCEDICOD=[F:CPY]CRN
              If [F:CPY]CRN=""
                WERR=mess(153,2006,1) #Company tax ID number is empty
              Endif
      When 4: #DUNS
#              this.EXCEDICOD=[F:CPY]DUNSCOD  #Future use. Not available for avenger
#              If [F:CPY]DUNSCOD=""
              If this.DUNS<>""
                this.EXCEDICOD=this.DUNS
              Else
                WERR=mess(72,108,1) : # null value
              Endif
      When 5: # EU Tax code
              this.EXCEDICOD=[F:CPY]EECNUM
              If [F:CPY]EECNUM=""
                WERR=mess(157,196,1) #The EU ID number is blank
              Endif
    Endcase
  Endif
  LogicClose File [CPY]
  If WERR<>""
    ASTATUS = fmet this.ASETERROR("EXCEDICOD",WERR,[V]CST_AWARNING)
  Endif
Return

####################################################################

$EXCEDICOD_PROPAGATE
  this.VALID = [V]CST_ANO
Return

####################################################################

#Init SAM 112148 XML signature
$SIGNATURE_INIT
  this.SIGNATURE=1
Return

$SIGNATURE_PROPAGATE
  If this.SIGNATURE<>[V]CST_AYES
    Call DELETELINES(this, "ECPD") From EDILIBA
  Endif
Return

####################################################################
$ECPD_USER_CONTROL
  Local Integer I, H, WOK
  Local Char WERR(250)
  this.USER= toupper(this.USER)

  If this.USER=""
    WERR= mess(103,2006,1)  #Value is mandatory
  Else
    Local File AUTILIS [AUS]
    Read [AUS]CODUSR=this.USER
    If fstat<>[V]CST_AOK
      WERR=mess(141,100,1) # Code utilisateur inexistant
    Endif
    LogicClose File [AUS]
    If WERR=""
      For I=1 To maxtab(this.APARENT.ECPD)
        If this.USER=this.APARENT.ECPD(I).USER
          H+=1
          If H>1: WERR = mess(22,100,1) : Break: Endif ## Record already exists
        Endif
      Next
    Endif
  Endif
  If WERR<>""
    ASTATUS = fmet this.ASETERROR("USER",WERR,[V]CST_AERROR)
  Endif
Return
#End 112148

####################################################################
#Ini 112149
$ECPD_CERTIFICATE_CONTROL
  Local Integer I, J, WOK, WFLD
  Local Char WERR(250), WOPTION1(40)
  Local Char WCERNAM(80): WCERNAM=this.CERTIFICATE
  Local Clbfile WOPTION(4)
  Local Clbfile WRESHEADCERT
  Local Clbfile WRESBODYCERT
  Local Clbfile WARGUMENTS(4)

  ### check certificate exists
  If this.CERTIFICATE<>""
    If this.USER="":  WFLD=0: WERR= mess(103,2006,1): Endif #Value is mandatory
    If WERR=""
      WFLD=1
      WOPTION ='"'+WCERNAM+'"'
      WOPTION1='"true"'
      WARGUMENTS = WOPTION+','+'"true"'

      WSTATUSCODE = func ASYRWEBSER.EXEC_JS("syracuse-xml/lib/helpers", "certificateExists", "wait", WARGUMENTS, "0,0", 0, "", "0", WRESHEADCERT, WRESBODYCERT)
      If WSTATUSCODE=200
        J=instr(1,WRESBODYCERT,"notAfter")
        If J>0
          Local Datetime WDATECER
          WDATECER=gdatetime$(mid$(WRESBODYCERT,14,26))
          If func SUBADC.DAT_DATETIME(WDATECER)>=date$
            WOK=0
          Else
            WOK=1
          Endif
        Elsif WRESBODYCERT=""
          WOK=2
        Endif
      Else WOK=2
      Endif

      If WOK>0
        Case WOK
          When 1: WERR=WCERNAM+"."-mess(194,2006,1)  # Validity date expired
          When 2: WERR=mess(1857,200,1)- mess(42,9003,1) # Certificate not found
        Endcase
      Endif
    Endif
  Endif

  If WERR<>""
    If WFLD=1
      ASTATUS = fmet this.ASETERROR("CERTIFICATE",WERR,[V]CST_AERROR)
    Else
      ASTATUS = fmet this.ASETERROR("USER",WERR,[V]CST_AERROR)
    Endif
  Endif
Return
#End 112149

####################################################################


