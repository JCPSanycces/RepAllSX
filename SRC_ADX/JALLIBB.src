#<AdxTL>@(#)1.0.0.0 $Revision$

# JALLIBB
#
# Routines diverses de traitement jalonnement
#########################################################################
# Subprog LOACAP(LDATD,LDATF,LCAP,LRET) (ancienne : plus utiliséé)      #
# Subprog LOACAPN(LDATD,LDATF,LCAP,LNBR,LRET) (nouvelle)                #
# Subprog LOACAPSUB(LDATD,LDATF,LCAP,LNBR,LRET)                         #
# Subprog CALDUR(LSIG,LDAT,LDAYFR,LTIME,LDATD,LDATF,LCODCAP,LCAP,       #
#                LDUR,LDATR,LDFRR)                                      #
# Subprog DIFFDAT(LCALC,LDAT1,LDFR1,LDAT2,LDFR2,LDIFF)                  #
# Subprog CONVHOU(LHOUC,LHOUD)                                          #
# Subprog CALDFR(LFCY, LDATE,LHOUD,LDAYCAP,LDAYFR, LWST)                #
# Subprog WSTLOAD(LMFGFCY,LWCR,LWST,LMFGSTA,LCAL,LCAP,LINFSTRD,LINFSTRF,#
#                 LINFENDD,LINFENDF,LNBRD,LNBR,LCOELAB,LSEC,LNBRP,LRET) #
# Subprog WSTUNLD(LMFGFCY,LWST,LMFGSTA,LCAL,LCAP,LINFSTRD,LINFSTRF,     #
#                 LINFENDD,LINFENDF,LNBRD,LNBR,LCOELAB,LRET,LSEC,LNBRP) #
#########################################################################

#########################################################################
# (llc 08.00 v130) nouvelle gestion des capacités
# Cette séquence n'est plus utilisée
# Chargement capacité
#   LDATD : Date début (borne incluse)
#   LDATF : Date fin   (borne incluse)
#   LCAP  : Tableau des capacités en retour (heures)
#   LRET  : code retour
#   les classes FCY, TUV et MWS doivent être en ligne !
#   les tables  TWD et CPV ouvertes !
Subprog LOACAP(LDATD,LDATF,LCAP,LRET)
#
Value    Date    LDATD
Value    Date    LDATF
Variable Decimal LCAP()
Variable Integer LRET
#
Local    Date WDATD : WDATD = LDATD
Local    Date WDATF : WDATF = LDATF
#Local    Char WMESS(250)
Local    Integer INBR  : INBR = 1                # llc 09.03 19553

#
Local    Integer I, J, K, L,  IDISP, IVAR, WNBR, IPER
Raz LCAP, LRET, I, IVAR, IPER
If WDATD = [0/0/0] | WDATF = [0/0/0] | WDATF < WDATD
  LRET = 1
  End
Endif

# lecture variations de capacité
Gosub LOAD_CPV
If LRET : End : Endif

# lecture schéma de référence
Gosub LOAD_TWD_FROM_MWS
If LRET : End : Endif

I = 0
While ((WDATD <= WDATF) & (I <= dim(LCAP) -1))
    WNBR = [F:MWS]WSTNBR

    # lecture schéma horaire
    Gosub LOAD_TWD_FROM_CPV
    If LRET : Break : Endif

$S_CAP
    J = dayn(WDATD) - 1
    # si capacité non nulle pour le jour
    If [F:TWD]DAYCAP(J) <> 0
        IDISP = 1
        # indisponibilité ?
        If [F:TUV]UVYNBR > 0
            For L = 0 To [F:TUV]UVYNBR - 1
                If [F:TUV]UVYSTRDAT(L) > WDATD : Break : Endif
                If WDATD >= [F:TUV]UVYSTRDAT(L) & WDATD <= [F:TUV]UVYENDDAT(L)
                    LCAP(I) = 0
                    IDISP   = 0
                    Break
                Endif
            Next
        Endif
        If IDISP = 1
            LCAP(I) = [F:TWD]DAYCAP(J) * WNBR
        Endif
    Else
        LCAP(I) = 0
    Endif

    # point d'entrée génération pondération capacité    19553
    Gosub PE_CAPACITY

$L_CAP
    WDATD += 1
    I     += 1
    IPER   = 0
Wend


End

#########################################################################
# (llc 08.00 v130) nouvelle gestion des capacités
# Chargement capacité + nb exemp.
#   LDATD : Date début (borne incluse)
#   LDATF : Date fin   (borne incluse)
#   LCAP  : Tableau des capacités en retour (heures)
#   LNBR  : Tableau des nombres d'exemplaires en retour (heures)
#   LRET  : code retour
#   les classes FCY, TUV et MWS doivent être en ligne !
#   les tables  TWD et CPV ouvertes !
Subprog LOACAPN(LDATD,LDATF,LCAP,LNBR,LRET)
#
Value    Date    LDATD
Value    Date    LDATF
Variable Decimal LCAP()
Variable Integer LNBR()
Variable Integer LRET
#
Local    Date WDATD : WDATD = LDATD
Local    Date WDATF : WDATF = LDATF
Local    Integer INBR  : INBR = 1                # llc 09.03 19553
#
Local    Integer I, J, K, L,  IDISP, IVAR, WNBR, IPER
Raz LCAP, LRET, I, IDISP, IVAR, IPER
If WDATD = [0/0/0] | WDATF = [0/0/0] | WDATF < WDATD
  LRET = 1
  End
Endif

# lecture variations de capacité
# Issue 95695 & 96955 GA 02/2014 optimisation
If ([F:CPV]WST <> [F:MWS]WST | [F:CPV]WCRFCY <> [F:MWS]WCRFCY)
  Gosub LOAD_CPV
  If LRET : End : Endif
Endif

# lecture schéma de référence
Gosub LOAD_TWD_FROM_MWS
If LRET : End : Endif

I = 0
While ((WDATD <= WDATF) & (I <= dim(LCAP) -1))

    WNBR = [F:MWS]WSTNBR

    # lecture schéma horaire
    Gosub LOAD_TWD_FROM_CPV
    If LRET : Break : Endif
    LNBR(I) = WNBR

$S_CAPN
    J = dayn(WDATD) - 1
    # si capacité non nulle pour le jour
    If [F:TWD]DAYCAP(J) <> 0
        IDISP = 1
        # indisponibilité ?
        If [F:TUV]UVYNBR > 0
            For L = 0 To [F:TUV]UVYNBR - 1
                If [F:TUV]UVYSTRDAT(L) > WDATD : Break : Endif
                If WDATD >= [F:TUV]UVYSTRDAT(L) & WDATD <= [F:TUV]UVYENDDAT(L)
                    LCAP(I) = 0
                    IDISP   = 0
                    Break
                Endif
            Next
        Endif
        If IDISP = 1
            LCAP(I) = [F:TWD]DAYCAP(J) * LNBR(I)
        Endif
    Else
        LCAP(I) = 0
    Endif

    # point d'entrée génération pondération capacité    19553
    Gosub PE_CAPACITY

$L_CAPN
    WDATD += 1
    I     += 1
    IPER   = 0
Wend

End

#########################################################################
# 09.05 32019 chargement capacité à 24 h pour sous-traitant
# Chargement capacité + nb exemp.
#   LDATD : Date début (borne incluse)
#   LDATF : Date fin   (borne incluse)
#   LCAP  : Tableau des capacités en retour (heures)
#   LNBR  : Tableau des nombres d'exemplaires en retour (heures)
#   LRET  : code retour
Subprog LOACAPSUB(LDATD,LDATF,LCAP,LNBR,LRET)
#
Value    Date    LDATD
Value    Date    LDATF
Variable Decimal LCAP()
Variable Integer LNBR()
Variable Integer LRET
#
Local    Integer I, J, K, L, IVAR, WNBR, IPER
Local    Date WDATD : WDATD = LDATD
Local    Date WDATF : WDATF = LDATF
Local    Integer INBR  : INBR = 1
#
Raz LRET
If WDATD = [0/0/0] | WDATF = [0/0/0] | WDATF < WDATD
  LRET = 1
  End
Endif

I = 0
While ((WDATD <= WDATF) & (I <= dim(LCAP) -1))
    LCAP(I) = 24
    LNBR(I) = 1
    WDATD += 1
    I     += 1
Wend

End

#########################################################################
# 06.05 30638
# Chargement capacité unitaire et nbr exemplaire = 1 pour charge MO secondaire
#   LDATD : Date début (borne incluse)
#   LDATF : Date fin   (borne incluse)
#   LCAP  : Tableau des capacités en retour (heures)
#   LNBR  : Tableau des nombres d'exemplaires en retour (heures)
#   LRET  : code retour
#   les classes FCY, TUV et MWS doivent être en ligne !
#   les tables  TWD et CPV ouvertes !
Subprog LOACAPNMO(LDATD,LDATF,LCAP,LNBR,LRET)
#
Value    Date    LDATD
Value    Date    LDATF
Variable Decimal LCAP()
Variable Integer LNBR()
Variable Integer LRET
#
Local    Date WDATD : WDATD = LDATD
Local    Date WDATF : WDATF = LDATF
Local    Integer INBR  : INBR = 1                # llc 09.03 19553

#
Local    Integer I, J, K, L,  IDISP, IVAR, WNBR, IPER
Raz LCAP, LRET, I, IVAR, IPER
If WDATD = [0/0/0] | WDATF = [0/0/0] | WDATF < WDATD
  LRET = 1
  End
Endif

# lecture variations de capacité
Gosub LOAD_CPV

# lecture schéma de référence
Gosub LOAD_TWD_FROM_MWS
If LRET : End : Endif

I = 0
While ((WDATD <= WDATF) & (I <= dim(LCAP) -1))

    WNBR = [F:MWS]WSTNBR

    # lecture nouveau schéma si nécessaire
    Gosub LOAD_TWD_FROM_CPV
    If LRET : Break : Endif
    LNBR(I) = WNBR

$S_CAPNMO
    If LNBR(I) > 1 : LNBR(I) = 1 : Endif
    J = dayn(WDATD) - 1
    # si capacité non nulle pour le jour
    If [F:TWD]DAYCAP(J) <> 0
        IDISP = 1
        # indisponibilité ?
        If [F:TUV]UVYNBR > 0
            For L = 0 To [F:TUV]UVYNBR - 1
                If [F:TUV]UVYSTRDAT(L) > WDATD : Break : Endif
                If WDATD >= [F:TUV]UVYSTRDAT(L) & WDATD <= [F:TUV]UVYENDDAT(L)
                    LCAP(I) = 0
                    IDISP   = 0
                    Break
                Endif
            Next
        Endif
        If IDISP = 1
            LCAP(I) = [F:TWD]DAYCAP(J)
        Endif
    Else
        LCAP(I) = 0
    Endif

    # point d'entrée génération pondération capacité    19553
    Gosub PE_CAPACITY

$L_CAPNMO
    WDATD += 1
    I     += 1
    IPER   = 0
Wend

End



#########################################################################
# (llc 08.00 v130) nouvelle gestion des capacités
# Chargement capacité + nb exemp.
#   LDATD : Date début (borne incluse)
#   LDATF : Date fin   (borne incluse)
#   LCAP  : Tableau des capacités en retour (heures)
#   LNBR  : Tableau des nombres d'exemplaires en retour (heures)
#   LRET  : code retour
#   les classes FCY, TUV et MWS doivent être en ligne !
#   les tables  TWD et CPV ouvertes !
# Même fonction que LOACAPN, sans multiplier la capacité par le nombre
# (gestion différente entre Gantt et jalonnement X3)
Subprog LOACAPO(LDATD,LDATF,LCAP,LNBR,LRET)
#
Value    Date    LDATD
Value    Date    LDATF
Variable Decimal LCAP()
Variable Integer LNBR()
Variable Integer LRET
#
Local    Date WDATD : WDATD = LDATD
Local    Date WDATF : WDATF = LDATF
Local    Integer INBR  : INBR = 0                # llc 09.03 19553

#
Local    Integer I, J, K, L,  IDISP, IVAR, WNBR, IPER
Raz LCAP, LRET, I, IVAR, IPER
If WDATD = [0/0/0] | WDATF = [0/0/0] | WDATF < WDATD
  LRET = 1
  End
Endif

# lecture variations de capacité
Gosub LOAD_CPV

# lecture schéma de référence
Gosub LOAD_TWD_FROM_MWS
If LRET : End : Endif

I = 0
While ((WDATD <= WDATF) & (I <= dim(LCAP) -1))

    WNBR = [F:MWS]WSTNBR

    # lecture nouveau schéma si nécessaire
    Gosub LOAD_TWD_FROM_CPV
    If LRET : Break : Endif
    LNBR(I) = WNBR

$S_CAPO
    J = dayn(WDATD) - 1
    # si capacité non nulle pour le jour
    If [F:TWD]DAYCAP(J) <> 0
        IDISP = 1
        # indisponibilité ?
        If [F:TUV]UVYNBR > 0
            For L = 0 To [F:TUV]UVYNBR - 1
                If [F:TUV]UVYSTRDAT(L) > WDATD : Break : Endif
                If WDATD >= [F:TUV]UVYSTRDAT(L) & WDATD <= [F:TUV]UVYENDDAT(L)
                    LCAP(I) = 0
                    IDISP   = 0
                    Break
                Endif
            Next
        Endif
        If IDISP = 1
            LCAP(I) = [F:TWD]DAYCAP(J)             # llc 10126 08.01
        Endif
    Else
        LCAP(I) = 0
    Endif

    # point d'entrée génération pondération capacité    19553
    Gosub PE_CAPACITY

$L_CAPO
    WDATD += 1
    I     += 1
    IPER   = 0
Wend


End

#########################################################################
# Calcul date début / fin et durée
#   LSIG    = "+" ou "-"
#   LDAT    = Date de référence
#   LDAYFR  = Fraction de jour correspondante
#   LTIME   = Temps(en H/100)
#   LDATD   = Date de début calendrier
#   LDATF   = Date de fin calendrier
#   LCODCAP = 0 : calendrier universel
#             1 : fonction de LCAP
#   LCAP    = Table capacités
#   LDUR    = Durée calculée (en J/100)
#   LDATR   = Date résultat
#   LDFRR   = Fraction de jour résultat
#   LNBRD   = Table nombre de postes
#   LNBR    = nombre de poste utilisé par l'opération
#   LTYP    = type de temps (1 = prp, 2 = réglage/opératoire, 3 = post/attente)
# réécriture 06.05 (prise en compte heures début de travail)
Subprog CALDUR(LSIG,LDAT,LDAYFR,LTIME,LDATD,LDATF,
&              LCODCAP,LCAP,LDUR,LDATR,LDFRR,LNBRD,LNBR,LTYP)
#
Value    Char     LSIG()
Variable Date     LDAT
Variable Decimal  LDAYFR
Variable Decimal  LTIME
Variable Date     LDATD
Variable Date     LDATF
Variable Integer  LCODCAP
Variable Decimal  LCAP()
Variable Decimal  LDUR
Variable Date     LDATR
Variable Decimal  LDFRR
Variable Integer  LNBRD()
Variable Integer  LNBR
Value    Integer  LTYP           : # GA 08/2008 paramètre manquant  (non utilisé ???)
#
Local    Integer  I
Local    Decimal  WCAP, WCAPS
Local    Decimal  WTIME
Local    Decimal  WDISP, WDISPA, WDISPR # Issue 82755 GA 10/2014 WDISP rounded
Local    Decimal  WDFR
Local    Date     WDAT
Local    Integer  OFFSET : OFFSET = 0
#
# 06.05 31012
Local    Decimal  WSTARTD

# 83321
If LDAT = [0/0/0] : End : Endif

LDUR = 0
LDATR = LDAT
LDFRR = LDAYFR
If LTIME > 0
    WDAT = LDAT
    WTIME = LTIME
    WDFR = LDAYFR
    # 05.05 30281
    If WDFR > 0.9999 & LSIG = "+" & WDAT <> [0/0/0]
        WDAT += 1
        LDATR = WDAT
        WDFR = 0
    Endif
    # 05.05 30281
    If WDFR < 0.0001 & LSIG = "-" & WDAT <> [0/0/0]
        WDAT -= 1
        LDATR = WDAT
        WDFR = 1
    Endif
    I = WDAT - LDATD
    If I < 0 : I = 0 : Endif
    If I > (dim(LCAP) - 1) : I = dim(LCAP) - 1 : Endif
    If I > LDATF-LDATD : WDAT = LDATF : I = LDATF-LDATD : LDATR = WDAT : Endif

    # Sens du parcours
    If LSIG = "+"
        # parcours aval
        While ((I < (LDATF-LDATD)) & (I <= dim(LCAP) -1))
            Gosub INIT_STARTD
            If LCODCAP = 0
                WCAP   = 24
                If LCAP(I) <> 0
                    If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) : Else : WCAP = LCAP (I) : Endif
                    WDISPA = (24 - (WDFR * WCAP) - WSTARTD)
                Else
                    WDISPA = 24 - (WDFR * WCAP) : # WDISPA = 24 : # Issue 64673 GH 08/01/2018 - case 22
                Endif
                WDISP   = WDISPA
            Else
                # si nb poste utilisé >= nb poste dispo, capacité max
                # sinon capacité "utile" = capacité unitaire * nb poste utilisé
                If LNBRD(I) <= LNBR
                    WCAP = LCAP(I)
                Else
                    If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) * LNBR : Else : WCAP = LCAP (I) : Endif
                Endif
                WDISP = WCAP * (1-WDFR)
            Endif
            WDISPR=arr(WDISP,10^-6) # Issue 82755 GA 10/2014 WDISP rounded
            If WTIME <= WDISPR
                Break
            Elsif WTIME-WDISP<1/30  # Issue 105739 GH 10/09/2018 - case 1 : don't go to the next day for less than half a minute
                WTIME = WDISP
                Break
            Else
                LDUR += 1 - WDFR
                LDATR += 1
                WTIME -= WDISP
                If (I + 1) < dim(LCAP) - 1
                    If (LCODCAP = 0 & LCAP(I+1) > 0)
                        OFFSET = 1
                        Gosub INIT_STARTD
                        WTIME -= WSTARTD
                    Endif
                Endif
                WDFR = 0
                I += 1
            Endif
        Wend
        LDFRR = WDFR
        If WCAP > 0
            If LCODCAP <> 1
                # 03.06 35265
                If WTIME >= (WCAP * (1-WDFR))
                    LDFRR = 1
                    LDUR += 1 - WDFR
                Else
                    LDUR += WTIME / WCAP
                    If LDUR < 0.0001
                        LDUR = 0.0001
                    Endif
                    # 03.06 35265
                    If WCAP <> 0 : LDFRR = WDFR + WTIME / WCAP : Else : LDFRR = WDFR : Endif        # 09.04 24927
                Endif
                # sur temps hors charge on peut dépasser 1
                If LDFRR > 1 : LDATR += 1 : LDFRR = 0 : Endif
            Else
                LDUR += WTIME / WCAP
                If LDUR < 0.0001
                   LDUR = 0.0001
                Endif
                LDFRR = WDFR + WTIME / WCAP
            Endif
        Endif
        If LDFRR < 0.0001
          If LCODCAP <> 1 | (I>0 & LCAP(I-1) > 0) # Issue 82755 GA 10/2014
            LDATR -= 1
            LDFRR = 1
          Else
          # Issue 82755 GA 10/2014 check capacity
          # Except when previous day is a day off
            LDFRR = 0
          Endif
        Endif
    Else
    # parcours amont
        While I > 0
            Gosub INIT_STARTD
            If LCODCAP <> 1
                WCAP = 24
                If LCAP(I) <> 0
                    If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) : Else : WCAP = LCAP (I) : Endif
                    WDISPA = (WDFR * WCAP) + WSTARTD
                Else
                    WDISPA = WDFR * 24 : # WDISPA = 24 : # Issue 64673 GH 08/01/2018 - case 22
                Endif
                # Issue 112545 - 2015-12-03 by LLC/BEEBE : waiting time longer than 24h will be clacouated badly
                #                                          bug in the enhancement made under requirement 108897
                #WDISP   = 24 # Issue 108897 by GA 07/2015 before WDISPA
                WDISP = WDISPA
            Else
                # si nb poste utilisé >= nb poste dispo, capacité max
                # sinon capacité "utile" = capacité unitaire * nb poste utilisé
                If LNBRD(I) <= LNBR
                    WCAP = LCAP(I)
                Else
                    If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) * LNBR : Else : WCAP = LCAP (I) : Endif
                Endif
                WDISP = WCAP * WDFR
            Endif
            WDISPR=arr(WDISP,10^-6) # Issue 82755 GA 10/2014 WDISP rounded
            If WTIME <= WDISPR
                Break
            Elsif WTIME-WDISP<1/30  # Issue 105739 GH 10/09/2018 - case 1 : don't go to the previous day for less than half a minute
                WTIME = WDISP
                Break
            Else
                LDUR += WDFR
                LDATR -= 1
                WTIME -= WDISP
                If (I - 1) > 0
                    If (LCODCAP <> 1 & LCAP(I-1) > 0)
                        OFFSET = -1
                        Gosub INIT_STARTD
                        If LNBRD(I-1) > 0 : WCAP = (LCAP(I-1) / LNBRD(I-1)) : Else : WCAP = LCAP (I-1) : Endif
                        WTIME -= (24 - WCAP - WSTARTD)
                    Endif
                Endif
                WDFR = 1
                I -= 1
            Endif
        Wend
        LDFRR = WDFR
        If WCAP > 0
            If LCODCAP <> 1
                 # 03.06 35265
                 If WTIME >= (WCAP * WDFR)
                    LDFRR = 0
                    LDUR += WDFR
                Else
                    LDUR += WTIME / WCAP
                    If LDUR < 0.0001
                        LDUR = 0.0001
                    Endif
                    # 03.06 35265
                    If WCAP <> 0 : LDFRR = WDFR - WTIME / WCAP : Else : LDFRR = WDFR : Endif
                    # sur temps hors charge on peut dépasser 1
                    If LDFRR < 0 : LDATR -= 1 : LDFRR = 1 : Endif
                    # Issue 108897 by GA 07/2015 LTYP=3 post-operation/waiting time
                    # hors charge sur periode non travaillée - time not worked out load period
                    If WDISPR-WTIME>WDISPA & LTYP=3 & LCODCAP=2 : LDFRR = 1 : Endif
                Endif
            Else
                LDUR += WTIME / WCAP
                If LDUR < 0.0001
                    LDUR = 0.0001
                Endif
                LDFRR = WDFR - WTIME / WCAP
            Endif
        Endif
        If LDFRR > 0.9999
          If LCODCAP <> 1 | (I <= dim(LCAP)-2 & LCAP(I+1) > 0) # Issue 82755 GA 10/2014
            LDATR += 1
            LDFRR = 0
          Else
          # Issue 82755 GA 10/2014 check capacity
          # Except when next day is a day off
            LDFRR = 1
          Endif
        Endif
    Endif
    If LCODCAP <> 1 : LDUR = LTIME / 24 : Endif
Endif
End

#########################################################################
# 06.06 31012
$INIT_STARTD
WSTARTD = 0
If LNBRD(I+OFFSET) > 1 : WCAPS = LCAP(I+OFFSET) / LNBRD(I+OFFSET) : Else : WCAPS = LCAP(I+OFFSET) : Endif
If WCAPS > 24 : WCAPS = 24 : Endif
If dim(LCODCAP)>0 & LCODCAP <> 1 WCAPS = 24          # Issue 108897 by GA 07/2015
Else
  If WCAPS > 0  & WCAPS <= 10 : Call CONVHOU(GSTRTEAM1,WSTARTD) : Endif
  If WCAPS > 10 & WCAPS <= 20 : Call CONVHOU(GSTRTEAM2,WSTARTD) : Endif
Endif
OFFSET = 0
Return

#########################################################################
# Calcul différence dates
#   LCALC = Type de calcul     : =1 LDIFF = LDAT2 - LDAT1
#                                =2 LDAT2 = LDAT1 + LDIFF
#   LDAT1 = Première date de référence
#   LDFR1 = Fraction de jour correspondante
#   LDAT2 = Deuxième date de référence
#   LDFR2 = Fraction de jour correspondante
#   LDIFF = Différence entre les deux dates (en J/100)
#
Subprog DIFFDAT(LCALC,LDAT1,LDFR1,LDAT2,LDFR2,LDIFF)
#
Variable Integer  LCALC
Variable Date     LDAT1
Variable Decimal  LDFR1
Variable Date     LDAT2
Variable Decimal  LDFR2
Variable Decimal  LDIFF
#
Local    Integer  WSIGN,WDDAT
Local    Date     WDAT1,WDAT2
Local    Decimal  WDFR1,WDFR2,WDIFF,WDDFR
#
Case LCALC
  When 1 :
    WDAT1 = LDAT1
    WDFR1 = LDFR1
    WDAT2 = LDAT2
    WDFR2 = LDFR2
    If WDAT1 > WDAT2 | (WDAT1 = WDAT2) & (WDFR1 > WDFR2)
      If WDFR1 < WDFR2
        WDFR1 += 1
        WDAT1 -= 1
      Endif
      LDIFF = - (WDAT1 - WDAT2) - (WDFR1 - WDFR2)
    Else
      If WDFR2 < WDFR1
        WDFR2 += 1
        WDAT2 -= 1
      Endif
      LDIFF = (WDAT2 - WDAT1) + (WDFR2 - WDFR1)
    Endif
  When 2 :
    WDAT1 = LDAT1
    WDFR1 = LDFR1
    WDIFF = LDIFF
    WSIGN = 1
    If WDIFF < 0
      WDIFF = -WDIFF
      WSIGN = 2
    Endif
    WDDAT = int(WDIFF)
    WDDFR = WDIFF - WDDAT
    If WSIGN = 1
      LDAT2 = WDAT1 + WDDAT
      LDFR2 = WDFR1 + WDDFR
      If LDFR2 > 1
        LDFR2 -= 1
        LDAT2 += 1
      Endif
    Else
      LDAT2 = WDAT1 - WDDAT
      LDFR2 = WDFR1 - WDDFR
      If LDFR2 < 0
        LDFR2 += 1
        LDAT2 += 1
      Endif
    Endif
Endcase
#
End
#
#########################################################################
# Transformation HH:MM en Centièmes d'heures
#   LHOUC   = HH:MM en caractères
#   LHOUD   = Heure,centième en décimal (en retour)
#
Subprog CONVHOU(LHOUC,LHOUD)
#
Variable Char     LHOUC()
Variable Decimal  LHOUD
#
Local Char    HH(2)
Local Char    MM(2)
Local Decimal HEURE
Local Decimal MINUTE
Local Integer ND
Local Char    DP(1)
#
HH = mid$(LHOUC,1,2)
ND = 3
DP = seg$(LHOUC,3,3)
If DP = ":" : ND = 4 : Endif
MM = mid$(LHOUC,ND,2)
#
HEURE = val(HH)
MINUTE = val(MM)
#
LHOUD = HEURE + MINUTE/60
#
End

#########################################################################
# Transformation HHMM en HH:MM
# 06.06 31012
#   LHOUC   = HHMM en caractères
#   LHOUC2  = HH:MM en caractères
#
Subprog CONVHOU1(LHOUC,LHOUC1)
#
Value     Char        LHOUC
Variable  Char        LHOUC1
#
Local Char    HH(2)
Local Char    MM(2)
Local Integer ND
Local Decimal HEURE
Local Decimal MINUTE

#
HH = mid$(LHOUC,1,2)
ND = 3
MM = mid$(LHOUC,ND,2)
HEURE = val(HH)
MINUTE = val(MM)

LHOUC1 = format$("N0:2#",HEURE)+format$("N0:2#",MINUTE)
End

#########################################################################
# Transformation HH:MM en HHMM
# 06.06 31012
#   LHOUC   = HH:MM en caractères
#   LHOUC2  = HHMM en caractères
#
Subprog CONVHOU2(LHOUC,LHOUC2)
#
Value     Char     LHOUC
Variable  Char     LHOUC2
#
Local Char    HH(2)
Local Char    MM(2)
Local Integer ND
Local Char    DP(1)
#
HH = mid$(LHOUC,1,2)
ND = 3
DP = seg$(LHOUC,3,3)
If DP = ":" : ND = 4 : Endif
MM = mid$(LHOUC,ND,2)
LHOUC2 = HH + MM

End

#########################################################################
# Transformation HH.MM en heure + centièmes d'heure
# 06.06 31012
#   LHOUC   = HH.MM en décimal
#   LHOUC2  = HH.MM en décimal
#
Subprog CONVHOU3(LHOUD1,LHOUD2)
Value     Decimal LHOUD1
Variable  Decimal LHOUD2

Local Decimal RMD, MMD
Local Integer WINT, MM

WINT = int(LHOUD1)
RMD = mod(LHOUD1, WINT)
MM = RMD * 100
MMD = MM / 60
LHOUD2 = WINT + MMD

End

#########################################################################
# désactivé 09.2009
Subprog NEWCALDFR(LFCY,LHOUD,LDAYCAP,LDAYFR, LWST)
Value    Char     LFCY
Variable Decimal  LHOUD
Variable Decimal  LDAYCAP
Variable Decimal  LDAYFR
Value    Char     LWST
LDAYFR = 0
End

#########################################################################
# remplace NEWCALDFR 09.2009
# prise en compte des schémas journaliers v6
Subprog CALDFR(LFCY,LDATE,LHOUD,LHOUC,LDAYCAP,LDAYFR,LWST)
Value    Char     LFCY
Value    Date     LDATE
Variable Decimal  LHOUD
Variable Char     LHOUC
Variable Decimal  LDAYCAP
Variable Decimal  LDAYFR
Value    Char     LWST

Local Integer WCODCAP : WCODCAP=1
Call CALDFRCAP(LFCY,LDATE,WCODCAP,LHOUD,LHOUC,LDAYCAP,LDAYFR,LWST,2)

End

#########################################################################
# Issue 108897 by GA 07/2015 sometimes CALDFR need to avoid using weekly structure
Subprog CALDFRCAP(LFCY,LDATE,LCODCAP,LHOUD,LHOUC,LDAYCAP,LDAYFR,LWST,LTYP)
Value    Char     LFCY
Value    Date     LDATE
Value    Integer  LCODCAP   # Issue 108897: New parameter
Variable Decimal  LHOUD
Variable Char     LHOUC
Variable Decimal  LDAYCAP
Variable Decimal  LDAYFR
Value    Char     LWST
Value    Integer  LTYP      # Issue 108897: New parameter 1=pre-op time, 2=Op time, 3=post-op time

Local    Decimal  WDAYFR, WTIME, WDURATION, WSTARTD, WDIFF
#Local    Char     WSTARTC
Local    Integer  J, K, LRET

If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif
If clalev([F:TWD])  = 0 : Local File TABWEEDIA  [TWD]  : Endif
If clalev([F:DIH])  = 0 : Local File DIAHOU     [DIH]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR     [CPV]  : Endif  # Issue 108515 GA 06/2015

# lecture poste
Gosub LOAD_MWS
If LRET : End : Endif

# Issue 108515 GA 06/2015 - start - Is there any Capacity variation ?
# lecture schéma de référence
#Gosub LOAD_TWD_FROM_MWS
#If LRET : End : Endif
# lecture variations de capacité
Local Integer IVAR, WNBR, IPER : Raz IVAR, IPER
Local Date    WDATD : WDATD = LDATE
Local Date    WDATF : WDATF = LDATE

WNBR=[F:MWS]WSTNBR
If ([F:CPV]WST <> [F:MWS]WST | [F:CPV]WCRFCY <> [F:MWS]WCRFCY)
  Gosub LOAD_CPV
  If LRET : End : Endif
Endif

# lecture schéma horaire
Gosub LOAD_TWD_FROM_CPV
If LRET : End : Endif
# Issue 108515 GA 06/2015 - end

J = dayn(LDATE) - 1

# lecture schéma horaire
# Issue 105739 GH 12/09/2018 - Performance enhancement
If ([F:TWD]DIAHOU(J)="" & [F:DIH]NUM<>GDEFDIH) | ([F:TWD]DIAHOU(J)<>"" & [F:TWD]DIAHOU(J)<>[F:DIH]NUM)
    If [F:TWD]DIAHOU(J)<>""
       Read [DIH]DIH0=[F:TWD]DIAHOU(J)
    Else
       fstat=5
    Endif
    If fstat
       If [F:DIH]NUM = GDEFDIH
          fstat=0
       Elsif GDEFDIH<>""
          Read [DIH]DIH0 = GDEFDIH
       Endif
       If fstat & [F:DIH]NUM<>""
          Raz [F:DIH]
       Endif
    Endif
Endif

# plafonne journée à 24h
If LDAYCAP > 24 | LDAYCAP <= 0 : LDAYCAP = 24 : Endif

# Issue 108897 by GA 07/2015 sometimes CALDFR need to avoid using weekly structure
#   LCODCAP = 0 : universal calendar 24h/day
#             1 : regarding LCAP
#             2 : universal calendar 24h/day
#                 - backward scheduling keep post-op time after  day work
#                 - forward scheduling  keep pre-op  time before day work
If LCODCAP <> 1
    LDAYCAP = 24 : WSTARD=0
    WDIFF = LHOUD - WSTARTD
    If WDIFF > LDAYCAP   : WDIFF = LDAYCAP : Endif

    If WDIFF > 0
        WDAYFR = WDIFF / LDAYCAP
        LDAYFR = WDAYFR
    Else
        LDAYFR = 0
    Endif

    Goto CALDFR_END
Endif

# Issue 108515 GA 06/2015 old method is obsolete, even if LDAYCAP=24
# si capa = 24 ou pas de schéma horaire, méthode v5
#If LDAYCAP = 24 | (dim([F:DIH]STRHOU) <= 0)
If (dim([F:DIH]STRHOU) <= 0)
    If (LDAYCAP > 0  & LDAYCAP <= 10) : Call CONVHOU(GSTRTEAM1,WSTARTD) From JALLIBB : Endif
    If (LDAYCAP > 10 & LDAYCAP <= 20) : Call CONVHOU(GSTRTEAM2,WSTARTD) From JALLIBB : Endif

    WDIFF = LHOUD - WSTARTD
    If WDIFF > LDAYCAP   : WDIFF = LDAYCAP : Endif

    If WDIFF > 0
        WDAYFR = WDIFF / LDAYCAP
        LDAYFR = WDAYFR
    Else
        LDAYFR = 0
    Endif
    Goto CALDFR_END
Endif

# parcours des horaires
For K = 0 To dim([F:DIH]STRHOU) - 1

    If K = 0 & LHOUC <= [F:DIH]STRHOU(K)
        LDAYFR = 0
        Break
    Endif

    If LHOUC <= [F:DIH]ENDHOU(K)
        # incohérence, si heure pendant un break, on réaligne sur début tranche
        If LHOUC < [F:DIH]STRHOU(K) : LHOUC = [F:DIH]STRHOU(K) : Endif
        Call DURATIONFROMDIH([F:DIH]STRHOU(K), LHOUC, WDURATION) From JALLIBB
        WTIME += WDURATION
        Break
    Endif

    # calcul durée ligne horaire
    Call DURATIONFROMDIH([F:DIH]STRHOU(K), [F:DIH]ENDHOU(K), WDURATION) From JALLIBB
    WTIME += WDURATION
Next K

If WTIME > LDAYCAP
    WDAYFR = 1
Else
    WDAYFR = WTIME / LDAYCAP
Endif
LDAYFR = WDAYFR

$CALDFR_END
End

#########################################################################
# Conversion fraction de jour en heure HH:MM suivant schéma horaire
# Si traitement de masse, penser à ouvrir les tables suivantes:
#    WORKSTATIO - TABWEEDIA - DIAHOU - CAPVAR
Subprog OPETIME(LFCY, LWST, LDAT, LFRACTION, LHOUR)
Value     Char    LFCY
Value     Char    LWST
Value     Date    LDAT
Value     Decimal LFRACTION
Variable  Char    LHOUR

Local Integer IEND
Local Integer J,K
Local Integer LRET, WNBR
Local Decimal WTIME, WDURATION, WDURTOT
Local Char    WDEFAULT(5) : WDEFAULT = "08:00"        # si pas moyen de calculer une heure on prend 08h00 comme référence
Local Char    WHOURC(5)                               # Issue 108515 GA 06/2015
Local Date    WDATD : WDATD = LDAT
Local Date    WDATF : WDATF = LDAT                    # Issue 95695 & 96955 GA 02/2014 mandatory for LOAD_CPV
Local Integer J, K, P, IVAR, WNBR, IPER, LRET
Local Decimal WCAP

Raz LHOUR
If LDAT = [0/0/0] : End : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif
If clalev([F:TWD])  = 0 : Local File TABWEEDIA  [TWD]  : Endif
If clalev([F:DIH])  = 0 : Local File DIAHOU     [DIH]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR     [CPV]  : Endif

# lecture poste
Gosub LOAD_MWS
If LRET : End : Endif
WNBR = [F:MWS]WSTNBR

# lecture variations de capacité
# Issue 95695 & 96955 GA 02/2014 optimisation
If ([F:CPV]WST <> [F:MWS]WST | [F:CPV]WCRFCY <> [F:MWS]WCRFCY)
  Gosub LOAD_CPV
  If LRET : End : Endif
Endif

# lecture schéma horaire
WDATD=LDAT
Gosub LOAD_TWD_FROM_CPV
If LRET : End : Endif

J = dayn(LDAT) - 1
 # Issue 64673 GH 08/01/2018 - case 22, consider a not working day is 24h
 # Issue 75830 GH 21/02/2018 - no need to consider the time table schema for a 24h working day
If [F:TWD]DAYCAP(J)=0 | [F:TWD]DAYCAP(J)=24
   Goto TIME24
Endif

# calcul temps
WCAP = [F:TWD]DAYCAP(J)
WTIME = LFRACTION * WCAP

# lecture schéma horaire
# Issue 105739 GH 12/09/2018 - Issue 75830 GH 21/12/2018 - Performance enhancement
If ([F:TWD]DIAHOU(J)="" & [F:DIH]NUM<>GDEFDIH) | ([F:TWD]DIAHOU(J)<>"" & [F:TWD]DIAHOU(J)<>[F:DIH]NUM)
    If [F:TWD]DIAHOU(J)<>""
       Read [DIH]DIH0=[F:TWD]DIAHOU(J)
    Else
       fstat=5
    Endif
    If fstat
       If [F:DIH]NUM = GDEFDIH
          fstat=0
       Elsif GDEFDIH<>""
          Read [DIH]DIH0 = GDEFDIH
       Endif
       If fstat & [F:DIH]NUM<>""
          Raz [F:DIH]
       Endif
    Endif
Endif
If [F:DIH]NUM="" : Goto END_TIME : Endif

$DIH_LOOP
# parcours des horaires
Raz LHOUR, WHOURC, IEND, WDURTOT, WDURATION
For K = 0 To dim([F:DIH]STRHOU) - 1
    If WTIME = 0 : LHOUR = [F:DIH]STRHOU(K) : IEND = 1 : Break : Endif
    If [F:DIH]STRHOU(K) ="" : Break : Endif   # Issue 108515 GA 06/2015
    If !IEND : WTIME -= WDURATION : Endif     # Issue 105739 GH 11/09/2018 - case 2

    # calcul durée ligne horaire
    Call DURATIONFROMDIH([F:DIH]STRHOU(K), [F:DIH]ENDHOU(K), WDURATION)
    WDURTOT+=WDURATION                        # Issue 108515 GA 06/2015

    If !IEND
       WHOURC=[F:DIH]STRHOU(K)                # Issue 108515 GA 06/2015
       # Issue 108515 GA 06/2015 Add WDURATION to check [F:TWD]DAYCAP(J)
       If WDURATION >= WTIME
          IEND=2
       # Issue 105739 GH 11/09/2018 - case 2 : WTIME decremented at the next iteration, if there is one
       #Else
       #   WTIME -= WDURATION
       Endif
    Endif
Next K

If IEND=1
   End
#Elsif [F:TWD]DAYCAP(J)<>WDURTOT : # Issue 116202 18/05/2016 by GH - rounding management
Elsif abs(WDURTOT-WCAP)>=0.01
   # For LDAT, day capacity of weekly schema (TWD) is not consistent duration of time table schema (DIH)
   If !P
     If GTRACE<>""
        # Inconsistent duration LWST Monday LDAT : TWD = DAYCAP h <> DIH = WDURTOT h
        Call ECR_TRACE(mess(332,193,1)-LWST-day$(J+1)-format$("D:"+GFMDAT4,LDAT)-":"
&                     -[F:TWD]TWD+"="+num$(WCAP)-mess(30,197,1)-"<>"-[F:DIH]NUM+"="+num$(arr(WDURTOT,0.001))-mess(30,197,1),-1) From GESECRAN
     Endif
     If K>0 & LFRACTION=1
       LHOUR=[F:DIH]ENDHOU(K-1)
       Goto END_TIME
     Else
       # Issue 75830 GH 21/12/2018 - in case of inconsistency, capacity is corrected with time schema duration
       WCAP = arr(WDURTOT,0.01)
       WTIME = LFRACTION * WCAP
       P=1 : Goto DIH_LOOP
     Endif
   Endif
Endif

If IEND=0 & K>dim([F:DIH]STRHOU)-1
   Goto END_TIME
Elsif WHOURC="" : # Issue 112302 - 2015-11-10 by GH - not calculate LHOUR from WHOURC blank
   Goto END_TIME
Endif

Call ADDDURATIONTOHOUR(WHOURC, WTIME, LHOUR)

$END_TIME
# si rien de calculé, par défaut on prend début = 08h00
If LHOUR = "" : Call ADDDURATIONTOHOUR(WDEFAULT, WTIME, LHOUR) : Endif

If LHOUR = "2400"  : LHOUR = "2359"
Elsif LHOUR>"2400" : Goto TIME24
Endif
End

$TIME24
# Calculation as if day capacity was 24h
WTIME = LFRACTION * 24 : # 0.5625*24 = 13.5
LHOUR = format$("N0:2#",int(WTIME))+format$("N0:2#",(WTIME-int(WTIME))*60) : # 1330
If LHOUR >= "2400"  : LHOUR = "2359" : Endif # Issue 105739 GH 18/09/2018 - for case 23 referenced for issue 64673
End

#########################################################################
# calcul une heure en ajoutant une durée
Subprog ADDDURATIONTOHOUR(LSTR, LDURATION, LHOUR)
Value     Char     LSTR
Value     Decimal  LDURATION
Variable  Char     LHOUR

Local Char    HH(2)
Local Char    MM(2)
Local Integer HOUR
Local Integer MINUTE
Local Integer ND
Local Char    DP(1)
Local Decimal WM, WMRMD
Local Integer WWRK, WMINT

HH = mid$(LSTR,1,2)
ND = 3
DP = seg$(LSTR,3,3)
If DP = ":" : ND = 4 : Endif
MM = mid$(LSTR,ND,2)

HOUR = val(HH)
MINUTE  = val(MM)

WWRK = int(LDURATION)
HOUR += WWRK
WM = (LDURATION - WWRK) * 60
WMINT = int(WM)
WMRMD = WM - WMINT
If WMRMD >= 0.5 : WMINT += 1 : Endif
WM = WMINT
If (MINUTE + WM) >= 60 : HOUR += 1 : MINUTE += (WM - 60) : Else : MINUTE += WM : Endif

LHOUR = format$("N0:2#",HOUR)+format$("N0:2#",MINUTE)
End

#########################################################################
# calcul la durée à partir d'une ligne de schéma horaire
Subprog DURATIONFROMDIH(LSTR, LEND, LDURATION)
Value     Char     LSTR
Value     Char     LEND
Variable  Decimal  LDURATION

Local Char    HHSTR(2), HHEND(2)
Local Char    MMSTR(2), MMEND(2)
Local Decimal STARTHOUR, ENDHOUR
Local Decimal STARTMIN, ENDMIN
Local Integer ND
Local Char    DP(1)

# astuce, car on ne peut pas paramétrer 24:00 pour minuit, on est obligé de mettre 00:00
If LEND = "0000"  : LEND = "2400"  : Endif
If LEND = "00:00" : LEND = "24:00" : Endif
If LEND = "2359"  : LEND = "2400"  : Endif
If LEND = "23:59" : LEND = "24:00" : Endif

HHSTR = mid$(LSTR,1,2)
ND = 3
DP = seg$(LSTR,3,3)
If DP = ":" : ND = 4 : Endif
MMSTR = mid$(LSTR,ND,2)

STARTHOUR = val(HHSTR)
STARTMIN  = val(MMSTR)

HHEND = mid$(LEND,1,2)
ND = 3
DP = seg$(LEND,3,3)
If DP = ":" : ND = 4 : Endif
MMEND = mid$(LEND,ND,2)

ENDHOUR = val(HHEND)
ENDMIN  = val(MMEND)

LDURATION = ENDHOUR - STARTHOUR
If ENDMIN > STARTMIN
    LDURATION -= 1
    LDURATION += (ENDMIN + (60 - STARTMIN)) / 60
Else
    LDURATION += (ENDMIN - STARTMIN) / 60
Endif
End


#########################################################################
# Chargement WORKLOAD du poste par l'opération
#   LMFGFCY  = Site
#   LWCR     = centre de charge
#   LWST     = code du poste
#   LMFGSTA  = statut OF
#   LCODORI  = Origine demande (2 = CBN, 3 = PDP)
#   LCAL     = numéro du calendrier
#   LCAP     = table des capacités journalières
#   LINFSTRD = date début
#   LINFSTRF = Fraction de jour début
#   LINFENDD = date fin
#   LINFENDF = Fraction de jour fin
#   LNBRD    = table des exemplaires journaliers
#   LNBR     = Nombre exemplaires demandé
#   LCOELAB  = Coefficient correctif main d'oeuvre
#   LSEC     = Mode MA ou MO principal: 0, Mode poste secondaire: 1            # 03.06 35162
#   LNBRP    = nombre d'exemplaire demandé poste principal                     # 03.06 35162
#   LRET  : code retour
#
# 03.06 35162
Subprog WSTLOAD(LMFGFCY,LWCR,LWST,LMFGSTA,LCODORI,LCAL,LCAP,LINFSTRD,LINFSTRF,
&               LINFENDD,LINFENDF,LNBRD,LNBR,LCOELAB,LSEC,LNBRP,LRET)
Variable Char     LMFGFCY
Variable Char     LWCR
Variable Char     LWST
Variable Integer  LMFGSTA
Value    Integer  LCODORI
Variable Char     LCAL
Variable Decimal  LCAP()
Variable Date     LINFSTRD
Variable Decimal  LINFSTRF
Variable Date     LINFENDD
Variable Decimal  LINFENDF
Variable Integer  LNBRD()
Variable Integer  LNBR
Variable Decimal  LCOELAB
Value    Integer  LSEC           # 03.06 35162
Variable Integer  LNBRP          # 03.06 35162
Variable Integer  LRET

Local    Integer  I
Local    Integer  WRET
Local    Decimal  WCALC
Local    Decimal  WCAP
Local    Decimal  WDFR
Local    Date     WDATD
Local    Decimal  WENDDFR
Local    Date     WSTRDAT
Local    Date     WENDDAT

Raz WRET
I = 0
If clalev([F:WKL])  = 0 : Local File WORKLOAD   [WKL]  : Endif

Filter [WKL] Where MFGFCY=LMFGFCY & WST=LWST
&            Order By Key WKL0
Read [WKL]WKL0 First
If fstat = 4
    fstat = 0
    Call INIWKL(LMFGFCY,LWCR,LWST,WRET) From JALLIBC
Endif
Filter [WKL]

WSTRDAT = LINFSTRD
WDFR = LINFSTRF
If WDFR = 1
  WSTRDAT += 1
  I += 1
  WDFR = 0
Endif
WENDDAT = LINFENDD
WENDDFR = LINFENDF
If WENDDFR = 1
  WENDDAT += 1
  WENDDFR = 0
Endif

# ----- PE FILTERWKL
If dim(GCAPACITY) > 0
    GPE = 0
    GPOINT = "FILTERWKL" : Gosub ENTREE From EXEFNC
Endif
# -----
If !GPE
    Filter [WKL] Where MFGFCY=LMFGFCY & WST=LWST & PEREND >= WSTRDAT
&                Order By Key WKL0
Endif

Read [WKL]WKL0 First
If fstat = 4 : Goto END_WSTLOAD : Endif
If fstat = 1 : LRET = 1 : Goto END_WSTLOAD : Endif

WDATD = WSTRDAT

While (WDATD <= WENDDAT) & (I <= dim(LCAP) -1)            # 08.06 37503

    If WDATD > [F:WKL]PEREND
        Readlock [WKL]WKL0 Next
        If fstat : Break : Endif
    Endif

    If WDATD = WENDDAT : WDFR += (1-WENDDFR) : Endif

    # 03.06 35162
    If LSEC
         If LNBRP > LNBRD(I)
             WCAP = LCAP(I)
         Else
             If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) * LNBRP : Else  : WCAP = 0 : Endif
         Endif
    Else
         If LNBRP > LNBRD(I)
             WCAP = LCAP(I)
         Else
             If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) * LNBR  : Else  : WCAP = 0 : Endif
         Endif
    Endif

    WCALC = WCAP * LCOELAB * (1-WDFR)
    WCALC = arr(WCALC,0.0001)

    [F:WKL]PERLOD += WCALC
    Case LMFGSTA
        When 1 : [F:WKL]OWFLOD += WCALC
        When 2 : [F:WKL]OWPLOD += WCALC
        When 3 : If LCODORI = 3
                     [F:WKL]ORSLOD += WCALC
                 Else
                     [F:WKL]OWSLOD += WCALC
                 Endif
    Endcase
    [F:WKL]UPDDAT = date$
    [F:WKL]UPDUSR = GUSER

    # ----- PE WORKLOAD
    If dim(GCAPACITY) > 0
        If GWKLACT <> "" : GPOINT = "WORKLOAD" : Gosub ENTREE From EXEFNC : Endif
    Endif
    # -----

    Rewrite [WKL]
    WDATD += 1
    I += 1
    WDFR = 0
Wend

$END_WSTLOAD
Filter [WKL]
fstat = 0
End


#########################################################################
# Déchargement WORKLOAD du poste par l'opération
#   LMFGFCY  = Site
#   LWST     = code du poste
#   LMFGSTA  = statut OF
#   LCODORI  = origine demande (2 = CBN, 3 = PDP)
#   LCAL     = numéro du calendrier
#   LCAP     = table des capacités journalières
#   LINFSTRD = date début
#   LINFSTRF = Fraction de jour début
#   LINFENDD = date fin
#   LINFENDF = Fraction de jour fin
#   LNBRD    = table exemplaires journalier
#   LNBR     = Nombre exemplaires demandé
#   LCOELAB  = Coefficient correctif main d'oeuvre
#   LSEC     = Mode MA ou MO principal: 0, Mode poste secondaire: 1            # 03.06 35162
#   LNBRP    = nombre d'exemplaire demandé poste principal                     # 03.06 35162
#   LRET     = code retour
#
# 03.06 35162
Subprog WSTUNLD(LMFGFCY,LWST,LMFGSTA,LCODORI,LCAL,LCAP,LINFSTRD,LINFSTRF,
&               LINFENDD,LINFENDF,LNBRD,LNBR,LCOELAB,LSEC,LNBRP,LRET)
Variable Char     LMFGFCY
Variable Char     LWST
Variable Integer  LMFGSTA
Value    Integer  LCODORI
Variable Char     LCAL
Variable Decimal  LCAP()
Variable Date     LINFSTRD
Variable Decimal  LINFSTRF
Variable Date     LINFENDD
Variable Decimal  LINFENDF
Variable Integer  LNBRD()
Variable Integer  LNBR
Variable Decimal  LCOELAB
Value    Integer  LSEC           # 03.06 35162
Variable Integer  LNBRP          # 03.06 35162
Variable Integer  LRET
#
Local    Integer  I
Local    Integer  WRET
Local    Decimal  WCALC
Local    Decimal  WCAP
Local    Decimal  WDFR
Local    Date     WDATD
Local    Decimal  WENDDFR
Local    Date     WSTRDAT
Local    Date     WENDDAT
#
Raz WRET
I = 0

#
If clalev([F:WKL])  = 0 : Local File WORKLOAD   [WKL]  : Endif
#
WSTRDAT = LINFSTRD
WDFR = LINFSTRF
If WDFR = 1
  WSTRDAT += 1
  I += 1
  WDFR = 0
Endif
WENDDAT = LINFENDD
WENDDFR = LINFENDF
If WENDDFR = 1
  WENDDAT += 1
  WENDDFR = 0
Endif
#
# ----- PE FILTERWKL
If dim(GCAPACITY) > 0
    GPE = 0
    GPOINT = "FILTERWKL" : Gosub ENTREE From EXEFNC
Endif
# -----
If !GPE
    Filter [WKL] Where MFGFCY=LMFGFCY & WST=LWST & PEREND >= WSTRDAT
&                Order By Key WKL0
Endif

Read [WKL]WKL0 First
If fstat = 4 : Goto END_WSTUNLD : Endif
If fstat = 1 : LRET = 1 : Goto END_WSTUNLD : Endif

WDATD = WSTRDAT

While (WDATD <= WENDDAT) & (I <= dim(LCAP) -1)            # 08.06 37503

    If WDATD > [F:WKL]PEREND
        Readlock [WKL]WKL0 Next
        If fstat : Break : Endif
    Endif

    If WDATD = WENDDAT : WDFR += (1-WENDDFR) : Endif

    # 03.06 35162
    If LSEC
         If LNBRP > LNBRD(I)
             WCAP = LCAP(I)
         Else
             If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) * LNBRP : Else  : WCAP = 0 : Endif
         Endif
    Else
         If LNBRP > LNBRD(I)
             WCAP = LCAP(I)
         Else
             If LNBRD(I) > 0 : WCAP = (LCAP(I) / LNBRD(I)) * LNBR  : Else  : WCAP = 0 : Endif
         Endif
    Endif

    WCALC = WCAP * LCOELAB * (1-WDFR)
    WCALC = arr(WCALC,0.0001)

    [F:WKL]PERLOD -= WCALC
    Case LMFGSTA
        When 1 : [F:WKL]OWFLOD -= WCALC
        When 2 : [F:WKL]OWPLOD -= WCALC
        When 3 : If LCODORI = 3
                     [F:WKL]ORSLOD -= WCALC
                 Else
                     [F:WKL]OWSLOD -= WCALC
                 Endif
    Endcase

    If [F:WKL]PERLOD < 0 : [F:WKL]PERLOD = 0 : Endif
    If [F:WKL]OWFLOD < 0 : [F:WKL]OWFLOD = 0 : Endif
    If [F:WKL]OWPLOD < 0 : [F:WKL]OWPLOD = 0 : Endif
    If [F:WKL]OWSLOD < 0 : [F:WKL]OWSLOD = 0 : Endif
    If [F:WKL]ORSLOD < 0 : [F:WKL]ORSLOD = 0 : Endif
    [F:WKL]UPDDAT = date$
    [F:WKL]UPDUSR = GUSER

    # ----- PE WORKLOAD
    If dim(GCAPACITY) > 0
        If GWKLACT <> "" : GPOINT = "WORKLOAD" : Gosub ENTREE From EXEFNC : Endif
    Endif
    # -----

    Rewrite [WKL]
    WDATD += 1
    I += 1
    WDFR = 0
Wend

$END_WSTUNLD
Filter [WKL]
fstat = 0
End

#########################################################################
# Chargement Workload en sous-programme
# llc 11.02 16478
Subprog WORKLOAD(LMFGFCY, LMFGNUM, LSCDFLG)
Variable Char  LMFGFCY
Value Char     LMFGNUM
Value Integer  LSCDFLG

If !find(LSCDFLG, 2, 4) : End : Endif

#Local Char     WCAL, WWST, WWCR, WLAB
Local Char     WCAL(2) # Cal number : unused
Local Char     WWCR (GLONWCR)
Local Char     WWST (GLONWST)
Local Char     WLAB (GLONWST)
Local Date     WSTRCAL
Local Date     WENDCAL
Local Decimal  WFSTSTRF, WLSTENDF
Local Integer  WRET, WNBR, WORI, WNBRP     # 03.06 35162
Local Decimal  WCOELAB
Local Decimal  WCAP (2000)               : # capacité journalière poste
Local Integer  WNBRD (2000)              : # nombre d'exemplaires disponible journalier poste
Local Integer  WMFGSTA


If clalev([F:SCH]) = 0 : Local File SCHEDULING   [SCH] : Endif
If clalev([F:MFO]) = 0 : Local File MFGOPE       [MFO] : Endif
If clalev([F:MWS]) = 0 : Local File WORKSTATIO   [MWS] : Endif
If clalev([F:TWD]) = 0 : Local File TABWEEDIA    [TWD] : Endif
If clalev([F:CPV]) = 0 : Local File CAPVAR       [CPV] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY     [FCY] : Endif
If clalev([F:TUV]) = 0 : Local File TABUNAVAIL   [TUV] : Endif

If [F:FCY]FCY <> LMFGFCY
    # lecture site
    Call LECTURE ("FCY", LMFGFCY, "") From CONTOBJ
Endif

If [F:TUV]UVYCOD <> [F:FCY]UVYCOD
    # lecture indisponibilités
    Read [F:TUV]UVY0=[F:FCY]UVYCOD
    If fstat : Raz [F:TUV] : Endif
Endif

# chargement WORKLOAD
Link [MFO] With [SCH]SCH0=[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
&          As   [SCOP]
&          Where MFGNUM=LMFGNUM & [F:MFO]OPESTA <> 6
&          Order By Key MFO0

For [SCOP]
    # saute les op terminées ou exclues
    If ([F:MFO]OPESTA > 4 & [F:MFO]OPESTA < 7) : Goto OPE_SUIV_1 : Endif

    WMFGSTA = [F:MFO]MFGSTA
    # lecture poste
    If [F:MFO]CPLWST = ""
        WWST     = [F:MFO]EXTWST
    Else
        WWST     = [F:MFO]CPLWST
    Endif
    Read [MWS]WST0=WWST;LMFGFCY
    If fstat : Break : Endif

    # pas de WORKLOAD pour sous-traitance
    If [F:MWS]WSTTYP <> 3

        # chargement calendrier correspondant
        If LSCDFLG = 2
            WSTRCAL = [F:SCH]INFCAPSTR
            WENDCAL = [F:SCH]INFCAPEND + 10
        Else
            WSTRCAL = [F:SCH]FITCAPSTR
            WENDCAL = [F:SCH]FITCAPEND + 10
        Endif

        WRET    = 0
        Call LOACAPN (WSTRCAL,WENDCAL,WCAP,WNBRD,WRET) From JALLIBB

        # chargement WORKLOAD
        WCOELAB = 1
        If [F:MFO]CPLWSTNBR = 0
            WNBRP    = [F:MFO]EXTWSTNBR            # 03.06 35162
        Else
            WNBRP    = [F:MFO]CPLWSTNBR            # 03.06 35162
        Endif
        WRET    = 0

        # --------- Initialisation pour PE WORKLOAD 10.06
        If dim(GCAPACITY) > 0
            GWKLACT = "L"
            GWKLMFG = [F:MFO]MFGNUM
            GWKLOPE = [F:MFO]OPENUM
            GWKLSPL = [F:MFO]OPESPLNUM
        Endif

        If LSCDFLG = 2
            # 03.06 35162
            Call WSTLOAD(LMFGFCY,WWCR,WWST,WMFGSTA, WORI,WCAL,WCAP,
&                        [F:SCH]INFCAPSTR,[F:SCH]INFCAPSTF,[F:SCH]INFCAPEND,[F:SCH]INFCAPENF,WNBRD,WNBRP,WCOELAB,0,WNBRP,WRET)
&                        From JALLIBB
        Else
            # 03.06 35162
            Call WSTLOAD(LMFGFCY,WWCR,WWST,WMFGSTA, WORI,WCAL,WCAP,
&                        [F:SCH]FITCAPSTR,[F:SCH]FITCAPSTF,[F:SCH]FITCAPEND,[F:SCH]FITCAPENF,WNBRD,WNBRP,WCOELAB,0,WNBRP,WRET)
&                        From JALLIBB
        Endif
        If WRET > 0 : Break : Endif

        # traitement main d'oeuvre
        # lecture poste main d'oeuvre

        # lecture poste
        If [F:MFO]CPLLAB = ""
            WLAB     = [F:MFO]EXTLAB
        Else
            WLAB     = [F:MFO]CPLLAB
        Endif

        If WLAB <> ""
            Read [MWS]WST0=WLAB;LMFGFCY
            If fstat : Break : Endif

            If LSCDFLG = 2
                # chargement WORKLOAD main d'oeuvre
                WCOELAB = [F:MFO]SETLABCOE
                If [F:MFO]CPLLABNBR = 0
                    WNBR    = [F:MFO]EXTLABNBR
                Else
                    WNBR    = [F:MFO]CPLLABNBR
                Endif
                WRET    = 0
                # 03.06 35162
                Call WSTLOAD(LMFGFCY,WWCR,WLAB,WMFGSTA,WORI,WCAL,WCAP,
&                            [F:SCH]INFCAPSTR,[F:SCH]INFCAPSTF,[F:SCH]SETENDDAT,[F:SCH]SETENDFRD,WNBRD,WNBR,WCOELAB,1,WNBRP,WRET)
&                            From JALLIBB
                If WRET > 0 : Break : Endif

                WCOELAB = [F:MFO]OPELABCOE
                WRET    = 0
                # 03.06 35162
                Call WSTLOAD(LMFGFCY,WWCR,WLAB,WMFGSTA,WORI,WCAL,WCAP,
&                            [F:SCH]SETENDDAT,[F:SCH]SETENDFRD,[F:SCH]INFCAPEND,[F:SCH]INFCAPENF,WNBRD,WNBR,WCOELAB,1,WNBRP,WRET)
&                            From JALLIBB
                If WRET > 0 : Break : Endif
            Else
                If [F:MFO]CPLLABNBR = 0
                    WNBR    = [F:MFO]EXTLABNBR
                Else
                    WNBR    = [F:MFO]CPLLABNBR
                Endif
                WCOELAB = [F:MFO]OPELABCOE
                WRET    = 0
                # 03.06 35162
                Call WSTLOAD(LMFGFCY,WWCR,WLAB,WMFGSTA,WORI,WCAL,WCAP,
&                            [F:SCH]FITCAPSTR,[F:SCH]FITCAPSTF,[F:SCH]FITCAPEND,[F:SCH]FITCAPENF,WNBRD,WNBR,WCOELAB,1,WNBRP,WRET)
&                            From JALLIBB
                If WRET > 0 : Break : Endif
            Endif
        Endif
    Endif
$OPE_SUIV_1
Next

fstat = 0
End

#########################################################################
# Déchargement Workload en sous-programme
# llc 11.02 16478
Subprog WORKUNLOAD(LMFGFCY, LMFGNUM, LSCDFLG)
Variable Char  LMFGFCY
Value Char     LMFGNUM
Value Integer  LSCDFLG

If !find(LSCDFLG, 2, 4) : End : Endif

Local Char     WCAL(2) # Cal number : unused
Local Date     WSTRCAL
Local Date     WENDCAL
Local Integer  WRET, WNBR, WORI, WNBRP     # 03.06 35162
Local Decimal  WCOELAB
Local Decimal  WCAP (2000)               : # capacité journalière poste
Local Integer  WNBRD (2000)              : # nombre d'exemplaires disponible journalier poste
Local Integer  WMFGSTA

If clalev([F:SCH]) = 0 : Local File SCHEDULING   [SCH] : Endif
If clalev([F:MFO]) = 0 : Local File MFGOPE       [MFO] : Endif
If clalev([F:MWS]) = 0 : Local File WORKSTATIO   [MWS] : Endif
If clalev([F:TWD]) = 0 : Local File TABWEEDIA    [TWD] : Endif
If clalev([F:CPV]) = 0 : Local File CAPVAR       [CPV] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY     [FCY] : Endif
If clalev([F:TUV]) = 0 : Local File TABUNAVAIL   [TUV] : Endif

If [F:FCY]FCY <> LMFGFCY
    # lecture site
    Call LECTURE ("FCY", LMFGFCY, "") From CONTOBJ
Endif

If [F:TUV]UVYCOD <> [F:FCY]UVYCOD
    # lecture indisponibilités
    Read [F:TUV]UVY0=[F:FCY]UVYCOD
    If fstat : Raz [F:TUV] : Endif
Endif

Link [MFO] With [SCH]SCH0=[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
&          As   [SCOP]
&          Where MFGNUM=LMFGNUM & [F:MFO]OPESTA <> 6
&          Order By Key MFO0

For [SCOP]
    # lecture poste prévu au jalonnement précédent
    If [F:SCH]CLCWST <> ""
        WMFGSTA = [F:MFO]MFGSTA

        Read [MWS]WST0=[F:SCH]CLCWST;LMFGFCY
        If fstat : Break : Endif

        # pas de WORKLOAD pour sous-traitance
        If [F:MWS]WSTTYP <> 3

            # chargement calendrier correspondant
            If LSCDFLG = 2
                WSTRCAL = [F:SCH]INFCAPSTR
                WENDCAL = [F:SCH]INFCAPEND + 10
            Else
                WSTRCAL = [F:SCH]FITCAPSTR
                WENDCAL = [F:SCH]FITCAPEND + 10
            Endif

            WRET    = 0
            Call LOACAPN (WSTRCAL,WENDCAL,WCAP,WNBRD,WRET)

            WCOELAB = 1
            If [F:MFO]CPLWSTNBR = 0
                WNBRP    = [F:MFO]EXTWSTNBR                # 03.06 35162
            Else
                WNBRP    = [F:MFO]CPLWSTNBR                # 03.06 35162
            Endif
            WRET    = 0

            # --------- Initialisation pour PE WORKLOAD 10.06
            If dim(GCAPACITY) > 0
                GWKLACT = "U"
                GWKLMFG = [F:MFO]MFGNUM
                GWKLOPE = [F:MFO]OPENUM
                GWKLSPL = [F:MFO]OPESPLNUM
            Endif

            If LSCDFLG = 2
                # 03.06 35162
                Call WSTUNLD(LMFGFCY,[F:SCH]CLCWST,WMFGSTA,WORI,WCAL,WCAP,[F:SCH]INFCAPSTR,[F:SCH]INFCAPSTF,
&                            [F:SCH]INFCAPEND,[F:SCH]INFCAPENF,WNBRD,WNBRP,WCOELAB,0,WNBRP,WRET)
&                            From JALLIBB
            Else
                # 03.06 35162
                Call WSTUNLD(LMFGFCY,[F:SCH]CLCWST,WMFGSTA,WORI,WCAL,WCAP,[F:SCH]FITCAPSTR,[F:SCH]FITCAPSTF,
&                            [F:SCH]FITCAPEND,[F:SCH]FITCAPENF,WNBRD,WNBRP,WCOELAB,0,WNBRP,WRET)
&                            From JALLIBB
            Endif
            If WRET > 0 : Break : Endif

            If [F:SCH]CLCLAB <> ""
                Read [MWS]WST0=[F:SCH]CLCLAB;LMFGFCY
                If fstat : Break : Endif

                If LSCDFLG = 2
                    # dechargement WORKLOAD main d'oeuvre
                    WCOELAB = [F:SCH]SETLABCOE
                    If [F:MFO]CPLLABNBR = 0
                        WNBR    = [F:MFO]EXTLABNBR
                    Else
                        WNBR    = [F:MFO]CPLLABNBR
                    Endif
                    WRET    = 0
                    # 03.06 35162
                    Call WSTUNLD(LMFGFCY,[F:SCH]CLCLAB,WMFGSTA,WORI,WCAL,WCAP,[F:SCH]INFCAPSTR,[F:SCH]INFCAPSTF,
&                               [F:SCH]SETENDDAT,[F:SCH]SETENDFRD,WNBRD,WNBR,WCOELAB,1,WNBRP,WRET)
&                              From JALLIBB
                    If WRET > 0 : Break : Endif

                    WCOELAB = [F:SCH]OPELABCOE
                    WRET    = 0
                    # 03.06 35162
                    Call WSTUNLD(LMFGFCY,[F:SCH]CLCLAB,WMFGSTA,WORI,WCAL,WCAP,[F:SCH]SETENDDAT,[F:SCH]SETENDFRD,
&                              [F:SCH]INFCAPEND,[F:SCH]INFCAPENF,WNBRD,WNBR,WCOELAB,1,WNBRP,WRET)
&                          From JALLIBB
                    If WRET > 0 : Break : Endif
                Else
                    WCOELAB = [F:SCH]OPELABCOE
                    If [F:MFO]CPLLABNBR = 0
                        WNBR    = [F:MFO]EXTLABNBR
                    Else
                        WNBR    = [F:MFO]CPLLABNBR
                    Endif
                    WRET    = 0
                    # 03.06 35162
                    Call WSTUNLD(LMFGFCY,[F:SCH]CLCLAB,WMFGSTA,WORI,WCAL,WCAP,[F:SCH]FITCAPSTR,[F:SCH]FITCAPSTF,
&                               [F:SCH]FITCAPEND,[F:SCH]FITCAPENF,WNBRD,WNBR,WCOELAB,1,WNBRP,WRET)
&                          From JALLIBB
                    If WRET > 0 : Break : Endif
                Endif
            Endif
        Endif
  Endif
Next

fstat = 0
End

#########################################################################
# Chargement Workload suggestions en sous-programme
# llc 11.02 16478
Subprog WORKLOADS(LMFGFCY, LMFGNUM, LSCDFLG)
Variable Char  LMFGFCY
Value Char     LMFGNUM
Value Integer  LSCDFLG

If !find(LSCDFLG, 2, 4) : End : Endif

#Local Char     WCAL, WWST, WWCR, WLAB
Local Char     WCAL(2) # Cal number : unused
Local Char     WWCR (GLONWCR)
Local Char     WWST (GLONWST)
Local Char     WLAB (GLONWST)
Local Date     WSTRCAL
Local Date     WENDCAL
Local Decimal  WFSTSTRF, WLSTENDF
Local Integer  WRET, WNBR, WORI, WNBRP     # 03.06 35162
Local Decimal  WCOELAB
Local Decimal  WCAP (2000)               : # capacité journalière poste
Local Integer  WNBRD (2000)              : # nombre d'exemplaires disponible journalier poste
Local Integer  WMFGSTA


If clalev([F:SCH]) = 0 : Local File SCHEDULING   [SCH] : Endif
If clalev([F:OPS]) = 0 : Local File OPERATIONS   [OPS] : Endif
If clalev([F:MWS]) = 0 : Local File WORKSTATIO   [MWS] : Endif
If clalev([F:TWD]) = 0 : Local File TABWEEDIA    [TWD] : Endif
If clalev([F:CPV]) = 0 : Local File CAPVAR       [CPV] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY     [FCY] : Endif
If clalev([F:TUV]) = 0 : Local File TABUNAVAIL   [TUV] : Endif

If [F:FCY]FCY <> LMFGFCY
    # lecture site
    Call LECTURE ("FCY", LMFGFCY, "") From CONTOBJ
Endif

If [F:TUV]UVYCOD <> [F:FCY]UVYCOD
    # lecture indisponibilités
    Read [F:TUV]UVY0=[F:FCY]UVYCOD
    If fstat : Raz [F:TUV] : Endif
Endif

# chargement WORKLOAD
Link [OPS] With [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM
&          As   [SCOP]
&          Where MFGNUM=LMFGNUM
&          Order By Key OPS1

For [SCOP]

    WMFGSTA = 3
    # lecture poste
    WWST     = [F:OPS]EXTWST
    Read [MWS]WST0=WWST;LMFGFCY
    If fstat : Break : Endif

    # pas de WORKLOAD pour sous-traitance
    If [F:MWS]WSTTYP <> 3

        # chargement calendrier correspondant
        If LSCDFLG = 2
            WSTRCAL = [F:SCH]INFCAPSTR
            WENDCAL = [F:SCH]INFCAPEND + 10
        Else
            WSTRCAL = [F:SCH]FITCAPSTR
            WENDCAL = [F:SCH]FITCAPEND + 10
        Endif

        WRET    = 0
        Call LOACAPN (WSTRCAL,WENDCAL,WCAP,WNBRD,WRET) From JALLIBB

        # chargement WORKLOAD
        WCOELAB = 1
        WNBRP   = [F:OPS]EXTWSTNBR            # 03.06 35162
        WRET    = 0

        # --------- Initialisation pour PE WORKLOAD 10.06
        If dim(GCAPACITY) > 0
            GWKLACT = "L"
            GWKLMFG = [F:OPS]MFGNUM
            GWKLOPE = [F:OPS]OPENUM
            GWKLSPL = [F:OPS]OPESPLNUM
        Endif

        If LSCDFLG = 2
            # 03.06 35162
            Call WSTLOAD(LMFGFCY,WWCR,WWST,WMFGSTA, WORI,WCAL,WCAP,
&                        [F:SCH]INFCAPSTR,[F:SCH]INFCAPSTF,[F:SCH]INFCAPEND,[F:SCH]INFCAPENF,WNBRD,WNBRP,WCOELAB,0,WNBRP,WRET)
&                        From JALLIBB
        Else
            # 03.06 35162
            Call WSTLOAD(LMFGFCY,WWCR,WWST,WMFGSTA, WORI,WCAL,WCAP,
&                        [F:SCH]FITCAPSTR,[F:SCH]FITCAPSTF,[F:SCH]FITCAPEND,[F:SCH]FITCAPENF,WNBRD,WNBRP,WCOELAB,0,WNBRP,WRET)
&                        From JALLIBB
        Endif
        If WRET > 0 : Break : Endif

        # traitement main d'oeuvre
        # lecture poste main d'oeuvre

        # lecture poste
        WLAB     = [F:OPS]EXTLAB
        If WLAB <> ""
            Read [MWS]WST0=WLAB;LMFGFCY
            If fstat : Break : Endif

            If LSCDFLG = 2
                # chargement WORKLOAD main d'oeuvre
                WCOELAB = [F:OPS]SETLABCOE
                WNBR    = [F:OPS]EXTLABNBR
                WRET    = 0
                # 03.06 35162
                Call WSTLOAD(LMFGFCY,WWCR,WLAB,WMFGSTA,WORI,WCAL,WCAP,
&                            [F:SCH]INFCAPSTR,[F:SCH]INFCAPSTF,[F:SCH]SETENDDAT,[F:SCH]SETENDFRD,WNBRD,WNBR,WCOELAB,1,WNBRP,WRET)
&                            From JALLIBB
                If WRET > 0 : Break : Endif

                WCOELAB = [F:OPS]OPELABCOE
                WRET    = 0
                # 03.06 35162
                Call WSTLOAD(LMFGFCY,WWCR,WLAB,WMFGSTA,WORI,WCAL,WCAP,
&                            [F:SCH]SETENDDAT,[F:SCH]SETENDFRD,[F:SCH]INFCAPEND,[F:SCH]INFCAPENF,WNBRD,WNBR,WCOELAB,1,WNBRP,WRET)
&                            From JALLIBB
                If WRET > 0 : Break : Endif
            Else
                WNBR    = [F:OPS]EXTLABNBR
                WCOELAB = [F:OPS]OPELABCOE
                WRET    = 0
                # 03.06 35162
                Call WSTLOAD(LMFGFCY,WWCR,WLAB,WMFGSTA,WORI,WCAL,WCAP,
&                            [F:SCH]FITCAPSTR,[F:SCH]FITCAPSTF,[F:SCH]FITCAPEND,[F:SCH]FITCAPENF,WNBRD,WNBR,WCOELAB,1,WNBRP,WRET)
&                            From JALLIBB
                If WRET > 0 : Break : Endif
            Endif
        Endif
    Endif
Next

fstat = 0
End

#########################################################################
# Déchargement Workload des suggestions en sous-programme
# llc 11.02 16478
Subprog WORKUNLOADS(LMFGFCY, LMFGNUM, LSCDFLG)
Variable Char  LMFGFCY
Value Char     LMFGNUM
Value Integer  LSCDFLG

If !find(LSCDFLG, 2, 4) : End : Endif

Local Char     WCAL(2) # Cal number : unused
Local Date     WSTRCAL
Local Date     WENDCAL
Local Integer  WRET, WNBR, WORI, WNBRP     # 03.06 35162
Local Decimal  WCOELAB
Local Decimal  WCAP (2000)               : # capacité journalière poste
Local Integer  WNBRD (2000)              : # nombre d'exemplaires disponible journalier poste
Local Integer  WMFGSTA

If clalev([F:SCH]) = 0 : Local File SCHEDULING   [SCH] : Endif
If clalev([F:OPS]) = 0 : Local File OPERATIONS   [OPS] : Endif
If clalev([F:MWS]) = 0 : Local File WORKSTATIO   [MWS] : Endif
If clalev([F:TWD]) = 0 : Local File TABWEEDIA    [TWD] : Endif
If clalev([F:CPV]) = 0 : Local File CAPVAR       [CPV] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY     [FCY] : Endif
If clalev([F:TUV]) = 0 : Local File TABUNAVAIL   [TUV] : Endif

If [F:FCY]FCY <> LMFGFCY
    # lecture site
    Call LECTURE ("FCY", LMFGFCY, "") From CONTOBJ
Endif

If [F:TUV]UVYCOD <> [F:FCY]UVYCOD
    # lecture indisponibilités
    Read [F:TUV]UVY0=[F:FCY]UVYCOD
    If fstat : Raz [F:TUV] : Endif
Endif

Link [OPS] With [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM
&          As   [SCOP]
&          Where MFGNUM=LMFGNUM
&          Order By Key OPS1

For [SCOP]
    # lecture poste prévu au jalonnement précédent
    If [F:SCH]CLCWST <> ""
        WMFGSTA = 3

        Read [MWS]WST0=[F:SCH]CLCWST;LMFGFCY
        If fstat : Break : Endif

        # pas de WORKLOAD pour sous-traitance
        If [F:MWS]WSTTYP <> 3

            # chargement calendrier correspondant
            If LSCDFLG = 2
                WSTRCAL = [F:SCH]INFCAPSTR
                WENDCAL = [F:SCH]INFCAPEND + 10
            Else
                WSTRCAL = [F:SCH]FITCAPSTR
                WENDCAL = [F:SCH]FITCAPEND + 10
            Endif

            WRET    = 0
            Call LOACAPN (WSTRCAL,WENDCAL,WCAP,WNBRD,WRET)

            WCOELAB = 1
            WNBRP   = [F:OPS]EXTWSTNBR        # 03.06 35162
            WRET    = 0

            # --------- Initialisation pour PE WORKLOAD 10.06
            If dim(GCAPACITY) > 0
                GWKLACT = "U"
                GWKLMFG = [F:OPS]MFGNUM
                GWKLOPE = [F:OPS]OPENUM
                GWKLSPL = [F:OPS]OPESPLNUM
            Endif

            If LSCDFLG = 2
                # 03.06 35162
                Call WSTUNLD(LMFGFCY,[F:SCH]CLCWST,WMFGSTA,WORI,WCAL,WCAP,[F:SCH]INFCAPSTR,[F:SCH]INFCAPSTF,
&                            [F:SCH]INFCAPEND,[F:SCH]INFCAPENF,WNBRD,WNBRP,WCOELAB,0,WNBRP,WRET)
&                            From JALLIBB
            Else
                # 03.06 35162
                Call WSTUNLD(LMFGFCY,[F:SCH]CLCWST,WMFGSTA,WORI,WCAL,WCAP,[F:SCH]FITCAPSTR,[F:SCH]FITCAPSTF,
&                            [F:SCH]FITCAPEND,[F:SCH]FITCAPENF,WNBRD,WNBRP,WCOELAB,0,WNBRP,WRET)
&                            From JALLIBB
            Endif
            If WRET > 0 : Break : Endif

            If [F:SCH]CLCLAB <> ""
                Read [MWS]WST0=[F:SCH]CLCLAB;LMFGFCY
                If fstat : Break : Endif

                If LSCDFLG = 2
                    # dechargement WORKLOAD main d'oeuvre
                    WCOELAB = [F:SCH]SETLABCOE
                    WNBR    = [F:OPS]EXTLABNBR
                    WRET    = 0
                    # 03.06 35162
                    Call WSTUNLD(LMFGFCY,[F:SCH]CLCLAB,WMFGSTA,WORI,WCAL,WCAP,[F:SCH]INFCAPSTR,[F:SCH]INFCAPSTF,
&                               [F:SCH]SETENDDAT,[F:SCH]SETENDFRD,WNBRD,WNBR,WCOELAB,1,WNBRP,WRET)
&                              From JALLIBB
                    If WRET > 0 : Break : Endif

                    WCOELAB = [F:SCH]OPELABCOE
                    WRET    = 0
                    # 03.06 35162
                    Call WSTUNLD(LMFGFCY,[F:SCH]CLCLAB,WMFGSTA,WORI,WCAL,WCAP,[F:SCH]SETENDDAT,[F:SCH]SETENDFRD,
&                              [F:SCH]INFCAPEND,[F:SCH]INFCAPENF,WNBRD,WNBR,WCOELAB,1,WNBRP,WRET)
&                          From JALLIBB
                    If WRET > 0 : Break : Endif
                Else
                    WCOELAB = [F:SCH]OPELABCOE
                    WNBR    = [F:OPS]EXTLABNBR
                    WRET    = 0
                    # 03.06 35162
                    Call WSTUNLD(LMFGFCY,[F:SCH]CLCLAB,WMFGSTA,WORI,WCAL,WCAP,[F:SCH]FITCAPSTR,[F:SCH]FITCAPSTF,
&                               [F:SCH]FITCAPEND,[F:SCH]FITCAPENF,WNBRD,WNBR,WCOELAB,1,WNBRP,WRET)
&                          From JALLIBB
                    If WRET > 0 : Break : Endif
                Endif
            Endif
        Endif
  Endif
Next

fstat = 0
End

#########################################################################
# Conversion fraction de jour en durée en heure(s)
# 12.07
Subprog FRAC2DUR(LFCY, LWST, LDAT, LFRACTION, LTIME)
Value     Char    LFCY  # FGR 14/01/2010 : X3SUIVI60986
Value     Char    LWST
Value     Date    LDAT
Value     Decimal LFRACTION
Variable  Decimal LTIME

Local Integer IVAR : IVAR = 0
Local Integer IPER : IPER = 0
Local Integer IEND : IEND = 0
Local Integer J,K
Local Decimal WMRMD
Local Integer WMINT
Local Integer LRET, WNBR

If LDAT = [0/0/0] : End : Endif

If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif
If clalev([F:TWD])  = 0 : Local File TABWEEDIA  [TWD]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR     [CPV]  : Endif


# lecture poste
Gosub LOAD_MWS
If LRET : End : Endif

If [F:MWS]WSTTYP = 3 : LDAYCAP = 24 : LTIME = LFRACTION * 24 : End : Endif

# lecture variations de capacité
# Issue 95695 & 96955 GA 02/2014 optimisation
If ([F:CPV]WST <> [F:MWS]WST | [F:CPV]WCRFCY <> [F:MWS]WCRFCY)
  Local Date WDATD : WDATD = LDAT
  Local Date WDATF : WDATF = LDAT
  Gosub LOAD_CPV
  If LRET : End : Endif
Endif

Gosub LOAD_TWD_FROM_CPV
If LRET : End : Endif

J = dayn(LDAT) - 1
# calcul temps
LTIME = LFRACTION * [F:TWD]DAYCAP(J)
WMINT = int(LTIME)
WMRMD = LTIME - WMINT
If (WMRMD) >= 0.6 : WMINT += 1 : WMRMD -= 0.6 : Endif
LTIME = WMINT + WMRMD
End

# ------------------------------------------------------------------------------
# Chargement variations de capacité                     # Issue 88445 GA 03/2013
#   WDATD : Date début (borne incluse)
#   WDATF : Date fin (borne incluse)                    # Issue 95695 & 96955 GA 02/2014
#   les classes FCY, TUV et MWS doivent être en ligne !
#   les tables  TWD et CPV ouvertes !
# Renvoie IVAR=9 si aucune variation pour le site/poste se trouvant dans [F:MWS]
# ------------------------------------------------------------------------------
$LOAD_CPV
# lecture variations de capacité
# Issue 95695 & 96955 GA 02/2014 always read
#If ([F:CPV]WST <> [F:MWS]WST | [F:CPV]WCRFCY <> [F:MWS]WCRFCY)
    IVAR = 9
    Read [CPV]CPV0=[F:MWS]WST;[F:MWS]WCRFCY
    If fstat : fstat = 0
    Else
    # Issue 88445 GA 03/2013 optimisation: IVAR=9 si pas de variation dans la période
      For K = 0 To 24
          If [F:CPV]STRDAT(K) = [0/0/0] : Break : Endif
          #If [F:CPV]STRDAT(K) > WDATD   : IVAR = 0 : Break : Endif # Issue 95695 & 96955 GA 02/2014 Ko
          If [F:CPV]ENDDAT(K) >= WDATD   : IVAR = 0 : Break : Endif # Issue 95695 & 96955 GA 02/2014 new
          If [F:CPV]STRDAT(K) <= WDATF   : IVAR = 0 : Break : Endif # Issue 95695 & 96955 GA 02/2014 new
      Next
    Endif
#Endif
Return

# ------------------------------------------------------------------------------
# Chargement poste de travail                           # Issue 88445 GA 03/2013
# ------------------------------------------------------------------------------
$LOAD_MWS
If [F:MWS]WST <> LWST | [F:MWS]WCRFCY <> LFCY
    Read [MWS]WST0=LWST;LFCY
    If fstat : LRET=1 : Endif
Endif
Return

# ------------------------------------------------------------------------------
# Schéma horaire tenant compte variations de capacité   # Issue 88445 GA 03/2013
#   WDATD : Date début (borne incluse)
# En sortie: [F:TWD] chargé, WNBR renseigné et IPER = 1 si variation constatée
# ------------------------------------------------------------------------------
$LOAD_TWD_FROM_CPV
IPER = 0
# y a t'il une variation de capacité ?
If IVAR <> 9
    For K = 0 To 24
        If [F:CPV]STRDAT(K) = [0/0/0] : Break : Endif        # llc 10.02
        If [F:CPV]STRDAT(K) > WDATD   : Break : Endif
        If WDATD >= [F:CPV]STRDAT(K) & WDATD <= [F:CPV]ENDDAT(K)
            IPER = 1
            Break
        Endif
    Next
Endif

# lecture nouveau schéma si nécessaire
If IPER = 1
    WNBR = [F:CPV]WSTNBR(K)
    If [F:CPV]TWD(K) <> [F:TWD]TWD
        Read [F:TWD]TWD0=[F:CPV]TWD(K)
        If fstat : LRET=1 : Endif
    Endif
Else
    WNBR = [F:MWS]WSTNBR
    Gosub LOAD_TWD_FROM_MWS
Endif
Return

# ------------------------------------------------------------------------------
# Schéma horaire courant                                # Issue 88445 GA 03/2013
#   WDATD : Date début (borne incluse)
# En sortie: [F:TWD] chargé
# ------------------------------------------------------------------------------
$LOAD_TWD_FROM_MWS
If [F:TWD]TWD <> [F:MWS]TWD
    Read [TWD]TWD0=[F:MWS]TWD
    If fstat : LRET=1 : Endif
Endif
Return

# ------------------------------------------------------------------------------
# GH 15/11/13 bug 94460 optimisation de l'appel du point d'entrée CAPACITY
# ------------------------------------------------------------------------------
$PE_CAPACITY
# If dim(GCAPACITY)>0
#    If GCAPACITY : GPOINT = "CAPACITY" : Gosub ENTREE From EXEFNC : Endif
# Else
#    GPOINT = "CAPACITY" : Gosub ENTREE From EXEFNC
# Endif

If dim([L]IPECAPACITY)<0
  Local Integer IPECAPACITY
  If dim([V]GCAPACITY)>0
     IPECAPACITY = GCAPACITY
  Else
     IPECAPACITY = find("JALLIBB",GENTSTD(1..GNBENTREE))
  Endif
  If IPECAPACITY
     Local Char ACTION(20)
  Endif
Endif

If IPECAPACITY
  ACTION = "CAPACITY"
  If dim([V]GPOINTTRA)>0 & GPOINTTRA=1
     Call ECR_TRACE(mess(118,133,1)-":"-"JALLIBB"-ACTION,0) From GESECRAN
  Endif
  Gosub ACTION From =GENTSPE(IPECAPACITY)
Endif
Return

#########################################################################
## To help to debug
#########################################################################

$TODAY
TODAY = date$
# To freeze TODAY date with a different value than the date of the day
If GUSER="GH" & 0
   TODAY = [04/09/2018]
Endif
Return

Funprog DBG(K)
Value Integer K
If GUSER="GH" & 0 : # To Debug (& 1) or not to debug (& 0)
   Case K
     When -1
       If 1 : # with a log (=1) or screen display (=0)
         Call OUVRE_TRACE("Scheduling debug"-[M:JALK]MFGNUM) From LECFIC
         Call ECR_TRACE("DBG_I"
&             +chr$(13)+"Operation"
&             +chr$(13)+"WOPESTRD/F"
&             +chr$(13)+"WINFSTRD/F"
&             +chr$(13)+"WSETENDD/F"
&             +chr$(13)+"WINFENDD/F"
&             +chr$(13)+"WOPEENDD/F"
&             +chr$(13)+"*"
&        ,0) From GESECRAN
       Endif
     When 1
       [V]DBG_I+=1
   Endcase
   End 1
Else
   End 0
Endif

Subprog DBG_TRACKING(TEX)
Value Char TEX()
If !func DBG(1) : End : Endif
TEX = num$([V]DBG_I) + TEX
If GTRACE=""
   Local Char    TEX2(30)(10)
   Local Integer I, J, K
   J=1
   Repeat
     I=instr(J,TEX,chr$(13))
     If I : TEX2(K) = seg$(TEX,J,I-1) : Else TEX2(K) = right$(TEX,J) : Endif
     K+=1
     J=I+1
   Until I=0
   Infbox TEX2(0..K-1)
Else
   Call ECR_TRACE(TEX,0) From GESECRAN
Endif
If [V]DBG_I = 1 & 0 : # To debug from a step identified by a DBG_I value
    Dbgaff     #CHECK IGNORE_LINE
Endif
End

Funprog HD(VAL1)
Value Decimal VAL1
If GTRACE=""
   End num$(VAL1)
Else
   End num$(arr(VAL1,10^-7))
Endif

