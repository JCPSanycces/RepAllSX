#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################################
#
# GESTION DES BIENS - SUPPRESSION : FENETRE DE SAISIE DES IMPUTATIONS ANALYTIQUES 
# ===============================================================================
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Liste des sous-programmes :
# -------------------------
# 
#
#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $ACTION
#
########################################################################################################################
# Modifications :
# -------------
#
# - USR - xx.xx.xxxx - Fq yyyyy - Commentaire
########################################################################################################################
End

#------------------------------------------
$ACTION
 Case ACTION
  When "DEBUT"   : Gosub DEBUT
  When "SETBOUT" : Gosub SETBOUT
  When "BOUTON"  : Gosub BOUTON
  When "OK"      : Gosub OK
  When Default
 Endcase
Return

#------------------------------------------
$DEBUT
 Raz [M:FCE]
 [M:FCE]DSP=[M:FC1]EDSP(NOLIGNSAV-1)
 [M:FCE]DSPSAV=[M:FCE]DSP 
 Local Integer I_DIE
 For I_DIE=1 To [M:FC1]NBLEDDIE
  [M:FCE]DIE([M:FCE]NBDIE)=evalue("[M:FC1]EDIE"+num$(I_DIE)+"(NOLIGNSAV-1)")
  [M:FCE]DIEDES([M:FCE]NBDIE)=GTITDIE([M:FCE]NBDIE+1)
  [M:FCE]CCE([M:FCE]NBDIE)=evalue("[M:FC1]ECCE"+num$(I_DIE)+"(NOLIGNSAV-1)")
  [M:FCE]CCESAV([M:FCE]NBDIE)=[M:FCE]CCE([M:FCE]NBDIE)
  [M:FCE]NBDIE+=1
 Next I_DIE
 Affzo [M:FCE]   
Return

#------------------------------------------
$SETBOUT
Return

#------------------------------------------
$BOUTON
 Case  BOUT
  When "b" : FIN=1
  When "r" : Gosub RETABLIR
 Endcase
Return

#------------------------------------------
$OK
 If dim(GMSKORI)>0
  Case GMSKORI
   When "FC1" : Gosub MAJ_ANA_FC1
  Endcase
 Endif
Return

#------------------------------------------
$MAJ_ANA_FC1
  If [M:FCE]DSP<>[M:FCE]DSPSAV
   Call UPD_EVT_ANA_INFO("DSP", [M:FCE]DSP, [M:FC1]EVTDAT(NOLIGNSAV-1), [M:FC1]DPRPLN) From TRTFASCNLDOT
  Endif
  Local Integer I_DIE
  For I_DIE=1 To [M:FCE]NBDIE
   If evalue("[M:FCE]CCE(I_DIE-1)<>[M:FCE]CCESAV(I_DIE-1)")
    Call UPD_EVT_ANA_INFO("CCE"+num$(I_DIE), [M:FCE]CCE(I_DIE-1), [M:FC1]EVTDAT(NOLIGNSAV-1), [M:FC1]DPRPLN) From TRTFASCNLDOT
   Endif
  Next I_DIE 
Return

#------------------------------------------
$RETABLIR
 [M:FCE]DSP=[M:FCE]DSPSAV
 Local Integer I_DIE
 For I_DIE=1 To [M:FC1]NBLEDDIE
  [M:FCE]CCE(I_DIE-1)=[M:FCE]CCESAV(I_DIE-1)
 Next I_DIE 
 Call AM_DSP([M:FCE]DSP)
 Affzo [M:FCE]
Return

######################################################################################
Subprog AM_DSP(VALEUR)
Variable Char    VALEUR()
 If VALEUR<>""
  Raz [M:FCE]CCE
  Grizo [M:FCE]CCE
 Else
  Actzo [M:FCE]
 Endif
 Affzo [M:FCE]
End

