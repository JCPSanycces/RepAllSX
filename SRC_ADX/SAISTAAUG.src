#<AdxTL>@(#)10.0.0.0 $Revision$
Local Mask SAISTA [SAP]
Gosub OUVRE From SAISTA
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"DSTAAUG","SAISTAAUG","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "OK"           : Gosub ENREG
 When Default
Endcase
Return

$OUVRE
If clalev([F:PS1])=0  : Local File PARSTA1   [PS1]  : Endif
If clalev([F:PS2])=0  : Local File PARSTA2   [PS2]  : Endif
Local Mask    STAAUG [STAI]
Local Integer I, J, K, P
Local Decimal TOTAL(10), AUGMENT(10), ARROND(10)
Local Decimal SOMME(10), AREPART(10), AMTZ(10)
Local Char    CRITERE(250)
Local Date    DAT1, DAT2, DATZ
Local Integer MAXCRI : MAXCRI = dim([F:PS2]TBL)
Local Char    INTCLENIV(30)(1..MAXCRI)
Return

$DEBUT
Raz [M:STAI], J
Call LECTURE("PS1",[F:PS2]RLG,"") From CONTOBJ
[M]CPY     = [M:SAP]CPY
[M]FCY     = [M:SAP]FCY
[M]DATDEB  = [M:SAP]DATDEB
[M]DATFIN  = [M:SAP]DATFIN
[M]NIVEAU  = [M:SAP]NIVEAU
For [PSL] Where COD=[F:PS2]COD
 [M]NBRAMT += 1
 [M]FRTFLG([M]NBRAMT-1) = [F:PSL]FRTFLG 
 If [M]FRTFLG([M]NBRAMT-1)=2
  J += 1
  [M]VARNAM(J-1) = [F:PSL]VARNAM
  If [F:PSL]VARNAM<>""
   I = find([F:PSL]VARNAM,[F:PS1]VARNAM)
   If I
    Call LECTEXTRA([M]AMTDES(J-1),"PARSTA1","VARINTIT",[F:PS1]COD,num$(I)) From ATEXTRA
   Endif
  Else
   Call LECTEXTRA([M]AMTDES(J-1),"PARSTALIG","INTITVAR",[F:PS2]COD,num$(J)) From ATEXTRA
  Endif
 Endif
Next
[M]NBVAR = J
Affzo [STAI]
Return

$ENREG
Raz J
For I=0 To [M]NBRAMT-1
 If [M]FRTFLG(I)=2
  J += 1
  AUGMENT(I) = [M]AUGMENT(J-1)
  ARROND(I)  = [M]ARROND(J-1)
 Endif
Next I
Gosub SETPER From SAISTA
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [SAP]
 CRITERE  = 'COD="'+[F:PS2]UPDCOD+'"'
 CRITERE -= '& CPY="'+[M]CPY+'"'
 CRITERE -= '& FCY="'+[M]FCY+'"'
 CRITERE -= '& DAT>=['+format$(GFMD,[M]DATDEB)+']'
 CRITERE -= '& DAT<=['+format$(GFMD,[M]DATFIN)+']'
 Case [M]NIVEAU
  When 1
   CRITERE -= '& CRI2="$$$" & CRI3="$$$" & CRI4="$$$"'
   Case MAXCRI
    When 5 : CRITERE -= '& CRI5="$$$"'
    When 6 : CRITERE -= '& CRI5="$$$" & CRI6="$$$"'
    When 7 : CRITERE -= '& CRI5="$$$" & CRI6="$$$" & CRI7="$$$"'
    When 8 : CRITERE -= '& CRI5="$$$" & CRI6="$$$" & CRI7="$$$" & CRI8="$$$"'
   Endcase
  When 2
   CRITERE -= '& CRI2<>"$$$" & CRI3="$$$" & CRI4="$$$"'
   Case MAXCRI
    When 5 : CRITERE -= '& CRI5="$$$"'
    When 6 : CRITERE -= '& CRI5="$$$" & CRI6="$$$"'
    When 7 : CRITERE -= '& CRI5="$$$" & CRI6="$$$" & CRI7="$$$"'
    When 8 : CRITERE -= '& CRI5="$$$" & CRI6="$$$" & CRI7="$$$" & CRI8="$$$"'
   Endcase
  When 3
   CRITERE -= '& CRI2<>"$$$" & CRI3<>"$$$" & CRI4="$$$"'
   Case MAXCRI
    When 5 : CRITERE -= '& CRI5="$$$"'
    When 6 : CRITERE -= '& CRI5="$$$" & CRI6="$$$"'
    When 7 : CRITERE -= '& CRI5="$$$" & CRI6="$$$" & CRI7="$$$"'
    When 8 : CRITERE -= '& CRI5="$$$" & CRI6="$$$" & CRI7="$$$" & CRI8="$$$"'
   Endcase
  When 4
   CRITERE -= '& CRI2<>"$$$" & CRI3<>"$$$" & CRI4<>"$$$"'
   Case MAXCRI
    When 5 : CRITERE -= '& CRI5="$$$"'
    When 6 : CRITERE -= '& CRI5="$$$" & CRI6="$$$"'
    When 7 : CRITERE -= '& CRI5="$$$" & CRI6="$$$" & CRI7="$$$"'
    When 8 : CRITERE -= '& CRI5="$$$" & CRI6="$$$" & CRI7="$$$" & CRI8="$$$"'
   Endcase
  When 5
   CRITERE -= '& CRI2<>"$$$" & CRI3<>"$$$" & CRI4<>"$$$" & CRI5<>"$$$"'
   Case MAXCRI
    When 6 : CRITERE -= '& CRI6="$$$"'
    When 7 : CRITERE -= '& CRI6="$$$" & CRI7="$$$"'
    When 8 : CRITERE -= '& CRI6="$$$" & CRI7="$$$" & CRI8="$$$"'
   Endcase
  When 6
   CRITERE -= '& CRI2<>"$$$" & CRI3<>"$$$" & CRI4<>"$$$" & CRI5<>"$$$" & CRI6<>"$$$"'
   Case MAXCRI
    When 7 : CRITERE -= '& CRI7="$$$"'
    When 8 : CRITERE -= '& CRI7="$$$" & CRI8="$$$"'
   Endcase
  When 7
   CRITERE -= '& CRI2<>"$$$" & CRI3<>"$$$" & CRI4<>"$$$" & CRI5<>"$$$" & CRI6<>"$$$" & CRI7<>"$$$"'
   Case MAXCRI
    When 8 : CRITERE -= '& CRI8="$$$"'
   Endcase
  When 8
   CRITERE -= '& CRI2<>"$$$" & CRI3<>"$$$" & CRI4<>"$$$" & CRI5<>"$$$" & CRI6<>"$$$" & CRI7<>"$$$"'
   CRITERE -= '& CRI8<>"$$$"'
 Endcase
 If clalev([F:AAA_]) : Close Local File [AAA_] : Endif
 Case MAXCRI
  When 4
   Local File STATPRV [AAA_] Where evalue(CRITERE) Order By Key CLE = CRI1;CRI2;CRI3;CRI4;DAT
   For [AAA_]CLE(4)
    Raz TOTAL
    For [AAA_]CLE
     For I=0 To [M]NBRAMT-1
      If [M]FRTFLG(I)=2
       TOTAL(I) += [F:AAA_]AMT(I)
      Endif
     Next I
    Next AAA_
    Gosub ENREG_AUG
    If GOK<1 : Break : Endif
   Next AAA_
  When 5
   Local File STATPRV [AAA_] Where evalue(CRITERE) Order By Key CLE = CRI1;CRI2;CRI3;CRI4;CRI5;DAT
   For [AAA_]CLE(5)
    Raz TOTAL
    For [AAA_]CLE
     For I=0 To [M]NBRAMT-1
      If [M]FRTFLG(I)=2
       TOTAL(I) += [F:AAA_]AMT(I)
      Endif
     Next I
    Next AAA_
    Gosub ENREG_AUG
    If GOK<1 : Break : Endif
   Next AAA_
  When 6
   Local File STATPRV [AAA_] Where evalue(CRITERE) Order By Key CLE = CRI1;CRI2;CRI3;CRI4;CRI5;CRI6;DAT
   For [AAA_]CLE(6)
    Raz TOTAL
    For [AAA_]CLE
     For I=0 To [M]NBRAMT-1
      If [M]FRTFLG(I)=2
       TOTAL(I) += [F:AAA_]AMT(I)
      Endif
     Next I
    Next AAA_
    Gosub ENREG_AUG
    If GOK<1 : Break : Endif
   Next AAA_
  When 7
   Local File STATPRV [AAA_] Where evalue(CRITERE) Order By Key CLE = CRI1;CRI2;CRI3;CRI4;CRI5;CRI6;CRI7;DAT
   For [AAA_]CLE(7)
    Raz TOTAL
    For [AAA_]CLE
     For I=0 To [M]NBRAMT-1
      If [M]FRTFLG(I)=2
       TOTAL(I) += [F:AAA_]AMT(I)
      Endif
     Next I
    Next AAA_
    Gosub ENREG_AUG
    If GOK<1 : Break : Endif
   Next AAA_
  When 8
   Local File STATPRV [AAA_] Where evalue(CRITERE) Order By Key CLE = CRI1;CRI2;CRI3;CRI4;CRI5;CRI6;CRI7;CRI8
&                                                                     ;DAT
   For [AAA_]CLE(8)
    Raz TOTAL
    For [AAA_]CLE
     For I=0 To [M]NBRAMT-1
      If [M]FRTFLG(I)=2
       TOTAL(I) += [F:AAA_]AMT(I)
      Endif
     Next I
    Next AAA_
    Gosub ENREG_AUG
    If GOK<1 : Break : Endif
   Next AAA_
 Endcase
 If    GOK=0 : Goto AB_TR1
 Elsif GOK<0 : Goto ROLL_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$ENREG_AUG
CRITERE  = 'COD="'+[F:PS2]UPDCOD+'"'
CRITERE -= '& CPY="'+[M]CPY+'"'
CRITERE -= '& FCY="'+[M]FCY+'"'
CRITERE -= '& DAT>=['+format$(GFMD,[M]DATDEB)+']'
CRITERE -= '& DAT<=['+format$(GFMD,[M]DATFIN)+']'
Case [M]NIVEAU
 When 1
  CRITERE -= '& CRI1="'+[F:AAA_]CRI1+'"'
 When 2
  CRITERE -= '& CRI1="'+[F:AAA_]CRI1+'" & CRI2="'+[F:AAA_]CRI2+'"'
 When 3
  CRITERE -= '& CRI1="'+[F:AAA_]CRI1+'" & CRI2="'+[F:AAA_]CRI2+'" & CRI3="'+[F:AAA_]CRI3+'"'
 When 4
  CRITERE -= '& CRI1="'+[F:AAA_]CRI1+'" & CRI2="'+[F:AAA_]CRI2+'" & CRI3="'+[F:AAA_]CRI3+'"'
  CRITERE -= '& CRI4="'+[F:AAA_]CRI4+'"'
 When 5
  CRITERE -= '& CRI1="'+[F:AAA_]CRI1+'" & CRI2="'+[F:AAA_]CRI2+'" & CRI3="'+[F:AAA_]CRI3+'"'
  CRITERE -= '& CRI4="'+[F:AAA_]CRI4+'" & CRI5="'+[F:AAA_]CRI5+'"'
 When 6
  CRITERE -= '& CRI1="'+[F:AAA_]CRI1+'" & CRI2="'+[F:AAA_]CRI2+'" & CRI3="'+[F:AAA_]CRI3+'"'
  CRITERE -= '& CRI4="'+[F:AAA_]CRI4+'" & CRI5="'+[F:AAA_]CRI5+'" & CRI6="'+[F:AAA_]CRI6+'"'
 When 7
  CRITERE -= '& CRI1="'+[F:AAA_]CRI1+'" & CRI2="'+[F:AAA_]CRI2+'" & CRI3="'+[F:AAA_]CRI3+'"'
  CRITERE -= '& CRI4="'+[F:AAA_]CRI4+'" & CRI5="'+[F:AAA_]CRI5+'" & CRI6="'+[F:AAA_]CRI6+'"'
  CRITERE -= '& CRI7="'+[F:AAA_]CRI7+'"'
 When 8
  CRITERE -= '& CRI1="'+[F:AAA_]CRI1+'" & CRI2="'+[F:AAA_]CRI2+'" & CRI3="'+[F:AAA_]CRI3+'"'
  CRITERE -= '& CRI4="'+[F:AAA_]CRI4+'" & CRI5="'+[F:AAA_]CRI5+'" & CRI6="'+[F:AAA_]CRI6+'"'
  CRITERE -= '& CRI7="'+[F:AAA_]CRI7+'" & CRI8="'+[F:AAA_]CRI8+'"'
Endcase
Delete [SAP] Where evalue(CRITERE)
If fstat=1
 GOK = -1 : GLOCK = "$STATPRV"-COD-CPY-FCY : Return
Endif
For I=0 To [M]NBRAMT-1
 If [M]FRTFLG(I)=2
  AREPART(I) = TOTAL(I)*(1+AUGMENT(I)/100)
 Endif
Next I
Raz [F:SAP]
[F:SAP]COD  = [F:PS2]UPDCOD
[F:SAP]CPY  = [M]CPY
[F:SAP]FCY  = [M]FCY
For I=1 To MAXCRI
 Case I
  When 1 : [F:SAP]CRI1 = [F:AAA_]CRI1
  When 2 : [F:SAP]CRI2 = [F:AAA_]CRI2
  When 3 : [F:SAP]CRI3 = [F:AAA_]CRI3
  When 4 : [F:SAP]CRI4 = [F:AAA_]CRI4
  When 5 : [F:SAP]CRI5 = [F:AAA_]CRI5
  When 6 : [F:SAP]CRI6 = [F:AAA_]CRI6
  When 7 : [F:SAP]CRI7 = [F:AAA_]CRI7
  When 8 : [F:SAP]CRI8 = [F:AAA_]CRI8
 Endcase
Next I
Raz SOMME
For J=1 To NBPER
 DATZ = DATPER(J)
 For I=0 To [M]NBRAMT-1
  AMTZ(I)   = arr((AREPART(I)/NBPER)+SOMME(I),ARROND(I)) - arr(SOMME(I),ARROND(I))
  SOMME(I) += AREPART(I)/NBPER
 Next I
 Case MAXCRI
  When 4 : Read [SAP]SAP0 = [F:PS2]UPDCOD ; [M]CPY ; [M]FCY ; DATZ
&                         ; [F:AAA_]CRI1 ; [F:AAA_]CRI2 ; [F:AAA_]CRI3 ; [F:AAA_]CRI4
  When 5 : Read [SAP]SAP0 = [F:PS2]UPDCOD ; [M]CPY ; [M]FCY ; DATZ
&                         ; [F:AAA_]CRI1 ; [F:AAA_]CRI2 ; [F:AAA_]CRI3 ; [F:AAA_]CRI4
&                         ; [F:AAA_]CRI5
  When 6 : Read [SAP]SAP0 = [F:PS2]UPDCOD ; [M]CPY ; [M]FCY ; DATZ
&                         ; [F:AAA_]CRI1 ; [F:AAA_]CRI2 ; [F:AAA_]CRI3 ; [F:AAA_]CRI4
&                         ; [F:AAA_]CRI5 ; [F:AAA_]CRI6
  When 7 : Read [SAP]SAP0 = [F:PS2]UPDCOD ; [M]CPY ; [M]FCY ; DATZ
&                         ; [F:AAA_]CRI1 ; [F:AAA_]CRI2 ; [F:AAA_]CRI3 ; [F:AAA_]CRI4
&                         ; [F:AAA_]CRI5 ; [F:AAA_]CRI6 ; [F:AAA_]CRI7
  When 8 : Read [SAP]SAP0 = [F:PS2]UPDCOD ; [M]CPY ; [M]FCY ; DATZ
&                         ; [F:AAA_]CRI1 ; [F:AAA_]CRI2 ; [F:AAA_]CRI3 ; [F:AAA_]CRI4
&                         ; [F:AAA_]CRI5 ; [F:AAA_]CRI6 ; [F:AAA_]CRI7 ; [F:AAA_]CRI8
 Endcase
 If fstat
  Raz [F:SAP]
  [F:SAP]COD  = [F:PS2]UPDCOD
  [F:SAP]CPY  = [M]CPY
  [F:SAP]FCY  = [M]FCY
  For I=1 To MAXCRI
   Case I
    When 1 : [F:SAP]CRI1 = [F:AAA_]CRI1
    When 2 : [F:SAP]CRI2 = [F:AAA_]CRI2
    When 3 : [F:SAP]CRI3 = [F:AAA_]CRI3
    When 4 : [F:SAP]CRI4 = [F:AAA_]CRI4
    When 5 : [F:SAP]CRI5 = [F:AAA_]CRI5
    When 6 : [F:SAP]CRI6 = [F:AAA_]CRI6
    When 7 : [F:SAP]CRI7 = [F:AAA_]CRI7
    When 8 : [F:SAP]CRI8 = [F:AAA_]CRI8
   Endcase
  Next I
  [F:SAP]DAT  = DATZ
  For I=0 To [M]NBRAMT-1
   [F:SAP]AMT(I) = AMTZ(I)
  Next I
  Write [SAP]
  If fstat
   GOK = 0 : Call FSTA("SAP") From GLOCK
   Break
  Endif
 Else
  For I=0 To [M]NBRAMT-1
   [F:SAP]AMT(I) += AMTZ(I)
  Next I
  Rewrite [SAP]
  If fstat
   GOK = 0 : Call FSTA("SAP") From GLOCK
   Break
  Endif
 Endif
Next J
If GOK<1 : Return : Endif
Default Mask [SAP]
Gosub MAJ_NIVEAU From SAISTA
Return


