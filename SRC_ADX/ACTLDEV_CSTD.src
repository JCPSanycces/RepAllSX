#<AdxTL>@(#)0.0.0.0 $Revision$
# Class ACTLDEV_COLACD

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When "COLACD"
    Case [L]AEVENT
      When "AREAD_AFTER"               : Gosub COLADX_AREAD_AFTER
      When "AINSERT_CONTROL_BEFORE"    : Gosub AINSERT
      When "ADELETE_CONTROL_AFTER"     : Gosub ADELETE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "COLACD.RAN"              : Gosub RAN
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return






$ADELETE
this.APARENT.NBLIG = this.AORDER

Return


$AINSERT
this.APARENT.NBLIG = maxtab(this.APARENT.COLACD)

Return

$RAN
Case [L]ARULE
  When "CONTROL"      : Gosub RAN_CONTROL
Endcase
Return


#**
#* RAN - Allow RAN selection based on object's restrictions
#*!
$RAN_CONTROL
#Variable Char VALEUR this.RAN is new property
Local Integer I , K , OK, OCCURS
Local Char    DEB(20) , FIN(20) , RANDEB(20) , RANFIN(20), WMESS(100)
[L]OCCURS=0

If this.RAN = AVOID.ACHAR : End : Endif  # ""
Local File ACTLDEV [ACD]
K = instr(1,this.RAN,"-")
If !K
 #GMESSAGE = mess(134,141,1) : # Erreur de SYNTAXE
 #mkstat = 1 : End
 [L]ASTATUS = fmet this.ASETERROR("RAN",mess(134,141,1),[V]CST_AERROR)
 Return
Endif

# Replace below with check of ACD using fmet method AREAD using new local instance
# Strictly a check to prevent entries reserved for supervisor or already on previous line
RANDEB = left$(this.RAN,K-1)
RANFIN = right$(this.RAN,K+1)
OK = 1
For [ACD] Where [ACD]COD<>this.APARENT.COD
 For I=1 To [F:ACD]NBLIG
  If [F:ACD]TYP(I-1)=this.TYP  #(nolign-1)
   K = instr(1,[F:ACD]RAN(I-1),"-")
   If K
    DEB = left$([F:ACD]RAN(I-1),K-1)
    FIN = right$([F:ACD]RAN(I-1),K+1)
    Case [F:ACD]TYP(I-1)
     When 1 , 4 : # Objets/Champs
      OKPLG  = (RANDEB>=DEB & RANDEB<=FIN)
      OKPLG += (RANFIN>=DEB & RANFIN<=FIN)
      OKPLG += (DEB>=RANDEB & DEB<=RANFIN)
      OKPLG += (FIN>=RANDEB & FIN<=RANFIN)
      OKPLG = !OKPLG
     When 2 , 3 : # Menus locaux/Tables diverse
      OKPLG  = (val(RANDEB)>=val(DEB) & val(RANDEB)<=val(FIN))
      OKPLG += (val(RANFIN)>=val(DEB) & val(RANFIN)<=val(FIN))
      OKPLG += (val(DEB)>=val(RANDEB) & val(DEB)<=val(RANFIN))
      OKPLG += (val(FIN)>=val(RANDEB) & val(FIN)<=val(RANFIN))
      OKPLG = !OKPLG
    Endcase
    If !OKPLG
     # Plage déjà utilisée
     WMESS = mess(207,133,1)
     WMESS += func ASYRFNC.TEXTRA("ACTLDEV","INTCOD",[F:ACD]COD,"")-"("+[F:ACD]COD+")"
     WMESS += "\"+[F:ACD]RAN(I-1)-func ASYRFNC.TEXTRA("ACTLDEV","INTRAN",[F:ACD]COD,num$(I-1))
     [L]ASTATUS = fmet this.ASETERROR("",WMESS,[V]CST_AERROR)
      OK = 0 : Break 2
    Endif
   Endif
  Endif
 Next I
Next ACB

If OK
Local Char MESSAGE(250)
  [L]ASTATUS=func SUPER_TOOL._UNIQUE_PROPERTY(this.APARENT.COLACD,"RAN",RANDEB+"-"+RANFIN,MESSAGE)  # Removed S from TOOLS
  If[L]ASTATUS<>[V]CST_AOK
    WMESS = MESSAGE
    OK=0
  Endif
Endif

If !OK
 [L]ASTATUS = fmet this.ASETERROR(this.RAN,WMESS,[V]CST_AERROR)
 Return
Endif
Return


$COLADX_AREAD_AFTER
this.INTRANIDX = this.AORDER-1           # ATEXTRA - index stored with comment
this.DSPIDX    = this.AORDER             # Display Index ( 1 to a max of COLACD)
Return

