#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
######################################################################################
$ACTION

Case ACTION
  When "INIT_DIA" : Gosub INIT_DIA
  When "EXEC"     : Gosub EXEC
Endcase

Return
######################################################################################
######################################################################################
$INIT_DIA

Raz [M:DVPIE]
Affzo [M:DVPIE]

Return
######################################################################################
######################################################################################
$EXEC

If [M:DVPIE]NBLIG = 0 : Return : Endif

Local Integer I, TRA
Local Char    SYMBOLE(50)
Local Char    DTYP(3)

If GTRACE = ""
  Call OUVRE_TRACE(mess(8,26,1)) From LECFIC
  TRA = 1
Endif

If !clalev([F:PIH]) : Local File PINVOICE [F:PIH] : Endif
If !clalev([F:SIH]) : Local File SINVOICE [F:SIH] : Endif

Call DEBTRANS From GLOCK
Trbegin [F:SIV], [F:PIH]

Case [M:DVPIE]TYP
  When 1
    [L]DTYP = "PIH"
    For I = 0 To [M:DVPIE]NBLIG
      Read [F:PIH]PIH0 = [M:DVPIE]VCRNUM(I)
      If !fstat
        SYMBOLE = [L]DTYP+[M:DVPIE]VCRNUM(I)
        Lock =SYMBOLE With lockwait=0
        If   fstat=1
          Call ECR_TRACE([M:DVPIE]EXTVCRNUM(I)-mess(10,100,1),1) From GESECRAN
          GOK = 0 : Break
        Elsif fstat = 0
          [F:PIH]PORIMPLIQNUM = [M:DVPIE]EXTVCRNUM(I)
          Rewrite [F:PIH]
          If !fstat : GOK = 0 : Break : Endif
          Unlock =SYMBOLE
          Call ECR_TRACE([M:DVPIE]VCRNUM(I)-mess(1,718,1)-mess(15,9003,1)-[M:DVPIE]EXTVCRNUM(I), 0) From GESECRAN
        Endif
      Endif
    Next
  When 2
    [L]DTYP = "SIV"
    For I = 0 To [M:DVPIE]NBLIG
      Read [F:SIH]SIH0 = [M:DVPIE]VCRNUM(I)
      If !fstat
        SYMBOLE = [L]DTYP+[M:DVPIE]VCRNUM(I)
        Lock =SYMBOLE With lockwait=0
        If   fstat=1
          Call ECR_TRACE([M:DVPIE]EXTVCRNUM(I)-mess(10,100,1),1) From GESECRAN
          GOK = 0 : Break
        Elsif fstat = 0
          [F:SIH]POREXPDCL = [M:DVPIE]EXTVCRNUM(I)
          Rewrite [F:SIH]
          If !fstat : GOK = 0 : Break : Endif
          Unlock =SYMBOLE
          Call ECR_TRACE([M:DVPIE]VCRNUM(I)-mess(1,718,1)-mess(15,9003,1)-[M:DVPIE]EXTVCRNUM(I), 0) From GESECRAN
        Endif
      Endif
    Next
Endcase

If !GOK
  Call RSTA([L]DTYP,[L]DCLNUM) From GLOCK
  Rollback
Else
  Commit
Endif

If TRA
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Return
######################################################################################
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" & [M:DVPIE]STRDAT <> [0/0/0] & [M:DVPIE]ENDDAT <> [0/0/0] & [M:DVPIE]TYP <> 0
  Call GETEXTVCRDOC (VALEUR, [M:DVPIE]STRDAT, [M:DVPIE]ENDDAT, [M:DVPIE]TYP)
Endif

End
######################################################################################
######################################################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR

If [M:DVPIE]CPY <> "" & VALEUR <> [0/0/0] & [M:DVPIE]ENDDAT <> [0/0/0] & [M:DVPIE]TYP <> 0
  Call GETEXTVCRDOC ([M:DVPIE]CPY, VALEUR, [M:DVPIE]ENDDAT, [M:DVPIE]TYP)
Endif

End
######################################################################################
######################################################################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR

If [M:DVPIE]CPY <> "" & [M:DVPIE]STRDAT <> [0/0/0] & VALEUR <> [0/0/0] & [M:DVPIE]TYP <> 0
  Call GETEXTVCRDOC ([M:DVPIE]CPY, [M:DVPIE]STRDAT, VALEUR, [M:DVPIE]TYP)
Endif

End
######################################################################################
######################################################################################
Subprog AM_TYP(VALEUR)
Variable Integer VALEUR

If [M:DVPIE]CPY <> "" & [M:DVPIE]STRDAT <> [0/0/0] & [M:DVPIE]ENDDAT <> [0/0/0] & VALEUR <> 0
  Call GETEXTVCRDOC ([M:DVPIE]CPY, [M:DVPIE]STRDAT, [M:DVPIE]ENDDAT, VALEUR)
Endif

End
######################################################################################
######################################################################################
Subprog GETEXTVCRDOC(CPY, STRDAT, ENDDAT, TYP)
Value Char    CPY
Value Date    STRDAT
Value Date    ENDDAT
Value Integer TYP

Raz [M:DVPIE]VCRNUM(0..dim([M:DVPIE]VCRNUM)-1)
Raz [M:DVPIE]EXTVCRNUM(0..dim([M:DVPIE]VCRNUM)-1)
Raz [M:DVPIE]NBLIG

Case [L]TYP
  When 1
    Local File PINVOICE [PIH]
    For [F:PIH] Where [F:PIH]CPY = [L]CPY & [F:PIH]ACCDAT >= [L]STRDAT & [F:PIH]ACCDAT <= [L]ENDDAT & [F:PIH]PORIMPLIQNUM <> ""
      [M:DVPIE]VCRNUM([M:DVPIE]NBLIG)    = [F:PIH]NUM
      [M:DVPIE]EXTVCRNUM([M:DVPIE]NBLIG) = [F:PIH]PORIMPLIQNUM
      [M:DVPIE]NBLIG                    += 1
    Next
  When 2
    Local File SINVOICE [SIH]
    For [F:SIH] Where [F:SIH]CPY = [L]CPY & [F:SIH]ACCDAT >= [L]STRDAT & [F:SIH]ACCDAT <= [L]ENDDAT & [F:SIH]POREXPDCL <> ""
      [M:DVPIE]VCRNUM([M:DVPIE]NBLIG)    = [F:SIH]NUM
      [M:DVPIE]EXTVCRNUM([M:DVPIE]NBLIG) = [F:SIH]POREXPDCL
      [M:DVPIE]NBLIG                    += 1
    Next
Endcase

Affzo [M:DVPIE]

End
######################################################################################
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

If func AFNC.PARAM("PORVAT",VALEUR)<>"2"
  mkstat = 2
  GMESSAGE = func AFNC.MES2(mess(00218,00125,1), "PORVAT", mess(00001,00001,1))
Endif

End
######################################################################################
######################################################################################
