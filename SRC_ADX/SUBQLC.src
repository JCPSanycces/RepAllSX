#<AdxTL>@(#)7.0.0.0 $Revision$
#Call GENDOS("GX3APP")
#End

###########################################################
## Programme de gestion des fiches techniques            ##
###########################################################
## écrit en novembre 1997 par Adeline Lenoir             ##
###########################################################
$ACTION
Case ACTION
  When "AVANT_OUVRE" : Gosub AVANT_OUVRE
  When "VERIF_CRE"   : Gosub VERIF_CRE
  When "CREATION"    : Gosub CREATION
  When "SETBOUT"     : Gosub SETBOUT
  When "EXEBOUT"     : Gosub EXEBOUT
  When "MODIF"       : Gosub GENECR
  When "AV_ANNULE"   : Gosub AV_ANNULE
  When "ANNULE"      : Gosub ANNULE                    # FGR 24/09/2009 : X3SUIVI58062
  When "LIENS"       : Gosub LIENS                     # hcb V6CQ
  When Default
Endcase
Return
#####################################################
$AVANT_OUVRE
# Création des fenetres premiere execution V140
Local Decimal W_SEQ : W_SEQ = 1
#
If clalev([F:QLC1]) = 0 : Local File QLYCRD [QLC1] : Endif
If clalev([F:QLC2]) = 0 : Local File QLYCRD [QLC2] : Endif

Filter [QLC1] Order  By Key QLC2
Read [QLC1] Last
If fstat = 0
  W_SEQ = [F:QLC1]SEQ+1
Endif
#
Filter [QLC1] Where SEQ    = 0 &
&                   NUMLIN = 1
&             Order By Key QLC1
For [QLC1]
  Trbegin [QLC1]
  GOK = 1
  Filter [QLC2] Where QLYCRD = [F:QLC1]QLYCRD
&               Order By Key QLC0
  For [QLC2]
    [F:QLC2]SEQ = W_SEQ
    Rewrite [QLC2]
    If fstat
      GOK = 0
      Call FSTA("QLC2") From GLOCK
      Break 2
    Endif
  Next
  Filter [QLC2]
  Call GENCRD(nomap,"QLYCRD1","IQLYCRD",[F:QLC1]QLYCRD) From CRDLIB
  W_SEQ += 1
  Case GOK
    When 1       : Commit
    When Default : Rollback
  Endcase
Next
Filter [QLC1]
Return
#####################################################
$VERIF_CRE

Filter [QLC1] Order  By Key QLC2
Readlock [QLC1] Last
If fstat = 0
  [M:QLC1]SEQ = [F:QLC1]SEQ+1
Else
  [M:QLC1]SEQ = 1
Endif
Filter [QLC1]
Return
#####################################################
$CREATION
   # FGR 24/09/2009 : X3SUIVI58062
  #--- maj de la table des libéllés traduisibles
  If nolign = 1
    # Pas la peine de le faire plusieurs fois
    Call MAJTEXTRA([M:QLC1]QLYDESAXX,"QLYCRD","QLYDESAXX",[M:QLC1]QLYCRD,"") From ATEXTRA
  Endif
  If dim([M:QLC1]ZQSTNUM) < 0 Then
     Call MAJTEXTRA([M:QLC1]QSTTEXAXX(nolign-1),"QLYCRD","QSTTEXAXX",[M:QLC1]QLYCRD,num$([F:QLC]NUMLIN)) From ATEXTRA
  Else
    If [M:QLC1]QSTNUM(nolign-1) = "" or [M:QLC1]ZQSTNUM(nolign-1) <> [M:QLC1]QSTTEXAXX(nolign-1) Then
       Call MAJTEXTRA([M:QLC1]QSTTEXAXX(nolign-1),"QLYCRD","QSTTEXAXX",[M:QLC1]QLYCRD,num$([F:QLC]NUMLIN)) From ATEXTRA
    Else
      # Si les deux textes sont indentiques : on le recopie dans toutes les langues disponibles
         Call DUPTEXTRA("QLYCRDQST","QSTDESAXX",[M:QLC1]QSTNUM(nolign-1),"", "QLYCRD","QSTTEXAXX",[M:QLC1]QLYCRD,num$([F:QLC]NUMLIN)) From ATEXTRA
    Endif
  Endif
  #
  If nolign = 1 & GREP <> "M"    # hcb cc 74033
    Gosub GENECR
  Endif
Return

#####################################################
$ANNULE
  # FGR 24/09/2009 : X3SUIVI58062
  #--- maj de la table des libéllés traduisibles
  Call SUPTEXTRA("QLYCRD","QLYDESAXX",[M:QLC1]QLYCRD,"") From ATEXTRA
  # Note FGR : le SUPTEXTRA ne fonctionne pas dans ce cas
  #Call SUPTEXTRA("QLYCRD","QSTTEXAXX",[M:QLC1]QLYCRD,num$([M:QLC1]NUMLIN(nolign-1))) From ATEXTRA
  Delete [AXX] Where CODFIC="QLYCRD" and ZONE="QSTTEXAXX" and IDENT1=[M:QLC1]QLYCRD
Return

#####################################################
$AV_ANNULE
Call DELCRD(nomap,"QLYCRD1","IQLYCRD",[M:QLC1]QLYCRD) From CRDLIB
Return
#####################################################
$GENECR
Call GENCRD(nomap,"QLYCRD1","IQLYCRD",[M:QLC1]QLYCRD) From CRDLIB
Return
#####################################################
$SETBOUT
If !clalev([F:AWI]) : Local File AWINDOW [AWI] : Endif
Look [AWI]AWI0="WUQ"+format$("N0:5#",[M:QLC1]SEQ)
If !CLECUR or REP<>"" or !VERROU or fstat
 Call VIREBOUT(CHAINE,"a") From GOBJET
Endif
Return
#####################################################
$EXEBOUT
Global Char GWSSMPLOT(20)          # hcb V6CQ
Global Char GWSSMPSLO(20)          # hcb V6CQ
GWSSMPLOT   = GSINVLOT             # hcb V6CQ
GWSSMPSLO   = GSINVSLO             # hcb V6CQ
Case REP
  When "a" : Call SIMUL("WUQ"+format$("N0:5#",[M:QLC1]SEQ)) From SUBAWI
Endcase
Return

#####################################################
#                                                  # hcb V6CQ deb
$LIENS
If [F:QLC]QSTNUM <> ""
   Read [QLQ]QLQ0=[F:QLC]QSTNUM
   If !fstat
      [M] = [F:QLQ]
      If [F:QLQ]DEMASWTYP = 1
         [M]STRVAL(nolign-1) = [F:QLQ]ALPSTRVAL
         [M]ENDVAL(nolign-1) = [F:QLQ]ALPENDVAL
         [M]NMNVAL(nolign-1 )= [F:QLQ]ALPNMNVAL                 # hcb V6CQ
      Else
         [M]STRVAL(nolign-1)= num$([F:QLQ]NUMSTRVAL)
         [M]ENDVAL(nolign-1)= num$([F:QLQ]NUMENDVAL)
         [M]NMNVAL(nolign-1)= num$([F:QLQ]NUMNMNVAL)
         If [F:QLQ]NUMSTRVAL=0 & [F:QLQ]DEMCTLTYP=1
            Raz [M]STRVAL(nolign-1)
         Endif
         If [F:QLQ]NUMENDVAL=0 & [F:QLQ]DEMCTLTYP=1
            Raz [M]ENDVAL(nolign-1)
         Endif
         If [F:QLQ]NUMNMNVAL=0 & [F:QLQ]DEMCTLTYP=1
            Raz [M]NMNVAL(nolign-1)
         Endif
      Endif
   Endif
Endif
Return
#                                                  # hcb V6CQ fin

#####################################################
Subprog AP_QSTNUM(VALEUR)
Variable Char     VALEUR
Local Char WTEX(50)                                             # hcb V6CQ
# alimentation du texte vide avec la désignation de la question
If VALEUR <> ""
   Read [QLQ]QLQ0=VALEUR
   If !fstat
      #If [M]TEX(nolign-1) <> ""                                 # hcb V6CQ
      If [M:QLC1]QSTTEXAXX(nolign-1) <> ""                       # FGR 24/09/2009 : X3SUIVI58062
         #WTEX = [M]TEX(nolign-1)                                # hcb V6CQ
         WTEX = [M:QLC1]QSTTEXAXX(nolign-1)                      # FGR 24/09/2009 : X3SUIVI58062
      Endif
      #Call LECTEXTRA([M]TEX(nolign-1),"QLYCRDQST","QSTDESAXX",[F:QLQ]QSTNUM,"") From ATEXTRA                                                      # hcb V6CQ
      Call LECTEXTRA([M:QLC1]QSTTEXAXX(nolign-1),"QLYCRDQST","QSTDESAXX",[F:QLQ]QSTNUM,"") From ATEXTRA   # FGR 24/09/2009 : X3SUIVI58062
      If [M:QLC1]QSTTEXAXX(nolign-1) = "" Then
        # FGR 24/09/2009 : X3SUIVI58062 on va voir s'il y a un court
        Call LECTEXTRA([M:QLC1]QSTTEXAXX(nolign-1),"QLYCRDQST","QSTSHOAXX",[F:QLQ]QSTNUM,"") From ATEXTRA   # FGR 24/09/2009 : X3SUIVI58062
      Endif
      #[M]TEX(nolign-1) = [F:QLQ]QSTDES
      [M] = [F:QLQ]                                             # hcb V6CQ
#     Affzo TEX(nolign-1)                                       # hcb V6CQ
      If WTEX <> ""                                             # hcb V6CQ
         #[M]TEX(nolign-1) = WTEX                               # hcb V6CQ
         [M:QLC1]QSTTEXAXX(nolign-1) = WTEX                     # FGR 24/09/2009 : X3SUIVI58062
      Endif                                                     # hcb V6CQ
      If [F:QLQ]DEMASWTYP = 1                                   # hcb V6CQ
         [M]STRVAL(nolign-1) = [F:QLQ]ALPSTRVAL                 # hcb V6CQ
         [M]ENDVAL(nolign-1) = [F:QLQ]ALPENDVAL                 # hcb V6CQ
         [M]NMNVAL(nolign-1 )= [F:QLQ]ALPNMNVAL                 # hcb V6CQ
      Else                                                      # hcb V6CQ
         [M]STRVAL(nolign-1)= num$([F:QLQ]NUMSTRVAL)            # hcb V6CQ
         [M]ENDVAL(nolign-1)= num$([F:QLQ]NUMENDVAL)            # hcb V6CQ
         [M]NMNVAL(nolign-1)= num$([F:QLQ]NUMNMNVAL)            # hcb V6CQ
         If [F:QLQ]NUMSTRVAL=0 & [F:QLQ]DEMCTLTYP=1             # hcb V6CQ
            Raz [M]STRVAL(nolign-1)                             # hcb V6CQ
         Endif                                                  # hcb V6CQ
         If [F:QLQ]NUMENDVAL=0 & [F:QLQ]DEMCTLTYP=1             # hcb V6CQ
            Raz [M]ENDVAL(nolign-1)                             # hcb V6CQ
         Endif                                                  # hcb V6CQ
         If [F:QLQ]NUMNMNVAL=0 & [F:QLQ]DEMCTLTYP=1             # hcb V6CQ
            Raz [M]NMNVAL(nolign-1)                             # hcb V6CQ
         Endif                                                  # hcb V6CQ
      Endif                                                     # hcb V6CQ
      #Affzo [M]TEX       (nolign-1)                            # hcb V6CQ
      Affzo [M:QLC1]QSTTEXAXX (nolign-1)                        # FGR 24/09/2009 : X3SUIVI58062
      Affzo [M]DEMASWTYP (nolign-1)                             # hcb V6CQ
      Affzo [M]DEMCTLTYP (nolign-1)                             # hcb V6CQ
      Affzo [M]TCT       (nolign-1)                             # hcb V6CQ
      Affzo [M]STRVAL    (nolign-1)                             # hcb V6CQ
      Affzo [M]STRVALFOR (nolign-1)                             # hcb V6CQ
      Affzo [M]ENDVAL    (nolign-1)                             # hcb V6CQ
      Affzo [M]ENDVALFOR (nolign-1)                             # hcb V6CQ
      Affzo [M]NMNVAL    (nolign-1)                             # hcb V6CQ
      Affzo [M]OSDASW    (nolign-1)                             # hcb V6CQ
      Affzo [M]LOKTYP    (nolign-1)                             # hcb V6CQ
      Affzo [M]ALPDEFASW (nolign-1)                             # hcb V6CQ
      Affzo [M]UOM       (nolign-1)                             # hcb V6CQ
      Affzo [M]UOMDEC    (nolign-1)                             # hcb V6CQ
      Affzo [M]GPG       (nolign-1)                             # hcb V6CQ
      Affzo [M]PRNCOD    (nolign-1)                             # hcb V6CQ
   Endif
Endif
End

############################################
Subprog C_QSTNUM(VALEUR)
Variable Char     VALEUR
Local Integer     IND
# on ne doit pas avoir plusieurs fois la même question ds une même fiche
If VALEUR <> ""
   For IND=0 To BASTAB-1
       If VALEUR=[M]QSTNUM(IND) & IND <> nolign-1
          GMESSAGE=mess(53,199,1)
          mkstat=2
          Break
       Endif
   Next
Endif
End

Subprog AV_NUMLIN(VALEUR)
Variable Decimal  VALEUR
VALEUR = nolign
End


###########################################################################
# Pour éxécution de la validation des fiches qualités  hcb 38951          #
# par la gestion de dossier                                               #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

# Issue 96423 - 2014-02-03 by SR
If filinfo(filpath("FIL","QLYCRD","fde",APPLI),0)<=0 : End : Endif

If clalev([F:QLC1])<=0
   Local File =APPLI+".QLYCRD" [QLC1]    # Utilisation de QLC1 car QLC est utilisé dans GENCRD
Endif
#
Filter [QLC1] Where NUMLIN = 1
&             Order By Key QLC1
For [QLC1]
  Trbegin [QLC1]
  GOK = 1
  Call GENCRD(APPLI,"QLYCRD1","IQLYCRD",[F:QLC1]QLYCRD) From CRDLIB
  Case GOK
    When 1       : Commit
    When Default : Rollback
  Endcase
Next
Filter [QLC1]

End


######################################################################################
## Etiquette ajoutée par Hcb V6CQ
######################################################################################
Subprog C_RPLQLYCRD(VALEUR)
Variable Char    VALEUR()
If clalev([F:QLC3]) = 0 : Local File QLYCRD [QLC3] : Endif
If VALEUR <> [M]QLYCRD
   Read [QLC3]QLC0=VALEUR
   If fstat
      GMESSAGE=mess(23,100,1)
      mkstat=2
   Endif
Endif
End

Subprog AS_RPLQLYCRD(VALEUR)
Variable Char    VALEUR()

If [M]LOKTYP(nolign-1) <> 4
   mkstat = 2
Endif
If [M]QSTNUM(nolign-1) = ""
   mkstat = 2
Endif

End


######################################################################################
