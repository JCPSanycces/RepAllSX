#<AdxTL>@(#)7.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "AP_IMPORT" : Gosub AP_IMPORT
 When "RAZCRE"    : Gosub RAZCRE
 When "VALID"     : Gosub VALID : If GOK=0 : GERREUR=1 : Endif
 When "SAIMSK"    : Gosub SAIMSK
Endcase
Return

###################################################################################

$OUVRE
Local Mask CTR0[CTR0], CTR1[CTR1], CTR2[CTR2], CTR4[CTR4], CTR5[CTR5], CTR6[CTR6], CTR8[CTR8], CTR9[CTR9]

Local Mask MAT0[EMP0], MAT1[EMP1]

Gosub OUVRE From WPDEFTABLE
#Fichier utilisés par les controles
If clalev ([F:CPY])=0  : Local File COMPANY          [CPY] : Endif
If clalev ([F:FCY])=0  : Local File FACILITY         [FCY] : Endif
If clalev ([F:TCY])=0  : Local File TABCOUNTRY       [TCY] : Endif
If clalev ([F:PRF])=0  : Local File PROFIL           [PRF] : Endif
If clalev ([F:SRV])=0  : Local File SERVICE          [SRV] : Endif
If clalev ([F:WAC])=0  : Local File TRVACC           [WAC] : Endif
If clalev ([F:WAR])=0  : Local File TRVACCRAT        [WAR] : Endif
If clalev ([F:BAN])=0  : Local File BANK             [BAN] : Endif
If clalev ([F:TCU])=0  : Local File TABCUR           [TCU] : Endif
If clalev ([F:ADI])=0  : Local File ATABDIV          [ADI] : Endif
If clalev ([F:IDE])=0  : Local File EMPLOID          [IDE] : Endif
If clalev ([F:CTRE])=0 : Local File EMPLOCTR        [CTRE] : Endif
If clalev ([F:ECT])=0  : Local File EMPCTR           [ECT] : Endif
If clalev ([F:CCE])=0  : Local File =GTABCPT+"CACCE" [CCE] : Endif
If clalev ([F:AOD])=0  : Local File AOBJEXTD         [AOD] : Endif
If !clalev([F:ACV])    : Local File ACTIV            [ACV] : Endif

# 70311
If clalev([F:POT])=0   : Local File POSTE            [POT] : Endif
If clalev ([F:CPR])=0 : Local File EMPLOCTRCPT       [CPR] : Endif

Local Integer ACT_BTP, ACT_INTMT

# JML 03/08/10 LOT P02 Somebody missed that one !
Read [ACV]CODACT="BTP"
If !fstat & [F:ACV]FLACT=2
 ACT_BTP = 1
 Local Mask CTR7[CTR7]
Endif
Read [ACV]CODACT="INTMT"
If !fstat & [F:ACV]FLACT=2
 ACT_INTMT = 1
 Local Mask CTR3[CTR3]
Endif
Return

###################################################################################

$RAZCRE
#Initialisation des masks et des variables
Raz [M:CTR0], [M:CTR1], [M:CTR2], [M:CTR4], [M:CTR5], [M:CTR6], [M:CTR8], [M:CTR9], [M:EMP0], [M:EMP1]
If ACT_BTP=1
 Raz [M:CTR7]
Endif
If ACT_INTMT=1
 Raz [M:CTR3]
Endif
Return

###################################################################################

$AP_IMPORT
If [F:HRCTR]REFNUM="" 
 If GIMP(1)=""
  # Salarié non importé; N° sécurité sociale incomplet
  Call TRACE(2,mess(63,10711,1)-GIMP(1)) From SUBIMPOBJ
  GOK=0 :  Return
 Endif
 #60944
 #Filter [ID] Where NUMSSC=GIMP(1)
 Filter [ID] Where left$(NUMSSC,13)=left$(GIMP(1),13)
 Read [ID]ID0 First
 Filter [ID]
 If fstat
  # Matricule inexistant
  Call TRACE(2,mess(00083,10702,1)-GIMP(1)) From SUBIMPOBJ 
  #60944
  #Raz [F:HRCTR]
  If [M:IMP2]TEST<>2 : Raz [F:HRCTR] : Endif
  GOK = 0 
  Return
 Else
 [F:HRCTR]REFNUM   = [F:ID]REFNUM
 Endif
Endif
Return

###################################################################################

$VALID
If [M:CTR0]REFNUM="" : Return : Endif

Read [ID]ID0=[M:CTR0]REFNUM
If !fstat
 [M:EMP0] = [F:ID]
 [M:EMP1] = [F:ID]
 Gosub VERIF_CTR From IMPORTEMP
 If GOK=0 : Return : Endif

 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK<=0 : GERREUR=1 : Goto AB_TR1 : Endif
Endif
Return

$AB_TR1
Rollback
Return

###################################################################################

$TR1
GOK=1
Trbegin [HRCTR],[CPR]

 Readlock[F:HRCTR]CTR0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT
 If !fstat & [M:AOE1]OPTUPD=2
  Raz[F:HRCTR]
  [F:HRCTR]=[M:CTR0]
  [F:HRCTR]=[M:CTR1]
  [F:HRCTR]=[M:CTR2]
  If ACT_INTMT=1
   [F:HRCTR] = [M:CTR3]
  Endif
  [F:HRCTR]=[M:CTR4]
  [F:HRCTR]=[M:CTR5]
  [F:HRCTR]=[M:CTR6]  
  If ACT_BTP=1
   [F:HRCTR] = [M:CTR7]
  Endif
  [F:HRCTR]=[M:CTR8]  
  [F:HRCTR]=[M:CTR9]  

  #################  
  # 70311 : 4 news fiels in EMPLOCTR (no required)
  # POT ; JOBPOT ; CLEEVETIM & SUICAR
  # if we have a job without the job's type, we search the job's type...
  If dim([F:HRCTR]POT)>0 & [F:HRCTR]POT<>"" 
   If dim([F:HRCTR]JOBPOT)>0 & [F:HRCTR]JOBPOT=""
    Read [F:POT]POT0=[F:HRCTR]POT
    If !fstat : [F:HRCTR]JOBPOT=[F:HRCTR]JOBPOT : Endif
   Endif
  Endif
  If dim([F:HRCTR]CLEEVETIM)>0 & [F:HRCTR]CLEEVETIM=0 : [F:HRCTR]CLEEVETIM=1 : Endif
  If dim([F:HRCTR]SUICAR)>0 & [F:HRCTR]SUICAR=0 : [F:HRCTR]SUICAR=1 : Endif

  #84275
  If dim([F:CTR]FLGVAR)>0 & [F:CTR]FLGVAR = 0 : [F:CTR]FLGVAR = 1 : Endif

  ############

  If dim([F:HRCTR]UPDDAT)>0 : [F:HRCTR]UPDDAT = date$ : Endif
  If dim([F:HRCTR]UPDUSR)>0 : [F:HRCTR]UPDUSR = GUSER : Endif
  If dim([F:HRCTR]UPDTIM)>0 : [F:HRCTR]UPDTIM = time : Endif
  Rewrite [F:HRCTR]
  Call TRACE(1,mess(80,10703,1)-[M:CTR0]REFNUM-[F:ID]NAM-[M:CTR0]CTRDAT) From SUBIMPOBJ
 Endif
 If fstat
  GOK=0 : Call FSTA("HRCTR") From GLOCK : Return
 Endif

 # 70311
 ###Infos cpt au niveau contrat
 If [M:CTR9]FLGCTRCPT = 2
  Readlock[F:CPR]CPR0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
  If fstat=5
   Gosub AFFECT_CTRCPT
   Write [F:CPR]
  Elsif !fstat & [M:AOE1]OPTUPD=2
   Gosub AFFECT_CTRCPT
   Rewrite [F:CPR]
  Endif
  If fstat
   GOK=0 : Call FSTA("CPR") From GLOCK : Return
  Endif
 Endif
 
 ## Si c'est le dernier enregistrement du contrat Alors maj de EMPLOCTR et EMPLOID 
 Filter [CTRE] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM
 Read [CTRE]CTR0 Last
 Filter [CTRE]
 If !fstat & [F:CTRE]CTRDAT=[F:HRCTR]CTRDAT
  ## Mise à jour table EMPCTR
  Readlock [ECT]ECT0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM
  If !fstat
   [F:ECT]SRV    = [F:HRCTR]ETRSRV
   [F:ECT]FCY    = [F:HRCTR]ETRFCY
   [F:ECT]PRF    = [F:HRCTR]PROPRF
   Rewrite [ECT]
   If fstat
    GOK=0 : Call FSTA("ECT") From GLOCK : Return
   Endif
  Elsif fstat=1
   GOK=0 : Call FSTA("ECT") From GLOCK : Return
  Endif
  
  ## Mise à jour fiche salarié
  Readlock [ID]ID0=[F:HRCTR]REFNUM
  If !fstat
   [F:ID]FCY      = [F:HRCTR]ETRFCY :#On prend le dernier
   [F:ID]SRV      = [F:HRCTR]ETRSRV :#On prend le dernier
   [F:ID]PRF      = [F:HRCTR]PROPRF :#On prend le dernier
   Read [FCY]FCY0=[F:ID]FCY
   If !fstat
    [F:ID]CPY     = [F:FCY]LEGCPY
   Endif
   Rewrite [ID]
   If fstat
    GOK=0 : Call FSTA("ID") From GLOCK : Return
   Endif
  Endif
 Endif

Commit
Return

# 73011
#########################
$AFFECT_CTRCPT
Raz[F:CPR]
[F:CPR]=[M:CTR9]
[F:CPR]REFNUM=[F:HRCTR]REFNUM   
[F:CPR]CTRNUM=[F:HRCTR]CTRNUM   
[F:CPR]CTRDAT=[F:HRCTR]CTRDAT   
If [F:CPR]DSP=""
 If GOPTCANA>=1 
  [F:CPR]CCE1 = [M:CTR9]SECTION(0) : [F:CPR]INICCE1 = [M:CTR9]REINIT(0)
 Endif
 If GOPTCANA>=2 
  [F:CPR]CCE2 = [M:CTR9]SECTION(1) : [F:CPR]INICCE2 = [M:CTR9]REINIT(1)
 Endif
 If GOPTCANA>=3
  [F:CPR]CCE3 = [M:CTR9]SECTION(2) : [F:CPR]INICCE3 = [M:CTR9]REINIT(2)
 Endif
 If GOPTCANA>=4
  [F:CPR]CCE4 = [M:CTR9]SECTION(3) : [F:CPR]INICCE4 = [M:CTR9]REINIT(3)
 Endif
 If GOPTCANA>=5
  [F:CPR]CCE5 = [M:CTR9]SECTION(4) : [F:CPR]INICCE5 = [M:CTR9]REINIT(4)
 Endif
 If GOPTCANA>=6
  [F:CPR]CCE6 = [M:CTR9]SECTION(5) : [F:CPR]INICCE6 = [M:CTR9]REINIT(5)
 Endif
 If GOPTCANA>=7
  [F:CPR]CCE7 = [M:CTR9]SECTION(6) : [F:CPR]INICCE7 = [M:CTR9]REINIT(6)
 Endif
 If GOPTCANA>=8
  [F:CPR]CCE8 = [M:CTR9]SECTION(7) : [F:CPR]INICCE8 = [M:CTR9]REINIT(7)
 Endif
 If GOPTCANA>=9
  [F:CPR]CCE9 = [M:CTR9]SECTION(8) : [F:CPR]INICCE9 = [M:CTR9]REINIT(8)
 Endif
Endif
Return

###################################################################################

$SAIMSK
#Affectation des masks [F:HRCTR] contient les données importées
Case IMPFIC
 When "HRCTR"
  Gosub CHARGE_MASK
  Filter [AOD] Where EXT=[M:DIA]MODIMP & FIL="EMPLOCTR" & FLD<>"/" & left$(FLD,1)<>"*"
  For [AOD]AOD0
   If evalue("dim([M:CTR1]"+[F:AOD]FLD+")")>0
    Assign "[M:CTR1]"+[F:AOD]FLD With evalue("[F:HRCTR]"+[F:AOD]FLD)
   Endif
   If evalue("dim([M:CTR2]"+[F:AOD]FLD+")")>0
    Assign "[M:CTR2]"+[F:AOD]FLD With evalue("[F:HRCTR]"+[F:AOD]FLD)
   Endif
   If evalue("dim([M:CTR3]"+[F:AOD]FLD+")")>0
    Assign "[M:CTR3]"+[F:AOD]FLD With evalue("[F:HRCTR]"+[F:AOD]FLD)
   Endif
   If evalue("dim([M:CTR4]"+[F:AOD]FLD+")")>0
    Assign "[M:CTR4]"+[F:AOD]FLD With evalue("[F:HRCTR]"+[F:AOD]FLD)
   Endif
   If evalue("dim([M:CTR5]"+[F:AOD]FLD+")")>0
    Assign "[M:CTR5]"+[F:AOD]FLD With evalue("[F:HRCTR]"+[F:AOD]FLD)
   Endif
   If evalue("dim([M:CTR6]"+[F:AOD]FLD+")")>0
    Assign "[M:CTR6]"+[F:AOD]FLD With evalue("[F:HRCTR]"+[F:AOD]FLD)
   Endif
   If evalue("dim([M:CTR7]"+[F:AOD]FLD+")")>0
    Assign "[M:CTR7]"+[F:AOD]FLD With evalue("[F:HRCTR]"+[F:AOD]FLD)
   Endif
   If evalue("dim([M:CTR8]"+[F:AOD]FLD+")")>0
    Assign "[M:CTR8]"+[F:AOD]FLD With evalue("[F:HRCTR]"+[F:AOD]FLD)
   Endif
   If evalue("dim([M:CTR9]"+[F:AOD]FLD+")")>0
    Assign "[M:CTR9]"+[F:AOD]FLD With evalue("[F:HRCTR]"+[F:AOD]FLD)
   Endif
   # JML 03/08/10 To do in last, because of duplicate zones XITDAT etc...
   If evalue("dim([M:CTR0]"+[F:AOD]FLD+")")>0
    Assign "[M:CTR0]"+[F:AOD]FLD With evalue("[F:HRCTR]"+[F:AOD]FLD)
   Endif
  Next
  Filter [AOD]
 # 70311
 When "CPR"
  Filter [AOD] Where EXT=[M:DIA]MODIMP & FIL="EMPLOCTRCPT" & FLD<>"/" & left$(FLD,1)<>"*"
  For [AOD]AOD0
   If evalue("dim([M:CTR9]"+[F:AOD]FLD+")")>0
    Assign "[M:CTR9]"+[F:AOD]FLD With evalue("[F:CPR]"+[F:AOD]FLD)
   Endif
   If dim([M:CTR9]NBAXECPR)>0 :  [M:CTR9]NBAXECPR = [V]GOPTCANA : Endif
   If dim([M:CTR9]FLGCTRCPT)>0 : [M:CTR9]FLGCTRCPT = 1 : Endif
   Case[F:AOD]FLD 
    When"DSP", "ACCCOD", "BPR", "CCE1", "CCE2", "CCE3", "CCE4","CCE5", "CCE6", "CCE7", "CCE8", "CCE9"
     If evalue("[F:CPR]"+[F:AOD]FLD) <> ""
      [M:CTR9]FLGCTRCPT = 2 : Break
     Endif
   Endcase 
  Next
  Filter [AOD]
  If [M:CTR9]DSP=""
   If GOPTCANA>=1 
    [M:CTR9]SECTION(0) = [F:CPR]CCE1 : [M:CTR9]REINIT(0) = [F:CPR]INICCE1
   Endif
   If GOPTCANA>=2 
    [M:CTR9]SECTION(1) = [F:CPR]CCE2 : [M:CTR9]REINIT(1) = [F:CPR]INICCE2
   Endif
   If GOPTCANA>=3
    [M:CTR9]SECTION(2) = [F:CPR]CCE3 : [M:CTR9]REINIT(2) = [F:CPR]INICCE3
   Endif
   If GOPTCANA>=4
    [M:CTR9]SECTION(3) = [F:CPR]CCE4 : [M:CTR9]REINIT(3) = [F:CPR]INICCE4
   Endif
  If GOPTCANA>=5
    [M:CTR9]SECTION(4) = [F:CPR]CCE5 : [M:CTR9]REINIT(4) = [F:CPR]INICCE5
   Endif
   If GOPTCANA>=6 
    [M:CTR9]SECTION(5) = [F:CPR]CCE6 : [M:CTR9]REINIT(5) = [F:CPR]INICCE6
   Endif
   If GOPTCANA>=7 
    [M:CTR9]SECTION(6) = [F:CPR]CCE7 : [M:CTR9]REINIT(6) = [F:CPR]INICCE7
   Endif
   If GOPTCANA>=8 
    [M:CTR9]SECTION(7) = [F:CPR]CCE8 : [M:CTR9]REINIT(7) = [F:CPR]INICCE8
   Endif
   If GOPTCANA>=9
    [M:CTR9]SECTION(8) = [F:CPR]CCE9 : [M:CTR9]REINIT(8) = [F:CPR]INICCE9
   Endif
  Endif
 Endcase
Return

###################################################################################

# Après import DADSu on a rempli EMPLOCTR. On prend le contrat qui a la même date. 
$CHARGE_MASK
nolign = 1
Filter [CTRE] Where REFNUM=[F:HRCTR]REFNUM & CTRDAT=[F:HRCTR]CTRDAT
Read [CTRE]CTR0 First
Filter [CTRE]
If !fstat
 [M:CTR0] = [F:CTRE]
 [M:CTR1] = [F:CTRE]
 [M:CTR2] = [F:CTRE]
 If ACT_INTMT=1
  [M:CTR3] = [F:CTRE]
 Endif
 [M:CTR4] = [F:CTRE]
 [M:CTR5] = [F:CTRE]
 [M:CTR6] = [F:CTRE]
 If ACT_BTP=1
  [M:CTR7] = [F:CTRE]
 Endif
 [M:CTR8] = [F:CTRE]
 [M:CTR9] = [F:CTRE]
Endif
Return
