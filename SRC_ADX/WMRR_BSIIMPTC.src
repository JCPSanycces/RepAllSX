#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank import type codes
# Supervisor
## CRUD-CLASSE ## BSIIMPTC
# 2018-08-16 22:22:47 533


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File BSIIMPTC [BSITC_]

If !SILENCE : Call TRACE("2 --> Local Instance R_BSIIMPTC") From ASYRCOM : Endif
Local Instance BSIIMPTC Using R_BSIIMPTC

If !SILENCE : Call TRACE("3 --> New Instance R_BSIIMPTC") From ASYRCOM : Endif
BSIIMPTC = NewInstance R_BSIIMPTC AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [BSITC_]BSITC0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of BSIIMPTC") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.AREAD([BSITC_]BSICODTC,[BSITC_]BAN))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("BSIIMPTC.BSITC.BSICODTC ="-num$(BSIIMPTC.BSITC.BSICODTC)) From ASYRCOM
 Call TRACE("BSIIMPTC.BSITC.BAN ="-num$(BSIIMPTC.BSITC.BAN)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(BSIIMPTC.BSITC.AKEYS)
  Call TRACE("-"-num$(I)-":"-BSIIMPTC.BSITC.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [BSITC_]
FreeGroup BSIIMPTC
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(BSIIMPTC,ACLE,ASTATUS,_ETAG)
Variable Instance BSIIMPTC Using R_BSIIMPTC
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _BSICODTC(10)
Local Char _BAN(5)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_BSICODTC = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_BAN = num$([L]CLE(2)) : Endif
Raz [L]_ETAG
Local File BSIIMPTC [BSITC]
Default File [F:BSITC]
Read [F:BSITC]BSITC0 = [L]_BSICODTC;[L]_BAN
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:BSITC]UPDTICK)>0
 [L]_ETAG = num$([F:BSITC]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(BSIIMPTC,ACLE,ASTATUS)
Variable Instance BSIIMPTC Using R_BSIIMPTC
Value Char ACLE
Variable Integer ASTATUS
Local Char _BSICODTC(10)
Local Char _BAN(5)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_BSICODTC = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_BAN = num$([L]CLE(2)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.AREAD([L]_BSICODTC,[L]_BAN))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(BSIIMPTC,_BSICODTC,_BAN,ASTATUS)
Variable Instance BSIIMPTC Using R_BSIIMPTC
Value Char _BSICODTC
Value Char _BAN
Variable Integer ASTATUS

If BSIIMPTC = null : End : Endif

Gosub AVARIABLES From WMR00BSIIMPTC
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If BSIIMPTC.APARENT=null
 [L]A_I = BSIIMPTC.freeSnapshot
 BSIIMPTC.snapshotEnabled = 0
 BSIIMPTC.setAccessorEnabled = 0
Endif

If fmet BSIIMPTC.ACTX.AGETAFCRIGHT(BSIIMPTC,"BSIIMPORT",[V]CST_ATRUE)>=[V]CST_AERROR : [L]ASTATUS=[V]CST_AERROR : Goto AREAD_END : Endif
Default File [F:BSITC]
Read [F:BSITC]BSITC0 = [L]_BSICODTC;[L]_BAN
If fstat
[L]A_ERROR = [L]_BSICODTC+"~"+[L]_BAN
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(BSIIMPTC,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If fmet BSIIMPTC.ACTX.AGETAFCRIGHTR(BSIIMPTC,"BSIIMPORT",[L]A_STRSITE,[V]CST_ATRUE)>=[V]CST_AERROR
 [L]ASTATUS=[V]CST_AERROR : Goto AREAD_END
Endif

[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("AREAD_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

BSIIMPTC.BSITC.setAccessorEnabled = 0
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.BSITC.AREAD([L]_BSICODTC,[L]_BAN))
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & BSIIMPTC.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If BSIIMPTC.APARENT=null
 BSIIMPTC.snapshotEnabled = 1
 BSIIMPTC.setAccessorEnabled = 1
Endif
LogicClose File [BSITC] ,[BSITCD]
End



