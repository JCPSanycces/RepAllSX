#<AdxTL>@(#)0.0.0.0 $Revision$ 
# ALSHE 06.12.2017
# Issue X3-108668 - 2018-09-21 by BAKHA : Changed REJECTCOD from local  menu to ADI

$ACTION
Case ACTION
    When "DEBUT"       : Gosub DEBUT
    When "OK"          : Gosub OK
Endcase
Return

######################################################################################

$DEBUT
# initialize fields
Raz[M:NCSR]REJDESC
Raz[M:NCSR]REJECTCOD
Return

######################################################################################

$OK
# if OK clicked, copy rejection description and rejection code to main screen H4
[M:NCSH4]REJDESC = [M:NCSR]REJDESC
[M:NCSH4]REJECTCOD = [M:NCSR]REJECTCOD
Return

######################################################################################
## Section automatically added (screen NCSR) 07.12.2017 10:19:04 (ALSHE)
######################################################################################
Subprog C_REJECTCOD(VALEUR)
Variable Char    VALEUR() # Issue X3-108668

# rejection code is mandatory
If VALEUR = "" # Issue X3-108668
    GERR=1
    GMESSAGE = mess(12,2038,1)
    mkstat = 2
Endif
End

######################################################################################

