#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECHACI","RECHACI",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return

$INIT
Local Integer I , J , K , INTE , OK
Local Char    ACT(10) , ACTION(10) , TEXTE(80)
Local Char    FIC(10) , TIT(30) , COD(10) , NAM(10)
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
Local Mask RECHACI [DIA]
Raz [M:DIA]
TRA = 1
Return

$EXEC
ACT = toupper([M:DIA]ACT)
Call OUVRE_BOITE(mess(26,115,1),100) From GESECRAN : # Recherche action
Call OUVRE_TRACE(mess(27,115,1)-ACT) From LECFIC : # Action
If [M:DIA]AMK=2 : Gosub ECRANS    : Endif
If [M:DIA]AWI=2 : Gosub FENETRES  : Endif
If [M:DIA]AFC=2 : Gosub FONCTIONS : Endif
If [M:DIA]ATY=2 : Gosub TYPES     : Endif
If [M:DIA]SUI=2 : Gosub ACTSUI    : Endif
Call FERME_TRACE From LECFIC
Call FERME_BOITE From GESECRAN
Call LEC_TRACE From LECFIC
Return

## Ecrans
$ECRANS
Local File AMSK [AMK] , AMSKZON [AMZ] , AMSKACT [AMA]
Call SET_BOITE(mess(17,125,1),nbrecord([AMK])) From GESECRAN : # Ecrans
Call ECR_TRACE(mess(17,125,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [AMK]CODMSK
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK
  If [F:AMA]ACTION<>"" & pat([F:AMA]ACTION,ACT)
   Read [AMZ]CODE = [F:AMK]CODMSK;[F:AMA]CODZON
   Call TEXTE([F:AMZ]INTIT,TEXTE) From OBJDIV
   Call ECR_TRACE([F:AMA]ACTION-":"-[F:AMZ]CODMSK-mess([F:AMA]TYPACT,31,1)-mess(17,115,1)
&   -[F:AMZ]CODZON-TEXTE,0) From GESECRAN
#  Zone
  Endif
 Next
Next
Close Local File [AMK] , [AMZ] , [AMA]
Call ECR_TRACE("",0) From GESECRAN
Return

## Fenêtres
$FENETRES
Local File AWINDOW [AWI] , AWINBOUT [AWT]
Call SET_BOITE(mess(82,125,1),nbrecord([AWI])) From GESECRAN : # Fenêtres
Call ECR_TRACE(mess(82,125,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [AWI]AWI0
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 For I=0 To dim([F:AWI]ACTSTD)-1
  If [F:AWI]ACTSTD(I)<>"" & pat([F:AWI]ACTSTD(I),ACT)
   Call TEXTE([F:AWI]DES,TEXTE) From OBJDIV
   Call ECR_TRACE([F:AWI]ACTSTD(I)-":"-[F:AWI]WIN-TEXTE-mess(206,123,1)-num$(I+1)
&   ,0) From GESECRAN
#  Bouton
  Endif
 Next I
 For [AWT]AWT0 Where WIN=[F:AWI]WIN
  If [F:AWT]ACTBOUT<>"" & pat([F:AWT]ACTBOUT,ACT)
   Call TEXTE([F:AWI]DES,TEXTE) From OBJDIV
   Call ECR_TRACE([F:AWT]ACTBOUT-":"-[F:AWI]WIN-TEXTE-mess(206,123,1)-[F:AWT]CODBOUT
&   ,0) From GESECRAN
#  Bouton
  Endif
 Next I
Next
Close Local File [AWI] , [AWT]
Call ECR_TRACE("",0) From GESECRAN
Return

$FONCTIONS
Local File AFONCTION [AFC]
Call SET_BOITE(mess(39,124,1),nbrecord([AFC])) From GESECRAN : # Fonctions
Call ECR_TRACE(mess(39,124,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [AFC]CODINT
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 If [F:AFC]ACTION<>"" & pat([F:AFC]ACTION,ACT)
  Call TEXTE([F:AFC]NOM,TEXTE) From OBJDIV
  Call ECR_TRACE([F:AFC]ACTION-":"-[F:AFC]CODINT-TEXTE,0) From GESECRAN
 Endif
Next
Close Local File [AFC]
Call ECR_TRACE("",0) From GESECRAN
Return

## Types de données
$TYPES
Local File ATYPE [ATY]
Call SET_BOITE(mess(19,125,1),nbrecord([ATY])) From GESECRAN : # Types
Call ECR_TRACE(mess(19,125,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [ATY]CODTYP
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 For J=0 To dim([F:ATY]ACTION)-1
  If [F:ATY]ACTION(J)<>"" & pat([F:ATY]ACTION(J),ACT)
   Call TEXTE([F:ATY]INTITTYP,TEXTE) From OBJDIV
   Call ECR_TRACE([F:ATY]ACTION(J)-":"-[F:ATY]CODTYP-mess([F:ATY]ACTTYP(J),31,1)-TEXTE,0) From GESECRAN
  Endif
 Next J
Next
Close Local File [ATY]
Call ECR_TRACE("",0) From GESECRAN
Return

## Actions suite
$ACTSUI
Local File ACTION [ACT]
Call SET_BOITE(mess(205,124,1),nbrecord([ACT])) From GESECRAN : # Actions suite
Call ECR_TRACE(mess(205,124,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [ACT]ACTION
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 If [F:ACT]ACTSUI<>"" & pat([F:ACT]ACTSUI,ACT)
  Call TEXTE([F:ACT]INTITA,TEXTE) From OBJDIV
  Call ECR_TRACE([F:ACT]ACTSUI-":"-[F:ACT]ACTION-TEXTE,0) From GESECRAN
 Endif
Next
Close Local File [ACT]
Call ECR_TRACE("",0) From GESECRAN
Return

