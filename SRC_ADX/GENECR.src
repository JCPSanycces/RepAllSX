#<AdxTL>@(#)248.0.0.0 $Revision$
###########################################################
# Sous programme standard de génération d'écrans
# Auteur     : Michel Giet
# Crée le    : mardi 19 août 1997
###########################################################
# Passage des paramètres
#  Subprog GENECR(APPLI,ECRORI,ECRDES,ABRDES,TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR)
#  APPLI  = Dossier
#
#  ECRORI = Nom écran origine
#           REMARQUE
#           Cet écran doit contenir un bloc invisible (de préférence le
#           dernier) pour le transfert des champs désactivés.
#
#  ECRDES = Nom écran généré
#           REMARQUE
#           le premiers caractères doit être "W" le suivant une lettre
#           correspondant au type d'ecran généré.
#
#  ABRDES = Abréviation souhaitée pour l'écran généré : vide si abréviation de l'écran standard origine
#
#  TBLOC  = Table des blocs à traiter (pour chaque bloc de 0 à 14)
#                         0 Pas de traitement
#                         1 Rendre le bloc invisible
#                         2 Transformer le bloc en mode affiché
#
#  TZONE  = Table des zones à modifier (noms de zones écran sur 10 car)
#
#  TMOD   = Table des codes modifications de zones
#                         2 Forcer la zone en mode affiché
#                         3 Forcer la zone en mode invisible
#                         4 Changer l'intitulé
#                         5 Substituer le champs avec intitulé court
#                         6 Substituer le champs avec intitulé normal
#                         7 Changer intitulé évalué
#                         8 Changer type de données
#                         9 Changer la présentation des données tableau (Tableau / Fiche)
#
#  TINT   = Table des numéros de message    (TMOD=4)
#           Table des intitulés évalué      (TMOD=7)
#           Table des types de données      (TMOD=8)
#           Table des présentations tableau (TMOD=9) : 1=Tableau+Fiche 2=Tableau 3=Fiche
#
#  TTAB   = Table des tables (si TMOD = 5 ou 6) sur 10 caractères
#
#  TFLD   = Table des champs (si TMOD = 5 ou 6) sur 10 caractères
#
#  OPT1   = Options       0 Recalcul des lignes debut et fin bloc
#                         1 Recalcul des lignes debut et fin bloc sauf
#                           ligne fin dernier bloc tableau
#                         2 Pas de recalcul des lignes debut et fin de bloc
#                         9 suppression du masque ECRDES
#
#  OPT2   = Affichage     0 Pas d'affichage du masque généré
#                         1 Affichage du masque généré
#
#  OPT3   = Présentation  0 Présentation d'origine
#                         nn Alignement sur 2 colonnes des blocs listes
#                            (nn = colonne de synchro)
#
#  RETOUR = Code retour 0 si ok
#                       1 écran origine absent
#                       2 écran destination ne commence pas par "W"
###########################################################
#
#X3-39935 : this function will take hidden fields of screens into account when we will calculate
#           the number of functions and programs to generate for screens management.
Subprog GENECR(APPLI,ECRORI,ECRDES,ABRDES,TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR)
Value    Char    APPLI
Variable Char    ECRORI
Variable Char    ECRDES
Value    Char    ABRDES
Variable Integer TBLOC
Variable Char    TZONE
Variable Integer TMOD
Variable Char    TINT
Variable Char    TTAB
Variable Char    TFLD
Value    Integer OPT1
Value    Integer OPT2
Value    Integer OPT3
Variable Integer RETOUR
Local Integer ISVALIDFULL :#X3-39935
  #X3-39935
  ISVALIDFULL=[V]CST_AYES
  Gosub EXECGENECR
  #end X3-39935
End

#X3-39935 : this function won't take hidden fields of screens into account when we will calculate
#           the number of functions and programs to generate for screens management.
Subprog GENECRMIN(APPLI,ECRORI,ECRDES,ABRDES,TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR)
Value    Char    APPLI
Variable Char    ECRORI
Variable Char    ECRDES
Value    Char    ABRDES
Variable Integer TBLOC
Variable Char    TZONE
Variable Integer TMOD
Variable Char    TINT
Variable Char    TTAB
Variable Char    TFLD
Value    Integer OPT1
Value    Integer OPT2
Value    Integer OPT3
Variable Integer RETOUR
Local Integer ISVALIDFULL

  ISVALIDFULL=[V]CST_ANO
  Gosub EXECGENECR

End
#end X3-39935

$EXECGENECR
RETOUR = 0
#
Local Integer BTAB : BTAB = 1 : # Constante bloc tableau
Local Integer BLIS : BLIS = 2 : # Constante bloc liste
Local Integer BPHO : BPHO = 3 : # Constante bloc photo
Local Integer BTEX : BTEX = 4 : # Constante bloc texte
Local Integer BINV : BINV = 5 : # Constante bloc invisible
# FGR 13/11/2009 : X3SUIVI56631 (début)
Local Integer BFLA : BFLA = 6 : # Constante bloc Flash
Local Integer BBUR : BBUR = 7 : # Constante bloc Bureautique
Local Integer BBRO : BBRO = 8 : # Constante bloc Browser
Local Integer BEHT : BEHT = 9 : # Constante bloc Editeur HTML
Local Integer BTEC : BTEC = 10: # Constante bloc Technique
Local Integer BBIT : BBIT = 11: # Constante bloc Business Intelligence
# FGR 13/11/2009 : X3SUIVI56631 (fin)
#
Local Integer ZSAI : ZSAI = 1 : # Constante Zone saisie
Local Integer ZAFF : ZAFF = 2 : # Constante zone affichée
Local Integer ZINV : ZINV = 3 : # Constante zone invisible
#
#
# Ouverture tables
If !clalev([F:AMK1])  Local File =APPLI+".AMSK"      [AMK1] : Endif
If !clalev([F:AMK2])  Local File =APPLI+".AMSK"      [AMK2] : Endif
If !clalev([F:AMZ1])  Local File =APPLI+".AMSKZON"   [AMZ1] : Endif
If !clalev([F:AMZ2])  Local File =APPLI+".AMSKZON"   [AMZ2] : Endif
If !clalev([F:AMA1])  Local File =APPLI+".AMSKACT"   [AMA1] : Endif
If !clalev([F:AMA2])  Local File =APPLI+".AMSKACT"   [AMA2] : Endif
If !clalev([F:AMP1])  Local File =APPLI+".AMSKPAR"   [AMP1] : Endif
If !clalev([F:AMP2])  Local File =APPLI+".AMSKPAR"   [AMP2] : Endif
If !clalev([F:AMC1])  Local File =APPLI+".AMOTCLE"   [AMC1] : Endif  # FGR 20/10/2015 : X3SUIVI111865
If !clalev([F:AMC2])  Local File =APPLI+".AMOTCLE"   [AMC2] : Endif  # FGR 20/10/2015 : X3SUIVI111865
If !clalev([F:ATX1])  Local File =APPLI+".ATEXTE"    [ATX1] : Endif
If !clalev([F:ATX2])  Local File =APPLI+".ATEXTE"    [ATX2] : Endif
If !clalev([F:ATY])   Local File =APPLI+".ATYPE"     [ATY]  : Endif
If !clalev([F:ATZ])   Local File =APPLI+".ATABZON"   [ATZ]  : Endif
If !clalev([F:ADS1])  Local File ADOSSIER            [ADS1] : Endif
#
#
# Zones de stockage masque origine
#
Local Integer NBBLO               : NBBLO =  dim([F:AMK1]TYPBLOC) : # Nombre de blocs maximum
Local Integer NBFLD               : NBFLD =  300                  : # Nombre de champs maximum
Local Integer NBLIG               : NBLIG = 24                    : # Constante nombre de lignes écran
#
Local Integer MBORI    (NBBLO)    : # Types bloc
Local Integer MTORI    (NBBLO)    : # Longueur textes
Local Integer IBLO                : # Nombre de blocs
Local Integer PBORI    (NBBLO)    : # Position bloc
Local Integer CBORI    (NBBLO)    : # Colonne bloc
Local Integer LBORI    (NBBLO)    : # Ligne bloc
Local Integer NLORI    (NBBLO)    : # Nombr de lignes  bloc
Local Integer LB       (NBBLO)    : # Largeur blocs disponible
Local Integer LT       (NBBLO)    : # Longueur textes zones
#
Local Char    ZZORI(GLONAVA)(NBFLD) : # Nom zones écran
Local Integer ZAORI    (NBFLD)    : # Code saisie/affiché
Local Integer ZBORI    (NBFLD)    : # Bloc de la zone
Local Decimal ZLORI    (NBFLD)    : # Ligne de la zone
Local Integer ZFORI    (NBFLD)    : # Longueur de la zone
Local Integer ZIORI    (NBFLD)    : # Intitule de la zone
Local Integer ZDORI    (NBFLD)    : # Dimension de la zone
Local Decimal ZLNEW    (NBFLD)    : # Ligne de la zone recalculée
Local Decimal TFIL     (NBFLD)    : # Filler avant zone
#
Local Integer TECR     (NBLIG)    : # Table occupation lignes écrans
Local Integer IORI                : # Nombre de zones
Local Integer IZONE               : # Nombre de zones modifiées
Local Integer I, J, K, L, M, N, O, P
Local Integer L1, L2
Local Integer POSD, POSF, FIL, CPT, NBI, DBA, VS
Local Decimal LID, LIG
###########################################################
Local Char    TYPFMT(10) , NUMFMT(10) , OPTFMT(10) , CHFMT(30)
Local Integer LNGFMT , MAXLNG
Local Char    SUF(4)
Local Char    FICANU(GDIMFIC)
Local Char    TRTANU(GDIMFIC)
Local Integer STAT
Local Char    WGLANGUE
Local Integer ILAN
Local Integer OKTRT
############################################################
# Lecture parametres dossier
Read [ADS1]DOSSIER=APPLI
If fstat
  RETOUR = 3
  Call ERREUR(APPLI-mess(52,150,1)) From GESECRAN
  Return :#X3-39935
Endif
###########################################################
# Contrôle que nom écran cible commence par la lettre "W"
If seg$(ECRDES,1,1)<> "W"
  RETOUR = 2
  Return :#X3-39935
Endif
###########################################################
# Traitement suppression seule du masque ECRDES
If OPT1 <> 9
###########################################################
# Contrôle nom écran origine stockage types de blocs
  If ECRORI = ""
    RETOUR = 1
    Return :#X3-39935
  Endif
###########################################################
# Comptage des modif de champs
  For IZONE = 0 To dim(TZONE)-1
    If TZONE(IZONE) = ""
      Break
    Endif
  Next IZONE
###########################################################
  Read [AMK1]CODMSK = ECRORI
  If fstat
    RETOUR = 1
    Return :#X3-39935
  Else
    For I = 0 To dim(MBORI)-1
      MBORI(I) = [F:AMK1]TYPBLOC(I)
      MTORI(I) = [F:AMK1]LNGLIB (I)
      PBORI(I) = [F:AMK1]POSBLOC(I)
      LBORI(I) = [F:AMK1]LINBLOC(I)
      NLORI(I) = [F:AMK1]NBLIGT (I)
      If MBORI(I) <> 0
        IBLO = I+1
      Endif
    Next I
  Endif
Endif
###########################################################
# Section d'effacement du précédent masque généré de même nom
###########################################################
Call DELMSK(ECRDES,APPLI) From MSKDIV
adxmbm      = adxmbm
###########################################################
# Fin si suppression seule
If OPT1 = 9
  Return :#X3-39935
Endif
###########################################################
# Lecture zones masque origine et stockage
IORI = 0
Filter [AMZ1] Where CODMSK = ECRORI
&            Order By Key CODE
For [AMZ1]
  If OPT3 = 0 | (OPT3 <>0 & seg$([AMZ1]CODZON,1,6)<>"FILLER")
    ZZORI(IORI) = [AMZ1]CODZON
    ZBORI(IORI) = [AMZ1]NUMBLOC
    ZLORI(IORI) = [AMZ1]NOZONE
    ZLNEW(IORI) = [AMZ1]NOZONE
    ZAORI(IORI) = [AMZ1]SAIAFF
    ZIORI(IORI) = [AMZ1]INTIT
    ZDORI(IORI) = [AMZ1]DIME
    Gosub CAL_LON
    If [AMZ1]INTIT <> 0
      LNGFMT += MTORI([AMZ1]NUMBLOC-1)
      LNGFMT += 3
    Else
      If [AMZ1]INTEVAL = ""
        LNGFMT += 1
      Else
        LNGFMT += MTORI([AMZ1]NUMBLOC-1)
        LNGFMT += 3
      Endif
    Endif
    ZFORI(IORI) = LNGFMT
    IORI += 1
  Endif
Next
Filter [AMZ1]
# Tri des tables
Sorta IORI ZZORI,ZAORI,ZBORI,ZFORI,ZLORI,ZLNEW,ZIORI,ZDORI
&     Order By ZBORI(indice),ZLORI(indice)
###########################################################
# Section de traitement des blocs et des zones
# Effacement table de travail des "filler"
# Positionement des blocs invisibles demandés
# Positionnement des champs invisibles demandés
# Forcage par programme des blocs ne contenant aucune zone visible
# Forcage par programme des zones invisibles des blocs invisibles
# Recalcul des numéros de ligne sauf si OPT1 = 0
# Recalcul des lignes début et fin de bloc
#
For I = 0 To dim(TFIL)-1
  TFIL(I) = 0
Next I
###########################################################
# Traitement global des blocs invisibles
For I = 0 To IBLO-1
  If TBLOC(I) = 1 & MBORI(I) > 1              : # MBT 04/02/2004
     MBORI(I) = BINV
  Elsif TBLOC(I) = 1 & MBORI(I) = 1           : # MBT 04/02/2004
     MBORI(I) = 6  : # Bloc tableau invisible : # MBT 04/02/2004
  Endif
Next I
###########################################################
# Traitement global des zones
For I = 0 To IZONE
  J = find(TZONE(I),ZZORI(0..IORI-1))
  If J <> 0 & TMOD(I) = 2 & ZAORI(J-1) <> ZAFF
    ZAORI(J-1) = ZAFF
  Endif
  If J <> 0 & TMOD(I) = 3
    ZAORI(J-1) = ZINV
  Endif
Next I
###########################################################
# Traitement global des blocs affichés
For I = 0 To IBLO-1
  If TBLOC(I) = 2 & MBORI(I) <> 0
    For J = 0 To IORI-1
      If ZBORI(J) = I+1 & ZAORI(J) = ZSAI
         ZAORI(J) = ZAFF
      Endif
    Next J
  Endif
Next I
###########################################################
# Bloc invisible si tous les champs sont invisibles
# sauf blocs tableaux
# FGR 13/11/2009 : X3SUIVI56631 et blocs techniques
For I = 0 To IBLO-1
  #If (MBORI(I) <> 0 & MBORI(I) <> BTAB)                   # FGR 13/11/2009 : X3SUIVI56631
  If (MBORI(I) <> 0 & MBORI(I) <> BTAB & MBORI(I) <> BTEC) # FGR 13/11/2009 : X3SUIVI56631
    J = 0
    For K = 0 To IORI-1
      If ZBORI(K) = I+1 & ZAORI(K) <> ZINV
        J = 1
      Endif
    Next K
    If J = 0
      MBORI(I) = BINV
    Endif
  Endif
Next I
###########################################################
# Recherche d'un bloc invisible pour rangement zones invisibles
# Recherche dernier bloc actif
NBI = 99
DBA = 0
For I = IBLO-1 To 0 Step -1
  If MBORI(I) =  BINV & NBI = 99
    NBI = I
  Endif
  If MBORI(I) <>  BINV & DBA = 0 : # MBT 04/02/2004
    DBA = I
  Endif
Next I
###########################################################
# Zones invisibles pour les bloc invisibles
For I = 0 To IBLO-1
  If MBORI(I) = BINV
    For J = 0 To IORI-1
      If ZBORI(J) = I+1
        ZAORI(J) = ZINV
      Endif
    Next J
  Endif
Next I
###########################################################
# Section de copie du masque
# Copie AMSK
Local Integer CPT1,CPT2
Read [AMK1]CODMSK = ECRORI
If fstat = 0
  [F:AMK2]        = [F:AMK1]
  [F:AMK2]CODMSK  = ECRDES
  If ABRDES<>""
    [F:AMK2]ABRMSK  = ABRDES
  Endif
  [F:AMK2]MDL     = 1
  For I = 0 To IBLO-1
    If MBORI(I) < 6                 : # MBT 04/02/2004
      [AMK2]TYPBLOC(I) = MBORI(I)
    Endif                           : # MBT 04/02/2004
    If MBORI(I)<>BINV
      Case right$(num$([AMK2]POSBLOC(I)),instr(1,num$([AMK2]POSBLOC(I)),".")+1)
        When "1" : CPT1 +=1
        When "2" : CPT2 +=1
      Endcase
    Else  : # 54066 Mettre à 0 COLBLOC LINBLOC  pour les blocs invisibles.
      [AMK2]POSBLOC(I) = 0
      [AMK2]LINBLOC(I) = 0
      [AMK2]COLBLOC(I) = 0
    Endif
  Next I
  If CPT1=0 & CPT2>0 : # 54066 CCL Mettre en colonne 1 les blocs s'il ne reste que des blocs en colonne 2.
   For I = 0 To IBLO-1
    If right$(num$([AMK2]POSBLOC(I)),instr(1,num$([AMK2]POSBLOC(I)),".")+1) = "2"
     [AMK2]POSBLOC(I) -= 0.1
    Endif
   Next
  Endif
  Write [AMK2]
  If fstat
    GOK=0
    Call FSTA("AMK2") From GLOCK
  Endif
Else
  GOK = 0
  Call FSTA("AMK1") From GLOCK
Endif
If GOK <> 1
  Return :#X3-39935
Endif
##########################################################
# Copie AMSKZON
Filter [AMZ1] Where CODMSK = ECRORI
&             Order By Key CODE
For [AMZ1]
  [F:AMZ2] = [F:AMZ1]
  [F:AMZ2]CODMSK = ECRDES
  Gosub MAJ_AMSKZON
  Write [AMZ2]
  If fstat
    GOK=0
    Call FSTA("AMZ2") From GLOCK
    Break
  Endif
  If FIL <> 0
    [F:AMZ2]CODTYP = "A"
    [F:AMZ2]CODZON = "FILLER"+num$(CPT)
    CPT += 1
    [F:AMZ2]LONG   = FIL
    [F:AMZ2]DIME   = 1
    [F:AMZ2]INTIT  = 0
    [F:AMZ2]NOZONE -= 0.1
    [F:AMZ2]SAIAFF = ZAFF
    Write [AMZ2]
    If fstat
      GOK=0
      Call FSTA("AMZ2") From GLOCK
      Break
    Endif
  Endif
Next
Filter [AMZ1]
#
If GOK <> 1
  Return :#X3-39935
Endif
###########################################################
# Copie AMSKACT
Filter [AMA1] Where TYPAFF = 1      &
&                   CODAFF = ECRORI
&             Order By Key TYPAFF
For [AMA1]
  [F:AMA2] = [F:AMA1]
  [F:AMA2]CODAFF = ECRDES
  Write [AMA2]
  If fstat
    GOK = 0
    Call FSTA("AMA2") From GLOCK
    Break
  Endif
Next
#
Filter [AMA1]
If GOK <> 1
  Return :#X3-39935
Endif
###########################################################
# Copie AMSKPAR
Filter [AMP1] Where TYPAFF = 1      &
&                   CODAFF = ECRORI
&             Order By Key CODPAR
For [AMP1]
  [F:AMP2] = [F:AMP1]
  [F:AMP2]CODAFF = ECRDES
  Write [AMP2]
  If fstat
    GOK = 0
    Call FSTA("AMP2") From GLOCK
    Break
  Endif
Next
#
If GOK <> 1
  Return :#X3-39935
Endif

###########################################################
# Copie AMOTCLE
# FGR 20/10/2015 : X3SUIVI111865 (début)
  # Mis parce que MSKDIV.DELMSK ne traite pas cette table
  Delete [F:AMC2] Where TYPZON = 2 and IDENT1 = ECRDES
  If fstat = 1 Then
   GOK = -1
   GLOCK = "$AMOTCLE" - MASQUE
   Return :#X3-39935
  Endif
  #
  Filter [AMC1] Where TYPZON = 2 and IDENT1 = ECRORI Order By Key AMC0
  For [AMC1]
    [F:AMC2] = [F:AMC1]
    [F:AMC2]IDENT1 = ECRDES
    Write [AMC2]
    If fstat Then
      GOK = 0
      Call FSTA("AMC2") From GLOCK
      Break
    Endif
  Next
  #
  If GOK <> 1 Then
    Return :#X3-39935
  Endif
# FGR 20/10/2015 : X3SUIVI111865 (fin)
###########################################################

# Sous-programme permettant d'intervenir sur les tables écrans générées

Call EXISTE_ADX("","","GENECRB",OKTRT) From ORDSYS
If OKTRT>0
 ACTION = "GENECR" : Gosub ACTION From GENECRB
Endif

# CCC (09/02/06) DM 34728
GPOINT = "VALGENECR"
Gosub ENTREE From EXEFNC
If GOK <> 1
  Return :#X3-39935
Endif

# Validation de l'écran
If ISVALIDFULL=[V]CST_AYES
  Call VALIDFULL(ECRDES,APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,VS) From VALMSK
Else
  Call VALID(ECRDES,APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,VS) From VALMSK
Endif
adxmbm      = adxmbm
#
#X3-39935
#$FIN
#End
Return
###########################################################
# Calcul de la longueur éditée de la zone
$CAL_LON
LNGFMT = 0
#
Read [ATY]CODTYP = [AMZ1]CODTYP
If fstat = 0
  Case [F:ATY]TYPTYP
    When 1 :
      LNGFMT = [F:AMZ1]LONG
    When 2, 3, 4, 5, 6 :
      If [F:AMZ1]LONG > 0
        L1 = int([F:AMZ1]LONG)
        L2 = 10*([F:AMZ1]LONG-L1)
        While L2 <> int(L2)
          L2 *= 10
        Wend
        LNGFMT = L1+L2+(L2<>0)
      Else
        L1 = int([F:ATY]LNGTYP)
        L2 = 10*([F:ATY]LNGTYP-L1)
        While L2 <> int(L2)
          L2 *= 10
        Wend
        LNGFMT = L1+L2+(L2<>0)
      Endif
    When 7 :
      If [F:AMZ1]LONG > 0
        If [F:AMZ1]OPTLNG > 0 & [F:AMZ1]OPTLNG < [F:AMZ1]LONG
          LNGFMT = [F:AMZ1]OPTLNG
        Else
          LNGFMT = [F:AMZ1]LONG
        Endif
      Else
        If evalue("dim(GLON"+[F:AMZ1]CODTYP+")>0")
          LNGFMT = evalue("GLON"+[F:AMZ1]CODTYP)
        Endif
      Endif
    When 8 :
      LNGFMT = 8
      If instr(1,[F:AMZ1]OPTSAI,"1")
        LNGFMT =  8
      Else
        If instr(1,[F:AMZ1]OPTSAI,"2")
          LNGFMT = 10
        Else
          If instr(1,[F:AMZ1]OPTSAI,"3")
            LNGFMT = 10
          Else
            If instr(1,[F:AMZ1]OPTSAI,"4")
              LNGFMT = 10
            Else
              If instr(1,[F:AMZ1]OPTSAI,"5")
                LNGFMT =  5
              Else
                If instr(1,[F:AMZ1]OPTSAI,"6")
                  LNGFMT =  5
                Else
                  If instr(1,[F:AMZ1]OPTSAI,"7")
                    LNGFMT =  5
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
  Endcase
Endif
Case [F:AMZ1]LIEN
  When 2 : LNGFMT += 31
  When 3 : LNGFMT += 11
Endcase
Return
###########################################################
# Calcul du numéro de ligne
# Essai de cadrage en colonne nn si OPT3 <> 0 et 2 zones dans la ligne
$CAL_LIGNE
If OPT3 = 0 | ZIORI(K) = 0 | (OPT3 <> 0 & POSD = 1) | (OPT3 <> 0 & POSD >=OPT3)
  POSF = POSD+ZFORI(K)
  Goto CAL_010
Endif
# Comptage des zones affectées sur la même ligne (avec texte)
N = 0
For O = 0 To IORI-1
  If ZBORI(O) = I+1 & int(ZLORI(O)) = int(ZLORI(K))& ZIORI(O) <> 0
    N += 1
  Endif
Next O
If N <> 2
  POSF = POSD+ZFORI(K)
  Goto CAL_010
Endif
#
POSF = OPT3+ZFORI(K)-1
If POSF > LB(I)
  POSF = POSD+ZFORI(K)
  Goto CAL_010
Endif
TFIL(K) = OPT3-POSD-1
POSD = OPT3
$CAL_010
If POSF > LB(I)
  LID  = int(LID)+1
  POSD = 1
Endif
LIG   = LID
LID  += 0.2
POSD += ZFORI(K)
Return
###########################################################
# Section de mise a jour enregistrements AMSKZON
$MAJ_AMSKZON
#----- Traitement variable bas de tableau d'un tableau passé en invisible -----#
J=find([F:AMZ2]CODZON,[F:AMK1]BASPAG)                   : # MBT 04/02/2004
If J>0 & [F:AMK1]TYPBLOC(J-1)=1 & MBORI(J-1)=6          : # MBT 04/02/2004
  [F:AMZ2]SAIAFF=3                                      : # MBT 04/02/2004
Endif                                                   : # MBT 04/02/2004
#----- Mise à jour code saisie/affichage -----#
FIL = 0
J =find([AMZ2]CODZON,ZZORI(0..dim(ZZORI)-1))
If J <> 0
  [AMZ2]NOZONE = ZLNEW(J-1)
  FIL          = TFIL(J-1)
  Case [AMZ2]SAIAFF
    When 1 : [AMZ2]SAIAFF = ZAORI(J-1)
    When 2 : If ZAORI(J-1) >= 2
               [AMZ2]SAIAFF = ZAORI(J-1)
             Endif
  Endcase
Endif
# Transfert dans bloc invisible des zones invisibles des blocs liste
# Le déplacement des zones invisibles est supprimé à cause :        : # MBT 16/03/2005
#    - des codes activités qui peuvent être mis sur les blocs       : # MBT 16/03/2005
#    - des instructions qui peuvent travailler sur des no de bloc   : # MBT 16/03/2005
#-----                                                              : # MBT 16/03/2005
#If [AMZ2]SAIAFF = ZINV & NBI <> 99  & MBORI([AMZ2]NUMBLOC-1)= BLIS : # MBT 16/03/2005
#  [AMZ2]NUMBLOC = NBI+1                                            : # MBT 16/03/2005
#Endif                                                              : # MBT 16/03/2005
J = 0
$MAJ_AMSKZON0
If J = IZONE
  Goto MAJ_AMSKZON1
Else
  If [AMZ2]CODZON = TZONE(J)
    Case TMOD(J)
      When 4 : [AMZ2]INTIT = val(TINT(J))
      When 5 : Gosub TRT_DIC
      When 6 : Gosub TRT_DIC
      When 7 : [AMZ2]INTIT   = 0
               [AMZ2]INTEVAL = TINT(J)
      When 8 : TINT(J) = vireblc(TINT(J),1)
               [AMZ2]CODTYP  = toupper(TINT(J))
      When 9 : [AMZ2]MODE  = val(TINT(J))
      When 10 : [AMZ2]OBLIG    = val(TINT(J))
      When 11 : [AMZ2]VALDEF   = TINT(J)
    Endcase
  Endif
Endif
J += 1
Goto MAJ_AMSKZON0
$MAJ_AMSKZON1
If [AMZ2]SAIAFF = 3
  Raz [AMZ2]OPTSAI
  Raz [AMZ2]OPTFOR
  [AMZ2]OBLIG  = 1
  [AMZ2]LIEN   = 1
  [AMZ2]TUNNEL = 1
Endif
Return
###########################################################
# Reprise des données du dictionnaire
$TRT_DIC
Read [ATZ]CODZONE = TTAB(J);TFLD(J)
If !fstat
  [AMZ2]CODTYP = [ATZ]CODTYP
  [AMZ2]CODACT = [ATZ]CODACT
  [AMZ2]LONG   = [ATZ]LONG
  [AMZ2]NOLIB  = [ATZ]NOLIB
  If TMOD(J) = 5
    [AMZ2]INTIT = [ATZ]NOABREG
  Endif
  If TMOD(J) = 6
    [AMZ2]INTIT = [ATZ]NOCOURT
  Endif
  [AMZ2]VALDEF  = ""
  [AMZ2]CODCTL  = ""
Endif
Return
###########################################################
$COPTRT
If TRAIT <> ""
 FICORG = filpath("TRT",TRAIT,"src",nomap)
 If filinfo(FICORG,0)>=0
  FICDES = filpath("TRT",TRAIT,"src",APPLI)
  Call COPIE(FICORG,FICDES,STAT) From ORDSYS
 Endif
 Call EXISTE_ADX("",nomap,TRAIT,OKTRT) From ORDSYS
 If OKTRT>0
  Call COPIE_ADX("",nomap,TRAIT,"",APPLI,TRAIT,STAT) From ORDSYS
 Endif
Endif
Return

