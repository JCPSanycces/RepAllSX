#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################################
#
# GESTION DES BIENS - SUPPRESSION : FENETRE DE GESTION DES EXTOURNES - Gestion des dépenses
# =========================================================================================
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Liste des sous-programmes :
# -------------------------
#
#
#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $ACTION
#
########################################################################################################################
# Modifications :
# -------------
#
# - USR - xx.xx.xxxx - Fq yyyyy - Commentaire
# - CBO - 28.11.2014 - FQ104360 - Undo a linked expense when balance sht val is changed
# - GBO - 18.05.2010 - Fq 64434 - Les dépenses origine interface ne peuvent pas être supprimées.
# - GBO - 07.05.2010 - Fq 64544 - Gestion des écarts entre plans d'amortissement
########################################################################################################################

#----------------------------------------
# CHARGEMENT DE L'ONGLET DEPENSES
#----------------------------------------
$LOAD_LOF

  Raz nolign
  For [LOF] Where AASREF=[M:FAS0]AASREF &[F:LOF]FLGLIKAAS=G_OUI &FLGLOFMAI=G_OUI
    Gosub ALIMENTE_LIGNE_DEPENSE
  Next
  For [LOF] Where AASREF=[M:FAS0]AASREF & [F:LOF]FLGLIKAAS=G_OUI & FLGLOFMAI=G_NON
    #------------------------------
    Gosub ALIMENTE_LIGNE_DEPENSE
  Next
  [M:FC3]NBDEST=nolign
  Affzo [M:FC3]
Return

#----------------------------------------
$ALIMENTE_LIGNE_DEPENSE
 nolign+=1
 LLOCK = func GLOBIENS.GET_KEY_LAYOUTFAS ([F:LOF]CODLOF, [F:LOF]LINLOF)
 If func GLOBIENS.LOCK_SYMBOLE ("LOF", [M:FAS0]CPY, LLOCK, 0) = 0 Then
   # l'enregistrement est locké ailleurs : on ne peut pas le choisir
   [M:FC3]LOCKED(nolign-1) = G_OUI
   [M:FC3]ICOLOCK(nolign-1) = "190"
 Else
   [M:FC3]LOCKED(nolign-1) = G_NON
   [M:FC3]ICOLOCK(nolign-1) = ""
 Endif
 [M:FC3]=[F:LOF]
 #> Par défaut les dépenses sont déliées
 [M:FC3]FLGULI(nolign-1)=G_OUI
 [M:FC3]FLGDETEXP(nolign-1) = G_OUI # FQ104360 Par défaut les dépenses sont détachables
 #> Les dépenses issues de l'interface ne peuvent pas être supprimées @Fq64434
 If [F:LOF]CREORI=GVML_COIMPOR
  Grizo [M:FC3]FLGDEL(nolign-1)
  Grizo [M:FC3]FLGULI(nolign-1)
 Else
  Actzo [M:FC3]FLGDEL(nolign-1)
  Actzo [M:FC3]FLGULI(nolign-1)
 Endif
Return


######################################################################################
# ACTIONS CHAMPS ECRAN FASCNL3
######################################################################################

#----------------------------------------
Subprog AM_FLGDEL(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_OUI & [M:FC3]FLGULI(nolign-1)=G_OUI
  [M:FC3]FLGULI(nolign-1)=G_NON : Affzo [M:FC3]FLGULI(nolign-1)
 Endif
End

#----------------------------------------
Subprog AM_FLGULI(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_OUI & [M:FC3]FLGDEL(nolign-1)=G_OUI
  [M:FC3]FLGDEL(nolign-1)=G_NON : Affzo [M:FC3]FLGDEL(nolign-1)
 Endif
End

#----------------------------------------
Subprog B1_NBDEST
 Local Char LFGRFGR
 Call OBJET_CHAR(LFGRFGR, "LOF",[M:FC3]CODLOF(nolign-1)+"@"+num$([M:FC3]LINLOF(nolign-1))) From GOBJET
End
