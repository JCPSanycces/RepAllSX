# Classe RESULTPRICE_C_COLL
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#  Case [L]CURPTH
#     When ""
#        Case [L]AEVENT
#        Endcase
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
        When "LOADFROMRESULT" :
                                Gosub LOADFROMRESULT
                                Return
  Endcase
Return
#--------------------------------------
#--------------------------------------------------------------------------------------------------
$PROPERTIES
Case [L]CURPRO

Endcase

Return
#--------------------------------------------------------------------------------------------------
#--LOADDOCFROMRESULT => sort of "interface" method
#--We ask the calling object to take what he needs from the result class
#--The object must therefor implement this method in order to be able to call the FINDPRICE method
$LOADFROMRESULT
#Variable Instance GENERIC_OBJ Using OBJECT
#Value    Integer  INDEXLINE
#Variable Instance MYPARAM     using OBJECT => used for both sales and purchase #Using C_SFINDPRICE

    If dim(INDEXLINE)<1
      Local Integer INDEXLINE
    Endif
    If INDEXLINE = 0 :INDEXLINE = 1 : Endif

    Local Integer WRET
    Local Char    WMESSA(250)

    If GENERIC_OBJ=null
    [L]ASTATUS = fmet this.ASETERROR ("", "GENERIC_OBJ :"-mess(18,9137,1), [V]CST_AERROR)
    Return
    Endif

    Local Instance MYDOC Using =GENERIC_OBJ.ObjectType
    MYDOC = cast(GENERIC_OBJ,=GENERIC_OBJ.ObjectType)

    Local Instance SPPARAM Using =MYPARAM.ObjectType
    SPPARAM = cast(MYPARAM,=MYPARAM.ObjectType)

    #--We ask the calling object to fill us
    #--The object must therefor implement this method in order to be able to call the FINDPRICE method
    #--We pass in a pointer to the current instance
    #Onerrgo ERR_LOADDOCFROMRESULT_NOTSUPPORTED
      WRET = fmet MYDOC.LOADDOCFROMRESULT(SPPARAM, INDEXLINE, this)
    #Onerrgo
    If WRET >=[V]CST_AERROR
      WMESSA = "" # 98394.n
      #WMESSA = mess(68,123,1)-":"-mess(1,7845,1)- "LOADFROMRESULT" # 98394.o
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSA, WRET)
      [L]ARET_VALUE = [L]ASTATUS # 98394.n
      Return
    Endif

    #FreeInstance MYDOC
Return
#--------------------------------------------------------------------------------------------------
$ERR_LOADDOCFROMRESULT_NOTSUPPORTED

#[L]ASTATUS = fmet this.ASETERROR ("", "Class"-MYDOC.ObjectType-" : No such method defined LOADDOCFROMRESULT", [V]CST_AERROR)

Resume
#--------------------------------------------------------------------------------------------------

