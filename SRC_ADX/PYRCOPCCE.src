#<AdxTL>@(#)8.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("CYM",GBIDC1,GBIDC2) From GOBJET
End

############################################################################
## Duplication pyramide
############################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC 
 When Default
Endcase
Return

$INIT
If clalev([F:CYM]) = 0 : Local File GCCEPYM  [CYM] : Endif
TMP = 1
GBIDC3 = ""
Return

$INIT_DIA
[M]PYRORG = PARAM(1)
zonsui = "PYM"
Return

$EXEC
Call COPIE([M]DOSORG,[M]DOSDES,[M]PYRORG,[M]PYM,[M]DES)
If GOK=1
 GBIDC3 = [M]PYM
Endif
Return

######################################################################################
## Ecran PYRCOP
######################################################################################
Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
End

Subprog C_DOSORG(VALEUR)
Variable Char    VALEUR()
Local File =VALEUR+".GCCEPYM" [CYM]
Read [CYM]CYM0 = [M]PYRORG
If fstat
 GMESSAGE = mess(96,102,1) : # Pyramide inexistante
 mkstat = 2 : End
Endif
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = [M]DOSORG
Endif
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Local File =[M]DOSORG+".GCCEPYM" [CYM]
Local File =VALEUR+".GDIE"       [DIE]
Read [CYM]CYM0 = [M]PYRORG
Read [DIE]DIE0 = [F:CYM]DIE
If fstat
 GMESSAGE = [F:CYM]DIE-":"-mess(80,103,1) : # Axe inexistant
 mkstat = 2 : End
Endif
End

Subprog C_PYM(VALEUR)
Variable Char    VALEUR()
Local File =[M]DOSDES+".GCCEPYM" [CYM]
Call LECTURE("CYM",VALEUR,"") From CONTOBJ
If !fstat         
  GMESSAGE = mess(94,102,1) : # Pyramide déjà existante
  mkstat = 2 : End
Endif
End

######################################################################################
Subprog COPIE (DOSORG,DOSDES,PYRORG,PYRDES,DESIG)
Value Char DOSORG
Value Char DOSDES
Value Char PYRORG
Value Char PYRDES
Value Char DESIG

Local File =DOSORG+".GCCEPYM"    [CYM1]
Local File =DOSDES+".GCCEPYM"    [CYM2]
Local File =DOSORG+".GCCEGRUPYM" [CRY1]
Local File =DOSDES+".GCCEGRUPYM" [CRY2]
Local File =DOSORG+".GCCEPYMLIK" [CYK1]
Local File =DOSDES+".GCCEPYMLIK" [CYK2]
Local File =DOSORG+".GCCEPYMPRT" [CYP1]
Local File =DOSDES+".GCCEPYMPRT" [CYP2]
Local File =DOSORG+".ATEXTRA"    [AXX1]
Local File =DOSDES+".ATEXTRA"    [AXX2]

Local Char TABLE(GLONATB)
Call DEBTRANS From GLOCK
Gosub TR1
End

$TR1
GOK = 1
Trbegin [CYM2],[CRY2],[CYK2]
 Read [CYM1]CYM0 = PYRORG
 If !fstat 
  [F:CYM2] = [F:CYM1]
  [F:CYM2]PYM    = PYRDES
  If dim([F:CYM2]DES)>0    : [F:CYM2]DES    = DESIG   : Endif
  If dim([F:CYM2]CREDAT)>0 : [F:CYM2]CREDAT = date$   : Endif
  If dim([F:CYM2]CREUSR)>0 : [F:CYM2]CREUSR = GUSER   : Endif
  If dim([F:CYM2]CRETIM)>0 : [F:CYM2]CRETIM = time    : Endif
  If dim([F:CYM2]UPDDAT)>0 : [F:CYM2]UPDDAT = [0/0/0] : Endif
  If dim([F:CYM2]UPDUSR)>0 : [F:CYM2]UPDUSR = ""      : Endif
  If dim([F:CYM2]UPDTIM)>0 : [F:CYM2]UPDTIM = 0       : Endif
  Write  [CYM2]
  If fstat 
   GOK = 0 : Call FSTA("CYM2") From GLOCK : Goto AB_TR1
  Endif
  #
  # Copie des groupes
  #
  Filter [CRY1] Where PYM=PYRORG
  For [CRY1] 
   [F:CRY2]       = [F:CRY1]
   [F:CRY2]PYM    = PYRDES
   If dim([F:CRY2]CREDAT)>0 : [F:CRY2]CREDAT = date$   : Endif
   If dim([F:CRY2]CREUSR)>0 : [F:CRY2]CREUSR = GUSER   : Endif
   If dim([F:CRY2]CRETIM)>0 : [F:CRY2]CRETIM = time    : Endif
   If dim([F:CRY2]UPDDAT)>0 : [F:CRY2]UPDDAT = [0/0/0] : Endif
   If dim([F:CRY2]UPDUSR)>0 : [F:CRY2]UPDUSR = ""      : Endif
   If dim([F:CRY2]UPDTIM)>0 : [F:CRY2]UPDTIM = 0       : Endif
   Write [CRY2]
   If fstat 
    GOK = 0 : Call FSTA("CRY2") From GLOCK : Break
   Endif
  Next
  Filter [CRY1]
  If GOK<1 : Goto AB_TR1 : Endif
  #
  # Copie des liens
  #
  Filter [CYK1] Where PYM=PYRORG
  For [CYK1] 
   [F:CYK2] = [F:CYK1]
   [F:CYK2]PYM = PYRDES
   Write [CYK2]
   If fstat 
    GOK = 0 : Call FSTA("CYK2") From GLOCK : Break
   Endif
  Next
  Filter [CYK1]
  If GOK<1 : Goto AB_TR1 : Endif
  #
  #
  # Copie des liens
  #
  Filter [CYP1] Where PYM=PYRORG
  For [CYP1] 
   [F:CYP2] = [F:CYP1]
   [F:CYP2]PYM = PYRDES
   Write [CYP2]
   If fstat 
    GOK = 0 : Call FSTA("CYP2") From GLOCK : Break
   Endif
  Next
  Filter [CYP1]
  If GOK<1 : Goto AB_TR1 : Endif
  #
  # Copie des textes
  #
  For TABLE="GCCEPYM","GCCEGRUPYM"
   For [AXX1] Where CODFIC=TABLE & IDENT1=PYRORG
    [F:AXX2] = [F:AXX1]
    [F:AXX2]IDENT1 = PYRDES
    If TABLE="GCCEPYM" & [F:AXX1]ZONE="DESTRA" & [F:AXX1]LANGUE=GLANGUE
     [F:AXX2]TEXTE = DESIG
    Endif
    Write [AXX2]
    If fstat
     GOK = 0 : Call FSTA("AXX2") From GLOCK : Break 2
    Endif
   Next
  Next TABLE
  If GOK<1 : Goto AB_TR1 : Endif
  #
 Commit
Endif
End

$AB_TR1
Rollback
Return

######################################################################################

