#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
#############################################################
#
# Fixed Assets migration process to U11
#
# --> Delete ATBDIV 967 (Taxes / véhicules des sociétés)
#
#############################################################
#

Subprog AMAJ
#** Called from DOSMAJ80
#*!
  Local Shortint IS_HISTO_FOLDER : IS_HISTO_FOLDER = func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)

  Call ECR_TRACE("Start AMAJ from FASMAJ80 on" - [F:ADS]DOSSIER, 0) From GESECRAN

  If !IS_HISTO_FOLDER : # FQ108289
    # Not to perform in an archive folder (settings data)

    # delete ATABDIV 967
    Gosub ADEL_967

  Endif


  Call ECR_TRACE("End AMAJ from FASMAJ80",0) From GESECRAN

End

Subprog MAJ
#** Called from DOSMAJ80
#*!
End

################################################################

################################################################
#
# delete ATBDIV 967
#
################################################################
$ADEL_967

  GOK = 1
  Call ECR_TRACE("Start of deleting ATABDIV 967", 0) From GESECRAN

  If clalev([F:ADI]) :   Close File  [ADI] :   Endif
  Local File =[F:ADS]DOSSIER + ".ATABDIV" [ADI]

  If clalev([F:ADV]) :   Close File  [ADV] :   Endif
  Local File =[F:ADS]DOSSIER + ".ATABTAB" [ADV]

  If clalev([F:AXX2]) :  Close File  [F:AXX2] :  Endif
  Local File =[F:ADS]DOSSIER + ".ATEXTRA" [AXX2]

  Onerrgo ERR_FASMAJ80

  Trbegin [ADI]

  Delete [F:AXX2] Where CODFIC="ATABDIV" and IDENT1=num$(967)
  Delete [F:ADI]  Where NUMTAB=967
  Delete [F:ADV]  Where NUMTAB=967

  If GOK
    Commit
  Else
    Rollback
  Endif

  Onerrgo

  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("End of deleting ATABDIV 967", 0) From GESECRAN

Return

$ERR_FASMAJ80
  GOK = 0
  Call ECR_TRACE(errm - errmes$(errn) - "/" -errp, -1) From GESECRAN
  Call ECR_TRACE("Line =" - num$(errl) - "Err number =" - num$(errn), -1) From GESECRAN
Resume

