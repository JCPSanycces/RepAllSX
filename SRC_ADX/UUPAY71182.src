#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UUPAY  Squelette pour Moulinette                      Module CPT       #
#            description de la moulinette                                #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UUPAY71182 Process") From LECFIC

  Call MAJ_71182(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_71182(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, NBRPYH
Local Char CRITERE(250)
Local Char ACLE1(30), ACLE2(30), ACLE3(30), ACLE4(30)
Local Integer ICLE1, ICLE2, ICLE3

Local Char SVG_NUM(30)

#----- Ouverture des fichiers -----#
If clalev([F:DAE])  =0  Local File =DOSSIER+".GACCENTRYD"   [DAE] : Endif
If clalev([F:DAT])  =0  Local File =DOSSIER+".GACCTMPD"     [DAT] : Endif
If clalev([F:PAN])  =0  Local File =DOSSIER+".PAYACCNUM"    [PAN] : Endif
If clalev([F:PMD])  =0  Local File =DOSSIER+".PAYACCNUMD"   [PMD] : Endif

If clalev([F:TPY])  =0  Local File =DOSSIER+".TABPAYTYP"    [TPY] : Endif
If clalev([F:PAY])  =0  Local File =DOSSIER+".PAYMENTH"     [PYH] : Endif
If clalev([F:BAN])  =0  Local File =DOSSIER+".BANK"         [BAN] : Endif
If clalev([F:JOU])  =0  Local File =DOSSIER+".GJOURNAL"     [JOU] : Endif
If clalev([F:JCO])  =0  Local File =DOSSIER+".GJOUCOA"      [JCO] : Endif

Local Integer ETAP, TYPJOU
Local Char COMPTE(GLONGAC), JOU(GLONJOU)
Local Char PLAN(GLONCOA)

#-------------------------------------------------------------------------------------------------
Call ECR_TRACE("UUPYH 1/3 : Process Start on : "+DOSSIER,-1) From GESECRAN

Gosub SET_FIRST From TRTFIRST
Raz STOP, CRITERE
Raz COMPTEUR, NBRPYH

$LOOP_PYH
Raz NB
If STOP = 1
 STOP = 0
 CRITERE = "[F:PYH]NUM>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

For [PYH]PYH0 Where evalue(CRITERE) 
 For I=0 To dim([F:PYH]ACCNUMTRE)-1
  If [F:PYH]ACCNUMTRE(I)<>0
   Read [DAE]DAE2 = [F:PYH]ACCNUMTRE(I)
   If fstat
    # Peut-être est ce en batch...
    Read [DAT]DAT1 = [F:PYH]ACCNUMTRE(I)
    If fstat
     # Code transaction ... Règlement
     Call ECR_TRACE(mess(102,105,1)-":"-[F:PYH]PAYTYP-mess(47,109,1)-":"-[F:PYH]NUM-"("+num$([F:PYH]ACCNUMTRE(I))+")"-mess([F:PYH]STA,689,1)-num$(I),0) From GESECRAN
     If SVG_NUM<>[F:PYH]NUM : NBRPYH+=1 : Endif
     SVG_NUM = [F:PYH]NUM
    Endif
   Endif
  Endif
 Next
 COMPTEUR+=1
 NB+=1

 If NB>GMAXUPDTRS
  ACLE1 = [F:PYH]NUM
  STOP=1
  Break
 Endif
Next

If STOP
 Goto LOOP_PYH
Endif
Gosub UNSET_FIRST From TRTFIRST

Call ECR_TRACE("UUPYH 1/3 : "+num$(COMPTEUR)+" records processed"-"("+num$(NBRPYH)+")",-1) From GESECRAN


#-------------------------------------------------------------------------------------------------
Call ECR_TRACE("UUPAN 2/3 : Process Start on : "+DOSSIER,-1) From GESECRAN

Link [PAN] With [PYH]PYH0=[F:PAN]NUM
&   As [LNK] Where [F:PYH]NUM<>""
&   Order By Key CLE = [F:PAN]NUM;[F:PAN]ACCNUM;[F:PAN]STA;[F:PAN]TYPNUM

Gosub SET_FIRST From TRTFIRST
Raz STOP, CRITERE
Raz COMPTEUR, NBRPYH

$LOOP_PAN
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:PAN]NUM='"+ACLE1+"' & [F:PAN]ACCNUM="+num$(ICLE1)+"  & [F:PAN]STA="+num$(ICLE2)+" & [F:PAN]TYPNUM>"+num$(ICLE3)
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:PAN]NUM='"+ACLE1+"' & [F:PAN]ACCNUM="+num$(ICLE1)+"  & [F:PAN]STA>"+num$(ICLE2)
Elsif STOP=3
 STOP = 4
 CRITERE = "[F:PAN]NUM='"+ACLE1+"' & [F:PAN]ACCNUM>"+num$(ICLE1)
Elsif STOP=4
 STOP = 0
 CRITERE = "[F:PAN]NUM>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

CRITERE+=' & [F:PAN]ACCNUM>0' 

For [LNK]CLE Where evalue(CRITERE) 
 Read [DAE]DAE2 = [F:PAN]ACCNUM
 If fstat
  # Peut-être est ce en batch...
  Read [DAT]DAT1 = [F:PAN]ACCNUM
  If fstat
   # Code Transaction... Règlement
   Call ECR_TRACE("*1/*"+mess(102,105,1)-":"-[F:PYH]PAYTYP-mess(47,109,1)-":"-[F:PAN]NUM-"("+num$([F:PAN]ACCNUM)+")"-format$("D:"+GFMDAT,[F:PYH]ACCDAT)-mess([F:PAN]TYPNUM,685,1)-mess([F:PYH]STA,689,1)-num$([F:PAN]STA),0) From GESECRAN
   If SVG_NUM<>[F:PAN]NUM : NBRPYH+=1 : Endif
   SVG_NUM = [F:PAN]NUM
  Endif
 Endif
 If [F:PAN]RVSACCNUM>0
  Read [DAE]DAE2 = [F:PAN]RVSACCNUM
  If fstat
   # Peut-être est ce en batch...
   Read [DAT]DAT1 = [F:PAN]RVSACCNUM
   If fstat
    Call ECR_TRACE("*2/*"+mess(102,105,1)-":"-[F:PYH]PAYTYP-mess(47,109,1)-":"-[F:PAN]NUM-"("+num$([F:PAN]RVSACCNUM)+")"-format$("D:"+GFMDAT,[F:PYH]ACCDAT)-mess([F:PAN]TYPNUM,685,1)-mess([F:PYH]STA,689,1)-num$([F:PAN]STA),0) From GESECRAN
   Endif
  Endif
 Endif

 COMPTEUR+=1
 NB+=1

 If NB>GMAXUPDTRS
  ACLE1 = [F:PAN]NUM
  ICLE1 = [F:PAN]ACCNUM
  ICLE2 = [F:PAN]STA
  ICLE3 = [F:PAN]TYPNUM
  STOP=1
  Break
 Endif
Next

If STOP
 Goto LOOP_PAN
Endif
Gosub UNSET_FIRST From TRTFIRST

Call ECR_TRACE("UUPAN 2/3 : "+num$(COMPTEUR)+" records processed"-"("+num$(NBRPYH)+")",-1) From GESECRAN

#-------------------------------------------------------------------------------------------------
Call ECR_TRACE("UUPMD 3/3 : Process Start on : "+DOSSIER,-1) From GESECRAN


Link [PMD] With [PYH]PYH0=[F:PMD]NUM
&   As [LNK] Where [F:PYH]NUM<>""
&   Order By Key CLE = [F:PMD]NUM;[F:PMD]ACCNUM;[F:PMD]ACCSTA

Gosub SET_FIRST From TRTFIRST
Raz STOP, CRITERE
Raz COMPTEUR, NBRPYH

$LOOP_PMD
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:PMD]NUM='"+ACLE1+"' & [F:PMD]ACCNUM="+num$(ICLE1)+" & [F:PMD]ACCSTA>"+num$(ICLE2)
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:PMD]NUM='"+ACLE1+"' & [F:PMD]ACCNUM>"+num$(ICLE1)
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:PMD]NUM>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

CRITERE+=' & [F:PMD]ACCNUM>0' 

For [LNK]CLE Where evalue(CRITERE) 
 Read [DAE]DAE2 = [F:PMD]ACCNUM
 If fstat
  # Peut-être est ce en batch...
  Read [DAT]DAT1 = [F:PMD]ACCNUM
  If fstat
   # Code transaction ... Règlement
   Call ECR_TRACE(mess(102,105,1)-":"-[F:PYH]PAYTYP-mess(47,109,1)-":"-[F:PMD]NUM-"("+num$([F:PMD]ACCNUM)+")"-format$("D:"+GFMDAT,[F:PYH]ACCDAT),0) From GESECRAN
   If SVG_NUM<>[F:PMD]NUM : NBRPYH+=1 : Endif
   SVG_NUM = [F:PMD]NUM
  Endif
 Endif

 If [F:PMD]RVSACCNUM>0
  Read [DAE]DAE2 = [F:PMD]RVSACCNUM
  If fstat
   # Peut-être est ce en batch...
   Read [DAT]DAT1 = [F:PMD]RVSACCNUM
   If fstat
    # Code transaction ... Règlement
    Call ECR_TRACE(mess(102,105,1)-":"-[F:PYH]PAYTYP-mess(47,109,1)-":"-[F:PMD]NUM-"("+num$([F:PMD]RVSACCNUM)+")"-format$("D:"+GFMDAT,[F:PYH]ACCDAT),0) From GESECRAN
   Endif
  Endif
 Endif

 COMPTEUR+=1
 NB+=1

 If NB>GMAXUPDTRS
  ICLE1 = [F:PMD]ACCNUM
  ACLE1 = [F:PMD]NUM
  ICLE2 = [F:PMD]ACCSTA
  STOP=1
  Break
 Endif
Next

If STOP
 Goto LOOP_PMD
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [DAE], [PAN]

Call ECR_TRACE("UUPMD 3/3 : "+num$(COMPTEUR)+" records processed"-"("+num$(NBRPYH)+")",-1) From GESECRAN

End







