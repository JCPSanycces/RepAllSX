#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque AJS1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone SEQ
mkstat = 0
zoncou = "SEQ"
indice = 0
If varmode([M]SEQ,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SEQ" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBENDP
mkstat = 0
zoncou = "NBENDP"
indice = 0
status = 1
zoncou = "NBENDP"
If varmode([M]NBENDP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBENDP" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBENDP
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBENDP = nolign
   status = 75
   Call SAI_NBENDP(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBENDP(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBENDP
mkstat = 0
zoncou = "NBENDP"

## Zone ALS
mkstat = 0
zoncou = "ALS"
If varmode([M]ALS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ALS" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]ALS(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "ALS" : GZNUM = 30818 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PRIORITY
mkstat = 0
zoncou = "PRIORITY"
If varmode([M]PRIORITY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PRIORITY" : Gosub ACTION From =IMPTRT
 Endif
 If [M]PRIORITY(indice)=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PRIORITY" : GZNUM = 1164 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone URL
mkstat = 0
zoncou = "URL"
If varmode([M]URL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "URL" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]URL(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "URL" : GZNUM = 26967 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone NBENDP
mkstat = 0
zoncou = "NBENDP"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "AJS1"
Return

