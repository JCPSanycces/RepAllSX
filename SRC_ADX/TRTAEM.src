#<AdxTL>@(#)7.0.0.0 $Revision$
################################################################################
# SBA - 16/09/13 - FQ920441 - US1927  Extraction fichier
################################################################################
Local Char    PARAM(10)(1..2)
Local Integer VALEUR
Call TRAITE_LIB([L]VALEUR,[L]PARAM,"","TRTAEM","DTRTAEM",4,"") From GTRAITE
End

$ACTION
Case [L]ACTION
 When "INIT"     : Goto INIT
 When "CONTROLE" : Goto CONTROLE
 When "EXEC"     : Goto EXEC
 When "TERMINE"  : Goto TERMINE
 When "SORTIE"   : Gosub SORTIE
#-------------------------------------------------------------------------------
 #81085
 When "DEBUT"    : Gosub DEBUT
 When "BOUTON"   : Gosub BOUTON
Endcase
Return

$DEBUT
#Multi-legislation
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
#81085
# SBA - 16/09/13 - FQ920441 - US1927
If [M:TAEM]TYPEXP=1
  Grizo [TAEM] FIL
Endif
Affzo [TAEM]
Setmok [TAEM] With 0
Call AFF_MEMO From DIVPAYE
Return

################################################################################
#81085
$BOUTON
Case BOUT
   When "R" :
     # Button "Rappel MEMO"
     If [M:TAEM]TYPEXP=1
        Grizo [TAEM] FIL
      Else
        Actzo [TAEM] FIL
      Endif
     Call AFF_MEMO From DIVPAYE
Endcase
Return

################################################################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Call DELOCK("MEA") From GLOCK
Return

################################################################################
#
# GTRAITE
#
################################################################################

$INIT
Local Integer STAT
Local Char    CRITERE(250), SYMBOLE(50)

If !clalev([F:ADI])   : Local File ATABDIV   [ADI]    : Endif
If !clalev([F:ID])    : Local File EMPLOID   [ID]     : Endif
If !clalev([F:HRCTR]) : Local File EMPLOCTR  [HRCTR]  : Endif
If !clalev([F:CTR2])  : Local File EMPLOCTR  [CTR2]   : Endif
If !clalev([F:FEH])   : Local File FILEDIH   [FEH]    : Endif
If !clalev([F:MEA])   : Local File MEAEMP    [MEA]    : Endif
If !clalev([F:VEP])   : Local File VALEMP    [VEP]    : Endif
If !clalev([F:HRPOA])   : Local File POPULA    [HRPOA]    : Endif
If !clalev([F:FEL])   : Local File FILEDIL   [FEL]    : Endif
If !clalev([F:FGR])   : Local File FACGROUP2 [FGR]    : Endif
Gosub OUVRE_FCY From EXTRAEM

Local Mask TRTAEM [TAEM]
#81085
Raz [M:TAEM]
Call LECMEMO("STD","[M:TAEM]","hraem2") From GMEMO
Call AFF_MEMO From DIVPAYE
Return


#-------------------------------------------------------------------------------
$CONTROLE
If [V]GSTATUT<>[V]GSTAOK : [L]FIN=1 : Return : Endif

Gosub OUVRE From WPDEFTABLE

If [M:TAEM]FILFLG<>2 : [L]CRITERE='ASSCOP=2'
Else                   [L]CRITERE='ASSCOP=4'
Endif
If [M:TAEM]DATDEB>[0/0/0]
 [L]CRITERE-='& [VEP]PYRDAT>=['+num$([M:TAEM]DATDEB)+']'
Endif
If [M:TAEM]DATFIN>[0/0/0]
 [L]CRITERE-='& [VEP]PYRDAT<=['+num$([M:TAEM]DATFIN)+']'
Endif
If [M:TAEM]MATDEB>"" : [L]CRITERE-='& REFNUM>="'+[M:TAEM]MATDEB+'"' : Endif
If [M:TAEM]MATFIN>"" : [L]CRITERE-='& REFNUM<="'+[M:TAEM]MATFIN+'"' : Endif
If [M:TAEM]CTRDEB>"" : [L]CRITERE-='& CTRNUM>="'+[M:TAEM]CTRDEB+'"' : Endif
If [M:TAEM]CTRFIN>"" : [L]CRITERE-='& CTRNUM<="'+[M:TAEM]CTRFIN+'"' : Endif
If [M:TAEM]MEADEB>"" : [L]CRITERE-='& AEMNUM>="'+[M:TAEM]MEADEB+'"' : Endif
If [M:TAEM]MEAFIN>"" : [L]CRITERE-='& AEMNUM<="'+[M:TAEM]MEAFIN+'"' : Endif
If [M:TAEM]ALLFCY<>2 : [L]CRITERE-='& [VEP]FCY="'+[M:TAEM]FCY+'"'   : Endif
If [M:TAEM]ALLSRV<>2 : [L]CRITERE-='& [VEP]SRV="'+[M:TAEM]SRV+'"'   : Endif
If [M:TAEM]ALLPRF<>2 : [L]CRITERE-='& [VEP]PRF="'+[M:TAEM]PRF+'"'   : Endif
If [M:TAEM]CPY<>""    : [L]CRITERE-='& [FGR]CPY="'+[M:TAEM]CPY+'"'   : Endif

# FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
If [M:TAEM]POP<>""
 Link [MEA] With [HRPOA]POA0(3)=[M:TAEM]POP;REFNUM;CTRNUM
&             , [FGR]FGR1(1) =FCY
&             , [ID]ID0      =REFNUM
&             , [HRCTR]CTR0(2) =REFNUM;CTRNUM
&             , [VEP]VEP6(2) =[F:FGR]FCY;REFNUM
&            As [MEAK]
&         Where find([VEP]AEMNUM,AEMNUM,"") & evalue([L]CRITERE)
&             & (left$(AEMNUM,1)="E" | left$(AEMNUM,4)="BZZZ")
&             & ([HRCTR]CTRDAT<=[VEP]PYRDAT | ([HRCTR]FLGRET=2 & [HRCTR]RETDATEFF<=[VEP]PYRDAT))
&             & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=[VEP]PYRDAT)  & [F:HRPOA]REFNUM<>""
Else
 Link [MEA] With[FGR]FGR1(1) =FCY
&             , [ID]ID0      =REFNUM
&             , [HRCTR]CTR0(2) =REFNUM;CTRNUM
&             , [VEP]VEP6(2) =[F:FGR]FCY;REFNUM
&            As [MEAK]
&         Where find([VEP]AEMNUM,AEMNUM,"") & evalue([L]CRITERE)
&             & (left$(AEMNUM,1)="E" | left$(AEMNUM,4)="BZZZ")
&             & ([HRCTR]CTRDAT<=[VEP]PYRDAT | ([HRCTR]FLGRET=2 & [HRCTR]RETDATEFF<=[VEP]PYRDAT))
&             & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=[VEP]PYRDAT)
Endif

Gosub LNK_FCY From EXTRAEM

[L]TMP=1
[L]TIT=mess(11,10721,1) : # Génération du fichier
If [V]GSERVEUR | 1 : [L]TRA=1 : Endif
Return

#-------------------------------------------------------------------------------
$EXEC
If [L]TRA
 If ![V]GSERVEUR
  Call OUVRE_TRACE([L]TIT) From LECFIC
 Else
  Call ECR_TRACE([L]TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Endif
Endif

[L]OK=-1
For [MEAK]MEA0(1)
 Call CONTROLE( [F:HRCTR]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[M:TAEM]CRI,[L]STAT,1
&             ) From DIVPAYE

 If [L]STAT
  [L]SYMBOLE="MEA"+[F:MEA]AEMNUM
  Lock =[L]SYMBOLE
  If fstat : [L]OK=0 : Elsif [L]OK=-1 : [L]OK=1 : Endif
  If fstat
   Call QUILOCKE([L]SYMBOLE,1) From DIVPAYE
   If [L]TRA
    Call ECR_TRACE([F:MEA]REFNUM+"\"+[V]GMESSAGE,1) From GESECRAN
    [V]GMESSAGE=""
   Else
    Break
   Endif
  Endif
 Endif
Next

If [L]OK=-1
 If [L]TRA
  Call ECR_TRACE(mess(4,10721,1) ,1) From GESECRAN : # Aucun salarié à déclarer
 Else
  [V]GMESSAGE=mess(4,10721,1) : # Aucun salarié à déclarer
 Endif
 [L]OK=0
Endif

If ![L]OK
 Call DELOCK("MEA") From GLOCK
 If ![L]TRA : [V]GERR=1 : [L]SAI=1 : Endif
 Return
Endif

Call EMISSION([L]TRA)
Return

#-------------------------------------------------------------------------------
$TERMINE
If ![V]GSERVEUR & [L]TRA
 Call FERME_TRACE From LECFIC
Endif
If ![L]OK & [L]TRA : [L]SAI=1 : Endif
Return

################################################################################
#
# Routines
#
################################################################################
# SBA - 16/09/13 - FQ920441 - US1927
# passage de value à variable pour ne pas afficher la trace si bouton annuler.
Subprog EMISSION(TRA)
Variable Integer TRA

Local Integer STAT, NBERR, I
Local Char    MATRI([V]GLONEML), FEH([V]GLONADI), CTR([V]GLONHRCTR)
Local Date    DATMAT

[L]FEH="AEM"
Gosub GENVAR From GENFEH
Gosub DEFVAR From =[L]FEHTRT
Gosub DEFVAR From GENFEH
Gosub DEFVAR

[L]EMISSION=1

# SBA - 16/09/13 - FQ920441 - US1927
# ajout du calcul du nom de fichier
Local Char    FICHIER([V]GDIMFIC), FICCLI([V]GDIMFIC)
[L]FICHIER=[M:TAEM]FIL
If [M:TAEM]TYPEXP=2
 [L]FICHIER=filpath([V]GDIRBQE,[M:TAEM]FIL,"aem",0)
Else
 [L]FICCLI=[L]FICHIER
 Call SET_FICNAM([L]FICCLI,[L]FICHIER,[L]MATRI) From ORDSYS
Endif
# SBA fin
Call DEBTRANS From GLOCK

$TR_EMISSION
[V]GOK=1
Trbegin [MEA]
 Gosub ECRITURE
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : Goto FIN : Else Goto TR_EMISSION : Endif
 Elsif ![V]GOK
  Rollback
  Goto FIN
 Endif
Commit

#-------------------------------------------------------------------------------
$FIN
adxifs=[L]SAVIFS
adxirs=[L]SAVIRS
adxium=[L]SAVIUM

# SBA - 16/09/13 - FQ920441 - US1927
If [M:TAEM]TYPEXP<2
 Local Char FICCLI(GDIMFIC)

 FICCLI=[M:TAEM]FIL
 Local Char W_EXT(6)
 W_EXT="aem"
 Gosub SET_FICDEF From ORDSYS
 If !instr(1,FICDEF,".")
  FICDEF+="."+W_EXT
 Else
  FICDEF=left$(FICDEF,instr(1,FICDEF,"."))+W_EXT
 Endif
 FICCLI+=FICDEF
Call COPCLI([L]FICHIER,[L]FICCLI,[L]STAT) From ORDSYS
 If [L]STAT<>0 : [L]TRA = 0 : Endif
Endif

If [L]TRA
  If [M:TAEM]TYPEXP=2
    [L]FICCLI=[L]FICHIER
  Endif
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE("|"+mess(104,121,1)-[L]FICCLI,0)From GESECRAN
Endif
# SBA fin
End

#-------------------------------------------------------------------------------
$DEFVAR
Local Char    DATFMT(8), SAVIRS(2), SAVIFS(1)
Local Libelle SAVIUM

[L]DATFMT  ="YYYYMMDD"
[L]SAVIRS  =adxirs
[L]SAVIFS  =adxifs
[L]SAVIUM  =adxium
adxirs     =chr$(10)
adxifs     =""
adxium     =[V]GASCII
Return

#-------------------------------------------------------------------------------
$ECRITURE

# SBA - 16/09/13 - FQ920441 - US1927
#Openo filpath([V]GDIRBQE,[M:TAEM]FIL,"aem",0), 0 Using [OPO]


Openo [L]FICHIER, 0 Using [OPO]
# SBA fin

Filter [MEAK] Order By Key CLE=[VEP]FCY;CTRNUM;AEMNUM

Columns [FEH] (LOC,LNG,ZON)
For [MEAK]CLE(1)
 Read [FCYK]CLE(1)=[F:VEP]FCY
 If !fstat : Read [FYKA]CLE(1)=[F:FCY]AEMFCY : Endif
 If !fstat
  For [MEAK]CLE(2)
   Call CONTROLE( [F:MEA]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[M:TAEM]CRI,[L]STAT,1
&               ) From DIVPAYE
   If [L]STAT

    For [MEAK]CLE(3)
     If [F:MEA]ASSCOP<>4
      Readlock [MEA]MEA0 =
      If fstat=1
       [V]GOK  =-1
       [V]GLOCK="$AEMEMP"-[F:MEA]AEMNUM
       Break 2
      Elsif fstat
       [V]GOK=0
       Call RSTA("MEA",[F:MEA]AEMNUM) From GLOCK
       Break 2
      Endif
     Endif

     If [M:TAEM]CRI=""
      [L]MATRI =[F:HRCTR]REFNUM
      [L]CTR   =[F:HRCTR]CTRNUM
      [L]DATMAT=[F:HRCTR]CTRDAT
      Gosub LECEMP From WPDEFTABLE
     Endif

     Gosub EMISSION From =[L]FEHTRT

     If [L]TRA
      Call ECR_TRACE("",0) From GESECRAN
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call ECR_TRACE( [F:MEA]REFNUM-[F:ID]NAM-[F:ID]SRN-[F:MEA]AEMNUM,0) From GESECRAN
     Endif

     [L]NBERR=0
     If [F:MEA]ASSCOP<>4
      Onerrgo ERREURWW
      Gosub CONTROLE From =[L]FEHTRT
      Onerrgo
     Endif

     If ![L]NBERR
      I=adxseek("OPO")
      For [FEH]FEH0 Where FEH=[L]FEH
       Case [F:FEH]ZON
       When ""
        Wrseq space$([F:FEH]LNG); Using [OPO]
       When "NUMASS"
         Wrseq left$([L]NUMASS,8)+space$([F:FEH]LNG-len(left$([L]NUMASS,8))); Using [OPO]
       When Default
        Case evalue("type([L]"+[F:FEH]ZON+")")
        When 1,2,4,8
         Wrseq format$("N0:"+num$([F:FEH]LNG)+"#",evalue("[L]"+[F:FEH]ZON)); Using [OPO]
        When 3
         Wrseq format$("D:"+[L]DATFMT,evalue("[L]"+[F:FEH]ZON)); Using [OPO]
        When 5,6,7,9
         Wrseq format$("N0:"+num$([F:FEH]LNG)+"#",100*evalue("[L]"+[F:FEH]ZON));
&              Using [OPO]
        When Default
         Wrseq left$(evalue("[L]"+[F:FEH]ZON),[F:FEH]LNG); Using [OPO]
        Endcase
        Wrseq space$([F:FEH]LOC+[F:FEH]LNG-(adxseek("OPO")-I+1)); Using [OPO]
       Endcase
      Next
      Wrseq Using [OPO]

      If [F:MEA]ASSCOP<>4
       Gosub MAJFIC From =[L]FEHTRT
       [F:MEA]ASSCOP=4 : # Emis
       Rewrite [MEA] Curr
       If fstat
        [V]GOK=0
        Call FSTA("MEA") From GLOCK
        Break 2
       Endif
      Endif
     Endif
    Next
   Endif
  Next
 Endif
Next
Filter  [MEAK]
Columns [FEH]
Openo Using [OPO]
Return

#-------------------------------------------------------------------------------
$ERREURWW
Openo Using [OPO]
Rollback
Call ECR_TRACE(errp-num$(errl)-errmes$(errn)-errm,1) From GESECRAN
Goto FIN

################################################################################
#
# Etiquettes de l'écran TRTAEM
#
################################################################################

########################################
Subprog C_FIL(VALEUR)
Variable Char    VALEUR()

Local Char    FICHIER(250)
Local Integer OK

Call C_NOMEXP(VALEUR,"aem") From TRTDUE
If mkstat=2 : End : Endif

Call EXISTE(filpath([V]GDIRBQE,[L]VALEUR,"aem",0),[L]OK) From ORDSYS
If [L]OK
 [V]GMESSAGE=mess(132,133,1) : # Fichier déjà existant
 [V]GERR    =3
 End
Endif

End
######################################################################################
## Section automatically added (screen TRTAEM) 24/05/2012 17:19:35 (ADW)
######################################################################################
Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR

If VALEUR = 2
  GCURLEG = ''
Endif

End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

If dim([F:CPY]LEG)>0
  Call LECTURE("CPY",VALEUR,"") From CONTOBJ
  GCURLEG = [F:CPY]LEG
Endif

End


######################################################################################
# SBA - 16/09/13 - FQ920441 - US1927
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR

If [V]GBATCH & [L]VALEUR<2
 [V]GMESSAGE=mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat     =2
 End
Endif

If [L]VALEUR=2 : Actzo [TAEM] FIL
Else             Grizo [TAEM] FIL
Endif
End

################################################################################
# SBA - 16/09/13 - FQ920441 - US1927
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
Raz [M:TAEM]FIL
If [L]VALEUR<2
 Call SET_NAMCLI([M:TAEM]FIL) From ORDSYS
Endif
End


######################################################################################
