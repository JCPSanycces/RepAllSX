#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
Subprog SUPP_CPPRIS(LEG,SOA_GOK,SOA_ERRMSG)
Value Char LEG
Variable Integer SOA_GOK
Variable Char SOA_ERRMSG

# use clalev in this routine - too many calls to this routine to try and control this
If !clalev([F:CNG])  : Local File CNGCPY  [CNG]  : Endif
If !clalev([F:CNE])  : Local File CNGEMP  [CNE]  : Endif
If !clalev([F:TIC])  : Local File TIMCNG  [TIC]  : Endif
If !clalev([F:TIC2]) : Local File TIMCNG  [TIC2] : Endif
If !clalev([F:TIP2]) : Local File TIMEMP  [TIP2] : Endif

Local Integer BLOQ
Local Char ERRMES(250)

Local Shortint AN(9), NBAN, I, J, NBCPY
Local Decimal  NBSUPP(9), SOLDE, HEURE, MINI
Local Date     DAT1, DAT2
Local Char     CPY(GLONCPY), CTR(GLONHRCTR)

SOA_GOK = 1  #just make sure it comes in with a value of 1

# table of (nb days/year)  linked to deleted time (TIMEMP)
# from TIC records linked to this time
For [TIC]TIC0 Where LIG=[F:TIP]LIG
 I=find([F:TIC]YEA,[L]AN(0..[L]NBAN-1))
 If !I : [L]AN([L]NBAN)=[F:TIC]YEA : [L]NBAN+=1 : I=[L]NBAN : Endif
 [L]NBSUPP(I-1)+=[F:TIC]NBRDAY
Next
#From current TIMEMP -> Delete all TIMCNG (Employee Holiday duration) with same LIG
Delete [TIC] Where LIG=[F:TIP]LIG
If fstat
 #[V]GOK=0
 #Call FSTA("TIC") From GLOCK
 SOA_ABR = "TIC"
 Gosub GLOCK_FSTA
 End
Endif

[L]CTR = [F:TIP]CTRNUM

# Link CNGCPY (Annual leave periods) & TIMCNG (Employee Holiday duration)
# From current TIMEMP (Employee Tracked times) -> all TIMCNG with same REFNUM + CTR + TIM
# -> all CNGCPY with same TIM
#
Link [CNG] With [CNE]CNE1~=[F:TIP]REFNUM;YEA;[L]CTR;[F:TIP]TIM
&            As [LNK]
&         Where TIM=[F:TIP]TIM

[L]NBCPY=rowcount([LNK])

###44617 : Pas de param et/ou de fiche congès pour cette année/cet evenèment : pas de gestion
If ![L]NBCPY : End : Endif

Local Integer  CNGYEA([L]NBCPY)
Local Date     CNGDEB([L]NBCPY), CNGFIN([L]NBCPY), CNGSTR([L]NBCPY)
Local Char     CNGCPY(GLONCPY)([L]NBCPY)

# All CNGCPY (Annual leave periods)  order CPY+YEA+TIM in a table
I=0
For [LNK]CNG0
 [L]CNGCPY(I) =[F:CNG]CPY    : # Company
 [L]CNGYEA(I) =[F:CNG]YEA    : # Year
#JASMI - 2014/08/31 - START
# [L]CNGSTR(I) =[F:CNG]STRDAT : # Start date
# [L]CNGDEB(I) =[F:CNG]DEBDAT : # Accepted start
# [L]CNGFIN(I) =[F:CNG]FINDAT : # Accepted end
 If func DIVPAYE.IS_ZA_DEV_LEG(LEG)
  If [F:CNE]EMPLEASTR = [0/0/0] Then
  #JASMI - 2014-10-29 - 2999 - START
#   Call CALC_LVE_DATES_KSA([F:TIP]TIM,[F:CNG]CPY,[F:CNG]YEA,[F:TIP]REFNUM,[L]CTR,
#&                          [F:CNE]EMPLEASTR,[F:CNE]EMPLEAEND,[F:CNE]EMPCYCSTR,[F:CNE]EMPCYCEND) From SUBCNEKSA
   Local Integer NEWYEA : [L]NEWYEA = 0
   Call CALC_LVE_DATES_KSA([F:TIP]TIM,[F:CNG]CPY,[F:CNG]YEA,[F:TIP]REFNUM,[L]CTR,
&                          [F:CNE]EMPLEASTR,[F:CNE]EMPLEAEND,[F:CNE]EMPCYCSTR,[F:CNE]EMPCYCEND,
&                          [0/0/0],[L]NEWYEA) From SUBCNEKSA_SOA        # done
  #JASMI - 2014-10-29 - 2999 - END
  Endif
  [L]CNGSTR(I) =[F:CNE]EMPLEASTR : # Start date
  [L]CNGDEB(I) =[F:CNE]EMPLEASTR : # Accepted start
  [L]CNGFIN(I) =[F:CNE]EMPLEAEND : # Accepted end
 Else
  [L]CNGSTR(I) =[F:CNG]STRDAT : # Start date
  [L]CNGDEB(I) =[F:CNG]DEBDAT : # Accepted start
  [L]CNGFIN(I) =[F:CNG]FINDAT : # Accepted end
 Endif
#JASMI - 2014/08/31 - END
I           +=1
Next

#Link TIMCNG (Employee Holiday duration) with TIMEMP (Employee Tracked times) with same LIG
Link [TIC] With [TIP2]TIP0=LIG As [LNK] Order By Key CLE=[TIP2]STRDAT;LIG;YEA

# From current TIMEMP (Employee Tracked times) -> all TIMEMP with same TIM + REFNUM + CTRNUM
# For each (STRDAT+LIG) of TIC : One per TIP
For [LNK]CLE(2) Where [TIP2]REFNUM=[F:TIP]REFNUM & [TIP2]TIM=[F:TIP]TIM & [TIP2]CTRNUM=[F:TIP]CTRNUM
 [L]SOLDE=[F:TIP2]NBRDAY

# From one TIP (TIMEMP), we can have a part of days linked to a year and another part linked to another year
# For each TIC (STRDAT+LIG+YEA) when more than One Year,
 For [LNK]CLE
  If [L]SOLDE>0
   # search the oldest CNGCPY (Annual leave periods) for the company of employee
   # corresponding to the dates
   [L]CPY=func DIVPAYE_SOA.GETSOC([F:TIP2]FCY)    # done
   For J=0 To [L]NBCPY-1
    # TIMEMP ending after "Accepted start" date of CNGCPY
    # and TIMEMP begining before "Accepted end" date of CNGCPY
    If [L]CNGCPY(J)=[L]CPY & [L]CNGDEB(J)<=[F:TIP2]ENDDAT
&    & [L]CNGFIN(J)>=[F:TIP2]STRDAT
     # if CNGCPY's year = TIC year
     If [L]CNGYEA(J)=[F:TIC]YEA
      [L]SOLDE-=[F:TIC]NBRDAY :# remove to balance, nb of days of TIC
      # ----------------------------------------------------------------
      If ![L]SOLDE : Break : Endif : # ------- >
     Endif
     # ----------------------------------------------------------------
     # If ![L]SOLDE <> 0
     # search CNGCPY year in list of years of TIMEMP deleted
     I=find([L]CNGYEA(J),[L]AN(0..[L]NBAN-1))
     If I
      Gosub AVANCE_TIC
      If SOA_GOK<1 : Break 3 : Elsif ![L]SOLDE : Break : Endif
     Endif
    Endif
   Next

  Else
   # ---------- SOLDE <= 0 - Delete TIC ----------------------
   # search TIC year in list of years of TIMEMP deleted
   I=find([F:TIC]YEA,[L]AN(0..[L]NBAN-1))
   # not found, add nb days/year in list of years of TIMEMP deleted
   If !I : [L]AN([L]NBAN)=[F:TIC]YEA : [L]NBAN+=1 : I=[L]NBAN : Endif
   [L]NBSUPP(I-1)+=[F:TIC]NBRDAY

   Delete [TIC] Curr
   If fstat
    SOA_GOK=0
    #Call FSTA("TIC") From GLOCK
    SOA_ABR = "TIC"
    Gosub GLOCK_FSTA
    Break 2
   Endif
  Endif
 Next
Next
If SOA_GOK<1 : End : Endif

# MAJ Employee counter / year / TIM
For I=0 To [L]NBAN-1
 Update [CNE] Where YEA=[L]AN(I) & REFNUM=[F:TIP]REFNUM & TIM=[F:TIP]TIM & CTRNUM=[L]CTR
&              With NBRPRI-=[L]NBSUPP(I)
 If fstat
  SOA_GOK=0
  #Call RSTA("CNE",[F:TIP]REFNUM-num$([L]AN(I))-[F:TIP]TIM-CTR) From GLOCK   #???
  BLOQ = 1  # this is an error - transaction stopped - check ASYRREQ_CSTD for example
  Call RSTA("CNE",[F:TIP]REFNUM-num$([L]AN(I))-[F:TIP]TIM-CTR,BLOQ,SOA_ERRMSG) From GLOCK_SYRA
  Break
 Endif
Next

End

################################################################################
$AVANCE_TIC

#SOA_GOK = 1  #just make sure it comes in with a value of 1

# drag the time on the year before
If [F:TIP2]STRDAT>=[L]CNGDEB(J) & [F:TIP2]ENDDAT<=[L]CNGFIN(J)
# if TIMEMP begining after "Accepted start" date
# &  TIMEMP ending before "Accepted end" date
 [L]MINI=[L]NBSUPP(I-1)
Else
# TIMENP is longer than CNGCPY period -> calculate duration linked to CNGCPY period
 [L]DAT1=max([F:TIP2]STRDAT,[L]CNGDEB(J))
 [L]DAT2=min([F:TIP2]ENDDAT,[L]CNGFIN(J))
 Call VALORIS( [L]DAT1,[L]DAT2,[F:TIP]REFNUM,[F:TIP]TIM,[L]MINI,[L]HEURE
&            , [F:TIP2]FCY,[F:TIP]CTRNUM
&            ) From SUBPLN_SOA                #done
 [L]MINI=min([L]MINI,[L]NBSUPP(I-1))
Endif

If [L]CNGYEA(J)<[F:TIC]YEA
# -------------- decrease nb days (or delete) TIC of year N &  Create TIC for Year N-1
 [L]MINI        =min([F:TIC]NBRDAY,[L]MINI)
 [L]NBSUPP(I-1)-=[L]MINI
 If [L]NBSUPP(I-1)=0 : Dela I-1, 1 [L]AN, [L]NBSUPP : [L]NBAN-=1 : Endif

 I=find([F:TIC]YEA,[L]AN(0..[L]NBAN-1))
 If !I : [L]AN([L]NBAN)=[F:TIC]YEA : [L]NBAN+=1 : I=[L]NBAN : Endif
 [L]NBSUPP(I-1)+=[L]MINI

 [F:TIC]NBRDAY -=[L]MINI
 If [F:TIC]NBRDAY : Rewrite [TIC] Curr : Else Delete [TIC] Curr : Endif
 If fstat
  SOA_GOK=0
  #Call FSTA("TIC") From GLOCK
  SOA_ABR = "TIC"
  Gosub GLOCK_FSTA
  Return
 Endif
# FQ 99541
# [F:TIC2]LIG   =[F:TIP]LIG :# not linked to deleted TIMEMP
 [F:TIC2]LIG   =[F:TIP2]LIG :# linked to TIMEMP on which loop (TIP2)
 [F:TIC2]YEA   =[L]CNGYEA(J)
 [F:TIC2]NBRDAY=[L]MINI
 [F:TIC2]FLGBEF=1+([F:TIP2]STRDAT<[L]CNGSTR(J))
 [F:TIC2]FLGREG=1+(maskcou="TPSSTDR")              #???? what is maskcou - might only be available in classis/V6

 Write [TIC2]
 If fstat
  SOA_GOK=0
  #Call FSTA("TIC2") From GLOCK
  SOA_ABR = "TIC2"
  Gosub GLOCK_FSTA
  Return
 Endif

Else
# -------------- Update TIC of the year -------------
 [L]MINI       =min([L]MINI,[L]SOLDE)
 [F:TIC]NBRDAY+=[L]MINI
 Rewrite [TIC] Curr
 If fstat
  SOA_GOK=0
  #Call FSTA("TIC") From GLOCK
  SOA_ABR = "TIC"
  Gosub GLOCK_FSTA
  Return
 Endif
 [L]NBSUPP(I-1)-=[L]MINI
 If [L]NBSUPP(I-1)=0 : Dela I-1, 1 [L]AN, [L]NBSUPP : [L]NBAN-=1 : Endif
Endif
[L]SOLDE-=[L]MINI
Return

################################################################################
# Ajoute les congés dans TIMCNG et CNGEMP
# [F:TIP] en ligne
# [L]JOUR tableau des jours de VALORDET From SUBPLN pour le [F:TIP] en ligne
####################################
Subprog ADD_CPPRIS(LEG,JOUR,SOA_GOK,SOA_ERRMSG)
Value Char LEG
Value Decimal JOUR(1..)
Variable Integer SOA_GOK
Variable Char SOA_ERRMSG

# use clalev in this routine - too many calls to this routine to try and control this
If !clalev([F:CNG]) : Local File CNGCPY  [CNG] : Endif
If !clalev([F:CNE]) : Local File CNGEMP  [CNE] : Endif
If !clalev([F:TIC]) : Local File TIMCNG  [TIC] : Endif

Local Integer I, REC_EXISTS
Local Char    CPY(GLONCPY), CTR(GLONHRCTR)

SOA_GOK = 1  #just make sure it comes in with a value of 1

[L]CPY=func DIVPAYE_SOA.GETSOC([F:TIP]FCY)
Link [CNE] With [CNG]CNG0=[L]CPY;YEA;TIM As [LNK]

###44617 : Pas de param et/ou de fiche congès pour cette année/cet evenèment : pas de gestion
#Local Shortint NBCPY
Local Integer NBCPY : # 93766 Quand on dépasse 32768 enregistrements dans CNE
[L]NBCPY=rowcount([LNK])
If ![L]NBCPY : End : Endif
###

CTR = [F:TIP]CTRNUM

#JASMI - 2014-08-29 - START
#For [LNK]CNE1 Where REFNUM=[F:TIP]REFNUM & TIM=[F:TIP]TIM & NBRPRI<NBRDAY & CTRNUM=CTR
#&                        & [CNG]DEBDAT<=[F:TIP]ENDDAT & [CNG]FINDAT>=[F:TIP]STRDAT
Local Char     CRITERIA(100)
If func DIVPAYE.IS_ZA_DEV_LEG(LEG) Then
  CRITERIA = '[CNE]EMPLEASTR<=[F:TIP]ENDDAT & [CNE]EMPLEAEND>=[F:TIP]STRDAT'
Else
  CRITERIA = '[CNG]DEBDAT<=[F:TIP]ENDDAT & [CNG]FINDAT>=[F:TIP]STRDAT'
Endif
For [LNK]CNE1 Where REFNUM=[F:TIP]REFNUM & TIM=[F:TIP]TIM & NBRPRI<NBRDAY & CTRNUM=CTR
&                        & evalue(CRITERIA)
#JASMI - 2014-08-29 - END

 # FQ82073 - MABON 04/01/13 - Recherche si enregistrement existe déjà
 REC_EXISTS=1
 Read [F:TIC]TIC0=[F:TIP]LIG;[F:CNG]YEA
 If fstat Then
  [F:TIC]LIG   =[F:TIP]LIG
  [F:TIC]YEA   =[F:CNG]YEA
  REC_EXISTS=0
 Endif
 # Fin MABON
 [F:TIC]NBRDAY=[F:CNE]NBRPRI
 [F:TIC]FLGREG=1+(maskcou="TPSSTDR")
 #JASMI - 2014/08/31 - START
# [F:TIC]FLGBEF=1+([F:TIP]STRDAT<[F:CNG]STRDAT)
 If func DIVPAYE.IS_ZA_DEV_LEG(LEG) Then
  [F:TIC]FLGBEF=1+([F:TIP]STRDAT<[F:CNE]EMPLEASTR)
 Else
  [F:TIC]FLGBEF=1+([F:TIP]STRDAT<[F:CNG]STRDAT)
 Endif
#JASMI - 2014/08/31 - END

For I=1 To dim([L]JOUR)

#JASMI - 2014-08-29 - START
#  If [L]JOUR(I)>0 & [F:TIP]STRDAT+I-1>=[F:CNG]DEBDAT
#   If [F:CNE]NBRPRI=[F:CNE]NBRDAY | [F:TIP]STRDAT+I-1>[F:CNG]FINDAT
#    Break
#   Elsif [F:CNE]NBRPRI+[L]JOUR(I)<[F:CNE]NBRDAY
#    [F:CNE]NBRPRI+=[L]JOUR(I)
#    [L]JOUR(I)    =0
#   Else
#    [L]JOUR(I)   -=[F:CNE]NBRDAY-[F:CNE]NBRPRI
#    [F:CNE]NBRPRI =[F:CNE]NBRDAY
#   Endif
#  Endif
   If func DIVPAYE.IS_ZA_DEV_LEG(LEG) Then
    If [L]JOUR(I)>0 & [F:TIP]STRDAT+I-1>=[F:CNE]EMPLEASTR
     If [F:CNE]NBRPRI=[F:CNE]NBRDAY | [F:TIP]STRDAT+I-1>[F:CNE]EMPLEAEND
      Break
     Elsif [F:CNE]NBRPRI+[L]JOUR(I)<[F:CNE]NBRDAY
      [F:CNE]NBRPRI+=[L]JOUR(I)
      [L]JOUR(I)    =0
     Else
      [L]JOUR(I)   -=[F:CNE]NBRDAY-[F:CNE]NBRPRI
      [F:CNE]NBRPRI =[F:CNE]NBRDAY
     Endif
    Endif
   Else
    If [L]JOUR(I)>0 & [F:TIP]STRDAT+I-1>=[F:CNG]DEBDAT
     If [F:CNE]NBRPRI=[F:CNE]NBRDAY | [F:TIP]STRDAT+I-1>[F:CNG]FINDAT
      Break
     Elsif [F:CNE]NBRPRI+[L]JOUR(I)<[F:CNE]NBRDAY
      [F:CNE]NBRPRI+=[L]JOUR(I)
      [L]JOUR(I)    =0
     Else
      [L]JOUR(I)   -=[F:CNE]NBRDAY-[F:CNE]NBRPRI
      [F:CNE]NBRPRI =[F:CNE]NBRDAY
     Endif
    Endif
   Endif
 Next
#JASMI - 2014-08-29 - END

 [F:TIC]NBRDAY=[F:CNE]NBRPRI-[F:TIC]NBRDAY
 If REC_EXISTS Then
  Rewrite [TIC]
 Else
  Write [TIC]
 Endif
 If fstat
  SOA_GOK=0
  #Call FSTA("TIC") From GLOCK
  SOA_ABR = "TIC"
  Gosub GLOCK_FSTA
  Break
 Endif

 Rewrite [CNE]
 If fstat
  SOA_GOK=0
  #Call FSTA("CNE") From GLOCK
  SOA_ABR = "CNE"
  Gosub GLOCK_FSTA
  Break
 Endif

 If sum([L]JOUR)=0 : Break : Endif
Next

#Il reste des jours à poser mais le solde est insuffisant -> SOLDE négatif
If sum([L]JOUR)<>0
#JASMI - 2014-08-29 - START
# Filter [LNK] Where REFNUM=[F:TIP]REFNUM & TIM=[F:TIP]TIM & CTRNUM=CTR
#&                 & [CNG]DEBDAT<=[F:TIP]ENDDAT & [CNG]FINDAT>=[F:TIP]STRDAT
 If func DIVPAYE.IS_ZA_DEV_LEG(LEG) Then
  Filter [LNK] Where REFNUM=[F:TIP]REFNUM & TIM=[F:TIP]TIM & CTRNUM=CTR
&                         & EMPLEASTR<=[F:TIP]ENDDAT & EMPLEAEND>=[F:TIP]STRDAT
 Else
  Filter [LNK] Where REFNUM=[F:TIP]REFNUM & TIM=[F:TIP]TIM & CTRNUM=CTR
&                         & [CNG]DEBDAT<=[F:TIP]ENDDAT & [CNG]FINDAT>=[F:TIP]STRDAT
 Endif
#JASMI - 2014-08-29 - END
 Read [LNK]CNE1 Last
 Filter [LNK]
 If !fstat
  [F:CNE]NBRPRI +=sum([L]JOUR)
  Rewrite [CNE]
  If fstat
   SOA_GOK=0 #: Call FSTA("CNE") From GLOCK
   SOA_ABR = "CNE"
   Gosub GLOCK_FSTA
   # there is no "End" here - see original code ????
  Endif
  Readlock [F:TIC]TIC0=[F:TIP]LIG;[F:CNG]YEA
  If !fstat
   [F:TIC]NBRDAY+=sum([L]JOUR)
   Rewrite [TIC]
   If fstat
    SOA_GOK=0 #: Call FSTA("TIC") From GLOCK
    SOA_ABR = "TIC"
    Gosub GLOCK_FSTA
    # there is no "End" here - see original code ????
   Endif
  Elsif fstat=5
   Raz [F:TIC]
   [F:TIC]LIG   =[F:TIP]LIG
   [F:TIC]YEA   =[F:CNG]YEA
   [F:TIC]NBRDAY=sum([L]JOUR)
   If maskcou="TPSSTDR"
    [F:TIC]FLGREG=2
   Else
    [F:TIC]FLGREG=1
   Endif
#JASMI - 2014/08/31 - START
#  [F:TIC]FLGBEF=1+([F:TIP]STRDAT<[F:CNG]STRDAT)
   If func DIVPAYE.IS_ZA_DEV_LEG(LEG) Then
    [F:TIC]FLGBEF=1+([F:TIP]STRDAT<[F:CNE]EMPLEASTR)
   Else
    [F:TIC]FLGBEF=1+([F:TIP]STRDAT<[F:CNG]STRDAT)
   Endif
#JASMI - 2014/08/31 - START
   Write [TIC]
   If fstat
    SOA_GOK=0 #: Call FSTA("TIC") From GLOCK
    SOA_ABR = "TIC"
    Gosub GLOCK_FSTA
   Endif
  Endif
 Endif
Endif
End
################################################################################
$GLOCK_RSTA

# looks like we are not calling this

SOA_GOK=0
Local Integer BLOQ
Local Char ERRMES(250)
BLOQ = 1  # this is an error - transaction stopped - check ASYRREQ_CSTD for example
#Call RSTA("CNE",this.REFNUM-'WRK=""',BLOQ,ERRMES) From GLOCK_SYRA   #????
#Rollback  # do we need to rollback?
#ASTATUS=fmet this.ASETERROR("",ERRMES,[V]CST_AERROR)  # call ASETERROR outside of this routine

Return
#-------------------------------------------------------------------------------
$GLOCK_FSTA

SOA_GOK=0
Local Integer BLOQ
BLOQ = 1 # this is an error - transaction stopped
Call FSTA(SOA_ABR,BLOQ,SOA_ERRMSG) From GLOCK_SYRA
#Set error in the calling program
#ASTATUS=fmet this.ASETERROR("",ERRMES,[V]CST_AERROR)  # call ASETERROR outside of this routine

Return
################################################################################
Funprog OUVRABLE(MATRI,ENDDAT,CTR,CDCG_FCY,SOA_GMESSAGE)
Value Char MATRI, CTR
Value Date ENDDAT
Value Char CDCG_FCY
Variable Char SOA_GMESSAGE

Local Integer ANNEE , SEMAINE , ANNCUR , SEMCUR , OK, TYP
Local Date    DAT , DEBUT , FIN
Local Char    PLNCUR(GLONPLN)

# GLobal required in SETSEM
Local Char    SOA_GTPSMAT (GLONMAT)
Local Char    SOA_GTPSCTR (GLONHRCTR)
Local Date    SOA_GTPSCTRDAT
Local Date    SOA_GTPSFINCTR
Local Date    SOA_GTPSDAT
Local Date    SOA_GTPSDEBUT
Local Date    SOA_GTPSFIN
Local Integer SOA_GTPSANNCUR
Local Integer SOA_GTPSSEMCUR
Local Char    SOA_GTPSPLNCUR (GLONPLN)
Local Char    SOA_GTPSSEMTYP(GLONSTY)
Local Char    SOA_GPLANNING(30)        : Call GPLANNING(SOA_GPLANNING) From ESSGLOB_SOA

Local Integer  SOA_GTPS :  Call GTPS(SOA_GTPS) From ESSGLOB_SOA

If clalev([F:WTY])  = 0  :  Local File TYPWEEK   [WTY]  :  Endif

OK = 1 : # 66374
DAT   = ENDDAT
Repeat
 Raz TYP
 Call DAT(DAT,ANNEE,SEMAINE) From SUBPLN_SOA         #done

# SEGAY 77853 14/11/11
# Read [PLE]PLE0=MATRI;DAT;CTR
# If !fstat
#  TYP = [F:PLE]TYPDAY
 If SOA_GTPS=1
   Read [PLE]PLE0=MATRI;DAT;CTR                     #Opened in C_TIM
 Endif
 If SOA_GTPS=1 and !fstat
    TYP = [F:PLE]TYPDAY
# END 77853 14/11/11
 Else
  If ANNEE<>ANNCUR | SEMAINE<>SEMCUR

   # 66374 - si on cherche sur +d'1 an, on arrête les frais
   If ANNEE<>ANNCUR & OK = 0
    #mkstat = 2
    SOA_GMESSAGE = mess(7,21,1)-mess(1,10404,1)+"/"+mess(2,10404,1)-":"-mess(8,10709,1)
    # Erreur Ouvrables/Ouvrés : Planning inexistant
    Break
   Endif

   If ANNEE<>ANNCUR & ANNCUR <> 0
    OK = 0
   Endif
   # fin 66374

   Gosub SETSEM From SUBPLN_SOA              #done
   SEMCUR = SEMAINE
   ANNCUR = ANNEE
  Endif
  If SEMTYP<>""
   TYP = [F:WTY]TYPDAY(DAT-DEBUT)           #open table above for [F:WTY]. Record read in routine SETSEM from SUBPLN_SOA (see above)
  Endif
 Endif
 If ANNEE<>[F:HLY]YEA
  #Read [HLY]HLY0 = ANNEE;[M]FCY             # need to pass in site from class
  Read [HLY]HLY0 = ANNEE;CDCG_FCY
  If fstat
   Read [HLY]HLY0 = ANNEE;""
  Endif
 Endif
 If !find(DAT,[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
  Case TYP
   When 1 : # Ouvrable
    OK = 1
    Break
   When 2 : # Ouvré
    OK = 0
    Break
  Endcase
 Endif
 DAT += 1
Until 1=0

End OK
################################################################################

