#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion objet DAQ
######################################################################################
Raz GPILOBJ
GBIDC1="200800000272"
GBIDC2="2009~ASN999999~20090101~1~1"
Call OBJET_CHAR(GBIDC1,"DAQ",GBIDC2) From GOBJET
End


## Etiquette ajoutée par le superviseur (Objet DAQ) 23/06/2009 17:34:23 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE From SUBDAP
 When "LIENS"       : Gosub LIENS
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "FILTRE"      : Gosub FILTRE
 When "FILGAUCHE"   : Gosub FILGAUCHE 
 When "VERF_ANU"    : Gosub VERF_ANU
 When "DEFTRANS"    : Gosub DEFTRANS From SUBDAE
 When "STATUT"      : Gosub STATUT From SUBDAE
Endcase
Return


###################################
$SETBOUT    #pour désactiver le bouton nouveau & chgt clé
Call VIREBOUT (CHAINE,"CH") From GOBJET
If REP<>""  | [F:HRDAE]FLGNEWSAL=2
 Call VIREBOUT (CHAINE,"G") From GOBJET
Endif
#Objet à 4 éléments de clé : ajout du btn suppression après que GOBJET l'ait viré !
If CLECUR & VERROU : CHAINE+="A" : Endif
If GREP=""
 CHMEN += "1"
Elsif GREP="M" | GREP="D"
 CHMEN=""
Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

###################################
$EXEBOUT
Case BOUT
 When "G"
  # Pas de lectcure si la création s'est mal passée...
  If !GOK : Return : Endif
  # Unlock la fiche qui était à l'écran quand on a fait "NOUVEAU"
  If VERROU : Gosub DEVERROU From GOBJET : Endif
 Gosub RAFFRAICHIR From GOBJSUB
 Gosub RELIT From GOBJSUB
Endcase
Return

###################################
$LIENS
#The read is in the object
[M:DAQ1]NAM=[F:HRDAE]NAM
[M:DAQ1]SRN=[F:HRDAE]SRN
[M:DAQ1]NUMSSEBNF1=[F:DAQ]NUMSSEBNF(0)
[M:DAQ1]NUMSSEBNF2=[F:DAQ]NUMSSEBNF(1)
Gosub CHARGE_TAB
Return

$CHARGE_TAB
nolign=0
For [DQE]DQE0 Where YEAEMPDDS=[M:DAQ1]YEAEMPDDS & EMPDDS=[M:DAQ1]EMPDDS
&  & ETRDAT=[M:DAQ1]ETRDAT & CTRNUM=[M:DAQ1]CTRNUM & TYPDAE=[M:DAQ1]TYPDAE & NUMLIG=[M:DAQ1]NUMLIG
 nolign += 1
 [M:DAQ1]=[F:DQE]
Next
[M:DAQ1]NBRDQE = nolign
Return

###################################
$INICRE
$INIMOD
[F:DAQ]NUMSSEBNF(0)=[M:DAQ1]NUMSSEBNF1
[F:DAQ]NUMSSEBNF(1)=[M:DAQ1]NUMSSEBNF2
Gosub SAUVE_TAB
Return

$SAUVE_TAB
Delete [DQE] Where YEAEMPDDS=[M:DAQ1]YEAEMPDDS & EMPDDS=[M:DAQ1]EMPDDS
&  & ETRDAT=[M:DAQ1]ETRDAT & CTRNUM=[M:DAQ1]CTRNUM & TYPDAE=[M:DAQ1]TYPDAE & NUMLIG=[M:DAQ1]NUMLIG
If fstat=1
 GOK =-1 : GLOCK = "$DADEMP121" : Return
Endif
For nolign=1 To [M:DAQ1]NBRDQE
 [F:DQE]=[M:DAQ1]
 [F:DQE]LIG=nolign
 Write [DQE]
 If fstat<>0
  GOK = 0 : Call FSTA("DQE") From GLOCK : Break
 Endif
Next
Return


###################################
$FILTRE
If find("DAE",GPILCOD(1..GPILOBJ))
 If FILTSUP<>"" : FILTSUP += " & " : Endif
 FILTSUP -= "YEAEMPDDS='"+[F]YEAEMPDDS+"'"
 FILTSUP -= "& EMPDDS='"+[F]EMPDDS+"'"
 FILTSUP -= "& CTRNUM='"+[F]CTRNUM+"'"
 FILTSUP -= "& ETRDAT=["+format$("D:"+GFMDAT4,[F]ETRDAT)+"]"
 FILTSUP -= "& TYPDAE="+num$([F]TYPDAE)
Else
 If GUSRACS<>2
  If FILTSUP<>"" : FILTSUP += " & " : Endif
  FILTSUP -= '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
  FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
 Else
  FILTSUP ="1=1"
 Endif 
 If [L]ANCOUR<>""
  FILTSUP -= "& [F:DAQ]YEAEMPDDS='"+[L]ANCOUR+"'"
 Endif
Endif
Return

###################################
$FILGAUCHE
If find("DAE",GPILCOD(1..GPILOBJ))
 If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
 FILGAUSUP -= "YEAEMPDDS='"+[F]YEAEMPDDS+"'"
 FILGAUSUP -= "& EMPDDS='"+[F]EMPDDS+"'"
 FILGAUSUP -= "& CTRNUM='"+[F]CTRNUM+"'"
 FILGAUSUP -= "& ETRDAT=["+format$("D:"+GFMDAT4,[F]ETRDAT)+"]"
 FILGAUSUP -= "& TYPDAE="+num$([F]TYPDAE)
Else
 If [L]ANCOUR<>""
  If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
  FILGAUCHE = "[F:DAQ]YEAEMPDDS='"+[L]ANCOUR+"'"
 Else
  FILGAUCHE = ""
 Endif
Endif
Return

###################################
$VERF_ANU
Trbegin [DAQ],[DQE]
 Delete [DAQ] Where YEAEMPDDS=[M:DAQ1]YEAEMPDDS & EMPDDS=[M:DAQ1]EMPDDS
& & ETRDAT=[M:DAQ1]ETRDAT & CTRNUM=[M:DAQ1]CTRNUM & TYPDAE=[M:DAQ1]TYPDAE
& & NUMLIG=[M:DAQ1]NUMLIG
 If fstat = 1  : # enreg locké
  GLOCK = "$DADEMP12" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [DQE] Where YEAEMPDDS=[M:DAQ1]YEAEMPDDS & EMPDDS=[M:DAQ1]EMPDDS
& & ETRDAT=[M:DAQ1]ETRDAT & CTRNUM=[M:DAQ1]CTRNUM & TYPDAE=[M:DAQ1]TYPDAE
& & NUMLIG=[M:DAQ1]NUMLIG
 If fstat = 1  : # enreg locké
  GLOCK = "$DADEMP121" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
Commit
Effzo
OK = 0 :# pour ne pas passer dans la suppression standard 
Return

###################################
$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VERF_ANU : Endif

###################################
$AB_ANN
Rollback
Return






