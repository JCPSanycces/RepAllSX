$_AOTHERS
Gosub DECLARE_VAR From WMC0EMPLOEXM
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_REFNUM From WMC1EMPLOEXM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_REFNUM From WMC1EMPLOEXM : Gosub TESTALLSTAT :  Endif
