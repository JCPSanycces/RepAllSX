If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CRETIM From WMC1EMPLOEXM : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CRETIM From WMC1EMPLOEXM : Gosub TESTALLSTAT :  Endif
