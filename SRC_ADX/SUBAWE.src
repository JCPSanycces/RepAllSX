Subprog AM_CHAMP(VALEUR)
Variable Char    VALEUR()
Local Integer I
For I=0 To [M]NBLIG-1
  If I<>nolign-1 and [M:AWE2]CHAMP(I)=VALEUR
    GMESSAGE=mess(24,123,1)-num$(I+1)   : #"Code déjà existant en ligne"
    mkstat=2
    Break 1
  Endif
Next I

End


