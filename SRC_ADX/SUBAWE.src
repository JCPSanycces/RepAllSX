Subprog AS_AUTMIN(VALEUR)
Variable Integer VALEUR
If [M]TYPPAR(nolign-1)<>2 and [M]TYPPAR(nolign-1)<>3
  VALEUR=1
  Effzo [M]VALMIN(nolign-1)
  Effzo [M]MININCLU(nolign-1)
  Affzo [M]VALMIN(nolign-1),MININCLU(nolign-1)
  mkstat=1
Endif
End

Subprog AM_AUTMIN(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
  Effzo [M]VALMIN(nolign-1)
  Effzo [M]MININCLU(nolign-1)
  Affzo [M]VALMIN(nolign-1),MININCLU(nolign-1)
Endif
End

Subprog AS_VALMIN(VALEUR)
