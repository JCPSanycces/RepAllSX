Subprog AM_GROUPE(VALEUR)
Variable Char    VALEUR()
# On ne peut mettre un nom de groupe déjà existant que si la cardinalité est identique
# Attention on peut avoir des champs dimensionnés dans les blocs groupes
# On interdit de réutiliser le même nom de groupe dans des groupes "discontinus"

# Si on est sur un objet on regarde si c'est un bloc autre que tableau  [M:AWE2]PBASTAB = 2 si tableau


Local Integer GRPERR,SAMENAME,DISCONT,NAMEBEFORE

If [M]TYPOBJ=1
# On vérifie que le nom de groupe n'est pas déjà pris
#       - par un tableau
#       - par un bloc "discontinu"
#       - qu'on ne crée pas une "discontinuité"

  For I=0 To [M]NBLIG-1
    If I<>nolign-1
      If [M:AWE2]GROUPE(I)=VALEUR and [M:AWE2]PBASTAB(I)=2 and
&     left$([M:AWE2]GRPCHP(I),instr(1,[M:AWE2]GRPCHP(I),"~"))<>left$([M:AWE2]GRPCHP(nolign-1),instr(1,[M:AWE2]GRPCHP(nolign-1),"~"))
        GMESSAGE=mess(272,123,1)-num$(I+1)   : #"Code déjà existant avec une dimension différente en ligne"
        GRPERR=1
        Break 1
      Endif
      If [M:AWE2]GROUPE(I)=VALEUR and
&     left$([M:AWE2]GRPCHP(I),instr(1,[M:AWE2]GRPCHP(I),"~"))<>left$([M:AWE2]GRPCHP(nolign-1),instr(1,[M:AWE2]GRPCHP(nolign-1),"~"))
        If [M:AWE2]PBASTAB(nolign-1)=2
#         "Utilisation multiple interdite pour un tableau. Code déjà utilisé en ligne"
          GMESSAGE=mess(281,123,1)-num$(I+1)
          GRPERR=1
          Break 1
        Endif
        SAMENAME=1
        If DISCONT=1
#         "Utilisation discontinue du nom de groupe interdite. Code déjà utilisé en ligne "
          GMESSAGE=mess(282,123,1)-num$(I+1)
          GRPERR=1
          Break 1
        Endif
      Endif
      If [M:AWE2]GROUPE(I)<>VALEUR and
&     left$([M:AWE2]GRPCHP(I),instr(1,[M:AWE2]GRPCHP(I),"~"))<>left$([M:AWE2]GRPCHP(nolign-1),instr(1,[M:AWE2]GRPCHP(nolign-1),"~"))
        If SAMENAME=1 and I<nolign-1
#         "Utilisation discontinue du nom de groupe interdite. Discontinuité crée en ligne "
          GMESSAGE=mess(283,123,1)-num$(I+1)
          GRPERR=1
          Break 1
        Endif
        SAMENAME=0
        If I>nolign-1 : DISCONT=1 : Endif
        If [M:AWE2]GROUPE(I)=[M:AWE2]GROUPE(nolign-1)
          If I<nolign-1
            NAMEBEFORE=1
          Else
            If NAMEBEFORE=1
#             "Utilisation discontinue du nom de groupe interdite. Discontinuité crée en ligne "
              GMESSAGE=mess(283,123,1)-num$(I+1)
              GRPERR=1
              Break 1
            Endif
          Endif
        Endif
      Endif
    Endif
  Next I

Else
# On vérifie que le nom de groupe n'est pas déjà pris
#       - par un bloc de cardinalité différente
#       - par un bloc "discontinu"
#       - qu'on ne crée pas une "discontinuité"
  For I=0 To [M]NBLIG-1
    If I<>nolign-1
      If [M:AWE2]GROUPE(I)=VALEUR and [M:AWE2]DIME(I)<>[M:AWE2]DIME(nolign-1)
        GMESSAGE=mess(272,123,1)-num$(I+1)   : #"Code déjà existant avec une dimension différente en ligne"
        GRPERR=1
        Break 1
      Endif
      If [M:AWE2]GROUPE(I)=VALEUR
        SAMENAME=1
        If DISCONT=1
#         "Utilisation discontinue du nom de groupe interdite. Code déjà utilisé en ligne "
          GMESSAGE=mess(282,123,1)-num$(I+1)
          GRPERR=1
          Break 1
        Endif
      Endif
      If [M:AWE2]GROUPE(I)<>VALEUR and [M:AWE2]GROUPE(I)<>[M:AWE2]GROUPE(nolign-1)
        If SAMENAME=1 and I<nolign-1
#         "Utilisation discontinue du nom de groupe interdite. Discontinuité crée en ligne "
          GMESSAGE=mess(283,123,1)-num$(I+1)
          GRPERR=1
          Break 1
        Endif
        SAMENAME=0
        If I>nolign-1 : DISCONT=1 : Endif
        If [M:AWE2]GROUPE(I)=[M:AWE2]GROUPE(nolign-1)
          If I<nolign-1
            NAMEBEFORE=1
          Else
            If NAMEBEFORE=1
#             "Utilisation discontinue du nom de groupe interdite. Discontinuité crée en ligne "
              GMESSAGE=mess(283,123,1)-num$(I+1)
              GRPERR=1
              Break 1
            Endif
          Endif
        Endif
      Endif
    Endif
  Next I
Endif

If GRPERR<>0 : mkstat=2 : End : Endif


# On applique le renommage à tous les champs du groupe dans les objets
# On le propose dans les sous-programmes

Local Integer OKT : OKT=2
If [M]TYPOBJ<>1
  Call OUINON(mess(273,123,1),OKT) From GESECRAN : # Appliquer le nouveau nom à tous les champs du groupe ?
Endif
If OKT=2
  For I=0 To [M]NBLIG-1
    If I<>nolign-1 and (([M]TYPOBJ<>1 and [M:AWE2]GROUPE(I)=[M:AWE2]GROUPE(nolign-1)) or ([M]TYPOBJ=1 and
&        left$([M:AWE2]GRPCHP(I),instr(1,[M:AWE2]GRPCHP(I),"~"))=left$([M:AWE2]GRPCHP(nolign-1),instr(1,[M:AWE2]GRPCHP(nolign-1),"~"))))
      [M:AWE2]GROUPE(I)=VALEUR
      Affzo [M:AWE2]GROUPE(I)
    Endif
  Next I
Endif
End

Subprog C_LONG(VALEUR)
Variable Decimal VALEUR
End


