Subprog AP_INVISIBLE(VALEUR)
Variable Integer VALEUR
If dim(ISNEW)>0
  Local Integer ISINVIS
  If VALEUR=2 : ISINVIS=1 : Endif
  Gosub CHMAPOBJ
  Kill ISNEW
  Affzo [M:AWE2]5
Endif
End

Subprog AP_SUBPRG(VALEUR)
