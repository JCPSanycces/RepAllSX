  VALEUR=1
  Raz [M]VALMAX(nolign-1),MAXINCLU(nolign-1)
  Affzo [M]VALMAX(nolign-1),MAXINCLU(nolign-1)
  mkstat=1
Endif
End

Subprog AM_AUTMAX(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
  Raz [M]VALMAX(nolign-1),MAXINCLU(nolign-1)
  Affzo [M]VALMAX(nolign-1),MAXINCLU(nolign-1)
Endif
End

