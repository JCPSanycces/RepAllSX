######################################################################################
Subprog B2_NBLIG
# Renommer groupe
Local Char NAM(100),GRLOC(50)
NAM=[M:AWE2]GROUPE(nolign-1)
GRLOC=left$([M:AWE2]GRPCHP(nolign-1),instr(1,[M:AWE2]GRPCHP(nolign-1),"~")-1)
Local Integer I
For I=0 To [M]NBLIG-1
  If left$([M:AWE2]GRPCHP(I),instr(1,[M:AWE2]GRPCHP(I),"~")-1)=GRLOC
    [M:AWE2]GROUPE(I)=NAM
  Endif
Next I
Affzo [M:AWE2]
End

Subprog B3_NBLIG
# Déselectionner groupe
NAM=[M:AWE2]GROUPE(nolign-1)
Local Integer I
For I=0 To [M]NBLIG-1
  If [M:AWE2]GROUPE(I)=NAM
    [M:AWE2]SELECT(I)=1
  Endif
Next I
Affzo [M:AWE2]
End

Subprog B4_NBLIG
# Sélectionner groupe
NAM=[M:AWE2]GROUPE(nolign-1)
Local Integer I
For I=0 To [M]NBLIG-1
  If [M:AWE2]GROUPE(I)=NAM
    [M:AWE2]SELECT(I)=2
  Endif
Next I
Affzo [M:AWE2]
End


