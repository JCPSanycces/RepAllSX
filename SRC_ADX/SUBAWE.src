Subprog AM_PUBLI(VALEUR)
Variable Char    VALEUR()

If VALEUR="" : End : Endif
Local File AWEBSERVIC [A_WE]
Read [A_WE]AWE1=VALEUR
If fstat=0
  If dim(ISNEW)>0
    Kill ISNEW
  Endif
Else
  Global Integer ISNEW
Endif

End


