Subprog C_SELECT(VALEUR)
Variable Integer VALEUR

# Désélection d'un champ de contrôle de tableau interdite

If VALEUR=1 and [M:AWE2]PBASTAB(nolign-1)=2 and [M:AWE2]DIME(nolign-1)<=1
  Infbox(mess(285,123,1))
  VALEUR=2
Endif
End


