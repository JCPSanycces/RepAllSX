#<AdxTL>@(#)6.0.0.0 $Revision$
###############################################################
## SUBAWE    Génération du traitement des WEB services       ##
###############################################################
###############################################################

Raz GPILOBJ , GNBMASKOUV
Call OBJET("AWE",GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case ACTION
  When "AVANT_CHOI" : Gosub AVANTCH
  When "LIENS"      : Gosub LIENS
  When "RAZCRE"     : Gosub LIENS     : # Bug 70112     CC - 28/12/2010
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEACT"     : Gosub EXEACT
  When "STATUT"     : Gosub VALGLOB
  When "EXEBOUT"    : Gosub BOUTON
  When "AB1_SUBPRG" : Global Integer GWEBTUNSP
  When "BB1_SUBPRG" : Kill GWEBTUNSP
  When "AP_ANNULE"  : Gosub SUPWS
  When "CREATION"   : Gosub CREATION
  When "MODIF"      : Gosub MODIF
  When "ANNULE"     : Gosub ANNULE
  When "FILGAUCHE"  : Gosub FILGAUCHE
Endcase
Return

$VERGEN
Local Char  VERGEN
VERGEN="4.00"
Return



$FILGAUCHE
Case currbox
 When "GAU_CHE1"
  FILGAUSUP = '[F:AWE]TYPOBJ = 1'
 When "GAU_CHE2"
  FILGAUSUP = '[F:AWE]TYPOBJ = 2'
 When "GAU_CHE"
  FILGAUSUP = ''
Endcase
Return

$VALGLOB
If BOUT="6"
# Voulez vous republier tous les web services ?
  Local Integer PGLO
  Call AVERTIR(mess(217,124,1),PGLO) From GESECRAN
  If PGLO=2
    Call PUBLIALLWS(nomap,1)
  Endif
Elsif BOUT="7"
# Voulez vous charger la table avec les web services définis sur disque ?
  Local Integer PGLO
  Call AVERTIR(mess(219,124,1),PGLO) From GESECRAN
  If PGLO=2
    Call RECUPWS(nomap)
  Endif
Endif
Return


$EXEACT
If REPONSE=GSTANEW
  Global Integer ISNEW
  Actzo 10,20,30
Endif
Return

$SETBOUT
If !CLECUR or REP<>"" or !VERROU
 Call VIREBOUT(CHMEN,"6") From GOBJET
 Call VIREBOUT(CHAINE,"abc") From GOBJET
Else
 CHMEN += "6" : # Génération totale
Endif
Local Integer OKR
Call DECRECUP(nomap,OKR)
If OKR=1
 CHMEN += "7" : # Propose récupération des web services
Else
 Call VIREBOUT(CHMEN,"7") From GOBJET
Endif
Return

$CREATION
$MODIF
Call MAJTEXTRA([M]LIBW,"AWEBSERVIC","LIBW",[M:AWE0]PUBLI,"") From ATEXTRA

If clalev([F:AWY])=0 : Local File AWEBSERDES [AWY] : Endif
Local Integer IMAP
Local Char CH1(50),CH2(50)

If dim(ABFIC)<0 : Local Char ABFIC : Endif
Local Char SAVABFIC : SAVABFIC=ABFIC
ABFIC="AWY"

For IMAP=0 To [M:AWE2]NBLIG-1
  If instr(1,[M:AWE2]GRPCHP(IMAP),"~")<>0
    CH1=left$([M:AWE2]GRPCHP(IMAP),instr(1,[M:AWE2]GRPCHP(IMAP),"~")-1)
    CH2=right$([M:AWE2]GRPCHP(IMAP),instr(1,[M:AWE2]GRPCHP(IMAP),"~")+1)
  Else
    CH1=""
    CH2=[M:AWE2]GRPCHP(IMAP)
  Endif
  Read [AWY]AWY1=[M:AWE0]PUBLI;CH1;CH2
  If fstat=0
      [F:AWY]SELECT=[M:AWE2]SELECT(IMAP)
      [F:AWY]GROUPE=[M:AWE2]GROUPE(IMAP)
      [F:AWY]CHAMP=[M:AWE2]CHAMP(IMAP)
      [F:AWY]LONCHP=[M:AWE2]LONG(IMAP)
      [F:AWY]AUTMIN=[M:AWE2]AUTMIN(IMAP)
      [F:AWY]VALMIN=[M:AWE2]VALMIN(IMAP)
      [F:AWY]MININCLU=[M:AWE2]MININCLU(IMAP)
      [F:AWY]AUTMAX=[M:AWE2]AUTMAX(IMAP)
      [F:AWY]VALMAX=[M:AWE2]VALMAX(IMAP)
      [F:AWY]MAXINCLU=[M:AWE2]MAXINCLU(IMAP)
      [F:AWY]TOTALDIGIT=[M:AWE2]TOTALDIGIT(IMAP)
      [F:AWY]FRACTIONDIG=[M:AWE2]FRACTIONDIG(IMAP)
      [F:AWY]PATTERN=[M:AWE2]PATTERN(IMAP)
      [F:AWY]NOLIB=[M:AWE2]NOLIB(IMAP)
      [F:AWY]IDX=IMAP+1
      Gosub INIMOD From GOBJSUB
      Rewrite [AWY]
  Else
      [F:AWY]PUBLI=[M:AWE0]PUBLI
      [F:AWY]SELECT=[M:AWE2]SELECT(IMAP)
      [F:AWY]GROUPE=[M:AWE2]GROUPE(IMAP)
      [F:AWY]CHAMP=[M:AWE2]CHAMP(IMAP)
      [F:AWY]LONCHP=[M:AWE2]LONG(IMAP)
      [F:AWY]AUTMIN=[M:AWE2]AUTMIN(IMAP)
      [F:AWY]VALMIN=[M:AWE2]VALMIN(IMAP)
      [F:AWY]MININCLU=[M:AWE2]MININCLU(IMAP)
      [F:AWY]AUTMAX=[M:AWE2]AUTMAX(IMAP)
      [F:AWY]VALMAX=[M:AWE2]VALMAX(IMAP)
      [F:AWY]MAXINCLU=[M:AWE2]MAXINCLU(IMAP)
      [F:AWY]TOTALDIGIT=[M:AWE2]TOTALDIGIT(IMAP)
      [F:AWY]FRACTIONDIG=[M:AWE2]FRACTIONDIG(IMAP)
      [F:AWY]PATTERN=[M:AWE2]PATTERN(IMAP)
      [F:AWY]NOLIB=[M:AWE2]NOLIB(IMAP)
      If instr(1,[M:AWE2]GRPCHP(IMAP),"~")<>0
        [F:AWY]GRP=left$([M:AWE2]GRPCHP(IMAP),instr(1,[M:AWE2]GRPCHP(IMAP),"~")-1)
        [F:AWY]CHP=right$([M:AWE2]GRPCHP(IMAP),instr(1,[M:AWE2]GRPCHP(IMAP),"~")+1)
      Else
        [F:AWY]CHP=[M:AWE2]GRPCHP(IMAP)
      Endif
      [F:AWY]IDX=IMAP+1
      Gosub INICRE From GOBJSUB
      Write [AWY]
  Endif
Next IMAP
ABFIC=SAVABFIC
Return

$ANNULE
Delete [AXX] Where CODFIC="AWEBSERVIC" & ZONE="LIBW" & IDENT1=[M:AWE0]PUBLI
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK
Endif
If clalev([F:AWY])=0 : Local File AWEBSERDES [AWY] : Endif
Delete [AWY] Where PUBLI=[M:AWE0]PUBLI
Return



$SUPWS
#   Suppression de [M:AWE0]PUBLI.xml
#   Suppression du programme wrapper (src et adx)
Local Char NAMEFIC1(250),PROGWR(40),WDOS(GLONADS),NOMOBJ(GLONAWE)
Local Integer IOK
#If [M]TYPOBJ=2
#  PROGWR="WJ"+[M:AWE0]PUBLI
#Else
#  PROGWR="WJ"+[M]OBJET+[M]VARIANTE
#  If [M]INVISIBLE=2 : PROGWR+="_I" : Endif
#ENDIF
WDOS = nomap
NOMOBJ = [M:AWE0]PUBLI
Gosub PROG_SUPWS

Raz [M]
Affzo [M]

If [M]TYPOBJ=2
  If clalev([F:ASU])=0 : Local File ASUBPROG [ASU] : Endif
  Read [ASU]ASU0=[M:AWE1]PRG;[M]SUBPRG
  If fstat=0
    [F:ASU]PUBLINAM=""
    Trbegin [ASU]
    Rewrite [ASU]
    Commit
  Endif
Endif
Return

$PROG_SUPWS
PROGWR="WJ"+NOMOBJ
NAMEFIC1=filpath("TRT",PROGWR,"src",WDOS)
Call EFFACE(NAMEFIC1,IOK) From ORDSYS
Call EFFACE_ADX("",WDOS,PROGWR,IOK) From ORDSYS
Call NAMEFIC(WDOS,"WEBS","",NOMOBJ,NAMEFIC1) From INTRUTILA
Call EFFACE(NAMEFIC1,IOK) From ORDSYS
PROGWR="WK"+NOMOBJ
NAMEFIC1=filpath("TRT",PROGWR,"src",WDOS)
If filinfo(NAMEFIC1,7)>0
  Call EFFACE(NAMEFIC1,IOK) From ORDSYS
  Call EFFACE_ADX("",WDOS,PROGWR,IOK) From ORDSYS
Endif
Return

$LIENS
Diszo [M:AWE1]NOMPG
If dim(GSPG_WEB)=1
  [M:AWE0]PUBLI=""
  [M]TYPOBJ=2
  [M:AWE1]PRG=GPG_WEB
  [M]SUBPRG=GSPG_WEB
  Actzo [M:AWE0]PUBLI
  If clalev([F:A_WE])=0 : Local File AWEBSERVIC [A_WE] : Endif
  Filter [A_WE] Where PRG=GPG_WEB and SUBPRG=GSPG_WEB
  Effzo [M:AWE1]40
  Effzo [M:AWE1]20
  For [A_WE]
    [M:AWE0]PUBLI=[F:A_WE]PUBLI
    [M]NOMPG="WJ"+[F:A_WE]PUBLI
    [M]DATPUB=[F:A_WE]DATPUB
    [M]USERP=[F:A_WE]USERP
 #   Diszo PUBLI
  Next
  Filter [A_WE]

  Affzo [AWE0]TYPOBJ
  Affzo [AWE1]PRG,SUBPRG
  Affzo [AWE1]NOMPG,DATPUB,USERP
  Diszo [AWE0]TYPOBJ
  Diszo [M:AWE1]20,30
  SUIZON="PUBLI"
  Kill GPG_WEB,GSPG_WEB
Else
  Actzo [AWE0]TYPOBJ
  Actzo [M:AWE1]20,30
Endif

If [M:AWE0]PUBLI<>""
 [M]NOMPG="WJ"+[M:AWE0]PUBLI
 Diszo [AWE1]20,30
 Actzo [M:AWE0]LIBW
Endif
If [M]TYPOBJ=1
  Local Integer ISINVIS
  If [M]INVISIBLE=2 : ISINVIS=1 : Endif
  Gosub CHMAPOBJ
  Affzo [M:AWE2]5
Endif
If [M]TYPOBJ=2
  Local Char SUBPRGTT : SUBPRGTT=[M]SUBPRG
  Gosub CHMAPSPG
  Affzo [M:AWE2]5
Endif

Return



$CHMAPSPG
  Raz [M:AWE2]
  If clalev([F:ASU])=0 : Local File ASUBPROG  [ASU] : Endif
  If clalev([F:ASP])=0 : Local File ASUBPROGD [ASP] : Endif
  Local Integer I
  Read [ASU]ASU0=[M:AWE1]PRG;SUBPRGTT
  If fstat=0
    I =0
    For [ASP] Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
      [M:AWE2]CHAMP(I)=[F:ASP]PARAM
      [M:AWE2]GRPCHP(I)=[F:ASP]PARAM
      [M:AWE2]NOTEX(I)=[F:ASP]INTITPAR
      [M:AWE2]TYPPAR(I)=[F:ASP]TYPPAR
      [M:AWE2]DIME(I)=[F:ASP]DIME
      [M:AWE2]NIVEAU(I)=1
      [M:AWE2]TYPFCT(I)=[F:ASP]ADRVAL
      [M:AWE2]SELECT(I)=2
      [M:AWE2]GROUPE(I)=[F:ASP]PUBLI
      [M:AWE2]LONG(I)=[F:ASP]LONG
      Call TEXTE([M:AWE2]NOTEX(I),[M:AWE2]INTIT(I)) From OBJDIV
      I += 1
    Next ASP
    [M:AWE2]NBLIG=[F:ASU]NBRPAR
  Endif
#   On remappe avec la table des web services
  If clalev([F:AWY])=0 : Local File AWEBSERDES [AWY] : Endif
  Local Integer IMAP,NGRP,IGRM, REINIT, ICOU
  If [M:AWE0]PUBLI<>""
   For IMAP=0 To [M:AWE2]NBLIG-1
    Read [AWY]AWY1=[M:AWE0]PUBLI;"";[M:AWE2]GRPCHP(IMAP)
    If fstat=0
      [M:AWE2]SELECT(IMAP)=[F:AWY]SELECT
      [M:AWE2]GROUPE(IMAP)=[F:AWY]GROUPE
# on initialise NGRP à la valeur max si il y a déjà des mappings
      If left$([M:AWE2]GROUPE(IMAP),3)="GRP"
        REINIT=1
        IGRM=val(right$([M:AWE2]GROUPE(IMAP),4))
        If IGRM>NGRP : NGRP=IGRM : Endif
      Endif
      [M:AWE2]CHAMP(IMAP)=[F:AWY]CHAMP
      [M:AWE2]LONG(IMAP)=[F:AWY]LONCHP

      [M:AWE2]AUTMIN(IMAP)=[F:AWY]AUTMIN
      [M:AWE2]VALMIN(IMAP)=[F:AWY]VALMIN
      [M:AWE2]MININCLU(IMAP)=[F:AWY]MININCLU
      [M:AWE2]AUTMAX(IMAP)=[F:AWY]AUTMAX
      [M:AWE2]VALMAX(IMAP)=[F:AWY]VALMAX
      [M:AWE2]MAXINCLU(IMAP)=[F:AWY]MAXINCLU

      [M:AWE2]TOTALDIGIT(IMAP)=[F:AWY]TOTALDIGIT
      [M:AWE2]FRACTIONDIG(IMAP)=[F:AWY]FRACTIONDIG
      [M:AWE2]PATTERN(IMAP)=[F:AWY]PATTERN
      [M:AWE2]NOLIB(IMAP)=[F:AWY]NOLIB
    Else
      If dim(GENGLOB)<0
        Global Integer DEGENREG : DEGENREG=1 :#  pour forcer en degrise bouton enreg
      Else
        GENGLOB=1
      Endif
    Endif
   Next IMAP
  Else
   If dim(GENGLOB)<0
     Global Integer DEGENREG : DEGENREG=2 :#  On met DEGENREG à 2 si on est en création - bug 79959  CC : 13/02/2012
   Else
     GENGLOB=1
   Endif
  Endif

#  On initialise les groupes si ils sont à vide
  If REINIT=0   : # (cas de la première publication)
    For IMAP=0 To [M:AWE2]NBLIG-1
      If [M:AWE2]GROUPE(IMAP)=""
        If IMAP=0 or [M:AWE2]DIME(IMAP)<>[M:AWE2]DIME(IMAP-1)
          NGRP+=1
        Endif
        [M:AWE2]GROUPE(IMAP)="GRP"+num$(NGRP)
      Endif
    Next IMAP
  Else  : # publication après modification
    For IMAP=0 To [M:AWE2]NBLIG-1
      If [M:AWE2]GROUPE(IMAP)=""
        If ICOU<>IMAP-1 or [M:AWE2]DIME(IMAP)<>[M:AWE2]DIME(IMAP-1)
          NGRP+=1
        Endif
        ICOU=IMAP
        [M:AWE2]GROUPE(IMAP)="GRP"+num$(NGRP)
      Endif
    Next IMAP
  Endif
Return

$CHMAPOBJ
  Raz [M:AWE2]
  Local Char HORDAT(14),ADOSS
  Call ENVVAR(HORDAT) From INTRUTILA
  If dim(GENGLOB)>0 :
   If dim(DOSSIER)>0
    ADOSS=DOSSIER
   Else
    ADOSS=nomap
   Endif
  Endif
  Call CHARGOBJ("MASK",[M:AWE1]OBJET,[M:AWE1]VARIANTE,ADOSS,ISINVIS,[M:AWE0]PUBLI) From AGENWEB
#   On remappe avec la table des web services
  If clalev([F:AWY])=0 : Local File AWEBSERDES [AWY] : Endif
  Local Integer IMAP
  For IMAP=0 To [M:AWE2]NBLIG-1
    Read [AWY]AWY1=[M:AWE0]PUBLI;left$([M:AWE2]GRPCHP(IMAP),instr(1,[M:AWE2]GRPCHP(IMAP),"~")-1);
&                  right$([M:AWE2]GRPCHP(IMAP),instr(1,[M:AWE2]GRPCHP(IMAP),"~")+1)
    If fstat=0
      [M:AWE2]SELECT(IMAP)=[F:AWY]SELECT
      [M:AWE2]GROUPE(IMAP)=[F:AWY]GROUPE
      [M:AWE2]CHAMP(IMAP)=[F:AWY]CHAMP

      [M:AWE2]AUTMIN(IMAP)=[F:AWY]AUTMIN
      [M:AWE2]VALMIN(IMAP)=[F:AWY]VALMIN
      [M:AWE2]MININCLU(IMAP)=[F:AWY]MININCLU
      [M:AWE2]AUTMAX(IMAP)=[F:AWY]AUTMAX
      [M:AWE2]VALMAX(IMAP)=[F:AWY]VALMAX
      [M:AWE2]MAXINCLU(IMAP)=[F:AWY]MAXINCLU

      [M:AWE2]TOTALDIGIT(IMAP)=[F:AWY]TOTALDIGIT
      [M:AWE2]FRACTIONDIG(IMAP)=[F:AWY]FRACTIONDIG
      [M:AWE2]PATTERN(IMAP)=[F:AWY]PATTERN
   Else
      If dim(GENGLOB)<0
        Global Integer DEGENREG : DEGENREG=1 :#  pour forcer en degrise bouton enreg
      Else
        GENGLOB=1
        [F:AWY]PUBLI=[M:AWE0]PUBLI
        [F:AWY]SELECT=[M:AWE2]SELECT(IMAP)
        [F:AWY]GROUPE=[M:AWE2]GROUPE(IMAP)
        [F:AWY]CHAMP=[M:AWE2]CHAMP(IMAP)
        [F:AWY]LONCHP=[M:AWE2]LONG(IMAP)
        [F:AWY]AUTMIN=[M:AWE2]AUTMIN(IMAP)
        [F:AWY]VALMIN=[M:AWE2]VALMIN(IMAP)
        [F:AWY]MININCLU=[M:AWE2]MININCLU(IMAP)
        [F:AWY]AUTMAX=[M:AWE2]AUTMAX(IMAP)
        [F:AWY]VALMAX=[M:AWE2]VALMAX(IMAP)
        [F:AWY]MAXINCLU=[M:AWE2]MAXINCLU(IMAP)
        [F:AWY]TOTALDIGIT=[M:AWE2]TOTALDIGIT(IMAP)
        [F:AWY]FRACTIONDIG=[M:AWE2]FRACTIONDIG(IMAP)
        [F:AWY]PATTERN=[M:AWE2]PATTERN(IMAP)
        [F:AWY]NOLIB=[M:AWE2]NOLIB(IMAP)
        If instr(1,[M:AWE2]GRPCHP(IMAP),"~")<>0
          [F:AWY]GRP=left$([M:AWE2]GRPCHP(IMAP),instr(1,[M:AWE2]GRPCHP(IMAP),"~")-1)
          [F:AWY]CHP=right$([M:AWE2]GRPCHP(IMAP),instr(1,[M:AWE2]GRPCHP(IMAP),"~")+1)
        Else
          [F:AWY]CHP=[M:AWE2]GRPCHP(IMAP)
        Endif
        [F:AWY]IDX=IMAP+1
        If dim(ABFIC)<0 : Local Char ABFIC : Endif
        Local Char SAVABFIC : SAVABFIC=ABFIC
        ABFIC="AWY"
        Gosub INICRE From GOBJSUB
        Write [AWY]
        ABFIC=SAVABFIC
      Endif
   Endif
  Next IMAP
Return


$AVANTCH
If dim(DEGENREG)>0
  If DEGENREG=1
    Gosub ENTRE_MODIF From GOBJSUB
  Endif
  Gosub SETBOUT From GOBJSUB
  Kill DEGENREG
Endif
Return

$BOUTON
If BOUT="a"
  Call PUBLIWS(nomap,[M:AWE0]PUBLI)
  Local Integer TYP1,INVIS1
  Local Char OBJ1,VARIA1,PRG1,SPRG1
  Call INFOWS(nomap,[M:AWE0]PUBLI,TYP1,OBJ1,VARIA1,INVIS1,PRG1,SPRG1,[M]USERP,[M]DATPUB)
  [M]NOMPG="WJ"+[M:AWE0]PUBLI
  Affzo [M:AWE1]USERP,DATPUB,NOMPG
Endif
If BOUT="b" :   # Visu XML

  # X3-82663.so Oct 1st 2018
  #  Local Char URL(200),RETOUR(200)
  #  URL=GVIRTDIR+"/"+nomap+"/GEN/ALL/WEBS/"+[M:AWE0]PUBLI+".xml"
  #  URL=ctrans(URL,"\","/")
  #
  #  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
  #&                           "UILocalDir="+ chr$(1) +"HTTP",
  #&                           "UILocalFile="+ chr$(1) +URL ,
  #&                           "UIAdxPubSubFile="+ chr$(1) + "1"
  # X3-82663.eo Oct 1st 2018

  Call DOWNLOAD_FILE("xml") # X3-82663 Oct 1st 2018

Endif
If BOUT="c" :   # Visu XSD

  # X3-82663.so Oct 1st 2018
  #  Local Char URL(200),RETOUR(200)
  #  URL=GVIRTDIR+"/"+nomap+"/GEN/ALL/WEBS/"+[M:AWE0]PUBLI+".xsd"
  #  URL=ctrans(URL,"\","/")
  #
  #  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
  #&                           "UILocalDir="+ chr$(1) +"HTTP",
  #&                           "UILocalFile="+ chr$(1) +URL ,
  #&                           "UIAdxPubSubFile="+ chr$(1) + "1"
  # X3-82663.eo Oct 1st 2018

  Call DOWNLOAD_FILE("xsd") # X3-82663 Oct 1st 2018

Endif
Return

#**
#* Download the publication xml or xsd file to the client
#*
#* @param FILETYPE : Extension of the file to download
#*!
Subprog DOWNLOAD_FILE(FILETYPE)
Value Char FILETYPE

  Local Char PATH(240), EXPORT_FILE_NAME(10), FULL_FILE_NAME(14)
  Local Integer STAT, WCLI_OK
  Raz EXPORT_FILE_NAME, FULL_FILE_NAME, PATH, STAT, WCLI_OK

  EXPORT_FILE_NAME = [M:AWE0]PUBLI #Mandatory field

  # Get path to file, copy it to the client and provide feedback
  PATH = filpath(nomap+"/GEN/ALL/WEBS/",EXPORT_FILE_NAME,FILETYPE,"X3_PUB")

  # Does the file exist and have contents?
  If filinfo(PATH,7) > 0

    FULL_FILE_NAME = EXPORT_FILE_NAME + "." + FILETYPE

    # COPCLI doesn't support copying a file that doesn't exist
    Call COPCLI(PATH,FULL_FILE_NAME,STAT) From ORDSYS

    # Check for SDATA transfer result: 0 = Success, 1 = Warning, All Else = Error
    Case STAT
      When 0: # Do nothing, we have no problem, file will download
      When 1: Call WARNING(mess(164,141,1),WCLI_OK) From GESECRAN
      When Default: Call ERREUR(mess(164,141,1)) From GESECRAN
    Endcase

  Else

    ### FILE DOES NOT EXIST ###
    If [M:AWE1]DATPUB = ""
      Call ERREUR(EXPORT_FILE_NAME + "." + FILETYPE -mess(87,9005,1)+".") From GESECRAN
    Else
      # The file doesn't exist, but it is marked published
      Call ERREUR(mess(88,9005,1) + ": " + EXPORT_FILE_NAME + "." + FILETYPE ) From GESECRAN
    Endif

  Endif

End

Subprog INFOWS(DOSS,PUBLI,TYP,OBJET,VARIANT,INVIS,PRG,SPRG,USERP,DATPUB)
Value Char DOSS
Value Char PUBLI
Variable Integer TYP
Variable Char OBJET
Variable Char VARIANT
Variable Integer INVIS
Variable Char PRG
Variable Char SPRG
Variable Char USERP
Variable Char DATPUB

Raz TYP,OBJET,VARIANT,INVIS,PRG,SPRG,USERP,DATPUB
Local Char DOSSIER : DOSSIER=DOSS
If DOSSIER="" : DOSSIER=nomap : Endif
Local File =DOSSIER+".AWEBSERVIC" [A_WE]
Read [A_WE]AWE1=PUBLI
If fstat<>0 : End : Endif
TYP=[F:A_WE]TYPOBJ
OBJET=[F:A_WE]OBJET
VARIANT=[F:A_WE]VARIANTE
INVIS=[F:A_WE]INVISIBLE
PRG=[F:A_WE]PRG
SUBPRG=[F:A_WE]SUBPRG
USERP=[F:A_WE]USERP
DATPUB=[F:A_WE]DATPUB
End

Subprog PUBLIWS(DOSS,PUBLI)
Value Char DOSS
Value Char PUBLI
Local Char DOSSIER : DOSSIER=DOSS
If DOSSIER="" : DOSSIER=nomap : Endif
Local File =DOSSIER+".AWEBSERDES" [AWY]
Local File =DOSSIER+".ASUBPROG"  [ASU]
Local File =DOSSIER+".ASUBPROGD" [ASP]

Local File =DOSSIER+".AWEBSERVIC" [A_WE]
Read [A_WE]AWE1=PUBLI
If fstat<>0
 # Web service non publié sur le dossier
 Call ECR_TRACE(PUBLI-":"-mess(216,124,1)-":"-DOSSIER,1) From GESECRAN
 End
Endif

#  Sauve les masque [AWEn]  existants et les valeurs qui vont être écrasées

If clalev([M:AWE0])>0
  Local Mask AWE0 [SAW0] : [SAW0]=[AWE0] : Raz [M:AWE0]
Else
  Local Mask AWE0 [AWE0]
Endif

If clalev([M:AWE1])>0
  Local Mask AWE1 [SAW1] : [SAW1]=[AWE1] : Raz [M:AWE1]
Else
  Local Mask AWE1 [AWE1]
Endif

If clalev([M:AWE2])>0
  Local Mask AWE2 [SAW2] : [SAW2]=[AWE2] : Raz [M:AWE2]
Else
  Local Mask AWE2 [AWE2]
Endif


Local Char SUBPRGTT
Local Integer ISINVIS
Global Integer GENGLOB

Local Char HORDAT(14)
Call ENVVAR(HORDAT) From INTRUTILA
Local Integer SAVLOCAL
If adxlog=0 : SAVLOCAL=1 : Trbegin[A_WE], [AWY] : Endif

[M:AWE0]PUBLI=PUBLI
If [F:A_WE]TYPOBJ=1
    [M:AWE1]OBJET=[F:A_WE]OBJET
    [M:AWE1]VARIANTE=[F:A_WE]VARIANTE
    ISINVIS=([F:A_WE]INVISIBLE=2)
    Gosub CHMAPOBJ From SUBAWE
    If GENGLOB=1
# Mapping incorrect entre les descriptions. Il faut forcer une mise à jour du Web service
      Call ECR_TRACE(mess(290,123,1)-[F:A_WE]OBJET-[F:A_WE]VARIANTE-" :"-[F:A_WE]PUBLI,1) From GESECRAN
      GENGLOB=0
    Endif
 #   Call ECR_TRACE(mess(204,133,1)-[F:A_WE]OBJET-[F:A_WE]VARIANTE-" :"-[F:A_WE]PUBLI,0) From GESECRAN
    Call CREOBJ([F:A_WE]OBJET,[F:A_WE]VARIANTE,DOSSIER,([F:A_WE]INVISIBLE=2),PUBLI,0,HORDAT) From AGENWEB
Else
 #   Call ECR_TRACE(mess(215,133,1)-[F:A_WE]PRG-[F:A_WE]SUBPRG-" :"-[F:A_WE]PUBLI,0) From GESECRAN
    [M:AWE1]PRG  =  [F:A_WE]PRG
    SUBPRGTT     =  [F:A_WE]SUBPRG
    Gosub CHMAPSPG From SUBAWE
    If GENGLOB=1
# Mapping incorrect entre les descriptions. Il faut forcer une mise à jour du Web service
      Call ECR_TRACE(mess(290,123,1)-[F:A_WE]PRG-[F:A_WE]SUBPRG-" :"-[F:A_WE]PUBLI,1) From GESECRAN
      GENGLOB=0
    Endif
    Call CRESP(DOSSIER,[F:A_WE]PRG,[F:A_WE]SUBPRG,[F:A_WE]PUBLI,0,HORDAT) From AGENWEB
Endif
[F:A_WE]DATPUB=HORDAT
[F:A_WE]USERP=GUSER
Gosub VERGEN From AGENWEB
[F:A_WE]VERGEN=VERGEN
Rewrite [F:A_WE]
If SAVLOCAL=1 : Commit : Endif

Kill GENGLOB
# Restaure contexte
If clalev([M:SAW0])>0 : [AWE0]=[SAW0] : Endif
If clalev([M:SAW1])>0 : [AWE1]=[SAW1] : Endif
If clalev([M:SAW2])>0 : [AWE2]=[SAW2] : Endif

End



Subprog PUBLIALLWS(DOSS,READTRACE)
Value Char DOSS
Value Integer READTRACE

Local Char DOSSIER : DOSSIER=DOSS
If DOSSIER="" : DOSSIER=nomap : Endif
Local File =DOSSIER+".AWEBSERVIC" [B_WE]
Local File =DOSSIER+".AWEBSERVIC" [A_WX]
Local File =DOSSIER+".AWEBSERDES" [AWY]
Local File =DOSSIER+".ASUBPROG"  [ASU]
Local File =DOSSIER+".ASUBPROGD" [ASP]

Local Integer OPENTRACE
If GTRACE=""
  Call OUVRE_TRACE(mess(218,124,1)+"    "-DOSSIER) From LECFIC
  OPENTRACE=1
Endif
Local Char HORDAT(14)
Call ENVVAR(HORDAT) From INTRUTILA

#  Sauve les masque [AWEn]  existants et les valeurs qui vont être écrasées

If clalev([M:AWE0])>0
  Local Mask AWE0 [SAW0] : [SAW0]=[AWE0] : Raz [M:AWE0]
Else
  Local Mask AWE0 [AWE0]
Endif

If clalev([M:AWE1])>0
  Local Mask AWE1 [SAW1] : [SAW1]=[AWE1] : Raz [M:AWE1]
Else
  Local Mask AWE1 [AWE1]
Endif

If clalev([M:AWE2])>0
  Local Mask AWE2 [SAW2] : [SAW2]=[AWE2] : Raz [M:AWE2]
Else
  Local Mask AWE2 [AWE2]
Endif


Local Char SUBPRGTT
Local Integer ISINVIS
Global Integer GENGLOB
Local Integer SAVLOCAL
If adxlog=0 : SAVLOCAL=1 : Trbegin[A_WX], [AWY] : Endif
For [B_WE]
  [M:AWE0]PUBLI=[F:B_WE]PUBLI
  If [F:B_WE]TYPOBJ=1
    [M:AWE1]OBJET=[F:B_WE]OBJET
    [M:AWE1]VARIANTE=[F:B_WE]VARIANTE
    ISINVIS=([F:B_WE]INVISIBLE=2)
    Gosub CHMAPOBJ From SUBAWE
    If GENGLOB=1
# Mapping incorrect entre les descriptions. Il faut forcer une mise à jour du Web service
      Call ECR_TRACE(mess(290,123,1)-[F:B_WE]OBJET-[F:B_WE]VARIANTE-" :"-[F:B_WE]PUBLI,1) From GESECRAN
      GENGLOB=0
    Endif
    Call ECR_TRACE(mess(204,133,1)-[F:B_WE]OBJET-[F:B_WE]VARIANTE-" :"-[F:B_WE]PUBLI,0) From GESECRAN
    Call CREOBJ([F:B_WE]OBJET,[F:B_WE]VARIANTE,DOSSIER,([F:B_WE]INVISIBLE=2),[F:B_WE]PUBLI,0,HORDAT) From AGENWEB
  Else
    Call ECR_TRACE(mess(215,133,1)-[F:B_WE]PRG-[F:B_WE]SUBPRG-" :"-[F:B_WE]PUBLI,0) From GESECRAN
    [M:AWE1]PRG  =  [F:B_WE]PRG
    SUBPRGTT     =  [F:B_WE]SUBPRG
    Gosub CHMAPSPG From SUBAWE
    If GENGLOB=1
# Mapping incorrect entre les descriptions. Il faut forcer une mise à jour du Web service
      Call ECR_TRACE(mess(290,123,1)-[F:B_WE]PRG-[F:B_WE]SUBPRG-" :"-[F:B_WE]PUBLI,1) From GESECRAN
      GENGLOB=0
    Endif
    Call CRESP(DOSSIER,[F:B_WE]PRG,[F:B_WE]SUBPRG,[F:B_WE]PUBLI,0,HORDAT) From AGENWEB
  Endif
  Read [A_WX]AWE1=[F:B_WE]PUBLI
  [F:A_WX]DATPUB=HORDAT
  [F:A_WX]USERP=GUSER
  Rewrite [F:A_WX]
Next
If SAVLOCAL=1 : Commit : Endif


Kill GENGLOB
# Restaure contexte
If clalev([M:SAW0])>0 : [AWE0]=[SAW0] : Endif
If clalev([M:SAW1])>0 : [AWE1]=[SAW1] : Endif
If clalev([M:SAW2])>0 : [AWE2]=[SAW2] : Endif
If OPENTRACE=1 : Call FERME_TRACE From LECFIC : Endif
If READTRACE=1 : Call LEC_TRACE   From LECFIC : Endif

End



Subprog REPRISWS(DOSS)
Value Char DOSS

Local Char DOSSIER : DOSSIER=DOSS
If DOSSIER="" : DOSSIER=nomap : Endif
Local File =DOSSIER+".AWEBSERVIC" [A_WE]



End



# Gestion du masque AWE1

######################################################################################
## Etiquette ajoutée par le superviseur (écran AWE1) 15/01/2008 17:08:04 (CCORA)
######################################################################################

Subprog AP_TYPOBJ(VALEUR)
Variable Integer    VALEUR()
If VALEUR=1
  Actzo [M:AWE1]20
  Effzo [M:AWE1]30 : Diszo [M:AWE1]30
Elsif VALEUR=2
  Effzo [M:AWE1]20 : Diszo [M:AWE1]20
  Actzo [M:AWE1]30
Endif
End

Subprog AM_TYPOBJ(VALEUR)
Variable Integer VALEUR
Effzo [M:AWE1]40
End


Subprog AS_VARIANTE(VALEUR)
Variable Char    VALEUR()
If (dim([M:AWE0]TYPOBJ))>0 & [M:AWE0]TYPOBJ<>1 : mkstat=1 : End : Endif
If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
Local Integer NB
Filter [AWI] Where OBJ=[M]OBJET
For [AWI]
   NB+=1
Next
Filter [AWI]
If NB<=1 : mkstat=1 : Endif
End


Subprog C_VARIANTE(VALEUR)
Variable Char    VALEUR()
Local File AWINDOW [A_WI]
If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
If (dim([M:AWE0]TYPOBJ))>0 & [M:AWE0]TYPOBJ<>1 : End : Endif
Local Integer NB
If VALEUR=""
  Filter [AWI] Where OBJ=[M]OBJET
  For [AWI]
   NB+=1
  Next
  Filter [AWI]
  If NB>1
    GMESSAGE=mess(10,123,1)   # Zone obligatoire
    mkstat=2
    End
  Endif
Else
  Filter [AWI] Where OBJ=[M]OBJET and TRN=VALEUR
  For [AWI]
   NB+=1
  Next
  Filter [AWI]
  If NB=0
    GMESSAGE=mess(40,114,1)   : # Transaction inexistante
    mkstat=2
    End
  Elsif NB=1
    [M]LIBVAR = [F:AWI]LIBEL
    Affzo [M]LIBVAR
  Endif
Endif
End


Subprog AM_INVISIBLE(VALEUR)
Variable Integer VALEUR
# On refuse si objet/variante/invisible identique est déjà publié sous un autre nom de publication
Local File AWEBSERVIC [A_WE]
Filter [A_WE] Where OBJET=[M]OBJET and VARIANTE=[M]VARIANTE and INVISIBLE=VALEUR
For [A_WE]
  Infbox(mess(215,124,1)-[F:A_WE]PUBLI) : # Ce composant est déjà publié sous le nom :
 # mkstat=2
  Break 1
Next
Filter [A_WE]
End


Subprog C_PRG(VALEUR)
Variable Char    VALEUR()
Local Char FICHIER(250)
If VALEUR="" and [M:AWE0]TYPOBJ=2
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Endif
End


Subprog C_SUBPRG(VALEUR)
Variable Char    VALEUR()
If [M:AWE0]TYPOBJ<>2 : End : Endif
If clalev([F:ASU])=0 : Local File ASUBPROG [ASU] : Endif
Read [ASU]ASU0=[M:AWE1]PRG;VALEUR
If (fstat<>0)
  GMESSAGE=mess(71,150,1)
  mkstat=2
  End
Endif
If [F:ASU]WEBS<>2
# Sous-programme non déclaré Web service
  GMESSAGE=mess(154,150,1)
  mkstat=2
Endif

End


Subprog AM_SUBPRG(VALEUR)
Variable Char    VALEUR()
# On prévient si le Programme/sous-Programme est déjà publié sous un autre nom de publication
Local File AWEBSERVIC [A_WE]
Filter [A_WE] Where PRG=[M:AWE1]PRG and SUBPRG=VALEUR
For [A_WE]
  Infbox(mess(215,124,1)-[F:A_WE]PUBLI) : # Ce composant est déjà publié sous le nom :
#  mkstat=2
  Break 1
Next
Filter [A_WE]
End


# ----------------------------------------------------------------------------------------------------
#
#      Programme de reprise des Web services dans la table AWEBSERVIC

Subprog RECUPWS(DOSS)
Value Char DOSS

#   Liste des Web services définis pour le dossier DOSS
#

Local Char APPLI(10)
APPLI=DOSS
If APPLI="" : APPLI=nomap : Endif

Local Char NOMFIC(200),VALL1(200),PROP,VPROP
Local Integer NBWS,NBWS1,D1,D2
Local Char LISTWS(20)(1..3000)

Local Char REPERT(200)
If clalev([F:HL1_])>0 : Close Local File [HL1_] : Endif
Call NAMEFIC(APPLI,"WEBS","","",REPERT) From INTRUTILA
D1 = instr(1,REPERT,"@")
If D1<>0 : REPERT = right$(REPERT,D1+1) : Endif
Local File (HLP(30)) From System adxmac(0)+'@lsadx -a'-toupper(nomap(0))-REPERT As [HL1_]
For [HL1_] Where HLP<>""
 If len([F:HL1_]HLP)>4 and right$([F:HL1_]HLP,len([F:HL1_]HLP)-3)=".xml"
   NBWS+=1
   LISTWS(NBWS)=left$([F:HL1_]HLP,len([F:HL1_]HLP)-4)
 Endif
Next HL1_
Close Local File [HL1_]

NBWS1=max(1,NBWS)
Local Char WPUBLI(20)(1..NBWS1)
Local Char WTYPE(1)(1..NBWS1)
Local Char LWTYPE(15)(1..NBWS1)
Local Char WOBJET(GLONAOB)(1..NBWS1)
Local Char WTRAN(10)(1..NBWS1)
Local Char WPROG(GLONADC)(1..NBWS1)
Local Char WSPROG(GLONASU)(1..NBWS1)
Local Char WINVIS(1)(1..NBWS1)
Local Char LWINVIS(8)(1..NBWS1)
Local Char WHORDAT(14)(1..NBWS1)
Local Char WUSER(15)(1..NBWS1)
Local Char WRP(15)(1..NBWS1)

# Boucle de traitement
# Pour chaque Web service
# - on recherche ses paramètres
# - on détruit son programme wrapper
# - on le crée dans la table AWEBSERVIC

Local Char PROGWR
Local Integer IOK
Local File =APPLI+".AWEBSERVIC" [A_WG]

For I=1 To NBWS
  Call NAMEFIC(APPLI,"WEBS","",LISTWS(I),NOMFIC) From INTRUTILA
  Openi NOMFIC Using [XML_]
  Iomode adxifs ""  Using [XML_]
  Iomode adxirs chr$(10)  Using [XML_]
  Iomode adxium GUTF8  Using [XML_]
  Rdseq VALL1 Using [XML_]
  For J=1 To 3
    Rdseq VALL1 Using [XML_]
    If fstat<>0 or instr(1,VALL1,"<ADXDATA>")<>0 : Break 1 : Endif
    PROP="PNA"  : Gosub RECHPROP
    PROP="TIM"  : Gosub RECHPROP
    PROP="OBJ"  : Gosub RECHPROP
    PROP="TRA"  : Gosub RECHPROP
    PROP="INV"  : Gosub RECHPROP
    PROP="USER" : Gosub RECHPROP
    PROP="PRG"  : Gosub RECHPROP
    PROP="SPG"  : Gosub RECHPROP
    PROP="WRP"  : Gosub RECHPROP
  Next J
  Openi Using [XML_]

# On détruit le wrapper ancien nom (src et adx)
If [M]TYPOBJ=2
  PROGWR="WR"+WPUBLI(I)
Else
  PROGWR="WJ"+WOBJET(I)+WTRAN(I)
  If WINVIS(I)="1" : PROGWR+="_I" : Endif
Endif
NOMFIC=filpath("TRT",PROGWR,"src",nomap)
Call EFFACE(NOMFIC,IOK) From ORDSYS
Call EFFACE_ADX("",nomap,PROGWR,IOK) From ORDSYS

# On crée l'enregistrement dans AWEBSERVIC
Trbegin [F:A_WG]
[F:A_WG]TYPOBJ=1
If WOBJET(I)="" : [F:A_WG]TYPOBJ=2 : Endif
[F:A_WG]OBJET=WOBJET(I)
[F:A_WG]VARIANTE=WTRAN(I)
[F:A_WG]PRG=WPROG(I)
[F:A_WG]SUBPRG=WSPROG(I)
[F:A_WG]PUBLI=WPUBLI(I)
[F:A_WG]INVISIBLE=val(WINVIS(I))+1
[F:A_WG]DATPUB=WHORDAT(I)
[F:A_WG]USERP=WUSER(I)
[F:A_WG]CREDAT=date$
If dim([F:A_WG]CRETIM)>0 : [F:A_WG]CRETIM=time : Endif
[F:A_WG]UPDDAT=date$
If dim([F:A_WG]UPDTIM)>0 : [F:A_WG]UPDTIM=time : Endif
[F:A_WG]CREUSR=GUSER
[F:A_WG]UPDUSR=GUSER
Write [F:A_WG]
Commit

Next I

# On publie tout
Call PUBLIALLWS(DOSS,1) From SUBAWE

End


$RECHPROP
D1=instr(1,VALL1,PROP+'="')
If D1<>0
  D2=instr(D1+len(PROP)+2,VALL1,'"')
  VALP=mid$(VALL1,D1+len(PROP)+2,D2-D1-len(PROP)-2)
  Case PROP
    When "PNA"  : WPUBLI(I)=VALP
    When "TIM"  : WHORDAT(I)=VALP
    When "OBJ"  : WOBJET(I)=VALP : WTYPE(I)="1" :  LWTYPE(I)=mess(1,906,1)
    When "TRA"  : WTRAN(I)=VALP
    When "INV"  : WINVIS(I)=VALP
                  If WINVIS(I)="1"
                    LWINVIS(I)=mess(2,1,1)
                  Else
                    LWINVIS(I)=mess(1,1,1)
                  Endif
    When "USER" : WUSER(I)=VALP
    When "PRG"  : WPROG(I)=VALP  : WTYPE(I)="2" : LWTYPE(I)=mess(2,906,1)
    When "SPG"  : WSPROG(I)=VALP
    When "WRP"  : WRP(I)=VALP
  Endcase
Endif
Return


Subprog DECRECUP(DOSS,OKR)
Value Char DOSS
Variable Integer OKR

# SI OKR=1 on peut proposer la recup

Local Char DOSSIER(10)
DOSSIER=DOSS
If DOSSIER="" : DOSSIER=nomap : Endif



Local Char NOMFIC(200),VALL1(200),PROP,VPROP
Local Integer D1,NBWS

#   Y-a-t-il des we services définis dans la table AWEBSERVICE
Local File =DOSSIER+".AWEBSERVIC" [A_WE]
For [A_WE]
  NBWS=1
  Break 1
Next

If NBWS<>0 : OKR=0 : End : Endif


#   Y-a-t-il des web services définis dans le répertoire WEBS

Local Char REPERT(200)
If clalev([F:HL1_])>0 : Close Local File [HL1_] : Endif
Call NAMEFIC(DOSSIER,"WEBS","","",REPERT) From INTRUTILA
D1 = instr(1,REPERT,"@")
If D1<>0 : REPERT = right$(REPERT,D1+1) : Endif
Local File (HLP(30)) From System adxmac(0)+'@lsadx -a'-toupper(nomap(0))-REPERT As [HL1_]
For [HL1_] Where HLP<>""
 If len([F:HL1_]HLP)>4 and right$([F:HL1_]HLP,len([F:HL1_]HLP)-3)=".xml"
   NBWS=1
   Break 1
 Endif
Next HL1_
Close Local File [HL1_]

OKR=NBWS

End


#-------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File AWEBSERVIC [AWE1]
 Local File AWEBSERDES [AWY1]
 Local File ATEXTRA    [AXX1]
Else
 Local File =[M]DOSORG+".AWEBSERVIC"    [AWE1]
 Local File =[M]DOSORG+".AWEBSERDES"    [AWY1]
 Local File =[M]DOSORG+".ATEXTRA"       [AXX1]
Endif
If [M]DOSDES=nomap
 Local File AWEBSERVIC [AWE2]
 Local File AWEBSERDES [AWY2]
 Local File ATEXTRA    [AXX2]
Else
 Local File =[M]DOSDES+".AWEBSERVIC"    [AWE2]
 Local File =[M]DOSDES+".AWEBSERDES"    [AWY2]
 Local File =[M]DOSDES+".ATEXTRA"       [AXX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AWE1] , [AWE2], [AWY1] , [AWY2] , [AXX1], [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [AWE2], [AWY2] , [AXX2]
 Delete [AWE2] Where PUBLI=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AWEBSERVIC" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AWE2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AWY2] Where PUBLI=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AWEBSERDES" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AWY2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AWE1] Where PUBLI=TABLE
  [F:AWE2] = [F:AWE1]
  Call COPTEXTRA("AWEBSERVIC","LIBW",TABLE,"") From ATEXTRA
  If GOK<1 : Break : Endif
  Write [AWE2]
  If fstat
   GOK = 0 : Call FSTA("AWE2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AWY1] Where PUBLI=TABLE
  [F:AWY2] = [F:AWY1]
  If GOK<1 : Break : Endif
  Write [AWY2]
  If fstat
   GOK = 0 : Call FSTA("AWY2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif



