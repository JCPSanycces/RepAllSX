#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion objet APV
Raz GPILOBJ
Call OBJET("APV",GBIDC1,GBIDC2) From GOBJET
End

 
#
#    Objet APV - gestion des vues du portail
#
# M001$ - 19012007 - En duplication avec chgt de code type SD: gestion grizage chps [M:APV1]SRCCOD
# M002$ - 09112007 - Adaptation suite modification saisie requete en graphique (ALH et TYP=3)
# M003$ - 20042009 - Gestion consultation
#
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE    
 When "LIENS"         : Gosub LIENS    
 When "SETBOUT"       : Gosub SETBOUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "CREATION"      : Gosub MAJ_TEXTRA
 When "MODIF"         : Gosub MAJ_TEXTRA
 When "ANNULE"        : Gosub ANNULE
 When "AP_VERF_ANU"   : Gosub APVERFANU
 When "CHANGE"        : Gosub CHANGE
 When "SEL_LISTE"     : Gosub SEL_LISTE
 When "FIN_LISTE"     : Gosub FIN_LISTE
 When "SEL_TABLE"     : Gosub SEL_TABLE
 When "CHX_TABLE"     : Gosub CHX_TABLE
 When default
Endcase
Return

#########################################
$APVERFANU
If OKANU=0 : Return : Endif
If clalev([F:AVP])=0 : Local File APORTVIG [AVP] : Endif
Filter [AVP] Where (CODFA="FSH" or CODFA="TAB") and PROPVAL(2)=[M]APVCOD
For [AVP]
  OKANU=0
 # Suppression impossible vue utilisée dans la vignette  xxxx
  Call ERREUR(mess(220,124,1)-[F:AVP]CODVI) From GESECRAN
  Break 1
Next
Filter [AVP]
Return


$OUVRE
Local Integer  W_PARUPD        # mise à jour de la fiche paramètres SD ou CV (0: pas de chgt , 1: chgt)
Local Integer  W_REP           # réponse utilisateur        (1: OK 2: Annuler)
Local Char     W_CODTYPCV(20)  # Code type Composants Visuel
Local Char     W_CODTYPSD(20)  # Code type Sources Données
Local Char     W_CODSD(20)     # Code Sources Données
Local Integer  W_HASTRTTIT     # Le traitement spécifique a une étiquette pour afficher les titres
Local Integer  WI,WJ,WFLG
Local Integer  WACT_ATRNL,WACT_SDNL,WACT_OFFSET   
Local Char     W_STR(200) 
Local Char     W_LSTMSG(250)(40)
Local Integer  W_LSTNB

If clalev ([F:APSD]) = 0 : Local File APTLPAR [F :APSD] : Endif    # paramètres SD
If clalev ([F:APCV]) = 0 : Local File APTLPAR [F :APCV] : Endif    # paramètres CV
Return

#########################################
$LIENS
Raz W_PARUPD
Gosub SETANDVERIF_PAR    # Valeurs et verif des paramètres
If [M:APV1]SRCCODTYP<>"TRT" & [M:APV1]WOBJ="" 
 Grizo [M:APV1]SRCCOD 
Else
 Actzo [M:APV1]SRCCOD
Endif
Return

#########################################
$SEL_LISTE
Local Integer CHANGE
Local Char SAV3(250),SAV2(250),SAV1(250)
FORCE=1
Case LISTE
 When "SELREQFLD" 
  SAV1 = VALEUR
  If left$(VALEUR,1)='"' 
   CHANGE = 1
   VALEUR = mid$(VALEUR,2,len(VALEUR)-2)
  Elsif left$(VALEUR,1)="'"
   CHANGE = 2
   VALEUR = mid$(VALEUR,2,len(VALEUR)-2)
  Else
   CHANGE = 3
  Endif
  Gosub SEL_REQ_CHAMP
Endcase
Return

#########################################
$FIN_LISTE
Case LISTE
 When "SELREQFLD" 
  Gosub APRES_C
 Endcase
Return

$APRES_C
If status <> 7 
 Local Integer K
 Local Char    SEP(1)
 SEP = ";"
 SAV3 = SAV2
 If instr(0,SAV3,SEP)
  While instr(0,SAV3,SEP)
   If VALEUR = left$(SAV3,instr(0,SAV3,SEP)-1)
    K=1
   Endif
   SAV3 = right$(SAV3,instr(0,SAV3,SEP)+1)
  Wend
 Elsif SAV3 <> ""
  If SAV3 = '"'+VALEUR+'"'
   Return
  Endif
 Endif
 If SAV3 = VALEUR
  K=1
 Endif
 If SAV2<>"" & K<>1
  VALEUR = SAV2+SEP+VALEUR
 Elsif K=1
  VALEUR = SAV2
 Endif 
Endif
If status <> 7 
 If find(CHANGE,1,3)
  VALEUR = '"'+VALEUR+'"'
 Elsif CHANGE = 2
  VALEUR = "'"+VALEUR+"'"
 Elsif SAV2<>""
  VALEUR = '"'+VALEUR+'"'
 Endif
Else
 VALEUR = SAV1
Endif
Return

$TRTCOP
If [M]DOSORG=nomap 
 Local File APTLVW    [APV1] 
 Local File ATEXTRA  [AXX1] 
Else 
 Local File =[M]DOSORG+".APTLVW"    [APV1]
 Local File =[M]DOSORG+".ATEXTRA"    [AXX1]
Endif 
If [M]DOSDES=nomap 
 Local File APTLVW    [APV2] 
 Local File ATEXTRA  [AXX2] 
Else 
 Local File =[M]DOSDES+".APTLVW"    [APV2]
 Local File =[M]DOSDES+".ATEXTRA"    [AXX2]
Endif
OK = 1
If GTRACE="" 
 Read [APV2]APV0 = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Gosub OUVDOS From ATEXTRA
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [APV1], [APV2], [AXX1], [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [APV2] 
 Delete [APV2] Where APVCOD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".APV" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("APV2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [APV1]APV0 = TABLE
 [F:APV2]=[F:APV1]
  If dim([F:APV2]UPDUSR)>0 : [F:APV2]UPDUSR = GUSER : Endif
  If dim([F:APV2]UPDDAT)>0 : [F:APV2]UPDDAT = date$ : Endif
  If dim([F:APV2]UPDTIM)>0 : [F:APV2]UPDTIM = time  : Endif
  Call COPTEXTRA("APTLVW","APVINTIT",TABLE,"") From ATEXTRA
  Write [APV2]
  If fstat
   GOK=0 : Call FSTA("APV2") From GLOCK 
  Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif




######################################## #M002$
$SEL_TABLE
Case TABLE
    When "SELREQ"    # Sélection requête std
        OBJET="ALH"
        OPTIONS="#"    # Pas de filtre issu de l'objet ALH
Endcase
Return

######################################### #M002$
$CHX_TABLE
Case TABLE
    When "SELREQ"    # Sélection requête std
        If PARAM(1)="ALH"
            CRITOBJ="TYP=1 | TYP=3"
        Elsif PARAM(1)="ALQ"
            CRITOBJ="TYP=2"
        Endif
Endcase
Return

#########################################
$SETBOUT
If GREP="" & W_PARUPD & W_REP=1 : Raz W_PARUPD, W_REP : REP="M" : Endif     # forcer enregistrer 
# NOTA: LIENS ne peut se dérouler que si une fiche est lue
Return

#########################################
$APRES_MODIF
Case COUZON
 When "SRCCODTYP"  
    W_CODTYPSD=CZ : W_CODSD=[M:APV1]SRCCOD : Gosub READ_PARSRC
    Effzo [M:APV1]20

    # gestion nouveau SD
    [M:APV1]WTYP=[F:APSD]SRCTYP
#    [M:APV1]WSRCDES=[F:APSD]APPDES
     For WI=0 To [F:APSD]PARNBR-1    
        WJ=1 : [M:APV1]SRCPARNBR+=1
        Insa WI,1 [M:APV1]SRCPARNBR
        [M:APV1]SRCPARCOD(WI)=[F:APSD]PARCOD(WI)
        [M:APV1]SRCPARFOR(WI)=[F:APSD]PARDEFVAL(WI)
        [M:APV1]PARTYP(WI)   =[F:APSD]PARTYP(WI)
        [M:APV1]PARLNG(WI)   =[F:APSD]PARLNG(WI)
    Next
    Gosub SET_PARSRC    # liste par sources de données
    Affzo [M:APV1]20
    
    # M001
    If [M:APV1]SRCCODTYP<>"TRT" & [M:APV1]WOBJ="" 
       [M:APV1]SRCCOD="" : Grizo [M:APV1]SRCCOD 
    Else
       Actzo [M:APV1]SRCCOD
    Endif
 
 When "CMPCODTYP"
    W_CODTYPCV=CZ : : Gosub READ_PARCMP
    Effzo [M:APV2]20
    # gestion nouveau CV
    For WI=0 To [F:APCV]PARNBR-1
        [M:APV2]CMPPARNBR+=1
        Insa WI,1 [M:APV2]CMPPARNBR
        [M:APV2]CMPPARCOD(WI)=[F:APCV]PARCOD(WI)
        [M:APV2]CMPPARFOR(WI)=[F:APCV]PARDEFVAL(WI)
        [M:APV2]PARTYP(WI)   =[F:APCV]PARTYP(WI)
        [M:APV2]PARLNG(WI)   =[F:APCV]PARLNG(WI)
    Next
    Gosub SET_PARCMP    # liste par composants visuels
    Affzo [M:APV2]20
 When "SRCCOD"
    If [M:APV1]SRCCODTYP="TRT" or [M:APV1]SRCCODTYP="CNS"  # Traitement ou consultation
        W_CODTYPSD=[M:APV1]SRCCODTYP : : W_CODSD=CZ
        If W_CODTYPSD="CNS" 
            Gosub DEL_CNSACT
            Gosub LD_CNSACT
            If GREP='C'         # Gestion init consultation
                # Composant visuel
                [M:APV2]CMPCODTYP="TB1"
                # CNS-MAX avec ecran std par defaut
                WI=find("CNS_MAX",[M:APV1]SRCPARCOD)
                If WI
                    If clalev([F:ACN])=0 : Local File ACONSULT [ACN] : Endif
                    If clalev([F:GTC])=0 : Local File GTABACC  [GTC] : Endif
                    Read [F:ACN]ACN0=W_CODSD
                    If !fstat
                        W_STR=[F:ACN]SCRCOD
                        If W_STR="" : W_STR="STD" : Endif
                        Read [F:GTC]GTC0=W_CODSD;W_STR
                        If !fstat
                            [M:APV1]SRCPARFOR(WI-1)=num$([F:GTC]NBRLIG)
                        Endif
                    Endif
                    
                    #CW_I=find("NBLIG",[F:AMK]BASPAG)
                    #If CW_I=0
                    #    EXPMES = mess(1, 75,1)-"NBLIG" : EXPSTA = 1 : Goto PTL_FIN
                    #Endif
                    #C_CNSMAXROW =[F:AMK]NBLIGT(CW_I-1)
                Endif
            Endif
        Endif
        Gosub SET_PARSRC    # liste par sources de données à rafraichir
        Affzo [M:APV1]20 
    Endif
 When default
Endcase
Return
#########################################
$MAJ_TEXTRA
Call MAJTEXTRA([M:APV0]APVINTIT,"APTLVW","APVINTIT",[M:APV0]APVCOD,"") From ATEXTRA
Return

$ANNULE
#suppresion texte traduisible
Delete [AXX] Where CODFIC="APTLVW"  & IDENT1=[M:APV0]APVCOD & ZONE ="APVINTIT"
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[M:APV0]APVCOD) From GLOCK 
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="APTLVW"  & IDENT1=[L]OCODE & ZONE ="APVINTIT" With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA APTLVW"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

######################################################################################
# Verification des para (en affichage)
$SETANDVERIF_PAR
Raz W_PARUPD, W_LSTMSG, W_LSTNB

W_CODTYPSD=[F:APV]SRCCODTYP : W_CODSD=[F:APV]SRCCOD : Gosub READ_PARSRC
W_CODTYPCV=[F:APV]CMPCODTYP : Gosub READ_PARCMP

# Vérification des para
  # SD
  ## -Paramètres attachés à la fonction Paramètres portail 
    For WI=0 To [F:APSD]PARNBR-1    
        If !find([F:APSD]PARCOD(WI),[M:APV1]SRCPARCOD) Then    # Paramètre nouveau
            W_LSTMSG(W_LSTNB)=mess(1,2912,1)-"-"-mess(34,137,1)-[F:APSD]PARCOD(WI) : W_LSTNB+=1
            W_PARUPD=1
        Endif 
    Next
    For WI=[M:APV1]SRCPARNBR-1 To 0 Step -1   # gestion suppression
        If !find([M:APV1]SRCPARCOD(WI),[F:APSD]PARCOD) Then
            # $003 - Pas une consultation ou un paramètre portail de consultation 
            If W_CODTYPSD<>"CNS" or left$([M:APV1]SRCPARCOD(WI),4)="CNS_"       
                W_LSTMSG(W_LSTNB)=mess(1,2912,1)-"-"-mess(35,137,1)-[M:APV1]SRCPARCOD(WI)-"/"-[M:APV1]SRCPARFOR(WI) : W_LSTNB+=1
                W_PARUPD=1
            Endif
        Endif 
    Next

  ## - $003 - Param associés à l'action consultation
    If W_CODTYPSD="CNS"        
        Raz WACT_ATRNL,WACT_SDNL,WACT_OFFSET
        # Position dernier par. avant ceux de l'action 
        For WACT_OFFSET=0 To [M:APV1]SRCPARNBR-1
            If left$([M:APV1]SRCPARCOD(WACT_OFFSET),4)<>"CNS_"  
                Break
            Endif
        Next

        # Création
        For [ATR]NOPAR Where ACTION="CONS"+[M:APV1]SRCCOD
            WACT_SDNL=find([F:ATR]CODPAR, [M:APV1]SRCPARCOD)
            If !WACT_SDNL Then    # Paramètre nouveau
                W_LSTMSG(W_LSTNB)=mess(1,2912,1)-"-"-mess(34,137,1)-[F:ATR]CODPAR : W_LSTNB+=1
                W_PARUPD=1
            Else
#                If [F:ATR]NOPAR <> WACT_SDNL - WACT_OFFSET
#                    W_LSTMSG(W_LSTNB)=mess(1,2912,1)-"-"-mess(70,137,1)-[F:ATR]CODPAR : W_LSTNB+=1
#                    W_PARUPD=1
#                Endif
            Endif
        Next       

        # Suppression
        WFLG=0
        For WI=[M:APV1]SRCPARNBR-1 To WACT_OFFSET+1 Step -1   # gestion suppression
            For [ATR]NOPAR Where ACTION="CONS"+[M:APV1]SRCCOD
                If [ATR]CODPAR=[M:APV1]SRCPARCOD(WI)
                    WFLG=1 : Break 
                Endif
            Next
            If !WFLG
                W_LSTMSG(W_LSTNB)=mess(1,2912,1)-"-"-mess(35,137,1)-[M:APV1]SRCPARCOD(WI)-"/"-[M:APV1]SRCPARFOR(WI) : W_LSTNB+=1
                W_PARUPD=1
            Endif
            WFLG=0
        Next
    Endif
    

  # CV
    For WI=0 To [F:APCV]PARNBR-1
        If !find([F:APCV]PARCOD(WI),[M:APV2]CMPPARCOD) Then    # Paramètre nouveau
            W_LSTMSG(W_LSTNB)= mess(2,2912,1)-"-"-mess(34,137,1)-[F:APCV]PARCOD(WI): W_LSTNB+=1
            W_PARUPD=1
        Endif 
    Next
    For WI=[M:APV2]CMPPARNBR-1 To 0 Step -1    # gestion suppression
        If !find([M:APV2]CMPPARCOD(WI),[F:APCV]PARCOD) Then  # Paramètre supprimé
            W_LSTMSG(W_LSTNB)=mess(2,2912,1)-"-"-mess(35,137,1)-[M:APV2]CMPPARCOD(WI)-"/"-[M:APV2]CMPPARFOR(WI) : W_LSTNB+=1
            W_PARUPD=1
        Endif
    Next

If W_PARUPD Then    # Question à l'utilisateur: 
    # Affichage écran pour lisibilité et message
    Affzo [APV0] : Affzo [APV1]
    For WI=0 To W_LSTNB-1 : Call MESSAGE(W_LSTMSG(WI)) From GESECRAN : Next

    # Les paramètres ont changés. Voulez-vous temporairement reporter la mise à jour ?
    Wrnbox mess(55,137,1) Using W_REP        # 1: Ok 2:annuler
    If W_REP=1        # Maj demandée
       # gestion suppression SD
        Raz WJ 
        For WI=[M:APV1]SRCPARNBR-1 To 0 Step -1   
            If !find([M:APV1]SRCPARCOD(WI),[F:APSD]PARCOD) Then
                # $003 - Pas une consultation ou un par. portail de consultation
                If W_CODTYPSD<>"CNS" or left$([M:APV1]SRCPARCOD(WI),4)="CNS_"  
                    WJ=1 : [M:APV1]SRCPARNBR-=1
                    Dela (WI),1 [M:APV1]SRCPARNBR
                Endif 
            Endif 
        Next

        # $003 - Param associés à l'action consultation
        If W_CODTYPSD="CNS" 
            WFLG=0
            For WI=[M:APV1]SRCPARNBR-1 To 0 Step -1   # gestion suppression
                For [ATR]NOPAR Where ACTION="CONS"+[M:APV1]SRCCOD
                    If [ATR]CODPAR=[M:APV1]SRCPARCOD(WI)
#                        If [F:ATR]NOPAR = WI - WACT_OFFSET          # Verif position
#                            WFLG=1
#                        Endif
                        WFLG=1
                        Break
                    Endif
                Next
                If !WFLG            
                    WJ=1 : [M:APV1]SRCPARNBR-=1
                    Dela (WI),1 [M:APV1]SRCPARNBR
                Endif
                WFLG=0
            Next
        Endif

        # gestion nouveau SD
        For WI=0 To [F:APSD]PARNBR-1    
            If !find([F:APSD]PARCOD(WI),[M:APV1]SRCPARCOD) Then    
                WJ=1 : [M:APV1]SRCPARNBR+=1
                Insa WI,1 [M:APV1]SRCPARNBR
                [M:APV1]SRCPARCOD(WI)=[F:APSD]PARCOD(WI)
                [M:APV1]SRCPARFOR(WI)=[F:APSD]PARDEFVAL(WI)
                [M:APV1]PARTYP(WI)   =[F:APSD]PARTYP(WI)
                [M:APV1]PARLNG(WI)   =[F:APSD]PARLNG(WI)
            Endif 
        Next

        # $003 - Param associés à l'action consultation
        If W_CODTYPSD="CNS" : Gosub LD_CNSACT : Endif

        # Dans ce contexte d'insert, suppression les textes AXX déplacés ne suivent pas bien...
        If WJ
            For WI=0 To [M:APV1]SRCPARNBR-1      
                Effzo [M:APV1]SRCPARDES(WI)        # Forcer un init
            Next
        Endif

        # gestion suppression CV
        Raz WJ 
        For WI=[M:APV2]CMPPARNBR-1 To 0 Step -1    # gestion suppression
            If !find([M:APV2]CMPPARCOD(WI),[F:APCV]PARCOD) Then  # Paramètre supprimé
                Dela (WI),1 [M:APV2]CMPPARNBR
                WJ=1 : [M:APV2]CMPPARNBR-=1
            Endif 
        Next
        # gestion nouveau CV
        For WI=0 To [F:APCV]PARNBR-1
            If !find([F:APCV]PARCOD(WI),[M:APV2]CMPPARCOD) Then    # gestion nouveau
                WJ=1 : [M:APV2]CMPPARNBR+=1
                Insa WI,1 [M:APV2]CMPPARNBR
                [M:APV2]CMPPARCOD(WI)=[F:APCV]PARCOD(WI)
                [M:APV2]CMPPARFOR(WI)=[F:APCV]PARDEFVAL(WI)
                [M:APV2]PARTYP(WI)   =[F:APCV]PARTYP(WI)
                [M:APV2]PARLNG(WI)   =[F:APCV]PARLNG(WI)
            Endif 
        Next
        # Dans ce contexte d'insert, suppression les textes AXX déplacés ne suivent pas bien...
        If WJ
            For WI=0 To [M:APV2]CMPPARNBR-1      
                Effzo [M:APV2]CMPPARDES(WI)        # Forcer un init
            Next
        Endif
    Endif
Endif

# Maj ecran
Gosub SET_PARSRC
Gosub SET_PARCMP
Return

# Source de données: lecture table des paramètres APP
# - - - - - - - 
$READ_PARSRC
Read [F:APSD]APP0=1;W_CODTYPSD   
If fstat
    Raz [F:APSD]
Endif
Return

# Paramètres sources de données par rapport à la table des paramètres APP ou du traitement
# - - - - - - - 
$SET_PARSRC
Raz W_HASTRTTIT

# Cas du trt spécifique avec etiquette titres
If W_CODTYPSD="TRT" & W_CODSD<>""    
  W_HASTRTTIT=1
Onerrgo ERR_SETTITLES
Gosub  T_SRCTITLES From =W_CODSD
Onerrgo
Endif


If !W_HASTRTTIT    # Affichage classique ou trt spécifique sans étiquette $T_SRCTITLES
    For WI=0 To [F:APSD]PARNBR-1    
        # Infos complémentaires
        WJ=find([F:APSD]PARCOD(WI),[M:APV1]SRCPARCOD)-1
        If WJ<>-1
            [M:APV1]PARNOLIB(WJ)=[F:APSD]PARNOLIB(WI)
            # intitulé
#   AXX      Call LECTEXTRA([M:APV1]SRCPARDES(WJ),"APTLPAR","PARDES","1",W_CODTYPSD+"~"+[M:APV1]SRCPARCOD(WJ)) From ATEXTRA
            Call TEXTE([F:APSD]PARDES(WI),[M:APV1]SRCPARDES(WJ)) From OBJDIV
        Endif
      # Infos complémentaires
      [M:APV1]PARNOLIB(WI)=[F:APSD]PARNOLIB(WI)
      [M:APV1]PARTYP(WI)  =[F:APSD]PARTYP(WI)
      [M:APV1]PARLNG(WI)  =[F:APSD]PARLNG(WI)
    Next

    # $003 - Cas action consultation
    If W_CODTYPSD="CNS" 
        For [ATR]NOPAR Where ACTION="CONS"+W_CODSD
            WACT_SDNL=find([F:ATR]CODPAR, [M:APV1]SRCPARCOD)
            If WACT_SDNL Then    
                If [F:ATR]INTITPAR<>0
                    Call TEXTE([F:ATR]INTITPAR,[M:APV1]SRCPARDES(WACT_SDNL-1)) From OBJDIV
                Else
                    Read [AAR]CODPAR=[F:ATR]CODPAR
                    If fstat=0
                        Call TEXTE([F:AAR]INTITPAR,[M:APV1]SRCPARDES(WACT_SDNL-1)) From OBJDIV
                    Endif
                Endif
            Endif
        Next    
    Endif   
Endif

# Intitulé SD
# Call LECTEXTRA([M:APV1]WSRCDES,"ATABDIV","LNGDES","90",W_CODTYPSD) From ATEXTRA

# Init de la zone objet liée à la source de donné
[M]WOBJ=""
[M]WTYP=[F:APSD]SRCTYP
Call LECTURE("ATY",[M]WTYP,"") From CONTOBJ  # Type
If !fstat
    [M]WOBJ=[F:ATY]OBJLIEN
Endif

Return

# Erreur d'accès à la définition des libellés dans le traitement spécifique utilisateur
# - - - - - - - 
$ERR_SETTITLES
W_HASTRTTIT=0
[M:APV1]SRCPARNBR=[F:APSD]PARNBR        # restauration du nb de ligne
Resume
Return

$READ_PARCMP
Read [F:APCV]APP0=2;W_CODTYPCV 
If fstat
    Raz [F:APCV]
Endif
Return

# Paramètres composants visuels par rapport à la table des paramètres APP
# - - - - - - - -
$SET_PARCMP
# Gestion message
For WI=0 To [F:APCV]PARNBR-1
    # Infos complémentaires
    WJ=find([F:APCV]PARCOD(WI),[M:APV2]CMPPARCOD)-1
    If WJ<>-1   
        [M:APV2]PARTYP(WI)  =[F:APCV]PARTYP(WI)
        [M:APV2]PARLNG(WI)  =[F:APCV]PARLNG(WI)
        [M:APV2]PARNOLIB(WJ)=[F:APCV]PARNOLIB(WI)
        # intitulé
# AXX        Call LECTEXTRA([M:APV2]CMPPARDES(WJ),"APTLPAR","PARDES","2",W_CODTYPCV+"~"+[M:APV2]CMPPARCOD(WJ)) From ATEXTRA
        Call TEXTE([F:APCV]PARDES(WI),[M:APV2]CMPPARDES(WJ)) From OBJDIV
    Endif
Next
# Intitulé CV
#Call LECTEXTRA([M:APV2]WCMPDES,"ATABDIV","LNGDES","91",W_CODTYPCV) From ATEXTRA
Return

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$LD_CNSACT
# Chargement param. associés à l'action de la consultation
    # Position dernier par. avant ceux de l'action 
    WACT_OFFSET=[F:APSD]PARNBR-1
    #
    For [ATR]NOPAR Where ACTION="CONS"+W_CODSD
        WACT_SDNL=find([F:ATR]CODPAR, [M:APV1]SRCPARCOD)
        If !WACT_SDNL Then  
            WI = WACT_OFFSET + [F:ATR]NOPAR
            WJ=1 : [M:APV1]SRCPARNBR+=1
            Insa WI,1 [M:APV1]SRCPARNBR
            [M:APV1]SRCPARCOD(WI)=[F:ATR]CODPAR
            #[M:APV1]SRCPARFOR(WI)=
            Case [ATR]TYPPAR
                When 1,6   # Char, Clob
                    [M:APV1]PARTYP(WI)   ="A"
                    [M:APV1]PARLNG(WI)   =80
                When 2,5   # Entier, libellé
                    [M:APV1]PARTYP(WI)   ="L"
                When 3     # Decimal
                    [M:APV1]PARTYP(WI)   ="DCB"
                When 4     # Date
                    [M:APV1]PARTYP(WI)   ="D"
            Endcase
        Endif
    Next       
Return

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$DEL_CNSACT
# Supppression param. associés à l'action de la consultation
    For WI=[M:APV1]SRCPARNBR-1 To 0 Step -1   # gestion suppression
        If left$([M:APV1]SRCPARCOD(WI),4)="CNS_" : Break : Endif
        [M:APV1]SRCPARNBR-=1
        Dela (WI),1 [M:APV1]SRCPARNBR
    Next
Return

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
Subprog MNL_PARFOR(MNL, CHX)
Value Integer MNL    # menu local
Value Integer CHX    # ligne nemu local
# S:    Valorisation de GBOUT2
Local Char WMES(40)

Raz GBOUT2
If MNL<>0    # menu local
    GBOUT2=mess(40,100,1)    # Choix
    GBOUT2=mess(18,100,1)    # Sélection
#    If CHX <> 0 & CHX <= len(mess(0,MNL,1))
#        GBOUT2-="("+mess(CHX,MNL,1)+")"
#    Endif
Endif
End

Subprog MNL_PARFORTXT(MNL, CHX, TXT)
Value Integer MNL    # menu local
Value Integer CHX    # ligne nemu local
Variable Char TXT
# S:    Valorisation de TXT
Local Char WMES(40)

TXT=""
If MNL<>0    # menu local
    If CHX <> 0 & CHX <= len(mess(0,MNL,1))
        TXT=mess(CHX,MNL,1)
    Endif
Endif
End

##########################################################################
## Gestion du masque APV1
##########################################################################
Subprog AS_SRCCOD(VALEUR)
Variable Char    VALEUR()
If [M:APV1]SRCCODTYP<>"TRT" & [M:APV1]WOBJ="" : VALEUR = "" : Grizo [M:APV1]SRCCOD : Endif
End

Subprog IB_SRCCOD
# pas de code obj pas de bouton
#If vireblc([M]WOBJ,4)=""
# GBOUT2=""
#Else
# Call TITOBJ([M:APV1]WOBJ,"",GBOUT2) From CONTOBJ
#Endif
End

Subprog C_SRCCOD(VALEUR)
Variable Char    VALEUR()
If [M]WOBJ="ALH"    # Modif ctl sur evolution saisie requête #M002$
 Local File ALISTEH [ALH]
 Read [ALH]ALH0=VALEUR
 If fstat
    mkstat=2 : GMESSAGE=mess(23,100,1)-VALEUR
 Else
    If !find([F:ALH]TYP,1,3)   
        mkstat=2 : GMESSAGE=mess(68,137,1)
    Endif
 Endif
 Close Local File [ALH]
Elsif [M]WOBJ <> ""
 Call CONTROLE([M:APV1]WOBJ,"",VALEUR,"!$",mkstat) From CONTOBJ
Endif
End

Subprog S_SRCCOD(VALEUR)
Variable Char     VALEUR
# --> E32158
# Mise en place d'une selection spécifique sur ALH car celle de AVV affiche toutes les requetes (std + sql)
#    cela car AVV ne prend pas en compte $FILTRE de l'objet
If !find([M:APV1]WOBJ,"ALH","ALQ")
 # Récupération du code généré sur S_SRCCOD / W1APV1 (avant indiquation sélection STD)

 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = [M]WTYP
 PARMSK(2) = "0"
 PARMSK(3) = "0"
 PARMSK(4) = [M]WAVVINTVAL
 PARMSK(5) = ""
 PARMSK(6) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]WAVVINTVAL = PARMSK(4)
 GACTION = SAVACT

 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = [M]WTYP
 PARMSK(2) = "0"
 PARMSK(3) = "0"
 PARMSK(4) = [M]WAVVINTVAL
 PARMSK(5) = ""
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]WAVVINTVAL = PARMSK(4)
 GACTION = SAVACT

Else
 # Récupération du code généré sur S_SRCCOD / W1APV1 (code provenant d'un bouton 10 provisoire avec SELOBJSTD)

 ## Action créée pour gérer les sélections sur ALH   #M002$
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELREQ"
 PARMSK(1) = [M:APV1]WOBJ   # "ALH" Gestion ALH et ALQ
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELREQ","SUBAPV","") From GACTION
 GACTION = SAVACT
 If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif

Endif
End

# Remplacement du std pour tunel correct sur type ALH de type 3  #M002$
Subprog B1_SRCCOD(VALEUR)
Variable Char    VALEUR()
 If [M]WTYP="ALH"
     Local File ALISTEH [ALH]
     Read [ALH]ALH0=VALEUR
     If !fstat
        GBIDC2=""
        If [F:ALH]TYP=1
            Call OBJET("ALH",VALEUR,GBIDC2) From GOBJET 
        Else    
            Call OBJET("ALT",VALEUR,GBIDC2) From GOBJET 
        Endif
     Else
            Call OBJET("ALT",VALEUR,GBIDC2) From GOBJET 
     Endif
     Close Local File [ALH]
 Else
     ## Action AFMTB1 (standard AVV)
     Local Char    PARMSK(250)(1..20) , SAVACT(20)
     SAVACT = GACTION : GACTION = "AFMTB1"
     PARMSK(1) = [M]WTYP
     PARMSK(2) = ""
     PARMSK(3) = "0"
     Call S_AFF_CHAR(VALEUR,PARMSK,"AFMTB1","FMTVAR","") From GACTION
     GACTION = SAVACT
  Endif
End

Subprog AV_WDES(VALEUR)    # recherche de l'intitulé de la fiche de l'objet demandé
Variable Char    VALEUR()
Local Char W_INTIT(20), W_OBJFILE(20)
VALEUR=""
If [M:APV1]WOBJ <> "" 
 Call LECTURE("AOB",[M:APV1]WOBJ,"") From CONTOBJ    # objet objet
 If !fstat
     Call LECTURE("ATB",[F:AOB]NOMFIC,"") From CONTOBJ  # table liée de l'objet requis
     If !fstat
        # Objet requis
        If evalue("clalev([F:"+[F:ATB]ABRFIC+"])")=0 : Local File =[F:AOB]NOMFIC : Endif
        Call LECTURE([M:APV1]WOBJ,[M:APV1]SRCCOD,"") From CONTOBJ
        If !fstat
            W_INTIT="[F:"+[F:ATB]ABRFIC+"]"+[F:ATB]INTIT
            If evalue("dim("+W_INTIT+")>=0")
                If clalev([F:ATZ])=0 : Local File ATABZON  [ATZ] : Endif
                Read [F:ATZ]CODZONE=[F:AOB]NOMFIC;[F:ATB]INTIT
                If fstat=0 and [F:ATZ]CODTYP="ATX"
                    Call TEXTE(evalue(W_INTIT),VALEUR) From OBJDIV
                Else
                    VALEUR=evalue(W_INTIT) 
                Endif
            Else    # type AXX
               Call LECTEXTRA(VALEUR,[F:AOB]NOMFIC,[F:ATB]INTIT,[M:APV1]SRCCOD,"") From ATEXTRA
            Endif
        Endif 
     Endif 
 Endif 
Endif
End

Subprog IB_SRCPARFOR
Call MNL_PARFOR([M:APV1]PARNOLIB(nolign-1), val([M:APV1]SRCPARFOR(nolign-1))) From SUBAPV
If clalev([F:ATY])=0 : Local File ATYPE  [ATY] : Endif
Call LECTURE("ATY",[M:APV1]PARTYP(nolign-1),"") From CONTOBJ
If [F:ATY]OBJLIEN<>""  & [F:ATY]OBJLIEN = [M:APV1]PARTYP(nolign-1) & [M:APV1]PARTYP(nolign-1) <> "ADI"
 GBOUT4 =""
Elsif [M:APV1]PARNOLIB(nolign-1) > 0
 GBOUT5 = ""
Else
 GBOUT4 = ""
 GBOUT5 = ""
Endif
End

Subprog AV_SRCPARNBR
Local Char WMES 
Call MNL_PARFORTXT([M:APV1]PARNOLIB(nolign-1), val([M:APV1]SRCPARFOR(nolign-1)), WMES) From SUBAPV
Inftxt WMES At 2
End

Subprog AP_SRCPARNBR
Inftxt "" At 2
End

Subprog AV_SRCPARLIB(VALEUR)
Variable Char    VALEUR()
Local Char CLE1(10)
If instr(0,[M:APV1]SRCPARFOR(nolign-1),"'") <> 0 | instr(0,[M:APV1]SRCPARFOR(nolign-1),'"') <> 0
 CLE1 = seg$([M:APV1]SRCPARFOR(nolign-1),2,len([M:APV1]SRCPARFOR(nolign-1))-1)
Else
 CLE1 = [M:APV1]SRCPARFOR(nolign-1)
Endif
If [M:APV1]PARTYP(nolign-1) = "M"
 Call MNL_PARFORTXT([M:APV1]PARNOLIB(nolign-1), val(CLE1), VALEUR) From SUBAPV
Elsif [M:APV1]PARTYP(nolign-1) = "ADI"
 VALEUR = ""
 Read [ADI]CODE = [M:APV1]PARNOLIB(nolign-1);CLE1
 If !fstat
  Call LECTEXTRA(VALEUR,"ATABDIV","LNGDES",num$([ADI]NUMTAB),[ADI]CODE) From ATEXTRA
 Endif
Endif
End

Subprog B5_SRCPARFOR(VALEUR)
Variable Char    VALEUR()
Local Char    PARAM(250)(1..20),SAV1(250)
Local Integer CHANGE
SAV1 = VALEUR
PARAM(1) = [M:APV1]PARTYP(nolign-1)
If left$(VALEUR,1)='"' 
 CHANGE = 1
 VALEUR = mid$(VALEUR,2,len(VALEUR)-2)
Elsif left$(VALEUR,1)="'"
 CHANGE = 2
 VALEUR = mid$(VALEUR,2,len(VALEUR)-2)
Else
 CHANGE = 3
Endif
If PARAM(1)="GTC"
    PARAM(3)=[M:APV1]SRCCOD
Endif
Call S_TAB_CHAR(VALEUR,PARAM,"SELOBJ","SELOBJ","") From GACTION
If status <> 7
 If find(CHANGE,1,3)
  VALEUR = '"'+VALEUR+'"'
 Elsif CHANGE = 2
  VALEUR = "'"+VALEUR+"'"
 Endif
Else
 VALEUR = SAV1
Endif
End

