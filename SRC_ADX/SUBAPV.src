## Gestion du masque APV2
##########################################################################
Subprog IB_CMPPARFOR
Call MNL_PARFOR([M:APV2]PARNOLIB(nolign-1), val([M:APV2]CMPPARFOR(nolign-1))) From SUBAPV
If clalev([F:ATY])=0 : Local File ATYPE  [ATY] : Endif
Call LECTURE("ATY",[M:APV2]PARTYP(nolign-1),"") From CONTOBJ
If [F:ATY]OBJLIEN<>""  & [F:ATY]OBJLIEN = [M:APV2]PARTYP(nolign-1) & [M:APV2]PARTYP(nolign-1) <> "ADI"
 GBOUT5 =""
 GBOUT4 =""
Elsif [M:APV2]PARNOLIB(nolign-1) > 0
 GBOUT3 = ""
 GBOUT5 = ""
Elsif find([M:APV1]WTYP,"ALH","ALQ","PS2") & [M:APV2]PARTYP(nolign-1) = "C" & [M:APV2]PARLNG(nolign-1) = 2
 GBOUT3 = ""
 GBOUT4 = ""
Else
 GBOUT4 = ""
 GBOUT3 = ""
 GBOUT5 = ""
Endif
End

Subprog AV_CMPPARNBR
Local Char WMES 
Call MNL_PARFORTXT([M:APV2]PARNOLIB(nolign-1), val([M:APV2]CMPPARFOR(nolign-1)), WMES) From SUBAPV
Inftxt WMES At 2
End

Subprog AP_CMPPARNBR
Inftxt "" At 2
End

Subprog C_CMPCODTYP(VALEUR)
Variable Char    VALEUR()
If [M:APV1]SRCCODTYP<>"WEB" & vireblc(VALEUR,2)="" 
 mkstat=2
 GERR=1 : GMESSAGE=mess(10,123,1)
Endif
End

Subprog AS_CMPPARFOR(VALEUR)
Variable Char    VALEUR()
End

Subprog AV_CMPPARLIB(VALEUR)
Variable Char    VALEUR()
Local Char CLE1(10)
If instr(0,[M:APV2]CMPPARFOR(nolign-1),"'") <> 0 | instr(0,[M:APV2]CMPPARFOR(nolign-1),'"') <> 0
 CLE1 = seg$([M:APV2]CMPPARFOR(nolign-1),2,len([M:APV2]CMPPARFOR(nolign-1))-1)
Else
 CLE1 = [M:APV2]CMPPARFOR(nolign-1)
Endif
If [M:APV2]PARTYP(nolign-1) = "M"
 Call MNL_PARFORTXT([M:APV2]PARNOLIB(nolign-1), val(CLE1), VALEUR) From SUBAPV
Elsif [M:APV2]PARTYP(nolign-1) = "ADI"
 VALEUR = ""
 Read [ADI]CODE = [M:APV2]PARNOLIB(nolign-1);CLE1
 If !fstat
  Call LECTEXTRA(VALEUR,"ATABDIV","LNGDES",num$([ADI]NUMTAB),[ADI]CODE) From ATEXTRA
 Endif
Endif
End

$SEL_REQ_CHAMP
If clalev([F:ALD])=0 : Local File ALISTED [ALD] : Endif
Local Char TEXTAX(250)
SAV2 = VALEUR
If find([M:APV1]WTYP,"ALH","ALQ")
 For [ALD]ALD0 Where COD = PARAM(2) & find(STREND,0,1,2)
  I += 1
  TEX(I) = num$([ALD]LIG)
  Call LECTEXTRA([L]TEXTAX,"ALISTED","INTITLIG",[ALD]COD,num$([ALD]LIG)) From ATEXTRA
  TEXTE(I) = num$([ALD]LIG)-":"-[L]TEXTAX
  [L]TEXTAX = ""
 Next
 NBTEX = I
 TIT  = mess(18,134,1) -[ALD]COD: # Requête
Elsif find([M:APV1]WTYP,"PS2")
 If clalev([F:PS2])=0 : Local File PARSTA2 [PS2] : Endif
 Read [PS2]PS20 = PARAM(2)
 If !fstat
  J=1
  TEX(J) = "2"
  TEXTE(J) = mess(30,109,1) : # Intitulé
  For I=0 To dim([PS2]AMTFRM)-1
   If func AFNC.TEXTRA("PARSTA2","INTITFRM",[F:PS2]COD,num$(I+1)) <> ""
    J+=1
    TEX(J) = num$(J+1)
    TEXTE(J) = func AFNC.TEXTRA("PARSTA2","INTITFRM",[F:PS2]COD,num$(I+1))
   Endif
  Next
  NBTEX = J
  TIT  = mess(7,26,1)-[PS2]COD : # Statistiques
 Endif
Endif
Return

Subprog B3_CMPPARFOR(VALEUR)
Variable Char    VALEUR()
Local Char    PARAM(250)(1..20),SAV1(250)
Local Integer CHANGE
SAV1 = VALEUR
PARAM(1) = [M:APV2]PARTYP(nolign-1)
If left$(VALEUR,1)='"' 
 CHANGE = 1
 VALEUR = mid$(VALEUR,2,len(VALEUR)-2)
Elsif left$(VALEUR,1)="'"
 CHANGE = 2
 VALEUR = mid$(VALEUR,2,len(VALEUR)-2)
Else
 CHANGE = 3
Endif
Call S_TAB_CHAR(VALEUR,PARAM,"SELOBJ","SELOBJ","") From GACTION
If status <> 7
 If find(CHANGE,1,3)
  VALEUR = '"'+VALEUR+'"'
 Elsif CHANGE = 2
  VALEUR = "'"+VALEUR+"'"
 Endif
Else
 VALEUR = SAV1
Endif
End


