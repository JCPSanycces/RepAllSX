#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
#    Process Name:    BPS1099SUM - 1099 payments summary workbench
######################################################################################

$ACTION

Case ACTION

    When "OUVRE"      : Gosub OUVRE
    When "BOUTON"     : Gosub BOUTON
    When "SETBOUT"    : Gosub SETBOUT
    When "BB1_NBLIG"  : Gosub BB1_NBLIG

    When "FIR"          : Gosub FIRSTPAGE
    When "LAS"          : Gosub LASTPAGE
    When "SUI"          : Gosub PAGEFORWARD
    When "PRE"          : Gosub PAGEBACK

Endcase

Return
############################################################
$OUVRE

Global Integer GMAXLIG

If clalev([F:B9P]) = 0  : Local File BPS1099PAY     [B9P]  : Endif    # Supplier 1099 Payments
If clalev([F:B9P2]) = 0 : Local File BPS1099PAY     [B9P2] : Endif    # Supplier 1099 Payments
If clalev([F:B9B]) = 0  : Local File BP1099BEGBAL   [B9B]  : Endif    # Supplier 1099 beginning balance
If clalev([F:B9B2]) = 0 : Local File BP1099BEGBAL   [B9B2] : Endif    # Supplier 1099 beginning balance
If clalev([F:BPS]) = 0  : Local File BPSUPPLIER     [BPS]  : Endif    # Supplier
If clalev([F:CPY])=0    : Local File COMPANY        [CPY]  : Endif    # Company


If clalev([F:B109]) = 0  : Local File BPS1099PAYBB     [B109]  : Endif    # Payments and Beginning Balance View

Local Mask BPS1099SUM [B9S1]

GMAXLIG = dim([M]FRM1099)

Local Char WFIL(250)

Local Integer CURPAGE, III

Gosub LOAD_SCREEN

nolign = 1

Return
############################################################
$LOAD_SCREEN

For I = 1 To dim(PARAM)
  Case I
    When 1 :                                                     # Year
      If PARAM(I) <> ""
        [M:B9S1]THEYEAR = PARAM(I)
      Endif
    When 2 :
      If PARAM(I) <> ""                                          # Company
        Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:B9S1]THECPY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""                                          # Supplier
        Call LECTURE("BPS",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:B9S1]BPSDEB = PARAM(I)
          [M:B9S1]BPSFIN = PARAM(I)
        Endif
      Endif
  Endcase
Next I

If [M:B9S1]THEYEAR <= 0
    If month(date$) < 6
        [M:B9S1]THEYEAR = year(date$) - 1
    Else
        [M:B9S1]THEYEAR = year(date$)
    Endif
Endif

[M]MOREPAGES = 0

Return
############################################################
$SETBOUT

Raz ETABOU

# If records are displayed
If [M]NBLIG > 0
  If CURPAGE > 1
    ETABOU(GPREC) = 1  # Page Backward
    ETABOU(GPREM) = 1  # First Page
  Endif

  If [M]MOREPAGES
    ETABOU(GSUIV) = 1  # Page forward
    ETABOU(GDERN) = 1  # Last Page
  Endif

Endif

ETABOU(GBFIN) = 1 # End
ETABOU(GSPE1) = 1 # Search

Return

############################################################
$BOUTON

Case BOUT
    When "1" :             # Search
        CURPAGE   = 1
        [M]MOREPAGES = 0
        [M]CURCPY = ""
        [M]CURBPS = ""
        [M]STARTREC = 1
        Gosub SEARCH_DISPLAY

Endcase

Return
############################################################
$BB1_NBLIG

# Refresh since data could have changed in the calling actions
Raz [M]CURCPY, [M]CURBPS, [M]CURFRM, [M]CURBOX

Gosub SEARCH_DISPLAY

Return

############################################################
$FIRSTPAGE

Raz [M]CURCPY, [M]CURBPS, [M]CURFRM, [M]CURBOX

CURPAGE = 1
[M]STARTREC = 1
Gosub SEARCH_DISPLAY

Return
############################################################
$LASTPAGE

Local Integer NUMRECS, NUMPAGES

Raz [M]CURCPY, [M]CURBPS, [M]CURFRM, [M]CURBOX

NUMRECS = func COUNT_RECORDS()
NUMPAGES = NUMRECS / GMAXLIG
If mod(NUMRECS,GMAXLIG) = 0
  NUMPAGES -= 1
Endif
CURPAGE = NUMPAGES + 1

If NUMRECS - GMAXLIG > [M]STARTREC
    [M]STARTREC = NUMRECS - GMAXLIG + 1
Else
    [M]STARTREC += GMAXLIG
Endif

Gosub SEARCH_DISPLAY

Return
############################################################
$PAGEFORWARD

Raz [M]CURCPY, [M]CURBPS, [M]CURFRM, [M]CURBOX

CURPAGE += 1
[M]STARTREC += GMAXLIG

Gosub SEARCH_DISPLAY

Return
############################################################
$PAGEBACK

Raz [M]CURCPY, [M]CURBPS, [M]CURFRM, [M]CURBOX

CURPAGE -= 1
[M]STARTREC -= GMAXLIG
If [M]STARTREC < 1
    [M]STARTREC = 1
Endif

Gosub SEARCH_DISPLAY

Return
############################################################
$SEARCH_DISPLAY

Local Integer LASTLINE
Local Decimal TOTPAYAMT, BEGBALAMT
Local Integer CURRENTREC, PAYRECORD

# Year is mandatory
If [M:B9S1]THEYEAR <= 0
  Return
Endif

LASTLINE = 0
CURRENTREC = 0
[M]MOREPAGES = 0

Gosub LOAD_FILTER

Effzo [M]20

nolign = 1

For [F:B109]

  If nolign <= GMAXLIG
    Gosub LOA_LIGNE
  Else
    [M]MOREPAGES = 1
    Break
  Endif

Next

If nolign <= GMAXLIG

  If [M]CURCPY <> ""
    LASTLINE = 1
    Gosub LOA_LIGNE
    LASTLINE = 0
  Endif

Endif

[M]NBLIG = nolign - 1
Affzo [M]

Return

############################################################
$LOAD_FILTER

WFIL = "YR1099 = [M:B9S1]THEYEAR"

If [M:B9S1]THECPY <> ""
    WFIL -= "& CPY = [M:B9S1]THECPY"
Endif

If [M:B9S1]BPSDEB <> ""
    WFIL -= "& BPSNUM>=[M:B9S1]BPSDEB"
Endif

If [M:B9S1]BPSFIN <> ""
    WFIL -= "& BPSNUM<=[M:B9S1]BPSFIN"
Endif

Filter [F:B109]  Where evalue(WFIL) Order By Key B1091

Return

############################################################
$LOA_LIGNE

If [F:B109]CPY <> [M]CURCPY or [F:B109]BPSNUM <> [M]CURBPS or [F:B109]FRM1099 <> [M]CURFRM or [F:B109]BOX1099 <> [M]CURBOX or LASTLINE

    If [M]CURCPY <> ""

        CURRENTREC += 1

        If CURRENTREC >= [M]STARTREC

            # Supplier
            Read [F:BPS]BPS0=[M]CURBPS
            If fstat = 0
                [M:B9S1]BPSNAM(nolign-1) = [F:BPS]BPSNAM
            Endif

            [M:B9S1]CPY(nolign-1)        = [M]CURCPY
            [M:B9S1]BPSNUM(nolign-1)     = [M]CURBPS
            [M:B9S1]FRM1099(nolign-1)    = [M]CURFRM
            [M:B9S1]BOX1099(nolign-1)    = [M]CURBOX
            [M:B9S1]BEGBAL(nolign-1)     = BEGBALAMT
            [M:B9S1]PAYAMT(nolign-1)     = TOTPAYAMT

            [M:B9S1]TOT1099AMT(nolign-1) = TOTPAYAMT + [M:B9S1]BEGBAL(nolign-1)
            [M:B9S1]PAYREC(nolign-1)     = PAYRECORD
            PAYRECORD = 0
            nolign += 1

        Endif

    Endif

    TOTPAYAMT = [F:B109]AMT1099
    BEGBALAMT = [F:B109]BEGBAL
    [M]CURCPY = [F:B109]CPY
    [M]CURBPS = [F:B109]BPSNUM
    [M]CURFRM = [F:B109]FRM1099
    [M]CURBOX = [F:B109]BOX1099
    If [F:B109]PAYNUM <> "" : PAYRECORD = 1 : Endif

Else
    TOTPAYAMT += [F:B109]AMT1099
    BEGBALAMT = [F:B109]BEGBAL
    If [F:B109]PAYNUM <> "" : PAYRECORD = 1 : Endif
Endif

Return

######################################################################################
# Count the qualifying records based on Filter
Funprog COUNT_RECORDS()

Local Integer NUMRECS
Local Char    THEBPS, THECPY, THEBOX
Local Integer THEFRM

NUMRECS = 0

Gosub LOAD_FILTER

For [F:B109]

    If [F:B109]CPY <> THECPY or [F:B109]BPSNUM <> THEBPS or [F:B109]FRM1099 <> THEFRM or [F:B109]BOX1099 <> THEBOX
        NUMRECS +=1
        THECPY = [F:B9P]CPY
        THEBPS = [F:B9P]BPSNUM
        THEFRM = [F:B9P]FRM1099
        THEBOX = [F:B9P]BOX1099
    Endif

Next

Filter [F:B109]

End NUMRECS

######################################################################################
Subprog AM_BPSDEB(VALEUR)
Variable Char    VALEUR()

    [M]BPSFIN = VALEUR

End


######################################################################################
Subprog C_THECPY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" and func AFNC.PARAM("DCLFEES",VALEUR) <> "3"
    GMESSAGE = mess(77,122,1)
    mkstat = 2
    End
Endif

End
######################################################################################
Subprog C_BPSDEB(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" and [F:BPS]FRM1099 < 2
    GMESSAGE = mess(76,122,1)
    mkstat = 2
    End
Endif

End
######################################################################################
Subprog C_BPSFIN(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" and [F:BPS]FRM1099 < 2
    GMESSAGE = mess(76,122,1)
    mkstat = 2
    End
Endif

End

######################################################################################
Subprog B2_NBLIG

Local Integer CLE1 : CLE1 = [M:B9S1]THEYEAR
Local Char CLE2 : CLE2 = [M:B9S1]CPY(nolign-1)
Local Char CLE3 : CLE3 = [M:B9S1]BPSNUM(nolign-1)

Call OBJET_CHAR(CLE2,"B9B",num$(CLE1)+"~"+CLE3) From GOBJET

# Refresh since data could have changed in the calling object
Raz [M]CURCPY, [M]CURBPS, [M]CURFRM, [M]CURBOX

Gosub SEARCH_DISPLAY

End

######################################################################################
Subprog B3_NBLIG

Local Integer CLE1 : CLE1 = [M:B9S1]THEYEAR
Local Char CLE2 : CLE2 = [M:B9S1]CPY(nolign-1)
Local Char CLE3 : CLE3 = [M:B9S1]BPSNUM(nolign-1)
Local Integer CLE4 : CLE4 = [M:B9S1]FRM1099(nolign-1)

Call OBJET_CHAR(CLE2,"B9M",num$(CLE1)+"~"+CLE3+"~"+num$(CLE4)) From GOBJET

End

######################################################################################
Subprog IB_NBLIG

If [M]PAYREC(nolign-1) = 0 : Raz GBOUT1 : Endif    # Can only edit payment amounts if there is one

End

######################################################################################
Subprog AP_THECPY(VALEUR)
Variable Char    VALEUR()
Read [CPY]CPY0=VALEUR
 If !fstat
  [M:B9S1]CUR = [F:CPY]ACCCUR
 Else
  Raz [CPY]
 Endif
 Affzo [M:B9S1]CUR
End


######################################################################################

