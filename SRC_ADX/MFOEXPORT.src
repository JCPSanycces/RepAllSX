#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
Case ACTION
    When "EXPORT" :        Gosub EXPORT
Endcase
Return


###################################################################################
$EXPORT
If EXPFIC="MFO" & GACTION="MESINT" : #interface MES
    # on verifie la selection dur MFG
    If [M:DIA]MFGFOR<>""
        Local Char    CRITMFG(255)
        If clalev([F:TFO]) = 0 : Local File TABFOR     [TFO] : Endif 
        If clalev([F:MFG]) = 0 : Local File MFGHEAD    [MFG] : Endif 
        Read [F:TFO]TFO0=44;[M:DIA]MFGFOR
        If !fstat 
            CRITMFG = [F:TFO]FORFOR                 
            Filter [MFG] Where MFGSTA=1 & evalue(CRITMFG)
            Read [MFG]MFG0=[F:MFO]MFGNUM
            If fstat : [L]OK=0 : Endif
            Filter [MFG]
            If [L]OK=0 : Return : Endif
        Endif
    Endif
    #ne pas exporter les opérations associée à un poste de sous-traitance
    If clalev ([F:MWS]) = 0 : Local File WORKSTATIO [MWS] : Endif
    Read [F:MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
    If !fstat 
        If [F:MWS]WSTTYP=3 : [L]OK=0 : Return : Endif 
    Endif
    #ne pas exporter les etapes sans jalon (on ne prend que 2=suivi normal et 3=bornes) 
    If clalev ([F:SCH]) = 0 : Local File SCHEDULING [SCH] : Endif
    Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
    If !fstat 
        If find([F:SCH]DACMST,2,3)=0 : [L]OK=0 : Return : Endif
    Endif
Endif
Return


