Onerrgo

[S]adxifs  = [L]DBG_SAVIFS
[S]adxirs  = [L]DBG_SAVIRS
[S]adxium  = [L]DBG_SAVIUM
If dim(APARAM)>-1 : APARAM = [LDB]DBG_APARAM : Endif
[S]fstat   = [LDB]DBG_FSTAT
[S]status  = [LDB]DBG_STATUS
[S]stat1   = [LDB]DBG_STAT1

End

Subprog ADJUST_MEMORY
  Onerrgo ERR_LOG
  # add 12000Kb to max if not already added
  If dbglong(33) > 0
    dbglong(33) = -12000
    maxmem = int([LDB]DBG_MAXMEM/1024) + abs(dbglong(33))
  Else
    dbglong(33) = 0
  Endif
  Onerrgo
End

######################################################################
#
# extrait le nom de traitement de la forme canonique :
# V6: serveur@X3BUG.TRT/IAEXEC$adx:68
# V5: serveur@X3BUG.TRT/IAEXEC:68
#
######################################################################

Subprog EXTRACT_FILE_PARTS(FILE_NAME, PROG_NAME, APP_NAME, SRV_NAME)
  Value Char FILE_NAME()
  Variable Char PROG_NAME()
  Variable Char APP_NAME()
  Variable Char SRV_NAME()

  Local Integer DOLLAR
  Local Integer IDX
  Local Integer IDX2

  DOLLAR = instr(1, FILE_NAME, '$')
  If DOLLAR > 0
    # From v6 : server@SUPERV.TRT/ZDL2$adx

    IDX = instr(1, FILE_NAME, "@")
    If IDX > 0
      SRV_NAME = left$(FILE_NAME, IDX - 1)
    Else
      SRV_NAME = ""
    Endif

    IDX += 1
    IDX2 = instr(IDX, FILE_NAME,".")
    If IDX2 > 0
      APP_NAME = mid$(FILE_NAME, IDX, IDX2 - IDX)
    Else
      APP_NAME = ""
      IDX2 = IDX - 1
    Endif
    IDX2 += 1
    IDX = instr(IDX2, FILE_NAME, "/")
    If IDX = 0
      IDX = instr(1, FILE_NAME, "\")
    Endif

    IDX += 1
    If IDX > 1
      PROG_NAME = mid$(FILE_NAME, IDX, DOLLAR - IDX)
    Else
      PROG_NAME = ""
    Endif

  Else
    # From v5 : Trt=[@SUPERV150.ZDL2]

    IDX = instr(1, FILE_NAME, "@")
    If IDX > 0
      SRV_NAME = left$(FILE_NAME, IDX - 1)
    Else
      SRV_NAME = ""
    Endif

    IDX += 1
    IDX2 = instr(IDX, FILE_NAME,".")
    If IDX2 > 0
      APP_NAME = mid$(FILE_NAME, IDX, IDX2 - IDX)
    Else
      APP_NAME = ""
      IDX2 = IDX - 1
    Endif

    IDX = IDX2 + 1
    If IDX > 1
      PROG_NAME = right$(FILE_NAME, IDX)
    Else
      PROG_NAME = ""
    Endif
  Endif

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".EXTRACT_FILE_PARTS(" + FILE_NAME + ")")
    Call TRACE_APPEND("==> server=" + SRV_NAME + ", app=" + APP_NAME + ", prog=" + PROG_NAME)
  Endif

End

Subprog EXTRACT_TRTNAME(DBGS_NAME)
  Variable Char DBGS_NAME()
  Local Integer WI
  [L]WI  = instr(1,[L]DBGS_NAME,"$adx")
  If [L]WI>0
    [L]DBGS_NAME = left$([L]DBGS_NAME,[L]WI-1)
    [L]WI  = instr(1,[L]DBGS_NAME,"TRT/")
    If [L]WI=0
      [L]WI  = instr(1,[L]DBGS_NAME,"TRT\")
    Endif
    If [L]WI>0
      [L]DBGS_NAME = right$([L]DBGS_NAME,[L]WI+4)
    Endif
  Endif
End

######################################################################
#
# extrait le nom du dossier de la forme canonique :
# serveur@X3BUG.IAEXEC:68 ==> X3BUG
# s'il n'y a pas de "@", retourne ""
#
######################################################################

Subprog EXTRACT_APPNAME(DBGS_NAME)
  Variable Char DBGS_NAME()
  Local Integer WI


  [L]WI  = instr(1,[L]DBGS_NAME,"@")
  If [L]WI>0
    [L]DBGS_NAME = right$([L]DBGS_NAME,[L]WI+1)
    [L]WI  = instr(1,[L]DBGS_NAME,".TRT/")
    If [L]WI=0
      [L]WI  = instr(1,[L]DBGS_NAME,".TRT\")
    Endif
    If [L]WI>0
      [L]DBGS_NAME = left$([L]DBGS_NAME,[L]WI-1)
    Endif
  Else
     [L]DBGS_NAME=""
  Endif
End

######################################################################
#
# extrait le nom du serveur de la forme canonique :
# serveur@X3BUG.TRT/IAEXEC$adx:68 ==> serveur
# s'il n'y a pas de "@", retourne ""
#
######################################################################

Subprog EXTRACT_SRVNAME(DBGS_NAME)
  Variable Char DBGS_NAME()
  Local Integer WI
  [L]WI  = instr(1,[L]DBGS_NAME,"@")
  If [L]WI>0
    [L]DBGS_NAME = left$([L]DBGS_NAME,[L]WI-1)
  Else
     [L]DBGS_NAME=""
  Endif

End

