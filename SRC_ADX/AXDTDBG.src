#**
#* Set current depth
#*
#* @param ARGS the command arguments
#*!
Subprog DBGP_SET_DEPTH(ARGS)
  Value Char ARGS()(97..122)

  #---------------------------------------------------------------
  # stack depth:
  #   optional, debugger engine should assume zero if not provided
  #---------------------------------------------------------------
  Local Integer DEPTH : DEPTH = func GET_NUM_VAL(ARGS(ascii('d')), [LDB]TOP_LEVEL)

  [LDB]CURRENT_STACK = [L]DEPTH

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".DBGP_SET_DEPTH:  depth=" + num$([L]DEPTH))
  Endif
End

#**
#* Set debug line offset (0 or 1, depending on sources first line management)
#*
#* @param ARGS the command arguments
#*!
Subprog DBGP_SET_DLO(ARGS)
  Value Char ARGS()(97..122)

  #---------------------------------------------------------------
  # debug line offset:
  #   optional, debugger engine should assume zero if not provided
  #---------------------------------------------------------------
  Local Integer OFFSET : [L]OFFSET = 0

  [L]OFFSET = func GET_NUM_VAL(ARGS(ascii('o')), 0)

  # LDB variable for local use
  [LDB]DEBUG_LINE_OFFSET = [L]OFFSET
  # System variable for X3 engine
  If dim([S]dbgLineOffset) > 0
    [S]dbgLineOffset = [L]OFFSET
  Endif

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".DBGP_SET_DLO: offset=" + num$([L]OFFSET) + ", dim=" + num$(dim([S]dbgLineOffset)))
  Endif
End

#**
#* Get source content (used when we don't have source files)
#*
#* @param ARGS the command arguments
#*!
Subprog DBGP_SOURCE_GET(ARGS)
  Value Char ARGS()(97..122)

  Local Integer SRC_BEGIN : [L]SRC_BEGIN = func GET_NUM_VAL(ARGS(ascii('b')), 0)
  Local Integer SRC_END : [L]SRC_END = func GET_NUM_VAL(ARGS(ascii('e')), 0)
  Local Char SRC_URI(250) : [L]SRC_URI = ARGS(ascii('f'))

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".DBGP_SOURCE_GET: source begin=" + num$([L]SRC_BEGIN) +
&      ", end=" + num$([L]SRC_END) + ", uri=" + [L]SRC_URI)
    Call TRACE_APPEND([LDB]DBGP_SRC_LINE)
  Endif

  # base64 encoded line content
  Local Integer LENGTH
  [L]LENGTH = func CORE_B64ENCODE([LDB]DBGP_SRC_LINE, [LDB]DBGP_SRC_LINE_B64, [LDB]DBG_UTF8)
  Call DBGP_ADD_DATA([LDB]DBGP_SRC_LINE_B64)
End

#**
#* Add property node to response xml
#*
#* @param PROP_NAME property name
#* @param CLASS_NAME class name (local, ...)
#* @param DEPTH stack level
#* @param PAGE_NUMBER page number
#* @param APPEND_SUCCESS 1 to indicates if success attribute must be added in response xml, 0
#* otherwise
#*!
Funprog ADD_PROPERTY(PROP_NAME, CLASS_NAME, DEPTH, PAGE_NUMBER, APPEND_SUCCESS)
  Value Char PROP_NAME
  Value Char CLASS_NAME
  Value Integer DEPTH
  Value Integer PAGE_NUMBER
  Value Integer APPEND_SUCCESS

  Local Integer ERR, L
  L = len(PROP_NAME)
  If L = 0 : End -1 : Endif

  Local Char ROOT_NAME(250) : ROOT_NAME = PROP_NAME
  Local Char SUFFIX(250) : SUFFIX = ""
  Local Integer PROP_LEVEL : PROP_LEVEL = 1

  If clalev([LDB]) & dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".ADD_PROPERTY: name=" + PROP_NAME +
&     ", depth=" + num$(DEPTH) +
&     ", page=" + num$(PAGE_NUMBER)
&     )
  Endif

  Local Integer VARDIM
  # try to know if prop_name is an expression or a variable
#  Local Integer I
#  Local Char C(1)
#  For I = 1 To L
#    C = mid$(PROP_NAME, I, 1)
#    If instr(1, "+-/*^?<>!%&|", C)
#    Endif
#  Next I
  VARDIM = func GET_PROP_DIM(DEPTH, PROP_NAME, 1)

  If VARDIM > 1
    Local Integer I,J
    # First get the position of the last part of the qualified name
    Repeat J = I : I = instr(I+1, PROP_NAME, ".") : Until I = 0
    # Then get the position of the parenthesis to get the root name
    I = instr(J+1, PROP_NAME, "(")
    If I > 1
      ROOT_NAME = left$(PROP_NAME, I - 1)
      Local Integer LG
      LG = len(PROP_NAME) - I - 1
      SUFFIX = mid$(PROP_NAME, I + 1, LG)

      # Next level = number of comma + 1 (for number of param) + 1 (to go next level)
      Local Integer CPT : CPT = -1
      Local Integer IDX : IDX = 0
      Repeat IDX = instr(IDX + 1, SUFFIX, ",") : CPT += 1 : Until IDX = 0
      PROP_LEVEL = CPT + 2
    Endif
  Endif

  If clalev([LDB]) & dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".ADD_PROPERTY: prop_level=" + num$(PROP_LEVEL))
  Endif

  If PROP_LEVEL < 0
    PROP_LEVEL = 1
  Endif
  ERR = func ADD_PROP_NODE(0, ROOT_NAME, "", CLASS_NAME, DEPTH, PAGE_NUMBER, SUFFIX, PROP_LEVEL, APPEND_SUCCESS)

End ERR

#**
#* Add property node to response xml
#* @private
#*
#* @param MAX_DEPTH the max depth in recursivity
#* @param PROP_NAME property name
#* @param QUALIFIER the property qualifier
#* @param CLASS_NAME class name (local, ...)
#* @param DEPTH stack level
#* @param PAGE_NUMBER page number
#* @param SUFFIX variable part of name for arrays
#* @param DIM_LEVEL the dim level to work with
#* @param APPEND_SUCCESS 1 to indicates if success attribute must be added in response xml, 0
#* otherwise
#*!
Funprog ADD_PROP_NODE(MAX_DEPTH, PROP_NAME, QUALIFIER, CLASS_NAME, STACK_DEPTH, PAGE_NUMBER, INDEX, DIM_LEVEL,APPEND_SUCCESS)
  Value Integer MAX_DEPTH
  Value Char PROP_NAME, QUALIFIER, CLASS_NAME
  Value Integer STACK_DEPTH, PAGE_NUMBER
  Value Char INDEX
  Value Integer DIM_LEVEL, APPEND_SUCCESS

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".ADD_PROP_NODE(name='"
    Append [LDB]DBG_TRACE, PROP_NAME
    Append [LDB]DBG_TRACE, "', index="
    Append [LDB]DBG_TRACE, INDEX
    Append [LDB]DBG_TRACE, ", qualifier='"
    Append [LDB]DBG_TRACE, QUALIFIER
    Append [LDB]DBG_TRACE, "', class="
    Append [LDB]DBG_TRACE, CLASS_NAME
    Append [LDB]DBG_TRACE, ", stack_depth="
    Append [LDB]DBG_TRACE, num$(STACK_DEPTH)
    Append [LDB]DBG_TRACE, ", page="
    Append [LDB]DBG_TRACE, num$(PAGE_NUMBER)
    Append [LDB]DBG_TRACE, ", dim_level="
    Append [LDB]DBG_TRACE, num$(DIM_LEVEL)
    Append [LDB]DBG_TRACE, ", max_depth="
    Append [LDB]DBG_TRACE, num$(MAX_DEPTH)
    Append [LDB]DBG_TRACE, ")"
    Call TRACE([LDB]DBG_TRACE)

#    If DEPTH = 0
#      [LDB]DBG_TRACE = "... type="
#      Append [LDB]DBG_TRACE, num$(evalue("type(" + PROP_NAME + ")"))
##      Append [LDB]DBG_TRACE, num$(evalue("typeCtx(" + PROP_NAME + "," + num$(DEPTH) + ")"))
##      Append [LDB]DBG_TRACE, num$(typeCtx(PROP_NAME, DEPTH))
#      Call TRACE_APPEND([LDB]DBG_TRACE)
#    Endif
  Endif

  # [LDB]F_MAX_DEPTH MUST be equal to 2 because of a dbpg issue
  If MAX_DEPTH >= [LDB]F_MAX_DEPTH
    End 0
  Endif

  Local Integer LENGTH
  Local Integer VARDIM : [L]VARDIM = 1
  Local Integer MAXIDX
  Local Integer LBOUND : LBOUND = 0
  Local Integer UBOUND : UBOUND = 0
  Local Integer CHILDREN_COUNT : CHILDREN_COUNT = 0

  Local Integer ERR
  Local Integer DBG_ERR
  Local Integer TYPE_NUM : TYPE_NUM = -1
  Local Char TYPE_NAME(30)
  Local Char EXPR_VALUE(250)
  Local Libelle ISNUM

  Local Char FULL_NAME(255)
  FULL_NAME = QUALIFIER + PROP_NAME

  #-------------------------------------------------------------------------
  # Dimension
  #-------------------------------------------------------------------------
  # Number of dimensions
  Local Integer NBDIM
  [L]NBDIM = func GET_PROP_DIM(STACK_DEPTH, FULL_NAME, 0)

  Local Integer HAS_CHILDREN : HAS_CHILDREN = 0
  Local Integer IS_STRUCT : IS_STRUCT = 0
  Local Integer IS_NULL : IS_NULL = 0
  Local Char PARENT(250)

  Onerrgo RECOVERABLE_ERROR
    If not [LDB]DBG_SUPPORT_DBGEVALUE2 #  or (STACK_DEPTH <= 0))
      IS_STRUCT = (evalue("type(" + FULL_NAME + ")") = 524)
    Else
      IS_STRUCT = (dbgEvalue2("type(" + FULL_NAME + ")", STACK_DEPTH) = 524)
    Endif
  Onerrgo

  If IS_STRUCT
    HAS_CHILDREN = 1
    PARENT = "object"
    Onerrgo RECOVERABLE_ERROR
    If not [LDB]DBG_SUPPORT_DBGEVALUE2 # or (STACK_DEPTH <= 0))
      IS_NULL = evalue(FULL_NAME + "=null")
    Else
      IS_NULL = dbgEvalue2(FULL_NAME + "=null", STACK_DEPTH )
    Endif
    If IS_NULL
      VARDIM = 0
    Else
      If [LDB]ENGINE_VERSION < "17r.100"
        VARDIM = evalue(FULL_NAME + ".stcnbs")
      Elsif not [LDB]DBG_SUPPORT_DBGEVALUE2 # or (STACK_DEPTH <= 0))
        VARDIM = evalue(FULL_NAME + ".objectnbs")
      Else
        VARDIM = dbgEvalue2( FULL_NAME + ".objectnbs", STACK_DEPTH )
      Endif
    Endif
    Onerrgo
    CHILDREN_COUNT = VARDIM
  Elsif left$(FULL_NAME, 1) = "[" and right$(FULL_NAME, len(FULL_NAME)) = "]"
    Onerrgo ADD_PROP_NODE_ERROR
    If not [LDB]DBG_SUPPORT_DBGEVALUE2 # or (STACK_DEPTH <= 0))
      HAS_CHILDREN = evalue("clalev(" + FULL_NAME + ")")
    Else
      HAS_CHILDREN = dbgEvalue2("clalev(" + FULL_NAME + ")", STACK_DEPTH )
    Endif
    If HAS_CHILDREN
        PARENT = "object"
        If not [LDB]DBG_SUPPORT_DBGEVALUE2 # or (STACK_DEPTH <= 0))
          VARDIM = evalue("clanbs(" + FULL_NAME + ", 1)")
        Else
          VARDIM = dbgEvalue2("clanbs(" + FULL_NAME + ", 1)", STACK_DEPTH )
        Endif
        CHILDREN_COUNT = VARDIM
    Endif
    Onerrgo # ADD_PROP_NODE_ERROR
  Endif

  If HAS_CHILDREN = 0
    If DIM_LEVEL > [L]NBDIM
      VARDIM = 1
      UBOUND = 0
    Else
      [L]VARDIM = func GET_PROP_DIM(STACK_DEPTH, FULL_NAME, DIM_LEVEL)
      UBOUND = VARDIM - 1
      If [L]VARDIM > 1 or [L]NBDIM > DIM_LEVEL
        HAS_CHILDREN = 1
        [L]PARENT = "array"
        LBOUND = func GET_PROP_DIM(STACK_DEPTH, FULL_NAME, 0 - DIM_LEVEL)
        UBOUND = LBOUND + VARDIM - 1

        # ugly hack to guess if it's an array with variable dimension
        If VARDIM = 32767
          MAXIDX = func GET_PROP_MAXIDX(STACK_DEPTH, FULL_NAME, DIM_LEVEL)
          If MAXIDX >= 0
            UBOUND = MAXIDX
          Endif
        Endif
      Endif
      CHILDREN_COUNT = UBOUND - LBOUND  + 1
      If CHILDREN_COUNT > [LDB]F_MAX_CHILDREN
        CHILDREN_COUNT = [LDB]F_MAX_CHILDREN
        UBOUND = LBOUND + CHILDREN_COUNT - 1
      Endif
    Endif
  Endif

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE("..ADD_PROP_NODE dim=" + num$([L]VARDIM)
&     + ", max_idx=" + num$(MAXIDX)
&     + ", hasChildren=" + num$(HAS_CHILDREN)
&     + ", isStruct=" + num$(IS_STRUCT)
&     + ", isNull=" + num$(IS_NULL)
&     + ", children_count=" + num$(CHILDREN_COUNT)
&     + ", ubound=" + num$(UBOUND)
&     + ", lbound=" + num$(LBOUND)
&     + ", parent=" + [L]PARENT)
  Endif
  #-------------------------------------------------------------------------

  # Format full name like MY_VAR(1,3,8)
  If INDEX <> ""
    FULL_NAME += "(" + INDEX + ")"
    Local Integer DIMVAR
    DIMVAR = func GET_PROP_DIM(STACK_DEPTH, FULL_NAME, 0)
#    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
#      Call TRACE(".ADD_PROP_NODE property=" + FULL_NAME + "dim=" + num$(DIMVAR))
#    Endif
    If DIMVAR < 0
      End 0
    Endif
  Endif

  If HAS_CHILDREN
    # property is a parent, let's build xml
    Call DBGP_ADD_NODE("property")
    If INDEX = ""
      Call DBGP_ADD_ATTRIBUTE("name", PROP_NAME)
    Else
      Call DBGP_ADD_ATTRIBUTE("name", INDEX)
    Endif
    Call DBGP_ADD_ATTRIBUTE("fullname", FULL_NAME)
    Call DBGP_ADD_ATTRIBUTE("children", "1")
    Call DBGP_ADD_ATTRIBUTE("numchildren", num$([L]CHILDREN_COUNT))
    Call DBGP_ADD_ATTRIBUTE("type", [L]PARENT)
    Call DBGP_ADD_ATTRIBUTE("pagesize", num$([LDB]F_MAX_CHILDREN))
    If PAGE_NUMBER > -1
      Call DBGP_ADD_ATTRIBUTE("page", num$(PAGE_NUMBER))
    Endif

#    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
#      Call TRACE(".ADD_PROP_NODE MAX_DEPTH=" + num$(MAX_DEPTH)+ ", maxDepth=" +
# num$([LDB]F_MAX_DEPTH))
#    Endif

    Local Integer I
    Local Integer CHILD_DIM_LEVEL : [L]CHILD_DIM_LEVEL = DIM_LEVEL + 1
    Local Char CHILD_SUFFIX(250)

    #---------------------------------------------------------------------------
    If [L]PARENT = "array"
    #---------------------------------------------------------------------------
      Local Integer STARTIDX
      Local Integer ENDIDX
      [L]STARTIDX = LBOUND
      [L]ENDIDX = UBOUND

      If ENDIDX - STARTIDX > [LDB]F_MAX_CHILDREN - 1
        ENDIDX = STARTIDX + [LDB]F_MAX_CHILDREN - 1
      Endif

      # Now consider page number
      If PAGE_NUMBER > -1
        Local Integer PAGE_ENDIDX
        [L]STARTIDX = PAGE_NUMBER * [LDB]F_MAX_CHILDREN + [L]STARTIDX
        [L]PAGE_ENDIDX = [L]STARTIDX + [LDB]F_MAX_CHILDREN - 1
        [L]ENDIDX = min([L]ENDIDX, [L]PAGE_ENDIDX)
      Endif

#        Local Char ROOT_NAME(250)
#        Local Integer BPOS : [L]BPOS = instr(0, FULL_NAME, ")")
#        If ([L]BPOS > 0)
#          [L]ROOT_NAME = left$(FULL_NAME, [L]BPOS - 1) + ","
#        Else
#          [L]ROOT_NAME = FULL_NAME + "("
#        Endif

      For [L]I = [L]STARTIDX To [L]ENDIDX
        If INDEX = ""
          [L]CHILD_SUFFIX = num$([L]I)
        Else
          [L]CHILD_SUFFIX = INDEX + "," + num$([L]I)
        Endif
        [L]ERR = func ADD_PROP_NODE(MAX_DEPTH + 1, PROP_NAME, QUALIFIER, CLASS_NAME, STACK_DEPTH, PAGE_NUMBER, [L]CHILD_SUFFIX, [L]CHILD_DIM_LEVEL, APPEND_SUCCESS)
      Next [L]I
    Else
      #---------------------------------------------------------------------------
      # [L]PARENT = "object" # Table, Mask or Object(Struct)
      #---------------------------------------------------------------------------
      Local Char VAR_EXPR_PFX(250)
      Local Char VAR_QUALIFIER(250)
      Local Char VAR_NAME(250)

      VAR_QUALIFIER = FULL_NAME
      If IS_STRUCT
        If [LDB]ENGINE_VERSION < "17r.100"
          VAR_EXPR_PFX = FULL_NAME + ".stcvar("
        Else
          VAR_EXPR_PFX = FULL_NAME + ".objectvar("
        Endif
        VAR_QUALIFIER += "."
      Else # Table or Mask
        VAR_EXPR_PFX = "clavar(" + FULL_NAME + ","
      Endif
      For [L]I = 1 To CHILDREN_COUNT
        Raz DBG_ERR
        Onerrgo RECOVERABLE_ERROR
        If not [LDB]DBG_SUPPORT_DBGEVALUE2 # or (STACK_DEPTH <= 0))
          VAR_NAME = evalue(VAR_EXPR_PFX + num$([L]I) + ")")
        Else
          VAR_NAME = dbgEvalue2(VAR_EXPR_PFX + num$([L]I) + ")", STACK_DEPTH )
        Endif
        Onerrgo
        If DBG_ERR = 0
          [L]ERR = func ADD_PROP_NODE(MAX_DEPTH + 1, VAR_NAME, VAR_QUALIFIER, CLASS_NAME, STACK_DEPTH, PAGE_NUMBER, "", DIM_LEVEL, APPEND_SUCCESS)
        Endif
      Next [L]I
    Endif

    Call DBGP_CLOSE_NODE()
    [L]ERR = 0

  Else
#    If [L]VARDIM = -1 # expressions
    Call ADD_PROP_XML(FULL_NAME, QUALIFIER, INDEX, STACK_DEPTH, CLASS_NAME, APPEND_SUCCESS)
    [L]ERR = 0
  Endif

End [L]ERR

$ADD_PROP_NODE_ERROR
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Append [LDB]DBG_TRACE, "["-errmes$(errn)-errp+"("+num$(errl)+") errm='"+errm+"']"
  Endif
  HAS_CHILDREN = 0
Resume

$RECOVERABLE_ERROR
#  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
#    Append [LDB]DBG_TRACE, "["-errmes$(errn)-errp+"("+num$(errl)+") errm='"+errm+"']"
#  Endif
  DBG_ERR = errn
Resume

#**
#* Get dimension of a variable, depending on debbuger version (light or full).
#* With light debugger, there is only one stack depth
#*
#* @param PROP_NAME variable name
#* @param STACK_DEPTH
#*!
Funprog GET_PROP_DIM(STACK_DEPTH, PROP_NAME, DIM_LEVEL)
  Value Integer STACK_DEPTH
  Value Char PROP_NAME
  Value Integer DIM_LEVEL

  Local Libelle IS_CLASS
  IS_CLASS = left$(PROP_NAME, 1) = "[" & right$(PROP_NAME, len(PROP_NAME)) = "]"

  If clalev([LDB]) & dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".GET_PROP_DIM(stack_depth=" + num$(STACK_DEPTH) + ", name='" + PROP_NAME +
&       "', level=" + num$(DIM_LEVEL) + ") : is_class=" + num$(IS_CLASS))
  Endif

  If IS_CLASS : End -1 : Endif

  Local Integer PROP_DIM
  Local Char EXPR(250)
  Onerrgo GET_PROP_DIM_ERR
  If [LDB]DBG_SUPPORT_DBGEVALUE2
    [L]PROP_DIM = dbgEvalue2("dim(" + PROP_NAME + "," + num$(DIM_LEVEL) + ")", STACK_DEPTH )
  Elsif (STACK_DEPTH > 0) & clalev([LDB]) & [LDB]DBG_FULL_DEBUG
    [L]PROP_DIM = dimctx(STACK_DEPTH, PROP_NAME, DIM_LEVEL)
  Else
    [L]PROP_DIM = evalue("dim(" + PROP_NAME + "," + num$(DIM_LEVEL) + ")")
  Endif
  Onerrgo
  If clalev([LDB]) & dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".GET_PROP_DIM -> dim=" + num$(PROP_DIM))
  Endif
End [L]PROP_DIM

$GET_PROP_DIM_ERR
  [L]PROP_DIM = -1
  Gosub TRACE_WHERE
Resume

#**
#* Get dimension of a variable, depending on debugger version (light or full).
#* With light debugger, there is only one stack depth
#*
#* @param PROP_NAME variable name
#* @param STACK_DEPTH
#*!
Funprog GET_PROP_MAXIDX(STACK_DEPTH, PROP_NAME, DIM_LEVEL)
  Value Integer STACK_DEPTH
  Value Char PROP_NAME
  Value Integer DIM_LEVEL

#  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
#    Call TRACE(".GET_PROP_MAXIDX(depth=" + num$(STACK_DEPTH) + ", name='" + PROP_NAME +
#&       "', level=" + num$(DIM_LEVEL) + ")")
#  Endif

  Local Integer MAXIDX
  Onerrgo GET_MAXIDX_ERR
#  If [LDB]DBG_FULL_DEBUG
#    [L]MAXIDX = MAXCTXTAB(STACK_DEPTH, PROP_NAME)
#  Else
  If (not [LDB]DBG_SUPPORT_DBGEVALUE2) or ([LDB]DBG_FULL_DEBUG = 0) #or (STACK_DEPTH <= 0)
    [L]MAXIDX = evalue("maxtab(" + PROP_NAME + ")")
  Else
    [L]MAXIDX = dbgEvalue2("maxtab(" + PROP_NAME + ")", STACK_DEPTH )
  Endif
#  Endif
  Onerrgo
#  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
#    Call TRACE(".GET_PROP_MAXIDX -> dim=" + num$(MAXIDX))
#  Endif
End [L]MAXIDX

$GET_MAXIDX_ERR
  [L]MAXIDX = -1
  Gosub TRACE_WHERE
Resume

#**
#* Get property xml (from engine with full debugger, or from here with light debugger)
#*
#* @param PROP_NAME variable name
#* @param QUALIFIER variable name
#* @param STACK_DEPTH depth
#*!
Funprog ADD_PROP_XML(PROP_NAME, QUALIFIER, INDEX, STACK_DEPTH, CLASS_NAME, APPEND_SUCCESS)
  Value Char PROP_NAME, QUALIFIER, INDEX
  Value Integer STACK_DEPTH
  Value Char CLASS_NAME
  Value Integer APPEND_SUCCESS

  Local Integer ERR : [L]ERR = 0
  Local Char PNAME(255) : PNAME = PROP_NAME
  If find(tolower(PNAME), [LDB]DBG_EXPR_VAR) > 0
      PNAME = "[LDB]DBG_" + toupper(PNAME)
  Endif

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".ADD_PROP_XML(name='" + PROP_NAME + "', qualifier='" + QUALIFIER + "', index='" + INDEX +
&       "', stack_depth=" + num$(STACK_DEPTH) + ", class='" + CLASS_NAME + "', append=" + num$(APPEND_SUCCESS) + ")")
  Endif

  If [LDB]DBG_FULL_DEBUG
    Onerrgo ERR_ADD_PROP_XML
    [L]ERR = dbgEvalue(PNAME, STACK_DEPTH, [LDB]DBG_PROP_XML)
    Onerrgo
#    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
#      Call TRACE_APPEND([LDB]DBG_PROP_XML)
#    Endif

    If APPEND_SUCCESS
      Call ADD_PROP_EVAL_SUCCESS([L]ERR)
    Endif

    If [L]ERR = 0
      Local Integer POS, TLEN
      If QUALIFIER <> ""
        # remove qualifier
        TLEN = len(QUALIFIER)
        POS = instr(1, [LDB]DBG_PROP_XML, ' name="' + QUALIFIER)
        If POS
          [LDB]DBG_PROP_XML = left$([LDB]DBG_PROP_XML, POS-1) + ' name="' + right$([LDB]DBG_PROP_XML, POS + 7 + TLEN)
        Endif
      Endif
      # remove undefined key
      POS = instr(1, [LDB]DBG_PROP_XML, ' key="????"')
      TLEN = len(' key="????"')
      If POS
        [LDB]DBG_PROP_XML = left$([LDB]DBG_PROP_XML, POS-1) + right$([LDB]DBG_PROP_XML, POS + TLEN)
      Endif

      Call DBGP_ADD_XML([LDB]DBG_PROP_XML)
    Else
      Local Char PROP_NAME_XML(250)
      PROP_NAME_XML = func TRANS_XML(PROP_NAME)
      Call DBGP_ADD_NODE("property")
      Call DBGP_ADD_ATTRIBUTE("name", PROP_NAME_XML)
      Call DBGP_ADD_ATTRIBUTE("fullname", QUALIFIER + PROP_NAME_XML)
      Call DBGP_CLOSE_NODE()
    Endif
  Else
    # Format property xml $OPX
    If PROP_NAME <> "" and PROP_NAME <> "DBGP_XMLRESP"

      #Local Integer TYPE_NUM : TYPE_NUM = -1
      Local Char TYPE_NAME(30)
      Local Char EXPR_VALUE(250)
      Local Libelle ISNUM
      Local Char OUT(250)(1)
      Local Integer LENGTH

      Onerrgo ERR_ADD_PROP_XML
      [L]ERR = func GET_TYPE(PROP_NAME, [L]TYPE_NAME)
      #[L]TYPE_NUM = func GET_TYPE_NUM([L]TYPE_NAME)

      [L]ERR = func EVAL_EXPR3(PNAME, [L]EXPR_VALUE, [L]ISNUM)
      Onerrgo

      If APPEND_SUCCESS
        Call ADD_PROP_EVAL_SUCCESS([L]ERR)
      Endif

      Local Char PROP_NAME_XML(250)
      PROP_NAME_XML = func TRANS_XML(PROP_NAME)

      Call DBGP_ADD_NODE("property")
      If INDEX = ""
        Call DBGP_ADD_ATTRIBUTE("name", PROP_NAME_XML)
      Else
        Call DBGP_ADD_ATTRIBUTE("name", INDEX)
      Endif
      Call DBGP_ADD_ATTRIBUTE("fullname", QUALIFIER + PROP_NAME_XML)

      If [L]TYPE_NAME <> ""
        Call DBGP_ADD_ATTRIBUTE("type", [L]TYPE_NAME)
      Else
        Call DBGP_ADD_ATTRIBUTE("type", "Char")
      Endif

      If CLASS_NAME <> ""
        Call DBGP_ADD_ATTRIBUTE("key", CLASS_NAME) # "facet" not used ?...
      Else
        Call DBGP_ADD_ATTRIBUTE("key", "local")
      Endif

    #    If TYPE_NUM = 522 or TYPE_NUM = 523
    #      Local Char OUT(250)(1)
    #      # if this is binary data, it should be base64 encoded with this attribute set
    #      Call DBGP_ADD_ATTRIBUTE("encoding", "base64")
    #      Call BASE64_ENCODE([L]EXPR_VALUE, OUT)
    #      Setlob CLB_DATA With OUT(0)
    #      Call DBGP_ADD_ATTRIBUTE("size", num$([L]LENGTH))
    #      Call DBGP_ADD_DATA([L]UTF8_VAL)
    #    Else


      If [L]ERR = 0
        [L]LENGTH = func UTF8_ENCODE2([L]EXPR_VALUE, [LDB]CLB_TEMP)

        Call WBASE64_ENCODE([LDB]CLB_TEMP, [L]OUT)
        Setlob [LDB]CLB_TEMP With [L]OUT(0)
        [L]LENGTH = len([LDB]CLB_TEMP)

        Call DBGP_ADD_ATTRIBUTE("encoding", "base64")
        Call DBGP_ADD_ATTRIBUTE("size", num$([L]LENGTH))
        Call DBGP_ADD_DATA([LDB]CLB_TEMP)
      Endif

      Call DBGP_CLOSE_NODE()

    Endif
  Endif

End

# Error on expression or variable evaluation
$ERR_ADD_PROP_XML
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
   [LDB]DBG_TRACE = ".ERR_ADD_PROP_XML: Failed to evaluate '" + PROP_NAME + "'"
    Call TRACE([LDB]DBG_TRACE)
    Gosub TRACE_WHERE
  Endif

  [L]ERR = errn
  If dim([LDB]DBG_PROP_XML) > 0
    Raz [LDB]DBG_PROP_XML
  Endif
Resume

Subprog ADD_PROP_EVAL_SUCCESS(ERR_CODE)
  Value Integer ERR_CODE
#  If ERR_CODE = 0
#    Call DBGP_ADD_ATTRIBUTE("success", "1")
#  Else
#    Call DBGP_ADD_ATTRIBUTE("success", "0")
#  Endif
  If ERR_CODE <> 0
    Call DBGP_ADD_ATTRIBUTE("success", "0")
  Endif
End


#**
#* Build the DBGP 'eval' response
#*
#* @param DATA the data to evaluate
#*!
Subprog DBGP_EVAL(DATA)
  Value Clbfile DATA()

  Local Char EXPR(255)
  Local Clbfile EXPR_CLB(6)
  Local Integer ERR_CODE
  Local Integer LENGTH
  Local Char OUT(250)(1)
  Local Integer ERRCODE, TRUSTED

  TRUSTED=1
  Onerrgo EVAL_EXPR_ERROR
    TRUSTED=func ADS_TOOL.ISTRUSTEDENV
  Onerrgo
  If not TRUSTED
    Call DBGP_ADD_ATTRIBUTE("success", "0")
    Call DBGP_ADD_NODE("error")
      Call DBGP_ADD_ATTRIBUTE("code", "500")
      Call DBGP_ADD_ATTRIBUTE("apperr", "")
      Call DBGP_ADD_NODE("message")
        [LDB]CLB_TEMP = "Forbidden"
        Call DBGP_ADD_DATA([LDB]CLB_TEMP)
      Call DBGP_CLOSE_NODE()
    Call DBGP_CLOSE_NODE()
    End
  Endif

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE('.DBGP_EVAL: DATA="' + DATA + '" depth=' + num$([LDB]CURRENT_STACK))
  Endif

  # [LDB]DBG_UTF8 format for DLTK framework
  LENGTH = func CORE_B64DECODE(DATA, [L]EXPR_CLB, [LDB]DBG_UTF8)
  Setlob [L]OUT With [L]EXPR_CLB
  EXPR = vireblc([L]OUT(0), 2)

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE('.DBGP_EVAL before parse: expr="' + [L]EXPR + '"')
  Endif

  Call PARSE_EXPR(EXPR)

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE('.DBGP_EVAL after parse: expr="' + [L]EXPR + '"')
  Endif
  [L]ERR_CODE = func ADD_PROPERTY([L]EXPR, "", [LDB]CURRENT_STACK, 0, 1)
End

Subprog PARSE_EXPR(EXPR)
  Variable Char EXPR()

  Onerrgo ERR_IGNORE
  If left$(EXPR, 1) = "="
    Local Char LVALUE(255), RVALUE(255)
    Call PARSE_ASSIGN(EXPR, LVALUE, RVALUE)
    Local Char STR(250)
#    STR = evalue('func FSET_VALUE("' + EXPR + '", ' + VAR_VALUE + ')')
    STR = func FSET_VALUE(LVALUE, evalue(RVALUE))
    EXPR = LVALUE
  Else
    Local Integer I
    I = find(tolower(EXPR), [LDB]DBG_EXPR_VAR)
    If I > 0
        EXPR = "[LDB]DBG_" + toupper(EXPR)
    Endif
  Endif
  Onerrgo
End

#**
#* Parses an assign expression and sets the lvalue and rvalue
#*
#* @param EXPR
#* @param LVALUE
#* @param RVALUE
#*!
Subprog PARSE_ASSIGN(EXPR, LVALUE, RVALUE)
  Variable Char LVALUE
  Variable Char RVALUE
  Local Integer L, I, ST
  Local Char C(1)

  L = len(EXPR)
  For I = 1 To L
    C = mid$(EXPR, I, 1)
    Case ST
      When 0 : # lookup expression start
        If C = "=" : ST = 1 : Endif
      When 1 : # in assign, lookup lvalue start
        If C <> " "
          LVALUE += C
          ST = 2
        Endif
      When 2 : # in lvalue
        If C = " "
          ST = 3
        Else
          LVALUE += C
        Endif
      When 3 : # lookup rvalue start
        If C <> " "
          RVALUE += C
          ST = 4
        Endif
      When 4 : # in rvalue
          RVALUE += C
    Endcase
  Next I
  RVALUE = vireblc(RVALUE, 1)
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".PARSE_ASSIGN: expr=" + EXPR)
    Call TRACE_APPEND("LVALUE=[" + LVALUE + "]")
    Call TRACE_APPEND("RVALUE=[" + RVALUE + "]")
  Endif
End

Funprog TEST_PARSE(EXPR)
  Local Char LVALUE(255), RVALUE(255)
  Call PARSE_ASSIGN(EXPR, LVALUE, RVALUE)

End EXPR + " => [" + LVALUE + "] [" + RVALUE + "]"

#**
#* Build the DBGP 'property_get' response
#*
#* @param ARGS the command arguments
#*!
Subprog DBGP_PROP_GET(ARGS)
  Value Char ARGS()(97..122)

  #---------------------------------------------------------------
  # stack depth:
  #   optional, debugger engine should assume zero if not provided
  #---------------------------------------------------------------
  Local Integer DEPTH : [L]DEPTH = func GET_NUM_VAL(ARGS(ascii('d')), [LDB]TOP_LEVEL)
  #---------------------------------------------------------------
  # context id:
  #   optional, retrieved by context-names,
  #   debugger engine should assume zero if not provided
  #---------------------------------------------------------------
  Local Integer CTX_ID : [L]CTX_ID = func GET_NUM_VAL(ARGS(ascii('c')), 0)
  #---------------------------------------------------------------
  # property long name:
  #   required
  #---------------------------------------------------------------
  Local Char LONG_NAME(250) : [L]LONG_NAME = ARGS(ascii('n'))
  #---------------------------------------------------------------
  # max data size to retrieve:
  #   optional
  #---------------------------------------------------------------
  #Local Integer MAX_SIZE : [L]MAX_SIZE = val(ARGS(ascii('m')))
  #---------------------------------------------------------------
  # data page:
  #   property_get, property_value: optional for arrays, hashes, objects, etc.
  #   property_set: not required, debugger engine should assume zero if not provided
  #---------------------------------------------------------------
  Local Integer PAGE_NUMBER : [L]PAGE_NUMBER = func GET_NUM_VAL(ARGS(ascii('p')), 0)

  #---------------------------------------------------------------
  # property key as retrieved in a property element:
  #   optional, used for property_get of children and property_value,
  #   required if it was provided by the debugger engine.
  #---------------------------------------------------------------
  #Local Char PROP_KEY(20) : PROP_KEY = ARGS(ascii('k'))
  #---------------------------------------------------------------
  # property address as retrieved in a property element:
  #   optional, used for property_set/value
  #---------------------------------------------------------------
  #Local Char PROP_ADDR(20) : PROP_ADDR = ARGS(ascii('a'))

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".DBGP_PROP_GET(name='" + [L]LONG_NAME + "', depth=" + num$([L]DEPTH) + ", page=" +num$([L]PAGE_NUMBER) + ")")
  Endif

  If [L]LONG_NAME <> ""
&      and !find(tolower(LONG_NAME), "typectx", "dimctx", "type", "dim")

    Local Char CLASS_NAME(20)
    If [L]CTX_ID = [LDB]DBG_CTX_LOCAL
      [L]CLASS_NAME = "local"
    Elsif [L]CTX_ID = [LDB]DBG_CTX_GLOBAL
      [L]CLASS_NAME = "global"
    Else
      [L]CLASS_NAME = ""
    Endif
    Local Integer RET
    [L]RET = func ADD_PROPERTY([L]LONG_NAME, [L]CLASS_NAME, [L]DEPTH, [L]PAGE_NUMBER, 0)
  Endif

End


#**
#* Gets the properties of a variable
#* @internal
#*
#* @param EXPR (in)
#* @param TYPE_NAME (out)
#*!
Funprog GET_TYPE(EXPR, TYPE_NAME)
  Value Char EXPR()
  Variable Char TYPE_NAME()

  Local Integer NBDIM
  Local Integer ARR_DIM(1..4)
  Local Integer ARR_IND(1..4)
  Local Libelle IS_BINARY
  Local Integer RET

  [L]RET = func VAR_INFO(EXPR, TYPE_NAME, [L]NBDIM, [L]ARR_DIM, [L]ARR_IND, [L]IS_BINARY)
  If RET = 0
    Local Integer POS
    [L]POS = instr(0, TYPE_NAME, "(")
    If [L]POS > 0
      TYPE_NAME = left$(TYPE_NAME, [L]POS - 1)
    Endif
  Else
    RET = -1
  Endif

End [L]RET

#**
#* Gets type name
#* @internal
#*
#* @param TYPE_NUM
#*!
Funprog GET_TYPE_NAME(TYPE_NUM)
  Value Integer TYPE_NUM()
  Local Char TYPE_NAME(20)

  Case TYPE_NUM
    When -1 : # Type does not exist
      TYPE_NAME = ""
    When 1
      TYPE_NAME = "Libelle"
    When 2
      TYPE_NAME = "Shortint"
    When 3
      TYPE_NAME = "Date"
    When 4
      TYPE_NAME = "Integer"
    When 5
      TYPE_NAME = "Float"
    When 6
      TYPE_NAME = "Double"
    When 7
      TYPE_NAME = "Decimal"
    When 8
      TYPE_NAME = "T8"
    When 9
      TYPE_NAME = "IbmDCB"
    When 522
      TYPE_NAME = "Blbfile"
      IS_BINARY = 1
    When 523
      TYPE_NAME = "Clbfile"
    When 524
      TYPE_NAME = "Object"
    When 525
      TYPE_NAME = "Uuident"
    When 526
      TYPE_NAME = "Datetime"
    When Default : # Alpha : len = type(...) - 10
      TYPE_NAME = "Char(" + num$(TYPE_NUM - 10) + ")"
  Endcase

End TYPE_NAME

#**
#* Gets type number
#* @internal
#*
#* @param TYPE_NAME
#*!
Funprog GET_TYPE_NUM(TYPE_NAME)
  Value Char TYPE_NAME()
  Local Integer TYPE_NUM

  Local Char TYPE_(50)
  Local Integer POSIT

  [L]POSIT = instr(0, TYPE_NAME, "(")
  If [L]POSIT > 0
    [L]TYPE_ = left$(TYPE_NAME , [L]POSIT - 1)
  Else
    [L]TYPE_ = TYPE_NAME
  Endif

  Case TYPE_
    When "" : # Type does not exist
      TYPE_NUM = -1
    When "Libelle"
      TYPE_NUM = 1
    When "Shortint"
      TYPE_NUM = 2
    When "Date"
      TYPE_NUM = 3
    When "Integer"
      TYPE_NUM = 4
    When "Float"
      TYPE_NUM = 5
    When "Double"
      TYPE_NUM = 6
    When "Decimal"
      TYPE_NUM = 7
    When "T8"
      TYPE_NUM = 8
    When "IbmDCB"
      TYPE_NUM = 9
    When "Blbfile"
      TYPE_NUM = 522
    When "Clbfile"
      TYPE_NUM = 523
    When "Object"
      TYPE_NUM = 524
    When Default : # Alpha : len = type(...) - 10
      #TYPE_NUM = "Char(" + num$(TYPE_NUM - 10) + ")"
      TYPE_NUM = 10
  Endcase

End TYPE_NUM

#**
#* Gets the properties of a variable
#* @internal
#*
#* @param LONG_NAME (in)
#* @param TYPE_NAME (out)
#* @param NBDIM (out)
#* @param ARR_DIM (out)
#* @param ARR_IND (out)
#* @param IS_BINARY (out)
#*!
Funprog VAR_INFO(LONG_NAME, TYPE_NAME, NBDIM, ARR_DIM, ARR_IND, IS_BINARY)
  Value Char LONG_NAME()
  Variable Char TYPE_NAME()
  Variable Integer NBDIM
  Variable Integer ARR_DIM(1..)
  Variable Integer ARR_IND(1..)
  Variable Libelle IS_BINARY

  Local Integer RET
  Onerrgo ERR_VAR_INFO
  RET = func VAR_INFO_(LONG_NAME, TYPE_NAME, NBDIM, ARR_DIM, ARR_IND, IS_BINARY)
  Onerrgo
End RET

$ERR_VAR_INFO
RET = errn
Resume

#**
#* Gets the properties of a variable
#* @private
#*
#* @param LONG_NAME (in)
#* @param TYPE_NAME (out)
#* @param NBDIM (out)
#* @param ARR_DIM (out)
#* @param ARR_IND (out)
#* @param IS_BINARY (out)
#*!
Funprog VAR_INFO_(VAR_NAME, TYPE_NAME, NBDIM, ARR_DIM, ARR_IND, IS_BINARY)
  Value Char VAR_NAME()
  Variable Char TYPE_NAME()
  Variable Integer NBDIM
  Variable Integer ARR_DIM(1..)
  Variable Integer ARR_IND(1..)
  Variable Libelle IS_BINARY

  IS_BINARY = 0
  Local Char DIM_EXT(50): DIM_EXT = ""
  Local Integer I
  NBDIM = evalue("dim(" + VAR_NAME + ",0)")
  For I = 1 To NBDIM
    ARR_DIM(I) = evalue("dim(" + VAR_NAME + "," + num$(I) +")")
    ARR_IND(I) = evalue("dim(" + VAR_NAME + ",-" + num$(I) +")")
    If I = NBDIM & ARR_DIM = 1
      # do not append mono dimension
    Else
    DIM_EXT += "("
    If ARR_IND(I) > 0
      DIM_EXT += num$(ARR_IND(I)) + ".." + num$(ARR_DIM(I) + ARR_IND(I))
    Else
      DIM_EXT += num$(ARR_DIM(I))
    Endif
    DIM_EXT += ")"
    Endif
  Next I

  Local Integer TYPE_ID
  TYPE_ID = evalue("type(" + VAR_NAME + ")")
  Case TYPE_ID
    When -1 : # variable does not exist
      TYPE_NAME = ""
    When 1
      TYPE_NAME = "Libelle"
    When 2
      TYPE_NAME = "Shortint"
    When 3
      TYPE_NAME = "Date"
    When 4
      TYPE_NAME = "Integer"
    When 5
      TYPE_NAME = "Float"
    When 6
      TYPE_NAME = "Double"
    When 7
      TYPE_NAME = "Decimal"
    When 8
      TYPE_NAME = "T8"
    When 9
      TYPE_NAME = "IbmDCB"
    When 522
      TYPE_NAME = "Blbfile"
      IS_BINARY = 1
    When 523
      TYPE_NAME = "Clbfile"
    When 524
      TYPE_NAME = "Object"
    When 525
      TYPE_NAME = "Uuident"
    When 526
      TYPE_NAME = "Datetime"
    When Default : # Alpha : len = type(...) - 10
      TYPE_NAME = "Char(" + num$(TYPE_ID - 10) + ")"
  Endcase

  TYPE_NAME += DIM_EXT
End 0

#**
#* Build the DBGP 'property_set' response
#*
#* @param ARGS the command arguments
#*!
Subprog DBGP_PROP_SET(ARGS, DATA)
  Value Char ARGS()(97..122)
  Value Clbfile DATA()

  # stack depth:
  #   optional, debugger engine should assume zero if not provided
  Local Integer DEPTH : [L]DEPTH = func GET_NUM_VAL(ARGS(ascii('d')), [LDB]TOP_LEVEL)
  # context id:
  #   optional, retrieved by context-names,
  #   debugger engine should assume zero if not provided
  Local Integer CTX_ID : [L]CTX_ID = func GET_NUM_VAL(ARGS(ascii('c')), 0)
  # property long name:
  #   required
  Local Char VAR_NAME(250) : VAR_NAME = ARGS(ascii('n'))
  # max data size to retrieve:
  #   optional
  Local Integer MAX_SIZE : MAX_SIZE = func GET_NUM_VAL(ARGS(ascii('m')), 0)
  # data type:
  #   property_set only, optional
  Local Char DATA_TYPE(50) : DATA_TYPE = ARGS(ascii('t'))
  # data page:
  #   property_get, property_value: optional for arrays, hashes, objects, etc.
  #   property_set: not required, debugger engine should assume zero if not provided
  Local Char DATA_PAGE(20) : DATA_PAGE = ARGS(ascii('p'))
  # property key as retrieved in a property element:
  #   optional, used for property_get of children and property_value,
  #   required if it was provided by the debugger engine.
  Local Char PROP_KEY(20) : PROP_KEY = ARGS(ascii('k'))
  # property address as retrieved in a property element:
  #   optional, used for property_set/value
  Local Char PROP_ADDR(20) : PROP_ADDR = ARGS(ascii('a'))

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".DBGP_PROP_SET:"
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE, "depth", num$([L]DEPTH))
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE, "name", [L]VAR_NAME)
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE, "type", [L]DATA_TYPE)
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE, "max", num$([L]MAX_SIZE))
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE, "page", [L]DATA_PAGE)
    Call TRACE([LDB]DBG_TRACE)
  Endif

  Local Clbfile OUTCLB(6)
  Local Integer LENGTH
  [L]LENGTH = func CORE_B64DECODE(DATA, [L]OUTCLB, [LDB]DBG_ASCII)

#  Local Char CDATA(250)(1)
#  Setlob CDATA With OUTCLB

  Call SET_VALUE(VAR_NAME, OUTCLB)
End

Subprog SET_VALUE(VAR_NAME, VAR_VALUE)
  Value Char VAR_NAME()

  RES__ = func SET_(VAR_NAME, VAR_VALUE)
  Kill RES__
End

Funprog FSET_VALUE(VAR_NAME, VAR_VALUE)
  Value Char VAR_NAME()

  RES__ = func SET_(VAR_NAME, VAR_VALUE)
  Kill RES__
End ""

Funprog SET_(VAR_NAME, VAR_VALUE)
  Value Char VAR_NAME()

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".SET_:"
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE, "VAR_NAME", VAR_NAME)
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE, "VAR_VALUE", VAR_VALUE)
    Call TRACE([LDB]DBG_TRACE)
  Endif

  Local Integer TYPE_ID
  TYPE_ID = evalue("type(" + VAR_NAME + ")")
  Case TYPE_ID
    When -1 : # variable does not exist
    When 1, 2, 4, 5, 6, 7 : # Libelle, Shortint, Integer, Float, Double, Decimal
      Call SET_NUMBER(VAR_NAME, VAR_VALUE)
    When 3 : # Date
      Assign VAR_NAME With evalue(VAR_VALUE)
    When 8 : # T8
    When 9 : # IbmDCB
    When 522 : # Blbfile
    When 523 : # Clbfile
      Call SET_STRING(VAR_NAME, VAR_VALUE)
    When 524 : # Object
      # not supported
    When 525 : # Uuident
      Assign VAR_NAME With evalue(VAR_VALUE)
    When 526 : # Datetime
      Assign VAR_NAME With evalue(VAR_VALUE)
    When Default : # Alpha
      Call SET_STRING(VAR_NAME, VAR_VALUE)
  Endcase

End evalue(VAR_NAME)

Subprog SET_STRING(VAR_NAME, VAR_VALUE)
  Value Char VAR_NAME()

  Case type(VAR_VALUE)
    When -1 : # variable does not exist
    When 1, 2, 4, 5, 6, 7 : # Libelle, Shortint, Integer, Float, Double, Decimal
      Assign VAR_NAME With num$(VAR_VALUE)
    When 3 : # Date
      Assign VAR_NAME With num$(VAR_VALUE)
    When 8 : # T8
    When 9 : # IbmDCB
    When 522 : # Blbfile
    When 523 : # Clbfile
      Assign VAR_NAME With VAR_VALUE
    When 524 : # Object
      # not supported
    When 525 : # Uuident
      Assign VAR_NAME With num$(VAR_VALUE)
    When 526 : # Datetime
      Assign VAR_NAME With num$(VAR_VALUE)
    When Default : # Alpha
      Assign VAR_NAME With VAR_VALUE
  Endcase
End

Subprog SET_NUMBER(VAR_NAME, VAR_VALUE)
  Value Char VAR_NAME()

  Case type(VAR_VALUE)
    When -1 : # variable does not exist
    When 1, 2, 4, 5, 6, 7 : # Libelle, Shortint, Integer, Float, Double, Decimal
      Assign VAR_NAME With VAR_VALUE
    When 3 : # Date
      Assign VAR_NAME With VAR_VALUE
    When 8 : # T8
    When 9 : # IbmDCB
    When 522 : # Blbfile
    When 523 : # Clbfile
      Assign VAR_NAME With val(VAR_VALUE)
    When 524, 525, 526 : # Object, Uuident, Datetime
      # not supported
    When Default : # Alpha
      Assign VAR_NAME With val(VAR_VALUE)
  Endcase
End


#**
#* Gets memory state
#* @internal
#*
#* @return the memory state
#*!
Subprog DBGP_MEMORY_GET()
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".DBGP_MEMORY_GET:"
    Call TRACE([LDB]DBG_TRACE)
  Endif

  Call DBGP_ADD_NODE("memory")
  Call DBGP_ADD_ATTRIBUTE("title", func UTF8_ENCODE(mess(18,9))) # Mémoire utilisée
  Call DBGP_ADD_ATTRIBUTE("used", num$([S]dbglong(0)))
  Call DBGP_ADD_ATTRIBUTE("loaded", num$([S]dbglong(1)))
  Call DBGP_ADD_ATTRIBUTE("max", num$([S]dbglong(2)))
  Call DBGP_CLOSE_NODE()

  Call DBGP_ADD_NODE("memory")
  Call DBGP_ADD_ATTRIBUTE("title", func UTF8_ENCODE(mess(19,9))) # Canaux utilisés
  Call DBGP_ADD_ATTRIBUTE("used", num$(([S]dbglong(9)+1)*[S]dbglong(104)+[S]dbglong(6)+3))
  Call DBGP_ADD_ATTRIBUTE("loaded", num$(([S]dbglong(10)+1)*[S]dbglong(104)+[S]dbglong(7)+3))
  Call DBGP_ADD_ATTRIBUTE("max", num$([S]dbglong(5)))
  Call DBGP_CLOSE_NODE()

  Call DBGP_ADD_NODE("memory")
  Call DBGP_ADD_ATTRIBUTE("title", func UTF8_ENCODE(mess(28,9))) # Fichiers séquentiels
  Call DBGP_ADD_ATTRIBUTE("used", num$([S]dbglong(6)))
  Call DBGP_ADD_ATTRIBUTE("max", num$([S]dbglong(7)))
  Call DBGP_ADD_ATTRIBUTE("size", num$([S]dbglong(8)))
  Call DBGP_CLOSE_NODE()

  Call DBGP_ADD_NODE("memory")
  Call DBGP_ADD_ATTRIBUTE("title", func UTF8_ENCODE(mess(20,9))) # Tables ouvertes
  Call DBGP_ADD_ATTRIBUTE("used", num$([S]dbglong(9)))
  Call DBGP_ADD_ATTRIBUTE("loaded", num$([S]dbglong(10)))
  Call DBGP_ADD_ATTRIBUTE("max", num$([S]dbglong(11)))
  Call DBGP_ADD_ATTRIBUTE("size", num$([S]dbglong(27)))
  Call DBGP_CLOSE_NODE()

  Call DBGP_ADD_NODE("memory")
  Call DBGP_ADD_ATTRIBUTE("title", func UTF8_ENCODE(mess(21,9))) # Masques ouverts
  Call DBGP_ADD_ATTRIBUTE("used", num$([S]dbglong(12)))
  Call DBGP_ADD_ATTRIBUTE("loaded", num$([S]dbglong(13)))
  Call DBGP_ADD_ATTRIBUTE("max", num$([S]dbglong(14)))
  Call DBGP_ADD_ATTRIBUTE("size", num$([S]dbglong(15)))
  Call DBGP_CLOSE_NODE()

  Call DBGP_ADD_NODE("memory")
  Call DBGP_ADD_ATTRIBUTE("title", func UTF8_ENCODE(mess(23,9))) # Traitements en mémoire
  Call DBGP_ADD_ATTRIBUTE("used", num$([S]dbglong(19)))
  Call DBGP_ADD_ATTRIBUTE("loaded", num$([S]dbglong(20)))
  Call DBGP_ADD_ATTRIBUTE("max", num$([S]dbglong(21)))
  Call DBGP_ADD_ATTRIBUTE("size", num$([S]dbglong(22)))
  Call DBGP_CLOSE_NODE()

End


#**
#* Get tables in use for displaying in debug view
#*
#*!
Subprog DBGP_TABLES_GET()
  Local Char WNAME(250)
  Local Char ABR(10)
  Local Integer WFILE
  Local Char WKEY(8)
  Local Char WCOMMENT(30)
  Local Integer WTYPE
  Local Integer WLENGTH

  Local Integer I
  Local Integer CURRENT_IDX

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".DBGP_TABLES_GET:"
    Call TRACE([LDB]DBG_TRACE)
  Endif

  WLENGTH = [S]dbglong(11)
  For I=1 To WLENGTH
    WNAME = [S]filename(I)
    If WNAME<>""
      WABR = [S]fileabre(I)
      If WABR<>""
        WFILE = filelev(I)
        WTYPE = filetyp(I)+1 : # 0 Neutre ou Inex, 1 CISAM, 2 ORACLE etc..
        Onerrgo ERR_IGNORE
        If WFILE<>0
          CURRENT_IDX  = evalue("[G:"+WABR+"]currind")
          If CURRENT_IDX<>0
            WKEY = evalue("[G:"+WABR+"]keyname("+num$(CURRENT_IDX-1)+")")
          Endif
        Endif
        WCOMMENT = filcom("FIL",WNAME,"fde")
        Onerrgo
      Else
        WTYPE = 1
      Endif

      Call DBGP_ADD_NODE("table")
      Call DBGP_ADD_ATTRIBUTE("name", WNAME)
      Call DBGP_ADD_ATTRIBUTE("abbreviation", WABR)
      Call DBGP_ADD_ATTRIBUTE("file", num$(WFILE))
      Call DBGP_ADD_ATTRIBUTE("key", WKEY)
      Call DBGP_ADD_ATTRIBUTE("comment", func UTF8_ENCODE(WCOMMENT))
      Call DBGP_ADD_ATTRIBUTE("type", func UTF8_ENCODE(mess(WTYPE,80,1)))
      Call DBGP_CLOSE_NODE()
    Endif
  Next I
End

#**
#* Get masks in use for displaying in debug view
#*
#*!
Subprog DBGP_MASKS_GET()
  Local Char WNAME(250)
  Local Char WABR(10)
  Local Integer WMASK
  Local Integer WNUM
  Local Integer WSIZE
  Local Char WCOMMENT(30)
  Local Integer WRANK1
  Local Integer WRANK2

  Local Integer I

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".DBGP_MASKS_GET:"
    Call TRACE([LDB]DBG_TRACE)
  Endif

  For I=0 To 24 # max 25 masks opened ?...
    WNAME = masknam(I+1)
    If WNAME<>""
      WABR = maskabr(I+1)
      WMASK  = masklev(I+1)
      WNUM = masknbf(I+1)
      WSIZE = masksiz(I+1)
      WRANK1 = maskrk(+1,1)
      WRANK2 = maskrk(I+1,-1)
      Onerrgo ERR_IGNORE
      WCOMMENT = filcom("E"+[LDB]DBG_LANG,WNAME,"msk")
      Onerrgo

      Call DBGP_ADD_NODE("mask")
      Call DBGP_ADD_ATTRIBUTE("name", WNAME)
      Call DBGP_ADD_ATTRIBUTE("abbreviation", WABR)
      Call DBGP_ADD_ATTRIBUTE("mask", num$(WMASK))
      Call DBGP_ADD_ATTRIBUTE("number", num$(WNUM))
      Call DBGP_ADD_ATTRIBUTE("size", num$(WSIZE))
      Call DBGP_ADD_ATTRIBUTE("comment", func UTF8_ENCODE(WCOMMENT))
      Call DBGP_ADD_ATTRIBUTE("rank1", num$(WRANK1))
      Call DBGP_ADD_ATTRIBUTE("rank2", num$(WRANK2))
      Call DBGP_CLOSE_NODE()
    Endif
  Next I
End

#**
#* Get processes running for displaying in debug view
#*
#*!
Subprog DBGP_PROCESSES_GET()
  Local Integer WLENGTH
  Local Integer I

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".DBGP_PROCESSES_GET:"
    Call TRACE([LDB]DBG_TRACE)
  Endif

  WLENGTH = progldd(0) - 1
  For I=0 To WLENGTH
    If progcan(I+1)<>""
      Call DBGP_ADD_NODE("process")
      Call DBGP_ADD_ATTRIBUTE("name", progcan(I+1))
      Call DBGP_ADD_ATTRIBUTE("size", num$(progsiz(I+1)))
      Call DBGP_ADD_ATTRIBUTE("used", num$(progusd(I+1)))
      Call DBGP_ADD_ATTRIBUTE("loaded", num$(progldd(I+1)))
      Call DBGP_CLOSE_NODE()
    Endif
  Next I
End

#**
#* Get classes in use for displaying in debug view
#*
#*!
Subprog DBGP_CLASSES_GET()
  Local Integer WLENGTH
  Local Integer I

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".DBGP_CLASSES_GET:"
    Call TRACE([LDB]DBG_TRACE)
  Endif

  WLENGTH = 299 # dim([M:DBG5]CLANA) - 1
  For I=0 To WLENGTH
    If clanam(I+1) <> ""
      Call DBGP_ADD_NODE("class")
      Call DBGP_ADD_ATTRIBUTE("number", num$(I+1))
      Call DBGP_ADD_ATTRIBUTE("name", clanam(I+1))
      Call DBGP_ADD_ATTRIBUTE("lock", num$(clalev(I+1)))
      Call DBGP_ADD_ATTRIBUTE("symbol1", num$(clanbs(I+1,1)))
      Call DBGP_ADD_ATTRIBUTE("symbol2", num$(clanbs(I+1,2)))
      Call DBGP_ADD_ATTRIBUTE("rank1", num$(clasiz(I+1,1)))
      Call DBGP_ADD_ATTRIBUTE("rank2", num$(clasiz(I+1,2)))
      Call DBGP_CLOSE_NODE()
    Endif
  Next I
End

#**
#* Get sequential files in use for displaying in debug view
#*
#*!
Subprog DBGP_SEQ_FILES_GET()
  Local Integer WLENGTH
  Local Integer I, K
  Local Char WNAME(250)(50)
  Local Char WABR(10)(50)
  Local Integer WPOSITION(50)

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".DBGP_SEQ_FILES_GET:"
    Call TRACE([LDB]DBG_TRACE)
  Endif

  WLENGTH = [S]dbglong(8) - 1
  For I=0 To WLENGTH
    If adxnfs(I+1)<>""
      WNAME(I) = adxnfs(I+1)
    Endif
    If adxcio(I+1)<>0
      K = adxcio(I+1)-1
      WNAME(K) = adxnfs(adxcio(I+1))
      WABR(K) = adxioa(I+1)
      WPOSITION(K) = adxseek(I+1)
    Endif
  Next I

  For I=0 To WLENGTH
    If WNAME(I) <> ""
      Call DBGP_ADD_NODE("seqfile")
      Call DBGP_ADD_ATTRIBUTE("name", WNAME(I))
      Call DBGP_ADD_ATTRIBUTE("abbreviation", WABR(I))
      If WPOSITION(I) > 0
        Call DBGP_ADD_ATTRIBUTE("position", num$(WPOSITION(I)))
      Endif
      Call DBGP_CLOSE_NODE()
    Endif
  Next I

End


#==========================================================
# Helper functions for expression evaluation
#==========================================================

#**
#* Gets the result of the evaluation of an expression
#* @internal
#*
#* @param EXPR the expression to evaluate
#* @return the result of the evaluation if no error
#* or the error message if the evaluation failed.
#*!
Funprog EVAL_EXPR(EXPR)
Value Char EXPR()

Local Char RESULT(250)
Local Integer ERRCODE

ERRCODE = func EVAL_EXPR2(EXPR, RESULT)
If ERRCODE <> 0
  RESULT = "Error(" + num$(ERRCODE) + "): " + errmes$(ERRCODE)
Endif

End RESULT

#**
#* Evaluates an expression
#* @internal
#*
#* @param EXPR (in) the expression to evaluate
#* @param RESULT (out) the result string of the evaluation
#* @return the error code
#*!
Funprog EVAL_EXPR2(EXPR, RESULT)
Value Char EXPR()
Variable Char RESULT()

Local Libelle ISNUM
End func EVAL_EXPR3(EXPR, RESULT, ISNUM)

#**
#* Evaluates an expression
#* @internal
#*
#* @param EXPR (in) the expression to evaluate
#* @param RESULT (out) the result string of the evaluation
#* @return the error code
#*!
Funprog EVAL_EXPR3(EXPR, RESULT, ISNUM)
  Value Char EXPR()
  Variable Char RESULT()
  Variable Libelle ISNUM

  Local Integer ERRCODE

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".EVAL_EXPR3: " + EXPR
    Call TRACE([LDB]DBG_TRACE)
  Endif

  ERRCODE = parse(EXPR)

  Onerrgo EVAL_EXPR_ERROR

  Local Integer OK
  Call FLUSHADX(OK) From AFLUSHADX

  ISNUM = 0
  If ERRCODE = 0
    RESULT = evalue(EXPR)
    # If an error is catched during evaluation ERRCODE is not 0 at this point
    If ERRCODE <> 0
      ERRCODE = 0
      ISNUM = 1
      RESULT = num$(evalue(EXPR))
    Endif
  Else
    RESULT = ""
  Endif
  Onerrgo

End ERRCODE

$EVAL_EXPR_ERROR
  If dim(ERRCODE) > 0 : ERRCODE = errn :Endif
Resume


#==========================================================
# DBGP notifications
#==========================================================
#**
#* Initializes the DBGP xml notification
#* @private
#* @param NOTIFYNAME
#* @param ARGS
#*!
Subprog DBGP_NOTIFY(NOTIFYNAME, DATA)
  Value Char NOTIFYNAME()
  Value Clbfile DATA()

  [LDB]DBGP_XMLRESP = '<notify name="'
  Append [LDB]DBGP_XMLRESP, NOTIFYNAME
  Append [LDB]DBGP_XMLRESP, '"'

  [LDB]DBGP_XMLLEVEL = 0
  [LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL) = "notify"

  Local Clbfile OUTCLB(6)
  Local Integer LENGTH
  [L]LENGTH = func CORE_B64ENCODE(DATA, [L]OUTCLB, [LDB]DBG_ASCII)

  Call DBGP_ADD_ATTRIBUTE("encoding", "base64")
  Call DBGP_ADD_ATTRIBUTE("body", [L]OUTCLB)

  Call DBGP_RESP_SEND()
End


#==========================================================
# TRACING
#==========================================================

#**
#* Initialize and start tracing
#*
#* @param ARGS
#*!
Subprog DBGP_TRACE_INIT(ARGS)
  Value Char ARGS()(97..122)

  #---------------------------------------------------------------
  # trace type:
  #   required (server or local)
  #---------------------------------------------------------------
  Local Char TRACE_TYPE(20) : TRACE_TYPE = ARGS(ascii('t'))

  If TRACE_TYPE = "server"
    [LDB]DBGP_TRATRA = 2
    Openo [LDB]DBGP_TRAFIC, 0 Using [DBG]
    Openo Using [DBG]
  Elsif TRACE_TYPE = "local"
    [LDB]DBGP_TRATRA = 3
  Else
    [LDB]DBGP_TRATRA = 1
  Endif

#  # System variable for X3 engine
#  If [LDB]DBG_FULL_DEBUG and dim([S]dbgTracing) > 0
#    If [LDB]DBGP_TRATRA = 1
#      [S]dbgTracing = 0
#    Else
#      [S]dbgTracing = 1
#    Endif
#  Endif

  Call DBGP_ADD_ATTRIBUTE("name", DBGP_TRACE_NAME)
End

#**
#* Stop tracing
#*
#* @param ARGS
#*!
Subprog DBGP_TRACE_STOP(ARGS)
  Value Char ARGS()(97..122)

  #---------------------------------------------------------------
  # trace name:
  #   required if tracing on server
  #---------------------------------------------------------------
  Local Char TRACE_NAME(250) : TRACE_NAME = ARGS(ascii('n'))

  [LDB]DBGP_TRATRA = 1

#  # System variable for X3 engine
#  If [LDB]DBG_FULL_DEBUG and dim([S]dbgTracing) > 0
#    [S]dbgTracing = 0
#  Endif

End

#**
#* Delete trace file
#*
#* @param ARGS
#*!
Subprog DBGP_TRACE_DELETE(ARGS)
  Value Char ARGS()(97..122)
  #---------------------------------------------------------------
  # trace name:
  #   required if tracing on server
  #---------------------------------------------------------------
  Local Char TRACE_NAME(250) : TRACE_NAME = ARGS(ascii('n'))

  # delete file
  Openo [LDB]DBGP_TRAFIC, 0 Using [DBG]
  Openo Using [DBG]
End

#**
#* Send a line to trace (file trace or notification trace).
#* If lines were bufferized, write them first
#*
#* @param WLINE traced line
#*!
Subprog DBGP_TRACE_CALL(WLINE)
  Value Clbfile WLINE()

  If [LDB]DBGP_TRATRA = 0
    # Bufferisation
    Setlob [LDB]DBGP_TRABUF([LDB]DBGP_TRABUF_IDX) With WLINE
    [LDB]DBGP_TRABUF_IDX+=1
    If [LDB]DBGP_TRABUF_IDX >= dim([LDB]DBGP_TRABUF)
      [LDB]DBGP_TRATRA = 1 # stop bufferisation
#      # System variable for X3 engine
#      If [LDB]DBG_FULL_DEBUG and dim([S]dbgTracing) > 0
#        [S]dbgTracing = 0
#      Endif
    Endif

  Elsif [LDB]DBGP_TRATRA = 2 or [LDB]DBGP_TRATRA = 3

    # Write bufferized lines first
    If [LDB]DBGP_TRABUF_IDX > 0
      Local Integer I
      For I=0 To [LDB]DBGP_TRABUF_IDX-1
        Call DBGP_TRACE_LINE([LDB]DBGP_TRABUF(I), [LDB]DBGP_TRATRA)
      Next I
      [LDB]DBGP_TRABUF_IDX = 0
      Raz [LDB]DBGP_TRABUF
    Endif

    # Write (not empty) current line
    If (WLINE<>"")
      Call DBGP_TRACE_LINE(WLINE, [LDB]DBGP_TRATRA)
    Endif
  Endif
End

Subprog DBGP_TRACE_LINE(WL, WTYPE)
  Value Clbfile WL()
  Value Integer WTYPE

  If WTYPE = 2
    Wrseq WL Using [DBG]
  Elsif WTYPE = 3
    Call DBGP_NOTIFY("xcmd_x3_trace_line", WL)
  Endif
End

#==========================================================
# Initialize server version switch for full debug $INS
#==========================================================
Subprog INIT_DEBUG_STATE()

  Local Integer POS
  Local Integer START_VERSION
  Local Integer END_VERSION

  [LDB]DBG_FULL_DEBUG = 1

  [LDB]ENGINE_VERSION = func AXDTMAIN.PARTSEP(ver$(0),2," ")
  If instr(0, [LDB]ENGINE_VERSION, "r.") = 0 : [LDB]ENGINE_VERSION = "99r.999" : Endif
#  [L]POS =  instr(0, ver$(0), "Debug")
#  If [L]POS = 0
#    [L]POS =  instr(0, ver$(0), "Version")
#    If ([L]POS > 0)
#      [L]START_VERSION = [L]POS + len("Version") + 1
#      [L]END_VERSION =  instr([L]START_VERSION, ver$(0), " ")
#      If ([L]END_VERSION > 0)
#        [LDB]ENGINE_VERSION = seg$(ver$(0), [L]START_VERSION, [L]END_VERSION)
#      Endif
#    Endif
#  Endif

  # Minimum engine version for full debugger
  If [LDB]ENGINE_VERSION < "16r.216"
    [LDB]DBG_FULL_DEBUG = 0
  Endif

  [LDB]DBG_FIX_STACK = ([LDB]ENGINE_VERSION < "17r.121" & [LDB]ENGINE_VERSION >= "17r.000" | [LDB]ENGINE_VERSION < "16r.223")
  [LDB]DBG_SUPPORT_DBGEVALUE2 = [LDB]ENGINE_VERSION >= "17r.116"
  [LDB]DBG_SUPPORT_CANONICAL_BP = [LDB]ENGINE_VERSION >= "17r.126" | ([LDB]ENGINE_VERSION < "17r.000" & [LDB]ENGINE_VERSION >= "16r.224")

  Onerrgo ERROR_IDSTATE
  Local Integer STAT

  # Call a new method from engine to know if engine support new debbuger features
  # (call stack, special breakpoints, ...)
  STAT = dbgBreakpointList([LDB]DBG_ARG)
  Onerrgo

#  If GUSER = "ERBOU" : [LDB]DBG_FULL_DEBUG = 0 : Endif

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".INIT_DEBUG_STATE: version=" + [LDB]ENGINE_VERSION + chr$(10)
    Append [LDB]DBG_TRACE, "  FULL_DEBUG=" + num$([LDB]DBG_FULL_DEBUG) + chr$(10)
    Append [LDB]DBG_TRACE, "  FIX_STACK=" + num$([LDB]DBG_FIX_STACK) + chr$(10)
    Append [LDB]DBG_TRACE, "  SUPPORT_DBGEVALUE2=" + num$([LDB]DBG_SUPPORT_DBGEVALUE2) + chr$(10)
    Append [LDB]DBG_TRACE, "  SUPPORT_CANONICAL_BP=" + num$([LDB]DBG_SUPPORT_CANONICAL_BP) + chr$(10)
    Call TRACE([LDB]DBG_TRACE)
  Endif

  Local Char DEBUG_PREFIX(4)
  If [LDB]DBG_FULL_DEBUG
    [L]DEBUG_PREFIX = "NEW_"
  Else
    [L]DEBUG_PREFIX = "OLD_"
  Endif

  [LDB]FN_STACK_GET = [L]DEBUG_PREFIX + "DBGP_STACK_GET"
  [LDB]FN_SET_BREAKPOINT = [L]DEBUG_PREFIX + "DBGP_SET_BREAKPOINT"
  [LDB]FN_GET_BREAKPOINT = [L]DEBUG_PREFIX + "DBGP_GET_BREAKPOINT"
  [LDB]FN_REM_BREAKPOINT = [L]DEBUG_PREFIX + "DBGP_REM_BREAKPOINT"
  [LDB]FN_UPD_BREAKPOINT = [L]DEBUG_PREFIX + "DBGP_UPD_BREAKPOINT"
  [LDB]FN_LIST_BREAKPOINT = [L]DEBUG_PREFIX + "DBGP_LIST_BREAKPOINT"
  [LDB]FN_CTX_GET = [L]DEBUG_PREFIX + "DBGP_CTX_GET"
  [LDB]FN_SOURCE_GET = [L]DEBUG_PREFIX + "DBGP_SOURCE_GET"

  # Does not work with all engines ...
  #[LDB]DBG_DEBUG_NAME = [S]adxdpg

  # ... so try another way, with adxpno
  [LDB]DBG_DEBUG_NAME = adxpno(0)
  Local Integer POS_START
  Local Integer POS_END
  [L]POS_START = instr(0, [LDB]DBG_DEBUG_NAME, "/")
  [L]POS_END = instr(0, [LDB]DBG_DEBUG_NAME, "$")
  If [L]POS_START > 0 and [L]POS_END > 0
    [LDB]DBG_DEBUG_NAME = mid$([LDB]DBG_DEBUG_NAME, [L]POS_START + 1, [L]POS_END - [L]POS_START - 1)
  Endif

End

$ERROR_IDSTATE
  [LDB]DBG_FULL_DEBUG = 0
Resume


#**
#* Attach to process
#*
#* @param ID proccess id to attach
#*!
Funprog ATTACH_PROCESS(HOST, PORT, ID)
 Value Char HOST()
 Value Char PORT()
 Value Char ID()
End func AXDTMAIN.ATTACH_PROCESS(HOST, PORT, ID)

#==========================================================
# Helper functions for Base 64 encoding/decoding
#==========================================================

#**
#* This method encodes the clob value into a clob in base 64
#* according to the specification given by the RFC 3548.
#*
#* This implementation is based on the java.util.prefs.Base64 class
#* @internal
#*
#* @param IN the input clob
#* @param OUT the output clob
#* @see <a href="http://www6.ietf.org/rfc/rfc3548.txt">RFC 3548</a><br/>
#* <a href="http://www6.ietf.org/rfc/rfc2045.txt">RFC 2045</a><br/>
#* <a href="http://base64-encoder-online.waraxe.us/">Online base64 encoder / decoder</a>
#*!
Funprog BASE64_ENCODE(INCLB, OUTCLB)
  Const Clbfile INCLB()
  Variable Clbfile OUTCLB()

  Local Integer IN_OCCURS
  Local Integer LENGTH
  IN_OCCURS = len(INCLB) / 180 + 1

  Local Char IN(180)(IN_OCCURS)
  Local Char OUT(240)(IN_OCCURS)
  Setlob IN With INCLB
  LENGTH = func WBASE64_ENCODE(IN, OUT)
  Setlob OUTCLB With OUT
End LENGTH

Funprog BASE64_DECODE(INCLB, OUTCLB)
  Const Clbfile INCLB()
  Variable Clbfile OUTCLB()

  Local Integer IN_OCCURS
  Local Integer LENGTH
  IN_OCCURS = len(INCLB) / 240 + 1

  Local Char IN(240)(IN_OCCURS)
  Local Char OUT(180)(IN_OCCURS)
  Setlob IN With INCLB
  LENGTH = func WBASE64_DECODE(IN, OUT)
  Setlob OUTCLB With OUT
End LENGTH

#**
#* This method encodes the string array into a string array in base 64
#* according to the specification given by the RFC 3548.
#*
#* This implementation is based on the java.util.prefs.Base64 class
#* @internal
#*
#* @param IN the array of strings (180 char long)
#* @param OUT the array of strings (240 char long)
#* @see <a href="http://www6.ietf.org/rfc/rfc3548.txt">RFC 3548</a><br/>
#* <a href="http://www6.ietf.org/rfc/rfc2045.txt">RFC 2045</a><br/>
#* <a href="http://base64-encoder-online.waraxe.us/">Online base64 encoder / decoder</a>
#*!
Funprog WBASE64_ENCODE(IN, OUT)
  Const Char IN()() : # must be char(180)(x)
  Variable Char OUT()() : # must be char(240)(x)

  Local Integer SRCLEN, CHUNKS, EXTRA
  Local Integer I, J, C, L
  Local Integer B0, B1, B2
  Local Integer CC(1..4)

  Raz OUT
  If [LDB]DBG_CHAR64(0) = 0
    # initialize the array for the next calls
    Local Char CHAR64(64) : CHAR64 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
    For I = 0 To 63
      [LDB]DBG_CHAR64(I) = ascii(mid$(CHAR64, I + 1, 1))
    Next I
  Endif
  SRCLEN = sigma(I=0, dim(IN)-1, len(IN(I)))
  CHUNKS = int(SRCLEN / 3)
  EXTRA = SRCLEN - (CHUNKS * 3)

  If SRCLEN = 0 : End 0 : Endif

  C = 0
  L = 0
  # Each 3 bytes of input we end up with 4 bytes of output (encoded)
  For I = 1 To CHUNKS
    # b & 0xff
    B0 = mod(ascii(mid$(IN(L), C + 1, 1)), 255)
    B1 = mod(ascii(mid$(IN(L), C + 2, 1)), 255)
    B2 = mod(ascii(mid$(IN(L), C + 3, 1)), 255)
    C += 3

    # b0 >> 2
    CC(1) = int(B0 / 4)
    # (b0 << 4) & 0x3f | (b1 >> 4)
    CC(2) = mod(B0 * 16, 64) + int(B1 / 16)
    # (b1 << 2) & 0x3f | (b2 >> 6)
    CC(3) = mod(B1 * 4, 64) + int(B2 / 64)
    # b2 & 0x3f
    CC(4) = mod(B2, 64)

    OUT(L) += sigma(J=1, 4, chr$([LDB]DBG_CHAR64(CC(J))))

    If C = 180
      C = 0
      L += 1
    Endif
  Next I

  # Partial chunk
  If EXTRA > 0
    # b0 & 0xff
    B0 = mod(ascii(mid$(IN(L), C + 1, 1)), 255)
    # b0 >> 2
    OUT(L) += chr$([LDB]DBG_CHAR64(int(B0 / 4)))
    If EXTRA = 1
      # (b0 << 4) & 0x3f
      OUT(L) += chr$([LDB]DBG_CHAR64(mod(B0 * 16, 64)))
      OUT(L) += "=="
    Else : # EXTRA = 2
      # b1 & 0xff
      B1 = mod(ascii(mid$(IN(L), C + 2, 1)), 255)
      # (b0 << 4) & 0x3f | (b1 >> 4)
      OUT(L) += chr$([LDB]DBG_CHAR64(mod(B0 * 16, 64) + int(B1 / 16)))
      # (b1 << 2) & 0x3f
      OUT(L) += chr$([LDB]DBG_CHAR64(mod(B1 * 4, 64)))
      OUT(L) += "="
    Endif
  Endif

End 0

#**
#* This method decodes the string array into a string array in base 64
#* according to the specification given by the RFC 3548.
#*
#* This implementation is based on the java.util.prefs.Base64 class
#* @internal
#*
#* @param IN the the array of strings (180 char long)
#* @param OUT the the array of strings (240 char long)
#* @see <a href="http://www6.ietf.org/rfc/rfc3548.txt">RFC 3548</a><br/>
#* <a href="http://www6.ietf.org/rfc/rfc2045.txt">RFC 2045</a><br/>
#* <a href="http://base64-encoder-online.waraxe.us/">Online base64 encoder / decoder</a>
#*!
Funprog WBASE64_DECODE(IN, OUT)
  Const Char IN()() : # must be char(240)(x)
  Variable Char OUT()() : # must be char(180)(x)

  Local Char ENDS(2)
  Local Integer SRCLEN, CHUNKS, FULLCHUNKS, MISSING, LLEN
  Local Integer I, J, C, L
  Local Integer B0, B1, B2, B3
  Local Integer CC(1..3)

  Raz OUT
  If [LDB]DBG_INT64(0) = 0
    # initialize the array for the next calls
    # we use char from 40 to 103 to map value from 0 to 63
    # char 126 '~' indicates an out of range value
    Local Char INT64(123) : INT64 = "f~~~g\]^_`abcde~~~~~~~()*+,-./0123456789:;<=>?@A~~~~~~BCDEFGHIJKLMNOPQRSTUVWXYZ["
    For I = 0 To 42
      [LDB]DBG_INT64(I) = 255
    Next I
    For I = 43 To 122
      [LDB]DBG_INT64(I) = ascii(mid$(INT64, I - 42, 1)) - 40
      If [LDB]DBG_INT64(I) > 63
        [LDB]DBG_INT64(I) = 255
      Endif
    Next I
  Endif

  SRCLEN = sigma(I=0, dim(IN)-1, len(IN(I)))
  CHUNKS = int(SRCLEN / 4)

  If SRCLEN = 0 : End 0 : Endif

  # finds the last non empty string in the array
  For I = dim(IN) - 1 To 0 Step -1
    LLEN = len(IN(I))
    If LLEN > 0 : L = I : Break : Endif
  Next I
  ENDS = right$(IN(L), LLEN - 1)

  FULLCHUNKS = CHUNKS
  MISSING = 0
  If right$(ENDS, 2) = "="
    FULLCHUNKS -= 1
    MISSING = 1
  Endif
  If ENDS = "=="
    MISSING = 2
  Endif

  C = 0
  L = 0
  # Each 3 bytes of input we end up with 4 bytes of output (encoded)
  For I = 1 To FULLCHUNKS
    B0 = [LDB]DBG_INT64(ascii(mid$(IN(L), C + 1, 1)))
    B1 = [LDB]DBG_INT64(ascii(mid$(IN(L), C + 2, 1)))
    B2 = [LDB]DBG_INT64(ascii(mid$(IN(L), C + 3, 1)))
    B3 = [LDB]DBG_INT64(ascii(mid$(IN(L), C + 4, 1)))
    C += 4

    # (b0 << 2) | (b1 >> 4)
    CC(1) = mod((B0 * 4) + int(B1 / 16), 256)
    # (b1 << 4) | (b2 >> 2)
    CC(2) = mod((B1 * 16) + int(B2 / 4), 256)
    # (b2 << 6) | b3
    CC(3) = mod((B2 * 64) + B3, 256)

    OUT(L) += sigma(J=1, 3, chr$(CC(J)))

    If C = 240
      C = 0
      L += 1
    Endif
  Next I

  # Partial chunk
  If MISSING > 0
    B0 = [LDB]DBG_INT64(ascii(mid$(IN(L), C + 1, 1)))
    B1 = [LDB]DBG_INT64(ascii(mid$(IN(L), C + 2, 1)))
    # (b0 << 2) | (b1 >> 4)
    OUT(L) += chr$(mod((B0 * 4) + int(B1 / 16), 256))
    If MISSING = 1
      B2 = [LDB]DBG_INT64(ascii(mid$(IN(L), C + 3, 1)))
      # (b1 << 4) | (b2 >> 2)
      OUT(L) += chr$(mod((B1 * 16) + int(B2 / 4), 256))
    Endif
  Endif

End 0

#==========================================================
# UTF-8 helper function
#==========================================================
#**
#* Encodes a string in its UTF-8 equivalent
#*
#* @param DATA
#*!
Funprog UTF8_ENCODE(DATA)
  Value Char DATA()

  Local Clbfile OUT(1)
  Local Integer L
  L = func UTF8_ENCODE2(DATA, OUT)
End OUT

#**
#* Encodes a clob in its UTF-8 equivalent
#*
#* Algorithm:
#* <pre>
#*    if (c<0x80)
#*       b1 = c>>0  & 0x7F | 0x00
#*       b2 = null
#*       b3 = null
#*       b4 = null
#*    else if (c<0x0800)
#*       b1 = c>>6  & 0x1F | 0xC0
#*       b2 = c>>0  & 0x3F | 0x80
#*       b3 = null
#*       b4 = null
#*    else if (c<0x010000)
#*       b1 = c>>12 & 0x0F | 0xE0
#*       b2 = c>>6  & 0x3F | 0x80
#*       b3 = c>>0  & 0x3F | 0x80
#*       b4 = null
#*    else if (c<0x110000)
#*       b1 = c>>18 & 0x07 | 0xF0
#*       b2 = c>>12 & 0x3F | 0x80
#*       b3 = c>>6  & 0x3F | 0x80
#*       b4 = c>>0  & 0x3F | 0x80
#*    end if
#* </pre>
#*
#* @param IN
#* @param OUT
#*!
Funprog UTF8_ENCODE2(IN, OUT)
  Const Clbfile IN()
  Variable Clbfile OUT()

  Local Libelle B(1..4)
  Local Shortint C
  Local Integer I, J
  Local Integer LENGTH

  LENGTH = len(IN)

  Raz OUT
  For I = 1 To LENGTH
    Raz B
    C = ascii(mid$(IN, I, 1))
  If C < 128 : # x80
    B(1) = C
  Elsif C < 32768 : # x008000
      # b1 = c>>6  & 0x1F | 0xC0
      B(1) = mod(int(C / 64), 32) + 192
      # b2 = c>>0  & 0x3F | 0x80
      B(2) = mod(C, 64) + 128
  Elsif C < 65536 : # x010000
      # b1 = c>>12 & 0x0F | 0xE0
      B(1) = mod(int(C / 4096), 16) + 224
      # b2 = c>>6  & 0x3F | 0x80
      B(2) = mod(int(C / 64), 64) + 128
      # b3 = c>>0  & 0x3F | 0x80
      B(3) = mod(C, 64) + 128
  Elsif C < 1114112 : # x110000
      # Should not happen because char are encoded using UCS-2
      # and therefore C is in range 0 - 65535
      # b1 = c>>18 & 0x07 | 0xF0
#      B(1) = mod(int(C / 262144), 8) + 240
      # b2 = c>>12 & 0x3F | 0x80
#      B(2) = mod(int(C / 4096), 64) + 128
      # b3 = c>>6  & 0x3F | 0x80
#      B(3) = mod(int(C / 64), 64) + 128
      # b4 = c>>0  & 0x3F | 0x80
#      B(4) = mod(C, 64) + 128
    Endif
    For J = 1 To 4
      If B(J) = 0
        Break
  Endif
      Append OUT, chr$(B(J))
    Next J
  Next I
End len(OUT)




#**
#* Encode data in base64
#*
#* @param CLBDATA data to be encoded
#* @param OUTCLB encoded result
#* @param CHARSET charset to convert data to before encoding (only used with full debugger)
#*!
Funprog CORE_B64ENCODE(INCLB, OUTCLB, CHARSET)
  Value Clbfile INCLB()
  Variable Clbfile OUTCLB()
  Value Integer CHARSET

  Local Integer LENGTH

  If [LDB]DBG_FULL_DEBUG
    Local Blbfile INBLB(6)
    [L]LENGTH = strEncode(INCLB, [L]INBLB, CHARSET)
    [L]LENGTH = b64Encode([L]INBLB, OUTCLB)
  Else
    [L]LENGTH = func BASE64_ENCODE([L]INCLB, [L]OUTCLB)
  Endif

#  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
#    [LDB]DBG_TRACE = ".CORE_B64ENCODE: encode '" + INCLB + "' to '" + OUTCLB + "'"
#    Call TRACE([LDB]DBG_TRACE)
#  Endif

End [L]LENGTH

#**
#* Decode base64 data
#*
#* @param INCLB data to be decoded
#* @param OUTCLB decoded result
#* @param CHARSET charset of encoded data (only used with full debugger)
#*!
Funprog CORE_B64DECODE(INCLB, OUTCLB, CHARSET)
  Value Clbfile INCLB()
  Variable Clbfile OUTCLB()
  Value Integer CHARSET

  Local Integer LENGTH

  If [LDB]DBG_FULL_DEBUG
    Local Blbfile OUTBLB(6)
    [L]LENGTH = b64Decode(INCLB, [L]OUTBLB)
    [L]LENGTH = strDecode([L]OUTBLB, OUTCLB, CHARSET)
  Else
    Local Char IN(250)(1)
    Local Char OUT(250)(1)
    Setlob [L]IN With INCLB
    [L]LENGTH = func WBASE64_DECODE([L]IN, [L]OUT)
    Setlob OUTCLB With [L]OUT
  Endif

#  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
#    [LDB]DBG_TRACE = ".CORE_B64DECODE: decode '" + OUTCLB + "' from '" + INCLB + "'"
#    Call TRACE([LDB]DBG_TRACE)
#  Endif

End [L]LENGTH


#--------------------------------------------------------------------
Funprog GET_PROGRAM(FULLFILENAME)
  Value Char FULLFILENAME()

  Local Integer NSTART, NEND
  Local Integer I : [L]I = 0
  Local Char FLD(32)
  Local Char EXT(10)
  Local Char PROGRAM(250)
  FULLFILENAME = ctrans(FULLFILENAME, "\", "/")

  Repeat
      [L]I = instr([L]NSTART, FULLFILENAME, "/")
      If [L]I <> 0
        If [L]NSTART > 0
          FLD = seg$(FULLFILENAME, [L]NSTART, [L]I-1)
        Endif
        [L]NSTART = [L]I + 1
      Endif
  Until [L]I = 0

  [L]NEND = instr([L]NSTART, FULLFILENAME, ".") - 1
  If [L]NEND < 1
    [L]NEND = len(FULLFILENAME)
  Else
    EXT = seg$(FULLFILENAME, [L]NEND+1, len(FULLFILENAME))
    If toupper(EXT) = ".SRC" : EXT = ".TRT" : Endif
  Endif

  [L]PROGRAM = seg$(FULLFILENAME, [L]NSTART, [L]NEND)
  If (not clalev([LDB]) | clalev([LDB]) & [LDB]DBG_SUPPORT_CANONICAL_BP) & instr(1, FULLFILENAME, "x3://") = 1
    # server@folder.TRT/process$adx
    [L]PROGRAM = "@" + FLD + toupper(EXT) + "/" + [L]PROGRAM + "$adx"
  Endif
End [L]PROGRAM


#--------------------------------------------------------------------
Funprog GET_SRC_NAME(DECORATED_NAME)
  Value Char DECORATED_NAME()

  Local Integer NSTART
  Local Char PROGRAM(250)

  # clean end of name
  [L]NSTART = instr( 1, DECORATED_NAME, '$' )
  If [L]NSTART
    [L]PROGRAM = left$(DECORATED_NAME, [L]NSTART - 1)
  Else
    [L]PROGRAM = DECORATED_NAME
  Endif

  # now clean beginning of name
  [L]NSTART  = instr( 1, [L]PROGRAM, 'TRT/' )
  If [L]NSTART
    [L]PROGRAM = right$([L]PROGRAM, [L]NSTART + 4)
  Else
    [L]NSTART  = instr( 1, [L]PROGRAM, '.' )
    If [L]NSTART
      [L]PROGRAM = right$([L]PROGRAM, [L]NSTART + 1)
    Endif
  Endif

End [L]PROGRAM

Funprog LOADFILE(FNAME)
  Value Char FNAME
  Local Integer FSIZE
  Local Char FPATH(255)

  Onerrgo ERR_LOADFILE
  FPATH = filpath("",FNAME,"")
  # Have we got the source code : (size > 0) ?
  FSIZE = filinfo(FPATH,7)
  If FSIZE > 0
    Openi FPATH Using [SRC]
    Iomode adxium GUTF8 Using [SRC]
    Iomode adxirs chr$(10) Using  [SRC]
    Iomode adxifs "" Using  [SRC]

    Local Schar LINE(250)
    Local Integer NUM, OFF, LLEN, STAT

    Raz [LDB]DBG_TRASRCBUF
    Repeat
      Rdseq LINE Using [SRC]
      STAT = fstat
      LLEN = len(LINE)
      [LDB]DBG_TRASRCINFO(NUM, 0)=OFF+1
      [LDB]DBG_TRASRCINFO(NUM, 1)=LLEN
      Append [LDB]DBG_TRASRCBUF, LINE
      Append [LDB]DBG_TRASRCBUF, chr$(10)
      NUM += 1
      OFF += LLEN+1
    Until STAT <> 0
  Endif
  Onerrgo
End FSIZE

$ERR_LOADFILE
  [LDB]DBG_TRACE = "Failed to load source file" + chr$(10)
  Gosub APPEND_ERR_WHERE
  Call LOG_LINE("ERROR", [LDB]DBG_TRACE)
Resume

#--------------------------------------------------------------------
Funprog TRANS_XML(INPUT)
  Value Char INPUT()

  Local Char OUTPUT(250)

  If instr (1, INPUT, '"') > 0 or instr (1, INPUT, "<") > 0
&     or instr (1, INPUT, ">") > 0 or instr (1, INPUT, "'") > 0 or instr (1, INPUT, '&') > 0
    Local Integer LG, I
    Local Char C
    # Iterate thru INPUT string to find xml entities
    [L]LG = len(INPUT)
    For I = 1 To [L]LG
      [L]C = mid$(INPUT, I, 1)
      If [L]C = "&"
        Append [L]OUTPUT, "&amp;"
      Elsif [L]C = ">"
        Append [L]OUTPUT, "&gt;"
      Elsif [L]C = "<"
        Append [L]OUTPUT, "&lt;"
      Elsif [L]C = "'"
        Append [L]OUTPUT, "&apos;"
      Elsif [L]C = '"'
        Append [L]OUTPUT, "&quot;"
      Else
        Append [L]OUTPUT, [L]C
      Endif
    Next I
  Else
    End INPUT
  Endif
End [L]OUTPUT

#---------------------------------------#
# Taken from AECLIDBG source
#---------------------------------------#
#**
#* Update a user parameter
#*
#* @param PARAM parameter
#* @param USR user (GUSER if blank)
#* @param VALEUR value to set perameter to
#* @deprecated see AXDTMAIN.SET_PARAM(PARAM, VALEUR)
#*!
Subprog MAJPARUSR(PARAM,USR,VALEUR)
Value Char PARAM,USR,VALEUR
Local Char RES(50)
# USER is always the current user
RES = func AXDTMAIN.SET_PARAM(PARAM, VALEUR)
End

Subprog SET_TRACE(PARAM)
Value Char PARAM()
  If toupper(PARAM) = "ON" or PARAM = "2"
    Call SET_PARAM("debug.trace","on")
  Else
    Call SET_PARAM("debug.trace","off")
  Endif
End

Subprog SET_HOST(IACTX_HOST)
  Value Char IACTX_HOST()
  Call SET_PARAM("debug.host",[L]IACTX_HOST)
End

Subprog SET_PORT(IACTX_PORT)
  Value Char IACTX_PORT()
  Call SET_PARAM("debug.port",[L]IACTX_PORT)
End

Subprog SET_PARAM(IACTX_ID,IACTX_VALUE)
  Value Char IACTX_ID()
  Value Char IACTX_VALUE()

  Local Integer WI
  Local Integer WJ

  [L]IACTX_ID += "="

  [L]WI = instr(1,[LDB]DBG_ADXCTX,[L]IACTX_ID)
  If [L]WI
    [L]WJ = instr([L]WI,[LDB]DBG_ADXCTX,";")
    If [L]WJ
      [L]IACTX_VALUE = [L]IACTX_ID + [L]IACTX_VALUE
      Call REPLACEINSTR([LDB]DBG_ADXCTX,[L]WI-1,[L]WJ,[L]IACTX_VALUE )
    Endif
  Else :# si le parmètre n'était pas présent => ajout à la fin
    [LDB]DBG_ADXCTX += [L]IACTX_ID + [L]IACTX_VALUE +";"
  Endif
End

Subprog REPLACEINSTR(IACTX_STR,IACTX_START,IACTX_END,IACTX_VALUE)
  Variable Char    IACTX_STR()
  Value    Integer IACTX_START
  Value    Integer IACTX_END
  Value    Char    IACTX_VALUE()

  Local Char WSTR(250)
  WSTR =  left$([L]IACTX_STR,[L]IACTX_START)
  WSTR += [L]IACTX_VALUE
  WSTR += right$([L]IACTX_STR,[L]IACTX_END)
  [L]IACTX_STR = WSTR
End

Subprog GET_PARAM(IACTX_ID,IACTX_VALUE,IACTX_DEFAULT)
  Value    Char IACTX_ID()
  Variable Char IACTX_VALUE()
  Value    Char IACTX_DEFAULT()

  Local Integer WI
  Local Integer WJ

  [L]IACTX_ID += "="

  [L]WI = instr(1,[LDB]DBG_ADXCTX,[L]IACTX_ID)
  If [L]WI
    [L]WI + =len([L]IACTX_ID)
    [L]WJ = instr([L]WI,[LDB]DBG_ADXCTX,";")
    If [L]WJ>[L]WI
      [L]IACTX_VALUE = seg$([LDB]DBG_ADXCTX,[L]WI,[L]WJ-1)
    Else
      [L]IACTX_VALUE = ""
    Endif
  Else
    [L]IACTX_VALUE = [L]IACTX_DEFAULT
  Endif

End

#**
#* Safe get context value
#*
#* @param CTX_NAME
#*!
Funprog GET_CTX_VAL(CTX_NAME)
  Value Char CTX_NAME
  Local Char CTX_VAL(255)
  Onerrgo ERR_IGNORE
  CTX_VAL = evalue('GACTX.' + toupper(CTX_NAME))
  Onerrgo
End CTX_VAL

$ERR_IGNORE
Resume

Subprog TRADBG(DBG_FICHIER, DBG_NUM_LIG, DBG_DSC)
Value    Char    DBG_FICHIER()   : # Nom du TRT à debugger
Value    Integer DBG_NUM_LIG     : # No Ligne courante du TRT à debugger
Value    Char    DBG_DSC()       : # Ligne courante du TRT
$TRADBG_
End

