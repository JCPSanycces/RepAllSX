#<AdxTL>@(#)2.0.4.29 $Revision$
##############################################################################
##
## Procedures and functions used to interact with the SAFE X3 Studio debugger
##
##                     ******* DO NOT EDIT *******
##
## This script is automatically updated by SAFE X3 Studio.
## Please, report any change request to Eric Boureau
##
##############################################################################
  End

##############################################################################
##
##  - [S]adxdpg TRT name of the debugger
##  - [S]adxdbo Subprog name for initialization (INIDBG by default)
##  - [S]adxdbc Subprog name for instruction (INPDBG by default)
##  - [S]adxdbx Subprog name for termination (ENDDBG by default)
##
##  - [S]adxkpg TRT name of the calc
##
##############################################################################

##############################################################################
# Subprog de déclaration dont le nom est stocké dans [S]adxdbo
##############################################################################

Subprog INIDBG
$INIDBG_
  Local Clbfile DBG_TRACE(3)          : # Trace débuggage du débuggeur
  Local Char    DBG_LOG_NAME(250)     : # Name of the error log file
  Local Shortint DBG_LOG_ERRN
  Local Clbfile  DBG_LOG_ERRMES(0)
  Local Clbfile  DBG_LOG_CTX(2)

  If clalev([M:AKL]) or dbgmode = 2
#    dbgmode(1)=0 :# arrêt du mode debug
    Raz [LDB]DBG_TRACE
    Append [LDB]DBG_TRACE, "Early exit! dbgmode(0..2)=[="
    Append [LDB]DBG_TRACE, 'dbgmode(0..2)=[' + num$(dbgmode(0)) + ', ' + num$(dbgmode(1)) + ', ' + num$(dbgmode(2)) + ']'
    Append [LDB]DBG_TRACE, ", clalev([M:AKL])="  + num$(clalev([M:AKL]))
    Call LOG_LINE("ERROR", [LDB]DBG_TRACE)
    End
  Endif

  Local Integer DBG_FREEMEM : [LDB]DBG_FREEMEM = freemem # save freemem value
  Local Integer DBG_MAXMEM : [LDB]DBG_MAXMEM = maxmem # save maxmem value
  Local Integer DBG_DBGMEMUSED : [LDB]DBG_DBGMEMUSED = [S]dbglong(0) # save mem used value
  Local Integer DBG_DBGMEMLOADED
  Local Integer DBG_DBGMEMDELTA

  Call ADJUST_MEMORY

  Local Char    DGNOMPRG(250)         : # Création dans la classe globale [LDB]
  Local Libelle DBG_TRASRC            : # 1 On a les sources, sinon nada
  Local Integer DGNOLIGN              : # No de ligne courant
  Local Integer NB_VAR_MAX            : # Nombre de variables Maximum
  Local Integer NB_BPT_MAX            : # Nombre de Break point maximum
  Local Integer NB_CALL_MAX           : # Nombre de Call imbriqués maximum
  Local Integer NIV_CALL              : # Niveau d'imbrication courant

  Local Integer DBG_ACT               : # =1 si opsock c'est bien passé
  Local Integer MOD_CLIWEB            : # session avec un client Web : 0 non , 1 oui
  Local Integer DBG_ON                : # flag général de l'activation du mode debugger
                                        # (valorisé par la READ_ADXCTX)

  Local Char    DBG_HOST(255)         : # Host de la machine où se trouve le debugger socket
                                        # (valorisé par la READ_ADXCTX)
  Local Char    DBG_PORT(255)         : # Port d'écoute du debugger socket (valorisé par la READ_ADXCTX)
  Local Char    DBG_SESTYP(5)         : # type de la session               (valorisé par la READ_ADXCTX)
  Local Char    DBG_SESWEI(3)         : # poids de la session              (valorisé par la READ_ADXCTX)

  Local Integer DBG_TRACON            : # mode débuggage du débuggeur
  Local Char    DBG_TRACE_NAME(250)   : # Name of the trace file
  Local Char    DBG_ADXCTX(250)       : # copy of adxctx to not depend on engine variable
  Local Clbfile DBG_PROP_XML(10)

  Local Shortint DBG_TRATNB
  Local Clbfile  DBG_TRASRCBUF(10)
  Local Integer  DBG_TRASRCINFO(10000,2)

  Local Char    DBG_IDEKEY(100)

  #-----------------------------------------------------------------------------
  ## DBGP feature values
  #-----------------------------------------------------------------------------
  Local Integer F_NOTIFY : [LDB]F_NOTIFY = 0
  Local Integer F_MAX_CHILDREN : [LDB]F_MAX_CHILDREN = 100
  Local Integer F_MAX_DATA : [LDB]F_MAX_DATA = 8192
  Local Integer F_MAX_DEPTH : [LDB]F_MAX_DEPTH = 2
  Local Char F_X3_CORE_PROGRAM(30) : [LDB]F_X3_CORE_PROGRAM = "AXDTMAIN"
  Local Clbfile DBGP_XMLRESP(12)
  Local Libelle DBGP_DELAYED
  Local Clbfile DBG_ARG(10)
  Local Clbfile CLB_TEMP(10)

  Local Char DBGP_XMLTAGS(30)(15) : # 15 levels of tags
  Local Integer DBGP_XMLLEVEL
  #Local Integer DBGP_BNB
  Local Char    DBGP_SRC_LINE(250)
  Local Clbfile DBGP_SRC_LINE_B64(2)
  Local Integer FIRST_STEP_INTO : [LDB]FIRST_STEP_INTO = 1

  Local Integer DBGP_TRACING : DBGP_TRACING = 0
  Local Integer DBGP_TRATRA : DBGP_TRATRA = 1 # 0 to activate bufferisation
  Local Char DBGP_TRACE_NAME(250) : DBGP_TRACE_NAME = "DBG_TRACE_"+num$(adxuid(2))
  Local Char DBGP_TRAFIC(250) : DBGP_TRAFIC = filpath("TRA", DBGP_TRACE_NAME, "tra")
  # For trace bufferization (because we are notified too late on debug init session)
  Local Clbfile DBGP_TRABUF(0)(100)
  Local Integer DBGP_TRABUF_IDX : DBGP_TRABUF_IDX = 0

  # Condition for full debugger (depending on server version)
  Local Shortint DBG_FULL_DEBUG
  # Functions name depending on light or full debugger
  # - NEW_... for full debugger
  # - OLD_... for light debugger (with old versions of X3 engine)
  Local Char FN_STACK_GET(100)
  Local Char FN_SET_BREAKPOINT(100)
  Local Char FN_GET_BREAKPOINT(100)
  Local Char FN_REM_BREAKPOINT(100)
  Local Char FN_UPD_BREAKPOINT(100)
  Local Char FN_LIST_BREAKPOINT(100)
  Local Char FN_CTX_GET(100)
  Local Char FN_CORE_GET_FILE(100)
  Local Char FN_SOURCE_GET(100)

  Local Libelle DBG_CHAR64(64)
  Local Libelle DBG_INT64(255)

  # Debugger program name
  Local Char DBG_DEBUG_NAME(130)
  # Debug line offset 0 or 1, depending on sources first line management
  Local Shortint DEBUG_LINE_OFFSET : [LDB]DEBUG_LINE_OFFSET = 0

  #-----------------------------------------------------------------------------
  ## JML 29/03/00 V130 Suggestion, essayer de préserver l'environnement
  #-----------------------------------------------------------------------------
  Local Libelle  DBG_FSTAT
  Local Shortint DBG_STAT1
  Local Shortint DBG_ERRN
  Local Shortint DBG_STATUS
  Local Char     DBG_APARAM(255)
  Local Integer  DBG_EXPR_NBVAR : [LDB]DBG_EXPR_NBVAR = 5
  Local Char     DBG_EXPR_VAR(7)(1..[LDB]DBG_EXPR_NBVAR) :#attention 7 caractères max !!!
  Local Char     ENGINE_VERSION(30)
  Local Char     AECLIPSE(1)
  Local Char     AECLIDBG(1)
  Local Char     AECLIMAC(255)
  Local Char     AECLIPRT(10)
  Local Char     AECLIDBGTR(1)
  Local Libelle  DBG_FIX_STACK
  Local Libelle  DBG_SUPPORT_DBGEVALUE2
  Local Libelle  DBG_SUPPORT_CANONICAL_BP

  [LDB]DBG_EXPR_VAR(1) = "fstat"
  [LDB]DBG_EXPR_VAR(2) = "stat1"
  [LDB]DBG_EXPR_VAR(3) = "status"
  [LDB]DBG_EXPR_VAR(4) = "errn"
  [LDB]DBG_EXPR_VAR(5) = "APARAM"

  [LDB]DGNOMPRG    = ""
  [LDB]NB_CALL_MAX = 25
  [LDB]NIV_CALL    = 0
  [LDB]MOD_CLIWEB= 0
  [LDB]DBG_TRACON = 0
  [LDB]DBG_TRACE_NAME = ""
  Raz [LDB]DBG_TRACE

  #@region Save Globals we are using to prevent from Kill [V]
  Local Integer DBG_UTF8
  If dim(GUTF8) > 0 : [LDB]DBG_UTF8 = GUTF8 : Else [LDB]DBG_UTF8 = 0 : Endif
  Local Integer DBG_ASCII
  If dim(GASCII) > 0 : [LDB]DBG_ASCII = GASCII : Else [LDB]DBG_ASCII = 50 : Endif
  Local Integer DBG_STABOU2
  If dim(GSTABOU2) > 0 : [LDB]DBG_STABOU2 = GSTABOU2 : Else [LDB]DBG_STABOU2 = 1800 : Endif
  Local Integer DBG_RDV
  If dim(GDBGRDV) > 0 : [LDB]DBG_RDV = GDBGRDV : Endif
  Local Char DBG_LANG(10)
  If dim(GLANGUE) > 0 : [LDB]DBG_LANG = GLANGUE : Endif
  # For V5 compatibility
  If dim(GACTX) > 0 : [LDB]DBG_LANG = func GET_CTX_VAL("LAN") : Endif
  #@endregion

  Call INIT_DEBUG_CONTEXT

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".INIDBG - start")
  Endif

  If [LDB]DBG_FULL_DEBUG
    Local Integer ENC_LENGTH
    Local Clbfile UTF8_VAL(8)
    Local Blbfile UTF8_BLOB(8)
  Endif

 [LDB]NB_VAR_MAX = 15
 [LDB]NB_BPT_MAX = 10

  # JML 03/05/01 Il faut apprendre à se passer du masque
  #              On redéfinit les variables et points d'arret

  Local Char     DBG_TRAEXP(80)(0..14) : # Expression des variables à suivre
  Local Shortint DBG_TRAVNB            : # Nbre de variables

  Local Shortint DBG_TRABNB            : # Nbre de points d'arret

  Local Shortint DBG_BK_ID            : DBG_BK_ID = 0
  Local Shortint DBG_BK_TYPE          : DBG_BK_TYPE = 1
  Local Shortint DBG_BK_STATE         : DBG_BK_STATE = 2
  Local Shortint DBG_BK_FILENAME      : DBG_BK_FILENAME = 3
  Local Shortint DBG_BK_LINENO        : DBG_BK_LINENO = 4
  Local Shortint DBG_BK_FUNCTION      : DBG_BK_FUNCTION = 5
  Local Shortint DBG_BK_EXCEPTION     : DBG_BK_EXCEPTION = 6
  Local Shortint DBG_BK_HIT_VALUE     : DBG_BK_HIT_VALUE = 7
  Local Shortint DBG_BK_HIT_CONDITION : DBG_BK_HIT_CONDITION = 8
  Local Shortint DBG_BK_HIT_COUNT     : DBG_BK_HIT_COUNT = 9

  Local Shortint DBG_BK_DATA_DIM      : DBG_BK_DATA_DIM = 2

  Local Char     DBG_BK_DEF(250)(0..[LDB]NB_BPT_MAX - 1, 10) : # Breakpoints definition table
  Local Clbfile  DBG_BK_DATA(DBG_BK_DATA_DIM)(0..[LDB]NB_BPT_MAX - 1) : # Breakpoints expression
# table

  Local Shortint DBG_CTX_LOCAL  : DBG_CTX_LOCAL = 0
  Local Shortint DBG_CTX_GLOBAL : DBG_CTX_GLOBAL = 1
  Local Shortint DBG_CTX_FILES  : DBG_CTX_FILES = 2
  Local Shortint DBG_CTX_MASKS  : DBG_CTX_MASKS = 3
  Local Shortint DBG_CTX_SYSTEM : DBG_CTX_SYSTEM = 4

  # Stack top level (0 or 1 ?)
  Local Shortint TOP_LEVEL : TOP_LEVEL = 0
  # Current stack level
  Local Shortint CURRENT_STACK : CURRENT_STACK = [LDB]TOP_LEVEL

  Local Shortint DBG_TRANIV(20)

  # JML 01/10/99 pour avoir valeur variable en mode trace après execution ligne

  Local Integer NB_TRATRAEXP
  Local Char    TRATRA_EXP(80)([LDB]NB_VAR_MAX+1) : # mb 4.6.2 bug 14517
  Local Integer NB_ARG([LDB]NB_CALL_MAX+1) : # Nbre max d'argument par niveau d'imbrication
  Local Char    TRA_EXP(80)([LDB]NB_VAR_MAX+1,[LDB]NB_CALL_MAX+1) : # TRA_EXP Valeurs des arguments
# par niveau

  #####
  ##### ATTENTION seul les 12 premiers DBG_EXCEPT_G sont reconnus !!
  #####

  Raz [LDB]NB_ARG, [LDB]TRA_EXP, [LDB]TRATRA_EXP
  Raz [LDB]NB_TRATRAEXP

  If [LDB]DBG_ON
    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
      [LDB]DBG_TRACE = "Open socket"
      Call TRACE_ADDPARAM([LDB]DBG_TRACE,"Host",[LDB]DBG_HOST)
      Call TRACE_ADDPARAM([LDB]DBG_TRACE,"Port",[LDB]DBG_PORT)
      Call TRACE([LDB]DBG_TRACE)
    Endif

    Onerrgo SOCKET_OPEN_ERR
    Opsock [LDB]DBG_HOST, val([LDB]DBG_PORT) Using [OPS]
    Iomode adxium [LDB]DBG_ASCII Using [OPS]
    Iomode adxirs "" Using  [OPS]
    Iomode adxifs "" Using  [OPS]
    Onerrgo
  Else
    [LDB]DBG_TRACE = "INIDBG - Debugger is not enabled!" + chr$(10)
    Append [LDB]DBG_TRACE, "  host=" + [LDB]DBG_HOST + ":" + num$([LDB]DBG_PORT)
    Append [LDB]DBG_TRACE, chr$(10) + '  dbgmode(0..2)=[' + num$(dbgmode(0)) + ', ' + num$(dbgmode(1)) + ', ' + num$(dbgmode(2)) + ']'
    Append [LDB]DBG_TRACE, chr$(10) + "  adxctx="
    Append [LDB]DBG_TRACE, [LDB]DBG_ADXCTX
    Call LOG_LINE("ERROR", [LDB]DBG_TRACE)
  Endif

  If dim([LDB]DBG_ON) > 0 & [LDB]DBG_ON
    Call SEEK_SOCK()

    [LDB]DBG_ACT=1
    Call DBGP_INIT()

    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE("Socket opened") : Endif
    # Pour passer le client ADAPI en mode Debug si communication ADAPI
    If [LDB]MOD_CLIWEB : Call TEMPON("$$DBG_OPE Debugger on") From GESECRAN : Endif
  Endif

  # if we quit the debug because of a fatal error the [LDB] no longer exists
  If clalev([LDB]) <= 0 or dim([LDB]DBG_ON) < 0
    Call LOG_FILE_LINE(func LOG_NAME,
&    "FATAL",
&    "Debugger crashed!" + chr$(10)
&    + "  clalev([LDB])=" + num$(clalev([LDB]))
&    + ", dim([LDB]DBG_ON)=" + num$(dim([LDB]DBG_ON)))
    End
  Endif
  [LDB]DBG_DBGMEMDELTA = [S]dbglong(0) - [LDB]DBG_DBGMEMUSED
  [LDB]DBG_DBGMEMLOADED = [S]dbglong(1) # save mem loaded value

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".INIDBG - end" + chr$(10)
    Append [LDB]DBG_TRACE, '  $maxmem=' + num$([LDB]DBG_MAXMEM) + chr$(10)
    Append [LDB]DBG_TRACE, '  $freemem=' + num$([LDB]DBG_FREEMEM) + chr$(10)
    Append [LDB]DBG_TRACE, '  $memory_used=' + num$([LDB]DBG_DBGMEMUSED) + chr$(10)
    Append [LDB]DBG_TRACE, '  $memory_delta=' + num$([LDB]DBG_DBGMEMDELTA) + chr$(10)
    Gosub MEMORY_INFO
    Call TRACE([LDB]DBG_TRACE)
  Endif
End

##############################################################################
# Subroutine de traitement d'erreur sur ouverture de la socket
##############################################################################
$SOCKET_OPEN_ERR

  [LDB]DBG_ON = 0  :#arret du mode debug!

  [LDB]DBG_TRACE = "Failed to open socket on " + [LDB]DBG_HOST + ":" + num$([LDB]DBG_PORT)
  Append [LDB]DBG_TRACE, chr$(10) + '  dbgmode(0..2)=[' + num$(dbgmode(0)) + ', ' + num$(dbgmode(1)) + ', ' + num$(dbgmode(2)) + ']'
  Gosub APPEND_ERR_WHERE
  Call LOG_LINE("ERROR", [LDB]DBG_TRACE)

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = "SOCKET_OPEN_ERR: stop debug mode"
    Call TRACE([LDB]DBG_TRACE)
    Gosub TRACE_WHERE
  Endif

  Local Char MSG(255)
  If mess(121,150,1)<>""
    MSG = mess(121,150,1)
  Else
    MSG = "Debugger not active. Start it first!"
  Endif
  If dim(GRELCLI) > 0 : Infbox(MSG + chr$(10) + " [" + [LDB]DBG_HOST + ":" + num$([LDB]DBG_PORT) + "]") : Endif


#  dbgmode(1)=0 :# arrêt du mode debug

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE('SOCKET_OPEN_ERR: dbgmode(0..2)=[' + num$(dbgmode(0)) + ', ' + num$(dbgmode(1)) + ', ' + num$(dbgmode(2)) + ']' + chr$(10))
  Endif
Resume


##############################################################################
# Subprog de fermeture dont le nom est stocké dans [S]adxdbx
##############################################################################
Subprog ENDDBG
$ENDDBG_
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".ENDDBG - start"
    Append [LDB]DBG_TRACE, ': dbgmode(0..2)=[' + num$(dbgmode(0)) + ', ' + num$(dbgmode(1)) + ', ' + num$(dbgmode(2)) + ']'
    If dim([LDB]DBG_ON) > 0
      Append [LDB]DBG_TRACE, ", DBG_ON=" + num$([LDB]DBG_ON)
    Else
      Append [LDB]DBG_TRACE, ", DBG_ON=<undefined>"
    Endif
    Call TRACE([LDB]DBG_TRACE)
  Endif

  If dim([LDB]DBG_ON) < 0 or [LDB]DBG_ON = 0
    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE(".ENDDBG - abort") : Endif
    End
  Endif

  If clalev([M:AKL]) or dbgmode = 2
    Call LOG_FILE_LINE(func LOG_NAME,
&    "FATAL",
&    "ENDDBG - Debugging aborted!" + chr$(10)
&    + "  clalev([M:AKL])=" + num$(clalev([M:AKL]))
&    + ', dbgmode(0..2)=[' + num$(dbgmode(0)) + ', ' + num$(dbgmode(1)) + ', ' + num$(dbgmode(2)) + ']'
&    )
#    dbgmode(1)=0 :# arrêt du mode debug
    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE(".ENDDBG - abort") : Endif
    End
  Endif


#  Local Integer CTX_MEM
#  CTX_MEM = int(([S]dbglong(1) - [LDB]DBG_DBGMEMLOADED) / 1024) + 1
#  If CTX_MEM < 0 : dbglong(33) = 0 : Else dbglong(33) = CTX_MEM : Endif

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Raz [LDB]DBG_TRACE
    Gosub MEMORY_INFO_EX
    Call TRACE_APPEND([LDB]DBG_TRACE)
  Endif

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = "Close socket"
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"Host",[LDB]DBG_HOST)
    Append [LDB]DBG_TRACE, chr$(10)
    Append [LDB]DBG_TRACE, '  maxmem=' + num$(maxmem) + chr$(10)
    Append [LDB]DBG_TRACE, '  freemem=' + num$(freemem)
    Call TRACE([LDB]DBG_TRACE)
  Endif

  # close Socket
  If [LDB]DBG_ACT=1
    Sleep 1
    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE("Socket closed") : Endif
    Onerrgo SOCKET_CLOSE_ERR
    Opsock [LDB]DBG_HOST,0 Using [OPS]
    [LDB]DBG_ACT=0
    Onerrgo
  Endif
  # Pour passer le client ADAPI en mode DebugOff
  If [LDB]MOD_CLIWEB : Call TEMPON("$$DBG_CLO Debugger off.") From GESECRAN : Endif

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE(".ENDDBG - end") : Endif

  # Turn off socket debugger
  Call DEBUGOFF
End

$MEMORY_INFO_EX
    Append [LDB]DBG_TRACE, '  $memory_ctx=' + num$(abs(dbglong(33))) + chr$(10)
    Append [LDB]DBG_TRACE, '  $maxmem=' + num$([LDB]DBG_MAXMEM) + chr$(10)
$MEMORY_INFO
    Append [LDB]DBG_TRACE, '  maxmem=' + num$(maxmem) + chr$(10)
    Append [LDB]DBG_TRACE, '  freemem=' + num$(freemem) + chr$(10)
    Append [LDB]DBG_TRACE, '  memory_used=' + num$([S]dbglong(0)) + chr$(10)
    Append [LDB]DBG_TRACE, '  memory_loaded=' + num$([S]dbglong(1)) + chr$(10)
    Append [LDB]DBG_TRACE, '  memory_max=' + num$([S]dbglong(2))
Return

##############################################################################
# Subroutine de traitement d'erreur sur fermeture de la socket
##############################################################################
$SOCKET_CLOSE_ERR
  [LDB]DBG_TRACE = "Failed to close socket"
  Gosub APPEND_ERR_WHERE
  Call LOG_LINE("ERROR", [LDB]DBG_TRACE)
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE("SOCKET_CLOSE_ERR=["+errmes$(errn) + "]") : Endif
Resume


##############################################################################
#  Subprog de commande dont le nom est stocké dans [S]adxdbc
##############################################################################
Subprog INPDBG(DBG_FICHIER, DBG_NUM_LIG, DBG_DSC, DBG_BNB, DBG_BNF, DBG_OPT)
Value    Char    DBG_FICHIER()   : # Nom du TRT à debugger
Value    Integer DBG_NUM_LIG     : # No Ligne courante du TRT à debugger
Value    Char    DBG_DSC()       : # Ligne courante du TRT correpondant à DBG_NUM_LIG
Variable Integer DBG_BNB         : # Nbre de point d'arrêt
Variable Char    DBG_BNF()()     : # Valeur des points d'arrêt
Variable Integer DBG_OPT         : # Status de sortie  du Boxinp
                                 : # 201 Ligne       : Passe à la ligne
                                 : # 202 Instruction : Saute les Call
                                 : # 203 Continuer   : Va au Break Point
                                 : # 007 Abandon
$INPDBG_

  If clalev([M:AKL]) or dbgmode = 2 or dim([LDB]DBG_ON) < 0 or [LDB]DBG_ON = 0
    DBG_OPT = 7
    dbgmode(1)=0 :# arrêt du mode debug
    End
  Endif

  [LDB]DBG_STAT1   = [S]stat1
  [LDB]DBG_ERRN    = errn
  [LDB]DBG_FSTAT   = [S]fstat
  [LDB]DBG_STATUS  = [S]status
  If dim(APARAM)>-1 : [LDB]DBG_APARAM  = APARAM : Else : [LDB]DBG_APARAM = "undefined" : Endif

#-----------------------------------------------------------------------------
## Try to preserve current environnement
#-----------------------------------------------------------------------------


### JML 02/05/01 Pour tracer les erreurs du debugger
Onerrgo ERR_LAST_CHANCE

#-----------------------------------------------------------------------------
#  ATTENTION AUX NOMS DE VARIABLES !!!
#  ===============================
#  On crée dans la classe [L] du TRT debuggué ...
#-----------------------------------------------------------------------------

Local Integer DBG_NL
Local Integer DBG_NL_MAX           : # JML 24/07/00 Nbre lignes Max de l'écran
Local Integer DBG_I, DBG_J, DBG_K
Local Integer DBG_NEXT             : # Position prochain ':'
Local Integer DBG_OK
Local Char    DBG_SRCFIC(250)      : # Nom du TRT à Débugger
Local Char    DBG_EXEFIC(250)      : # Nom du TRT$adx à Débugger
Local Char    DBG_CHAINEA(250)
Local Char    DBG_CHAINEB(250)
Local Char    DBG_SAVIFS(5)
Local Char    DBG_SAVIRS(5)
Local Integer DBG_SAVIUM
Local Char    DBG_NOM_TRT(250)
Local Char    DBG_OPENI(250)(2)    : # Pour adxcio, 0=openi, 1=openo
Local Integer DBG_ADXSEEK(2)       : # Pour adxcio
Local Char    DBG_NOM_MACHINE(250)
Local Char    DBG_NOM_APPLI(250)
Local Integer DBG_ERR

[L]DBG_SAVIFS  = [S]adxifs
[L]DBG_SAVIRS  = [S]adxirs
[L]DBG_SAVIUM  = [S]adxium
[S]adxifs = ""
[S]adxirs = chr$(10)

If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
  [LDB]DBG_TRACE = ".INPDBG - start"
  Call TRACE_ADDPARAM([LDB]DBG_TRACE,"Trt",DBG_FICHIER)
  Call TRACE_ADDPARAM([LDB]DBG_TRACE,"Line",DBG_DSC)
  Call TRACE_ADDPARAM([LDB]DBG_TRACE,"NumLine",num$(DBG_NUM_LIG))
  Append [LDB]DBG_TRACE, chr$(10) + "  traceType=" + num$([LDB]DBGP_TRATRA)
  Call TRACE([LDB]DBG_TRACE)
Endif

# si le flag DBG_ON false
If ![LDB]DBG_ON
  [LDB]DBG_TRACE = "INPDBG - Debugger is not enabled!" + chr$(10)
  Append [LDB]DBG_TRACE, "  host=" + [LDB]DBG_HOST + ":" + num$([LDB]DBG_PORT)
  Append [LDB]DBG_TRACE, chr$(10) + '  dbgmode(0..2)=[' + num$(dbgmode(0)) + ', ' + num$(dbgmode(1)) + ', ' + num$(dbgmode(2)) + ']'
  Append [LDB]DBG_TRACE, chr$(10) + "  adxctx="
  Append [LDB]DBG_TRACE, [LDB]DBG_ADXCTX
  Call LOG_LINE("ERROR", [LDB]DBG_TRACE)

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(">>>>> Stop debug mode!")
  Else
    If ![LDB]MOD_CLIWEB & dim(GRELCLI) > 0 : Infbox("Debugger is not started!")  Titled "Debugger" : Endif
  Endif
  DBG_OPT = 7
  End
Endif

Local Clbfile TRACED_LINE(5)
Local Char    TRA_SRC_LINE(250)

If DBG_FICHIER = ""
  End
Endif

#-----------------------------------------------------------------------------
## DBGP variable
#-----------------------------------------------------------------------------

Local Char     DBGP_CMDNAME(30)       : # DBGP command name
# command args from ascci('a')=97 to ascii('z')=122
Local Char     DBGP_CMDARGS(250)(97..122)  : # DBGP command args ( DBGP_CMDARGS(0)= -a arg,
# DBGP_CMDARGS(1) = -b arg, ...)
Local Clbfile  DBGP_CMDDATA(5)        : # DBGP command data

#-----------------------------------------------------------------------------
# niv0 - pour avoir valeur variables après execution ligne
#-----------------------------------------------------------------------------
#If not [LDB]DBG_FULL_DEBUG
  If ([LDB]DBGP_TRATRA=0 or [LDB]DBGP_TRATRA=2 or [LDB]DBGP_TRATRA=3) and [LDB]NB_TRATRAEXP
    If [LDB]DBGP_TRATRA = 2
      Raz [L]DBG_OPENI, [L]DBG_ADXSEEK
      If adxcio(1)<>-1 : # Pbl tokenisation pour adxcio, jcd n'a pas envoyé rcptok à MGA
                         # JML 17/09/99 De plus en 110 ADXCIO renvoi n'importe quoi, dixit JCD
                         #              Sur Unix ADXNFS(0) renvoi '', sur NT @nomap.Nom_trt.src !!
                         #              et Boum, mais la vache savait nager...
        [L]DBG_OPENI(1)   = adxnfs(adxcio(1)) : # Toujours pbl token adxnfs !!
        [L]DBG_ADXSEEK(1) = adxseek(1)
      Endif
      adxifs = ""
      adxirs = chr$(10)
      Openo [LDB]DBGP_TRAFIC , -1 Using [DBG]  : # On conserve l'existant !
    Endif

    # Maintenant au tour des variables
    For [L]DBG_OK=1 To [LDB]NB_TRATRAEXP
      Onerrgo ERREUR
      # JML/JC 18/10/99 X3 transforme fstat en Ctrl B ) et donc le wrseq est perdu
      #                 Avec KT tout doit rentrer dans l'ordre

      TRACED_LINE = "(After)  " + [LDB]TRATRA_EXP([L]DBG_OK)+"="+num$(evalue([LDB]TRATRA_EXP([L]DBG_OK)))
      Call DBGP_TRACE_CALL(TRACED_LINE)

      Onerrgo
    Next [L]DBG_OK

    If [LDB]DBGP_TRATRA = 2
      Openo Using [DBG]
      [S]adxifs = [L]DBG_SAVIFS
      [S]adxirs = [L]DBG_SAVIRS
      [S]adxium = [L]DBG_SAVIUM
    Endif

    Raz [LDB]NB_TRATRAEXP, [LDB]TRATRA_EXP
  Endif
#Endif

[L]DBG_NOM_TRT = func GET_SRC_NAME([L]DBG_FICHIER)
[LDB]DGNOLIGN = [L]DBG_NUM_LIG
[LDB]DBGP_SRC_LINE = [L]DBG_DSC
Raz [LDB]DBGP_SRC_LINE_B64

#-----------------------------------------------------------------------------
# Format source name
#-----------------------------------------------------------------------------
# [L]DBG_SRCFIC must be equal to @SUPERV.TRT/ZDL2.src
[L]DBG_NL = instr(1, [L]DBG_FICHIER, '$')
If [L]DBG_NL > 0
  # From v6 : Trt=[@SUPERV.TRT/ZDL2$adx]
  If instr(1, [L]DBG_FICHIER, '.TRT')
    [L]DBG_SRCFIC = left$([L]DBG_FICHIER,[L]DBG_NL-1)+".src"
  Else
    [L]DBG_SRCFIC = left$([L]DBG_FICHIER,[L]DBG_NL-1)+".stc"
  Endif
Else
  # From v5 : Trt=[@SUPERV150.ZDL2]
  [L]DBG_NL = instr( 1, [L]DBG_FICHIER, '.' )
  [L]DBG_SRCFIC = left$([L]DBG_FICHIER, [L]DBG_NL) + "TRT/" + [L]DBG_NOM_TRT + ".src"
Endif

#-----------------------------------------------------------------------------
# niv0 - Chargement du source du traitement si rupture sur le nom du source
#-----------------------------------------------------------------------------
If [L]DBG_FICHIER<>[LDB]DGNOMPRG
  # Current source has changed

  # Have we got the source code : (size > 0) ?
  [LDB]DBG_TRASRC = func LOADFILE([L]DBG_SRCFIC) > 0

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = "Adx changed:"
    Call TRACE_ADDPARAM([LDB]DBG_TRACE,"current", [LDB]DGNOMPRG)
    Call TRACE_ADDPARAM([LDB]DBG_TRACE,"new",[L]DBG_FICHIER)
    Call TRACE_ADDPARAM([LDB]DBG_TRACE,"file",[L]DBG_SRCFIC)
    Call TRACE_ADDPARAM([LDB]DBG_TRACE,"full source",num$([LDB]DBG_TRASRC))
    Call TRACE([LDB]DBG_TRACE)
  Endif

  [LDB]DGNOMPRG = [L]DBG_FICHIER   : # mémo du source courant (Déclaré dans Subprog INIDBG)
Else
  # Current source has not changed
  # then do not change [LDB]DBG_TRASRC current value
Endif

If [LDB]DBG_TRASRC : # On a les sources
  [L]TRA_SRC_LINE = mid$([LDB]DBG_TRASRCBUF, [LDB]DBG_TRASRCINFO([L]DBG_NUM_LIG,0), [LDB]DBG_TRASRCINFO([L]DBG_NUM_LIG,1))
Else
  [L]TRA_SRC_LINE = [L]DBG_DSC
Endif


Raz [L]DBG_CHAINEA

#-----------------------------------------------------------------------------
# niv0 - gestion des lignes "Subprog"
# si on n'est pas en mode d'affichage JAVA
# si on a un source
# si la Ligne courante du TRT commence par "SUBPROG"
#-----------------------------------------------------------------------------

#  [M:DBG] --> [LDB]DBG_

If [LDB]DBG_TRASRC & instr(1,toupper([L]DBG_DSC),"SUBPROG")
 If [LDB]NIV_CALL<[LDB]NB_CALL_MAX-1
  If [LDB]NIV_CALL>0 & [LDB]NB_ARG([LDB]NIV_CALL)>0
   # On commence par virer les arguments en cours
   For [L]DBG_I=[LDB]DBG_TRAVNB-1 To 0 Step -1
    If [LDB]DBG_TRANIV([L]DBG_I)=[LDB]NIV_CALL
     #Dela [L]DBG_I, 1 [LDB]DBG_TRAVNB # Only for mask
     [LDB]DBG_TRAVNB -= 1
    Endif
   Next [L]DBG_I
  Endif
  [LDB]NIV_CALL += 1
  Raz [LDB]NB_ARG([LDB]NIV_CALL)
  For [L]DBG_I=0 To [LDB]NB_VAR_MAX-1
   Raz [LDB]TRA_EXP([L]DBG_I,[LDB]NIV_CALL)
  Next [L]DBG_I
  [L]DBG_NL = instr(1,[L]TRA_SRC_LINE,"(")
  If [L]DBG_NL>0
   [L]DBG_CHAINEA = right$([L]TRA_SRC_LINE,[L]DBG_NL+1)
  Endif
  While [L]DBG_NL>0
   [L]DBG_NL = instr(1,[L]DBG_CHAINEA,",")
   If [L]DBG_NL<=0
    [L]DBG_NL = instr(1,[L]DBG_CHAINEA,")")
   Endif
   If [L]DBG_NL>0 & left$([L]DBG_CHAINEA,[L]DBG_NL-1)<>"(" : # Cas pas d'argument
    If [LDB]DBG_TRAVNB<[LDB]NB_VAR_MAX
     [LDB]DBG_TRAEXP([LDB]DBG_TRAVNB) = left$([L]DBG_CHAINEA,[L]DBG_NL-1)
     [LDB]DBG_TRANIV([LDB]DBG_TRAVNB) = [LDB]NIV_CALL
     [LDB]DBG_TRAVNB += 1

     [LDB]TRA_EXP([LDB]NB_ARG([LDB]NIV_CALL),[LDB]NIV_CALL) = left$([L]DBG_CHAINEA,[L]DBG_NL-1)
     [LDB]NB_ARG([LDB]NIV_CALL) += 1

     [L]DBG_CHAINEA = right$([L]DBG_CHAINEA,[L]DBG_NL+1)
     If [L]DBG_CHAINEA=""
      [L]DBG_NL = 0 : # On sort ...
     Endif
    Else
     [L]DBG_NL = 0 : # On sort ...
    Endif : #     If [LDB]DBG_TRAVNB<[LDB]NB_VAR_MAX
   Endif : #    If [L]DBG_NL>0 & left$([L]DBG_CHAINEA,[L]DBG_NL-1)<>"("
  Wend
 Endif : # If [LDB]NIV_CALL<[LDB]NB_CALL_MAX

#-----------------------------------------------------------------------------
# niv0 - gestion des lignes "end"
# si on n'est pas en mode d'affichage JAVA
# si on a un source
# si la Ligne courante du TRT commence par "END"
#-----------------------------------------------------------------------------
Elsif [LDB]DBG_TRASRC & instr(1,toupper([L]DBG_DSC),"END")

 # Il faut dépiler le niveau et recharger les variables
 If [LDB]NB_ARG([LDB]NIV_CALL)>0
  # On commence par virer les arguments en cours
  For [L]DBG_I=[LDB]DBG_TRAVNB-1 To 0 Step -1
   If [LDB]DBG_TRANIV([L]DBG_I)=[LDB]NIV_CALL
    #Dela [L]DBG_I, 1 [LDB]DBG_TRAVNB # Only for mask
    [LDB]DBG_TRAVNB -= 1
   Endif
  Next [L]DBG_I
 Endif
 If [LDB]NIV_CALL>0
  [LDB]NIV_CALL -= 1
  [L]DBG_I = 0
  While [L]DBG_I<=[LDB]NB_ARG([LDB]NIV_CALL)-1
   [LDB]DBG_TRAEXP([LDB]DBG_TRAVNB) = [LDB]TRA_EXP([L]DBG_I,[LDB]NIV_CALL)
   [LDB]DBG_TRANIV([LDB]DBG_TRAVNB) = [LDB]NIV_CALL
   [LDB]DBG_TRAVNB += 1
   [L]DBG_I += 1
  Wend
 Endif
Endif : # If instr(1,toupper([L]DBG_DSC),"SUBPROG")

# Trace
  If [LDB]DBGP_TRATRA = 0 or [LDB]DBGP_TRATRA = 2 or [LDB]DBGP_TRATRA = 3
    If [LDB]DBGP_TRATRA = 2
      Raz [L]DBG_OPENI, [L]DBG_ADXSEEK
      If adxcio(1)<>-1 : # Pbl tokenisation pour adxcio, jcd n'a pas envoyé rcptok à MGA
                         # JML 17/09/99 De plus en 110 ADXCIO renvoi n'importe quoi, dixit JCD
                         #              Sur Unix ADXNFS(0) renvoi '', sur NT @nomap.Nom_trt.src !!
                         #              et Boum, mais la vache savait nager...
        [L]DBG_OPENI(1)   = adxnfs(adxcio(1)) : # Toujours pbl token adxnfs !!
        [L]DBG_ADXSEEK(1) = adxseek(1)
      Endif

      adxifs = ""
      adxirs = chr$(10)

      Openo [LDB]DBGP_TRAFIC, -1 Using [DBG]  : # On conserve l'existant !
    Endif

    TRACED_LINE = format$("K:30X",[L]DBG_FICHIER)+"("+format$("N0:4",[L]DBG_NUM_LIG)+"):"
    TRACED_LINE += [L]TRA_SRC_LINE

    Call DBGP_TRACE_CALL(TRACED_LINE)

    # Maintenant au tour des variables
    Raz [LDB]NB_TRATRAEXP, [LDB]TRATRA_EXP

    For [L]DBG_OK=0 To [LDB]DBG_TRAVNB-1

      If instr(1,[L]TRA_SRC_LINE,[LDB]DBG_TRAEXP([L]DBG_OK))
        Onerrgo ERREUR

        TRACED_LINE = "(before) " + [LDB]DBG_TRAEXP([L]DBG_OK)+"="+num$(evalue([LDB]DBG_TRAEXP([L]DBG_OK)))
        Call DBGP_TRACE_CALL(TRACED_LINE)

        Onerrgo
        # JML 01/10/99 MAJ des variables pour connaitre valeur après execution de la ligne
        If [LDB]NB_TRATRAEXP<[LDB]NB_VAR_MAX
          [LDB]NB_TRATRAEXP += 1
          [LDB]TRATRA_EXP([LDB]NB_TRATRAEXP) = [LDB]DBG_TRAEXP([L]DBG_OK)
        Endif
      Endif
    Next [L]DBG_OK

    Openo Using [DBG]

    adxifs = [L]DBG_SAVIFS
    adxirs = [L]DBG_SAVIRS
    adxium = [L]DBG_SAVIUM

  Endif

If [LDB]DBGP_TRACING = 0
  # Commencer par donner la position
  Call SEEK_SOCK()

  Repeat

    #==================================================================
    # Parse the DBGP command
    # command [SPACE] [arguments] [SPACE] -- base64(data) [NULL]
    #==================================================================
    Call DBGP_PARSE_COMMAND([L]DBGP_CMDNAME, [L]DBGP_CMDARGS, [L]DBGP_CMDDATA)
    If [LDB]DBG_ON=0
      [L]DBG_OPT = 7
#      dbgmode(1)=0
      Break
    Endif
    Call DBGP_RESPONSE([L]DBGP_CMDNAME, [L]DBGP_CMDARGS)

    #default action is to iterate until an continuation command
    [L]DBG_OPT = [LDB]DBG_STABOU2
    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
      [LDB]DBG_TRACE = '.CMD_LOOP_START' + chr$(10)
      Append [LDB]DBG_TRACE, '  DBG_OPT=' + num$([L]DBG_OPT) + chr$(10)
      If dim([LDB]DBG_RDV) > 0
        Append [LDB]DBG_TRACE, '  DBG_RDV=' + num$([LDB]DBG_RDV) + chr$(10)
      Else
        Append [LDB]DBG_TRACE, '  DBG_RDV=<undefined>' + chr$(10)
      Endif
      Gosub MEMORY_INFO
      Call TRACE([LDB]DBG_TRACE)
    Endif

    ################################################################
    # [L]DBG_OPT = 7     : # Status de sortie  du Boxinp
    #                    : # 201 Ligne       : Passe à la ligne
    #                    : # 202 Instruction : Saute les Call
    #                    : # 203 Continuer   : Va au Break Point
    #                    : # 007 Abandon
    ################################################################

    ##########################
    If [L]DBGP_CMDNAME = "stack_get"
    ##########################
      Call DBGP_STACK_GET([L]DBGP_CMDARGS)

    ##########################
    Elsif [L]DBGP_CMDNAME = "feature_set"
    ##########################
      Call DBGP_FEATURE_SET([L]DBGP_CMDARGS)

    ##########################
    Elsif [L]DBGP_CMDNAME = "feature_get"
    ##########################
      Call DBGP_FEATURE_GET([L]DBGP_CMDARGS)

    ##########################
    Elsif [L]DBGP_CMDNAME = "stdout"
    ##########################
      Call DBGP_ADD_ATTRIBUTE("success", "1")

    ##########################
    Elsif [L]DBGP_CMDNAME = "stderr"
    ##########################
      Call DBGP_ADD_ATTRIBUTE("success", "1")

    ##########################
    Elsif [L]DBGP_CMDNAME = "step_into"
    ##########################
      If [LDB]FIRST_STEP_INTO = 0
        [L]DBG_OPT = 201 : # Next ligne
      Else
#        [L]DBG_OPT = [LDB]DBG_STABOU2
        If dim([LDB]DBG_RDV) > 0 & [LDB]DBG_RDV = 1
          [LDB]DBG_RDV = 0
          [L]DBG_OPT = 203
        Endif
        [LDB]FIRST_STEP_INTO = 0
      Endif
      Call DBGP_CONTINUATION("break", "ok")

      If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE("201 StepIn") : Endif

    ##########################
    Elsif [L]DBGP_CMDNAME = "step_over"
    ##########################
      If [LDB]DBGP_TRATRA = 0 or [LDB]DBGP_TRATRA = 2 or [LDB]DBGP_TRATRA = 3
        [L]DBG_OPT = 201
        [LDB]DBGP_TRACING = 202
      Else
        [L]DBG_OPT = 202 : #Instruction, Saute les Call
      Endif

      Call DBGP_CONTINUATION("break", "ok")

      If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE("202 StepOver") : Endif

    ##########################
    Elsif [L]DBGP_CMDNAME = "step_out"
    ##########################
      If [LDB]DBGP_TRATRA = 0 or [LDB]DBGP_TRATRA = 2 or [LDB]DBGP_TRATRA = 3
        [L]DBG_OPT = 201
        [LDB]DBGP_TRACING = 204
      Else
        [L]DBG_OPT = 204 : #Instruction, arret après le prochain end ou procahin Return
      Endif

      Call DBGP_CONTINUATION("break", "ok")

      If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE("204 StepOut") : Endif

    ##########################
    Elsif [L]DBGP_CMDNAME="run"
    ##########################
      If [LDB]DBGP_TRATRA = 0 or [LDB]DBGP_TRATRA = 2 or [LDB]DBGP_TRATRA = 3
        [L]DBG_OPT = 201
        [LDB]DBGP_TRACING = 203
      Else
        [L]DBG_OPT = 203 : # Next break point
      Endif
      Call DBGP_CONTINUATION("break", "ok")

      If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE("203 Next bkp") : Endif

      ##------------------------------------------------------------------------------
      ##                            B R E A K P O I N T S (light debugger version) $OBK
      ##------------------------------------------------------------------------------
      If not [LDB]DBG_FULL_DEBUG
       # Ré-affectons les variables du moteur...
       Raz [L]DBG_BNF
       [L]DBG_BNB = 0

       For [L]DBG_I = 0 To [LDB]NB_BPT_MAX-1

        [L]DBG_CHAINEA = func OLD_GET_X3_BREAKPOINT([L]DBG_I)

#        If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
#           [LDB]DBG_TRACE = "- Def breakpoint("-num$([L]DBG_I)-")=["+[L]DBG_CHAINEA+"]"
#            Call TRACE([LDB]DBG_TRACE)
#        Endif

        If left$([L]DBG_CHAINEA,1) = chr$(1)     #si c'est un break point "expression vérifiée"

        Elsif left$([L]DBG_CHAINEA,1) = chr$(2)  #si c'est un break point "modif de variable"

        Elsif left$([L]DBG_CHAINEA,1) = chr$(3)  #si c'est un break point "instruction"

        Elsif left$([L]DBG_CHAINEA,1) = chr$(4)  #si c'est un break point "line" + condition
          # already formatted
        Else                                     #si c'est un break  point "sur numéro de ligne"
          # découpage de la définition du break  point par rapport au séparateur du numéro de ligne
          [L]DBG_J = instr(1,[L]DBG_CHAINEA,":")
          If [L]DBG_J>0
            [L]DBG_CHAINEB = left$([L]DBG_CHAINEA,[L]DBG_J-1)
            Call EXTRACT_FILE_PARTS([L]DBG_CHAINEB, [L]DBG_NOM_MACHINE, [L]DBG_NOM_APPLI, [L]DBG_NOM_TRT)

            #recup numéro de ligne
            [L]DBG_CHAINEA = right$([L]DBG_CHAINEA,[L]DBG_J)
             #si il n'y a pas de serveur
             If [L]DBG_NOM_MACHINE="" | [L]DBG_NOM_MACHINE=adxmac(0)
               #si l'appli est l'appli courante => NomDuTraitement:numligne
               If [L]DBG_NOM_APPLI = nomap
                [L]DBG_CHAINEA = [L]DBG_NOM_TRT + [L]DBG_CHAINEA
               #sinon => NomAppli.NomDuTraitement:numligne
               Else
                [L]DBG_CHAINEA = [L]DBG_NOM_APPLI +"."+ [L]DBG_NOM_TRT + [L]DBG_CHAINEA
               Endif
             #sinon => NomMachine@NomAppli.NomDuTraitement:numligne
             Else
               [L]DBG_CHAINEA = [L]DBG_NOM_MACHINE +"@"+ [L]DBG_NOM_APPLI +"."+ [L]DBG_NOM_TRT + [L]DBG_CHAINEA
             Endif
          Endif
        Endif

        If [L]DBG_CHAINEA <> ""
          [L]DBG_BNF([L]DBG_BNB) = [L]DBG_CHAINEA
          If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
             [LDB]DBG_TRACE = "- Add breakpoint("-num$([L]DBG_BNB)-")=["+[L]DBG_CHAINEA+"]"
             Call TRACE([LDB]DBG_TRACE)
          Endif
          [L]DBG_BNB += 1
        Endif

       Next [L]DBG_I
      Endif
      ##-----------------------------------------------------------------------------

    ##########################
    Elsif [L]DBGP_CMDNAME="stop"
    ##########################

      [L]DBG_OPT = 7
      If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
        Call TRACE('STOP: dbgmode(0..2)=[' + num$(dbgmode(0)) + ', ' + num$(dbgmode(1)) + ', ' + num$(dbgmode(2)) + ']')
      Endif
      Call DBGP_CONTINUATION("stopped", "ok")

    ##########################
    Elsif [L]DBGP_CMDNAME="detach"
    ##########################

      # Stop debug + quit
      [L]DBG_OPT = 7
      If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
        Call TRACE('DETACH: dbgmode(0..2)=[' + num$(dbgmode(0)) + ', ' + num$(dbgmode(1)) + ', ' + num$(dbgmode(2)) + ']')
      Endif
      Call DBGP_CONTINUATION("stopped", "ok")
      dbgmode(1)=0

    ##########################
    Elsif [L]DBGP_CMDNAME="breakpoint_set"
    ##########################
      Call DBGP_SET_BREAKPOINT([L]DBGP_CMDARGS, [L]DBGP_CMDDATA)

    ##########################
    Elsif [L]DBGP_CMDNAME="breakpoint_get"
    ##########################
      Call DBGP_GET_BREAKPOINT([L]DBGP_CMDARGS)

    ##########################
    Elsif [L]DBGP_CMDNAME="breakpoint_update"
    ##########################
      Call DBGP_UPD_BREAKPOINT([L]DBGP_CMDARGS)

    ##########################
    Elsif [L]DBGP_CMDNAME="breakpoint_list"
    ##########################
      Call DBGP_LIST_BREAKPOINT()

    ##########################
    Elsif [L]DBGP_CMDNAME="breakpoint_remove"
    ##########################
      Call DBGP_REM_BREAKPOINT([L]DBGP_CMDARGS)

    ##########################
    Elsif [L]DBGP_CMDNAME="context_names"
    ##########################
      Call DBGP_CTX_NAME([L]DBGP_CMDARGS)

    ##########################
    Elsif [L]DBGP_CMDNAME="context_get"
    ##########################
      Call DBGP_CTX_GET([L]DBGP_CMDARGS)

      # envoi des "file", "mask" et "class" courante
  #    Call SEND_MESS3("52","dbgstr",0,dbgstr(0))
  #    Call SEND_MESS3("52","dbgstr",1,dbgstr(1))
  #    Call SEND_MESS0("53")

    ##########################
    Elsif [L]DBGP_CMDNAME="eval"
    ##########################
      Call DBGP_EVAL([L]DBGP_CMDDATA)

    ##########################
    Elsif [L]DBGP_CMDNAME="property_get"
    ##########################
      Call DBGP_PROP_GET([L]DBGP_CMDARGS)

    ##########################
    Elsif [L]DBGP_CMDNAME="property_set"
    ##########################
      Call DBGP_PROP_SET([L]DBGP_CMDARGS, [L]DBGP_CMDDATA)

    ##########################
    Elsif [L]DBGP_CMDNAME="xcmd_x3_memory_get"
    ##########################
      Call DBGP_MEMORY_GET()

    ##########################
    Elsif [L]DBGP_CMDNAME="xcmd_x3_tables_get"
    ##########################
      Call DBGP_TABLES_GET()

    ##########################
    Elsif [L]DBGP_CMDNAME="xcmd_x3_masks_get"
    ##########################
      Call DBGP_MASKS_GET()

    ##########################
    Elsif [L]DBGP_CMDNAME="xcmd_x3_processes_get"
    ##########################
      Call DBGP_PROCESSES_GET()

    ##########################
    Elsif [L]DBGP_CMDNAME="xcmd_x3_classes_get"
    ##########################
      Call DBGP_CLASSES_GET()

    ##########################
    Elsif [L]DBGP_CMDNAME="xcmd_x3_seq_files_get"
    ##########################
      Call DBGP_SEQ_FILES_GET()

    # Tracing ##########################################################
    ##########################
    Elsif [L]DBGP_CMDNAME="xcmd_x3_trace_init"
    ##########################
      Call DBGP_TRACE_INIT([L]DBGP_CMDARGS)

    ##########################
    Elsif [L]DBGP_CMDNAME="xcmd_x3_trace_stop"
    ##########################
      If [LDB]DBGP_TRATRA = 2
        Call DBGP_TRACE_STOP([L]DBGP_CMDARGS)
      Endif

    ##########################
    Elsif [L]DBGP_CMDNAME="xcmd_x3_trace_delete"
    ##########################
      If [LDB]DBGP_TRATRA = 2
        Call DBGP_TRACE_DELETE([L]DBGP_CMDARGS)
      Endif

    # Tracing ##########################################################


    ##########################
    Elsif [L]DBGP_CMDNAME="xcmd_x3_set_depth"
    ##########################
      Call DBGP_SET_DEPTH([L]DBGP_CMDARGS)

    ##########################
    Elsif [L]DBGP_CMDNAME="xcmd_x3_set_debug_line_offset"
    ##########################
      Call DBGP_SET_DLO([L]DBGP_CMDARGS)

    ##########################
    Elsif [L]DBGP_CMDNAME="source"
    ##########################
      Call DBGP_SOURCE_GET([L]DBGP_CMDARGS)

    ##########################
    Elsif [L]DBGP_CMDNAME="$error"
    ##########################
      Raz [LDB]CLB_TEMP
      Local Integer LENGTH
      [L]LENGTH = func CORE_B64DECODE([L]DBGP_CMDDATA, [LDB]CLB_TEMP, [LDB]DBG_ASCII)
      Call LOG_LINE("ERROR", [LDB]CLB_TEMP)
      [L]DBG_OPT = 7

    ##########################
    Else
    ##########################

      If [LDB]DBG_TRACON = 1
         Call TRACE(".DBGP_ERROR: unmanaged command '" + DBGP_CMDNAME + "'")
      Endif
      [L]DBG_OPT = 7

    Endif

    # send the DBGP response
    Call DBGP_RESP_SEND()

    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
      Call TRACE(".CMD_LOOP_TEST: DBG_OPT=" + num$([L]DBG_OPT))
    Endif

  Until [L]DBG_OPT<>[LDB]DBG_STABOU2
Endif

