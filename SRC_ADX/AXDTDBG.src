######################################################################
#Extraction des paramètres Host,Port,trt,sub et line de la copie de l'adxctx
#ADAPI:NA1:debug.on=on;debug.trt=;debug.sub=;debug.line=tata;
#debug.host=;debug.port=1789;trace.on=off;trace.filepath=%24HOME%2Ftmp;trace.dbglong=200;
######################################################################
Subprog READ_ADXCTX
  Local Integer WI
  Local Integer WJ

  #si type de session "ADAPI" dans ADXCTX  => communication ADAPI
  If toupper(left$([LDB]DBG_ADXCTX,5))="ADAPI" :  [LDB]MOD_CLIWEB = 1 : Endif

  #trace entrée spgm
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE(".READ_ADXCTX Start") : Endif

  Raz [LDB]DBG_ON
  Raz [LDB]DBG_HOST
  Raz [LDB]DBG_PORT
  Raz [LDB]DBG_SESTYP
  Raz [LDB]DBG_SESWEI

  WI = instr(1,[LDB]DBG_ADXCTX,"debug.on=on")
  If WI
   [LDB]DBG_ON = 1
  Endif

  WI = instr(1,[LDB]DBG_ADXCTX,"debug.host=")
  If WI
   WJ = instr(WI,[LDB]DBG_ADXCTX,";")
   If WJ
    [LDB]DBG_HOST = seg$([LDB]DBG_ADXCTX,WI+11,WJ-1)
   Endif
  Endif

  WI = instr(1,[LDB]DBG_ADXCTX,"debug.port=")
  If WI
   WJ = instr(WI,[LDB]DBG_ADXCTX,";")
   If WJ
    [LDB]DBG_PORT = seg$([LDB]DBG_ADXCTX,WI+11,WJ-1)
   Endif
  Endif

  If [LDB]DBG_HOST=""
    WI = instr(1,[LDB]DBG_ADXCTX,"address=")
    If WI
      WJ = instr(WI,[LDB]DBG_ADXCTX,";")
      If WJ
       [LDB]DBG_HOST = seg$([LDB]DBG_ADXCTX,WI+8,WJ-1)
      Endif
    Endif
  Endif

  If [LDB]DBG_HOST<>"" and [LDB]DBG_PORT<>"" : [LDB]DBG_ON = 1 : Endif

  [LDB]DBG_SESTYP = left$([LDB]DBG_ADXCTX,5)
  [LDB]DBG_SESWEI = mid$([LDB]DBG_ADXCTX,7,3)

  #trace sortie spgm
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".READ_ADXCTX parametres:"
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"Debugger_On",num$([LDB]DBG_ON))
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"Host",[LDB]DBG_HOST)
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"Port",[LDB]DBG_PORT)
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"Type",[LDB]DBG_SESTYP)
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"SubType",[LDB]DBG_SESWEI)
    Call TRACE ([LDB]DBG_TRACE)
    Call TRACE (".READ_ADXCTX - end")
  Endif

End

######################################################################
#
######################################################################
$ERR_LAST_CHANCE
  [LDB]DBG_TRACE = "Last chance error!" + chr$(10)
  Gosub APPEND_ERR_WHERE
  Call LOG_LINE("FATAL", [LDB]DBG_TRACE)

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
   [LDB]DBG_TRACE = ".ERR_LAST_CHANCE"
    Call TRACE([LDB]DBG_TRACE)
    Gosub TRACE_WHERE
  Endif
  dbgmode(1)=0 :# arrêt du mode debug
  End
Resume

$TRACE_WHERE
  If len([LDB]DBG_LOG_ERRMES) = 0
    [LDB]DBG_LOG_ERRMES = "  [" + num$(errn) + " - " + errmes$(errn)-errp+"("+num$(errl)+"): '"+errm+"']"
  Endif
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE_APPEND([LDB]DBG_LOG_ERRMES)
  Endif
  Raz [LDB]DBG_LOG_ERRMES
Return

$APPEND_ERR_WHERE
  [LDB]DBG_LOG_ERRMES = "  [" + num$(errn) + " - " + errmes$(errn)-errp+"("+num$(errl)+"): '"+errm+"']"
   Append [LDB]DBG_TRACE, chr$(10)
   Append [LDB]DBG_TRACE, [LDB]DBG_LOG_ERRMES
Return

######################################################################
# Ajoute " lib=[value]" à la fin d'une line
######################################################################
Subprog TRACE_ADDPARAM(DBGT_LINE, DBGT_LIB, DBGT_VALUE)
  Variable Clbfile DBGT_LINE()
  Value    Char    DBGT_LIB()

  Append DBGT_LINE, " "
  Append DBGT_LINE, DBGT_LIB
  Append DBGT_LINE, "=["
  Case type(DBGT_VALUE)
    When -1 : # variable does not exist
    When 1, 2, 4, 5, 6, 7 : # Libelle, Shortint, Integer, Float, Double, Decimal
      Append DBGT_LINE, num$(DBGT_VALUE)
    When 3 : # Date
      Append DBGT_LINE, num$(DBGT_VALUE)
    When 8 : # T8
    When 9 : # IbmDCB
    When 522 : # Blbfile
    When 523 : # Clbfile
      Append DBGT_LINE, DBGT_VALUE
    When 524 : # Object
      Append DBGT_LINE, "<Object>"
    When 525 : # Uuident
      Append DBGT_LINE, num$(DBGT_VALUE)
    When 526 : # Datetime
      Append DBGT_LINE, num$(DBGT_VALUE)
    When Default : # Alpha
      Append DBGT_LINE, DBGT_VALUE
  Endcase

   Append DBGT_LINE, "]"
End

Subprog LOG_LINE(ETYPE, LINE)
  Value Char ETYPE
  If [LDB]DBG_LOG_NAME = ""
    [LDB]DBG_LOG_NAME = func LOG_NAME
    Call LOG_CLEAR([LDB]DBG_LOG_NAME)
  Endif

  Call LOG_FILE_LINE([LDB]DBG_LOG_NAME, ETYPE, LINE)
  If dim([LDB]DBG_LOG_CTX) > 0 & len([LDB]DBG_LOG_CTX) > 0
    Call LOG_FILE_LINE([LDB]DBG_LOG_NAME, "CONTEXT", [LDB]DBG_LOG_CTX)
  Endif
End

#**
#* Adds a line to the trace file
#* @internal
#*
#* @param DBGT_LINE
#*!
Subprog LOG_FILE_LINE(FNAME, ETYPE, LINE)
  Value Char FNAME
  Value Char ETYPE

  Openo FNAME, -1 Using [TR__]
  Iomode adxifs "" Using [TR__]
  Iomode adxium [LDB]DBG_UTF8 Using [TR__]
  Wrseq num$(datetime$) + " ["+ ETYPE + "] ", LINE Using [TR__]
  Openo Using [TR__]
End

#**
#* Adds a line to the trace file
#* @internal
#*
#* @param DBGT_LINE
#*!
Subprog TRACE(DBGT_LINE)
  Openo [LDB]DBG_TRACE_NAME, -1 Using [TR__]
  Iomode adxium [LDB]DBG_ASCII Using [TR__]
  Wrseq num$(datetime$) + " " + DBGT_LINE Using [TR__]
  Openo Using [TR__]
End

#**
#* Adds a line to the trace file
#* @internal
#*
#* @param DBGT_LINE
#*!
Subprog TRACE_APPEND(DBGT_LINE)
  Openo [LDB]DBG_TRACE_NAME, -1 Using [TR__]
  Iomode adxium [LDB]DBG_ASCII Using [TR__]
  Wrseq DBGT_LINE Using [TR__]
  Openo Using [TR__]
End

#**
#* Init the trace context
#* @internal
#*!
Subprog TRACE_INIT
  If instr(1,[LDB]DBG_ADXCTX,"debug.trace=on") : [LDB]DBG_TRACON = 1 : Endif
  If dim([LDB]DBG_TRACON) < 0 | [LDB]DBG_TRACON=0
    End
  Endif

  If dim(GDBGTRACE) > -1 & GDBGTRACE <> ""
    [LDB]DBG_TRACE_NAME = GDBGTRACE
  Endif
  If [LDB]DBG_TRACE_NAME = ""
    [LDB]DBG_TRACE_NAME = filpath("TRA","X3DEBUG_" + toupper(ctrans(adxusr,".\/|*@","______")),"tra" ,0)
  Endif
  Call LOG_CLEAR([LDB]DBG_TRACE_NAME)
End

#**
#* Clears the content of a log file
#* @internal
#*!
Subprog LOG_CLEAR(NAME)
  Value Char NAME

  Openo NAME,0 Using [TR__]
  Openo Using [TR__]
End

$ERR_LOG
[LDB]DBG_LOG_ERRN = errn
[LDB]DBG_TRACE = "Unexpected error"
Gosub APPEND_ERR_WHERE
Call LOG_LINE("ERROR", [LDB]DBG_TRACE)
Resume

#**
#* Returns the log file name
#* @internal
#*!
Funprog LOG_NAME()
End filpath("TRA","X3DEBUG_ERR_" + toupper(ctrans(adxusr,".\/|*@","______")),"tra" ,0)


#**
#* Returns the trace name
#* @internal
#*!
Funprog TRACE_NAME()
End [LDB]DBG_TRACE_NAME

#**
#* Init the eclispe debugger context
#* @internal
#*!
Subprog INIT_DEBUG_CONTEXT()
  Onerrgo ERR_LOG
  # pour assurer la compatibilité avec le mode client serveur
  # attention au format :
  # - type de session sur 5 caractère (ex: ADAPI, X3_CS,...)
  # - poids de la session sur 3 caractères (ex: NAx, PUB,...)
  If dim(GBROWS) < 0 | GBROWS=0
    [LDB]DBG_ADXCTX = "X3_CS:NA1:"
  Else
    [LDB]DBG_ADXCTX = adxctx
  Endif

  Call SET_PARAM("debug.on","on")

  Local Char HOST(250)
  Local Integer K
#  If GBROWS = 0
#    Call PARCLI("ComputerName", HOST) From GLOBVAR
#    Infbox "ComputerName=" + HOST + chr$(10) + "adxmac(-2)=" + adxmac(-2)
#    Call SET_HOST(HOST) : # @ip du pc
#  Endif

  Local Char USR(5)
  USR = func AXDTMAIN.GET_USER()

  Local Char PARAMVAL(255)
  Call PARAMUTIL("AECLIPSE", PARAMVAL, USR, "") From SUBAUS
  [LDB]AECLIPSE = PARAMVAL
  Call PARAMUTIL("AECLIDBG", PARAMVAL, USR, "") From SUBAUS
  [LDB]AECLIDBG = PARAMVAL
  Call PARAMUTIL("AECLIMAC", PARAMVAL, USR, "") From SUBAUS
  [LDB]AECLIMAC = PARAMVAL
  Call PARAMUTIL("AECLIPRT", PARAMVAL, USR, "") From SUBAUS
  [LDB]AECLIPRT = PARAMVAL
  Call PARAMUTIL("AECLIDBGTR", PARAMVAL, USR, "") From SUBAUS
  [LDB]AECLIDBGTR = PARAMVAL

  If dim(GDBGTRACE) > -1 & GDBGTRACE <> ""
    [LDB]AECLIDBGTR = "2"
  Endif
  Call SET_TRACE([LDB]AECLIDBGTR)

  Call TRACE_INIT

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".INIT_DEBUG_CONTEXT: environment" + chr$(10)
    Append [LDB]DBG_TRACE, '  debugger="' + func GETVERSION() + '"' + chr$(10)
    Append [LDB]DBG_TRACE, '  AXDTMAIN="' + func AXDTMAIN.GETVERSION() + '"' + chr$(10)
    Append [LDB]DBG_TRACE, '  runtime="' + ver$(0) + '"' + chr$(10)
    Append [LDB]DBG_TRACE, '  supervisor='
    If dim(GVERSOL) > 0
      Append [LDB]DBG_TRACE, '"' + GVERSOL + '"'
    Endif
    Append [LDB]DBG_TRACE, chr$(10)
    Append [LDB]DBG_TRACE, '  client='
    If dim(GRELCLI) > 0
      Append [LDB]DBG_TRACE, '"' + GRELCLI + '"'
    Endif
    Append [LDB]DBG_TRACE, chr$(10)
    Append [LDB]DBG_TRACE, '  adxctx="' + [LDB]DBG_ADXCTX + '"' + chr$(10)
    Append [LDB]DBG_TRACE, '  adxuid(1..2)=[' + num$(adxuid(1)) + ', ' + num$(adxuid(2)) + ']' + chr$(10)
    Append [LDB]DBG_TRACE, '  adxusr=' + adxusr + chr$(10)
    Append [LDB]DBG_TRACE, '  adxpid=' + num$(adxpid) + chr$(10)
    Append [LDB]DBG_TRACE, '  adxdir=' + adxdir + chr$(10)
    Append [LDB]DBG_TRACE, '  dbgmode(0..2)=[' + num$(dbgmode(0)) + ', ' + num$(dbgmode(1)) + ', ' + num$(dbgmode(2)) + ']' + chr$(10)
    Append [LDB]DBG_TRACE, '  adxpid=' + num$(adxpid) + chr$(10)
    Append [LDB]DBG_TRACE, '  AECLIPSE="' + [LDB]AECLIPSE + '"' + chr$(10)
    Append [LDB]DBG_TRACE, '  AECLIDBG="' + [LDB]AECLIDBG + '"' + chr$(10)
    Append [LDB]DBG_TRACE, '  AECLIMAC="' + [LDB]AECLIMAC + '"' + chr$(10)
    Append [LDB]DBG_TRACE, '  AECLIPRT="' + [LDB]AECLIPRT + '"' + chr$(10)
    Append [LDB]DBG_TRACE, '  adxmac(-2..2)=["' + adxmac(-2) + '", "' + adxmac(-1) + '", "'
    Append [LDB]DBG_TRACE, adxmac(0) + '", "' + adxmac(1) + '", "' + adxmac(2) + '"]' + chr$(10)
    Local Integer APPCOUNT, I
    APPCOUNT = dim(nomap)
    Append [LDB]DBG_TRACE, '  nomap(0..' + num$(APPCOUNT-1) + ')=['
    For I = 0 To APPCOUNT - 1
      If I <> 0
        Append [LDB]DBG_TRACE, ','
      Endif
      Append [LDB]DBG_TRACE, '"' + nomap(I) + '"'
    Next I
    Append [LDB]DBG_TRACE, ']' + chr$(10)

    If dim(GDBGMAC) > 0
      Append [LDB]DBG_TRACE, '  GDBGMAC="' + GDBGMAC + '"' + chr$(10)
    Endif
    If dim(GDBGPORT) > 0
      Append [LDB]DBG_TRACE, '  GDBGPORT=' + num$(GDBGPORT) + chr$(10)
    Endif
    If dim(GDBGRDV) > 0
      Append [LDB]DBG_TRACE, '  GDBGRDV=' + num$(GDBGRDV) + chr$(10)
    Endif
    If dim(GDBGTRACE) > 0
      Append [LDB]DBG_TRACE, '  GDBGTRACE="' + GDBGTRACE + '"' + chr$(10)
    Endif
    Append [LDB]DBG_TRACE, '  GUSER='
    If dim(GUSER) > 0
      Append [LDB]DBG_TRACE, '"' + GUSER + '"'
    Endif
    Append [LDB]DBG_TRACE, chr$(10)
    Append [LDB]DBG_TRACE, '  GACTX.USER='
    If dim(GACTX) > 0
      Append [LDB]DBG_TRACE, '"' + func GET_CTX_VAL("USER") + '"'
    Endif
    Append [LDB]DBG_TRACE, chr$(10)
    Append [LDB]DBG_TRACE, '  adxpno(0..)=['
    Local Integer LEVEL
    While adxpno(LEVEL) <> ""
      If LEVEL > 0
        Append [LDB]DBG_TRACE, ', '
      Endif
      Append [LDB]DBG_TRACE, "'" + adxpno(LEVEL) + "'"
      LEVEL += 1
    Wend
    Append [LDB]DBG_TRACE, '"]' + chr$(10)
    Append [LDB]DBG_TRACE, '  $freemem=' + num$([LDB]DBG_FREEMEM) + chr$(10)
    Append [LDB]DBG_TRACE, '  $memory_used=' + num$([LDB]DBG_DBGMEMUSED) + chr$(10)
    Gosub MEMORY_INFO_EX
    Append [LDB]DBG_TRACE, '  Comm_Adapi=' + num$([LDB]MOD_CLIWEB) + chr$(10)
    Append [LDB]DBG_TRACE, '  Default_Mask=' + dbgstr(1)

    Call TRACE([LDB]DBG_TRACE)
  Endif

  # Init debugger variable from potential attach rendez-vous
  Call INIT_FROM_ATTACH()

  Call READ_ADXCTX

  If [LDB]DBG_HOST = ""
    [LDB]DBG_HOST = adxmac(-2)
  Endif

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".INIT_DEBUG_CONTEXT: after initialization" + chr$(10)
    Append [LDB]DBG_TRACE, "  DBGP=" + num$([LDB]DBG_ON) + chr$(10)
    Append [LDB]DBG_TRACE, '  host="' + [LDB]DBG_HOST + '"' + chr$(10)
    Append [LDB]DBG_TRACE, "  port=" +num$([LDB]DBG_PORT)
    Call TRACE([LDB]DBG_TRACE)
  Endif

  # Init debug state (full or light)
  Call INIT_DEBUG_STATE()
  Onerrgo
End

Subprog INIT_FROM_ATTACH()
  Local Char HOST(250)
  Local Char PORT(10)

  # Retrieve the potential attach event
  Local Integer ID    # Process ID
  Local Char WRK(250) # Workspace ID
  Local Char NAM(250) # IDE Alias
  Local Char REF(250) # internal identifier of the event (uniq per solution)
  Local Char TRT(250) # Program name
  Local Char MES(250) # Status message
  Local Integer STA
  [L]ID = adxpid # process ID, used to match attach event
  Onerrgo ERR_LOG
    If dim(GSERVEUR)<=0 : Global Integer GSERVEUR : Endif
    # AECLIRDV is now part of the update process through Eclipse
    [L]STA = func AECLIRDV.ATTACHRDV([L]ID, [L]WRK, [L]NAM, [L]REF, [L]TRT, [L]MES)
    If [L]WRK <> "" : [LDB]DBG_IDEKEY = [L]WRK : Endif
  Onerrgo

  [LDB]DBG_LOG_CTX = "PID=" + num$([L]ID) + ", IDEKEY=" + [LDB]DBG_IDEKEY + chr$(10)
  Append [LDB]DBG_LOG_CTX, '  MES=' +[L]MES + chr$(10)
  Append [LDB]DBG_LOG_CTX, '  GDBGMAC='
  If dim(GDBGMAC) > 0 : Append [LDB]DBG_LOG_CTX, GDBGMAC : Else Append [LDB]DBG_LOG_CTX, "<undefined>" : Endif
  Append [LDB]DBG_LOG_CTX, chr$(10) + '  GDBGPORT='
  If dim(GDBGPORT) > 0 : Append [LDB]DBG_LOG_CTX, num$(GDBGPORT) : Else Append [LDB]DBG_LOG_CTX, "<undefined>" : Endif
  Append [LDB]DBG_LOG_CTX, chr$(10) + '  AECLIMAC=' + [LDB]AECLIMAC + chr$(10)
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".INIT_FROM_ATTACH: STA=" + num$([L]STA) + ", ID=" + num$([L]ID) + ", UUID=" + [L]WRK + ", MES=" + [L]MES
    Call TRACE([LDB]DBG_TRACE)
  Endif

  Local Char PROXY(255)
  Local Integer POS
  # Set user debugger machine
  If dim(GDBGMAC) > -1 & GDBGMAC <> ""
   # extract proxy and workspace id from the machine uri
   If instr(0, GDBGMAC, "dbgp://") > 0
     POS = instr(8, GDBGMAC, "/")
     If POS > 0
       [LDB]DBG_IDEKEY = right$(GDBGMAC, POS + 1)
       PROXY = mid$(GDBGMAC, 8, POS - 8)
     Else
       PROXY = right$(GDBGMAC, 8)
     Endif
     If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
       [LDB]DBG_TRACE = ".INIT_FROM_ATTACH: extract from GDBGMAC proxy=" + [L]PROXY
       Call TRACE([LDB]DBG_TRACE)
     Endif
   Endif
   HOST = GDBGMAC
   Raz GDBGMAC
  Endif
  # AECLIMAC is use as a workaround to set the IDEKEY to allow debug with dbgaff
  If left$([LDB]AECLIMAC, 1) = "@"
    [LDB]DBG_IDEKEY = right$([LDB]AECLIMAC, 2)
  Elsif HOST = ""
    HOST = [LDB]AECLIMAC
  Endif

  # Set user debugger port
  If dim(GDBGPORT) > -1 & GDBGPORT > -1
    PORT = num$(GDBGPORT)
    GDBGPORT = -1
  Endif
  If val(PORT) = 0
    PORT = [LDB]AECLIPRT
  Endif
  If val(PORT) = 0
    # If not filled, set to default port
    PORT = "10000"
#    PORT = "9514" :# currently unassigned in iana port list
# http://www.iana.org/assignments/service-names-port-numbers/service-names-port-numbers.xml
  Endif

  Append [LDB]DBG_LOG_CTX, '  PROXY=' + PROXY + chr$(10)
  If [LDB]DBG_IDEKEY <> ""
    # if an idekey is specified we want to use a proxy
    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
      Call TRACE(".INIT_FROM_ATTACH: before get proxy=" + PROXY)
    Endif
    If PROXY = ""
      PROXY = func AXDTMAIN.GET_IDEPROXY([LDB]DBG_IDEKEY)
    Endif
    Append [LDB]DBG_LOG_CTX, '  IDEPROXY=' + PROXY + chr$(10)
    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
      Call TRACE(".INIT_FROM_ATTACH: after get proxy=" + PROXY)
    Endif
    POS = instr(0, PROXY, ":")
    If POS > 0
      Local Char PROXY_HOST(250), PROXY_PORT(10)
      Local Integer PROXY_ERR
      PROXY_HOST = left$(PROXY, POS-1)
      PROXY_PORT = right$(PROXY, POS+1)
      Onerrgo PROXY_OPEN_ERR
      Opsock PROXY_HOST, val(PROXY_PORT) Using [PXY]
      Opsock PROXY_HOST, 0 Using [PXY]
      Onerrgo
      If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
        Call TRACE(".INIT_FROM_ATTACH: proxy open error=" + num$(PROXY_ERR) + " - " + errmes$(PROXY_ERR))
      Endif
      If PROXY_ERR = 0
        HOST = PROXY_HOST
        PORT = PROXY_PORT
      Endif
    Endif
  Endif

  Append [LDB]DBG_LOG_CTX, '  DBGADDR=' + HOST + ":" + PORT + chr$(10)
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".INIT_FROM_ATTACH: Host=" + HOST + ", Port=" + PORT)
  Endif
  If HOST <> ""
    Call SET_HOST(HOST)
  Endif
  Call SET_PORT(PORT)
End

$DEBUGON_ERR
Resume

$PROXY_OPEN_ERR
 PROXY_ERR = errn
 [LDB]DBG_TRACE = "Failed to open proxy connection on "
 Append [LDB]DBG_TRACE, PROXY
 Gosub APPEND_ERR_WHERE
 Call LOG_LINE("WARN", [LDB]DBG_TRACE)
Resume

Subprog DEBUGOFF()
#  If dim([LDB]DBG_ADXCTX)>0 : Kill [LDB]DBG_ADXCTX : Endif
  [LDB]DBG_ON = 0
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE('.DEBUGOFF (normal end): dbgmode(0..2)=[' + num$(dbgmode(0)) + ', ' + num$(dbgmode(1)) + ', ' + num$(dbgmode(2)) + '], DBG_ON=' + num$([LDB]DBG_ON))
  Endif
  If dbgmode(1) = 1
    dbgmode(1)=0 :# arrêt du mode debug
  Endif
End

#==========================================================
# Helper functions for DBGP command parsing and xml generation
#==========================================================

Subprog SEEK_SOCK()
#  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE(".BEFORE SEEK: seekpos=" +
# num$(adxseek("OPS")) + ", fstat=" + num$(fstat)) : Endif
  Seek 0 Using [OPS]
#  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE(".AFTER_SEEK: seekpos=" +
# num$(adxseek("OPS")) + ", fstat=" + num$(fstat)) : Endif
End


#**
#* Convert value from string format to integer format
#*
#* @private
#* @param STR string containing numeric value
#* @param DEF default value
#* @return numeric value
#*!
Funprog GET_NUM_VAL(STR, DEF)
  Value Char STR()
  Value Integer DEF
  Local Integer NUM_VALUE : [L]NUM_VALUE = DEF
  If STR <> ""
    [L]NUM_VALUE = val(STR)
  Endif
End [L]NUM_VALUE


#**
#* Parse a DBGP command line
#* <code>command [SPACE] [arguments] [SPACE] -- base64(data) [NULL]</code>
#* @private
#* @param DBGP_CMDNAME (out) the command name
#* @param DBGP_CMDARGS (out) the command args array
#* @param DBGP_CMDDATA (out) the command data
#*
#* @see <a href="http://www.xdebug.org/docs-dbgp.php">DBGP protocol documentation</a>
#*!
Subprog DBGP_PARSE_COMMAND(DBGP_CMDNAME, DBGP_CMDARGS, DBGP_CMDDATA)
  Variable Char     DBGP_CMDNAME()
  Variable Char     DBGP_CMDARGS()(97..122)
  Variable Clbfile  DBGP_CMDDATA()

  Local Libelle  BYTEVAL
  Local Char     CMDLINE(250)
  Local Char     CMDPART(250)
  Local Char     ARG(1)
  Local Integer  CMDIDX

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".DBGP_WAIT_COMMAND: DELAYED=" + num$([LDB]DBGP_DELAYED))
  Endif

  # send pending dbgp response
  If [LDB]DBGP_DELAYED
    [LDB]DBGP_DELAYED = 0
    Call DBGP_RESP_SEND()
  Endif


  DBGP_CMDNAME = ""
  DBGP_CMDDATA = ""
  Raz DBGP_CMDARGS

#  Call SEEK_SOCK()
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE_APPEND("")
    Call TRACE(".DBGP_WAIT_COMMAND: seekpos=" + num$(adxseek("OPS")) + ", fstat=" + num$(fstat))
  Endif
  CMDLINE = ""
  CMDPART = ""
  CMDIDX = -1
  Repeat
    Getseq 1, BYTEVAL Using [OPS]
    If fstat = 1
      [LDB]DBG_TRACE = "End of socket stream!"
      Append [LDB]DBG_TRACE, chr$(10) + "seekpos=" + num$(adxseek("OPS")) + ", fstat=" + num$(fstat)
      Call LOG_LINE("FATAL", [LDB]DBG_TRACE)

      If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
          Call TRACE("FATAL ERROR: >>>>>>>> END OF SOCKET STREAM <<<<<<<<")
          Call TRACE_APPEND("seekpos=" + num$(adxseek("OPS")) + ", fstat=" + num$(fstat) + chr$(10))
      Endif

      If [LDB]FIRST_STEP_INTO = 1
        Local Char MSG(255)
        If mess(121,150,1)<>""
          MSG = mess(121,150,1)
        Else
          MSG = "Debugger not active. Start it first!"
        Endif
        If dim(GRELCLI) > 0 : Infbox(MSG + chr$(10) + " [" + [LDB]DBG_HOST + ":" + num$([LDB]DBG_PORT) + "]") : Endif
      Endif
      [LDB]DBG_ON = 0  :#arret du mode debug!
      Break
    Endif

    CMDLINE += chr$(BYTEVAL)

    # break string on space
    If BYTEVAL = 32 | BYTEVAL = 0

      # first part is command name
      If len(DBGP_CMDNAME) = 0
        DBGP_CMDNAME = tolower(CMDPART)
#        If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE("...DBGP command: " +
# DBGP_CMDNAME) : Endif
      Elsif len(CMDPART) > 0
        # is it an arg ?
        If left$(CMDPART, 1) = "-"
          CMDIDX = -1
          If len(CMDPART) > 1
            ARG = tolower(mid$(CMDPART, 2, 1))
            If ARG = "-"
              CMDIDX = 0
            Else
              CMDIDX = ascii(ARG)
            Endif
          Endif
        Else
          If CMDIDX > 96 & CMDIDX < 123
            DBGP_CMDARGS(CMDIDX) = CMDPART
          Else CMDIDX = 0
            DBGP_CMDDATA = CMDPART
          Endif
        Endif
      Endif
      CMDPART = ""
    Else
      CMDPART += chr$(BYTEVAL)
#      If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1 : Call TRACE("...DBGP command part: " +
# CMDPART) : Endif
    Endif

  Until BYTEVAL = 0

  Call SEEK_SOCK()

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
      Call TRACE(".DBGP_PARSE_COMMAND: seekpos=" + num$(adxseek("OPS")) + ", fstat=" + num$(fstat))
      Call TRACE_APPEND(CMDLINE)
  Endif
End

#**
#* Sends the xml response in the format:
#* <code>[NUMBER] [NULL] XML(data) [NULL]</code>
#* @private
#* @param DBGP_DATA the xml string
#*!
Subprog DBGP_SEND(DBGP_DATA)
  Const Clbfile DBGP_DATA()
  Local Libelle SEP : SEP = 0
  Local Integer I

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
#    Local Char TEXTE (128)(1..64)
#    Setlob TEXTE With DBGP_DATA

    Call TRACE(".DBGP_RESP: seekpos=" + num$(adxseek("OPS")) + ", fstat=" + num$(fstat))
    Call TRACE_APPEND(num$(len(DBGP_DATA)))
    Call TRACE_APPEND(DBGP_DATA)
#    For I = 1 To dim(TEXTE)
#      If len(TEXTE(I)) = 0
#        Break
#      Endif
#      Call TRACE(TEXTE(I))
#    Next I
  Endif

  Wrseq num$(len(DBGP_DATA)) Using [OPS]
  Putseq 1, SEP Using [OPS]
  Wrseq DBGP_DATA Using [OPS]
  Putseq 1, SEP Using [OPS]
  Call SEEK_SOCK()

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".DBGP_RESP_SENDED: seekpos=" + num$(adxseek("OPS")) + ", fstat=" + num$(fstat))
  Endif
End

#**
#* Initializes the DBGP xml response
#* @private
#* @param CMDNAME
#* @param ARGS
#*!
Subprog DBGP_RESPONSE(CMDNAME, ARGS)
  Value Char CMDNAME()
  Value Char ARGS()(97..122)

  Local Char TID(20) : TID = ARGS(ascii('i'))
#  Raz [LDB]DBGP_XMLRESP
  [LDB]DBGP_XMLRESP = '<response command="'
  Append [LDB]DBGP_XMLRESP, CMDNAME
  Append [LDB]DBGP_XMLRESP, '" transaction_id="'
  Append [LDB]DBGP_XMLRESP, TID
  Append [LDB]DBGP_XMLRESP, '"'

  [LDB]DBGP_XMLLEVEL = 0
  [LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL) = "response"
End

#**
#* Adds preformatted xml bloc to the current DBGP xml response
#* @private
#* @param DATA
#*!
Subprog DBGP_ADD_XML(DATA)
  Const Clbfile DATA()

  # current xml tag is not already closed
  If left$([LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL), 1) <> "/"
    Append [LDB]DBGP_XMLRESP, '>'
    [LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL) = "/" + [LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL)
  Endif

  Local Integer I
#  Append [LDB]DBGP_XMLRESP, DATA
  Append [LDB]DBGP_XMLRESP, ctrans(DATA, sigma(I=0,31,chr$(I)), "")

End

#**
#* Adds an attribute to the current DBGP xml response
#* @private
#* @param ATTNAME
#* @param ATTVAL
#*!
Subprog DBGP_ADD_ATTRIBUTE(ATTNAME, ATTVAL)
  Value Char ATTNAME

  Append [LDB]DBGP_XMLRESP, ' '
  Append [LDB]DBGP_XMLRESP, ATTNAME
  Append [LDB]DBGP_XMLRESP, '="'
  Append [LDB]DBGP_XMLRESP, ATTVAL
  Append [LDB]DBGP_XMLRESP, '"'
End

#**
#* Adds a data text element to the current DBGP xml response
#* @private
#* @param DATA Clbfile
#*!
Subprog DBGP_ADD_DATA(DATA)
  Const Clbfile DATA

  # current xml tag is not already closed
  If left$([LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL), 1) <> "/"
    Append [LDB]DBGP_XMLRESP, '>'
    [LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL) = "/" + [LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL)
  Endif
  Append [LDB]DBGP_XMLRESP, DATA
End

Subprog DBGP_ADD_NODE(NODENAME)
  Value Char NODENAME()

  # current xml tag is not already closed
  If left$([LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL), 1) <> "/"
    Append [LDB]DBGP_XMLRESP, '>'
    [LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL) = "/" + [LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL)
  Endif
  [LDB]DBGP_XMLLEVEL += 1
  [LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL) = NODENAME

  Append [LDB]DBGP_XMLRESP, '<'
  Append [LDB]DBGP_XMLRESP, NODENAME
End

Subprog DBGP_CLOSE_NODE()
  If left$([LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL), 1) = "/"
    Append [LDB]DBGP_XMLRESP, '<'
    Append [LDB]DBGP_XMLRESP, [LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL)
    Append [LDB]DBGP_XMLRESP, '>'
  Else
    Append [LDB]DBGP_XMLRESP, '/>'
  Endif
  [LDB]DBGP_XMLTAGS([LDB]DBGP_XMLLEVEL) = ""
  [LDB]DBGP_XMLLEVEL -= 1
End

#**
#* Adds an attribute to the current DBGP xml response
#* @private
#*!
Subprog DBGP_RESP_SEND()
  If [LDB]DBGP_DELAYED : End : Endif

  Repeat
    Call DBGP_CLOSE_NODE()
  Until [LDB]DBGP_XMLLEVEL = -1

  Raz [LDB]DBGP_XMLTAGS
  [LDB]DBGP_XMLLEVEL = 0

# Convert all xml to UTF-8
# No longer converted since 20110627 (the engine now do the job)

  If not [LDB]DBG_FULL_DEBUG
    #[LDB]ENC_LENGTH = func UTF8_ENCODE2([LDB]DBGP_XMLRESP, [LDB]UTF8_VAL)
    [LDB]ENC_LENGTH = strEncode([LDB]DBGP_XMLRESP, [LDB]UTF8_BLOB, 0)
    [LDB]ENC_LENGTH = strDecode([LDB]UTF8_BLOB, [LDB]UTF8_VAL, 50)
    Call DBGP_SEND([LDB]UTF8_VAL)
    Raz [LDB]UTF8_VAL
  Else
    Call DBGP_SEND([LDB]DBGP_XMLRESP)
    Raz [LDB]DBGP_XMLRESP
  Endif
End

#==========================================================
# DBGP responses
#==========================================================

#**
#* Sends the dbgp init xml
#* @private
#*!
Subprog DBGP_INIT()
  Local Char IDEKEY(100)
  Local Char SERVER(250)

  IDEKEY = "com.sage.x3.xdt.dltk.debugger"
  SERVER = func AXDTMAIN.GET_APP_SERVER()

  [LDB]DBGP_XMLRESP = '<init'
  If [LDB]DBG_IDEKEY <> ""
    Append [LDB]DBGP_XMLRESP, ' idekey="' + [LDB]DBG_IDEKEY + '"'
  Else
    Append [LDB]DBGP_XMLRESP, ' idekey="' + [L]IDEKEY + '"'
  Endif
  Append [LDB]DBGP_XMLRESP, ' fileuri=""'
  Append [LDB]DBGP_XMLRESP, ' session="' + func AXDTMAIN.GET_BASEURL() + "/$debug"
  Append [LDB]DBGP_XMLRESP, "?idekey=" + [L]IDEKEY + "&amp;rtm=" + [LDB]ENGINE_VERSION + '"'
  Append [LDB]DBGP_XMLRESP, ' thread="' + num$(adxpid) + '"'
  Append [LDB]DBGP_XMLRESP, ' parent="'
   Append [LDB]DBGP_XMLRESP, adxdir
  Append [LDB]DBGP_XMLRESP, '"'
  Append [LDB]DBGP_XMLRESP, ' appid="'
    Append [LDB]DBGP_XMLRESP, SERVER + ":" + num$(adxtcp)
    Append [LDB]DBGP_XMLRESP, "/" + func AXDTMAIN.GET_APP_NAME()
    Append [LDB]DBGP_XMLRESP, "/" + func AXDTMAIN.ESCAPE_XML(adxusr) + "/" + num$(adxuid(2)) + "/" + num$(adxuid(1))
  Append [LDB]DBGP_XMLRESP, '"'
  Append [LDB]DBGP_XMLRESP, ' language="X3"'
  Append [LDB]DBGP_XMLRESP, ' protocol_version="1.0">'
  Append [LDB]DBGP_XMLRESP, '<engine version="' + [LDB]ENGINE_VERSION + '"/>'
  Append [LDB]DBGP_XMLRESP, '<author>Sage</author>'
  Append [LDB]DBGP_XMLRESP, '<url><![CDATA[http://www.sage.com]]></url>'
  Append [LDB]DBGP_XMLRESP, '<copyright><![CDATA[Copyright (c) 2000-'
  Append [LDB]DBGP_XMLRESP, num$(year(date$))
  Append [LDB]DBGP_XMLRESP, ' Sage]]></copyright>'
  Append [LDB]DBGP_XMLRESP, '</init>'

  Call DBGP_SEND([LDB]DBGP_XMLRESP)
End

#**
#* Sends the dbgp xml response to a continuation command (run, step_into, step_over, step_out, stop,
#* detach)
#*
#* @param STT the status (starting, stopping, stopped, running, break)
#* @param REASON the reason (ok, error, aborted, exception
#*!
Subprog DBGP_CONTINUATION(STT, REASON)
  Value Char STT()
  Value Char REASON()

  If STT = "break"
    [LDB]DBGP_DELAYED = 1
  Endif
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE(".DBGP_CONTINUATION: DELAYED=" + num$([LDB]DBGP_DELAYED))
  Endif

  Call DBGP_ADD_ATTRIBUTE("status", STT)
  Call DBGP_ADD_ATTRIBUTE("reason", REASON)
End

#**
#* Send response to the feature_get command:
#* <code>feature-get -i transaction_id -n feature_name</code>
#*
#* @param ARGS the argument list
#*!
Subprog DBGP_FEATURE_GET(ARGS)
  Value Char ARGS()(97..122)

  Local Char FEATURE_NAME(50) : FEATURE_NAME = ARGS(ascii('n'))
  Local Libelle SUPPORTED : SUPPORTED = 1
  Local Clbfile DATA(1) : DATA = ""

  Local Char PROP_ADDR(20) : PROP_ADDR = ARGS(ascii('a'))

  Case FEATURE_NAME
    When "language_supports_threads"
      DATA = "0"

    When "language_name"
      DATA = "x3"

    When "language_version"
      DATA = "1.7"

    When "encoding"
      DATA = "UTF-8"

    When "data_encoding"
      DATA = "base64"
#      DATA = "none"

    When "protocol_version"
      DATA = "1"

    When "supports_async"
      DATA = "0"

    # seems not to be called (by dltk framework)...
    When "breakpoint_types"
      DATA = "line conditional"
      If [LDB]DBG_FULL_DEBUG
        DATA += " exception watch"
      Endif

    When "multiple_sessions"
      DATA = "0"

    # max number of array or object children to initially retrieve
    When "max_children"
      DATA = num$([LDB]F_MAX_CHILDREN)

    # max amount of variable data to initially retrieve
    When "max_data"
      # TODO: support max_data
      DATA = num$([LDB]F_MAX_DATA)

    # maximum depth that the debugger engine may return when sending arrays, hashs or object
# structures to the IDE.
    When "max_depth"
      DATA = num$([LDB]F_MAX_DEPTH)

    When Default
      SUPPORTED = 0
      DATA = ""
  Endcase

  Call DBGP_ADD_ATTRIBUTE("feature_name", FEATURE_NAME)
  Call DBGP_ADD_ATTRIBUTE("supported", num$(SUPPORTED))
  Call DBGP_ADD_DATA(DATA)
End


#**
#* Send response to the feature_set command:
#* <code>feature_set -i transaction_id -n feature-name -v value</code>
#*
#* @param ARGS the argument list
#*!
Subprog DBGP_FEATURE_SET(ARGS)
  Value Char ARGS()(97..122)

  Local Char FEATURE_NAME(50) : FEATURE_NAME = ARGS(ascii('n'))
  Local Char FEATURE_VALUE(250) : FEATURE_VALUE = ARGS(ascii('v'))
  Local Libelle SUCCESS : SUCCESS = 1

  Case FEATURE_NAME
    When "encoding"

    When "multiple_sessions"

    # get|set [0|1] This feature can get set by the IDE if it wants to have
    # more detailed internal information on properties (eg. private members of
    # classes, etc.) Zero means that hidden members are not shown to the IDE.
    When "show_hidden"

    # allow IDE notifications
    When "notify_ok"
      [LDB]F_NOTIFY = val(FEATURE_VALUE)

    # max number of array or object children to initially retrieve
    When "max_children"
      [LDB]F_MAX_CHILDREN = val(FEATURE_VALUE)

    # max amount of variable data to initially retrieve
    When "max_data"
      [LDB]F_MAX_DATA = val(FEATURE_VALUE)

    # maximum depth that the debugger engine may return when sending arrays, hashs or object
# structures to the IDE.
    When "max_depth"
      [LDB]F_MAX_DEPTH = val(FEATURE_VALUE)
      # [LDB]F_MAX_DEPTH MUST be equal to 2 because of a dbpg issue
      [LDB]F_MAX_DEPTH = 2

    # core program name, which contains version
    When "x3_core_program_name"
      [LDB]F_X3_CORE_PROGRAM = FEATURE_VALUE
      [LDB]FN_CORE_GET_FILE = [LDB]F_X3_CORE_PROGRAM + ".GET_FILE"

    When Default
  Endcase

  Call DBGP_ADD_ATTRIBUTE("feature_name", FEATURE_NAME)
  Call DBGP_ADD_ATTRIBUTE("success", num$(SUCCESS))
End

#**
#* Send response to the stack_get command:
#* <code>stack_get -d [NUM] -i transaction_id</code></br>
#* The response is:
#* <pre>&lt;response command="stack_get" transaction_id="transaction_id"&gt;
#*   &lt;stack level="[NUM]"
#*          type="file|eval|?"
#*          filename="..."
#*          lineno="[NUM]"
#*          where=""
#*          cmdbegin="line_number:offset"
#*          cmdend="line_number:offset"/&gt;
#*   &lt;stack level="[NUM]"
#*          type="file|eval|?"
#*          filename="..."
#*          lineno="[NUM]"
#*          where=""
#*          cmdbegin="line_number:offset"
#*          cmdend="line_number:offset"/&gt;
#* &lt;/response&gt;
#* </pre>
#*!
Subprog DBGP_STACK_GET(ARGS)
  Value Char ARGS()(97..122)
  Call =[LDB]FN_STACK_GET With ARGS From =[LDB]DBG_DEBUG_NAME
End

#**
#* Get call stack  (full debugger version)
#*
#* @param ARGS
#*!
Subprog NEW_DBGP_STACK_GET(ARGS)
  Value Char ARGS()(97..122)

  #---------------------------------------------------------------
  # stack depth:
  #   optional, debugger engine should assume zero if not provided
  #---------------------------------------------------------------
  Local Integer DEPTH : DEPTH = func GET_NUM_VAL(ARGS(ascii('d')), [LDB]TOP_LEVEL)

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE (".NEW_DBGP_STACK_GET depth=" + num$([L]DEPTH))
  Endif

  Local Integer STAT
#  Raz [LDB]DBG_ARG
  [L]STAT = dbgCallStack([L]DEPTH, [LDB]DBG_ARG)
  If not [LDB]DBG_FIX_STACK
    Call DBGP_ADD_XML([LDB]DBG_ARG)
  Else
#  If 1
    Raz [LDB]CLB_TEMP
    Call FIX_STACK([LDB]CLB_TEMP, [LDB]DBG_ARG)
    Call DBGP_ADD_XML([LDB]CLB_TEMP)
  Endif
End

#**
#* Get call stack  (light debugger version)
#* With light debugger, there is only one stack level
#*
#* @param ARGS
#*!
Subprog OLD_DBGP_STACK_GET(ARGS)
  Value Char ARGS()(97..122)

  #---------------------------------------------------------------
  # stack depth:
  #   optional, debugger engine should assume zero if not provided
  #---------------------------------------------------------------
  Local Integer DEPTH : [L]DEPTH = func GET_NUM_VAL(ARGS(ascii('d')), [LDB]TOP_LEVEL)

  Local Char FILE_NAME(250)
  Local Integer POS
  Local Char SRCFIC(250)
  Local Integer LINENO
  Local Integer STACK_ADDED
  Local Char SERVER(250)

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE (".OLD_DBGP_STACK_GET depth=" + num$([L]DEPTH))
  Endif

  [L]SRCFIC = func GET_SRC_NAME([LDB]DGNOMPRG)
  [L]SERVER = func AXDTMAIN.GET_APP_SERVER()

  # x3://server:port/appli/file
  # x3://sodaix02:16008/@SUPERV.ZIDEX3Z$src
#  If [LDB]DBG_TRASRC # On a les sources
    [L]FILE_NAME = "x3://" + [L]SERVER + ":" + num$(adxtcp) + "/" + nomap + "/" + [L]SRCFIC + ".src"
#  Else
#    [L]FILE_NAME = "dbgp://" + [L]SERVER + ":" + num$(adxtcp) + "/" + nomap + "/" + [L]SRCFIC +
# ".src"
#  Endif

  [L]LINENO = [LDB]DGNOLIGN + [LDB]DEBUG_LINE_OFFSET

  Call DBGP_ADD_NODE("stack")
  Call DBGP_ADD_ATTRIBUTE("level", "0")
  Call DBGP_ADD_ATTRIBUTE("type", "file")
  Call DBGP_ADD_ATTRIBUTE("filename", [L]FILE_NAME)
  Call DBGP_ADD_ATTRIBUTE("lineno", num$([L]LINENO))
  Call DBGP_ADD_ATTRIBUTE("where", [L]SRCFIC)
  Call DBGP_ADD_ATTRIBUTE("cmdbegin", num$([L]LINENO) + ":0")
  Call DBGP_ADD_ATTRIBUTE("cmdend", num$([L]LINENO) + ":-1")
End

Funprog FIX_STACK(CLB, STACK)
  Variable Clbfile CLB()
  Variable Clbfile STACK()

  Local Integer TOK_POS
  Local Integer TOK_MARK
  Local Integer TOK_START
  Local Integer TOK_END
  Local Integer RES, COUNT
  Local Char APPLIW(50)
  Local Char APPLIF(50)
  Local Char FNAME(255)
  Local Char WHER(255)
  Local Char PARTS(50)(5)
  Local Integer N
  Local Integer X

  TOK_START = 1
  TOK_POS = 1
  Repeat
    TOK_POS = instr(TOK_POS, STACK, '<stack ')
    If TOK_POS = 0 : Break : Endif
    Raz FNAME
    Raz WHER
    Raz PARTS
    Raz APPLIW
    Raz APPLIF

    TOK_MARK = TOK_POS + 1

    TOK_POS = instr(TOK_POS, STACK, 'where=')
    If TOK_POS <> 0
      TOK_POS = instr(TOK_POS, STACK, '"') + 1
      TOK_END = instr(TOK_POS, STACK, '"')
      WHER = mid$(STACK, TOK_POS, TOK_END - TOK_POS)
      If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
        Call TRACE(".FIX_STACK: where=" + WHER)
      Endif
      TOK_POS = 1
      N = 0
      Repeat
        TOK_END = instr(TOK_POS, WHER, '.')
        If TOK_END = 0
          PARTS(N) = right$(WHER, TOK_POS)
          Break
        Endif
        PARTS(N) = mid$(WHER, TOK_POS, TOK_END - TOK_POS)
        N += 1
        TOK_POS = TOK_END + 1
      Until 0
      If PARTS(2) <> ""
        APPLIW = PARTS(0)
      Endif
    Endif

    TOK_POS = instr(TOK_MARK, STACK, 'filename=')
    If TOK_POS <> 0
      TOK_POS = instr(TOK_POS, STACK, '"')
      Append CLB, mid$(STACK, TOK_START, TOK_POS - TOK_START)
      TOK_START = TOK_POS + 1
      TOK_END = instr(TOK_START, STACK, '" ')
      FNAME = mid$(STACK, TOK_START, TOK_END - TOK_START)
      TOK_START = TOK_END + 2
      TOK_MARK = TOK_POS
      TOK_POS = 1
      Append CLB, '"'

      If instr(TOK_POS, FNAME, 'x3://') > 0
        Append CLB, 'x3://'
        TOK_POS += 5
      Endif
      TOK_END = instr(TOK_POS, FNAME, '/') + 1
      Append CLB, mid$(FNAME, TOK_POS, TOK_END - TOK_POS)
      TOK_POS = TOK_END

      TOK_END = instr(TOK_POS, FNAME, '/')
      APPLIF = mid$(FNAME, TOK_POS, TOK_END - TOK_POS)
      If APPLIW <> "" & APPLIW <> APPLIF
        Append CLB, APPLIW
      Else
        Append CLB, APPLIF
      Endif
      Append CLB, right$(FNAME, TOK_END)
      Append CLB, '" '
      TOK_POS = TOK_MARK
    Else
      TOK_POS = TOK_MARK
    Endif

    X += 1
  Until X > 100
  Append CLB, right$(STACK, TOK_START)
End 1

#-----------------------------------------------------------------------------------
#                                 B R E A K P O I N T S
#-----------------------------------------------------------------------------------

#**
#* Add a breakpoint
#*
#* @param ARGS
#* @param DATA
#*!
Subprog DBGP_SET_BREAKPOINT(ARGS, DATA)
  Value Char ARGS()(97..122)
  Value Clbfile DATA()
  Call =[LDB]FN_SET_BREAKPOINT With ARGS, DATA From =[LDB]DBG_DEBUG_NAME
End

#**
#* Add a breakpoint (full debugger version) $NBK<br/>
#*
#* breakpoint_set -i TRANSACTION_ID [arguments...] -- base64(expression)
#*
#* @param ARGS the command args
#* @param DATA the expression
#*!
Subprog NEW_DBGP_SET_BREAKPOINT(ARGS, DATA)
  Value Char ARGS()(97..122)
  Value Clbfile DATA()

  Local Char BRK_TYPE_STR(20)   : [L]BRK_TYPE_STR = ARGS(ascii('t'))
  Local Char BRK_STATE_STR(20)  : [L]BRK_STATE_STR = ARGS(ascii('s'))
  Local Char BRK_FULL_FILE(250) : [L]BRK_FULL_FILE = ARGS(ascii('f'))
  Local Integer BRK_LINE        : [L]BRK_LINE = func GET_NUM_VAL(ARGS(ascii('n')), 0)
  #Local Char BRK_FUNC(250)      : [L]BRK_FUNC = ARGS(ascii('m'))
  Local Char BRK_EXCEP(250)     : [L]BRK_EXCEP = ARGS(ascii('x'))
  #Local Integer BRK_HIT_VAL     : [L]BRK_HIT_VAL = func GET_NUM_VAL(ARGS(ascii('h')), 0)
  #Local Char BRK_HIT_COND(250)  : [L]BRK_HIT_COND = ARGS(ascii('o'))
  #Local Char BRK_TEMPORARY(250) : [L]BRK_TEMPORARY = ARGS(ascii('r'))
  Local Char BRK_EXPRESSION(250)
  Local Clbfile BRK_EXPRESSION_CLB(6)

  Local Integer ID,ERRNUM

  Local Char BRK_PROGRAM(32)
  [L]BRK_PROGRAM = func GET_PROGRAM([L]BRK_FULL_FILE)
#  If GUSER ="ERBOU" & len([L]BRK_FOLDER) > 0 & find([L]BRK_FOLDER, nomap) = 0
#    # This breakpoint could not be set in this environment
#    End
#  Endif

  Local Integer BRK_STATE : [L]BRK_STATE = 1
  If [L]BRK_STATE_STR <> "enabled"
    [L]BRK_STATE = 0
  Endif

  Local Integer BRK_TYPE : [L]BRK_TYPE = 1
  If [L]BRK_TYPE_STR = "watch"
    [L]BRK_TYPE = 2 # Type watch ...
  Elsif [L]BRK_TYPE_STR = "exception"
    [L]BRK_TYPE = 3 # Type error ...
  Endif

  Local Integer LENGTH
  # GASCII format for X3 engine
  [L]LENGTH = func CORE_B64DECODE(DATA, [L]BRK_EXPRESSION_CLB, [LDB]DBG_ASCII)
  [L]BRK_EXPRESSION = [L]BRK_EXPRESSION_CLB

  # Breakpoint on error
  If [L]BRK_TYPE = 3
    # Error name format : X3_002_MissingOpenParenthesisException
    If len([L]BRK_EXCEP) > 5
      [L]BRK_EXPRESSION = mid$([L]BRK_EXCEP, 4, 3)
    Endif
    [L]BRK_PROGRAM = ""
    [L]BRK_LINE = 0
#    [L]BRK_STATE = 1
  Endif

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = "Add breakpoint : type=" + num$([L]BRK_TYPE) + ", program=" + [L]BRK_PROGRAM
&    + ", line=" + num$([L]BRK_LINE) + ", state=" + num$([L]BRK_STATE) + ", data=" + [L]BRK_EXPRESSION
    Call TRACE([LDB]DBG_TRACE)
  Endif

  ERRNUM = 0
  Onerrgo ERR_BRK
    [L]ID = -1
    If [L]BRK_TYPE = 3
      [L]ID = dbgBreakpointAdd([L]BRK_TYPE, "", "", val([L]BRK_EXPRESSION), [L]BRK_STATE, 0, "")
    Else
      [L]ID = dbgBreakpointAdd([L]BRK_TYPE, [L]BRK_PROGRAM, [L]BRK_LINE, [L]BRK_EXPRESSION, [L]BRK_STATE, 0, "")
    Endif
  Onerrgo
  If ERRNUM > 0
    Call LOG_LINE("ERROR", "SET_BREAKPOINT: (" + num$(ERRNUM) + ") " + errmes$(ERRNUM))
    Call DBGP_ADD_NODE("error")
    Call DBGP_ADD_ATTRIBUTE("code", "200")
    Call DBGP_ADD_ATTRIBUTE("apperr", num$(ERRNUM))
    Call DBGP_ADD_NODE("message")
    [LDB]CLB_TEMP = errmes$(ERRNUM)
    Call DBGP_ADD_DATA([LDB]CLB_TEMP)
    Call DBGP_CLOSE_NODE()
    Call DBGP_CLOSE_NODE()
  Elsif [L]ID > -1
    Call DBGP_ADD_ATTRIBUTE("state", num$([L]BRK_STATE))
    Call DBGP_ADD_ATTRIBUTE("id", num$([L]ID))
  Endif


End

$ERR_BRK
  ERRNUM = errn
Resume

#**
#* Add a breakpoint (light debugger version)
#*
#* @param ARGS
#* @param DATA
#*!
Subprog OLD_DBGP_SET_BREAKPOINT(ARGS, DATA)
  Value Char ARGS()(97..122)
  Value Clbfile DATA()

  Local Char BRK_TYPE(20)       : [L]BRK_TYPE      = ARGS(ascii('t'))
  Local Char BRK_STATE(20)      : [L]BRK_STATE     = ARGS(ascii('s'))
  Local Char BRK_FILE(250)      : [L]BRK_FILE      = ARGS(ascii('f'))
  Local Char BRK_LINE(250)      : [L]BRK_LINE      = ARGS(ascii('n'))
  Local Char BRK_FUNC(250)      : [L]BRK_FUNC      = ARGS(ascii('m'))
  Local Char BRK_EXCEP(250)     : [L]BRK_EXCEP     = ARGS(ascii('x'))
  Local Char BRK_HIT_VAL(250)   : [L]BRK_HIT_VAL   = ARGS(ascii('h'))
  Local Char BRK_HIT_COND(250)  : [L]BRK_HIT_COND  = ARGS(ascii('o'))
  Local Char BRK_TEMPORARY(250) : [L]BRK_TEMPORARY = ARGS(ascii('r'))

  Local Char BRK_PROGRAM(32)
  [L]BRK_PROGRAM = func GET_PROGRAM([L]BRK_FILE)

  # si il y a encore de la place dans le tableau
  If [LDB]DBG_TRABNB >= [LDB]NB_BPT_MAX
    # On envoi un message avec titre boite;code(1=erreur, 2=info, 3=warning);texte
    #Call SEND_MESS3("04","Info",2,"Can't add breakpoint. There are already"
    #& - num$([LDB]DBG_TRABNB) -"breakpoints.")
  Else

    Local Integer INDEX
    [L]INDEX = func FIRST_FREE_BK_INDEX()
    If [L]INDEX <> -1
      [LDB]DBG_TRABNB += 1

      [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_ID) = num$([L]INDEX)
      [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_TYPE)= [L]BRK_TYPE
      [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_STATE) = [L]BRK_STATE
      #[LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_FILENAME) = [L]BRK_PROGRAM
      [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_FILENAME) = [L]BRK_FILE
      [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_LINENO) = [L]BRK_LINE
      [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_FUNCTION) = [L]BRK_FUNC
      [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_EXCEPTION) = [L]BRK_EXCEP
      [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_VALUE) = [L]BRK_HIT_VAL
      [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_CONDITION) = [L]BRK_HIT_COND
      [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_COUNT) = "0"
      Setlob [LDB]DBG_BK_DATA([L]INDEX) With DATA
    Endif

    Call DBGP_ADD_ATTRIBUTE("state", [L]BRK_STATE)
    Call DBGP_ADD_ATTRIBUTE("id", num$([L]INDEX))

  Endif
End


#**
#* Get a breakpoint
#*
#* @param ARGS
#*!
Subprog DBGP_GET_BREAKPOINT(ARGS)
  Value Char ARGS()(97..122)
  Call =[LDB]FN_GET_BREAKPOINT With ARGS From =[LDB]DBG_DEBUG_NAME
End

#**
#* Get a breakpoint (full debugger version)
#*
#* @param ARGS
#*!
Subprog NEW_DBGP_GET_BREAKPOINT(ARGS)
  Value Char ARGS()(97..122)

  Local Integer BRK_ID(20) : [L]BRK_ID = func GET_NUM_VAL(ARGS(ascii('d')), 0)
  Local Integer STAT

  STAT = dbgBreakpointGet([L]BRK_ID, [LDB]DBG_ARG)

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = "Get breakpoint : ID=" + num$([L]BRK_ID) + "  xml="
    Append [LDB]DBG_TRACE, [LDB]DBG_ARG
    Call TRACE([LDB]DBG_TRACE)
  Endif

  Call DBGP_ADD_XML([LDB]DBG_ARG)

End

#**
#* Get a breakpoint (light debugger version)
#*
#* @param ARGS
#*!
Subprog OLD_DBGP_GET_BREAKPOINT(ARGS)
  Value Char ARGS()(97..122)

  Local Char BRK_ID(20) : [L]BRK_ID = ARGS(ascii('d'))
  Local Integer INDEX : [L]INDEX = val([L]BRK_ID)

  Call OLD_GET_BREAKPOINT(INDEX)
End

Subprog OLD_GET_BREAKPOINT(INDEX)
  Value Integer INDEX

  Local Char BRK_ID(20)         : [L]BRK_ID        = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_ID)
  Local Char BRK_TYPE(20)       : [L]BRK_TYPE      = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_TYPE)
  Local Char BRK_STATE(10)      : [L]BRK_STATE     = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_STATE)
  Local Char BRK_FILE(250)      : [L]BRK_FILE      = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_FILENAME)
  Local Char BRK_LINE(250)      : [L]BRK_LINE      = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_LINENO)
  Local Char BRK_FUNC(250)      : [L]BRK_FUNC      = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_FUNCTION)
  Local Char BRK_EXCEP(250)     : [L]BRK_EXCEP     = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_EXCEPTION)
  Local Char BRK_HIT_VAL(250)   : [L]BRK_HIT_VAL   = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_VALUE)
  Local Char BRK_HIT_COND(250)  : [L]BRK_HIT_COND  = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_CONDITION)
  Local Char BRK_HIT_COUNT(250) : [L]BRK_HIT_COUNT = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_COUNT)
  Local Clbfile BRK_EXPR([LDB]DBG_BK_DATA_DIM)
  Setlob [L]BRK_EXPR With [LDB]DBG_BK_DATA([L]INDEX)

  Call DBGP_ADD_NODE("breakpoint")
  Call DBGP_ADD_ATTRIBUTE("id", [L]BRK_ID)
  Call DBGP_ADD_ATTRIBUTE("type", [L]BRK_TYPE)
  Call DBGP_ADD_ATTRIBUTE("state", [L]BRK_STATE)
  Call DBGP_ADD_ATTRIBUTE("filename", [L]BRK_FILE)
  Call DBGP_ADD_ATTRIBUTE("lineno", [L]BRK_LINE)
  If [L]BRK_FUNC <> ""
    Call DBGP_ADD_ATTRIBUTE("function", [L]BRK_FUNC)
  Endif
#  If [L]BRK_EXCEP <> ""
#    Call DBGP_ADD_ATTRIBUTE("exception", [L]BRK_EXCEP)
#  Endif
#  Call DBGP_ADD_ATTRIBUTE("hit_value", [L]BRK_HIT_VAL)
#  Call DBGP_ADD_ATTRIBUTE("hit_condition", [L]BRK_HIT_COND)
#  Call DBGP_ADD_ATTRIBUTE("hit_count", [L]BRK_HIT_COUNT)

  If [L]BRK_EXPR <> ""
    Call DBGP_ADD_NODE("expression")
    Call DBGP_ADD_DATA([L]BRK_EXPR)
  Endif
End


#**
#* Remove a breakpoint
#*
#* @param ARGS
#*!
Subprog DBGP_REM_BREAKPOINT(ARGS)
  Value Char ARGS()(97..122)
  Call =[LDB]FN_REM_BREAKPOINT With ARGS From =[LDB]DBG_DEBUG_NAME
End

#**
#* Remove a breakpoint (full debugger version)
#*
#* @param ARGS
#*!
Subprog NEW_DBGP_REM_BREAKPOINT(ARGS)
  Value Char ARGS()(97..122)

  Local Integer BRK_ID(20) : [L]BRK_ID = func GET_NUM_VAL(ARGS(ascii('d')), 0)
  Local Integer ERROR

  If [L]BRK_ID > -1
    [L]ERROR = dbgBreakpointRemove([L]BRK_ID)
    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
      [LDB]DBG_TRACE = "Remove breakpoint [ID="+num$([L]BRK_ID)+"]" : Call TRACE([LDB]DBG_TRACE)
    Endif
  Endif
  #[L]DBG_OPT = [LDB]DBG_STABOU2 # ???
End

#**
#* Remove a breakpoint (light debugger version)
#*
#* @param ARGS
#*!
Subprog OLD_DBGP_REM_BREAKPOINT(ARGS)
  Value Char ARGS()(97..122)

  Local Char BRK_ID(20) : BRK_ID = ARGS(ascii('d'))
  Local Integer INDEX   : [L]INDEX = val([L]BRK_ID)

  If [L]INDEX > -1
    If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
      [LDB]DBG_TRACE = "Remove breakpoint ["-num$([L]INDEX)-"]" : Call TRACE([LDB]DBG_TRACE)
    Endif

    # Remove breakpoint from breakpoints table
    Call DEL_BREAKPOINT(INDEX)
    [LDB]DBG_TRABNB -= 1
  Endif

  #[L]DBG_OPT = [LDB]DBG_STABOU2 # ???

End

#**
#* Update a breakpoint
#*
#* @param ARGS
#*!
Subprog DBGP_UPD_BREAKPOINT(ARGS)
  Value Char ARGS()(97..122)
  Call =[LDB]FN_UPD_BREAKPOINT With ARGS From =[LDB]DBG_DEBUG_NAME
End

#**
#* Update a breakpoint (full debugger version)
#*
#* @param ARGS
#*!
Subprog NEW_DBGP_UPD_BREAKPOINT(ARGS)
  Value Char ARGS()(97..122)

  Local Integer BRK_ID(20) : [L]BRK_ID = func GET_NUM_VAL(ARGS(ascii('d')), 0)
  Local Integer BRK_NUM_LIG : [L]BRK_NUM_LIG = func GET_NUM_VAL(ARGS(ascii('n')), 0)
  Local Char BRK_STATE_STR(250) : [L]BRK_STATE_STR = ARGS(ascii('s')) # Breakpoint state
  Local Char BRK_HIT_CONDITION(250) : [L]BRK_HIT_CONDITION = ARGS(ascii('o')) # Hit condition : %
# multiple, == equal, >= greater than or equal
  Local Char BRK_HIT_VALUE_STR(250) : [L]BRK_HIT_VALUE_STR = ARGS(ascii('h')) # Hit value

  Local Integer ERROR
  Local Integer PROPERTY_ID : [L]PROPERTY_ID = -1

  If [L]BRK_STATE_STR <> ""
    Local Integer BRK_STATE : [L]BRK_STATE = 1
    If [L]BRK_STATE_STR <> "enabled"
      [L]BRK_STATE = 0
    Endif
    [L]PROPERTY_ID = 1
    [L]ERROR = dbgBreakpointUpdate([L]BRK_ID, [L]PROPERTY_ID, [L]BRK_STATE)
  Endif

  If [L]BRK_HIT_VALUE_STR <> ""
    Local Integer BRK_HIT_VALUE : [L]BRK_HIT_VALUE = func GET_NUM_VAL([L]BRK_HIT_VALUE_STR, 0)
    [L]PROPERTY_ID = 2
    [L]ERROR = dbgBreakpointUpdate([L]BRK_ID, [L]PROPERTY_ID, [L]BRK_HIT_VALUE)
  Endif

  If [L]BRK_HIT_CONDITION <> ""
    [L]PROPERTY_ID = 3
    [L]ERROR = dbgBreakpointUpdate([L]BRK_ID, [L]PROPERTY_ID, [L]BRK_HIT_CONDITION)
  Endif

#  # Not used yet
#  If [L]BRK_NUM_LIG <> 0
#    [L]PROPERTY_ID = 4
#    [L]ERROR = dbgBreakpointUpdate([L]BRK_ID, [L]PROPERTY_ID, val([L]BRK_NUM_LIG))
#  Endif

  # Breakpoint Update
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = "Update breakpoint [ID="+num$([L]BRK_ID)+"]" + "  property changed=" + num$([L]PROPERTY_ID)
    Call TRACE([LDB]DBG_TRACE)
  Endif

End


#**
#* Update a breakpoint (light debugger version)
#*
#* @param ARGS
#*!
Subprog OLD_DBGP_UPD_BREAKPOINT(ARGS)
  Value Char ARGS()(97..122)

  Local Char BRK_ID(20) : BRK_ID = ARGS(ascii('d'))
  Local Integer BK_NUM_LIG : [L]BK_NUM_LIG = val(ARGS(ascii('n'))) # The line number of the
# breakpoint
  Local Char BK_STATE(250) : [L]BK_STATE = ARGS(ascii('s')) # Breakpoint state
  Local Char BK_HIT_CONDITION(250) : [L]BK_HIT_CONDITION = ARGS(ascii('o')) # Hit condition : %
# multiple, == equal, >= greater than or equal
  Local Char BK_HIT_VALUE(250) : [L]BK_HIT_VALUE = ARGS(ascii('h')) # Hit value

  # Update the BP with the given ID
  Local Integer INDEX : [L]INDEX = val([L]BRK_ID)

  If [L]BK_NUM_LIG <> 0
    [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_LINENO) = num$([L]BK_NUM_LIG)
  Endif
  If [L]BK_STATE <> ""
    [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_STATE) = [L]BK_STATE
  Endif
  If [L]BK_HIT_CONDITION <> ""
    [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_CONDITION) = [L]BK_HIT_CONDITION
  Endif
  If [L]BK_HIT_VALUE <> ""
    [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_VALUE) = [L]BK_HIT_VALUE
  Endif

  # Break point Update
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = "Upd breakpoint ["-num$(INDEX)-"]" : Call TRACE([LDB]DBG_TRACE)
  Endif
End



#**
#* Get breakpoints list (full debugger version)
#*
#* @param ARGS
#*!
Subprog DBGP_LIST_BREAKPOINT()
  Call =[LDB]FN_LIST_BREAKPOINT With From =[LDB]DBG_DEBUG_NAME
End

Subprog NEW_DBGP_LIST_BREAKPOINT()
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = "Breakpoint List :" + [L]BREAKPOINTS : Call TRACE([LDB]DBG_TRACE)
  Endif

  Local Integer STAT
  STAT = dbgBreakpointList([LDB]DBG_ARG)
  Call DBGP_ADD_XML([LDB]DBG_ARG)

End

Subprog OLD_DBGP_LIST_BREAKPOINT()
  Local Integer BRK_ID

  For [L]BRK_ID = 0 To [LDBK]NB_BPT_MAX-1
    Call OLD_GET_BREAKPOINT([L]BRK_ID)
  Next BRK_ID

End

#**
#* Get index of the first empty entry in breakpoints table (light debugger version)
#*!
Funprog FIRST_FREE_BK_INDEX()
  Local Integer IDX : [L]IDX = -1
  Local Integer I
  For [L]I = 0 To [LDB]NB_BPT_MAX-1
    If [LDB]DBG_BK_DEF([L]I, [LDB]DBG_BK_ID) = ""
      [L]IDX = [L]I
      Break
    Endif
  Next [L]I
End [L]IDX

#**
#* Get breakpoint in X3 engine format (light debugger version)
#*
#* @param INDEX index of the breakpoint in breakpoints table
#*!
Funprog OLD_GET_X3_BREAKPOINT(INDEX)
  Value Integer INDEX
  Local Char BK_BREAK(250) : [L]BK_BREAK = ""

  Local Char BK_ID(250)
  Local Char BK_TYPE(250)
  Local Char BK_STATE(250)
  Local Char BK_FILENAME(250)
  Local Integer BK_LINENO
  Local Char BK_FUNCTION(250)
  Local Char BK_EXCEPTION(250)
  Local Char BK_HIT_VALUE(250)
  Local Char BK_HIT_CONDITION(250)
  Local Char BK_HIT_COUNT(250)
  Local Clbfile BK_EXPRESSION([LDB]DBG_BK_DATA_DIM)

  [L]BK_ID = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_ID)
  [L]BK_TYPE = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_TYPE)
  [L]BK_STATE = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_STATE)
  [L]BK_FILENAME = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_FILENAME)
  [L]BK_LINENO = val([LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_LINENO))
  [L]BK_LINENO -= [LDB]DEBUG_LINE_OFFSET
  [L]BK_FUNCTION = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_FUNCTION)
  [L]BK_EXCEPTION = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_EXCEPTION)
  [L]BK_HIT_VALUE = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_VALUE)
  [L]BK_HIT_CONDITION = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_CONDITION)
  [L]BK_HIT_COUNT = [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_COUNT)
  Setlob [L]BK_EXPRESSION With [LDB]DBG_BK_DATA([L]INDEX)

  Local Char BK_SRC_FILE(250)

  # Base 64
  Local Char IN(250)(1)
  Local Char OUT(250)(1)
  Local Char EXPR(250)

  Local Integer DBG_I
  Local Integer DBG_J
  Local Integer DBG_K

#  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
#     [LDB]DBG_TRACE = "----> breakpoint("-num$(INDEX)-")=[type="+[L]BK_TYPE+",
# line="+num$([L]BK_LINENO)+", expression="+[L]BK_EXPRESSION+"]"
#      Call TRACE([LDB]DBG_TRACE)
#  Endif


  # Si numéro de ligne positif => c'est un break point "sur numéro de ligne", type dbgp = line
  If [L]BK_TYPE = "line" or [L]BK_TYPE = "conditional" and [L]BK_LINENO > 0

     If [L]BK_TYPE = "conditional"
       # expression is encoded in base64
       Setlob IN With [L]BK_EXPRESSION
       Call WBASE64_DECODE(IN, OUT)
       EXPR = OUT(0)
       [L]BK_BREAK = chr$(4)+EXPR
     Endif

     # Create the canonical name 'server@folder.TRT/process$adx:lineNum'
     Local Integer I : [L]I = 0
     Local Integer J : [L]J = 0
     Local Integer K : [L]K = 0
     Repeat [L]I = instr([L]I+1, [L]BK_FILENAME, "/")
       If [L]I > 0
         [L]J = [L]I
       Endif
     Until [L]I = 0
     [L]K = instr(1, [L]BK_FILENAME, ".")
     If [L]K = 0
        [L]BK_LINENO = 0
     Else
        [L]BK_SRC_FILE = seg$([L]BK_FILENAME, [L]J+1, [L]K-1)
     Endif
     Call ISSOURCEEXIST([L]BK_SRC_FILE, [L]K)
     # 20110620 : Can use breakpoint even if source is not present
#     If [L]K = 0
#        [L]BK_LINENO = 0
#     Else
        [L]BK_BREAK += "@" + nomap + ".TRT/" + [L]BK_SRC_FILE + "$adx"
#     Endif

     # ajout du BKP si on a pas mis le numéro de ligne à zéro (erreur)
     If [L]BK_LINENO > 0
       [L]BK_BREAK += ":"
       [L]BK_BREAK += num$([L]BK_LINENO)
     Endif

  # si numéro de ligne = -1  => c'est un break point "expression vérifiée", type dbgp = conditional
  Elsif [L]BK_TYPE = "conditional"
     Setlob IN With [L]BK_EXPRESSION
     Call WBASE64_DECODE(IN, OUT)
     EXPR = OUT(0)
     [L]BK_BREAK = chr$(1)+EXPR

#  # si numéro de ligne = -2  => c'est un break point "modif de variable ", type dbgp = watch
#  Elsif [L]BK_TYPE = "watch"
#     # TODO manage watch break
#     [L]BK_BREAK = chr$(2)+[L]BK_BREAK
#
#  # si numéro de ligne = -3  => c'est un break point "instruction ", type dbgp = ???
#  Elsif [L]BK_LINENO = -3
#     # TODO manage instruction break
#     [L]BK_BREAK = chr$(3)+chr$(val([L]BK_BREAK))

  Endif

End BK_BREAK

#**
#* Remove a breakpoint from breakpoints table  (light debugger version)
#* @param INDEX index of the breakpoint to be removed
#*!
Subprog DEL_BREAKPOINT(INDEX)
  Value Integer INDEX

  [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_ID) = ""
  [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_TYPE) = ""
  [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_STATE) = ""
  [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_FILENAME) = ""
  [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_LINENO) = ""
  [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_FUNCTION) = ""
  [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_EXCEPTION) = ""
  [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_VALUE) = ""
  [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_CONDITION) = ""
  [LDB]DBG_BK_DEF([L]INDEX, [LDB]DBG_BK_HIT_COUNT) = ""
  Setlob [LDB]DBG_BK_DATA([L]INDEX) With ""
End


#**
#* The names of currently available contexts at a given stack depth,
#* typically Local, Global and Class.
#* These SHOULD be UI friendly names.
#* The numerical id attribute returned with the names is used
#* in other commands such as context_get to identify the context.
#* The context id zero is always considered to be the 'default' context
#* is no context id is provided.
#* In most languages, this will the be 'local' context.
#* <br><br>
#* Only display local variables.
#* Global variables can be displayed in <b>Expression view</b>.
#* Masks and Tables can be displayed in <b>Masks view</b> and <b>Tables view</b>.
#*
#* @private
#*
#* @param ARGS
#*!
Subprog DBGP_CTX_NAME(ARGS)
  Value Char ARGS()(97..122)

  Local Integer DEPTH : [L]DEPTH = func GET_NUM_VAL(ARGS(ascii('d')), [LDB]TOP_LEVEL)
#  [LDB]CURRENT_STACK = [L]DEPTH

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE (".DBGP_CTX_NAME")
  Endif

  Call DBGP_ADD_NODE("context")
  Call DBGP_ADD_ATTRIBUTE("name", "Local")
  Call DBGP_ADD_ATTRIBUTE("id", num$([LDB]DBG_CTX_LOCAL))
  Call DBGP_CLOSE_NODE()

#  Call DBGP_ADD_NODE("context")
#  Call DBGP_ADD_ATTRIBUTE("name", "[G] Global")
#  Call DBGP_ADD_ATTRIBUTE("id", num$([LDB]DBG_CTX_GLOBAL))
#  Call DBGP_CLOSE_NODE()
#
#  Call DBGP_ADD_NODE("context")
#  Call DBGP_ADD_ATTRIBUTE("name", "[F] Files")
#  Call DBGP_ADD_ATTRIBUTE("id", num$([LDB]DBG_CTX_FILES))
#  Call DBGP_CLOSE_NODE()
#
#  Call DBGP_ADD_NODE("context")
#  Call DBGP_ADD_ATTRIBUTE("name", "[M] Masks")
#  Call DBGP_ADD_ATTRIBUTE("id", num$([LDB]DBG_CTX_MASKS))
#  Call DBGP_CLOSE_NODE()
#
#  Call DBGP_ADD_NODE("context")
#  Call DBGP_ADD_ATTRIBUTE("name", "[S] System")
#  Call DBGP_ADD_ATTRIBUTE("id", num$([LDB]DBG_CTX_SYSTEM))
#  Call DBGP_CLOSE_NODE()

End

#**
#* Returns an array of properties in a given context at a given stack depth.
#* If the stack depth is omitted, the current stack depth is used.
#* If the context name is omitted, the context with an id zero is used
#* (generally the 'locals' context).
#*
#* @param ARGS
#*!
Subprog DBGP_CTX_GET(ARGS)
  Value Char ARGS()(97..122)
  Call =[LDB]FN_CTX_GET With ARGS From =[LDB]DBG_DEBUG_NAME
End


Subprog NEW_DBGP_CTX_GET(ARGS)
  Value Char ARGS()(97..122)

  Local Integer CTX_ID : [L]CTX_ID = func GET_NUM_VAL(ARGS(ascii('c')), 0)
  Local Integer DEPTH : [L]DEPTH = func GET_NUM_VAL(ARGS(ascii('d')), [LDB]TOP_LEVEL)
  [LDB]CURRENT_STACK = [L]DEPTH

  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    Call TRACE (".DBGP_CTX_GET ID=" + num$([L]CTX_ID) + "  depth=" + num$([L]DEPTH))
  Endif

  Call DBGP_ADD_ATTRIBUTE("context", num$([L]CTX_ID))

  Onerrgo CTX_GET_ERR
  Local Integer RET

  If [L]CTX_ID = [LDB]DBG_CTX_LOCAL
    Local Integer LG
    Local Integer N : [L]N = claCtxNbs([L]DEPTH)
    Local Integer I
    Local Char VARNAME(64)

    For [L]I=1 To [L]N
      [L]VARNAME = claCtxVar([L]DEPTH, [L]I)
      RET = func ADD_PROPERTY([L]VARNAME, "local", [L]DEPTH, -1, 0)
    Next [L]I
#  Elsif CTX_ID = [LDB]DBG_CTX_GLOBAL

  Endif

  Onerrgo

End

$CTX_GET_ERR
  If dim([LDB]DBG_TRACON) > 0 & [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".CTX_GET_ERR: Ensure your engine supports stack context function." + chr$(10)
    Append [LDB]DBG_TRACE, "["-errmes$(errn)-errp+"("+num$(errl)+") errm='"+errm+"']"
    Call TRACE([LDB]DBG_TRACE)
  Endif
Resume

