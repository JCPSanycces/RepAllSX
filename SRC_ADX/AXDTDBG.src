#        AVAILABLE = 0
#        If NBVAR > 0
#          AVAILABLE = evalue("dim(" + CLNAME + vireblc(format$("KT:30X",clavar(I, 1)), 4) + ")")
#        Endif
#        If AVAILABLE > 0
#          If CLNAME = "[L]" | CLNAME = "[C]"
#            For J = 1 To NBVAR
#              [L]VARNAME = clavar(I, J)
