  Endif

  Call DBGP_ADD_ATTRIBUTE("context", num$([L]CTX_ID))

# TODO : how to find local variables
  Local Integer RET
  If [L]CTX_ID = [LDB]DBG_CTX_LOCAL
    Local Char VARNAME(250), CLASS_NAME(250)

