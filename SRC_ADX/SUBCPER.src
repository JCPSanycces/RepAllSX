#<AdxTL>@(#)81.0.0.0 $Revision$
################################################################
# Etiquettes masque CREPER : Création des périodes
################################################################
Subprog AS_CREAT(VALEUR) 
Variable Integer VALEUR  
If [M:DIA]FIYSTA(nolign-1)=1
 VALEUR = 1 : mkstat=2 : End    
Elsif [M:DIA]FIYSTA(nolign-1)>2 : # Fermé
 mkstat=2 : End    
Endif  
If nolign>1   
 If [M:DIA]CREAT(nolign-2)<>2  
  VALEUR = 1 : mkstat=2 : End  
 Endif  
Endif 
End 
 
Subprog C_CREAT(VALEUR) 
Variable Integer VALEUR   
Local Integer IJ  
If VALEUR<>2  
 For IJ=nolign To [M:DIA]NBLIG-1  
  [M:DIA]CREAT(IJ) = 1  
 Next IJ  
Endif 
End 

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
# A ne saisir qu'en Batch !
If [M]BATCH<>1
 mkstat=2 : End
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer  EXE_SUIV
Local Integer  I_J 
If VALEUR<>[M:DIA]CPY
 [M:DIA]CPY = VALEUR
 Gosub CHARGE From CLOPER
 If !I_J
  # Toutes les périodes sont fermées
  GMESSAGE = VALEUR-mess(62,100,1)-"("-format$("D:"+GFMDAT,datesyst)-")" 
  [M:DIA]CPY = ""
  mkstat=1 : End
 Endif
 [M:DIA]NBLIG = I_J
 Affzo [DIA]
Endif
End

Subprog B2_NBLED
Local Integer I
For I=1 To [M]NBLED
 [M]LEDFLG(I-1) = 2
Next I
Affzo LEDFLG
End

Subprog B3_NBLED
Local Integer I
For I=1 To [M]NBLED
 [M]LEDFLG(I-1) = 1
Next I
Affzo LEDFLG
End

