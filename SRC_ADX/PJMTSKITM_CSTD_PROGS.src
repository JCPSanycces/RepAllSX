#######################################################################################
Funprog GET_ALLQTY_VALUE(ACTX, PROJECT, TASK, SITMREF, NALLQTY, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char PROJECT
Value Char TASK
Value Char SITMREF
Variable Decimal NALLQTY
Variable Char SMESSAGE

Local Integer IARENDRE
Local Integer IRET
Local Char SOPPNUM(GLONOPP)
Local Char STASCOD(GLONTAC)
Local Char SPBUCOD(GLONPBU)

  # Issue X3-31898 - 2017-11-23 by FGR
  IARENDRE = [V]CST_AOK
  Raz SMESSAGE
  # ----------------------
  Local File PJMTSKITM [JTT]
  # ----------------------
  If TASK = AVOID.ACHAR Then
    IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(ACTX, PROJECT, SOPPNUM, SPBUCOD, STASCOD)
  Else
    SOPPNUM = PROJECT
    STASCOD = TASK
  Endif
  # ----------------------
  NALLQTY = 0
  Filter [JTT] Where [F:JTT]OPPNUM = SOPPNUM and [F:JTT]TASCOD = STASCOD and [F:JTT]ITMREF = SITMREF
  For [JTT]
    NALLQTY = [JTT]ALLQTY
  Next
  Filter [JTT]
End IARENDRE

#######################################################################################
Funprog GET_KEYCONCAT(CTX, SOPPNUM, STASCOD, IITTSEQ)
Variable Instance CTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SOPPNUM
Value Char STASCOD
Value Integer IITTSEQ

Local Char SARENDRE(GLONVPJ)

  # Issue X3-68131 - 2018-02-12 by FGR
  SARENDRE = SOPPNUM + "~" + STASCOD + "~" + num$(IITTSEQ)
End SARENDRE

#######################################################################################
Funprog GET_ITMDES1(CTX, SOPPNUM, STASCOD, IITTSEQ)
Variable Instance CTX Using OBJECT
Value Char SOPPNUM
Value Char STASCOD
Value Integer IITTSEQ

Local Char SARENDRE(GLONDCO)
Local Char SKEYCONCAT(GLONVPJ)

  # Issue X3-68131 - 2018-02-12 by FGR
  Raz SARENDRE
  SKEYCONCAT = func GET_KEYCONCAT(CTX.ACTX, SOPPNUM, STASCOD, IITTSEQ)
  Call LECTEXTRA_SYR(CTX, AVOID.ACHAR, SARENDRE, "PJMTSKITM", "ITMDES1", SKEYCONCAT, AVOID.ACHAR) From ATEXTRA
End SARENDRE

