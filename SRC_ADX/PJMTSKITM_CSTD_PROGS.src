  # Issue X3-6422/120397 - 2017-03-15 by SINGC
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "PJMTSKITM", "ITTCOMTEX", SIDENT2, AVOID.ACHAR, AVOID.ACHAR)
