Funprog ITTDESTEX_EXIST(ACTX, SIDENT2)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-03-15 by SINGC
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "PJMTSKITM", "ITTDESTEX", SIDENT2, AVOID.ACHAR, AVOID.ACHAR)
End IARENDRE

#######################################################################################
