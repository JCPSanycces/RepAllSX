#<AdxTL>@(#)2.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("AEN",GBIDC2,GBIDC3) From GOBJET
End

####################################################################
$ACTION
Case ACTION
 When "LIENS"       : Gosub LIENS
 When "CREATION"    : Gosub MAJTEX
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "MODIF"       : Gosub MAJTEX
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "SETBOUT"     : Gosub SETBOUT
 When "GAUCHE"      : Gosub GAUCHE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Gosub CHANGE
Endcase
Return

$LIENS
Call LECTEXTRA([M]DES,"AENCHAINE","DES",[M]CODE,"") From ATEXTRA
Return

$MAJTEX
Call MAJTEXTRA([M]DES,"AENCHAINE","DES",[M]CODE,"") From ATEXTRA
Return

$VERIF_MOD
Local Integer TYPCUR
For I=0 To [M]NBLIG-1
 Read [AOE]AOE0=[M]MODELE(I)
 If !fstat
  If TYPCUR=0
   TYPCUR = [F:AOE]TYPFIL
  Elsif TYPCUR=7 & [F:AOE]TYPFIL<>TYPCUR
   OK = 0 : Break
  Elsif TYPCUR<>7 & [F:AOE]TYPFIL=7
   OK = 0 : Break
  Endif
 Endif
Next I
If !OK
 # Les modèles de type # ne peuvent pas être utilisés avec des modèles d'un autre type
 GMESSAGE = func AFNC.MES(mess(168,141,1),'"'+mess(7,94,1)+'"')
 mkstat = 2 : Return
Endif
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
K = 0
If [M]MODELE<>""
 Read [AOE]AOE0=[M]MODELE
 If !fstat & [F:AOE]TYPFIL=7
  K = 1
 Endif
Endif
If K & REP<>"M" & VERROU
 CHMEN += "3"
Endif
Return

$OUVRE_BOITE
Local Integer BROWAOE
Local Char    BOXAOE(10)
BROWAOE = find("AOE",OBJLIS(1..8)) : BOXAOE = "GAU_CHE"+num$(BROWAOE)
Return

$FILGAUCHE
Raz FILGAUSUP
FILGAUSUP = "[F:AOE]ENAFLG=2"
Return

$GAUCHE
Case currbox
 When BOXAOE
  If [F:AOE]EXT<>"" & !find([F:AOE]EXT,[M]MODELE(0..[M]NBLIG-1)) & [M]NBLIG<dim([M]MODELE)
   OK = 0
   Case REP
    When "C","M","D"
     OK = 1
    When ""
     If CLECUR & VERROU & ACTMOD & !GCONSULT
      OK = 1
     Endif
   Endcase
   If OK
    Read [AOE]AOE0 =
    [M]MODELE([M]NBLIG) = [F:AOE]EXT
    [M]CHEMIN([M]NBLIG) = [F:AOE]FILEXT
    [M]NBLIG += 1
    Affzo 10
    If REP=""
     Gosub ENTRE_MODIF From GOBJSUB
    Endif
   Endif
  Endif
Endcase
Return

$ANNULE
Delete [AXX] Where CODFIC="AENCHAINE"  & IDENT1=[L]CODE  & ZONE ="DES"
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[M]COD) From GLOCK
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="AENCHAINE" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA AENCHAINE"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

####################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File AENCHAINE [AEN1]
 Local File AOBJEXT   [AOE1]
 Local File AOBJEXTD  [AOD1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[M]DOSORG+".AENCHAINE" [AEN1]
 Local File =[M]DOSORG+".AOBJEXT"   [AOE1]
 Local File =[M]DOSORG+".AOBJEXTD"  [AOD1]
 Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
Endif
If [M]DOSDES=nomap
 Local File AENCHAINE [AEN2]
 Local File AOBJEXT   [AOE2]
 Local File AOBJEXTD  [AOD2]
 Local File ATEXTRA   [AXX2]
Else
 Local File =[M]DOSDES+".AENCHAINE" [AEN2]
 Local File =[M]DOSDES+".AOBJEXT"   [AOE2]
 Local File =[M]DOSDES+".AOBJEXTD"  [AOD2]
 Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
OK = 1
If GTRACE=""
 Read [AEN2]CODE = TABLE
 If !fstat
  Call AVERTIR(mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [AEN1], [AOE1], [AOD1], [AEN2], [AOE2], [AOD2], [AXX1] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [AEN2] , [AOE2] , [AOD2]
 For [AEN2] Where CODE=TABLE
  Delete [AOE2] Where EXT=[F:AEN2]MODELE
  If fstat=1
   GOK=-1 : GLOCK = "$"+[M]DOSDES+".AOBJEXT" : Break
  Elsif fstat>5
   GOK = 0 : Call RSTA("AOE2","") From GLOCK : Break
  Endif
  Delete [AOD2] Where EXT=[F:AEN2]MODELE
  If fstat=1
   GOK=-1 : GLOCK = "$"+[M]DOSDES+".AOBJEXTD" : Break
  Elsif fstat>5
   GOK = 0 : Call RSTA("AOD2","") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Delete [AEN2] Where CODE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AENCHAINE" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AEN2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AEN1]CODE Where CODE=TABLE
  [F:AEN2] = [F:AEN1]
  Call COPTEXTRA("AENCHAINE","DES",[F:AEN2]CODE,"") From ATEXTRA
  If dim([F:AEN2]UPDUSR)>0 : [F:AEN2]UPDUSR = GUSER : Endif
  If dim([F:AEN2]UPDDAT)>0 : [F:AEN2]UPDDAT = date$ : Endif
  Write [AEN2]
  If fstat
   GOK=0 : Call FSTA("AEN2") From GLOCK : Break
  Endif
  Look [AOE2]AOE0 = [F:AEN1]MODELE
  If fstat
   For [AOE1]AOE0 Where EXT=[F:AEN1]MODELE
    [F:AOE2] = [F:AOE1]
    Write [AOE2]
    If fstat
     GOK=0 : Call FSTA("AOE2") From GLOCK : Break 2
    Endif
    For [AOD1]AOD0 Where EXT=[F:AEN1]MODELE
     [F:AOD2] = [F:AOD1]
     Write [AOD2]
     If fstat
      GOK=0 : Call FSTA("AOD2") From GLOCK : Break 3
     Endif
    Next
   Next
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

###########################################################################
# Etiquettes du masque AEN1
###########################################################################
Subprog C_MODELE(VALEUR)
Variable Char VALEUR()
Local Integer I , OK , TYPCUR
Read [AOE]AOE0=VALEUR
TYPCUR = [F:AOE]TYPFIL
OK = 1
For I=0 To [M]NBLIG-1
 If I<>nolign-1
  Read [AOE]AOE0=[M]MODELE(I)
  If !fstat
   If TYPCUR=7 & [F:AOE]TYPFIL<>TYPCUR
    OK = 0 : Break
   Elsif TYPCUR<>7 & [F:AOE]TYPFIL=7
    OK = 0 : Break
   Endif
  Endif
 Endif
Next I
If !OK
 # Les modèles de type # ne peuvent pas être utilisés avec des modèles d'un autre type
 GMESSAGE = func AFNC.MES(mess(168,141,1),'"'+mess(7,94,1)+'"')
 mkstat = 2 : End
Endif
End

Subprog AS_CHEMIN(VALEUR)
Variable Char VALEUR()
#112713
#If VALEUR="" : End : Endif
If VALEUR<>"" : End : Endif
Call LECTURE("AOE",[M:AEN1]MODELE(nolign-1),"") From CONTOBJ
If len([F:AOE]FILEXT)>0
 #set the model's path
 VALEUR = [F:AOE]FILEXT
Else
 #set the default path
 Call GETREP("REPEXPDEF",VALEUR) From SUBEXPOBJ
Endif
End

Subprog SET_NOMFIC(FICHIER,NOMEXP)
Value Char FICHIER
Variable Char NOMEXP
Local Integer ER
Local Char    REPERT(GDIMFIC) , MACHINE(GDIMFIC)
NOMEXP = FICHIER
If !instr(1,NOMEXP,"@") & !find(left$(NOMEXP,1),"/") & !pat(left$(NOMEXP,3),"!:\")
 Call GETREP("REPEXPDEF",REPERT) From SUBEXPOBJ
 If REPERT<>""
  Call MACHINE(REPERT,MACHINE,REPERT) From ORDSYS
  Call SETFIC(REPERT,FICHIER,MACHINE,NOMEXP) From SUBEXPOBJ
 Endif
Endif
End


