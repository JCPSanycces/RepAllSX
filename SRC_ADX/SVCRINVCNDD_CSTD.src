#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SVCRINVCNDD
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AINIT"                    : Gosub INIT                   From SVCRINVCNDD_EVENTS
        When "ACONTROL"                 : Gosub ACONTROL               From SVCRINVCNDD_EVENTS
        When "ADELETE_CONTROL_BEFORE"   : Gosub ADELETE_CONTROL_BEFORE From SVCRINVCNDD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"   : Gosub AUPDATE_CONTROL_BEFORE From SVCRINVCNDD_EVENTS
      Endcase
  Endcase

Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#---------------------------------------------------------------
$PROPERTIES
  Case [L]ARULE
    When "INIT"      :
      Case CURPRO
        When "INVCNDSTA"                : Gosub INIT_INVCNDSTA         From SVCRINVCNDD_PROPERTIES
        When "VCRTYP"                   : Gosub INIT_VCRTYP            From SVCRINVCNDD_PROPERTIES
        When "MODFLG"                   : Gosub INIT_MODFLG            From SVCRINVCNDD_PROPERTIES
      Endcase
    When "CONTROL"   :
      Case CURPRO
        When "VCRTYP"                   : Gosub CONTROL_VCRTYP         From SVCRINVCNDD_PROPERTIES
      Endcase
    When "PROPAGATE" :
      Case CURPRO
      Endcase
  Endcase
Return
#---------------------------------------------------------------

