#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TVTLEGPOR 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:58"
A_USER  = "DOC"
A_STAMP = "20181109230658"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask TVTLEGPOR [TVTPOR]
Gosub HORODAT
Local Inpbox "TVTLEGPOR" From GFONCTION At A_STAMP With A_WINDPREV Mask [TVTPOR] As [SIM_]
Grizo [TVTPOR]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [TVTPOR]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=30 : X2(0)=82 : Y1(0)=12 : Y2(0)=16
Return

$ON_EXEMOT
Onevent CONTROL Call C_EXEMOT(zc) From W1TVTLEGPOR
Onevent AFTER_CHANGE Gosub AMM_EXEMOT From W1TVTLEGPOR
Onevent BEFORE_INPUT Call AS_EXEMOT(zc) From W1TVTLEGPOR
Return

Subprog AS_EXEMOT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_EXEMOT(zc) From W1TVTLEGPOR
Gosub _AFF
End

Subprog C_EXEMOT(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "EXEMOT" : GZNUM = 26903 : Endif
If !mkstat
 ## Action STD
 Call C_EXEMOT(VALEUR) From TRTTVTLEGPOR
 If mkstat : GERR = 1 : GZONE = "EXEMOT" : GZNUM = 26903 : Endif
Endif
Gosub _AFF
End

$AMM_EXEMOT
Call AM_EXEMOT(zc)
If !mkstat & GOBJET
 zoncou = "EXEMOT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_EXEMOT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_EXEMOT(VALEUR) From TRTTVTLEGPOR
If mkstat : GERR = 1 : GZONE = "EXEMOT" : GZNUM = 26903 : Endif
Gosub _AFF
End

Subprog S_EXEMOT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCONSYR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCONSYR"
 PARMSK(1) = "VATEXEREA"
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","TRTCONVSYR","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$CHG_STY
Return


