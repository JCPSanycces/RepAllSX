#--- TS 106217
# Première boucle : [M:ALP]ECCVALMAJ=""
For J=0 To dim([F:TRU]STAFLT)-1

   # Plus de lignes de règles
   If [F:TRU]STAFLT(J)=0 Break Endif

   Gosub FIL_LOOP_1_3

   WFME2="[M]WINCLOT(I)"+"+'"+chr$(65+J)+chr$(49)+"'+"
   WFML2="[M]WINCLOT(I)"+"+'"+chr$(65+J)+chr$(50)+"'+"

   Gosub FIL_TRI

   # Ecriture du source
   If J=0
      Wrseq "  If [M]ECCVALMAJ=''"
      Wrseq "    [M]WCOND(I)="+WFME
      Wrseq "&               "+WFME2
      Wrseq "&               +"+WFML
      Wrseq "&               "+WFML2
   Else
      Wrseq "&               +"+WFME
      Wrseq "&               "+WFME2
      Wrseq "&               +"+WFML
      Wrseq "&               "+WFML2
  Endif

Next J

Wrseq       "&               +'9999Z'"

WECC = "[M]WECCVALMAJ(I)=[M]ECCVALMAJ"

# Deuxième boucle : [M:ALP]ECCVALMAJ est renseigné et il sert de filtre
For J=0 To dim([F:TRU]STAFLT)-1

   # Plus de lignes de règles
   If [F:TRU]STAFLT(J)=0 Break Endif

   Gosub FIL_STA_UNI

   # Ajout filtre sur version
   If WCDE=""
      WCDE+=WECC
   Else
      WCDE+="&"+WECC
   Endif
   # Si la condition n'est pas la première,
   # la ligne ne doit pas être déjà élue (14 car maxi)
   WCDE1=string$(J>0,"[M]WCOND(I)=''")
   # Combinaison des 2 filtres (1 car maxi)
   If WCDE<>"" & WCDE1<>""
      WCDE += "&"+WCDE1
   Else
      WCDE += WCDE1
   Endif

   # La formule de tri (emplacement filtre allocation) commence par A1,B1,C1...
   # pour tenir compte de l'ordre des critères (14 car)
   # [M]WINCLOT(I) permet de traiter le mono-lot
   WFME ="string$("+WCDE+","
   WFME2="[M]WINCLOT(I)"+"+'"+chr$(65+J)+chr$(49)+"'+"

   Gosub FIL_LOC

   # Ajout filtre sur version
   If WCDT=""
      WCDT+=WECC
   Else
      WCDT+="&"+WECC
   Endif
   # Si la condition n'est pas la première,
   # la ligne ne doit pas être déjà élue (14 car maxi)
   WCDT1="[M]WCOND(I)=''"
   # Combinaison des 2 filtres (1 car maxi)
   If WCDT<>"" & WCDT1<>""
      WCDT += "&"+WCDT1
   Else
      WCDT += WCDT1
   Endif

   # La formule de tri (emplacement règle allocation) commence par A2,B2,C2...
   # pour tenir compte de l'ordre des critères (14 car)
   WFML ="string$("+WCDT+","
   WFML2="[M]WINCLOT(I)"+"+'"+chr$(65+J)+chr$(50)+"'+"

   Gosub FIL_TRI

   # Ecriture du source
   If J=0
      Wrseq "  Else"
      Wrseq "    [M]WCOND(I)="+WFME
      Wrseq "&               "+WFME2
      Wrseq "&               +"+WFML
      Wrseq "&               "+WFML2
   Else
      Wrseq "&               +"+WFME
      Wrseq "&               "+WFME2
      Wrseq "&               +"+WFML
      Wrseq "&               "+WFML2
  Endif

Next J

# Troisième boucle : [M:ALP]ECCVALMAJ est renseigné mais il ne sert pas de filtre
#                    Le filtre a été exploité dans la deuxième boucle
For J=0 To dim([F:TRU]STAFLT)-1

   # Plus de lignes de règles
   If [F:TRU]STAFLT(J)=0 Break Endif

   Gosub FIL_LOOP_1_3

   WFME2="[M]WINCLOT(I)"+"+'"+chr$(65+J+dim([F:TRU]STAFLT))+chr$(49)+"'+"
   WFML2="[M]WINCLOT(I)"+"+'"+chr$(65+J+dim([F:TRU]STAFLT))+chr$(50)+"'+"

   Gosub FIL_TRI

   # Ecriture du source
   Wrseq "&               +"+WFME
   Wrseq "&               "+WFME2
   Wrseq "&               +"+WFML
   Wrseq "&               "+WFML2

Next J

Wrseq       "&               +'9999Z'"
Wrseq       "  Endif"
#--- TS 106217 End

Wrseq "Next I"
Wrseq
Wrseq "# Tri du tableau sur deux colonnes seulement pour raisons de performance"
Wrseq "Sorta [M]NBLIG [M]WCOND,[M]NLIG"
Wrseq "[M]NBLIG=sigma(0,[M]NBLIG-1,[M]WCOND(indcum)<'9999Z')"
Wrseq "# Si gestion dépôt et dépôt préférentiel renseigné"
Wrseq "If GWRHACT=2 & !find(LWRH,'','*')"
Wrseq "   For I=0 To [M]NBLIG-1"
Wrseq "      If pat([M]WWRH(I),LWRH)"
Wrseq "         [M]WCOND(I)='1'+[M]WCOND(I)"
Wrseq "      Else"
Wrseq "         [M]WCOND(I)='9'+[M]WCOND(I)"
Wrseq "      Endif"
Wrseq "   Next I"
Wrseq "Endif"
Wrseq "# Si propriétaire"
Wrseq "If [M]PECOWNER<>''"
Wrseq "   For I=0 To [M]NBLIG-1"
Wrseq "      If [M]WCOND(I)='9999Z'"
Wrseq "         [M]WCOND(I)='9'+[M]WCOND(I)"
Wrseq "      Else"
Wrseq "         [M]WCOND(I)=[M]WOWN(I)+[M]WCOND(I)"
Wrseq "      Endif"
Wrseq "   Next I"
Wrseq "Endif"
Wrseq "Return"

Openo
# Validation du traitement généré
Call VALID("TRT",NOMTRT,APPLI,OK) From VALMSKSUB

adxifs = WADXIFS
adxirs = WADXIRS
adxium = WADXIUM

Return

#--- TS 106217
#############################################################
$FIL_LOOP_1_3

   Gosub FIL_STA_UNI

   # Si la condition n'est pas la première,
   # la ligne ne doit pas être déjà élue (14 car maxi)
   WCDE1=string$(J>0,"[M]WCOND(I)=''")
   # Combinaison des 2 filtres (1 car maxi)
   If WCDE<>"" & WCDE1<>""
      WCDE += "&"+WCDE1
   Else
      WCDE += WCDE1
   Endif

   # La formule de tri (emplacement filtre allocation) commence par A1,B1,C1...
   # pour tenir compte de l'ordre des critères (14 car)
   # [M]WINCLOT(I) permet de traiter le mono-lot
   WFME ="string$("+WCDE+","

   Gosub FIL_LOC

   # Si la condition n'est pas la première,
   # la ligne ne doit pas être déjà élue (14 car maxi)
   WCDT1="[M]WCOND(I)=''"
   # Combinaison des 2 filtres (1 car maxi)
   If WCDT<>"" & WCDT1<>""
      WCDT += "&"+WCDT1
   Else
      WCDT += WCDT1
   Endif

   # La formule de tri (emplacement règle allocation) commence par A2,B2,C2...
   # pour tenir compte de l'ordre des critères (14 car)
   WFML ="string$("+WCDT+","

Return
#---

#--- TS 106217
#############################################################
$FIL_STA_UNI
   # Filtre statut (35 car maxi)
   Case [F:TRU]STAFLT(J)
    When 1,2,4   : WCDT="left$([M]WSTA(I),1)='"+mid$("AQ R",[F:TRU]STAFLT(J),1)+"'"
    When 3       : WCDT="find(left$([M]WSTA(I),1),'A','Q')>0"
    When 5       : WCDT="find(left$([M]WSTA(I),1),'A','R')>0"
    When 6       : WCDT="find(left$([M]WSTA(I),1),'Q','R')>0"
    When Default : WCDT=""
   Endcase

   # Filtre unités + coef (69 car maxi)
   If [F:TRU]STUFLT(J)=2
      If [F:TRU]PCUFLT(J)=2
         WCDT2="[M]WPCU(I)=[M]STU|([M]WPCU(I)<>[M]STU"
         Case [F:TRU]COEFLT(J)
          When 1 : WCDT1=""
          When 2 : WCDT1=WCDT2+"&[M]WPCUSTUCOE(I)=[M]PCUSTUCOE)"
          When 3 : WCDT1=WCDT2+"&[M]WPCUSTUCOE(I)<=[M]PCUSTUCOE)"
          When 4 : WCDT1=WCDT2+"&[M]WPCUSTUCOE(I)>=[M]PCUSTUCOE)"
         Endcase
      Elsif [F:TRU]DOCFLT(J)=2
         WCDT2="[M]WPCU(I)=[M]STU|([M]WPCU(I)=[M]PCU"
         Case [F:TRU]COEFLT(J)
          When 1 : WCDT1=WCDT2+")"
          When 2 : WCDT1=WCDT2+"&[M]WPCUSTUCOE(I)=[M]PCUSTUCOE)"
          When 3 : WCDT1=WCDT2+"&[M]WPCUSTUCOE(I)<=[M]PCUSTUCOE)"
          When 4 : WCDT1=WCDT2+"&[M]WPCUSTUCOE(I)>=[M]PCUSTUCOE)"
         Endcase
      Else
         WCDT1="[M]WPCU(I)=[M]STU"
      Endif
   Else
      If [F:TRU]PCUFLT(J)=2
         WCDT2="[M]WPCU(I)<>[M]STU"
         Case [F:TRU]COEFLT(J)
          When 1 : WCDT1=WCDT2
          When 2 : WCDT1=WCDT2+"&[M]WPCUSTUCOE(I)=[M]PCUSTUCOE"
          When 3 : WCDT1=WCDT2+"&[M]WPCUSTUCOE(I)<=[M]PCUSTUCOE"
          When 4 : WCDT1=WCDT2+"&[M]WPCUSTUCOE(I)>=[M]PCUSTUCOE"
         Endcase
      Elsif [F:TRU]DOCFLT(J)=2
         WCDT2="[M]WPCU(I)=[M]PCU"
         Case [F:TRU]COEFLT(J)
          When 1 : WCDT1=WCDT2
          When 2 : WCDT1=WCDT2+"&[M]WPCUSTUCOE(I)=[M]PCUSTUCOE"
          When 3 : WCDT1=WCDT2+"&[M]WPCUSTUCOE(I)<=[M]PCUSTUCOE"
          When 4 : WCDT1=WCDT2+"&[M]WPCUSTUCOE(I)>=[M]PCUSTUCOE"
         Endcase
      Else
         WCDT1="[M]WSTA(I)='ZZZ'"
      Endif
   Endif
   # Combinaison des 2 filtres (1 car maxi)
   If WCDT<>"" & WCDT1<>""
      WCDT += "&"+WCDT1
   Else
      WCDT += WCDT1
   Endif

   # Récupération des critères dans WCDE pour exploitation de l'emplacement
   # du filtre allocation par lignes de règle d'allocation
   WCDE =WCDT

   # Filtre emplacement du filtre allocation (51 car maxi)
   WCDE1="pat([M]WLOC(I),[M]LOC)|pat([M]WLOCTYP(I),[M]LOCTYP)"
   # Filtre emplacement du filtre allocation (22 car maxi)
   #WCDE1="pat([M]WLOC(I),[M]LOC)"
   # Combinaison des 2 filtres (1 car maxi)
   If WCDE<>"" & WCDE1<>""
      WCDE += "&"+WCDE1
   Else
      WCDE += WCDE1
   Endif

Return
#---

#--- TS 106217
#############################################################
$FIL_LOC
   # Filtre emplacement de la règle d'allocation (55 car maxi)
   Case [F:TRU]LOCFLT(J)
    When 2       : WCDT1="pat([M]WLOC(I),[M]STOLOC)"
    When 3       : WCDT1="pat([M]WLOC(I),WDEFLOC)&pat([M]WLOCTYP(I),WDEFLOCTYP)"
    When 4       : WCDT1="pat([M]WLOC(I),WDEFLOC2)&pat([M]WLOCTYP(I),WDEFLOCTYP2)"
    When 5       : WCDT1="pat([M]WLOC(I),WDEFLOC3)&pat([M]WLOCTYP(I),WDEFLOCTYP3)"
    When Default : WCDT1=""
   Endcase
   # Combinaison des 2 filtres (1 car maxi)
   If WCDT<>"" & WCDT1<>""
      WCDT += "&"+WCDT1
   Else
      WCDT += WCDT1
   Endif

Return
#---

#--- TS 106217
#############################################################
$FIL_TRI
   # Puis on y place l'ordre de tri selon le coef (47 car maxi)
   # 3 = Tri croissant / 2 = Tri décroissant
   If [F:TRU]COESOR(J)=3
      WFML2+="format$('N0:12',10^6*[M]WPCUSTUCOE(I))+"
      WFME2+="format$('N0:12',10^6*[M]WPCUSTUCOE(I))+"
   Elsif [F:TRU]COESOR(J)=2
      WFML2+="format$('N0:12',10^11-1-10^6*[M]WPCUSTUCOE(I))+"
      WFME2+="format$('N0:12',10^11-1-10^6*[M]WPCUSTUCOE(I))+"
   Endif

   # On y place enfin, l'ordre de tri des lots (41 car maxi)
   Case [F:TRU]LOTMGT
    When 1 : WFML2+="format$('K:20X',[M]WLOT(I))+[M]WSLO(I)"
             WFME2+="format$('K:20X',[M]WLOT(I))+[M]WSLO(I)"
    When 2 : WFML2+="format$('D:4YMMDD',[M]WLOTCREDAT(I))"
             WFME2+="format$('D:4YMMDD',[M]WLOTCREDAT(I))"
    When 3 : WFML2+="format$('D:4YMMDD',[M]WSHLDAT(I))"
             WFME2+="format$('D:4YMMDD',[M]WSHLDAT(I))"
    When 4 : WFML2+="format$('D:4YMMDD',WDATMAX-[M]WLOTCREDAT(I))"
             WFME2+="format$('D:4YMMDD',WDATMAX-[M]WLOTCREDAT(I))"
   Endcase
   # --> 242 caractères maxi
   WFML2+=")"
   # --> 244 caractères maxi
   WFME2+=")"

Return
#---

#############################################################
$DEL_TRT
Local Char    NOMTRT(10), FICTRT(GDIMFIC), EXT(4)
Local Integer STAT

If dim(APPLI)<0 Local Char APPLI Endif
If APPLI=""     APPLI=nomap      Endif

#--- Avant archivage des adx
# Suppression des traitements associés
#NOMTRT="WV"+[F:TRU]TRUCOD
#For EXT="adx","src"
#   FICTRT=filpath("TRT",NOMTRT,EXT,APPLI)
#   While filinfo(FICTRT,0)>=0
#      Call EFFACE(FICTRT,STAT) From ORDSYS
#      FICTRT=filpath("TRT",NOMTRT,EXT,APPLI)
#   Wend
#Next EXT
#--- Depuis archivage des adx
# Suppression des traitements associés
NOMTRT="WV"+[F:TRU]TRUCOD
EXT="src"
FICTRT=filpath("TRT",NOMTRT,EXT,APPLI)
While filinfo(FICTRT,0)>=0
   Call EFFACE(FICTRT,STAT) From ORDSYS
   FICTRT=filpath("TRT",NOMTRT,EXT,APPLI)
Wend
Call EFFACE_ADX("","",NOMTRT,STAT) From ORDSYS

Return

########################################
Subprog AP_DOCFLT(VALEUR)
Variable Integer VALEUR
If VALEUR=1 & [M]PCUFLT(nolign-1)=1
   Grizo [M]COEFLT(nolign-1)
   Grizo [M]COESOR(nolign-1)
   [M]COEFLT(nolign-1)=1
   [M]COESOR(nolign-1)=1
Else
   Actzo [M]COEFLT(nolign-1)
   Actzo [M]COESOR(nolign-1)
Endif
Affzo [M]COEFLT(nolign-1), COESOR(nolign-1)
End

########################################
Subprog AP_PCUFLT(VALEUR)
Variable Integer VALEUR

If VALEUR=1 & [M]DOCFLT(nolign-1)=1
   Grizo [M]COEFLT(nolign-1)
   Grizo [M]COESOR(nolign-1)
   [M]COEFLT(nolign-1)=1
   [M]COESOR(nolign-1)=1
Else
   Actzo [M]COEFLT(nolign-1)
   Actzo [M]COESOR(nolign-1)
Endif
Affzo [M]COEFLT(nolign-1), COESOR(nolign-1)
End

########################################
Subprog AP_COEFLT(VALEUR)
Variable Integer VALEUR

If VALEUR=2
   Grizo [M]COESOR(nolign-1)
   [M]COESOR(nolign-1)=1
Else
   Actzo [M]COESOR(nolign-1)
Endif
Affzo [M]COESOR(nolign-1)
End

#################################################
$TRTCOP
# TABLE contient la valeur du paramètre 2 de l'action ACOPIE (ici [M]TRUCOD)
If [M]DOSORG=nomap
 Local File TABALLRUL [TRU1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[M]DOSORG+".TABALLRUL" [TRU1]
 Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
Endif
If [M]DOSDES=nomap
 Local File TABALLRUL [TRU2]
 Local File ATEXTRA   [AXX2]
Else
 Local File =[M]DOSDES+".TABALLRUL" [TRU2]
 Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
Endif
OK = 1
If GTRACE=""
 Read [TRU2]TRU0 = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
Gosub OUVDOS From ATEXTRA
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [TRU1], [TRU2]
Close Local File [AXX1], [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [TRU2]
 Delete [TRU2] Where TRUCOD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABALLRUL" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("TRU2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [TRU1]TRU0=TABLE
 If !fstat
  [F:TRU2] = [F:TRU1]
  If dim([F:TRU2]UPDUSR)>0 : [F:TRU2]UPDUSR = GUSER : Endif
  If dim([F:TRU2]UPDDAT)>0 : [F:TRU2]UPDDAT = date$ : Endif
  If dim([F:TRU2]UPDTIM)>0 : [F:TRU2]UPDTIM = time  : Endif
  Write [TRU2]
  If fstat
   GOK=0 : Call FSTA("TRU2") From GLOCK
  Endif
 Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Call COPTEXTRA("TABALLRUL","TRUAXX",[F:TRU2]TRUCOD,"") From ATEXTRA
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

###########################################################################
# Pour éxécution de la validation des règles d'allocations et sorties     #
# par la gestion de dossier                                               #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

If clalev([F:TRU])<=0 : Local File =APPLI+".TABALLRUL"    [TRU] : Endif

For [TRU]TRU0
   Gosub GEN_TRT
Next

End
