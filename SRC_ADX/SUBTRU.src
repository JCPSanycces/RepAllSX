#<AdxTL>@(#)3.0.0.0 $Revision$
Local File TABALLRUL [TRU]
For [TRU]TRU0
   Gosub GEN_TRT
Next
End

#############################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF
 When "VERIF_MOD"   : Gosub VERIF
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INICRE
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Call CHANGE_AXX ("TABALLRUL", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase
Return

#############################################################
$OUVRE
# Si on ne vient pas de la gestion des règles d'allocations

# mis en commentaire par HCB suite à demande de Cyrille Hamon  24 05 04
#If GFONCTION1<>"GESTRU" GCONSULT=2 Endif

Return

$INICRE
    Call MAJTEXTRA([M:TRU1]TRUAXX,"TABALLRUL","TRUAXX",[M:TRU1]TRUCOD,"") From ATEXTRA
Return

$ANNULE
    Delete [AXX] Where CODFIC="TABALLRUL" & ZONE="TRUAXX" & CLE1= [M:TRU1]TRUCOD
Return

############################################################
$LIENS
Local Integer I

[M:TRU1]NBLIG = find(0,[M:TRU1]STAFLT(0..dim([M:TRU1]STAFLT)-1))
If [M:TRU1]NBLIG = 0
   [M:TRU1]NBLIG = dim([M:TRU1]STAFLT)
Else
   [M:TRU1]NBLIG -= 1
Endif

# Affichage pour que les grizo soient effectifs
If AFFICHE
   Gosub AFFZONE From GOBJSUB
Endif

For I=0 To [M]NBLIG-1
   Actzo [M]COEFLT(I)
   Actzo [M]COESOR(I)
   If [M]DOCFLT(I)=1 & [M]PCUFLT(I)=1
      Grizo [M]COEFLT(I)
      Grizo [M]COESOR(I)
   Endif
   If [M]COEFLT(I)=2
      Grizo [M]COESOR(I)
   Endif
Next I

Return

#############################################################
$VERIF
Local Integer I

If [M]NBLIG=0
   OK=0 : GMESSAGE=mess(205,199,1)
Endif

For I=0 To [M]NBLIG-1
   If [M]DOCFLT(I)+[M]STUFLT(I)+[M]PCUFLT(I)<4
      OK=0 : GMESSAGE=mess(361,199,1)
      Break
   Endif
Next I

Return

#############################################################
$APRES_CRE
Gosub GEN_TRT
Return

#############################################################
$APRES_MOD
Gosub DEL_TRT
Gosub GEN_TRT
Return

#############################################################
$AP_ANNULE
Gosub DEL_TRT
Return

#############################################################
$GEN_TRT
Local Char    WFML(250), WFME(250), WFML2(250), WFME2(250)
Local Char    WCDT(230), WCDE(230)            : # TS 106217 passage de 200 à 230
Local Char    WCDT1(120), WCDE1(100)
Local Char    WCDT2(50)
Local Char    NOMTRT(10), FICTRT(GDIMFIC), EXT(4)
Local Integer STAT, OK
Local Char    WADXIFS(1), WADXIRS(2)
Local Integer WADXIUM
#--- TS 106217
Local Char    WECC(30)

WADXIFS = adxifs
WADXIRS = adxirs
WADXIUM = adxium

adxifs  = ""
adxirs  = chr$(10)
adxium  = GASCII

If dim([L]APPLI)<0 Local Char APPLI Endif
If [L]APPLI=""     [L]APPLI=nomap      Endif

NOMTRT="WV"+[F:TRU]TRUCOD
FICTRT=filpath("TRT",NOMTRT,"src",APPLI)

Openo FICTRT,0
Wrseq "#<AdxT"+GADOVERS+">@(#)%|%","Algorithme pour règle d'allocation"+[F:TRU]TRUCOD
Wrseq "#-----------------------------------------------------------------"
Wrseq "# WV";[F:TRU]TRUCOD;"                                         ";format$(GFMD,date$)
Wrseq "#-----------------------------------------------------------------"
Wrseq "$TRT_ALLOC"
#Wrseq "Default Mask [ALP]"
Wrseq "Local Date WDATMAX : WDATMAX=[31/12/2100]"
Wrseq "For I=0 To [M]NBLIG-1"

