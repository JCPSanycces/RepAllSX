#<AdxTL>@(#)2.0.0.0 $Revision$
# TRTITC  Traitement pour la gestion des coûts modélisées    TB Avril 2003
#         CONTROLE DE GESTION                                (v 140)
# Actions pour les boutons 'Détail' du tableau des coûts std (SAIITCDET...)
# Site, Article, Type, Année et Seq en paramètre pour lecture éventuelle
# l'écran ITCDET est déjà ouvert sous les 4 abv depuis l'objet ITC
# Actions pour le bouton 'Détail' de la consultation prix de revient (SAIMFCDET...)
# Actions pour le détail des natures de frais généraux : SAIITCNAT SAIMFCNAT
# Actions pour le détail des coûts du niveau : SAIITCLEV (intégration du spécif US)

$ACTION
# actions pour GSAISIE
Case ACTION

 When "OUVRE"
   Case GACTION
    When "SAIMFCDET" :      Gosub OUV_MFCD
    When Default     :      Gosub OUVRE
   Endcase
 When "TITRE"        :      Gosub TITLE
 When "OUVRE_BOITE"  :      Gosub OUVRE_BOITE
 When "DEBUT" 
    If left$(GACTION,9) = "SAIITCDET"  | left$(GACTION,9) = "ITCDETLEV"
                            Gosub DEB_ITCD
    Endif 
    If left$(GACTION,9) = "SAIITCLEV"
                            Gosub DEB_ICL
    Endif 
    Case GACTION
      When "SAIITCNAT" :    Gosub DEB_ICN
      When "SAIMFCDET" :    Gosub DEB_MFCD
      When "SAIMFCNAT" :    Gosub DEB_MCN
    Endcase
 When "SETBOUT" :           Gosub SETBOUT
 When "ENR"
      Case GACTION
        When "SAIITCDET" :  Gosub ENR_ITCD
      Endcase
        
 When "APRES_MODIF" :       Gosub APRES_MODIF
Endcase
Return

$TITLE
    If left$(GACTION,6) = "SAIITC" | left$(GACTION,9) = "ITCDETLEV"  # pour SAIITCDETx et SAIITCLEVx 
      Gosub TIT_FEN
    Endif
    # 
    If left$(GACTION,9) = "SAIITCLEV"  | left$(GACTION,9) = "ITCDETLEV"
        TIT -= "("+mess(509,197,1)+")"  # (niveau)
    Endif
Return

$OUVRE
If !clalev([F:ITC]) Local File ITMCOST   [ITC]  Endif : # Pour lecture éventuelle
If !clalev([F:ICN]) Local File ITCNAT    [ICN]  Endif
If !clalev([F:ITM]) Local File ITMMASTER [ITM]  Endif
Local Integer LMODIF
Raz LMODIF
Return

$OUV_MFCD
If !clalev([F:MFC]) Local File MFGCOST [MFC]  Endif : # Pour lecture éventuelle
If !clalev([F:MCN]) Local File MFCNAT  [MCN]  Endif
Return

$TIT_FEN
Case PARAM(3)
  When "1"    TIT = mess(75,197,1)
  When "2"    TIT = mess(76,197,1)
  When "3"    TIT = mess(77,197,1)
  When "4"    TIT = mess(78,197,1)
Endcase
Return

$OUVRE_BOITE
Return

$DEB_ITCD
# Quand on vient de la gestion des coûts les écrans sont déjà chargés
# sinon lire le coût avec les paramètres et charger ## !!ITC > HIC les écrans existent déjà et ITC est filtré !
If GFONCTION = "GESITC"
        Case PARAM(3)
            When "1"    [M:ICST] = [M:ITCD] # le standard
            When "2"    [M:ICST] = [M:ITCA]
            When "3"    [M:ICST] = [M:ITCB]
            When "4"    [M:ICST] = [M:ITCS]
        Endcase
Else
  Read [ITC]ITC0 = PARAM(1);PARAM(2);val(PARAM(3));val(PARAM(4));0
  If !fstat
    [M:ICST] = [F:ITC]
  Endif
Endif

If left$(GACTION,9) = "ITCDETLEV"
    [M:ICST]MATTOT = sum([M:ICST]MATLEVCST)
    [M:ICST]MACTOT = sum([M:ICST]MACLEVCST)
    [M:ICST]LABTOT = sum([M:ICST]LABLEVCST)
Endif

Affzo [M:ICST]
Return

$DEB_ICL
#charger l'écran des couts du niveau
Local Char    SITE(GLONFCY)  : SITE   = PARAM(1)
Local Char    ART(GLONITM)   : ART    = PARAM(2)
Local Integer TYP            : TYP    = val(PARAM(3))
Local Integer SEQ            : SEQ    = val(PARAM(4))
If [F:ITM]ITMREF <> ART
  Read [ITM]ITM0 = ART
Endif
Read [ITC]ITC0 = PARAM(1);PARAM(2);val(PARAM(3));val(PARAM(4));0
If !fstat
    [M:ICL] = [F:ITC]

#    # rassembler tout ce qui n'est pas du niveau dans la part matière :
#    [M:ICL]MATLEVCST = [F:ITC]MATTOT + ([F:ITC]LABTOT - [F:ITC]LABLEVCST) +
#&     ([F:ITC]MACTOT - [F:ITC]MACLEVCST) + ([F:ITC]SCOTOT - [F:ITC]SCOLEVCST) +
#&     ([F:ITC]OVETOT - [F:ITC]OVELEVCST)
    [M:ICL]MATLEVCST = sum([F:ITC]MATLEVCST)
    [M:ICL]MACLEVCST = sum([F:ITC]MACLEVCST)
    [M:ICL]LABLEVCST = sum([F:ITC]LABLEVCST)

    # Affichage de la devise d'après le site
    Call GETDEV(SITE) From DEVSUB
    [M:ICL]CUR = [F:TCU]CUR
    [M:ICL]STU = [F:ITM]STU  # pour format de la qté
    
Endif

Return

$DEB_ICN
#charger l'écran des natures de frais
Local Char    SITE(GLONFCY)  : SITE   = PARAM(1)
Local Char    ART(GLONITM)   : ART    = PARAM(2)
Local Integer TYP            : TYP    = val(PARAM(3))
Local Integer SEQ            : SEQ    = val(PARAM(4))
Local Integer LUID           : LUID   = val(PARAM(5))


Read [ITC]ITC0 = SITE;ART;TYP;SEQ;LUID
[M:ICN] = [F:ITC]
nolign = 0 
# Chargement de la classe ecran 
For [ICN] Where STOFCY=SITE & ITMREF=ART & CSTTYP=TYP
&             & ITCSEQ=SEQ  & UID = LUID
    nolign += 1
    [M:ICN] = [F:ICN] :  # écran détail des natures de FG 
    [M:ICN]NATTOT(nolign-1) = [F:ICN]NATAMTLEV+[F:ICN]NATAMTSSE
    If nolign = 100 Break Endif :# éviter de dépasser le tableau
Next

[M:ICN]NBNAT = nolign
Affzo [M:ICN]1-99  # tableau
Return

$DEB_MFCD
Read [MFC]MFC0 = PARAM(1);PARAM(2);val(PARAM(3));PARAM(4);val(PARAM(5));val(PARAM(6));0
If !fstat
    [M:MFCD] = [F:MFC]
Endif
Return

$DEB_MCN
#charger l'écran des natures de frais
Local Char    SITE(GLONFCY)  : SITE   = PARAM(1)
Local Char    ART(GLONITM)   : ART    = PARAM(2)
Local Integer TYP            : TYP    = val(PARAM(3))
Local Char    ORDRE(GLONMFG) : ORDRE  = PARAM(4)
Local Integer LIGNE          : LIGNE  = val(PARAM(5))
Local Integer MTYP           : MTYP = val(PARAM(6))

[M:MCN]STOFCY = SITE
[M:MCN]ITMREF = ART
[M:MCN]VCRTYP = TYP
[M:MCN]VCRNUM = ORDRE
[M:MCN]VCRLIN = LIGNE # = ligne de l'OF + MFCTYP modulo 4  !
[M:MCN]MFCTYP = MTYP

nolign = 0 
# Chargement de la classe ecran 
For [MCN] Where STOFCY=SITE & ITMREF=ART & VCRTYP=TYP & VCRNUM=ORDRE
&             & VCRLIN = LIGNE & MFCTYP=MTYP
    nolign += 1
    [M:MCN] = [F:MCN] :  # écran détail des natures de FG 
    [M:MCN]NATTOT(nolign-1) = [F:MCN]NATAMTLEV+[F:MCN]NATAMTSSE
    If nolign = 100 Break Endif :# éviter de dépasser le tableau
Next

[M:MCN]NBNAT = nolign
Affzo [MCN]10  # tableau
Return

$SETBOUT
Return

$APRES_MODIF
    REP="M"
    LMODIF=1
    If evalue("type([M:SDP]"+COUZON+")")<10
        Assign "[M:SDP]"+COUZON+"(indice)" With val(CZ)    # Pour que le calcul des totaux soit bon
    Else
        Assign "[M:SDP]"+COUZON+"(indice)" With CZ    # Pour que le calcul des totaux soit bon
    Endif
    Gosub CAL_TOT From SUBSDP
Return

$ENR_ITCD
If LMODIF
    Case val(PARAM(3))
        When 1:
            [M:ITCD] = [M:ICST]
            [M:ITC1]STDCST(0) = sum([M:ITCD]MATCST)  : # matière
            [M:ITC1]STDCST(1) = sum([M:ITCD]MACCST)  : # machine
            [M:ITC1]STDCST(2) = sum([M:ITCD]LABCST)  : # main d'oeuvre
            [M:ITC1]STDCST(3) =     [M:ITCD]SCOTOT   : # sous-traitance
            [M:ITC1]STDCST(4) =     [M:ITCD]OVEMATCST+[M:ITCD]OVEMACCST+[M:ITCD]OVELABCST+[M:ITCD]OVESCOCST   : # FG
            [M:ITC1]STDCST(5) = sum([M:ITC1]STDCST(0..3))   : # Tot sans FG
            [M:ITC1]STDCST(6) = sum([M:ITC1]STDCST(0..4))  : # Tot avec FG
            For I=0 To dim(STDCST)-1
                [M:ITC2]STDCST(I) = [M:ITC1]STDCST(I)
            Next
        When 2:
            [M:ITCA] = [M:ICST]
            [M:ITC1]ACTCST(0) = sum([M:ITCA]MATCST)  : # matière
            [M:ITC1]ACTCST(1) = sum([M:ITCA]MACCST)  : # machine
            [M:ITC1]ACTCST(2) = sum([M:ITCA]LABCST)  : # main d'oeuvre
            [M:ITC1]ACTCST(3) =     [M:ITCA]SCOTOT   : # sous-traitance
            [M:ITC1]ACTCST(4) =     [M:ITCA]OVETOT   : # FG
            [M:ITC1]ACTCST(5) =     [M:ITCA]CSTTOT   : # Tot sans FG
            [M:ITC1]ACTCST(6) =     [M:ITCA]CSTTOT  + [M:ITCA]OVETOT : # Tot avec FG
            For I=0 To dim(ACTCST)-1
                [M:ITC2]ACTCST(I) = [M:ITC1]ACTCST(I)
            Next
    
        When 3:
            [M:ITCB] = [M:ICST]
            [M:ITC1]BUDCST(0) = sum([M:ITCB]MATCST)  : # matière
            [M:ITC1]BUDCST(1) = sum([M:ITCB]MACCST)  : # machine
            [M:ITC1]BUDCST(2) = sum([M:ITCB]LABCST)  : # main d'oeuvre
            [M:ITC1]BUDCST(3) =     [M:ITCB]SCOTOT   : # sous-traitance
            [M:ITC1]BUDCST(4) =     [M:ITCB]OVETOT   : # FG
            [M:ITC1]BUDCST(5) =     [M:ITCB]CSTTOT   : # Tot sans FG
            [M:ITC1]BUDCST(6) =     [M:ITCB]CSTTOT + [M:ITCB]OVETOT : # Tot avec FG
            For I=0 To dim(BUDCST)-1
                [M:ITC2]BUDCST(I) = [M:ITC1]BUDCST(I)
            Next
    
        When 4:
            [M:ITCS] = [M:ICST]
            [M:ITC1]SIMCST(0) = sum([M:ITCS]MATCST)  : # matière
            [M:ITC1]SIMCST(1) = sum([M:ITCS]MACCST)  : # machine
            [M:ITC1]SIMCST(2) = sum([M:ITCS]LABCST)  : # main d'oeuvre
            [M:ITC1]SIMCST(3) =     [M:ITCS]SCOTOT   : # sous-traitance
            [M:ITC1]SIMCST(4) =     [M:ITCS]OVETOT   : # FG
            [M:ITC1]SIMCST(5) =     [M:ITCS]CSTTOT   : # Tot sans FG
            [M:ITC1]SIMCST(6) =     [M:ITCS]CSTTOT + [M:ITCS]OVETOT : # Tot avec FG
            For I=0 To dim(SIMCST)-1
                [M:ITC2]SIMCST(I) = [M:ITC1]SIMCST(I)
            Next
    Endcase
    mkstat=4
Endif
FIN=1
Return

$CALTOT
[M:ICST]MATTOT = sum([M:ICST]MATCST)
Return

