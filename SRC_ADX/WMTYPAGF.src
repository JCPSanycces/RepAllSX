#<AdxTL>@(#)0.0.0.0 $Revision$Class Site groupings
# Supervisor
## ATY-ATYPE ## AGF
# 2018-11-09 07:13:32 139

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,GRP,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char GRP
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File AGRPFCY [AGF]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".AGRPFCY" [AGF]
Endif

Default File [F:AGF]
Read [F:AGF]AGF0 = [L]GRP
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]GRP)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When "B"
  [L]ATSTFILTER = ([F:AGF]FLGLEG=[V]CST_AYES) : [L]AMESFILTER= func ASYRFNC.TEXTE(29867)
 When "C"
  [L]ATSTFILTER = ([F:AGF]FLGCPY=[V]CST_AYES) : [L]AMESFILTER= func ASYRFNC.TEXTE(29868)
 When "F"
  [L]ATSTFILTER = ([F:AGF]FLGCPY<>[V]CST_AYES) : [L]AMESFILTER= func ASYRFNC.TEXTE(39516)
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]GRP)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


