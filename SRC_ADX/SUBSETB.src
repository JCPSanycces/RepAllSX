##########################################################################################################
#   Programmes utilitaires pour la gestion des modèles de demandes de services Module CRM  24 Juin 2003
#
#   LOADHDT     : Chargement des consommations
#   SAVEHDT     : Enregistrement des consommations
#   LOADMAC     : Chargement du parc concerné
#   SAVEMAC     : Enregistrement du parc concerné
#   SAVECPNLIN  : Enregistrement d'une ligne de composant concerné
#   SAVECPNWKEY : Enregistrement des composants suite à la transaction de création de la demande
#   RAZMAC      : Suppression du tableau du parc concerné
#   DUPLICPN    : Duplication des composants concernés
#   DISPICON    : Affichage des icônes
#   SAVEHD1     : Enregistrement du CLOB description complète
#   DELHD1      : Suppression du CLOB description complète
#   LOADHD1     : Chargement du CLOB description complète
#   ADDHDTITM   : Ajoute l'article concerné par défaut sur une ligne de consommation
##########################################################################################################
##########################################################################################################
# Chargement des consommations
#####################################################################
Subprog LOADHDT(SZSETNUM)
Value Char SZSETNUM

Local Integer ILINDEB

  ILINDEB = 0
  Raz [M:SET2]NBLIG
  Raz [M:SET2]HDTMACSET
  Raz [M:SET2]HDTCPN
  Raz [M:SET2]HDTTYP
  Raz [M:SET2]HDTITM
  Raz [M:SET2]HDTQTY
  Raz [M:SET2]HDTUOM
  Raz [M:SET2]HDTINVMOD
  Raz [M:SET2]HDTNUM
  #Chargement à partir de HDKTASK
  Filter [HDT] Where [F:HDT]SRENUM = SZSETNUM and [F:HDT]TPL = 2 Order By [F:HDT]HDTMACSET Asc; [F:HDT]HDTCPN Asc; [F:HDT]HDTITM Asc
  nolign = 0
  For [HDT] Hint Key HDT1
    If ILINDEB >= dim([M:SET2]HDTMACSET) Then
      Break
    Endif
    #Transclass
    nolign += 1
    [M:SET2] = [F:HDT]
    [M:SET2]HDTMACSET(ILINDEB) = [F:HDT]HDTMACSET
    #Call LECTEXTRA([M:SET2]HDTDES(ILINDEB), "ITMMASTER", "DES1AXX", [F:HDT]HDTMACSET, "") From ATEXTRA
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:HDT]HDTMACSET,[M:SET2]HDTDES(ILINDEB), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
    [M:SET2]HDTCPN(ILINDEB) = [F:HDT]HDTCPN
    [M:SET2]HDTTYP(ILINDEB) = [F:HDT]HDTTYP
    [M:SET2]HDTITM(ILINDEB) = [F:HDT]HDTITM
    [M:SET2]HDTQTY(ILINDEB) = [F:HDT]HDTQTY
    [M:SET2]HDTUOM(ILINDEB) = [F:HDT]HDTUOM
    [M:SET2]HDTINVMOD(ILINDEB) = [F:HDT]HDTINVMOD
    [M:SET2]HDTNUM(ILINDEB) = [F:HDT]HDTNUM
    ILINDEB += 1
  Next
  Filter [HDT]
  [M:SET2]NBLIG = ILINDEB
  Affzo [M:SET2]1-99
End

##########################################################################################################
# Enregistrement des consommations
#####################################################################
Subprog SAVEHDT(SZSETNUM)
Value Char SZSETNUM

Local Integer ITER
Local Integer IERR

  IERR = 0
  #On efface tout
  Call DEBTRANS From GLOCK
  Trbegin [HDT]
  Delete [HDT] Where [F:HDT]SRENUM = SZSETNUM and [F:HDT]TPL = 2
  If fstat Then
    If fstat = 4 Then
      Commit
    Else
      #Erreur lors de l'enregistrement des consommations.
      GMESSAGE = mess(186,182,1)
      GERR = 1
      Rollback
    Endif
  Else
    Commit
  Endif
  #On récrée
  Call DEBTRANS From GLOCK
  Trbegin [HDT]
  nolign =  0
  For ITER = 0 To [M:SET2]NBLIG-1
    If [M:SET2]HDTITM(ITER) <> "" Then
      Raz [F:HDT]
      nolign += 1
      #Enregistrement de la clé
      If [M:SET2]HDTNUM(ITER) = "" Then
        #------------------------------------------------------------#
        # --> Calcul du code compteur                                #
        #------------------------------------------------------------#
        Call CPTHDTKEY([M:SET0]SALFCY, [F:HDT]HDTNUM, IERR) From SUBSREB1
        If IERR Then
          #Erreur lors de l'enregistrement des travaux.
          GMESSAGE = mess(186,182,1)
          GERR = 1
          Rollback
          Break
        Endif
        [M:SET2]HDTNUM(ITER) = [F:HDT]HDTNUM
      Else
        [F:HDT]HDTNUM = [M:SET2]HDTNUM(ITER)
      Endif
      #Transclass
      [F:HDT] = [M:SET2]
      [F:HDT]SRENUM = SZSETNUM
      [F:HDT]TPL = 2
      Write [HDT]
      If fstat Then
        #Erreur lors de l'enregistrement des travaux.
        GMESSAGE = mess(186,182,1)
        GERR = 1
        Rollback
        Break
      Endif
    Endif
  Next
  If GERR Then
    End
  Else
    Commit
  Endif
End

##########################################################################################################
# Calcul un code séquence temporaire pour la création d'un modèle de demande de service
################################################################
Subprog SETSEQNUM(SZSEQNUM)
Variable Char SZSEQNUM

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # Récupération du compteur de séquence
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK1", [M:SET0]SALFCY, GSR2CSETCPT, date$, "", SZSEQNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 0 Then
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
    Endif
  Endif
End

##########################################################################################################
# Chargement du parc concerné
#####################################################################
Subprog LOADMAC(SZSETNUM)
Value Char SZSETNUM

Local Integer ILINDEB

  ILINDEB = 0
  Raz [M:SET4]NBMAC
  Raz [M:SET4]NBMACSEL
  Raz [M:SET4]ITMREF
  Raz [M:SET4]ITMDES
  Filter [SEM] Where [F:SEM]SETNUM = SZSETNUM Order By [F:SEM]ITMREF Asc
  nolign = 0
  For [SEM]
    If ILINDEB >= dim([M:SET4]ITMREF) Then
      Break
    Endif
    #Transclass
    nolign += 1
    [M:SET4] = [F:SEM]
    If ILINDEB = 0 Then
      [M:SET4]NBMACSEL(ILINDEB) = "->"
    Else
      [M:SET4]NBMACSEL(ILINDEB) = ""
    Endif
    [M:SET4]ITMREF(ILINDEB) = [F:SEM]ITMREF
    #Call LECTEXTRA([M:SET4]ITMDES(ILINDEB), "ITMMASTER", "DES1AXX", [M:SET4]ITMREF(ILINDEB), "") From ATEXTRA
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:SET4]ITMREF(ILINDEB),[M:SET4]ITMDES(ILINDEB), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
    ILINDEB += 1
  Next
  Filter [SEM]
  [M:SET4]NBMAC = ILINDEB
End

##########################################################################################################
# Enregistrement du parc concerné
#####################################################################
Subprog SAVEMAC(SZSETNUM)
Value Char SZSETNUM

Local Integer ITER

  If SZSETNUM = "" Then
    End
  Endif

  Call DEBTRANS From GLOCK
  Trbegin [SEM]
  nolign =  0
  #Enregistre le tableau du parc concerné
  For ITER = 0 To [M:SET4]NBMAC-1
    If [M:SET4]ITMREF(ITER) <> "" Then
      nolign += 1
      Read [SEM]SEM0=SZSETNUM;[M:SET4]ITMREF(ITER)
      If fstat = 5 Then
        #Enregistrement non trouvé il faut le créer
        #Transclass
        [F:SEM] = [M:SET4]
        [F:SEM]SETNUM = SZSETNUM
        [F:SEM]ITMREF = [M:SET4]ITMREF(ITER)
        [F:SEM]CREDAT = date$
        [F:SEM]CREUSR = GUSER
        Write [SEM]
        If fstat Then
          #Erreur lors de l'enregistrement du parc listé.
          GMESSAGE = mess(245,182,1)
          GERR = 1
          Rollback
          Break
        Endif
      Elsif fstat = 0 Then
        #Enregistrement trouvé il faut le mettre à jour
        #Transclass
        [F:SEM] = [M:SET4]
        [F:SEM]SETNUM = SZSETNUM
        [F:SEM]ITMREF = [M:SET4]ITMREF(ITER)
        [F:SEM]CREDAT = date$
        [F:SEM]CREUSR = GUSER
        Rewrite [SEM]
        If fstat Then
          #Erreur lors de l'enregistrement du parc listé.
          GMESSAGE = mess(245,182,1)
          GERR = 1
          Rollback
          Break
        Endif
      Endif
    Endif
  Next
  If GERR Then
    End
  Else
    Commit
  Endif
End

##########################################################################################################
# Chargement des composants
#####################################################################
Subprog LOADCPN(SZSETNUM, SZITMREF, ITPYFLG)
Value Char SZSETNUM
Value Char SZITMREF
Value Integer ITPYFLG

  If SZITMREF = "" Then
    End
  Endif

Local Integer ILINCPN

  ILINCPN = 0
  Raz [M:SET4]NBCPN
  Raz [M:SET4]CPNITM
  Raz [M:SET4]CPNITMDES
  Raz [M:SET4]CPNQTY
  Raz [M:SET4]CPNSEQ
  Filter [SEN] Where [F:SEN]SETNUM = SZSETNUM and [F:SEN]ITMREF = SZITMREF and [F:SEN]TPYFLG = ITPYFLG Order By [F:SEN]CPNITM Asc
  For [SEN]
    If ILINCPN >= dim([M:SET4]CPNITM) Then
      Break
    Endif
    [M:SET4]CPNITM(ILINCPN) = [F:SEN]CPNITM
    #Call LECTEXTRA([M:SET4]CPNITMDES(ILINCPN), "ITMMASTER", "DES1AXX", [M:SET4]CPNITM(ILINCPN), "") From ATEXTRA
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:SET4]CPNITM(ILINCPN),[M:SET4]CPNITMDES(ILINCPN), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
    [M:SET4]CPNSEQ(ILINCPN) = [F:SEN]CPNSEQ
    [M:SET4]CPNQTY(ILINCPN) = [F:SEN]CPNQTY
    ILINCPN += 1
  Next
  Filter [SEN]
  [M:SET4]NBCPN = ILINCPN
End

##########################################################################################################
# Enregistrement des composants
#####################################################################
Subprog SAVECPN(SZSETNUM, SZITMREF, ITPYFLG)
Value Char SZSETNUM
Value Char SZITMREF
Value Integer ITPYFLG

Local Integer ITER

  #On efface tout
  Call DEBTRANS From GLOCK
  Trbegin [SEN]
  Delete [SEN] Where [F:SEN]SETNUM = SZSETNUM and [F:SEN]ITMREF = SZITMREF and [F:SEN]TPYFLG = ITPYFLG
  If fstat Then
    If fstat = 4 Then
      Commit
    Else
      #Erreur lors de l'enregistrement des composants du parc concerné.
      GMESSAGE = mess(181,182,1)
      GERR = 1
      Rollback
      End
    Endif
  Else
    Commit
  Endif
  #On récrée
  Call DEBTRANS From GLOCK
  Trbegin [SEN]
  For ITER = 0 To [M:SET4]NBCPN-1
    If [M:SET4]CPNITM <> "" Then
      [F:SEN]SETNUM = SZSETNUM
      [F:SEN]ITMREF = SZITMREF
      [F:SEN]TPYFLG = ITPYFLG
      [F:SEN]CPNITM = [M:SET4]CPNITM(ITER)
      [F:SEN]CPNSEQ = [M:SET4]CPNSEQ(ITER)
      [F:SEN]CPNQTY = [M:SET4]CPNQTY(ITER)
      [F:SEN]CREDAT = date$
      [F:SEN]CREUSR = GUSER
      Write [SEN]
      If fstat Then
        #Erreur lors de l'enregistrement des composants du parc concerné.
        GMESSAGE = mess(181,182,1)
        GERR = 1
        Rollback
        Break
      Endif
    Endif
  Next
  If GERR Then
    End
  Else
    Commit
  Endif
End

##########################################################################################################
# Enregistrement d'une ligne de composant concerné
#####################################################################
Subprog SAVECPNLIN(SZSETNUM, SZITMREF, SZCPNNUM, ITPYFLG, INOL)
Value Char SZSETNUM
Value Char SZITMREF
Value Char SZCPNNUM
Value Integer ITPYFLG
Value Integer INOL

  #On efface tout
  Call DEBTRANS From GLOCK
  Trbegin [SEN]
  Delete [SEN] Where [F:SEN]SETNUM = SZSETNUM and [F:SEN]ITMREF = SZITMREF and [F:SEN]CPNITM = SZCPNNUM and [F:SEN]TPYFLG = ITPYFLG
  If fstat Then
    If fstat = 4 Then
      Commit
    Else
      #Erreur lors de l'enregistrement des composants du parc concerné.
      GMESSAGE = mess(181,182,1)
      GERR = 1
      Rollback
      End
    Endif
  Else
    Commit
  Endif
  #On récrée
  If [M:SET4]CPNITM(INOL) <> "" Then
    Call DEBTRANS From GLOCK
    Trbegin [SEN]
    [F:SEN]SETNUM = SZSETNUM
    [F:SEN]ITMREF = SZITMREF
    [F:SEN]TPYFLG = ITPYFLG
    [F:SEN]CPNITM = SZCPNNUM
    [F:SEN]CPNSEQ = [M:SET4]CPNSEQ(INOL)
    [F:SEN]CPNQTY = [M:SET4]CPNQTY(INOL)
    [F:SEN]CREDAT = date$
    [F:SEN]CREUSR = GUSER
    Write [SEN]
    If fstat Then
      #Erreur lors de l'enregistrement des composants du parc concerné.
      GMESSAGE = mess(181,182,1)
      GERR = 1
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
# Enregistrement des composants suite à la transaction de création de la demande
#####################################################################
Subprog SAVECPNWKEY(SZSEQNUM, SZSETNUM)
Value Char SZSEQNUM
Value Char SZSETNUM

  #On récrée sur la base de l'ancien numéro de séquence
  Local File SETMACCPN [SEN2]
  Call DEBTRANS From GLOCK
  Trbegin [SEN]
  Filter [SEN2] Where [F:SEN2]SETNUM = SZSEQNUM and [F:SEN2]TPYFLG = 1 Order By [F:SEN2]ITMREF Asc; [F:SEN2]CPNITM Asc
  For [SEN2]
    [F:SEN] = [F:SEN2]
    [F:SEN]SETNUM = SZSETNUM
    [F:SEN]TPYFLG = 0
    [F:SEN]CREDAT = date$
    [F:SEN]CREUSR = GUSER
    Write [SEN]
    If fstat Then
      #Erreur lors de l'enregistrement des composants du parc concerné.
      GMESSAGE = mess(181,182,1)
      GERR = 1
      Rollback
      Break
    Endif
  Next
  If GERR Then
    Close Local File [SEN2]
    End
  Else
    Commit
  Endif
  #On efface tout
  Call DEBTRANS From GLOCK
  Trbegin [SEN2]
  Delete [SEN2] Where [F:SEN2]SETNUM = SZSEQNUM and [F:SEN2]TPYFLG = 1
  If fstat Then
    If fstat = 4 Then
      Commit
    Else
      #Erreur lors de l'enregistrement des composants du parc concerné.
      GMESSAGE = mess(181,182,1)
      GERR = 1
      Rollback
    Endif
  Else
    Commit
  Endif
  Close Local File [SEN2]
End

##########################################################################################################
# Suppression du parc concerné
#####################################################################
Subprog RAZMAC

  Raz [M:SET4]NBMAC
  Raz [M:SET4]NBMACSEL
  Raz [M:SET4]ITMREF
  Raz [M:SET4]ITMDES
  Raz [M:SET4]NBCPN
  Raz [M:SET4]CPNITM
  Raz [M:SET4]CPNITMDES
  Raz [M:SET4]CPNQTY
  Raz [M:SET4]CPNSEQ
  Call DEBTRANS From GLOCK
  Trbegin [SEM], [SEN]
  If GREP = "C" Then
    Delete [SEM] Where [F:SEM]SETNUM = [M:SET0]CRESEQ
    If fstat Then
      If fstat <> 4 Then
        Rollback
        Affzo [M:SET4]1-99
        End
      Endif
    Endif
    Delete [SEN] Where [F:SEN]SETNUM = [M:SET0]CRESEQ and [F:SEN]TPYFLG = 1
    If fstat Then
      If fstat <> 4 Then
        Rollback
        Affzo [M:SET4]1-99
        End
      Endif
    Endif
  Elsif GREP = "D" Then
    Delete [SEM] Where [F:SEM]SETNUM = [M:SET0]CRESEQ
    If fstat Then
      If fstat <> 4 Then
        Rollback
        Affzo [M:SET4]1-99
        End
      Endif
    Endif
    Delete [SEN] Where [F:SEN]SETNUM = [M:SET0]CRESEQ and [F:SEN]TPYFLG = 1
    If fstat Then
      If fstat <> 4 Then
        Rollback
        Affzo [M:SET4]1-99
        End
      Endif
    Endif
  Else
    Delete [SEM] Where [F:SEM]SETNUM = [M:SET0]SETNUM
    If fstat Then
      If fstat <> 4 Then
        Rollback
        Affzo [M:SET4]1-99
        End
      Endif
    Endif
    Delete [SEN] Where [F:SEN]SETNUM = [M:SET0]SETNUM and [F:SEN]TPYFLG = 1
    If fstat Then
      If fstat <> 4 Then
        Rollback
        Affzo [M:SET4]1-99
        End
      Endif
    Endif
  Endif
  Commit
End

##########################################################################################################
# Duplication des composants concernés
#####################################################################
Subprog DUPLICPN(SZSETNUM, SZCRESEQ)
Value Char SZSETNUM
Value Char SZCRESEQ

  Local File SETMACCPN [SEN2]
  Call DEBTRANS From GLOCK
  Trbegin [SEN]
  Filter [SEN2] Where [F:SEN2]SETNUM = SZSETNUM and [F:SEN2]TPYFLG = 0
  For [SEN2]
    [F:SEN] = [F:SEN2]
    [F:SEN]SETNUM = SZCRESEQ
    [F:SEN]TPYFLG = 1
    [F:SEN]CREDAT = date$
    [F:SEN]CREUSR = GUSER
    Write [SEN]
    If fstat Then
      #Erreur lors de l'enregistrement des composants du parc concerné.
      GMESSAGE = mess(181,182,1)
      GERR = 1
      Rollback
      Break
    Endif
  Next
  Filter [SEN2]
  Close Local File [SEN2]
  If GERR Then
    End
  Else
    Commit
  Endif
End

##########################################################################################################
#Affichage des icônes
######################################################
$DISPICON
Local Char SZDESCTL(250)

  Gosub DEFICONNUM From CRMUTIL150
  #Synthèse
  Raz SZDESCTL
  Setlob SZDESCTL With [M:SET1]FULDES
  If SZDESCTL = "" Then
    [M:SET1]DESICO = ""
    [M:SET1]DES = ""
  Else
    If len(SZDESCTL) > 235 Then
      If [M:SET1]DESFLG Then
        [M:SET1]DESICO = SZICOSYNDON
      Else
        [M:SET1]DESICO = SZICOSYN
        [M:SET1]DES = SZDESCTL
      Endif
    Else    
      [M:SET1]DES = SZDESCTL
      [M:SET1]DESICO = ""    
    Endif
  Endif
Return

##########################################################################################################
#Enregistrement du CLOB description complète
######################################################
$SAVEHD1
  Gosub DELHD1
  If GOK < 1 Then
    Return
  Endif

Local Char SZCTLCLOB(250)

  Raz SZCTLCLOB
  Setlob SZCTLCLOB With [M:SET1]FULDES
  If SZCTLCLOB = "" Then
    Return
  Endif
  Raz [F:HD1]
  [F:HD1]NUM = [M:SET1]NUMFULDES
  [F:HD1]TYP = [M:SET1]TYPFULDES
  [F:HD1]CLOB = [M:SET1]FULDES
  Write [HD1]
  If fstat Then
    #Erreur lors de l'enregistrement de la description complète du modèle de demande. Transaction abandonnée.
    GMESSAGE = mess(856,182,1)
    GERR = 1
    Call FSTA("HD1") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
#Suppression du CLOB description complète
######################################################
$DELHD1
  Delete [HD1] Where [F:HD1]NUM = [M:SET1]NUMFULDES and [F:HD1]TYP = [M:SET1]TYPFULDES
  If fstat Then
    #Erreur lors de la suppression de la description complète du modèle de demande. Transaction abandonnée.
    GMESSAGE = mess(857,182,1)
    GERR = 1
    Call FSTA("HD1") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB description complète
######################################################
$LOADHD1
  If [M:SET1]NUMFULDES = "" Then
    Raz [M:SET1]FULDES
    Return
  Endif
  If [M:SET1]TYPFULDES = "" Then
    Raz [M:SET1]FULDES
    Return
  Endif
  Read [HD1]HD10=[M:SET1]NUMFULDES;[M:SET1]TYPFULDES
  If fstat Then
    Raz [M:SET1]FULDES
  Else
    [M:SET1]FULDES = [F:HD1]CLOB
  Endif
Return

##########################################################################################################
# Ajoute l'article concerné par défaut sur une ligne de consommation
#####################################################
$ADDHDTITM
  If [M:SET4]NBMAC <= 0 Then
    Return
  Endif
  If [M:SET4]NBMAC >= 1 Then
    [M:SET2]HDTMACSET(nolign-1) = [M:SET4]ITMREF(0)
    If [M:SET4]NBCPN >= 1 Then
      [M:SET2]HDTCPN(nolign-1) = [M:SET4]CPNITM(0)
    Endif
  Endif
Return
