#<AdxTL>@(#)7.0.0.0 $Revision$

End

########################################################################
#  SIXCCE : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog SIXCCE                                                        #
#     Création des Axes et Sections Analytiques                         #
#                                                                       #
#                                                                       #
#########################################################################
# Supp...
If !clalev([F:CCE])  : Local File CACCE      [CCE]  : Endif   # Sections analytiques
If !clalev([F:XCAN]) : Local File XICNTANA   [XCAN] : Endif   # Centres analytiques
If !clalev([F:XPAN]) : Local File XIPLACBANA [XPAN] : Endif   # Sections analytiques

Trbegin [CCE], [XCAN], [XPAN]
 Delete [CCE] Where 1=1
 Update [XCAN] Where 1=1 With FLGREP=1
 Update [XPAN] Where 1=1 With FLGREP=1
Commit 
# Fin Supp
End

Gosub SI_CONTEXT From SIXFONCTION
Global Integer X_NB
Call OUVRE_BOITE("XIPLACBANA",nbrecord([XCAN])+nbrecord([XPAN])) From GESECRAN
Raz X_NB
Call EXEC
Call FERME_BOITE From GESECRAN
Kill X_NB

End

#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE
If GTRACE = ""
 Call OUVRE_TRACE("SIXCCE : Process translation file from INTEGRALE to X3") From LECFIC
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#---- Création enregistrement CACCE ------#
Call ECR_TIME("SIXCCE : "+SI_MES(74)+" CACCE") From DOSSUB
#---- Création axes analytiques X3... Déplacé sous SIXCPY pour la V6
#Call SI_AXI
#If GOK<>1 : Goto FIN_CCE : Endif
#---- Création sections analytiques X3 à partir des Centres analytiques de l'Intégrale
Call SI_CACCE1
If GOK<>1 : Goto FIN_CCE : Endif
#---- Création sections analytiques X3 à partir des Sections analytiques de l'Intégrale
Call SI_CACCE2
If GOK<>1 : Goto FIN_CCE : Endif
#---- Création des croisements d'axes.
#Call SI_BPX
#If GOK<>1 : Goto FIN_CCE : Endif

#--- Création des Axes par défaut
Call SI_CADIEDEF
If GOK<>1 : Goto FIN_CCE : Endif
#--- Création Sections par défaut
Call SI_CACCEDEF
If GOK<>1 : Goto FIN_CCE : Endif


$FIN_CCE
Onerrgo 
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE(errp-"("-num$(errl)-") :"-errmes$(errn)-errm, 1) From GESECRAN
Resume


#########################################################################
# Création des axes analytiques
#########################################################################
$SI_AXI

Local Char    LANMES0(99), FMTAXE(10)
Local Integer I, NUMAXE, NBAXE, SVGANA

## Tables Intégrale
If !clalev([F:XSO2]) : Local File =SI_DOSSIER+".XISOCDIV2"  [XSO2] : Endif   # Paramètres société

## Tables X3
If !clalev([F:DIE])  : Local File =SI_DOSSIER+".GDIE"      [DIE]  : Endif   # Axes
If !clalev([F:AXX])  : Local File =SI_DOSSIER+".ATEXTRA"   [AXX]  : Endif   # Textes traduisibles

 Call NBAXE(NBAXE)
 For NUMAXE=1 To NBAXE
  Delete [DIE] Where   [F:DIE]DIE = "AX"+num$(NUMAXE)
  If fstat
   Call ERREUR("GDIE"-[F:DIE]DIE,3) From DOSDIC
   GOK=0 : Return
  Endif
 Next

 For NUMAXE=1 To NBAXE
  # Traitement des axes analytiques
  Raz [F:DIE] 
  [F:DIE]DIE  = "AX"+num$(NUMAXE)
  #[F:DIE]DES    = [F:DIE]DIE
  #[F:DIE]DESSHO = [F:DIE]DIE
  # F59072
  If NUMAXE<NBAXE
   [F:DIE]DES    = evalue("[F:XSO2]LIBAXE"+num$(NUMAXE))
   [F:DIE]DESSHO = [F:DIE]DES
  Else
   [F:DIE]DES    = "Autres"
   [F:DIE]DESSHO = "Autres"
  Endif
  Call MAJTEXTRA([F:DIE]DES,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
  Call MAJTEXTRA([F:DIE]DES,"GDIE","SHOTRA",[F:DIE]DIE,"") From ATEXTRA
  Call MAJTEXTRA([F:DIE]DES,"GDIE","COLHEA",[F:DIE]DIE,"") From ATEXTRA

  FMTAXE = "15c"
  [F:DIE]CCEFMT = FMTAXE

  [F:DIE]CREAUT = 2
  [F:DIE]PRJMGT = 2

  [F:DIE]CREUSR = GUSER
  [F:DIE]CREDAT = date$
  [F:DIE]UPDUSR = GUSER
  [F:DIE]UPDDAT = date$

  Write [DIE]
  If fstat
   Call ERREUR("GDIE"-[F:DIE]DIE,1) From DOSDIC
   GOK = 0 : Return
  Endif

 Next 

Return

Subprog NBAXE(NBAXE)
Variable Integer NBAXE
If !clalev([F:XSO2]) : Local File =SI_DOSSIER+".XISOCDIV2"  [XSO2] : Endif   # Paramètres société
Local Integer I
NBAXE = 0
Read [XSO2]IND0 First
If !fstat
 For I=1 To 13
  If evalue("[F:XSO2]LGRAXE"+num$(I))<>0
   NBAXE += 1
  Endif
 Next
Endif 
## on rajoute un axe supplémentaire pour les sections analytiques définies dans l'Intégrale qui ne
## correspondent pas à des centres analytiques (à voir ensuite pour rajouter cet axe uniquement s'il y a
## dans le dossier des sections ne correspondant pas à des centres ana)
NBAXE += 1
End


######################################################################################
## Création des sections analytiques à partir des centres analytiques de l'Intégrale
## (Table XICNTANA (CNT_ANA)) 
######################################################################################
Subprog SI_CACCE1

Local Char    LREPRISE(50), LRERISE2(50)
Local Char    ABRFIC(5)
Local Integer STOP, NB, NUMDIE

## Tables Intégrale
If !clalev([F:XCAN]) : Local File =SI_DOSSIER+".XICNTANA"   [XCAN] : Endif   # Centres analytiques

## Tables X3
If !clalev([F:CCE])  : Local File =SI_DOSSIER+".CACCE"      [CCE]  : Endif   # Sections analytiques

SI_SUBPRG = "SIXCCE"
SI_TABLE  = "XICNTANA"
Gosub SI_CRITSUP From SIXFONCTION

$LOOP_CCE_ANA1
Raz NB

If STOP=1
 CRITERE = "((NUMAXE='"+LREPRISE2+"' & ELEANA>'"+LREPRISE+"') or NUMAXE>'"+LREPRISE2+"')"
 STOP=0
Else
 CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Trbegin [CCE] 
 
## Traitement des sections analytiques à partir des centres analytiques de l'Intégrale (table XICNTANA)
## Dans X3, on peut définir jusqu'à 9 axes. Le dernier va servir à mettre les sections ana
## ne correspondant pas à la concaténation de centres analytiques. Donc on ne reprendra
## qu'au max que les sections des 8 premiers axe des l'Intégrale
## (théoriquement, on ne devrait pas avoir de dossier Intégrale avec + de 8 axes : cela 
## signifierait que la dimension des sections ana d'au moins 4 axes fasse 1 caractère !!!) 
## que les en
ABRFIC = "XCAN"
For [XCAN] Where left$(ELEANA,2)<>"$$" & FLGREP<>2 & NUMAXE<"9"
&             & evalue(CRITERE)
&             & evalue(SI_CRITERE)
  
 GOK = 1
 Call AFFBOITE([F:XCAN]ELEANA) From SUBSIM

 # creation section (CACCE)
 Gosub CRE_CCE_ANA
 If GOK>0 & SI_SIMU<>2
  Readlock [XCAN] Curr
  [F:XCAN]FLGREP = 2
  Rewrite [F:XCAN]
 Endif

 If GOK<1 & SI_SIMU <> 2
  Break
 Endif

 # NB alimenté dans CRE_CCE
 If NB>1000
  LREPRISE  = [F:XCAN]ELEANA
  LREPRISE2 = [F:XCAN]NUMAXE
  STOP     = 1
  Break
 Endif
Next

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
 If STOP
  Goto LOOP_CCE_ANA1
 Endif
Else
 Rollback
Endif
End


################################################################################################
## Création des sections analytiques à partir des sections analytiques de l'Intégrale
## Les sections analytiques de la table Intégrale XIPLACBANA (PLA_CTB_ANA) qui ne correspondent
## pas à la concaténation de centres analytiques traités ci-dessus, seront créées dans
## X3 sur l'axe supplémentaire rajouté à cet effet 
#################################################################################################
Subprog SI_CACCE2

Local Char    LREPRISE(50)
Local Char    ABRFIC(5)
Local Char    CENTRE_ANA(13)
Local Char    TABAXI(10)(1..13) : # Tableau des n°axes analytiques définis dans l'Intégrale
Local Integer STOP, NB
Local Integer I, NBAXE, NUMAXE, NUMDIE
Local Integer OK_CONCAT      : # Indicateur 1:la section correspond à la concaténation de centres ana
Local Integer TLNGAXI(1..13) : # Tableau des longueurs des axes analytiques définis dans l'Intégrale
Local Integer TOTLNG

## Tables Intégrale
If !clalev([F:XPAN]) : Local File =SI_DOSSIER+".XIPLACBANA" [XPAN] : Endif   # Sections analytiques
If !clalev([F:XCAN]) : Local File =SI_DOSSIER+".XICNTANA"   [XCAN] : Endif   # Centres analytiques
If !clalev([F:XSO2]) : Local File =SI_DOSSIER+".XISOCDIV2"  [XSO2] : Endif   # Paramètres société

## Tables X3
If !clalev([F:CCE])  : Local File =SI_DOSSIER+".CACCE"      [CCE]  : Endif   # Sections analytiques

SI_SUBPRG = "SIXCCE"
SI_TABLE  = "XIPLACBANA"
Gosub SI_CRITSUP From SIXFONCTION

Read [XSO2]IND0 First
If !fstat
 For I=1 To 13 : # Maximum 13 axes...
  If evalue("[F:XSO2]LGRAXE"+num$(I))<>0
   NBAXE += 1
   TLNGAXI(NBAXE) = evalue("[F:XSO2]LGRAXE"+num$(I))
  Endif
 Next
Endif 

Raz TABAXI : I = 0
For [XCAN]IND0(1)
 I += 1
 TABAXI(I) = [F:XCAN]NUMAXE
Next

$LOOP_CCE_ANA2
Raz NB

If STOP=1
 CRITERE = "SECANA>'"+LREPRISE+"'"
 STOP=0
Else
 CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Trbegin [CCE] 

ABRFIC = "XPAN"

For [XPAN] Where left$(SECANA,2)<>"$$" & FLGREP<>2
&             & evalue(CRITERE)
&             & evalue(SI_CRITERE)
  
 GOK = 1
 Call AFFBOITE([F:XPAN]SECANA) From SUBSIM

 OK_CONCAT = 0 : TOTLNG = 0
 For NUMAXE=1 To NBAXE
  If NUMAXE = 1
   CENTRE_ANA = vireblc(mid$([F:XPAN]SECANA,1,TLNGAXI(NUMAXE)),1)
   TOTLNG += TLNGAXI(NUMAXE)
  Else
   CENTRE_ANA = vireblc(mid$([F:XPAN]SECANA,TOTLNG+1,TLNGAXI(NUMAXE)),1)
   TOTLNG += TLNGAXI(NUMAXE)
  Endif
  Read [XCAN]IND0 = TABAXI(NUMAXE) ; CENTRE_ANA
  If !fstat
   OK_CONCAT = 1
  Else
   OK_CONCAT = 0 : Break    
  Endif
 Next  

 If !OK_CONCAT
  ## creation section (CACCE). Les sections de l'Intégrale qui ne correspondent pas à la concaténation
  ## de centres analytiques seront isolées dans un axe à part rajouté à cet effet 
  Gosub CRE_CCE_ANA
  If GOK>0 & SI_SIMU<>2
   Readlock [XPAN] Curr
   [F:XPAN]FLGREP = 2
   Rewrite [F:XPAN]
  Endif

  If GOK<1 & SI_SIMU <> 2
   Break
  Endif
 Endif

 # NB alimenté dans CRE_CCE
 If NB>1000
  LREPRISE = [F:XPAN]SECANA
  STOP     = 1
  Break
 Endif
Next

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
 If STOP
  Goto LOOP_CCE_ANA2
 Endif
Else
 Rollback
Endif

End

##################################################################
$CRE_CCE_ANA
Raz [F:CCE]

# recupération et contrôle code section analytique
If ABRFIC = "XCAN"
 If !func SIXFONCTION.SI_CTL("CCE",[F:XCAN]X3CLE,"XICNTANA("+[F:XCAN]ELEANA+")")
  GOK=0 : Return
 Else
  NUMDIE = val([F:XCAN]NUMAXE)
  [F:CCE]DIE    = "AX"+num$(NUMDIE)
  [F:CCE]CCE    = [F:XCAN]X3CLE
 Endif
Elsif ABRFIC = "XPAN"
 If !func SIXFONCTION.SI_CTL("CCE",[F:XPAN]X3CLE,"XIPLACBANA("+[F:XPAN]SECANA+")")
  GOK=0 : Return
 Else
  ## Les sections de l'Intégrale qui ne correspondent pas à la concaténation
  ## de centres analytiques seront isolées dans un axe à part rajouté à cet effet (d'où l'initialisation
  ## de [F:CCE]DIE par NBAXE+1...) 
  [F:CCE]DIE    = "AX"+num$(NBAXE+1)
  [F:CCE]CCE    = [F:XPAN]X3CLE
 Endif
Endif

# Intitulé de la section analytique
#-------------------------------------------------
[F:CCE]DESSHO = evalue("[F:"+ABRFIC+"]LIBAPL")
If ABRFIC = "XCAN"
 [F:CCE]DES    = [F:XCAN]ITT1
Elsif ABRFIC = "XPAN"
 [F:CCE]DES    = [F:XPAN]NOMSEC
Endif
Call MAJTEXTRA([F:CCE]DES,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
Call MAJTEXTRA([F:CCE]DESSHO,"CACCE","SHOTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA

# Flags
#-------------------------------------------------
## Flag 'Remise à zéro' : # <PP à contrôler>
## Dans l'Intégrale, les soldes des sections Chantier ouvertes sont reportées de l'exercice clos vers
## l'exercice en cours, en "A-nouveaux" par report analytique
If ABRFIC = "XCAN"
 If [F:XCAN]TYPELE = "C" : # C = Chantier 
  [F:CCE]FRW = 2
 Else : # P = Permanent
  [F:CCE]FRW = 1 
 Endif
Elsif ABRFIC = "XPAN"
 If [F:XPAN]TYPSEC = "C" : # C = Chantier 
  [F:CCE]FRW = 2
 Else : # P = Permanent
  [F:CCE]FRW = 1 
 Endif
Endif
[F:CCE]ENAFLG = 2
[F:CCE]BUDTRK = 2
[F:CCE]IPT = 2

# Dates et utilisateurs
#-------------------------------------------------
[F:CCE]CREDAT  = evalue("[F:"+ABRFIC+"]DATCRE")  # date création    
If [F:CCE]CREDAT   = [0/0/0]
 [F:CCE]CREDAT = date$
 [F:CCE]CREUSR = GUSER              
Endif
[F:CCE]UPDDAT = date$             # date modification
[F:CCE]UPDUSR = GUSER             # operateur modification


SI_TABLE = "CACCE"
Gosub SI_BEFWRI From SIXFONCTION

Write [CCE]
If fstat
 If ABRFIC = "XCAN"
  # Section XXX axe YYY  : Erreur d'écriture 
  Call ECR_TRACE(mess(48,105,1)-[F:CCE]CCE-mess(2,103,1)-[F:CCE]DIE-"("+[F:XCAN]X3CLE+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0 : Return
 Elsif ABRFIC = "XPAN"
  # Section XXX axe YYY  : Erreur d'écriture 
  Call ECR_TRACE(mess(48,105,1)-[F:CCE]CCE-mess(2,103,1)-[F:CCE]DIE-"("+[F:XPAN]X3CLE+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0 : Return
 Endif
Else
 NB+=1
Endif
Return

########################################################################################
#  Initialisation XIPLACBANA... appelé lors de Importation des Tables Intégrale
########################################################################################
$INI_X3CAT1

Local Integer NUMAXE, NBAXE
Local Integer OK_CONCAT      : # Indicateur 1:la section correspond à la concaténation de centres ana
Local Char    TABAXI(10)(1..13) : # Tableau des n°axes analytiques définis dans l'Intégrale
Local Integer TOTLNG
Local Char    CENTRE_ANA(13)
Local Integer TLNGAXI(1..13) : # Tableau des longueurs des axes analytiques définis dans l'Intégrale

If !clalev([F:XPAN]) : Local File =SI_DOSSIER+".XIPLACBANA" [XPAN] : Endif   # Sections analytiques
If !clalev([F:XCAN]) : Local File =SI_DOSSIER+".XICNTANA"   [XCAN] : Endif   # Centres analytiques

If !clalev([F:XSO2]) : Local File =SI_DOSSIER+".XISOCDIV2"  [XSO2] : Endif   # Paramètres société

Read [XSO2]IND0 First
If !fstat
 For I=1 To 13 : # Maximum 13 axes...
  If evalue("[F:XSO2]LGRAXE"+num$(I))<>0
   NBAXE += 1
   TLNGAXI(NBAXE) = evalue("[F:XSO2]LGRAXE"+num$(I))
  Endif
 Next
Endif 

Raz TABAXI : I = 0
For [XCAN]IND0(1)
 I += 1
 TABAXI(I) = [F:XCAN]NUMAXE
Next

Call DEBTRANS From GLOCK
Trbegin [XPAN] 

For [XPAN] 

 GOK = 1

 OK_CONCAT = 0 : TOTLNG = 0
 For NUMAXE=1 To NBAXE
  If NUMAXE = 1
   CENTRE_ANA = vireblc(mid$([F:XPAN]SECANA,1,TLNGAXI(NUMAXE)),1)
   TOTLNG += TLNGAXI(NUMAXE)
  Else
   CENTRE_ANA = vireblc(mid$([F:XPAN]SECANA,TOTLNG+1,TLNGAXI(NUMAXE)),1)
   TOTLNG += TLNGAXI(NUMAXE)
  Endif
  Read [XCAN]IND0 = TABAXI(NUMAXE) ; CENTRE_ANA
  If !fstat
   OK_CONCAT = 1
  Else
   OK_CONCAT = 0 : Break    
  Endif
 Next  

 [F:XPAN]X3CAT = OK_CONCAT        # 1 : Axe et 0 : Section
 Rewrite [XPAN]
 If fstat
  Call ECR_TRACE("X3CAT "-[F:XPAN]SECANA-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0 : Break
 Endif

Next

If GOK>0
 Commit
Else
 Rollback
Endif
Return


########################################################################################
#  Initialisation XIHISANA... appelé lors de Importation des Tables Intégrale
########################################################################################
$INI_X3CAT2

If !clalev([F:XHSA]) : Local File =SI_DOSSIER+".XIHISANA" [XHSA] : Endif   # Historique Analytique

Call DEBTRANS From GLOCK
Trbegin [XHSA] 

Update [XHSA] Where left$([F:XHSA]LIBECR,21)<>"Reprise des soldes au" With X3CAT=1
If fstat
 # Erreur d'écriture
 Call ECR_TRACE("X3DAT XIHISANA"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0 : Rollback : Return
Endif

Commit
Return

########################################################################################
#  Initialisation XIBROCBANA... appelé lors de Importation des Tables Intégrale
########################################################################################
$INI_X3CAT3

If !clalev([F:XBCA]) : Local File =SI_DOSSIER+".XIBROCBANA" [XBCA] : Endif   # Brouillard Analytique

Call DEBTRANS From GLOCK
Trbegin [XBCA] 

Update [XBCA] Where left$([F:XBCA]LIBECR,21)<>"Reprise des soldes au" With X3CAT=1
If fstat
 # Erreur d'écriture
 Call ECR_TRACE("X3DAT XIBROCBANA"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0 : Rollback : Return
Endif

Commit
Return





#######################################################################################
#  Initialisation CADIEDEF : Axes par défaut
########################################################################################
Subprog SI_CADIEDEF
Local Integer NUMAXE, NBAXE, MODIF

## Tables X3
If !clalev([F:CDI])  : Local File =SI_DOSSIER+".CADIEDEF"      [CDI]  : Endif   # Axes par défaut

Call NBAXE(NBAXE)

Call DEBTRANS From GLOCK
Trbegin [CDI] 

For [CDI]CDI0
 
 MODIF = 0
 For NUMAXE=1 To NBAXE
  AXE = "AX"+num$(NUMAXE)
  If !find(AXE,[F:CDI]DIE(0..[F:CDI]NBRDIE-1))
   [F:CDI]DIE([F:CDI]NBRDIE) = AXE
   [F:CDI]NBRDIE+=1
   MODIF = 1
  Endif
 Next

 If MODIF
  Rewrite [CDI]
  If fstat
   # Erreur d'écriture
   Call ECR_TRACE("CADIEDEF"-mess([F:CDI]OBJ,2230,1)-":"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   GOK = 0 : Rollback : Break
  Endif
 Endif

Next
If !GOK : End : Endif
Commit
End

########################################################################################
#  Initialisation CACCEDEF :  Sections par défaut
########################################################################################
Subprog SI_CACCEDEF
Local Integer NUMAXE, NBAXE, IND, MODIF

## Tables X3
If !clalev([F:CDE])  : Local File =SI_DOSSIER+".CACCEDEF"      [CDE]  : Endif   # Sections par défaut
Call NBAXE(NBAXE)

Trbegin [CDE]
For [CDE]CDE0
 
 MODIF = 0
 For NUMAXE=1 To NBAXE
  AXE = "AX"+num$(NUMAXE)
  If !find(AXE,[F:CDE]DIE(0..[F:CDE]NBRDIE-1))
   [F:CDE]DIE([F:CDE]NBRDIE) = AXE
   [F:CDE]NBRDIE+=1  

   For IND=0 To dim([F:CDE]CCE1)-1
    If evalue("[F:CDE]CCE"+num$([F:CDE]NBRDIE)+"("+num$(IND)+")") = 0
     Assign "[F:CDE]CCE"+num$([F:CDE]NBRDIE)+"("+num$(IND)+")" With 22
    Endif
   Next

   MODIF = 1 
  Endif
 Next

 If MODIF
  Rewrite [CDE]
  If fstat
   # Erreur d'écriture
   Call ECR_TRACE("CACCEDEF"-[F:CDE]COD-":"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   GOK = 0 : Rollback : Break
  Endif
 Endif

Next
If !GOK : End : Endif
Commit
End





