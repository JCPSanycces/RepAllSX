#<AdxTL>@(#)0.0.0.0 $Revision$
##################################################################################
# DOSMAJ30 : Mises à jour à effectuer lors du passage à la version 6 (Release 30)
# moulinette avant la version 6
##################################################################################
# Issue 106947 - 20151105 by LD : Migration of historic folder

Subprog AMAJ
#-------------------------------------#
#         Avant mise à jour           #
#-------------------------------------#
Local Integer VERSION

Onerrgo ERREUR
VERSION = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ30 - AMAJ - VERSION = "-num$(VERSION),-1) From GESECRAN

#----- Rectification du dico Tronc commun
Call ECR_TRACE("************** ADICMAJ30 TRCMAJ30 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  Call ADICMAJ30 From TRCMAJ30 : # Moulinettes Tronc commun
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

#----- Rectification du dico Immobilisation
#Fq-XXXXX-mdjCall ECR_TRACE("************** AIMMMAJ30 IMMMAJ30 ***************",-1) From GESECRAN
If [F:ADS]MODULE(13)=2 and  VERSION >= 25
  Call ECR_TRACE("************** AIMMMAJ30 IMMMAJ30 ***************",-1) From GESECRAN
  Call AIMMMAJ30 From IMMMAJ30 : # Moulinettes Immos
Endif

#----- Rectification du dico Comptabilisation
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
 Call ECR_TRACE("************** ADICMAJ30 CPTMAJ30 ***************",-1) From GESECRAN
 If [F:ADS]MODULE(1)=2
  Call ADICMAJ30 From CPTMAJ30 : # Moulinettes Comptabilisation
  If VERSION<25 : Gosub GRUCPYE From CPTMAJ25 : Endif
 Endif
 Call ADICMAJ30_ANA From CPTMAJ30 : # Force le code activité ANA
Endif


#----- Rectification du dico Stock
Call ECR_TRACE("************** AMAJDIC30 STOMAJ30 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
   If [F:ADS]MODULE(6)=2
      Call AMAJDIC30 From STOMAJ30 : # Màj valeurs codes act MAT, MAC et LAB
   Endif
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

#------ Désactiver tout ce qui concerne la migration Intégrale en V6.0 ------ #
# 1/ Passage code activité SMI à Inactif
Call CHGSMI
# 2/ RAZ du code activité sur toutes tables commençant par XI et protégées par le code activité XXI. Par la
## suite le superviseur se charge de RAZ les tables commençant par X et non protégées par un code activité
Call ATBXI

#-----
# Rajout des types de données
# Rajout des codes activités
# Rajout des nouveaux champs V6
# Les index sont préservés
#-----

Call MAJDIC From SUPMAJ30
# Issue 108760 - 2015-06-12 by SR : adaptation
# Issue 106947 - 20150811 by LD : Migration of historic folder
# CPTANALIN table creation : only on a historic folder
## if CPTANALIN is a view and if one of the related tables is historized (so is  not a view)
#If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=1 & func DOSVUE.ISVIEW([F:ADS]DOSSIER,"CPTANALIN")=1
#&                                           & (func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SQUOTED")=0  | func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SORDERP")=0 |
#&                                              func DOSVUE.ISVIEW([F:ADS]DOSSIER,"PREQUISD")=0 | func DOSVUE.ISVIEW([F:ADS]DOSSIER,"PORDERP")=0)
# simplification : if CPTANALIN is a view and if one of the module that used it is present
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=1 & func DOSVUE.ISVIEW([F:ADS]DOSSIER,"CPTANALIN")=1
&                                           & sum([F:ADS]MODULE(4),[F:ADS]MODULE(5),[F:ADS]MODULE(6),[F:ADS]MODULE(7),[F:ADS]MODULE(11),[F:ADS]MODULE(12))>2
    Call CRE_HISTAB([F:ADS]DOSREF,[F:ADS]DOSSIER,[F:ADS]TYPDBA, "CPTANALIN") From CREHISTO
    Call ECR_TRACE(mess(59,123,1)-mess(56,123,1)-"CPTANALIN",-1) From GESECRAN
Endif
# SVCRFOOT table creation : only on a historic folder
## if SVCRFOOT is a view and if one of the related tables is historized (so is  not a view)
#If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=1 & func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SVCRFOOT")=1
#&                                           & (func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SQUOTE")=0    | func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SORDER")=0 |
#&                                              func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SDELIVERY")=0 | func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SINVOICEV")=0)
# simplification : if SVCRFOOT  is a view and if one of the module that used it is present
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=1 & func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SVCRFOOT")=1
&                                           & find([F:ADS]MODULE(4),2)
    Call CRE_HISTAB([F:ADS]DOSREF,[F:ADS]DOSSIER,[F:ADS]TYPDBA, "SVCRFOOT") From CREHISTO
    Call ECR_TRACE(mess(59,123,1)-mess(56,123,1)-"SVCRFOOT",-1) From GESECRAN
Endif
# SVCRVAT table creation : only on a historic folder
## if SVCRVAT is a view and if one of the related tables is historized (so is  not a view)
#If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=1 & func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SVCRVAT")=1
#&                                           & (func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SQUOTE")=0    | func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SORDER")=0 |
#&                                              func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SDELIVERY")=0 | func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SINVOICEV")=0)
# simplification : if SVCRVAT   is a view and if one of the module that used it is present
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=1 & func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SVCRVAT")=1
&                                           & find([F:ADS]MODULE(4),2)
    Call CRE_HISTAB([F:ADS]DOSREF,[F:ADS]DOSSIER,[F:ADS]TYPDBA, "SVCRVAT") From CREHISTO
    Call ECR_TRACE(mess(59,123,1)-mess(56,123,1)-"SVCRVAT",-1) From GESECRAN
Endif
# Issue 106947 - 20150811 by LD

# Issue 108760 - 2015-06-12 by SR : PVCRFOOT/PVCRVAT
# PVCRFOOT table creation : only on a historic folder
## if PVCRFOOT   is a view and if one of the module that used it is present
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=1 & func DOSVUE.ISVIEW([F:ADS]DOSSIER,"PVCRFOOT")=1
&                                           & find([F:ADS]MODULE(5),2)
    Call CRE_HISTAB([F:ADS]DOSREF,[F:ADS]DOSSIER,[F:ADS]TYPDBA, "PVCRFOOT") From CREHISTO
    Call ECR_TRACE(mess(59,123,1)-mess(56,123,1)-"PVCRFOOT",-1) From GESECRAN
Endif
# PVCRVAT table creation : only on a historic folder
## if PVCRVAT   is a view and if one of the module that used it is present
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=1 & func DOSVUE.ISVIEW([F:ADS]DOSSIER,"PVCRVAT")=1
&                                           & find([F:ADS]MODULE(5),2)
    Call CRE_HISTAB([F:ADS]DOSREF,[F:ADS]DOSSIER,[F:ADS]TYPDBA, "PVCRVAT") From CREHISTO
    Call ECR_TRACE(mess(59,123,1)-mess(56,123,1)-"PVCRVAT",-1) From GESECRAN
Endif
# End issue 108760

#----- Superviseur en premier

Call AMAJ   From SUPMAJ30      : # Moulinettes Superviseur

GVALIDE(2) = 1 : # Ecrans
GVALIDE(3) = 1 : # Objets
GVALIDE(4) = 1 : # Fenêtres et TRT générés superviseur
GVALIDE(5) = 1 : # Consultations

#----- Puis Tronc commun

Call ECR_TRACE("************** ATRCMAJ30 TRCMAJ30 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  Call ATRCMAJ30   From TRCMAJ30 : # Moulinettes Tronc commun
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

#----- Ensuite les autres modules

If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
 Call ECR_TRACE("************** ATRCMAJ30 CPTMAJ30 ***************",-1) From GESECRAN
 Call ATRCMAJ30 From CPTMAJ30 : # Moulinettes Compta - Commun # LOT CP5
 If [F:ADS]MODULE(1)=2
  Call ECR_TRACE("************** ACPTMAJ30 CPTMAJ30 ***************",-1) From GESECRAN
  Call ACPTMAJ30 From CPTMAJ30 : # Moulinettes Compta
  GVALTRANS(2)=2
 Endif
Endif

If [F:ADS]MODULE(2)=2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
 Call ECR_TRACE("************** ATRSMAJ30 CPTMAJ30 ***************",-1) From GESECRAN
 Call ATRSMAJ30 From CPTMAJ30 : # Moulinettes Tiers
 GVALTRANS(3)=2
Endif

Call ECR_TRACE("************** AVENMAJ30 VENMAJ30 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR
If [F:ADS]MODULE(4)=2
    Call AVENMAJ30 From VENMAJ30 : # Moulinettes Ventes
    GVALTRANS(5)=2               : # TRT générés Ventes (transactions, tarifs)
  Endif
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

Call ECR_TRACE("************** AACHMAJ30 ACHMAJ30 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If [F:ADS]MODULE(5)=2
    Call AACHMAJ30 From ACHMAJ30 : # Moulinettes Achats
    GVALTRANS(6)=2               : # TRT générés Achats (transactions, tarifs, signatures)
  Endif
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

Call ECR_TRACE("************** ASTOMAJ30 STOMAJ30 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If [F:ADS]MODULE(6)=2
    Call ASTOMAJ30 From STOMAJ30 : # Moulinettes Stock
    GVALTRANS(7)=2               : # TRT générés stocks (transactions)
  Endif
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

If [F:ADS]MODULE(7)=2
  Call ECR_TRACE("************** AGPAMAJ30 GPAMAJ30 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 111795 - 2015-10-15 by GH : all modifications concern views in a historised folder
      Call AGPAMAJ30 From GPAMAJ30 : # Moulinettes GPAO
      GVALTRANS(8)=2               : # TRT générés GPAO (transactions)
  Else
      Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif

Call ECR_TRACE("************** ACR1MAJ30 CRMMAJ30 ***************",-1) From GESECRAN
# Issue 106947
# To do if historic folder
#If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
# End issue 106947
  If [F:ADS]MODULE(11)=2
    Call ACR1MAJ30 From CRMMAJ30 : # Moulinettes CRM1
    GVALTRANS(12)=2              : # TRT générés Support clients
  Endif
# Issue 106947
#Else
# Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
#Endif
# End issue 106947

Call ECR_TRACE("************** ACR2MAJ30 CRMMAJ30 ***************",-1) From GESECRAN
# Issue 106947
# To do if historic folder
#If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
# End issue 106947
  If [F:ADS]MODULE(12)=2
    Call ACR2MAJ30 From CRMMAJ30 : # Moulinettes CRM2
    GVALTRANS(13)=2              : # TRT générés Action commerciale
  Endif
# Issue 106947
#Else
# Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
#Endif
# End issue 106947

#Fq-XXXX(mdj)  Call ECR_TRACE("************** AFASMAJ30 FASMAJ30 ***************",-1) From GESECRAN
If [F:ADS]MODULE(13)=2  and VERSION  >= 25
  Call ECR_TRACE("************** AFASMAJ30 FASMAJ30 ***************",-1) From GESECRAN
  Call AFASMAJ30 From FASMAJ30 : # Moulinettes Immobilisations
  GVALTRANS(14)=2              : # TRT générés Immobilisations
Endif

Onerrgo
End

Subprog CHGSMI
If clalev([F:ADA])=0 : Local File ADOSACT [ADA] : Endif
Trbegin [ADA]
 Read [ADA]ADA0 = [F:ADS]DOSSIER;"SMI"
 If !fstat
  [F:ADA]FLACT = 1
  Rewrite [ADA]
  If fstat
   Call ERREUR("ADOSACT"-[F:ADA]DOSSIER-"SMI",2) From DOSDIC
  Endif
 Endif
Commit
Close Local File [ADA]
End

Subprog ATBXI
Local File =[F:ADS]DOSSIER+".ATABLE"     [ATB]
Filter [ATB] Where CODACT="XXI" & left$([F:ATB]CODFIC,2)="XI"
For [ATB]
 [F:ATB]CODACT = ""
 Rewrite [ATB]
 If fstat
  Call ERREUR("ATABLE"-[F:ATB]CODFIC,2) From DOSDIC
 Endif
Next
Filter [ATB]
Close Local File [ATB]
End



###################################################################################
###################################################################################
###################################################################################

Subprog MAJ
#-------------------------------------#
#          Après mise à jour          #
#-------------------------------------#

Local Integer VERSION

Onerrgo ERREUR

VERSION = val (func DOSSUB.RELEASE([F:ADS]DOSSIER))
Call ECR_TRACE("DOSMAJ30 - MAJ - VERSION = "-num$(VERSION),-1) From GESECRAN

#----- Superviseur en premier

Call ECR_TRACE("************** MAJ SUPMAJ30 ***************",-1) From GESECRAN
Call MAJ      From SUPMAJ30     : # Moulinettes Superviseur

#----- Puis Tronc commun et CRM

Call ECR_TRACE("************** TRCMAJ30 TRCMAJ30 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  Call TRCMAJ30 From TRCMAJ30     : # Moulinettes Tronc commun
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

#----- Ensuite les autres modules

If [F:ADS]MODULE(1)=2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
 Call ECR_TRACE("************** CPTMAJ30 CPTMAJ30 ***************",-1) From GESECRAN
 Call CPTMAJ30  From CPTMAJ30  : # Moulinettes Compta
Endif

If [F:ADS]MODULE(2)=2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
 Call ECR_TRACE("************** TRSMAJ30 CPTMAJ30 ***************",-1) From GESECRAN
 Call TRSMAJ30  From CPTMAJ30  : # Moulinettes Tiers
Endif

#*Fq-61366Call ECR_TRACE("************** IMMMAJ30 CPTMAJ30 ***************",-1) From GESECRAN
#*Fq-61366If [F:ADS]MODULE(3)=2
#*Fq-61366  Call IMMMAJ30  From CPTMAJ30  : # Moulinettes Immos
#*Fq-61366Endif

Call ECR_TRACE("************** VENMAJ30 VENMAJ30 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR
  If [F:ADS]MODULE(4)=2
    Call VENMAJ30  From VENMAJ30  : # Moulinettes Ventes
  Endif
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

Call ECR_TRACE("************** ACHMAJ30 ACHMAJ30 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If [F:ADS]MODULE(5)=2
    Call ACHMAJ30  From ACHMAJ30  : # Moulinettes Achats
  Endif
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

Call ECR_TRACE("************** STOMAJ30 STOMAJ30 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If [F:ADS]MODULE(6)=2
    Call STOMAJ30  From STOMAJ30  : # Moulinettes Stock
  Endif
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

If [F:ADS]MODULE(7)=2
  Call ECR_TRACE("************** GPAMAJ30 GPAMAJ30 ***************",-1) From GESECRAN
  If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 111795 - 2015-10-15 by GH : all modifications concern views in a historised folder
     Call GPAMAJ30  From GPAMAJ30  : # Moulinettes GPAO
  Else
     Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
  Endif
Endif

Call ECR_TRACE("************** CR1MAJ30 CRMMAJ30 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If [F:ADS]MODULE(11)=2
    Call CR1MAJ30  From CRMMAJ30  : # Moulinettes CRM1
  Endif
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

Call ECR_TRACE("************** CR2MAJ30 CRMMAJ30 ***************",-1) From GESECRAN
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If [F:ADS]MODULE(12)=2
    Call CR2MAJ30  From CRMMAJ30  : # Moulinettes CRM2
  Endif
Else
 Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

Call ECR_TRACE("************** FASMAJ30 FASMAJ30 ***************",-1) From GESECRAN
If [F:ADS]MODULE(13)=2 and VERSION >= 25
  Call FASMAJ30  From FASMAJ30  : # Moulinettes Immo
Endif
Onerrgo
End

###################################################################################
