######################################################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [M]ENDDAT
  [M]ENDDAT = VALEUR
Endif
[M:SMA1]FLG = 0
End

Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
[M:SMA1]FLG = 0
End

######################################################################################
Subprog LNK2VCR(PTYP, PNUM)
Value Integer PTYP
Value Char    PNUM

GCONSULT = 2
Case PTYP
When 2   # commande vente
    Call OBJET("SOH",PNUM,num$(PTYP)) From GOBJET
When 4   # livraison
    Call OBJET("SDH",PNUM,num$(PTYP)) From GOBJET
When 5   # Facture vente
    Call OBJET("SIH",PNUM,num$(PTYP)) From GOBJET
When 6   # reception
    Call OBJET("PTH",PNUM,num$(PTYP)) From GOBJET
When 8   # Retour fournisseur
    Call OBJET("PNH",PNUM,num$(PTYP)) From GOBJET
When 9   # inventaire
    #MAE, bg 76607
    Gosub SET_NOL From STKINV
    GCONSULT = 2
    #Call OBJET("SNL",PNUM,num$(PTYP)) From GOBJET
    Call OBJET("SNL",PNUM,[M:SMA2]VCRNUMORI(NOL)) From GOBJET
    GCONSULT = 0
When 10  # ordre de fabrication
    Call OBJET("MFG",PNUM,num$(PTYP)) From GOBJET
When 12  # suivi matiere
    Call OBJET("MTK",PNUM,num$(PTYP)) From GOBJET
When 13  # retour client
    Call OBJET("SRH",PNUM,num$(PTYP)) From GOBJET
When 14  # commande achat
    Call OBJET("POH",PNUM,num$(PTYP)) From GOBJET
When 15  # declaration de production
    Call OBJET("MTK",PNUM,num$(PTYP)) From GOBJET
When 17  # facture achat
    Call OBJET("PIH",PNUM,num$(PTYP)) From GOBJET
When 18  # avoir vente
    Call OBJET("SIH",PNUM,num$(PTYP)) From GOBJET
When 19  # entrée diverse
    Call OBJET("SMR",PNUM,num$(PTYP)) From GOBJET
When 20  # sortie diverse
    Call OBJET("SMO",PNUM,num$(PTYP)) From GOBJET
When 26  # Réintégration stock (inactif)
    Call OBJET("SCS",PNUM,num$(PTYP)) From GOBJET
When 28  # controle qualite
    Call OBJET("STQ",PNUM,num$(PTYP)) From GOBJET
When 29  # changement de stock
    Call OBJET("SCS",PNUM,num$(PTYP)) From GOBJET
When 31  # assemblage
    Call OBJET("BBY",PNUM,num$(PTYP)) From GOBJET
When 32  # desassemblage
    Call OBJET("DBY",PNUM,num$(PTYP)) From GOBJET
When 33  # Demande de service
    Call OBJET("SRE",PNUM,num$(PTYP)) From GOBJET
When 35  # modification des lots
    #MAE, bg 77811 pas de tunnel sur modification de lot car on ne sait pas
    #quel objet utilisé : SMX ou SLM
    #Call OBJET("SLM",PNUM,num$(PTYP)) From GOBJET
When 36  # Ordre de sous-traitance
    Call OBJET("SCO",PNUM,num$(PTYP)) From GOBJET
Endcase
GCONSULT = 0

End

