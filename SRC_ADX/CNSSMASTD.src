#<AdxTL>@(#)0.0.0.0 $Revision$ 
Local Char PARAM(20)(1..8)
PARAM(1) = "0"
PARAM(2) = "GAL"
PARAM(3) = "A-HN140"
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = "0"
PARAM(7) = ""
PARAM(8) = ""
Call GCONSULT("SMA","",PARAM) From GCONSULT
End
############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz [M:CSMA]: Transmask [M:SMA1] To [M:CSMA] # Issue 25606 [M:CSMA] = [M:SMA1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
Raz GSOC_ACTIVE                                               # Ana

If clalev([F:STJ]) = 0 : Local File STOJOU     [STJ] : Endif
If clalev([F:STJ2])= 0 : Local File STOJOU     [STJ2]: Endif
If clalev([F:SJV]) = 0 : Local File STOJOUVAL  [SJV] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY]) = 0 : Local File COMPANY    [CPY] : Endif
If clalev([F:TCU]) = 0 : Local File TABCUR     [TCU] : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR     [TFO] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:TCM]) = 0 : Local File TABCOSTMET [TCM] : Endif
If GMODU(2)=2 : # Si module compta actif                       # Ana
  If !clalev([F:GCM])    Local File GACM       [GCM] : Endif   # Ana
Endif                                                          # Ana

# Chargement des globales référenciels, comptes et sections de la société
GFCY=GFCYDEF(7)                                                # Ana
Call GETCPY(GFCY,"",0,"") From TRTX3CPT                        # Ana
[M:SMA1]CUR=GLOCALDEV
GORITITCOL=1                                                   # Ana

Local Char    WFIL1(250),WFIL2(250), WFILS(250), WFILF(250), WFILX(250), WSTR(250), WFILSPE(250)
Local Integer WNOLIGN, WFSTAT, WREAD, WSKIP, WLIG, WCLA, WSEL, WPAGE
Local Decimal WSTO, WWSTO
Local Decimal WAMT, WWAMT
Local Decimal WBEFSTO, WAFTSTO, WBEFAMT, WAFTAMT
Local Char    WSAP
Local Char    WCOL(13) : WCOL = "1111110001110"
#Local Integer WBUT
Local Integer I, J
Local Integer WOK
Local Char    WPAR
Local Integer WSTL
Local  Integer WGCONSULT : WGCONSULT = GCONSULT

Local Decimal LAMTORD, LVARORD, LAMTVAL, LVARVAL, LPRIORD, LPRIVAL, LQTYSTU, LACTQTY, LQTYPCU, LAMTDEV
Local Integer LAGGFLG   # Indique si on est en train d'agréger un mouvement sur une ligne

WNOLIGN = nolign
Gosub LOAD_SCREEN

NAVIG="CONSSMA"
SUITE  = 1
RETOUR = 1

If [M:SMA1]NBFOR=0   # ne pas les rajouter si un MEMO a déjà été rechargé GA 07/2010
    [M:SMA1]FORASY([M:SMA1]NBFOR) = "[M:SMA2]AFTSTO(nolign-1)<0"
    [M:SMA1]CODSTL([M:SMA1]NBFOR) = "BACKRED"
    [M:SMA1]CODZON([M:SMA1]NBFOR) = "AFTSTO"
    [M:SMA1]NBFOR+=1
    [M:SMA1]FORASY([M:SMA1]NBFOR) = "[M:SMA2]IPTDAT(nolign-1)<>[M:SMA2]CREDAT(nolign-1)"
    [M:SMA1]CODSTL([M:SMA1]NBFOR) = "BACKORANGE"
    [M:SMA1]CODZON([M:SMA1]NBFOR) = "IPTDAT"
    [M:SMA1]NBFOR+=1
    [M:SMA1]FORASY([M:SMA1]NBFOR) = "nolign<[M:SMA2]NBLIG & [M:SMA2]AFTPRI(nolign)<>0 & abs(1-[M:SMA2]AFTPRI(nolign-1)/[M:SMA2]AFTPRI(nolign))>0.1"
    [M:SMA1]CODSTL([M:SMA1]NBFOR) = "BACKYELLOW"
    [M:SMA1]CODZON([M:SMA1]NBFOR) = "AFTPRI"
    [M:SMA1]NBFOR+=1
Endif
Call GENTRT(WOK)
If WOK
    FIN=1
Endif

Return


Subprog GENTRT(PRET)
Variable Integer PRET
Local Integer I
Local Char TRTGEN(20),FICTRT(250)
Local Char SAV_IFS(10), SAV_IRS(10)
TRTGEN="WCNSSMASTD"
FICTRT=filpath('TRT',TRTGEN,'src',nomap)

SAV_IFS = adxifs # sauvegarde des variables systèmes séparateurs
SAV_IRS = adxirs
adxifs = ""
adxirs = chr$(10)  # ou utiliser Iomode

Openo FICTRT , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision:   1.0  $"-"Alimentation du fichier temporaire d'agrégation"
Wrseq
Wrseq "Subprog AFFSTL(PSTL,PLIG)"
Wrseq "Value Integer PSTL"
Wrseq "Value Integer PLIG"
Wrseq "Case PSTL"
For I=0 To [M:SMA1]NBFOR-1
Wrseq "    When "+num$(I)+" : Chgstl [M:SMA2]"+[M:SMA1]CODZON(I)+"(PLIG) With '"+[M:SMA1]CODSTL(I)+"'"
Next
Wrseq "Endcase"
Wrseq "End"

adxifs = SAV_IFS
adxirs = SAV_IRS
Call VALID("TRT",TRTGEN,nomap,PRET) From VALMSKSUB
If PRET = 0
    PRET=2
    Call ERREUR(mess(20,123,1)) From GESECRAN    #"ERREUR EN VALIDATION DU TRAITEMENT
Else
    Raz PRET
Endif

End

############################################################
$FIN_CRIT
[M:SMA1]FLG = 0
[M:SMA1] = [M:CSMA]
Call GENTRT(GBIDI1)
Return
############################################################
$AP_MAGNETO
[M:SMA1]FLG = 0
Return
############################################################
$FERME
Raz GORITITCOL                                         # Ana
Filter [STJ]
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif

If dim(WNOLIGN) > 0
  nolign = WNOLIGN
Endif
Return
############################################################
$LOAD_SCREEN

For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SMA1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SMA1] = [F:ITM]
        Endif
      Endif
    When 4 :
    When 5 :
    When 6 :
      If PARAM(I) <> ""
        [M:SMA1]VCRTYPSEL = val(PARAM(I)) + 1
      Else
        [M:SMA1]VCRTYPSEL = 1
      Endif
    When 7 :
      [M:SMA1]VCRNUMSEL = PARAM(I)
    When 8 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I

[M:CSMA]STRDAT = [M:SMA1]STRDAT
[M:CSMA]ENDDAT = [M:SMA1]ENDDAT
#
[M:SMA1]SRTCOD = 7
If [M:SMA1]STOCOUSEL <> 0 | WFILS <> "1=1" | GCONSULT <> 0
  [M:SMA1]MISFLG    = 2
Else
  If clalev([M:CSMA]) <> 0 & [M:CSMA]MEMO = "STD"
    [M:SMA1] = [M:CSMA]
  Else
    [M:SMA1]MISFLG = 1
  Endif
Endif
Return
############################################################
$LECTURE
# Affichage entêtes de colonne variables                       # Ana
Gosub AFF_TITCOL                                               # Ana

#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:SMA1]ITMREF
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:SMA1]ITMREF
        Diszo [M:SMA1]FCY
    Endif
Endif

If [M:SMA1]ITMREF = ""
  NBLU = 0
  Return
Endif

# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
#WBUT   = 0
[M:SMA2]NBLIG=0
Raz nolign

Case CHGPAG
  When 1 :
    WSKIP=0
    WPAGE=0
    Gosub ADDLIN
    NOL+=nolign
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    WSKIP = WPAGE * MAXLIG
    Gosub ADDLIN
    NOL+=nolign
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Raz [M:SMA2]
    WLIG=0
    Raz [F:STJ2]
    If [M:SMA1]REGFLG<>2
        For [STJ]
            If !([F:STJ]VCRTYP=[F:STJ2]VCRTYP
&            & [F:STJ]VCRNUM=[F:STJ2]VCRNUM
&            & [F:STJ]VCRLIN=[F:STJ2]VCRLIN
&            & [F:STJ]CREMVTSEQ=[F:STJ2]CREMVTSEQ)
                WLIG+=1
            Endif
            [F:STJ2]VCRTYP=[F:STJ]VCRTYP
            [F:STJ2]VCRNUM=[F:STJ]VCRNUM
            [F:STJ2]VCRLIN=[F:STJ]VCRLIN
            [F:STJ2]CREMVTSEQ=[F:STJ]CREMVTSEQ
        Next
    Else
        WLIG = rowcount([STJ])
    Endif
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    # Sur le btn dernier, le superviseur considère qu'on remplit toutes les lignes du tableau et supprimme celles en trop
    # Il faut donc se décaler
#    nolign=(MAXLIG)-(WLIG-WSKIP)
#    NOL=nolign
    Gosub ADDLIN
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
    CHGPAG=2
    NOL=nolign-1
  When -2 :
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    Gosub ADDLIN
    NOL    = 0
    If WPAGE = 1
      RETOUR = 1
    Endif
Endcase
# Pas dépositionné
###Filter [STJ]
[M:SMA2]NBLIG = max(0,min(nolign,MAXLIG))

If CHGPAG=1
    Affzo [M:SMA2]
Endif
# Styles de mise en relief
WOK=1
Chgstl [M:SMA2] With ""

Onerrgo ERR_FOR
For nolign=1 To [M:SMA2]NBLIG
    For WSTL=0 To [M:SMA1]NBFOR-1
        If WOK
            If !sigma(0,WSTL-1,[M:SMA1]CODZON(indcum)=[M:SMA1]CODZON(WSTL)) & evalue([M:SMA1]FORASY(WSTL))
                Call AFFSTL(WSTL,nolign-1) From WCNSSMASTD
            Endif
        Else
            Break 2
        Endif
    Next
Next
Onerrgo

Affzo [M:SMA2]
Return

$ERR_FOR
    Call ERREUR(errmes$(errn)+"\"+[M:SMA1]FORASY(WSTL)) From GESECRAN
    WOK=0
Resume

$ADDLIN
    Raz WLIG
#    Call OUVRE_TRACE("ccc") From LECFIC
    Raz [F:STJ2]
    For [STJ]
#        Call ECR_TRACE(num$(WLIG)-num$(WSKIP)-num$([F:STJ]QTYSTU)-";"-num$([F:STJ]IPTDAT)-";"-num$([F:STJ]CREMVTSEQ)-";"-num$([F:STJ]VCRTYP)-";"-[F:STJ]VCRNUM-";"-num$([F:STJ]VCRLIN),0) From GESECRAN
        LAGGFLG=0
        If  [M:SMA1]REGFLG<>2
&         & [F:STJ]VCRTYP=[F:STJ2]VCRTYP
&         & [F:STJ]VCRNUM=[F:STJ2]VCRNUM
&         & [F:STJ]VCRLIN=[F:STJ2]VCRLIN
&         & [F:STJ]CREMVTSEQ=[F:STJ2]CREMVTSEQ
            LAGGFLG=1
#            Call ECR_TRACE ("agrège :"-num$(nolign)-num$(LVARORD)-num$(LQTYSTU),0) From GESECRAN
        Endif
        If WLIG > WSKIP | WLIG=WSKIP & !LAGGFLG
#          Call ECR_TRACE (num$(nolign),0) From GESECRAN
          If nolign < MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
          Else
            Break
          Endif
        Else
          If WSEL = 0 #& WBUT = 0
            If [M:SMA1]SRTCOD = 7 | [M:SMA1]SRTCOD = 10
              WSTO -= [F:STJ]ACTQTY
              WAMT -= [F:STJ]VARORD
            Else
              WSTO += [F:STJ]ACTQTY
              WAMT += [F:STJ]VARORD
            Endif
          Endif
        Endif
        If find([M:SMA1]SRTCOD,7,9)
            If [F:STJ]IPTDAT>[M:SMA1]ENDDAT
                Goto NEXT_STJ
            Endif
        Else
            If [F:STJ]CREDAT>[M:SMA1]ENDDAT
                Goto NEXT_STJ
            Endif
        Endif
        If !LAGGFLG
            WLIG += 1
        Endif
        [F:STJ2]VCRTYP=[F:STJ]VCRTYP
        [F:STJ2]VCRNUM=[F:STJ]VCRNUM
        [F:STJ2]VCRLIN=[F:STJ]VCRLIN
        [F:STJ2]CREMVTSEQ=[F:STJ]CREMVTSEQ
        $NEXT_STJ
    Next
#    If !GSERVEUR : Call FERME_TRACE() From LECFIC : Endif
#    Call LEC_TRACE From LECFIC
Return

############################################################
$TRT_FILTER
#
If [M:SMA1]FLG = 0 | CHGPAG = 1   # hcb 96842
  Filter [STJ]
  [M:SMA1]FLG = 1
  Raz [M:SMA2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  Case [M:SMA1]SRTCOD
    When 9 :
      Onerrgo ERR_FORM9
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By IPTDAT Asc; CREMVTDAT Asc; CREMVTTIM Asc; MVTSEQ Desc; MVTIND Desc
      Onerrgo
    When 10 :
      Onerrgo ERR_FORM10
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By CREDAT Desc; CRETIM Desc; IPTDAT Desc; MVTSEQ
      Onerrgo
    When 11 :
      Onerrgo ERR_FORM11
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By CREDAT; CRETIM; IPTDAT; MVTSEQ Desc
      Onerrgo
    When Default :
      Onerrgo ERR_FORM
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By IPTDAT Desc; CREMVTDAT Desc; CREMVTTIM Desc; MVTSEQ Asc; MVTIND Asc
      Onerrgo
  Endcase
# Chargement stock initial
  WSTO = 0
  WAMT = 0
  If WSEL = 0
    Raz [F:ITV]
    Read [ITV]ITV0=[M:SMA1]ITMREF;[M:SMA1]FCY
    WSTO = [F:ITV]AVCBASQTY
    WAMT = [F:ITV]AVCBASAMT
    If find([M:SMA1]SRTCOD,9,11)
        For [STJ]
            WSTO -= [F:STJ]ACTQTY
            WAMT -= [F:STJ]VARORD
        Next
    Endif
  Endif
  WWSTO = WSTO
  WWAMT = WAMT
  Raz [F:STJ]
  fstat = 0
Else
  WSTO = WWSTO
  WAMT = WWAMT
Endif
Return

############################################################
$ERR_FORM9
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)
&                  Order By IPTDAT Asc; CREMVTDAT Asc; CREMVTTIM Asc; MVTSEQ Desc; MVTIND Desc
Resume

$ERR_FORM10
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)
&            Order By CREDAT Desc; CRETIM Desc; IPTDAT Desc; MVTSEQ
Resume

$ERR_FORM11
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)
&            Order By CREDAT; CRETIM; IPTDAT; MVTSEQ
Resume

$ERR_FORM
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)
&                  Order By IPTDAT Desc; CREMVTDAT Desc; CREMVTTIM Desc; MVTSEQ Asc; MVTIND Asc
Resume

############################################################
$LOAD_FILTER
Raz WFILX, WFIL1
# Chargement des filtres
# WSEL = 1 pour interdir le calcul des champs stock avant et stock après
If [M:SMA1]SRTCOD = 0
  [M:SMA1]SRTCOD = 7
Endif
If find([M:SMA1]SRTCOD,7,9,10,11)
  WSEL = 0
Else
  WSEL = 1
Endif
# Filtre site
If [M:SMA1]FCY <> ""                             # graph
  WFIL1 = "[F:STJ]STOFCY=[M:SMA1]FCY"            # graph
  WFILX = "[F:STO]STOFCY=[M:SMA1]FCY"            # graph
  If [M:SMA1]UPDFLG <> 2                         # graph
    WFIL1 += "&[F:STJ]UPDCOD=2"
  Else
    WSEL   = 1
    WFIL1 += "&[F:STJ]UPDCOD=1"
  Endif
Else
  If [M:SMA1]UPDFLG <> 2                         # graph
    WFIL1 = "[F:STJ]UPDCOD=2"
  Else
    WSEL  = 1
    WFIL1 = "[F:STJ]UPDCOD=1"
  Endif
Endif
# Sélection numéro article
WFIL1 += "&[F:STJ]ITMREF=[M:SMA1]ITMREF"    # graph
If WFILX=""
  WFILX  = "[F:STO]ITMREF=[M:SMA1]ITMREF"   # graph
Else
  WFILX += "&[F:STO]ITMREF=[M:SMA1]ITMREF"  # graph
Endif
# Pas de selection date et tous mouvements si filtre chrono stock
If [M:SMA1]STOCOUSEL <> 0                   # graph
  WFILX += "&[F:STO]STOCOU=[M:SMA1]STOCOUSEL"  # graph
Endif
# Filtre date
If find([M:SMA1]SRTCOD,7,9)
    WFIL1 += "&[F:STJ]IPTDAT>=[M:SMA1]STRDAT"
Else
    WFIL1 += "&[F:STJ]CREDAT>=[M:SMA1]STRDAT"
Endif


# Pour filtrer les enregistrements bidon d'inventaire
WFIL2 = "[F:STJ]TRSTYP<>0"

# Filtre types de mvts
If [M:SMA1]MISFLG <> 2                                      # graph
       # Issue X3-53322- 2018-06-01 by MAE : ajout type 36
       WFIL2 += "&!find([F:STJ]TRSTYP,7,8,9,21,25,36)"  # graph
Endif

# Filtre type pièce
If [M:SMA1]VCRTYPSEL > 1                    # graph
  WSEL   = 1
  WFIL2 += "&[F:STJ]VCRTYP=[M:SMA1]VCRTYPSEL-1"  # graph
Endif
# Filtre numéro pièce
If [M:SMA1]VCRNUMSEL <> ""                        # graph
  WSEL   = 1
  WFIL2 += "&[F:STJ]VCRNUM=[M:SMA1]VCRNUMSEL"
Endif
# Filtre formule
WFILF = "1=1"
If [M:SMA1]SELFOR <> ""                          # graph
  Read [TFO]TFO0=11;[M:SMA1]SELFOR               # graph
  If fstat = 0
    WSEL  = 1
    WFILF = [F:TFO]FORFOR
  Endif
Endif
Return
############################################################
############################################################
$LOA_LIGNE

#Filter [STJ2] Where STOFCY = [F:STJ]STOFCY
#&                 & VCRTYP = [F:STJ]VCRTYP
#&                 & VCRNUM = [F:STJ]VCRNUM
#&                 & VCRLIN = [F:STJ]VCRLIN
#&                 & REGFLG = 1
#Look [F:STJ2] First
#If fstat
#    Return
#Endif

If WSEL = 0
  If [M:SMA1]SRTCOD = 7 | [M:SMA1]SRTCOD = 10
    If !LAGGFLG
        WAFTSTO = WSTO
        WAFTAMT = WAMT
    Endif
    WSTO -= [F:STJ]ACTQTY
    WBEFSTO = WSTO
    WAMT -= [F:STJ]VARORD
    WBEFAMT = WAMT
  Else
    If !LAGGFLG
        WBEFSTO = WSTO
        WBEFAMT = WAMT
    Endif
    WSTO += [F:STJ]ACTQTY
    WAFTSTO = WSTO
    WAMT += [F:STJ]VARORD
    WAFTAMT = WAMT
  Endif

Endif

# Si on est hors période de consultation, on n'affiche rien
If find([M:SMA1]SRTCOD,7,9)
    If [F:STJ]IPTDAT>[M:SMA1]ENDDAT
        Return
    Endif
Else
    If [F:STJ]CREDAT>[M:SMA1]ENDDAT
        Return
    Endif
Endif

If LAGGFLG & find([M:SMA1]SRTCOD,7,10)  # Tri descendant
    [F:STJ2] = [M:SMA2]
    [M:SMA2] = [F:STJ]
    [F:STJ] = [F:STJ2]
    [F:STJ2]=[M:SMA2]
Else
    [F:STJ2] = [F:STJ]
Endif

If LAGGFLG
    LVARORD = [M:SMA2]VARORD(nolign-1)
    LVARVAL = [M:SMA2]VARVAL(nolign-1)
    LQTYSTU = [M:SMA2]QTYSTU(nolign-1)
    LQTYPCU = [M:SMA2]QTYPCU(nolign-1)
    If [M:SMA2]PCU(nolign-1) <> [F:STJ]PCU
        LQTYPCU = LQTYSTU
        [F:STJ]PCU = [F:STJ]STU
        [F:STJ]QTYPCU = [F:STJ]QTYSTU
    Endif
    LACTQTY = [M:SMA2]ACTQTY(nolign-1)
    LAMTDEV = [M:SMA2]AMTDEV(nolign-1)
Else
    Raz LAMTORD, LVARORD, LAMTVAL, LVARVAL, LPRIORD, LPRIVAL, LQTYSTU, LACTQTY, LAMTDEV
    nolign+=1
Endif
    LAMTORD += [F:STJ2]VARORD
    LAMTVAL += [F:STJ2]VARVAL
    LPRIORD = [F:STJ2]PRIORD
    LPRIVAL = [F:STJ2]PRIVAL
#If [F:STJ]REGFLG=1
#    LAMTORD += [F:STJ]AMTORD
#    LAMTVAL += [F:STJ]AMTVAL
#    LPRIORD = [F:STJ]PRIORD
#    LPRIVAL = [F:STJ]PRIVAL
#Endif

[M:SMA2] = [F:STJ]

#                                              # hcb 70350 deb
If [F:STJ]ITMREF <> [F:ITM]ITMREF
  Read [ITM]ITM0=[F:STJ]ITMREF
  If fstat
    Raz [F:ITM]
  Endif
Endif

If [F:ITM]SERMGTCOD=4
  [M:SMA2]SERNUM(nolign-1) = [F:STJ]SERDEB
  [M:SMA2]SERFIN(nolign-1) = [F:STJ]SERFIN
Endif
#                                              # hcb 70350 fin

For I=1 To GNBDIE
   Assign "[M:SMA2]CCE"+num$(I)+"(nolign-1)" With [F:STJ]CCE(I-1)
Next I

#lecture ITMFACILIT  pour recuperer STOMGTCOD
If [F:ITF]STOFCY <> [F:STJ]STOFCY | [F:ITF]ITMREF <> [F:STJ]ITMREF
   Read [ITF]ITF0 = [F:STJ]ITMREF;[F:STJ]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

If dim([M:SMA2]POT) > 0 & [F:ITF]STOMGTCOD <> 3
  [M:SMA2]POT(nolign-1) = 0
Endif
If dim([M:SMA2]ACT) > 0 & [F:ITF]STOMGTCOD <> 4
  [M:SMA2]ACT(nolign-1) = 0
Endif
If [F:FCY]FCY<>[F:STJ]STOFCY
    Read [F:FCY]FCY0=[F:STJ]STOFCY
Endif

[M:SMA2]BEFSTO(nolign-1) = 0
[M:SMA2]AFTSTO(nolign-1) = 0
If WSEL = 0 #& WBUT = 0 #& [M:SMA2]TRSTYP(nolign-1)<>23
  [M:SMA2]BEFSTO(nolign-1) = WBEFSTO
  [M:SMA2]AFTSTO(nolign-1) = WAFTSTO
Endif

[M:SMA2]BEFAMT(nolign-1) = 0
[M:SMA2]AFTAMT(nolign-1) = 0
[M:SMA2]BEFPRI(nolign-1) = 0
[M:SMA2]AFTPRI(nolign-1) = 0
If WSEL = 0
  [M:SMA2]BEFAMT(nolign-1) = WBEFAMT
  [M:SMA2]AFTAMT(nolign-1) = WAFTAMT
  If WBEFSTO<>0
      [M:SMA2]BEFPRI(nolign-1) = WBEFAMT / WBEFSTO
  Endif
  If WAFTSTO<>0
      [M:SMA2]AFTPRI(nolign-1) = WAFTAMT / WAFTSTO
  Endif
Endif

If LAGGFLG
    [M:SMA2]AMTORD(nolign-1) = LAMTORD
    [M:SMA2]AMTVAL(nolign-1) = LAMTVAL
    [M:SMA2]PRIORD(nolign-1) = LPRIORD
    [M:SMA2]PRIVAL(nolign-1) = LPRIVAL
    [M:SMA2]VARORD(nolign-1) += LVARORD
    [M:SMA2]VARVAL(nolign-1) += LVARVAL
    [M:SMA2]QTYSTU(nolign-1) += LQTYSTU
    [M:SMA2]QTYPCU(nolign-1) += LQTYPCU
    [M:SMA2]ACTQTY(nolign-1) += LACTQTY
    [M:SMA2]AMTDEV(nolign-1) += LAMTDEV
Endif

#If find([M:SMA1]SRTCOD,7,10)  # Tri descendant
    [F:STJ] = [F:STJ2]
#Endif
Return

#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL                             : # ana
If dim([M:SMA2]CCE1)>0                                             # hcb 112700
#If GSOC_UPDFLG & dim([M:SMA2]CCE1)>0                              # hcb 112700
  Local Char BASPAG(10)
  Call ISSCREENOK (nomap,"CONSSMA2") From INTRUTILB
  BASPAG="NBLIG" : Gosub TIT_COL From W1CONSSMA2
  # Pour forcer l'utilisation des formats évalués si tableau vide
  If [M:SMA2]NBLIG=0
    [M:SMA2]NBLIG=1 : Affzo [SMA2]5 : Effzo [SMA2]5
  Endif
Endif
Raz GSOC_UPDFLG
Return

#------------------------------------------------------------------------#
# initialisation suivant contexte article
#------------------------------------------------------------------------#
Subprog INIT_PAR(PITM,PFCY)
Value Char PITM
Value Char PFCY

Local Char LTCM
Local Integer LRET

Call GETTCM(PITM, PFCY, LTCM, LRET) From STKVAL
If [F:TCM]PRIREGS=2
    [M:SMA1]SRTCOD = 7
Else
    [M:SMA1]SRTCOD = 10
    [M:SMA1]REGFLG = 2
Endif
Affzo [M:SMA1]SRTCOD
End


############################################################
$SETBOUT

If [M:SMA1]ITMREF <> ""
   CHMEN += "12"
Endif
Return
############################################################
$EXEBOUT
Return
