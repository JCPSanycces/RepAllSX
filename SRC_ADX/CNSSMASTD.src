######################################################################################
## SYMEU 61044 (21/12/2009) : oublié de tester la présence du champ [M:SMA2]LOT
######################################################################################
Subprog IB_NBLIG
    # Seules les réceptions et les entrées OF ont pu être régularisées
    If !find([M:SMA2]TRSTYP(nolign-1),3,5)
        Raz GBOUT2
    Endif
    If [M:SMA2]NUMVCR(nolign-1)=""
        Raz GBOUT3
    Endif
    # Pas de consultation stock/lot ou traçabilité si lot non renseigné
    If dim([M:SMA2]LOT) > 0 Then      # SYMEU 61044
      If [M:SMA2]LOT(nolign-1)="" Then
          Raz GBOUT4
      Endif
    Endif
    If (dim([M:SMA2]LOT) > 0 and [M:SMA2]LOT(nolign-1)="") or [F:ITM]TRKCOD<=1 Then   # SYMEU 61044
        Raz GBOUT5
    Endif
    If !GACTDECCST | [M:SMA1]REGFLG<>2
        Raz GBOUT6, GBOUT7
    Endif
    If !find([M:SMA2]VCRTYP(nolign-1),2,4,5,6,8,9,10,12,13,14,15,17,18,19,20,26,28,29,31,32,33,36)
        Raz GBOUT8
    Else
        GBOUT8 = mess([M:SMA2]VCRTYP(nolign-1),701,1)-"("+[M:SMA2]VCRNUM(nolign-1)+")"
    Endif
    If !find([M:SMA2]VCRTYPORI(nolign-1),2,4,5,6,8,9,10,12,13,14,15,17,18,19,20,26,28,29,31,32,33,36)
        Raz GBOUT9
    Else
        GBOUT9 = mess([M:SMA2]VCRTYPORI(nolign-1),701,1)-"("+[M:SMA2]VCRNUMORI(nolign-1)+")"
    Endif
    #MAE, bg 76931, type de mvt=demande d'analyse ou type de piéce=controle qualité
    #=>pas de tunnel
    If [M:SMA2]TRSTYP(nolign-1)=34 | [M:SMA2]VCRTYP(nolign-1)=28
      Raz GBOUT8
      #si piéce origine=changement de stock, pas de tunnel car le changement de stock
      #lié à un controle qualité n'est pas visible par l'objet
      If [M:SMA2]VCRTYPORI(nolign-1)=29
        Raz GBOUT9
      Endif
    Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSMA2) 02/02/2009 10:11:13 (CCC)
######################################################################################
Subprog B6_NBLIG
    GBIDC1="SJVO"
    Gosub ACT_SAIDECPRI
End

Subprog B7_NBLIG
    GBIDC1="SJVV"
    Gosub ACT_SAIDECPRI
End

$ACT_SAIDECPRI
If GACTDECCST
    Raz [F:STJ], [F:SJV]
    For [STJ] Where STOFCY=[M:SMA2]STOFCY(nolign-1)
&                 & UPDCOD=2
&                 & ITMREF=[M:SMA1]ITMREF
&                 & IPTDAT=[M:SMA2]IPTDAT(nolign-1)
&                 & MVTSEQ=[M:SMA2]MVTSEQ(nolign-1)
&                 & MVTIND=[M:SMA2]MVTIND(nolign-1)
        Break
    Next
    Read [SJV]SJV0=[M:SMA2]STOFCY(nolign-1);2;[M:SMA1]ITMREF;[M:SMA2]IPTDAT(nolign-1);[M:SMA2]MVTSEQ(nolign-1);[M:SMA2]MVTIND(nolign-1)
    If fstat
        mkstat=2
    Endif
Endif
Return

######################################################################################
Subprog B8_NBLIG
Local Integer NOL : NOL = nolign-1
Call LNK2VCR([M:SMA2]VCRTYP(NOL),[M:SMA2]VCRNUM(NOL))
End

######################################################################################
Subprog B9_NBLIG
Local Integer NOL : NOL = nolign-1
Call LNK2VCR([M:SMA2]VCRTYPORI(NOL),[M:SMA2]VCRNUMORI(NOL))
End


#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SMA") From SUBGTC

End


