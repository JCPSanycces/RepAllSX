#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#Infbox ACTION
Case ACTION
  When "ADD_BPA"      : Gosub ADD_BPA
  When "REMP_ADRB"    : Gosub REMP_ADRB
Endcase
Return

$ADD_BPA
Call CREBPA_KPO(NUMBPA,[M:FCY0]FCY)
Return

$REMP_ADRB
If dim([M:BPF]XADMDIVCOD)> 0
  [M:BPF]XADMDIVCOD    = [M:BPF]ADMDIVCOD(NOL)
  Affzo [M:BPF]
Endif
Return

Subprog CREBPA_KPO(TYP,ENTITE)
Value Integer TYP
Value Char    ENTITE
Local Integer STA ,I,J
If !clalev([F:BPAPOR]) : Local File BPADDRESSPOR [BPAPOR] : Endif
If dim([M:BPF]NBADR)> 0
  If [M:BPF]NBADR>0 & !find(2,[M:BPF]BPAADDFLG(0..[M]NBADR-1))
    [M:BPF]BPAADDFLG(0) = 2
    [M:BPF]FLMOD(0)=1
  Endif
  For nolign=1 To [M:BPF]NBADR
    If [M:BPF]FLMOD(nolign-1)
      Readlock [F:BPAPOR]BPAPOR0 = TYP;ENTITE;[M:BPF]CODADR(nolign-1)
      STA = fstat
      If STA=1
        GOK = -1 : GLOCK = "$BPADDRESSPOR"-num$(TYP)-ENTITE-[M:BPF]CODADR(nolign-1) : Break
      Endif
      [F:BPAPOR] = [M:BPF]
      [F:BPAPOR]BPATYP = TYP
      [F:BPAPOR]BPANUM = ENTITE
      [F:BPAPOR]BPAADD = [M]CODADR(nolign-1)

      If STA
        If dim([F:BPAPOR]CREDAT)>0 : [F:BPAPOR]CREDAT = date$ : Endif
        If dim([F:BPAPOR]CREUSR)>0 : [F:BPAPOR]CREUSR = GUSER : Endif
        If dim([F:BPAPOR]CRETIM)>0 : [F:BPAPOR]CRETIM = time  : Endif
        If dim([F:BPAPOR]UPDDAT)>0 : [F:BPAPOR]UPDDAT = [0/0/0] : Endif
        If dim([F:BPAPOR]UPDUSR)>0 : [F:BPAPOR]UPDUSR = "" : Endif
        If dim([F:BPAPOR]UPDTIM)>0 : [F:BPAPOR]UPDTIM = 0  : Endif
        Write [BPAPOR]
      Else
        If dim([F:BPAPOR]UPDDAT)>0 : [F:BPAPOR]UPDDAT = date$ : Endif
        If dim([F:BPAPOR]UPDUSR)>0 : [F:BPAPOR]UPDUSR = GUSER : Endif
        If dim([F:BPAPOR]UPDTIM)>0 : [F:BPAPOR]UPDTIM = time  : Endif
        Rewrite [BPAPOR]
      Endif
      If fstat
        GOK = 0 : Call FSTA("BPAPOR") From GLOCK : Break
      Endif
    Endif
  Next nolign
Endif
End

Subprog AM_XADMDIVCOD(VALEUR)
Variable Char    VALEUR()
[M]ADMDIVCOD([M]XNUMLIG) = VALEUR
[M]FLMOD([M]XNUMLIG) = 1
End


Subprog CHARG_BPA_KPO(TYP,ENTITE)
Value Integer TYP
Value Char    ENTITE
If !clalev([F:BPAPOR]) : Local File BPADDRESSPOR [BPAPOR] : Endif

  For nolign=1 To [M:BPF]NBADR
    Read [BPAPOR]BPAPOR0=TYP;ENTITE;[M]CODADR(nolign-1)
    If !fstat Then
      [M:BPF] = [F:BPAPOR]
    Endif
  Next

  NOL = 0
  Gosub REMP_ADRB
End

