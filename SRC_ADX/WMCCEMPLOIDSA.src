If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_LNRSKL From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To 3
 If this.PERCNT(AINDCLA)<>null& find(this.PERCNT(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.PERCNT(AINDCLA)._AFORMAT : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_CREDATTIM From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_UPDDATTIM From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_AUUID From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_CREUSR From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_UPDUSR From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
Return

####################################################################
# OTHERS
####################################################################

$_AOTHERS
Gosub DECLARE_VAR From WMC0EMPLOIDSA
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_REFNUM From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_REFNUM From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SECNAM From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SECNAM From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MADNAM From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MADNAM From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_DISRSN From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_DISRSN From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_NBRADD From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_NBRADD From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To 3
 If this.EMPADR(AINDCLA)<>null& find(this.EMPADR(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EMPADR(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_NBRPAS From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_NBRPAS From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To 3
 If this.PASDET(AINDCLA)<>null& find(this.PASDET(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.PASDET(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_BUSTEL From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_BUSTEL From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FINTAXCLC From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FINTAXCLC From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_RSAID From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_RSAID From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ETHGRP From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ETHGRP From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_RCEGRP From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_RCEGRP From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_EMPTAXNR From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_EMPTAXNR From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_LNRSKL From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_LNRSKL From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To 3
 If this.PERCNT(AINDCLA)<>null& find(this.PERCNT(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.PERCNT(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREDATTIM From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREDATTIM From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDDATTIM From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDDATTIM From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_AUUID From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_AUUID From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREUSR From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREUSR From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDUSR From WMC1EMPLOIDSA : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDUSR From WMC1EMPLOIDSA : Gosub TESTALLSTAT :  Endif
[L]ASTATUS = fmet this.ACONTROL
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



