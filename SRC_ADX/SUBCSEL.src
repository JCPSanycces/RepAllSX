Subprog MAJ_ANDOR(LNUM,LVAL)
Value    Integer LNUM
Variable Integer LVAL
Local    Integer W_J
Assign "[M:CSEL]SELINT"+num$(LNUM) With LVAL

Local Integer W_J : W_J = 0
If [M:CSEL]SELINT1 = 2
  W_J = 1
Endif
If [M:CSEL]SELINT2 = 1
  [M:CSEL]ANDOR1 = 1
Else
  If W_J = 0
    [M:CSEL]ANDOR1 = 1
  Endif
  W_J = 1
Endif
If [M:CSEL]SELINT3 = 1
  [M:CSEL]ANDOR2 = 1
Else
  If W_J = 0
     [M:CSEL]ANDOR2 = 1
  Endif
  W_J = 1
Endif
If [M:CSEL]SELINT4 = 1
  [M:CSEL]ANDOR3 = 1
Else
  If W_J = 0
     [M:CSEL]ANDOR3 = 1
  Endif
  W_J = 1
Endif
Affzo [M:CSEL]ANDOR1
Affzo [M:CSEL]ANDOR2
Affzo [M:CSEL]ANDOR3
End
