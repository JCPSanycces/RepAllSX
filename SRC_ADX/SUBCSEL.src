Subprog AS_QTYSTU(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
If [M:CSEL]SELQTY(NOL) <> 2 | [M]SELFLG(NOL) <> 2
  mkstat = 2
Endif
End
