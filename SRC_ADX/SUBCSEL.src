############################################################
Subprog AV_SEQTXT(VALEUR)
Variable Char VALEUR
Gosub SET_NOL
Local Integer I, M
pcolor = GCOUL(0)
For I = 0 To [F:CSE]RULNBR-1
  If [F:CSE]RUL(I) = 1
    Gosub RUL_CND
    If M = 1 & [F:CSE]RULOPT1(I) = [M:CSEL]SEQ(NOL) 
      pcolor = GCOUL(3)
      Break
    Endif
  Endif
Next I
End
############################################################
Subprog AS_SELSUP(VALEUR)
Variable Char    VALEUR()
Call CFGSETFOR(7,[M:CSEL]CFGLIN1,"DEFG",[M:CSEL]FILTAB,[M:CSEL]TEXCON,[M:CSEL]VARSUP) From CFGLIB
End
