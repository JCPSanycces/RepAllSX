Subprog C_SELSUP(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Local Char    W_RES(30)
  Local Char    W_EVA(80)
  Onerrgo C_SELSUP_ERR
  W_RES = num$(evalue(VALEUR))
  Onerrgo
Endif
End
#
C_SELSUP_ERR
