#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du fichier CFGSEL
$ACTION            # Obligatoire pour triater le cas d'actions avec paramètre: action avant/après zone
Case ACTION
 When default
Endcase
Return


$SET_NOL
Local Integer NOL : NOL = nolign-1
Return
############################################################
Subprog AS_NBLIG
GBOUT3 = mess(22,198,1)
GBOUT4 = mess(4,198,1)
If nolign <= [M:CSEL]NBLIG & dim([M:CSEL]IMGFLG) > 0 & [M:CSEL]IMGFLG(nolign-1) <> 2
  GBOUT7 = ""
Endif
End
############################################################
Subprog B3_NBLIG
GCONSULT = 2
Call OBJET("ITM",[M:CSEL]ITMREF(nolign-1),"") From GOBJET  #CHECK IGNORE_LINE
GCONSULT = 0
End
############################################################
Subprog B4_NBLIG
GCONSULT = 2
Call OBJET("ITF",[M:CSEL]FCY,[M:CSEL]ITMREF(nolign-1)) From GOBJET  #CHECK IGNORE_LINE
GCONSULT = 0
End
############################################################
Subprog APRES_NBLIG
Gosub SET_NOL
If dim([M:CSEL]CST) < 0
    End
Endif
Local Integer I
Local Char    WFCY : WFCY = [M:CSEL]FCY
Local Integer WCOD 
Local Date    WDAT : WDAT = date$
Local Integer WRET 
Local Decimal WQUS, WQUV, WPRI, WCST
Local Char    WDMY : WDMY = ""
#
Read [ITM]ITM0=[M:CSEL]ITMREF(NOL)   #CHECK IGNORE_LINE
If fstat
  End
Endif
Read [ITF]ITF0=[F:ITM]ITMREF;[M:CSEL]FCY
If fstat
  Raz [F:ITF]
Endif 
Read [ITV]ITV0=[F:ITM]ITMREF;[M:CSEL]FCY
If fstat
  Raz [F:ITV]
Endif 
Read [ITS]ITS0=[F:ITM]ITMREF
If fstat
  Raz [F:ITS]
Endif
Read [TCU]TCU0=[M:CSEL]CUR
If fstat
  Raz [F:TCU]
Endif
# Calcul quantité en US et UV
If [F:ITM]SAUSTUCOE = 0
  [F:ITM]SAUSTUCOE = 1
Endif
Case [F:CSE]SELQTY 
  When 1
    WQUS = 1
    WQUV = 1
  When 2 : 
    WQUS = [M:CSEL]QTYSTU(NOL)
    WQUV = [M:CSEL]QTYSTU(NOL)*[F:ITM]SAUSTUCOE
    If dim([M:CSEL]QTYSAU)>0    # CCC (15/12/05) Bug 33805
        [M:CSEL]QTYSAU(NOL) = [M:CSEL]QTYSTU(NOL)/[F:ITM]SAUSTUCOE
    Endif
  When Default : 
    WQUS = [M:CSEL]QTYSAU(NOL)/[F:ITM]SAUSTUCOE
    WQUV = [M:CSEL]QTYSAU(NOL)
    If dim([M:CSEL]QTYSTU)>0    # CCC (15/12/05) Bug 33805
        [M:CSEL]QTYSTU(NOL) = [M:CSEL]QTYSAU(NOL)*[F:ITM]SAUSTUCOE
    Endif
Endcase
#Onerrgo APRES_NBLIG_ERR
WCST = 0
# SELPRI: menu 774
Case [F:CSE]SELPRI  
  When 2 : WPRI = evalue([F:CSE]PRIFOR)
           WCST = arr(WQUV*WPRI,10^-[F:TCU]DECNBR)
  When 4 : WPRI = 0
  # JPJ DEFPRI/STOCKLIB -> Non reconduite et DEFPRI/STKVAL non équivalente
  When 3,5,6,7,9 :     
           # Le calcul doit se faire dans la devise [M]CURORI 
           # GA 09/2007 avant WYEAR => S_IPTDAT selon CFGLIBC
           Call CAL_CST(0,[F:CSE]SELPRI,WFCY,[ITM]ITMREF,S_IPTDAT,[M]CURORI,WPRI,WRET) From CFGLIBD
           WCST=WPRI           #WCOD = 1, 2, 2   Call DEFPRI(WFCY,WCOD,WDMY,WDMY,WDAT,WQUS,WPRI,WRET) From STOCKLIB   
           #WCST = arr(WQUS*WPRI,10^-[F:TCU]DECNBR)
  # JPJ STOCKLIB <-
Endcase
If [M]CUR = [M]CURORI
  [M:CSEL]CSTORI(NOL) = WCST
  [M:CSEL]CST(NOL)    = WCST
Else
  [M:CSEL]CSTORI(NOL) = WCST
  Call CONVERT([M]CURORI,[M]CUR,GSYSCUR,1,date$,[M]CSTORI(NOL),[M]CST(NOL),WRET) From TRTDEV
Endif
# CCC (15/12/05) Bug 33850
If dim([M:CSEL]QTYSAU)>0    # Si la zone existe c'est parce qu'on saisi dans cette unité
  [M:CSEL]CSTORI(NOL) *= [F:ITM]SAUSTUCOE
  [M:CSEL]CST(NOL)    *= [F:ITM]SAUSTUCOE
Endif
Affzo [M:CSEL]CST(NOL)
Onerrgo
# calcul cout total
[M:CSEL]CSTTOT = 0
For I = 0 To [M:CSEL]NBLIG-1
  If [M:CSEL]SELFLG(I) = 2
    # CCC (15/12/05) Bug 33850
    #[M:CSEL]CSTTOT += [M:CSEL]CST(I)
    If dim([M:CSEL]QTYSAU)>0
       [M:CSEL]CSTTOT += [M:CSEL]CST(I) * [M:CSEL]QTYSAU(I) : # FQ 46210 avant [M:CSEL]QTYSAU(NOL)
    Else
       [M:CSEL]CSTTOT += [M:CSEL]CST(I) * [M:CSEL]QTYSTU(I) : # FQ 46210 avant [M:CSEL]QTYSTU(NOL)
    Endif
  Endif
Next I
# Point d'entrée après ligne selections
GPOINT = "AFTLIGSEL"
Gosub  ENTREE From EXEFNC 
Affzo [M:CSEL]CSTTOT
End
$APRES_NBLIG_ERR
WPRI = 0
Resume
############################################################
Subprog AS_SELFLG(VALEUR)
Variable Integer VALEUR
Gosub SET_NOL
Local Integer I, J, K, M
If VALEUR = 2
  End
Else
  Case [M:CSEL]SELTYP 
    When 1 : 
      J = 0
      For I = 0 To [M:CSEL]NBLIG-1
        If [M:CSEL]SELFLG(I) = 2
          J += 1
        Endif
      Next I
      Case [M:CSEL]SELMUL
        When 2  :     :
          GMESSAGE = mess(25,188,1)
          mkstat= 2
        When 3 :    :
          If J = 1 
            mkstat = 2 
            GMESSAGE = mess(26,188,1)
          Endif
        When 4 :
          If J = 1
            mkstat = 2 
            GMESSAGE = mess(26,188,1)
          Endif
        When Default :
          End
      Endcase  
    When 2 :
      For I = 0 To [M:CSEL]NBLIG-1
        If [M:CSEL]SEQ(I) = [M:CSEL]SEQ(NOL) & [M:CSEL]SELFLG(I) = 2 & I <> NOL
          [M:CSEL]SELFLG(I) = 1
          Affzo [M:CSEL]SELFLG(I) 
          If dim([M:CSEL]QTYSTU) > 0
            [M:CSEL]QTYSTU(I) = 0
            Affzo [M:CSEL]QTYSTU(I)
          Endif
          If dim([M:CSEL]QTYSAU) > 0
            [M:CSEL]QTYSAU(I) = 0
            Affzo [M:CSEL]QTYSAU(I)
          Endif
          If dim([M:CSEL]CST) > 0
            [M:CSEL]CST(I) = 0
            Affzo [M:CSEL]CST(I)
          Endif 
        Endif
      Next I
      For I = 0 To [F:CSE]RULNBR-1
        If [F:CSE]RUL(I) = 3
          Gosub RUL_CND
          If M = 1
            For J = 0 To [M:CSEL]NBLIG-1
              If [M:CSEL]SELFLG(J) = 2 & J <> NOL           
                If [M:CSEL]SEQ(J) = [F:CSE]RULOPT1(I) & [M:CSEL]SEQ(NOL) = [F:CSE]RULOPT2(I) 
                  mkstat = 2
                  GMESSAGE = mess(27,188,1)-[M:CSEL]SEQTXT(J)
                  Break 2
                Endif
                If [M:CSEL]SEQ(J) = [F:CSE]RULOPT2(I) & [M:CSEL]SEQ(NOL) = [F:CSE]RULOPT1(I) 
                  mkstat = 2
                  GMESSAGE = mess(27,188,1)-[M:CSEL]SEQTXT(J)
                  Break 2
                Endif
              Endif
            Next J
          Endif
        Endif
      Next I
  Endcase
Endif
End
############################################################
$RUL_CND
M = 1
If [F:CSE]RULCND(I) <> ""
  Onerrgo RUL_CND_ERR
  M = evalue([F:CSE]RULCND(I))
  Onerrgo
Endif
Return
$RUL_CND_ERR
M = 0
Resume
############################################################
Subprog AM_SELFLG(VALEUR)
Variable Integer VALEUR
Gosub SET_NOL
Local Integer I, J, K, M
Local Integer WVALEUR
Local Char    WIND(1)([M:CSEL]NBLIG)
WVALEUR = [M:CSEL]SELFLG(NOL)
[M:CSEL]SELFLG(NOL) = VALEUR
#
If dim([M:CSEL]QTYSTU)> 0
  If VALEUR = 1
    [M:CSEL]QTYSTU(NOL) = 0
  Else
    If [M:CSEL]QTYSTU(NOL) = 0
      If dim([M:CSEL]FORQTY) > 0 & [M:CSEL]FORQTY(NOL) <> ""
        Onerrgo ERR_CALQTY
        [M:CSEL]QTYSTU(NOL) = evalue([M:CSEL]FORQTY(NOL)) 
        Onerrgo
      Else 
        [M:CSEL]QTYSTU(NOL) = 1 
      Endif
    Endif
  Endif 
  Affzo [M:CSEL]QTYSTU(NOL)
Endif
If dim([M:CSEL]QTYSAU)> 0
  If VALEUR = 1
    [M:CSEL]QTYSAU(NOL) = 0
  Else
    Read [ITS]ITS0=[M:CSEL]ITMREF(NOL)  #CHECK IGNORE_LINE
    If fstat
      Raz [F:ITS]
    Endif
    If [M:CSEL]QTYSAU(NOL) = 0
      If dim([M:CSEL]FORQTY) > 0 & [M:CSEL]FORQTY(NOL) <> ""
        Onerrgo ERR_CALQTY
        [M:CSEL]QTYSAU(NOL) = evalue([M:CSEL]FORQTY(NOL)) 
        Onerrgo
      Else 
        If [F:ITS]MINQTY > 0 
          [M:CSEL]QTYSAU(NOL) = [F:ITS]MINQTY
        Else
          [M:CSEL]QTYSAU(NOL) = 1
        Endif
      Endif
    Endif
  Endif 
  Affzo [M:CSEL]QTYSAU(NOL)
Endif
If [M:CSEL]SELTYP = 2
  Raz WIND
  For I = 0 To [F:CSE]RULNBR-1
    If [F:CSE]RUL(I) = 3
      Gosub RUL_CND
      If M = 1
        For J = 0 To [M:CSEL]NBLIG-1
          If [M:CSEL]SEQ(J) = [F:CSE]RULOPT1(I) & [M:CSEL]SELFLG(J) = 2
            For K = 0 To [M:CSEL]NBLIG-1
              If [M:CSEL]SEQ(K) = [F:CSE]RULOPT2(I) & K <> J
                WIND(K) = "*"
              Endif
            Next K 
          Else
            If [M:CSEL]SEQ(J) = [F:CSE]RULOPT2(I) & [M:CSEL]SELFLG(J) = 2
              For K = 0 To [M:CSEL]NBLIG-1
                If [M:CSEL]SEQ(K) = [F:CSE]RULOPT1(I) & K <> J
                  WIND(K) = "*"
                Endif
              Next K 
            Endif
          Endif
        Next J
      Endif
    Endif
  Next I
Endif
[M:CSEL]ITMSEL = 0
For I = 0 To [M:CSEL]NBLIG-1
  If [M:CSEL]SELFLG(I) = 2
    [M:CSEL]ITMSEL += 1
  Endif
  If WIND(I) <> [M:CSEL]SELIND(I)
    [M:CSEL]SELIND(I) = WIND(I)
    Affzo [M:CSEL]SELIND(I)
  Endif 
Next I
Affzo [M:CSEL]ITMSEL
[M:CSEL]SELFLG(NOL) = WVALEUR
End
$ERR_CALQTY
Resume
