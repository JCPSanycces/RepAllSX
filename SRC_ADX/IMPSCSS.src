#<AdxTL>@(#)0.0.0.0 $Revision$ Import changement emplacements
Dbgaff###########################################################################
# IMPSCSS : Import spécifique des changements emplacements HCB 11/03/2005 #
# ----------------------------------------------------------------------- #
###########################################################################


$ACTION
If dim(GSTK_TRACE)>0 & GSTK_TRACE=2 & [L]ACTION<>"IMP_ZONE" & [L]ACTION<>"EXP_ZONE"
  GSTK_ACT=[L]ACTION : GSTK_PGM="IMPSCSS" : Gosub TRACE_DETAILLEE From STKIMP
Endif
Case [L]ACTION
  When "IMP_COMPILE"   : Gosub IMP_COMPILE
  When "IMP_TRTSUP"    : Gosub IMP_TRTSUP
  When "IMP_ZONE"      : Gosub IMP_ZONE
  When "AP_IMPORT"     : Gosub AP_IMPORT
  When "IMP_FERME"     : Gosub IMP_FERME
  #-----
  When "EXP_OUVRE"     : Gosub EXP_OUVRE   From IMPSCS
  When "EXPORT"        : Gosub EXPORT      From IMPSCS
  When "EXP_ZONE"      : Gosub EXP_ZONE    From IMPSCS
Endcase
Return


###########################################################################
#                                 IMPORT                                  #
###########################################################################


#-------------------------------------------------------------------------#
# Début de la génération du traitement WWIxxxxxx, appelé par le SUBIMPOBJ #
#-------------------------------------------------------------------------#
$IMP_COMPILE
Return


#-----------------------------------------------------------------------#
# Fin de la génération du traitement WWIxxxxxx, appelé par le SUBIMPOBJ #
#-----------------------------------------------------------------------#
$IMP_TRTSUP
Return


#-------------------------------------------------------------#
# Après chargement de la classe [F] effectué par le WWIxxxxxx #
# IMPFIC : Abréviation du fichier en cours SMH, SMD, STJ      #
#-------------------------------------------------------------#
$AP_IMPORT

Return


#-----------------------------------------------------------------#
# Début import, étiquette appelée directement depuis le SUBIMPOBJ #
#-----------------------------------------------------------------#
$OUVRE
#--- Bug 68893
If !clalev([M:SCS1]) Local Mask SCS1  [SCS1] : Endif
If !clalev([F:SRT])  Local File STKTRS [SRT] : Endif
If !clalev([F:DTR])  Local File DIETRS [DTR] : Endif
GABREV="SCS" : GFLAG=""
#----- Sélection de la transaction de changementg emplacement---#
Filter [SRT] Where SRTTYP=3 & ENAFLG=2 & BETFCYCOD = 1 & CHGEMPCOD = 2
Read [SRT] First
Filter [SRT]
If fstat
   If GTRACE<>""
     Call ECR_TRACE(mess(114,192,1),1) From GESECRAN
   Endif
   OK=0 : Return
Endif
GFLAG   = [F:SRT]SRTNUM
GSCSNUM = [F:SRT]SRTNUM    # hcb 89329

[F:SRT]SRGWAIFLG = 1 : # On force l'autorisation d'une réception à quai à "Non"
[F:SRT]PRNCOD1   = 1 : # On force l'impression d'étiquettes à "Non"
[F:SRT]PRNNBFLG1 = 1 : # On force le nbre d'impression à "Non"

Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0       # Ana
If fstat                                                    # Ana
   Raz [F:DTR]                                              # Ana
Endif                                                       # Ana


#-----
[L]ACTION="OUVRE"   : Gosub ACTION From GOBJSUB : Gosub DEFAUT From WOSCS
If !clalev([M:STA])  Local Mask STOANA [STA] : Endif
Gosub FLD_MODELE From TRTX3IMP
#----- Principaux contrôles sur le modèle -----#
If !find("[F:SGH]STOFCY(0)",[M:AOE2]ZONMSK1)
  #----- Le site de stockage est obligatoire -----#
  OK=0 : GERR=1 : GMESSAGE=mess(323,199,1)-"([F:SGH]STOFCY)" : Return
Elsif !find("[F:SGD]ITMREF(0)",[M:AOE2]ZONMSK1)
  #----- La référence article est obligatoire -----#
  OK=0 : GERR=1 : GMESSAGE=mess(323,199,1)-"([F:SGD]ITMREF)" : Return
Elsif !find("[F:SGD]PCU(0)",[M:AOE2]ZONMSK1)
  #----- L unité est obligatoire -----#
  OK=0 : GERR=1 : GMESSAGE=mess(323,199,1)-"([F:SGD]PCU)" : Return
Elsif !find("[F:SGD]STA(0)",[M:AOE2]ZONMSK1)
  #----- Le statut est obligatoire -----#
  OK=0 : GERR=1 : GMESSAGE=mess(323,199,1)-"([F:SGD]STA)"    : Return
Elsif !find("[F:SGD]LOC(0)",[M:AOE2]ZONMSK1)
  #----- L emplacement origine est obligatoire -----#
  OK=0 : GERR=1 : GMESSAGE=mess(323,199,1)-"([F:SGD]LOC)"    : Return
Endif

# hcb 31107 deb
#----- Principaux contrôles sur le modèle -----#
#      ce modele ne sert qu au changement d'emplacement
#        # Le site de destination est interdit pour contrer le transfert inter site
#        # Le sous traitant et l emplacement de sous traitance sont interdit pour contrer le
#          transfert sous traitant

If find("[F:SGH]FCYDES(0)",[M:AOE2]ZONMSK1)
  #----- Le site de destination est interdit -----#
  OK=0 : GERR=1 : GMESSAGE=mess(507,199,1)-"([F:SGH]FCYDES)" : Return
Elsif find("[F:SGH]BPSNUM(0)",[M:AOE2]ZONMSK1)
  #----- Le sous traitant est interdit -----#
  OK=0 : GERR=1 : GMESSAGE=mess(507,199,1)-"([F:SGH]BPSNUM)" : Return
Elsif find("[F:SGH]SCOLOC(0)",[M:AOE2]ZONMSK1)
  #----- L emplacement de sous traitance est interdit  -----#
  OK=0 : GERR=1 : GMESSAGE=mess(507,199,1)-"([F:SGH]SCOLOC)" : Return
Endif
# hcb 31107 fin

#----- Variables locales -----#
Local  Integer  J, K
Local  Char     SYMBOL2(30)
Local  Libelle  WTEST_CCE
#----- Gestion des textes (pas de texte pour l'instant !) -----#
Gosub DECLARE_TEXTE From TRTX3IMP
G_IMPORT=1 : Gosub OUVRE_TEXTE From IMPSCS
#----- Globales à definir pour import stock -----#
Global Char     GSTK_ACTION(20)                               : # Nom de l'action
Global Char     GSTK_BASTAB(20) : GSTK_BASTAB="[M:SCS1]NBLIG" : # Nom variable bas tableau
Global Libelle  GSTK_TRSTYP     : GSTK_TRSTYP=7               : # Type mouvement (M.704)
Global Libelle  GSTK_VCRTYP     : GSTK_VCRTYP=29              : # Type pièce (M.701)
Global Libelle  GSTK_TRACE      : GSTK_TRACE =1               : # Trace détaillée si =2

Global Libelle  GSTK_ERR                : # Indicateur d'erreur
Local  Char     WSTK_ITMREF(GLONITM), WSTK_STOFCY(GLONFCY)
Local  Libelle  WSTK_FLAG
Local  Char     WSTK_FILTRA(250)

#-----
If GSTOTRACE>2  GSTK_TRACE=2 : Endif
#-----
If GSTK_TRACE=2
  Call ECR_TRACE(mess(27,115,1)-"OUVRE"+space$(17)+"From IMPSCSS",0) From GESECRAN
Endif
#-----
GSTK_ACTION="OUVRE" : Gosub ACTION From STKIMP
Return


#--------------------------------------------------------------------------------------#
# Nouveau document à importer, appelé directement depuis le traitement généré WWIxxxxx #
#--------------------------------------------------------------------------------------#
$RAZCRE

If GSTK_TRACE=2
   GSTK_ACT="RAZCRE" : GSTK_PGM="IMPSCSS" : Gosub TRACE_DETAILLEE From STKIMP
Endif
GREP="C"
Raz  [M:SCS1]
Raz  [M:SGW]                                      # hcb 119840
If GSTK_TRACE=2
   GSTK_ACT="RAZCRE" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
Endif
[L]ACTION="RAZCRE"   : Gosub ACTION From GOBJSUB : Gosub DEFAUT From WOSCS
GSTK_ACTION="RAZCRE" : Gosub ACTION From STKIMP
Return


#------------------------------------------------------------------------------------#
# Chargement masques écrans, appelé directement depuis le traitement généré WWIxxxxx #
#------------------------------------------------------------------------------------#
$SAIMSK
If GREP="A"  Return : Endif
If GSTK_TRACE=2
   GSTK_ACT="SAIMSK" : GSTK_PGM="IMPSCSS" : Gosub TRACE_DETAILLEE From STKIMP
Endif

# hcb 91491 deb
    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
    If [F:SRT]SRTTYP <> 3 | [F:SRT]SRTNUM <> GSCSNUM
       Read [SRT]SRT0=3;GSCSNUM : If fstat Raz [F:SRT] : Endif
    Endif
# hcb 91491 fin

Case IMPFIC

  When "SGH"
    #----- Test rupture sur ligne document -----#
    If GSTK_NBLIG
      GSTK_ACTION="RUPT_LIGDOC" : Gosub ACTION From STKIMP : # Articles gérés stock
    Endif
    #-----
    Gosub IMPORT_TEXTE From IMPSCS : # Import des textes entête, pied
    Default File [SGH]
    If GSTK_TRACE=2
      GSTK_ACT="SAIMSK" : GSTK_PGM="W0SCS1" : Gosub TRACE_DETAILLEE From STKIMP
    Endif
    Default Mask [SCS1]
    Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
    Call SAIMSK("SGH","IMP_ZONE","SUBIMPOBJ") From W0SCS1
    If mkstat  NBERR+=1 : Call TRACE2(2,GMESSIMP,-10) From SUBIMPOBJ : Endif
    If GREP="A"
      REP="A" : Actzo [SCS1]VCRDES, STOFCY, IPTDAT, PJT, TRSFAM , LOCDESH
    Endif
    Setmode
    If GREP="A"  Return : Endif
    If mkstat  GREP="" : REP="" : mkstat=0 : GOK=0 : Return : Endif
    #----- Traitement des textes entête et pied -----#
    If GREP="C"  Gosub IMP_ZONE_TEXTE From IMPSCS : Endif
    #----- Traitement champs invisibles -----#
    If find("[F:SGH]TRSCOD(0)",[M:AOE2]ZONMSK1)
      [M:SCS1]TRSCOD=[F:SGH]TRSCOD
    Endif
    If find("[F:SGH]ENTCOD(0)",[M:AOE2]ZONMSK1)
      [M:SCS1]ENTCOD=[F:SGH]ENTCOD
    Endif
#                                                             # hcb X3-98706 deb
    [M:SCS1]LOTACT  = 0
    [M:SCS1]LOTACT  = func AFNC.ACTIV("LOT")
    [M:SCS1]LOTACT  +=1
#                                                             # hcb X3-98706 end
    #-----
    GSTK_TRSCOD=[M:SCS1]TRSCOD
    GSTK_ENTCOD=[M:SCS1]ENTCOD
  When "SGD"

    Local Char    LLOT
    Local Char    LSLO
    Local Char    LPAL
    Local Char    LCTR
    Local Char    LSTA
    Local Char    LLOC
    Local Char    LPCU
    Local Decimal LCOE
    Local Char    LSER
    Local Char    LQLY
    Local Char    LOWN
    Local Char    LSF1
    Local Char    LSF2
    Local Decimal LSTOCOU
    Local Char    LLPN(GLONLPN)     : #--- Issue X3-53322
#                                                                      # hcb 110327 deb
    Local    Integer J, WRET, WNBSERIE
    Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
    Global   Integer GSTJ
    GSTJ = 2
#                                                                      # hcb 110327 fin


    #----- Test rupture sur ligne document -----#
    If GSTK_NBLIG
      GSTK_ACTION="RUPT_LIGDOC" : Gosub ACTION From STKIMP : # Articles gérés stock
    Endif
    #-----
    Gosub IMPORT_TEXTE From IMPSCS : # Import des textes ligne

    #-----
    status=73
    Default File [SGD]
    If GSTK_TRACE=2
      GSTK_ACT="SAI_NBLIG" : GSTK_PGM="W0SCS1" : Gosub TRACE_DETAILLEE From STKIMP
    Endif
    Default Mask [SCS1]


    If [F:ITM]ITMREF<>[F:SGD]ITMREF
      Read [ITM] ITM0=[F:SGD]ITMREF
      If fstat  Raz [F:ITM] : Endif
    Endif
    If [F:ITF]ITMREF  <>[F:SGD]ITMREF | [F:ITF]STOFCY<>[F:SGH]STOFCY
       Read [ITF]ITF0 = [F:SGD]ITMREF; [F:SGH]STOFCY
       If fstat : Raz [F:ITF] : Endif
    Endif
# recherche ligne de stock et controles
    [L]WSTK_ITMREF=[F:SGD]ITMREF
    [L]WSTK_STOFCY=[F:SGH]STOFCY

#----- Constitution du filtre recherche stock à modifier -----#
    [L]WSTK_FILTRA='ITMREF="'+[L]WSTK_ITMREF+'" & STOFCY="'+[L]WSTK_STOFCY+'"'
    Raz WSTK_FLAG
    Raz GSTK_ERR
#----- Article géré en numéro de série  ce numéro doit être renseigné ----#
    If [F:ITM]SERMGTCOD = 3 & (!find("[F:SGD]SERNUM(0)",[M:AOE2]ZONMSK1) | [F:SGD]SERNUM="")
    #----- Article géré en no de série : Son no de série doit être renseigné -----#
          [L]WSTK_FLAG=2
          [L]WSTK_FILTRA=[L]WSTK_ITMREF-mess(155,193,1)-mess(431,182,1)
     Endif
#----- Article géré en lot : Le lot doit être renseigné ! -----#
    If  [F:ITM]LOTMGTCOD>1 & (!find("[F:SGD]LOT(0)"   ,[M:AOE2]ZONMSK1) | [F:SGD]LOT="")          # hcb 74208
          [L]WSTK_FLAG=2
          [L]WSTK_FILTRA=[L]WSTK_ITMREF-mess(612,197,1)
    Endif                                                                                         # hcb 74208
#----- Article géré en sous-lot : Le sous-lot doit être renseigné ! -----#
    If    [F:ITM]LOTMGTCOD>3 & (!find("[F:SGD]SLO(0)",[M:AOE2]ZONMSK1) | [F:SGD]SLO="")           # hcb 74208
          [L]WSTK_FLAG=2
          [L]WSTK_FILTRA=[L]WSTK_ITMREF-mess(613,197,1)
    Endif                                                                                        # hcb 74208
#----- Article géré par emplacement : L'emplacement doit être renseigné ! -----#
    If    [F:ITF]LOCMGTCOD>1 & (!find("[F:SGD]LOC(0)",[M:AOE2]ZONMSK1) | [F:SGD]LOC="")          # hcb 74208
          [L]WSTK_FLAG=2
          [L]WSTK_FILTRA=[L]WSTK_ITMREF-mess(614,197,1)
    Endif
#----- Filtre en fonction des caractéristiques renseignées -----#
          If find("[F:SGD]LOT(0)",[M:AOE2]ZONMSK1) & [F:ITM]LOTMGTCOD>1 & [F:SGD]LOT<>""
             [L]WSTK_FLAG=1
             LLOT = [F:SGD]LOT
             [L]WSTK_FILTRA-='& LOT="'+[F:SGD]LOT+'"'
          Endif
          If find("[F:SGD]SLO(0)",[M:AOE2]ZONMSK1) & [F:ITM]LOTMGTCOD>3 & [F:SGD]SLO<>""
             [L]WSTK_FLAG=1
             LSLO = [F:SGD]SLO
             [L]WSTK_FILTRA-='& SLO="'+[F:SGD]SLO+'"'
          Endif
          If find("[F:SGD]PALNUM(0)",[M:AOE2]ZONMSK1) & [F:SGD]PALNUM<>""
             LPAL = [F:SGD]PALNUM
             [L]WSTK_FILTRA-='& PALNUM="'+[F:SGD]PALNUM+'"'
          Endif
          If find("[F:SGD]CTRNUM(0)",[M:AOE2]ZONMSK1) & [F:SGD]CTRNUM<>""
             LCTR = [F:SGD]CTRNUM
             [L]WSTK_FILTRA-='& CTRNUM="'+[F:SGD]CTRNUM+'"'
          Endif
          If find("[F:SGD]STA(0)",[M:AOE2]ZONMSK1) & [F:SGD]STA<>""
             LSTA = [F:SGD]STA
             [L]WSTK_FILTRA-='& STA="'+[F:SGD]STA+'"'
          Endif
          If find("[F:SGD]LOC(0)",[M:AOE2]ZONMSK1) & [F:ITF]LOCMGTCOD>1 & [F:SGD]LOC<>""
             [L]WSTK_FLAG=1
             LLOC = [F:SGD]LOC
             [L]WSTK_FILTRA-='& LOC="'+[F:SGD]LOC+'"'
          Endif
          If find("[F:SGD]PCU(0)",[M:AOE2]ZONMSK1) & [F:SGD]PCU<>""
             LPCU = [F:SGD]PCU
             [L]WSTK_FILTRA-='& PCU="'+[F:SGD]PCU+'"'
          Endif
          If find("[F:SGD]PCUSTUCOE(0)",[M:AOE2]ZONMSK1) & [F:SGD]PCUSTUCOE<>0
             LCOE = [F:SGD]PCUSTUCOE
          Endif
          If LPCU <> ""
             If LCOE = 0 & LPCU = [F:ITM]STU
                LCOE = 1
             Endif
            [L]WSTK_FILTRA-='& PCUSTUCOE='+num$(LCOE)
          Endif
          If find("[F:SGD]SERNUM(0)",[M:AOE2]ZONMSK1) & find([F:ITM]SERMGTCOD,2,3) & [F:SGD]SERNUM<>""   # hcb 110327
             [L]WSTK_FLAG=1
             LSER = [F:SGD]SERNUM
             [L]WSTK_FILTRA-='& SERNUM="'+[F:SGD]SERNUM+'"'
          Endif
          If find("[F:SGD]QLYCTLDEM(0)",[M:AOE2]ZONMSK1) & [F:SGD]QLYCTLDEM <>""
             LQLY = [F:SGD]QLYCTLDEM
             [L]WSTK_FILTRA-='& QLYCTLDEM="'+[F:SGD]QLYCTLDEM+'"'
          Endif
          If find("[F:SGD]OWNER(0)",[M:AOE2]ZONMSK1) & [F:SGD]OWNER <>""
             LOWN = [F:SGD]OWNER
             [L]WSTK_FILTRA-='& OWNER="'+[F:SGD]OWNER+'"'
          Endif
          If find("[F:SGD]STOFLD1(0)",[M:AOE2]ZONMSK1) & [F:SGD]STOFLD1<>""
             LSF1 = [F:SGD]STOFLD1
             [L]WSTK_FILTRA-='& STOFLD1="'+[F:SGD]STOFLD1+'"'
          Endif
          If find("[F:SGD]STOFLD2(0)",[M:AOE2]ZONMSK1) & [F:SGD]STOFLD2<>""
             LSF2 = [F:SGD]STOFLD2
             [L]WSTK_FILTRA-='& STOFLD2="'+[F:SGD]STOFLD2+'"'
          Endif
          #--- Issue X3-53322
          If find("[F:SGD]LPNNUM(0)",[M:AOE2]ZONMSK1) & [F:SGD]LPNNUM<>""
             LLPN = [F:SGD]LPNNUM
             [L]WSTK_FILTRA-='& LPNNUM="'+[F:SGD]LPNNUM+'"'
          Endif
          #---
          If LOWN = ""                           # hcb 96017
             LOWN = WSTK_STOFCY                  # hcb 96017
          Endif                                  # hcb 96017
#----- Trace du filtre ligne de stock à modifier -----#
    If GSTK_TRACE=2
       If [L]WSTK_FLAG<2
          GSTK_MESS=mess(302,198,1)-":"-[L]WSTK_FILTRA              # filtre
          Call ECR_TRACE(GSTK_MESS,0) From GESECRAN
          If len([L]WSTK_FILTRA)>97-len(mess(302,198,1))
             GSTK_MESS=right$([L]WSTK_FILTRA,98-len(mess(302,198,1)))
             Call ECR_TRACE(GSTK_MESS,0) From GESECRAN
          Endif
       Else
          GSTK_MESS=[L]WSTK_FILTRA
          Call ECR_TRACE(GSTK_MESS,1) From GESECRAN
          GSTK_ERR=1
       Endif
    Elsif [L]WSTK_FLAG=2
       GSTK_MESS=[L]WSTK_FILTRA
       Call ECR_TRACE(GSTK_MESS,1) From GESECRAN
       GSTK_ERR=1
    Endif
#-----
    Local Integer LRET
    #--- Issue X3-53322 : Ajout LPN pour l'instant ""
    If [L]WSTK_FLAG<2
       LSTOCOU = func STKLIB.CLESTOFUN(WSTK_STOFCY,WSTK_ITMREF,LLOT,LSLO,LPAL,
&                     LCTR,LSTA,LLOC,LPCU,LCOE,LSER,LQLY,LOWN,LSF1,LSF2,"STO",LLPN)
       If LSTOCOU
# la ligne stock trouvée ne doit pas etre en inventaire
          Read [STO]STO0=WSTK_STOFCY;LSTOCOU
          If fstat
             Call ECR_TRACE(mess(49,125,1)-"STO"-num$(LSTOCOU),0) From GESECRAN  # Erreur lecture fichier
             GSTK_ERR=1
          Else
# ligne de stock en inventaire
             If [F:STO]CUNLOKFLG = 2
                GSTK_ERR=1
                Call ECR_TRACE(mess(126,184,1)-num$(LSTOCOU),0) From GESECRAN    # ligne de stock en inventaire
             Endif
# ligne de stock en attente de rangement
             If [F:STO]LOCCAT    = 2
                Raz LRET
   # Contrôle que la ligne de stock en attente de rangement est complète
                Call CTLPLFLOC([F:STO]ITMREF,"",LRET) From STKSOR
                If LRET<>0
                   GSTK_ERR=1
                   Call ECR_TRACE(mess(378,199,1)-mess(377,199,1)-num$(LSTOCOU),0) From GESECRAN  # stock en attente de rangement
                Endif
   # Si mouvement interne et changement d'emplacement non autorisé
   # Changement de statut et défractionnement interdit si stock non rangé
                If [M:SCS1]BETFCYCOD=1 & [F:SRT]CHGEMPCOD<>2 & LRET <> 0
                   GSTK_ERR=1
                 #traitement impossible ce stock est en attente de rangement
                   Call ECR_TRACE(mess(135,184,1)-num$(LSTOCOU),0) From GESECRAN
                Endif
             Endif
# Ligne de stock avec demande d'analyse
             If [F:STO]QLYCTLDEM<>""
   # Si changement de statut
                If  [F:SRT]CHGPCUCOD<>2 & ([F:SRT]CHGEMPCOD<>2 | [F:ITF]LOCMGTCOD<>2)
                    GSTK_ERR=1
                # changement de statut impossible sur un controle qualite
                    Call ECR_TRACE(mess(80,184,1)-num$(LSTOCOU),0) From GESECRAN
   # Sinon recherche de la ligne de demande d'analyse pour vérifier
   # que celle-ci n'a pas déjà été partiellement contrôlée
                Else
                    LRET = 0
                    For [QLD]QLD1 Where ITMREF=[F:STO]ITMREF & STOFCY=[F:STO]STOFCY
&                                     & VCRTYP=28 & VCRNUM=[F:STO]QLYCTLDEM
                        If   [F:QLD]LOT      =[F:STO]LOT
&                          & [F:QLD]SLO      =[F:STO]SLO
&                          & [F:QLD]SERNUM   =[F:STO]SERNUM
&                          & [F:QLD]STA      =[F:STO]STA
&                          & [F:QLD]LOC      =[F:STO]LOC
&                          & [F:QLD]PCU      =[F:STO]PCU
&                          & [F:QLD]PCUSTUCOE=[F:STO]PCUSTUCOE
&                          & [F:QLD]PALNUM   =[F:STO]PALNUM
&                          & [F:QLD]CTRNUM   =[F:STO]CTRNUM
&                          & [F:QLD]OWNER    =[F:STO]OWNER
&                          & [F:QLD]STOFLD1  =[F:STO]STOFLD1
&                          & [F:QLD]STOFLD2  =[F:STO]STOFLD2
                             If [F:QLD]QTYSTU=[F:STO]QTYSTU
                                LRET = 1
                                Break
                             Else
                                Break
                             Endif
                        Endif
                    Next
                    If LRET = 0
                       GSTK_ERR=1
                  # vous devez terminer ce controle pour acceder a ce stock
                       Call ECR_TRACE(mess(28,701)-mess(164,184,1)-num$(LSTOCOU),0) From GESECRAN
                    Endif
                Endif
             Endif
             If GSTK_ERR <> 0             # hcb 84038
                Gosub DELRESSTO
                GREP=""
                REP=""
                mkstat=0
                GOK=0
                Return
             Endif                        # hcb 84038
#                                                                                  # hcb 110327 deb
             If [F:ITM]SERMGTCOD = 4
# si la qty  importée est <> de la ligne de stock  le numero de serie ne peut etre à blanc
                 If [F:SGD]QTYPCU <> [F:STO]QTYSTU & [F:SGD]SERNUM = ""
                    GSTK_ERR=1
                  # Quantité importée  <>  quantitée de la ligne de stock le n° serie début doit etre renseigné
                    Call ECR_TRACE(mess(463,184,1)-":"-num$(LSTOCOU)-":"-num$([F:STO]QTYSTU)-":"-num$([F:SGD]QTYPCU),1) From GESECRAN
                 Elsif [F:SGD]QTYPCU <> [F:STO]QTYSTU
                       WNBSERIE = [F:SGD]QTYPCU
                       WNUMDEB  = [F:SGD]SERNUM
                       WNUMFIN  = [F:SGD]SERNUM
                       Read [STS]STS3=[F:STO]ITMREF;[F:STO]STOCOU;WNUMFIN
                       If fstat
                          # numéro de série inexistant
                          Call ECR_TRACE(mess(43,196,1)-num$(LSTOCOU)-":"-WNUMFIN,1) From GESECRAN
                          GSTK_ERR=1
                          Goto FIN_TST
                       Endif
                       If [F:STS]ISSDAT<>[0/0/0]
                          # numéro de série sorti par une autre piece
                          Call ECR_TRACE(mess(37,184,1)-num$(LSTOCOU)-":"-WNUMFIN,1) From GESECRAN
                          GSTK_ERR=1
                          Goto FIN_TST
                       Endif
                       If [F:STS]SDHNUM<>""
                          # numero de série alloué par une autre piece
                          Call ECR_TRACE(mess(443,184,1)-num$(LSTOCOU)-":"-WNUMFIN,1) From GESECRAN
                          GSTK_ERR=1
                          Goto FIN_TST
                       Endif
                       WRET = func STKLIB.REC_STOSERW([F:STO]ITMREF,WNUMFIN)
                       If WRET = 1
                          # numero de série en cours de traitement
                          Call ECR_TRACE(mess(449,184,1)-num$(LSTOCOU)-":"-WNUMFIN,1) From GESECRAN
                          GSTK_ERR=1
                          Goto FIN_TST
                       Endif
                       For J=2 To WNBSERIE
                           Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
                           If WRET=0
                              Read [STS]STS3=[F:STO]ITMREF;[F:STO]STOCOU;WNUMFIN
                              If fstat
                                 # numéro de série inexistant
                                 Call ECR_TRACE(mess(43,196,1)-num$(LSTOCOU)-":"-WNUMFIN,1) From GESECRAN
                                 GSTK_ERR=1
                                 Break
                              Endif
                              If [F:STS]ISSDAT<>[0/0/0]
                                 # numéro de série sorti par une autre piece
                                 Call ECR_TRACE(mess(37,184,1)-num$(LSTOCOU)-":"-WNUMFIN,1) From GESECRAN
                                 GSTK_ERR=1
                                 Break
                              Endif
                              If [F:STS]SDHNUM<>""
                                 # numero de série alloué par une autre piece
                                 Call ECR_TRACE(mess(443,184,1)-num$(LSTOCOU)-":"-WNUMFIN,1) From GESECRAN
                                 GSTK_ERR=1
                                 Break
                              Endif
                              WRET = func STKLIB.REC_STOSERW([F:STO]ITMREF,WNUMFIN)
                              If WRET = 1
                                 # numero de série en cours de traitement
                                 Call ECR_TRACE(mess(449,184,1)-num$(LSTOCOU)-":"-WNUMFIN,1) From GESECRAN
                                 GSTK_ERR=1
                                 Break
                              Endif
                              WNUMDEB = WNUMFIN
                           Else
                              # erreur sur incrementation des numéros de serie
                              Call ECR_TRACE(mess(476,197,1)-num$(LSTOCOU)-":"-WNUMFIN,1) From GESECRAN
                              GSTK_ERR=1
                              Break
                           Endif
                       Next J
$FIN_TST
                       If GSTK_ERR <> 0
                          Gosub DELRESSTO
                          GREP=""
                          REP=""
                          mkstat=0
                          GOK=0
                          Return
                       Endif
                       [F:SGD]SERNUMF = WNUMFIN
                 Endif
                 If GSTK_ERR <> 0
                    Gosub DELRESSTO
                    GREP=""
                    REP=""
                    mkstat=0
                    GOK=0
                    Return
                 Endif
             Endif
#                                                                                  # hcb 110327 fin
#alimentation ligne de document avec ligne de stock + calcul disponible
             Gosub ALI_DOC From SUBSCSB
          Endif
      Else

          GSTK_ERR=1
          #Call ECR_TRACE(mess(46,141,1)-WSTK_ITMREF-LLOT-LSLO-LSTA-LLOC-LPCU,1) From GESECRAN   # stock inexistant # hcb 100689
          Call ECR_TRACE(mess(46,141,1)-WSTK_ITMREF-LLOT-LSLO-LSTA-LLOC-LPCU-LLPN,1) From GESECRAN   # Issue 100690 - 2018-07-25 by MAE : ajout du LPN dans le message
          Gosub DELRESSTO  # hcb 84038
          GREP=""
          REP=""
          mkstat=0
          GOK=0
          Return
      Endif
    Endif

    If GSTK_ERR <> 0
       Gosub DELRESSTO
       GREP=""
       REP=""
       mkstat=0
       GOK=0
       Return
    Endif

# hcb 200405
    indice=nolign-1
    Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
    Call SAI_NBLIG("SGD","IMP_ZONE","SUBIMPOBJ") From W0SCS1
    If mkstat  NBERR+=1 : Call TRACE2(2,GMESSIMP,-10) From SUBIMPOBJ : Endif
    Setmode
    If mkstat
       Gosub DELRESSTO
       GREP=""
       REP=""
       mkstat=0
       GOK=0
       Return
    Endif
# hcb 200405

    #----- Traitement des textes entête et pied -----#
    If GREP="C"  Gosub IMP_ZONE_TEXTE From IMPSCS : Endif

  When "STJ"

#                                                                                              # hcb X3-98706 deb
    # ligne de stock associée à un LPN
    If [F:STO]LPNNUM <> "" & [F:STO]LOC <> [F:STJ]LOC
       # Stock associé à un no. contenant. Changement d'emplacement interdit
       #Call ECR_TRACE(mess(555,184,1)-num$(LSTOCOU),0) From GESECRAN
       Call ECR_TRACE(mess(555,184,1)-num$(LSTOCOU),1) From GESECRAN    # Issue 100690 - 2018-07-25 by MAE : Erreur pas en rouge
       GSTK_ERR=1
       GREP=""
       REP=""
       mkstat=0
       GOK=0
       If GSTJ = 2
          Raz GSTJ
          Gosub DELRESSTO
       Endif
       Return
    Endif
#                                                                                              # hcb X3-98706 fin

    GSTK_ACTION="SAIMSK" : Gosub ACTION From STKIMP
#                                                                                    # hcb 110327 deb
    If [F:ITM]SERMGTCOD = 4 & [F:SGD]QTYPCU <> [F:STJ]QTYPCU
       # numero de série en cours de traitement
       Call ECR_TRACE(mess(464,184,1)-":"-num$(LSTOCOU)-":"-num$([F:SGD]QTYPCU)-":"-num$([F:STJ]QTYPCU),1) From GESECRAN
       GSTK_ERR=1
       GREP=""
       REP=""
       mkstat=0
       GOK=0
       If GSTJ = 2
          Raz GSTJ
          Gosub DELRESSTO
       Endif
       Return
    Endif
#                                                                                     # hcb 110327 fin
Endcase
Return


#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
# --------------------------------------- #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#-----------------------------------------#
$IMP_ZONE
If GREP="A"  Return : Endif
If dim([L]WTST_CHAMP)<1  Local Libelle  WTST_CHAMP : Endif
Case IMPFIC
  When "SGH"

    Case IMPMSK
      When "SCS1"
        If find("[F:SGH]"+IMPZON+"(0)",[M:AOE2]ZONMSK1)
          If GSTK_TRACE=2
            GSTK_ACT="IMP_ZONE("+IMPZON+")" : GSTK_PGM="IMPSCSS"
            Gosub TRACE_DETAILLEE From STKIMP
          Endif
          If evalue("[M:SCS1]"+IMPZON+"("+num$(indice)+")")<>evalue("[F:SGH]"+IMPZON)
            Assign "[M:SCS1]"+IMPZON+"("+num$(indice)+")" With evalue("[F:SGH]"+IMPZON)
            IMPMOD=1
          Endif
          OK=0
        Endif
    Endcase
  When "SGD"
    If find("[F:SGD]"+IMPZON+"(0)",[M:AOE2]ZONMSK1)
      If GSTK_TRACE=2
        GSTK_ACT="IMP_ZONE("+IMPZON+")" : GSTK_PGM="IMPSCSS"
        Gosub TRACE_DETAILLEE From STKIMP
      Endif
      If evalue("[M:SCS1]"+IMPZON+"("+num$(indice)+")")<>evalue("[F:SGD]"+IMPZON)
        Assign "[M:SCS1]"+IMPZON+"("+num$(indice)+")" With evalue("[F:SGD]"+IMPZON)
        IMPMOD=1
      Endif
      OK=0
    Endif
  When "STJ"
    GSTK_ACTION="IMP_ZONE" : Gosub ACTION From STKIMP

Endcase
Return


#----------------------------------------------------------------------------#
# Enregistrement du document importé, appelé directement depuis le SUBIMPOBJ #
#----------------------------------------------------------------------------#
$VALID
If GSTK_TRACE=2
  GSTK_ACT='VALID(GREP="'+GREP+'")' : GSTK_PGM="IMPSCSS" : Gosub TRACE_DETAILLEE From STKIMP
Endif
If GREP=""  Raz GSTK_NBLIG : Return : Endif
[L]OK=1 : Raz GERREUR
If GREP="C"
  #-----
#  Gosub RUPT_LIGDOC                                  #hcb 2504
  GSTK_ACTION = "VALID" : Gosub ACTION From STKIMP    #hcb 2504
  If ![L]OK  GOK=0 : Goto FIN_GENSCS : Endif
  #-----
  If GSTK_TRACE=2
    GSTK_ACT="VERIF_CRE" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
  Endif
  [L]ACTION="VERIF_CRE"  : Gosub ACTION From GOBJSUB
  #--- Bug 71029
  If ![L]OK  GOK=0 : Goto FIN_GENSCS : Endif
  #If ![L]OK  GOK=0 : Gosub TRACE_CTL From SUBIMPOBJ : Goto FIN_GENSCS : Endif  # hcb 87116
  #---
Elsif GREP="A"
  If GSTK_TRACE=2
    GSTK_ACT="LIENS" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
  Endif
  [L]ACTION="LIENS" : Gosub ACTION From GOBJSUB
  If [M:SCS1]NBLIG=0  GOK=0 : Goto FIN_GENSCS : Endif
  [L]SYMBOL2="SCS"+[M:SCS1]VCRNUM : Lock=[L]SYMBOL2
  If fstat
    Call ECR_TRACE("$SCHGH"-[M:SCS1]VCRNUM-mess(10,100,1),1) From GESECRAN
    GOK=0 : Goto FIN_GENSCS
  Endif
  If GSTK_TRACE=2
    GSTK_ACT="VERF_ANU" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
  Endif
  [L]ACTION="VERF_ANU" : Gosub ACTION From GOBJSUB
  If ![L]OK
    If GMESSAGE<>""  Call ECR_TRACE(GMESSAGE,1) From GESECRAN : Raz GMESSAGE : Endif
    Unlock=[L]SYMBOL2
    GOK=0 : Goto FIN_GENSCS
  Endif
Endif
Call DEBTRANS From GLOCK
#-----
$TR_GENSCS
GOK=1
If GSTK_TRACE=2
  GSTK_ACT="Trbegin" : GSTK_PGM="" : Gosub TRACE_DETAILLEE From STKIMP
Endif
Trbegin [SGH], [SGD]
  Raz [F:SGH], [F:SGD]
  [F:SGH]=[M:SCS1]
  Default File [SGH]
  If GSTK_TRACE=2
    GSTK_ACT="INICRE" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
  Endif
  [L]ACTION="INICRE"   : Gosub ACTION From GOBJSUB
  If GOK<0  Goto ROLL_GENSCS  Elsif !GOK  Goto AB_GENSCS : Endif
  If GSTK_TRACE=2
    GSTK_ACT="Write [SGH]" : GSTK_PGM="" : Gosub TRACE_DETAILLEE From STKIMP
  Endif
  [F:SGH]CREUSR=GUSER
  [F:SGH]CREDAT=date$
  Write [SGH]
  If fstat  GOK=0 : Call FSTA("SGH") From GLOCK : Goto AB_GENSCS : Endif
  If GSTK_TRACE=2
    GSTK_ACT="CREATION" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
  Endif
  [L]ACTION="CREATION" : Gosub ACTION From GOBJSUB
  If GOK<0  Goto ROLL_GENSCS  Elsif !GOK  Goto AB_GENSCS : Endif
  If GSTK_TRACE=2
    GSTK_ACT="Commit" : GSTK_PGM="" : Gosub TRACE_DETAILLEE From STKIMP
  Endif
Commit
Case GREP
  When "C" : Call TRACE( 0,mess(29,701,1)-[F:SGH]VCRNUM)  From SUBIMPOBJ
  When "M" : Call TRACE( 1,mess(29,701,1)-[M:SCS1]VCRNUM) From SUBIMPOBJ : # Pas activé !
  When "A" : Call TRACE(-1,mess(29,701,1)-[M:SCS1]VCRNUM) From SUBIMPOBJ
Endcase
If GREP="C"
  If GSTK_TRACE=2
    GSTK_ACT="APRES_CRE" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
  Endif
  [L]ACTION="APRES_CRE" : Gosub ACTION From GOBJSUB
Elsif GREP="A"
  Unlock=[L]SYMBOL2
  If GSTK_TRACE=2
    GSTK_ACT="AP_ANNULE" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
  Endif
  [L]ACTION="AP_ANNULE" : Gosub ACTION From GOBJSUB
Endif
Goto FIN_GENSCS
#-----
$ROLL_GENSCS
If GSTK_TRACE=2
  GSTK_ACT="Rollback" : GSTK_PGM="" : Gosub TRACE_DETAILLEE From STKIMP
Endif
Rollback
Call ROLL From GLOCK
If GROLL
  If GREP="C"
    If GSTK_TRACE=2

      GSTK_ACT="AB_CREATION" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
    Endif
    [L]ACTION="AB_CREATION" : Gosub ACTION From GOBJSUB : Goto FIN_GENSCS
  Elsif GREP="A"
    Unlock=[L]SYMBOL2
  Endif
  Goto FIN_GENSCS
Else
  Goto TR_GENSCS
Endif
#-----
$AB_GENSCS
If GSTK_TRACE=2
  GSTK_ACT="Rollback" : GSTK_PGM="" : Gosub TRACE_DETAILLEE From STKIMP
Endif
Rollback
If GREP="C"
  If GSTK_TRACE=2
    GSTK_ACT="AB_CREATION" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
  Endif
  [L]ACTION="AB_CREATION" : Gosub ACTION From GOBJSUB : Goto FIN_GENSCS
Elsif GREP="A"
  Unlock=[L]SYMBOL2
Endif
#-----
$FIN_GENSCS
Return


#-------------------------------#
# Rupture sur ligne de document #
#-------------------------------#
$RUPT_LIGDOC
If GSTK_TRACE=2
  GSTK_ACT="RUPT_LIGDOC(STJ="+vireblc(mess((GSTK_NBLIG>0)+1,1,1),2)+")"
  GSTK_PGM="IMPSCSS" : Gosub TRACE_DETAILLEE From STKIMP
Endif
Local Integer WSTOMGTCOD

If [F:ITM]ITMREF<>[M:SCS1]ITMREF([M:SCS1]NBLIG-1)
   Read [ITM] ITM0=[M:SCS1]ITMREF([M:SCS1]NBLIG-1) : If fstat  Raz [F:ITM] : Endif
Endif
WSTOMGTCOD = [F:ITM]STOMGTCOD

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITM]STOMGTCOD > 1
   If [F:ITF]STOFCY <> WSTK_STOFCY | [F:ITF]ITMREF <> [M:SCS1]ITMREF([M:SCS1]NBLIG-1)
      Read [ITF]ITF0 = [M:SCS1]ITMREF([M:SCS1]NBLIG-1);WSTK_STOFCY
      If fstat
         Raz [F:ITF]
      Endif
   Endif
   WSTOMGTCOD = [F:ITF]STOMGTCOD
Endif

If WSTOMGTCOD>1
   GSTK_ACTION="RUPT_LIGDOC" : Gosub ACTION From STKIMP
Endif
Raz GSTK_NBLIG
Return


#------------#
# Fin import #
#------------#
$IMP_FERME
If GSTK_TRACE=2
  GSTK_ACT="FERME" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
Endif
[L]ACTION="FERME"       : Gosub ACTION From GOBJSUB : Gosub DEFAUT From WOSCS
GSTK_ACTION="IMP_FERME" : Gosub ACTION From STKIMP
Kill GSTK_ACTION, GSTK_BASTAB, GSTK_TRSTYP, GSTK_VCRTYP, GSTK_TRACE
Return


$DELRESSTO
If [M:SGW]NBLIG  <> 0            # hcb 74208 et 81076
   Local Integer WTRBEGIN
# Si pas de transaction en cours
   If adxlog<>1
      GOK=1
      Trbegin [STO]
      WTRBEGIN=1
   Endif
  Local Integer II                                                          # hcb 119840
  For II=0 To [M:SGW]NBLIG-1                                                # hcb 119840
      If [M:SGW]WSTOSEQ(II)>0                                               # hcb 119840
         Readlock [STO]STO0=[F:SGH]STOFCY;[M:SGW]WSTOCOU(II)                # hcb 119840
         If !fstat
            [F:STO]CUMWIPQTY -= [M:SGW]WWIPQTY(II)                          # hcb 119840
            [F:STO]CUMWIPQTA -= [M:SGW]WWIPQTA(II)                          # hcb 119840
            # Suppression qté en cours de traitement
            Call DEL_STOWIPW([F:STO]STOCOU,[M:SGW]WWIPQTY(II)) From STKLIB  # hcb 119840
            Rewrite [F:STO]
         Endif
                #                                                                  # hcb 110327 deb
         If [F:STO]ITMREF <> [F:ITM]ITMREF
            Readlock [ITM]ITM0=[F:STO]ITMREF
            If fstat
               Raz [F:ITM]
            Endif
         Endif
         If [F:ITM]SERMGTCOD = 4 & [M:SGW]WSERNUM(II) <> ""
            Local Integer WRET
            Raz WRET
            Call DEL_STOSERW([F:STO]ITMREF,[M:SGW]WSERNUM(II),[M:SGW]WQTYSTUDES(II),WRET) From STKLIB
         Endif
     #                                                                  # hcb 110327 end
       Endif                                                                 # hcb 119840
  Next                                                                      # hcb 119840

# Si on a ouvert une transaction
   If WTRBEGIN=1
      Commit
      Raz WTRBEGIN
   Endif
Endif                              # hcb 74208
Return

