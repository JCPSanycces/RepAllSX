#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################
#             BUSINESS INTELLIGENCE                      #
#      GESTION des règles de synchronistation            #
#                                                        #
# Action appelées pour la BI : VENTES                    #
#   Variable Locale contenant la table de fait : table   #
#   Variable Locale contenant la dimension     : table   #
#                                                        #
##########################################################

$ACTION
Case ACTION
  When "DEBUT_FAT"        : Gosub DEBUT_FAT
  When "FIN_FAT"          : Gosub FIN_FAT
  When "DEBUT_DIM"        : Gosub DEBUT_DIM
  When "FIN_DIM"          : Gosub FIN_DIM
Endcase
Return

##############################################
## DEBUT_FAT : Avant éxécution Table de fait
##############################################
$DEBUT_FAT
Gosub DEBUT_FAT From TRTVENBI
Return

##############################################
## FIN_FAT   : Après éxécution Table de fait
##############################################
$FIN_FAT
Gosub FIN_FAT   From TRTVENBI
Return

##############################################
## DEBUT_DIM : Avant éxécution Dimension
##############################################
$DEBUT_DIM
Return

##############################################
## FIN_DIM   : Après éxécution Dimension
##############################################
$FIN_DIM
Return

