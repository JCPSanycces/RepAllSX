###                     WMESS3=":"-mess(5,10935,1)-[F:DML]EMP-"/"-mess(33,10717,1)-[F:DEM]STG : #  matricule / Stage
##                      WMESS1=""
##                      WMESS3=mess(5,10935,1)-[F:DML]EMP-[F:ID]NAM-[F:ID]SRN-"/": #  matricule / Stage
##                      WMESS3-=mess(33,10717,1)-[F:DEM]STG-[F:STG]DES: #  matricule / Stage
##                      If [F:DEM]CODCSI<>"" Then WMESS3-="/"-mess(138,10717,1)-[F:DEM]CODCSI : Endif :# Parcours
##                      If dim([M:GDEM]SIMUL)>0 & [M:GDEM]SIMUL=2 Then
###                       Call ECR_TRACE(mess(202,10717,1)-" "-":"-mess(5,10935,1)-[F:DML]EMP-"/"-mess(33,10717,1)-[F:DEM]STG,0) From GESECRAN : # Demande de formation : matricule / Stage
##                       WMESS2=" "
##                      Else
###                       Call ECR_TRACE(mess(202,10717,1)-[F:DEM]DEMNUM-":"-mess(5,10935,1)-[F:DML]EMP-"/"-mess(33,10717,1)-[F:DEM]STG,0) From GESECRAN : # Demande de formation : matricule / Stage
##                       WMESS2=[F:DEM]DEMNUM
##                      Endif
##                      Call ECR_TRACE(WMESS1-WMESS2-WMESS3,0) From GESECRAN : # Demande de formation : matricule / Stage
##                      NBENREG2 += 1
##  #                  Next
##                  Endif
###                  If !GOK Then
###                    Call ECR_TRACE(mess(59,123,1)-mess(202,10717,1)-[F:DEM]DEMNUM,0) From GESECRAN : # Création Demande de formation
###                  Endif
##                Endif
##              Endif
##            Endif
##          Endif
##        Next
##      Endif
##      If GOK Then
##        Rollback
##      Else
##        # SEGAY 31/07/12 FQ81491 US602
###        Commit
##        If dim([M:GDEM]SIMUL)>0 & [M:GDEM]SIMUL=2 Then
##          Rollback
##        Else
##          Commit
##        Endif
##        Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
##        If NBENREG2>0 Then
##          Call ECR_TRACE(mess(150,10717,1)-":"-num$(NBENREG2),0) From GESECRAN : # Nombre de demandes pour parcours individualisé
##        Else
##          Call ECR_TRACE(mess(148,10717,1),0) From GESECRAN : # Aucune demande à traiter
##        Endif
##      Endif
##    Endif
##  Endif
Return
#LIPET - 2017-06-21 - X3-35995 - START
$OUVRE_CRE_DEM

  If clalev([F:DEM])=0 : Local File DEMANDE   [DEM]  : Endif
  If clalev([F:DML])=0 : Local File DEMLIG    [DML]  : Endif
  If clalev([F:ID])=0  : Local File EMPLOID   [ID]   : Endif
  If clalev([F:STG])=0 : Local File STAGE     [STG]  : Endif
  If clalev([F:HRSES])=0 : Local File SESSIONS  [HRSES]  : Endif
  If clalev([F:FCY])=0 : Local File FACILITY  [FCY]  : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR  [HRCTR]  : Endif
  If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA]  : Endif
Return

#**
#* Sous-pro générique de création demande
#*
#* @param CODSTG  : code stage
#* @param ORI     : origine
#* @param PIO     : priorité
#* @param REF     : matricule demandeur
#* @param CTR     : contrat demandeur
#* @param NBREMP  : nombre participants par ligne
#* @param PDEMNUM : numéro de demande
#* @param PNUMLIG : numéro de ligne
#* @param REFNUM  : matricule participant
#* @param CTRNUM  : contrat participant
#* @param CODSES  : code session
#* @param DOM     : domaine demande
#* @param THM     : thème demande
#* @param CATACN  : catégorie d'action
#* @param NATFIS  : nature fiscale
#* @param STRDATS : date début souhaitée
#* @param ENDDATS : date fin souhaitée
#* @param STRDAT  : date début
#* @param CODCSI  : code parcours
#* @param ORIDEM  : origine demande
#* @param FLGPRO  : période professionnalisation O/N
#* @param JOBPOT  : emploi type
#* @param POT     : poste
#* @param CATFRT  : catégorie 2483
#* @param SEX     : sexe du salarié
#* @param AGE     : tranche d'âge
#* @param SRV     : service
#* @param FCY     : site
#* @param PRENREF : motif de refus
#* @param TYPFRT  : dispositif utilisé
#* @param TRACE   : trace O/N
#* @param FLG_ACTCTR  : contrat participants non encore actif  O/N 93303
#* @param NBENREG : nombre de lignes créées
#* @param LRET    : variable retour : 0=OK, 1=KO
#*!
Subprog CRE_DEM(CODSTG,ORI,PIO,REF,CTR,CODSES,DOM,THM,CATACN,NATFIS,STRDATS,ENDDATS,STRDAT,CODCSI,ORIDEM,FLGPRO,CMTDEM,PDEMNUM,PNUMLIG,
&               NBREMP,REFNUM,CTRNUM,JOBPOT,POT,CATFRT,SEX,AGE,SRV,FCY,STADML,PRENREF,TYPFRT,TRACE,FLG_ACTCTR,NBENREG,LRET)

Value    Char    CODSTG(),REF(),CTR(),CODCSI(),CODSES(),REFNUM()(0..),CTRNUM()(0..)
Variable Char    DOM(),THM()
Variable Char    CATACN(),NATFIS()         : # JML 08/09/15
Variable Char    JOBPOT()(0..),POT()(0..),CATFRT()(0..),AGE()(0..),SRV()(0..),FCY()(0..)
Variable Char    PRENREF()(0..)
Variable Char    TYPFRT()(0..)               : # JML 08/09/15
Variable Integer SEX(0..),STADML(0..)
Value    Integer ORI,PIO,NBREMP(0..),FLGPRO,ORIDEM,TRACE,FLG_ACTCTR : # 93303
Variable Date    STRDATS,ENDDATS
Value    Date    STRDAT
Value    Clbfile CMTDEM()
Variable Char    PDEMNUM()
Variable Integer PNUMLIG(0..)
Variable Integer NBENREG,LRET
Local    Char    DEMNUM(GLONVCR)
Local    Integer IL,SAV_GOK
Local Char       CRITACTCTR(255) : # 93303

  Gosub OUVRE_CRE_DEM
  # Pour avoir ID du demandeur (si compteur à le site du demandeur)
  Call LECTURE("EML",REF,"") From CONTOBJ

  # Pour avoir CTR du demandeur (si compteur à le site du demandeur)
  Filter [HRCTR] Where [HRCTR]REFNUM=REF and [HRCTR]CTRNUM=CTR
&                and [HRCTR]CTRDAT<=date$
&                and ([HRCTR]XITDAT=[0/0/0] or [HRCTR]XITDAT>=date$)
  Read [HRCTR]CTR0 Last
  Filter [F:HRCTR]
  DEMNUM = func CALC_DEMNUM(LRET) : # Calcul n° demande
  # 93303
  [L]CRITACTCTR="([F:HRCTR]CTRDAT<=[L]STRDAT | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=[L]STRDAT))"
  If FLG_ACTCTR : [L]CRITACTCTR="1=1" : Endif
  # END 93303

  If LRET=0 Then
    # En-tête demande
    Raz [F:DEM]
    [F:DEM]DEMNUM      = DEMNUM             : # Numéro demande
    [F:DEM]STG         = CODSTG             : # Stage
    [F:DEM]DATDEM      = date$              : # Date demande
    [F:DEM]PIO         = PIO                : # Priorité
    [F:DEM]ORIDEM      = ORIDEM             : # Origine demande = parcours
    [F:DEM]ORI         = ORI                : # Origine = individuelle ou hiérarchique
    [F:DEM]REFNUM      = REF                : # Matricule demandeur
    [F:DEM]CTR         = CTR                : # Contrat demandeur
    [F:DEM]SES         = CODSES             : # Session
    [F:DEM]DOM         = DOM                : # Domaine
    [F:DEM]THM         = THM                : # Thème
    # Segay 02/02/11 bug 71254
    [F:DEM]DESCATACN   = CATACN             : # Catégorie d'action
    [F:DEM]DESNATFIS   = NATFIS             : # Nature fiscale
    [F:DEM]DATSTR      = STRDATS            : # Date début souhaitée
    [F:DEM]DATEND      = ENDDATS            : # Date fin souhaitée
    [F:DEM]CODCSI      = CODCSI             : # Code parcours
    [F:DEM]FLGPRO      = FLGPRO             : # Période professionnalisation
    [F:DEM]FLGPLF      = 1                  : # Hors plan
    Call LECTURE("STG", CODSTG, "") From CONTOBJ
    If [F:STG]COD<>"" Then
      # FQ72868 - MABON 15/04/11 - Récupération Hors plan
      # FQ93180 - SEGAY 24/10/13 - Initialisation FLGPLF <> 0
      If [F:STG]FLGPLF <> 0
         [F:DEM]FLGPLF    = [F:STG]FLGPLF
      Else
         [F:DEM]FLGPLF    = 1
      Endif
      If DOM="" Then
        [F:DEM]DOM     = [F:STG]DOM         : # Domaine
      Endif
      If THM="" Then
        [F:DEM]THM     = [F:STG]THM         : # Thème
      Endif
      # Segay 02/02/11 bug 71254
#      If CATACN=0 Then
      If CATACN=""   : # JML 08/09/15
        [F:DEM]DESCATACN = [F:STG]CATACN    : # Catégorie d'action
      Endif
#      If NATFIS=0 Then
      If NATFIS=""  : # JML 08/09/15
        [F:DEM]DESNATFIS = [F:STG]NATFIS    : # Nature fiscale
      Endif
      # Segay 05/01/12 79052 Si on est en origine saisie=1 (Portail) on garde ces dates
      If STRDATS=[0/0/0] & ORIDEM <> 1 Then
          [F:DEM]DATSTR    = [F:STG]STRVLY    : # Date début
          [F:DEM]DATEND    = [F:STG]ENDVLY    : # Date fin
      Endif
    Endif
    Call LECTURE("HRSES", CODSES, "") From CONTOBJ
    If [F:HRSES]COD<>"" Then
      If DOM="" Then
        [F:DEM]DOM     = [F:HRSES]DOM         : # Domaine
      Endif
      If THM="" Then
        [F:DEM]THM     = [F:HRSES]THM         : # Thème
      Endif
      If STRDATS=[0/0/0] Then
        Filter [F:SEJ] Where SES=[F:HRSES]COD Order By DAT
        Read [F:SEJ] First : [F:DEM]DATSTR = [F:SEJ]DAT : # Date début session
        Read [F:SEJ] Last  : [F:DEM]DATEND = [F:SEJ]DAT : # Date fin session
        Filter [F:SEJ]
      Endif
    Endif

    # JML 08/09/15 Not needed anymore
#    If [F:DEM]DESCATACN=0 Then
#      [F:DEM]DESCATACN=len(mess(0,453,1))   : # Non défini
#    Endif
#    If [F:DEM]DESNATFIS=0 Then
#      [F:DEM]DESNATFIS=len(mess(0,452,1))   : # Non défini
#    Endif
    [F:DEM]CMT         = CMTDEM
    [F:DEM]CREDAT      = date$              : # Date création
    [F:DEM]CRETIM      = time               : # Heure création
    [F:DEM]CREUSR      = GUSER              : # Créateur

# SEGAY 31/07/12 FQ81491 US602
#    Write [F:DEM]
#    If fstat Then LRET=1 : Endif
    If dim([M:GDEM]SIMUL)<=0 | [M:GDEM]SIMUL=1 Then
      Write [F:DEM]
      If fstat Then LRET=1 : Endif
    Endif
    # Lignes demande
    If LRET=0 Then
      # Réinitialiser les paramètres pour le retour portail
      NATFIS  = [F:DEM]DESNATFIS
      CATACN  = [F:DEM]DESCATACN
      DOM     = [F:DEM]DOM
      THM     = [F:DEM]THM
      PDEMNUM = [F:DEM]DEMNUM
      STRDATS = [F:DEM]DATSTR
      ENDDATS = [F:DEM]DATEND

      IL=0
      While IL<=dim(NBREMP)-1 & NBREMP(IL)>0
        Raz [F:DML]
        [F:DML]DEMNUM    = [F:DEM]DEMNUM    : # Numéro demande
        [F:DML]NUMLIG    = IL               : # N° de ligne
        [F:DML]NBREMP    = NBREMP(IL)       : # Nombre participants
        [F:DML]EMP       = REFNUM(IL)       : # Matricule
        [F:DML]CTRNUM    = CTRNUM(IL)       : # Contrat
        [F:DML]JOBPOT    = JOBPOT(IL)       : # Emploi type
        [F:DML]POT       = POT(IL)          : # Poste
        [F:DML]CATFRT    = CATFRT(IL)       : # Catégorie 2483
        [F:DML]SRV       = SRV(IL)          : # Service
        [F:DML]FCY       = FCY(IL)          : # Site
        # FQ72318 - MABON 11/03/11 - Prise en compte date d'effet
        If NBREMP(IL)=1 Then
         # 93303
#          Filter [F:CTR] Where CTRNUM=[L]CTRNUM(IL) & REFNUM=[L]REFNUM(IL)
#&                           & (CTRDAT<=[L]STRDAT | ([F:CTR]RETDATEFF<>[0/0/0] & [F:CTR]RETDATEFF<=[L]STRDAT)) Order By CTRDAT Desc
          Filter [F:HRCTR] Where CTRNUM=[L]CTRNUM(IL) & REFNUM=[L]REFNUM(IL)
&                           & evalue([L]CRITACTCTR) Order By CTRDAT Desc
         #END 93303
          Read [F:HRCTR] First
          If !fstat Then
            If FCY(IL)="" Then
              [F:DML]FCY   = [F:HRCTR]ETRFCY  : # Site
            Endif
            Read [FCY]FCY0=[F:DML]FCY
            If !fstat Then
              [F:DML]CPY   = [F:FCY]LEGCPY  : # Société
            Endif
            If SRV(IL)="" Then
              [F:DML]SRV   = [F:HRCTR]ETRSRV  : # Service
            Endif
            If CATFRT(IL)="" Then
              Call CAT2483(REFNUM(IL),CTRNUM(IL),[F:DML]CATFRT) From SUBDEM : # Catégorie 2483
            Endif
            If JOBPOT(IL)="" Then
              [F:DML]JOBPOT= [F:HRCTR]JOBPOT  : # Emploi type
            Endif
            If POT(IL)="" Then
              [F:DML]POT   = [F:HRCTR]POT     : # Poste
            Endif
          Endif
          Filter [F:HRCTR]
        Endif
        If NBREMP(IL)=1 & [F:DML]EMP <> ""
          Call LECTURE("EML",[F:DML]EMP,"") From CONTOBJ
          [F:DML]SEX       = SEX(IL)          : # Sexe
          If SEX(IL)=0 Then
            [F:DML]SEX     = [F:ID]SEX
          Endif
          [F:DML]AGE       = AGE(IL)          : # Tranche d'âge
          If AGE(IL)="" Then
            [F:DML]AGE     = func CALC_AGE([F:ID]DATBRN)
          Endif
        Else
           [F:DML]SEX       = SEX(IL)          : # Sexe
           [F:DML]AGE       = AGE(IL)          : # Tranche d'âge
        Endif
        [F:DML]DESTYPFRT = TYPFRT(IL)       : # Dispositif
        If TYPFRT(IL)="" & [F:STG]COD<>"" : # JML 08/09/15
          [F:DML]DESTYPFRT = [F:STG]TYPFRT
        Endif

        # FQ80186 - MABON 23/03/12 - Si création demandes en masses, le statut est directement positionné à Acceptée
        # Sinon, on calcule en fonction de l'origine
        If STADML(IL)=0 Then
          If [F:DEM]ORI=1 Then : # Origine = individuelle
            [F:DML]STA     = 1                : # Statut = Saisie
          Elsif [F:DEM]ORI=2   : # Origine = hiérarchique
            [F:DML]STA     = 2                : # Statut = En cours
          Endif
        Else
          [F:DML]STA       = STADML(IL)
        Endif
        [F:DML]FLGINS    = 1                : # Suivi = Saisi

# SEGAY 31/07/12 FQ81491 US602
#        Write [F:DML]
        If dim([M:GDEM]SIMUL)<=0 | [M:GDEM]SIMUL=1 Then
          Write [F:DML]
        Endif
        If fstat Then
          LRET=1 : Break
        Else
          If TRACE=2 Then
# SEGAY 31/07/12 FQ81491 US602
#            Call ECR_TRACE(mess(202,717,1)-[F:DEM]DEMNUM-":"-mess(5,2281,1)-[F:DML]EMP-"/"-mess(33,717,1)-[F:DEM]STG,0) From GESECRAN : # Demande de formation : matricule / Stage
            If dim([M:GDEM]SIMUL)>0 & [M:GDEM]SIMUL=2 Then
            # FQ84252 - SEGAY 04/09/12 - Prise en compte multi contrat
#              Call ECR_TRACE(mess(202,717,1)-" "-":"-mess(5,2281,1)-[F:DML]EMP-"/"-mess(33,717,1)-[F:DEM]STG,0) From GESECRAN : # Demande de formation : matricule / Stage
              # Demande de formation : matricule / Contrat / Stage
              Call ECR_TRACE(mess(202,10717,1)-" "-":"-mess(5,10935,1)-[F:DML]EMP-"/"-mess(72,10720,1)-[F:DML]CTRNUM-"/"-mess(33,10717,1)-[F:DEM]STG,0) From GESECRAN
            Else
            # FQ84252 - SEGAY 04/09/12 - Prise en compte multi contrat
#              Call ECR_TRACE(mess(202,717,1)-[F:DEM]DEMNUM-":"-mess(5,2281,1)-[F:DML]EMP-"/"-mess(33,717,1)-[F:DEM]STG,0) From GESECRAN : # Demande de formation : matricule / Stage
              # Demande de formation : matricule / Contrat / Stage
              Call ECR_TRACE(mess(202,10717,1)-[F:DEM]DEMNUM-":"-mess(5,10935,1)-[F:DML]EMP-"/"-mess(72,10720,1)-[F:DML]CTRNUM-"/"-mess(33,10717,1)-[F:DEM]STG,0) From GESECRAN
            Endif
          Endif
          # Réinitialiser les paramètres pour le retour portail
          PNUMLIG(IL) = [F:DML]NUMLIG
          JOBPOT(IL)  = [F:DML]JOBPOT
          POT(IL)     = [F:DML]POT
          CATFRT(IL)  = [F:DML]CATFRT
          SEX(IL)     = [F:DML]SEX
          AGE(IL)     = [F:DML]AGE
          SRV(IL)     = [F:DML]SRV
          FCY(IL)     = [F:DML]FCY
          TYPFRT(IL)  = [F:DML]DESTYPFRT
          PRENREF(IL) = [F:DML]RENREF
          NBENREG += 1
        Endif
        IL += 1
      Wend
      SAV_GOK=GOK : Gosub WORKFLOW : GOK=SAV_GOK
    Endif
  Endif
End
#LIPET - 2017-06-21 - X3-35995 - END
