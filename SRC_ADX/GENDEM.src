# BUG : 91564
$GEN_DEM_HABILIT
Local Integer W_NBENREG1 : W_NBENREG1=0

# on passe w_ok et W_NBENREG1 au lieu des variables GOK et NBENREG1. on réassigne après traitement.
# GOK maj uniquement sur erreur

  If GOK=0
      DOM="" : THM=""
#      CATACN=0 : NATFIS=0
      CATACN="" : NATFIS=""    : # JML 08/09/15
      STRDATS=[0/0/0] : ENDDATS=[0/0/0]
      Call CRE_DEM([M:GDEM]STGDEM,ORI,1,REF,func CALC_CTR(REF,GCURLEG),"",DOM,THM,CATACN,NATFIS,STRDATS,ENDDATS,date$,"",3,1,"",DEMNUM,PNUMLIG,
&                    NBREMP,REFNUM,CTRNUM,JOBPOT,POT,CATFRT,SEX,AGE,SRV,FCY,STADML,RENREF,TYPFRT,2,[L]FLG_ACTCTR,W_NBENREG1,GOK)
      NBENREG1+=W_NBENREG1
  Endif
# end 91564
Return
