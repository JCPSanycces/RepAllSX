#&                               & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>date$)
                For [HRCTR] Where [F:HRCTR]REFNUM=[F:ID]REFNUM & evalue([L]CRITACTCTR)
&                              & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>date$)
                # End 93303

                  Call LECTURE("FCY", [F:HRCTR]ETRFCY, "") From CONTOBJ
                  LCPY=""
                  If !fstat Then LCPY=[F:FCY]LEGCPY Endif
                  If evalue(CRITCPY) & evalue(CRITFCY) Then
                   #* SEGAY 26/06/12 81085 US500
                   WLEGCTR =""
                   Call CRTLEG([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,WLEGCTR)
#                  MABOS-#MABOS-07/11/12-FQ 81085-US927 : Add Legislation (mandatory) in window
#                   If (WLEG <> "" & WLEG <> WLEGCTR ) | ([M:GDEM]LEG <> WLEGCTR) Then
                   If ([M:GDEM]LEG <> WLEGCTR) Then
                    # Nothing to do
                   Else
                   #* END 81085 US500
            # FQ84252 - SEGAY 04/09/12 - Prise en compte multi contrat
#                   OKCTR=2 : Break
                    AUZCFY = func SUBHRSES.GET_AUZ(LCPY, [F:HRCTR]ETRFCY, "GENDEM")
                    If AUZCFY=2 Then
                      # bug 91564
                      #ADNGO - 2017-11-21 - START
                      REFNUMTMP(W_NBTOT)=[F:ID]REFNUM
                      W_NBTOT+=1
                      #ADNGO - 2017-11-21 - END
                      #ADNGO - 2017-11-21 - START
                      #If NUMDML>WMAXLINES
                      If IM>WMAXLINES
                      #ADNGO - 2017-11-21 - END
                      #ADNGO - 2017-11-21 - START
                      # on génère une nouvelle demande
