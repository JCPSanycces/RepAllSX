# bug : 91564
# AJOUT FONCTIONS
$SET_DEM_NUM
  DEMNUM = func CALC_DEMNUM(GOK) : # Calcul n° demande
Return


$SET_ONE_LINE
  Raz [F:DML]
  [F:DML]DEMNUM    = [F:DEM]DEMNUM    : # Numéro demande
  [F:DML]NUMLIG    = NUMDML           : # N° de ligne
  [F:DML]NBREMP    = 1                : # Nombre participants
  [F:DML]EMP       = [F:HAB]REFNUM    : # Matricule

  [F:DML]CTRNUM    = [F:HRCTR]CTRNUM  : # Contrat
  Read [FCY]FCY0=[F:HRCTR]ETRFCY
  If !fstat Then
    [F:DML]CPY     = [F:FCY]LEGCPY  : # Société
  Endif
  [F:DML]SRV       = [F:HRCTR]ETRSRV  : # Service
  [F:DML]FCY       = [F:HRCTR]ETRFCY  : # Site
  Call CAT2483([F:HAB]REFNUM,[F:HRCTR]CTRNUM,[F:DML]CATFRT) From SUBDEM : # Catégorie 2483
  [F:DML]JOBPOT    = [F:HRCTR]JOBPOT  : # Emploi type
  [F:DML]POT       = [F:HRCTR]POT     : # Poste
  Call LECTURE("EML",[F:DML]EMP,"") From CONTOBJ
  [F:DML]SEX       = [F:ID]SEX        : # Sexe
  [F:DML]AGE       = func CALC_AGE([F:ID]DATBRN) : # Tranche d'âge
  [F:DML]DESTYPFRT = [F:STG]TYPFRT    : # Dispositif
  If [F:DML]DESTYPFRT = "" Then
    #[F:DML]DESTYPFRT=len(mess(0,10455,1))   : # Non défini
    [F:DML]DESTYPFRT=""   : # Non défini
  Endif
  [F:DML]STA       = 1                : # Statut = Saisie
  [F:DML]FLGINS    = 1                : # Suivi = Saisi

# SEGAY 31/07/12 FQ81491 US602
#                   Write [F:DML]
  If dim([M:GDEM]SIMUL)<=0 | [M:GDEM]SIMUL=1 Then
    Write [F:DML]
  Endif
Return


$SET_ENTETE_DEM
# En-tête demande
  Raz [F:DEM]
  [F:DEM]DEMNUM      = DEMNUM             : # Numéro demande
  [F:DEM]STG         = [M:GDEM]STGDEM     : # Stage
  [F:DEM]DATDEM      = date$              : # Date demande
  [F:DEM]PIO         = 1                  : # Priorité
  [F:DEM]ORIDEM      = 3                  : # Origine demande = habilitation
#            If REF=[F:HAB]REFNUM Then
  If rowcount([F:HA_])=1 Then
    For [F:HA_]
      If REF=[F:HAB]REFNUM Then
        [F:DEM]ORI       = 1                  : # Origine = individuelle
      Else
        [F:DEM]ORI       = 2                  : # Origine = hiérarchique
      Endif
    Next
  Else
    [F:DEM]ORI       = 2                  : # Origine = hiérarchique
  Endif
  [F:DEM]REFNUM      = REF                : # Matricule demandeur
#MABOS-07/12/12-FQ 81085-US1046
#* SEGAY 26/06/12 81085 US500
#          [F:DEM]CTR         = func CALC_CTR(REF) : # Contrat demandeur
#          [F:DEM]CTR         = func CALC_CTR(REF,WLEG) : # Contrat demandeur
  [F:DEM]CTR         = [M:GDEM]CTR
#* END 81085 US500
# end MABOS-07/12/12-FQ 81085-US1046
  [F:DEM]FLGPLF      = 1                  : # Hors plan
  Call LECTURE("STG", [M:GDEM]STGDEM, "") From CONTOBJ
  If [F:STG]COD<>"" Then
# FQ72868 - MABON 15/04/11 - Récupération Hors plan
    # FQ93180 - SEGAY 24/10/13 - Initialisation FLGPLF <> 0
    If [F:STG]FLGPLF <> 0
       [F:DEM]FLGPLF    = [F:STG]FLGPLF
    Else
       [F:DEM]FLGPLF    = 1
    Endif
    [F:DEM]DOM       = [F:STG]DOM         : # Domaine
    [F:DEM]THM       = [F:STG]THM         : # Thème
    [F:DEM]DESCATACN = [F:STG]CATACN      : # Catégorie d'action
    [F:DEM]DESNATFIS = [F:STG]NATFIS      : # Nature fiscale
    [F:DEM]DATSTR    = [F:STG]STRVLY      : # Date début
    [F:DEM]DATEND    = [F:STG]ENDVLY      : # Date fin
  Endif
  If [F:DEM]DESCATACN="" Then
    #[F:DEM]DESCATACN=len(mess(0,10453,1))   : # Non défini
    [F:DEM]DESCATACN=""   : # Non défini
  Endif
  If [F:DEM]DESNATFIS="" Then
    #[F:DEM]DESNATFIS=len(mess(0,10452,1))   : # Non défini
    [F:DEM]DESNATFIS=""   : # Non défini
  Endif
  [F:DEM]CREDAT      = date$              : # Date création
  [F:DEM]CRETIM      = time               : # Heure création
  [F:DEM]CREUSR      = GUSER              : # Créateur

# SEGAY 31/07/12 FQ81491 US602
#         Write [F:DEM]
#         If fstat Then GOK=1 : Endif
  If dim([M:GDEM]SIMUL)<=0 | [M:GDEM]SIMUL=1 Then
    Write [F:DEM]
    If fstat Then GOK=1 : Endif
  Endif
Return

# end 91564


#TODO     SEGAY - 08/08/12 - EXI 81491 83397 US606
$WORKFLOW
Local Char SAVABR (GLONAOB), SAVFONC(GLONAFC)
Local Char GRPDEB(250), GRPW(20)
Local Char CLEW2(30)(1..4)
  # SEGAY 31/07/12 FQ81491 US602
  If dim([M:GDEM]SIMUL)>0 & [M:GDEM]SIMUL=2 : Return : Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  Read [FCY]FCY0 = [F:ID]FCY
  SAVABR = GABREV   : GABREV = "DEM"
  SAVFONC=GFONCTION : GFONCTION="GESDEM"
  Call IDENT3("DEM",[L]GRPDEB,num$([F:DEM]DEMNUM),[L]CLEW2) From GOBJTXT
  Call WRKGLOB(170,[L]GRPDEB,"DEMANDE","") From GOBJACT
  Call WORKPLUS(2,"DEM","C",[L]GRPDEB,"",0,0,0,[L]GRPW) From AWRK   : # 62014
  GABREV = SAVABR   : GFONCTION=SAVFONC
  If !GOK           : # ne peut arriver que si le workflow est en mode débug
    GERR=1
    GMESSAGE=mess(7,21,1)-mess(1,75,1) : # Erreur Workflow
  Endif
Return

