                JOBPOT(0)=[F:CSI]JOBPOT : POT(0)=[F:CSI]POT : TYPFRT(0)=[F:CIL]TYPFRT
                PNUMLIG(0)=0 : RENREF(0)=""
                CATACN=[F:CIL]CATACN : NATFIS=[F:CIL]NATFIS :# ML 453 ML 452
                ENDDATS=[0/0/0]
