###                  If fstat Then GOK=1 : Endif
##                  If dim([M:GDEM]SIMUL)<=0 | [M:GDEM]SIMUL=1 Then
##                   Write [F:DEM]
##                   If fstat Then GOK=1 : Endif
##                  Endif
##
##                  # Lignes demande
##                  If GOK=0 Then
##  #                  For [F:HA_]
##                      Raz [F:DML]
##                      [F:DML]DEMNUM    = [F:DEM]DEMNUM    : # Numéro demande
##                      [F:DML]NUMLIG    = 1                : # N° de ligne
##                      [F:DML]NBREMP    = 1                : # Nombre participants
##                      [F:DML]EMP       = [F:CSI]REFNUM    : # Matricule
##                      [F:DML]CTRNUM    = [F:CSI]CTR       : # Contrat
##                      [F:DML]JOBPOT    = [F:CSI]JOBPOT    : # Emploi type
##                      [F:DML]POT       = [F:CSI]POT       : # Poste
##                      # FQ72318 - MABON 11/03/11 - Prise en compte date d'effet
###                      Filter [F:HRCTR] Where CTRNUM=[F:CSI]CTR & REFNUM=[F:CSI]REFNUM & CTRDAT<=[F:CSI]STRDAT Order By CTRDAT Desc
##                      Filter [F:HRCTR] Where CTRNUM=[F:CSI]CTR & REFNUM=[F:CSI]REFNUM
##&                                          & (CTRDAT<=[F:CSI]STRDAT | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=[F:CSI]STRDAT)) Order By CTRDAT Desc
##                      Read [F:HRCTR] First
##                      If !fstat Then
##                        Read [FCY]FCY0=[F:HRCTR]ETRFCY
##                        If !fstat Then
##                          [F:DML]CPY     = [F:FCY]LEGCPY  : # Société
##                        Endif
##                        [F:DML]SRV       = [F:HRCTR]ETRSRV  : # Service
##                        [F:DML]FCY       = [F:HRCTR]ETRFCY  : # Site
##                        Call CAT2483([F:CSI]REFNUM,[F:HRCTR]CTRNUM,[F:DML]CATFRT) From SUBDEM : # Catégorie 2483
##                        If [F:CSI]JOBPOT="" Then
##                          [F:DML]JOBPOT  = [F:HRCTR]JOBPOT  : # Emploi type
##                        Endif
##                        If [F:CSI]POT="" Then
##                          [F:DML]POT     = [F:HRCTR]POT     : # Poste
##                        Endif
##                      Endif
##                      Filter [F:HRCTR] : # remis #MABOS-07/12/12-FQ 81085-US1046
##
##  #                    If dim(GOFIDEF )>0 Then
##  #                       [F:DML]ORGFIN = GOFIDEF
##  #                    Endif
