                         IM=0
                       #ADNGO - 2017-11-21 - END
                      Endif
                      Gosub SET_ONE_LINE
                      #ADNGO - 2017-11-21 - START
                      REFNUM(IM)=[F:HRCTR]REFNUM
                      NBREMP(IM) = 1
                      CTRNUM(IM) = [F:HRCTR]CTRNUM  : # Contrat

                      CATFRT(IM)="" : SEX(IM)=0 : AGE(IM)="" : SRV(IM)="" : FCY(IM)=""
                      # FQ80186 - MABON 23/03/12 - Si création demandes en masses, le statut est directement à Acceptée
                      STADML(IM)=5 : # Statut Acceptée directement
                      # Fin MABON
                      JOBPOT(IM)="" : POT(IM)="": TYPFRT(IM)="" : # JML 08/09/15
                      PNUMLIG(IM)=0 : RENREF(IM)=""
                      IM += 1
                      #ADNGO - 2017-11-21 - END
