          Call ECR_TRACE(mess(149,10717,1)-":"-num$(NBENREG1),0) From GESECRAN : # Nombre de participants pour renouvellement d'habilitation
        Endif
      Endif
    Endif

    # Génération des demandes pour les parcours individualisés
    If GOK=0 and [M:GDEM]PARFLG=2 Then
      Trbegin [F:DEM], [F:DML] : GOK=0
      NBENREG2 = 0
      # 93303
      # Pas de test sur contrat pas encore inactif pour les demandes venant du pascours individualisé
      [L]FLG_ACTCTR=0
      [L]CRITACTCTR="([F:HRCTR]CTRDAT<=[F:CSI]STRDAT | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=[F:CSI]STRDAT))"
#      If dim([M:GDEM]ACTCTR)> 0 & [M:GDEM]ACTCTR=2 : [L]CRITACTCTR="1=1" : [L]FLG_ACTCTR=1 : Endif
      # END 93303
      CRITDAT = "1=1"
      #LIPET - 2017-06-22 - X3-39329 - START
#      If [M:GDEM]STRDATPAR<>[0/0/0] Then CRITDAT -= "& [F:CSI]STRDAT>=["+format$("D:"+GFMDAT4,[M:GDEM]STRDATPAR)+"]" : Endif
#      If [M:GDEM]ENDDATPAR<>[0/0/0] Then CRITDAT -= "& [F:CSI]STRDAT<=["+format$("D:"+GFMDAT4,[M:GDEM]ENDDATPAR)+"]" : Endif
      If [M:GDEM]STRDATPAR<>[0/0/0] Then CRITDAT -= "& [F:CSI]STRDAT>=[M:GDEM]STRDATPAR" : Endif
      If [M:GDEM]ENDDATPAR<>[0/0/0] Then CRITDAT -= "& [F:CSI]STRDAT<=[M:GDEM]ENDDATPAR" : Endif
      #LIPET - 2017-06-22 - X3-39329 - END
      Link [F:CIL] With [F:CSI]CSI0=[F:CIL]COD As [CI_] Where [F:CSI]COD>=[M:GDEM]STRCODPAR & [F:CSI]COD<=[M:GDEM]ENDCODPAR
&                                                       & evalue(CRITDAT)
      If rowcount([F:CI_])>0 Then
        For [F:CI_] : # On génère une demande par stage composant le parcours individualisé (on peut avoir d'autre parcours pour le salarié)
          Read [F:ID]ID0=[F:CSI]REFNUM
          OKCTR=1
          # FQ72318 - MABON 11/03/11 - Prise en compte date d'effet
#          For [HRCTR] Where REFNUM=[F:CSI]REFNUM & CTRNUM=[F:CSI]CTR & CTRDAT<=[F:CSI]STRDAT & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>[F:CSI]ENDDAT)
          # 93303
#          For [HRCTR] Where REFNUM=[F:CSI]REFNUM & CTRNUM=[F:CSI]CTR & (CTRDAT<=[F:CSI]STRDAT | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=[F:CSI]STRDAT))
#&                         & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>[F:CSI]ENDDAT)
          For [HRCTR] Where [F:HRCTR]REFNUM=[F:CSI]REFNUM & [F:HRCTR]CTRNUM=[F:CSI]CTR & evalue([L]CRITACTCTR)
&                         & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>[F:CSI]ENDDAT)
          # END 93303
            Call LECTURE("FCY", [F:HRCTR]ETRFCY, "") From CONTOBJ
            LCPY=""
            If !fstat Then LCPY=[F:FCY]LEGCPY  : Endif
            If evalue(CRITCPY) & evalue(CRITFCY) Then
                #MABOS-07/12/12-FQ 81085-US1046 - ne traiter que les contrats de la même leg
                WLEG=""
                Call CRTLEG([F:CSI]REFNUM,[F:CSI]CTR,[F:CSI]CTRDAT,WLEG)
                If (WLEG = [M:GDEM]LEG ) Then
                  OKCTR=2 : Break
                Endif
                #end MABOS-07/12/12-FQ 81085-US1046
            Endif
          Next
          If OKCTR=2 Then
            Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM As [DM_] Where [F:DML]EMP=[F:CSI]REFNUM & [F:DEM]STG=[F:CIL]STG & [F:DEM]CODCSI=[F:CIL]COD & [F:DEM]ORIDEM=2
            If rowcount([F:DM_])=0 Then : # On ne génère que les demandes qui n'existent pas déjà
              AUZCFY = func SUBHRSES.GET_AUZ([F:ID]CPY, [F:ID]FCY, "GENDEM")
