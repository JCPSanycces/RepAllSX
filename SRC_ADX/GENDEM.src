          Gosub SET_DEM_NUM
        #END 91564
        Endif
        If GOK=0 Then
        # bug 91564
        # déplacement du code dans la fonction
          Gosub SET_ENTETE_DEM
        # end 91564

          # Lignes demande
          NUMDML=1 : IM=0
          If GOK=0 Then
            #ADNGO - 2017-11-21 - START
            #Raz LISMAT
            #ADNGO - 2017-11-21 - END
            For [F:HA_]
              # bug : 91564  Ajout borne pour perf.
              #ADNGO - 2017-11-21 - START
              #If !find([F:ID]REFNUM, LISMAT(0..IM)) Then
              If !find([F:ID]REFNUM, REFNUMTMP(0..W_NBTOT)) Then
              #ADNGO - 2017-11-21 - END
                #ADNGO - 2017-11-21 - START
                #LISMAT(IM)=[F:ID]REFNUM : IM += 1
                #ADNGO - 2017-11-21 - END
                OKCTR=1
                # FQ84252 - SEGAY 04/09/12 - Prise en compte multi contrat
                # Recherche d'un contrat sur le salarié
                Filter [F:HRCTR] Where REFNUM=[F:HAB]REFNUM Order By CTRDAT Desc
                # END FQ84252 - SEGAY 04/09/12 - Prise en compte multi contrat

                # FQ72318 - MABON 11/03/11 - Prise en compte date d'effet
