##                  DEMNUM = func CALC_DEMNUM(GOK) : # Calcul n° demande
                Endif
                NBREMP(0)=1             : CATFRT(0)=""      : SEX(0)=0                : AGE(0)=""
                SRV(0)=""               : FCY(0)=""         : REFNUM(0)=[F:CSI]REFNUM : CTRNUM(0)=[F:CSI]CTR
                # FQ80186 - MABON 23/03/12 - Si création demandes en masses, le statut est directement à Acceptée
                STADML(IM)=5 : # Statut Acceptée directement
