#**#####################################################################################
#* Contrôle les autorisations
#*!
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local    Integer AUZCFY

  AUZCFY = func SUBHRSES.GET_AUZ(VALEUR, "", "GENDEM")
  If AUZCFY=1 Then
    mkstat=2
  Endif

  If clalev([F:AGC])=0 : Local File AGRPCPY  [AGC] : Endif
  If clalev([F:AGF])=0 : Local File AGRPFCY [AGF] : Endif
  Read [F:AGF]AGF0=VALEUR
  If !fstat & [F:AGF]FLGCPY=1 Then : # Ce n'est pas un groupe de sociétés
    Filter [F:AGC] Where GRP=VALEUR
    If rowcount([F:AGC])=0 Then : # Groupe de sites
      GMESSAGE=VALEUR-mess(216,10717,1) : # est un groupe de sites
      mkstat=2
    Endif
    Filter [F:AGC]
  Endif
End

#**#####################################################################################
#* Initialisation de la borne fin par la borne début
#*!
Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR

  If [M:GDEM]STRDAT<>[00/00/00] and VALEUR=[00/00/00] Then
    VALEUR=[M:GDEM]STRDAT
  Endif
End

Subprog AV_ALLFCY(VALEUR)
Variable Integer VALEUR

  If [M:GDEM]ALLCPY=2 Then
    Grizo [M:GDEM]ALLFCY, FCY
  Endif
End

