#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque GENDEM
# Création
#     MABON - 10/09/10 - EXI 66191 LOT 7
#              - Génération en masse des demandes sur renouvellement des habilitations
#              - Génération en masse des demandes sur parcours individualisés
#     SYMEU - 04/10/10 - EXI 66191 LOT 10 - V6.1 : stage non défini
# Modification
#     SEGAY - 04/09/12 - EXI 84252 :Prise en compte multi contrat
#     MABOS - 07/11/12 - FQ 81085-US927 : Add Legislation
#                      - correct message/Habilitation et/ou Parcours
#     MABOS - 07/12/12 - FQ 81085-US1046
#     MABOS - 22/04/13  - FQ 86015 - US 1531 - improvement traces in mass processing
#     SEGAY - 15/11/13 - EXI 93303 US 2114 :Flag ACTCTR si =1  on prend aussi les contrats qui ne sont pas encore actif
######################################################################################

$ACTION
  Case ACTION
    When "INIT_DIA"   : Gosub INIT_DIA
    When "CONTROLE"   : Gosub CONTROLE
    When "EXEC"       : Gosub EXEC
    When "TERMINE"    : Gosub TERMINE
    When "SEL_TABLE"
      Case TABLE
        When "SELSTGHAB"   : Gosub SELSTGHAB
      Endcase
  Endcase
Return

#**#####################################################################################
#*
#*!
$INIT_DIA
#  Grizo [M:GDEM]STRDAT, ENDDAT, STGDEM
  If GFONCTION="GESCSI" and clalev([M:CSI0])>0 Then
    Actzo [M:GDEM]STRCODPAR, ENDCODPAR
    [M:GDEM]PARFLG=2
    [M:GDEM]STRCODPAR=[M:CSI0]COD
    [M:GDEM]ENDCODPAR=[M:CSI0]COD
    [M:GDEM]STRDATPAR=[M:CSI1]STRDAT
    [M:GDEM]ENDDATPAR=[M:CSI1]ENDDAT
    #MABOS-07/11/12-FQ 81085-US927 : Add Legislation
    [M:GDEM]LEG = GCURLEG
  Else
    Raz [M:GDEM]
    Grizo [M:GDEM]STRCODPAR, ENDCODPAR
  Endif
  #MABOS-07/11/12-FQ 81085-US927 : Add Legislation

  If [M:GDEM]LEG="" Then [M:GDEM]LEG=GLEGFIL : Endif
  GCURLEG=[M:GDEM]LEG
Return

#####################################
$CONTROLE
Local Char REF, REFCTR
Local Char SAVE_GCURLEG_GD, SAVE_GLEGFIL_GD, SAVE_GSOCIETE_GD
Global Char CPL_TIT(250)
  If [M:GDEM]HABFLG<>2 & [M:GDEM]PARFLG<>2 Then
  #MABOS-07/11/12-FQ 81085-US927 : correct message
#    GMESSAGE = mess(157,10717,1) : # Vous devez cocher au moins l'une des deux cases
    GMESSAGE = mess(294,10717,1) : # Vous devez cocher Habilitation et/ou Parcours
    GERR=1 : SAI=1 : Return
  Endif
  #MABOS-07/12/12-FQ 81085-US1046
  Raz [M:GDEM]REFNUM, CTR
  Call PARAMUTIL("REFNUM", REF, GUSER,"") From SUBAUS : # On récupère le paramètre salarié correspondant au GUSER, qui servira à définir le matricule demandeur
  If REF="" Then
    GMESSAGE = mess(176,10717,1)-GUSER-mess(177,10717,1): # Matricule relatif au user non paramétré (paramètre REFNUM)
    GERR=1 : SAI=1 : Return
  Else
      If clalev([F:ID])=0 : Local File EMPLOID   [ID] : Endif
      Read[F:ID]ID0=REF
      If !fstat Then
        SAVE_GCURLEG_GD =  GCURLEG
        SAVE_GLEGFIL_GD = GLEGFIL
        If dim(SAVE_GSOCIETE_GD)>0 : SAVE_GSOCIETE_GD = GSOCIETE : Endif
        CPL_TIT = "->"-func TOOLSHRLEG.LIB_FIELD("DEM1","REFNUM") : # Matricule demandeur
        CPL_TIT -= REF-[F:ID]NAM-[F:ID]SRN-"("- mess(176,10717,1)-GUSER-")" : # Matricule relatif au user
        Call SELCTRMLEG(REF,datesyst, datesyst,[M]LEG,REFCTR) From TOOLSHRLEG
        GCURLEG = SAVE_GCURLEG_GD
        GLEGFIL = SAVE_GLEGFIL_GD
        If dim(SAVE_GSOCIETE_GD)>0 : GSOCIETE =  SAVE_GSOCIETE_GD : Endif

        If REFCTR = "" Then
          GMESSAGE = mess(296,10717,1)-CPL_TIT: # Aucun contrat sélectionné ou valide (lié au paramètre REFNUM)
        Else
          [M:GDEM]REFNUM = REF
          [M:GDEM]CTR =  REFCTR
        Endif

      Endif
  Endif
  Kill CPL_TIT
  If REFCTR = "" Then
      GERR=1 : SAI=1 : Return
  Endif
  # end  MABOS-07/12/12-FQ 81085-US1046
  If GSTATUT<>GSTAOK
    FIN = 1
  Else
    TMP = 1
    TRA = 1
  Endif
Return


#**#####################################################################################
#* Exécution de l'action
#*!
$EXEC
Local  Integer LOK # SEGAY 31/07/12 FQ81491 US602
  # Tables ouvertes pour les demandes de renouvellement d'habilitation
  If clalev([F:DEM])=0    : Local File DEMANDE   [DEM]    : Endif
  If clalev([F:DML])=0    : Local File DEMLIG    [DML]    : Endif
  If clalev([F:HAB])=0    : Local File EMPLOHAB  [HAB]    : Endif
  If clalev([F:ID])=0     : Local File EMPLOID   [ID]     : Endif
  If clalev([F:STG])=0    : Local File STAGE     [STG]    : Endif
  If clalev([F:HRSTR])=0  : Local File STAGETRG  [HRSTR]  : Endif
  If clalev([F:ADI])=0    : Local File ATABDIV   [ADI]    : Endif
  If clalev([F:FCY])=0    : Local File FACILITY  [FCY]    : Endif
  If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]  : Endif
  If clalev([F:TCA])=0    : Local File TABCOUAFF [TCA]    : Endif
  # Tables ouvertes pour les demandes relatives à un parcours individualisé
  If clalev([F:CSI])=0    : Local File COURSEI   [CSI]    : Endif
  If clalev([F:CIL])=0    : Local File COURISLIG [CIL]    : Endif
#* SEGAY 26/06/12 81085 US500
  If clalev([F:CPY])=0    : Local File COMPANY   [CPY]    : Endif

# SEGAY 31/07/12 FQ81491 US602
  If dim([M:GDEM]SIMUL)<=0 | [M:GDEM]SIMUL=1 Then
    Call OUINON(mess(191,10717,1), LOK) From GESECRAN : # Ce traitement est un traitement réel. Confirmez-vous ?
    If LOK = 1 Then Return : Endif
  Endif
# END 31/07/12 FQ81491 US602

  TIT = mess(147,10717,1) : # Génération des demandes de stages
  If !GSERVEUR # FQ84252 - SEGAY 04/09/12
    Call OUVRE_TRACE(TIT) From LECFIC
  Endif # FQ84252 - SEGAY 04/09/12
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
# SEGAY 31/07/12 FQ81491 US602
#MABOS-22/04/13-FQ86015-US1531
  Call LIB_CRIT("[M:GDEM]","GENDEM")From DIVPAYE
#  If dim([M:GDEM]SIMUL)>0 & [M:GDEM]SIMUL=2 Then
#    Call ECR_TRACE(toupper(mess(27,107,1)),0) From GESECRAN : # SIMULATION
#    Call ECR_TRACE("------------------------------------",0) From GESECRAN
#  Endif
# end MABOS-22/04/13-FQ86015-US1531
# END 31/07/12 FQ81491 US602
  SYMBOLE = "GENDEM"
  Lock =SYMBOLE
  If fstat
    GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
    Unlock =SYMBOLE
    GERR = 1 : SAI = 1 : Return
  Endif

  Call DEBTRANS From GLOCK

  Gosub TR1

  Unlock =SYMBOLE

  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  If !GSERVEUR # FQ84252 - SEGAY 04/09/12
    Call FERME_TRACE From LECFIC
# FQ84252 - SEGAY 04/09/12
    Call TEMPOFF() From GESECRAN
    Call LEC_TRACE From LECFIC
  Endif  # FQ84252 - SEGAY 04/09/12
  SAI=1  # FQ84252 - SEGAY 04/09/12

Return

$TERMINE

  Filter [F:HRCTR]
Return

#**#####################################################################################
#* Calcul critère sur les sociétés
#*!
Funprog CALC_CRITCPY
Local Char    CRITERE(255)
Local Char    LIS_CPY(GLONCPY)(0..100)
Local Integer I

  CRITERE = "1=1"
  If [M:GDEM]ALLCPY<>2 Then
    I=0 : Call CALC_GRPCPY([M:GDEM]CPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then
      CRITERE -= "& find([F:FCY]LEGCPY,"
      For K=0 To I-1
        CRITERE += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRITERE += "," : Endif
      Next
      CRITERE += ")>0"
    Endif
  Endif
End CRITERE

#**#####################################################################################
#* Calcul critère sur les sites
#*!
Funprog CALC_CRITFCY
Local Char CRITERE(255)

  CRITERE = "1=1"
  If [M:GDEM]ALLFCY<>2 Then CRITERE -= "& [F:HRCTR]ETRFCY='"+[M:GDEM]FCY+"'" : Endif
End CRITERE

#**#####################################################################################
#* Calcul critère sur les dates
#*!
Funprog CALC_CRITDAT
Local Char CRITERE(255)

  CRITERE = "1=1"
  #LIPET - 2017-06-22 - X3-39329 - START
#  If [M:GDEM]STRDAT<>[0/0/0] Then CRITERE -= "& [F:HAB]HABEND>=["+format$("D:"+GFMDAT4,[M:GDEM]STRDAT)+"]" : Endif
#  If [M:GDEM]ENDDAT<>[0/0/0] Then CRITERE -= "& [F:HAB]HABEND<=["+format$("D:"+GFMDAT4,[M:GDEM]ENDDAT)+"]" : Endif
  If [M:GDEM]STRDAT<>[0/0/0] Then CRITERE -= "& [F:HAB]HABEND>=[M:GDEM]STRDAT" : Endif
  If [M:GDEM]ENDDAT<>[0/0/0] Then CRITERE -= "& [F:HAB]HABEND<=[M:GDEM]ENDDAT" : Endif
  #LIPET - 2017-06-22 - X3-39329 - END
End CRITERE

#**#####################################################################################
#* Calcul n° demande
#*!
Funprog CALC_DEMNUM(LRET)
Variable Integer LRET
Local    Char    COMPTEUR(GLONANM)
Local    Integer STAT
Local    Char    DEMNUM(GLONVCR)

#  Read [TCA]TCA0 = 20 : # Module gestion des talents
#  COMPTEUR = [F:TCA]CODNUM(0)
#  If COMPTEUR="" Then
#    Call ECR_TRACE(mess(4,10717,1),0) From GESECRAN : # Compteur demande non défini
#    LRET=1
#  Else
  Call LECTCA(20,STAT) From SUBTCA : # Module gestion des talents
  If !STAT
    GMESSAGE = mess(4,10717,1) : # Compteur demande non défini
    LRET=1
  Else
    COMPTEUR= [F:TCA]CODNUM(0)
    LRET=1 : Call NUMERO(COMPTEUR, "", datesyst, "", DEMNUM, STAT) From SUBANM
    If STAT Then
      Call ECR_TRACE(mess(4,10702,1)-COMPTEUR,0) From GESECRAN : # Erreur sur compteur
      LRET=1
    Else
      LRET=0
    Endif
  Endif
End DEMNUM

#**#####################################################################################
#* Calcul tranche d'âge
#*!
Funprog CALC_AGE(DAT_BRN)
Value Date DAT_BRN
Local Char AGE

  Filter [ADI] Where NUMTAB=10454 Order By Key CLE=N1
  For [ADI]CLE
    If fix((date$-DAT_BRN)/365)<=[F:ADI]N1
      Break
    Endif
  Next
  Filter [ADI]
  AGE = [F:ADI]CODE
End AGE

#**
#* Détermination du contrat relatif au salarié par rapport à la date du jour
#*
#* @param REF : matricule
#* @param PLEG : LEG
#*!
Funprog CALC_CTR(REF,PLEG)
Value Char REF
Value Char PLEG() # SEGAY 26/06/12 81085 US500
Local Char CTR
If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
If clalev([F:HRCT1])=0  : Local File EMPLOCTR  [HRCT1]  : Endif
Raz [F:ILEG]

#  Call LECTURE("ID",REF,"") From CONTOBJ
  Call LECTURE("EML",REF,"") From CONTOBJ
  # FQ72318 - MABON 11/03/11 - Prise en compte date d'effet
#  Filter [F:HRCTR] Where REFNUM=REF & CTRDAT<=date$ & (XITDAT=[0/0/0] or XITDAT>date$) Order By CTRDAT Desc
# SEGAY 26/06/12 81085 US500
#  Link [F:HRCTR] With [F:ID]ID0=[F:HRCTR]REFNUM,
#&                    [F:FCY]FCY0=[F:HRCTR]ETRFCY
#&                As [NEW]
#&              Where [F:HRCTR]REFNUM=REF & ([F:HRCTR]CTRDAT<=date$ | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=date$))
#&               & (PLEG="" or [F:FCY]LEG=PLEG )
#&               & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>date$) Order By CTRDAT Desc
  Filter [F:ILEG] Where REFNUM=REF
  Link [F:ILEG] With [F:CPY]CPY0=[F:ILEG]LEGCPY,
&                    [F:HRCT1]CTR0=[F:ILEG]REFNUM;[F:ILEG]CTRNUM;[F:ILEG]CTRDAT
&                As [NEW2]
&              Where ([L]PLEG="" or [F:CPY]LEG=[L]PLEG )
&                &   ([F:ILEG]CTRDAT<=date$ | ([F:HRCT1]RETDATEFF<>[0/0/0] & [F:HRCT1]RETDATEFF<=date$))
&               & ([F:ILEG]XITDAT=[0/0/0] or [F:ILEG]XITDAT>date$)
&                Order By [F:ILEG]CTRDAT Desc
 #Read [F:HRCTR] First
 #SBA
  Read [F:NEW2] First
  If !fstat Then
    CTR = [F:ILEG]CTRNUM
  Endif
  Filter [F:ILEG]
End CTR

#* SEGAY 26/06/12 81085 US500
Subprog CRTLEG(PREFNUM,PCTR,PCTRDAT,PLEG)
Value Char PREFNUM()
Value Char PCTR()
Value Date PCTRDAT()
Variable Char PLEG()
If clalev([F:HRCT1])=0  : Local File EMPLOCTR  [HRCT1]  : Endif

  Read [HRCT1]CTR0=PREFNUM;PCTR;PCTRDAT
  If !fstat
    Call LECTURE("FCY",[F:HRCT1]ETRFCY,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    PLEG=[F:CPY]LEG
  Endif
  Filter [HRCT1]
End

#**#####################################################################################
#* Génération des demandes :
#*    - Une seule demande avec tous les matricules pour le renouvellement des habilitations
#*    - Une demande par stage composant le parcours individualisé
#*!
$TR1
Local Char    CRITCPY(255), CRITFCY(255), CRITERE(255), CRITDAT(255), REF(GLONEML), DEMNUM(GLONVCR), LCPY(GLONCPY)
Local Char    CRITACTCTR(255) : # 93303
Local Integer NBENREG1, NBENREG2, NUMDML
Local Integer LOK, AUZCFY, OKCTR, IM
# bug : 91564 passage en dynamique de listmat pour lever la limitation
#Local Char    HABTRG(GLONADI)(0..100), LISMAT(GLONEML)(0..100)
Local Char    HABTRG(GLONADI)(0..100), LISMAT(GLONEML)(0..)
# end 91564
#ADNGO - 2017-06-29 - X3-35995 - START
#on calcule le nombre de ligne max par demande.
Local Integer WMAXLINES : WMAXLINES =100
#ADNGO - 2017-11-21 - START
Local Integer WI
If clalev([F:AMK])=0 : Local File AMSK [AMK] : Endif
If clalev([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
Read [AMK]CODMSK = "DEM3"
If ! fstat
  For WI=0 To [F:AMK]NBBLOC
    If("NBRDEM"=[F:AMK]BASPAG(WI))
      If([F:AMK]NBLIGT(WI)<>0)
        WMAXLINES=[F:AMK]NBLIGT(WI)
      Else
       Read [F:ACV]CODACT=[F:AMK]ACTBLOC(WI)
        If !fstat Then
          WMAXLINES=[F:ACV]DIME
        Endif
      Endif
      Break
    Endif
  Next
Endif
# on part de l'indice 0
WMAXLINES-=1
Local Char    HABTRG(GLONADI)(0..100) #, LISMAT(GLONMAT)(0..100)
# FQ77785 - MABON 08/12/11 - Déclaration variable pour externalisation création demande, pour utilisation dans le portail
Local Integer ORI,NBREMP(0..WMAXLINES),SEX(0..WMAXLINES),PNUMLIG(0..WMAXLINES),STADML(0..WMAXLINES)
#ADNGO - 2017-11-21 - END
Local Char    TYPFRT(50)(0..WMAXLINES)     : # JML 08/09/15
#ADNGO - 2017-11-21 - START
Local Char    REFNUM(GLONEML)(0..WMAXLINES),CTRNUM(GLONHRCTR)(0..WMAXLINES),CATFRT(GLONADI)(0..WMAXLINES),AGE(GLONADI)(0..WMAXLINES)
Local Char    SRV(GLONSRV)(0..WMAXLINES),FCY(GLONFCY)(0..WMAXLINES),JOBPOT(GLONJOT)(0..WMAXLINES),POT(GLONPOT)(0..WMAXLINES)
Local Char    RENREF(60)(0..WMAXLINES)
Local Char    DOM(20),THM(20)
#ADNGO - 2017-11-21 - END
Local Char    CATACN(GLONHRCAN),NATFIS(GLONHRFCN)              : # JML 08/09/15
Local Date    STRDATS,ENDDATS
Local Char    REFNUMTMP(GLONEML)(0..)
Local Integer W_NBTOT
#ADNGO - 2017-06-29 - X3-35995 - END
Local Char    WLEG(GLONADI) : WLEG="" #* SEGAY 26/06/12 81085 US500       : LEG du Stage
Local Char    WLEGCTR(GLONADI) : WLEGCTR="" #* SEGAY 26/06/12 81085 US500 : LEG du contrat
Local Char    WCTR(GLONHRCTR) : WCTR="" #* SEGAY 26/06/12 81085 US500
Local Char    WLISTLEG(5)(1..10) #* SEGAY 26/06/12 81085 US500            : LEGs du demandeur
Local Char    WCRIT(250) #* SEGAY 26/06/12 81085 US500
Local Integer WNBLEG #* SEGAY 26/06/12 81085 US500                        : nb LEGs demandeur
Local Char    WMESSAGE(250), WMESS1(250), WMESS2(250) #* SEGAY 26/06/12 81085 US500
Local Char    WMESS1(250), WMESS2(250), WMESS3(250)  : #MABOS-11/12/2012-US1046
Local Integer FLG_ACTCTR : # 93303

  If [M:GDEM]HABFLG=2 | [M:GDEM]PARFLG=2 Then
  # Habilitation ou Parcours Individualisé
    CRITCPY = func CALC_CRITCPY
    CRITFCY = func CALC_CRITFCY
    CRITERE = CRITCPY - "&" - CRITFCY
    #MABOS-07/12/12
##    Call PARAMUTIL("REFNUM", REF, GUSER,"") From SUBAUS : # On récupère le paramètre salarié correspondant au GUSER, qui servira à définir le matricule demandeur
##* SEGAY 26/06/12 81085 US500
#    Raz WLISTLEG
#    Raz WNBLEG
#    Call LIST_LEG_EML(REF,"",1, WLISTLEG, WNBLEG, WCRIT) From TOOLSHRLEG
##* END SEGAY 26/06/12 81085 US500
    REF =  [M:GDEM]REFNUM : # Matricule Demandeur
    # end MABOS-07/12/12
    GOK=0
    # Génération des demandes pour le renouvellement des habilitations
    If GOK=0 and [M:GDEM]HABFLG=2 Then
      # 93303
      Trbegin [F:DEM], [F:DML] : GOK=0
      NBENREG1 = 0
      CRITDAT = func CALC_CRITDAT
      [L]FLG_ACTCTR=0
      [L]CRITACTCTR="([F:HRCTR]CTRDAT<=date$ | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=date$))"
      If dim([M:GDEM]ACTCTR)> 0 & [M:GDEM]ACTCTR=2 : [L]CRITACTCTR="1=1" : [L]FLG_ACTCTR=1 : Endif
      # END 93303
      Trbegin [F:DEM], [F:DML] : GOK=0
#ADNGO - 2017-11-09 - X3-35995 - START
#      #on calcule le nombre de ligne max par demande.
#      Local Integer WMAXLINES : WMAXLINES =100
#ADNGO - 2017-11-09 - X3-35995 - END
      Local Integer WI
      If clalev([F:AMK])=0 : Local File AMSK [AMK] : Endif
      If clalev([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
      Read [AMK]CODMSK = "DEM3"
      If ! fstat
        For WI=0 To [F:AMK]NBBLOC
          If("NBRDEM"=[F:AMK]BASPAG(WI))
            If([F:AMK]NBLIGT(WI)<>0)
              WMAXLINES=[F:AMK]NBLIGT(WI)
            Else
              Read [F:ACV]CODACT=[F:AMK]ACTBLOC(WI)
              If !fstat Then
                WMAXLINES=[F:ACV]DIME
              Endif
            Endif
            Break
          Endif
        Next
      Endif
      NBENREG1 = 0
      CRITDAT = func CALC_CRITDAT
#      Link [F:HAB] With [F:ID]ID0=[F:HAB]REFNUM As [HA_] Where HABFLG=2 & evalue(CRITERE) & evalue(CRITDAT): # HABFLG = habilitations à renouveler
      Read [F:HRSTR]STR0=[M:GDEM]STGDEM
      If !fstat Then
        #Call CALC_TRG([F:HRSTR]HABTRG, "ADI", "10397", HABTRG) From SUBDEM
        Call CALC_TRG([F:HRSTR]HABTRG, "HRLICAUT", "COD", HABTRG) From SUBDEM :#114309 US204
      Endif
# FQ84252 - SEGAY 04/09/12 - Prise en compte multi contrat
#       Error Oracle
#      Link [F:HAB] With [F:ID]ID0=[F:HAB]REFNUM As [HA_] Where HABFLG=2 & find(HAB, HABTRG(0..50))>0
#&                                                              & evalue(CRITDAT): # HABFLG = habilitations à renouveler
#      Link [F:HAB] With [F:ID]ID0=[F:HAB]REFNUM As [HA_] Where HABFLG=2 & find(HAB, HABTRG(0..50))>0
#&                                                              & evalue(CRITDAT): # HABFLG = habilitations à renouveler
      Link [F:HAB] With [F:ID]ID0=[F:HAB]REFNUM As [HA_] Where HABFLG=2 & find(HAB, HABTRG(0..50))>0
&                                                              & evalue(CRITDAT)
      If rowcount([HA_])>0 Then
#* SEGAY 26/06/12 81085 US500
        Call LECTURE("STG", [M:GDEM]STGDEM, "") From CONTOBJ
        WLEG=""
        WLEG=[F:STG]LEG
        If WLEG <> ""
          If WLEG <> [M:GDEM]LEG Then
               WMESSAGE=mess(00102,10720,1)- WLEG+"."-mess(202,10717,1)-mess(287,10717,1)+":"-mess(5,10935,1)-REF-"/"-mess(33,10717,1)-[M:GDEM]STGDEM
               Call ECR_TRACE(WMESSAGE,1) From GESECRAN
               # La législation doit être
               # Demande de formation non générée : matricule
               GOK=1
           # MABOS-07/12/12-FQ 81085-US1046 : une seule leg obligatoire sur l'écran de critère
