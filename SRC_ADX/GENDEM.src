###                      Call LECTURE("ID",[F:DML]EMP,"") From CONTOBJ
##                      Call LECTURE("EML",[F:DML]EMP,"") From CONTOBJ
##                      [F:DML]SEX       = [F:ID]SEX        : # Sexe
##                      [F:DML]AGE       = func CALC_AGE([F:ID]DATBRN) : # Tranche d'âge
##                      [F:DML]DESTYPFRT = [F:CIL]TYPFRT    : # Dispositif
##                      If [F:CIL]TYPFRT=0 Then
##                        [F:DML]DESTYPFRT = [F:STG]TYPFRT
##                      Endif
##
##                      [F:DML]STA       = 1                : # Statut = Saisie
##                      [F:DML]FLGINS    = 1                : # Suivi = Saisi
##
##                      # SEGAY 31/07/12 FQ81491 US602
###                     Write [F:DML]
##                      If dim([M:GDEM]SIMUL)<=0 | [M:GDEM]SIMUL=1 Then
##                       Write [F:DML]
##                      Endif
##
##                      If fstat Then GOK=1 : Break : Endif
##
##                      # SEGAY 31/07/12 FQ81491 US602
##                      #MABOS-11/12/12-US1046
##                      #MABOS-22/04/13-FQ86015-US1531
