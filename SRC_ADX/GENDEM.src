#**#####################################################################################
#* Contrôle les autorisations
#*!
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Local    Integer AUZCFY

  AUZCFY = func SUBHRSES.GET_AUZ("", VALEUR, "GENDEM")
  If AUZCFY=1 Then
    mkstat=2
  Endif
End

#**#####################################################################################
#* Contrôle que la borne fin est supérieure à la borne début
#*!
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

  Call CTLDATV(VALEUR, [M:GDEM]STRDAT) From CONTDIV
End

######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : contrôle du stage
######################################################################################
Subprog C_STGDEM(VALEUR)
Variable Char    VALEUR()

  Call CTL_STG_NON_DEF(VALEUR) From DIVFOR
  If mkstat Then End Endif

  If clalev([F:HRSTR])=0 : Local File STAGETRG [HRSTR] : Endif
  Read [F:HRSTR]STR0=VALEUR
  If !fstat & [F:HRSTR]HABTRG="" Then
  #LIPET - 2017-06-21 - X3-35995 - START
   GMESSAGE = mess(307,10717,1)
  #LIPET - 2017-06-21 - X3-35995 - END
    mkstat=2
  Endif
End

#**#####################################################################################
#* Grisage des zones suivant la valeur de HABFLG
#*!
Subprog AM_HABFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR=2 Then
    #LIPET - 2017-06-21 - X3-35995 - START
    #Actzo [M:GDEM]STRDAT, ENDDAT, STGDEM
    Actzo [M:GDEM]STRDAT, ENDDAT, STGDEM, ACTCTR
    #LIPET - 2017-06-21 - X3-35995 - END
    If dim([M:GDEM]ACTCTR)> 0 : Actzo [M:GDEM]ACTCTR : Endif
  Else
    [M:GDEM]STRDAT=[0/0/0] : [M:GDEM]ENDDAT=[0/0/0]
    [M:GDEM]STGDEM=""
    Grizo [M:GDEM]STRDAT, ENDDAT, STGDEM
    If dim([M:GDEM]ACTCTR)> 0 : [M:GDEM]ACTCTR=1 : Grizo [M:GDEM]ACTCTR : Endif
  Endif
End

#**#####################################################################################
#* Grisage des zones suivant la valeur de PARFLG
#*!
Subprog AM_PARFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR=2 Then
    Actzo [M:GDEM]STRCODPAR, ENDCODPAR, STRDATPAR, ENDDATPAR
  Else
    [M:GDEM]STRCODPAR=""      : [M:GDEM]ENDCODPAR=""
    [M:GDEM]STRDATPAR=[0/0/0] : [M:GDEM]ENDDATPAR=[0/0/0]
    Grizo [M:GDEM]STRCODPAR, ENDCODPAR, STRDATPAR, ENDDATPAR
  Endif
End

#**#####################################################################################
#* Grisage des zones suivant la valeur de HABFLG
#*!
Subprog AV_STRDAT(VALEUR)
Variable Date    VALEUR

  If [M:GDEM]HABFLG<>2 Then
    Grizo [M:GDEM]STRDAT, ENDDAT, STGDEM
    If dim([M:GDEM]ACTCTR)> 0 : [M:GDEM]ACTCTR=1 : Grizo [M:GDEM]ACTCTR : Endif
  Endif
End

#**#####################################################################################
#* Grisage des zones suivant la valeur de PARFLG
#*!
Subprog AV_STRCODPAR(VALEUR)
Variable Char    VALEUR()
  If [M:GDEM]PARFLG<>2 Then
    Grizo [M:GDEM]STRCODPAR, ENDCODPAR, STRDATPAR, ENDDATPAR
  Endif
End

Subprog AS_ENDCODPAR(VALEUR)
Variable Char    VALEUR()

  If [M:GDEM]STRCODPAR<>"" and VALEUR="" Then
    VALEUR=[M:GDEM]STRCODPAR
  Endif
End


Subprog AS_ENDDATPAR(VALEUR)
Variable Date    VALEUR

  If [M:GDEM]STRDATPAR<>[00/00/00] and VALEUR=[00/00/00] Then
    VALEUR=[M:GDEM]STRDATPAR
  Endif
End

Subprog C_ENDDATPAR(VALEUR)
Variable Date    VALEUR

  Call CTLDATV(VALEUR, [M:GDEM]STRDATPAR) From CONTDIV
End

#**
#* Sélection des stages qui ont une habilitation cible
#*!
$SELSTGHAB
  #LIPET - 2017-06-21 - X3-35995 - START
  Call SELOBJ("STG",OPTIONS,NBCOL,COL,TIT) From CONTOBJ
  #LIPET - 2017-06-21 - X3-35995 - END
  If clalev([F:STG])=0 : Local File STAGE    [STG] : Endif
  If clalev([F:HRSTR])=0 : Local File STAGETRG [HRSTR] : Endif
  #MABOS-07/11/12-FQ 81085-US927 : Correct Bug Link + add legislation
  Local Char CRITERE_LEG([V]GDIMFIC)
    CRITERE_LEG= "1=1"
  If dim([M:GDEM]LEG)>0 & [M:GDEM]LEG <> ""
    CRITERE_LEG += "& (find([F:STG]LEG,'"+[M:GDEM]LEG+"','')>0)"
  Endif
#  Link [F:HRSTR] With [F:STG]STG0=[F:HRSTR]COD As [ST_] Where [F:HRSTR]HABTRG<>""
  Link [F:STG] With [F:HRSTR]STR0=[F:STG]COD As [ST_] Where [F:HRSTR]HABTRG<>""
& & evalue(CRITERE_LEG)
  Default File [ST_]
  Call SELOBJ("STG",OPTIONS,NBCOL,COL,TIT) From CONTOBJ
  ORDRE = "[F:STG]COD"

Return

#MABOS-07/11/12-FQ 81085-US927 : ADD LEGISLATION
Subprog INIT_BYLEG(LEG)
Value   Char LEG
# call by DIVPAYE
# Raz all fields after Leg, if leg is modified
#Raz [M]STRDAT, [M]ENDDAT,[M]STGDEM,[M]STRCODPAR,[M]ENDCODPAR,[M]STRDATPAR,[M]ENDDATPAR
Raz [M]STGDEM,[M]STRCODPAR,[M]ENDCODPAR
Raz [M]ZSTGDEM
[M]HABFLG=1
[M]PARFLG=1
[M]SIMUL=2
#Affzo STGDEM,STRCODPAR,ENDCODPAR
#Affzo [M]HABFLG, PARFLG, SIMUL
#Affzo [M]ZSTGDEM
Affzo [M]15-25
End

