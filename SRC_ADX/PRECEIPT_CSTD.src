#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure PRECEIPT

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"    : Gosub AREAD_AFTER
        When "AINIT"          : Gosub AINIT                # 108613.n
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
     When "INIT_TSSCODADI" : Gosub INIT_TSSCODADI       # 108613.n
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "LEG" :
      Case [L]ARULE
        When "GET"     : Gosub LEG_GET
      Endcase
  Endcase
Return


#######################################################################################
$AREAD_AFTER
  Local Integer IRET
  IRET = fmet this.INIT_TSSCODADI() # 108613.n

  #Set the Invoiced (quantity) field
  If [F:PTH]INVLINCTR=0
    this.WINVFLG=1
  Elsif [F:PTH]INVLINNBR<[F:PTH]LINNBR
    this.WINVFLG=2
  Else
    this.WINVFLG=3
  Endif

  If [F:PTH]INVFLG=3 : this.WCLEFLG=2 : Else : this.WCLEFLG=1 : Endif

  #Set shipment address.  This is not stored in the header unless a change has been made.
  Local Integer TMP
  # Read address from BPADDRESS if address has not been modified
  If this.BPOADDLIG1 = AVOID.ACHAR and
&   this.BPOADDLIG2 = AVOID.ACHAR and
&   this.BPOADDLIG3 = AVOID.ACHAR and
&   this.BPOCTY     = AVOID.ACHAR and
&   this.BPOPOSCOD  = AVOID.ACHAR and
&   this.BPOSAT     = AVOID.ACHAR and
&   this.BPOCRY     = AVOID.ACHAR and
&   this.BPOADD    <> AVOID.ACHAR
    Local Instance BPARTNER Using C_BPARTNER
    BPARTNER = NewInstance C_BPARTNER AllocGroup null
    [L]ASTATUS = fmet BPARTNER.AREAD(this.BPSNUM)
    For TMP=1 To maxtab(BPARTNER.C_BPRNAM)
      Assign "this.BPONAM"+num$(TMP) With BPARTNER.C_BPRNAM(TMP).BPRNAM
    Next
    Local Instance BPADDRESS Using C_BPADDRESS
    BPADDRESS = NewInstance C_BPADDRESS AllocGroup BPARTNER
    [L]ASTATUS = fmet BPADDRESS.AREAD(1, this.BPSNUM, this.BPOADD)
    If [L]ASTATUS=[V]CST_AOK
      this.BPOADDLIG1 = BPADDRESS.BPAADDLIG1
      this.BPOADDLIG2 = BPADDRESS.BPAADDLIG2
      this.BPOADDLIG3 = BPADDRESS.BPAADDLIG3
      this.BPOCTY     = BPADDRESS.CTY
      this.BPOPOSCOD  = BPADDRESS.POSCOD
      this.BPOSAT     = BPADDRESS.SAT
      this.BPOCRY     = BPADDRESS.CRY
      this.BPOCRYNAM  = BPADDRESS.CRYNAM
    Endif
    FreeGroup BPARTNER
    BPARTNER = null
    BPADDRESS = null
  Else
    # Separate multi-dimensional fields into individual properties
    For TMP=1 To maxtab(this.COLBPONAM)
      Assign "this.BPONAM"+num$(TMP) With this.COLBPONAM(TMP).BPONAM
    Next
    For TMP=1 To maxtab(this.COLBPOADDLIG)
      Assign "this.BPOADDLIG"+num$(TMP) With this.COLBPOADDLIG(TMP).BPOADDLIG
    Next
  Endif
Return

#######################################################################################
$AINIT # 108613.n
  Local Integer IRET
  IRET = fmet this.INIT_TSCCODADI()
Return

################################################################################
$INIT_TSSCODADI # 108613.n
  Local Integer DIM_STS
  Local Integer NI

  DIM_STS = func ASYRFNC.ACTIV("STS")
  # -------------------
  For NI = 1 To DIM_STS
  If this.COLTSSCOD(NI)<>null
    #this.C_TSSCOD(NI).TSSCODADI = NI + 40
    this.COLTSSCOD(NI).TSSCODADI = NI + 40
  Endif
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return

################################################################################
$LEG_GET
  Local Instance FACILITY Using C_FACILITY
  FACILITY = NewInstance C_FACILITY AllocGroup null
  [L]ASTATUS = fmet FACILITY.AREAD(this.PRHFCY)
  If [L]ASTATUS=[V]CST_AOK

    Local Instance VATX Using C_TABVAT
    VATX = NewInstance C_TABVAT AllocGroup FACILITY
    [L]ASTATUS = fmet VATX.AREAD(this.LEG,FACILITY.LEG)
    If [L]ASTATUS<>[V]CST_AOK
      [L]ASTATUS = fmet VATX.AREAD(this.LEG,AVOID.ACHAR)
    Endif
    If [L]ASTATUS=[V]CST_AOK
      this.LEG = VATX.LEG
    Endif
    VATX = null
  Endif
  FreeGroup FACILITY
  FACILITY = null
Return

