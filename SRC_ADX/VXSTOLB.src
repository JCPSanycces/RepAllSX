#<AdxTL>@(#)12.0.0.0 $Revision$
####################################################################################
# Program Name: VXSTOLB
# Description : ADC PO Receipt
# Author      : Deutschbauer/Bromley/MBT
# Date        : March 1st, 2006 and March 12th, 2007
####################################################################################
########################################################
# Purchase Receipt
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# POHNUM, POPLIN, POQSEQ, ITMREF, UOM, QTYUOM, STU, QTYSTU, UOMSTUCOE,
# STA, LOC, LOCTYP, LOT, SLO, SLOF, BPSLOT, GESLOT, NBSLO
# WSOLDE, PRHFCY, RCPDAT, BPSNUM,
# PALNUM, CTRNUM, SERNUM, SERNUMF, TCLCOD, WSTOSEQ, WLOCSEQ
#
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Auto print'     --> No 
# Field 'Form'           --> No auto print 
# Block 'Lot': all field --> No 
#
# XAPR is the VT screen
#
########################################################


$ACTION
#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "OK"            : Gosub OK
 When "FIN"           : Gosub FIN
Endcase
Return


########################################################
# Actions liées à la fenètre de saisie
########################################################


########################################################
$OUVRE
If !clalev([F:STJ1]) : Local File STOJOU [STJ1] : Endif
If !clalev([F:LBP]) : Local File LABELPRN  [LBP] : Endif
Global Integer GWNUMREQ     : # pour passage du no de requete
GVTMOD=1
Return


########################################################
$DEBUT
Gosub INIT_SCREEN
#récupération des paramètres
Global Char WFCY
Global Integer WVCRTYP
Global Char   WVCRNUM

If PARAM(1) <> ""
    WFCY = PARAM(1)
Endif
If PARAM(2)<> ""
    WVCRTYP = val(PARAM(2))
Endif
If PARAM(3) <> ""
    WVCRNUM = PARAM(3)
Endif
 
Return


########################################################
$SETBOUT
Return


########################################################
$FIN
Return
########################################################
$OK
#lecture et parcours de la table STOJOU
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
Raz TBPAR, TBVAL


 Filter [STJ1] Where STOFCY = WFCY  &
&                     VCRTYP = WVCRTYP           &
&                     VCRNUM = WVCRNUM 
&               Order By VCRLIN;MVTSEQ*-1;MVTIND
  For [STJ1]
    [F:STJ1]PRNFLG = 2
    Rewrite [STJ1]
    GWNUMREQ=uniqid([LBP])
    I+=1
    Gosub $REMPL_LBP
    If GOK=1
        Raz GBIDI1
        Call ETAT([M:APR2]LBEFMT,[M:APR2]PRT,GLANGUE,0,"",TBPAR,TBVAL) From AIMP3
    Endif
  Next 
  Filter [STJ1] 

Return


########################################################
$REMPL_LBP
Local Integer J
#On arrive ici pour chaque ligne de mouvement de stock
Call DEBTRANS From GLOCK 
Trbegin [LBP]

Raz [F:LBP]
[F:LBP]USR    = GUSER
[F:LBP]NUMREQ = GWNUMREQ
[F:LBP]CREDAT = date$
[F:LBP]CREUSR = GUSER

        [F:LBP]RPTCOD = [M:APR2]LBEFMT
        [F:LBP]STOFCY = WFCY
        [F:LBP]UPDCOD = [F:STJ1]UPDCOD
        [F:LBP]ITMREF = [F:STJ1]ITMREF
        [F:LBP]IPTDAT = [F:STJ1]IPTDAT
        [F:LBP]MVTSEQ = [F:STJ1]MVTSEQ
        [F:LBP]MVTIND = [F:STJ1]MVTIND
        [F:LBP]VCRTYP = 6
        [F:LBP]VCRNUM = [F:STJ1]VCRNUM
        [F:LBP]VCRLIN = [F:STJ1]VCRLIN
        For J = 1 To [M:APR2]LBENBR
                 [F:LBP]NUMLIG = J
                 Write [F:LBP]
        Next J
        If fstat : GOK = 0 : Endif

If GOK = 0 : Rollback : Else : Commit : Endif

Return



########################################################
$INIT_SCREEN
Actzo [APR2]1-99
Affzo [APR2]1-99



Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran VXSTOLB) 06/08/2008 15:24:59 (MAE)
######################################################################################
Subprog C_PRT(VALEUR)
Variable Char    VALEUR()

Call AIMCONT(VALEUR,[M:APR2]LBEFMT,0) From IMPRIME
If mkstat
    Call ERREUR(GMESSAGE) From GESECRAN : Endif
End


######################################################################################

