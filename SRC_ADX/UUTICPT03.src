#<AdxTL>@(#)8.0.0.0 $Revision$
#CHECK IGNORE_SOURCE

##############################################################################
## Initialisation du champ MODULE de la table CACCEDEF
###############################################################################
Call MAJ_UTICPT03    
End

Subprog MAJ_UTICPT03

Local Char DOSSIER(30) : DOSSIER=nomap
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTICPT03:"-"Initialisation field MODULE (table CACCEDEF)") From LECFIC
Call SAIDOS(DOSSIER,"UTICPT03") From SAIDOS
If DOSSIER<>"" Call EXE_UTICPT03(DOSSIER) : Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End


Subprog EXE_UTICPT03(APPLI)
Value Char APPLI
Local Integer OK
If filinfo(filpath("FIL","CACCEDEF","fde",APPLI),0) < 0 : End : Endif
If clalev([F:CDE])=0 : Local File =APPLI+".CACCEDEF" [CDE] : Endif

Call ECR_TRACE("UTICPT03: Process Start on : "+APPLI,0) From GESECRAN

Call DEBTRANS From GLOCK
Gosub TR_UTICPT03
Call ECR_TRACE("UTICPT03: Process End on : "+APPLI,0) From GESECRAN
End


#### Corps de la moulinette - début
$TR_UTICPT03
Trbegin [CDE]
 For [CDE]CDE0 Where MODULE=0
  [F:CDE]MODULE = [F:CDE]MDU
  Rewrite [CDE]
  If fstat
   GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"CACCEDEF"-":"-[F:CDE]COD-[F:CDE]CPY,1) From GESECRAN
   Break
  Endif
 Next
 If !GOK : Goto AB_UTICPT03 : Endif
Commit
Return


$AB_UTICPT03
Rollback
Return 

#### Corps de la moulinette - fin 

Subprog PATCH(APPLI)
Value Char    APPLI
Call EXE_UTICPT03(APPLI)
End






