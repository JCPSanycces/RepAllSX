A_DATE  = [09/11/2018]
A_HEURE = "23:07:33"
A_USER  = "DOC"
A_STAMP = "20181109230733"
Return

$DEFAUT
Default File [HLY]
Return

$OUVFIC
Local File HLYDAY [HLY]
Return

$NOMFIC
Local Integer NBLNK , TITLNK(1..20)
Local Char    OBJLNK(GLONAOB)(1..20) , CODLNK(GLONADI)(1..20)
Local Char    DESLNK(20)(1..20) , ABRLNK(GLONABR)(1..20)
Local Integer NUMLNK(1..20) , LIGLNK(1..20)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , ABTAB(GLONABR) , NOMINT(GLONAVA)
Local Integer TYPGES , FLGSTAT , SELORD , TYPOBJ
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA), FLDGRF(GLONAVA), FLDLEG(GLONAVA), FLDGRC(GLONAVA)
Local Char    REPORT1(GLONARP) , REPORT2(GLONARP) , NOMKEY(GLONAVA)
Local Integer DELDEF, FCYREQ
Local Char    SELIND(250) , ADDURL(250)
NOMFIC = "HLYDAY"
ABFIC  = "HLY"
ABTAB  = "HLY"
NOMINT = ""
TYPGES = 1
SELORD = 1
ZSITE  = ""
ZACC   = ""
FLDGRF = ""
FLDGRC = ""
FLDLEG = ""
FCYREQ = 0
PPAG   = 0
SELIND = ""
DELDEF = 0
ADDURL = ""
FLGSTAT = 0
TITOBJ = 56618
NBLNK = 0
Raz NUMLNK , LIGLNK
Return

$OUVRE
If clalev([F:FCY])=0 : Local File FACILITY     [FCY] : Endif
Return

$ESPION
NUMESPION = 1
Return

$TIT
Local Char TIT(60)
Call TEXTE(56618,TIT) From OBJDIV
Return

$SETCLE
Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..1) , CLELIG(GLONAVA)
CLEPRIM = 'FCY'
CLESEC(0) = 'YEA'
CLESEC(1) = 'LEG'
Return

$OPTIONS
Local Integer  NBCOND
Local Char     CONDIT(50)(1..20)
Local Char     OPT(1)(1..20) , OPTSEL(20)
Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
OPTSEL = ''
Return

$LIBPAR
Local Char LIBPAR(30)
Call TEXTE(0,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Shortint A_BUF1(0..GNBDERNIER)
Local Char     A_BUF2(5)(0..GNBDERNIER)
Local Char     A_BUF3(20)(0..GNBDERNIER)
If clalev([F:HLY9])>0 : Close Local File [HLY9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Shortint A_TAB1,
& Char     A_TAB2(5),
& Char     A_TAB3(20)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3
& As [HLY9]
Return

$LEC_DERLU
Return

$CHARGE_DERLU
If clalev([F:HLY9])>0
 Read [HLY9] = [F:HLY9]A_TABI
 [L]CLE = [F:HLY9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:HLY9])>0
 Filter [HLY9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [HLY1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:HLY9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:HLY]FCY+"~"
 A_CLEDERLU += num$([F:HLY]YEA)+"~"
 A_CLEDERLU += [F:HLY]LEG+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:HLY9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:HLY9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:HLY]YEA"
Call TEXTE(1879,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 2
SELFMT(NBSEL) = "N:4F"
SELFOR(NBSEL) = "N:4#"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:HLY]YEA"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:HLY]FCY"
Call TEXTE(1344,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:HLY]FCY"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:HLY]LEG"
Call TEXTE(26213,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:HLY]LEG"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:HLY_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
Link [HLY] With
& [FCY]FCY0=[F:HLY]FCY
& As [HLY_]
Return

$DEFAUT_LISTE
Default file [HLY_]
Return

$OUVRE_JOIN
Local Char    ORDRE_JOI(250)
ORDRE_JOI = "A_TABJ1;A_TABJ2;A_TABJ3"
Local Shortint A_BUFJ1(1..GNBSEL)
Local Char     A_BUFJ2(5)(1..GNBSEL)
Local Char     A_BUFJ3(20)(1..GNBSEL)
Local Char     A_BUFJ4(15)(1..GNBSEL)
Local Char     A_BUFJ5(80)(1..GNBSEL)
Local File(
& Shortint A_TABJ1,
& Char     A_TABJ2(5),
& Char     A_TABJ3(20),
& Char     A_TABJ4(15),
& Char     A_TABJ5(80)
& ) From Variable A_BUFJ1, A_BUFJ2, A_BUFJ3, A_BUFJ4, A_BUFJ5
& As [PCEJ]
Return

$TIT_JOIN
Local Char TITJOI(30)(1..5)
Call TEXTE(1879,TITJOI(1)) From OBJDIV
Call TEXTE(1344,TITJOI(2)) From OBJDIV
Call TEXTE(26213,TITJOI(3)) From OBJDIV
TITJOI(4) = mess(59,100,1) : # Type
TITJOI(5) = mess(38,100,1) : # Nom
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Kf:5c"
LG = 0
TIT = ""
End

Subprog FORMCLE2(FMT)
Variable Char    FMT()
FMT = "Nf:4#"
End

