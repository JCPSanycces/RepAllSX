# Class SIFINFYD
##########################################################
$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
        When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
      Endcase
Endcase
Return
##########################################################
$PROPERTIES
Case [L]CURPRO
Endcase
Return
##########################################################
$AQUERY_TRANS_AFTER

  # Convert Fiscal year end to character
  this.SIFYD.FYEND = num$(year([F]FIYEND))

  # Convert Ledger type to character
  this.SIFYD.LEDTYP_A = num$([F]LEDTYP)

Return
##########################################################


