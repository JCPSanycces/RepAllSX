#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour table ALISTED
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Mise à jour table ALSITED") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##############################################################################
## Init champ LNG de la table ALISTED
##############################################################################
Call PATCH(nomap)
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub LNG
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub LNG
End

$LNG
Local File =DOSSIER+".ALISTED" [ALD]
Local File =DOSSIER+".ATYPE"   [ATY]  

# Mise à jour de la table ACTION
Call ECR_TRACE(mess(81,125,1)-"ALISTED:"-time$,0) From GESECRAN
Trbegin [ALD]
 For [ALD]
  Read [ATY]CODTYP = [F:ALD]CODTYP
  If !fstat & [F:ATY]LNGTYP<>0
   [F:ALD]LNG = 0
   Rewrite [ALD]
   If fstat
    Call ERREUR("ALSITED"-[F:ALD]COD,2) From DOSDIC
   Endif
  Endif
 Next
Commit
Close Local File [ALD], [ATY]
Return

