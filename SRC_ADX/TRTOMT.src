################################################################################################################
# Saisie des caractéristiques d'un salon professionnels                   Module CRM          06 novembre 2000 #
################################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When Default
Endcase
Return


$OUVRE
Return

$DEFBOUT
Return

$SETBOUT
Return

$OUVRE_BOITE
Return

$DEBUT
Return

$AV_CHOIX
Return

AP_CHOIX
Return

$FINSAI
Return

$FIN
Return

$ABANDON
Return

$APRES_MODIF
Return

$AVANT_BOUTON
Return

$BOUTON
Case BOUT
    When "a"
        Gosub ONOK
    When Default
Endcase
Return

$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################
$ONOK
Call DEBTRANS From GLOCK
Trbegin [OMT]
#[F:OMT] = [M:OMT]
Write [OMT]
If fstat
    GMESSAGE = mess(100,141,1) #Erreur création
    GERR = 1
    Unlock [OMT]
    Rollback
    End
Else
    Commit
    Unlock [OMT]
Endif
Return
