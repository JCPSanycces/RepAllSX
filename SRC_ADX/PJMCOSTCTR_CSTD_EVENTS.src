###################################################################################################
$ADELETE_AFTER
Local Integer ISTATUT

  [L]ASTATUS = [V]CST_AOK
  # ---------------------------------------
  ISTATUS = fmet this.CDIE_DELETE()
  [L]ASTATUS = max([L]ASTATUS, ISTATUS)
Return

###################################################################################################
$DATRATE_AREAD_AFTER
  this.PCCCUR = this.APARENT.PCCCUR
Return

###################################################################################################
$DATRATE_ACONTROL
  [L]ASTATUS = [V]CST_AOK
  # ---------------------------------------
  If this.PCCCUR <> this.APARENT.PCCCUR Then
    ASTATUS = fmet this.ASETERROR("PCCCUR", mess(331,2260,1), [V]CST_AERROR)
  Endif
  # -----------------------------
  If this.APARENT.PCCU = AVOID.ACHAR Then
    ASTATUS = fmet this.ASETERROR("PCCU", mess(326,2260,1), [V]CST_AERROR)
  Endif
  # -----------------------------
  If this.APARENT.PCCCUR = AVOID.ACHAR Then
    ASTATUS = fmet this.ASETERROR("PCCCUR", mess(327,2260,1), [V]CST_AERROR)
  Endif
Return

###################################################################################################
$DATRATE_ADDLINE_BEFORE
  [L]ASTATUS = [V]CST_AOK
  # ---------------------------------------
  If this.PCCU = AVOID.ACHAR Then
    ASTATUS = fmet this.ASETERROR("PCCU", mess(330,2260,1), [V]CST_AERROR)
  Endif
  # -----------------------------
  If this.PCCCUR = AVOID.ACHAR Then
    ASTATUS = fmet this.ASETERROR("PCCCUR", mess(329,2260,1), [V]CST_AERROR)
  Endif
  # -----------------------------
Return

###################################################################################################
$DATRATE_ADDLINE_AFTER
  [L]ASTATUS = [V]CST_AOK
  # ---------------------------------------
  this.PCCCUR = this.APARENT.PCCCUR
Return

###################################################################################################
$CDIE_ACONTROL
  [L]ASTATUS = [V]CST_AOK
  # ---------------------------------------
  # Issue X3-4848/119127 - 2016-10-14 by FGR
  If this.CHX = [V]CST_AYES Then
    If this.CCE <> this.APARENT.PCCCOD and this.CCE <> AVOID.ACHAR Then
      [L]ASTATUS = fmet this.ASETERROR("CCE", this.DIE - ":" - mess(18,9804,1) - "(a)", [V]CST_AERROR)
    Endif
  Endif
Return

###################################################################################################
$CDIE_AINSERT_BEFORE
  [L]ASTATUS = [V]CST_AOK
  # ---------------------------------------
  # Issue X3-4848/119127 - 2016-10-14 by FGR
  If this.CHX = [V]CST_AYES Then
    If this.CCE <> this.APARENT.PCCCOD Then
      [L]ASTATUS = fmet this.ASETERROR("CCE", this.DIE - ":" - mess(18,9804,1) - "(b)", [V]CST_AERROR)
    Endif
  Endif
Return

###################################################################################################
$CDIE_AUPDATE_BEFORE
  [L]ASTATUS = [V]CST_AOK
  # ---------------------------------------
  # Issue X3-4848/119127 - 2016-10-14 by FGR
  If this.CHX = [V]CST_AYES Then
    If this.CCE <> this.APARENT.PCCCOD Then
      [L]ASTATUS = fmet this.ASETERROR("CCE", this.DIE - ":" - mess(18,9804,1) - "(b)", [V]CST_AERROR)
    Endif
  Endif
Return

###################################################################################################
$COSTGRP_ACONTROL
Local Integer NI

  # Issue X3-26712 - 2017-05-19 by ALMON/FGR
  [L]ASTATUS = [V]CST_AOK
  # ---------------------------------------
  For NI = 1 To maxtab(this.APARENT.COSTGRP)
    If this.APARENT.COSTGRP(NI) <> null and find(this.APARENT.COSTGRP(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.APARENT.COSTGRP(NI) <> this Then
        If this.APARENT.COSTGRP(NI).PCGTYP = this.PCGTYP Then
          Case this.APARENT.COSTGRP(NI).PCGTYP
            When 1
              If this.APARENT.COSTGRP(NI).PCGGRPMAT = this.PCGGRPMAT Then
                [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPMAT", func AFNC.MES2(mess(544,2260,1), mess(this.PCGTYP,7722,1), mess(this.PCGGRPMAT,325,1)), [V]CST_AERROR))
              Endif
            When 2
              If this.APARENT.COSTGRP(NI).PCGGRPLAB = this.PCGGRPLAB Then
                [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPLAB", func AFNC.MES2(mess(544,2260,1), mess(this.PCGTYP,7722,1), mess(this.PCGGRPLAB,316,1)), [V]CST_AERROR))
              Endif
            When 3
              If this.APARENT.COSTGRP(NI).PCGGRPMAC = this.PCGGRPMAC Then
                [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPMAC", func AFNC.MES2(mess(544,2260,1), mess(this.PCGTYP,7722,1), mess(this.PCGGRPMAC,316,1)), [V]CST_AERROR))
              Endif
          Endcase
        Endif
      Endif
    Endif
  Next NI
  # ---------------------------------------
  Local File PJMCOSTCTR [PJCC]
  Local File PJMCOSTGRP [PJCG]
  Link [PJCG] With [F:PJCC]PCC0=[F:PJCG]PCCCOD As [LNK]
  Filter [LNK] Where [F:PJCG]PCCCOD <> this.PCCCOD and
&                    [F:PJCC]ENAFLG = [V]CST_AYES and find([F:PJCC]PCCFCY,this.APARENT.PCCFCY, AVOID.ACHAR) <> 0 and
&                    [F:PJCG]PCGTYP = this.PCGTYP and [F:PJCG]PCGGRPMAT = this.PCGGRPMAT and [F:PJCG]PCGGRPLAB = this.PCGGRPLAB and [F:PJCG]PCGGRPMAC = this.PCGGRPMAC
  For [LNK]
    Case this.PCGTYP
      When 1
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPMAT", func AFNC.MES2(mess(552,2260,1), mess(this.PCGGRPMAT,325,1), [F:PJCG]PCCCOD), [V]CST_AERROR))
      When 2
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPLAB", func AFNC.MES2(mess(553,2260,1), mess(this.PCGGRPLAB,316,1), [F:PJCG]PCCCOD), [V]CST_AERROR))
      When 3
        [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("PCGGRPMAC", func AFNC.MES2(mess(554,2260,1), mess(this.PCGGRPMAC,316,1), [F:PJCG]PCCCOD), [V]CST_AERROR))
    Endcase
    Break
  Next
  Filter [LNK]
  # ---------------------------------------
Return

