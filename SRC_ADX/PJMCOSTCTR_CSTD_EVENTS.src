#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMCOSTCTR
###################################################################################################
# EVENTS
###################################################################################################
$AREAD_AFTER
Local Integer IRET

  [L]ASTATUS = [V]CST_AOK
  # -----------------------------
  # Issue X3-4848/119127 - 2016-10-14 by FGR
  IRET = fmet this.TCHREPDIECCE.INIT()
  IRET = fmet this.TCHNODIEEXE.INIT()
Return

###################################################################################################
$ACONTROL
Local Integer ICOUNT
Local Char    L_CPY(GLONCPY)
Local Integer ICOUNT

  [L]ASTATUS = [V]CST_AOK
  # ---------------------------------------
  If this.PCCFCY <> AVOID.ACHAR Then
    L_CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.PCCFCY,"LEGCPY")
    If this.PCCCUR <> fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(L_CPY,"RGCCUR") Then
      [L]ASTATUS = fmet this.ASETERROR("PCCCUR", func AFNC.MES1(mess(340,2260,1), L_CPY), [V]CST_AERROR)
    Endif
  Endif
  # ---------------------------------------
  ICOUNT = uni(this.DATRATE(1..maxtab(this.DATRATE)).PCCDATCST)
  If ICOUNT > 1 Then
    [L]ASTATUS = fmet this.ASETERROR("DATRATE", func AFNC.MES1(mess(150,2260,1), format$("DD2",this.DATRATE(ICOUNT).PCCDATCST)), [V]CST_AERROR)
  Endif
  # -----------------------------
  If this.PCCPROV = [V]CST_AYES Then
    # -----------------------------
    If this.PCCCOD2 <> AVOID.ACHAR Then
      [L]ASTATUS = fmet this.ASETERROR("PCCPROV", func AFNC.MES1(mess(109,2260,1), this.PCCCOD2), [V]CST_AERROR)
    Endif
    # -----------------------------
    If this.PCCPRCT > 0 Then
      [L]ASTATUS = fmet this.ASETERROR("PCCPROV", func AFNC.MES1(mess(315,2260,1), num$(this.PCCPRCT)), [V]CST_AERROR)
    Endif
    # -----------------------------
  Endif
  # -----------------------------
  If this.PCCCOD2 <> AVOID.ACHAR Then
    If this.PCCCOD2 = this.PCCCOD Then
      [L]ASTATUS = fmet this.ASETERROR("PCCCOD2", mess(341,2260,1), [V]CST_AERROR)
    Endif
  Endif
  # -----------------------------
  ICOUNT = fmet this.DATRATE_COUNT()
  If ICOUNT > 0 Then
    If this.PCCCUR = AVOID.ACHAR Then
      [L]ASTATUS = fmet this.ASETERROR("PCCCUR", mess(327,2260,1), [V]CST_AERROR)
    Endif
    If this.PCCU = AVOID.ACHAR Then
      [L]ASTATUS = fmet this.ASETERROR("PCCU", mess(326,2260,1), [V]CST_AERROR)
    Endif
  Endif
  # -----------------------------
Return

###################################################################################################
$AINSERT_CONTROL_BEFORE
Local Integer ISTATUS

  [L]ASTATUS = [V]CST_AOK
  # -----------------------------
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
  # -----------------------------
  #[L]ASTATUS = fmet this.CDIE_INSERT() # Issue X3-4848/119127 - 2016-10-14 by FGR : Move on AINSERT_AFTER
  # -----------------------------
  # Issue X3-4848/119127 - 2016-10-14 by FGR : BEGIN
  If this.TCHNODIEEXE = [V]CST_AYES Then
    If this.PCCFCY = AVOID.ACHAR Then
      ISTATUT = fmet this.CDIE_ERASE_COLLECTION()
      If ISTATUT = [V]CST_AOK Then
        ISTATUT = fmet this.CDIE_INIT()
        [L]ASTATUS = max([L]ASTATUS, ISTATUS)
      Else
        [L]ASTATUS = max([L]ASTATUS, ISTATUS)
      Endif
    Endif
  Endif
  # Issue X3-4848/119127 - 2016-10-14 by FGR : END
  # -----------------------------
Return

###################################################################################################
$AUPDATE_CONTROL_BEFORE
  [L]ASTATUS = [V]CST_AOK
  # -----------------------------
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
  # -----------------------------
  [L]ASTATUS = fmet this.DATRATE_CONVERT()
  # -----------------------------
Return

###################################################################################################
$AINSERT_AUPDATE_CONTROL_BEFORE
Local Char SCPY(GLONCPY)
Local Char SUOM(GLONUOM)
Local Char SCUR(GLONCUR)

  [L]ASTATUS = [V]CST_AOK
  # -----------------------------
  If fmet this.DATRATE_COUNT > 0 and this.PCCFCY <> AVOID.ACHAR Then
    If this.PCCU = AVOID.ACHAR Then
      this.PCCU = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, this.PCCFCY, "UNITWORK")
    Endif
  Endif
  # -----------------------------
  If this.SHOAXX = AVOID.ACHAR Then
    this.SHOAXX = left$(this.DESAXX, type(this.SHOAXX)-10)
  Endif
  # -----------------------------
Return

###################################################################################################
AINSERT_BEFORE
Local Integer ISTATUT

  [L]ASTATUS = [V]CST_AOK
  # ---------------------------------------
  # Issue X3-4848/119127 - 2016-10-14 by FGR
  ISTATUS = fmet this.CDIE_INSERT()
  [L]ASTATUS = max([L]ASTATUS, ISTATUS)
Return

# Issue X3-4848/119127 - 2016-10-14 by FGR BEGIN
###################################################################################################
$AUPDATE_BEFORE
Local Integer ISTATUT

  [L]ASTATUS = [V]CST_AOK
  # ---------------------------------------
  # Issue X3-4848/119127 - 2016-10-14 by FGR
  ISTATUS = fmet this.CDIE_UPDATE()
  [L]ASTATUS = max([L]ASTATUS, ISTATUS)
Return

###################################################################################################
#$AUPDATE_AFTER
#  [L]ASTATUS = fmet this.CDIE_UPDATE()
#Return
