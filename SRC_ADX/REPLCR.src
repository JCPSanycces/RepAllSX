#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"REPLCR"
 GFONCTION="REPLCR" : Call AUTORIS From EXEFNC
Endif
GACTION = "REPLCR"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","REPLCR","DREPLCR",3,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

$ACTION
Case ACTION
 When "INIT"      : Gosub INIT
 When "INIT_DIA"  : Gosub INIT_DIA
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
 When "TERMINE"   : Gosub TERMINE
 When "SEL_TABLE" : Gosub SEL_TABLE
Endcase
Return

#########
$INIT_DIA
#########
Case GACTION
 When "REPLCR"
  ###############################################################################
  ## On peut utiliser le poste client
  Local Char    DIR_FICBAN(GDIMFIC)
  Local Char    MACHIN(GDIMFIC)                      : # Machine
  Local Char    IRS(2)                               : # Séparateur
  Local Char    OS(20) 
  Local Integer OK

  Raz [M]
  Call SETPARAM(DIR_FICBAN,MACHIN,IRS,OS,OK) From PARFICBAN
  If OK
   If MACHIN<>""
    [M:DIA]FILNAM = MACHIN+"@"
   Endif
   [M:DIA]FILNAM += DIR_FICBAN

   If OS="unix"
    [M:DIA]FILNAM += "/"+GDIRBQE
   Else
    [M:DIA]FILNAM += "\"+GDIRBQE
   Endif
  Else
   [M:DIA]FILNAM = filpath(GDIRBQE,"","")
  Endif

  Onerrgo CHUT From CONTROLE
  If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
  If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
  If !clalev([F:BES])  : Local File BILSTA     [BES]  : Endif
  Onerrgo
  If GERREUR : GERREUR=0 : Endif
Endcase
Return

#####
$INIT
#####
Case GACTION
 When "REPLCR1"
  OK=2 : TIT=mess(36,100,1)   :# Confirmation ?
Endcase
Return

#########
$CONTROLE
#########
Case GACTION
 When "REPLCR" 
  If GSERVEUR : [M:DIA]TRCFLG=2 : Endif
  TMP=1 : TIT="V"
Endcase
Return

#####
$EXEC 
#####
Local Integer STA
Local Char   MESSA(80)

Case GACTION
 When "REPLCR"
  Onerrgo ERREUR From CONTROLE
  If clalev([F:BES])=0 : Local File BILSTA [BES] : Endif
  Onerrgo
  If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

  Local Integer NBREM
  Local Char    CRITERE(250), SYMBOLE(30)

  If !GSERVEUR & [M:DIA]TRCFLG=2
   Call TITAWI(BCRIT,CRITERE) From OBJDIV
   Call OUVRE_TRACE(CRITERE) From LECFIC
  Endif

  CRITERE = "FLGEXP=1 & LIN=0" 
  If [M:DIA]ALLCPY<>2
   CRITERE -= '& CPY="'+[M:DIA]CPY+'"'
  Endif
  If [M:DIA]ALLBAN<>2 
   CRITERE -= '& BAN="'+[M:DIA]BAN+'"' 
  Endif 
  If [M:DIA]VCRSTR=[M:DIA]VCREND & [M:DIA]VCRSTR<>""
   CRITERE -= '& FRMNUM="'+[M:DIA]VCRSTR+'"'
  Else
   If [M:DIA]VCRSTR<>""
    CRITERE -= '& FRMNUM>="'+[M:DIA]VCRSTR+'"'
   Endif
   If [M:DIA]VCREND<>""
    CRITERE -= '& FRMNUM<="'+[M:DIA]VCREND+'"'
   Endif
  Endif
  # Restriction aux sites autorisés
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
   CRITERE -= '& find(FCY,GUSRFCY(1..GNBAUZ))'
  Endif

  Filter [BES] Where evalue(CRITERE)
  For [BES]BES0  :# Par relevé 
    SYMBOLE = "FRM"+[F:BES]FRMNUM+"\2"  
    Lock =SYMBOLE With lockwait=0  
    If fstat  
     If [M:DIA]TRCFLG=2
      # Modification en cours sur un autre poste  
      Call ECR_TRACE([F:BES]FRMNUM-mess(10,100,1),1) From GESECRAN 
     Endif
    Else   
     NBREM += 1 
     Call FICHIER([F:BES]FRMNUM,STA,MESSA) 
     If [M:DIA]TRCFLG=2
      If STA=0 : # Avis de domiciliation ... Fichier banque
       Call ECR_TRACE(mess(123,117,1)-[F:BES]FRMNUM-":"-mess(101,117,1)-MESSA,0) From GESECRAN 
      Else  
       Call ECR_TRACE(mess(123,117,1)-[F:BES]FRMNUM-":"-MESSA,1) From GESECRAN 
      Endif 
     Endif 
     Unlock =SYMBOLE
    Endif
  Next 
  Filter [BES]

  If !GSERVEUR & [M:DIA]TRCFLG=2
   Call FERME_TRACE From LECFIC
   TRA=1
  Endif

 When "REPLCR1"
  Call FICHIER(PARAM(1),STA,MESSA)
  If !STA
   # Fichier banque
   GERR=2 : GMESSAGE=mess(101,117,1)-MESSA
  Else
   GERR=1 : GMESSAGE=MESSA
  Endif
Endcase
Return

########
$TERMINE
########
Case GACTION
 When "REPLCR"
  If GSERVEUR : Return : Endif
  If !NBREM
   # Aucun relevé traité
   GERR=2 : GMESSAGE=mess(189,117,1)
  Elsif [M:DIA]TRCFLG<>2 
   # NBREM relevé(s) traité(s) 
   GERR=2 : GMESSAGE=num$(NBREM)-mess(190,117,1)
  Endif
Endcase
Return
 
#############################
## Génération d'un fichier ##
#############################
Subprog FICHIER(NUMERO,STA,MESSA)
Value    Char    NUMERO
Variable Integer STA
Variable Char    MESSA()
 
Local Char    ADELEA(5) , PABFCY(5) , PABCOT(5) , DEBACC(11) , NAMDEB(24) 
Local Char    NUM(8) , INDCUR(1) , PROCEN(6) 
Local Date    PAYDAT , VALDAT , CREDAT 
Local Decimal AMT 
Local Decimal TOTPAY , TOTDET , TOTIMP , AMTIMP  
Local Char    CURDES(GLONCUR) , CURORG(GLONCUR) , SIREN(15) , MOTIF(3) , DEVLED(GLONCUR)

Local Integer STAT , TYP , NUMF 
Local Char    CODE(10) , BANQUE(GLONBAN) , BANCUR(GLONBAN) , DEVBAN(GLONCUR), VLEG(GLONADI), LEGCUR(GLONADI)
Local Char    FICHIER(250) , NOM(10) , EXT(3)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Char    RESULT(250) , SYMBOLE(32)
Local Integer NUMREC , DECIM
Local Date    DATJ

## Laisser la possibilité d'aller sur le client
Local Char    DIR_FICBAN(GDIMFIC)
Local Char    MACHIN(GDIMFIC)                      : # Machine
Local Char    IRS(2)                               : # Séparateur
Local Char    OS(20)
Local Integer OK

Local File BILSTA [BES], PAYMENTH [PYH], PAYFRM [FRM]
If clalev([F:TFB])=0 : Local File TABFILBAN [TFB] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:BAN])=0 : Local File BANK      [BAN] : Endif 
If clalev([F:TCU])=0 : Local File TABCUR    [TCU] : Endif 

STA = 0
 
Read [BES]BES0 = NUMERO;0
If fstat : STA = 1 : Goto FINFIC : Endif

BANQUE=[F:BES]BAN  
Call LECTURE("BAN",[F:BES]BAN,"") From CONTOBJ  
# Accessibilité
If dim([F:BAN]ACS)>0
 Call CONTEXE([F:BAN]ACS) From CPTSUB
 If mkstat : STA = 7 : mkstat=0 : Goto FINFIC : Endif
Endif

Call LECTURE("CPY",[F:BES]CPY,"") From CONTOBJ  
[L]VLEG=[F:CPY]LEG
Call SETCUR(1,[F:BES]CPY,DEVLED) From CPTDIV
 
SYMBOLE = "FRM"+NUMERO+"\2"
Lock =SYMBOLE
If fstat=1 : STA = 6 : Goto FINFIC : Endif
   
Call LECTURE("TCU",DEVLED,"") From CONTOBJ 
DECIM = 10^[F:TCU]DECNBR

CODE = "REPLCRBOR"
If CODE="" : STA = 2 : Goto FINFIC : Endif
 
##############################################################
## Laisser la possibilité d'aller sur le client
Call SETPARAM(DIR_FICBAN,MACHIN,IRS,OS,OK) From PARFICBAN
If OK
 If OS="unix"
  DIR_FICBAN += "/"+GDIRBQE
 Else
  DIR_FICBAN += "\"+GDIRBQE
 Endif
 If MACHIN<>""
  DIR_FICBAN = MACHIN+"@"+DIR_FICBAN
 Endif
Else
 DIR_FICBAN = filpath(GDIRBQE,"","",0)
 Call MACHINE(DIR_FICBAN,MACHIN,DIR_FICBAN) From ORDSYS
 Call GET_OS(MACHIN,OS) From ORDSYS
Endif

If filinfo(DIR_FICBAN,0)<0
 STA = 4 : Goto FINFIC
Endif
 
EXT = [F:BAN]FILEXT
If EXT="" : EXT = left$([F:BAN]BAN,3) : Endif 

Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1 : STA = 3 : Goto FINFIC : Endif
 
Read [TFB]TFB0(5) = CODE;[F:BES]BAN;1;0;[L]VLEG
If fstat
 Read [TFB]TFB0(5) = CODE;[F:BES]BAN;1;0;""
 If fstat
  Read [TFB]TFB0(5) = CODE;"";1;0;[L]VLEG
  If fstat
   Read [TFB]TFB0(5) = CODE;"";1;0;""
  Endif
 Endif
Endif

NOM = [F:TFB]FILREF
If NOM="" : NOM = left$([F:TFB]COD,2) : Endif
NOM += format$("N0:5#",NUMF)

##############################################################
## Laisser la possibilité d'aller sur le client
If OS="unix"
 DIR_FICBAN += "/"
Else
 DIR_FICBAN += "\"
Endif
If [F:TFB]FILEXO<>""
 DIR_FICBAN += NOM+EXT+"."+[F:TFB]FILEXO
Else
 DIR_FICBAN += NOM+"."+EXT
Endif
FICHIER = DIR_FICBAN

Openo FICHIER,0
SAVIFS = adxifs
SAVIRS = adxirs
adxifs = ""
adxirs = ""
[L]DATJ=datesyst

# En-tête et lignes 
Raz [L]TOTPAY , TOTDET , TOTIMP
For [F:BES]BES0 Where FRMNUM=NUMERO & FLGANO<>2

 # En-tête 
 If [F:BES]LIN=0 
  
  SIREN = left$([F:CPY]CRN,14) 
  NUMREC = 1 
  TYP = 1 : Gosub ENREG 
  [L] = [F:BES] 
  Case [L]INDCUR 
   When " ","F" : [L]CURDES = DEVLED
   When "E"     : [L]CURDES = GEURO
  Endcase 
 
 # Lignes 
 Else 
  Raz [L]AMTIMP : Raz [L]MOTIF 
  If [F:BES]PAYNUM<>""  :# Effet rapproché 
   Call LECTURE("PAY",[F:BES]PAYNUM,"") From CONTOBJ 
   If [F:PYH]PABFLG=1 
    [L]MOTIF  = [F:PYH]PABREN 
    [L]AMTIMP = [F:BES]AMTCUR - [F:PYH]PABAMTPRT  
    [L]CURORG = [F:PYH]CUR
   Endif 
  Else  :# Effet non rapproché 
   If [F:BES]PABFLG=1 
    [L]MOTIF  = [F:BES]PABREN 
    [L]AMTIMP = [F:BES]AMTCUR 
    [L]CURORG = [F:BES]CUR 
    If [L]CURORG="" : [L]CURORG = [L]CURDES : Endif
   Endif 
  Endif 

  If [L]AMTIMP<>0 & [L]CURDES<>[L]CURORG
   Call CONVERT([L]CURORG,[L]CURDES,"",0,[L]DATJ,[L]AMTIMP,[L]AMTIMP,STAT) From TRTDEV   
  Endif 

  [L]TOTIMP += [L]AMTIMP 
  [L]TOTPAY += [F:BES]AMT - [L]AMTIMP 

  If [L]AMTIMP<>0  :# Uniquement les effets impayés 
   [L]TOTDET += [F:BES]AMT
   TYP = 2 : Gosub ENREG 
  Endif
 Endif 
Next 

# Fin
NUMREC += 1
TYP = 3 : Gosub ENREG
Openo
adxifs = SAVIFS
adxirs = SAVIRS 
 
Call DEBTRANS From GLOCK
Gosub TR2
If GOK<1 : STA = 5 : Endif

$FINFIC
Case STA
 When 0 : MESSA = "|"+DIR_FICBAN+"|"
 When 1 : MESSA = mess(191,117,1)                   : # Relevé inexistant
 When 2 : MESSA = mess(192,117,1)                   : # Pas d'export à faire
 When 3 : MESSA = mess(104,117,1)-"NUMFIL"          : # Erreur sur compteur
 When 4 : MESSA = "|"+DIR_FICBAN-"|:"-mess(9,141,1) : # Répertoire inexistant
 When 5 : MESSA = mess(35,110,1)                    : # Erreur transactionnelle
 When 6 : MESSA = mess(10,100,1)                    : # Modification en cours sur un autre poste 
 When 7 : MESSA = GMESSAGE-mess(1,653,1)-[F:BAN]BAN : # Vous n'avez pas les droits d'éxécution Banque
Endcase
If SYMBOLE<>""
 Unlock =SYMBOLE
Endif
End

####
$TR1
####
GOK = 1
Trbegin [BAN]
 Lock NUMFIL
 If fstat
  GOK = -1 : GLOCK = "%NUMFIL" : Goto ROLL_TR1
 Endif
 [C]NUMFIL += 1
 If fstat=0 & [C]NUMFIL>=100000
  [C]NUMFIL = 1
 Endif
 If fstat=1
  GOK = -1 : GLOCK = "@NUMFIL" : Goto ROLL_TR1
 Elsif fstat
  GOK = 0 : Call RSTA("@NUMFIL","") From GLOCK : Goto AB_TR1
 Endif
 NUMF = [C]NUMFIL
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

####
$TR2
####
GOK = 1
Trbegin [BES], [PYH], [FRM]

 Update [BES] Where FRMNUM=[L]NUMERO & LIN=0 With FLGEXP=2
 If fstat=1
  GOK = -1 : GLOCK = "$BILSTA"-[L]NUMERO-"0" : Goto ROLL_TR2
 Elsif fstat
  GOK = 0 : Call RSTA("BES",[L]NUMERO-"0") From GLOCK : Goto AB_TR2
 Endif

 Update [PYH] Where FRMNUM=[L]NUMERO & FRMFLG=2 With TFBFIL=[L]NOM+"."+[L]EXT, TFBDAT=[L]DATJ
 If fstat=1
  GOK = -1 : GLOCK = "$PAYMENTH"-"2"-[L]NUMERO : Goto ROLL_TR2
 Elsif fstat
  GOK = 0 : Call RSTA("PYH","2"-[L]NUMERO) From GLOCK : Goto AB_TR2
 Endif

 Update [FRM] Where FRMNUM=[L]NUMERO & FRMFLG=2 With  TFBFIL=[L]NOM+"."+[L]EXT, TFBDAT=[L]DATJ
 If fstat=1
  GOK = -1 : GLOCK = "$PAYFRM"-"2"-[L]NUMERO : Goto ROLL_TR2
 Elsif fstat
  GOK = 0 : Call RSTA("FRM","2"-[L]NUMERO) From GLOCK : Goto AB_TR2
 Endif

Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

######
$ENREG
######

Filter [TFB] Where COD=CODE & BAN=BANQUE & RECTYP=TYP & LEG=VLEG
If rowcount([TFB]) <= 0
 Filter [TFB] Where COD=CODE & BAN=BANQUE & RECTYP=TYP & LEG=""
 If rowcount([TFB]) <= 0
  Filter [TFB] Where COD=CODE & BAN="" & RECTYP=TYP & LEG=VLEG
  If rowcount([TFB]) <= 0
   Filter [TFB] Where COD=CODE & BAN="" & RECTYP=TYP & LEG=""
   If rowcount([TFB]) <= 0
    Raz [TFB]
   Else
    [L]BANCUR=""
    [L]LEGCUR=""
   Endif
  Else
   [L]BANCUR=""
   [L]LEGCUR=VLEG
  Endif
 Else
  [L]BANCUR=BANQUE
  [L]LEGCUR=""
 Endif
Else
[L]BANCUR=BANQUE
[L]LEGCUR=VLEG
Endif

For [TFB]TFB0(4) Where COD=CODE & BAN=[L]BANCUR & RECTYP=TYP & LEG=[L]LEGCUR
 If TYP=2 : NUMREC+=1 : Endif
 For [TFB]TFB0
  RESULT = ""
  If [F:TFB]FRM<>""
   Onerrgo ERREUR
   ER = 0
   Case [F:TFB]FLDTYP
    When 3,4,5,6,7 : # Dates pour l'avoir sous forme AAAAMMJJ
     RESULT = evalue([F:TFB]FRM)
    When Default
     RESULT = num$(evalue([F:TFB]FRM))
   Endcase
   Onerrgo
  Endif
  LONG = [F:TFB]LNG
  Case [F:TFB]FLDTYP
   When 1 : # Chaîne cadrée à gauche
    RESULT = toupper(ctrans(left$(RESULT+space$(LONG),LONG)))
   When 2 : # Numérique cadré à gauche
    RESULT = right$(string$(LONG,"0")+RESULT,len(RESULT)+1)
   When 3 : # Date JJMMAA
    RESULT = mid$(RESULT,7,2)+mid$(RESULT,5,2)+mid$(RESULT,3,2)
   When 4 : # Date AAMMJJ
    RESULT = right$(RESULT,3)
   When 5 : # Année
    Case LONG
     When 1 : RESULT = mid$(RESULT,4,1)
     When 2 : RESULT = mid$(RESULT,3,2)
     When 4 : RESULT = mid$(RESULT,1,4)
    Endcase
   When 6 : # Mois
    RESULT = mid$(RESULT,5,2)
   When 7 : # Jour
    RESULT = mid$(RESULT,7,2)
   When 8 : # Séquence spéciale (binaire)
   When 9 : # Montant
    RESULT = num$(arr(DECIM*val(RESULT),1))
    RESULT = right$(string$(LONG,"0")+RESULT,len(RESULT)+1)
  Endcase
  RESULT = left$(RESULT+space$(LONG),LONG)
  Wrseq RESULT;
 Next  
Next
Wrseq 
Return

$ERREUR
Resume

##################################
## Etiquettes de l'écran REPLCR ##
##################################

$SEL_TABLE
Case COUZON
 When "VCRSTR","VCREND" : # Bornes de relevé
  If !clalev([ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([BES]) : Local File BILSTA  [BES] : Endif
  TIT(0) = mess(12,123,1)-mess(199,117,1) : # Choix relevé 
  NBCOL=1
  COL(NBCOL) = "FRMNUM" : Gosub TEX_BILSTA
  COL(NBCOL) = "BAN"    : Gosub TEX_BILSTA
  COL(NBCOL) = "PAYDAT" : Gosub TEX_BILSTA
  COL(NBCOL) = "CPY"    : Gosub TEX_BILSTA
  COL(NBCOL) = "FCY"    : Gosub TEX_BILSTA
  NBCOL-=1 : SIZCOL = 80 : SIZLIG=240 : ORDRE = "FRMNUM"
  CRITERE = "FLGEXP=1 & LIN=0"
  If [M]BAN<>""
   CRITERE -= "& BAN='"+[M]BAN+"'"
  Elsif [M]CPY<>""
   CRITERE -= "& CPY='"+[M]CPY+"'"
  Endif
  # Filtre sur sites autorisés
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
   CRITERE -= "& find(FCY,GUSRFCY(1..GNBAUZ))"
  Endif
  Default File [BES]
Endcase
Return

$TEX_BILSTA 
Read [ATZ]CODZONE = "BILSTA";[L]COL(NBCOL) 
Call TEXTE([F:ATZ]NOABREG,TIT(NBCOL)) From OBJDIV   
[L]NBCOL+=1
Return  

Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
If GUSRFCY(1)<>"\" : mkstat = 1 : Endif
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]ALLCPY = 2 : mkstat = 1 : Endif
End

Subprog AS_ALLBAN(VALEUR) 
Variable Integer  VALEUR 
If [M:DIA]ALLCPY=2 : VALEUR=2 : mkstat=2 : Endif 
End 
  
Subprog AS_BAN(VALEUR)
Variable Char    VALEUR()
If [M:DIA]ALLCPY=2 | [M:DIA]ALLBAN=2 : mkstat=1 : Endif
End
  
Subprog C_BAN(VALEUR)
Variable Char     VALEUR
If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
Call LECTURE("BAN",VALEUR,"") From CONTOBJ
If [F:BAN]CPY<>[M:DIA]CPY 
 # Société
 mkstat=1 : GMESSAGE = mess(2,116,1)-[F:BAN]CPY
Endif
End 
 
Subprog AM_VCRSTR(VALEUR)
Variable Char     VALEUR
If VALEUR="" : End : Endif
If clalev([F:BES])=0 : Local File BILSTA [BES] : Endif
Read [BES]BES0=VALEUR;0
If fstat 
 # Relevé inexistant
 GERR=2 : GMESSAGE = mess(191,117,1) 
Elsif [F:BES]FLGEXP=2 
 # Relevé déjà exporté
 GMESSAGE = mess(193,117,1)
 mkstat = 1
Elsif [M]BAN<>""
 If [F:BES]BAN<>[M]BAN 
  # Banque
  GMESSAGE = mess(1,653,1)-[F:BES]BAN
  mkstat = 1
 Endif
Elsif [M]CPY<>""
 If [F:BES]CPY<>[M]CPY 
  # Société
  GMESSAGE = mess(2,116,1)-[F:BES]CPY
  mkstat = 1
 Endif
Endif
End
 
Subprog AS_VCREND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]DEB : VALEUR=[M]VCRSTR : Endif
End

Subprog C_VCREND(VALEUR)
Variable Char     VALEUR
If VALEUR="" : End : Endif
If VALEUR<>"" & VALEUR<[M]VCRSTR
 GMESSAGE = mess(44,199,1) :# La borne fin est inferieure a la borne debut
 mkstat = 1
Endif
End

Subprog AM_VCREND(VALEUR)
Variable Char    VALEUR()
Call AM_VCRSTR(VALEUR)
End
