# GTAMMAS massif
 Raz GPILOBJ
 Call DEFVAR From GLOBIMM
 Call INIVAR From GLOBIMM
 Call LAUNCH_ACT(GTAMMAS)
End
#==============================================================#
#            Gestion de l'action métier LEAPAY                 #
#==============================================================#
######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
$ACTION
 #Infbox "TRTLEAPAY /"-ACTION
 Case ACTION
  When "INIT"         : Gosub INIT
  When "INIT_DIA"     : Gosub INIT_DIA
  When "AVANT_PAR"    : Gosub AVANT_PAR
  When "OUVRE"        : Gosub OUVRE
  When "OUVRE_BATCH"  : Gosub OUVRE_BATCH
  When "DEBUT"        : Gosub DEBUT
  When "APRES_MODIF"  : Gosub APRES_MODIF
  When "SETBOUT"      : Gosub SETBOUT
  When "AP_CHOIX"     : Gosub AP_CHOIX
  When "BOUTON"       : Gosub BOUTON
  When "END"          : Gosub END_BOITE
  When "OK"           : Gosub OK
  When "EXEC"         : Gosub EXEC
  When "CONTROLE"     : Gosub CONTROLE
  When "FIN"          : Gosub FIN
  When "TERMINE"      : Gosub TERMINE
  When "SORTIE"       : Gosub SORTIE
  When Default
 Endcase

Return
#=====================================================================
$OUVRE_BATCH             # (Massif uniquement - Soumission batch uniquement)

 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT
 Gosub OUVRE_TABLES

Return
#=====================================================================
$INIT_DIA                    # (Massif - Saisie des paramètres)

 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT

 Gosub OUVRE_TABLES

Return
#=====================================================================
$INIT                    # (Massif uniquement - interactif et exécution batch)

 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT

 Gosub OUVRE_TABLES

 If GSERVEUR
    #==> Déclaration globales
    Gosub CREE_GLOBTRT
 Endif

Return
#=====================================================================
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

  ##### Ouverture des masques de la fenêtre de l'action massive pour pouvoir les garder jusqu'à
  ##### EXEC - Ouverture manuelle des masques de la fenêtre.
  ##### Nécessaire jusqu'à ce qu'une modif permette de lancer une action massive avec plus
  ##### d'un écran de critère.

  Local Char WINACT : WINACT=ACTMETNAM+""
  Local Integer I_MSK, I
  If !clalev([F:AWI]) : Local File AWINDOW : Endif
  If !clalev([F:AMK]) : Local File AMSK    : Endif
  Read [AWI]AWI0=WINACT
  If !fstat
   Local Mask =[F:AWI]MSKENT
   For I_MSK=0 To [F:AWI]NBMSK
     Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
     Local Mask =[F:AMK]CODMSK
   Next I_MSK
  Endif

Return
#=====================================================================
$OUVRE                   # (Massif interactif et Unitaire)

  If dim(TRTMODACT)<0
   Global Char TRTMODACT
   TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Endif
  Gosub ACTION From =TRTMODACT

  #==> Ouverture des tables
  Gosub OUVRE_TABLES

  If !GSERVEUR
   Gosub CREE_GLOBTRT
  Endif

Return
#=====================================================================
$CREE_GLOBTRT

  Global Integer    G_TRACE
  Global Integer    G_NBLEA
  Global Integer    G_NBLEA_TRT, G_NBLEA_LBB
  Global Date       GPAYSTRDAT, GPAYENDDAT, GPERSTRDAT, GPERENDDAT, GFSTMTHDAT
  Global Decimal    GPAYAMT, GPAYAMTM
  Global Decimal    GPRIAMT, GPRIAMTM
  Global Decimal    GINTAMT, GINTAMTM
  # Issue X3-56289
  Global Decimal    GVARPAY, GVARPAYM
  Global Decimal    GRSDVAL, GRSDVALM
  Global Decimal    GPUROPT, GPUROPTM
  Global Decimal    GTERPEN, GTERPENM

Return
#=====================================================================
$DEBUT # (Massif et Unitaire)

  Gosub ACTION From =TRTMODACT


  Raz[LEAP] :  Affzo [LEAP]
  #--> On rend le masque invalide pour faire tous les contrôles
  Setmok [M:LEAP] With 0

  #--> 37124-Lancement de tâche batch.
  If GBATCH=1
   Affzo [LEAP]
  Endif


Return
#=====================================================================
$APRES_MODIF

#*FQ-61084
If GCNXPROIAS <> G_OUI
  Chgfmt [M:LEAP]STRPAYDATI With "-D:"+GFMDAT4
  Chgfmt [M:LEAP]ENDPAYDATI With "-D:"+GFMDAT4
  Chgtbk [M:LEAP]15 With ""
Else
  Chgfmt [M:LEAP]STRPAYDATI With "D:"+GFMDAT4
  Chgfmt [M:LEAP]ENDPAYDATI With "D:"+GFMDAT4
  Chgtbk[M:LEAP]15 With mess(112,GML_MSGGRT,1)
Endif #*FQ-61084

Gosub ACTION From =TRTMODACT

Return
#=====================================================================
$SETBOUT                 # (Massif interactif et unitaire : )
  Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$AP_CHOIX                 # (Unitaire : )
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$BOUTON                  # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$END_BOITE               # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$OK                      # (Massif intéractif et unitaire)
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$CONTROLE

If (GSERVEUR) Then
  Call ACTION_CPY ([M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)) From GLOFCYCPY
Endif

Gosub ACTION From =TRTMODACT

Return
#=====================================================================
$EXEC                    # (Massif intéractif et batch)
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$FIN                     # ()
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$TERMINE                  # ()
 Gosub ACTION From =TRTMODACT

  Call FERME_BOITE From GESECRAN

  If dim(G_TRACE)      >0     : Kill G_TRACE        : Endif
  If dim(G_NBLEA)      >0     : Kill G_NBLEA        : Endif
  If dim(G_NBLEA_TRT)  >0     : Kill G_NBLEA_TRT    : Endif
  If dim(G_NBLEA_LBB)  >0     : Kill G_NBLEA_LBB    : Endif

  If dim(GPAYAMT)      >0     : Kill GPAYAMT        : Endif
  If dim(GPAYAMTM)     >0     : Kill GPAYAMTM     : Endif
  If dim(GPRIAMT)      >0     : Kill GPRIAMT        : Endif
  If dim(GPRIAMTM)     >0     : Kill GPRIAMTM      : Endif
  If dim(GINTAMT)      >0     : Kill GINTAMT        : Endif
  If dim(GINTAMTM)     >0     : Kill GINTAMTM      : Endif

  # Issue X3-56289
  If dim(GVARPAY)      >0     : Kill GVARPAY        : Endif
  If dim(GRSDVAL)      >0     : Kill GRSDVAL        : Endif
  If dim(GPUROPT)      >0     : Kill GPUROPT        : Endif
  If dim(GTERPEN)      >0     : Kill GTERPEN        : Endif
  If dim(GVARPAYM)     >0     : Kill GVARPAYM       : Endif
  If dim(GRSDVALM)     >0     : Kill GRSDVALM       : Endif
  If dim(GPUROPTM)     >0     : Kill GPUROPTM       : Endif
  If dim(GTERPENM)     >0     : Kill GTERPENM       : Endif


  If dim(GPAYSTRDAT)    >0     : Kill GPAYSTRDAT     : Endif
  If dim(GPAYENDDAT)    >0     : Kill GPAYENDDAT     : Endif
  If dim(GPERSTRDAT)    >0     : Kill GPERSTRDAT     : Endif
  If dim(GPERENDDAT)    >0     : Kill GPERENDDAT     : Endif
  If dim(GFSTMTHDAT)    >0     : Kill GFSTMTHDAT     : Endif


Return

#=====================================================================
$SORTIE
 Gosub ACTION From =TRTMODACT
Return
######################################################################
# Points d'entrée de l'action métier communs unitaire / massif
######################################################################
$ACTMET

 Case ACTMET

  When "SET_GLO_MAS"        :   Gosub SET_GLO_MAS
  When "SET_CRITACT"        :   Gosub SET_CRITACT          # UM - CRITACT critère de sélection particulier à l'action métier
  When "FILL_HEA"           :   Gosub FILL_HEA             # U  - Alimentation partie spécifique en-tête

# Locker

  When "OUVR_LOCK"          :   Gosub OUVR_LOCK            # UM - Ouverture de tables annexes pour les lock
  When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        # UM  - Exclusion élément de la population à sélectionner
  When "MAS1_LOCK_AUTRE"    :   Gosub MAS1_LOCK_AUTRE      # UM - Lock objet lié à l'enr en ligne de la population

# Charger

  When "OUVR_ALIM_TMP1"     :   Gosub OUVR_ALIM_TMP1       # UM - Ouverture de tables annexes pour l'alim des table tmp.
  When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       # UM - Transfert zones tables de données -> tables tempo

# Applique_temp

  When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       # UM - Ouverture de tables annexes
  When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       # UM - Application des paramètres de l'action aux enr de la table temporaire principale
  When "TPF1_APPL_TPF1"     :   Gosub TPF1_APPL_TPF1       # UM - Application des paramètres de l'action aux enr de la table temporaire annexe

# Report_mask Report objet principal dans les masques (unitaire uniquement)

  When "TMP1_ALIM_MASK"     :   Gosub TMP1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'écran
  When "TPF1_ALIM_MASK"     :   Gosub TPF1_ALIM_MASK       # U  - Tansfert table temporaire annexe     -> masques de l'écran
  When "REAF_ALIM_MASK"     :   Gosub REAF_ALIM_MASK       # U  - Tansfert tables temporaires -> masques de l'écran (pour réaffichage)

# Applique_dirt Mise à jour directe (massif uniquement)

  When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
  When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       # M  - Mise à jour directe des tables de données avec les paramètres de l'action

# reporter

  When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      # UM - Ouverture tables annexes avant report tables tempo -> tables de données
  When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      # UM - Report table temporaire principale -> table de données
  When "TPF1_ALIM_TABLE"    :   Gosub TPF1_ALIM_TABLE      # UM - Report table temporaire par plan   -> table de données par plan

  When Default

 Endcase

Return
#=====================================================================
# Unitaire / massif :
$SET_GLO_MAS
Return
#=====================================================================
# Unitaire / massif : Critère de sélection particulier à l'action métier
$SET_CRITACT

  # Seuls les contrats  en cours sont sélectionnés
  CRITACT=" ( LEASTA = GVML_STENCOU ) "

Return
#=====================================================================
# Unitaire : Permet d'alimenter des zones spécifiques de l'en-tête de la fenêtre
$FILL_HEA
Return
#=====================================================================
# Unitaire et massif : Sert à ouvrir des tables utilisées dans MAS1_CONTROLE
#                      et MAS1_LOCK_AUTRE
$OUVR_LOCK
  Gosub OUVRE_TABLES

Return
#=====================================================================
# Unitaire / massif : contrôle élément pour retrait de la population
$MAS1_CONTROLE
Return
#=====================================================================
# Unitaire / massif : Lock d'objet lié à l'enregistrement en ligne
#                     Alimenter RMES si un message soit apparaître
$MAS1_LOCK_AUTRE
Return
#=====================================================================
# Unitaire / massif : Sert à ouvrir des tables utilisées dans MAS1_ALIM_TMP1
$OUVR_ALIM_TMP1
Return
#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelée par le s/p CHARGER
#                     Si une erreur se produit dans cette étiquette
#                     Alimenter RMES avec le message qui doit apparaître
#                     dans une boîte en unitaire ou en massif
$MAS1_ALIM_TMP1
Return
#=====================================================================
# Unitaire / massif : Ouverture de tables annexes
$OUVR_APPL_TMP1
Return
#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire principale
$TMP1_APPL_TMP1
Return
#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire annexe (par plan)
$TPF1_APPL_TPF1
Return
#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TMP1_ALIM_MASK
Return
#=====================================================================
# Unitaire : Permet de reporter les infos de TPF1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TPF1_ALIM_MASK
Return
#=====================================================================
# Unitaire : Permet de réafficher les masques de l'objet métier si des modifs
#            y ont été reportées.
REAF_ALIM_MASK
Return
#=====================================================================
# Massif : Sert à ouvrir des tables utilisées dans MAS1_APPL_MAS1
$OUVR_APPL_DIRT

  Gosub OUVRE_TABLES
  # Société courante : rupture société pour émission en-tête trace
  Local Char    TRC_CPY
  Local Char    TRC_LEAREF
  Local Char    TXTPROG(40)
  Local Integer NBLEA

  TXTPROG = mess(99,GML_MSGGRT,1)
  G_NBLEA   = NBOBJLCK
  Call TEMPOFF() From GESECRAN
  Call OUVRE_BOITE(TXTPROG, G_NBLEA) From GESECRAN
  Call SET_BOITE(TXTPROG, G_NBLEA) From GESECRAN

Return

#=====================================================================
# Massif : Application paramètres action aux tables de données : mise à jour directe
$MAS1_APPL_DIRT

Local  Char    TXTPROG(40)
Local  Integer NBLEA_TRT, LOK
Local  Date    W_CNX_DATE(1..5)
Local  Date    PSTRDAT
Local  Date    PENDDAT
Local  Integer WEVT_PLN
Local  Integer RTRN
Local  Integer RNBD
Local  Integer RNBM
Local  Integer RNBW
Local  Integer RNBY
Local  Integer NBJOURS, NBJOURSP
Local  Integer NBMOIS
Local  Integer WNBJ_MOIS(1..12)
Local  Char    WPAYAMTM, WPRIAMTM, WINTAMTM
Local  Decimal WMTPAY, WMTPRI, WMTINT
Local  Decimal WVARPAY, WRSDVAL, WPUROPT, WTERPEN  : # Issue X3-56289
Local  Decimal NMNT
Global Char    GLEAREF, GLEAREFI
Global Integer G_NBLBB_TRT, G_NBLBB_MAJ, G_NBLBB_ERR

#-> A rupture société on émet un en-tête dans la trace
  If ( [F:MAS1]CPY<>TRC_CPY )
    Gosub ECR_ENTETE
    TRC_CPY=[F:MAS1]CPY
    Raz G_NBLEA_TRT
    Raz NBCPYMAJ
    Raz NBCPYTRT
  Endif

#-> A rupture contrat
  If ( [F:MAS1]LEAREF <> TRC_LEAREF )
    TRC_LEAREF =[F:MAS1]LEAREF
    Raz G_NBLBB_TRT
    Raz G_NBLBB_MAJ
    Raz G_NBLBB_ERR
    Raz NBCPYMAJ
    Raz NBCPYTRT
  Endif

  Read [LEA]LEA0=  [F:MAS1]LEAREF
  If fstat :  GOK=0 : Return :  Endif
  GLEAREF  = [F:MAS1]LEAREF
  GLEAREFI = [F:MAS1]LEAREF

  If [M:LEAP]STRPAYDAT <> [0/0/0] & [M:LEAP]ENDPAYDAT <> [0/0/0]
     WEVT_PLN = 1
     PSTRDAT= [M:LEAP]STRPAYDAT
     PENDDAT= [M:LEAP]ENDPAYDAT
     Gosub PREPA_EVTS
     Call ECR_TRACE_DETSTAT([F:MAS1]LEAREF, WEVT_PLN, G_NBLBB_TRT, G_NBLBB_MAJ, G_NBLBB_ERR)
  Endif

  If [M:LEAP]STRPAYDATI <> [0/0/0] & [M:LEAP]ENDPAYDATI <> [0/0/0]
     WEVT_PLN = 6
     PSTRDAT= [M:LEAP]STRPAYDATI
     PENDDAT= [M:LEAP]ENDPAYDATI
     Raz G_NBLBB_TRT
     Raz G_NBLBB_MAJ
     Raz G_NBLBB_ERR
     Gosub PREPA_EVTS
     Call ECR_TRACE_DETSTAT([F:MAS1]LEAREF, WEVT_PLN, G_NBLBB_TRT, G_NBLBB_MAJ, G_NBLBB_ERR)
  Endif


  #G_NBLEA_TRT += 1
  TXTPROG    = mess(293,GML_MSGFAS,1)+[F:MAS1]LEAREF+'['+num$(G_NBLEA_TRT)+'/'+num$(G_NBLEA)+']'
  Call AFF_BOITE(TXTPROG,G_NBLEA_TRT,LOK) From GESECRAN

  If RTRN=0
     NBCPYMAJ += 1
  Endif

  If ( FLGSIM = G_NON ) Then
    Rewrite [MAS1]
    If fstat
      # Erreur technique
      RMES= mess(104,GML_MSGFAS,1)+" LEABILBOOK"+mess(105,GML_MSGFAS,1)+" 01"+mess(106,GML_MSGFAS,1)-[F:MAS1]LEAREF
      GOK=0 : Return
    Endif
  Endif

Return
#==========================================================
$PREPA_EVTS
Local Date WDATDEBM, WDATFINM
Local Decimal   CUMPAYAMT
Local Decimal   CUMPRIAMT
Local Decimal   CUMINTAMT
# Issue 56289
Local Decimal   CUMVARPAY
Local Decimal   CUMRSDVAL
Local Decimal   CUMPUROPT
Local Decimal   CUMTERPEN
Local Integer   R_NB_MOIS   #*FQ107913

If WEVT_PLN = 1
   Filter [LBB] Where ( LEAREF=[F:MAS1]LEAREF )  & ( PAYDAT = [0/0/0] & PAYREF = "" ) & ( FARFLG <> G_OUI )
Else
   Filter [LBB] Where ( LEAREF=[F:MAS1]LEAREF )  & ( PAYDAT = [0/0/0] & PAYREF = "" ) & ( FARFLGI <> G_OUI )
Endif
#Fq-55966 Ajout de With Stability pour bases Sql server
For [LBB]LBB0 Where (( [F:LBB]STRPERDAT  >=  PSTRDAT   & [F:LBB]STRPERDAT  <=   PENDDAT )   or
&                    ( [F:LBB]ENDPERDAT  >=  PSTRDAT   & [F:LBB]ENDPERDAT  <=   PENDDAT )   or
&                    ( [F:LBB]STRPERDAT  <   PSTRDAT   & [F:LBB]ENDPERDAT  >    PENDDAT ) )   With Stability

       If  PSTRDAT   > [F:LBB]STRPERDAT
           GPERSTRDAT = PSTRDAT
       Else
           GPERSTRDAT = [F:LBB]STRPERDAT
       Endif
       If PENDDAT < [F:LBB]ENDPERDAT
           GPERENDDAT = PENDDAT
       Else
           GPERENDDAT = [F:LBB]ENDPERDAT
       Endif
       GPAYSTRDAT = PSTRDAT
       GPAYENDDAT = PENDDAT
        #----- Nombre mois/jours de l'échéance
        #*FQ107913 NBMOIS     =  [F:LBB]NBRMONPER
        #* Recalcul du nombre de mois compris dans l'échéance à traiter
        Call GET_DATE_MONTH_DELTA ([F:LBB]STRPERDAT, [F:LBB]ENDPERDAT, R_NB_MOIS) From SUBLEA   #*FQ107913
        NBMOIS     =  R_NB_MOIS                                                                 #*FQ107913
        NBJOURS    =  [F:LBB]NBRDAYPER
        #------------------------------
        CUMPAYAMT = 0
        CUMPRIAMT = 0
        CUMINTAMT = 0
        # Issue 56289
        Raz CUMVARPAY
        Raz CUMRSDVAL
        Raz CUMPUROPT
        Raz CUMTERPEN
        For I_M = 1 To NBMOIS
           If I_M = 1
              WDATDEBM = [F:LBB]STRPERDAT
           Endif
           If I_M= NBMOIS
              WDATFINM =  [F:LBB]ENDPERDAT
           Else
              WDATFINM = eomonth(WDATDEBM)
           Endif
           GPAYAMT    = [F:LBB]RNTAMT
           GPRIAMT    = [F:LBB]FINDPR
           GINTAMT    = [F:LBB]FINEXS
           # Issue X3-56289
           GVARPAY    = [F:LBB]VARPAY
           GRSDVAL    = [F:LBB]RSDVAL
           GPUROPT    = [F:LBB]PUROPT
           GTERPEN    = [F:LBB]TERPEN
           If I_M <  NBMOIS
              Call  CALCUL_NB_D_M_W_Y (WDATDEBM, WDATFINM, RNBD, RNBM, RNBW, RNBY)
              WMTPAY   =  (GPAYAMT * RNBD)  / NBJOURS
              Call GET_MNT_ARRONDI (WMTPAY ,[F:MAS1]LEACUR, NMNT) From GLOBIENS
              GPAYAMTM = NMNT
              CUMPAYAMT += NMNT
              WMTPRI   = ( GPRIAMT * RNBD)  / NBJOURS
              Call GET_MNT_ARRONDI (WMTPRI,[F:MAS1]LEACUR, NMNT) From GLOBIENS
              GPRIAMTM = NMNT
              CUMPRIAMT += NMNT
              WMTINT   = ( GINTAMT * RNBD)  / NBJOURS
              Call GET_MNT_ARRONDI ( WMTINT,[F:MAS1]LEACUR, NMNT) From GLOBIENS
              GINTAMTM = NMNT
              CUMINTAMT += NMNT
              # Issue X3-56289
              WVARPAY   =  (GVARPAY * RNBD)  / NBJOURS
              Call GET_MNT_ARRONDI (WVARPAY ,[F:MAS1]LEACUR, NMNT) From GLOBIENS
              GVARPAYM = NMNT
              CUMVARPAY += NMNT
              WRSDVAL   =  (GRSDVAL * RNBD)  / NBJOURS
              Call GET_MNT_ARRONDI (WRSDVAL ,[F:MAS1]LEACUR, NMNT) From GLOBIENS
              GRSDVALM = NMNT
              CUMRSDVAL += NMNT
              WPUROPT   =  (GPUROPT * RNBD)  / NBJOURS
              Call GET_MNT_ARRONDI (WPUROPT ,[F:MAS1]LEACUR, NMNT) From GLOBIENS
              GPUROPTM = NMNT
              CUMPUROPT += NMNT
              WTERPEN   =  (GTERPEN * RNBD)  / NBJOURS
              Call GET_MNT_ARRONDI (WTERPEN ,[F:MAS1]LEACUR, NMNT) From GLOBIENS
              GTERPENM = NMNT
              CUMTERPEN += NMNT
           Else
              GPAYAMTM = GPAYAMT-CUMPAYAMT
              GPRIAMTM = GPRIAMT-CUMPRIAMT
              GINTAMTM = GINTAMT-CUMINTAMT
              # Issue X3-56289
              GVARPAYM = GVARPAY-CUMVARPAY
              GRSDVALM = GRSDVAL-CUMRSDVAL
              GPUROPTM = GPUROPT-CUMPUROPT
              GTERPENM = GTERPEN-CUMTERPEN
           Endif
           GFSTMTHDAT =  gdat$(0,month(WDATDEBM)+1, year(WDATDEBM))
           Gosub GENERATION_EVTS
           G_NBLEA_TRT += 1
           G_NBLBB_TRT += 1
           If RTRN <> 0
             Gosub MSG_ERREUR
             G_NBLBB_ERR +=1
           Endif
           WDATDEBM = WDATFINM+1
        Next I_M


        ################################################
        # Fq-84671  Point d'entrée                     #
        ################################################
        GPOINT = "LEAPAY_LBB" : Gosub ENTREE From EXEFNC
        #### Point d'entrée - Fin ######################
        ################################################

 Next
 Filter [LBB]

Return
#==========================================================
$GENERATION_EVTS

#    RTRN =  0    #  OK
#    RTRN =  1    #  Erreur génération événement

Local Char    EVTINT
Local Char    EVT
Local Integer LCDRET
Local Integer RCOD
Local Date    WDATEFF
Local Date    WDATCPTINT

   WDATEFF    = WDATFINM
   WCPTDATINT = WDATFINM
   GPERSTRDAT = WDATDEBM
   GPERENDDAT = WDATFINM

   If (FLGSIM = G_NON)
      # Génération événement de redevance pour le plan comptable et/ou le plan IAS/IFRS
      EVTINT="LEAPAY"+num$(WEVT_PLN)
      EVT="LEAPAY"
      [F:E44]CREDAT     = date$
      [F:E44]CRETIM     = time
      [F:E44]TIMSTP     = func GENEVE.BUILD_TIMSTP([F:E44]CREDAT, [F:E44]CRETIM)
      #FQ95500 Read [E44]EVE2=G_OUI;WEVT_PLN;[F:MAS1]CPY;[F:MAS1]FCY;[F:MAS1]LEAREF après modif index EVE2 de la table LEAPAY
      Read [E44]EVE2=G_OUI;WEVT_PLN;GPERENDDAT;[F:MAS1]CPY;[F:MAS1]FCY;[F:MAS1]LEAREF
      #*FQ-61427 If fstat
      If fstat = 5
         Call GENER_EVE (GVML_OMLOCFI,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]LEAREF,0,EVTINT,WDATEFF,WCPTDATINT,LCDRET)  From GENEVE
      #*FQ-61427Else
      #*FQ-61427   Local Integer NBMAXTRY : NBMAXTRY=2
      #*FQ-61427   For NBTRY=1 To NBMAXTRY
      #*FQ-61427      Call TEMPO_EVT() From GENEVE
      #*FQ-61427      [F:E44]CRETIM = time
      #*FQ-61427      [F:E44]TIMSTP = func GENEVE.BUILD_TIMSTP([F:E44]CREDAT, [F:E44]CRETIM)
      #*FQ-61427      Call GENER_EVE (GVML_OMLOCFI,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]LEAREF,0,EVTINT,WDATEFF,WCPTDATINT,LCDRET)  From GENEVE
      #*FQ-61427      If !fstat
      #*FQ-61427        Break
      #*FQ-61427      Endif
      #*FQ-61427   Next NBTRY
      #*FQ-61427   #> Si la nouvelle tentative après tempo a de nouveau échouée, erreur
      #*FQ-61427   If fstat
      #*FQ-61427      RCOD = 90
      #*FQ-61427      Infbox "Erreur : création événement /"-num$(RERROR)-"\"-[F:E44]CPY-"-"-[F:E44]EVT-"-"-num$([F:E44]PLN)-"-"-[F:E44]REF
      #*FQ-61427      GOK    = 0
      #*FQ-61427   Endif
      Endif
      If (LCDRET > 20 )
         RTRN = 1 :  Return :   # Erreur génération évènement
      Else
        Gosub ECR_LIGNE
        Gosub MAJ_FARFLG
      Endif
   Else
      Gosub ECR_LIGNE
      G_NBLBB_MAJ+=1
   Endif

Return
#==========================================================
# Maj indicateur de génération de l'événement d'échéance
#==========================================================
$MAJ_FARFLG

   If !clalev([F:LBB]) : Local File LEABILBOOK  [LBB] : Endif

 If WEVT_PLN = 1
    Update [LBB] Where (LEAREF = [F:MAS1]LEAREF &  ENDPERDAT = [F:LBB]ENDPERDAT) With FARFLG=G_OUI,UPDUSR=GUSER,UPDDAT=date$
 Else
    Update [LBB] Where (LEAREF = [F:MAS1]LEAREF &  ENDPERDAT = [F:LBB]ENDPERDAT) With FARFLGI=G_OUI,UPDUSR=GUSER,UPDDAT=date$
 Endif
 If fstat
     G_NBLBB_ERR +=1
     GOK=0 : Return
 Else
    G_NBLBB_MAJ+=1
    #Infbox "enregistrements modifiés"-num$(adxuprec)
 Endif

Return
#==========================================================
Subprog CALCUL_NB_D_M_W_Y (P_DATE_DEB, P_DATE_FIN, R_NB_JOUR, R_NB_MOIS, R_NB_WEEK, R_NB_YEAR)
# calcul les nombres de jour, mois et semaines pour une période
Value    Date    P_DATE_DEB
Value    Date    P_DATE_FIN
Variable Integer R_NB_JOUR
Variable Integer R_NB_MOIS
Variable Integer R_NB_WEEK
Variable Integer R_NB_YEAR

Local Integer LOK
Local Integer W_NB_AN

  Call GET_DATE_MONTH_DELTA (P_DATE_DEB, P_DATE_FIN, R_NB_MOIS) From GLOBIENS
  R_NB_JOUR = P_DATE_FIN - P_DATE_DEB + 1
  R_NB_WEEK = arr(R_NB_JOUR/7, 0)


End
########################################
$MSG_ERREUR

#    RTRN = -1    #  Pas régularisable
#    RTRN =  0    #  OK
#    RTRN =  1    #  Secteur d'activité non trouvé dans la table 410
#    RTRN =  2    #  Erreur mise à jour DEPREC
#    RTRN =  3    #  Erreur conversion  DEPREC
#    RTRN =  4    #  Erreur génération événement
#    RTRN =  5    #  Erreur extourne événements
#    RTRN =  6    #  Erreur suppression amortissements
#    RTRN =  7    #  Erreur en gestion des flux


  If (RTRN > 0 ) Then
    If (RTRN = 1 )
       # Contrat  -> réf contrat - Erreur lors de la génération d'événement
       RMES= mess(100,GML_MSGGRT,1)-[F:MAS1]LEAREF-mess(101,GML_MSGGRT,1)
    Endif
    NBCPYERR += 1 :

    GOK=0 : Return
  Endif


Return

