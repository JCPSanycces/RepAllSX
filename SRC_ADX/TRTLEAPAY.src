#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.
#=====================================================================

#==============================================================#
# Cette action est appelée pour chaque enregistrement lu dans  #
# la table temporaire par plan pour l'objet métier sur lequel  #
# on vient de cliquer.                                         #
# Alimenter ici les zones du tableau par plan spécifique à l'  #
# action                                                       #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#
$LOADPLN
  # Chargement du masque tableau des infos "spécifiques" par plan suite à clique sur bien
  # Appelée pour chaque enreg de la table temporaire
  # Masque: [M:MFS0]   Table: [F:TPF]   Ligne courante: nolign
Return

#==============================================================#
# Cette action est appelée pour chaque enregistrement de la    #
# table temporaire à mettre à jour.                            #
# Alimenter ici les zones spécifiques à l'action de la table   #
# temporaire par plan à partir des zones du tableau par plan   #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#
$SAVEPLN
  # MAJ table temporaire avec les infos "spécifiques" du masque tableau des infos par plan
  # Appelée pour chaque enreg de la table temporaire
  # Table: [F:TPF]   Masque: [M:MFS0]   Ligne courante: nolign
Return


################################################################################
# Traitement du masque de reprise de l'action massive                          #
# -----> MFASTRFCR                                                             #
################################################################################

#==============================================================#
# Actions de contrôle sur champ                                #
#==============================================================#
##=====================================================================
Subprog C_STRPAYDAT(VALEUR)
Variable Date    VALEUR
End
#=====================================================================
Subprog C_ENDPAYDAT(VALEUR)
Variable Date    VALEUR

#
# La date de fin doit être > à la date de début
#
If ( [M:LEAP]STRPAYDAT <> [0/0/0] & VALEUR <= [M:LEAP]STRPAYDAT) Then
  GERR= 1
  GMESSAGE= mess(33, GML_MSGGRT, 1)
  mkstat = 2
  End
Endif
End
#=====================================================================
Subprog C_STRPAYDATI(VALEUR)
Variable Date    VALEUR
End
#=====================================================================
Subprog C_ENDPAYDATI(VALEUR)
Variable Date    VALEUR
#
# La date de fin doit être > à la date de début
#
If ( [M:LEAP]STRPAYDATI <> [0/0/0] &  VALEUR <= [M:LEAP]STRPAYDATI) Then
  GERR= 1
  GMESSAGE= mess(33, GML_MSGGRT, 1)
  mkstat = 2
  End
Endif

End
##########################################################################
#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#
#=====================================================================
$ECR_ENTETE
Local    Char    LINE(115)

If ( FLGDET = G_OUI )
   If [M:LEAP]STRPAYDAT <> [0/0/0]
      # Entête  événements pour écritures destinées aux comptes individuels
      # Entête (ligne 1)
      # Entête (ligne 2)
      #---------------------------------------------------------------------
      LINE = ""
      Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
      #---------------------------------------------------------------------
      #***104-EVENEMENTS GENERES POUR ECRITURES DESTINEES AUX COMPTES INDIVIDUELS
      LINE = mess(104,GML_MSGGRT,1)
      Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
      #---------------------------------------------------------------------
      LINE = ""
      Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
      #---------------------------------------------------------------------
      # Période traitée
      LINE  =  mess(102,GML_MSGGRT,1)+"  "
      LINE += (num$([M:LEAP]STRPAYDAT)+ "  " + mess(103,GML_MSGGRT,1)+"  "+num$([M:LEAP]ENDPAYDAT))
      Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
      #---------------------------------------------------------------------
      LINE = string$(115,"")
      Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
      #---------------------------------------------------------------------
      LINE = string$(115,"*")
      Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
      #*FQ95502 Création of messages 115 to 119
      LINE =      left$( mess(100,GML_MSGGRT,1)  + string$(20,' '), 20)+" ! "         # Contrat
      LINE +=     left$( mess(115,GML_MSGGRT,1)  + string$(10,' '), 10)+" ! "
      LINE +=     left$( mess(116,GML_MSGGRT,1)  + string$(10,' '), 10)+" !   "
      LINE +=     left$( mess(117,GML_MSGGRT,1)  + string$(19,' '), 19)+" !  "
      LINE +=     left$( mess(118,GML_MSGGRT,1)  + string$(19,' '), 19)+" !  "
      LINE +=     left$( mess(119,GML_MSGGRT,1)  + string$(19,' '), 19)+" ! "
      Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
      #---------------------------------------------------------------------
      LINE = string$(115,"*")
      Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
      #---------------------------------------------------------------------
   Endif

   If [M:LEAP]STRPAYDATI <> [0/0/0]
       # Entête événements pour écritures destinées aux comptes consolidés
       # Entête (ligne 1)
       # Entête (ligne 2)
       #---------------------------------------------------------------------
       LINE = ""
       Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACT1, LINE, 0,1) From TRACEABX3
       #---------------------------------------------------------------------
       #***105-EVENEMENTS GENERES POUR ECRITURES DESTINEES AUX COMPTES CONSOLIDES
       LINE = mess(105,GML_MSGGRT,1)
       Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACT1, LINE, 0,1) From TRACEABX3
       #---------------------------------------------------------------------
       LINE = ""
       Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACT1, LINE, 0,1) From TRACEABX3
       #---------------------------------------------------------------------
       #**102-Période traitée
       LINE  =  mess(102,GML_MSGGRT,1)+"  "
       LINE +=  (num$([M:LEAP]STRPAYDATI)+"  "+ mess(103,GML_MSGGRT,1)+"  "+num$([M:LEAP]ENDPAYDATI))
       Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACT1, LINE, 0,1) From TRACEABX3
       #---------------------------------------------------------------------
       LINE = string$(115,"")
       Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACT1, LINE, 0,1) From TRACEABX3
       #---------------------------------------------------------------------
       LINE = string$(115,"*")
       Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACT1, LINE, 0,1) From TRACEABX3
       #---------------------------------------------------------------------
       #*FQ95502 Création of messages 115 to 119
       LINE =      left$( mess(100,GML_MSGGRT,1)     + string$(20,' '), 20)+" ! "         # Contrat
       LINE +=     left$( mess(115,GML_MSGGRT,1)     + string$(12,' '), 12)+" ! "
       LINE +=     left$( mess(116,GML_MSGGRT,1)     + string$(12,' '), 12)+" !   "
       LINE +=     left$( mess(117,GML_MSGGRT,1)     + string$(19,' '), 19)+" !  "
       LINE +=     left$( mess(118,GML_MSGGRT,1)     + string$(19,' '), 19)+" !  "
       LINE +=     left$( mess(119,GML_MSGGRT,1)     + string$(19,' '), 19)+" ! "
       Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACT1, LINE, 0,1) From TRACEABX3
       #---------------------------------------------------------------------
       LINE = string$(115,"*")
       Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACT1, LINE, 0,1) From TRACEABX3
       #---------------------------------------------------------------------

    Endif
  Endif

Return
################################################################################
# Traitement de gestion de la trace - informations particulières à l'action    #
################################################################################
$ECR_LIGNE
Local    Char    LINE(115)
Local Char FMTDAT4

FMTDAT4="D:" + GFMDAT4
  #===================================
  If ( FLGDET = G_OUI ) Then
    #==========================
    If ( WEVT_PLN=1 )  &  ( [M:LEAP]STRPAYDAT <> [0/0/0] & GPAYAMTM <> 0 )
        #  (ligne 1)
        If GLEAREF <> ""
           LINE    =  left$(GLEAREF+ string$(20,' '), 20) +"   "
           GLEAREF = ""
        Else
           LINE    =  string$(23," ")
        Endif
        LINE  +=  left$( format$(FMTDAT4,WDATDEBM)  + string$(10,' '), 10) +"   "
        LINE  +=  left$( format$(FMTDAT4,WDATFINM)  + string$(10,' '), 10) + string$(6," ")
        LINE  +=  left$( format$('N:'+GFMT3, GPAYAMTM) + string$(19,' '), 19) +"  "
        LINE  +=  left$( format$('N:'+GFMT3, GPRIAMTM) + string$(19,' '), 19) +"  "
        LINE  +=  left$( format$('N:'+GFMT3, GINTAMTM) + string$(19,' '), 19) +" "
        Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    Endif
    #==========================
    If ( WEVT_PLN=6 )  &  ( [M:LEAP]STRPAYDATI <> [0/0/0] & GPAYAMTM <> 0 )
        #  (ligne 1)
        If GLEAREFI <> ""
           LINE     =  left$( GLEAREFI+ string$(20,' '), 20) +"   "
           GLEAREFI = ""
        Else
           LINE     =  string$(23," ")
        Endif
        LINE  +=  left$( format$(FMTDAT4,WDATDEBM)    + string$(10,' '), 10) +"   "
        LINE  +=  left$( format$(FMTDAT4,WDATFINM)    + string$(10,' '), 10) + string$(6," ")
        LINE  +=  left$( format$('N:'+GFMT3, GPAYAMTM) + string$(18,' '), 18) +"  "
        LINE  +=  left$( format$('N:'+GFMT3, GPRIAMTM) + string$(18,' '), 18) +"  "
        LINE  +=  left$( format$('N:'+GFMT3, GINTAMTM) + string$(18,' '), 18) +" "
        Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACT1, LINE, 0,1) From TRACEABX3
    Endif
    #====
  Endif
Return
#=====================================================================
$ECR_LIGNE_VAR
Local    Char    LINE(115)
  #===================================
  If ( FLGDET = G_OUI ) Then
    #==========================
    #  (ligne 1)
    LINE =  left$( [F:MAS1]LEAREF                          + string$(20,' '), 20) +"!"
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    #===================================
  Endif
Return
#=====================================================================
$GESTRACE
Local Char LDES
Local Integer I, LERROR, ERROR
Local    Char    LINE(115)
Local Integer IFIRST

  Case TRTYP
    When 1         # Ouverture de la trace
      Call OUVRE_TRACE(mess(99,GML_MSGGRT,1),1) From TRACEABX3
    When 20        # Paramètres de l'action
      # Date des loyers
      # EVENEMENTS GENERES POUR ECRITURES DESTINEES AUX COMPTES INDIVIDUELS
      If [M:LEAP]STRPAYDAT <> [0/0/0]
         LINE  =  mess(104,GML_MSGGRT,1)
         Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3
         LINE  =  "      "+mess(102,GML_MSGGRT,1)+"  "
         LINE +=  left$(num$([M:LEAP]STRPAYDAT), 20)+ "  " + mess(103,GML_MSGGRT,1)+"  "+num$([M:LEAP]ENDPAYDAT)
         Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3
      Endif
      # EVENEMENTS GENERES POUR ECRITURES DESTINEES AUX COMPTES CONSOLIDES
      If [M:LEAP]STRPAYDATI <> [0/0/0]
         LINE  =  mess(105,GML_MSGGRT,1)
         Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3
         LINE  =  "      "+mess(102,GML_MSGGRT,1)+"  "
         LINE +=  left$(num$([M:LEAP]STRPAYDATI), 20)+ "  " + mess(103,GML_MSGGRT,1)+"  "+num$([M:LEAP]ENDPAYDATI)
         Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3
      Endif
    When Default
  Endcase
Return

######################################################################
# Sous-pro et routines communes
######################################################################
Subprog LAUNCH_ACT(PACTTYP)
Value Char PACTTYP

 Case PACTTYP
   When GTAMUNI
     Infbox mess(1,GML_MSGACT,1)
   When GTAMMAS
     Local Char PARAM(30)(1..5)
     Local Char VALEUR
     PARAM(1)=GTAMMAS             # Massif / unitaire
     PARAM(2)="LEAPAY"         # Nom de l'action métier
     PARAM(3)=num$(GVML_OMLOCFI)  # Objet métier de référence
     PARAM(4)=num$(G_OUI)         # Mono société
     PARAM(5)=num$(G_NON)         # Plan d'amortissement
     #  Traitement      Fenêtre
     Call TRAITE_CHAR(VALEUR,PARAM,"","TRTLEAPAY","LEAPAY",4,"") From GTRAITE
   When Default
  Endcase
End
######################################################################################
#========================================================================
#
Subprog ECR_TRACE_DETSTAT(PLEAREF,PPLN, PTRT,PMAJ,PERR)
#
# Sous-programme d'émission des statistiques par contrat
# ------------------------------------------------------------------------------
Value Char    PLEAREF     # Contrat pour laquelle les stats sont émises
Value Integer PPLN        # Plan traité
Value Integer PTRT        # Nombre de contrats traités traités
Value Integer PMAJ        # Nombre de contrats mis à jour
Value Integer PERR        # Nombre de contrats en erreur

If ACTSILENCE=G_OUI : End : Endif

Local Char    LIGNE(115)
Local Integer CHAPITRE   #: CHAPITRE=GTRC_STAT

 If PPLN=1    : CHAPITRE = GTRC_CRACTIO : Endif
 If PPLN=6    : CHAPITRE = GTRC_CRACT1   : Endif


Call ECR_TRACE(PLEAREF,CHAPITRE,"",0,1) From TRACEABX3

If PTRT > 0
   LIGNE=mess(506,GML_MSGFAS,1)-"("+PLEAREF+")"
   Call ECR_TRACE(PLEAREF,CHAPITRE,LIGNE,0,1) From TRACEABX3 #"Statistiques"

   LIGNE=string$(36,"=")
   Call ECR_TRACE(PLEAREF,CHAPITRE,LIGNE,0,1) From TRACEABX3

   LIGNE =space$(1)
   LIGNE+=left$(mess(507,GML_MSGFAS,1)+space$(12),12)+space$(1)
   LIGNE+=left$(mess(508,GML_MSGFAS,1)+space$(10),10)+space$(2)
   LIGNE+=left$(mess(509,GML_MSGFAS,1)+space$(7),7)
   Call ECR_TRACE(PLEAREF,CHAPITRE,LIGNE,0,1) From TRACEABX3

   LIGNE=string$(36,"=") : Call ECR_TRACE(PLEAREF,CHAPITRE,LIGNE,0,1) From TRACEABX3
   LIGNE=space$(1)+num$(PTRT)+space$(13-len(num$(PTRT)))
&                 +num$(PMAJ)+space$(12-len(num$(PMAJ)))
&                 +num$(PERR)+space$(12-len(num$(PERR)))
   Call ECR_TRACE(PLEAREF,CHAPITRE,LIGNE,0,1) From TRACEABX3

   LIGNE=string$(36,"-")
   Call ECR_TRACE(PLEAREF,CHAPITRE,LIGNE,0,1) From TRACEABX3
Endif

End

