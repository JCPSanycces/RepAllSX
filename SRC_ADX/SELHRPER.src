  Call C_SELSTA([M:SEP]SELSTA1,[M:SEP]SELSTA2,[M:SEP]SELSTA3,[M:SEP]SELSTA4,VALEUR,[M:SEP]SELSTA6,[M:SEP]SELSTA7)
