  Call C_SELSTA([M:SEP]SELSTA1,[M:SEP]SELSTA2,[M:SEP]SELSTA3,[M:SEP]SELSTA4,[M:SEP]SELSTA5,VALEUR,[M:SEP]SELSTA7)
