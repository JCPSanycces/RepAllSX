Subprog C_SELSTA4(VALEUR)
Variable Integer VALEUR
  Call C_SELSTA([M:SEP]SELSTA1,[M:SEP]SELSTA2,[M:SEP]SELSTA3,VALEUR,[M:SEP]SELSTA5,[M:SEP]SELSTA6,[M:SEP]SELSTA7)
