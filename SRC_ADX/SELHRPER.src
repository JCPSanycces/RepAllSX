######################################################################################
# Fiche 64978 - SYMEU - 04/01/2011 : ajout de critĆØres dans le filtre
######################################################################################
Subprog C_SELSTA(P_STA1,P_STA2,P_STA3,P_STA4,P_STA5,P_STA6,P_STA7)
Value Integer P_STA1,P_STA2,P_STA3,P_STA4,P_STA5,P_STA6,P_STA7
   If P_STA1 = 1 and P_STA2 = 1 and P_STA3 = 1 and P_STA4 = 1
& and P_STA5 = 1 and P_STA6 = 1 and P_STA7 = 1 Then
    GMESSAGE = mess(195,709,1)
    mkstat=2
  Endif
End
