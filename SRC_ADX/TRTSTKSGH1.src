#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
######################################################################################
$ACTION
Return
######################################################################################
######################################################################################
Subprog VAL_SGH(VCRNUM)
Variable Char    VCRNUM()

Local Integer WRET
Call VALIDATE ([M:SCS1]VCRNUM,[L]WRET)  From TRTSTKSGH1

End
######################################################################################
######################################################################################
Subprog VALIDATE(SGHNUM,RETVAL)
Value Char     SGHNUM
Value Integer  RETVAL

[L]RETVAL = 0

Local File SCHGH  [SGH]
Local File SCHGD  [SGD]

Local Char    SYMBOLSGH
Local Integer LRET
Local Char    WABREV(3)
Local Char    CBLOB(3)
Local Char    WCPT(GLONANM)

#----- Open trace -----#
Call OUVRE_TRACE(mess(144,7711,1)) From LECFIC

#----- Logic symbol -----#
SYMBOLSGH="SGH"+[L]SGHNUM
Lock=SYMBOLSGH
If fstat
  Call ECR_TRACE("$SCHGH"-[L]SGHNUM-mess(10,100,1),1) From GESECRAN
  SYMBOLSGH="" : Goto FINVAL
Endif

Call DEBTRANS From GLOCK

$TR_VALID

Trbegin [F:SGH]
Readlock [F:SGH]SGH0=[L]SGHNUM
If fstat=1
  GOK=-1 : GLOCK="$SCHGH"                      : Goto ROL_VAL
Elsif fstat
  GOK=0  : Call RSTA("SGH",[L]SGHNUM) From GLOCK : Goto AB_VAL
Endif

#85785
Local Integer PORDIGSIGN : [L]PORDIGSIGN = func PORLEGLIB.DIGSIGN([F:SGH]STOFCY, "")

If [L]PORDIGSIGN = 1

  Local Char LNUM(GLONVCR)

  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  Call LEC_FCY ([F:SGH]STOFCY) From CPTLEC

  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC

  # Document type
  If [F:SGH]SGHTYP<>""
    If !clalev ([F:TSG]) : Local File TABSGHTYP [TSG] : Endif
    Call LEC_TSG_LEG([F:CPY]LEG,[F:SGH]SGHTYP,LRET) From TRTLECLEG
    If LRET<>0 Raz [F:TSG] : Endif
    WCPT = [F:TSG]CODNUMEND

    If func PORLEGLIB.ANM_OK(WCPT, GMESSAGE) <> 1
      GERR=1 : GOK=0 : Goto AB_VAL
    Endif

  Endif

  Call NUMERO(WCPT,[F:SGH]STOFCY,[F:SGH]IPTDAT,"",LNUM,LRET) From SUBANM

  If GOK<0 Goto ROL_VAL Endif

  If LRET <> 0 | GOK<1
    Local Char MESSA(80)
    Local Integer SAUV_STAT
    If dim(STAT)<0 : Local Integer STAT : Endif
    SAUV_STAT=STAT : STAT=LRET
    #GMESSAGE=mess(60,199,1)-"("+[F:TCA]CODNUM(13)+") : "
    GMESSAGE=mess(60,199,1)-"("+WCPT+") : "
    Gosub MESSAGE From SUBANM
    STAT=SAUV_STAT
    GMESSAGE-=MESSA : GERR=1 : GOK=0 : Goto AB_VAL
  Endif

  # BRBAN 08-07-2014 SAM#93745 US2
  If [L]PORDIGSIGN=1
    If find([F:TSG]RECTYP,2,3,4)
      If [F:SGH]MANDOC=''
        If GTRACE = ''
          If find([F:TSG]RECTYP,2,3)
            GMESSAGE=mess(128,7711,1) #Should fill the manual/backup document number.
          Else #4
            GMESSAGE=mess(196,7711,1) #Should fill the manual document field with the external document number.
          Endif
          GERR= 1
          GOK = 0
        Else
          If find([F:TSG]RECTYP,2,3)
            Call ECR_TRACE(mess(128,7711,1),1) From GESECRAN #Should fill the manual/backup document number.
          Else #4
            Call ECR_TRACE(mess(196,7711,1),1) From GESECRAN #Should fill the manual document field with the external document number.
          Endif
          GOK = 0
        Endif
      Endif
    Endif
  Endif
  If GOK=0 : Goto AB_VAL : Endif

  #If [L]PORDIGSIGN = 1
    Gosub CTRL_CHRONOLOGIC
    If GOK=0 : Goto AB_VAL : Endif
  #Endif

  # Table updates with the new sequence counter
  If !clalev([F:ABB]) : Local File ABLOB     [ABB] : Endif
  If !clalev([F:ACB]) : Local File ACLOB     [ACB] : Endif
  If !clalev([F:AOX]) : Local File AOBJTXT   [AOX] : Endif
  If !clalev([F:AOM]) : Local File AOBJTXTA  [AOM] : Endif
  If !clalev([F:CAL]) : Local File CPTANALIN [CAL] : Endif
  If !clalev([F:STA]) : Local File STOALL    [STA] : Endif
  If !clalev([F:STO]) : Local File STOCK     [STO] : Endif
  If !clalev([F:STJ]) : Local File STOJOU    [STJ] : Endif
  If !clalev([F:STL]) : Local File STOLOT    [STL] : Endif
  If !clalev([F:STS]) : Local File STOSER    [STS] : Endif
  If !clalev([F:STR]) : Local File STOTRK    [STR] : Endif

  [L]WABREV="SGH"

  Update [AOX] Where ABREV=[L]WABREV & IDENT1=[L]SGHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("AOX") From GLOCK
    Goto AB_VAL
  Endif
  Update [AOM] Where ABREV=[L]WABREV & IDENT1=[L]SGHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("AOM") From GLOCK
    Goto AB_VAL
  Endif
  [L]CBLOB = "PJ_" : # Pour les pieces jointes
  Update [ACB] Where CODBLB=[L]CBLOB+[L]WABREV & IDENT1=[L]SGHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("ACB") From GLOCK
    Goto AB_VAL
  Endif
  Update [ABB] Where CODBLB=[L]CBLOB+[L]WABREV & IDENT1=[L]SGHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("ABB") From GLOCK
    Goto AB_VAL
  Endif
  [L]CBLOB = "CO_" : # Pour les commentaires
  Update [ACB] Where CODBLB=[L]CBLOB+[L]WABREV & IDENT1=[L]SGHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("ACB") From GLOCK
    Goto AB_VAL
  Endif

  Update [STA] Where VCRTYP=29 & VCRNUM=[L]SGHNUM With VCRNUM=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("STA") From GLOCK
    Goto AB_VAL
  Endif
  Update [STJ] Where VCRTYP=29 & VCRNUM=[L]SGHNUM With VCRNUM=LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("STJ") From GLOCK
    Goto AB_VAL
  Endif
  Update [STJ] Where VCRTYPORI=29 & VCRNUMORI=[L]SGHNUM With VCRNUMORI=LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("STJ") From GLOCK
    Goto AB_VAL
  Endif
  Update [STR] Where VCRTYP=29 & VCRNUM=[L]SGHNUM With VCRNUM=LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("STR") From GLOCK
    Goto AB_VAL
  Endif
  Update [STR] Where VCRTYPORI=29 & VCRNUMORI=[L]SGHNUM With VCRNUMORI=LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("STR") From GLOCK
    Goto AB_VAL
  Endif

  Update [CAL] Where ABRFIC="SGD" & VCRTYP=29 & VCRNUM=[L]SGHNUM With VCRNUM=LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("CAL") From GLOCK
    Goto AB_VAL
  Endif

  Update [SGD] Where VCRNUM=[L]SGHNUM With VCRNUM=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("SGD") From GLOCK
    Goto AB_VAL
  Endif

  [F:SGH]TMPSGHNUM = [L]SGHNUM
  [F:SGH]VCRNUM = LNUM
  Rewrite [SGH]
  If fstat
    GOK=0 : Call FSTA("SGH") From GLOCK
    Goto AB_VAL
  Endif
  Readlock [SGH]SGH0 = LNUM
  If fstat=1
    GOK=-1 : GLOCK="$SCHGH"+SGHNUM : Goto ROL_VAL
  Elsif fstat
     GOK=0  : Call RSTA("SRH",SGHNUM) From GLOCK : Goto AB_VAL
  Endif

  If clalev([M:SCS1]) : If dim([M:SCS1]VCRNUM)>0 : [M:SCS1]VCRNUM = LNUM : Endif : Endif

  #If [L]PORDIGSIGN = 1
    Gosub DIGSIGN

    If [L]LRET > 1
      If GMESSAGE <> "" : Call ECR_TRACE(GMESSAGE,1) From GESECRAN : Endif
      Raz GMESSAGE : Goto AB_VAL
    Endif

  #Endif
  If [L]LRET=0
    Gosub SEND_TO_AT
  Endif

  [F:SGH]CFMFLG = 2
  Rewrite [F:SGH]
  If fstat : GOK=0 : Call FSTA("SGH") From GLOCK : Goto AB_VAL : Endif

Endif

Commit
[L]RETVAL = 1

Goto FINVAL
#----- Rollback with retry -----#
$ROL_VAL
Rollback
Call ROLL From GLOCK
If GROLL
  Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
  Goto FINVAL
Else
  Goto TR_VALID
Endif
#----- Definitive rollback -----#
$AB_VAL
Rollback
If GMESSAGE <> ""
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Endif
Call ECR_TRACE(mess(18,114,1),1) From GESECRAN
Call ECR_TRACE([F:SGH]VCRNUM-mess(123,197,1),0) From GESECRAN

$FINVAL
If SYMBOLSGH<>""  Unlock=SYMBOLSGH : Raz SYMBOLSGH : Endif

Call ECR_TRACE(mess(144,7711,1)-mess(124,100,1),0) From GESECRAN
Call FERME_TRACE  From LECFIC
Call LEC_TRACE  From LECFIC

End
######################################################################################
######################################################################################
$DIGSIGN

#signature variables
Local Char    CURTIM          : [L]CURTIM = time$
Local Date    CURDAT          : [L]CURDAT = date$
Local Char    MESSTOSIGN(250)
Local Integer TYP             : [L]TYP = 0

Case [F:SGH]BETFCYCOD
  When 2 : [L]TYP = 6
  When 4 : [L]TYP = 7
  When 5 : [L]TYP = 8
Endcase

[L]MESSTOSIGN = format$("D:YYYY[-]MM[-]DD",[F:SGH]IPTDAT) + ";" + format$("D:YYYY[-]MM[-]DD",[L]CURDAT) + "T" + [L]CURTIM + ";" + [F:SGH]SGHTYP-[F:SGH]VCRNUM + ";" +
& "0.00" + ";"
Call SIGNDOC_NEW ([F:SGH]VCRNUM, [L]TYP, [F:SGH]SGHTYP,[L]MESSTOSIGN,[L]WCPT,[F:SGH]IPTDAT,
&             [L]CURDAT,[L]CURTIM,[F:TSG]RECTYP,[F:TSG]SAFTTRNTYP,LRET)                           From DKSLIB

Return
######################################################################################
######################################################################################
$CTRL_CHRONOLOGIC

Local Integer SEQ
Local Char    DOCNUM(GLONVCR) : DOCNUM=[L]LNUM
If clalev([F:SGHB])=0 Local File SCHGH [SGHB] Endif

Repeat
 Call NUMERO_PREC(WCPT,[F:SGH]STOFCY,[F:SGH]IPTDAT,"",[L]DOCNUM,SEQ,LRET) From SUBANM
 If LRET<>0
    GMESSAGE = WCPT-DOCNUM-mess(60,199,1) : GOK=0 : Break
 Endif
 If SEQ>=1
    Read [F:SGHB]SGH0=DOCNUM
    If !fstat
       If [F:SGHB]IPTDAT>[F:SGH]IPTDAT
          GOK=0 :GMESSAGE = mess(145,7711,1)
       Endif
       SEQ=0
    Endif
 Endif
Until SEQ<=1
Close Local File [F:SGHB]
Return
######################################################################################
######################################################################################
$SGHTYP
#85785 - used also on migration tool, carefull
If !clalev([F:FGR]) : Local File FACGROUP  [FGR] : Endif
If !clalev([F:TSG]) : Local File TABSGHTYP [TSG] : Endif
If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif

If [F:FCY]FCY <> GFCY
  Filter [F:FCY] Where [F:FCY]FCY = GFCY
  Read [F:FCY]FCY0 First
  Filter [F:FCY]
  If fstat > 1 : Raz [F:FCY] : Endif
Endif

Link [TSG] With [FGR]FGR0=[F:TSG]GFY;GFCY As [KTSG]

Filter [KTSG] Where ([F:TSG]GFY="" | [FGR]FCY=GFCY) & ([F:TSG]LEG=[F:FCY]LEG | [F:TSG]LEG="" ) & [F:TSG]BETFCYCOD = [F:SRT]BETFCYCOD Order By [F:TSG]LEG Desc;[F:FGR]FCY Desc
Read [KTSG] First
If fstat=0
  WSGHTYP = [F:TSG]SGHTYP
Endif

Filter [KTSG]
If clalev([KTSG]) : Close File [KTSG] : Endif

Return
######################################################################################
######################################################################################
$SEND_TO_AT
If [F:SGH]ATDTCOD <> ""
   If !clalev ([F:DKD]) : Local File DKSDATA [DKD] : Endif
   Read [F:DKD]DKD0 = "SAFT-PT";[F:SGH]SGHTYP;[F:SGH]VCRNUM
   If !fstat
      If [F:DKD]ATDTCOD <> ""
         Call ECR_TRACE(mess(46,8933,1),1) From GESECRAN
      Else
         [F:DKD]ATDTCOD    = [F:SGH]ATDTCOD
         [F:DKD]ATDTCOMSTA = "0"
         [F:DKD]ATDTINPTYP = 1
         [F:DKD]RECTYP     = [F:TSG]RECTYP
         Rewrite [F:DKD]
         If fstat
            Call ECR_TRACE(mess(47,8933,1),1) From GESECRAN
         Endif
      Endif
   Else
      Call ECR_TRACE(mess(2,8933,1),1) From GESECRAN
   Endif
Else
   Local Char    AUTSND(1)
   Local Integer RETSTAT
   Local Integer ITYP

   Case [F:SGH]BETFCYCOD
     When 2 : [L]ITYP = 6
     When 4 : [L]ITYP = 7
     When 5 : [L]ITYP = 8
   Endcase

  Call PARAM([F:SGH]STOFCY, "AUTCOMAT", [L]AUTSND) From ADOVAL
  # BRBAN 24-03-2015 #106027
  If [L]AUTSND = '2' & func PORLEGLIB.DOCCTR([L]ITYP,'',[F:SGH]SGHTYP,[F:SGH]STOFCY) = 1 & [F:BPA]CRY='PT' & func PORLEGLIB1.CTRL_COMDAT([F:SGH]STOFCY,[F:SGH]DPEDAT,[F:SGH]ETD)=1
    Call SENDDTTOAT([F:SGH]VCRNUM,[L]ITYP, [L]RETSTAT) From PORLEGLIB1
  Endif
Endif

Return
######################################################################################
######################################################################################

