#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################################
#  US Revisions                                                                         #
#                                                                                       #
#  Rev #  Log #        Rev Date     Who Description                                     #
#  -----  ------------ ------------ --- ------------------------------------------------#
#   001   US125R1      07/31/01     LPD Customer, Supplier & Product Searches 
#########################################################################################

Local Char PARAM(250)(1..1)
Local Char VALEUR(30)
Call SAISIE_CHAR(VALEUR,PARAM,"USASUPSEA","USATRTSEA","") From GSAISIE
End

$ACTION
If dim(BOITE)>0
 Case BOITE
  When "USAPRDSEA"
   Case ACTION
    When "DEBUT" : Gosub DEB_PRD
    When "OK"    : VALEUR = [F:ITM]ITMREF : Read [F:ITM] ITM0 = VALEUR
   Endcase
  When "USACUSSEA"
   Case ACTION
    When "DEBUT" : Gosub DEB_CUS
    When "OK"    : VALEUR = [F:BPA]BPANUM : Read [F:BPC] BPC0 = VALEUR
   Endcase
  When "USASUPSEA"
   Case ACTION
    When "DEBUT" : Gosub DEB_SUP
    When "OK"    : VALEUR = [F:BPA]BPANUM : Read [F:BPS] BPS0 = VALEUR
   Endcase
 Endcase
Else
 Case ACTION
  When "SEL_TABLE"
   Case TABLE
    When "USAPRDSEA" : Gosub SEL_PRD
    When "USACUSSEA" : Gosub SEL_CUS
    When "USASUPSEA" : Gosub SEL_SUP
   Endcase
 Endcase
Endif
Return

################################################################################
#    Quick Product Search Routine
#    Quick Product Search by Search Key and Description
################################################################################

$DEB_PRD

If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : Endif

[M]SEAKEY = ""
[M]PRDDES = ""

Return

################################################################################

$SEL_PRD

If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:ITG]) = 0 : Local File ITMCATEG  [ITG] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ITS]) = 0 : Local File ITMSALES  [ITS] : Endif
If clalev([F:TCU]) = 0 : Local File TABCUR    [TCU] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX] : Endif  # FGR 30/06/2009 : X3SUIVI56189

Local Char FMT (15)

FMT = ""
Read [TCU]TCU0 = "USD"
If !fstat : FMT = [F:TCU]CURFMT1 : Endif

CRITERE = "1=1"

#Description
If [M]PRDDES <> ""
 #Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:ITM]ITMDES1,"' + [M]PRDDES + '")',"&") From GOBJSUB
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:AXX]TEXTE,"' + [M]PRDDES + '")',"&") From GOBJSUB  # FGR 30/06/2009 : X3SUIVI56189
Endif

#Search Key
If [M]SEAKEY <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:ITM]SEAKEY,"' +[M]SEAKEY +'")',"&") From GOBJSUB
Endif

If [M]SLDFLG = 2
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:ITG]SALFLG = 2',"&") From GOBJSUB
Endif

#Link [ITM] With [ITG]ITG0="";[F:ITM]TCLCOD
#&             , [ITS]ITS0=[F:ITM]ITMREF
#&          As [LNK]
Link [ITM] With [ITG]ITG0="";[F:ITM]TCLCOD
&             , [ITS]ITS0=[F:ITM]ITMREF
&             , [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:ITM]ITMREF;""
&          As [LNK]                                                                                 # FGR 30/06/2009 : X3SUIVI56189

Default File [LNK]

ORDRE = '[F:ITM]SEAKEY;[ITM]ITMREF'
START = '[F:ITM]ITMREF'

NBCOL = 1
COL(NBCOL) = "[F:ITM]ITMREF"
Call TEXTFIC("ITMMASTER","ITMREF",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
#COL(NBCOL) = "[F:ITM]ITMDES1"
#Call TEXTFIC("ITMMASTER","ITMDES1",2,TIT(NBCOL) ) From OBJDIV # FGR 30/06/2009 : X3SUIVI56189
COL(NBCOL) = "[F:AXX]TEXTE"                                    # FGR 30/06/2009 : X3SUIVI56189
Call TEXTFIC("ITMMASTER","DES1AXX",2,TIT(NBCOL) ) From OBJDIV  # FGR 30/06/2009 : X3SUIVI56189
NBCOL += 1
COL(NBCOL) = "[F:ITM]SEAKEY"
Call TEXTFIC("ITMMASTER","SEAKEY",2,TIT(NBCOL) ) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:ITM]TCLCOD"
Call TEXTFIC("ITMMASTER","TCLCOD",2,TIT(NBCOL) ) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:ITG]TCLDES"
Call TEXTFIC("ITMCATEG","TCLDES",2,TIT(NBCOL) ) From OBJDIV
NBCOL += 1
COL(NBCOL) = "mess([F:ITS]ITMTYP,436,1)"
Call TEXTFIC("ITMSALES","ITMTYP",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = 'format$("N:"+FMT,[F:ITS]BASPRI)'
Call TEXTFIC("ITMSALES","BASPRI",2,TIT(NBCOL)) From OBJDIV

TIT(0) = mess( 1,1010,1)
Return

################################################################################

$DEB_CUS

If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif

[M]BPRSHO = ""
[M]BPCNAM = ""
[M]NAF = ""
[M]POSCOD = ""
[M]TEL = ""
[M]CTY = ""
[M]SAT = ""

Return

################################################################################

$SEL_CUS

If clalev([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif

# select (bpanum >= last customer number AND bpaadd > last address displayed for customer) or 
# (bpanum > last customer displayed)
 
CRITERE = "[F:BPC]BPCSTA=2" #only show active customers

#Namekey
If [M]BPRSHO <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPR]BPRSHO,"' + [M]BPRSHO + '")',"&") From GOBJSUB
Endif

#Company name
If [M]BPCNAM <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPC]BPCNAM,"' +[M]BPCNAM +'")',"&") From GOBJSUB
Endif

#Type
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:BPC]BPCTYP=' + num$([M]BPCTYP),"&") From GOBJSUB

#SIC code
If [M]NAF <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPR]NAF,"'+[M]NAF +'")',"&") From GOBJSUB
Endif

#Postal code
If [M]POSCOD<> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPA]POSCOD,"' +[M]POSCOD +'")',"&") From GOBJSUB
Endif

#Telephone number
If [M]TEL <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPA]TEL,"' +[M]TEL +'")',"&") From GOBJSUB
Endif

#City
If [M]CTY <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPA]CTY,"'+[M]CTY+'")',"&") From GOBJSUB
Endif

#State
If [M]SAT <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPA]SAT,"'+[M]SAT+'")',"&") From GOBJSUB
Endif

#Country
If [M]CRY <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPA]CRY,"'+[M]CRY+'")',"&") From GOBJSUB
Endif

#Default address
#the field [F:BPC]BPAADD contains the default address for the customer
If [M]DEFADD = 2 #box is checked
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:BPC]BPAADD= [F:BPA]BPAADD',"&") From GOBJSUB
Endif

Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","[BPA]BPATYP=1 & [BPR]BPCFLG=2 & [BPC]BPCNUM=[BPR]BPRNUM","&")
& From GOBJSUB

Link [BPA] With [BPC]BPC0 = [BPA]BPANUM,
&               [BPR]BPR0 = [BPA]BPANUM
&        As [LNK]

Default File [LNK]

ORDRE = "[F:BPA]BPATYP;[F:BPA]BPANUM;[F:BPA]BPAADD"
START = '[F:BPA]BPANUM'

NBCOL = 1
COL(NBCOL) = "[F:BPA]BPANUM"
Call TEXTFIC("BPADDRESS","BPANUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:BPR]BPRSHO"
Call TEXTFIC("BPARTNER","BPRSHO",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:BPC]BPCNAM"
Call TEXTFIC("BPCUSTOMER","BPCNAM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "mess([F:BPC]BPCTYP,401,1)"
Call TEXTFIC("BPCUSTOMER","BPCTYP",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:BPR]NAF"
Call TEXTFIC("BPARTNER","NAF",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "format$([F:TCY]TELFMT,[F:BPA]TEL)"
Call TEXTFIC("BPADDRESS","TEL",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "format$([F:TCY]POSCODFMT,[F:BPA]POSCOD)"
Call TEXTFIC("BPADDRESS","POSCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:BPA]CTY"
Call TEXTFIC("BPADDRESS","CTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:BPA]SAT"
Call TEXTFIC("BPADDRESS","SAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:BPA]CRY"
Call TEXTFIC("BPADDRESS","CRY",2,TIT(NBCOL)) From OBJDIV

TIT(0) = mess( 2,1010,1)

Return

################################################################################

$DEB_SUP

If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif

[M]BPRSHO = ""
[M]BPSNAM = ""    
[M]NAF = ""
[M]POSCOD = ""
[M]TEL = ""
[M]CTY = ""
[M]SAT = ""

Return

################################################################################

$SEL_SUP

If clalev([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif

CRITERE = "[F:BPS]ENAFLG=2" #only show active suppliers

#Namekey
If [M]BPRSHO <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPR]BPRSHO,"' + [M]BPRSHO + '")',"&") From GOBJSUB
Endif

#Company name
If [M]BPSNAM <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPS]BPSNAM,"' + [M]BPSNAM +'")',"&") From GOBJSUB
Endif

#Type
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:BPS]BPSTYP=' + num$([M]BPSTYP),"&") From GOBJSUB

#SIC code
If [M]NAF <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPR]NAF,"'+[M]NAF +'")',"&") From GOBJSUB
Endif

#Postal code
If [M]POSCOD <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPA]POSCOD,"' +[M]POSCOD +'")',"&") From GOBJSUB
Endif

#Telephone number
If [M]TEL <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPA]TEL,"' +[M]TEL +'")',"&") From GOBJSUB
Endif

#City
If [M]CTY <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPA]CTY,"' +[M]CTY+'")',"&") From GOBJSUB
Endif

#State
If [M]SAT <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPA]SAT,"' +[M]SAT+'")',"&") From GOBJSUB
Endif

#Country
If [M]CRY <> ""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'pat([F:BPA]CRY,"'+[M]CRY+'")',"&") From GOBJSUB
Endif

#Default address
#the field [F:BPR]BPAADD contains the default address for the customer
If [M]DEFADD = 2 #box is checked
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:BPS]BPAADD= [F:BPA]BPAADD',"&") From GOBJSUB
Endif

Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","[BPA]BPATYP=1 & [BPR]BPSFLG=2 & [BPS]BPSNUM=[BPR]BPRNUM","&")
& From GOBJSUB

Link [BPA] With [BPS]BPS0 = [BPA]BPANUM,
&               [BPR]BPR0 = [BPA]BPANUM
&        As [LNK]

Default File [LNK]

ORDRE = "[F:BPA]BPATYP;[F:BPA]BPANUM;[F:BPA]BPAADD"
START = '[F:BPA]BPANUM'

NBCOL = 1
COL(NBCOL) = "[F:BPA]BPANUM"
Call TEXTFIC("BPADDRESS","BPANUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:BPR]BPRSHO"
Call TEXTFIC("BPARTNER","BPRSHO",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:BPS]BPSNAM"
Call TEXTFIC("BPSUPPLIER","BPSNAM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "mess([F:BPS]BPSTYP,501,1)"
Call TEXTFIC("BPSUPPLIER","BPSTYP",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:BPR]NAF"
Call TEXTFIC("BPARTNER","NAF",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "format$([F:TCY]TELFMT,[F:BPA]TEL)"
Call TEXTFIC("BPADDRESS","TEL",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "format$([F:TCY]POSCODFMT,[F:BPA]POSCOD)"
Call TEXTFIC("BPADDRESS","POSCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:BPA]CTY"
Call TEXTFIC("BPADDRESS","CTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:BPA]SAT"
Call TEXTFIC("BPADDRESS","SAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1
COL(NBCOL) = "[F:BPA]CRY"
Call TEXTFIC("BPADDRESS","CRY",2,TIT(NBCOL)) From OBJDIV

TIT(0) =  mess( 6,1010,1)

Return

