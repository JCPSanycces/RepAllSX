#<AdxTL>@(#)11.0.0.0 $Revision$
#Raz GPILCOD, GBIDC1 : Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET : End
Local Char PARAM(30)(1..4) , VALEUR(10)
PARAM(1) = "SAC" : PARAM(2) = "GB103/012"
Call TRAITE_CHAR(VALEUR,PARAM,"","TXSEXP","DTXSEXP",3,"") From GTRAITE : End

# Issue X3-107197 - 2018-09-11 by CBO : PARAMETER AND ACTIVITY CODE



$ACTION
Case ACTION
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
Endcase
Return

$INIT_DIA
If clalev([F:TXM])=0  : Local File TXSM       [TXM]  : Endif
If clalev([F:TXW])=0  : Local File TXSW       [TXW]  : Endif
If clalev([F:TXS])=0  : Local File TXSA       [TXS]  : Endif
Local Char    LIGNE(255), FICHIER(GDIMFIC), CHEMIN(GDIMFIC), MACHINE(GDIMFIC), EXT(5), INTERDIT(50),FICHIER1(100), NOMFIC(GDIMFIC)
Local Char    SAVIFS(5), SAVIRS(5), SEPENR(5), SEPCHP(5), SEPTXT(5), SEPDEC(1) , MNT(50), URL(GDIMFIC)
Local Decimal MONTANT
Local Integer I , J , K , IC , SAVIUM , STAT , ER

Default Mask [DIA]
Raz [M]
[M]TXSNAM  = PARAM(1)
[M]VERSION = PARAM(2)
INTERDIT = '?"/\<>*[]|^:;,='
FICHIER   = ctrans(PARAM(1)+"_"+PARAM(2),INTERDIT,string$(len(INTERDIT),'_'))
FICHIER1=FICHIER
If func AFNC.ACTIV("TDB")   # Issue X3-107197
  Call PARAM("","EXPTDB",CHEMIN) From ADOVAL
Endif   # Issue X3-107197
If GBROWS=0
 If CHEMIN<>""
  [L]NOMFIC = filpath(CHEMIN,FICHIER,"csv","","","#")
 Else
  [L]NOMFIC = filpath("",FICHIER,"csv","temp","","#")
 Endif
Else
 Call NAMEFIC(nomap,"TMP","","F"+num$(adxuid(1))+"_"+FICHIER1+".csv",[L]NOMFIC) From INTRUTILA
Endif
Read [TXS]TXS1 = [M]TXSNAM
If !fstat
 Call LECTEXTRA([M]TXSDES,"TXSA","TXSDES",[F:TXS]TXSNAM,"") From ATEXTRA
Endif
Read [TXW]TXW1 = [M]TXSNAM;[M]VERSION
If !fstat
 [M]VERDES = [F:TXW]VERDES
Endif
Return

$CONTROLE
Return


$EXEC
Call TEMPON("") From GESECRAN
Call SET_FICNAM([L]NOMFIC,FICHIER,URL) From ORDSYS
Gosub TR1
Call TEMPOFF From GESECRAN
If ER : Return : Endif
Case [M]EXC
 When 1 : # Enregistrer sur le poste client
  Call COPCLI(FICHIER,[L]NOMFIC,STAT) From ORDSYS
  If STAT=1
   # Fichier non copié sur le poste client
   Call ERREUR(mess(164,141,1)) From GESECRAN
  Elsif STAT>1
   # Fichier inexistant
   Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  Endif
 When 2 : # Activer Excel
  Call OPEN_HTTP(URL) From ORDSYS
Endcase
Return

$TR1
ER = 0
SEPCHP = ";"                                    : # Séparateur de champ (point virgule)
SEPENR = chr$(13)+chr$(10)                      : # Séparateur de ligne (CR+LF)
SEPTXT = '"'                                    : # Séparateur de texte
SEPDEC = mid$(adxsca,4,1)                       : # Séparateur décimal
SAVIFS = adxifs : adxifs = ""
SAVIRS = adxirs : adxirs = SEPENR
SAVIUM = adxium : adxium = GASCII
Onerrgo ERREUR
Openo FICHIER,0
Onerrgo
If ER
 Call ERREUR(mess(13,100,1)+"\|"+FICHIER+"|") From GESECRAN
 Return
Endif
If [M]INTIT=2
 Read [TXS]TXS1 = [M]TXSNAM
 Wrseq '"'+mess(82,123,1)+'"'; : # Intitulé
 For [TXA]TXA0 Where TXSNAM=[M]TXSNAM
  If [F:TXA]SAICOL<3
   I = [F:TXA]NUMCOL-1
   Wrseq SEPCHP+SEPTXT+[M:TXM1]DIVMES(I)+SEPTXT;
  Endif
 Next I
 Wrseq
Endif
Filter [TXM] Where TXSNAM=[M]TXSNAM & VERSION=[M]VERSION & IND=0
For [TXM]TXM0(3) : # Ligne
 J = 0
 COLCUR = 0
 For [TXM]TXM0(4) : # Colonne
  If [F:TXM]COL=0 & [M]INTIT=2
   For [TXM]TXM0
    Wrseq SEPTXT+[M:TXM1]INTIT([F:TXM]LIG-1)+SEPTXT;
    J = 1
   Next
  Elsif [F:TXM]COL<>0
   Read [TXA]TXA0=[M]TXSNAM;[F:TXM]COL
   If [F:TXA]SAICOL<3
    For [TXM]TXM0
     If J : Wrseq SEPCHP; : Endif
     For K=COLCUR+1 To [F:TXM]COL-1
      Wrseq 0;SEPCHP;
     Next K
     COLCUR = [F:TXM]COL
     If [M]UPDAMT=2 & [F:TXM]UPDVAL<>""
      MONTANT = val([F:TXM]UPDVAL)/[F:TXA]DIVCOL
     Else
      MONTANT = val([F:TXM]AMTVAL)/[F:TXA]DIVCOL
     Endif
     Read [TXD]TXD0 = [M]TXSNAM;[F:TXM]LIG;[F:TXM]COL
     MNT = num$(arr(MONTANT,10^-[F:TXD]DECCOL))
     K = instr(1,MNT,".")
     If K
      MNT = left$(MNT,K-1)+SEPDEC+right$(MNT,K+1)
     Endif
     Wrseq MNT;
     J = 1
    Next
   Else
    COLCUR += 1
   Endif
  Endif
 Next
 Wrseq
Next
Filter [TXM]
Openo
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Return

$ERREUR
ER = errn
Resume

###################################
#### Etiquettes du masque TXSEXP
###################################
Subprog AM_TXSNAM(VALEUR)
Variable Char    VALEUR()
Read [TXS]TXS1 = VALEUR
If !fstat
 Call LECTEXTRA([M]TXSDES,"TXSA","TXSDES",VALEUR,"") From ATEXTRA
Else
 GMESSAGE=mess(23,100,1)   :# Fiche inexistante
 mkstat=2 : End
Endif
End

Subprog C_TXSNAM(VALEUR)
Variable Char    VALEUR()
Read [TXS]TXS1 = VALEUR
If !fstat & ( ([F:TXS]NBRCOL>20 & GFLAG="LIMIT") or ([F:TXS]NBRCOL<=20 & GFLAG="NOLIMIT") )
 # Accès impossible à cette fiche
 GMESSAGE = mess(8,123,1) : mkstat=2 : End
Endif
End

Subprog C_VERSION(VALEUR)
Variable Char    VALEUR()
Read [TXW]TXW1 = [M]TXSNAM;VALEUR
If !fstat
 [M]VERDES = [F:TXW]VERDES
Else
 GMESSAGE = mess(23,100,1)   :# Fiche inexistante
 mkstat=2 : End
Endif
End

