###############################################################################


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"    : Gosub AREAD_AFTER
      Endcase
    When "EXU"
      Case [L]AEVENT
        When "AREAD_AFTER"    : Gosub EXU_AREAD_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$PROPERTIES
#  Case [L]CURPRO
#  Endcase
Return




#********************************************************************
# Method AREAD_AFTER
#********************************************************************
#* Switch the display
#*!
$AREAD_AFTER
  Local Integer WPOS  : WPOS = 0
  Local Integer WNB   : WNB = 0
  Local Integer WPOS2 : WPOS2 = 0
  Local Integer WNB2  : WNB2 = 0


  #display EDI XML file setup using the XSD file
  Local File EDIXMLFIL [EXF]
  Local File EDIXMLFILXSD [EXSD]

  Link [EXSD] With [EXF]EXF0 = [EXSD]MSGCOD;[EXSD]MSGREL;[EXSD]MSGFILNOR As [LIEN]
&   Where [EXSD]CODE = this.EXU.CODE
  For [LIEN]
    WNB = WNB + 1
    If WNB < func AFNC.ACTIV("EDINB") #100 #limit of collection
      WPOS = fmet this.ADDLINE('FIL', [V]CST_ALASTPOS)
      this.FIL(WPOS).FILMSGCOD    = [EXF]MSGCOD
      this.FIL(WPOS).FILMSGREL    = [EXF]MSGREL
      this.FIL(WPOS).FILMSGFILNOR = [EXF]MSGFILNOR
      this.FIL(WPOS).FILFILDES    = [EXF]FILDES
      this.FIL(WPOS).FILVALID     = [EXF]VALID


      #display EDI flows using the current XML File structure
      Local File EDIFLO [EFL]
      Local File EDIFLOD [EFLD]
      Link [EFLD] With [EFL]EFL0 = [EFLD]FLOCOD;[EFLD]FLOREL As [LIEN2] Where [EFLD]MSGTYP = 1
&      and [EFLD]MSGCOD = [EXF]MSGCOD and [EFLD]MSGREL = [EXF]MSGREL and [EFLD]MSGFILNOR = [EXF]MSGFILNOR
      For [LIEN2]
        WNB2 = WNB2 + 1
        If WNB2 < func AFNC.ACTIV("EDINB") #100 #limit of collection
          WPOS2 = fmet this.ADDLINE('FLO', [V]CST_ALASTPOS)
          this.FLO(WPOS2).FLOFLOCOD = [EFLD]FLOCOD
          this.FLO(WPOS2).FLOFLOREL = [EFLD]FLOREL
          this.FLO(WPOS2).FLOFLODES = [EFL]FLODES
          this.FLO(WPOS2).FLOVALID  = [EFL]VALID
          this.FLO(WPOS2).FLOFLGACT = [EFL]FLGACT
        Endif
      Next
      LogicClose File [EFLD]
      LogicClose File [EFL]

    Endif
  Next

  LogicClose File [EXSD]
  LogicClose File [EXF]

Return

#********************************************************************
# Method EXU_AREAD_AFTER
#********************************************************************
#* Switch the display
#*!
$EXU_AREAD_AFTER
  If func XSD_IS_USED_IN_XML(this.CODE) = [V]CST_ATRUE
    WOK = fmet this.ASETATTRIBUTE("FILTXT", "$isDisabled", "true") #hide property
  Else
    WOK = fmet this.ASETATTRIBUTE("FILTXT", "$isDisabled", "false") #display property
  Endif
Return


####################################################################

Funprog XSD_IS_USED_IN_XML(WCODE)
Value Char WCODE

  Local Integer WOK : WOK = [V]CST_AFALSE

  Local File EDIXMLFILXSD [EXSD]
  Filter [EXSD] Where [EXSD]CODE = WCODE
  For [EXSD]
    WOK = [V]CST_ATRUE
    Break
  Next
  LogicClose File [EXSD]
End WOK

