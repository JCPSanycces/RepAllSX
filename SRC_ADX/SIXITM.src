#<AdxTL>@(#)0.0.0.0 $Revision$
Local File XIART [XART]
Local File ITMMASTER, ITMFACILIT, ITMCOST,ITMSALES [ITS], ITMBPC [ITU], ITMBPS [ITP], ATEXTRA [AXX]
Local File TEXCLOB    [TXC]

Trbegin [XART]
For [XART] Where FLGREP=2
&              & find(X3CLE,"BIZANCE")
#&              &!find(X3CLE,"TRANSPORT","THEMA","VIRGA","GALLET","SIMBIO","ALANDA","VERTEBRA","BIZANCE","ALKY","CDPLUS")
    Raz [F:ITS]
    Read [ITS]ITS0=[F:XART]X3CLE
    Raz [F:ITM]
    Read [ITM]ITM0=[F:XART]X3CLE
    If [F:ITS]ITPTEX<>""
        Delete [TXC] Where CODE = [F:ITS]ITPTEX    # Texte préparation
    Endif
    If [F:ITS]ITSTEX<>""
        Delete [TXC] Where CODE = [F:ITS]ITSTEX    # Texte vente
    Endif
    Delete [ITP] Where ITMREF=[XART]X3CLE
    Delete [ITU] Where ITMREF=[XART]X3CLE
    Delete [ITS] Where ITMREF=[XART]X3CLE
    Delete [ITC] Where ITMREF=[XART]X3CLE
    Delete [ITF] Where ITMREF=[XART]X3CLE
    If [F:ITM]MFGTEX<>""
        Delete [TXC] Where CODE = [F:ITM]MFGTEX
    Endif
    If [F:ITM]PURTEX<>""
        Delete [TXC] Where CODE = [F:ITM]PURTEX
    Endif
    Delete [ITM] Where ITMREF=[XART]X3CLE
    Delete [AXX] Where CODFIC="ITMMASTER" & IDENT1=[XART]X3CLE
    [F:XART]FLGREP=1
    Rewrite [XART]
Next
Commit
End

#########################################################################
#  SIXITM : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog EXEC                                                          #
#     Création des articles, articles-sites, article-vente              #
#     articles-fournisseurs, coûts standard                             #
#########################################################################

Gosub SI_CONTEXT From SIXFONCTION
SI_SIMU=2
Local File SIPARX3  [SPX]
Local File SIPARVAC [SPV]
Read [SPX] First
Call EXEC From SIXITM
End

#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE

If GTRACE = ""
    Call OUVRE_TRACE("SIXITM : "+SI_MES(1)) From LECFIC
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR
#---- Création enregistrement ITMMASTER ------#
Call ECR_TIME("SIXITM : "+mess(213,124,1)+" ITMMASTER") From DOSSUB
Call SIXITM

If GOK<>1 : Goto FIN_ITM : Endif


$FIN_ITM
Onerrgo
If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End


$TRT_ERR
    Call ECR_TRACE( errp-"ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
    GOK=0
Resume


#########################################################################
# Création des articles
#########################################################################
Subprog SIXITM

Gosub VAR_DECL

Gosub OPEN_FILES

SI_SUBPRG = "SIXITM"
SI_TABLE = "XIART"
Gosub SI_CRITSUP From SIXFONCTION

LLANGUE = [F:SPX]LAN

Call DEBTRANS From GLOCK
Local Integer NBTRT
# Traitement des articles
For [XART] Hint Key IND0
&          Where evalue(SI_CRITART)
&              & left$(CODART,2)<>"$$"
&              & FLGREP<>2
&              & evalue(SI_CRITERE)

    Call AFFBOITE([XART]CODART) From SUBSIM

    Trbegin [ITM]

    LERR = 0

    Gosub CRE_ITM
    If GOK<=0 & SI_SIMU<>2
        Break
    Endif

    If LERR=0
        If [F:ITG]TCLCOD<>[F:ITM]TCLCOD
            Raz [F:ITG]
            Read [ITG]ITG0="";[F:ITM]TCLCOD
        Endif
        If [F:ITG]SALFLG=2
            Gosub CRE_ITS
            If GOK<=0 & SI_SIMU<>2
                Break
            Endif
        Endif
    Endif

    If LERR=0
        Gosub CRE_ITU
        If GOK<=0 & SI_SIMU<>2
            Break
        Endif
    Endif

    If LERR=0
        Gosub CRE_ITP
        If GOK<=0 & SI_SIMU<>2
            Break
        Endif
    Endif

    If LERR=0
        Gosub CRE_ITF
        If GOK<=0 & SI_SIMU<>2
            Break
        Endif
    Endif

    If SI_SIMU<>2 & (LERR=0  | fstat=3)
        Update [XAR2] Where CODART=[F:XART]CODART
&                     With  FLGREP = 2
        Commit
    Else
        Rollback
    Endif

Next

If SI_SIMU<>2
    Call DEBTRANS From GLOCK

    For [ITM] Where RPLITM<>""
        Look [ITM2]ITM0=[F:ITM]RPLITM
        If fstat
            Trbegin [ITM]
            Call ECR_TRACE(mess(27,159,1)-[F:ITM]ITMREF-mess(316,198,1)-":"+[F:ITM]RPLITM,-1) From GESECRAN
            Raz [F:ITM]RPLITM
            Rewrite [ITM]
            If fstat
                Call ECR_TRACE(mess(13,100,1)-"[ITM] "-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
            Endif
            If !fstat & LERR=0 & SI_SIMU<>2
                Commit
            Else
                Rollback
            Endif
        Endif
    Next

    # Création des gammes-sites = "ITMREF+FCY"
    Link [XART] With [ITM]ITM0~=[XART]X3CLE,[ITF]ITF0~=[ITM]ITMREF;[F:SPX]FCY,[XNMC]IND0(2)~="";[XART]CODART
&                 As [LNK]
&              Where [XART]FLGREP=2
&                  & [XNMC]NUMCST=0
&                  & [XART]NATPDT="GA"
&              Order By Key IND=[XART]CODART
    For [LNK]IND(1)
        X_NB-=1    # Pour rester à 100% dans la barre de progression
        Call AFFBOITE(mess(63,198,1)-":"-[F:XART]CODART) From SUBSIM
        For [FCY] Where MFGFLG=2
            [F:ITM]ITMREF=[XART]X3CLE+[F:FCY]FCY
            Write [ITM]
            Case fstat
                When 0:
                    # Les articles-sites ne sont pas nécessaires
    
                    # Copie des désignations
                    For [AXX] Where CODFIC="ITMREF" & IDENT1=[XART]X3CLE
                        [F:AXX]IDENT1 = [XART]X3CLE+[F:FCY]FCY
                        [F:AXX]TEXTE -= [F:FCY]FCY
                        Write [F:AXX]
                    Next

                When 3:    # Rien, ça peut arriver si les articles sont repris en plusieurs fois

                When Default:
                    Call ECR_TRACE(mess(13,100,1)-"[ITM]"+mess(63,198,1)-":"-[XART]X3CLE+[F:FCY]FCY+" : "-func SIXFONCTION.FSTATMSG(fstat),-1) From GESECRAN
            Endcase
        Next
    Next
Endif

End


####################################################
# Création des enregistrements ITMMASTER
$CRE_ITM
Raz [F:ITM], LDGN, LBLN, LCLBDES, LCLBBLN, LITSTEX, LITPTEX

If !func SIXFONCTION.SI_CTL("ITMREF",[F:XART]X3CLE,"XIART ("+[F:XART]CODART+")")
    LERR=1
Else
    [F:ITM]ITMREF    = [F:XART]X3CLE
Endif

#--- Catégorie ---#
LNUMITG = 0    # Par défaut : "Acheté+Vendu"
If !find([F:XART]NATPDT,"MO","OP")    # Les opérations ne peuvent être fabriquées ou gérées en stock
    If find([F:XART]NATPDT,"PF","GA")
        LNUMITG += 1
    Endif
    If [F:XART]GESSTK="O"
        LNUMITG += 2
    Endif
Endif
Case LNUMITG
    When 1 : # Acheté + Vendu + Fabriqué
        [F:ITM]TCLCOD = [F:SPX]ITGAVF
    When 2 : # Acheté + Vendu + Stock
        [F:ITM]TCLCOD = [F:SPX]ITGAVS
    When 3 : # Acheté + Vendu + Fabriqué + Stock
        [F:ITM]TCLCOD = [F:SPX]ITGAVFS
    When Default : # Acheté + Vendu
        [F:ITM]TCLCOD = [F:SPX]ITGAV
Endcase

LDGN = 16    # Désignations complémentaires dans les 2 autres désignations
If [F:XART]NATPDT="GA"
    LBLN = 2      # Production
Else
    LBLN = 1+4    # Achat + vente
Endif

Raz GPE
SI_TABLE = "ITMMASTER"
Gosub SI_INIVALEUR From SIXFONCTION
If GPE=0
    # Pour initialiser les valeurs provenant de la catégorie, on prend celles de la catégorie générale
    If [F:ITG]TCLCOD<>[F:ITM]TCLCOD | [F:ITG]STOFCY<>""
        Read [F:ITG]ITG0="";[F:ITM]TCLCOD
    Else
        Look [F:ITG]ITG0="";[F:ITM]TCLCOD
    Endif
    If fstat
        Call ECR_TRACE(mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")"-mess(338,199,1)+":"-[F:ITM]TCLCOD,1) From GESECRAN
        LERR=1
    Endif
Endif
# Les types de catégorie doivent obligatoirement correspondre à ceux de la catégorie
[F:ITM] = [F:ITG]

# En attendant modif pour avoir le champ dans la catégorie
If dim([F:ITG]FLGFAS)<=0
    [F:ITM]FLGFAS = 1
Endif

If [F:XART]CODFAM<>"" & dim([F:ITM]TSICOD(0))>0
    [F:ITM]TSICOD(0) = func SIXFONCTION.SI_COR("XIFAMART",[F:XART]CODFAM,"20",mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")")
Endif
If [F:XART]CODSOUFAM<>"" & dim([F:ITM]TSICOD(1))>0
    [F:ITM]TSICOD(1) = func SIXFONCTION.SI_COR2("XISOUFMART",[F:XART]CODFAM,[F:XART]CODSOUFAM,"21",mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")")
Endif

#[F:ITM]CCE(0) = ""    # On ne voit pas comment on pourrait l'alimenter
#[F:ITM]DIE(x) = ""    # Les CCE n'étant pas renseignés, il n'est pas nécessaire d'alimenter les DIE.
If [F:ITM]ACCCOD=""    # Peut avoir été alimenté par la catégorie
    [F:ITM]ACCCOD = "TRADING"    # Code comptable inclus dans le dossier de référence. Peut être modifié par le PE SI_BEFWRI.
Endif

Read [SPV]SPV0=[F:SPX]CLE;[XART]CODTVAVEN;[XART]CODTVAACH;[XART]TVADBTENC;0
If !fstat
    [F:ITM]VACITM(0) = [F:SPV]VACITM1
Endif
If [XART]CODTPF>0
    Read [SPV]SPV0=[F:SPX]CLE;0;0;"";[XART]CODTPF
    If !fstat & dim([F:ITM]VACITM)>1
        [F:ITM]VACITM(1) = [F:SPV]VACITM2
    Endif
Endif
If [F:XART]TAXADD="O" & dim([F:ITM]VACITM)>2
    [F:ITM]VACITM(2) = [F:SPX]VACITM3
Endif

[F:ITM]ITMDES1 = [F:XART]DGN         # FGR 03/07/2009 : X3SUIVI56319 : normal que ça reste comme ça
If [F:ITM]ITMDES1=""                 # FGR 03/07/2009 : X3SUIVI56319 : normal que ça reste comme ça
    [F:ITM]ITMDES1 = [F:ITM]ITMREF   # FGR 03/07/2009 : X3SUIVI56319 : normal que ça reste comme ça
Endif

Raz GBIDI1
# Récupération des désignation traduites (Numlig=0 --> désignation 1 de l'article)
For [XDGN] Where PFXART="AR"
&              & CODART=[F:XART]CODART
&              & NUMLIG=0
    Raz [F:AXX]
    [F:AXX]CODFIC = "ITMMASTER"
    [F:AXX]ZONE   = "DES1AXX"
    If [F:XDGN]CODLAN<>""
        [F:AXX]LANGUE = func SIXFONCTION.SI_COR("XILAN",[F:XDGN]CODLAN,"TABLAN",mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")")
        If [F:AXX]LANGUE<>""
            [F:AXX]TEXTE  = [F:XDGN]LIBTXT
            [F:AXX]IDENT1 = [F:ITM]ITMREF
            [F:AXX]IDENT2 = ""
            If LERR=0
                Write [F:AXX]
                If fstat
                    Call ECR_TRACE(mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")"-mess(2,761,1)+" ("+[F:AXX]LANGUE+"): "-func SIXFONCTION.FSTATMSG(fstat), 1) From GESECRAN
                Endif
                If [F:AXX]LANGUE=LLANGUE
                    GBIDI1 = 1
                Endif
            Endif
        Endif
    Endif
Next

If GBIDI1=0
    Raz [F:AXX]
    [F:AXX]CODFIC = "ITMMASTER"
    [F:AXX]ZONE   = "DES1AXX"
    [F:AXX]LANGUE = LLANGUE
    [F:AXX]TEXTE  = [F:ITM]ITMDES1  # FGR 03/07/2009 : X3SUIVI56319 : normal que ça reste comme ça
    [F:AXX]IDENT1 = [F:ITM]ITMREF
    [F:AXX]IDENT2 = ""
    If LERR=0
        Write [F:AXX]
        If fstat
            Call ECR_TRACE(mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")"-mess(2,761,1)+" ("+[F:AXX]LANGUE+"): "-func SIXFONCTION.FSTATMSG(fstat), 1) From GESECRAN
        Endif
    Endif
Endif

# Récupération des désignation traduites + Textes
# Par défaut : Numlig=1 --> désignation 2 de l'article
#              Numlig=2 --> désignation 3 de l'article
#              Boc-notes --> Textes achat et vente ou Texte Production si l'article est une Gamme
#LDGN = 16
#LBLN = 1+4    # Achat + vente
#LBLN = 2      # Production
If LDGN>0
    Raz LNUMCLB
    For [XDGN] Where PFXART="AR"
&                  & CODART=[F:XART]CODART
&                  & NUMLIG>0
        LNUMDES = [F:XDGN]NUMLIG+1
        Raz [F:AXX]
        [F:AXX]LANGUE = func SIXFONCTION.SI_COR("XILAN",[F:XDGN]CODLAN,"TABLAN",mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")")
        If mod(LDGN,32)>=16 & find(LNUMDES,2,3)
            [F:AXX]CODFIC = "ITMMASTER"
            [F:AXX]ZONE   = "DES"+num$(LNUMDES)+"AXX"
            If [F:XDGN]CODLAN<>""
                If [F:AXX]LANGUE<>""
                    [F:AXX]TEXTE  = left$([F:XDGN]LIBTXT,GLONAX3)
                    [F:AXX]IDENT1 = [F:ITM]ITMREF
                    [F:AXX]IDENT2 = ""
                    If LERR=0
                        Write [F:AXX]
                        If fstat
                            Call ECR_TRACE(mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")"-mess(2,761,1)+" ("+[F:AXX]LANGUE+"): "-func SIXFONCTION.FSTATMSG(fstat), 1) From GESECRAN
                        Endif
                    Endif
                Endif
            Endif
        Endif
        If LDGN<>16 & [F:AXX]LANGUE=LLANGUE
            LCLBDES(LNUMCLB) = [F:XDGN]LIBTXT
            LNUMCLB += 1
        Endif
    Next
Endif

#---- Reprise du bloc-notes ------#
Read [XBLN]IND0="AR";[F:XART]CODART
If !fstat
    For I=1 To 18
        LCLBBLN(I-1) = evalue("[F:XBLN]LIG"+num$(I))
    Next
Endif


Raz SI_CLOB,I,J
If mod(LDGN,2)>=1
    For I=0 To LNUMCLB-1
        SI_CLOB(I) = LCLBDES(I)
    Next
Endif

If mod(LBLN,2)>=1
    For J=I To dim(SI_CLOB)-1
        If J-I>=dim(LCLBBLN) : Break : Endif
        SI_CLOB(J) = LCLBBLN(J-I)
    Next
Endif

If I+J>0
    [F:ITM]PURTEX = func SIXFONCTION.SI_CLOB("ITM")
Endif


Raz SI_CLOB,I,J
If mod(LDGN,4)>=2
    For I=0 To LNUMCLB-1
        SI_CLOB(I) = LCLBDES(I)
    Next
Endif

If mod(LBLN,4)>=2
    For J=I To dim(SI_CLOB)-1
        If J-I>=dim(LCLBBLN) : Break : Endif
        SI_CLOB(J) = LCLBBLN(J-I)
    Next
Endif

If I+J>0
    [F:ITM]MFGTEX = func SIXFONCTION.SI_CLOB("ITM")
Endif

# !!!!! L'alimentation se fait dans ITMSALES et utilise LITSTEX et LITPTEX  !!!!!
#       => il ne faut pas modifier cette variable entre temps               !!!!!
Raz SI_CLOB,I,J
If mod(LDGN,8)>=4
    For I=0 To LNUMCLB-1
        SI_CLOB(I) = LCLBDES(I)
    Next
Endif

If mod(LBLN,8)>=4
    For J=I To dim(SI_CLOB)-1
        If J-I>=dim(LCLBBLN) : Break : Endif
        SI_CLOB(J) = LCLBBLN(J-I)
    Next
Endif

If I+J>0
    LITSTEX = func SIXFONCTION.SI_CLOB("ITS")
Endif


Raz SI_CLOB,I,J
If mod(LDGN,16)>=8
    For I=0 To LNUMCLB-1
        SI_CLOB(I) = LCLBDES(I)
    Next
Endif

If mod(LBLN,16)>=8
    For J=I To dim(SI_CLOB)-1
        If J-I>=dim(LCLBBLN) : Break : Endif
        SI_CLOB(J) = LCLBBLN(J-I)
    Next
Endif

If I+J>0
    LITPTEX = func SIXFONCTION.SI_CLOB("ITS")
Endif

[F:ITM]DLU = 1

[F:ITM]EANCOD = [F:XART]CODBAR
Case [F:XART]SML
    When "O"     : [F:ITM]ITMSTA = 6
    When Default : [F:ITM]ITMSTA = 1
Endcase

#---- Unités ----#
[F:ITM]STU = func SIXFONCTION.SI_COR("XIUNIFAC",[F:XART]UNIFAC,"TABUNIT",mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")")
[F:ITM]PUU = [F:ITM]STU
[F:ITM]SAU = [F:ITM]STU
[F:ITM]SSU = [F:ITM]STU
[F:ITM]PUUSTUCOE = 1
[F:ITM]SAUSTUCOE = 1
[F:ITM]SSUSTUCOE = 1

Raz GBIDI1
For [XACT] Where ARTPCP=[F:XART]CODART    # Article conditionnement
    [F:ITM]PCU(GBIDI1) = func SIXFONCTION.SI_COR("XIUNIFAC",[F:XACT]UNIVEN,"TABUNIT",mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")")
    # Vérifier que la valeur renvoyée est différente de l'unité de stock
    If [F:ITM]PCU(GBIDI1)<>"" & [F:ITM]PCU(GBIDI1)<>[F:ITM]STU
        If [F:XACT]CDTSTK<>0
            [F:ITM]PCUSTUCOE(GBIDI1) = [F:XACT]CDTVEN/[F:XACT]CDTSTK
        Else
            [F:ITM]PCUSTUCOE(GBIDI1) = 1
            Call ECR_TRACE("ARTCDT="+[F:XACT]ARTCDT+" : CDTSTK=0",1) From GESECRAN
        Endif
        [F:ITM]PCURUL(GBIDI1)    = 1
        [F:ITM]DACPCUCOE(GBIDI1) = 1
        [F:ITM]LBEFMT(GBIDI1)    = ""
        GBIDI1 += 1
    Endif
Next

If [F:XART]GESSTK="O"
    [F:ITM]STOMGTCOD=2
Else
    [F:ITM]STOMGTCOD=1
Endif

[F:ITM]LOTMGTCOD=1
[F:ITM]SERMGTCOD=1
If [F:XART]GESNUMSER="O"
    If [F:XART]NUMSERLOT="L"
        If [F:XART]TYPMVTGES="T"
            [F:ITM]LOTMGTCOD=3    # Lot obligatoire
        Else
            [F:ITM]LOTMGTCOD=2    # Lot facultatif
        Endif
        If [F:XART]AFCENT<>""
            [F:ITM]LOTCOU=func SIXFONCTION.SI_COR("XINSRLTENT",[F:XART]AFCENT,"ACODNUM",mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")")
        Endif
    Elsif [F:XART]NUMSERLOT="S" & find([F:XART]TYPMVTGES,"T","S")
        If [F:XART]TYPMVTGES="T"
            [F:ITM]SERMGTCOD=3    # Série E/S
        Elsif [F:XART]TYPMVTGES="S"
            [F:ITM]SERMGTCOD=2    # Série S
        Endif
        If [F:XART]AFCENT<>""
            [F:ITM]SERCOU=func SIXFONCTION.SI_COR("XINSRLTENT",[F:XART]AFCENT,"ACODNUM",mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")")
        Endif
    Endif
Endif

[F:ITM]NEGSTO = 2

[F:ITM]RPLITM = func SIXFONCTION.SI_COR("XIART",[F:XART]ARTRPC,"","")
# La vérification de l'existence de l'article de remplacement
# ne peut se faire qu'une fois tous les articles créés

If dim([F:ITM]EECGES)>0
    [F:ITM]EECGES = 2
Endif
If [F:XART]NUMNMCPDT=""
    [F:ITM]EEU=""
    [F:ITM]EEUSTUCOE=0
Else
    [F:ITM]CUSREF = [F:XART]NUMNMCPDT    # Le code ne change pas entre X3 et Intégrale
    Read [XNPC]IND0=[F:XART]NUMNMCPDT
    If !fstat
        If [F:XNPC]EDIUNISPL="O"
            If find([F:XART]UNINMCDOU,0,1)
                [F:ITM]EEU=[F:ITM]STU
                [F:ITM]EEUSTUCOE=1
            Else
                If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
                Read [F:ATZ]CODZONE="ITMMASTER";"EEUSTUCOE"
                If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
                Read [ATY]CODTYP=[F:ATZ]CODTYP
                If fstat = 0
                    LRND= 10^-(mod([F:ATY]LNGTYP,1)*10)
                Else
                    LRND=0.000001
                Endif
                [F:ITM]EEUSTUCOE=arr(1/[F:XART]UNINMCDOU,LRND)
            Endif
        Else
            [F:ITM]EEU=""
            [F:ITM]EEUSTUCOE=0
        Endif
    Endif
Endif

[F:ITM]BRDCOD = 1

[F:ITM]CREDAT = [F:XART]DATCRE
[F:ITM]UPDDAT = date$
[F:ITM]UPDUSR = GUSER


SI_TABLE = "ITMMASTER"
Gosub SI_BEFWRI From SIXFONCTION

#----------------------- Contrôles -------------------------#

If [F:ITM]CUSREF<>""
    Look [INO]INO0=[F:ITM]CUSREF
    If fstat
        Call TEXTE(2148,GBIDC1) From OBJDIV    # Référence douanière
        Call ECR_TRACE(mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")"-GBIDC1-[F:ITM]CUSREF+" : "+mess(23,100,1),-1) From GESECRAN    # Fiche inexistante
    Endif
Endif

# Zones obligatoires
For GBIDC1="STU","TCLCOD","ACCCOD"
    If vireblc(evalue("[F:ITM]"+GBIDC1),4)=""
        # Zone obligatoire
        Call ECR_TRACE(mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")"-GBIDC1+" : "+mess(10,123,1),1) From GESECRAN
        LERR=1
    Endif
Next

If [F:ITM]ACCCOD<>""
    Look [F:CAC]CAC1 = 1;[F:ITM]ACCCOD
    If fstat # Code comptable inexistant
        Call ECR_TRACE([F:ITM]ITMREF-"("+[F:XART]CODART+") : "-mess(11,114,1)-[F:ITM]ACCCOD,1) From GESECRAN
        LERR=1
    Endif
Endif
# L'unité CEE doit être renseignée dans la catégorie
If [F:ITM]EEU="" & [F:ITM]EEUSTUCOE<>0
    Call TEXTE(13672,GBIDC1) From OBJDIV    # Coef UCEE-US
    Call TEXTE(13671,GBIDC2) From OBJDIV    # Unité CEE
    Call ECR_TRACE(mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")"-GBIDC1+"="+num$([F:ITM]EEUSTUCOE)-GBIDC2-mess(10,123,1),1) From GESECRAN
    [F:ITM]EEUSTUCOE=0
Endif


# fantôme non vendu : pas de controle du niveau de taxe
If  ( (dim([F:ITG]MFGFLG)>0 & [F:ITG]MFGFLG<>2) | (dim([F:ITG]CLSTYP)>0 & [F:ITG]CLSTYP<>7))
& | [F:ITG]SALFLG=2
    # "le 1er niveau doit correspondre à une taxe de type TVA"
    If [F:ITM]VACITM(0) = ""
        # Zone obligatoire
        Call ECR_TRACE(mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+") VACITM(0) : "+mess(10,123,1),1) From GESECRAN
        LERR=1
    Else
        LRET=1
        # recherche de tous les régimes combinés à ce niveau de taxe
        If dim([F:TVC]VATTYP)<=0    # V140
            For [TVC] Where VACITM = [F:ITM]VACITM(0)
                Read [TVT]TVT0 = [F:TVC]VAT
                If fstat | [F:TVT]VATTYP <> 1
                    LRET = 0
                    Break
                Endif
            Next
        Else                        # V6
            For [TVC] Where VACITM = [F:ITM]VACITM(0) & [F:TVC]VATTYP<>1
                LRET=0
                Break
            Next
        Endif
        If LRET = 0
            # "Le premier niveau de taxe doit correspondre à une taxe de type TVA"
            Call ECR_TRACE(mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+") VACITM(0)="+[F:ITM]VACITM(0)+" : "+mess(133,199,1),1) From GESECRAN
            LERR=1
        Endif
    Endif
Endif

If LERR=0
    Write [ITM]
    If fstat
        Call ECR_TRACE(mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
        LERR=1
    Endif
Endif    
Return



##################################################################
# Article vente
$CRE_ITS

Raz [F:ITS]    # CCC (19/05/08) Bug 47422
[F:ITS]ITMREF = [F:ITM]ITMREF
#[F:ITS]ITMDES1 = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:ITS]ITMDES1, "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56270 : normal que ça reste
[F:ITS]ITMTYP = 1
# L'article de substitution X3 n'a pas d'équivalent dans Intégral (en particulier à cause de la date)

If mod(LBLN,8)>=4
    [F:ITS]ITSTEX = LITSTEX
Endif
If mod(LBLN,16)>=8
    [F:ITS]ITPTEX = LITPTEX
Endif

[F:ITS]LNDFLG = 1

If [F:XART]ARTCTQ="N"
    [F:ITS]CTMFLG = 1
Else
    [F:ITS]CTMFLG = 2
Endif
[F:ITS]MINPRI = [F:XART]PRXMIN
If [F:XART]DEBTRF2<=date$ & [F:XART]DEBTRF2<>[0/0/0]
    [F:ITS]THEPRI = [F:XART]PRXVENHT2
Else
    [F:ITS]THEPRI = [F:XART]PRXVENHT1
Endif
[F:ITS]BASPRI = [F:ITS]THEPRI

[F:ITS]CREDAT = [F:XART]DATCRE
[F:ITS]UPDDAT = date$
[F:ITS]UPDUSR = GUSER

#----------------------- A VOIR -------------------------#
[F:ITS]CTMQTY = 0
#--------------------------------------------------------#


SI_TABLE = "ITMSALES"
Gosub SI_BEFWRI From SIXFONCTION
If LERR=0
    Write [ITS]
    If fstat
        Call ECR_TRACE(mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
        LERR=1
    Endif
Endif
Return

##################################################################
# Article client
$CRE_ITU

For [XACL] Where CODART=[F:XART]CODART
&            and REFART<>""
    Raz [F:ITU]
    [F:ITU]ITMREF = [F:ITM]ITMREF
    [F:ITU]BPCNUM = func SIXFONCTION.SI_COR("XICLT",[F:XACL]CODCLT,"BPCUSTOMER",mess(28,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")")
    [F:ITU]ITMREFBPC = [F:XACL]REFART
    If [F:ITM]SAU=""
        [F:ITU]SAU       = [F:ITM]STU 
        [F:ITU]SAUSTUCOE = 1
    Else
        [F:ITU]SAU       = [F:ITM]SAU
        [F:ITU]SAUSTUCOE = [F:ITM]SAUSTUCOE
    Endif
    If dim([F:ITU]ENAFLG)>0 : [F:ITU]ENAFLG=2 : Endif
    [F:ITU]CREDAT = date$
    [F:ITU]CREUSR = GUSER
    
    SI_TABLE = "ITMBPC"
    Gosub SI_BEFWRI From SIXFONCTION
    If LERR=0
        Write [ITU]
        If fstat
            Call ECR_TRACE(mess(28,159,1)-[F:ITM]ITMREF+"/"+[F:ITU]BPCNUM-"("+[F:XART]CODART+"/"+[F:XACL]CODCLT+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),-1) From GESECRAN
        Endif
    Endif
    Raz LERR     # On n'empêche pas l'écriture de l'article si l'article-client est en duplicate ou autre
Next
    
Return

##################################################################
# Article fournisseur
$CRE_ITP

For [XAFO] Where CODART=[F:XART]CODART
    Raz [F:ITP]
    [F:ITP]ITMREF = [F:ITM]ITMREF
    [F:ITP]BPSNUM = func SIXFONCTION.SI_COR("XIFOU",[F:XAFO]CODFOU,"BPSUPPLIER",mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")")
    If [F:XART]FOUPCP = [F:XAFO]CODFOU
        [F:ITP]PIO    = 0
    Else
        [F:ITP]PIO    = 1
    Endif
    [F:ITP]ITMREFBPS = [F:XAFO]REFART
    [F:ITP]PURMINQTY = [F:XAFO]QTEMIN

    If [F:ITP]ITMREFBPS=""
        [F:ITP]ITMREFBPS = [F:ITM]ITMREF
    Endif

    Look [ITP]ITP2=[F:ITP]BPSNUM;[F:ITP]ITMREFBPS

    If !fstat
        Call ECR_TRACE(mess(23,198,1)-[F:ITM]ITMREF+"/"+[F:ITP]BPSNUM-"("+[F:XART]CODART+"/"+[F:XAFO]CODFOU+")"-"Référence article-fournisseur : '"+[F:ITP]ITMREFBPS+"' --> '"+[F:ITM]ITMREF+"'",-1) From GESECRAN
        [F:ITP]ITMREFBPS = [F:ITM]ITMREF
    Endif

    [F:ITP]DOUFLG    = 1
    [F:ITP]PUU       = [F:ITM]PUU
    [F:ITP]PUUSTUCOE = [F:ITM]PUUSTUCOE
    [F:ITP]QUAFLG    = [F:ITG]QUAFLG
    [F:ITP]QLYCRD    = [F:ITG]QLYCRD

    Raz [F:XTFI]
    Filter [XTFI] Where DATDEB<=date$ & DATFIN>=date$
&                     & CODFOU=[F:XAFO]CODFOU
&                     & ART=[F:XAFO]CODART
    Read [XTFI]IND0 First
    If fstat
        Filter [XTFI] Where DATDEB<=date$ & DATFIN>=date$
&                         & ART=[F:XAFO]CODART
        Read [XTFI]IND0 First
    Endif
    Filter [XTFI]
    [F:ITP]CPRCOE = [F:XTFI]TAUFRA
    [F:ITP]CTMBPSFLG = 1
    [F:ITP]CREDAT = date$
    [F:ITP]CREUSR = GUSER

    SI_TABLE = "ITMBPS"
    Gosub SI_BEFWRI From SIXFONCTION


    #----------------------- Contrôles -------------------------#
    If [F:ITP]BPSNUM=""
        Call ECR_TRACE(mess(23,198,1)-[F:ITM]ITMREF+"/"+[F:ITP]BPSNUM-"("+[F:XART]CODART+"/"+[F:XAFO]CODFOU+") BPSNUM: "+mess(10,123,1),-1) From GESECRAN
        LERR=1
    Endif

    If LERR=0
        Write [ITP]
        If fstat
            Call ECR_TRACE(mess(23,198,1)-[F:ITM]ITMREF+"/"+[F:ITP]BPSNUM-"("+[F:XART]CODART+"/"+[F:XAFO]CODFOU+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),-1) From GESECRAN
        Endif
    Endif
    Raz LERR    # On n'empêche pas l'écriture de l'article quelque soit le cas : article-fournisseur en duplicate, erreur dans le contrôle...
Next
    
Return

##################################################################
# Article site
$CRE_ITF
For [XADP] Where CODART=[F:XART]CODART
    Gosub ECR_ITF
    If [F:ITM]STOMGTCOD > 1
        Call LECITV([F:ITF]STOFCY,[F:ITF]ITMREF,"",LRET) From STKLIB 
        #calcul date prochain inventaire 
        LDAT = date$
        LCUNCOD = [F:ITF]CUNCOD
        Call CAL_NEXINV([F:ITF]STOFCY,[F:ITM]TCLCOD,LDAT,LCUNCOD) From STKINV
        Rewrite [ITV]  
        If fstat
            Call ECR_TRACE(mess(4,198,1)-[F:ITF]ITMREF+"/"+[F:ITF]STOFCY-"("+[F:XADP]CODART+"/"+[F:XADP]CODDPO+") [ITV]"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
        Endif  
    Endif 
Next

# Si l'article est une gamme ou un PF il faut créer l'article-site sur le site de prod
[F:XADP]CODDPO = func GETMFGFCY    # Récupère le site de production et le flague "dépot" et "production" si nécessaire
If [F:XADP]CODDPO<>""
    Read [XDPO]IND0=[F:XADP]CODDPO
    If !fstat
        Look [ITF]ITF0=[F:ITM]ITMREF;[F:XDPO]X3CLE
        If fstat
            [F:XADP]CODART= [F:XART]CODART
            Gosub ECR_ITF
        Endif
    Endif
Endif

# Si l'article-site n'a pas été créé pour le site principal, on force sa création
Look [ITF]ITF0=[F:ITM]ITMREF;[F:SPX]FCY
If fstat
    [F:XADP]CODART=[F:XART]CODART
    Filter [XDPO] Where X3CLE = [F:SPX]FCY
    Read [XDPO] First
    Filter [XDPO]
    If !fstat
        [F:XADP]CODDPO=[F:XDPO]CODDPO
        Gosub ECR_ITF
    Endif
Endif
Return

# Etiquette appelée aussi en création de gamme lors de la reprise des nomenclatures d'Intégrale.
$ECR_ITF
If dim(LERR)<=0
    Local Integer LERR    # n'existe pas forcément dans le programme appelant
    Local Integer LVAR
Endif
        Raz [F:ITF]
        [F:ITF] = [F:ITM]
        [F:ITF] = [F:ITG]
        [F:ITF]STOFCY=func SIXFONCTION.SI_COR("XIDPO",[F:XADP]CODDPO,"FACILITY",mess(27,159,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+")")
        If [F:ITF]STOFCY="" #| [F:XART]NATPDT="GA" & [F:SPX]FCY<>[F:ITF]STOFCY & abs([F:XADP]QTESTKINI)+abs([F:XADP]QTEENT)+abs([F:XADP]QTESOR)=0
            Return
        Endif

        [F:ITF]SMPTYP = 1
        [F:ITF]GENLEVINS = 0
        [F:ITF]SMPMOD = 0
        [F:ITF]NQA = 0

        [F:ITF]LOCMGTCOD = 1    # Il n'y a pas de récupération des emplacements Intégrale
                                # => on ne peut pas alimenter l'emplacement dans les lignes de stock

        [F:ITF]VLTCOD = ""    # La méthode de valo se trouve au niveau de la catégorie. Pour la changer il faut utiliser le PE
        [F:ITF]REDMODFLG = 1    # Mode de redressement
        [F:ITF]CUNFLG = 1
        [F:ITF]WIPPRO = 1

        [F:ITF]SAFSTO = [F:XADP]QTESEUSRT
        [F:ITF]REOTSD = [F:XADP]QTESEURPV
        [F:ITF]MAXSTO = [F:XADP]QTESEUMAX
        If [F:ITF]SAFSTO=0 : [F:ITF]SAFSTO = [F:XART]SEUSRT : Endif
        If [F:ITF]REOTSD=0 : [F:ITF]REOTSD = [F:XART]SEURPV : Endif
        If [F:ITF]MAXSTO=0 : [F:ITF]MAXSTO = [F:XART]SEUMAX : Endif

        [F:ITF]RELSCATIA = 2
        [F:ITF]CREDAT = date$
        [F:ITF]CREUSR = GUSER

#        [F:ITF]STDCSTUPD = --> [ITG]
#        [F:ITF]CUTCSTUPD = --> [ITG]
#        [F:ITF]BUDCSTUPD = --> [ITG]
#        [F:ITF]SIMCSTUPD = --> [ITG]
#        [F:ITF]OFS = --> [ITG]    # Délai de réappro
#        [F:ITF]ABCCLS = --> [ITG]
#        [F:ITF]CUNCOD = --> [ITG]    # Inventaire annuel
#        [F:ITF]STOCOD = --> [ITG]    # Mode retrait stock = Immédiat
#        [F:ITF]REOMGTCOD = --> [ITG]
#        [F:ITF]REOCOD    = --> [ITG]
#        [F:ITF]MFGSHTCOD = --> [ITG]

    
        SI_TABLE = "ITMFACILIT"
        Gosub SI_BEFWRI From SIXFONCTION
        If LERR=0
            Write [ITF]
            If fstat
                Call ECR_TRACE(mess(4,198,1)-[F:ITF]ITMREF+"/"+[F:ITF]STOFCY-"("+[F:XADP]CODART+"/"+[F:XADP]CODDPO+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
                LERR=1
            Endif
            Gosub CRE_ITC
        Endif
If dim(LVAR)>0
    Kill LERR, LVAR
Endif
Return


##################################################################
# Article coût standard
$CRE_ITC

Raz [F:ITC]
[F:ITC]ITMREF = [F:ITF]ITMREF
[F:ITC]STOFCY = [F:ITF]STOFCY
[F:ITC]CSTTYP = 1
# à partir d'une date de référence on recherche l'"année" du cout qui correspond
If [F:FCY]FCY <> [F:ITC]STOFCY  : Read [FCY]FCY0=[F:ITC]STOFCY : Endif
# CCC (2009-09-11) Bug 57468 : Utilisation du paramètre [F:SPX]IPTDATSTK au lieu de date$
If [F:SPX]IPTDATSTK<>[0/0/0]
    [F:ITC]ITCSTRDAT = [F:SPX]IPTDATSTK
Else
    [F:ITC]ITCSTRDAT = date$            # si on n'a pas trouvé d'exercice
Endif

[F:ITC]YEA = year([F:ITC]ITCSTRDAT)

For [FIY] Where CPY=[F:FCY]LEGCPY & [F:ITC]ITCSTRDAT>=[F:FIY]FIYSTR & [F:ITC]ITCSTRDAT<=[F:FIY]FIYEND
    [F:ITC]YEA = year([F:FIY]FIYEND)  # année de la fin d'exercice
    Break
Next
[F:ITC]CSTSEQ = 0
[F:ITC]ITCDAT = date$

[F:ITC]FIYNUM = [F:FIY]FIYNUM
[F:ITC]ITCSEQ = 1
[F:ITC]ITCENDDAT = [F:FIY]FIYEND
If [F:ITC]ITCENDDAT<date$
    [F:ITC]ITCENDDAT = gdat$(31,12,year(date$))
Endif


# On récupère les composantes de coût...
[F:ITC]MATTOT = [F:XART]PARCST
[F:ITC]MACTOT = [F:XART]PAROPE
[F:ITC]LABTOT = [F:XART]PARMDO
[F:ITC]SCOTOT = [F:XART]PARSOUTRT
[F:ITC]OVETOT = [F:XART]PARFRAGNR
[F:ITC]CSTTOT = [F:ITC]MATTOT+[F:ITC]MACTOT+[F:ITC]LABTOT+[F:ITC]SCOTOT
[F:ITC]VLTTOT = [F:ITC]CSTTOT+[F:ITC]OVETOT
#... mais si elles sont toutes nulles, on récupère un prix défini en paramètre
If [F:ITC]VLTTOT=0
    If [F:SPX]PRXFLD1<>""
        [F:ITC]VLTTOT = evalue("[F:XART]"+[F:SPX]PRXFLD1)
    Endif
    If [F:ITC]VLTTOT=0 & [F:SPX]PRXFLD2<>""
        [F:ITC]VLTTOT = evalue("[F:XART]"+[F:SPX]PRXFLD2)
    Endif
    [F:ITC]CSTTOT = [F:ITC]VLTTOT
    [F:ITC]MATTOT = [F:ITC]VLTTOT
Endif


[F:ITC]MATCST(0) = [F:ITC]MATTOT
[F:ITC]MACCST(0) = [F:ITC]MACTOT
[F:ITC]LABCST(0) = [F:ITC]LABTOT
[F:ITC]SCOCST    = [F:ITC]SCOTOT
[F:ITC]OVEMATCST = [F:ITC]OVETOT
[F:ITC]CLCQTY    = 1
[F:ITC]MATLEVCST(0) = [F:ITC]MATTOT
[F:ITC]MACLEVCST(0) = [F:ITC]MACTOT
[F:ITC]LABLEVCST(0) = [F:ITC]LABTOT
[F:ITC]OVELEVCST    = [F:ITC]OVETOT
[F:ITC]SCOLEVCST    = [F:ITC]SCOTOT
[F:ITC]OVEMATLEV    = [F:ITC]OVETOT

[F:ITC]CREDAT = date$
[F:ITC]CREUSR = GUSER

SI_TABLE = "ITMCOST"
Gosub SI_BEFWRI From SIXFONCTION
If LERR=0
    Write [ITC]
    If fstat
        Call ECR_TRACE(mess(2,776,1)-[F:ITM]ITMREF-"("+[F:XART]CODART+"/"+[F:XAFO]CODCLT+") [F:ITC]YEA="+num$([F:ITC]YEA)-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
        LERR=1
    Endif
Endif
Return


######################################################################
# Renseigne la classe [F:ITV] courante avec le PMP et le dernier prix d'achat
# La classe [F:XART] doit être positionnée
$SI_ITV_VAL
#--- PMP ---#
[F:ITV]AVC = [F:XART]PMP
[F:ITV]AVCBASQTY = "qty base" # ???
[F:ITV]AVCBASAMT = [F:ITV]AVC*[F:ITV]AVCBASQTY

#--- Dernier prix ---#
[F:ITV]LASRCPPRI = [F:XART]DERNPRXACH
[F:ITV]LASPURPRI = [F:ITV]LASRCPPRI
Return


######################################################################
# Renvoie le site de production d'un article
# et met à jour le site (flag dépot et production) si nécessaire
# La classe [F:XART] doit être renseignée
Funprog GETMFGFCY
Local Char LFCY(GLONFCY)

If !find([F:XART]NATPDT,"PF","GA","MO","OP")
    End ""
Endif

If !clalev([F:XDPO]) : Local File XIDPO    [XDPO] : Endif
If !clalev([F:FCY])  : Local File FACILITY [FCY]  : Endif

If [F:XART]CNTFAB<>""
    LFCY = func MAJMFGFCY([F:XART]CNTFAB)
Endif
If LFCY="" & [F:XART]SOUTYPPDT<>""
    If !clalev([F:XSTP]) : Local File XISOUTPPDT [X:XSTP] : Endif
    Read [XSTP]IND0 = [F:XART]SOUTYPPDT
    LFCY = func MAJMFGFCY([F:XSTP]CNTFAB)
Endif
If LFCY="" & [F:XART]TYPPDT<>""
    If !clalev([F:XTP]) : Local File XITYPPDT [X:XTP] : Endif
    Read [XTP]IND0 = [F:XART]TYPPDT
    LFCY = func MAJMFGFCY([F:XTP]CNTFAB)
Endif
If LFCY=""
    If !clalev([F:XTP]) : Local File XITYPPDT [X:XTP] : Endif
    Read [XTP]IND0 = "**"
    If [F:XTP]CNTFAB<>""
        LFCY = func MAJMFGFCY([F:XTP]CNTFAB)
    Endif
Endif
If LFCY=""
    If !clalev([F:XSOC]) : Local File XISOC [X:XSOC] : Endif
    Read [XSOC] First
    If [F:XSOC]DPOIPC<>""
        LFCY = func MAJMFGFCY([F:XSOC]DPOIPC)
    Endif
Endif
End LFCY


Funprog MAJMFGFCY(PDPO)
Value Char PDPO

    Read [XDPO]IND0=PDPO
    If !fstat
        Read [FCY]FCY0=[XDPO]X3CLE
        If !fstat
            If [F:FCY]MFGFLG<>2 | [F:FCY]WRHFLG<>2
                [F:FCY]MFGFLG=2
                [F:FCY]WRHFLG=2
                Rewrite [FCY]
            Endif
            End [XDPO]X3CLE
        Endif
    Endif
End ""


$VAR_DECL
Local Integer LNUMITG    # Détermine la catégorie par défaut
Local Integer LRET
Local Integer LERR    # 0=OK 1=Erreur => pas d'écriture de l'enregistrement
Local Integer LDGN, LBLN    # Variables indiquant quels textes doivent être repris et où (modifiable par PE)
Local Char    LLANGUE(GLONLAN)
Local Integer LNUMDES, LNUMCLB
Local Char    LCLBDES(type(SI_CLOB)-10)(dim(SI_CLOB))
Local Char    LCLBBLN(type(SI_CLOB)-10)(dim(SI_CLOB))
Local Char    LITSTEX(GLONTXC), LITPTEX(GLONTXC), LNUMTEX(GLONTXC)
Local Integer I,J
Local Date    LDAT
Local Decimal LRND
Local Integer LCUNCOD
Return

$OPEN_FILES
If !clalev([F:ITM])  : Local File =SI_DOSSIER+".ITMMASTER" [ITM] : Endif
