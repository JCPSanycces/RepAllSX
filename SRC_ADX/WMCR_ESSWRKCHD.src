#<AdxTL>@(#)0.0.0.0 $Revision$Class Children
# Supervisor
## CRUD-CLASSE ## ESSWRKCHD
# 2018-10-23 06:53:15 747


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File ESSWRKCHD [EWCHD_]

If !SILENCE : Call TRACE("2 --> Local Instance C_ESSWRKCHD") From ASYRCOM : Endif
Local Instance ESSWRKCHD Using C_ESSWRKCHD

If !SILENCE : Call TRACE("3 --> New Instance C_ESSWRKCHD") From ASYRCOM : Endif
ESSWRKCHD = NewInstance C_ESSWRKCHD AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [EWCHD_]EWCHD0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of ESSWRKCHD") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD.AREAD([EWCHD_]UID))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("ESSWRKCHD.UID ="-num$(ESSWRKCHD.UID)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(ESSWRKCHD.AKEYS)
  Call TRACE("-"-num$(I)-":"-ESSWRKCHD.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [EWCHD_]
FreeGroup ESSWRKCHD
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(ESSWRKCHD,ACLE,ASTATUS,_ETAG)
Variable Instance ESSWRKCHD Using C_ESSWRKCHD
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Integer _UID
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_UID = val([L]CLE(1)) : Endif
Raz [L]_ETAG
Local File ESSWRKCHD [EWCHD]
Default File [F:EWCHD]
Read [F:EWCHD]EWCHD0 = [L]_UID
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:EWCHD]UPDTICK)>0
 [L]_ETAG = num$([F:EWCHD]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(ESSWRKCHD,ACLE,ASTATUS)
Variable Instance ESSWRKCHD Using C_ESSWRKCHD
Value Char ACLE
Variable Integer ASTATUS
Local Integer _UID
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_UID = val([L]CLE(1)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD.AREAD([L]_UID))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(ESSWRKCHD,_UID,ASTATUS)
Variable Instance ESSWRKCHD Using C_ESSWRKCHD
Value Integer _UID
Variable Integer ASTATUS

If ESSWRKCHD = null : End : Endif

Gosub AVARIABLES From WMC00ESSWRKCHD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If ESSWRKCHD.APARENT=null
 [L]A_I = ESSWRKCHD.freeSnapshot
 ESSWRKCHD.snapshotEnabled = 0
 ESSWRKCHD.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & ESSWRKCHD.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If ESSWRKCHD.APARENT=null
 ESSWRKCHD.snapshotEnabled = 1
 ESSWRKCHD.setAccessorEnabled = 1
Endif
LogicClose File [EWCHD]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD._ACTION_PARAM("AREAD_BEFORE",[L]_UID))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:EWCHD]
Read [F:EWCHD]EWCHD0 = [L]_UID
If fstat
[L]A_ERROR = num$([L]_UID)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(ESSWRKCHD,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:EWCHD]AUUID)>0 & [F:EWCHD]AUUID=NullUuid
 [F:EWCHD]AUUID = getUuid
Endif
SetInstance ESSWRKCHD With [F:EWCHD]
ESSWRKCHD.ASTALIN = [V]CST_ALL

[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



