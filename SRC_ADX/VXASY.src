#<AdxTL>@(#)9.0.0.0 $Revision$
####################################################################################
# Program Name: VXASY
# Description : ADC Storage Plan Putaway
# Author      : TS
# Date        : March, 2007
####################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)

Call SAISIE_CHAR(VALEUR,PARAM,"VXASY","VXASY","XWVXASY") From GSAISIE
End

########################################################
# Storage Plan Putaway
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# STOFCY, ITMREF,
# PCU, QTYPCU, STU, QTYSTUDES, PCUSTUCOE
# STA, LOC, LOT, SLO, PALNUM, CTRNUM, SERNUM, SERNUMF
# STADES, LOCDES, LOCTYPDES
# PCUDES, COEDES, QTYPCUDES
# WSTOSEQ, WLOCSEQ
#
# VXASY is the VT screen
#
########################################################

########################################################
$ACTION

#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "AVANT_OK"      : Gosub AVANT_OK
 When "OK"            : Gosub OK
 When "FIN"           : Gosub FIN
 When "BOUTON"        : Gosub BOUTON

Endcase

Return

########################################################
# Actions liées à la fenètre de saisie
########################################################

########################################################
$OUVRE

GVTMOD=1

If clalev([F:SGW1])=0  Local File STOSRGW   [SGW1]  Endif
If clalev([M:ASYW])=0  Local Mask VXASYW    [ASYW]  Endif
If clalev([M:SSL1])=0  Local Mask SSL1      [SSL1]  Endif
If clalev([M:SLP]) =0  Local Mask STOLBEIMP [SLP]   Endif       #--- Lot V01


# Initialisation du site de stock
Gosub INIT_STOFCY From ENVADC

Gosub OUVRE From TRTSSLA
OK=1

Return

########################################################
$DEBUT

Local  Integer INOL, WRET, WNB
Local  Decimal WQTY
Local  Char    WSERNUM(GLONSER), WSERNUMF(GLONSER), WSERNUMFIN(GLONSER)
Local  Decimal LQTA, LSHT
Local  Integer LNBR, LNBJ
Global Char    SYMBOLSRG

#--- Lot V01 deb
# GFLAG contains the transaction
GFLAG = func ENVADC.SETTRANS(7)

[M:XASY]SRTNUM = GFLAG
#--- Lot V01 fin

If GXAFCY=""
   Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN=1 : Return
Endif

Gosub INIT_SCREEN

Return

########################################################
$SETBOUT

If !find("O",CHBOU) CHBOU+="O" Endif
If !find("2",CHMEN) CHMEN+="2" Endif

Gosub SET_BOUT_SPE From GSAISIE

Return

########################################################
$APRES_MODIF

If find(COUZON,"SRGPPS")
   Raz [M:ASYW]
   # Chargement de l'écran de travail VXASYW
   Gosub ALI_ASYW

   INOL=0
   # Chargement de l'écran de saisie VXASY
   Gosub ALI_XASY
Endif

Return

########################################################
$AVANT_OK
Return

########################################################
$OK

# Pour interdire la navigation
GREP="C"
FIN = 0
# Alimentation de [M:ENTW]
nolign=1

[M:ENTW] = [M:XASY]

[M:ENTW]STA(0)    = [M:XASY]STADES
[M:ENTW]LOC(0)    = [M:XASY]LOCDES
[M:ENTW]LOCTYP(0) = [M:XASY]LOCTYPDES

# Alimentation info lot -> dans bloc [M:ENTW]
# Issue 118812 - 2016-10-04 by MAE : oubli des versions dans les paramètres
#Call SETCPTLOTAUTO([M:XASY]ITMREF,"ENTW",0,[M:XASY]LOT,[M:XASY]SLO,[M:XASY]BPSLOT,[M:XASY]GESLOT,WRET) From STKENT
Call SETCPTLOTAUTO([M:XASY]ITMREF,"ENTW",0,[M:XASY]LOT,[M:XASY]SLO,[M:XASY]BPSLOT,[M:XASY]GESLOT,"","",1,WRET) From STKENT
If [M:ENTW]NUMLIGLOT(0) <> -1
   # S'il existe dans STOLOT non modifiable
   If [M:ENTW]MODIF([M:ENTW]NUMLIGLOT(0))=2
      [M:ENTW]SHLDAT([M:ENTW]NUMLIGLOT(0))  = [F:SGW]SHLDAT
      [M:ENTW]POT([M:ENTW]NUMLIGLOT(0))     = [F:SGW]POT
      [M:ENTW]ACT([M:ENTW]NUMLIGLOT(0))     = [F:SGW]ACT
      [M:ENTW]USRFLD1([M:ENTW]NUMLIGLOT(0)) = [F:SGW]USRFLD1
      [M:ENTW]USRFLD2([M:ENTW]NUMLIGLOT(0)) = [F:SGW]USRFLD2
      [M:ENTW]USRFLD3([M:ENTW]NUMLIGLOT(0)) = [F:SGW]USRFLD3
      [M:ENTW]USRFLD4([M:ENTW]NUMLIGLOT(0)) = [F:SGW]USRFLD4
      [M:ENTW]REFPER([M:ENTW]NUMLIGLOT(0))  = [F:SGW]REFPER
      [M:ENTW]SHL([M:ENTW]NUMLIGLOT(0))     = [F:SGW]SHL
   Endif
Endif

[M:ENTW]NBLIG = 1

# Mise à jour
Call DEBTRANS From GLOCK
Trbegin [SRG]

Raz WRET
# Mise à jour de STOSRGW (delete,rewrite) et TABWIPSTO,
# ainsi que [M:ASYW] si nécessaire
Gosub MAJ_STOSRGW

If WRET=0
   # Initialisation de l'en-tête
   Raz [M:STW]
   [M:STW]STOFCY  = [M:XASY]STOFCY
   [M:STW]TRSTYP  = 22
   [M:STW]VCRTYP  = [M:ASYW]VCRTYP(INOL)
   [M:STW]VCRNUM  = [M:ASYW]VCRNUM(INOL)
   [M:STW]VCRLIN  = [M:ASYW]VCRLIN(INOL)
   [M:STW]ITMREF  = [M:XASY]ITMREF
   [M:STW]MVTDES  = [M:XASY]MVTDES
   [M:STW]PRIORDH = 0
   [M:STW]PJT     = ""
   [M:STW]TRSFAM  = ""
   [M:STW]IPTDAT  = [F:SRG]IPTDAT
   [M:STW]CCECOD  = "STJEND"
   [M:STW]CUR     = GLOCALDEV
   [M:STW]BPRNUM  = [M:XASY]BPRNUM

   Call ALISTOWORK(2,[M:XASY]WSTOSEQ,LQTA,LSHT,LNBR,LNBJ,WRET) From STKINT

   # Mise à jour des stock
   # Mise à jour enregistrement STOSRG
   If WRET=0
      Call MAJ_STOCK From STKMAJ
   Endif

Endif

If WRET<>0 | GOK<1
   WRET=1
   Rollback
Else
   Commit
   #--- Lot V01
#-----impression des étiquettes ----#
   If [F:SRT]PRNCOD1 = 2
      Raz [M:SLP]
      [M:SLP]WZONVCRTYP = "VCRTYP(I)"
      [M:SLP]WZONVCRNUM = "VCRNUM(I)"
      [M:SLP]WZONVCRLIN = "VCRLIN(I)"
      [M:SLP]WZONNBLIG  = "NBLIG"
      [M:SLP]WMSKFIL    = "1=1"

      [M:SSL1]VCRTYP(0) = [M:ASYW]VCRTYP(INOL)
      [M:SSL1]VCRNUM(0) = [M:ASYW]VCRNUM(INOL)
      [M:SSL1]VCRLIN(0) = [M:ASYW]VCRLIN(INOL)
      [M:SSL1]NBLIG     = 1
      Call PRINT_ETI(GXAFCY,[M:ASYW]VCRTYP(INOL),[M:ASYW]VCRNUM(INOL)) From STKADC
   Endif
Endif

# Passage à la ligne à ranger suivante
#INOL+=1
#If INOL>[M:ASYW]NBLIG-1
#   INOL=0
#   If sum([M:ASYW]TRTFLG) >= [M:ASYW]NBLIG*2
#      Call MESSAGE(mess(22,7750,1)) From GESECRAN
#      Gosub INIT_SCREEN
#      zonsui="SRGPPS"
#      Return
#   Else
#      Call MESSAGE(mess(23,7750,1)) From GESECRAN
#   Endif
#Endif
#While [M:ASYW]TRTFLG(INOL)=2
#   INOL+=1
#Wend
#If INOL>[M:ASYW]NBLIG-1
#   Gosub INIT_SCREEN
#   zonsui="SRGPPS"
#   Return
#Else
#   Gosub ALI_XASY
#   zonsui="QTYPCU"
#Endif

#new###########################
# Passage à la ligne à ranger suivante
INOL+=1
While [M:ASYW]TRTFLG(INOL)=2
   INOL+=1
Wend

If INOL>[M:ASYW]NBLIG-1
   INOL=0
   If sum([M:ASYW]TRTFLG) >= [M:ASYW]NBLIG*2
      Call MESSAGE(mess(22,7750,1)) From GESECRAN
      Gosub INIT_SCREEN
      zonsui="SRGPPS"
      Return
   Else
      Call MESSAGE(mess(23,7750,1)) From GESECRAN
      While [M:ASYW]TRTFLG(INOL)=2
         INOL+=1
      Wend
      Gosub ALI_XASY
      If OK=0
         Gosub INIT_SCREEN
         zonsui="SRGPPS"
         Return
      Endif
      zonsui="QTYPCU"
   Endif
Else
   Gosub ALI_XASY
   If OK=0
      Gosub INIT_SCREEN
      zonsui="SRGPPS"
      Return
   Endif
   zonsui="QTYPCU"
Endif
###############################
Return

########################################################
$FIN

If SYMBOLSRG<>""
   Unlock = SYMBOLSRG
Endif

GVTMOD=0
GREP=""

Return

########################################################
$BOUTON

Case BOUT
 When "2" : If [M:ASYW]NBLIG=0 Return Endif
            INOL+=1
            While [M:ASYW]TRTFLG(INOL)=2
               INOL+=1
            Wend
            If INOL>[M:ASYW]NBLIG-1
               INOL=0
               If sum([M:ASYW]TRTFLG) >= [M:ASYW]NBLIG*2
                  Call MESSAGE(mess(22,7750,1)) From GESECRAN
                  Gosub INIT_SCREEN
                  zonsui="SRGPPS"
                  Return
               Else
                  Call MESSAGE(mess(23,7750,1)) From GESECRAN
                  While [M:ASYW]TRTFLG(INOL)=2
                     INOL+=1
                  Wend
                  Gosub ALI_XASY
                  If OK=0
                     Gosub INIT_SCREEN
                     zonsui="SRGPPS"
                     Return
                  Endif
                  zonsui="QTYPCU"
               Endif
            Else
               Gosub ALI_XASY
               If OK=0
                  Gosub INIT_SCREEN
                  zonsui="SRGPPS"
                  Return
               Endif
               zonsui="QTYPCU"
            Endif
Endcase

Return

########################################################
# Initialisation écran de saisie
########################################################
$INIT_SCREEN

# Remise à zero du masque STOENTW
Call DELSTOENTW(-1,-1,"XASY",1,1,GXAFCY,0,"") From STKENT
Raz [M:SSL1]
[M:SSL1]STOFCY = GXAFCY

Raz [M:XASY]
[M:XASY]STOFCY = [M:SSL1]STOFCY
[M:XASY]SRTNUM = GFLAG                 #--- Lot V01

Affzo [M:XASY]1-99

Return

########################################################
# Chargement de l'écran de travail VXASYW
# avec les enregistrents STOSRGW de la liste à ranger
########################################################
$ALI_ASYW

nolign=1
For [SGW] Where SRGPPS=[M:XASY]SRGPPS

   # Si no série, n [M:ASYW] pour 1 [F:SGW]
   # Issue 110327 - 2016-11-10 by MAE : Uniquement si pas en serie globale
   # Lecture article
   Call LECITM([F:SGW]STOFCY,[F:SRG]ITMREF,"",0,"",WRET) From STKLIB
   If WRET<>0 : OK=0 : Return : Endif
   #If [F:SGW]SERNUM<>""
   If [F:SGW]SERNUM<>"" & [F:ITM]SERMGTCOD <> 4
      I = nolign + [F:SGW]QTYSTU
      If I >= dim([M:ASYW]STOCOU)
         Call ERREUR(mess(53,184,1)-mess(232,184,1)) From GESECRAN
         Break
      Endif
      I = 1
      WSERNUM = [F:SGW]SERNUM
      For I=1 To [F:SGW]QTYSTU
         [M:ASYW] = [F:SGW]
         [M:ASYW]TRTFLG(nolign-1)  = 1
         [M:ASYW]SERNUM(nolign-1)  = WSERNUM

         Call PLUS_UN(WSERNUM,WSERNUMF,WRET) From STKLIB
         WSERNUM = WSERNUMF
         nolign += 1
      Next I
   Else
      If nolign >= dim([M:ASYW]STOCOU)
         Call ERREUR(mess(53,184,1)-mess(232,184,1)) From GESECRAN
         Break
      Endif
      [M:ASYW] = [F:SGW]
      [M:ASYW]TRTFLG(nolign-1) = 1
      nolign += 1
   Endif

Next

[M:ASYW]NBLIG = nolign-1

Return

########################################################
# Chargement de l'écran de saisie VXASY
# avec un élément de la liste à ranger ([M:ASYW] indicé par INOL)
########################################################
$ALI_XASY

Read [SGW]SGW0=[M:ASYW]STOCOU(INOL);[M:ASYW]VCRTYP(INOL);[M:ASYW]VCRNUM(INOL);[M:ASYW]VCRLIN(INOL);[M:ASYW]SRGSEQ(INOL)
If fstat
   Call RSTA("SGW",num$([M:ASYW]VCRTYP(INOL))-[M:ASYW]VCRNUM(INOL)-num$([M:ASYW]VCRLIN(INOL))) From GLOCK
   OK=0 : Return
Endif
Read [SRG]SRG0=[M:ASYW]STOCOU(INOL);[M:ASYW]VCRTYP(INOL);[M:ASYW]VCRNUM(INOL);[M:ASYW]VCRLIN(INOL)
If fstat
   Call RSTA("SRG",num$([M:ASYW]VCRTYP(INOL))-[M:ASYW]VCRNUM(INOL)-num$([M:ASYW]VCRLIN(INOL))) From GLOCK
   OK=0 : Return
Endif

# Lecture de l'enregistrement origine du rangement
Gosub TRT_ORIGINE_TRSCOD From TRTSSLA

Raz WRET
# Lecture article
Call LECITM([F:SRG]STOFCY,[F:SRG]ITMREF,"",0,"",WRET) From STKLIB
If WRET<>0 : OK=0 : Return : Endif
# Lecture règle de gestion
Call LECSRU([F:SRG]STOFCY,[F:ITG]TCLCOD,[F:SRG]TRSTYP,WTRSCOD,"",WRET) From STKLIB
If WRET<>0 : OK=0 : Return : Endif

nolign = INOL+1

[M:XASY]          = [F:SGW]
[M:XASY]STADES    = [F:SGW]STA
[M:XASY]LOCDES    = [F:SGW]LOC
[M:XASY]LOCTYPDES = [F:SGW]LOCTYP

[M:XASY]ITMREF    = [F:SRG]ITMREF
[M:XASY]STA       = [F:SRG]STA
[M:XASY]LOC       = [F:SRG]LOC
[M:XASY]TRSTYP    = [F:SRG]TRSTYP

[M:XASY]BPRNUM    = WBPRNUM
[M:XASY]TRSCOD    = WTRSCOD

[M:XASY]QTYPCUORI = [F:SGW]QTYPCU

# Si no série, n [M:ASYW] pour 1 [F:SGW]
If [F:SGW]SERNUM<>""
   [M:XASY]SERNUM    = [M:ASYW]SERNUM(nolign-1)
   #MAE, issue 110327
   If [F:ITM]SERMGTCOD = 3
    [M:XASY]SERNUMF   = [M:ASYW]SERNUM(nolign-1)
    [M:XASY]QTYPCU    = 1
    [M:XASY]QTYSTU    = 1
    [M:XASY]PCUSTUCOE = 1
    [M:XASY]QTYPCUORI = 1
   Endif
Endif

[M:XASY]WSTOSEQ=1

# Disable fields that should not be prompted for, based on the product
If [F:ITM]LOTMGTCOD<2
   Grizo [M:XASY]LOT
Elsif [M:XASY]LOT<>""
   Diszo [M:XASY]LOT
Else
   Actzo [M:XASY]LOT
Endif
If [F:ITM]LOTMGTCOD<>4
   Grizo [M:XASY]SLO
Elsif [M:XASY]SLO<>""
   Diszo [M:XASY]SLO
Else
   Actzo [M:XASY]SLO
Endif
If [F:ITM]SERMGTCOD<3
   Grizo [M:XASY]SERNUM
   Grizo [M:XASY]SERNUMF
Elsif [M:XASY]SERNUM<>""
   Diszo [M:XASY]SERNUM
   Diszo [M:XASY]SERNUMF
Else
   Actzo [M:XASY]SERNUM
   Actzo [M:XASY]SERNUMF
Endif

Affzo [M:XASY]1-99

Return

########################################################
# Mise à jour de STOSRGW (delete,rewrite) et TABWIPSTO,
# ainsi que [M:ASYW] (nouvelle ligne) si nécessaire
########################################################
$MAJ_STOSRGW

Readlock [SGW]SGW0=[M:ASYW]STOCOU(INOL);[M:ASYW]VCRTYP(INOL);[M:ASYW]VCRNUM(INOL);[M:ASYW]VCRLIN(INOL);[M:ASYW]SRGSEQ(INOL)
If fstat
   Call RSTA("SGW",num$([M:ASYW]VCRTYP(INOL))-[M:ASYW]VCRNUM(INOL)-num$([M:ASYW]VCRLIN(INOL)))
&            From GLOCK
   WRET=1 : Return
Endif

# Traitement d'un numéro de série
If [M:XASY]SERNUM<>""
   # Le numéro de série traité est le premier de STOSRGW
   If [M:XASY]SERNUM=[F:SGW]SERNUM
      # et le dernier
      [M:ASYW]TRTFLG(INOL) = 2
      If [M:XASY]SERNUM=[F:SGW]SERNUMF
         # Suppression du STOSRGW
         Delete [SGW] Curr
         # Suppression du STOWIPW
         If GWIPSTOLCK=2
            Delete [F:TWS] Where STOCOU=[F:SGW]STOCOU & STOSEQ=[F:SGW]STOSEQTWS
         Endif
      Else
        # Issue 110327 - 2016-11-10 by MAE : Si serie globale, c'est SERNUMF qu'on incrémente
         If [F:ITM]SERMGTCOD = 4
          # Réécriture du STOSRGW avec la qté restant à traiter
          # et incrémentation du no série début
          [F:SGW]QTYPCU -= [M]QTYPCU
          [F:SGW]QTYSTU -= [M]QTYPCU
          WSERNUM = [F:SGW]SERNUM
          Call PLUS_NB(WSERNUM,[M]QTYPCU+1,WSERNUMF,WRET) From STKLIB
         Else
          # Réécriture du STOSRGW avec la qté restant à traiter
          # et incrémentation du no série début
          [F:SGW]QTYPCU -= 1
          [F:SGW]QTYSTU -= 1
          WSERNUM = [F:SGW]SERNUM
          Call PLUS_UN(WSERNUM,WSERNUMF,WRET) From STKLIB
         Endif
         [F:SGW]SERNUM = WSERNUMF
         Rewrite [SGW]
         If fstat
            Call FSTA("SGW") From GLOCK
            WRET=1 : Return
         Endif
         # Maj du STOWIPW
         If GWIPSTOLCK=2
            WQTY=1
            Gosub MAJ_TWS
         Endif
        Endif
      Return
   # Le numéro de série traité est le dernier de STOSRGW
   Elsif [M:XASY]SERNUM=[F:SGW]SERNUMF
      [M:ASYW]TRTFLG(INOL) = 2
      # Issue 110327 - 2016-11-10 by MAE : Si serie globale, c'est SERNUMF qu'on incrémente
      If [F:ITM]SERMGTCOD = 4
        # Réécriture du STOSRGW avec la qté restant à traiter
        # et décrémentation du no série fin
        [F:SGW]QTYPCU -= [M]QTYPCU
        [F:SGW]QTYSTU -= [M]QTYPCU
        WSERNUM = [F:SGW]SERNUMF
        Call MOINS_UN(WSERNUM,WSERNUMF,WRET) From STKLIB
      Else
        # Réécriture du STOSRGW avec la qté restant à traiter
        # et décrémentation du no série fin
        [F:SGW]QTYPCU -= 1
        [F:SGW]QTYSTU -= 1
        WSERNUM = [F:SGW]SERNUMF
        Call MOINS_UN(WSERNUM,WSERNUMF,WRET) From STKLIB
      Endif
      [F:SGW]SERNUMF = WSERNUMF
      Rewrite [SGW]
      If fstat
         Call FSTA("SGW") From GLOCK
         WRET=1 : Return
      Endif
      # Maj du STOWIPW
      If GWIPSTOLCK=2
         WQTY=1
         Gosub MAJ_TWS
      Endif
      Return
   # Le numéro de série traité est au milieu de STOSRGW
   Elsif [F:SGW]SERNUM<>"" & [F:SGW]SERNUMF<>""
      [M:ASYW]TRTFLG(INOL) = 2
      # Sauvegarde no série fin
      WSERNUMFIN = [F:SGW]SERNUMF
      # Réécriture du STOSRGW avec la qté restant à traiter
      # jusqu'au no série traité
      WSERNUM = [M:XASY]SERNUM
      Call MOINS_UN(WSERNUM,WSERNUMF,WRET) From STKLIB
      [F:SGW]SERNUMF = WSERNUMF
      WRET=0
      Call NB_SERIE([F:SGW]SERNUM,[F:SGW]SERNUMF,WNB,WRET) From STKLIB
      If WRET<>0 Return Endif
      [F:SGW]QTYPCU = WNB
      [F:SGW]QTYSTU = WNB
      Rewrite [SGW]
      If fstat
         Call FSTA("SGW") From GLOCK
         WRET=1 : Return
      Endif
      # Maj du STOWIPW
      If GWIPSTOLCK=2
         WQTY=1
         Gosub MAJ_TWS
      Endif

      # Ecriture d'un nouveau STOSRGW avec la qté restant à traiter
      # depuis le no série traité jusqu'au no série fin
      WSERNUM = [M:XASY]SERNUM
      Call PLUS_UN(WSERNUM,WSERNUMF,WRET) From STKLIB
      [F:SGW]SERNUM  = WSERNUMF
      [F:SGW]SERNUMF = WSERNUMFIN
      WRET=0
      Call NB_SERIE([F:SGW]SERNUM,[F:SGW]SERNUMF,WNB,WRET) From STKLIB
      If WRET<>0 Return Endif
      [F:SGW]QTYPCU = WNB
      [F:SGW]QTYSTU = WNB
      # Récupération du prochain no séquence
      Filter [SGW1] Where STOCOU = [F:SGW1]STOCOU &
&                         VCRTYP = [F:SGW1]VCRTYP &
&                         VCRNUM = [F:SGW1]VCRNUM &
&                         VCRLIN = [F:SGW1]VCRLIN
&                         Order By Key SGW0
      Read [SGW1] Last
      If fstat=0
         [F:SGW]SRGSEQ=[F:SGW1]SRGSEQ+1
      Else
         [F:SGW]SRGSEQ=1
      Endif
      Filter [SGW1]

      Write [SGW]
      If fstat
         Call FSTA("SGW") From GLOCK
         WRET=1 : Return
      Endif
      # Maj du SRGSEQ du nouveau [F:SRGW] dans le tableau
      For I=INOL+1 To INOL+WNB
         [M:ASYW]SRGSEQ(I)=[F:SGW]SRGSEQ
      Next I
      Return

   # STOSRGW ne contient pas de no série
   Else
      # On traite comme s'il ni avait pas de no série
      # --> on continue
   Endif
Endif

# Quantité à ranger traitée partiellement
If [M:XASY]QTYPCU<[M:XASY]QTYPCUORI
   # Réécriture du STOSRGW avec la qté restant à traiter
   [F:SGW]QTYPCU = [M:XASY]QTYPCUORI-[M:XASY]QTYPCU
   [F:SGW]QTYSTU = [F:SGW]QTYPCU*[F:SGW]PCUSTUCOE
   Rewrite [SGW]
   If fstat
      Call FSTA("SGW") From GLOCK
      WRET=1 : Return
   Endif
   # Maj du STOWIPW
   If GWIPSTOLCK=2
      WQTY=[M:XASY]QTYPCU*[F:SGW]PCUSTUCOE
      Gosub MAJ_TWS
   Endif

# Quantité à ranger traitée en totalité
Else
   [M:ASYW]TRTFLG(INOL) = 2
   # Suppression du STOWIPW
   If GWIPSTOLCK=2
      Delete [F:TWS] Where STOCOU=[F:SGW]STOCOU & STOSEQ=[F:SGW]STOSEQTWS
   Endif
   # Suppression du STOSRGW
   Delete [SGW] Curr
Endif

Return

# Maj du STOWIPW
$MAJ_TWS
Readlock [TWS]TWS0=[F:SGW]STOCOU;[F:SGW]STOSEQTWS
If !fstat
   [F:TWS]WIPQTY-=WQTY
   [F:TWS]WIPQTA-=WQTY
   Rewrite [TWS]
Endif

Return
########################################################
# Actions champs
########################################################

########################################################
Subprog C_SRGPPS(VALEUR)
Variable Char    VALEUR()

If VALEUR="" mkstat=2 : End Endif

Call CTRPPSSRG("XASY",VALEUR) From TRTSSLA

End

########################################################
Subprog AM_SRGPPS(VALEUR)
Variable Char    VALEUR()

If [M:XASY]SRGPPS<>""
   Unlock = SYMBOLSRG
Endif

[M:XASY]SRGPPS = VALEUR

SYMBOLSRG = "SRGLIS"+[M:XASY]SRGPPS
Lock = SYMBOLSRG
If fstat
   GERR=1
   Call ERREUR([M:XASY]SRGPPS-":"-mess(10,100,1)) From GESECRAN
   mkstat=2 : End
Endif

End

########################################################
Subprog AP_QTYPCU(VALEUR)
Variable Decimal VALEUR

Local    Integer WRET # Issue 110327

If VALEUR<=0 mkstat=2 : End Endif
# La quantité ne peut être supérieure à la quantité à ranger
If VALEUR>[M:XASY]QTYPCU mkstat=2 : End Endif

If VALEUR<>[M:XASY]QTYPCU
   [M:XASY]QTYSTU = VALEUR*[M:XASY]PCUSTUCOE
   Call QTEARR([M:XASY]QTYSTU,[F:ITM]STU) From TRTDIV
   # Issue 110327 - 2016-11-10 by MAE : Gestion des series globales
   If [F:ITM]SERMGTCOD=4
    Call PLUS_NB([M:XASY]SERNUM,VALEUR,[M:XASY]SERNUMF,WRET) From STKLIB
   Endif
Endif

End

########################################################
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
   Call STKCTRSLO(VALEUR,1,[M:XASY]LOT,[M:XASY]ITMREF,[M:XASY]BPSLOT,[M:XASY]GESLOT,"",
&                 0,0,0,[M:XASY]STOFCY,[M:XASY]SLOF) From STKACT
Endif

End

########################################################
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()

Local    Integer WRET

If VALEUR=""
   If [F:ITM]SERCOU=""
      mkstat=2 : End
   Else
      [M:XASY]SERNUMF=""
   Endif
Elsif VALEUR<>[M:XASY]SERNUM
   Call PLUS_NB(VALEUR,[M:XASY]QTYSTU,[M:XASY]SERNUMF,WRET) From STKLIB
Endif

End
########################################################
Subprog C_STADES(VALEUR)
Variable Char    VALEUR()

If VALEUR=""
   mkstat=2 : End
Endif

End

########################################################
Subprog C_LOCDES(VALEUR)
Variable Char    VALEUR()

If VALEUR="" | VALEUR=[M:XASY]LOC
   Raz [M:XASY]LOCTYPDES
   mkstat=2 : End
Endif

[M:XASY]LOCTYPDES=[F:STC]LOCTYP

End

