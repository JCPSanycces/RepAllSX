#<AdxTL>@(#)0.0.0.0 $Revision$Class Sequential file
# Supervisor
## CRUD-CLASSE ## EDISEQFIL
# 2018-11-06 07:05:06 399


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(EDISEQFIL,ASTATUS)
Variable Instance EDISEQFIL Using C_EDISEQFIL
Variable Integer ASTATUS

If EDISEQFIL = null : End : Endif

Gosub _AVARIABLES From WMC00EDISEQFIL

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_EDISEQFIL

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EDISEQFIL,ASTATUS)
Variable Instance EDISEQFIL Using C_EDISEQFIL
Variable Integer ASTATUS

If EDISEQFIL = null : End : Endif

Gosub AVARIABLES From WMC00EDISEQFIL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EDISEQFIL
Else
 Gosub ADELETE_EDISEQFIL
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EDISEQFIL,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EDISEQFIL.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDISEQFIL.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EDISEQFIL.ESFN)
 If EDISEQFIL.ESFN([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFN([L]A_I).ACTION("ADELETE_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDISEQFIL.ESFD) : # EDISEQFILD -- 2
 If EDISEQFIL.ESFD(A_N2) <> null
& and EDISEQFIL.ESFD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDISEQFIL.ESFD(A_N2).ASTALIN<>[V]CST_ANEW
   EDISEQFIL.ESFD(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFD(A_N2).ACTION("ADELETE_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDISEQFIL.ESFF) : # EDISEQFILF -- 3
 If EDISEQFIL.ESFF(A_N2) <> null
& and EDISEQFIL.ESFF(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDISEQFIL.ESFF(A_N2).ASTALIN<>[V]CST_ANEW
   EDISEQFIL.ESFF(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFF(A_N2).ACTION("ADELETE_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER
For A_N2=1 To maxtab(EDISEQFIL.ESFD) : # EDISEQFILD -- 2
 If EDISEQFIL.ESFD(A_N2) <> null
& and EDISEQFIL.ESFD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFD(A_N2).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDISEQFIL.ESFF) : # EDISEQFILF -- 3
 If EDISEQFIL.ESFF(A_N2) <> null
& and EDISEQFIL.ESFF(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFF(A_N2).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [L]A_I=1 To maxtab(EDISEQFIL.ESFN)
 If EDISEQFIL.ESFN([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFN([L]A_I).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EDISEQFIL
Trbegin [F:ESF]
 Gosub ADELETE_EDISEQFIL
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_EDISEQFIL
[L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDISEQFIL.ESFD)
 If EDISEQFIL.ESFD(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFD(A_N2).ACTION("ADELETE_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDISEQFIL.ESFD(A_N2).ASTALIN=[V]CST_ADEL
  [L]ASTATUS = func WMC00EDISEQFIL._MAJSQL_EDISEQFILD(EDISEQFIL.ESFD(A_N2))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFD(A_N2).ACTION("ADELETE_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDISEQFIL.ESFF)
 If EDISEQFIL.ESFF(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFF(A_N2).ACTION("ADELETE_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDISEQFIL.ESFF(A_N2).ASTALIN=[V]CST_ADEL
  [L]ASTATUS = func WMC00EDISEQFIL._MAJSQL_EDISEQFILF(EDISEQFIL.ESFF(A_N2))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  [L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ESFF(A_N2).ACTION("ADELETE_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(EDISEQFIL,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EDISEQFIL._MAJSQL_EDISEQFIL(EDISEQFIL))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDISEQFIL.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EDISEQFIL.snapshotEnabled=1
 [L]A_RETIK = EDISEQFIL.revertUpdTick
Endif
[L]ASTATUS = max(fmet EDISEQFIL.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



