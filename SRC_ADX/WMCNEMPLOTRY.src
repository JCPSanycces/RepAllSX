####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EMPLOTRY
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_REFNUM From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_NUMLIG From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_STRDATTRY From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_ENDDATTRY From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_FNCTRY From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_SRVTRY From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_STATRY From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_CPYTRY From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_PLCCPYTRY From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_DESTRY1 From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_DESTRY2 From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_DESTRY3 From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_CREDAT From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_CRETIM From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_UPDDAT From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_UPDTIM From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub AINIT From WMC0EMPLOTRY : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EMPLOTRY
Gosub _ALOADATTRIBUTE_REFNUM From WMC1EMPLOTRY : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EMPLOTRY
Gosub LNKPRO_REFNUM From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub LNKPRO_STATRY From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC1EMPLOTRY : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1EMPLOTRY : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



