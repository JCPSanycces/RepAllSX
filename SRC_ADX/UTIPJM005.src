#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM005
# Issue X3-8079/120058 - 2016-11-28 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM005(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM005(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NI
Local Integer NE
Local Integer NCOUNTOK
Local Integer NCOUNTERROR

  IERR = 0
  Call ECR_TRACE("UTIPJM005: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table PJMTIMEMP
  #
  If filinfo(filpath("FIL", "PJMTSK", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PJMTSK" [PJTA]
  Local File =SZAPPLI + ".PJMTSKOPE" [PTKO]
  Local File =SZAPPLI + ".PJMOPEAFF" [PJOA]
  # -------------------------
  Trbegin [PJTA]
  NCOUNT = 0
  NCOUNTERROR = 0
  Call ECR_TRACE("UTIPJM005: Updating PJMTSKOPE/PJMOPEAFF", 0) From GESECRAN
  Filter [PJTA] Where [F:PJTA]TASSTATE > 1
  For [PJTA]
    # -----------------------------
    Filter [PTKO] Where [F:PTKO]OPPNUM = [F:PJTA]OPPNUM and [F:PTKO]TASCOD = [F:PJTA]TASCOD and ([F:PTKO]OPESTR = [0/0/0] or [F:PTKO]OPEEND = [0/0/0])
    For [PTKO]
      [F:PTKO]OPESTR = [F:PJTA]TASSTARTDT
      [F:PTKO]OPEEND = [F:PJTA]TASENDDT
      NCOUNT += 1
      Rewrite [PTKO]
      If fstat Then
        Call ECR_TRACE("File PJMTSKOPE" - [F:PTKO]OPPNUM - [F:PTKO]TASCOD - num$([F:PTKO]OPENUM) - num$([F:PTKO]OPESPLNUM) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [PTKO]
    # -----------------------------
    Filter [PJOA] Where [F:PJOA]OPPNUM = [F:PJTA]OPPNUM and [F:PJOA]TASCOD = [F:PJTA]TASCOD and ([F:PJOA]POASTR = [0/0/0] or [F:PJOA]POAEND = [0/0/0])
    For [PJOA]
      [F:PJOA]POASTR = [F:PJTA]TASSTARTDT
      [F:PJOA]POAEND = [F:PJTA]TASENDDT
      NCOUNT += 1
      Rewrite [PJOA]
      If fstat Then
        Call ECR_TRACE("File PJMOPEAFF" - [F:PJOA]OPPNUM - [F:PJOA]TASCOD - num$([F:PJOA]OPENUM) - num$([F:PJOA]OPESPLNUM) - num$([F:PJOA]POANUM) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [PTKO]
    # -----------------------------
  Next
  Filter [PJTA]
  # -------------------------
  If NCOUNTERROR = 0 Then
    Call ECR_TRACE("UTIPJM005: PJMTSKOPE/PJMOPEAFF" - num$(NCOUNT) - "updated.", 0) From GESECRAN
  Else
    Call ECR_TRACE("UTIPJM005: PJMTSKOPE/PJMOPEAFF" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
  Endif
  # -----------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM005 : records processed without error.", 0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM005 : records processed with error(s).", 0) From GESECRAN
  Endif
  # -------------------------
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------------
  # Issue X3-8278/120038 - 2016-11-30 by FGR : BEGIN
  If filinfo(filpath("FIL","PJMTSK","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSK") : End : Endif
  # Issue X3-8278/120038 - 2016-11-30 by FGR : END
  # -------------------------------
  Call MAJ_UTIPJM005(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  # -------------------------------
  # Issue X3-8278/120038 - 2016-11-30 by FGR : BEGIN
  If filinfo(filpath("FIL","PJMTSK","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSK") : End : Endif
  # Issue X3-8278/120038 - 2016-11-30 by FGR : END
  # -------------------------------
  Call MAJ_UTIPJM005(APPLI)
End

