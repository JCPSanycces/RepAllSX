#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
#UTIPJM002
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    #Call MAJ_UTIPJM002(DOSSIER)
    Call MAJ_UTIPJM003(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM002(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NCOUNTOK
Local Integer NCOUNTERROR
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)
Local Char SSEPARCODE(1)

  IERR = 0
  # -------------------------
  If filinfo(filpath("FIL", "OPPORPJM", "fde", SZAPPLI), 0) <= 0 Then
    # If OPPORPJM table is not existing PJM is not on the folder. Not necessary to do anything
    End
  Endif
  # -------------------------
  Call ECR_TRACE("UTIPJM002: Process Start on : "+SZAPPLI, 0) From GESECRAN
  #
#  SSEPARCODE = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, SZAPPLI, "SEPARCODE")
#  If SSEPARCODE = "" Then
#    Call ECR_TRACE("SEPARCODE folder parameter is empty on folder" - SZAPPLI, 1) From GESECRAN
#    End
#  Endif
#  If fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, GACTX.AFOLDER, "SEPARCODE") = "" Then
#    Call ECR_TRACE("SEPARCODE folder parameter is empty on folder" - GACTX.AFOLDER, 1) From GESECRAN
#    End
#  Endif
  # ---------------------------------------------------------------------------
  # Traitement table PIMPL
  If filinfo(filpath("FIL", "PIMPL", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PIMPL" [PIM]
  # -------------------------
  Trbegin [PIM]
  NCOUNT = 0
  NCOUNTERROR = 0
  Call ECR_TRACE("UTIPJM002: Updating PIMPL", 0) From GESECRAN
  Filter [PIM] Where [F:PIM]PIMTYP >= 4 and [F:PIM]PIMTYP <= 7
  For [PIM]
    NCOUNT += 1
    # -----------------------------
    IUPDATE = [V]CST_ANO
    Case [F:PIM]PIMTYP
      When 4
        # Budget
        WCHAINE = func GET_PIMNUM_BUDGET(GACTX, [F:PIM]OPPNUM, [F:PIM]PBUCOD)
        If WCHAINE <> [F:PIM]PIMNUM Then
          IUPDATE = [V]CST_AYES
          [F:PIM]PIMNUM = WCHAINE
        Endif
      When Default
        # Task
        WCHAINE = func GET_PIMNUM_TASK(GACTX, [F:PIM]OPPNUM, [F:PIM]TASCOD)
        If WCHAINE <> [F:PIM]PIMNUM Then
          IUPDATE = [V]CST_AYES
          [F:PIM]PIMNUM = WCHAINE
        Endif
    Endcase
    # -----------------------------
    If IUPDATE = [V]CST_AYES Then
      Rewrite [PIM]
      If fstat Then
        Call ECR_TRACE("File PIMPL" - [F:PIM]PIMNUM + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Endif
  Next
  Filter [PIM]
  # -------------------------
  If NCOUNTERROR = 0 Then
    Call ECR_TRACE("UTIPJM002: PIMPL" - num$(NCOUNT) - "updated.", 0) From GESECRAN
  Else
    Call ECR_TRACE("UTIPJM002: PIMPL" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
  Endif
  # -----------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM002 PIMPL : records processed without error.", 0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM002 PIMPL : records processed with error(s).", 0) From GESECRAN
  Endif
  # ---------------------------------------------------------------------------
  # Traitement table PJMBUD
  If filinfo(filpath("FIL", "PJMBUD", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PJMBUD" [PJBU]
  # -------------------------
  Trbegin [PJBU]
  NCOUNT = 0
  NCOUNTERROR = 0
  Call ECR_TRACE("UTIPJM002: Updating PJMBUD", 0) From GESECRAN
  Filter [PJBU]
  For [PJBU]
    NCOUNT += 1
    # -----------------------------
    IUPDATE = [V]CST_ANO
    # Budget
    WCHAINE = func GET_PIMNUM_BUDGET(GACTX, [F:PJBU]OPPNUM, [F:PJBU]PBUCOD)
    If WCHAINE <> [F:PJBU]KEYCONCAT Then
      IUPDATE = [V]CST_AYES
      [F:PJBU]KEYCONCAT = WCHAINE
    Endif
    # -----------------------------
    If IUPDATE = [V]CST_AYES Then
      Rewrite [PJBU]
      If fstat Then
        Call ECR_TRACE("File PJMBUD" - [F:PJBU]OPPNUM - "/" - [F:PJBU]PBUCOD + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Endif
  Next
  Filter [PJBU]
  # -------------------------
  If NCOUNTERROR = 0 Then
    Call ECR_TRACE("UTIPJM002: PJMBUD" - num$(NCOUNT) - "updated.", 0) From GESECRAN
  Else
    Call ECR_TRACE("UTIPJM002: PJMBUD" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
  Endif
  # -----------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM002 PJMBUD : records processed without error.", 0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM002 PJMBUD : records processed with error(s).", 0) From GESECRAN
  Endif
  # ---------------------------------------------------------------------------
  # Traitement table PJMTSK
  If filinfo(filpath("FIL", "PJMTSK", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PJMTSK" [PJTA]
  # -------------------------
  Trbegin [PJTA]
  NCOUNT = 0
  NCOUNTERROR = 0
  Call ECR_TRACE("UTIPJM002: Updating PJMTSK", 0) From GESECRAN
  Filter [PJTA]
  For [PJTA]
    NCOUNT += 1
    # -----------------------------
    IUPDATE = [V]CST_ANO
    # Budget
    WCHAINE = func GET_PIMNUM_TASK(GACTX, [F:PJTA]OPPNUM, [F:PJTA]TASCOD)
    If WCHAINE <> [F:PJTA]KEYCONCAT Then
      IUPDATE = [V]CST_AYES
      [F:PJTA]KEYCONCAT = WCHAINE
    Endif
    # -----------------------------
    If IUPDATE = [V]CST_AYES Then
      Rewrite [PJTA]
      If fstat Then
        Call ECR_TRACE("File PJMTSK" - [F:PJTA]OPPNUM - "/" - [F:PJTA]TASCOD + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Endif
  Next
  Filter [PJTA]
  # -------------------------
  If NCOUNTERROR = 0 Then
    Call ECR_TRACE("UTIPJM002: PJMTSK" - num$(NCOUNT) - "updated.", 0) From GESECRAN
  Else
    Call ECR_TRACE("UTIPJM002: PJMTSK" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
  Endif
  # -------------------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM002 PJMTSK : records processed without error.", 0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM002 PJMTSK : records processed with error(s).", 0) From GESECRAN
  Endif
  # ---------------------------------------------------------------------------
End

##########################################################################
Subprog MAJ_UTIPJM003(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NCOUNTOK
Local Integer NCOUNTERROR
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)
Local Char SSEPARCODE(1)
Local Integer STAT
Local Integer IOK

  IERR = 0
  # -------------------------
  If filinfo(filpath("FIL", "PJMTSK", "fde", SZAPPLI), 0) <= 0 Then
    # If OPPORPJM table is not existing PJM is not on the folder. Not necessary to do anything
    End
  Endif
  # -------------------------
  Call ECR_TRACE("UTIPJM003: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # ---------------------------------------------------------------------------
  # Traitement table PIMPL
  If filinfo(filpath("FIL", "PJMBUD", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PJMTSK"    [PJTA]
  Local File =SZAPPLI + ".PJMBUD"    [PJBU]
  #
  Local File =SZAPPLI + ".TABCOUAFF" [TCA]
  Local File =SZAPPLI + ".AVALNUM"   [AVN]
  Local File =SZAPPLI + ".ACODNUM"   [ANM]
  # ---------------------------------------------------------------------------
  # Traitement table PJMBUD
  # -------------------------
  Call LECTCA(9, IOK) From SUBTCA
  Call ECR_TRACE("UTIPJM003 Counter for PJMBUD :" - [F:TCA]CODNUM(13), 0) From GESECRAN
  Call ECR_TRACE("UTIPJM003 Counter for PJMTSK :" - [F:TCA]CODNUM(12), 0) From GESECRAN
  # -------------------------
  If dim([F:PJBU]PBUNUM) >= 0 Then
    Trbegin [PJBU]
    NCOUNT = 0
    NCOUNTERROR = 0
    Call ECR_TRACE("UTIPJM003: Updating PJMBUD", 0) From GESECRAN
    Filter [PJBU] Where [F:PJBU]PBUNUM = ""
    For [PJBU]
      NCOUNT += 1
      # -----------------------------
      IUPDATE = [V]CST_AYES
      # Budget
      Call NUMERO([F:TCA]CODNUM(13), [F:PJBU]PBUFCY, date$, "", [F:PJBU]PBUNUM, STAT) From SUBANM
      If STAT > 0 Then
        Call ECR_TRACE("File PJMBUD" - [F:PJBU]OPPNUM - "/" - [F:PJBU]PBUCOD + ", Error =" - num$(STAT), 1) From GESECRAN
        IUPDATE = [V]CST_ANO
      Endif
      # -----------------------------
      If IUPDATE = [V]CST_AYES Then
        Rewrite [PJBU]
        If fstat Then
          Call ECR_TRACE("File PJMBUD" - [F:PJBU]OPPNUM - "/" - [F:PJBU]PBUCOD + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          NCOUNTERROR += 1
        Endif
      Endif
    Next
    Filter [PJBU]
    # -------------------------
    If NCOUNTERROR = 0 Then
      Call ECR_TRACE("UTIPJM003: PJMBUD" - num$(NCOUNT) - "updated.", 0) From GESECRAN
    Else
      Call ECR_TRACE("UTIPJM003: PJMBUD" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
    Endif
    # -----------
    If IERR = 0 Then
      Commit
      Call ECR_TRACE("UTIPJM003 PJMBUD : records processed without error.", 0) From GESECRAN
    Else
      Rollback
      Call ECR_TRACE("UTIPJM003 PJMBUD : records processed with error(s).", 0) From GESECRAN
    Endif
  Endif
  # ---------------------------------------------------------------------------
  # Traitement table PJMTSK
  # -------------------------
  If dim([F:PJTA]TASNUM) >= 0 Then
    Trbegin [PJTA]
    NCOUNT = 0
    NCOUNTERROR = 0
    Call ECR_TRACE("UTIPJM003: Updating PJMTSK", 0) From GESECRAN
    Filter [PJTA] Where [F:PJTA]TASNUM = ""
    For [PJTA]
      NCOUNT += 1
      # -----------------------------
      IUPDATE = [V]CST_AYES
      # Task
      Call NUMERO([F:TCA]CODNUM(12), [F:PJTA]TASFCY, date$, "", [F:PJTA]TASNUM, STAT) From SUBANM
      If STAT > 0 Then
        Call ECR_TRACE("File PJMTSK" - [F:PJTA]OPPNUM - "/" - [F:PJTA]TASCOD + ", Error =" - num$(STAT), 1) From GESECRAN
        IUPDATE = [V]CST_ANO
      Endif
      # -----------------------------
      If IUPDATE = [V]CST_AYES Then
        Rewrite [PJTA]
        If fstat Then
          Call ECR_TRACE("File PJMTSK" - [F:PJTA]OPPNUM - "/" - [F:PJTA]TASCOD + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          NCOUNTERROR += 1
        Endif
      Endif
    Next
    Filter [PJTA]
    # -------------------------
    If NCOUNTERROR = 0 Then
      Call ECR_TRACE("UTIPJM003: PJMTSK" - num$(NCOUNT) - "updated.", 0) From GESECRAN
    Else
      Call ECR_TRACE("UTIPJM003: PJMTSK" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
    Endif
    # -------------------------
    If IERR = 0 Then
      Commit
      Call ECR_TRACE("UTIPJM003 PJMTSK : records processed without error.", 0) From GESECRAN
    Else
      Rollback
      Call ECR_TRACE("UTIPJM003 PJMTSK : records processed with error(s).", 0) From GESECRAN
    Endif
  Endif
  # ---------------------------------------------------------------------------
End

###################################################################################################
Funprog GET_PIMNUM_BUDGET(ACTX, SOPPNUM, SPBUCOD)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SOPPNUM
Value Char SPBUCOD

Local Char SARENDRE(250)
Local Char SSEPARCODE(1)

  SSEPARCODE = "!"
  SARENDRE = SOPPNUM + SSEPARCODE + SSEPARCODE + SPBUCOD
End SARENDRE

###################################################################################################
Funprog GET_PIMNUM_TASK(ACTX, SOPPNUM, STASCOD)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SOPPNUM
Value Char STASCOD

Local Char SARENDRE(250)
Local Char SSEPARCODE(1)

  SSEPARCODE = "!"
  SARENDRE = SOPPNUM + SSEPARCODE + STASCOD
End SARENDRE

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------------
  # Issue X3-8278/120038 - 2016-11-30 by FGR : BEGIN
  If filinfo(filpath("FIL","PJMTSK","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSK") : End : Endif
  # Issue X3-8278/120038 - 2016-11-30 by FGR : END
  # -------------------------------
  Call MAJ_UTIPJM002(APPLI)
  Call MAJ_UTIPJM003(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  # -------------------------------
  # Issue X3-8278/120038 - 2016-11-30 by FGR : BEGIN
  If filinfo(filpath("FIL","PJMTSK","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSK") : End : Endif
  # Issue X3-8278/120038 - 2016-11-30 by FGR : END
  # -------------------------------
  Call MAJ_UTIPJM002(APPLI)
  Call MAJ_UTIPJM003(APPLI)
End

