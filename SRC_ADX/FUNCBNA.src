#<AdxTL>@(#)4.0.0.0 $Revision$
#---------------------------------------------------------------------------#
# Replanification           (version 2.0)                                   #
# Novembre 2003 (llc)                                                       #
#---------------------------------------------------------------------------#
# Issue 107498/15 - 2016-07-08 by BAKHA : for project demand, assume simulation mode
# Issue 107498/19 - 2016-07-22 by BAKHA : if you have product twice on project demand then
#                                         some WOS/POS are missing.

$REPLANNING
Local Char    CUSFLT(255)      : Raz CUSFLT      # FQ 69832 GA 12/2010 ajout PE
Local Char    CUSCBD1_BWD(255) : Raz CUSCBD1_BWD # Issue 93050 & 92357 GA 10/2013 ajout CUSCBD1_BWD
Local Char    CUSCBD1_FRW(255) : Raz CUSCBD1_FRW # Issue 93050 & 92357 GA 10/2013 ajout CUSCBD1_FRW

# Issue 59610 - 2017-10-19 by STLIG : Assignment quantity (MTOQTY) filter
Local Char MTOFLT(255) : MTOFLT=""

XRPLNOMESS = 1 # Issue 92226 GA 09/2013 modifiable par le PE REPLANNING
XRPLCTLSPE = 1 # Issue 92357 GA 09/2013 before replanning use entry point CTLSPE

#---- point d'entrée
GREPLANNING = "RPL_PROCESS"
GPE=0 : GPOINT = "REPLANNING" : Gosub ENTREE From EXEFNC
If GPE <> 0 : Return : Endif
#----
# préparation filtre des ressources
WFILCBD = ""
If find(WRPLMOD(0),2,3) : WFILCBD += "(WIPTYP=5 & WIPSTA=1)|" : Endif
If find(WRPLMOD(1),2,3) : WFILCBD += "(WIPTYP=5 & WIPSTA=2)|" : Endif
If find(WRPLMOD(2),2,3) : WFILCBD += "(WIPTYP=2 & WIPSTA=1)|" : Endif
If find(WRPLMOD(3),2,3) : WFILCBD += "(WIPTYP=2 & WIPSTA=2)|" : Endif
If find(WRPLMOD(4),2,3) : WFILCBD += "(WIPTYP=7 & WIPSTA=1)|" : Endif
If find(WRPLMOD(5),2,3) : WFILCBD += "(WIPTYP=7 & WIPSTA=2)|" : Endif
If find(WRPLMOD(6),2,3) : WFILCBD += "(WIPTYP=13 & WIPSTA=1)|": Endif
If find(WRPLMOD(7),2,3) : WFILCBD += "(WIPTYP=13 & WIPSTA=2)|": Endif
# Issue 107498/15 - include project/task
If func AFNC.ACTIV("PJM")
  If WRPLMOD(0) = 1 : WFILCBD += "(PJT<>'' & WIPTYP=5&WIPSTA=1)|" : Endif
  If WRPLMOD(1) = 1 : WFILCBD += "(PJT<>'' & WIPTYP=5&WIPSTA=2)|" : Endif
  If WRPLMOD(2) = 1 : WFILCBD += "(PJT<>'' & WIPTYP=2&WIPSTA=1)|" : Endif
  If WRPLMOD(3) = 1 : WFILCBD += "(PJT<>'' & WIPTYP=2&WIPSTA=2)|" : Endif
  If WRPLMOD(4) = 1 : WFILCBD += "(PJT<>'' & WIPTYP=7&WIPSTA=1)|" : Endif
  If WRPLMOD(5) = 1 : WFILCBD += "(PJT<>'' & WIPTYP=7&WIPSTA=2)|" : Endif
  If WRPLMOD(6) = 1 : WFILCBD += "(PJT<>'' & WIPTYP=13&WIPSTA=1)|": Endif
  If WRPLMOD(7) = 1 : WFILCBD += "(PJT<>'' & WIPTYP=13&WIPSTA=2)|": Endif
Endif
# End issue 107498/15

WADJUST = 0
# parcours des ressources à replanifier
If WFILCBD <> ""
 # FQ 69832 GA 12/2010 ajout PE pour filtrage de Suggestions à replanifier
   GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
   If CUSFLT = "" : CUSFLT = "1=1" : Endif
   If CUSCBD1_BWD = "" : CUSCBD1_BWD = "1=1" : Endif # Issue 93050 & 92357 GA 10/2013
   If CUSCBD1_FRW = "" : CUSCBD1_FRW = "1=1" : Endif # Issue 93050 & 92357 GA 10/2013

    WFILCBD = "("+left$(WFILCBD, len(WFILCBD)-1)+")"  : # supprime le dernier |

  # Issue 59610 - 2017-10-19 by STLIG : Assignment quantity (MTOQTY) resource selection criteria.
  #                                     Set MTOFLT in CUSSELFLT - entry point
  If (MTOFLT="") : MTOFLT="MTOQTY=0" : Endif

# 30015 => Oubli correction V5 reportée GA 12/2010
#    Filter [CBD] Where ITMREF  = [F:CBH]ITMREF    &
#&                      STOFCY  = [F:CBH]STOFCY    &
#&                      REQDAT  > [F:CBH]PLHENDDAT &
#&                      REQDAT  <= WANADATF        &
#&                      evalue(WFILCBD)
#&                Order By Key CBD3

  # Issue 59610 - 2017-10-19 by STLIG : Apply assignment quantity (MTOQTY) filter
    Filter [CBD] Where ITMREF  = [F:CBH]ITMREF    &
&                      STOFCY  = [F:CBH]STOFCY    &
&                      REQDAT  <= WANADATF        &
&                      evalue(MTOFLT)             &
&                      evalue(WFILCBD)            &
&                      evalue(CUSFLT)
&                Order By Key CBD3
    For [CBD] With Stability
        # si protection ordres en cours pas de replanification
        If find(WWIPPRO,2,3) & [F:CBD]WIP = 2 : Goto NEXT_RESS : Endif
        Readlock [CBD] Curr
        If !fstat
            Gosub PROCESS_RESS
            If GOK <> 1 : Break : Endif
        Else
          GOK = 0 : Call FSTA("CBD") From GLOCK : Break
        Endif
$NEXT_RESS
    Next
    Filter [CBD]
Endif
Return

############################################################
# replanification d'une ressource
$PROCESS_RESS

# Issue 119203 - 2016-10-21 by STLIG : Filter resources by product and version.
Local Char FILTER_VERSION(255) : Raz FILTER_VERSION

# initialisations variables
XRPLMOD      = WRPLMOD   (func CBNLIB.MAPRPL([F:CBD]WIPTYP, [F:CBD]WIPSTA))
XRPLBWDLTI   = WRPLBWDLTI(func CBNLIB.MAPRPL([F:CBD]WIPTYP, [F:CBD]WIPSTA))
XRPLFRWLTI   = WRPLFRWLTI(func CBNLIB.MAPRPL([F:CBD]WIPTYP, [F:CBD]WIPSTA))
XRPLUPDQTY   = WRPLUPDQTY(func CBNLIB.MAPRPL([F:CBD]WIPTYP, [F:CBD]WIPSTA))
XRPLUPDDAT   = WRPLUPDDAT(func CBNLIB.MAPRPL([F:CBD]WIPTYP, [F:CBD]WIPSTA))

# Issue 107498/15 - assume simulation mode for PJT
If (func AFNC.ACTIV("PJM") and [F:CBD]PJT <> "")
  XRPLMOD = 3
  XRPLBWDLTI = 0
  XRPLFRWLTI = 0
  XRPLUPDQTY = 4
  XRPLUPDDAT = 4
Endif

# 30015
If [F:CBD]REQDAT <= [F:CBH]PLHENDDAT
    XRPLUPDQTY = 1
    # Issue 92226 GA/LLC 09/2013 selon PE RPLNOMESS
    If XRPLNOMESS = 2
       XRPLUPDDAT = 1
       WRPLQTY = [F:CBD]REQQTY
       Goto PROCESS_FIN
    Endif
Endif

# Issue 92357 GA 09/2013 éviter la replanif selon critères spécifiques
If XRPLCTLSPE=2
    GPE=0 : GPOINT = "CTLSPE" : Gosub ENTREE From EXEFNC
    If GPE
       XRPLUPDQTY = 1
       XRPLUPDDAT = 1
       WRPLQTY = [F:CBD]REQQTY
       # Issue 106456 GA 03/2015 Message info, sans erreur !
       #Call ECR_TRACE("Entry point CTLSPE: no replanning for"-[F:CBD]ITMREF-[F:CBD]VCRNUM-mess([F:CBD]VCRTYP,701,1),0) From GESECRAN
       Call ECR_DEBUG("Entry point CTLSPE: no replanning for"-[F:CBD]ITMREF-[F:CBD]VCRNUM-mess([F:CBD]VCRTYP,701,1)) From FUNCBN
       Goto PROCESS_FIN
    Endif
Endif

WRESSQTY     = [F:CBD]REQQTY
WRPLDAT      = [0/0/0]
WRPLQTY      = 0
WLOOP        = 0
WBREAKLOOP   = 0
If (XRPLMOD = 3) : WSIM = 1 : Else : WSIM = 0 : Endif
WECART       = 1
WRESSRMN     = [F:CBD]REQQTY

# Issue 107498/15 - for project demand find any matching POP/POF etc

If (func AFNC.ACTIV("PJM") and [F:CBD]PJT <> "")

$LOOP_PJT
  Filter [CBD1] Where ITMREF   = [F:CBH]ITMREF   &
&                   STOFCY   = [F:CBH]STOFCY   &
&                   find(WIPTYP,2,5,7,13)      &
&                   WIPSTA   = 3               &
&                   MRPMES <> 6                &
&                   RPLFLG <> 2                &
&                   PJT = [F:CBD]PJT
&              Order By Key CBD3

  Readlock [CBD1]CBD3 First
  If !fstat
      Gosub CONSO_SUG
      If [F:CBH]REOQTYCOD = 1 & WREOPOLDIS = 1 & [F:CBH]SPLCOD = 1 : Goto PROCESS_FIN : Endif
      Goto PROCESS_LOOP_PJT
  Else
      Filter [CBD1]
  Endif
Endif
# End issue 107498/15

#--------------------------------------
# gestion de l'analyse amont
$PROCESS_BWD

# si délai amont = 0, pas de recherche amont
If (XRPLBWDLTI = 0) : Goto PROCESS_FRW : Endif

# si on ne peut pas avancer, la replanification amont est inutile
If !find(XRPLUPDDAT,2,4)
    Goto PROCESS_FRW
Endif

# chargement de borne pour recherche amont
WANAMST  = [F:CBD]REQDAT
WANAMST -= XRPLBWDLTI

# boucle de parcours des suggestions amont
$LOOP_BWD

# préparation filtre de recherche amont
WFILCBD1 = "[F:CBD1]REQDAT>=WANAMST&[F:CBD1]REQDAT<=[F:CBD]REQDAT"

# Issue 93050 & 92357 GA 10/2013 ajout CUSCBD1_BWD
# recherche suggestion en amont dans l'ordre chronologique

# Issue 119203 - 2016-10-21 by STLIG : Filter resources by product and version.
If ([F:CBD]ECCVALMAJ<>"")
  FILTER_VERSION="ECCVALMAJ=[F:CBD]ECCVALMAJ & ECCVALMIN=[F:CBD]ECCVALMIN"
Else
  FILTER_VERSION="1=1"
Endif
Filter [CBD1] Where ITMREF   = [F:CBH]ITMREF   &
&                   evalue(FILTER_VERSION)     &
&                   STOFCY   = [F:CBH]STOFCY   &
&                   find(WIPTYP,2,5,7,13)      &
&                   WIPSTA   = 3               &
&                   MRPMES <> 6                &
&                   RPLFLG <> 2                &
&                   evalue(CUSCBD1_BWD)        &
&                   evalue(WFILCBD1)
&              Order By Key CBD3

Readlock [CBD1]CBD3 First
If !fstat
    Gosub CONSO_SUG
    # si réappro net + respect de la politique + pas de fractionnement, pas de replanification multiple (pas de couverture)
    If [F:CBH]REOQTYCOD = 1 & WREOPOLDIS = 1 & [F:CBH]SPLCOD = 1 : Goto PROCESS_FIN : Endif
    Goto PROCESS_LOOP_BWD
Else
    Filter [CBD1]
Endif

#--------------------------------------
# gestion de l'analyse aval
$PROCESS_FRW

# si délai aval = 0, pas de recherche aval
If (XRPLFRWLTI = 0 | WBREAKLOOP) : Goto PROCESS_FIN : Endif

# chargement de borne pour recherche aval
WANAMST  = [F:CBD]REQDAT
WANAMST += XRPLFRWLTI

# boucle de parcours des suggestions aval
$LOOP_FRW

# préparation filtre
# si on ne peut pas avancer, on inclut l'égalité en date pour assurer la couverture
# qui n'a pas été fait en recherche amont
If !find(XRPLUPDDAT,2,4)
    WFILCBD1 = "[F:CBD1]REQDAT>=[F:CBD]REQDAT&[F:CBD1]REQDAT<=WANADATF&[F:CBD1]REQDAT<=WANAMST"
Else
    WFILCBD1 = "[F:CBD1]REQDAT>[F:CBD]REQDAT&[F:CBD1]REQDAT<=WANADATF&[F:CBD1]REQDAT<=WANAMST"
Endif

# Issue 93050 & 92357 GA 10/2013 ajout CUSCBD1_FRW
# recherche suggestion en aval, chronologique

# Issue 119203 - 2016-10-21 by STLIG : Filter resources by product and version.
If ([F:CBD]ECCVALMAJ<>"")
  FILTER_VERSION="ECCVALMAJ=[F:CBD]ECCVALMAJ & ECCVALMIN=[F:CBD]ECCVALMIN"
Else
  FILTER_VERSION="1=1"
Endif
Filter [CBD1] Where ITMREF   = [F:CBH]ITMREF   &
&                   evalue(FILTER_VERSION)     &
&                   STOFCY   = [F:CBH]STOFCY   &
&                   find(WIPTYP,2,5,7,13)      &
&                   WIPSTA   = 3               &
&                   MRPMES <> 6                &
&                   RPLFLG <> 2                &
&                   evalue(CUSCBD1_FRW)        &
&                   evalue(WFILCBD1)
&             Order By Key CBD3

Readlock [CBD1]CBD3 First
If !fstat
    Gosub CONSO_SUG
    # si réappro net + respect de la politique + pas de fractionnement, pas de replanification multiple (pas de couverture)
    If [F:CBH]REOQTYCOD = 1 & WREOPOLDIS = 1 & [F:CBH]SPLCOD = 1 : Goto PROCESS_FIN : Endif
    Goto PROCESS_LOOP_FRW
Endif
Goto PROCESS_FIN

#----------------
# gestion des boucles

# Issue 107498/15
$PROCESS_LOOP_PJT
If !WBREAKLOOP : Filter [CBD1] :  WLOOP = 1 : Goto LOOP_PJT : Endif

$PROCESS_LOOP_BWD
If !WBREAKLOOP : Filter [CBD1] :  WLOOP = 1 : Goto LOOP_BWD : Endif

$PROCESS_LOOP_FRW
If !WBREAKLOOP : Filter [CBD1] :  WLOOP = 1 : Goto LOOP_FRW : Endif

# fin du traitement ressource
$PROCESS_FIN
Gosub UPD_RESS
Filter [CBD1]
Return

#--------------------------------------------------------------------------
# analyse de l'impact de la suggestion sur la replanification a effectuer
$CONSO_SUG

# ajustement qté suggestion avec écart issu de replanification précédente arrondie au lot éco
# incrémentation du total des suggestions
If [F:CBD1]REQQTY >= WADJUST
    WRPLQTY += [F:CBD1]REQQTY - WADJUST
    WADJUST = 0
    # si WRPLDAT est nulle, on analyse la replanification en date
    If WRPLDAT = [0/0/0]
        Case XRPLUPDDAT
            When 1: WRPLDAT = [F:CBD]REQDAT
            When 2: If [F:CBD1]REQDAT < [F:CBD]REQDAT : WRPLDAT = [F:CBD1]REQDAT : Endif        # avancer
            When 3: If [F:CBD1]REQDAT > [F:CBD]REQDAT : WRPLDAT = [F:CBD1]REQDAT : Endif        # retarder
            When 4: WRPLDAT = [F:CBD1]REQDAT                                                    # avancer/retarder
        Endcase
    Endif
Else
    WADJUST -= [F:CBD1]REQQTY
Endif

# si pas d'augmentation de quantité et dépassement, on a fini
If WRPLQTY >= [F:CBD]REQQTY & !find(XRPLUPDQTY,3,4) : WBREAKLOOP = 1 : Endif

# mise à jour de la suggestion
Gosub UPD_SUG
Return

#--------------------------------------------------------------------------
# suppression suggestion
$DEL_SUG
If WSIM | [F:CBD]REQDAT <= [F:CBD1]REQDAT
Call ECR_DEBUG("DEL_SUG Delete CBD1:"-[F:CBD1]ITMREF
&                   -num$([F:CBD1]REQDAT)-num$([F:CBD1]STRDAT)-num$([F:CBD1]ENDDAT)-[F:CBD1]WIPNUM)  From FUNCBN
    Delete [CBD1]
    If fstat
        GOK = 0
        Call FSTA("CBD") From GLOCK
    Endif
Else
    [F:CBD1]RPLFLG = 2
    [F:CBD1]MRPMES = 6
    # la qté suggérée ne peut être < au lot éco si qté mini (sauf si fractionnement)
    If [F:ITF]REOMINQTY<>0 & [F:CBD1]REQQTY<[F:ITF]REOMINQTY
&    & [F:CBH]SPLCOD = 1   & find([F:CBH]REOQTYCOD,2,3)
       [F:CBD1]REQQTY    = [F:ITF]REOMINQTY
       [F:CBD1]EXTQTY    = [F:CBD1]REQQTY
       [F:CBD1]RMNEXTQTY = [F:CBD1]REQQTY
    Endif

    If [F:CBH]REOQTYCOD = 3 & [F:ITF]MFGLOTQTY <> 0 & mod([F:CBD1]REQQTY,[F:ITF]MFGLOTQTY) <> 0
        S = int([F:CBD1]REQQTY/[F:ITF]MFGLOTQTY) + 1
        [F:CBD1]REQQTY = S * [F:ITF]MFGLOTQTY
        [F:CBD1]EXTQTY = [F:CBD1]REQQTY
        [F:CBD1]RMNEXTQTY = [F:CBD1]REQQTY
    Endif
Call ECR_DEBUG("DEL_SUG Rewrite CBD1:"-[F:CBD1]ITMREF
&                   -num$([F:CBD1]REQDAT)-num$([F:CBD1]STRDAT)-num$([F:CBD1]ENDDAT)-[F:CBD1]WIPNUM) From FUNCBN
    Rewrite [CBD1]
    If fstat
        GOK = 0
        Call FSTA("CBD") From GLOCK
    Endif
Endif
Return

#--------------------------------------------------------------------------
# diminution suggestion
$UPD_SUG
# si la ressource est suffisante pour couvrir cette suggestion,
# ou si on peut augmenter la ressource, on efface la suggestion
If ([F:CBD]REQQTY - WRPLQTY) >= 0 | (find(XRPLUPDQTY,3,4) & WSIM)
    Gosub DEL_SUG
    Return
Endif
# en mode messages seuls, si la ressource est insuffisante, on réduit la suggestion
# à hauteur de la quantité manquante si la ressource est antérieure ou à la màªme date
# on laisse la suggestion à sa quantité (nette) si ressource postérieure
# si on a déjà fait l'écart entre 1 sug et la ressource, on le fait pas 2 fois
If WSIM
    If WECART
        [F:CBD1]EXTQTY = WRPLQTY - [F:CBD]REQQTY
    Endif
    WECART = 0
Else
    If [F:CBD]REQDAT <= [F:CBD1]REQDAT
        If WRESSRMN > 0
            If WRESSRMN >= [F:CBD1]REQQTY
                WRESSRMN -= [F:CBD1]REQQTY
                Gosub DEL_SUG
                Return
            Else
                [F:CBD1]EXTQTY -= WRESSRMN
                WRESSRMN = 0
            Endif
        Endif
    Endif
Endif

[F:CBD1]RMNEXTQTY = [F:CBD1]EXTQTY
[F:CBD1]REQQTY = [F:CBD1]EXTQTY

If find(XRPLUPDQTY,3,4)
    [F:CBD1]RPLFLG = 2
    [F:CBD1]MRPMES = 6
    # FQ 50649 GA 11/2008 la qté suggérée ne peut être < au lot éco si qté mini (sauf si fractionnement)
    If [F:ITF]REOMINQTY<>0 & [F:CBD1]REQQTY<[F:ITF]REOMINQTY
&    & [F:CBH]SPLCOD = 1   & find([F:CBH]REOQTYCOD,2,3)
       [F:CBD1]REQQTY    = [F:ITF]REOMINQTY
       [F:CBD1]EXTQTY    = [F:CBD1]REQQTY
       [F:CBD1]RMNEXTQTY = [F:CBD1]REQQTY
    Endif

    If [F:CBH]REOQTYCOD = 3 & [F:ITF]MFGLOTQTY <> 0 & mod([F:CBD1]REQQTY,[F:ITF]MFGLOTQTY) <> 0
        S = int([F:CBD1]REQQTY/[F:ITF]MFGLOTQTY) + 1
        [F:CBD1]REQQTY = S * [F:ITF]MFGLOTQTY
        [F:CBD1]EXTQTY = [F:CBD1]REQQTY
        [F:CBD1]RMNEXTQTY = [F:CBD1]REQQTY
    Endif
Endif
# 10.06 38030 si suggestion couvrant SS, raz flag
If [F:CBD1]COVQTY > 0 : [F:CBD1]COVQTY = 0  : XSAFREC = 0 : Endif

Call ECR_DEBUG("UPD_SUG Rewrite CBD1:"-[F:CBD1]ITMREF
&                   -num$([F:CBD1]REQDAT)-num$([F:CBD1]STRDAT)-num$([F:CBD1]ENDDAT)-[F:CBD1]WIPNUM) From FUNCBN
# réécriture suggestion
Rewrite [CBD1]
If fstat
    GOK = 0
    Call FSTA("CBD") From GLOCK
Endif
Return

#--------------------------------------------------------------------------
# mise à jour ressource replanifiée
$UPD_RESS

# si pas de date de replanification, on a pas trouvé de déplacement compatible avec les
# règles, on laisse la date de la ressource telle qu'elle est ...
If WRPLDAT = [0/0/0] : WRPLDAT = [F:CBD]REQDAT : Endif

If WRPLQTY = 0
    [F:CBD]MRPMES = 6                                                               # ----- inutile
    [F:CBD]MRPQTY = 0
    [F:CBD]MRPDAT = [0/0/0]
Else
# on vérifie si la ressource est > au besoin réel
# on ajuste l'objectif par rapport au paramètre permettant la diminution des ressources
# sous le lot éco

    # si on est en mode lot éco, il faut mémoriser l'écart entre qté à couvrir et qté proposée
    # sur la ressource car si celle-ci est "gonflée", le surplus de qté doit àªtre déduit des
    # suggestions suivantes (sinon déséquilibre des autres replanifications)
    # on le fait toujours en simulation et en messages seuls seulement si qté ressource > besoin
    K = 0
    # mémorisation quantité nette à couvrir pour vérifier si gonflage
    If find([F:CBH]REOQTYCOD,2,3)
        If WSIM | (WRPLQTY < [F:CBD]REQQTY) : K = 1 : WMEMRPL = WRPLQTY : Endif
    Endif

    # si ressource suffisante voire excessive, on évalue sa diminimution suivant mode réappro
    If WRPLQTY < [F:CBD]REQQTY
        If WRESBLWLOT = 1
            If find([F:CBH]REOQTYCOD,2,3)
                If [F:CBD]REQQTY > [F:ITF]REOMINQTY
                    If [F:ITF]REOMINQTY > WRPLQTY
                        WRPLQTY = [F:ITF]REOMINQTY
                    Else
                        # llc 06.04
                        If [F:CBH]REOQTYCOD = 3 & [F:ITF]MFGLOTQTY <> 0 & mod(WRPLQTY,[F:ITF]MFGLOTQTY) <> 0
                            S = int(WRPLQTY/[F:ITF]MFGLOTQTY) + 1
                            WRPLQTY = S * [F:ITF]MFGLOTQTY
                        Endif
                    Endif
                Else
                    WRPLQTY = [F:CBD]REQQTY
                Endif
            Endif
        Else
            # si on permet la diminution sous le lot éco, on doit éventuellement arrondir suivant le
            # lot technique néanmoins (02.04)
            If [F:CBH]REOQTYCOD = 3 & [F:ITF]MFGLOTQTY <> 0 & mod(WRPLQTY,[F:ITF]MFGLOTQTY) <> 0
                S = int(WRPLQTY/[F:ITF]MFGLOTQTY) + 1
                WRPLQTY = S * [F:ITF]MFGLOTQTY
            Endif
        Endif
    Else
        # si ressource insuffisante, on évalue la quantité à replanifier suivant mode réappro
        If find([F:CBH]REOQTYCOD,2,3) & WRPLQTY > [F:CBD]REQQTY
            If WRPLQTY < [F:ITF]REOMINQTY
                WRPLQTY = [F:ITF]REOMINQTY
            Else
                # augmentation arrondie suivant lot technique (02.04)
                If [F:CBH]REOQTYCOD = 3 & [F:ITF]MFGLOTQTY <> 0 & mod(WRPLQTY,[F:ITF]MFGLOTQTY) <> 0
                    S = int(WRPLQTY/[F:ITF]MFGLOTQTY) + 1
                    WRPLQTY = S * [F:ITF]MFGLOTQTY
                Endif
            Endif
        Endif
    Endif

    # on teste si la quantité de replanification est <> car altérée par le mode lot éco
    If (find([F:CBH]REOQTYCOD,2,3) & WRPLQTY <> WMEMRPL & K) : WADJUST += WRPLQTY - WMEMRPL : Endif

    # si messages seuls et ressource > besoin, ajustement
    If !WSIM & WRPLQTY < [F:CBD]REQQTY : WADJUST += [F:CBD]REQQTY - WRPLQTY : Endif

    # si pas d'augmentation de quantité possible, pas d'ajustement nécessaire
    If !find(XRPLUPDQTY,3,4) & WRPLQTY > [F:CBD]REQQTY : WADJUST = 0 : Endif

    If [F:CBD]REQDAT = WRPLDAT
        # pas de message
        If [F:CBD]REQQTY = WRPLQTY
            Call UPDATE_MES(1, 0, [0/0/0], 0, 0)                                    # ----- pas de message
        Else
            # Augmenter ou diminuer la quantité
            If [F:CBD]REQQTY > WRPLQTY
                Call UPDATE_MES(5, WRPLQTY, WRPLDAT, XRPLUPDQTY, XRPLUPDDAT)        # ----- diminuer
            Else
                Call UPDATE_MES(4, WRPLQTY, WRPLDAT, XRPLUPDQTY, XRPLUPDDAT)        # ----- augmenter
            Endif
        Endif
    Else
        If [F:CBD]REQDAT < WRPLDAT
            If [F:CBD]REQQTY = WRPLQTY
                Call UPDATE_MES(3, WRPLQTY, WRPLDAT, XRPLUPDQTY, XRPLUPDDAT)        # ----- retarder
            Else
                If [F:CBD]REQQTY > WRPLQTY
                    Call UPDATE_MES(10, WRPLQTY, WRPLDAT, XRPLUPDQTY, XRPLUPDDAT)   # ----- retarder/diminuer
                Else
                    Call UPDATE_MES(9, WRPLQTY, WRPLDAT, XRPLUPDQTY, XRPLUPDDAT)    # ----- retarder/augmenter
                Endif
            Endif
        Else
            If [F:CBD]REQQTY = WRPLQTY
                Call UPDATE_MES(2, WRPLQTY, WRPLDAT, XRPLUPDQTY, XRPLUPDDAT)        # ----- avancer
            Else
                If [F:CBD]REQQTY > WRPLQTY
                    Call UPDATE_MES(8, WRPLQTY, WRPLDAT, XRPLUPDQTY, XRPLUPDDAT)    # ----- avancer/diminuer
                Else
                    Call UPDATE_MES(7, WRPLQTY, WRPLDAT, XRPLUPDQTY, XRPLUPDDAT)    # ----- avancer/augmenter
                Endif
            Endif
        Endif
    Endif
Endif

# si simu et au delà horizon ferme, mise à jour ressource "comme si"
If [F:CBD]REQDAT > [F:CBH]PLHENDDAT & WSIM & [F:CBD]MRPMES <> 1
    [F:CBD]REQQTY = [F:CBD]MRPQTY
    If [F:CBD]MRPDAT <> [0/0/0]
        [F:CBD]REQDAT = [F:CBD]MRPDAT
    Endif
Endif

# si simulation et date non nulle, changement potentiel de bucket
If [F:CBD]MRPDAT <> [0/0/0] & WSIM
    I = [F:CBD]MRPDAT - WCALDATD
    If I < 0          : I = 0          : Endif
    If I > WNBJOU - 1 : I = WNBJOU - 1 : Endif
    [F:CBD]BUC = WBUCNUM(I)
Endif


$END_UPD_RESS
Call ECR_DEBUG("UPD_RESS Rewrite CBD:"-[F:CBD]ITMREF-num$([F:CBD]STRDAT)-num$([F:CBD]ENDDAT)
&                                       -[F:CBD]WIPNUM-num$([F:CBD]WIPTYP))  From FUNCBN
# mise à jour
Rewrite [CBD]
If fstat
    GOK = 0
    Call FSTA("CBD") From GLOCK
Endif
Return

#--------------------------------------------------------------------------
# analyse compatibilité entre la replanification et les règles
Subprog UPDATE_MES(LMRPMES, LMRPQTY, LMRPDAT, LRPLUPDQTY, LRPLUPDDAT)
Value    Integer LMRPMES
Value    Decimal LMRPQTY
Value    Date    LMRPDAT
Value    Integer LRPLUPDQTY
Value    Integer LRPLUPDDAT

[F:CBD]MRPMES = LMRPMES
[F:CBD]MRPQTY = LMRPQTY
[F:CBD]MRPDAT = LMRPDAT

Case [F:CBD]MRPMES
    When 1:    # rien
    When 2:    If !find(LRPLUPDDAT,2,4)                            # avancer
                  [F:CBD]MRPMES = 1
                  [F:CBD]MRPQTY = 0
                  [F:CBD]MRPDAT = [0/0/0]
               Endif
    When 3:    If !find(LRPLUPDDAT,3,4)                            # retarder
                  [F:CBD]MRPMES = 1
                  [F:CBD]MRPQTY = 0
                  [F:CBD]MRPDAT = [0/0/0]
               Endif
    When 4:    If !find(LRPLUPDQTY,3,4)                            # augmenter
                  [F:CBD]MRPMES = 1
                  [F:CBD]MRPQTY = 0
                  [F:CBD]MRPDAT = [0/0/0]
               Endif
    When 5:    If !find(LRPLUPDQTY,2,4)                            # diminuer
                  [F:CBD]MRPMES = 1
                  [F:CBD]MRPQTY = 0
                  [F:CBD]MRPDAT = [0/0/0]
               Endif
    When 6:    # rien, on a toujours le droit de mettre un message "inutile"
    When 7:    If find(LRPLUPDDAT,2,4)                             # avancer/augmenter
                  If !find(LRPLUPDQTY,3,4)
                      [F:CBD]MRPMES = 2
                      [F:CBD]MRPQTY = [F:CBD]REQQTY
                  Endif
               Else
                  If !find(LRPLUPDQTY,3,4)
                      [F:CBD]MRPMES = 1
                      [F:CBD]MRPQTY = 0
                      [F:CBD]MRPDAT = [0/0/0]
                  Else
                      [F:CBD]MRPMES = 4
                      [F:CBD]MRPDAT = [F:CBD]REQDAT
                  Endif
               Endif
    When 8:    If find(LRPLUPDDAT,2,4)                             # avancer/diminuer
                  If !find(LRPLUPDQTY,2,4)
                      [F:CBD]MRPMES = 2
                      [F:CBD]MRPQTY = [F:CBD]REQQTY
                  Endif
               Else
                  If !find(LRPLUPDQTY,2,4)
                      [F:CBD]MRPMES = 1
                      [F:CBD]MRPQTY = 0
                      [F:CBD]MRPDAT = [0/0/0]
                  Else
                      [F:CBD]MRPMES = 5
                      [F:CBD]MRPDAT = [F:CBD]REQDAT
                  Endif
               Endif
    When 9:    If find(LRPLUPDDAT,3,4)                             # retarder/augmenter
                  If !find(LRPLUPDQTY,3,4)
                      [F:CBD]MRPMES = 3
                      [F:CBD]MRPQTY = [F:CBD]REQQTY
                  Endif
               Else
                  If !find(LRPLUPDQTY,3,4)
                      [F:CBD]MRPMES = 1
                      [F:CBD]MRPQTY = 0
                      [F:CBD]MRPDAT = [0/0/0]
                  Else
                      [F:CBD]MRPMES = 4
                      [F:CBD]MRPDAT = [F:CBD]REQDAT
                  Endif
               Endif
    When 10:    If find(LRPLUPDDAT,3,4)                             # retarder/diminuer
                  If !find(LRPLUPDQTY,2,4)
                      [F:CBD]MRPMES = 3
                      [F:CBD]MRPQTY = [F:CBD]REQQTY
                  Endif
               Else
                  If !find(LRPLUPDQTY,2,4)
                      [F:CBD]MRPMES = 1
                      [F:CBD]MRPQTY = 0
                      [F:CBD]MRPDAT = [0/0/0]
                  Else
                      [F:CBD]MRPMES = 5
                      [F:CBD]MRPDAT = [F:CBD]REQDAT
                  Endif
               Endif
Endcase
End

# Issue 107498/19 - Gosub $BALANCE moved to FUNCBN.src
