############################################################
# Recherche des dépassements stocks maxi
$TRT_MAXSTO
WMAXSTO = [F:ITF]MAXSTO + [F:ITF]MFGLOTQTY
WBUC = 0
WSTO = [F:CBH]STRSTO
For [CBD]CBD3 Hint Key CBD3
&            Where ITMREF = [F:CBH]ITMREF &
&                  STOFCY = [F:CBH]STOFCY
  If WBUC <> [F:CBD]BUC
    If WSTO >= WMAXSTO
       Gosub MSG_MAXSTO
    Endif
  Endif
  If find([F:CBD]WIPTYP,WTYPDEM)
    WSTO -= [F:CBD]REQQTY
  Else
    WSTO += [F:CBD]REQQTY
  Endif
  WBUC = [F:CBD]BUC
Next
If WSTO >= WMAXSTO
  Gosub MSG_MAXSTO
Endif
#Filter [CBD]
Return
############################################################
# Ecriture message surstock
$MSG_MAXSTO
Raz [F:CBD1]
[F:CBD1]       = [F:CBH]
[F:CBD1]WIPTYP = 11
[F:CBD1]WIPSTA = 3
[F:CBD1]MRPMES = 13
[F:CBD1]MRPQTY = WSTO
[F:CBD1]MRPDAT = WBUCFIN(WBUC)
[F:CBD1]BUC    = WBUC
[F:CBD1]CREDAT = date$
[F:CBD1]CREUSR = GUSER
[F:CBD1]EXPNUM = [C]EXPORT
Call ECR_DEBUG("MSG_MAXSTO Write CBD1 Itm="+[F:CBD]ITMREF-"Cpn="+[F:CBD1]ITMREF
&                   -num$([F:CBD1]REQDAT)-num$([F:CBD1]STRDAT)-num$([F:CBD1]ENDDAT)-[F:CBD1]WIPNUM) From FUNCBN
Write [CBD1]
If !find(fstat,0,3)
  GOK = 0
  Call FSTA("CBD") From GLOCK
Endif
fstat = 0
Return

############################################################
# Génération besoins matières WOS et POS et EOS
$GEN_TRACES
# Lecture entete nomenclature
# Issue 108013 - 2015-07-17 by GA : ECC for MRP fixed BOMALT can be different than MRP BOMALT
#Case [F:CBH]REOCOD
#    When 3:  Read [BOH]BOH0=[F:CBH]ITMREF;WBOMALT;2
#    When 5:  Read [BOH]BOH0=[F:CBH]ITMREF;WBOMALT;3
#    When Default: Return
#Endcase
WBOMALT=[F:CBH]BOMALT
Read [BOH]BOH0=[F:CBH]ITMREF;[F:CBH]BOMALT;[F:CBH]BOMALTTYP
If fstat = 0 & [F:BOH]USESTA = 2
  IBOM = 0
# For [CBD] With Nohint
  Filter [CBD] Where ITMREF = [F:CBH]ITMREF    &
&                    STOFCY = [F:CBH]STOFCY    &
&                    find(WIPTYP,2,5,7,13)     &
&                    WIPSTA = 3
&              Order By Key CBD3
  For [CBD]CBD3 Hint Key CBD3
    If [F:CBD]REQQTY <> 0
      Gosub GEN_UNE_TRACE
        If GOK <> 1
          Break
        Endif
        fstat = 0
    Endif
  Next
  Filter [CBD]
Endif
Return

############################################################
# Correction eventuelle des délais avec la gamme
# Génération besoins matières
$GEN_UNE_TRACE
Local Date WOPESTR : WOPESTR=[0/0/0] # FQ 77115 GA 12/2011 Début du Service
WDATGAM = 0
# Issue 110935 - 2016-04-20 by BEEBE : Deactivate EP PE_BOMDATCTL for product managed by version
Local Char WITMREF(GLONITM)

# Issue 105251 GA 04/2015 wich date to check availability of component ?
Local Integer WBOMDATCTL : WBOMDATCTL=2
Local Date    WBOMDAT

WITMREF = [F:CBD]ITMREF
If clalev([F:ITM])=0 | [F:ITM]ITMREF <> WITMREF
    Gosub READ_ITM From ITMLIB
Endif

If [F:CBD]WIPTYP = 5  & GMODU(8) = 2
  Case WFABLTI
    When 2 :
      If [F:CBD]ENDDAT < WCAPDATF
        Gosub TRT_JAL
      Endif
    When 3 :
      Gosub TRT_JAL
  Endcase
  # Issue 105251 GA 04/2015 Use EP in MFGAUTLIB
  If dim([F:ITM]ECCFLG)<=0 | [F:ITM]ECCFLG<>2
      Gosub PE_BOMDATCTL From MFGAUTLIB
  Endif

# Issue 83727 GA 09/2012 - Raz Issue 80128 Ko
Elsif [F:CBD]WIPTYP = 13 # FQ 77115 GA 12/2011 Début du Service
#  Readlock [F:CBD] Curr
#  If !fstat
     Gosub TRT_DATSCS
#     Rewrite [F:CBD]
#  Endif
  # Issue 105251 GA 04/2015 Use EP in SCOAUTLIB
  If dim([F:ITM]ECCFLG)<=0 | [F:ITM]ECCFLG<>2
      Gosub PE_BOMDATCTL From SCOAUTLIB
  Endif
Endif
# End issue 110935
WDAT = [F:CBD]REQDAT
WBES = [F:CBD]REQQTY
# Issue 98638 GA 07/2014 Variable to modify in entry point
Local Integer WSCOBOMOFS : WSCOBOMOFS=2

# FQ 75650 GA 09/2011 Permettre de changer d'alternative de nomenclature selon qté à produire/date/...
GPE=0 : GPOINT="CTLBOMALT" : Gosub ENTREE From EXEFNC
If IBOM <= 0 & GPE=0

    # Issue 114658 - 2016-03-22 by CCC
    # 1- Get validity period of all versions available (with derogation) between WCALDATD and WCALDATF
    If clalev([F:EVL])=0 : Local File ECCVAL [EVL] : Endif
    If WECCFLG & [F:CBD]ECCVALMAJ<>""
        Raz I, WECCAVA, WECCSTR, WECCEND, WECCSTRMIN, WECCENDMAX, WEXNDAT
        For [EVL] Where ITMREF    = [F:CBD]ITMREF
&                     & BOMALT    = [F:CBH]BOMALT
&                     & ECCTYP    = [F:CBH]BOMALTTYP
&                     & STRDAT <= WCALDATF
&                     & ( ENDDAT = [0/0/0]
&                       | ENDDAT >= WCALDATD
&                       | EXNFLG = 2 & (EXNDAT=[0/0/0] | EXNDAT>=WCALDATD)
&                       )
            WECCAVA(I) = [F:EVL]ECCVALMAJ-[F:EVL]ECCVALMIN
            WECCSTR(I) = [F:EVL]STRDAT
            If [F:EVL]ENDDAT=[0/0/0]
                WECCEND(I) = [31/12/2199]
            Else
                WECCEND(I) = [F:EVL]ENDDAT
            Endif

            If WECCSTRMIN=[0/0/0]
                WECCSTRMIN = [F:EVL]STRDAT
            Else
                WECCSTRMIN = min(WECCSTRMIN,[F:EVL]STRDAT)
            Endif
            WECCENDMAX = max(WECCENDMAX,WECCEND(I))

            If [F:EVL]EXNFLG=2
                If [F:EVL]EXNDAT=[0/0/0]
                    WEXNDAT(I) = [31/12/2199]
                Else
                    WEXNDAT(I) = [F:EVL]EXNDAT
                Endif
            Endif
            I+=1
        Next
    Endif

#Lecture liens
  Filter  [BOD] Where ITMREF    = [F:CBD]ITMREF    &
&                     BOMALT    = [F:CBH]BOMALT    &
&                     BOMALTTYP = [F:CBH]BOMALTTYP &
&                     find(CPNTYP,5,6)=0           &
&                     SCOFLG <> 3
&               Order By Key BOD0
  For [BOD]
    If [F:BOD]BOMSTRDAT = [0/0/0]
       [F:BOD]BOMSTRDAT = WCALDATD
    Endif
    If [F:BOD]BOMENDDAT = [0/0/0]
       [F:BOD]BOMENDDAT = WCALDATF
    Endif
# Issue 105251 GA 04/2015 use start date instead of [F:CBD]REQDAT to check availability of component
# Check validity date of the link
#    If WDAT < [F:BOD]BOMSTRDAT | WDAT > [F:BOD]BOMENDDAT
#      Goto GEN_UNE_TRACE1
#    Endif

# 113215 mm 02.2016
 WMSG=""
# Lecture article composant
    Read [ITM1]ITM0=[F:BOD]CPNITMREF
    If fstat
      # 113215 mm 02.2016
      If WMSG=""
        WMSG = [F:BOD]CPNITMREF-mess(297,199,1)
      Endif
    Endif
# Lecture entete composant et controle code plus bas niveau
    Read [CBH1]CBH0=WFCY;[F:BOD]CPNITMREF
    If fstat
      If [F:ITM1]ITMSTA > 3
        # 113215 mm 02.2016
        If WMSG=""
          WMSG = WFCY-[F:BOD]CPNITMREF-mess(327,199,1)-mess([F:ITM1]ITMSTA,246,1)
        Endif
      Endif
      If ([F:ITM1]LIFSTRDAT <> [0/0/0] & [F:ITM1]LIFSTRDAT > WCALDATF) |
&        ([F:ITM1]LIFENDDAT <> [0/0/0] & [F:ITM1]LIFENDDAT < WCALDATD)
        # 113215 mm 02.2016
        If WMSG=""
          WMSG = WFCY-[F:BOD]CPNITMREF-mess(328,199,1)
        Endif
      Endif
      # 113215 mm 02.2016
      If WMSG=""
        WMSG = WFCY-[F:BOD]CPNITMREF-mess(326,199,1)
      Endif
    Endif
    # Issue 104223 - 2015-03-27 by CCC : LLC cheking is not necessary for by-products
    #If fstat = 0 & [F:CBH1]LLC <= [F:CBH]LLC
    If fstat = 0 & [F:BOD]CPNTYP<>4 & [F:CBH1]LLC <= [F:CBH]LLC
      # 113215 mm 02.2016
      If WMSG=""
        WMSG = WFCY-[F:BOD]CPNITMREF-mess(252,199,1)
      Endif
    Endif
    Raz [F:CBD1]
    [F:CBD1] = [F:CBD]
    Call NUMERO(GSUG,WFCY,WCALDATD,"",[F:CBD1]WIPNUM,WRET) From SUBANM
    If WRET <> 0
      Call ECR_TRACE(mess(66,187,1),1) From GESECRAN
      GOK = 0
      Break
    Endif

    Case [F:CBD]WIPTYP
        When 5:    Case [F:BOD]CPNTYP
                       When 4       :     [F:CBD1]WIPTYP    = 9
                       When Default :     [F:CBD1]WIPTYP    = 6
                   Endcase
        When 13:   Case [F:BOD]CPNTYP
                       When 7       :     [F:CBD1]WIPTYP    = 4
                       When Default :     [F:CBD1]WIPTYP    = 3
                   Endcase
    Endcase

    Call LIKQTY(WBES,[F:ITM1]STU,[F:BOH]BASQTY,[F:BOD]LIKQTYCOD,[F:BOD]LIKQTY,
&             [F:BOD]QTYRND,[F:BOD]SCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
    [F:CBD1]ITMREF    = [F:BOD]CPNITMREF
    [F:CBD1]ECCVALMAJ = [F:BOD]ECCVALMAJ            # Issue 114658 - 2016-03-31 by CCC : get the right version of the component
    [F:CBD1]ECCVALMIN = [F:BOD]ECCVALMIN            # Issue 114658 - 2016-03-31 by CCC : get the right version of the component
    [F:CBD1]BOMOPE    = [F:BOD]CPNOPE
    [F:CBD1]BOMOFS    = [F:BOD]BOMOFS                # 02.06 35076
    If WSHRFLG = 2
      [F:CBD1]EXTQTY    = WQTYNA
      [F:CBD1]RMNEXTQTY = WQTYNA
      [F:CBD1]REQQTY    = WQTYNA
    Else
      [F:CBD1]EXTQTY    = WQTYBA
      [F:CBD1]RMNEXTQTY = WQTYBA
      [F:CBD1]REQQTY    = WQTYBA
    Endif
# Calcul dates début fin et besoin
    # Issue 84659 - 2012-11-29 by CCC : Si l'opération n'est pas dans le calcul du jalonnement
    #If WDATGAM <> 0 & [F:BOD]CPNOPE <> 0
    If WDATGAM <> 0 & [F:BOD]CPNOPE <> 0 & find([F:BOD]CPNOPE,[M:JALK]OPENUM)<>0
      O = 0
      While [M:JALK]OPENUM(O) <> 0
        If [M:JALK]OPENUM(O) = [F:BOD]CPNOPE
          WDATR = [M:JALK]OPESTRDAT(O)
          Break
        Else
          O += 1
        Endif
      Wend
    Elsif [F:BOD]CPNTYP=7      # FQ 77115 GA 11/2011
      WDATR = WOPESTR
    Else
     # FQ 77115 GA 11/2011 Case [F:CBD]WIPTYP supprimé, les MSS doivent être traitées comme MWS
      If WDATGAM=2
         WDATR = WOPESTR
      Else
         WDATR = [F:CBD]STRDAT
      Endif
      WCOR  = 8
      Case [F:CBD1]WIPTYP       # Issue 98638 GA 07/2014
        When 6       :   WCOD  = 2    # 2=jours ouvrés (avec correction calendrier)
        When 3       :
         If WSCOBOMOFS=2 WCOD  = 1    # 1=jours calendaires, sauf si WSCOBOMOFS<>2
         Else            WCOD  = 2 Endif
        When Default :   WCOD  = 2    # 2=jours ouvrés (avec correction calendrier)
      Endcase
      WDEL  = [F:BOD]BOMOFS
      If WDEL > 0
         Call CALDAT("+",WCOR,WDATR,WCOD,WDEL,WCAP,WCALDATD,WDATR) From CBNLIB
      Else
         WDEL = [F:BOD]BOMOFS * -1
         Call CALDAT("-",WCOR,WDATR,WCOD,WDEL,WCAP,WCALDATD,WDATR) From CBNLIB
      Endif
    Endif
    If WDATR < WCALDATD
      If [F:CBD1]BOMOPE=0  # Issue 95981 GA 03/2014 except when [F:BOD]CPNOPE <> 0
         WDATR = WCALDATD
      Endif
      [F:CBD1]MRPMES = 11
    Else
      [F:CBD1]MRPMES = 1
    Endif
     # 11.04 26248
    If WDATR > [F:CBD]STRDAT & [F:CBD]MRPMES = 11
        If [F:CBD1]BOMOPE=0  # Issue 83204 GA 02/2013 except when [F:BOD]CPNOPE <> 0
           WDATR = [F:CBD]STRDAT
           If WDATR < WCALDATD : WDATR = WCALDATD : Endif                # 03.05 28900
        Endif
        [F:CBD1]MRPMES = 11
    Endif

    [F:CBD1]STRDAT    = WDATR
    # FQ 77115 GA 12/2011 # FQ 66321 GA 09/2010
    If !find([F:CBD1]WIPTYP,9,4) # sauf si sous-produit BWS ou Service SCS, garder date fin
       [F:CBD1]ENDDAT = WDATR
       [F:CBD1]REQDAT = WDATR
    Endif
    I = WDATR-WCALDATD
    If I < 0          : I = 0          : Endif
    If I > WNBJOU - 1 : I = WNBJOU - 1 : Endif
    [F:CBD1]BUC = WBUCNUM(I)
    If [F:CBH]PHAFLG <> 2 & [F:CBD]TRCFLG <> 2
      [F:CBD1]WIPTYPORI = [F:CBD]WIPTYP
      [F:CBD1]WIPSTAORI = [F:CBD]WIPSTA
      [F:CBD1]WIPNUMORI = [F:CBD]WIPNUM
      [F:CBD1]WIPLINORI = 0
      [F:CBD1]WIPSEQORI = 0
      [F:CBD1]PJT       = ""
      [F:CBD1]BPRNUM    = ""
    Endif
    If [F:ITM1]STDFLG = 4 : [F:CBD1]TRCFLG = 2 : Endif
    [F:CBD1]SUGTYP    = [F:CBD]WIPTYP
    [F:CBD1]SUGNUM    = [F:CBD]WIPNUM
    [F:CBD1]SUGSTA    = [F:CBD]WIPSTA
    [F:CBD1]ITMREFORI = [F:CBD]ITMREF
    # FQ 75650 GA 09/2011 Permettre de changer d'alternative de nomenclature
    If dim([F:CBD1]BOMALT)>0
       [F:CBD1]BOMALT    = [F:BOD]BOMALT
       [F:CBD1]BOMALTTYP = [F:BOD]BOMALTTYP
    Endif
    [F:CBD1]CREUSR    = GUSER
    [F:CBD1]CREDAT    = date$
    [F:CBD1]EXPNUM    = [C]EXPORT

# Issue 105251 GA 04/2015 use start date instead of [F:CBD]REQDAT to check availability of component
# Check validity date of the link
    Case WBOMDATCTL
      When 1 : WBOMDAT=WDAT            # this correspond to [F:CBD]REQDAT: used until V6lp31
      When 2 : WBOMDAT=[F:CBD1]STRDAT  # new mode
    Endcase

    # Issue 114658 - 2016-03-21 by CCC
    # 2- If [cbd]eccvalmaj<>"" then :
    If WECCFLG & [F:CBD]ECCVALMAJ<>""
    #       - if the validity period of the product is completely outside of all available versions => skip it
        I=find([F:CBD]ECCVALMAJ-[F:CBD]ECCVALMIN,WECCAVA)-1
        If I<0 | ([F:BOD]BOMENDDAT < WECCSTRMIN | [F:BOD]BOMSTRDAT > WECCENDMAX)
            Goto GEN_UNE_TRACE2
        Endif
    #       - if start date is outside of validity period, replace WBOMDAT with the closer one (especially for derogation time)
        If WBOMDAT>WECCEND(I) : WBOMDAT = WECCEND(I) : Endif
        If WBOMDAT<WECCSTR(I) : WBOMDAT = WECCSTR(I) : Endif
    Endif

    If WBOMDAT >= [F:BOD]BOMSTRDAT & WBOMDAT <= [F:BOD]BOMENDDAT
        # 113215 mm 02.2016- display message only if BOM link is valid
        If WMSG<>""
          Call ECR_TRACE(WMSG,1) From GESECRAN
          Goto GEN_UNE_TRACE2
        Endif
        # ---- Point d'entrée
        GPE=0 : GPOINT = "MRPWRITRC" : Gosub ENTREE From EXEFNC
        If GPE=0
# Issue 114658 - 2016-03-31 by CCC : get the right version of the component at the same time than component code
#          If WECCFLG & [F:ITM1]ECCFLG>1  # Issue 108013 - 07/2015 by GA : version for MRP
#             [F:CBD1]ECCVALMAJ = [F:BOD]ECCVALMAJ
#             [F:CBD1]ECCVALMIN = [F:BOD]ECCVALMIN
#          Endif
        # ----
          Call ECR_DEBUG("GEN_UNE_TRACE Write CBD1 (A1) Itm="+[F:CBD1]ITMREF-"CpnTyp"+num$([F:BOD]CPNTYP)-"WipTyp="+num$([F:CBD1]WIPTYP)
&                            -num$([F:CBD1]REQDAT)-num$([F:CBD1]STRDAT)-num$([F:CBD1]ENDDAT)-[F:CBD1]WIPNUM
&                            -"Qty="+num$([F:CBD1]EXTQTY)-"Date gamme"+num$(WDATGAM)) From FUNCBN
          Write [CBD1]
          If fstat
            GOK = 0
            Call FSTA("CBD") From GLOCK
            Break
          Endif
        Endif
    Endif
# Chargement des tableaux données liens
#$GEN_UNE_TRACE1
    If IBOM < WBOM & IBOM <> -1
      WCMP(IBOM)      = [F:BOD]CPNITMREF
      WCPNTYP(IBOM)   = [F:BOD]CPNTYP
      WSTU(IBOM)      = [F:ITM1]STU
      WDTED(IBOM)     = [F:BOD]BOMSTRDAT
      WDTEF(IBOM)     = [F:BOD]BOMENDDAT
      WOFS(IBOM)      = [F:BOD]BOMOFS
      WQTYC(IBOM)     = [F:BOD]LIKQTYCOD
      WQTYL(IBOM)     = [F:BOD]LIKQTY
      WRND(IBOM)      = [F:BOD]QTYRND
      WSCA(IBOM)      = [F:BOD]SCA
      WOPE(IBOM)      = [F:BOD]CPNOPE
      WTRC(IBOM)      = [F:CBD1]TRCFLG
      If WECCFLG   # Issue 108013 - 07/2015 by GA : version for MRP
        WCMPEVLMAJ(IBOM)= [F:CBD1]ECCVALMAJ
        WCMPEVLMIN(IBOM)= [F:CBD1]ECCVALMIN
      Endif
      IBOM += 1
    Else
      IBOM = -1
    Endif
$GEN_UNE_TRACE2
  fstat = 0
  Next
  Filter [BOD]
Else
  For J = 0 To IBOM-1
# Issue 105251 GA 04/2015 use start date instead of [F:CBD]REQDAT to check availability of component
# Check validity date of the link
#    If WDAT >= WDTED(J) & WDAT <= WDTEF(J)
      Raz [F:CBD1]
      [F:CBD1] = [F:CBD]
      Call NUMERO(GSUG,WFCY,WCALDATD,"",[F:CBD1]WIPNUM,WRET) From SUBANM
      If WRET <> 0
          Call ECR_TRACE(mess(66,187,1),1) From GESECRAN
          GOK = 0
          Break
      Endif
      # llc 05.00 sous-produit
      Case [F:CBD]WIPTYP
          When 5:    Case WCPNTYP(J)
                         When 4       :     [F:CBD1]WIPTYP    = 9
                         When Default :     [F:CBD1]WIPTYP    = 6
                     Endcase
          When 13:   Case WCPNTYP(J)
                         When 7       :     [F:CBD1]WIPTYP    = 4
                         When Default :     [F:CBD1]WIPTYP    = 3
                     Endcase
      Endcase

      Call LIKQTY(WBES,WSTU(J),[F:BOH]BASQTY,WQTYC(J),WQTYL(J),WRND(J),WSCA(J),
&                 WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
      [F:CBD1]ITMREF    = WCMP(J)
      If WECCFLG   # Issue 118951 GH 07/10/16 - crashed for a folder with no versioning
         [F:CBD1]ECCVALMAJ = WCMPEVLMAJ(J) # Issue 114658 - 2016-03-31 by CCC : get the right version of the component
         [F:CBD1]ECCVALMIN = WCMPEVLMIN(J) # Issue 114658 - 2016-03-31 by CCC : get the right version of the component
      Endif
      [F:CBD1]BOMOPE    = WOPE(J)
      [F:CBD1]BOMOFS    = WOFS(J)
      If WSHRFLG = 2
        [F:CBD1]EXTQTY    = WQTYNA
        [F:CBD1]RMNEXTQTY = WQTYNA
        [F:CBD1]REQQTY    = WQTYNA
      Else
        [F:CBD1]EXTQTY    = WQTYBA
        [F:CBD1]RMNEXTQTY = WQTYBA
        [F:CBD1]REQQTY    = WQTYBA
      Endif
   # Calcul dates début fin et besoin
      # Isssue 95981 GA 02/2014 # Issue 83204 GA 02/2013 LLC/EXA
      #If WDATGAM <> 0 & [F:BOD]CPNOPE <> 0 & find([F:BOD]CPNOPE,[M:JALK]OPENUM)>0
      If WDATGAM <> 0 & [F:CBD1]BOMOPE <> 0 & find([F:CBD1]BOMOPE,[M:JALK]OPENUM)<>0
        O = 0
        While [M:JALK]OPENUM(O) <> 0
          If [M:JALK]OPENUM(O) = [F:CBD1]BOMOPE # # Isssue 95981 GA 03/2014 [F:BOD]CPNOPE
            WDATR = [M:JALK]OPESTRDAT(O)
            Break
          Else
            O += 1
          Endif
        Wend
      Elsif WCPNTYP(J)=7  # FQ 77115 GA 12/2011 cas particulier du Service EOS
        WDATR = [F:CBD]ENDDAT
        WCOR  = 8
        WCOD  = 1   # 1=délai achat en jours calendaires, 2=délai fab en jours ouvrés (???)
        WDEL  = WOFS(J)
        Call CALDAT("-",WCOR,WDATR,WCOD,WDEL,WCAP,WCALDATD,WDATR) From CBNLIB
        If [F:CBD]STRDAT > WDATR
           [F:CBD]STRDAT = WDATR
        Endif
      Else
        WDATR = [F:CBD]STRDAT
        WCOR  = 8
        WCOD  = 2    # Issue 80806 GA 16/04/2012 BOMOFS en jours ouvrés (avant: 1)
        WDEL  = WOFS(J)
        If WDEL > 0
           Call CALDAT("+",WCOR,WDATR,WCOD,WDEL,WCAP,WCALDATD,WDATR) From CBNLIB
        Else
           WDEL = WOFS(J) * -1
           Call CALDAT("-",WCOR,WDATR,WCOD,WDEL,WCAP,WCALDATD,WDATR) From CBNLIB
        Endif
      Endif
      If WDATR < WCALDATD
        WDATR = WCALDATD
        [F:CBD1]MRPMES = 11
      Else
        [F:CBD1]MRPMES = 1
      Endif
      If WDATR > [F:CBD]STRDAT & [F:CBD]MRPMES = 11
          If [F:CBD1]BOMOPE=0  # Issue 95981 GA 03/2014 except when [F:BOD]CPNOPE <> 0
             WDATR = [F:CBD]STRDAT
             If WDATR < WCALDATD : WDATR = WCALDATD : Endif                # 03.05 28900
          Endif
          [F:CBD1]MRPMES = 11
      Endif
      [F:CBD1]STRDAT    = WDATR
      # FQ 77115 GA 12/2011 # FQ 66321 GA 09/2010
      If !find([F:CBD1]WIPTYP,9,4) # sauf si sous-produit BWS ou Service SCS, garder date fin
         [F:CBD1]ENDDAT = WDATR
         [F:CBD1]REQDAT = WDATR
      Endif
      I = WDATR-WCALDATD
      If I < 0          : I = 0          : Endif
      If I > WNBJOU - 1 : I = WNBJOU - 1 : Endif
      [F:CBD1]BUC = WBUCNUM(I)
      If [F:CBH]PHAFLG <> 2 & [F:CBD]TRCFLG <> 2
        [F:CBD1]WIPTYPORI = [F:CBD]WIPTYP
        [F:CBD1]WIPSTAORI = [F:CBD]WIPSTA
        [F:CBD1]WIPNUMORI = [F:CBD]WIPNUM
        [F:CBD1]WIPLINORI = 0
        [F:CBD1]WIPSEQORI = 0
        [F:CBD1]PJT       = ""
        [F:CBD1]BPRNUM    = ""
      Endif
      [F:CBD1]TRCFLG    = WTRC(J)
      [F:CBD1]SUGTYP    = [F:CBD]WIPTYP
      [F:CBD1]SUGNUM    = [F:CBD]WIPNUM
      [F:CBD1]SUGSTA    = [F:CBD]WIPSTA
      [F:CBD1]ITMREFORI = [F:CBD]ITMREF
      [F:CBD1]CREUSR    = GUSER
      [F:CBD1]CREDAT    = date$

  # Issue 105251 GA 04/2015 use start date instead of [F:CBD]REQDAT to check availability of component
  # Check validity date of the link
      Case WBOMDATCTL
        When 1 : WBOMDAT=WDAT            # this correspond to [F:CBD]REQDAT: used until V6lp31
        When 2 : WBOMDAT=[F:CBD1]STRDAT  # new mode
      Endcase

      # Issue 114658 - 2016-03-21 by CCC
      # If [cbd]eccvalmaj<>"" then compare :
      If WECCFLG & [F:CBD]ECCVALMAJ<>""
    #       - if the validity period of the product is completely outside of all available versions => skip it
          I=find([F:CBD]ECCVALMAJ-[F:CBD]ECCVALMIN,WECCAVA)-1
          If I<0
              Break
          Endif
    #       - if start date is outside of validity period, replace WBOMDAT with the closer one (especially for derogation time)
          If WBOMDAT>WECCEND(I) : WBOMDAT = WECCEND(I) : Endif
          If WBOMDAT<WECCSTR(I) : WBOMDAT = WECCSTR(I) : Endif
      Endif

      If WBOMDAT >= WDTED(J) & WBOMDAT <= WDTEF(J)
        # ---- Point d'entrée
        GPE=0 : GPOINT = "MRPWRITRC" : Gosub ENTREE From EXEFNC
        If GPE=0
# Issue 114658 - 2016-03-31 by CCC : get the right version of the component at the same time than component code
#          If WECCFLG   # Issue 108013 - 07/2015 by GA : version for MRP
#             [F:CBD1]ECCVALMAJ = WCMPEVLMAJ(J)
#             [F:CBD1]ECCVALMIN = WCMPEVLMIN(J)
#          Endif
        # ----
          Call ECR_DEBUG("GEN_UNE_TRACE Write CBD1 (B) Itm="+[F:CBD]ITMREF-"CpnTyp"+num$(WCPNTYP(J))-"Cpn="+[F:CBD1]ITMREF-"BOMOFS="+num$([F:CBD1]BOMOFS)
&                            -num$([F:CBD1]REQDAT)-num$([F:CBD1]STRDAT)-num$([F:CBD1]ENDDAT)-num$([F:CBD1]EXTQTY)) From FUNCBN

          Write [CBD1]
          If fstat
            GOK = 0
            Call FSTA("CBD") From GLOCK
            Break
          Endif
        Endif
      Endif
  Next J
Endif
Return
############################################################
$TRT_JAL
Raz [M:OPSS]
[M:OPSS] = [F:CBD]
[M:OPSS]CODMAJ   = 2
If WPRO = 1
  [M:OPSS]OPSTYP = 2
Else
  [M:OPSS]OPSTYP = 1
Endif
[M:OPSS]OPSSTA = 3
[M:OPSS]PLNFCY = WFCY
[M:OPSS]MFGFCY = WFCY
[M:OPSS]BOMALT = WBOMALT

If GLATSUGDAT = 2 & [F:CBH]PLHENDDAT > WCALDATD & WPLHDAT <> 2
    WCOR = 8
    WCOD = 2
    WDEL = 1
    Call CALDAT("+",WCOR,[F:CBH]PLHENDDAT,WCOD,WDEL,WCAP,WCALDATS,[M:OPSS]TRTDAT) From CBNLIB
Else
    [M:OPSS]TRTDAT = WCALDATD
Endif
[M:OPSS]STRDAT = [M:OPSS]ENDDAT
[M:OPSS]EXTQTY = [F:CBD]REQQTY

# ---- Point d'entrée
GPOINT = "MRPSCHDAT" : Gosub ENTREE From EXEFNC
# ----

Call GEN_LOA_SUG From CBNLIBO
#
If [M:OPSS]CODRET = 0
   WDATGAM = 1
   If [M:JALK]ENDDAT = [F:CBD]ENDDAT
      [F:CBD]STRDAT = [M:JALK]STRDAT
      # Issue 104765 GA 01/2015
      If [F:CBD]MRPMES = 11 & [F:CBD]ENDDAT<=[F:CBD]REQDAT : [F:CBD]MRPMES = 1 : Endif
   Elsif [M:JALK]ENDDAT < [F:CBD]ENDDAT   # Issue 105987 GA 02/2015
      [F:CBD]STRDAT = [M:JALK]STRDAT
      [F:CBD]ENDDAT = [M:JALK]ENDDAT
      If [F:CBD]MRPMES = 11 & [F:CBD]ENDDAT<=[F:CBD]REQDAT : [F:CBD]MRPMES = 1 : Endif
   Else
      [F:CBD]MRPMES = 11
   Endif

   # Issue 111414 - 2016-01-20 by CCC : If scheduling failed because of route version -> mrpmes=14
    If [M:JALK]CODRET=2
        [F:CBD]MRPMES=14
    Endif

    # Issue 94841 GA 12/2013 ---- Point d'entrée
    GPE=0 : GPOINT = "BEFREWCBD" : Gosub ENTREE From EXEFNC
    If !GPE
       Call ECR_DEBUG("TRT_JAL Rewrite CBD:"-[F:CBD]ITMREF-num$([F:CBD]WIPTYP)-[F:CBD]WIPNUM
&                    -"\Date CBN        "-num$([F:CBD]STRDAT)-"<=>"-num$([F:CBD]ENDDAT)
&                    -"\Date jalonnement"-num$([M:JALK]STRDAT)-"<=>"-num$([M:JALK]ENDDAT)-num$([F:CBD]MRPMES))  From FUNCBN

       Rewrite [CBD]
       If fstat
          GOK = 0
          Call FSTA("CBD") From GLOCK
        Endif
    Endif
Endif
Return

############################################################
# Mise à jour table ORDERS
$MAJ_ORDERS
# Selection selon mode réapro MPS / MRP
If WPRO = 1
  Filter [CBH] Where STOFCY    = WFCY &
&                    REOMGTCOD = 3
&              Order By Key CBH0
Else
  Filter [CBH] Where STOFCY    = WFCY &
&                    REOMGTCOD = 2
&              Order By Key CBH0
Endif
#
GOK  = 1
WTRT = 0
Trbegin [ORD]
For [CBH]
  WPHAENC = mess(7,744,1)-[F:CBH]ITMREF-[F:CBH]ITMDES1
  GOK = 1
  Gosub MAJ_ITMORD
  If GOK <> 1
    Rollback
    Break
  Else
    If WTRT > WTRTMAX
      Commit
      Trbegin [ORD]
      WTRT = 0
    Else
      WTRT += 1
    Endif
  Endif
  fstat = 0
Next
Filter [CBH]
If GOK = 1
  Commit
Endif
Return

###########################################################
$MAJ_ITMORD

Filter [CBD] Where STOFCY = WFCY          &
&                  ITMREF = [F:CBH]ITMREF &
&                  !find(WIPTYP,3,4,6)
&            Order By Key CBD3
For [CBD]CBD3 Hint Key CBD3
  #en V5: If [F:CBD]WIPTYP = 2 & [F:CBD]WIPSTA = 3 & find([F:CBH]SUGTYP,2,3,4)
  If find([F:CBD]WIPTYP,2,5,7,13) & [F:CBD]WIPSTA = 3 & find([F:CBH]SUGTYP,2,3,4)
    Gosub CRE_SUGORD
      If GOK <> 1
        Break
      Endif
  Endif
  If [F:CBD]MRPMES <> 1
    Readlock [ORD]ORD0=[F:CBD]WIPTYP;[F:CBD]WIPNUM;[F:CBD]ITMREF
    If fstat = 0
      [F:ORD]MRPMES = [F:CBD]MRPMES
      # si ressource en cours, il faut tenir compte du réalisé (car la replanification raisonne sur le restant)
      [F:ORD]MRPQTY = [F:CBD]MRPQTY + [F:ORD]CPLQTY
      [F:ORD]MRPDAT = [F:CBD]MRPDAT

      # Issue 105987 GA 02/2015 when the suggestion is not late
      #If [F:ORD]MRPMES = 11 & find([F:ORD]WIPTYP, WTYPSUG) : [F:ORD]MRPDAT = [F:CBD]REQDAT : Endif

      # Issue X3-38625 - 2017-09-07 by STLIG : Apply test (end date + lead time > required date) to
      #                                        purchase order and sub-contract suggestion..
      If [F:ORD]MRPMES = 11 & find([F:ORD]WIPTYP, 2,5,13)
         If [F:ORD]ENDDAT > [F:CBD]REQDAT
            [F:ORD]MRPDAT = [F:CBD]REQDAT
         Else
            [F:ORD]MRPMES = 1

            # Issue X3-38625 - 2017-09-07 by STLIG : ORDERS message changed, change CBNDET message..
            Readlock [CBD1]CBD0=[F:CBD]STOFCY;[F:CBD]ITMREF;[F:CBD]BUC;[F:CBD]REQDAT;[F:CBD]WIPTYP;[F:CBD]WIPNUM
            If (fstat=0)
              [F:CBD1]MRPMES = 1
              Rewrite [CBD1]
            Endif

         Endif
      Endif

      [F:ORD]UPDDAT = date$
      [F:ORD]UPDUSR = GUSER
      [F:ORD]EXPNUM = [C]EXPORT
      Rewrite [ORD]
      If fstat
        GOK = 0
        Call FSTA("ORD") From GLOCK
        Break
      Endif
    Endif
  Endif
Next
$MAJ_ITMORD_FIN
Filter [CBD]
Return

############################################################
# Generation selon parametre suggestions et traces
$CRE_SUGORD
Local Date WDATCAL

# 107310(55934) product-site supplier
Local Integer ITMBPS

If [F:CBH]REOCOD <> 1 & [F:CBD]REQQTY <> 0
# génération des traces si fabriqué/sous-traité
  If find([F:CBH]REOCOD,3,5) & GOK = 1 & find([F:CBH]SUGTYP,2,4)
    Gosub CRE_MXSORD
  Endif

  Raz [F:ORD]
  [F:ORD] = [F:CBD]
  Case [F:CBH]REOCOD
    When 2:         # Achat
      [F:ORD]WIPTYP = 2
      [F:ORD]ORIFCY = WFCY
      [F:ORD]STOFCY = WFCY
#      Raz [F:ORD]BPRNUM    # FQ 55168 GA 05/2009 sinon BPRNUM contient parfois le code du client SOF
      If [F:ORD]BPRNUM = ""
        # 107310(55934) product-site supplier
        Call DEFBPSNUM([F:CBD]ITMREF,"",WFCY,"",1,[F:ORD]BPRNUM,ITMBPS) From TRTACHDEF1
      Endif
    When 3:        # Fabrication
      [F:ORD]WIPTYP = 5
      [F:ORD]ORIFCY = WFCY
      [F:ORD]STOFCY = WFCY
    When 4:         # Transfert inter-site
      [F:ORD]WIPTYP = 8
      [F:ORD]ORIFCY = WFCY
      [F:ORD]STOFCY = [F:CBH]REOFCY
      If [F:ORD]BPRNUM = "" & [F:CBH]REOFCY<>""  # Issue 97355 GA 03/2014 fournisseur intersite
          Filter [BPR] Where FCY=[F:CBH]REOFCY & BETFCY=2 & BPSFLG=2
          For [BPR]
              [F:ORD]BPRNUM = [F:BPR]BPRNUM : Break
          Next
          Filter [BPR]
      Endif
    When 5 :        # Sous-traitance
      [F:ORD]WIPTYP = 13
      [F:ORD]ORIFCY = WFCY
      [F:ORD]STOFCY = WFCY
      WCOD = 0

      # 107310(55934) product-site supplier
      Call FIND_BPRNUM ([F:CBD]ITMREF,WBOMALT,"",WFCY,[F:ORD]BPRNUM) From SCOLIB

  Endcase
# Issue 108013 - 2015-06-19 by GA : product/BOM with version
  If WECCFLG & [F:CBD]ECCVALMAJ<>""
    [F:ORD]ECCVALMAJ = [F:CBD]ECCVALMAJ
    [F:ORD]ECCVALMIN = [F:CBD]ECCVALMIN
  Endif
# Suggestion ecrite avec quantité nulle si "trace seule"
  If [F:CBH]SUGTYP = 4
    [F:ORD]EXTQTY    = 0
    [F:ORD]RMNEXTQTY = 0
  Else
    [F:ORD]EXTQTY    = [F:CBD]REQQTY
    [F:ORD]RMNEXTQTY = [F:CBD]REQQTY
  Endif
  [F:ORD]FMI       = 1
  If dim([F:CBD]BOMALT)>0   # FQ 75650 GA 09/2011 Permettre de changer d'alternative de nomenclature
    [F:ORD]BOMALT    = [F:CBD]BOMALT
    [F:ORD]BOMALTTYP = [F:CBD]BOMALTTYP
  Else
    [F:ORD]BOMALT    = [F:CBH]BOMALT
    [F:ORD]BOMALTTYP = [F:CBH]BOMALTTYP
  Endif

  Case WPRO
      When 1:    [F:ORD]ORI = 5
      When 2:    [F:ORD]ORI = 6
  Endcase
  [F:ORD]VCRTYP    = 11
  [F:ORD]VCRNUM    = [F:ORD]WIPNUM
  [F:ORD]VCRLIN    = 0
  Case [F:CBD]WIPTYPORI
    When 1       :
     [F:ORD]VCRTYPORI = 2
     [F:ORD]VCRNUMORI = [F:CBD]WIPNUMORI
     [F:ORD]VCRLINORI = [F:CBD]WIPLINORI
     [F:ORD]VCRSEQORI = [F:CBD]WIPSEQORI
    When Default :
     If [F:CBD]WIPTYPORI <> 0
       [F:ORD]VCRTYPORI = 11
       [F:ORD]VCRNUMORI = [F:CBD]WIPNUMORI
       [F:ORD]VCRLINORI = [F:CBD]WIPLINORI
       [F:ORD]VCRSEQORI = [F:CBD]WIPSEQORI
     Endif
  Endcase

  # X3-77621(also 72707) - STWIL/STLIG - Should copy project code only for project demands
  # if product is available stock
  Filter [CBD1] Where VCRNUM=[F:CBD]WIPNUMORI
  Read [CBD1]CBD0 First
  If ([F:CBD1]WIPTYP <> 14 &
&     [F:CBH]STDFLG=3)
    [F:ORD]PJT = ""
  Endif
  Filter [CBD1]

  If dim([F:ORD]MTOREF)>0 & dim([F:CBD]MTOREF)>0 & [F:CBD]MTOREF<>""
     [F:ORD]MTOREF = [F:CBD]MTOREF
  Endif
  [F:ORD]PIO       = 1
  [F:ORD]UPDDAT    = [0/0/0]
  [F:ORD]UPDUSR    = ""
  [F:ORD]EXPNUM    = [C]EXPORT
  If ([F:CBH]REOCOD = 2 & WPOSFCY  = 2 & find([F:CBH]SUGTYP,2,3,4)) |
&    ([F:CBH]REOCOD = 3 & WWOSFCY  = 2 & find([F:CBH]SUGTYP,2,3,4)) |
&    ([F:CBH]REOCOD = 4 & WWOSFCYI = 2 & find([F:CBH]SUGTYP,2,3,4)) |
&    ([F:CBH]REOCOD = 5 & WEOSFCY  = 2 & find([F:CBH]SUGTYP,2,3,4))
    GPOINT = "BEFWRISUG"
    Gosub  ENTREE From EXEFNC
    If GPOINT <> ""
      Local Date WSTRTRF, WENDTRF
      WSTRTRF = [F:ORD]STRDAT
      WENDTRF = [F:ORD]ENDDAT
      If [F:CBH]REOCOD = 4 : [F:ORD]ENDDAT = [F:ORD]STRDAT : Endif
      If [F:ORD]STRDAT > [F:ORD]ENDDAT : [F:ORD]ENDDAT = [F:ORD]STRDAT : Endif
   Call ECR_DEBUG("CRE_SUGORD Write ORD :"-[F:ORD]ITMREF
&                                       -num$([F:ORD]STRDAT)-num$([F:ORD]ENDDAT)
&                                       -[F:ORD]WIPNUM-num$([F:ORD]WIPTYP))  From FUNCBN

      Write [ORD]
      If fstat
        GOK = 0
        Call FSTA("ORD") From GLOCK
      Endif
      If [F:CBH]REOCOD = 4
        [F:ORD]WIPTYP = 7
        [F:ORD]STRDAT = WSTRTRF
        [F:ORD]ENDDAT = WENDTRF
        [F:ORD]ORIFCY = [F:CBH]REOFCY
        [F:ORD]STOFCY = WFCY
        Write [ORD]
        If fstat
          GOK = 0
          Call FSTA("ORD") From GLOCK
        Endif
      Endif
    Endif
  Endif

  If [F:ORD]WIPTYP = 5         &
&    [F:ORD]WIPSTA = 3         &
&    [F:ORD]ENDDAT <= WCAPDATF &
&    GMODU(8) = 2              &
&    GOK = 1
    Raz [M:OPSS]
    [M:OPSS] = [F:ORD]
    [M:OPSS]CODMAJ = 0
    If WPRO = 1
      [M:OPSS]OPSTYP = 2
    Else
      [M:OPSS]OPSTYP = 1
    Endif
    [M:OPSS]OPSSTA = 3
    [M:OPSS]PLNFCY = WFCY
    [M:OPSS]MFGFCY = WFCY
    [M:OPSS]VCRNUM = [F:ORD]WIPNUM
    If GLATSUGDAT = 2 & [F:CBH]PLHENDDAT > WCALDATD & WPLHDAT <> 2
        WCOR = 8
        WCOD = 2
        WDEL = 1
        Call CALDAT("+",WCOR,[F:CBH]PLHENDDAT,WCOD,WDEL,WCAP,WCALDATS,[M:OPSS]TRTDAT) From CBNLIB
    Else
        [M:OPSS]TRTDAT = WCALDATD
    Endif

    # ---- Point d'entrée
    GPOINT = "MRPSCHDAT" : Gosub ENTREE From EXEFNC
    # ----
    Call GEN_LOA_SUG From CBNLIBO

    # Issue 94841 GA 12/2013 ---- ajout Point d'entrée + maj éventuelle
    GPE=0 : GPOINT = "BEFREWORD" : Gosub ENTREE From EXEFNC
    If GPE>0
       Readlock [ORD] Curr
       If fstat = 0
   Call ECR_DEBUG("CRE_SUGORD Rewrite ORD suite PE BEFREWORD:"-[F:ORD]ITMREF
&                           -"StrDat:"-num$([F:ORD]STRDAT)-"==>"-num$([M:OPSS]STRDAT)
&                           -"EndDat:"-num$([F:ORD]ENDDAT)-"==>"-num$([M:OPSS]ENDDAT)
&                           -[F:ORD]WIPNUM-num$([F:ORD]WIPTYP))  From FUNCBN
          [F:ORD]STRDAT = [M:OPSS]STRDAT
          [F:ORD]ENDDAT = [M:OPSS]ENDDAT
          Rewrite [ORD]
       Endif
    Endif
  Elsif [F:ORD]WIPTYP = 13 & GLATSUGDAT = 1 & [F:ORD]MRPMES = 11
  # Si EOS en retard et "1ere date possible": on recalcule la date de fin
         WDATD = [F:ORD]STRDAT
         WDATF = [F:ORD]ENDDAT
         Read [F:ITF]ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY
         If !fstat
            WDATR = WDATD
            WCOR = 8
            WCOD = 1
            #WDEL = [F:ITF]OFS     # délai du Service !
            If [F:ORD]BPRNUM=""
              # 107310(55934) product-site supplier
              Call FIND_BPRNUM ([F:ORD]ITMREF,[F:ORD]BOMALT,"",WFCY,[F:ORD]BPRNUM) From SCOLIB
            Endif
            Local Char     WSRVITMREF(GLONITM)
            Call FIND_SCI_LTI([F:ORD]ITMREF,[F:ORD]BPRNUM,[F:ORD]STOFCY,[F:ORD]BOMALT,WSRVITMREF,WDEL) From SCOLIB
            WCOE = [F:ITF]MIC
            If [F:ITF]REOMINQTY <> 0
                WLOT  = [F:ITF]REOMINQTY
            Else
                WLOT  = [F:ITF]MFGLOTQTY
            Endif
            WSUG = [F:ORD]EXTQTY
            Call CORDEL(WDEL,WSUG,WCOE,WLOT) From CBNLIB
            Call CALDAT("+",WCOR,WDATR,WCOD,WDEL,WCAP,WCALDATD,WDATF) From CBNLIB
            # si EOS, recadrage des dates de besoin matières et service
            # Issue 107243 GA 03/2015 improve performance find(...)<>0 + Key ORD3
            #For [ORD1] Where STOFCY = WFCY & find(WIPTYP,3,4) & WIPSTA = 3 & VCRNUM = [F:ORD]VCRNUM
            For [ORD1]ORD3 Hint Key ORD3
&                          Where STOFCY = WFCY & VCRTYP = [F:ORD]VCRTYP & VCRNUM = [F:ORD]VCRNUM
&                              & find(WIPTYP,3,4)<>0 & WIPSTA = 3
               # Issue 107243 GA 03/2015 improve performance ORD0=WIPTYP+WIPNUM+ITMREF primary key
               #Readlock [ORD1]  Curr
               Readlock [ORD1]ORD0=[F:ORD1]WIPTYP;[F:ORD1]WIPNUM;[F:ORD1]ITMREF
                If fstat = 0
                   If [F:ORD1]WIPTYP=4
                      WDATR = WDATF     # Cas des SCS
                   Else
                      WDATR = WDATD     # Cas des MSS
                   Endif

       Call ECR_DEBUG("CRE_SUGORD Rewrite ORD1 car EOS rectifié:"-[F:ORD1]ITMREF
&                                           -"StrDat:"-num$([F:ORD1]STRDAT)-"==>"-num$(WDATR)
&                                           -"EndDat:"-num$([F:ORD1]ENDDAT)-"==>"-num$(WDATR)
&                                           -[F:ORD1]WIPNUM-num$([F:ORD1]WIPTYP))  From FUNCBN
                    [F:ORD1]STRDAT = WDATD
                    [F:ORD1]ENDDAT = WDATR
                    Rewrite [ORD1]
                Endif
            Next
          Endif

          Readlock [ORD]ORD0=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
          If fstat = 0
   Call ECR_DEBUG("CRE_SUGORD Rewrite ORD rectifié:"-[F:ORD]ITMREF
&                                       -"StrDat:"-num$([F:ORD]STRDAT)-"==>"-num$(WDATD)
&                                       -"EndDat:"-num$([F:ORD]ENDDAT)-"==>"-num$(WDATF)
&                                       -[F:ORD]WIPNUM-num$([F:ORD]WIPTYP))  From FUNCBN
                [F:ORD]STRDAT = WDATD
                [F:ORD]ENDDAT = WDATF
                Rewrite [ORD]
          Endif

  Else
  # Si suggestion en retard et "1ere date possible + délai": on recalcule la date de fin
    If (GLATSUGDAT = 2 & [F:ORD]MRPMES = 11)
        Read [F:ITF]ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY
        If !fstat
            WDATD = [F:ORD]STRDAT
            WDATF = [F:ORD]ENDDAT
            If [F:ORD]WIPTYP = 5
                WDATR = WDATD
                WCOR = 8
                WCOD = 2
                WSUG = [F:ORD]EXTQTY
                # Issue 104765 GA 01/2015 case added idem FUNCBN(CAL_SUGLTI)
                # WDEL = [F:ITF]MFGLTI

                WCOE = [F:ITF]MIC
                If [F:ITF]REOMINQTY <> 0
                    WLOT  = [F:ITF]REOMINQTY
                Else
                    WLOT  = [F:ITF]MFGLOTQTY
                Endif

                If ( WFABLTI=3 | (WFABLTI=2 & [F:ITF]MFGLTI=0))
                  # Recherche d'une alternative de gamme valide
                  # Issue 111414 - 2016-02-11 by CCC : Look for a valid route considering versioning
                  #Call FIND_ROUTING(1, [F:ORD]BOMALT, WDATR, WSUG) From CBNLIBO
                  #If [F:ROH]ROUALT <> 0
                  If func CBNLIBO.FIND_ROUTING2(1, [F:ORD]ITMREF, "", [F:ORD]STOFCY, [F:ORD]BOMALT, WDATR, WSUG) <> 0
                    Call CAL_ROH_LTI(WDATR, WSUG,WDEL) From CBNLIBO

                    Call CORDEL(WDEL,WSUG,WCOE,WLOT) From CBNLIB
                    Call CALDAT("+",WCOR,WDATR,WCOD,WDEL,WCAP,WCALDATD,WDATF) From CBNLIB

                  Else
                    WDEL = [F:ITF]MFGLTI

                    Call CORDEL(WDEL,WSUG,WCOE,WLOT) From CBNLIB
                    Call CALDAT("+",WCOR,WDATR,WCOD,WDEL,WCAP,WCALDATD,WDATF) From CBNLIB

                    # Issue 58145/87111 - 2017-11-20 by STLIG : Incorporate quality control lead time in end date calculation
                    #                                     for manufactured product, routing/product lead times and
                    #                                     always routing lead times - if no routing (WFABLTI=2 or 3).
                    WDEL = [F:ITF]QUALTI
                    Call CALDAT("+",WCOR,WDATF,WCOD,WDEL,WCAP,WCALDATD,WDATF) From CBNLIB


                  Endif
                Else
                  WDEL = [F:ITF]MFGLTI

                  Call CORDEL(WDEL,WSUG,WCOE,WLOT) From CBNLIB
                  Call CALDAT("+",WCOR,WDATR,WCOD,WDEL,WCAP,WCALDATD,WDATF) From CBNLIB

                  # Issue 58145/87111 - 2017-11-20 by STLIG : Incorporate quality control lead time in end date calculation
                  #
                  WDEL = [F:ITF]QUALTI
                  Call CALDAT("+",WCOR,WDATF,WCOD,WDEL,WCAP,WCALDATD,WDATF) From CBNLIB

                Endif

            Elsif [F:ORD]WIPTYP = 13   # Issue 89511 GA 08/2013 1ere date possible + délai (du service)
                WDATR = WDATD
                WCOR = 8
                WCOD = 1
                #WDEL = [F:ITF]OFS     # délai du Service !
                If [F:ORD]BPRNUM=""
                  # 107310(55934) product-site supplier
                  Call FIND_BPRNUM ([F:ORD]ITMREF,[F:ORD]BOMALT,"",WFCY,[F:ORD]BPRNUM) From SCOLIB
                Endif
                Local Char     WSRVITMREF(GLONITM)
                Call FIND_SCI_LTI([F:ORD]ITMREF,[F:ORD]BPRNUM,[F:ORD]STOFCY,[F:ORD]BOMALT,WSRVITMREF,WDEL) From SCOLIB
                WCOE = [F:ITF]MIC
                If [F:ITF]REOMINQTY <> 0
                    WLOT  = [F:ITF]REOMINQTY
                Else
                    WLOT  = [F:ITF]MFGLOTQTY
                Endif
                WSUG = [F:ORD]EXTQTY
                Call CORDEL(WDEL,WSUG,WCOE,WLOT) From CBNLIB
                Call CALDAT("+",WCOR,WDATR,WCOD,WDEL,WCAP,WCALDATD,WDATF) From CBNLIB

                # Issue 58145 - 2017-11-06 by STLIG : Incorporate quality control lead time in end date calculation
                #                                     for subcontracted product.
                WCOR = 8
                WCOD = 2
                WDEL = [F:ITF]QUALTI
                Call CALDAT("+",WCOR,WDATF,WCOD,WDEL,WCAP,WCALDATD,WDATF) From CBNLIB

            # si EOS, recadrage des dates de besoin matières et service
                #If [F:ORD]WIPTYP = 13
                    #For [ORD1] Where STOFCY = WFCY & WIPTYP <> 13 & WIPSTA = 3 & VCRNUM = [F:ORD]VCRNUM
                    # Issue 107243 GA 03/2015 improve performance find(...)<>0
                    #For [ORD1] Where STOFCY = WFCY & find(WIPTYP,3,4) & WIPSTA = 3 & VCRNUM = [F:ORD]VCRNUM
                     For [ORD1]ORD3 Hint Key ORD3
&                                   Where STOFCY = WFCY & VCRTYP = [F:ORD]VCRTYP & VCRNUM = [F:ORD]VCRNUM
&                                       & find(WIPTYP,3,4)<>0 & WIPSTA = 3
                      # Issue 107243 GA 03/2015 improve performance ORD0=WIPTYP+WIPNUM+ITMREF primary key
                       #Readlock [ORD1]  Curr
                        Readlock [ORD1]ORD0=[F:ORD1]WIPTYP;[F:ORD1]WIPNUM;[F:ORD1]ITMREF
                        If fstat = 0
                           # Issue 110392 - 2015-08-18 by BEEBE : ORD1 instead of ORD
                           If [F:ORD1]WIPTYP=4
                              WDATR = WDATF     # Cas des SCS
                              [F:ORD1]STRDAT = WDATD
                              [F:ORD1]ENDDAT = WDATF
                           Else
                              WDATR = WDATD     # Cas des MSS
                              WDEL = [F:ORD1]BOMOFS
                              If WDEL=0
                               [F:ORD1]STRDAT = WDATR
                               [F:ORD1]ENDDAT = WDATR
                              Else
                                 # Issue 99888 & 98638 GA 08/2014 sur les MSS [F:ORD]STRDAT +/- BOMOFS
                                 Call CALDAT("+",WCOR,WDATR,WCOD,WDEL,WCAP,WCALDATD,WDATCAL) From CBNLIB
                                 [F:ORD1]STRDAT = WDATCAL
                                 [F:ORD1]ENDDAT = WDATCAL
                             Endif
                           Endif
                           Call ECR_DEBUG("CRE_SUGORD Rewrite ORD1 car EOS en retard rectifié:"-[F:ORD1]ITMREF
&                                           -"StrDat:"-num$([F:ORD1]STRDAT)-"==>"-num$(WDATR)
&                                           -"EndDat:"-num$([F:ORD1]ENDDAT)-"==>"-num$(WDATR)
&                                           -[F:ORD1]WIPNUM-num$([F:ORD1]WIPTYP))  From FUNCBN
                           Rewrite [ORD1]
                        Endif
                    Next
                #Endif
            Else
                 WDATR = WDATD
                 WCOR = 8
                 WCOD = 1
                 WDEL = [F:ITF]OFS
                 WCOE = [F:ITF]MIC
                 If [F:ITF]REOMINQTY <> 0
                     WLOT  = [F:ITF]REOMINQTY
                 Else
                     WLOT  = [F:ITF]MFGLOTQTY
                 Endif
                 WSUG = [F:ORD]EXTQTY
                 Call CORDEL(WDEL,WSUG,WCOE,WLOT) From CBNLIB
                 Call CALDAT("+",WCOR,WDATR,WCOD,WDEL,WCAP,WCALDATD,WDATF) From CBNLIB

                 # Issue 58145 - 2017-11-06 by STLIG : Incorporate quality control lead time in end date calculation
                 #                                     for purchased product.
                 WCOR = 8
                 WCOD = 2
                 WDEL = [F:ITF]QUALTI
                 Call CALDAT("+",WCOR,WDATF,WCOD,WDEL,WCAP,WCALDATD,WDATF) From CBNLIB

                 # Correction jour ouvré suivant
                 WCOR = 8
                 WCOD = 1
                 WDEL = 0
                 Call CALDAT("+",WCOR,WDATF,WCOD,WDEL,WCAP,WCALDATD,WDATF) From CBNLIB

                 If WDATF <= [F:CBH]PLHENDDAT & WPLHDAT <> 2
                   # ------------------------------------------------------------------------
                   # Issue 99888 GA 08/2014 - Start
                   # 1er jour ouvré à compter du jour suivant la fin d'horizon ferme
                   # first business day after the day following the end of firm horizon
                   # ------------------------------------------------------------------------
                   #  WDATF = [F:CBH]PLHENDDAT + 1
                   #  # Correction jour ouvré suivant
                   #  WCOR = 8
                   #  WCOD = 1
                   #  WDEL = 0
                   #  Call CALDAT("+",WCOR,WDATF,WCOD,WDEL,WCAP,WCALDATD,WDATF) From CBNLIB
                    WDATD = [F:CBH]PLHENDDAT
                    WCOR = 8
                    WCOD = 2   # Correction jour ouvré suivant
                    WDEL = 1
                    Call CALDAT("+",WCOR,WDATD,WCOD,WDEL,WCAP,WCALDATS,WDATD) From CBNLIB
                    WDATF = WDATD

                Endif
            Endif

            Readlock [ORD]ORD0=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
            If fstat = 0
   Call ECR_DEBUG("CRE_SUGORD Rewrite ORD rectifié:"-[F:ORD]ITMREF
&                                       -"StrDat:"-num$([F:ORD]STRDAT)-"==>"-num$(WDATD)
&                                       -"EndDat:"-num$([F:ORD]ENDDAT)-"==>"-num$(WDATF)
&                                       -[F:ORD]WIPNUM-num$([F:ORD]WIPTYP))  From FUNCBN
                [F:ORD]STRDAT = WDATD
                [F:ORD]ENDDAT = WDATF
                Rewrite [ORD]
            Endif

        Endif
    Endif
  Endif
Endif
Return

############################################################
$CRE_MXSORD
Local Integer WWBOMALT,WWBOMALTTYP            # FQ 75650 GA 09/2011
WSTYP = [F:CBD]SUGTYP
WSSTA = [F:CBD]SUGSTA
WSNUM = [F:CBD]SUGNUM
Filter [CBD1] Where STOFCY = WFCY  &
&                   find(WIPTYP,3,4,6,9) &
&                   SUGTYP = WSTYP &
&                   SUGSTA = WSSTA &
&                   SUGNUM = WSNUM
&             Order By Key CBD1
For [CBD1]CBD1 Hint Key CBD1
  Raz [F:ORD]
  [F:ORD]          = [F:CBD1]
  # FQ 75650 GA 09/2011 Permettre de changer d'alternative de nomenclature
  If dim([F:CBD1]BOMALT)>0 & [F:CBD1]BOMALT>0
    WWBOMALT    = [F:CBD1]BOMALT
    WWBOMALTTYP = [F:CBD1]BOMALTTYP
  Else
    WWBOMALT    = [F:CBH]BOMALT
    WWBOMALTTYP = [F:CBH]BOMALTTYP
  Endif
  [F:ORD]ORIFCY    = WFCY
  [F:ORD]STOFCY    = WFCY
  [F:ORD]EXTQTY    = [F:CBD1]REQQTY
  [F:ORD]RMNEXTQTY = [F:CBD1]REQQTY
  [F:ORD]FMI       = 1
  Case [F:CBD1]WIPTYP
      When 3:   [F:ORD]BOMALT    = WWBOMALT
                [F:ORD]BOMALTTYP = WWBOMALTTYP
      When 4:   [F:ORD]BOMALT    = WWBOMALT
                [F:ORD]BOMALTTYP = WWBOMALTTYP
                [F:ORD]ABBFIL    = "SCO"            # pour reconnaitre les SCS liée à une suggestion de sous-traitance
      When 6:   [F:ORD]BOMALT    = WWBOMALT
                [F:ORD]BOMALTTYP = WWBOMALTTYP
      When 9:   [F:ORD]BOMALT    = 0
                [F:ORD]BOMALTTYP = 0
  Endcase
  # distinguer suggestions issues du MPS/MRP
  Case WPRO
      When 1:    [F:ORD]ORI = 5
      When 2:    [F:ORD]ORI = 6
  Endcase
  [F:ORD]VCRTYP    = 11
  [F:ORD]VCRNUM    = WSNUM
  If [F:CBD1]WIPTYP = 9
      [F:ORD]VCRTYPORI = 0
      [F:ORD]VCRNUMORI = ""
      [F:ORD]VCRLINORI = 0
      [F:ORD]VCRSEQORI = 0
  Else
      Case [F:CBD1]WIPTYPORI
        When 1       :
          [F:ORD]VCRTYPORI = 2
          [F:ORD]VCRNUMORI = [F:CBD1]WIPNUMORI
          [F:ORD]VCRLINORI = [F:CBD1]WIPLINORI
          [F:ORD]VCRSEQORI = [F:CBD1]WIPSEQORI
        When Default :
          If [F:CBD1]WIPTYPORI <> 0
            [F:ORD]VCRTYPORI = 11
            [F:ORD]VCRNUMORI = [F:CBD1]WIPNUMORI
            [F:ORD]VCRLINORI = [F:CBD1]WIPLINORI
            [F:ORD]VCRSEQORI = [F:CBD1]WIPSEQORI
          Endif
      Endcase
  Endif
  If dim([F:ORD]MTOREF)>0 & dim([F:CBD1]MTOREF)>0 & [F:CBD1]MTOREF<>""
     [F:ORD]MTOREF = [F:CBD1]MTOREF
  Endif
  [F:ORD]PIO       = 1
  [F:ORD]UPDDAT    = [0/0/0]
  [F:ORD]UPDUSR    = ""
  [F:ORD]EXPNUM    = [C]EXPORT
  If ([F:CBH]REOCOD = 2 & WPOSFCY  = 2 & find([F:CBH]SUGTYP,2,3,4)) |
&    ([F:CBH]REOCOD = 3 & WWOSFCY  = 2 & find([F:CBH]SUGTYP,2,3,4)) |
&    ([F:CBH]REOCOD = 4 & WWOSFCYI = 2 & find([F:CBH]SUGTYP,2,3,4)) |
&    ([F:CBH]REOCOD = 5 & WEOSFCY  = 2 & find([F:CBH]SUGTYP,2,3,4))
      #GPOINT = "BEFWRIMWS"
      GPOINT = "BEFWRIORD"
      Gosub  ENTREE From EXEFNC
      If GPOINT <> ""
   Call ECR_DEBUG("CRE_MXSORD Write ORD:"-[F:ORD]ITMREF-num$([F:ORD]STRDAT)-num$([F:ORD]ENDDAT)
&                                       -[F:ORD]WIPNUM-num$([F:ORD]WIPTYP)
&                                       -"BOMOFS="+num$([F:ORD]BOMOFS)-"BOMOPE="+num$([F:ORD]BOMOPE))  From FUNCBN

        Write [ORD]
        If fstat
          GOK = 0
          Call FSTA("ORD") From GLOCK
          Break
        Endif
      Endif
  Endif
Next
Filter [CBD1]
Return

############################################################
# optimisation en cours fantômes
$MAJ_GHOST
Local Integer WONORDER : WONORDER = 0
GOK  = 1
Local File ORDERS [ORDX]

# Issue 122597 - 2017-04-24 by STLIG : Build CBNHEA filter -
#                                      If 'MPS and MRP products' is ticked then
#                                         process all phantoms.
#                                      If 'MPS and MRP products' is not ticked then
#                                         process "By order" phantoms only.
Local Char PHANTOM_FILTER(255) : Raz PHANTOM_FILTER
PHANTOM_FILTER="STOFCY=WFCY & PHAFLG=2"
If (WITM<>2)
  PHANTOM_FILTER-="& STDFLG=4"
Endif
Filter [CBH] Where evalue(PHANTOM_FILTER)
&          Order By Key CLE=STOFCY;LLC Desc;ITMREF

For [CBH]
    If fstat : Break : Endif

    # une transaction par article
    GOK = 1
    Trbegin [ORDX]

    # Issue 107243 MB 30-03-2015 Columns # GA [F:ORD] replaced by [F:ORDX]
    Columns [ORDX] (STOFCY,VCRTYP,VCRNUM,VCRTYPORI,
&                    VCRNUMORI,VCRLINORI,ITMREF,ITMREFORI,
&                    EXTQTY)
    For [ORDX]ORD4 Hint Key ORD4
&                 Where ITMREF = [F:CBH]ITMREF & STOFCY = WFCY & WIPTYP = 5 & WIPSTA = 3
        # Issue 107243 GA 03/2015 new parameter [F:ORDX]VCRTYPORI
        Call PUR_FAN([F:ORDX]STOFCY, [F:ORDX]VCRTYP, [F:ORDX]VCRNUM,[F:ORDX]VCRTYPORI,
&                    [F:ORDX]VCRNUMORI, [F:ORDX]VCRLINORI, [F:ORDX]ITMREF, [F:ORDX]ITMREFORI,
&                    [F:ORDX]EXTQTY, WONORDER)
        If GOK <> 1 : Break : Endif
    Next
    # Issue 107243 MB 30-03-2015
    Columns [ORDX]

    If GOK <> 1
        Rollback
    Else
        Commit
    Endif
$NEXT_LNK
Next
Filter [CBH]   # FQ 70583 GA 01/2011
Close File [ORDX] # Issue 107243 GA  04/2015 Close is mandatory
GOK = 1
Return

#########################################################
# suppression suggestion sur fantôme
# suppression ou diminution du besoin sur le fantôme selon PEC stock
# Issue 107243 GA 03/2015 new parameter [F:ORD]VCRTYPORI
Subprog PUR_FAN(LFCY, LVCRTYP, LVCRNUM, LVCRTYPORI, LVCRNUMORI, LVCRLINORI, LITMREF, LITMREFORI, LQTY, LONORDER)
Value Char         LFCY
Value Integer      LVCRTYP
Value Char         LVCRNUM
Value Integer      LVCRTYPORI   # Issue 107243 GA 03/2015
Value Char         LVCRNUMORI
Value Integer      LVCRLINORI
Value Char         LITMREF
Value Char         LITMREFORI
Value Decimal      LQTY
Variable Integer   LONORDER

Local Char         WVCRNUMUP(GLONVCR)

# ici on détermine si on est dans un contexte sur stock ou à la commande
Local File ORDERS [ORD]
LONORDER = 1

# Issue 107243 GA 03/2015 new parameter LVCRTYPORI
For [ORD]ORD4 Hint Key ORD4
&             Where ITMREF = LITMREFORI & STOFCY = LFCY & WIPTYP = 5
&                 & VCRTYPORI = LVCRTYPORI & VCRNUMORI = LVCRNUMORI
    LONORDER = 0
    WVCRNUMUP = [F:ORD]VCRNUM
    Break      # Issue 107243 GA 03/2015 improve performance
Next

# pas de WOS d'origine (PF géré à la commande), on sort
If LONORDER : Goto ONORDER :  Endif
#------------------------------
# si article géré sur stock
# recherche + suppression MWS
# Issue 107243 GA 03/2015 improve performance: find(...)<>0
#&                 & find(WIPTYP,3,6) & find(LVCRNUMORI,VCRNUM,VCRNUMORI)
For [ORD]ORD4 Hint Key ORD4
&             Where ITMREF = LITMREF & STOFCY = LFCY
&                 & find(WIPTYP,3,6)<>0 & find(LVCRNUMORI,VCRNUM,VCRNUMORI)<>0
    # Issue 107243 GA 03/2015 improve performance ORD0=WIPTYP+WIPNUM+ITMREF primary key
    #Readlock [ORD]  Curr
    Readlock [ORD]ORD0=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
    If fstat : Break : Endif

    # si qté WOS < qté MWS, on a pris en compte du stock, il faut conserver le besoin
    If LQTY < [F:ORD]EXTQTY
        [F:ORD]EXTQTY -= LQTY
        [F:ORD]RMNEXTQTY  = [F:ORD]EXTQTY
        Rewrite [ORD]
        If fstat : GOK = 0 :  : Endif
    Else
        Delete [ORD]
        If fstat : GOK = 0 : Break : Endif   # FQ 69909 Ctrl des sources avant End
    Endif

  # Issue 107243 GA 03/2015 improve performance: find(...)<>0
    For [ORD1]ORD3 Hint Key ORD3
&                  Where STOFCY = LFCY & VCRTYP = LVCRTYP & VCRNUM = LVCRNUM
&                      & find(WIPTYP,3,4,6)<>0 & WIPSTA = 3
       # Issue 107243 GA 03/2015 improve performance ORD0=WIPTYP+WIPNUM+ITMREF primary key
       #Readlock [ORD1]  Curr
       Readlock [ORD1]ORD0=[F:ORD1]WIPTYP;[F:ORD1]WIPNUM;[F:ORD1]ITMREF
       If fstat : Break : Endif
       [F:ORD1]VCRNUM    = WVCRNUMUP
       [F:ORD1]ITMREFORI = LITMREFORI
       Rewrite [ORD1]
       If fstat : GOK = 0 : Break 2 : Endif  # FQ 69909 Ctrl des sources avant Return (???)
    Next
    If GOK <= 0 : Break : Endif              # FQ 69909 Ctrl des sources (ligne ajoutée)
Next
If GOK <= 0 : End : Endif                    # FQ 69909 Ctrl des sources (ligne ajoutée)

Goto REMOVE_WOS

#------------------------------
# si article géré à la commande
# recherche + suppression MWS
$ONORDER
# Issue 107243 GA 03/2015 improve performance  + new parameter LVCRTYPORI
#For [ORD]ORD4 Hint Key ORD4
#&             Where ITMREF = LITMREF & STOFCY = LFCY & WIPTYP = 6 & VCRNUMORI = LVCRNUMORI & VCRLINORI = LVCRLINORI
#    If [F:ORD]ITMREFORI <> LITMREFORI : Goto NXT_ONORDER1 : Endif
For [ORD]ORD4 Hint Key ORD4
&             Where ITMREF = LITMREF & STOFCY = LFCY & WIPTYP = 6
&                 & VCRTYPORI = LVCRTYPORI & VCRNUMORI = LVCRNUMORI & VCRLINORI = LVCRLINORI & ITMREFORI=LITMREFORI
    # Issue 107243 GA 03/2015 improve performance ORD0=WIPTYP+WIPNUM+ITMREF primary key
    #Readlock [ORD]  Curr
    Readlock [ORD]ORD0=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
    If fstat : Break : Endif

    # si qté WOS < qté MWS, on a pris en compte du stock, il faut conserver le besoin
    If LQTY < [F:ORD]EXTQTY
        [F:ORD]EXTQTY -= LQTY
        [F:ORD]RMNEXTQTY  = [F:ORD]EXTQTY
        Rewrite [ORD]
        If fstat : GOK = 0 : Break : Endif    # FQ 69909 Ctrl des sources avant End
    Else
        Delete [ORD]
        If fstat : GOK = 0 : Break : Endif    # FQ 69909 Ctrl des sources avant End
    Endif

    Raz WVCRNUMUP # Issue 107243 GA 03/2015
    # à la commande, la remontée des composants sous le fantôme se fait ici
    # car on a besoin de l'article d'origine de la MWS du fantôme
    # recherche n° WOS niveau supérieur
    For [ORD1]ORD4 Hint Key ORD4
&                  Where ITMREF = [F:ORD]ITMREFORI & STOFCY = LFCY & WIPTYP = 5
&                      & VCRTYPORI = LVCRTYPORI & VCRNUMORI = LVCRNUMORI & VCRLINORI = LVCRLINORI
        WVCRNUMUP  = [F:ORD]VCRNUM
        Break      # Issue 107243 GA 03/2015 improve performance  + new parameter LVCRTYPORI
    Next

# Issue 107243 GA 03/2015 improve performance
#    For [ORD1]ORD3 Hint Key ORD3
#&                  Where STOFCY = LFCY & VCRTYP = LVCRTYP & VCRNUM = LVCRNUM & find(WIPTYP,4,6) & WIPSTA = 3  &
#&                        VCRNUMORI = [F:ORD]VCRNUMORI & VCRLINORI = [F:ORD]VCRLINORI
#        If [F:ORD1]VCRNUM <> LVCRNUM : Goto NXT_ONORDER2 : Endif
#        Readlock [ORD1]  Curr
    If WVCRNUMUP<>""  # Issue 107243 GA 03/2015
    For [ORD1]ORD3 Hint Key ORD3
&                    Where STOFCY = LFCY & VCRTYP = LVCRTYP & VCRNUM = LVCRNUM & find(WIPTYP,4,6)<>0 & WIPSTA = 3
&                        & VCRTYPORI = [F:ORD]VCRTYPORI & VCRNUMORI = [F:ORD]VCRNUMORI & VCRLINORI = [F:ORD]VCRLINORI
        Readlock [ORD1]ORD0=[F:ORD1]WIPTYP;[F:ORD1]WIPNUM;[F:ORD1]ITMREF
        If fstat : Break : Endif

        [F:ORD1]VCRNUM = WVCRNUMUP
        [F:ORD1]ITMREFORI = [F:ORD]ITMREFORI
        Rewrite [ORD1]
        If fstat : GOK = 0 : Break 2 : Endif    # FQ 69909 Ctrl des sources avant End
#$NXT_ONORDER2
    Next
    If GOK <= 0 : Break : Endif               # FQ 69909 Ctrl des sources (ligne ajoutée)
    Endif
#$NXT_ONORDER1
Next
If GOK <= 0 : End : Endif                     # FQ 69909 Ctrl des sources (ligne ajoutée)

$REMOVE_WOS
# relecture WOS/EOS + purge
# Issue 107243 GA 03/2015 improve performance + WIPSTA=3 ?
#For [ORD]ORD4 Hint Key ORD4
#&             Where ITMREF = LITMREF & STOFCY = LFCY
#&                 & find(WIPTYP,5,13) & VCRNUM = LVCRNUM
For [ORD]ORD4 Hint Key ORD4
&             Where ITMREF = LITMREF & STOFCY = LFCY & find(WIPTYP,5,13)<>0 & WIPSTA = 3
&                 & VCRNUM = LVCRNUM
    # Issue 107243 GA 03/2015 improve performance ORD0=WIPTYP+WIPNUM+ITMREF primary key
    #Readlock [ORD]  Curr
    Readlock [ORD]ORD0=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
    If fstat : GOK = 0 : Break : Endif        # FQ 70617 Ctrl des sources avant End
    Call PUR_LOA_SUG(LFCY, LVCRNUM) From CBNLIBO
    Delete [ORD]
    If fstat : GOK = 0 : Break : Endif        # FQ 69909 Ctrl des sources avant End
Next
End

############################################################
# FQ 77115 GA 12/2011 Recherche du Service pour caler les dates des MSS et EOS
$TRT_DATSCS
If clalev([BODW])<=0  Local File BOMD       [BODW]   Endif
Local Date WDATBES : WDATBES = [F:CBD]REQDAT

Filter  [BODW] Where ITMREF    = [F:CBD]ITMREF    &
&                    BOMALT    = [F:CBH]BOMALT    &
&                    BOMALTTYP = [F:CBH]BOMALTTYP &
&                   (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= WDATBES)) &
&                   (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= WDATBES)) &
&                    CPNTYP    = 7
&             Order By Key BOD0
For [BODW]
    # 1er service valide
    WDATR = [F:CBD]ENDDAT
    WCOR  = 8
    WCOD  = 1   # 1=délai achat en jours calendaires, 2=délai fab en jours ouvrés (???)
    If [F:BODW]BOMOFS>0
        WDEL  = [F:BODW]BOMOFS
    Else
        # positionner [F:ITM] [F:ITF]
        If [F:ITM1]ITMREF<>[F:BODW]ITMREF
           Read [F:ITM1]ITM0=[F:BODW]ITMREF
           If fstat : Raz [F:ITM1] : Break : Endif
        Endif
        WDEL = [F:ITM1]OFS
        If [F:ITF1]ITMREF<>[F:BODW]ITMREF | [F:ITF1]STOFCY<>[F:CBD]STOFCY
           Read [F:ITF1]ITF0=[F:BODW]ITMREF;[F:CBD]STOFCY
           If fstat Raz [F:ITF1] Endif
        Endif
        If [F:ITF1]OFS>0 WDEL = [F:ITF1]OFS Endif

    Endif
    Call CALDAT("-",WCOR,WDATR,WCOD,WDEL,WCAP,WCALDATD,WDATR) From CBNLIB
    If [F:CBD]STRDAT > WDATR
       [F:CBD]STRDAT = WDATR
    Endif
    WDATGAM = 2 : WOPESTR = WDATR  # Stocker la date de début du Service
    Break
Next
Filter [BODW]

Return

