#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"FCHK","SUBCHK","") From GSAISIE
End
# Issue X3-66556 - 2017-12-15 by MDJ : Bank statement reconciliation false when date is not a period end date
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "SETBOUT"      : Gosub SETBOUT
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "FIR"          : Gosub PREMIER
 When "LAS"          : Gosub DERNIER
 When "SUI"          : Gosub SUIVANT
 When "PRE"          : Gosub PRECEDENT
 When "ENR"          : Gosub ENREGISTRE
 When "ABA"          : Gosub ABANDON
 When "END"          : Gosub FIN
 When "MEN"          : Gosub BOUTON_MENU
 When "BOUTON"       : Gosub BOUTON
 When "RAF"          : Gosub LECTURE : Gosub CHARGE_ECR
 When "AB1_NBLIG"    : GCONSULT = 1
 When "BB1_NBLIG"    : GCONSULT = 0
 When "INIT_DIA"     : Gosub INIT_RECH
 When "CONTROLE"     : Gosub CONT_RECH
 When "SORTIE"       : Gosub SORT_RECH
Endcase
Return


$OUVRE
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
If clalev([F:BAL])=0 : Local File BALANCE    [BAL] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:BAN])=0 : Local File BANK       [BAN] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:ALS])=0 : Local File ALSTRD     [ALS] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON    [AMZ] : Endif
If clalev([F:PAN])=0 : Local File PAYACCNUM  [PAN] : Endif

# GRNA 18/07/2011
Gosub OUVRE_CHN From CHKLIB

#poseverrou indique si verrou sur AUTCHK
#verrou indique si le compte de banque est en cours de pointage => lock a échoué sur AUTCHK
Local Integer POSEVERROU, VERROU, SAVNOL, NOL, MAXLIG, RECHOK
Local Char    SYMBCHK(20), CHAINE(30), TITMASQ(20), MASQUE(20), CLECOUR(5)
Local Libelle KIAOK         : # Code activité KIA : date de banque (Italie)
Local Char    CAR(1)
Local Integer I,J
Local Integer CALL_PT : Raz CALL_PT
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("SUBCHK",GENTSTD(1..GNBENTREE))
 CALL_PT=1
Endif

Local Mask    RAPBAN3 [RB3] : # Criteres de tri
Local Mask    CHK1    [CHK1]
Return

$DEBUT
Raz [M]
Filter [BAN]
REP = ""
CLECOUR = ""
KIAOK = (dim([M]BANDAT)>0)
MAXLIG = dim([M]REF)
Return

$SETBOUT
Raz ETABOU
If CLECOUR<>""
 ETABOU(GSUIV) = 1
 ETABOU(GPREC) = 1
 CHMEN += "U"
 Gosub SET_BOUT_SPE From GSAISIE
Else
 CHMEN = "V"
Endif
If REP="M"
 CHMEN = ""
 ETABOU(GENRE) = 1
 ETABOU(GABAN) = 1
Elsif REP=""
 ETABOU(GRAFF) = 1
Endif
ETABOU(GPREM) = 1
ETABOU(GDERN) = 1
ETABOU(GBFIN) = 1
Return

$INIT_RECH
Raz [M:DIA]
Return

$CONT_RECH
[M:CHK1] = [M:DIA]
Return

$SORT_RECH
PARAM(1)=num$(OK)   :# Boutons OK, FIN de la fenetre de recherche
Return

$BOUTON_MENU
Case BOUT
 When "S"
  If RECHOK=2 : Gosub MTRECH : Endif
Endcase
Return

$MTRECH
SAVNOL = nolign-1
Default Mask [CHK0]
NOL = find([M:CHK1]MTRECH,[M]AMTBNQ(nolign..[M]NBLIG-1))
If NOL=0
 NOL = find([M:CHK1]MTRECH,[M]AMTBNQ(0..nolign-1))
 If NOL<>0 : nolign = NOL : Endif
Else
 nolign += NOL
Endif
If NOL<>0
 SUIZON = "CHK("+num$(nolign-1)+")"
Else    : # Modif 26/07/99 Ne pas passer en mode saisie si on a pas trouvé
 SUIZON = "CHK("+num$(SAVNOL)+")"
 mkstat = 2
Endif
Return

$BOUTON
Case BOUT
 When "U" : If RECHOK=2 : Gosub TRI   : Endif
 When "V" : Gosub CHARGE_ECR
Endcase
Return

$TRI
Local Char    CRIT1(20), CRIT2(20), CRIT3(20), CRIT4(20), CRIT5(20), CRIT6(20)
Default Mask [CHK0]
For J=1 To 6
 I = find(J,[M:RB3]ORDRE(0..[M:RB3]NBLIG-1))
 If I=1 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "AMTBNQ([S]INDICE)"  : Endif
 If I=1 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "AMTBNQT([S]INDICE)" : Endif
 If I=2 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "ACCDAT([S]INDICE)"  : Endif
 If I=2 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "ACCDATT([S]INDICE)" : Endif
 If I=3 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "BANCIB([S]INDICE)"  : Endif
 If I=3 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "BANCIBT([S]INDICE)" : Endif
 If I=4 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "REF([S]INDICE)"     : Endif
 If I=4 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "REFT([S]INDICE)"    : Endif
 If I=5 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "NUM([S]INDICE)"     : Endif
 If I=5 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "NUMT([S]INDICE)"    : Endif
 If I=6 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "DES([S]INDICE)"     : Endif
 If I=6 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "DEST([S]INDICE)"    : Endif
Next J

If CRIT1="" & CRIT2="" & CRIT3="" & CRIT4="" & CRIT5="" & CRIT6="" : Return : Endif
If CRIT1="" : CRIT1 = "1=1" : Endif
If CRIT2="" : CRIT2 = "1=1" : Endif
If CRIT3="" : CRIT3 = "1=1" : Endif
If CRIT4="" : CRIT4 = "1=1" : Endif
If CRIT5="" : CRIT5 = "1=1" : Endif
If CRIT6="" : CRIT6 = "1=1" : Endif

Sorta NBLIG NBLIG Order By evalue(CRIT1),evalue(CRIT2),evalue(CRIT3),evalue(CRIT4),evalue(CRIT5),evalue(CRIT6)
Affzo [M]15

Return

$PREMIER
Filter [BAN] Where BANCSH=1
Read [BAN]BAN0 First
Gosub SUIVPREC
Return

$DERNIER
Filter [BAN] Where BANCSH=1
Read [BAN]BAN0 Last
Gosub SUIVPREC
Return

$SUIVANT
Filter [BAN] Where BANCSH=1
Read [BAN]BAN0 >
Gosub SUIVPREC
Return

$PRECEDENT
Filter [BAN] Where BANCSH=1
Read [BAN]BAN0 <
Gosub SUIVPREC
Return

$SUIVPREC
Filter [BAN]
If fstat
 GERR = 2 : GMESSAGE = mess(11,100,1) : # Début/Fin de fichier
Else
 Call ACCES_POINTAGE(GOK,[F:BAN]BAN) From SUBCHK
 If !GOK
  GERR=1 : GMESSAGE = mess(25,120,1)-" "-[F:BAN]BAN : #Vous n'avez pas accés à la banque
  Return
 Endif
 Gosub LECTURE
 Gosub CHARGE_ECR
 REP = ""
 Actzo [M]BAN
 SUIZON = "CHK(0)"
Endif
Return

#Remplit les zones d'entête
$LECTURE
If POSEVERROU : Gosub DEVERROU : Endif
Effzo [M]12
Effzo [M]15
Read [BAN]BAN0=[F:BAN]BAN
[M] = [F:BAN]
Call SETCUR(1,[F:BAN]CPY,[M]CURLED) From CPTDIV
If [M]ACCDATFIN<>[0/0/0]
 Call SOLDEBAL([M]CUR,[M]CPY,[M]FCY,[M]BANACC,[M]BANBPR,[M]SNSBLC,[M]ACCDATFIN,[M]BLC) From SUBCHK
Else
 Call SOLDEBAL([M]CUR,[M]CPY,[M]FCY,[M]BANACC,[M]BANBPR,[M]SNSBLC,datesyst,[M]BLC) From SUBCHK
Endif
If !VERROU : CLECOUR = [M]BAN : Affzo
Else       : CLECOUR = "" : Effzo [M] : [M]BAN=[F:BAN]BAN : Affzo [M]BAN
Endif
Return

#Remplit le tableau des lignes
$CHARGE_ECR
Call TEMPON("L") From GESECRAN
Effzo [M]15
VERROU = 0
nolign = 0
SYMBCHK ="AUTCHK"+"\"+[M]BAN
Lock =SYMBCHK
If fstat
 GERR = 1 : GMESSAGE = mess(23,120,1) : # Compte en cours de pointage
 VERROU = 1
 Return
Endif
POSEVERROU = 1
For [DAE]DAE3 Where LEDTYP=GTYPGEN & CPY=[M]CPY & ACC=[M]BANACC & BPR=[M]BANBPR & CHK=""
 Raz OK
 If ([F:DAE]BPR="" | [F:DAE]BPR=[M]BANBPR) & ([M]FCY="" | [M]FCY=[F:DAE]FCYLIN)
  Gosub CTL
 Endif
 If OK
  [M]NUM(nolign)    = [F:DAE]NUM
  I = 1
  While I<=len([F:DAE]NUM)
   CAR = mid$([F:DAE]NUM,I,1)
   If 256-ascii(CAR)>0 : [M]NUMT(nolign) += chr$(256-ascii(CAR)) : Endif
   I +=1
  Wend
  If len([F:DAE]NUM)=0
   [M]NUMT(nolign) = chr$(256-1)
  Endif

  [M]DES(nolign)    = [F:DAE]DES
  I = 1
  While I<=len([F:DAE]DES)
   CAR = mid$([F:DAE]DES,I,1)
   If 256-ascii(CAR)>0 : [M]DEST(nolign) += chr$(256-ascii(CAR)) : Endif
   I +=1
  Wend
  If len([F:DAE]DES)=0
   [M]DEST(nolign) = chr$(256-1)
  Endif
  [M]ACCNUM(nolign)  = [F:DAE]ACCNUM
  [M]TYP(nolign)     = [F:HAE]TYP
  [M]AMTBNQ(nolign)  = [F:DAE]AMTCUR
  [M]AMTBNQT(nolign) = -[M]AMTBNQ(nolign)
  [M]BANCUR(nolign)  = [F:DAE]CUR
  If [F:DAE]AMTFLG <> 0
   [M]AMTLED(nolign) = [F:DAE]AMTLED1
  Else
   [M]AMTLED(nolign) = [F:DAE]AMTLED
  Endif
  If [F:DAE]SNS=1
   [M]SNS(nolign)    = 1
   [M]SNS2(nolign)   = "D"
  Else
   [M]SNS(nolign)    = 2
   [M]SNS2(nolign)   = "C"
  Endif
  [M]REF(nolign)     = [F:HAE]REF
  I = 1
  While I<=len([F:HAE]REF)
   CAR = mid$([F:HAE]REF,I,1)
   If 256-ascii(CAR)>0 : [M]REFT(nolign) += chr$(256-ascii(CAR)) : Endif
   I +=1
  Wend
  If len([F:HAE]REF)=0
   [M]REFT(nolign) = chr$(256-1)
  Endif
  [M]ACCDAT(nolign)  = [F:HAE]ACCDAT
  [M]ACCDATT(nolign) = -nday([F:HAE]ACCDAT)
  [M]BANCIB(nolign)  = [F:HAE]BANCIB
  [M]BANCIBT(nolign) = -val([F:HAE]BANCIB)
  [M]VALDAT(nolign)  = [F:HAE]VALDAT
  If KIAOK
   [M]BANDAT(nolign) = [F:HAE]BANDAT
  Endif
  Filter [PAN] Where ACCNUM=[F:DAE]ACCNUM & CPTBAN=2 & TYPNUM=1
  Read [PAN]PAN0 First
  If !fstat
   [M]FRMNUM(nolign) = [F:PAN]NUM
  Else
   [M]FRMNUM(nolign) = ""
  Endif
  Filter [PAN]
  nolign +=1
  If nolign >= MAXLIG
   GERR=2 : GMESSAGE = mess(26,100,1) : Break   :# Tableau plein
  Endif
 Endif
Next
[M]NBLIG = nolign
Call TEMPOFF From GESECRAN
If sum([M:RB3]ORDRE(0..dim([M:RB3]ORDRE)-1))=0
 Call LECMEMO("STD","[M:RB3]","tri") From GMEMO
Endif
Gosub TRI
If !VERROU : CLECOUR = [M]BAN : Affzo
Else       : CLECOUR = "" : Effzo [M] : [M]BAN=[F:BAN]BAN : Affzo [M]BAN
Endif
Return

$CTL
OK = 1
Read [HAE]HAE0 = [F:DAE]TYP; [F:DAE]NUM
If fstat : OK = 0 : Return : Endif
If [F:HAE]CAT <> 1 | [F:HAE]FLGREP = 2  : OK = 0 : Return : Endif : #(LA618) Réel (LA1)A nouveau

# Ne pas afficher les pièces d'écart de conversion
If [F:HAE]REFINT = "CNVEC" : OK = 0 : Return : Endif
#Issue 74113 – 2018-01-31 by MADOR - Adjustments driven from the FIFRC automatic journal
If left$([F:HAE]REFINT, 4) = "FIFO" : OK = 0 : Endif
#Issue end

If [M]ACCDATDEB <> [0/0/0]  & [F:HAE]ACCDAT < [M]ACCDATDEB : OK = 0 : Return : Endif
If [M]ACCDATFIN <> [0/0/0]  & [F:HAE]ACCDAT > [M]ACCDATFIN : OK = 0 : Return : Endif
If [M]VALDATDEB <> [0/0/0]  & [F:HAE]VALDAT < [M]VALDATDEB : OK = 0 : Return : Endif
If [M]VALDATFIN <> [0/0/0]  & [F:HAE]VALDAT > [M]VALDATFIN : OK = 0 : Return : Endif
Return

$DEVERROU
Unlock =SYMBCHK
POSEVERROU = 0
Call DEBTRANS From GLOCK
Trbegin [HAE]
 Call DELOCK("HAE") From GLOCK
Commit
Return

$APRES_MODIF
Case COUZON
 When "BAN"
  REP = ""
  Read [BAN]BAN0 = CZ
  Gosub LECTURE
  If VERROU : mkstat = 2 : Endif
 When "CHK", "VALDAT", "BANDAT"
  REP = "M"
  Grizo [M]BAN
  [M]CHGDAT(nolign-1)=1
 When "ACCDATFIN"
  If CZ<>[0/0/0] :
   Call SOLDEBAL([M]CUR,[M]CPY,[M]FCY,[M]BANACC,[M]BANBPR,[M]SNSBLC,CZ,[M]BLC) From SUBCHK
  Else
   Call SOLDEBAL([M]CUR,[M]CPY,[M]FCY,[M]BANACC,[M]BANBPR,[M]SNSBLC,datesyst,[M]BLC) From SUBCHK
  Endif
  Affzo [M]BLC
  Call D_SNSBLC2([M]SNSBLC2) From SUBCHK :   Affzo [M]SNSBLC2
Endcase
OK = 1
Return

$ENREGISTRE
#Enregistrement
Call TEMPON("V") From GESECRAN
Call DEBTRANS From GLOCK
Gosub VALID
Gosub DEVERROU
Actzo [M]BAN
Call TEMPOFF From GESECRAN
OK = 1
REP = ""
Return

$ABANDON
#Abandon de la modification
Gosub LECTURE
Gosub CHARGE_ECR
Actzo [M]BAN
REP = ""
Return

$FIN
# Close the mask to charge the STD memo each time
Close Local Mask [RB3]
Gosub DEVERROU
Return

$VALID
GOK = 1
Trbegin [DAE], [HAE]
 For NOL=0 To [M]NBLIG-1
  If [M]CHGDAT(NOL)<>0
   GCLE = num$([M]ACCNUM(NOL))
   Readlock [DAE]DAE2 = [M]ACCNUM(NOL)
   If fstat=1
    GOK = -1 : GLOCK = "$GACCENTRYD"-GCLE : Break
   Elsif fstat
    GOK = 0 : Call RSTA("DAE",GCLE) From GLOCK
   Elsif !fstat
    [F:DAE]CHK    = [M]CHK(NOL)
    [F:DAE]CHKDAT = date$
    Gosub PE_BEFWRIDAE
    Rewrite [DAE]
    If fstat
      GOK = 0 : Call FSTA("DAE") From GLOCK : Break
    Endif
    GCLE = [F:DAE]TYP-[F:DAE]NUM
    Readlock [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
    If fstat=1
     GOK = -1 : GLOCK = "$GACCENTRY"-GCLE : Break
    Elsif fstat
     GOK = 0 : Call RSTA("HAE",GCLE) From GLOCK
    Elsif !fstat
     [F:HAE]VALDAT = [M]VALDAT(NOL)
     If KIAOK : [F:HAE]BANDAT = [M]BANDAT(NOL) : Endif
     Rewrite [HAE]
     If fstat
      GOK = 0 : Call FSTA("HAE") From GLOCK : Break
     Endif
     # GRNA 18/07/2011
     Gosub CLEAR_CHN From CHKLIB
     If GOK<1 : Break : Endif
    Endif
   Endif
   [M]CHGDAT(NOL)=0
  Endif
 Next NOL
 If    GOK<0 : Goto ROLL_TR_VALID
 Elsif GOK=0 : Goto AB_TR_VALID
 Endif

Commit
Return

$ROLL_TR_VALID
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VALID
Endif

$AB_TR_VALID
Rollback
Return

$PE_BEFWRIDAE
If CALL_PT : GPOINT = "BEFWRIDAE" : Gosub ENTREE From EXEFNC : Endif
Return


########################################
Subprog C_BAN(VALEUR)
Variable Char    VALEUR()
Call ACCES_POINTAGE(GOK,VALEUR) From SUBCHK
If !GOK
 GMESSAGE = mess(25,120,1)-" "-VALEUR : #Vous n'avez pas accés à la banque
 mkstat = 2
 End
Endif

End

Subprog AS_BAN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Call BANDEF(VALEUR)
Endif
End

Subprog D_SNSBLC2(VALEUR)
Variable Char    VALEUR()
If [M]SNSBLC=1
 VALEUR = "D"
Else
 VALEUR = "C"
Endif
End

Subprog IB_NBLIG
GBOUT1 = mess(145,117,1)  :# Pièce comptable
End

Subprog AM_CHK(VALEUR)
Variable Char    VALEUR
Local Decimal MNT
Local Integer NOL : NOL = nolign-1
If VALEUR<>""
 VALEUR = tolower(VALEUR)  :# Pour le Web
 Lock ="HAE"+[M]NUM(NOL)+"\"+[M]TYP(NOL) With lockwait=0
 If fstat
  # Modification en cours sur un autre poste
  GMESSAGE = mess(10,100,1)
  mkstat=1 : End
 Else
  # Relecture
  Read [DAE]DAE2=[M]ACCNUM(NOL)
  If fstat
   # Ecriture inexistante
   GMESSAGE = mess(33,110,1)
   mkstat=1 : End
  Else
   Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
   If [M]ACCDAT(NOL)<>[F:HAE]ACCDAT
    [M]ACCDAT(NOL) = [F:HAE]ACCDAT : Affzo [M]ACCDAT(NOL)
   Endif
   If [M]REF(NOL)<>[F:HAE]REF
    [M]REF(NOL) = [F:HAE]REF : Affzo [M]REF(NOL)
   Endif
   If [M]BANCIB(NOL)<>[F:HAE]BANCIB
    [M]BANCIB(NOL) = [F:HAE]BANCIB : Affzo [M]BANCIB(NOL)
   Endif
   If [M]DES(NOL)<>[F:DAE]DES
    [M]DES(NOL) = [F:DAE]DES : Affzo [M]DES(NOL)
   Endif
   If [F:DAE]AMTFLG<>0
    MNT = [F:DAE]AMTLED1
   Else
    MNT = [F:DAE]AMTLED
   Endif
   If [M]AMTLED(NOL)<>MNT
    [M]AMTLED(NOL) = MNT : Affzo [M]AMTLED(NOL)
   Endif
   If [F:DAE]SNS=1
    SENS = 1
   Else
    SENS = 2
   Endif
   If SENS<>[M]SNS(NOL)
    [M]SNS(NOL) = SENS
    If SENS=1 : [M]SNS2(NOL) = "D" : Else [M]SNS2(NOL) = "C" : Endif
    Affzo [M]SNS(NOL),SNS2(NOL)
   Endif
  Endif
 Endif
Endif
End

Subprog AVANT_NBLIG
[M]OLDCHK = [M]CHK(nolign-1)
End

Subprog APRES_NBLIG
Local Decimal MTTOT
Local Integer SENSTOT, NOL
Local Integer STAT

NOL = nolign-1
## C'est juste le code pointage qui change
If [M]OLDCHK<>"" & [M]CHK(NOL)<>"" : End : Endif

## Crédit => -1 / Debit=>+1
If [M]SNS(NOL)=2 : SENSTOT = -1 : Else : SENSTOT = 1 : Endif

## Recherche du montant dans la devise de la banque
Case [M]CUR
 When [M]CURLED      : MTTOT = SENSTOT*[M]AMTLED(NOL)
 When [M]BANCUR(NOL) : MTTOT = SENSTOT*[M]AMTBNQ(NOL)
 When Default  :
  Call CONVERT([M]CURLED,[M]CUR,[M]CURLED,1,[M]ACCDAT(NOL),[M]AMTLED(NOL),MTTOT,STAT) From TRTDEV
  If !STAT
   If [M]SNS(NOL)=2 : SENSTOT = -1 : Else : SENSTOT = 1 : Endif
   MTTOT = SENSTOT*MTTOT
  Endif
Endcase

## Pointage : On ajoute le montant au total pointage
## Suppression du pointage : On retranche le montant du total pointage
If [M]CHK(NOL)<>"" & [M]OLDCHK=""   : # Pointage
 If [M]SNSCHK = "C"
  [M]TOTCHK -= MTTOT
  If [M]TOTCHK<=0
   [M]SNSCHK = "D"
   [M]TOTCHK = -[M]TOTCHK
  Endif
 Else
  [M]TOTCHK += MTTOT
  If [M]TOTCHK<0
   [M]SNSCHK = "C"
   [M]TOTCHK = -[M]TOTCHK
  Else [M]SNSCHK= "D"
  Endif
 Endif
Elsif [M]OLDCHK<>"" & [M]CHK(NOL)="" : # Dépointage
 If [M]SNSCHK = "C"
  [M]TOTCHK += MTTOT
  If [M]TOTCHK<=0
   [M]SNSCHK = "D"
   [M]TOTCHK = -[M]TOTCHK
  Endif
 Else
  [M]TOTCHK -= MTTOT
  If [M]TOTCHK<0
   [M]SNSCHK = "C"
   [M]TOTCHK = -[M]TOTCHK
  Else [M]SNSCHK = "D"
  Endif
 Endif
Endif

Affzo [M]TOTCHK,SNSCHK
End

Subprog ACCES_POINTAGE(OK,BANQUE)
Variable Integer OK
Value Char BANQUE()
OK = 1
If !clalev([F:BANK]): Local File BANK     [BAN] : Endif
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
If GNBAUZ=0 : OK = 0 : End : Endif
Read [BAN]BAN0=BANQUE
If GUSRFCY(1)<>"\"
 If [F:BAN]FCY<>""
  If !find([F:BAN]FCY,GUSRFCY(1..GNBAUZ))
   OK = 0 : End
  Endif
 Else
  Call CONTALLFCY([F:BAN]CPY) From CPTSUB
  If mkstat
   OK = 0 : End
  Endif
 Endif
Endif

If dim([F:BAN]ACS)>0 & [F:BAN]ACS<>""
 Call CONTEXE([F:BAN]ACS) From CPTSUB
 If mkstat : OK = 0 : End : Endif
Endif
End

Subprog BANDEF(BANK)
Variable Char    BANK()
If GBANDEF=""
 If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
 Read [AUS]CODUSR = GPROFIL
 Call PARAMUTIL("BANKDEF",BANK,"","") From SUBAUS
Else
 BANK = GBANDEF
Endif
End

#*X3-66556 Subprog SOLDEBAL(DEV,SOC,SITE,CPT,BPR,SENS,DATSOL,MTBAL)
#*X3-66556  Value    Char DEV(),SOC(),SITE(),CPT(),BPR()
Subprog SOLDEBAL(DEV,SOC,SITE,CPT,BANBPR,SENS,DATSOL,MTBAL)
Value    Char DEV(),SOC(),SITE(),CPT(),BANBPR()
Variable Integer SENS()
Value    Date    DATSOL
Variable Decimal MTBAL
Local Decimal EXERCICE, PERIODE, PDEB, PFIN, PMAX, EDEB, EFIN, MTDES
Local Date    DATECT
Local Integer FLECT, STAT

If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif

# Le pointage s'effectue uniquement sur le référentiel générale principal
Local Char COALED(GLONCOA), CURLED(GLONCUR)
If SITE<>""
 Call GETSOC(SITE) From DEVSUB
Else
 Call SETMAINREF(SOC,GTYPGEN,GTYPANA) From CPTDIV
Endif
Call LECLED(SOC,GTYPGEN,COALED,CURLED) From CPTDIV

MTBAL=0
Call GETPERSOC(SOC,GTYPGEN,DATSOL,EFIN,PERIODE) From CPTSUB
If DATSOL = [F:PER]PEREND
 PFIN = PERIODE : FLECT = 0
Else
 PFIN = PERIODE-1 : FLECT = 1 : DATECT = [F:PER]PERSTR
Endif
Filter [FIY] Where CPY=SOC & LEDTYP=GTYPGEN & FIYSTA=2
Read [FIY]FIY0 First
Filter [FIY]
EDEB = [F:FIY]FIYNUM
If EFIN<EDEB : EDEB = EFIN : Endif
PMAX = dim([F:BAL]DEB)-1
For EXERCICE=EDEB To EFIN
 Gosub CUMSOLDAT
Next
If FLECT
 Call LECTURE("GAC",CPT,COALED) From CONTOBJ
 If [F:GAC]CUR<>""
  #*X3-66556 For [DAE]DAE3 Where ACC=CPT & BPR=BPR & ACCDAT>=DATECT & ACCDAT<=DATSOL & CPY=SOC & CUR=[F:GAC]CUR & LEDTYP=GTYPGEN
  For [DAE]DAE3 Where ACC=CPT & BPR=BANBPR & ACCDAT>=DATECT & ACCDAT<=DATSOL & CPY=SOC & CUR=[F:GAC]CUR & LEDTYP=GTYPGEN
   If (SITE="" | SITE=[F:DAE]FCYLIN)
    Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
    If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
     MTBAL += [F:DAE]SNS*[F:DAE]AMTCUR
    Endif
   Endif
  Next
 Else
  #*X3-66556 For [DAE]DAE3 Where ACC=CPT & BPR=BPR & ACCDAT>=DATECT & ACCDAT<=DATSOL & CPY=SOC & LEDTYP=GTYPGEN
  For [DAE]DAE3 Where ACC=CPT & BPR=BANBPR & ACCDAT>=DATECT & ACCDAT<=DATSOL & CPY=SOC & LEDTYP=GTYPGEN
   If (SITE="" | SITE=[F:DAE]FCYLIN)
    Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
    If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
     Case DEV
      When [L]CURLED  : MTBAL += [F:DAE]SNS*[F:DAE]AMTLED
      When [F:DAE]CUR : MTBAL += [F:DAE]SNS*[F:DAE]AMTCUR
      When Default  :
       Call CONVERT([L]CURLED,DEV,[L]CURLED,1,[F:HAE]ACCDAT,[F:DAE]AMTLED,MTDES,STAT) From TRTDEV
       If !STAT
        MTBAL += [F:DAE]SNS*MTDES
       Endif
     Endcase
    Endif
   Endif
  Next
 Endif
Endif
If MTBAL>=0
 SENS = 1
Else
 MTBAL = -MTBAL
 SENS = 2
Endif
End

$CUMSOLDAT
# Solde : compte en banque dans la devise de banque
##*X3-66556 Filter [BAL] Where LEDTYP=GTYPGEN & CPY=SOC & FCY=SITE & FIY=EXERCICE & ACC=CPT & BPR=[L]BPR
Filter [BAL] Where LEDTYP=GTYPGEN & CPY=SOC & FCY=SITE & FIY=EXERCICE & ACC=CPT & BPR=[L]BANBPR
For [BAL]BAL0
 If EDEB=EFIN
  If PFIN>0
   Case DEV
     When [F:BAL]CUR    : MTBAL += sum([F:BAL]DEB(0..PFIN))-sum([F:BAL]CDT(0..PFIN))
     When [F:BAL]CURLED : MTBAL += sum([F:BAL]DEBLED(0..PFIN))-sum([F:BAL]CDTLED(0..PFIN))
   Endcase
  Endif
 Elsif EXERCICE=EDEB
  Case DEV
    When [F:BAL]CUR    : MTBAL += sum([F:BAL]DEB(0..PMAX))-sum([F:BAL]CDT(0..PMAX))
    When [F:BAL]CURLED : MTBAL += sum([F:BAL]DEBLED(0..PMAX))-sum([F:BAL]CDTLED(0..PMAX))
  Endcase
 Elsif EXERCICE=EFIN
  Case DEV
    When [F:BAL]CUR    : MTBAL += sum([F:BAL]DEB(1..PFIN))-sum([F:BAL]CDT(1..PFIN))
    When [F:BAL]CURLED : MTBAL += sum([F:BAL]DEBLED(1..PFIN))-sum([F:BAL]CDTLED(1..PFIN))
  Endcase
 Else
  Case DEV
    When [F:BAL]CUR    : MTBAL += sum([F:BAL]DEB(1..PMAX))-sum([F:BAL]CDT(1..PMAX))
    When [F:BAL]CURLED : MTBAL += sum([F:BAL]DEBLED(1..PMAX))-sum([F:BAL]CDTLED(1..PMAX))
  Endcase
 Endif
Next
Filter [BAL]
Return

