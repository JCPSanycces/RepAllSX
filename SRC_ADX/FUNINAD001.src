#<AdxTL>@(#)11.0.0.0 $Revision$
########################################
Subprog AP_TOUS(VALEUR)
Variable Integer    VALEUR()
If (VALEUR=2) Then
  [M]MEND=0
  [M]MENA=0
  Diszo [M]MEND,MENA
  Affzo [M]MEND,MENA
Else
  If [M]MEND=0 : [M]MEND=1 : Endif
  If [M]MENA=0 : [M]MENA=9999 : Endif
  Actzo [M]MEND,MENA
  Affzo [M]MEND,MENA
Endif
End
########################################
Subprog AS_MEND(VALEUR)
Variable Decimal VALEUR
If [M]TOUS=2
  mkstat=2
Endif
End

########################################
Subprog AP_MEND(VALEUR)
Variable Decimal VALEUR
If [M]TOUS<>2 and VALEUR > [M]MENA
  GMESSAGE=mess(109,150,1)
  mkstat=2
Endif
End

########################################
Subprog AS_MENA(VALEUR)
Variable Decimal VALEUR
If [M]TOUS=2
  mkstat=2
Endif
End

########################################
Subprog AP_MENA(VALEUR)
Variable Decimal VALEUR
If [M]TOUS<>2 and VALEUR < [M]MEND
  GMESSAGE=mess(109,150,1)
  mkstat=2
Endif
End

########################################
