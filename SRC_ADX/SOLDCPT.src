#<AdxTL>@(#)1.0.0.0 $Revision$
## Action SOLDCPT
Local Char PARBOUT(30)(1..15)
Local Char VALBOUT(30)
PARBOUT(1) = "411900"
PARBOUT(5) = "APN"
PARBOUT(6) = "ASN"
PARBOUT(7) = "20090101"
PARBOUT(8) = "20101231"
PARBOUT(9) = "EUR"
PARBOUT(10) = "1"
Call SAISIE_CHAR(VALBOUT,PARBOUT,"DSOLDCPT","SOLDCPT","") From GSAISIE
End


$ACTION
Case ACTION
 When "OUVRE" : Gosub VERIF
 When "DEBUT" : Gosub SOLDE
Endcase
Return

$VERIF
Local Integer OK, LEDTYP
Local Date    DATDEB, DATFIN
Local Char    CPY (GLONCPY)
CPY    = PARAM(5)
DATDEB = PARAM(7)
DATFIN = PARAM(8)
LEDTYP = val(PARAM(10))
Call CONTEXE(CPY,LEDTYP,DATDEB,DATFIN,OK) From CONSSUB
If !OK : # Période incompatibles sur la société
 GERR=1 : GMESSAGE = mess(11,101,1)-CPY : FIN=1 : Return
Endif

Onerrgo ERREUR From CONTROLE
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:BAL])=0 : Local File BALANCE    [BAL] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:GSC])=0 : Local File GRPSAC     [GSC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
If clalev([F:CLS])=0 : Local File GACCCLS    [CLS] : Endif
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Endif
Return

$SOLDE
Local Char    CPT(GLONGAC), SAC(GLONSAC), GRPSAC(GLONGSC),
&             BPR(GLONBPR), CPY(GLONCPY), FCY(GLONFCY),
&             PLAN(GLONCOA), DEVISE(GLONCUR), WLED(GLONCOA),DEVLED(GLONCUR)
Local Date    DATDEB, DATFIN,DDEB, DFIN
Local Integer EDEB, EFIN, NBSITE, OK, LEDTYP
Local Decimal EXERCICE, PERIODE
Local Libelle XDEV
NBSITE = max(1,GNBSITE)
Local Char    TSITE(GLONFCY)(1..NBSITE)
NBSITE = 0
XDEV   = 0
CPT    = PARAM(1)
SAC    = PARAM(2)
GRPSAC = PARAM(3)
BPR    = PARAM(4)
CPY    = PARAM(5)
FCY    = PARAM(6)
DATDEB = PARAM(7)
DATFIN = PARAM(8)
DEVISE = PARAM(9)
LEDTYP = val(PARAM(10))
PLAN   = PARAM(11)

Call LECLED(CPY,LEDTYP,WLED,DEVLED) From CPTDIV
Call LECTURE("CPY",[L]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2 : # Société Juridique
 Call GETPERSOC(CPY,LEDTYP,DATDEB,EXERCICE,PERIODE) From CPTSUB
 EDEB = EXERCICE
 Call GETPERSOC(CPY,LEDTYP,DATFIN,EXERCICE,PERIODE) From CPTSUB
 EFIN = EXERCICE
 Call SOLDCPT(LEDTYP,PLAN,GRPSAC,SAC,CPT,BPR,CPY,FCY,DEVLED,DEVISE,EDEB,EFIN,0)
Else
 For [FGR]FGR0 Where CPY = [L]CPY
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
  Filter [FIY] Where CPY=[F:FCY]LEGCPY & LEDTYP=[L]LEDTYP
  Read [FIY]FIY0 First
  If DATDEB>=[F:FIY]FIYSTR : DDEB=DATDEB : Else DDEB=[F:FIY]FIYSTR : Endif
  Read [FIY]FIY0 Last
  If DATFIN<=[F:FIY]FIYEND : DFIN=DATFIN : Else DFIN=[F:FIY]FIYEND : Endif
  Filter [FIY]
  If DDEB<=DFIN
   NBSITE+=1
   TSITE(NBSITE) = [F:FGR]FCY
  Endif
 Next : # [FGR]
 Call SOLDCPT2(LEDTYP,PLAN,GRPSAC,SAC,CPT,BPR,NBSITE,TSITE,DEVLED,DEVISE,DATDEB,DATFIN,XDEV)
Endif
Affzo
Return

Subprog SOLDCPT(LEDTYP,PLAN,GROUPE,COLLEC,COMPTE,TIERS,SOCIETE,SITE,DEVLED,DEVSEL,EXEDEB,EXEFIN,CTVDEV)
Value Integer LEDTYP
Value Char    PLAN
Value Char    GROUPE
Value Char    COLLEC
Value Char    COMPTE
Value Char    TIERS
Value Char    SOCIETE
Value Char    SITE
Value Char    DEVLED
Value Char    DEVSEL
Value Integer EXEDEB
Value Integer EXEFIN
Value Libelle CTVDEV
Local Integer II
Raz [M:SOL1]
Gosub SOL_CPT
For II=0 To [M:SOL1]NBLIG-1
 [M:SOL1]SOLDEB(II) = SOL_DEB(II)
 [M:SOL1]SOLCRE(II) = SOL_CRE(II)
 [M:SOL1]TOTDEB(II) = TOT_DEB(II)
 [M:SOL1]TOTCRE(II) = TOT_CRE(II)
 [M:SOL1]CTVSOLDEB(II) = CTVSOL_DEB(II)
 [M:SOL1]CTVSOLCRE(II) = CTVSOL_CRE(II)
 [M:SOL1]CTVTOTDEB(II) = CTVTOT_DEB(II)
 [M:SOL1]CTVTOTCRE(II) = CTVTOT_CRE(II)
Next II
End

Subprog SOLDCPT2(LEDTYP,PLAN,GROUPE,COLLEC,COMPTE,TIERS,NBSITE,TSITE,DEVLED,DEVSEL,DATDEB,DATFIN,CTVDEV)
Value Integer LEDTYP
Value Char    PLAN
Value Char    GROUPE
Value Char    COLLEC
Value Char    COMPTE
Value Char    TIERS
Value Integer NBSITE
Value Char    TSITE()(1..)
Value Char    DEVLED
Value Char    DEVSEL
Value Date    DATDEB, DATFIN
Value Libelle CTVDEV
Local Char    SITE(GLONFCY), SOCIETE(GLONCPY)
Local Integer JJ, II , REPONSE
Local Decimal EXEDEB, EXEFIN
Local Decimal EXER, PERIO
Raz [M:SOL1]
For JJ=1 To NBSITE
 SITE = TSITE(JJ)
 Call LECTURE("FCY",SITE,"") From CONTOBJ
 SOCIETE = [F:FCY]LEGCPY
 Call GETPERSOC(SOCIETE,LEDTYP,DATDEB,EXER,PERIO) From CPTSUB
 EXEDEB = EXER
 Call GETPERSOC(SOCIETE,LEDTYP,DATFIN,EXER,PERIO) From CPTSUB
 EXEFIN = EXER
 Gosub SOL_CPT
 For II=0 To [M:SOL1]NBLIG-1
  # On doit avoir le même nombre de lignes car les périodes sont les mêmes...
  # ($CONTPER)
  [M:SOL1]SOLDEB(II) += SOL_DEB(II)
  [M:SOL1]SOLCRE(II) += SOL_CRE(II)
  [M:SOL1]TOTDEB(II) += TOT_DEB(II)
  [M:SOL1]TOTCRE(II) += TOT_CRE(II)
  [M:SOL1]CTVSOLDEB(II) += CTVSOL_DEB(II)
  [M:SOL1]CTVSOLCRE(II) += CTVSOL_CRE(II)
  [M:SOL1]CTVTOTDEB(II) += CTVTOT_DEB(II)
  [M:SOL1]CTVTOTCRE(II) += CTVTOT_CRE(II)
 Next II
Next JJ
End

$SOL_CPT
Local Integer I , J , K , SPSTAT , EXERCICE , LIGDEB , GRP
Local Char    BALSIT(GLONFCY) , BALACC(GLONGAC), BALBPR(GLONBPR), DEVSOC(GLONCUR)
Local Decimal SOLDINI, CTVSOLDINI
Local Decimal SOL_DEB(0..dim([M:SOL1]DAT)-1)
Local Decimal SOL_CRE(0..dim([M:SOL1]DAT)-1)
Local Decimal TOT_DEB(0..dim([M:SOL1]DAT)-1)
Local Decimal TOT_CRE(0..dim([M:SOL1]DAT)-1)
Local Decimal CTVSOL_DEB(0..dim([M:SOL1]DAT)-1)
Local Decimal CTVSOL_CRE(0..dim([M:SOL1]DAT)-1)
Local Decimal CTVTOT_DEB(0..dim([M:SOL1]DAT)-1)
Local Decimal CTVTOT_CRE(0..dim([M:SOL1]DAT)-1)
Local Integer PMAX

BALACC = COMPTE
BALBPR = TIERS

If SITE=""
 BALSIT=""
Else
 BALSIT = SITE
Endif

Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
DEVSOC = [F:CPY]ACCCUR
GRP=([F:CPY]CPYLEGFLG=1)

Filter [FIY] Where CPY=SOCIETE & FIYSTA=2 & LEDTYP=[L]LEDTYP
Read [FIY]FIY0 First
Filter [FIY]
EDEB = [F:FIY]FIYNUM
If EXEDEB = 0 : EXEDEB = 1 : Endif
If EXEDEB<EDEB : EDEB = EXEDEB : Endif
EFIN = EXEFIN
PMAX = dim([F:BAL]DEB)-1

[M:SOL1]NBLIG = 0
Raz SOLDINI, CTVSOLDINI
Raz SOL_DEB, SOL_CRE, TOT_DEB, TOT_CRE
Raz CTVSOL_DEB, CTVSOL_CRE, CTVTOT_DEB, CTVTOT_CRE

Call LEC_COA(PLAN) From CPTLEC
For EXERCICE=EDEB To EFIN

 If EXERCICE>=EXEDEB
  LIGDEB = [M:SOL1]NBLIG
  For [PER]PER0 Where [F:PER]CPY=SOCIETE & [F:PER]FIYNUM=EXERCICE & [F:PER]LEDTYP=[L]LEDTYP
   [M:SOL1]DAT([M:SOL1]NBLIG)= [F:PER]PEREND
   [M:SOL1]NBLIG += 1
  Next
 Endif

 If EXERCICE>EXEDEB
  For I=LIGDEB To [M:SOL1]NBLIG-1
   SOL_DEB(I) = SOL_DEB(LIGDEB-1)
   CTVSOL_DEB(I) = CTVSOL_DEB(LIGDEB-1)
  Next I
 Elsif EXERCICE=EXEDEB
  For I=LIGDEB To [M:SOL1]NBLIG-1
   SOL_DEB(I) = SOLDINI
   CTVSOL_DEB(I) = CTVSOLDINI
  Next I
 Endif

 If COMPTE<>""
  Call LEC_GAC(COMPTE, PLAN) From CPTLEC
  Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
  If [F:CLS]ERA=2 or EXERCICE=EFIN
   BALACC=COMPTE : Raz BALBPR : Gosub CALBAL
  Endif
 Else
  If COLLEC<>""
   Read [GAC]GAC1 = PLAN;COLLEC
   Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
   If [F:CLS]ERA=2 or EXERCICE=EFIN
    BALACC=[F:GAC]ACC : BALBPR=TIERS : Gosub CALBAL
   Endif
  Elsif GROUPE<>""
   For [GSC]GSC0 Where COA=PLAN & GRU=GROUPE
    Read [GAC]GAC1 = PLAN;[F:GSC]SAC
    Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
    If [F:CLS]ERA=2 or EXERCICE=EFIN
     BALACC=[F:GAC]ACC : BALBPR=TIERS : Gosub CALBAL
    Endif
   Next
  Else
   For [GAC]GAC1 Where COA=PLAN & ACCSHO>""
    Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
    If [F:CLS]ERA=2 or EXERCICE=EFIN
     BALACC=[F:GAC]ACC : BALBPR=TIERS : Gosub CALBAL
    Endif
   Next
  Endif
 Endif
Next EXERCICE

For I=0 To [M:SOL1]NBLIG-1
 If SOL_DEB(I)<0
  SOL_CRE(I) = -SOL_DEB(I) : SOL_DEB(I) = 0
 Endif
 If CTVSOL_DEB(I)<0
  CTVSOL_CRE(I) = -CTVSOL_DEB(I) : CTVSOL_DEB(I) = 0
 Endif
Next I
Return

$CALBAL
If DEVSEL<>"" & !GRP
 Filter [BAL] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & FCY=BALSIT & ACC=BALACC & BPR=BALBPR & FIY=EXERCICE
&                  & CUR=DEVSEL
Else
 Filter [BAL] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & FCY=BALSIT & ACC=BALACC & BPR=BALBPR & FIY=EXERCICE
Endif
For [BAL]BAL0
 Gosub CUMSOLDE
Next
Filter [BAL]
Return


$CUMSOLDE
#72595 : Ajout du critère sur DEVSEL pour ne pas cumuler sur des devises
#       différentes ce qui n'aurait pas de sens.
If EXERCICE<EXEDEB
 If EXERCICE=EDEB
  If DEVSEL<>"" & !GRP
   SOLDINI += sum([F:BAL]DEB(0..PMAX))-sum([F:BAL]CDT(0..PMAX))
  Endif
  CTVSOLDINI += sum([F:BAL]DEBLED(0..PMAX))-sum([F:BAL]CDTLED(0..PMAX))
 Else
  If DEVSEL<>"" & !GRP
   SOLDINI += sum([F:BAL]DEB(1..PMAX))-sum([F:BAL]CDT(1..PMAX))
  Endif
  CTVSOLDINI += sum([F:BAL]DEBLED(1..PMAX))-sum([F:BAL]CDTLED(1..PMAX))
 Endif
Else
 For I=LIGDEB To [M:SOL1]NBLIG-1
  J = I-LIGDEB+1
  If EXERCICE=EDEB
   If DEVSEL<>"" & !GRP
    SOL_DEB(I) += sum([F:BAL]DEB(0..J))-sum([F:BAL]CDT(0..J))
   Endif
   CTVSOL_DEB(I) += sum([F:BAL]DEBLED(0..J))-sum([F:BAL]CDTLED(0..J))
  Else
   If DEVSEL<>"" & !GRP
    SOL_DEB(I) += sum([F:BAL]DEB(1..J))-sum([F:BAL]CDT(1..J))
   Endif
   CTVSOL_DEB(I) += sum([F:BAL]DEBLED(1..J))-sum([F:BAL]CDTLED(1..J))
  Endif
  If DEVSEL<>"" & !GRP
   TOT_DEB(I) += [F:BAL]DEB(J)
   TOT_CRE(I) += [F:BAL]CDT(J)
  Endif
  CTVTOT_DEB(I) += [F:BAL]DEBLED(J)
  CTVTOT_CRE(I) += [F:BAL]CDTLED(J)
 Next I
Endif
Return

