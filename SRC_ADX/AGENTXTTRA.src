#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AGENTXTTRA","",2,"") From GTRAITE
End

#########################################
$ACTION
Case ACTION
 When "AVANT_PAR" : Gosub AVANT_PAR
 When "EXEC"      : Gosub EXEC
Endcase
Return

#########################################
$AVANT_PAR
TIT = mess(128,126,1) : # Génération fichiers textes traduisibles
TMP = 1
Return

#########################################
$EXEC
TRA = 1
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call GENERE(nomap)
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

#########################################
Subprog GENERE(DOSSIER)
Value Char    DOSSIER

Local File =DOSSIER+".ATEXTRA"  [AXX]
Local File =DOSSIER+".ATEXTRA"  [AX2]
Local File =DOSSIER+".TABLAN"   [TLA]
Local File =DOSSIER+".ADOVAL"   [ADW]
Local File =DOSSIER+".ATABLE"   [ATB]

Local Integer LONG , TRAD , NBFIC , I , STAT , NBLAN
Local Char    LAN(GLONLAN) , FICHIER(GDIMFIC) , CHAINE(250) , WITEMTRA(10) , LANDES(GLONDES)
Local Char    ORDRE(250) , FIC(20)(1..500) , MACHINE(250) , APPLI(250) , HISDOS(250)
Local Char    TBLAN(GLONLAN)(1..300)

Read [ADW]ADW0 = "";"";"ITEMTRA"
If !fstat
 WITEMTRA = [F:ADW]VALEUR
Endif

LONG = 90 : # Longueur de la ligne contenant les éléments de clé

# On commence à effacer tous les fichiers textra* pour éviter des cohérences de transfert sur le poste client

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Read [ADW]ADW0 = "";"";"HISDOS"
If !fstat & [F:ADW]VALEUR<>""
 HISDOS = [F:ADW]VALEUR
 If MACHINE<>""
  HISDOS = MACHINE+"@"+HISDOS
 Endif
Endif

FICHIER = filpath("","","",DOSSIER)
Call MACHINE(FICHIER,MACHINE,CHAINE) From ORDSYS
ORDRE = 'lsadx -a'-APPLI-CHAINE
Call SYSTEME2(MACHINE,ORDRE,'',NBFIC,FIC) From ORDSYS
NBFIC = min(NBFIC,dim(FIC))
For I=1 To NBFIC
 If left$(FIC(I),6)="textra"
  FICHIER = filpath("",FIC(I),"",DOSSIER)
  Call EFFACE(FICHIER,STAT) From ORDSYS
  If HISDOS<>""
   FICHIER = filpath("",FIC(I),"",HISDOS)
   Call EFFACE(FICHIER,STAT) From ORDSYS
  Endif
 Endif
Next I

# Puis on génère ces fichiers sous la forme textra+langue.tmp pour éviter les transferts de fichier
# pas complément terminé

NBLAN = 0
For [TLA]
 LAN = ""
 Filter [AXX] Where LANGUE=[F:TLA]LAN & CODFIC<>""
 For [AXX]AXX0(1)
  If dim([F:ATB]GENTRA)>0
   Read [ATB]CODFIC = [F:AXX]CODFIC
   If !fstat & [F:ATB]GENTRA=1
    GEN = 1
   Else
    GEN = 2
   Endif
  Else
   GEN = 2
  Endif
  # Prise en compte des désignations articles / param général ITEMTRA 06/12/01
  # Obsolète (MB 29.3.6 )
  If [F:AXX]CODFIC="ITMMASTER" & WITEMTRA<>""
   GEN = val(WITEMTRA)
  Endif
  If GEN=2
   For [AXX]AXX0
    If LAN=""
     LAN = tolower([F:AXX]LANGUE)
     NBLAN += 1
     TBLAN(NBLAN) = LAN
     Read [AX2]AXX0 = "TABLAN";"INTDES";GLANGUE;[F:TLA]LAN;""
     LANDES = [F:AX2]TEXTE    
     Call ECR_TRACE(mess(128,126,1)-LANDES,0) From GESECRAN : # Maj des textes traduisibles
     FICHIER = filpath("","textra"+LAN,"tmp",DOSSIER)
     Openo FICHIER,0 Using [TRAD]
     Iomode adxifs "" Using [TRAD]
     Iomode adxirs chr$(10) Using [TRAD]
     Iomode adxium GUTF8 Using [TRAD]
    Endif
    CHAINE = [F:AXX]CODFIC+"~"+[F:AXX]ZONE+"~"+[F:AXX]IDENT1+"~"+[F:AXX]IDENT2+"~"
    Wrseq format$("K:"+num$(LONG)+"X",CHAINE) Using [TRAD]
    Wrseq [F:AXX]TEXTE Using [TRAD]
    Wrseq "|" Using [TRAD]
   Next AXX
  Endif
 Next AXX(1)
 Filter [AXX]
 If LAN<>""
  Openo Using [TRAD]
 Endif
Next TLA

# Enfin on move les .tmp (et on copie dans le dossier histo)

For I=1 To NBLAN
 Call MOVE(filpath("","textra"+TBLAN(I),"tmp",DOSSIER),filpath("","textra"+TBLAN(I),"",DOSSIER),STAT)
& From ORDSYS 
 If HISDOS<>""
  Call COPIE(filpath("","textra"+TBLAN(I),"",DOSSIER),filpath("","textra"+TBLAN(I),"",HISDOS),STAT)
& From ORDSYS 
 Endif
Next I

End

