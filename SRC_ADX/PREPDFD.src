#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################################
# Script : PREPDFD
#
# Fonction  :  Deferred depreciations
#      1- Loading the temporary table TMPDFD  for report DFDDPE (Deferred depreciations)
#########################################################################################
#    Modifications :
# UUUUU jj.mm.aaaa nnnnnn_nn Cccccccccccccccccccccccccccccccccccccccccccccccccccccccc
# MDJ   03.02.2016 114161    Intitulés Code comptable absents (en sqlserver)
# MDJ  02.12.2014 FQ104327
#########################################################################################$ACTION

    Case ACTION
        When "OUVRE" :   Gosub OUVRE
        When "EXEC"  :   Gosub EXEC
        When "FIN"   :   Gosub FIN
    Endcase
Return
######################################################################################
$OUVRE
#=============================================================================
# PREPDFD processing : loading the table TMPTDF
#=============================================================================
If clalev([F:TDF])=0   :  Local File TMPDFD     [TDF]  : Endif
If clalev([F:TDFM])=0  :  Local File TMPDFD     [TDFM] : Endif

If clalev([F:FAS])=0   :  Local File FXDASSETS  [FAS]  : Endif
If clalev([F:CCE])=0   :  Local File CACCE      [CCE]  : Endif
If clalev([F:DSP])=0   :  Local File CADSP      [DSP]  : Endif

If clalev([F:CPY])=0   :  Local File COMPANY    [CPY]  : Endif
If clalev([F:CNX])=0   :  Local File CONTEXT    [CNX]  : Endif
If clalev([F:FIY])=0   :  Local File FISCYEAR   [FIY]  : Endif
#  Accounts depreciation plan
If clalev([F:DEPC])=0  :  Local File DEPREC     [DEPC] : Endif    # DEPREC
If clalev([F:PCE])=0   :  Local File DEPREC     [PCE]  : Endif    # DEPREC FY  Accounts depreciation plan
If clalev([F:PCP])=0   :  Local File DEPREC     [PCP]  : Endif    # DEPREC PER Accounts depreciation plan

# Finance depreciation plan
If clalev([F:DEPF])=0  :  Local File DEPREC     [DEPF] : Endif    # DEPREC
If clalev([F:PFE])=0   :  Local File DEPREC     [PFE]  : Endif    # DEPREC  FY  Finance depreciation plan
If clalev([F:PFP])=0   :  Local File DEPREC     [PFP]  : Endif    # DEPREC  PER Finance depreciation plan
If clalev([F:FCY])=0   :  Local File FACILITY   [FCY]  : Endif    # Financial site

If clalev([F:CAC])=0   :  Local File GACCCODE   [CAC]  : Endif    # Accounting code

If clalev([F:GACC])=0  :  Local File GACCOUNT   [GACC] : Endif    # CoA account
If clalev([F:GACI])=0  :  Local File GACCOUNT   [GACI] : Endif    # IFRS account

If clalev([F:ADI])=0   :  Local File ATABDIV    [ADI]  : Endif    # Miscellaneous table
If clalev([F:AFF])=0   :  Local File AFCTFCY    [AFF]  : Endif    # Site profile function

If clalev([FAM])=0     :  Local File FASFAM     [FAM]  : Endif    # Families

Return
######################################################################################
$FIN

Unlock PREPDFD

Return
######################################################################################
$EXEC

Lock PREPDFD With lockwait = 3
If fstat
   Return
Endif

Gosub MAJ_TMPTDF

Return
###################################################
$MAJ_TMPTDF
#-------------------------------------------------------------- --------------#
#-- Creation of a temporary table for the report  DEPDFD                   ---#
#-----------------------------------------------------------------------------#

   Gosub OUVRE

    Local Integer I, I_COA
    Local Integer RCNX, WCNX
    Local Char    LCPYDEB (GLONCPY)    # Company start
    Local Char    LCPYFIN (GLONCPY)    # Company end
    Local Char    LFCYDEB (GLONFCY)    # Site start
    Local Char    LFCYFIN (GLONFCY)    # Site end
    Local Char    LCCPTDEB (GLONCAC)   # Accounting codes start
    Local Char    LCCPTFIN (GLONCAC)   # Accounting codes end
    Local Char    LACCDEB (GLONGAC)    # GL account start
    Local Char    LACCFIN (GLONGAC)    # GL account end
    Local Char    LIASACDEB (GLONGAC)  # IFRS account start
    Local Char    LIASACFIN (GLONGAC)  # IFRS account end
    Local Integer LTYPDETDEB           # Holding type start
    Local Integer LTYPDETFIN           # Holding type end
    Local Date    LDATDEB              # Date start
    Local Date    LDATFIN              # Date end
    Local Char    LREFDEB              # réf start
    Local Char    LREFFIN              # réf fin
    Local Integer LSITUAT              # Situation
    Local Integer LPLAN                # Depreciation plan
    Local Integer LENCOURS             # In progess ?
    Local Integer LACTIF               # Active ?
    Local Integer LSELENT              # Entry selection
    Local Integer LSELSOR              # Selection of the issued assets
    Local Date    LDATNULL : LDATNULL = [01/01/1900]
    Local Integer LBAS0                # Basis,total,nv set to=0 if issued ?
    Local Integer LTRI2                # Classification criterion 2
    Local Integer LTRI3                # Classification criterion 3
    Local Integer LDET                 # Detailed  ?
    Local Integer LEDTNUM              # Session identifier
    Local Char    LCRITERE  (250)      # Selection criterion
    Local Char    LCRITERE2 (250)      # Selection criterion
    Local Decimal WENDDPET
    Local Char    SCPY (GLONCPY)       # Company
    Local Char    SFCY (GLONFCY)       # Financial site
    Local Char    X3PRF                # User profile
    Local Char    X3FCT                # Function
    Global Char   GWCOA (GLONCOA)      # Chart of accounts

    If clalev([TDF])=0 : Local File TMPDFD [TDF] : Endif
    Trbegin [TDF]
    Delete [TDF] Where CREUSR = GUSER
    If fstat = 1
      #  "Problem in deleting the temporary file"
      Call MESSAGE (mess(155,197,1)) From GESECRAN
      Rollback
      Return
    Else
       Commit
    Endif

   Call GETPARAM("cpydeb",NBPAR,PARAMETRE,LCPYDEB)
   Call GETPARAM("cpyfin",NBPAR,PARAMETRE,LCPYFIN)

   Call GETPARAM("fcydeb",NBPAR,PARAMETRE,LFCYDEB)
   Call GETPARAM("fcyfin",NBPAR,PARAMETRE,LFCYFIN)
   Call GETPARAM("ccptdeb",NBPAR,PARAMETRE,LCCPTDEB)
   Call GETPARAM("ccptfin",NBPAR,PARAMETRE,LCCPTFIN)
   Call GETPARAM("accdeb",NBPAR,PARAMETRE,LACCDEB)
   Call GETPARAM("accfin",NBPAR,PARAMETRE,LACCFIN)
   Call GETPARAM("accifrsdeb",NBPAR,PARAMETRE,LIASACDEB)
   Call GETPARAM("accifrsfin",NBPAR,PARAMETRE,LIASACFIN)
   Call GETPARAM("typdetdeb",NBPAR,PARAMETRE,PARAM)    : LTYPDETDEB = val(PARAM)
   Call GETPARAM("typdetfin",NBPAR,PARAMETRE,PARAM)    : LTYPDETFIN = val(PARAM)
   Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM)       : LDATDEB    =  PARAM
   Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM)       : LDATFIN    =  PARAM
   Call GETPARAM("refdeb",NBPAR,PARAMETRE,LREFDEB)
   Call GETPARAM("reffin",NBPAR,PARAMETRE,LREFFIN)
   Call GETPARAM("situation",NBPAR,PARAMETRE,PARAM)    : LSITUAT    = val(PARAM)
   Call GETPARAM("situation",NBPAR,PARAMETRE,PARAM)    : LSITUAT    = val(PARAM)
 # Call GETPARAM("plan",NBPAR,PARAMETRE,PARAM)         : LPLAN      = val(PARAM)
   Call GETPARAM("encours",NBPAR,PARAMETRE,PARAM)      : LENCOURS   = val(PARAM)
   Call GETPARAM("actif",NBPAR,PARAMETRE,PARAM)        : LACTIF     = val(PARAM)
   Call GETPARAM("selentree",NBPAR,PARAMETRE,PARAM)    : LSELENT    = val(PARAM)
   Call GETPARAM("selbiensor",NBPAR,PARAMETRE,PARAM)   : LSELSOR    = val(PARAM)
   Call GETPARAM("biensor",NBPAR,PARAMETRE,PARAM)      : LBAS0      = val(PARAM)
   Call GETPARAM("tri2",NBPAR,PARAMETRE,PARAM)         : LTRI2      = val(PARAM)
   Call GETPARAM("tri3",NBPAR,PARAMETRE,PARAM)         : LTRI3      = val(PARAM)
   Call GETPARAM("detail",NBPAR,PARAMETRE,PARAM)       : LDET       = val(PARAM)
   Call GETPARAM("edtnum",NBPAR,PARAMETRE,PARAM)       : LEDTNUM    = val(PARAM)

   Call GETPARAM("X3PRF",NBPAR,PARAMETRE,X3PRF)
   Call GETPARAM("X3FCT",NBPAR,PARAMETRE,X3FCT)

   LPLAN= G301FIS

   LCRITERE = "1=1"
   For I=1 To NBPAR
      J=instr(1,[L]PARAMETRE(I),"=")
      If J
         [L]PARAM  = left$([L]PARAMETRE(I),J-1)
         [L]VALEUR = right$([L]PARAMETRE(I),J+1)
         Case [L]PARAM
            When "cpydeb" :
                  If LCPYDEB <> ""
                     LCRITERE =    "CPY>='"+LCPYDEB+"'"
                  Else
                     LCRITERE =    "CPY<='"+LCPYFIN+"'"
                  Endif
            When "cpyfin" :
                  If LCPYDEB <> ""
                     LCRITERE += "& CPY<='"+LCPYFIN+"'"
                  Endif
            When "fcydeb"     :     LCRITERE += "& FCY>='"+LFCYDEB+"'"
            When "fcyfin"     :     LCRITERE += "& FCY<='"+LFCYFIN+"'"
            When "ccptdeb"    :     LCRITERE += "& ACCCOD>='"+LCCPTDEB+"'"
            When "ccptfin"    :     LCRITERE += "& ACCCOD<='"+LCCPTFIN+"'"
            When "accdeb"     :     LCRITERE += "& GAC>='"+LACCDEB+"'"
            When "accfin"     :     LCRITERE += "& GAC<='"+LACCFIN+"'"
            When "accifrsdeb" :     LCRITERE += "& IASACC>='"+LIASACDEB+"'"
            When "accifrsfin" :     LCRITERE += "& IASACC<='"+LIASACFIN+"'"
            When "refdeb"     :     LCRITERE += "& AASREF>='"+LREFDEB+"'"
            When "reffin"     :     LCRITERE += "& AASREF<='"+LREFFIN+"'"
            When "encours"
                  If LENCOURS=1
                     LCRITERE2 =    "GACACN <3"
                  Else
                     LCRITERE2 =    "GACACN<>1"
                  Endif
            When "actif"
                  If LACTIF=1
                     LCRITERE2 +=    "& ENAFAS<>1"
                  Else
                     LCRITERE2 +=    "& ENAFAS=1"
                  Endif
            When "selentree"
                  Case LSELENT
                     When 1 :  LCRITERE2 +=  "& (AASIPTDAT<= ["+format$(GFMD,LDATFIN)+"]"
                               LCRITERE2 +=  "| ITSDAT   <= ["+format$(GFMD,LDATFIN)+"])"
                     When 2 :  LCRITERE2 +=  "& AASIPTDAT>= ["+format$(GFMD,LDATDEB)+"]"
                               LCRITERE2 +=  "& AASIPTDAT<= ["+format$(GFMD,LDATFIN)+"]"
                     When 3 :  LCRITERE2 +=  "& AASIPTDAT<  ["+format$(GFMD,LDATDEB)+"]"
                  Endcase
            When "selbiensor"
                  Case LSELSOR
                     When 1 :  LCRITERE2 +=  "& (ISSDAT  <= ["+format$(GFMD,LDATNULL)+"]"
                               LCRITERE2 +=  "| ISSDAT   >  ["+format$(GFMD,LDATNULL)+"])"
                     When 2 :  LCRITERE2 +=  "& (ISSDAT  <= ["+format$(GFMD,LDATNULL)+"]"
                               LCRITERE2 +=  "| ISSDAT   >  ["+format$(GFMD,LDATFIN)+"])"
                     When 3 :
                        If LSITUAT = 1
                               LCRITERE2 +=  "& ISSDAT   >= ["+format$(GFMD,LDATNULL)+"]"
                               LCRITERE2 +=  "& ISSDAT   <= ["+format$(GFMD,LDATFIN)+"]"
                        Else
                               LCRITERE2 +=  "& ISSDAT   >= ["+format$(GFMD,LDATNULL)+"]"
                        Endif
                  Endcase
         Endcase
      Endif
   Next
#--------------------------------
   If clalev([TDF])=0 : Local File TMPDFD [TDF] : Endif
   Trbegin [TDF]
   Delete [TDF] Where CREUSR = GUSER
   If fstat=1 | fstat>5
     Rollback
    Else
        Commit
   Endif

   #
   Trbegin [TDF]
   SCPY= ""
   SFCY= ""
   GWCOA= ""
   Filter [FAS] Where ( evalue(LCRITERE) &  evalue(LCRITERE2) )  and (OWNTYP >= LTYPDETDEB ) and (OWNTYP <= LTYPDETFIN ) Order By CPY
   For [FAS] With Stability
     If  LSELENT = 1 and
&        ([F:FAS]AASIPTDAT <= [F:FAS]ITSDAT)   and  ([F:FAS]AASIPTDAT > LDATFIN) or
&        ([F:FAS]AASIPTDAT > [F:FAS]ITSDAT)    and  ([F:FAS]ITSDAT    > LDATFIN)
         Goto NEXTFAS
     Endif
     If [F:FAS]CPY <> SCPY
        # Reading depreciation context
        Call GET_CNX_FROM_PLAN ([F:FAS]CPY, G301CPT, RCNX) From GLOBIENS
        WCNX=RCNX
        # Reading current FY
        Filter [FIY] Where CPY=[F:FAS]CPY and CNX=WCNX and DATSTRFIY=LDATDEB & DATENDFIY=LDATFIN
        Read [FIY]First
        Filter [FIY]
        SCPY= [F:FAS]CPY
        Read[CNX]CNX0= SCPY;WCNX
        If fstat=0
           I_COA = find(G301CPT,[F:CNX]PLNCAA(0..[F:CNX]NBPLC-1))
           If I_COA > 0
              GWCOA= [F:CNX]COA(I_COA-1)
          Endif
        Endif
     Endif

     If [F:FAS]FCY <> SFCY
       Read [AFF]AFF0 = [F:FAS]FCY;X3PRF;X3FCT
        If fstat <> 0
           Goto NEXTFAS
        Endif
        SFCY= [F:FAS]FCY
     Endif
     #1------------
     Raz[TDFM]
     [F:TDFM] = [F:FAS]
     [F:TDFM]COA = GWCOA
     #=========================================================
     # Recovery of the titles of fields
     #=========================================================
     Read [CPY]CPY0    = [F:FAS]CPY
     If fstat=0 :     [F:TDFM]CPYNAM    = [F:CPY]CPYNAM  : Endif
     Read [FCY]FCY0    = [F:FAS]FCY
     If fstat=0 :     [F:TDFM]FCYNAM    = [F:FCY]FCYNAM : Endif
     [F:TDFM]AASDES1   = [F:FAS]AASDES1
     # Issue 114161  READ[CAC]CAC0="15";[F:FAS]ACCCOD;GWCOA
     Read[CAC]CAC0=15;[F:FAS]ACCCOD;GWCOA
     If fstat=0
        Call LECTEXTRA([F:TDFM]ACCDES,"GACCCODE","DESTRA","15",[F:FAS]ACCCOD) From ATEXTRA
        # Issue 114161 [F:TDFM]ACCDES=[F:CAC]DESTRA
     Endif
     Read[GACC]GAC0=GWCOA;[F:FAS]GAC
     If fstat=0
        Call LECTEXTRA([F:TDFM]GACDES,"GACCOUNT","DESTRA",GWCOA,[F:FAS]GAC) From ATEXTRA
     Endif
     Read[GACI]GAC0=GWCOA;[F:FAS]IASACC
     If fstat=0
        Call LECTEXTRA([F:TDFM]IASACCDES,"GACCOUNT","DESTRA",GWCOA,[F:FAS]IASACC) From ATEXTRA
     Endif
      Read[DSP]DSP0=[F:FAS]DSP;1
     If fstat=0
      [F:TDFM]DSPDES = [F:DSP]DESTRA
     Endif
     # Recovery of the titles of Dim/Analytical dimensions
     [F:TDFM]DIE(0)=[F:FAS]DIE(0)
     Read[CCE]CCE0=[F:FAS]DIE(0);[F:FAS]CCE(0)
     If fstat=0
       [F:TDFM]CCE1=[F:FAS]CCE(0)
       Call LECTEXTRA ([F:TDFM]CCE1DES , "CACCE", "DESTRA", num$([F:FAS]DIE(0)), [F:FAS]CCE(0)) From ATEXTRA
     Endif
     [F:TDFM]DIE(1)=[F:FAS]DIE(1)
     Read[CCE]CCE0=[F:FAS]DIE(1);[F:FAS]CCE(1)
     If fstat=0
       [F:TDFM]CCE2=[F:FAS]CCE(1)
       Call LECTEXTRA ([F:TDFM]CCE2DES , "CACCE", "DESTRA", num$([F:FAS]DIE(1)), [F:FAS]CCE(1)) From ATEXTRA
     Endif

     [F:TDFM]DIE(2)=[F:FAS]DIE(2)
     Read[CCE]CCE0=[F:FAS]DIE(2);[F:FAS]CCE(2)
     If fstat=0
       [F:TDFM]CCE3=[F:FAS]CCE(2)
       Call LECTEXTRA ([F:TDFM]CCE3DES , "CACCE", "DESTRA", num$([F:FAS]DIE(2)), [F:FAS]CCE(2)) From ATEXTRA
     Endif
     [F:TDFM]DIE(3)=[F:FAS]DIE(3)
     Read[CCE]CCE0=[F:FAS]DIE(3);[F:FAS]CCE(3)
     If fstat=0
       [F:TDFM]CCE4=[F:FAS]CCE(3)
       Call LECTEXTRA ([F:TDFM]CCE4DES , "CACCE", "DESTRA", num$([F:FAS]DIE(3)), [F:FAS]CCE(3)) From ATEXTRA
     Endif
     [F:TDFM]DIE(4)=[F:FAS]DIE(4)
      Read[CCE]CCE0=[F:FAS]DIE(4);[F:FAS]CCE(4)
     If fstat=0
       [F:TDFM]CCE5=[F:FAS]CCE(4)
       Call LECTEXTRA ([F:TDFM]CCE5DES , "CACCE", "DESTRA", num$([F:FAS]DIE(4)), [F:FAS]CCE(4)) From ATEXTRA
     Endif
      [F:TDFM]DIE(5)=[F:FAS]DIE(5)
     Read[CCE]CCE0=[F:FAS]DIE(5);[F:FAS]CCE(5)
     If fstat=0
       [F:TDFM]CCE6=[F:FAS]CCE(5)
       Call LECTEXTRA ([F:TDFM]CCE6DES , "CACCE", "DESTRA", num$([F:FAS]DIE(5)), [F:FAS]CCE(5)) From ATEXTRA
     Endif
     [F:TDFM]DIE(6)=[F:FAS]DIE(6)
     Read[CCE]CCE0=[F:FAS]DIE(6);[F:FAS]CCE(6)
     If fstat=0
       [F:TDFM]CCE7=[F:FAS]CCE(6)
       Call LECTEXTRA ([F:TDFM]CCE7DES , "CACCE", "DESTRA", num$([F:FAS]DIE(6)), [F:FAS]CCE(6)) From ATEXTRA
     Endif
      [F:TDFM]DIE(7)=[F:FAS]DIE(7)
     Read[CCE]CCE0=[F:FAS]DIE(7);[F:FAS]CCE(7)
     If fstat=0
       [F:TDFM]CCE8=[F:FAS]CCE(7)
       Call LECTEXTRA ([F:TDFM]CCE8DES , "CACCE", "DESTRA", num$([F:FAS]DIE(7)), [F:FAS]CCE(7)) From ATEXTRA
     Endif
     [F:TDFM]DIE(8)=[F:FAS]DIE(8)
     Read[CCE]CCE0=[F:FAS]DIE(8);[F:FAS]CCE(8)
     If fstat=0
       [F:TDFM]CCE9=[F:FAS]CCE(8)
       Call LECTEXTRA ([F:TDFM]CCE9DES , "CACCE", "DESTRA", num$([F:FAS]DIE(8)), [F:FAS]CCE(8)) From ATEXTRA
     Endif
     Read [F:FAM]FAM0 = [F:FAS]ACGGRP
     If fstat=0
        Call LECTEXTRA ([F:TDFM]ACGGRPDES, "FASFAM", "FAMDES", [F:FAS]ACGGRP, "") From ATEXTRA
     Endif
     Read [ADI]CODE = 613;[F:FAS]IASCGU
     If fstat=0
        Call LECTEXTRA ([F:TDFM]IASCGUDES, "ATABDIV", "LNGDES", "613", [F:ADI]CODE) From ATEXTRA
     Endif
     #=========================================================
     GDFD=G_NON
     #========================================================
     # FY situation
     #========================================================
     If LSITUAT = 1
       #----- Fiscal year -----
       Gosub FY_PROCESS
     Else
       #----- Périod (Now no period for deferred type)-----
       # Gosub PERIOD_PROCESS
      Endif
      If GDFD=G_OUI
        [F:TDF]=[F:TDFM]
        [F:TDF]EDTNUM = LEDTNUM
        [F:TDF]CREUSR = GUSER
        [F:TDF]CREDAT = date$
        Write [F:TDF]
        If fstat <> 0
           GOK=0
           Rollback
           Unlock[TDF]
        Else
           Commit
           Unlock[TDF]
        Endif
        #1------------
      Endif
      $NEXTFAS
   Next
   Filter[FAS]


Commit

Unlock PREPDFD

Return
######################################################################################
$LOAD_TDFM_FY

     [F:TDFM]   = [F:PFE]

      # Base, cumul et VN = 0 si sortis
      If ([FAS]ISSDAT <> [0/0/0] and [FAS]ISSDAT <= LDATFIN ) and LBAS0=1
         [F:TDFM]DPRBASF     = 0
         [F:TDFM]NBVF        = 0
      Else
        [F:TDFM]DPRCUMF      = [F:PFE]DPRCUM
        [F:TDFM]ENDDPEF      = [F:PFE]ENDDPE
        [F:TDFM]EXCDPRF      = [F:PFE]EXCDPR
        [F:TDFM]NBVF         = [F:PFE]NBV
      Endif

      #** Lecture du plan comptable
      Filter [PCE] Where ( CPY=[F:FAS]CPY    & AASREF=[F:FAS]AASREF & DPRPLN=G301CPT   &
&                          FIYSTRDAT=LDATDEB & FIYENDDAT=LDATFIN )
        Read[PCE]DEP0 Last
        [F:TDFM]DPRCUM      = [F:PCE]DPRCUM
        [F:TDFM]ENDDPE      = [F:PCE]ENDDPE
        [F:TDFM]EXCDPR      = [F:PCE]EXCDPR
        [F:TDFM]NBV         = [F:PCE]NBV
      Filter [PCE]
      # Base, cumul et VN = 0 si sortis
      If ([FAS]ISSDAT <> [0/0/0] and [FAS]ISSDAT <= LDATFIN ) and LBAS0=1
         [F:TDFM]DPRBAS     = 0
         [F:TDFM]NBV        = 0
      Endif

Return
######################################################################################
$LOAD_TDFM_PER
Local Integer RRET

   [F:TDFM]   = [F:PFP]

   [F:TDFM]DPRCUMF      = [F:PFP]DPRCUM + [F:PFP]PERCLOCUM + [F:PFP]PERCLOEXC
   [F:TDFM]PERCLOCUMF   = [F:PFP]PERCLOCUM
   [F:TDFM]PERCLOEXCF   = [F:PFP]PERCLOEXC
   [F:TDFM]PERENDDPEF   = [F:PFP]PERENDDPEF
   [F:TDFM]PEREXCDPRF   = [F:PFP]PEREXCDPR
   [F:TDFM]ENDDPEF      = [F:PFP]PERENDDPEF + [F:PFP]PEREXCDPR
   [F:TDFM]NBVF         = [F:PFP]NBV
   [F:TDFM]DPRBASF      = [F:PFP]DPRBAS

   If [FAS]ISSDAT > [0/0/0]
      # Basis,total,nv set to=0 if issued
      If [FAS]ISSDAT <=LDATFIN and LBAS0=1
         [F:TDFM]DPRBASF     = 0
         [F:TDFM]NBVF        = 0
      Endif
   Endif

   #** Reading of Accounts depreciation plan
    Filter[PCP] Where (CPY=[F:FAS]CPY    & AASREF=[F:FAS]AASREF & DPRPLN=G301CPT &
&                            PERSTRDAT=LDATDEB & PERENDDAT=LDATFIN )
      Read[PCP]DEP0 Last
      [F:TDFM]DPRCUM      = [F:PCP]DPRCUM + [F:PCP]PERCLOCUM + [F:PCP]PERCLOEXC
      [F:TDFM]PERCLOCUM   = [F:PCP]PERCLOCUM
      [F:TDFM]PERCLOEXC   = [F:PCP]PERCLOEXC
      [F:TDFM]PERENDDPE   = [F:PCP]PERENDDPE
      [F:TDFM]PEREXCDPR   = [F:PCP]PEREXCDPR
      [F:TDFM]ENDDPE      = [F:PCP]PERENDDPE +  [F:PCP]PEREXCDPR
      [F:TDFM]NBV         = [F:PCP]NBV
      [F:TDFM]DPRBAS      = [F:PCP]DPRBAS
   Filter[PCP]

   If [FAS]ISSDAT > [0/0/0]
      # Basis,total,nv set to=0 if issued
      If [FAS]ISSDAT <=LDATFIN and LBAS0=1
         [F:TDFM]DPRBAS     = 0
         [F:TDFM]NBV        = 0
      Endif
   Endif

Return
######################################################################################
$FY_PROCESS

  Filter [PFE] Where ( CPY=[F:FAS]CPY  & AASREF=[F:FAS]AASREF & DPRPLN=LPLAN  & FIYSTRDAT=LDATDEB & FIYENDDAT=LDATFIN )
  Read[PFE]DEP0 Last
  Filter [PFE]
  If fstat = 0
     If  [F:PFE]DFDBLC <> 0 or  [F:PFE]DFD <> 0 or  [F:PFE]DFDRVE <> 0
       GDFD=G_OUI
       Gosub LOAD_TDFM_FY
      Else
        GDFD=G_NON
      Endif
  Else
     GDFD=G_NON
  Endif

Return
######################################################################################
$PERIOD_PROCESS

  Filter[PFP] Where (CPY=[F:FAS]CPY & AASREF=[F:FAS]AASREF & DPRPLN=LPLAN & PERSTRDAT=LDATDEB & PERENDDAT=LDATFIN )
  Read[PFP]DEP0 Last
  Filter[PFP]
  If fstat <> 0 or ([F:PFP]DFDBLC = 0 and  [F:PFP]DFD = 0 and  [F:PFP]DFDRVE = 0)
    Goto NEXTFAS
  Endif
  If fstat = 0
    # if "Issued and non issued assets" : if issue before FY : the asset is not printed
    # if "Non issued assets" :  if issue <  start date of the period  : the asset is not printed
    # if "Issued assets" :  if not issued or issued after the end of the period  : the asset is not printed
    Case  LSELSOR
      When 1  :  GDFD=G_OUI
      When 2
        If ( [F:FAS]ISSDAT >  [0/0/0] and [F:FAS]ISSDAT < LDATDEB  and [F:FAS]ISSDAT >= [F:PCP]FIYSTRDAT ) or
&          ( [F:FAS]ISSDAT > LDATFIN)  or
&          ( [F:FAS]ISSDAT =  [0/0/0] )
           GDFD=G_OUI
         Else
           GDFD=G_NON
         Endif
       When 3
         If  [F:FAS]ISSDAT < [PFP]FIYSTRDAT or [F:FAS]ISSDAT > LDATFIN
           GDFD=G_NON
         Else
           GDFD=G_OUI
         Endif
         When Default : GDFD=G_OUI
      Endcase

      If GDFD=G_OUI
         Gosub LOAD_TDFM_PER
      Endif

   Endif

Return
######################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
End
####################################################
#================================================================
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L

   Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
   L = len(PARAM)
   If right$(PARAM,L-2)="deb"
      If VALEUR=string$(len(VALEUR)," ")
          VALEUR = ""
      Endif
   Endif

End
####################################################

