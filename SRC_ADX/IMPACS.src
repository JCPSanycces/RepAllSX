#<AdxTL>@(#)6.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMPORT"     : Gosub IMPORT
Endcase
Return

$IMPORT
If [F:ACS]CODACC="" : Return : Endif
I = find([F:ACS]CODACC,[M:ACS1]CODACC(0..[M:ACS1]NBLIG-1))
If I
 nolign = I
Else
 [M:ACS1]NBLIG += 1
 nolign = [M:ACS1]NBLIG
 NBMOD += 1
Endif
[M:ACS1] = [F:ACS]
Return
