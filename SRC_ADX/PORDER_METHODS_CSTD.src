#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
$AREAD_AFTER
  Local Integer IRET
  IRET = fmet this.INIT_TSSCODADI()

  #Set order address.  This is not stored in the header unless a change has been made.
  Local Integer TMP

  # Read the order address from BPADDRESS if address has not been modified
  If this.BPAADDLIG1 = AVOID.ACHAR and
&    this.BPAADDLIG2 = AVOID.ACHAR and
&    this.BPAADDLIG3 = AVOID.ACHAR and
&    this.CTY        = AVOID.ACHAR and
&    this.POSCOD     = AVOID.ACHAR and
&    this.SAT        = AVOID.ACHAR and
&    this.CRY        = AVOID.ACHAR and
&    this.BPSNUM    <> AVOID.ACHAR

    Local Instance BPARTNER Using C_BPARTNER
    BPARTNER = NewInstance C_BPARTNER AllocGroup null
    [L]ASTATUS = fmet BPARTNER.AREAD(this.BPSNUM)
    For TMP=1 To maxtab(BPARTNER.C_BPRNAM)
      Assign "this.BPRNAM"+num$(TMP) With BPARTNER.C_BPRNAM(TMP).BPRNAM
    Next

    Local Instance BPADDRESS Using C_BPADDRESS
    BPADDRESS = NewInstance C_BPADDRESS AllocGroup BPARTNER
    [L]ASTATUS = fmet BPADDRESS.AREAD(1, this.BPSNUM, this.BPAADD)    # 1 = BP
    If [L]ASTATUS=[V]CST_AOK
      this.BPAADDLIG1 = BPADDRESS.BPAADDLIG1
      this.BPAADDLIG2 = BPADDRESS.BPAADDLIG2
      this.BPAADDLIG3 = BPADDRESS.BPAADDLIG3
      this.CTY        = BPADDRESS.CTY
      this.POSCOD     = BPADDRESS.POSCOD
      this.SAT        = BPADDRESS.SAT
      this.CRY        = BPADDRESS.CRY
      this.CRYNAM     = BPADDRESS.CRYNAM
    Endif
    FreeGroup BPARTNER
    BPARTNER = null
    BPADDRESS = null

  Else

    # Separate multi-dimensional fields into individual properties
    this.BPRNAM1 = [F:POH]BPRNAM(0)
    this.BPRNAM2 = [F:POH]BPRNAM(1)

    this.BPAADDLIG1 = [F:POH]BPAADDLIG(0)
    this.BPAADDLIG2 = [F:POH]BPAADDLIG(1)
    this.BPAADDLIG3 = [F:POH]BPAADDLIG(2)

  Endif


  #Set the shipment address.  This is not stored in the header unless a change has been made.

  # Read the shipment address from BPADDRESS if address has not been modified
  If this.BPOADDLIG1 = AVOID.ACHAR and
&    this.BPOADDLIG2 = AVOID.ACHAR and
&    this.BPOADDLIG3 = AVOID.ACHAR and
&    this.BPOCTY     = AVOID.ACHAR and
&    this.BPOPOSCOD  = AVOID.ACHAR and
&    this.BPOSAT     = AVOID.ACHAR and
&    this.BPOCRY     = AVOID.ACHAR and
&    this.BPSNUM    <> AVOID.ACHAR

    Local Instance BPARTNER Using C_BPARTNER
    BPARTNER = NewInstance C_BPARTNER AllocGroup null
    [L]ASTATUS = fmet BPARTNER.AREAD(this.BPSNUM)
    For TMP=1 To maxtab(BPARTNER.C_BPRNAM)
      Assign "this.BPONAM"+num$(TMP) With BPARTNER.C_BPRNAM(TMP).BPRNAM
    Next

    Local Instance BPADDRESS Using C_BPADDRESS
    BPADDRESS = NewInstance C_BPADDRESS AllocGroup BPARTNER
    [L]ASTATUS = fmet BPADDRESS.AREAD(1, this.BPSNUM, this.BPOADD)    # 1 = BP
    If [L]ASTATUS=[V]CST_AOK
      this.BPOADDLIG1 = BPADDRESS.BPAADDLIG1
      this.BPOADDLIG2 = BPADDRESS.BPAADDLIG2
      this.BPOADDLIG3 = BPADDRESS.BPAADDLIG3
      this.BPOCTY     = BPADDRESS.CTY
      this.BPOPOSCOD  = BPADDRESS.POSCOD
      this.BPOSAT     = BPADDRESS.SAT
      this.BPOCRY     = BPADDRESS.CRY
    Endif
    FreeGroup BPARTNER
    BPARTNER = null
    BPADDRESS = null

  Else

    # Separate multi-dimensional fields into individual properties
    this.BPONAM1 = [F:POH]BPONAM(0)
    this.BPONAM2 = [F:POH]BPONAM(1)

    this.BPOADDLIG1 = [F:POH]BPOADDLIG(0)
    this.BPOADDLIG2 = [F:POH]BPOADDLIG(1)
    this.BPOADDLIG3 = [F:POH]BPOADDLIG(2)

  Endif


Return

#######################################################################################
$AINIT
  Local Integer IRET

  IRET = fmet this.INIT_TSSCODADI()
Return

#######################################################################################
$INIT_TSSCODADI
  Local Integer DIM_STC
  Local Integer NI

  DIM_STC = func ASYRFNC.ACTIV("STS")
  # -------------------
  For NI = 1 To DIM_STC
    this.C_TSSCOD(NI).TSSCODADI = NI + 40
  Next NI  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return

