#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
Funprog LOAD_OST(BPCNUM, CTX, CPY, FCY, CUR, OSTCTL, OSTAUZ, OST, CDTISR, CDTISRDAT, ORDMINAMT)
Value Char BPCNUM
Variable Instance CTX Using C_WMACONTEXT : #
Value Char CPY
Value Char FCY
Variable Char CUR
Variable Shortint OSTCTL #Variable Integer OSTCTL #Variable TINYINT OSTCTL  #
Variable Decimal OSTAUZ
Variable Decimal OST
Variable Decimal CDTISR
Variable Date CDTISRDAT
Variable Decimal ORDMINAMT

#---- conversion montants de devise dossier vers devise affichage (société ou société du site par défaut)
Local Decimal WMONTORG (0..2)
Local Decimal WMONTDES (0..2)
Local Integer CTX_CHGTYP
Local Char    CTX_SYSCUR(GLONCUR)
Local Char    CTX_CUR(GLONCUR)
Local Integer SPSTAT
Local Char    WLEGCPY(GLONCPY)
Local Decimal WDECIMAL
Local Decimal ENCOURS
Local Integer ARET_VALUE

  [L]ARET_VALUE = 0 # OK
  # --------------------------------------
  Local File TABCUR [TCU]
  Local File COMPANY [CPY]
  Local File FACILITY [FCY]
  Local File BPCUSTOMER [BPC]
  Local File BPCUSTOMER [BPC1]
  # --------------------------------------
  Read [BPC]BPC0=BPCNUM
  If fstat
    Raz [F:BPC]
    [L]ARET_VALUE = 1 # Error
    End ARET_VALUE
  Endif
  # --------------------------------------
  CTX_SYSCUR = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, CTX.AFOLDER, "SYSCUR")
  CUR = CTX_SYSCUR
  CTX_CHGTYP = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD, CTX.AFOLDER, "CHGTYP")
  # --------------------------------------
  #--Avant tout il faut chercher le site par défaut afin d'initialiser l'ancienne GCUR
  #---- devise site alimentée par devise dossier ----#
  CTX_CUR = CTX_SYSCUR # GCUR= GSYSCUR
  #---- lecture du site par défaut ----#
  If CPY <> "" Then
    WLEGCPY = CPY
  Else
    Raz WLEGCPY
    If FCY <> "" Then
      Read [FCY]FCY0=FCY
      If fstat = 0 Then
        WLEGCPY = [F:FCY]LEGCPY
        #WFINRSPFCY = [F:FCY]FINRSPFCY
      Endif
    Endif
  Endif
  #---- lecture société correspondant au site ----#
  If WLEGCPY <> "" Then
    Read [CPY]CPY0=WLEGCPY
    If fstat = 0 Then
      CTX_CUR = [F:CPY]ACCCUR
    Endif
  Endif
  # ---------------------
  #-- si pas de cours entre devise dossier et devise affichage
  #-- la devise affichage devient la devise de reporting
  #-- cg le 14 septembre 99 demande numéro ????
  # --------------------------------------
  Call CONVERT(CTX, CTX_SYSCUR, CTX_CUR, CTX_CUR, CTX_CHGTYP, datesyst, AVOID.ADEC, AVOID.ADEC, SPSTAT) From TRTDEV_SYRA
  If SPSTAT <> 0 Then
    CTX_CUR = CTX_SYSCUR
  Endif
  #-----------------------#
  # decimal de la devise  #
  #-----------------------#
  WDECIMAL = 0
  Read [TCU]TCU0=CTX_CUR
  If fstat = 0 Then
    WDECIMAL = [F:TCU]CURRND
  Endif
  # ------------------
  WMONTORG(0) = [F:BPC]ORDMINAMT
  Call CONVERT2(CTX, CTX_SYSCUR, CTX_CUR, CTX_CUR, CTX_CHGTYP, datesyst, WMONTORG(0), WMONTDES(0), SPSTAT) From TRTDEV_SYRA
  If SPSTAT = 0 Then
    ORDMINAMT = arr(WMONTDES(0), WDECIMAL)
  Else
    ORDMINAMT = [F:BPC1]ORDMINAMT
  Endif
  # -----------------------------------------------
  #--Calcul et alimentation de la partie "En-cours"
  # -----------------------------------------------
  Raz ENCOURS
  # L'en-cours est géré sur le tiers risque
  #--CPO Pour l'instant GCUR=CTX_CUR
  If [F:BPC]BPCRSK <> BPCNUM Then
    # Le client n'est pas le tiers risque
    # -----------------------------------
    Read [BPC1]BPC0=[F:BPC]BPCRSK
    If fstat Then
      Raz [F:BPC1]
      [L]ARET_VALUE = 1 # Error
      End ARET_VALUE
    Endif
    OSTCTL = [F:BPC1]OSTCTL
    #---- conversion en-cours autorisé de devise dossier vers devise affichage (société ou société du site par défaut)
    WMONTORG(0) = [F:BPC1]OSTAUZ
    Call CONVERT2(CTX, CTX_SYSCUR, CTX_CUR, CTX_CUR, CTX_CHGTYP, datesyst, WMONTORG(0), WMONTDES(0), SPSTAT) From TRTDEV_SYRA
    If SPSTAT = 0 Then
      OSTAUZ = arr(WMONTDES(0), WDECIMAL)
    Else
      OSTAUZ = [F:BPC1]OSTAUZ
    Endif
    If dim([F:BPC1]CDTISR) <> -1 Then
       #---- conversion assurance crédit de devise dossier vers devise affichage (société ou société du site par défaut)
       WMONTORG(0) = [F:BPC1]CDTISR
       Call CONVERT2(CTX, CTX_SYSCUR, CTX_CUR, CTX_CUR, CTX_CHGTYP, datesyst, WMONTORG(0), WMONTDES(0), SPSTAT) From TRTDEV_SYRA
       If SPSTAT = 0 Then
         CDTISR = arr(WMONTDES(0), WDECIMAL)
       Else
         CDTISR = [F:BPC1]CDTISR
       Endif
    Endif
    CDTISRDAT = [F:BPC1]CDTISRDAT
  Else
    # Le client est le tiers risque
    # -----------------------------
    OSTCTL = [F:BPC]OSTCTL
    #---- conversion en-cours autorisé de devise dossier vers devise affichage (société ou société du site par défaut)
    WMONTORG(0) = [F:BPC]OSTAUZ
    Call CONVERT2(CTX, CTX_SYSCUR, CTX_CUR, CTX_CUR, CTX_CHGTYP, datesyst, WMONTORG(0), WMONTDES(0), SPSTAT) From TRTDEV_SYRA
    If SPSTAT = 0 Then
      OSTAUZ = arr(WMONTDES(0), WDECIMAL)
    Else
      OSTAUZ = [F:BPC]OSTAUZ
    Endif
    If dim([F:BPC]CDTISR) <> -1 Then
      #---- conversion assurance crédit de devise dossier vers devise affichage (société ou société du site par défaut)
      WMONTORG(0) = [F:BPC]CDTISR
      Call CONVERT2(CTX, CTX_SYSCUR, CTX_CUR, CTX_CUR, CTX_CHGTYP, datesyst, WMONTORG(0), WMONTDES(0), SPSTAT) From TRTDEV_SYRA
      If SPSTAT = 0 Then
        CDTISR = arr(WMONTDES(0), WDECIMAL)
      Else
        CDTISR = [F:BPC]CDTISR
      Endif
    Endif
    CDTISRDAT = [F:BPC]CDTISRDAT
  Endif
  # Calcul de l'en-cours
  Raz ENCOURS
  Call CALENC(CTX, WLEGCPY, [F:BPC]BPCRSK, datesyst, ENCOURS) From TRTBPMVT_SYRA
  OST = ENCOURS
  CUR = CTX_CUR
End ARET_VALUE
