#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion du fichier AEXPV3
Raz GPILOBJ , GNBMASKOUV
Call OBJET("AEV",GBIDC1,GBIDC2) From GOBJET
End

###############################################################
$ACTION
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "ANNULE"      : Gosub ANNULE
 When "GAUCHE"      : Gosub GAUCHE
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_CRE
 When "CHANGE"      : Gosub CHANGE
 When Default
Endcase
Return

$OUVRE_BOITE
Local Char BROWA(20)
I = find("AOE",OBJLIS(1..dim(OBJLIS)-1))
If I
 BROWA = "GAU_CHE"+num$(I)
Endif
Return

$VERIF_CRE
If [M]NBRFLG>1
 For I=0 To [M]NBRFLG-2
  If [M]FLGV3(I)=""
   GMESSAGE = mess(10,123,1) : # Zone obligatoire
   zonsui = "[M:AEV1]FLGV3("+num$(I)+")"
   OK = 0 : Break
  Endif
 Next I
 If !OK : Return : Endif
 TROUVE = 0
 For I=0 To [M]NBRLIG-1
  If [M]FLD(I)="/" & [M]TYP(I)=[M]FLGREC([M]NBRFLG-1)
   If [M]ZON(I)<>""
    TROUVE = 1
   Endif
   Break
  Endif
 Next I
 If [M]FLGV3([M]NBRFLG-1)=""
  If !TROUVE
   GMESSAGE  =mess(10,123,1) : # Zone obligatoire
   zonsui = "[M:AEV2]ZON("+num$(I)+")"
   OK = 0
  Endif
 Elsif TROUVE
  [M]FLGV3([M]NBRFLG-1)=""
 Endif
Endif
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"12") From GOBJET
Endif
Return

$EXEBOUT
Case REP
 When "1"
  Local Char    FILV3(GDIMFIC) , FILX3(GDIMFIC)
  Local Integer TYPV3 , TYPX3
  Local Integer WERROR

  [L] = [M:AEV1]

  # commun avec SUBAEV et TRTIMPV3
  Call IMPORT_SUBAEV (TYPV3,TYPX3,FILV3,FILX3,CLECUR1,[M]CODDBA,WERROR) From SUBAEV
  If WERROR <> 0
      # en erreur
      OK = 0
  Endif
Endcase
Return




$CREATION
Call MAJTEXTRA([M]INTIT,"AEXPV3","INTIT",[M]CODE,"") From ATEXTRA
For nolign=1 To [M]NBRLIG
 Raz [F:AED]
 If [M]ZON(nolign-1)<>"" | [M]COND(nolign-1)<>"" | [M]INIT(nolign-1)<>""
  [F:AED] = [M:AEV0]
  [F:AED] = [M:AEV1]
  [F:AED] = [M:AEV2]
  [F:AED]LIG = nolign
  Write [AED]
  If fstat
   GOK = 0 : Call FSTA("AED") From GLOCK : Break
  Endif
 Endif
Next nolign
Return

$ANNULE
Delete [AED] Where CODE=[L]CODE
If fstat
 GOK = -1 : Call RSTA("AED",[F:AEV]CODE) From GLOCK
Endif
Delete [AXX] Where CODFIC="AEXPV3" & ZONE = "INTIT"  & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="AEXPV3" & ZONE = "INTIT" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA AOBJEXT"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

$MODIF
Local Char CODE(GLONAEV) : [L]CODE=[F:AEV]CODE
Gosub ANNULE
If GOK<1 : Return : Endif
Gosub CREATION
Return

$LIENS
Gosub CHARGE
For I=0 To [F:AOE]NBRFLG-1
 [M:AEV1]FLGV3(I)  = [F:AEV]FLGV3(I)
Next I
For [AED]AED0 Where CODE=[F:AEV]CODE
 [M:AEV2]ZON([F:AED]LIG-1)    = [F:AED]ZON
 [M:AEV2]COND([F:AED]LIG-1)   = [F:AED]COND
 [M:AEV2]INIT([F:AED]LIG-1)   = [F:AED]INIT
 [M:AEV2]OBLIG([F:AED]LIG-1)  = [F:AED]OBLIG
 [M:AEV2]NUMTAB([F:AED]LIG-1) = [F:AED]NUMTAB
Next

Return

$CHARGE
Call LECTURE("AOE",[M:AEV1]MODELE,"") From CONTOBJ
For I=0 To [F:AOE]NBRFLG-1
 [M:AEV1]FLGREC(I) = [F:AOE]FLGREC(I)
 [M:AEV1]FLGLEV(I) = [F:AOE]FLGLEV(I)
 [M:AEV1]FLGFIL(I) = [F:AOE]FLGFIL(I)
Next I
[M:AEV1]NBRFLG = [F:AOE]NBRFLG
nolign = 0
For [AOD]AOD0 Where EXT=[M:AEV1]MODELE
 nolign += 1
 [M:AEV2]TYP(nolign-1) = [F:AOD]TYP
 [M:AEV2]FIL(nolign-1) = [F:AOD]FIL
 [M:AEV2]FLD(nolign-1) = [F:AOD]FLD
 #If [F:AOD]FLD="/"
  [M:AEV2]ZON(nolign-1) = ""
  [M:AEV2]COND(nolign-1) = ""
  [M:AEV2]INIT(nolign-1) = ""
  [M:AEV2]OBLIG(nolign-1)  = 0
  [M:AEV2]NUMTAB(nolign-1) = 0
 #Endif
 [M:AEV2]COM(nolign-1) = func SUBAOE.INTFLD([F:AOD]EXT,[F:AOD]FIL,[F:AOD]FLD)
Next
[M:AEV2]NBRLIG = nolign
Call AM_TYPV3([M:AEV1]TYPV3)
Call AM_TYPX3([M:AEV1]TYPX3)
Return

$GAUCHE
If currbox=BROWA & [M]CODE<>""
 Gosub CHANGE_MODELE
Endif
Return

$CHANGE_MODELE
If [M]NBRLIG<>0
 OK = 2
 Call AVERTIR(mess(127,141,1),OK) From GESECRAN : # Voulez-vous vraiment changer le modèle ?
 If OK<>2 : Return : Endif
Endif
[M]MODELE = [F:AOE]EXT
Read [AOE]AOE0 = [M]MODELE
[M]FILV3  = [F:AOE]FILEXT
[M]FILX3  = [F:AOE]FILEXT
Gosub CHARGE
Affzo [M:AEV1]
Affzo [M:AEV2]
Return

####################################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File AEXPV3   [AEV1]
 Local File AEXPV3D  [AED1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".AEXPV3"   [AEV1]
 Local File =[M]DOSORG+".AEXPV3D"  [AED1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File AEXPV3   [AEV2]
 Local File AEXPV3D  [AED2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".AEXPV3"   [AEV2]
 Local File =[M]DOSDES+".AEXPV3D"  [AED2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
OK = 1
If GTRACE=""
 Read [AEV2]AEV0 = TABLE
 If !fstat
  # Fiche déjà existante
  Call AVERTIR(TABLE-":"-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [AEV1], [AED1], [AEV2], [AED2]
Return

$TR_COP
GOK = 1
Trbegin [AEV2] , [AED2]
 Delete [AEV2] Where CODE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AEXPV3" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AEV2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AED2] Where CODE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AEXPV3D" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AED2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AEV1]AEV0 Where CODE=TABLE
  [F:AEV2] = [F:AEV1]
  Call COPTEXTRA("AEXPV3","INTIT",TABLE,"") From ATEXTRA
  If dim([F:AEV2]UPDUSR)>0 : [F:AEV2]UPDUSR = GUSER : Endif
  If dim([F:AEV2]UPDDAT)>0 : [F:AEV2]UPDDAT = date$ : Endif
  Write [AEV2]
  If fstat
   GOK=0 : Call FSTA("AEV2") From GLOCK : Break
  Endif
  For [AED1]AED0 Where CODE=TABLE
   [F:AED2] = [F:AED1]
   Write [AED2]
   If fstat
    GOK=0 : Call FSTA("AED2") From GLOCK : Break 2
   Endif
  Next
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif



######################################################
Subprog IMPORT_SUBAEV (RTYPV3,RTYPX3,RFILV3,RFILX3,RCODCNV,RCODDBA,RERROR)
Value    Integer RTYPV3
Value    Integer RTYPX3
Value    Char    RFILV3
Value    Char    RFILX3
Value    Char    RCODCNV
Value    Integer RCODDBA
Variable Integer RERROR


Local Char    WNOMFIC(GDIMFIC)
Local Char    FIC_V3(GDIMFIC) , FIC_X3(GDIMFIC)
Local Char    FICSRV_V3(GDIMFIC) , FICSRV_X3(GDIMFIC)

Local Integer STAT , ER
Local Char    WFICPATH(250)

Raz GMESSAGE
If RTYPV3=1 and GSERVEUR
           GMESSAGE = mess(163,141,1) : # poste client inaccessible en batch
           RERROR = 1  : Goto FIN_IMPORT_SUBAEV
Endif
If RTYPX3=1 and GSERVEUR
           GMESSAGE = mess(163,141,1) : # poste client inaccessible en batch
           RERROR = 1  : Goto FIN_IMPORT_SUBAEV
Endif
#
If RTYPV3=1 & RTYPX3=1
          # ici on ne peut pas entre en batch (controle avant)
           Call SETNAM(RFILV3,FIC_V3) From ORDSYS
           Call SETNAM(RFILX3,FIC_X3) From ORDSYS
           # nom du fichier est le même on remet à blanc
           If FIC_V3=FIC_X3
                Raz RFILV3 , RFILX3
           Endif
Endif

Raz FIC_V3 , FIC_X3
Raz FICSRV_V3 , FICSRV_V3

If RFILV3="" & RTYPV3=1
       RFILV3 = "file"+mess(max(1,RCODDBA),945,1)+".dat"
Endif
If RFILX3="" & RTYPX3=1
       RFILX3 = "filecnv.dat"
Endif
Call SET_NOMFIC(RFILV3,FIC_V3,RTYPV3) From GIMPOBJ
If RTYPV3=2
       Raz WFICPATH
       Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
       mkstat = func ASYRSTO.CTL_VOLFIL(RTYPV3,FIC_V3,WFICPATH,E_TYPE_FILEREAD,GMESSAGE)
       If mkstat
                GERR = 1 : RERROR = 1 : Goto FIN_IMPORT_SUBAEV
       Endif
       FICSRV_V3 = WFICPATH
Else
       Call SET_FICNAM(FIC_V3,FICSRV_V3,WNOMFIC) From ORDSYS
       Call COPSRV(FIC_V3,FICSRV_V3,ER) From ORDSYS
       If ER=1
                GMESSAGE = mess(164,141,1) : # Fichier non copié sur le poste client
                RERROR = 1  : Goto FIN_IMPORT_SUBAEV
       Elsif ER>1
                GMESSAGE = mess(101,100,1)-"("+num$(ER)+")" : # Fichier inexistant
                RERROR = 1  : Goto FIN_IMPORT_SUBAEV
       Endif
Endif
Call SET_NOMFIC(RFILX3,FIC_X3,RTYPX3) From GIMPOBJ
If FIC_X3<>"" & FIC_X3=FIC_V3
       GMESSAGE = mess(125,141,1) : # Les noms des fichiers doivent être différents
       GERR = 1 : RERROR = 1 : Goto FIN_IMPORT_SUBAEV
Endif
If RTYPX3=2
       Raz WFICPATH
       Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
       mkstat = func ASYRSTO.CTL_VOLFIL(RTYPX3,FIC_X3,WFICPATH,E_TYPE_FILEOVERWRITE,GMESSAGE)
       If mkstat
                GERR = 1 : RERROR = 1 : Goto FIN_IMPORT_SUBAEV
       Endif
       FICSRV_X3 = WFICPATH
Else
       Call SET_FICNAM(FIC_X3,FICSRV_X3,WNOMFIC) From ORDSYS
Endif
#
Call CONV3(RCODCNV,FICSRV_V3,FICSRV_X3,STAT) From TRTIMPV3
If STAT <> 0
        RERROR = 1  : Goto FIN_IMPORT_SUBAEV
Else
      If RTYPX3=1
           Call COPCLI(FICSRV_X3,RFILX3,ER) From ORDSYS
           If ER=1
                GMESSAGE = mess(164,141,1) : # Fichier non copié sur le poste client
                RERROR = 1  : Goto FIN_IMPORT_SUBAEV
           Elsif ER>1
                GMESSAGE = mess(101,100,1)-"("+num$(ER)+")" : # Fichier inexistant
                RERROR = 1  : Goto FIN_IMPORT_SUBAEV
           Endif
      Endif
Endif

$FIN_IMPORT_SUBAEV
End

########################################################
Subprog C_MODELE(VALEUR)
Variable Char    VALEUR()
Call CONTROLE("AOE","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
If [F:AOE]IMPORT<>2
 GMESSAGE = mess(109,141,1) : # Import impossible sur ce modèle
 mkstat = 1 : End
Elsif !find([F:AOE]TYPFIL,2,3) : # Ascii2, délimité
 GMESSAGE = mess(40,126,1)-"<>"-mess(2,94,1)-mess(3,94,1) : # Type de fichier incorrect <> Ascii2
 mkstat = 1 : End
Endif
End

Subprog AP_MODELE(VALEUR)
Variable Char    VALEUR()
Local    Integer OK
If VALEUR<>[M]MODELE
 Gosub CHANGE_MODELE
 If OK<>2
  VALEUR = [M]MODELE
  mkstat = 2 : End
Endif
Endif
End

Subprog D_FILV3(VALEUR)
Variable Char VALEUR()
If VALEUR<>"" : End : Endif
Call LECTURE("AOE",[M]MODELE,"") From CONTOBJ
VALEUR = [F:AOE]FILEXT
End

Subprog C_FILV3(VALEUR)
Variable Char VALEUR()
Local Char FICPATCH(250)
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO

If GBATCH
   mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPV3, VALEUR,[L]FICPATCH,E_TYPE_FILEOVERWRITE,GMESSAGE)
Else
   mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPV3, VALEUR,[L]FICPATCH,E_TYPE_FILEREAD,GMESSAGE)
Endif

End

Subprog D_FILX3(VALEUR)
Variable Char VALEUR()
If VALEUR<>"" : End : Endif
Call LECTURE("AOE",[M]MODELE,"") From CONTOBJ
VALEUR = [F:AOE]FILEXT
End

Subprog C_FILX3(VALEUR)
Variable Char VALEUR()
Local Char FICPATCH(250)
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPX3, VALEUR,[L]FICPATCH,E_TYPE_FILEOVERWRITE,GMESSAGE)
If VALEUR<>"" & VALEUR=[M]FILV3
 GMESSAGE = mess(125,141,1) : # Les noms des fichiers doivent être différents
 mkstat = 1
Endif
End

Subprog AS_FLGV3(VALEUR)
Variable Char    VALEUR()
End

Subprog C_FLGV3(VALEUR)
Variable Char    VALEUR()
Local    Integer I, J, K
Local    Char    BID(20)
If nolign<[M]NBRFLG & VALEUR=""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 1 : End
Else
 BID = VALEUR
 K = 0
 While BID<>""
  J = instr(1,BID,";")
  K += 1
  If J
   I = val(left$(BID,J-1))
   BID = right$(BID,J+1)
  Else
   I = val(BID)
   BID = ""
  Endif
  If !I
   GMESSAGE = mess(127,123,1) : # Donnée non numérique
   mkstat = 1 : Break
  Endif
 Wend
Endif
End

Subprog AS_ZON(VALEUR)
Variable Char    VALEUR()
If [M]FLD(nolign-1)="/"
 If [M]NBRFLG<=1
  mkstat = 1
 Elsif [M]FLGV3([M]NBRFLG-1)<>""
  mkstat = 1
 Elsif [M]TYP(nolign-1)<>[M]FLGREC([M]NBRFLG-1)
  mkstat = 1
 Endif
Endif
End

Subprog C_ZON(VALEUR)
Variable Char    VALEUR()
If [M]FLD(nolign-1)="/"
 If VALEUR=""
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat = 1 : End
 Endif
Elsif VALEUR<>"" & val(VALEUR)=0
  GMESSAGE = mess(127,123,1) : # Donnée non numérique
  mkstat = 1 : End
Endif
End

Subprog AS_COND(VALEUR)
Variable Char    VALEUR()
If [M]FLD(nolign-1)="/"
 mkstat = 1
Endif
End

Subprog AS_INIT(VALEUR)
Variable Char    VALEUR()
If [M]FLD(nolign-1)="/"
 mkstat = 1
Endif
End

Subprog AS_OBLIG(VALEUR)
Variable Integer VALEUR
If [M]FLD(nolign-1)="/"
 mkstat = 1
Endif
End

Subprog AS_NUMTAB(VALEUR)
Variable Decimal VALEUR
If [M]FLD(nolign-1)="/"
 mkstat = 1
Endif
End

######################################################################################
Subprog AM_TYPV3(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
 [M:AEV1]FILV3 = ""
 Grizo [M:AEV1]FILV3
Else
 Actzo [M:AEV1]FILV3
Endif
Affzo [M:AEV1]FILV3
End

Subprog AM_TYPX3(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
 [M:AEV1]FILX3 = ""
 Grizo [M:AEV1]FILX3
Else
 Actzo [M:AEV1]FILX3
Endif
Affzo [M:AEV1]FILX3
End

