#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet AUTI
######################################################################################
# Management of utility (UTIXXX)
# File AUTILITY - Screen AUTI1 and Windows OAUTI
#
##GROUPING FLAG (yes/no) GROUPFLG field
# if SET = yes the exe is launched only once in the patch integration
#=> we group all the utility code which have the same
# EXE CODE (and no LAUNCH GROUP) and we launch the utility only once
#
# init of the module = 10 to force the dev to enter a right value
# controle with adictrt
#
# all control are done in label VERIF
######################################################################################
$ACTION
Case ACTION
    When "AFFMASK"   : Gosub AFFMASK
    When "SETBOUT"   : Gosub SETBOUT
    When "EXEBOUT"   : Gosub EXEBOUT
    When "LIENS"     : Gosub LIENS
    When "RAZCRE"    : Gosub RAZCRE
    When "RAZDUP"    : Gosub RAZCRE
    When "INICRE"    : Gosub INI_CREMOD
    When "INIMOD"    : Gosub INI_CREMOD
    When "VERIF_CRE" : Gosub VERIF_CREMOD
    When "VERIF_MOD" : Gosub VERIF_CREMOD
    When "SEL_LISTE" : Gosub SEL_LISTE
    When Default
Endcase
Return

######################################################################################
##                  action gobjet
######################################################################################

#-----------------------#
#-----------------------#
$AFFMASK
Return

#-----------------------#
#-----------------------#
$LIENS
#format "D:DD[/]MM[/]YYYY[ ......
If gdatetime$("") = [F:AUTI]LASLAUNCHDAT
    Raz [M:AUTI1]WLASLAUNCHDA
Else
    [M:AUTI1]WLASLAUNCHDA = format$(GACTX.AINTL.SHORTDATETIM,[F:AUTI]LASLAUNCHDAT)
Endif
If gdatetime$("") = [F:AUTI]LAUNCHDAT
    Raz  [M:AUTI1]WLAUNCHDAT
Else
    [M:AUTI1]WLAUNCHDAT   = format$(GACTX.AINTL.SHORTDATETIM,[F:AUTI]LAUNCHDAT)
Endif
Diszo  [M:AUTI1]LOGFIL
Return

#-----------------------#
# init fied...
#-----------------------#
$RAZCRE

[M:AUTI1]UPDATEFLG    = 2
[M:AUTI1]LAUNCHSTATUS = 1
# at the moment only case after is implemented
# field only displayed at the moment
[M:AUTI1]LAUNCHTYP       = 2

Raz [M:AUTI1]LAUNCHNBR
Raz [M:AUTI1]WLAUNCHDAT
Raz [M:AUTI1]LAUNCHUSR
Raz [M:AUTI1]WLASLAUNCHDA
Raz [M:AUTI1]LASLAUNCHUSR
Raz [M:AUTI1]RELEASE
Raz [M:AUTI1]LOGFIL

Affzo [M:AUTI1]LAUNCHTYP

Affzo [M:AUTI1]UPDATEFLG
Affzo [M:AUTI1]LAUNCHSTATUS
Affzo [M:AUTI1]LAUNCHNBR
Affzo [M:AUTI1]WLAUNCHDAT
Affzo [M:AUTI1]LAUNCHUSR
Affzo [M:AUTI1]WLASLAUNCHDA
Affzo [M:AUTI1]LASLAUNCHUSR
Affzo [M:AUTI1]RELEASE
Affzo [M:AUTI1]LOGFIL
#
Diszo  [M:AUTI1]LOGFIL

Return

#-----------------------#
#-----------------------#
$INI_CREMOD
If [M:AUTI1]WLASLAUNCHDA = ""
      Raz [F:AUTI]LASLAUNCHDAT
Endif
If [M:AUTI1]WLAUNCHDAT = ""
      Raz [F:AUTI]LAUNCHDAT
Endif
If [M:AUTI1]GROUP = "" and [M:AUTI1]GROUPSEQ <> 0
      [F:AUTI]GROUPSEQ = 0
Endif
Return

#-----------------------#
# before creation- modif
#-----------------------#
$VERIF_CREMOD
# we must verify if script exist under TRT directory and if the source code contains the right label.
# adx ok ?
Local Char WMESSAGE(GDIMFIC)
Raz WMESSAGE
Local Integer WOK
Local Char WTRT(GDIMFIC)
Local Char WLIGNE(GDIMFIC)
Local Integer WMESS
Local Clbfile WAFF_TEXT (3)


WMESS = 0

# script must not be a specific script if code is STD.
If left$([M:AUTI1]UTICOD,1) < "X" and left$([M:AUTI1]SCRIPT,1) >= "X"
    WMESS =12
    Append WAFF_TEXT, "- "+func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
    Append WAFF_TEXT,chr$(13)+chr$(10)
Elsif left$([M:AUTI1]UTICOD,1) >= "X" and left$([M:AUTI1]SCRIPT,1) < "X"
    # script must not be a std script if code is spe.
    WMESS =18
    Append WAFF_TEXT, "- "+func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
    Append WAFF_TEXT,chr$(13)+chr$(10)
Elsif left$([M:AUTI1]SCRIPT,1) = "W"
    # script must not begin by W in any case
    WMESS =13
    Append WAFF_TEXT, "- "+func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
    Append WAFF_TEXT,chr$(13)+chr$(10)
Else
    # verify the module on this uti and the module of script ADICTRT
    Read [ADC]ADC0=[M:AUTI1]SCRIPT
    If fstat = 0
         If [M:AUTI1]MODULE <> [F:ADC]MODULE or [M:AUTI1]CODACT <>[F:ADC]CODACT
              WMESS =11
              Append WAFF_TEXT,"- "+ func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
              Append WAFF_TEXT,chr$(13)+chr$(10)
         Endif
    Else
        WMESS =10
        Append WAFF_TEXT, "- "+func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
        Append WAFF_TEXT,chr$(13)+chr$(10)
    Endif
Endif

# si combiné pas de group ni de numero de seq.
# on ne doit pas avoir les deux. ne sert à rien
If [M:AUTI1]GROUPFLG = 2 and [M:AUTI1]GROUP <> ""
     WMESS =9
     Append WAFF_TEXT,"- "+ func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
     Append WAFF_TEXT,chr$(13)+chr$(10)
Endif

# si group seq doit etre <> 0
If [M:AUTI1]GROUPSEQ = 0 and [M:AUTI1]GROUP <> ""
    WMESS =15
    Append WAFF_TEXT,"- "+ func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
    Append WAFF_TEXT,chr$(13)+chr$(10)
Endif

# au moins root ou chidl doievent etre coché
If [M:AUTI1]ROOTRUN = 1 and [M:AUTI1]CHILDRUN = 1
    WMESS =14
    Append WAFF_TEXT,"- "+ func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
    Append WAFF_TEXT,chr$(13)+chr$(10)
Endif

# coherence type validation type patch
# si avant integration : choix fin - differe pas possible
# si apres integration : choix debut pas possible
# au moins un des deux actifs
If [M:AUTI1]LAUNCHTYP = 1 and ([M:AUTI1]LAUNCHTYPVAL > 1 and [M:AUTI1]LAUNCHTYPVAL < 4)
    WMESS =16
    Append WAFF_TEXT, "- "+func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
    Append WAFF_TEXT,chr$(13)+chr$(10)
Elsif [M:AUTI1]LAUNCHTYP = 2 and [M:AUTI1]LAUNCHTYPVAL = 1
    WMESS =16
    Append WAFF_TEXT,"- "+ func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
    Append WAFF_TEXT,chr$(13)+chr$(10)
Elsif [M:AUTI1]LAUNCHTYP = 4 and [M:AUTI1]LAUNCHTYPVAL = 4
    WMESS =17
    Append WAFF_TEXT, "- "+func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
    Append WAFF_TEXT,chr$(13)+chr$(10)
Endif

# Ajout controle sur le group avec coherence autre uti du même group
# car sur un group on ne pourra pas avoir des uti avant integration et apres integration
# dans le même group... ca n a pas de sens....
# prendre le premier et faire controle avec ...


# adx exist ?
Call EXISTE_ADX("","",[M:AUTI1]SCRIPT,WOK) From ASYRSYS
If WOK = 0
    WMESS =1
    Append WAFF_TEXT, "- "+func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
    Append WAFF_TEXT,chr$(13)+chr$(10)
Else
    # Trt with a patch label ?
    # open the trt and check label PATCH. and UTI_MOUL
    WOK = 0
    Raz WTRT
    Raz WLIGNE
    WTRT= filpath("TRT",[M:AUTI1]SCRIPT,"src","","","")
    # src exist ?
    If filinfo(WTRT,0)>=0
      Openi WTRT    Using [W_TRT]
      Repeat
        Rdseq WLIGNE Using [W_TRT]
          If fstat = 0
              If pat(WLIGNE,"*Subprog*")
                # look if PATCH label
                  If pat(WLIGNE,"*PATCH*")
                      # Check if line not in comment
                          If (instr(1,WLIGNE,"#")>instr(1,WLIGNE,"PATCH")) or instr(1,WLIGNE,"#") = 0
                                WOK += 1
                          Endif
                  Elsif pat(WLIGNE,"*UTI_MOUL*")
                      # look if UTI_MOUL label
                          # Check if line not in comment
                          If (instr(1,WLIGNE,"#")>instr(1,WLIGNE,"UTI_MOUL")) or instr(1,WLIGNE,"#") = 0
                                WOK += 2
                          Endif
                  Endif
              Endif
          Endif
      Until fstat <> 0 or WOK = 3
      Openi Using [W_TRT]
      # wok = 3 all is ok
      # wok = 0 labels are missing patch and uti_moul
      # wok = 1 label patch is ok but label uti_moul is missing (not important if uti is not active in valdos)
      # wok = 2 label uti_moul is ok but label patch is missing
      If WOK <> 3
          If WOK  = 2
              WMESS  =2
              Append WAFF_TEXT,"- "+ func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
              Append WAFF_TEXT,chr$(13)+chr$(10)
          Elsif WOK  = 1
              If [M:AUTI1]LAUNCHTYPVAL <> 4
                    WMESS  =8
                    Append WAFF_TEXT,"- "+ func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
                    Append WAFF_TEXT,chr$(13)+chr$(10)
              Endif
          Else
              WMESS  =2
              Append WAFF_TEXT, "- "+func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
              Append WAFF_TEXT,chr$(13)+chr$(10)
              If [M:AUTI1]LAUNCHTYPVAL <> 4
                    WMESS  =8
                    Append WAFF_TEXT, func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
                    Append WAFF_TEXT,chr$(13)+chr$(10)
              Endif
          Endif
          WOK = 0
      Endif
    Else
      WMESS  =1
      Append WAFF_TEXT, "- "+func AFNC.MES1 (mess(WMESS,7842,1),[M:AUTI1]SCRIPT)
      Append WAFF_TEXT,chr$(13)+chr$(10)
    Endif
Endif

# display all messages in once.
If WMESS <> 0
    Call AFFMES(WAFF_TEXT) From GESECRAN
    OK = 0
Endif

Return

#-----------------------#
# disable or enable button
#-----------------------#
$SETBOUT
#If GADONIX<>2
#    Call VIREBOUT(CHAINE,"AHM")      From GOBJET
#Elsif [M:AUTI1]UPDATEFLG = 1
# Only Sage can remove & rename Standard records
If [M:AUTI1]UPDATEFLG = 1
    # no modif if the record is commit in github or patch
    Call VIREBOUT(CHAINE,"AHM")      From GOBJET
Endif
If GPROFIL <> GSUPER
    # no launch is authorized if not admin profil
    Call VIREBOUT(CHAINE,"2")      From GOBJET
Endif
If GREP <> "" or [M:AUTI1]SCRIPT = ""
     Call VIREBOUT(CHAINE,"2")      From GOBJET
Endif
# laisser possibilte de faire modif  sur les codes  en x y z * car ne remonter pas dans github
Return

#-----------------------#
# execute button
#-----------------------#
$EXEBOUT
Case BOUT
       When "2" : Gosub LAUNCH_UTILITY
Endcase
Return

#---------------------------#
# selection
#---------------------------#
$SEL_LISTE
Case LISTE
      When "SELGROUPSEQ"   : Gosub SEL_GROUPSEQ
      When "SELGROUP"      : Gosub SEL_GROUP
Endcase
Return


######################################################################################
##                  Gosub
######################################################################################
#########################################################################


$SEL_GROUP
Local Integer NBTEX
Local Char    TEX(10)(1..GDIMFIC) , TEXTE(GLONDES)(1..GDIMFIC,1..5)
NBTEX = 0
Filter [AUTI] Where GROUPSEQ<>0 Order By GROUP  Asc ; GROUPSEQ Asc
For [AUTI]
   If NBTEX<dim(TEX)
      NBTEX += 1
      TEX(NBTEX)     = [F:AUTI]GROUP
      TEXTE(NBTEX,1) = [F:AUTI]GROUP
      TEXTE(NBTEX,2) = format$("N:8#",[F:AUTI]GROUPSEQ)
      TEXTE(NBTEX,3) = [F:AUTI]UTICOD
      TEXTE(NBTEX,4) = [F:AUTI]SCRIPT
      TEXTE(NBTEX,5) = [F:AUTI]COMMENT
   Endif
Next
Filter [AUTI]

Return


$SEL_GROUPSEQ
Local Integer NBTEX
Local Char    TEX(10)(1..GDIMFIC) , TEXTE(GLONDES)(1..GDIMFIC,1..4)
NBTEX = 0
Filter [AUTI] Where GROUP=[M]GROUP Order By GROUPSEQ Asc
For [AUTI]
   If NBTEX<dim(TEX)
      NBTEX += 1
      TEX(NBTEX)     = format$("N:8#",[F:AUTI]GROUPSEQ)
      TEXTE(NBTEX,1) = format$("N:8#",[F:AUTI]GROUPSEQ)
      TEXTE(NBTEX,2) = [F:AUTI]UTICOD
      TEXTE(NBTEX,3) = [F:AUTI]SCRIPT
      TEXTE(NBTEX,4) = [F:AUTI]COMMENT
   Endif
Next
Filter [AUTI]
Return

#-----------------------#
# launch utility
#-----------------------#
$LAUNCH_UTILITY

Call OUVRE_TRACE([M:AUTI1]SCRIPT + ": Processing manually") From LECFIC

Call LAUNCH_UTI_FILTER (nomap,[M:AUTI1]SCRIPT,[M:AUTI1]UTICOD,[M:AUTI1]MODULE, [M:AUTI1]CODACT,[M:AUTI1]ROOTRUN,[M:AUTI1]CHILDRUN,[M:AUTI1]LAUNCHNBR,"",GTRACE)

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
# need to read again to display the right elements
Gosub RELIT From GOBJSUB
Return

#------------------------------------------#
# copy the contains of trace_suite in gtrace at the end for patcheur
#------------------------------------------#
$ADD_TRACE

Local Libelle BUFFER(1..30)
Local Integer NB , COMPTE , NOCT
Local Char WCHAINE(GDIMFIC)
Local Char WFIC_TRACE(GDIMFIC)
Local Char WFIC_TRACE_SUITE(GDIMFIC)

WFIC_TRACE = filpath("TRA",TRACE,"tra")
WFIC_TRACE_SUITE = filpath("TRA",TRACE_SUITE,"tra")

Openo WFIC_TRACE, -1    Using [TRA]
Openi WFIC_TRACE_SUITE   Using [TRA2]
adxifs = ""
adxirs = chr$(10)
adxium = GTRAFOR
Wrseq              Using [TRA]

Raz WCHAINE
WCHAINE="-----------------------------"-mess(28,7902,1)
WCHAINE-="-----------------------------"
Wrseq WCHAINE      Using [TRA]
Wrseq              Using [TRA]

NOCT = filinfo(WFIC_TRACE_SUITE,7)
NB = dim(BUFFER)
Getseq NB , BUFFER Using [TRA2]
COMPTE = 0
While !fstat
  COMPTE += NB
  Putseq NB , BUFFER Using [TRA]
  Getseq NB , BUFFER Using [TRA2]
Wend
fstat=0

If NOCT>COMPTE
  NB = NOCT-COMPTE
  Putseq NB , BUFFER Using [TRA]
Endif

Wrseq          Using [TRA]
WCHAINE="---------------------------"-mess(31,7902,1)
WCHAINE-="---------------------------"

Wrseq WCHAINE   Using [TRA]

Openi Using [TRA2]
Openo Using [TRA]

Return


######################################################################################
##                  Subprog or funcprog
######################################################################################
#**
#* UPDATE_LAUNCHNBR :
#* if the uti is not yet launched : update the launch date + user
#* if uti is already launched : don't update the launch date + user (only the last field)
#*
#* @param PUTICOD
#* @param PLAUNCHNBR
#* @param PAPPLI
#* @param PLOGFIL
#*!
#-----------------------------------------------------------------------------------------#
# if the uti is not yet launched : update the launch date + user
# if uti is already launched : don't update the launch date + user (only the last field)
#-----------------------------------------------------------------------------------------#
Subprog UPDATE_LAUNCHNBR(PUTICOD,PLAUNCHNBR,PAPPLI,PLOGFIL)
Value Char    PUTICOD
Value Integer PLAUNCHNBR
Value Char    PAPPLI
Value Char    PLOGFIL

# look the release number to udpate
Local Char WRELEASE(20)
WRELEASE= func APRODUCT.AGETRELEASE(PAPPLI)

If PLAUNCHNBR = 0
    Update [F:AUTI] Where UTICOD = PUTICOD With LAUNCHSTATUS=2, LAUNCHNBR+=1, LAUNCHDAT= datetime$, LAUNCHUSR= GUSER,
&                                               LASLAUNCHDAT= datetime$, LASLAUNCHUSR= GUSER, RELEASE=WRELEASE,
&                                               LOGFIL = PLOGFIL
Else
    Update [F:AUTI] Where UTICOD = PUTICOD With LAUNCHSTATUS=2, LAUNCHNBR+=1, LASLAUNCHDAT= datetime$, LASLAUNCHUSR= GUSER,
&                                               LOGFIL = PLOGFIL
Endif
End


#**
#* UPDATE_LAUNCHSTATUS :
#* if the uti can not be launched in this context : update the flag
#*
#* @param PUTICOD
#*!
#-----------------------------------------------------------------------------------------#
# if the uti can not be launched in this context
# update the flag
#-----------------------------------------------------------------------------------------#
Subprog UPDATE_LAUNCHSTATUS(PUTICOD)
Value Char    PUTICOD

Update [F:AUTI] Where UTICOD = PUTICOD With LAUNCHSTATUS=3
End

#**
#* UPDATE_LAUNCHSTATUS_ERROR :
#* if the uti can not be launched due to an error : update the flag + log
#*
#* @param PUTICOD
#* @param PLOGFIL
#*!
#-----------------------------------------------------------------------------------------#
# if the uti can not be launched due to an error
# update the flag + log
#-----------------------------------------------------------------------------------------#
Subprog UPDATE_LAUNCHSTATUS_ERROR(PUTICOD,PLOGFIL)
Value Char    PUTICOD
Value Char    PLOGFIL


Update [F:AUTI] Where UTICOD = PUTICOD With LAUNCHSTATUS=4, LOGFIL = PLOGFIL
End

#-----------------------------------------------------------------------------------------#
#             loop on each uti in function of the filter or manually
# folder
# script uti
# code uti
# module
# activity code
# flag root folder  to execute
# flag child folder to execute
# number of launch
# rtype = "patch" from patcheur and empty if manually
# trace - log
#-----------------------------------------------------------------------------------------#
Subprog LAUNCH_UTI_FILTER (RDOSSIER,RSCRIPT,RUTICOD,RMODULE,RCODACT,RROOTRUN,RCHILDRUN,RLAUNCHNBR,RTYPE,TRACE_SUITE)
Value Char    RDOSSIER
Value Char    RSCRIPT
Value Char    RUTICOD
Value Integer RMODULE
Value Char    RCODACT
Value Integer RROOTRUN
Value Integer RCHILDRUN
Value Integer RLAUNCHNBR
Value Char    RTYPE
Variable Char TRACE_SUITE


$LAUNCH_AUTI
Local Integer WREASON
Local Integer WOK
Local Char WLOG (GDIMFIC)

If RTYPE = "VALDOS" or RTYPE ="PATCH"
      # log add notion if log is in root folder
      WLOG = GDOSX3+"/[TRA]/"+TRACE_SUITE
Else
      WLOG = TRACE_SUITE
Endif


Call ECR_TRACE(RSCRIPT + ": Process for folder "+RDOSSIER,0) From GESECRAN

# adx exist ? doesn't normal if adx is not here
Call EXISTE_ADX("","",RSCRIPT,WOK) From ASYRSYS
If WOK = 0
        Call ECR_TRACE(func AFNC.MES1 (mess(1,7842,1),RSCRIPT),1) From GESECRAN
        # update field LAUNCHSTATUS to put error to not relaunch the uti next time
        # si prob il faudra faire un autre utility
        # attention à mindo qui avec change manager restaure tout ????
        Call UPDATE_LAUNCHSTATUS_ERROR(RUTICOD,WLOG)
Else
        # code reason = 4 execution not authorized on root folder
        # code reason = 5 execution not authorized on child folder
        # code reason = 6 execution not authorized activbity code disable
        # code reason = 7 execution not authorized module disable
        WOK     = 0
        WREASON = 0
        # test module + test activity code  + test the folder
        # find the module in folder and find if activity is active
        # adossier is already open
        Read [ADS]DOSSIER=RDOSSIER
        If fstat = 0
            If RMODULE <= 0
                WREASON = 7
            Elsif [F:ADS]MODULE(RMODULE-1) <> 2
                WREASON = 7
            Else
                If func AFNC.ACTIV(RCODACT)
                  If RROOTRUN = 2 and RDOSSIER = GDOSX3
                      WOK= 1
                  Elsif RCHILDRUN = 2 and RDOSSIER <> GDOSX3
                      WOK= 1
                  Else
                      If RROOTRUN = 2 and RDOSSIER <> GDOSX3
                            WREASON = 4
                      Else
                            WREASON = 5
                      Endif
                  Endif
                Else
                  WREASON = 6
              Endif
          Endif
      Endif
      If WOK = 1
        Call ECR_TRACE(RSCRIPT + ": Process is launched ",0) From GESECRAN
        # tracker erreur car on ne maitrise pas ce qu il y a dans le script
        # si plantage on marque uti en error
        # le developpeur devra corriger la moulinette et refaire un autre UTI
        Onerrgo ERROR_LAUNCH_UTI
        If RTYPE <> "VALDOS"
              Call PATCH(RDOSSIER) From =RSCRIPT
        Else
              Call UTI_MOUL(RDOSSIER) From =RSCRIPT
        Endif
        Onerrgo
        # update fields after launch uti
        Call UPDATE_LAUNCHNBR(RUTICOD,RLAUNCHNBR,RDOSSIER,WLOG)
        Call ECR_TRACE(RSCRIPT + ": Process is finished ",0) From GESECRAN
      Else
        # update field LAUNCHSTATUS to put not active
        Call UPDATE_LAUNCHSTATUS(RUTICOD)
        If WREASON<> 0
            Call ECR_TRACE(RSCRIPT-":"-mess(3,7842,1)-mess(WREASON,7842,1),0) From GESECRAN
        Else
            Call ECR_TRACE(RSCRIPT-":"-mess(3,7842,1),0) From GESECRAN
        Endif
      Endif
Endif

End

$ERROR_LAUNCH_UTI
# update field LAUNCHSTATUS to put error
Call UPDATE_LAUNCHSTATUS_ERROR(RUTICOD,WLOG)
End


#**
#* EXEC_PATCH_AFTER
#*    Utilities to launch after the integration of the patches of after validation of folder
#*
#* @param RDOSSIER
#* @param RSAV_GTRACE
#* @param RTYPE
#*!
####################################################################################
# Utilities to launch after the integration of the patches of after validation of folder
# rtype = patch ou valdos
####################################################################################
Subprog EXEC_PATCH_AFTER (RDOSSIER,RSAV_GTRACE,RTYPE)
Value Char RDOSSIER
Value Char RSAV_GTRACE
Value Char RTYPE

Local File =RDOSSIER+".AUTILITY" [AUTI]

#Local Integer WREASON
#Local Integer WOK
Local Char WCOD_SCRIPT (GLONADC)

# each launch of uti must have its own log
Local Char TRACE(GDIMFIC)
Local Char TRACE_SUITE(GDIMFIC)

If RSAV_GTRACE<>""
   TRACE       = RSAV_GTRACE
Endif

#
# uti not launched and patched and must be launched after integration patch
# in any cases the record must be rewrite with a status launched or not active or error


# on execute ici tous les uti qui n ont pas été lancé
# si le patch integration c'est planté en plein milieu .. on aura quand même trace des uti à lancer
# et à la prochaine intégration d une mnt ces exe seront relances dans tous les cas.

# first step
# group  = empty and groupflg = 2
Raz WCOD_SCRIPT
If RTYPE = "VALDOS"
  Filter [AUTI] Where LAUNCHSTATUS = 1 and LAUNCHTYPVAL = 2 and GROUP = "" and GROUPFLG = 2 Order By SCRIPT Asc
Else
  Filter [AUTI] Where LAUNCHSTATUS = 1 and LAUNCHTYP = 2 and GROUP = "" and GROUPFLG = 2 Order By SCRIPT Asc
Endif
For [AUTI]
  # rupture script execute the script only once
  # premier on execute les autres on fait simplement le udpate status
  If WCOD_SCRIPT= ""
      WCOD_SCRIPT = [F:AUTI]SCRIPT
      Gosub LAUNCH_AUTI_AFTER
  Elsif  WCOD_SCRIPT = [F:AUTI]SCRIPT
      # update field LAUNCHSTATUS to put not active
      Call UPDATE_LAUNCHSTATUS([F:AUTI]UTICOD)
  Else
      WCOD_SCRIPT = [F:AUTI]SCRIPT
      Gosub LAUNCH_AUTI_AFTER
  Endif
Next

Filter [AUTI]

# second step
# group  = empty and groupflg = 1
If RTYPE = "VALDOS"
    Filter [AUTI] Where LAUNCHSTATUS = 1 and LAUNCHTYPVAL = 2 and GROUP = "" and GROUPFLG = 1 Order By UTICOD Asc
Else
    Filter [AUTI] Where LAUNCHSTATUS = 1 and LAUNCHTYP = 2 and GROUP = "" and GROUPFLG = 1 Order By UTICOD Asc
Endif
For [AUTI]
   Gosub LAUNCH_AUTI_AFTER
Next

Filter [AUTI]
# third step
# sort on group <> empty and groupseq order ascending
If RTYPE = "VALDOS"
    Filter [AUTI] Where LAUNCHSTATUS = 1 and LAUNCHTYPVAL = 2 and GROUP <> "" and GROUPSEQ <> 0 Order By GROUP Asc ; GROUPSEQ Asc
Else
    Filter [AUTI] Where LAUNCHSTATUS = 1 and LAUNCHTYP = 2 and GROUP <> "" and GROUPSEQ <> 0 Order By GROUP Asc ; GROUPSEQ Asc
Endif
For [AUTI]
    Gosub LAUNCH_AUTI_AFTER
Next
Filter [AUTI]


GTRACE    = RSAV_GTRACE
GLTRACE   = filinfo(GTRACE,7)
LogicClose File [AUTI]

End
###############################################################################################
#----------------------------------------------
#loop on each uti in function of the filter
#----------------------------------------------
$LAUNCH_AUTI_AFTER

Raz TRACE_SUITE
Call OUVRE_TRACE (" Utility"-[F:AUTI]UTICOD-"on folder"-RDOSSIER) From LECFIC
TRACE_SUITE = GTRACE
# rtype = patch or empty if manually or valdos
Call LAUNCH_UTI_FILTER (RDOSSIER,[F:AUTI]SCRIPT,[F:AUTI]UTICOD,[F:AUTI]MODULE,[F:AUTI]CODACT,[F:AUTI]ROOTRUN,[F:AUTI]CHILDRUN,[F:AUTI]LAUNCHNBR,RTYPE,TRACE_SUITE)
# merge the 2 logs in any case
If TRACE<>"" and TRACE_SUITE<>""
      Call FERME_TRACE From LECFIC
      Gosub ADD_TRACE
Endif
Return


######################################################################################
##                  screen AUTI1
######################################################################################
Subprog IB_SCRIPT
# editor script is forbidden in this context
Raz GBOUT1
End


Subprog AM_GROUPFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    Grizo [M:AUTI1]GROUP
    Grizo [M:AUTI1]GROUPSEQ
Else
    Actzo [M:AUTI1]GROUP
    Actzo [M:AUTI1]GROUPSEQ
Endif
End

Subprog IB_LOGFIL
Raz GBOUTS
Raz GBOUT1
Raz GBOUT2
If [M]LOGFIL <> ""
  # button read log
  GBOUT2 = mess(82,115,1)
Endif

End

Subprog B2_LOGFIL(VALEUR)
Variable Char    VALEUR()
Local Char SAV_GTRACE(GDIMFIC)
Local Char WREPERT(GDIMFIC)
Local Char WDOSSIER

# read the log file
# caution follow valdos the log is in root folder under tra
# caution follow patch the log can be in root folder under tra or appli folder
# amnually under appli folder
SAV_GTRACE=GTRACE
If VALEUR <> ""
    If instr(0,VALEUR,"/[TRA]/") <> 0
         WDOSSIER = func AFNC.PARTSEP(VALEUR,1,"/[TRA]/")
         If WDOSSIER <> ""
            GTRACE=func AFNC.PARTSEP(VALEUR,2,"/[TRA]/")
            WREPERT = filpath ("","TRA","",WDOSSIER)
            Call LECFIC(WREPERT,GTRACE,"tra") From LECFIC
         Else
            GTRACE=VALEUR
            Call CONS_TRACE From LECFIC
         Endif
     Else
         GTRACE=VALEUR
         Call CONS_TRACE From LECFIC
     Endif
Endif
GTRACE=SAV_GTRACE
End

Subprog S_GROUP(VALEUR)
Variable Char VALEUR
# selection on the group
Local Char PARAM(30)(1..1)
Call S_LIS_CHAR(VALEUR,PARAM,"SELGROUP","SUBAUTI","") From GACTION

End

Subprog S_GROUPSEQ(VALEUR)
Variable Decimal VALEUR
# selection on the sequence number
If [M:AUTI1]GROUP <> ""
  Local Char PARAM(30)(1..1)
  Call S_LIS_NUM(VALEUR,PARAM,"SELGROUPSEQ","SUBAUTI","") From GACTION
Endif
End

