#         mkstat = 2
#         End
#    Endif
#Endif
#---
End

########################################
# EMPLACEMENT
########################################
$AB1_LOC
    GLOCSEL = "LOCTYP='"+[M:DBY1]LOCTYP(nolign-1)+"'"
Return

$BB1_LOC
    Raz GLOCSEL
Return

Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
    Read [STC]STC0=[M:DBY0]STOFCY;VALEUR
    Read [TLO]TLO0=[M:DBY0]STOFCY;[F:STC]LOCTYP
    # test si type quai autorisé
    If !fstat & [M:DBY0]SRGWAIFLG <> 2 & [F:TLO]LOCCAT = 2         # hcb 50197
         GMESSAGE = mess(854,196,1)
         mkstat = 2
         End
    Endif
Endif
Affzo [M:DBY1]LOCTYP(nolign-1)    # Il a pu etre modifié par le controle STKCTREMP
End

########################################################################
#SUP_LIG                       Suppression d'une ligne dans le tableau #
########################################################################
Subprog SUP_LIG(NLIG, WRET)
Value Integer NLIG
Variable Integer WRET    : WRET = 0

If   dim([M]ITMREF) = [M]NBLIG
     Dela NLIG,1 [M:DBY1]NBLIG
Else
     Dela NLIG,1,[M:DBY1]NBLIG-1 [M:DBY1]NBLIG
Endif
[M:DBY1]NBLIG -=1

End
##########################################################################
## Etiquette ajoutée par le superviseur 03/03/2004 10:36:00 (HCB)
##########################################################################
Subprog B3_SLO(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL
Call RECLASTSLO([M:DBY1]ITMREF(NOL), [M:DBY1]LOT(NOL), "","", VALEUR) From STKLIB

End



