Variable Char    VALEUR()
#--- Bug 72649
If [M:DBY1]LOCTYP(nolign-1)<>VALEUR
   Call RAZLOC([M:DBY1]LOC(nolign-1),[M:DBY1]WLOCSEQ(nolign-1)) From STKACT
Endif
#If VALEUR <> ""
