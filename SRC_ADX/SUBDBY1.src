$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE  Return : Endif
Call INIT_CCE(VALEUR,AXE,"STKDBYD","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:DBY0]IPTDAT) From TRTX3CPT
Return




#                                                                          # hcb 71276 deb
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
If VALEUR <> [M:DBY1]LOT (nolign-1)                                        # hcb 117626
   If dim([M:DBY1]ECCVALMAJ) > 0 & [M:DBY1]ECCSAIFLG(nolign-1) <> 9        # hcb 117626
      Raz [M:DBY1]ECCVALMAJ(nolign-1)                                      # hcb 117626
      Raz [M:DBY1]ECCVALMIN(nolign-1)                                      # hcb 117626
      Raz [M:DBY1]ECCSAIFLG(nolign-1)                                      # hcb 117626
   Endif
Endif
End
#                                                                          # hcb 71276 fin







