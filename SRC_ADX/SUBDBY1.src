#<AdxTL>@(#)0.0.0.0 $Revision$ Ligne désassemblage
########################################################################
# Gestion du masque DBY1  Entrées
########################################################################

$ACTION
Case ACTION
 When "AAPRES_NBLIG" : Gosub AAPRES_NBLIG From SUBDBY1
 When "AB5_NBLIG"    : Gosub AB5_NBLIG    From SUBDBY1
 When "BB5_NBLIG"    : Gosub BB5_NBLIG    From SUBDBY1
 When "AB1_LOC"      : Gosub AB1_LOC      From SUBDBY1
 When "BB1_LOC"      : Gosub BB1_LOC      From SUBDBY1
 When Default
Endcase
Return

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

# suppression d un composant non gere en stock
#             delete SMVTD
#             recalcul priord du composé
$SUPP_NONGERE


#   Gosub VERROU From GOBJET
#   If !OK
#    GMESSAGE = mess(10,100,1) : # Modification en cours sur un autre poste
#    Return
#   Endif
Call DEBTRANS From GLOCK
Trbegin [SMD]

For I=NOL To NOL1
    Readlock [SMD]SMD0=32;[M:DBY0]VCRNUM;[M:DBY1]VCRLIN(I)
    If fstat = 1
       GOK = -1
       GLOCK = "$SMVTD"-[M:DBY0]VCRNUM-num$([M:DBY1]VCRLIN(I))
       Rollback
       mkstat = 2
       Return
    Elsif fstat
       GOK =  0
       Call RSTA ("SMD",[M:DBY0]VCRNUM-num$([M:DBY1]VCRLIN(I))) From GLOCK
       Rollback
       mkstat = 2
       Return
    Endif
    If fstat = 0
       Delete [SMD] Curr
       If fstat
          Rollback
          mkstat = 2
          Return
       Endif
    #----- Suppression  sections de la ligne de document  -----#     # ana
       Delete [CAL] Where ABRFIC="SMD" & VCRTYP=[F:SMD]VCRTYP & VCRNUM=[F:SMD]VCRNUM & VCRLIN=[F:SMD]VCRLIN # ana
       If fstat=1
          GOK= 0 : GLOCK="$CPTANALIN SMD 0"-[F:SMD]VCRNUM-num$([F:SMD]VCRLIN) : Return                      # ana
          Rollback
          mkstat = 2
          Return                                                                       # ana
       Endif                                                                                                # ana
    Endif
Next

Commit
Global Integer GSUP

Return


########################################
# NBLIG
########################################
# Gère la suppression et l'insertion des lignes
########################################
Subprog AVANT_NBLIG
Local Integer LLIG
    # Insertion de ligne.
    # Le status est en insertion uniquement sur "Avant_nblig" pas sur "Avant_saisie"

    If status=73 | status=82
        Local Integer LRET
        If dim([M:DBY1]ITMREF)=nolign-1
            GMESSAGE=mess(53,184,1) #"Tableau plein."
            GERR = 1
        Else
            Call STKACTLIGM(nolign-1,"DBY1") From STKECR
            Actzo [M]ITMREF(nolign-1),ITMDES1(nolign-1)
            If dim([M]PCU)>0
                Actzo [M]PCU(nolign-1),QTYPCU(nolign-1)
            Endif
            If dim([M]PCUSTUCOE)>0
                Actzo [M]PCUSTUCOE(nolign-1)
            Endif
            If dim([M]PRIORD)>0
                Actzo [M]PRIORD(nolign-1)
            Endif
            If dim([M]MVTDES)>0
                Actzo [M]MVTDES(nolign-1)
            Endif
        Endif
        If GREP = "M"
           If dim(GCTRDATDBY) <= 0
              If [M:DBY0]IPTDAT < date$
                 Global Integer GCTRDATDBY
                 # Attention ! la date d imputation est antérieure à la date du jour
                 Call MESSAGE(mess(162,184,1)) From GESECRAN
              Endif
           Endif
        Endif

    Endif
    If status=75             # modification de ligne
       Call LECFICENT([M:DBY0]STOFCY,"", "",(nolign-1),[M:DBY0]TRSTYPC,[M:DBY0]TRSCOD,1) From STKECR
    Endif

End

########################################
# Ajoute le menu contextuel "Détail", permettant de décomposer la ligne
# ou le menu contextuel "Modification", permettant de modifier la ligne et son détail
Subprog IB_NBLIG
Gosub SET_NOL

If ([M:DBY1]ITMREF(NOL) = "") | [M:DBY1]STOMGTCOD(NOL) <= 1     # hcb 28654
    GBOUT2 = ""
    GBOUT3 = ""
    GBOUT4 = ""
    GBOUT5 = ""
Else
    #                                                                 # hcb 119942 deb
    If GREP ="C" & [M:DBY0]VCRNUMORI <> ""  
       GBOUT2 = mess(377,198,1)  # Saisie détails quantités
       GBOUT8 = ""               # consultation mvt 
       GBOUT5 = ""               # modification entrées
       End
    Else
#                                                                 # hcb 119942 fin
       Call STKINIBTN( 2, 5, 3, 4, "DBY1", "SRT", [M:DBY1]ITMREF(NOL) , [M:DBY0]STOFCY ) From STKENT
    Endif                                                         # hcb 119942 

Endif

If  [M:DBY1]LO(NOL) <> 0
    GBOUT5 = ""
    GBOUT2 = ""
Endif
If [M:DBY1]LO(NOL) = 0
        GBOUT8 = ""    # consultation mvt
Endif
If [M:DBY0]VCRNUM = ""
        GBOUT8 = ""    # consultation mvt
Endif

# initialisation des Globales
GVCRTYP = 32
GVCRNUM = [M:DBY0]VCRNUM

#If [M:DBY0]VCRNUM = "" & [M:DBY1]LO(NOL) <> 0
#   GVCRTYP = 32                                       # hcb 22993
#   GVCRNUM = [M:DBY0]VCRNUMORI
#Endif

If [M:DBY0]VCRNUM <> "" & [M:DBY1]LO(NOL) <> 0
   GVCRTYP = 32
   GVCRNUM = [M:DBY0]VCRNUM
Endif


End
########################################
Subprog B2_NBLIG
#Ouverture fenêtre de détail par clic droit
GOUVENT = 16384 # =2^14
End

########################################
Subprog B3_NBLIG
    Call INFOLOT("DBY1", nolign-1) From STKENT
End
########################################
Subprog B4_NBLIG
    GOUVLOT = GOUVLOT-mod(GOUVLOT,2)    # Ouverture du complément lot par clic droit (1er bit de GOUVLOT à 0)
    GOUVENT = 1     # permet de passer le test de l'ouverture de la fenetre complément lot
End


########################################
$AB5_NBLIG
#-- Habilitation Modification mvts stock si on trouve K dans la chaine des boutons autorisés
# hcb 27842
Raz GBIDI2
GFCY=[M:DBY0]STOFCY
GBIDC2="K" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMESSAGE=mess(2,104,1)
   GOUVENT=0
   Return
Endif


If [M:DBY0]VCRNUM<>""
  SYMBOLE2="DBY"+[M:DBY0]VCRNUM
  Lock=SYMBOLE2
  If fstat
    GMESSAGE=[M:DBY0]VCRNUM-mess(10,100,1)   # modification sur un autre poste
    Call ERREUR(GMESSAGE) From GESECRAN
    GOUVENT=0
    Return
  Endif
Endif
GOUVENT=2
Return

########################################
$BB5_NBLIG
If [M:DBY0]VCRNUM<>""
  SYMBOLE2="DBY"+[M:DBY0]VCRNUM
  Unlock=SYMBOLE2
Endif
If GRELITSMR=1
    mkstat=4
Endif

Return

########################################
Subprog C_NBLIG
Gosub SET_NOL
Local Integer NOL1                                  # hcb 28654
Local Integer WNONGERE                              # hcb 28654

Case status
     When 73 :  # insertion
        If [M:DBY1]VCRLIN(NOL) < 5
           Call MESSAGE(mess(467,199,1)) From GESECRAN
           mkstat = 2
           End
        Endif
     When 65     :                                # Suppression d'une ligne
        If [M:DBY1]LO (NOL) <> 0
           GMESSAGE = mess (91,184,1)   # Suppression interdite ! Cette ligne à été désassemblée.
           mkstat = 2
           End
         Else
           If [M:DBY1]STOMGTCOD (NOL) < 2       # hcb 28654
              NOL1 = NOL                        # hcb 28654
              WNONGERE = 1                      # hcb 28654
              Gosub SUPP_NONGERE                # hcb 28654
           Endif                                # hcb 28654
        Endif
        When 68, 83 :                                # Suppression d'un groupe de lignes
           Raz WNONGERE                        # hcb 28654
            For I=nolign-1 To nolign1-1
                If [M:DBY1]CREFLG(I)<>0
                   If  [M:DBY1]STOMGTCOD (I) > 1
                       Raz WNONGERE                        # hcb 28654
                       Break
                   Else
                       If [M:DBY1]LO (I) <> 0
                          GMESSAGE = mess (91,184,1)   # Suppression interdite ! Cette ligne à été désassemblée.
                          mkstat = 2
                          Raz WNONGERE                        # hcb 28654
                          Break
                       Else                           # hcb 28654
                          WNONGERE = 1                # hcb 28654
                       Endif                          # hcb 28654
                   Endif                              # hcb 28654
                Else
                   Raz WNONGERE                       # hcb 28654
                Endif                                 # hcb 28654
            Next
            If WNONGERE = 1
               NOL1 = nolign1-1                       # hcb 28654
               Gosub SUPP_NONGERE                     # hcb 28654
            Endif                                     # hcb 28654
Endcase


If mkstat = 2
   End
Endif
If WNONGERE = 1
   End
Endif

If [M:DBY0]NBLIG>0
    Diszo [M:DBY0]STOFCY
Else
    Actzo [M:DBY0]STOFCY
Endif

Call STKCTRNBLIG("DBY1",[M:DBY0]STOFCY) From STKENT


End

########################################
# Appelé avant l'action SAISTOENT
# Permet de vérifier s'il faut la lancer ou non
$AAPRES_NBLIG
#If [M:DBY0]VCRNUMORI <> ""    # hcb 119942
#   Return                     # hcb 119942
#Endif                         # hcb 119942
If [M:DBY1]STOMGTCOD(nolign-1) <= 1 # hcb 28654
   Raz GOUVENT
   Raz GOUVLOT
   Return                           # hcb 28654
Endif                               # hcb 28654

Local Shortint WRET
Local Integer  WRET1
Local Char     LECCMAJ(GLONECS), LECCMIN(GLONEVL)
Raz WRET1
Raz GOUVSOR

If adxgtb<>1 & !find(status,65,68,83)
    Diszo [M]ITMREF(nolign-1)
Endif
Call OUVENT([M:DBY0]STOFCY,"DBY1",1,[M:DBY0]TRSCOD,"",19,[M:DBY0]IPTDAT,nolign-1,[M:DBY1]NBLIG,"SRT","",WRET) From STKENT
# CCC (24/07/06) Je ne vois pas pourquoi ce serait seulement dans le cas où on a une ligne d'origine ?!
#If [M:DBY1]LO(nolign-1)<>0
    Raz LECCMAJ, LECCMIN
    If dim([M:DBY1]ECCVALMAJ)>0
        [L]LECCMAJ = string$([M:DBY1]ECCVALMAJ(nolign-1)<>"$",[M:DBY1]ECCVALMAJ(nolign-1))
        [L]LECCMIN = string$([M:DBY1]ECCVALMIN(nolign-1)<>"$",[M:DBY1]ECCVALMIN(nolign-1))
    Endif
    Call SETNEWPRIOVE([M:DBY1]ITMREF(nolign-1),LECCMAJ,LECCMIN,[M:DBY0]STOFCY,[M:DBY0]IPTDAT,[M:DBY1]WSTOSEQ(nolign-1),[M:DBY1]PRIORD(nolign-1),1,[M:DBY1]QTYSTU(nolign-1),"",WRET1) From STKVAL
#Endif
Affzo [M]ITMREF(nolign-1)
Return


########################################
# ITMREF
########################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL
pcolor=GCOUL(0)         # hcb 28654

If [M:DBY1]STOMGTCOD(NOL) > 1   # 28654
    If [M:DBY1]WSTOFLG(NOL)=0 & [M:DBY1]CREFLG(NOL)=0
        pcolor=GCOUL(1)
    Else
        pcolor=GCOUL(0)
    Endif
Endif                           # 28654
End

########################################
# Quand la saisie d'une réf article s'est bien passée
# on remplit le champ désignation
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer I
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
Read [ITF]ITF0 = VALEUR;[M:DBY0]STOFCY
If fstat
   mkstat = 2
   GMESSAGE = mess(25,192,1)
   End
Endif

If [F:ITF]STOMGTCOD = 1           # hcb 28654 deb
   I= 1
   Call OUINON(VALEUR-mess(2,196,1)+"  "+mess(36,100,1),I) From GESECRAN
   If I = 1
      mkstat = 2
      End
   Endif
Endif

#[M:DBY1]ITMDES1  (nolign-1) = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:DBY1]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:DBY1]STOMGTCOD(nolign-1) = [F:ITF]STOMGTCOD   # hcb 28654

End

########################################
# UNITE de conditionnement
########################################
# Recherche le coefficient UC/US pour initialiser le champ PCUSTUCOE
Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()

    Local Char LUSCAV
    Local Char LFMT
    Local Integer LMODIF

    Gosub SET_NOL

    Call CTLUOM ([M:DBY1]ITMREF(NOL),3,"", VALEUR,[M:DBY1]PCUSTUCOE(NOL), LUSCAV, LFMT, LMODIF) From STKACT
    If LUSCAV <> "S"
       If LUSCAV <> "C"
          mkstat = 2
          End
       Endif
    Endif

    If LMODIF=2
        Actzo [M:DBY1]PCUSTUCOE(NOL)
    Endif

    [M:DBY1]QTYSTU(NOL) = [M:DBY1]QTYPCU(NOL) * [M:DBY1]PCUSTUCOE(NOL)
    Call QTEARR( [M:DBY1]QTYSTU(NOL), [M:DBY1]STU(NOL) ) From TRTDIV
    Affzo [M:DBY1]PCUSTUCOE(NOL),QTYSTU(NOL)

End

########################################
# QUANTITE
########################################
Subprog C_QTYPCU(VALEUR)
Variable Decimal VALEUR
    If VALEUR<=0
        mkstat=2
    Endif
End

########################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
    Gosub SET_NOL

    #--- Contrôle si la quantité UC génère une qté US arrondie
    Local Integer LRET
    If [M:DBY1]PCU(NOL)<>[M:DBY1]STU(NOL)
       Call STKCTRCOE(VALEUR,[M:DBY1]PCUSTUCOE(NOL),[M:DBY1]STU(NOL),LRET) From STKACT
       If LRET=0 : mkstat=2 : End : Endif
    Endif

    [M:DBY1]QTYSTU(NOL) = VALEUR * [M:DBY1]PCUSTUCOE(NOL)
    Call QTEARR( [M:DBY1]QTYSTU(NOL), [M:DBY1]STU(NOL) ) From TRTDIV
    Affzo [M:DBY1]QTYSTU(NOL)
End

########################################
# PCUSTUCOE Coef UC/US
########################################
Subprog AM_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR
    Gosub SET_NOL

    #--- Contrôle si le coef UC/US génère une qté US arrondie
    Local Integer LRET
    If [M:DBY1]PCU(NOL)<>[M:DBY1]STU(NOL)
       Call STKCTRCOE([M:DBY1]QTYPCU(NOL),VALEUR,[M:DBY1]STU(NOL),LRET) From STKACT
       If LRET=0 : mkstat=2 : End : Endif
    Endif

    [M:DBY1]QTYSTU(NOL) = [M:DBY1]QTYPCU(NOL) * VALEUR
    Call QTEARR( [M:DBY1]QTYSTU(NOL), [M:DBY1]STU(NOL) ) From TRTDIV
    Affzo QTYSTU(NOL)
End


########################################
Subprog IB_LOT
    Gosub SET_NOL
    # Compteur lot (intéressant en particulier pour les réceptions à quai)
    If [F:ITM]LOTCOU = ""
        GBOUT2 = ""
    Else
        GBOUT2 = mess(439,198,1)
    Endif

    # Lot blanc
    If   [F:ITM]LOTMGTCOD = 2
&      & ([F:ITM]LOTCOU <> "" | [F:SRU]LOTSUPINH=3)
        GBOUT3 = mess(440,198,1)
    Else
        GBOUT3 = ""
    Endif

    # Info lot
    If [F:ITM]LOTMGTCOD = 1 | [M:DBY1]LOT(NOL) <> ""
        GBOUT4 = ""
    Else
        GBOUT4 = mess(441,198,1)
    Endif
End

########################################
# Lot blanc : Indique qu'il n'y a pas de n° de lot
Subprog B3_LOT(VALEUR)
Variable Char    VALEUR()
    Gosub SET_NOL
    VALEUR = ""
    [M:DBY1]GESLOT(NOL) = "B"

End

########################################
# Info lot : Indique si le lot est blanc ou géré par un compteur
Subprog B4_LOT(VALEUR)
Variable Char    VALEUR()
    # Indique si le lot est blanc ou géré par compteur
    # (Un sous pro a été créé car il est appellé à 2 endroits
    # et dans plusieurs écrans: bouton3 NBLIG et bouton4 Lot
    Call INFOLOT("DBY1", nolign-1) From STKENT
End

########################################
# NBSLO
########################################
Subprog C_NBSLO(VALEUR)
Variable Decimal VALEUR

    Call STKCTRNBSLO(VALEUR, [M:DBY1]PCU(nolign-1), [M:DBY1]QTYPCU(nolign-1)) From STKACT

End

########################################
# SLO
########################################
# Calcul le n° de sous lot fin en vérifiant, si nécessaire, l'existence des sous lots.
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()

Gosub SET_NOL

If VALEUR<>""
    Call STKCTRSLO(VALEUR, [M:DBY1]NBSLO(NOL), [M:DBY1]LOT(NOL),
&                  [M:DBY1]ITMREF(NOL), [M:DBY1]BPSLOT(NOL), [M:DBY1]GESLOT(NOL), "", 0, 0, 0,
&                  [M:DBY0]STOFCY, [M:DBY1]SLOF(NOL)) From STKACT
    If !mkstat
        Affzo [M:DBY1]SLOF(NOL)
    Endif
Endif
End

########################################
# Dépôt
########################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2
  VALEUR = [M:DBY0]WRHE : mkstat=2 : End
Endif
If VALEUR=""
  VALEUR = [M:DBY0]WRHE
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M:DBY1]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M:DBY1]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

#--- Bug 60553
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
If [M:DBY1]WRH(nolign-1)<>""
   Raz [M:DBY1]LOC(nolign-1)
Endif
End

########################################
# TYPE D'EMPLACEMENT
########################################
