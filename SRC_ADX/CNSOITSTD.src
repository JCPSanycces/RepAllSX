#<AdxTL>@(#)7.0.0.0 $Revision$ Consultation OIT
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When "TRT_DIV"    : Gosub TRT_DIV
  When default
Endcase
Return
############################################################
$TRT_DIV
Case TRAIT
  When "INFWIP" : Call INFWIP(val(PARAM(1)),val(PARAM(2)),PARAM(3))
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ORD])=0 : Local File ORDERS     [ORD] : Endif
#
Local Char    WFIL(250), WFILSPE(250)
Local Char    WFIL1(250)
Local Char    WFIL2(250)
Local Char    WFIL3(250)
Local Char    WFIL4(250)
Local Char    WEVA(30)
Local Integer WFSTAT, WREAD, WSKIP, WLNE, WCLA, WSEL
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I, J
#
Local Integer WFIRTYP
Local Char    WFIRNUM
#
Gosub LOAD_SCREEN
#
SUITE  = 1
RETOUR = 1

# Mail TS du 18/03/08
NAVIG="CONSOIT"
Return
############################################################
$FIN_CRIT
[M:OIT1]FLG = 0
Return
############################################################
$AP_MAGNETO
[M:OIT1]FLG = 0
Return
############################################################
$SETBOUT
If [M:OIT1]SELFLG = 0
  Call VIREBOUT(CHAINE,"a") From GOBJET
Endif
Return
############################################################
$EXEBOUT
Case BOUT
  When "a" :
    If nolign > 0
      PARAM(5) = num$([M:OIT2]WIPTYP(nolign-1))
      PARAM(6) = [M:OIT2]VCRNUM(nolign-1)
      REPONSE = GSTAFIN
    Endif
  Endcase
Return
############################################################
$FERME
If clalev([F:ORD]) <> 0 : Filter [ORD] : Endif 
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I  
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat 
          [M:OIT1]FCY = PARAM(I) 
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat 
          [M:OIT1] = [F:ITM]
        Endif
      Endif
    When 4 :
      [M:OIT1]SELFLG = val(PARAM(I))
    When 5 :
      If PARAM(I) <> ""      
        WEVA =  "dim("+PARAM(I)+")"
        J = evalue(WEVA)
        Case J
          When 1 : 
            WEVA  = PARAM(I)
            WFIL1 = evalue(WEVA) 
          When 2 :
            WEVA  = PARAM(I)+"(0)"
            WFIL1 = evalue(WEVA) 
            WEVA  = PARAM(I)+"(1)"
            WFIL2 = evalue(WEVA) 
          When 3 :
            WEVA  = PARAM(I)+"(0)"
            WFIL1 = evalue(WEVA) 
            WEVA  = PARAM(I)+"(1)"
            WFIL2 = evalue(WEVA) 
            WEVA  = PARAM(I)+"(2)"
            WFIL3 = evalue(WEVA) 
          When Default :
            WEVA  = PARAM(I)+"(0)"
            WFIL1 = evalue(WEVA) 
            WEVA  = PARAM(I)+"(1)"
            WFIL2 = evalue(WEVA) 
            WEVA  = PARAM(I)+"(2)"
            WFIL3 = evalue(WEVA) 
            WEVA  = PARAM(I)+"(3)"
            WFIL4 = evalue(WEVA) 
        Endcase 
      Endif
  Endcase 
Next I 
Return
############################################################
$LECTURE
If [M:OIT1]ITMREF = "" | [M:OIT1]FCY = ""
  NBLU = 0
  Return
Endif
# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [ORD]  
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [ORD] 
      If WLIG >= WSKIP 
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif  
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:OIT2]
    WLIG = 0
    For [ORD]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [ORD] 
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1 
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif  
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [ORD] 
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return
############################################################
$TRT_FILTER
If [M:OIT1]FLG = 0
  [M:OIT1]FLG = 1
  Raz [M:OIT2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  If WFIL4 <> ""
    Filter [ORD] Where evalue(WFIL) & evalue(WFILSPE) &
&                     (evalue(WFIL1) or evalue(WFIL2) or evalue(WFIL3) or evalue(WFIL4))
&                Order By Key ORD1
  Else
    If WFIL3 <> ""
      Filter [ORD] Where evalue(WFIL) & evalue(WFILSPE) &
&                       (evalue(WFIL1) or evalue(WFIL2) or evalue(WFIL3))
&                  Order By Key ORD1
    Else
      If WFIL2 <> ""
        Filter [ORD] Where evalue(WFIL) & evalue(WFILSPE) &
&                         (evalue(WFIL1) or evalue(WFIL2))
&                    Order By Key ORD1 
      Else
        If WFIL1 <> ""
          Filter [ORD] Where evalue(WFIL) & evalue(WFILSPE) &
&                            evalue(WFIL1)    
&                      Order By Key ORD1
        Else
          Filter [ORD] Where evalue(WFIL) & evalue(WFILSPE)     
&                Order By Key ORD1
         Endif 
      Endif 
    Endif  
  Endif
  Raz [F:ORD]
Endif
Return
############################################################
$LOAD_FILTER
WFIL = "[F:ORD]STOFCY=[M:OIT1]FCY&[F:ORD]ITMREF=[M:OIT1]ITMREF"
Return
############################################################
$LOA_LIGNE
[M:OIT2] = [F:ORD]
[M:OIT2]WIPTYPSTA(nolign-1) = mess([F:ORD]WIPTYP,341,1)+
&                             mess([F:ORD]WIPSTA,342,1)
[M:OIT2]STU(nolign-1)       = [F:ITM]STU
Return
############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
VALEUR = vireblc(VALEUR,4)
If VALEUR <> ""
  Call VERFCY(VALEUR) From CONTX3
Endif
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:OIT1]FLG = 0
End
############################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:OIT1] = [F:ITM]
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:OIT1]FLG = 0
End
############################################################
Subprog INFWIP(LTYP,LSTA,LNUM)
Value Integer LTYP
Value Integer LSTA
Value Char    LNUM
Local Char    WMSG(80)
WMSG = mess(LTYP,341,1)+mess(LSTA,342,1)+" = "+mess(LTYP,306,1)- mess(LSTA,317,1)-
&      +" : "+LNUM
Call MESSAGE(WMSG) From GESECRAN
End
############################################################
Subprog AV_WIPTYPSTA(VALEUR)
Variable Char    VALEUR()
If nolign > 0
  If find([M:OIT2]WIPTYP(nolign-1),1,3,4,6,8)
    pcolor = GCOUL(1)
  Else
    pcolor = GCOUL(0)
  Endif
Endif
End


# FQ 57754 Module Tronc commun GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(9)<>2 End Endif

Call VALGTC(APPLI,"OIT") From SUBGTC

End



