#<AdxTL>@(#)4.0.0.0 $Revision$
# Gestion du masque CHGWRH
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "OK"       : Gosub OK
 When Default
Endcase
Return


$OUVRE
If !clalev([F:FCY])  Local File FACILITY    [FCY]  Endif
If !clalev([F:AUT])  Local File AUTILIS    [AUT]  Endif
Return


$DEBUT
Raz [M:CWRH]
If GFCYDEF(7) <> ""
    [M:CWRH]STOFCY = GFCYDEF(7)
Else
    Call STKASFCY([M:CWRH]STOFCY) From STKACT
Endif
[M:CWRH]WRH    = GUSRWRH
[M:CWRH]NEWWRH = GUSRWRH
Return

$OK
# Permet de changer de dépôt utilisateur ou de le remettre à blanc
GUSRWRH = [M:CWRH]NEWWRH
#MAJ de la table AUTILIS
Trbegin AUTILIS[AUT]
Readlock [AUT]CODUSR=GUSER
[F:AUT]WRH = GUSRWRH
If fstat  Goto ABANDON  Endif
Rewrite[AUT]
If fstat  Goto ABANDON  Endif
Commit
Return

$ABANDON
Rollback
Return




