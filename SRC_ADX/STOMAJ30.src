###############################################################################
# STKSRU : Init de la règle de sortie sous-traitance dans les règles de gestion
###############################################################################
# Paramètres E : LDOS   = Dossier
###############################################################################
Subprog STKSRU(LDOS)
Value Char LDOS  # FGR 18/01/2010 : X3SUIVI60986

Local File =LDOS+".TABSTORUL"  [SRU]
Local Integer TYP, TYPORI

# Sortie ordre sous-traitance
TYP=29 : TYPORI=6
Gosub INI_SRU
# Retour réception sous-traitance
TYP=32 : TYPORI=11
Gosub INI_SRU
# Réception sous-traitance
TYP=16 : TYPORI=3
Gosub INI_SRU
# Retour livraison sous-traitance
TYP=33 : TYPORI=12
Gosub INI_SRU

Call DEBTRANS From GLOCK
Trbegin [SRU]
For [SRU]
   #Readlock [SRU] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
   #If !fstat
      [F:SRU]LOCNUM  += 1
      [F:SRU]LOCNUM2 += 1
      [F:SRU]LOCNUM3 += 1
      If [F:SRU]SHLLOT = 2
         [F:SRU]SHLLOT = 3
      Endif
      Rewrite [SRU]
      If fstat
         Call ECR_TRACE("File TABSTORUL, Error ="-num$(fstat),1) From GESECRAN
      Endif
   #Endif
Next
Commit

End

$INI_SRU
Read [SRU]SRU0="";"";TYP;""
If fstat
   Call DEBTRANS From GLOCK
   Trbegin [SRU]
   Read [SRU]SRU0="";"";TYPORI;""
   If fstat
      Raz [F:SRU]
      [F:SRU]AUZSTA    = 1
      [F:SRU]AUZSST    = "A*"
      [F:SRU]FORSTA    = 'pat(%,"A*")<>0'
      [F:SRU]QLYCTLFLG = 1
      [F:SRU]DACLOT    = 2
      [F:SRU]LOTSUPINH = 1
      [F:SRU]SHLLOT    = 1
   Endif
   [F:SRU]TRSTYP    = TYP
   [F:SRU]CREUSR    = GUSER
   [F:SRU]CREDAT    = date$
   Write [SRU]
   If fstat
      Call ECR_TRACE("File TABSTORUL, Error ="-num$(fstat),1) From GESECRAN
   Endif
   Commit
Endif
Return

###############################################################################
# STKITG : MAJ des catégories:
#             - Init des nouvelles règles d'allocation
#             - Init des types de mouvements pour FG
###############################################################################
# Paramètres E : LDOS   = Dossier
###############################################################################
Subprog STKITG(LDOS)
Value Char LDOS  # FGR 18/01/2010 : X3SUIVI60986

Local File =LDOS+".ITMCATEG"   [ITG]
Local File =LDOS+".OVERHEAD"   [OVE]

Call DEBTRANS From GLOCK
Trbegin [ITG]
For [ITG]ITG0
   #---- Règles d'allocations ----#
   [F:ITG]ALLRULORD = [F:ITG]ALLRULSHI
   [F:ITG]ALLRULMAT = [F:ITG]ALLRULMFG
   #---- FG ----#
   If [F:ITG]OVECOD<>""
      Read [OVE]OVE0=[F:ITG]OVECOD
      If [F:OVE]CLCLEV=1  # Appliqué en entrée
         [F:ITG]OTRSTYP(0) = 5 # --> entrée OF
      Else                # Appliqué en sortie
         [F:ITG]OTRSTYP(0) = 6 # --> sortie OF
      Endif
      If [F:OVE]CLCMOD=1
         [F:ITG]OVECPNFLG=1
      Else
         [F:ITG]OVECPNFLG=2
      Endif
   Endif
   Rewrite [ITG]
   If fstat
      Call ECR_TRACE("File ITMCATEG, Error ="-num$(fstat),1) From GESECRAN
   Endif
Next
Commit

End

###############################################################################
# STKITF : MAJ des articles-sites
#             - Init des types de mouvements pour FG
#             - Init de STOMGTCOD
###############################################################################
# Paramètres E : LDOS   = Dossier
###############################################################################
Subprog STKITF(LDOS)
Value Char LDOS  # FGR 18/01/2010 : X3SUIVI60986

Local File =LDOS+".ITMFACILIT" [ITF]
Local File =LDOS+".OVERHEAD"   [OVE]
Local File =LDOS+".ITMMASTER"  [ITM]

Call DEBTRANS From GLOCK
Trbegin [ITF]
For [ITF]ITF0
   #---- FG ----#
   If [F:ITF]OVECOD<>""
      Read [OVE]OVE0=[F:ITF]OVECOD
      If [F:OVE]CLCLEV=1  # Appliqué en entrée
         [F:ITF]OTRSTYP(0) = 5 # --> entrée OF
      Else                # Appliqué en sortie
         [F:ITF]OTRSTYP(0) = 6 # --> sortie OF
      Endif
      If [F:OVE]CLCMOD=1
         [F:ITF]OVECPNFLG=1
      Else
         [F:ITF]OVECPNFLG=2
      Endif
   Endif
   #---- STOMGTCOD ----#
   Read [ITM]ITM0=[F:ITF]ITMREF
   If !fstat
      [F:ITF]STOMGTCOD = [F:ITM]STOMGTCOD
   Endif
   Rewrite [ITF]
   If fstat
      Call ECR_TRACE("File ITMFACILIT, Error ="-num$(fstat),1) From GESECRAN
   Endif
Next
Commit

End

###############################################################################
# STKSTO : MAJ des stocks
#             - Init propriétaire
###############################################################################
# Paramètres E : LDOS   = Dossier
#################################################################################
Subprog STKSTO(LDOS)
Value Char LDOS

#----- Ouverture des fichiers -----#
If clalev([F:STO])  =0  Local File =LDOS+".STOCK"   [STO] : Endif

Local Integer COMPTEUR
Local Integer STOP
Local Char    CRIT(250)
Local Char    LSTOFCY
Local Decimal LSTOCOU

Gosub SET_FIRST From TRTFIRST

Raz STOP
$BOUCLE_STO
If STOP=1
   CRIT = "STOFCY=LSTOFCY & STOCOU>LSTOCOU"
   STOP = 2
Elsif STOP=2
   CRIT = "STOFCY>LSTOFCY"
   STOP = 0
Else
   CRIT = "1=1"
Endif
Trbegin [STO]
Raz COMPTEUR
For [STO]STO0 Where evalue(CRIT)
   If [F:STO]OWNER=""
      #Readlock [STO]Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
      #If fstat
      #   Call ECR_TRACE("File STOCK, Error ="-num$(fstat),1) From GESECRAN
      #Else
         [F:STO]OWNER = [F:STO]STOFCY
         Rewrite [STO]
         If fstat
            Call ECR_TRACE("File STOCK, Error ="-num$(fstat),1) From GESECRAN
         Else
            COMPTEUR +=1
         Endif
      #Endif
   Endif
   If COMPTEUR>GMAXUPDTRS
      LSTOFCY = [F:STO]STOFCY
      LSTOCOU = [F:STO]STOCOU
      STOP = 1
      Break
   Endif
Next
Commit
If STOP
   Goto $BOUCLE_STO
Endif

Gosub UNSET_FIRST From TRTFIRST

End

###############################################################################
# STKCUD : MAJ des inventaires
#             - Init propriétaire
###############################################################################
# Paramètres E : LDOS   = Dossier
#################################################################################
Subprog STKCUD(LDOS)
Value Char LDOS

#----- Ouverture des fichiers -----#
If clalev([F:CUD])  =0  Local File =LDOS+".CUNLISDET"   [CUD] : Endif

Call DEBTRANS From GLOCK
Trbegin [CUD]
Update [CUD] Where OWNER=""
&            With  OWNER=STOFCY
If fstat
   Call ECR_TRACE("File CUNLISDET : Update --> fstat="+num$(fstat),1) From GESECRAN
Endif
Commit

End

