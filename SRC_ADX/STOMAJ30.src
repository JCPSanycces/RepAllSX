#########################################################################
#  STKBENCHTRS  : Mise à jour  table  BENCHTRS
#########################################################################
Subprog STKBENCHTRS
Local Integer K
Local Integer INDIC
If filinfo (filpath ("FIL", "BENCHTRS"   , "fde",[F:ADS]DOSSIER ) ,0) < 0: End : Endif

Local File =[F:ADS]DOSSIER+".BENCHTRS"   [BTS]

Trbegin [BTS]
For [BTS]BTS0
    Raz INDIC
    Case [F:BTS]BTSTYP
        When 51:     # Planning global
                     If [F:BTS]LAN(10) = 0
                         For K = 9 To 3 Step -1
                             [F:BTS]SUG(K) = [F:BTS]SUG(K-1)
                             [F:BTS]PLN(K) = [F:BTS]PLN(K-1)
                             [F:BTS]LAN(K) = [F:BTS]LAN(K-1)
                             [F:BTS]CRIT(K) = [F:BTS]CRIT(K-1)
                             [F:BTS]NCRIT(K) = [F:BTS]NCRIT(K-1)
                             If [F:BTS]SUG(K) = 0 : [F:BTS]SUG(K) = 1 : Endif
                             If [F:BTS]PLN(K) = 0 : [F:BTS]PLN(K) = 1 : Endif
                             If [F:BTS]LAN(K) = 0 : [F:BTS]LAN(K) = 1 : Endif
                             If [F:BTS]CRIT(K) = 0 : [F:BTS]CRIT(K) = 1 : Endif
                             If [F:BTS]NCRIT(K) = 0 : [F:BTS]NCRIT(K) = 1 : Endif
                         Next K
                         [F:BTS]SUG(2) = 1
                         [F:BTS]PLN(2) = 1
                         [F:BTS]LAN(2) = 1
                         [F:BTS]CRIT(2) = 1
                         [F:BTS]NCRIT(2) = 1
                         [F:BTS]SUG(10) = 1
                         [F:BTS]PLN(10) = 1
                         [F:BTS]LAN(10) = 1
                         [F:BTS]CRIT(10) = 1
                         [F:BTS]NCRIT(10) = 1
                         INDIC = 1
                     Endif
                     # FQ 68706 GA 11/2010
                     If [F:BTS]MRPFLG=0
                         [F:BTS]MRPFLG=3 # Menu local 2312: 3=Toutes (suggestions)
                         INDIC = 1
                     Endif
        When 52:     # Plan détaillé
                     If [F:BTS]LAN(10) = 0
                         For K = 9 To 3 Step -1
                             [F:BTS]SUG(K) = [F:BTS]SUG(K-1)
                             [F:BTS]PLN(K) = [F:BTS]PLN(K-1)
                             [F:BTS]LAN(K) = [F:BTS]LAN(K-1)
                             [F:BTS]CRIT(K) = [F:BTS]CRIT(K-1)
                             [F:BTS]NCRIT(K) = [F:BTS]NCRIT(K-1)
                             If [F:BTS]SUG(K) = 0 : [F:BTS]SUG(K) = 1 : Endif
                             If [F:BTS]PLN(K) = 0 : [F:BTS]PLN(K) = 1 : Endif
                             If [F:BTS]LAN(K) = 0 : [F:BTS]LAN(K) = 1 : Endif
                             If [F:BTS]CRIT(K) = 0 : [F:BTS]CRIT(K) = 1 : Endif
                             If [F:BTS]NCRIT(K) = 0 : [F:BTS]NCRIT(K) = 1 : Endif
                         Next K
                         [F:BTS]SUG(2) = 2
                         [F:BTS]PLN(2) = 2
                         [F:BTS]LAN(2) = 2
                         [F:BTS]CRIT(2) = 2
                         [F:BTS]NCRIT(2) = 2
                         [F:BTS]SUG(10) = 2
                         [F:BTS]PLN(10) = 2
                         [F:BTS]LAN(10) = 2
                         [F:BTS]CRIT(10) = 2
                         [F:BTS]NCRIT(10) = 2
                         INDIC = 1
                     Endif
                     # FQ 68706 GA 11/2010
                     If [F:BTS]MRPFLG=0
                         [F:BTS]MRPFLG=3 # Menu local 2312: 3=Toutes (suggestions)
                         INDIC = 1
                     Endif
        When 53:     # Regroupement
                     # FQ 68706 GA 11/2010
                     If [F:BTS]MRPFLG=0
                         [F:BTS]MRPFLG=3 # Menu local 2312: 3=Toutes (suggestions)
                         INDIC = 1
                     Endif
    Endcase
    If INDIC = 1
        Rewrite [F:BTS]
    Endif
Next
Commit
Close Local File [BTS]

End

#########################################################################
#  STKPARMRP : mise à jour  table  PARMRP
#########################################################################
Subprog STKPARMRP(LDOS)
Value Char LDOS

If filinfo(filpath("FIL","PARMRP","fde",LDOS),0) < 0  : End : Endif

Local File =LDOS+".PARMRP"       [PCB]

Call DEBTRANS From GLOCK
Trbegin [PCB]
For [PCB]
    GOK = 1
    #Readlock [PCB]PCB0 Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat
    #    Call ECR_TRACE("File PARMRP, Error ="-num$(fstat),1) From GESECRAN
    #Else
        #------------------- MRP: ajout Type d'alternative en V6
        If dim([F:PCB]MRPALTTYP)>0 & dim([F:PCB]MPSALTTYP)>0
           If [F:PCB]MRPALTTYP=0 : [F:PCB]MRPALTTYP=2 : Endif
           If [F:PCB]MPSALTTYP=0 : [F:PCB]MPSALTTYP=2 : Endif
        Endif
        Rewrite [PCB]
    #Endif
Next

Commit
Close Local File [PCB]
End

#########################################################################
#  UPDPAS : mise à jour  table  PARSTOACC (alimentation de la législation)
#########################################################################
Subprog UPDPAS(LDOS)
Value Char LDOS

If filinfo(filpath("FIL","PARSTOACC","fde",LDOS),0) < 0  : End : Endif

Local File =LDOS+".PARSTOACC"       [PAS]
Local File =LDOS+".PARSTOACC"       [PAS2]

Local Integer LRET
Local Integer LNBLEG
Local Char    LDOSLEG(type(GDOSLEG(1))-10)(1..dim(GDOSLEG))

Call SETLEG(LDOS,LDOSLEG,LNBLEG) From DOSCONT

If LNBLEG=0
    Call ECR_TRACE(LDOS-": No legislation found",1) From GESECRAN
    End
Endif

Call DEBTRANS From GLOCK
Trbegin [PAS]
Update [PAS] Where LEG=""
&            With LEG=LDOSLEG(1)
Commit
For I_LEG=2 To LNBLEG
    Trbegin [PAS]
    For [PAS] Where LEG=LDOSLEG(1)
        [F:PAS2] = [F:PAS]
        [F:PAS2]LEG = LDOSLEG(I_LEG)
        Write [PAS2]
    Next
    Commit
Next

# On ne génère pas le traitement car cela est de toute façon fait au moment de la comptabilisation.

# Mise à jour de l'onglet sélection de l'objet PAS
Call MAJ_SEL(LDOS,"PAS") From PATCHAOB
Call VALID("PAS",LDOS,1,LRET) From VALOBJ
Call VALID("OPAS",LDOS,1,LRET) From VALWIN

Close Local File [PAS]
Close Local File [PAS2]
End

###############################################################################
# LOTFCY : Décomposition de la valeur du lot                                  #
###############################################################################
# Paramètres E : PDOS   = Dossier
###############################################################################
Subprog LOTFCY(PDOS)
Value Char PDOS

Local File =PDOS+".ACTIV"   [ACV]
Read [ACV]CODACT="SPD"
If [F:ACV]FLACT<>2
    End
Endif

If filinfo(filpath("FIL","STOLOTFCY","fde",PDOS),0)<=0 : End : Endif
If filinfo(filpath("FIL","ITMCOST","fde",PDOS),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": STOLOTFCY"-time$,0) From GESECRAN : # maj table

Local File =PDOS+".STOLOTFCY" [SLF]
Local File =PDOS+".ITMCOST"   [ITC]
Local File =PDOS+".ITMMVT"    [ITV]
Local File =PDOS+".ITMMASTER" [ITM]

#                                      hcb 77238 deb
# Validation des écrans
Local Integer LERR
Call VALIDDIRECT ("SAIDECPRI",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,LERR) From VALMSK
If LERR<>1
   Call ECR_TRACE(mess(21,123,1)-": SAIDECPRI",1) From GESECRAN
   End
Endif
Raz LERR
#                                      hcb 77238 fin


If !clalev([M:SDP]) : Local Mask =PDOS+".SAIDECPRI" [SDP] : Endif

Local Integer LNB, LSTOP
Local Char    LFIL(250)
Local Char    LITM(GLONITM), LFCY(GLONFCY), LLOT(GLONLOT), LSLO(GLONSLO)
Local Decimal LPRI
#Local Integer LERR                 # hcb 77238
Local Char LDOS : LDOS = PDOS
Gosub SAVE_GACT

Gosub SET_FIRST From TRTFIRST

# Issue 117168 - 2016-11-17 by ERMIL : Incorrect rounding of AVCBASAMT
If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
Call INIRNDVAL("STOLOTFCY","AVCBASAMT") From STKVALECR

$SLF_LOOP
Call DEBTRANS From GLOCK
Trbegin [SLF]

If LSTOP = 1
    LFIL = "ITMREF=LITM & STOFCY=LFCY & LOT=LLOT & SLO>LSLO"
    LSTOP +=1
Elsif LSTOP = 2
    LFIL = "ITMREF=LITM & STOFCY=LFCY & LOT>LLOT"
    LSTOP +=1
Elsif LSTOP = 3
    LFIL = "ITMREF=LITM & STOFCY>LFCY"
    LSTOP +=1
Elsif LSTOP = 4
    LFIL = "ITMREF>LITM"
    LSTOP =0
Else
    LFIL = "1=1"
Endif

Filter [SLF] Where evalue(LFIL) Order By ITMREF;STOFCY;LOT;SLO
For [SLF]
    If [F:SLF]ITMREF<>LITM | [F:SLF]STOFCY<>LFCY
        Call GETPRI([F:SLF]ITMREF,"","",[F:SLF]STOFCY, date$, 1, "", "", 1, LPRI, LERR) From STKVAL    # SDP ouvert => rempli par getpri
    Endif
    If LERR>1
        Call ECR_TRACE([F:SLF]ITMREF - [F:SLF]STOFCY-"GETPRI error : "+num$(LERR),1) From GESECRAN
    Else
        # La décomposition de la valeur du lot se fait après mise à jour car SDP n'existe pas encore
        LDIFPRI = [F:SLF]AVCBASAMT - [M:SDP]PRI
        Gosub REPARTIR From SUBSDP
        Call SDP2FIL("[F:SLF]", "A", 1) From SUBSDPCOM
        #GRNDVAL = 10^-6  #117168.o
        If [F:SLF]AVCBASQTY=0
            [F:SLF]AVC=0
            Call ECR_TRACE([F:SLF]ITMREF-[F:SLF]STOFCY-" : [F:SLF]AVCBASQTY=0",1) From GESECRAN
        Else
            Gosub UPDLOTAVC From STKVALMAJ2
        Endif
        Rewrite [SLF]
        LNB +=1
    Endif
    LITM=[F:SLF]ITMREF
    LFCY=[F:SLF]STOFCY
    LLOT=[F:SLF]LOT
    LSLO=[F:SLF]SLO
    If LNB>GMAXUPDTRS
        LSTOP=1
        Break
    Endif
Next
Filter [SLF]

Raz LNB
Commit
If LSTOP>0
    Goto SLF_LOOP
Endif

Gosub UNSET_FIRST From TRTFIRST

Gosub REST_GACT

End




###########################################################################
# STKANASMH : Création d'enregistrements dans nouvelle    table CPTANALIN #
#             Remplacement des champs comptes et sections table SMVTH     #
###########################################################################
Subprog STKANASMH(LDOS)
Value Char LDOS
#

If [F:ADS]MODULE(1)=2  Local File =LDOS+".GACM" [GCM] : Endif
If clalev([F:SMH]) = 0 : Local File =LDOS+".SMVTH"      [SMH] : Endif
If clalev([F:SMD]) = 0 : Local File =LDOS+".SMVTD"      [SMD] : Endif
If clalev([F:CAL]) = 0 : Local File =LDOS+".CPTANALIN"  [CAL] : Endif

#----                                                                SMVH SMVTD ----#

Call ECR_TRACE("Start trace : SMVH SMVTD / Cce" ,0) From GESECRAN
Local Integer I
Local Integer J

Call DEBTRANS From GLOCK
Trbegin [SMH] , [SMD]
For [SMH]
#----
    #Readlock [SMH] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If !fstat
    #----- Alimentation champs pour le multi-référenciels comptabilité -----#
       Call RECUP_GLOBAL_CPT(LDOS,[F:SMH]STOFCY) From TRTX3CPT
       For I=1 To max(GNBDIE,GOPTCANA)
           [F:SMH]DIE(I-1) = GDIE(I)
           If evalue("dim([F:SMH]CCE"+num$(I)+")")>0
              [F:SMH]CCE(I-1) =  evalue("[F:SMH]CCE"+num$(I))
           Endif
       Next I
       Rewrite [SMH]
       If fstat
          Call ECR_TRACE("File SMVTH"-[F:SMH]VCRNUM+", Error ="-num$(fstat),1) From GESECRAN
       Endif
    #Endif
    For [SMD] Where VCRTYP = [F:SMH]VCRTYP & VCRNUM=[F:SMH]VCRNUM
#----
        Read [SMD] Curr
        If fstat
           Call ECR_TRACE("File SMVTD"-[F:SMH]VCRNUM+", Error ="-num$(fstat),1) From GESECRAN
        Else
           Look [CAL] CAL0="SMD";[F:SMD]VCRTYP;[F:SMD]VCRNUM;[F:SMD]VCRLIN;0;"";1
           If fstat
              Raz [F:CAL]
              [F:CAL]ABRFIC="SMD"
              [F:CAL]VCRTYP=[F:SMD]VCRTYP
              [F:CAL]VCRNUM=[F:SMD]VCRNUM
              [F:CAL]VCRLIN=[F:SMD]VCRLIN
              [F:CAL]ANALIG=1
              For J=1 To max(GNBCOA,2)
                [F:CAL]LED(J-1)=GLEDSOC(J)
                [F:CAL]COA(J-1)=GCOA(J)
              Next J
              For J=1 To max(GNBDIE,GOPTCANA)
                  [F:CAL]DIE(J-1)=GDIE(J)
                  If evalue("dim([F:SMD]CCE"+num$(J)+")")>0
                    [F:CAL]CCE(J-1)=evalue("[F:SMD]CCE"+num$(J))
                  Endif
              Next J
              Write [CAL]
              If fstat
                 Call ECR_TRACE("File CPTANALIN SMD"-num$([F:SMD]VCRTYP)-[F:SMD]VCRNUM-num$([F:SMD]VCRLIN)
&                             +", Error ="-num$(fstat),1) From GESECRAN
              Endif
           Endif
        Endif
    Next
Next
Commit

If [F:ADS]MODULE(1)=2  Close Local File [GCM] : Endif

End


###########################################################################
# STKANASGH : Création d'enregistrements dans nouvelle    table CPTANALIN #
#             Remplacement des champs comptes et sections table SCHGH     #
###########################################################################
Subprog STKANASGH(LDOS)
Value Char LDOS

If [F:ADS]MODULE(1)=2  Local File =LDOS+".GACM" [GCM] : Endif
If clalev([F:SGH]) = 0 : Local File =LDOS+".SCHGH"      [SGH] : Endif
If clalev([F:SGD]) = 0 : Local File =LDOS+".SCHGD"      [SGD] : Endif
If clalev([F:CAL]) = 0 : Local File =LDOS+".CPTANALIN"  [CAL] : Endif


Call ECR_TRACE("Start trace : SCHGH SCHGD / Cce" ,0) From GESECRAN
Local Integer I
Local Integer J

Call DEBTRANS From GLOCK
Trbegin [SGH] , [SGD]
For [SGH]
#----
    #Readlock [SGH] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If !fstat
    #----- Alimentation champs pour le multi-référenciels comptabilité -----#
       Call RECUP_GLOBAL_CPT(LDOS,[F:SGH]STOFCY) From TRTX3CPT
       For I=1 To max(GNBDIE,GOPTCANA)
           [F:SGH]DIE(I-1) = GDIE(I)
           If evalue("dim([F:SGH]CCE"+num$(I)+")")>0
              [F:SGH]CCE(I-1) =  evalue("[F:SGH]CCE"+num$(I))
           Endif
       Next I
      Rewrite [SGH]
       If fstat
          Call ECR_TRACE("File SCHGH"-[F:SGH]VCRNUM+", Error ="-num$(fstat),1) From GESECRAN
       Endif
    #Endif
    For [SGD] Where VCRNUM = [F:SGH]VCRNUM
#----
        Read [SGD] Curr
        If fstat
           Call ECR_TRACE("File SCHGD"-[F:SGH]VCRNUM+", Error ="-num$(fstat),1) From GESECRAN
        Else
           Look [CAL] CAL0="SGD";29;[F:SGD]VCRNUM;[F:SGD]VCRLIN;0;"";1
           If fstat
              Raz [F:CAL]
              [F:CAL]ABRFIC="SGD"
              [F:CAL]VCRTYP= 29
              [F:CAL]VCRNUM=[F:SGD]VCRNUM
              [F:CAL]VCRLIN=[F:SGD]VCRLIN
              [F:CAL]ANALIG=1
              For J=1 To max(GNBCOA,2)
                [F:CAL]LED(J-1)=GLEDSOC(J)
                [F:CAL]COA(J-1)=GCOA(J)
              Next J
              For J=1 To max(GNBDIE,GOPTCANA)
                  [F:CAL]DIE(J-1)=GDIE(J)
                  If evalue("dim([F:SGD]CCE"+num$(J)+")")>0
                    [F:CAL]CCE(J-1)=evalue("[F:SGD]CCE"+num$(J))
                  Endif
            Next J
            Write [CAL]
              If fstat
                 Call ECR_TRACE("File CPTANALIN SGD"-[F:SGD]VCRNUM-num$([F:SGD]VCRLIN)
&                             +", Error ="-num$(fstat),1) From GESECRAN
              Endif
           Endif
        Endif
    Next
Next
Commit

If [F:ADS]MODULE(1)=2  Close Local File [GCM] : Endif

End

###########################################################################
# STKANASRT : Création d'enregistrements dans nouvelle    table DIETRS    #
#             depuis STKTRS                                               #
###########################################################################
#  1 Transactions entrees diverses                                 #
#  2 Transactions sorties diverses                                 #
#  5 Transactions plan de rangement                                #
#  3 Transactions changement de stock                              #
#  6 Transactions inventaire            (en attente)               #
#  7 Transactions assemblage / desassemblage                       #
#------------------------------------------------------------------#
Subprog STKANASRT(LDOS)
Value Char LDOS
Local Integer WI
Raz WI
If clalev([F:SRT]) = 0 : Local File =LDOS+".STKTRS"      [SRT] : Endif
If clalev([F:DTR]) = 0 : Local File =LDOS+".DIETRS"      [DTR] : Endif
If clalev([F:DIE]) = 0 : Local File =LDOS+".GDIE"        [DIE] : Endif

Call ECR_TIME(" Stock Transactions : Update STKTRS") From DOSSUB
#----- S'assurer que la table contient les anciens champs supprimés -----#

Call DEBTRANS From GLOCK
Trbegin [DTR]
For [SRT] SRT0 Where find(SRTTYP,1,2,3,5,6,7)
    Read [SRT] Curr
    If fstat
       Call ECR_TRACE("File STKTRS"-num$([F:SRT]SRTTYP)-[F:SRT]SRTNUM+", Error ="-num$(fstat),1) From GESECRAN
    Else
       #----- Alimentation nouvelle table pour axes analytiques -----#
       Look [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0
       If fstat
          If [F:SRT]HEACCECOD=0  [F:SRT]HEACCECOD=3 : Endif
          If [F:SRT]CCECODS  =0  [F:SRT]CCECODS  =3 : Endif
          Raz [F:DTR]
          [F:DTR]ABRFIC="SRT"
          [F:DTR]DTRTYP=[F:SRT]SRTTYP
          [F:DTR]DTRNUM=[F:SRT]SRTNUM
          [F:DTR]DIE   =""
          [F:DTR]HEACCECOD=[F:SRT]HEACCECOD
          [F:DTR]STOCCECOD=[F:SRT]CCECODS
          [F:DTR]DSPCOD =3
          [F:DTR]DSPSCR =1
          [F:DTR]CCESCR =[F:SRT]CCESCR(0)
          [F:DTR]CCESCR2=1
          [F:DTR]CCESCR3=1
          Write [DTR]
          If fstat
            Call ECR_TRACE("File DIETRS"-[F:DTR]ABRFIC-num$([F:DTR]DTRTYP)+", ERROR ="-num$(fstat),1) From GESECRAN
          Endif
          Raz WI
          For [DIE] DIE0
              Look [DTR] DTR1="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;1;[F:DIE]DIE
              If fstat
                 [F:DTR]DTRTNU=1
                 [F:DTR]DTRLIN=WI+1
                 [F:DTR]DIE   =[F:DIE]DIE
                 If dim([F:SRT]CCECOD)>WI & [F:SRT]CCECOD(WI)>0 & [F:SRT]CCECOD(WI)<3
                   [F:DTR]CCECOD=[F:SRT]CCECOD(WI)
                   Write [DTR]
                   If fstat
                     Call ECR_TRACE("File DIETRS"-[F:DTR]ABRFIC-num$([F:DTR]DTRTYP)+", ERROR ="-num$(fstat),1) From GESECRAN
                   Endif
                 Endif
              Endif
              WI+=1
          Next
       Endif
    Endif
Next
Commit

#-----
End


###########################################################################
# STKANACUN : Remplacement des champs comptes et sections table CUNLISTE  #
#             Remplacement des champs comptes et sections table CUNLISDET #
###########################################################################
Subprog STKANACUN(LDOS)
Value Char LDOS
#

If [F:ADS]MODULE(1)=2  Local File =LDOS+".GACM" [GCM] : Endif
If clalev([F:CUL]) = 0 : Local File =LDOS+".CUNLISTE"   [CUL] : Endif
If clalev([F:CUD]) = 0 : Local File =LDOS+".CUNLISDET"  [CUD] : Endif

#----                                                                SMVH SMVTD ----#

Call ECR_TRACE("Start trace : CUNLISTE CUNLISDET / Cce" ,0) From GESECRAN
Local Integer I
Local Integer J

Call DEBTRANS From GLOCK
Trbegin [CUL] , [CUD]
For [CUL]
#----
    #Readlock [CUL] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If !fstat
    #----- Alimentation champs pour le multi-référenciels comptabilité -----#
       Call RECUP_GLOBAL_CPT(LDOS,[F:CUL]STOFCY) From TRTX3CPT
       For I=1 To max(GNBDIE,GOPTCANA)
           [F:CUL]DIE(I-1) = GDIE(I)
           If evalue("dim([F:CUL]CCE"+num$(I)+")")>0
              [F:CUL]CCE(I-1) =  evalue("[F:CUL]CCE"+num$(I))
           Endif
       Next I
       Rewrite [CUL]
       If fstat
          Call ECR_TRACE("File CUNLISTE"-[F:CUL]CUNSSSNUM-[F:CUL]CUNLISNUM+", Error ="-num$(fstat),1) From GESECRAN
       Endif
    #Endif
    For [CUD] Where CUNSSSNUM = [F:CUL]CUNSSSNUM & CUNLISNUM=[F:CUL]CUNLISNUM
#----
        #Readlock [CUD] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
        #If !fstat
           For I=1 To max(GNBDIE,GOPTCANA)
               [F:CUD]DIE(I-1) = GDIE(I)
               If evalue("dim([F:CUD]CCE"+num$(I)+")")>0
                  [F:CUD]CCE(I-1) =  evalue("[F:CUD]CCE"+num$(I))
               Endif
           Next I
           Rewrite [CUD]
           If fstat
              Call ECR_TRACE("File CUNLISDET"-[F:CUD]CUNSSSNUM-[F:CUD]CUNLISNUM+", Error ="-num$(fstat),1) From GESECRAN
           Endif
        #Endif
    Next
Next
Commit

If [F:ADS]MODULE(1)=2  Close Local File [GCM] : Endif

End


$SAVE_GACT
Local Integer LACTMAT, LACTMAC, LACTLAB

LACTMAT = GACTMAT
LACTMAC = GACTMAC
LACTLAB = GACTLAB

GACTLAB = func AFNC.ACTIVDOS(LDOS,"LAB")
GACTMAC = func AFNC.ACTIVDOS(LDOS,"MAC")
GACTMAT = func AFNC.ACTIVDOS(LDOS,"MAT")
Return

$REST_GACT
GACTMAT = LACTMAT
GACTMAC = LACTMAC
GACTLAB = LACTLAB
Return

