#CHECK IGNORE_SOURCE
Call OUVRE_TRACE ("ccc") From LECFIC
Local File ADOSSIER
Read [F:ADS]DOSSIER="GX3APP"
#Call ASTOMAJ30
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End
#################################################################################
# Avant mise à jour dictionnaire    AMAJDIC30                                   #
# ----------------------------------------------------------------------------- #
# Affecte les valeurs 6, 3 et 3 aux nouveaux codes activités MAT, MAC et LAB    #
# ----------------------------------------------------------------------------- #
# Avant mise à jour                 ASTOMAJ30                                   #
# ----------------------------------------------------------------------------- #
#   - DES2AXX     : Remplacement des champs DES par des intitulés traduisibles  #
#   - ALOTFCY     : Remplit la nouvelle table STOLOTFCY                         #
#   - STKSTJ      : Init nouvelles zones mouvements de stock                    #
#   - STKSTQ      : Evolutions liées au contrôle qualité                        #
#   - STKSTL      : Evolutions à la péremption                                  #
# ----------------------------------------------------------------------------- #
# Après mise à jour                 STOMAJ30                                    #
# ----------------------------------------------------------------------------- #
#   - STKSRU      : Init règle sortie ordre s-traitance, réception s-traitance, #
#                   retour réception s-traitance, retour livraison s-traitance  #
#                   Décalage des intitulés d'emplacements dans les règles       #
#   - STKITG      : Init nouvelles zones catégories articles                    #
#   - STKITF      : Init nouvelles zones articles-sites                         #
#   - STKSTO      : Init propriétaire dans stocks                               #
#   - STKCUD      : Init propriétaire dans inventaires                          #
#   - STKQLD      : Init propriétaire dans détail contrôle qualité              #
#   - STKSGD      : Init propriétaire dans détail changement de stock           #
#   - UPDSMD      : Initialisation nouvelles zones                              #
#   - MAJVALITV   : Init des détails de prix (PMP et dernier prix)              #
#   - MAJVALSTP   : Init des détails de prix de la pile FIFO                    #
#   - STKBENCHTRS : Init plans de travail                                       #
#   - UPDPAS      : Initialisation nouvelle zone législation                    #
#   - LOTFCY      : Décomposition de la valeur du lot                           #
#                                                                               #
#################################################################################

Subprog AMAJDIC30

Local File ADOSACT                  [ADA]
Local File =[F:ADS]DOSSIER+".ACTIV" [ACV]
#---- Affecte les valeurs 6, 3 et 3 aux nouveaux codes activités MAT, MAC et LAB ----#
Update [ADA] Where DOSSIER=[F:ADS]DOSSIER & CODACT="MAT" With DIME=6
Update [ACV] Where CODACT="MAT" With DIME=6
Update [ADA] Where DOSSIER=[F:ADS]DOSSIER & CODACT="MAC" With DIME=3
Update [ACV] Where CODACT="MAC" With DIME=3
Update [ADA] Where DOSSIER=[F:ADS]DOSSIER & CODACT="LAB" With DIME=3
Update [ACV] Where CODACT="LAB" With DIME=3

End

Subprog ASTOMAJ30
Local Integer NUMPROC
Raz NUMPROC

#---- Remplacement des désignation par des textes traduisibles ------#
NUMPROC += 1
Call ECR_TIME("ASTOMAJ30 Stock Transactions Process "+num$(NUMPROC)+": DES --> AXX") From DOSSUB
Call DES2AXX([F:ADS]DOSSIER)

#---- Remplissage de la nouvelle table STOLOTFCY ------#
NUMPROC += 1
Call ECR_TIME("ASTOMAJ30 Stock Transactions Process "+num$(NUMPROC)+": STOLOTFCY") From DOSSUB
Call ALOTFCY([F:ADS]DOSSIER)

#---- Init des nouvelles zones mouvements de stock ------#
# FAIT DANS UUMGTRTSTO01
#NUMPROC += 1
#Call ECR_TIME("ASTOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update STOJOU") From DOSSUB
#Call STKSTJ([F:ADS]DOSSIER)

NUMPROC += 1
Call ECR_TIME("ASTOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update STOQLYH/D") From DOSSUB
Call STKSTQ([F:ADS]DOSSIER)

NUMPROC += 1
Call ECR_TIME("ASTOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update STOLOT") From DOSSUB
Call STKSTL([F:ADS]DOSSIER)

# UUMGTRTSTO03
#NUMPROC += 1
#Call ECR_TIME("ASTOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update STOCOST") From DOSSUB
#Call STKSTP([F:ADS]DOSSIER)

NUMPROC += 1
Call ECR_TIME("ASTOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update SMVTH") From DOSSUB
Call STKANASMH([F:ADS]DOSSIER)

NUMPROC += 1
Call ECR_TIME("ASTOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update SCHGH") From DOSSUB
Call STKANASGH([F:ADS]DOSSIER)

NUMPROC += 1
Call ECR_TIME("ASTOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update STKTRS") From DOSSUB
Call STKANASRT([F:ADS]DOSSIER)

NUMPROC += 1
Call ECR_TIME("ASTOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update CUNLISDET") From DOSSUB
Call STKANACUN([F:ADS]DOSSIER)

End

#################################################################################
Subprog STOMAJ30
Local Integer NUMPROC
Raz NUMPROC

#---- Init règle sortie sous-traitance dans les règles de gestion ------#
NUMPROC += 1
Call ECR_TIME("STOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update TABSTORUL") From DOSSUB
Call STKSRU([F:ADS]DOSSIER)

#---- Init des nouvelles zones catégories ------#
NUMPROC += 1
Call ECR_TIME("STOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update ITMCATEG") From DOSSUB
Call STKITG([F:ADS]DOSSIER)

#---- Init des nouvelles zones articles-sites ------#
NUMPROC += 1
Call ECR_TIME("STOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update ITMFACILIT") From DOSSUB
Call STKITF([F:ADS]DOSSIER)

#---- Init des nouvelles zones stocks ------#
NUMPROC += 1
Call ECR_TIME("STOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update STOCK") From DOSSUB
Call STKSTO([F:ADS]DOSSIER)

#---- Init des nouvelles zones inventaires ------#
NUMPROC += 1
Call ECR_TIME("STOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update CUNLISDET") From DOSSUB
Call STKCUD([F:ADS]DOSSIER)

#---- Init des nouvelles zones détails contrôle qualité ------#
NUMPROC += 1
Call ECR_TIME("STOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update STOQLYD") From DOSSUB
Call STKQLD([F:ADS]DOSSIER)

#---- Init des nouvelles zones détails changement de stock ------#
NUMPROC += 1
Call ECR_TIME("STOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update SCHGD") From DOSSUB
Call STKSGD([F:ADS]DOSSIER)

#---- MAJ de la table SMVTD ------#
NUMPROC += 1
Call ECR_TIME("STOMAJ30 Stock movement detail Process "+num$(NUMPROC)+": Update SMVTD") From DOSSUB
Call UPDSMD([F:ADS]DOSSIER)

# UUMGTRTSTO03
##---- Init des nouvelles zones suite à gestion du desassemblage partiel ------#
#NUMPROC += 1
#Call ECR_TIME("STOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update ITMMVT") From DOSSUB
#Call MAJVALITV([F:ADS]DOSSIER)
#
##---- Init des nouvelles zones suite à gestion du desassemblage partiel ------#
#NUMPROC += 1
#Call ECR_TIME("STOMAJ30 Stocks Transactions Process "+num$(NUMPROC)+": Update STOCOST") From DOSSUB
#Call MAJVALSTP([F:ADS]DOSSIER)

#---- MAJ de la table BENCHTRS ------#
NUMPROC += 1
Call ECR_TIME("STOMAJ30 Work benches Transactions Process "+num$(NUMPROC)+": Update BENCHTRS") From DOSSUB
Call STKBENCHTRS

#---- MAJ de la table PARMRP ------#
NUMPROC += 1
Call ECR_TIME("STOMAJ30 MRP setup Process "+num$(NUMPROC)+": Update PARMRP") From DOSSUB
Call STKPARMRP([F:ADS]DOSSIER)

#---- MAJ de la table PARSTO ------#
NUMPROC += 1
Call ECR_TIME("STOMAJ30 PAS setup Process "+num$(NUMPROC)+": Update PARSTOACC") From DOSSUB
Call UPDPAS([F:ADS]DOSSIER)

#---- Décomposition de la valeur du lot ------#
NUMPROC += 1
Call ECR_TIME("STOMAJ30 Stock Transactions Process "+num$(NUMPROC)+": Update STOLOTFCY") From DOSSUB
Call LOTFCY([F:ADS]DOSSIER)

End

#################################################################################
# Met à jour les tables dont le(s) champ(s) désignation sont devenus traduisibles
#################################################################################
# Tables mises à jour:
#  - TABALLRUL
#  - CFGABQ
#  - CFGLNK
#  - CFGMAC
#  - CFGOPTVAR
#  - CFGQST
#  - CFGSCE
#  - CFGSEL
#  - CFGSHA
#################################################################################
Subprog DES2AXX(PDOS)
Value Char PDOS
If filinfo(filpath("FIL","ATEXTRA","fde",PDOS),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$,0) From GESECRAN : # maj table

Local File =PDOS+".ATEXTRA"   [AXX]

#----- Sauvegarde puis récupération de la langue du dossier à migrer -----#
Local Char SAV_GLANGUE(GLONLAN)
SAV_GLANGUE=GLANGUE
GLANGUE=[F:ADS]LANDEF

#------- TABALLRUL  [TRU] : Règles de gestion ---------------------
If filinfo(filpath("FIL","TABALLRUL","fde",PDOS),0)>0 # Issue 79733 & dim([F:TRU]TRUDES)>0
   Local File =PDOS+".TABALLRUL"   [TRU]
   If dim([F:TRU]TRUDES)>0 # Issue 79733
     Trbegin [AXX]
       For [TRU]
           Call MAJTEXTRA ([F:TRU]TRUDES,"TABALLRUL","TRUAXX",[F:TRU]TRUCOD,"") From ATEXTRA
       Next
     Commit
     Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$-"TABALLRUL",0) From GESECRAN : # maj table
   Endif
   Close File [TRU]
Endif

#------- CFGABQ  [CAB] : Abaques configurateur ---------------------
If filinfo(filpath("FIL","CFGABQ","fde",PDOS),0)>0 # Issue 79733 & dim([F:CAB]ABQDES)>0
   Local File =PDOS+".CFGABQ"   [CAB]
   If dim([F:CAB]ABQDES)>0 # Issue 79733
     Trbegin [AXX]
       For [CAB] Where ABQLIN=1
           Call MAJTEXTRA ([F:CAB]ABQDES,"CFGABQ","ABQAXX",[F:CAB]ABQNUM,"") From ATEXTRA
           Call MAJTEXTRA ([F:CAB]ABSDES,"CFGABQ","ABSAXX",[F:CAB]ABQNUM,"") From ATEXTRA
           Call MAJTEXTRA ([F:CAB]ORDDES,"CFGABQ","ORDAXX",[F:CAB]ABQNUM,"") From ATEXTRA
           Call MAJTEXTRA ([F:CAB]RESDES,"CFGABQ","RESAXX",[F:CAB]ABQNUM,"") From ATEXTRA
       Next
     Commit
     Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$-"CFGABQ",0) From GESECRAN : # maj table
   Endif
   Close File [CAB]
Endif

#------- CFGLNK [CLN] : Liens entre symboles configurateur ---------------------
If filinfo(filpath("FIL","CFGLNK","fde",PDOS),0)>0
    Local File =PDOS+".CFGLNK"   [CLN]
    Local Char WCLE1 (50)
    Local Char WCLE2 (50)
    Trbegin [AXX], [CLN]
    For [CLN]
        WCLE1 = num$([F:CLN]SYMTYPWUS)+"~"+[F:CLN]SYMNUMWUS
        WCLE2 = num$([F:CLN]SYMTYP)+"~"+[F:CLN]SYMNUM
        If dim([F:CLN]CLE1)>0 & dim([F:CLN]CLE2)>0   # FQ 52780 ces colonnes n'existent pas ?
           [F:CLN]CLE1 = WCLE1
           [F:CLN]CLE2 = WCLE2
           Rewrite [CLN]
           If fstat
              Call ERREUR("CFGLNK"-WCLE1-"~"-WCLE2,2) From DOSDIC
           Endif
        Endif
        If dim([F:CLN]SYMDESWUS)>0
           Call MAJTEXTRA ([F:CLN]SYMDESWUS,"CFGLNK","SYMAXXWUS",WCLE1,WCLE2) From ATEXTRA
        Endif
    Next
   Commit
   Close File [CLN]
Endif

#------- CFGMAC  [CFM] : Procedures configurateur ---------------------
If filinfo(filpath("FIL","CFGMAC","fde",PDOS),0)>0 # Issue 79733 & dim([F:CFM]MACDES)>0
   Local File =PDOS+".CFGMAC"   [CFM]
   If dim([F:CFM]MACDES)>0 # Issue 79733
     Trbegin [AXX]
     For [CFM]
          If [F:CFM]MACLIN=1
              Call MAJTEXTRA ([F:CFM]MACDES,"CFGMAC","MACAXX",[F:CFM]MACNUM,"") From ATEXTRA
          Endif
          Call MAJTEXTRA ([F:CFM]SCETXT,"CFGMAC","TXTAXX",[F:CFM]MACNUM,num$([F:CFM]MACLIN)) From ATEXTRA
     Next
     Commit
     Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$-"CFGMAC",0) From GESECRAN : # maj table
   Endif
   Close File [CFM]
Endif

#------- CFGOPTVAR  [COV] : Options/Variantes configurateur ---------------------
If filinfo(filpath("FIL","CFGOPTVAR","fde",PDOS),0)>0 # Issue 79733 & dim([F:COV]ITMREFOPV)>0
   Local File =PDOS+".CFGOPTVAR"   [COV]
   If dim([F:COV]ITMREFOPV)>0 # Issue 79733
     Trbegin [AXX]
       For [COV]
           Call MAJTEXTRA ([F:COV]ITMREFOPV,"CFGOPTVAR","ITMOPVAXX",[F:COV]SELNUM,num$([F:COV]SELSEQ)) From ATEXTRA
       Next
     Commit
     Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$-"CFGMAC",0) From GESECRAN : # maj table
   Endif
   Close File [COV]
Endif

#------- CFGQST  [CQU] : Symboles configurateur ---------------------
If filinfo(filpath("FIL","CFGQST","fde",PDOS),0)>0 # Issue 79733 & dim([F:CQU]QSTDES)>0
   Local File =PDOS+".CFGQST"   [CQU]
   If dim([F:CQU]QSTDES)>0 # Issue 79733
     Trbegin [AXX]
       For [CQU]
           Call MAJTEXTRA ([F:CQU]QSTDES,"CFGQST","QSTAXX",[F:CQU]QSTNUM,"") From ATEXTRA
       Next
     Commit
     Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$-"CFGQST",0) From GESECRAN : # maj table
   Endif
   Close File [CQU]
Endif

#------- CFGSCE  [CSC] : Scénarii configurateur ---------------------
If filinfo(filpath("FIL","CFGSCE","fde",PDOS),0)>0 # Issue 79733 & dim([F:CSC]SCEDES)>0
   Local File =PDOS+".CFGSCE"   [CSC]
   If dim([F:CSC]SCEDES)>0 # Issue 79733
     Trbegin [AXX]
       For [CSC]
           Call MAJTEXTRA ([F:CSC]SCEDES,"CFGSCE","SCEAXX",[F:CSC]SCENUM,"") From ATEXTRA
       Next
     Commit
     Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$-"CFGSCE",0) From GESECRAN : # maj table
   Endif
   Close File [CSC]
Endif

#------- CFGSEL  [CSE] : Sélections configurateur ---------------------
If filinfo(filpath("FIL","CFGSEL","fde",PDOS),0)>0 # Issue 79733 & dim([F:CSE]SELDES)>0
   Local File =PDOS+".CFGSEL"   [CSE]
   If dim([F:CSE]SELDES)>0 # Issue 79733
     Trbegin [AXX]
       For [CSE]
           Call MAJTEXTRA ([F:CSE]SELDES,"CFGSEL","SELAXX",[F:CSE]SELNUM,"") From ATEXTRA
       Next
     Commit
     Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$-"CFGSEL",0) From GESECRAN : # maj table
   Endif
   Close File [CSE]
Endif

#------- CFGSHA  [CSH] : Formes et modèles configurateur ---------------------
If filinfo(filpath("FIL","CFGSHA","fde",PDOS),0)>0 # Issue 79733 & dim([F:CSH]SHACATDES)>0
   Local File =PDOS+".CFGSHA"   [CSH]
   If dim([F:CSH]SHACATDES)>0 # Issue 79733
     Trbegin [AXX]
       For [CSH]
          # FQ 63171 GA 03/2010 pb s/texte associé à la Forme
          # Call MAJTEXTRA ([F:CSH]SHACATDES,"CFGSHA","SHACATAXX",[F:CSH]SHACAT,[F:CSH]SHANUM) From ATEXTRA
           Call MAJTEXTRA ([F:CSH]SHACATDES,"CFGSHA","SHACATAXX",[F:CSH]SHACAT,"") From ATEXTRA
           Call MAJTEXTRA ([F:CSH]SHANUMDES,"CFGSHA","SHANUMAXX",[F:CSH]SHACAT,[F:CSH]SHANUM) From ATEXTRA
       Next
     Commit
     Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$-"CFGSHA",0) From GESECRAN : # maj table
   Endif
   Close File [CSH]
#------- CFGSHA  [CSH] : Formes et modèles configurateur ---------------------
Elsif filinfo(filpath("FIL","CFGSHA","fde",PDOS),0)>0 # Issue 79733 & dim([F:CSH]SHACATDES)<=0
# FQ 63171 GA 03/2010 pb s/texte associé à la Forme
   Local File =PDOS+".CFGSHA"   [CSH]
   Trbegin [AXX]
    For [CSH]
        # Si le texte a n'existe pas
        # pour la clé [AXX]AXX0="CFGSHA";"SHACATAXX";GLANGUE;[F:CSH]SHACAT;""
        # on reprend  [AXX]AXX0="CFGSHA";"SHACATAXX";[F:ADS]LAN(I);[F:CSH]SHACAT;[F:CSH]SHANUM
        # et on supprime les "doublons" (même libellé) sur les autres codes SHANUM de cette valeur SHACAT
        Read [AXX]AXX0="CFGSHA";"SHACATAXX";GLANGUE;[F:CSH]SHACAT;""
        If fstat
            For I=0 To [F:ADS]NBRLAN-1
              #Readlock [AXX]AXX0="CFGSHA";"SHACATAXX";[F:ADS]LAN(I);[F:CSH]SHACAT;[F:CSH]SHANUM  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
              Read [AXX]AXX0="CFGSHA";"SHACATAXX";[F:ADS]LAN(I);[F:CSH]SHACAT;[F:CSH]SHANUM  # FGR 11/03/2010 : X3SUIVI63191
              If !fstat
                  [AXX]IDENT2=""
                  Rewrite [AXX]
              Endif
            Next
        Endif
        If [F:CSH]SHANUM<>""
            Call SUPTEXTRA("CFGSHA","SHACATAXX",[F:CSH]SHACAT,[F:CSH]SHANUM) From ATEXTRA
        Endif
    Next
   Commit
Endif

#----- Restitution du code langue de connexion -----#
GLANGUE=SAV_GLANGUE
End

###############################################################################
# ALOTFCY : Remplissage de la nouvelle table STOLOTFCY
###############################################################################
# Paramètres E : PDOS   = Dossier
###############################################################################
Subprog ALOTFCY(PDOS)
Value Char PDOS

If filinfo(filpath("FIL","STOLOT","fde",PDOS),0)<=0 : End : Endif
If filinfo(filpath("FIL","STOLOTFCY","fde",PDOS),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": STOLOTFCY"-time$,0) From GESECRAN : # maj table

Local File =PDOS+".STOLOT"    [STL]
Local File =PDOS+".STOCK"     [STO]
Local File =PDOS+".STOLOTFCY" [SLF]
Local File =PDOS+".TABCUR"    [TCU]
Local File =PDOS+".TABCHANGE" [TCH]
# Pour récupérer la valeur du paramètre SYSCUR du bon dossier il faut ouvrir les tables ici
# sinon ce seront les tables du dossier en cours qui seront ouvertes et SYSCUR ne sera pas bon
Local File =PDOS+".ADOVAL"    [ADW]
Local File =PDOS+".ADOPAR"    [ADP]

Local Decimal LCUMAAA, LCUMQQQ, LCUMRRR, LCUMACT
Local Decimal LRNDCUR
Local Integer LNB, LSTOP
Local Char    LFIL(250)
Local Char    LITM(GLONITM), LFCY(GLONFCY), LLOT(GLONLOT), LSLO(GLONSLO)
Local Char    LSYSCUR(GLONCUR)
Local Decimal LCOURS, LPRI
Local Integer LSTAT, LERR

Call PARAM("","SYSCUR",LSYSCUR) From ADOVAL

Gosub SET_FIRST From TRTFIRST

# Issue 117168 - 2016-11-17 by ERMIL : Incorrect rounding of AVCBASAMT
If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
Call INIRNDVAL("STOLOTFCY","AVCBASAMT") From STKVALECR

$ASLF_LOOP
Call DEBTRANS From GLOCK
Trbegin [SLF]

If LSTOP = 1
    LFIL = "ITMREF=LITM & STOFCY=LFCY & LOT=LLOT & SLO>LSLO"
    LSTOP +=1
Elsif LSTOP = 2
    LFIL = "ITMREF=LITM & STOFCY=LFCY & LOT>LLOT"
    LSTOP +=1
Elsif LSTOP = 3
    LFIL = "ITMREF=LITM & STOFCY>LFCY"
    LSTOP +=1
Elsif LSTOP = 4
    LFIL = "ITMREF>LITM"
    LSTOP =0
Else
    LFIL = "1=1"
Endif

For [STO]STO3(4) Where evalue(LFIL)
    Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO

    # Issue 117168 - 2016-11-17 by ERMIL : Incorrect rounding of AVCBASAMT
    #If [F:TCU]CUR<>[F:STL]CUR
    #    Read [TCU] TCU0=[F:STL]CUR
    #    If fstat : Raz [F:TCU] : Endif
    #
    #    If [F:TCU]CUR<>""
    #        LRNDCUR=[F:TCU]CURRND
    #    Else
    #        LRNDCUR=0.01
    #    Endif
    #Endif
    Raz LCUMAAA, LCUMQQQ, LCUMRRR
    Raz LCUMACT                       # hcb 89544


    For [STO]STO3
        Case left$([F:STO]STA,1)
            When "A" : LCUMAAA+=[F:STO]QTYSTU
            When "Q" : LCUMQQQ+=[F:STO]QTYSTU
            When "R" : LCUMRRR+=[F:STO]QTYSTU
        Endcase
        LCUMACT += [F:STO]QTYSTUACT
    Next

    #Readlock [SLF]SLF0= [F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO;[F:STO]STOFCY  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    Read [SLF]SLF0= [F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO;[F:STO]STOFCY  # FGR 11/03/2010 : X3SUIVI63191
    If fstat
        [F:SLF] = [F:STL]
        [F:SLF]STOFCY    = [F:STO]STOFCY
        [F:SLF]AAACUMQTY = LCUMAAA
        [F:SLF]QQQCUMQTY = LCUMQQQ
        [F:SLF]RRRCUMQTY = LCUMRRR
        [F:SLF]AVCBASQTY = LCUMACT
        If [F:STL]AAACUMQTY+[F:STL]QQQCUMQTY+[F:STL]RRRCUMQTY=0
            [F:SLF]AVCBASAMT=0
            [F:SLF]AVC=0
            Call ECR_TRACE([F:STO]ITMREF-[F:STO]STOFCY-": [F:STL]AAACUMQTY+[F:STL]QQQCUMQTY+[F:STL]RRRCUMQTY=0",-1) From GESECRAN
        Else
            #[F:SLF]AVCBASAMT = arr([F:STL]LOTCST*([F:SLF]AAACUMQTY+[F:SLF]QQQCUMQTY+[F:SLF]RRRCUMQTY)/([F:STL]AAACUMQTY+[F:STL]QQQCUMQTY+[F:STL]RRRCUMQTY),LRNDCUR)  # 117168.o
            [F:SLF]AVCBASAMT = arr([F:STL]LOTCST*([F:SLF]AAACUMQTY+[F:SLF]QQQCUMQTY+[F:SLF]RRRCUMQTY)/([F:STL]AAACUMQTY+[F:STL]QQQCUMQTY+[F:STL]RRRCUMQTY),GRNDVAL)   # 117168.n
            If LFCY<>[F:SLF]STOFCY
                Call GETDEV([F:SLF]STOFCY) From DEVSUB    # --> alimente GLOCALDEV
                Call COURDEV(LSYSCUR,GLOCALDEV,1,date$,LCOURS,LSTAT) From TRTDIV
            Endif
            Call CONVERT([F:SLF]AVCBASAMT, LSYSCUR, [F:SLF]AVCBASAMT, GLOCALDEV, LCOURS) From TRTDIV
        Endif

        # La décomposition de la valeur du lot se fait après mise à jour car SDP n'existe pas encore

        # LASRCPDAT, LASISSDAT, LASCUNDAT, VCRTYP,VCRNUM et VCRLIN ne sont pas modifiés.
        # Ils le seront au fur et à mesure de l'utilisation des lots
        Write [SLF]
        LNB +=1
    Endif
    LITM=[F:STO]ITMREF
    LFCY=[F:STO]STOFCY
    LLOT=[F:STO]LOT
    LSLO=[F:STO]SLO
    If LNB>GMAXUPDTRS
        LSTOP=1
        Break
    Endif
Next

Raz LNB
Commit
If LSTOP>0
    Goto ASLF_LOOP
Endif

Gosub UNSET_FIRST From TRTFIRST

End

