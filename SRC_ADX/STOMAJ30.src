###############################################################################
# STKSTQ   : MAJ  Catégories site (Récupération QUAFLG QUAACS         sur site)
#            MAJ  Article    site (Récupération QUAFLG QUAACS QLYCRD  sur site)
#            INIT Article    site (QUAFRY SMPTYP GENLEVINS NQA SMPMOD sur site)

###############################################################################
# Paramètres E : LDOS   = Dossier
###############################################################################
Subprog STKSTQ(LDOS)
Value Char LDOS

Local File =LDOS+".ITMCATEG"   [ITG]
Local File =LDOS+".ITMCATEG"   [ITG1]
Local File =LDOS+".STOQLYH"    [QLH]
Local File =LDOS+".STOQLYD"    [QLD]
Local File =LDOS+".QLYCRDQST"  [QLQ]
#
Local Integer WRE
#----                                                           ITMCATEG ----#

Call ECR_TRACE("Start trace : ITMCATEG / CQ" ,0) From GESECRAN
Raz WRE
Trbegin [ITG]

Filter [ITG1] Where STOFCY = ""
&             Order By Key ITG0
For [ITG1]
#----
    Filter [ITG] Where TCLCOD = [F:ITG1]TCLCOD & STOFCY <> ""
&            Order By Key ITG0

    For [ITG]
        #Readlock [ITG] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
        #If !fstat
           [F:ITG]QUAFLG = [F:ITG1]QUAFLG
           [F:ITG]QUAACS = [F:ITG1]QUAACS
           Rewrite [ITG]
           WRE +=1
        #Endif
    Next
    Filter [ITG]
Next
Filter [ITG1]
Commit

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),0) From GESECRAN
Local Integer WRE

#----                                                                STOQLYH ----#
Call ECR_TRACE("Start trace : STOQLYH/D " ,0) From GESECRAN
Raz WRE
Trbegin [QLD]

For [QLH]
#----
    Filter [QLD] Where VCRTYP = [F:QLH]VCRTYP & VCRNUM = [F:QLH]VCRNUM
&            Order By Key QLD0

    For [QLD]
        #Readlock [QLD] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
        #If !fstat
           [F:QLD]QLYCRD = [F:QLH]QLYCRD
           Rewrite [QLD]
           WRE +=1
        #Endif
    Next
    Filter [QLD]
Next
Commit

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),0) From GESECRAN
#----                                                                QLYCRDQST ----#
Call ECR_TRACE("Start trace : QLYCRDQST" ,0) From GESECRAN
Raz WRE
Trbegin [QLQ]

#----
Filter [QLQ] Where DEMASWTYP = 2
&      Order By Key QLQ0
For [QLQ]
    #Readlock [QLQ] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If !fstat
       [F:QLQ]UOMDEC = 9
       Rewrite [QLQ]
       WRE +=1
    #Endif
Next
Filter [QLQ]
Commit

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),0) From GESECRAN

End

