###############################################################################
# STKSGD : MAJ du détail changement de stock
#             - Init propriétaire
###############################################################################
# Paramètres E : LDOS   = Dossier
#################################################################################
Subprog STKSGD(LDOS)
Value Char LDOS

#----- Ouverture des fichiers -----#
If clalev([F:SGD])  =0  Local File =LDOS+".SCHGD"   [SGD] : Endif
If clalev([F:SGH])  =0  Local File =LDOS+".SCHGH"   [SGH] : Endif

Local Integer COMPTEUR
Local Integer STOP
Local Char    CRIT(250)
Local Char    LVCRNUM
Local Decimal LVCRLIN

Raz [F:SGH]VCRNUM

Gosub SET_FIRST From TRTFIRST

Raz STOP
$BOUCLE_SGD
If STOP=1
   CRIT = "VCRNUM=LVCRNUM & VCRLIN>LVCRLIN"
   STOP = 2
Elsif STOP=2
   CRIT = "VCRNUM>LVCRNUM"
   STOP = 0
Else
   CRIT = "1=1"
Endif
Trbegin [SGD]
Raz COMPTEUR
For [SGD]SGD0 Where evalue(CRIT)
   If [F:SGD]OWNER=""
      If [F:SGD]VCRNUM<>[F:SGH]VCRNUM
         Read [SGH]SGH0=[F:SGD]VCRNUM
         If fstat
            Call ECR_TRACE("File SCHGH, Error ="-num$(fstat),1) From GESECRAN
            Goto SUITE_SGD
         Endif
      Endif

      #Readlock [SGD]Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
      #If fstat
      #   Call ECR_TRACE("File SCHGD, Error ="-num$(fstat),1) From GESECRAN
      #Else
         [F:SGD]OWNER = [F:SGH]STOFCY
         Rewrite [SGD]
         If fstat
            Call ECR_TRACE("File SCHGD, Error ="-num$(fstat),1) From GESECRAN
         Else
            COMPTEUR +=1
         Endif
      #Endif
   Endif
   If COMPTEUR>GMAXUPDTRS
      LVCRNUM = [F:SGD]VCRNUM
      LVCRLIN = [F:SGD]VCRLIN
      STOP = 1
      Break
   Endif
   $SUITE_SGD
Next
Commit
If STOP
   Goto $BOUCLE_SGD
Endif

Gosub UNSET_FIRST From TRTFIRST

End

###############################################################################
# SYNBBY : Init des nouvelles zones suite à gestion du desassemblage partiel
###############################################################################
# Paramètres E : LDOS   = Dossier
###############################################################################

Subprog SYNBBY(LDOS)
Value Char LDOS  # FGR 18/01/2010 : X3SUIVI60986

Local File =LDOS+".SMVTD"  [SMD]
Local File =LDOS+".SMVTH"  [SMH]

#-------------------- Assemblage -#
$STOSMD_LOOP

Call DEBTRANS From GLOCK

Trbegin [SMD]
Local Integer I

Filter [SMD] Where VCRTYP = 31
For [SMD]
   Raz I
   If [F:SMD]QTYPCUORI = 0 & [F:SMD]VCRTYPORI = 0
      [F:SMD]QTYPCUORI = [F:SMD]QTYPCU
      I = 1
   Endif
   If [F:SMD]QTYSTUORI = 0 & [F:SMD]VCRTYPORI = 0
      [F:SMD]QTYSTUORI = [F:SMD]QTYSTU
      I = 1
   Endif
   If I = 1
      Rewrite [SMD]
   Endif
   If [F:SMD]VCRLIN = 1
      If ([F:SMD]VCRTYPORI = 32 & [F:SMD]QTYSTUORI = 0) | ([F:SMD]VCRTYPORI = 32 & [F:SMD]QTYPCUORI = 0)
         #Readlock [SMH]SMH0=[F:SMD]VCRTYP;[F:SMD]VCRNUM  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
         Read [SMH]SMH0=[F:SMD]VCRTYP;[F:SMD]VCRNUM  # FGR 11/03/2010 : X3SUIVI63191
         If !fstat
            If ([F:SMD]QTYSTUORI = 0 & [F:SMD]VCRTYPORI = 32) | ([F:SMD]QTYPCUORI = 0 & [F:SMD]VCRTYPORI = 32)
               If [F:SMH]DBYFLG <> 2
                  [F:SMH]DBYFLG = 2
                  Rewrite [SMH]
               Endif
            Endif
         Endif
      Endif
   Endif
Next

Filter [SMD]
Commit

End

####################################################################################
Subprog UPDSMD(LDOS)
Value Char LDOS  # FGR 18/01/2010 : X3SUIVI60986

Local File =LDOS+".SMVTD"       [SMD]
Local File =LDOS+".SMVTH"       [SMH]
Local File =LDOS+".TABBOMALT"   [TBO]

Call DEBTRANS From GLOCK
Trbegin [SMD]
For [SMD] Where find(VCRTYP,31,32)
   If [F:SMD]BOMALT<>0
      Read [F:TBO]TBO2(1)=[F:SMD]BOMALT
      If !fstat : [F:SMD]BOMALTTYP=[F:TBO]BOMALTTYP : Endif
   Endif
   # Init des nouvelles zones suite à gestion du desassemblage partiel
   If [F:SMD]VCRTYP=31
      If [F:SMD]QTYPCUORI=0 & [F:SMD]VCRTYPORI=0
         [F:SMD]QTYPCUORI=[F:SMD]QTYPCU
      Endif
      If [F:SMD]QTYSTUORI=0 & [F:SMD]VCRTYPORI=0
         [F:SMD]QTYSTUORI=[F:SMD]QTYSTU
      Endif
      If [F:SMD]VCRLIN=1
         If ([F:SMD]VCRTYPORI=32 & [F:SMD]QTYSTUORI=0) | ([F:SMD]VCRTYPORI=32 & [F:SMD]QTYPCUORI=0)
            #Readlock [SMH]SMH0=[F:SMD]VCRTYP;[F:SMD]VCRNUM  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
            Read [SMH]SMH0=[F:SMD]VCRTYP;[F:SMD]VCRNUM  # FGR 11/03/2010 : X3SUIVI63191
            If !fstat
               If ([F:SMD]QTYSTUORI=0 & [F:SMD]VCRTYPORI=32) | ([F:SMD]QTYPCUORI=0 & [F:SMD]VCRTYPORI=32)
                  If [F:SMH]DBYFLG<>2
                     [F:SMH]DBYFLG =2
                     Rewrite [SMH]
                  Endif
               Endif
            Endif
         Endif
      Endif
   Endif
   Rewrite [SMD]
Next
Commit

Filter [SMD]
Close Local File [SMD]
Close Local File [TBO]

End

