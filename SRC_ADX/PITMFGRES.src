#<AdxTL>@(#)12.0.0.0 $Revision$
###########################################################################
# Routines diverses pour mise à jour des résultats de PREACTOR            #
###########################################################################
###########################################################################
###########################################################################
Subprog OPTRES(ID,CLETRT,P_MFGFCY,P_TRACE2,OK)
Value Char ID()
Value Char CLETRT ()
Value Char P_MFGFCY ()
Value Integer P_TRACE2
Variable Integer OK


Local Char     OPTRES(200)
Local Integer  NBOPMX   : NBOPMX=100
Local Integer  NBJCAL   : NBJCAL=1000
Local Char     WRESULT(250)(31)
Local Char     MFGNUMTRT , MFGNUMTRTERR
Local Integer  NBOP
Local Date     WSTRDAT
Local Date     WENDDAT

##RBA TEST X3-85577
Local Date     WSTRDATNEW
Local Date     WENDDATNEW
Local Integer  NBOPNEW
Local Date     WOPEFITSTDNEW(NBOPMX)             # début préparation date
Local Date     WFITOPEENDNEW(NBOPMX)             # fin opération date

Local Decimal  WCOELAB
Local Date     WMFGSTR, WMFGEND, WRETDAT
Local Integer  WSCDLTI
Local Decimal  WEXTHOU
Local Char     WTAB
Local Char     WCLE
Local Char     WMESS(85)
Local Char     WMESS1(85)
Local Decimal  WCRGAV, WCRGAP
Local Integer  WSUB, WERR
Local Decimal  WCOEFF, MCOEFF
##Local Char     PATH
Local Integer  WNEWWST, TROUVE
##VPO
Local Char WHOU (4)
Local Decimal WDIFFHOU
Local Decimal WDIFFDAT

# description fichier résultat "results.csv"
Local Char     WMFGNUM(GLONVCR)(NBOPMX)       # numéro OF
Local Integer  WOPENUM(NBOPMX)                # numéro opération
Local Integer  WOPESPLNUM(NBOPMX)             # numéro fraction opération
Local Char     WOPEWST(30)(NBOPMX)            # poste de charge
Local Char     WOPELAB(30)(NBOPMX)            # poste M/O
Local Decimal  WOPELABCOE(NBOPMX)             # coefficient opératoire MO
Local Decimal  WPRPTIM(NBOPMX)                # temps de préparation
Local Decimal  WSETTIM(NBOPMX)                # temps total fab
Local Decimal  WEXTTIM(NBOPMX)                # temps total fab
Local Decimal  WPSTTIM(NBOPMX)                # temps post-opératoire
Local Decimal  WSCOLTI(NBOPMX)                # délai sous-traitance                      11.06 35988
Local Integer  WWSTNBR(NBOPMX)                # nombre de postes MA
Local Integer  WLABNBR(NBOPMX)                # nombre de postes MO
Local Date     WOBJDAT(NBOPMX)                # début objectif initial
Local Date     WOPESTR(NBOPMX)                # début opération au plus tôt
Local Date     WFRCSTRDAT(NBOPMX)             # début forcé date
Local Decimal  WFRCSTRFRD(NBOPMX)             # début forcé fraction
Local Date     WOPEFITSTD(NBOPMX)             # début préparation date
Local Decimal  WOPEFITSTF(NBOPMX)             # début préparation fraction
Local Decimal  WOPEFITSTF_SAV(NBOPMX)             # début préparation fraction
Local Date     WFITCAPSTR(NBOPMX)             # début fabrication date
Local Decimal  WFITCAPSTF(NBOPMX)             # début fabrication fraction
Local Decimal  WFITCAPSTF_SAV(NBOPMX)             # début fabrication fraction
Local Date     WFITCAPEND(NBOPMX)             # début post-opératoire date
Local Decimal  WFITCAPENF(NBOPMX)             # début post-opératoire fraction
Local Decimal  WFITCAPENF_SAV(NBOPMX)             # début post-opératoire fraction
Local Date     WFITOPEEND(NBOPMX)             # fin opération date
Local Decimal  WFITOPEENF(NBOPMX)             # fin opération fraction
Local Decimal  WFITOPEENF_SAV(NBOPMX)             # fin opération fraction
Local Decimal  WFITPRPDUR(NBOPMX)             # durée préparation
Local Decimal  WFITWORDUR(NBOPMX)             # durée opératoire
Local Decimal  WFITPSTDUR(NBOPMX)             # durée post-opératoire
Local Decimal  WFITDELAY (NBOPMX)             # avance/retard
Local Integer  WMFGPIO   (NBOPMX)             # priorité OF
Local Date     WEXTDAT   (NBOPMX)             # date traitement

# données d'enrichissement
Local Char     WMFGFCY(GLONFCY)(NBOPMX)
Local Integer  WMFGSTA         (NBOPMX)
Local Integer  WOPESTA         (NBOPMX)
Local Char     WWCR   (GLONWCR)(NBOPMX)
Local Char     WWST   (GLONWST)(NBOPMX)
Local Char     WWCRLAB(GLONWCR)(NBOPMX)
Local Char     WLAB   (GLONWST)(NBOPMX)
Local Integer  WWSTTYP         (NBOPMX)
Local Integer  WOPEWSTTYP      (NBOPMX)
Local Decimal  WOPTTIM  (NBOPMX)
Local Decimal  WSETLABR (NBOPMX)
Local Decimal  WOPELABR (NBOPMX)
Local Date     WINFSTRD (NBOPMX)
Local Decimal  WINFSTRF (NBOPMX)
Local Date     WSETENDD (NBOPMX)
Local Decimal  WSETENDF (NBOPMX)
Local Date     WINFENDD (NBOPMX)
Local Decimal  WINFENDF (NBOPMX)
Local Char     WSCHSBB  (15) (NBOPMX)
Local Char     XCRITERE(250)

Local Char     WCAL(3)(NBOPMX)
Local Date     WDATD(NBOPMX)
Local Date     WDATF(NBOPMX)
Local Integer  WCOR(NBOPMX)
Local Decimal  WCAP(NBJCAL)
Local Integer  WNBRD (NBJCAL)
Local Integer  WRET, I, WPREC, OPTIM, WNBR
Local Integer  WCODORI

Local Decimal  LHOUD
Local Decimal  LDAYCAP
Local Decimal  LDAYFR
Local Char     XSCHSBB(15)

Local Integer  WHDEB,WHFIN, WHWRK

Local Mask OPTK [OPTK] : Raz [OPTK]
[M:OPTK]MFGFCY = P_MFGFCY
[M:OPTK]SEPCHR = ";"
##[M:OPTK]REP = filpath("!","","","","","#")+"\temp\"
[M:OPTK]TRACE2 = P_TRACE2
# Issue 96850 GA 07/2014 identify Preactor interface - see OPTLIBA
#[M:OPTK]TRTMOD=4 # This line may be added to avoid date optimization in OPTLIBA

Call TEMPON(mess(105,190 ,1)) From GESECRAN

If clalev([F:TWD])  = 0 : Local File TABWEEDIA  [TWD]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING [SCH]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD    [MFG]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT     [MFM]  : Endif
If clalev([F:OPS])  = 0 : Local File OPERATIONS [OPS]  : Endif
If clalev([F:WKL])  = 0 : Local File WORKLOAD   [WKL]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT [ITF]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM     [MFI]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE     [MFO]  : Endif
If clalev([F:ORD])  = 0 : Local File ORDERS     [ORD]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER  [ITM]  : Endif

If clalev([M:OPSK]) = 0 : Local Mask OPSK       [OPSK] : Endif
If clalev([M:ORDK]) = 0 : Local Mask ORDK       [ORDK] : Endif

If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:TUV])  = 0 : Local File TABUNAVAIL [TUV]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR     [CPV]  : Endif
If clalev([F:STA])  = 0 : Local File STOALL     [STA] : Endif

# lecture site
Call LECTURE ("FCY", P_MFGFCY, "") From CONTOBJ

If clalev([F:PJA])  = 0 : Local File PARJAL     [PJA]  : Endif

If [F:PJA]MFGFCY <> P_MFGFCY
    Read [PJA]PJA0 = P_MFGFCY
    If fstat : Raz [PJA] : Endif
Endif

If [F:PJA]AUTWIPSCD = 2 : XCRITERE = "1=1" Else : XCRITERE = "MATSTA=1" : Endif

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
If ID='ORP' | ID='ORO'
adxium = GASCII
Else
adxium = GUTF8
Endif
adxifs = [M:OPTK]SEPCHR
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
adxifs = [M:OPTK]SEPCHR

# transfert fichiers résultats du client vers le serveur (E pour client vers serveur)
###PATH = "tmp"+"/"+tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")) + ".ilres"
###Callui RETOUR="" With     "UIAction="+chr$(1)+"PutFileAlways",
###&                         "UIRemoteFile="+ chr$(1) +PATH,
###&                         "UILocalDir="+ chr$(1) +"UserTemp",
###&                         "UILocalFile="+ chr$(1) +"OrdersOut.csv"

Raz WERR
Onerrgo ERR_LEC
OPTRES = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"ilres")
Openi OPTRES Using [RESO]
Onerrgo
If WERR : Call TEMPOFF From GESECRAN : Goto FIN_OPTRES : Endif

# ouverture trace
If P_TRACE2 = 2
    ##Call OUVRE_TRACE(mess(177,195,1)) From LECFIC
    ##la trace est déjà ouverte
    Call ECR_TRACE(mess(177,195,1),0) From GESECRAN
    WHDEB = time
Endif
NBOPNEW = 0 #Issue X3-85577 - 2018-04-18 by RBA
NBOP = 0
Raz [F:MWS]
Raz [F:TWD]

#le fichier a une entete obligatoire donc on saute la 1ere ligne
Gosub NEXT_RES
If fstat : Goto FIN_FICOPTRES : Endif

#Issue X3-85577 - 2018-04-18 by RBA
WMFGSTRNEW = [0/0/0]
WMFGENDNEW = [0/0/0]
NBOPNEW    = 0

Gosub NEXT_RES
While fstat = 0
    Raz WERR
    If MFGNUMTRT = "" : MFGNUMTRT = WRESULT(0) : Gosub READ_MFG : Endif
    # si rupture sur numéro OF, mise à jour
    If WRESULT(0) <> MFGNUMTRT
        If MFGNUMTRTERR <> MFGNUMTRT
            Gosub MAJRES From OPTLIBA
            # Issue 103803 - 2015-27-06 by RBA : flag optimisation de l'OF reinitialisé si positionné à Oui avant traitement
            Gosub MAJ_OF
            #/ Issue 103803
        Endif
        #Issue X3-85577 - 2018-04-18 by RBA
        WMFGSTRNEW = [0/0/0]
        WMFGENDNEW = [0/0/0]
        NBOPNEW    = 0

        NBOP = 0
        Gosub RAZ_MFG
        MFGNUMTRT = WRESULT(0)
        Gosub READ_MFG
    Endif
    If [F:MFG]MFGNUM<>MFGNUMTRT
        MFGNUMTRTERR = MFGNUMTRT
        Goto SUITE_LEC
    Endif
    If MFGNUMTRTERR = MFGNUMTRT
        MFGNUMTRTERR = MFGNUMTRT
        Goto SUITE_LEC
    Endif
    # llc 11.02 7550
    # transcodage
    WMFGNUM(NBOP)        = WRESULT(0)
    WOPENUM(NBOP)        = val(WRESULT(1))
    WOPESPLNUM(NBOP)     = 0
    #Infbox "WMFGNUM/WOPENUM = "+WMFGNUM(NBOP)+"/"+num$(WOPENUM(NBOP))
    Gosub READ_OPE
    If WERR : Goto SUITE_LEC : Endif
    WOPEWST(NBOP)        = WRESULT(2)
    If [F:MWS]WST<>WOPEWST(NBOP)
      Read [MWS]WST0=WOPEWST(NBOP);P_MFGFCY
      If fstat
        Call ECR_TRACE(mess(196,193,1)-":"-WOPEWST(NBOP)-P_MFGFCY,1) From GESECRAN
        MFGNUMTRTERR = MFGNUMTRT
        Goto SUITE_LEC
      Endif
      # lecture schéma de référence
      If  [F:TWD]TWD <> [F:MWS]TWD : Read [F:TWD]TWD0=[F:MWS]TWD  : Endif
    Endif

    WSCHSBB(NBOP) = ""

    WOPELAB(NBOP)        = func PITMFG.OPE_GETLAB
    WOPELABCOE(NBOP)     = func PITMFG.OPE_GETOPELABCOE

    WPRPTIM(NBOP)        = func PITMFG.OPE_GETPRPTIM
    WSETTIM(NBOP)        = func PITMFG.OPE_GETEXTSETTIM
    WEXTTIM(NBOP)        = func PITMFG.OPE_GETOPETIM
    WPSTTIM(NBOP)        = func PITMFG.OPE_GETPSPTIM
    WSCOLTI(NBOP)        = func PITMFG.OPE_GETSCOLTI_REEL
    WWSTNBR(NBOP)        = func PITMFG.OPE_GETWSTNBR
    WLABNBR(NBOP)        = func PITMFG.OPE_GETLABNBR
    WOBJDAT(NBOP)        = func PITMFG.MFG_GETOBJDAT
# date début opération au plus tôt : inutilisé pour le moment ...
#   WOPESTR(NBOP)        = WRESULT(14)
    ##If WRESULT(15) <> ""
    ##    WFRCSTRDAT(NBOP)     = func PITMFG.OPE_GETFRCSTRDAT
    ##    WFRCSTRFRD(NBOP)     = val(func PITMFG.OPE_GETWFRCSTRF)
    ##Else
        WFRCSTRDAT(NBOP)     = [0/0/0]
        WFRCSTRFRD(NBOP)     = 0
    ##Endif

    #temps preparation
    WOPEFITSTD(NBOP)     = left$(WRESULT(3),8)
    WHOU = right$(WRESULT(3),9)
    Call CONVHOU(WHOU ,WOPEFITSTF(NBOP)) From JALLIBB
    WOPEFITSTF_SAV(NBOP) = WOPEFITSTF(NBOP)
    # calcul fraction
    J = dayn(WOPEFITSTD(NBOP)) - 1
    LHOUD = WOPEFITSTF(NBOP)
    LDAYCAP = [F:TWD]DAYCAP(J)
    If pat(GVERSION,"1.5.*")
        Call NEWCALDFR(P_MFGFCY,LHOUD,LDAYCAP,LDAYFR, WOPEWST(NBOP)) From JALLIBB
    Else
        Call CALDFR(P_MFGFCY,WOPEFITSTD(NBOP),LHOUD ,WHOU ,LDAYCAP ,LDAYFR,WOPEWST(NBOP)) From JALLIBB
    Endif
    WOPEFITSTF(NBOP) = LDAYFR


    #temps fabrication
    WFITCAPSTR(NBOP)     = left$(WRESULT(4),8)
    WHOU = right$(WRESULT(4),9)
    Call CONVHOU(WHOU ,WFITCAPSTF(NBOP)) From JALLIBB
    WFITCAPSTF_SAV(NBOP)=WFITCAPSTF(NBOP)
    # calcul fraction
    J = dayn(WFITCAPSTR(NBOP)) - 1
    LHOUD = WFITCAPSTF(NBOP)
    LDAYCAP = [F:TWD]DAYCAP(J)
    If pat(GVERSION,"1.5.*")
        Call NEWCALDFR(P_MFGFCY,LHOUD,LDAYCAP,LDAYFR, WOPEWST(NBOP)) From JALLIBB
    Else
        Call CALDFR(P_MFGFCY,WFITCAPSTR(NBOP),LHOUD ,WHOU ,LDAYCAP ,LDAYFR,WOPEWST(NBOP)) From JALLIBB
    Endif
    WFITCAPSTF(NBOP) = LDAYFR

    #temps post-operatoire
    WFITCAPEND(NBOP)     = left$(WRESULT(5),8)
    WHOU = right$(WRESULT(5),9)
    Call CONVHOU(WHOU ,WFITCAPENF(NBOP)) From JALLIBB
    WFITCAPENF_SAV(NBOP) = WFITCAPENF(NBOP)
    # calcul fraction
    J = dayn(WFITCAPEND(NBOP)) - 1
    LHOUD = WFITCAPENF(NBOP)
    LDAYCAP = [F:TWD]DAYCAP(J)
    If pat(GVERSION,"1.5.*")
        Call NEWCALDFR(P_MFGFCY,LHOUD,LDAYCAP,LDAYFR, WOPEWST(NBOP)) From JALLIBB
    Else
        Call CALDFR(P_MFGFCY,WFITCAPEND(NBOP),LHOUD ,WHOU ,LDAYCAP ,LDAYFR,WOPEWST(NBOP)) From JALLIBB
    Endif
    WFITCAPENF(NBOP) = LDAYFR


    #fin operation
    WFITOPEEND(NBOP)     = left$(WRESULT(6),8)
    WHOU = right$(WRESULT(6),9)
    Call CONVHOU(WHOU ,WFITOPEENF(NBOP)) From JALLIBB
    WFITOPEENF_SAV(NBOP) = WFITOPEENF(NBOP)
    # calcul fraction
    J = dayn(WFITOPEEND(NBOP)) - 1
    LHOUD = WFITOPEENF(NBOP)
    LDAYCAP = [F:TWD]DAYCAP(J)
    If pat(GVERSION,"1.5.*")
        Call NEWCALDFR(P_MFGFCY,LHOUD,LDAYCAP,LDAYFR, WOPEWST(NBOP)) From JALLIBB
    Else
        Call CALDFR(P_MFGFCY,WFITOPEEND(NBOP),LHOUD ,WHOU ,LDAYCAP ,LDAYFR,WOPEWST(NBOP)) From JALLIBB
    Endif
    WFITOPEENF(NBOP) = LDAYFR

    #Infbox "PRE="+num$(WOPEFITSTF(NBOP))-"FAB="+num$(WFITCAPSTF(NBOP))-"POST="+num$(WFITCAPENF(NBOP))-"FIN="+num$(WFITOPEENF(NBOP))

    ##################################
    #on calcule les durées en jours
    ##################################
    #DUREE PREPARATION
    WDIFFDAT = WFITCAPSTR(NBOP) - WOPEFITSTD(NBOP)
    WDIFFHOU = WFITCAPSTF_SAV(NBOP) - WOPEFITSTF_SAV(NBOP)
    If WDIFFHOU < 0
        ##WDIFFDAT -= 1
        ##WDIFFHOU = 24 + WDIFFHOU
        WDIFFHOU = WDIFFHOU / 24
    Else
        WDIFFHOU = WDIFFHOU / 24
    Endif
    WFITPRPDUR(NBOP)     = WDIFFDAT + arr(WDIFFHOU,0.01) : #DUREE PREPARATION

    #DUREE OPERATOIRE
    WDIFFDAT = WFITCAPEND(NBOP) - WFITCAPSTR(NBOP)
    WDIFFHOU = WFITCAPENF_SAV(NBOP) - WFITCAPSTF_SAV(NBOP)
    If WDIFFHOU < 0
        ##WDIFFDAT -= 1
        ##WDIFFHOU = 24 + WDIFFHOU
    Endif

    # calcul fraction
    If [F:MWS]WSTTYP = 3 : # sous-traitance
        WDIFFHOU /= 24
    Else
        J = dayn(WFITCAPEND(NBOP)) - 1
        # si capacité non nulle pour le jour
        If [F:TWD]DAYCAP(J) <> 0
            WDIFFHOU  = int((WDIFFHOU  / [F:TWD]DAYCAP(J)) * 100) / 100
        Else
            WDIFFHOU =0
        Endif
    Endif
    WFITWORDUR(NBOP)     = WDIFFDAT + arr(WDIFFHOU,0.01)  : #DUREE OPERATOIRE


    #DUREE POST-OPERATOIRE
    WDIFFDAT = WFITOPEEND(NBOP) - WFITCAPEND(NBOP)
    WDIFFHOU = WFITOPEENF_SAV(NBOP) - WFITCAPENF_SAV(NBOP)
    If WDIFFHOU < 0
        ##WDIFFDAT -= 1
        ##WDIFFHOU = 24 + WDIFFHOU
        WDIFFHOU = WDIFFHOU / 24
    Else
        WDIFFHOU = WDIFFHOU / 24
    Endif
    WFITPSTDUR(NBOP)     = WDIFFDAT + arr(WDIFFHOU,0.01) : #DUREE POST-OPERATOIRE

    #Infbox "WFITPRPDUR="+num$(WFITPRPDUR(NBOP))-"WFITWORDUR="+num$(WFITWORDUR(NBOP))-"WFITPSTDUR="+num$(WFITPSTDUR(NBOP))

    WFITDELAY(NBOP)      = 0 : # avance/retard ???
    WMFGPIO(NBOP)        = func PITMFG.MFG_GETMFGPIO
    WEXTDAT(NBOP)        = date$
    NBOP += 1
$SUITE_LEC
    Gosub NEXT_RES
Wend
If MFGNUMTRTERR <> MFGNUMTRT
    Gosub MAJRES From OPTLIBA
    # Issue 103803 - 2015-27-06 by RBA : flag optimisation de l'OF reinitialisé si positionné à Oui avant traitement
    Gosub MAJ_OF
    #/ Issue 103803
Endif

$FIN_FICOPTRES
Openi

Call TEMPOFF From GESECRAN

# fermeture trace
If P_TRACE2 = 2
  WHFIN = time
  WHWRK = WHFIN-WHDEB
  J = mod(WHWRK,60)
  K = WHWRK/60
  K = int(K)
  WMESS=mess(107,190,1)+":"-num$(K)-mess(2,301,1)-num$(J)
  Call ECR_TRACE(WMESS,0) From GESECRAN
# Issue 98174 - 2014-03-21 by RBA
#  Call FERME_TRACE From LECFIC
#  # lecture trace
#  Call LEC_TRACE From LECFIC
  If ![V]GSERVEUR
    Call FERME_TRACE From LECFIC
    # lecture trace
    Call LEC_TRACE From LECFIC
  Endif
#/ Issue 98174
Endif

$FIN_OPTRES
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

###########################################################################
$READ_MFG
   Raz [F:MFG]
   Read [MFG]MFG0=MFGNUMTRT
   If fstat
       Raz [F:OPS]
       Read [OPS]OPS1=MFGNUMTRT
       If fstat
            Call ECR_TRACE(mess(151,193,1)-":"-MFGNUMTRT,1) From GESECRAN
       Else
            Raz [F:MFG]
            [F:MFG]MFGNUM=MFGNUMTRT
       Endif
   Endif
Return

$RAZ_MFG
#Issue X3-85577 - 2018-04-18 by RBA
Raz  WOPEFITSTDNEW :              # début préparation date
Raz  WFITOPEENDNEW :              # fin opération date

# description fichier résultat "results.csv"
Raz  WMFGNUM :        # numéro OF
Raz  WOPENUM :                 # numéro opération
Raz  WOPESPLNUM :              # numéro fraction opération
Raz  WOPEWST :             # poste de charge
Raz  WOPELAB :             # poste M/O
Raz  WOPELABCOE :              # coefficient opératoire MO
Raz  WPRPTIM :                 # temps de préparation
Raz  WSETTIM :                 # temps total fab
Raz  WEXTTIM :                 # temps total fab
Raz  WPSTTIM :                 # temps post-opératoire
Raz  WSCOLTI :                 # délai sous-traitance                      11.06 35988
Raz  WWSTNBR :                 # nombre de postes MA
Raz  WLABNBR :                 # nombre de postes MO
Raz  WOBJDAT :                 # début objectif initial
Raz  WOPESTR :                 # début opération au plus tôt
Raz  WFRCSTRDAT :              # début forcé date
Raz  WFRCSTRFRD :              # début forcé fraction
Raz  WOPEFITSTD :              # début préparation date
Raz  WOPEFITSTF :              # début préparation fraction
Raz  WOPEFITSTF_SAV :              # début préparation fraction
Raz  WFITCAPSTR :              # début fabrication date
Raz  WFITCAPSTF :              # début fabrication fraction
Raz  WFITCAPSTF_SAV :              # début fabrication fraction
Raz  WFITCAPEND :              # début post-opératoire date
Raz  WFITCAPENF :              # début post-opératoire fraction
Raz  WFITCAPENF_SAV :              # début post-opératoire fraction
Raz  WFITOPEEND :              # fin opération date
Raz  WFITOPEENF :              # fin opération fraction
Raz  WFITOPEENF_SAV :              # fin opération fraction
Raz  WFITPRPDUR :              # durée préparation
Raz  WFITWORDUR :              # durée opératoire
Raz  WFITPSTDUR :              # durée post-opératoire
Raz  WFITDELAY  :              # avance/retard
Raz  WMFGPIO    :              # priorité OF
Raz  WEXTDAT    :              # date traitement

# données d'enrichissement
Raz  WMFGFCY :
Raz  WMFGSTA          :
Raz  WOPESTA          :
Raz  WWCR    :
Raz  WWST    :
Raz  WWCRLAB :
Raz  WLAB    :
Raz  WWSTTYP          :
Raz  WOPEWSTTYP       :
Raz  WOPTTIM   :
Raz  WSETLABR  :
Raz  WOPELABR  :
Raz  WINFSTRD  :
Raz  WINFSTRF  :
Raz  WSETENDD  :
Raz  WSETENDF  :
Raz  WINFENDD  :
Raz  WINFENDF  :
Raz  WSCHSBB    :
Return
###########################################################################
$READ_OPE
    NOMFO=0 : NOOPS=0
    Raz [F:MFO]
    Read [MFO]MFO0=WMFGNUM(NBOP);WOPENUM(NBOP);WOPESPLNUM(NBOP)
    If fstat
       NOMFO=1
    Endif
    Raz [F:OPS]
    Read [OPS]OPS1=WMFGNUM(NBOP);WOPENUM(NBOP);WOPESPLNUM(NBOP)
    If fstat
       NOOPS=1
    Endif
    If NOOPS & NOMFO
       #Issue X3-85577 - 2018-04-18 by RBA
       Raz [F:MFO]
       Filter [MFO] Where MFGNUM = WMFGNUM(NBOP) and OPENUM = WOPENUM(NBOP)
       For [MFO]
         If [MFO]OPESTA = 7 #ordered
           Gosub SET_MFG_DAT
           Break
         Endif
       Next
       Filter [MFO]
       Read [MFO]MFO0=WMFGNUM(NBOP);WOPENUM(NBOP);WOPESPLNUM(NBOP)

       WERR=1
    Elsif NOOPS
        [F:OPS] = [F:MFO]
        # Issue 80364 - 2012-03-26 by RBA : on passe à l'ope suivante si rien dans OPERATIONS
        WERR=1
    Else
        Gosub SET_MFG_DAT #Issue X3-85577 - 2018-04-18 by RBA
        [F:MFO] = [F:OPS]
    Endif
Return

#Issue X3-85577 - 2018-04-18 by RBA
$SET_MFG_DAT
  WOPEFITSTDNEW(NBOPNEW) = left$(WRESULT(3),8)
  WFITOPEENDNEW(NBOPNEW) = left$(WRESULT(6),8)
  # mémorisation date la + petite et date la + grande pour borner l'OF
  If WMFGSTRNEW = [0/0/0] : WMFGSTRNEW = WOPEFITSTDNEW(NBOPNEW) : Endif
  If WMFGENDNEW = [0/0/0] : WMFGENDNEW = WFITOPEENDNEW(NBOPNEW) : Endif
  If WOPEFITSTDNEW(NBOPNEW) < WMFGSTRNEW : WMFGSTRNEW = WOPEFITSTDNEW(NBOPNEW) : Endif
  If WFITOPEENDNEW(NBOPNEW) > WMFGENDNEW : WMFGENDNEW = WFITOPEENDNEW(NBOPNEW) : Endif
  NBOPNEW += 1
Return

###########################################################################
$NEXT_RES
Rdseq WRESULT(0), WRESULT(1), WRESULT(2), WRESULT(3), WRESULT(4), WRESULT(5), WRESULT(6),
&     WRESULT(7)
&     Using [RESO]
Return

###########################################################################
# Issue 103803 - 2015-27-06 by RBA : flag optimisation de l'OF reinitialisé si positionné à Oui avant traitement
$MAJ_OF
#  Trbegin [MFG]
#  Read [MFG]MFG0=MFGNUMTRT
#  If [S]fstat=0 & [F:MFG]OPTFLG=2
#     [F:MFG]OPTFLG=1
#     Rewrite [F:MFG]
#     If [S]fstat>0
#        [V]GOK=0 : Call FSTA("MFG") From GLOCK
#     Endif
#  Endif
#  If [V]GOK=1
#     Commit
#  Else
#     Rollback
#  Endif

  Trbegin [MFG]
  Read [MFG]MFG0=MFGNUMTRT
  If [S]fstat=0
    If [F:MFG]OPTFLG=2
      [F:MFG]OPTFLG=1
    Endif
    [F:MFG]STRDAT    = WMFGSTRNEW #Issue X3-85577 - 2018-04-18 by RBA
    [F:MFG]ENDDAT    = WMFGENDNEW #Issue X3-85577 - 2018-04-18 by RBA
    Rewrite [F:MFG]
    If [S]fstat>0
      [V]GOK=0 : Call FSTA("MFG") From GLOCK
    Endif
  Endif
  If [V]GOK=1
     Commit
  Else
     Rollback
  Endif

# Issue X3-96498 - 2018-06-21 by RBA
# chargement résultats composés sur MFGITM et ORDERS
  For [MFI]MFI0 Where [MFI]MFGNUM = MFGNUMTRT & [MFI]ITMSTA < 3
    Readlock [MFI]MFI0 Curr
    If fstat = 0
      Update [ORD]
&       Where [ORD]WIPNUM = [F:MFI]WIPNUM
&           & [ORD]WIPTYP = 5
&           & [ORD]ITMREF = [F:MFI]ITMREF
&       With  STRDAT = WMFGSTRNEW,
&             ENDDAT = WMFGENDNEW
      If fstat = 0
    #    If [F:MFI]ITMSTA = 1 : [F:MFI]STRDAT = WMFGSTR : Endif
    #    [F:MFI]ENDDAT = WMFGEND
        If [F:MFI]ITMSTA < 3 : [F:MFI]STRDAT = WMFGSTRNEW : Endif
        [F:MFI]ENDDAT = WMFGENDNEW
        Rewrite [MFI]
      Else
        #on sort
      Endif
    Else
      #on sort
    Endif
    Unlock [MFI]
  Next
#/ Issue X3-96498

Return
#/ Issue 103803

###########################################################################
$ERR_LEC
    Infbox mess(149,193,1)
    WERR = 1
Resume

