#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################
# Created by : RMA
# Date       : 20/11/2014
# Tool for feeding the AUTINV, RECTYP and SAFTINVTYP (according to INVTYP) in table TABPIVTYP
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITC65: QAV7.1 P7 : Default values for AUTINV, RECTYP and SAFTINVTYP on TABPIVTYP") From LECFIC
  Call EXE_UTITC65(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Subroutine execution of the tool
#* @param APPLI  Folder to process
#*!
Subprog EXE_UTITC65(APPLI)
Value Char APPLI

If clalev([F:TPV]) : Close Local File [TPV] : Endif
Local File =APPLI+".TABPIVTYP" [TPV]

Call ECR_TRACE("UTITC65: Process Start on : "+APPLI,0) From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR_UTITC65
Call ECR_TRACE("UTITC65: Process End on : "+APPLI,0) From GESECRAN

End
########################################
#### Tool - Begin                   ####
########################################
$TR_UTITC65

Local Shortint DO_SAFTINVTYP : DO_SAFTINVTYP = 0
Local Shortint DO_AUTINV     : DO_AUTINV     = 0
Local Shortint DO_RECTYP     : DO_RECTYP     = 0
Local Shortint RUPD          : RUPD          = 0

If dim([F:TPV]AUTINV) > 0
  DO_AUTINV = 1
Endif

If dim([F:TPV]RECTYP) > 0
  DO_RECTYP = 1
Endif

If dim([F:TPV]SAFTINVTYP) > 0
  DO_SAFTINVTYP = 1
Endif

For [F:TPV]
  RUPD = 0
  If DO_AUTINV = 1
    If [F:TPV]AUTINV = 0
      [F:TPV]AUTINV = 1
      RUPD          = 1
      Call ECR_TRACE([F:TPV]PIVTYP + ":AUTINV updated with"-mess([F:TPV]AUTINV,1,1), 0) From GESECRAN
    Endif
  Endif
  If DO_RECTYP = 1
    If [F:TPV]RECTYP = 0
      [F:TPV]RECTYP = 1
      RUPD          = 1
      Call ECR_TRACE([F:TPV]PIVTYP + ":RECTYP updated with"-mess([F:TPV]RECTYP,2029,1), 0) From GESECRAN
    Endif
  Endif
  If DO_SAFTINVTYP > 0
    If [F:TPV]SAFTINVTYP = 0
      Case [F:TPV]INVTYP
        When 1, 5
          [F:TPV]SAFTINVTYP = 1
        When 2, 4
          [F:TPV]SAFTINVTYP = 4
        When 3
          [F:TPV]SAFTINVTYP = 3
      Endcase
      RUPD = 1
      Call ECR_TRACE([F:TPV]PIVTYP + ":SAFTINVTYP updated with"-mess([F:TPV]SAFTINVTYP,2028,1), 0) From GESECRAN
    Endif

  Endif
  If RUPD = 1
    Trbegin [F:TPV]
    Rewrite [F:TPV]
    If fstat
      Rollback
      Break
    Endif
    Commit
  Endif
Next

Return
########################################
#### Tool - End                   ######
########################################

#**
#*  Subroutine execution of the tool
#* @param APPLI  Folder to process
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","TABPIVTYP","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTITC65(APPLI)
End

#**
#* For execution from dosmajx (folder validation)
#* @param APPLI  Dossier to update
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","TABPIVTYP","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTITC65(APPLI)
End
