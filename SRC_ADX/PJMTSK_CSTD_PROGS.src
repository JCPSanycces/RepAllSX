###################################################################################################
# Classe PJMTSK
###################################################################################################
Funprog TASDESTEX_EXIST(ACTX, SIDENT2, SIDENT3)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2
Value Char SIDENT3

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-03-14 by SINGC
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "PJMTSK", "TASDESTEX", SIDENT2, SIDENT3, AVOID.ACHAR)
End IARENDRE

