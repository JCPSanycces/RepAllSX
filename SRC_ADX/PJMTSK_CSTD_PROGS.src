###################################################################################################
Funprog GET_ICON(IPIMTYP)
Value Integer IPIMTYP

Local Char SARENDRE(250)

  # Issue X3-29489 - 2017-03-29 by SINGC
  Case IPIMTYP
    When 5
      # Main d'oeuvre
      SARENDRE = "maindoeuvre.gif"
    When 6
      # Matière
      SARENDRE = "produit.png"
    When 7
      # Mixte
      SARENDRE = "mix.png"
    When 8
      # Misc
      # Issue X3-33209 - 2017-06-12 by TEJAC
      SARENDRE = "252.png"
    When Default
      SARENDRE = "Folder.gif"
  Endcase
End SARENDRE

###################################################################################################
Funprog IS_TCACOD_USED(ACTX, STCACOD)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char STCACOD

Local Integer IARENDRE

  # Issue X3-5329 - 2017-04-28 by FGR
  IARENDRE = [V]CST_ANO
  # -------------------
  Local File PJMTSK [PJTA]
  Filter [PJTA] Where [F:PJTA]TCACOD = STCACOD
  For [F:PJTA]
    IARENDRE = [V]CST_AYES
    Break
  Next
  Filter [PJTA]
End IARENDRE

###################################################################################################
Funprog GET_TASSTARTDT(ACTX, SOPPNUM, STASCOD, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SOPPNUM
Value Char STASCOD
Variable Char SMESSAGE

Local Date DARENDRE

  # Issue X3-26991/X3-43920 - 2017-07-04 by FGR
  Raz DARENDRE
  Raz SMESSAGE
  # -------------------
  Local File PJMTSK [PJTA]
  Read [PJTA]PTA0=SOPPNUM;STASCOD
  If fstat Then
    SMESSAGE = func AFNC.MES1(mess(591,2260,1), SOPPNUM, STASCOD)
  Else
    DARENDRE = [F:PJTA]TASSTARTDT
  Endif
End DARENDRE

