###################################################################################################
Funprog GET_KEYCONCAT_FROM_TASNUM(ACTX, STASNUM, SKEYCONCAT, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char STASNUM
Variable Char SKEYCONCAT
Variable Char SMESSAGE

Local Integer IARENDRE
Local Integer IFOUND

  IARENDRE = [V]CST_AOK
  Raz SKEYCONCAT
  Raz SMESSAGE
  # Issue X3-31898 - 2017-11-17 by FGR
  # -------------------
  IFOUND = [V]CST_ANO
  Local File PJMTSK [PJTA]
  Filter [PJTA] Where [F:PJTA]TASNUM = STASNUM
  For [F:PJTA]
    IFOUND = [V]CST_AYES
    SKEYCONCAT = [F:PJTA]KEYCONCAT
    Break
  Next
  Filter [PJTA]
  If IFOUND = [V]CST_ANO Then
    IARENDRE = [V]CST_AERROR
    SMESSAGE = func AFNC.MES1(mess(1004,2260,1), STASNUM)
  Endif
  # -------------------
End IARENDRE

###################################################################################################
Funprog GET_TASNUM_FROM_KEYCONCAT(ACTX, SKEYCONCAT, STASNUM, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SKEYCONCAT
Variable Char STASNUM
Variable Char SMESSAGE

Local Integer IARENDRE
Local Integer IFOUND
Local Integer IRET
Local Char BUDGET(GLONPBU)
Local Char TASK(GLONTAC)
Local Char PROJECT(GLONOPP)

  IARENDRE = [V]CST_AOK
  Raz STASNUM
  Raz SMESSAGE
  # Issue X3-31898 - 2017-11-17 by FGR
  # -------------------
  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(ACTX, SKEYCONCAT, PROJECT, BUDGET, TASK)
  IFOUND = [V]CST_ANO
  If TASK <> AVOID.ACHAR Then
    Local File PJMTSK [PJTA]
    Read [PJTA]PTA0=PROJECT;TASK
    STASNUM = [F:PJTA]TASNUM
  Endif
  If IFOUND = [V]CST_ANO Then
    IARENDRE = [V]CST_AERROR
    SMESSAGE = func AFNC.MES1(mess(1004,2260,1), STASNUM)
  Endif
  # -------------------
End IARENDRE

