#<AdxTL>@(#)3.0.0.0 $Revision$
####################################################################################
# Program Name: CHECKS
# Description : Check Printing Preprocessor
# Author      : GRNA
####################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call IMPRIME(NBPAR,PARAMETRE) From TRSRPT
If GOK<1 : End : Endif

Call EXEC(NBPAR,PARAMETRE)

End


####################################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Local    Integer STAT

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

Raz FILTRE, IFILT
Call ADDCRIT(FILTRE,IFILT,"STD","[PYH]STA<>9 & [PYH]STAFLG(8)<>2 & [PYH]AMTCUR>0 & [PYH]SNS=1"," & ") From GOBJSUB
Call ADDCRIT(FILTRE1,IFILT,"STD","[PYH]STA<>9 & [PYH]STAFLG(8)<>2 & [PYH]AMTCUR>0 & [PYH]SNS=1"," & ") From GOBJSUB

[L]FILT  = "1=1"
[L]FILT2 = "AMTLIN2<>0"

For I=0 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "__REQUETE": [L]NUMREQ1 = val([L]VALEUR)
   When "etat"     : [L]ETAT = [L]VALEUR
   When "societe"  : If [L]VALEUR<>""
                      Call ADDCRIT(FILTRE,IFILT,"CPY","[F:PYH]CPY='"+[L]VALEUR+"'"," & ") From GOBJSUB
                      Call ADDCRIT(FILTRE1,IFILT,"CPY","[F:PYH]CPY='"+[L]VALEUR+"'"," & ") From GOBJSUB
                      Call AM_CPY(VALEUR) From CPTTRT
                     Endif
   When "sitedeb"  : Call ADDCRIT(FILTRE,IFILT,"FCY","[F:PYH]FCY>='"+[L]VALEUR+"'"," & ") From GOBJSUB
                     Call ADDCRIT(FILTRE1,IFILT,"FCY","[F:PYH]FCY>='"+[L]VALEUR+"'"," & ") From GOBJSUB
   When "sitefin"  : Call ADDCRIT(FILTRE,IFILT,"FCY","[F:PYH]FCY<='"+[L]VALEUR+"'"," & ") From GOBJSUB
                     Call ADDCRIT(FILTRE1,IFILT,"FCY","[F:PYH]FCY<='"+[L]VALEUR+"'"," & ") From GOBJSUB
   When "bank"     : If [L]VALEUR<>""
                      Call ADDCRIT(FILTRE,IFILT,"BAN","[F:PYH]BAN='"+[L]VALEUR+"'"," & ") From GOBJSUB
                      Call ADDCRIT(FILTRE1,IFILT,"BAN","[F:PYH]BAN='"+[L]VALEUR+"'"," & ") From GOBJSUB
                      [L]BANK = [L]VALEUR
                     Endif
   When "datedeb"
    [L]DTE=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
    Call ADDCRIT(FILTRE,IFILT,"ACCDAT","[F:PYH]ACCDAT>=["+format$(GFMD,[L]DTE)+"]"," & ") From GOBJSUB
   When "datefin"
    [L]DTE=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
    Call ADDCRIT(FILTRE,IFILT,"ACCDAT","[F:PYH]ACCDAT<=["+format$(GFMD,[L]DTE)+"]"," & ") From GOBJSUB
   When "codedt"   : [L]EDIT = [L]VALEUR
   When "regdeb"   : Call ADDCRIT(FILTRE,IFILT,"NUM","[F:PYH]NUM>='"+[L]VALEUR+"'"," & ") From GOBJSUB
                     [L]PAYNUMDEB = [L]VALEUR
   When "regfin"   : Call ADDCRIT(FILTRE,IFILT,"[F:PYH]NUM","NUM<='"+[L]VALEUR+"'"," & ") From GOBJSUB
                     [L]PAYNUMFIN = [L]VALEUR
   When "numedt"   : If [L]VALEUR<>"0"
                      [L]NUMREQ2 = val([L]VALEUR)                   # user chosen ReportNo
                      [L]PARAMETRE(I) = "numedt="+[L]VALEUR
                     Else
                      [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ1)  # new system assigned ReportNo
                     Endif
   When "debche"   : [L]DEBCHE = [L]VALEUR
   When "chedeb"   : [L]CHEDEB = vireblc([L]VALEUR,2)
   When "chefin"   : If !instr(1,[L]VALEUR,"zzzz") :  [L]CHEFIN = vireblc([L]VALEUR,2) : Endif
   When "X3FCT"    : [L]FONCTION = [L]VALEUR
   When "X3ETA"    : [L]CODRPT = [L]VALEUR
   When "reprintche" : [L]REPRINT=val([L]VALEUR)
  Endcase
 Endif
Next

# Create  Log
If !GSERVEUR
 Call OUVRE_TRACE(mess(168,121,1)) From LECFIC
Endif

# Reprint existing check or create new checks
If  [L]REPRINT
    Gosub REPRINT_CHECK
Else
    Gosub NEW_CHECK
Endif

End


####################################################################
#   New Checks
$NEW_CHECK
Raz [L]WNUMLIG, OKSITE

ASSNEW=1

# 93332.sn FUTURE
#Case SORT
#  When 1 : Filter [PYH] Where evalue([L]FILTRE) & CHQNUM='' Order By Key CLE=BPR;PAYNUM #AMTLOC     # Business Partner
#  When 2 : Filter [PYH] Where evalue([L]FILTRE) & CHQNUM='' Order By toupper(BPANAM) # ;PAYNUM #AMTLOC  # Trade Name  ## Test toupper BPRNAM
#  When 3 : Filter [PYH] Where evalue([L]FILTRE) & CHQNUM='' Order By Key CLE=PAYTYP;PAYNUM #AMTLOC  # Transaction
#  When 4 : Filter [PYH] Where evalue([L]FILTRE) & CHQNUM='' Order By Key CLE=DUDDAT;PAYNUM #AMTLOC  # Open Item
#  When Default
#Endcase

#93332.so
#Link [CHQ] With [PYH]PYH0 = [CHQ]PAYNUM As [PYHS]
#& Where evalue([L]FILTRE) & CHQNUM='' Order By [CHQ]SORT; [CHQ]PAYNUM
#Read [PYHS] First
#If  fstat
#    Call ERREUR(func AFNC.MES2(mess(177,121,1),[L]PAYNUMDEB,[L]PAYNUMFIN)) From GESECRAN
#    GOK=0
#    Return
#Endif
#93332.eo

# 93332.sn
# 99920.o Filter [PYH] Where evalue([L]FILTRE) & CHQNUM='' Order By toupper(BPANAM) #  93332.n
# 99920 Always print checks by the Payment number order and NA-CHECKS.rpt changed as well
Filter [PYH] Where evalue([L]FILTRE) & CHQNUM='' Order By Key PYH0 #  99920.n
Read [PYH] First
If  fstat
    Call ERREUR(func AFNC.MES2(mess(177,121,1),[L]PAYNUMDEB,[L]PAYNUMFIN)) From GESECRAN
    GOK=0
    Return
Endif

# not needed - Filter [PYH] Where evalue([L]FILTRE) & CHQNUM='' Order By Key PYHX = BPANAM PYH0
# 93332.en

OLDCHE = [L]DEBCHE

#For [PYHS] # 93332.o
For [PYH]   # 93332.n
  # Verify site authorization
  OKSITE = 1
  If FONCTION<>""
   Read [AFF]AFF0=[F:PYH]FCY;GPROFIL;FONCTION
   If fstat : OKSITE = 0 : Endif
  Endif
  # Verify currency
  Gosub CTRL_DEVISE
  If OKSITE & OKDEV
   Call DEBTRANS From GLOCK
   OK = 1
   Gosub TR1
   If OK=0 : Break : Endif
  Endif
Next
If !(OKSITE  and OKCHQ) or !OK
     GOK=0
Endif

Return


####################################################################
#   New Checks
$REPRINT_CHECK
Raz NBT, NBE, OKCHQ

If  [L]CHEFIN<[L]CHEDEB
    # Range of the check numbers incorrect
    Call ERREUR(mess(18,121,1)) From GESECRAN
    GOK=0 : Return
Endif
[L]ASSNEW = ([L]DEBCHE<>[L]CHEDEB)           # use existing check number or assign new check numbers on reprint

# If use existing check number verify existance and check status = 2
If ![L]ASSNEW
    Read [F:CHN]CHN0=[L]BANK;[L]DEBCHE
    If  fstat
        Call ERREUR(func AFNC.MES2(mess(174,121,1),[L]BANK,[L]DEBCHE)) From GESECRAN
        GOK=0 : Return
    Elsif [F:CHN]STA <> 2
        Call ERREUR(func AFNC.MES2(mess(175,121,1),[L]BANK,[L]DEBCHE)) From GESECRAN
        GOK=0 : Return
    Endif
Endif

# Filter checks in check number range to find issued checks
Link [CHN2] With [PYH]PYH0=PAYNUM As [LNK] Where [L]BANK=[CHN2]BAN & [L]CHEDEB<=[CHN2]CHQNUM &
&                        [CHN2]CHQNUM<=[L]CHEFIN & [CHN2]STA=2  & evalue([L]FILTRE1)

# Verify a check is issued in range requested by user
Read [LNK] First
If fstat
    Call ERREUR(func AFNC.MES3(mess(175,121,1),[L]BANK,[L]CHEDEB,[L]CHEFIN)) From GESECRAN
    GOK=0 : Return
Endif

OLDCHE = [L]DEBCHE            # Reprint of check
For [LNK]
   Call DEBTRANS From GLOCK
   OK = 1
   Gosub TR1
   If !GOK | !OK : Break : Endif
Next
If !GOK : Return : Endif

If OLDCHE>[L]CHEFIN & OK=0
  If OKCHQ=0
     Call ERREUR(mess(18,121,1)) From GESECRAN  # Range of the check numbers incorrect
     GOK=0
  Else
     Call ERREUR(mess(23,121,1)) From GESECRAN  # Last check edited. Payments remain to be printed.
  Endif
Endif

Return


####################################################################################
$TR1
# Printing of Check
GOK = 1
Trbegin [ARM], [PYH], [CHN], [BAN]
# Raz [F:TPY]CODEDT, [F:TED]TRT #112154.n - Removed for 114312
 Call LEC_TPY_LEG(GCURLEG,[F:PYH]PAYTYP) From CPTLEC

 # 112154/114312.sn - If CODEDT is not populated, clear the cache for [F:TED], otherwise, read the right record
 If [F:TPY]CODEDT = ""
  Raz [F:TED]
 Else
  Call LEC_TED(GCURLEG,[F:TPY]CODEDT) From CPTLEC
 Endif
 # 112154/114312.en

 If [F:TED]TRT = [L]EDIT                    # Must be type "CHE"
  Filter [PYD] Where NUM=[F:PYH]NUM & evalue([L]FILT2)
  NBPYD = rowcount([PYD])
  Filter [PYD]
  WNUMLIG += 1
  Raz [F:ARM]
  Gosub ADDRESS
  [F:ARM]USR     = GUSER
  [F:ARM]RPTCOD  = [L]ETAT
  [F:ARM]NUMREQ  = [L]NUMREQ1
  [F:ARM]NUMLIG  = [L]WNUMLIG
  [F:ARM]CLEA1   = [F:PYH]NUM
  [F:ARM]CLEN2   = NBPYD
  [F:ARM]CREDAT  = date$
  Write [ARM]
  If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR1 : Endif

  Readlock [PYH2]PYH0=[F:PYH]NUM
  If fstat = 1
   GOK = -1 : GLOCK = "$PAYMENTH"-[F:PYH]NUM : Goto ROLL_TR1
  Elsif fstat
   GOK = 0 : Call RSTA("PYH2",[F:PYH]NUM) From GLOCK : Goto AB_TR1
  Endif

  If func AFNC.PARAM("CHQCT",[F:PYH]CPY)="2"
    If [L]REPRINT & [L]ASSNEW
      Gosub VOID_CHECK
    Endif

    If [L]ASSNEW
      Gosub SET_CHECK
      If !GOK : Goto AB_TR1 : Endif
      [F:PYH2]CHQNUM = OLDCHE
      Gosub GET_NEW_CHECK
      If !GOK : Goto AB_TR1 : Endif
    Endif
  Else
    Call INCSERIE(NEWCHE,OLDCHE,1) From CHKLIB
    OLDCHE = NEWCHE
  Endif

  [F:PYH2]EDTNUM = [L]NUMREQ1
  Rewrite [PYH2]
  If fstat
   GOK = 0 : Call FSTA("PYH2") From GLOCK : Goto AB_TR1
  Endif

  OKCHQ+=1
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1
Endif

$AB_TR1
Rollback
Return


####################################################################################
#  Determine whether to print address from BPADDRESS or PAYMENTH
####################################################################################
$ADDRESS
I=0

For J=0 To dim([F:PYH]BPAADDLIG)-1
 If vireblc([F:PYH]BPAADDLIG(J),2)<>"" : I=1 : Break : Endif
Next J
If [F:PYH]POSCOD <> "" or [F:PYH]CTY <> "" or [F:PYH]CRYNAM <> "" : I=1 : Endif
If I : Raz [F:ARM]CLEN1, [F:ARM]CLEA3
Elsif [F:PYH]BPR<>""
 [F:ARM]CLEN1 = 1
 [F:ARM]CLEA2 = [F:PYH]BPAINV
 [F:ARM]CLEA3 = [F:PYH]BPR
 Return
Endif
Raz [F:ARM]CLEA2
Return


# Void Existing check on reprint and assigning new check numbers
####################################################################################
$VOID_CHECK

Local Char BAN(GLONBAN),CHQNUM(15)

# Assign new check check number, set old check to void if payment is assigned to old check
Read [F:CHN]CHN0=[L]BANK;[F:PYH]CHQNUM
If  fstat
    Return
Endif

[L]BAN=[F:CHN]BAN
[L]CHQNUM=[F:CHN]CHQNUM
If  [L]CHQNUM<>""
    Gosub CHEQUE_VOID From CHKLIB
    Call ECR_TRACE(func AFNC.MES3(mess(169,121,1),[L]BAN,[L]CHQNUM,[F:PYH]NUM),-2) From GESECRAN
    Call ECR_TRACE(func AFNC.MES3(mess(170,121,1),[L]BAN,[L]OLDCHE,[F:PYH]NUM),-2) From GESECRAN
Endif

Return


# Update current check and get next check number
# Also call from EDITCHE
####################################################################################
$SET_CHECK

If !clalev([F:CHN]) : Local File CHQNUM [CHN] : Endif

# Verify existing check is ok or handle duplicate
Gosub VERIF_CHECK

# Update Check table
Readlock [CHN]CHN0=[L]BANK;OLDCHE
If !fstat
 [F:CHN]CHQTYP = 2          # Normal check
 [F:CHN]STA    = 2          # Issued
 [F:CHN]PAYNUM = [F:PYH]NUM
 [F:CHN]PRNFLG = 2          # Printed
 [F:CHN]PRNDAT = [F:PYH]ACCDAT
 [F:CHN]UPDUSR = GUSER
 [F:CHN]UPDDAT = date$
 [F:CHN]CLODAT = [00/00/00]
 Rewrite [CHN]
Elsif fstat=5               # Check not found, create it
 Raz [F:CHN]
 [F:CHN]BAN    = [L]BANK
 [F:CHN]CHQNUM = OLDCHE
 [F:CHN]STA    = 2          # Issued
 [F:CHN]PAYNUM = [F:PYH]NUM
 [F:CHN]CHQTYP = 2          # Normal
 [F:CHN]PRNFLG = 2          # Printed
 [F:CHN]PRNDAT = [F:PYH]ACCDAT
 [F:CHN]CREUSR = GUSER
 [F:CHN]CREDAT = date$
 [F:CHN]CLODAT = [00/00/00]
 Write [CHN]
Else
 GOK = 0 : Call RSTA("CHN",[L]BANK-OLDCHE) From GLOCK : Return
Endif
If fstat
 GOK = 0 : Call FSTA("CHN") From GLOCK : Return
Endif

Return
####################################################################################
# Find next available check and update bank
$GET_NEW_CHECK
OLDCHE = ctrans(right$(OLDCHE,1),"ABCDEFGHIJKLMNOPQRSTUVWXYZ","")  # clear any check suffix
Call INCSERIE(NEWCHE,OLDCHE,1) From CHKLIB
OLDCHE = NEWCHE

# Update bank with next check
Update [BAN] Where BAN=[L]BANK With NXTSEQ=OLDCHE
If fstat : GOK = 0 : Call FSTA("BAN") From GLOCK : Return : Endif

Return


####################################################################################
# Verify that the check is available (if it already exists)
$VERIF_CHECK
Local Char DUPCHE(30)

Read [CHN]CHN0=[F:PYH]BAN;OLDCHE
If !fstat & find([F:CHN]STA,2,5)   # Issued or Cleared  - means create suffix on check
  DUPCHE=OLDCHE
  Call GETDUP([F:CHN]BAN,OLDCHE)
  Call ECR_TRACE(func AFNC.MES5(mess(171,121,1),[F:CHN]BAN,[L]DUPCHE,[F:CHN]BAN,[L]OLDCHE,[F:PYH]NUM),-2) From GESECRAN
Endif

Return


##############################################################################
$CTRL_DEVISE

OKDEV=1
NBT=+1
#If find([L]CODRPT,"CHECK") & [PYH]CUR="EUR"
#    NBT-=1 : NBE+=1 : OKDEV=0
#    Call ECR_TRACE(func AFNC.MES1(mess(172,121,1),[F:PYH]NUM),-2) From GESECRAN
#Endif
Return


####################################################################################
Subprog GETDUP(BNK,CHE)
Value Char BNK()
Variable Char CHE()

Local Char TMP_CHE(15)
Local Integer SUF, CNT

If !clalev([CHN]) Local File CHQNUM [F:CHN] : Endif
TMP_CHE = CHE
SUF = ascii(right$(TMP_CHE,len(TMP_CHE)))           # ascii version of last char

If SUF>=65
    TMP_CHE = left$(TMP_CHE,len(TMP_CHE)-1)
Endif

For CNT= 66 To 90
 CHE = TMP_CHE + chr$(CNT)  # increment the letter suffix
 Read [F:CHN]CHN0=[L]BNK;[L]CHE
 If fstat
    Break
 Elsif [F:CHN]STA<>2 and [F:CHN]STA<>5         # Unissued or voided
       Break
 Endif
Next

End


####################################################################################
$OUVRE
Local File PAYMENTH [PYH], PAYMENTH [PYH2], PAYMENTD [PYD], AREPORTM [ARM], TABPAYTYP [TPY],
& BPADDRESS [BPA], BPARTNER [BPR], BPCUSTOMER [BPC], BPSUPPLIER [BPS], GACCOUNT [GAC],
& AFCTFCY [AFF], GACCENTRY [HAE], BANK [BAN], CHQNUM [CHN], CHQNUM [CHN2],
& COMPANY [CPY], TABCODEDT [TED] #93332.o, CHQNAM [CHQ]
Return


####################################################################################
$DECLARE
Local Date DTE
Local Integer I, J, NUMREQ1, NUMREQ2, WNUMLIG, NBR, CHQNBR, OK, OKSITE, NBT, NBE, OKCHQ, NBPYD,OKDEV
Local Char FILT(100), FILT2(100), ETAT(GLONARP), PARAM(30), VALEUR(30), EDIT(3), CODRPT(15)
Local Char CHEDEB(15), CHEFIN(15), OLDCHE(15), NEWCHE(15), BANK(GLONBAN), FONCTION(10)
Local Char DEBCHE(15),PAYNUMDEB(GLONVCR),PAYNUMFIN(GLONVCR)
Local Integer ASSNEW,REPRINT

# Variables pour effectur le filtre
Local Char FILTRE(250)(1..2),FILTRE1(250)(1..2)
Local Integer IFILT : IFILT = 1
Return


##############################################################################
$ACTION

Case ACTION
 When "OUVRE"
  Local Integer P2
  # Starting Check Number
  P2 = find("bank",[M]PARCOD(0..[M]NBRPAR-1))
  If P2 & [M]VALEUR1(P2-1)<>""
     Call DEF_CHQNUM([M]VALEUR1(P2-1),ACTION)
  Endif
  P2 = find("reprintche",[M]PARCOD(0..[M]NBRPAR-1))
  If P2
     Gosub SAVE_SCR_FIELDS
     Gosub SET_DEF_REPRINT
     Gosub SET_SCR_FIELDS
  Endif
 When "CONT1"
  If [M]PARCOD(nolign-1)="reprintche"
     P2=nolign
     Gosub SAVE_SCR_FIELDS
     Gosub SET_SCR_FIELDS
  Endif

  If [M]PARCOD(nolign-1)="bank"
   Call DEF_CHQNUM([M]VALINT1(nolign-1),ACTION)
  Endif

  If [M]PARCOD(nolign-1)="debche" & !CHK_DEBCHE
    P2=nolign
    Call DEBCHE(VALEUR,P2)
  Endif
 When "CONT2"
  If [M]PARCOD(nolign-1)="debche"
   If VALEUR="" : VALEUR = "zzzzzzzzzzzzzzz" : Return : Endif
   Local Integer L1 , L2
   L1 = len(VALEUR) : L2 = len([M]VALEUR1(nolign-1))
   If L1>L2
    [M]VALEUR1(nolign-1) = string$(L1-L2,"0")+[M]VALEUR1(nolign-1)
    [M]VALINT1(nolign-1) = [M]VALEUR1(nolign-1)
    Affzo VALEUR1(nolign-1)
   Elsif L2>L1
    VALEUR = string$(L2-L1,"0") + VALEUR
    [M]VALINT2(nolign-1) = VALEUR
   Endif
  Endif
 When "AP_IMPRIME"
  Local Integer P2
  # Starting Check number
  P2 = find("bank",[M]PARCOD(0..[M]NBRPAR-1))
  If P2 & [M]VALEUR1(P2-1)<>""
     Call DEF_CHQNUM([M]VALEUR1(P2-1),ACTION)
  Endif
  P2 = find("reprintche",[M]PARCOD(0..[M]NBRPAR-1))
  If P2
     Gosub SAVE_SCR_FIELDS
     Gosub SET_SCR_FIELDS
  Endif
  Call FERME_TRACE From LECFIC
  Call TEMPOFF From GESECRAN
  Call LEC_TRACE From LECFIC
  Kill NXT_CHECK,DATEDEB1,DATEFIN1,REGDEB1,REGFIN1,CHEDEB1,CHEFIN1
  Kill CHK_DEBCHE
 When Default :
Endcase
Return


##############################################################################
Subprog DEBCHE(VALEUR,P2)        # Next Check Number
Variable Char VALEUR()
Value Integer P2
Local Integer P3,OK

P3 = find("chedeb",[M]PARCOD(0..[M]NBRPAR-1))
If  (VALEUR<NXT_CHECK) & ([M]VALEUR1(P3-1)<>VALEUR)  # check number is less than nxt check and not printing same check again
    Call OUINON(func AFNC.MES2(mess(173,121,1),VALEUR,NXT_CHECK),OK) From GESECRAN
    If OK=1
       mkstat=2
       [M]VALEUR1(P2-1) = NXT_CHECK
       [M]VALINT1(P2-1) = NXT_CHECK
       Affzo [M]VALEUR1(P2-1)
       Raz CHK_DEBCHE
    Else
       CHK_DEBCHE = 1
    Endif
Else
    CHK_DEBCHE = 2
Endif

End


##############################################################################
$SAVE_SCR_FIELDS

Local Integer P3
Global Char NXT_CHECK(30),DATEDEB1(20),DATEFIN1(20),REGDEB1(GLONVCR),REGFIN1(GLONVCR),CHEDEB1(30),CHEFIN1(30)
Global Integer CHK_DEBCHE

P3 = find("datedeb",[M]PARCOD(0..[M]NBRPAR-1))
DATEDEB1=[M]VALEUR1(P3-1)
DATEFIN1=[M]VALEUR2(P3-1)

P3 = find("regdeb",[M]PARCOD(0..[M]NBRPAR-1))
REGDEB1=[M]VALEUR1(P3-1)
REGFIN1=[M]VALEUR2(P3-1)

P3 = find("chedeb",[M]PARCOD(0..[M]NBRPAR-1))
CHEDEB1=[M]VALEUR1(P3-1)
CHEFIN1=[M]VALEUR2(P3-1)

P3 = find("debche",[M]PARCOD(0..[M]NBRPAR-1))
NXT_CHECK=[M]VALEUR1(P3-1)

Return


##############################################################################
$SET_DEF_REPRINT

Local Integer DEF_REPRINT
Call GET_PYH(REGDEB1,DEF_REPRINT)
If  DEF_REPRINT
    VALINT1(P2-1)="2"
    VALEUR1(P2-1)=mess(2,1,1)
Else
    VALINT1(P2-1)="1"
    VALEUR1(P2-1)=mess(1,1,1)
Endif

DEBCHE = 0

Return


##############################################################################
$SET_SCR_FIELDS
If dim([L]REPRINT)<1 : Local Integer REPRINT : Endif

[L]REPRINT=val(VALINT1(P2-1))-1
If  [L]REPRINT
    Call UPD_SCR_FIELDS("datedeb","","",2)
    Call UPD_SCR_FIELDS("regdeb","","",2)
    Call UPD_SCR_FIELDS("chedeb",CHEDEB1,CHEFIN1,1)
Else
    Call UPD_SCR_FIELDS("datedeb",DATEDEB1,DATEFIN1,1)
    Call UPD_SCR_FIELDS("regdeb",REGDEB1,REGFIN1,1)
    Call UPD_SCR_FIELDS("chedeb","","",2)
Endif

Affzo [M]
Return


##############################################################################
Subprog UPD_SCR_FIELDS(FLDNAM,VAL1,VAL2,ZO)
Value Char FLDNAM
Value Char VAL1
Value Char VAL2
Value Integer ZO  # 1 = Actzo, 2 = Grizo

Local Integer P3
P3 = find(FLDNAM,[M]PARCOD(0..[M]NBRPAR-1))

[M]VALEUR1(P3-1) = VAL1
Call CHARGE([M]VALEUR1(P3-1),[M]PARTYP(P3-1),[M]NOLIB(P3-1),[M]LONG(P3-1),[M]VALINT1(P3-1)) From FMTVAR
[M]VALEUR2(P3-1) = VAL2
Call CHARGE([M]VALEUR2(P3-1),[M]PARTYP(P3-1),[M]NOLIB(P3-1),[M]LONG(P3-1),[M]VALINT2(P3-1)) From FMTVAR

Case ZO
  When 1 : Actzo [M]VALEUR1(P3-1),VALEUR2(P3-1)
  When 2 : Grizo [M]VALEUR1(P3-1),VALEUR2(P3-1)
Endcase
End


# Get payment header check print status
##############################################################################
Subprog GET_PYH(PYH_NUM,DEF_REPRINT)
Value Char PYH_NUM()
Variable Integer DEF_REPRINT
DEF_REPRINT=1
If  PYH_NUM<>""

    If !clalev([F:PYH]) : Local File PAYMENTH [PYH] : Endif # 114312.n

    Read [F:PYH]PYH0=PYH_NUM
    If fstat | [F:PYH]CHQNUM="" | func AFNC.PARAM("CHQCT",[F:PYH]CPY)<>"2"
       DEF_REPRINT=0
    Endif
Else
    DEF_REPRINT=0
Endif
End

# default check number
# Also called from EDITCHE
##############################################################################
Subprog DEF_CHQNUM(BANK,ACTION)
Value Char BANK(),ACTION()

If !clalev([F:BAN2]) : Local File BANK [BAN2] : Endif

Local Integer P1 : P1 = find("debche",[M]PARCOD(0..[M]NBRPAR-1))
If P1=0 : P1 = find("chedeb",[M]PARCOD(0..[M]NBRPAR-1)) : Endif  # For EDITCHE
#FQ122491
Local Integer P2 : P2 = find("numedt",[M]PARCOD(0..[M]NBRPAR-1))

If (P1 & [M]VALEUR1(P1-1)="") | (P1 & [M]VALEUR1(P1-1)="0") | ACTION="AP_IMPRIME"
 If [L]BANK<>[F:BAN2]BAN
  Read [BAN2]BAN0=[L]BANK
  If fstat : End : Endif
 Endif
 NXT_CHECK = [F:BAN2]NXTSEQ
 #FQ122491
 #If func AFNC.PARAM("CHQCT",[F:BAN2]CPY)<>"2"
 If func AFNC.PARAM("CHQCT",[F:BAN2]CPY)<>"2" or (P2 and [M]VALEUR1(P2-1)<>"0")
  NXT_CHECK = [F:PYH]CHQNUM
 Endif
 [M]VALEUR1(P1-1) = NXT_CHECK
 [M]VALINT1(P1-1) = [M]VALEUR1(P1-1)
 Affzo [M]VALEUR1(P1-1)
 If [M]DEBFIN(P1-1)>1
  [M]VALEUR2(P1-1) = NXT_CHECK
  [M]VALINT2(P1-1) = [M]VALEUR2(P1-1)
  Affzo [M]VALEUR2(P1-1)
 Endif
Endif

End

