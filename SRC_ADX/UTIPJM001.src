#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM001
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    #Call MAJ_UTIPJM001(DOSSIER)
    Call MAJ_UTIPJM002(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM001(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NI
Local Integer NCOUNTOK
Local Integer NCOUNTERROR
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)

  IERR = 0
  Call ECR_TRACE("UTIPJM001: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table PJMTIMEMP
  #
  If filinfo(filpath("FIL", "PJMTIMEMP", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PJMTIMEMP" [PTE]
  # -------------------------
  If dim([F:PTE]SVGPTEORI) > 0 Then
    # Je mets la modification de ADI ici pour ne faire cette modification qu'une seule fois
    Trbegin [PTE]
    NCOUNT = 0
    NCOUNTERROR = 0
    Call ECR_TRACE("UTIPJM001: Updating PJMTIMEMP", 0) From GESECRAN
    Filter [PTE] Where [F:PTE]SVGPTEORI = "" or [F:PTE]SVGPTESTA = ""
    For [PTE]
      NCOUNT += 1
      # -----------------------------
      If [F:PTE]SVGPTEORI = "" Then
        [F:PTE]SVGPTEORI = [F:PTE]PTEORI
      Endif
      If [F:PTE]SVGPTESTA = "" Then
        [F:PTE]SVGPTESTA = [F:PTE]PTESTA
      Endif
      # -----------------------------
      Rewrite [PTE]
      If fstat Then
        Call ECR_TRACE("File PJMTIMEMP" - [F:ADI]CODE - "/" - [F:ADI]N3 + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [PTE]
    # -------------------------
    If NCOUNTERROR = 0 Then
      Call ECR_TRACE("UTIPJM001: PJMTIMEMP" - num$(NCOUNT) - "updated.", 0) From GESECRAN
    Else
      Call ECR_TRACE("UTIPJM001: PJMTIMEMP" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
    Endif
    # -----------
    If IERR = 0 Then
      Commit
      Call ECR_TRACE("UTIPJM001 : records processed without error.", 0) From GESECRAN
    Else
      Rollback
      Call ECR_TRACE("UTIPJM001 : records processed with error(s).", 0) From GESECRAN
    Endif
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM002(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NI
Local Integer NCOUNTOK
Local Integer NCOUNTERROR
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)

  IERR = 0
  Call ECR_TRACE("UTIPJM002: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table PJMTIMEMP
  #
  If filinfo(filpath("FIL", "PJMTIMEMP", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PJMTIMEMP" [PTE]
  # -------------------------
  If dim([F:PTE]SVGPTEORI) > 0 Then
    # Je mets la modification de ADI ici pour ne faire cette modification qu'une seule fois
    Trbegin [PTE]
    NCOUNT = 0
    NCOUNTERROR = 0
    Call ECR_TRACE("UTIPJM002: Updating PJMTIMEMP", 0) From GESECRAN
    Filter [PTE]
    For [PTE]
      NCOUNT += 1
      # -----------------------------
      Case [F:PTE]SVGPTESTA
        When "NEW"
          [F:PTE]PTESTA = 1
        When "VAL"
          [F:PTE]PTESTA = 2
        When "INV"
          [F:PTE]PTESTA = 3
        When "POS"
          [F:PTE]PTESTA = 4
        When Default
          [F:PTE]PTESTA = 1
      Endcase
      # -----------------------------
      Case [F:PTE]SVGPTEORI
        When "MAN"
          [F:PTE]PTEORI = 1
        When "IMP"
          [F:PTE]PTEORI = 2
        When Default
          [F:PTE]PTEORI = 1
      Endcase
      # -----------------------------
      Rewrite [PTE]
      If fstat Then
        Call ECR_TRACE("File PJMTIMEMP" - [F:ADI]CODE - "/" - [F:ADI]N3 + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [PTE]
    # -------------------------
    If NCOUNTERROR = 0 Then
      Call ECR_TRACE("UTIPJM002: PJMTIMEMP" - num$(NCOUNT) - "updated.", 0) From GESECRAN
    Else
      Call ECR_TRACE("UTIPJM002: PJMTIMEMP" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
    Endif
    # -----------
    If IERR = 0 Then
      Commit
      Call ECR_TRACE("UTIPJM002 : records processed without error.", 0) From GESECRAN
    Else
      Rollback
      Call ECR_TRACE("UTIPJM002 : records processed with error(s).", 0) From GESECRAN
    Endif
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------------
  # Issue X3-8278/120038 - 2016-11-30 by FGR : BEGIN
  If filinfo(filpath("FIL","PJMTIMEMP","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTIMEMP") : End : Endif
  # Issue X3-8278/120038 - 2016-11-30 by FGR : END
  # -------------------------------
  Call MAJ_UTIPJM001(APPLI)
  Call MAJ_UTIPJM002(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  # -------------------------------
  # Issue X3-8278/120038 - 2016-11-30 by FGR : BEGIN
  If filinfo(filpath("FIL","PJMTIMEMP","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTIMEMP") : End : Endif
  # Issue X3-8278/120038 - 2016-11-30 by FGR : END
  # -------------------------------
  Call MAJ_UTIPJM001(APPLI)
  Call MAJ_UTIPJM002(APPLI)
End

