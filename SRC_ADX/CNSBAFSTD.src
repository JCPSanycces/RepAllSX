#<AdxTL>@(#)2.0.0.0 $Revision$
#######################################################################################
#
#  Balance inquirie in Conversion Currency
#     --> Obtain the details of mouvements in ledger currency and/or choosen conversion
#     currency
#######################################################################################
Raz GNBMASKOUV
Local Char PARAM(10)(1..7)
Call GCONSULT("BAF","",PARAM) From GCONSULT
End

Subprog PATCH(APPLI)
Value Char APPLI
If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(1)<>2 End Endif
Call VALGTC(APPLI,"BAF") From SUBGTC
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LECTURE"     : Gosub LECTURE
 When "LISTE1"      : Gosub LISTE1
 When "LISTE2"      : Gosub LISTE2
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "APRES_CHOI"  : Raz BALPRG1,BALPRG2,BALPRG3,BALPRG4,BALPRG5,BALPRG6
Endcase
Return


#######################################################################################
$OUVRE
Local Char    TYPDEV
Local Integer NBSITE, TYPBAL, EXRATE,SPSTAT
Local Date    DSTR, DEND
Local Integer DERPER,MAXPER(0..50)
Local Integer I, J, K, CTLACS,ERRCNV0,ERRCNV1,STAT,STATA
Local Integer E, EDEB, EFIN, PDEB, PFIN, BDEB, BFIN
Local Char    RACDEB(GLONGAC), RACFIN(GLONGAC), STRFLT(GLONGAC), ENDFLT(GLONGAC),TMPEXRATE(GLONGAC)
Local Char    KEEPACC(GLONGAC),KEEPCUR(10), FIRSTACC(GLONGAC),DEVSOC(GLONCUR),DEVLED(GLONCUR),DEVLEDA(GLONCUR),CODLED(GLONLED)
Local Char    FILBAL(250), MESSA(250)
Local Libelle LCPY,COHGRP,LIG,CPTLIG,LBLCLEDPRG, LIGFLG
Local Decimal EXERCICE, PERIODE , MTNTDEB, MTNTCDT, MTNTRES, MTNTPRG
Local Char    SACCRR(GLONSAC), CPTCRR(10),COLL(10)
Local Date    DDEB, DFIN, DEBEX
#Pour gérer l'export des soldes progressifs quand un compte est à cheval sur 2 écrans
Local Decimal BALPRG1, BALPRG2, BALPRG3, BALPRG4, BALPRG5, BALPRG6

If clalev([GCM])=0 : Local File GACM [GCM] : Endif

NBSITE = max(1,GNBSITE)
Local Integer TPDEB(1..NBSITE) , TPFIN(1..NBSITE)
Local Integer TEDEB(1..NBSITE) , TEFIN(1..NBSITE) , TMAXPER(0..50,1..NBSITE)
Local Char    TSITE(GLONFCY)(1..NBSITE), TSOCIETE(GLONCPY)(1..NBSITE)

Local Char    TDEVLEC(GLONCUR)(1..NBSITE) , TDEVSOC(GLONCUR)(1..NBSITE)
Local Char    TDEVLED(GLONCUR)(1..NBSITE)
NBSITE=0

DERPER = dim([F:BAL]DEB)-1

Gosub DEFCRIT
Return


#######################################################################################
$DEFCRIT
# Check the facility autorisation
If [M:BAF1]FCY<>"" & GUSRFCY(1)<>"\" & !find([M:BAF1]FCY,GUSRFCY(1..GNBAUZ))
 [M:BAF1]FCY=""
Endif

DDEB=[M:BAF1]DATDEB
DFIN=[M:BAF1]DATFIN

# Defaults Values
Default Mask [BAF1]
Call INIT(DSTR,DEND) From CONSSUB
If [M:CBAF]FIY1=0 : [M:CBAF]FIY1 = 2 : Endif
If [M:CBAF]CLO =0 : [M:CBAF]CLO  = 2 : Endif
If [M:CBAF]EXC =0 : [M:CBAF]EXC  = 2 : Endif

# Check the integrity between criterias
For I=1 To dim(PARAM)
 Case I
  When 1 : # Company
   If PARAM(I)<>""
    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:BAF1]CPY = PARAM(I)
     If [M:BAF1]FCY<>""
      Call LECTURE("FCY",[M:BAF1]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY<>[M:BAF1]CPY : [M:BAF1]FCY="" : Endif
     Endif
    Endif
   Endif
  When 2 : # Facility
   If PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     [M:BAF1]FCY = PARAM(I)
     [M:BAF1]CPY = [F:FCY]LEGCPY
     PARAM(1)=""
    Endif
   Endif
  When 3 : # Ledger type
   If clalev([GCM])=0 : Local File GACM [GCM] : Endif
   If clalev([LED])=0 : Local File GLED [LED] : Endif
   If val(PARAM(I))<>0
    If [M:BAF1]CPY<>""
     Call LECTURE("CPY",[M:BAF1]CPY,"") From CONTOBJ
     Call LECTURE("GCM",[F:CPY]ACM,"")  From CONTOBJ
     If [F:GCM]LED(val(PARAM(I))-1)<>""
      Call LECTURE ("LED",[F:GCM]LED(val(PARAM(I))-1),"") From CONTOBJ
      [M:BAF1]LEDTYP = val(PARAM(I))
      [M:BAF1]COA    = [F:LED]COA
     Endif
    Endif
   Endif
   If [M:BAF1]LEDTYP = 0 :  [M:BAF1]LEDTYP = 1 : Endif
  When 4 : # Summary account
   If PARAM(I)<>""
    Read [GAC]GAC1 = [M:BAF1]COA;PARAM(I)
    If !fstat & [F:GAC]SAC=2 : [M:BAF1]SAC = PARAM(I) : Endif
   Endif
  When 5 : # Filter
   If PARAM(I)<>""
    mkstat=0 : Call C_STRFLT(PARAM(I))
    If !mkstat : [M:BAF1]STRFLT = PARAM(I) : Endif
   Endif
  When 6 : # Start date
   If instr(1,PARAM(I),"/")
    [M:BAF1]DATDEB = "["+PARAM(I)+"]"
   Elsif PARAM(I)<>""
    [M:BAF1]DATDEB = PARAM(I)
   Endif
  When 7 : # End Date
   If instr(1,PARAM(I),"/")
    [M:BAF1]DATFIN = "["+PARAM(I)+"]"
   Elsif PARAM(I)<>""
    [M:BAF1]DATFIN = PARAM(I)
   Endif
  When 8 : Break
 Endcase
Next I

#default values for filter by exercice.
Default Mask [BAF1]
Call INIT(DDEB,DFIN) From CONSSUB

# Initialisation of the criteria mask with the main mask values
Gosub CRITENT From =PROGCNS
Return


#######################################################################################
$LECTURE
# If the company and the dates are not filled in , reset to 1 NBLU.
If [M:BAF1]CPY=""  | [M:BAF1]DATDEB=[0/0/0] | [M:BAF1]DATFIN=[0/0/0] : NBLU = 0
 Return
Endif
Effzo [M:BAF2]5
ERRCNV0=0

#Check on the first page if no exchange rate of ledger currency
If [M]CNVCUR<>"" and (CHGPAG=1 or CHGPAG=3)
 If [M:BAF1]CURLED<>""
  Call PARAM([M:BAF1]CPY,"CNSTYPCUR",TMPEXRATE) From ADOVAL
  EXRATE = val(TMPEXRATE) : TMPEXRATE=""
  If EXRATE=0 : EXRATE = 1 : Endif
  # Amount just to test the exchange rate
  MTNTDEB=1
  MTNTRES=1
  Call CONVERT([M:BAF1]CURLED,[M:BAF1]CNVCUR,[M:BAF1]CURLED,EXRATE,datesyst,MTNTDEB,MTNTRES,STAT)From TRTDEV
  If STAT : ERRCNV0=1 : Endif
  If ERRCNV0=1 : Gosub ERRCUR : Endif
 Endif
Endif

Call LECTURE("CPY",[M:BAF1]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG<>2
 # Do not check the consistency between beginnings period (Allowed financials years)
  Call CNTCOHPERV6([M:BAF1]CPY,[M:BAF1]LEDTYP,[M:BAF1]DATDEB,[M:BAF1]DATFIN,SPSTAT,GMESSAGE) From CPTCNT
 If SPSTAT=0 : Return : Endif
Endif

Gosub INIT

If LCPY & !COHGRP & (CHGPAG=1 or CHGPAG=3)
  # Non traduit
  # Les exercices de ce groupe sont décalés, pas de soldes antérieurs
 Call MESSAGE(mess(62,109,1)) From GESECRAN
Endif

#if the ledger currency is not the same for all the companies then do not calculate the progressif balances
LBLCLEDPRG=0
If LCPY & (CHGPAG=1 or CHGPAG=3)
 Call CNTCOHDEV([M:BAF1]CPY,[M:BAF1]LEDTYP,CODLED,DEVLEDA,STATA,MESSA) From CPTCNT
 If !STATA
   #Non traduit
   #Toute les sociétés n'ont pas la même devise pour ce référentiel :
   #: non calcul des soldes progressifs en devise de référentiel.
   Call MESSAGE([L]MESSA-mess(216,107,1)) From GESECRAN
   LBLCLEDPRG=1
 Endif
Endif

# To define the balance type according to the summary account (SAC)
If [M:BAF1]SAC<>""
 Read [GAC]GAC1 = [M:BAF1]COA;[M:BAF1]SAC
 TYPBAL = 2 : COLL = [F:GAC]ACC
Else
 TYPBAL = 1 : COLL = ""
Endif

# To manage the page change
If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif

J = instr(1,[M:BAF1]STRFLT,"*")
K = instr(1,[M:BAF1]STRFLT,"?")

If     J & K : J = min(J,K)
Elsif !J & K : J = K
Endif

If J
 RACDEB = left$([M:BAF1]STRFLT,J-1)
 If RACDEB<>""
  RACFIN = left$(RACDEB,len(RACDEB)-1)+chr$(ascii(mid$(RACDEB,len(RACDEB),1))+1)
 Endif
Endif

If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:BAF2] : Endif

# if Legal ComPanY go to the reading RDLCPY
If !LCPY
 Gosub RDLCPY
Else
#Else go to RDNOTLCPY
 Gosub RDNOTLCPY
Endif
SACCRR = [M:BAF1]SAC
CPTCRR = [M:BAF1]STRFLT

If !CTLACS
 # Your results are constrained by your users rights.
 Call MESSAGE(mess(55,109,1)) From GESECRAN
 Return
Endif
Return

#######################################################################################
$INIT
Raz MAXPER
Call LECTURE("CPY",[M:BAF1]CPY,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
Call LECTURE("LED",[F:GCM]LED([M:BAF1]LEDTYP-1),"") From CONTOBJ
LCPY=([F:CPY]CPYLEGFLG=1)

# If legal company
If !LCPY
 [M:BAF1]COA = [F:LED]COA
 Call GETPERSOC([M:BAF1]CPY,[M:BAF1]LEDTYP,[M:BAF1]DATDEB,EXERCICE,PERIODE) From CPTSUB
 EDEB = EXERCICE
 PDEB = PERIODE

 Call GETPERSOC([M:BAF1]CPY,[M:BAF1]LEDTYP,[M:BAF1]DATFIN,EXERCICE,PERIODE) From CPTSUB
 EFIN = EXERCICE
 PFIN = PERIODE

 Read [FIY]FIY0 = [M:BAF1]CPY;EXERCICE
 For EXERCICE=EDEB To EFIN
  Filter [PER] Where CPY=[M:BAF1]CPY & FIYNUM=EXERCICE
  Read [PER]PER0 Last
  MAXPER(EXERCICE) = [F:PER]PERNUM
 Next
 Filter [PER]
 DEVSOC = [F:CPY]ACCCUR
 DEVLED = [F:GCM]CUR([M:BAF1]LEDTYP-1)
 COHGRP=1

# Else if not legal company
Else
 COHGRP = 1
 NBSITE = 0
 For [FGR]FGR0 Where CPY = [M:BAF1]CPY
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ

  # Borders with first and last financial year.
  Filter [FIY] Where CPY=[F:FCY]LEGCPY & LEDTYP=[M:BAF1]LEDTYP
  Read [FIY]FIY0 First
  If [M:BAF1]DATDEB>=[F:FIY]FIYSTR : DDEB = [M:BAF1]DATDEB : Else : DDEB = [F:FIY]FIYSTR : Endif
  Read [FIY]FIY0 Last
  If [M:BAF1]DATFIN<=[F:FIY]FIYEND : DFIN = [M:BAF1]DATFIN : Else : DFIN = [F:FIY]FIYEND : Endif
  Filter [FIY]

  # Include Site if financial year in action.
  If DDEB<=DFIN
   NBSITE += 1
   TSITE(NBSITE) = [F:FGR]FCY
   Call GETPERSOC([F:FCY]LEGCPY,[M:BAF1]LEDTYP,DDEB,EXERCICE,PERIODE) From CPTSUB
   TEDEB(NBSITE) = EXERCICE
   TPDEB(NBSITE) = PERIODE
   Read [FIY]FIY0 = [F:FCY]LEGCPY;[M:BAF1]LEDTYP;EXERCICE
   If NBSITE=1
    DEBEX = [F:FIY]FIYSTR
   Elsif DEBEX<>[F:FIY]FIYSTR
    COHGRP = 0
   Endif
   Call GETPERSOC([F:FCY]LEGCPY,[M:BAF1]LEDTYP,DFIN,EXERCICE,PERIODE) From CPTSUB
   TEFIN(NBSITE) = EXERCICE
   TPFIN(NBSITE) = PERIODE
   For EXERCICE=TEDEB(NBSITE) To TEFIN(NBSITE)
    Filter [PER] Where CPY=[F:FCY]LEGCPY & LEDTYP=[M:BAF1]LEDTYP & FIYNUM=EXERCICE
    Read [PER]PER0 Last
    TMAXPER(EXERCICE,NBSITE) = [F:PER]PERNUM
    Filter [PER]
   Next
   TSOCIETE(NBSITE) = [F:FCY]LEGCPY
   Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
   TDEVSOC(NBSITE) = [F:CPY]ACCCUR
   Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
   TDEVLED(NBSITE) = [F:GCM]CUR([M:BAF1]LEDTYP-1)
   TDEVSOC(NBSITE) = TDEVLED(NBSITE) : # Il n'y a plus de DEVSOC!
   Call LECTURE("LED",[F:GCM]LED([M:BAF1]LEDTYP-1),"") From CONTOBJ
   [M:BAF1]COA = [F:LED]COA
  Endif
 Next : # [FGR]
Endif
Return

#######################################################################################
## Define the type of displayed balance
#######################################################################################
$TYPBLC
Case [M:BAF1]CNVCUR
 When "" :
  # No converted currency so opération fields and ledger fields are displayed.
  TYPDEV = "1"
 When [M:BAF1]CURLED :
  # if converted currency is the same as ledger one
  # so opération fields and ledger fields are displayed.
  TYPDEV = "2"
 When Default :
  # Operation fields, legder fields and converted fields
  TYPDEV = "3"
Endcase
Return


#######################################################################################
## Reading for a legal company                                                       ##
#######################################################################################
$RDLCPY

#Define the exchange rate
Call PARAM([M:BAF1]CPY,"CNSTYPCUR",TMPEXRATE) From ADOVAL
EXRATE = val(TMPEXRATE) : TMPEXRATE=""
If EXRATE=0 : EXRATE = 1 : Endif

#Define the type of displayed balance
Gosub TYPBLC

#Define the Balance filter
Gosub FILTRE

# if specific program
If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

#In case of change page manage the desc or asc display.
If CHGPAG>0
 Filter [BAL] Where evalue(FILBAL)
&             Order By Key CLE = LEDTYP;ACC;BPR;CUR;CPY;FCY;FIY

Else
 Filter [BAL] Where evalue(FILBAL)
&             Order By Key CLE =  LEDTYP Desc; ACC Desc;BPR Desc;CUR Desc;CPY Desc;FCY Desc;FIY Desc
Endif #CHGPAG

CTLACS = 1

For [BAL]CLE(3) : # BPR
 CPTLIG=0
 OK = 1
 If TYPBAL=1
  Read [GAC]GAC0 = [M:BAF1]COA;[F:BAL]ACC
  If !fstat
   If [F:GAC]CLSCOD<>"" & [M:CBAF]EXC<>2
    Call LECTURE("COA",[F:GAC]COA,"") From CONTOBJ
    Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD
    If [F:CLS]TYP=2
     OK = 0
    Endif
   Endif
  Endif
  If [F:GAC]ACS<>""
   Local Integer DROIT
   Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
   If !DROIT : OK = 0  : CTLACS=0 : Endif
  Endif
 Endif #TYPBAL

 If OK
  If NBLU=1
   If CHGPAG=2 or CHGPAG=-2 : Raz [M:BAF2] : Endif
   NBLU=2
  Endif

  If CHGPAG>0
   If NOL>=MAXLIG-1 : SUITE=2 : Break : Endif
   NOL += 1
   Case TYPBAL
   When 1
    If NOL=0 : STRFLT=[F:BAL]ACC : Endif
    ENDFLT=KEEPACC
   When 2
    If NOL=0 : STRFLT=[F:BAL]BPR : Endif
    ENDFLT=[F:BAL]BPR
   Endcase
  Else
   If NOL<=0 : RETOUR = 2 : Break : Endif
   NOL -= 1
   Case TYPBAL
   When 1
    If NOL=MAXLIG-1 : ENDFLT=[F:BAL]ACC : Endif
    STRFLT = KEEPACC
   When 2
    If NOL=MAXLIG-1 : ENDFLT=[F:BAL]BPR : Endif
    STRFLT=[F:BAL]BPR
   Endcase
  Endif #CHGPAG

  Case TYPBAL
  When 1
   [M:BAF2]ACC(NOL) = [F:BAL]ACC
   Call LECTEXTRA([M:BAF2]ACCDES(NOL),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
   If NOL=0 : FIRSTACC=[M:BAF2]ACC(0):Endif
  When 2
   Read [BPR]BPR0 = [M:BAF2]ACC(NOL)
   If !fstat : [M:BAF2]ACCDES(NOL)=[F:BPR]BPRNAM : Endif
   [M:BAF2]ACC(NOL) = [F:BAL]BPR
   If NOL=0 : FIRSTACC=[M:BAF2]ACC(0):Endif
  Endcase

  LIGFLG=0
  For [BAL]CLE(4) # cur
   Gosub RAZE
   KEEPCUR=""
   If LIGFLG
    If CHGPAG>0
     If NOL < MAXLIG-1
      NOL += 1
     Endif
    Elsif NOL>0
     NOL -= 1
    Endif
    LIGFLG=0
   Endif
   For [BAL]CLE # details
    #Timekeeper of Balance
    E = [F:BAL]FIY
    #Middle financial year , take on all
    BDEB = 1
    BFIN = MAXPER(E)
    # First financial year , no financialyear-1, special column
    If E=EDEB
     BDEB=PDEB
    Endif
    # Last financial year, add on Close
    If E=EFIN
     If PFIN=MAXPER(E) & [M:CBAF]CLO=2 & COHGRP : BFIN = DERPER
     Else                                       : BFIN = PFIN
     Endif
    Endif
    # For Italy !
    #If [F:LED]ENDVCR=2
    # If BDEB=1 & [M:CBAF]FIY1=2 : BDEB = 0 : Endif
    #Endif

    Case TYPBAL
    When 1
     [M:BAF2]ACC(NOL) = [F:BAL]ACC
     Call LECTEXTRA([M:BAF2]ACCDES(NOL),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
    When 2
     [M:BAF2]ACC(NOL) = [F:BAL]BPR
     Read [BPR]BPR0 = [M:BAF2]ACC(NOL)
     If !fstat : [M:BAF2]ACCDES(NOL)=[F:BPR]BPRNAM : Endif
    Endcase

    [M:BAF2]CUR(NOL)=[F:BAL]CUR
    #Calculation of amount DEBIT and CREDIT
    Gosub CALCUL
   Next #details (FIY)

   If LIG #At least one line calculated so
    CPTLIG=1
    #Calculation of balances
    Gosub TOTAUX

    # Manage the change page
    If CHGPAG>0
     # Due to the MAXLIG do not increment the NOL at the last loop.
     If NOL < MAXLIG-1
      NOL += 1
     Else
      KEEPACC=[M:BAF2]ACC(NOL)
      KEEPCUR=[M:BAF2]CUR(NOL)
      If REPONSE=GSTAXLS2 | REPONSE=GSTAXLS
       BALPRG1 = [M:BAF2]ANTCNVPRG(NOL)
       BALPRG2 = [M:BAF2]PRGBLCCNV(NOL)
       BALPRG3 = [M:BAF2]FINPRGCNV(NOL)
       BALPRG4 = [M:BAF2]ANTPRGLED(NOL)
       BALPRG5 = [M:BAF2]PRGBLCLED(NOL)
       BALPRG6 = [M:BAF2]FINPRGLED(NOL)
      Endif
      SUITE=2
      Break 2
     Endif

     Case TYPBAL
     When 1
      If NOL=0 : [M:BAF2]CUR(NOL)=[F:BAL]CUR : Endif
      [M:BAF2]CUR(NOL)=KEEPCUR
     When 2
      If NOL=0 : [M:BAF2]CUR(NOL)=[F:BAL]CUR : Endif
      [M:BAF2]CUR(NOL)=KEEPCUR
     Endcase

    Elsif CHGPAG<0
     If NOL >0
      NOL -=1
     Else
      KEEPACC=[M:BAF2]ACC(NOL)
      KEEPCUR=[M:BAF2]CUR(NOL)
      RETOUR = 2
      Break 2
     Endif

     Case TYPBAL
     When 1
      If NOL=MAXLIG-1 : [M:BAF2]CUR(NOL)=[F:BAL]CUR : Endif
      [M:BAF2]CUR(NOL)=KEEPCUR
     When 2
      If NOL=MAXLIG-1 : [M:BAF2]CUR(NOL)=[F:BAL]CUR : Endif
      [M:BAF2]CUR(NOL)=KEEPCUR
     Endcase

    Endif #CHGPAG
   Else #LIG
    [M:BAF2]ACC(NOL)=""
    [M:BAF2]CUR(NOL)=""
    [M:BAF2]CURLED(NOL)=""
    [M:BAF2]ACCDES(NOL)=""
    If CHGPAG>0 and NOL<>0
     NOL -= 1
    Elsif CHGPAG<=0 and NOL<>MAXLIG-1
     NOL += 1
    Endif
    LIGFLG=1
    CPTLIG=1
   Endif #LIG
  Next  #cur

  #No TOTAUX so do not display lines and go back line number
  If !CPTLIG
   [M:BAF2]ACC(NOL)=""
   [M:BAF2]CUR(NOL)=""
   [M:BAF2]ACCDES(NOL)=""
   If NOL<>0
    If CHGPAG>0
     NOL -= 1
    Else
     NOL += 1
    Endif
   Endif
  Endif #CPTLIG

 Endif  #OK
Next # acc/bpr

#In order to manage the Next/Back button : keep the CUR and ACC.
STRFLT = [M:BAF2]ACC(0)
If STRFLT="" : STRFLT = [M:BAF2]ACC(1) : Endif
ENDFLT = [M:BAF2]ACC(max(0,min(NOL,dim([M:BAF2]ACC)-1)))
KEEPCUR = [M:BAF2]CUR(max(0,min(NOL,dim([M:BAF2]ACC)-1)))
If ENDFLT=""  & NOL>0 : ENDFLT  = [M:BAF2]ACC(NOL-1) : Endif
If KEEPCUR="" & NOL>0 : KEEPCUR = [M:BAF2]CUR(NOL-1) : Endif
Filter [BAL]
Return


#######################################################################################
## Calculation
#######################################################################################

$RAZE
Raz LIG,MTNTRES,MTNTDEB,MTNTCDT,MTNTPRG,CPTLIG,GMESSAGE,ERRCNV1
Return

#######################################################################################
$CALCUL
#Calculation of amount DEBIT and CREDIT
Case TYPDEV
 When "1":
 #case1 and case2 => Operation fields and legder fields
  Gosub CALC_OPLED

 When "2","3" :
 #case3 => Operation fields and legder fields
  Gosub CALC_OPLED
 #and converted fields
  [M:BAF2]CNVCUR(NOL)     = [M:BAF1]CNVCUR
  #Debit conversion
  MTNTRES = 0
  MTNTDEB = [M:BAF2]LEDDEB(NOL)
  If MTNTDEB <>0
   Call CONVERT([M:BAF2]CURLED(NOL),[M:BAF1]CNVCUR,[F:BAL]CURLED,EXRATE,datesyst,MTNTDEB,MTNTRES,STAT)From TRTDEV
   If STAT : ERRCNV1 = 1
   Else [M:BAF2]CNVDEB(NOL) = MTNTRES
   Endif
  Endif

  #Credit conversion
  MTNTRES = 0
  MTNTCDT = [M:BAF2]LEDCDT(NOL)
  If MTNTCDT <>0
   Call CONVERT([M:BAF2]CURLED(NOL),[M:BAF1]CNVCUR,[F:BAL]CURLED,EXRATE,datesyst,MTNTCDT,MTNTRES,STAT)From TRTDEV
   If STAT : ERRCNV1=1
   Else [M:BAF2]CNVCDT(NOL) = MTNTRES
   Endif
  Endif

 Endcase

#At least one line has been calculated so go to the "TOTAUX" (balance) calculation : LIG=1
If sum([F:BAL]DEB(BDEB..BFIN)) or sum([F:BAL]CDT(BDEB..BFIN)) or sum([F:BAL]DEBLED(BDEB..BFIN)) or sum([F:BAL]CDTLED(BDEB..BFIN))
 LIG=1
Endif

If [M:CBAF]FIY1=2 and ([M:BAF2]ANTDEB(NOL)<>0 or [M:BAF2]ANTCDT(NOL)<>0 or [M:BAF2]ANTDEBLED(NOL)<>0 or [M:BAF2]ANTCDTLED(NOL)<>0)
 LIG=1
Endif
Return

#######################################################################################
$CALC_OPLED
#Calculation of Operation fields and legder fields
If COHGRP & E=EDEB
   [M:BAF2]ANTDEB(NOL)    += sum([F:BAL]DEB(1..BDEB-1))
   [M:BAF2]ANTCDT(NOL)    += sum([F:BAL]CDT(1..BDEB-1))
   [M:BAF2]ANTDEBLED(NOL) += sum([F:BAL]DEBLED(1..BDEB-1))
   [M:BAF2]ANTCDTLED(NOL) += sum([F:BAL]CDTLED(1..BDEB-1))
   If [M:CBAF]FIY1=2
    [M:BAF2]ANTDEB(NOL)    += [F:BAL]DEB(0)
    [M:BAF2]ANTCDT(NOL)    += [F:BAL]CDT(0)
    [M:BAF2]ANTDEBLED(NOL) += [F:BAL]DEBLED(0)
    [M:BAF2]ANTCDTLED(NOL) += [F:BAL]CDTLED(0)
   Endif
  Endif
  [M:BAF2]DEB(NOL)       += sum([F:BAL]DEB(BDEB..BFIN))
  [M:BAF2]CDT(NOL)       += sum([F:BAL]CDT(BDEB..BFIN))
  [M:BAF2]CURLED(NOL)     = [F:BAL]CURLED
  [M:BAF2]LEDDEB(NOL)    += sum([F:BAL]DEBLED(BDEB..BFIN))
  [M:BAF2]LEDCDT(NOL)    += sum([F:BAL]CDTLED(BDEB..BFIN))
Return
#######################################################################################

#######################################################################################
$TOTAUX
#calculation of balance
Case TYPDEV
 When "1":
  #TOTAUX for Operation fields and Ledger fields balances
  Gosub TOT_OPLED

 When "2","3" :
  #TOTAUX for Operation fields and Ledger fields balances
  Gosub TOT_OPLED
  #And Converted balances
  #Balance Credit and Debit conversion (we calculate difference between Deb/Cdt converted)
  If [M:BAF2]CNVDEB(NOL)>[M:BAF2]CNVCDT(NOL)
   [M:BAF2]DEBBLCCNV(NOL) = [M:BAF2]CNVDEB(NOL)-[M:BAF2]CNVCDT(NOL)
   [M:BAF2]CDTBLCCNV(NOL) = 0
  Else
   [M:BAF2]CDTBLCCNV(NOL) = [M:BAF2]CNVCDT(NOL)-[M:BAF2]CNVDEB(NOL)
   [M:BAF2]DEBBLCCNV(NOL) = 0
  Endif
  #Progressif balances conversion (we calculate difference between balance Deb/Cdt converted)
  If NOL=0 and ENDFLT=[M:BAF2]ACC(NOL)
   If    [M:BAF2]DEBBLCCNV(NOL)<>0 : [M:BAF2]PRGBLCCNV(NOL) =  [M:BAF2]DEBBLCCNV(NOL)+ BALPRG2
   Elsif [M:BAF2]CDTBLCCNV(NOL)<>0 : [M:BAF2]PRGBLCCNV(NOL) = -[M:BAF2]CDTBLCCNV(NOL)+ BALPRG2
   Endif
  Elsif NOL=0 or [M:BAF2]ACC(NOL-1)=""
   If    [M:BAF2]DEBBLCCNV(NOL)<>0 : [M:BAF2]PRGBLCCNV(NOL) =  [M:BAF2]DEBBLCCNV(NOL)
   Elsif [M:BAF2]CDTBLCCNV(NOL)<>0 : [M:BAF2]PRGBLCCNV(NOL) = -[M:BAF2]CDTBLCCNV(NOL)
   Endif
  Elsif NOL>0
   If    [M:BAF2]DEBBLCCNV(NOL)<>0 : [M:BAF2]PRGBLCCNV(NOL) = [M:BAF2]PRGBLCCNV(NOL-1)+ [M:BAF2]DEBBLCCNV(NOL)
   Elsif [M:BAF2]CDTBLCCNV(NOL)<>0 : [M:BAF2]PRGBLCCNV(NOL) = [M:BAF2]PRGBLCCNV(NOL-1)- [M:BAF2]CDTBLCCNV(NOL)
   Elsif [M:BAF2]DEBBLCCNV(NOL)=0 and [M:BAF2]CDTBLCCNV(NOL)= 0 : [M:BAF2]PRGBLCCNV(NOL)= [M:BAF2]PRGBLCCNV(NOL-1)
   Endif
  Endif

  #Previous Balance Debit conversion
  MTNTRES = 0
  MTNTDEB = [M:BAF2]ANTDEBLED(NOL)
  If MTNTDEB <>0
   Call CONVERT([M:BAF2]CURLED(NOL),[M:BAF1]CNVCUR,[F:BAL]CURLED,EXRATE,datesyst,MTNTDEB,MTNTRES,STAT)From TRTDEV
   If STAT : ERRCNV1=1
   Else [M:BAF2]ANTCNVDEB(NOL) = MTNTRES
   Endif
  Endif
  #Previous Balance Credit conversion
  MTNTRES = 0
  MTNTCDT = [M:BAF2]ANTCDTLED(NOL)
  If MTNTCDT<>0
   Call CONVERT([M:BAF2]CURLED(NOL),[M:BAF1]CNVCUR,[F:BAL]CURLED,EXRATE,datesyst,MTNTCDT,MTNTRES,STAT)From TRTDEV
   If STAT : ERRCNV1=1
   Else [M:BAF2]ANTCNVCDT(NOL) = MTNTRES
   Endif
  Endif
  If NOL=0 and ENDFLT=[M:BAF2]ACC(NOL)
   If    [M:BAF2]ANTCNVDEB(NOL)<>0 : [M:BAF2]ANTCNVPRG(NOL) =  [M:BAF2]ANTCNVDEB(NOL)+ BALPRG1
   Elsif [M:BAF2]ANTCNVCDT(NOL)<>0 : [M:BAF2]ANTCNVPRG(NOL) = -[M:BAF2]ANTCNVCDT(NOL)+ BALPRG1
   Endif
  Elsif NOL=0 or [M:BAF2]ACC(NOL-1)=""
   If    [M:BAF2]ANTCNVDEB(NOL)<>0 : [M:BAF2]ANTCNVPRG(NOL) =  [M:BAF2]ANTCNVDEB(NOL)
   Elsif [M:BAF2]ANTCNVCDT(NOL)<>0 : [M:BAF2]ANTCNVPRG(NOL) = -[M:BAF2]ANTCNVCDT(NOL)
   Endif
  Elsif NOL>0
   If    [M:BAF2]ANTCNVDEB(NOL)<>0 : [M:BAF2]ANTCNVPRG(NOL) = [M:BAF2]ANTCNVPRG(NOL-1)+ [M:BAF2]ANTCNVDEB(NOL)
   Elsif [M:BAF2]ANTCNVCDT(NOL)<>0 : [M:BAF2]ANTCNVPRG(NOL) = [M:BAF2]ANTCNVPRG(NOL-1)- [M:BAF2]ANTCNVCDT(NOL)
   Elsif [M:BAF2]ANTCNVDEB(NOL)=0 and [M:BAF2]ANTCNVCDT(NOL)= 0 : [M:BAF2]ANTCNVPRG(NOL)= [M:BAF2]ANTCNVPRG(NOL-1)
   Endif
  Endif

  #End Balance Debit conversion
  MTNTRES = 0
  MTNTDEB = [M:BAF2]FINDEBLED(NOL)
  If MTNTDEB <>0
   Call CONVERT([M:BAF2]CURLED(NOL),[M:BAF1]CNVCUR,[F:BAL]CURLED,EXRATE,datesyst,MTNTDEB,MTNTRES,STAT)From TRTDEV
   If STAT : ERRCNV1=1
   Else [M:BAF2]FINDEBCNV(NOL) = MTNTRES
   Endif
  Endif
  #End Balance Credit conversion
  MTNTRES = 0
  MTNTCDT = [M:BAF2]FINCDTLED(NOL)
  If MTNTCDT<>0
   Call CONVERT([M:BAF2]CURLED(NOL),[M:BAF1]CNVCUR,[F:BAL]CURLED,EXRATE,datesyst,MTNTCDT,MTNTRES,STAT)From TRTDEV
   If STAT : ERRCNV1=1
   Else [M:BAF2]FINCDTCNV(NOL) = MTNTRES
   Endif
  Endif
  If NOL=0 and ENDFLT=[M:BAF2]ACC(NOL)
   If    [M:BAF2]FINDEBCNV(NOL)<>0 : [M:BAF2]FINPRGCNV(NOL) =  [M:BAF2]FINDEBCNV(NOL)+ BALPRG3
   Elsif [M:BAF2]FINCDTCNV(NOL)<>0 : [M:BAF2]FINPRGCNV(NOL) = -[M:BAF2]FINCDTCNV(NOL)+ BALPRG3
   Endif
  Elsif NOL=0 or [M:BAF2]ACC(NOL-1)=""
   If    [M:BAF2]FINDEBCNV(NOL)<>0 : [M:BAF2]FINPRGCNV(NOL) =  [M:BAF2]FINDEBCNV(NOL)
   Elsif [M:BAF2]FINCDTCNV(NOL)<>0 : [M:BAF2]FINPRGCNV(NOL) = -[M:BAF2]FINCDTCNV(NOL)
   Endif
  Elsif NOL>0
   If    [M:BAF2]FINDEBCNV(NOL)<>0 : [M:BAF2]FINPRGCNV(NOL) = [M:BAF2]FINPRGCNV(NOL-1)+ [M:BAF2]FINDEBCNV(NOL)
   Elsif [M:BAF2]FINCDTCNV(NOL)<>0 : [M:BAF2]FINPRGCNV(NOL) = [M:BAF2]FINPRGCNV(NOL-1)- [M:BAF2]FINCDTCNV(NOL)
   Elsif [M:BAF2]FINDEBCNV(NOL)=0 and [M:BAF2]ANTCNVCDT(NOL)= 0 : [M:BAF2]FINPRGCNV(NOL)= [M:BAF2]FINPRGCNV(NOL-1)
   Endif
  Endif

Endcase

# if the field DIV is filled in then divide (by it) the balances
# in case of soft currency.
Local Integer DIV
If [M:BAF1]DIV<>0
 DIV = [M:BAF1]DIV
 [M:BAF2]ANTCDT(NOL)    /= DIV
 [M:BAF2]ANTDEB(NOL)    /= DIV
 [M:BAF2]DEB(NOL)       /= DIV
 [M:BAF2]CDT(NOL)       /= DIV
 [M:BAF2]DEBBLC(NOL)    /= DIV
 [M:BAF2]CDTBLC(NOL)    /= DIV
 [M:BAF2]FINDEB(NOL)    /= DIV
 [M:BAF2]FINCDT(NOL)    /= DIV

 [M:BAF2]ANTDEBLED(NOL) /= DIV
 [M:BAF2]ANTCDTLED(NOL) /= DIV
 [M:BAF2]ANTPRGLED(NOL) /= DIV
 [M:BAF2]LEDDEB(NOL)    /= DIV
 [M:BAF2]LEDCDT(NOL)    /= DIV
 [M:BAF2]DEBBLCLED(NOL) /= DIV
 [M:BAF2]CDTBLCLED(NOL) /= DIV
 [M:BAF2]PRGBLCLED(NOL) /= DIV
 [M:BAF2]FINDEBLED(NOL) /= DIV
 [M:BAF2]FINCDTLED(NOL) /= DIV
 [M:BAF2]FINPRGLED(NOL) /= DIV

 [M:BAF2]ANTCNVDEB(NOL) /= DIV
 [M:BAF2]ANTCNVCDT(NOL) /= DIV
 [M:BAF2]ANTCNVPRG(NOL) /= DIV
 [M:BAF2]CNVDEB(NOL)    /= DIV
 [M:BAF2]CNVCDT(NOL)    /= DIV
 [M:BAF2]DEBBLCCNV(NOL) /= DIV
 [M:BAF2]CDTBLCCNV(NOL) /= DIV
 [M:BAF2]PRGBLCCNV(NOL) /= DIV
 [M:BAF2]FINDEBCNV(NOL) /= DIV
 [M:BAF2]FINCDTCNV(NOL) /= DIV
 [M:BAF2]FINPRGCNV(NOL) /= DIV
Else
 DIV = 1
Endif

Return

#######################################################################################
$TOT_OPLED
# Prévious balances
If [M:BAF2]ANTDEB(NOL)>[M:BAF2]ANTCDT(NOL)
 [M:BAF2]ANTDEB(NOL) = [M:BAF2]ANTDEB(NOL)-[M:BAF2]ANTCDT(NOL)
 [M:BAF2]ANTCDT(NOL) = 0
Else
 [M:BAF2]ANTCDT(NOL) = [M:BAF2]ANTCDT(NOL)-[M:BAF2]ANTDEB(NOL)
 [M:BAF2]ANTDEB(NOL) = 0
Endif

# Operation balances
If [M:BAF2]DEB(NOL)>[M:BAF2]CDT(NOL)
 [M:BAF2]DEBBLC(NOL) = [M:BAF2]DEB(NOL)-[M:BAF2]CDT(NOL)
 [M:BAF2]CDTBLC(NOL) = 0
Else
 [M:BAF2]CDTBLC(NOL) = [M:BAF2]CDT(NOL)-[M:BAF2]DEB(NOL)
 [M:BAF2]DEBBLC(NOL) = 0
Endif
[M:BAF2]FINDEB(NOL) = [M:BAF2]ANTDEB(NOL)-[M:BAF2]ANTCDT(NOL)+[M:BAF2]DEBBLC(NOL)-[M:BAF2]CDTBLC(NOL)
If [M:BAF2]FINDEB(NOL)<0
 [M:BAF2]FINCDT(NOL) = -[M:BAF2]FINDEB(NOL)
 [M:BAF2]FINDEB(NOL) = 0
Endif

# Previous ledger balances
If [M:BAF2]ANTDEBLED(NOL)>[M:BAF2]ANTCDTLED(NOL)
 [M:BAF2]ANTDEBLED(NOL) = [M:BAF2]ANTDEBLED(NOL)-[M:BAF2]ANTCDTLED(NOL)
 [M:BAF2]ANTCDTLED(NOL) = 0
Else
 [M:BAF2]ANTCDTLED(NOL) = [M:BAF2]ANTCDTLED(NOL)-[M:BAF2]ANTDEBLED(NOL)
 [M:BAF2]ANTDEBLED(NOL) = 0
Endif
#Progressif previous ledger balance (only one colunm)only if same ledger currency for all companies
If !LBLCLEDPRG
 If NOL=0 and [M:BAF2]ACC(NOL)=ENDFLT
  If    [M:BAF2]ANTDEBLED(NOL)<>0 : [M:BAF2]ANTPRGLED(NOL) =  [M:BAF2]ANTDEBLED(NOL)+ BALPRG4
  Elsif [M:BAF2]ANTCDTLED(NOL)<>0 : [M:BAF2]ANTPRGLED(NOL) = -[M:BAF2]ANTCDTLED(NOL)+ BALPRG4
  Endif
 Elsif NOL=0 or [M:BAF2]ACC(NOL-1)=""
  If    [M:BAF2]ANTDEBLED(NOL)<>0 : [M:BAF2]ANTPRGLED(NOL) =  [M:BAF2]ANTDEBLED(NOL)
  Elsif [M:BAF2]ANTCDTLED(NOL)<>0 : [M:BAF2]ANTPRGLED(NOL) = -[M:BAF2]ANTCDTLED(NOL)
  Endif
 Elsif NOL>0
  If    [M:BAF2]ANTDEBLED(NOL)<>0 : [M:BAF2]ANTPRGLED(NOL) = [M:BAF2]ANTPRGLED(NOL-1)+ [M:BAF2]ANTDEBLED(NOL)
  Elsif [M:BAF2]ANTCDTLED(NOL)<>0 : [M:BAF2]ANTPRGLED(NOL) = [M:BAF2]ANTPRGLED(NOL-1)- [M:BAF2]ANTCDTLED(NOL)
  Elsif [M:BAF2]ANTDEBLED(NOL)= 0 and [M:BAF2]ANTCDTLED(NOL)= 0 : [M:BAF2]ANTPRGLED(NOL) = [M:BAF2]ANTPRGLED(NOL-1)
  Endif
 Endif
Endif

#Ledger balances
If [M:BAF2]LEDDEB(NOL)>[M:BAF2]LEDCDT(NOL)
 [M:BAF2]DEBBLCLED(NOL) = [M:BAF2]LEDDEB(NOL)-[M:BAF2]LEDCDT(NOL)
 [M:BAF2]CDTBLCLED(NOL) = 0
Else
 [M:BAF2]CDTBLCLED(NOL) = [M:BAF2]LEDCDT(NOL)-[M:BAF2]LEDDEB(NOL)
 [M:BAF2]DEBBLCLED(NOL) = 0
Endif
If !LBLCLEDPRG
 #Progressif ledger balances (only one colunm) only if same ledger currency for all companies
 If NOL=0 and [M:BAF2]ACC(NOL)=ENDFLT
  If    [M:BAF2]DEBBLCLED(NOL)<>0 : [M:BAF2]PRGBLCLED(NOL) =  [M:BAF2]DEBBLCLED(NOL)+ BALPRG5
  Elsif [M:BAF2]CDTBLCLED(NOL)<>0 : [M:BAF2]PRGBLCLED(NOL) = -[M:BAF2]CDTBLCLED(NOL)+ BALPRG5
  Endif
 Elsif NOL=0 or [M:BAF2]ACC(NOL-1)=""
  If    [M:BAF2]DEBBLCLED(NOL)<>0 : [M:BAF2]PRGBLCLED(NOL) =  [M:BAF2]DEBBLCLED(NOL)
  Elsif [M:BAF2]CDTBLCLED(NOL)<>0 : [M:BAF2]PRGBLCLED(NOL) = -[M:BAF2]CDTBLCLED(NOL)
  Endif
 Elsif NOL>0
  If    [M:BAF2]DEBBLCLED(NOL)<>0 : [M:BAF2]PRGBLCLED(NOL) = [M:BAF2]PRGBLCLED(NOL-1)+ [M:BAF2]DEBBLCLED(NOL)
  Elsif [M:BAF2]CDTBLCLED(NOL)<>0 : [M:BAF2]PRGBLCLED(NOL) = [M:BAF2]PRGBLCLED(NOL-1)- [M:BAF2]CDTBLCLED(NOL)
  Elsif [M:BAF2]DEBBLCLED(NOL)= 0 and [M:BAF2]CDTBLCLED(NOL)= 0 : [M:BAF2]PRGBLCLED(NOL) = [M:BAF2]PRGBLCLED(NOL-1)
  Endif
 Endif
Endif

#End ledger balances
[M:BAF2]FINDEBLED(NOL) = [M:BAF2]ANTDEBLED(NOL)-[M:BAF2]ANTCDTLED(NOL)+[M:BAF2]DEBBLCLED(NOL)-[M:BAF2]CDTBLCLED(NOL)
If [M:BAF2]FINDEBLED(NOL)<0
 [M:BAF2]FINCDTLED(NOL) = -[M:BAF2]FINDEBLED(NOL)
 [M:BAF2]FINDEBLED(NOL) = 0
Endif
#Progressif end ledger balances (only one colunm) only if same ledger currency for all companies
If !LBLCLEDPRG
 If NOL=0 and [M:BAF2]ACC(NOL)=ENDFLT
  If    [M:BAF2]FINDEBLED(NOL)<>0 : [M:BAF2]FINPRGLED(NOL) =  [M:BAF2]FINDEBLED(NOL)+ BALPRG6
  Elsif [M:BAF2]FINCDTLED(NOL)<>0 : [M:BAF2]FINPRGLED(NOL) = -[M:BAF2]FINCDTLED(NOL)+ BALPRG6
  Endif
 Elsif NOL=0 or [M:BAF2]ACC(NOL-1)=""
  If    [M:BAF2]FINDEBLED(NOL)<>0 : [M:BAF2]FINPRGLED(NOL) =  [M:BAF2]FINDEBLED(NOL)
  Elsif [M:BAF2]FINCDTLED(NOL)<>0 : [M:BAF2]FINPRGLED(NOL) = -[M:BAF2]FINCDTLED(NOL)
  Endif
 Elsif NOL>0
  If    [M:BAF2]FINDEBLED(NOL)<>0 : [M:BAF2]FINPRGLED(NOL) = [M:BAF2]FINPRGLED(NOL-1)+ [M:BAF2]FINDEBLED(NOL)
  Elsif [M:BAF2]FINCDTLED(NOL)<>0 : [M:BAF2]FINPRGLED(NOL) = [M:BAF2]FINPRGLED(NOL-1)- [M:BAF2]FINCDTLED(NOL)
  Elsif [M:BAF2]FINDEBLED(NOL)= 0 and [M:BAF2]FINCDTLED(NOL)= 0 : [M:BAF2]FINPRGLED(NOL)=[M:BAF2]FINPRGLED(NOL-1)
  Endif
 Endif
Endif

Return
#######################################################################################


#######################################################################################
## Filter for a legal company                                                        ##
#######################################################################################
$FILTRE
FILBAL = 'LEDTYP='+num$([M:BAF1]LEDTYP)
FILBAL -= '& FCY="'+[M:BAF1]FCY+'"'
FILBAL -= '& CPY="'+[M:BAF1]CPY+'"'
FILBAL -= '& FIY>='+num$(EDEB)+' & FIY<='+num$(EFIN)

Case TYPBAL
 When 1
  FILBAL -= '& BPR=""'
  If J
   If RACDEB<>"" : FILBAL -= '& ACC>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILBAL -= '& ACC<"'+RACFIN+'"' : Endif
   FILBAL -= '& pat(ACC,"'+[M:BAF1]STRFLT+'")'
  Elsif [M:BAF1]STRFLT<>""
   FILBAL -= '& ACC>="'+[M:BAF1]STRFLT+'"'
  Endif
 When 2
  FILBAL -= '& ACC="'+COLL+'" & BPR<>""'
  If J
   If RACDEB<>"" : FILBAL -= '& BPR>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILBAL -= '& BPR<"'+RACFIN+'"' : Endif
   FILBAL -= '& pat(BPR,"'+[M:BAF1]STRFLT+'")'
  Elsif [M:BAF1]STRFLT<>""
   FILBAL -= '& BPR>="'+[M:BAF1]STRFLT+'"'
  Endif
Endcase

If SACCRR=[M:BAF1]SAC & CPTCRR=[M:BAF1]STRFLT
 Case CHGPAG
  When 3 : # Refresh
   Case TYPBAL
    When 1 : FILBAL -= '& ACC>="'+STRFLT+'"'
    When 2 : FILBAL -= '& BPR>="'+STRFLT+'"'
   Endcase
  When 2 : # Next
   # EXPLI var of GCONSULT telling us if Export CSV or Export Excel. In this case
   # we don't make the pagination.
   Case TYPBAL
    When 1 :
     If !EXPCLI
      FILBAL -= '& ACC>="'+ENDFLT+'"'
     Else
      FILBAL -= '& (ACC>"'+ENDFLT+'" or (ACC="'+ENDFLT+'" and CUR>"'+KEEPCUR+'"))'
     Endif
    When 2 :
     If !EXPCLI
      FILBAL -= '& BPR>="'+ENDFLT+'"'
     Else
      FILBAL -= '& (BPR>"'+ENDFLT+'" or (BPR="'+ENDFLT+'" and CUR>"'+KEEPCUR+'"))'
     Endif
   Endcase
  When -2 : # Back
   Case TYPBAL
    When 1 : FILBAL -= '& ACC<="'+STRFLT+'"'
    When 2 : FILBAL -= '& BPR<="'+STRFLT+'"'
   Endcase
 Endcase
Endif
Return

#######################################################################################
## Reading for not a Legal company (a group)                                                       ##
#######################################################################################
$RDNOTLCPY

Call PARAM("","CNSTYPCUR",TMPEXRATE) From ADOVAL
EXRATE = val(TMPEXRATE) : TMPEXRATE=""
If EXRATE=0 : EXRATE = 1 : Endif

#Define the type of displayed balance
Gosub TYPBLC

Gosub FILT_GRP

If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

#Manage the change page for asc or desc
If CHGPAG>0

 Link [BAL] With [FGR]FGR0=[M]CPY;[F:BAL]FCY , [GAC]GAC0=[F:BAL]COA;[F:BAL]ACC
&              , [BPR]BPR0=[F:BAL]BPR , [LED]LED0=[F:BAL]LED
&  As [LNK]
& Where evalue(FILBAL)
& Order By Key CLE2 = LEDTYP;ACC;BPR;CUR;CPY;FCY;FIY

Else

 Link [BAL] With [FGR]FGR0=[M]CPY;[F:BAL]FCY , [GAC]GAC0=[F:BAL]COA;[F:BAL]ACC
&              , [BPR]BPR0=[F:BAL]BPR , [LED]LED0=[F:BAL]LED
&  As [LNK]
& Where evalue(FILBAL)
& Order By Key CLE2 =  LEDTYP Desc; ACC Desc;BPR Desc;CUR Desc;CPY Desc;FCY Desc;FIY Desc

Endif

CTLACS = 1

For [LNK]CLE2(3) : # ACC/BPR
 CPTLIG=0
 OK=1
 If TYPBAL=1
  If [F:GAC]CLSCOD<>"" & [M:CBAF]EXC<>2
   Call LECTURE("COA",[F:GAC]COA,"") From CONTOBJ
   Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD
   If [F:CLS]TYP=2
    OK = 0
   Endif
  Endif
  If [F:GAC]ACS<>""
   Local Integer DROIT
   Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
   If !DROIT : OK = 0  : CTLACS = 0 : Endif
  Endif
 Endif #TYPBAL

 If OK
  If NBLU=1
   If CHGPAG=2 or CHGPAG=-2 : Raz [M:BAF2] : Endif
   NBLU=2
  Endif

  If CHGPAG>0
   If NOL>=MAXLIG-1 : SUITE=2 : Break : Endif
   NOL += 1
   Case TYPBAL
   When 1
    If NOL=0 : STRFLT=[F:BAL]ACC : Endif
    ENDFLT=KEEPACC
   When 2
    If NOL=0 : STRFLT=[F:BAL]BPR : Endif
    ENDFLT=[F:BAL]BPR
   Endcase
  Else
   If NOL<=0 : RETOUR = 2 : Break : Endif
   NOL -= 1
   Case TYPBAL
   When 1
    If NOL=MAXLIG-1 : ENDFLT=[F:BAL]ACC : Endif
    STRFLT = KEEPACC
   When 2
    If NOL=MAXLIG-1 : ENDFLT=[F:BAL]BPR : Endif
    STRFLT=[F:BAL]BPR
   Endcase
  Endif #CHGPAG

  Case TYPBAL
  When 1
   [M:BAF2]ACC(NOL) = [F:BAL]ACC
   Call LECTEXTRA([M:BAF2]ACCDES(NOL),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  When 2
   Read [BPR]BPR0 = [M:BAF2]ACC(NOL)
   If !fstat : [M:BAF2]ACCDES(NOL)=[F:BPR]BPRNAM : Endif
   [M:BAF2]ACC(NOL) = [F:BAL]BPR
  Endcase

  For [LNK]CLE2(4) # cur
   Gosub RAZE
   For [LNK]CLE2 : # Details
    I = find([F:BAL]FCY,TSITE(1..NBSITE))
    If I
     DEVSOC=TDEVSOC(I)
     DEVLED=TDEVLED(I)
     EDEB = TEDEB(I) : EFIN = TEFIN(I) : PDEB = TPDEB(I) : PFIN = TPFIN(I)
     For E=EDEB To EFIN : MAXPER(E) = TMAXPER(E,I) : Next E

     If [F:BAL]FIY>=EDEB & [F:BAL]FIY<=EFIN
      KEEPCUR=""

      # Timekeeper balance
      E = [F:BAL]FIY
      # Middle financial year, take on all
      BDEB = 1
      BFIN = MAXPER(E)
      # First financial year , no Fiscal year-1, special column
      If E=EDEB
       BDEB=PDEB
      Endif
      # Last financial year, add on close
      If E=EFIN
       If PFIN=MAXPER(E) & [M:CBAF]CLO=2 & COHGRP : BFIN = DERPER
       Else                                       : BFIN = PFIN
       Endif
      Endif
      # For Italy
      # If [F:LED]ENDVCR=2
      #  If BDEB=1 & [M:CBAF]FIY1=2 : BDEB = 0 : Endif
      # Endif

      Case TYPBAL
      When 1
       [M:BAF2]ACC(NOL) = [F:BAL]ACC
       Call LECTEXTRA([M:BAF2]ACCDES(NOL),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
      When 2
       [M:BAF2]ACC(NOL) = [F:BAL]BPR
       Read [BPR]BPR0 = [M:BAF2]ACC(NOL)
       If !fstat : [M:BAF2]ACCDES(NOL)=[F:BPR]BPRNAM : Endif
      Endcase

      [M:BAF2]CUR(NOL)=[F:BAL]CUR
      #Calculation of amount DEBIT and CREDIT
      Gosub CALCUL

     Endif # period
    Endif # site
   Next # detail
   If LIG
    CPTLIG=1
    #calculation of balance
    Gosub TOTAUX

    # Manage the change page
    If CHGPAG>0
     # Due to the MAXLIG do not increment the NOL at the last loop.
     If NOL < MAXLIG-1
      NOL += 1
     Else
      KEEPACC=[M:BAF2]ACC(NOL)
      KEEPCUR=[M:BAF2]CUR(NOL)
      SUITE=2
      Break 2
     Endif

     Case TYPBAL
     When 1
      If NOL=0 : [M:BAF2]CUR(NOL)=[F:BAL]CUR : Endif
      [M:BAF2]CUR(NOL)=KEEPCUR
     When 2
      If NOL=0 : [M:BAF2]CUR(NOL)=[F:BAL]CUR : Endif
      [M:BAF2]CUR(NOL)=KEEPCUR
     Endcase
    Elsif CHGPAG<0
     If NOL >0
      NOL -=1
     Else
      KEEPACC=[M:BAF2]ACC(NOL)
      KEEPCUR=[M:BAF2]CUR(NOL)
      If NOL = 0 : RETOUR =1
      Else : RETOUR = 2
      Endif
      Break 2
     Endif

     Case TYPBAL
     When 1
      If NOL=MAXLIG-1 : [M:BAF2]CUR(NOL)=[F:BAL]CUR : Endif
      [M:BAF2]CUR(NOL)=KEEPCUR
     When 2
      If NOL=MAXLIG-1 : [M:BAF2]CUR(NOL)=[F:BAL]CUR : Endif
      [M:BAF2]CUR(NOL)=KEEPCUR
     Endcase
    Endif #CHGPAG

   Else #LIG do not display blank line
    [M:BAF2]ACC(NOL)=""
    [M:BAF2]CUR(NOL)=""
    [M:BAF2]ACCDES(NOL)=""
   Endif # LIG
  Next : # cur

  # No TOTAUX so do not display lines and decrease line number
  If !CPTLIG
   [M:BAF2]ACC(NOL)=""
   [M:BAF2]CUR(NOL)=""
   [M:BAF2]ACCDES(NOL)=""
   If CHGPAG>0
    NOL -= 1
   Else
    NOL += 1
   Endif
  Endif #CPTLIG

 Endif #OK
Next #ACC/BPR

#In order to manage the Next/Back button
STRFLT = [M:BAF2]ACC(0)
If STRFLT="" : STRFLT = [M:BAF2]ACC(1) : Endif
ENDFLT = [M:BAF2]ACC(max(0,NOL))
If ENDFLT="" & NOL>0 : ENDFLT = [M:BAF2]ACC(NOL-1) : Endif
Return


######################################################################################
## Filter for not a Legal company (a group)
######################################################################################
$FILT_GRP
FILBAL  = '[F:BAL]LEDTYP='+num$([M:BAF1]LEDTYP)
FILBAL -= '& [F:BAL]COA="'+[M:BAF1]COA+'"'
FILBAL -= '& [F:FGR]CPY="'+[M]CPY+'"'
FILBAL -= '& [F:BAL]FCY<>""'

Case TYPBAL
 When 1
  FILBAL -= '& [F:BAL]BPR=""'
  If J
   If RACDEB<>"" : FILBAL -= '& [F:BAL]ACC>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILBAL -= '& [F:BAL]ACC<"'+RACFIN+'"'  : Endif
   FILBAL -= '& pat([F:BAL]ACC,"'+[M:BAF1]STRFLT+'")<>0'
  Elsif [M:BAF1]STRFLT<>""
   FILBAL -= '& [F:BAL]ACC>="'+[M:BAF1]STRFLT+'"'
  Endif
 When 2
  FILBAL -= '& [F:BAL]BPR<>""'
  FILBAL -= '& [F:BAL]ACC="'+COLL+'"'
  If J
   FILBAL -= '& pat([F:BAL]BPR,"'+[M:BAF1]STRFLT+'")<>0'
   If RACDEB<>"" : FILBAL -= '& [F:BAL]BPR>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILBAL -= '& [F:BAL]BPR<"'+RACFIN+'"' : Endif
  Elsif [M:BAF1]STRFLT<>""
   FILBAL -= '& [F:BAL]BPR>="'+[M:BAF1]STRFLT+'"'
  Endif
Endcase

If SACCRR=[M:BAF1]SAC & CPTCRR=[M:BAF1]STRFLT
 Case CHGPAG
  When 3 : # Refresh
   Case TYPBAL
    When 1 : FILBAL -= '& [F:BAL]ACC>="'+STRFLT+'"'
    When 2 : FILBAL -= '& [F:BAL]BPR>="'+STRFLT+'"'
   Endcase

  When 2 : # Next
   # EXPLI var of GCONSULT telling us if Export CSV or Export Excel. In this case
   # we don't make the pagination.
   Case TYPBAL
    When 1 :
     If !EXPCLI
      FILBAL -= '& [F:BAL]ACC>="'+ENDFLT+'"'
     Else
      FILBAL -= '& ([F:BAL]ACC>"'+ENDFLT+'" or ([F:BAL]ACC="'+ENDFLT+'" and CUR>"'+KEEPCUR+'"))'
     Endif
    When 2 :
     If !EXPCLI
      FILBAL -= '& [F:BAL]BPR>="'+ENDFLT+'"'
     Else
      FILBAL -= '& ([F:BAL]BPR>"'+ENDFLT+'" or ([F:BAL]BPR="'+ENDFLT+'" and CUR>"'+KEEPCUR+'"))'
     Endif
   Endcase
  When -2 : # Back
   Case TYPBAL
    When 1 : FILBAL -= '& [F:BAL]ACC<="'+STRFLT+'"'
    When 2 : FILBAL -= '& [F:BAL]BPR<="'+STRFLT+'"'
   Endcase
 Endcase
Endif

Return

#######################################################################################
$ERRCUR
Local Integer OK
If GMESSAGE=""
 #No Exchange Rate - CURLED => (Menu 202 : Exhange rate type)- date
 GMESSAGE=mess(4,109,1)-[M:BAF1]CURLED-"=>"-[M:BAF1]CNVCUR
&          -"("+mess(EXRATE,202,1)-format$("D:"+GFMDAT,datesyst)+")"
 Call ERREUR (GMESSAGE) From GESECRAN
Endif
Return

#######################################################################################
$LISTE1
If [M:BAF1]SAC<>""
 RPTCOD="BALGRPDEVAUX"
Else
 RPTCOD="BALGRPDEV"
Endif
Return

$LISTE2
[M:BAF1]CSTR = ""
[M:BAF1]CEND = "ZZZ"
If [M:BAF1]STRFLT<>""
 J = instr(1,[M:BAF1]STRFLT,"*")
 K = instr(1,[M:BAF1]STRFLT,"?")
 If     J & K : J = min(J,K)
 Elsif !J & K : J = K
 Endif
 If J
  [M:BAF1]CSTR = left$([M:BAF1]STRFLT,J-1)
  If [M:BAF1]CSTR<>""
   [M:BAF1]CEND = [M:BAF1]CSTR+"ZZZ"
  Endif
 Endif
Endif
Call LECTURE("CPY",[M:BAF1]CPY,"") From CONTOBJ
GRP=([F:CPY]CPYLEGFLG=1)
If [M:BAF1]CNVCUR<>""
 DEVLEC = [M:BAF1]CNVCUR
Else
 DEVLEC = [M:BAF1]CURLED
Endif

Raz J
J += 1 : TBPAR(J) = "devimp" : TBVAL(J) = DEVLEC : # Devise

Return

#######################################################################################
$APRES_MODIF
If COUZON="NBLIG"
 Call LECTURE("GAC",[M]ACC(nolign-1),[M:BAF1]COA) From CONTOBJ
 If [F:GAC]SAC=2
  [M:BAF1]SAC   = [F:GAC]ACCSHO
  [M:BAF1]STRFLT = ""
  CHGPAG=1
  Default [L]
  Gosub LECTURE From GCONSULT
  Gosub SETBOUT From GCONSULT
  Affzo
 Endif
Endif
Return


##################################################################################################
##                                                                                              ##
##  Tag of followings masks : CONSBAF1 & CRITBAF & CONSBAF2                                         ##
##                                                                                              ##
##################################################################################################

Subprog C_CPY(VALEUR)
Variable Char VALEUR()
Local Char    ZZRACDEB(GLONGAC)
Call C_CPY(VALEUR) From CONSSUB
## Si on a saisi un regroupement de sites, on contrôle qu'on ait accès à tous les sites du regroupement
Call LEC_CPY(VALEUR) From CPTLEC
If [F:CPY]CPYLEGFLG<>2
 Call CONTALLFCY(VALEUR) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CONSSUB
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CONSSUB
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer OPTION
OPTION=1 : # General Ledger
Call LEDTYP_CHOICE([M]CPY,OPTION) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Call C_LEDTYP(VALEUR) From CONSSUB
End

Subprog AS_DATDEB(VALEUR)
Variable Date    VALEUR
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Call C_DATDEB(VALEUR) From CONSSUB
If mkstat : End : Endif
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2
 Filter [PER] Where CPY=[F:CPY]CPY & LEDTYP=[M]LEDTYP & PERSTR<=VALEUR
 Read [PER]PER0 Last
 Filter [PER]
 If fstat<=2
  VALEUR = [F:PER]PERSTR
 Endif
Else
Endif
End

Subprog AS_DATFIN(VALEUR)
Variable Date    VALEUR
Call C_DATFIN(VALEUR) From CONSSUB
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Call C_DATFIN(VALEUR) From CONSSUB
If mkstat : End : Endif
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2
 Filter [PER] Where CPY=[F:CPY]CPY & LEDTYP=[M]LEDTYP & PEREND>=VALEUR
 Read [PER]PER0 First
 Filter [PER]
 If fstat<=2
  VALEUR = [F:PER]PEREND
 Endif
Else
Endif
End

Subprog C_SAC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [GAC]GAC1 = [M:BAF1]COA;VALEUR
 If [F:GAC]ACS<>""
  Local Integer DROIT
  Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
  If !DROIT
   # You do not have the rights for this code
   GMESSAGE = mess(4,104,1)
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog C_STRFLT(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Local Integer I
Local Char    LISTE(50)
LISTE = "ABCDEFGHIJKLMNOPQRSTUVWXYZ*?0123456789."
For I=1 To len(VALEUR)
 If !instr(1,LISTE,mid$(VALEUR,I,1))
  mkstat = 1 : Break
 Endif
Next I
Read [GAC]GAC0 = [M:BAF1]COA;VALEUR
If !fstat & [F:GAC]ACS<>""
  Local Integer DROIT
  Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
  If !DROIT
   # You do not have the rights for this code
   GMESSAGE = mess(4,104,1)
   mkstat = 2 : End
  Endif
Endif
End

Subprog IB_STRFLT
Raz GBOUT1, GBOUT2
If [M]SAC=""
 GBOUT1 = mess(8,31,1)   # Selection
Else
 GBOUT2 = mess(8,31,1)   # Selection
Endif
End

Subprog IB_NBLIG
Raz GBOUT1, GBOUT2
If nolign-1>=[M]NBLIG : End : Endif
If !GTUNCPT(1)
 If [M:BAF1]SAC<>""
  GBOUT1 = mess(25,109,1)   # Account
 Else
  Call LECTURE("GAC",[M:BAF2]ACC(nolign-1),[M:BAF1]COA) From CONTOBJ
  If [F:GAC]SAC<>2
   GBOUT1 = mess(25,109,1)  # Account
  Else
   GBOUT2 = mess(25,109,1)  # Account
  Endif
 Endif
Endif
End

Subprog B2_NBLIG
Call LECTURE("GAC",[M:BAF2]ACC(nolign-1),[M:BAF1]COA) From CONTOBJ
If [F:GAC]SAC=2
 mkstat = 4
Endif
End

Subprog C_CNVCUR(VALEUR)
Variable Char    VALEUR()
End

######################################################################################

