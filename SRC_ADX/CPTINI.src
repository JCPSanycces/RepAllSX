#######################################################################################################
# INIACC : compte par défaut d'autre plan de compte
# INICCE : initialisation section analytique d'un axe
# AROQTE : renvoir la quantité arrondie par rapport à l'UO
#######################################################################################################

###########################################################################################################
## Renvoie le compte par défaut/crible compte d'un autre plan de compte (par exemple pour initialiser le compte
## IAS ou le compte analytique à partir du compte social)
Subprog INIACC(COAORG,ACCORG,COADES,ACCDES,SCRACCDES)
Value    Char COAORG()    : # Plan compte origine
Value    Char ACCORG()    : # Compte origine
Value    Char COADES()    : # Plan compte destination
Variable Char ACCDES()    : # Compte destination
Variable Char SCRACCDES() : # Crible compte destination
Local Integer VU
If COADES="" : End : Endif
If COAORG = COADES
 ACCDES = ACCORG
Endif
Call LECTURE("GAC",ACCORG,COAORG) From CONTOBJ
VU = find(COADES,[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
If VU
 ACCDES    = [F:GAC]DEFACC(VU-1)
 SCRACCDES = [F:GAC]SCRACC(VU-1)
Endif
End


###########################################################################################################
Subprog INICCE(VALEUR,DIE,LED,ACC,SECDEF)
Variable Char VALEUR : # Code section
Value    Char DIE    : # Code axe
Value    Char LED    : # Code référentiel
Value    Char ACC    : # Compte
Value    Char SECDEF : # Code section par défaut
If !clalev([F:GAC]) : Local File =GTABCPT+"GACCOUNT" [GAC] : Endif
Local Integer I, J
Local Integer IND,AXI : Raz IND, AXI
Local Libelle SUIVI
If VALEUR<>"" | [L]ACC="" : End : Endif
#--- Recherche des indices pour variables globales
#--- Indice du référentiel et existence de l'axe 
Call INDLED([L]LED,[L]DIE,IND,AXI) From CPTDIV
If !IND or !AXI : End : Endif
Call LECTURE("GAC",[L]ACC,GLEDCOA(IND)) From CONTOBJ
#--- Axe est il suivi...
SUIVI = find([L]DIE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
If !SUIVI : End : Endif
Call INISEC(VALEUR,SECDEF,DIE) From SUBCDE
If VALEUR = ""
 #--- Section par défaut défini dans le compte (qui est forcément suivi analytique)
 VALEUR = [F:GAC]CCEDEF(SUIVI-1)
Endif
End

#########################################
Subprog AROQTE(VALEUR,UOM)
Variable Decimal VALEUR
Value Char       UOM
Local Decimal    ARRO
Call LECTURE("TUN",UOM,"") From CONTOBJ
If fstat
 ARRO = 1
Elsif [F:TUN]UOMDEC=0
 ARRO = 1
Else
 ARRO = val("0."+string$([F:TUN]UOMDEC-1,"0")+"1")
Endif
VALEUR = arr(VALEUR,ARRO)
End

