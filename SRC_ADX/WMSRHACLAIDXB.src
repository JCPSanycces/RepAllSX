$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 50499: RES='Index des classes'
   When 48728: RES='Code classe'
   When 8: RES='Intitulé'
   When 4: RES='Code activité'
  Endcase
 When "ENG":
  Case _ID
   When 50499: RES='Class index'
   When 48728: RES='Class code'
   When 8: RES='Description'
   When 4: RES='Activity code'
  Endcase
 When "ITA":
  Case _ID
   When 50499: RES='Indice classi'
   When 48728: RES='Codice classe'
   When 8: RES='Descrizione'
   When 4: RES='Codice attività'
  Endcase
 When "POR":
  Case _ID
   When 50499: RES='Index das classes'
   When 48728: RES='Cód. Classe'
   When 8: RES='Descr.'
   When 4: RES='Cód. activ.'
  Endcase
 When "SPA":
  Case _ID
   When 50499: RES='Índice clases'
   When 48728: RES='Código clase'
   When 8: RES='Descripción'
   When 4: RES='Código actividad'
  Endcase
 When "BRI":
  Case _ID
   When 50499: RES='Class index'
   When 48728: RES='Class code'
   When 8: RES='Description'
   When 4: RES='Activity code'
  Endcase
 When "GER":
  Case _ID
   When 50499: RES='Index Klassen'
   When 48728: RES='Klassencode'
   When 8: RES='Bezeichnung'
   When 4: RES='Aktivitätscode'
  Endcase
 When "POL":
  Case _ID
   When 50499: RES='Indeks klasy'
   When 48728: RES='Kod klasy'
   When 8: RES='Opis'
   When 4: RES='Kod działań'
  Endcase
 When "CHI":
  Case _ID
   When 50499: RES='类索引'
   When 48728: RES='类代码'
   When 8: RES='标题'
   When 4: RES='业务代码'
  Endcase
 When "ARB":
  Case _ID
   When 50499: RES='مؤشر الفئات'
   When 48728: RES='رمز الطبقة'
   When 8: RES='العنوان'
   When 4: RES='رمز النشاط'
  Endcase
Endcase
Return
#---------------------------------------------------------------------------------------------------#
