#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque JOT2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:15"
A_USER  = "DOC"
A_STAMP = "20181109230515"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRDIC"
  If [M]NBRDIC=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask JOT2 [JOT2]
Gosub HORODAT
Local Inpbox "JOT2" From GFONCTION At A_STAMP With A_WINDPREV Mask [JOT2] As [SIM_]
Grizo [JOT2]5
Grizo [JOT2]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [JOT2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=80 : Y1(0)=1 : Y2(0)=22
X1(1)=1 : X2(1)=80 : Y1(1)=23 : Y2(1)=24
Return

$ON_NBRDIC
Onevent BEFORE_INPUT Call AS_NBRDIC From W1JOT2
Return

Subprog AS_NBRDIC
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(13751,GBOUT1) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NBRDIC From W1JOT2
Gosub _AFF
End

Subprog B1_NBRDIC
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B1_NBRDIC From SUBJOT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_FLD
Onevent CONTROL Call C_FLD(zc) From W1JOT2
Onevent BEFORE_INPUT Call AS_FLD(zc) From W1JOT2
Return

Subprog AS_FLD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44944,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_FLD(zc) From W1JOT2
Onkey   2 Titled GBOUTS Call S_FLD(zc) From W1JOT2
Gosub _AFF
End

Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_FLD(VALEUR) From SUBJOT
If mkstat : GERR = 1 : GZONE = "FLD" : GZNUM = 1261 : Endif
Gosub _AFF
End

Subprog S_FLD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call S_FLD(VALEUR) From SUBJOT
Endif
Gosub _AFF
End

Subprog B1_FLD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action GOBJET1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJET1"
 Call OBJET_CHAR(VALEUR,"DIC",VALEUR) From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

