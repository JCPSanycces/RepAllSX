Subprog AS_CLLCVT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44763,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRCLV
Call DEFHRCLV(VALEUR,GCURLEG,GSOCIETE) From SUBHRCLV
If mkstat=2
 [M]CLLCVT(INDIC) = VALEUR
 Affzo CLLCVT(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action STD
 Call AS_CLLCVT(VALEUR) From SUBJOT
 If mkstat=2
  [M]CLLCVT(INDIC) = VALEUR
  Affzo CLLCVT(INDIC) : mkstat = 2
 Endif
 Onkey 129 Titled GBOUT1 Call B1_CLLCVT(zc) From W1JOT2
 Onkey   2 Titled GBOUTS Call S_CLLCVT(zc) From W1JOT2
 Onkey 144 Titled GBOUTP Call P_CLLCVT(zc) From W1JOT2
 Onkey 146 Titled GBOUTA Call SA_CLLCVT(zc) From W1JOT2
Endif
Gosub _AFF
End

Subprog C_CLLCVT(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CLLCVT" : GZNUM = 44763 : Endif
If !mkstat
 ## Action CONTHRCLV
 Call CONTHRCLV(VALEUR,GCURLEG,GSOCIETE) From SUBHRCLV
 If mkstat : GERR = 1 : GZONE = "CLLCVT" : GZNUM = 44763 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CLLCVT" : GZNUM = 44763 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_CLLCVT(VALEUR)
