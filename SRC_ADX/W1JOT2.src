$ON_VALDEF
Onevent BEFORE_INPUT Call AS_VALDEF(zc) From W1JOT2
Onevent CONTROL Call C_VALDEF(zc) From W1JOT2
Onevent AFTER_AREA Call AP_VALDEF(zc) From W1JOT2
Return

Subprog IB_VALDEF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTBOUT
 Call BOUTSEL(VALEUR,[M:JOT2]CODTYP(nolign-1),[M:JOT2]NOLIB(nolign-1),"") From FMTVAR
Endif
Gosub _AFF
End

Subprog AS_VALDEF(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(877,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_VALDEF(VALEUR)
## Action AFMTSAI
Call ASAISIE(VALEUR,[M:JOT2]CODTYP(nolign-1)) From FMTVAR
If mkstat=2
 [M]VALDEF(INDIC) = VALEUR
 Affzo VALDEF(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action STD
 Call AS_VALDEF(VALEUR) From SUBJOT
 If mkstat=2
  [M]VALDEF(INDIC) = VALEUR
  Affzo VALDEF(INDIC) : mkstat = 2
 Endif
 Onkey 129 Titled GBOUT1 Call B1_VALDEF(zc) From W1JOT2
 Onkey   2 Titled GBOUTS Call S_VALDEF(zc) From W1JOT2
Endif
Gosub _AFF
End

Subprog C_VALDEF(VALEUR)
Variable Char    VALEUR()
## Action AFMTCONT
Call CONTROLE(VALEUR,[M:JOT2]CODTYP(nolign-1),[M:JOT2]NOLIB(nolign-1),[M:JOT2]LONG(nolign-1),[M:JOT2]VALINT(nolign-1)) From FMTVAR
If mkstat : GERR = 1 : GZONE = "VALDEF" : GZNUM = 88 : Endif
If !mkstat
 ## Action ACONTACL
 Call CONTACL([M:JOT2]VALINT(nolign-1),[M:JOT2]CODTYP(nolign-1),"","") From SUBACL
 If mkstat : GERR = 1 : GZONE = "VALDEF" : GZNUM = 88 : Endif
 If !mkstat
  ## Action STD
  Call C_VALDEF(VALEUR) From SUBJOT
  If mkstat : GERR = 1 : GZONE = "VALDEF" : GZNUM = 88 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog AP_VALDEF(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AP_VALDEF(VALEUR) From SUBJOT
If mkstat : GERR = 1 : GZONE = "VALDEF" : GZNUM = 88 : Endif
Gosub _AFF
End

Subprog S_VALDEF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = [M:JOT2]CODTYP(nolign-1)
 PARMSK(2) = num$([M:JOT2]NOLIB(nolign-1))
 PARMSK(3) = num$([M:JOT2]LONG(nolign-1))
 PARMSK(4) = [M:JOT2]VALINT(nolign-1)
 PARMSK(5) = [M:JOT2]VALPAR(nolign-1)
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M:JOT2]VALINT(nolign-1) = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = [M:JOT2]CODTYP(nolign-1)
 PARMSK(2) = num$([M:JOT2]NOLIB(nolign-1))
 PARMSK(3) = num$([M:JOT2]LONG(nolign-1))
 PARMSK(4) = [M:JOT2]VALINT(nolign-1)
 PARMSK(5) = [M:JOT2]VALPAR(nolign-1)
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M:JOT2]VALINT(nolign-1) = PARMSK(4)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_VALDEF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTB1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTB1"
 PARMSK(1) = [M:JOT2]CODTYP(nolign-1)
 PARMSK(2) = [M:JOT2]VALPAR(nolign-1)
 PARMSK(3) = num$([M:JOT2]NOLIB(nolign-1))
 PARMSK(4) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFMTB1","FMTVAR","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_EMPMDL
Onevent CONTROL Call C_EMPMDL(zc) From W1JOT2
Onevent AFTER_CHANGE Gosub AMM_EMPMDL From W1JOT2
Onevent BEFORE_INPUT Call AS_EMPMDL(zc) From W1JOT2
Return

Subprog AS_EMPMDL(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44843,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_EMPMDL(zc) From W1JOT2
Onkey   2 Titled GBOUTS Call S_EMPMDL(zc) From W1JOT2
Onkey 144 Titled GBOUTP Call P_EMPMDL(zc) From W1JOT2
Onkey 146 Titled GBOUTA Call SA_EMPMDL(zc) From W1JOT2
Gosub _AFF
End

Subprog C_EMPMDL(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTEMP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTEMP"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 PARMSK(6) = GCURLEG
 Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "EMPMDL" : GZNUM = 47669 : Endif
Endif
If !mkstat
 ## Action DROITEMP
 Call DROIT(VALEUR,"","","") From DIVPAYE
 If mkstat : GERR = 1 : GZONE = "EMPMDL" : GZNUM = 47669 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("EML","!",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "EMPMDL" : GZNUM = 47669 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_EMPMDL
Call AM_EMPMDL(zc)
If !mkstat & GOBJET
 zoncou = "EMPMDL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_EMPMDL(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_EMPMDL(VALEUR) From SUBJOT
If mkstat : GERR = 1 : GZONE = "EMPMDL" : GZNUM = 47669 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZEMPMDL)")>indice
 [M]EMPMDL(indice) = VALEUR
 Affzo ZEMPMDL(indice)
Endif
Gosub _AFF
End

Subprog S_EMPMDL(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMLLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMLLEG"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_EMPMDL" : PROGSUB = "SUBJOT" : PROGSPE = "SPEJOT2" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = GCURLEG
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELEMLLEG","TOOLSHRLEG","") From GACTION
 ACTION = "BS_EMPMDL" : PROGSUB = "SUBJOT" : PROGSPE = "SPEJOT2" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_EMPMDL(VALEUR)
Variable Char    VALEUR()
Call OBJET("EML",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_EMPMDL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EML"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_EMPMDL(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("EML",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZEMPMDL
Onevent BEFORE_AREA Gosub AV_ZEMPMDL From W1JOT2
Return

$AV_ZEMPMDL
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Call LECTURE("EML",num$([M]EMPMDL(indice)),"") From CONTOBJ
zc = [F:ID]NAM
Gosub _AFF
Return

$CHG_STY
Return


