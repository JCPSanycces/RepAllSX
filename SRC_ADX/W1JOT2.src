$ON_LEV
Onevent BEFORE_INPUT Call AS_LEV(zc) From W1JOT2
Onevent CONTROL Call C_LEV(zc) From W1JOT2
Onevent INIT_AREA Call D_LEV(zc) From W1JOT2
Return

Subprog D_LEV(VALEUR)
Variable Integer VALEUR
If varinit([M]LEV,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_LEV(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10508) From COMBOS
## Action STD
Call AS_LEV(VALEUR) From SUBJOT
If mkstat=2
 [M]LEV(INDIC) = VALEUR
 Affzo LEV(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10508,1))))
Endif
If !mkstat
 Discombo 0 From LEV(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From LEV(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_LEV(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
## Action STD
Call C_LEV(VALEUR) From SUBJOT
If mkstat : GERR = 1 : GZONE = "LEV" : GZNUM = 5230 : Endif
Gosub _AFF
End

$ON_LEGLEV
Onevent INIT_AREA Call D_LEGLEV(zc) From W1JOT2
Onevent CONTROL Call C_LEGLEV(zc) From W1JOT2
Onevent BEFORE_INPUT Call AS_LEGLEV(zc) From W1JOT2
Return

Subprog D_LEGLEV(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEGLEV,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_LEGLEV(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"909") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_LEGLEV(VALEUR) From SUBJOT
If mkstat=2
 [M]LEGLEV(INDIC) = VALEUR
 Affzo LEGLEV(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_LEGLEV(zc) From W1JOT2
Onkey   2 Titled GBOUTS Call S_LEGLEV(zc) From W1JOT2
Onkey 144 Titled GBOUTP Call P_LEGLEV(zc) From W1JOT2
Onkey 146 Titled GBOUTA Call SA_LEGLEV(zc) From W1JOT2
If VALEUR="" : Call INIADI(VALEUR,"909") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_LEGLEV(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LEGLEV" : GZNUM = 26213 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"909","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "LEGLEV" : GZNUM = 26213 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"909",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "LEGLEV" : GZNUM = 26213 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_LEGLEV(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "909"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_LEGLEV(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"909") From GOBJET
Gosub _AFF
End

Subprog SA_LEGLEV(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "909"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_LEGLEV(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "909"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

