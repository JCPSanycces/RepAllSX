#<AdxTL>@(#)3.0.0.0 $Revision$
####################################################################################
# Program Name: MANHLDREL
####################################################################################

$ACTION

Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "OK"            : Gosub OK
  When "AVANT_OK"      : Gosub AVANT_OK
Endcase

Return

####################################################################################
$OUVRE

If !clalev([F:SOH])  : Local File SORDER     [F:SOH]  : Endif
If !clalev([F:ADI])  : Local File ATABDIV    [F:ADI]  : Endif

Read [SOH]SOH0=PARAM(1)
If fstat
  Call ERREUR(mess(8,492,1) - PARAM(1)) From GESECRAN
  FIN = 1 : Return
Endif

Return

####################################################################################
$ORD_HLD
Local Char VALBOUT(250) , PARM(250)(1..20)
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE

If !clalev([M:SHR])  : Local Mask MANHLDREL    [SHR]  : Endif

Raz [M:SHR]

If [F:SOH]HLDSTA<=1 # Order on hold
  Default Mask [SHR]
  Grizo [M:SHR]HLDCOD
  [M:SHR]HLDCOD = [F:SOH]HLDCOD
  SAVACT = GACTION
  PARM(1) = [M:SOH0]SOHNUM
  FLGEXE = 1
  GACTION = "MANHLDREL"
  Call TRAITE_CHAR(VALBOUT,PARM,"","MANHLDREL","MANHLDREL",4,"XYMANHLDREL") From GTRAITE
  GACTION = SAVACT
  Actzo [M:SHR]1-99
  Gosub MANHLD_LIENS From MANHLDLIB
Endif

Return

####################################################################################
$AVANT_OK

If [M:SHR]HLDCOD=""
  GERR = 1
  GMESSAGE = mess(2,492,1)  # Invalid hold code
  FOK = 0
  FIN = 0
  Return
Endif

Return

####################################################################################
$OK
Local Integer RET
Local Char MESSAGE(200)

Call ORDERHOLD([F:SOH]SOHNUM,[M:SHR]HLDCOD,RET,MESSAGE) From MANHLDLIB
If RET : Call ERREUR(MESSAGE) From GESECRAN : Return : Endif

Return

####################################################################################
Subprog HLDREL_BTN(SOHNUM)
Value    Char    SOHNUM
Local Integer ERR, OK

If !clalev([F:ADI])  : Local File ATABDIV    [F:ADI]  : Endif

If [M:SOH1]HLDCOD<>""
 Read [ADI]CODE=204;[M:SOH1]HLDCOD
 If fstat
  GMESSAGE = mess(2,492,1) - [M:SOH1]HLDCOD # Invalid hold code
  GERR = 1 : End
 Endif
Endif

If [M:SOH1]HLDSTA<2
 # Not on Hold; call ORD_HLD routine
 Gosub ORD_HLD
Else
 # Already on Hold - simply release with pop-up.
 If [F:ADI]A1<>"" & GUSRACS<>2 & GUSER<>[F:SOH]HLDUSR # access code check
  Read [ACC]CODACC=GUSER;[F:ADI]A1
  If fstat
  Call ERREUR(mess(22,492,1)) From GESECRAN
  End
 Endif
Endif

#X3-46260.sn - JOBRO - make sure the table has the same order that is on the screen
If [M:SOH0]SOHNUM <> [F:SOH]SOHNUM
  Read [F:SOH]SOH0=[M:SOH0]SOHNUM
  If fstat or [M:SOH0]SOHNUM=""
    GMESSAGE = mess(8,492,1) - [M:SOH0]SOHNUM # unble to read sales order
    GERR = 1
    End
  Endif
Endif
#X3-46260.en

Call OUINON(mess(12,492,1)-[M:SOH1]HLDCOD-"?",OK) From GESECRAN
If OK<>2 : End : Endif

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [SOH] : Endif
If [F:SOH]HLDCOD<>""
 [F:SOH]HLDCODP = [F:SOH]HLDCOD
 [F:SOH]HLDUSRP = [F:SOH]HLDUSR
 [F:SOH]HLDDATP = [F:SOH]HLDDAT
 [F:SOH]HLDTIMP = [F:SOH]HLDTIM
 [F:SOH]HLDDAT  = date$ # to capture release date
 [F:SOH]HLDTIM  = time$ # to capture release time
 [F:SOH]HLDUSR  = GUSER # to capture release user
Endif
Raz [F:SOH]HLDCOD  # blank
[F:SOH]HLDSTA = 1  # OK
Rewrite [SOH]
If fstat
 If !TMP_ADXLOG : Rollback : Endif
 ERR = 1
 ERRMSG =  mess(1,492,1) # Unable to update hold status
 Call ERREUR(ERRMSG) From GESECRAN
 End
Else
 If !TMP_ADXLOG : Commit : Endif
 Raz [M:SOH1]HLDCOD  # blank
 [M:SOH1]HLDSTA = 1  # OK
 Affzo [M:SOH1]HLDCOD,HLDSTA
Endif
Gosub MANHLD_LIENS From MANHLDLIB
Endif

End

