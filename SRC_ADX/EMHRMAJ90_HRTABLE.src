#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# EMHRMAJ90_HRTABLE UTI process                                 PAY Module
#                   Migration To U12 - Vnext version
#
# ==>  Copy data from tables to new HR named tables
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

  If WDOSSIER <> ""
    Infbox WDOSSIER
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

    # Check Payroll Module
    If [F:ADS]MODULE(14)<>2 : End : Endif

    Call OUVRE_TRACE("Copy data from tables to new HR named tables") From LECFIC

    Call MAJ_EMHRMAJ90_HRTABLE(WDOSSIER)

    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif

  Close Local File
End

Subprog MAJ_EMHRMAJ90_HRTABLE(LDOSSIER)
Value Char LDOSSIER

  Onerrgo CYCLECHECKERROR

  Local Char OLDTABLES(GLONATB)(1..)
  Local Char NEWTABLES(GLONATB)(1..)
  Local Integer I, NBRTAB

  Call ECR_TRACE("EMHRMAJ90_HRTABLE: Copy data from tables to new HR named tables",0) From GESECRAN
  Call ECR_TRACE("EMHRMAJ90_HRTABLE: Start of process on : "+LDOSSIER,0) From GESECRAN

  Call ECR_TRACE("EMHRMAJ90_HRTABLE: Defining tables to be updated",0) From GESECRAN
  Gosub DEFINE_TABLES

  Call ECR_TRACE("EMHRMAJ90_HRTABLE: Copying table data",0) From GESECRAN
  Gosub COPY_TABLES

End

$CYCLECHECKERROR
  Call ECR_TRACE("Error in EMHRMAJ90_HRTABLE: " + num$(errn)-errmes$(errn)-errm, -1) From GESECRAN
Resume

$DEFINE_TABLES

  I  = 0
  I += 1 : OLDTABLES(I) = "WHREXPENSES"  : NEWTABLES(I) = "HREXPENSES"
  I += 1 : OLDTABLES(I) = "WHREXSKMETRE" : NEWTABLES(I) = "HREXSKMETRE"
  I += 1 : OLDTABLES(I) = "WHRFILTDS"    : NEWTABLES(I) = "HRFILTDS"
  I += 1 : OLDTABLES(I) = "WHRFRMPAY"    : NEWTABLES(I) = "HRFRMPAY"
  I += 1 : OLDTABLES(I) = "WHRPARVAREXP" : NEWTABLES(I) = "HRPARVAREXP"
  I += 1 : OLDTABLES(I) = "WHRPAYTMP"    : NEWTABLES(I) = "HRPAYTMP"
  I += 1 : OLDTABLES(I) = "WHRTABEXPENS" : NEWTABLES(I) = "HRTABEXPENS"
  I += 1 : OLDTABLES(I) = "WHRTABFILBAN" : NEWTABLES(I) = "HRTABFILBAN"

  [L]NBRTAB = I
Return

$COPY_TABLES

  For I = 1 To [L]NBRTAB
    Call ECR_TRACE("EMHRMAJ90_HRTABLE: Copy data from"+ OLDTABLES(I) +" to table "+ NEWTABLES(I),0) From GESECRAN
    If !clalev([F:WWWW_N]): Local File = LDOSSIER+"."+NEWTABLES(I) [F:WWWW_N] : Endif
    If !clalev([F:WWWW_O]): Local File = LDOSSIER+"."+OLDTABLES(I) [F:WWWW_O] : Endif

    For [F:WWWW_O]
      [F:WWWW_N] = [F:WWWW_O]
      Write [F:WWWW_N]
      Call ECR_TRACE("Row result = " - num$(fstat),0) From GESECRAN
    Next

    Close Local File [F:WWWW_N], [F:WWWW_O]
  Next

Return

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call MAJ_EMHRMAJ90_HRTABLE(APPLI)
End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call MAJ_EMHRMAJ90_HRTABLE(APPLI)
End

