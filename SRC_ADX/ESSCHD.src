#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "OK"          : Gosub OK
Endcase
Return

$OUVRE
Local Char GLOBEML(GLONEML)
Global Integer GLOBILINE

#Disabling the classic CUD operation - Hybrid development (ANOWRITE)
ANOWRITE = 1

#Read the data from the class and transfer to the mask (Default Values)
Global Instance I_ESSCHDEMP Using C_ESSCHDEMP

GLOBEML=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
GCURLEG = func DIVPAYE_SOA.GET_LEG_EMP(GLOBEML, 1) #Site level

#Manage Localisations
Call MANAGE_LOCALISATION("ESSCHD") From DIVPAYE
Return


$DEBUT
Local Char EMPCODE (GLONEML)
EMPCODE=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
[M:ESCHD]REFNUM = EMPCODE

#Filter child table on EMCODE
Gosub CHARGE_ALL

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSCHDHIDE
Call SHOW_LEGACTCALLS From WESSCHDSHOW

Return


$OK
Local Integer WORKFLOWTRIGGER
Local Integer NI,MY_STATUS
Local Integer WRKFLOW_STAT_CHD
Local Integer WRKFLOW_STAT_CHDOK
[L]WRKFLOW_STAT_CHD     = [V]CST_ANOTDEFINED
[L]WRKFLOW_STAT_CHDOK   = [V]CST_ANOTDEFINED

#Trigger workflow
If I_ESSCHDEMP.ESSCHD <> null
  For NI = 1 To maxtab(I_ESSCHDEMP.ESSCHD)
    If I_ESSCHDEMP.ESSCHD(NI) <> null Then
      [L]WRKFLOW_STAT_CHD = fmet I_ESSCHDEMP.ESSCHD(NI).EMP_WRKREQ(I_ESSCHDEMP.REFNUM,"EMPLOCHD","ESSCHD",I_ESSCHDEMP.ESSCHD(NI).TCH_CHDSTA,"EMPLOCHD","CHD")
      If [L]WRKFLOW_STAT_CHD <> [V]CST_AOK and [L]WRKFLOW_STAT_CHD <> [V]CST_ANOTDEFINED
        Call RECOVERS_ERROR_IN_CLASSIC(I_ESSCHDEMP.ESSCHD(NI)) From ESS_WRKFLOW_FUNC_HYBRID
        If GMESSAGE = AVOID.ACHAR Then
          GMESSAGE = mess(0009,10727,1)
        Endif
        If [L]WRKFLOW_STAT_CHD <> [V]CST_AWARNING and [L]WRKFLOW_STAT_CHD <> [V]CST_AINFO Then
          OK=0
          Break
          Return
        Endif
      Else
       If [L]WRKFLOW_STAT_CHD = [V]CST_AOK
        [L]WRKFLOW_STAT_CHDOK = [V]CST_AOK
       Endif
      Endif
    Endif
  Next
Endif

If [L]WRKFLOW_STAT_CHDOK = [V]CST_ANOTDEFINED
  GMESSAGE = mess(0016,10727,1)
  GERR = 2
  Return
Endif

If GMESSAGE = AVOID.ACHAR Then
  GMESSAGE= mess(11,10727,1)
Else
  GMESSAGE= mess(11,10727,1)+":"-GMESSAGE
Endif
GERR = 2
Return

$CHARGE_ALL
Local Integer MY_STATUS

#-------------------------------Hybrid----------------------------------#
nolign = 0

I_ESSCHDEMP = NewInstance C_ESSCHDEMP AllocGroup null
[L]MY_STATUS = fmet I_ESSCHDEMP.AREAD(EMPCODE)
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_ESSCHDEMP) From ESS_WRKFLOW_FUNC_HYBRID
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    Return
  Endif
Endif
#Transfer class
Gosub SET_ALL

[M:ESCHD]NBRCHD = nolign

#-------------------------------Hybrid----------------------------------#
Affzo [M:ESCHD]1-99
Return

$SET_ALL
Local Integer NI
If I_ESSCHDEMP.ESSCHD <> null
  For NI = 1 To maxtab(I_ESSCHDEMP.ESSCHD)
    If I_ESSCHDEMP.ESSCHD(NI) <> null and find(I_ESSCHDEMP.ESSCHD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      #Populate the techical property
      I_ESSCHDEMP.ESSCHD(NI).TCH_CHDSTA = "T"
      SetInstance [M:ESCHD]10 With I_ESSCHDEMP.ESSCHD(NI)
    Endif
  Next
Endif
Return

Subprog UPDATE_ESSCHDEMP_ESSCHD(VNLINE)
Value Integer VNLINE
SetInstance [M:ESCHD]10 With I_ESSCHDEMP.ESSCHD(VNLINE)
Affzo [M:ESCHD]10

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSCHDHIDE
Call SHOW_LEGACTCALLS From WESSCHDSHOW
End

Subprog C_NBRCHD
Local Integer ILINE,IRET
If status = 82 or status = 73 Then
# Insert line
  ILINE = fmet I_ESSCHDEMP.ADDLINE("ESSCHD", [V]CST_ALASTPOS)
  If ILINE <> [V]CST_ANOTDEFINED Then
    Call AM_NUMLIG(ILINE)
    Call SHOW_ESSCHDEMP_ESSCHD(ILINE) From ESSCHD
    GLOBILINE = ILINE
  Else
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(I_ESSCHDEMP)
    GERR = 4
    mkstat = 2
    GOK = 1
    End
  Endif
  Affzo [M:ESCHD]10

  #Manage localisations
  Call HIDE_ACTIVITYFIELDS From WESSCHDHIDE
  Call SHOW_LEGACTCALLS From WESSCHDSHOW
Elsif status = 65 #or status = 71 Then
  If status = 65
    ILINE = [M:ESCHD]NUMLIG(nolign-1)
  Elsif status = 71
    ILINE = maxtab(I_ESSCHDEMP.ESSCHD)
  Endif
  # Delete a line
  IRET = fmet I_ESSCHDEMP.ADELLINE("ESSCHD", I_ESSCHDEMP.ESSCHD(ILINE).AORDER)
  If IRET = [V]CST_ANOTDEFINED Then
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(I_ESSCHDEMP)
    GOK = 0
    GERR = 1
    mkstat = 2
  Endif
Elsif status = 71 Then
  If GLOBILINE <> AVOID.AINT and [M:ESCHD]CHDNAM(nolign-1)=AVOID.ACHAR and [M:ESCHD]CHDSRN(nolign-1)=AVOID.ACHAR
    # Delete a line
    IRET = fmet I_ESSCHDEMP.ADELLINE("ESSCHD", I_ESSCHDEMP.ESSCHD(GLOBILINE).AORDER)
    Raz GLOBILINE
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(I_ESSCHDEMP)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
Endif
End

Subprog SHOW_ESSCHDEMP_ESSCHD(VNLINE)
Value Integer VNLINE

SetInstance [M:ESCHD]10 With I_ESSCHDEMP.ESSCHD(VNLINE)
[M:ESCHD]NUMLIG(nolign-1) = VNLINE   # Line index in the collection
End

Subprog AM_NUMLIG(VALEUR)
Variable Integer VALEUR
I_ESSCHDEMP.ESSCHD(VALEUR).NUMLIG = VALEUR
Call RECOVERS_ERROR_IN_CLASSIC(I_ESSCHDEMP.ESSCHD(VALEUR)) From ESS_WRKFLOW_FUNC_HYBRID
If GERR = 1 Then
  I_ESSCHDEMP.ESSCHD(VALEUR).NUMLIG = I_ESSCHDEMP.ESSCHD(VALEUR).snapshot.NUMLIG
  GERR = 1
  mkstat = 2
  End
Else
  Call UPDATE_ESSCHDEMP_ESSCHD(VALEUR)
Endif
End


Subprog AM_CHDNAM(VALEUR)
Variable Char    VALEUR()
I_ESSCHDEMP.ESSCHD([M:ESCHD]NUMLIG(nolign-1)).CHDNAM = VALEUR
Call RECOVERS_ERROR_IN_CLASSIC(I_ESSCHDEMP.ESSCHD([M:ESCHD]NUMLIG(nolign-1))) From ESS_WRKFLOW_FUNC_HYBRID
If GERR = 1 Then
  I_ESSCHDEMP.ESSCHD([M:ESCHD]NUMLIG(nolign-1)).CHDNAM = I_ESSCHDEMP.ESSCHD([M:ESCHD]NUMLIG(nolign-1)).snapshot.CHDNAM
  GERR = 1
  mkstat = 2
  End
Else
  Call UPDATE_ESSCHDEMP_ESSCHD([M:ESCHD]NUMLIG(nolign-1))
Endif
End

