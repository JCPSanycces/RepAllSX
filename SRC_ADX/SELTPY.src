#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(30)(1..5) , VALEUR(10)
Call S_TAB_CHAR(VALEUR,PARAM,"SELTPY","SELTPY","") From GACTION
End

#######################################################################
# Action SELTPY
#######################################################################
$ACTION
Case ACTION
 When "SEL_TABLE"
  Case TABLE
    When "SELTPY"    : Gosub SELTPY
  Endcase
Endcase
Return

$SELTPY

If clalev([F:TPY])=0  : Local File TABPAYTYP   [TPY] : Endif
If clalev([F:TPYS])=0 : Local File LEGTPYSEL  [TPYS] : Endif
If clalev([F:TPYG])=0 : Local File LEGTPYGFY  [TPYG] : Endif  # Vues
If clalev([F:TPYP])=0 : Local File LEGTPYPAR  [TPYP] : Endif  # Vues
If clalev([F:TPYY])=0 : Local File LEGTPYYGRP [TPYY] : Endif  # Vues
If clalev([F:TPYZ])=0 : Local File LEGTPYZGRP [TPYZ] : Endif  # Vues

If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif

Local Char FCY(GLONFCY)
Local Char CPY(GLONCPY)
Local Char LEG(GLONADI)
Local Char GRP(GLONAGC)

Local Char SAVE_FCY(GLONFCY) : SAVE_FCY=GCURFCY
Local Char SAVE_CPY(GLONCPY) : SAVE_CPY=GSOCIETE
Local Char SAVE_LEG(GLONADI) : SAVE_LEG=GCURLEG
Local Char SAVE_GRP(GLONAGC) : SAVE_GRP=GGRPFCY

#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------
If GFONCTION="ADPVAL" : # Saisie valeurs paramètres. Type de données = PCD
 FCY = [M:ADWP]FCY
 CPY = [M:ADWP]CMP
 If dim([M:ADWP]LEG)>0
  LEG = [M:ADWP]LEG
 Else
  LEG = GDOSLEG
 Endif
Elsif GFONCTION="GESAUS"
 Call PARAMUTIL("LEGFIL",LEG,[M:AUSP]USR,"") From SUBAUS
Elsif dim([M:RPT]ETAT)>0  #GACTION="AFMTSEL" : # = Sélection paramètres d'édition
 I = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
 If I
  CPY = [M:RPT]VALINT1(I-1)
  Call LEC_CPY(CPY) From CPTLEC
  LEG = [F:CPY]LEG
 Endif
#ISSUE 33455 – 2017-07-07 By MANOW
Elsif GFONCTION="GESBAN" and [M:BAN2]FCY = ""
  [L]CPY = [M:BAN2]CPY
Elsif GFONCTION="GESCAI" and [M:CAI1]FCY = ""
  [L]CPY = [M:CAI1]CPY
#ISSUE END
Elsif GFONCTION<>"GEXPOBJ"
 LEG    = PARAM(1)
 GRP    = PARAM(2)
 If GCURFCY  <>""  & [L]FCY="" : [L]FCY = GCURFCY  : Endif
 If GSOCIETE <>""  & [L]CPY="" : [L]CPY = GSOCIETE : Endif
 If GCURLEG  <>""  & [L]LEG="" : [L]LEG = GCURLEG  : Endif
 If GGRPFCY  <>""  & [L]GRP="" : [L]GRP = GGRPFCY  : Endif
Endif

# Initialisations diverses FCY/CPY/LEG & GCURFCY/GSOCIETE/GCURLEG
If [L]FCY<>""
 Call LEC_FCY([L]FCY) From CPTLEC
 Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
 [L]CPY = [F:CPY]CPY : GSOCIETE = [L]CPY
 [L]LEG = [F:CPY]LEG : GCURLEG  = [L]LEG
 [L]GRP = ""
Elsif [L]CPY<>""
 Call LEC_CPY([L]CPY) From CPTLEC
 [L]CPY = [F:CPY]CPY : GSOCIETE = [L]CPY
 [L]LEG = [F:CPY]LEG : GCURLEG  = [L]LEG
 [L]GRP = ""
Endif
# Si groupe de société (non société juridique) alors GCURLEG et LEG à vide pour que la sélection présente toutes les données.
If [L]CPY<>""
 Call LEC_CPY([L]CPY) From CPTLEC
 If [F:CPY]CPYLEGFLG<>2
  [L]LEG="" : GCURLEG="" : [L]GRP = [L]CPY : [L]CPY="" : [L]FCY="" #US227
 Endif
Endif

#--------------------------------------------------------------------------------------------------
# Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------

Gosub OUVRE_LISTE From WOTPY

For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I) = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I

NBCOL  = NBSEL
SIZCOL = 240
SIZLIG = 100
TIT(0) = mess(12,123,1)  # Choix
Call TITOBJ("TPY","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START  = "[F:TPY]PAYTYP"
ORDRE  = "[F:TPY]PAYTYP;[F:TPY]LEG"
OBJET  = ""


#--------------------------------------------------------------------------------------------------
# Critères pour la sélection standard
#--------------------------------------------------------------------------------------------------

## Critères de sélection
## Le link fait des liaisons "externes gauches"
## Toute la subtilité de la chose est de mettre des fonctions qui
## ne sont pas transmises à la base de données : len() , num$()
## sinon celle-ci ne renvoie rien du tout

CRITERE(1)  = '[F:TPY]ENAFLG=2'


#ISSUE 33455 – 2017-06-09  By MANOW
If [L]LEG<>""
  Case GFONCTION
    When "GESCAI"
      If(func AFNC.PARAM("BCREG", [M:CAI1]CPY) = "2")
        CRITERE(1) -= '& ([F:TPY]LEG="' + [L]LEG + '")'
      Endif
    When "GESBAN"
      If(func AFNC.PARAM("BCREG", [M:BAN2]CPY) = "2")
        CRITERE(1) -= '& ([F:TPY]LEG="' + [L]LEG + '")'
      Endif
    When Default
      CRITERE(1) -= '& ([F:TPY]LEG="' + [L]LEG + '" | [F:TPY]LEG="")'
  Endcase
Endif
#ISSUE END


If [L]FCY<>""
 CRITERE(1) -= '& ([F:TPY]GFY="" | ([F:TPY]GFY<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
Elsif [L]CPY<>""
 CRITERE(1) -= '& ([F:TPY]GFY="" | ([F:TPY]GFY<>"" & [F:TPYG]LEGCPY="'+[L]CPY+'"))'
Elsif [L]GRP<>""
 If [L]LEG<>""
  CRITERE(1) -= '& ([F:TPY]GFY="" | ([F:TPY]GFY<>"" & [F:TPYY]GRPORI="'+[L]GRP+'"))'
 Else
  CRITERE(1) -= '& ([F:TPY]GFY="" | ([F:TPY]GFY<>"" & [F:TPYZ]GRPORI="'+[L]GRP+'"))'
 Endif
Endif

CRITERE(1) -= '& (GUSRACS=2 | [F:TPY]ACS="" | num$([F:ACC]CONSUL)="2")'
If dim(SELCAR)>0 & SELCAR<>0
 CRITERE(1) -= '& left$([F:TPY]PAYTYP,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

ICRITERE = 2
Call FILROLE("TPY",FILROLE) From SUBARL
If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

#--------------------------------------------------------------------------------------------------
# Critères pour la sélection spécifique
#--------------------------------------------------------------------------------------------------

Case GFONCTION
 When "BANAFFA","BANAFFM" :
  CRITERE(2) -= "& [F:TPY]STA4=2"
  If dim([M]SNS)>=0 : CRITERE(2) += " & ([F:TPY]SNS=3 | [F:TPY]SNS="+num$([M]SNS)+")" : Endif
 When "EXPCASPAY" :
  CRITERE(2) -= "& [F:TPY]FLGCAS>1"
 When "FICMAG" :
  CRITERE(2) -= "& ([F:TPY]STA6=2 | [F:TPY]EPACDTTRF=2)"
 When "GENAVIDOM","GESPAB" :
  CRITERE(2) -= "& [F:TPY]STA7=2"
 When "GENBORREM","GESFRM" :
  CRITERE(2) -= "& [F:TPY]STA5=2"
 When "PAYMEP" :
  CRITERE(2) -= "& [F:TPY]STA3=2"
 When "PAYPROPAL" :
  CRITERE(2) -= "& [F:TPY]PAYPPS=2"
  If dim([M]SNS)>=0 : CRITERE(2) -= " & ([F:TPY]SNS=3 | [F:TPY]SNS="+num$([M]SNS)+")" : Endif
 When "REMBAN" :
  CRITERE(2)=""
  If [M:DIA]PAY5=2 : CRITERE(2) -=" | [F:TPY]STA5=2" : Endif
  If [M:DIA]PAY7=2 : CRITERE(2) -=" | [F:TPY]STA7=2" : Endif
  If [M:DIA]PAY9=2 : CRITERE(2) -=" | ([F:TPY]STA5<>2 & [F:TPY]STA7<>2)" : Endif
  If CRITERE(2)="" : CRITERE(2) =" & [F:TPY]STA9=2 & [F:TPY]STA9<>2"
  Else             : CRITERE(2) =" & [F:TPY]STA9=2 & ("+right$(CRITERE(2),4)+")"
  Endif
 When "REMCPT" :
  CRITERE(2) -= "& [F:TPY]STA8=2"
 When "RETACC" :
  CRITERE(2) -= "& [F:TPY]STA2=2"
 When "VALPORT" :
  CRITERE(2) -= "& (([F:TPY]STA3=2 & [F:TPY]UPDBIL>1) | [F:TPY]AUTACE10<>'')"
 When "GESSER" :
  Case zoncou
   When"PAYTYP" : CRITERE(2) -=" & find([F:TPY]SNS,2,3)"  # Revenue & Unspec
   When"CDTTYP" : CRITERE(2) -=" & find([F:TPY]SNS,1,3)"  # Expense & Unspec
  Endcase
 When "GESRBB"
  CRITERE(2) -="& STA3=1 & STA5=1 & STA7=1 & STA8=1 & STA9=2"
#ISSUE 33455 – 2017-05-17  By MANOW
 When "GESCAI"
  If (zoncou = 'INPAYTRA')
    CRITERE(2) -= "& SNS=2 & BANCSH=2 & DACPAYTYP=2 "
  Elsif (zoncou = 'OUTPAYTRA')
    CRITERE(2) -= "& SNS=1 & BANCSH=2 & DACPAYTYP=2 "
  Endif
 When "GESBAN"
  If (zoncou = 'INPAYTRA')
    CRITERE(2) -= "& SNS=2 & BANCSH=1 & DACPAYTYP=3 "
  Elsif (zoncou = 'OUTPAYTRA')
    CRITERE(2) -= "& SNS=1 & BANCSH=1 & DACPAYTYP=3 "
  Endif
#END ISSUE
#ISSUE 39260 - 2017-08-01 By MANOW/MRDAB
 When "IMPAYE"
  If func AFNC.ACTIV("REGBC")
    CRITERE(2) -= "& DACREGNUM<>2 "
  Endif
#END ISSUE
Endcase

#--------------------------------------------------------------------------------------------------
# Appel à la vue
#--------------------------------------------------------------------------------------------------
If [L]LEG<>""
 If [L]FCY<>""
  # Vues via LEG/FCY
  Link [TPY] With [AXX]AXX0     = "TABPAYTYP";"DESTRA";GLANGUE;[F:TPY]PAYTYP;[F:TPY]LEG
&               , [ACC]CODACC   =  GUSER;[F:TPY]ACS
&               , [FGR]FGR1     =  [L]FCY;[F:TPY]GFY
&               , [TPYS]TPY0   ~=  [F:TPY]PAYTYP;[F:TPY]LEG;[L]LEG
&               , [TPYG]TPY0    =  [F:TPY]PAYTYP;[F:TPY]LEG;[F:TPY]GFY;[L]CPY
& As [LNC]
 Elsif [L]CPY<>""
  # Vues via LEG/CPY
  Link [TPY] With [AXX]AXX0     = "TABPAYTYP";"DESTRA";GLANGUE;[F:TPY]PAYTYP;[F:TPY]LEG
&               , [ACC]CODACC   =  GUSER;[F:TPY]ACS
&               , [TPYS]TPY0   ~=  [F:TPY]PAYTYP;[F:TPY]LEG;[L]LEG
&               , [TPYG]TPY0    =  [F:TPY]PAYTYP;[F:TPY]LEG;[F:TPY]GFY;[L]CPY
& As [LNC]
 Elsif [L]GRP<>""
 # Vues via LEG/GRP
  Link [TPY] With [AXX]AXX0     = "TABPAYTYP";"DESTRA";GLANGUE;[F:TPY]PAYTYP;[F:TPY]LEG
&               , [ACC]CODACC   =  GUSER;[F:TPY]ACS
&               , [TPYS]TPY0   ~=  [F:TPY]PAYTYP;[F:TPY]LEG;[L]LEG
&               , [TPYY]TPYY0  ~=  [L]GRP;[F:TPY]PAYTYP;[F:TPY]GFY;[CDA]LEG
& As [LNC]
 Else
  # Vues via LEG/No FCY, No CPY, No GRP
   Link [TPY] With [AXX]AXX0     = "TABPAYTYP";"DESTRA";GLANGUE;[F:TPY]PAYTYP;[F:TPY]LEG
&               , [ACC]CODACC   =  GUSER;[F:TPY]ACS
&               , [TPYS]TPY0   ~=  [F:TPY]PAYTYP;[F:TPY]LEG;[L]LEG
& As [LNC]
 Endif
Else
 If [L]FCY<>""
  Link [TPY] With [AXX]AXX0     = "TABPAYTYP";"DESTRA";GLANGUE;[F:TPY]PAYTYP;[F:TPY]LEG
&               , [ACC]CODACC   =  GUSER;[F:TPY]ACS
&               , [FGR]FGR1     =  [L]FCY;[F:TPY]GFY
&               , [TPYP]TPY0   ~=  [F:TPY]PAYTYP;[F:TPY]LEG
&               , [TPYG]TPY0    =  [F:TPY]PAYTYP;[F:TPY]LEG;[F:TPY]GFY;[L]CPY
& As [LNC]
 Elsif [L]CPY<>""
 # Vues via No LEG but CPY
  Link [TPY] With [AXX]AXX0     = "TABPAYTYP";"DESTRA";GLANGUE;[F:TPY]PAYTYP;[F:TPY]LEG
&               , [ACC]CODACC   =  GUSER;[F:TPY]ACS
&               , [TPYP]TPY0   ~=  [F:TPY]PAYTYP;[F:TPY]LEG
&               , [TPYG]TPY0    =  [F:TPY]PAYTYP;[F:TPY]LEG;[F:TPY]GFY;[L]CPY
& As [LNC]
 Elsif [L]GRP<>""
  # Vues via No LEG but GRP
  Link [TPY] With [AXX]AXX0     = "TABPAYTYP";"DESTRA";GLANGUE;[F:TPY]PAYTYP;[F:TPY]LEG
&               , [ACC]CODACC   =  GUSER;[F:TPY]ACS
&               , [TPYP]TPY0   ~=  [F:TPY]PAYTYP;[F:TPY]LEG
&               , [TPYZ]TPYZ0  ~=  [L]GRP;[F:TPY]PAYTYP;[F:TPY]GFY;[TPY]LEG
& As [LNC]
 Else
  # Vues via No LEG and No FCY/CPY/GRP
 Link [TPY] With [AXX]AXX0     = "TABPAYTYP";"DESTRA";GLANGUE;[F:TPY]PAYTYP;[F:TPY]LEG
&               , [ACC]CODACC  =  GUSER;[F:TPY]ACS
&               , [TPYP]TPY0  ~=  [F:TPY]PAYTYP;[F:TPY]LEG
& As [LNC]
 Endif
Endif
Default File [LNC]
DEFPAG = 1

GCURFCY  = SAVE_FCY
GSOCIETE = SAVE_CPY
GCURLEG  = SAVE_LEG
GGRPFCY  = SAVE_GRP
Return

