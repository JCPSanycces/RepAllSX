# Pour mettre à jour des fichiers spécifiques
GPOINT="CFMINVMAJ" : Gosub ENTREE From EXEFNC
If GOK < 1 Goto AB_TRT1 Endif
# Maj des statistiques détail
For [SID]SID0 Where NUM=[F:SIV]NUM
  Call VALSTA("SID",1) From SUBPS2
  If GOK < 1 Break Endif
  # Issue 107888 - 2016-08-04 by CPO : US210 Scheduling invoices - Invoice posting
  Gosub INVOICE_POSTING_SET_SVIC_INVCNDSTA From LIBSAL_INVCND_SIH
  # End issue 107888 US210
Next
If GOK < 1 Goto AB_TRT1 Endif

# Maj des statistiques entête
Call VALSTA("SIH",1) From SUBPS2
If GOK < 1 Goto AB_TRT1 Endif

# FGR 04/01/2011 : X3SUIVI70100 (début) c'est mieux dans la transaction
# Si présence module Support Client, gestion du parc client
#    si facture directe avec m.a.j. stock
#    si facture de commande
#    si facture de livraison (lignes ajoutées et livraisons de prêt)
If GMODU(12)=2
   If [F:SIV]INVTYP=1 & ([F:SIV]SIHORI=1 & [F:SIV]STOMVTFLG=2) |
&     [F:SIV]SIHORI=2 | [F:SIV]SIHORI=3
      Gosub TRT_MACRULE
      If GOK < 1 Goto AB_TRT1 Endif  # ... et ajout de la gestion d'erreur
   Endif
Endif
# FGR 04/01/2011 : X3SUIVI70100 (fin) c'est mieux dans la transaction

# Issue 107888 - 2016-08-04 by CPO : US210 Scheduling invoices - Invoice posting
Gosub INVOICE_POSTING_UPD_SVIC From LIBSAL_INVCND_SIH
# End issue 107888 US210

Commit

# Issue 116638 - 2016-06-02 by ERMIL : Move webservice calls outside of transaction
# Local Tax and USA Tax
Local Integer WSGOK
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
  WSGOK = GOK

  # Make sure the mask SIHX still exists
  If !clalev([M:SIHX]) : Local Mask SIHV [SIHX] : Endif

  Gosub POST_TAX From TRTTAXSST
  # If the posting fails - don't stop processing.  Just warn user so they can commit from portal
  If !GOK
    If GTRACE=""
      GERR=1
    Else
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      GMESSAGE = func AFNC.MES1(mess(536,192,1),[F:SIH]NUM)
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      Raz GMESSAGE
    Endif
  Endif
  # We no longer want to end processing here.  So set GOK back
  GOK = WSGOK
Endif

# 78411 Sage Exchange
If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SIH]PTE)  #Sage exchange active and SE payment method
  Local Integer SEVCRTYP
  WSGOK = GOK
  If find([F:SIH]INVTYP,2,4) : SEVCRTYP = 18 : Else : SEVCRTYP = 5 : Endif
  Call DOC_VALIDATION (SEVCRTYP,[F:SIH]NUM) From SEPPLIB2
  If !GOK
    If GTRACE=""
      GERR=1
    Else
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      GMESSAGE = func AFNC.MES1(mess(60,2092,1),[F:SIH]NUM)
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      Raz GMESSAGE
    Endif
  Endif

  # Assuming no error - time to create the payment
  Local Integer NUMPAY
  If GOK : Call AUTO_PAYMENT(SEVCRTYP,[F:SIH]NUM,[L]NUMPAY) From SEPPLIB2 : Endif
  If GOK : Call AUTH_BKO([F:SIH]NUM) From SEPPLIB : Endif

  # We no longer want to end processing here.  So set GOK back
  GOK = WSGOK

Endif
# End issue 116638

Return

#------------------------------------------------------------------------
# Rollback
#------------------------------------------------------------------------
#-- rollback + nouvelle tentative
$ROL_TRT1
Rollback
Call ROLL From GLOCK
If GROLL
   # mess : rollback suite a une erreur dans la transaction
   If GTRACE <> ""
       Call ECR_TRACE(LNUM-mess(17,107,1),1) From GESECRAN
   Else
       If GMESSAGE <> "" GMESSAGE += "\" Endif
       GERR=1 : GMESSAGE += LNUM-mess(17,107,1)
   Endif
Else Goto TRT1
Endif
Return

#-- rollback
$AB_TRT1
Rollback

# mess : rollback suite a une erreur dans la transaction
If GMESSAGE<>"" : GMESSAGE += "\" : Endif
    GMESSAGE += LNUM-mess(17,107,1)
If GTRACE="" : GERR=1
Else
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Endif
Return

#########################################################################

#########################################################################
# A SUPPRIMER
#########################################################################
#------------------------------------------------------------------------
# Transfert dans masque SIHV
#------------------------------------------------------------------------
#$CHARGEMENT_SIHV_SIV

#For JL=0 To dim([F:SIV]VAT)-1
#  If [F:SIV]VAT(JL)<>""
#    [M:SIHV]XVTAX(JL) = [F:SIV]VAT(JL)
#    [M:SIHV]XVTYP(JL) = [F:SIV]VATTYP(JL)
#    [M:SIHV]XVNOT(JL) = [F:SIV]VATGRO(JL)
#    [M:SIHV]XVSMI(JL) = [F:SIV]VATNET(JL)
#    [M:SIHV]XVRAT(JL) = [F:SIV]VATRAT(JL)
#    [M:SIHV]XVAMT(JL) = [F:SIV]VATAMT(JL)
#    [M:SIHV]XVSUP(JL) = [F:SIV]VATSUPAMT(JL)
#  Endif
#Next JL
#Return
#########################################################################
# A SUPPRIMER
#########################################################################

$CHARGEMENT_SIHV

For [SVV]SVV1 Where VCRTYP=4 & VCRNUM=[F:SIH]NUM
  If [F:SVV]VAT<>""
    [M:SIHV]XVTAX([M:SIHV]NBVAT) = [F:SVV]VAT
    [M:SIHV]XVTYP([M:SIHV]NBVAT) = [F:SVV]VATTYP
    [M:SIHV]XVNOT([M:SIHV]NBVAT) = [F:SVV]VATGRO
    [M:SIHV]XVSMI([M:SIHV]NBVAT) = [F:SVV]VATNET
    [M:SIHV]XVRAT([M:SIHV]NBVAT) = [F:SVV]VATRAT
    [M:SIHV]XVAMT([M:SIHV]NBVAT) = [F:SVV]VATAMT
    [M:SIHV]XVSUP([M:SIHV]NBVAT) = [F:SVV]VATSUPAMT
    [M:SIHV]NBVAT += 1
  Endif
Next
Return
#------------------------------------------------------------------------
# Transfert dans masque SIH4
#------------------------------------------------------------------------
$CHARGEMENT_SIH4
[M:SIH4]NBLIG = JNOL
nolign = JNOL
[M:SIH4] = [F:SID]
[M:SIH4]VAT1(JNOL-1)       = [F:SID]VAT(0)
[M:SIH4]VAT2(JNOL-1)       = [F:SID]VAT(1)
[M:SIH4]VAT3(JNOL-1)       = [F:SID]VAT(2)
[M:SIH4]BASTAXLIN1(JNOL-1) = [F:SID]BASTAXLIN(0)
[M:SIH4]BASTAXLIN2(JNOL-1) = [F:SID]BASTAXLIN(1)
[M:SIH4]BASTAXLIN3(JNOL-1) = [F:SID]BASTAXLIN(2)
[M:SIH4]BASTAXLIN4(JNOL-1) = [F:SID]BASTAXLIN(3)
[M:SIH4]BASTAXLIN5(JNOL-1) = [F:SID]BASTAXLIN(4)
[M:SIH4]BASTAXLIN6(JNOL-1) = [F:SID]BASTAXLIN(5)
[M:SIH4]AMTTAXLIN1(JNOL-1) = [F:SID]AMTTAXLIN(0)
[M:SIH4]AMTTAXLIN2(JNOL-1) = [F:SID]AMTTAXLIN(1)
[M:SIH4]AMTTAXLIN3(JNOL-1) = [F:SID]AMTTAXLIN(2)
Return

#------------------------------------------------------------------------
# Ajustement des taxes à la ligne
#   Dans les lignes, le montant des taxes ne tient pas compte de l'influence des
#   éléments de facturation ( par exemple les remises )
#   Il ne faut pas recalculer les taxes à la ligne mais uniquement ajuster en fonction
#   des montants taxes calculés sur l'ensemble de la facture.
#   La différence entre la valeur de la taxe et la somme des taxes à la ligne ne doit pas
#   etre affectee à une seule ligne
# -1- ajuster au prorata les montants de chaque ligne sur le nouveau montant global
# -2- rechercher différence entre la somme des prorata et le montant global
#     (PB des arrondis)
# -3- saupoudrage de la différence dans l'ordre des plus gros montants
#     (le montant est modifié de la valeur de l'arrondi devise [F:TCU]CURRND )
#------------------------------------------------------------------------
# Attention : section appelée en import de facture
#------------------------------------------------------------------------
$TAXES_LIGNES
Local Integer JL, JLL, WSENS, JNOL, JLRG, JLRG1
Local Integer JLC       : # compteur nbre de lignes concernées par saupoudrage
Local Integer JLBM      : # indice ligne ayant la base de taxe maxi (pour saupoudrage)
Local Decimal TOTLIG    : # cumul des montants de la taxe dans les lignes
Local Decimal TOTLIG1
Local Decimal BASTAXMAX : # mt + grande base taxable d'une ligne (pour saupoudrage)
Local Decimal REPARTIR  : # montant à repartir
Local Decimal UNITEREP  : # unite de repartition
Local Integer JLL1
Local Decimal TAXLIGABS (0..dim([M:SIH4]ITMREF))
Local Integer TAXLIGFLG (0..dim([M:SIH4]ITMREF))

# --> Si changement de devise
If [F:TCU]CUR<>[F:SIV]CUR
    Read [TCU]TCU0=[F:SIV]CUR
Endif

# boucle de traitement pour chaque taxe du tableau des taxes (XV)
For JL=0 To dim([M:SIHV]XVTAX)-1

  Raz [M:SIH4]AMTTAXPRO
  Raz JLC, TOTLIG, TOTLIG1, JLBM, JLRG, JLRG1, BASTAXMAX

  If [M:SIHV]XVTAX(JL)<>""

#   on calcule le montant total de cette taxe dans les lignes
    For JLL=0 To [M:SIH4]NBLIG-1
      If    [M:SIH4]VAT1(JLL)=[M:SIHV]XVTAX(JL) : TOTLIG += [M:SIH4]AMTTAXLIN1(JLL)
      Elsif [M:SIH4]VAT2(JLL)=[M:SIHV]XVTAX(JL) : TOTLIG += [M:SIH4]AMTTAXLIN2(JLL)
      Elsif [M:SIH4]VAT3(JLL)=[M:SIHV]XVTAX(JL) : TOTLIG += [M:SIH4]AMTTAXLIN3(JLL)
      Endif
    Next JLL

#   on doit affecter le montant d'une taxe "minuscule" a une ligne (bug 12418)
    If [M:SIHV]XVAMT(JL)<>0 & TOTLIG=0
      Gosub TAXES_MINUS
    Endif

#   pour chaque ligne de la facture traitement de cette taxe
    For JLL=0 To [M:SIH4]NBLIG-1
      If    [M:SIH4]VAT1(JLL)=[M:SIHV]XVTAX(JL) : # la premiere taxe de la ligne
        If [M:SIHV]XVAMT(JL)=0
          [M:SIH4]AMTTAXLIN1(JLL)=0
        Else
          If TOTLIG<>0 & [M:SIH4]AMTTAXLIN1(JLL)<>0
            [M:SIH4]AMTTAXPRO(JLL)=arr(([M:SIH4]AMTTAXLIN1(JLL)*[M:SIHV]XVAMT(JL))/TOTLIG,[F:TCU]CURRND)
            [M:SIH4]AMTTAXLIN1(JLL)=[M:SIH4]AMTTAXPRO(JLL)
            JLC += 1
          Endif
        Endif
      Elsif [M:SIH4]VAT2(JLL)=[M:SIHV]XVTAX(JL) : # la seconde taxe de la ligne
        If [M:SIHV]XVAMT(JL)=0
          [M:SIH4]AMTTAXLIN2(JLL)=0
        Else
          If TOTLIG<>0 & [M:SIH4]AMTTAXLIN2(JLL)<>0
            [M:SIH4]AMTTAXPRO(JLL)=arr(([M:SIH4]AMTTAXLIN2(JLL)*[M:SIHV]XVAMT(JL))/TOTLIG,[F:TCU]CURRND)
            [M:SIH4]AMTTAXLIN2(JLL)=[M:SIH4]AMTTAXPRO(JLL)
            JLC += 1
          Endif
        Endif
      Elsif [M:SIH4]VAT3(JLL)=[M:SIHV]XVTAX(JL) : # la troisieme taxe de la ligne
        If [M:SIHV]XVAMT(JL)=0
          [M:SIH4]AMTTAXLIN3(JLL)=0
        Else
          If TOTLIG<>0 & [M:SIH4]AMTTAXLIN3(JLL)<>0
            [M:SIH4]AMTTAXPRO(JLL)=arr(([M:SIH4]AMTTAXLIN3(JLL)*[M:SIHV]XVAMT(JL))/TOTLIG,[F:TCU]CURRND)
            [M:SIH4]AMTTAXLIN3(JLL)=[M:SIH4]AMTTAXPRO(JLL)
            JLC += 1
          Endif
        Endif
      Endif
      TAXLIGABS(JLL)=abs([M:SIH4]AMTTAXPRO(JLL))
    Next JLL

    REPARTIR=[M:SIHV]XVAMT(JL)-sum([M:SIH4]AMTTAXPRO) : # calcul de la différence

    If REPARTIR<>0
      If REPARTIR<0 WSENS=-1 Else WSENS=1 Endif       : # sens de la difference
      REPARTIR=REPARTIR*WSENS                         : # on passe en positif
      If JLC<>0 & [F:TCU]CURRND<>0
        UNITEREP=[F:TCU]CURRND
      Else
        UNITEREP=REPARTIR
      Endif

#--   Saupoudrage dans la colonne de repartition
      While REPARTIR<>0
#            recherche du plus grand montant taxe ligne ( valeur absolue )
        JNOL=find(max(TAXLIGABS(0..[M:SIH4]NBLIG-1)),TAXLIGABS(0..[M:SIH4]NBLIG-1))
#            si absence de montant positif dans le tableau des valeurs absolues
#              - toutes les lignes ont été modifiées : remettre le tableau en positif
#              - rechercher le plus grand montant
        If JNOL
          If TAXLIGABS(JNOL-1)<=0
            For JLL1=0 To [M:SIH4]NBLIG-1
              TAXLIGABS(JLL1)=abs([M:SIH4]AMTTAXPRO(JLL1))
            Next JLL1
            JNOL=find(max(TAXLIGABS(0..[M:SIH4]NBLIG-1)),TAXLIGABS(0..[M:SIH4]NBLIG-1))
          Endif
        Endif

        If JNOL
          If REPARTIR > UNITEREP
            REPARTIR -= UNITEREP
          Else
            UNITEREP = REPARTIR : REPARTIR = 0
          Endif
          [M:SIH4]AMTTAXPRO(JNOL-1) += UNITEREP * WSENS
          TAXLIGABS(JNOL-1) *= -1      : # bascule de la valeur absolue en négatif
          TAXLIGFLG(JNOL-1) = 1        : # flag de modification de la taxe à la ligne
        Else
          REPARTIR = 0
        Endif
      Wend

#-- On reinjecte dans les lignes
      For JLL=0 To [M:SIH4]NBLIG-1
        If TAXLIGFLG(JLL) = 1
          If    [M:SIH4]VAT1(JLL)=[M:SIHV]XVTAX(JL) & [M:SIH4]AMTTAXLIN1(JLL)<>0
            [M:SIH4]AMTTAXLIN1(JLL) = [M:SIH4]AMTTAXPRO(JLL)
          Elsif [M:SIH4]VAT2(JLL)=[M:SIHV]XVTAX(JL) & [M:SIH4]AMTTAXLIN2(JLL)<>0
            [M:SIH4]AMTTAXLIN2(JLL) = [M:SIH4]AMTTAXPRO(JLL)
          Elsif [M:SIH4]VAT3(JLL)=[M:SIHV]XVTAX(JL) & [M:SIH4]AMTTAXLIN3(JLL)<>0
            [M:SIH4]AMTTAXLIN3(JLL) = [M:SIH4]AMTTAXPRO(JLL)
          Endif
        Endif
      Next JLL
    Endif
  Endif
Next JL

Return

#----
#     Pour chaque ligne, la base de taxe n'est pas suffisante pour calculer un montant de taxe
#     significatif; par contre le cumul des bases taxables est suffisant pour calculer
#     un montant de taxe pour l'ensemble des lignes.
#     La valeur de cette taxe va etre imputee a la ligne qui contient la + grande base de taxe
#
$TAXES_MINUS
Raz JLBM, JLRG, BASTAXMAX
For JLL=0 To [M:SIH4]NBLIG-1
  Raz TOTLIG1, JLRG1
  If    [M:SIH4]VAT1(JLL)=[M:SIHV]XVTAX(JL)   : # en principe la 1ere taxe est une TVA
    JLRG1=1
    Case [M:SIHV]XVTYP(JL)
      When 1    TOTLIG1  = [M:SIH4]BASTAXLIN1(JLL)
                TOTLIG1 += [M:SIH4]BASTAXLIN4(JLL)+[M:SIH4]BASTAXLIN5(JLL)+[M:SIH4]BASTAXLIN6(JLL)
      When 2,3  TOTLIG1  = [M:SIH4]BASTAXLIN1(JLL)
    Endcase
  Elsif [M:SIH4]VAT2(JLL)=[M:SIHV]XVTAX(JL)   : # et les autres des taxes parafiscales ou speciales
    JLRG1=2 : TOTLIG1  = [M:SIH4]BASTAXLIN2(JLL)
  Elsif [M:SIH4]VAT3(JLL)=[M:SIHV]XVTAX(JL)
    JLRG1=3 : TOTLIG1  = [M:SIH4]BASTAXLIN3(JLL)
  Endif
  If TOTLIG1<>0 & TOTLIG1>BASTAXMAX
    JLBM=JLL            : # indice de la ligne ayant la plus grande base taxable
    JLRG=JLRG1          : # rang de la taxe (1 2 ou 3) dans la ligne
    BASTAXMAX=TOTLIG1   : # valeur maxi de la base taxable
  Endif
Next JLL
#--- on injecte la valeur dans la ligne
Case JLRG
  When 1  [M:SIH4]AMTTAXLIN1(JLBM)=[M:SIHV]XVAMT(JL)
  When 2  [M:SIH4]AMTTAXLIN2(JLBM)=[M:SIHV]XVAMT(JL)
  When 3  [M:SIH4]AMTTAXLIN3(JLBM)=[M:SIHV]XVAMT(JL)
Endcase
TOTLIG=[M:SIHV]XVAMT(JL)
Return

#------------------------------------------------------------------------
# Determine le parametrage interface
# en 1 :
#------------------------------------------------------------------------
$TRANSAC
If clalev([GAU])=0 : Local File GAUTACE   [GAU] : Endif
If clalev([TSV])=0 : Local File TABSIVTYP [TSV] : Endif
Raz WTRANSAC
#- X3Suivi 71937 Multi-législation -#
Call GETLEG([F:SIV]CPY,"G",LEGIS) From DEVSUB
If LEGIS='' : Call GETLEG([F:SIV]CPY,"T",LEGIS) From DEVSUB : Endif
#Read [TSV]TSV0=[F:SIV]SIVTYP
Local Integer WERR
# Issue 120615
If func AFNC.ACTIV("INVCA")>0
  If [F:SIH]REVCANSTA = 2
    If !clalev([F:SIVA]) : Local File SINVOICEV [SIVA] : Endif
    Read [F:SIVA]SIV0=[F:SIH]INVNUM
    If !fstat
      Call LEC_TSV_LEG(LEGIS,[F:SIVA]SIVTYP,WERR) From TRTLECLEG
      If !fstat
        WTRANSAC=[F:TSV]COD
        Read [GAU]GAU0=WTRANSAC
        If fstat Raz WTRANSAC Endif
      Endif
    Endif
  Endif
Endif
# End issue 120615
If WTRANSAC=""
  Call LEC_TSV_LEG(LEGIS,[F:SIV]SIVTYP,WERR) From TRTLECLEG
  If !fstat
    WTRANSAC=[F:TSV]COD
    Read [GAU]GAU0=WTRANSAC
    If fstat Raz WTRANSAC Endif
  Endif
Endif
If WTRANSAC=""
  Case [F:SIH]INVTYP
    When 1 : WTRANSAC="SIHI"     : # facture
    When 2 : WTRANSAC="SIHC"     : # avoir
             Read [GAU]GAU0=WTRANSAC
             If fstat : WTRANSAC="SIHI" : Endif
  Endcase
Endif
Return

#------------------------------------------------------------------------
# Prise en compte des acomptes dans les echeances de la facture
# - la partie acompte commande affectée à la facture est retranchée des échéances
# - lettrage de la partie affectée aux acomptes
#------------------------------------------------------------------------
$MAJ_ECHEANCES
Local Decimal ACOMPTES, ENLEVER
Local Integer STAT

If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:PYO])=0 : Local File PAYORDER   [PYO] : Endif
# Bug 67451
If GMODU(3) = 2   : # Présence du module tiers
    If clalev([F:PYH])=0 : Local File PAYMENTH   [PYH] : Endif
    If clalev([F:PYD])=0 : Local File PAYMENTD   [PYD] : Endif
Endif
# Bug 67451

Gosub LET_ACOMPTES
If GOK<1 : Return : Endif

Return

#---
# - recherche des versements affectés aux acomptes de la facture
# - si versements en moins dans PAYORDER de l'acompte (sup. si = 0)
# -               créat. d'un PAYORDER facture ( en + si existe )
$LET_ACOMPTES

Local Integer IA
# Boucle de recherche des réglements des acomptes affectés à la facture
Local Integer WNBPAY
For IA=0 To dim([F:SIV]INSORDNUM)-1
  If [F:SIV]INSORDNUM(IA)<>""
    Read [DUD]DUD0="*SO";[F:SIV]INSORDNUM(IA);1;[F:SIV]INSLIN(IA)
    If !fstat
      For [PYO] Where DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
          WNBPAY+=1
      Next
    Endif
  Endif
Next
WNBPAY=max(20, WNBPAY)

Local Integer WNB                :   # compteur de ligne du tableau
Local Integer WDUDNUM    (0..WNBPAY-1) :   # no interne echeance acompte
Local Integer WDUDLIG    (0..WNBPAY-1) :   # no ligne
Local Decimal WDUDPAYAMT (0..WNBPAY-1) :   # montant réglé
Local Char    WPAYVCR (20) (0..WNBPAY-1) : # réglement (clé de la pièce)
Local Integer WPAYNUM    (0..WNBPAY-1) :   # no interne pièce réglement
Local Integer WREGLIG    (0..WNBPAY-1) :   # no ligne pièce règlement
Local Integer WINVNUM    (0..WNBPAY-1) :   # no interne facture
Local Decimal WENLEVER   (0..WNBPAY-1) :   # passer acompte --> facture pour un acompte
Local Decimal WINSATI
Local Decimal WENLEVER_CDE       :   # total passer acompte --> facture pour une cde
Local Integer WERR               :   # 67451

Local Integer WPOINT_ENTREE : WPOINT_ENTREE=0
GPOINT="LETACOMPTE" : Gosub ENTREE From EXEFNC
If GOK < 1 Return Endif
If WPOINT_ENTREE=1 Return Endif

# boucle sur les acomptes commande affectés à la facture (4 possibles actuellement)
For IA=0 To dim([F:SIV]INSORDNUM)-1
  If [F:SIV]INSORDNUM(IA)<>""
    Read [DUD]DUD0="*SO";[F:SIV]INSORDNUM(IA);1;[F:SIV]INSLIN(IA)
    If !fstat
#     le règlement de l'acompte doit être valide : pas en temporaire (Bug 16171)
      If [F:DUD]TMPCUR<>0
        # Bug 67451
        # Au moins une étape de comptabilisation doit être passée
        WERR=1
        If GMODU(3) = 2   : # Présence du module tiers
            WERR=0
            For [PYD]PYD1 Where DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
                Read [PYH]PYH0=[F:PYD]NUM
                If fstat | ([F:PYH]STAFLG(2)<>2  & ([F:PYH]STAFLG(7)<>2 | [F:PYH]STAFLG(8)<>2))
                    WERR=1 : Break
                Endif
            Next
        Endif
        If WERR
        # Bug 67451
            If GTRACE <> ""
                Call ECR_TRACE(mess(824,196,1)-"("+mess(2,292,1)-[F:DUD]NUM+")",1) From GESECRAN
            Else
                GERR=1 : GMESSAGE=mess(824,196,1)-"("+mess(2,292,1)-[F:DUD]NUM+")"
            Endif
            GOK=0 : Break
        Endif
      Endif

      ENLEVER=0
      WENLEVER_CDE=0
#     partie de la facture affectée à l'acompte
      If [F:SIV]CUR <> [F:DUD]CUR
          STAT=0
          Call CONVERT([F:SIV]CUR,[F:DUD]CUR,GLOCALDEV,[F:SIH]CURTYP,datesyst,
&                      [F:SIV]INSATI(IA),WINSATI,STAT) From TRTDEV
          If STAT<>0 : WINSATI=[F:SIV]INSATI(IA) : Endif
      Else
          WINSATI=[F:SIV]INSATI(IA)
      Endif
      ACOMPTE=WINSATI
#     recherche réglement de cet acompte non encore imputé à une facture
#     (creation d'un enr. [PYO] uniquement si le règlement est validé)
      Filter [PYO] Where DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
&                  Order By Key PYO0
      For [PYO]
        If ACOMPTE <= 0 : Break : Endif
        If !fstat
          If [F:PYO]DUDPAYAMT<ACOMPTE
               ENLEVER=[F:PYO]DUDPAYAMT
          Else ENLEVER=ACOMPTE
          Endif
          ACOMPTE -= ENLEVER
          WDUDNUM(WNB)    = [F:PYO]DUDNUM      : # on garnit la table
          WDUDLIG(WNB)    = [F:PYO]DUDLIG
          WDUDPAYAMT(WNB) = [F:PYO]DUDPAYAMT
          WPAYVCR(WNB)    = [F:PYO]PAYVCR
          WPAYNUM(WNB)    = [F:PYO]PAYNUM
          WREGLIG(WNB)    = 1
          WINVNUM(WNB)    = [F:PYO]INVNUM
          WENLEVER(WNB)   = ENLEVER
          WENLEVER_CDE += ENLEVER
          WNB += 1
        Endif
      Next
      Filter [PYO]

#     Traitement du montant de l'acompte affecté à la facture et non encore réglé
#     --> On considère ce montant comme réglé : Le règlement se fera sur la facture
#      If ([F:SIV]INSATI(IA) - ENLEVER) > 0
#      If (WINSATI - ENLEVER) > 0
      If (WINSATI - WENLEVER_CDE >0)  # Bug 22210

          Readlock [DUD] Curr
          If fstat=1
            GOK=-1 : GLOCK="$GACCDUDATE"-[F:SIV]INSORDNUM(IA) : Break
          Elsif fstat
            GOK=0  : Call RSTA("DUD",[F:SIV]INSORDNUM(IA)) From GLOCK : Break
          Endif

#          [F:DUD]PAYCUR += ([F:SIV]INSATI(IA) - ENLEVER)
#          [F:DUD]PAYCUR += (WINSATI - ENLEVER)
          [F:DUD]PAYCUR += (WINSATI - WENLEVER_CDE) # Bug 22210


#          conversion en devise locale GLOCALDEV
           STAT=0
           Call CONVERT([F:SIH]CUR,GLOCALDEV,GLOCALDEV,[F:SIH]CURTYP,datesyst,
&                       [F:DUD]PAYCUR,[F:DUD]PAYLOC,STAT) From TRTDEV
           If STAT<>0 : [F:DUD]PAYLOC=[F:DUD]PAYCUR : Endif

#          conversion en devise reporting (dossier) GSYSCUR
           STAT=0
#           Call CONVERT([F:SIH]CUR,GSYSCUR,GLOCALDEV,[F:SIH]CURTYP,datesyst,
#&                       [F:DUD]PAYCUR,[F:DUD]PAYRPT,STAT) From TRTDEV
#           If STAT<>0 : [F:DUD]PAYRPT=[F:DUD]PAYCUR : Endif
           Call SLDECH("DUD")From MODECHE
           Local Decimal EXERCICE, PERIODE
           Call GETPERSOC([F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
           [F:DUD]FIY= EXERCICE
           [F:DUD]PER= PERIODE
           Rewrite [DUD]
           If fstat
             GOK=0 : Call FSTA("DUD") From GLOCK : Break
           Endif
           Call HISTOECH("DUD",1,[F:SIH]ACCDAT)From MODECHE
      Endif
    Endif
  Endif
Next IA
If GOK < 1 Return Endif

For IA=0 To dim(WDUDNUM)-1
  If WDUDNUM(IA)=0 : Break : Endif

# traitement du payorder de l'acompte
  Read [PYO]PYO0 = WDUDNUM(IA);WDUDLIG(IA);WPAYNUM(IA)
  If !fstat
    WDUDPAYAMT(IA) -= WENLEVER(IA)
    If WDUDPAYAMT(IA)=0
      Delete [PYO]
      If fstat=1
        GOK = -1 : GLOCK="$PAYORDER"-num$(WDUDNUM(IA)) : Return
      Endif
    Else
      [F:PYO]DUDPAYAMT=WDUDPAYAMT(IA)
      Rewrite [PYO]
      If fstat
        GOK = 0 : Call FSTA("PYO") From GLOCK : Return
      Endif
    Endif

#   traitement du payorder de la facture
#   lecture payorder facture (ajout montant a enregistrement ou creer)

    Read [PYO]PYO0 = [F:SIH]ACCNUM;WDUDLIG(IA);WPAYNUM(IA)
    If !fstat
      [F:PYO]DUDPAYAMT += WENLEVER(IA)
      [F:PYO]INVNUM    = [F:SIH]ACCNUM
      Rewrite [PYO]
      If fstat
        GOK = 0 : Call FSTA("PYO") From GLOCK : Return
      Endif
    Else
      [F:PYO]DUDNUM    = [F:SIH]ACCNUM
      [F:PYO]DUDLIG    = WDUDLIG(IA)
      [F:PYO]DUDPAYAMT = WENLEVER(IA)
      [F:PYO]PAYVCR    = WPAYVCR(IA)
      [F:PYO]PAYNUM    = WPAYNUM(IA)
      [F:PYO]INVNUM    = [F:SIH]ACCNUM
      Write [PYO]
      If fstat
        GOK = 0 : Call FSTA("PYO") From GLOCK : Return
      Endif
    Endif
  Endif

Next IA

#   imputation de ce reglement à la facture (si présence module compta)
    If WNB <> 0
        If GMODU(2)=2   : # presence du module compta
          #--CPO 75788
          #Call IMPUTE([F:SIH]ACCNUM,WPAYNUM,WREGLIG,WENLEVER,WNB) From IPTACPT
          Call IMPUTE2([F:SIH]ACCNUM,WPAYNUM,WREGLIG,WENLEVER,WNB,WPAYVCR) From IPTACPT
          #--CPO fin
          #VPO 07/07/09 55751 gestion message d'erreur
          If GOK<1 & GMESSAGE<>""
             If GTRACE <> ""
                Call ECR_TRACE(GMESSAGE,1) From GESECRAN
             Else
                GERR=1
             Endif
             Return
          Endif
        Endif
    Endif
Return

#########################################################################
#-----------------------------------------------------------------------#
# Mise a jour des stocks                                                #
#-----------------------------------------------------------------------#
Subprog LES_STOCKS

Local Integer LORI, LNBR, LNBJ, LRET
Local Decimal LQTY, LSHT, WMOINSSTU
Local Integer WLND, I
Local Char     SYMBOLE2(50)
Local Char     WCRIT(80)
Local Char     WCRITSTO1(240)     : # Filtre statut
Local Integer  WQAR
Local Date     WDATPER
#DLUBPC
Local Char  NBDAY(10)
Raz NBDAY

If !clalev ([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
If !clalev ([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
If !clalev ([F:STA]) : Local File STOALL     [STA] : Endif
If !clalev ([F:STL]) : Local File STOLOT     [STL] : Endif
If !clalev ([F:STO]) : Local File STOCK      [STO] : Endif
If !clalev ([F:STS]) : Local File STOSER     [STS] : Endif
If !clalev ([F:SOQ]) : Local File SORDERQ    [SOQ] : Endif
If !clalev ([F:MVC]) : Local File BPCUSTMVT  [MVC] : Endif
If !clalev ([F:LCM]) : Local File LASTCUSMVT [LCM] : Endif
If !clalev ([F:BPD]) : Local File BPDLVCUST  [BPD] : Endif
If !clalev ([F:SRU]) : Local File TABSTORUL  [SRU] : Endif
#DLUBPC
If !clalev ([F:ITU]) : Local File ITMBPC  [ITU] : Endif

If GMODU(6)=2 & clalev([F:POQ])=0 : Local File PORDERQ [POQ] : Endif

# ---------------------------------------
# FGR 17/04/2015 : X3SUIVI107637 (début)
  Link [STA] With [STO]STO0~=[F:STA]STOFCY;[F:STA]STOCOU
&              As [KSTA]
&    Order By Key STA1=[F:STA]VCRTYP;[F:STA]VCRNUM;[F:STA]VCRLIN;[F:STA]VCRSEQ;[F:STA]STOCOU

  Link [SID] With [ITM]ITM0~=[F:SID]ITMREF,
&                 [ITF]ITF0~=[F:SID]ITMREF;[F:SID]STOFCY
&              As [KSID]
&           Where [F:SID]STOMGTCOD <> 1
&    Order By Key SID0=[F:SID]NUM;[F:SID]SIDLIN
# FGR 17/04/2015 : X3SUIVI107637 (fin)
# ---------------------------------------

# Classe écran pour les encours
If !clalev([M:ORDK]) : Local Mask ORDK       [ORDK] : Endif
# Classe écran pour le moteur de maj
If !clalev([M:STW])  : Local Mask STOWORK    [STW]  : Endif

If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif
Raz [M:SVW]

Raz GMESSAGE
# Si facture de livraison et pièce origine renseigné
# lecture livraison pour savoir s'il s'agit d'un prêt
Raz WLND
If [F:SIV]SIHORI=3 & [F:SIV]SIHORINUM<>""
   Read [SDH]SDH0=[F:SIV]SIHORINUM
   If !fstat & [F:SDH]LND=2
      WLND=[F:SDH]LND
   Endif
Endif

#DLUBPC
#lecture ITMBPC  pour recuperer DLUBPC
If [F:SIV]BPCORD <> ""
   Read [ITU]ITU0 = [F:ITM]ITMREF;[F:SIV]BPCORD
   If fstat
      Raz [F:ITU]
   Endif
Endif

# Si facture diverse ou de commande ou ligne directe d'un facture de livraison
# Vérification des stocks à sortir
# FGR 10/07/2015 : X3SUIVI109265 (début) - impact sur les performances
#If find([F:SIV]SIHORI,1,2) | ([F:SIV]SIHORI=3 & [F:SID]SDHNUM="")
#   # FGR 17/04/2015 : X3SUIVI107637 (début)
#   #For [SID]SID0 Where NUM=[F:SIV]NUM
#   For [KSID]SID0 Where [F:SID]NUM=[F:SIV]NUM
If find([F:SIV]SIHORI,1,2,3)
   # FGR 17/04/2015 : X3SUIVI107637 (début)
   #For [SID]SID0 Where NUM=[F:SIV]NUM
   For [KSID]SID0 Where [F:SID]NUM=[F:SIV]NUM and [F:SID]STOMGTCOD<>1 and (find([F:SIV]SIHORI,1,2) or ([F:SIV]SIHORI=3 & [F:SID]SDHNUM=""))
# FGR 10/07/2015 : X3SUIVI109265 (fin) - impact sur les performances
   # FGR 17/04/2015 : X3SUIVI107637 (fin)

      Raz WCRITSTO1
      # Ligne géré en stock
      If [F:SID]STOMGTCOD<>1
         # FGR 17/04/2015 : X3SUIVI107637 (début) : plus la peine c'est dans le link
         #Read [ITM]ITM0=[F:SID]ITMREF
         #If fstat
         #   Call RSTA("ITM",[F:SID]ITMREF) From GLOCK
         #   GOK=0 : Break
         #Else
         #   Read [ITF]ITF0=[F:SID]ITMREF;[F:SID]STOFCY
         #   If fstat
         #      Call RSTA("ITF",[F:SID]STOFCY-[F:SID]ITMREF) From GLOCK
         #      GOK=0 : Break
         #   Endif
         #Endif
         # FGR 17/04/2015 : X3SUIVI107637 (fin)
         Call LECSRU([F:SID]STOFCY,[F:ITM]TCLCOD,4,[F:SIV]TRSCOD,"",LRET)
&                    From STKLIB
         If LRET <>0 GOK=0 : Break Endif

        #DLU Client, calcul du nbre de jours à retrancher à la DLU article
        If [F:ITU]DLUBPC <> 0
          Call CALNBDAYCLI([F:ITM]EXYMGTCOD,[F:ITM]SHL,[F:ITM]SHLUOM,[F:ITF]DLU,[F:ITU]DLUBPC,NBDAY) From STKLIB
        Endif

         # Si statuts renseignés dans filtre allocation
         If !find([F:SID]STA,"","*")
            # Décodage de la liste de statuts --> transformation en
            # une formule contenant des 'pat(%,statut)'
            Call DECODE_STAT([F:SID]STA,WCRIT) From TRTCATEG
            # Remplacement des '%' par la variable à tester
            Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTO1) From TRTCATEG
            Raz WCRIT
         # Sinon prise en compte des sous-statuts autorisés
         Elsif !find([F:SRU]AUZSST,"","*")
            Call CREE_FORMULE([F:SRU]FORSTA,"[F:STO]STA",WCRITSTO1) From TRTCATEG
         Endif

         # S'il n'y avait pas de filtre statut, on traite ceux de la règle d'allocation
         # restreint par les statuts autorisés pour le mouvement ds la catégorie article
         If WCRITSTO1=""
            # Statuts autorisés par la règle de gestion de stock
            WAQR=[F:SRU]AUZSTA

            # Alimentation du filtre sur le statut
            Case WAQR
             When 1       : WCRITSTO1='left$([F:STO]STA,1)="A"'
             When 2       : WCRITSTO1='left$([F:STO]STA,1)="Q"'
             When 3       : WCRITSTO1='(left$([F:STO]STA,1)="A"|left$([F:STO]STA,1)="Q")'
             When 4       : WCRITSTO1='left$([F:STO]STA,1)="R"'
             When 5       : WCRITSTO1='(left$([F:STO]STA,1)="A"|left$([F:STO]STA,1)="R")'
             When 6       : WCRITSTO1='(left$([F:STO]STA,1)="Q"|left$([F:STO]STA,1)="R")'
             When 7       : WCRITSTO1='1=1'
             When Default : WCRITSTO1='left$([F:STO]STA,1)="A"'
            Endcase
         Endif

         # Pas de demande d'analyse
         If WCRITSTO1<>""
            WCRITSTO1 = "("+WCRITSTO1+")"
         Endif
         WCRITSTO1 += '&[F:STO]QLYCTLDEM=""'

         # Si stock négatif interdit
         If [F:ITM]NEGSTO<>2
            Filter [STA] Where VCRTYP=5 & VCRNUM=[F:SID]NUM & VCRLIN=[F:SID]SIDLIN & ALLTYP=4
            #Read [STA]STA1 First      # FGR 17/04/2015 : X3SUIVI107637
            Look [STA]STA1 First       # FGR 17/04/2015 : X3SUIVI107637
            If !fstat
               Call ECR_TRACE([F:STA]STOFCY-[F:STA]ITMREF-":"-mess(184,192,1),1) From GESECRAN
               GOK=0
               Filter [STA]
               Break
            Else
               Filter [STA]
            Endif
         Endif

         # FGR 17/04/2015 : X3SUIVI107637 (début)
         #For [STA]STA1 Where VCRTYP=5 & VCRNUM=[F:SID]NUM  & VCRLIN=[F:SID]SIDLIN & ALLTYP=2
         For [KSTA]STA1 Where [F:STA]VCRTYP=5 & [F:STA]VCRNUM=[F:SID]NUM  & [F:STA]VCRLIN=[F:SID]SIDLIN & [F:STA]ALLTYP=2
         # FGR 17/04/2015 : X3SUIVI107637 (fin)

            # FGR 17/04/2015 : X3SUIVI107637 (début) : plus la peine c'est dans le link
            # Lecture du stock
            #Read [STO]STO0=[F:STA]STOFCY;[F:STA]STOCOU
            #If fstat
            #   Call RSTA("STO",[F:STA]STOFCY-[F:STA]ITMREF-num$([F:STA]STOCOU)) From GLOCK
            #   GOK=0 : Break 2
            ## Ligne de stock bloquée pour inventaire
            #Elsif [F:ITF]CUNFLG=2 & [F:STO]CUNLOKFLG=2
            # FGR 17/04/2015 : X3SUIVI107637 (fin)

            # Ligne de stock bloquée pour inventaire
            If [F:ITF]CUNFLG=2 & [F:STO]CUNLOKFLG=2
               Call ECR_TRACE(mess(55,198,1)-[F:SID]NUM-"/"-[F:STO]ITMREF-[F:STO]LOT
&                             -[F:STO]LOC-":"-mess(126,184,1),1) From GESECRAN
               GOK=0 : Break 2
            # Emplacement en attente de rangement
            Elsif [F:STO]LOCCAT=2 & [F:STA]ITMREF<>[F:STO]ITMREF
               # Contrôle que les lignes de stock en attente de rangement sont complètes
               Call CTLPLFLOC([F:STO]ITMREF,"",LRET) From STKSOR
               If LRET<>0
                  Call ECR_TRACE(mess(55,198,1)-[F:SID]NUM-"/"-[F:STO]ITMREF-
&                                [F:STO]LOC-":"-mess(378,199,1),1) From GESECRAN
                  GMESSAGE = mess(377,199,1)-":"
                  Case LRET
                   When 1 : GMESSAGE += mess(43,197,1)-","-mess(456,197,1)
                   When 2 : GMESSAGE += mess(453,197,1)
                   When 3 : GMESSAGE += mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
                  Endcase
                  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
                  GOK=0 : Break 2
               Endif
            Endif
            # Contrôle statuts autorisés
            If !evalue(WCRITSTO1)
               If GSTOADMIN=2
                  Call ECR_TRACE(mess(55,198,1)-[F:SID]NUM-"/"-[F:STO]ITMREF-
&                      mess(399,198,1)-[F:STO]STA-":"-mess(366,199,1),0) From GESECRAN
               Else
                  Call ECR_TRACE(mess(55,198,1)-[F:SID]SDHNUM-"/"-[F:STO]ITMREF-
&                      mess(399,198,1)-[F:STO]STA-":"-mess(366,199,1),1) From GESECRAN
                  GOK=0 : Break 2
               Endif
            Endif
            # Lots périmés interdits
            If [F:SRU]SHLLOT<>3
               Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
               If !fstat
                  If [F:SRU]SHLLOT= 2
                     WDATPER = [F:STL]DLUDAT+val(NBDAY)
                  Else
                     WDATPER = [F:STL]SHLDAT
                  Endif
                  If WDATPER <>[0/0/0]
                     If WDATPER<[F:SIV]INVDAT
                        If GSTOADMIN=2
                           Call ECR_TRACE(mess(55,198,1)-[F:SID]NUM-"/"-[F:STO]ITMREF-
&                               ":"-mess(398,199,1)-[F:STO]LOT,0) From GESECRAN
                        Else
                           Call ECR_TRACE(mess(55,198,1)-[F:SID]NUM-"/"-[F:STO]ITMREF-
&                               ":"-mess(398,199,1)-[F:STO]LOT,1) From GESECRAN
                           GOK=0 : Break 2
                        Endif
                     Endif
                  Endif
               Endif
            Endif
            # No série en sortie non saisis et pas de compteur série
            If [F:ITM]SERMGTCOD=2 & [F:ITM]SERCOU=""
               #MAE, le 27/09/2010, bg 67175, si inter-site et intra-société, pas de n° série a saisir
               If [M:STW]TRFFCY="" & [M:STW]BETCPY = 2
                  If [F:STA]SERNUM=""
                     Call ECR_TRACE(mess(55,198,1)-[F:SID]NUM-"/"-[F:STO]ITMREF-
&                     ":"-mess(312,184,1),1) From GESECRAN
                     GOK=0 : Break 2
                  Endif
               Endif
            Endif
            #--- Issue 110327
            # No série en E/S global non associé à l'allocation
            If [F:ITM]SERMGTCOD=4 & [F:STA]SERNUM=""
              Call ECR_TRACE([F:SID]NUM-[F:STO]ITMREF-":"-mess(312,184,1),1) From GESECRAN
              GOK=0 : Break 2
            Endif
            #---
         Next
         # Vérification pour les manquants
         For [STA]STA1  Where VCRTYP=5 & VCRNUM=[F:SID]NUM  & VCRLIN=[F:SID]SIDLIN & ALLTYP=4
            # No série en sortie non saisis et pas de compteur série
            If [F:ITM]SERMGTCOD=2 & [F:ITM]SERCOU=""
                #MAE, le 27/09/2010, bg 67175, si inter-site et intra-société, pas de n° série a saisir
                If [M:STW]TRFFCY="" & [M:STW]BETCPY = 2
                   If [F:STA]SERNUM=""
                      Call ECR_TRACE(mess(55,198,1)-[F:SID]NUM-"/"-[F:STA]ITMREF-
&                          ":"-mess(312,184,1),1) From GESECRAN
                      GOK=0 : Break 2
                   Endif
                Endif
            Endif
         Next
      Endif
   Next
   If GOK<1 End Endif
Endif

#-- Traitement du détail facture
For [SID]SID0 Where NUM=[F:SIV]NUM
   #-- Ligne non issue d'une livraison
   If [F:SID]SDHNUM = ""
      #-- mais issue d'une commande
      If [F:SID]SOHNUM<>"" & [F:SID]SOQSEQ<>0
         #-- maj détail commande
         Gosub MAJ_SOQ        : If GOK < 1 : Break : Endif
         #-- maj encours
         If [F:SID]STOMGTCOD>1
            Gosub ENCOURS     : If GOK < 1 : Break : Endif
         Endif
      Endif
   Endif
   # Ligne géré en stock
   If [F:SID]STOMGTCOD<>1
      # Si facture de livraison et livraison non encore lu
      # lecture livraison pour savoir s'il s'agit d'un prêt
      If [F:SIV]SIHORI=3 & [F:SID]SDHNUM<>"" & [F:SIV]SIHORINUM = ""
         Raz WLND     :  # 87050 : Facturation livraison de prêt : Pb init WLND
         If [F:SDH]SDHNUM<>[F:SID]SDHNUM
            #Raz WLND :  # 87050 : Facturation livraison de prêt : Pb init WLND
            Read [SDH]SDH0=[F:SID]SDHNUM
            If !fstat & [F:SDH]LND=2
               WLND = [F:SDH]LND
            Endif
# 87050 : Facturation livraison de prêt : Pb init WLND
         Elsif [F:SDH]LND=2
            WLND = [F:SDH]LND
# 87050 : Facturation livraison de prêt : Pb init WLND
         Endif
      Endif

      # Si facture diverse ou de commande #
      # ou ligne directe d'un facture de livraison
      # ou facture d'une livraison de prêt
      # Traitement des stocks
      If find([F:SIV]SIHORI,1,2) | ([F:SIV]SIHORI=3 & [F:SID]SDHNUM="") |
&        ([F:SIV]SIHORI=3 & [F:SID]SDHNUM<>"" & WLND=2)
         # Recalcul du prix de revient
         Gosub MAJ_SID
         If GOK < 1 Break Endif
         # Chargement écran travail pour interface maj stock
         Gosub CHARGE_STW
         # Facture livraison de prêt
         If [F:SIV]SIHORI=3 & [F:SID]SDHNUM<>"" & WLND=2
            LORI = 10
         Else
            LORI = 1
         Endif
         LQTY = [F:SID]QTYSTU
         # Interface pour la maj des stocks
         Call ALISTOWORK(LORI,0,LQTY,LSHT,LNBR,LNBJ,LRET) From STKINT
         If LRET=0
            # La qté à facturer est différente de la qté allouée + rupture
            If LQTY+LSHT <> [F:SID]QTYSTU
               Call ECR_TRACE([F:SIV]NUM-[F:SID]ITMREF+"\"+mess(255,192,1),1)
&                            From GESECRAN
               Raz GOK : Break
            Endif
            # Mise à jour des stocks
            Call MAJ_STOCK From STKMAJ
            If GOK < 1 Break Endif
         Else
            Raz GOK : Break
         Endif
      Endif
   Endif
Next

End

# 107888 : Scheduled invoices : (LD:14/09/16)
#-----------------------------------------------------------------------#
# Posting of an invoice tied to scheduled invoices                      #
# --> Update of the orders tied to the scheduled invoice                #
#-----------------------------------------------------------------------#
$INVOICE_POSTING_UPD_SOH

Local Char     SYMBOLE2(50)
Local Decimal  WMOINSSTU

If !clalev ([F:SOQ]) : Local File SORDERQ    [SOQ] : Endif

Raz GMESSAGE

#-- Traitement du détail facture
For [SID]SID0 Where NUM=[F:SIV]NUM
    If [F:SID]SOHNUM<>"" & [F:SID]SOQSEQ<>0
      #-- maj détail commande
      #-- maj encours article
      Gosub MAJ_SOQ        : If GOK < 1 : Break : Endif
    Endif
Next

Return
# 107888 : Scheduled invoices : (LD:14/09/16)

#-----------------------------------------------------------------------#
#    Mise a jour détail commande                                        #
#-----------------------------------------------------------------------#
$MAJ_SOQ
Local Integer WRET
If !clalev ([F:SOH]) Local File SORDER [SOH] Endif

#--> lock de la commande entière
SYMBOLE2 = "SOH"+[F:SID]SOHNUM
Lock = SYMBOLE2 With lockwait=0
If   fstat=1
     GOK=-1
     If GTRACE <> ""
         Call ECR_TRACE([F:SID]SOHNUM-mess(10,100,1),1) From GESECRAN
     Else
        GERR=1 : GMESSAGE = [F:SID]SOHNUM-mess(10,100,1)
     Endif
     Return
Endif
#--> décrémentation en-cours livraison et incrémentation livré
Readlock [SOQ]SOQ0 = [F:SID]SOHNUM; [F:SID]SOPLIN; [F:SID]SOQSEQ
If   fstat
     GOK=0
     Call RSTA("SOQ",[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)) From GLOCK
     Return
Endif

WMOINSSTU = min([F:SID]QTYSTU,[F:SOQ]QTYSTU-[F:SOQ]INVQTYSTU)

[F:SOQ]ODLQTY    -= [F:SID]QTY
[F:SOQ]ODLQTYSTU -= [F:SID]QTYSTU
[F:SOQ]INVQTY    += [F:SID]QTY
[F:SOQ]INVQTYSTU += [F:SID]QTYSTU

Rewrite [SOQ]
If fstat : GOK=0 : Call FSTA("SOQ") From GLOCK : Return : Endif
Unlock =SYMBOLE2

# Maj de l'en-cde client dans les mouvements article
# --> Si cde signée ou Si paramètre maj encours article cde non signée à Oui
# --> Si article géré en stock
If [F:SOH]SOHNUM<>[F:SID]SOHNUM
    Read [SOH]SOH0 =[F:SID]SOHNUM
    If fstat
        GOK=0
        Call RSTA("SOH", [F:SID]SOHNUM) From GLOCK
        Return
    Endif
Endif
If ([F:SOH]APPFLG>2 | GSOHAPPORD=2) & [F:SOQ]STOMGTCOD <> 1
    #WMOINSSTU = [F:SID]QTYSTU
    # Si commande soldée et c'est la dernière facture --> solde de l'en-cours
    #If [F:SOQ]SOQSTA=3 & [F:SOQ]ODLQTYSTU=0
    #   WMOINSSTU += max(0,[F:SOQ]QTYSTU-[F:SOQ]INVQTYSTU)
    #Endif
    Call MAJITVVEN([F:SOQ]ITMREF,[F:SOQ]STOFCY,WMOINSSTU,"-","S",WRET) From TRTVENMAJ
    If GOK < 1 Return Endif
    #--------------
Endif

Return

