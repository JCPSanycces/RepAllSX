  [F:SIH]EXPNUM = [C]EXPORT
Endif
# FGR 06/11/2009 : X3SUIVI59068 (fin)
[F:SIH]STA=3
Rewrite [SIH]
If fstat
  GOK=0 : Call FSTA("SIH") From GLOCK : Goto AB_TRT1
Endif

# FGR 06/11/2009 : X3SUIVI59068 (début)
If dim([F:SIV]UPDDAT) > 0 Then
  [F:SIV]UPDDAT = date$
Endif
If dim([F:SIV]UPDUSR) > 0 Then
  [F:SIV]UPDUSR = GUSER
Endif
