If GTRACE<>""
    Call ECR_TRACE(mess(120,150,1)-mess(742,197,1)-[F:SIH]NUM,0) From GESECRAN
    Call ECR_TRACE(mess(40,107,1)-WNUMEROS,0) From GESECRAN
Else

Endif
#-----
# Dde 59109 : Localisation Polonaise


#   ------------------------------------------------------------- #
#   Spécificité USA : Branchement du sous-pro de calcul des taxes #
#   ------------------------------------------------------------- #
#   Branchement du sous-pro pour stocker les montants de taxes    #
#   Ceci uniquement pour les factures et les avoirs               #
#   ------------------------------------------------------------- #
#   Brancher en dernier si la facture a bien été validée
    Local Integer LOK
#    If GLOCUSATAX                           #101381.O     Global Variable not ALWAYS PROPERLY SET DURING INVOICE VALIDATION. # 106867.so
#    Local Integer USATAXABLE                                     #101381.ns
#    USATAXABLE = func TRTTAXUSA.GET_GLOCUSATAX([F:SIH]FCY)
#   If USATAXABLE                                                #101381.ne   # 106867.eo
    If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
        If find([F:SIV]INVTYP, 1,2)
            Gosub VALID_SIV_USA From TRTTAXSST   # 106867.n
            # Gosub VALID_SIV_USA From TRTTAXUSA   # 106867.o
            If ORI=1 & GMESSAGE <> "" & !GIMPORT
                Call MESSAGE(GMESSAGE) From GESECRAN
                Raz GMESSAGE
            Endif
            If GOK<0   : Goto ROL_TRT1
            Elsif !GOK : Goto AB_TRT1
            Endif
        Endif
    Endif

