#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################
#                                                                       #
# TRAITEMENT de VALIDATION de FACTURE  -    TRTVENFACV                  #
#                                                                       #
#########################################################################
#                                                                       #
# ACTIONS MODELISEES E-COMMERCE :                                       #
#-----------------------------------------------------------------------#
# Traitement standard (GTRAITE)                                         #
#-----------------------------------------------------------------------#
#                                                                       #
# TRTVALSIH   : Validation d'une facture                                #
#                                                                       #
#*X3-39795  MDJ  Manage ORIGIN and ORICOD fields in GL Entry
#########################################################################
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
Case ACTION
 When "INIT"    : TMP=1: TIT=mess(1,100,1)
 When "EXEC"    : Gosub EXEC
 When "TERMINE" : If GTRACE <> "" Call FERME_TRACE From LECFIC : TRA=1 Endif
Endcase
Return
#########################################################################
#    Détail des actions                                                 #
#########################################################################
#########################################################################
$EXEC
Close Local File [REP], [PRS], [SPK]
Call VALIDATION(1,[M:SIH0]NUM) From TRTVENFACV
Local File SALESREP [REP]
Local File PRICSTRUCT [PRS]
Local File SPRICLINK [SPK]
Return
#########################################################################
# TRTVENFACV : Validation de la facture
#   - M.a.j. du stock (pour factures directes et cdes)
#   - M.a.j. du mouvement client
#   - Repartition des taxes à la ligne
#      (pas de raz des bases taxes des lignes)
#   - M.a.j. des echeances reglees par les acomptes
#   - Choix du paramétrage de pièce (si paramétrage spécifiques pour avoirs)
#   - Création de pièce comptable
#   - M.a.j. flag passage en comptabilité
#########################################################################
# Garnir
# [F:SIH]  CUR CURTYP VAC
# [F:SIV]  INVDAT PRITYP INVDTA INVDTAAMT
# [M:SIHX] LIGNE (JNOL)
# [M:SIH4] ITMREF NETPRI QTY CLCAMTx VATx
# [M:SIH4] VATx RATTAXLIN BASTAXLINx AMTTAXLINx AMTNOTLIN AMTATILIN
#########################################################################
# Masque SIHV : Tableau des taxes XV
#------------------------------------------------------------------------
# XVSHO     : libelle reduit de la taxe
# XVNOT     : montant HT pour cette taxe
# XVSMI     : montant net soumis (XVSMIP+XVSMIF+XVSMITP+XVSMITS)
# XVSMIP    : montant soumis produit
# XVSMIF    : montant soumis pied de la ligne
# XVSMITP   : montant soumis taxe parafiscale
# XVSMITS   : montant soumis taxe spéciale
# XVRAT     : taux de taxe
# XVAMT     : montant de la taxe principale
# XVSUP     : montant cumulé des taxes annexes (soumises ou non)
# XVATI     : montant TTC
# XVTAX     : code taxe
# XVTYP     : type taxe (1=tva 2=para 3=speciale)
# XVCHA     : taxe supplementaire soumise (1=non 2=oui)
# XVBAS     : montant soumis (1=ht 2=montant1 3=montant2)
# XVPRO     : total des lignes pour prorata dans les lignes (saupoudrage)
#------------------------------------------------------------------------
# Masque SIHV : Bloc liste
#------------------------------------------------------------------------
# NHT       : nbre lignes ht a traiter - 1 (pour boucle)
#########################################################################

Subprog VALIDATION(ORI,LNUM)
Value Integer ORI  : # 1=appel de objet SIH / 2=appel de FUNCFMINV (m.a.j. globale)
Value Char    LNUM

Local Integer JL, JLL, WSENS, JNOL, JLRG, JLRG1, OK, WRETOUR, WINVTYP
Local Integer JLC       : # compteur nbre de lignes concernées par saupoudrage
Local Integer JLBM      : # indice ligne ayant la base de taxe maxi (pour saupoudrage)
Local Decimal TOTLIG    : # cumul des montants de la taxe dans les lignes
Local Decimal TOTLIG1
Local Decimal BASTAXMAX : # mt + grande base taxable d'une ligne (pour saupoudrage)
Local Decimal REPARTIR  : # montant à repartir
Local Decimal UNITEREP  : # unite de repartition
Local Char    WMESSAGE(250), IDENT(30), WTRANSAC(10)
Local Char    SYMBOLE1(50)
Local Char    WPCEAUTO(GLONGAU)
Local Char    SYMBOL2 : Raz SYMBOL2   :#FQ 64832
Local Integer WRET                    :#FQ 64832

IDENT=LNUM

# Dde de Cyrille le 030604 : Afficher toujours la trace
#If ORI=1 & WACTFLG="KIK" Call OUVRE_TRACE(mess(38,191,1))  From LECFIC Endif
#FQ 67229
#If GTRACE="" Call OUVRE_TRACE(mess(38,191,1))  From LECFIC Endif
If ORI=1
  # Appel objet SIH
  Call OUVRE_TRACE(mess(38,191,1))  From LECFIC
Else
  # 2=appel de FUNCFMINV (m.a.j. globale), si autre valeur voir par la suite
  If GTRACE="" Call OUVRE_TRACE(mess(38,191,1))  From LECFIC Endif
Endif
#Fin 67229

# --> Lecture entete facture
Read [SIH]SIH0=LNUM
If fstat : GOK=0 : Call RSTA("SIH",LNUM) From GLOCK : End : Endif
WINVTYP=[F:SIH]INVTYP
Read [SIV]SIV0=LNUM
If fstat : GOK=0 : Call RSTA("SIV",LNUM) From GLOCK : End : Endif

# -- le client facture doit etre actif (contrôle supprime : bug 12782)
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
Read [BPC]BPC0=[F:SIH]BPR
#If [F:BPC]BPCSTA<>2
#  WMESSAGE=mess(66,100,1)-LNUM-"("-mess(4,119,1)-")"
#  If ORI=2
#    Call ECR_TRACE(WMESSAGE,1) From GESECRAN
#  Else
#    GERR=1 : GMESSAGE=WMESSAGE
#  Endif
#  End
#Endif

# Issue 115715 - 2016-04-05 by RICAR : POR Leg.: debit notes without reference period
# Issue 114715
If func AFNC.ACTIV("KPO")
#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
#If find([F:SIH]INVTYP,2,4) & func AFNC.ACTIV("KPO")
# End issue 115715
  If func PORLEGLIB.DIGSIGN([F:SIV]SALFCY, "")
    Gosub VLD_CREDIT_NOTE_SIH From PORLEGLIB
    If GOK = 0 : End : Endif
  Endif
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - END
#119503 JOBRO - If applicable, check for valid Sage Exchange Authorization
If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SIH]PTE)  #Sage exchange active and SE payment method
    If not func SEPPLIB2.INVOICE_AUTH_CHECK([F:SIH]NUM)
      GOK=0
      If GTRACE<>""
        Call ECR_TRACE([F:SIH]NUM-":"-mess(35,2092,1),1) From GESECRAN
      Else
        GMESSAGE = [F:SIH]NUM-":"-mess(35,2092,1)
        GERR=1
      Endif
      End
    Endif
Endif
#End 119503
#---------------------------------
#FQ 64832
#Le problème était que le unlock délockait le lock posé par l'objet
#et ceci (pour le pb soulevé par la fiche) quelque soit la réussite ou l'échec du ttt
#----- Contrôle lock logique -----#
Call JELOCKE("SIV"+[F:SIV]NUM,WRET) From OBJDIV
If [L]WRET=0
    SYMBOL2="SIV"+[F:SIV]NUM : Lock=SYMBOL2
    If fstat
        Raz SYMBOL2
        If GTRACE<>""
          Call ECR_TRACE("$SINVOICEV :"-[F:SIV]NUM-mess(10,100,1),1) From GESECRAN
          GOK=0 : End
        Else
          If GMESSAGE <> "" GMESSAGE += "\" Endif
          GOK=0 : GMESSAGE += [F:SIV]NUM-mess(10,100,1) : GERR=1 : End
        Endif
    Endif
Endif

#SYMBOLE1 = "SIV"+[F:SIV]NUM
#Lock = SYMBOLE1
#If fstat
#   # modification en cours sur un autre poste
#   Call ECR_TRACE("$SINVOICEV :"-[F:SIV]NUM-mess(10,100,1),1) From GESECRAN
#   GOK=0 : End
#Endif
#Unlock = SYMBOLE1

#fin FQ 64832
#---------------------------------

# --> Appel Transaction
Call DEBTRANS From GLOCK
Gosub TRT1

# Issue 111411 - 2015-09-30 by CPO : Modèle comptable avec une ordre des référentiels différent du standard
# Complément du 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED (repris TRTACHFAC1)
# on restaure la valeur car peut-être écrasé dans ss-pro de compta
For I=1 To 10
    GTYPLED(I)=GTYPLED_X3TC(I)
Next I
# End issue 111411

# Il y a eu un problème
#FQ 64832
#If GOK<1 End Endif
If GOK<1
  #--- Lors de 71559
  #If SYMBOL2<>"" : Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
  #End
  Goto END_VALIDATION
Endif

# FGR 04/01/2011 : X3SUIVI70100 (début) déplacé dans la transaction
# Si présence module Support Client, gestion du parc client
#    si facture directe avec m.a.j. stock
#    si facture de commande
#    si facture de livraison (lignes ajoutées et livraisons de prêt)
#If GMODU(12)=2
#   If [F:SIV]INVTYP=1 & ([F:SIV]SIHORI=1 & [F:SIV]STOMVTFLG=2) |
#&     [F:SIV]SIHORI=2 | [F:SIV]SIHORI=3
#      Gosub TRT_MACRULE
#   Endif
#Endif
# FGR 04/01/2011 : X3SUIVI70100 (fin) déplacé dans la transaction

# --> Si inter-société et flux autorisé : creation de facture achat correspondante
#     ssi facture issues de liv. de cdes ou issues de cdes avec flux automatique (ORIFCY<>SALFCY)
#         facture issues de liv. directes (ORIFCY="")
#     Hors de la transaction creation facture vente : pas de blocage vente si erreur sur
#     facture achat. Transaction séparée pour création facture achat

# 92732 : Création de factures d'achat inter-site
# Point d'entrée permettant la creation de factures d'achat inter-site
Local Integer WPE_CREPIH : Raz WPE_CREPIH
GPOINT ="CREPIH" : Gosub ENTREE From EXEFNC
#If [F:SIV]BETCPY=2 & [F:SIV]PIHNUM="" & [F:SIV]ORIFCY<>[F:SIV]SALFCY
If ([F:SIV]BETCPY=2 & [F:SIV]PIHNUM="" & [F:SIV]ORIFCY<>[F:SIV]SALFCY) | WPE_CREPIH
# 92732
   Local Char    LPOHFCY (GLONFCY)  : # site achat
   Local Integer FLUX_OK            : # 0=interdit / 1=autorise
   Local Integer WTRFPRI            : # Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
   Call ALIBETCPY (5,[F:SIV]SALFCY,[F:SIV]BPCINV,GBIDC1,LPOHFCY,GBIDC2,GBIDI1,GBIDI1)
&                 From TRTVENISOC
   # Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
   #Call IS_FLUX (5,[F:SIV]SALFCY,LPOHFCY,FLUX_OK) From FUNBCH
   Call IS_FLUX (5,[F:SIV]SALFCY,LPOHFCY,WTRFPRI, FLUX_OK) From FUNBCH
   # Issue 26113 - 20150707 by LD : Inter-site : Price recalculation
# 92732 : Création de factures d'achat inter-site
#   If FLUX_OK
   If FLUX_OK | WPE_CREPIH
# 92732
      Local Char    WNDO : WNDO=[F:SIV]NUM   :  # no facture vente
      Local Integer WCOD : WCOD=2            :  # 2=creation facture
      Local Char    WTRT : WTRT="TRTACHFAC2" :  # traitement
      Local Integer WTRA : WTRA=2            :  # 2=oui
      Local Integer WRET                     :  # 0-1=ok / 2-99= erreur+GMESSAGE
      #--CPO 79834 Désactivation des contrôles sur les autorisations
      #------- CPO 71559 Droits en génération de facture achat inter-société
      Local Char WSAVGFONCTION(type(GFONCTION)-10)
      WSAVGFONCTION=GFONCTION
      Local Char WSAVGABREV(type(GABREV)-10)     # FGR 30/01/2014 : X3SUIVI94078
      WSAVGABREV = GABREV                        # FGR 30/01/2014 : X3SUIVI94078

      #--- Pas de contrôle en sortie du Call AUTORIS car l'objectif est de positionner
      #--- les globales avec les autorisations correspondantes à la fonction GESPIH
      #--- Les contrôles seront fait par la suite, en genération de la facture achat
      GFONCTION="GESPIH" : Call AUTORIS From EXEFNC

      If dim(GDIMSIT)>0 and GNBAUZ<GDIMSIT
        GUSRAUZ(GNBAUZ+1) = "CMNS"
        GUSRFCY(GNBAUZ+1) = LPOHFCY
        GNBAUZ     += 1
      Endif
      #--/
      Call GENERE_PIH (WNDO,WCOD,WTRT,WTRA,WRET) From TRTACHFAC2

      #--CPO 79834 Désactivation des contrôles sur les autorisations
      #------- CPO 71559 Il faut restaurer le GFONCTION et refaire le Call AUTORIS
      GFONCTION = WSAVGFONCTION : Call AUTORIS From EXEFNC
      #--/
      GABREV = WSAVGABREV                        # FGR 30/01/2014 : X3SUIVI94078
   Endif
Endif

#--- Lors de 71559
$END_VALIDATION
If SYMBOL2<>"" : Unlock=SYMBOL2 : Raz SYMBOL2 : Endif :#FQ 64832

End

#########################################################################
#########################################################################
# Transaction
#########################################################################
#########################################################################
$TRT1
#*X3-39795Local Char    TZONE(10)(1..3) : # Table des zones à forcer (Ex: type de pièce)
#*X3-39795Local Char    TVAL(10)(1..3)  : # Table des valeurs des zones à forcer
Local Char     TZONE(10)(1..10) : # Table des zones à forcer (Ex: type de pièce)
Local Char     TVAL(30)(1..10)  : # Table des valeurs des zones à forcer
Local Char     TMESSA(100)(1..10) : # Dde 59109 : Localisation Polonaise
Local Integer  FVAL(1..10)        : # Dde 59109 : Localisation Polonaise
Local Integer  NBRVCR, INDVCR     : # Dde 59109 : Localisation Polonaise
Local Char     WNUMEROS(250)      : # Dde 59109 : Localisation Polonaise
Local Char     LEGIS(GLONADI)

GOK=1
Trbegin [SIH]
#------------------------------------------------------------------------
#-- Verrouillage entete facture
Readlock [SIH]SIH0=LNUM
If    fstat=1 : GOK=-1 : GLOCK="$SINVOICE"+LNUM           : Goto ROL_TRT1
Elsif fstat   : GOK=0  : Call RSTA("SIH",LNUM) From GLOCK : Goto AB_TRT1
Endif

Readlock [SIV]SIV0=LNUM
If    fstat=1 : GOK=-1 : GLOCK="$SINVOICEV"+LNUM          : Goto ROL_TRT1
Elsif fstat   : GOK=0  : Call RSTA("SIV",LNUM) From GLOCK : Goto AB_TRT1
Endif
# --> Alimentation GFINRSP
Call GETDEV([F:SIV]SALFCY) From DEVSUB
# --- Chargement paramètre Etalement des prestations -----#
Local  Char    PARAM2(10)
If func AFNC.ACTIV("KIT")
    Call PARAML([F:SIV]SALFCY,"ITAPRE",PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
    GLOCITAPRE=val(PARAM2)
    If GLOCITAPRE>0  GLOCITAPRE-=1 : Endif
Else
    Raz GLOCITAPRE
Endif
# --> Alimentation paramètres stock (No transaction livraison (GTRSVENLIV))
If [F:SIV]STOFCY <> "" Call GLOBSTOFCY([F:SIV]STOFCY) From TRTVENGLOB Endif

#------------------------------------------------------------------------
# Mise a jour du stock
# uniquement si type facture
# si facture directe avec m.a.j. stock  (SIHORI=1)
# si facture de commande  (SIHORI=2)
# si facture de livraison (lignes ajoutées et livraisons de prêt) (SIHORI=3)
If [F:SIV]INVTYP=1
  If ([F:SIV]SIHORI=1 & [F:SIV]STOMVTFLG=2) | [F:SIV]SIHORI=2 | [F:SIV]SIHORI=3
    Call LES_STOCKS
    If GOK<0   : Goto ROL_TRT1
    Elsif !GOK : Goto AB_TRT1
    Endif
  Endif
Endif

# 107888 : Scheduled invoices : (LD:14/09/16)
# Invoice tied to scheduled invoices
# --> Update of the orders tied to the scheduled invoices
If [F:SIV]INVTYP=1 & [F:SIV]SIHORI=10 & [F:SIV]SIHORITYP=10 & [F:SIV]SIHORINUM<>""
    Gosub INVOICE_POSTING_UPD_SOH
    If GOK<0   : Goto ROL_TRT1
    Elsif !GOK : Goto AB_TRT1
    Endif
Endif
# 107888 : Scheduled invoices : (LD:14/09/16)

#------------------------------------------------------------------------
# Mise a jour des mouvement client (diminution facture non comptabilise)
Local Char SIGNE (1)
Local Char WTYPMVC # FGR 06/08/2009 : X3SUIVI57009

If [F:SIH]INVTYP=1
  SIGNE="-"
  WTYPMVC = "I"     # FGR 06/08/2009 : X3SUIVI57009 Facture
Else
  SIGNE="+"
  WTYPMVC = "N"     # FGR 06/08/2009 : X3SUIVI57009 Avoir
Endif

Local Decimal WCOURS : WCOURS=0
If [F:SIH]RATDIV(GTYPGEN-1)<>0 WCOURS=arr([F:SIH]RATMLT(GTYPGEN-1)/[F:SIH]RATDIV(GTYPGEN-1), 10^-GDECRCU) : Endif
#Call  MAJMVC ([F:SIV]BPCINV, [F:SIH]CUR, [F:SIH]CURTYP, WCOURS, [F:SIV]INVDAT, [F:SIV]NUM, [F:SIV]SALFCY,
#&   0, [F:SIH]AMTATI, SIGNE, "I", "V", 0) From TRTBPMVT
Call  MAJMVC ([F:SIV]BPCINV, [F:SIH]CUR, [F:SIH]CURTYP, WCOURS, [F:SIV]INVDAT, [F:SIV]NUM, [F:SIV]SALFCY,
&   0, [F:SIH]AMTATI, SIGNE, WTYPMVC, "V", 0) From TRTBPMVT   # FGR 06/08/2009 : X3SUIVI57009

If GOK<0   : Goto ROL_TRT1
Elsif !GOK : Goto AB_TRT1
Endif

#------------------------------------------------------------------------
# ajustement des montants de taxes à la ligne
# suppression bases de calcul taxes à la ligne (excepté la première pour US)
Raz [M:SIHV]XVPRO       : # calcul par taxe du cumul dans les lignes

If ORI=2
  Raz [M:SIHV] : Raz [M:SIH4]
  Raz [M:SIH0] : Raz [M:SIH1] : Raz [M:SIH2]
  [M:SIH0] = [F:SIH] : [M:SIH0] = [F:SIV]
  [M:SIH1] = [F:SIH] : [M:SIH1] = [F:SIV]
  [M:SIH2] = [F:SIH] : [M:SIH2] = [F:SIV]
  Gosub CHARGEMENT_SIHV
  # chargement des lignes de la facture dans le tableau de calcul [SIH4]
  JNOL = 0
  For [SID]SID0 Where NUM=[F:SIV]NUM
    JNOL += 1
    Gosub CHARGEMENT_SIH4
  Next
Endif
Gosub TAXES_LIGNES

# mise à jour des lignes factures
JNOL = 0
#For [SID] Where NUM=[F:SIV]NUM With Lock

For [SID]SID0 Where NUM=[F:SIV]NUM

  Readlock [SID] Curr

  If fstat=1
    GOK=-1 : GLOCK="$SINVOICED"-[F:SIV]NUM          : Break
  Elsif fstat
    GOK=0  : Call RSTA("SID",[F:SIV]NUM) From GLOCK : Break
  Endif
  JNOL += 1
  [F:SID]AMTTAXLIN(0) = [M:SIH4]AMTTAXLIN1(JNOL-1)
  [F:SID]AMTTAXLIN(1) = [M:SIH4]AMTTAXLIN2(JNOL-1)
  [F:SID]AMTTAXLIN(2) = [M:SIH4]AMTTAXLIN3(JNOL-1)
# uniquement bases 0 (principalement pour taxes US), 1 (b21720), 2 (b21720) sont conserves
  [F:SID]BASTAXLIN(3)=0 : [F:SID]BASTAXLIN(4)=0 : [F:SID]BASTAXLIN(5)=0
  Rewrite [SID]
  If fstat
    GOK=0 : Call FSTA("SID") From GLOCK
    Break
  Endif
  #TODO 107888 CPO Here, for SIHORI=10 we'll have to set the [SVICDD]INVCNDSTA from 5or6 to 2or3

Next
If GOK<0   : Goto ROL_TRT1
Elsif !GOK : Goto AB_TRT1
Endif
If GMODU(2) = 2    : # Présence du module compta
    #------------------------------------------------------------------------
    # Choix du paramétrage de pièce
    Gosub TRANSAC
    #------------------------------------------------------------------------
    # interface comptable
    Raz GNUMPCE
    Raz TMESSA, TZONE, TVAL                        : # Dde 59109 : Localisation Polonaise
    TZONE(1)="TYP"    : TVAL(1)=[F:SIH]GTE
    TZONE(2)="JOU"    : TVAL(2)=[F:SIH]JOU
    TZONE(3)="TYPDUD" : TVAL(3)="2"
    # (MWA X3-39795)  début
    TZONE(5)="ORIGIN" : TVAL(5)="2"        :#Automatic loading  #*X3-39795
    TZONE(6)="ORICOD" : TVAL(6)=WTRANSAC
    # (MWA X3-39795)  fin

    GFCYDEF=GFCYDEF(2)
    # Dde 59109 : Localisation Polonaise
    #Call VALPCE3(WTRANSAC,IDENT,WRETOUR,WMESSAGE,TZONE,TVAL) From CPTAUTO
    #----- Passage par les groupes de pièces -----#
    Call EVALGRP(WTRANSAC,"NUM","SIH]NUM",FVAL) From VALGRP
    Call VALGRP3(WTRANSAC,IDENT,WRETOUR,TMESSA,TZONE,TVAL,FVAL) From VALGRP
    # Dde 59109 : Localisation Polonaise
    #-----
    GFCYDEF=GFCYDEF(5)
    #-----
    If WRETOUR
      GOK=0
      If GTRACE <> ""
          Call ECR_TRACE(LNUM-TMESSA(1),1) From GESECRAN                       : # Dde 59109 : Localisation Polonaise
      Else
          GERR=1 : GMESSAGE=LNUM-TMESSA(1)                                     : # Dde 59109 : Localisation Polonaise
      Endif
      Goto AB_TRT1
    Endif
    If GNUMPCE="" & [F:SIH]AMTATI<>0
      GOK=0
      If GTRACE <> ""
          Call ECR_TRACE(LNUM-mess(272,199,1),1) From GESECRAN
      Else
          GERR=1 : GMESSAGE=LNUM-mess(272,199,1)
      Endif
      Goto AB_TRT1
    Endif

    # Dde 59109 : Localisation Polonaise
    #----- Màj de la table des liens et chargement de la liste des pièces créées -----#
    Raz WNUMEROS
    NBRVCR= find("",TMESSA(1..dim(TMESSA)))
    For INDVCR=1 To NBRVCR-1
      Call LNKGRP("2",[F:SIH]NUM,[F:SIH]ACCNUM,TMESSA(INDVCR),WRETOUR,WMESSAGE) From VALGRP
      If WRETOUR
        GOK = 0 : Break
      Elsif WNUMEROS=""
        WNUMEROS=WMESSAGE
      Else
        WNUMEROS+=","-WMESSAGE
      Endif
    Next
    If GOK=0  Goto AB_TRT1 : Endif
    # Dde 59109 : Localisation Polonaise

    # Etalement des prestations
    If GLOCITAPRE
      Raz GNUMPCE, WRETOUR, GMESSAGE
      #----- Recherche code pièce auto -----#
      Call PARAML([F:SIH]FCY,"GAUKIK3",WPCEAUTO) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
      If WPCEAUTO=""  WPCEAUTO="KIK3" : Endif
      #-----
      Call TRANSFERT(WPCEAUTO,[F:SIH]NUM,[F:SIH]SIVTYP,WRETOUR) From CPTTRS
      If WRETOUR
          If GTRACE <> ""
              Call ECR_TRACE(GMESSAGE,1) From GESECRAN
          Else
              GERR=1
          Endif
      Endif
      If GOK<0
        Goto ROL_TRT1
      Elsif !GOK | WRETOUR
        GOK = 0
        Goto AB_TRT1
      Endif
    Endif
Endif

#------------------------------------------------------------------------
# affectation des acomptes aux echeances
If sum([F:SIV]INSATI)>0
  Gosub MAJ_ECHEANCES
  If GOK<0   : Goto ROL_TRT1
  Elsif !GOK : Goto AB_TRT1
  Endif
Endif


If GMODU(3) = 2   : # Présence du module tiers
    #------------------------------------------------------------------------
    # Lettrage des avoirs (avec facture origine)
    If [F:SIH]INVNUM<>""
      Call LETAVOIR([F:SIH]NUM,[F:SIH]INVNUM) From SUBBIC
    Endif
Endif

#------------------------------------------------------------------------
# mise à jour de SINVOICE et SINVOICEV (les zones sont OK) les indicateurs
# FGR 06/11/2009 : X3SUIVI59068 (début)
If dim([F:SIH]UPDDAT) > 0 Then
  [F:SIH]UPDDAT = date$
Endif
