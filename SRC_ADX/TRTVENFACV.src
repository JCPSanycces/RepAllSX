#-----------------------------------------------------------------------#
#    Mise à jour détail facture                                         #
#    --> Recalcul du prix de revient et de la marge                     #
#-----------------------------------------------------------------------#
$MAJ_SID
# Bug 43723 : Calcul du prix de revient pour les gratuits
#If [F:SID]NETPRI = 0 & [F:SID]FOCFLG = 3 Return Endif

Local Decimal COUTHT, COUTHTC, WQTY
Local Integer STAT, LOK, WNATPRI

Local Decimal PHTNET              : # 95792 : Variable inexistante dans PE CALPFM
Local Decimal XCRPPRI, XPFM

If clalev([F:ITS])=0 : Local File ITMSALES [ITS] : Endif

If [F:ITM]ITMREF <> [F:SID]ITMREF
   Read [ITM]ITM0 = [F:SID]ITMREF
   If fstat
      GOK=0
      Call RSTA("ITM",[F:SID]ITMREF) From GLOCK
      Return
   Endif
Endif
If [F:ITS]ITMREF <> [F:SID]ITMREF
   Read [ITS]ITS0 = [F:SID]ITMREF
   If fstat
      GOK=0
      Call RSTA("ITS",[F:SID]ITMREF) From GLOCK
      Return
   Endif
Endif

XCPRPRI  = [F:SID]CPRPRI
XPFM     = [F:SID]PFM
PHTNET   = [F:SID]NETPRINOT       : # 95792 : Variable inexistante dans PE CALPFM

WQTY = [F:SID]QTYSTU
# Recalcul du prix de revient
Call DEFCPR ([F:SID]ITMREF,[F:SID]STOFCY,5,[F:SIV]NUM,[F:SID]SIDLIN,-1,
&            [F:SIV]INVDAT,WQTY,COUTHT,LOK) From STKVAL
If LOK = 0
    # Si devise document <> devise base calcul marge (société du site expé)
    If [F:SIV]CUR <> GLOCALDEV & COUTHT <> 0
        # 89253 : Si facture, conversion en utilisant les cours de la facture
        Local Decimal WCOURS : WCOURS=0 : If [M:SIH2]RAT1<>0 WCOURS=arr(1/([M:SIH2]RAT2/[M:SIH2]RAT1), 10^-GDECRCU) : Endif
        Call COURMNT(GLOCALDEV,[F:SIV]CUR,GLOCALDEV,[F:SIH]CURTYP,[F:SIV]INVDAT,0, COUTHT,COUTHTC,WCOURS,STAT) From TRTDEV
        #Call CONVERT (GLOCALDEV, [F:SIV]CUR, GLOCALDEV, [F:SIH]CURTYP, [F:SIV]INVDAT, COUTHT, COUTHTC, STAT) From TRTDEV
        # 89253
        COUTHT=COUTHTC
    Endif
    If COUTHT <> 0 | [F:SID]CPRPRI = 0
        # Le prix de revient est exprimé en US : Le convertir en UV
        COUTHT=COUTHT*[F:SID]SAUSTUCOE

        #  Point d'entree calcul d'un cout supplémentaire pour le calcul de la marge
        Gosub CALSPEPFM From TRTVENPRI

        If GSALRND = 2
            Call ARRDEV(COUTHT,[F:SIV]CUR) From TRTDIV
            XCPRPRI=COUTHT
        Else
            XCPRPRI=arr(COUTHT,10^-GDECPRI)
        Endif
        # Pas de calcul de marge pour les gratuits
        If [F:SID]NETPRI<>0 | [F:SID]FOCFLG<>3
            # Calcul de marge pour les articles vendus ou les articles livrables ayant un prix net
            If [F:ITM]SALFLG=2 | ([F:ITM]SALFLG=1 & [F:SID]NETPRINOT<>0)
                # --> Calcul de la marge
              XPFM = [F:SID]NETPRINOT - XCPRPRI
            Endif
        Endif
    Else
        # Si Prix de revient récupéré à 0 : S'il était renseigné on ne fait rien
    Endif
Endif

# Point d'entree pour recalcul de la marge
Gosub CALSPEPFM1 From TRTVENPRI

Readlock [SID]SID0=[F:SID]NUM;[F:SID]SIDLIN
If fstat
   GOK=0
   Call RSTA("SID", [F:SID]NUM-num$([F:SID]SIDLIN)) From GLOCK
   Return
Endif

[F:SID]CPRPRI= XCPRPRI
[F:SID]PFM   = XPFM

Rewrite [SID]
If fstat : GOK=0 : Call FSTA("SID") From GLOCK : Return : Endif
Return
# Bug 80451

#-----------------------------------------------------------------------#
#    Suppression ou maj de l'encours                                    #
#-----------------------------------------------------------------------#
$ENCOURS
#-- suppression encours si ligne cde soldée
Local  Char     WPJT(20), WSALFCY(GLONFCY), WTRTORD
Local  Decimal  WCPLQTY

WCPLQTY = [F:SOQ]INVQTYSTU

If !clalev ([F:SOH]) Local File SORDER [SOH] Endif
If [F:SOH]SOHNUM <> [F:SID]SOHNUM
   Read [SOH]SOH0=[F:SID]SOHNUM
Endif

WTRTORD = "M"

## Gestion des signatures : Si la cde n'est pas si signée et pas de maj des encours si cde non signée
## Qté prévue = Reste à livrer et non la qté cdée
#If [F:SOH]APPFLG=1 & GSOHAPPORD=1 WTRTORD = "S" Endif

# Si ligne soldée et il n'y a plus d'en-cours de livraison
If [F:SOQ]SOQSTA = 3 & [F:SOQ]ODLQTYSTU = 0
   WTRTORD = "A"
Endif

Gosub APPELWIP From TRTVENMAJ

Return

#-----------------------------------------------------------------------#
# Chargement écran travail pour interface maj stock                     #
#-----------------------------------------------------------------------#
$CHARGE_STW

Raz [M:STW]
[M:STW]STOFCY    = [F:SID]STOFCY
[M:STW]TRSTYP    = 4
[M:STW]VCRTYP    = 5
[M:STW]VCRNUM    = [F:SIV]NUM
[M:STW]VCRLIN    = [F:SID]SIDLIN
[M:STW]ITMREF    = [F:SID]ITMREF
[M:STW]MVTDES    = ""            : # Contenu dans l'allocation
[M:STW]BPRNUM    = [F:SIV]BPCINV
[M:STW]BPAADD    = [F:SIV]BPAADD
[M:STW]CUR       = [F:SIV]CUR
[M:STW]ENTCOD    = [F:SIV]ENTCOD
[M:STW]CCECOD    = "STKFAC"
[M:STW]PJT       = [F:SIV]PJT
[M:STW]TRSFAM    = [F:SIH]TRSFAM
[M:STW]TRSCOD    = [F:SIV]TRSCOD
[M:STW]IPTDAT    = [F:SIV]INVDAT
[M:STW]TRFFCY    = ""
[M:STW]TRFFCY    = ""
[M:STW]BETCPY    = 1

Raz WLND
If [F:SIV]SIHORI=3
   If [F:SIV]SIHORINUM<>""
      Read [SDH]SDH0=[F:SIV]SIHORINUM
      If !fstat & [F:SDH]LND=2
         WLND=[F:SDH]LND
      Endif
   Else
      If [F:SDH]SDHNUM<>[F:SID]SDHNUM
         #Raz WLND    : # 87050 : Facturation livraison de prêt : Pb init WLND
         Read [SDH]SDH0=[F:SID]SDHNUM
         If !fstat & [F:SDH]LND=2
            WLND = [F:SDH]LND
         Endif
# 87050 : Facturation livraison de prêt : Pb init WLND
      Elsif [F:SDH]LND=2
         WLND = [F:SDH]LND
# 87050 : Facturation livraison de prêt : Pb init WLND
      Endif
   Endif
Endif

# Si facture d'une livraison de prêt
If [F:SIV]SIHORI=3 & [F:SID]SDHNUM<>"" & WLND=2
   [M:STW]VCRTYPORI = 4
   [M:STW]VCRNUMORI = [F:SID]SDHNUM
   [M:STW]VCRLINORI = [F:SID]SDDLIN
   [M:STW]VCRSEQORI = 0
# Si facture d'une commande
Elsif [F:SIV]SIHORI=2 & [F:SID]SOHNUM<>""
   [M:STW]VCRTYPORI = 2
   [M:STW]VCRNUMORI = [F:SID]SOHNUM
   [M:STW]VCRLINORI = [F:SID]SOPLIN
   [M:STW]VCRSEQORI = [F:SID]SOQSEQ
Else
   [M:STW]VCRTYPORI = 0
   [M:STW]VCRNUMORI = ""
   [M:STW]VCRLINORI = 0
   [M:STW]VCRSEQORI = 0
Endif
[M:STW]PRIORDH   = 0
[M:STW]PRIPUR    = 0
[M:STW]SEQ       = 0

Return

#---------------------------------------#
#   Gestion du parc client              #
#---------------------------------------#
$TRT_MACRULE
Local Integer I, WTYP, WRET, WERR
Local Char    WSERNUM(GLONSER), WSERNUMF(GLONSER)
Local Integer IBTRTMAC
Local Integer INBMAC

  Raz WRET
  IBTRTMAC = 0
  INBMAC = 0
  If !clalev ([M:MACW]) : Local Mask MACW   [MACW] : Endif
  If !clalev ([F:STJ])  : Local File STOJOU [STJ]  : Endif
  If !clalev ([F:MACL]) : Local File MACHINES   [MACL] : Endif
  # FGR 31/01/2012 : X3SUIVI78319 (début) : Création du WTYP=8 pour "Validation de facture"
  #WTYP=2
  WTYP = 8
  # FGR 31/01/2012 : X3SUIVI78319 (fin)
  # Facture d'un prêt
  If [F:SIV]SIHORI=3 & [F:SIV]SIHORINUM<>""
    Read [SDH]SDH0=[F:SIV]SIHORINUM
    If !fstat & [F:SDH]LND=2
      WTYP=5
    Endif
  Endif
  For [SID]SID0 Where NUM=[F:SIV]NUM
    Read [ITM]ITM0 = [F:SID]ITMREF
    If fstat Then
      Raz [F:ITM]
    Endif
    If [F:SID]SAUSTUCOE=0 Then
      [F:SID]SAUSTUCOE=1
    Endif
    IBTRTMAC=1
    #MODIF LSE FQ37707
    #On regarde si parc déjà créer dans cas livraison
    If [F:SIV]SIHORI=3
      If [F:SID]SDHNUM<>""
        If [F:ITM]SERMGTCOD < 2
          INBMAC=0
          For [MACL] Where [F:MACL]MACPDTCOD=[F:SID]ITMREF
&                      and [F:MACL]MACORI=3 and [F:MACL]MACORIVCR= [F:SID]SDHNUM
&                      and [F:MACL]MACORIVCRL= [F:SID]SDDLIN
            INBMAC=INBMAC+1
            Break
          Next
          If INBMAC>0
            IBTRTMAC=0
          Endif
        Endif
      Endif
    Endif
    If IBTRTMAC=1
      If [F:ITM]SERMGTCOD < 2
        # Pas de gestion des no série
        Gosub CHARGE_MACW
        # Appel au composant d'intégration
        Call MACRULE(WTYP,[F:SIV]BPCORD,WRET) From TRTMACRULE
        If WRET Then
          Gosub ERR_MACRULE
          Break                         # FGR 04/01/2011 : X3SUIVI70100
        Endif
      Else
        # Gestion des no séries
        For [STJ]STJ1 Where STOFCY=[F:SIV]STOFCY & VCRTYP=5 & VCRNUM=[F:SID]NUM
&                         & VCRLIN=[F:SID]SIDLIN & REGFLG<>2 & QTYSTU<0
          # No série géré en sortie
          If [F:ITM]SERMGTCOD = 2
            WSERNUM = [F:STJ]SERNUM
            Gosub CHARGE_MACW
            # Appel au composant d'intégration
            Call MACRULE(WTYP,[F:SIV]BPCORD,WRET) From TRTMACRULE
            If WRET
              Gosub ERR_MACRULE
              Break                     # FGR 04/01/2011 : X3SUIVI70100
            Elsif abs([F:STJ]QTYSTU)>=2
              For I=2 To abs(int([F:STJ]QTYSTU))
                Call PLUS_UN(WSERNUM,WSERNUMF,WRET) From STKLIB
                If WRET Then
                  Break 3
                Endif
                WSERNUM = WSERNUMF
                Gosub CHARGE_MACW
                # Appel au composant d'intégration
                Call MACRULE(WTYP,[F:SIV]BPCORD,WRET) From TRTMACRULE
                If WRET Then
                  Gosub ERR_MACRULE
                  Break
                Endif
              Next I
              If WRET Then              # FGR 04/01/2011 : X3SUIVI70100
                Break
              Endif
            Endif
          Else
            WSERNUM = [F:STJ]SERNUM
            Gosub CHARGE_MACW
            # Appel au composant d'intégration
            Call MACRULE(WTYP,[F:SIV]BPCORD,WRET) From TRTMACRULE
            If WRET Then
              Gosub ERR_MACRULE
              Break                     # FGR 04/01/2011 : X3SUIVI70100
            Endif
          Endif
        Next
        If WRET Then                    # FGR 04/01/2011 : X3SUIVI70100
          Break
        Endif
      Endif
    Endif
  Next
Return

# Traitement des erreurs
$ERR_MACRULE
  GOK = 0                               # FGR 04/01/2011 : X3SUIVI70100
  If WERR=0
    Call ECR_TRACE (mess(90,182,2),0)   From GESECRAN
    WERR=1
  Endif
  If WSERNUM=""
    Call ECR_TRACE ([F:SID]ITMREF-":"-mess(WRET,182,2),0) From GESECRAN
  Else
    Call ECR_TRACE ([F:SID]ITMREF-WSERNUM-":"-mess(WRET,182,2),0) From GESECRAN
  Endif
Return

# Chargement du masque [MACW]
$CHARGE_MACW
  Raz [M:MACW]
  [M:MACW]MACPDTCOD  = [F:SID]ITMREF
  [M:MACW]MACORIVCR  = [F:SID]NUM
  [M:MACW]MACORIVCRL = [F:SID]SIDLIN

  [M:MACW]SALFCY     = [F:SIV]SALFCY
  # FGR 17/04/2012 : X3SUIVI81629 (début)
  If clalev ([F:FCY])<=0 Local File FACILITY [FCY] : Endif
  If [M:MACW]SALFCY <> "" Then
    # Déduit le code société
    Read [FCY]FCY0=[M:MACW]SALFCY
    If !fstat Then
      [M:MACW]CPY = [F:FCY]LEGCPY
    Endif
  Endif
  # FGR 17/04/2012 : X3SUIVI81629 (fin)

  [M:MACW]FCYITN     = [F:SIV]BPAADD
  [M:MACW]CUR        = [F:SIV]CUR
  # FGR 28/08/2012 : X3SUIVI82665 (début)
  #[M:MACW]MACSALPRI  = [F:SID]NETPRINOT  # FGR 02/11/2011 : X3SUIVI77136 : on ne divise pas le parc #/[F:SID]SAUSTUCOE
  # FGR 28/08/2012 : X3SUIVI82665 (fin)
  If WTYP=5
    [M:MACW]PREORI     = 3
    [M:MACW]PREORIVCR  = [F:SID]SDHNUM
    [M:MACW]PREORIVCRL = [F:SID]SDDLIN
  Endif
  [M:MACW]MACPURDAT  = [F:SIV]INVDAT
  [M:MACW]MACITNDAT  = [F:SIV]INVDAT
  If [F:ITM]SERMGTCOD < 2
    [M:MACW]MACQTY     = [F:SID]QTYSTU
    [M:MACW]MACSALPRI  = [F:SID]AMTNOTLIN                                       # FGR 28/08/2012 : X3SUIVI82665
  Else
    [M:MACW]MACQTY     = 1
    [M:MACW]MACSERNUM  = WSERNUM
    [M:MACW]MACSALPRI  = arr([F:SID]NETPRINOT / [F:SID]SAUSTUCOE,10^-GDECPRI)   # FGR 28/08/2012 : X3SUIVI82665
    Call ARRDEV([M:MACW]MACSALPRI, [M:MACW]CUR) From TRTDIV                     # FGR 28/08/2012 : X3SUIVI82665
  Endif

  [M:MACW]VACBPR = [F:SIH]VAC          # Issue X3-68002 - 2018-02-22 by FGR

  # FGR 12/11/2009 : X3SUIVI56282 (début) arr(NET,10^-GDECPRI)
  Local Char SZMACWCNT(GLONDES)
  Local Char SZMACWPRE(GLONDES)

  SZMACWCNT = "TRTVENFACV"
  SZMACWPRE = ""
  Gosub PE_MACWAUTO From TRTCRMPE
  # FGR 12/11/2009 : X3SUIVI56282 (fin)
Return


#########################################################################
##### A supprimer #######################################################
#########################################################################

#-----------------------------------------------------------------------#
#    Maj des no série (facture de prêt)                                 #
#-----------------------------------------------------------------------#
$MAJ_STS_PRE

# Traitement automatique no série
# Attention s'il sont géré uniquement en sortie, on ne fait rien (il faudrait les saisir!)
Raz WQTYSTU
If [F:ITM]SERMGTCOD=3
   For [STS]STS2 Where ITMREF=[F:SID]ITMREF
&                    & SDHTYP=4 & SDHNUM=[F:SID]SDHNUM & SDDLIN=[F:SID]SDDLIN
      Readlock [STS]STS2=[F:STS]ITMREF;[F:STS]SDHTYP;[F:STS]SDHNUM;[F:STS]SDDLIN;[F:STS]SERNUM
      If !fstat
         # Récriture no série avec date sortie et pièce sortie (facture)
         [F:STS]ISSDAT=[F:SIV]INVDAT
         [F:STS]SDHTYP=5
         [F:STS]SDHNUM=[F:SIV]NUM
         [F:STS]SDDLIN=[F:SID]SIDLIN
         Rewrite [STS]
         If fstat
            GOK=0 : Call FSTA("STS") From GLOCK : Break
         Endif
         WQTYSTU+=1
      Else
         GOK=0 : Call RSTA("STS",[F:STS]ITMREF-[F:STS]SERNUM) From GLOCK : Break
      Endif
   Next
   If GOK=0 Return Endif
   # Le nombre de no série ne correspond pas à la quantité facturée
   If WQTYSTU<>[F:SID]QTYSTU
      GOK=0
      If GTRACE <> ""
         Call ECR_TRACE(mess(246,199,1),1) From GESECRAN
      Else
         GERR=1 : GMESSAGE=mess(246,199,1)
      Endif
      Return
   Endif
Endif

Return

