##########################################################################################
# UTITC62  Creation de l'enregistrement ADOVAL : "BPCADDOPT"                SAM # 100229 #
# FGR :  July 2014                                                                      #
##########################################################################################
Local Char DOSSIER(30) : DOSSIER = nomap

  Call SAIDOS(DOSSIER,"") From SAIDOS
  If DOSSIER <> ""
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE(mess(45,9901,1)-mess(47,195,1)-mess(892,10031,1)) From LECFIC  # Updating notes categories

    If [F:ADS]MODULE(8) = 2 Then
      Call MAJ_UTITC62(DOSSIER)
    Endif
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#############################
Subprog MAJ_UTITC62(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR, WNOT, WRET
Local Integer TODO
Local Char SKEY1(250)
Local Char SKEY2(250)

  Call ECR_TRACE("UTITC62 : Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If filinfo(filpath("FIL", "ADOVAL", "fde", DOSSIER), 0) <= 0 Then
    # Si la table n'est pas là, on ne fait rien
    End
  Endif
  Local File =DOSSIER+".ADOVAL" [ADW]
  Raz COMPTEUR
  Read [F:ADW]ADW0="";"";"BPCADDOPT"
  If fstat Then
    Raz [F:ADW]
    Trbegin [ADW]
    [F:ADW]CMP = ""
    [F:ADW]FCY = ""
    [F:ADW]PARAM = "BPCADDOPT"
    [F:ADW]VALEUR = "1"
    Write [F:ADW]
    If fstat Then
      GOK = 0
      Call ECR_TRACE(mess(100,141,1) - "ADOVAL='';'';'BPCADDOPT'", 1) From GESECRAN
      Call FSTA("ADW") From GLOCK
      Rollback
    Else
      COMPTEUR += 1
      Commit
    Endif
  Endif
  Call ECR_TRACE("UTITC62 :" - num$(COMPTEUR) - mess(192,124,1), 0) From GESECRAN
End

