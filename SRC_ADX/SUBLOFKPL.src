#-----------------------------------------
$LIENS
 If [M:FPC]LEG<>"POL" or G_ACTKPL <> G_OUI
  Chgfmt [M:LOF1]KMDRFLG     With "-LA01:10X"
 Else
  Affzo [M:LOF1]KMDRFLG
  If varmode([M:LOF1]KMDRFLG)=3     : Chgfmt [M:LOF1]KMDRFLG   With "+LA01:10X"         : Endif
 Endif
Return
