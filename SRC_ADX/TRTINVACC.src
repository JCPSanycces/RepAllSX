#<AdxTL>@(#)8.0.0.0 $Revision$
###################################
#     Trt de l'état BPCINV        #
# Aide à la récupération des taux #
###################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Gosub DECLARE

## Récup paramètres
Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT) From ETAT
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT  : [L]NUMREQ = val(PARAM)
PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Call GETPARAM("societe",NBPAR,PARAMETRE,[L]SOCIETE) From ETAT
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,[L]SITDEB) From ETAT
Call GETPARAM("sitefin",NBPAR,PARAMETRE,[L]SITFIN) From ETAT
Call GETPARAM("datedeb",NBPAR,PARAMETRE,PARAM) From ETAT    : [L]DATDEB   = PARAM
Call GETPARAM("datefin",NBPAR,PARAMETRE,PARAM) From ETAT    : [L]DATFIN   = PARAM
Call GETPARAM("numdeb",NBPAR,PARAMETRE,[L]NUMDEB) From ETAT
Call GETPARAM("numfin",NBPAR,PARAMETRE,[L]NUMFIN) From ETAT
Call GETPARAM("duplicata",NBPAR,PARAMETRE,PARAM) From ETAT  : [L]DUPLICATA = val(PARAM)

Gosub CRITERE

Link [PYH] With [TPY]TPY0=[F:PYH]PAYTYP, [CPY]CPY0=[F:PYH]CPY
& As [LNK]
& Where evalue(CRITERE1) & evalue(CRITERE2)
& Order By Key LNK0=[PYH]NUM Asc;[TPY]LEG Desc

Call DEBTRANS From GLOCK
Gosub TR_DELRPT
If GOK<=0 : End : Endif

Raz [ARM]
[F:ARM]USR    = GUSER
[F:ARM]RPTCOD = [L]ETAT
[F:ARM]NUMREQ = [L]NUMREQ
[F:ARM]CREDAT = date$

Call DEBTRANS From GLOCK
Gosub TR1
End

#########################################################################################################################
## Ouverture de tables et déclaration des variables
#########################################################################################################################
$DECLARE
If clalev([ARM])=0 : Local File AREPORTM  [ARM] : Endif
If clalev([SIT])=0 : Local File BPCINVVAT [SIT] : Endif
If clalev([TRA])=0 : Local File TABRATVAT [TRA] : Endif
If clalev([TVT])=0 : Local File TABVAT    [TVT] : Endif
If clalev([PYH])=0 : Local File PAYMENTH  [PYH] : Endif
If clalev([PYD])=0 : Local File PAYMENTD  [PYD] : Endif
If clalev([DAE])=0 : Local File GACCENTRYD[DAE] : Endif
If clalev([HAE])=0 : Local File GACCENTRY [HAE] : Endif
If clalev([TPY])=0 : Local File TABPAYTYP [TPY] : Endif
If clalev([CDA])=0 : Local File GACCDENCOD[CDA] : Endif
If clalev([GAC])=0 : Local File GACCOUNT  [GAC] : Endif
If clalev([PAN])=0 : Local File PAYACCNUM [PAN] : Endif
If clalev([CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([TAM])=0 : Local File TABPAM    [TAM] : Endif

Local Char    PARAM(30) , ETAT(GLONARP)
Local Integer NUMREQ
Local Integer I, J, K, OK, NUMLIG
Local Char    SOCIETE(GLONCPY) , SITDEB(GLONFCY) , SITFIN(GLONFCY)
Local Char    NUMDEB(20) , NUMFIN(20), CRITERE1(250), CRITERE2(250)
Local Date    DATDEB , DATFIN
Local Integer DUPLICATA, LNG, TYPLED
LNG = dim([F:SIT]CODE)-1
Local Char    CODE(GLONVAT)(0..LNG), TEX(80)(0..LNG)
Local Char    OLDVATLIN(GLONVAT) ,OLDCURLIN(GLONCUR)
Local Decimal TAUX(0..LNG), MTTVA
Return

#########################################################################################################################
## Critères
#########################################################################################################################
$CRITERE
CRITERE1 = "SNS="+num$(2)
If [L]NUMDEB<>""      : CRITERE1 -= "& NUM>='"+NUMDEB+"'"                     : Endif
If [L]NUMFIN<>""      : CRITERE1 -= "& NUM<='"+NUMFIN+"'"                     : Endif
If [L]SOCIETE<>""     : CRITERE1 -= "& CPY='"+[L]SOCIETE+"'"                  : Endif
If [L]SITDEB<>""      : CRITERE1 -= "& FCY>='"+[L]SITDEB+"'"                  : Endif
If [L]SITFIN<>""      : CRITERE1 -= "& FCY<='"+[L]SITFIN+"'"                  : Endif
If [L]DATDEB<>[0/0/0] : CRITERE1 -= "& ACCDAT>=["+format$(GFMD,[L]DATDEB)+"]" : Endif
If [L]DATFIN<>[0/0/0] : CRITERE1 -= "& ACCDAT<=["+format$(GFMD,[L]DATFIN)+"]" : Endif

CRITERE2 = "(([F:TPY]STA3="+num$(2)-"& [F:PYH]STAFLG(2)="+num$(2)+") | ([F:TPY]STA8="+num$(2)
CRITERE2 -="& [F:PYH]STAFLG(7)="+num$(2)+") | ([F:TPY]STA9="+num$(2)-"& [F:PYH]STAFLG(8)="+num$(2)-"& [F:TPY]ACETYP91="+num$(1)+") )"
CRITERE2 -="& ([F:CPY]LEG=[F:TPY]LEG | [F:TPY]LEG='"+"')"
Return

#########################################################################################################################
## Raz table AREPORTM
#########################################################################################################################
$TR_DELRPT
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER & CREDAT<date$
 If fstat=1 | fstat>5
  GOK = -1 : GLOCK = "AREPORTM"-GUSER : Goto ROLL_TR_DELRPT
 Endif
Commit
Return

$ROLL_TR_DELRPT
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else Goto TR_DELRPT: Endif

#########################################################################################################################
$TR1
GOK = 1
Trbegin [SIT]

 #Parcours des règlements
 Columns [CPY](CPY,LEG)
 Columns [PYH](NUM,CPY,PAM,ACCDAT,PAYTYP,STAFLG)
 For [LNK]LNK0(1)
  Gosub CONTROLE
  If OK
   # Raz table SIT
   Gosub TR_DEL
   If GOK<=0 : Break : Endif

   # Recherche du montant total TVA
   Raz MTTVA
   Call LECLEDMAIN(1,[F:PYH]CPY,TYPLED) From CPTDIV

   Filter [PAN] Where TYPNUM=3 & NUM=[F:PYH]NUM & TYPVCR="A" & STA=3
   Read [PAN]First
   Filter [PAN]
   If !fstat
    Read [DAE]DAE2=[F:PAN]ACCNUM
    If !fstat
     Read [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM
     For [DAE]DAE0 Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LEDTYP=TYPLED
      Read [GAC]GAC0=[F:DAE]COA;[F:DAE]ACC
      If !fstat & [F:GAC]FLGVAT=3
       MTTVA +=[F:DAE]AMTCUR
      Endif
     Next
    Endif
   Endif

   # Mode de règlement TAM (AREPORTM déjà exploité => CLEA5 contient la LEG de [F:TAM]
   Call LEC_TAM([F:CPY]LEG,[F:PYH]PAM) From CPTLEC
   If fstat : Raz [F:TAM] Endif

   #Préparation maj table SIT + Maj AREPORTM
   K = 0 : J = 0
   Raz CODE, TAUX, TEX
   For [PYD]PYD0 Where NUM=[F:PYH]NUM
    If [F:PYD]VATLIN<>""
     # Cas particulier société ??
     Call LEC_TVT_LEG([F:CPY]LEG,[F:PYD]VATLIN) From CPTLEC
     Filter [TRA] Where CPY=[F:PYH]CPY & VAT=[F:PYD]VATLIN & STRDAT<=[F:PYH]ACCDAT & LEG=[F:TVT]LEG
     Read [TRA]TRA0 Last
     If fstat
      # sinon on se rabat sur le code dossier
      Filter [TRA] Where CPY="" & VAT=[F:PYD]VATLIN & STRDAT<=[F:PYH]ACCDAT & LEG=[F:TVT]LEG
      Read [TRA]TRA0 Last
     Endif
     Filter [TRA]
     If !fstat & !find([F:TRA]VAT,CODE(0..LNG))
      CODE(J)=[F:TRA]VAT
      TAUX(J)=[F:TRA]VATRAT
      J +=1
      Call LECTEXTRA(TEX(K),"TABVAT","TEXAXX",[F:TRA]VAT,[F:TVT]LEG) From ATEXTRA
      If len(TEX(K))<>0
       K +=1
      Endif
     Endif
    Endif

    [L]NUMLIG    +=1
    [F:ARM]NUMLIG = [L]NUMLIG
    [F:ARM]CLEA1  = [F:PYD]NUM
    [F:ARM]CLEA2  = [F:HAE]TYP
    [F:ARM]CLEA3  = [F:HAE]NUM
    [F:ARM]CLEA4  = mess(32,2289,1)
    [F:ARM]CLEA5  = [F:TAM]LEG
    [F:ARM]CLEA6  = [F:PYD]VATLIN
    [F:ARM]CLED1  = [F:HAE]ACCDAT
    [F:ARM]CLEMD2 = [F:PYD]AMTLIN
    [F:ARM]CLEMD1 = MTTVA
    Write [F:ARM]
    If fstat : GOK=0 : Call FSTA("ARM") From GLOCK : Break 2 : Endif
   Next

   # Maj table SIT
   Gosub TR2
   If !GOK : Break : Endif
  Endif
 Next
 Columns [CPY]
 Columns [PYH]
 If !GOK : Rollback : End : Endif
Commit
End

#########################################################################################################################
$TR_DEL
Delete [SIT] Where NUM=[F:PYH]NUM
If fstat=1 | fstat>5
 GOK = -1 : GLOCK = "BPCINVVAT"-[F:PYH]NUM : Goto ROLL_TR1
Endif
Return


$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else Goto TR1: Endif

#########################################################################################################################
$TR2
Raz [F:SIT]
## [F:SIT]DOC=mention à imprimer sur la facture 1=Pas de mention à imprimer, car facture définitive, 2=Duplicata
If [L]DUPLICATA = 0 : # Pas de duplicata demandé
 [F:SIT]DOC = 1
Else                : # Duplicata demandé
 [F:SIT]DOC = 2
Endif
[F:SIT]NUM  = [F:PYH]NUM
For I=0 To LNG
 [F:SIT]CODE(I) = CODE(I)
 [F:SIT]TAUX(I) = TAUX(I)
 [F:SIT]TEX(I)  = TEX(I)
Next
Write [SIT]
If fstat : GOK=0 : Call FSTA("SIT") From GLOCK : Return : Endif
Return

#########################################################################################################################
$CONTROLE
OK = 1
I = 0
# Contrôle qu'il n'y a que des lignes d'acomptes de même code taxe et de même devise
# Le compte acompte doit être renseigné dans destination comptable
For [PYD]PYD0 Where NUM=[F:PYH]NUM
 If I=0
  I=1
  OLDVATLIN = [F:PYD]VATLIN
  OLDCURLIN = [F:PYD]CURLIN
 Endif
 If [F:PYD]ACCTYP<>1 | [F:PYD]VATLIN<>OLDVATLIN | [F:PYD]CURLIN<>OLDCURLIN
  OK = 0 : Break
 Endif
 Call LEC_CDA_LEG([F:CPY]LEG,[F:PYD]DENCOD) From CPTLEC
 If fstat | [F:CDA]ACCBPR="" | [F:CDA]RPCVAT<>2
  OK = 0 : Break
 Endif
Next
Return

