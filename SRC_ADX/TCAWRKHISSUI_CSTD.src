#<AdxTL>@(#)8.0.0.0 $Revision$
#######################################################################################
# Class TCAWRKHISSUI - Workflow monitor
#
#######################################################################################

#######################################################################################
# MAIN SWITCH BLOCK
#######################################################################################

$ACTION
  If [L]CURPRO = "" Then
    Gosub METHODS
  Else
    Gosub PROPERTIES
  Endif
Return

#######################################################################################
# METHODS SWITCH BLOCK
#######################################################################################
$METHODS
 Case CURPTH
   When ""
     Case ACTION
       When "OSIGNACTION" Gosub OSIGNACTION # Signature operation (VAL or REJ) with action/email parameter
       When "OREAD"       Gosub OREAD       # Aknowledgement operation (no parameter)
       When Default
     Endcase
   When Default
 Endcase
Return

#######################################################################################
# PROPERTIES SWITCH BLOCK
#######################################################################################
$PROPERTIES
Return

#######################################################################################
# OPERATIONS
#######################################################################################

#**************************************************************************************
#* This operation is used on signed documents and its purpose is to set the
#* workflow record as "Read". Doing this, the document disapear from the signed
#* document list.
#*
#* @key      CHRONO - Sequence number of the workflow record
#* @key      DEST   - User who will be able to read the record
#*
#* @return - ARET_VALUE
#**************************************************************************************
#*!
$OREAD

  Local Integer  WLOG         : WLOG=[V]CST_ANO
  Local Char     WERR(255)
  Local Integer  WRET
  Local Instance AWH Using C_TCAWRKHISSUI

  #> Diagnosis log opening
  #  ---------------------

  If WLOG=CST_AYES
   Local Integer ALOG_RET
   Local Instance ALOG Using C_ALOG
   ALOG = NewInstance With C_ALOG
   ALOG_RET = fmet ALOG.ASETNAME("OREAD"+"_"+this.ACTX.USER+"_"+num$(adxuid(2)))
   ALOG_RET = fmet ALOG.ABEGINLOG("Workflow dataclass diagnosis log - OREAD Operation")
  Endif

  #> Acknowledgment action
  #  ---------------------

  AWH=NewInstance With C_TCAWRKHISSUI
  WRET=fmet AWH.AREAD(DEST,CHRONO)
  If WRET<>0
    WERR        = "[TCAWRKHISSUI-OREAD] Error AWH.AREAD: Key"-DEST-CHRONO
    ASTATUS     = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
    ARET_VALUE  = [V]CST_AERROR
  Else
    AWH.FLGSIG = 4 : # Visé
    AWH.USRSIG = AWH.ACTX.USER
    AWH.MAISIG = ""
    AWH.DATSIG = date$
    AWH.TIMSIG = left$(time$,2)+mid$(time$,4,2)+right$(time$,7)
    WRET=fmet AWH.AUPDATE
    If WRET<>0
      WERR        = "[TCAWRKHISSUI-OREAD] Error AWH.AUPDATE: Key"-DEST-CHRONO
      ASTATUS     = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
      ARET_VALUE  = [V]CST_AERROR
    Endif
  Endif
  FreeInstance    AWH
  If WRET=0
    WERR        = mess(97,75,1)-DEST-CHRONO #"Visa"
    ASTATUS     = fmet this.ASETERROR("",WERR,[V]CST_AINFO)
    ARET_VALUE  = [V]CST_AOK
  Endif

  #> log closing
  #  -----------

  If WLOG=[V]CST_AYES
   ALOG_RET = fmet ALOG.APUTINSTERRS(this)
   ALOG_RET = fmet ALOG.AENDLOG()
   FreeInstance ALOG
  Endif

Return


#######################################################################################
# Signature operation :
# -------------------
# This operation create a .lka file processed by the batch task AWRKSIG.
#
#######################################################################################

#**************************************************************************************
#* Operation used to sign documents. Two actions are avalaible : validation or reject
#* The operation create a lka file in the folder build with WRKTMPDIR and WRKTMPMAC
#* parameters and solution and current folder name.
#*
#* @key      CHRONO  - Sequence number of the workflow record
#* @key      DEST    - User who will be able to read the record
#*
#* @param    PACTION - VAL or REJ
#* @param    PEMAIL  - Email adress coming from the user profile (user who sign)
#*
#* @return   ARET_VALUE
#*
#**************************************************************************************
#*!
$OSIGNACTION

 Local Integer WLOG       : WLOG = [V]CST_ANO
 Local Char    WERR(255)

 #> Diagnosis log opening
 #  ---------------------

 If WLOG=CST_AYES
  Local Integer ALOG_RET
  Local Instance ALOG Using C_ALOG
  ALOG = NewInstance With C_ALOG
  ALOG_RET = fmet ALOG.ASETNAME("OSIGNACTION"+"_"+this.ACTX.USER+"_"+num$(adxuid(2)))
  ALOG_RET = fmet ALOG.ABEGINLOG("Workflow dataclass diagnosis log - OSIGNACTION Operation")
 Endif

 #> lka file generation
 #  -------------------
 Gosub TRT_LIEN_HTTP

 If WERR=""
  WERR        = mess(98,75,1) #"Workflow signature"
  ASTATUS     = fmet this.ASETERROR("",WERR,[V]CST_AOK)
  ARET_VALUE  = [V]CST_AOK
 Endif

 If WLOG=[V]CST_AYES
  WERR        = "Action"-"PACTION ["+[L]PACTION+"]"-"PEMAIL"-"["+[L]PEMAIL+"]"-"CHRONO"-"["+[L]CHRONO+"]"-"DEST"-"["+[L]DEST+"]"
  ASTATUS     = fmet this.ASETERROR("",WERR,[V]CST_AOK)
  ARET_VALUE  = [V]CST_AOK
 Endif

 #> log closing
 #  -----------

 If WLOG=[V]CST_AYES
  ALOG_RET = fmet ALOG.APUTINSTERRS(this)
  ALOG_RET = fmet ALOG.AENDLOG()
  FreeInstance ALOG
 Endif

Return

#**************************************************************************************
#* lka file creation process
#**************************************************************************************!
$TRT_LIEN_HTTP

Local Char    LWRKRMTDIR(255)
Local Char    LWRKRMTMAC(255)

LWRKRMTDIR = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"WRKRMTDIR")
LWRKRMTMAC = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"WRKRMTMAC")

Local Char    LFOLDER(50)    : LFOLDER    = this.ACTX.AFOLDER
Local Char    LSOLUTION(50)  : LSOLUTION  = this.ACTX.ASOLUTION
Local Char    LACTVAL(3)     : LACTVAL    = "VAL"
Local Char    LACTREJ(3)     : LACTREJ    = "REJ"
Local Char    LACTCAN(3)     : LACTCAN    = "CAN"
Local Char    LEXTFIL(3)     : LEXTFIL    = "lka"

Local Char    RACINE(255)
Local Char    REPERT(255)
Local Char    FICHIER(255)
Local Char    FICHIERINV(255)
Local Char    LIGNE(255)
Local Char    ERM(255)
Local Integer ERN

Local Char    ORDSYS(250), CMD(250), DIR(250)  # FGR 29/10/2013 :X3SUIVI93700
Local Integer K                                  # FGR 29/10/2013 :X3SUIVI93700

#> Folder checking
#  ---------------

# Chemin serveur
RACINE = vireblc(LWRKRMTDIR,2)

# Répertoire des fichiers liens actions
Onerrgo ERRFIC
REPERT     = RACINE+"/"+LSOLUTION+LFOLDER
FICHIER    = filpath("","","","","",LWRKRMTMAC)
If ERN
  ERM = "|"+LWRKRMTMAC-":"-mess(199,100,1) : # Machine inaccessible
Else
  FICHIER = filpath(REPERT,"","","","",LWRKRMTMAC)
  If ERN
    ERM = "|"+REPERT-":"-mess(147,141,1) : # Répertoire inaccessible
  Else
    K = filinfo(FICHIER,0)
  Endif
Endif
Onerrgo
If ERN
  STAT = 1 : Goto ERROR
Elsif K<0
  # FGR 29/10/2013 :X3SUIVI93700 (début) repris de AWRKSIG
  K = instr(1,FICHIER,"@")
  If K
    ORDSYS = left$(FICHIER,K)
    DIR = right$(FICHIER,K+1)
  Else
    ORDSYS = ""
    DIR = FICHIER
  Endif
  ORDSYS += 'ae_mkdir'-'"'+DIR+'"'
  System CMD=ORDSYS
  K = filinfo(FICHIER,0)
  If K<0
    ERM = "|"+FICHIER-":"-mess(86,133,1)-FICHIER : # Répertoire inexistant
    STAT = 1 : Goto ERROR
  Endif
  # FGR 29/10/2013 :X3SUIVI93700 (fin) repris de AWRKSIG
Endif

#> lka file creation
#  -----------------

#> Filename building

# 98952.sn
#Local File AUTILIS [AUS]
#Read [AUS]CODUSR=DEST
#If !fstat and [AUS]ADDEML=""
Local File AWRKHISSUI [AWS]  # 99635.sn
  Read [F:AWS]AWS0=[L]CHRONO;[L]DEST
If !fstat and [AWS]EMAIL ="" # 99635.en
  ERM=mess(1,76,1)-DEST-mess(1,75,1)-mess(38,143,1)+"."-mess(189,197,1)
  Goto WARNING
Endif
# 98952.en

Local File AWRKHISDES [AWO]
Read [F:AWO]AWO0=CHRONO;PEMAIL
If fstat
 ERM=CHRONO-"/"-PEMAIL-num$(fstat)-mess(106,75,1) #"Nothing to sign"
 Goto WARNING
Endif

If PACTION = LACTCAN Then
  # If "CANcel" action, FLGSIG have to be equal 5
  Local File AWRKHISSUI [AWS]
  Read [F:AWS]AWS0=[L]CHRONO;[L]DEST
  If [F:AWS]FLGSIG <> 5 Then
    #ERM = CHRONO - "/" - PEMAIL - mess(158,75,1) - ":"  - mess(186,123,1) - "(" + mess([F:AWS]FLGSIG,2922,1) + ")" #Annulation signature : Action impossible
    ERM = mess(158,75,1) - ":"  - mess(186,123,1) - "(" + num$([F:AWS]FLGSIG) + ":" + mess([F:AWS]FLGSIG,2922,1) + ")" #Annulation signature : Action impossible
    Goto ERROR
  Endif
Endif

If PACTION=LACTREJ
 FICHIERINV=FICHIER+"\"+CHRONO+"-"+LACTVAL+"."+LEXTFIL
Elsif PACTION=LACTVAL
 FICHIERINV=FICHIER+"\"+CHRONO+"-"+LACTREJ+"."+LEXTFIL
Elsif PACTION=LACTCAN
 FICHIERINV=FICHIER+"\"+CHRONO+"-"+LACTCAN+"."+LEXTFIL
Endif
FICHIER+="\"+CHRONO+"-"+PACTION+"."+LEXTFIL

#> Check if file exists

If filinfo(FICHIER,7)>0
 ERM=CHRONO-"/"-PEMAIL-num$(fstat)-mess(127,75,1) #"Workflow already signed"
 Goto INFO
Else
 If filinfo(FICHIERINV,7)>0
  ERM=CHRONO-"/"-PEMAIL-num$(fstat)-mess(127,75,1) #"Workflow already signed"
  Goto INFO
 Endif
Endif

#> File creation

Openo FICHIER,0 Using [_LKA]
Wrseq "K="+[F:AWO]LNKHTP Using [_LKA]
Openo Using [_LKA]

Return

#**************************************************************************************
#* Error on file creation
#**************************************************************************************!
$ERRFIC
ERN = errn
ERM = "|"+errp-"("+num$(errl)+")"-mess(6,123,1)-num$(ERN)-":"-errmes$(abs(ERN))-errm

#**************************************************************************************
#* Error management : Information
#**************************************************************************************!
$INFO
 WERR         = ERM
 ASTATUS      = fmet this.ASETERROR("",WERR,[V]CST_AINFO)
 ARET_VALUE   = [V]CST_AINFO
Return

#**************************************************************************************
#* Error management : Warning
#**************************************************************************************!
$WARNING
  WERR        = ERM
  ASTATUS     = fmet this.ASETERROR("",WERR,[V]CST_AWARNING)
  ARET_VALUE  = [V]CST_AWARNING
Return

#**************************************************************************************
#* Error management : Error
#**************************************************************************************!
$ERROR
  ERM += "\"+mess(125,75,1)-CHRONO : # Erreur fichier signature. Chrono non signé
  WERR        = ERM
  ASTATUS     = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
  ARET_VALUE  = [V]CST_AERROR
Return

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

