# Class DEMCONGEESS


# Note - Important:  when going to DEMCONGEESS_CSTD_nnn those routines will route out to DEMCONGE_CSDT_nnn

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#TODO: Move to own source
#Handling all the event code in EXPENSESESS_CSTD_EVT
Gosub EVENTS From DEMCONGEESS_CSTD_EVT

Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Handling all the property code in EXPENSESESS_CSTD_PRO
Gosub PROPERTIES From DEMCONGEESS_CSTD_PRO
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#No methods exists yet but a call will be created for extension in the future
#Handling Public and private methods

If (left$([L]AMETHOD,1) = "_")
  #Private
  Gosub METHODS From DEMCONGEESS_CSTD_MPR
Else
  #Public
  Gosub METHODS From DEMCONGEESS_CSTD_MPU
Endif
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#No operations exists yet but a call will be created for extension in the future
#Handling Public and Private operations

If (left$([L]AOPERATION,1) = "_")
  #Private
  Gosub OPERATIONS From DEMCONGEESS_CSTD_MPR
Else
  #Public
  Gosub OPERATIONS From DEMCONGEESS_CSTD_MPU
Endif
Return

