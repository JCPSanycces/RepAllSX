#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#  Case [L]CURPTH
#     When ""
#        Case [L]AEVENT
#        Endcase
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "LOAD_TO_SPK_FILE" : Gosub LOAD_TO_SPK_FILE
  Endcase
Return
#--------------------------------------

$PROPERTIES
Case [L]CURPRO
Endcase
Return

#-------------------------------------------------------
#--Method used to load properties from class SPRICLINKH to [F:SPK]
$LOAD_TO_SPK_FILE
Local Integer IJ

  If dim([F:SPK]CPY)<1
    [L]ASTATUS = fmet this.ASETERROR ("", "Data Class SPRICLINKH : Method call LOAD_TO_SPK_FILE no [F:SPK] file opened", [V]CST_AERROR)
    [L]ARET_VALUE = [L]ASTATUS
    Return
  Endif

  SetInstance [F:SPK] With this
  #--Parcours des collections
  #--TSCCOD
  For IJ=1 To maxtab(this.C_TSCCOD)
    If dim([F:SPK]TSCCOD(IJ-1))<1 : Break : Endif

    [F:SPK]TSCCOD(IJ-1) = "" #AVOID.ACHAR

    If this.C_TSCCOD(IJ)<>null
      [F:SPK]TSCCOD(IJ-1) = this.C_TSCCOD(IJ).TSCCOD
    Endif

  Next IJ

Return

