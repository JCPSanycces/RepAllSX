#<AdxTL>@(#)0.0.0.0 $Revision$ 
Funprog AV_BNKACCNAM(T_VREFNUM)
##Call DEBUG_TRACE(1, "ESS", "AV_BNKACCNAM") From DEBUGTRACE
Local Char VREFNUM : VREFNUM = T_VREFNUM
Local Integer MYLEN
Local Char RETVAL(250),INIT(250)
Local Char M_CIVA(15),M_NCKNAM(5),M_NAM(40),M_SRN(40),M_SECNAM(20)

Local File EMPLOID [ID1]
Local File EMPLOIDSA [ESA1]

Read [ID1]ID0 = VREFNUM
If fstat = [V]CST_AOK
  M_NAM = [F:ID1]NAM
  M_SRN = [F:ID1]SRN
Else
  End M_NCKNAM
Endif

#M_NCKNAM=toupper(left$(vireblc(M_SRN,4),2)+left$(vireblc(M_NAM,4),3))
    MYLEN = len(M_NAM)
    INIT=toupper(left$(vireblc(M_NAM,4),1))

    For I = 2 To MYLEN
      If mid$(M_NAM,I,1) = " " Then
        INIT+=mid$(M_NAM,I+1,1)
      Endif
    Next

    INIT=toupper(vireblc(INIT,4))
    M_NCKNAM=INIT

  #append initials from second name
    Read [ESA1]ESA0 = VREFNUM
    If fstat = [V]CST_AOK
      M_SECNAM = [ESA1]SECNAM
      If M_SECNAM<>""
      MYLEN = len(M_SECNAM)
      INIT=toupper(left$(vireblc(M_SECNAM,4),1))

      For I = 2 To MYLEN
        If mid$(M_SECNAM,I,1) = " " Then
          INIT+=mid$(M_SECNAM,I+1,1)
        Endif
      Next

      INIT=toupper(vireblc(INIT,4))
      M_NCKNAM+=INIT
    Endif
  Endif

  RETVAL = num$(mess([F:ID1]CIV,11654,1))-num$(M_NCKNAM)-num$([F:ID1]SRN)
LogicClose File [ID1]
LogicClose File [ESA1]
End RETVAL

$AM_BIDNUM
#This check is already performed for all legislations. The control can also not exist in PROPAGATE
#If this.BIDNUM<>""
#  Local File EMPLORIB [BID1]
#  Filter [BID1] Where [BID1]BIDNUM=this.BIDNUM and [BID1]REFNUM<>this.REFNUM
#  If rowcount([BID1])>0
#    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(48 ,11662,1),[V]CST_AERROR)
#  Endif
#  LogicClose File [BID1]
#Endif
Return


