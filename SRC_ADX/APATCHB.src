#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(30)(1..1) , VALEUR(250)
Call TRAITE_CHAR(VALEUR,PARAM,"","PATCH","PATCH",3,"") From GTRAITE
End
#######

$ACTION
 Case ACTION
  When "CREEXE"        : Gosub CREEXE : # Création de patch
  When "CRELST"        : Gosub CRELST
  When "C_NOMOBJ"      : Gosub C_NOMOBJ
  When "SEL_TABLE"     : Gosub SEL_TABLE
  When "CTL_OBJPAT"    : Gosub CTL_OBJPAT
  When "INI_B2_NBOBJ"  : Gosub INI_B2_NBOBJ
  When "EXTOBJ"        : Gosub EXTOBJ
  When "INTEXE"        : Gosub INTEXE : # Intégration de patch
  When "INTINI"        : Gosub INTINI   # Issue X3-61478 - 2017-12-15 by FGR
 Endcase
Return

$INTINI
  # Issue X3-61478 - 2017-12-15 by FGR
  If GADONIX = 2 and APPLI = "REPOSX3" Then
    Call UTI_MOUL(APPLI) From UTICRM17001
    Call UTI_MOUL(APPLI) From UTIPJM201804001
  Endif
Return

$INTEXE
Case TYPOBJ
 When "GAU" : Gosub PIECE From PATCHGAU   : OK = 0
 When "CDE" : Gosub SECTION From PATCHCDE : OK = 0
Endcase
Return

$EXTOBJ
### Traitement d'une pièce automatique
If filinfo(filpath("FIL","GAUTACE","fde",[M]DOSSIER),0)>=0
 For [GAU]GAU0 Where CODACT = [L]ACTIV
  OBJET = "GAU"
  NOM   = [F:GAU]COD
  INTITULE = [F:GAU]DES
  Gosub EXTOBJ From APATCH : If !OK : Break : Endif
 Next
 If !OK : Return : Endif
Endif
Return

$INI_B2_NBOBJ
If filinfo(filpath("FIL","GAUTACE","fde",[M]DOSSIER),0)>=0
 If clalev([F:GAU])=0 : Local File =[M]DOSSIER+".GAUTACE"   [GAU] : Endif
Endif
Return

$CTL_OBJPAT
Case OBJTYP
 When "GAU"       : VALEUR = vireblc(format$("K:"+num$(GLONGAU)+"c",VALEUR),2) : CTL_OBJPAT=1
Endcase
Return

$SEL_TABLE
Case OBJTYP
 When "GAU"
  Local File =[L]DOSSIER+".GAUTACE" [GAU]
  OBJET = "GAU"
Endcase
Return

$CRELST
If filinfo(filpath("FIL","GAUTACE","fde",[L]DOSSIER),0)>=0
 NBTEX += 1 : TEX(NBTEX) = "GAU" : TEXTE(NBTEX,2) = mess(64,125,1)  : # Pièce automatique
Endif
Return

$C_NOMOBJ
Case OBJTYP
 When "GAU"
  C_NOMOBJ = 1
  Local File =[L]DOSSIER+".GAUTACE" [GAU]
  Call CONTROLE("GAU","",VALEUR,"",mkstat) From CONTOBJ
  #If fstat : mkstat = 1 : End : Else : INTIT = [F:GAU]DES : Endif  # F59022
  If fstat : mkstat = 1 : End : Else : Call LECTEXTRA(INTIT,"GAUTACE","DESTRA",[F:GAU]COD,"") From ATEXTRA  : Endif
Endcase
Return

$CREEXE
Case ABROBJ
 When "GAU" : Gosub PIECE : OK = 0
Endcase
Return

### Traitement d'une pièce automatique
$PIECE
If filinfo(filpath("FIL","GAUTACE","fde",APPLI),0)>=0
 Local File =APPLI+".GAUTACE"   [GAU]
 Local File =APPLI+".GAUTACED"  [GAD]
 Local File =APPLI+".GAUTACEF"  [GAG]
Endif
If filinfo(filpath("FIL","GVARPARVAL","fde",APPLI),0)>=0
 Local File =APPLI+".GVARPARVAL"[GVV]
Endif
Read [GAU]GAU0 = [L]CLEOBJ
If !fstat
 FICHIER = "GAUTACE" : ABR = "GAU" : IDENT = [F:GAU]COD : Gosub FICHIER From APATCH2
 For [GAD]GAD0 Where COD=[L]CLEOBJ
  FICHIER = "GAUTACED" : ABR = "GAD" : IDENT = num$([F:GAD]LINNUM) : Gosub FICHIER From APATCH2
 Next
 For [GAG]GAG0 Where COD=[L]CLEOBJ
  FICHIER = "GAUTACEF" : ABR = "GAG" : IDENT = num$([F:GAG]LINNUM) : Gosub FICHIER From APATCH2
 Next
 If clalev([F:GVV])>0
  For [GVV]GVV0 Where COD=[L]CLEOBJ
   FICHIER = "GVARPARVAL" : ABR = "GVV" : IDENT = num$([F:GVV]LINNUM) : Gosub FICHIER From APATCH2
  Next
 Endif
Endif
If filinfo(filpath("FIL","GAUTACE","fde",APPLI),0)>=0
 Close Local File [GAU],[GAD],[GAG]
Endif
If filinfo(filpath("FIL","GVARPARVAL","fde",APPLI),0)>=0
 Close Local File [GVV]
Endif
Return

