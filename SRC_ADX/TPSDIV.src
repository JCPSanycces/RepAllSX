################################################################################

########################################
# Action BSBPCNUM
Subprog AS_BPCNUM(VALEUR,SOC)
Variable Char    VALEUR()
Value    Char    SOC()

If [L]SOC=""
 mkstat=1
Else
 Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
 If [F:CPY]FDRX3="" : mkstat=1 : Endif
Endif

End

########################################
# Action PMBPCNUM
Subprog AM_BPCNUM(VALEUR,SOC)
Variable Char    VALEUR()
Value    Char    SOC()

If [L]VALEUR="" : End : Endif

Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
Onerrgo FDRERR
Local File =[F:CPY]FDRX3+".BPCUSTOMER" [BPC]
Onerrgo
Read [BPC]BPC0=[L]VALEUR
If fstat
#ADNGO - 2017-01-09 - X3-11765 - START
 #[V]GMESSAGE = mess(71,709,1) : # Client inexistant
 [V]GMESSAGE = mess(71,10709,1) : # Client inexistant
 #ADNGO - 2017-01-09 - X3-11765 - END
 mkstat = 2 : End
Endif
If dim([M]INVFLG(nolign-1))=1 : [M]INVFLG(nolign-1)=2 : Endif

End

########################################
# Action PMSOHNUM
Subprog AM_SOHNUM(VALEUR,SOC)
Variable Char    VALEUR()
Value    Char    SOC()

If [L]VALEUR="" : End : Endif

Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
Onerrgo FDRERR
Local File =[F:CPY]FDRX3+".SORDER"  [SOH]
Onerrgo
Read [SOH]SOH0=[L]VALEUR
If fstat
#ADNGO - 2017-01-09 - X3-11765 - START
 #[V]GMESSAGE = mess(72,709,1) : # Commande inexistante
 [V]GMESSAGE = mess(72,10709,1) : # Commande inexistante
#ADNGO - 2017-01-09 - X3-11765 - END
 mkstat = 2 : End
Endif

End

########################################
# Action PM_SOHLIG
##**92876 : To add TRS parameter (Transaction de saisie)
Subprog AM_SOHLIG(VALEUR,SOC,OBJ,CLE, TRS)
Variable Decimal VALEUR
Value    Char    SOC(), OBJ(), CLE(), TRS()

If [L]VALEUR=0 : End : Endif

Local Shortint I, J
Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
Onerrgo FDRERR
Local File =[F:CPY]FDRX3+".SORDERP" [SOP]
Local File =[F:CPY]FDRX3+".CPTANALIN" [CAL]     : ##**92876 : To add file [CAL]
Onerrgo
Read [SOP]SOP0(2)=[M]SOHNUM(nolign-1);[L]VALEUR
If fstat
#ADNGO - 2017-01-09 - X3-11765 - START
 #[V]GMESSAGE = mess(73,709,1) : # Ligne inexistante
 [V]GMESSAGE = mess(73,10709,1) : # Ligne inexistante
 #ADNGO - 2017-01-09 - X3-11765 - END
 mkstat = 2 : End
Endif

If clalev([F:CDT])=0  : Local File CADIETPS  [CDT]  : Endif
If clalev([F:STH])=0  : Local File SCRTPSH   [STH]  : Endif
If [L]TRS="" : End : Endif
Read [CAL]CAL0="SOP";0;[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ;"";1
If !fstat
 Read[F:STH]STH0=[L]TRS
 If !fstat & [F:STH]CODCDT<>""
  Read [CDT]CDT0=[F:STH]CODCDT
  If ! fstat
   For I=1 To [F:CDT]NBRDIE
    If I>GOPTCANA : Break : Endif
    J=find([F:CDT]DIE(I-1),[F:CAL]DIE(0..dim([F:CAL]DIE)-1))
    If J & [F:CDT]SOH(I-1)=2
      Assign "[M]CCE"+num$(I)+"(nolign-1)" With [F:CAL]CCE(J-1)
    Endif
   Next
   Affzo [M]
  Endif
 Endif
Endif
End

#####################################################
Subprog CONTHM(HEURE)
Variable Char HEURE
Local Integer HH, MM
Local Char    WH
If HEURE="" : End : Endif
WH = HEURE
Case len(WH)
 When 0
  WH = "0000"
 When 1
  WH = "0" + WH + "00"
 When 2
  WH = WH + "00"
 When 3
  WH = "0" + WH
Endcase
HH = val(left$(WH,2))
MM = val(right$(WH,3))
If HH >23 | MM > 59
 mkstat = 1 : GMESSAGE = mess(69,134,1) : End : # Heure incorrecte
Endif
HEURE = WH
End

Subprog INIHM(HEURE)
Variable Char HEURE
If HEURE<>""
 HEURE = left$(HEURE+"0000",4)
Endif
End

####################################################################################################################################
##**92876  : CONTROLS TYPE DIMENSOIN & DIMENSION IN TIME MANAGEMENT
####################################################################################################################################

# Initialisation des sections
####################################
Subprog INICCE(NAT,TIM,AXE,VALEUR)
Value    Char    NAT
Value    Char    TIM
Value    Integer AXE
Variable Char    VALEUR()

# AVoir la anture en ligne pour le calcul de la section par defaut
Call LECT_NATCOD (NAT)
#[F:TIP]=[M]                             :# [DBA] pas repris car pas compris ?!?

If clalev([F:TIM])=0  : Local File TIMCOD    [TIM]  : Endif
#ADNGO - 2017-01-26 - X3-11765 - START
#Call LECTURE("TIM",TIM,"") From CONTOBJ
Call LECTURE("HRTIM",TIM,GCURLEG) From CONTOBJ
#ADNGO - 2017-01-26 - X3-11765 - END
# Init en fonction de la section par défaut definie dans TIM
If VALEUR="" & [F:TIM]CCEINI<>""
# Call INISEC(VALEUR,[F:TIM]CCEINI,num$(AXE)) From SUBCDE
 Call INISEC(VALEUR,[F:TIM]CCEINI,[F:TIM]DIE(AXE-1)) From SUBCDE
Endif
# Init en fonction de la section saisie dans TIM
If VALEUR=""
 VALEUR = [F:TIM]CCE(AXE-1)
Endif
End

# Initialisation des sections
# en fonction du code de l'axe à rechercher
# dans la nature d'évènement
####################################
Subprog AXECODINICCE(NAT,TIM,AXE,VALEUR, ISEDITABLE)
Value    Char    NAT
Value    Char    TIM
Value    Char    AXE
Variable Char    VALEUR()
Variable Integer ISEDITABLE
Local    Integer J

ISEDITABLE=0
If clalev([F:TIM])=0  : Local File TIMCOD [TIM]  : Endif
#ADNGO - 2017-01-26 - X3-11765 - START
#Call LECTURE("TIM",TIM,"") From CONTOBJ
Call LECTURE("HRTIM",TIM,GCURLEG) From CONTOBJ
#ADNGO - 2017-01-26 - X3-11765 - END
J=find(AXE,[F:TIM]DIE)
If J
  ISEDITABLE=[F:TIM]CCEDAC(J-1)
  If (ISEDITABLE<>2 | (ISEDITABLE=2 & VALEUR=""))
    VALEUR=""
    Call INICCE([L]NAT,[L]TIM,J,VALEUR) From TPSDIV
  Endif
Endif
End

#Lecture de la nature d'activité
####################################
Subprog LECT_NATCOD (NATURE)
Value Char NATURE
If clalev([F:NAT])=0  : Local File NATACTIV  [NAT]  : Endif
If NATURE<>"" Then
  If [F:NAT]COD<>NATURE Then
  #ADNGO - 2017-01-26 - X3-11765 - START
    #Call LECTURE("NAT",NATURE,"") From CONTOBJ
    Call LECTURE("NAT",NATURE,GCURLEG) From CONTOBJ
  #ADNGO - 2017-01-26 - X3-11765 - END
  Endif
Else
 Raz [F:NAT]
Endif
End

#Verification si l'axe est suivi par la société du site courant
####################################
Subprog CPY_AXE(AXE, SIT, OK)
Value Integer AXE
Value Char SIT
Variable Integer OK
Local Integer NBPLAN, NBAXE
Local Integer REFTYP(1..10)
Local Integer OBLIG(1..max(GOPTCANA,20))
Local Char   LSTPLAN(GLONCOA)(1..10)
Local Char   LSTAXE(GLONDIE)(1..10)
Local Char    ACMCUR(GLONGCM)

OK=1
If [F:FCY]FCY<>SIT
 Call LECTURE("FCY",SIT,"") From CONTOBJ
Endif
Call SETGCM([F:FCY]LEGCPY,ACMCUR) From CPTDIV : # Récupération du code du modèle de la société
# Récupération de la liste des axes de tous les référentiels du modèle
Call SETPLAN2(ACMCUR,NBPLAN,LSTPLAN,REFTYP,NBAXE,LSTAXE,OBLIG) From CPTDIV
If dim([M]DIE)>=0
 If !find ([M]DIE(AXE-1), LSTAXE(1..NBAXE)) :  OK = 0 : End :  Endif
##**92876 : WDIE is the field used in time management (TPSSTD & TPSSTDR)
Elsif dim([M]WDIE)>=0
 If !find ([M]WDIE(AXE-1), LSTAXE(1..NBAXE)):  OK = 0 : End :  Endif
Endif
End

#Controles des CCE paramétrées comme obligatoire dans la transaction de saisie d'axes
####################################
Subprog CONTCCEOBG (VALEUR,AXE)
Value Char VALEUR ()
Value Integer    AXE ()
If [F:STH]COD<>GFLAG
 Read[F:STH]STH0=GFLAG
Endif
If [F:STH]CODCDT="" : End : Endif
If [F:STH]CODCDT<>[F:CDT]COD
 Read [F:CDT]CDT0=[F:STH]CODCDT
Endif
If VALEUR="" & [F:CDT]OBG(AXE-1)=2
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2 : End
Endif
End

