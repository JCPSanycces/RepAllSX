$VERFSOH3
PARAM(3) = num$([F:SOP]SOPLIN)
Read [SOP]SOP0(2) =
Local Integer AX
If PARAM(5)="" : Return : Endif
Read [CAL]CAL0="SOP";0;[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ;"";1
If !fstat
 Read[F:STH]STH0=PARAM(5)
 If !fstat & [F:STH]CODCDT<>""
  Read [CDT]CDT0=[F:STH]CODCDT
  If ! fstat
   For AX=1 To [F:CDT]NBRDIE
    If AX>GOPTCANA : Break : Endif
    I=find([F:CDT]DIE(AX-1),[F:CAL]DIE(0..dim([F:CAL]DIE)-1))
    If I & [F:CDT]SOH(AX-1)=2
     If evalue("dim([M]CCE"+num$(AX)+PARAM(4)+")")>0  : Assign "[M]CCE"+num$(AX)+PARAM(4)  With [F:CAL]CCE(I-1) : Endif
    Endif
   Next AX
   Affzo [M]
  Endif
 Endif
Endif
Return


