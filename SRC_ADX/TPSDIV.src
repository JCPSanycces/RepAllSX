$ACTION
Case ACTION
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "VERF_TABLE"   : Gosub VERF_TABLE
Endcase
Return

$SEL_TABLE
Case TABLE
 When "SELBPR"    : Gosub SELBPR
 When "SELSOH"    : Gosub SELSOH
 When "SELSOH3"   : Gosub SELSOH
 When "SELSOH2"   : Gosub SELSOH2
 When "SELSOP"    : Gosub SELSOP
Endcase
Return

$VERF_TABLE
Case TABLE
 When "SELSOH"    : Gosub VERFSOH
 When "SELSOH3"   : Gosub VERFSOH3
 When "SELSOP"    : Gosub VERFSOP
Endcase
Return

$SELBPR
Gosub SETSOC
If ![L]OK : Return : Endif
Default File [BPC]
#ADNGO - 2017-01-09 - X3-11765 - START
#TIT(0) = mess(89,709,1) : # Sélection client
TIT(0) = mess(89,10709,1) : # Sélection client
#ADNGO - 2017-01-09 - X3-11765 - END
NBCOL = 0
#ADNGO - 2017-01-09 - X3-11765 - START
#NBCOL += 1 : COL(NBCOL) = "BPCNUM" : TIT(NBCOL) = mess(82,709,1) : # Client
#NBCOL += 1 : COL(NBCOL) = "BPCNAM" : TIT(NBCOL) = mess(83,709,1) : # Nom
NBCOL += 1 : COL(NBCOL) = "BPCNUM" : TIT(NBCOL) = mess(82,10709,1) : # Client
NBCOL += 1 : COL(NBCOL) = "BPCNAM" : TIT(NBCOL) = mess(83,10709,1) : # Nom
#ADNGO - 2017-01-09 - X3-11765 - END
CRITERE(1) = "BPCSTA=2"
If VALEUR<>""
 CRITERE(1) -= '& BPCNUM>="'+left$(VALEUR,1)+'"'
Endif
Return

$SELSOH
Gosub SETSOC
If ![L]OK : Return : Endif
Link [SOP] With [SOH]SOH0 = [F:SOP]SOHNUM As [LSOH]
Default File [LSOH]
#ADNGO - 2017-01-09 - X3-11765 - START
#TIT(0) = mess(90,709,1) : # Sélection commande
TIT(0) = mess(90,10709,1) : # Sélection commande
#ADNGO - 2017-01-09 - X3-11765 - END
NBCOL = 0
#ADNGO - 2017-01-09 - X3-11765 - START
#NBCOL += 1 : COL(NBCOL) = "[SOP]SOHNUM"    : TIT(NBCOL) = mess(84,709,1) : # Commande
#NBCOL += 1 : COL(NBCOL) = "[SOP]SOPLIN"    : TIT(NBCOL) = mess(85,709,1) : # Ligne
#NBCOL += 1 : COL(NBCOL) = "[SOH]ORDDAT"    : TIT(NBCOL) = mess(97,709,1) : # Date
#NBCOL += 1 : COL(NBCOL) = "[SOH]PJT"       : TIT(NBCOL) = mess(86,709,1) : # Projet
#NBCOL += 1 : COL(NBCOL) = "[SOH]CUSORDREF" : TIT(NBCOL) = mess(98,709,1) : # Réf client
#NBCOL += 1 : COL(NBCOL) = "[SOP]ITMREF"    : TIT(NBCOL) = mess(87,709,1) : # Article
#NBCOL += 1 : COL(NBCOL) = "[SOP]ITMDES"    : TIT(NBCOL) = mess(88,709,1) : # Désignation
NBCOL += 1 : COL(NBCOL) = "[SOP]SOHNUM"    : TIT(NBCOL) = mess(84,10709,1) : # Commande
NBCOL += 1 : COL(NBCOL) = "[SOP]SOPLIN"    : TIT(NBCOL) = mess(85,10709,1) : # Ligne
NBCOL += 1 : COL(NBCOL) = "[SOH]ORDDAT"    : TIT(NBCOL) = mess(97,10709,1) : # Date
NBCOL += 1 : COL(NBCOL) = "[SOH]PJT"       : TIT(NBCOL) = mess(86,10709,1) : # Projet
NBCOL += 1 : COL(NBCOL) = "[SOH]CUSORDREF" : TIT(NBCOL) = mess(98,10709,1) : # Réf client
NBCOL += 1 : COL(NBCOL) = "[SOP]ITMREF"    : TIT(NBCOL) = mess(87,10709,1) : # Article
NBCOL += 1 : COL(NBCOL) = "[SOP]ITMDES"    : TIT(NBCOL) = mess(88,10709,1) : # Désignation
#ADNGO - 2017-01-09 - X3-11765 - END
CRITERE(1) = "[SOH]ORDSTA<2 & [SOP]SOQSTA<3"
If PARAM(2)<>""
 CRITERE -= '& [SOP]BPCORD="'+PARAM(2)+'"'
Endif
ORDRE = "[SOP]SOHNUM;[SOP]SOPLIN"
Return

$VERFSOH
PARAM(3) = num$([F:SOP]SOPLIN)
Read [SOP]SOP0(2) =
Local Integer AX
##**92876 : New process (V7 process)
If PARAM(4)="" : Return : Endif
Read [CAL]CAL0="SOP";0;[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ;"";1
If !fstat
 Read[F:STH]STH0=PARAM(4)
 If !fstat & [F:STH]CODCDT<>""
  Read [CDT]CDT0=[F:STH]CODCDT
  If ! fstat
   For AX=1 To [F:CDT]NBRDIE
    If AX>GOPTCANA : Break : Endif
    I=find([F:CDT]DIE(AX-1),[F:CAL]DIE(0..dim([F:CAL]DIE)-1))
    If I & [F:CDT]SOH(AX-1)=2
     Assign "[M]CCE"+num$(AX)+"(nolign-1)" With [F:CAL]CCE(I-1)
    Endif
   Next AX
   Affzo [M]
  Endif
 Endif
Endif
Return

