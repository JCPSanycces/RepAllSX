#<AdxTL>@(#)7.0.0.0 $Revision$
#################################################################################
## VALMSKSRM Ecriture du masque
#################################################################################

#################################################################################
## Boucle sur les langues demandées
#################################################################################
$VALMSK
DIRECR = adxrob(0)
LANGUE = GLANGUE
Gosub SET_LANGUE
Gosub LEC_TEXTE From VALMSKLEC
Gosub VALMSK_LAN
adxrob(0) = DIRECR
Return

#################################################################################
## Validation sans une langue
#################################################################################
$VALMSK_LAN
FICSRM = filpath(adxrob(0),"","",APPLI)
If filinfo(FICSRM,0)<0
 Call ECR_TRACE("|"+FICSRM-mess(86,133,1),1) From GESECRAN : # Répertoire inexistant
 Return
Endif
FICSRM = filpath(adxrob(0),ECRAN,"srm",APPLI)
If filinfo(FICSRM,0)>=0
 OLDSRM = filpath(adxrob(0),ECRAN,"old",APPLI)
 Call MOVE(FICSRM,OLDSRM,STAT) From ORDSYS
 If STAT
  Call ECR_TRACE(mess(6,123,1)+num$(STAT)-"MOVE"+"\"+ctrans(FICSRM,"\","/")+"\"+ctrans(OLDSRM,"\","/"),1) From GESECRAN
 Endif
Endif
Openo FICSRM , 0
Gosub ECRIRE_MASQUE
Openo
Call VALID(adxrob(0),ECRAN,APPLI,OK) From VALMSKSUB
If OK
 Call EFFACE(OLDSRM,STAT) From ORDSYS
 If STAT
  Call ECR_TRACE(mess(6,123,1)-num$(STAT)-"EFFACE"+"\"+ctrans(OLDSRM,"\","/"),1) From GESECRAN
 Endif
Endif
Return

$ECRIRE_MASQUE
MAXX = 0
MAXY = 0
MINX = 80
MINY = 21
For B=1 To BLC_NBR
 If BLC_TYP(B)<>5
  MAXX = max(MAXX,BLC_X(B)+BLC_NCO(B))
  MAXY = max(MAXY,BLC_Y(B)+BLC_NLI(B))
  MINX = min(MINX,BLC_X(B))
  MINY = min(MINY,BLC_Y(B))
 Endif
Next B

adxifs = ""
adxirs = chr$(10)
Wrseq "#<AdxV"+GADOVERS+">@(#)%I%"+TET_TXT
Wrseq "#  "+TET_ABR

# En-tête d'écran

If TET_TAI=5 : # C'est un écran d'en-tête
 Call COORD(MINY,0,MINX,0)
 Wrseq tab$;
 If MINY=1
  Call SURFACE(22-MINY,0,MAXX-MINX,0)
 Else
  Call SURFACE(23-MINY,0,MAXX-MINX,0)
 Endif
 Wrseq tab$;
 Wrseq "Folder ";
 Call COORD(MAXY+1-MINY+1,0,1,0)
 Wrseq tab$;
 If MINY=1
  Call SURFACE(21-MAXY,6,MAXX-MINX,0)
 Else
  Call SURFACE(22-MAXY,6,MAXX-MINX,0)
 Endif
 Wrseq
Else
 Call COORD(MINY,0,MINX,0)
 Wrseq tab$;
 Call SURFACE(MAXY-MINY+1,0,MAXX-MINX,0)
 Wrseq
Endif

# Parcours des blocs

For B=1 To BLC_NBR
 If find(BLC_TYP(B),1,2,4,5)

  NBCHAMP = 0
  NBVISIB = 0
  For I=1 To LIG_NBR(B)
   If LIG_ZON(B,I)=BLC_BAS(B)
    L = I
   Else
    NBCHAMP += 1
    If LIG_SAI(B,I)<3
     NBVISIB += 1
    Endif
   Endif
  Next I

  If NBCHAMP or BLC_TYP(B)=4 : # On ne génère plus les blocs vides

   Wrseq "##### DEBUT DE BLOC"
#   Début de bloc
   Wrseq "<"
#   Coordonnées
   If BLC_TYP(B)=5
    Wrseq "0,0";tab$;"0,0";
   Else
    Call COORD(BLC_Y(B)-MINY+1,1,BLC_X(B)-MINX+1,1)
    Wrseq tab$;
    Call SURFACE(BLC_NLI(B),0,BLC_NCO(B)-1,0)
   Endif
#   Intitulé
   If BLC_EVL(B)<>""
    Wrseq tab$;vireblc(format$("KT:250X",BLC_EVL(B)),2) : INTI = 1
   Elsif BLC_TXT(B)<>""
    Wrseq tab$;'"';BLC_TXT(B);'"' : INTI = 1
   Else
    Wrseq tab$;'""' : INTI = 0
   Endif

# Traitement des différents types de blocs

   Case BLC_TYP(B)

    When 1 : # Tableau
 
     If NBCHAMP
      Wrseq "%"
      If INTI : # S'il y a un intitulé, on décale vers le bas
       Call COORD(2,-2,1,1)
       Wrseq tab$;
       Call SURFACE(BLC_NLI(B),-6,BLC_NCO(B)-1,-4)
      Else
       Call COORD(1,+5,1,1)
       Wrseq tab$;
       Call SURFACE(BLC_NLI(B),-5,BLC_NCO(B)-1,-4)
      Endif
      Wrseq
      OPTTAB = BLC_OPT(B) 
      K = 0  : # k, nb de colonnes fixes
      For I=1 To 9
       J = instr(1,OPTTAB,num$(I))
       If J
        OPTTAB = left$(OPTTAB,J-1)+right$(OPTTAB,J+1)
        K = I : Break
       Endif
      Next I
      If instr(1,OPTTAB,"K")  : OPTTAB += "M" : Endif : # Option d'enchaînement de saisie
      If !instr(1,OPTTAB,"G") : OPTTAB += "G" : Endif
      Wrseq BLC_LIG(B);",";LIG_NBR(B);tab$;'"';OPTTAB;'"';
      Wrseq tab$;BLC_BAS(B);tab$;BLC_RNG(B);
      Wrseq tab$;num$(K)
      Gosub ACTION
      PRZON = 1
      For L=1 To LIG_NBR(B)
       If LIG_ZON(B,L)<>BLC_BAS(B)
        If PRZON & LIG_TYP(B,L)=FMTSHO & LIG_SAI(B,L)=2 : # Pour virer le "NUMLIG"
         LIG_FTY(B,L) = "-N"
         LIG_SAI(B,L) = 3
        Endif
        Gosub ZONE_TABLEAU
        PRZON = 0
       Endif
      Next L
      Wrseq "%"
     Endif

    When 2 : # Liste

#  Les zones
     For L=1 To LIG_NBR(B)
      Case LIG_GRA(B,L)
       When 3       : Gosub BOUT_VERT_CAD
       When 4       : Gosub BOUT_VERT_SANS
       When 5       : Gosub BOUT_HZ_CAD
       When 6       : Gosub BOUT_HZ_SANS
       When Default : Gosub ZONE
      Endcase
     Next L

#   Les fonds
     For L=1 To LIG_NBR(B)
      If LIG_SAI(B,L)<3 & (LIG_EVL(B,L)<>"" or LIG_TXT(B,L)<>"") & find(LIG_GRA(B,L),1,10)
       LNGFMT = BLC_CAR(B,LIG_POS(B,L)-1)
       Call COORD(LIG_Y(B,L),-1,LIG_X(B,L)-2-LNGFMT,0)
       Wrseq tab$;"1";tab$;"8,"+num$(4*LNGFMT);tab$;
       If LIG_EVL(B,L)<>""
        If left$(LIG_EVL(B,L),1)="#"
         For indice=0 To LIG_DIM(B,L)-1
          If indice>0
           Call COORD(LIG_Y(B,L)+indice,-1,LIG_X(B,L)-2-LNGFMT,0)
           Wrseq tab$;"1";tab$;"8,"+num$(4*LNGFMT);tab$;
          Endif
          Wrseq '"'+evalue(right$(LIG_EVL(B,L),2))+'"'
         Next indice
        Else
         Wrseq LIG_EVL(B,L)
        Endif
       Elsif LIG_TXT(B,L)<>""
        If LIG_DIM(B,L)>1 & LIG_GRA(B,L)=1
         LIGNE = LIG_TXT(B,L)
         For J=1 To LIG_DIM(B,L)
          If LIGNE="" : Break : Endif
          If J>1
           Call COORD(LIG_Y(B,L)+J-1,-1,LIG_X(B,L)-2-LNGFMT,0)
           Wrseq tab$;"1";tab$;"8,"+num$(4*LNGFMT);tab$;
          Endif
          K = instr(1,LIGNE,"\")
          If !K
           Wrseq '"';LIGNE;'"'
           LIGNE = ""
          Else
           Wrseq '"';left$(LIGNE,K-1);'"'
           LIGNE = right$(LIGNE,K+1)
          Endif
         Next J
        Else
         Wrseq '"';LIG_TXT(B,L);'"'
        Endif
       Endif
      Endif
     Next L

    When 4 : # Texte

#   Les fonds
     For L=1 To LIG_NBR(B)
      If LIG_EVL(B,L)<>"" or LIG_TXT(B,L)<>""
       Call COORD(LIG_Y(B,L),-1,LIG_X(B,L),-1)
       Wrseq tab$;"1";tab$;"8,"+num$(4*(BLC_CAR(B,1)-2));tab$;
       If LIG_EVL(B,L)<>""
        If left$(LIG_EVL(B,L),1)="#"
         Wrseq vireblc(format$("KT:250X",right$(LIG_EVL(B,L),2)),2)
        Else
         Wrseq LIG_EVL(B,L)
        Endif
       Elsif LIG_TXT(B,L)<>""
        Wrseq '"';LIG_TXT(B,L);'"'
       Endif
      Endif
     Next L

    When 5 : # Invisible

     For L=1 To LIG_NBR(B)
      Gosub ZONE
     Next L

   Endcase

# Bloc vide
   If NBCHAMP=0
    Wrseq "1,1";tab$;"1";tab$;'1,1';tab$;'""'
   Endif
#   Fin de bloc
   Wrseq ">"
  Endif
 Endif
Next B
Return

#################################################################################
## Ecriture d'une zone. Cas liste
#################################################################################
$ZONE
If LIG_TYP(B,L)<>FMTFIL : # Filler
 Wrseq "{"
 Wrseq LIG_ZON(B,L);tab$;LIG_FNU(B,L);tab$;
 If find(LIG_TYI(B,L),1,7)
  Wrseq LIG_LNG(B,L);
 Else
  Wrseq "0";
 Endif
 Wrseq tab$;LIG_DIM(B,L)
 If LIG_SAI(B,L)<3
  Call COORD(LIG_Y(B,L),-1,LIG_X(B,L),-3)
 Else
  Wrseq "0,0";
 Endif
 Wrseq tab$;
 Gosub FORMA
 If LIG_GRA(B,L)=2
  If LIG_EVL(B,L)<>""
   If left$(LIG_EVL(B,L),1)="#"
    Wrseq ',';vireblc(format$("KT:80X",right$(LIG_EVL(B,L),2)),2);
   Else
    Wrseq ',';vireblc(format$("KT:80X",LIG_EVL(B,L)),2);
   Endif
  Else 
   Wrseq ',"'+LIG_TXT(B,L)+'"';
  Endif
 Endif
 Wrseq tab$;BLC_RNG(B);
 If BLC_TYP(B)<>5
  If LIG_TYI(B,L)=1 & LIG_GRA(B,L)=1 : # Combos
   Wrseq tab$;4*(LIG_FLN(B,L)-2);
  Else
   If LIG_TYI(B,L)=7 & LIG_FLN(B,L)>15 & LIG_GRA(B,L)=1
    Wrseq tab$;int(COEF11*4*LIG_FLN(B,L)); : # Pour compenser la réduction du client
   Elsif find(LIG_GRA(B,L),10,11,12)
    Wrseq tab$;int(COEF11*4*LIG_FLN(B,L)); : # Pour compenser la réduction du client
   Else
    Wrseq tab$;4*LIG_FLN(B,L);
   Endif
  Endif
 Else
  Wrseq tab$;"0";
 Endif
 Wrseq
 Gosub AIDE
 Gosub ACTION
 Wrseq "}"
Endif
Return

$FORMA
If LIG_FMT(B,L)<>""
 If left$(LIG_FMT(B,L),1)="="
  Wrseq right$(LIG_FMT(B,L),2);
 Else
  Wrseq '"'+LIG_FMT(B,L)+'"';
 Endif
Elsif left$(LIG_FTY(B,L),1)="="
 Wrseq right$(LIG_FTY(B,L),2)+LIG_FOP(B,L)+":"+LIG_FCH(B,L);
Else
 Wrseq '"'+LIG_FTY(B,L)+LIG_FOP(B,L)+":"+LIG_FCH(B,L)+'"';
Endif
Return

$AIDE
If LIG_SAI(B,L)<3
 Wrseq '"|'+ECRAN+'|"+GFONCTION+"|'+LIG_AID(B,L)+'"';tab$; : # Aide sur F1
 Wrseq '"'+LIG_TXT(B,L)+'"'                                : # Aide obligatoire
Else
 Wrseq '""';tab$;'""'
Endif
Return    

#################################################################################
## Ecriture d'une zone. Cas tableau
#################################################################################
$ZONE_TABLEAU
Wrseq "{"
If left$(LIG_EVL(B,L),1)="#"
 Wrseq '"'+evalue(right$(LIG_EVL(B,L),2))+'"';
 LRGENT = len(evalue(right$(LIG_EVL(B,L),2)))
Elsif LIG_EVL(B,L)<>""
 Wrseq vireblc(format$("KT:80X",LIG_EVL(B,L)),2);
 If LIG_LGR(B,L)<>0
  LRGENT = LIG_LGR(B,L)
 Else
  LRGENT = len(vireblc(format$("KT:80X",LIG_EVL(B,L)),2))
 Endif
Elsif LIG_TXT(B,L)<>""
 Wrseq '"'+LIG_TXT(B,L)+'"';
 LRGENT = len(LIG_TXT(B,L))
Else
 Wrseq '""';
 LRGENT = 0
Endif
Wrseq tab$;
LRGENT = -int(-COEF2*LRGENT) : # Le titre des colonnes est en minuscule gras
Gosub FORMA
If NBVISIB=1
 # Le retaillage d'une colonne d'un tableau mono-colonne étant impossible
 Wrseq tab$;num$(4*max(LRGENT,LIG_FLN(B,L)));
Else
 If LIG_TYI(B,L)=7 & LIG_FLN(B,L)>15 & LIG_GRA(B,L)=1
  # Pour compenser la réduction du client
  Wrseq tab$;4*min(LCOLMAX,max(LRGENT,int(COEF11*LIG_FLN(B,L))));
 Else
  Wrseq tab$;4*min(LCOLMAX,max(LRGENT,LIG_FLN(B,L)));
 Endif
Endif
Wrseq
Wrseq LIG_ZON(B,L);tab$;LIG_FNU(B,L);tab$;
If find(LIG_TYI(B,L),1,7)
 Wrseq LIG_LNG(B,L)
Else
 Wrseq "0"
Endif
Gosub AIDE
Gosub ACTION
Wrseq "}"
Return

#################################################################################
## Ecriture d'une zone. Cas boutons
#################################################################################
$BOUT_VERT_CAD
Wrseq "##### BOUTON"
Wrseq "<"
Call COORD(LIG_Y(B,L),0,LIG_X(B,L),0)
Wrseq tab$;
Call SURFACE(len(mess(0,LIG_LIB(B,L),1))+1,0,LIG_FLN(B,L)-1,0)
Wrseq tab$;'"';LIG_TXT(B,L);'"'
Wrseq "{"
Wrseq LIG_ZON(B,L);tab$;LIG_FNU(B,L);tab$;LIG_FLN(B,L);tab$;LIG_DIM(B,L)
Call COORD(2,-1,2,-3)
Wrseq tab$;
Gosub FORMA
Wrseq tab$;BLC_RNG(B);tab$;"0"
Gosub AIDE
Gosub ACTION
Wrseq "}"
Wrseq ">"
Return

$BOUT_VERT_SANS
Wrseq "##### BOUTON"
Wrseq "{"
Wrseq LIG_ZON(B,L);tab$;LIG_FNU(B,L);tab$;LIG_LNG(B,L);tab$;LIG_DIM(B,L)
Call COORD(LIG_Y(B,L),-1,LIG_X(B,L),-3)
Wrseq tab$;
Gosub FORMA
Wrseq tab$;BLC_RNG(B);tab$;"0"
Gosub AIDE
Gosub ACTION
Wrseq "}"
Return

$BOUT_HZ_CAD
Wrseq "##### BOUTON"
Wrseq "<"
Call COORD(LIG_Y(B,L),0,LIG_X(B,L),0)
Wrseq tab$;
Call SURFACE(2,0,LIG_FLN(B,L),-2)
Wrseq tab$;'"';LIG_TXT(B,L);'"'
Wrseq "{"
Wrseq LIG_ZON(B,L);tab$;LIG_FNU(B,L);tab$;-int(-COEF1*LIG_LNG(B,L));tab$;LIG_DIM(B,L)
Call COORD(2,-1,2,-3)
Wrseq tab$;
Gosub FORMA
Wrseq tab$;BLC_RNG(B);tab$;"0"
Gosub AIDE
Gosub ACTION
Wrseq "}"
Wrseq ">"
Return

$BOUT_HZ_SANS
Wrseq "##### BOUTON"
Wrseq "{"
Wrseq LIG_ZON(B,L);tab$;LIG_FNU(B,L);tab$;LIG_LNG(B,L);tab$;LIG_DIM(B,L)
Call COORD(LIG_Y(B,L),-1,LIG_X(B,L),-3)
Wrseq tab$;
Gosub FORMA
Wrseq tab$;BLC_RNG(B);tab$;"0"
Gosub AIDE
Gosub ACTION
Wrseq "}"
Return

#################################################################################
## Génération des événements
#################################################################################
$ACTION
#  Actions
Gosub SETPROG
NBETQ = 0
For A=LIG_PTA(B,L) To LIG_PTA(B,L)+LIG_ACT(B,L)-1
 If find(ACT_ETQ(A),"IB_","AV_","D_","AS_","C_","AP_","AM_","AVANT_","APRES_","S_","SA_","P_")
  NBETQ = 1 : Break
 Endif
Next A
If NBETQ
 Wrseq "Gosub ON_";LIG_ZON(B,L);" From ";NOMPROG
Endif
Return

$SETPROG
NOMPROG = "W"+num$(LIG_PRO(B,L))+TET_AUT
Return

#################################################################################
## Sous-programmes divers
#################################################################################
$SET_LANGUE
adxrob(0)   = "E"+LANGUE 
adxrob(1)   = "M"+LANGUE 
messname(0) = LANGUE
adxtms      = APPLI+".APLSTD"
adxmbm      = adxmbm
GLANGUE     = LANGUE
Return

Subprog COORD(Y,DY,X,DX)
Value Integer Y
Value Integer DY
Value Integer X
Value Integer DX
Wrseq num$(8*(Y-1)+DY)+","+num$(4*(X-1)+DX);
End

Subprog SURFACE(Y,DY,X,DX)
Value Integer Y
Value Integer DY
Value Integer X
Value Integer DX
Wrseq num$(8*Y+DY)+","+num$(4*X+DX);
End

