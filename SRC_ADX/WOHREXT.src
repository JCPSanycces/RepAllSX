# Superviseur
# Gestion objet HREXT

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:07:33"
A_USER  = "DOC"
A_STAMP = "20181109230733"
Return

$DEFAUT
Default File [HREXT]
Return

$OUVFIC
Local File HREXTRACT [HREXT]
Return

$NOMFIC
Local Integer NBLNK , TITLNK(1..20)
Local Char    OBJLNK(GLONAOB)(1..20) , CODLNK(GLONADI)(1..20)
Local Char    DESLNK(20)(1..20) , ABRLNK(GLONABR)(1..20)
Local Integer NUMLNK(1..20) , LIGLNK(1..20)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , ABTAB(GLONABR) , NOMINT(GLONAVA)
Local Integer TYPGES , FLGSTAT , SELORD , TYPOBJ
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA), FLDGRF(GLONAVA), FLDLEG(GLONAVA), FLDGRC(GLONAVA)
Local Char    REPORT1(GLONARP) , REPORT2(GLONARP) , NOMKEY(GLONAVA)
Local Integer DELDEF, FCYREQ
Local Char    SELIND(250) , ADDURL(250)
NOMFIC = "HREXTRACT"
ABFIC  = "HREXT"
ABTAB  = "HREXT"
NOMINT = "EXRTIT"
TYPGES = 1
SELORD = 1
ZSITE  = ""
ZACC   = "EXRCODACC"
FLDGRF = ""
FLDGRC = ""
FLDLEG = ""
FCYREQ = 0
PPAG   = 0
SELIND = "[F:HREXT]EXRTEP"
DELDEF = 0
ADDURL = ""
NOMKEY = "HREXT0"
FLGSTAT = 0
TITOBJ = 55254
NBLNK = 0
Raz NUMLNK , LIGLNK
Return

$OUVRE
If clalev([F:HREXD])=0 : Local File HREXTRACTDAT [HREXD] : Endif
If clalev([F:HREXF])=0 : Local File HREXTRACTFIL [HREXF] : Endif
If clalev([F:HREXP])=0 : Local File HREXTRACTPAR [HREXP] : Endif
If clalev([F:HREXL])=0 : Local File HREXTRACTDEF [HREXL] : Endif
If clalev([F:HREXV])=0 : Local File HREXTRACTVAL [HREXV] : Endif
If clalev([F:HREXG])=0 : Local File HREXTRACTGRP [HREXG] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
Return

$ESPION
NUMESPION = 1
Return

$TIT
Local Char TIT(60)
Call TEXTE(55254,TIT) From OBJDIV
Return

$SETCLE
Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..0) , CLELIG(GLONAVA)
CLEPRIM = 'EXRTEP'
Return

$OPTIONS
Local Integer  NBCOND
Local Char     CONDIT(50)(1..20)
Local Char     OPT(1)(1..20) , OPTSEL(20)
Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
OPTSEL = ''
Return

$LIBPAR
Local Char LIBPAR(30)
Call TEXTE(0,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(20)(0..GNBDERNIER)
Local Char     A_BUF2(50)(0..GNBDERNIER)
If clalev([F:HREXT9])>0 : Close Local File [HREXT9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(20),
& Char     A_TAB2(50)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2
& As [HREXT9]
Return

$LEC_DERLU
Read [ACC]CODACC = GUSER ; [F:HREXT]EXRCODACC
If fstat : Raz [F:ACC] : Endif
Return

$CHARGE_DERLU
If clalev([F:HREXT9])>0
 Read [HREXT9] = [F:HREXT9]A_TABI
 [L]CLE = [F:HREXT9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:HREXT9])>0
 Filter [HREXT9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [HREXT1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:HREXT9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:HREXT]EXRTEP+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:HREXT9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:HREXT9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:HREXT]EXRTEP"
Call TEXTE(5296,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:HREXT]EXRTEP"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:HREXT]EXRTIT"
Call TEXTE(1826,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:50X"
SELFOR(NBSEL) = "K:50X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:HREXT]EXRTIT"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:HREXT_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif
Link [HREXT] With
& [ACC]CODACC=GUSER;[F:HREXT]EXRCODACC
& As [HREXT_]
Return

$DEFAUT_LISTE
Default file [HREXT_]
Return

$OUVRE_JOIN
Local Char    ORDRE_JOI(250)
ORDRE_JOI = "A_TABJ1"
Local Char     A_BUFJ1(20)(1..GNBSEL)
Local Char     A_BUFJ2(15)(1..GNBSEL)
Local Char     A_BUFJ3(80)(1..GNBSEL)
Local File(
& Char     A_TABJ1(20),
& Char     A_TABJ2(15),
& Char     A_TABJ3(80)
& ) From Variable A_BUFJ1, A_BUFJ2, A_BUFJ3
& As [PCEJ]
Return

$TIT_JOIN
Local Char TITJOI(30)(1..3)
Call TEXTE(5296,TITJOI(1)) From OBJDIV
TITJOI(2) = mess(59,100,1) : # Type
TITJOI(3) = mess(38,100,1) : # Nom
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Kf:20X"
LG = 0
TIT = ""
End

$LIENS
Return

$LIAISONS
Return

