#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion objet AUR
Raz GPILOBJ
Call OBJET("AUR",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "LIENS"     : Gosub LIENS
 When "EXEBOUT"   : Gosub BOUTON
 When "SEL_LISTE" : Gosub SELLIST
 When "SETBOUT"   : Gosub SETBOUT
 When "RAZCRE"    : Gosub RAZCRE
 When Default
Endcase
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return

$SELLIST
#   Code sélection SELFXSL
 Raz TEXTE,TEX,NBTEX
 Local Char LCOD(10)(1..100)
 Local Integer NBCOD
 Local File ATABDIV [A_TD]
 Filter [A_TD] Where NUMTAB=915 and A1="PARG"
 For [A_TD]
   If [F:A_TD]A2<>"XSL" and [F:A_TD]A2<>""
     NBCOD+=1
     LCOD(NBCOD)=[F:A_TD]A2
   Endif
 Next
 Filter [A_TD]
 Filter [A_TD] Where NUMTAB=915 and A1<>"" and A1<>"PARG"
 For [A_TD]
  If !find([F:A_TD]A1,LCOD(1..NBCOD)) and !find([F:A_TD]A1,TEX(1..NBTEX))
    NBTEX += 1
    TEXTE(NBTEX) = [F:A_TD]A1
    TEX(NBTEX) = [F:A_TD]A1
  Endif
 Next
 Filter [A_TD]
 Close Local File [A_TD]
Return

#########################################################
$RAZCRE
[M:AUR0]SECLEV=2 : Affzo [M:AUR0]SECLEV
Return

#########################################################
$LIENS
Call TEXTE([M:AUR0]INTIT,[M:AUR0]ZINTIT) From OBJDIV
Diszo [M:AUR0]PLEURL
Case [M:AUR0]TYPURL
  When 1            : # URL
    Diszo [M:AUR1]
    Diszo [M:AUR2]
    Diszo [M:AUR0]TYPXSL,PARXSL
    Actzo [M:AUR0]PLEURL
  When 2            : # XSL
    Actzo [M:AUR1]
    Actzo [M:AUR2]
    Actzo [M:AUR0]TYPXSL,PARXSL
  When 3            : # Html
    Actzo [M:AUR1]
    Diszo [M:AUR2]
    Diszo [M:AUR0]TYPXSL,PARXSL
Endcase

Return

$BOUTON
If BOUT="3" : Call RECHUTURL([M:AUR0]CODURL) : Endif
Return

#########################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File AURL    [AUR1]
 Local File ATEXTE  [ATX1]
Else
 Local File =[M]DOSORG+".AURL"    [AUR1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AURL    [AUR2]
 Local File ATEXTE  [ATX2]
Else
 Local File =[M]DOSDES+".AURL"    [AUR2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AUR1], [ATX1], [AUR2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [AUR2] , [ATX2]
 Delete [AUR2] Where CODURL=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AURL" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AUR2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AUR1]AUR0 Where CODURL=TABLE
  [F:AUR2] = [F:AUR1]
  Call COPTEXTE([F:AUR1]INTIT,[F:AUR2]INTIT) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:AUR2]UPDUSR)>0 : [F:AUR2]UPDUSR = GUSER : Endif
  If dim([F:AUR2]UPDDAT)>0 : [F:AUR2]UPDDAT = date$ : Endif
  If dim([F:AUR2]UPDTIM)>0 : [F:AUR2]UPDTIM = time  : Endif
  Write [AUR2]
  If fstat
   GOK=0 : Call FSTA("AUR2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#########################################################
Subprog AV_TYPXSL(VALEUR)
Variable Integer VALEUR
If [M:AUR0]TYPURL<>2 : mkstat=1 : Endif
End

Subprog AV_URL(VALEUR)
Variable Char    VALEUR()
If [M:AUR0]TYPURL<>1 and [M:AUR0]TYPURL<>3 : mkstat=1 : Endif
End

Subprog AS_XSLCLOB(VALEUR)
Variable Clbfile VALEUR
End

Subprog AV_UCOD(VALEUR)
Variable Char    VALEUR()
If indice>0 and [M]UCOD(indice-1)="" : mkstat=1 : Endif
End

Subprog C_UCOD(VALEUR)
Variable Char    VALEUR()
VALEUR=vireblc(VALEUR,2)
If indice>0
  For I=0 To indice-1
    If [M]UCOD(I)=VALEUR
      GMESSAGE=mess(149,150,1)+num$(I+1)  : # Code déjà défini en ligne xx
      mkstat=2
      End
    Endif
  Next I
Endif
End

Subprog AV_UMEN(VALEUR)
Variable Decimal VALEUR
If [M]UCOD(indice)="" : mkstat=1 : Endif
End

Subprog C_UMEN(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : End : Endif
If clalev([F:AML])=0 : Local File AMENLOC [AML] : Endif
Read [AML]MENLOC=VALEUR
If fstat<>0
  GMESSAGE=mess(154,124,1) :   # Menu inexistant
  mkstat=2
Else
  If VALEUR<100
    [M]ULIB(indice)=mess(VALEUR,0,1)
  Elsif VALEUR>200
    [M]ULIB(indice)=mess(VALEUR-200,200,1)
  Endif
  If vireblc([M]ULIB(indice),2)=""
    [M]ULIB(indice)=mess(0,VALEUR,1)
  Endif
  Affzo [M]ULIB
Endif
End

Subprog AV_ULIB(VALEUR)
Variable Char    VALEUR()
If [M]UMEN(indice)=0 : mkstat=1 : Endif
End


Subprog AV_UPRG(VALEUR)
Variable Char    VALEUR()
End

Subprog C_UPRG(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If clalev([F:ASU])=0 : Local File ASUBPROG [ASU] : Endif
Filter [ASU] Where PRG=VALEUR
Local Integer NB
For [ASU]
  NB+=1
Next
Filter [ASU]
If NB=0
  GMESSAGE=mess(90,123,1)
  mkstat=2
Endif
End

Subprog AV_USPRG(VALEUR)
Variable Char    VALEUR()
If [M]UPRG(indice)="" : mkstat=1 : Endif
End

Subprog C_USPRG(VALEUR)
Variable Char    VALEUR()
If clalev([F:ASU])=0 : Local File ASUBPROG [ASU] : Endif
Read [ASU]ASU0=[M]UPRG(indice);VALEUR
If fstat<>0
  GMESSAGE=mess(71,150,1)
  mkstat=2
  End
Endif
#  Contrôle que la valeur est différente de celles déjà saisies
For I=0 To indice-1
  If [M]UPRG(I)=[M]UPRG(indice) and [M]USPRG(I)=VALEUR
    GMESSAGE=mess(29,100,1)-num$(I+1)  : # Code déjà saisi en ligne ..
    mkstat=2
  Endif
Next I

Call TEXTE([F:ASU]INTIT,[M]UINTIT(indice)) From OBJDIV
End

Subprog AV_UINTIT(VALEUR)
Variable Char    VALEUR()
If [M]UPRG(indice)="" or [M]USPRG(indice)=""  : mkstat=1 : Endif
End

Subprog AV_UPARCOD(VALEUR)
Variable Char    VALEUR()
If indice>0 and [M]UPARCOD(indice-1)="" : mkstat=1 : Endif
End

Subprog AV_UPARLIB(VALEUR)
Variable Char    VALEUR()
If [M]UPARCOD(indice)="" : mkstat=1 : Endif
End

Subprog AV_UPARDEF(VALEUR)
Variable Char    VALEUR()
If [M]UPARCOD(indice)="" : mkstat=1 : Endif
End

Subprog AV_UPARMEN(VALEUR)
Variable Integer VALEUR
If [M]UPARCOD(indice)="" : mkstat=1 : Endif
End

Subprog D_ULIB(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  If clalev([F:AML])=0 : Local File AMENLOC [AML] : Endif
  Read [AML]MENLOC=[M]UMEN(indice)
  If fstat=0
    If [M]UMEN(indice)<100
      VALEUR=mess([M]UMEN(indice),0,1)
    Elsif [M]UMEN(indice)>200
      VALEUR=mess([M]UMEN(indice)-200,200,1)
    Endif
  Endif
Endif
End

Subprog D_UINTIT(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  If clalev([F:ASU])=0 : Local File ASUBPROG [ASU] : Endif
  Read [ASU]ASU0=[M]UPRG(indice);[M]USPRG(indice)
  If fstat=0
    Call TEXTE([F:ASU]INTIT,VALEUR) From OBJDIV
  Endif
Endif
End

Subprog C_UPARCOD(VALEUR)
Variable Char    VALEUR()
Local Integer I
If indice>0
  For I=0 To indice-1
    If [M]UPARCOD(I)=VALEUR
      GMESSAGE=mess(149,150,1)+num$(I+1)  : # Code déjà défini en ligne xx
      mkstat=2
      End
    Endif
  Next I
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran AURL0) 18/04/2006 14:31:41 (CCORA)
######################################################################################
Subprog AP_TYPURL(VALEUR)
Variable Integer VALEUR
Diszo [M:AUR0]PLEURL
Case VALEUR
  When 1            : # URL
    Diszo [M:AUR1]
    Diszo [M:AUR2]
    Diszo [M:AUR0]TYPXSL,PARXSL
    Actzo [M:AUR0]PLEURL
  When 2            : # XSL
    Actzo [M:AUR1]
    Actzo [M:AUR2]
    Actzo [M:AUR0]TYPXSL,PARXSL
  When 3            : # html
    Actzo [M:AUR1]
    Diszo [M:AUR2]
    Diszo [M:AUR0]TYPXSL,PARXSL
Endcase
End

Subprog AM_TYPURL(VALEUR)
Variable Integer VALEUR
If VALEUR=1         : # URL
 If [M:AUR0]PLEURL=0
  [M:AUR0]PLEURL=1
  Affzo [M:AUR0]PLEURL
 Endif
Endif
End


######################################################################################
Subprog RECHUTURL(CODURL)
Value Char CODURL
If CODURL="" : End : Endif

Local Char INTITM(50)
Local File AMSK [AM1K]
#Filter [AM1K] Where BLOCLIEN1=CODURL or BLOCLIEN2=CODURL or BLOCLIEN3=CODURL
Filter [AM1K] Where find(CODURL,BLOCLIEN1(0..14)) or find(CODURL,BLOCLIEN2(0..14))
&                or find(CODURL,BLOCLIEN3(0..14))


Call OUVRE_TRACE(" ") From LECFIC
Call ECR_TRACE(mess(235,123,1)-CODURL,0) From GESECRAN

For [AM1K]
  Call TEXTE([F:AM1K]INTMSK,INTITM) From OBJDIV
  Call ECR_TRACE(mess(176,126,1)-":"-[F:AM1K]CODMSK-INTITM,0) From GESECRAN
Next
Close Local File [AM1K]

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

