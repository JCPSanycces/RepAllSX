#<AdxTL>@(#)0.0.0.0 $Revision$
#** ####################################################################################################################
#*
#* Label      : action
#* Purpose    : standard entry point
#*
#*! ####################################################################################################################
$ACTION
  Case ACTION
    When "BOUTON"  : Gosub BOUTON
    When Default   :
  Endcase
Return

#** ####################################################################################################################
#*
#* Label      : bouton
#* Purpose    : a button at the bottom of the screen was activated
#*
#*! ####################################################################################################################
$BOUTON
  If BOUT = "S" Then
    # search button
    Call SEARCH()
  Endif
Return

#** ####################################################################################################################
#*
#* SubProg    : search
#* Purpose    : checks the selected criteria and afterwards the actual search will be performed
#*
#* Parameters :
#*
#*! ####################################################################################################################
Subprog SEARCH()
  Local Integer I

  If [M:F246]CPY = "" Then
    End
  Endif

  GOK = 0

  # open tables
  If clalev([F:CNX]) = 0 Then : Local File CONTEXT  [CNX] : Endif
  If clalev([F:FIS]) = 0 Then : Local File FISCYEAR [FIS] : Endif

  Link [CNX] With [FIS]FIY0 = [F:CNX]CPY;[F:CNX]CNX
&   As [LNK]
&   Where [F:CNX]CPY = [M:F246]CPY
&   Order By [F:FIS]DATSTRFIY
  For [LNK]
    If [M:F246]TYPPER = 1 Then
      # fiscal year
      If [M:F246]DATSTR = [F:FIS]DATSTRFIY and [M:F246]DATEND = [F:FIS]DATENDFIY Then
        GOK = 1
      Endif
    Else
      # periods
      For I = 0 To [F:FIS]NBRPER
        If [M:F246]DATSTR = [F:FIS]DATSTRPER(I) and [M:F246]DATEND = [F:FIS]DATENDPER(I) Then
          GOK = 1
        Endif
      Next I
    Endif
  Next

  # close tables
  If clalev([F:CNX]) <> 0 Then : Close Local File [CNX] : Endif
  If clalev([F:FIS]) <> 0 Then : Close Local File [FIS] : Endif

  If GOK = 1 Then
    Call COLLECT_DATA()
  Else
    Call ECR_TRACE(mess(1010,2299,1), 1) From GESECRAN
  Endif
End

#** ####################################################################################################################
#*
#* SubProg    : collect_data
#* Purpose    : performs the actual data mapping
#*
#* Parameters :
#*
#*! ####################################################################################################################
Subprog COLLECT_DATA()
  Local Integer I : I = 0

  Call TEMPON("L") From GESECRAN

  # open tables
  If clalev([F:FLU]) = 0 Then : Local File FXDLIFL   [FLU] : Endif
  If clalev([F:FAS]) = 0 Then : Local File FXDASSETS [FAS] : Endif
  If clalev([F:PFL]) = 0 Then : Local File PARFLUX   [PFL] : Endif
  If clalev([F:DEP]) = 0 Then : Local File DEPREC    [DEP] : Endif
  If clalev([F:GAC]) = 0 Then : Local File GACCOUNT  [GAC] : Endif
  If clalev([F:CNX]) = 0 Then : Local File CONTEXT   [CNX] : Endif

  Effzo [M:F246]10

  If [M:F246]TYPPER = 1 Then
    # fiscal year
    Link [FLU] With [FAS]FAS1 = [F:FLU]CPY;[F:FLU]AASREF,
&                   [PFL]PFL0 = [F:FLU]CODTXS;[F:FLU]COA;[F:FLU]TXSCAT,
&                   [DEP]DEP0 = [F:FLU]AASREF;[F:FLU]DPRPLN;[F:FLU]FIYENDDAT;[F:FLU]FIYENDDAT,
&                   [GAC]GAC0 = [F:FLU]COA;[F:FLU]GAC,
&                   [CNX]CNX0 = [F:FLU]CPY;[F:FLU]CNX
&     As [LNK]
&     Where [F:FLU]CPY       = [M:F246]CPY
&       and [F:FLU]DPRPLN    = [M:F246]DPRPLN
&       and [F:FLU]CODTXS    = [M:F246]CODTXS
&       and [F:FLU]FIYSTRDAT = [M:F246]DATSTR
&       and [F:FLU]FIYENDDAT = [M:F246]DATEND
&       and [F:FLU]PERSTRDAT = [0/0/0]
&       and [F:FLU]PERENDDAT = [0/0/0]
&     Order By [F:PFL]POSTXS;[F:FLU]GAC;[F:FAS]AASREF
  Else
    # periods
    Link [FLU] With [FAS]FAS1 = [F:FLU]CPY;[F:FLU]AASREF,
&                   [PFL]PFL0 = [F:FLU]CODTXS;[F:FLU]COA;[F:FLU]TXSCAT,
&                   [DEP]DEP0 = [F:FLU]AASREF;[F:FLU]DPRPLN;[F:FLU]FIYENDDAT;[F:FLU]PERENDDAT,
&                   [GAC]GAC0 = [F:FLU]COA;[F:FLU]GAC,
&                   [CNX]CNX0 = [F:FLU]CPY;[F:FLU]CNX
&     As [LNK]
&     Where [F:FLU]CPY       = [M:F246]CPY
&       and [F:FLU]DPRPLN    = [M:F246]DPRPLN
&       and [F:FLU]CODTXS    = [M:F246]CODTXS
&       and [F:FLU]PERSTRDAT = [M:F246]DATSTR
&       and [F:FLU]PERENDDAT = [M:F246]DATEND
&     Order By [F:PFL]POSTXS;[F:FLU]GAC;[F:FAS]AASREF
  Endif

  # main loop
  For [LNK]
    [M:F246]PFLDES(I)   = [F:PFL]DES
    [M:F246]GAC(I)      = [F:FLU]GAC
    [M:F246]GACDES(I)   = [F:GAC]DES
    [M:F246]AASREF(I)   = [F:FLU]AASREF
    [M:F246]AASDES(I)   = [F:FAS]AASDES1
    [M:F246]PURDAT(I)   = [F:FAS]PURDAT
    [M:F246]DPRTYP(I)   = [F:DEP]DPM
    [M:F246]DPRDUR(I)   = [F:DEP]DPRDUR
    [M:F246]DPRRAT(I)   = [F:FLU]DPRRAT
    [M:F246]BASSTR(I)   = [F:FLU]BSEVALSTR

### START IND6 ###
    If [F:FLU]RVAAMT <> 0 Then
      [M:F246]DPRSTR(I)  = [F:FLU]RVAAMT - [F:FLU]INCBUY
      [M:F246]NETSTR(I)  = [M:F246]BASSTR(I) - [M:F246]DPRSTR(I)
      [M:F246]BASDISP(I) = [M:F246]DPRSTR(I)
      [M:F246]DPRDSP(I)  = -[M:F246]DPRSTR(I)
      If [F:FLU]RVAAMT < 0 Then
        [M:F246]BASDEC(I) = -[F:FLU]RVAAMT
      Else
        [M:F246]BASINC(I) = [F:FLU]RVAAMT
      Endif
    Else
      [M:F246]DPRSTR(I)   = [F:FLU]DPRCUMSTR
      [M:F246]NETSTR(I)   = [M:F246]BASSTR(I) - [M:F246]DPRSTR(I)
      [M:F246]BASADDN(I)  = [F:FLU]INCBUY
      [M:F246]BASDISP(I)  = [F:FLU]DCRSAL
      If [F:FLU]TXSCATORI <> "" or [F:FLU]FCYORI <> "" Then
        [M:F246]TRFVAL(I) = [F:FLU]INCTRF
        [M:F246]DPRDSP(I) = [F:FLU]INCDPRTRF
      Else
        [M:F246]TRFVAL(I) = -[F:FLU]DCRTRF
        [M:F246]DPRDSP(I) = -([F:FLU]DCRDPEOUT + [F:FLU]DCRDPRTRF)
      Endif
    Endif
###  END  ###

    [M:F246]DPRCUM(I)   = [F:FLU]DPE + [F:FLU]EXCDPR
    [M:F246]BASEND(I)   = [M:F246]BASSTR(I) + [M:F246]BASADDN(I) - [M:F246]BASDISP(I) + [M:F246]TRFVAL(I) - [M:F246]BASDEC(I) + [M:F246]BASINC(I)
    [M:F246]DPREND(I)   = [M:F246]DPRSTR(I) + [M:F246]DPRCUM(I) + [M:F246]DPRDSP(I)
    [M:F246]NETEND(I)   = [M:F246]BASEND(I) - [M:F246]DPREND(I)
    [M:F246]NETVAL(I)   = [M:F246]BASADDN(I) - [M:F246]BASDISP(I) + [M:F246]TRFVAL(I) - [M:F246]DPRCUM(I) - [M:F246]DPRDSP(I) - [M:F246]BASDEC(I) + [M:F246]BASINC(I)
    I += 1
  Next
  [M:F246]CUR = [F:CNX]CUR

  # close tables
  If clalev([F:FLU]) <> 0 Then : Close Local File [FLU] : Endif
  If clalev([F:FAS]) <> 0 Then : Close Local File [FAS] : Endif
  If clalev([F:PFL]) <> 0 Then : Close Local File [PFL] : Endif
  If clalev([F:DEP]) <> 0 Then : Close Local File [DEP] : Endif
  If clalev([F:GAC]) <> 0 Then : Close Local File [GAC] : Endif
  If clalev([F:CNX]) <> 0 Then : Close Local File [CNX] : Endif

  # count
  [M:F246]BASPAG = I
  nolign = I
  # reset the table
  Affzo [M:F246]10

  Call TEMPOFF From GESECRAN
End
