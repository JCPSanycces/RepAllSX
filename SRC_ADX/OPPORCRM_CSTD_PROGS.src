#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe OPPORCRM
###################################################################################################
Funprog GET_OPPSRENUM_VALUE(ACTX, SPIMNUM, SSRENUM)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SPIMNUM
Variable Char SSRENUM

Local Integer IARENDRE
Local Integer IRET
Local Integer IPIMTYP
Local Char SPROJECT(GLONOPP)
Local Char SBUDGET(GLONVCR)
Local Char STASK(GLONVCR)
Local Char SMESS(250)

  # Issue X3-60926 - 2018-03-30 by FGR
  IARENDRE = [V]CST_AOK
  Raz SSRENUM
  # -------------------
  If SPIMNUM <> AVOID.ACHAR Then
    Local File OPPORCRM [OPPCRM]
    # -------------------
    IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(ACTX, SPIMNUM, SPROJECT, SBUDGET, STASK)
    IPIMTYP = func PIMPL_CSTD_PROGS.GET_PIMTYP_VALUE(ACTX, SPROJECT, AVOID.ACHAR, AVOID.ACHAR, SMESS)
    If IPIMTYP = 1 or IPIMTYP = 3 Then
      Read [OPPCRM]OPPCRM0=SPROJECT
      If fstat = [V]CST_AOK Then
        SSRENUM = [F:OPPCRM]OPPSRENUM
      Endif
    Endif
  Endif
End IARENDRE

