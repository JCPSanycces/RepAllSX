#<AdxTL>@(#)4.0.0.0 $Revision$
####################################################
## Etat HISTOVRA
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    SOCIETE(GLONCPY) , SITEDEB(GLONFCY) , SITEFIN(GLONFCY) , MATDEB(GLONEML) , MATFIN(GLONEML)
Local Date    DATEDEB , DATEFIN
Local Char    PARAM(20) , PROFIL(GLONPRF) , SERVICE(GLONSRV) , POPULATION(GLONPOP)
Local Char    CRITERE1(250) , CRITERE2(250)
Local Integer TYPMONT
Local Integer I , J , K , NBMOIS , GRP , NUMREQ , OK
Local Decimal MONT(1..120)

If clalev([F:VLA])=0    : Local File VALEUR    [VLA]  : Endif
If clalev([F:VEP])=0    : Local File VALEMP    [VEP]  : Endif
If clalev([F:ID])=0     : Local File EMPLOID   [ID]   : Endif
If clalev([F:HRPOA])=0    : Local File POPULA    [HRPOA]  : Endif
If clalev([F:FGR])=0    : Local File FACGROUP  [FGR]  : Endif
If clalev([F:VRA])=0    : Local File VARIA     [VRA]  : Endif
If clalev([F:TMP])=0    : Local File TMPHISTO  [TMP]  : Endif
If clalev([F:ACC])=0    : Local File ACCES     [ACC]  : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]: Endif
#THRAM 27/03/2017 - start
If clalev([F:CPY])=0    : Local File COMPANY  [CPY]: Endif
#THRAM 27/03/2017 - end

Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE)
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,SITEDEB)
Call GETPARAM("sitefin",NBPAR,PARAMETRE,SITEFIN)
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION)
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB)
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN)
Call GETPARAM("datedeb",NBPAR,PARAMETRE,PARAM) : DATEDEB = PARAM
Call GETPARAM("datefin",NBPAR,PARAMETRE,PARAM) : DATEFIN = PARAM
Call GETPARAM("profil",NBPAR,PARAMETRE,PROFIL)
Call GETPARAM("service",NBPAR,PARAMETRE,SERVICE)
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

CRITERE1 = '[F:VLA]TYP=4 & [F:VLA]CPY="" & [F:VLA]FCY="" & [F:VLA]BUL<>""'
If DATEDEB<>[0/0/0]
 CRITERE1 -= "& [F:VEP]PYRDAT>=["+format$(GFMD,DATEDEB)+"]"
Endif
If DATEFIN<>[0/0/0]
 CRITERE1 -= "& [F:VEP]PYRDAT<=["+format$(GFMD,DATEFIN)+"]"
Endif
If MATDEB<>""
 CRITERE1 -= '& [F:VLA]EMP>="'+MATDEB+'"'
Endif
If MATFIN<>""
 CRITERE1 -= '& [F:VLA]EMP<="'+MATFIN+'"'
Endif

CRITERE2 = '[F:FGR]CPY="'+SOCIETE+'"'
CRITERE2 -= "& [F:VRA]PRNFLG(0)=2"
If SITEDEB<>""
 CRITERE2 -= '& [F:VEP]FCY>="'+SITEDEB+'"'
Endif
If SITEFIN<>""
 CRITERE2 -= '& [F:VEP]FCY<="'+SITEFIN+'"'
Endif
If PROFIL<>""
 CRITERE2 -= '& [F:VEP]PRF="'+PROFIL+'"'
Endif
If SERVICE<>""
 CRITERE2 -= '& [F:VEP]SRV="'+SERVICE+'"'
Endif


#THRAM 27/03/2017 - start
#If POPULATION<>""
# Link [VLA] With [VRA]VRA0=[F:VLA]VARCOD , [ID]ID0=[F:VLA]EMP
#& , [VEP]VEP5=[F:VLA]BUL , [FGR]FGR0=SOCIETE;[F:VEP]FCY , [HRPOA]POA0=POPULATION;[F:VLA]EMP
#& As [LVLA]
#& Where evalue(CRITERE1) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
#& Order By Key CLE=[F:VLA]EMP;[F:VEP]CTRNUM;[F:VLA]VARCOD
#Else
# Link [VLA] With [VRA]VRA0=[F:VLA]VARCOD , [ID]ID0=[F:VLA]EMP
#& , [VEP]VEP5=[F:VLA]BUL , [FGR]FGR0=SOCIETE;[F:VEP]FCY
#& As [LVLA]
#& Where evalue(CRITERE1) & evalue(CRITERE2)
#& Order By Key CLE=[F:VLA]EMP;[F:VEP]CTRNUM;[F:VLA]VARCOD
#Endif

Filter [F:CPY] Where CPY= SOCIETE
Read First
GCURLEG = [F:CPY]LEG
Filter [F:CPY]

If POPULATION<>""
 Link [VLA] With [VRA]VRA0=GCURLEG;[F:VLA]VARCOD , [ID]ID0=[F:VLA]EMP
& , [VEP]VEP5=[F:VLA]BUL , [FGR]FGR0=SOCIETE;[F:VEP]FCY , [HRPOA]POA0=POPULATION;[F:VLA]EMP
& As [LVLA]
& Where evalue(CRITERE1) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
& Order By Key CLE=[F:VLA]EMP;[F:VEP]CTRNUM;[F:VLA]VARCOD
Else
 Link [VLA] With [VRA]VRA0=GCURLEG;[F:VLA]VARCOD , [ID]ID0=[F:VLA]EMP
& , [VEP]VEP5=[F:VLA]BUL , [FGR]FGR0=SOCIETE;[F:VEP]FCY
& As [LVLA]
& Where evalue(CRITERE1) & evalue(CRITERE2)
& Order By Key CLE=[F:VLA]EMP;[F:VEP]CTRNUM;[F:VLA]VARCOD
Endif
#THRAM 27/03/2017 - end

#FQ69466 - MABON 30/11/2010
SVFONCTION = GFONCTION
Call GETPARAM("X3FCT",NBPAR,PARAMETRE,GFONCTION)
Call AUTORIS From EXEFNC

NBMOIS = 12*year(DATEFIN)+month(DATEFIN)-(12*year(DATEDEB)+month(DATEDEB))+1
Call DEBTRANS From GLOCK
Gosub TR1
Call TEMPOFF From GESECRAN
#FQ69466 - SEGAY 09/12/13
GFONCTION = SVFONCTION
Call AUTORIS From EXEFNC
End

$TR1
Local Integer LASTMONTH
GOK = 1
Trbegin [TMP]
 Delete [TMP] Where USR=GUSER & DAT<date$
 If fstat=1
  GOK = -1 : GLOCK = "TMPHISTO"-GUSER : Goto ROLL_TR1
 Endif
 K = 0
 For [LVLA]CLE(2)
  LASTMONTH=val(func AFNC.PARAM("DMA",[F:VEP]FCY))
  If LASTMONTH=0 : LASTMONTH=12 : Endif
  Read [ID]ID0=[F:VLA]EMP
  If !fstat
   Filter [HRCTR] Where REFNUM=[F:VLA]EMP & CTRNUM=[F:VEP]CTRNUM
   Read [HRCTR]CTR0 Last
   Filter [HRCTR]
   If !fstat
    Call CONTROLE([F:VLA]EMP,[F:VLA]DAT,[F:VEP]CTRNUM,"",OK,0) From DIVPAYE
   Else
    OK = 0
   Endif
  Else
   OK = 0
  Endif
  If OK
   For [LVLA]CLE(3)
    Raz MONT
    For [LVLA]CLE
     If LASTMONTH=12
      MOIS = 12*year([F:VEP]PYRDAT)+month([F:VEP]PYRDAT)-(12*year(DATEDEB)+month(DATEDEB))+1
     Else
      #overdue pay
      MOIS = 12*year([F:VEP]PYRDAT)+month(addmonth([F:VEP]PYRDAT,-1))-(12*year(DATEDEB)+month(DATEDEB))+2
     Endif
     If MOIS>dim(MONT)
      # La période ne doit pas dépasser N mois
      Call ERREUR(mess(40,10708,1)-num$(dim(MONT))-mess(41,10708,1)) From GESECRAN
      GOK = 0
      Break 3
     Endif
     If [F:VEP]RVS=2 & [F:VLA]VARVAL>0
      MONT(MOIS) += [F:VLA]VARVAL*-1
     Else
      MONT(MOIS) += [F:VLA]VARVAL
     Endif
    Next
    Raz [F:TMP]
    [F:TMP]USR    = GUSER
    [F:TMP]RQT    = [L]NUMREQ
    [F:TMP]EMP    = [F:ID]REFNUM
    [F:TMP]CTRNUM = [F:VEP]CTRNUM
    [F:TMP]RUB    = [F:VLA]VARCOD
    [F:TMP]DAT    = date$
    For GRP=1 To int((NBMOIS-1)/6)+1
     [F:TMP]GRP   = GRP
     If sum(MONT(1..6*GRP))<>0
      For I=1 To 6
       J = 6*(GRP-1)+I
       If J<=NBMOIS
        [F:TMP]AMT(I-1) = MONT(J)
       Endif
      Next I
      K += 1
      [F:TMP]MOI = addmonth(DATEDEB,6*(GRP-1))
      [F:TMP]LIG = K
      [F:TMP]TOT = sum(MONT(1..6*GRP))
      Write [TMP]
      If fstat
       GOK = 0 : Call FSTA("TMP") From GLOCK : Break 3
      Endif
     Endif
    Next GRP
   Next
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If !GROLL : Goto TR1 : Endif
Return

Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

