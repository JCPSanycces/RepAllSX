#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
# Traitement : SUBRBB5
# -----------------------------------------------------------------------------------
# Description: Releves belges - Validation releve bordereau
# -----------------------------------------------------------------------------------
######################################################################################
#**
#* @param IN_RBKNUM : statement
#* @param IN_RBKLIN : statement line
#* @param OUT_STAT  : status 1=Ok, <>1=Ko
#*!
Subprog  RBKVALFRM(IN_RBKNUM,IN_RBKLIN, OUT_STAT)
Value Char      IN_RBKNUM
Value Integer   IN_RBKLIN
Variable Integer OUT_STAT

Local Char    SAV_GFONCTION(GLONFCT), SYMBOLE(30)

OUT_STAT = 1

[L]SYMBOLE=""
[L]SAV_GFONCTION=""

#-- read line to be validated
Read [F:RBD]RBD0=IN_RBKNUM;IN_RBKLIN
If fstat
  Call RSTA("RBD",IN_RBKNUM-num$(IN_RBKLIN)) From GLOCK
  OUT_STAT=0
  Goto END_PROCESS
Endif

#-- Is there smthng to process ?
If [F:RBD]FRMNUM=""
  ## Le numéro de bordereau n'est pas renseigné sur la ligne à valider
  Call ECR_TRACE(mess(192,121,1)-IN_RBKNUM+"/"+num$(IN_RBKLIN),1) From GESECRAN
  OUT_STAT=0
  Goto END_PROCESS
Endif

#-- Is FRM still in the good status since creation ?
If !clalev([F:FRM]) : Local File PAYFRM  [FRM] : Endif
Read [F:FRM]FRM0=1;[F:RBD]FRMNUM
If fstat
  ## Bordereau non trouvé
  Call ECR_TRACE(mess(193,121,1)+" : "-[F:RBD]FRMNUM,1) From GESECRAN
  OUT_STAT=0
  Goto END_PROCESS
Endif
If [F:FRM]STA=9
  ## Bordereau # déjà validé
  Call ECR_TRACE(func AFNC.MES(mess(194,121,1),[F:RBD]FRMNUM),0) From GESECRAN
  Goto UPDATE_RBD
Endif
If [F:FRM]STA<>8
  ## La comptabilisation intermédiaire n'a pas été réalisée sur le bordereau
  Call ECR_TRACE(mess(188,121,1)+" : "-[F:RBD]FRMNUM,1) From GESECRAN
  OUT_STAT=0
  Goto END_PROCESS
Endif

#-- Are we allowed to process
[L]SAV_GFONCTION=GFONCTION
GFONCTION="REMBAN"
Call AUTORIS From EXEFNC
If GNBAUZ=0
  Call ECR_TRACE(GFONCTION-mess(74,100,1),1) From GESECRAN
  OUT_STAT = 0
  Goto END_PROCESS
Endif

#-- Is the statement locked ?
[L]SYMBOLE ="FRM"+[F:RBD]FRMNUM+"\1"
Lock =[L]SYMBOLE With lockwait=0
If fstat
  ## Bordereau de remise xxxx Modification en cours sur un autre poste
  Call ECR_TRACE(mess(126,117,1)-[F:RBD]FRMNUM+" : "+mess(10,100,1),1) From GESECRAN
  OUT_STAT = 0
Endif

#-- call validation s/b
If clalev([M:DIA]) : Close Local Mask [DIA] : Endif
Local Mask PAYREMBAN [DIA]
Raz [M:DIA]
[M:DIA]ACCSTA=9
[M:DIA]VALDAT=[F:RBD]VALDAT
[M:DIA]ACCDAT=[F:RBD]ACCDAT
[M:DIA]ALLCPY=2
[M:DIA]ALLFCY=2
[M:DIA]ALLTYP=2
[M:DIA]ALLUSR=2
[M:DIA]PRO=2
[M:DIA]TRC=2
[M:DIA]ALLLOT=2
[M:DIA]ALLBAN=2
[M:DIA]ALLFRMTYP=2
[M:DIA]PAY5=2

[M:DIA]PAY7=1
[M:DIA]PAY9=1

Call PAYCPT([F:RBD]FRMNUM) From PAYCPTA
If GOK < 1 : OUT_STAT=0 : Goto END_PROCESS : Endif

#-- update statement line
$UPDATE_RBD
Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1 : OUT_STAT=0 : Endif

#-- end process statement line
$END_PROCESS
If clalev([M:DIA]) : Close Local Mask [DIA] : Endif
If [L]SAV_GFONCTION <> ""
  GFONCTION=[L]SAV_GFONCTION
  Call AUTORIS From EXEFNC
Endif
If [L]SYMBOLE<>"" : Unlock =[L]SYMBOLE : Endif
End

######################################################################################
#-- update statement line
$TR1
Trbegin [RBD]
Readlock [F:RBD]RBD0=IN_RBKNUM;IN_RBKLIN
If fstat=1
  GOK=-1 : GROLL="$RBD"-IN_RBKNUM-num$(IN_RBKLIN) : Goto ROLL_TR1
Elsif fstat
  GOK=0 : Call RSTA("RBD",IN_RBKNUM-num$(IN_RBKLIN)) From GLOCK
  Goto AB_TR1
Endif
[F:RBD]STATUT= 3 :# Validate
[F:RBD]VALFLG= 1 :# not to validate
Rewrite [F:RBD]
If fstat
  GOK=0 :  Call FSTA("RBD") From GLOCK : Goto AB_TR1
Endif
Commit
Return

$AB_TR1
Rollback
Return
$ROLL_TR1
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else Goto TR1 : Endif
######################################################################################

