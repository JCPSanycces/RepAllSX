#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
Subprog IB_NBITM

  Raz GBOUT1
  Raz GBOUT2
  Raz GBOUT3
  If nolign > [M:CONH]NBITM Then
    End
  Endif
  If [M:CONH]COVTYP(nolign-1) = 1 Then
    #Produit physique
    GBOUT1 = mess(31,124,1) #Détail
  Elsif [M:CONH]COVTYP(nolign-1) = 2 Then
    #Code produit
    GBOUT2 = mess(31,124,1) #Détail
  Endif
  If ![M:CONH]DIRTYFLG Then
    If [M:CONH]CONMACCOD(nolign-1) <> "" Then
      If [M:CONH]CONMACNUM(nolign-1) <> "" Then
        GBOUT3 = mess(287,182,1)  #Couverture financière
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog IB_NBCPN

  Raz GBOUT1
  If ![M:CONH]DIRTYFLG Then
    If [M:CONH]CNNCPN(nolign-1) <> "" Then
      GBOUT1 = mess(287,182,1)  #Couverture financière
    Endif
  Endif
End

##########################################################################################################
Subprog AS_NBITM

  Call GESNBITM(nolign-1) From TRTCONH
End

##########################################################################################################
Subprog C_NBITM
Local Integer NUMLIGNE

  NUMLIGNE = 0
  If status = 65 Then
    #Effacement d'une seule ligne
    Call DEBTRANS From GLOCK
    Trbegin [CCV]
    If [M:CONH]TPL = 2 Then
      Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]RECNUM = [M:CONH]CONMACNUM(nolign-1) and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
    Else
      Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]RECNUM = [M:CONH]CONMACNUM(nolign-1) and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
    Endif
    If fstat Then
      #Erreur suppression
      GMESSAGE = mess(815,196,1)
      GERR = 1
      Rollback
      Affzo [M:CONH]1-99
      End
    Endif
    If [M:CONH]TPL = 2 Then
      Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM(nolign-1)
    Else
      Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM(nolign-1)
    Endif
    If fstat Then
      #Erreur suppression
      GMESSAGE = mess(815,196,1)
      GERR = 1
      Rollback
      Affzo [M:CONH]1-99
      End
    Endif
    If [M:CONH]TPL = 2 Then
      Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "AAA" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM(nolign-1)
    Else
      Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "AAA" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM(nolign-1)
    Endif
    If fstat Then
      #Erreur suppression
      GMESSAGE = mess(815,196,1)
      GERR = 1
      Rollback
      Affzo [M:CONH]1-99
      End
    Endif
    Commit
    Raz [M:CONH]NBCPN
    Raz [M:CONH]MORCOVCPN
    Raz [M:CONH]CNNICDFLG
    Raz [M:CONH]CNNCPN
    Raz [M:CONH]CNNCPNDES
    Raz [M:CONH]ITMICDFLG
    Raz [M:CONH]CNNIHEIPRC
    Raz [M:CONH]CNNIMINCOV
    Raz [M:CONH]CNNIMAXCOV
    Raz [M:CONH]LABICDFLG
    Raz [M:CONH]CNNLHEIPRC
    Raz [M:CONH]CNNLMINCOV
    Raz [M:CONH]CNNLMAXCOV
    Raz [M:CONH]EXSICDFLG
    Raz [M:CONH]CNNEHEIPRC
    Raz [M:CONH]CNNEMINCOV
    Raz [M:CONH]CNNEMAXCOV
  Elsif status = 68 or status = 83 Then
    #Effacement d'un groupe de lignes
    For NUMLIGNE = nolign-1 To nolign1 - 1
      Call DEBTRANS From GLOCK
      Trbegin [CCV]
      If [M:CONH]TPL = 2 Then
        Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]RECNUM = [M:CONH]CONMACNUM(NUMLIGNE) and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
      Else
        Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]RECNUM = [M:CONH]CONMACNUM(NUMLIGNE) and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL
      Endif
      If fstat Then
        #Erreur suppression
        GMESSAGE = mess(815,196,1)
        GERR = 1
        Rollback
        Affzo [M:CONH]1-99
        Break
      Endif
      If [M:CONH]TPL = 2 Then
        Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM(NUMLIGNE)
      Else
        Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM(NUMLIGNE)
      Endif
      If fstat Then
        #Erreur suppression
        GMESSAGE = mess(815,196,1)
        GERR = 1
        Rollback
        Affzo [M:CONH]1-99
        Break
      Endif
      If [M:CONH]TPL = 2 Then
        Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "AAA" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM(NUMLIGNE)
      Else
        Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "AAA" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM(NUMLIGNE)
      Endif
      If fstat Then
        #Erreur suppression
        GMESSAGE = mess(815,196,1)
        GERR = 1
        Rollback
        Affzo [M:CONH]1-99
        Break
      Endif
      Commit
    Next
    Raz [M:CONH]NBCPN
    Raz [M:CONH]MORCOVCPN
    Raz [M:CONH]CNNICDFLG
    Raz [M:CONH]CNNCPN
    Raz [M:CONH]CNNCPNDES
    Raz [M:CONH]ITMICDFLG
    Raz [M:CONH]CNNIHEIPRC
    Raz [M:CONH]CNNIMINCOV
    Raz [M:CONH]CNNIMAXCOV
    Raz [M:CONH]LABICDFLG
    Raz [M:CONH]CNNLHEIPRC
    Raz [M:CONH]CNNLMINCOV
    Raz [M:CONH]CNNLMAXCOV
    Raz [M:CONH]EXSICDFLG
    Raz [M:CONH]CNNEHEIPRC
    Raz [M:CONH]CNNEMINCOV
    Raz [M:CONH]CNNEMAXCOV
    If GERR Then
      End
    Endif
  Elsif status = 73 Then
    #Insertion d'une ligne
    GINSERT = 1
  Endif
  Call GESNBITM(nolign-1) From TRTCONH
End

##########################################################################################################
Subprog IB_CONMACCOD

  Raz GBOUT1
  Raz GBOUT2
  Raz GBOUT3
  Raz GBOUT4
  If [M:CONH]COVTYP(nolign-1) = 1 Then
    #Produit physique
    Call TEXTE(6109, GBOUT1) From OBJDIV      #Sélection
    GBOUT2 = mess(272,196,1) #Parc client
  Elsif [M:CONH]COVTYP(nolign-1) = 2 Then
    #Code produit
    Call TEXTE(6109, GBOUT1) From OBJDIV      #Sélection
    GBOUT3 = mess(22,198,1) #Articles
  Elsif [M:CONH]COVTYP(nolign-1) = 3 Then
    #Famille commerciale de produit
    Call TEXTE(6109, GBOUT4) From OBJDIV      #Sélection
  Endif
End

##########################################################################################################
Subprog C_CONMACCOD(VALEUR)
Variable Char    VALEUR()

Local Integer I
Local Integer IADINUM

  IADINUM = 19 + GFAMCIA
  If VALEUR = "" Then
    mkstat = 2
    End
  Endif
  #Vérifie si un code identique n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:CONH]CONMACCOD)-1
    If I <> nolign-1 Then
      If [M:CONH]CONMACCOD(I) = VALEUR and [M:CONH]CONMACCOD(I) <> "" and [M:CONH]COVTYP(I) = [M:CONH]COVTYP(nolign-1) Then
        VALEUR = ""
        mkstat = 2
        If [M:CONH]COVTYP(nolign-1) = 1 Then
          #Machine physique
          GMESSAGE = mess(435,196,1) #Cet identifiant de parc a déjà été saisi.
        Elsif [M:CONH]COVTYP(nolign-1) = 2 Then
          #Code produit
          GMESSAGE = mess(434,196,1) #Cet article a déjà été saisi.
        Elsif [M:CONH]COVTYP(nolign-1) = 3 Then
          #Famille commerciale
          GMESSAGE = mess(144,182,1) #Cette famille commerciale a déjà été saisie.
        Endif
        GERR = 2
        #End   # FGR 02/02/2010 : X3SUIVI60986
        Break  # FGR 02/02/2010 : X3SUIVI60986
      Endif
    Endif
  Next
  If GERR Then
    # FGR 02/02/2010 : X3SUIVI60986
    End
  Endif
  #Renseigne le numéro de série de la machine sélectionnée.
  If [M:CONH]COVTYP(nolign-1) = 1 Then
    #Machine physique
    Read [MAC]MAC0=VALEUR
    If fstat Then
      If VALEUR <> "" Then
        GMESSAGE = mess(419,196,1) #Le code saisi ne correspond pas à un élément de parc client. Saisie refusée.
        GERR = 2
        mkstat = 2
      Else
        mkstat = 2
      Endif
      End
    Else
      [M:CONH]MACDES(nolign-1) = [F:MAC]MACDES
      [M:CONH]MACITMREF(nolign-1) = [F:MAC]MACPDTCOD
      If [M:CONH]TPL <> 2 Then
        [M:CONH]SERNUM(nolign-1) = [F:MAC]MACSERNUM
      Endif
    Endif
  Elsif [M:CONH]COVTYP(nolign-1) = 2 Then
    #Code produit
    Read [ITM]ITM0=VALEUR
    If fstat Then
      If VALEUR <> "" Then
        GMESSAGE = mess(420,196,1) #Le code saisi ne correspond pas à un article. Saisie refusée.
        GERR = 2
        mkstat = 2
      Else
        mkstat = 2
      Endif
      End
    Else
      #Call LECTEXTRA([M:CONH]MACDES(nolign-1), "ITMMASTER", "DES1AXX", VALEUR, "") From ATEXTRA
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CONH]MACDES(nolign-1), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
      [M:CONH]MACITMREF(nolign-1) = [F:ITM]ITMREF
    Endif
    If [M:CONH]TPL <> 2 Then
      [M:CONH]SERNUM(nolign-1) = ""
    Endif
  Elsif [M:CONH]COVTYP(nolign-1) = 3 Then
    #Famille commerciale
    Read [ADI]CODE=IADINUM;VALEUR
    If fstat Then
      If VALEUR <> "" Then
        #Le code saisi ne correspond pas à une famille commerciale de produit. Saisie refusée.
        GMESSAGE = mess(145,182,1) 
        GERR = 2
        mkstat = 2
      Else
        mkstat = 2
      Endif
      End
    Else
      Call GET_LIB(IADINUM, VALEUR, [M:CONH]MACDES(nolign-1)) From CRM_UTIL
    Endif
    If [M:CONH]TPL <> 2 Then
      [M:CONH]SERNUM(nolign-1) = ""
    Endif
    [M:CONH]MACITMREF(nolign-1) = ""
  Endif
  If [M:CONH]CONMACNUM(nolign-1) = "" Then
    If GINSERT Then
      [M:CONH]CONMACNUM(nolign-1) = num$([M:CONH]NBITM-1)
      GINSERT = 0
    Else
      [M:CONH]CONMACNUM(nolign-1) = num$([M:CONH]NBITM)
    Endif
  Endif
  Affzo [M:CONH]MACDES(nolign-1)
  If [M:CONH]TPL <> 2 Then
    Affzo [M:CONH]SERNUM(nolign-1)
  Endif
End

##########################################################################################################
Subprog C_CNNCPN(VALEUR)
Variable Char    VALEUR()

Local Integer I

  If VALEUR = "" Then
    mkstat = 2
    End
  Endif
  #Vérifie si ce composant n'a pas déjà été préalablement saisie dans ce tableau
  For I = 0 To dim ([M:CONH]CNNCPN)-1
    If I <> nolign-1 Then
      If [M:CONH]CNNCPN(I) = VALEUR and [M:CONH]CNNCPN(I) <> "" Then
        VALEUR = ""
        mkstat = 2
        #Ce composant a déjà été saisi en ligne n°
        GMESSAGE = mess(268,182,1) - num$(I+1)
        GERR = 2
        Break
      Endif
    Endif
  Next
End

##########################################################################################################
Subprog AM_CNNCPN(VALEUR)
Variable Char    VALEUR()

  Read [ITM]ITM0=VALEUR
  If fstat Then
   [M:CONH]CNNCPNDES(nolign-1) = ""
  Else
    #Call LECTEXTRA([M:CONH]CNNCPNDES(nolign-1), "ITMMASTER", "DES1AXX", VALEUR, "") From ATEXTRA
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CONH]CNNCPNDES(nolign-1), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
  Endif
  Affzo [M:CONH]CNNCPNDES(nolign-1)
End

##########################################################################################################
Subprog C_NBCPN
Local Integer NUMLIGNE

  If status = 65 Then
    #Effacement d'une seule ligne
    Call DEBTRANS From GLOCK
    Trbegin [CCV]
    If [M:CONH]TPL = 2 Then
      Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]RECNUM = [M:CONH]CNNCPN(nolign-1) and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM([M:CONH]PRECONHNOL)
    Else
      Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]RECNUM = [M:CONH]CNNCPN(nolign-1) and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM([M:CONH]PRECONHNOL)
    Endif
    If fstat Then
      #Erreur suppression
      GMESSAGE = mess(815,196,1)
      GERR = 1
      Rollback
      Affzo [M:CONH]1-99
      End
    Endif
    If [M:CONH]TPL = 2 Then
      Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "AAA" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM([M:CONH]PRECONHNOL) and [F:CCV]PAEKEY(2) = [M:CONH]CNNCPN(nolign-1)
    Else
      Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "AAA" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM([M:CONH]PRECONHNOL) and [F:CCV]PAEKEY(2) = [M:CONH]CNNCPN(nolign-1)
    Endif
    If fstat Then
      #Erreur suppression
      GMESSAGE = mess(815,196,1)
      GERR = 1
      Rollback
      Affzo [M:CONH]1-99
      End
    Endif
    Commit
  Elsif status = 68 or status = 83 Then
    #Effacement d'un groupe de lignes
    For NUMLIGNE = nolign-1 To nolign1-1
      Call DEBTRANS From GLOCK
      Trbegin [CCV]
      If [M:CONH]TPL = 2 Then
        Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]RECNUM = [M:CONH]CNNCPN(NUMLIGNE) and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM([M:CONH]PRECONHNOL)
      Else
        Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "CPN" and [F:CCV]RECNUM = [M:CONH]CNNCPN(NUMLIGNE) and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM([M:CONH]PRECONHNOL)
      Endif
      If fstat Then
        #Erreur suppression
        GMESSAGE = mess(815,196,1)
        GERR = 1
        Rollback
        Affzo [M:CONH]1-99
        #End   # FGR 02/02/2010 : X3SUIVI60986
        Break  # FGR 02/02/2010 : X3SUIVI60986
      Endif
      If [M:CONH]TPL = 2 Then
        Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "AAA" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM([M:CONH]PRECONHNOL) and [F:CCV]PAEKEY(2) = [M:CONH]CNNCPN(NUMLIGNE)
      Else
        Delete [CCV] Where [F:CCV]CONNUM = [M:CONH]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "AAA" and [F:CCV]PAEKEY(0) = [M:CONH]CONPBL and [F:CCV]PAEKEY(1) = [M:CONH]CONMACNUM([M:CONH]PRECONHNOL) and [F:CCV]PAEKEY(2) = [M:CONH]CNNCPN(NUMLIGNE)
      Endif
      If fstat Then
        #Erreur suppression
        GMESSAGE = mess(815,196,1)
        GERR = 1
        Rollback
        Affzo [M:CONH]1-99
        #End   # FGR 02/02/2010 : X3SUIVI60986
        Break  # FGR 02/02/2010 : X3SUIVI60986
      Endif
      Commit
    Next
    If GERR Then
      # FGR 02/02/2010 : X3SUIVI60986
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AM_ICDFLGX(VALEUR)
Variable Integer VALEUR

  [M:CONH]CPNICDFLG([M:CONH]PRECONHNOL) = VALEUR
End

##########################################################################################################
Subprog AS_COVTYP(VALEUR)
Variable Integer VALEUR

  If [M:CONH]TPL = 2 Then
    GMENLOC(1) = 1
  Endif
End

##########################################################################################################
Subprog IB_CNNCPN

  Raz GBOUT3
  If [M:CONH]MACITMREF([M:CONH]PRECONHNOL) <> "" Then
    GBOUT3 = mess(275,182,1)    #Nomenclature après-vente
  Endif
End

##########################################################################################################
Subprog AS_CNNICDFLG(VALEUR)
Variable Integer VALEUR

  Case [M:CONH]ICDFLGX
    When 0
      [M:CONH]CNNICDFLG(nolign-1) = 2
    When 1
      [M:CONH]CNNICDFLG(nolign-1) = 2
    When 2
      [M:CONH]CNNICDFLG(nolign-1) = 1
  Endcase
  Affzo [M:CONH]CNNICDFLG(nolign-1)
End
