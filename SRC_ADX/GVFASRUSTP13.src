 [F:EVT0]IVCVATAMT  = 0
 [F:EVT0]DEDVATAMT  = 0
 [F:EVT0]RATCUR     = [F:DEP]RATCUR
 If G_ACTKRU=G_OUI
  [F:EVT0]KBONUS     = [F:FAS]KBONUS
 Endif
 #--> Zones alphanumériques
 [F:EVT0]ACCCOD     = [F:FAS]ACCCOD
 [F:EVT0]CUR        = Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)
 [F:EVT0]USRFLDA1   = [F:FAS]USRFLDA1
 [F:EVT0]USRFLDA2   = [F:FAS]USRFLDA2
 [F:EVT0]USRFLDA3   = [F:FAS]USRFLDA3
