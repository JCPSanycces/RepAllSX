 [F:EVT0]DIE15      = [F:FAS]DIE(14)
 [F:EVT0]CCE15      = [F:FAS]CCE(14)
 [F:EVT0]DIE16      = [F:FAS]DIE(15)
 [F:EVT0]CCE16      = [F:FAS]CCE(15)
 [F:EVT0]DIE17      = [F:FAS]DIE(16)
 [F:EVT0]CCE17      = [F:FAS]CCE(16)
 [F:EVT0]DIE18      = [F:FAS]DIE(17)
 [F:EVT0]CCE18      = [F:FAS]CCE(17)
