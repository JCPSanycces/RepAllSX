 #--> Dates
 [F:EVT0]USRFLDD1   = [F:FAS]USRFLDD1
 [F:EVT0]USRFLDD2   = [F:FAS]USRFLDD2
 [F:EVT0]USRFLDD3   = [F:FAS]USRFLDD3
