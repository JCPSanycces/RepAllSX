#<AdxTL>@(#)0.0.0.0 $Revision$
# MODIFIE PAR : CBO
# LE          : 22 Décembre  2017 14:30:17

$OUVRE_TABLE
 If dim(APPLI)<0 : Local Char APPLI(30) : APPLI=nomap : Endif
 If !clalev([F:EVT0]) : Local File =APPLI+".EFASRUSTP" [EVT0] : Endif
 If !clalev([F:EVT1]) : Local File =APPLI+".EFASRUSTP" [EVT1] : Endif
Return

$CONDITION_EVE
 LCNDREQEVT="CPY=PCPY & REF=PREF & DPRPLN=LPLN & EVTINT=CODEVTINT & SNSEVE=PSNSEVE"
Return

$RAZ_F_EVT0_1
 Raz [F:EVT0]
 Raz [F:EVT1]
Return

$AIGUILLAGE
 Gosub OUVRE_TABLE
 Gosub RAZ_F_EVT0_1
 Gosub FASRUSTP13
 [F:EVT0]CPY       = PCPY
 [F:EVT0]FCY       = PFCY
 [F:EVT0]REF       = PREF
 [F:EVT0]CURPERSTR = LCURPERSTR
 [F:EVT0]CREUSR    = GUSER
 [F:EVT0]CREDAT    = date$
 [F:EVT0]CRETIM    = time
 [F:EVT0]UPDUSR    = ""
 [F:EVT0]UPDDAT    = [0/0/0]
 [F:EVT0]DPRPLN    = LPLN
 [F:EVT0]EVTINT    = CODEVTINT
 [F:EVT0]EVTDAT    = PDAT
 [F:EVT0]CPTFLG    = 1
 [F:EVT0]SNSEVE    = 1
 [F:EVT0]CREUSRO   = ""
 [F:EVT0]TIMSTPO   = ""
 If PACCDAT<>[0/0/0]
  [F:EVT0]CPTDATINT = PACCDAT
 Else
  [F:EVT0]CPTDATINT = PDAT
 Endif
 Gosub CALCUL_TIMSTP
 Gosub ALIM_CUR
Return
 
$CALCUL_TIMSTP
 [F:EVT0]TIMSTP = func GENEVE.BUILD_TIMSTP([F:EVT0]CREDAT, [F:EVT0]CRETIM)
Return

$ALIM_CUR
 [F:EVT0]CUR=Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)
Return

$ANNULE_EVE
 [F:EVT0]SNSEVE = 2
 [F:EVT0]CREUSRO = [F:EVT0]CREUSR
 [F:EVT0]TIMSTPO = [F:EVT0]TIMSTP
 [F:EVT0]CPTDATINTO = [F:EVT0]CPTDATINT
 [F:EVT0]CREUSR = GUSER
 [F:EVT0]CREDAT = date$
 [F:EVT0]CRETIM = time
 [F:EVT0]UPDUSR = ""
 [F:EVT0]UPDDAT = [0/0/0]
 [F:EVT0]CPTFLG = 1
 [F:EVT0]EVTDAT = PDAT
 Gosub CALCUL_TIMSTP
Return

$FASRUSTP13
 #--> Désignation
 [F:EVT0]DES        = [F:FAS]AASDES1
 #--> Menus locaux
 [F:EVT0]OWNTYP     = [F:FAS]OWNTYP
 [F:EVT0]ETRNAT     = [F:FAS]ETRNAT
 [F:EVT0]KSTPDEPSTA = [F:DEP]KSTPDEPSTA
 #--> Zones numériques
 [F:EVT0]USRFLDM1   = [F:FAS]USRFLDM1
 [F:EVT0]USRFLDM2   = [F:FAS]USRFLDM2
 [F:EVT0]USRFLDM3   = [F:FAS]USRFLDM3
 [F:EVT0]USRFLDM4   = [F:FAS]USRFLDM4
 [F:EVT0]USRFLDM5   = [F:FAS]USRFLDM5
 [F:EVT0]USRFLDM6   = [F:FAS]USRFLDM6
 [F:EVT0]USRFLDC1   = [F:FAS]USRFLDC1
 [F:EVT0]USRFLDC2   = [F:FAS]USRFLDC2
