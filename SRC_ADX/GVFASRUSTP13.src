 [F:EVT0]PURDAT     = [F:FAS]PURDAT
 [F:EVT0]ITSDAT     = [F:FAS]ITSDAT
 [F:EVT0]AASIPTDAT  = [F:FAS]AASIPTDAT
Return

$ECLATE_NBFLD
 LNBFLD=-6
Return

$ECLATE_STATUS
Return

$INFO_EVTINT
 EVT = "FASRUSTP"
 LPLN= 13
Return

