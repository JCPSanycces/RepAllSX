 [F:EVT0]USRFLDA5   = [F:FAS]USRFLDA5
 [F:EVT0]USRFLDA6   = [F:FAS]USRFLDA6
 [F:EVT0]USRFLDA7   = [F:FAS]USRFLDA7
 [F:EVT0]USRFLDA8   = [F:FAS]USRFLDA8
 [F:EVT0]USRFLDA9   = [F:FAS]USRFLDA9
 [F:EVT0]USRFLDA10  = [F:FAS]USRFLDA10
 [F:EVT0]ACGGRP     = [F:FAS]ACGGRP
 [F:EVT0]AASBUS     = [F:FAS]AASBUS
 [F:EVT0]DSP        = [F:FAS]DSP
 [F:EVT0]DIE1       = [F:FAS]DIE(0)
 [F:EVT0]CCE1       = [F:FAS]CCE(0)
 [F:EVT0]DIE2       = [F:FAS]DIE(1)
 [F:EVT0]CCE2       = [F:FAS]CCE(1)
 [F:EVT0]DIE3       = [F:FAS]DIE(2)
 [F:EVT0]CCE3       = [F:FAS]CCE(2)
 [F:EVT0]DIE4       = [F:FAS]DIE(3)
 [F:EVT0]CCE4       = [F:FAS]CCE(3)
 [F:EVT0]DIE5       = [F:FAS]DIE(4)
 [F:EVT0]CCE5       = [F:FAS]CCE(4)
 [F:EVT0]DIE6       = [F:FAS]DIE(5)
 [F:EVT0]CCE6       = [F:FAS]CCE(5)
 [F:EVT0]DIE7       = [F:FAS]DIE(6)
 [F:EVT0]CCE7       = [F:FAS]CCE(6)
 [F:EVT0]DIE8       = [F:FAS]DIE(7)
 [F:EVT0]CCE8       = [F:FAS]CCE(7)
 [F:EVT0]DIE9       = [F:FAS]DIE(8)
 [F:EVT0]CCE9       = [F:FAS]CCE(8)
 If G_ACTIAS=G_OUI
  [F:EVT0]IASCGU     = [F:FAS]IASCGU
 Endif
 [F:EVT0]GAC        = [F:FAS]GAC
 If G_ACTLEA=G_OUI
  [F:EVT0]ACCCODLEA  = string$(max(0,dim(GACCCODLEA)),[F:LEA]ACCCOD)
 Endif
 [F:EVT0]DIE10      = [F:FAS]DIE(9)
 [F:EVT0]CCE10      = [F:FAS]CCE(9)
