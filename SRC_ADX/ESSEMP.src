#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "OK"          : Gosub OK
Endcase

Return

$OUVRE
Local Char GLOBEML(GLONEML)
#Disabling the classic CUD operation - Hybrid development (ANOWRITE)
Local Integer ANOWRITE
ANOWRITE = 1

#Opening tables and declaring an instance of the main class
If clalev([F:ID2])      = 0 : Local File EMPLOID      [ID2]      : Endif
If clalev([F:HRCTR])    = 0 : Local File EMPLOCTR     [HRCTR]   : Endif
If clalev([F:BBB])      = 0 : Local File BBLOB        [BBB]     : Endif

#Instantiate global basic classes
#Get the legislation and instiate only applicable classes
GLOBEML=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
GCURLEG = func DIVPAYE_SOA.GET_LEG_EMP(GLOBEML, 1) #Site level

#Manage Localisations
Call MANAGE_LOCALISATION("ESSEMP") From DIVPAYE

#-------------------------------Hybrid----------------------------------#
If GLOBEML <> AVOID.ACHAR and GCURLEG <> AVOID.ACHAR
  #Instantiate EMPLOID - All Employees
  Gosub INSTANCE_ESSEMP
  Gosub LOAD_ESSEMP

  #KZA - EMPLOIDSA
  If func DIVPAYE.IS_KZA(GCURLEG)>0
    Gosub INSTANCE_ESSEMPKZA
    Gosub LOAD_ESSEMPKZA
  Endif

  #KUK - EMPLOIDUKI
  If func DIVPAYE.IS_KUK_LEG(GCURLEG)>0
    Gosub INSTANCE_ESSEMPUKI
    Gosub LOAD_ESSEMPUKI
  Endif
Endif
#-------------------------------Hybrid----------------------------------#
Return

$INSTANCE_ESSEMP
Global Instance I_ESSEMP Using C_ESSEMP
Return

$INSTANCE_ESSEMPKZA
If clalev([F:ESA2]) = 0 :   Local File EMPLOIDSA  [ESA2]      : Endif
Global Instance I_ESSEMPKZA Using C_ESSEMPKZA
Return

$INSTANCE_ESSEMPUKI
If clalev([F:IDUKI2]) = 0 :   Local File EMPLOIDUKI  [IDUKI2]      : Endif
Global Instance I_ESSEMPUKI Using C_ESSEMPUKI
Return


$DEBUT
Local Integer MNOLIB
[M:ESEMP]WLEG = GCURLEG
#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSEMPHIDE
Call SHOW_LEGACTCALLS From WESSEMPSHOW

#-------------------------------Hybrid----------------------------------#
#Read the data from the class and transfer to the mask (Default Values)

#Transfer data to the class
#EMPLOID - All employee global data
Gosub UPDATE_ESSEMP

#EMPLOIDSA - KZA - RSA Employee information
If func DIVPAYE.IS_KZA(GCURLEG)>0
  Gosub UPDATE_ESSEMPKZA
Endif

#EMPLOIDSA - KZA - RSA Employee information
If func DIVPAYE.IS_KUK_LEG(GCURLEG)>0
  Gosub UPDATE_ESSEMPUKI
Endif

#-------------------------------Hybrid----------------------------------#

#Update picture
Read [BBB]BBB0 = "EMPPIC";[M:ESEMP]REFNUM;"";""
If !fstat
   [M:ESEMP]EMPPIC = [F:BBB]BLOB
Endif

#Set CIV
MNOLIB = func SET_CIV(I_ESSEMP.REFNUM)
If MNOLIB>0
  [M:ESEMP]NOLIB  = MNOLIB
  [M:ESEMP]VALINT = num$([M:ESEMP]CIV)
  [M:ESEMP]CIVA   = mess([M:ESEMP]CIV,[M:ESEMP]NOLIB,1)
Endif

Gosub HIDE_SHOW_ADDHOC
Affzo [M:ESEMP]1-99


Return



$OK

Local Integer WRKFLOW_STAT_EMP
Local Integer WRKFLOW_STAT_EMPKZA
Local Integer WRKFLOW_STAT_EMPUK
Local Integer WORKFLOWTRIGGER
Local Integer PHOTOUPLOAD
Local Char ERRMESSAGE(250)

[L]WRKFLOW_STAT_EMP     = [V]CST_ANOTDEFINED
[L]WRKFLOW_STAT_EMPKZA  = [V]CST_ANOTDEFINED
[L]WRKFLOW_STAT_EMPUK   = [V]CST_ANOTDEFINED


#---------------------------Update picture--------------------------------------#
Trbegin [BBB]
Read [BBB]BBB0 = "EMPPIC";[M:ESEMP]REFNUM;"";"";""
If !fstat
  [F:BBB]BLOB = [M:ESEMP]EMPPIC
  Rewrite [F:BBB]
Else
 Raz [BBB]
 [F:BBB]BLOB    = [M:ESEMP]EMPPIC
 [F:BBB]CODBLB  = "EMPPIC"
 [F:BBB]IDENT1 = [M:ESEMP]REFNUM
 [F:BBB]IDENT2 = ""
 [F:BBB]IDENT3 = ""
 [F:BBB]IDENT4 = ""
 Write [F:BBB]
 PHOTOUPLOAD = 1
Endif

If !fstat
  Commit
Else
  Rollback
Endif
#---------------------------Update picture--------------------------------------#




#---------------------------Trigger workflow------------------------------------#
#EMPLOID-ESSEMP
[L]WRKFLOW_STAT_EMP = fmet I_ESSEMP.EMP_WRKREQ(I_ESSEMP.REFNUM,"EMPLOID","ESSEMP","T","EMPLOID","ID",ERRMESSAGE)
If [L]WRKFLOW_STAT_EMP <> [V]CST_AOK and [L]WRKFLOW_STAT_EMP <> [V]CST_ANOTDEFINED
  Call RECOVERS_ERROR_IN_CLASSIC(I_ESSEMP) From ESS_WRKFLOW_FUNC_HYBRID
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If ERRMESSAGE <> AVOID.ACHAR
    GMESSAGE = ERRMESSAGE
  Endif
  If [L]WRKFLOW_STAT_EMP <> [V]CST_AWARNING and [L]WRKFLOW_STAT_EMP <> [V]CST_AINFO Then
    GERR=1
    OK = 0
    Return
  Endif
Endif




##EMPLOIDSA-ESSEMPKZA
If func DIVPAYE.IS_KZA(GCURLEG)>0
  [L]WRKFLOW_STAT_EMPKZA = fmet I_ESSEMPKZA.EMP_WRKREQ(I_ESSEMP.REFNUM,"EMPLOIDSA","ESSEMPKZA","T","EMPLOIDSA","ESA",ERRMESSAGE)

  If [L]WRKFLOW_STAT_EMPKZA <> [V]CST_AOK and [L]WRKFLOW_STAT_EMPKZA <> [V]CST_ANOTDEFINED
    Call RECOVERS_ERROR_IN_CLASSIC(I_ESSEMPKZA) From ESS_WRKFLOW_FUNC_HYBRID
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(0009,10727,1)
    Endif
    If ERRMESSAGE <> AVOID.ACHAR
      GMESSAGE = ERRMESSAGE
    Endif
    If [L]WRKFLOW_STAT_EMPKZA <> [V]CST_AWARNING and [L]WRKFLOW_STAT_EMPKZA <> [V]CST_AINFO Then
      GERR=1
      OK = 0
      Return
    Endif
  Endif
Endif



##EMPLOIDUKI-ESSEMPUKI
If func DIVPAYE.IS_KUK_LEG(GCURLEG)>0
  [L]WRKFLOW_STAT_EMPUK = fmet I_ESSEMPUKI.EMP_WRKREQ(I_ESSEMP.REFNUM,"EMPLOIDUKI","ESSEMPUKI","T","EMPLOIDUKI","IDUKI",ERRMESSAGE)
  If [L]WRKFLOW_STAT_EMPUK <> [V]CST_AOK and [L]WRKFLOW_STAT_EMPUK <> [V]CST_ANOTDEFINED
    Call RECOVERS_ERROR_IN_CLASSIC(I_ESSEMPUKI) From ESS_WRKFLOW_FUNC_HYBRID
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(0009,10727,1)
    Endif
    If ERRMESSAGE <> AVOID.ACHAR
      GMESSAGE = ERRMESSAGE
    Endif
    If [L]WRKFLOW_STAT_EMPUK <> [V]CST_AWARNING and [L]WRKFLOW_STAT_EMPUK <> [V]CST_AINFO Then
      GERR=1
      OK = 0
      Return
    Endif
 Endif
Endif


If [L]WRKFLOW_STAT_EMPKZA = [V]CST_ANOTDEFINED and [L]WRKFLOW_STAT_EMPUK = [V]CST_ANOTDEFINED and [L]WRKFLOW_STAT_EMP = [V]CST_ANOTDEFINED
  If PHOTOUPLOAD = 0
    Return
  Else
    GMESSAGE = mess(0016,10727,1)
    GERR = 2
    Return
  Endif
Endif


If GMESSAGE = AVOID.ACHAR Then
  GMESSAGE= mess(11,10727,1)
Else
  GMESSAGE= mess(11,10727,1)+":"-GMESSAGE
Endif
GERR = 2

Return

$LOAD_ESSEMP
Local Integer MY_STATUS
If I_ESSEMP <> null Then
  FreeGroup I_ESSEMP
Endif

I_ESSEMP = NewInstance C_ESSEMP AllocGroup null
[L]MY_STATUS = fmet I_ESSEMP.AREAD(GLOBEML)
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_ESSEMP) From ESS_WRKFLOW_FUNC_HYBRID
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    OK = 0
    Return
  Endif
Endif

Return


$LOAD_ESSEMPKZA
Local Integer MY_STATUS
If I_ESSEMPKZA <> null Then
  FreeGroup I_ESSEMPKZA
Endif

I_ESSEMPKZA = NewInstance C_ESSEMPKZA AllocGroup null
[L]MY_STATUS = fmet I_ESSEMPKZA.AREAD(GLOBEML)
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_ESSEMPKZA) From ESS_WRKFLOW_FUNC_HYBRID
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    OK = 0
    Return
  Endif
Endif

Return

$LOAD_ESSEMPUKI
Local Integer MY_STATUS
If I_ESSEMPUKI <> null Then
  FreeGroup I_ESSEMPUKI
Endif

I_ESSEMPUKI = NewInstance C_ESSEMPUKI AllocGroup null
[L]MY_STATUS = fmet I_ESSEMPUKI.AREAD(GLOBEML)
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_ESSEMPUKI) From ESS_WRKFLOW_FUNC_HYBRID
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    OK = 0
    Return
  Endif
Endif

Return

$UPDATE_ESSEMP
#Load the data from the class to the screen
SetInstance [M:ESEMP] With I_ESSEMP
Affzo [M:ESEMP]1-99
Return

$UPDATE_ESSEMPKZA
#Load the data from the class to the screen
SetInstance [M:ESEMP] With I_ESSEMPKZA
Affzo [M:ESEMP]1-99
Return

$UPDATE_ESSEMPUKI
#Load the data from the class to the screen
SetInstance [M:ESEMP] With I_ESSEMPUKI
Affzo [M:ESEMP]1-99
Return


$HIDE_SHOW_ADDHOC
If func DIVPAYE.IS_KUK_LEG(GCURLEG)>0
  If dim([M:ESEMP]CRYBRN)>0       : Chgfmt [M:ESEMP]CRYBRN      With "-K:3" : Raz[M:ESEMP]CRYBRN  : Endif
  If dim([M:ESEMP]EML)>0          : Diszo [M:ESEMP]EML     : Endif
Endif

Return

Funprog SET_CIV(VREFNUM)
Value Char VREFNUM
Local Char NUMLIB(10)
Local Char PFCY(GLONFCY)
Local Integer INTNUMLIB

If clalev([F:ID8]) = 0 : Local File EMPLOID [ID8]      : Endif
Read [F:ID8]ID0 = VREFNUM
If !fstat
  PFCY = [F:ID8]FCY
  Call PARAM(PFCY,"CIVIL",NUMLIB) From ADOVAL
Endif

INTNUMLIB = val(NUMLIB)
End INTNUMLIB

Subprog AM_CIVA(VALEUR)
Variable Char    VALEUR()
[M:ESEMP]CIV=val([M]VALINT)
#------------------------Hybrid-------------------------#

I_ESSEMP.CIV = [M:ESEMP]CIV
Call RECOVERS_ERROR_IN_CLASSIC(I_ESSEMP) From ESS_WRKFLOW_FUNC_HYBRID
If GERR = 1 Then
  I_ESSEMP.CIV  = I_ESSEMP.snapshot.CIV
  GERR = 1
  mkstat = 2
  End
Else
  Gosub UPDATE_ESSEMP
Endif
#------------------------Hybrid-------------------------#

End


