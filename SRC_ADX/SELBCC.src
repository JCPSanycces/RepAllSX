#<AdxTL>@(#)2.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
Local Char PARAM(30)(1..10) , VALEUR(10)
PARAM(1) = "4"
PARAM(2) = "PAR"
PARAM(3) = "20000828"
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = "0"

Call S_TAB_CHAR(VALEUR,PARAM,"SELCCE","SELBCC","") From GACTION
End
#*********************************************************************
#    GBO - 14.03.2006    (FQ 35212) : La pagination ne fonctionne
#*********************************************************************

#######################################################################
# Action SELCCE modélisée
#######################################################################
$ACTION
 Case ACTION
  When "SEL_TABLE"
   Case TABLE
     When "SELCCE" : Gosub SELCCE
   Endcase
  When "FIN_TABLE"
   Case TABLE
     When "SELCCE" : Gosub F_SELCCE
   Endcase
  When "BOUT_TABLE"
   Case TABLE
     When "SELCCE" : Gosub P_SELCCE
  Endcase
 Endcase
Return   

##########################
# Pagination
##########################
P_SELCCE
 Case GSTATUT
  When GSTASVG    : Gosub PAGE_SUIV 
  When GSTAPRG    : Gosub PAGE_PREC
 Endcase
Return

##########################
# Pagination avant
##########################
$PAGE_SUIV
 
 If dim(T_CLEDEB)<0 : Global Char T_CLEDEB(10)(GNBPAG) : Endif
 If dim(T_CLEFIN)<0 : Global Char T_CLEFIN(10)(GNBPAG) : Endif
 If dim(I_PAG)<0    : Global Integer I_PAG    : Endif

 #> Alimentation du tableau de clé

 #> paginations suivantes

 If I_PAG<>0
  T_CLEDEB(I_PAG)=T_CLEFIN(I_PAG-1)
  T_CLEFIN(I_PAG)=[F:CCE]CCE
  I_PAG+=1
 Endif
 
 #> Première pagination

 If I_PAG=0
  T_CLEDEB(0)=""
  T_CLEFIN(0)=[F:CCE]CCE
  I_PAG+=1
 Endif

 FILSUITE = "CCE>'"+[F:CCE]CCE+"'"

Return
 
##########################
# Pagination arrière
##########################
$PAGE_PREC
 If dim(I_PAG)>0
  If I_PAG<>0
   FILSUITE = "CCE>'"+T_CLEDEB(I_PAG-1)+"'"  
   T_CLEDEB(I_PAG)=""
   T_CLEFIN(I_PAG)=""
   I_PAG-=1
  Endif
 Endif
Return

###############################################################################
## BY le 29/09/1999
## Enorme usine à gaz qui permet de ne sélectionner que les sections
## auxquelles on a le droit
###############################################################################
$SELCCE
Local Integer AXE     : # l'axe
Local Char    FCY(GLONFCY)  : # le site
Local Date    DAT     : # la date
Local Char    CNA(GLONCNA) : # la nature
Local Char    CCE(GLONCCE) : # "[M]CCE#" par exemple, # indique zone indicée
Local Integer NOL     : # le numéro de ligne dans le tableau CCE#
Local Integer CNADIM, ACCDIM

#If GTABCPT<>"" : OBJET="CCE" : Return : Endif : # Pas possible de linker des tables de différents dossiers
If GTABCPT<>"" : OBJET="CCE" : CRITERE(1)  = '[F:CCE]AXI='+PARAM(1)+' & [F:CCE]IPT=2' : Return : Endif : # Pas possible de linker des tables de différents dossiers

AXE = val(PARAM(1))
FCY = PARAM(2)
If PARAM(3)<>""
 DAT = gdat$(PARAM(3))
Else
 DAT = [0/0/0]
Endif
CNADIM = dim([M]CNA)   :# bug 16694
ACCDIM = dim([M]ACC)
If CNADIM>0
 If CNADIM>1
  CNA = [M]CNA(nolign-1)
 Else
  CNA = [M]CNA   :# écran SAIANA de la fonction CPTANA (Saisie analytique)
 Endif
Elsif ACCDIM>0   :# cas des US
 If ACCDIM>1
  CNA = [M]ACC(nolign-1)
 Else
  CNA = [M]ACC   :# écran SAIANA
 Endif
Endif
CCE = PARAM(4)
NOL = val(PARAM(5))

Local Char    SECTION(GLONCCE) , SECAUZ(3)(1..8)
Local Integer TB(1..8)
Local Integer ERR , I , J , K , MAXLNK

MAXLNK = 5 : # Nb maximum de fois qu'on peut linker [AUZ] avec [CCE] (limite des 8 links)

## Position et taille de la fenêtre

SIZCOL = 240
SIZLIG = 100

## Il risque d'y avoir un problème de nombre de fichiers ouverts

ERR = 0
Onerrgo ERROUV
If !clalev([F:CCE]) : Local File CACCE    [CCE] : Endif
If !clalev([F:CNA]) : Local File CACNA    [CNA] : Endif
If !clalev([F:AUZ]) : Local File CAAUZ    [AUZ] : Endif
If !clalev([F:FGR]) : Local File FACGROUP [FGR] : Endif
Columns [AUZ] (TYP,AUZ1,AUZ2)
If clalev([F:ACS])=0 : Local File ACCES [ACS] : Endif
For I=1 To min(MAXLNK,AXE-1)
 Case I
  When 1 : Local File CAAUZ [AU1] : Columns [AU1] (TYP,AUZ1,AUZ2)
  When 2 : Local File CAAUZ [AU2] : Columns [AU2] (TYP,AUZ1,AUZ2)
  When 3 : Local File CAAUZ [AU3] : Columns [AU3] (TYP,AUZ1,AUZ2)
  When 4 : Local File CAAUZ [AU4] : Columns [AU4] (TYP,AUZ1,AUZ2)
  When 5 : Local File CAAUZ [AU5] : Columns [AU5] (TYP,AUZ1,AUZ2)
  When 6 : Local File CAAUZ [AU6] : Columns [AU6] (TYP,AUZ1,AUZ2)
  When 7 : Local File CAAUZ [AU7] : Columns [AU7] (TYP,AUZ1,AUZ2)
  When 8 : Local File CAAUZ [AU8] : Columns [AU8] (TYP,AUZ1,AUZ2)
 Endcase
Next I
Onerrgo
If ERR
# Si ça merde, on se déroute sur le select standard
 OBJET = "CCE"
 Return
Else
 OBJET = ""
Endif

Call LECTURE("CNA",CNA,"") From CONTOBJ

# Evaluation des autres codes interdiction sections

Raz SECAUZ
For I=1 To AXE-1
 K = instr(1,[L]CCE,"#") 
 Onerrgo ERROUV
 ERR = 0
 If K
# SECTION = evalue(left$([L]CCE,K-1)+num$(I)+"("+num$(NOL)+")")
  SECTION = evalue(left$([L]CCE,K-1)+num$(I)+"("+num$(nolign-1)+")") : # modif ELA 5/7/2004
 Else
# SECTION = evalue([L]CCE+"("+num$(NOL)+")")
  SECTION = evalue([L]CCE+"("+num$(I-1)+")") : # modif ELA 5/7/2004
 Endif
 Onerrgo
 If ERR : SECTION = "" : Endif
 If SECTION<>""
  Read [CCE]CCE0 = I;SECTION
  If !fstat
   SECAUZ(I) = [F:CCE]AUZ
  Endif 
 Endif
Next I

## Link d'enfer
## Y'a aussi un risque avec l'instruction link
## Il faudra mettre un "columns"

Gosub OUVRE_LISTE From WOCCE

Call TITOBJ("CCE","!",TIT(0)) From CONTOBJ : # ajout ELA 5/7/2004
TIT(0)  = mess(12,123,1)-TIT(0) : # Sélection : # ajout ELA 5/7/2004

For I=1 To NBSEL
 COL(I) = SELZON(I)
 TIT(I) = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I
NBCOL = NBSEL

## Critères de sélection
## Le link fait des liaisons "externes gauches"
## Toute la subtilité de la chose est de mettre des fonctions qui
## ne sont pas transmises à la base de données : len() , num$()
## sinon celle-ci ne renvoie rien du tout...sniff

CRITERE(1)  = '[F:CCE]AXI='+num$(AXE)+' & [F:CCE]IPT=2'

If [L]FCY<>""
 CRITERE(1) -= '& ([F:CCE]FCY="" | [F:CCE]FCY="'+[L]FCY+'" | [F:FGR]CPY<>"")'
Endif

If DAT<>[0/0/0]
 CRITERE(1) -= '& ([F:CCE]VLYSTR=[0/0/0] | [F:CCE]VLYSTR<=['+format$(GFMD,DAT)+'])'
 CRITERE(1) -= '& ([F:CCE]VLYEND=[0/0/0] | [F:CCE]VLYEND>=['+format$(GFMD,DAT)+'])'
Endif

CRITERE(2) = '& (GUSRACS=2 | [F:CCE]ACS="" | num$([F:ACS]EXEC)="2")'
If dim(SELCAR)>0 & SELCAR<>0
 CRITERE(2) -= '& left$([F:CCE]CCE,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

CRITERE(3) = '& string$(1,[F:AUZ]AUZ1)=""'
K = 0
For I=1 To AXE-1
 If SECAUZ(I)<>"" & K<MAXLNK
  K += 1
  CRITERE(3) -= '& string$(1,[F:AU'+num$(K)+']AUZ1)=""'
  TB(K) = I
 Endif
Next I

Case K
 When 0
  Link [CCE] With [AUZ]AUZ0   = 2;[F:CCE]AUZ;[F:CNA]AUZ
&               , [ACS]CODACC = GUSER;[F:CCE]ACS
&               , [FGR]FGR1   = [L]FCY;[F:CCE]FCY
&  As [LNC]
 When 1
  Link [CCE] With [AUZ]AUZ0   = 2;[F:CCE]AUZ;[F:CNA]AUZ
&               , [ACS]CODACC = GUSER;[F:CCE]ACS
&               , [FGR]FGR1   = [L]FCY;[F:CCE]FCY
&               , [AU1]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(1))
&  As [LNC]
 When 2
  Link [CCE] With [AUZ]AUZ0   = 2;[F:CCE]AUZ;[F:CNA]AUZ
&               , [ACS]CODACC = GUSER;[F:CCE]ACS
&               , [FGR]FGR1   = [L]FCY;[F:CCE]FCY
&               , [AU1]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(1))
&               , [AU2]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(2))
&  As [LNC]
 When 3
  Link [CCE] With [AUZ]AUZ0   = 2;[F:CCE]AUZ;[F:CNA]AUZ
&               , [ACS]CODACC = GUSER;[F:CCE]ACS
&               , [FGR]FGR1   = [L]FCY;[F:CCE]FCY
&               , [AU1]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(1))
&               , [AU2]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(2))
&               , [AU3]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(3))
&  As [LNC]
 When 4
  Link [CCE] With [AUZ]AUZ0   = 2;[F:CCE]AUZ;[F:CNA]AUZ
&               , [ACS]CODACC = GUSER;[F:CCE]ACS
&               , [FGR]FGR1   = [L]FCY;[F:CCE]FCY
&               , [AU1]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(1))
&               , [AU2]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(2))
&               , [AU3]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(3))
&               , [AU4]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(4))
&  As [LNC]
 When 5
  Link [CCE] With [AUZ]AUZ0   = 2;[F:CCE]AUZ;[F:CNA]AUZ
&               , [ACS]CODACC = GUSER;[F:CCE]ACS
&               , [FGR]FGR1   = [L]FCY;[F:CCE]FCY
&               , [AU1]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(1))
&               , [AU2]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(2))
&               , [AU3]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(3))
&               , [AU4]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(4))
&               , [AU5]AUZ0   = 1;[F:CCE]AUZ;SECAUZ(TB(5))
&  As [LNC]
Endcase

Default File [LNC]

If dim(T_CLEDEB)>0 : Kill T_CLEDEB : Endif
If dim(T_CLEFIN)>0 : Kill T_CLEFIN : Endif
If dim(I_PAG)>0    : Kill I_PAG    : Endif
If dim(GNBENR)<0 : Global Integer GNBENR : Endif
If dim(GNBPAG)<0 : Global Integer GNBPAG : Endif
GNBENR=rowcount([F:LNC])     # Récupère le nombre d'enregistrements 
GNBPAG=int(GNBENR/adxmxl)+1  # Nombre de pages possibles

Return

$F_SELCCE
If clalev([F:AUZ]) : Columns [AUZ] : Endif

If dim(GNBENR)>0   : Kill GNBENR      : Endif
If dim(T_CLEDEB)>0 : Kill T_CLEDEB    : Endif
If dim(T_CLEFIN)>0 : Kill T_CLEFIN    : Endif
If dim(I_PAG)>0    : Kill I_PAG       : Endif

Return   # CP 03/05/01

$ERROUV
ERR = errn
Resume
