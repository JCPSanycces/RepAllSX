#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du masque PCRITRCP
#######################################################################
# SUBPCR1 : Saisie des critères pour filtre du picking   MBT 02/12/99 #
#           de préchargement des lignes du retour                     #
# ------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p de     #
#        saisie des critères "SAISIE_CRIT" et ne sert qu'à gérer le   #
#        masque écran "PCRITRCP [PCR1]".                              #
#######################################################################

$ACTION
Return

Subprog IB_WBPSNUM
#--------------------------------------------------#
# Initialisation des boutons sur champ fournisseur #
#--------------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
GBOUT1=mess(457,198,1) : # Fournisseurs
End

Subprog AM_WBPSNUM(VALEUR)
#--------------------------------#
# Après modification fournisseur #
#--------------------------------#
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
End

Subprog C_WNUMCDE(VALEUR)
#-----------------------------#
# Contrôle numéro de commande #
#-----------------------------#
Variable Char    VALEUR()
If VALEUR="" End : Endif
#----- Contrôle existence et appartenance à la même société -----#
If clalev([F:FCY])=0 Local File FACILITY [FCY] : Endif
Read [POH] POH0=VALEUR : If fstat Raz [F:POH]  : End : Endif
Read [FCY] FCY0=[F:POH]POHFCY : If fstat Raz [F:FCY] : Endif
If [F:FCY]LEGCPY<>GSOCIETE GMESSAGE=mess(2,194,1): GERR = 1 : mkstat=1 : End : Endif
End

Subprog C_WNUMRCP(VALEUR)
#------------------------------#
# Contrôle numéro de réception #
#------------------------------#
Variable Char    VALEUR()
If VALEUR="" End : Endif
#----- Contrôle existence et appartenance à la même société -----#
If clalev([F:FCY])=0 Local File FACILITY [FCY] : Endif
Read [PTH] PTH0=VALEUR : If fstat Raz [F:PTH]  : End : Endif
Read [FCY] FCY0=[F:PTH]PRHFCY : If fstat Raz [F:FCY] : Endif
If [F:FCY]LEGCPY<>GSOCIETE GMESSAGE=mess(2,194,1) : GERR = 1 :  mkstat=1 : End : Endif
End

Subprog IB_WITMREF
#---------------------------------------------#
# Initialisation bouton sur référence article #
#---------------------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4
GBOUT1=mess(22,198,1) : # Articles : Tunnel sur les articles
End

Subprog AM_WITMREF(VALEUR)
#----------------------------#
# Contrôle référence article #
#----------------------------#
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
End
