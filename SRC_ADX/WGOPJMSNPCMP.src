#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OPJMSNPCMP

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:14:47"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OPJMSNPCMP",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="PJSC0;PJSC1;PJSC2;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
If clalev([M:PJSC0])=0 : Local Mask PJMSNPCMP0 [PJSC0] : Endif
If clalev([M:PJSC1])=0 : Local Mask PJMSNPCMP1 [PJSC1] : Endif
If clalev([M:PJSC2])=0 : Local Mask PJMSNPCMP2 [PJSC2] : Endif
Gosub TIT
nolign = 1
Return

$DEF_BOITE
Gosub HORODAT From WGOPJMSNPCMP
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPJMSNPCMP" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJSC0]
&   Folder Mask [PJSC1]
& , Folder Mask [PJSC2]
& As [PJSC1]
Titled [PJSC1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOPJMSNPCMP
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPJMSNPCMP" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJSC0]
&   Folder Mask [PJSC1]
& , Folder Mask [PJSC2]
& As [PJSC1]
Titled [PJSC1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [PJSC1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [PJSC1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [PJSC1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TIT(60) , TITTRN(60)
Call TEXTE(1003780,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Return

$DEFAUT_BRO
Return

$SETBOX
Return

$SETORDER
Return

$ENDORDER
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "PJMSNPCMP0"   : ABMSK(0)  = "PJSC0"    : AMA(0) = 1
NOMMSK(1) = "PJMSNPCMP1"   : ABMSK(1)  = "PJSC1"    : AMA(1) = 1
NOMMSK(2) = "PJMSNPCMP2"   : ABMSK(2)  = "PJSC2"    : AMA(2) = 1
NBMASK = 2
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:PJSC0])>0 : Default Mask [PJSC0] : Endif
 When 1 : If clalev([M:PJSC1])>0 : Default Mask [PJSC1] : Endif
 When 2 : If clalev([M:PJSC2])>0 : Default Mask [PJSC2] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:PJSC0])>0 : Gosub TITRES From W1PJMSNPCMP0 : Endif
 When 1 : If clalev([M:PJSC1])>0 : Gosub TITRES From W1PJMSNPCMP1 : Endif
 When 2 : If clalev([M:PJSC2])>0 : Gosub TITRES From W1PJMSNPCMP2 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:PJSC0])>0 : Close Local Mask [PJSC0] : Endif
If clalev([M:PJSC1])>0 : Close Local Mask [PJSC1] : Endif
If clalev([M:PJSC2])>0 : Close Local Mask [PJSC2] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:PJSC0])>0 : Raz [M:PJSC0] : Endif
 When 1 : If clalev([M:PJSC1])>0 : Raz [M:PJSC1] : Endif
 When 2 : If clalev([M:PJSC2])>0 : Raz [M:PJSC2] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:PJSC0])>0 : Affzo [M:PJSC0] : Endif
 When 1 : If clalev([M:PJSC1])>0 : Affzo [M:PJSC1] : Endif
 When 2 : If clalev([M:PJSC2])>0 : Affzo [M:PJSC2] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Return

$CHARGEMSK
Return

$GRISE_CLE
Return

$DEGRISE_CLE
Return

$BOUTON
STDBOUT = ""
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "1" : LBOUT(NBTEX) = 1101 : Call TEXTE(16031,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


