########################################################################
##
## Get a text from ATEXTE table by number and language.
##
########################################################################

Funprog GETTEXT( NUMBER, LANGUAGE )
Value Decimal NUMBER
Value Char LANGUAGE
    Local Char TEXT(255) : Raz TEXT

    If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif

    Filter [ATX] Where LAN = [L]LANGUAGE & NUMERO = [L]NUMBER
    Read [ATX]NUMERO First
    Filter [ATX]
    If !fstat
        TEXT = [F:ATX]TEXTE
    Endif

End TEXT


