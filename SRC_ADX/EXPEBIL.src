##
##    NEW/MODIFIED OBJECTS:
##
##    AMK    EXPEBIL    NEW
##    AWI    EXPEBIL    NEW
##    ACT    EXPEBIL    NEW
##    AFC    EXPEBIL    NEW
##    TRT    EXPEBIL    NEW
##    ADP    EXPEBIL    NEW
##    TRT    EXPBAL     MODIFIED (see code comments on SAM #92886)
##
############################################################################



########################################################################
##
## Initialize variables etc. (nothing to to, yet).
##
########################################################################

$INIT
    # ... [NOTHING TO DO, YET]
Return


########################################################################
##
## Write header line(s) to export file.
##
########################################################################

$EXPORT_HEADER
    Local Char NAMEFUNC(255) : NAMEFUNC = func GETTEXT( 52044, GLANGUE ) # 'Export to Sage E-Bilanz'

    adxifs = SEPCHP
    adxirs = SEPENR
# 2014-04-23 DNE MODIF BEGIN
    Wrseq "#LIC='" + fmet GACTX.AGETLIC_SERIAL( "1" ) + "'",
# 2014-04-23 DNE MODIF ORIG
#    Wrseq "#LIC='" + func GETLIC() + "'",
# 2014-04-23 DNE MODIF END
    Wrseq "FUNCTION='" + NAMEFUNC + "'",
    Wrseq "CPY='" + SOCIETE + "'", "CPYNAM='" + [F:CPY]CPYNAM + "'",
    Wrseq "START='" + [M]DATDEB + "'", "END='" + [M]DATFIN + "'"
    Wrseq "ID", "DESCR", "DEBIT", "CREDIT"
Return


########################################################################
##
## Export of an account
##
########################################################################

# 2014-04-11 DNE MODIF BEGIN
$EXPORT
    Wrseq ctrans( COMPTE, TRANS1, TRANS2 );             # Account
    Wrseq ctrans( DESIG,  TRANS1, TRANS2 );             # Accoung description

    Local Decimal CPTVAL : CPTVAL = CPTDEB - CPTCRE     # Create signed balance

    If ( [M:DIA]ANO = 2 ) and ( CPTANO <> 0 )
        CPTVAL += CPTANO                                # Add carry over.
    Endif

    If CPTVAL >= 0                                      # Write unsigned balance (debit/credit)
        MONT = CPTVAL  : Wrseq MONT;
        MONT = 0       : Wrseq MONT
    Else
        MONT = 0       : Wrseq MONT;
        MONT = -CPTVAL : Wrseq MONT
    Endif
Return
