#<AdxTL>@(#)8.0.0.0 $Revision$
######################################################################
## Liens échéances (lettrage)
######################################################################
Subprog DUDLNK(NBECH,TBECR,TBECH,TBIPT)
Value    Integer NBECH
Value    Integer TBECR(1..)
Value    Integer TBECH(1..)
Value    Decimal TBIPT(1..)
#
#MV Gennaio 2007 aggiunti  i campi BPR e CPY su DUDLNK per pulizie in fase di ricostruzione
# 
If clalev([F:DLN])=0 : Local File =GTABCPT+"DUDLNK" [DLN] : Endif
Local Integer I , J
Local Integer TBTYP(1..dim(TBECR))
Local Char    PLAN(GLONCOA)
Local Char    ID1(15) , ID2(15)
Local Decimal MNT
#
Local Char TST(1)  : TST = ""
Local Char TYP(1)  : TYP = ""
Local Integer SG : SG = 0
Local Integer SNS(1..NBECH)

For I=1 To NBECH
 Read [DUD]DUD1 = TBECR(I);TBECH(I)
 If !fstat
  If I=1
   Call LECMAINPLAN(1,[F:DUD]CPY,PLAN) From CPTDIV
  Endif
  TBTYP(I) = [F:DUD]TYPDUD
  SNS(I)= [F:DUD]SNS
  If TST = ""   
   Read [GAC]GAC1 = PLAN ; [F:DUD]SAC
   SG=[F:GAC]SNSDEF 
   TST= "Y"
  Endif 
 Endif
Next I

For I=1 To NBECH
 If TBTYP(I)=3 : # Règlement 
  For J=1 To NBECH
  # If TBTYP(J)=2 : # Facture
   If TBTYP(J)<>3 : # Facture
    ID1 = num$(TBECR(I))+"/"+num$(TBECH(I))
    ID2 = num$(TBECR(J))+"/"+num$(TBECH(J))
    MNT = min(TBIPT(I),TBIPT(J))
    If MNT<>0
     Read [DLN]DLN1 = ID1;ID2
     If fstat
      Raz [F:DLN]
      [F:DLN]BPR =[F:DUD]BPR
      [F:DLN]CPY =[F:DUD]CPY
      [F:DLN]NUM     = uniqid([DLN])
      [F:DLN]NUMDUD1 = ID1
      [F:DLN]NUMDUD2 = ID2
      [F:DLN]AMTCUR  = MNT
      [F:DLN]DAT     = date$
      Write [F:DLN]
     Else
      [F:DLN]BPR =[F:DUD]BPR
      [F:DLN]CPY =[F:DUD]CPY
      [F:DLN]AMTCUR  = MNT
      [F:DLN]DAT     = date$
      Rewrite [F:DLN]
     Endif
     If fstat
      GOK = 0 : Call FSTA("DLN") From GLOCK : Break 2
     Endif
     TBIPT(I) -= MNT
     TBIPT(J) -= MNT
    Else
     Delete [DLN] Where NUMDUD1=ID1 & NUMDUD2=ID2
     If fstat=1
      GOK = -1 : GLOCK = "$DUDLNK"-ID1-ID2 : Break 2
     Endif
    Endif
   Endif
  Next J
 Endif
Next I
## MV Maggio 2006 Aggiunta section tratta3 e tratta4 per gestire i casi di pareggio 3/3 ##
Gosub TRATTA3
Gosub TRATTA4
##MV Maggio 2006 fine
End

$TRATTA3
For I=1 To NBECH
 If TBTYP(I)=3 : # Règlement 
  For J=1 To NBECH
   If TBTYP(J)=3 : # Règlement
    ID1 = num$(TBECR(I))+"/"+num$(TBECH(I))
    ID2 = num$(TBECR(J))+"/"+num$(TBECH(J))
    MNT = min(TBIPT(I),TBIPT(J))
   If ID1<>ID2
   If MNT<>0
     Read [DLN]DLN1 = ID1;ID2
     If fstat
      Raz [F:DLN]
      [F:DLN]NUM     = uniqid([DLN])
      [F:DLN]NUMDUD1 = ID1
      [F:DLN]NUMDUD2 = ID2
      [F:DLN]AMTCUR  = MNT
      [F:DLN]DAT     = date$
      [F:DLN]BPR =[F:DUD]BPR
      [F:DLN]CPY =[F:DUD]CPY
      Write [F:DLN]
     Else
      [F:DLN]AMTCUR  = MNT
      [F:DLN]DAT     = date$
     [F:DLN]BPR =[F:DUD]BPR
     [F:DLN]CPY =[F:DUD]CPY
      Rewrite [F:DLN]
     Endif
     If fstat
      GOK = 0 : Call FSTA("DLN") From GLOCK : Break 2
     Endif
     TBIPT(I) -= MNT
     TBIPT(J) -= MNT
    Else
     Delete [DLN] Where NUMDUD1=ID1 & NUMDUD2=ID2
     If fstat=1
      GOK = -1 : GLOCK = "$DUDLNK"-ID1-ID2 : Break 2
     Endif
    Endif
   Endif: Endif
 Next J
 Endif
Next I
Return

$TRATTA4
For I=1 To NBECH
 If (TBTYP(I)=4 or TBTYP(I)=2) : # CERCA  SE SEGNO CONGRUENTE  E NON E' SE STESSO
  For J=1 To NBECH
   If num$(TBECR(I))<>num$(TBECR(J))
   If TBTYP(J)<>3  & (SG=1 & SNS(J)=1) or (SG=2 & SNS(J)=-1)     
   # Facture 
    ID1 = num$(TBECR(I))+"/"+num$(TBECH(I))
    ID2 = num$(TBECR(J))+"/"+num$(TBECH(J))
    MNT = min(TBIPT(I),TBIPT(J))
    If MNT<>0
     Read [DLN]DLN1 = ID1;ID2
     If fstat
      Raz [F:DLN]
      [F:DLN]BPR =[F:DUD]BPR
      [F:DLN]CPY =[F:DUD]CPY
      [F:DLN]NUM     = uniqid([DLN])
      [F:DLN]NUMDUD1 = ID1
      [F:DLN]NUMDUD2 = ID2
      [F:DLN]AMTCUR  = MNT
      [F:DLN]DAT     = date$
      Write [F:DLN]
     Else
      [F:DLN]BPR =[F:DUD]BPR
      [F:DLN]CPY =[F:DUD]CPY
      [F:DLN]AMTCUR  = MNT
      [F:DLN]DAT     = date$
      Rewrite [F:DLN]
     Endif
     If fstat
      GOK = 0 : Call FSTA("DLN") From GLOCK : Break 2
     Endif
     TBIPT(I) -= MNT
     TBIPT(J) -= MNT
    Else
     Delete [DLN] Where NUMDUD1=ID1 & NUMDUD2=ID2
     If fstat=1
      GOK = -1 : GLOCK = "$DUDLNK"-ID1-ID2 : Break 2
     Endif
    Endif
   Endif
  Endif
 Next J
 Endif
Next I
Return

######################################################################
## Liens échéances (délettrage)
######################################################################
Subprog DUDUNLNK

# [DAE] est en ligne
If clalev([F:DLN])=0 : Local File =GTABCPT+"DUDLNK" [DLN] : Endif
Local File =GTABCPT+"GACCENTRYD" [DAE2]

Local Integer I , J , NBECH1 , NBECH2
Local Char    TBECH1(15)(1..100)
Local Integer TBTYP1(1..100)
Local Char    TBECH2(15)(1..1000)
Local Integer TBTYP2(1..1000)

Call SETMAINREF([F:DAE]CPY,GTYPGEN,GTYPANA) From CPTDIV
If [F:DAE]LEDTYP<>GTYPGEN : End : Endif

NBECH1 = 0
For [DUD]DUD1 Where ACCNUM=[F:DAE]ACCNUM 
 NBECH1 +=1
 TBECH1(NBECH1) = [F:DUD]NUMDUD
 TBTYP1(NBECH1) = [F:DUD]TYPDUD
Next
If NBECH1=0 : End : Endif


NBECH2 = 0
For [DAE2]DAE1 Where CPY=[F:DAE]CPY & FCYLIN=[F:DAE]FCYLIN & LEDTYP=[F:DAE]LEDTYP & ACC=[F:DAE]ACC & BPR=[F:DAE]BPR & MTC=[F:DAE]MTC
 For [DUD]DUD1 Where ACCNUM=[F:DAE2]ACCNUM
  NBECH2 +=1
  TBECH2(NBECH2) = [F:DUD]NUMDUD
  TBTYP2(NBECH2) = [F:DUD]TYPDUD
 Next
Next
If NBECH2=0 : End : Endif

For I=1 To NBECH1
 For J=1 To NBECH2
  If    TBTYP1(I)=3 & TBTYP2(J)=2
   Delete [DLN] Where NUMDUD1=TBECH1(I) & NUMDUD2=TBECH2(J)
  Elsif TBTYP1(I)=2 & TBTYP2(J)=3
   Delete [DLN] Where NUMDUD2=TBECH1(I) & NUMDUD1=TBECH2(J)
  Endif
  If fstat=1
   GOK = -1 : GLOCK = "$DUDLNK"-TBECH1(I)-TBECH2(J) : Break 2
  Endif
#Aggiunte in test
  If    TBTYP1(I)=3 & TBTYP2(J)=4
   Delete [DLN] Where NUMDUD1=TBECH1(I) & NUMDUD2=TBECH2(J)
  Elsif TBTYP1(I)=4 & TBTYP2(J)=3
   Delete [DLN] Where NUMDUD2=TBECH1(I) & NUMDUD1=TBECH2(J)
  Endif
  If fstat=1
   GOK = -1 : GLOCK = "$DUDLNK"-TBECH1(I)-TBECH2(J) : Break 2
  Endif
  If    TBTYP1(I)=4 & TBTYP2(J)=2
   Delete [DLN] Where NUMDUD1=TBECH1(I) & NUMDUD2=TBECH2(J)
  Elsif TBTYP1(I)=2 & TBTYP2(J)=4
   Delete [DLN] Where NUMDUD2=TBECH1(I) & NUMDUD1=TBECH2(J)
  Endif
  If fstat=1
   GOK = -1 : GLOCK = "$DUDLNK"-TBECH1(I)-TBECH2(J) : Break 2
  Endif
  If    TBTYP1(I)=4 & TBTYP2(J)=4
   Delete [DLN] Where NUMDUD1=TBECH1(I) & NUMDUD2=TBECH2(J)
   Delete [DLN] Where NUMDUD2=TBECH1(I) & NUMDUD1=TBECH2(J)
  Endif
##
##MV Maggio 2006 Aggiunte pulizie eventuali su casi 3/3 e 2/2
  If    TBTYP1(I)=2 & TBTYP2(J)=2
   Delete [DLN] Where NUMDUD1=TBECH1(I) & NUMDUD2=TBECH2(J)
   Delete [DLN] Where NUMDUD2=TBECH1(I) & NUMDUD1=TBECH2(J)
  Endif
  If    TBTYP1(I)=3 & TBTYP2(J)=3
   Delete [DLN] Where NUMDUD1=TBECH1(I) & NUMDUD2=TBECH2(J)
   Delete [DLN] Where NUMDUD2=TBECH1(I) & NUMDUD1=TBECH2(J)
  Endif
##MV Maggio 2006 fine
  If fstat=1
   GOK = -1 : GLOCK = "$DUDLNK"-TBECH1(I)-TBECH2(J) : Break 2
  Endif
 Next J
Next I
End



