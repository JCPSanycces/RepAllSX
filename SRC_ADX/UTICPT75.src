#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICPT75   UTI process
#
#    Update Table for Audit Field
##########################################################################


Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTICPT75(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT75(DOSSIER)
Value Char DOSSIER

Local Char TABLE(GLONATB), FLD(GLONAVA)
Local Integer WCOMPTEUR, CRE, UPD, DEL, OK

Call ECR_TRACE("UTICPT75 : Start of process on : "+DOSSIER,0) From GESECRAN

# Update AUCRE,AUUPD, AUDDEL fileds on ATBLE table + # Update of ATABAUD table

#TABLE = "ZZCP"  :
#OK = 1 : CRE = 2 : UPD = 2 : DEL = 2 : Gosub  UPD_ATABLE
#If OK : Gosub  UPD_ATABAUD : Endif
#If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

#--Supervisor Table
TABLE = "ADOPAR"
OK = 1 :CRE = 1 : UPD = 2 : DEL = 2 : Gosub  UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "ADOVAL"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2 : Gosub  UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "ADOVALAUS"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "ATABLE"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "ATABAUD"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "ACODNUM"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

#-- Common Table
TABLE = "TABVAT"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "TABRATVAT"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "GACCCODE"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "GAUTACE"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "GAUTACED"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "GAUTACEF"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "GVARPARVAL"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "GTYPACCENT"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "TABPIVTYP"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "TABSIVTYP"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "ITMFACILIT"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "TABCOSTMET"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

#-- Fixed Asset Table
TABLE = "TYPACE"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

TABLE = "TYPACEINT"
OK = 1 : CRE = 2 : UPD = 2 : DEL = 2  : Gosub UPD_ATABLE
If OK : Gosub  UPD_ATABAUD : Endif
If OK : Call MAJTRIG(TABLE,DOSSIER) From VALDIC : Endif

Call ECR_TRACE("UTICPT75 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN
End


$UPD_ATABLE
If filinfo(filpath("FIL","ATABLE","fde",DOSSIER),0)<=0 or func DOSVUE.ISVIEW(DOSSIER,"ATABLE")<>0 : Return : Endif

If clalev([F:ATB])  =0  Local File =DOSSIER+".ATABLE"   [ATB] : Endif
Call DEBTRANS From GLOCK
Trbegin [ATB]
Readlock [ATB]CODFIC = [L]TABLE
If !fstat & [F:ATB]CODACT<"X"
 [F:ATB]AUDCRE = [L]CRE
 [F:ATB]AUDUPD = [L]UPD
 [F:ATB]AUDDEL = [L]DEL
 Rewrite [F:ATB]
 If !fstat :
  WCOMPTEUR += 1
#  Call ECR_TRACE("Table Update : "+TABLE,0) From GESECRAN
 Endif
Else
 OK=0
Endif
Commit
Close Local File [ATB]
Return

$UPD_ATABAUD
If filinfo(filpath("FIL","ATABAUD","fde",DOSSIER),0)<=0 or func DOSVUE.ISVIEW(DOSSIER,"ATABAUD")<>0 : Return : Endif

If clalev([F:ATA])  =0  Local File =DOSSIER+".ATABAUD"   [ATA] : Endif
If clalev([F:ATZ])  =0  Local File =DOSSIER+".ATABZON"   [ATZ] : Endif

# If fields audited exist, then X3 do nothing
Read [ATA]ATA0(1) = TABLE
If !fstat : Return : Endif

Raz [ATA]
OK=0
Case TABLE
 When "ZZCP"
  FLD = "OBJET"    : Gosub UPD
  FLD = "JEU"      : Gosub UPD
  FLD = "CHAPITRE" : Gosub UPD
 When "ADOPAR"
  FLD = "PARAM"    : Gosub UPD
  FLD = "CHAPITRE" : Gosub UPD
  FLD = "GRPPAR"   : Gosub UPD
  FLD = "MODIF"    : Gosub UPD
  FLD = "CNDMOD"   : Gosub UPD
 When "ADOVAL"
  FLD = "PARAM"    : Gosub UPD
  FLD = "CMP"      : Gosub UPD
  FLD = "FCY"      : Gosub UPD
  FLD = "JEU"      : Gosub UPD
  FLD = "VALEUR"   : Gosub UPD
 When "ADOVALAUS"
  FLD = "PARAM"    : Gosub UPD
  FLD = "CODUSR"   : Gosub UPD
  FLD = "JEU"      : Gosub UPD
  FLD = "VALEUR"   : Gosub UPD
When "ATABLE"
  FLD = "CODFIC"   : Gosub UPD
  FLD = "AUDCRE"   : Gosub UPD
  FLD = "AUDUPD"   : Gosub UPD
  FLD = "AUDDEL"   : Gosub UPD
When "ATABAUD"
  FLD = "CODFIC"   : Gosub UPD
  FLD = "FLD"      : Gosub UPD
  FLD = "NUMLIG"   : Gosub UPD
  FLD = "OPE"      : Gosub UPD
  FLD = "VALEUR"   : Gosub UPD
When "TABVAT"
  FLD = "VAT"      : Gosub UPD
  FLD = "VATVAC"   : Gosub UPD
  FLD = "VATPAY"   : Gosub UPD
  FLD = "VATTYP"   : Gosub UPD
  FLD = "ACCCOD"   : Gosub UPD
When "TABRATVAT"
  FLD = "VAT"      : Gosub UPD
  FLD = "CPY"      : Gosub UPD
  FLD = "STRDAT"   : Gosub UPD
  FLD = "VATRAT"   : Gosub UPD
  FLD = "DEDRAT"   : Gosub UPD
  FLD = "VATEXEFLG": Gosub UPD
When "ACODNUM"
  FLD = "NIVDEF"   : Gosub UPD
  FLD = "NIVRAZ"   : Gosub UPD
  FLD = "CTLCHR"   : Gosub UPD
When "GTYPACCENT"
  FLD = "COU"       : Gosub UPD
  FLD = "MANNUM"    : Gosub UPD
  FLD = "VCRREA"    : Gosub UPD
  FLD = "VCRSIM"    : Gosub UPD
  FLD = "AUZLED"    : Gosub UPD
  FLD = "AUZJOU"    : Gosub UPD
  FLD = "VAT"       : Gosub UPD
  FLD = "VATPAI"    : Gosub UPD
  FLD = "ESDTRK"    : Gosub UPD
  FLD = "FLGEXPCRE" : Gosub UPD
When "TABPIVTYP"
  FLD = "PIVTYP"   : Gosub UPD
  FLD = "INVTYP"   : Gosub UPD
  FLD = "COD"      : Gosub UPD
  FLD = "COD2"     : Gosub UPD
  FLD = "JOU"      : Gosub UPD
  FLD = "GTE"      : Gosub UPD
When "TABSIVTYP"
  FLD = "SIVTYP"   : Gosub UPD
  FLD = "INVTYP"   : Gosub UPD
  FLD = "COD"      : Gosub UPD
  FLD = "COD2"     : Gosub UPD
  FLD = "JOU"      : Gosub UPD
  FLD = "GTE"      : Gosub UPD
When "TYPACE"
  FLD = "ENAFLG"     : Gosub UPD
  FLD = "ACETYP"     : Gosub UPD
  FLD = "DES"        : Gosub UPD
  FLD = "LEG"        : Gosub UPD
  FLD = "CPY"        : Gosub UPD
  FLD = "ACEGRP"     : Gosub UPD
  FLD = "SRCTYP"     : Gosub UPD
  FLD = "EVTTYP"     : Gosub UPD
  FLD = "EVTPLN"     : Gosub UPD
  FLD = "TABCPT"     : Gosub UPD
  FLD = "TRTSPE"     : Gosub UPD
  FLD = "TABOBJ"     : Gosub UPD
  FLD = "DPRPLN"     : Gosub UPD
  FLD = "PERCLOFLG"  : Gosub UPD
  FLD = "PERCOUFLG"  : Gosub UPD
  FLD = "PEROPEFLG"  : Gosub UPD
  FLD = "DIVCRIT"    : Gosub UPD
  FLD = "NBCRIT"     : Gosub UPD
  FLD = "SORTFLDTAB" : Gosub UPD
  FLD = "SORTFLD"    : Gosub UPD
  FLD = "RUPPCEFLG"  : Gosub UPD
  FLD = "GAU"        : Gosub UPD
  FLD = "GTE"        : Gosub UPD
  FLD = "GTEPRO"     : Gosub UPD
  FLD = "JOU"        : Gosub UPD
  FLD = "JOUPRO"     : Gosub UPD
  FLD = "ACCDATRUL"  : Gosub UPD
  FLD = "ACCDATFIX"  : Gosub UPD
  FLD = "SORTCCE"    : Gosub UPD
  FLD = "DIRCPTFLG"  : Gosub UPD
  FLD = "DIRCPTTRA"  : Gosub UPD
  FLD = "CPTREF"     : Gosub UPD
  FLD = "CREDAT"     : Gosub UPD
  FLD = "CREUSR"     : Gosub UPD
  FLD = "UPDDAT"     : Gosub UPD
  FLD = "UPDUSR"     : Gosub UPD
  FLD = "TRTINT"     : Gosub UPD
  FLD = "DBGMOD"     : Gosub UPD
When "TYPACEINT"
  FLD = "ACETYP"     : Gosub UPD
  FLD = "TMPIND"     : Gosub UPD
  FLD = "ORITAB"     : Gosub UPD
  FLD = "ORIFLD"     : Gosub UPD
  FLD = "ORIEXP"     : Gosub UPD
  FLD = "ORICND"     : Gosub UPD
  FLD = "ENALIG"     : Gosub UPD
  FLD = "NUMLIG"     : Gosub UPD
  FLD = "CREDAT"     : Gosub UPD
  FLD = "CREUSR"     : Gosub UPD
  FLD = "UPDDAT"     : Gosub UPD
  FLD = "UPDUSR"     : Gosub UPD
When "ITMFACILIT"
  FLD = "VLTCOD"     : Gosub UPD
When "TABCOSTMET"
  FLD = "VLTCOD"     : Gosub UPD
  FLD = "TCMDES"     : Gosub UPD
  FLD = "TCMSHO"     : Gosub UPD
  FLD = "RCPVLTCOD"  : Gosub UPD
  FLD = "RCPVLT2"    : Gosub UPD
  FLD = "ISSVLTCOD"  : Gosub UPD
  FLD = "ISSVLT2"    : Gosub UPD
  FLD = "VLTINT"     : Gosub UPD
  FLD = "CUNPOS"     : Gosub UPD
  FLD = "CUNPOS2"    : Gosub UPD
  FLD = "CUNNEG"     : Gosub UPD
  FLD = "CUNNEG2"    : Gosub UPD
  FLD = "PRIREG"     : Gosub UPD
  FLD = "PRIREGS"    : Gosub UPD
  FLD = "NULPRI"     : Gosub UPD
  FLD = "AVCPER"     : Gosub UPD
  FLD = "PFMCLCBAS"  : Gosub UPD
  FLD = "PFMCLC2"    : Gosub UPD
  FLD = "EXPNUM"     : Gosub UPD
Endcase
Close Local File [ATA], [ATZ]
Return

$UPD
Read [ATZ]CODZONE = TABLE;FLD
If !fstat
 [F:ATA]CODFIC = TABLE   : [F:ATA]NUMLIG+=1  : [F:ATA]FLD = FLD : [F:ATA]OPE = 1
 Write [F:ATA]
 If !fstat
  OK+=1 : WCOMPTEUR += 1
#  Call ECR_TRACE("Table Update : "+TABLE-FLD,0) From GESECRAN
 Endif
Endif
Return

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT75 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif


If filinfo(filpath("FIL","ATABAUD","fde",APPLI),0)<=0 : End : Endif
If func DOSVUE.ISVIEW(APPLI,"ATABAUD") : End : Endif

Call MAJ_UTICPT75(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

#If APPLI=GDOSX3: End : Endif

If filinfo(filpath("FIL","ATABAUD","fde",APPLI),0)<=0 : End : Endif
If func DOSVUE.ISVIEW(APPLI,"ATABAUD") : End : Endif

Call MAJ_UTICPT75(APPLI)
End

