# Recherche des mots-clés dans un titre
# (on garde tous les mots de plus de 3 caractères , algorithme à affiner selon la langue ?)
# si la source est de type "###,###", il s'agit d'un mot-clé que l'on prend tel quel
Subprog MAJMOTC(SOURCE,TBL,NUMTBL)
Variable Char TBL()(1..)
Value Char SOURCE()
Variable Integer NUMTBL
Local Char TMPCH(250),TMPCH1(250)
  If pat(SOURCE,"###,###")
    TMPCH1=func AGENADO.MST(val(left$(SOURCE,3)),val(right$(SOURCE,5)))
    NUMTBL+=1
    TBL(NUMTBL)=left$(TMPCH1,1)+tolower(right$(TMPCH1,2))
    If find(TBL(NUMTBL),TBL(1..NUMTBL-1))
        NUMTBL-=1
    Endif
  Else
    TMPCH=ctrans(toupper(ctrans(SOURCE)),sigma(1,64,chr$(indcum))+sigma(91,255,chr$(indcum)),space$(229))
    DESTIN=""
    While TMPCH<>""
        TMPCH1=vireblc(TMPCH,3)
        TMPCH=vireblc(right$(vireblc(TMPCH,0),len(TMPCH1)+1),0)
        If len(TMPCH1)>3
            NUMTBL+=1
            TBL(NUMTBL)=left$(TMPCH1,1)+tolower(right$(TMPCH1,2))
            If find(TBL(NUMTBL),TBL(1..NUMTBL-1))
                NUMTBL-=1
            Endif
        Endif
    Wend
  Endif
End

#
# Sous-programmes déplacés depuis AGENADO, et appelés par AGENADO
#
# Détermination de la pile des menus
# Chaque cas est traité par un sous-programme PILE_???MEN
# Un traitement par défaut (renvoi vers INDEX) existe
#
$PILE_MENUS

  #JPGA 07/04/2010 BUG-57357 : Si Solution sans BI : Code activité ABI desactivé donc pas de table BI : Ne pas generer les menus BI
  Case [ADO]TYP
      When "ABF" : If [L]BIDOC : Gosub PILE_ABFMEN : Endif : #VPO 04/09/08 48971 ajout ABF et ABM
      When "ABM" : If [L]BIDOC : Gosub PILE_ABMMEN : Endif : #VPO 04/09/08 48971 ajout ABF et ABM
      When "ABO" : If [L]BIDOC : Gosub PILE_ABOMEN : Endif : #VPO 14/01/08 41049,42137 doc ABO
      When "ACT" : Gosub PILE_ACTMEN
      When "ACV" : Gosub PILE_ACVMEN
      When "ADC" : Gosub PILE_ADCMEN
      When "ADM" : Gosub PILE_ADMMEN
      When "ADP" : Gosub PILE_ADPMEN
      When "AFC" : Gosub PILE_AFCMEN
      When "AGB" : Gosub PILE_AGBMEN
      When "AML" : Gosub PILE_AMLMEN
      When "AOE" : Gosub PILE_AOEMEN
      When "APM" : Gosub PILE_APMMEN
      When "ARP" : Gosub PILE_ARPMEN
      When "ASU" : Gosub PILE_ASUMEN
      #VPO 19/06/08 39766 ajout ATD: différences de tables
      #VPO 27/10/08 49955 ajout AT3: différences de tables 130
      When "ATD","AT3" : Gosub PILE_ATDMEN
      When "ATB" : Gosub PILE_ATBMEN
      When "ATY" : Gosub PILE_ATYMEN
      When "AWA" : Gosub PILE_AWAMEN
      When "CDA" : Gosub PILE_CDAMEN
      When "CDE" : If [L]CDEDOC : Gosub PILE_CDEMEN : Endif : #JPGA 13/04/2010 BUG-63897 : Alimentation de la variable CDEDOC pour savoir si les sections par défaut sont présentes
      When "GAU" : If [L]GAUDOC : Gosub PILE_GAUMEN : Endif : #JPGA 10/08/2010 BUG-66637 : Alimentation de la variable GAUDOC pour savoir si les Pièces automatiques sont présentes
      When "PLA" : Gosub PILE_PLAMEN : # VPO 07/01/08 evol 45065
      When "PS1" : Gosub PILE_PS1MEN
      When "AHI" : Gosub PILE_AHIMEN
      When Default : Gosub PILE_DEFMEN
  Endcase
Return

# Pile des menus pour les actions
$PILE_ACTMEN
  IPIL=1
  PILE_MEN(IPIL)=""
  Read [ACT]ACTION=[ADO]COD
  PILE_NOMEN(IPIL)=func AGENADO.MST(30,124)-[ADO]COD-"("+func AGENADO.RDT([ACT]INTITA)+")" : # "Action"
  IPIL+=1
  PILE_MEN(IPIL)="ACT_"+num$([ACT]MODULE) : # Le menu intermédiaire s'appellera ACT_numéro
