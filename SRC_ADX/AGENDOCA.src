##################
Funprog TRTINT(CHAINE)
Value Char CHAINE()
Local Integer NUM_MSG
If CHAINE="" : End CHAINE : Endif

#VPO 09/01/08 43109
If [ADC1]CODTRT<>CHAINE
    Read [ADC1]ADC0=CHAINE
    If fstat<>0
        End CHAINE
    Endif
Endif

#VPO 09/01/08 43109
#If COD_LAN<>"FRA"
If COD_LAN="FRA"
   #End CHAINE-"("+[ADC1]DES+")"
   End [ADC1]DES
Endif

If clalev([ZATX])=0 : Local File ATEXTE [ZATX] : Endif
Read [ZATX]TEXTE="FRA";[ADC1]DES
If fstat<>0
    Read [ZATX]CLEREC="FRA";left$(vireblc(toupper(ctrans([ADC1]DES)),4),20)
    If fstat<>0
        End CHAINE
    Endif
Endif
NUM_MSG=[ZATX]NUMERO

Read [ZATX]NUMERO=[V]COD_LAN;NUM_MSG
If fstat=0
    #End CHAINE-"("+[ZATX]TEXTE+")"
    End [ZATX]TEXTE
Else
    End CHAINE
Endif
End


# La fonction principale de génération des données de doc sur points d'entrée
# On ne génère un paragraphe de titre, et un paragraphe par point d'entrée
# Pour ne pas avoir de problème de génération en double, le début du titre du
# paragraphe est exactement le code du point d'entrée (un espace ou une parenthèse doivent suivre)
$GENE_ADCDOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[ADC]CODTRT
  CODE_MODULE=[ADC]MODULE
  CODE_ACTIV="" : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    #VPO 09/01/08 43109 on ajoute le libellé dans le titre
    [ADO]TIT=func AGENADO.RDM("ADC1","CODTRT")-[ADC]CODTRT-':'-func AGENDOCA.TRTINT([ADC]CODTRT)
    Write [ADO]
  Else
    #VPO 09/01/08 43109 on met à jour le titre
    If instr(0,[ADO]TIT,":")=0
        [ADO]TIT=func AGENADO.RDM("ADC1","CODTRT")-[ADC]CODTRT-':'-func AGENDOCA.TRTINT([ADC]CODTRT)
        Gosub SET_ACTIV
        Rewrite [ADO]
    Endif
  Endif

# Recherche des liens existant vers des points d'entrée
  PAR_DOC="APE" : [ADO]PAR=PAR_DOC
  Gosub LIT_VALEURS From AGENADO

# Recherche du dernier rang utilisé pour les paragraphes de point d'entrée
  JJ=10 : KK=10
  For [ADO]ADO0 Where LAN=COD_LAN & TYP="ADC" & PAR="APE"
&                   & (pat(COD,CODE_DOC+" *")<>0 or pat(COD,CODE_DOC+"(*")<>0)
    JJ=[ADO]LEV : KK=[ADO]SUBLEV
  Next

# Pour chaque point d'entrée, vérification d'existence et création si pas trouvé
  For LL=1 To II
    MM=0
    For [ADO]ADO0 Where LAN=COD_LAN & COD=CODE_DOC & TYP="ADC" & TIT=VALEURS(LL)
        MM=1 : Break
    Next
    If MM=0

        # Paragraphe de titre
        JJ+=10 : [L]LEV=JJ : [L]SUBLEV=KK : PAR_DOC="APE"
        Gosub SET_ADO
        [ADO]TIT=VALEURS(LL)
        Write [ADO]

        # Contexte
        [L]LEV=JJ : [L]SUBLEV=KK+10 : PAR_DOC="CTX"
        Gosub SET_ADO
        [ADO]STY=4
        [ADO]TIT=func AGENADO.MST(153,142)
        Write [ADO]

    Endif
  Next LL

# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="ADC_"+num$([ADC]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Points d'entrée" "Module" module
    Read [AF1]CODINT="GESAPE"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)-func AGENADO.RDM("ATB1","MODULE")-func AGENADO.MST([ADC]MODULE,14)
    Write [ADO]
  Endif
  CODE_DOC="ADC_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Points d'entrée"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="ADC"

Return

# La fonction principale de génération des données de doc sur sous-programmes
$GENE_ASUDOC
# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  # JPGA 19/08/2009 Bug-52238 : Procedure de recherche pour savoir si on est en présence de clé multiples pour les docs
  Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
  If find(COD_TYP, [L]DOC_CLE_MULT)
    CODE_DOC=[ASU]PRG+[L]WTIRET+[ASU]SUBPRG
  Else
    CODE_DOC=[ASU]PRG
  Endif
  CODE_MODULE=[ASU]MODULE
  CODE_ACTIV=[ASU]CODACT : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.RDM("ASU1","SUBPRG")-[ASU]SUBPRG-"("+func AGENADO.RDT([ASU]INTIT)+")"
    Write [ADO]
  Else
    [ADO]MODULE=CODE_MODULE
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif


  # Paragraphe de présentation
  # On renseigne TEXTES avec les textes trouvés dans le dictionnaire en cas de première création
  # Le champ [ASU]TEX est amené à disparaître en version 150...
  Raz TEXTES
  If dim([ASU]TEX)>0
      Setlob TEXTES With [ASU]TEX
  Endif
  Gosub CR_PRET

# Critères du sous-programme
  PAR_DOC="CRI" : [L]LEV=20 : [L]SUBLEV=10
  Gosub TST_CREER
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.MST(37,142) : # "Liste des critères"
    [ADO]STY=4
    Write [ADO]
  Else
    [ADO]MODULE=CODE_MODULE
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif


# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="ASU_"+num$([ASU]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Types" "Module" module
    Read [AF1]CODINT="GESASU"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)-func AGENADO.RDM("ATB1","MODULE")-func AGENADO.MST([ASU]MODULE,14)
    Write [ADO]
  Endif
  CODE_DOC="ASU_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Sous-programmes"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="ASU"

Return

# La fonction principale de génération des données de doc sur variables
$GENE_AGBDOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[AGB]CODVAR
  CODE_MODULE=[AGB]MODULE
  CODE_ACTIV=[AGB]CODACT : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    [ADO]TIT=func AGENADO.RDM("AGB1","CODVAR")-[AGB]CODVAR-"("+func AGENADO.RDT([AGB]INTIT)+")"
    Write [ADO]
  Else
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

  # Paragraphe de présentation
  # On renseigne TEXTES avec les textes trouvés dans le dictionnaire en cas de première création
  # Le champ [AGB]DES est amené à disparaître en version 150...
  II=0
  If dim([AGB]DES)>0
    For II=0 To 2
        If [AGB]DES(II)<>""
            TEXTES(II+1)=[AGB]DES(II)+" "
        Else
            TEXTES(II+1)=""
        Endif
    Next II
  Endif
  TEXTES(II+1)=""
  Gosub CR_PRET

# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="AGB_"+num$([AGB]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Types" "Module" module
    Read [AF1]CODINT="GESAGB"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)-func AGENADO.RDM("ATB1","MODULE")-func AGENADO.MST([AGB]MODULE,14)
    Write [ADO]
  Endif
  CODE_DOC="AGB_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Variables globales"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="AGB"

Return

# La fonction principale de génération des doc diverses
# On ne génère qu'un titre
$GENE_DIVDOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=DOC_DEB
  If CODE_DOC="" : Return : Endif : # Pas de docs vides, scrogneugneu !!!

  CODE_MODULE=9 : # Tronc commun
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=""
    Write [ADO]
  Endif

Return


$GENE_AHIDOC
  # Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[AHI]COD
  CODE_MODULE=[AHI]MODULE
  CODE_ACTIV=""
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.RDM("AHI1","")

    # Quelques mots-clés...
    II=0
    Call MAJMOTC(func AGENADO.RDT([AHI]DES),TXT_TAB,II) :  # A rendre traduisible
    Call MAJMOTC(format$("N0:3",[AHI]MODULE)+",014",TXT_TAB,II)
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADH]
    Write [ADO]
  Endif

  # Paragraphe de présentation
  Gosub CR_PRE
  # Paragraphe remarques
  Gosub CR_REM

  # Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="AHI_"+num$([AHI]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    Gosub SET_VLD
    # "Règles d'épuration" "Module" nom du module
    Read [AF1]CODINT="GESAHI"
    [ADO]TIT=func AGENADO.MST(120,176)-func AGENADO.RDM("AHI1","MODULE")
&           -func AGENADO.MST([AHI]MODULE,14)
    Write [ADO]
  Endif

  CODE_DOC="AHI_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    Gosub SET_VLD
    # "Règle d'épuration"
    [ADO]TIT=func AGENADO.MST(120,176)
    Write [ADO]
  Endif
  # Remise à jour du code type
  COD_TYP="AHI"
Return


# Sous-programmes

# Test régénération
# Si le paragraphe n'existe pas, il faut le générer, donc REGEN=1
# Si le paragraphe existait sans texte dedans, on l'efface (il sera recréé s'il est réellement nécessaire)
#  (sauf si le paragraphe est validé, modification du 10 mai 2007)
# Si le paragraphe existait avec un texte dedans, on le respecte (on ne sait jamais, REGEN=0 dans ce cas)
# Modification du 16/08/2006 : Gestion du flag de validation, de CREDAT
$TST_REGEN
  Read [ADO]ADO0=[V]COD_LAN;COD_TYP;CODE_DOC;[L]LEV;[L]SUBLEV
  If fstat
    REGEN=1
    Raz [ADO]VLDDAT
    If dim([ADO]UPDDAT)>0    : Raz [ADO]UPDDAT     : Endif
    If dim([ADO]UPDUSR)>0    : Raz [ADO]UPDUSR     : Endif
    If dim([ADO]UPDTIM)>0    : Raz [ADO]UPDTIM     : Endif
    If dim([ADO]UPDDATTIM)>0 : Raz [ADO]UPDDATTIM  : Endif
    [ADO]VLDFLG=1
    If dim([ADO]CREUSR)>0    : [ADO]CREUSR    = GUSER                                      : Endif  : #VPO 01/07/08
    If dim([ADO]CREDATTIM)>0 : [ADO]CREDATTIM = datetime$
      If dim([ADO]CREDAT)>0  : [ADO]CREDAT    = func SUBADC.DAT_DATETIME([ADO]CREDATTIM)   : Endif
    Else
      If dim([ADO]CREDAT)>0  : [ADO]CREDAT    = date$                                      : Endif
      If dim([ADO]CRETIM)>0  : [ADO]CRETIM    = time                                       : Endif
    Endif
  Else
    Read [ADH]ADH0=[V]COD_LAN;COD_TYP;CODE_DOC;[L]LEV;[L]SUBLEV
    If fstat=0
        Setlob TEXTES With [ADH]TEXTE
    Else
        Read [ADH2]ADH0=[V]COD_LAN;COD_TYP;CODE_DOC;[L]LEV;[L]SUBLEV
        If fstat=0
            #VPO 15/01/08 Setlob TEXTES With [ADH]TEXTE
            Setlob TEXTES With [ADH2]TEXTE
        Else
            Raz TEXTES
        Endif
    Endif

    If TEXTES(1)="" & [ADO]VLDFLG=1
        Delete [ADO]ADO0=[V]COD_LAN;COD_TYP;CODE_DOC;[L]LEV;[L]SUBLEV
        REGEN=1
    Else
        REGEN=0
        If dim([ADO]UPDUSR)>0    : [ADO]UPDUSR    = GUSER                                      : Endif
        If dim([ADO]UPDDATTIM)>0 : [ADO]UPDDATTIM = datetime$
          If dim([ADO]UPDDAT)>0  : [ADO]UPDDAT    = func SUBADC.DAT_DATETIME([ADO]UPDDATTIM)   : Endif
        Else
          If dim([ADO]UPDDAT)>0  : [ADO]UPDDAT    = date$                                      : Endif
          If dim([ADO]UPDTIM)>0  : [ADO]UPDTIM    = time                                       : Endif
        Endif
    Endif
  Endif
Return

#TRACE_COR_TIT : Etiquette de tracage du paragraphe TIT dans la génération ADOCUMENT
$TRACE_COR_TIT
   #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Marquage Réalisé pour les Ecritures de la Génération ADOCUMENT (On ne le fait que sur TIT en CREATION)
   # Le besoin réside seulement dans la création du Lien OBJET-GROUPE et non le Marquage pour le Pousse-pousse mais TRACE_COR fait les 2 !
   If PAR_DOC="TIT" & REGEN
      Call TRACE_GROUPE("ADO", [V]COD_LAN, COD_TYP, CODE_DOC, "C") From AGENLIBA
   Endif
Return

# Test création
# Vérifie simplement si l'enregistrement existe déjà, mais ne le supprime pas
# REGEN vaut 1 si le paragraphe n'existe pas

$TST_CREER
  Read [ADO]ADO0=[V]COD_LAN;COD_TYP;CODE_DOC;[L]LEV;[L]SUBLEV
  REGEN=(fstat<>0)
  If REGEN
    Raz [ADO]VLDDAT
    If dim([ADO]UPDDAT)>0    : Raz [ADO]UPDDAT     : Endif
    If dim([ADO]UPDUSR)>0    : Raz [ADO]UPDUSR     : Endif
    If dim([ADO]UPDTIM)>0    : Raz [ADO]UPDTIM     : Endif
    If dim([ADO]UPDDATTIM)>0 : Raz [ADO]UPDDATTIM  : Endif
    [ADO]VLDFLG=1
    If dim([ADO]CREUSR)>0    : [ADO]CREUSR    = GUSER                                      : Endif
    If dim([ADO]CREDATTIM)>0 : [ADO]CREDATTIM = datetime$
      If dim([ADO]CREDAT)>0  : [ADO]CREDAT    = func SUBADC.DAT_DATETIME([ADO]CREDATTIM)   : Endif
    Else
      If dim([ADO]CREDAT)>0  : [ADO]CREDAT    = date$                                      : Endif
      If dim([ADO]CRETIM)>0  : [ADO]CRETIM    = time                                       : Endif
    Endif
  Else
    If dim([ADO]UPDUSR)>0    : [ADO]UPDUSR    = GUSER                                      : Endif
    If dim([ADO]UPDDATTIM)>0 : [ADO]UPDDATTIM = datetime$
      If dim([ADO]UPDDAT)>0  : [ADO]UPDDAT    = func SUBADC.DAT_DATETIME([ADO]UPDDATTIM)   : Endif
    Else
      If dim([ADO]UPDDAT)>0  : [ADO]UPDDAT    = date$                                      : Endif
      If dim([ADO]UPDTIM)>0  : [ADO]UPDTIM    = time                                       : Endif
    Endif
  Endif
Return

# test de création (REGEN=0) ou maj (REGEN=1 pour [ADH] ou 2 pour [ADH2])
$TST_REGENADH
    Read [ADH]ADH0=[V]COD_LAN;COD_TYP;CODE_DOC;[L]LEV;[L]SUBLEV
    If fstat=0
        REGEN=1
        Setlob TEXTES With [ADH]TEXTE
    Else
        Read [ADH2]ADH0=[V]COD_LAN;COD_TYP;CODE_DOC;[L]LEV;[L]SUBLEV
        If fstat=0
            REGEN=2
            #VPO 15/01/08 Setlob TEXTES With [ADH]TEXTE
            Setlob TEXTES With [ADH2]TEXTE
        Else
            REGEN=0
            Raz TEXTES
            Raz [ADH]
            [ADH]=[ADO]
            If dim([ADH]CREUSR)>0    : [ADH]CREUSR    = GUSER                                      : Endif
            If dim([ADH]CREDATTIM)>0 : [ADH]CREDATTIM = datetime$
              If dim([ADH]CREDAT)>0  : [ADH]CREDAT    = func SUBADC.DAT_DATETIME([ADH]CREDATTIM)   : Endif
            Else
              If dim([ADH]CREDAT)>0  : [ADH]CREDAT    = date$                                      : Endif
              If dim([ADH]CRETIM)>0  : [ADH]CRETIM    = time                                       : Endif
            Endif
            If dim([ADH]UPDUSR)>0    : [ADH]UPDUSR    = GUSER                                      : Endif
            If dim([ADH]UPDDATTIM)>0 : [ADH]UPDDATTIM = datetime$
              If dim([ADH]UPDDAT)>0  : [ADH]UPDDAT    = func SUBADC.DAT_DATETIME([ADH]UPDDATTIM)   : Endif
            Else
              If dim([ADH]UPDDAT)>0  : [ADH]UPDDAT    = date$                                      : Endif
              If dim([ADH]UPDTIM)>0  : [ADH]UPDTIM    = time                                       : Endif
            Endif
        Endif
    Endif
Return

# Renseignement des champs par défaut du document
$SET_ADO_VLD
  Gosub SET_ADO
  Gosub SET_VLD
Return
$SET_VLD
#VPO 11/01/08 41171 creation SET_VLD
  If [ADO]VLDDAT=[0/0/0] : [ADO]VLDDAT=date$ : Endif
  If [ADO]VLDFLG<>2 : [ADO]VLDFLG=2 : Endif
Return
$SET_ADO
  [ADO]TYP=COD_TYP
  [ADO]COD=CODE_DOC
  [ADO]LEV=[L]LEV
  [ADO]SUBLEV=[L]SUBLEV
  [ADO]PAR=PAR_DOC
  [ADO]LAN=[V]COD_LAN
  [ADO]MODULE=CODE_MODULE
  Raz [ADO]TIT,[ADH]TEXTE,[ADO]MSK,[ADO]STY,[ADO]CODACT,[ADO]VLDDAT
  [ADO]VLDFLG=1
  [ADH]=[ADO]
Return

#
#VPO 11/01/08 40090
$SET_ACTIV
If find([ADO]TYP,"AFC","ADP","ACT","AGB","ABF","ABM","ADC")<>0 & [ADO]CODACT<>"FAL" & [ADO]CODACT<>CODE_ACTIV & CODE_ACTIV<>""
   [ADO]CODACT=CODE_ACTIV
Endif
If find([ADO]TYP,"AFC","ADP","ACT","AGB","ABF","ABM","ADC")<>0 & [ADO]MODULE<>CODE_MODULE
   [ADO]MODULE=CODE_MODULE
Endif
Return

# Création du paragraphe de présentation
$CR_PRE
  PAR_DOC="PRE" : [L]LEV=10 : [L]SUBLEV=20
  Gosub TST_CREER
  If REGEN
    Raz TXT_PARAG : # On ne met plus "à renseigner" pour faciliter la traduction
#   TXT_PARAG="<p>"+func AGENADO.MST(148,142)+"</p>" : # "A renseigner"
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    [ADO]TIT=func AGENADO.MST(2,142) : # "Présentation"
    Setlob [ADH]TEXTE With TXT_PARAG(1..1)
    Write [ADH]
    Write [ADO]
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(2,142) : # "Présentation"
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif
Return

