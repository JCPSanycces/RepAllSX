# Pile des menus pour les sous-programmes
$PILE_ASUMEN
  IPIL=1
  PILE_MEN(IPIL)=""
  # JPGA 19/08/2009 Bug-52238 : Procedure de recherche pour savoir si on est en présence de clé multiples pour les docs "ASU"
  Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
  I = instr(1,[ADO]COD,[L]WTIRET)
  If find([ADO]TYP, [L]DOC_CLE_MULT) & I
    Read [ASU]ASU0=left$([ADO]COD,I-1);right$([ADO]COD,I+1)
    Read [ADC]ADC0=left$([ADO]COD,I-1)
    PILE_NOMEN(IPIL)=func AGENADO.RDM("ASU1","PRG")-left$([ADO]COD,I-1)+", "
&                   +func AGENADO.RDM("ASU1","SUBPRG")-right$([ADO]COD,I+1)
  Else
    Read [ASU]ASU0=[ADO]COD
    Read [ADC]ADC0=[ADO]COD
    PILE_NOMEN(IPIL)=func AGENADO.RDM("ASU1","PRG")-[ADO]COD
  Endif
  IPIL+=1
  PILE_MEN(IPIL)="ASU_"+num$([ADC]MODULE) : # Le menu intermédiaire s'appellera ADC_numéro
  PILE_NOMEN(IPIL)=func AGENADO.RDM("ATB1","MODULE")-func AGENADO.MST([ASU]MODULE,14) : # "Module"
$PILE0_ASUMEN
  IPIL+=1
  PILE_MEN(IPIL)="ASU_0": # Le menu intermédiaire s'appellera ADC_0
  PILE_NOMEN(IPIL)=func AGENADO.RDM("ASU1","") : # "Points d'entrée"
  IPIL+=1
Return

# Pile des menus pour les variables
$PILE_AGBMEN
  IPIL=1
  PILE_MEN(IPIL)=""
  Read [AGB]AGB0=[ADO]COD
  PILE_NOMEN(IPIL)=func AGENADO.RDM("AGB1","CODVAR")-[ADO]COD
  IPIL+=1
  PILE_MEN(IPIL)="AGB_"+num$([AGB]MODULE) : # Le menu intermédiaire s'appellera AGB_numéro
  PILE_NOMEN(IPIL)=func AGENADO.RDM("AGB1","MODULE")-func AGENADO.MST([AGB]MODULE,14) : # "Module"
$PILE0_AGBMEN
  IPIL+=1
  PILE_MEN(IPIL)="AGB_0": # Le menu intermédiaire s'appellera AGB_0
  PILE_NOMEN(IPIL)=func AGENADO.RDM("AGB1","") : # "Variables globales"
  IPIL+=1
Return

# Pile des menus pour les types
$PILE_ATYMEN
  IPIL=1
  PILE_MEN(IPIL)=""
  Read [ATY]CODTYP=[ADO]COD
  PILE_NOMEN(IPIL)=func AGENADO.RDM('ATY1','CODTYP')-[ADO]COD-"("+func AGENADO.RDT([ATY]INTITTYP)+")" : # "Type"
  IPIL+=1
  PILE_MEN(IPIL)="ATY_"+num$([ATY]MODULE) : # Le menu intermédiaire s'appellera ATY_numéro
  PILE_NOMEN(IPIL)=func AGENADO.MST(58,105)-func AGENADO.MST([ATY]MODULE,14) : # "Module"
$PILE0_ATYMEN
  IPIL+=1
  PILE_MEN(IPIL)="ATY_0": # Le menu intermédiaire s'appellera ATY_0
  Read [AF1]CODINT="GESATY"
  PILE_NOMEN(IPIL)=func AGENADO.RDT([AF1]NOM) : # "Types de données"
  IPIL+=1
Return

#VPO 07/01/08 evol 45065
# Pile des menus pour menu du plan de paie
$PILE_PLAMEN
  IPIL=1
  If pat([ADO]COD,"???_0")=0
      PILE_MEN(IPIL)=""
      PILE_NOMEN(IPIL)=[ADO]TIT: # ici on a le titre
      IPIL+=1
  Endif
  #VPO 07/07/08 evol 48427 ajout par="LNK"
  If [ADO]COD<>"PLA_0"
        Read [AD1]ADO1=[ADO]LAN;[ADO]TYP;[ADO]COD;"LNK"
        If fstat=0
          # JPGA 29/03/2011 BUG-72715 : Ne pas générer les accents dans le nom des ficiers accédés par Href !
          CH2=[AD1]TIT  :  Gosub CORRIGE_PLA  From AGENADO
          PILE_MEN(IPIL)=left$([AD1]COD,3)+"_"+CH2+"_0" : # Le menu intermédiaire s'appellera XXX_0
          PILE_NOMEN(IPIL)=[AD1]TIT: # ici on a le titre
          IPIL+=1
        Endif
  Endif
  If [ADO]COD<>"PLA_0"
      PILE_MEN(IPIL)=left$([ADO]COD,3)+"_0" : # Le menu intermédiaire s'appellera XXX_0
      Read [AOB]ABREV=left$([ADO]COD,3)
      PILE_NOMEN(IPIL)=func AGENADO.RDT([AOB]LIBEL): # ici on a le titre
      IPIL+=1
  Endif
  PILE_MEN(IPIL)="PLA_0": # Le menu intermédiaire s'appellera PLA_0
  # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
  PILE_NOMEN(IPIL)=func AGENLIBA.RECH_DESIGNATION('ADI', '910', 'PLA') : # "PLAN de paie"
  IPIL+=1
Return

# Pile des menus par défaut
# On recherche s'il existe une documentation nommée INDEX de même type que la doc d'origine
# Si c'est le cas, çà constitue la pile
# L'enregistrement courant est le titre de la doc
$PILE_DEFMEN
  IPIL=1
  PILE_MEN(IPIL)=""
  PILE_NOMEN(IPIL)=[AD1]TIT
  IPIL+=1
  Read [AD1]ADO1=[ADO]LAN;[ADO]TYP;"INDEX";"TIT"
  If fstat=0
    PILE_MEN(IPIL)="INDEX"
    PILE_NOMEN(IPIL)=[AD1]TIT
    IPIL+=1
  Endif
Return

# Pile des menus trouvée dans un paragraphe LNK (table AD1)
$PILE_MENLNK
  IPIL=1
  PILE_MEN(IPIL)=""
  If [AD1]TIT<>""
      PILE_NOMEN(IPIL)=[AD1]TIT
  Else
        PILE_NOMEN(1)=TITRED
  Endif
  IPIL+=1

# On remplit le tableau des liens (VALEURS(1..II-1))
  Read [ADH]ADH0=[AD1]LAN;[AD1]TYP;[AD1]COD;[AD1]LEV;[AD1]SUBLEV
  If fstat=0
    Setlob TEXTES With [ADH]TEXTE
  Else
    Read [ADH2]ADH0=[AD1]LAN;[AD1]TYP;[AD1]COD;[AD1]LEV;[AD1]SUBLEV
    If fstat=0
        Setlob TEXTES With [ADH2]TEXTE
    Else
        Raz TEXTES
    Endif
  Endif

  Gosub RECHLNK From AGENADO
  For KK=1 To II-1
    JJ=instr(1,VALEURS(KK),"/")
    LL=instr(1,VALEURS(KK),"#")
    If LL
        CHAINE=right$(VALEURS(KK),LL)
        VALEURS(KK)=left$(VALEURS(KK),LL-1)
    Else
        CHAINE=""
    Endif
    If JJ
        Read [AD1]ADO1=[ADO]LAN;left$(VALEURS(KK),JJ-1);right$(VALEURS(KK),JJ+1);"TIT"
    Else
        Read [AD1]ADO1=[ADO]LAN;'AFC';VALEURS(KK);"TIT"
    Endif
    If fstat=0
        CH1=[AD1]TYP : CH2=[AD1]COD : CH3=""
        If [AD1]TYP="ADP" : Read [ADP]ADP1=[AD1]COD : CH3="ADP_"+[ADP]CHAPITRE : Endif
        Gosub REP_NOM_FIC From AGENADO
        PILE_MEN(IPIL)="../"+CH4+"/"+CH5
        PILE_NOMEN(IPIL)=[AD1]TIT
        IPIL+=1
    Endif
  Next KK
Return

# Recherche de l'utilisation de la fonction
# Lorsque la fonction n'est pas dans un menu, on essaie de trouver où elle peut être branchée
#
$REC_FNC

# VPO 09/06/08 bug47517
If [AFC]ACTION="" : Return : Endif

# On définit la requête qui permettra de retrouver les fenêtres utilisant l'action associée
  If [AFC]ACTION="GOBJET"
      Link [AWP] With [AWT]AWT0(2)=[AWP]WIN;[AWP]NUM As [AZZ]
&                Where [AWP]NOPAR=2
&                    & pat([AWT]ACTBOUT,"GOBJET*")<>0 & [AWP]VALEUR=[AFC]VALPAR(0)& [AWP]WIN<"W"
  Else
      Link [AWT] With [AWI]AWI0=[AWT]WIN
&       As [AZZ] Where [AWT]ACTBOUT=[AFC]ACTION & [AWT]WIN<"W"
  Endif

  For [AZZ]
    # La fenêtre est-elle associée à un objet ?
    If pat([AWT]WIN,"O???")
        Read [AFC]CODINT="GES"+right$([AWT]WIN,2)
        If fstat=0
            CODOBJ=right$([AWT]WIN,2)
            Break
        Endif
    Else
        # On recherche une consultation
        For [ACN] Where WND1=[AWT]WIN or WND0=[AWT]WIN
            Read [AFC]CODINT="CONS"+[ACN]COD
            If fstat<>0
                Raz [AFC]
            Else
                CONDCON=[ACN]COD
            Endif
        Next

        # On recherche une autre fonction
        Link [AFC] With [ACT]ACTION=[AFC]ACTION
&         As [AZC] Where left$([AFC]CODINT,3)<>"GES" and left$([AFC]CODINT,4)<>"CONS"
        For [AZC] Where [ACT]PARAM2=[AWI]WIN or [ACT]PARAM4=[AWI]WIN
            Break 2
        Next
    Endif
  Next

Return

Subprog MAJ_LIENS(TEXT,TYP,REP,ERR,ERRMS,TEXTE1,IMOD)
Variable Clbfile TEXT
Value Char REP,TYP
Variable Char ERRMS
Variable Integer ERR
Variable Char TEXTE1()(1..)
Variable Integer IMOD
Local Char TEXTE(250)(1..1000)
Local Char LIEN(100),NOMD(100)
Local Integer II,JJ,IEXIST,NBER
Local Char REPCTL,TPDO(250)
  Setlob TEXTE With TEXT
  ERRMS="" : NBER=0
  Call FILTRE_DOCS(TEXTE,TEXTE1)
  II=1
  While TEXTE1(II)<>""
    If pat(toupper(vireblc(TEXTE1(II),5)),'<A HREF="*">*')
        TEXTE1(II)=vireblc(TEXTE1(II),5)
        LIEN=seg$(TEXTE1(II),instr(1,TEXTE1(II),'"')+1,instr(1,TEXTE1(II),'">')-1)

# Corrections automatiques de liens
        If instr(1,LIEN,"\")
            LIEN=ctrans(LIEN,"\","/")
            IMOD=1
        Endif
        If pat(LIEN,"APE_*")
            LIEN="ADC_"+right$(LIEN,5)
            IMOD=1
        Endif

        TEXTE1(II)=right$(TEXTE1(II),instr(1,TEXTE1(II),'">')+1)
        If pat(LIEN,"./*")
            LIEN=right$(LIEN,3)
            REPCTL=REP
            Gosub CTLIEN
        Elsif (ascii(toupper(LIEN))>=65 and ascii(toupper(LIEN))<=90)
            REPCTL=REP
            Gosub CTLIEN
        Elsif pat(LIEN,"../*")
            LIEN=right$(LIEN,4)
            If pat(LIEN,"*/*")
                JJ=instr(1,LIEN,"/")
                REPCTL=toupper(left$(LIEN,JJ-1))
                LIEN=right$(LIEN,JJ+1)
                Gosub CTLIEN
            Endif
        Endif
    Endif
    II+=1
  Wend
  If NBER<>0
    ERRMS+=string$(NBER>1," and "+num$(NBER-1)+" other error"+string$(NBER>2,"s"))
    ERR=3
  Endif
End

# Vérification d'existence (limitée) du lien
# REPCTL est le répertoire où çà devrait être
# LIEN est le lien
# NBER donne le compte des erreurs
# ERRMS donne le premier message
$CTLIEN

  TEXTE1(II)='<A href="../'+REPCTL+'/'+LIEN+'"'+TEXTE1(II)
  IMOD=1
  NOMD=vireblc(ctrans(LIEN,".#","  "),3)
  IEXIST=0

  Case REPCTL
    When "FCT"
        TPDO='TYP="DI" or TYP="AFC"'
    When "OBJ"
        TPDO='len(TYP)=3 and TYP<>"AFC"'
        While instr(1,NOMD,"_")
            NOMD=right$(NOMD,instr(1,NOMD,"_")+1)
        Wend
    When "FLD"
        TPDO=""
    When "MCD"
        #VPO 19/06/08 39766 ajout ATD: différences de tables
        #VPO 27/10/08 49955 ajout AT3: différences de tables 130
        TPDO='TYP="ATD" or TYP="AT3" or TYP="ATB" or TYP="ATY" or TYP="AML"'
  Endcase

  If TPDO<>""
    If clalev([ADO2])=0 : Local File ADOCUMENT [ADO2] : Endif
    For [ADO2] Where LAN=[M]LAN and evalue(TPDO) and COD=NOMD and PAR="TIT"
        IEXIST=1 : Break
    Next
  Elsif REPCTL="FLD"
    If clalev([ADZ3])=0 : Local File ADOCFLD [ADZ3] : Endif
    For [ADZ3] Where LAN=[M]LAN and MOTCLE=NOMD
        IEXIST=1 : Break
    Next
    #VPO 14/02/08 BUG45947
    DOSSUP=func AFNC.PARAM('SUPDOS','')
    #VPO 04/01/08 BUG44500
    If clalev([ADZ5])=0 : Local File =DOSSUP+".ADOCFLD" [ADZ5] : Endif
    For [ADZ5] Where LAN=[M]LAN and MOTCLE=NOMD
        IEXIST=1 : Break
    Next
  Else
    Return
  Endif

  If IEXIST=0
    NBER+=1
    If NBER=1
        ERRMS="Problem on the following link :"-NOMD
    Endif
  Endif
Return

# Copie TEXT dans TEXT1 en se synchronisant sur les liens hyper-textes
Subprog FILTRE_DOCS(TEXT,TEXT1)
Variable Char TEXT()(1..)
Variable Char TEXT1()(1..)
Local Char CHAINE(255),ORICHAINE(255)
Local Integer II,JJ,KK,LL,MM

  KK=type(TEXT1)-25 : # Sécurité
  II=1 : LL=1
  ORICHAINE=TEXT(II)
  While ORICHAINE<>""
    JJ=instr(2,ORICHAINE,"<")
    If JJ
        CHAINE=left$(ORICHAINE,JJ-1)
        ORICHAINE=right$(ORICHAINE,JJ)
    Else
        CHAINE=ORICHAINE
        JJ=len(CHAINE)
        II+=1
        ORICHAINE=TEXT(II)
        If len(CHAINE)<KK
            MM=instr(1,ORICHAINE,"<")
            MM+=(MM=0)*len(ORICHAINE)
            MM=max(0,min(MM-1,KK-len(CHAINE)))
            CHAINE+=left$(ORICHAINE,MM)
            ORICHAINE=right$(ORICHAINE,MM+1)
        Endif
    Endif
    While JJ>KK
        TEXT1(LL)=left$(CHAINE,KK)
        LL+=1
        CHAINE=right$(CHAINE,KK+1)
        JJ-=KK
    Wend
    If CHAINE<>""
        TEXT1(LL)=CHAINE
        LL+=1
    Endif
  Wend
End

######################################################################################
# On teste l'existence du sous-répertoire si on ne l'a pas déjà testé (optimisation)
$TEST_SOUS_REPERT

  # On retrouve le sous-répertoire à partir du nom de fichier
  MM=instr(1,FICOUV,SLASH)
  NN=instr(MM,FICOUV,SLASH)
  While NN
    MM=NN
    NN=instr(NN+1,FICOUV,SLASH)
  Wend
  ORSY=left$(FICOUV,MM-1)

  # S'il n'a pas déjà été testé, on teste son existence
  If find(ORSY,REPTST(1..NB_REPTST))=0
    If NB_REPTST<dim(REPTST)
        NB_REPTST+=1 : REPTST(NB_REPTST)=ORSY
    Endif

    # S'il n'existe pas, on le crée
    Local Integer EXISTE : EXISTE=1
    If filinfo(ORSY,0)<0
        EXISTE=0
#       Errbox "Le répertoire"-ORSY-"doit être créé"
        MM = instr(1,ORSY,"@")
        If MM
            MACHI=left$(ORSY,MM-1)
            ORSY = 'ae_mkdir'-'"'+right$(ORSY,MM+1)+'"'
        Else
            MACHI=""
            ORSY = 'ae_mkdir'-'"'+ORSY+'"'
        Endif
        Call SYSTEME(MACHI,ORSY,"",MM) From ORDSYS
    Endif
  Endif
Return

# Elimination des codes activité superviseur s'il en existe
# (correction faite pour que çà marche sur tous les dossiers et pas que sur SUPERV)
$ELIMINE_ACV
 CHAINE="(VALEURS(I2)<>'FAL')"+string$(dim([ACV3]FLGSUP)>0,"& ([ACV3]FLGSUP<>2)")
 Local Integer I1,I2
 I2=1
 For I1=1 To II
   Read [ACV3]CODACT=VALEURS(I1)
   VALEURS(I2)=VALEURS(I1)
   I2+=evalue(CHAINE)
 Next I1
 II=I2-1
Return

#
# Verrue rajoutée après coup
#
# Dans le superviseur uniquement,
# si un masque existe dans la classe [ADO], on vérifie si le module correspondant au masque est le même
# Sinon c'est le masque qui l'emporte en général...
# avec un transcodage de "Spécial produit" en "Interne superviseur"
#
$VERIF_MODULE
 If GPRODUIT=-1 : # Superviseur
    If clalev([AMK1])=0 : Local File AMSK [AMK1] : Endif
    Read [AMK1]CODMSK=[ADO]MSK
    If fstat=0
        If [ADO]MODULE<>[AMK1]MODULE
            [ADO]MODULE=[AMK]MODULE
            If [ADO]MODULE=10
                [ADO]MODULE=2
            Endif
        Endif
    Endif
 Endif
Return
# On récupère la liste des codes boutons du dictionnaire
# Inspiré d'un code standard
#
Subprog OWRK(TEXT,OBJET,NBT)
Variable Char TEXT()(1..)
Value Char OBJET()
Variable Integer NBT
Local Char FEN(20),DIVTXT(200)
Raz TEXT

  # Opérations standard possibles sur GOBJET
  NBT += 1 : TEXT(NBT) = "C"+mess(59,123,1)  : # Création
  NBT += 1 : TEXT(NBT) = "M"+mess(60,123,1)  : # Modif
  NBT += 1 : TEXT(NBT) = "A"+mess(53,123,1)  : # Suppression
  NBT += 1 : TEXT(NBT) = "H"+mess(2,115,1)   : # Changement de code
  NBT += 1 : TEXT(NBT) = "E"+mess(61,123,1)  : # Impression
  NBT += 1 : TEXT(NBT) = "L"+mess(137,124,1) : # Liste
  NBT += 1 : TEXT(NBT) = "W"+mess(206,123,1) : # Bouton Workflow

  If OBJET<>""
    # Recherche fenêtre principale d'un objet
    Filter [AWI] Where OBJ=OBJET
    Read [AWI]AWI0 = "O"+OBJET
    If !fstat
        FEN = [F:AWI]WIN
    Else
        For [AWI]
            FEN = [F:AWI]WIN : Break
        Next AWI
    Endif
    Filter [AWI]
    If FEN<>""
        # Boutons/menus possibles dans la fenêtre de l'objet
        For [AWT] Where WIN=FEN & find(TYPBOUT,1,3)
            NBT += 1
            TEXT(NBT) = right$([F:AWT]CODBOUT,len([F:AWT]CODBOUT))
            If [F:AWT]TYPBOUT=3
                For I=1 To len([F:AWT]CODBOUT)-1
                    For [AWT2] Where WIN=FEN & TYPBOUT=2 & CODBOUT=left$([F:AWT]CODBOUT,I)
                        Call TEXTE([F:AWT2]TXTBOUT,DIVTXT) From OBJDIV
                        TEXT(NBT)+=string$(len(TEXT(NBT))>1,"/")+DIVTXT
                    Next AWT2
                Next I
            Endif
            Call TEXTE([F:AWT]TXTBOUT,DIVTXT) From OBJDIV
            TEXT(NBT)+=string$(len(TEXT(NBT))>1,"/")+DIVTXT
        Next
    Endif
  Endif
End

# Lecture du texte dans TEXTE à partir de [ADO]
# TEXBASE=0 (pas de texte), 1 (texte dans ADH), 2 (texte dans ADH2)
$LEC_ADO
  Read [ADH]ADH0=[ADO]LAN;[ADO]TYP;[ADO]COD;[ADO]LEV;[ADO]SUBLEV
  If fstat=0
      Setlob TEXTES With [ADH]TEXTE
      TEXBASE=vireblc(TEXTES(1),4)<>""

  Else
      Read [ADH2]ADH0=[ADO]LAN;[ADO]TYP;[ADO]COD;[ADO]LEV;[ADO]SUBLEV
      If fstat=0
          Setlob TEXTES With [ADH2]TEXTE
          TEXBASE=2*(vireblc(TEXTES(1),4)<>"")
      Else
          Raz TEXTES,TEXBASE
      Endif
  Endif
Return

$LEC_WR_ADO
  Gosub LEC_ADO
$WR_TEX
  If TEXBASE=1
    Wrseq [ADH]TEXTE Using [DOC]
  Elsif TEXBASE=2
    Wrseq [ADH2]TEXTE Using [DOC]
  Endif
Return

# Lecture du texte dans TEXTE à partir de [AD1]
# TEXBASE=0 (pas de texte), 1 (texte dans ADH), 2 (texte dans ADH2)
$LEC_AD1
  Read [ADH]ADH0=[AD1]LAN;[AD1]TYP;[AD1]COD;[AD1]LEV;[AD1]SUBLEV
  If fstat=0
      Setlob TEXTES With [ADH]TEXTE
      TEXBASE=vireblc(TEXTES(1),4)<>""

  Else
      Read [ADH2]ADH0=[AD1]LAN;[AD1]TYP;[AD1]COD;[AD1]LEV;[AD1]SUBLEV
      If fstat=0
          Setlob TEXTES With [ADH2]TEXTE
          TEXBASE=2*(vireblc(TEXTES(1),4)<>"")
      Else
          Raz TEXTES,TEXBASE
      Endif
  Endif
Return
# On met dans les variables I_TYP, I_LEV, I_SUBLEV les composantes de clé
# du paragraphe correspondant à une inclusion si elle existe
# Le texte de l'inclusion est dans TEXTES(1)

$RECH_INCL
 If TEXTES(1)<>""
    II=instr(1,toupper(TEXTES(1)),"<P>")
    If II
        TEXTES(1)=right$(TEXTES(1),II+3)
    Endif
    II=instr(1,toupper(TEXTES(1)),"</P>")
    If II
        TEXTES(1)=left$(TEXTES(1),II-1)
    Endif
    TEXTES(1)=vireblc(TEXTES(1),4)
    fstat=0
    If pat(TEXTES(1),"?*/?*")
        TEXTES(1)=ctrans(TEXTES(1),"/"," ")
        I_TYP=vireblc(TEXTES(1),3)
        TEXTES(1)=right$(TEXTES(1),len(I_TYP)+2)
        I_COD=vireblc(TEXTES(1),3)
        TEXTES(1)=right$(TEXTES(1),len(I_COD)+2)
        If pat(TEXTES(1),"#* #*")
            I_LEV=val(vireblc(TEXTES(1),3))
            TEXTES(1)=right$(TEXTES(1),len(vireblc(TEXTES(1),3))+2)
            I_SUBLEV=val(TEXTES(1))
        Endif
    Else
        fstat=1
    Endif
  Else
    fstat=1
  Endif
Return

$REPERT_LAN
  If dim(GDIRDOC)>0
   REPERT_DOC = GDIRDOC
  Else
   REPERT_DOC = ""
  Endif
  Gosub REMPLACE_POURCENT From AGENDOCA
Return

$REMPLACE_POURCENT
  II=instr(1,REPERT_DOC,"%")
  If II
    #cg mai 2013 pour syracuse le code langue doit etre remplace par code iso ex fr-FR
    # on ne test plus la version v6  et/ou v5 car on ne copie plsu le trt de la v7 vers la v6
    # attention uniquement lors generation html les autres cas on garde comme avant
    # donc si la var n existe pas pas grave c'est juste pour extraction html
     #JPGA 2013/12/11 BUG-95146 : Activation Code-ISO en V7 + Changement caractère - en _
       If dim (GISO_COD_LAN) >= 0
            If GISO_COD_LAN <> ""
                REPERT_DOC=left$(REPERT_DOC,II-1)+GISO_COD_LAN+right$(REPERT_DOC,II+1)
           Else
                REPERT_DOC=left$(REPERT_DOC,II-1)+COD_LAN+right$(REPERT_DOC,II+1)
           Endif
       Else
           REPERT_DOC=left$(REPERT_DOC,II-1)+COD_LAN+right$(REPERT_DOC,II+1)
       Endif
  Else
    REPERT_DOC=REPERT_DOC
  Endif
  SLASH=string$(instr(1,REPERT_DOC,"\")=0,"/")+string$(instr(1,REPERT_DOC,"\")<>0,"\")
Return

# Recherche des tâches batch associées à une fonction
$ABT_AFC
  For [ABT] Where FONCTION=[AFC]CODINT
    II+=1 : VALEURS(II)=[ABT]CODTAC : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  Next
Return

# Recherche des fonctions appelant des états
$AFC_ARP
  MM=0
  For [ARX] Where EXTCOD=[ARP]RPTCOD
    MM=1
    For [AF1] Where RPT1=[ARX]INTCOD or RPT2=[ARX]INTCOD
      II+=1 : VALEURS(II)=[AF1]CODINT : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Next
  Next

  If MM=0
    For [AF1] Where RPT1=[ARP]RPTCOD or RPT2=[ARP]RPTCOD
      II+=1 : VALEURS(II)=[AF1]CODINT : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Next
  Endif
Return

# Recherche des tables utilisées par les états
$ATB_ARP
  For [ARO] Where RPTCOD=[ARP]RPTCOD
    II+=1 : VALEURS(II)=[ARO]TBL : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  Next
Return

# Recherche des tables utilisées par les événements déclenchants
$ATB_PS1
  For JJ=0 To [PS1]NBRTBL-1
    II+=1 : VALEURS(II)=[PS1]TBL(JJ) : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  Next JJ
Return

# Sous-programmes divers
# Pour créer des ancres en fonction du paragraphe
# Sert pour les paragraphes qui peuvent être multiples (MIS, BOU, BME, CTX, APE, BOT)
# et qui peuvent être référencés dans une table des matières...
Subprog ANCRE(NOMANCR,PAR,LEV,SUBLEV)
Variable Char NOMANCR()
Value Char PAR()
Value Integer LEV,SUBLEV

  If find(PAR,"MIS","BOU","BME","CTX","APE","BOT","INC","MIN")
    NOMANCR=PAR+"_"+num$(LEV)+"_"+num$(SUBLEV)
  Else
    NOMANCR=PAR
  Endif

End

# Pour remplacer les titres vides par des titres génériques en fonction du paragraphe
# A généraliser à terme
Subprog TITANC(PAR,TIT)
Variable Char PAR(),TIT()
If TIT=""
    Case PAR
        When "PRD" : TIT=func AGENADO.MST(126,142)
    Endcase
Endif
End

# Ecriture de l'introduction
$WR_INTRO
  Wrseq '    <div id="intro">' Using [DOC]
  Wrseq '      <div id="presentation">' Using [DOC]
  Wrseq '        <p class="p1"><span></span></p>' Using [DOC]
  II=1
Return

# Analyse de l'écran pour intégrer les aides en ligne
$ANAMSK

  Raz TITRE_BLOC, BLOC_CHAMP, CHAMPS_ECR, HELP_CHAMP, INT_CHAMP, TYPE_CHAMP, TYPE_BLOC, UNAFF_CHAMP

# Compte du nombre de blocs tableaux et de nombre de blocs visibles
  NBT=sigma(1,[AMK]NBBLOC,[AMK]TYPBLOC(indcum-1)=1)
  NBB=sigma(1,[AMK]NBBLOC,[AMK]TYPBLOC(indcum-1)<>5)

# Exploration des blocs (JJ=rang courant du nombre de tableaux, KK=rang courant du nombre de blocs)
  Raz JJ,KK

  For II=1 To [AMK]NBBLOC
    If [AMK]TYPBLOC(II-1)=1 : # Bloc tableau
        JJ+=1
        For [AMZ]CODZON Where CODMSK=[AMK]CODMSK and [AMZ]NUMBLOC=II and [AMZ]CODTYP="ABS"
            If [AMZ]SAIAFF=3
                [AMK]TYPBLOC(II-1)=5 : # c'est un bloc tableau dont la variable de bas de tableau est invisible
                NBT-=1 :  NBB-=1       # On ne le considère plus comme un bloc tableau, mais comme un bloc invisible
                JJ-=1
                Break
            Endif
        Next
    Endif

    If [AMK]TYPBLOC(II-1)=5
        # TITRE_BLOC(II)=""
    Else
        KK+=1
        TYPE_BLOC(KK)=[AMK]TYPBLOC(II-1)
        ONG_BLOC(KK) =[AMK]POSBLOC(II-1)
        ONG_NO_2(KK) =II-sigma(0,II-1,[AMK]TYPBLOC(indcum)=5) : # ne pas prendre en comptes les invisibles : on décale les indices

        If [AMK]TITBLOC(II-1)=0
           If NBB=1
               TITRE_BLOC(KK)="!" : # Ne rien afficher
           Else
               If [AMK]TYPBLOC(II-1)=1
                  If NBT=1 : # Un seul tableau
                     TITRE_BLOC(KK)=" ": # func MST(133,142) : # Tableau
                  Else
                     TITRE_BLOC(KK)=num$(JJ) : # func MST(132,142)-num$(JJ) : # Tableau i
                  Endif
               Else
                  TITRE_BLOC(KK)=func AGENADO.MST(12,142)-num$(KK) : # Bloc numéro
               Endif
           Endif
        Else
           TITRE_BLOC(KK)=func AGENADO.RDT([AMK]TITBLOC(II-1))
        Endif
    Endif
Next II

Raz NB_CHAMP,II
  # Issue 75246/7 - 2012-07-19 by VPO :  mot clé d'aide
  Link [AMZ] With [AMC]AMC0=2;[AMZ]CODMSK;[AMZ]CODZON As [AMCZ] Where CODMSK=[AMK]CODMSK Order By Key CODZON
  #For [AMZ]CODZON Where CODMSK=[AMK]CODMSK
  For [AMCZ]
    II+=1
    If [AMZ]SAIAFF<=2 and [AMK]TYPBLOC([AMZ]NUMBLOC-1)<>5: # Seuls les champs saisis ou affichés sont vus
        CHAMPS_ECR(II)=[AMZ]CODZON
        BLOC_CHAMP(II)=[AMZ]NUMBLOC-sigma(0,[AMZ]NUMBLOC-2,[AMK]TYPBLOC(indcum)=5) : # décalage
        NB_CHAMP=max(NB_CHAMP,II)
        #HELP_CHAMP(II)=[AMZ]MOTCLE
        HELP_CHAMP(II)=[AMC]MOTCLE
        UNAFF_CHAMP(II)=[AMC]UNAFFHTM
        INT_CHAMP(II)=string$([AMZ]INTIT<>0,func AGENADO.RDT([AMZ]INTIT))
        Read [ATY]CODTYP=[AMZ]CODTYP
        If [ATY]OBJLIEN<>""
            TYPE_CHAMP(II)=[ATY]OBJLIEN
        Elsif find([ATY]CODTYP,"ABS","W") : # Pour filtrer les variables de bas de tableau et de cadrage
            TYPE_CHAMP(II)=[ATY]CODTYP
        Endif
    Endif
  Next
Return

###################################################################
Subprog GRISE_GENFIN(PAR)
Value Integer    PAR()
   If PAR > 1
     # Génération HTML Complère ou selon Code Activité
     Actzo [M]HLPLNKFLD, HLPFLD, HLPVLD, HLPDEB, HLPFIN
   Else
     # Pas de Génération HTML
     Grizo [M]HLPLNKFLD, HLPFLD, HLPVLD, HLPDEB, HLPFIN
     Effzo [M]HLPLNKFLD, HLPFLD, HLPVLD, HLPDEB, HLPFIN
   Endif
End

