# Pile des menus pour les sections par défaut
$PILE_CDEMEN
  IPIL=1
  PILE_MEN(IPIL)=""
  # JPGA 19/08/2009 Bug-52238 : Procedure de recherche pour savoir si on est en présence de clé multiples pour les docs "CDE"
  Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
  I = instr(1,[ADO]COD,[L]WTIRET)
  If find([ADO]TYP, [L]DOC_CLE_MULT) & I
    Read [CDE]CDE0=left$([ADO]COD,I-1);right$([ADO]COD,I+1)
    # JPGA 01/10/2010 Bug-67364 : Affichage en + de la Société
    PILE_NOMEN(IPIL)=func AGENADO.RDM("CDE0","COD")-left$([ADO]COD,I-1)+", "
&                   +string$(right$([ADO]COD,I+1)="", func AGENADO.MST(145,139))
&                   +string$(right$([ADO]COD,I+1)<>"",func AGENADO.RDM("CDE0","CPY")-right$([ADO]COD,I+1))
  Else
    Read [CDE]CDE0=[ADO]COD
    PILE_NOMEN(IPIL)=func AGENADO.RDM("CDE0","COD")-[ADO]COD
  Endif
  # JPGA 01/10/2010 Bug-67364 : Affichage en + de la Société au niveau de la barre de navigation du sommaire
  IPIL+=1
  PILE_MEN(IPIL)="CDE_"+num$([ADO]MODULE) : # Le menu intermédiaire s'appellera CDE_numéro
  PILE_NOMEN(IPIL)=func AGENADO.RDM("ATB1","MODULE")-func AGENADO.MST([ADO]MODULE,14) : # "Module"
$PILE0_CDEMEN
  IPIL+=1
  PILE_MEN(IPIL)="CDE_0": # Le menu intermédiaire s'appellera CDE_0
  PILE_NOMEN(IPIL)=func AGENADO.MST(23,142) : # "Sections par défaut"
  IPIL+=1
Return

