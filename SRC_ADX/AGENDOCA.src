#<AdxTL>@(#)4.0.0.0 $Revision$
###################################################################
# AGENDOCA
###################################################################
# Génération automatique du squelette de l'aide
# dans la table ADOCUMENT, à partir du dictionnaire étendu de l'objet
#
# AGENDOC splitté en 2 AGENDOC et AGENDOCA à partir v7 car limite atteinte
###################################################################
$INIT
If adxmto<150
 adxmto=150
Endif

Local Mask AGENDOC [DIA]
Raz [M:DIA]
[M:DIA]LAN     = GLANGUE
If PARAM(3)<>"" : ## VPO 26/09/07 BUG43186
    [M:DIA]LAN = PARAM(3)
Endif
[M:DIA]ALLTYP  = 1
[M:DIA]TYPEDOC = PARAM(1)
[M:DIA]FUNDEB  = PARAM(2)
If GABREV="ADO"
 [M:DIA]GENDOC = 1 : # Non
 If adxmother=nomap
  [M:DIA]GENFIN = 2 : # Complète
 Else
  [M:DIA]GENFIN = 3 : # Selon code activité
 Endif
Else
 [M:DIA]GENDOC = 2 : # Toutes
 [M:DIA]GENFIN = 1 : # Non
Endif

# JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Call INIT_ALLCREGRP("[M:DIA]ALLCREGRP") From AGENLIBA
# JPGA 09/04/2010 Bug-51883 : Appel à la procédure de recherche du Répertoire xml d'extraction
Call INIT_REPERT_LAN([M:DIA]REPERT,"html") From AGENLIBA
Return

###################################################################
$CONTROLE
Return

###################################################################
$FERME
# cg mai  2013
# il faut killer var globales crée via prog
# aucun var global dans doc n est kille
# MAIS là il faut virer la globale du code iso
Gosub FERME_KILL From AGENLIBA
Return

###################################################################
$FIN
# cg mai  2013
# en fct d ou on vient et de ce que l on fait dans doc...
# il faut remettre vide la var globale des codes iso
If dim (GISO_COD_LAN) >=0
    GISO_COD_LAN =  ""
Endif
Return


######################################################################################

$CONT
Local Char MACHINE(250) , REPERT(GDIMFIC) , OS(30)
Local Integer ER

  If REPDOC=""
    Call ERREUR(mess(86,133,1)) From GESECRAN                     :  # Répertoire inaccessible
    FIN = 1 : Return
  Endif

  #JPGA 29/01/2013 EXI-79844-97 : En BATCH : le controle de répertoire part en Boucle infinie en Toutes langues : Test à faire avant GET_OS
  If GBROWS | GSERVEUR  :  # En mode BATCH ou WEB : pas de répertoire local permis !!!
    If left$(REPDOC,1)="#"
      Call ERREUR("|"+REPDOC+"|\"+mess(162,141,1)) From GESECRAN  :  # Le répertoire doit être indiqué sur un serveur
      FIN = 1 : Return
    Endif
  Endif

  Call MACHINE(REPDOC,MACHINE,[L]REPERT) From ORDSYS
  Call GET_OS(MACHINE,OS) From ORDSYS
  If OS=""
    Call ERREUR(MACHINE-mess(90,141,1)) From GESECRAN             : # Machine inexistante
    FIN = 1 : Return
  Endif
  If OS<>"unix" & left$([L]REPERT,1)="/"
    Call ERREUR("|"+REPDOC+"|\"+mess(147,141,1)) From GESECRAN    : # Répertoire inaccessible
    FIN = 1 : Return
  Endif

  #JPGA 09/04/2010 BUG-51883 controle pour savoir si le répertoire est accessible ou nom par creation d'un fichier qui est supprimé ensuite.
  #JPGA 13/10/2010 BUG-68216 : Génération HTML "Toutes Langues" sur serveur Unix : Vérification/Création par langue à faire
  Local Integer DOC_CODERET
  Call CONTROLE_REPERTOIRE(REPDOC, [V]COD_LAN, [L]DOC_CODERET, 1) From AGENLIBA
  If [L]DOC_CODERET
    Call ERREUR("|"+REPDOC+"|\"+mess(203,139,1)) From GESECRAN    : # Répertoire non autorisé
    FIN = 1 : Return
  Endif
Return

###################################################################
$VERDOC
  Gosub VERDOC From AGENDOC
Return

###################################################################
# La fonction de génération à proprement parler
# Appelée depuis le bouton Génération (de gestion des objets documentables)
$EXEC
 Local Char FONC_COUR(30)

# Variables communes à AGENADO et AGENDOC
# a mettre avant la declaration des tables
  Gosub DECL_COMVAR    From AGENLIBA

# Tables à utiliser
  Gosub DECLARE_TABLES From AGENLIBA

# cg apres ouverture des tables
# Affectation des variables de génération
  Gosub GENE_ADOCUMENT_CHAMPS

# Déclaration des variables de travail
  Gosub DECL_VARTRA    From AGENLIBA

# Sauvegarde de la fonction courante
  If [AFC]CODINT<>""
    FONC_COUR=[AFC]CODINT
  Endif

# Ici on appelle soit une fois la boucle, soit N fois (une fois par type)
  Gosub GENERATION
Return

###################################################################
# Renseignement des champs nécessaire au process de Génération
$GENE_ADOCUMENT_CHAMPS
  [V]COD_LAN=[DIA]LAN
  # cg mai 2013 pour init code iso
  # code iso doit etre en phase avec la var globale COD_LAN
  Gosub INIT_COD_ISO
  #
  COD_TYP=[M:DIA]TYPEDOC
  DOC_DEB=[M:DIA]FUNDEB
  DOC_FIN=[M:DIA]FUNFIN
  ALL_TYP=[M:DIA]ALLTYP
  ALL_LAN=[M:DIA]ALLLAN
  GEN_DOC=[M:DIA]GENDOC
  GEN_FIN=[M:DIA]GENFIN
  HLP_FLD=[M:DIA]HLPFLD
  HLP_DEB=[M:DIA]HLPDEB
  HLP_FIN=[M:DIA]HLPFIN
Return

$INIT_COD_ISO
  # cg nouveau code pour code iso generation doc
  # on init le code iso en fct du code langue
  # recuperation du code iso dans table des langues et si n existe pas en dur
     #JPGA 2013/12/11 BUG-95146 : Activation Code-ISO en V7 + Changement caractère - en _
     # SI025 TCH 88553_3 : Code Iso _ remplacé par -
     If dim (GISO_COD_LAN) >= 0
          # test de existence de tla pour ne pas planter
          If dim ([F:TLA]LANISO) >= 0
              Read [TLA]TLA0=[V]COD_LAN
              If fstat=0 and [F:TLA]LANISO<>"" and len([F:TLA]LANISO)>=3
                  GISO_COD_LAN=ctrans([F:TLA]LANISO,"_","-")
              Else
                  # cas ou le code iso dans langue n est pas renseigné
                  # au moins pour nos langues std
                  Case [V]COD_LAN
                     When "FRA" : GISO_COD_LAN="fr-FR"
                     When "ENG" : GISO_COD_LAN="en-US"
                     When "BRI" : GISO_COD_LAN="en-GB"
                     When "GER" : GISO_COD_LAN="de-DE"
                     When "ITA" : GISO_COD_LAN="it-IT"
                     When "POL" : GISO_COD_LAN="pl-PL"
                     When "POR" : GISO_COD_LAN="pt-PT"
                     When "RUS" : GISO_COD_LAN="ru-RU"
                     When "SPA" : GISO_COD_LAN="es-ES"
                     When "CHI" : GISO_COD_LAN="zh-CN"
                  Endcase
              Endif
           Else
              # cas ou on n a pas pu ouvrir la table des codes langues
              # au moins pour nos langues std
              Case [V]COD_LAN
                     When "FRA" : GISO_COD_LAN="fr-FR"
                     When "ENG" : GISO_COD_LAN="en-US"
                     When "BRI" : GISO_COD_LAN="en-GB"
                     When "GER" : GISO_COD_LAN="de-DE"
                     When "ITA" : GISO_COD_LAN="it-IT"
                     When "POL" : GISO_COD_LAN="pl-PL"
                     When "POR" : GISO_COD_LAN="pt-PT"
                     When "RUS" : GISO_COD_LAN="ru-RU"
                     When "SPA" : GISO_COD_LAN="es-ES"
                     When "CHI" : GISO_COD_LAN="zh-CN"
              Endcase
           Endif
    Endif
Return

###################################################################
# La fonction de génération (génération initiale et finale selon les choix faits)
$GENERATION
  If READONLY_MOD=0 : # On est dans le cas où la doc est locale, on peut donc générer la table ADOCUMENT
    If GEN_DOC>1
        Gosub GEN_ADOC
    Endif
  Endif
  If GEN_FIN>1
    Gosub GEN_DOCF From AGENADO
  Endif
Return

###################################################################
# Boucle de génération dans ADOCUMENT
# Correction : si tous types, il faut faire une boucle (uniquement jusqu'à "X")
$GEN_ADOC
  [V]NB_GEN_ADOC=0
  EVALTYP =string$(ALL_LAN=1,"LAN=[V]COD_LAN")
  EVALTYP+=string$(EVALTYP<>""," & ")+"LAN<>''"       : # JPGA 20/08/2012 BUG-84088 : Vérification Langue non Vide
  EVALTYP+=string$(EVALTYP="","1=1")

  #JPGA 18/03/2010 BUG-51973 : Prise en compte de la génération toutes Langues pour ADOCUMENT
  For [AD1]ADO0(1) Where evalue(EVALTYP)
     [V]COD_LAN=[AD1]LAN
     If ALL_TYP=2
        For B_ADI=1 To dim(ADITYP)
           COD_TYP=ADITYP(B_ADI)
           #VPO 09/01/07 38377 ligne déplacée après affectation COD_TYP
           DOC_DEB="" : DOC_FIN=string$(COD_TYP="AML","99999")+string$(COD_TYP<>"AML","X")
           Gosub GENT_ADOC
        Next B_ADI
     Else
        Gosub GENT_ADOC
     Endif
  Next

  # JPGA - 03/02/2009 - Bug-52221 : Si suppression d'objet, on ne savait pas que la génération ADOCUMENT ne traitait rien
  # CBO 2009.07.07 Bug-56218
  If [V]NB_GEN_ADOC = 0
     If GTRACE <> ""   # 0 "Objets traités dans ADOCUMENT"
        Call ECR_TRACE("* ADO"+":"+string$(ALL_LAN=1,[V]COD_LAN)+string$(ALL_LAN=2,"~")+"~"+COD_TYP+"~"+DOC_DEB-num$([V]NB_GEN_ADOC)-func AGENADO.MST(283,142),0) From GESECRAN
     Else
        Call   MESSAGE("* ADO"+":"+string$(ALL_LAN=1,[V]COD_LAN)+string$(ALL_LAN=2,"~")+"~"+COD_TYP+"~"+DOC_DEB-num$([V]NB_GEN_ADOC)-func AGENADO.MST(283,142))   From GESECRAN
     Endif
  Endif
Return

###################################################################
$GENT_ADOC
  Trbegin [ADO]

  Case COD_TYP
    When "AFC"
        For [AFC] Where CODINT>=DOC_DEB and CODINT<=DOC_FIN
            Gosub GENE_AFCDOC
        Next
    When "ADI"
        #VPO 30/06/08 48129 : ajout liste des tables diverses
        Gosub GENE_ADIDOC
    When "ADP"
        For [ADP]ADP1 Where PARAM>=DOC_DEB and PARAM<=DOC_FIN and MODIF=2
            Gosub GENE_ADPDOC
        Next
    When "ACT" : # On ne documente que les actions publiques (si le flag existe)
        If dim([ACT]PUBFLG)>0
            For [ACT]ACTION Where ACTION>=DOC_DEB and ACTION<=DOC_FIN and PUBFLG>1
                Gosub GENE_ACTDOC
            Next
        Else
            For [ACT]ACTION Where ACTION>=DOC_DEB and ACTION<=DOC_FIN
                Gosub GENE_ACTDOC
            Next
        Endif
    When "ACV" : # On ne documente pas les codes activités internes du superviseur
        If dim([ACV]FLGSUP)>0
            For [ACV]CODACT Where CODACT>=DOC_DEB and CODACT<=DOC_FIN and FLGSUP<>2 & DEP=1
                Gosub GENE_ACVDOC
            Next
        Else
            For [ACV]CODACT Where CODACT>=DOC_DEB and CODACT<=DOC_FIN & DEP=1
                Gosub GENE_ACVDOC
            Next
        Endif
    When "ADM"
        For [ADM]ADM0 Where COD>=DOC_DEB and COD<=DOC_FIN
            Gosub GENE_ADMDOC
        Next
    When "AOE"
        For [AOE]AOE0 Where EXT>=DOC_DEB and EXT<=DOC_FIN
            Gosub GENE_AOEDOC
        Next
    When "ARP"
        For [ARP]ARP0 Where RPTCOD>=DOC_DEB and RPTCOD<=DOC_FIN
            Gosub GENE_ARPDOC
        Next
    When "AWA"
        For [AWA]AWA0 Where CODE>=DOC_DEB and CODE<=DOC_FIN
            Gosub GENE_AWADOC
        Next
    When "CDE" : #JPGA 13/04/2010 BUG-63897 : Alimentation de la variable CDEDOC pour savoir si les sections par défaut sont présentes
        If [L]CDEDOC
           # JPGA-Bug -10/06/2009 : Procedure de recherche pour savoir si on est en présence de clé multiples pour les docs
           Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
           If find(COD_TYP, [L]DOC_CLE_MULT)  &  DOC_DEB<>""  &  instr(1,DOC_DEB,[L]WTIRET)  &  instr(1,DOC_FIN,[L]WTIRET)
              CLE1_DEB=left$(DOC_DEB,instr(1,DOC_DEB,[L]WTIRET)-1)
              CLE1_FIN=left$(DOC_FIN,instr(1,DOC_FIN,[L]WTIRET)-1)
              CLE2_DEB=right$(DOC_DEB,instr(1,DOC_DEB,[L]WTIRET)+1)
              CLE2_FIN=right$(DOC_FIN,instr(1,DOC_FIN,[L]WTIRET)+1)
              For [CDE]CDE0 Where COD>=CLE1_DEB and COD<=CLE1_FIN and CPY>=CLE2_DEB and CPY<=CLE2_FIN
                  Gosub GENE_CDEDOC
              Next
           Else
              For [CDE]CDE0 Where COD>=DOC_DEB and COD<=DOC_FIN
                  Gosub GENE_CDEDOC
              Next
           Endif
        Endif
    When "GAU" : #JPGA 10/08/2010 BUG-66637 : Alimentation de la variable GAUDOC pour savoir si les Pièces automatiques sont présentes
        If [L]GAUDOC
           For [GAU]GAU0 Where COD>=DOC_DEB and COD<=DOC_FIN
               Gosub GENE_GAUDOC
           Next
        Endif
    When "PS1"
        For [PS1]PS10 Where COD>=DOC_DEB and COD<=DOC_FIN
            Gosub GENE_PS1DOC
        Next
    When "ATD","AT3"
            #VPO 19/06/08 39766 ajout ATD: différences de tables
            #VPO 27/10/08 49955 ajout AT3: différences de tables 130
            # on ne fait rien
    When "ATB"
        For [ATB]CODFIC Where CODFIC>=DOC_DEB and CODFIC<=DOC_FIN
            Gosub GENE_ATBDOC
        Next
    When "AML"
        For [AML]MENLOC Where MENLOC>=val(DOC_DEB) and MENLOC<=val(DOC_FIN) and MENLOCAL=2
            Gosub GENE_AMLDOC
        Next
    When "ATY"
        For [ATY]CODTYP Where CODTYP>=DOC_DEB and CODTYP<=DOC_FIN
            Gosub GENE_ATYDOC
        Next
    When "ADC"
        For [ADC]ADC0 Where CODTRT>=DOC_DEB and CODTRT<=DOC_FIN
            Gosub GENE_ADCDOC
        Next
    When "AGB" : # On ne documente que les variables publiques
        If dim([AGB]PUBFLG)>0
            For [AGB]AGB0 Where CODVAR>=DOC_DEB and CODVAR<=DOC_FIN and PUBFLG>1
                Gosub GENE_AGBDOC
            Next
        Else
            For [AGB]AGB0 Where CODVAR>=DOC_DEB and CODVAR<=DOC_FIN
                Gosub GENE_AGBDOC
            Next
        Endif
    When "ASU"
        # JPGA 19/08/2009 Bug-52238 : Prise en comtpe des clés multiples pour ASU ou CDE
        Local Char  FILTR_PUBFLG(20)
        If dim([ASU]PUBFLG)>0
            [L]FILTR_PUBFLG =" PUBFLG>1 "
        Else
            [L]FILTR_PUBFLG =" 1=1 "
        Endif
        #VPO 16/09/08 49223 poss de traiter une seule doc ASU
        Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
        If DOC_DEB<>"" & instr(1,DOC_DEB,[L]WTIRET) & instr(1,DOC_FIN,[L]WTIRET)
            CLE1_DEB=left$(DOC_DEB,instr(1,DOC_DEB,[L]WTIRET)-1)
            CLE1_FIN=left$(DOC_FIN,instr(1,DOC_FIN,[L]WTIRET)-1)
            CLE2_DEB=right$(DOC_DEB,instr(1,DOC_DEB,[L]WTIRET)+1)
            CLE2_FIN=right$(DOC_FIN,instr(1,DOC_FIN,[L]WTIRET)+1)
            For [ASU]ASU0 Where PRG>=CLE1_DEB and PRG<=CLE1_FIN and SUBPRG>=CLE2_DEB and SUBPRG<=CLE2_FIN and evalue([L]FILTR_PUBFLG)
                Gosub GENE_ASUDOC
            Next
        Else
            For [ASU]ASU0 Where PRG>=DOC_DEB and PRG<=DOC_FIN and evalue([L]FILTR_PUBFLG)
                Gosub GENE_ASUDOC
            Next
        Endif
    When "APM" : # On génère les fonctions de type menu
        For [AFC] Where CODINT>=DOC_DEB and CODINT<=DOC_FIN and TYPTRAIT=2
            Gosub GENE_AFCDOC
        Next
    #VPO 14/01/08 41049,42137 doc ABO
    When "ABO"
        If [L]BIDOC
            For [ABO]ABO0 Where COD>=DOC_DEB and COD<=DOC_FIN
                Gosub GENE_ABODOC
            Next
        Endif
#VPO 04/09/08 48971 ajout ABF et ABM
    When "ABF"
        If [L]BIDOC
            For [ABF]ABF0 Where CODABF>=DOC_DEB and CODABF<=DOC_FIN
                Gosub GENE_ABFDOC
            Next
        Endif
    When "ABM"
        If [L]BIDOC
            For [ABM]ABM0 Where COD>=DOC_DEB and COD<=DOC_FIN
                Gosub GENE_ABMDOC
            Next
        Endif
    When "AHI"
        For [AHI] Where COD>=DOC_DEB and COD<=DOC_FIN
            Gosub GENE_AHIDOC
        Next
    When Default : # Type de doc non spécifiquement connu, on ne génère qu'un titre
        Gosub GENE_DIVDOC
  Endcase
  Commit

  If FONC_COUR<>""
    Read [AFC]CODINT=FONC_COUR
  Endif
Return

# La fonction principale de génération des données de doc sur fonction
$GENE_AFCDOC
  #VPO 13/10/08: 49722 ARP généré sans VLDDAT,VLDFLG
  VLDFLGAFC=1
  VLDDATAFC=[0/0/0]
# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[AFC]CODINT
  CODE_MODULE=[AFC]MODULE
  CODE_ACTIV=[AFC]CODACT : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
# Lecture de la fenêtre, détermination du type de l'objet
  Gosub LECWIN From AGENADO

  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    # Modification 18/8/06 les fonctions RPT* seront nommées en fonction du groupe à la génération finale
    If pat([AFC]CODINT,"RPT*")
        [ADO]TIT=""
    Else
        [ADO]TIT=func AGENADO.RDT([AFC]LIBMENU)
    Endif

# Fonctions sur menus : on change le type, on ne cherche pas de mots-clés, on valide la doc (14/3/2007)
    If TYPEFONC=6
        [ADO]TYP="APM"
        Gosub SET_VLD
        Write [ADO]
        Return
    Endif

# Pour les fonctions normales, quelques mots-clés...
    II=0
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    Call MAJMOTC(string$(TYPEFONC=1,func AGENADO.RDM("AWI1","OBJ")),TXT_TAB,II)
    Call MAJMOTC(string$(TYPEFONC=2,func AGENADO.RDM("AWI1","CNS")),TXT_TAB,II)
    Call MAJMOTC(string$(TYPEFONC=6,func AGENADO.RDM("AFP1","MENU1")),TXT_TAB,II)
    Setlob [ADH]TEXTE With ""+sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADO]
    Write [ADH]
  Else
    #VPO 13/10/08: 49722 ARP généré sans VLDDAT,VLDFLG
    VLDFLGAFC=[ADO]VLDFLG
    VLDDATAFC=[ADO]VLDDAT
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        # Modification 18/8/06 les fonctions RPT* seront nommées en fonction du groupe à la génération finale
        If pat([AFC]CODINT,"RPT*")
            [ADO]TIT=""
        Else
            [ADO]TIT=func AGENADO.RDT([AFC]LIBMENU)
        Endif
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Si le paragraphe de titre existe, mais avec un code activité FAL, on arrête les frais
# (il s'agit du cas d'une "fausse" fonction)
# Arrêt également pour les fonctions sur menus
  If [ADO]CODACT="FAL" or TYPEFONC=6
    Return
  Endif

  # Paragraphe de présentation
  Gosub CR_PRE

# Recherche des codes activités concernés (si le paragraphe doit être régénéré)
  PAR_DOC="ACV" : [L]LEV=30 : [L]SUBLEV=20
  Gosub TST_REGEN
  If REGEN
    Gosub CR_ACV
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(6,142) : # "Codes activité"
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Recherche des paramètres concernés (si le paragraphe doit être régénéré)
# On les retrouve dans les liens
  PAR_DOC="ADP" : [L]LEV=30 : [L]SUBLEV=30
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Gosub LIT_VALEURS From AGENADO
    Gosub LIT_AUSSI_VALINV From AGENADO
    If II>0
        [ADO]TIT=func AGENADO.MST(9,142) : # "Paramètres généraux"
        [ADO]STY=4
        Write [ADO]
    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(9,142) : # "Paramètres généraux"
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Recherche des compteurs concernés (si le paragraphe doit être régénéré)
  PAR_DOC="ANM" : [L]LEV=30 : [L]SUBLEV=40
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Gosub LIT_VALEURS From AGENADO
    If II>0
        [ADO]TIT=func AGENADO.MST(13,142) : # "Compteurs"
        [ADO]STY=4
        Write [ADO]
    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(13,142) : # "Compteurs"
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Recherche des pièces automatiques concernées (si le paragraphe doit être régénéré)
  PAR_DOC="GAU" : [L]LEV=30 : [L]SUBLEV=50
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Gosub LIT_VALEURS From AGENADO
    If II>0
        [ADO]TIT=func AGENADO.MST(27,142) : # "Pièces automatiques"
        [ADO]STY=5
        Write [ADO]
    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(27,142) : # "Pièces automatiques"
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Recherche des sections par défaut concernées (si le paragraphe doit être régénéré)
  PAR_DOC="CDE" : [L]LEV=30 : [L]SUBLEV=60
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Gosub LIT_VALEURS From AGENADO
    If II>0
        [ADO]TIT=func AGENADO.MST(23,142) : # "Sections par défaut"
        [ADO]STY=5
        Write [ADO]
    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(23,142) : # "Sections par défaut"
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Paragraphe relatif aux habilitations (si objet, options, codes d'accès)
# Rajouter à terme ce qui va bien si consultations
  PAR_DOC="HAB" : [L]LEV=30 : [L]SUBLEV=70
  If [AFC]FCYAUZ=2 or [AFC]NBOPT>0 or TYPEFONC=1 or [AOB]ZACC<>""
    Gosub TST_REGEN
    If REGEN
        Gosub SET_ADO
        #VPO 11/01/08 40090
        Gosub SET_ACTIV
        [ADO]TIT=func AGENADO.MST(124,142) : # "Habilitations"
        [ADO]STY=4
        Write [ADO]
    Else
        #VPO 12/06/08 41386
        If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
            [ADO]TIT=func AGENADO.MST(124,142) : # "Habilitations"
        Endif
        #VPO 11/01/08 40090
        Gosub SET_ACTIV
        Rewrite [ADO]
    Endif
  Endif

# Paragraphe relatif aux transactions de saisie s'il y en a
  If TYPEFONC=1 or TYPEFONC=3 : # Modif pour la paye
    PAR_DOC="TRS" : [L]LEV=30 : [L]SUBLEV=80
    Gosub TST_REGEN
    If REGEN
        Gosub SET_ADO
        #VPO 11/01/08 40090
        Gosub SET_ACTIV
        Gosub LIT_VALEURS From AGENADO
        If II>0
            [ADO]TIT=func AGENADO.MST(33,142) : # "Transactions de saisie"
            [ADO]STY=4
            Write [ADO]
        Endif
    Else
      #VPO 12/06/08 41386
      If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
            [ADO]TIT=func AGENADO.MST(33,142) : # "Transactions de saisie"
      Endif
      #VPO 11/01/08 40090
      Gosub SET_ACTIV
      Rewrite [ADO]
    Endif

# Paragraphe relatif aux consultations s'il y en a
  Elsif TYPEFONC=2
    PAR_DOC="GTC" : [L]LEV=30 : [L]SUBLEV=80
    Gosub TST_REGEN
    If REGEN
        II=0
        Gosub GTC_ACN From AGENADO
        If II>0
            Gosub SET_ADO
            #VPO 11/01/08 40090
            Gosub SET_ACTIV
            [ADO]TIT=func AGENADO.MST(39,142) : # "Ecrans de consultation"
            [ADO]STY=4
            Write [ADO]
        Endif
    Else
      #VPO 12/06/08 41386
      If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
            [ADO]TIT=func AGENADO.MST(39,142) : # "Ecrans de consultation"
      Endif
      #VPO 11/01/08 40090
      Gosub SET_ACTIV
      Rewrite [ADO]
    Endif
  Endif

# Paragraphe relatif aux pre-requis divers
  PAR_DOC="PRD" : [L]LEV=30 : [L]SUBLEV=90
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    # On génère ce paragraphe s'il existe au moins un lien de type ADI, AT2, ou AML dans la table des liens
    LNK_TYPE="ADI"
    Gosub LIT_PAR_VAL From AGENADO
    If II=0
        LNK_TYPE="AT2"
        Gosub LIT_PAR_VAL From AGENADO
        If II=0
            LNK_TYPE="AML"
            Gosub LIT_PAR_VAL From AGENADO
        Endif
    Endif
    If II<>0
        [ADO]TIT="" : # func AGENADO.MST(57,142), qui contient "Pré-requis divers", est inutile...
        [ADO]STY=4
        Write [ADO]
    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT="" : # func AGENADO.MST(57,142), qui contient "Pré-requis divers", est inutile...
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Paragraphe relatif aux workflow s'il en existe
  PAR_DOC="AWA" : [L]LEV=30 : [L]SUBLEV=100
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    # On génère ce paragraphe s'il existe au moins un lien de type AWA dans la table des liens
    LNK_TYPE="AWA"
    Gosub LIT_PAR_VAL From AGENADO
    If II<>0
        [ADO]TIT=func AGENADO.MST(125,142) : # "Règles de Workflow liées"
        [ADO]STY=4
        Write [ADO]
    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(125,142) : # "Règles de Workflow liées"
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

  #VPO 11/01/08 40090 on met à jour le paragraphe si détail ou si on le trouve
  TROUVE=0
# Paragraphe introductif des pre-requis si au moins un pré-requis existe
  For [ADO]ADO0 Where LAN=[V]COD_LAN & TYP="AFC"& COD=[AFC]CODINT & LEV=30 & SUBLEV>10
    TROUVE=1
    Break
  Next
  PAR_DOC="PRQ" : [L]LEV=30 : [L]SUBLEV=10
  Gosub TST_REGEN
  If REGEN
    If TROUVE=1
        Gosub SET_ADO
        #VPO 11/01/08 40090
        Gosub SET_ACTIV
        [ADO]TIT=func AGENADO.MST(4,142) : # "Pré-requis"
        Write [ADO]
    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(4,142) : # "Pré-requis"
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Paragraphes décrivant la fenêtre de la fonction (onglets, boutons, barre de menus)
# Ces paragraphes ne sont créés que si la fenêtre existe ([AWI]WIN<>"")
# L'algorithme est le suivant :
# - on analyse la fenêtre pour connaître la liste des onglets et des boutons
# - on donne un rang aux paragraphes liés aux onglets en fonction du rang dans la fenêtre
# - on numérote les boutons de 5 en 5 (5=Bouton 1, 10=Bouton 2... 100=Bouton 20)
# - s'il y a plus d'un tableau, le deuxième est numéroté 105=Bouton 1, 110=Bouton 2.. 200=Bouton 20)
# - et ainsi de suite...
# L'algorithme n'est pas parfait, si on numérote les onglets de 1 en 1 et que l'on a deux tableaux dont
# le deuxième va jusqu'au bouton 20, on a un conflit

# On commence par créer les paragraphes liés aux onglets

  If [AWI]WIN<>""

    NB_ONG=0

# Paragraphe introductif dans tous les cas
    PAR_DOC="ECR" : [L]LEV=40 : [L]SUBLEV=50
    Gosub TST_CREER
    If REGEN
        Gosub SET_ADO
        #VPO 11/01/08 40090
        Gosub SET_ACTIV
        [ADO]TIT=func AGENADO.MST(60,142) : # "Gestion de l'écran"
        Write [ADO]
    Else
        #VPO 12/06/08 41386
        If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
            [ADO]TIT=func AGENADO.MST(60,142) : # "Gestion de l'écran"
        Endif
        #VPO 11/01/08 40090
        Gosub SET_ACTIV
        Rewrite [ADO]
    Endif

# Onglet d'en-tête
    If [AWI]MSKENT<>"" and [AWI]FVT<>2
        NB_ONG=1
        PAR_DOC="ENT" : [L]LEV=40 : [L]SUBLEV=100
        Gosub TST_CREER
        If REGEN
            Gosub SET_ADO
            #VPO 11/01/08 40090
            Gosub SET_ACTIV
            [ADO]TIT=func AGENADO.MST(64,142) : # "En-tête"
            [ADO]STY=4
            [ADO]MSK=[AWI]MSKENT
            Gosub VERIF_MODULE
            Write [ADO]
        Else
            #VPO 12/06/08 41386
            If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
                [ADO]TIT=func AGENADO.MST(64,142) : # "En-tête"
            Endif
            #VPO 11/01/08 40090
            Gosub SET_ACTIV
            Gosub VERIF_MODULE
            Rewrite [ADO]
        Endif
    Endif

# Tri des différents onglets de la fenêtre dans l'ordre d'apparition
    Gosub TRI_FENETRE_ONGLET From AGENLIBA

# Boucle sur les différents onglets
    For II=1 To [AWI]NBMSK

# Le paragraphe de l'onglet
        Read [AMK]CODMSK=ONG_NOM(II)
        NB_ONG+=1
        PAR_DOC="ON"+string$(ONG_NO(II)<=9,num$(ONG_NO(II)))+string$(ONG_NO(II)>9,chr$(55+ONG_NO(II)))
        [L]LEV=40 : [L]SUBLEV=200*II
        Gosub TST_CREER
        If REGEN
            Gosub SET_ADO
            #VPO 11/01/08 40090
            Gosub SET_ACTIV
            # Titre de l'onglet = "Ecran de saisie" si un seul onglet et pas d'en-tête
            If [AWI]NBMSK=1 & [AWI]MSKENT=""
                [ADO]TIT=func AGENADO.MST(83,142) : # "Ecran de saisie"
            Elsif [AWI]INTMSK(ONG_NO(II)-1)<>0 : # Si l'onglet a un intitulé, on l'utilise
                [ADO]TIT=func AGENADO.RDT([AWI]INTMSK(ONG_NO(II)-1))
            Else : # Sinon, on ne met rien (le titre onglet numéro I sera généré à la fin)
                [ADO]TIT=""
            Endif
            [ADO]STY=4
            [ADO]MSK=ONG_NOM(II)
            #VPO 11/01/08 40090 on reaffecte activ ssi renseigné
            #If ONG_ACT(II)<>"" & [ADO]MSK=ONG_NOM(II)
            #VPO 20/10/08 49850 ne pas ecraser code activité à FAL
            If ONG_ACT(II)<>"" & [ADO]MSK=ONG_NOM(II) & [ADO]CODACT<>"FAL"
                [ADO]CODACT=ONG_ACT(II)
            Endif
            Gosub VERIF_MODULE
            Write [ADO]
        Else
            #VPO 12/06/08 41386
            If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
                # Titre de l'onglet = "Ecran de saisie" si un seul onglet et pas d'en-tête
                If [AWI]NBMSK=1 & [AWI]MSKENT=""
                    [ADO]TIT=func AGENADO.MST(83,142) : # "Ecran de saisie"
                Elsif [AWI]INTMSK(ONG_NO(II)-1)<>0 : # Si l'onglet a un intitulé, on l'utilise
                    [ADO]TIT=func AGENADO.RDT([AWI]INTMSK(ONG_NO(II)-1))
                Endif
            Endif
            #VPO 11/01/08 40090
            Gosub SET_ACTIV
            #VPO 11/01/08 40090 on reaffecte activ ssi renseigné
            #If ONG_ACT(II)<>"" & [ADO]MSK=ONG_NOM(II)
            #VPO 20/10/08 49850 ne pas ecraser code activité à FAL
            If ONG_ACT(II)<>"" & [ADO]MSK=ONG_NOM(II) & [ADO]CODACT<>"FAL"
                [ADO]CODACT=ONG_ACT(II)
            Endif
            Gosub VERIF_MODULE
            Rewrite [ADO]
        Endif

# Recherche des tableaux de l'onglet pour voir si boutons sont à documenter
        NB_FTAB=0
        For JJ=1 To [AMK]NBBLOC

# Tri préliminaire des blocs dans l'ordre d'apparition
            If [AMK]TYPBLOC(JJ-1)=1
                For [AMZ]Where CODMSK=[AMK]CODMSK and [AMZ]NUMBLOC=JJ and [AMZ]CODTYP="ABS"
                    Break
                Next

# Si c'est un bloc tableau dont la variable de bas de tableau est visible, on insère un paragraphe
                If [AMZ]SAIAFF<>3 and [AMZ]CODTYP="ABS"
                    For [AMA]NOACT Where TYPAFF=1 and CODAFF=[AMK]CODMSK and CODZON=[AMZ]CODZON
                        If ([AMA]TYPACT>=9 and [AMA]TYPACT<=12) or ([AMA]TYPACT>=15 and [AMA]TYPACT<=30)
                            KK=[AMA]TYPACT-8 : KK-=2*(KK>5)
                            PAR_DOC="BOT"
                            NB_FTAB+=1
                            [L]LEV=40 : [L]SUBLEV=200*II+5*NB_FTAB
                            Gosub TST_CREER
                            If REGEN
                                Gosub SET_ADO
                                #VPO 11/01/08 40090
                                Gosub SET_ACTIV
                                [ADO]TIT=func AGENADO.RDT([AMA]INTITACT)
                                [ADO]STY=6
                                #VPO 11/01/08 40090 on reaffecte activ ssi renseigné
                                #If [AMK]ACTBLOC(JJ-1)<>""
                                #VPO 20/10/08 49850 ne pas ecraser code activité à FAL
                                If [AMK]ACTBLOC(JJ-1)<>"" & [ADO]CODACT<>"FAL"
                                    [ADO]CODACT=[AMK]ACTBLOC(JJ-1)
                                Endif
                                Write [ADO]
                            Else
                                #VPO 12/06/08 41386
                                If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
                                    [ADO]TIT=func AGENADO.RDT([AMA]INTITACT)
                                Endif
                                #VPO 11/01/08 40090
                                Gosub SET_ACTIV
                                #VPO 11/01/08 40090 on reaffecte activ ssi renseigné
                                #If [AMK]ACTBLOC(JJ-1)<>""
                                #VPO 20/10/08 49850 ne pas ecraser code activité à FAL
                                If [AMK]ACTBLOC(JJ-1)<>"" & [ADO]CODACT<>"FAL"
                                    [ADO]CODACT=[AMK]ACTBLOC(JJ-1)
                                Endif
                                Rewrite [ADO]
                            Endif
                        Endif
                    Next
                Endif

            Endif
        Next JJ

# Fin de boucle sur les onglets
    Next II

# S'il existe des boutons dans la fenêtre, on insère les paragraphes correspondants
    NB_BOU=0

    If [AWI]BSTD(1)=2 & TYPEFONC=2 : # Le bouton "Critères" dispose d'un traitement de faveur
        NB_BOU+=1 : PAR_DOC="BOU" : [L]LEV=70 : [L]SUBLEV=10*(NB_BOU+1)
        Gosub TST_CREER
        If REGEN
            Gosub SET_ADO
            #VPO 11/01/08 40090
            Gosub SET_ACTIV
            [ADO]TIT=func AGENADO.MST(182,133) : # "Critères"
            Write [ADO]
        Else
            #VPO 12/06/08 41386
            If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
                [ADO]TIT=func AGENADO.MST(182,133) : # "Critères"
            Endif
            #VPO 11/01/08 40090
            Gosub SET_ACTIV
            Rewrite [ADO]
        Endif
    Endif

# Recherche des autres boutons spécifiques
    For [AWT]AWT0 Where WIN=[AWI]WIN & TYPBOUT=1
        NB_BOU+=1 : PAR_DOC="BOU" : [L]LEV=70 : [L]SUBLEV=10*(NB_BOU+1)
        Gosub TST_CREER
        If REGEN
            Gosub SET_ADO
            #VPO 11/01/08 40090
            Gosub SET_ACTIV
            [ADO]TIT=func AGENADO.RDT([AWT]TXTBOUT)
            #VPO 11/01/08 40090 on reaffecte activ ssi renseigné
            #If [AWT]CODACTBOUT<>""
            #VPO 20/10/08 49850 ne pas ecraser code activité à FAL
            If [AWT]CODACTBOUT<>"" & [ADO]CODACT<>"FAL"
                [ADO]CODACT=[AWT]CODACTBOUT
            Endif
            Write [ADO]
        Else
            #VPO 12/06/08 41386
            If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
                [ADO]TIT=func AGENADO.RDT([AWT]TXTBOUT)
            Endif
            #VPO 11/01/08 40090
            Gosub SET_ACTIV
            #VPO 11/01/08 40090 on reaffecte activ ssi renseigné
            #If [AWT]CODACTBOUT<>""
            #VPO 20/10/08 49850 ne pas ecraser code activité à FAL
            If [AWT]CODACTBOUT<>"" & [ADO]CODACT<>"FAL"
                [ADO]CODACT=[AWT]CODACTBOUT
            Endif
            Rewrite [ADO]
        Endif
    Next

# Paragraphe introductif
    If NB_BOU
        PAR_DOC="BOU" : [L]LEV=70 : [L]SUBLEV=10
        Gosub TST_CREER
        If REGEN
            Gosub SET_ADO
            #VPO 11/01/08 40090
            Gosub SET_ACTIV
            [ADO]TIT=func AGENADO.MST(94,142)
            Write [ADO]
        Else
            #VPO 12/06/08 41386
            If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
                [ADO]TIT=func AGENADO.MST(94,142)
            Endif
            #VPO 11/01/08 40090
            Gosub SET_ACTIV
            Rewrite [ADO]
        Endif
    Endif

# Recherche dans la barre de menus
    NB_MEN=0
    For [AWT]AWT0 Where WIN=[AWI]WIN & TYPBOUT=3

# Intertitre pour le premier menu
        NB_MEN+=1
        If NB_MEN=1
            PAR_DOC="BME" : [L]LEV=80 : [L]SUBLEV=10
            Gosub TST_CREER
            If REGEN
                Gosub SET_ADO
                #VPO 11/01/08 40090
                Gosub SET_ACTIV
                [ADO]TIT=func AGENADO.MST(90,142)
                Write [ADO]
            Else
                #VPO 12/06/08 41386
                If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
                    [ADO]TIT=func AGENADO.MST(90,142)
                Endif
                #VPO 11/01/08 40090
                Gosub SET_ACTIV
                Rewrite [ADO]
            Endif
        Endif

# On génère le titre des menus suivants
        [ADO]TIT=""
        PAR_DOC="BME" : [L]LEV=80 : [L]SUBLEV=10*(NB_MEN+1)
        Gosub TST_CREER
        If REGEN
            Gosub SET_ADO
            #VPO 11/01/08 40090
            Gosub SET_ACTIV
            CO_MEN=[AWT]CODBOUT
            If len(CO_MEN)=3
                For [AWT2]AWT0 Where WIN=[AWI]WIN and TYPBOUT=2 and CODBOUT=left$(CO_MEN,1)
                    [ADO]TIT=func AGENADO.RDT([AWT2]TXTBOUT)
                    Break
                Next
                For [AWT2]AWT0 Where WIN=[AWI]WIN and TYPBOUT=2 and CODBOUT=left$(CO_MEN,2)
                    [ADO]TIT+=string$([ADO]TIT<>""," / ")+func AGENADO.RDT([AWT2]TXTBOUT)
                    Break
                Next
            Endif
            If len(CO_MEN)=2
                For [AWT2]AWT0 Where WIN=[AWI]WIN and TYPBOUT=2 and CODBOUT=left$(CO_MEN,1)
                    [ADO]TIT+=string$([ADO]TIT<>""," / ")+func AGENADO.RDT([AWT2]TXTBOUT)
                    Break
                Next
            Endif

            [ADO]TIT+=string$([ADO]TIT<>""," / ")+func AGENADO.RDT([AWT]TXTBOUT)
            [ADO]STY=4
            #VPO 11/01/08 40090 on reaffecte activ ssi renseigné
            #If [AWT]CODACTBOUT<>""
            #VPO 20/10/08 49850 ne pas ecraser code activité à FAL
            If [AWT]CODACTBOUT<>"" & [ADO]CODACT<>"FAL"
                [ADO]CODACT=[AWT]CODACTBOUT
            Endif
            Write [ADO]
        Else
            #VPO 12/06/08 41386
            If instr(0,[ADO]TIT,"[") & instr(0,[ADO]TIT,"]")
                [ADO]TIT=""
                CO_MEN=[AWT]CODBOUT
                If len(CO_MEN)=3
                    For [AWT2]AWT0 Where WIN=[AWI]WIN and TYPBOUT=2 and CODBOUT=left$(CO_MEN,1)
                        [ADO]TIT=func AGENADO.RDT([AWT2]TXTBOUT)
                        Break
                    Next
                    For [AWT2]AWT0 Where WIN=[AWI]WIN and TYPBOUT=2 and CODBOUT=left$(CO_MEN,2)
                        [ADO]TIT+=string$([ADO]TIT<>""," / ")+func AGENADO.RDT([AWT2]TXTBOUT)
                        Break
                    Next
                Endif
                If len(CO_MEN)=2
                    For [AWT2]AWT0 Where WIN=[AWI]WIN and TYPBOUT=2 and CODBOUT=left$(CO_MEN,1)
                        [ADO]TIT+=string$([ADO]TIT<>""," / ")+func AGENADO.RDT([AWT2]TXTBOUT)
                        Break
                    Next
                Endif
                [ADO]TIT+=string$([ADO]TIT<>""," / ")+func AGENADO.RDT([AWT]TXTBOUT)
            Endif
            #VPO 11/01/08 40090
            Gosub SET_ACTIV
            #VPO 11/01/08 40090 on reaffecte activ ssi renseigné
            #If [AWT]CODACTBOUT<>""
            #VPO 20/10/08 49850 ne pas ecraser code activité à FAL
            If [AWT]CODACTBOUT<>"" & [ADO]CODACT<>"FAL"
                [ADO]CODACT=[AWT]CODACTBOUT
            Endif
            Rewrite [ADO]
        Endif
    Next

#   Si c'est une doc objet et que l'objet est documentable, on ajoute 3 paragraphes de liens sur barre de menu
#   et le paragraphe introductif s'il n'existe pas
    If TYPEFONC=1
        #VPO 30/06/08 48129
        Filter [ADI] Where N1<>2
        Read [ADI]CODE=910;CODOBJ
        If fstat=0
            If NB_MEN=0
                PAR_DOC="BME" : [L]LEV=80 : [L]SUBLEV=10
                Gosub TST_CREER
                If REGEN
                    Gosub SET_ADO
                    #VPO 11/01/08 40090
                    Gosub SET_ACTIV
                    [ADO]TIT=func AGENADO.MST(90,142)
                    Write [ADO]
                Else
                    #VPO 12/06/08 41386
                    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
                        [ADO]TIT=func AGENADO.MST(90,142)
                    Endif
                    #VPO 11/01/08 40090
                    Gosub SET_ACTIV
                    Rewrite [ADO]
                Endif
            Endif
            For JJ=500,510,520
                PAR_DOC="INC" : [L]LEV=80 : [L]SUBLEV=JJ
                Gosub TST_CREER
                If REGEN
                    TXT_PARAG="<p>DI/ADO_FCT</p>"
                    Gosub SET_ADO
                    #VPO 11/01/08 40090
                    Gosub SET_ACTIV
                    [ADO]TIT=""
                    Setlob [ADH]TEXTE With TXT_PARAG(1..1)
                    Write [ADH]
                    Write [ADO]
                Else
                    #VPO 11/01/08 40090
                    Gosub SET_ACTIV
                    Rewrite [ADO]
                Endif
            Next JJ
        Endif
        Filter [ADI]
    Endif

# Fin du If relatif à l'existence de la fenêtre
  Endif

# S'il existe des états associés, on génère le paragraphe
  PAR_DOC="ARP" : [L]LEV=50 : [L]SUBLEV=10
  Gosub TST_REGEN
  #VPO 13/10/08: 49722 ARP généré sans VLDDAT,VLDFLG
  #Gosub SET_ADO
  Gosub LIT_VALEURS From AGENADO
  If ([AFC]RPT1<>"" or [AFC]RPT2<>"" or II>0)
      If REGEN
          #VPO 13/10/08: 49722 ARP généré sans VLDDAT,VLDFLG
          Gosub SET_ADO
          If VLDFLGAFC=2
              [ADO]VLDFLG=VLDFLGAFC
              [ADO]VLDDAT=VLDDATAFC
          Endif
          #VPO 11/01/08 40090
          Gosub SET_ACTIV
          [ADO]TIT=func AGENADO.MST(78,142)
          Write [ADO]
      Else
          #VPO 13/10/08: 49722 ARP généré sans VLDDAT,VLDFLG
          If VLDFLGAFC=2
              [ADO]VLDFLG=VLDFLGAFC
              [ADO]VLDDAT=VLDDATAFC
          Endif
          #VPO 12/06/08 41386
          If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
              [ADO]TIT=func AGENADO.MST(78,142)
          Endif
          #VPO 11/01/08 40090
          Gosub SET_ACTIV
          Rewrite [ADO]
      Endif
  Endif


# Lancement batch : on ne le supprime jamais, on le crée uniquement si au moins une tâche ou un lien existe
  If TYPEFONC=3
    PAR_DOC="ABT" : [L]LEV=60 : [L]SUBLEV=10
    Gosub TST_CREER
    If REGEN
        Gosub SET_ADO
        #VPO 11/01/08 40090
        Gosub SET_ACTIV
        Gosub LIT_VALEURS From AGENADO
        Gosub ABT_AFC
        If II>0
            [ADO]TIT=func AGENADO.MST(89,142)
            Write [ADO]
        Endif
    Else
        #VPO 12/06/08 41386
        If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
            [ADO]TIT=func AGENADO.MST(89,142)
        Endif
        #VPO 11/01/08 40090
        Gosub SET_ACTIV
        Rewrite [ADO]
    Endif
  Endif

# Paragraphe lié aux erreurs
  Gosub CR_ERR

# Paragraphe des tables
  [ADO]PAR="ATB" : [L]LEV=100 : [L]SUBLEV=10
  Gosub LIT_VALEURS From AGENADO
  Gosub ATB_AFC From AGENADO
  Gosub CR_ATB
Return

#VPO 30/06/08 48129 : ajout liste des tables diverses
# La fonction principale de génération des données de doc sur liste des table diverses
$GENE_ADIDOC
# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="ADI_0"
  CODE_MODULE=1

  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  Gosub TRACE_COR_TIT
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Tables diverses"
    [ADO]TIT=func AGENADO.MST(48,142)
    Write [ADO]
  Endif
Return


# La fonction principale de génération des données de doc sur paramètres
$GENE_ADPDOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[ADP]PARAM
  CODE_ACTIV=[ADP]CODACT : #VPO 11/01/08 40090

# Le seul dico où le module n'existe pas !
  # JPGA - 14/05/2009 - Bug-55126 : La generation modifie le module en ne prenant en compte que X3 a tord !!!
  Case GPRODUIT
     When 0  # X3
        Case [ADP]CHAPITRE
           When "SUP","ADX","WEB" : CODE_MODULE=1
           When "BUD","CPT"       : CODE_MODULE=2
           When "TRS"             : CODE_MODULE=3
           When "VEN"             : CODE_MODULE=5
           When "ACH"             : CODE_MODULE=6
           When "STO"             : CODE_MODULE=7
           When "GPA"             : CODE_MODULE=8
           When "HDK"             : CODE_MODULE=12
           When "CRM"             : CODE_MODULE=13
           When "AAS"             : CODE_MODULE=14
           When Default           : CODE_MODULE=9  # Tronc commun
        Endcase
     When 1  # GEODE
        Case [ADP]CHAPITRE
           When "SUP","ADX"       : CODE_MODULE=1  # Superviseur
           When Default           : CODE_MODULE=2  # Géode GX
        Endcase
     When 2  # PAIE
        Case [ADP]CHAPITRE
           When "SUP","ADX"                        : CODE_MODULE=1  # Superviseur
           When "BIL","BUL","CP","PAY","PLA","TDS" : CODE_MODULE=2  # Paie
           When "CPT","ANA"                        : CODE_MODULE=3  # Interface compta
           When "TPS"                              : CODE_MODULE=4  # Gestion des temps
           When "FRT"                              : CODE_MODULE=5  # Formation
           When "NOF"                              : CODE_MODULE=6  # Notes de frais
           When "TC"                               : CODE_MODULE=9  # Tronc commun
           When Default                            : CODE_MODULE=2  # Paie
        Endcase
     When 3  # ABEL
        Case [ADP]CHAPITRE
           When "SUP","ADX"       : CODE_MODULE=1  # Superviseur
           When "FIN"             : CODE_MODULE=4  # Financement
           When "AAS","IMP"       : CODE_MODULE=5  # Immobilisations
           When Default           : CODE_MODULE=5  # Immobilisations
        Endcase
     When Default                 : CODE_MODULE=1  # Si produit SUPERVISEUR ou autre : on initie quand même à 1 pour avoir une valeur
  Endcase
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    [ADO]TIT=func AGENADO.RDT([ADP]NAM)

# Quelques mots-clés...
    II=0
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    Call MAJMOTC(func AGENADO.RDM("ADP1","PARAM"),TXT_TAB,II)
    # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
    Call MAJMOTC(func AGENLIBA.RECH_DESIGNATION('ADI', '901', [ADP]CHAPITRE),TXT_TAB,II)
    Call MAJMOTC(format$("N0:3",[ADP]NIVDEF)+",987",TXT_TAB,II)
    Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADH]
    Write [ADO]
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.RDT([ADP]NAM)
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

  # Paragraphe de présentation
  Gosub CR_PRE

# Paragraphe lié au niveau de localisation et la variable globale
  PAR_DOC="LEV" : [L]LEV=30 : [L]SUBLEV=10
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    [ADO]TIT=func AGENADO.MST(160,142) : # "Niveau de localisation / Variable globale"
    Write [ADO]
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(160,142) : # "Niveau de localisation / Variable globale"
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Recherche des paramètres concernés dans le dictionnaire et la table des liens
  PAR_DOC="ADP" : [L]LEV=40 : [L]SUBLEV=10
  Gosub SET_ADO
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Gosub LIT_VALEURS From AGENADO
    Gosub LIT_AUSSI_VALINV From AGENADO
    If II>0
        [ADO]TIT=func AGENADO.MST(158,142) : # "Paramètres liés"
        Write [ADO]
    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(158,142) : # "Paramètres liés"
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Paragraphe lié aux fonctions concernées
  PAR_DOC="AFC" : [L]LEV=50 : [L]SUBLEV=10
  Gosub SET_ADO
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Gosub LIT_VALINV From AGENADO
    If II>0
        [ADO]TIT=func AGENADO.MST(192,142) : # "Fonctions concernées"
        Write [ADO]
    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(192,142) : # "Fonctions concernées"
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Recherche des codes activités concernés (si le paragraphe doit être régénéré)
  PAR_DOC="ACV" : [L]LEV=60 : [L]SUBLEV=10
  Gosub SET_ADO
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Gosub LIT_VALEURS From AGENADO
    Gosub ACV_ADP From AGENADO
    Gosub ELIMINE_ACV
    If II>0
        [ADO]TIT=func AGENADO.MST(6,142) : # "Codes activité"
        Write [ADO]
    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(6,142) : # "Codes activité"
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Paragraphe remarques par défaut
  Gosub CR_REM

# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="ADP_"+[ADP]CHAPITRE
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Paramètres généraux" "Chapitre" XXX (nom)
    # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
    [ADO]TIT=func AGENADO.MST(9,142)-func AGENADO.RDM("ADP1","CHAPITRE")-[ADP]CHAPITRE-'('
&           +func AGENLIBA.RECH_DESIGNATION('ADI', '901', [ADP]CHAPITRE)+")"
    Write [ADO]
  Endif
  CODE_DOC="ADP_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Paramètres généraux"
    [ADO]TIT=func AGENADO.MST(9,142)
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="ADP"

Return

# La fonction principale de génération des données de doc sur actions
$GENE_ACTDOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[ACT]ACTION
  CODE_MODULE=[ACT]MODULE
  CODE_ACTIV=[ACT]CODACT : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    [ADO]TIT=func AGENADO.RDT([ACT]INTITA)

# Quelques mots-clés...
    II=0
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    Call MAJMOTC(func AGENADO.RDM("AMK2","ACTION"),TXT_TAB,II)
    Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADH]
    Write [ADO]
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.RDT([ACT]INTITA)
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

  # Paragraphe de présentation
  # On renseigne TEXTES avec les textes trouvés dans le dictionnaire en cas de première création
  # Le champ [ACT]INFO est amené à disparaître en version 150...
  II=0
  If dim([ACT]INFO)>0
    For II=0 To 3
        If [ACT]INFO(II)<>0
            TEXTES(II+1)=func AGENADO.RDT([ACT]INFO(II))+" "
        Else
            TEXTES(II+1)=""
        Endif
    Next II
  Endif
  TEXTES(II+1)=""
  Gosub CR_PRET

# Paragraphe lié aux paramètres
  PAR_DOC="PAR" : [L]LEV=30 : [L]SUBLEV=10
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    [ADO]TIT=func AGENADO.MST(188,142)
    Write [ADO]
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(188,142)
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Paragraphe lié aux utilisations de l'action
  PAR_DOC="UTI" : [L]LEV=40 : [L]SUBLEV=10
  Gosub TST_CREER
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    [ADO]TIT=func AGENADO.MST(200,142)
    Write [ADO]
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(200,142)
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Paragraphe lié aux actions liées
  PAR_DOC="ACT" : [L]LEV=50 : [L]SUBLEV=10
  Gosub SET_ADO
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Gosub LIT_VALEURS From AGENADO
    If II>0
        [ADO]TIT=func AGENADO.MST(210,142) : # "Actions liées"
        Write [ADO]
    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(210,142) : # "Actions liées"
    Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="ACT_"+num$([ACT]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Actions" "Module" nom du module
    [ADO]TIT=func AGENADO.RDM("ACOMPOBJ","ACT")-func AGENADO.RDM("ACT1","MODULE")
&           -func AGENADO.MST([ACT]MODULE,14)
    Write [ADO]
  Endif
  CODE_DOC="ACT_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Paramètres généraux"
    [ADO]TIT=func AGENADO.RDM("ACOMPOBJ","ACT")
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="ACT"

Return

# La fonction principale de génération des données de doc sur codes activité
$GENE_ACVDOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[ACV]CODACT
  CODE_MODULE=[ACV]MODULE
  CODE_ACTIV="" : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.RDT([ACV]LIBACT)

# Quelques mots-clés...
    II=0
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    Call MAJMOTC(func AGENADO.RDM("ATB1","CODACT"),TXT_TAB,II)
    Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADO]
    Write [ADH]
  Endif

  # Paragraphe de présentation : si le code activité est dépendant, on ne génère pas de texte
  PAR_DOC="PRE" : [L]LEV=10 : [L]SUBLEV=20
  Gosub TST_CREER
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.MST(2,142) : # "Présentation"
    If [ACV]DEP=1
        Raz TXT_PARAG : # On ne met plus "à renseigner" pour faciliter la traduction
#       TXT_PARAG="<p>"+func AGENADO.MST(148,142)+"</p>" : # "A renseigner"
        Setlob [ADH]TEXTE With TXT_PARAG(1..1)
        Write [ADH]
    Endif
    Write [ADO]
  Endif

# Paragraphe lié aux valeurs recommandées (uniquement pour les codes activité indépendants)
  If [ACV]DEP=1
    PAR_DOC="REC" : [L]LEV=30 : [L]SUBLEV=10
    Gosub TST_CREER
    If REGEN
        Gosub SET_ADO
        [ADO]TIT=func AGENADO.MST(191,142) : # "Valeurs recommandées"
        Write [ADO]
    Endif
  Endif

# Paragraphe lié aux fonctions concernées
  PAR_DOC="AFC" : [L]LEV=40 : [L]SUBLEV=10
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    Gosub LIT_VALINV From AGENADO
    Gosub AFC_ACV From AGENADO
    If II>0
        [ADO]TIT=func AGENADO.MST(192,142) : # "Fonctions concernées"
        Write [ADO]
    Endif
  Endif

# Paragraphe lié aux codes activités liés
  PAR_DOC="ACV" : [L]LEV=50 : [L]SUBLEV=10
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    II=0
    Gosub ACV_ACV From AGENADO
    Gosub ELIMINE_ACV

    If II>0
        [ADO]TIT=func AGENADO.MST(156,142) : # "Codes activités liés"
        Write [ADO]
    Endif
  Endif

# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="ACV_"+num$([ACV]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Codes activité" "Module" nom du module
    Read [AF1]CODINT="GESACV"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)-func AGENADO.RDM("ACT1","MODULE")
&           -func AGENADO.MST([ACV]MODULE,14)
    Write [ADO]
  Endif
  CODE_DOC="ACV_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Codes activité"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="ACV"

Return

# La fonction principale de génération des données de doc sur variables de dimensionnement
$GENE_ADMDOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[ADM]COD
  CODE_MODULE=[ADM]MODULE
  CODE_ACTIV="" : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.RDT([ADM]DES)

# Quelques mots-clés...
    Read [AFC]CODINT="GESADM"
    II=0
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    Call MAJMOTC(func AGENADO.RDT([AFC]NOM),TXT_TAB,II)
    Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADH]
    Write [ADO]

  Endif

  # Paragraphe de présentation
  Gosub CR_PRE

# Paragraphe lié aux valeurs recommandées
  PAR_DOC="REC" : [L]LEV=30 : [L]SUBLEV=10
  Gosub TST_CREER
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.MST(191,142) : # "Valeurs recommandées"
    Write [ADO]
  Endif

# Paragraphe lié aux tables concernées
  [ADO]PAR="ATB" : [L]LEV=100 : [L]SUBLEV=10
  Gosub LIT_VALEURS From AGENADO
  Gosub ATB_ADM From AGENADO
  If II>0
    Gosub CR_ATB
  Endif

# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="ADM_"+num$([ADM]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Eléments de dimensionnement" "Module" nom du module
    Read [AF1]CODINT="GESADM"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)-func AGENADO.RDM("ADM1","MODULE")
&           -func AGENADO.MST([ADM]MODULE,14)
    Write [ADO]
  Endif
  CODE_DOC="ADM_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Eléments de dimensionnement"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="ADM"

Return

# La fonction principale de génération des données de doc sur modèles d'import/export
$GENE_AOEDOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[AOE]EXT
  CODE_MODULE=[AOE]MODULE
  CODE_ACTIV="" : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
    [ADO]TIT=func AGENLIBA.RECH_DESIGNATION('AOE', [AOE]EXT, '')

    # Quelques mots-clés...
    II=0
    Call MAJMOTC(func AGENADO.RDM("AOE0","EXT"),TXT_TAB,II)
    If [AOE]IMPORT=2
        Read [AFC]CODINT="GIMPOBJ"
        Call MAJMOTC(func AGENADO.RDT([AFC]NOM),TXT_TAB,II)
    Endif
    If [AOE]EXPORT=2
        Read [AFC]CODINT="GEXPOBJ"
        Call MAJMOTC(func AGENADO.RDT([AFC]NOM),TXT_TAB,II)
    Endif
    Call MAJMOTC(func AGENADO.RDT([AFC]NOM),TXT_TAB,II)
    Call MAJMOTC(format$("N0:3",[AOE]MODULE)+",014",TXT_TAB,II)
    Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADH]
    Write [ADO]
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
        [ADO]TIT=func AGENLIBA.RECH_DESIGNATION('AOE', [AOE]EXT, '')
    Endif
    Rewrite [ADO]
  Endif

  # Paragraphe de présentation
  Gosub CR_PRE

# Paragraphe pré-requis
  PAR_DOC="PRQ" : [L]LEV=30 : [L]SUBLEV=10
  Gosub TST_CREER
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.MST(4,142)
    Write [ADO]
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(4,142)
    Endif
    Rewrite [ADO]
  Endif

# Paragraphe paramètres à renseigner
  PAR_DOC="ADP" : [L]LEV=30 : [L]SUBLEV=20
  Gosub TST_CREER
  If REGEN
    Gosub SET_ADO
    Gosub LIT_VALEURS From AGENADO
    Gosub LIT_AUSSI_VALINV From AGENADO
    If II>0
        [ADO]TIT=func AGENADO.MST(72,142) : # "Paramètres à renseigner"
        [ADO]STY=4
        Write [ADO]
    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(72,142) : # "Paramètres à renseigner"
    Endif
    Rewrite [ADO]
  Endif

# Tables à renseigner
  PAR_DOC="AT2" : [L]LEV=30 : [L]SUBLEV=30
  Gosub TST_REGEN
  If REGEN
#VPO 22/09/08 49314
#    Gosub SET_ADO
#    LNK_TYPE="AT2"
#    Gosub LIT_VALEURS From AGENADO
#    If II>0
#        [ADO]TIT=func AGENADO.MST(51,142) : # "Tables à renseigner"
#        [ADO]STY=4
#        Write [ADO]
#    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(51,142) : # "Tables à renseigner"
    Endif
    [ADO]CODACT="FAL" : #VPO 22/09/08 49314
    Rewrite [ADO]
  Endif

#VPO 22/09/08 49314
# Paragraphe relatif aux pre-requis divers
  PAR_DOC="PRD" : [L]LEV=30 : [L]SUBLEV=90
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    # On génère ce paragraphe s'il existe au moins un lien de type ADI, AT2, ou AML dans la table des liens
    LNK_TYPE="ADI"
    Gosub LIT_PAR_VAL From AGENADO
    If II=0
        LNK_TYPE="AT2"
        Gosub LIT_PAR_VAL From AGENADO
        If II=0
            LNK_TYPE="AML"
            Gosub LIT_PAR_VAL From AGENADO
        Endif
    Endif
    If II<>0
        [ADO]TIT="" : # func AGENADO.MST(57,142), qui contient "Pré-requis divers", est inutile...
        [ADO]STY=4
        Write [ADO]
    Endif
  Else
    [ADO]TIT="" : # func AGENADO.MST(57,142), qui contient "Pré-requis divers", est inutile...
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif


# Champs obligatoires
  PAR_DOC="CHO" : [L]LEV=40 : [L]SUBLEV=10
  Gosub TST_CREER
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.MST(207,142) : # "Champs obligatoires du modèle"
    Write [ADO]
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(207,142) : # "Champs obligatoires du modèle"
    Endif
    Rewrite [ADO]
  Endif

# Messages d'erreur
  Gosub CR_ERR

# Tables mises à jour
  [ADO]PAR="ATB" : [L]LEV=100 : [L]SUBLEV=10
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    Gosub LIT_VALEURS From AGENADO
    Gosub ATB_AOE From AGENADO
    Gosub CR_ATB
  Endif

# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="AOE_"+num$([AOE]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Modèles d'import/export" "Module" nom du module
    Read [AF1]CODINT="GESAOE"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)-func AGENADO.RDM("AOE1","MODULE")
&           -func AGENADO.MST([AOE]MODULE,14)
    Write [ADO]
  Endif
  CODE_DOC="AOE_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Modèles d'import/export"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="AOE"

Return

# La fonction principale de génération des données de doc sur états
$GENE_ARPDOC
# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[ARP]RPTCOD
  CODE_MODULE=[ARP]MODULE
  CODE_ACTIV="" : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.RDT([ARP]RPTDES)

# Quelques mots-clés...
    II=0
    Call MAJMOTC(func AGENADO.RDM("AIA1","RPTCOD"),TXT_TAB,II)
    Call MAJMOTC(func AGENADO.RDM("AOB1","RPT1"),TXT_TAB,II)
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    Call MAJMOTC(format$("N0:3",[ARP]MODULE)+",014",TXT_TAB,II)
    Call MAJMOTC(format$("N0:3",[ARP]GRP)+",097",TXT_TAB,II)
    Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADH]
    Write [ADO]
  Else
    #VPO 28/04/08 bug47169 on renseigne TITRE s'il ne l'est pas
    Gosub TST_REGENADH
    If TEXTES=""
    # Quelques mots-clés...
        II=0
        Call MAJMOTC(func AGENADO.RDM("AIA1","RPTCOD"),TXT_TAB,II)
        Call MAJMOTC(func AGENADO.RDM("AOB1","RPT1"),TXT_TAB,II)
        Call MAJMOTC([ADO]TIT,TXT_TAB,II)
        Call MAJMOTC(format$("N0:3",[ARP]MODULE)+",014",TXT_TAB,II)
        Call MAJMOTC(format$("N0:3",[ARP]GRP)+",097",TXT_TAB,II)
        Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))

        If REGEN=2
            [ADH2]TEXTE=[ADH]TEXTE
            Rewrite [ADH2]
        Elsif REGEN=1
            Rewrite [ADH]
        Else
            Write [ADH]
        Endif
    Endif
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.RDT([ARP]RPTDES)
    Endif
    Rewrite [ADO]
  Endif

  # Paragraphe de présentation
  Gosub CR_PRE

# Paragraphe pré-requis
  PAR_DOC="PRQ" : [L]LEV=30 : [L]SUBLEV=10
  Gosub TST_CREER
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.MST(4,142) : # "Pré-requis"
    Write [ADO]
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(4,142) : # "Pré-requis"
    Endif
    Rewrite [ADO]
  Endif

# Paragraphe accès à l'état
  PAR_DOC="AFC" : [L]LEV=30 : [L]SUBLEV=20
  Gosub TST_REGEN
  If REGEN
    Gosub LIT_VALINV From AGENADO
    Gosub AFC_ARP
    If II>0
        Gosub SET_ADO
        [ADO]TIT=func AGENADO.MST(169,142) : # "Accès à l'état"
        [ADO]STY=4
        Write [ADO]
    Endif
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(169,142) : # "Accès à l'état"
    Endif
    Rewrite [ADO]
  Endif

# Critères de l'état (uniquement s'il y a des paramètres)
  II=0
  For [ARD] Where RPTCOD=CODE_DOC
    II=1 : Break
  Next
  If II
    PAR_DOC="CRI" : [L]LEV=30 : [L]SUBLEV=30
    Gosub TST_CREER
    If REGEN
        Gosub SET_ADO
        [ADO]TIT=func AGENADO.MST(37,142) : # "Liste des critères"
        [ADO]STY=4
        Write [ADO]
    Else
        #VPO 12/06/08 41386
        If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
            [ADO]TIT=func AGENADO.MST(37,142) : # "Liste des critères"
        Endif
        Rewrite [ADO]
    Endif
  Endif

# Description de l'état
  PAR_DOC="DES" : [L]LEV=40 : [L]SUBLEV=10
  Gosub TST_CREER
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.MST(209,142) : # "Description de l'état"
    Write [ADO]
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(209,142) : # "Description de l'état"
    Endif
    Rewrite [ADO]
  Endif

# Paragraphe lié aux tables concernées par l'état
  [ADO]PAR="ATB" : [L]LEV=100 : [L]SUBLEV=10
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    Gosub LIT_VALEURS From AGENADO
    Gosub ATB_ARP
    If II>0
        Gosub CR_ATB
    Endif
  Endif

# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="ARP_"+num$([ARP]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Etats" "Module" nom du module
    Read [AF1]CODINT="GESARP"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)-func AGENADO.RDM("ARP1","MODULE")
&           -func AGENADO.MST([ARP]MODULE,14)
    Write [ADO]
  Endif
  CODE_DOC="ARP_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Etats"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="ARP"

Return

#VPO 14/01/08 41049,42137 doc ABO
# La fonction principale de génération des données de doc sur états BO
$GENE_ABODOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[ABO]COD
  CODE_MODULE=[ABO]MODULE
  CODE_ACTIV="" : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.RDT([ABO]DES)

# Quelques mots-clés...
    II=0
    Call MAJMOTC(func AGENADO.RDM("ABO1",""),TXT_TAB,II)
    Call MAJMOTC(func AGENADO.RDM("ABIIMP",""),TXT_TAB,II)
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    Call MAJMOTC(format$("N0:3",[ABO]MODULE)+",014",TXT_TAB,II)
    Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADH]
    Write [ADO]
  Else
    Gosub TST_REGENADH
    If TEXTES=""
    # Quelques mots-clés...
        II=0
        Call MAJMOTC(func AGENADO.RDM("ABO1",""),TXT_TAB,II)
        Call MAJMOTC(func AGENADO.RDM("ABIIMP",""),TXT_TAB,II)
        Call MAJMOTC([ADO]TIT,TXT_TAB,II)
        Call MAJMOTC(format$("N0:3",[ABO]MODULE)+",014",TXT_TAB,II)
        Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))

        If REGEN=2
            [ADH2]TEXTE=[ADH]TEXTE
            Rewrite [ADH2]
        Elsif REGEN=1
            Rewrite [ADH]
        Else
            Write [ADH]
        Endif
    Endif
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.RDT([ABO]DES)
    Endif
    Rewrite [ADO]
  Endif

  # Paragraphe de présentation
  Gosub CR_PRE


# Critères de l'état (uniquement s'il y a des paramètres)
  II=0
  For [ABQ] Where COD=CODE_DOC
    II=1 : Break
  Next
  If II
    PAR_DOC="CRI" : [L]LEV=20 : [L]SUBLEV=10
    Gosub TST_CREER
    If REGEN
        Gosub SET_ADO
        [ADO]TIT=func AGENADO.MST(250,142) : # "Invites utilisateur"
        Write [ADO]
    Else
        #VPO 12/06/08 41386
        If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
            [ADO]TIT=func AGENADO.MST(250,142) : # "Invites utilisateur"
        Endif
        Rewrite [ADO]
    Endif
  Endif


# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="ABO_"+num$([ABO]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Etats" "Module" nom du module
    Read [AF1]CODINT="GESABO"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)-func AGENADO.RDM("ABO1","MODULE")
&           -func AGENADO.MST([ABO]MODULE,14)
    Write [ADO]
  Endif
  CODE_DOC="ABO_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Etats"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="ABO"

Return

#VPO 04/09/08 48971 ajout ABF et ABM
# La fonction principale de génération des données de doc sur table de faits ABF
$GENE_ABFDOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[ABF]CODABF
  CODE_MODULE=[ABF]MODULE #TCH 05/06/2014 100639 SI029 modules sur tables de fait
  CODE_ACTIV=[ABF]CODACT : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.RDM("ABF1","")-func AGENADO.RDT([ABF]INTIT)

# Quelques mots-clés...
    II=0
    Call MAJMOTC(func AGENADO.RDM("ABF1",""),TXT_TAB,II)
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADH]
    Write [ADO]
  Else
    Gosub TST_REGENADH
    If TEXTES=""
    # Quelques mots-clés...
        II=0
        Call MAJMOTC(func AGENADO.RDM("ABF1",""),TXT_TAB,II)
        Call MAJMOTC([ADO]TIT,TXT_TAB,II)
        Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))

        If REGEN=2
            [ADH2]TEXTE=[ADH]TEXTE
            Rewrite [ADH2]
        Elsif REGEN=1
            Rewrite [ADH]
        Else
            Write [ADH]
        Endif
    Endif
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.RDM("ABF1","")-func AGENADO.RDT([ABF]INTIT)
    Endif
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif

  # Paragraphe de présentation
  Gosub CR_PRE

# Génération des paragraphes liés aux menus intermédiaires
# TCH 05/06/2014 100639 SI029 modules sur tables de fait
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="ABF_"+num$([ABF]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Tables fait" "Module" nom du module
    Read [AF1]CODINT="GESABF"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)-func AGENADO.RDM("ABF1","MODULE")
&           -func AGENADO.MST([ABF]MODULE,14)
    Write [ADO]
  Endif
  #
  COD_TYP="APM" : PAR_DOC="LNK" : [L]LEV=10 : [L]SUBLEV=20
  CODE_DOC="ABF_"+num$([ABF]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    Setlob [ADH]TEXTE With "<P>APM/ABF_0</P><P>DI/BI_0</P>"
    Write [ADH]
    #VPO 11/01/08 41171
    Gosub SET_VLD
    [ADO]TIT=""
    Write [ADO]
  Endif
  ###
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="ABF_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    Read [AF1]CODINT="GESABF"
    # "Table de faits"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)
    Write [ADO]
  Endif

  #VPO 14/10/08 49749: ajout lien depuis DI/BI_0
  COD_TYP="APM" : PAR_DOC="LNK" : [L]LEV=10 : [L]SUBLEV=20
  CODE_DOC="ABF_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    Setlob [ADH]TEXTE With "<P>DI/BI_0</P>"
    Write [ADH]
    #VPO 11/01/08 41171
    Gosub SET_VLD
    [ADO]TIT=""
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="ABF"

Return

