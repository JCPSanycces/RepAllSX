# Pile des menus pour les menus
$PILE_APMMEN
  IPIL=1
  Read [AFC]CODINT=[ADO]COD
  If fstat=0
    Goto PILE_AFCMEN
  Endif

# La pile des menus dans le cas des menus intermédiaires complémentaires
# Sauf si le code est déjà XXX_0, on remonte sur XXX_0
  IPIL=1
  PILE_MEN(IPIL)=""
  PILE_NOMEN(IPIL)=[ADO]TIT
  If pat([ADO]COD,"???_*")<>0
    If pat([ADO]COD,"???_0")=0
        Case left$([ADO]COD,3)
            When "ABF" : Gosub PILE0_ABFMEN : #VPO 04/09/08 48971 ajout ABF et ABM
            When "ABM" : Gosub PILE0_ABMMEN : #VPO 04/09/08 48971 ajout ABF et ABM
            When "ABO" : Gosub PILE0_ABOMEN : #VPO 14/01/08 41049,42137 doc ABO
            When "ACT" : Gosub PILE0_ACTMEN
            When "ACV" : Gosub PILE0_ACVMEN
            When "ADC" : Gosub PILE0_ADCMEN
            When "ADM" : Gosub PILE0_ADMMEN
            When "ADP" : Gosub PILE0_ADPMEN
            When "AGB" : Gosub PILE0_AGBMEN
            When "AML" : Gosub PILE0_AMLMEN
            When "AOE" : Gosub PILE0_AOEMEN
            When "ARP" : Gosub PILE0_ARPMEN
            When "ASU" : Gosub PILE0_ASUMEN
            #VPO 19/06/08 39766 ajout ATD: différences de tables
            #VPO 27/10/08 49955 ajout AT3: différences de tables 130
            When "ATD","AT3" : Gosub PILE0_ATDMEN
            When "ATB" : Gosub PILE0_ATBMEN
            When "ATY" : Gosub PILE0_ATYMEN
            When "AWA" : Gosub PILE0_AWAMEN
            When "CDA" : Gosub PILE0_CDAMEN
            When "CDE" : Gosub PILE0_CDEMEN
            When "GAU" : Gosub PILE0_GAUMEN
            When "PS1" : Gosub PILE0_PS1MEN
            When "AHI" : Gosub PILE0_AHIMEN
        Endcase
    Else
        ##VPO 13/11/07 BUG43701 on supprime le lien redondant vers sommaire
        ##IPIL+=1
        ##PILE_MEN(IPIL)="../index"
        ##PILE_NOMEN(IPIL)=ctrans(mess(41,9138,1),"&","") : # Sommaire
        IPIL+=1
    Endif
  Endif
Return

# Pile des menus pour les fonctions
$PILE_AFCMEN
  IPIL=1
  Read [AFC]CODINT=[ADO]COD
  If [AFC]MENU<>""
    While fstat=0 & [AFC]CODINT<>"GENE" & IPIL<6
        PILE_MEN(IPIL)=[AFC]CODINT
        PILE_NOMEN(IPIL)=func AGENADO.RDT([AFC]LIBMENU)
        # VPO 09/06/08 bug47517
        If PILE_NOMEN(IPIL) = "" & [AFC]CODINT="VT"
            PILE_NOMEN(IPIL)=func AGENADO.RDT([AFC]NOM)
        Endif
        IPIL+=1
        Read [AFC]CODINT=[AFC]MENU
    Wend

    # On restaure la fonction courante
    Read [AFC]CODINT=[ADO]COD

  Else
    PILE_MEN(IPIL)=[AFC]CODINT
    PILE_NOMEN(IPIL)=func AGENADO.RDT([AFC]LIBMENU)
    # VPO 09/06/08 bug47517
    If PILE_NOMEN(IPIL) = "" & [AFC]CODINT="VT"
        PILE_NOMEN(IPIL)=func AGENADO.RDT([AFC]NOM)
    Endif
    IPIL+=1

    # On cherche à voir où la fonction est utilisée
    Gosub REC_FNC
    If [AFC]MENU=""
        Read [AFC]CODINT=[ADO]COD
    Endif

# On recherche à nouveau la pile des menus
    While fstat=0 & [AFC]CODINT<>"GENE" & IPIL<6 & [AFC]MENU<>""
        PILE_MEN(IPIL)=[AFC]CODINT
        PILE_NOMEN(IPIL)=func AGENADO.RDT([AFC]LIBMENU)
        IPIL+=1
        Read [AFC]CODINT=[AFC]MENU
    Wend

    # On restaure la fonction et la fenêtre courantes
    Gosub LIREWIN From AGENADO
  Endif
Return

