    Gosub SET_ADO
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    If TEXTES(1)=""
        # On ne met plus "à renseigner" pour faciliter la traduction
#       TXT_PARAG="<p>"+func AGENADO.MST(148,142)+"</p>" : # "A renseigner"
        Setlob [ADH]TEXTE With TXT_PARAG(1..1)
    Else
        Setlob [ADH]TEXTE With TEXTES(1..4)
    Endif
    [ADO]TIT=func AGENADO.MST(2,142) : # "Présentation"
    Write [ADH]
    Write [ADO]
  Else
    #VPO 12/06/08 41386
    If left$([ADO]TIT,1)="[" & right$(vireblc([ADO]TIT,2),len(vireblc([ADO]TIT,2)))="]"
        [ADO]TIT=func AGENADO.MST(2,142) : # "Présentation"
    Endif
    If [ADO]TYP="ASU" : [ADO]MODULE=CODE_MODULE : Endif
    #VPO 11/01/08 40090
    Gosub SET_ACTIV
    Rewrite [ADO]
  Endif
Return

