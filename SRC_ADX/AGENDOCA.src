# La fonction principale de génération des données de doc sur événements Workflow
$GENE_AWADOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[AWA]CODE

# Recherche d'un code module
  CODE_MODULE=9 : # Tronc commun...
  CODE_ACTIV="" : #VPO 11/01/08 40090
  If [AWA]TYPEVT=2
    Read [AOB]ABREV=[AWA]CODEVT
    If fstat=0
        CODE_MODULE=[AOB]MODULE
    Endif
  Elsif [AWA]TYPEVT=3
    Read [AFC]CODINT=[AWA]CODEVT
    If fstat=0
        CODE_MODULE=[AFC]MODULE
    Endif
  Elsif [AWA]TYPEVT=4
    Read [ARP]ARP0=[AWA]CODEVT
    If fstat=0
        CODE_MODULE=[ARP]MODULE
    Endif
  Elsif [AWA]TYPEVT=5 or [AWA]TYPEVT=6
    Read [ABT]CODTAC=[AWA]CODEVT
    If fstat=0
        CODE_MODULE=[ABT]MODULE
    Endif
  Elsif [AWA]TYPEVT=7
    Read [AOE]AOE0=[AWA]CODEVT
    If fstat=0
        CODE_MODULE=[AOE]MODULE
    Endif
  Elsif [AWA]TYPEVT=1
    Case [AWA]CODEVT
        When "CON","DEC","KIL","PWD","TIM","TRA"
            CODE_MODULE=1
    Endcase
  Endif

  If CODE_MODULE=9 and [AWA]MODELE<>""
    Read [AWM]AWM0=[AWA]MODELE
    If fstat=0
        CODE_MODULE=[AWM]MODULE
    Endif
  Endif

  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
    [ADO]TIT=func AGENLIBA.RECH_DESIGNATION('AWA', [AWA]CODE, '')

# Quelques mots-clés...
    II=0
    Call MAJMOTC(func AGENADO.RDM("AWA0",""),TXT_TAB,II)
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    Call MAJMOTC(format$("N0:3",[AWA]TYPEVT)+",988",TXT_TAB,II)
    Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADH]
    Write [ADO]

  Endif

# Paragraphe de présentation
  Gosub CR_PRE

# Paragraphe relatif aux flux
# Généré s'il y a au moins un suivi
  Read [AWF]AWF0=[AWA]CODE
  If [AWF]NBRSIG>2
    PAR_DOC="FLW" : [L]LEV=20 : [L]SUBLEV=10
    Gosub TST_REGEN
    If REGEN
        Gosub SET_ADO
        [ADO]TIT=func AGENADO.MST(157,142) : # "Description du flux de Workflow"
        Write [ADO]
    Endif
  Endif

# Paragraphe contexte (en 30,10)
  Gosub CR_CTX

# Paragraphe relatif aux critères de déclenchement s'il y en a au moins un
  If [AWA]NBCOND>0
    PAR_DOC="TRG" : [L]LEV=30 : [L]SUBLEV=20
    Gosub TST_REGEN
    If REGEN
        Gosub SET_ADO
        [ADO]TIT=func AGENADO.MST(143,142) : # "Critères de déclenchement"
        [ADO]STY=4
        Write [ADO]
    Endif
  Endif

# Paragraphe relatif aux destinataires
  PAR_DOC="DST" : [L]LEV=30 : [L]SUBLEV=30
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.MST(144,142) : # "Destinataires"
    [ADO]STY=4
    Write [ADO]
  Endif

# Paragraphe relatif aux choix de signatures s'il y en a
  PAR_DOC="SIG" : [L]LEV=30 : [L]SUBLEV=40
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    If [AWF]NBRSIG>0
        [ADO]TIT=func AGENADO.MST(147,142) : # "Choix de signatures"
        [ADO]STY=4
        Write [ADO]
    Endif
  Endif

# Paragraphe relatif aux workflow associés s'il en existe
  PAR_DOC="AWA" : [L]LEV=40 : [L]SUBLEV=10
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    # On génère ce paragraphe s'il existe au moins un lien de type AWA dans la table des liens
    LNK_TYPE="AWA"
    Gosub LIT_PAR_VAL From AGENADO
    If II<>0
        [ADO]TIT=func AGENADO.MST(125,142) : # "Règles de Workflow liées"
        Write [ADO]
    Endif
  Endif

# Paragraphe relatif aux actions déclenchées
  PAR_DOC="ACT" : [L]LEV=50 : [L]SUBLEV=10
  Gosub TST_REGEN
  If REGEN
    Gosub SET_ADO
    II=0
    For [AWC]AWC0 Where CODE=[AWA]CODE
        II+=1 : Break
    Next
    If II<>0
        [ADO]TIT=func AGENADO.MST(134,142) : # "Règles de Workflow déclenchées par l'événement"
        Write [ADO]
    Endif
  Endif

# Paragraphe tables concernées
  [ADO]PAR="ATB" : [L]LEV=100 : [L]SUBLEV=10
  Gosub LIT_VALEURS From AGENADO
  Gosub ATB_AWA From AGENADO
  Gosub CR_ATB

# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="AWA_"+[AWA]CATEG
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Règles workflow" "Catégorie" code catégorie (intitulé)
    Read [AF1]CODINT="GESAWA"
    # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)-func AGENADO.RDM("AWA0","CATEG")
&           -[AWA]CATEG-"("+func AGENLIBA.RECH_DESIGNATION('ADI', '51', [AWA]CATEG)+")"
    Write [ADO]
  Endif
  CODE_DOC="AWA_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Règles Workflow"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="AWA"

Return

# La fonction principale de génération des données de doc sur codes section
$GENE_CDEDOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  # JPGA 19/08/2009 Bug-52238 : Procedure de recherche pour savoir si on est en présence de clé multiples pour les docs
  Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
  If find(COD_TYP, [L]DOC_CLE_MULT)
    CODE_DOC=[CDE]COD+[L]WTIRET+[CDE]CPY
  Else
    CODE_DOC=[CDE]COD
  Endif
  CODE_MODULE=[CDE]MODULE
  CODE_ACTIV="" : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.RDM("CDE1","")

# Quelques mots-clés...
    II=0
    # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
    Call MAJMOTC(func AGENLIBA.RECH_DESIGNATION('CDE', [CDE]COD, ''),TXT_TAB,II)
    Call MAJMOTC(format$("N0:3",[CDE]MODULE)+",014",TXT_TAB,II)
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADH]
    Write [ADO]

  Endif

  # Paragraphe de présentation
  Gosub CR_PRE

# Paragraphe mode opératoire
  Gosub CR_OPM

# Paragraphe remarques
  Gosub CR_REM

# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="CDE_"+num$([CDE]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Pièces automatiques" "Module" nom du module
    Read [AF1]CODINT="GESCDE"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)-func AGENADO.RDM("CDE1","MODULE")
&           -func AGENADO.MST([CDE]MODULE,14)
    Write [ADO]
  Endif

  CODE_DOC="CDE_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Sections par défaut"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)
    Write [ADO]
  Endif


# Remise à jour du code type
  COD_TYP="CDE"

Return

# La fonction principale de génération des données de doc sur pièces automatiques
$GENE_GAUDOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[GAU]COD
  CODE_MODULE=[GAU]MODULE
  CODE_ACTIV="" : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.RDM("GAU1","")

# Quelques mots-clés...
    II=0
    Call MAJMOTC([GAU]DES,TXT_TAB,II) :  # A rendre traduisible
    Call MAJMOTC(format$("N0:3",[GAU]MODULE)+",014",TXT_TAB,II)
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADH]
    Write [ADO]

  Endif

  # Paragraphe de présentation
  Gosub CR_PRE

# Paragraphe mode opératoire
  Gosub CR_OPM

# Paragraphe écritures générées
  Gosub CR_ECG

# Paragraphe remarques
  Gosub CR_REM

# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="GAU_"+num$([GAU]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Pièces automatiques" "Module" nom du module
    Read [AF1]CODINT="GESGAU"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)-func AGENADO.RDM("GAU1","MODULE")
&           -func AGENADO.MST([GAU]MODULE,14)
    Write [ADO]
  Endif

  CODE_DOC="GAU_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Pièces automatiques "
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="GAU"

Return

# La fonction principale de génération des données de doc sur événements déclenchants de statistiques
$GENE_PS1DOC

# Arrêt si la génération se fait sur la doc existante et que la doc n'existe pas
  CODE_DOC=[PS1]COD
  CODE_MODULE=[PS1]MODULE
  CODE_ACTIV="" : #VPO 11/01/08 40090
  If func AGENLIBA.DOC_NE_PAS_GENERER (GEN_DOC, COD_LAN, COD_TYP, CODE_DOC) : Return : Endif
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If ! func AGENLIBA.TEST_GROUPE_OK("ADO", COD_LAN, COD_TYP, CODE_DOC, "[M:DIA]ALLCREGRP") : Return : Endif

  [V]NB_GEN_ADOC+=1
  # Paragraphe de titre
  PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  Gosub TST_CREER
  Gosub TRACE_COR_TIT
  If REGEN
    Gosub SET_ADO
    [ADO]TIT=func AGENADO.RDM("PS10","")+CODE_DOC
    # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
    [ADO]TIT-="("+func AGENLIBA.RECH_DESIGNATION('PS1', [PS1]COD, '')+")"

    # Quelques mots-clés...
    II=0
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
    Call MAJMOTC(func AGENLIBA.RECH_DESIGNATION('PS1', [PS1]COD, ''),TXT_TAB,II)
    Call MAJMOTC(format$("N0:3",[PS1]MODULE)+",014",TXT_TAB,II)
    Call MAJMOTC([ADO]TIT,TXT_TAB,II)
    Setlob [ADH]TEXTE With sigma(1,max(1,II),string$(indcum>1,",")+TXT_TAB(indcum))
    Write [ADH]
    Write [ADO]

  Endif

  # Paragraphe de présentation
  Gosub CR_PRE

# Paragraphe contexte
  Gosub CR_CTX

# Paragraphe remarques
  Gosub CR_REM

# Paragraphe tables concernées
  [ADO]PAR="ATB" : [L]LEV=100 : [L]SUBLEV=10
  Gosub LIT_VALEURS From AGENADO
  Gosub ATB_PS1
  Gosub CR_ATB

# Génération des paragraphes liés aux menus intermédiaires
  COD_TYP="APM" : PAR_DOC="TIT" : [L]LEV=10 : [L]SUBLEV=10
  CODE_DOC="PS1_"+num$([PS1]MODULE)
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Evénements déclenchants" "Module" module
    Read [AF1]CODINT="GESPS1"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)-func AGENADO.RDM("PS11","MODULE")-func AGENADO.MST([PS1]MODULE,14)
    Write [ADO]
  Endif
  CODE_DOC="PS1_0"
  CODE_MODULE=1
  Gosub SET_ADO_VLD
  Gosub TST_REGEN
  If REGEN
    #VPO 11/01/08 41171
    Gosub SET_VLD
    # "Evénements déclenchants"
    [ADO]TIT=func AGENADO.RDT([AF1]NOM)
    Write [ADO]
  Endif

# Remise à jour du code type
  COD_TYP="PS1"

Return

