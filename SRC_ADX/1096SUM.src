#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION

Case ACTION
  When "CONTPRT" : Gosub CONTPRT
  When Default  :
 Endcase
Return
#########################################################################

#########################################################################

#-----------------------------------------#
# Contrﾃｴle destination (choix imprimante) #
# --------------------------------------- #
#  Prﾃｩchargement du nombre de copies      #
#  Par dﾃｩfaut provient des destinations   #
#-----------------------------------------#
$CONTPRT

If GFONCTION<> "BPS1099GEN"
  Grizo [M:RPT]10-50
Endif

Return

#########################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

If GFONCTION<> "BPS1099GEN"
  GMESSAGE = mess(170,142,1)
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  GOK=0
  GERR=1
  End
Endif

Call EXEC(NBPAR,PARAMETRE)

End
######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value Integer    NBPAR
Variable Char    PARAMETRE()()
# -- ARCCLIENT2
Local Date    DATREF

#--- ouverture des tables
Gosub OUVRE
Lock [F:B96R] With lockwait=10
#--- declaration des variables
Gosub DECLARE

# Page align only
If VALINT1(0)="2"
 Gosub ALIGN
 End
Endif


# 1096 Generated table
#103113.so
#Filter [F:B9G] Where [F:B9G]YR1099=[M:B9G]THEYEAR & [F:B9G]CPY=[M:B9G]THECPY & [F:B9G]FRM1099=2 &
#&                    find([F:B9G]BOX1099,"1","2","3","4","5","6","7","8","10","11","13","14","15a","15b","16","18")
#&                    Order By [F:B9G]BPSNUM
#103113.eo

#103113.sn Changes for 2014 requirements (Remove Box 11)
Filter [F:B9G] Where [F:B9G]YR1099=[M:B9G]THEYEAR & [F:B9G]CPY=[M:B9G]THECPY & [F:B9G]FRM1099=2 &
&                    find([F:B9G]BOX1099,"1","2","3","4","5","6","7","8","10","13","14","15a","15b","16","18")
&                    Order By [F:B9G]BPSNUM
#103113.en

Gosub TRT_B96

Filter [B9G]

End

###################################################################
###################################################################
$TRT_B96
Raz WNUMLIG
Default File [B96R]

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [B96R] : Endif
Delete [B96R] Where 1=1
Commit

Gosub TR2
 Unlock [F:B96R]
Return

##########################################################################
$TR2

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [B96R] : Endif
#Crﾃｩation de l'enregistrement dans la table BP1096PRN
WNUMLIG      += 1

Raz [F:B96R]
Raz SAVBPS

For [F:B9G]
    If SAVBPS<>[F:B9G]BPSNUM  # Count forms on a recipient basis
     [F:B96R]FRMCNT  += 1
    Endif
    [F:B96R]USR     = GUSER
    [F:B96R]RPTCOD  = [F:ARP]RPTCOD
    [F:B96R]NUMREQ  = [L]NUMREQ
    [F:B96R]NUMLIG  = WNUMLIG
    [F:B96R]YR1099  = [F:B9G]YR1099
    [F:B96R]CPY     = [F:B9G]CPY
    If find([F:B9G]BOX1099, "1","2","3","5","6","7","8","10","13","14") <> 0  : [F:B96R]AMT1099 += [F:B9G]AMT1099 : Endif #Exclude amt from Box 4, 15a (which is 19), 15b, 16, 18
    [F:B96R]CREDAT  = date$
    If (instr(1,[M:B9G]TEL,'-')) > 0 # - in phone number
     [F:B96R]TEL = [M:B9G]TEL
     [F:B96R]FAX = [M:B9G]FAX
    Else
     [F:B96R]TEL = left$([M:B9G]TEL,3) + " " + mid$([M:B9G]TEL,4,3) + "-" + right$([M:B9G]TEL,7)
     [F:B96R]FAX = left$([M:B9G]FAX,3) + " " + mid$([M:B9G]FAX,4,3) + "-" + right$([M:B9G]FAX,7)
    Endif
    If [F:B9G]BOX1099="4" : [F:B96R]AMTBOX4 += [F:B9G]AMT1099 : Endif
    SAVBPS=[F:B9G]BPSNUM
Next

Write [F:B96R]
If fstat : GOK = 0 : Call FSTA("B96R") From GLOCK : Goto AB_TR2 : Endif
Commit
Return


$ROLL_TR2
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$AB_TR2
Rollback
Return

###########################################################################
$ALIGN
Raz WNUMLIG
Default File [B96R]

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [B96R] : Endif
Delete [F:B96R] Where 1=1
Commit

Filter [F:B9G] Where [F:B9G]FRM1099=2 & [F:B9G]CPY = [M:B9G]THECPY & [F:B9G]YR1099 = [M:B9G]THEYEAR
Read [F:B9G] First
If fstat : Filter [F:B9G] : Return : Endif
Filter [F:B9G]

TMP_ADXLOG = adxlog
If !TMP_ADXLOG : Trbegin [B96R] : Endif
#Crﾃｩation de l'enregistrement dans la table BP1096PRN
WNUMLIG      += 1

Raz [F:B96R]
Raz SAVBPS

 Read [F:B96R]B96R0 =[F:B9G]YR1099;[F:B9G]CPY;[F:B9G]BPSNUM
 If fstat
    [F:B96R]USR     = GUSER
    [F:B96R]RPTCOD  = [F:ARP]RPTCOD
    [F:B96R]NUMREQ  = [L]NUMREQ
    [F:B96R]NUMLIG  = WNUMLIG
    [F:B96R]YR1099  = [F:B9G]YR1099
    [F:B96R]CPY     = [F:B9G]CPY
    [F:B96R]CREDAT  = date$
    [F:B96R]AMT1099 = 99999999.99
    [F:B96R]AMTBOX4 = 9999999.99
 Endif

Write [F:B96R]
If fstat : GOK = 0 : Call FSTA("B96R") From GLOCK : Goto AB_TR1 : Endif
Commit
Return

$ROLL_TR1
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto ALIGN : Endif

$AB_TR1
Rollback

Return

###########################################################################
$OUVRE
Local File BP1096PRN   [B96R]
If clalev ([F:B9G])=0   : Local File BPS1099GEN [B9G]   : Endif
If clalev ([F:B9M])=0   : Local File BPS1099MNT [B9M]   : Endif
If clalev ([F:B96R])=0  : Local File BP1096PRN  [B96R]  : Endif
If clalev ([F:BPS])=0   : Local File BPSUPPLIER [BPS]   : Endif

Return

###########################################################################
$DECLARE
Local Char    CRITERE(250), CRITERE2(255), PARAM(30) , VALEUR(30) , ETAT(15), SAVBPS(15)
Local Integer WNUMLIG, NUMREQ, IMPR, TMP_ADXLOG

Return

###########################################################################
