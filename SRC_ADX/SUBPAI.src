#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion objet PAI
Raz GPILOBJ
Call OBJET("PAI",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "LIENS"        : Gosub LIENS
 When "FILTRE"       : Gosub FILTRE
Endcase
Return

$OUVRE
If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
If clalev([F:CPY])=0    : Local File COMPANY    [CPY]   : Endif
If clalev([F:ID]) =0    : Local File EMPLOID    [ID]    : Endif
If clalev([F:HRREP])=0    : Local File REPART     [HRREP]   : Endif
If clalev([F:FDS])=0    : Local File FONDS      [FDS]   : Endif
If clalev([F:PAC])=0    : Local File PARCOL     [PAC]   : Endif
If clalev([F:HRCOT])=0  : Local File COTISATION [HRCOT] : Endif
If !clalev([F:ID3])     : Local File EMPLOID    [ID3]   : Endif # FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom

Return

#Impossible créer, de dupliquer ou de changer de clé
$SETBOUT
Call VIREBOUT (CHAINE,"CDH") From GOBJET
#Objet à 4 éléments de clé : Ajout du bouton suppression après que GOBJET l'ait viré !
If CLECUR & [M]STA=1
 CHAINE+="A"
Endif
If [M]STA>1 : # Répartition validée ou soldée
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
# FQ66382 - MABON 13/05/11 - Ajout menu Arrêté participation
If [F:PAI]TRFREQ<>2 & [F:PAI]STA>1 Then
  CHMEN += "A"
Endif
Return

$LIENS
Call AM_NUMPAR([F:PAI]NUMPAR)
Read [ID]ID0 = [F:PAI]REFNUM
If !fstat
 Call GRISE_CTRNUM([F:ID]FLGMULCTR)
Endif
# FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom
Call UPD_NAMSRN([F:PAI]REFNUM,"[M]","","SRN",0,0) From DIVPAYE
Return

$FILTRE
If GUSRACS<>2
 FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
Else
 FILTSUP = "1=1"
Endif
Return

Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M]CTRNUM
Else
 Diszo [M]CTRNUM
Endif
Affzo [M]CTRNUM
End



######################################################################################
## Etiquettes écrans
######################################################################################
Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
Call LECTURE("EML",VALEUR,"") From CONTOBJ
If VALEUR<>[M]REFNUM
 Read [F:PAI]PAI0=[M]CPY;VALEUR;[M]CTRNUM;[M]NUMPAR
 If fstat<=2
  [M]=[F:PAI]
  mkstat = 4
 Else
  GMESSAGE = mess(23,100,1)
  #Fiche inexistante
  mkstat = 2 : End
 Endif
Endif
End

Subprog AM_NUMPAR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("PAC",VALEUR,"") From CONTOBJ
 [M]EXO=[F:PAC]EXO
 Affzo[M]EXO
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran PAI0) 03/02/2009 16:56:34 (DBA)
######################################################################################
Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Read [ID]ID0 =VALEUR
If !fstat
 Call GRISE_CTRNUM([F:ID]FLGMULCTR)
Else
 Effzo CTRNUM
Endif
End

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Call SELCTR([M]REFNUM,[M]DAT,[M]DAT,VALEUR) From DIVPAYE
Endif
End
