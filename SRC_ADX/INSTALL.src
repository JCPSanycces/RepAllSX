#<AdxTL>@(#)6.0.0.0 $Revision$
Call INSTALL
End

######################################################################
Subprog INSTALL

Local Integer DBATYP , NBLAN
Local Decimal OLDVERS , RELEASE : #X3-15226 Manage sub-revision number
Local Char    LANGUE(10)(1..50) , LANDEF(10) , PARAM(250) , RELABR(10)
Local Char    RACINE(20) , DEMO(20) , RESULT(10) , APPLI(20)
Local Integer I , J , K , STAT , ER

If dim(GOK)<=0
 Global Integer GOK , GSERVEUR
 GOK = 1
 GSERVEUR = 1
Endif

Gosub GLOBVAR

# Ce qui caractérise le superviseur, c'est que la table ADOSSIER est locale

If filinfo(filpath("FIL","ADOSSIER","fde",0),0)<0
 GSUPERVIS = 0
Else
 GSUPERVIS = 1
Endif
If filinfo(filpath("","sophia_gaillard",""),0)>=0
 GSUPERVIS = 0
 Goto ABORT : # Pour pas le faire sur nos machines
Endif

# Le superviseur a-t-il été installé (présence du paramètre INSTALL)

If !GSUPERVIS
 For APPLI=nomap(1),nomap(2)
  If filinfo(filpath("FIL","ADOSSIER","fde",APPLI),0)>0
   RACINE = APPLI : Break
  Endif
 Next APPLI
 Onerrgo ERR
 If RACINE=""
  Call PARAM("","SUPDOS",RACINE) From ADOVAL
  Local File =RACINE+".ADOPAR" [ADP]
 Else
  Local File =RACINE+".ADOPAR" [ADP]
 Endif
 Read [ADP]ADP1 = "INSTALL"
 K = fstat
 Close Local File [ADP]
 Onerrgo
 If ER
  # Paramètres d'installation impossible à déterminer\Dossier # inaccessible
  Call ERREUR(func AFNC.MES(mess(184,125,1),RACINE)) From GESECRAN
  Goto ECHEC
 Elsif !K
  Goto ABORT
 Else
  # Installation du superviseur impossible\Il faut se connecter au dossier #
  Call ERREUR(func AFNC.MES(mess(179,125,1),RACINE)) From GESECRAN
  Goto ECHEC
 Endif
Else
 Local File ADOPAR [ADP]
 Read [ADP]ADP1 = "INSTALL"
 Close Local File [ADP]
 If !fstat : Goto ABORT : Endif
 RACINE = nomap
Endif

If dim(GADONIX)<=0
 Call GLOBVAR1 From GLOBVAR
 GOK = 1
 GSERVEUR = 1
Endif

Gosub GLOBVAR

# mb 28.11.13 bug 94736 affichage des boîtes messages pendant l'installation du superviseur

GTIMOUT = 5
Call ERREURT("The supervisor will complete its installation. This operation may take a few minutes",0) From GESECRAN

# Produit

Call PARAM("","TYPDOS",PARAM) From ADOVAL
GPRODUIT = val(PARAM)-1

# Release
#106969
# caution value must be in decimal for release
# release is a decimal variable caution with the value like 90.010.... in character
# num$() --> "90.01" not exactly the same as "90.010"
# release must stay in decimal a fct is available in aproduct to convert in the right way teh value
# when we need to write the param.

RELEASE=func APRODUCT._AGETINSTRELEASE()
RELABR=func APRODUCT._AGETINSTRELABR()

# Phase d'installation du superviseur
adxrob(0) = "ECR"
adxrob(1) = "M"+messname(0)

Call TEMPON(mess(179,123,1)) From GESECRAN : # Installation superviseur

# Identification du type de base

Local Char FICSRC(250) , LIGNE(80)
FICSRC = filpath("FIL","ADOSSIER","srf",0)
Openi FICSRC
adxifs = "" : adxirs = chr$(10)
Rdseq LIGNE
Rdseq LIGNE
Rdseq LIGNE
Rdseq LIGNE
Openi
Case left$(LIGNE,1)
 When "2" : DBATYP = 3 : # C-ISAM
 When "3" : DBATYP = 1 : # Oracle
 When "5" : DBATYP = 2 : # SQL-Serveur
 When "6" : DBATYP = 4 : # DB2
 When Default
  Call ERREUR(mess(180,123,1)) From GESECRAN : # Type de base incorrect
  Goto ECHEC
Endcase

# Recherche des langues

Local File ATEXTE [ATX]
NBLAN = 0
For [ATX]NUMERO(1)
 NBLAN += 1
 LANGUE(NBLAN) = [F:ATX]LAN
Next
If find(messname,LANGUE(1..NBLAN))
 LANDEF = messname
Else
 LANDEF = LANGUE(1)
Endif

# Dossier X3

Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = nomap
If fstat : # Il n'existe pas, c'est une première installation...
 Call CREDOS(nomap,DBATYP,LANDEF,LANGUE,NBLAN)
 If GOK<1 : Goto ECHEC : Endif
Else
 Call PARAM("","RELEASE",PARAM) From ADOVAL
 OLDVERS = val(PARAM)
Endif

# Transfert du menu X3

For I=1 To NBLAN
 If filinfo(filpath("M"+LANGUE(I),"ADMIN","mnu",0),0)<0
  If filinfo(filpath("M"+LANGUE(I),"X3","mnu",0),0)>=0
   Call COPIE(filpath("M"+LANGUE(I),"X3","mnu",0),filpath("M"+LANGUE(I),"ADMIN","mnu",0),STAT) From ORDSYS
   Call COPIEMEN(nomap,LANGUE(I),"X3","ADMIN") From VALCSTWEB
  Endif
 Endif
Next I

# Mise à jour des paramètres

Local File ADOVAL [ADW] , ADOPAR [ADP]
Call SETPAR("ADONIX","1") : # On n'est pas chez nous
If GOK<1 : Goto ECHEC : Endif
Call SETPAR("STRDAT","00000000") : # On speut se connecter quand on veut
If GOK<1 : Goto ECHEC : Endif
Call SETPAR("ENDDAT","99991231")
If GOK<1 : Goto ECHEC : Endif
Call SETPAR("SUPVOL","0")
If GOK<1 : Goto ECHEC : Endif
Call SETPAR("SUPIAP","IAP")
If GOK<1 : Goto ECHEC : Endif
Call SETPAR("TYPDBA",num$(DBATYP))
If GOK<1 : Goto ECHEC : Endif
# Issue X3-108947 - 2018-09-18 by CCC
# release must stay in decimal but the convertion in using num$ doesn't give the same value
# need a new fct to convert the value
# in char 90.010 must stay "90.010" and not "90.01"
Call SETPAR("RELEASE",func APRODUCT.FORMAT_RELEASE(RELEASE))
If GOK<1 : Goto ECHEC : Endif
Call SETPAR("RELABR",RELABR)
If GOK<1 : Goto ECHEC : Endif

# Création du paramètre INSTALL

Trbegin [ADP] , [ADW]
 Raz [F:ADP]
 [F:ADP]PARAM    = "INSTALL"
 [F:ADP]CHAPITRE = "SUP"
 [F:ADP]NIVDEF   = 1
 [F:ADP]MODIF    = 1
 Write [ADP]
 Raz [F:ADW]
 [F:ADW]PARAM  = "INSTALL"
 [F:ADW]VALEUR = "1"
 Write [ADW]
 # Création valeur parametre LANDEMOBI pour publication dosssier demo et bi
 Raz [F:ADW]
 [F:ADW]PARAM  = "LANDEMOBI"
 [F:ADW]VALEUR = LANDEF
 Write [ADW]
Commit
Close Local File [ADW] , [ADP]

# Mise à jour de SUPDOS sur tous les dossiers (changement de nom)

For [ADS]DOSSIER
 If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>=0
  Local File =[F:ADS]DOSSIER+".ADOVAL" [ADW]
  Call SETPAR("SUPDOS",nomap)
  Close Local File [ADW]
  If GOK<1 : Break : Endif
 Endif
Next ADS
If GOK<1 : Goto ECHEC : Endif


#109897
If dim(GDOSX3)<0
 Global Char    GDOSX3(GLONADS)
Endif
GDOSX3=nomap

# Installation du serveur batch
Call INSTALL From INSTSERV

# Création du fichier folders
Call CREFOLDERS From VALCSTWEB
#109897
Call PATCH(nomap) From UTIMAJREPSRV

# Création des vues
If filinfo(filpath("FIL","AVIEW","fde"),0)>0
 Call INSTALL_VUE(nomap,K) From DOSVUE
Endif

# Installation des .biar
## ancienne version Call MAJBIAR(nomap,"",LIGNE) From PATCHABI
Call IMPBIAR(nomap,"",2,2,LIGNE) From ABIIMPETA

# Invalidation du contexte

#Call EFFACE_STC("",nomap,func SUBACLA.PREFIX_CLA+"WMACONTEXT",STAT) From ORDSYS
Call INVALID_STC("",nomap,func SUBACLA.PREFIX_CLA+"WMACONTEXT",STAT) From ORDSYS

# Mise à jour de l'archive des traitements

System PARAM=adxmac(0)+'@archive -n -f -d'-nomap         : # Création de l'archive
System PARAM=adxmac(0)+'@archive -d'-nomap-'-t'-'-c "*"' : # Traitements
System PARAM=adxmac(0)+'@archive -d'-nomap-'-o'-'-c "*"' : # Classes

# Détection présence de l'appli démo et installation de cette appli

If filinfo(filpath("","X3","new",0),0)<0 : # On n'est pas dans une mise à jour
 Call VERIF_DOS(RACINE,DEMO)
 If DEMO<>""
  Call INIGLOBVAR(STAT) From GLOBVAR
  If !STAT : Goto ECHEC : Endif
  Read [ADS]DOSSIER = DEMO
  If fstat : # Il n'existe pas, c'est une première installation...
   Call CREDOS(DEMO,DBATYP,LANDEF,LANGUE,NBLAN)
  Endif
  Local File =DEMO+".ADOVAL" [ADW]
  Call SETPAR("SUPDOS",RACINE)
  If GOK<1 : Goto ECHEC : Endif
  Call SETPAR("ADONIX","1") : # On n'est pas chez nous
  If GOK<1 : Goto ECHEC : Endif
  Call SETPAR("SUPVOL","0")
  If GOK<1 : Goto ECHEC : Endif
  Call SETPAR("TYPDBA",num$(DBATYP))
  If GOK<1 : Goto ECHEC : Endif
  # Issue X3-108947 - 2018-09-18 by CCC
  # release must stay in decimal but the convertion in using num$ doesn't give the same value
  # need a new fct to convert the value
  # in char 90.010 must stay "90.010" and not "90.01"
  Call SETPAR("RELEASE",func APRODUCT.FORMAT_RELEASE(RELEASE))
  If GOK<1 : Goto ECHEC : Endif
  Call SETPAR("RELABR",RELABR)
  If GOK<1 : Goto ECHEC : Endif
  Close Local File [ADW]
  #109897
  Call PATCH(DEMO) From UTIMAJREPSRV
  Call INIT_CONSOLE(DEMO,RESULT,PARAM) From AINSTCONS
  If RESULT<>"1" : Goto ECHEC : Endif
 Endif
Endif

GOK = 1
Call TEMPOFF From GESECRAN

# mb 28.11.13 bug 94736 affichage des boîtes messages pendant l'installation du superviseur
# mb 21.1.15 demande 100249 la phase d'installation sous convergence n'est plus stoppée
#Call MESSAGE("The supervisor is installed. You can continue the installation of the product") From GESECRAN

#If dim(GFUSION)>0 and GFUSION
# GOK = -1 : # Pour forcer la déconnexion en Convergence ()
#Endif

End

#---------------#
$ABORT
GOK = 1
Call TEMPOFF From GESECRAN
End

#---------------#
$ECHEC
GOK = 0
Call TEMPOFF From GESECRAN
End

#---------------#
$ERR
ER = errn
Resume

#------------------------------------------------------------------------------------#
$GLOBVAR
If dim(GLONADC)<0 : Global Integer GLONADC : GLONADC = 30  : Endif
If dim(GLONAOB)<0 : Global Integer GLONAOB : GLONAOB = 10  : Endif
If dim(GLONABR)<0 : Global Integer GLONABR : GLONABR = 8   : Endif
If dim(GLONADS)<0 : Global Integer GLONADS : GLONADS = 20  : Endif
If dim(GLONLAN)<0 : Global Integer GLONLAN : GLONLAN = 10  : Endif
If dim(GLONATB)<0 : Global Integer GLONATB : GLONATB = 20  : Endif
If dim(GLONASO)<0 : Global Integer GLONASO : GLONASO = 20  : Endif
If dim(GLONAMC)<0 : Global Integer GLONAMC : GLONAMC = 250 : Endif
If dim(GLONAVA)<0 : Global Integer GLONAVA : GLONAVA = 20  : Endif
If dim(GLONADI)<0 : Global Integer GLONADI : GLONADI = 50  : Endif
If dim(GLONCRY)<0 : Global Integer GLONCRY : GLONCRY = 10  : Endif
If dim(GTIMOUT)<0 : Global Integer GTIMOUT                 : Endif
If dim(GFMDAT)<0  : Global Char GFMDAT(20) : GFMDAT  = "DD[/]MM[-]YY" : Endif
#115557 get right GINSTID in solution.xml
If dim(GVIRTDIR)<0
 Global Char     GVIRTDIR(100)       : # Virtual Directory de publication
Endif
If dim(GINSTID)<0
 Global Char     GINSTID(30)         : # Nom de la solution
Endif
If GINSTID=""
 Local Char    ACCESS(250) , BASE(250)
 Call INIVWEB(GINSTID,GVIRTDIR,ACCESS,BASE) From INTRUTILA
Endif
If GINSTID=""
 Local Integer TESTID
 Call RECHPROP("component.application.name",GINSTID,TESTID) From INTRUTILA
Endif
Return

################################################
## Affectation d'un paramètre à une valeur    ##
################################################
Subprog SETPAR(NOMPAR,VALPAR)
Value Char NOMPAR
Value Char VALPAR
Call DEBTRANS From GLOCK
Gosub TR1
End

$TR1
GOK = 1
Trbegin [ADW]
 Readlock [ADW]ADW0 = "";"";NOMPAR
 If fstat=1
  GOK = -1 : GLOCK = "$ADOVAL"-NOMPAR : Goto ROLL_TR1
 Elsif fstat
  GOK = 0 : Call RSTA("ADW",NOMPAR) From GLOCK : Goto AB_TR1
 Endif
 [F:ADW]VALEUR = VALPAR
 Rewrite [ADW]
 If fstat
  GOK = 0 : Call FSTA("ADW") From GLOCK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

##################################################
## Création du dossier (superviseur/demo        ##
##################################################
Subprog CREDOS(DOSSIER,DBATYP,LANDEF,LANGUE,NBLAN)
Value Char    DOSSIER
Value Integer DBATYP
Value Char    LANDEF
Value Char    LANGUE()(1..)
Value Integer NBLAN
Local Integer I
Call DEBTRANS From GLOCK
Gosub TR2
End

$TR2
GOK = 1
Trbegin [ADS]
 Raz [ADS]
 [F:ADS]DOSSIER = DOSSIER
 [F:ADS]DOSREF  = DOSSIER
 [F:ADS]STRDAT  = [1/1/1998]
 For I=0 To dim([F:ADS]MODULE)-1
  [F:ADS]MODULE(I) = 2
 Next I
 [F:ADS]TYPDBA = DBATYP
 [F:ADS]CREOBJ = 2
 [F:ADS]CREMSK = 2
 [F:ADS]NBRLAN = 1
 [F:ADS]LAN(0) = LANDEF
 For I=1 To NBLAN
  If LANGUE(I)<>LANDEF
   [F:ADS]LAN([F:ADS]NBRLAN) = LANGUE(I)
   [F:ADS]NBRLAN += 1
   If [F:ADS]NBRLAN>=dim([F:ADS]LAN) : Break : Endif
  Endif
 Next I
 [F:ADS]LANDEF = LANDEF
 Write [ADS]
 If fstat
  GOK = 0 : Call FSTA("ADS") From GLOCK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

##################################################
## Vérif présence dossier démo                  ##
##################################################
Subprog VERIF_DOS(RACINE,DEMO)
Value    Char RACINE
Variable Char DEMO
Local Char REPERT(GDIMFIC) , MACHINE(GDIMFIC) , FICHIER(GDIMFIC)
Local Char FIC(30)(1..100)
Local Char DOSVER(10) , SUPVER(10)
Local Integer I , K , NBFIC , NBDOS
DEMO = ""
REPERT = filpath("","","",RACINE)
K = 0
For I=len(REPERT) To 1 Step -1
 If find(mid$(REPERT,I,1),"/","\")
  K = I : Break
 Endif
Next I
If !K : End : Endif
REPERT = left$(REPERT,K-1)
Call MACHINE(REPERT,MACHINE,FICHIER) From ORDSYS
Call SYSTEME2(MACHINE,'lsadx -a'-nomap-FICHIER,'',NBFIC,FIC) From ORDSYS
NBFIC = min(NBFIC,dim(FIC))
NBDOS = 0
For I=1 To NBFIC
 If filinfo(filpath("FIL","ADOVAL","fde",FIC(I),"",MACHINE),0)>0 & FIC(I)<>RACINE
  NBDOS += 1
  If NBDOS=1
   DEMO = FIC(I)
  Endif
 Endif
Next I
If NBDOS>1
 # Trop de dossiers : application DEMO impossible à déterminer
 Call ERREUR(mess(178,125,1)) From GESECRAN
 DEMO = "" : End
Elsif NBDOS=0 or DEMO=""
 DEMO = "" : End
Endif
Local File =DEMO+".ADOVAL" [ADW_]
Read [ADW_]ADW0="";"";"RELEASE"
If !fstat
 DOSVER = [F:ADW_]VALEUR
Else
 DOSVER = ""
Endif
Close Local File [ADW_]
Local File =RACINE+".ADOVAL" [ADW_]
Read [ADW_]ADW0="";"";"RELEASE"
If !fstat
 SUPVER = [F:ADW_]VALEUR
Else
 SUPVER = ""
Endif
Close Local File [ADW_]
If DOSVER<>SUPVER
 # Installation du dossier démo impossible\Version du dossier : #
 Call ERREUR(func AFNC.MES(mess(181,125,1),DOSVER)) From GESECRAN
 DEMO = "" : End
Endif
End

#-------------------------------------------------------#
Subprog TRACE(COMMENT)
Value Char COMMENT
Openo filpath("tmp","installX3mb","log") Using [TT_]
Wrseq date$-time$-COMMENT Using [TT_]
Openo Using [TT_]
End

