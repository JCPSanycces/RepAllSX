#<AdxTL>@(#)7.0.0.0 $Revision$
#*********************************************************************
#
#                GESTION DU PARAMETRAGE DES ZONES LIBRES
#
#*********************************************************************
#    Création
#    ELA - 01.06.2003
#
#*********************************************************************
#    Modification
#    ELA - 29.09.2003    Ajout demande de confirmation supplémentaire en suppression d'1 paramétrage
#                        Société, si des objets existent sur la société
#    ELA - 02.04.2004    Ajout de la gestion des habilitations
#    ELA - 06.07.2004    Ajout message d'avertissement en modification et création/duplication,
#                        si des objets existent
#    XXX - 99.99.9999    description détaillée de la modif....
#
#*********************************************************************
#
GBIDC1=""
Call OBJET("FRF",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "LIENS"       : Gosub LIENS
  When "SETBOUT"     : Gosub SETBOUT
  When "RAZCRE"      : Gosub RAZCRE
  When "RAZDUP"      : Gosub RAZDUP
  When "AVANT_MOD"   : Gosub AVANT_MOD
  When "APRES_MODIF" : Gosub APRES_MODIF
  When "MODIF"       : Gosub MODIF
  When "CREATION"    : Gosub CREATION
  When "ANNULE"      : Gosub ANNULE
  When "APRES_CHOI"  : Gosub APRES_CHOI
  When "FILGAUCHE"   : Gosub FILGAUCHE
  When Default
Endcase
Return

$OUVRE
Local Integer IND                    : # indice de parcours des variables dimensionnées
Local Integer STAT                   : # réponse call VERFALLCPY
Local Char    L_CPY(GLONCPY)         : # société pour contrôle habilitation
Return

$LIENS
# Affichage de l'intitulé de la table de référence
For [L]IND=0 To dim([M]ZINTIT)-1
  Call LECTEXTRA([M]ZINTIT([L]IND),"ATABTAB","LNGDES",num$([M]ALPREF([L]IND)),"") From ATEXTRA
Next [L]IND
# Activation/désactivation abréviation écran en fonction de l'absence/présence de CPY et de l'environnement
If [M]CPY="" & GADONIX=G_OUI
  Actzo [M]ABRMSK
Elsif [M]CPY<>""
  Grizo [M]ABRMSK
Else
  Diszo [M]ABRMSK
Endif
Return

$SETBOUT
# Désactivation de l'action   "Changement de clé"
Call VIREBOUT(CHAINE,"H") From GOBJET
# Pas de suppression du paramétrage par défaut en dehors des environnements de développement
If GADONIX=G_NON & [M]CPY=""
  Call VIREBOUT(CHAINE,"A") From GOBJET
Else
# Pas de suppression du paramétrage par défaut si pas d'habilitation "tous sites du dossier"
  If [M]CPY="" & GNBAUZ <> GNBSITE
    Call VIREBOUT(CHAINE,"A") From GOBJET
  Else
# Pas de suppression du paramétrage d'1 société si pas d'habilitation "tous sites de la société"
    Call VERFALLFCY([M:FRF1]CPY,[L]STAT) From SUPCPT
    If [L]STAT < 1 : Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
  Endif
Endif
Return

$RAZCRE
# Désactivation table de référence (zones alpha)
For [L]IND=0 To dim([M]ALPREF)-1
  Grizo [M]ALPREF([L]IND)
Next [L]IND
# Désactivation devise et règle de prorata (zones montant)
For [L]IND=0 To dim([M]AMTCUR)-1
  Grizo [M]AMTCUR([L]IND)
  Grizo [M]AMTRIOIND([L]IND)
Next [L]IND
Return

$RAZDUP
# RAZ abréviation en duplication
Raz [M]ABRMSK
Affzo [M]ABRMSK
Return

$MODIF
$CREATION
# Maj des textes traduisibles
Gosub MAJTEXTRA
Return

$ANNULE
# Suppression des textes traduisibles
Delete [AXX] Where CODFIC="FREFLD" & IDENT1=num$([M:FRF1]OBJ) & IDENT2=[M:FRF1]CPY
Return

$APRES_CHOI
# Avertissement annulation paramétrage société si fiches existantes
Case REPONSE
  When GSTAANU : Call EXISTE_FICHES("A",[L]STAT) : If ![L]STAT : REPONSE=0 : Endif
Endcase
Return

$AVANT_MOD
# Contrôle habilitation / société
L_CPY=[M:FRF1]CPY
Gosub AUZ_CPY
If !OK : Return : Endif
Return

$APRES_MODIF
# Contrôle habilitation / société
If COUZON="CPY"
  L_CPY=CZ
  Gosub AUZ_CPY
  If !OK : Return : Endif
Endif
Return

$FILGAUCHE
# Pas de subventions
If G_ACTGRT=G_NON : FILGAUCHE="OBJ<>3" : Endif
# Pas de contrats de location
If G_ACTLEA=G_NON
  If FILGAUCHE<>"" : FILGAUCHE+=" & " : Endif
  FILGAUCHE+="OBJ<>4"
Endif
Return

$AUZ_CPY
# Fonction de contrôle de l'habilitation / société
If GNBAUZ <> GNBSITE : # Pas d'habilitation tous sites
  If L_CPY <> ""
    mkstat=0
    Call CONTALLFCY(L_CPY) From SUPCPT
    If mkstat : OK=0 : mkstat=0 : Endif
  Else
    # Vous n'êtes pas habilité pour la modification des paramètrages par défaut
    OK=0 : GMESSAGE=mess(113,7770,1)
  Endif
Endif
Return

$MAJTEXTRA
# Maj des textes traduisibles
For [L]IND=0 To dim([M]ALPDES)-1
  Call MAJTEXTRA([M]ALPDES([L]IND),"FREFLD","USRFLDA"+num$([L]IND+1),num$([M]OBJ),[M]CPY) From ATEXTRA
Next [L]IND
For [L]IND=0 To dim([M]RATDES)-1
  Call MAJTEXTRA([M]RATDES([L]IND),"FREFLD","USRFLDC"+num$([L]IND+1),num$([M]OBJ),[M]CPY) From ATEXTRA
Next [L]IND
For [L]IND=0 To dim([M]DATDES)-1
  Call MAJTEXTRA([M]DATDES([L]IND),"FREFLD","USRFLDD"+num$([L]IND+1),num$([M]OBJ),[M]CPY) From ATEXTRA
Next [L]IND
For [L]IND=0 To dim([M]AMTDES)-1
  Call MAJTEXTRA([M]AMTDES([L]IND),"FREFLD","USRFLDM"+num$([L]IND+1),num$([M]OBJ),[M]CPY) From ATEXTRA
Next [L]IND
Return

Subprog AS_OBJ(VALEUR)
Variable Integer  VALEUR
  GMENLOC(GVML_OMINVEN) = 1 : # Il n'y a pas d'objet métier paramétrable "Inventaire" (Fiche 27426)
End

Subprog AM_OBJ(VALEUR)
Variable Integer  VALEUR
Local    Integer  IND                    : # indice de parcours des variables dimensionnées
# Activation/désactivation règle de prorata en fonction de la présence de l'intitulé (zones montant)
#                                 et de l'objet géré (Subvention => prorata inactif, autres  => prorata actif)
For [L]IND=0 To dim([M]AMTDES)-1
  If VALEUR>2 | [M]AMTDES([L]IND)=""
    [M]AMTRIOIND([L]IND)=0
    Grizo [M]AMTRIOIND([L]IND)
  Else
    [M]AMTRIOIND([L]IND)=2
    Actzo [M]AMTRIOIND([L]IND)
  Endif
Next [L]IND
Affzo [M]AMTRIOIND
End

Subprog AP_OBJ(VALEUR)
Variable Integer  VALEUR
Local    Integer  OK
# Avertissement en création/duplication d'un paramétrage société si fiches existantes
If [M]CPY<>""
  Look [FRF]FRF0=VALEUR;[M]CPY
  If fstat
    Call EXISTE_FICHES("C",[L]OK) : If ![L]OK : mkstat=2 : End : Endif
  Endif
Endif
End

Subprog AM_CPY(VALEUR)
Variable Char     VALEUR
# Activation/désactivation abréviation écran en fonction de l'absence/présence de CPY et de l'environnement
If VALEUR="" & GADONIX=2
  Actzo [M]ABRMSK
Elsif VALEUR<>""
  Grizo [M]ABRMSK
Else
  Diszo [M]ABRMSK
Endif
End

Subprog AM_ALPDES(VALEUR)
Variable Char     VALEUR
Local    Integer  OK
If VALEUR=""
# Avertissement en changement de table de référence (elle va être razée) si fiches existantes
  Call EXISTE_FICHES("M",[L]OK) : If ![L]OK : mkstat=2 : End : Endif
# Activation/désactivation table de référence en fonction de la présence de l'intitulé (zones alpha)
  Effzo [M]ALPREF(indice)
  Effzo [M]ZINTIT(indice)
  Grizo [M]ALPREF(indice)
Else
  Actzo [M]ALPREF(indice)
Endif
Affzo [M]ALPREF(indice),ZINTIT(indice)
End

Subprog C_ALPREF(VALEUR)
Variable Decimal  VALEUR
# Contrôle existence table de référence
If VALEUR
  Call LECTURE("ADV",num$(VALEUR),"") From CONTOBJ
  If fstat
    GMESSAGE=mess(124,124,1) : mkstat=2
  Endif
Endif
End

Subprog AM_ALPREF(VALEUR)
Variable Decimal  VALEUR
Local    Integer  OK
# Avertissement en changement de table de référence si fiches existantes
If VALEUR<>[F:FRF]ALPREF(indice)
  Call EXISTE_FICHES("M",[L]OK) : If ![L]OK : mkstat=2 : End : Endif
Endif
# Affichage de l'intitulé de la table de référence
If VALEUR
### Lecture ATEXTRA en 140
  Call LECTEXTRA([M]ZINTIT(indice),"ATABTAB","LNGDES",num$(VALEUR),"") From ATEXTRA
Else
  Effzo ZINTIT(indice)
Endif
End

Subprog AM_AMTDES(VALEUR)
Variable Char     VALEUR
# Activation/désactivation devise et règle de prorata en fonction de la présence de l'intitulé (zones montant)
#                                 et de l'objet géré (Subvention => prorata inactif, autres  => prorata actif)
If VALEUR=""
  [M]AMTCUR(indice)=0
  Grizo [M]AMTCUR(indice)
Else
  [M]AMTCUR(indice)=1
  Actzo [M]AMTCUR(indice)
Endif
If VALEUR="" | [M]OBJ>2
  [M]AMTRIOIND(indice)=0
  Grizo [M]AMTRIOIND(indice)
Else
  [M]AMTRIOIND(indice)=2
  Actzo [M]AMTRIOIND(indice)
Endif
Affzo [M]AMTCUR(indice),AMTRIOIND(indice)
End

Subprog AS_AMTCUR(VALEUR)
Variable Integer  VALEUR
# la devise est toujours celle de la société sur les objets autres que Dépense
If [M]OBJ > 1
  GMENLOC(2) = 1
Endif
End

Subprog AM_AMTCUR(VALEUR)
Variable Integer VALEUR
Local    Integer  OK
# Avertissement en changement de devise si fiches existantes
If VALEUR<>[F:FRF]AMTCUR(indice)
  Call EXISTE_FICHES("M",[L]OK) : If ![L]OK : mkstat=2 : End : Endif
Endif
End

Subprog D_ALPDES(VALEUR)
Variable Char     VALEUR
# Activation/désactivation table de référence en fonction de la présence de l'intitulé (zones alpha)
If VALEUR=""
  Grizo [M]ALPREF(indice)
Else
  Actzo [M]ALPREF(indice)
Endif
End

Subprog D_AMTDES(VALEUR)
Variable Char     VALEUR
# Activation/désactivation devise et règle de prorata en fonction de la présence de l'intitulé (zones montant)
#                                 et de l'objet géré (Subvention => prorata inactif, autres  => prorata actif)
If VALEUR=""
  Grizo [M]AMTCUR(indice)
  Grizo [M]AMTRIOIND(indice)
Else
  Actzo [M]AMTCUR(indice)
  If [M]OBJ<3
    Actzo [M]AMTRIOIND(indice)
  Else
    Grizo [M]AMTRIOIND(indice)
 Endif
Endif
End

Subprog D_AMTCUR(VALEUR)
Variable Integer VALEUR
VALEUR=0
End

Subprog D_AMTRIOIND(VALEUR)
Variable Integer VALEUR
VALEUR=0
End

###############################################################
# Recherche existence de fiches concernées par le paramétrage #
#    créé, modifié ou supprimé et demande de confirmation     #
###############################################################
Subprog EXISTE_FICHES(REP,OK)
Value Char       REP
Variable Integer OK

[L]OK=1
# recherche table principale de l'objet
Read [AOB]ABREV=GOBJTAB([M:FRF1]OBJ)
If fstat : Call FSTA("AOB") From GLOCK : [L]OK=0 : End : Endif
# ouverture table principale de l'objet
Local File =[F:AOB]NOMFIC [FRFO]
# recherche d'un index de la table principale de l'objet commençant par la société
Filter [ATI] Where CODFIC=[F:AOB]NOMFIC
IND=0
For [ATI]CODIND
  IND += 1
  If pat([F:ATI]DESCRIPT,"CPY*")
    [G:FRFO]currind=IND # On force l'accès par le premier index de la table commençant par CPY
    Break
  Endif
Next
Filter [ATI]
If [M:FRF1]CPY <> ""        : # paramétrage société
  # Filtre sur la société
  Filter [FRFO] Where CPY=[M:FRF1]CPY
  Read [FRFO] First
  Filter [FRFO]
  If !fstat : # Il existe au moins une fiche OBJ dans cette société (CPY),
              # êtes-vous sûr de vouloir créer/modifier/supprimer ce paramétrage
    Call OUINON (mess(57,7770,1)-mess([M:FRF1]OBJ,3141,1)-mess(58,7770,1)-"("+[M:FRF1]CPY+"),"
&                -string$(REP="C",mess(133,7770,1))+string$(REP="M",mess(132,7770,1))
&                +string$(REP="A",mess(59,7770,1)),[L]OK) From GESECRAN
    If [L]OK<>G_OUI : [L]OK=0 : Endif
  Endif
Else                                                           : # paramétrage par défaut
  [G:FRFO]currlen=1 : # Boucle sur les sociétés de la table principale de l'objet
  For [FRFO]
    Look [FRF]FRF0=[M]OBJ;[F:FRFO]CPY
    If fstat : [L]OK=0 : Break : Endif
  Next : # [FRFO]
  If ![L]OK : # Il existe au moins une fiche OBJ dans une société utilisant le paramétrage par
              # défaut (CPY), êtes-vous sûr de vouloir modifier ce paramétrage
    [L]OK=1
    Call OUINON (mess(57,7770,1)-mess([M:FRF1]OBJ,3141,1)-mess(134,7770,1)-"("+[F:FRFO]CPY+"),"-
&                 mess(132,7770,1),[L]OK) From GESECRAN
    [L]OK=[L]OK-1
  Endif
Endif
Close Local File [FRFO]
End
