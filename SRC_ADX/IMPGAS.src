#<AdxTL>@(#)10.0.0.0 $Revision$
#*X3-39795  MDJ  Manage ORIGIN and ORICOD fields in GL Entry
$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub OUVRE
 When "IMPORT"        : Gosub IMPORT
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_TAB"       : Gosub IMP_ZONE
 When "IMP_VERIF_CRE" : Gosub VERIF
 When "IMP_VERIF_MOD" : Gosub VERIF
 When "IMP_INICRE"    : Gosub INIT
 When "IMP_INIMOD"    : Gosub INIT
Endcase
Return

###############################################
$OUVRE
Raz GTUNCPT
Raz GSCHEMA

If clalev([F:FCY])=0 : Local File FACILITY    [FCY]  : Endif : # Site
If clalev([F:CPY])=0 : Local File COMPANY     [CPY]  : Endif : # Société
If clalev([F:GCM])=0 : Local File GACM        [GCM]  : Endif : # Modèle comptable
If clalev([F:LED])=0 : Local File GLED        [LED]  : Endif : # Plan comptable
If clalev([F:GDE])=0 : Local File GDIAENTRY   [GDE]  : Endif : # Transaction de saisie
If clalev([F:JOU])=0 : Local File GJOURNAL    [JOU]  : Endif
If clalev([F:JST])=0 : Local File GAJOUSTA    [JST]  : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR  [FIY]  : Endif
If clalev([F:PER])=0 : Local File PERIOD      [PER]  : Endif
If clalev([F:BPR])=0 : Local File BPARTNER    [BPR]  : Endif
If clalev([F:GTE])=0 : Local File GTYPACCENT  [GTE]  : Endif
Return

###############################################
$INIT
If GSCHEMA<>""
 [F:HAE]DACDIA = GSCHEMA
Endif
Return

###############################################
### Read one record by one
###############################################
$IMPORT

Case IMPFIC

 When "HAE" : # En-tête de pièce

  GSCHEMA = [F:HAE]DACDIA
  If [F:HAE]DACDIA<>""
   GFLAG = [F:HAE]DACDIA
   If GFLAG<>GSCHSTDL and GFLAG<>GSCHSTDC
    Read [GDE]DIA = GFLAG
    If [GDE]TYPENT = 2
     GFLAG = GSCHSTDL
    Else
     GFLAG = GSCHSTDC
    Endif
   Endif
   [M:HAE0]DACDIA = GFLAG
  Else
   [M:HAE0]DACDIA = GFLAG
  Endif
  If [M:HAE0]DACDIA=""
   # Zone obligatoire
   OK = 0 :  Call ECR_TRACE("DACDIA : "-mess(10,123,1),1) From GESECRAN : Return
  Else
   # Issue X3-62176 - 2017-11-06 by FHA :
   #                  Importing a different ACCDAT on a Journal entry which is in 'Final' Status does not change the ACCDAT.
   #                  The issue : here the [M:HAEF]PER field is calculated according to the ACCDAT of the import file
   #                  (in the INIMSKFMT3 subprog) and updates at the end [F:DAE]PER whereas the ACCDAT and PER on the
   #                  header are not changed. Fix : in this case forcing the imported ACCDAT [F] to the existing ACCDAT [M]
   If [M]STA=2 & [M]ACCDAT<>[F:HAE]ACCDAT
    [F:HAE]ACCDAT=[M]ACCDAT
   Endif
   # End issue X3-62176
   Call INIMSKFMT3([F:HAE]FCY,[F:GDE]TYPENT,[M:HAE0]DACDIA,[F:HAE]TYP,[F:HAE]ACCDAT,STAT) From SUBGASA
   For I=1 To [M:HAEF]NBRLED
    Assign "[M:HAE1]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
    Assign "[M:HAE2]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
   Next
  Endif

  #*X3-39795  Manage ORIGIN/ORICOD
  [M:HAE1]ORIGIN   =  3       :# Import
  [M:HAE1]ORICOD  =  [F:AOE]EXT

  If GREP="M" & [M]STA<2
   Local Integer OKCHAMP
   Call TST_CHAMP("DAE","TAX",OKCHAMP) From SUBIMPOBJ
   If OKCHAMP : Raz [M]TAX : Endif
  Endif

 When "DAE" : # Lignes de pièce
  If find([F:DAE]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))

   ## Recherche du numéro de ligne en modif
   If [F:DAE]LIN>=1 & [F:DAE]LIN<=[M]NBLIG : # Modif ligne existante
    nolign = [F:DAE]LIN
   Else                                               : # Ajout d'une ligne
    If [M]NBLIG>=dim([M]DEB)
     If GREP<>""
      Call ECR_TRACE([F:HAE]NUM-mess(33,106,1),1) From GESECRAN
      # Tableau de saisie des lignes plein
     Endif
     OK = 0 : Return
    Endif
    [M]NBLIG += 1
    nolign = [M]NBLIG
   Endif
   [F:DAE]LIN = nolign : # Mémo pour ligne ana
  Else
   OK = -1 : Return
  Endif

 # Lignes analytiques
 When "DAA"
  If find([F:DAE]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   Local Integer AX , AXE, OPTV , OPTF , NBANA , OKCHAMP

   ## Recherche no de ligne géné
   If [F:DAA]LIN>=1 & [F:DAA]LIN<=[M]NBLIG : # Si ligne OK
    nolign = [F:DAA]LIN
   # Sinon dernière ligne lue
   Else
    nolign = [F:DAE]LIN
   Endif

   ## Recherche no de ligne ana
   If [M]PTV(nolign-1)=0
     # On génére une ligne "bidon"
    If [M:VT2]PTVENT+1>=dim([M:VT2]TBAMT)
     If GREP<>""
      Call ECR_TRACE([F:HAE]NUM-mess(79,117,1),1) From GESECRAN : # Trop ventilations analytiques
     Endif
     OK = 0 : Return
    Endif
    K = [M:VT2]PTVENT+1
    [M:VT2]PTVENT = K
    [M]PTV(nolign-1) = K
    [M]PTF(nolign-1) = K
   Else
    NBANA = [M]PTF(nolign-1)-[M]PTV(nolign-1)+1
    If [F:DAA]ANALIN>=1 & [F:DAA]ANALIN<=NBANA : # Modif ligne existante
     K = [M]PTV(nolign-1)+[F:DAA]ANALIN-1
    Elsif [M:VT2]PTVENT=[M]PTF(nolign-1)    : # Y'a la place
     If [M:VT2]PTVENT+1>=dim([M:VT2]TBAMT)
      # Trop de ventilation analytique
      If GREP<>"" : Call ECR_TRACE([F:HAE]NUM-mess(79,117,1),1) From GESECRAN : Endif
      OK = 0 : Return
     Endif
     K = [M:VT2]PTVENT+1
     [M:VT2]PTVENT    = K
     [M]PTF(nolign-1) = K
    Else                                      : # On met plus loin
     OPTV = [M]PTV(nolign-1)
     OPTF = [M]PTF(nolign-1)
     If [M:VT2]PTVENT+OPTF-OPTV+1>=dim([M:VT2]TBAMT)
      # Trop de ventilation analytique
      If GREP<>"" : Call ECR_TRACE([F:HAE]NUM-mess(79,117,1),1) From GESECRAN : Endif
      OK = 0 : Return
     Endif
     K = [M:VT2]PTVENT+1
     [M]PTV(nolign-1) = K
     For I=0 To OPTF-OPTV
      [M:VT2]TBAMT(K+I) = [M:VT2]TBAMT(OPTV+I)
      [M:VT2]TBQTY(K+I) = [M:VT2]TBQTY(OPTV+I)
      For AX=1 To dim([F:DAA]CCE)
       AXE = find(evalue("[F:DAA]DIE"+"("+num$(AX-1)+")"),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
       If AXE>0
        Assign"[M:VT2]TBCCE"+num$(AXE)+"("+num$(K+I)+")" With  evalue("[M:VT2]TBCCE"+num$(AX)+"("+num$(OPTV+I)+")")
       Endif
      Next AX
     Next I
     K += OPTF-OPTV+1
     [M:VT2]PTVENT = K
     [M]PTF(nolign-1) = K
     Call ANUVENTIL([M]PTV,[M]PTF,[M]NBLIG,OPTV,OPTF-OPTV+1) From VENTILE
     K -= OPTF-OPTV+1
    Endif
   Endif
   [M]DSP(nolign-1) = "$"

   ## Transfert des infos

   For AX=1 To dim([F:DAA]CCE)
    mkstat = 0
     Call CONTCCE([F:DAA]CCE(AX-1),[F:DAA]LED,[F:DAA]DIE(AX-1),[F:DAA]FCYLIN,[M]ACCDAT,
&                 [F:DAE]ACC,[M:VT2]TBDIE,"[M:VT2]TBCCE#",K) From CPTCNT
    If mkstat
     Call ECR_TRACE(GMESSAGE,1) From GESECRAN
     Raz GMESSAGE
     OK = 0 : Break
    Endif
    AXE = find(evalue("[F:DAA]DIE"+"("+num$(AX-1)+")"),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
    If AXE>0
      Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$(K)+")" With [F:DAA]CCE(AX-1)
     Endif
   Next AX
   If !OK : Return : Endif

   ### Pour ceux qui veulent importer les montants en devise locale et reporting
   If dim([M:VT2]TBLED)>0
    [M:VT2]TBLED(K) = [F:DAA]AMTLED
   Endif

   Call TST_CHAMP("DAA","AMTCUR",OKCHAMP) From SUBIMPOBJ
   If OKCHAMP : [M:VT2]TBAMT(K) = [F:DAA]AMTCUR : Endif
   Call TST_CHAMP("DAA","QTY",OKCHAMP) From SUBIMPOBJ
   If OKCHAMP : [M:VT2]TBQTY(K) = [F:DAA]QTY : Endif
   [M]QTY(nolign-1) = sum([M:VT2]TBQTY([M]PTV(nolign-1)..[M]PTF(nolign-1)))

  Else
   OK = -1 : Return
  Endif

Endcase
Return

#############################################################
## Cas particuliers
#############################################################

$IMP_ZONE
Local Integer STAT
Local Integer OKCHAMP
Local Integer I,IND
Local Char WCOA(GLONCOA)

Case IMPZON
 When "CUR"

  #-- Initialisation du masque commun SAICURLED (sans les cours enregistrés)
  If [F:HAE]CUR<>"" : [M]CUR=[F:HAE]CUR : Endif
  Call INIT([M]CUR,[M]CPY,[M]TYPRAT,[M]RATDAT,0) From SUBSCL
  Gosub CHARG_ZONES_DEV From SUBSCL

  For J=0 To min([M:HAEF]NBRC,len(mess(0,2644,1)))-1
   If [F:HAE]RATDIV(J)<>0 : [M:HAEF]RATDIVC(J) = [F:HAE]RATDIV(J) : Endif
   If [F:HAE]RATMLT(J)<>0 : [M:HAEF]RATMLTC(J) = [F:HAE]RATMLT(J) : Endif
  Next

  # Initialisation des cours
  Gosub INIT_COURS From SUBSCL

  For J=0 To min([M:SCL]NBRC,len(mess(0,2644,1)))-1
   I = [M:SCL]LEDTYP(J)-1
   If [M:HAEF]RATMLTC(I)<>0 : [M:SCL]RATMLT(J)  = [M:HAEF]RATMLTC(I) : Endif
   If [M:HAEF]RATDIVC(I)<>0 : [M:SCL]RATDIV(J)  = [M:HAEF]RATDIVC(I) : Endif
  Next

  # Remplissage du masque HAEF
  For I=0 To len(mess(0,2644,1))-1
   If [F:GCM]LED(I)<>""
    # Devise de pièce = Devise de référentiel
    If [F:GCM]CUR(I)=[M:SCL]CURENT
     Assign "[M:HAEF]RATMLTC("+num$(I)+")" With 1
     Assign "[M:HAEF]RATDIVC("+num$(I)+")" With 1
    Elsif [F:GCM]CUR(I)=[M:SCL]CURLED([M:SCL]LIGLED(I)-1)
     Assign "[M:HAEF]RATMLTC("+num$(I)+")" With [M:SCL]RATMLT([M:SCL]LIGLED(I)-1)
     Assign "[M:HAEF]RATDIVC("+num$(I)+")" With [M:SCL]RATDIV([M:SCL]LIGLED(I)-1)
    Endif
   Endif
  Next


 When "ACCDAT"

  Call INIMSKFMT3([M]FCY,[F:GDE]TYPENT,[M]DACDIA,[M]TYP,[M]ACCDAT,STAT) From SUBGASA
  If STAT
   GMESSAGE=""
   Call TITOBJ("GDE","!",GMESSAGE) From CONTOBJ
   Gosub MESSAGE From CPTAUTO
   GMESSAGE -= ":"-[F:GDE]DIA+"\"+mess(86,105,1)+"\"+MESSA : # Paramétrage à revoir
   OK = 0 : Return
  Endif
  For I=1 To [M:HAEF]NBRLED
   Assign "[M:HAE1]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
   Assign "[M:HAE2]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
  Next


  When "DEB"
   Call TST_CHAMP("DAE","AMTCUR",OKCHAMP) From SUBIMPOBJ
   If OKCHAMP
    If [F:DAE]SNS>=0
     [M]DEB(indice) = [F:DAE]AMTCUR
    Endif
   Endif

  When "CDT"
   Call TST_CHAMP("DAE","AMTCUR",OKCHAMP) From SUBIMPOBJ
   If OKCHAMP
    If [F:DAE]SNS<0
     [M]CDT(indice) = [F:DAE]AMTCUR
    Endif
   Endif

  # Attention aux variables communes
  When "BPR"    : If [M]BPR(indice)<>""    : OK = 0 : Endif
                  If [M]BPR(indice)<>[F:BPR]BPRNUM  : Raz [F:BPR] : Endif
  When "TAX"    : If [M]TAX(indice)<>""    : OK = 0 : Endif
  When "CSLCOD" : If [M]CSLCOD(indice)<>"" : OK = 0 : Endif
  When "CSLFLO" : If [M]CSLFLO(indice)<>"" : OK = 0 : Endif
  When "CSLBPR" : If [M]CSLBPR(indice)<>"" : OK = 0 : Endif
  When "QTY"    : If [M]QTY(indice)<>0     : OK = 0 : Endif
  When "UOM"    : If [M]UOM(indice)<>""    : OK = 0 : Endif

 Endcase
 If !OK : Return : Endif

# Do the following only for IMPZON of the "DAE" part (not the ACCDAT of HAE for example)
If IMPFIC="DAE"
 NBLED=find([F:DAE]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 If NBLED
  # Saisie Ligne
  If [M:HAEF]TYPENT = 2
   If left$(IMPZON,3)="SAC"
    Assign "[M]SAC1("+num$(indice)+")" With [F:DAE]SAC
    Assign "[M]ACC1("+num$(indice)+")" With ""
   Elsif left$(IMPZON,3)="ACC"
    # Si le collectif est renseigné, on n'importe pas le compte, il est bon
    If evalue("[M]SAC1("+num$(indice)+")")<>""
     OK = 0 : Return
    Else
     Assign "[M]ACC1("+num$(indice)+")" With [F:DAE]ACC
    Endif
   Elsif left$(IMPZON,3)="CPA"
    Assign "[M]CPA1("+num$(indice)+")" With [F:DAE]OFFACC
   Endif
   If IMPZON="LEDTYP"
    Call LECPLAN([M]CPY,[F:DAE]LEDTYP,WCOA) From CPTDIV
    Assign "[M]COA1("+num$(indice)+")" With WCOA
   Endif

  # si pas saisie ligne
  Else
   If left$(IMPZON,3)="SAC"
    Assign "[M]SAC"+num$(NBLED)+"("+num$(indice)+")" With [F:DAE]SAC
    Assign "[M]ACC"+num$(NBLED)+"("+num$(indice)+")" With ""
   Elsif left$(IMPZON,3)="ACC"
    # Si le collectif est renseigné, on n'importe pas le compte, il est bon
    If evalue("[M]SAC"+num$(NBLED)+"("+num$(indice)+")")<>""
     OK = 0 : Return
    Else
     Assign "[M]ACC"+num$(NBLED)+"("+num$(indice)+")" With [F:DAE]ACC
    Endif
   Elsif left$(IMPZON,3)="CPA"
    Assign "[M]CPA"+num$(NBLED)+"("+num$(indice)+")" With [F:DAE]OFFACC
   Endif
   If IMPZON="LEDTYP"
    Call LECPLAN([M]CPY,[F:DAE]LEDTYP,WCOA) From CPTDIV
    Assign "[M]COA"+num$(NBLED)+"("+num$(indice)+")" With WCOA
   Endif
  Endif

  If left$(IMPZON,6)="AMTFLG"
   Call TST_CHAMP("DAE","AMTFLG",OKCHAMP) From SUBIMPOBJ
   If OKCHAMP
    Assign "[M]AMTFLG"+num$(NBLED)+"("+num$(NOL)+")" With [F:DAE]AMTFLG
   Endif
  Elsif left$(IMPZON,6)="AMTFRC"
   Call TST_CHAMP("DAE","AMTLED1",OKCHAMP) From SUBIMPOBJ
   If OKCHAMP
    Assign "[M]AMTFRC"+num$(NBLED)+"("+num$(NOL)+")" With [F:DAE]AMTLED1
   Endif
  Endif # left$
 Endif  # NBLED
Endif    #IMPZON
Return


$VERIF
K=0
For I=0 To [M]NBLIG-1
 If [M]DSP(I)="$" & ([M]DEB(I)+[M]CDT(I)<>sum([M:VT2]TBAMT([M]PTV(I)..[M]PTF(I)))
&  or [M]QTY(I)<>sum([M:VT2]TBQTY([M]PTV(I)..[M]PTF(I))))
   # Répartition déséquilibrée - ligne no ...
   Call ECR_TRACE(mess(28,106,1)-mess(61,100,1)-num$(I+1)
&                +"\"+[M]ACC1(I)-[M]BPR(I)-num$([M]DEB(I)+[M]CDT(I)),1) From GESECRAN
   OK = 0 : Break
 Endif
Next I
Return

