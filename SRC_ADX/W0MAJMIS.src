#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque MAJMIS 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone RPLSUP
mkstat = 0
zoncou = "RPLSUP"
indice = 0
IMPENT = [M]RPLSUP
If varinit([M]RPLSUP,indice)=0
 IMPENT = 1
Endif
If varmode([M]RPLSUP,indice)=0
 [M]RPLSUP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "RPLSUP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]RPLSUP(indice)
 Endif
Endif
[M]RPLSUP = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "MAJMIS"
Return

