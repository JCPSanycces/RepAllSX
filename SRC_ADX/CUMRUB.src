#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(30)(1..3) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"CUMRUB","CUMRUB","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "ABA"         : Gosub ABANDON
 When "ENR"         : Gosub ENREGISTRER
 When "SETBOUT"     : Gosub SETBOUT
 When "FIN"         : Gosub FIN
Endcase
Return

$OUVRE
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$DEBUT
Local Integer I, J, OK, K, DERRUB, PLEIN
Local Char   SYMBOLE(30), PCOD(GLONRUB)
Local File RUBRIQUE[RUB]
Local File CUMUL   [CUM]

If dim([M]LEG)=0
  GCURLEG = GDOSLEG
Endif

Raz [M:MRUB]
REPORT2="LISRUBCUM"
Return


$APRES_MODIF
Case COUZON
 When "CUMDEB"
  If [M]CUMFIN<>""
   [M]CUMDEB = CZ
   Gosub DEVERROU
   Gosub CHARGE
  Endif
 When "CUMFIN"
  If [M]CUMDEB<>""
   [M]CUMFIN = CZ
   Affzo [M]CUMFIN
   Gosub DEVERROU
   Gosub CHARGE
  Endif
 When "NBLIG"
  If GREP=""
   If instr(1,GUSRAUZ(1),"M")
    GREP = "M"
    Gosub GRISE
   Else
    mkstat = 2
   Endif
  Endif
Endcase
Return


$ABANDON
Gosub DEVERROU
Gosub DEGRISE
Raz [M:MRUB]
Affzo [M:MRUB]
Raz GREP
SUIZON="[M:MRUB]LEG"
Return


$ENREGISTRER
Call DEBTRANS From GLOCK
Gosub TR1
Gosub ABANDON
Return

$TR1

Trbegin [RUB]

## Raz des cumuls dans RUBRIQUE

For K=0 To [M]NBL-1
 Call LECTURE("RUB",[M]SYM(K),GCURLEG) From CONTOBJ
 # On traite le tableau des cumuls
 OK = 0
 For I=0 To [F:RUB]NBRCUM-1
  If [F:RUB]CUM(I)>=[M:MRUB]CUMDEB & [F:RUB]CUM(I)<=[M:MRUB]CUMFIN
   #91750
   Raz [F:RUB]CUM(I), [F:RUB]OPTCUM(I), [F:RUB]CNDCUM(I)
   [F:RUB]NBRCUM -=1
   OK = 1
  Endif
 Next I
 For I=0 To [F:RUB]NBRCUM-1
  J = I
  While [F:RUB]CUM(I)=""
   J+=1
   [F:RUB]CUM(I)    = [F:RUB]CUM(J)
   [F:RUB]OPTCUM(I) = [F:RUB]OPTCUM(J)
   #91750
   [F:RUB]CNDCUM(I) = [F:RUB]CNDCUM(J)
   Raz [F:RUB]CUM(J), [F:RUB]OPTCUM(J), [F:RUB]CNDCUM(J)
   #
  Wend
 Next I

 If [F:RUB]TYPRUB=5
  # On traite les rubriques de type assiette
  # Plafond
  For I=0 To dim([F:RUB]CUMMAX)-1
   If ([F:RUB]CUMMAX(I)>=[M:MRUB]CUMDEB & [F:RUB]CUMMAX(I)<=[M:MRUB]CUMFIN) | [F:RUB]CUMMAX(I)=""
    Raz [F:RUB]CUMMAX(I)
    OK = 1
   Endif
  Next I
  For I=0 To dim([F:RUB]CUMMAX)-1
   J = I
   While [F:RUB]CUMMAX(I)="" & J<dim([F:RUB]CUMMAX)-1
    J +=1
    [F:RUB]CUMMAX(I) = [F:RUB]CUMMAX(J)
    Raz [F:RUB]CUMMAX(J)
   Wend
  Next I

  # Tranche
  For I=0 To dim([F:RUB]CUMAMT)-1
   If ([F:RUB]CUMAMT(I)>=[M:MRUB]CUMDEB & [F:RUB]CUMAMT(I)<=[M:MRUB]CUMFIN) | [F:RUB]CUMAMT(I)=""
    Raz [F:RUB]CUMAMT(I)
    OK = 1
   Endif
  Next I
  For I=0 To dim([F:RUB]CUMAMT)-1
   J = I
   While [F:RUB]CUMAMT(I)="" & J<dim([F:RUB]CUMAMT)-1
    J +=1
    [F:RUB]CUMAMT(I) = [F:RUB]CUMAMT(J)
    Raz [F:RUB]CUMAMT(J)
   Wend
  Next I

  # Base
  If ([F:RUB]CUMBAS>=[M:MRUB]CUMDEB & [F:RUB]CUMBAS<=[M:MRUB]CUMFIN)
   OK = 1
   Raz [F:RUB]CUMBAS
  Endif

 Endif

 If OK : Rewrite [RUB] : Endif

Next K

## Maj des cumuls dans RUBRIQUE

Sorta NBLIG NBLIG Order By ROW([S]indice),CUM([S]indice)
PCOD = ""
For I=0 To [M]NBLIG-1 : # Parcours des comptes du tableau triés sur rang
 If [M]COD(I)<>PCOD
  If PCOD<>""         : # Changement de rubrique il faut enregistrer
   Rewrite [F:RUB]
   If fstat
    GOK = 0 : Call FSTA("RUB") From GLOCK : Break
   Endif
  Endif
  Read [RUB]RUB0=GCURLEG;[M]COD(I)
  If fstat
   GOK = 0 : Call RSTA("RUB",[M]COD(I)) From GLOCK : Break
  Endif
  PCOD = [M]COD(I)
 Endif
 If [F:RUB]NBRCUM>dim([F:RUB]CUM)-1
  GOK = 0
  # cumuls maximum par rubrique
  Call ERREUR(num$(dim([F:RUB]CUM))-mess(87,10702,1)-"("-[F:RUB]COD-")") From GESECRAN
  Break
 Endif
#Tax band
 Case [M]OPTCUM(I)
  When 6,7,8                                 : # Tranche A B C
   [F:RUB]CUMAMT([M]OPTCUM(I)-6) = [M]CUM(I)
  When 13,14,15,16,17,18                     : # Tranche D E F...
   [F:RUB]CUMAMT([M]OPTCUM(I)-10) = [M]CUM(I)
  When 9,10,11                               : # Plafond A B C
   [F:RUB]CUMMAX([M]OPTCUM(I)-9) = [M]CUM(I)
  When 19,20,21,22,23,24                     : # Plafond D E F..
   [F:RUB]CUMMAX([M]OPTCUM(I)-16) = [M]CUM(I)
  When 12                                    : # Base
   [F:RUB]CUMBAS = [M]CUM(I)
  When Default                               : # Tableau de cumuls
   [F:RUB]CUM([F:RUB]NBRCUM)    = [M]CUM(I)
   [F:RUB]OPTCUM([F:RUB]NBRCUM) = [M]OPTCUM(I)
   #91750
   [F:RUB]CNDCUM([F:RUB]NBRCUM) = [M]CNDCUM(I)
   [F:RUB]NBRCUM +=1
 Endcase
Next I
If GOK=0
 Goto AB_TR1
Elsif PCOD<>""        : # Enregistrement de la dernière rubrique
 Rewrite [RUB]
 If fstat
  GOK = 0 : Call FSTA("RUB") From GLOCK : Goto AB_TR1
 Endif
Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Goto FIN : Else : Goto TR1 : Endif
Return

$AB_TR1
Rollback
Goto FIN
Return


$SETBOUT
CHMEN = ""
CHBOU = ""
If GREP="M"
 CHBOU = "EA"
 STADEF = GSTAENR
Endif
Gosub SET_BOUT_STD From GSAISIE
Gosub SET_BOUT_SPE From GSAISIE
Return


##############################################################################
# Chargement du tableau avec tous les cumuls des rubriques
##############################################################################

$CHARGE
Call TEMPON("R") From GESECRAN
Filter [RUB] Where LEG=GCURLEG and (NBRCUM>0 | TYPRUB=5)

I = 0
PLEIN = 0
For [RUB]RUB1
 OK = 1
 # Charge tableau de cumuls
 For J=0 To [F:RUB]NBRCUM-1
  If [F:RUB]CUM(J)>=[M]CUMDEB & [F:RUB]CUM(J)<=[M]CUMFIN
   If instr(1,GUSRAUZ(1),"M") & OK = 1 : Gosub SYMLCK : Endif
   If OK
    [M]ROW(I)    = [F:RUB]ROW
    [M]COD(I)    = [F:RUB]COD
    [M]CUM(I)    = [F:RUB]CUM(J)
    [M]OPTCUM(I) = [F:RUB]OPTCUM(J)
    #91750
    [M]CNDCUM(I) = [F:RUB]CNDCUM(J)
    Call LECTURE("CUM",[F:RUB]CUM(J),GCURLEG) From CONTOBJ
    [M]CUMPER(I) = [F:CUM]CUMPER
    I +=1
    If I>dim([M]ROW)-1 : PLEIN=1 : Break : Endif
   Endif
  Endif
 Next J

 If PLEIN : Break : Endif

 If [F:RUB]TYPRUB=5
  # Charge cumul base
  If [F:RUB]CUMBAS>=[M]CUMDEB & [F:RUB]CUMBAS<=[M]CUMFIN
   # OK<>2: Pour ne pas locker une assiette déjà lockée par le tableau des cumuls
   If instr(1,GUSRAUZ(1),"M") & OK<>2 : Gosub SYMLCK : Endif
   If OK
    [M]ROW(I)    = [F:RUB]ROW
    [M]COD(I)    = [F:RUB]COD
    [M]CUM(I)    = [F:RUB]CUMBAS
    [M]OPTCUM(I) = 12                  : # mess(12,372,1) Base
    #91750
    [M]CNDCUM(I) = ""
    Call LECTURE("CUM",[F:RUB]CUMBAS,GCURLEG) From CONTOBJ
    [M]CUMPER(I) = [F:CUM]CUMPER
    I +=1
    If I>dim([M]ROW)-1 : PLEIN=1 : Break : Endif
   Endif
  Endif

  # Charge cumul tranche
  For J=0 To dim([F:RUB]CUMAMT)-1
   If [F:RUB]CUMAMT(J)>=[M]CUMDEB & [F:RUB]CUMAMT(J)<=[M]CUMFIN
    # OK<>2: Pour ne pas locker une assiette déjà lockée par le tableau des cumils
    If instr(1,GUSRAUZ(1),"M") & OK<>2 : Gosub SYMLCK : Endif
    If OK
     [M]ROW(I)    = [F:RUB]ROW
     [M]COD(I)    = [F:RUB]COD
     [M]CUM(I)    = [F:RUB]CUMAMT(J)
     #Tax band
     If J<3
      [M]OPTCUM(I) = 6+J                  : # mess(6+J,372,1) Tranche A, B, C
     Else
      [M]OPTCUM(I) = 10+J                  : # mess(10+J,372,1) Tranche D, E, F...
     Endif
     #91750
     [M]CNDCUM(I) = ""
     Call LECTURE("CUM",[F:RUB]CUMAMT(J),GCURLEG) From CONTOBJ
     [M]CUMPER(I) = [F:CUM]CUMPER
     I +=1
     If I>dim([M]ROW)-1 : PLEIN=1 : Break : Endif
    Endif
   Endif
  Next J

  If PLEIN : Break : Endif

  # Charge cumul plafond
  For J=0 To dim([F:RUB]CUMMAX)-1
   If [F:RUB]CUMMAX(J)>=[M]CUMDEB & [F:RUB]CUMMAX(J)<=[M]CUMFIN
    # OK<>2: Pour ne pas locker une assiette déjà lockée par le tableau des cumils
    If instr(1,GUSRAUZ(1),"M") & OK<>2 : Gosub SYMLCK : Endif
    If OK
     [M]ROW(I)    = [F:RUB]ROW
     [M]COD(I)    = [F:RUB]COD
     [M]CUM(I)    = [F:RUB]CUMMAX(J)
     #Tax band
     If J<4
      [M]OPTCUM(I) = 9+J                 : # mess(9+J,372,1) Plafond A, B, C
     Else
      [M]OPTCUM(I) = 16+J                 : # mess(15+J,372,1) Plafond D, E, F...
     Endif
     #91750
     [M]CNDCUM(I) = ""
     Call LECTURE("CUM",[F:RUB]CUMMAX(J),GCURLEG) From CONTOBJ
     [M]CUMPER(I) = [F:CUM]CUMPER
     I +=1
     If I>dim([M]ROW)-1 : PLEIN=1 : Break : Endif
    Endif
   Endif
  Next J

  If PLEIN : Break : Endif

 Endif
 DERRUB = [F:RUB]ROW
Next
Filter [RUB]
Call TEMPOFF From GESECRAN
[M]NBLIG = I
If PLEIN
 Unlock =SYMBOLE
 [M]NBL -=1
 Raz [M]SYM([M]NBL)
 For J=0 To [M]NBLIG-1
  If [M]ROW(J)=[F:RUB]ROW
   #91750
   Raz [M]ROW(J),[M]COD(J),[M]CUM(J),[M]OPTCUM(J),[M]CUMPER(J),[M]CNDCUM(J)
   I -=1
  Endif
 Next J
 # Tableau plein Dernière rubrique traitée
 Call MESSAGE(mess(26,100,1)-"\"-mess(91,10703,1)-num$(DERRUB)) From GESECRAN
Endif
[M]NBLIG = I
Sorta NBLIG NBLIG Order By CUM([S]indice), ROW([S]indice)
Affzo [M:MRUB]
Return

$SYMLCK
SYMBOLE = "RUB"+[F:RUB]COD+GCURLEG
Lock =SYMBOLE
If fstat
 OK = 0
 Call ECR_TRACE(mess(60,100,1)-num$([F:RUB]ROW)-[F:RUB]COD,0) From GESECRAN : # Enregistrement verrouillé
Else
 OK = 2
 [M]SYM([M]NBL) = [F:RUB]COD
 [M]NBL +=1
Endif
Return


$GRISE
Grizo [M]CUMDEB,CUMFIN,LEG
Return


$DEGRISE
Actzo [M]CUMDEB,CUMFIN,LEG
Return


$DEVERROU
For I=0 To [M]NBL-1
 SYMBOLE = "RUB"+[M]SYM(I)+GCURLEG
 Unlock =SYMBOLE
Next I
Return


$FIN
Gosub DEVERROU
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

########################################
# Ecran CUMRUB
########################################

Subprog AP_CUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Filter [CUM] Where LEG=GCURLEG
 Read[CUM]CUM0 First
 Filter [CUM]
 VALEUR = [F:CUM]CUMCOD
Endif
End

Subprog AP_CUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Filter [CUM] Where LEG=GCURLEG
 Read[CUM]CUM0 Last
 Filter [CUM]
 VALEUR = [F:CUM]CUMCOD
Endif
If VALEUR < [M:MRUB]CUMDEB
 GMESSAGE = mess(28,10702,1)         : # Borne incorrecte
 mkstat   = 2
Endif
End

Subprog AS_NBLIG
If [M]NBLIG=0
 GMESSAGE = mess(78,10703,1)         : # Aucune rubrique à traiter
 mkstat   = 1
Endif
Call LECTEXTRA([M:MRUB]CUMDES,"CUMUL","CUMDES",GCURLEG,[M:MRUB]CUM(nolign-1)) From ATEXTRA
Affzo [M:MRUB]CUMDES
End

Subprog AVANT_NBLIG
Local Char SYMBOLE(30)
Raz GBIDI1
If status=73 | status=82           : # Ajout ou insertion
 GBIDI1 = 1
Endif
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Local Char SYMBOLE(30)

If GBIDI1=1 & VALEUR<>"" : # Poser le verrou
 If !find(VALEUR,[M]SYM(0..[M]NBL-1))
  SYMBOLE = "RUB"+VALEUR+GCURLEG
  Lock =SYMBOLE
  If !fstat
   [M]SYM([M]NBL) = VALEUR
   [M]NBL +=1
  Else
   GMESSAGE = mess(60,100,1)       : # enregistrement verrouillé
   mkstat = 2
  Endif
 Endif
Else GBIDI1=0
Endif

Call LECTURE("RUB",VALEUR,GCURLEG) From CONTOBJ
If [F:RUB]TMPCAL=2 & [F:CUM]CUMTMP<>2
 # Un calcul intermédiaire ne peut mouvementer que des cumuls intermédiares
 GMESSAGE = mess(8,10708,1)+"\"+mess(9,10708,1)
 mkstat=2
Else
 If [F:RUB]TYPRUB=5 & [F:RUB]REG=2 & [F:CUM]CUMTMP=2
  GMESSAGE = mess(10,10708,1)        : # Cumul intermédiaire
  mkstat = 2
 Endif
Endif
End

Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
Call LECTURE("RUB",VALEUR,GCURLEG) From CONTOBJ
[M]ROW(nolign-1) = [F:RUB]ROW
Affzo [M]ROW(nolign-1)
End

Subprog AM_CUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]CUMDEB | VALEUR>[M]CUMFIN
 GMESSAGE = mess(86,10702,1) : # Cumul hors des bornes
 mkstat   = 2
 End
Endif
[M:MRUB]CUMPER(nolign-1) = [F:CUM]CUMPER
End

Subprog AS_OPTCUM(VALEUR)
Variable Integer VALEUR
Call LECTURE("RUB",[M]COD(nolign-1),GCURLEG) From CONTOBJ
If [F:RUB]TYPRUB<>5
 GMENLOC(6) = 1 : GMENLOC(7) = 1 : GMENLOC(8) = 1 : GMENLOC(9) = 1 : GMENLOC(10) = 1
 GMENLOC(11) = 1 : GMENLOC(12) = 1
#Tax band (D to I)
If func AFNC.ACTIV("TXB")<9
 For I=func AFNC.ACTIV("TXB")+10 To 18
  GMENLOC(I)=1
 Next
 For I=func AFNC.ACTIV("TXB")+15 To len(mess(0,10372,1))
  GMENLOC(I)=1
 Next
Endif

Endif
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR
End


######################################################################################

