#<AdxTL>@(#)4.0.0.0 $Revision$
# Gestion du masque HISCOST2 (Graphique)
################################################################
#
$CHARG_GRAPHE
Local Integer LIND, I
Local Decimal LAMT

Effzo [M:HIM2]10

For I=0 To [M:HIM1]NBLIG-1
    LIND = find([M:HIM1]VCRNUM(I),[M:HIM2]VCRNUM)-1
    If LIND<0
        LIND = [M:HIM2]NBLIG
        [M:HIM2]NBLIG += 1
    Endif
    [M:HIM2]VCRNUM(LIND) = [M:HIM1]VCRNUM(I)
    Raz LAMT
    If [M:HIM2]MATFLG=2
        LAMT += [M:HIM1]MATTOT(I)
    Endif
    If [M:HIM2]MACFLG=2
        LAMT += [M:HIM1]MACTOT(I)
    Endif
    If [M:HIM2]LABFLG=2
        LAMT += [M:HIM1]LABTOT(I)
    Endif
    If [M:HIM2]SCOFLG=2
        LAMT += [M:HIM1]SCOTOT(I)
    Endif
    If [M:HIM2]INVDTAFLG=2
        LAMT += [M:HIM1]INVDTATOT(I)
    Endif
    If [M:HIM2]OVEFLG=2
        LAMT += [M:HIM1]OVETOT(I)
    Endif
    Case [M:HIM1]MFCTYP(I)
        When 1: [M:HIM2]CST1(LIND) = LAMT
        When 2: [M:HIM2]CST2(LIND) = LAMT
        When 3: [M:HIM2]CST3(LIND) = LAMT
        When 4: [M:HIM2]CST4(LIND) = LAMT
    Endcase
Next

Affzo [M:HIM2]

Return

