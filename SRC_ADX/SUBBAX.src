#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du masque APPA
########################################
# Gestion des conflits de rendez-vous
########################################
###########################################################
# Fonction de déprogrammation d'intervenants en conflits
###########################################################
Subprog B1_NBCONF
Local Integer I
Local Integer I2

  Read [BAP]APP0=[M:BAPA]APPNUM(nolign-1)
  If fstat Then
    End
  Endif
  #Interdit la déprogrammation d'un intervenant principal sur un rendez-vous
  If [F:BAP]APTREPNUM(0) = [M:BAPA]REPNUM(nolign-1) Then
    # Impossible de déprogrammer cet intervenant.
    # Il s'agit de l'intervenant principal de ce rendez-vous.
    GMESSAGE = mess(225,196,1)
    GERR = 2
    End
  Endif
  For I = 0 To dim([F:BAP]APTREPNUM)-1
    If [F:BAP]APTREPNUM(I) = "" Then
      Break
    Endif
    If [F:BAP]APTREPNUM(I) = [M:BAPA]REPNUM(nolign-1) Then
      Call DEBTRANS From GLOCK
      Trbegin [BAP]
      #Modifie le tableau à partir du représentant recherché.
      For I2 = I To dim([F:BAP]APTREPNUM)-1
        If [F:BAP]APTREPNUM(I2) = "" Then
          Break
        Endif
        [F:BAP]APTREPNUM(I2) = [F:BAP]APTREPNUM(I2+1)
      Next
      Rewrite [BAP]
      If fstat Then
        Rollback
        GMESSAGE = mess(157,199,1) #Transaction abandonnée. Erreur ou conflit d'accès.
        GERR = 1
        #End   # FGR 02/02/2010 : X3SUIVI60986
        Break  # FGR 02/02/2010 : X3SUIVI60986
      Else
        Commit
      Endif
    Endif
  Next
  If GERR Then
    # FGR 02/02/2010 : X3SUIVI60986
    End
  Endif
  #Recharge le tableau des conflits de rdv
  For I = nolign-1 To NBCONF-1
    If [M:BAPA]REP(I) = "" Then
      Break
    Endif
    [M:BAPA]REP(I) = [M:BAPA]REP(I+1)
    [M:BAPA]DAT(I) = [M:BAPA]DAT(I+1)
    [M:BAPA]HOU(I) = [M:BAPA]HOU(I+1)
    [M:BAPA]DATEND(I) = [M:BAPA]DATEND(I+1)
    [M:BAPA]HOUEND(I) = [M:BAPA]HOUEND(I+1)
    [M:BAPA]BPC(I) = [M:BAPA]BPC(I+1)
    [M:BAPA]CNT(I) = [M:BAPA]CNT(I+1)
    [M:BAPA]APPNUM(I) = [M:BAPA]APPNUM(I+1)
    [M:BAPA]REPNUM(I) = [M:BAPA]REPNUM(I+1)
  Next
  [M:BAPA]NBCONF -= 1
  Affzo [M:BAPA]
End
