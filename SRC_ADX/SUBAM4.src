#PARAM(1)="DEMO"
#PARAM2="PL01~UUTIMIGTCR07"
Call SAISIE_CHAR(VALEUR,PARAM,"AMOULIN4","SUBAM4","") From GSAISIE

End


$ACTION
Case ACTION
  When "EXEC" : Gosub EXECACT
Endcase

Return


$EXECACT
#  CRITERE est sous la forme PLAN~TRAITEMENT

Local Integer POS,STAT
POS=instr(1,[M:AM4]CRIT1,":")
Global Char GMIGPROC : GMIGPROC=right$([M:AM4]CRIT1,POS+1)
Global Char GMIGPLAN : GMIGPLAN=left$([M:AM4]CRIT1,POS-1)
Local Char PRGTOCALL : PRGTOCALL=GMIGPROC

#    Protocole de test CC
#If left$(GMIGPROC,1)="Z" : PRGTOCALL="ZCCMIGTEST" : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
#107271
#Read [ADS]DOSSIER=[M:AM4]DOSSIER
#If fstat : Raz [F:ADS] : Endif
STAT=func DOSSUB.FILL_ADS([M:AM4]DOSSIER)

# Où on en est des versions ?
If func DOSSUB.RELEASE([F:ADS]DOSREF)<> func DOSSUB.RELEASE([F:ADS]DOSSIER)
 # Le numéro de version du dossier est incorrect
 Call ECR_TRACE(mess(142,100,1)-[F:ADS]DOSSIER+"="+func DOSSUB.RELEASE([F:ADS]DOSSIER)-[F:ADS]DOSREF+"="+func DOSSUB.RELEASE([F:ADS]DOSREF),1) From GESECRAN
 Call MIGSTKENDFLG ([F:ADS]DOSSIER,PRGTOCALL,7,STAT) From TRTMIG : #7=Erreur
 Return
Endif

Call ="MAJ_"+PRGTOCALL With [F:ADS]DOSSIER From =PRGTOCALL

Return






# --------------------- Statuts des moulinettes et plan : menu 7944 ---------------------------------------------
#
#  1 : En attente                 2 : En cours           3 : Terminé  4 : Terminé avec erreurs  5 : Interrompu
#  6 : En attente interruption    7 : En attente arrêt   8 : Lancé    9 : Arrêté               10 : Bloqué    11 : Débrayé
#
# ---------------------------------------------------------------------------------------------------------------

Subprog CREPLAN(PLAN,DOSSIER,NBPARL,OKCP)
Variable Char PLAN
Value Char DOSSIER
Value Integer NBPARL
Value Integer START
Variable Integer OKCP

#   Si PLAN=""     On crée le plan de nom "MIG"+MM+JJ+"N"+nn et on l'active
#   Si PLAN<>""    On utilise ce plan, en le lançant
#                  Si il n'existe pas ou n'a pas un statut "En attente" on crée le plan "MIG"+MM+JJ+"N"+nn
#   En retour OKCP=1 si tout s'est bien passé

OKCP=1
Local Integer INDC,NEXIST,OK
If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
If PLAN<>""
  Read [AI1]AI11=PLAN
  If fstat=0 and [F:AI1]STATUT=1
    If GTRACE<>""
      Trbegin [AI1]
      [F:AI1]NOMTRACE=GTRACE
      Rewrite [AI1]
      Commit
    Endif
    Call ACTIVPLAN(PLAN,OKCP) From AMOULINETTE
    End
  Endif
Endif

# Le plan n'existe pas ou n'est pas "en attente", on crée un plan par défaut

INDC=1
While NEXIST=0
  PLAN="MIG"+right$(date$,5)+"N"+format$("N0:##",INDC)
  Read [AI1]AI11=PLAN
  If fstat<>0
    NEXIST=1
  Else
    INDC+=1
  Endif
Wend
Call CREPLAN(PLAN,mess(14,7902,1)-DOSSIER-date$,1,DOSSIER,NBPARL,2,2,OKCP) From AMOULINETTE
Call ACTIVPLAN(PLAN,OKCP) From AMOULINETTE

End

# ----------------------------------------------------------------------------------------------------------

Subprog UPDMIG(PLAN,CODE,NBREAD,NBWRIT,STATUTC,CODRET)
Value Char PLAN
Value Char CODE
Value Integer NBREAD
Value Integer NBWRIT
Value Char STATUTC
Variable Char CODRET

#  Information envoyée par la procédure CODE du PLAN
#  NBREAD  = Nombre d'enregistrements à traiter
#  NBWRIT  = Nombre d'enregistrements traités
#  STATUTC = "START"   démarrage
#            "ERROR"   la moulinette va s'arrêter en erreur
#            "STOP"    la moulinette répond à une demande de Stop et s'arrête (sans erreur)
#            "END"     la moulinette se termine sans erreur
#            "RUN"     la moulinette est en cours
#
#  CODRET  = "STOP"    il y a une demande d'arrêt. Il faut stopper la moulinette
#          = "WRONGP"  mauvais paramètres. La procédure n'existe pas
#

CODRET=""
Global Char GMIGPLAN : GMIGPLAN=PLAN
Global Char GMIGPROC : GMIGPROC=CODE

If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif

Read [AI1]AI11=PLAN
If fstat<>0 : CODRET="WRONGP" : End : Endif


Read [AI2]AI21=PLAN;CODE
If fstat<>0 : CODRET="WRONGP" : End : Endif

Local Integer STATORIG : STATORIG=[F:AI2]STATUT

Case STATUTC
  When "START","RUN" :   If [F:AI2]STATUT<>6 and [F:AI2]STATUT<>7 : [F:AI2]STATUT=2 : Endif
  When "STOP"        :   [F:AI2]STATUT=5
  When "ERROR"       :   [F:AI2]STATUT=4
  When "END"         :   [F:AI2]STATUT=3
Endcase
Trbegin [AI2]
[F:AI2]DATEMAJ=date$
[F:AI2]HEUMAJ=left$(time$,2)+mid$(time$,4,2)
[F:AI2]NBENREG=NBREAD
[F:AI2]NBENREGT=NBWRIT
[F:AI2]FICTRA=GTRACE


If ([F:AI1]STATUT=6 or [F:AI2]STATUT=6) and (STATUTC="START" or STATUTC="RUN")
  CODRET="STOP"
  [F:AI2]STATUT=6
Endif

Rewrite [AI2]
Commit

# On appelle le moniteur qui va lancer ce qu'il peut selon le contexte

#Local Integer OKML
#Call LANCENEXTMOUL(PLAN,"",OKML) From AMOULINETTE


#If STATUTC="ERROR" or STATUTC="STOP" or STATUTC="END"
#  Kill GMIGPLAN,GMIGPROC
#Endif


End

# ----------------------------------------------------------------------------------------------------------

Subprog TRTFINMIG

#  Trigger de fin si plantage d'une procédure sans passer par l'arrêt normal


Onerrgo ERRTRIG

If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif

Read [AI1]AI11=GMIGPLAN
If fstat<>0  : End : Endif


Read [AI2]AI21=GMIGPLAN;GMIGPROC
If fstat<>0 : End : Endif

#  Cumule dans le fichier trace
#If (STATUTC="END" or STATUTC="ERROR") and [F:AI1]NOMTRACE<>"" and [F:AI2]FICTRA<>""
Local Char TRACE(GDIMFIC)
Local Char TRACE_SUITE(GDIMFIC)
If [F:AI1]NOMTRACE<>"" and [F:AI2]FICTRA<>""
   TRACE=[F:AI1]NOMTRACE
   TRACE_SUITE=[F:AI2]FICTRA
Endif

# --------------------- Statuts des moulinettes et plan : menu 7944 ---------------------------------------------
#
#  1 : En attente                 2 : En cours           3 : Terminé  4 : Terminé avec erreurs  5 : Interrompu
#  6 : En attente interruption    7 : En attente arrêt   8 : Lancé    9 : Arrêté               10 : Bloqué   11 : Débrayé
#
# ---------------------------------------------------------------------------------------------------------------


# Revoit le statut si la requête a planté en erreur

If clalev([F:ABR])=0 : Local File ABATRQT [ABR] : Endif
Read [ABR]NUMREQ = [F:AI2]NUMREQ
If fstat=0 and ([F:ABR]FLAG=6 or [F:ABR]FLAG=7)
  If [F:AI2]STATUT=2 or [F:AI2]STATUT=6 or [F:AI2]STATUT=7
    [F:AI2]DATEMAJ=date$
    [F:AI2]HEUMAJ=left$(time$,2)+mid$(time$,4,2)
  Endif
  [F:AI2]STATUT=4
Endif

Trbegin [AI2]
Rewrite [AI2]
Commit

#84463 add trace before update plan
If TRACE<>"" and TRACE_SUITE<>""
  Gosub ADDTRACE
Endif

Local Integer OKML
Call LANCENEXTMOUL(GMIGPLAN,"",OKML) From AMOULINETTE

Kill GMIGPLAN,GMIGPROC
End


$ERRTRIG
Onerrgo
End

# -------------------------------------------------------------------------------------------------

$ADDTRACE
# Copie du contenu du fichier TRACE_SUITE à la fin du fichier TRACE

Local Libelle BUFFER(1..30)
Local Integer NB , COMPTE , NOCT

TRACE = filpath("TRA",TRACE,"tra")
TRACE_SUITE = filpath("TRA",TRACE_SUITE,"tra")

Openo TRACE, -1 Using [TRA]
Openi TRACE_SUITE Using [TRA2]
adxifs = ""
adxirs = chr$(10)
adxium = GTRAFOR
Wrseq Using [TRA]
Local Char VALL1(250)
VALL1="-----------------------------"-mess(28,7902,1)-GMIGPROC
If [F:AI2]NBREL<=1
  VALL1-="("+mess(29,7902,1)+")"
Else
  VALL1-="("+mess(30,7902,1)-num$([F:AI2]NBREL)+")"
Endif
VALL1-="-----------------------------"
Wrseq VALL1 Using [TRA]
Wrseq Using [TRA]
NOCT = filinfo(TRACE_SUITE,7)
NB = dim(BUFFER)
Getseq NB , BUFFER Using [TRA2]
COMPTE = 0
While !fstat
  COMPTE += NB
  Putseq NB , BUFFER Using [TRA]
  Getseq NB , BUFFER Using [TRA2]
Wend
fstat=0

If NOCT>COMPTE
  NB = NOCT-COMPTE
  Putseq NB , BUFFER Using [TRA]
Endif

Wrseq Using [TRA]
VALL1="---------------------------"-mess(31,7902,1)-GMIGPROC
If [F:AI2]NBREL<=1
  VALL1-="("+mess(29,7902,1)+")"
Else
  VALL1-="("+mess(30,7902,1)-num$([F:AI2]NBREL)+")"
Endif
VALL1-="---------------------------"
Wrseq VALL1 Using [TRA]


Openi Using [TRA2]
Openo Using [TRA]
Return

