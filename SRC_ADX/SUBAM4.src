Subprog C_DOSSIER(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER=VALEUR
If fstat
 If func DOSSUB.ISHISTFOLD(VALEUR)=0
  GMESSAGE=mess(7,125,1)
  GERR=1
  mkstat=2
 Endif
Endif
Call CTLDOS(VALEUR) From DOSCONT
End

Subprog AM_DOSSIER(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV & VALEUR<>""
 ## Action APASSWD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "APASSWD"
 PARMSK(1) = ""
 PARMSK(2) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"APASSWD","APASSWD","SPEPASSWD") From GSAISIE
 GACTION = SAVACT
Endif
End

Subprog S_DOSSIER(VALEUR)
Variable Char    VALEUR()
Gosub DEFSEL2
Local File ADOSSIER [ADS]
  For [ADS]
    NBTEX+= 1
    TEX(NBTEX,1) = [F:ADS]DOSSIER
    TEX(NBTEX,2) = [F:ADS]NOMDOS
    If [F:ADS]DOSHIS<>""
     NBTEX+= 1
     TEX(NBTEX,1) = [F:ADS]DOSHIS
     TEX(NBTEX,2) = mess(291,125,1)-[F:ADS]DOSSIER
    Endif
  Next
  CHOI = 0
  TIT(0) = mess(22,123,1) # Sélection
  TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ADS0", "DOSSIER")
  TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ADS0", "NOMDOS")
  Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,80) From GESECRAN
  If status<>7 & CHOI<>0
   VALEUR = TEX(CHOI,1)
  Endif
End

$DEFSEL2
Local Integer NBTEX, CHOI,I
Local Char    TEX(GLONDES+10)(1..500,1..2) , TIT(GLONDES)(0..2) , CRITERE(250)
Return


