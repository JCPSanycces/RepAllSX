#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(250)(1..4) , VALEUR(GLONAWA)
Local Mask AMK0 [AMK0]
Call TRAITE_CHAR(VALEUR,PARAM,"","SAIWRKMAN","SAIWRKMAN",3,"") From GTRAITE
End

#-----------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "SEL_TABLE"  : Gosub SEL_TABLE
Endcase
Return

#----------------------------#
$INIT
Local Char    CODE(GLONAWA) , CODEVT(10) , TIT(30)
Local Char    FILTRE(250) , CRITERE(250)(1..10)
Local Char    GRPDEB(GLONVCR)
Local Integer SIMUL , ERD , ERN , DIFFERE
Local Char    ERM(250) , NOMPROG(GLONADC)
Local Char    CLEOBJ(250) , PREF(250)
Local Integer I , J , K , ICRITERE
Local Char    NUMTRA(250)
If clalev([F:AWA])=0  : Local File AWRKPAR   [AWA]  : Endif
Local Mask AWAM [AWAM]
[M]CODE   = PARAM(1)
[M]FILTRE = PARAM(2)
[M]SIMUL  = max(1,min(2,val(PARAM(3))))
Return

#----------------------------#
$CONTROLE
[L] = [M]
Read [AWA]AWA0 = CODE
If fstat | [F:AWA]TYPEVT<>10 : FIN = 1 : Return : Endif
CODEVT = [F:AWA]CODEVT
ERD = [F:AWA]DEBUG
Call SET_PREF(CODE,PREF) From SUBAWA
NOMPROG = PREF+CODE
Onerrgo ER
Gosub LNKREF From =NOMPROG
Onerrgo
If LNKREF="" | ERN
 FIN = 1 : Return
Endif
Return

#----------------------------#
$ER
ERN = errn
ERM = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(ERN)-":"-errmes$(ERN)-errm
If ERD
 Call ECR_TRACE(ERM,0) From GESECRAN
Endif
Resume

#----------------------------#
$EXEC
TRA = 1
Call TITAWI("SAIWRKMAN",TIT) From OBJDIV
If !GSERVEUR
 Call OUVRE_TRACE(TIT-[L]CODE) From LECFIC
 Call TEMPON(TIT-[L]CODE) From GESECRAN
Endif

# Ordre de lecture de la table principale
Gosub ORDREF From =NOMPROG

# Conditions ligne
Raz CRITERE , ICRITERE
For I=1 To [F:AWA]NBCOND
 If [F:AWA]TYPCND(I-1)=3 & [F:AWA]CONDITION(I-1)<>""
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+[F:AWA]CONDITION(I-1)+")","&") From GOBJSUB
 Endif
Next I
If CRITERE="" : CRITERE = "1=1" : Endif

If FILTRE=""  : FILTRE  = "1=1" : Endif

GRPDEB  = ""
DIFFERE = 1

Case NBRREF
 When 1       : For [LNM_]CLE(1) Where evalue(FILTRE) & evalue(CRITERE) : Gosub WRK : Next LNM_
 When 2       : For [LNM_]CLE(2) Where evalue(FILTRE) & evalue(CRITERE) : Gosub WRK : Next LNM_
 When 3       : For [LNM_]CLE(3) Where evalue(FILTRE) & evalue(CRITERE) : Gosub WRK : Next LNM_
 When 4       : For [LNM_]CLE(4) Where evalue(FILTRE) & evalue(CRITERE) : Gosub WRK : Next LNM_
 When 5       : For [LNM_]CLE(5) Where evalue(FILTRE) & evalue(CRITERE) : Gosub WRK : Next LNM_
 When 6       : For [LNM_]CLE(6) Where evalue(FILTRE) & evalue(CRITERE) : Gosub WRK : Next LNM_
 When 7       : For [LNM_]CLE(7) Where evalue(FILTRE) & evalue(CRITERE) : Gosub WRK : Next LNM_
 When Default : For [LNM_]CLE(8) Where evalue(FILTRE) & evalue(CRITERE) : Gosub WRK : Next LNM_
Endcase

If SIMUL<>2
 K = GTEST : GTEST = ERD : # Pour trace envoi message
 NUMTRA = GTRACE :  GTRACE = "" # Issue X3-101692 - 2018-09-10 by ALSHE : create extra trace for mail
 Call ENVOI_GROUPE(GRPDEB) From AWRK
 GTRACE = NUMTRA
 GTEST = K
Endif

If !GSERVEUR
 Call TEMPOFF From GESECRAN
 Call FERME_TRACE From LECFIC
Endif
Return

#----------------------------#
$WRK
CLEOBJ = evalue(CLEREF)
Call WORKPLUS(10,CODEVT,"",CLEOBJ,CODE,(SIMUL=2),DIFFERE,0,GRPDEB) From AWRK
Return

#----------------------------#
$SEL_TABLE
OBJET = "AWA"
CRITERE = "TYPEVT = 10" : # Manuel
Return

#----------------------------#
Subprog C_CODE(VALEUR)
Variable Char    VALEUR()
If clalev([F:AWA])=0  : Local File AWRKPAR   [AWA]  : Endif
Read [AWA]AWA0 = VALEUR
If !fstat & [F:AWA]TYPEVT<>10
 mkstat = 1 : End
Endif
End

