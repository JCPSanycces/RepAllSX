#<AdxTL>@(#)9.0.0.0 $Revision$
#############################################################################
# SUBPNHC : Gestion des retours d'achat de sous-traitance        GA 03/2006 #
# ------------------------------------------------------------------------- #
# Traitements liés aux achats de sous-traitance OF ou EO                    #
# déclenchés en validation MODCRELIG ou MODSUPLIG                           #
# si on est en retour de réception ss-traitance                             #
# ------------------------------------------------------------------------- #
# Les traitements sur champ "Call"             se trouvent dans le SUBPNH   #
# Les actions "Gosub" de l'objet "PNH"         se trouvent dans le SUBPNHA  #
# Traitements complémentaires de l'objet "PNH" se trouvent dans le SUBPNHB  #
# ------------------------------------------------------------------------- #
# $CRELIG en création/modif d'une ligne retour de réception ss-traitance    #
# $SUPLIG en suppression    d'une ligne retour de réception ss-traitance    #
#############################################################################

# Création ou modification d'une ligne retour
$CRELIG
  # Ne pas ouvrir de masque écran en cours de transaction,
  # car le default mask est écrasé !  MBT 16/03/09
  #If clalev([M:SBCK])=0 Local Mask SBCK  [SBCK] : Endif
  Gosub MAJ_RETITM
Return


# Suppression d'une ligne retour
$SUPLIG
  # Ne pas ouvrir de masque écran en cours de transaction,
  # car le default mask est écrasé !  MBT 16/03/09
  #If clalev([M:SBCK])=0 Local Mask SBCK  [SBCK] : Endif
  Gosub SUP_RETITM
Return


$MAJ_RETITM
#-----------------------------------------#
# Mise à jour article sous-traité         #
#-----------------------------------------#
Raz [M:SBCK]
[M:SBCK]MAJCOD = "N"               : # Retour article sous-traité
#[M:SBCK]VCRTYP = 6                : # Menu local 701: toujours 6=Commande d'achat
[M:SBCK]VCRNUM = [F:PND]POHNUM
[M:SBCK]VCRLIN = [F:PND]POPLIN
[M:SBCK]VCRSEQ = [F:PND]POQSEQ
If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:PTD]LINTYP Endif  # FQ 76147 GA 09/2011
#
[M:SBCK]PTHNUM = [F:PND]PTHNUM
[M:SBCK]PTDLIN = [F:PND]PTDLIN
#
[M:SBCK]VCRTYPORI = [F:PTD]VCRTYPORI 
[M:SBCK]VCRNUMORI = [F:PTD]VCRNUMORI 
[M:SBCK]VCRLINORI = [F:PTD]VCRLINORI 
[M:SBCK]VCRSEQORI = [F:PTD]VCRSEQORI 
#
[M:SBCK]RCPQTY = -1 * [F:PND]QTYSTU
[M:SBCK]MSGFLG = 1
Call MAJ_SBC From SBCLIB
If [M:SBCK]CODRET<>0
   Case [M:SBCK]VCRTYPORI : 
     When 10 :
     GMESSAGE=[F:PND]ITMREF-mess(96,193,1) : GERR=1 : GOK=0 : Return
     When 36 :
     GMESSAGE=[F:PND]ITMREF-mess(913,196,1) : GERR=1 : GOK=0 : Return
   Endcase
Endif
Return

$SUP_RETITM
#-----------------------------------------#
# Mise à jour article sous-traité         #
#-----------------------------------------#
Raz [M:SBCK]
[M:SBCK]MAJCOD = "N"               : # Annulation Retour article sous-traité
#[M:SBCK]VCRTYP = 6                : # Menu local 701: toujours 6=Commande d'achat
[M:SBCK]VCRNUM = [F:PND]POHNUM
[M:SBCK]VCRLIN = [F:PND]POPLIN
[M:SBCK]VCRSEQ = [F:PND]POQSEQ
If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:PTD]LINTYP Endif  # FQ 76147 GA 09/2011
#
[M:SBCK]PTHNUM = [F:PND]PTHNUM
[M:SBCK]PTDLIN = [F:PND]PTDLIN
#
[M:SBCK]VCRTYPORI = [F:PTD]VCRTYPORI 
[M:SBCK]VCRNUMORI = [F:PTD]VCRNUMORI 
[M:SBCK]VCRLINORI = [F:PTD]VCRLINORI 
[M:SBCK]VCRSEQORI = [F:PTD]VCRSEQORI 
#
[M:SBCK]RCPQTY = [F:PND]QTYSTU
[M:SBCK]MSGFLG = 1
Call MAJ_SBC From SBCLIB
If [M:SBCK]CODRET<>0
   Case [M:SBCK]VCRTYPORI : 
     When 10 :
     GMESSAGE=[F:PND]ITMREF-mess(96,193,1) : GERR=1 : GOK=0 : Return
     When 36 :
     GMESSAGE=[F:PND]ITMREF-mess(913,196,1) : GERR=1 : GOK=0 : Return
   Endcase
Endif
Return
