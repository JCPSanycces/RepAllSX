$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE           From SUBTRNPA
 When "RAZCRE"       : Gosub RAZCRE          From SUBTRNPA    # Issue 111257 US3
 When "RAZDUP"       : Gosub RAZDUP          From SUBTRNPA    # Issue 53829
 When "INICRE"       : Gosub INICRE          From SUBTRNPA
 When "LIENS"        : Gosub LIENS           From SUBTRNPA
 When "APRES_CRE"    : Gosub APRES_CRE       From SUBTRNPA
 When "AV_ANNULE"    : Gosub AV_ANNULE       From SUBTRNPA
 When "ANNULE"       : Gosub ANNULE          From SUBTRNPA
 When "DEFLIG"       : Gosub DEFLIG          From SUBTRNPA
 When "ABANDON"      : Gosub ABANDON         From SUBTRNPA
 When "CREATION"     : Gosub CREATION        From SUBTRNPA
 When "MODIF"        : Gosub MODIF           From SUBTRNPA
 When "INICRE_LIG"   : Gosub INICRE_LIG      From SUBTRNPA
 When "LIENS_LIG"    : Gosub LIENS_LIG       From SUBTRNPA
 When "VALLIG"       : Gosub VALLIG          From SUBTRNPA
 When "FERME"        : Gosub FERME           From SUBTRNPA
 When Default
Endcase
Return


Subprog AM_DPETPC(VALEUR)
Variable Char    VALEUR()

# recherche pays
Read [TPC] TPC0=VALEUR
If fstat
  Raz [F:TPC]
  Raz [M:TRNP1]DPECRY
Else
  Filter [F:BPA] Where BPATYP=8 & BPANUM = [F:TPC]TPC
  Read [F:BPA] First
  [M:TRNP1]DPECRY = [F:BPA]CRY
Endif

Affzo [M:TRNP1]DPECRY

End

Subprog AM_ARVTPC(VALEUR)
Variable Char    VALEUR()

# recherche pays
Read [TPC] TPC0=VALEUR
If fstat
  Raz [F:TPC]
  Raz [M:TRNP1]ARVCRY
Else
  Filter [F:BPA] Where BPATYP=8 & BPANUM = [F:TPC]TPC
  Read [F:BPA] First
  [M:TRNP1]ARVCRY = [F:BPA]CRY
Endif

Affzo [M:TRNP1]ARVCRY

End


