Subprog IB_SDFILNAM
If [M:TRNPD]SDFILNAM(nolign-1) =""
  Raz GBOUT2
Endif
End

Subprog AM_SDFILNAM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Actzo [M:TRNPD]SDDOC(nolign-1)
  [M:TRNPD]SDDOC(nolign-1) = "175"
Else
  Grizo [M:TRNPD]SDDOC(nolign-1)
  [M:TRNPD]SDDOC(nolign-1) = "191"
  Raz GBOUT2
Endif
Affzo [M:TRNPD]SDDOC(nolign-1)
End


