Subprog IB_NBLIGNE
Case [M:TRNPT]TRKLIGSTAT(nolign-1)
  When 1
    Raz GBOUT1
    GBOUT2 = mess(3,2250,1)
  When 2
    GBOUT1 = mess(3,21,1)
    Raz GBOUT2
  When 3
    GBOUT1 = mess(50,9139,1)
    Raz GBOUT2
Endcase
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran TRNPTRACK) 27/04/2016 11:56:15 (MAE)
######################################################################################
Subprog AM_TRKDEPCOD(VALEUR)
Variable Char VALEUR()
Local Integer WPOS
# Issue 53814 - 2017-09-07 by MAE
#If VALEUR <> AVOID.ACHAR
# End issue 53814
  WPOS = find(toUuid([M:TRNPT]AUUID(nolign-1)), WTRANSPORT.SHIPT(1..maxtab(WTRANSPORT.SHIPT)).AUUID)
  If WPOS = 0
    GMESSAGE = "Position not found"
    GOK=0 : GERR=1
    End
  Else
    WTRANSPORT.SHIPT(WPOS).TRKDEPCOD = VALEUR
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WTRANSPORT)
      If GMESSAGE <> AVOID.ACHAR
        GOK = 0 :GERR = 1: mkstat = 2
        #la classe a renvoyé une erreur mais l'erreur sur le propagate n'empêche pas l'enregistrement
        VALEUR = AVOID.ACHAR
        End
      Endif
   VALEUR = WTRANSPORT.SHIPT(WPOS).TRKDEPCOD
  Endif
# Issue 53814 - 2017-09-07 by MAE
#Endif
# End issue 53814
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran TRNPTRACK) 02/05/2016 10:50:08 (MAE)
######################################################################################
Subprog C_NBLIGNE
Local Integer IRET
Local Integer INDEX
  # ---------------------------------------------------------------------------------
  If (status = 82 or status = 73)
    If nolign > [M:TRNPT]NBLIGNE Then
      # Add a new line at the end
      If WTRANSPORT <> null
        INDEX = fmet WTRANSPORT.ADDLINE("SHIPT", [V]CST_ALASTPOS)
        If INDEX <> [V]CST_ANOTDEFINED Then
          Call SHOW_TRACK_LINE(INDEX) From SUBTRNPA
          Affzo [M:TRNPT]1-99
        Else
          Dela nolign-1,1 [M:TRNPT]NBLIGNE
          [M:TRNPT]NBLIGNE-=1
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WTRANSPORT)
          GERR = 4
          mkstat = 2
          GOK = 1
          End
        Endif
      Endif
    Endif
  Elsif status = 65 Then
    # Delete a line
    IRET = fmet WTRANSPORT.ADELLINE("SHIPT", WTRANSPORT.SHIPT([M:TRNPT]COLLIN(nolign-1)).AORDER)
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WTRANSPORT)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
    Call SHOW_TRACK_LINE([M:TRNPT]COLLIN(nolign-1)) From SUBTRNPA
    Affzo [M:TRNPT]1-99
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran TRNPTRACK) 03/05/2016 16:04:36 (FGR)
######################################################################################
Subprog AV_TRKCOD(VALEUR)
Variable Char    VALEUR()

Local Integer INDEX

  If [M:TRNPT]STLIN(nolign-1) = 0 Then
    If WTRANSPORT <> null
      INDEX = fmet WTRANSPORT.ADDLINE("SHIPT", nolign)
      If INDEX <> [V]CST_ANOTDEFINED Then
        Call SHOW_TRACK_LINE(INDEX) From SUBTRNPA
        Affzo [M:TRNPT]1-99
      Else
        # Afficher le message d'erreur
        Dela nolign-1,1 [M:TRNPT]NBLIGNE
        [M:TRNPT]NBLIGNE-=1
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WTRANSPORT)
        GERR = 4: mkstat = 2: GOK = 1
        End
      Endif
    Endif
  Endif
End

