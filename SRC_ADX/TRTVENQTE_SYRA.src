#<AdxTL>@(#)0.0.0.0 $Revision$
#------------------------------------------------------------------------------#
# Recherche du coef.de conversion de l'unité tarif vers                        #
# l'unité de commande                                                          #
#------------------------------------------------------------------------------#
# Entrée  ART      : Article                                                   #
#         CLI      : Client                                                    #
#         SAUORI   : Unité origine (tarif)                                     #
#         SAUDST   : Unité destination (commande)                              #
#         COEF (1) : Coefficient unité de commande-unité de stock : Facultatif #
# Sortie  COEF (0) : Coefficient                                               #
#------------------------------------------------------------------------------#
# Si COEF(1) est renseigné, il contient le coef conv. Unité cde-Unité stock    #
#            car c'est maintenant un coef modifiable dans les documents        #
#------------------------------------------------------------------------------#
Subprog SREC_COE(ART,CLI,SAUORI,SAUDST,COEF)
Value    Char    ART
Value    Char    CLI
Value    Char    SAUORI
Value    Char    SAUDST
Variable Decimal COEF  (0..)

  Raz COEF(0)
  Local    Integer I, J

  If SAUORI = SAUDST : COEF(0) = 1 : End : Endif
  If SAUORI = "" End Endif

  #-------------------------------------------------------#
  # Lecture ITM                                           #
  #-------------------------------------------------------#
  If ART = "" End Endif

  Local File ITMMASTER [ITM]
  Local File ITMBPC    [ITU]
  Local File TABCOEFF  [TCO]

  Read [ITM] ITM0=ART
  If fstat : Raz [F:ITM] : COEF(0)=1 : End : Endif

  # Si unité origine(tarif)=unité de stock et coeff. Unité cde-Unité de stock renseigné, c'est lui qu'il faut prendre
  If dim(COEF)>1 & SAUORI=[F:ITM]STU & COEF(1)<>0 COEF(0)=COEF(1): End : Endif

  Gosub CTR_ITMCOEF     : # init. données ITM utilisées comme diviseurs

  #-------------------------------------------------------------#
  # Lecture ITU                                                 #
  # Récupération coefficients ITU et ITM                        #
  # [ITU]UV-[ITU]UC1  / [ITU]UV-[ITU]UC2                        #
  # [ITU]UV-[ITM]UV   / [ITU]UV-[ITM]US  / [ITU]UV-[ITM]UC(i)   #
  # [ITU]UC1-[ITU]UC2                                           #
  # [ITU]UC1-[ITM]UV  / [ITU]UC1-[ITM]US / [ITU]UC1-[ITM]UC(i)  #
  # [ITU]UC2-[ITM]UV  / [ITU]UC2-[ITM]US / [ITU]UC2-[ITM]UC(i)  #
  #-------------------------------------------------------------#

  I=find(SAUORI,[F:ITM]PCU(0..dim([F:ITM]PCU)-1))
  J=find(SAUDST,[F:ITM]PCU(0..dim([F:ITM]PCU)-1))

  If CLI <> ""

    If [F:ITU]ITMREF<>ART | [F:ITU]BPCNUM<>CLI
      Read [ITU] ITU0=ART;CLI
      If fstat Raz [ITU] Endif
    Endif

    Gosub CTR_ITUCOEF     : # init. données ITM utilisées comme diviseurs

    If SAUORI=[F:ITU]SAU
      If SAUDST=[F:ITU]PCU1 COEF(0)=[F:ITU]PCUSAUCOE1                      Endif
      If SAUDST=[F:ITU]PCU2 COEF(0)=[F:ITU]PCUSAUCOE2                      Endif
      If SAUDST=[F:ITM]SAU  COEF(0)=[F:ITM]SAUSTUCOE/[F:ITU]SAUSTUCOE      Endif
      If SAUDST=[F:ITM]STU  COEF(0)=1/[F:ITU]SAUSTUCOE                     Endif
      If J<>0               COEF(0)=[F:ITM]PCUSTUCOE(J-1)/[F:ITU]SAUSTUCOE Endif
    Elsif SAUDST=[F:ITU]SAU
      If SAUORI=[F:ITU]PCU1 COEF(0)=1/[F:ITU]PCUSAUCOE1                    Endif
      If SAUORI=[F:ITU]PCU2 COEF(0)=1/[F:ITU]PCUSAUCOE2                    Endif
      If SAUORI=[F:ITM]SAU  COEF(0)=[F:ITU]SAUSTUCOE/[F:ITM]SAUSTUCOE      Endif
      If SAUORI=[F:ITM]STU  COEF(0)=[F:ITU]SAUSTUCOE                       Endif
      If I<>0               COEF(0)=[F:ITU]SAUSTUCOE/[F:ITM]PCUSTUCOE(I-1) Endif
    Elsif SAUORI=[F:ITU]PCU1
      If SAUDST=[F:ITU]PCU2 COEF(0)=[F:ITU]PCUSAUCOE2/[F:ITU]PCUSAUCOE1                        Endif
      If SAUDST=[F:ITM]SAU  COEF(0)=[F:ITM]SAUSTUCOE/([F:ITU]PCUSAUCOE1*[F:ITU]SAUSTUCOE)      Endif
      If SAUDST=[F:ITM]STU  COEF(0)=1/([F:ITU]PCUSAUCOE1*[F:ITU]SAUSTUCOE)                     Endif
      If J<>0               COEF(0)=[F:ITM]PCUSTUCOE(J-1)/([F:ITU]PCUSAUCOE1*[F:ITU]SAUSTUCOE) Endif
    Elsif SAUDST=[F:ITU]PCU1
      If SAUORI=[F:ITM]SAU  COEF(0)=([F:ITU]PCUSAUCOE1*[F:ITU]SAUSTUCOE)/[F:ITM]SAUSTUCOE      Endif
      If SAUORI=[F:ITM]STU  COEF(0)= [F:ITU]SAUSTUCOE*[F:ITU]PCUSAUCOE1                        Endif
      If I<>0               COEF(0)=([F:ITU]PCUSAUCOE1*[F:ITU]SAUSTUCOE)/[F:ITM]PCUSTUCOE(I-1) Endif
    Elsif SAUORI=[F:ITU]PCU2
      If SAUDST=[F:ITU]PCU1 COEF(0)=[F:ITU]PCUSAUCOE1/[F:ITU]PCUSAUCOE2                        Endif
      If SAUDST=[F:ITM]SAU  COEF(0)=[F:ITM]SAUSTUCOE/([F:ITU]PCUSAUCOE2*[F:ITU]SAUSTUCOE)      Endif
      If SAUDST=[F:ITM]STU  COEF(0)=1/([F:ITU]PCUSAUCOE2*[F:ITU]SAUSTUCOE)                     Endif
      If J<>0               COEF(0)=[F:ITM]PCUSTUCOE(J-1)/([F:ITU]PCUSAUCOE2*[F:ITU]SAUSTUCOE) Endif
    Elsif SAUDST=[F:ITU]PCU2
      If SAUORI=[F:ITM]SAU  COEF(0)=([F:ITU]PCUSAUCOE2*[F:ITU]SAUSTUCOE)/[F:ITM]SAUSTUCOE      Endif
      If SAUORI=[F:ITM]STU  COEF(0)= [F:ITU]SAUSTUCOE*[F:ITU]PCUSAUCOE2                        Endif
      If I<>0               COEF(0)=([F:ITU]PCUSAUCOE2*[F:ITU]SAUSTUCOE)/[F:ITM]PCUSTUCOE(I-1) Endif
    Endif
  Endif

  If COEF(0)<>0 Gosub ARRCOE : End Endif

  #-------------------------------------------------------#
  # Récupération coefficient ITM                          #
  # [ITM]UV-[ITM]US                                       #
  #-------------------------------------------------------#
  If SAUORI=[F:ITM]SAU & SAUDST=[F:ITM]STU
    COEF(0) = 1/[F:ITM]SAUSTUCOE
    If COEF(0)<>0 Gosub ARRCOE : End : Endif
  Endif
  If SAUORI=[F:ITM]STU & SAUDST=[F:ITM]SAU
    COEF(0) = [F:ITM]SAUSTUCOE
    If COEF(0)<>0 Gosub ARRCOE : End : Endif
  Endif

  #------------------------------------------------------------------#
  # Récupération coefficient ITM                                     #
  # [ITM]UV-[ITM]UC(i) / [ITM]US-[ITM]UC(i) / [ITM]UC(i)-[ITM]UC(j)  #
  #------------------------------------------------------------------#
  If SAUORI=[F:ITM]SAU
    If J<>0  COEF(0)=[F:ITM]PCUSTUCOE(J-1)/[F:ITM]SAUSTUCOE  Endif
  Elsif SAUDST=[F:ITM]SAU
    If I<>0  COEF(0)=[F:ITM]SAUSTUCOE/[F:ITM]PCUSTUCOE(I-1)  Endif
  Elsif SAUORI=[F:ITM]STU
    If J<>0  COEF(0)=[F:ITM]PCUSTUCOE(J-1)                   Endif
  Elsif SAUDST=[F:ITM]STU
    If I<>0  COEF(0)=1/[F:ITM]PCUSTUCOE(I-1)                 Endif
  Endif

  If COEF(0)<>0 Gosub ARRCOE : End Endif

  If I<>0 & J<>0   COEF(0)=[F:ITM]PCUSTUCOE(J-1)/[F:ITM]PCUSTUCOE(I-1)  Endif

  If COEF(0)<>0 Gosub ARRCOE : End Endif

  #-------------------------------------------------------#
  # Lecture TCO  : -->  Récup. coef.conversion            #
  #-------------------------------------------------------#
  Read [TCO]TCO0=SAUORI;SAUDST
  If [F:TCO]COEUOM=0 : [F:TCO]COEUOM=1 : Endif
  If fstat = 0
    COEF(0) = 1/[F:TCO]COEUOM
  Else
    Read [TCO]TCO0=SAUDST;SAUORI
    If [F:TCO]COEUOM=0 : [F:TCO]COEUOM=1 : Endif
    If fstat = 0
      COEF(0) = [F:TCO]COEUOM
    Else
      If COEF(0)=0 : Gosub CTR_COEF_TARIF : Endif
    Endif
  Endif

  Gosub ARRCOE

End
#--------------------------------------------------------------------------------------------------
$ARRCOE
COEF(0) = arr(COEF(0),0.000001)
If COEF(0)=0 : COEF(0)=1 : Endif
Return

$CTR_ITMCOEF
Local Integer K
If [F:ITM]SAUSTUCOE=0 : [F:ITM]SAUSTUCOE=1 : Endif
For K=0 To dim([F:ITM]PCU)-1
   If vireblc([F:ITM]PCU(K),2)<>"" & [F:ITM]PCUSTUCOE(K)=0
      [F:ITM]PCUSTUCOE(K)=1
   Endif
Next K

Return
#--------------------------------------------------------------------------------------------------
$CTR_ITUCOEF

  If [F:ITU]SAUSTUCOE=0  : [F:ITU]SAUSTUCOE=1  : Endif
  If [F:ITU]PCUSAUCOE1=0 : [F:ITU]PCUSAUCOE1=1 : Endif
  If [F:ITU]PCUSAUCOE2=0 : [F:ITU]PCUSAUCOE2=1 : Endif

Return
#--------------------------------------------------------------------------------------------------
#--- Concerne uniquement l'appel depuis la recherche tarif
#    si non trouvé dans table conversion TCO ne pas mettre coef=1
$CTR_COEF_TARIF
  Local Integer JL0,TRT_DEB,TRT_FIN
  Local Char    TRT_NOM

  # adxpno en V6 (Idem V140) : @GX3APP.TRT/EXEFNC$adx
  JL0=len(adxpno(1))
  While JL0>0
        If seg$(adxpno(1),JL0,JL0)="/"  : TRT_DEB=JL0 : Endif
        If seg$(adxpno(1),JL0,JL0)="$"  : TRT_FIN=JL0 : Endif
        JL0 -=1
  Wend

  TRT_NOM=seg$(adxpno(1),TRT_DEB+1,TRT_FIN-1)

  If len(TRT_NOM)>3
     If mid$(TRT_NOM,1,3)="WBT" : COEF(0)=0 : End : Endif
     If mid$(TRT_NOM,1,3)="WAT" : COEF(0)=0 : End : Endif
  Endif

Return
#--------------------------------------------------------------------------------------------------
#----------------------------------------------------------#
# Calcul de qté d'une unité de cde vers l'unite de vente   #
#   avec recherche du coef. de conversion ds ITU, ITM, TCO #
#   avec renvoi du coef                                    #
#----------------------------------------------------------#
# Entrée  QTYORI   : Quantité origine                      #
#         ART      : Article                               #
#         CLI      : Client                                #
#         SAUORI   : Unité origine                         #
#                    Unité de vente conditionnementou stock#
#         SAUDST   : Unité destination                     #
#                    Unité de vente définie dans ITM       #
# Sortie  QTYDST   : Quantité calculée                     #
#         COEF     : Coefficient trouvé vers UV            #
#----------------------------------------------------------#
Subprog SCAL_QUV(QTYORI, ART,CLI,SAUORI,SAUDST,QTYDST, COEF)
Value    Decimal QTYORI
Value    Char    ART
Value    Char    CLI
Value    Char    SAUORI
Value    Char    SAUDST
Variable Decimal QTYDST
Variable Decimal COEF

  Raz COEF

  #-------------------------------------------------------#
  # Lecture ITM :  Si l'unité est l'unité de stock        #
  #                -->  Calcul coef.conversion US-UV      #
  #                     US-UV = 1 / UV-US                 #
  #-------------------------------------------------------#
  #If ART <> ""
      Local File ITMMASTER [ITM]
      Read [ITM] ITM0=ART
      If fstat : Raz [F:ITM] : Endif

      Gosub CTR_ITMCOEF     : # init. données ITM utilisées comme diviseurs

      If SAUORI = [F:ITM]STU & [F:ITM]SAUSTUCOE <> 0
          COEF = 1 / [F:ITM]SAUSTUCOE
      Endif

      If COEF <> 0 Gosub CAL_QTY2 : End : Endif

  #Endif

  #-------------------------------------------------------#
  # Lecture ITU  : Si l'unité est une unité de cond.      #
  #                -->  Récup. coef.conversion UC-UV      #
  #-------------------------------------------------------#
  If CLI <> ""

      Local File ITMBPC [ITU]

      Read [ITU] ITU0=ART;CLI
      If fstat Raz [ITU] : Endif

      Gosub CTR_ITUCOEF     : # init. données ITU utilisées comme diviseurs

      If    SAUORI = [F:ITU]SAU  COEF  = [F:ITU]SAUSTUCOE/[F:ITM]SAUSTUCOE
      Elsif SAUORI = [F:ITU]PCU1 COEF  = ([F:ITU]PCUSAUCOE1*[F:ITU]SAUSTUCOE)/[F:ITM]SAUSTUCOE
      Elsif SAUORI = [F:ITU]PCU2 COEF  = ([F:ITU]PCUSAUCOE2*[F:ITU]SAUSTUCOE)/[F:ITM]SAUSTUCOE
      Endif

  Endif

  If COEF <> 0 Gosub CAL_QTY2 : End : Endif

  #-------------------------------------------------------#
  #                Si l'unité est une unité de cond.      #
  #                -->  Calcul coef.conversion UC-UV      #
  #                     UC-UV = UC-US / UV-US             #
  #-------------------------------------------------------#
  If ART <> ""
     If [F:ITM]SAUSTUCOE <> 0
        If SAUORI=[F:ITM]SAU
           COEF=1
        Else
           Local Integer K
           For K=0 To dim([F:ITM]PCU)-1
              If SAUORI=[F:ITM]PCU(K)
                 COEF=[F:ITM]PCUSTUCOE(K)/[F:ITM]SAUSTUCOE
                 Break
              Endif
           Next K
        Endif
     Endif
  Endif

  If COEF <> 0 : Gosub CAL_QTY2 : End : Endif

  #-------------------------------------------------------#
  # Lecture TCO  : -->  Récup. coef.conversion            #
  #-------------------------------------------------------#
  Local File TABCOEFF [TCO]

  Read [TCO]TCO0=SAUORI;SAUDST
  If [F:TCO]COEUOM=0 : [F:TCO]COEUOM=1 : Endif
  If fstat = 0 COEF = [F:TCO]COEUOM:Endif

  Gosub CAL_QTY2

End
#--------------------------------------------------------------------------------------------------
# --> Conversion de la qté
$CAL_QTY2

  If COEF = 0 COEF=1 Endif
  If COEF = 0 | COEF = 1 | QTYORI=0 QTYDST = QTYORI
  Else                              QTYDST = QTYORI*COEF
                                    Call QTEARR(QTYDST, SAUDST) From TRTDIV_SYRA :Endif
  COEF = arr(COEF,0.000001)

Return

#----------------------------------------------------------#
# Calcul de qté d'une unité de cde vers l'unite de stock   #
#   recherche du coef. de conversion ds ITM, ITU, ITM, TCO #
#   avec renvoi du coef                                    #
#----------------------------------------------------------#
# Entrée  QTYORI   : Quantité origine                      #
#         ART      : Article                               #
#         CLI      : Client                                #
#         SAUORI   : Unité origine                         #
#                    Unité de stock ou vente ou condit.    #
#         SAUDST   : Unité destination                     #
#                    Unité de stock définie dans ITM       #
# Sortie  QTYDST   : Quantité calculée                     #
#         COEF     : Coefficient trouvé vers US            #
#----------------------------------------------------------#
Subprog SCAL_QUS(QTYORI, ART,CLI,SAUORI,SAUDST,QTYDST,COEF)
Value    Decimal QTYORI
Value    Char    ART
Value    Char    CLI
Value    Char    SAUORI
Value    Char    SAUDST
Variable Decimal QTYDST
Variable Decimal COEF

Raz COEF

  Local File ITMMASTER [ITM]
If SAUORI = SAUDST COEF=1 : Gosub CAL_QTY2 : End : Endif

#-------------------------------------------------------#
# Lecture ITU  : Si l'unité est l'unité de vente        #
#                -->  Récup coef.conversion UV-US       #
#                Si l'unité est une unité de cond.      #
#                -->  Calcul coef.conversion UC-US      #
#                     UC-US = UC-UV (ITU) * UV-US (ITM) #
#-------------------------------------------------------#
If CLI <> AVOID.ACHAR Then
    Local File ITMBPC [ITU]
    Read [ITU] ITU0=ART;CLI
    If fstat Raz [F:ITU] : Endif

      Gosub CTR_ITUCOEF     : # init. données ITU utilisées comme diviseurs
      Case SAUORI
       When [F:ITU]SAU  : COEF  = [F:ITU]SAUSTUCOE
       When [F:ITU]PCU1 : COEF  = [F:ITU]PCUSAUCOE1*[F:ITU]SAUSTUCOE
       When [F:ITU]PCU2 : COEF  = [F:ITU]PCUSAUCOE2*[F:ITU]SAUSTUCOE
       When Default
      Endcase
    If COEF <> 0 Gosub CAL_QTY2:End:Endif
Endif
#-------------------------------------------------------#
# Lecture ITM  : Si l'unité est l'unité de vente        #
#                -->  Récup. coef.conversion UV-US      #
#-------------------------------------------------------#
  Read [ITM] ITM0=ART
  If fstat Raz [F:ITM] : Endif

Gosub CTR_ITMCOEF     : # init. données ITM utilisées comme diviseurs
If SAUORI = [F:ITM]SAU  COEF = [F:ITM]SAUSTUCOE :Endif
If COEF <> 0 Gosub CAL_QTY2:End:Endif

#-------------------------------------------------------#
#                Si l'unité est une unité de cond. ITM  #
#                -->  Récup. coef.conversion UC-US      #
#-------------------------------------------------------#
Local Integer K
For K=0 To dim([F:ITM]PCU)-1
   If SAUORI=[F:ITM]PCU(K)
      COEF=[F:ITM]PCUSTUCOE(K)
      Break
   Endif
Next K
If COEF <> 0 Gosub CAL_QTY2:End:Endif

#-------------------------------------------------------#
# Lecture TCO  : -->  Récup. coef.conversion            #
#-------------------------------------------------------#
Local File TABCOEFF [TCO]
Read [TCO]TCO0=SAUORI;SAUDST
If [F:TCO]COEUOM=0 : [F:TCO]COEUOM=1 : Endif
If fstat = 0 COEF = [F:TCO]COEUOM:Endif
Gosub CAL_QTY2
End

#----------------------------------------------------------#
# Calcul de qté d'une unité de cde vers l'unite destination#
#   recherche du coef. de conversion ds ITM, ITU, ITM, TCO #
#   avec renvoi du coef                                    #
#----------------------------------------------------------#
# Entrée  QTYORI   : Quantité origine                      #
#         ART      : Article                               #
#         CLI      : Client                                #
#         SAUORI   : Unité origine                         #
#                    Unité de stock ou vente ou condit.    #
#         SAUDST   : Unité destination                     #
#                    Unité de stock définie dans ITM       #
# Sortie  QTYDST   : Quantité calculée                     #
#         COEF     : Coefficient trouvé vers US            #
#----------------------------------------------------------#
Subprog SCAL_QDST(QTYORI, ART,CLI,SAUORI,SAUDST,QTYDST,COEF)
Value    Decimal QTYORI
Value    Char    ART
Value    Char    CLI
Value    Char    SAUORI
Value    Char    SAUDST
Variable Decimal QTYDST
Variable Decimal COEF

Raz COEF

  Local File ITMMASTER [ITM]
If SAUORI = SAUDST COEF=1 : Gosub CAL_QTY2 : End : Endif

#-------------------------------------------------------#
# Lecture ITM  : Si l'unité est l'unité de vente        #
#                -->  Récup. coef.conversion UV-US      #
#-------------------------------------------------------#
  Read [ITM] ITM0=ART
  If fstat Raz [F:ITM] : Endif

  Gosub CTR_ITMCOEF     : # init. données ITM utilisées comme diviseurs

  If SAUORI <> [F:ITM]STU Then
    # On revient d'abord à l'unité de stock
    Call SCAL_QUS(QTYORI, ART, CLI, SAUORI, [F:ITM]STU, QTYORI, COEF)
    SAUORI = [F:ITM]STU  # L'origine devient alors l'unité de stock
    Raz COEF
  Endif

#-------------------------------------------------------#
# Lecture ITU  : Si l'unité est l'unité de vente        #
#                -->  Récup coef.conversion UV-US       #
#                Si l'unité est une unité de cond.      #
#                -->  Calcul coef.conversion UC-US      #
#                     UC-US = UC-UV (ITU) * UV-US (ITM) #
#-------------------------------------------------------#
If CLI <> AVOID.ACHAR Then
    Local File ITMBPC [ITU]
    Read [ITU] ITU0=ART;CLI
    If fstat Raz [F:ITU] : Endif

      Gosub CTR_ITUCOEF     : # init. données ITU utilisées comme diviseurs
      Case SAUDST
       When [F:ITU]SAU  : COEF  = 1 / ([F:ITU]SAUSTUCOE)
       When [F:ITU]PCU1 : COEF  = 1 / ([F:ITU]PCUSAUCOE1*[F:ITU]SAUSTUCOE)
       When [F:ITU]PCU2 : COEF  = 1 / ([F:ITU]PCUSAUCOE2*[F:ITU]SAUSTUCOE)
       When Default
      Endcase
    If COEF <> 0 Gosub CAL_QTY2:End:Endif
Endif


If SAUDST = [F:ITM]SAU  COEF = 1 / ([F:ITM]SAUSTUCOE) :Endif
If COEF <> 0 Gosub CAL_QTY2:End:Endif

#-------------------------------------------------------#
#                Si l'unité est une unité de cond. ITM  #
#                -->  Récup. coef.conversion UC-US      #
#-------------------------------------------------------#
Local Integer K
For K=0 To dim([F:ITM]PCU)-1
   If SAUDST=[F:ITM]PCU(K)
      COEF= 1 / [F:ITM]PCUSTUCOE(K)
      Break
   Endif
Next K
If COEF <> 0 Gosub CAL_QTY2:End:Endif

#-------------------------------------------------------#
# Lecture TCO  : -->  Récup. coef.conversion            #
#-------------------------------------------------------#
Local File TABCOEFF [TCO]
Read [TCO]TCO0=SAUORI;SAUDST
If [F:TCO]COEUOM=0 : [F:TCO]COEUOM=1 : Endif
If fstat = 0 COEF = [F:TCO]COEUOM:Endif
Gosub CAL_QTY2
End

