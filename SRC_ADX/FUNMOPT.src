#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################
#    ACTION MODELISATION                                                #
#                                                                       #
# GACTION  : FSCDILL/FSCDOPT : Actions ordonnancement                   #
#                                                                       #
#########################################################################
# Paramètres
#########################################################################
$ACTION
Case ACTION
    When "OUVRE"          : Gosub OUVRE
    When "DEBUT"          : Gosub DEBUT
    When "TITRE"          : TIT = XTITLE
    When "SETBOUT"        : Gosub SETBOUT
    When "AP_CHOIX"       : Gosub AP_CHOIX
    When "OK"             : Gosub OK
    When "FIN"            : Gosub FIN
Endcase
Return

########################################################################
$OUVRE
# If GBROWS # désactivation en Web
If !(GBROWS=0 | (GBROWS=1 & GFUSION=1)) : # GH 24/11/2014 dm 103835
   GMESSAGE = mess(85,150,1) : GERR = 2 : FIN = 1
Endif

Local Char WFCY(GLONFCY) : WFCY = PARAM(1)

Local Integer  WRET, I, K
Local Integer  WSTA, WERR,WERRA, WOPTION
Local Char     OPTWCR(200)
Local Char     OPTPAR(200)
Local Char     WPAR(250)(12)
Local Integer  WLONITM
Local Integer  WSPACE
Local Integer  WEXTGANTT
Local Integer  OK
Local Integer  NBOF
Local Integer  WNBOF
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
Local Char     CUSFLT(255)
Local Char     FORMULE1(255)                        # 05.05 30049
Local Char     WMESS(150)
Local Char     WMESS1(85)
Local Char     WMESS2(85)
Local Integer  WPREMFG        : WPREMFG = 0
Local Integer  WPREOPE        : WPREOPE = 0
Local Integer  WPRELNK        : WPRELNK = 0
Local Date     WENDDAT, WENDDATMAX
Local Integer  IRESULT
Local Integer  WTRACE1,WTRACE2, WTRTMOD
Local Char     WSEPCHR, WMFGFCY(GLONFCY)
Local Integer  WHDEB,WHFIN, WHWRK
Local Integer  WOPT1
Local Char     XTITLE
Local Integer  SAVIUM : SAVIUM = adxium

#---------
# variable globale pour inhiber point d'entree OPE_FOCUS si non utile (performances)
Global Integer GSCHENTRY : GSCHENTRY = 0
GSCHENTRY = find("OPTLIB",GENTSTD(1..GNBENTREE))
Global Integer GSCHENTRYA : GSCHENTRYA = 0
GSCHENTRYA = find("OPTLIBA",GENTSTD(1..GNBENTREE))
Global Integer GSCHENTRYB : GSCHENTRYB = 0
GSCHENTRYB = find("OPTLIBB",GENTSTD(1..GNBENTREE))
Global Integer GFOCUSOPEN : GFOCUSOPEN = 0

Global Integer GINVOPEN : GINVOPEN = 0
Global Integer GCUSTOMOPEN: GCUSTOMOPEN = 0

Global Char GSCHFOCUS(200)
Global Char GSCHINV(200)



# 03.06 distinction 35512 # 05/2008 V6 GLONFCY au lieu de (3)
If dim(GOPTFCY) <= 0 : Global Char    GOPTFCY(GLONFCY) : Endif

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub CHARG_PARAM

# Ouverture des fichiers utilisés
If clalev([F:TWD])  = 0 : Local File TABWEEDIA   [TWD]  : Endif
If clalev([F:DIH])  = 0 : Local File DIAHOU      [DIH]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO  [MWS]  : Endif
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM      [MFI]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE      [MFO]  : Endif
If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING  [SCH]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif
If clalev([F:ATY])  = 0 : Local File ATYPE       [ATY]  : Endif
If clalev([F:BPC])  = 0 : Local File BPCUSTOMER  [BPC]  : Endif
If clalev ([F:TFO]) = 0 : Local File TABFOR      [TFO]  : Endif         # 05.05 30049
If clalev ([F:PJA]) = 0 : Local File PARJAL      [PJA]  : Endif         # 06.06 31012

# Déclaration classes ecran
Local Mask ORDK     [ORDK]
Local Mask OPTK     [OPTK]
Local Mask OPTW1    [OPW1]                                              # 07.05 31503
Local Mask MOPTDISPK [MODK]                                             # 02.07

# titre de la boîte
Case GFONCTION
    When "FUNMILL": XTITLE = mess(235,195,1)
    When "FUNMOPT": XTITLE = mess(177,195,1)
    When "FUNMCNS": XTITLE = mess(236,195,1)
Endcase

# contrôle des autorisations
#If   GUSRACC(1)=0 & GUSRACC(2)=0
#     Call ERREUR(mess(1,123,1)) from GESECRAN
#     # autorisation connection
#     FIN=1
#Endif

Return

########################################################################
$DEBUT
Raz [M:MOP1]
Raz [M:OPTK]
If WFCY <> "" : [M:MOP1]MFGFCY = WFCY : Else : [M:MOP1]MFGFCY = GFCY : Endif
[M:MOP1]MRPFLG = 3
[M:MOP1]UPDWCR = 2

# initialisation priorités
For I = 0 To dim([M:MOP1]TYP) - 1
    [M:MOP1]TYP(I) = I + 1
    Case I
        When 0:    [M:MOP1]FACTOR(I) = 10
        When 1:    [M:MOP1]FACTOR(I) = 100
        When 2:    [M:MOP1]FACTOR(I) = 50
        When 3:    [M:MOP1]FACTOR(I) = 20
        When 4:    [M:MOP1]FACTOR(I) = 0
        When 5:    [M:MOP1]FACTOR(I) = 0
    Endcase
Next I
[M:MOP1]NBLIG = 6

If GFONC1 = "FUNMCNS" : [M:MOP1]TRTMOD = 3 : Endif

# 06.06 31012
If [F:PJA]MFGFCY <> [M:MOP1]MFGFCY
    Read [PJA]PJA0=[M:MOP1]MFGFCY
    If fstat : Raz [PJA] : Endif
Endif
Call INIT_STARTHOUR From MFGLIB
Call CONVHOU1(GSTRTEAM1, [M:MOP1]STRTEAM1) From JALLIBB
Call CONVHOU1(GSTRTEAM2, [M:MOP1]STRTEAM2) From JALLIBB

Affzo [M:MOP1]
Gosub CHECK_WCR
Return

#########################################################################
$SETBOUT
If [M:MOP1]MFGFCY <> "" : ETABOU(GVALI) = 1 : Else : ETABOU(GVALI) = 0 : Endif     # OK
ETABOU(GSPE1) = 1 : # Paramètres
ETABOU(GABAN) = 1 : # Fin
Return

#########################################################################
$AP_CHOIX
# interception de la touche return
If REPONSE = GSTARET
    Gosub OK
    Raz REPONSE
Endif
Return

#########################################################################
$OK
FIN = 0
Raz [M:OPTK]
# lecture site
Call LECTURE ("FCY", [M:OPTK]MFGFCY, "") From CONTOBJ

If find([M:MOP1]OPTION,1,2)
    If [M:MOP1]TRACE1 = 2
        Call OUVRE_TRACE(TIT) From LECFIC
        Call ECR_TRACE(" ",0) From GESECRAN
        Call ECR_TRACE(string$(82,"-"),0) From GESECRAN
        Call PRTSCR("MAUTOPT1","MOP1","",0,1) From ATRTX3
        Call ECR_TRACE(string$(82,"-"),0) From GESECRAN
        Call ECR_TRACE(" ",0) From GESECRAN
        WHDEB = time
    Endif
    # lecture en cours
    Call TEMPON(mess(195,195,1)) From GESECRAN
    # traitement des Paramètres
    Gosub TRT_PAR
    If !WOPT1 : Call TEMPOFF From GESECRAN : Return : Endif
    # traitement des Postes
    If [M:MOP1]UPDWCR = 2 : Gosub TRT_TEC : Endif
    # préparation des critères de filtre
    Gosub SEL_OF
    # traitement des OF
    NBOF = 0 : # GH 22/07/15 bug 108630
    Gosub TRT_OF

    Gosub TRF_FILES
    Call TEMPOFF From GESECRAN
    If [M:MOP1]TRACE1 = 2
        WHFIN = time
        WHWRK = WHFIN-WHDEB
        J = mod(WHWRK,60)
        K = WHWRK/60
        K = int(K)
        WMESS=mess(106,190,1)+":"-num$(K)-mess(2,301,1)-num$(J)
        Call ECR_TRACE(WMESS,0) From GESECRAN
        # fermeture trace
        Call FERME_TRACE From LECFIC
    Endif
    # aucun OF extrait ou lecture trace
    If !NBOF : Call MESSAGE(mess(88,193,1)) From GESECRAN : Endif
    If [M:MOP1]TRACE1 = 2 : Call LEC_TRACE From LECFIC : Endif
Endif

# si aucun OF extrait, on sort
If (NBOF & [M:MOP1]OPTION=1) | [M:MOP1]OPTION=3
    WTRTMOD = [M:MOP1]TRTMOD
    WTRACE1 = [M:MOP1]TRACE1
    WTRACE2 = [M:MOP1]TRACE2
    WSEPCHR = [M:MOP1]SEPCHR
    WMFGFCY = [M:MOP1]MFGFCY
    WOPTION = [M:MOP1]OPTION
    Gosub GANTT
    Return
Endif

If [M:MOP1]OPTION = 4
    WTRACE2 = [M:MOP1]TRACE2
    WSEPCHR = [M:MOP1]SEPCHR
    Gosub OPTIMX3
Endif
Return

#########################################################################
$FIN
# 99508 mm 11.2014 - License management V7
#If WOPT1 : Gosub TRT_END From OPTLIB : Endif
adxium = SAVIUM
Return

########################################################################
$CHECK_WCR
# check presence of workcenter and parameters data on server

adxifs = [M:MOP1]SEPCHR
adxirs = chr$(13)+chr$(10)
adxium = GASCII
Raz WERR
Onerrgo ERR_LECWST
OPTWCR = func OPTLIB.FILNAM([M:MOP1]MFGFCY,"ilwst",0)
Openi OPTWCR Using [RESO]
Openi
Onerrgo

Raz WERRA
Onerrgo ERR_LECPAR
OPTPAR = func OPTLIB.FILNAM([M:MOP1]MFGFCY,"ilpar",0)
Openi OPTPAR Using [RESO]

Rdseq WPAR(0), WPAR(1), WPAR(2), WPAR(3), WPAR(4), WPAR(5), WPAR(6),
&     WPAR(7), WPAR(8), WPAR(9), WPAR(10), WPAR(11)
&     Using [RESO]

[M:MOP1]ACALSTRDAT = WPAR(8)
[M:MOP1]ACALDAYNBR = val(WPAR(9))

Openi
Onerrgo
If WERR | WERRA
    [M:MOP1]UPDWCR = 2
    [M:MOP1]AVAWCR = 1
    [M:MOP1]AVASTR = [0/0/0]
    [M:MOP1]AVAEND = [0/0/0]
    Grizo [M:MOP1]UPDWCR
Else
    [M:MOP1]AVAWCR = 2
    [M:MOP1]AVASTR = [M:MOP1]ACALSTRDAT + ([M:MOP1]OPTAMMAR * 7)
    [M:MOP1]AVAEND = ([M:MOP1]ACALSTRDAT + [M:MOP1]ACALDAYNBR) - ([M:MOP1]OPTAVMAR*7)
Endif
Return

########################################################################
$ERR_LEC
    Infbox mess(148,193,1)
    WERR = 1
Resume

###########################################################################
$ERR_LECWST
    WERR = 1
Resume

###########################################################################
$ERR_LECPAR
    WERRA = 1
Resume

########################################################################
# Contrôle horizon sélectionné (dépassement)
$CHK_DATE
# si dates incohérentes, on force ...
If [M:MOP1]UPDWCR = 1
    If [M:MOP1]STRDAT < [M:MOP1]AVASTR | [M:MOP1]ENDDAT > [M:MOP1]AVAEND
        [M:MOP1]UPDWCR = 2
    Endif
Endif

If [M:MOP1]UPDWCR = 1
    [M:MOP1]CALSTRDAT = [M:MOP1]ACALSTRDAT
    [M:MOP1]CALDAYNBR = [M:MOP1]ACALDAYNBR
    WENDDAT = [M:MOP1]CALSTRDAT + [M:MOP1]CALDAYNBR
Else
    # calcul horizon en fonction des marges amont/aval
    [M:MOP1]CALSTRDAT = [M:MOP1]STRDAT - ([M:MOP1]OPTAMMAR * 7)
    [M:MOP1]CALDAYNBR = (([M:MOP1]OPTAVMAR*7) + [M:MOP1]ENDDAT) - [M:MOP1]CALSTRDAT

    WENDDAT = [M:MOP1]CALSTRDAT + [M:MOP1]CALDAYNBR

    # calcul date maximum pour un horizon limite de 2 ans
    WENDDATMAX = gdat$(day([M:MOP1]CALSTRDAT),month([M:MOP1]CALSTRDAT),year([M:MOP1]CALSTRDAT)+2)

    # 03.06 35472
    If WENDDAT > WENDDATMAX
        # si dépassement, on force 2 ans et on écrit une trace
        [M:MOP1]CALDAYNBR = WENDDATMAX - [M:MOP1]CALSTRDAT
        [M:MOP1]STRDAT    = [M:MOP1]CALSTRDAT + (GOPTAMMAR * 7)
        [M:MOP1]ENDDAT    = [M:MOP1]CALSTRDAT + [M:MOP1]CALDAYNBR
        WENDDAT           = [M:MOP1]ENDDAT
        # 09.05 32055, si date référence en dehors des bornes, on recadre
        [M:MOP1]TRTDAT    = [M:MOP1]STRDAT
        If [M:MOP1]TRACE1 = 2
            WMESS = mess(139,193,1)
            Call ECR_TRACE(WMESS,2) From GESECRAN
            WMESS = mess(306,197,1)-tolower(mess(94,100,1))-format$(GFMD,[M:MOP1]CALSTRDAT)-
&                   tolower(mess(95,100,1))-format$(GFMD,WENDDATMAX)
            Call ECR_TRACE(WMESS,1) From GESECRAN
            Raz WMESS
        Endif
    Endif
    If [M:MOP1]TRTDAT < [M:MOP1]CALSTRDAT
        [M:MOP1]TRTDAT = [M:MOP1]STRDAT
        If [M:MOP1]TRACE1 = 2
            WMESS = mess(2,772,1)+":"-mess(83,123,1)-mess(223,197,1)-"("+format$(GFMD,[M:MOP1]TRTDAT)+")"
            Call ECR_TRACE(WMESS,1) From GESECRAN
            Raz WMESS
        Endif
    Endif
Endif

Return

########################################################################
# Traitement des paramètres
$TRT_PAR
Gosub CHK_DATE
[M:OPTK] = [M:MOP1]
If [M:OPTK]TRTMOD = 3 : [M:OPTK]TRTMOD = 2 : Endif

# 06.06 31012
If [M:MOP1]STRTEAM1 = "" : [M:MOP1]STRTEAM1 = "0800" : Endif
If [M:MOP1]STRTEAM2 = "" : [M:MOP1]STRTEAM2 = "0400" : Endif

[M:OPTK]STRTEAM1 = val([M:MOP1]STRTEAM1) / 100
[M:OPTK]STRTEAM2 = val([M:MOP1]STRTEAM2) / 100
# récupération répertoire x3 client
WOPT1 = 0
Call OPTPAR(GFONC1, WOPT1) From OPTLIB
Raz fstat
Return

########################################################################
# Traitement des postes
$TRT_TEC
[M:OPTK] = [M:MOP1]
Call OPTWST From OPTLIB
Raz fstat
Return

########################################################################
# Préparation du filtre sur la table encours (WOx)
$SEL_OF
Raz CRITERE
Raz CRITERE1
Raz CRITERE2

If [M:MOP1]WOSFLG = 2
    Case [M:MOP1]MRPFLG
        When 1:     CRITERE  = "[F:OPS]OPSSTA=3&[F:OPS]OPSTYP=2"
        When 2:     CRITERE  = "[F:OPS]OPSSTA=3&[F:OPS]OPSTYP=1"
        When 3:     CRITERE  = "[F:OPS]OPSSTA=3"
    Endcase
    Gosub LOAD_CRITERE
Endif

If [M:MOP1]WOPFLG = 2
    CRITERE  = "[F:OPS]OPSSTA=2"
    Gosub LOAD_CRITERE
Endif

If [M:MOP1]WOFFLG = 2
    CRITERE  = "[F:OPS]OPSSTA=1"
    Gosub LOAD_CRITERE
Endif

# fin de la première partie
CRITERE1 += ")"

#----------------------------------------------------------------------------------------------
GPOINT = "OPTDATSEL"
Gosub  ENTREE From EXEFNC
If !GPE
    CRITERE = "[F:OPS]OPESTR>=[M:MOP1]CALSTRDAT"
    Gosub LOAD_CRITERE2

    CRITERE = "[F:OPS]OPEEND<=[M:MOP1]ENDDAT"
    Gosub LOAD_CRITERE2

    CRITERE  = "[F:OPS]MFGFCY = [M:MOP1]MFGFCY"
    Gosub LOAD_CRITERE2
Endif

Return

########################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

########################################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 225
  CRITERE1 += "&"
  CRITERE1 += CRITERE
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return

########################################################################
# Traitement des ordres
$TRT_OF
If GSOPHIA & GUSER='VPOz'
#CHECK IGNORE_BEGIN
    Call TRT_OF('STD',[M:OPTK]MFGFCY,"OPTMFG","OPTOPE","OPTLNK","",CRITERE1,CRITERE2,[M:MOP1]FORMULE,
&               [M:MOP1]TRACE1,[M:MOP1]TRTMOD,[M:MOP1]CALSTRDAT,WENDDAT,NBOF,OK) From PITMFG

    Return
#CHECK IGNORE_END
Endif
Raz FORMULE1
If CRITERE2 = "" : CRITERE2 = "1=1" : Endif

# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
  Raz CUSFLT
  GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
  If CUSFLT = "" : CUSFLT = "1=1" : Endif

# 05.05 30049
# analyse présence formule de sélection
If [M:MOP1]FORMULE  <> ""
    Read [F:TFO]TFO0=10;[M:MOP1]FORMULE
    If !fstat
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

# -----------------------------------------------------------
#   PE pour extraction des liens de succession entre OFs
GPOINT = "INIT_ACTLINK"  : Gosub ENTREE From EXEFNC
# -----------------------------------------------------------

fstat = 0
# s'il existe une formule on débranche sur un link
If FORMULE1 <> ""
## GH 25/09/2013 bug 82915
#    Link [OPS] With [MFG]MFG0~=[F:OPS]MFGNUM, [ITF]ITF0~=[F:MFG]ROUNUM;[F:MFG]MFGFCY, [ITM]ITM0~=[F:ITF]ITMREF As [OPX]
#&              Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
#&              Order By Key OPS1(1)
    Link [OPS] With [MFG]MFG0=[F:OPS]MFGNUM, [ITF]ITF0=[F:MFG]ROUNUM;[F:MFG]MFGFCY, [ITM]ITM0=[F:ITF]ITMREF As [OPX]
&              Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
&              Order By Key OPS1(1)
    For [OPX]
       # ---- PE CHECKOPS
       GOK = 1
       GPOINT="CHECKOPS" : Gosub ENTREE From EXEFNC
       If GOK  :  Gosub PROCESS_OF : Endif
    Next
Else
    Filter [OPS] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT)
&               Order By Key OPS1(1)
    For [OPS]
       # ---- PE CHECKOPS
       GOK = 1
       GPOINT="CHECKOPS" : Gosub ENTREE From EXEFNC
       If GOK  :  Gosub PROCESS_OF : Endif
    Next
    Filter [OPS]
Endif
Return

########################################################################
# 05.05 30049
$PROCESS_OF
[M:OPTK]MFGFCY     = [F:OPS]MFGFCY
[M:OPTK]MFGNUM     = [F:OPS]MFGNUM
[M:OPTK]MFGSTA     = [F:OPS]OPSSTA
OK = 2
If find([F:OPS]OPSSTA,1,2)
    If FORMULE1 = ""
        Read [MFG]MFG0=[F:OPS]MFGNUM
        If fstat : Goto NXT2 : Endif
    Endif
    #----------------------------------------------------------------------------------------------
    GPOINT = "OPTDATCONT"
    Gosub  ENTREE From EXEFNC
    If !GPE
        If [F:MFG]STRDAT < [M:MOP1]CALSTRDAT | [F:MFG]ENDDAT > WENDDAT
          Goto NXT2
        Endif
    Endif
    # 09.05 31940
    Raz [M:OPTK]PJT
    # chargement du champ PJT
    For [MFI]MFI0 Where MFGNUM = [F:OPS]MFGNUM
                    Break
    Next
    If [F:MFI]BPCTYPDEN = 2 & [F:MFI]BPCNUM <> ""
        Read [BPC]BPC0=[F:MFI]BPCNUM
        If fstat : Raz [BPC] : Endif
        [M:OPTK]PJT = [F:BPC]BPCNAM
    Endif
    Case [M:MOP1]PJTCOD
        When 1:        If [F:MFI]VCRNUMORI <> ""   : [M:OPTK]PJT = [F:MFI]VCRNUMORI   : Endif
                       If [F:MFI]PJT <> ""         : [M:OPTK]PJT = [F:MFI]PJT         : Endif
        When 2:        If [F:MFI]PJT <> ""         : [M:OPTK]PJT = [F:MFI]PJT         : Endif
                       If [F:MFI]VCRNUMORI <> ""   : [M:OPTK]PJT = [F:MFI]VCRNUMORI   : Endif
    Endcase

    Case [M:MOP1]RELITM
        When 1: [M:OPTK]ITMREF     = [F:MFG]ROUNUM
        When 2: [M:OPTK]ITMREF = [F:MFI]ITMREF
    Endcase

    [M:OPTK]MFGSTRDAT  = [F:MFG]STRDAT
Else
    Read [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM
    If fstat : Goto NXT2 : Endif
    If [F:SCH]OPESTRDAT = [0/0/0] : Goto NXT2 : Endif
    [M:OPTK]ITMREF     = [F:SCH]ROUNUM
    [M:OPTK]MFGSTRDAT  = [F:SCH]OPESTRDAT
    For [ORD]ORD3 Where STOFCY = [M:MOP1]MFGFCY & VCRTYP = 11 & VCRNUM = [F:OPS]MFGNUM & WIPTYP = 5
        #----------------------------------------------------------------------------------------------
        GPOINT = "OPTDATCONT"
        Gosub  ENTREE From EXEFNC
        If !GPE
            If [F:ORD]STRDAT < [M:MOP1]CALSTRDAT | [F:ORD]ENDDAT > WENDDAT
                OK = 0
            Endif
        Endif
        If [M:MOP1]RELITM = 2 : [M:OPTK]ITMREF = [F:ORD]ITMREF : Endif
    Next
    #VPO 17/03/09 ajout RAZ
    Raz [M:OPTK]PJT
    # 09.05 31913
    If [F:ORD]PJT <> ""
      [M:OPTK]PJT = [F:ORD]PJT
    Endif
    If [F:ORD]VCRTYPORI <> 11 & [F:ORD]VCRNUMORI <> ""
      [M:OPTK]PJT = [F:ORD]VCRNUMORI
    Endif
Endif
If !OK : Goto NXT2 : Endif

# si formule, article déjà en ligne
If FORMULE1 = ""
    #   lecture article
    If [F:ITM]ITMREF <> [M:OPTK]ITMREF
      Read [ITM]ITM0=[M:OPTK]ITMREF
      If fstat : Raz [F:ITM] :  Endif
    Endif
    #   lecture article/site
    If [F:ITF]ITMREF <> [M:OPTK]ITMREF | [F:ITF]STOFCY <> [M:OPTK]MFGFCY
        Read [ITF]ITF0=[M:OPTK]ITMREF;[M:OPTK]MFGFCY
        If fstat : Raz [F:ITF] : Endif
    Endif
Endif

If find([F:OPS]OPSSTA,1,2)
    Gosub SEL_OFCOMPL
    If OK = 1 : Goto NXT2 : Endif
Endif

# lecture longueur type de donnée
Read [ATY]CODTYP="ITM"
If !fstat
    WITMLON = [F:ATY]LNGTYP
Else
    WITMLON = 20
Endif
WSPACE = (WITMLON - 3) - len([M:OPTK]ITMREF)
If WSPACE > 0
    Case [F:ITF]ABCCLS
        When 1: [M:OPTK]ITMREF = [M:OPTK]ITMREF+space$(WSPACE) + '"A"'
        When 2: [M:OPTK]ITMREF = [M:OPTK]ITMREF+space$(WSPACE) + '"B"'
        When 3: [M:OPTK]ITMREF = [M:OPTK]ITMREF+space$(WSPACE) + '"C"'
        When 4: [M:OPTK]ITMREF = [M:OPTK]ITMREF+space$(WSPACE) + '"D"'
    Endcase
Endif
Gosub TRTEXT
$NXT2
Return

########################################################################
# Sélections complémentaires
$SEL_OFCOMPL
OK=1
If !find([F:MFG]SCDFLG,2,4)
    # 11.05 33303
    WMESS   = mess(156,197,1)+" "+mess([M:OPTK]MFGSTA,317,1)+" "+[M:OPTK]MFGNUM+" "+mess(1,335,1)
    If [M:MOP1]TRACE1 = 2
        Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif
    Return
Endif
If [F:MFG]MFGTRKFLG > 4 : Return : Endif
If [F:MFG]CFMFLG <> 2
    WMESS   = mess(156,197,1)+" "+mess([M:OPTK]MFGSTA,317,1)+" "+[M:OPTK]MFGNUM+" "+
&             mess(182,197,1)
    If [M:MOP1]TRACE1 = 2
        Call ECR_TRACE(WMESS,1) From GESECRAN
    Endif
    Return
Endif
If [F:MFG]OPTFLG = 2 & [M:MOP1]TRTMOD = 1
    WMESS   = mess(156,197,1)+" "+mess([M:OPTK]MFGSTA,317,1)+" "+[M:OPTK]MFGNUM+" "+
&             mess(125,193,1)+"("+[F:MFG]OPTUSR+")"
    If [M:MOP1]TRACE1 = 2
        Call ECR_TRACE(WMESS,1) From GESECRAN
    Endif
    Return
Endif
OK=2

Return

########################################################################
# Traitement extraction
$TRTEXT
If !OK : Return : Endif
Call DEBTRANS From GLOCK
GOK = 1
Gosub EXTRAC
Return

########################################################################
# Extraction
$EXTRAC
WMESS   = mess(156,197,1)+" "+mess([M:OPTK]MFGSTA,317,1)+" "+[M:OPTK]MFGNUM+" "+mess(214,197,1)
Trbegin [MFG]
#[M:OPTK]ITMDES1    = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:OPTK]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:OPTK]STU        = [F:ITM]STU
If find([F:OPS]OPSSTA,1,2)
    [M:OPTK]RMNEXTQTY  = [F:MFG]RMNEXTQTY
    [M:OPTK]MFGPIO     = [F:MFG]MFGPIO
Else
    [M:OPTK]RMNEXTQTY  = [F:ORD]RMNEXTQTY
    [M:OPTK]MFGPIO     = [F:ORD]PIO
Endif
[M:OPTK]           = [M:MOP1]
# récupération répertoire x3 client
Call OPTMFG From OPTLIB
If [M:OPTK]CODRET <> 0 : Goto AB_TRTEXT : Endif

# mise à jour OF pour statut "à l'étude" si mode mise à jour
If [M:MOP1]TRTMOD = 1 & [M:OPTK]MFGSTA <> 3
    Readlock [MFG]MFG0=[M:OPTK]MFGNUM
    If fstat=1 & !GSERVEUR
        WTAB="MFG"
        WCLE=[M:OPTK]MFGNUM
        Goto ROL_TRTEXT
    Endif
    If fstat
        WTAB="MFG"
        WCLE=[M:OPTK]MFGNUM
        Goto AB_TRTEXT
    Endif
    [F:MFG]OPTFLG = 2
    [F:MFG]OPTUSR = GUSER
    Rewrite [MFG]
    Unlock [MFG]
Endif

# traces
If [M:MOP1]TRACE1 = 2
    Call ECR_TRACE(WMESS,0) From GESECRAN
Endif
NBOF += 1

Commit
Raz fstat
Return


########################################################################
# Positionnement d'un verrou sur l'entête OF
$VERROU
SYMBOLE = "MFG"+[F:MFG]MFGNUM
Lock = SYMBOLE With lockwait = 0
OK = 1
If fstat
    If [M:MOP1]TRACE1 = 2
        Call ECR_TRACE([F:MFG]MFGNUM - mess(10,100,1),1) From GESECRAN
    Endif
    fstat = 0
    OK = 0
Endif

Return


########################################################################
# appel du Gantt
$GANTT

# 03.06 distinction
GOPTFCY = [M:MOP1]MFGFCY

#------------------------------------------------------------------------------------------------------------------
# point d'entrée EXTGANTT
WEXTGANTT = 0
GPOINT = "EXTGANTT" : Gosub ENTREE From EXEFNC
#------------------------------------------------------------------------------------------------------------------
If !WEXTGANTT
    Call X3SCHEDULE(IRESULT) From ILOGLIB
Endif

# si mode simulation on sort
If WTRTMOD <> 1 : Return : Endif

If IRESULT
    Gosub OPTIMX3
    If OK = 1 : Gosub FREEX3 : Endif
Else
    Gosub FREEX3
Endif
Return


########################################################################
# transfert fichiers serveur vers client
$TRF_FILES
If GFOCUSOPEN = 0    & (dim(GSCHFOCUS) > 0)  : Call RESET_FOCUS From OPTLIBB     : Endif
If GINVOPEN = 0      & (dim(GSCHINV) > 0)    : Call RESET_INVENTORY From OPTLIBB : Endif

# focus
Call ILFIL2CSV([M:MOP1]MFGFCY,"ilfocus","v6_x3_focus") From OPTLIB

# paramètres
Call ILFIL2CSV([M:MOP1]MFGFCY,"ilpar","v6_optpar") From OPTLIB

# tunnels
Call ILFIL2CSV([M:MOP1]MFGFCY,"iltun","v6_opttun") From OPTLIB

Gosub TRF_TEC
Gosub TRF_WO

# -----------------------------------------------------------
#   PE pour extraction des liens de succession entre OFs
GPOINT = "TRF_ACTLINK"  : Gosub ENTREE From EXEFNC
If GPE : Gosub TRF_ACTLINK : Endif
# -----------------------------------------------------------

Return

########################################################################
# transfert fichiers serveur vers client -> données techniques
$TRF_TEC
Call ILFIL2CSV([M:MOP1]MFGFCY,"ilwst","v6_optwst") From OPTLIB

# postes de remplacement
Call ILFIL2CSV([M:MOP1]MFGFCY,"ilrpw","v6_optrpw") From OPTLIB

# variations de capacité
Call ILFIL2CSV([M:MOP1]MFGFCY,"ilcpv","v6_optcpv") From OPTLIB

# motifs de variations
Call ILFIL2CSV([M:MOP1]MFGFCY,"iladi","v6_optadi") From OPTLIB

# schémas hebdomadaires
Call ILFIL2CSV([M:MOP1]MFGFCY,"iltwd","v6_opttwd") From OPTLIB

# schémas horaires
Call ILFIL2CSV([M:MOP1]MFGFCY,"ildih","v6_optdih") From OPTLIB

# indisponibilités site
Call ILFIL2CSV([M:MOP1]MFGFCY,"iltuv","v6_opttuv") From OPTLIB

Return


########################################################################
# transfert fichiers serveur vers client -> WO
$TRF_WO
# ordres
Call ILFIL2CSV([M:MOP1]MFGFCY,"ilmfg","v6_optmfg") From OPTLIB

If GSOPHIA & GUSER='VPOz'
  # articles
  Call ILFIL2CSV([M:MOP1]MFGFCY,"ilitm","v6_optitm") From OPTLIB
Endif

# opérations
Call ILFIL2CSV([M:MOP1]MFGFCY,"ilope","v6_optope") From OPTLIB

# liens opérations
Call ILFIL2CSV([M:MOP1]MFGFCY,"illnk","v6_optlnk") From OPTLIB
Return

########################################################################
# transfert fichiers serveur vers client
$TRF_ACTLINK
# activity link
Call ILFIL2CSV([M:MOP1]MFGFCY,"ilacl","v6_optacl") From OPTLIB
Return

########################################################################
# Mise à jour des OF optimisés
$OPTIMX3
OK=1
Call OUINON(mess(103,190,1),OK) From GESECRAN
If OK=2
    [M:OPTK]TRACE2 = WTRACE2
    [M:OPTK]SEPCHR = WSEPCHR
    [M:OPTK]TRTMOD = WTRTMOD
    # récupération répertoire x3 client
    Call OPTRES From OPTLIBA
Endif
Return

########################################################################
# Libération des OF en cours d'optimisation (sortie sans mise à jour)
$FREEX3
# pour le moment on réactive systématiquement ...
OK=1
Call OUINON(mess(104,190,1),OK) From GESECRAN
If OK=2
    Case WTRACE1
        When 1:    Call FREEMFG(WMFGFCY, GUSER, 0) From OPTLIBA
        When 2:    Call FREEMFG(WMFGFCY, GUSER, 1) From OPTLIBA
    Endcase
Endif
Return


########################################################################
# Suppression du verrou sur l'entête OF
$DEVERROU
Unlock=SYMBOLE
Return

########################################################################
# Rollback
$ROL_TRTEXT
Rollback
Call ROLL From GLOCK
If GROLL
     If [M:MOP1]TRACE1 = 2
         Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
     Endif
Else Goto EXTRAC :Endif
Return

########################################################################
# Abandon
$AB_TRTEXT
Rollback
If [M:MOP1]TRACE1 = 2
    Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Endif
Return

########################################################################
# Chargement variables globales
$CHARG_PARAM
# Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO

# Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA

Return

#########################################################################
#                     ETIQUETTES                                        #
#########################################################################

########################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:MOP1]AVASTR
    If [M:MOP1]UPDWCR = 1
        Infbox mess(138,190,1)
        [M:MOP1]UPDWCR = 2
    Endif
Endif
End

#########################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date VALEUR
If VALEUR < [M:MOP1]STRDAT : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
If VALEUR > [M:MOP1]AVAEND
    If [M:MOP1]UPDWCR = 1
        Infbox mess(138,190,1)
        [M:MOP1]UPDWCR = 2
    Endif
Endif

End

########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
Local    Integer WERR, WERRA
Local    Char    WFCY
Local    Char    OPTWCR(200)
Local    Char    OPTPAR(200)
Local    Char    WPAR(250)(12)
GFCY=VALEUR
Gosub CHARG_PARAM
WFCY = VALEUR
Gosub CHECK_WCR
# 06.06 31012
If [F:PJA]MFGFCY <> VALEUR
    Read [PJA]PJA0=VALEUR
    If fstat : Raz [PJA] : Endif
Endif
Call INIT_STARTHOUR From MFGLIB
Call CONVHOU1(GSTRTEAM1, [M:MOP1]STRTEAM1) From JALLIBB
Call CONVHOU1(GSTRTEAM2, [M:MOP1]STRTEAM2) From JALLIBB
End

########################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
[M:MOP1]CALSTRDAT = VALEUR - ([M:MOP1]OPTAMMAR * 7)
End

########################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
[M:MOP1]CALDAYNBR = (VALEUR + ([M:MOP1]OPTAVMAR * 7)) - [M:MOP1]STRDAT
End

########################################
Subprog AM_OPTION(VALEUR)
Variable Integer VALEUR
Local Integer WETABOU(1..GNBBOU)

Case VALEUR
    When 1,2: Actzo [M:MOP1]10-20
              WETABOU(GSPE1) = 1 : # Paramètres
              WETABOU(GVALI) = 1 : # OK
              WETABOU(GABAN) = 1 : # Fin
    When 3,4  Grizo [M:MOP1]10-20
              WETABOU(GSPE1) = 0 : # Paramètres
              WETABOU(GVALI) = 1 : # OK
              WETABOU(GABAN) = 1 : # Fin
Endcase
Call SETBOUT(WETABOU) From GESECRAN
End


########################################
Subprog C_WOSFLG(VALEUR)
Variable Integer VALEUR
If [M:MOP1]WOFFLG = 1 &
&  [M:MOP1]WOPFLG = 1 &
&  VALEUR = 1
    mkstat = 1
Endif
End

########################################
Subprog AS_OPTION(VALEUR)
Variable Integer VALEUR
If GFONC1 = "FUNMCNS"
    GMENLOC(4) = 1
    Diszo [M:MOP1]TRTMOD
Endif
End

########################################
Subprog AV_TRTDAT(VALEUR)
Variable Date    VALEUR
If GFONC1 = "FUNMCNS"
    Diszo [M:MOP2]20
    Diszo [M:MOP2]WOMAR
    Diszo [M:MOP2]FRHOR
    Diszo [M:MOP2]STRTEAM1
    Diszo [M:MOP2]STRTEAM2
    Diszo [M:MOP2]45
Endif
End

########################################
Subprog AS_TRTMOD(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
End
