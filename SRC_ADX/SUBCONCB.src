#<AdxTL>@(#)7.0.0.0 $Revision$
#############################################################################################
#   Composants technique de gestion de contrat de service       Module CRM       20 Aout 2003 
#
# UPDCON    : Sous-programme de mise à jour d'un contrat de service.
#
#############################################################################################

Subprog UPDCON(SZCRECONTRT, ITRACE, ILEC_TRACE, SZCONNUM, LERRCOD) 

Value Char    SZCRECONTRT
Value Integer ITRACE
Value Integer ILEC_TRACE
Value Char    SZCONNUM
Variable Integer LERRCOD

Global Char GSZCRECONTRT
Global Integer GICRECONTRACE

Local Integer IBOPENTRACE
IBOPENTRACE=0
GSZCRECONTRT = SZCRECONTRT
GICRECONTRACE = ITRACE

If GSZCRECONTRT = ""
    GSZCRECONTRT = "SUBCONCB"
Endif

Raz LERRCOD, GMESSAGE
GOK=1
If ITRACE
    If GTRACE=""
        Call OUVRE_TRACE ("Service contract modification is running from process : " + GSZCRECONTRT) From LECFIC
        IBOPENTRACE=1
    Endif
Endif
OK=1
#--- variables
Local  Integer OK, SAVGIMPORT 
Local  Char    ACTION(20), ABREV(5) 
Local Char SAVGABREV

#--- declaration et chargement des variables objet 
ABREV="CON"
SAVGABREV = GABREV
GABREV="CON"
Gosub DEFVAR From GOBJET
SAVGIMPORT=GIMPORT : GIMPORT=1

OK=1
If ITRACE
    Call ECR_TRACE("ACTION=AVANT_OUVRE",0) From GESECRAN
Endif

ACTION="AVANT_OUVRE" : Gosub ACTION From GOBJSUB
If !OK
    Gosub ONERROR
    End
Endif

#--- ouverture de la fenêtre contrat
If clalev([M:CON0])=0 : Local Mask CON0 [CON0] : Endif
If clalev([M:CON1])=0 : Local Mask CON1 [CON1] : Endif
If clalev([M:CON4])=0 : Local Mask CON4 [CON4] : Endif
If clalev([M:CON8])=0 : Local Mask CON8 [CON8] : Endif
If clalev([M:CONG])=0 : Local Mask CONG [CONG] : Endif
If clalev([M:CON2])=0 : Local Mask CON2 [CON2] : Endif
If clalev([M:CON5])=0 : Local Mask CON5 [CON5] : Endif
Raz [M:CON0], [M:CON1], [M:CON4], [M:CON8], [M:CONG], [M:CON2], [M:CON5]

#--- ouverture des tables necessaires
If clalev([F:CON])=0 : Local File CONTSERV [CON] : Endif
Gosub OUVRE From WOCON 
If ITRACE
    Call ECR_TRACE("ACTION=OUVRE",0) From GESECRAN
Endif
ACTION="OUVRE"       : Gosub ACTION From GOBJSUB

If !OK
    Gosub ONERROR
    End
Endif

WINPROG = "WGOCON"

GREP="M"

Read [CON] CON0 = SZCONNUM
If fstat
    Gosub ONERROR
    End
Endif

#--- chargement des masques de objet
If ITRACE
    Call ECR_TRACE("MASK",0) From GESECRAN
Endif
#------------------------------------------------------------------------  
# chargement masques enregistrement entête facture
Default Mask [CON0]
Call SAIMSK("CON","IMP_ZONE","SUBCONCB") From W0CON0
If !GOK
    Gosub ONERROR
    End
Endif

Default Mask [CON1]
Call SAIMSK("CON","IMP_ZONE","SUBCONCB") From W0CON1
If !GOK
    Gosub ONERROR
    End
Endif

Default Mask [CON4]
Call SAIMSK("CON","IMP_ZONE","SUBCONCB") From W0CON4
If !GOK
    Gosub ONERROR
    End
Endif

Default Mask [CON8]
Call SAIMSK("CON","IMP_ZONE","SUBCONCB") From W0CON8
If !GOK
    Gosub ONERROR
    End
Endif

Default Mask [CONG]
Call SAIMSK("CON","IMP_ZONE","SUBCONCB") From W0CONG
If !GOK
    Gosub ONERROR
    End
Endif

Default Mask [CON2]
Call SAIMSK("CON","IMP_ZONE","SUBCONCB") From W0CON2
If !GOK
    Gosub ONERROR
    End
Endif

Default Mask [CON5]
Call SAIMSK("CON","IMP_ZONE","SUBCONCB") From W0CON5
If !GOK
    Gosub ONERROR
    End
Endif

GPOINT="MSKUPDCON" : Gosub ENTREE From EXEFNC  #CHECK IGNORE_LINE
OK=1
If ITRACE
    Call ECR_TRACE("ACTION=VERIF_CRE",0) From GESECRAN
Endif
ACTION="VERIF_MOD"   : Gosub ACTION From GOBJSUB
If !OK
    Gosub ONERROR
    End
Endif

Raz [F:CON]
Default File [F:CON]
[F:CON]=[M:CON0]
[F:CON]=[M:CON1]
[F:CON]=[M:CON4]
[F:CON]=[M:CON8]
[F:CON]=[M:CONG]
[F:CON]=[M:CON2]
[F:CON]=[M:CON5]

If ITRACE
    Call ECR_TRACE("Rewrite [F:CON]  -  CONNUM="+[F:CON]CONNUM,0) From GESECRAN
Endif

Rewrite [F:CON]
If fstat
    Call FSTA("CON") From GLOCK
    Gosub ONERROR
    End
Endif

If ITRACE
    Call ECR_TRACE("ACTION=MODIF",0) From GESECRAN
Endif
ACTION="MODIF"    : Gosub ACTION From GOBJSUB

If ITRACE
    Call ECR_TRACE("ACTION=APRES_MOD",0) From GESECRAN
Endif
ACTION="APRES_MOD"   : Gosub ACTION From GOBJSUB
If !GOK
    Gosub ONERROR
    End
Endif

If ITRACE
    Call ECR_TRACE("ACTION=FERME",0) From GESECRAN
Endif
ACTION="FERME"       : Gosub ACTION From GOBJSUB

Call FERME_TRACE From LECFIC

GIMPORT = SAVGIMPORT
GABREV = SAVGABREV

Kill GSZCRECONTRT 
Kill GICRECONTRACE

If IBOPENTRACE=1
    If ILEC_TRACE
        Call LEC_TRACE From LECFIC  
    Endif
Endif
End

##############################################################################
$ACTION
If GICRECONTRACE
   Call ECR_TRACE("ACTION="+ACTION-"IMPZON="+IMPZON-"XOK="+num$(XOK),0) From GESECRAN 
Endif

IMPMOD = 1
Case ACTION 
     When "IMP_ZONE" : Gosub SET_HEA_INFO From=GSZCRECONTRT
     When "IMP_TAB"  : Gosub SET_DET_INFO From=GSZCRECONTRT
Endcase
Return

##############################################################################
$ONERROR
Call FERME_TRACE From LECFIC
LERRCOD=1
GOK=0
GIMPORT = SAVGIMPORT
GABREV = SAVGABREV
Kill GSZCRECONTRT 
Kill GICRECONTRACE

If IBOPENTRACE=1
    If ILEC_TRACE
        Call LEC_TRACE From LECFIC  
    Endif
Endif
Return

