######################################################################################
## Etiquette ajoutée par le superviseur (Objet HRSUS) 14/08/2015 09:17:36 (JML)
######################################################################################
$ACTION
Case ACTION
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "LIENS"       : Gosub LIENS
 When "OUVRE"       : Gosub OUVRE
 When "FERME"       : Gosub FERME
 When "ANNULE"      : Gosub ANNULE
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "RAZCRE"      : Gosub RAZCRE
 When Default
Endcase
Return

######################################################################################
$OUVRE
#LIPET - 2017-04-18 - X3-29540 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#LIPET - 2017-04-18 - X3-29540 - END
Return
######################################################################################
$CREATION
$MODIF
Gosub TEXTRA
Return

######################################################################################
$LIENS
GCURLEG = [F:HRSUS]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]DES,"HRSYSUSED","DES",GCURLEG,[M]SUSCOD) From ATEXTRA
Return

$RAZCRE
  GCURLEG=""
Return

######################################################################################
$ANNULE
Call SUPTEXTRA("HRSYSUSED","DES",SUPP,[L]CODE) From ATEXTRA
Return
######################################################################################

######################################################################################
# To manage translated texts (data type AX3 & AX1) in creation and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("HRSYSUSED","DES",CLECUR1,"","HRSYSUSED","DES",GCURLEG,[F:HRSUS]SUSCOD)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DES,"HRSYSUSED","DES",GCURLEG,[F:HRSUS]SUSCOD) From ATEXTRA
Return

######################################################################################
$AP_CHANGE
Call CHGTEXTRA("HRSYSUSED","DES",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Return
######################################################################################
$FERME
#LIPET - 2017-04-18 - X3-29540 - START
 If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#LIPET - 2017-04-18 - X3-29540 - END
  If TUNNEL<>1 : Return : Endif
  If dim(VCOD)<1 : Global Char VCOD(GLONHRSUS) : Endif
  VCOD = CLE1
Return

#ADNGO - 2017-11-16 - START
$SEL_TABLE
  Case TABLE
  When "SELHRSUS"
    If clalev ([F:HRSUS])=0 : Local File HRSYSUSED [HRSUS] : Endif
    Filter [F:HRSUS]
    OBJET="HRSUS"
    START="[F:HRSUS]SUSCOD"
    If GCURLEG<>""
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRSUS]LEG="'+GCURLEG+'" | [F:HRSUS]LEG="")',"&") From GOBJSUB
    Endif
  Endcase
Return
#ADNGO - 2017-11-16 - END


Subprog TUNHRSUS(COD)
Variable Char    COD()

Local Integer TOKILL

  TOKILL = 0
  If dim(VCOD)<1
   Global Char VCOD(GLONHRSUS)
   TOKILL = 1
  Endif

  If clalev([F:HRSUS])=0 : Local File HRSYSUSED [HRSUS] : Endif

  VCOD = COD

  If VCOD="" & GLECOBJ=2
  #If no code is specified, it's better to select one of the curent legislation
    Filter [HRSUS] Where LEG=GCURLEG
    Read [F:HRSUS] First
    Filter [HRSUS]
    If !fstat : VCOD=[F:HRSUS]SUSCOD : Endif
  Else
    Read [HRSUS]HRSUS0 = GCURLEG;VCOD
  Endif

  Call OBJET("HRSUS",VCOD,GCURLEG) From GOBJET
  COD = VCOD

  If TOKILL : Kill VCOD : Endif

End

######################################################################################
Subprog VERF_PARAM(L_PARAM,L_VALINT,L_OK)
Value    Char    L_PARAM()
Value    Char    L_VALINT()
Variable Integer L_OK

If L_PARAM='SUS' & len(L_VALINT)<>3
 #LIPET - 2017-04-18 - X3-29540 - START
 ###Message 321 does not exist on GX3APP therefore i have added it on 667
 #Call ECR_TRACE(mess(321,199,1),1) From GESECRAN : #### La longueur doit être de 3 caractères
 Call ECR_TRACE(mess(667,199,1),1) From GESECRAN : #### La longueur doit être de 3 caractères
 #LIPET - 2017-04-18 - X3-29540 - END
 L_OK = 0 : End
Endif
End
######################################################################################

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#LIPET - 2017-11-01 - X3-29540 - START
 If GCURLEG <> VALEUR Then : Effzo [M:HRSUS1]TIMSUS:Endif
 GCURLEG = VALEUR
#LIPET - 2017-11-01 - X3-29540 - END

End


######################################################################################


##################################################
Subprog CONTHRSUS(COD)
Variable Char    COD
If GFONCTION = "GESHRSUS" | COD="" : End : Endif

  If clalev([F:HRSUS])=0 : Local File HRSYSUSED  [HRSUS] : Endif

  If COD <> ""
    Filter [F:HRSUS] Where SUSCOD=[L]COD
    Read [F:HRSUS] First
    Filter [F:HRSUS]
    If fstat
        GMESSAGE = COD-":"-mess(23,100,1)
        mkstat = 2 : End
    Else
        Read [F:HRSUS]HRSUS0 = GCURLEG;[L]COD
        If fstat
          Filter [F:HRSUS] Where SUSCOD=[L]COD & LEG=GCURLEG
          Read [F:HRSUS] First
          Filter [F:HRSUS]
          If [F:HRSUS]LEG<>"" & GCURLEG <> ""
            GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:HRSUS]LEG
            mkstat = 2 : End
          Endif
        Endif
    Endif
  Endif
  Filter [F:HRSUS]
End

