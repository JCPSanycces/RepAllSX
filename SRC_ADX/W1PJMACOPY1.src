#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMACOPY1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:42"
A_USER  = "DOC"
A_STAMP = "20181109230542"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIGB"
  If [M]NBLIGB=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMACOPY1 [PJMAC1]
Gosub HORODAT
Local Inpbox "PJMACOPY1" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJMAC1] As [SIM_]
Grizo [PJMAC1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJMAC1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=90 : Y1(0)=1 : Y2(0)=28
Return

$ON_SELBUD
Onevent AFTER_AREA Call AP_SELBUD(zc) From W1PJMACOPY1
Onevent INIT_AREA Call D_SELBUD(zc) From W1PJMACOPY1
Onevent BEFORE_INPUT Call AS_SELBUD(zc) From W1PJMACOPY1
Return

Subprog D_SELBUD(VALEUR)
Variable Integer VALEUR
If varinit([M]SELBUD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SELBUD(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AP_SELBUD(VALEUR)
Variable Integer VALEUR
## Action STD
Call AP_SELBUD(VALEUR) From SUBPJMACOPY
If mkstat : GERR = 1 : GZONE = "SELBUD" : GZNUM = 8255 : Endif
Gosub _AFF
End

$ON_PBUSTATE
Onevent INIT_AREA Call D_PBUSTATE(zc) From W1PJMACOPY1
Return

Subprog D_PBUSTATE(VALEUR)
Variable Integer VALEUR
If varinit([M]PBUSTATE,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_DESTCOD
Onevent AFTER_AREA Call AP_DESTCOD(zc) From W1PJMACOPY1
Onevent CONTROL Call C_DESTCOD(zc) From W1PJMACOPY1
Return

Subprog C_DESTCOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DESTCOD" : GZNUM = 7537 : Endif
Gosub _AFF
End

Subprog AP_DESTCOD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AP_DESTCOD(VALEUR) From SUBPJMACOPY
If mkstat : GERR = 1 : GZONE = "DESTCOD" : GZNUM = 7537 : Endif
Gosub _AFF
End

$ON_SELBUD1
Onevent INIT_AREA Call D_SELBUD1(zc) From W1PJMACOPY1
Return

Subprog D_SELBUD1(VALEUR)
Variable Integer VALEUR
If varinit([M]SELBUD1,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_PBUFCY
Onevent CONTROL Call C_PBUFCY(zc) From W1PJMACOPY1
Onevent BEFORE_INPUT Call AS_PBUFCY(zc) From W1PJMACOPY1
Return

Subprog AS_PBUFCY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_PBUFCY(zc) From W1PJMACOPY1
Onkey 144 Titled GBOUTP Call P_PBUFCY(zc) From W1PJMACOPY1
Onkey 146 Titled GBOUTA Call SA_PBUFCY(zc) From W1PJMACOPY1
Gosub _AFF
End

Subprog C_PBUFCY(VALEUR)
Variable Char    VALEUR()
## Action ACONTFCY
Call CONTSITE(VALEUR) From SUBAGF
If mkstat : GERR = 1 : GZONE = "PBUFCY" : GZNUM = 1344 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("FCY","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PBUFCY" : GZNUM = 1344 : Endif
 If !mkstat
  ## Action STD
  Call C_PBUFCY(VALEUR) From SUBPJMACOPY
  If mkstat : GERR = 1 : GZONE = "PBUFCY" : GZNUM = 1344 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_PBUFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "FCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_PBUFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PBUFCY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$CHG_STY
Return


