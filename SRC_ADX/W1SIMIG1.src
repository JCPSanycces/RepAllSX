#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIMIG1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:25"
A_USER  = "DOC"
A_STAMP = "20181109230625"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask SIMIG1 [SIM1]
Gosub HORODAT
Local Inpbox "SIMIG1" From GFONCTION At A_STAMP With A_WINDPREV Mask [SIM1] As [SIM_]
Grizo [SIM1]5
Grizo [SIM1]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [SIM1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=64 : Y1(0)=1 : Y2(0)=13
X1(1)=1 : X2(1)=64 : Y1(1)=14 : Y2(1)=17
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1SIMIG1
Return

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(28988,GBOUT2) From OBJDIV
Call TEXTE(28989,GBOUT3) From OBJDIV
Onkey 130 Titled GBOUT2 Call B2_NBLIG From W1SIMIG1
Onkey 131 Titled GBOUT3 Call B3_NBLIG From W1SIMIG1
Gosub _AFF
End

Subprog B2_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B2_NBLIG From SUBSIM
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B3_NBLIG From SUBSIM
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_VALID
Onevent INIT_AREA Call D_VALID(zc) From W1SIMIG1
Onevent BEFORE_INPUT Call AS_VALID(zc) From W1SIMIG1
Return

Subprog D_VALID(VALEUR)
Variable Integer VALEUR
If varinit([M]VALID,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_VALID(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_SIMFLG
Onevent INIT_AREA Call D_SIMFLG(zc) From W1SIMIG1
Onevent BEFORE_INPUT Call AS_SIMFLG(zc) From W1SIMIG1
Return

Subprog D_SIMFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]SIMFLG,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_SIMFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_EXEC
Onevent BEFORE_INPUT Call AS_EXEC(zc) From W1SIMIG1
Onevent INIT_AREA Call D_EXEC(zc) From W1SIMIG1
Return

Subprog D_EXEC(VALEUR)
Variable Char    VALEUR()
If varinit([M]EXEC,indice)=0
 VALEUR = "258"
Endif
Gosub _AFF
End

Subprog AS_EXEC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUTI) From OBJDIV
Onkey 178 Titled GBOUTI Call CL_EXEC(zc) From W1SIMIG1
Gosub _AFF
End

Subprog CL_EXEC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call CL_EXEC(VALEUR) From SUBSIM
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


