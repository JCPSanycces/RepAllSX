#<AdxTL>@(#)1.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Reprise bloc documentation du dico des trt dans la documentation
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update process documentation") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJDOC
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJDOC
End

#-------------------#
$MAJDOC
If DOSSIER<>GDOSX3 : Return : Endif
Local File =DOSSIER+".ADICTRT" [ADC] , =DOSSIER+".ADOCUMENT" [ADO] , =DOSSIER+".ADOCCLB" [ADH]
&        , =DOSSIER+".ATABDIV" [ADI]
Local Integer DOC , NBCRE
Local Char    CODDOC(GLONADI)

CODDOC = func SUBADC.CODDOC

Read [ADI]CODE=910;CODDOC
If fstat : Return : Endif : # Le code TRT n'existe pas dans la table diverse 910

If dim([F:ADC]TEXTE)<0
 Close Local File [ADC],[ADO],[ADH],[ADI]
 Return 
Endif

# Mise à jour de la table ADOCUMENT
Call ECR_TRACE(mess(81,125,1)-"ADOCUMENT:"-time$,0) From GESECRAN

NBCRE = 0

Trbegin [ADO]
 For [ADC]
  If [F:ADC]TEXTE<>""
   DOC = 0   
   For [ADO] Where LAN=GLANGUE & TYP=[L]CODDOC & COD=[F:ADC]CODTRT & [F]PAR="PRE"
    [L]DOC = 1 : Break
   Next ADO
   If !DOC
    Raz [F:ADO]
    [F:ADO]LAN    = GLANGUE
    [F:ADO]TYP    = [L]CODDOC
    [F:ADO]COD    = [F:ADC]CODTRT
    [F:ADO]LEV    = 10
    [F:ADO]SUBLEV = 20
    [F:ADO]PAR    = "PRE"
    [F:ADO]TIT    = mess(2,142,1) : # Présentation
    [F:ADO]MODULE = [F:ADC]MODULE
    [F:ADO]CODACT = [F:ADC]CODACT
    [F:ADO]CREDAT = date$ 
    [F:ADO]CREUSR = GUSER 
    [F:ADO]CRETIM = time
    Write [ADO]
    If fstat 
     Call ERREUR("ADOCUMENT"-[F:ADC]CODTRT,1) From DOSDIC
    Endif
   Else
    [F:ADO]TIT    = mess(2,142,1) : # Présentation
    [F:ADO]MODULE = [F:ADC]MODULE
    [F:ADO]CODACT = [F:ADC]CODACT
    [F:ADO]CREDAT = date$ 
    [F:ADO]CREUSR = GUSER 
    [F:ADO]CRETIM = time
    Rewrite [ADO]
    If fstat 
     Call ERREUR("ADOCUMENT"-[F:ADC]CODTRT,2) From DOSDIC
    Endif
   Endif
   Read [ADH]ADH0=[F:ADO]LAN;[F:ADO]TYP;[F:ADO]COD;[F:ADO]LEV;[F:ADO]SUBLEV
   If fstat     
    Raz [F:ADH]
    [F:ADH] = [F:ADO]
    [F:ADH]TEXTE = [F:ADC]TEXTE
    [F:ADH]CREDAT = date$ 
    [F:ADH]CREUSR = GUSER 
    [F:ADH]CRETIM = time
    Write [ADH]
    If fstat 
     Call ERREUR("ADOCCLB"-[F:ADC]CODTRT,1) From DOSDIC
    Endif
   Endif
   [F:ADC]TEXTE = ""
   Rewrite [ADC]
   If fstat 
    Call ERREUR("ADICTRT"-[F:ADC]CODTRT,2) From DOSDIC
   Endif
   NBCRE += 1
  Endif
 Next ADC
Commit

Call ECR_TRACE("count update :"-num$(NBCRE),0) From GESECRAN

Close Local File [ADC],[ADO],[ADH],[ADI]

Return
