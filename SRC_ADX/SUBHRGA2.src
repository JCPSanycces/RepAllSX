#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
##################################################################################
## Le même en prenant en compte la notion de site                               ##
##################################################################################
Subprog CONVERT_SIT(DEVORG,DEVDES,DEVSOC,INDD,INDF,DEBORG,DEBDES,CREORG,CREDES
&         ,FLTRICHE,TRICHE,SITE,TYPCOURS,DATCOURS,COURS,ARRONDI,SNS,STAT)
Value    Char    DEVORG
Value    Char    DEVDES
Value    Char    DEVSOC
Value    Integer INDD
Value    Integer INDF
Value    Decimal DEBORG(0..)
Variable Decimal DEBDES(0..)
Value    Decimal CREORG(0..)
Variable Decimal CREDES(0..)
Value    Integer FLTRICHE(0..)
Value    Decimal TRICHE(0..)
Value    Char    SITE()(0..)
Value    Integer TYPCOURS
Value    Date    DATCOURS
Value    Decimal COURS
Value    Decimal ARRONDI
Value    Integer SNS(0..)
Variable Integer STAT

# Il faut le faire même si le cours vaut 1 à cause de l'arrondi
Local Integer I
Local Integer ISITE , NBSITE
Local Char    TBSITE(GLONFCY) (1..GNBSITE)
Local Decimal SOMORG , SOMDES
Local Integer NBLIBRE , ILIBRE
Local Integer ORGFLG, DESFLG      : # Flags monnaie 'In'
Local Decimal AMTINT              : # Montant intermédiaire

# Table des sites
For I=INDD To INDF
 DEBDES(I)=0 : CREDES(I)=0
 ISITE = find(SITE(I),TBSITE(1..NBSITE))
 If !ISITE
  NBSITE += 1 : TBSITE(NBSITE) = SITE(I)
 Endif
Next I

ORGFLG=1 : DESFLG=1
I = find(DEVORG, GDEVISE(1..GNBDEV))
If I & GDEVDAT(I) <= DATCOURS : ORGFLG = 2 : Endif    : # Si devise 'Out', GDEVDAT=31/12/9999
I = find(DEVDES, GDEVISE(1..GNBDEV))
If I & GDEVDAT(I) <= DATCOURS : DESFLG = 2 : Endif

## Conversion par rapport à un cours imposé
If COURS<>0
 For ISITE=1 To NBSITE
  SOMORG = 0 : SOMDES = 0
  For I=INDD To INDF
   If FLTRICHE(I)<>0 & SITE(I)=TBSITE(ISITE)
    If CREORG(I)<>0
     SOMORG   -= CREORG(I)
     SOMDES   -= TRICHE(I)
     CREDES(I) = TRICHE(I)
    Elsif DEBORG(I)<>0
     SOMORG   += DEBORG(I)
     SOMDES   += TRICHE(I)
     DEBDES(I) = TRICHE(I)
    Elsif SNS(I)=-1
     SOMORG   -= CREORG(I)
     SOMDES   -= TRICHE(I)
     CREDES(I) = TRICHE(I)
    Else
     SOMORG   += DEBORG(I)
     SOMDES   += TRICHE(I)
     DEBDES(I) = TRICHE(I)
    Endif
   Endif
  Next I
  For I=INDD To INDF
   If FLTRICHE(I)=0 & SITE(I)=TBSITE(ISITE)
    If DEBORG(I)<>0
     If ORGFLG=1
       If DESFLG=1
         #---- 'Out' --> 'Out'
         DEBDES(I) = arr((SOMORG+DEBORG(I))*COURS, ARRONDI)-SOMDES
       Else
         #---- 'Out' --> 'In'
         If DEVDES = GEURO
            DEBDES(I) = arr((SOMORG+DEBORG(I))*COURS, ARRONDI)-SOMDES
         Else      : # Si on a un cours, c'est celui de l'Euro
            AMTINT = arr((SOMORG+DEBORG(I))*COURS, 10^(-GAROEURO))
            Call CONVERT(GEURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,AMTINT,DEBDES(I),STAT) From TRTDEV
            DEBDES(I) -= SOMDES
            If STAT : # Pas de cours de devises GEURO -> DEVDES (ACCDAT)
              GMESSAGE=mess(16,114,1)-GEURO-"->"-DEVDES-"("+format$("D:"+GFMDAT,DATCOURS)+")"
              mkstat=2 : Break 2
            Endif
         Endif
       Endif
     Else
       If DESFLG=1
         #---- 'In' --> 'Out'
         If DEVORG = GEURO
            DEBDES(I) = arr((SOMORG+DEBORG(I))*COURS, ARRONDI)-SOMDES
         Else
            Call CONVERT(DEVORG,GEURO,DEVSOC,TYPCOURS,DATCOURS,DEBORG(I),AMTINT,STAT) From TRTDEV
            DEBDES(I) = arr((SOMORG+AMTINT)*COURS, ARRONDI)-SOMDES
            If STAT : # Pas de cours de devises DEVORG -> GEURO (ACCDAT)
              GMESSAGE=mess(16,114,1)-DEVORG-"->"-GEURO-"("+format$("D:"+GFMDAT,DATCOURS)+")"
              mkstat=2 : Break 2
            Endif
         Endif
       Else
         #---- 'In' --> 'In'
         DEBDES(I) = arr((SOMORG+DEBORG(I))*COURS, ARRONDI)-SOMDES
       Endif
     Endif
     SOMORG += DEBORG(I)
     SOMDES += DEBDES(I)
    Elsif CREORG(I)<>0
     If ORGFLG=1
       If DESFLG=1
         #---- 'Out' --> 'Out'
         CREDES(I) = -(arr((SOMORG-CREORG(I))*COURS,ARRONDI)-SOMDES)
       Else
         #---- 'Out' --> 'In'
         If DEVDES = GEURO
           CREDES(I) = -(arr((SOMORG-CREORG(I))*COURS, ARRONDI)-SOMDES)
         Else
           AMTINT = arr((SOMORG-CREORG(I))*COURS, 10^(-GAROEURO))
           Call CONVERT(GEURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,AMTINT,CREDES(I),STAT) From TRTDEV
           CREDES(I) = -(CREDES(I)-SOMDES)
           If STAT : # Pas de cours de devises GEURO -> DEVDES (ACCDAT)
             GMESSAGE=mess(16,114,1)-GEURO-"->"-DEVDES-"("+format$("D:"+GFMDAT,DATCOURS)+")"
             mkstat=2 : Break 2
           Endif
         Endif
       Endif
     Else
       If DESFLG=1
         #---- 'In' --> 'Out'
         If DEVORG<>GEURO   : # Si on a un cours, c'est celui de l'Euro
           Call CONVERT(DEVORG,GEURO,DEVSOC,TYPCOURS,DATCOURS,CREORG(I),AMTINT,STAT) From TRTDEV
           CREDES(I) = -(arr((SOMORG-AMTINT)*COURS, ARRONDI)-SOMDES)
           If STAT : # Pas de cours de devises GEURO -> DEVDES (ACCDAT)
             GMESSAGE=mess(16,114,1)-GEURO-"->"-DEVDES-"("+format$("D:"+GFMDAT,DATCOURS)+")"
             mkstat=2 : Break 2
           Endif
         Else
           CREDES(I) = -(arr((SOMORG-CREORG(I))*COURS, ARRONDI)-SOMDES)
         Endif
       Else
         #---- 'In' --> 'In'
         CREDES(I) = -(arr((SOMORG-CREORG(I))*COURS, ARRONDI)-SOMDES)
       Endif
     Endif
     SOMORG -= CREORG(I)
     SOMDES -= CREDES(I)
    Endif
   Endif
  Next I
 Next ISITE
Else
 ## Conversion standard
 Local Decimal MTDORG(INDD..INDF) , MTCORG(INDD..INDF)
 Local Decimal MTDDES(INDD..INDF) , MTCDES(INDD..INDF)
 Local Integer PT(INDD..INDF) , NB2
 For ISITE=1 To NBSITE
  NB2 = INDD-1
  For I=INDD To INDF
   If SITE(I)=TBSITE(ISITE)
    NB2 += 1 : PT(NB2) = I
    MTDORG(NB2) = DEBORG(I)
    MTCORG(NB2) = CREORG(I)
   Endif
  Next I
  If NB2>0
   Call CONVERT_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS
&   ,MTDORG(INDD..NB2),MTDDES(INDD..NB2),STAT) From TRTDEV
   If STAT : # Pas de cours de devises DEVORG -> DEVDES (ACCDAT)
    GMESSAGE=mess(16,114,1)-DEVORG-"->"-DEVDES-"("+format$("D:"+GFMDAT,DATCOURS)+")"
    mkstat=2 : Break
   Endif
   Call CONVERT_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS
&   ,MTCORG(INDD..NB2),MTCDES(INDD..NB2),STAT) From TRTDEV
   If STAT : # Pas de cours de devises DEVORG -> DEVDES (ACCDAT)
    GMESSAGE=mess(16,114,1)-DEVORG-"->"-DEVDES-"("+format$("D:"+GFMDAT,DATCOURS)+")"
    mkstat=2 : Break
   Endif
  Endif
  SOMDES = 0
  NBLIBRE = 0
  For I=INDD To NB2
   If FLTRICHE(PT(I))<>0
    If CREORG(PT(I))<>0
     CREDES(PT(I)) = TRICHE(PT(I))
     SOMDES -= CREDES(PT(I))
    Elsif DEBORG(PT(I))<>0
     DEBDES(PT(I)) = TRICHE(PT(I))
     SOMDES += DEBDES(PT(I))
    Endif
   Else
    NBLIBRE += 1
    ILIBRE = I
    DEBDES(PT(I)) = MTDDES(I)
    CREDES(PT(I)) = MTCDES(I)
    SOMDES += DEBDES(PT(I))-CREDES(PT(I))
   Endif
  Next I
  If SOMDES<>0
   If NBLIBRE=1
    If CREDES(PT(ILIBRE))<>0
     CREDES(PT(ILIBRE)) += SOMDES
    Else
     DEBDES(PT(ILIBRE)) -= SOMDES
    Endif
   Else
    While SOMDES<>0
     For I=INDD To NB2
      If FLTRICHE(PT(I))=0
       If SOMDES>0
        If DEBDES(PT(I))<>0
         DEBDES(PT(I)) -= ARRONDI
        Else
         CREDES(PT(I)) += ARRONDI
        Endif
        SOMDES -= ARRONDI
       Else
        If DEBDES(PT(I))<>0
         DEBDES(PT(I)) += ARRONDI
        Else
         CREDES(PT(I)) -= ARRONDI
        Endif
        SOMDES += ARRONDI
       Endif
      Endif
      If SOMDES=0 : Break : Endif
     Next I
    Wend
   Endif
  Endif
 Next ISITE
Endif
End

#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END

