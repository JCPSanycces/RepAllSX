$ACTION
Case ACTION
     When  "INICRE"        :  Gosub INICRE
     When  "OUVRE"         :  Gosub OUVRE
     When  "LIENS"         :  Gosub LIENS
     When  "MODIF"         :  Gosub MODIF
     When   Default
Endcase
Return



#------------------------------------------------------------------------------------
$INICRE
Return

#============

$OUVRE
  If clalev([F:XB0])=0 : Local File HRSTADLM  [XB0] : Endif #XMC
  If clalev([F:XT1])=0 : Local File HRSOCSECSET1  [XT1] : Endif #XMB
  If clalev([F:XT2])=0 : Local File HRSOCSECSET3  [XT2] : Endif #XMD
  If clalev([F:XB3])=0 : Local File HRSOCSECSET2  [XB3] : Endif #XMF
  If clalev([F:XT3])=0 : Local File HRSOCSECINC2  [XT3] : Endif #XMG
  If clalev([F:XB5])=0 : Local File HRSOCSECINC1  [XB5] : Endif #XMH
  If clalev([F:XX5])=0 : Local File HRSOCSECINC1  [XX5] : Endif #XMH
  If clalev([F:XB6])=0 : Local File HRSOCSECSETS  [XB6] : Endif #XMI
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  If clalev([F:XID])=0 : Local File EMPLOID [XID] : Endif
  If clalev([F:XCT])=0 : Local File EMPLOCTR[XCT] : Endif
  If clalev([F:XLA])=0 : Local File VALEUR  [XLA] : Endif

Return


#==============================
$LIENS

    If !GIMPORT  :  Affzo [M:HRSSS1]  :  Endif
    Raz GREP

    Local Integer YI : Raz YI
    ## Rémplissage tableau salarié Préétabli
    ## Filling table predetermined employee

    nolign=0
    [M:HRSSS1]LIGD = 0
    For [F:XT2] Where [F:XT2]PER =[M:HRSSS0]PER & [F:XT2]CPYAFFNUM = [M:HRSSS0]CPYAFFNUM
      nolign+=1
      [M:HRSSS1]=[F:XT2]
    Next
    [M:HRSSS1]LIGD = nolign

    ## Rémplissage Total  salarié Préétabli
    ## Total pre filling employee

    nolign=0
    [M:HRSSS1]LIG2 = 0
    For [F:XB3] Where [F:XB3]PER =[M:HRSSS0]PER & [F:XB3]CPYAFFNUM= [M:HRSSS0]CPYAFFNUM
      nolign+=1
      [M:HRSSS1]=[F:XB3]
    Next
    [M:HRSSS1]LIG2 = nolign

    If !GIMPORT Then Affzo [M:HRSSS1] : Endif

    ## Rémplissage tableau salarié Entrants
    ## Filling table employee Incoming

    nolign=0
    [M:HRSSS2]LIG = 0
    For [F:XT3] Where [F:XT3]PER =[M:HRSSS0]PER & [F:XT3]CPYAFFNUM= [M:HRSSS0]CPYAFFNUM
      nolign+=1
      [M:HRSSS2]=[F:XT3]
    Next
    If nolign>0 Then
      [M:HRSSS2]LIG = nolign
    Endif

    ## Rémplissage tableau Récap Général
    ## Filling Table Recap General

    For [F:XB6] Where [F:XB6]PER =[M:HRSSS0]PER & [F:XB6]CPYAFFNUM= [M:HRSSS0]CPYAFFNUM
      [M:HRSSS3]=[F:XB6]
    Next

    If !GIMPORT Then Affzo [M:HRSSS3] : Endif

Return

######################################################################################
$MODIF
    Gosub ANNULE2
    Gosub CREATION2
    Gosub CALCUL
    Gosub LIENS

Return


######################################################################################

$CALCUL

Local Integer J
Local Char  XSALREEL,XSALPLAF
#Gosub OPEN_FILE

#JOJAC - 2016-01-07 - Req. No. 111847 - START

    For [XB0]  Where PER=[M]PER and CPYAFFNUM=[M]CPYAFFNUM
      [XB0]RECTYP="B00"
      Rewrite[XB0]

    Next

    For[XT1]  Where PER=[M]PER and CPYAFFNUM=[M]CPYAFFNUM
      [XT1]RGTTYP ="B01"
      Rewrite[XT1]

    Next

    For[XT2]  Where PER=[M]PER and CPYAFFNUM=[M]CPYAFFNUM
#JASMI - START
#        Call LECTURE("ADI",[XT2]STA,"1001") From CONTOBJ #4999
#JASMI - 2017-03-20 - Issue 122087 - START
#        Call LECTURE("ADI",[XT2]STA,"17004") From CONTOBJ #4999
        Call LECTURE("ADI",[XT2]STA,"11705") From CONTOBJ #4999
#JASMI - 2017-03-20 - Issue 122087 - END
#JASMI - END
           # If ![F:ADI]N1 : End : Endif

        Raz XSALREEL,XSALPLAF
        XSALREEL=num$([XT2]ACTSAL)
        XSALPLAF=num$([XT2]SALCLG)
        #Call XCALC_SAL(XSALREEL) From XGXMJ
        #Call XCALC_SAL(XSALPLAF) From XGXMJ
        Call XCALC_SAL(XSALREEL) #DEHEN - Added subprog
        Call XCALC_SAL(XSALPLAF) #DEHEN - Added subprog

        #[XT2]SCTR= [XT2]NUMASSUR + [XT2]AFREVERSER+[XT2]NJOURDEC+[XT2]SALREL+[XT2]SALPLAF+[F:ADI]N1
        [XT2]CTLFLD= [XT2]SSCNUM + [XT2]REVSER+[XT2]NUMDAY +val(XSALREEL)+val(XSALPLAF)+[F:ADI]N1

        [XT2]RSVFLD=space$(104)
        [XT2]RGTTYP="B02"
        Rewrite[XT2]

    Next

    For[XB3]  Where PER=[M]PER and CPYAFFNUM=[M]CPYAFFNUM

        Raz[XB3]TOTREV
        Raz[XB3]TOTDAY
        Raz[XB3]TOTWAG
        Raz[XB3]TOTSALCLG
        Raz[XB3]TOTCHD
        Raz[XB3]CTLFLD
        Raz[XB3]NUMMAT

        J=0
        For[XT2] Where PER=[M]PER and CPYAFFNUM=[M]CPYAFFNUM
          J+=1
          [XB3]TOTREV+=[XT2]REVSER
          [XB3]TOTDAY+=[XT2]NUMDAY
          [XB3]TOTWAG+=[XT2]ACTSAL
          [XB3]TOTSALCLG+=[XT2]SALCLG
          [XB3]TOTCHD+=[XT2]NUMCHD
          [XB3]CTLFLD +=[XT2]CTLFLD
          [XB3]NUMMAT+=[XT2]SSCNUM

        Next
        [XB3]NUMEMP=J
        [XB3]RGTTYP="B03"
        [XB3]RSVFLD=space$(116)
        Rewrite [XB3]

    Next

    For[XT3]  Where PER=[M]PER and CPYAFFNUM=[M]CPYAFFNUM

        Raz XSALREEL,XSALPLAF
        XSALREEL=num$([XT3]SAL)
        XSALPLAF=num$([XT3]SALCLG)

        #Call XCALC_SAL(XSALREEL) From XGXMJ
        #Call XCALC_SAL(XSALPLAF) From XGXMJ
        Call XCALC_SAL(XSALREEL) #DEHEN - Added subprog
        Call XCALC_SAL(XSALPLAF) #DEHEN - Added subprog

        [XT3]CTLFLD= [XT3]SSCNUM +[XT3]NUMDAY+val(XSALREEL)+val(XSALPLAF)
        [XT3]RSVFLD=space$(124)
        [XT3]RGTTYP="B04"

        Rewrite [XT3]
    Next

Delete[XB5] Where PER=[M]PER and CPYAFFNUM=[M]CPYAFFNUM
Read [XB5]HRSIA0=[M]CPYAFFNUM;[M]PER

  If fstat Then
    J=0
    Raz [XB5]TOTDAY
    Raz [XB5]TOTWAG
    Raz [XB5]TOTSALCLG
    Raz [XB5]NUMMAT
    Raz [XB5]CTLFLD
    For[XT3]  Where PER=[M]PER and CPYAFFNUM=[M]CPYAFFNUM
      J+=1
#JASMI - 2017-03-14 - START
#      [XB5]PER=[M]PER
#      [XB5]CPYAFFNUM=[M]CPYAFFNUM
#JASMI - 2017-03-14 - END
      [XB5]TOTDAY+=[XT3]NUMDAY
      [XB5]TOTWAG+=[XT3]SAL
      [XB5]TOTSALCLG+=[XT3]SALCLG
      [XB5]CTLFLD +=[XT3]CTLFLD
      [XB5]NUMMAT +=[XT3]SSCNUM
    Next
#JASMI - 2017-03-14 - START
      [XB5]PER=[M]PER
      [XB5]CPYAFFNUM=[M]CPYAFFNUM
#JASMI - 2017-03-14 - END
      [XB5]NUMEMP=J
      [XB5]RGTTYP="B05"
      [XB5]RSVFLD=space$(170)

    Write [XB5]
    If fstat Then
      Call FSTA("XB5") From GLOCK
      GOK=0
    Endif

  Endif

    For [XB6]
       Delete[XB6] Where PER=[M]PER and CPYAFFNUM=[M]CPYAFFNUM
    Next

    Read[XB3]HRSSB0=[M]CPYAFFNUM;[M]PER
    Read[XB5]HRSIA0=[M]CPYAFFNUM;[M]PER
    [XB6]TOTDAY=[XB3]TOTDAY+[XB5]TOTDAY
    [XB6]TOTWAG=[XB3]TOTWAG+[XB5]TOTWAG
    [XB6]TOTSALCLG=[XB3]TOTSALCLG+[XB5]TOTSALCLG
    [XB6]CTLFLD =[XB3]CTLFLD + [XB5]CTLFLD
    [XB6]NUMMAT =[XB3]NUMMAT+[XB5]NUMMAT
    [XB6]NUMEMP=[XB3]NUMEMP +[XB5]NUMEMP
    [XB6]PER=[M]PER
    [XB6]CPYAFFNUM=[M]CPYAFFNUM
    [XB6]RGTTYP="B06"
    [XB6]RSVFLD=space$(170)
    Write [XB6]

Return


$ANNULE2 #Supprimer la table XB002

    For[XT2]
      Delete[XT2] Where PER=[M]PER and CPYAFFNUM=[M]CPYAFFNUM

    Next


    For[XB3]
      Delete[XB3] Where PER=[M]PER and CPYAFFNUM=[M]CPYAFFNUM

    Next

    For[XT3]
      Delete[XT3] Where PER=[M]PER and CPYAFFNUM=[M]CPYAFFNUM

    Next

    For[XB6]
      Delete[XB6] Where PER=[M]PER and CPYAFFNUM=[M]CPYAFFNUM

    Next

Return


$CREATION2 #CREATION DE la table XB002

    Local Integer J , I : Raz I
     J=0

      For J=0 To [M:HRSSS1]LIGD-1
            nolign=J+1
            [F:XT2]=[M:HRSSS1]
            [F:XT2]PER  =[M]PER
            [F:XT2]CPYAFFNUM =[M]CPYAFFNUM
            Filter[XID]
              For [XID] Where  [XID]NUMSSC = num$([M:HRSSS1]SSCNUM(I))
                [XT2]CPY=[XID]CPY
                [XT2]FCY=[XID]FCY
      Next

            Write [F:XT2]
            If fstat Then
                Call FSTA("XT2") From GLOCK
                GOK=0 : Break
            Endif
      Next
     For I=0 To [M:HRSSS1]LIG2-1
            nolign=I+1
            [F:XB3]=[M:HRSSS1]
            [F:XB3]PER =[M]PER
            [F:XB3]CPYAFFNUM=[M]CPYAFFNUM
            Write [F:XB3]
            If fstat Then
                Call FSTA("XB3") From GLOCK
                GOK=0  : Break
            Endif
      Next

    For I=0 To [M:HRSSS2]LIG-1
            nolign=I+1
            [F:XT3]=[M:HRSSS2]
            [F:XT3]PER=[M]PER
            [F:XT3]CPYAFFNUM=[M]CPYAFFNUM
            Write [F:XT3]
            If fstat Then
                Call FSTA("XT3") From GLOCK
                GOK=0  : Break
            Endif
      Next

      For [F:XB6] Where [F:XB6]PER =[M:HRSSS0]PER & [F:XB6]CPYAFFNUM= [M:HRSSS0]CPYAFFNUM
       [F:XB6]=[M:HRSSS3]
       Write [F:XB6]
       If fstat Then
         Call FSTA("XB6") From GLOCK
         GOK=0  :  Break
       Endif

      Next

Return

######################################################################################
## Section automatically added (screen HRSSS1) 02/05/2016 13:56:39 (DEHEN)
######################################################################################
Subprog AVANT_LIG
  [M:HRSSS1]TOTWAG  -=[M:HRSSS1]ACTSAL(nolign-1)
  [M:HRSSS1]TOTSALCLG -=[M:HRSSS1]SALCLG(nolign-1)
  [M:HRSSS1]TOTDAY-=[M:HRSSS1]NUMDAY(nolign-1)
  [M:HRSSS1]TOTCHD -=[M:HRSSS1]NUMCHD(nolign-1)
  If NAM(nolign-1) <> "" Then
      [M:HRSSS1]NUMEMP    -= 1
  Endif
  If !GIMPORT Then Affzo [M:HRSSS1]NUMEMP,TOTWAG,TOTSALCLG,TOTDAY,TOTCHD : Endif
End

Subprog APRES_LIG
  [M:HRSSS1]TOTWAG  += [M:HRSSS1]ACTSAL(nolign-1)
  [M:HRSSS1]TOTSALCLG += [M:HRSSS1]SALCLG(nolign-1)
  [M:HRSSS1]TOTDAY += [M:HRSSS1]NUMDAY(nolign-1)
  [M:HRSSS1]TOTCHD += [M:HRSSS1]NUMCHD(nolign-1)
  If NAM(nolign-1) <> "" Then
     [M:HRSSS1]NUMEMP    += 1
  Endif
  If !GIMPORT Then Affzo [M:HRSSS1]TOTWAG,TOTSALCLG,TOTDAY,TOTCHD,NUMEMP : Endif
End

Subprog C_SSCNUM(VALEUR)
Variable Decimal VALEUR
  If len(num$(VALEUR)) <> 9 Then
      Call ERREUR (mess(48,11706,1)) From GESECRAN : mkstat=2 #DEHEN - Added message
  Endif
End

#DEHEN - Added XCALC_SAL - START
Subprog XCALC_SAL(XSALR)
Variable Char XSALR
If val(XSALR)<>0 Then

    Local Integer XI,XU : Raz XI,XU
    Local Char XDCM  : Raz XDCM
    For XI=1  To len(XSALR)
       If mid$(XSALR,XI,1)="." Then
          XU=XI
          XDCM=mid$(XSALR,XI+1,2) : Break
       Endif
    Next
    If val(XDCM)=0 Then
       XDCM="00"
    Else
      If len(XDCM)=1 Then
         XDCM=XDCM+"0"
      Elsif len(XDCM)>2 Then
         XDCM=mid$(XDCM,1,2)
      Endif
    Endif

    If XU>0 Then
       XSALR=mid$(XSALR,1,XU-1)+XDCM
    Else
       XSALR=XSALR+XDCM
    Endif
Else
    XSALR="0"
Endif
End
#DEHEN - Added XCALC_SAL - END

