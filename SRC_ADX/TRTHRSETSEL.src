########################################
$SEL_TABLE
#Tax band
Infbox TABLE
Case TABLE
 When "HRSETSEL"
  Case [M:HRSDS0]TYPAMT(nolign-1)
   When 1,2,3,4,5,13,14,15,16,17,18
    OBJET = "RUB"
    Case [M:HRSDS0]TYPAMT(nolign-1)
     When 2
      CRITERE = "TYPRUB=6 | (TYPRUB=2 & RAT2<>'') | (TYPRUB=3 & RAT2<>'')"
     When 3,4,5,13,14,15,16,17,18
      CRITERE = "TYPRUB=5"
    Endcase
   When 6
    OBJET = "CUM"
    CRITERE = "CUMTMP<>2"
   When 7
    OBJET = "VRA"
  Endcase
  VALEUR = toupper(VALEUR)
Endcase
Return

#########################################
#
##Tax band
Subprog CONTVAL(FORMULE)
Variable Char FORMULE
Local Integer I , J , T , OK, K
Local Char    OP2(2) , OP3(3) , OP(3) , CODE(80)
I = 0
While I<=len(FORMULE)-1
 OP2 = mid$(FORMULE,I,2)
 OP3 = mid$(FORMULE,I,3)
 T = 0
 #65041
 If find(OP2,"R_","V_","C_","B_")
  T = 1 : J = I+2 : I += 2 : OP = OP2
 Endif
 If find(OP3,"TA_","TB_","TC_","EA_","EB_","EC_","[F]","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_")
  T = 1 : J = I+3 : I += 3 : OP = OP3
 Endif
 If find(OP3,"[F:")
  # Expression incorrecte Remplacer par : [F]
  GMESSAGE = mid$(FORMULE,I,7)-mess(37,124,1)-"\"-mess(28,9802,1)-"[F]"
  mkstat = 2 : Break
 Endif
 If T
  While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  Case OP
   When "R_","TA_","TB_","TC_","EA_","EB_","EC_","B_","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_" : #65041
    Read [RUB]RUB0 = CODE
    If fstat
     Read [RUB]RUB1 = val(CODE)
     If !fstat
      FORMULE = left$(FORMULE,J-1)+[F:RUB]COD+right$(FORMULE,I+1)
      I += len([F:RUB]COD)-len(CODE)
      CODE = [F:RUB]COD
     Endif
    Endif
   When "[F]"
    OK = 1
    For [ATZ]DICO Where CODZONE=CODE
     If [F:ATZ]CODFIC="TIMEMPDAT"
      If clalev([F:TID])=0 : Local File TIMEMPDAT [TID] : Endif
      If evalue("type([F:TID]"+CODE+")")>=10
       OK = 0 : Break
      Endif
     Elsif [F:ATZ]CODFIC="TIMRECAP"
      If clalev([F:TIR])=0 : Local File TIMRECAP [TIR] : Endif
      If evalue("type([F:TIR]"+CODE+")")>=10
       OK = 0 : Break
      Endif
     Else
      K = find([F:ATZ]CODFIC,GEMPTAB(1..GNBEMPTAB))
      If K>0
       If clalev([F:F_E])<>0 : Close Local File [F_E] Endif
       Local File =GEMPTAB(K) [F_E]
       If evalue("type([F:F_E]"+CODE+")")>=10 | evalue("type([F:F_E]"+CODE+")")=3
        OK = 0 : Break
       Endif
      Endif
     Endif
    Next
    If !OK
     # Donnée non numérique
     mkstat = 2 : GMESSAGE = CODE-":"-mess(127,123,1) : Break
    Endif
  Endcase
  I += 1
 Else
  I += 1
 Endif
Wend
End
