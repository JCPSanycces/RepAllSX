#                                 est gérée au niveau de l'objet
#  GBO   14.05.2008 FQ 47108   Plantage transfert massif U.G.T.
##########################################################################
$TEXTE
Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

################################################################################
##
##   S/P RELATIFS AUX TABLES DIVERSES
##
################################################################################
########################################
Subprog GET_VAL_ATABDIV (PCODE, PCHAPITRE, RINTL, RINTC, RA1, RA2, RA3, RA4, RN1, RN2, RERROR)
# Rend toutes les valeurs relatives à un code d'une table diverse dans un chapitre
# Si le code ou le chapitre n'existe pas, RERROR = -1, RERROR = 0 sinosn
# ------------------------------------------------------------------------------
Value Char PCODE
Value Integer PCHAPITRE
Variable Char RINTL
Variable Char RINTC
Variable Char RA1
Variable Char RA2
Variable Char RA3
Variable Char RA4
Variable Decimal RN1
Variable Decimal RN2
Variable Integer RERROR

Local Char CHAINE

  If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif

  RERROR  = -1
  RINTL   = ""
  RINTSHO = ""
  RA1     = ""
  RA2     = ""
  RA3     = ""
  RA4     = ""
  RN1     = 0
  RN2     = 0
  For [ADI] Where NUMTAB=PCHAPITRE and CODE=PCODE
    Call LECTEXTRA (RINTL, "ATABDIV", "LNGDES", num$(PCHAPITRE), num$(PCODE)) From ATEXTRA
    Call LECTEXTRA (RINTC, "ATABDIV", "SHODES", num$(PCHAPITRE), num$(PCODE)) From ATEXTRA

    RA1 = [F:ADI]A1
    RA2 = [F:ADI]A2
    RA3 = [F:ADI]DEPCOD
   #RA4 = [F:ADI]A4
    RN1 = [F:ADI]N1
    RN2 = [F:ADI]N2
    RERROR = 0
  Next
End

########################################
Subprog GET_TDIV_ALPHA (PCODE, PCHAPITRE, PZONE, RVALEUR, RERROR)
# Rend dans RVALEUR, la valeur de la zone demandée par PZONE
# PZONE = 'L'    Libellé long
# PZONE = 'C'    Libellé Court
# PZONE = '1'    Zone Libre 1
# PZONE = '2'    Zone Libre 2
# PZONE = '3'    Code dépendance
# PZONE = '4'    Zone Libre 4
# Si le code ou le chapitre n'existe pas, RERROR = -1,
# Si PZONE est invalide RERROR = -2
# RERROR = 0 sinon
# ------------------------------------------------------------------------------
Value Char PCODE
Value Integer PCHAPITRE
Value Char PZONE
Variable Char RVALEUR
Variable Integer RERROR

Local Char INTL
Local Char INTC
Local Char A1
Local Char A2
Local Char A3
Local Char A4
Local Decimal N1
Local Decimal N2

  If PZONE <> 'L' and PZONE <> 'C' and PZONE <> '1' and PZONE <> '2' and PZONE <> '3' and PZONE <> '4' Then
    # Le code fourni est invalide
    RERROR = -2
  Else
    Call GET_VAL_ATABDIV (PCODE, PCHAPITRE, INTL, INTC, A1, A2, A3, A4, N1, N2, RERROR)
    If RERROR = 0 Then
      If PZONE = 'L' Then
        RVALEUR = INTL
      Elsif PZONE = 'C' Then
        RVALEUR = INTC
      Elsif PZONE = '1' Then
        RVALEUR = A1
      Elsif PZONE = '2' Then
        RVALEUR = A2
      Elsif PZONE = '3' Then
        RVALEUR = A3
      Elsif PZONE = '4' Then
        RVALEUR = A4
      Endif
    Endif
  Endif
End

########################################
Subprog GET_TDIV_NUM (PCODE, PCHAPITRE, PZONE, RVALEUR, RERROR)
# Rend dans RVALEUR, la valeur de la zone demandée par PZONE
# PZONE = '1'    Zone Libre num 1
# PZONE = '2'    Zone Libre num 2
# Si le code ou le chapitre n'existe pas, RERROR = -1,
# Si PZONE est invalide RERROR = -2
# RERROR = 0 sinon
# ------------------------------------------------------------------------------
Value Char PCODE
Value Integer PCHAPITRE
Value Char PZONE
Variable Decimal RVALEUR
Variable Integer RERROR

Local Char INTL
Local Char INTC
Local Char A1
Local Char A2
Local Char A3
Local Char A4
Local Decimal N1
Local Decimal N2

  If PZONE <> '1' and PZONE <> '2' Then
    # Le code fourni est invalide
    RERROR = -2
  Else
    Call GET_VAL_ATABDIV (PCODE, PCHAPITRE, INTL, INTC, A1, A2, A3, A4, N1, N2, RERROR)
    If RERROR = 0 Then
      If PZONE = '1' Then
        RVALEUR = N1
      Elsif PZONE = '2' Then
        RVALEUR = N2
      Endif
    Endif
  Endif
End

################################################################################
##
##   S/P DIVERS
##
################################################################################
########################################
Funprog GET_LIBELLE_PARAM (PARAM)
# Rend le libellé du paramètre passé
# ------------------------------------------------------------------------------
Value Char    PARAM

Local Char LCHAINE(50)

  If clalev([F:ADP])=0 : Local File ADOPAR    [ADP] : Endif

  Read [ADP]ADP1=PARAM
  If fstat Then
    LCHAINE = ""
  Else
    Call DECODE_TEXTE ([F:ADP]NAM, LCHAINE)
  Endif
End LCHAINE

