###############################################################################
#*! Syracused in Class TABCOUAFF as GET_NEW_REFERENCE in FXDFCT_SYRA
Subprog GET_NUMERO(PABREV, PNUMAFF, PINDEX, PCPY, PFCY, PDATE, RNUMERO, STAT)
# Numérote les objets métiers
# PABREV  : Abréviation (standard) de la table ppale de l'objet métier
# PNUMAFF : indice du compteur de l'objet dans l'affectation des compteurs
# PINDEX  : Rang de l'index à utiliser pour contrôler l'absence du numéro attribué
# PCPY    : Société
# PFCY    : Site de référence pour le compteur
# PDATE   : Date de référence pour le compteur
#
# Rend :
# RNUMERO : Numéro
# STAT    : Statut (0 : OK, >0 : KO)
# ------------------------------------------------------------------------------
Value    Char    PABREV
Value    Integer PNUMAFF
Value    Integer PINDEX
Value    Char    PCPY
Value    Char    PFCY
Value    Date    PDATE
Variable Char    RNUMERO
Variable Integer STAT

Local Integer L_NBESSAI
Local Char    L_COMPTEUR(5)
Local Char    MESSA(255)
Local Char    COMP(6)       : # Complement (end of accounting context current fiscal year) FQ105344

  If clalev([F:ATB])=0  : Local File ATABLE    [ATB]  : Endif  : # Table des tables
  If clalev([F:TCA])=0  : Local File TABCOUAFF [TCA]  : Endif  : # Table des affectations de compteurs
  If clalev([F:ANM])=0  : Local File ACODNUM   [ANM]  : Endif  : # Counter table FQ105344
  If clalev([F:WFIS])=0 : Local File FISCYEAR  [WFIS] : Endif  : # Fiscal year table FQ105344

# Recherche de la table correspondant à l'abréviation
  Read [ATB]ABRFIC = PABREV
  If fstat : Raz [F:ATB] : Endif

  # Recherche du compteur de document
  Local Char    L_SOCIETE(GLONCPY) :   L_SOCIETE = PCPY
  Local Integer L_MODULE           :   L_MODULE  = [F:ATB]MODULE
  Local Integer B_TCAFND
  Gosub FAS_LECTCA
  If (!B_TCAFND) Then : Raz [F:TCA] : Endif

  L_COMPTEUR     = [F:TCA]CODNUM(PNUMAFF)
  If L_COMPTEUR = "" Then
    L_COMPTEUR   = PABREV                     : # Par défaut on prend l'abréviation de la table comme compteur
  Endif

  # FQ105344 START
  # Complement (year of the current fiscal year end date of the accounting and fiscal context)
  COMP   = ""

  # Reading of counters table to know on how many caracters we must set the complement
  # If it's 4, the year is return on four digits.
  # If it's 6, the year is return on four digits with the number of the current period on two digits
  # Else the year is return on its last two digits
  Read [F:ANM]ANM0=L_COMPTEUR
  If !fstat
    Local Integer LIGNE
    LIGNE = find(9,[F:ANM]POSTYP) : # Searching the Complement. It could be not found, it's not an issue.
    If (LIGNE > 0)
      # Reading the acounting and financial current fiscal year of the company
      Read [F:WFIS]FIY1=PCPY;[V]CST_CNXCPFI;[V]CST_TECOURA
      If fstat
        # Error in the automatic counter (COUNTER) : valeur(fstat)
        GMESSAGE = mess(22,7770,1)-"("+L_COMPTEUR+") :" - num$(fstat)
        STAT     = 99
        End
      Endif

      Case [F:ANM]POSLNG(LIGNE-1)
        When 4 :
          COMP = format$("D:YYYY",[F:WFIS]DATENDFIY)
        When 6 :
          COMP = format$("D:YYYY",[F:WFIS]DATENDFIY)+format$("N0:2",[F:WFIS]INDCURPER)
        When Default :
          COMP = format$("D:YY",[F:WFIS]DATENDFIY)
      Endcase
    Endif
  Endif
  # FQ105344 END

  $ININUM
  # Appel du compteur de numérotation Syracuse (compatible jusqu'à AKIRA Upgrade 8 inclus)
  STAT = func ANM_TOOL.NUMERO([V]GACTX,L_COMPTEUR,PFCY,PDATE,COMP,RNUMERO,MESSA)
  GPOINT = "NUMEROFAS" : Gosub ENTREE From EXEFNC
  If (STAT>=[V]CST_AERROR)
    # Erreur dans la numérotation automatique (COMPTEUR) : xxxxx
    GMESSAGE = mess(22,7770,1)-"("+L_COMPTEUR+") :" - MESSA
    End
  Else
    # Contrôle existence du numéro rendu
    Assign "[G:"+PABREV+"]currind" With PINDEX
    Assign "[G:"+PABREV+"]currlen" With 1
    Default File "["+PABREV+"]"
    Look [F] = RNUMERO
    If !fstat : # Ca existe déjà, on prend le suivant..
      L_NBESSAI += 1
      If L_NBESSAI>100 : # On va quand même pas boucler éternellement
        # Erreur dans la numérotation automatique (COMPTEUR) : Séquence de numérotation déjà utilisée
        GMESSAGE  = mess(22,7770,1)-"("+L_COMPTEUR+") :"-mess(135,7770,1)
        STAT = 99
        End
      Else
        Goto ININUM
      Endif
    Endif
  Endif
End

########################################
#
# FAS_LECTCA - Accès à TABCOUAFF selon société ou législation FQ85464
#
# En entrée
#   L_MODULE
#   L_SOCIETE
# En sortie
#   B_TCAFND à vrai si un enregistrement TABCOUAFF trouvé
#
$FAS_LECTCA

Local Integer INDEX_LEG
  B_TCAFND = 0
  INDEX_LEG = -1

  #-1 ---------------------------
  If ( L_SOCIETE <> "" ) Then
    # look for the counter for the given company
    Read [TCA]TCA0=L_MODULE;"";L_SOCIETE
    If (!fstat) Then
      B_TCAFND = 1
    Else
      # look for the legislation of the given company in GLECSOC
      INDEX_LEG = find(L_SOCIETE, GSOC)
      If ( INDEX_LEG > 0 ) Then
        # look for the counter for the legislation of the given company
        Read [TCA]TCA0=L_MODULE;GLEGSOC(INDEX_LEG);""
        If (!fstat) Then
          B_TCAFND = 1
        Else
          # if still not found, look for the counter of the whole module
          Read [TCA]TCA0=L_MODULE;"";""
          If (!fstat) Then
            B_TCAFND = 1
          Endif
        Endif
      Else
        # if still not found, look for the counter of the whole module
        Read [TCA]TCA0=L_MODULE;"";""
        If (!fstat) Then
          B_TCAFND = 1
        Endif
      Endif
    Endif
  Endif
  #-1 ---------------------------
Return

