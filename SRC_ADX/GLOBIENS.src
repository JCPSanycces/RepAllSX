########################################
Subprog VIRE_PLN_STD_NOK (PCPY, PSTD, NB_PLN)
# Enlève d'une combo menu local tous les plans non gérés sur la société
# ou gérés selon une norme différente des normes passées en paramètre, et
# retourne le nombre de plan conservés.
# La rubrique doit être déclarée en MM et pas en M pour que la destruction
# des valeurs puisse fonctionner.
# S/P à appeler en "Avant Saisie" d'une rubrique.
# Si PSTD (0) = 0 la combo conserve tous les plan gérés sur la société
# et le fonctionnement est analogue à VIRE_PLN_NON_GERES avec PCNX=0
#  peut être utile pour passer notamment G301AUC (Aucun)
Value    Char    PCPY     : # Société
Value    Integer PSTD ()  : # Liste des modes des plans à conserver
Variable Integer NB_PLN   : # Nombre de plans conservés

Local    Integer N_I      : # Indice du plan
Local    Integer LCONTEXT : # Contexte du plan
Local    Integer LTROUVE  : # Indicateur des gestion du plan N_I dans le contexte LCONTEXT
Local    Integer I_PLN    : # Rang du plan dans le contexte


  If clalev([F:CNX])  = 0 : Local File CONTEXT     [CNX]  : Endif : # Contextes

  NB_PLN = 0
  GMENLOC(G301AUC) = 1

  #>1 >>>>>>>>>>>>>>>
  For N_I = 1 To G301MAX
    Call GET_CNX_FROM_PLAN ( PCPY, N_I, LCONTEXT) From GLOBIENS : # Contexte du plan ?
    # --------------------------
    If ( LCONTEXT > 0 ) Then
      Read [CNX]CNX0=PCPY;LCONTEXT : # Le contexte est-il géré pour cette société ?
      If  (fstat) Then
        # Le contexte (donc le plan) n'est pas géré pour cette société
        GMENLOC(N_I) = 1
      Else
        # Le contexte est géré pour cette société
        I_PLN =  find(N_I,[F:CNX]PLNCAA)
        If ( PSTD(0) <> 0 and find([F:CNX]PLNSTD(I_PLN-1), PSTD) = 0 )
          GMENLOC(N_I) = 1 : # Le plan ne correspond pas à la norme passé en paramètre
        Else
          NB_PLN += 1
        Endif
      Endif
    Else
      GMENLOC(N_I) = 1
    Endif
  Next N_I
  #<1 <<<<<<<<<<<<<<
End
