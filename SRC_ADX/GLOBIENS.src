###############################################################################
# Permet de savoir si une société contient au moins un bien inactif
Funprog HAS_CPY_FAS_DISABLE (PCPY)
# ------------------------------------------------------------------------------
Value Char PCPY
Local Integer LRET

  LRET = G_NON

  If clalev([F:FAS])  = 0 : Local File FXDASSETS   [FAS]  : Endif

  Filter [FAS] Where ( CPY = PCPY ) & ( ENAFAS = G_NON )
  # FQ37882 Read [FAS]FAS0 First
  Read [FAS] First With Nohint
  Filter [FAS]

  If !fstat : LRET = G_OUI : Endif

End LRET

###############################################################################
# Permet de savoir si un bien n'a subit aucun événement autre que celui
# d'immobilisation, et que celui-ci n'a pas été comptabilisé.
# Cette fonction est utilisée dans SUBFAS pour savoir si un bien peut passer d'actif
# à inactif.
Funprog IS_FAS_MODIFIED (PCPY, PAASREF)
# ------------------------------------------------------------------------------
Value Char PCPY
Value Char PAASREF
Local Integer LRET

 LRET = G_NON
 If clalev([F:ADI])  = 0 : Local File ATABDIV   [ADI]  : Endif

 # FQ59941
 Local Char LREQUETE(200)
 LREQUETE = "CODE<>'FASCRT' and CODE<>'FASRUCRT'  "
 For [ADI] Where NUMTAB=GTD_EVENT & N2=GVML_OMBIEN  & evalue(LREQUETE)  # Table diverse 962
  If find([F:ADI]A2,GTABEVT) : # FQ59900
   If clalev([F:EFS]) : Close Local File [F:EFS] : Endif
   Local File =[F:ADI]A2 [EFS]
   Filter [EFS] Where ( CPY = PCPY ) & ( REF = PAASREF )
   If rowcount([EFS]) > 0 : LRET = G_OUI : Break : Endif
  Endif
 Next
 If LRET<>G_OUI
  Read [F:ADI]CODE=GTD_EVENT;"FASCRT" # Table diverse 962
  If clalev([F:EFS]) : Close Local File [F:EFS] : Endif
  Local File =[F:ADI]A2 [EFS]
  Filter [EFS] Where ( CPY = PCPY ) & ( REF = PAASREF ) & (CPTFLG = G_OUI)
  If rowcount([EFS]) > 0 : LRET = G_OUI : Endif
 Endif
 Filter [EFS]

End LRET

###############################################################################
# X3-63786 Permet de savoir si un bien a été comptabilisé via les évènements
#
Funprog IS_FAS_POSTED (PCPY, PAASREF)
# ------------------------------------------------------------------------------
Value Char PCPY
Value Char PAASREF
Local Integer LRET

 LRET = G_NON
 If clalev([F:ADI])  = 0 : Local File ATABDIV   [ADI]  : Endif

 # FQ59941
 Local Char LREQUETE(200)
 LREQUETE = "CODE<>'FASRUCRT'  "
 For [ADI] Where NUMTAB=GTD_EVENT & N2=GVML_OMBIEN  & evalue(LREQUETE)  # Table diverse 962
  If find([F:ADI]A2,GTABEVT) : # FQ59900
   If clalev([F:EFS]) : Close Local File [F:EFS] : Endif
   Local File =[F:ADI]A2 [EFS]
   Filter [EFS] Where ( CPY = PCPY ) & ( REF = PAASREF ) & (CPTFLG = G_OUI)
   If rowcount([EFS]) > 0 : LRET = G_OUI : Break : Endif
  Endif
 Next

End LRET

