Funprog AX3_RIGHT(PCHAINE, PLEN)
# Rend les PLEN caractères de droite de la chaine
Value Char    PCHAINE()
Value Integer PLEN

Local Char    LCHAINE(len(PCHAINE))

  PCHAINE = right$(PCHAINE, len(PCHAINE)-PLEN+1)
End PCHAINE

################################################################################
Subprog GET_DATE_MONTH_DELTA (PDATEDEB, PDATEFIN, RNBMOIS)
# rend le nombre de mois compris entre deux dates
# Note : un mois commencé compte pour un mois
# RNBMOIS = -1 si l'une ou l'autre des dates n'est pas renseignée
# ------------------------------------------------------------------------------
Value Date PDATEDEB
Value Date PDATEFIN
Variable Integer RNBMOIS

Local Integer AN_1_DATE
Local Integer AN_2_DATE
Local Integer MOIS_1_DATE
Local Integer MOIS_2_DATE


############ Gbn-22102004
#
#  If PDATEDEB = [0/0/0] or PDATEFIN = [0/0/0] Then
#    RNBMOIS = -1
#  Else
#    AN_1_DATE = year (PDATEDEB)
#    MOIS_1_DATE = month (PDATEDEB)
#    AN_2_DATE = year (PDATEFIN)
#    MOIS_2_DATE = month (PDATEFIN)
#    RNBMOIS = abs (
#&                    (abs (AN_1_DATE - AN_2_DATE) * 12)
#&                  - (abs (MOIS_1_DATE - MOIS_2_DATE))
#&                 ) + 1
#  Endif
############

  If PDATEDEB = [0/0/0] or PDATEFIN = [0/0/0] Then
    RNBMOIS = -1
  Else
    If PDATEDEB<PDATEFIN
     AN_1_DATE = year (PDATEDEB)
     MOIS_1_DATE = month (PDATEDEB)
     AN_2_DATE = year (PDATEFIN)
     MOIS_2_DATE = month (PDATEFIN)
    Else
     AN_1_DATE = year (PDATEFIN)
     MOIS_1_DATE = month (PDATEFIN)
     AN_2_DATE = year (PDATEDEB)
     MOIS_2_DATE = month (PDATEDEB)
    Endif
    RNBMOIS = (AN_2_DATE-AN_1_DATE)*12 + (MOIS_2_DATE-MOIS_1_DATE)+1
  Endif

End

################################################################################
Subprog CALCUL_NB_D_M_W_Y (P_DATE_DEB, P_DATE_FIN, R_NB_JOUR, R_NB_MOIS, R_NB_WEEK, R_NB_YEAR)
# calcul les nombres de jour, mois et semaines pour une période
Value Date P_DATE_DEB
Value Date P_DATE_FIN
Variable Integer R_NB_JOUR
Variable Integer R_NB_MOIS
Variable Integer R_NB_WEEK
Variable Decimal R_NB_YEAR

Local Integer LOK
Local Decimal W_NB_AN

  Call GET_DATE_MONTH_DELTA (P_DATE_DEB, P_DATE_FIN, R_NB_MOIS) From GLOBIENS
  R_NB_JOUR = P_DATE_FIN - P_DATE_DEB + 1
  R_NB_WEEK = arr(R_NB_JOUR/7, 0)

  Call CALCUL_DUREE_EN_ANNEE (P_DATE_DEB, P_DATE_FIN, W_NB_AN, LOK )
  R_NB_YEAR = W_NB_AN

End


##----------------------------------------------------------------------------##
## Calcul du nombre d'année entre 2 dates                                     ##
##----------------------------------------------------------------------------##
Subprog CALCUL_DUREE_EN_ANNEE (PDATEDEB, PDATEFIN, RDUREE, ROK )
Value Date  PDATEDEB
Value Date  PDATEFIN
Variable Decimal RDUREE
Variable Integer ROK

Local Decimal WNBJOUR29

If PDATEDEB > PDATEFIN
   ROK = G_NON
   End
Endif

Call CALCUL_NB_2902 (PDATEDEB , PDATEFIN, WNBJOUR29, ROK) From GLOBIENS

# On diminue le nb de 29/02 du nombre de jour pour calcul de la durée
RDUREE= arr( (PDATEFIN  - PDATEDEB - WNBJOUR29) / 365 , 0.05 )

ROK = G_OUI
End

##----------------------------------------------------------------------------##
## Nombre de 29/02 entre 2 dates                                              ##
##----------------------------------------------------------------------------##
Subprog CALCUL_NB_2902 (PDATEDEB, PDATEFIN, R_AN_BISSEXT, ROK )

Value Date  PDATEDEB
Value Date  PDATEFIN
Variable Decimal R_AN_BISSEXT
Variable Integer ROK

Local Decimal WDURAN

Local Decimal WBISSAN1

Local Decimal WAN1
Local Decimal WAN2

Local Decimal WDEBRESTE1
Local Decimal WFINDEPASS1
Local Decimal WDURRESTE3
Local Decimal WRESTE4
Local Decimal WMOIS


    WAN1      =  year(PDATEDEB)
    WAN2      =  year(PDATEFIN)

   # si date début dans année bissextile et avant 29/2 --> on prend en compte l'année de début
   # sinon : on ne la prend pas en compte
    WMOIS      = month (PDATEDEB)
    WDEBRESTE1 = mod(WAN1 , 4)
    If WDEBRESTE1  = 0 and WMOIS  < 3
    Else
         WAN1 += 1
    Endif

    WDEBRESTE1  =  mod(WAN1 , 4)
    If WDEBRESTE1  > 0
        WDEBRESTE1  = 4 - WDEBRESTE1
    Endif

   # si date fin dans année bissextile et après 29/2 --> on prend en compte l'année de fin
   # sinon : on ne la prend pas en compte
    WMOIS  = month (PDATEFIN)
    WFINDEPASS1=  mod(WAN2 , 4)
   If WFINDEPASS1 = 0 and WMOIS  > 2
   Else
         WAN2 -= 1
   Endif
   WFINDEPASS1=  mod(WAN2 , 4)

   # Durée en année = diff en année  début et fin
    WDURAN     = WAN2 - WAN1 + 1

   # On calcul le reste d'année , une fois la durée divisée par 4
   WBISSAN1    = WDURAN / 4
   R_AN_BISSEXT    = fix(WBISSAN1 )
   WDURRESTE3  = mod(WDURAN , 4)

   # Nombre de 29/02 = R_AN_BISSEXT
   If WDEBRESTE1  < WDURRESTE3
              R_AN_BISSEXT += 1
   Endif

End



