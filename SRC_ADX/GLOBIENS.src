Funprog GET_PLN_STD(PCPY,PPLAN)
# Rend le type de norme du plan de la société passés en paramètre
# (ML392 : 1 STD, 2 CRC, 3 IAS)
Value Char    PCPY
Value Integer PPLAN
Local Integer RNORME
Local Integer LCNX
Local Integer I_PLN

 If !clalev([F:CNXW]) : Local File CONTEXT [CNXW] : Endif
 Call GET_CNX_FROM_PLAN (PCPY, PPLAN, LCNX)
 Read [CNXW]CNX0=PCPY;LCNX
 If !fstat
  I_PLN=find(PPLAN,[F:CNXW]PLNCAA)
  If I_PLN<>0
   RNORME=[F:CNXW]PLNSTD(I_PLN-1)
  Endif
 Else
  RNORME=-1
  End RNORME
 Endif
End RNORME
#***Fq 64120
#####################################################################
Subprog IS_PLAN_DEPREC_OU_REEVAL (PCPY, PAASREF,PPLN, PDEM, RETOUR)
#-------------------------------------------------------
# Permet de savoir si un plan a subi une dépreciation ou
# une réévaluation dans la période courante
#---------------------------------------------------------
Value    Char      PCPY          # Société
Value    Char      PAASREF       # Référence bien comptable
Value    Integer   PPLN          # Plan comptable
Value    Integer   PDEM          # Paramètre demande : 1 = deprec, 2= rééval

Variable Integer RETOUR        # Est-ce que le plan a été déprécié ou réévalué : G_OUI ou G_NON

Local Date    LCNXDAT(1..5)
Local Integer PRET, RCNX


  Call GET_CNX_FROM_PLAN (PCPY, PPLN, RCNX) From GLOBIENS
  Call GET_CNX_DAT(PCPY,RCNX,LCNXDAT,PRET) From GLOBIENS

  If !clalev([F:DEPW]) : Local File DEPREC   [DEPW] : Endif
  Read [DEPW]DEP0=PAASREF;PPLN; LCNXDAT(2); LCNXDAT(4)
  If (!fstat) Then
  If ( PDEM=1 ) Then
    #-----------------------
    # Test la dépréciation #
    #-----------------------
    If ( [F:DEPW]IML <> 0 or [F:DEPW]IMLRVE <> 0) Then
      RETOUR=G_OUI
    Else
      RETOUR=G_NON
    Endif
  Else
    If ( PDEM=2 ) Then
      #-----------------------
      # Test la réévaluation  #
      #-----------------------
      If ( [F:DEPW]RVAAMT <> 0 ) Then
        RETOUR=G_OUI
      Else
        RETOUR=G_NON
      Endif
    Endif
  Endif
Endif

End

# FQ103705
#**
#*
#*
#* @param PCPY        Société
#* @param PAASREF     Référence bien comptable
#* @param RESULT      Est-ce que le bien a été déprécié (indice 0 pour au moins sur un plan)
#* @param RDEPEXECLO  Dépréciation effectuée dans un exercice clos
#* @param RDEPPERCLO  Dépréciation effectuée dans une période close
#*!
Subprog IS_BCO_DEPRECIE(PCPY, PAASREF, RESULT)
#------------------------------
# Permet de savoir si un bien
# a subi une dépreciation
#------------------------------
Value    Char    PCPY
Value    Char    PAASREF
Variable Integer RESULT()
#Variable Integer RDEPEXECLO, RDEPPERCLO # FQ103705

  Local Integer I_PLN

#  RDEPEXECLO = G_NON
#  RDEPPERCLO = G_NON

  If !clalev([F:DEPW]) : Local File DEPREC   [DEPW] : Endif
  If !clalev([F:CNXW]) : Local File CONTEXT  [CNXW] : Endif
  If !clalev([F:FISW]) : Local File FISCYEAR [FISW] : Endif

  For I_PLN = 0 To G301MAX-1
    RESULT(I_PLN)=G_NON
  Next I_PLN

  # >>>>>>>>>>>
  For [CNXW] Where CPY=PCPY
    Read [FISW] FIY1=PCPY;[F:CNXW]CNX;GVML_TECOURA
    If ( !fstat ) Then
      # >>>>>>>>>>>
      For I_PLN = 1 To [F:CNXW]NBPLC
        If ( [F:CNXW]PLNSTD(I_PLN-1) <> GVML_NPSTD ) Then
          Read [DEPW]DEP0=PAASREF;[F:CNXW]PLNCAA(I_PLN-1);[F:FISW]DATENDFIY;[F:FISW]DATENDPER(INDCURPER-1)
          If ( !fstat and [F:DEPW]IML <> 0 ) Then
            RESULT([F:CNXW]PLNCAA(I_PLN-1)) = G_OUI
            RESULT(0) = G_OUI
          Endif
#          # FQ103705
#          If [F:DEPW]PERIMLCUM
#            RDEPPERCLO = G_OUI
#          Endif
#          If [F:DEPW]EXEIMLCUM
#            RDEPEXECLO = G_OUI
#          Endif
        Endif
      Next I_PLN
      # >>>>>>>>>>>
    Endif
  Next
  # >>>>>>>>>>>

End

#####################################################################
Subprog IS_BCO_REEVALUE(PCPY,PAASREF,RESULT)
#------------------------------
# Permet de savoir si un bien
# a subi une réévaluation
#------------------------------
Value    Char    PCPY                  # Société
Value    Char    PAASREF               # Référence bien comptable
Variable Integer RESULT()              # Est-ce que le bien a été réévalué

  Local Integer I_PLN

  For I_PLN = 0 To G301MAX-1
    RESULT(I_PLN)=G_NON
  Next I_PLN

  # >>>>>>>>>>>
  For [CNXW] Where CPY=PCPY
    Read [FISW] FIY1=PCPY;[F:CNXW]CNX;GVML_TECOURA
    If ( !fstat ) Then
      For I_PLN = 1 To [F:CNX]NBPLC
        If ( [F:CNXW]PLNSTD(I_PLN-1) <> GVML_NPSTD ) Then
          Read [DEPW]DEP0=PAASREF;[F:CNXW]PLNCAA(I_PLN-1);[F:FISW]DATENDFIY;[F:FISW]DATENDPER(INDCURPER-1)
          If ( !fstat and [F:DEPW]RVADAT <> [0/0/0] ) Then
            RESULT([F:CNXW]PLNCAA(I_PLN-1)) = G_OUI
            RESULT(0) = G_OUI
          Endif
        Endif
      Next I_PLN
    Endif
  Next
  # >>>>>>>>>>>

End


################################################################################
##
##   S/P - DATES PERIODES ET EXERICES
##
################################################################################

#---------------------------------------------------------------------
# S/P de récupération des dates d'un contexte dans la variable dimensionnée
# PCNXDAT :
#
#  1 Date de début d'exercice
#  2 Date de fin d'exercice
#  3 Date de début de période courante
#  4 Date de fin de période courante
#  5 Date de dernière cloture (Dernier jour de l'exercice ou
#                             de la période précédente)
#
#####################################################################
Subprog GET_CNX_DAT( PCPY, PCNX, PCNXDAT, PRET )
Value    Char    PCPY
Value    Integer PCNX
Variable Date    PCNXDAT(1..5)
Variable Integer PRET

  If !(clalev([F:FIS])) : Local File FISCYEAR [FIS] : Endif
  Filter [FIS] Where CPY=PCPY & CNX=PCNX & STAFIY=GVML_TECOURA
  Read [FIS]FIY0 Last : Filter [FIS]
  If ( fstat ) Then : PRET=-1 :  End :  Endif

  PCNXDAT(1) = [F:FIS]DATSTRFIY
  PCNXDAT(2) = [F:FIS]DATENDFIY
  PCNXDAT(3) = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
  PCNXDAT(4) = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
  If ( [F:FIS]INDCURPER = 1 ) Then
    PCNXDAT(5)=PCNXDAT(1)-1
  Else
    PCNXDAT(5)=PCNXDAT(3)-1
  Endif
End

#---------------------------------------------------------------------
# S/P de récupération des dates d'un contexte dans la variable dimensionnée
# PCNXDAT :
#
#  1 Date de début d'exercice
#  2 Date de fin d'exercice
#  3 Date de début de période courante
#  4 Date de fin de période courante
#  5 Date de dernière cloture (Dernier jour de l'exercice ou
#                             de la période précédente)
#
#####################################################################
Subprog GET_CNX_DAT2(PCPY, PCNX, PEXE, PCNXDAT, PRET)
Value    Char    PCPY
Value    Integer PCNX
Value    Integer PEXE
Variable Date    PCNXDAT(1..5)
Variable Integer PRET

  If !(clalev([F:FIS])) : Local File FISCYEAR [FIS] : Endif
  Filter [FIS] Where CPY=PCPY & CNX=PCNX & STAFIY=PEXE
  Read [FIS]FIY0 Last : Filter [FIS]
  If ( fstat ) Then :  PRET=-1 :  End  :  Endif

  PCNXDAT(1)=[F:FIS]DATSTRFIY
  PCNXDAT(2)=[F:FIS]DATENDFIY
  PCNXDAT(3)=[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
  PCNXDAT(4)=[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
  If ( [F:FIS]INDCURPER = 1 ) Then
    PCNXDAT(5)=PCNXDAT(1)-1
  Else
    PCNXDAT(5)=PCNXDAT(3)-1
  Endif

End
#---------------------------------------------------------------------
# S/P de récupération des dates de l'exercice suivant d'un contexte
# dans la variable dimensionnée PCNXDAT :
#  1 Date de début d'exercice suivant
#  2 Date de fin d'exercice suivant
#  3 Date de début de période courante de l'exercice suivant
#  4 Date de fin de période courante de l'exercice suivant
#  5 Date de dernière cloture (Dernier jour de l'exercice ou
#                             de la période précédente de l'exercice suivant)
#####################################################################
Subprog GET_CNX_DAT_CS(PCPY, PCNX, PCNXDATC, PCNXDATS, PRET)
Value    Char    PCPY
Value    Integer PCNX
Variable Date    PCNXDATC(1..5)
Variable Date    PCNXDATS(1..5)
Variable Integer PRET

  If !(clalev([F:FIS])) : Local File FISCYEAR [FIS] : Endif

  # dates exercice courant
  Filter [FIS] Where CPY=PCPY & CNX=PCNX & STAFIY=GVML_TECOURA
  Read [FIS]FIY0 Last : Filter [FIS]
  If ( fstat ) Then : PRET=-1 :  End :  Endif
  PCNXDATC(1)=[F:FIS]DATSTRFIY
  PCNXDATC(2)=[F:FIS]DATENDFIY
  PCNXDATC(3)=[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
  PCNXDATC(4)=[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
  If ( [F:FIS]INDCURPER = 1 ) Then
    PCNXDATC(5)=PCNXDATC(1)-1
  Else
    PCNXDATC(5)=PCNXDATC(3)-1
  Endif

  # dates exercice suivant
  Filter [FIS] Where CPY=PCPY & CNX=PCNX & STAFIY=GVML_TESUIV
  Read [FIS]FIY0 Last : Filter [FIS]
  If ( fstat ) Then : PRET=-1 : End : Endif
  PCNXDATS(1)=[F:FIS]DATSTRFIY
  PCNXDATS(2)=[F:FIS]DATENDFIY
  PCNXDATS(3)=[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
  PCNXDATS(4)=[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
  If ( [F:FIS]INDCURPER = 1 ) Then
    PCNXDATS(5)=PCNXDATS(1)-1
  Else
    PCNXDATS(5)=PCNXDATS(3)-1
  Endif

End
#--------------------------------------------------------------#
# S/P de récupération des dates des contextes gérés pour une   #
# société passée en paramétre                                  #
#####################################################################
Subprog GET_CPY_DAT(PCPY,RSTRFIYCOU,RENDFIYCOU,RSTRPERCOU,RENDPERCOU,PRET)
Value    Char    PCPY                # Société passée en paramètre
Variable Date    RSTRFIYCOU(1..)     # Début d'exercice courant
Variable Date    RENDFIYCOU(1..)     # Fin d'exercice courant
Variable Date    RSTRPERCOU(1..)     # Début de période courante
Variable Date    RENDPERCOU(1..)     # Fin de période courante
Variable Integer PRET

  Local Integer I_CNX

  If !clalev([F:CNX]) : Local File CONTEXT  [CNX] : Endif
  If !clalev([F:FIS]) : Local File FISCYEAR [FIS] : Endif

  Filter [CNX] Where CPY=PCPY
  For [CNX]
    Filter [FIS] Where (CPY=PCPY & CNX=[F:CNX]CNX & STAFIY=GVML_TECOURA)
    Read [FIS] First
    If (!fstat) Then
      RSTRFIYCOU([F:CNX]CNX)=[F:FIS]DATSTRFIY
      RENDFIYCOU([F:CNX]CNX)=[F:FIS]DATENDFIY
      RSTRPERCOU([F:CNX]CNX)=[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
      RENDPERCOU([F:CNX]CNX)=[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
    Endif
  Next
  Filter [FIS]
  Filter [CNX]

End
#--------------------------------------------------------------#
# S/P de récupération des dates des contextes gérés pour une   #
# société passée en paramétre                                  #
#####################################################################
Subprog GET_CPY_DAT_CS(PCPY,RSTRFIYCOU,RENDFIYCOU,RSTRPERCOU,RENDPERCOU,
&                                      RSTRFIYSUI,RENDFIYSUI,RSTRPERSUI,RENDPERSUI,PRET)
Value    Char    PCPY                # Société passée en paramètre
Variable Date    RSTRFIYCOU(1..)     # Début d'exercice courant
Variable Date    RENDFIYCOU(1..)     # Fin d'exercice courant
Variable Date    RSTRPERCOU(1..)     # Début de période courante
Variable Date    RENDPERCOU(1..)     # Fin de période courante
Variable Date    RSTRFIYSUI(1..)     # Début d'exercice suivant
Variable Date    RENDFIYSUI(1..)     # Fin d'exercice suivant
Variable Date    RSTRPERSUI(1..)     # Début de période suivante
Variable Date    RENDPERSUI(1..)     # Fin de période SUIVANTE
Variable Integer PRET

  Local Integer I_CNX

  If !clalev([F:CNX]) : Local File CONTEXT  [CNX] : Endif
  If !clalev([F:FIS]) : Local File FISCYEAR [FIS] : Endif

  Filter [CNX] Where CPY=PCPY
  For [CNX]
    Filter [FIS] Where (CPY=PCPY & CNX=[F:CNX]CNX & STAFIY=GVML_TECOURA)
    Read [FIS] First
    If (!fstat) Then
      RSTRFIYCOU([F:CNX]CNX)=[F:FIS]DATSTRFIY
      RENDFIYCOU([F:CNX]CNX)=[F:FIS]DATENDFIY
      RSTRPERCOU([F:CNX]CNX)=[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
      RENDPERCOU([F:CNX]CNX)=[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
    Endif

    Filter [FIS] Where (CPY=PCPY & CNX=[F:CNX]CNX & STAFIY=GVML_TESUIV)
    Read [FIS] First
    If (!fstat) Then
      RSTRFIYSUI([F:CNX]CNX)=[F:FIS]DATSTRFIY
      RENDFIYSUI([F:CNX]CNX)=[F:FIS]DATENDFIY
      RSTRPERSUI([F:CNX]CNX)=[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
      RENDPERSUI([F:CNX]CNX)=[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
    Endif
  Next
  Filter [FIS]
  Filter [CNX]

End

#--------------------------------------------------------------#
# S/P de récupération des dates de fin d'exercice et de fin de #
# période à partir d'une date passé en paramètre               #
#####################################################################
Subprog GET_FIY_PER(PDAT,PCPY,PCNX,RFIYENDDAT,RPERENDDAT,RCOD)
Value    Date    PDAT       # Date à évaluer
Value    Char    PCPY       # Société
Value    Integer PCNX       # Contexte de référence
Variable Date    RFIYENDDAT # Date de fin d'exercice auquel appartient PDAT
Variable Date    RPERENDDAT # Date de fin de période à laquelle appartient PDAT [0/0/0] si l'exercice n'est pas géré en périodique
Variable Integer RCOD       # Code retour du s/p

  If !clalev([F:FIS]) : Local File FISCYEAR [FIS] : Endif

  # Détermination de la date de fin d'exercice
  Filter [FIS] Where (CPY=PCPY & CNX=PCNX & PDAT >= DATSTRFIY & PDAT <= DATENDFIY)
  Read [FIS] Last
  If ( fstat ) Then : RCOD=1 : Filter [FIS] :  End : Endif
  RFIYENDDAT=[F:FIS]DATENDFIY

  Local Integer I_PER
  For I_PER = 1 To dim([F:FIS]DATSTRPER)
   If (PDAT>=[F:FIS]DATSTRPER(I_PER-1) & PDAT<=[F:FIS]DATENDPER(I_PER-1))
    RPERENDDAT=[F:FIS]DATENDPER(I_PER-1)
    Break
   Endif
  Next I_PER

  Filter [FIS]

End

#--------------------------------------------------------------#
# S/P Récupération du Type LVA du contexte fiscal & comptable  #
# Low value assets FQ67615                                     #
################################################################
Subprog GET_FIY_LVATYP( PCPY, PFIYSTR, PFIYEND, RLVATYP)
Value    Char    PCPY     # Société
Variable Date    PFIYSTR  # Date de début d'exercice du plan comptable
Variable Date    PFIYEND  # Date de fin d'exercice du plan comptable
Variable Integer RLVATYP  # Type de gestion LVA

  If !clalev([F:FIS]) : Local File FISCYEAR [FIS] : Endif

  Read [FIS]FIY0=PCPY;G300CPFI;PFIYSTR
  RLVATYP = [F:FIS]LVATYP
  If (RLVATYP = 0) Then : RLVATYP = GVML_GLVAAUC : Endif

End

#--------------------------------------------------------------#
# S/P Récupération du seuil LVA contexte fiscal & comptable    #
# Low value assets FQ67615                                     #
################################################################
Subprog GET_FIY_LVALIM( PCPY, PFIYSTR, PFIYEND, RLVALIM)
Value    Char    PCPY     # Société
Variable Date    PFIYSTR  # Date de début d'exercice du plan comptable
Variable Date    PFIYEND  # Date de fin d'exercice du plan comptable
Variable Decimal RLVALIM  # Seuil LVA

  If !clalev([F:FIS]) : Local File FISCYEAR [FIS] : Endif

  Read [FIS]FIY0=PCPY;G300CPFI;PFIYSTR
  RLVALIM = [F:FIS]LVALIM

End
#-----------------------------------------------------------------------#
# S/P de récupération des dates début/fin d'exercice et de début/fin de #
# période à partir d'une date passé en paramètre                        #
#####################################################################
Subprog GET_DATFIY_DATPER(PDAT,PCPY,PCNX,RFIYSTRDAT,RFIYENDDAT,RPERSTRDAT,RPERENDDAT,RCOD)
Value    Date    PDAT       # Date à évaluer
Value    Char    PCPY       # Société
Value    Integer PCNX       # Contexte de référence
Variable Date    RFIYSTRDAT # Date de début d'exercice auquel appartient PDAT
Variable Date    RFIYENDDAT # Date de fin d'exercice auquel appartient PDAT
Variable Date    RPERSTRDAT # Date de début de période à laquelle appartient PDAT
                            # [0/0/0] si l'exercice n'est pas géré en périodique
Variable Date    RPERENDDAT # Date de fin de période à laquelle appartient PDAT
                            # [0/0/0] si l'exercice n'est pas géré en périodique

Variable Integer RCOD       # Code retour du s/p

  If !clalev([F:FIS]) : Local File FISCYEAR [FIS] : Endif

  # Détermination des dates d'exercice
  Filter [FIS] Where (CPY=PCPY & CNX=PCNX & PDAT >= DATSTRFIY & PDAT <= DATENDFIY)
  Read [FIS] Last
  If (fstat) Then : RCOD=1 :  Filter [FIS] :  End : Endif
  RFIYSTRDAT=[F:FIS]DATSTRFIY
  RFIYENDDAT=[F:FIS]DATENDFIY

  # Détermination des dates de période
  Local Integer I_PER
  For I_PER = 1 To dim([F:FIS]DATSTRPER)
    If (PDAT>=[F:FIS]DATSTRPER(I_PER-1) & PDAT<=[F:FIS]DATENDPER(I_PER-1))
      RPERSTRDAT=[F:FIS]DATSTRPER(I_PER-1)
      RPERENDDAT=[F:FIS]DATENDPER(I_PER-1)
      Break
    Endif
  Next I_PER
  Filter [FIS]

End

