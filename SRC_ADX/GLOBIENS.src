################################################################################
###############################################################################
Funprog PRIVATE_GET_STRING_LOCK (PTABLE, PCPY, PKEY)
Value Char PTABLE
Value Char PCPY
Value Char PKEY

Local Char LLOCK(200)

  If PKEY = "" Then
    LLOCK = PTABLE+PCPY
  Else
    LLOCK = PTABLE+PKEY
  Endif
End LLOCK

###############################################################################
Funprog PRIVATE_GET_STRING_LOCK_CPY (PTABLE, PCPY, PKEY)
Value Char PTABLE
Value Char PCPY
Value Char PKEY

Local Char LLOCK(200)

  LLOCK = PTABLE+'¤'+PCPY+'¤'+PKEY
End LLOCK

###############################################################################
Funprog PRIVATE_LOCK_SYMBOLE (PTABLE, PCPY, PKEY, PWAIT)
# Verrouille les enregistrement d'une table
# ======================================================
# FONCTION PRIVEE A NE PAS UTILISER PAR LES PROGRAMMEURS
# ======================================================
# PTABLE : Abréviation (standard) de la table à locker (OBLIGATOIRE)
# PCPY   : Société (OBLIGATOIRE)
# PKEY   : Identifiant de l'enregistrement à locker (FACULTATIF)
#          Si vide, c'est tous les enregistrements de la société qui sont lockés
# PWAIT  : Nombre de secondes d'essai
#
# Rend :
# LERROR : 0 = Enregistrement déjà locké
#          1 = Enregistrement locké
# ------------------------------------------------------------------------------
Value Char PTABLE
Value Char PCPY
Value Char PKEY
Value Integer PWAIT

Local Char LLOCK(200)
Local Integer LERROR

  LERROR = 0
  LLOCK = func GLOBIENS.PRIVATE_GET_STRING_LOCK (PTABLE, PCPY, PKEY)
  Lock =LLOCK With lockwait = PWAIT
  If [S]fstat Then
    LERROR = 0
  Else
    LERROR = 1
  Endif
End LERROR

###############################################################################
Funprog QUI_LOCKE ()
# Rend un chaîne indiquant qui empêche de locker l'enregistrement
# Doit être appelé DIRECTEMENT après une tentative de lockage infructueuse
# ou après avoir demandé si un enregistrement est locké... et qu'il l'est !
# ------------------------------------------------------------------------------
Local Char LLOCK(200)
Local Char LMACLCK(30), LUSRLCK(30)

  Call QUILOCKE([F:ALK]LCKSYM, LMACLCK, LUSRLCK) From OBJDIV
  If LUSRLCK <> "" Then
    LLOCK = mess(92,7770,1)-LUSRLCK+'\'+LMACLCK : # Verrouillé par
  Else
    LLOCK = mess(93,7770,1)                     : # Verrouillé par un autre utilisateur
  Endif
End LLOCK

###############################################################################
Funprog IS_SYMBOLE_LOCKED (PTABLE, PCPY, PKEY)
# Indique si le symbole est locké ou pas
# PTABLE : Abréviation (standard) de la table à locker (OBLIGATOIRE)
# PCPY   : Société (OBLIGATOIRE)
# PKEY   : Identifiant de l'enregistrement à locker (FACULTATIF)
#          Si vide, c'est tous les enregistrements de la société qui sont lockés
#
# COMMENTAIRE : Ca peut paraître pas optimisé de regarder de cette façon avant de
#               locker, mais ça permet de tester si la table n'est pas lockée pour
#               la société aussi
# Rend :
# LERROR : 0 = Enregistrement déjà locké
#          1 = Enregistrement libre
#         -1 = Paramètres incomplets
# ------------------------------------------------------------------------------
Value Char PTABLE
Value Char PCPY
Value Char PKEY

Local Integer LERROR
Local Char LLOCK(200)

  G_MSGQUILOCK = ""
  If clalev([F:ALK])=0     : Local File APLLCK    [ALK]  : Endif
  LERROR = 1
  If PTABLE = "" or PCPY = "" Then
    # Paramètres incomplets
    LERROR = -1
  Else
    # S'il est verrouillable c'est qu'il est libre : il faut donc tenter de le verrouiller
    # pour savoir s'il est libre
    # a°) on regarde d'abord si la table pour la société est libre ou pas
    LLOCK = func GLOBIENS.PRIVATE_GET_STRING_LOCK (PTABLE, PCPY, "")
    # On teste adxuid(2), parce s'il est verrouilé par nous, on le considère comme libre
    Filter [ALK] Where LCKSYM=LLOCK and LCKPID=adxuid(2)
    Read [ALK]LCKCLE Last
    Filter [ALK]
    If fstat>2 Then
      If func GLOBIENS.PRIVATE_LOCK_SYMBOLE (PTABLE, PCPY, "", 0) = 0 Then
        # Elle n'est pas libre, on ne peut pas verrouiller
        LERROR        = 0
        For [ALK] Where LCKSYM=LLOCK and LCKPID<>adxuid(2)
          Lock =[F:ALK]LCKSYM
          If fstat Then
            LERROR        = 0
            G_MSGQUILOCK = func GLOBIENS.QUI_LOCKE ()
            If GTRACE <> "" Then
              # Enregistrer celui qui locke dans la trace
              # (c'est le dernier qui locke qui sera stocké dans G_MSGQUILOCK
              Call ECR_TRACE(G_MSGQUILOCK,1) From GESECRAN
            Else
              # Si il n'y a pas de trace on arrête sur le premier qui bloque.
              Break
            Endif
          Else
            Unlock =[F:ALK]LCKSYM
          Endif
        Next
      Else
        # Elle est libre
        # b°) on la déverouille avant de continuer... si c'est pas nous qui le bloquons !
        Call UNLOCK_SYMBOLE (PTABLE, PCPY, "")
        If PKEY = "" Then
          # c°) si on teste pour un lockage société, on regarde si aucun enregistrement de la
          #     société n'est locké
          LLOCK = func GLOBIENS.PRIVATE_GET_STRING_LOCK_CPY (PTABLE, PCPY, "")
          For [ALK] Where pat(LCKSYM, LLOCK+'*')=1 and LCKPID<>adxuid(2)
            Lock =[F:ALK]LCKSYM
            If fstat Then
              LERROR        = 0
              G_MSGQUILOCK = func GLOBIENS.QUI_LOCKE ()
              If GTRACE <> "" Then
                # Enregistrer celui qui locke dans la trace
                # (c'est le dernier qui locke qui sera stocké dans G_MSGQUILOCK
                Call ECR_TRACE(G_MSGQUILOCK,1) From GESECRAN
              Else
                # Si il n'y a pas de trace on arrête sur le premier qui bloque.
                Break
              Endif
            Else
              Unlock =[F:ALK]LCKSYM
            Endif
          Next
        Else
          # d°) si on teste pour un lockage symbole, on regarde si le symbole est libre
          LLOCK = func GLOBIENS.PRIVATE_GET_STRING_LOCK (PTABLE, PCPY, PKEY)
          # On teste adxuid(2), parce s'il est verrouilé par nous, on le considère comme libre
          Filter [ALK] Where LCKSYM=LLOCK and LCKPID=adxuid(2)
          Read [ALK]LCKCLE Last
          Filter [ALK]
          If fstat>2 Then
            If func GLOBIENS.PRIVATE_LOCK_SYMBOLE (PTABLE, PCPY, PKEY, 0) = 0 Then
              # Il n'est pas libre, on ne peut pas verrouiller
              LERROR = 0
              G_MSGQUILOCK = func GLOBIENS.QUI_LOCKE ()
            Else
              # Il est libre aussi, c'est bon !
              # d°) on le déverouille avant de continuer
              Call UNLOCK_SYMBOLE (PTABLE, PCPY, PKEY)
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
End LERROR

###############################################################################
Funprog IS_SYMBOLE_ALREADY_LOCKED (PTABLE, PCPY, PKEY)
# Indique si le symbole est locké ou pas
# PTABLE : Abréviation (standard) de la table à locker (OBLIGATOIRE)
# PCPY   : Société (OBLIGATOIRE)
# PKEY   : Identifiant de l'enregistrement à locker (FACULTATIF)
#          Si vide, c'est tous les enregistrements de la société qui sont lockés
#
# COMMENTAIRE : Ca peut paraître pas optimisé de regarder de cette façon avant de
#               locker, mais ça permet de tester si la table n'est pas lockée pour
#               la société aussi
# Rend :
# LERROR : 1 = Non locké ou locké par quelqu'un d'autre
#          2 = Déjà locké par nous
#         -1 = Paramètres incomplets
# ------------------------------------------------------------------------------
Value Char PTABLE
Value Char PCPY
Value Char PKEY

Local Integer LERROR
Local Char LLOCK(200)

 If clalev([F:ALK])=0     : Local File APLLCK    [ALK]  : Endif
 LERROR = G_NON

 LLOCK = func GLOBIENS.PRIVATE_GET_STRING_LOCK (PTABLE, PCPY, PKEY)
 Filter [ALK] Where LCKSYM=LLOCK and LCKPID=adxuid(2)
 Read [ALK]LCKCLE Last
 If !fstat
  # Symbole trouvé dans : il est donc déjà locké par nous
  LERROR = G_OUI
 Endif
 Filter [ALK]

End LERROR

###############################################################################
Funprog LOCK_SYMBOLE (PTABLE, PCPY, PKEY, PWAIT)
# Verrouille les enregistrement d'une table
# PTABLE : Abréviation (standard) de la table à locker (OBLIGATOIRE)
# PCPY   : Société (OBLIGATOIRE)
# PKEY   : Identifiant de l'enregistrement à locker (FACULTATIF)
#          Si vide, c'est tous les enregistrements de la société qui sont lockés
# PWAIT  : Nombre de secondes d'essai
#
# Rend :
# LERROR : 0 = Enregistrement déjà locké
#          1 = Enregistrement locké
#         -1 = Paramètres invalides
# ------------------------------------------------------------------------------
Value Char PTABLE
Value Char PCPY
Value Char PKEY
Value Integer PWAIT

Local Char LLOCK(200)
Local Integer LERROR

  LERROR = 0
  If PTABLE = "" or PCPY = "" or PWAIT < 0 Then
    # Paramètres invalides
    LERROR = -1
  Else
    If func GLOBIENS.IS_SYMBOLE_LOCKED (PTABLE, PCPY, PKEY) = 0 Then
      # L'enregistrement ou la société est déjà lockée
      LERROR = 0
    Else
      If func GLOBIENS.PRIVATE_LOCK_SYMBOLE (PTABLE, PCPY, PKEY, PWAIT) = 0 Then
        # Il n'est pas libre, on ne peut pas verrouiller
        LERROR = 0
        G_MSGQUILOCK = mess(93,7770,1)                     : # Verrouillé par un autre utilisateur
      Else
        # Voilà, c'est nous qu'on l'a !
        LERROR = 1
        If PKEY <> "" Then
          # Dans ce cas on n'est pas dans la situation où le symbole de base n'a pas été locké
          # par l'objet : donc on locke aussi le symbole sur sa société
          If func GLOBIENS.LOCK_SYMBOLE_CPY (PTABLE, PCPY, PKEY, PWAIT) = 0 Then
            # Rien à tester, on est déjà propriétaire de l'objet
          Endif
        Endif
      Endif
    Endif
  Endif
End LERROR

###############################################################################
Funprog LOCK_SYMBOLE_CPY (PTABLE, PCPY, PKEY, PWAIT)
# Verrouille un enregistrement d'une table en tenant compte aussi de la société
# PTABLE : Abréviation (standard) de la table à locker (OBLIGATOIRE)
# PCPY   : Société (OBLIGATOIRE)
# PKEY   : Identifiant de l'enregistrement à locker (OBLIGATOIRE)
#          Si vide, c'est tous les enregistrements de la société qui sont lockés
# PWAIT  : Nombre de secondes d'essai
#
# Rend :
# LERROR : 0 = Enregistrement déjà locké
#          1 = Enregistrement locké
#         -1 = Paramètres invalides
# ------------------------------------------------------------------------------
Value Char PTABLE
Value Char PCPY
Value Char PKEY
Value Integer PWAIT

Local Char LLOCK(200)
Local Integer LERROR

  LERROR = 0
  If PTABLE = "" or PCPY = "" or PKEY = "" or PWAIT < 0 Then
    # Paramètres invalides
    LERROR = -1
  Else
    LLOCK  = func GLOBIENS.PRIVATE_GET_STRING_LOCK_CPY (PTABLE, PCPY, PKEY)
    If func GLOBIENS.IS_SYMBOLE_LOCKED (PTABLE, PCPY, LLOCK) = 0 Then
      # L'enregistrement ou la société est déjà lockée
      LERROR = 0
    Else
      Lock =LLOCK With lockwait = PWAIT
      If [S]fstat Then
        # Il n'est pas libre, on ne peut pas verrouiller
        LERROR        = 0
        G_MSGQUILOCK = mess(93,7770,1)     : # Verrouillé par un autre utilisateur
        If GTRACE <> "" Then
          # Enregistrer celui qui locke dans la trace
          Call ECR_TRACE(G_MSGQUILOCK,1) From GESECRAN
        Endif
      Else
        # Voilà, c'est nous qu'on l'a !
        LERROR = 1
      Endif
    Endif
  Endif
End LERROR

###############################################################################
Subprog UNLOCK_SYMBOLE (PTABLE, PCPY, PKEY)
# déverrouille les enregistrement d'une table
# PTABLE : Abréviation (standard) de la table à délocker (FACULTATIF)
# PCPY   : Société (FACULTATIF)
# PKEY   : Identifiant de l'enregistrement à délocker (FACULTATIF)
#          Si PCPY et PKEY vides, ce sont tous les enregistrements lockés
#          par l'utilisateur (adxuid(2)) sur PTABLE qui sont délockés
#
# ------------------------------------------------------------------------------
Value Char PTABLE
Value Char PCPY
Value Char PKEY

Local Char LLOCK(200)
Local Integer LERROR

  LERROR = 0
  If PCPY = "" and PKEY = "" Then
    If !clalev([F:ALK]) : Local File APLLCK [ALK] : Endif
    If PTABLE = "" Then
      LLOCK = "1=1"
    Else
      LLOCK = "LEFT$(LCKSYM,3)='"+PTABLE+"'"
    Endif
    Filter [ALK] Where (LCKPID=adxuid(2)) &evalue(LLOCK)
    For [ALK]
      SYMBOLE = [F:ALK]LCKSYM
      Unlock =SYMBOLE
    Next
    If [S]fstat Then
      LERROR = 0
    Else
      LERROR = 1
    Endif
    Filter [ALK]
  Elsif PTABLE <> "" Then
    LLOCK = func GLOBIENS.PRIVATE_GET_STRING_LOCK (PTABLE, PCPY, PKEY)
    Unlock =LLOCK
    If [S]fstat Then
      LERROR = 0
    Else
      LERROR = 1
      If PKEY <> "" Then
        # Dans ce cas on n'est pas dans la situation où le symbole de base n'a pas été locké
        # par l'objet : donc on délocke aussi le symbole sur sa société
        Call UNLOCK_SYMBOLE_CPY (PTABLE, PCPY, PKEY)
      Endif
    Endif
  Else
    LERROR = -1
  Endif
End

###############################################################################
Subprog UNLOCK_SYMBOLE_CPY (PTABLE, PCPY, PKEY)
# déverrouille les enregistrement d'une table
# PTABLE : Abréviation (standard) de la table à délocker (OBLIGATOIRE)
# PCPY   : Société (FACULTATIF)
# PKEY   : Identifiant de l'enregistrement à délocker (OBLIGATOIRE)
#
# ------------------------------------------------------------------------------
Value Char PTABLE
Value Char PCPY
Value Char PKEY

Local Char LLOCK(200)
Local Integer LERROR

  LERROR = 0
  If PTABLE = "" or PCPY = "" or PKEY = "" Then
    # Paramètres invalides
    LERROR = -1
  Else
    LLOCK  = func GLOBIENS.PRIVATE_GET_STRING_LOCK_CPY (PTABLE, PCPY, PKEY)
    Unlock =LLOCK
    If [S]fstat Then
      LERROR = 0
    Else
      LERROR = 1
    Endif
  Endif
End

