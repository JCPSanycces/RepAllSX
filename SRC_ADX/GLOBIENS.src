Subprog TEST_BIEN_ACTIF  (PAASREF, RACTIF)
# Indique si le bien est actif. Le bien n'est pas actif s'il participe a une cession intra-groupe
Value Char PAASREF
Variable Integer RACTIF

RACTIF = G_OUI

If G_ACTCIG <> G_OUI : End : Endif   #Fq-80503

Local Char FICHIER(250)
FICHIER=filpath("FIL","CIGFXDSOR","fde",-1)
If filinfo(FICHIER,0) < 0
 End
Endif

If clalev([F:CIB]) =0    : Local File CIGFXDSOR     [CIB]    : Endif : # Biens sortis CIG

Read [CIB]CIB4=PAASREF
If fstat = 0
     RACTIF = G_NON
Endif
End

################################################################################ FQ32031
# Sous-programme de contrôle des restrictions Société/Site
#
Subprog VERIF_FCY(PTYPE, P_FCY, PCPY, PFCY, PVALEUR)
Value Char PTYPE    : # Objet : DSP ou CCE
Value Char P_FCY    : # restriction
Value Char PCPY     : # Société de l'objet
Value Char PFCY     : # Site de l'objet
Value Char PVALEUR  : # valeur de la zone pour les messages

 Local Integer IS_SITE, IS_SOC, N_MESS
 If find(P_FCY,GSITE(1..GNBSITE)) : IS_SITE=1 : Endif
 If find(P_FCY,GSOC(1..GNBSOC))   : IS_SOC=1  : Endif

 Case PTYPE
   When "DSP" : N_MESS = 529 : # Répartition
   When "CCE" : N_MESS = 345 : # Section
 Endcase

 #-> Restriction à une société

 If IS_SOC
  Call LECTURE("CPY",P_FCY,"") From CONTOBJ
  If [F:CPY]CPYLEGFLG=G_OUI
   #Société juridique
   If P_FCY<>PCPY
    GERR=1
    GMESSAGE=PVALEUR-mess(N_MESS,7773,1)-mess(82,106,1)-P_FCY  # "Section/Répartition réservée à la société"
    mkstat=2
   Endif
  Else
   # Issue 112662 - 2015-11-20 by MDJ
   If !clalev([F:WFGR]) : Local File FACGROUP [WFGR] : Endif
   #Société non juridique : regroupement de sites
   Local Integer FCY_OK : FCY_OK = G_NON
   Filter [WFGR] Where CPY=P_FCY
   For [WFGR]
    If [F:WFGR]FCY=PFCY
     FCY_OK = G_OUI
     Break
    Endif
   Next
   If FCY_OK = G_NON
    GERR=1
    GMESSAGE=PVALEUR-mess(N_MESS,7773,1)-mess(83,106,1)-P_FCY  # "Section/Répartition reservée au groupe de sites"
    mkstat=2
   Endif
   Filter [WFGR]
  Endif
 Endif

 #-> Restriction à un site

 If IS_SITE & (P_FCY<> PFCY)
  GERR=1
  GMESSAGE=PVALEUR-mess(N_MESS,7773,1)-mess(81,106,1)-P_FCY  # "Section/Répartition reservée au site"
  mkstat=2
 Endif
End

###############################################################################
# FQ67255
# Permet de savoir si, dans son exercice d'acquisition, un bien donné a déjà
# subi au moins une comptabilisation sur l'exercice courant ou sur le suivant.
# Cette fonction est utilisée dans SUBFAS pour savoir si on peut ou non modifier
# la date de mise en service et/ou la date de comptabilisation du bien considéré.
##########################################################################
Funprog IS_FAS_COMPTABILISE(PCPY, PAASREF)
Value Char    PCPY
Value Char    PAASREF

Local Integer RRET    : RRET    = 0
Local Decimal WTOTPST : WTOTPST = 0

Local Date    LCNXDATC(1..5)
Local Date    LCNXDATS(1..5)
Local Integer LRET


  If !clalev([F:CNXW]) : Local File CONTEXT [CNXW] : Endif
  If !clalev([F:DEPW])  : Local File DEPREC [DEPW] : Endif

  # Dès que l'on trouve du comptabilisé on sort.
  # >>>>>>
  For [CNXW]CNX0 Where CPY = PCPY

    # Date exerccice courant et exercice suivant
    Call GET_CNX_DAT_CS( PCPY, [F:CNXW]CNX, LCNXDATC, LCNXDATS, LRET) From GLOBIENS

    # Hors exercice d'acquisition, on sort
    Filter[DEPW] Where AASREF= PAASREF and CNX= [F:CNXW]CNX #Fq69900-Suppression de la société
    Read[DEPW] First
    If ( fstat ) Then
      RRET = 0
      Break
    Endif
    If ([F:DEPW]FIYSTRDAT < LCNXDATC(1)) Then
      RRET = 1
      Break
    Endif
    Filter[DEPW]
    # Dès que du comptabilisé est détecté on sort.
    # On ne va pas au delà de l'exercice suivant.
    Columns [DEPW] (PSTDER, PSTDERRVE, PSTDPE, PSTEXC)
    Filter [F:DEPW] Where AASREF = PAASREF  and CNX = [F:CNXW]CNX and FIYENDDAT <= LCNXDATS(2) #Fq69900-Suppression de la société
    For [F:DEPW]
       WTOTPST =  [F:DEPW]PSTDER + [F:DEPW]PSTDERRVE + [F:DEPW]PSTDPE + [F:DEPW]PSTEXC
       If ( WTOTPST > 0 ) Then
          RRET = 1
          Break 2
       Endif
    Next
  Next
  # <<<<<<
  Columns [DEPW] #Fq68271
  Filter [DEPW]
End RRET

###############################################################################
# Permet de savoir si il y a déjà eu du comptabilisé pour une période donnée
# d'un contexte donné
# Cette fonction est utilisée dans SUBCNX pour savoir si on peut ou non passer
# le type de comptabilisation de "Définitif" à "Provisoire"
##########################################################################
Funprog IS_DEJA_COMPTABILISE(PCPY,PCNX, PDATSTR, PDATEND)
Value Char    PCPY
Value Integer PCNX
Value Date    PDATSTR
Value Date    PDATEND

Local Integer RRET    : RRET    = G_NON
Local Decimal WTOTPST : WTOTPST = 0

If !clalev([F:DEP]) : Local File DEPREC [DEP] : Endif
#Fq-81074Columns [DEP] (PSTDER, PSTDERRVE , PSTDPE, PSTEXC)
#Fq-81074 For [F:DEP] Where CPY=PCPY & CNX = PCNX & PERSTRDAT = PDATSTR & PERENDDAT = PDATEND
   #FQ-93596 Filter [DEP] Where CPY=PCPY & CNX = PCNX & PERSTRDAT = PDATSTR & PERENDDAT = PDATEND & FLGPST=G_OUI
   #FQ-93596    Look[DEP]DEPA First
   #Fq-81074 WTOTPST =  [F:DEP]PSTDER    +  [F:DEP]PSTDERRVE + [F:DEP]PSTDPE+ [F:DEP]PSTEXC
   #Fq-81074 #&          + [F:DEP]PSTRVACRB +  [F:DEP]PSTRVETRF
   #Fq-81074 If WTOTPST > 0
   #FQ-93596If fstat=0
   #FQ-93596   RRET = G_OUI
   #FQ-93596   #Fq-81074Break
   #FQ-93596Endif
#Fq-81074Next
#Fq-81074Columns [DEP]

#<<<< FQ-93596 Optimisation conditionnée par la présence de l'index SPE_DEPB ---_
Filter [DEP] Where CPY=PCPY & CNX = PCNX & PERSTRDAT = PDATSTR & PERENDDAT = PDATEND & FLGPST=G_OUI
   Local Integer INDEX
   INDEX=find("SPE_DEPB",[G:DEP]keyname(0..[G:DEP]nbind-1))
   If INDEX
      Look[DEP]SPE_DEPB(4) First
   Else
      Look[DEP]First
   Endif
   If fstat=0
      RRET = G_OUI
   Endif
Filter [DEP]
# ---- FQ-93596 >>>>

End RRET

##########################################################################
# Permet de savoir si un contexte dont la dernière période est la période
# courante a toutes ses périodes en comptabilisation définitive.
#
# Dans le cas où la période courante n'est pas la dernière de l'exercice,
# on renvoie G_OUI
##########################################################################
Funprog IS_ALL_PER_POSTED(PCPY, PCNX, PDATENDFIY)
Value Char       PCPY
Value Integer    PCNX
Value Date       PDATENDFIY

  Local Integer RRET    : RRET = G_OUI

  If !clalev([F:WFIS]) : Local File FISCYEAR [WFIS] : Endif
  Read [WFIS]FIY2=PCPY;PCNX;PDATENDFIY

  # Dans le cas d'une clôture exercice, on contrôle que toutes les périodes sont en
  # comptabilisation définitives
  If ([F:WFIS]DATENDPER([F:WFIS]INDCURPER-1) = [F:WFIS]DATENDFIY) and find(GVML_TPSTPRO,[F:WFIS]TYPPST) Then
    RRET = G_NON
  Endif
End RRET

##########################################################################
# Permet de savoir si un contexte donné n'a pas de "A comptabiliser"
# en attente sur ses DEPREC
#
# Renvoie G_OUI si le contexte est comptabilisé, G_NON sinon
##########################################################################
Funprog IS_CNX_POSTED(PCPY, PCNX, PDATENDFIY, PDATENDPER)
Value Char       PCPY
Value Integer    PCNX
Value Date       PDATENDFIY
Value Date       PDATENDPER

  Local Integer RTLSTPLN(1)    # Tableau bidon.
  Local Integer RTLSTNBE(1)    # Tableau bidon

End func GLOBIENS.IS_CNX_POSTED_FILLTAB(PCPY, PCNX, G_NON, PDATENDFIY, PDATENDPER, RTLSTPLN, RTLSTNBE)

Funprog IS_CNX_POSTED_FILLTAB(PCPY, PCNX, PFILLTAB, PDATENDFIY, PDATENDPER, TLSTPLN, TLSTNBE)
Value Char       PCPY
Value Integer    PCNX
Value Integer    PFILLTAB     # Alimentation des tableaux de retour TLSTxxx : G_OUI / G_NON
Value Date       PDATENDFIY
Value Date       PDATENDPER
Variable Integer TLSTPLN()    # Tableau des plans pour lesquels il reste des événements non comptabilisés.
Variable Integer TLSTNBE()    # Tableau des compteurs d'événements non comptabilisés

  Local Char    CRITERE(255)
  Local Integer RRET    : RRET = G_OUI
  Local Integer N_PLN
  Local Integer N_COUNT
  Local Integer N_FILL  : N_FILL = 0

  If !clalev([F:WCNX]) : Local File CONTEXT  [WCNX] : Endif
  If !clalev([F:WFIS]) : Local File FISCYEAR [WFIS] : Endif
  If !clalev([F:WDEP]) : Local File DEPREC   [WDEP] : Endif

  Read [WCNX]CNX0=PCPY;PCNX
  Read [WFIS]FIY2=PCPY;PCNX;PDATENDFIY

  For N_PLN=0 To [F:WCNX]NBPLC-1
    If func SUBTPE.PLAN_COMPTABILISE([F:WCNX]CPY, [F:WCNX]PLNCAA(N_PLN), G_OUI) = G_OUI Then
      If [F:WFIS]TYPPST([F:WFIS]INDCURPER-1) = GVML_TPSTDEF or [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1) = [F:WFIS]DATENDFIY Then
        If [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1) = [F:WFIS]DATENDFIY Then
          # Sur la dernière période de l'exercice, on contrôle que toutes les dotations de l'exercice sont comptabilisées
          #115849  CRITERE="FLGDEV=G_OUI&CPY=[F:WCNX]CPY&CNX=[F:WCNX]CNX&FIYENDDAT=[F:WFIS]DATENDFIY&PERENDDAT=PDATENDPER&DPRPLN=[F:WCNX]PLNCAA(N_PLN)"
          CRITERE="FLGDEV=G_OUI&CPY=[F:WCNX]CPY&CNX=[F:WCNX]CNX&FIYENDDAT=[F:WFIS]DATENDFIY&PERENDDAT<=PDATENDPER&DPRPLN=[F:WCNX]PLNCAA(N_PLN)"
        Else
          # Sur une période lambda, seules la comptabilisation des dotations de la période est contrôlée.
          #FQ93596 CRITERE="FLGDEV=G_OUI&CPY=[F:WCNX]CPY&FIYENDDAT=[F:WFIS]DATENDFIY&PERENDDAT=[F:WFIS]DATENDPER([F:WFIS]INDCURPER-1)&DPRPLN=[F:WCNX]PLNCAA(N_PLN)"
         CRITERE="FLGDEV=G_OUI&CPY=[F:WCNX]CPY&CNX=[F:WCNX]CNX&FIYENDDAT=[F:WFIS]DATENDFIY&PERENDDAT=[F:WFIS]DATENDPER([F:WFIS]INDCURPER-1)&DPRPLN=[F:WCNX]PLNCAA(N_PLN)"
        Endif
        Filter [WDEP] Where evalue(CRITERE) Order By Key DEP7
        If PFILLTAB = G_OUI : # FQ66106
          N_COUNT = rowcount([F:WDEP])
          If N_COUNT > 0
            TLSTPLN(N_FILL) = [F:WCNX]PLNCAA(N_PLN)
            TLSTNBE(N_FILL) = N_COUNT
            N_FILL += 1
            RRET = G_NON
          Endif
          Filter [WDEP]
        Else
           Read [WDEP]DEP7(5) First
          Filter [WDEP]
          If !fstat
            RRET = G_NON
            Break
          Endif
        Endif
      Endif
    Endif
  Next N_PLN
End RRET

Funprog GET_CNX_POSTED_FILTER(PCPY, PPLNCAA, PDATENDPER, PDATENDFIY)
Value Char    PCPY
Value Integer PPLNCAA
Value Date    PDATENDPER
Value Date    PDATENDFIY

  If PDATENDPER = PDATENDFIY Then
    # Sur la dernière période de l'exercice, on contrôle que toutes les dotations de l'exercice sont comptabilisées
    End "FLGDEV=G_OUI&CPY='"+PCPY+"'&FIYENDDAT=["+format$(GFMD,PDATENDFIY)+"]&DPRPLN="+num$(PPLNCAA)
  Else
    # Sur une période lambda, seules la comptabilisation des dotations de la période est contrôlée.
    End "FLGDEV=G_OUI&CPY='"+PCPY+"'&FIYENDDAT=["+format$(GFMD,PDATENDFIY)+"]&PERENDDAT=["+format$(GFMD,PDATENDPER)+"]&DPRPLN="+num$(PPLNCAA)
  Endif
End

##########################################################################
# Vérification qu'il n'existe pas, pour les biens sortis dans l'exercice,
# du "A comptabiliser" sur des périodes futures en comptabilisation définitives
#
# Renvoie G_OUI si le contexte est comptabilisé pour ces biens, G_NON sinon
##########################################################################
Funprog IS_CNX_POSTED_ISS_FUTURE(PCPY, PCNX)
Value Char    PCPY
Value Integer PCNX

  Local Integer RRET    : RRET = G_OUI
  Local Integer N_PER

  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif
  If !clalev([F:WDEP]) : Local File DEPREC    [WDEP] : Endif
  If !clalev([F:WFIS]) : Local File FISCYEAR  [WFIS] : Endif
  If !clalev([F:WFI2]) : Local File FISCYEAR  [WFI2] : Endif

  Read [WFIS]FIY1=PCPY;PCNX;GVML_TECOURA
  Read [WFI2]FIY1=PCPY;PCNX;GVML_TESUIV

  # FQ61679 : réécriture avec un LINK suite bug sélection trop large
  #If find(GVML_TPSTDEF,[F:WFI2]TYPPST(0..[F:WFI2]NBRPER-1)) Then
  #    # Il y a de la comptabilisation définitive sur l'exercice suivant
  #    For [WFAS] Where CPY=PCPY and ISSDAT>=[F:WFIS]DATSTRFIY and ISSDAT<=[F:WFIS]DATENDFIY and EXTISSFLG=G_NON
  #      Look [F:WDEP]DEP7(4)=G_OUI;PCPY;PCNX;[F:WFI2]DATENDFIY
  #
  #      If !fstat
  #        RRET = G_NON
  #        Break
  #      Endif
  #    Next
  #Endif
  For N_PER = 0 To [F:WFI2]NBRPER-1
    If [F:WFI2]TYPPST(N_PER) = GVML_TPSTDEF
      Link [WDEP] With [WFAS]FAS0=AASREF As [LIEN]
&     Where [WFAS]CPY=PCPY and [WFAS]ISSDAT>=[F:WFIS]DATSTRFIY and [WFAS]ISSDAT<=[F:WFIS]DATENDFIY and [WFAS]EXTISSFLG=G_NON
&       and [WDEP]FLGDEV=G_OUI and [WDEP]CPY=PCPY and [WDEP]CNX=PCNX and [WDEP]FIYENDDAT=[F:WFI2]DATENDFIY and [WDEP]PERENDDAT=[F:WFI2]DATENDPER(N_PER)
#FQ93596  &       and [WDEP]FLGDEV=G_OUI and [WDEP]CNX=PCNX and [WDEP]FIYENDDAT=[F:WFI2]DATENDFIY and [WDEP]PERENDDAT=[F:WFI2]DATENDPER(N_PER)
      If rowcount([LIEN]) > 0
        RRET = G_NON
      Endif
    Endif
  Next
End RRET

##########################################################################
# Permet de savoir si un contexte donné est considéré comme calculé pour
# une période donnée
#
# Renvoie G_OUI si le contexte est calculé, G_NON sinon
##########################################################################
Funprog IS_CNX_CALCULATE(PCPY, PCNX, PDATENDFIY, PDATENDPER)
Value Char    PCPY
Value Integer PCNX
Value Date    PDATENDFIY
Value Date    PDATENDPER

  Local Integer RRET    : RRET = G_OUI

  If !clalev([F:WCNX]) : Local File CONTEXT   [WCNX] : Endif
  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif

  # Le contexte a-t'il subit des modifications remettant en cause le calcul ?
  Read [WCNX]CNX0=PCPY;PCNX
  If [F:WCNX]UPDWAINBR>0 Then
    # FQ66894
    Local Shortint N_UPD
    For N_UPD = 0 To [F:WCNX]UPDWAINBR-1
      If [F:WCNX]UPDWAIPAR(N_UPD)<>"FLUX"
        RRET=G_NON
        End RRET
      Endif
    Next
  Endif

  # Y-a-t'il des biens non calculés ?
  # FQ69639 : les biens annulés sont exclus du test
  #Look [DEP]DEP6=GVML_SCNOCAL;PCPY;PCNX;PDATENDFIY;PDATENDPER
  Link [DEP] With [WFAS]FAS0=AASREF As [LDEP] Where [WFAS]OWNTYP<>GVML_TDANNUL
  Look [LDEP]DEP6=GVML_SCNOCAL;PCPY;PCNX;PDATENDFIY;PDATENDPER

  If !fstat
    RRET=G_NON
    End RRET
  Endif

  # FQ53001
  If PDATENDFIY = PDATENDPER
    Filter [F:WFAS] Where FLGCNXCLC(PCNX-1) = GVML_RCCLO
    Look [WFAS]FAS1(1)=PCPY
    Filter [F:WFAS]

    If !fstat
      RRET=G_NON
      End RRET
    Endif
  Endif
End RRET

##########################################################################
# Permet de savoir si un contexte est retenu pour les gestion des UO
#
# Renvoie G_OUI ou G_NON
##########################################################################
Funprog IS_CNX_UO(PCPY, PCNX)
Value Char    PCPY
Value Integer PCNX

  Local Integer RRET    : RRET = G_NON

  If !clalev([F:WCNX]) : Local File CONTEXT [WCNX] : Endif

  # Le contexte a-t'il subit des modifications remettant en cause le calcul ?
  Read [WCNX]CNX0=PCPY;PCNX
  If [F:WCNX]FLGCNXUO=G_OUI Then
    RRET=G_OUI
  Endif
End RRET

##########################################################################
# Permet de savoir si le plan d'un bien donné est considéré comme calculé
# pour une période donnée.
#
# Le plan d'un bien est considéré comme calculé si
#    d'une part   [F:DEP]DEPSTA est à "Calculé"
#    d'autre part si le contexte du plan n'a pas subi
#                 de modification pouvant remettre en cause le calcul
#
# Renvoie 1 si le bien est considéré comme calculé
#         0 si le bien n'est pas considéré comme calculé

##########################################################################
Funprog IS_PLN_CALCULATE(PCPY, PBCO, PCNX, PPLN, PDATENDFIY, PDATENDPER)
Value Char    PCPY
Value Char    PBCO
Value Integer PCNX
Value Integer PPLN
Value Date    PDATENDFIY
Value Date    PDATENDPER

Local Integer RRET    : RRET = 1

  If !clalev([F:WCNX]) : Local File CONTEXT [WCNX] : Endif
  If !clalev([F:WDEP]) : Local File DEPREC  [WDEP] : Endif  :   # FQ68347

  # Le contexte a-t'il subi des modifications remettant en cause le calcul ?
  Read [WCNX]CNX0=PCPY;PCNX
  If ([F:WCNX]UPDWAINBR>0) Then
    RRET=0
    End RRET
  Endif

  # Le plan du bien est-il calculé ?
  Read [WDEP]DEP3=PCPY;PPLN;PBCO;PDATENDFIY;PDATENDPER
  If ( [F:WDEP]DEPSTA <> GVML_SCCAL ) Then
    RRET=0
    End RRET
  Endif
End RRET

##########################################################################
# Permet de savoir si les biens d'une UGT pour le contexte d'une société donné
# peuvent être considérés comme calculés pour une période donnée.
#
# Les biens d'une UGT pour le contexte d'une société sont considérés comme calculés si
#    d'une part   [F:FAS]FLGCNXCLC est à "Non"
#    d'autre part si le contexte du plan n'a pas subi
#                 de modification pouvant remettre en cause le calcul
#
# Renvoie 1 si les biens de l'UGT pour le contexte de la société sont considérés comme calculés
#         0 si les biens de l'UGT pour le contexte de la société ne sont pas tous considérés comme calculés
##########################################################################
Funprog IS_UGT_CALCULATE(PCPY, PCNX, PUGT, PDATENDFIY, PDATENDPER)
Value Char    PCPY
Value Integer PCNX
Value Char    PUGT
Value Date    PDATENDFIY
Value Date    PDATENDPER

Local Integer RRET    : RRET = 1

  If !clalev([F:WCNX]) : Local File CONTEXT   [WCNX] : Endif
  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif  :   # FQ68347
  If !clalev([F:WFIS]) : Local File FISCYEAR  [WFIS] : Endif  :   # FQ86581

  # Si l'UGT n'est pas renseignée, elle est considérée comme non calculée
  If (PUGT = "") Then
    RRET=0
    End RRET
  Endif

  # Le contexte a-t'il subi des modifications remettant en cause le calcul ?
  Read [WCNX]CNX0=PCPY;PCNX
  If ([F:WCNX]UPDWAINBR>0) Then
    RRET=0
    End RRET
  Endif

  # Détermination du la date de début d'exercice courant FQ86581
  Read [WFIS]FIY1=PCPY;PCNX;GVML_TECOURA
  If fstat Then
    # Cette situation est normalement impossible (un contexte sans exercice courant). Si elle
    # survient on considère que l'UGT n'est pas calculée pour bloquer l'utilisateur le temps
    # d'analyser le problème
    RRET=0
    End RRET
  Endif

  # Y-a-t'il au moins un bien de l'UGT non calculé pour le contexte ?
  # FQ53001
  # Filter [WFAS] Where IASCGU=PUGT and ( FLGCNXCLC(PCNX-1)=G_OUI )
  # Filter [WFAS] Where IASCGU=PUGT and ( FLGCNXCLC(PCNX-1) = GVML_RCOUI or FLGCNXCLC(PCNX-1) = GVML_RCCLO )
  # FQ86581 : ajout du filtre sur la date de sortie pour exclure les biens sortis dans un exercice
  #           antérieur
  Filter [WFAS] Where ( IASCGU = PUGT )
&                 and ((FLGCNXCLC(PCNX-1) = GVML_RCOUI) or (FLGCNXCLC(PCNX-1) = GVML_RCCLO))
&                 and ((ISSDAT = [0/0/0]) or (ISSDAT >= [F:WFIS]DATSTRFIY))
  Read [WFAS] First
  If !(fstat) Then
    RRET=0
    End RRET
  Endif
  Filter [WFAS]

End RRET


##########################################################################
#
#           FONCTIONS DE CONTROLE COMPTA/IMMO
#
##########################################################################
#DEBUT FQ76672
#**
#* Permet de savoir si le paramètre FRADGI est à "oui" pour la société passée en paramètre
#* Retourne 0-FRADGI="non", 1-FRADGI="oui".
#*
#* @param PCPY : société
#*!
Funprog FRADGI(PCPY)
Value Char PCPY

  Local Shortint RVALUE : RVALUE = 0

  If GMODU(2)=G_OUI and func AFNC.PARAM("FRADGI", PCPY) = num$(G_OUI)
    RVALUE = 1
  Endif
End RVALUE

# FQ76672

#DEBUT FQ70465
#**
#* Permet de savoir s'il faut exécuter les contrôles de cohérence avec le découpage exercices/périodes de la compta
#* pour la société passée en paramètre. Retourne 0-pas de contrôle à faire, 1-contrôle à faire.
#*
#* @param PCPY : société
#*!
Funprog ACCPERCTL(PCPY)
Value Char PCPY

  Local Shortint RVALUE : RVALUE = 0

  If GMODU(2)=G_OUI and func AFNC.PARAM("ACCPERCTL", PCPY) = num$(G_OUI)
    RVALUE = 1
  Endif
End RVALUE

# FQ65110
#**
#* Permet de savoir pour une société et un référentiel donnés si la
#* période est clôturée (utilisé par la clôture X3).
#*
#* @param PCPY    : Société
#* @param PLED    : Référentiel
#* @param PSTRDAT : Date de début de période
#* @param PENDDAT : Date de fin de période
#* @param RVALUE  : Code retour : 0 période non close, 1 période close, -1 incohérence dans les dates
#* @param RPLNCAA : Pour une période non close, donne le numéro du plan (menu local 3101)
#* @param RCNX    : Pour une période non close, donne le numéro du contexte (menu local 3100)
#*!
Subprog IS_PER_CLOSED(PCPY, PLED, PSTRDAT, PENDDAT, RVALUE, RPLNCAA, RCNX)
Value Char        PCPY
Value Char        PLED
Value Date        PSTRDAT
Value Date        PENDDAT
Variable Shortint RVALUE
Variable Integer  RPLNCAA
Variable Integer  RCNX

Local Shortint I_PLNCAA, I_PER

  If !clalev([WCNX]) : Local File CONTEXT  [WCNX] : Endif
  If !clalev([WFIS]) : Local File FISCYEAR [WFIS] : Endif

  RVALUE = 1

  If !func GLOBIENS.ACCPERCTL(PCPY) : End : Endif : # FQ70465

  For [WCNX]CNX0 Where CPY=PCPY
    RPLNCAA = 0
    RCNX    = [F:WCNX]CNX

    If  (find(G301CPT,[WCNX]PLNCAA) or find(G301IAS,[WCNX]PLNCAA))
&   and (find(PLED,[WCNX]LED))
      # Le contexte contient le plan comptable et/ou le plan IAS et le référentiel est associé à au moins un
      # plan de ce contexte
      RPLNCAA = [F:WCNX]PLNCAA(find(PLED,[WCNX]LED)-1)
      # Recherche de l'exercice contenant la période à contrôler
      Filter [WFIS] Where DATSTRFIY<=PSTRDAT and DATENDFIY>=PENDDAT
      Read [WFIS]FIY0(2)=[F:WCNX]CPY;[F:WCNX]CNX
      Filter [WFIS]
      If fstat
        # Pas d'exercice trouvé, c'est anormal
        RVALUE = -1
        Break
      Else
        I_PER=find(PSTRDAT,[F:WFIS]DATSTRPER)
        If (I_PER=0) or ([F:WFIS]DATENDPER(I_PER-1)<>PENDDAT)
          # Pas de période dans le contexte correspondant aux dates, c'est anormal
          RVALUE = -1
          Break
        Else
          If [F:WFIS]STAPER(I_PER-1)<>GVML_SPCLOSE
            # la période n'est pas close
            RVALUE = 0
            Break
          Endif
        Endif
      Endif
    Endif
  Next
End

#**
#* Permet de savoir si une période peut être fermée en compta.
#*
#* La fermeture d’une période en compta n’est pas possible :
#* • si cette période correspond à la période courante d’un contexte immo
#* • si la période d’un contexte immo est ouverte avec comptabilisation réelle.
#*
#* @param PCPY    : Société
#* @param PLEDTYP : Type de eéférentiel
#* @param PSTRDAT : Date de début de période
#* @param PENDDAT : Date de fin de période
#* @param RPLNCAA : Donne le numéro du plan (menu local 3101) qui empêche la fermeture
#* @param RCNX    : Donne le numéro du contexte (menu local 3100) qui empêche la fermeture
#* @param RVALUE  : Code retour : 0 période ne peux pas être fermée, 1 période peut être fermée, -1 incohérence dans les dates
#*!
Funprog IS_PERCPT_CLOSABLE(PCPY, PLEDTYP, PSTRDAT, PENDDAT, RCNX, RPLNCAA)
Value Char        PCPY
Value Integer     PLEDTYP
Value Date        PSTRDAT
Value Date        PENDDAT
Variable Integer  RCNX
Variable Integer  RPLNCAA

Local Shortint RVALUE
Local Shortint I_PLNCAA, I_PER

  If !clalev([WCNX]) : Local File CONTEXT  [WCNX] : Endif
  If !clalev([WFIS]) : Local File FISCYEAR [WFIS] : Endif

  RVALUE = 1

  If !func GLOBIENS.ACCPERCTL(PCPY) : End RVALUE : Endif

  For [WCNX]CNX0 Where CPY=PCPY
    RPLNCAA = 0
    RCNX    = [F:WCNX]CNX

    If find(PLEDTYP,[WCNX]LEDTYP)
      RPLNCAA = [F:WCNX]PLNCAA(find(PLEDTYP,[WCNX]LEDTYP)-1)

      If func GLOBIENS.IS_DESYNC_CNX(PCPY, [F:WCNX]CNX) = G_OUI
        RVALUE = 0
        Break
      Endif

      # Recherche de l'exercice contenant la période à contrôler
      Filter [WFIS] Where DATSTRFIY<=PSTRDAT and DATENDFIY>=PENDDAT
      Read [WFIS]FIY0(2)=[F:WCNX]CPY;[F:WCNX]CNX
      Filter [WFIS]
      If fstat
        # Pas d'exercice trouvé, c'est anormal
        RVALUE = -1
        Break
      Else
        I_PER=find(PSTRDAT,[F:WFIS]DATSTRPER)
        If (I_PER=0) or ([F:WFIS]DATENDPER(I_PER-1)<>PENDDAT)
          # Pas de période dans le contexte correspondant aux dates, c'est anormal
          RVALUE = -1
          Break
        Else
          If I_PER = [F:WFIS]INDCURPER or [F:WFIS]TYPPST(I_PER) = GVML_TPSTDEF
            # la période correspond à la période courante ou le type de comptabilisation est "Réel",
            # la période comptable ne peux pas être fermée
            RVALUE = 0
            Break
          Endif
        Endif
      Endif
    Endif
  Next
End RVALUE

#**
#* Permet de connaitre l'état d'une période de la compta.
#*
#* @param PCPY    : Société
#* @param PLED    : Référentiel
#* @param PSTRDAT : Date de début de période
#* @param RVALUE  : Code retour : 1 non ouverte, 2 ouverte, 3 Fermée, -1 incohérence dans les dates
#*!
Funprog PERCPT_STATE(PCPY, PLEDTYP, PSTRDAT)
Value Char        PCPY
Value Integer     PLEDTYP
Value Date        PSTRDAT

Local Shortint RVALUE

  If !clalev([WPER]) : Local File PERIOD     [WPER] : Endif

  RVALUE = 1

  Filter [F:WPER] Where PERSTR=PSTRDAT
  Read [F:WPER]PER0(2)=PCPY;PLEDTYP
  Filter [F:WPER]

  If fstat
    # C'est anormal, les périodes devraient être synchronisées
    RVALUE = -1
  Else
    RVALUE = [F:WPER]PERSTA
  Endif
End RVALUE

#**
#* Permet de marquer les contextes d'une société comme étant désynchronisé avec les exercices/périodes de la compta.
#*
#* @param PCPY    : Société
#* @param PLEDTYP : Type de référentiel
#* @param RCOD    : Code retour : 0-OK, KO sinon
#*!
Funprog DESYNC_CNX(PCPY, PLEDTYP)
Value Char    PCPY
Value Integer PLEDTYP

  Local Integer RCOD : RCOD = 0

  If !func GLOBIENS.ACCPERCTL(PCPY) : End RCOD : Endif

  If !clalev([F:WCNX]) : Local File CONTEXT [WCNX] : Endif

  For [WCNX]CNX0 Where CPY=PCPY
    If find(PLEDTYP,[F:WCNX]LEDTYP)
      Call ADD_UPD_WAI_CNX([WCNX]CPY, [F:WCNX]CNX, "CNX", "DESYNC", "", "", RCOD) From UPDWAICNX
    Endif
  Next
End RCOD

#**
#* Permet de savoir si un contexte est désynchronisé.
#*
#* @param PCPY    : Société
#* @param PCNX    : Contexte (0 si tous les contextes de la société)
#* @param RCOD    : Code retour : 1-Non, 2-Oui
#*!
Funprog IS_DESYNC_CNX(PCPY, PCNX)
Value Char    PCPY
Value Integer PCNX

  Local Integer RCOD : RCOD = G_NON
  Local Char    CRIT_CNX(254)

  If !func GLOBIENS.ACCPERCTL(PCPY) : End RCOD : Endif

  If !clalev([F:CNX_]) : Local File CONTEXT [CNX_] : Endif

  If PCNX=0
    CRIT_CNX = "1=1"
  Else
    CRIT_CNX = "CNX="+num$(PCNX)
  Endif

  For [CNX_]CNX0 Where CPY=PCPY and evalue(CRIT_CNX)
    If find("DESYNC",[F:CNX_]UPDWAIPAR)
      RCOD = G_OUI
      Break
    Endif
  Next

  Close Local File [CNX_]
End RCOD

#FIN FQ70465

##########################################################################
# Permet de savoir une société est en cours de cession intra-groupe
#
# Seules les CIG ayant le statut "Sortie traitées" sont bloquantes
##########################################################################
Subprog CONTROLE_CIG(PCPY, PTYPMES, RETOUR)
Value    Char    PCPY     # Société
Value    Integer PTYPMES  # Type de message   : 0 - Boîte de dialogue
#                                               1 - Information dans la trace (Serveur batch par ex).
#                                               2 - Pas d'information
Variable Integer RETOUR   # Code retour du sous-programme.

 Local  Char    SOC     : SOC     = PCPY
 Global Char    LISTCIG(10)(1..100)
 Global Char    LISTCIGDES(50)(1..100)
 Global Integer LISTCIGSTA(1..100)
 Global Integer LISTCIGNBBCO(1..100)
 Local  Integer I_RET
 Local  Integer CDRET

 CDRET = 0

 If func CTRL_CPY_CIG(SOC, "", LISTCIG, LISTCIGDES, LISTCIGSTA, LISTCIGNBBCO, CDRET)<>0

  #> Liste des erreurs dans une fenêtre.

  If PTYPMES=0
   Call ERREUR(mess(201,7780,1)-":"-SOC) From GESECRAN # Une ou plusieurs opération de cession intra-groupe sont en cours 201
   Local Char PARAM(30)(1..2)
   Local Char VALEUR
   PARAM(1)="CTRLCIG"
   Call TRAITE_CHAR(VALEUR,PARAM,"","TRTLISERR","LISERR",4,"") From GTRAITE
   If CDRET=1
    Local Integer POK
    Local Char LMESS(80)(3)
    LMESS(0)=mess(214,7780,1) #"Toutes les CIG sont en préparation."
    LMESS(1)=mess(215,7780,1) #"Vous pouvez clôturer mais leur paramétrage peut devenir incorrect"
    LMESS(2)=mess(216,7780,1) #"Confirmez-vous ?"
    Call OUINON(LMESS,POK) From GESECRAN
    If POK=2
     RETOUR = 0
    Else
     RETOUR = 1
    Endif
   Elsif CDRET>1
    RETOUR = 0
   Endif
  Endif

  #> Liste des erreurs dans une trace.

  If PTYPMES=1
   Local Char    LIGNE(115)
   Local Integer L_OPENTRC
   If GTRACE=""
    Call OUVRE_TRACE(mess(202,7780,1)) From LECFIC # Contrôle des cessions intra-groupes en cours 202
    L_OPENTRC=1
   Endif

   LIGNE=mess(203,7780,1)-":"-SOC # Opérations de cession intra-groupe en cours 203
   Call ECR_TRACE(LIGNE,1) From GESECRAN
   Call ECR_TRACE("",0) From GESECRAN
   LIGNE =left$(mess(204,7780,1)+space$(20),20)+space$(6)   # Référence CIG   204
   LIGNE+=left$(mess(205,7780,1)+space$(30),30)+space$(6)   # CIG             205
   LIGNE+=left$(mess(206,7780,1)+space$(20),20)+space$(6)   # Statut CIG      206
   LIGNE+=mess(207,7780,1)                                  # Nombre de biens 207
   Call ECR_TRACE(LIGNE,0) From GESECRAN
   LIGNE =string$(20,"=")+space$(6)
   LIGNE+=string$(30,"=")+space$(6)
   LIGNE+=string$(20,"=")+space$(6)
   LIGNE+=string$(15,"=")
   Call ECR_TRACE(LIGNE,0) From GESECRAN
   For I_RET=1 To 100
    If LISTCIG(I_RET)=""
     Break
    Else
     LIGNE =left$(LISTCIG(I_RET)+space$(20),20)+space$(6)
     LIGNE+=left$(LISTCIGDES(I_RET)+space$(30),30)+space$(6)
     LIGNE+=left$(mess(LISTCIGSTA(I_RET),3131,1)+space$(20),20)+space$(6)
     LIGNE+=num$(LISTCIGNBBCO(I_RET))
     Call ECR_TRACE(LIGNE,0) From GESECRAN
    Endif
   Next I_RET
   Call ECR_TRACE("",0) From GESECRAN
   If L_OPENTRC=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
   Endif
   RETOUR = 1
  Endif

  #> Pas de trace.

  # FQ67506 : les CIG en préparation ne sont pas bloquantes
  #If PTYPMES=2
  If PTYPMES=2 and CDRET>1
   RETOUR = 1
  Endif
 Endif

 If dim(LISTCIG)      : Kill LISTCIG      : Endif
 If dim(LISTCIGDES)   : Kill LISTCIGDES   : Endif
 If dim(LISTCIGSTA)   : Kill LISTCIGSTA   : Endif
 If dim(LISTCIGNBBCO) : Kill LISTCIGNBBCO : Endif

End

########################################
#gbn-021006-Seules les CIG "Sorties traitées" sont bloquantes.
Funprog CTRL_CPY_CIG(PCPY, PPNAME, TLISTCIG, TLISTCIGDES, TLISTCIGSTA, TLISTCIGNBBCO, RET)
Value    Char     PCPY               # Société à test
Value    Char     PPNAME             # Nom du programme à appeler dans la boucle principale
Variable Char     TLISTCIG()         # Liste des CIG en cours sur cette société
Variable Char     TLISTCIGDES()      # Désignation des CIG en cours sur cette société
Variable Integer  TLISTCIGSTA()      # Nombre de biens de la société concernés pour chaque CIG en cours
Variable Integer  TLISTCIGNBBCO()    # Nombre de biens de la société concernés pour chaque CIG en cours
Variable Integer  RET                # Code retour

# FQ64960
If G_ACTCIG <> G_OUI : End 0 : Endif

If !clalev([F:CIG]) : Local File CIGDEF    [CIG] : Endif
If !clalev([F:CIB]) : Local File CIGFXDSOR [CIB] : Endif

Local Char    L_REQU1(255)
Local Char    L_REQU2(255)
Local Integer L_NBCIG

L_REQU1="(CPYSRC=PCPY | CPYDES=PCPY)& CIGSTA<>3"

Filter [CIG] Where evalue(L_REQU1)
For [CIG]
 #
 RET=1
 #
 TLISTCIG   (L_NBCIG) = [F:CIG]CIGCOD
 TLISTCIGDES(L_NBCIG) = [F:CIG]DES
 TLISTCIGSTA(L_NBCIG) = [F:CIG]CIGSTA
 # Evaluation du nombre de bien traités
 L_REQU2 = "CIGCOD=[F:CIG]CIGCOD & (CPYSRC=[F:CIG]CPYSRC | CPYDES=[F:CIG]CPYDES)"
 Filter [CIB] Where evalue(L_REQU2)
 If PPNAME = ""
   TLISTCIGNBBCO(L_NBCIG) = rowcount([F:CIB])
 Else
   Gosub CTRL_CPY_CIG From =PPNAME
 Endif
 Filter [CIB]
 #
 L_NBCIG+=1
 #gbn-021006-Fq 37482-Les CIGSTA=1 ne sont pas bloquantes
 If [F:CIG]CIGSTA=2
  RET=2
 Endif
Next
Filter [CIG]

End L_NBCIG

# FQ68568
#*
#* Contrôle si l'option est autorisé pour le site et la fonction courante.
#*
#* Résultat du contrôle (0 = Non autorisé,  1 = Autorisé)
#*
#* @param PFCY : Site à contrôler
#* @param POPT : Option à contrôler
#*!
Funprog AUTORIS_OPT(PFCY, POPT)
Value Char PFCY
Value Char POPT

If GUSRFCY(1)="\"
  If PFCY=""
    If instr(1,GUSRAUZ(1),POPT)
      End 1
    Endif
  Else
    End 1
  Endif
Elsif find(PFCY,GUSRFCY(1..GNBAUZ))
  If instr(1,GUSRAUZ(find(PFCY,GUSRFCY(1..GNBAUZ))),POPT)
    End 1
  Endif
Endif
End 0

# FQ67615
########################################
#**
#* Vérifie si il existe un bien POOL ou LVA dans l'exercice passé en paramètre pour la société
#*
#* @param PCMPSTA     type de bien GVML_SBPOOL ou GVML_SBLVA
#* @param PDATSTRFIY  début d'exercice traité
#* @param PDATENDFIY  fin d'exercice traité
#* @param PCPY        société
#*!
Funprog EXISTEBIENLVA(PCMPSTA, PDATSTRFIY, PDATENDFIY, PCPY)
Value Integer PCMPSTA
Value Date PDATSTRFIY, PDATENDFIY
Value Char PCPY

Local Char WFILTRE(250), WFILTRE2(250)
Local Integer WRETOUR

  If PCMPSTA <> GVML_SBPOOL and PCMPSTA <> GVML_SBLVA
    End 0
  Endif
  #  1°) Recherche d'1 bien avec date de compta dans l'exercice
  WFILTRE = "CPY = '" + PCPY + "' and CMPSTA =" - num$(PCMPSTA)
  WFILTRE -= "and AASIPTDAT >= PDATSTRFIY and AASIPTDAT <= PDATENDFIY"

  WRETOUR = 0
  Filter [FAS] Where evalue(WFILTRE) Order By Key FAS11
  For [FAS]FAS11

    # recherche d'1 DEPREC
    # 2a°) Date De debut d'amt dans l'exercice
    WFILTRE2 = "[F:DEP]AASREF = [F:FAS]AASREF"
    WFILTRE2 -= "and [F:DEP]DPRPLN =" - num$(G301CPT)
    WFILTRE2 -= "and [F:DEP]STRDPRDAT >= PDATSTRFIY and [F:DEP]STRDPRDAT <= PDATENDFIY"

    Filter [DEP] Where evalue(WFILTRE2)
    Read [DEP]DEP0 First
    If fstat = 0
      WRETOUR = 1
      Filter [DEP]
      Break
    Endif

    # 2b°) Date De debut d'amt ds l'exercice précédent et cum forcé à 0
    WFILTRE2 = "[F:DEP]AASREF = [F:FAS]AASREF"
    WFILTRE2 -= "and [F:DEP]DPRPLN =" - num$(G301CPT)
    WFILTRE2 -= "and [F:DEP]STRDPRDAT < PDATSTRFIY"

    Filter [DEP] Where evalue(WFILTRE2) Order By Key DEP0
    Read [DEP]DEP0 First
    If fstat = 0
      Filter [DEP]
      If [F:DEP]DPRCUM = 0 and [F:DEP]DPRCUMFLG = G_OUI
        WRETOUR = 1
        Break
      Endif
    Endif
    Filter [DEP]
  Next
  Filter [FAS]

  End WRETOUR

# FQ95754
########################################
#**
#*
#* Recherche des biens classés pour vente non sortis dans l'exercice.
#* Retourne G_NON s'il n'y a pas de biens classés pour vente non sortis dans l'exercice, G_OUI s'il y en a.
#*
#* @param PCPY       : société
#* @param PDATENDFIY : date de fin d'exercice
#*!
Funprog HAS_FAS_SALCLS(PCPY, PDATENDFIY)
Value Char PCPY
Value Date PDATENDFIY

  Local Char RTLSTFAS(GLONVC9)(1)    # Tableau bidon

End func GLOBIENS.HAS_FAS_SALCLS_FILLTAB(PCPY, G_NON, PDATENDFIY, RTLSTFAS)

#**
#* Recherche des biens classés pour vente non sortis dans l'exercice.
#* Retourne G_NON s'il n'y a pas de biens classés pour vente non sortis dans l'exercice, G_OUI s'il y en a.
#* Alimente un tableau de biens classés pour vente non sortis dans l'exercice si le paramètre PFILLTAB est à G_OUI.
#*
#* @param PCPY       : société
#* @param PFILLTAB   : alimentation du tableau de retour TLSTFAS (G_OUI / G_NON)
#* @param PDATENDFIY : date de fin d'exercice
#* @param TLSTFAS    : tableau de retour contenant la liste des biens répondant au critère
#*!
Funprog HAS_FAS_SALCLS_FILLTAB(PCPY, PFILLTAB, PDATENDFIY, TLSTFAS)
Value Char       PCPY
Value Integer    PFILLTAB     # Alimentation des tableaux de retour TLSTxxx : G_OUI / G_NON
Value Date       PDATENDFIY
Variable Char    TLSTFAS()    # Tableau des biens classées pour vente non sortis

  Local Integer N_FILL  : N_FILL = 0
  Local Integer RRET    : RRET = G_NON
  Local Char    HAS_FAS_SALCLS_FILTER(255)

  HAS_FAS_SALCLS_FILTER = func GLOBIENS.HAS_FAS_SALCLS_FILTER(PCPY, PDATENDFIY)

  Local File FXDASSETS [WFAS] Where evalue(HAS_FAS_SALCLS_FILTER)

  If PFILLTAB = G_NON
    Read [WFAS]FAS1 First
    If !fstat
      RRET = G_OUI
    Endif
  Else
    For [WFAS]
      If N_FILL >= dim(TLSTFAS)
        Break
      Endif
      TLSTFAS(N_FILL) = [F:WFAS]AASREF
      N_FILL += 1
    Next
    If N_FILL > 0
      RRET = G_OUI
    Endif
  Endif
End RRET

#**
#* Retourne le filtre pour sélection des biens classés pour vente non sortis dans l'exercice
#*
#* @param PCPY       : société
#* @param PDATENDFIY : date de fin d'exercice
#*!
Funprog HAS_FAS_SALCLS_FILTER(PCPY, PDATENDFIY)
Value Char PCPY
Value Date PDATENDFIY
End "(CPY='"+PCPY+"') and (SALCLSDAT <> [0/0/0]) and (SALCLSDAT <= ["+format$("D:DD[/]MM[/]YYYY",PDATENDFIY)+"])" +
&                        "and (ISSDAT = [0/0/0] or (ISSDAT > ["+format$("D:DD[/]MM[/]YYYY",PDATENDFIY)+"] and EXTISSFLG <> G_OUI))"

