################################################################################
Subprog GET_MNT_ARRONDI (PMNT, PDEVISE, RMONTANT)
# Rend un montant arrondi en fonction de sa devise
# Si aucune devise n'est passée ou si celle-ci n'existe pas,
# on rend le montant passé
# ------------------------------------------------------------------------------
Value Decimal PMNT
Value Char PDEVISE
Variable Decimal RMONTANT

Local Decimal WCURRND

# Issue 109496
  If PDEVISE = "" Then
    # Pas de devise : on rend le montant passé
    RMONTANT = PMNT
  Else
    WCURRND = fmet GACTX.ACACHE.ACUR.AGETVALDEC(PDEVISE, "CURRND")
    RMONTANT = arr(PMNT, WCURRND)
  Endif

#  If PDEVISE <> "" Then
#
#    If clalev([F:TCUB])=0 : Local File TABCUR     [TCUB] : Endif
#    If [F:TCUB]CUR<>PDEVISE : # FQ96948
#       Read [TCUB]TCU0=PDEVISE
#       If fstat Then
#         # Erreur lecture devise : on rend le montant passé
#         RMONTANT = PMNT
#       Else
#         # Lecture OK : on applique l'arrondi au montant
#         RMONTANT = arr(PMNT, [F:TCUB]CURRND)
#       Endif
#    Else
#       # La classe était déjà chargée avec la bonne devise : on applique l'arrondi au montant
#       RMONTANT = arr(PMNT, [F:TCUB]CURRND)
#    Endif
#  Else
#    # Pas de devise : on rend le montant passé
#    RMONTANT = PMNT
#  Endif
# End Issue 109496
End

################################################################################
Subprog GET_QTY_ARRONDIE (PQTY, PUOM, RQUANTITE)
# Rend une quantité arrondie en fonction de son unité
# Si aucune unité n'est passée ou si celle-ci n'existe pas,
# on rend la quantité passée
# ------------------------------------------------------------------------------
Value Decimal PQTY
Value Char PUOM
Variable Decimal RQUANTITE

Local Decimal TUOMRND

  If PUOM <> "" Then
    If clalev([F:TUNB])=0 : Local File TABUNIT    [TUNB] : Endif
    Read [TUNB]TUN0=PUOM
    If fstat Then
      # Erreur lecture unité : on rend le quantité passée
      RQUANTITE = PQTY
    Else
      # Lecture OK : on applique l'arrondi à la quantité
      RQUANTITE = arr(PQTY, 10^(-[F:TUNB]UOMDEC))
    Endif
  Else
    # Pas de devise : on rend le quantité passée
    RQUANTITE = PQTY
  Endif
End

################################################################################
Funprog GET_UNITE_ARTICLE (PITM)
# Rend l'unité de l'article si elle est renseigné
# Si l'article n'existe pas, rend ""
# ------------------------------------------------------------------------------
Value Char PITM()

Local Char RUOM(GLONUOM)

  If PITM <> "" Then
    If clalev([F:ITM])=0 : Local File =GTABCPT+"ITMMASTER"   [ITM] : Endif
    Read [ITM]ITM0=PITM
    If fstat Then
      # Erreur lecture article
      RUOM = ""
    Else
      RUOM = [F:ITM]STU
    Endif
  Else
    RUOM = ""
  Endif
End RUOM

################################################################################
Funprog GET_FAMILLE_ARTICLE (PITM, PLEG)
# Rend la famille de la législation de l'article si elle est renseigné
# Si l'article n'existe pas, rend ""
# ------------------------------------------------------------------------------
Value Char PITM
Value Char PLEG

Local Char WCACGGRP

  If PITM <> "" Then
    If clalev([F:ITA])=0 : Local File "ITMACGGRP" [ITA] : Endif

    # FQ85470
    If (GLEGACT = 1) Then
      # Dossier mono législation
      Read [ITA]ITA0=PITM;""
    Else
      # Dossier multi législation
      Read [ITA]ITA0=PITM;PLEG
    Endif
    If fstat : Raz [F:ITA] : Endif

    If dim([F:ITA]ACGGRP)
      WCACGGRP = [F:ITA]ACGGRP
    Endif
  Endif
End WCACGGRP

################################################################################
Funprog GET_FORMAT_DEVISE (PCUR, PFORMAT, PNFMT)
# Rend le format numérique de la devise passée
# PFORMAT est un format numérique valide (non testable). Ex. : NzZ:
# 3 formats sont disponible, PNFMT indique celui souhaité
# rend 10.2 si rien n'est trouvé et PFORMAT vide ou selon exemple NzZ:10.2
# ------------------------------------------------------------------------------
Value Char    PCUR()
Value Char    PFORMAT()
Value Integer PNFMT

Local Char RFMTCUR(10)

  If left$(PFORMAT,1) <> "N" Then
    PFORMAT = ""
  Endif
  If PCUR <> "" and PNFMT >= 1 and PNFMT <= 3 Then
    If clalev([F:TCU])=0 : Local File "TABCUR"   [TCU] : Endif
    Read [TCU]TCU0=PCUR
    If fstat Then
      # Erreur lecture devise
      RFMTCUR = PFORMAT+"10.2"
    Else
      If PNFMT = 1 Then
        RFMTCUR = PFORMAT+[F:TCU]CURFMT1
      Elsif PNFMT = 2 Then
        RFMTCUR = PFORMAT+[F:TCU]CURFMT2
      Elsif PNFMT = 3 Then
        RFMTCUR = PFORMAT+[F:TCU]CURFMT3
      Endif
    Endif
  Else
    RFMTCUR = PFORMAT+"10.2"
  Endif
End RFMTCUR

################################################################################
##
##   S/P SUR TEXTES TRADUITS
##
################################################################################
################################################################################
Subprog DECODE_TEXTE (PINTIT, RZINTIT)
# Rend le texte dans la langue en cours à partir de son numéro
# ------------------------------------------------------------------------------
Value Integer PINTIT
Variable Char RZINTIT

  If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif

  Read [ATX]NUMERO=GLANGUE;PINTIT
  If fstat Then
    RZINTIT = ""
  Else
    RZINTIT = [F:ATX]TEXTE
  Endif
End

################################################################################
Funprog GET_LIBELLE_CHAMP (PCPY, PCODMSK, PCODZON, PNOBJET)
# Rend le libellé d'un champ d'écran.
# Si le libellé est disponible dans l'écran, il est récupéré
# Si le champs est une zone libre, le libellé est récupéré dans le paramétrage
#   des zones libres
# Si le libellé n'est pas dans les deux cas précédent, on va rechercher le
#   libellé du premier champs ayant le même nom dans l'une des tables de
#   l'écran sur lequel il se trouve.
# Si aucun libellé n'est trouvé, le code champ est rendu pour libellé.
# ------------------------------------------------------------------------------
Value    Char    PCPY     : # Société (utilisé pour le cas des paramétrage zones libres)
Value    Char    PCODMSK  : # Code écran sur lequel se trouve le champs
Value    Char    PCODZON  : # Nom du champs
Value    Integer PNOBJET  : # Code objet métier (utilisé pour le cas des paramétrage zones libres)

Local Char    CHAINE1(250), LCODZON(20)
Local Integer N_I, N_LIBTROUVE
Local Integer LNUMZLIB, LINDCODZON
Local Char    LZINTIT

  If clalev([F:AMKB])=0 : Local File AMSK    [AMKB] : Endif
  If clalev([F:ATZB])=0 : Local File ATABZON [ATZB] : Endif
  If clalev([F:FRF]) =0 : Local File FREFLD  [FRF]  : Endif
  If clalev([F:AMZC])=0 : Local File AMSKZON [AMZC] : Endif
  If clalev([F:ATXB])=0 : Local File ATEXTE  [ATXB] : Endif
  #------------------------------
  LZINTIT =  ""
  #------------------------------
  LCODZON =  func GLOBIENS.VIRE_INDICE_CODZON (PCODZON)
  If pat(PCODZON, '*(*') <> 0 Then
    LINDCODZON = val(seg$(PCODZON, instr(1, PCODZON, '(')+1, instr(instr(1, PCODZON, '(')+1, PCODZON, ')')-1))+1
    LINDCODZON += 1 # FQ114608
  Else
    LINDCODZON = 0
  Endif
  #------------------------------
  Filter [AMZC] Where CODMSK=PCODMSK and CODZON=LCODZON
  Read [AMZC]CODE First
  Filter [AMZC]
  If fstat>2 Then
  Else
    If [F:AMZC]CODTYP='CCE' or [F:AMZC]CODTYP='BCC' Then
      # Si c'est un axe analytique
      LZINTIT = mess(LINDCODZON,GML_AXEANAL,1)
    Else
      Call DECODE_TEXTE ([F:AMZC]INTIT, LZINTIT) From GLOBIENS
    Endif
  Endif
  #------------------------------
  If LZINTIT =  "" Then
    # On trouve pas le libellé dans l'écran
    # On regarde si c'est une zone libre ou pas
    N_LIBTROUVE = G_NON
    #------------------------------
    If left$(PCODZON, 4) = "USRF" Then
      #------------------------------
      # C'est une zone libre
      Read [FRF]FRF0=PNOBJET;PCPY
      If fstat Then
        Read [FRF]FRF0=PNOBJET;""
      Endif
      #------------------------------
      If fstat Then
      Else
        LNUMZLIB = val(mid$(PCODZON, 8, len(PCODZON)))
        Call LECTEXTRA(LZINTIT,"FREFLD",left$(PCODZON, 7)+num$(LNUMZLIB),num$(PNOBJET),[F:FRF]CPY) From ATEXTRA
        If LZINTIT <> "" Then
          N_LIBTROUVE = G_OUI
        Endif
      Endif
      #------------------------------
    Endif
    #------------------------------
    If N_LIBTROUVE = G_NON Then
      # C'est pas une zone libre, on va tenter de trouver le libellé dans la table
      Filter [AMKB] Where CODMSK=PCODMSK
      Read [AMKB]CODMSK First
      Filter [AMKB]
      CHAINE1 = ""
      For N_I = 0 To [AMKB]NBFIC-1
        If CHAINE1 <> "" Then
          CHAINE1 += "|"
        Endif
        CHAINE1 += "[F:ATZB]CODFIC='"+[F:AMKB]FICREF(N_I)+"'"
        #------------------------------
        # Suite de la boucle
      Next N_I
      If CHAINE1 <> "" Then
        CHAINE1 = "("+CHAINE1+")"
        Filter [ATZB] Where evalue(CHAINE1) &CODZONE=PCODZON
        Read [ATZB]CODZONE First
        Filter [ATZB]
        If fstat>2 Then
          LZINTIT = PCODZON
        Else
          Call DECODE_TEXTE ([F:ATZB]NOLONG, LZINTIT) From GLOBIENS
          If LZINTIT = "" Then
            LZINTIT = PCODZON
          Endif
        Endif
      Else
        LZINTIT = PCODZON
      Endif
    Endif
  Endif
End LZINTIT

################################################################################
Funprog VIRE_INDICE_CODZON (PCODZON)
# enlève l'indice d'un code champs
#   CCE(0)  est rendu CCE
#   CHAMP   est rendu CHAMP
# ------------------------------------------------------------------------------
Value    Char    PCODZON  : # Nom du champs

  If pat(PCODZON, '*(*') <> 0 Then
    LCODZON = left$(PCODZON, instr(1, PCODZON, '(')-1)
  Else
    LCODZON = PCODZON
  Endif
End LCODZON

################################################################################
##
##   S/P DIVERS
##
################################################################################
################################################################################
Subprog GET_WIN_ON_341 (PCHOIX, RWIN)
# Rend le code fenêtre à partir du code du menu local 341
# ------------------------------------------------------------------------------
Value Integer PCHOIX
Variable Char RWIN

  If PCHOIX = 1 Then
    # Dépense
    RWIN = 'OLOF'
  Elsif PCHOIX = 2 Then
    # Bien comptable
    RWIN = 'OFAS'
  Elsif PCHOIX = 3 Then
    # Subvention
    RWIN = 'OGRT'
  Elsif PCHOIX = 4 Then
    # contrat de location financement
    RWIN = 'OLEA'
  Elsif PCHOIX = 6 Then
    RWIN = 'OPHY'    # élément physique.
  Elsif PCHOIX = 7 Then
    RWIN = 'OCCN'    # Concessions. Fq67541
  Else
    RWIN = ''
  Endif
End

################################################################################
Funprog IS_CHAMP_ENABLE (PCHAMP, PIND)
# Reçoit un nom de champ écran sous la forme [M:xxx]MONCHAMP
# et rend G_OUI si le champ est ENABLE
# ou rend G_NON si le champs est DISABLE
# ------------------------------------------------------------------------------
Value Char PCHAMP
Value Integer PIND

Local Integer LENABLE
Local Char    LCHAINE(250)

  LCHAINE = "varmode(" + PCHAMP + "," + num$(PIND) + ")"
  If evalue(LCHAINE) = 0 Then
    LENABLE = G_OUI
  Else
    LENABLE = G_NON
  Endif
End LENABLE

################################################################################
Funprog ISENABLE (PCHAMP, PIND)
# Reçoit un nom de champ écran sous la forme [M:xxx]MONCHAMP
# et rend G_OUI si le champ est ENABLE
# ou rend G_NON si le champs est DISABLE
# Bidouille, ne pas utiliser celui là, c'est pour pouvoir mettre le test dans
# le type de donnée MZS et la fonction normale est trop longue
# ------------------------------------------------------------------------------
Value Char PCHAMP
Value Integer PIND

Local Integer LENABLE

  LENABLE = func GLOBIENS.IS_CHAMP_ENABLE (PCHAMP, PIND)
End LENABLE

################################################################################
Subprog GET_LISTE_ECRAN (PWIN, RCHAINE)
# Rend sous forme de (... or ...) la liste des écrans de la fenêtre PWIN
# ------------------------------------------------------------------------------
Value Char PWIN
Variable Char RCHAINE

  If clalev([F:AWIB])=0 : Local File AWINDOW  [AWIB] : Endif : # Dictionnaire des fenêtres
  If [F:AWIB]WIN <> PWIN Then
    Filter [AWIB] Where WIN=PWIN
    Read [AWIB]AWI0 First
    Filter [AWIB]
  Endif

  RCHAINE = ""
  If [AWIB]MSKENT <> "" Then
    RCHAINE += "[F:AMZB]CODMSK='"+[AWIB]MSKENT+"'"
  Endif
  For N_I = 0 To [F:AWIB]NBMSK-1
    If RCHAINE <> "" Then
      RCHAINE += "|"
    Endif
    RCHAINE += "[F:AMZB]CODMSK='"+[F:AWIB]NOMMSK(N_I)+"'"
    #------------------------------
    # Suite de la boucle
  Next N_I
  If RCHAINE <> "" Then
    RCHAINE = "("+RCHAINE+")"
  Endif
End

################################################################################
Funprog GET_BLOC_CHAMP (PWIN, PCHAMP, RABRMSK, RTYPBLOC, RBASPAG, RLIGBLOC)
# Rend le numéro du bloc du champ de l'écran
# ------------------------------------------------------------------------------
Value    Char    PWIN
Value    Char    PCHAMP
Variable Char    RABRMSK
Variable Integer RTYPBLOC
Variable Char    RBASPAG
Variable Integer RLIGBLOC

Local    Integer LBLOC, N_I

  If clalev([F:AMZB])=0 : Local File AMSKZON [AMZB] : Endif
  If clalev([F:AMKB])=0 : Local File AMSK    [AMKB] : Endif

  Filter [AMZB] Where CODMSK=PWIN and CODZON=PCHAMP
  Read [AMZB]CODE First
  Filter [AMZB]

  Filter [AMKB] Where CODMSK=PWIN
  Read [AMKB]CODMSK First
  Filter [AMKB]
  N_I      = [F:AMZB]NUMBLOC
  RLIGBLOC = N_I
  LBLOC    = [F:AMKB]RANG(N_I-1)
  RTYPBLOC = [F:AMKB]TYPBLOC(N_I-1)
  RBASPAG  = [F:AMKB]BASPAG(N_I-1)

  RABRMSK  = [F:AMKB]ABRMSK
End LBLOC

################################################################################
Subprog ACTION_LIGNE_TABLEAU (PACTION, PECRAN, PCHAMP, PLIGNE)
#
# Objet :  Effectue l'operation PACTION sur tous les champs saisissables
#          de la ligne d'un bloc tableau d'un masque.
#
#          PACTION = 1 : Affzo
#                  = 2 : Effzo
#                  = 3 : Actzo
#                  = 4 : Diszo
#                  = 5 : Grizo
#          PMASQUE nom de l'écran
#          PCHAMP  variable de bas de tableau,
#          PLIGNE  la ligne du tableau concernée (0 à n)
#
# ------------------------------------------------------------------------------
Value Integer PACTION
Value Char    PECRAN
Value Char    PCHAMP
Value Integer PLIGNE

Local Schar   LBLKNBR(20)  : # Numéro du bloc tableau
Local Char    LABRMSK(GLONABR)   : # Abréviation du bloc tableau # Issue X3-42506
Local Integer LTYPBLOC     : # Type de bloc (1 bloc tableau)
Local Char    LBASPAG
Local Integer LLIGBLOC

  If clalev([F:AMZB])=0 : Local File AMSKZON [AMZB] : Endif

  LBLKNBR = num$(func GLOBIENS.GET_BLOC_CHAMP (PECRAN, PCHAMP, LABRMSK, LTYPBLOC, LBASPAG, LLIGBLOC))

  If ( LTYPBLOC = 1 ) Then
    Default Mask "["+LABRMSK+"]"
    Case PACTION
      When ACB_ACTZO
        For [AMZB]CODTYP Where CODMSK=PECRAN and NUMBLOC=LLIGBLOC and CODTYP<>'ABS' and SAIAFF=1
          Actzo = [F:AMZB]CODZON+"("+num$(PLIGNE)+")"
        Next
      When ACB_AFFZO
        For [AMZB]CODTYP Where CODMSK=PECRAN and NUMBLOC=LLIGBLOC and CODTYP<>'ABS' and SAIAFF=1
          Affzo = [F:AMZB]CODZON+"("+num$(PLIGNE)+")"
        Next
      When ACB_EFFZO
        For [AMZB]CODTYP Where CODMSK=PECRAN and NUMBLOC=LLIGBLOC and CODTYP<>'ABS' and SAIAFF=1
          Effzo = [F:AMZB]CODZON+"("+num$(PLIGNE)+")"
        Next
      When ACB_DISZO
        For [AMZB]CODTYP Where CODMSK=PECRAN and NUMBLOC=LLIGBLOC and CODTYP<>'ABS' and SAIAFF=1
          Diszo =[F:AMZB]CODZON+"("+num$(PLIGNE )+")"
        Next
      When ACB_GRIZO
        For [AMZB]CODTYP Where CODMSK=PECRAN and NUMBLOC=LLIGBLOC and CODTYP<>'ABS' and SAIAFF=1
          Grizo =[F:AMZB]CODZON+"("+num$(PLIGNE)+")"
        Next
    Endcase
  Endif

End

################################################################################
Subprog ACTION_BLOCK (PACTION, PWIN, PCHAMP)
# Rend le numéro du bloc du champ de l'écran
# PACTION = 1 : Affzo
# PACTION = 2 : Effzo
# PACTION = 3 : Actzo
# PACTION = 4 : Diszo
# PACTION = 5 : Grizo
# ------------------------------------------------------------------------------
Value Integer PACTION
Value Char    PWIN
Value Char    PCHAMP

Local Schar   LBLKNBR(20), LCHAINE(200)
Local Char    LABRMSK(GLONABR) # Issue X3-42506
Local Integer LTYPBLOC, LBLOC
Local Char    LBASPAG
Local Integer LLIGBLOC
  If clalev([F:AMZB])=0 : Local File AMSKZON [AMZB] : Endif

  LBLKNBR = num$(func GLOBIENS.GET_BLOC_CHAMP (PWIN, PCHAMP, LABRMSK, LTYPBLOC, LBASPAG, LLIGBLOC))

  Default Mask "["+LABRMSK+"]"
  Case PACTION
    When ACB_AFFZO : Affzo =LBLKNBR
    When ACB_EFFZO : Effzo =LBLKNBR
    When ACB_ACTZO
      If LTYPBLOC <> 1 Then
        Actzo =LBLKNBR
      Elsif LTYPBLOC = 1 Then
        For [AMZB]CODTYP Where CODMSK=PWIN and NUMBLOC=LLIGBLOC and CODTYP<>'ABS' and SAIAFF=1
          Actzo =[F:AMZB]CODZON
          #------------------------------
          # Suite de la boucle
        Next
      Endif
    When ACB_DISZO
      If LTYPBLOC <> 1 Then
        Diszo =LBLKNBR
      Elsif LTYPBLOC = 1 Then
        For [AMZB]CODTYP Where CODMSK=PWIN and NUMBLOC=LLIGBLOC and CODTYP<>'ABS' and SAIAFF=1
          Diszo =[F:AMZB]CODZON
          #------------------------------
          # Suite de la boucle
        Next
      Endif
    When ACB_GRIZO
      If LTYPBLOC <> 1 Then
        Grizo =LBLKNBR
      Elsif LTYPBLOC = 1 Then
        For [AMZB]CODTYP Where CODMSK=PWIN and NUMBLOC=LLIGBLOC and CODTYP<>'ABS' and SAIAFF=1
          Grizo =[F:AMZB]CODZON
          #------------------------------
          # Suite de la boucle
        Next
      Endif
  Endcase
End

################################################################################
Funprog GET_TYPE_PHYSIQUE (PCODFIC, PCODZONE)
# Rend le type physique d'une colonne de table
#  1 : Numérique
#  2 : Alpha-numérique
#  3 : Date
#  0 : Inconnu !
Value Char PCODFIC            : # Table à consulter
Value Char PCODZONE           : # Zone à consulter

Local Integer RTYPEPHY

  #------------------------------
  If clalev([F:ATY])=0  : Local File ATYPE        [ATY]  : Endif : # Types de données
  If clalev([F:ATZ])=0  : Local File ATABZON      [ATZ]  : Endif : # dictionnaire des champs de table
  #------------------------------
  Filter [ATZ] Where CODFIC=PCODFIC &CODZONE=PCODZONE
  Read [ATZ]CODZONE Last
  Filter [ATZ]
  #------------------------------
  Filter [ATY] Where CODTYP=[F:ATZ]CODTYP
  Read [ATY]CODTYP Last
  Filter [ATY]
  #------------------------------
  If [F:ATY]TYPTYP < 7 Then
    # Numérique
    RTYPEPHY = GNUMBER
  Elsif [F:ATY]TYPTYP = 7 Then
    # Alpha-numérique
    RTYPEPHY = GALPHA
  Elsif [F:ATY]TYPTYP = 8 Then
    # Date
    RTYPEPHY = GDATE
  Else
    RTYPEPHY = GINCONN
  Endif
End RTYPEPHY

