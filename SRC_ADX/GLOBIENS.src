Funprog CPY_PLN_GERE(PCPY, PPLN)
Value Char    PCPY()
Value Integer PPLN

Local Integer LREPONSE, LTROUVE
Local Integer LCONTEXT

  LREPONSE = G_NON
  If ( PPLN > 0 and PPLN <> G301AUC ) Then
    If !clalev([F:CNXW]) : Local File CONTEXT [CNXW] : Endif
    # >>>>>>
    For [CNXW]CNX0 Where CPY = PCPY
      If ( find(PPLN, [F:CNXW]PLNCAA) <> 0 ) Then
        LREPONSE = G_OUI
        Break
      Endif
    Next
    # <<<<<<
  Endif

End LREPONSE

########################################
Funprog GET_NORME_PLAN (PCPY,PPLAN)
# Rend la norme du plan de la société passés en paramètre
# (ML392 : 1 STD, 2 CRC, 3 IAS)
Value Char    PCPY
Value Integer PPLAN
Local Integer RNORME

Local Integer LCNX
Local Integer I_PLN

  RNORME=-1

  If !clalev([F:CNXW]) : Local File CONTEXT [CNXW] : Endif
  Call GET_CNX_FROM_PLAN(PCPY, PPLAN, LCNX)
  If (LCNX > 0 ) Then
    Read [CNXW]CNX0=PCPY;LCNX
    If ( fstat = 0 ) Then
      I_PLN = find(PPLAN,[F:CNXW]PLNCAA)
      If ( I_PLN <> 0 ) Then
        RNORME=[F:CNXW]PLNSTD(I_PLN-1)
      Endif
    Endif
  Endif

End RNORME

########################################
Subprog GET_CNX_FROM_PLAN (PCPY, PPLN, RCNX)
# Rend le contexte correspondant au plan passé
# Rend -1 si erreur, 0 si plan=0, sinon rend le contexte

Value    Char    PCPY     # Société
Value    Integer PPLN     # Plan
Variable Integer RCNX

  RCNX = -1
  If ( PPLN = 0 ) Then
    RCNX = 0
  Else
    If !clalev([F:CNXW]) : Local File CONTEXT [CNXW] : Endif
    # >>>>>>
    For [CNXW]CNX0 Where CPY = PCPY
      If ( find(PPLN, [F:CNXW]PLNCAA) <> 0 ) Then
        RCNX =[F:CNXW]CNX
        Break
      Endif
    Next
    # <<<<<<
  Endif

End

########################################
Funprog GET_LEDTYP_FROM_PLAN (PCPY, PPLN)
# Rend le contexte correspondant au plan passé
# Rend -1 si erreur, 0 si plan=0, sinon rend le contexte

Value    Char    PCPY     # Société
Value    Integer PPLN     # Plan

Local Integer RLEDTYP
Local Integer RCNX
Call GET_CNX_FROM_PLAN (PCPY, PPLN, RCNX)
If RCNX > 0    : # FQ71307
 If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif
 Read [F:CNX]CNX0=PCPY;RCNX
 If !fstat
  Local Integer I_PLN
  I_PLN=find(PPLN,[F:CNX]PLNCAA)
  If I_PLN
   RLEDTYP=[F:CNX]LEDTYP(I_PLN-1)
  Endif
 Endif
Else
 RLEDTYP = -1  : # FQ71307
Endif

End RLEDTYP

########################################
Subprog VIRE_CNX_NON_GERES (PCPY)
# S/P à appeler en "Avant Saisie" d'une rubrique.
# Enlève d'une combo menu local tous les contextes non gérés sur la société
# passée en paramètre. ( Attention ML doit être déclaré en MM)
#
Value Char PCPY

Local Integer N_I, NTROUVE

  If clalev([F:CNX])  = 0 : Local File CONTEXT     [CNX]  : Endif : # Contextes
  For N_I = 1 To G300MAX
    Read [CNX]CNX0=PCPY;N_I
    If fstat Then
      GMENLOC(N_I) = 1
    Endif
  Next N_I

End

########################################
Subprog VIRE_CNX_GERES (PCPY)
# S/P à appeler en "Avant Saisie" d'une rubrique.
# Enlève d'une combo menu local tous les contextes gérés sur la société
# passée en paramètre.( Attention ML doit être déclaré en MM)
#
Value Char PCPY

Local Integer N_I, NTROUVE

  If clalev([F:CNX])  = 0 : Local File CONTEXT     [CNX]  : Endif : # Contextes
  For [CNX] Where CPY=PCPY
    GMENLOC([F:CNX]CNX) = 1
  Next N_I

End

########################################
Subprog VIRE_PLN_NON_GERES (PCPY, PCNX)
# Enlève d'une combo menu local tous les plans non gérés sur la société
# et le contexte passé en paramètre.
# La rubrique doit être déclarée en MM et pas en M pour que la destruction
# des valeurs puisse fonctionner.
# S/P à appeler en "Avant Saisie" d'une rubrique.
# Si PCNX = 0 la combo conserve tous les plan gérés sur la société
Value    Char    PCPY
Value    Integer PCNX



  Local Integer N_I, I
  Local Integer BPLN(1..G301MAX)
  Local Char    SEL(255)

  If clalev([F:CNX])  = 0 : Local File CONTEXT     [CNX]  : Endif : # Contextes
  # --------------------------
  GMENLOC(G301AUC) = 1

  Raz BPLN
  If ( PCNX = 0 ) Then
    SEL = "[F:CNX]CPY=PCPY"
  Else
    SEL = "[F:CNX]CPY=PCPY and [F:CNX]CNX= PCNX"
  Endif

  For [CNX]CNX0 Where evalue(SEL)
    # Plans du contexte
    For I = 1 To [F:CNX]NBPLC
      BPLN([F:CNX]PLNCAA(I-1)) = 1
    Next I
  Next CNX0

  NBTEX = 0
  For I=1 To 15
    If not( BPLN(I) ) Then : GMENLOC(I) = 1 :   Endif
  Next I


End

########################################
Subprog VIRE_PLN_CUR_DIFFERENTE (PCPY, PCUR, PAUTRE)
# Enlève d'une combo menu local tous les plans non gérés sur la société
# ou gérés dans une devise différente de PCUR
# La rubrique doit être déclarée en MM et pas en M pour que la destruction
# des valeurs puisse fonctionner.
# S/P à appeler en "Avant Saisie" d'une rubrique.
# Si PCUR = "" la combo conserve tous les plan gérés sur la société
# et le fonctionnement est analogue à VIRE_PLN_NON_GERES avec PCNX=0
# PAUTRE permet de conserver un plan dans la liste sans rien contrôler
#        peut être utile pour passer notamment G301AUC (Aucun)
Value    Char    PCPY
Value    Char    PCUR
Value    Integer PAUTRE

Local    Integer N_I
Local    Integer LCNXCOR
Local    Integer NTROUVE

  If clalev([F:CNX])  = 0 : Local File CONTEXT     [CNX]  : Endif : # Contextes
  # >>>>>>>>>>>
  For N_I = 1 To G301MAX
    If ( PAUTRE = 0 or PAUTRE <> N_I ) Then
      # --------------------------
      Call GET_CNX_FROM_PLAN (PCPY, N_I, LCNXCOR) From GLOBIENS
      # --------------------------
      If ( LCNXCOR > 0 ) Then
        Read [CNX]CNX0=PCPY;LCNXCOR
        If (fstat) Then
          NTROUVE = 0
        Else
          NTROUVE =  find(N_I,[F:CNX]PLNCAA)
        Endif
        If ( NTROUVE = 0 ) Then
          GMENLOC(N_I) = 1
        Else
          If PCUR <> "" and [F:CNX]CUR <> PCUR Then
            GMENLOC(N_I) = 1
          Endif
        Endif
      Endif
    Endif
  Next N_I
  # <<<<<<<<<<<
End

