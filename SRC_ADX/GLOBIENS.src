##
##
##
##
################################################################################
################################################################################
Funprog CTRL_CHAR_NUM_0_254 (PCODE)
# Contrôle que la chaîne passée est un nombre compris entre 0 et 254 entiers
# Rend : G_OUI si la condition est remplie ou si la chaîne est vide
#        G_NON si la condition n'est pas remplie (>255 ou des lettre dans la chaine)
# ------------------------------------------------------------------------------
Value Char PCODE()

Local Integer LNOMBRE
Local Integer LCTRL_OK

  If PCODE = "" Then
    # La chaîne est vide : c'est pas faux !
    LCTRL_OK = G_OUI
  Elsif len(PCODE) > 3 Then
    # >3 caractères : ça peut pas etre bon !
    LCTRL_OK = G_NON
  Elsif val(PCODE) > 254 Then
    # Supérieur à 255 : dépasse la limite maxi
    LCTRL_OK = G_NON
  Elsif val(PCODE) <> num$(val(PCODE)) Then
    # Le code ne contient pas que des chiffres (0 à 9 uniquement)
    LCTRL_OK = G_NON
  Endif
End LCTRL_OK

################################################################################
Subprog CTRL_VEHIC (PCODE)
Value Char PCODE()

  If func GLOBIENS.CTRL_CHAR_NUM_0_254(PCODE)=G_NON Then
    GERR     = 1
    GMESSAGE = mess(130,7770,1)
    mkstat   = 2
  Endif
End

