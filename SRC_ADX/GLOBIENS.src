Subprog GET_NUMERO_ELTPHY(PABREV, PNUMAFF, PINDEX, PFCY, PDATE, PCPY, PREFBCO, RNUMERO, STAT)
# ------------------------------------------------------------------------------
# Fiche 49517 : numérotation des éléments physiques à partir du bien
# ------------------------------------------------------------------------------
# V5.1 (SYMEU) : Numérote les objets métiers pour les éléments physiques
# Cette méthode va diriger vers la méthode standard d'affectation de compteur
# ------------------------------------------------------------------------------
# PABREV  : Abréviation (standard) de la table ppale de l'objet métier
# PNUMAFF : indice du compteur de l'objet dans l'affectation des compteurs
# PINDEX  : Rang de l'index à utiliser pour contrôler l'absence du numéro attribué
# PFCY    : Site de référence pour le compteur
# PDATE   : Date de référence pour le compteur
# PCPY    : Société de référence
# PREFBCO : Référence du bien auquel l’élément physique est rattaché
#
# Rend :
# RNUMERO : Numéro
# STAT    : Statut (0 : OK, >0 : KO)
# ------------------------------------------------------------------------------
Value    Char    PABREV
Value    Integer PNUMAFF
Value    Integer PINDEX
Value    Char    PFCY
Value    Date    PDATE
Value    Char    PCPY
Value    Char    PREFBCO
Variable Char    RNUMERO
Variable Integer STAT

# FQ109840
#If GPHYNUMBCO = G_OUI and vireblc(PREFBCO,4) <> "" Then
#  Call GET_NUMEROPHY(PCPY, PREFBCO, RNUMERO, STAT)
#Else
  Call GET_NUMERO(PABREV,PNUMAFF,PINDEX,PCPY,PFCY,PDATE,RNUMERO,STAT)  : #FQ85464
#Endif
End

