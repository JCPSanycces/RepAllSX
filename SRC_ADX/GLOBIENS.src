##
##
##   SOUS-PROGRAMMES SUR LES COMPTE PCG ET IAS ET LES CODES COMPTABLES
##
##
##
################################################################################
################################################################################
Funprog GET_GACCCODE (PTPCODGAC, PINDLOPCG, PCPTPCG, PINDLOIAS, PCPTIAS, RERROR)
# Rend le PREMIER code comptable utilisant le compte passé en paramètres
# et en tenant compte des autres paramètres
# ------------------------------------------------------------------------------
Value    Integer PTPCODGAC       : # Type de code comptable à consulter (ML602)
Value    Integer PINDLOPCG       : # Indice PCG sur lequel porte la recherche dans les codes comptables
Value    Char    PCPTPCG         : # Compte PCG recherché
Value    Integer PINDLOIAS       : # Indice IAS sur lequel porte la recherche dans les codes comptables
Value    Char    PCPTIAS         : # Compte IAS recherché
Variable Integer RERROR          : # 0=Tout c'est bien passé -1=Erreur et LCODE est vide

Local Char LCODE(GLONCAC)
Local Char LREQUETE(250)

 If clalev([F:CAC])=0    : Local File GACCCODE   [CAC] : Endif
 If clalev([F:CACI])=0   : Local File GACCCODE   [CACI] : Endif # Issue 109829 -pour lecture plan de compte IAS
 RERROR = -1
 LCODE  = ""
# Issue 109829 LREQUETE = ""

# Issue 109829 If PINDLOPCG <> -1 Then : LREQUETE  =  "(COA=GFASLEDSOC & ACC(PINDLOPCG)=PCPTPCG)" : Endif
# Issue 109829 If PINDLOIAS <> -1 Then : LREQUETE -= "!(COA=GFASLEDIAS & ACC(PINDLOIAS)=PCPTIAS)" : Endif

# Issue 109829 For [CAC]CAC0(2) Where TYP = PTPCODGAC & evalue(LREQUETE)
# Issue 109829   RERROR = 0
# Issue 109829   LCODE = [F:CAC]ACCCOD
# Issue 109829   Break
# Issue 109829 Next

Filter [CAC] Where ( TYP=PTPCODGAC & COA=GFASLEDSOC & ACC(PINDLOPCG)=PCPTPCG )
  For [CAC]
    If PINDLOIAS <> -1
      For[CACI]CAC0 Where (TYP=PTPCODGAC & COA= GFASLEDIAS & ACC(PINDLOIAS)=PCPTIAS)
        If [F:CACI]ACCCOD=[F:CAC]ACCCOD
   RERROR = 0
          LCODE = [F:CACI]ACCCOD
          Break
        Endif
      Next
    Else
   RERROR = 0
   LCODE = [F:CAC]ACCCOD
   Break
    Endif
 Next
Filter [CAC]

End LCODE

################################################################################
Funprog GET_GAC_FROM_GACCCODE (PTPCODGAC, PACCCOD, PCOA, PINDLOOK, RERROR)
# Rend le compte demandé (PINDLOOK) pour le code comptable passé en paramètre
# ------------------------------------------------------------------------------
Value    Integer PTPCODGAC    : # Type de code comptable à consulter (ML602)
Value    Char    PACCCOD      : # Code comptable à consulter
Value    Char    PCOA         : # Plan de comptes
Value    Integer PINDLOOK     : # Indice sur lequel porte la recherche dans les codes comptables
Variable Integer RERROR       : # 0=Tout c'est bien passé -1=Erreur et LCOMPTE est vide

Local Char LCOMPTE

  If clalev([F:CAC])=0    : Local File GACCCODE   [CAC] : Endif

  Read [CAC]CAC0=PTPCODGAC;PACCCOD;PCOA
  If fstat Then
    RERROR  = -1
    LCOMPTE = ""
  Else
    RERROR  = 0
    LCOMPTE = [F:CAC]ACC(PINDLOOK)
  Endif
End LCOMPTE

################################################################################
Funprog GET_GACACN_FROM_GAC (PGAC,PCOA)
# Rend la nature de compte à partir du compte PCG. Rend 0 si erreur
# ------------------------------------------------------------------------------
Value Char    PGAC              : # Compte PCG à traiter
Value Char    PCOA              : # Plan de comptes

Local Integer LGACACN

 If clalev([F:GAC])=0    : Local File GACCOUNT   [GAC] : Endif

If 1=0
  Filter [GAC] Where ACC=PGAC
  Read [GAC]GAC0 First
  Filter [GAC]
  If fstat>0 Then
    LGACACN = 0
  Else
    LGACACN = [F:GAC]GACACN
  Endif
Endif

 Read [F:GAC]GAC0=PCOA;PGAC
 If fstat
  LGACACN = 0
 Else
  LGACACN = [F:GAC]GACACN
 Endif

End LGACACN

################################################################################
Subprog GET_GAC_IAS_FROM_GACCODE (PTPCODGAC, PACCCOD, PINDGAC, PINDIAS, RGACACN, RGAC, RIASACN, RIASACC)
Value    Integer PTPCODGAC    : # Type de code comptable à consulter (ML602)
Value    Char    PACCCOD      : # Code comptable à consulter
Value    Integer PINDGAC      : # Indice sur lequel porte la recherche dans les codes comptables PCG
Value    Integer PINDIAS      : # Indice sur lequel porte la recherche dans les codes comptables IAS
Variable Integer RGACACN      : # Nature PCG
Variable Char    RGAC         : # Compte PGC
Variable Integer RIASACN      : # Nature IAS
Variable Char    RIASACC      : # Compte IAS

Local Integer LERROR

  RGACACN     = 0
  RGAC        = ""
  If PINDGAC <> -1 Then
    RGAC      = func GLOBIENS.GET_GAC_FROM_GACCCODE (PTPCODGAC, PACCCOD, GFASLEDSOC,PINDGAC, LERROR)
    If LERROR = 0 Then
      RGACACN = func GLOBIENS.GET_GACACN_FROM_GAC (RGAC, GFASLEDSOC)
      If RGACACN = 0 Then
        RGAC  = ""
      Endif
    Endif
  Endif

  RIASACN     = 0
  RIASACC     = ""
  If PINDIAS <> -1 Then
    RIASACC   = func GLOBIENS.GET_GAC_FROM_GACCCODE (PTPCODGAC, PACCCOD, GFASLEDIAS,PINDIAS, LERROR)
    If LERROR = 0 Then
      RIASACN = func GLOBIENS.GET_GACACN_FROM_GAC (RIASACC, GFASLEDIAS)
      If RIASACN = 0 Then
        RIASAC = ""
      Endif
    Endif
  Endif
End

################################################################################
Funprog GET_LVATYP_FROM_GAC (PGAC,PCOA)
# FQ67615 : Rend le type LVA du compte 0 si erreur ; 1= Aucun 2= LVA 3= POOL
# ------------------------------------------------------------------------------
Value Char    PGAC              : # Compte PCG à traiter
Value Char    PCOA              : # Plan de comptes

Local Integer L_LVATYP

 If clalev([F:GAC])=0    : Local File GACCOUNT   [GAC] : Endif

 Read [F:GAC]GAC0=PCOA;PGAC
 If fstat
  L_LVATYP = 0
 Else
  L_LVATYP = [F:GAC]LVATYP
 Endif

End L_LVATYP
################################################################################
Subprog GET_LVATYP_FROM_GACCODE (PTPCODGAC, PACCCOD, PINDGAC, RPCGLVATYP)
# FQ67615 : Rend le type LVA du compte PCG
Value    Integer PTPCODGAC    : # Type de code comptable à consulter (ML602)
Value    Char    PACCCOD      : # Code comptable à consulter
Value    Integer PINDGAC      : # Indice sur lequel porte la recherche dans les codes comptables PCG
Variable Integer RPCGLVATYP   : # LVA Type PCG

Local Integer LERROR

  Local Char L_GAC         : # Compte PGC
  RPCGLVATYP     = 0
  If PINDGAC <> -1 Then
    L_GAC  = func GLOBIENS.GET_GAC_FROM_GACCCODE (PTPCODGAC, PACCCOD, GFASLEDSOC, PINDGAC, LERROR)
    If LERROR = 0 Then
      RPCGLVATYP = func GLOBIENS.GET_LVATYP_FROM_GAC (L_GAC, GFASLEDSOC)
    Endif
  Endif
  If (RPCGLVATYP = 0) Then : RPCGLVATYP = GVML_GLVAAUC : Endif
End

################################################################################
Subprog GET_FAS_ENTRY_LEVEL (PFIYSTRC, PFIYENDC, PFIYENDS, PAASIPTDAT, PSTRDPRDAT, PDPRCUM, PDPRCUMFLG, RETRLVL)
# FQ67615 : Rend le niveau d'entrée d'un bien
Value    Date    PFIYSTRC     : # Début exercice courant fiscal et comptable
Value    Date    PFIYENDC     : # Fin exercice courant fiscal et comptable
Value    Date    PFIYENDS     : # Fin exercice suivant fiscal et comptable
Value    Date    PAASIPTDAT   : # Date d'imputation comptable
Value    Date    PSTRDPRDAT   : # Début d'amortissement plan comptable
Value    Decimal PDPRCUM      : # Cumul E-1 plan comptable
Value    Integer PDPRCUMFLG   : # Indicateur de forçage du Cumul E-1 plan comptable

Variable Integer RETRLVL      : # -1 Antérieur à l'exercice
                                #  0 Exercice courant
                                # +1 Exercice suivant
                                #  2 Exercice ultérieur
  If ( PAASIPTDAT < PFIYSTRC ) Then
    RETRLVL = -1
  Else
    If ( PSTRDPRDAT < PFIYSTRC ) Then
      If ( PDPRCUMFLG = G_OUI and PDPRCUM = 0 ) Then
        RETRLVL = 0
      Else
        RETRLVL = -1
      Endif
    Elsif( PSTRDPRDAT < PFIYENDC ) Then
      RETRLVL = 0
    Elsif( PSTRDPRDAT < PFIYENDS ) Then
      RETRLVL = 1
    Else
      RETRLVL = 2
    Endif
  Endif
End

################################################################################
# FQ38032 : contrôle générique de l'autorisation société / site / regroupement
Subprog CTRL_AUT_OBJ(POBJ, PCLE, PCLE_SUPP, PFCY, PDAT)
Value Char POBJ      : # Type d'objet
Value Char PCLE      : # Clé de l'objet
Value Char PCLE_SUPP : # Clé secondaire de l'objet (axes analytiques)
Value Char PFCY      : # Site
#Value Char PDAT      : # Date à contrôler : # FQ38093
Value Date PDAT      : # Date à contrôler

Local Char    OBJ_FCY    : # champs Société/Site/Regroupement de l'objet
Local Date    OBJ_VLYSTR : # champs Date début validité de l'objet
Local Date    OBJ_VLYEND : # champs Date fin  validité de l'objet
Local Char    OBJ_ACS    : # champs Code d'accès de l'objet

  Case POBJ
   When "GAC"
    If clalev([F:GAC])=0 : Local File =GTABCPT+"GACCOUNT" [GAC] : Endif
    # FQ95579 ajout de PCLE_SUPP
    Call LECTURE("GAC", PCLE, PCLE_SUPP) From CONTOBJ
    OBJ_FCY    = [F:GAC]FCY
    OBJ_VLYSTR = [F:GAC]VLYSTR
    OBJ_VLYEND = [F:GAC]VLYEND
    OBJ_ACS    = [F:GAC]ACS

    # FQ95579 Compte actif
    If [F:GAC]ENAFLG <> G_OUI
#      RMESSAGE = WMES1 - mess(00006, 103, 1)
      GMESSAGE = mess(00006, 103, 1)
      mkstat = 2
      End
    Endif
   When "CCE"
    If clalev([F:CCE])=0 : Local File =GTABCPT+"CACCE"    [CCE] : Endif
    Call LECTURE("CCE",PCLE,PCLE_SUPP) From CONTOBJ
    OBJ_FCY    = [F:CCE]FCY
    OBJ_VLYSTR = [F:CCE]VLYSTR
    OBJ_VLYEND = [F:CCE]VLYEND
    OBJ_ACS    = [F:CCE]ACS
   When "DSP"
    If clalev([F:DSP])=0 : Local File =GTABCPT+"CADSP"    [DSP] : Endif
    # FQ95579 ajout de PCLE_SUPP
    Call LECTURE("DSP", PCLE, PCLE_SUPP) From CONTOBJ
    OBJ_FCY    = [F:DSP]FCY
    OBJ_VLYSTR = [F:DSP]VLYSTR
    OBJ_VLYEND = [F:DSP]VLYEND
    OBJ_ACS    = [F:DSP]ACS
  Endcase

  # Vérification Société/Site/Regroupement
  # FQ47881 : ajout du "If PFCY..."
  If PFCY <> "" Then
    Call VERIF(OBJ_FCY,PFCY,PCLE) From CFYSUB
    If mkstat : End : Endif
  Endif

  # Vérification des dates
  If PDAT <> [0/0/0] Then
    Call CTLVLYDAT(PDAT,OBJ_VLYSTR,OBJ_VLYEND) From CPTSUB
    If mkstat : GMESSAGE = PCLE-GMESSAGE : End : Endif
  Endif

  # Vérification code acces
  Call CONTEXE(OBJ_ACS) From CPTSUB
  If mkstat : GMESSAGE = PCLE-GMESSAGE : End : Endif


  #--- unauthorized code Control
#  If POBJ = "GAC"
#  If [F:GAC]AUZ <> ""
#      If !clalev([F:CAZ])
#          Local File =GTABCPT + "CAAUZ" [CAZ]
#      Endif
#
#      Look [CAZ]CAZ0 = 3 ; [F:GAC]AUZ ; ""
#      If fstat = 0
#          RMESSAGE = WMES1 - mess(1, 2647, 1)
#          End 0
#      Endif
#  Endif
#  Endif

End



