#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
    When "OUVRE" : Gosub OUVRE
    When "DEBUT" : Gosub DEBUT
    When "OK"    : Gosub OK
Endcase
Return

$OUVRE
Local Char LMABR
LMABR = "[M:"+PARAM(1)+"]"
Return

$DEBUT
    Case LMABR
        When "[M:TVM1]" : 
            [M:TVM] = [M:TVM1]
            Call TEXTE(18740,[M:TVM]W) From OBJDIV
            [M:TVM]W -= "1"
        When "[M:TVM2]" : [M:TVM] = [M:TVM2]
            Call TEXTE(18740,[M:TVM]W) From OBJDIV
            [M:TVM]W -= "2"
    Endcase
Affzo [M:TVM]
Return

$OK
    Case LMABR
        When "[M:TVM1]" : [M:TVM1] = [M:TVM]
        When "[M:TVM2]" : [M:TVM2] = [M:TVM]
    Endcase
    mkstat = 4
Return


# Gestion du masque ZCCTVM

######################################################################################
Subprog AS_ISSVLTCOD(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,263,1))
    If func SUBTVM.AUZVLT(I,2,0,0,"")=0
        GMENLOC(I)=1
    Endif
Next
End

######################################################################################
Subprog AS_ISSVLT2(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,263,1))
    If func SUBTVM.AUZVLT(I,2,1,0,"")=0
        GMENLOC(I)=1
    Endif
Next
End

