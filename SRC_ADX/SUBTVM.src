######################################################################################
Subprog C_PRIREG(VALEUR)
Variable Integer VALEUR
# si entrée au PMP,Pmlot ou dernier prix sans régul
If find([M:TVM]RCPVLTCOD,3) & VALEUR < 2
   GERR = 2
   GMESSAGE = mess(496,196,1) # "régularisation préconisée..."
Endif
End

######################################################################################
Subprog APRES_NBLIG
[M]CONCATKEY(nolign-1) = num$([M]MVTTYP(nolign-1)) + [M]TRSCOD(nolign-1)
End

######################################################################################
Subprog AS_MVTTYP(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,704,1))
    # CCC (12/08/08) Bug 48471 : on autorise de choisir "Inter-site" pour le cas de l'inter-société
    If !find(func STKLIB.SENSTRS(I),1,-2) & I<>14 | I=28
        GMENLOC(I) = 1
    Endif
Next
End

######################################################################################
Subprog C_TRSCOD(VALEUR)
Variable Char    VALEUR()
Local Char CONC
# Controle d'unicité
CONC = num$([M:TVM]MVTTYP(nolign-1)) + VALEUR
Call UNICITE(CONC,[M:TVM]CONCATKEY(0..[M:TVM]NBLIG-1)) From OBJDIV
If mkstat = 2 : End : Endif 
End

######################################################################################
Subprog AS_MVTVLT(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,263,1))
    If func SUBTVM.AUZVLT(I,1,0,[M:TVM]MVTTYP(nolign-1),"")=0
        GMENLOC(I)=1
