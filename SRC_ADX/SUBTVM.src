######################################################################################
#Paramètres E: PVLT    : méthode à tester
#              PIO     : 1 = Entrée (ou écart positif)
#                        2 = Sortie (ou écart négatif)
#              PVLT2   : Valeur de repli (0=non/1=oui)
#              PTRSTYP : Type de mouvement (exception) ou 13=inventaire
#              PSUP    : Option (non utilisé pour l'instant)
######################################################################################
Funprog AUZVLT(PVLT,PIO,PVLT2,PTRSTYP,PSUP)
Value Integer PVLT
Value Integer PIO
Value Integer PVLT2
Value Integer PTRSTYP
Value Char    PSUP

Local Integer LRET

Case PVLT
    When 1 : # standard
        LRET = 1

    When 2 : # standard actualisé
        LRET = 1

    When 3 : # dernier prix
        # La méthode de dernier prix d'entrée prend la valeur
        # du dernier prix d'achat pour les documents de réception
        If PIO=1&PVLT2=0&PTRSTYP=0 | PTRSTYP = 12 & PVLT2=0   # CCC (03/03/04) : 12 --> suite à demande de CH
            LRET = 0
        Else
            LRET = 1
        Endif

    When 4 : # PMP
        If PIO = 1 & PVLT2=0 & PTRSTYP=0
            LRET = 0
        Else
            LRET = 1
        Endif

    When 5,8 : # FIFO
        If PIO=1
            LRET = 0
        Else
            LRET = 1
        Endif

    When 6 : # PM Lot
        If PIO = 1 & PVLT2=0 & PTRSTYP=0
            LRET = 0
        Else
            LRET = 1
        Endif

    When 7 : # Prix ordre
        # DM 27187 : Même pour la valo de repli afin de pouvoir forcer le prix nul
        If PIO<>1 | PTRSTYP=13
            LRET = 0
        Else
            LRET = 1
        Endif
    When 9 : # Dernier prix d'achat
        # Autorisée uniquement en valeur de repli des entrées et écart positif d'inventaire
        If PIO=1 & PVLT2=1
&        | PIO=1 & PTRSTYP<>0
            LRET=1
        Else
            LRET = 0
        Endif
Endcase

End LRET

######################################################################################
## Etiquette ajoutée par le superviseur (écran TVM) 13/01/2011 11:02:19 (CCC)
######################################################################################
Subprog C_RCPVLT2(VALEUR)
Variable Integer VALEUR
Local Integer I
If find([M:TVM]RCPVLTCOD,1,2) & VALEUR<>[M:TVM]RCPVLTCOD
    GERR=1
    GMESSAGE=mess(378,184,1)
    I=instr(1,GMESSAGE,'%1')
    GMESSAGE = left$(GMESSAGE,I-1)+mess([M:TVM]RCPVLTCOD,263,1)+right$(GMESSAGE,I+2)
Endif
End


######################################################################################
Subprog C_MVTVLT2(VALEUR)
Variable Integer VALEUR
If find([M:TVM]MVTVLT(nolign-1),1,2) & VALEUR<>[M:TVM]MVTVLT(nolign-1)
    GERR=1
    GMESSAGE=mess(378,184,1)
    I=instr(1,GMESSAGE,'%1')
    GMESSAGE = left$(GMESSAGE,I-1)+mess([M:TVM]MVTVLT(nolign-1),263,1)+right$(GMESSAGE,I+2)
Endif
End


