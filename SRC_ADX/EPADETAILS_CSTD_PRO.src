#FRLAA - 2016-12-06 - REQUIREMENT X3-11647 US X3-12771 - START
$PROPERTIES
Case [L]CURPRO
  When "EPABAL"       Gosub EPADETAILS_EPABAL
Endcase
Return

$EPADETAILS_EPABAL
Case [L]ARULE
  When "CONTROL"
    Gosub EPADETAILS_EPABAL_CONTROL
  When "PROPAGATE"
Endcase
Return


$EPADETAILS_EPABAL_CONTROL
#Hybrid development - the control is shared with a method called from V6 code
#PVALEUR and PMTHINS are parameters from V6 - mimic V6 variable here to use one method
Local Decimal PVALEUR, PMTHINS
Local Integer PBALFLG

PVALEUR   = this.EPABAL
PMTHINS   = this.MTHINS
PBALFLG   = this.BALFLG
Local Integer ARETVALUECLASS
Local Integer ARET_VALUE

Gosub BALCONTROL From EPADETAILS_CSTD_MPU
#Test the status from the Method
If [L]ARETVALUECLASS = 2
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00005,11662,1),[V]CST_AERROR) # Amount may not be negative
Elsif [L]ARETVALUECLASS = 3
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00009,10661,1),[V]CST_AERROR) # Balance may not be less than the installment
Endif
Return

#FRLAA - 2016-12-06 - REQUIREMENT X3-11647 US X3-12771 - END

