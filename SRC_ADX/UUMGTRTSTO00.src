#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# UUMGTRTSTO00                                              Module Stocks  #
# Outils pour les moulinettes de migrations                                #
############################################################################
# OUVRE_STO : Charge les types d'alternatives dans WBOMALTTYP(1..99)
############################################################################

###################################
$OUVRE_STO
# Déclaration des variables communes de travail
Local Integer COMPTEUR, I, J

#déclaration des variables locales de travail
Local Integer WJ, WI
Local Integer ERR

Return

$INIT_TBO
# Chargement des types d'alternatives dans un tableau
Local File =[F:ADS]DOSSIER+".TABBOMALT"   [TBO]
Local Integer WBOMALTTYP(1..99)
For [TBO]
    WBOMALTTYP([F:TBO]BOMALT)=[F:TBO]BOMALTTYP
Next
Return

$INIT_FIY
# Chargement des dates d'exercices dans un tableau
Local Integer WNBEXE, WNBCPY

Local Integer WINDSTR,WINDEND
Local Char    WCPY(GLONCPY)
Local Integer WYEA

Local File =[F:ADS]DOSSIER+".FISCALYEAR"   [FIY]
Local File =[F:ADS]DOSSIER+".COMPANY"      [CPY]
If dim([FIY]LEDTYP)>0
    Filter [F:FIY] Where LEDTYP=1
    WNBEXE = rowcount([F:FIY])
    # La fermeture du filtre se fait après le chargement
Else
    WNBEXE = nbrecord([F:FIY])
Endif
WNBCPY = nbrecord([F:CPY])

Local Char    WTABCPY(GLONCPY)(WNBCPY)  # Contient tous les code CPY
Local Integer WINDYEA(WNBCPY,2)         # Indice dans le tableau WTABYEA des années liées au CPY
Local Integer WTABYEA(WNBEXE)           # Contient toutes les années des exercices pour chaque CPY
Local Integer WTABFIY(WNBEXE)           # Contient les n° d'exercices en correspondance avec le n° d'année et CPY
Local Date    WDATEXE(WNBEXE,2)

Raz WJ, WI
For [FIY]FIY0(1)
    WTABCPY(WI) = [F:FIY]CPY
    WINDYEA(WI,0)= WJ
    For [FIY]FIY0
        # Issue 102990 - 2015-03-04 by CCC : take year as it was done in STKVAL up to V5
        #WTABYEA(WJ) = year(addmonth([F:FIY]FIYSTR,6))
        WTABYEA(WJ) = year([F:FIY]FIYEND)
        WTABFIY(WJ) = [F:FIY]FIYNUM
        WDATEXE(WJ,0) = [F:FIY]FIYSTR
        WDATEXE(WJ,1) = [F:FIY]FIYEND
        WJ+=1
    Next
    WINDYEA(WI,1)= WJ-1
    WI+=1
Next
Filter [F:FIY]

For WI=0 To WNBCPY-1
    Call ECRTRACE(WTABCPY(WI)-num$(WINDYEA(WI,0))-num$(WINDYEA(WI,1)),0)
    For WJ=WINDYEA(WI,0) To WINDYEA(WI,1)
        Call ECRTRACE(num$(WTABYEA(WJ))-num$(WDATEXE(WJ,0))-num$(WDATEXE(WJ,1)),0)
    Next
Next

Return

###########################################
$INIT_TUN
Local File =[F:ADS]DOSSIER+".TABUNIT"    [TUN]
Local Integer NBTUN : NBTUN=nbrecord([TUN])
Local Char WTUNUOM(GLONUOM)(0..NBTUN)
Local Integer WTUNUOMDEC(0..NBTUN)
Local Char WTUNUOMOLD(GLONUOM)
Local Integer WJTUN
Raz WJTUN
Raz WJ
For [TUN]
    # Chargement des éléments dans un tableau memoire
    WTUNUOM(WJ)=[F:TUN]UOM
    WTUNUOMDEC(WJ)=[F:TUN]UOMDEC
    WJ+=1
Next
Return
###########################################

Subprog ECRTRACE(PTXT,PERR)
Value Char PTXT
Value Integer PERR

If 0
    Call ECR_TRACE(PTXT,PERR) From GESECRAN
Endif
End
