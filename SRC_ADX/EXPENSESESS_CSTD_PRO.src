$EXPENSESESS_CTRNUM_CONTROL

#V6 has before entry to get contract number if null
#If CONTRACT NUMBER = "" : CALLS ->  Call SELCTR([M:EXS0]REFNUM,[M:EXS0]STRDAT,[M:EXS0]ENDDAT,VALEUR) From DIVPAYE (SEE CODE BELOW)
#TODO
#  - check that contract is valid or exists over the period
#
Local File EMPLOCTR [HRCTR]
#Filter [CTR] Where REFNUM=this.REFNUM & CTRNUM=this.CTRNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT)) & (XITDAT>=this.STRDAT | XITDAT=[0/0/0])
# SOA - changed the above to filter by descending contract date
Filter [HRCTR] Where REFNUM=this.REFNUM & CTRNUM=this.CTRNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT)) & (XITDAT>=this.STRDAT | XITDAT=[0/0/0]) Order By CTRDAT Desc
#Read [CTR]CTR0 First  #having issue with CTR0
Read [HRCTR] First
Filter [HRCTR]
If fstat <> [V]CST_AOK
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(25,10718,1),[V]CST_AERROR)
Endif
LogicClose File [HRCTR]

Gosub CHECK_SUBORDINATE
Return

$CHECK_SUBORDINATE
If this.REFNUM = AVOID.ACHAR
  Return
Endif

If this.STRDAT = AVOID.ADATE
  Return
Endif

If this.ENDDAT = AVOID.ADATE
  Return
Endif

Local File EMPLOCTR [HRCTR4]

If this.CTRNUM = AVOID.ACHAR
  Filter [HRCTR4] Where REFNUM=this.REFNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT))
&           & (XITDAT=[0/0/0] | XITDAT>=this.STRDAT) Order By CTRDAT Desc
Else
  Filter [HRCTR4] Where REFNUM=this.REFNUM & CTRNUM=this.CTRNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT))
&           & (XITDAT=[0/0/0] | XITDAT>=this.STRDAT) Order By CTRDAT Desc
Endif
Read [HRCTR4] First
If fstat = [V]CST_AOK
  #After setting the Contract, check that the logged in user can log a request for the employee
  Local File EMPSBD [ESB1]
  If this.TCH_EMPSBD <> AVOID.ACHAR
    #Subordinate selected - Only available on Manager ESS
    Local Integer FOUND_CHEF
    Filter [F:ESB1] Where REFNUM = [F:HRCTR4]REFNUM and CTRNUM = [F:HRCTR4]CTRNUM and CTRDAT = [F:HRCTR4]CTRDAT
    For [ESB1]
      If [F:ESB1]CHEF = fmet this.ACTX.ACACHE.USRESS.AGETVALCHAR(this.ACTX.USER,"REFNUM")
        FOUND_CHEF = 1
        Break
      Endif
    Next
    If FOUND_CHEF <> 1
      ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00192,10702,1),[V]CST_AERROR)
    Endif
  Endif
  Filter [F:ESB1]
  LogicClose File [ESB1]
Endif

Filter [F:HRCTR4]
LogicClose File [HRCTR4]
Return

#---------------------------
$EXPENSESESS_CTRNUM_PROPAGATE

# - call DIETYP and set some screen variables
#Gosub DIE_TYP # TODO - wait for Damian to add this code

# ???? check against sub
Local Integer FUNC_STA #FRLAA X3-53638 2017-08-25
Local File EMPLOCTR [HRCTR]

#Filter [CTR] Where REFNUM=this.REFNUM & CTRNUM=this.CTRNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT)) & (XITDAT>=this.STRDAT | XITDAT=[0/0/0])
# SOA - changed the above to filter by descending contract date #????#
Filter [HRCTR] Where REFNUM=this.REFNUM & CTRNUM=this.CTRNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT)) & (XITDAT>=this.STRDAT | XITDAT=[0/0/0]) Order By CTRDAT Desc
#Read [CTR]CTR0 First
Read [HRCTR] First
Filter [HRCTR]
If fstat = [V]CST_AOK
  this.ETRFCY =[F:HRCTR]ETRFCY
  this.ETRSRV =[F:HRCTR]ETRSRV
  this.CTRDAT =[F:HRCTR]CTRDAT
  this.LEG = func DIVPAYE_SOA.GET_LEG_FCY([F:HRCTR]ETRFCY, 1)
  FUNC_STA = func DIVPAYE_SOA.SET_CACHED_LEG(this.ACTX.USER, this.LEG) #FRLAA X3-53638 2017-08-25
  If maxtab(this.HEADIM) = 0
    Call DIE_TYP(this)
  Endif
  #Gosub DIE_TYP  #???? Damian's code

  #???? should we update all FCY on EXPENSES from here
  Gosub UPDATE_EXPENSES_FCY From HREXPENSES_CSTD_PRO

Endif
LogicClose File [HRCTR]

#Affzo [EXS0] ETRFCY, ETRSRV

Return



############################################################################################################
Subprog CCEMSK(FIC,ECR,NOL,CEXP)
Value Char     FIC(), ECR()
Value Shortint NOL
Variable Instance CEXP Using C_EXPENSESESS
Local Integer SOA_GOPTCANA : Call GOPTCANA(SOA_GOPTCANA) From ESSGLOB_SOA

If SOA_GOPTCANA = [V]CST_AOK : End : Endif

If NOL=0: Call DIE_TYP(CEXP): Endif

End
############################################################################################################
Subprog DIE_TYP(CEXP)
Variable Instance CEXP Using C_EXPENSESESS
#Dbgaff
If CEXP.REFNUM = AVOID.ACHAR : Return : Endif

If maxtab(CEXP.HEADIM)= 0
  For NK=1 To 20
    K = fmet CEXP.ADDLINE("HEADIM",NK)
  Next
Endif

Local Char SOA_GTABCPT(80) : Call GTABCPT(SOA_GTABCPT) From ESSGLOB_SOA
Local Integer I,J,NK

If !clalev([F:FCY]) : Local File FACILITY [FCY]                : Endif
If !clalev([F:CPY]) : Local File COMPANY [CPY]                 : Endif
If !clalev([F:AXXX]): Local File =SOA_GTABCPT+"ATEXTRA" [AXXX] : Endif
If !clalev([F:CTRX]): Local File EMPLOCTR [CTRX]               : Endif
Raz [F:FCY], [F:CPY]

For NK = 1 To maxtab(CEXP.HEADIM)
  CEXP.HEADIM(NK).DIETYP = AVOID.ACHAR
  CEXP.HEADIM(NK).INTDIE = AVOID.ACHAR
  CEXP.HEADIM(NK).FMTDIE = AVOID.ACHAR
Next

Filter [CTRX] Where REFNUM=CEXP.REFNUM  & (CTRDAT<=CEXP.ENDDAT | (FLGRET=2 & RETDATEFF<=CEXP.ENDDAT))
&                & (XITDAT=[0/0/0] | XITDAT>=CEXP.STRDAT)
&     Order By Key CLE=ETRFCY

For [CTRX]CLE
  If [F:CTRX]ETRFCY<>[F:FCY]FCY
    Call LEC_FCY([F:CTRX]ETRFCY) From CPTLEC_SOA
    If [F:FCY]LEGCPY<>[F:CPY]CPY
      Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC_SOA
      For I=0 To 19
      If [F:CPY]DIE(I)="" or I=dim([F:CPY]DIE): Break: Endif
        For J=1 To 20
          If [F:CPY]DIE(I)=CEXP.HEADIM(J).DIETYP : Break : Endif
            If CEXP.HEADIM(J).DIETYP = AVOID.ACHAR
              CEXP.HEADIM(J).DIETYP = [F:CPY]DIE(I)
              Read [F:AXXX]AXX0="GDIE";"SHOTRA";GACTX.LAN;CEXP.HEADIM(J).DIETYP
              If !fstat
                CEXP.HEADIM(J).INTDIE = [F:AXXX]TEXTE
              Endif
              Break
          Endif
        Next J
      Next I
    Endif
  Endif
Next

For I=1 To 20
  If CEXP.HEADIM(I).DIETYP = AVOID.ACHAR
    ASTATUS = fmet CEXP.ASETATTRIBUTE("CEXP.HEADIM(" + num$(I) + ").FMTDIE", "$isHidden", "true")
  Else
    ASTATUS = fmet CEXP.ASETATTRIBUTE("CEXP.HEADIM(" + num$(I) + ").FMTDIE", "$isHidden", "false")
  Endif
Next

LogicClose File [CTRX]
End

############################################################################################################

