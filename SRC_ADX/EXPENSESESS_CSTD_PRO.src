$EXPENSESESS_REFNUM_PROPAGATE

#  If only 1 contract allowed (i.e. [F:ID]FLGMULCTR<>2) then get contract/disable contract field
#  If multiple contracts allowed then make contract field enterable
#  If employee id is not same as current (snapshot) employee id, then get name for screen display
#  Create new routine: DIVPAYE_SOA for label below
#  Call CHERCHE_CTRPER(VALEUR,[M:EXS0]STRDAT,[M:EXS0]ENDDAT,[M:EXS0]CTRNUM) From DIVPAYE
#

Local File EMPLOID [ID]
Read [ID]ID0=this.REFNUM
If fstat <> [V]CST_AOK
  #ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(170,720,1),[V]CST_AERROR)
  LogicClose File [ID]
  Return
Else
  this.TCH_NAMSRN = toupper([F:ID]NAM)-tolower([F:ID]SRN)
  #this.TCH_SBDSRN = toupper([F:ID]NAM)-tolower([F:ID]SRN)
Endif
If [F:ID]FLGMULCTR<>2
 # get contract number
 Local Date CTRDAT
 Call CHERCHE_CTRPER(this.REFNUM,this.STRDAT,this.ENDDAT,this.CTRNUM,this.CTRDAT) From DIVPAYE_SOA
 #???? should we update all FCY on EXPENSES from here
Else
Endif
LogicClose File [ID]

Return
############################################################################################################
$EXPENSESESS_TCH_EMPSBD
Case [L]ARULE
  When "INIT"
    Gosub EXPENSESESS_TCH_EMPSBD_INIT
  When "CONTROL"
