$EXPENSESESS_ENDDAT_INIT
If this.ENDDAT = AVOID.ADATE
  this.ENDDAT = date$
Endif
Return
#---------------------------
$EXPENSESESS_ENDDAT_CONTROL

#TODO
#
# - ADD To CONTROL - If ENDDAT <> [0/0/0] and ENDDAT < STRDAT - ERROR MESSAGE
#  Loop through each line in grid/class - if DATEXS <> [00/00/00] then make sure that date on line is within date range
#  If only 1 contract allowed (no contract found):
#  - make sure that employee has a contract for this end date and start date
#
#If DATFIN<>[0/0/0] & DATFIN<DATDEB
 ##GMESSAGE = mess(1,104,1) # FGR 27/08/2015 : X3SUIVI110593
 #GMESSAGE = mess(1,104,1) - ":" - format$("D:"+GFMDAT4,DATFIN) - "<" - format$("D:"+GFMDAT4,DATDEB) # FGR 27/08/2015 : X3SUIVI110593
 #mkstat = 2
# Date incorrecte
#Endif
Local Char ERR_MSG(250)
Local Char SOA_GFMDAT4(20) : SOA_GFMDAT4 = "DD[/]MM[/]YYYY"
If this.ENDDAT <> [0/0/0] & this.ENDDAT < this.STRDAT
  ERR_MSG = mess(1,104,1) - ":" - format$("D:"+SOA_GFMDAT4,this.ENDDAT) - "<" - format$("D:"+SOA_GFMDAT4,this.STRDAT)
  ASTATUS=fmet this.ASETERROR([L]CURPRO,ERR_MSG,[V]CST_AERROR)
  Return
Endif

# decide whether this code should be called here or after user creates/saves
Local File EMPLOCTR [HRCTR]
Local File EMPLOID  [ID]

Local Char ERR_MSG(250)
Local Integer MAXL, NI
MAXL = maxtab(this.HREXPENSES)
For NI = 1 To MAXL
  If this.HREXPENSES(NI) <> null and find(this.HREXPENSES(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
    If this.HREXPENSES(NI).DATEXS>[0/0/0] & (this.HREXPENSES(NI).DATEXS>this.ENDDAT | this.HREXPENSES(NI).DATEXS<this.STRDAT)
      [L]ERR_MSG=mess(3,10718,1)-"("+mess(61,100,1)-num$(NI)+")"
      ASTATUS=fmet this.ASETERROR([L]CURPRO,[L]ERR_MSG,[V]CST_AERROR)
      Break
    Endif
  Endif
Next NI

If ASTATUS = [V]CST_AERROR
  LogicClose File [HRCTR]
  LogicClose File [ID]
  Return
Endif

Read [ID]ID0=this.REFNUM
If fstat <> [V]CST_AOK
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(38,10720,1)-num$(this.ENDDAT),[V]CST_AERROR)
  LogicClose File [HRCTR]
  LogicClose File [ID]
  Return
Endif

If [F:ID]FLGMULCTR<2   #2=multiple contracts open at the same time
  #Filter [CTR] Where REFNUM=this.REFNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT)) & (XITDAT>=this.STRDAT | XITDAT=[0/0/0])
  # SOA - changed the above to filter by descending contract date
  Filter [HRCTR] Where REFNUM=this.REFNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT)) & (XITDAT>=this.STRDAT | XITDAT=[0/0/0]) Order By CTRDAT Desc
  #Read [CTR]CTR0 First
  Read [HRCTR] First
  If fstat <> [V]CST_AOK
    Local Char SOA_GFMDAT4(20) : Call GFMDAT4(SOA_GFMDAT4) From ESSGLOB_SOA
    [L]ERR_MSG=func AFNC.MES2(mess(171,10709,1),format$("D:"+SOA_GFMDAT4,this.STRDAT),format$("D:"+SOA_GFMDAT4,this.ENDDAT))
    ASTATUS=fmet this.ASETERROR([L]CURPRO,[L]ERR_MSG,[V]CST_AERROR)
  Endif
  Filter [HRCTR]
Endif

LogicClose File [HRCTR]
LogicClose File [ID]

Return
#---------------------------
$EXPENSESESS_ENDDAT_PROPAGATE

#  If only 1 contract allowed (contract found):
#  - get contract number and add to screen mask
#  - calls DIETYP - which will propogate dimension fields on the header - Damian to handle this code

Local File EMPLOCTR [HRCTR]
Local File EMPLOID  [ID]

Read [ID]ID0=this.REFNUM
If fstat = [V]CST_AOK & [F:ID]FLGMULCTR<2  #???? Check <2
  #Filter [CTR] Where REFNUM=this.REFNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT)) & (XITDAT>=this.STRDAT | XITDAT=[0/0/0])
  # SOA - changed the above to filter by descending contract date
  Filter [HRCTR] Where REFNUM=this.REFNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT)) & (XITDAT>=this.STRDAT | XITDAT=[0/0/0]) Order By CTRDAT Desc
  #Read [CTR]CTR0 First
  Read [HRCTR] First
  If fstat = [V]CST_AOK
     this.CTRNUM=[F:HRCTR]CTRNUM
     this.CTRDAT=[F:HRCTR]CTRDAT
     #Gosub DIE_TYP #???? wait for Damian's code
     #???? should we update all FCY on EXPENSES from here
     Gosub UPDATE_EXPENSES_FCY From HREXPENSES_CSTD_PRO
  Endif
  Filter [HRCTR]
Endif

#Call CCEMSK("EXS","EXS0",maxtab(this.HREXPENSES),this) From EXPENSESESS_CSTD_EVT
Call CCEMSK("EXS","EXS0",maxtab(this.HREXPENSES),this)

LogicClose File [HRCTR]
LogicClose File [ID]

Return
