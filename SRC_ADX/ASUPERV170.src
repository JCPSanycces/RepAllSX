                        Break
                    Endif
                Endif
            Next W_INDICE
        Endif
    Endif


    #---------------------------------------------
    # mise a jour geode v7 
    If GFOLDER_V170(2) <> ""
        # lecture dans le fichier XYX code langue FRA
        # recherche du texte correspond 
        # dans geode ne porte pas le même numéro obligatoirement
        # attention test aussi de la zone commentaire en FRA 
        Raz WTAB_NUM
        W_INDICE  =0

        Filter [XYX] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
        WTAB_INDICE = 0
        For [XYX]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XYX]NUMERO
        Next
        Filter [XYX]
        If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur geode on sort
