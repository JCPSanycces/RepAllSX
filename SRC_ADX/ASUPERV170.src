#<AdxTL>@(#)5.0.0.0 $Revision$
##################################################################################################
#  traduction ATEXTE : mise a jour des différents produits pour la V7
#  utilise par INDUS
##################################################################################################
End

#--------------------------------------------#
# mise a jour table du superviseur
#--------------------------------------------#
$MAJSUPER_170
Local Integer WTAB_NUM (1..100)
Local Integer WTAB_INDICE

Local Integer W_INDICE


#---------------------------------
# en premier 
# il faut ici mettre à jour le produit en v5 X3 X3IND160
# il faudra aussi mettre a jour PAYIND160 car depuis v7 :  paie et x3 sont dans meme dossier
# et ensuite on regarde pour la v170
# ----------------------------------------


If GPRODUIT = 0
    #---------------------------------------------
    # mise a jour X3IND160
    # lecture dans le fichier XUZ code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
    # attention test aussi de la zone commentaire en FRA 
    # mise a jour de atexte de la version 160 pour x3 code XUZ X3IND160


    Raz WTAB_NUM
    W_INDICE  =0

    Filter [XUZ] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
    WTAB_INDICE = 0
    For [XUZ]
        WTAB_INDICE +=1
        WTAB_NUM (WTAB_INDICE)= [F:XUZ]NUMERO
    Next
    Filter [XUZ]
    If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur X3IND160
        #Return
    Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XUZ]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
           If [F:XUZ]COMMENT = WTEXTE_COMMENT
                Gosub X3IND160_TEXTE From ATRADTEX
           Endif
        Endif
    Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XUZ]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XUZ]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub X3IND160_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
    Endif

    #---------------------------------------------
    # mise a jour PAIEIND160
    #  à faire Gosub PAIEIND160_TEXTE
    #  ne porte pas le même numéro 
    #  on le fait ici car dans le trt ASUPERV160 c'est fait aussi
    #  mais uniquement dans le cas d'un texte supervisuer
    # il faut aussi le faire sur un texte paye uniquement
    #---------------------------------------------
    Raz WTAB_NUM
    W_INDICE  =0

    Filter [XUP] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
    WTAB_INDICE = 0
    For [XUP]
        WTAB_INDICE +=1
        WTAB_NUM (WTAB_INDICE)= [F:XUP]NUMERO
    Next
    Filter [XUP]
    If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur paiev6
        #Return
    Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XUP]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
           If [F:XUP]COMMENT = WTEXTE_COMMENT
                Gosub PAYIND160_TEXTE From ATRADTEX
           Endif
        Endif
    Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XUP]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XUP]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub PAYIND160_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
    Endif

Endif

If GPRODUIT = 1
    #---------------------------------------------
    # mise a jour GEOIND160
    # lecture dans le fichier Xxxxx code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
    # attention test aussi de la zone commentaire en FRA 
    # mise a jour de atexte de la version 160 pour code XxxxX GEOIND160
Endif

If GPRODUIT = 2
    #---------------------------------------------
    # mise a jour PAYIND160
    # lecture dans le fichier XUP code langue FRA
    # recherche du texte correspond  normalement c'est le même numéro
    # attention test aussi de la zone commentaire en FRA 
    Raz WTAB_NUM
    W_INDICE  =0

    Filter [XUP] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
    WTAB_INDICE = 0
    For [XUP]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XUP]NUMERO
    Next
    Filter [XUP]
    If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur paye on sort
            Return
    Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XUP]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XUP]COMMENT = WTEXTE_COMMENT
                    Gosub PAYIND160_TEXTE From ATRADTEX
               Endif
            Endif
    Else
            # +sieurs textes correspondant on regarde le commentaire
            # pour faire le choix 
            For W_INDICE = 1 To WTAB_INDICE
                Read [XUP]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XUP]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub PAYIND160_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
    Endif

Endif

If GPRODUIT = 3
    # n'existe plus en V6
    # abelx3 est dans X3......... depuis la v6
Endif





#--------------------------------------------#
# mise a jour ATEXTE de SUPERV170
# lecture dans le fichier XYS code langue FRA
# recherche du texte correspond 
# dans superv170 ne porte pas le même numéro obligatoirement
# attention test aussi de la zone commentaire en FRA 
#--------------------------------------------#

Raz WTAB_NUM
W_INDICE  =0

Filter [XYS] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
WTAB_INDICE = 0
For [XYS]
    WTAB_INDICE +=1
    WTAB_NUM (WTAB_INDICE)= [F:XYS]NUMERO
Next
Filter [XYS]


If WTAB_INDICE = 0 
        # on n'a pas trouvé l'equivalent sur superv170 on sort
        # on ne cherche meme pas a mettre a jour abelx3 ou x3 ou geode
        Return
Elsif WTAB_INDICE = 1
        # un seul texte correspond
        # lecture dans la langue de trad
        # on enregistre le texte dans la langue de traduction
        W_INDICE = 1
        Read [XYS]NUMERO = GFRA; WTAB_NUM (W_INDICE)
        If fstat = 0
             If [F:XYS]COMMENT = WTEXTE_COMMENT
                    Gosub SUPERV170_TEXTE From ATRADTEX
                Endif
        Endif
Else
        # +sieurs textes correspondant on regarde le commentaire
        # pour faire le choix 
        For W_INDICE = 1 To WTAB_INDICE
                Read [XYS]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYS]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub SUPERV170_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
        Next W_INDICE
Endif


#--------------------------------------------#
# on fait idem si on est sur x3
# mise a jour ATEXTE de geode et de la paye
#--------------------------------------------#

If GPRODUIT = 0
    #---------------------------------------------
    # mise a jour ABELX V7 : jamais plus 
     If GFOLDER_V170(4) <> ""
     Endif
    #---------------------------------------------
    # mise a jour geode v7 
    If GFOLDER_V170(2) <> ""
        # lecture dans le fichier XYX code langue FRA
        # recherche du texte correspond 
        # dans geode ne porte pas le même numéro obligatoirement
        # attention test aussi de la zone commentaire en FRA 
        Raz WTAB_NUM
        W_INDICE  =0

        Filter [XYX] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
        WTAB_INDICE = 0
        For [XYX]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XYX]NUMERO
        Next
        Filter [XYX]
        If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur geode on sort
            Return
        Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XYX]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XYX]COMMENT = WTEXTE_COMMENT
                    Gosub GEOIND170_TEXTE From ATRADTEX
               Endif
            Endif
        Else
            # +sieurs textes correspondant on regarde le commentaire
            # pour faire le choix 
            For W_INDICE = 1 To WTAB_INDICE
                Read [XYX]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYX]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub GEOIND170_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
        Endif
    Endif
    #---------------------------------------------
    # mise a jour paye v7 
    If GFOLDER_V170(3) <> ""
        # lecture dans le fichier XYP code langue FRA
        # recherche du texte correspond 
        # dans geode ne porte pas le même numéro obligatoirement
        # attention test aussi de la zone commentaire en FRA 
        Raz WTAB_NUM
        W_INDICE  =0

        Filter [XYP] Where TEXTE = WTEXTE_FRA  and LAN = GFRA
        WTAB_INDICE = 0
        For [XYP]
            WTAB_INDICE +=1
            WTAB_NUM (WTAB_INDICE)= [F:XYP]NUMERO
        Next
        Filter [XYP]
        If WTAB_INDICE = 0 
            # on n'a pas trouvé l'equivalent sur paye on sort
            Return
        Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XYP]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XYP]COMMENT = WTEXTE_COMMENT
                    Gosub PAYIND170_TEXTE From ATRADTEX
               Endif
            Endif
        Else
            # +sieurs textes correspondant on regarde le commentaire
            # pour faire le choix 
            For W_INDICE = 1 To WTAB_INDICE
                Read [XYP]NUMERO = GFRA; WTAB_NUM (W_INDICE)
                If fstat = 0
                    If [F:XYP]COMMENT = WTEXTE_COMMENT
                        # ok on a trouve le bon texte, on met a jour
                        Gosub PAYIND170_TEXTE From ATRADTEX
                        Break
                    Endif
                Endif
            Next W_INDICE
        Endif

    Endif
Endif

#--------------------------------------------#
# on fait idem si on est sur geodev7
# mise a jour ATEXTE de X3 et la paye
# a faire plus tard
#--------------------------------------------#

If GPRODUIT = 1
Endif

#--------------------------------------------#
# on fait idem si on est sur payev7
# mise a jour ATEXTE de X3  et de geode
#--------------------------------------------#
If GPRODUIT = 2

    #---------------------------------------------
    # mise a jour x3 v7 
