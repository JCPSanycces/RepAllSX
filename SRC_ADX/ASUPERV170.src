        Elsif WTAB_INDICE = 1
            # un seul texte correspond
            # lecture dans la langue de trad
            # on enregistre le texte dans la langue de traduction
            W_INDICE = 1
            Read [XYX]NUMERO = GFRA; WTAB_NUM (W_INDICE)
            If fstat = 0
               If [F:XYX]COMMENT = WTEXTE_COMMENT
