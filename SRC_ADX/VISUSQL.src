#<AdxTL>@(#)5.0.0.0 $Revision$
Close Mask
Local Char PARAM(10)(1..3) , VALEUR(250)
PARAM(1) = GFLAG
PARAM(2) = "1"
PARAM(3) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"ALISTE","SUBALH2","ALISTE",6,"SPEALH") From GTRAITE
End 

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "BOUTON"       : Gosub BOUTON
 When "SETBOUT"      : Gosub SETBOUT
 When "TITRE"        : Gosub TIT
 When "SUI"          : Gosub SUIVANT
 When "PRE"          : Gosub PRECEDENT
 When "FIR"          : Gosub PREMIER
 When "LAS"          : Gosub DERNIER
 When "RAF"          : Gosub RAFFRAICHIR
 When "EDI"          : Gosub LISTE
 When "LIS"          : Gosub IMPRIME
 When "TRN"          : Gosub TRANSAC
 When "END"          : Gosub FIN
 When "TERMINE"      : Gosub SORTIE
 When "SORTIE"       : Gosub SORTIE

 When "AB1_NBLIG" : Local Integer NOBOUT : NOBOUT = 1 : Goto AV_BOUTON
 When "AB2_NBLIG" : Local Integer NOBOUT : NOBOUT = 2 : Goto AV_BOUTON
 When "AB3_NBLIG" : Local Integer NOBOUT : NOBOUT = 3 : Goto AV_BOUTON
 When "AB4_NBLIG" : Local Integer NOBOUT : NOBOUT = 4 : Goto AV_BOUTON
 When "AB5_NBLIG" : Local Integer NOBOUT : NOBOUT = 5 : Goto AV_BOUTON
 When "AB6_NBLIG" : Local Integer NOBOUT : NOBOUT = 6 : Goto AV_BOUTON
 When "AB7_NBLIG" : Local Integer NOBOUT : NOBOUT = 7 : Goto AV_BOUTON
 When "AB8_NBLIG" : Local Integer NOBOUT : NOBOUT = 8 : Goto AV_BOUTON
 When "BB1_NBLIG" : Local Integer NOBOUT : NOBOUT = 1 : Goto AP_BOUTON
 When "BB2_NBLIG" : Local Integer NOBOUT : NOBOUT = 2 : Goto AP_BOUTON
 When "BB3_NBLIG" : Local Integer NOBOUT : NOBOUT = 3 : Goto AP_BOUTON
 When "BB4_NBLIG" : Local Integer NOBOUT : NOBOUT = 4 : Goto AP_BOUTON
 When "BB5_NBLIG" : Local Integer NOBOUT : NOBOUT = 5 : Goto AP_BOUTON
 When "BB6_NBLIG" : Local Integer NOBOUT : NOBOUT = 6 : Goto AP_BOUTON
 When "BB7_NBLIG" : Local Integer NOBOUT : NOBOUT = 7 : Goto AP_BOUTON
 When "BB8_NBLIG" : Local Integer NOBOUT : NOBOUT = 8 : Goto AP_BOUTON
Endcase
Return

$OUVRE
Gosub ALISTER From SUBALH2
Gosub SET_VARIA From SUBALQ9
If clalev([F:ARV])=0  : Local File AREPORTV [ARV] : Endif
If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 Local Char SAV_FCY(GLONFCY), SAV_DEP(GLONDEP)
Endif
REQUETE  = PARAM(1)
LISTE = REQUETE
CHGTLIS  = val(PARAM(2))
EXEC     = val(PARAM(3))
Return

$TIT
Call LECTEXTRA(TIT,"ALISTEH","INTIT",[F:ALH]COD,"") From ATEXTRA
Return

$SET_IDENT
Local Char IDENT(15)
IDENT=format$("K:"+num$(GLONAUS)+"X",GUSER)+num$(adxuid(2))
Return

$SET_ENV
If dim([F:ALH]TYPENV)<0 : Return : Endif
If GPRODUIT=1 : ## GEODE
 Local Char    LFCY(GLONFCY), LDEP(GLONDEP)
Endif
Return

$ENVALR
If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 [F:ALR]FCY    = LFCY
 [F:ALR]DEP    = LDEP
Endif
Return

$DEBUT
MAXLIG = dim([M]C1)
Gosub TIT From =TRAITEMENT
Gosub SET_ENV

UTIL0 = GDIV(0)
If UTIL0=GUSER & [F:ALH]ALLUSR<>2 & GPRODUIT=1 : ## GEODE
 Gosub SET_IDENT
 Read [ALR]ALR0(4) = LISTE;LFCY;LDEP;IDENT
 If fstat<2 : UTIL=IDENT : UTIL0=IDENT : Endif
Endif

If EXEC
 If EXEC=9 : EXEC=0 : Endif : ## CRELIS
 Call SUBALQ9(LISTE,0)
 If GOK=1 : Gosub SET_UTIL From SUBALQ9 : Else UTIL="" : Endif
Elsif [F:ALH]ALLUSR=3 : # Théorique
 UTIL=""
Else
 If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
  If [F:ALH]ALLUSR=2
   Read [ALR]ALR0(3) = REQUETE;LFCY;LDEP  
  Else
   Read [ALR]ALR0(4) = REQUETE;LFCY;LDEP;UTIL0
  Endif
 Elsif [F:ALH]ALLUSR=2
  Read [ALR]ALR0(1) = REQUETE
 Else
  Read [ALR]ALR0(2) = REQUETE;UTIL0
 Endif
 If !fstat
  UTIL = [F:ALR]USR
 Else
  UTIL = ""
  If UTIL0<>GUSER & [F:ALH]ALLUSR<>2 : ## GEODE
   Call TEMPON("O") From GESECRAN
   ## copie [ALR]USR = GUSER -> IDENT
   GOK=1
   Trbegin [ALR]
    For [ALR] Where COD=REQUETE & USR=GUSER & FCY=LFCY & DEP=LDEP
     [F:ALR]USR=UTIL0
     Write [ALR]
     If fstat
      GOK = 0 : Call FSTA("ALR") From GLOCK : Break
     Else 
      GOK = 2
     Endif
    Next
   If GOK : Commit   : If GOK=2 : GOK=1 : UTIL=UTIL0 : Endif 
   Else   : Rollback
   Endif
   Call TEMPOFF From GESECRAN
  Endif
 Endif
Endif

Gosub LECTURE
Return

$RAFFRAICHIR
BOUT = "E"
Gosub BOUTON
Return

$AVANT_BOUTON
Case BOUT
 When "X" : # Export
  If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE 
   SAV_FCY = GFCY : GFCY = LFCY
   SAV_DEP = GDEP : GDEP = LDEP
  Endif
Endcase
Return

$BOUTON
Case BOUT
 When "E" : # Exécuter
  Gosub EXERQT
 When "R" : # Critères
  If GOK=1
   Read [ALH]ALH0 = LISTE
   Gosub SET_UTIL From SUBALH9
   Gosub LECTURE
  Endif
 When "C" : # Chgt code
  GOK = 2
  FIN = 1
 When "X" : # Export
  If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE 
   GFCY = SAV_FCY : GDEP = SAV_DEP
  Endif
Endcase
Return

$EXERQT
Call SUBALQ9(LISTE,0)
If !GOK : Return : Endif
Gosub SET_UTIL From SUBALH9

$LECTURE
If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 Read [ALR]ALR0 = REQUETE;LFCY;LDEP;UTIL;1;0;0
Else
 Read [ALR]ALR0 = REQUETE;UTIL;1;0;0
Endif
If fstat
 Raz [M]DAT, [M]TIM, [M]USR, [M]LIG 
Else
 [M]DAT = [F:ALR]CREDAT
 If dim([F:ALR]CRETIM)>0
  [M]TIM = [F:ALR]CRETIM
 Endif
 [M]USR = [F:ALR]USR
 [M]LIG = [F:ALR]NUM
Endif
NBPAG = int(([M]LIG-1)/MAXLIG)+1
PAGE = 1 : Gosub LIRE
Return

$FIN
GOK = 1
FIN = 1
Return

$SORTIE
Inftxt " " At 2
If clalev([M:LST])>0 : Close Local Mask [LST] : Endif
Return

$REMPLACE
For I=1 To dim(TEXTE)
 K = 0
 Repeat
  K = instr(K+1,TEXTE(I),"%")
  If K
   L = instr(K+1,TEXTE(I),"%")    
   If L>K
    GENTYP = ""
    VARGLB = seg$(TEXTE(I),K+1,L-1)
    If instr(1,VARGLB,"(")
     VARGLB = left$(VARGLB,instr(1,VARGLB,"(")-1)
    Endif
    Read [AGB]AGB0=VARGLB
    If !fstat
     GENTYP = [F:AGB]CODTYP
    Elsif L<K+4
     VARGLB = ""
     J = val(seg$(TEXTE(I),K+1,L-1))
     J = find(J,[M:DIA]NUMPAR(0..[M:DIA]NBLIG-1))
     If J>0
      GENTYP = [M:DIA]CODTYP(J-1)
     Endif
    Endif
    If GENTYP<>""
     If VARGLB<>""
      If evalue(seg$(TEXTE(I),K+1,L-1))<>""
       TEXTE(I) = left$(TEXTE(I),K-1)+"'"+evalue(seg$(TEXTE(I),K+1,L-1))+"'"+right$(TEXTE(I),L+1)
      Else
       Read [ATY]CODTYP = GENTYP
       Case [F:ATY]TYPTYP
        When 1,2,3,4,5,6
         TEXTE(I) = left$(TEXTE(I),K-1)+"0"+right$(TEXTE(I),L+1)
        When 7
         If mid$(TEXTE(I),K-1,1)="%" & mid$(TEXTE(I),L+1,1)="%" : # Cas du 'like'
          TEXTE(I) = left$(TEXTE(I),K-1)+" "+right$(TEXTE(I),L+1)
         Else
          TEXTE(I) = left$(TEXTE(I),K-1)+"' '"+right$(TEXTE(I),L+1)
         Endif
        When 8
         If BASE=3 : # Oracle
          TEXTE(I) = left$(TEXTE(I),K-1)+"to_date('20000101','YYYYMMDD')"+right$(TEXTE(I),L+1)
         Else      : # Sql
          TEXTE(I) = left$(TEXTE(I),K-1)+"convert(datetime,'20000101',112)"+right$(TEXTE(I),L+1)
         Endif
       Endcase
      Endif
     Elsif [M:DIA]CODTYP(J-1)=""
      If [M:DIA]VALDEB(J-1)=""
       [M:DIA]VALDEB(J-1) = " "
      Endif
      TEXTE(I) = left$(TEXTE(I),K-1)+"'"+[M:DIA]VALDEB(J-1)+"'"+right$(TEXTE(I),L+1)
     Else
      Read [ATY]CODTYP = GENTYP
      Case [F:ATY]TYPTYP
       When 1,2,3,4,5,6
        If [M:DIA]VALDEB(J-1)=""
         [M:DIA]VALDEB(J-1) = "0"
        Endif
        TEXTE(I) = left$(TEXTE(I),K-1)+[M:DIA]VALDEB(J-1)+right$(TEXTE(I),L+1)
       When 7
        If [M:DIA]VALDEB(J-1)=""
         [M:DIA]VALDEB(J-1) = " "
        Endif
        If mid$(TEXTE(I),K-1,1)="%" & mid$(TEXTE(I),L+1,1)="%" : # Cas du 'like'
         TEXTE(I) = left$(TEXTE(I),K-1)+[M:DIA]VALDEB(J-1)+right$(TEXTE(I),L+1)
        Else
         TEXTE(I) = left$(TEXTE(I),K-1)+"'"+[M:DIA]VALDEB(J-1)+"'"+right$(TEXTE(I),L+1)
        Endif
       When 8
        If find([M:DIA]VALDEB(J-1),"","00000000")
         [M:DIA]VALDEB(J-1) = "20000101"
        Endif
        If BASE=3
         TEXTE(I) = left$(TEXTE(I),K-1)+"to_date('"+[M:DIA]VALDEB(J-1)+"','YYYYMMDD')"+right$(TEXTE(I),L+1)
        Else
         TEXTE(I) = left$(TEXTE(I),K-1)+"convert(datetime,'"+[M:DIA]VALDEB(J-1)+"',112)"+right$(TEXTE(I),L+1)
        Endif
      Endcase
     Endif
     K = L
    Endif
   Endif
  Endif
 Until K=0
Next I
Return

$REMPLACE_CLOB
Setlob CLOB With TEXTE
Repeat
 K = instr(K+1,CLOB,"%")
 If K
  L = instr(K+1,CLOB,"%")    
  If L>K
   GENTYP = ""
   VARGLB = seg$(CLOB,K+1,L-1)
   If instr(1,VARGLB,"(")
    VARGLB = left$(VARGLB,instr(1,VARGLB,"(")-1)
   Endif
   Read [AGB]AGB0=VARGLB
   If !fstat
    GENTYP = [F:AGB]CODTYP
   Elsif L<K+4
    VARGLB = ""
    J = val(seg$(CLOB,K+1,L-1))
    J = find(J,[M:DIA]NUMPAR(0..[M:DIA]NBLIG-1))
    If J>0
     GENTYP = [M:DIA]CODTYP(J-1)
    Endif
   Endif
   If GENTYP<>""
    If VARGLB<>""
     If evalue(seg$(CLOB,K+1,L-1))<>""
      CLOB = left$(CLOB,K-1)+"'"+evalue(seg$(CLOB,K+1,L-1))+"'"+right$(CLOB,L+1)
     Else
      Read [ATY]CODTYP = GENTYP
      Case [F:ATY]TYPTYP
       When 1,2,3,4,5,6
        CLOB = left$(CLOB,K-1)+"0"+right$(CLOB,L+1)
       When 7
        If mid$(CLOB,K-1,1)="%" & mid$(CLOB,L+1,1)="%" : # Cas du 'like'
         CLOB = left$(CLOB,K-1)+" "+right$(CLOB,L+1)
        Else
         CLOB = left$(CLOB,K-1)+"' '"+right$(CLOB,L+1)
        Endif
       When 8
        If BASE=3 : # Oracle
         CLOB = left$(CLOB,K-1)+"to_date('20000101','YYYYMMDD')"+right$(CLOB,L+1)
        Else      : # Sql
         CLOB = left$(CLOB,K-1)+"convert(datetime,'20000101',112)"+right$(CLOB,L+1)
        Endif
      Endcase
     Endif
    Elsif [M:DIA]CODTYP(J-1)=""
     If [M:DIA]VALDEB(J-1)=""
      [M:DIA]VALDEB(J-1) = " "
     Endif
     CLOB = left$(CLOB,K-1)+"'"+[M:DIA]VALDEB(J-1)+"'"+right$(CLOB,L+1)
    Else
     Read [ATY]CODTYP = GENTYP
     Case [F:ATY]TYPTYP
      When 1,2,3,4,5,6
       If [M:DIA]VALDEB(J-1)=""
        [M:DIA]VALDEB(J-1) = "0"
       Endif
       CLOB = left$(CLOB,K-1)+[M:DIA]VALDEB(J-1)+right$(CLOB,L+1)
      When 7
       If [M:DIA]VALDEB(J-1)=""
        [M:DIA]VALDEB(J-1) = " "
       Endif
       If mid$(CLOB,K-1,1)="%" & mid$(CLOB,L+1,1)="%" : # Cas du 'like'
        CLOB = left$(CLOB,K-1)+[M:DIA]VALDEB(J-1)+right$(CLOB,L+1)
       Else
        CLOB = left$(CLOB,K-1)+"'"+[M:DIA]VALDEB(J-1)+"'"+right$(CLOB,L+1)
       Endif
      When 8
       If find([M:DIA]VALDEB(J-1),"","00000000")
        [M:DIA]VALDEB(J-1) = "20000101"
       Endif
       If BASE=3
        CLOB = left$(CLOB,K-1)+"to_date('"+[M:DIA]VALDEB(J-1)+"','YYYYMMDD')"+right$(CLOB,L+1)
       Else
        CLOB = left$(CLOB,K-1)+"convert(datetime,'"+[M:DIA]VALDEB(J-1)+"',112)"+right$(CLOB,L+1)
       Endif
     Endcase
    Endif
    K = L
   Endif
  Endif
 Endif
Until K=0
Setlob TEXTE With CLOB
Return

$SETBOUT
If !CHGTLIS
 Call VIREBOUT(CHMEN,"C") From GOBJET 
Endif
If ![M]NBLIG   : Call VIREBOUT(CHMEN,"X") From GOBJET : Endif
CHBOU += "IL"
If ![M]NBLIG   : Call VIREBOUT(CHBOU,"IL") From GOBJET : Endif
If PAGE<=1     : Call VIREBOUT(CHBOU,"0<") From GOBJET : Endif
If PAGE>=NBPAG : Call VIREBOUT(CHBOU,"9>") From GOBJET : Endif
CHBOU += "="
If [F:ALH]ACS<>""
 Read [ACC]CODACC = GUSER ; [F:ALH]ACS
 If fstat or [F:ACC]EXEC<>2
  Call VIREBOUT(CHMEN,"E") From GOBJET
  Call VIREBOUT(CHBOU,"=") From GOBJET
 Endif
Endif
If TEXTE<>""
 ETABOU(GTRAN) = 1
Endif
Return

$TRANSAC
Call MESSAGE(sum(TEXTE)) From GESECRAN
Return
 
$LIRE
Effzo 20 : # Tableau

If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 Filter [ALR] Where COD=REQUETE & USR=UTIL & NIV=1 & LIG>(PAGE-1)*MAXLIG
&                 & FCY=LFCY & DEP=LDEP
Else
 Filter [ALR] Where COD=REQUETE & USR=UTIL & NIV=1 & LIG>(PAGE-1)*MAXLIG
Endif
For [ALR]ALR0
 I = [F:ALR]LIG-(PAGE-1)*MAXLIG
 If I>MAXLIG : Break : Endif
 K = [F:ALR]COL
 Case K
  When -1 : If dim([M]FCY)>1 : [M]FCY(I-1) = [F:ALR]VLR : Endif
  When -2 : If dim([M]DEP)>1 : [M]DEP(I-1) = [F:ALR]VLR : Endif
  When Default
   Case [F:ALR]TYP
    When 1,2,3,4,5,6 : Assign "[M]C"+num$(K)+"("+num$(I-1)+")" With [F:ALR]NUM
    When 7           : Assign "[M]C"+num$(K)+"("+num$(I-1)+")" With [F:ALR]VLR
    When 8           : Assign "[M]C"+num$(K)+"("+num$(I-1)+")" With [F:ALR]DAT
   Endcase
 Endcase
 [M]NBLIG = max(I,[M]NBLIG)
Next
Filter [ALR]
[M]COD = REQUETE
Call LECTEXTRA([M]DES,"ALISTEH","INTIT",[F:ALH]COD,"") From ATEXTRA
[M]PAG = num$(PAGE)+"/"+num$(NBPAG)
Affzo

If [M]LIG=0
 Inftxt mess(151,126,1) At 2 : # Saisir les critères ou F5 pour raffraîchir
Else
 Inftxt " " At 2
Endif
Return

$SUIVANT
If PAGE<NBPAG
 PAGE += 1
 Gosub LIRE
Endif
Return

$PRECEDENT
If PAGE>1
 PAGE -= 1
 Gosub LIRE
Endif
Return

$PREMIER
PAGE = 1
Gosub LIRE
Return

$DERNIER
PAGE = NBPAG
Gosub LIRE
Return

$LISTE
Onerrgo RIEN
If clalev([F:AMZ1])=0 : Local File AMSKZON [AMZ1] : Endif
Trbegin [AMZ1]
 For I=1 To dim(TIT)
  If TIT(I)<>""
   Read [AMZ1]CODE="WN"+[M:LST]COD;"C"+num$(I)
   If !fstat
    [F:AMZ1]INTEVAL = '"'+TIT(I)+'"'
    Rewrite [AMZ1]
   Endif
  Endif
 Next I
Commit
Onerrgo
Call HCOPY("WN"+[M:LST]COD,"LST",[M:LST]DES)
Return

$RIEN
Resume

$IMPRIME
Local Char    ETAT(16),ETATDES(16)
Local Char    TBPAR(10)(1..60),TBVAL(30)(1..60),FONT(40)(1..16)
Local Char    DIRBIN(GDIMFIC),DIRRPT(GDIMFIC),MACHINE(GDIMFIC)
Local Integer NBPAR,TAILLETIT(1..16),TAILLEMAX(1..16),UNDERLINE(1..16),BOLD(1..16),ITALICS(1..16)

If clalev([F:AST])=0 : Local File APLSTD [AST] : Endif

If dim([F:ALH]RPT)>0 & [F:ALH]RPT<>""
 ETAT = [F:ALH]RPT
 ETATDES = ETAT
Else
 ETAT = "ALISTE"
Endif

If ETAT="ALISTE"
 If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
  ETATDES = "ALISTENV"
 Else
  ETATDES = "ALISTE"
 Endif
Endif

NIVEAU = 1
NBGRP = 0

NBPAR = 0
NBPAR += 1 : TBPAR(NBPAR)="liste"  : TBVAL(NBPAR) = LISTE
NBPAR += 1 : TBPAR(NBPAR)="user"   : TBVAL(NBPAR) = UTIL
NBPAR += 1 : TBPAR(NBPAR)="titre"  
Call LECTEXTRA(TBVAL(NBPAR),"ALISTEH","INTIT",[F:ALH]COD,"") From ATEXTRA 
If dim(TITLIS)> 0 
 If TITLIS<>"" 
  TBVAL(NBPAR) -= "-"-TITLIS 
 Endif
Endif
NBPAR += 1 : TBPAR(NBPAR)="niveau" : TBVAL(NBPAR) = num$(NIVEAU)

K = 0
I = 0
For [ALD]ALD0 Where COD=LISTE & STREND<=2 & LIG <=16
 I += 1
 NBPAR += 1 : K += 1
 TBPAR(NBPAR) = "titre"+num$(K) 
 Call LECTEXTRA(TBVAL(NBPAR),"ALISTED","INTITLIG",[F:ALD]COD,num$([F:ALD]LIG)) From ATEXTRA 
 TAILLETIT(K) = len(TBVAL(NBPAR))
 NBPAR +=1
 TBPAR(NBPAR) = "col"+num$(K)   : TBVAL(NBPAR) = num$(I)
 NBPAR += 1
 TBPAR(NBPAR) = "cum"+num$(K)
 If K>=16 : Break : Endif
Next
For I=K+1 To 16
 NBPAR += 1
 TBPAR(NBPAR) = "titre"+num$(I) : TBVAL(NBPAR) = ""
 NBPAR += 1
 TBPAR(NBPAR) = "col"+num$(I)   : TBVAL(NBPAR) = "0"
 NBPAR += 1
 TBPAR(NBPAR) = "cum"+num$(I)
 TBVAL(NBPAR) = "1"
Next I
NBPAR += 1
TBPAR(NBPAR) = "grp"
If NIVEAU>1
 TBVAL(NBPAR) = num$(GRP(1))
Else
 TBVAL(NBPAR) = "0"
Endif

If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 NBPAR += 1 : TBPAR(NBPAR)="ldep"  : TBVAL(NBPAR) = LDEP
 NBPAR += 1 : TBPAR(NBPAR)="lfcy"  : TBVAL(NBPAR) = LFCY
Endif

Call ETAT(ETATDES,GFONCTION,TBPAR,TBVAL) From ETAT
Return

Subprog HCOPY(NOMMSK,ABMSK,TIT)
Value Char NOMMSK
Value Char ABMSK
Value Char TIT
Call PRTSCR(NOMMSK,ABMSK,TIT,0,0) From ATRTX3
Call IMPSCR From ATRTX3
End

#######################################################
## Etiquettes écran VISUSQL
#######################################################
Subprog IB_NBLIG
Gosub PFIX From SUBALQ
Gosub BOUTONS From =PREFPRG+[M]COD
End

$AV_BOUTON
Local Integer NOL, SAVCONS
Local Char    SAVB1(30) , SAVB2(30) , SAVB3(30) , SAVB4(30)
Local Char    SAVB5(30) , SAVB6(30) , SAVB7(30) , SAVB8(30)
NOL = nolign-1
Raz GBIDC1, GBIDC2, GBIDC3

SAVCONS = GCONSULT
GBIDC1 = [M]TUNNEL(NOBOUT)
If GBIDC1<>""
 GBIDC2 = num$(evalue("[M:LST]C"+num$([M]TUNZON(NOBOUT))+"("+num$(NOL)+")"))
 If GBIDC2<>""
  GCONSULT = 2
  SAVB1 = GBOUT1
  SAVB2 = GBOUT2
  SAVB3 = GBOUT3
  SAVB4 = GBOUT4
  SAVB5 = GBOUT5
  SAVB6 = GBOUT6
  SAVB7 = GBOUT7
  SAVB8 = GBOUT8
 Endif
Endif
Return

$AP_BOUTON
GCONSULT = SAVCONS
GBOUT1 = SAVB1
GBOUT2 = SAVB2
GBOUT3 = SAVB3
GBOUT4 = SAVB4
GBOUT5 = SAVB5
GBOUT6 = SAVB6
GBOUT7 = SAVB7
GBOUT8 = SAVB8
Return


Subprog SUBALQ9(LISTE,BCRIT)
Value Char    LISTE()
Value Integer BCRIT
Local Char PARAM(250)(1..7) , VALEUR(10) 
PARAM(1) = LISTE
PARAM(2) = "0"
PARAM(3) = "1"
If !BCRIT
 Call TRAITE_CHAR(VALEUR,PARAM,"","SUBALQ9","",4,"SPEALQ") From GTRAITE
Else
 Call TRAITE_CHAR(VALEUR,PARAM,"","SUBALQ9","ALQ9",4,"SPEALQ") From GTRAITE
Endif
End

