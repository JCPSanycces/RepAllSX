#<AdxTL>@(#)9.0.0.0 $Revision$
$ACTION
Case ACTION
 When "SEL_TABLE"  : Gosub SEL_TABLE
 When "VERF_TABLE" : Gosub VERF_TABLE
Endcase
Return

$SEL_TABLE
Case TABLE
 When "SECH2" : Gosub S_ECH
Endcase
Return

$VERF_TABLE
Case TABLE
 When "SECH2" : Gosub C_ECH
Endcase
Return

#################################################################
# Etiquette masque DUDATMGT3
#################################################################

Subprog AVANT_NB
Case [M:DDM3]STAT
 When 82  :# Ajout de ligne
  Local Integer REF : # Indice ligne de référence
  Gosub SETNOL
  If NOL=0
   REF = 1
  Else
   REF = NOL-1
  Endif
  # affectation des zones en insertion
  [M:DDM3]TYP(NOL)     = [M:DDM3]TYP(REF)
  [M:DDM3]NUM(NOL)     = [M:DDM3]NUM(REF)
  [M:DDM3]LIG(NOL)     = [M:DDM3]LIG(REF)
  [M:DDM3]ACCNUM(NOL)  = [M:DDM3]ACCNUM(REF)
  [M:DDM3]CPY(NOL)     = [M:DDM3]CPY(REF)
  [M:DDM3]FCY(NOL)     = [M:DDM3]FCY(REF)
  [M:DDM3]CUR(NOL)     = [M:DDM3]CUR(REF)
  [M:DDM3]SAC(NOL)     = [M:DDM3]SAC(REF)
  [M:DDM3]BPR(NOL)     = [M:DDM3]BPR(REF)
  [M:DDM3]BPRPAY(NOL)  = [M:DDM3]BPRPAY(REF)
  [M:DDM3]BPRTYP(NOL)  = [M:DDM3]BPRTYP(REF)
  [M:DDM3]DUDDAT(NOL)  = [M:DDM3]DUDDAT(REF)
  [M:DDM3]DEP(NOL)     = [M:DDM3]DEP(REF)
  [M:DDM3]PAM(NOL)     = [M:DDM3]PAM(REF)
  [M:DDM3]PAMTYP(NOL)  = [M:DDM3]PAMTYP(REF)
  [M:DDM3]SNS(NOL)     = [M:DDM3]SNS(REF)
  [M:DDM3]FLGFUP(NOL)  = [M:DDM3]FLGFUP(REF)
  [M:DDM3]LEVFUP(NOL)  = [M:DDM3]LEVFUP(REF)
  [M:DDM3]DATFUP(NOL)  = [M:DDM3]DATFUP(REF)
  [M:DDM3]DPTCOD(NOL)  = [M:DDM3]DPTCOD(REF)
  [M:DDM3]SOI(NOL)     = [M:DDM3]SOI(REF)
  [M:DDM3]FLGPAZ(NOL)  = [M:DDM3]FLGPAZ(REF)
  [M:DDM3]VAT(NOL)     = [M:DDM3]VAT(REF)
Endcase
End

Subprog C_NB
[M:DDM3]STAT = status
## Modification montant interdit
If find(status,73,65,68,83,82) & [M:SAI1]M4=1
 mkstat = 2 : End
Endif
Gosub SETNOL
If NOL>=dim([M:DDM3]NUM) : End : Endif
Case status
 When 65,68,83 :# Annulation de ligne
  Local Integer OK
  If [M:DDM3]NB=1  :# Une seule échéance
   #### Il n'y a qu'une échéance , Annulation impossible
   GMESSAGE = mess(48,117,1)+"\"+mess(49,117,1)
   mkstat = 2 : End
  Endif
  If find(status,68,83) & min(nolign1,[M:DDM3]NB)-nolign+1=[M:DDM3]NB
   # Annulation impossible de toutes les echeances
   GMESSAGE = mess(32,117,1)
   mkstat = 2 : End
  Endif
  If status=65
   Gosub TEST_LIGNE
  Else
   For NOL=nolign-1 To min(nolign1,[M:DDM3]NB)-1
    Gosub TEST_LIGNE
    If mkstat : Break : Endif
   Next
  Endif
 When 75 :# Modification ligne
  If [M:DDM3]AMTCUR(NOL)=0 : End : Endif
  If abs([M:DDM3]PAYCUR(NOL)+[M:DDM3]TMPCUR(NOL))>=abs([M:DDM3]AMTCUR(NOL))
   [M:SAI1]M3 = 1 : # Relance/BAP non modIfiable
  Endif
  If [M:DDM3]SOINUM(NOL)<>""
   [M:SAI1]M1 = 1  :# Date échéance
   [M:SAI1]M2 = 1  :# Mode règlement
   [M:SAI1]M4 = 1  :# Montant échéance
   [M:SAI1]M5 = 1  :# Tiers
  Endif
  If [M:DDM3]TMPCUR(NOL)<>0  :# Règlements provisoires
   [M:SAI1]M5 = 1  :# Tiers payeur / payé
  Endif
Endcase
End

$TEST_LIGNE
[L]OK = 1
If [M:DDM3]PAYCUR(NOL)+[M:DDM3]TMPCUR(NOL)<>0  :# Règlements
 [L]OK = 0
Else
 Case [M:DDM3]TYP(NOL)
  When GDIV(0)
   Filter [PYD] Where IPTTYP=1 & DUDNUM=[M:DDM3]ACCNUM(NOL) & DUDLIG=[M:DDM3]DUDLIG(NOL)
&               Order By Key CLE=IPTTYP;DUDNUM;DUDLIG
  When GDIV(1)
   Filter [PYD] Where IPTTYP=2 & DUDNUM=[M:DDM3]ACCNUM(NOL) & DUDLIG=[M:DDM3]DUDLIG(NOL)
&               Order By Key CLE=IPTTYP;DUDNUM;DUDLIG
  When Default
   Filter [PYD] Where IPTTYP=3 & DUDNUM=[M:DDM3]ACCNUM(NOL) & DUDLIG=[M:DDM3]DUDLIG(NOL)
&               Order By Key CLE=IPTTYP;DUDNUM;DUDLIG
 Endcase
 Read [F:PYD]CLE First
 If fstat=0
  [L]OK = 0
 Endif
 Filter [PYD]
Endif
If ![L]OK
 # Ligne x , Il y a un règlement sur cette échéance , Annulation impossible
 GMESSAGE = mess(061,100,1)-num$(NOL+1)+"\"+mess(50,117,1)+"\"+mess(49,117,1)
 mkstat = 2 : Return
Endif
If [M:DDM3]SOINUM(NOL)<>""
 #  Ligne x , L'échéance appartient à un relevé , Annulation impossible
 GMESSAGE = mess(061,100,1)-num$(NOL+1)+"\"+mess(51,117,1)+"\"+mess(49,117,1)
 mkstat = 2 : Return
Endif
Return

Subprog AS_DUDDAT(VALEUR)
Variable Date     VALEUR
If [M:SAI1]M1=1 : mkstat = 2 : Endif
End

## Sélection des échéances
$S_ECH
Gosub SETNOL
Local Char TYP(GLONGTE)
Case [M:SAI1]TYP(NOL)
 When GDIV(0) : [L]TYP = "*SO"
 When GDIV(1) : [L]TYP = "*PO"
 When Default : [L]TYP = [M:SAI1]TYP(NOL)
Endcase
Filter [F:DUD2] Where ACCNUM=[M:SAI1]ACCNUM([M:DDM3]IND)
I = 0
For [F:DUD2]
 I += 1 : If I>1 : Break : Endif
Next
Filter [F:DUD2]
If I<2 : OK = 0 : Return : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON : Endif
Default File [DUD2]
CRITERE = 'TYP="'+[L]TYP+'" & NUM="'+VALEUR+'" & AMTCUR*(AMTCUR-PAYCUR-TMPCUR)>0'
START   = 'NUM'
TIT(0) = mess(9,117,1)
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "TYP"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "NUM"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "LIG"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "DUDLIG" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "DUDDAT" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "AMTCUR" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "ACCNUM" : Gosub TEXTE
Return

$TEXTE
Read [F:AMZ]CODE = "DUDATMGT2";COL(NBCOL)
Call TEXTE([F:AMZ]INTIT,TIT(NBCOL)) From OBJDIV
Return

$C_ECH
Read [F:DUD2]DUD1 = [F:DUD2]ACCNUM;[F:DUD2]DUDLIG
## Vérif que cette échéance n'a pas déjà été saisie
If [M:DDM3]DUDLIG([L]NOL)=0
 I = find([F:DUD2]DUDLIG,[M:DDM3]DUDLIG(0..[M:DDM3]NB-1))
 If I>0
  GERR = 1 : GMESSAGE = mess(46,117,1)-num$(I) : # Echéance déjà saisie en ligne
  mkstat = 2
 Else
  nolign = NOL+1
  [M:DDM3] = [F:DUD2]
  Call GETSOC([F:DUD2]FCY) From DEVSUB
 Endif
Endif
Return

Subprog AS_PAM(VALEUR)
Variable Char     VALEUR
If [M:SAI1]M2=1 : mkstat = 2 : Endif
If dim([M:DDM3]UMRNUM)>0 & GSDDMGT=2 & [M:DDM3]BPRTYP(nolign-1)=1 & [M:DDM3]TYPDUD(nolign-1)=2
 If [M:DDM3]AMTCUR(nolign-1)<>0 & abs([M:DDM3]PAYCUR(nolign-1))+abs([M:DDM3]TMPCUR(nolign-1))<>0
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_PAM(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
Local Integer OK
If VALEUR<>[M:DDM3]PAM(NOL)
 If ([M:DDM3]SOINUM(NOL)<>"" | [M:DDM3]SOI(NOL)=2)
  Call LEC_TAM(GCURLEG, VALEUR) From CPTLEC
  If [F:TAM]SOI=""  :# Pas de code relevé
   # Mode de règlement non concerné par les relevés
   GMESSAGE = mess(38,117,1)
   mkstat = 2 : End
  Endif
 Endif
 If dim([M:DDM3]UMRNUM)>0
  Call LEC_TAM(GCURLEG,VALEUR) From CPTLEC
  If [F:TAM]SDDFLG<>2 : Raz [M:DDM3]UMRNUM(NOL) : Endif
 Endif
Endif
End

Subprog AS_AMTCUR(VALEUR)
Variable Decimal  VALEUR
If [M:SAI1]M4=1 : mkstat = 2 : Endif
End

Subprog C_AMTCUR(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
If [M:DDM3]AMTCUR(NOL)<>0 & sgn(VALEUR)<>sgn([M:DDM3]AMTCUR(NOL)) : mkstat=1 : End : Endif
Local Integer OK
If VALEUR<>[M:DDM3]AMTCUR(NOL) & abs(VALEUR)<abs([M:DDM3]PAYCUR(NOL)+[M:DDM3]TMPCUR(NOL))
 GMESSAGE = mess(37,117,1) :# Mt échéance < Mt déjà réglé
 mkstat = 1
Endif
End

Subprog B2_AMTCUR(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
Local Decimal TOTECHE
For I=0 To [M:DDM3]NB-1
 If I<>NOL
  [L]TOTECHE += [M:DDM3]AMTCUR(I)
 Endif
Next I
VALEUR = [M:DDM3]TOTAMT-[L]TOTECHE
End

Subprog AS_FLGFUP(VALEUR)
Variable Integer  VALEUR
If [M:SAI1]M3=1
 mkstat = 2
Endif
End

Subprog AS_DPTCOD(VALEUR)
Variable Char  VALEUR
If [M:SAI1]M3=1
 mkstat = 2
Endif
End

Subprog AS_LEVFUP(VALEUR)
Variable Decimal  VALEUR
If [M:SAI1]M3=1
 mkstat = 2
Endif
End

Subprog AS_FLGPAZ(VALEUR)
Variable Integer  VALEUR
Local Char BONAPAY(1)
If [M:DDM3]BPRTYP(nolign-1)=1 | [M:SAI1]M3=1 | VALEUR>[M:DDM]NIVBAP
 mkstat = 2 : End
Elsif [M:DDM]PRESELECT=2 & [M:DDM]ALLFCY=1
 Call PARAM([M:DDM3]FCY(nolign-1),"FLGPAZ",[L]BONAPAY) From ADOVAL
 If [L]BONAPAY="1" : mkstat = 2 : End : Endif
Else
 Call PARAM([M:DDM3]FCY(nolign-1),"FLGPAZ",[L]BONAPAY) From ADOVAL
 If [L]BONAPAY="1" : mkstat = 2 : End : Endif
Endif
End

Subprog C_FLGPAZ(VALEUR)
Variable Integer  VALEUR
If VALEUR>[M:DDM]NIVBAP
 GMESSAGE = mess(29,119,1) : mkstat = 2
 # Niveau de bon à payer non autorisé
Endif
End

Subprog AS_BPRPAY(VALEUR)
Variable Char     VALEUR
If [M:SAI1]M5=1 : mkstat = 2 : Endif
End

Subprog AM_DEP(VALEUR)
Variable Char    VALEUR()
Call CNTDEPTYP(0,[M:DDM3]ACCNUM(nolign-1),"",VALEUR) From CPTCNT
If mkstat : End : Endif
End

######################################################################
$SETNOL
Local Integer NOL
NOL = nolign-1
Return

######################################################################################
Subprog AM_BPRPAY(VALEUR)
Variable Char    VALEUR()
If dim([M:DDM3]UMRNUM)>0 & [M:DDM3]UMRNUM(nolign-1)<>""
 Raz [M:DDM3]UMRNUM(nolign-1)
Endif
End

Subprog AS_UMRNUM(VALEUR)
Variable Char    VALEUR()
# TYPDUD n'est pas initialisé dans le cas d'une nouvelle échéance... 
If [M]TYPDUD(nolign-1)=0 & [M]TYPDUD(0)<>0 : [M]TYPDUD(nolign-1)=[M]TYPDUD(0) : Endif

Call AS_UMRNUM(VALEUR) From SUBDDM2
End

Subprog C_UMRNUM(VALEUR)
Variable Char    VALEUR()
Call C_UMRNUM(VALEUR) From SUBDDM2
End
######################################################################################

