If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_CACHEUUID From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_ABRCLA From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
