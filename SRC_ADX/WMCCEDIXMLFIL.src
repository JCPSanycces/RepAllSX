If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_FILDES From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_MSGDIR From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To 20
 If this.EXFN(AINDCLA)<>null& find(this.EXFN(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EXFN(AINDCLA)._AFORMAT : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_VALID From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_FLGMUX From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_UUIDXMLTYP From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To maxtab(this.EXSD)
 If this.EXSD(AINDCLA)<>null& find(this.EXSD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EXSD(AINDCLA)._AFORMAT : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EXFD)
 If this.EXFD(AINDCLA)<>null& find(this.EXFD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EXFD(AINDCLA)._AFORMAT : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EXFF)
 If this.EXFF(AINDCLA)<>null& find(this.EXFF(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EXFF(AINDCLA)._AFORMAT : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_KEYALIAS From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_KEYDES From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_KEYPROPERTY From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_KEYPROTOPATH From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_CREUSR From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_UPDUSR From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_CREDATTIM From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_UPDDATTIM From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_AUUID From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
Return

####################################################################
# OTHERS
####################################################################

$_AOTHERS
Gosub DECLARE_VAR From WMC0EDIXMLFIL
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MSGCOD From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MSGCOD From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MSGREL From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MSGREL From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MSGFILNOR From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MSGFILNOR From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MSGFOR From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MSGFOR From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_TYPFIL From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_TYPFIL From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CACHEUUID From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CACHEUUID From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ABRCLA From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ABRCLA From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_REPCOD From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_REPCOD From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CODACT From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CODACT From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FILDES From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FILDES From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MSGDIR From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MSGDIR From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To 20
 If this.EXFN(AINDCLA)<>null& find(this.EXFN(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EXFN(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_VALID From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_VALID From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FLGMUX From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FLGMUX From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UUIDXMLTYP From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UUIDXMLTYP From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To maxtab(this.EXSD)
 If this.EXSD(AINDCLA)<>null& find(this.EXSD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EXSD(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EXFD)
 If this.EXFD(AINDCLA)<>null& find(this.EXFD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EXFD(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EXFF)
 If this.EXFF(AINDCLA)<>null& find(this.EXFF(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EXFF(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_KEYALIAS From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_KEYALIAS From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_KEYDES From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_KEYDES From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_KEYPROPERTY From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_KEYPROPERTY From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_KEYPROTOPATH From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_KEYPROTOPATH From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREUSR From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREUSR From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDUSR From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDUSR From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREDATTIM From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREDATTIM From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDDATTIM From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDDATTIM From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_AUUID From WMC1EDIXMLFIL : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_AUUID From WMC1EDIXMLFIL : Gosub TESTALLSTAT :  Endif
[L]ASTATUS = fmet this.ACONTROL
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



