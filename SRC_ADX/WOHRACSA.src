$OUVFIC_LISTE
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
Link [HRCTR] With
& [ID]ID0=[F:HRCTR]REFNUM,
& [FCY]FCY0=[F:HRCTR]ETRFCY
& As [HRCTR_]
Return

$DEFAUT_LISTE
Default file [HRCTR_]
Return

$OUVRE_JOIN
Local Char    ORDRE_JOI(250)
ORDRE_JOI = "A_TABJ1;A_TABJ2;A_TABJ3"
Local Char     A_BUFJ1(15)(1..GNBSEL)
Local Char     A_BUFJ2(20)(1..GNBSEL)
Local Date     A_BUFJ3(1..GNBSEL)
Local Char     A_BUFJ4(15)(1..GNBSEL)
Local Char     A_BUFJ5(80)(1..GNBSEL)
Local File(
& Char     A_TABJ1(15),
& Char     A_TABJ2(20),
& Date     A_TABJ3,
& Char     A_TABJ4(15),
& Char     A_TABJ5(80)
& ) From Variable A_BUFJ1, A_BUFJ2, A_BUFJ3, A_BUFJ4, A_BUFJ5
& As [PCEJ]
Return

$TIT_JOIN
Local Char TITJOI(30)(1..5)
Call TEXTE(10793,TITJOI(1)) From OBJDIV
Call TEXTE(5481,TITJOI(2)) From OBJDIV
Call TEXTE(212,TITJOI(3)) From OBJDIV
TITJOI(4) = mess(59,100,1) : # Type
TITJOI(5) = mess(38,100,1) : # Nom
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Kf:20X"
LG = 0
TIT = ""
End

Subprog FORMCLE2(FMT)
Variable Char    FMT()
FMT = "Kf:15c"
End

$LIENS
