Call TEXTE(0,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(15)(0..GNBDERNIER)
Local Char     A_BUF2(40)(0..GNBDERNIER)
Local Char     A_BUF3(40)(0..GNBDERNIER)
Local Char     A_BUF4(20)(0..GNBDERNIER)
Local Date     A_BUF5(0..GNBDERNIER)
Local Date     A_BUF6(0..GNBDERNIER)
Local Char     A_BUF7(20)(0..GNBDERNIER)
Local Char     A_BUF8(5)(0..GNBDERNIER)
Local Char     A_BUF9(5)(0..GNBDERNIER)
Local Char     A_BUF10(5)(0..GNBDERNIER)
Local Char     A_BUF11(3)(0..GNBDERNIER)
Local Libelle  A_BUF12(0..GNBDERNIER)
Local Libelle  A_BUF13(0..GNBDERNIER)
Local Libelle  A_BUF14(0..GNBDERNIER)
If clalev([F:HRCTR9])>0 : Close Local File [HRCTR9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(15),
& Char     A_TAB2(40),
& Char     A_TAB3(40),
& Char     A_TAB4(20),
& Date     A_TAB5,
& Date     A_TAB6,
& Char     A_TAB7(20),
& Char     A_TAB8(5),
& Char     A_TAB9(5),
& Char     A_TAB10(5),
& Char     A_TAB11(3),
& Libelle  A_TAB12,
& Libelle  A_TAB13,
& Libelle  A_TAB14
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5,A_BUF6,A_BUF7,A_BUF8,A_BUF9,A_BUF10,A_BUF11,A_BUF12,A_BUF13,A_BUF14
& As [HRCTR9]
Return

$LEC_DERLU
Read [ID]ID0=[F:HRCTR]REFNUM
If fstat : Raz [F:ID] : Endif
Read [FCY]FCY0=[F:HRCTR]ETRFCY
If fstat : Raz [F:FCY] : Endif
Return

$CHARGE_DERLU
If clalev([F:HRCTR9])>0
 Read [HRCTR9] = [F:HRCTR9]A_TABI
 [L]CLE = [F:HRCTR9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:HRCTR9])>0
 Filter [HRCTR9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [HRAC1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:HRCTR9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:HRCTR]CTRNUM+"~"
 A_CLEDERLU += [F:HRCTR]REFNUM+"~"
 A_CLEDERLU += [F:HRCTR]CTRDAT+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:HRCTR9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:HRCTR9]
 Endif
Endif
Return

