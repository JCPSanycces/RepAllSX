Call TEXTE(5481,TIT) From OBJDIV
Return

$SETCLE
Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..1) , CLELIG(GLONAVA)
CLEPRIM = 'CTRNUM'
CLESEC(0) = 'REFNUM'
CLESEC(1) = 'CTRDAT'
Return

$OPTIONS
Local Integer  NBCOND
Local Char     CONDIT(50)(1..20)
Local Char     OPT(1)(1..20) , OPTSEL(20)
Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
NBCOND += 1
OPT(NBCOND)    = 'V'
CONDIT(NBCOND) = "STACTR=2"
Call TEXTE(47957,LIBOPT(NBCOND)) From OBJDIV
Call TEXTE(47956,MESSAG(NBCOND)) From OBJDIV
OPTSEL = ''
Return

$LIBPAR
