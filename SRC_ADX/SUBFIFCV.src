#<AdxTL>@(#)0.0.0.0 $Revision$ Object management FIFCV
######################################################################################
## Section automatically added (Object FIFCV) 09/28/2017 09:33:27 (MADOR)
######################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "CREATION"     : Gosub CREATION
    When "AVANT_CHOI"   : Gosub AVANT_CHOI
    When "MODIF"        : Gosub MODIF
    When "LIENS"        : Gosub LIENS
    When "RAZCRE"       : Gosub RAZCRE
    When "FERME"        : Gosub FERME
    When "AV_ANNULE"    : Gosub AV_ANNULE
    When "ANNULE"       : Gosub ANNULE
    When "ABANDON"      : Gosub ABANDON
    When "SETBOUT"      : Gosub SETBOUT
    When "EXEBOUT"      : Gosub EXEBOUT
    When "STATUT"       : Gosub STATUT
    When "APRES_MOD"    : Gosub APRES_CRE_MOD
    When "APRES_CRE"    : Gosub APRES_CRE_MOD
    When "FIN_ACTION"   : Gosub FIN_ACTION
  Endcase
Return
######################################################################################
######################################################################################
#
#   Object Events (ACTION)
#
######################################################################################
######################################################################################
$OUVRE
  Global Instance WFIFOCONVAR Using C_FIFOCONVAR

  Global  Shortint  COMPUTING, AVOID_MKSTAT
  Local  Integer  CREATION_MODE, I
  Local  Shortint NOL
  Local Tinyint TRACE_TYPES(0..)
  Local Char TRACE_MESSAGES(255)(0..)

  If !clalev([F:BAN])    : Local File BANK         [BAN]    : Endif
  If !clalev([F:CPY])    : Local File COMPANY      [CPY]    : Endif
  If !clalev([F:HAE])    : Local File GACCENTRY    [HAE]    : Endif
  If !clalev([F:DAE])    : Local File GACCENTRYD   [DAE]    : Endif

  ANOWRITE = 1
  [L]CREATION_MODE = (rowcount([F:FIFCV]) = 0 )

Return
######################################################################################
$CREATION
  Local  Integer WRET

  SetInstance WFIFOCONVAR With [F:FIFCV]
  [L]WRET = fmet WFIFOCONVAR.AINSERT()
  If [L]WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WFIFOCONVAR)
    Raz WFIFOCONVAR.AERROR
    GOK = 0 : GERR = 1
    Return
  Endif

  SetInstance [F:FIFCV] With WFIFOCONVAR

Return
######################################################################################
$AVANT_CHOI

  # creation mode for the very first conversion variance record
  If CREATION_MODE
    [L]CREATION_MODE = 0
    REPONSE=GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
  Endif

Return
######################################################################################
$MODIF
  Local  Integer WRET

  SetInstance WFIFOCONVAR With [F:FIFCV]

  [L]WRET = fmet WFIFOCONVAR.AUPDATE()
  If [L]WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WFIFOCONVAR)
    Raz WFIFOCONVAR.AERROR
    GOK = 0 : GERR = 1
    Return
  Endif

Return
######################################################################################
$LIENS
  Local  Integer WRET

  WFIFOCONVAR = NewInstance C_FIFOCONVAR AllocGroup null
  [L]WRET = fmet WFIFOCONVAR.AREAD([M:FIFCV0]FIFONO)

  If [L]WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WFIFOCONVAR)
    Raz WFIFOCONVAR.AERROR
    GERR = 1
    Raz [F:FIFCV] : Raz [M:FIFCV0]
    Return
  Endif

  Gosub BLOCK_FIELDS
  Gosub SHOW_LINES
  Gosub REFRESH_GENERATED_ENTRIES

Return
######################################################################################
$RAZCRE

  Gosub INITIALIZE
  Affzo [M:FIFCV0]

Return
######################################################################################
$FERME

  If (WFIFOCONVAR <> null) : FreeGroup WFIFOCONVAR : Endif
  Kill WFIFOCONVAR

Return
######################################################################################
$AV_ANNULE

  ANOWRITE = 1

Return
######################################################################################
$ANNULE
  Local  Integer WRET

  WRET = fmet WFIFOCONVAR.ADELETE()
  If [L]WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WFIFOCONVAR)
    Raz WFIFOCONVAR.AERROR
    GOK = 0 : GERR = 1
    Return
  Endif

Return
######################################################################################
$ABANDON

  If (WFIFOCONVAR.FIFONO = AVOID.ACHAR ) & GREP <> "C" & REP <> "C"
    Gosub INITIALIZE
  Endif

  Gosub BLOCK_FIELDS
Return
######################################################################################
$SETBOUT

Local Char BUTTONS_TO_DISABLE(30), BUTTONS_TO_ENABLE(30)
Local Integer WRET

If [M:FIFCV0]FLDPOS <> 2
  BUTTONS_TO_DISABLE += "2"
  # disable Data extract when record doesn't yet exist
  If (GREP = "C" | REP = "C" | !CLECUR)
    BUTTONS_TO_DISABLE += "1"
  Endif
Else
  BUTTONS_TO_DISABLE += "1A"
Endif

# disable Post button
GBIDC2 = "G" : Gosub AUTORIS_OPT From CONTX3
If ([M:FIFCV0]FLDPOS = 2 | GREP <> "" | !CLECUR | !GBIDI2)
  BUTTONS_TO_DISABLE += "3"
Endif

# Enable Account cancellation
If (WFIFOCONVAR <> null)
  [L]WRET = fmet WFIFOCONVAR.IS_LAST_FIFO()
  GBIDC2 = "R" : Gosub AUTORIS_OPT From CONTX3
  If ([M:FIFCV0]FLDPOS = 2 & GREP = "" & CLECUR & GBIDI2 & [L]WRET = 1)
    BUTTONS_TO_ENABLE += "4"
  Endif
Endif

Call VIREBOUT (CHAINE, BUTTONS_TO_DISABLE) From GOBJET

CHMEN += BUTTONS_TO_ENABLE

Return
######################################################################################
$EXEBOUT
  [V]COMPUTING = 0
  Case BOUT
    When "1"  : Gosub COMPUTE_FIFO
    When "3"  : Gosub POST_FIFO
  Endcase

Return
######################################################################################
$STATUT

Case BOUT
  When "4"
    If GOK
      Gosub DOCUMENT_REVERSAL
    Else
      GOK = 1
    Endif
Endcase

Return
######################################################################################
$APRES_CRE_MOD

  Gosub RELIT From GOBJSUB

Return
######################################################################################
$FIN_ACTION

  If BOUT = "1" &  GREP=""
    Gosub ENTRE_MODIF From GOBJSUB
  Endif

  Call LOG_TRACE([L]TRACE_MESSAGES, [L]TRACE_TYPES)

Return
######################################################################################
$SHOW_LINES
  Local Integer I, II
  Effzo [M:FIFCV1]
  II = 0
  # SCREEN FIFCV1 - Entry journals
  For I = 1 To maxtab(WFIFOCONVAR.FIFCVD)
    If WFIFOCONVAR.FIFCVD(I)<>null and find(WFIFOCONVAR.FIFCVD(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      If (WFIFOCONVAR.FIFCVD(I).ISCURSTO = 1)
        #blue
        Chgstl [M:FIFCV1]NBLIG(II)   With  "SIMPLN1"
      Elsif (WFIFOCONVAR.FIFCVD(I).SNS = 1)
        #green
        Chgstl [M:FIFCV1]NBLIG(II)   With  "SIMPLN2"
      Elsif (WFIFOCONVAR.FIFCVD(I).SNS = -1)
        #red
        Chgstl [M:FIFCV1]NBLIG(II)   With  "NBNEGATIF"
      Endif

      [M:FIFCV1]ACCDAT(II) = WFIFOCONVAR.FIFCVD(I).ACCDAT
      [M:FIFCV1]AMTCUR(II) = WFIFOCONVAR.FIFCVD(I).AMTCUR
      [M:FIFCV1]AMTLED(II) = WFIFOCONVAR.FIFCVD(I).AMTLED
      [M:FIFCV1]BALSH(II) = WFIFOCONVAR.FIFCVD(I).BALSH
      [M:FIFCV1]BPRVCR(II) = WFIFOCONVAR.FIFCVD(I).BPRVCR
      [M:FIFCV1]EXRATDIF(II) = WFIFOCONVAR.FIFCVD(I).EXRATDIF
      [M:FIFCV1]FORSETTL(II) = WFIFOCONVAR.FIFCVD(I).FORSETTL
      [M:FIFCV1]MULRATE(II) = WFIFOCONVAR.FIFCVD(I).MULRATE
      [M:FIFCV1]NUM(II) = WFIFOCONVAR.FIFCVD(I).NUM
      [M:FIFCV1]RATECALC(II) = WFIFOCONVAR.FIFCVD(I).RATECALC
      [M:FIFCV1]TOTAMO(II) = WFIFOCONVAR.FIFCVD(I).TOTAMO
      [M:FIFCV1]TYP(II) = WFIFOCONVAR.FIFCVD(I).TYP
      #brown
      Chgstl [M:FIFCV1]FORSETTL(II)   With  "SIMPLN3"
      II+=1
    Endif
    [M:FIFCV1]NBLIG = II
    Affzo [M:FIFCV1]
  Next

  # SCREEN FIFCV2 - Dimensions
  For I = 1 To maxtab(WFIFOCONVAR.C_DIECCE)
    If WFIFOCONVAR.C_DIECCE(I) <> null and find(WFIFOCONVAR.C_DIECCE(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL)=0
      If (I <= func AFNC.ACTIV("ANA"))
        [M:FIFCV2]DIE(I-1) = WFIFOCONVAR.C_DIECCE(I).DIE
        [M:FIFCV2]CCE(I-1) = WFIFOCONVAR.C_DIECCE(I).CCE
        [M:FIFCV2]NBAXE = I
      Else
        GMESSAGE =  mess(321,107,1)
        OK = 0 : GERR = 1
        Break
      Endif
    Endif
  Next
  Affzo [M:FIFCV2]

Return
######################################################################################
$INITIALIZE
  Local  Integer WRET
  Local  Integer FLDPOS_DEFAULT : FLDPOS_DEFAULT = 1

  If (WFIFOCONVAR <> null) : FreeGroup WFIFOCONVAR : Endif
  WFIFOCONVAR = NewInstance C_FIFOCONVAR AllocGroup null

  WRET = fmet WFIFOCONVAR.AINIT()
  If [L]WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WFIFOCONVAR)
    Raz WFIFOCONVAR.AERROR
    GOK = 0 : GERR = 1
    Return
  Endif

  SetInstance [F:FIFCV] With WFIFOCONVAR
  [M:FIFCV0] = [F:FIFCV]

  If (WFIFOCONVAR.FIFONO = AVOID.ACHAR)
    [M:FIFCV0]FLDPOS = FLDPOS_DEFAULT
    Affzo [M:FIFCV0]FLDPOS
    Effzo [M:FIFCV2]
  Endif

Return
######################################################################################
$CHECK_IF_ERROR

  GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WFIFOCONVAR)
  If GMESSAGE <> ""
    Raz WFIFOCONVAR.AERROR
    GOK = 0 : GERR = 1
    If [V]AVOID_MKSTAT = 0
      mkstat = 2
    Endif
  Endif
  [V]AVOID_MKSTAT = 0

Return
######################################################################################
$BLOCK_FIELDS

    If (WFIFOCONVAR.FIFONO <> AVOID.ACHAR)
        Diszo [M:FIFCV0]FCY
        Diszo [M:FIFCV0]FIFTYP
        Diszo [M:FIFCV0]FIFCOD

        Actzo [M:FIFCV0]FINDAT
        If [M:FIFCV0]FLDPOS = 2
            Diszo [M:FIFCV0]STARTDAT
            Diszo [M:FIFCV0]FINDAT
        Endif
    Else
        [M:FIFCV0]FLDPOS = 1
        Affzo [M:FIFCV0]FLDPOS
    Endif

    If WFIFOCONVAR.SDADIS = 2
        Diszo [M:FIFCV0]STARTDAT
    Elsif [M:FIFCV0]FLDPOS = 1
        Actzo [M:FIFCV0]STARTDAT
    Endif

Return
######################################################################################
## Section automatically added (screen FIFCV0) 10/02/2017 15:27:00 (MADOR)
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
    WFIFOCONVAR.FCY = VALEUR
    Gosub CHECK_IF_ERROR

    If !mkstat
        [M:FIFCV0]CPY = WFIFOCONVAR.CPY
    Endif
End
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

    If [M:FIFCV0]FCY <> ""
        Local Integer SAVREGTYP : [L]SAVREGTYP = [M:FIFCV0]FIFTYP
        Gosub INITIALIZE
        [M:FIFCV0]FCY = VALEUR
        [M:FIFCV0]FIFTYP = [L]SAVREGTYP
    Endif

    WFIFOCONVAR.FCY = VALEUR
    WFIFOCONVAR.FIFTYP = [M:FIFCV0]FIFTYP
    [M:FIFCV0]CPY = WFIFOCONVAR.CPY

    Affzo [M:FIFCV0]
    Affzo [M:FIFCV2]
End
######################################################################################
## Section automatically added (screen FIFCV0) 10/02/2017 16:36:00 (MADOR)
######################################################################################
Subprog AM_FIFCOD(VALEUR)
Variable Char    VALEUR()

    Local Integer WRET
    Local Date FINDAT
    Local Tinyint NBDIE, I

    WFIFOCONVAR.FIFCOD = VALEUR

    [M:FIFCV0]FLDBIN = WFIFOCONVAR.FLDBIN
    [M:FIFCV0]FLDACC = WFIFOCONVAR.FLDACC
    [M:FIFCV0]FLDCUR = WFIFOCONVAR.FLDCUR

    Affzo [M:FIFCV0]FLDBIN
    Affzo [M:FIFCV0]FLDACC
    Affzo [M:FIFCV0]FLDCUR

    [M:FIFCV0]STARTDAT = fmet WFIFOCONVAR.STARTDAT_INITIALIZE([M:FIFCV0]FIFONO, VALEUR)
    WFIFOCONVAR.STARTDAT = [M:FIFCV0]STARTDAT
    [M:FIFCV0]SDADIS = WFIFOCONVAR.SDADIS

    If WFIFOCONVAR.SDADIS = 2
      Diszo [M:FIFCV0]STARTDAT
    Else
      Actzo [M:FIFCV0]STARTDAT
    Endif

    [M:FIFCV0]FINDAT = fmet WFIFOCONVAR.FINDAT_INITIALIZE([M:FIFCV0]STARTDAT, [M:FIFCV0]CPY)
    Affzo [M:FIFCV0]FINDAT

    [M:FIFCV0]SDADIS = WFIFOCONVAR.SDADIS
    Affzo [M:FIFCV0]STARTDAT

    [L]FINDAT = [M:FIFCV0]FINDAT
    [V]AVOID_MKSTAT = 1 : Gosub FINDATE_UPDATE

    If dim([M:FIFCV2]CCE) > 0
      [L]NBDIE = fmet WFIFOCONVAR.DIMENSION_INITIALIZE()
      If [L]NBDIE <> [V]CST_ANOTDEFINED
        For I=1 To NBDIE
          [M:FIFCV2]DIE(I-1) = WFIFOCONVAR.C_DIECCE(I).DIE
          [M:FIFCV2]CCE(I-1) = WFIFOCONVAR.C_DIECCE(I).CCE
        Next

        [M:FIFCV2]NBAXE = NBDIE
        Affzo [M:FIFCV2]
      Endif
    Endif
End
######################################################################################
## Section automatically added (screen FIFCV0) 10/04/2017 11:52:50 (MADOR)
######################################################################################
Subprog AM_FIFTYP(VALEUR)
Variable Integer VALEUR

    Local Char SAVFCY(5) : [L]SAVFCY = [M:FIFCV0]FCY
    Gosub INITIALIZE
    [M:FIFCV0]FCY = [L]SAVFCY
    [M:FIFCV0]FIFTYP = VALEUR

    WFIFOCONVAR.FCY = [L]SAVFCY
    WFIFOCONVAR.FIFTYP = VALEUR
    [M:FIFCV0]CPY = WFIFOCONVAR.CPY

    Affzo [M:FIFCV0]
    Affzo [M:FIFCV2]
End
######################################################################################
## Section automatically added (screen FIFCV0) 10/04/2017 16:08:12 (MADOR)
######################################################################################
Subprog C_FIFCOD(VALEUR)
Variable Char    VALEUR()

    Local  Integer WRET

    [L]WRET = fmet WFIFOCONVAR.FIFCOD_VALIDATE([M:FIFCV0]FIFONO, VALEUR, [M:FIFCV0]CPY, [M:FIFCV0]FCY)

    If [L]WRET >= [V]CST_AERROR
        Gosub CHECK_IF_ERROR
    Endif
End
######################################################################################
## Section automatically added (screen FIFCV0) 10/06/2017 10:51:05 (MADOR)
######################################################################################
Subprog AM_STARTDAT(VALEUR)
Variable Date    VALEUR
    Local  Integer WRET

    [L]WRET = fmet WFIFOCONVAR.STARTDAT_VALIDATE(VALEUR, [M:FIFCV0]FIFCOD)

    If [L]WRET >= [V]CST_AERROR
        Gosub CHECK_IF_ERROR
    Else
        WFIFOCONVAR.STARTDAT = VALEUR
    Endif

End
######################################################################################
## Section automatically added (screen FIFCV0) 10/06/2017 17:45:54 (MADOR)
######################################################################################
Subprog AM_FINDAT(VALEUR)
Variable Date    VALEUR
Local  Date FINDAT

If [M:FIFCV0]FIFONO = ""
    [L]FINDAT = VALEUR
    Gosub FINDATE_UPDATE
Endif

End
######################################################################################
## Section automatically added (screen FIFCV0) 11/07/2017 15:41:35 (MANOW)
######################################################################################
Subprog C_FINDAT(VALEUR)
Variable Date    VALEUR
Local Integer OKCAN : OKCAN = 1 : #cancel
Local Date    FINDAT
Local Date    LASTDATE : [L]LASTDATE = [M:FIFCV0]FINDAT

[V]COMPUTING = 0
If(VALEUR <> [L]LASTDATE & [M:FIFCV0]FIFONO <> "") # - we should check also during creation
  Call AVERTIR (mess(10,7708,1), OKCAN) From GESECRAN
  If (OKCAN <> 2)    #rollback to previous date
    mkstat = 2
  Elsif (OKCAN = 2) #all the lines from the screen except initial stock, will be removed from the screen
    [V]COMPUTING = 1
    [L]FINDAT = VALEUR
    Gosub FINDATE_UPDATE
    If mkstat <> 2
        Gosub COMPUTE_FIFO
        Affzo [M:FIFCV1]NBLIG
    Endif
  Endif
Endif

End
######################################################################################
## Section automatically added (screen FIFCV2) 11/28/2017 08:48:11 (MRDAB)
######################################################################################
Subprog AM_CCE(VALEUR)
Variable Char    VALEUR()

WFIFOCONVAR.C_DIECCE(nolign).CCE = VALEUR

End
######################################################################################

$FINDATE_UPDATE
Local  Integer WRET
[L]WRET = fmet WFIFOCONVAR.FINDAT_VALIDATE([L]FINDAT, [M:FIFCV0]CPY)
If [L]WRET >= [V]CST_AERROR
  Gosub CHECK_IF_ERROR
Else
  WFIFOCONVAR.FINDAT = [L]FINDAT
#  [L]WRET = fmet WFIFOCONVAR.PAYMENTS_VALIDATE()
#  If [L]WRET >= [V]CST_AERROR
#    Gosub CHECK_IF_ERROR
#  Endif
Endif

Return
######################################################################################
$COMPUTE_FIFO
Local  Integer WRET

[L]WRET = fmet WFIFOCONVAR.COMPUTE_FIFO()
If [L]WRET >= [V]CST_AERROR
  GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WFIFOCONVAR)
  Raz WFIFOCONVAR.AERROR
  GOK = 0 : GERR = 1
  Return
Endif

[M:FIFCV0]SDADIS = WFIFOCONVAR.SDADIS
[M:FIFCV0]TOTAMOH = WFIFOCONVAR.TOTAMOH
If WFIFOCONVAR.SDADIS = 2
  Diszo [M:FIFCV0]STARTDAT
Elsif WFIFOCONVAR.SDADIS = 1
  Actzo [M:FIFCV0]STARTDAT
Endif
Gosub SHOW_LINES

Return
######################################################################################
$POST_FIFO
Local Integer VALIDATION_RESULT, PROCEED_FLAG, WRET

[L]PROCEED_FLAG = 1

Raz [V]GTYPPCE, [V]GNUMPCE

# prompt to post or not
Call OUINON(mess(11,7708,1), [L]PROCEED_FLAG) From GESECRAN
# perform posting
If [L]PROCEED_FLAG = 2

  [L]TRACE_MESSAGES(0) = mess(23,7708,1)
  [L]TRACE_TYPES(0) = AVOID.AINT

  [L]TRACE_MESSAGES(maxtab([L]TRACE_MESSAGES) + 1) = mess(23,7708,1) + ":" - WFIFOCONVAR.FIFONO
  [L]TRACE_TYPES(maxtab([L]TRACE_MESSAGES)) = 0

  [L]WRET = fmet WFIFOCONVAR.POST_FIFO()
  If [L]WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WFIFOCONVAR)

    [L]TRACE_MESSAGES(maxtab([L]TRACE_MESSAGES) + 1) = GMESSAGE
    [L]TRACE_TYPES(maxtab([L]TRACE_MESSAGES)) = 1

    Raz WFIFOCONVAR.AERROR
    GERR = 1
    Return
  Else
    If [V]GNUMPCE <> AVOID.ACHAR & [V]GTYPPCE <> AVOID.ACHAR
      [L]TRACE_MESSAGES(maxtab([L]TRACE_MESSAGES) + 1) = ">" - mess(40,107,1) - [V]GTYPPCE - [V]GNUMPCE
    Else
      [L]TRACE_MESSAGES(maxtab([L]TRACE_MESSAGES) + 1) = mess(25,7708,1)
    Endif
    [L]TRACE_TYPES(maxtab([L]TRACE_MESSAGES)) = 0

    Gosub RELIT From GOBJSUB
  Endif

Endif

Return
######################################################################################
$REFRESH_GENERATED_ENTRIES
Local Char LREFINT(GLONVCR + 5)

If WFIFOCONVAR.FIFONO <> ""
  [L]LREFINT = 'FIFO' - WFIFOCONVAR.FIFONO
  nolign = 0
  Link [F:DAE] With [F:HAE]HAE0 ~= [F:DAE]TYP;NUM As [GENENT] Where [F:HAE]REFINT = [L]LREFINT
&               and [F:HAE]NUM = [F:DAE]NUM and [F:DAE]ACC = WFIFOCONVAR.FLDACC
  For [F:GENENT]
    [M:FIFCV3]PSTACENUM(nolign) = [F:HAE]NUM
    [M:FIFCV3]PSTACETYP(nolign) = [F:HAE]TYP
    [M:FIFCV3]PSTACEACCDAT(nolign) = [F:HAE]ACCDAT
    [M:FIFCV3]PSTACEAMT(nolign) = [F:DAE]AMTLED
    [M:FIFCV3]PSTACECUR(nolign) = [F:DAE]CURLED
    nolign += 1
    If nolign >= dim([M:FIFCV3]PSTACENUM)
      Break
    Endif
  Next
  [M:FIFCV3]NBLIG = nolign

  Close File [F:GENENT]

Endif

Return
######################################################################################
$DOCUMENT_REVERSAL

Local Integer WRET
Local Char VCRNUM(GLONVCR), VCRTYP(GLONTPY)

[L]VCRNUM = WFIFOCONVAR.FLDJOE
[L]VCRTYP = WFIFOCONVAR.FLDJOETYP
[L]TRACE_MESSAGES(0) = mess(24,7708,1)
[L]TRACE_TYPES(0) = AVOID.AINT

[L]TRACE_MESSAGES(maxtab([L]TRACE_MESSAGES) + 1) = mess(24,7708,1) + ":" - WFIFOCONVAR.FIFONO
[L]TRACE_TYPES(maxtab([L]TRACE_MESSAGES)) = 0

Raz [V]GTYPPCE, [V]GNUMPCE

[L]WRET = fmet WFIFOCONVAR.DOCUMENT_REVERSAL([M:FIFCV0]RVSEXTSNS,[M:FIFCV0]RVSDESVCR,[M:FIFCV0]RVSACCDAT)

If [L]WRET >= [V]CST_AERROR
  GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WFIFOCONVAR)

  [L]TRACE_MESSAGES(maxtab([L]TRACE_MESSAGES) + 1) = GMESSAGE
  [L]TRACE_TYPES(maxtab([L]TRACE_MESSAGES)) = 1

  Raz WFIFOCONVAR.AERROR
  GOK = 0 : GERR = 1
  Return
Else
  If [V]GNUMPCE <> AVOID.ACHAR & [V]GTYPPCE <> AVOID.ACHAR
    [L]TRACE_MESSAGES(maxtab([L]TRACE_MESSAGES) + 1) = ">" - [V]GTYPPCE - [V]GNUMPCE - mess(10,107,1) - [L]VCRTYP - [L]VCRNUM
  Else
    [L]TRACE_MESSAGES(maxtab([L]TRACE_MESSAGES) + 1) = mess(26,7708,1)
  Endif
  [L]TRACE_TYPES(maxtab([L]TRACE_MESSAGES)) = 0
Endif

Gosub RELIT From GOBJSUB

Return
######################################################################################
### input values: TRACE_MESSAGES array of messages to be displayed
###             : TRACE_TYPES array of types of messages - 0 - info, 1 - error
###             : 0 index reserved for the name of the trace
######################################################################################
Subprog LOG_TRACE(TRACE_MESSAGES, TRACE_TYPES)
Variable Char TRACE_MESSAGES()
Variable Tinyint TRACE_TYPES

Local Integer I

If !GSERVEUR & maxtab([L]TRACE_MESSAGES) > -1
  Call OUVRE_TRACE([L]TRACE_MESSAGES(0)) From LECFIC

  For I = 1 To maxtab([L]TRACE_MESSAGES)
    If [L]TRACE_MESSAGES(I) <> AVOID.ACHAR
      Call ECR_TRACE([L]TRACE_MESSAGES(I), [L]TRACE_TYPES(I)) From GESECRAN
    Endif
  Next

  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
  Call SUPP_TRACE From LECFIC
  Raz [L]TRACE_MESSAGES, [L]TRACE_TYPES
Endif

End
######################################################################################

