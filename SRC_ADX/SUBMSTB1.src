#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
$INIT_VARIABLE
Local Integer INBNONTRT
Local Integer INBTRTOK
Local Integer INBTRTKO
Local Integer IDIMREP_BPC  #nombre représentants associés à un client
Local Integer IDIMREP_BPD  #nombre représentants associés à un client livré
Local Integer IDIMREP_BRS  #nombre représentants secondaires
Local Integer IREPONSE_REP
Local Integer IREPONSE_SECTEUR

  IDIMREP_BPC = func AFNC.ACTIV("REC") #nombre représentants associés à un client
  IDIMREP_BRS = func AFNC.ACTIV("BRS") #nombre représentants secondaires
  IDIMREP_BPD = func AFNC.ACTIV("RED") #nombre représentants associés à un client livré
Return

##########################################################################################################
# gestion de l'affectation d'un secteur de marché
##########################################################
$TRT_MST
Local Char SZOLDADRESSE(GLONADR)       # Issue X3-61585 - 2018-04-19 by FGR
Local Char SZNEWADRESSE(GLONADR)       # Issue X3-61585 - 2018-04-19 by FGR
Local Integer IFOUND

  IREPONSE_REP = 0
  IREPONSE_SECTEUR = 0
  Raz SZOLDADRESSE
  Raz SZNEWADRESSE
  IFOUND = 0
  #GMSTACT
  #    1 : Aucun
  #    2 : Dynamique
  #    3 : Manuelle
  #Si pas automatique on ne fait rien
  If GMSTACT <> 2 Then
    Return
  Endif
  #On ne traite que les clients ou les prospects
  If [F:BPR]BPCFLG <> 2 and [F:BPR]PPTFLG <> 2 Then
    Return
  Endif
  #---------------------------------------------------#
  If !clalev([F:MAR]) : Local File MARASSREP [MAR] : Endif
  If !clalev([F:MAR2]) : Local File MARASSREP [MAR2] : Endif
  If !clalev([F:RSE]) : Local File REPSEC [RSE] : Endif
  If !clalev([F:MAD]) : Local File MARASSDEF [MAD] : Endif
  If !clalev([F:MST]) : Local File MARSCT [MST] : Endif
  If !clalev([F:MDF]) : Local File MARDEF [MDF] : Endif
  If !clalev([F:MRS]) : Local File MARREPSEC [MRS] : Endif
  If !clalev([F:BPD]) : Local File BPDLVCUST [BPD] : Endif
  #---------------------------------------------------#
  Gosub INIT_VARIABLE
  If IDIMREP_BPC = 0 Then
    #On ne gère pas de représentant
    Return
  Endif
  #---------------------------------------------------#
  #recherche nouvelle adresse par défaut
  IFOUND = find(2,[M]BPAADDFLG(0..[M]NBADR-1))
  If IFOUND > 0 Then
    SZNEWADRESSE = [M]CODADR(IFOUND-1)
  Endif
  #Ancienne Adresse
  Case GSZCRMOBJET
    When "BPR"
      SZOLDADRESSE = [M:BPR0]XPREFLGADD
    When "BPP"
      SZOLDADRESSE = [M:BPP0]XPREFLGADD
    When "BPC"
      SZOLDADRESSE = [M:BPC0]XPREFLGADD
    When "BPS"
      SZOLDADRESSE = [M:BPS0]XPREFLGADD
    When "REP"
      SZOLDADRESSE = [M:REP0]XPREFLGADD
    When "BPT"
      SZOLDADRESSE = [M:BPT0]XPREFLGADD
    When Default
      SZOLDADRESSE = ""
  Endcase
  #---------------------------------------------------#
  If SZOLDADRESSE <> "" and SZOLDADRESSE <> SZNEWADRESSE Then
    Call MODIF_ADRDEFAUT(IDIMREP_BPC, IDIMREP_BPD, [F:BPR]BPRNUM, [F:BPR]BPCFLG, SZOLDADRESSE, SZNEWADRESSE)
    If GOK < 1 Then
      Return
    Endif
  Endif
  #---------------------------------------------------#
  # Gestion des changements de représentants sur les écrans de prospects ou clients
  If GSZCRMOBJET = "BPP" or GSZCRMOBJET = "BPC" Then
    Call GERE_MODIF_REP(IDIMREP_BPC, IDIMREP_BPD, [F:BPR]BPRNUM, SZNEWADRESSE, [F:BPR]BPCFLG, GKEEPREP, GKEEPMST)
    If GOK < 1 Then
      Return
    Endif
  Endif
  #---------------------------------------------------#
  #recherche des secteurs
  Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:BPR]BPRNUM
  For [BPA]
    If [F:BPR]BPCFLG = 2 Then
      # Si c'est un CLIENT : il faut lire les clients livrés (il peut ne pas y en avoir)
      Read [BPD]BPD0=[F:BPR]BPRNUM;[F:BPA]BPAADD
      If fstat <> 0 Then
        Raz [F:BPD]
      Endif
    Endif
    Read [BPC]BPC0=[F:BPR]BPRNUM
    If fstat <> 0 Then
      Raz [F:BPC]
    Endif
    Call GERE_ONE_BPC_ADR_SEC(IDIMREP_BPC, IDIMREP_BPD, IDIMREP_BRS, [F:BPR]BPRNUM, SZNEWADRESSE, [F:BPA]BPAADD, [F:BPR]BPCFLG, 0, GKEEPREP, GKEEPMST, IREPONSE_REP, IREPONSE_SECTEUR,
&                             INBTRTOK, INBNONTRT, INBTRTKO)
    If GOK < 1 Then
      Break
    Endif
  Next
  Filter [BPA]
Return

##########################################################################################################
Subprog MODIF_ADRDEFAUT(IDIMREP_BPC, IDIMREP_BPD, SZBPRNUM, IBPCFLG, SZOLDADRESSE, SZNEWADRESSE)
Value Integer IDIMREP_BPC
Value Integer IDIMREP_BPD
Value Char SZBPRNUM
Value Integer IBPCFLG
Value Char SZOLDADRESSE
Value Char SZNEWADRESSE

Local Integer IAFFECT_MANUEL_BPC_NEW
Local Integer IAFFECT_MANUEL_BPD_NEW

  #-----------------------------------------
  #On recherche si il y avait les secteurs associé
  IAFFECT_MANUEL_BPC_NEW = func GET_MANUEL_BPD (IDIMREP_BPC, SZBPRNUM, SZNEWADRESSE, "BPR")
  #-----------------------------------------
  # Gestion de l'affectation des représentants principaux ATTENTION ICI : BPC
  If IAFFECT_MANUEL_BPC_NEW = 1 Then
    Call REP_BPC_AUTO(IDIMREP_BPC, SZBPRNUM, SZOLDADRESSE, SZNEWADRESSE)
  Else
    Call REP_BPC_MANU(IDIMREP_BPC, SZBPRNUM, SZOLDADRESSE, SZNEWADRESSE)
  Endif
  If GOK < 1 Then
    End
  Endif
  If GMSTDLV = 2 and IBPCFLG = 2 Then
    If IDIMREP_BPD = 0 Then
      End
    Endif
    #-----------------------------------------
    # Il faut mettre à jour les clients livrés ATTENTION ICI : BPD
    IAFFECT_MANUEL_BPD_NEW = func GET_MANUEL_BPD (IDIMREP_BPD, SZBPRNUM, SZNEWADRESSE, "BPD")
    #Gestion de l'affectation des clients livrés
    If IAFFECT_MANUEL_BPD_NEW = 1 Then
      Call REP_BPD_AUTO(IDIMREP_BPD, SZBPRNUM, SZOLDADRESSE, SZNEWADRESSE)
    Else
      Call REP_BPD_MANU(IDIMREP_BPD, SZBPRNUM, SZOLDADRESSE, SZNEWADRESSE)
    Endif
    If GOK < 1 Then
      End
    Endif
  Endif
End

##########################################################################################################
# Rend : 1 S'il y a au moins un représentant forcé manuellement
#        0 Sinon
#####################################################################
Funprog GET_MANUEL_BPD(IDIMREP, SZBPRNUM, SZADRESSE, SZRECORDTYP)
Value Integer IDIMREP
Value Char SZBPRNUM
Value Char SZADRESSE
Value Char SZRECORDTYP

Local Integer IINDICE
Local Integer IARENDRE

  IARENDRE = 0
  For IINDICE = 1 To IDIMREP
    Read [MAR]MAR2=SZBPRNUM;SZADRESSE;SZRECORDTYP;IINDICE
    If fstat = 0 Then
      If [F:MAR]MANASS = 1 Then
        IARENDRE = 1
        Break
      Else
        IARENDRE = 0
      Endif
    Else
      IARENDRE = 0
      Break
    Endif
  Next
End IARENDRE

##########################################################################################################
# Affectation du client
#####################################################################
##########################################################################################################
# Affectation manuelle du client
Subprog REP_BPC_MANU(IDIMREP_BPC, SZBPRNUM, SZOLDADRESSE, SZNEWADRESSE)
Value Integer IDIMREP_BPC
Value Char SZBPRNUM
Value Char SZOLDADRESSE
Value Char SZNEWADRESSE

Local Integer IINDICE
Local Integer IBERROR

  # Il faut lire [BPC] parce qu'on n'a pas forcément modifié l'adresse principale depuis les clients
  Read [BPC]BPC0=[F:BPR]BPRNUM
  If fstat <> 0 Then
    # Si on n'arrive pas à lire le client c'est qu'il y a quelque chose qui ne va pas dans la base !
    GMESSAGE = mess(523,196,1) - "(a)"
    GERR = 1
    GOK = 0
    End
  Endif
  For IINDICE = 1 To IDIMREP_BPC
    Read [MAR]MAR2=SZBPRNUM;SZNEWADRESSE;"BPR";IINDICE
    If fstat = 0 Then
      Call WRITE_MAR(1, [F:MAR]RECORDNUM, [F:MAR]RECORDADD, [F:MAR]RECORDTYP, [F:BPC]REP(IINDICE-1), [F:MAR]REPTYP, [F:MAR]REPMSS, [F:MAR]REPITM, 1, IBERROR)
      If IBERROR Then
        # Erreur lors de l'affectation du secteur de marché.
        GMESSAGE = mess(523,196,1) - "(b)"
        GERR = 1
        GOK = 0
        Break
      Endif
    Endif
  Next
  If GOK < 1 Then
    End
  Endif
  #Représentants secondaires
  Call FAIT_SUIVRE_REP_SEC(SZBPRNUM, SZOLDADRESSE, SZNEWADRESSE)
  If GOK < 1 Then
    End
  Endif
End

##########################################################################################################
# Affectation automatique du client
Subprog REP_BPC_AUTO(IDIMREP_BPC, SZBPRNUM, SZOLDADRESSE, SZNEWADRESSE)
Value Integer IDIMREP_BPC
Value Char SZBPRNUM
Value Char SZOLDADRESSE
Value Char SZNEWADRESSE

Local Integer IBERROR
Local Integer IAUTASS

  Readlock [BPC]BPC0=[F:BPR]BPRNUM
  If fstat <> 0 Then
    # Si on n'arrive pas à lire le client c'est qu'il y a quelque chose qui ne va pas dans la base !
    GMESSAGE = mess(523,196,1) - "(c)"
    GERR = 1
    GOK = 0
    End
  Endif
  Raz [F:BPC]REP
  Filter [MAR] Where [F:MAR]RECORDNUM = SZBPRNUM and [F:MAR]RECORDADD = SZNEWADRESSE and [F:MAR]RECORDTYP = "BPR" and [F:MAR]REPTYP > 0
  For [MAR]MAR2
    If [F:MAR]REPTYP > IDIMREP_BPC Then
      # Pour traiter le cas improbable ou on aurait réduit le nb de représentant sur les clients livrés
      # On détruit ceux qui dépassent
      Delete [MAR]Curr
      If fstat <> 0 Then
        # Erreur lors de l'affectation du secteur de marché.
        GMESSAGE = mess(523,196,1) - "(d)"
        GERR = 1
        GOK = 0
        Break
      Endif
    Else
      [F:BPC]REP([F:MAR]REPTYP-1) = [F:MAR]REPNUM
    Endif
  Next
  Filter [MAR]
  If GOK < 1 Then
    End
  Endif
  Call FLDUPD("BPC") From OBJDIV  # Issue X3-90630 - 2018-05-18 by FGR : To force update of all technical fields
  Rewrite [BPC]
  If fstat Then
    GMESSAGE = mess(523,196,1) - "(e)" #Erreur lors de l'affectation du secteur de marché.
    GERR = 1
    GOK = 0
    End
  Endif
  #Représentants secondaires
  # C'était en commentaire... Mais pour moi si les représentants principaux changent sur le tiers avec le changement d'adresse principale
  #  Les secondaires doivent changer aussi
  Delete [RSE] Where [F:RSE]BPCNUM = [F:BPR]BPRNUM
  If fstat <> 0 Then
    GMESSAGE = mess(523,196,1) - "(f)" #Erreur lors de l'affectation du secteur de marché.
    GERR = 1
    GOK = 0
    End
  Endif
  Filter [MAR] Where [F:MAR]RECORDNUM = [F:BPR]BPRNUM and [F:MAR]RECORDADD = SZNEWADRESSE and [F:MAR]RECORDTYP = "BPR" and [F:MAR]REPTYP = 0
  For [MAR]MAR2
    If [F:MAR]MANASS = 1 Then
      IAUTASS = 0
    Else
      IAUTASS = 1
    Endif
    Call WRITE_RSE(0, [F:MAR]RECORDNUM, [F:MAR]REPNUM, [F:MAR]REPMSS, [F:MAR]REPITM, IAUTASS, IBERROR)
    If IBERROR Then
      GMESSAGE = mess(523,196,1) - "(h)" #Erreur lors de l'affectation du secteur de marché.
      GERR = 1
      GOK = 0
      Break
    Endif
  Next
  Filter [MAR]
  If GOK < 1 Then
    End
  Endif
End

##########################################################################################################
Subprog FAIT_SUIVRE_REP_SEC(SZBPRNUM, SZOLDADRESSE, SZNEWADRESSE)
Value Char SZBPRNUM
Value Char SZOLDADRESSE
Value Char SZNEWADRESSE

Local Integer IBERROR

  #Représentants secondaires :
  #   SUR LES TIERS ([RSE]) : Les représentants secondaires sont liés au tiers.
  #   SUR LES SECTEURS DE MARCHE ([MAR]) : Chaque adresse peut avoir ses représentant secondaires
  #      => Donc quand on recopie les représentants secondaires sur une autre adresse on ne les détruit pas de leur adresse d'origine
  Delete [MAR] Where [F:MAR]RECORDNUM = SZBPRNUM and [F:MAR]RECORDADD = SZNEWADRESSE and [F:MAR]RECORDTYP = "BPR" and [F:MAR]REPTYP = 0
  If fstat <> 0 Then
    # Erreur lors de l'affectation du secteur de marché.
    GMESSAGE = mess(523,196,1) - "(i)"
    GERR = 1
    GOK = 0
    End
  Endif
  # On peut se permettre de lire par rapport à [MAR2] parce que l'écran de saisie des représentants secondaire entretien en même
  # temps [MAR] et [RSE] lorsqu'on les modifie manuellement (TRTREPSEC)
  Filter [MAR2] Where [F:MAR2]RECORDNUM = SZBPRNUM and [F:MAR2]RECORDADD = SZOLDADRESSE and [F:MAR2]RECORDTYP = "BPR" and [F:MAR2]REPTYP = 0
  For [MAR2]MAR2
    Call WRITE_MAR(0, [F:MAR2]RECORDNUM, SZNEWADRESSE, [F:MAR2]RECORDTYP, [F:MAR2]REPNUM, [F:MAR2]REPTYP, [F:MAR2]REPMSS, [F:MAR2]REPITM, [F:MAR2]MANASS, IBERROR)
    If IBERROR Then
      # Erreur lors de l'affectation du secteur de marché.
      GMESSAGE = mess(523,196,1) - "(j)"
      GERR = 1
      GOK = 0
      Break
    Endif
  Next
  Filter [MAR2]
  If GOK < 1 Then
    End
  Endif
End

##########################################################################################################
# Affectation client livré
#####################################################################
#Affectation manuelle
Subprog REP_BPD_MANU(IDIMREP_BPD, SZBPRNUM, SZOLDADRESSE, SZNEWADRESSE)
Value Integer IDIMREP_BPD
Value Char SZBPRNUM
Value Char SZOLDADRESSE
Value Char SZNEWADRESSE

Local Integer IINDICE
Local Integer IBERROR

  #Affectation manuelle
  Read [BPD]BPD0=SZBPRNUM;SZOLDADRESSE
  If fstat = 0 Then
    For IINDICE = 1 To IDIMREP_BPD
      Read [MAR]MAR2=SZBPRNUM;SZNEWADRESSE;"BPD";IINDICE
      If fstat = 0 Then
        Call WRITE_MAR(1, [F:MAR]RECORDNUM, [F:MAR]RECORDADD, [F:MAR]RECORDTYP, [F:BPD]REP(IINDICE-1), [F:MAR]REPTYP, [F:MAR]REPMSS, [F:MAR]REPITM, 1, IBERROR)
        If IBERROR Then
          GMESSAGE = mess(523,196,1) - "(k)" #Erreur lors de l'affectation du secteur de marché.
          GERR = 1
          GOK = 0
          Break
        Endif
      Endif
    Next
  Endif
End

##########################################################################################################
# Affectation client livré
#####################################################################
#Affectation automatique
Subprog REP_BPD_AUTO(IDIMREP_BPD, SZBPRNUM, SZOLDADRESSE, SZNEWADRESSE)
Value Integer IDIMREP_BPD
Value Char SZBPRNUM
Value Char SZOLDADRESSE
Value Char SZNEWADRESSE

  #Affectation automatique
  Read [BPD]BPD0=SZBPRNUM;SZNEWADRESSE
  If fstat = 0 Then
    # Il n'y a pas obligatoirement de client livré à l'adresse. Ca n'est pas une erreur
    Filter [MAR] Where [F:MAR]RECORDNUM = SZBPRNUM and [F:MAR]RECORDADD = SZNEWADRESSE and [F:MAR]RECORDTYP = "BPD" and [F:MAR]REPTYP > 0
    For [MAR]MAR2
      If [F:MAR]REPTYP > IDIMREP_BPD Then
        # Pour traiter le cas improbable ou on aurait réduit le nb de représentant sur les clients livrés
        # On détruit ceux qui dépassent
        Delete [MAR]Curr
        If fstat <> 0 Then
          # Erreur lors de l'affectation du secteur de marché.
          GMESSAGE = mess(523,196,1) - "(l)"
          GERR = 1
          GOK = 0
          Break
        Endif
      Else
        [F:BPD]REP([F:MAR]REPTYP-1) = [F:MAR]REPNUM
      Endif
    Next
    Filter [MAR]
    If GOK < 1 Then
      End
    Endif
    Call FLDUPD("BPD") From OBJDIV  # Issue X3-90630 - 2018-05-18 by FGR : To force update of all technical fields
    Rewrite [BPD]
    If fstat <> 0 Then
      GMESSAGE = mess(523,196,1) - "(m)" #Erreur lors de l'affectation du secteur de marché.
      GERR = 1
      GOK = 0
    Endif
  Endif
End

##########################################################################################################
Subprog GERE_MODIF_REP(IDIMREP_BPC, IDIMREP_BPD, SZBPRNUM, SZADRDEFAUT, IBPCFLG, ITRT_KEEPREP, ITRT_KEEPMST)
Value Integer IDIMREP_BPC
Value Integer IDIMREP_BPD
Value Char SZBPRNUM
Value Char SZADRDEFAUT
Value Integer IBPCFLG
Value Integer ITRT_KEEPREP
Value Integer ITRT_KEEPMST

Local Integer IBREWRITE
Local Integer IBERROR
Local Integer IINDICE
Local Integer IINDTBADR
Local Integer IBMODIF_REP_BPC
Local Integer IBMODIF_REP_BPD
Local Integer IBQUESTION
Local Integer IREPONSE
Local Integer IBMODIF
Local Integer INBTAB_ADRESSE
Local Integer IDIMREP_BPA                       #nombre d'adresse par tiers

  IDIMREP_BPA = func AFNC.ACTIV("BPA")          #nombre d'adresse par tiers

Local Char SZTAB_ADRESSE(GLONADR)(IDIMREP_BPA)
Local Char SZTAB_REP0(GLONREP)(IDIMREP_BPA)
If IDIMREP_BPD > 1 Then
  Local Char SZTAB_REP1(GLONREP)(IDIMREP_BPA)
Endif

  IBMODIF_REP_BPD = 0
  #Détermine les occurences du tableau des représentants modifiées
  IBMODIF_REP_BPC = 0
  Case GSZCRMOBJET
    When "BPP"
      For IINDICE = 0 To IDIMREP_BPC-1
        If [F:BPC]REP(IINDICE) <> [M:BPP1]PREREP(IINDICE) Then
          IBMODIF_REP_BPC = 1
          Break
        Endif
      Next
    When "BPC"
      For IINDICE = 0 To IDIMREP_BPC-1
        If [F:BPC]REP(IINDICE) <> [M:BPC1]PREREP(IINDICE) Then
          IBMODIF_REP_BPC = 1
          Break
        Endif
      Next
    When Default
      End
  Endcase
  If GMSTDLV = 2 and IBPCFLG = 2 Then
    If IBMODIF_REP_BPC Then
      #report modification des représentants
      If ITRT_KEEPMST <> 1 Then
        Read [BPD]BPD0=SZBPRNUM;SZADRDEFAUT
        If fstat = 0 Then
          IBQUESTION = 0
          For IINDICE = 0 To min(IDIMREP_BPC, IDIMREP_BPD)-1
            If [F:BPC]REP(IINDICE) <> [F:BPD]REP(IINDICE) Then
              IBQUESTION = 1
              Break
            Endif
          Next
          IREPONSE = 0
          If IBQUESTION = 1 Then
            If ITRT_KEEPREP = 2 Then
              Call OUINON(mess(545,196,1), IREPONSE) From GESECRAN
            Endif
          Endif
          If IREPONSE = 2 Then
            #Mise à jour du client livré
            For IINDICE = 0 To min(IDIMREP_BPC, IDIMREP_BPC)-1
              [F:BPD]REP(IINDICE) = [F:BPC]REP(IINDICE)
            Next
            Call FLDUPD("BPD") From OBJDIV  # Issue X3-90630 - 2018-05-18 by FGR : To force update of all technical fields
            Rewrite [BPD]
            If fstat <> 0 Then
              GMESSAGE = mess(523,196,1) - "(n)" #Erreur lors de l'affectation du secteur de marché.
              GOK = 0
              End
            Endif
            IBMODIF_REP_BPD = 1
            #Met à jour MARASSREP
            For IINDICE = 1 To min(IDIMREP_BPC, IDIMREP_BPD)
              Read [MAR]MAR2=SZBPRNUM;SZADRDEFAUT;"BPD";IINDICE
              If fstat <> 0 Then
                IBREWRITE = 0
              Else
                IBREWRITE = 1
              Endif
              Call WRITE_MAR(IBREWRITE, SZBPRNUM, SZADRDEFAUT, "BPD", [F:BPC]REP(IINDICE-1), IINDICE, "", "", 1, IBERROR)
              If IBERROR Then
                GMESSAGE = mess(523,196,1) - "(o)" #Erreur lors de l'affectation du secteur de marché.
                GOK = 0
                Break
              Endif
            Next
          Endif
        Endif
      Endif
    Endif
    If GOK < 1 Then
      End
    Endif
    #Détermine les représentants du tableau des clients livrés modifiés.
    If GSZCRMOBJET = "BPC" Then
      IBMODIF = 0
      INBTAB_ADRESSE = 0
      Raz SZTAB_ADRESSE
      Raz SZTAB_REP0
      If IDIMREP_BPD > 1 Then
        Raz SZTAB_REP1
      Endif
      For IINDICE = 0 To [M:BPC4]NBDLV-1
        If [M:BPC4]BPAADD(IINDICE) <> SZADRDEFAUT Then
          If [M:BPC4]REP0(IINDICE) <> [M:BPC4]PREREP0(IINDICE) Then
            IBMODIF = 1
          Endif
          If IDIMREP_BPD > 1 Then
            If [M:BPC4]REP1(IINDICE) <> [M:BPC4]PREREP1(IINDICE) Then
              IBMODIF = 1
            Endif
          Endif
          If IBMODIF = 1 Then
            SZTAB_ADRESSE(INBTAB_ADRESSE) = [M:BPC4]BPAADD(IINDICE)
            SZTAB_REP0(INBTAB_ADRESSE) = [M:BPC4]REP0(IINDICE)
            If IDIMREP_BPD > 1 Then
              SZTAB_REP1(INBTAB_ADRESSE) = [M:BPC4]REP1(IINDICE)
            Endif
            INBTAB_ADRESSE += 1
          Endif
        Else
          If IBMODIF_REP_BPD = 0 Then
            #Pas de modification par rapport aux représentants, on prend dans le tableau
            If [M:BPC4]REP0(IINDICE) <> [M:BPC4]PREREP0(IINDICE) Then
              IBMODIF = 1
            Endif
            If IDIMREP_BPD > 1 Then
              If [M:BPC4]REP1(IINDICE) <> [M:BPC4]PREREP1(IINDICE) Then
                IBMODIF = 1
              Endif
            Endif
            If IBMODIF = 1 Then
              SZTAB_ADRESSE(INBTAB_ADRESSE) = [M:BPC4]BPAADD(IINDICE)
              SZTAB_REP0(INBTAB_ADRESSE) = [M:BPC4]REP0(IINDICE)
              If IDIMREP_BPD > 1 Then
                SZTAB_REP1(INBTAB_ADRESSE) = [M:BPC4]REP1(IINDICE)
              Endif
              INBTAB_ADRESSE += 1
            Endif
          Else
            #Modification par rapport aux représentants, on prend dans [F:BPD]
            If IDIMREP_BPD > 0 Then
              If [F:BPD]REP(0) <> [M:BPC4]PREREP0(IINDICE) Then
                IBMODIF = 1
              Endif
            Endif
            If IDIMREP_BPD > 1 Then
              If [F:BPD]REP(1) <> [M:BPC4]PREREP1(IINDICE) Then
                IBMODIF = 1
              Endif
            Endif
            If IBMODIF = 1 Then
              SZTAB_ADRESSE(INBTAB_ADRESSE) = SZADRDEFAUT
              SZTAB_REP0(INBTAB_ADRESSE) = [F:BPD]REP(0)
              If IDIMREP_BPD > 1 Then
                SZTAB_REP1(INBTAB_ADRESSE) = [F:BPD]REP(1)
              Endif
              INBTAB_ADRESSE += 1
            Endif
          Endif
        Endif
      Next
      If INBTAB_ADRESSE > 0 Then
        #On a des données modifiées, il faut mettre à jour MARASSREP
        For IINDTBADR = 0 To INBTAB_ADRESSE-1
          Read [BPA]BPA0=1;SZBPRNUM;SZTAB_ADRESSE(IINDTBADR)
          If fstat = 0 Then
            Read [BPD]BPD0=SZBPRNUM;[F:BPA]BPAADD
            If fstat = 0 Then
              If [F:BPA]BPAADD <> SZADRDEFAUT Then
                For IINDICE = 1 To min(IDIMREP_BPC, IDIMREP_BPD)
                  Read [MAR]MAR2=SZBPRNUM;[F:BPA]BPAADD;"BPR";IINDICE
                  If fstat <> 0 Then
                    IBREWRITE = 0
                  Else
                    IBREWRITE = 1
                  Endif
                  Call WRITE_MAR(IBREWRITE, SZBPRNUM, [F:BPA]BPAADD, "BPR", [F:BPD]REP(IINDICE-1), IINDICE, "", "", 1, IBERROR)
                  If IBERROR Then
                    GMESSAGE = mess(523,196,1) - "(p)" #Erreur lors de l'affectation du secteur de marché.
                    GOK = 0
                    Break
                  Endif
                Next
                If GOK < 1 Then
                  Break
                Endif
              Endif
              For IINDICE = 1 To IDIMREP_BPD
                Read [MAR]MAR2=SZBPRNUM;[F:BPA]BPAADD;"BPD";IINDICE
                If fstat <> 0 Then
                  IBREWRITE = 0
                Else
                  IBREWRITE = 1
                Endif
                Call WRITE_MAR(IBREWRITE, SZBPRNUM, [F:BPA]BPAADD, "BPD", [F:BPD]REP(IINDICE-1), IINDICE, "", "", 1, IBERROR)
                If IBERROR Then
                  GMESSAGE = mess(523,196,1) - "(q)" #Erreur lors de l'affectation du secteur de marché.
                  GOK = 0
                  Break
                Endif
              Next
              If GOK < 1 Then
                Break
              Endif
            Endif
          Endif
        Next
      Endif
    Endif
    If GOK < 0 Then
      End
    Endif
  Endif
  #Si les champs Représentant ont été modifiés.
  If IBMODIF_REP_BPC Then
    For IINDICE = 1 To IDIMREP_BPC
      Read [MAR]MAR2=SZBPRNUM;SZADRDEFAUT;"BPR";IINDICE
      If fstat <> 0 Then
        IBREWRITE = 0
      Else
        IBREWRITE = 1
      Endif
      Call WRITE_MAR(IBREWRITE, SZBPRNUM, SZADRDEFAUT, "BPR", [F:BPC]REP(IINDICE-1), IINDICE, "", "", 1, IBERROR)
      If IBERROR Then
        GMESSAGE = mess(523,196,1) - "(r)" #Erreur lors de l'affectation du secteur de marché.
        GOK = 0
        Break
      Endif
    Next
  Endif
End

##########################################################################################################
Funprog GENTRT_GETNOM
Local Char SZPROGNAME(GLONADC)

  SZPROGNAME = "WCRMMSTGEN"
End SZPROGNAME

##########################################################################################################
Subprog GENTRT_NOMTRT(SZPROGNAME, SZFULLSRC, SZFULLADX)
Variable Char SZPROGNAME
Variable Char SZFULLSRC
Variable Char SZFULLADX

  Raz SZPROGNAME
  Raz SZFULLSRC
  Raz SZFULLADX
  SZPROGNAME = func GENTRT_GETNOM
  SZFULLSRC = filpath("TRT", SZPROGNAME, "src", nomap)
  SZFULLADX = filpath("TRT", SZPROGNAME, "adx", nomap)
End

##########################################################################################################
Subprog GENTRT_DELTRT(IQUOI)
Value Integer IQUOI  # 0=Supprime tout
                     # 1=Supprime TRT
                     # 2=Supprime ADX
Local Char SZPROGNAME(GLONADC)
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer IEXIST

  Call GENTRT_NOMTRT(SZPROGNAME, SZFULLSRC, SZFULLADX)
  #
  If IQUOI = 0 or IQUOI = 1 Then
    IEXIST = 0
    Call EXISTE(SZFULLSRC,IEXIST) From ORDSYS
    If IEXIST Then
      IEXIST = 1
      Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
    Endif
  Endif
  #
  If IQUOI = 0 or IQUOI = 2 Then
    IEXIST = 0
    Call EXISTE(SZFULLADX,IEXIST) From ORDSYS
    If IEXIST Then
      IEXIST = 1
      Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
    Endif
  Endif
End

##########################################################################################################
Funprog GENTRT_VALIDE(IACTION)
Value Integer IACTION

Local Integer ARENDRE
Local Char SZPROGNAME(GLONADC)
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer IEXIST

  # Le SRC et l'ADX doivent exister
  ARENDRE = 0
  If IACTION = 1 Then
    # On regarde
    If dim(GTRTMSTOK) <= 0 Then
      # Si la globale n'existe pas on la crée et on l'initialise
      Global Integer GTRTMSTOK
      #
      Call GENTRT_NOMTRT(SZPROGNAME, SZFULLSRC, SZFULLADX)
      IEXIST = 0
      Call EXISTE(SZFULLSRC,IEXIST) From ORDSYS
      If IEXIST Then
        IEXIST = 0
        Call EXISTE(SZFULLADX,IEXIST) From ORDSYS
        If IEXIST Then
          ARENDRE = 1
        Endif
      Endif
      GTRTMSTOK = ARENDRE
    Else
      # Si la globale existe, on rend sa valeur
      ARENDRE = GTRTMSTOK
    Endif
  Elsif IACTION = 2 Then
    # On a fini : on détruit la globale si elle existe
    If dim(GTRTMSTOK) >= 0 Then
      Kill GTRTMSTOK
    Endif
  Endif
End ARENDRE

##########################################################################################################
Subprog GENTRT_TEST_SECTEUR(IERROR)
Variable Integer IERROR

Local Char SZCONDITION(250)(100)
Local Integer INBCONDITION
Local Integer NI
Local Integer IVALIDOK
Local Char SZPROGNAME(GLONADC)
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Char SZADXIFS(type(adxifs)-10)   # Issue X3-61585 - 2018-04-19 by FGR
Local Char SZADXIRS(type(adxirs)-10)   # Issue X3-61585 - 2018-04-19 by FGR

  IERROR = 0
  # Issue X3-61585 - 2018-04-19 by FGR : BEGIN
  #If !clalev([F:MST]) : Local File MARSCT [MST] : Endif
  #If !clalev([F:MDF]) : Local File MARDEF [MDF] : Endif
  Local File MARSCT [MST]
  Local File MARDEF [MDF]
  # Issue X3-61585 - 2018-04-19 by FGR : END
  #
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  #
  Call GENTRT_DELTRT(0)
  Call GENTRT_NOMTRT(SZPROGNAME, SZFULLSRC, SZFULLADX)
  #
  #Ouverture du traitement à générer
  Openo SZFULLSRC, 0 Using [MST1]
  #
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [MST1]
  Wrseq "#Traitement généré d'affectation de secteur de marché" Using [MST1]
  Wrseq "" Using [MST1]
  Wrseq "Funprog TEST_SECTEUR_GEN (ITRTBAT)" Using [MST1]
  Wrseq "value integer ITRTBAT" Using [MST1]
  Wrseq "" Using [MST1]
  Wrseq "Local Integer IRESULT" Using [MST1]
  Wrseq "" Using [MST1]
  Wrseq "  IRESULT = 0" Using [MST1]
  #
  Filter [MST] Where [F:MST]MSTENA = 2 Order By [F:MST]MSTORD Asc;[F:MST]MARSCTNUM Asc
  For [MST]
    #-----------------
    Call CREATECLAUSE(SZCONDITION, INBCONDITION)
    If INBCONDITION > 0 Then
      Wrseq "  If" Using [MST1]
      For NI = 0 To INBCONDITION-1
        Wrseq "&    " + SZCONDITION(NI) Using [MST1]
      Next NI
      Wrseq "&  Then" Using [MST1]
      Wrseq "    IRESULT = 1" Using [MST1]
      Wrseq "    Read [MST]MST0='" + [F:MST]MARSCTNUM + "'" Using [MST1]
      Wrseq "    End IRESULT" Using [MST1]
      Wrseq "  Endif" Using [MST1]
    Endif
    #-----------------
  Next
  Filter [MST]
  Wrseq "End IRESULT" Using [MST1]
  #Fermeture du traitement généré
  Openo Using [MST1]
  #
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  # Compilation du traitement généré
  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, nomap, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    IERROR = 1
    Call GENTRT_DELTRT(2) # Je ne supprime pas le TRT pour pouvoir vérifier pourquoi ça ne compile pas
  Endif
End

##########################################################################################################
Subprog GERE_ONE_BPC_ADR_SEC(IDIMREP_BPC, IDIMREP_BPD, IDIMREP_BRS, SZBPRNUM, SZADRDEFAUT, SZBPAADD, IBPCFLG, ITRTBAT, ITRT_KEEPREP, ITRT_KEEPMST, IREPONSE_REP, IREPONSE_SECTEUR, INBTRTOK, INBNONTRT,
& INBTRTKO)
Value Integer IDIMREP_BPC
Value Integer IDIMREP_BPD
Value Integer IDIMREP_BRS
Value Char SZBPRNUM
Value Char SZADRDEFAUT
Value Char SZBPAADD
Value Integer IBPCFLG
Value Integer ITRTBAT
Value Integer ITRT_KEEPREP
Value Integer ITRT_KEEPMST
Variable Integer IREPONSE_REP
Variable Integer IREPONSE_SECTEUR
Variable Integer INBTRTOK
Variable Integer INBNONTRT
Variable Integer INBTRTKO

Local Integer IINDICE
Local Integer IBERROR
Local Integer IBREWRITE
Local Integer IBSEC_AFFECTER
Local Integer IBFORCE_MANU
Local Integer IBSEC_RECHERCHE
Local Char SZTAB_REP(GLONREP)(IDIMREP_BPC+IDIMREP_BRS)
Local Integer INBTAB_REP
Local Integer IBREP_RECHERCHE
Local Integer IBAFFECT_MANUEL_BPC
Local Integer IBAFFECT_MANUEL_BPD
Local Integer IBSEC_FOUND
Local Integer IBDELETE_MAR
Local Integer IBAFFECTER_MAR
Local Char SZCHFUNC(250)

  IBSEC_AFFECTER = 0
  IBFORCE_MANU = 0
  IBSEC_RECHERCHE = 0
  IBAFFECT_MANUEL_BPC = 0
  IBAFFECT_MANUEL_BPD = 0
  IBSEC_FOUND = 0
  IBDELETE_MAR = 0
  IBAFFECTER_MAR = 0
  #On vérifie l'affectation du secteur
  Read [MAD]MAD0=SZBPRNUM;SZBPAADD;"BPR"
  If fstat = 0 Then
    Read [MST]MST0=[F:MAD]MARSCTNUM
    If fstat <> 0 Then
      # Le site est affecté à un secteur qui n'existe plus.
      # Le secteur n'existe plus on supprime systématiquement
      Delete [MAD] Where [F:MAD]RECORDNUM = SZBPRNUM and [F:MAD]RECORDADD = SZBPAADD and [F:MAD]RECORDTYP = "BPR"
      If fstat <> 0 Then
        #Erreur lors de l'affectation du secteur de marché.
        If ITRTBAT = 0 Then
          GMESSAGE = mess(523,196,1) - "(s)"
        Else
          Call ECR_TRACE(mess(523,196,1) - "(s)",1) From GESECRAN
        Endif
        GOK = 0
        End
      Endif
      IBSEC_AFFECTER = 0
      IBFORCE_MANU = 0
    Else
      IBSEC_AFFECTER = 1
      IBFORCE_MANU = [F:MAD]MANASS
    Endif
  Else
    IBSEC_AFFECTER = 0
  Endif
  If IBSEC_AFFECTER = 1 Then
    Case ITRT_KEEPMST
      When 1
        IBSEC_RECHERCHE = 0
      When Default
        IBSEC_RECHERCHE = 1
    Endcase
  Else
    IBSEC_RECHERCHE = 1
  Endif
  #On vérifie l'affectation des représentants
  INBTAB_REP = 0
  Raz SZTAB_REP
  IBREP_RECHERCHE = 0
  Filter [MAR] Where [F:MAR]RECORDNUM = SZBPRNUM and [F:MAR]RECORDADD = SZBPAADD and [F:MAR]RECORDTYP = "BPR"
  For [MAR]
    Read [REP]REP0=[F:MAR]REPNUM
    If fstat <> 0 Then
      #représentant non valide
      #il faut supprimer l'enregistrement
      SZTAB_REP(INBTAB_REP) = [F:MAR]REPNUM
      INBTAB_REP += 1
      IBREP_RECHERCHE += 1
    Else
      If [F:MAR]MANASS = 1 Then
        If ITRT_KEEPREP <> 1 Then
          IBREP_RECHERCHE += 1
        Endif
      Else
        IBREP_RECHERCHE += 1
      Endif
    Endif
  Next
  Filter [MAR]
  If INBTAB_REP > 0 Then
    For IINDICE = 0 To INBTAB_REP-1
      Delete [MAR] Where [F:MAR]RECORDNUM = SZBPRNUM and [F:MAR]RECORDADD = SZBPAADD and [F:MAR]RECORDTYP = "BPR" and [F:MAR]REPNUM = SZTAB_REP(IINDICE)
    Next
  Endif
  If IBREP_RECHERCHE > 0 Then
    IBSEC_RECHERCHE = 1
  Endif
  #==========================
  If IBSEC_RECHERCHE = 1 Then
    # ON RECHERCHE LE SECTEUR DE MARCHE QUI VA BIEN PARMI TOUS
    If func GENTRT_VALIDE(1) = 1 Then
      SZCHFUNC = func GENTRT_GETNOM + ".TEST_SECTEUR_GEN"
      IBSEC_FOUND = func =SZCHFUNC With (ITRTBAT)
    Else
      IBSEC_FOUND = 0
      Filter [MST] Where [F:MST]MSTENA = 2 Order By [F:MST]MSTORD Asc;[F:MST]MARSCTNUM Asc
      For [MST]
        #-----------------
        IBSEC_FOUND = func TEST_SECTEUR
        #-----------------
        If IBSEC_FOUND = 1 Then
          Break # Quand on l'a trouvé on s'arrête : il est dans [F:MST]MARSCTNUM
        Endif
      Next
      Filter [MST]
    Endif
    If ITRTBAT = 1 Then
      #on est en traitement batch
      If IBSEC_FOUND = 1 Then
        INBTRTOK += 1
        Call ECR_TRACE("      " - mess(576,177,1) - ":" - [F:MST]MARSCTNUM,0) From GESECRAN
      Else
        INBTRTKO += 1
        Call ECR_TRACE("      " - mess(577,177,1),0) From GESECRAN
      Endif
    Endif
    #=========================================================================================================
    #Traitement des affectations de secteurs
    Read [MAD]MAD0=SZBPRNUM;SZBPAADD;"BPR"
    If fstat <> 0 Then
      IBREWRITE = 0
      IBFORCE_MANU = 0
    Else
      IBREWRITE = 1
      IBFORCE_MANU = [F:MAD]MANASS
    Endif
    IBSEC_AFFECTER = 0
    Case ITRT_KEEPMST
      When 1
        If IBFORCE_MANU = 0 Then
          IBSEC_AFFECTER = 1
        Endif
      When 2
        If IBFORCE_MANU = 1 Then
          If IREPONSE_SECTEUR = 0 Then
            # Note : On teste "IREPONSE_SECTEUR = 0" comme ça on ne pose la question QUE la première fois.
            #        La réponse est ensuite valable pour toutes les adresses.
            Call OUINON(mess(525,196,1), IREPONSE_SECTEUR) From GESECRAN
          Endif
          If IREPONSE_SECTEUR = 2 Then
            IBSEC_AFFECTER = 1
          Endif
        Else
          IBSEC_AFFECTER = 1
        Endif
      When 3
        IBSEC_AFFECTER = 1
      When Default
        IBSEC_AFFECTER = 1
    Endcase
    If IBSEC_FOUND = 1 Then
      If IBSEC_AFFECTER = 1 Then
        #on a trouvé et il faut affecter
        Call WRITE_MAD(IBREWRITE, SZBPRNUM, SZBPAADD, "BPR", [F:MST]MARSCTNUM, 0, IBERROR)
        If IBERROR Then
          #Erreur lors de l'affectation du secteur de marché.
          If ITRTBAT = 0 Then
            GMESSAGE = mess(523,196,1) - "(t)"
          Else
            Call ECR_TRACE(mess(523,196,1) - "(t)",1) From GESECRAN
          Endif
          GOK = 0
        Endif
      Endif
    Else
      If IBSEC_AFFECTER = 1 Then
        #On n'a pas trouve et il faut supprimer
        If IBREWRITE = 1 Then
          Delete [MAD] Where [F:MAD]RECORDTYP = "BPR" and [F:MAD]RECORDNUM = SZBPRNUM and [F:MAD]RECORDADD = SZBPAADD
          If fstat <> 0 Then
            #Erreur lors de l'affectation du secteur de marché.
            If ITRTBAT = 0 Then
              GMESSAGE = mess(523,196,1) - "(u)"
            Else
              Call ECR_TRACE(mess(523,196,1) - "(u)",1) From GESECRAN
            Endif
            GOK = 0
          Endif
        Endif
      Endif
    Endif
    If GOK < 1 Then
      End
    Endif
    #=========================================================================================================
    #traitements des représentants
    IBAFFECT_MANUEL_BPC = 0
    Filter [MAR] Where [F:MAR]RECORDNUM = SZBPRNUM and [F:MAR]RECORDADD = SZBPAADD and [F:MAR]RECORDTYP = "BPR" and [F:MAR]MANASS = 1
    For [MAR]
      IBAFFECT_MANUEL_BPC = 1
      Break
    Next
    Filter [MAR]
    Case ITRT_KEEPREP
      When 1
        If IBAFFECT_MANUEL_BPC = 1 Then
          IBDELETE_MAR = 0
          IBAFFECTER_MAR = 0
        Else
          IBDELETE_MAR = 1
          IBAFFECTER_MAR = 1
        Endif
      When 2
        IBDELETE_MAR = 0
        IBAFFECTER_MAR = 0
        If IBAFFECT_MANUEL_BPC = 1 Then
          # Note : On teste "IREPONSE_REP = 0" comme ça on ne pose la question QUE la première fois.
          #        La réponse est ensuite valable pour toutes les adresses.
          If IREPONSE_REP = 0 Then
            Call OUINON(mess(977,196,1), IREPONSE_REP) From GESECRAN
          Endif
          If IREPONSE_REP = 2 Then
            IBDELETE_MAR = 1
            IBAFFECTER_MAR = 1
          Endif
        Else
          IBDELETE_MAR = 1
          IBAFFECTER_MAR = 1
        Endif
      When 3
        IBDELETE_MAR = 1
        IBAFFECTER_MAR = 1
    Endcase
    If GOK < 1 Then
      End
    Endif
    If IBDELETE_MAR = 1 Then
      Delete [MAR] Where [F:MAR]RECORDTYP = "BPR" and [F:MAR]RECORDNUM = SZBPRNUM and [F:MAR]RECORDADD = SZBPAADD
      If fstat <> 0 Then
        #Erreur lors de l'affectation du secteur de marché.
        If ITRTBAT = 0 Then
          GMESSAGE = mess(523,196,1) - "(v)"
        Else
          Call ECR_TRACE(mess(523,196,1) - "(v)",1) From GESECRAN
        Endif
        GOK = 0
      Else
        If SZBPAADD = SZADRDEFAUT Then
          Delete [RSE] Where [F:RSE]BPCNUM = SZBPRNUM
          If fstat <> 0 Then
            #Erreur lors de l'affectation du secteur de marché.
            If ITRTBAT = 0 Then
              GMESSAGE = mess(523,196,1) - "(w)"
            Else
              Call ECR_TRACE(mess(523,196,1) - "(w)",1) From GESECRAN
            Endif
            GOK = 0
          Endif
        Endif
      Endif
    Endif
    If GOK < 1 Then
      End
    Endif
    If IBAFFECTER_MAR = 1 Then
      If IBSEC_FOUND = 1 Then
        For IINDICE = 1 To IDIMREP_BPC
          If [F:MST]MARSCTREP(IINDICE-1) <> "" Then
            #Affectation dans les secteurs de marché
            Call WRITE_MAR(0, SZBPRNUM, SZBPAADD, "BPR", [F:MST]MARSCTREP(IINDICE-1), IINDICE, "", "", 0, IBERROR)
            If IBERROR Then
              #Erreur lors de l'affectation des représentants.
              If ITRTBAT = 0 Then
                GMESSAGE = mess(524,196,1)
              Else
                Call ECR_TRACE(mess(524,196,1),1) From GESECRAN
              Endif
              GOK = 0
              Break
            Endif
          Endif
          If SZBPAADD = SZADRDEFAUT Then
            [F:BPC]REP(IINDICE-1) = [F:MST]MARSCTREP(IINDICE-1)
          Endif
        Next
        If GOK < 1 Then
          End
        Endif
        If SZBPAADD = SZADRDEFAUT Then
          #On affecte sur BPCUSTOMER
          Call FLDUPD("BPC") From OBJDIV  # Issue X3-90630 - 2018-05-18 by FGR : To force update of all technical fields
          Rewrite [BPC]
          If fstat <> 0 Then
            #Erreur lors de l'affectation des représentants.
            If ITRTBAT = 0 Then
              GMESSAGE = mess(524,196,1)
            Else
              Call ECR_TRACE(mess(524,196,1),1) From GESECRAN
            Endif
            GOK = 0
          Endif
        Endif
        If GOK < 1 Then
          End
        Endif
        Filter [MRS] Where [F:MRS]MARSCTNUM = [F:MST]MARSCTNUM and [F:MRS]SCTREPSEC <> ""
        For [MRS]
          #Table associée aux secteurs
          Call WRITE_MAR(0, SZBPRNUM, SZBPAADD, "BPR", [F:MRS]SCTREPSEC, 0, [F:MRS]SCTREPMSS, [F:MRS]SCTREPITM, 0, IBERROR)
          If IBERROR Then
            #Erreur lors de l'affectation des représentants.
            If ITRTBAT = 0 Then
              GMESSAGE = mess(524,196,1)
            Else
              Call ECR_TRACE(mess(524,196,1),1) From GESECRAN
            Endif
            GOK = 0
            Break
          Endif
          #Tables des représentants secondaires
          If SZBPAADD = SZADRDEFAUT Then
            Call  WRITE_RSE(0, SZBPRNUM, [F:MRS]SCTREPSEC, [F:MRS]SCTREPMSS, [F:MRS]SCTREPITM, 1, IBERROR)
            If IBERROR Then
              #Erreur lors de l'affectation des représentants.
              If ITRTBAT = 0 Then
                GMESSAGE = mess(524,196,1)
              Else
                Call ECR_TRACE(mess(524,196,1),1) From GESECRAN
              Endif
              GOK = 0
              Break
            Endif
          Endif
        Next
      Else
        #On n'a rien trouvé mais il faut affecter, donc on reinitialise
        If SZBPAADD = SZADRDEFAUT Then
          For IINDICE = 1 To IDIMREP_BPC
            [F:BPC]REP(IINDICE-1) = "" # Issue X3-5703/119197 - 2016-10-18 by FGR : Not [F:MST]MARSCTREP(IINDICE-1)
          Next
          Call FLDUPD("BPC") From OBJDIV  # Issue X3-90630 - 2018-05-18 by FGR : To force update of all technical fields
          Rewrite [BPC]
          If fstat <> 0 Then
            #Erreur lors de l'affectation des représentants.
            If ITRTBAT = 0 Then
              GMESSAGE = mess(524,196,1)
            Else
              Call ECR_TRACE(mess(524,196,1),1) From GESECRAN
            Endif
            GOK = 0
          Endif
        Endif
      Endif
      If GOK < 1 Then
        End
      Endif
      #Clients livrés
      If GMSTDLV = 2 and IBPCFLG = 2 and [F:BPD]BPCNUM <> "" Then
        Filter [MAR] Where [F:MAR]RECORDTYP = "BPD" and [F:MAR]RECORDNUM = SZBPRNUM and [F:MAR]RECORDADD = SZBPAADD
        For [MAR]
          If [F:MAR]MANASS = 1 Then
            IBAFFECT_MANUEL_BPD = 1
            Break
          Endif
        Next
        Filter [MAR]
        Case ITRT_KEEPREP
          When 1
            If IBAFFECT_MANUEL_BPD = 1 Then
              IBDELETE_MAR = 0
              IBAFFECTER_MAR = 0
            Else
              IBDELETE_MAR = 1
              IBAFFECTER_MAR = 1
            Endif
          When 2
            IBDELETE_MAR = 0
            IBAFFECTER_MAR = 0
            If IBAFFECT_MANUEL_BPD = 1 Then
              If IREPONSE_REP = 0 Then
                # Note : On teste "IREPONSE_REP = 0" comme ça on ne pose la question QUE la première fois.
                #        La réponse est ensuite valable pour toutes les adresses.
                Call OUINON(mess(977,196,1), IREPONSE_REP) From GESECRAN
              Endif
              If IREPONSE_REP = 2 Then
                IBDELETE_MAR = 1
                IBAFFECTER_MAR = 1
              Endif
            Else
              IBDELETE_MAR = 1
              IBAFFECTER_MAR = 1
            Endif
          When 3
            IBDELETE_MAR = 1
            IBAFFECTER_MAR = 1
        Endcase
        If IBDELETE_MAR = 1 Then
          Delete [MAR] Where [F:MAR]RECORDTYP = "BPD" and [F:MAR]RECORDNUM = SZBPRNUM and [F:MAR]RECORDADD = SZBPAADD
          If fstat <> 0 Then
            #Erreur lors de l'affectation du secteur de marché.
            If ITRTBAT = 0 Then
              GMESSAGE = mess(523,196,1) - "(x)"
            Else
              Call ECR_TRACE(mess(523,196,1) - "(x)",1) From GESECRAN
            Endif
            GOK = 0
          Endif
        Endif
        If GOK < 1 Then
          End
        Endif
        If IBAFFECTER_MAR = 1 Then
          If IBSEC_FOUND = 1 Then
            For IINDICE = 1 To IDIMREP_BPD
              If [F:MST]MARSCTREP(IINDICE-1) <> "" Then
                #Affectation dans les secteurs de marché
                Call WRITE_MAR(0, SZBPRNUM, SZBPAADD, "BPD", [F:MST]MARSCTREP(IINDICE-1), IINDICE, "", "", 0, IBERROR)
                If IBERROR Then
                  #Erreur lors de l'affectation du secteur de marché.
                  If ITRTBAT = 0 Then
                    GMESSAGE = mess(523,196,1) - "(y)"
                  Else
                    Call ECR_TRACE(mess(523,196,1) - "(y)",1) From GESECRAN
                  Endif
                  GOK = 0
                  Break
                Endif
              Endif
              [F:BPD]REP(IINDICE-1) = [F:MST]MARSCTREP(IINDICE-1)
            Next
            If GOK < 1 Then
              End
            Endif
            Call FLDUPD("BPD") From OBJDIV  # Issue X3-90630 - 2018-05-18 by FGR : To force update of all technical fields
            Rewrite [BPD]
            If fstat <> 0 Then
              #Erreur lors de l'affectation des représentants.
              If ITRTBAT = 0 Then
                GMESSAGE = mess(524,196,1)
              Else
                Call ECR_TRACE(mess(524,196,1),1) From GESECRAN
              Endif
              GOK = 0
            Endif
          Else
            For IINDICE = 1 To IDIMREP_BPD
              [F:BPD]REP(IINDICE-1) = ""
            Next
            Call FLDUPD("BPD") From OBJDIV  # Issue X3-90630 - 2018-05-18 by FGR : To force update of all technical fields
            Rewrite [BPD]
            If fstat <> 0 Then
              #Erreur lors de l'affectation des représentants.
              If ITRTBAT = 0 Then
                GMESSAGE = mess(524,196,1)
              Else
                Call ECR_TRACE(mess(524,196,1),1) From GESECRAN
              Endif
              GOK = 0
            Endif
          Endif
        Endif
        If GOK < 1 Then
          End
        Endif
      Endif
    Endif
  Else
    If ITRTBAT = 1 Then
      #Non traité
      Call ECR_TRACE("      " - mess(414,177,1),0) From GESECRAN
      INBNONTRT += 1
    Endif
  Endif
End

##########################################################################################################
Funprog TEST_SECTEUR()
Local Char SZCONDITION(250)(100)
Local Integer INBCONDITION
Local Integer IRESULT

  IRESULT = 0
  Call CREATECLAUSE(SZCONDITION, INBCONDITION)
  If INBCONDITION > 0 Then
    IRESULT = evalue(SZCONDITION)
  Endif
End IRESULT

##########################################################################################################
Subprog CREATECLAUSE(SZCONDITION, INBCONDITION)
Variable Char SZCONDITION()()
Variable Integer INBCONDITION

Local Date DTDATE
Local Char SZCHAINE(250)
Local Char SZCHAMP(30)
Local Char SZVALEUR(100)

  Raz SZCONDITION
  INBCONDITION = 0
  If [F:MST]MSTCRI = 1 or [F:MST]MSTCRI = 3 Then
    # "Critère" ou "Critère et formule"
    SZCONDITION(INBCONDITION) = "("
    INBCONDITION += 1
    Filter [MDF] Where [F:MDF]MARSCTNUM = [F:MST]MARSCTNUM Order By CRINUM Asc
    For [MDF]
      Raz SZCHAINE
      Raz SZCHAMP
      Raz SZVALEUR
      If [F:MDF]MARSCTOPD = 2 Then
        SZCHAINE = " and "
      Elsif [F:MDF]MARSCTOPD = 3 Then
        SZCHAINE = " or "
      Endif
      If [F:MDF]NBPARDEB > 0 Then
        SZCHAINE = SZCHAINE + string$([F:MDF]NBPARDEB,"(")
      Endif
      SZCHAMP = "[F:" + [F:MDF]MDFABRFIC + "]" + [F:MDF]MARSCTFIE
      # Issue X3-80444 - 2018-04-06 by FGR : BEGIN
      #If [F:MDF]MDFINDOK = 2 Then
      #  SZCHAMP = SZCHAMP + "(" + num$(MDFINDNUM) + ")"
      #Endif
      If evalue("dim(" + SZCHAMP + ")") > 1 Then
        SZCHAMP = SZCHAMP + "(" + num$([F:MDF]MDFINDNUM) + ")"
      Endif
      # Issue X3-80444 - 2018-04-06 by FGR : END
      Case [F:MDF]MDFFIETYP
        When 1
          Case [F:MDF]MARSCTCND
            When 3
              #commence par
              SZVALEUR = '"' + [F:MDF]MDFVAL + '*"'
            When 4
              #contient
              SZVALEUR = '"*' + [F:MDF]MDFVAL + '*"'
            When 5
              #se termine par
              SZVALEUR = '"*' + [F:MDF]MDFVAL + '"'
            When Default
              SZVALEUR = '"' + [F:MDF]MDFVAL + '"'
          Endcase
        When 2
          SZVALEUR = [F:MDF]MDFVAL
        When 3
          Call CONVID([F:MDF]MDFVAL, DTDATE) From CRMUTIL150
          SZVALEUR = '[' + format$(GFMDAT4, DTDATE) + ']' # FGR 02/11/2009 : X3SUIVI59445 : Il n'y avait pas les "[]" autour
      Endcase
      #
      Case [F:MDF]MARSCTCND
        When 1
          #Egal
          SZCHAINE = SZCHAINE + SZCHAMP + "=" + SZVALEUR
        When 2
          #Différent
          SZCHAINE = SZCHAINE + SZCHAMP + "<>" + SZVALEUR
        When 3
          #commence par
          SZCHAINE = SZCHAINE + "pat(" + SZCHAMP + "," + SZVALEUR + ")<>0"
        When 4
          #contient
          SZCHAINE = SZCHAINE + "pat(" + SZCHAMP + "," + SZVALEUR + ")<>0"
        When 5
          #se termine par
          SZCHAINE = SZCHAINE + "pat(" + SZCHAMP + "," + SZVALEUR + ")<>0"
        When 6
          #supérieur à
          SZCHAINE = SZCHAINE + SZCHAMP + ">" + SZVALEUR
        When 7
          #supérieur ou égal
          SZCHAINE = SZCHAINE + SZCHAMP + ">=" + SZVALEUR
        When 8
          #Inférieur à
          SZCHAINE = SZCHAINE + SZCHAMP + "<" + SZVALEUR
        When 9
          #Inférieur ou égal à
          SZCHAINE = SZCHAINE + SZCHAMP + "<=" + SZVALEUR
      Endcase
      If [F:MDF]NBPARFIN > 0 Then
        SZCHAINE = SZCHAINE + string$([F:MDF]NBPARFIN,")")
      Endif
      SZCONDITION(INBCONDITION) = SZCHAINE
      INBCONDITION += 1
    Next
    Filter [MDF]
    SZCONDITION(INBCONDITION) = ")"
    INBCONDITION += 1
  Endif
  # Issue X3-61585 - 2018-04-19 by FGR : BEGIN
  #If [F:MST]MSTCRI = 2 Then
  #  # "Formule"
  #  SZCONDITION(INBCONDITION) = [F:MST]MSTFOR
  #  INBCONDITION += 1
  #Elsif [F:MST]MSTCRI = 3 Then
  #  # "Critère et formule"
  #  Raz SZCHAINE
  #  If INBCONDITION > 0 Then
  #    If [F:MDF]MARSCTOPD = 2 Then
  #      SZCHAINE = " and ("
  #    Elsif [F:MDF]MARSCTOPD = 3 Then
  #      SZCHAINE = " or ("
  #    Endif
  #    SZCONDITION(INBCONDITION) = SZCHAINE
  #    INBCONDITION += 1
  #    SZCHAINE = ")"
  #  Endif
  If [F:MST]MSTCRI = 2 Then
    # "Formule"
    SZCONDITION(INBCONDITION) = [F:MST]MSTFOR
    INBCONDITION += 1
  Elsif [F:MST]MSTCRI = 3 Then
    # "Critère et formule"
    Raz SZCHAINE
    If INBCONDITION > 0 Then
      If [F:MST]MSTFOROPD = 2 Then
        SZCHAINE = " and ("
      Elsif [F:MST]MSTFOROPD = 3 Then
        SZCHAINE = " or ("
      Endif
      SZCONDITION(INBCONDITION) = SZCHAINE
      INBCONDITION += 1
      SZCHAINE = ")"
    Endif
    # Issue X3-61585 - 2018-04-19 by FGR : END
    SZCONDITION(INBCONDITION) = [F:MST]MSTFOR
    INBCONDITION += 1
    If SZCHAINE <> "" Then
      SZCONDITION(INBCONDITION) = SZCHAINE
      INBCONDITION += 1
    Endif
  Endif
End

##########################################################################################################
Subprog WRITE_MAR(IBREWRITE, SZRECORDNUM, SZRECORDADD, SZRECORDTYP, SZREPNUM, IREPTYP, SZREPMSS, SZREPITM, IMANASS, IBERROR)
Value Integer IBREWRITE
Value Char SZRECORDNUM
Value Char SZRECORDADD
Value Char SZRECORDTYP
Value Char SZREPNUM
Value Integer IREPTYP
Value Char SZREPMSS
Value Char SZREPITM
Value Integer IMANASS
Variable Integer IBERROR

  IBERROR = 0
  If IBREWRITE = 0 Then
    Raz [F:MAR]
  Endif
  [F:MAR]RECORDNUM = SZRECORDNUM
  [F:MAR]RECORDADD = SZRECORDADD
  [F:MAR]RECORDTYP = SZRECORDTYP
  [F:MAR]REPNUM = SZREPNUM
  [F:MAR]REPTYP = IREPTYP
  [F:MAR]REPMSS = SZREPMSS
  [F:MAR]REPITM = SZREPITM
  [F:MAR]MANASS = IMANASS
  If IBREWRITE = 0 Then
    Call FLDCRE("MAR") From OBJDIV  # Issue X3-90630 - 2018-05-18 by FGR : To force update of all technical fields
    Write [MAR]
  Else
    Call FLDUPD("MAR") From OBJDIV  # Issue X3-90630 - 2018-05-18 by FGR : To force update of all technical fields
    Rewrite [MAR]
  Endif
  If fstat Then
    IBERROR = 1
  Endif
End

##########################################################################################################
Subprog WRITE_MAD(IBREWRITE, SZRECORDNUM, SZRECORDADD, SZRECORDTYP, SZMARSCTNUM, IMANASS, IBERROR)
Value Integer IBREWRITE
Value Char SZRECORDNUM
Value Char SZRECORDADD
Value Char SZRECORDTYP
Value Char SZMARSCTNUM
Value Integer IMANASS
Variable Integer IBERROR

  IBERROR = 0
  If IBREWRITE = 0 Then
    Raz [F:MAD]
  Endif
  [F:MAD]RECORDNUM = SZRECORDNUM
  [F:MAD]RECORDADD = SZRECORDADD
  [F:MAD]RECORDTYP = SZRECORDTYP
  [F:MAD]MARSCTNUM = SZMARSCTNUM
  [F:MAD]MANASS = IMANASS
  If IBREWRITE = 0 Then
    Call FLDCRE("MAD") From OBJDIV  # Issue X3-90630 - 2018-05-18 by FGR : To force update of all technical fields
    Write [MAD]
  Else
    Call FLDUPD("MAD") From OBJDIV  # Issue X3-90630 - 2018-05-18 by FGR : To force update of all technical fields
    Rewrite [MAD]
  Endif
  If fstat <> 0 Then
    IBERROR = 1
  Endif
End

##########################################################################################################
Subprog WRITE_RSE(IBREWRITE, SZBPRNUM, SZREPNUM, SZREPMSS, SZREPITM, IAUTASS, IBERROR)
Value Integer IBREWRITE
Value Char SZBPRNUM
Value Char SZREPNUM
Value Char SZREPMSS
Value Char SZREPITM
Value Integer IAUTASS
Variable Integer IBERROR

  IBERROR = 0
  If IBREWRITE = 0 Then
    Raz [F:RSE]
  Endif
  [F:RSE]BPCNUM = SZBPRNUM
  [F:RSE]REPNUM = SZREPNUM
  [F:RSE]MSS = SZREPMSS
  [F:RSE]GRPITM = SZREPITM
  [F:RSE]AUTASS = IAUTASS
  If IBREWRITE = 0 Then
    Call FLDCRE("RSE") From OBJDIV  # Issue X3-90630 - 2018-05-18 by FGR : To force update of all technical fields
    Write [RSE]
  Else
    Call FLDUPD("RSE") From OBJDIV  # Issue X3-90630 - 2018-05-18 by FGR : To force update of all technical fields
    Rewrite [RSE]
  Endif
  If fstat Then
    IBERROR = 1
  Endif
End

##########################################################################################################
# Charge les représentants des clients livrés si une affectation par secteur de marché est définie.
############################################################
Subprog LREPDLV(SZADDCOD, INOL)
Value Char SZADDCOD
Value Integer INOL

Local Integer ITER
Local Integer IDIMREP_BPD  #nombre représentants associés à un client livré

  #Si la synchro n'est pas active on ne fait rien
  If GMSTDLV = 2 Then
    IDIMREP_BPD = func AFNC.ACTIV("RED")
    If !clalev([F:MAR]) : Local File MARASSREP [MAR] : Endif
    For ITER = 1 To IDIMREP_BPD
      Read [MAR]MAR2=[M:BPC0]BPCNUM;SZADDCOD;"BPR";ITER
      If !fstat Then
        # FGR 28/07/2014 : X3SUIVI100229 : on affecte seulement si ça change. Donc on flag seulement si ça change
        If ITER = 1 Then
          If [M:BPC4]REP0(INOL) <> [F:MAR]REPNUM Then
            [M:BPC4]REP0(INOL) = [F:MAR]REPNUM
            [M:BPC4]FLMOD(INOL) = 1
          Endif
          If [M:BPC4]PREREP0(INOL) <> [F:MAR]REPNUM Then
            [M:BPC4]PREREP0(INOL) = [F:MAR]REPNUM
            [M:BPC4]FLMOD(INOL) = 1
          Endif
        Elsif ITER = 2 Then
          If [M:BPC4]REP1(INOL) <> [F:MAR]REPNUM Then
            [M:BPC4]REP1(INOL) = [F:MAR]REPNUM
            [M:BPC4]FLMOD(INOL) = 1
          Endif
          If [M:BPC4]PREREP1(INOL) <> [F:MAR]REPNUM Then
            [M:BPC4]PREREP1(INOL) = [F:MAR]REPNUM
            [M:BPC4]FLMOD(INOL) = 1
          Endif
        Endif
      Endif
    Next
  Endif
End

