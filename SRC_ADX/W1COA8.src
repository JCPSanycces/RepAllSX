#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque COA8 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:18"
A_USER  = "DOC"
A_STAMP = "20181109230318"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask COA8 [COA8]
Gosub HORODAT
Local Inpbox "COA8" From GFONCTION At A_STAMP With A_WINDPREV Mask [COA8] As [SIM_]
Grizo [COA8]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [COA8]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=24
Return

$ON_ACCDEB
Onevent CONTROL Call C_ACCDEB(zc) From W1COA8
Return

Subprog C_ACCDEB(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ACCDEB" : GZNUM = 41979 : Endif
If !mkstat
 ## Action STD
 Call C_ACCDEB(VALEUR) From SUBCOA
 If mkstat : GERR = 1 : GZONE = "ACCDEB" : GZNUM = 41979 : Endif
Endif
Gosub _AFF
End

$ON_INTITDEB
Onevent BEFORE_AREA Gosub AV_INTITDEB From W1COA8
Return

$AV_INTITDEB
## Action STD
Call AV_INTITDEB(zc) From SUBCOA
Gosub _AFF
Return

$ON_ACCCDT
Onevent CONTROL Call C_ACCCDT(zc) From W1COA8
Return

Subprog C_ACCCDT(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ACCCDT" : GZNUM = 41980 : Endif
If !mkstat
 ## Action STD
 Call C_ACCCDT(VALEUR) From SUBCOA
 If mkstat : GERR = 1 : GZONE = "ACCCDT" : GZNUM = 41980 : Endif
Endif
Gosub _AFF
End

$ON_INTITCDT
Onevent BEFORE_AREA Gosub AV_INTITCDT From W1COA8
Return

$AV_INTITCDT
## Action STD
Call AV_INTITCDT(zc) From SUBCOA
Gosub _AFF
Return

$CHG_STY
Return


