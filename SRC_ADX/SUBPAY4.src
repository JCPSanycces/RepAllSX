#<AdxTL>@(#)3.0.0.0 $Revision$
###############################################################################
# History:
# 2018-03-16 Bader X3-81475 PICKE: When user didn't click "New" before picking > enforce RAZCRE for correct initialization
###############################################################################


GFLAG=""
Raz GBIDC1, GBIDC2
Call OBJET("PAY",GBIDC2,GBIDC3) From GOBJET
End

###############################################################################
###############################################################################
############## GESTION des TIROIRS sous la saisie des règlements  #############
###############################################################################
###############################################################################
## $TIROIR     : Rafraichissement des tiroirs des échéances (RAF_ECHE)
## $FILGAUCHE  : Filtre pour les tiroirs
## $GAUCHE     : Contrôle sur le tiroir des Lots de saisie
## $PICKE      : Pick les éléments des tiroirs des échéances
## $DEPICK     : Depick les éléments des tiroirs des échéances
## $FIN_PICK   : Rafraichissement du tableau de saisie
## $HINT_KEY   : Amélioration des performances (DdM31546)
## $FIN_ACTION
###############################################################################

##################################################delai#############################
#### Rafraîchissement des tiroirs des échéances
###############################################################################
$RAF_ECHE
Case currbox
 When "GAU_CHE"+num$(ILISDU5),"GAU_CHE"+num$(ILISDU6)  : # Tiroir Echéances groupées
                                                       : # Tiroir Echéances
  ILIS=val(right$(currbox,8))
  Gosub REMP_LISGAU From GOBJSUB
  Gosub MARQUE From SUBPAY4
Endcase
Return

###############################################################################
#### Filtre pour les tiroirs
###############################################################################
$FILGAUCHE
If ILIS
 Case ILIS
  When ILISPYL   :# Liste des Lots de saisie
   If FLGLOT & GUSRFCY(1)<>"\"
    FILGAUSUP = "[F:PYL]PAYTYP='"+GFONC1+"'"   # Type de règlement de la transaction
    Call ADDCRIT(FILGAUSUP,IFILGAUSUP, "FILGAUCHE","find([PYL]FCY,GUSRFCY(1..GNBAUZ))","&")From GOBJSUB
   Elsif FLGLOT
    FILGAUSUP = "[F:PYL]PAYTYP='"+GFONC1+"'"   # Type de règlement de la transaction
   Else
    FILGAUSUP = "[F:PYL]PAYTYP='z'"
   Endif

  # Echéances groupées, Echéances : on ne peut voir que les échéances des sites sur lesquels on a des habilitations users
  When ILISDU5, ILISDU6
   Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "FLGCLE=1", " & ") From GOBJSUB
   Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ( ( find(TYP,'*SO','*PO')<>0 ) | (DUDSTA=2 & find(TYP,'*SO','*PO')=0)) ","") From GOBJSUB
   If [M]FCY<>""
    Call PARAM([M]FCY,"SEVFCYENT",OPT) From ADOVAL  : # OD inter-sites
    If ILIS=ILISDU5 : Call IND_SELRAP("DU5","FCY",IND) From GOBJACT : Endif
    If ILIS=ILISDU6 : Call IND_SELRAP("DU6","FCY",IND) From GOBJACT : Endif
    If OPT<>"2" |  (IND>0 & SAIRAP(IND)="")
     Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "FCY=[M]FCY", " & ") From GOBJSUB
    Elsif GUSRFCY(1)<>"\"
     Call ADDCRIT(FILGAUSUP,IFILGAUSUP, "FILGAUCHE","find([F:DUD]FCY,GUSRFCY(1..GNBAUZ))","&")From GOBJSUB
    Endif
   Elsif GUSRFCY(1)<>"\"
    Call ADDCRIT(FILGAUSUP,IFILGAUSUP, "FILGAUCHE","find([F:DUD]FCY,GUSRFCY(1..GNBAUZ))","&")From GOBJSUB
   Endif

   If [M]BPR<>""
    Call PARAM([M]FCY,"SEVBPRENT",OPT) From ADOVAL : # OD inter-tiers
    If ILIS=ILISDU5 : Call IND_SELRAP("DU5","BPR",IND) From GOBJACT : Endif
    If ILIS=ILISDU6 : Call IND_SELRAP("DU6","BPR",IND) From GOBJACT : Endif
    If OPT<>"2" |  (IND>0 & SAIRAP(IND)="")
     Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "BPRPAY=[M]BPR", " & ") From GOBJSUB
    Endif
   Endif

   If [F:TPY]EPACDTTRF=2 & dim(GSDDMGT)>0  & GSDDMGT=2 & [F:TPY]SNS=2
    If [M]UMRNUM<>""
     Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "( ( find(TYP,'*SO','*PO')<>0 ) | ([F:DUD]UMRNUM=[M]UMRNUM & find(TYP,'*SO','*PO')=0))", " & ") From GOBJSUB
    Else
     Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "( ( find(TYP,'*SO','*PO')<>0 ) | ([F:DUD]UMRNUM<>'' & find(TYP,'*SO','*PO')=0))", " & ") From GOBJSUB
    Endif
   Else
    If [M]BPAINV<>""
     If ILIS=ILISDU5 : Call IND_SELRAP("DU5","BPAPAY",IND) From GOBJACT : Endif
     If ILIS=ILISDU6 : Call IND_SELRAP("DU6","BPAPAY",IND) From GOBJACT : Endif
     If OPT<>"2" |  (IND>0 & SAIRAP(IND)="")
      Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "BPAPAY=[M]BPAINV", " & ") From GOBJSUB
     Endif
    Endif
   Endif

   Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "BPRFCT=''", " & ") From GOBJSUB

   # Pas de pièce comptable pour les acomptes
   Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ( ( find(TYP,'*SO','*PO')<>0 ) | ([F:HAE]FLGREP<>2 & find(TYP,'*SO','*PO')=0)) ","") From GOBJSUB
   Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ( ( find(TYP,'*SO','*PO')<>0 ) | ([F:HAE]CAT=1 & find(TYP,'*SO','*PO')=0)) ","") From GOBJSUB


   # SAM #110081 angre 21.01.2016
   #original code begin
    #Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ( ( find(TYP,'*SO','*PO')<>0 ) | (left$([F:HAE]REFINT,3)<>'PYH' & left$([F:HAE]REFINT,3)<>'FRM' & find(TYP,'*SO','*PO')=0)) ","") From
# GOBJSUB
   #original code end

   #new code begin
   Local Char MPLAN(30)
   Call LECPLAN([M]CPY,GTYPGEN,MPLAN) From CPTDIV

   #get parameter PAYUNALL (local menu #1)
   Local Char PAYUNALL(1)
   Call PARAM([M]CPY,"PAYUNALL",PAYUNALL) From ADOVAL
   #if parameter set to no
   If PAYUNALL <> "2" or (PAYUNALL = "2" and [M]BPR = "") #if BPR is empty ignore PAYUNALL = YES
    Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ( ( find(TYP,'*SO','*PO') ) | (left$([F:HAE]REFINT,3)<>'PYH' & left$([F:HAE]REFINT,3)<>'FRM' & !find(TYP,'*SO','*PO'))) ","") From GOBJSUB
   Else #if parameter set to yes
    Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ([F:GAC]COA='" + MPLAN + "' & [F:GAC]ACCSHO = [F:DUD]SAC & [F:GAC]FLGVAT <> 5)  ","") From GOBJSUB
   Endif
  #new code end

   If [M]USRPAZ<[M]MAXPAZ | ([M]USRPAZ>=[M]MAXPAZ & [L]OPTCTLBAP="1")
    Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "(SNS=1 | FLGPAZ>="+num$([M]MAXPAZ)+")", " & ") From GOBJSUB
   Endif

   If ILIS=ILISDU6
    If [F:TPY]SNS=1
     Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "BPRTYP=2", "&") From GOBJSUB
    Endif
    If [F:TPY]SNS=2
     Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", "BPRTYP=1", "&") From GOBJSUB
    Endif
   Endif

   If dim([F:GTES]CURLEG)>0
    If GCURLEG<>"" & [M]FCY<>""
     Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ( ( find(TYP,'*SO','*PO')<>0 ) | ([F:GTES]CURLEG='"+GCURLEG+"' & [F:GTE]DUDDATFLG=2 & find(TYP,'*SO','*PO')=0)) ","") From GOBJSUB
    Elsif GFLAGLEG<>""
     Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ( ( find(TYP,'*SO','*PO')<>0 ) | ([F:GTES]CURLEG='"+GFLAGLEG+"' & [F:GTE]DUDDATFLG=2 & find(TYP,'*SO','*PO')=0)) ","") From GOBJSUB
    Elsif GLEGFIL<>""
     Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ( ( find(TYP,'*SO','*PO')<>0 ) | ([F:GTES]CURLEG='"+GLEGFIL+"' & [F:GTE]DUDDATFLG=2 & find(TYP,'*SO','*PO')=0)) ","") From GOBJSUB
    Else
     Call ADDCRIT(FILGAUSUP , IFILGAUSUP, "FILGAUCHE", " & ( ( find(TYP,'*SO','*PO')<>0 ) | ([F:GTES]CURLEG='"+GDOSLEG+"' & [F:GTE]DUDDATFLG=2 & find(TYP,'*SO','*PO')=0)) ","") From GOBJSUB
    Endif
   Endif

   GPOINT = "CRITERE" : Gosub ENTREE From EXEFNC
 Endcase
Endif
Return

###############################################################################
#### Contrôle sur le tiroir des Lots de saisie
###############################################################################
$GAUCHE
Case currbox
 When "GAU_CHE"+num$(ILISPYL)   :# Tiroir Lots de saisie
  Read [PYL]PYL0=[F:PYL]COD # Lot clické
  Read [PYH]PYH2=[F:PYL]COD;[F:PYL]NBRPAY # Dernier règlement du lot
 Endcase
Return

###############################################################################
#### Pick les éléments des tiroirs des échéances
###############################################################################
$PICKE
# Bader 2018-07-04 begin
Local Integer CHGAMTCUR
Local Decimal SAVAMTCUR
# Bader 2018-07-04 end

# X3-81475 BEGIN When user didn't click "New" before picking > enforce RAZCRE for correct initialization
If [M]FCY="" and GREP = ""
   REP = "C" : GREP = "C"
   ACTION = "RAZCRE" : Gosub ACTION From GOBJSUB
Endif
# X3-81475 END

DISPLAY_AFTPICK = 0
# Il faut lire la table des échéances.
Case currbox
 When "GAU_CHE"+num$(ILISDU5)  : # Tiroir Echéances groupées
  Read [DU2_]DUD9 = [F:DU2_]BPR;[F:DU2_]BPAPAY;[F:DU2_]NUMDUD
  [F:DUD] = [F:DU2_]
 When "GAU_CHE"+num$(ILISDU6)  : # Tiroir Echéances
  Read [DU1_]DUD0 = [F:DU1_]TYP;[F:DU1_]NUM;[F:DU1_]LIG;[F:DU1_]DUDLIG
  [F:DUD] = [F:DU1_]
Endcase

# Vérification des droits de modifications sur le règlement
Gosub OK_MODIF From SUBPAY3 : If !OK : Return : Endif

# If FCY is not populated, the value of GCURLEG can be anything that is not correct.
If [M]FCY="" : GCURLEG = GFLAGLEG : Endif

# Contrôle sur la destination comptable par défaut ainsi que ces droits d'accès.
If [F:TPY]DENDEF<>""
 Call CONTCDA([F:TPY]DENDEF,GCURLEG,"") From SUBCDA
 If mkstat
  # Destination comptable
  GMESSAGE=mess(40,121,1)-[F:TPY]DENDEF-"\"+GMESSAGE
  mkstat=0 : OK=0
 Elsif [F:CDA]ACCTYP=1    :# Schéma de compte Banque<=>Tiers
  If dim([F:CDA]ACS)>0   :# Code d'accès
   Call CONTEXE([F:CDA]ACS) From CPTSUB
   If mkstat : mkstat=0 : OK=0 : Endif
  Endif
 Else
  GMESSAGE=mess(87,117,1)-mess(1,612,1) : OK=0
  # Le schéma de compte doit etre Banque<=>Tiers
 Endif
 If !OK : Return : Endif

 If !find([F:DUD]TYP,"*SO","*PO")
  Call CONTGTE([F:DUD]TYP,GCURLEG,"") From SUBGTE
  If mkstat
   # Destination comptable
   GMESSAGE=mess(40,121,1)-[F:CDA]COD-"\"+GMESSAGE : mkstat=0 : OK=0
  Elsif [F:CDA]ACCBPR<>""
   # Destination comptable  \ Type de pièce incorrecte
   GMESSAGE=mess(40,121,1)-[F:CDA]COD-"("+[F:CDA]ACCBPR+")\"-[F:DUD]TYP-mess(43,106,1) : OK=0
  Else
   Call CONTEXE([F:GTE]ACS) From CPTSUB
   If mkstat : mkstat=0 : OK=0 : Endif
  Endif
 Endif
Else
 GMESSAGE=mess(88,117,1) : OK=0 : # Dest. comptable non paramétrée
Endif
If !OK : Return : Endif

If [F:TPY]EPACDTTRF=2

 If dim(GSDDMGT)>0 & GSDDMGT=2 & [M]SNS=2
  If !find([F:DUD]TYP,"*SO","*PO") & [M]UMRNUM<>"" & [F:DUD]UMRNUM<>[M]UMRNUM
   GMESSAGE = mess(279,117,1)-[M]UMRNUM : OK = 0 : Return
  Elsif find([F:DUD]TYP,"*SO","*PO") & [M]UMRNUM=""
   GMESSAGE=mess(10,123,1) : OK = 0 : Return
  Endif
 Endif
Endif

Local Char    OPT(1)
Local Decimal MONTANT

OPT = "P"
Raz MONTANT

# Initalisation du sens du réglement qd sens de transaction de réglement indéterminé [F:TPY]SNS =3 (donc [M]SNS=0)
# On utilise le AV_SNS de SUBPAY qui est appelé en fait plus tard dans le process qd on remplit le masque
# pour éviter qd on charge l'échéance d'avoir un [M]SNS=0 valeur fausse utilisé pour les ctrl sur les différents sens
# (DUD, TPY, Piéce etc..)
If varinit([M]SNS)=0
 Local Integer SENS
 SENS =0
 If[F:DUD]BPRPAY<>"" & [F:DUD]SAC<>"" & [M]ACC=""
  [M]BPR=[F:DUD]BPRPAY : [M]BPRSAC=[F:DUD]SAC
  Call AS_ACC([M]ACC) From SUBPAY
 Endif
 Call AV_SNS(SENS) From SUBPAY
 [M]SNS=SENS
Endif


# Génération automatique des escomptes/agios
If [F:DUD]DEP<>""

 Local Char DENCOD(GLONCDA)
 Local Integer DELAI, SIGN
 Local Decimal ARD,TAUX_ESC, MONT_ESC
 Local Char    DEPTAX(GLONVAT)

 # Destinations comptables des escomptes
 Case [M]SNS
  When 1 : Call PARAM([M]CPY,"DENPAY",GDIV(2)) From ADOVAL  # AP Discounts
  When 2 : Call PARAM([M]CPY,"DENDEP",GDIV(2)) From ADOVAL  # AR Discounts
 Endcase
 If GDIV(2)<>""
  Call CONTCDA(GDIV(2),GCURLEG,"") From SUBCDA
  # Destination comptable non paramétrée
  If mkstat : GMESSAGE = mess(40,121,1)-GDIV(2)+"\"+GMESSAGE : mkstat=0 : Return : Endif

  # Destination comptable : Le schéma de compte doit être Compte<=>Tiers
  If [F:CDA]ACCTYP<>3 : GMESSAGE = mess(40,121,1)-[F:CDA]COD+"\"+mess(87,117,1)-mess(3,612,1) : Return : Endif

  # Destination comptable : Code comptable non défini
  If [F:CDA]ACCCOD="" : GMESSAGE = mess(40,121,1)-[F:CDA]COD+"\"+mess(179,105,1) : Return : Endif

  # Destination comptable : Destination non imputable
  If [F:CDA]IPTDAC=1  : GMESSAGE = mess(40,121,1)-[F:CDA]COD+"\"+mess(60,117,1) : Return : Endif
 Else
  #Destination comptable : Compte inexistant
  GMESSAGE = mess(40,121,1)-":"-mess(38,106,1)
  Return
 Endif

 # Destinations comptables des agios
 Call PARAM([M]CPY,"DENCRG",GDIV(5)) From ADOVAL
 If GDIV(5)<>""
  Call CONTCDA(GDIV(5),GCURLEG,"") From SUBCDA
  # Destination comptable non paramétrée
  If mkstat  : GMESSAGE = mess(40,121,1)-GDIV(5)-"\"-GMESSAGE : mkstat=0 : Return : Endif

  # Destination comptable : Le schéma de compte doit être Compte<=>Tiers
  If [F:CDA]ACCTYP<>3 : GMESSAGE =  mess(40,121,1)-[F:CDA]COD+"\"+mess(87,117,1)-mess(3,612,1) : Return : Endif

  # Destination comptable : Code comptable non défini
  If [F:CDA]ACCCOD="" : GMESSAGE = mess(40,121,1)-[F:CDA]COD+"\"+mess(179,105,1) : Return : Endif

  # Destination comptable : Destination non imputable
  If [F:CDA]IPTDAC=1  : GMESSAGE = mess(40,121,1)-[F:CDA]COD+"\"+mess(60,117,1) : Return : Endif
 Else
  #Destination comptable : Compte inexistant
  GMESSAGE = mess(40,121,1)-":"-mess(38,106,1)
  Return
 Endif
 #If GMESSAGE<>"" :  Return : Endif


 # Lecture devise
 Call LECTURE("TCU",[F:DUD]CUR,"") From CONTOBJ
 ARD=[F:TCU]CURRND

 # Date comptable
 If [M]ACCDAT=[0/0/0] : [M]ACCDAT=datesyst : Endif
 ## Demande PE 55191
 Local Integer CAL_ESCAGIO : CAL_ESCAGIO = 0
 Local Integer FLGDEP : FLGDEP = 0
 GPOINT = "CAL_ESCAGIO" : Gosub ENTREE From EXEFNC

 If ((CAL_ESCAGIO=2) or ([F:TPY]SNS<>2 & [F:DUD]SNS=-1) or ([F:TPY]SNS>=2 & [F:DUD]SNS=1)) & !find([F:DUD]TYP,"*SO","*PO")
  Raz DELAI, TAUX_ESC
  MONTANT = [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR

  If GDEPMGTMOD = 1 | GDEPMGTMOD = 5
   Call FLGDEP([F:DUD]CPY,[F:DUD]DEP,FLGDEP) From PAYDEPLIB2
  Endif

  Call ESC_AGIO([F:DUD]DEP,MONTANT,[M]ACCDAT,[F:DUD]DUDDAT,DELAI,[L]TAUX_ESC,[L]MONT_ESC,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From TRTDIV
  If ([L]TAUX_ESC<0 & GDIV(2)="") or ([L]TAUX_ESC>0 & GDIV(5)="") : [L]TAUX_ESC=0 : Endif
  If [L]MONT_ESC<>0
   If [L]TAUX_ESC <> 0
    If [L]TAUX_ESC>0 and DELAI<0 : [L]MONT_ESC *= -1 : Endif
   Endif
   [L]MONT_ESC = arr([L]MONT_ESC,ARD)
  Endif
  If [L]TAUX_ESC<0 | ([L]TAUX_ESC=0 & [L]MONT_ESC<0) # Escompte
   [L]DENCOD = GDIV(2)
   # 81683 Early discounts - auto add discount line
   If [M]SNS=2 & func AFNC.PARAM("AUTDEPCUS",[M]CPY)="1"
    Raz [L]MONT_ESC
   Endif
  Elsif [L]TAUX_ESC>0 | ([L]TAUX_ESC=0 & [L]MONT_ESC>0) # Agio
   [L]DENCOD = GDIV(5)
  Endif
 Endif

 # 2015-09-11 TOGAN/DNE INSERT BEGIN (SAM #106044)
 # Note: SAM #106044: According to PRD chapter 6.2 AUTDEPCUS has to be active as well as DEPMSK and
 #       additionally the open item has to have a discount condition to open the discount pop-up screen.
 #       It is restricted to discounts only.
 #
 # Note: The following variables from current context are used and their values are changed on return:
 #         - [L]MONTANT      the amount in currency
 #         - [L]TAUX_ESC     discount/charge rate
 #         - [L]MONT_ESC     discount/charge in currency
 #         - [L]DENCODE      paymente attribute (from GDIV(2) and GDIV(5))
 #       The following variables are only used for their values:
 #         - [F:DUD]CUR      currency code
 #         - [L]ARD          rounding parameter from currency
 #         - GDIV(2)         payment attribute for early discount
 #         - GDIV(5)         payment attribute for late charge
 #         - [M]ACCDAT       reference date for "days over..."
# X3-99653 Bader 2018-07-04 begin
 Raz CHGAMTCUR
# X3-99653 Bader 2018-07-04 end
 If [F:DUD]DEP <> ""
&   and func AFNC.PARAM("AUTDEPCUS", [M]CPY) = "2"
&   and func AFNC.PARAM("DEPMSK", [M]CPY) = "2"
&   and [F:DUD]SNS = 1
&   and [F:DUD]TYPDUD = 2
&   and not([L]TAUX_ESC > 0 or ([L]TAUX_ESC = 0 and [L]MONT_ESC > 0))  # AR / No late Charge
#&   and [M]AMTCUR = 0 # No allocated amount
# X3-99653 Bader 2018-07-04 begin
     If [M]RSTIMPUT <> 0            # if "Remaining for allocation" is filled (BP amount has been entered) > set "BP amount" temporarily to zero and restore later
        [L]SAVAMTCUR = [M]AMTCUR    # save value of "BP amount"
        [L]CHGAMTCUR = 1            # set flag "BP amount changed"
        [M]AMTCUR = 0               # set "BP amount" to zero to enforce correct calculation of discount in case of manual change in discount screen
     Endif
# X3-99653 Bader 2018-07-04 end
     Call DISCOUNT_MANAGEMENT([L]MONTANT, [L]TAUX_ESC, [L]MONT_ESC, [L]DENCOD, [F:DUD]CUR, [M]RSTIMPUT, [M]CUR, [L]ARD, GDIV(2), GDIV(5), [M]ACCDAT) From SUBPAYDISMSK
 Endif
# 2015-09-11 TOGAN/DNE INSERT END

 # Chargement de l'échéance sélectionnée
 [L]MONTANT += MONT_ESC
 Call LEC_CDA_LEG(GCURLEG,[F:TPY]DENDEF) From CPTLEC
 Gosub CHARGE_DUD From SUBPAY2
 Gosub INIT_CCE

 ## Early discount/later charge Loading
 ## Les escomptes/agio sont eclatés par taxe dans les cas suivant
 ## 1) Si GDEPMGTMOD=1 (Rebate on VAT) :
 ##      - Pour une facture saisie avant la migration V6->V7, l'éclatement se fera par code taxe en exploitant la pièce comptable facture (ss prog ECLAT_TVA_HAE)
 ##      - Pour une facture saisie après la migration V6->V7, l'éclatement se fera par code taxe en exploitant les tables PVCRVAT/SVCRVAT pour les factures négoce
 ##        et les tables BPCINVLIG/BPSINVLIG pour les factures tiers
 ##      - Pour une facture qui n'existe pas dans SINVOICE/PINVOICE (saisie directement dans la compta),l'éclatement se fera par code taxe
 ##        en exploitant la pièce comptable facture
 ## 2) Si GDEPMGTMOD=2 (Ventilation par TVA/niveau facture) :
 ##      - Pour une facture saisie avant la migration V6->V7, l'éclatement se fera par code taxe en exploitant la pièce comptable facture (ss prog ECLAT_TVA_HAE)
 ##      - Pour une facture saisie après la migration V6->V7, l'éclatement se fera par code taxe en exploitant les tables PVCRVAT/SVCRVAT pour les factures négoce
 ##        et les tables BPCINVLIG/BPSINVLIG pour les factures tiers
 ##      - Pour une facture qui n'existe pas dans SINVOICE/PINVOICE (saisie directement dans la compta),l'éclatement se fera par code taxe
 ##        en exploitant la pièce comptable facture
 ## 3) Si GDEPMGTMOD=3 (Mode Global) :
 ##      Pas déclatement pas code taxe
 ## 4) Si GDEPMGTMOD=4 (Ventilation par code taxe/niveau compte)
 ##      Eclatement par code taxe en exploitant la pièce comptable et le flag 'Soumis à escompte (O/N)' defini au niveau des comptes (ss prog ECLAT_TVA_HAE)
 ## 5) If GEPMGTMOD= 5 (Belgium case), an only one discount line must be generated (no split by tax code)
 ##      - If the Open Item is attached to an early discount code which contains an invoicing element, the
 ##        only one discount line generated must be associated to the tax code defined in the 'DEPEXETAX' Parameter
 ##      - If the Open Item is not attached to an early discount code or is attached to an early discount code
 ##        which doesn't contain invoicing element, the only one discount line generated will be associated
 ##        to the tax code attached to the discount account (same behavior than the "Global" Mode (GDEPMGTMOD=3)

 If GDEPMGTMOD = 3 | GDEPMGTMOD=5 | ([L]TAUX_ESC>0 | ([L]TAUX_ESC=0 & [L]MONT_ESC>0))
  [L]MONTANT = MONT_ESC
  If [L]MONTANT
   [L]SIGN = 0
   Call SNSPAYECH([F:CDA]ACCSNS,[F:TPY]SNS,[F:DUD]SNS,[L]SIGN) From SUBPAY2
   [L]MONTANT = -[L]MONTANT*[L]SIGN
   Call LEC_CDA_LEG(GCURLEG,[L]DENCOD) From CPTLEC
   Gosub CHARGE_DUD From SUBPAY2
   If GDEPMGTMOD=5 & FLGDEP & !([L]TAUX_ESC>0 | ([L]TAUX_ESC=0 & [L]MONT_ESC>0))
    ## In that case and only if it's a discount and not a late charge, the tax code associated to
    ## the discount line must be the one defined in the DEPEXETAX Parameter
    nolign = [M]NBLIG
    Call PARAML([M]FCY,"DEPEXETAX",[L]DEPTAX) From ADOVAL
    [M]VATLIN(nolign-1) = [L]DEPTAX
    If dim([M:PAY1]VATLIN)>0
     Affzo [M:PAY1]VATLIN(nolign-1)
    Elsif dim([M:PAY2]VATLIN)>0
     Affzo [M:PAY2]VATLIN(nolign-1)
    Endif
    [M]EARDISFLG(nolign-1) = 2
   Endif
   Gosub INIT_CCE
  Endif
 Else
  If [L]MONT_ESC
   [L]SIGN = 0
   Call SNSPAYECH([F:CDA]ACCSNS,[F:TPY]SNS,[F:DUD]SNS,[L]SIGN) From SUBPAY2
   Call LEC_CDA_LEG(GCURLEG,[L]DENCOD) From CPTLEC
   If GDEPMGTMOD = 4 | ((GDEPMGTMOD=1 | GDEPMGTMOD=2) & dim(GLASINTNUM)>0 & GLASINTNUM>0 & [F:DUD]ACCNUM<=GLASINTNUM)
    Gosub ECLAT_VAT_HAE From PAYDEPLIB3
   Elsif GDEPMGTMOD = 1 | GDEPMGTMOD = 2
    Gosub ECLAT_VAT_INV From PAYDEPLIB3
   Endif
  Endif
 Endif
Else
 # Chargement de l'échéance sélectionnée
 Gosub CHARGE_DUD From SUBPAY2
 Gosub INIT_CCE
Endif

If OPT=""
 GMESSAGE=mess(94,121,1)-"="-num$(sum([M]AMTLIN2(0..[M]NBLIG-1)))-[M]CUR : OK=0
 # Montants imputés = MT
Else OK=1
# X3-99653 Bader 2018-07-04 begin
 If [L]CHGAMTCUR = 1                        # if [M]AMTCUR has been temporarily set to zero before displaying discount screen
    [M]AMTCUR = [L]SAVAMTCUR                # > restore original value of [M]AMTCUR ...
    If dim([M]RSTIMPUT)>0 & [M]AMTCUR<>0    # ... and recalculate correct value of "Remaining for allocation"
     [M]RSTIMPUT = [M]AMTCUR-[M]TOTIMPUT
    Endif
    Affzo RSTIMPUT
 Endif
# X3-99653 Bader 2018-07-04 end

 If CLECUR : # Une échéance a été transférée sur un règlement existant
  If [M]SNS=1 & REP="": # Dépense
   Call FOUBAP([M]BPR) From SUBPAY2
   If GMESSAGE<>"" : OK=0 : DISPLAY_AFTPICK=1 : Endif
  Endif
  Gosub ENTRE_MODIF From GOBJSUB
 Else : # On entre en création
  If REP=""
   Gosub SETNOK From GOBJSUB
   REP = "C" : GREP = "C"
   ACTION = "RAZCRE" : Gosub ACTION From GOBJSUB
  Endif
 Endif
Endif

# Issue 101378: Localization Switzerland, 2016-01-25 TOGAN
If func AFNC.ACTIV("KSW")>0
# X3-99013 2018-07-25 Bader begin
#  If dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2 : # parameter "Swiss checks in payments" = yes?
  If (dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2) or (dim(GSWIPAYQR) > 0 and GSWIPAYQR = 2) Then # parameter "Swiss ISR/QR checks in payments" = yes?
# X3-99013 2018-07-25 Bader end
    Gosub PICKE From SUBPAY4SWI
  Endif
Endif
# End issue 101378: Localization Switzerland
Return

###############################################################################
#### Depick les éléments des tiroirs des échéances
###############################################################################
$DEPICK
Local Integer I,K,PARAMITA1
Local Char PARAMITA(5)
Raz K,OK

DISPLAY_AFTPICK = 1

# Il faut lire la table des échéances.
Case currbox
 When "GAU_CHE"+num$(ILISDU5)  : # Tiroir Echéances groupées
  Read [DU2_]DUD9 = [F:DU2_]BPR;[F:DU2_]BPAPAY;[F:DU2_]NUMDUD
  [F:DUD] = [F:DU2_]
 When "GAU_CHE"+num$(ILISDU6)  : # Tiroir Echéances
  Read [DU1_]DUD0 = [F:DU1_]TYP;[F:DU1_]NUM;[F:DU1_]LIG;[F:DU1_]DUDLIG
  [F:DUD] = [F:DU1_]
Endcase

# Vérifier le paramètre de localisation italienne
Call PARAM([M]CPY,"RTZPRW",PARAMITA) From ADOVAL
PARAMITA1 = val(PARAMITA)

# Recherche l'échéance à supprimer.
If dim([M]RITAMT)>0 and PARAMITA1 = 2
 # Cas retenue : il faut dépicker toutes les échéances de la facture.
 For I=[M]NBLIG-1 To 0 Step -1
  If [M]DUDNUM(I)=[F:DUD]ACCNUM
   K=I+1
   If K   : # Echéance en ligne K
    nolign=K : status=65
    Call AVANT_NBLIG From SUBPAY
    Gosub UPDATE_VT2
    Dela K-1 [M]NBLIG
    [M]NBLIG-=1 : OK=1
   Endif
  Endif
 Next I
 Gosub RAF_ECHE From SUBPAY4
# sinon comportement normal
Else
 For I=[M]NBLIG-1 To 0 Step -1
  If [M]DUDNUM(I)=[F:DUD]ACCNUM & [M]DUDLIG(I)=[F:DUD]DUDLIG
   K=I+1
   If K   : # Echéance en ligne K
    nolign=K : status=65
    Call AVANT_NBLIG From SUBPAY
    Gosub UPDATE_VT2
    Dela K-1 [M]NBLIG
    [M]NBLIG-=1 : OK=1
   Endif
  Endif
 Next I
Endif
Return

$UPDATE_VT2
If [M]PTF(I)-[M]PTV(I)>1
 Call ANUVENTIL([M]PTV,[M]PTF,[M]NBLIG,[M]PTV(I),[M]PTF(I)-[M]PTV(I)+1) From VENTILE
Endif
Return

###############################################################################
#### Rafraichissement du tableau de saisie
###############################################################################
$FIN_PICK
If DISPLAY_AFTPICK=1
 Affzo [PAY1]1-99
Endif
If clalev([M:PAY2]) : Affzo [PAY2]1-99 : Endif
If clalev([M:PAY1]) : Affzo [PAY1]1-99 : Endif # Discdat
Return

###############################################################################
## $HINT_KEY   : Amélioration des performances (DdM31546)
###############################################################################
$HINT_KEY
If ILIS
 Case ILIS
  When ILISDU5, ILISDU6   :# Echéances groupées, Echéances
   HINTLIS(ILIS)="DUD3"
 Endcase
Endif
Return

###############################################################################
$FIN_ACTION
Case REPONSE
 When GSTAANU
  If !CLECUR
   LOTCUR="*" # Pour forcer le prochain refresh de l'onglet Lot
  Endif
 When GSTARAF
  #--- Rafraichissement du tiroir Echeances
  Gosub RAF_ECHE From SUBPAY4
  Gosub MARQUE From SUBPAY4
  #--- Rafraichissement de l'onglet Lot de saisie
  If FLGLOT
   LOTCUR="*" : Raz OFILPICK
   If CLECUR : [L]VALC1=[F:PYH]PAYLOT : Else [L]VALC1="" : Endif
   Gosub CHARG_LOT From SUBPAY5
   If ROK : Affzo [PAY4] : Endif
  Endif
 When GSTAPRG,GSTASVG
  Case currbox
   When "GAU_CHE"+num$(ILISDU5),"GAU_CHE"+num$(ILISDU6)  : # Tiroir Echéances groupées
                                                         : # Tiroir Echéances
    Gosub MARQUE
  Endcase
 When GSTASRA
  Gosub MARQUE From SUBPAY4
Endcase

#--- Gestion de l'adresse en saisie Règlement ----#
Case BOUT
 When "5" : # Adresse Règlement
  If [L]ADRREG<>[M:PAY1]BPAINV |
&    [L]BPRNAM <> [M:PAY1]BPRNAM |
&    [L]BPAADDLIG(0)<>[M:PAY1]BPAADDLIG(0) |
&    [L]BPAADDLIG(1)<>[M:PAY1]BPAADDLIG(1) |
&    [L]BPAADDLIG(2)<>[M:PAY1]BPAADDLIG(2) |
&    [L]CRY<>[M:PAY1]CRY |
&    [L]CRYNAM<>[M:PAY1]CRYNAM |
&    [L]SAT<>[M:PAY1]SAT |
&    [L]POSCOD<>[M:PAY1]POSCOD |
&    [L]CTY<>[M:PAY1]CTY
   # Si création de règlement la modif d'adresse n'est pas une modif du règlement
   If !find(GREP,"C","D")
    GREP="M" : REP="M"
    If [M:PAY0]NUM<>"" : Gosub GRISE_CLE From =WINPROG : Endif
   Endif
  Endif
Endcase
Return

########
$MARQUE
If [M]NBLIG>0
 For I=0 To [M]NBLIG-1
  If [M]DUDNUM(I)>0 & [M]DUDLIG(I)>0
   Read [DUD]DUD1 =[M]DUDNUM(I);[M]DUDLIG(I)
   If !fstat : Gosub REPICK From GOBJSUB
   Else        Gosub DEPICK From GOBJSUB
   Endif
  Endif
 Next I
Endif
Return

###############################################################################
Subprog CHARGE_LIG(MT1,MT3)
Value Decimal MT1, MT3
Local Integer NOL, I
NOL = [M]NBLIG

Raz [M]ACC1(NOL),[M]ACC2(NOL),[M]ACC3(NOL),[M]ACC4(NOL),[M]ACC5(NOL),[M]ACC6(NOL),[M]ACC7(NOL),[M]ACC8(NOL),[M]ACC9(NOL),[M]ACC10(NOL)
Raz [M]SACLIN(NOL),[M]BPRLIN(NOL)
[M]DENCOD(NOL)=[F:CDA]COD
[M]ACCTYP(NOL)=[F:CDA]ACCTYP
[M]ACCSNS(NOL)=[F:CDA]ACCSNS

# Localization Switzerland, 2015-05-21 Bader
If func AFNC.ACTIV("KSW")>0
  If dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2 Then # parameter "Swiss checks in payments" = yes?
    Gosub CHARGE_LIG From SUBPAY4SWI
  Endif
Endif
# End Localization Switzerland

# Pour pouvoir charger des zones spécifiques dans les lignes de règlements
GPOINT = "CHARGE_LIG" : Gosub ENTREE From EXEFNC

[M]VCRNUM(NOL)=[F:DUD]NUM
Case [F:DUD]TYP
 When ""      : [M]VCRTYP(NOL)=""         : [M]IPTTYP(NOL)=0
 When "*SO"   : [M]VCRTYP(NOL)=[M]BPCTYP  : [M]IPTTYP(NOL)=1
 When "*PO"   : [M]VCRTYP(NOL)=[M]BPSTYP  : [M]IPTTYP(NOL)=2
 When Default : [M]VCRTYP(NOL)=[F:DUD]TYP : [M]IPTTYP(NOL)=3
Endcase
[M]DUDLIG(NOL)=[F:DUD]DUDLIG
[M]DUDNUM(NOL)=[F:DUD]ACCNUM

# Bug 12901 : vérifier que l'échéance n'est pas en cours de lettrage,
# pour ne pas la régler une 2eme fois
Filter [MTB] Where ACCNUM=[M]DUDNUM(NOL) & DUDLIG=[M]DUDLIG(NOL)
Look [MTB]MTB0 First
Filter [MTB]
If !fstat
 GMESSAGE=mess(70,119,1) : End     :# Echéance en cours de lettrage
Endif

[M]BPRINV(NOL)    = [F:DUD]BPR
[M]BPRSACINV(NOL) = [F:DUD]SAC

If [F:DUD]FCY<>"" : [M]FCYLIN(NOL)=[F:DUD]FCY
Else              : [M]FCYLIN(NOL)=[M]FCY
Endif
If [F:DUD]CUR<>"" : [M]CURLIN(NOL)=[F:DUD]CUR
Else              : [M]CURLIN(NOL)=[M]CUR
Endif
[M]DESLIN(NOL)=[M]DES
Raz [M]CURLIN2(NOL),[M]UOM(NOL), [M]QTYLIN(NOL)
[M]AMTLIN(NOL) = MT1
If dim([M]RITAMT)>0
 Raz [M]RITAMT2(NOL), [M]ORIT
 [M]RITAMT(NOL) = MT3
Endif
nolign=NOL+1 : Call AP_AMTLIN([M]AMTLIN(NOL)) From SUBPAY
If dim(GDEPVATLIN)> 0 & GDEPVATLIN<>""
 Gosub SET_ACCLIN From SUBPAY
Endif
Gosub RECH_ACCANA From SUBPAY3
Call LECTURE("GAC",CPTANA,PLANA) From CONTOBJ
If [F:GAC]FLGUOM=2
 [M]UOM(NOL)=[F:GAC]UOM
 Call D_QTYLIN([M]QTYLIN(NOL)) From SUBPAY
Endif
indice = NOL
Call D_VATLIN([M]VATLIN(NOL)) From SUBPAY
[M]NBLIG += 1
Gosub DEFMSKLIG From SUBPAY3
If dim([M]RITAMT)>0
 Affzo DENCOD(NOL), VCRTYP(NOL), VCRNUM(NOL), FCYLIN(NOL), CURLIN(NOL), AMTLIN(NOL),
&      RITAMT(NOL), AMTLIN2(NOL), VATLIN(NOL), UOM(NOL), QTYLIN(NOL), DSP(NOL)
Else
 Affzo DENCOD(NOL), VCRTYP(NOL), VCRNUM(NOL), FCYLIN(NOL), CURLIN(NOL), AMTLIN(NOL),
&      AMTLIN2(NOL), VATLIN(NOL), UOM(NOL), QTYLIN(NOL), DSP(NOL)
Endif
If dim([M]TOTIMPUT)>0
 [M]TOTIMPUT = sum([M]AMTLIN2)
 [M]DEVISE = [M]CUR
Endif
If dim([M]RSTIMPUT)>0 & [M]AMTCUR<>0
 [M]RSTIMPUT = [M]AMTCUR-[M]TOTIMPUT
Endif
Affzo TOTIMPUT, DEVISE, RSTIMPUT
If dim([M:PAY1]ACCDAT)>0 : Affzo [PAY1]ACCDAT : Endif
For I=1 To GNBAXE
 Case I
  When 1  : Affzo CCE1(NOL)
  When 2  : Affzo CCE2(NOL)
  When 3  : Affzo CCE3(NOL)
  When 4  : Affzo CCE4(NOL)
  When 5  : Affzo CCE5(NOL)
  When 6  : Affzo CCE6(NOL)
  When 7  : Affzo CCE7(NOL)
  When 8  : Affzo CCE8(NOL)
  When 9  : Affzo CCE9(NOL)
  When 10 : Affzo CCE10(NOL)
  When 12 : Affzo CCE12(NOL)
  When 13 : Affzo CCE13(NOL)
  When 14 : Affzo CCE14(NOL)
  When 15 : Affzo CCE15(NOL)
  When 16 : Affzo CCE16(NOL)
  When 17 : Affzo CCE17(NOL)
  When 18 : Affzo CCE18(NOL)
  When 19 : Affzo CCE19(NOL)
  When 20 : Affzo CCE20(NOL)
 Endcase
Next I
#nolign = NOL+1 : Gosub SETCHPLST From SUBPAY3
End

$INIT_CCE
Local Char    SPROG(15)
Local Char    SECTION(GLONCCE)
Local Integer AXI
nolign = [M]NBLIG
If nolign<1 : Return : Endif
For AXI=1 To GNBAXE
 SPROG = "D_CCE"+num$(AXI)
 SECTION = evalue("[M]CCE"+num$(AXI)+"("+num$(nolign-1)+")")
 Call =SPROG With SECTION From SUBPAY
 Assign "[M]CCE"+num$(AXI)+"("+num$(nolign-1)+")" With SECTION
Next AXI
Return

Subprog ECLAT_TVA(SOCIETE,SENS,NUMERO,ACC_NUM,DEPCOD,TTC,NBTAX,TCODTAX,TBASTAX,TAMTTAX,ECLVAT)
Value    Char    SOCIETE()      : # Code société
Value    Integer SENS           : # Sens
Value    Char    NUMERO()       : # Numéro document
Value    Integer ACC_NUM        : # Numéro interne accnum de l'échéance à règler
Value    Char    DEPCOD()       : # Code escompte/agio
Variable Decimal TTC            : # Montant TTC (=montant de la ligne d'écriture associée au numéro interne ACC_NUM)
Variable Integer NBTAX          : # Nombre de codes taxes de la facture (forcément...)
Variable Char    TCODTAX()(1..) : # Tableau des codes taxes de la facture
Variable Decimal TBASTAX(1..)   : # Tableau des bases de taxes par code taxe
Variable Decimal TAMTTAX(1..)   : # Tableau des montants de taxes par code taxe
Variable Integer ECLVAT         : # 1:On éclate l'esc/agio par code taxe 0:On n'éclate pas = 1 seule ligne esc/agio
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif : # Comptes
If clalev([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif : # Factures fournisseurs
If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif : # Factures clients
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif : # Lignes d'écritures comptables
If clalev([F:DUD2])=0 : Local File GACCDUDATE [DUD2] : Endif : # Echéances

Local Char    PRIO(2), TYPPCE(GLONGTE), PLAN(GLONCOA)
Local Integer I, INDTAX, CEE_FLG, FLGFAC

ECLVAT = 0 : CEE_FLG = 0 : FLGFAC = 0
If SENS=1 : PRIO="FC" : Else PRIO="CF" : Endif
For I=1 To 2
 Case mid$(PRIO,I,1)
  When "C"
   Call LECTURE("BIC",NUMERO,"") From CONTOBJ
   If fstat=0
    TYPPCE = [F:SIH]GTE : ECLVAT = 1 : FLGFAC = 1 : Break
   Endif
  When "F"
   Call LECTURE("BIS",NUMERO,"") From CONTOBJ
   If fstat=0
    TYPPCE = [F:PIH]GTE : ECLVAT = 1 : FLGFAC = 2 : [L]CEE_FLG=[F:PIH]CEEFLG : Break
   Endif
 Endcase
Next I
If !FLGFAC
 Read [DUD2]DUD1 = ACC_NUM
 If !fstat
  If [F:DUD2]BPRTYP = 1
   TYPPCE = [F:DUD]TYP : ECLVAT = 1 : FLGFAC = 1
  Elsif [F:DUD2]BPRTYP = 2
   TYPPCE = [F:DUD]TYP : ECLVAT = 1 : FLGFAC = 2
  Endif
 Endif
Endif
If ECLVAT = 0 : End : Endif
## On contrôle qu'il n'y a pas de compte charge/produit non soumis autre que la ligne auxiliarisée
## correspondant à la ligne du tiers facturé/facturant
Call SETMAINREF(SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call LECPLAN(SOCIETE,GTYPGEN,PLAN) From CPTDIV
Raz TTC, NBTAX, TCODTAX, TBASTAX, TAMTTAX

For [DAE]DAE0 Where TYP=[L]TYPPCE & NUM=[L]NUMERO & LEDTYP=GTYPGEN
 If [F:DAE]ACCNUM=[L]ACC_NUM
  TTC = [F:DAE]AMTCUR
 Else
  Call LECTURE("GAC",[F:DAE]ACC,[L]PLAN) From CONTOBJ
  If [F:GAC]FLGDEP=2 | func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)="1" | func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)="2"
   If ( !find([F:GAC]FLGVAT,2,3) & func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)<>"4" )
&   | ( !find([F:GAC]FLGVAT,2,3,4) & func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)="4" )
    ECLVAT = 0 : Break
   Else
    If [F:GAC]FLGVAT=2
     Gosub CALTAXE
     ## Code TVA
     INDTAX = find([F:DAE]TAX,TCODTAX(1..NBTAX))
     If !INDTAX
      NBTAX += 1
      TCODTAX(NBTAX) = [F:DAE]TAX
      INDTAX = NBTAX
     Endif
     TBASTAX(INDTAX) += [F:DAE]AMTCUR
     TAMTTAX(INDTAX) += [L]AMTVAT
     ## Code taxe 1
     If dim([F:DAE]TAX2)>0 & [F:DAE]TAX2<>""
      INDTAX = find([F:DAE]TAX2,TCODTAX(1..NBTAX))
      If !INDTAX
       NBTAX += 1
       TCODTAX(NBTAX) = [F:DAE]TAX2
       INDTAX = NBTAX
      Endif
      TAMTTAX(INDTAX) += [L]AMTTAX1
     Endif
     ## Code taxe 2
     If dim([F:DAE]TAX3)>0 & [F:DAE]TAX3<>""
      INDTAX = find([F:DAE]TAX3,TCODTAX(1..NBTAX))
      If !INDTAX
       NBTAX += 1
       TCODTAX(NBTAX) = [F:DAE]TAX3
       INDTAX = NBTAX
      Endif
      TAMTTAX(INDTAX) += [L]AMTTAX2
     Endif
    Endif
   Endif
  Endif
 Endif
Next
GPOINT = "DEPVATSLT" : Gosub ENTREE From EXEFNC
If ECLVAT = 0
 Raz NBTAX, TCODTAX, TBASTAX, TAMTTAX
 End
Endif
End

$CALTAXE
Local Char    TAXES(GLONVAT)(1..3)
Local Integer TYPREG , STAT
Local Decimal MONTVAT(1..3), MONTDED(1..3)
Local Decimal AMTTAX1, AMTTAX2, AMTVAT
If dim([F:DAE]TAX2)>0
 TAXES(1) = [F:DAE]TAX2  : # Code taxe 1
Endif
If dim([F:DAE]TAX3)>0
 TAXES(2) = [F:DAE]TAX3  : # Code taxe 2
Endif
TAXES(3) = [F:DAE]TAX    : # Code TVA
Call CALTAXE([F:DAE]CPY,[F:DAE]ACCDAT,"",[F:DAE]CUR,3,TAXES,1,[F:DAE]AMTCUR,MONTVAT,MONTDED,TYPREG,STAT) From SUBTVT
If FLGFAC=1 & TYPREG<>1
 Raz MONTVAT, MONTDED
Elsif FLGFAC=2 & TYPREG<>1 & (TYPREG<>4 | [L]CEE_FLG)
 Raz MONTVAT, MONTDED
Endif
[L]AMTTAX1 = MONTVAT(1)
[L]AMTTAX2 = MONTVAT(2)
[L]AMTVAT  = MONTVAT(3)
Return

Subprog BREAK_VAT(SOCIETE,SENS,NUMERO,ACC_NUM,DEPCOD,TTC,NBTAX,TCODTAX,TBASTAX,TAMTTAX,TVTLTAX,TDIE,TCCE1,TCCE2,TCCE3,TCCE4,TCCE5,TCCE6,
& TCCE7,TCCE8,TCCE9,TCCE10,TCCE11,TCCE12,TCCE13,TCCE14,TCCE15,TCCE16,TCCE17,TCCE18,TCCE19,TCCE20,TRATDSP,ECLVAT)
Value    Char    SOCIETE()         : # Code société
Value    Integer SENS              : # Sens
Value    Char    NUMERO()          : # Numéro document
Value    Integer ACC_NUM           : # Numéro interne accnum de l'échéance à règler
Value    Char    DEPCOD()          : # Code escompte/agio
Variable Decimal TTC               : # Montant TTC (=montant de la ligne d'écriture associée au numéro interne ACC_NUM)
Variable Integer NBTAX             : # Nombre de codes taxes de la facture (forcément...)
Variable Char    TCODTAX()(1..)    : # Tableau des codes taxes de la facture
Variable Decimal TBASTAX(1..)      : # Tableau des bases de taxes par code taxe
Variable Decimal TAMTTAX(1..)      : # Tableau des montants de taxes par code taxe
Variable Integer TVTLTAX(1..)      : # Tableau du nombre de lignes de ventilation par code taxe
Variable Char    TDIE()(1..)     : # Array of the dimension type of the company
Variable Char    TCCE1()(1..,1..)  : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE2()(1..,1..)  : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE3()(1..,1..)  : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE4()(1..,1..)  : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE5()(1..,1..)  : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE6()(1..,1..)  : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE7()(1..,1..)  : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE8()(1..,1..)  : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE9()(1..,1..)  : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE10()(1..,1..) : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE11()(1..,1..) : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE12()(1..,1..) : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE13()(1..,1..) : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE14()(1..,1..) : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE15()(1..,1..) : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE16()(1..,1..) : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE17()(1..,1..) : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE18()(1..,1..) : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE19()(1..,1..) : # Array of the dimensions by tax code and analytical line
Variable Char    TCCE20()(1..,1..) : # Array of the dimensions by tax code and analytical line
Variable Decimal TRATDSP(1..,1..)  : # Array of the rate allocated by tax code for each allocated line
Variable Integer ECLVAT            : # 1:On éclate l'esc/agio par code taxe 0:On n'éclate pas = 1 seule ligne esc/agio

If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif : # Comptes
If clalev([F:PIH])=0  : Local File PINVOICE   [PIH]  : Endif : # Factures fournisseurs
If clalev([F:SIH])=0  : Local File SINVOICE   [SIH]  : Endif : # Factures clients
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif : # Lignes d'écritures comptables
If clalev([F:DUD2])=0 : Local File GACCDUDATE [DUD2] : Endif : # Echéances
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif : # Company
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif : # Header
If clalev([F:DAA])=0  : Local File GACCENTRYA [DAA]  : Endif : # Analytical
If clalev([F:TVT])=0  : Local File TABVAT     [TVT]  : Endif : # Tax code
If clalev([F:GDE])=0  : Local File GDIAENTRY  [GDE]  : Endif : # Journal entry transaction

Local Char    PRIO(2), TYPPCE(GLONGTE), PLAN(GLONCOA)
Local Integer I, INDTAX, CEE_FLG, FLGFAC
Local Integer TRSLIN                          : # =1 if the journal entry belongs to a journal entry line transaction
Local Integer LNBRLED                         : # Number of automatic ledgers in the company
Local Tinyint LLEDTYP(1..len(mess(0,2644,1))) : # List of the automatic ledger types in the company
Local Tinyint LEDTYPDAA                       : # Store the current ledger type of DAA
Local Decimal AMTDISVAT(1..99)                : # Base escomptable TTC  Discount Amount+TVA
Local Decimal RATDSP                          : # Rate to allocated that initializes TRATDSP
Local Integer IANA                            : # Number of the analytical line in TCCEx
Local Integer SAVANALIN                       : # Current ana line saved
Local Char    SAVIDTLIN(5)                    : # Current line identifier saved
Local Integer SAVLIN                          : # Current line saved
Local Integer SNSACCBPR                       : # Sens of the partner account
Local Integer I, J, K, ASTATUS, OK

Raz AMTDISVAT
ECLVAT = 0 : CEE_FLG = 0 : FLGFAC = 0

If SENS=1 : PRIO="FC" : Else PRIO="CF" : Endif
For I=1 To 2
 Case mid$(PRIO,I,1)
  When "C"
   Call LECTURE("BIC",NUMERO,"") From CONTOBJ
   If fstat=0
    TYPPCE = [F:SIH]GTE : ECLVAT = 1 : FLGFAC = 1 : Break
   Endif
  When "F"
   Call LECTURE("BIS",NUMERO,"") From CONTOBJ
   If fstat=0
    TYPPCE = [F:PIH]GTE : ECLVAT = 1 : FLGFAC = 2 : [L]CEE_FLG=[F:PIH]CEEFLG : Break
   Endif
 Endcase
Next I
If !FLGFAC
 Read [DUD2]DUD1 = ACC_NUM
 If !fstat
  If [F:DUD2]BPRTYP = 1
   TYPPCE = [F:DUD]TYP : ECLVAT = 1 : FLGFAC = 1
  Elsif [F:DUD2]BPRTYP = 2
   TYPPCE = [F:DUD]TYP : ECLVAT = 1 : FLGFAC = 2
  Endif
 Endif
Endif

If ECLVAT = 0  : End : Endif


## On contrôle qu'il n'y a pas de compte charge/produit non soumis autre que la ligne auxiliarisée
## correspondant à la ligne du tiers facturé/facturant
Call SETMAINREF(SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call LECPLAN(SOCIETE,GTYPGEN,PLAN) From CPTDIV

Call LEC_CPY(SOCIETE) From CPTLEC
For I=1 To dim(TDIE)
 TDIE(I) = [F:CPY]DIE(I-1)
Next
# List of the non automatic ledgers
ASTATUS = func FINACM_SYRA.GET_LSTLEDTYP(GACTX, SOCIETE, 1, LNBRLED, LLEDTYP, GMESSAGE)
# Journal entry transaction line or column.
If [F:HAE]NUM<>[L]NUMERO & [F:HAE]TYP<>[L]TYPPCE
 Read [HAE]HAE0=[L]TYPPCE;[L]NUMERO
Endif
Call LEC_GDE([F:HAE]DACDIA) From CPTLEC
If [F:GDE]TYPENT = 2
 TRSLIN = [V]CST_ATRUE
Else
 TRSLIN = [V]CST_AFALSE
Endif

Raz TTC, NBTAX, TCODTAX, TBASTAX, TAMTTAX
Raz TCCE1, TCCE2, TCCE3, TCCE4, TCCE5, TCCE6, TCCE7, TCCE8, TCCE9, TCCE10, TCCE11, TCCE12, TCCE13
Raz TCCE14, TCCE15, TCCE16, TCCE17, TCCE18, TCCE19, TCCE20
Raz TVTLTAX, TRATDSP

SNSACCBPR = 1

For [DAE]DAE0 Where TYP=[L]TYPPCE & NUM=[L]NUMERO & LEDTYP=GTYPGEN
 If [F:DAE]ACCNUM=[L]ACC_NUM
  TTC = [F:DAE]AMTCUR
  SNSACCBPR = [F:DAE]SNS
 Else

  Call LECTURE("GAC",[F:DAE]ACC,[L]PLAN) From CONTOBJ
  If [F:GAC]FLGDEP=2 | func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)="1" | func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)="2"
   If ( !find([F:GAC]FLGVAT,2,3) & func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)<>"4" )
&   | ( !find([F:GAC]FLGVAT,2,3,4) & func AFNC.PARAM("DEPMGTMOD",[F:DUD]CPY)="4" )
    ECLVAT = 0 : Break
   Else
    If [F:GAC]FLGVAT=2
     Gosub CALTAXE
     ## Code TVA
     INDTAX = find([F:DAE]TAX,TCODTAX(1..NBTAX))
     If !INDTAX
      NBTAX += 1
      TCODTAX(NBTAX) = [F:DAE]TAX
      INDTAX = NBTAX
     Endif
     TBASTAX(INDTAX) += [F:DAE]AMTCUR
     TAMTTAX(INDTAX) += [L]AMTVAT

     If [F:DAE]SNS<>SNSACCBPR
      AMTDISVAT(INDTAX) += [F:DAE]AMTCUR + [L]AMTVAT
     Else
      AMTDISVAT(INDTAX) += ([F:DAE]AMTCUR + [L]AMTVAT)*(-1)
     Endif

     Raz LEDTYPDAA, SAVIDTLIN, SAVANALIN, SAVLIN
     IANA = TVTLTAX(INDTAX)
     # Loop on DAA : TYP+NUM+LIN+ANALIN+LEDTYP
     For [DAA]DAA2 Where TYP=[L]TYPPCE & NUM=[L]NUMERO & IDTLIN=[F:DAE]IDTLIN & find(LEDTYP,LLEDTYP(1..LNBRLED))<>0
      # For the journal entry line transaction, take the analytic of the first ledger with allocation
      OK = 1
      If TRSLIN=[V]CST_ATRUE & LEDTYPDAA=0
       LEDTYPDAA = [F:DAA]LEDTYP
      Elsif TRSLIN=[V]CST_ATRUE & LEDTYPDAA<>[F:DAA]LEDTYP
       OK = 0
      Endif

      #For the journal entry line transaction, take the analytic of the first allocation of the ledger
      If OK=1 & TRSLIN=[V]CST_ATRUE & SAVIDTLIN<>"" & SAVLIN<>0 & [F:DAA]IDTLIN=SAVIDTLIN & [F:DAA]LIN<>SAVLIN
       OK = 0
      Endif

      If OK
       # We cumulate the dimension for all the ledgers of the same idtlin and analin
       If [F:DAA]IDTLIN<>SAVIDTLIN or [F:DAA]ANALIN<>SAVANALIN
        IANA +=1
        # Exceed the dimension
        If IANA>dim(TCCE1,2)
         Break
        Endif
        SAVIDTLIN = [F:DAA]IDTLIN
        SAVANALIN = [F:DAA]ANALIN
        SAVLIN    = [F:DAA]LIN
       Endif
       For I=0 To 8
        If [F:DAA]DIE(I)="" : Break : Endif
        If [F:DAA]CCE(I)<>""
         J = find([F:DAA]DIE(I),TDIE)
         Case J
          When 1 : TCCE1(INDTAX,IANA)  = [F:DAA]CCE(I)
          When 2 : TCCE2(INDTAX,IANA)  = [F:DAA]CCE(I)
          When 3 : TCCE3(INDTAX,IANA)  = [F:DAA]CCE(I)
          When 4 : TCCE4(INDTAX,IANA)  = [F:DAA]CCE(I)
          When 5 : TCCE5(INDTAX,IANA)  = [F:DAA]CCE(I)
          When 6 : TCCE6(INDTAX,IANA)  = [F:DAA]CCE(I)
          When 7 : TCCE7(INDTAX,IANA)  = [F:DAA]CCE(I)
          When 8 : TCCE8(INDTAX,IANA)  = [F:DAA]CCE(I)
          When 9 : TCCE9(INDTAX,IANA)  = [F:DAA]CCE(I)
          When 10: TCCE10(INDTAX,IANA) = [F:DAA]CCE(I)
          When 11: TCCE11(INDTAX,IANA) = [F:DAA]CCE(I)
          When 12: TCCE12(INDTAX,IANA) = [F:DAA]CCE(I)
          When 13: TCCE13(INDTAX,IANA) = [F:DAA]CCE(I)
          When 14: TCCE14(INDTAX,IANA) = [F:DAA]CCE(I)
          When 15: TCCE15(INDTAX,IANA) = [F:DAA]CCE(I)
          When 16: TCCE16(INDTAX,IANA) = [F:DAA]CCE(I)
          When 17: TCCE17(INDTAX,IANA) = [F:DAA]CCE(I)
          When 18: TCCE18(INDTAX,IANA) = [F:DAA]CCE(I)
          When 19: TCCE19(INDTAX,IANA) = [F:DAA]CCE(I)
          When 20: TCCE20(INDTAX,IANA) = [F:DAA]CCE(I)
         Endcase
        Endif
       Next

       If TRATDSP(INDTAX,IANA)=0
        If [F:DAE]SNS<>SNSACCBPR
         TRATDSP(INDTAX,IANA) = [F:DAA]AMTCUR
        Else
         TRATDSP(INDTAX,IANA) = [F:DAA]AMTCUR*(-1)
        Endif
       Endif
      Endif
     Next

     # The allocation of this DAE exceeds the total dimension for a tax code.
     # This limit is reached inside a group of allocations ($ or allocation code) of one DAE line
     # The balance is sumed into the last line of TRATDSP
     If IANA>dim(TCCE1,2) & [F:DAA]IDTLIN=SAVIDTLIN
      If [F:DAE]SNS<>SNSACCBPR
       TRATDSP(INDTAX,IANA-1) += [F:DAE]AMTCUR - sum(TRATDSP(INDTAX,TVTLTAX(INDTAX)+1..IANA-1))
      Else
       TRATDSP(INDTAX,IANA-1) += ([F:DAE]AMTCUR * -1) - sum(TRATDSP(INDTAX,TVTLTAX(INDTAX)+1..IANA-1))
      Endif
      IANA -=1
      Gosub CHECK_COST
      IANA+=1
      TVTLTAX(INDTAX) = IANA-1 : # We stop the allocation for this tax code
     Else
      # We have already reached th limit
      If TVTLTAX(INDTAX)<dim(TCCE1,2)
       Gosub CHECK_COST
       TVTLTAX(INDTAX) = IANA - K
      Endif
     Endif

     ## Code taxe 1
     If dim([F:DAE]TAX2)>0 & [F:DAE]TAX2<>""
      INDTAX = find([F:DAE]TAX2,TCODTAX(1..NBTAX))
      If !INDTAX
       NBTAX += 1
       TCODTAX(NBTAX) = [F:DAE]TAX2
       INDTAX = NBTAX
      Endif
      TAMTTAX(INDTAX) += [L]AMTTAX1
     Endif
     ## Code taxe 2
     If dim([F:DAE]TAX3)>0 & [F:DAE]TAX3<>""
      INDTAX = find([F:DAE]TAX3,TCODTAX(1..NBTAX))
      If !INDTAX
       NBTAX += 1
       TCODTAX(NBTAX) = [F:DAE]TAX3
       INDTAX = NBTAX
      Endif
      TAMTTAX(INDTAX) += [L]AMTTAX2
     Endif
    Endif
   Endif
  Endif
 Endif
Next

For INDTAX=1 To NBTAX
 For J=1 To TVTLTAX(INDTAX)
  RATDSP = ( TRATDSP(INDTAX,J) + ( (TAMTTAX(INDTAX)*TRATDSP(INDTAX,J))/TBASTAX(INDTAX) ) ) / AMTDISVAT(INDTAX)
  TRATDSP(INDTAX,J) = RATDSP
 Next
Next

GPOINT = "DEPVATSLT" : Gosub ENTREE From EXEFNC
If ECLVAT = 0
 Raz NBTAX, TCODTAX, TBASTAX, TAMTTAX
 End
Endif
End

$CHECK_COST
K = 0
# Check that the analytical allocation added in the index iana is not already stored for the same tax code
For I=1 To TVTLTAX(INDTAX)
 For J=TVTLTAX(INDTAX)+1 To IANA-K
  If TCCE1(INDTAX,J)=TCCE1(INDTAX,I) & (dim(TCCE2,2)=1 | TCCE2(INDTAX,J)=TCCE2(INDTAX,I))
&& (dim(TCCE3,2)=1 | TCCE3(INDTAX,J)=TCCE3(INDTAX,I)) & (dim(TCCE4,2)=1 |TCCE4(INDTAX,J)=TCCE4(INDTAX,I))
&& (dim(TCCE5,2)=1 | TCCE5(INDTAX,J)=TCCE5(INDTAX,I)) & (dim(TCCE6,2)=1 | TCCE6(INDTAX,J)=TCCE6(INDTAX,I))
&& (dim(TCCE7,2)=1 | TCCE7(INDTAX,J)=TCCE7(INDTAX,I)) & (dim(TCCE8,2)=1 | TCCE8(INDTAX,J)=TCCE8(INDTAX,I))
&& (dim(TCCE9,2)=1 | TCCE9(INDTAX,J)=TCCE9(INDTAX,I)) & (dim(TCCE10,2)=1 | TCCE10(INDTAX,J)=TCCE10(INDTAX,I))
&& (dim(TCCE11,2)=1 | TCCE11(INDTAX,J)=TCCE11(INDTAX,I)) & (dim(TCCE12,2)=1 | TCCE12(INDTAX,J)=TCCE12(INDTAX,I))
&& (dim(TCCE13,2)=1 | TCCE13(INDTAX,J)=TCCE13(INDTAX,I)) & (dim(TCCE14,2)=1 | TCCE14(INDTAX,J)=TCCE14(INDTAX,I))
&& (dim(TCCE15,2)=1 | TCCE15(INDTAX,J)=TCCE15(INDTAX,I)) & (dim(TCCE16,2)=1 | TCCE16(INDTAX,J)=TCCE16(INDTAX,I))
&& (dim(TCCE17,2)=1 | TCCE17(INDTAX,J)=TCCE17(INDTAX,I)) & (dim(TCCE18,2)=1 | TCCE18(INDTAX,J)=TCCE18(INDTAX,I))
&& (dim(TCCE19,2)=1 | TCCE19(INDTAX,J)=TCCE19(INDTAX,I)) & (dim(TCCE20,2)=1 | TCCE20(INDTAX,J)=TCCE20(INDTAX,I))
   # We find an index with the same allocation then we sum in this index
   TRATDSP(INDTAX,I) += TRATDSP(INDTAX,J)
   For M=J To IANA-K
    If M = IANA-K
     # Raz the last index
     Raz TRATDSP(INDTAX,M)
     Raz TCCE1(INDTAX,M)
     If M<=dim(TCCE2,2)  : Raz TCCE2(INDTAX,M)  : Endif
     If M<=dim(TCCE3,2)  : Raz TCCE3(INDTAX,M)  : Endif
     If M<=dim(TCCE4,2)  : Raz TCCE4(INDTAX,M)  : Endif
     If M<=dim(TCCE5,2)  : Raz TCCE5(INDTAX,M)  : Endif
     If M<=dim(TCCE6,2)  : Raz TCCE6(INDTAX,M)  : Endif
     If M<=dim(TCCE7,2)  : Raz TCCE7(INDTAX,M)  : Endif
     If M<=dim(TCCE8,2)  : Raz TCCE8(INDTAX,M)  : Endif
     If M<=dim(TCCE9,2)  : Raz TCCE9(INDTAX,M)  : Endif
     If M<=dim(TCCE10,2) : Raz TCCE10(INDTAX,M) : Endif
     If M<=dim(TCCE11,2) : Raz TCCE11(INDTAX,M) : Endif
     If M<=dim(TCCE12,2) : Raz TCCE12(INDTAX,M) : Endif
     If M<=dim(TCCE13,2) : Raz TCCE13(INDTAX,M) : Endif
     If M<=dim(TCCE14,2) : Raz TCCE14(INDTAX,M) : Endif
     If M<=dim(TCCE15,2) : Raz TCCE15(INDTAX,M) : Endif
     If M<=dim(TCCE16,2) : Raz TCCE16(INDTAX,M) : Endif
     If M<=dim(TCCE17,2) : Raz TCCE17(INDTAX,M) : Endif
     If M<=dim(TCCE18,2) : Raz TCCE18(INDTAX,M) : Endif
     If M<=dim(TCCE19,2) : Raz TCCE19(INDTAX,M) : Endif
     If M<=dim(TCCE20,2) : Raz TCCE20(INDTAX,M) : Endif
    Else
     # Shift the index because the index with the same allocation has been summed and this index has to be deleted
     TRATDSP(INDTAX,M) = TRATDSP(INDTAX,M+1)
     TCCE1(INDTAX,M) = TCCE1(INDTAX,M+1)
     If M<=dim(TCCE2,2)  : TCCE2(INDTAX,M) = TCCE2(INDTAX,M+1)  : Endif
     If M<=dim(TCCE3,2)  : TCCE3(INDTAX,M) = TCCE3(INDTAX,M+1)  : Endif
     If M<=dim(TCCE4,2)  : TCCE4(INDTAX,M) = TCCE4(INDTAX,M+1)  : Endif
     If M<=dim(TCCE5,2)  : TCCE5(INDTAX,M) = TCCE5(INDTAX,M+1)  : Endif
     If M<=dim(TCCE6,2)  : TCCE6(INDTAX,M) = TCCE6(INDTAX,M+1)  : Endif
     If M<=dim(TCCE7,2)  : TCCE7(INDTAX,M) = TCCE7(INDTAX,M+1)  : Endif
     If M<=dim(TCCE8,2)  : TCCE8(INDTAX,M) = TCCE8(INDTAX,M+1)  : Endif
     If M<=dim(TCCE9,2)  : TCCE9(INDTAX,M) = TCCE9(INDTAX,M+1)  : Endif
     If M<=dim(TCCE10,2) : TCCE10(INDTAX,M) = TCCE10(INDTAX,M+1) : Endif
     If M<=dim(TCCE11,2) : TCCE11(INDTAX,M) = TCCE11(INDTAX,M+1) : Endif
     If M<=dim(TCCE12,2) : TCCE12(INDTAX,M) = TCCE12(INDTAX,M+1) : Endif
     If M<=dim(TCCE13,2) : TCCE13(INDTAX,M) = TCCE13(INDTAX,M+1) : Endif
     If M<=dim(TCCE14,2) : TCCE14(INDTAX,M) = TCCE14(INDTAX,M+1) : Endif
     If M<=dim(TCCE15,2) : TCCE15(INDTAX,M) = TCCE15(INDTAX,M+1) : Endif
     If M<=dim(TCCE16,2) : TCCE16(INDTAX,M) = TCCE16(INDTAX,M+1) : Endif
     If M<=dim(TCCE17,2) : TCCE17(INDTAX,M) = TCCE17(INDTAX,M+1) : Endif
     If M<=dim(TCCE18,2) : TCCE18(INDTAX,M) = TCCE18(INDTAX,M+1) : Endif
     If M<=dim(TCCE19,2) : TCCE19(INDTAX,M) = TCCE19(INDTAX,M+1) : Endif
     If M<=dim(TCCE20,2) : TCCE20(INDTAX,M) = TCCE20(INDTAX,M+1) : Endif
    Endif
   Next
   K +=1
  Endif
 Next
Next
Return

