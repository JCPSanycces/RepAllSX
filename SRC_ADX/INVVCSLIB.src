##########################################################
##  Localisation Belge (VCS Sequencing Number)          ##
##########################################################

##########################################################
##  VCS control                                         ##
##########################################################
Subprog BELCONTVCS (VCS,SPSTAT)
Variable Char    VCS()
Variable Integer SPSTAT :#-- 1: non numeric / 2: control key error

SPSTAT=0
VCS   = vireblc(VCS,2)
If VCS="" : End : Endif

Local Char W_VCS(GLONVCS*2)
Local Integer I, W_KEYCALC, W_KEYVCS

#-- VCS must be numeric
For I=1 To len(VCS)
  If mid$(VCS,I,1)<"0" | mid$(VCS,I,1)>"9"
     SPSTAT=1 : Break
  Endif
Next I
If SPSTAT : End : Endif

#-- format VCS number on "GLONVCS" digits
If len(VCS)=GLONVCS
    W_VCS = VCS
Else
    W_VCS = string$(GLONVCS,"0")+VCS
    W_VCS = right$ (W_VCS, 1 + len(W_VCS) - GLONVCS)
    #VCS   = W_VCS
Endif

W_KEYVCS  = val(right$(W_VCS, GLONVCS-1))          :#-- VCS key to control
W_KEYCALC = mod(val(left$(W_VCS,GLONVCS-2)),97)    :#-- calculated VCS control Key

If  W_KEYCALC = 0
    If W_KEYVCS <> 97 : SPSTAT=2 : Endif
Elsif W_KEYCALC <> W_KEYVCS
     SPSTAT=2
Endif

End

##########################################################
##  Localisation Belge (VCS Sequencing Number)          ##
##  VCS control (control is on data_type "VCS" )        ##
##########################################################
Subprog CONTVCS(VCS)
Variable Char  VCS

Local Integer SPSTAT

If func AFNC.PARAM("BELVCS",GSOCIETE)="2"
  Call BELCONTVCS(VCS,SPSTAT)
  If GIMPORT & SPSTAT = 1 : SPSTAT=2 : Endif
  Case SPSTAT
    When 0
    When 1
      GMESSAGE = mess(166,187,1)  :#-- VCS number must be numeric
      mkstat=2
   When Default
      GMESSAGE = mess(164,187,1)  :#--Belgian VCS number incorrect
      GERR=3                      :#-- warning only
  Endcase
Else
  Raz VCS
Endif
End

#############################################################################
## Localisation Belge (VCS Sequencing Number)                              ##
## Display of "VCS number" field on supplier's invoice screens : PIH1, BIS1##
## The show/hide of the field depends on :                                 ##
##     - the activity code (KBE) and the value of the BELVCS parameter     ##
## The Entry of the field depends on the supplier's country code           ##
##                                                                         ##
##  Parameters:                                                            ##
##  -    WMASQUE    : IN -  mask abbreviation                              ##
##  -    WPAYS      : IN - country of the supllier                         ##
##  -    WSTATUS    : IN - invoice status  (3=valid) <--> grizo            ##
##  -    WRAZ       : IN - ">0" : raz field requested                      ##
##  -    WRAZ       : IN - "<0" : hide field requested                     ##
#############################################################################
Subprog DISPLAY_VCS(WMASQUE,WPAYS,WSTATUS,WRAZ)
Value  Char    WMASQUE()
Value  Char    WPAYS()
Value  Integer WSTATUS
Value  Integer WRAZ

If GIMPORT : End : Endif

Local Char WSHOW(1), WGRIZO(1), WFORMAT(10)

If func AFNC.PARAM("BELVCS",GSOCIETE)<>"2" or WRAZ<0 Then
  WSHOW = "-" : WGRIZO   = ""
Else
  WSHOW = ""
  If WPAYS="BE" and WSTATUS < 3
    WGRIZO = ""
  Else
    WGRIZO = "P"
  Endif
Endif

WFORMAT= WSHOW+"K"+WGRIZO+":"+num$(GLONVCS)+"X" :#-- new field format

Case WMASQUE
  When "PIH1"
    Chgfmt [M:PIH1]BELVCS  With WFORMAT
    If WGRIZO = "" : Actzo [M:PIH1]BELVCS : Endif        :#--!!field must be always re-activated
    If WRAZ > 0    : Raz   [M:PIH1]BELVCS : If WSHOW="" : Affzo [M:PIH1]BELVCS : Endif : Endif
  When "BIS1" : Chgfmt [M:BIS1]BELVCS  With WFORMAT
    If WGRIZO = "" : Actzo [M:BIS1]BELVCS : Endif
    If WRAZ > 0    : Raz   [M:BIS1]BELVCS : If WSHOW="" : Affzo [M:BIS1]BELVCS : Endif : Endif
  When "BIC1" : Chgfmt [M:BIC1]BELVCS  With WFORMAT
  When "SIH1" : Chgfmt [M:SIH1]BELVCS  With WFORMAT
  When Default
Endcase
End

#############################################################################

##############################################################
##  Localisation Belge                                      ##
##  Getting the next value for the VCS Sequencing Number    ##
##############################################################
Subprog BELSETVCS(WSITE,WDATE,WVCS,WSTAT,WMESSA)
Value    Char    WSITE
Value    Date    WDATE
Variable Char    WVCS
Variable Integer WSTAT
Variable Char    WMESSA

If func AFNC.PARAM("BELVCS",GSOCIETE)="2" Then

  # Récupération du compteur VCS
  Local Char    VCSCPT(GLONANM)
  Local Integer OK
  If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif
  Call LECTCA(9,OK) From SUBTCA # Compteur au niveau du module "Tronc commun"
  VCSCPT = ""
  If OK Then
    VCSCPT = [F:TCA]CODNUM(1)
  Else
    VCSCPT="VCS"
  Endif

  Call NUMERO(VCSCPT,WSITE,WDATE,"",WVCS,WSTAT) From SUBANM

  If WSTAT
    # Problème lors de la récupération du compteur
    Local Integer STAT
    STAT=WSTAT
    WMESSA=mess(60,199,1)-"("+VCSCPT+") : "
    Gosub MESSAGE From SUBANM
    WMESSA-=MESSA
  Endif
Endif

End


#############################################################################

###################################################################
##  Localisation Belge                                           ##
##  When file SEPA : control of the VCS number structured or not ##
###################################################################

Funprog CONTVCSSEPA(VCS)
 Variable Char  VCS
 Local Integer SPSTAT : SPSTAT =0

 If VCS <> "" Then
  Call BELCONTVCS(VCS,SPSTAT)From INVVCSLIB
 Else
  SPSTAT =3
 Endif
End SPSTAT

