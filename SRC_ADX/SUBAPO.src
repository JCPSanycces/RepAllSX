#<AdxTL>@(#)7.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("APO",GBIDC1,GBIDC2) From GOBJET
End

##########################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Gosub CHANGE
 When "INICRE"  : Gosub INICRE
 When "RAZDUP"  : Gosub RAZDUP
 When "RAZCRE"  : Gosub RAZCRE
 When "AFFMASK" : Gosub AFFMASK
 When "LIENS":  Gosub LIENS
Endcase
Return

#-----------------------#
$AFFMASK
If dim([M:APO1]LEG)>0
 If !func AFNC.ACTIV("LEG")
  Chgfmt [M:APO1]LEG With "-K:"+num$(GLONADI)+"B"
  If dim([M:APO1]ZLEG)>0
   Chgfmt [M:APO1]ZLEG With "-K:"+num$(type([M:APO1]ZLEG)-10)+"X"
  Endif
 Endif
Endif
Return

#-----------------------#
$RAZCRE
$RAZDUP
If dim([M:APO1]LEG)>0 & !func AFNC.ACTIV("LEG")
 [M:APO1]LEG = GDOSLEG
Endif
Return

#--------------------------------#
$INICRE
If !func AFNC.ACTIV("LEG")
 [F:APO]LEG = GDOSLEG
Endif
Return

#################################################################
$OUVRE
Local File APROCESSUS [APR]
Return

#################################################################
$CREATION
$MODIF
Call MAJTEXTRA([M:APO1]INTLNG,"APROMEN","INTLNG",[M:APO1]LEG,[M:APO1]CODMEN) From ATEXTRA
Call MAJTEXTRA([M:APO1]COMMENT,"APROMEN","COMMENT",[M:APO1]LEG,[M:APO1]CODMEN) From ATEXTRA
Return

#################################################################
$ANNULE
Delete [AXX] Where CODFIC="APROMEN" & IDENT1=[L]SUPP(0) & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

#################################################################
$CHANGE

Update [AXX] Where CODFIC="APROMEN" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA APROMEN"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

#----------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File APROMEN    [APO1]
 Local File ATEXTRA [AXX1]
Else
 Local File =[M]DOSORG+".APROMEN"    [APO1]
 Local File =[M]DOSORG+".ATEXTRA" [AXX1]
Endif
If [M]DOSDES=nomap
 Local File APROMEN    [APO2]
 Local File ATEXTRA [AXX2]
Else
 Local File =[M]DOSDES+".APROMEN"    [APO2]
 Local File =[M]DOSDES+".ATEXTRA" [AXX2]
Endif
OK = 1
Local Char    DOSLEG(30)(1..30)
Local Integer NBLEG
Local Integer MONOLEG
Call SETLEG([M]DOSDES,DOSLEG,NBLEG) From DOSCONT
MONOLEG = !func AFNC.ACVDOSACT([M]DOSDES,"LEG")
If GTRACE=""
 If MONOLEG
  If (TABLE2="" or TABLE2=DOSLEG)
   Read [APO2]APO1 = DOSLEG;TABLE
   If !fstat
    OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
    If OK<>2 : OK = 0 : Endif
   Endif
  Else
   # Législation non gérée par le dossier
   Call ERREUR(TABLE2-":"-mess(67,127,1)-[M]DOSDES) From GESECRAN
   OK = 0
  Endif
 Else
  If TABLE2<>"" & !find(TABLE2,DOSLEG(1..NBLEG))
   # Législation non gérée par le dossier
   Call ERREUR(TABLE2-":"-mess(67,127,1)-[M]DOSDES) From GESECRAN
   OK = 0
  Else
   Read [APO2]APO1 = TABLE2;TABLE
   If !fstat
    OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
    If OK<>2 : OK = 0 : Endif
   Endif
  Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [APO1], [APO2]
Return

#----------------------------------------#
$TR_COP
GOK = 1
Trbegin [APO2]
 Read [APO1]APO1=TABLE2;TABLE
 If !fstat
  If [F:APO1]LEG="" or find([F:APO1]LEG,DOSLEG(1..NBLEG))
   Readlock [APO2]APO1=TABLE2;TABLE
   If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".APO" : Goto ROLL_TR_COP
   Else
    If MONOLEG & [F:APO1]LEG=""
     Readlock [APO2]APO1=DOSLEG(1);TABLE
     If fstat=1
      GOK=-1 : GLOCK = "$"+[M]DOSDES+".APO" : Goto ROLL_TR_COP
     Elsif fstat
      [F:APO2]=[F:APO1]
      [F:APO2]LEG = DOSLEG(1)
      Call COPTEXAPO("APROMEN","INTLNG",TABLE2,TABLE,DOSLEG(1),TABLE)
      Call COPTEXAPO("APROMEN","COMMENT",TABLE2,TABLE,DOSLEG(1),TABLE)
      If GOK<0 : Goto ROLL_TR_COP
      Elsif !GOK : Goto AB_TR_COP
      Endif
      If dim([F:APO2]UPDUSR)>0 : [F:APO2]UPDUSR = GUSER : Endif
      If dim([F:APO2]UPDDAT)>0 : [F:APO2]UPDDAT = date$ : Endif
      If dim([F:APO2]UPDTIM)>0 : [F:APO2]UPDTIM = time  : Endif
      Write [APO2]
      If fstat
       GOK=0 : Call FSTA("APO2") From GLOCK : Goto AB_TR_COP
      Endif
     Else
      [F:APO2]=[F:APO1]
      [F:APO2]LEG = DOSLEG(1)
      Call COPTEXAPO("APROMEN","INTLNG",TABLE2,TABLE,DOSLEG(1),TABLE)
      Call COPTEXAPO("APROMEN","COMMENT",TABLE2,TABLE,DOSLEG(1),TABLE)
      If GOK<0 : Goto ROLL_TR_COP
      Elsif !GOK : Goto AB_TR_COP
      Endif
      If dim([F:APO2]UPDUSR)>0 : [F:APO2]UPDUSR = GUSER : Endif
      If dim([F:APO2]UPDDAT)>0 : [F:APO2]UPDDAT = date$ : Endif
      If dim([F:APO2]UPDTIM)>0 : [F:APO2]UPDTIM = time  : Endif
      Rewrite [APO2]
      If fstat
       GOK=0 : Call FSTA("APO2") From GLOCK : Goto AB_TR_COP
      Endif
     Endif
    Elsif fstat
     [F:APO2]=[F:APO1]
     Call COPTEXTRA("APROMEN","INTLNG",TABLE2,TABLE) From ATEXTRA
     Call COPTEXTRA("APROMEN","COMMENT",TABLE2,TABLE) From ATEXTRA
     If GOK<0 : Goto ROLL_TR_COP
     Elsif !GOK : Goto AB_TR_COP
     Endif
     If dim([F:APO2]UPDUSR)>0 : [F:APO2]UPDUSR = GUSER : Endif
     If dim([F:APO2]UPDDAT)>0 : [F:APO2]UPDDAT = date$ : Endif
     If dim([F:APO2]UPDTIM)>0 : [F:APO2]UPDTIM = time  : Endif
     Write [APO2]
     If fstat
      GOK=0 : Call FSTA("APO2") From GLOCK : Goto AB_TR_COP
     Endif
    Else
     [F:APO2]=[F:APO1]
     Call COPTEXTRA("APROMEN","INTLNG",TABLE2,TABLE) From ATEXTRA
     Call COPTEXTRA("APROMEN","COMMENT",TABLE2,TABLE) From ATEXTRA
     If GOK<0 : Goto ROLL_TR_COP
     Elsif !GOK : Goto AB_TR_COP
     Endif
     If dim([F:APO2]UPDUSR)>0 : [F:APO2]UPDUSR = GUSER : Endif
     If dim([F:APO2]UPDDAT)>0 : [F:APO2]UPDDAT = date$ : Endif
     If dim([F:APO2]UPDTIM)>0 : [F:APO2]UPDTIM = time  : Endif
     Rewrite [APO2]  # Issue X3-103420 - 28-08-2018, before was 'Write'
     If fstat
      GOK=0 : Call FSTA("APO2") From GLOCK : Goto AB_TR_COP
     Endif
    Endif
   Endif
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

Subprog COPTEXAPO(TABLE,CHAMP,CLE1,CLE2,NCLE1,NCLE2)
Value    Char    TABLE, CHAMP, CLE1, CLE2, NCLE1, NCLE2
For [AXX1] Where CODFIC=TABLE & ZONE=CHAMP & IDENT1=CLE1 & IDENT2=CLE2
 Read [F:AXX2]AXX0 = TABLE;CHAMP;[F:AXX1]LANGUE;NCLE1;NCLE2
 If !fstat
  [F:AXX2]TEXTE = [F:AXX1]TEXTE
  Call FLDUPD("AXX2") From OBJDIV
  Rewrite [AXX2]
  If fstat
   GOK=0 : Call FSTA("AXX2") From GLOCK : Break
  Endif
 Else
  [F:AXX2] = [F:AXX1]
  [F:AXX2]IDENT1 = NCLE1
  [F:AXX2]IDENT2 = NCLE2
  Call FLDUPD("AXX2") From OBJDIV
  Write [AXX2]
  If fstat
   GOK=0 : Call FSTA("AXX2") From GLOCK : Break
  Endif
 Endif
Next
End

######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran APO1) 07/03/2013 17:21:13 (CCL)
######################################################################################
Subprog C_NIVEAU(VALEUR)
Variable Integer VALEUR
If [M]NBPROC=0 and [M]NBPROC=VALEUR<>1
  VALEUR=1 : End
Endif
If nolign<2 : End : Endif
If [M]NBPROC>0 and (VALEUR>[M]NIVEAU(nolign-2)+1 or (VALEUR=[M]NIVEAU(nolign-2)+1 and [M]MENU(nolign-2)<>2))
  GMESSAGE=mess(53,127,1) : # Niveau incorrect
  mkstat=2
Endif
End

Subprog AS_NIVEAU(VALEUR)
Variable Integer VALEUR
If VALEUR<>0 : End : Endif
If [M]NBPROC=0 : VALEUR=1 : End : Endif
# On initialise en fonction de la ligne précédente si non initialisé
If nolign<2 : End : Endif
If [M]MENU(nolign-2)=1
  VALEUR=[M]NIVEAU(nolign-2)
Else
  VALEUR=min([M]NIVEAU(nolign-2)+1,3)
Endif
End

# ---------------------------------------------------------#
Subprog AV_MENU(VALEUR)
Variable Integer VALEUR
If clalev([F:APR])=0 : Local File APROCESSUS [APR] : Endif
Read [APR]APR0=[M]PROCESSUS(nolign-1)
If fstat=0
  VALEUR=[F:APR]TYPEP
Endif
End

# ---------------------------------------------------------#
Subprog MENMET(MENMET,LANGD,CLBNAV)
Value Char MENMET             : # Menu métier
Value Char LANGD              : # Langue
Variable Clbfile CLBNAV()     : # Résultat

If clalev([F:APR])=0 : Local File APROCESSUS [APR] : Endif
If clalev([F:APO])=0 : Local File APROMEN    [APO] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
If clalev([F:A_US])=0 : Local File AUTILIS [A_US] : Endif

Local Integer ALLAC,MENCOU,DEBMENCOU
Local Char LANGDE(GLONLAN) : LANGDE=LANGD
If LANGDE="" : LANGDE=GLANGUE : Endif
Read [A_US]CODUSR=GUSER
If fstat=0 : ALLAC=[F:A_US]ALLACS : Endif

Local Char LEGISL(10)
Local Integer MONOLEG
If dim(GLEGFIL)>0 : LEGISL = GLEGFIL : Endif
If LEGISL=""
 MONOLEG = 0
 If clalev([F:ACV])>0
  Read [ACV]CODACT="LEG"
  If fstat or [F:ACV]FLACT<>2
   MONOLEG = 1
  Endif
 Endif
 If MONOLEG
  LEGISL = GDOSLEG(1)
 Endif
Endif
Raz CLBNAV
Read [APO]APO1=LEGISL;MENMET
If fstat<>0
 Read [APO]APO1="";MENMET
 If fstat<>0 :  End : Endif
Endif

Local Char SAVGL(GLONLAN) : SAVGL=GLANGUE : GLANGUE=LANGDE

Local Integer I,NIVC
Local Char LIBF(50)

CLBNAV+='<node>'
For I=0 To [F:APO]NBPROC-1
#   70399 -- Filtre sur législation dans le menu     CC - 21/01/2011
  Read [APR]APR1=LEGISL;[F:APO]PROCESSUS(I)
  If fstat<>0
    If LEGISL<>""
      Read [APR]APR1="";[F:APO]PROCESSUS(I)
      If fstat<>0 : Goto SUITMEN : Endif
    Else
      Goto SUITMEN
    Endif
  Endif
  If [F:APR]CODACC<>"" and ALLAC<>2
    Read [ACC]CODACC = GUSER;[F:APR]CODACC
    If fstat<>0 : Goto SUITMEN : Endif
  Endif
  If [F:APR]CODACT<>""      : #    Bug 80834   - CC    19/03/2012
    Read [ACV]CODACT = [F:APR]CODACT
    If fstat or [F:ACV]FLACT<>2 : Goto SUITMEN : Endif
  Endif

  Call LECTEXTRA(LIBF,"APROCESSUS","INTIT1",[F:APO]PROCESSUS(I),"") From ATEXTRA
#  Call TEXTE([F:APR]INTIT,LIBF) From OBJDIV
# Y-a-t il un ou des menus à fermer
  If [F:APO]NIVEAU(I)<NIVC
    CLBNAV+='</node>'
    If NIVC-[F:APO]NIVEAU(I)=3 : CLBNAV+='</node></node>' : Endif
    If NIVC-[F:APO]NIVEAU(I)=2 : CLBNAV+='</node>' : Endif
  Elsif [F:APO]NIVEAU(I)=NIVC and MENCOU=1 and [F:APR]TYPEP=2
   # CLBNAV+='</node>'
    CLBNAV=left$(CLBNAV,DEBMENCOU)
  Endif
  NIVC=[F:APO]NIVEAU(I)
  Case [F:APR]TYPEP
    When 1 : Gosub ADDELT
    When 2 : Gosub ADDNOD
  Endcase
$SUITMEN
Next I
If MENCOU=1 : CLBNAV=left$(CLBNAV,DEBMENCOU)  : Endif
Case NIVC
  When 1 : # If MENCOU=1 : CLBNAV+='</node>  : Endif
  When 2 :  CLBNAV+='</node>'
  When 3 :  CLBNAV+='</node></node>'
Endcase
CLBNAV+='</node>'
GLANGUE=SAVGL
End

$ADDNOD
 DEBMENCOU=len(CLBNAV)
 CLBNAV+='<node label="'+LIBF+'">'
 MENCOU=1
Return

$ADDELT
 CLBNAV+='<element label="'+LIBF+'" data="'+[F:APO]PROCESSUS(I)+'"/>'
 MENCOU=0
Return

# ---------------------------------------------------------#
Subprog AP_PROCESSUS(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA([M]INTIT1(nolign-1),"APROCESSUS","INTIT1",VALEUR,"") From ATEXTRA
End

# ---------------------------------------------------------#
Subprog C_PROCESSUS(VALEUR)
Variable Char    VALEUR()
Local Integer OK
[L]OK = 1
Read [APR]APR1 = [M:APO1]LEG;VALEUR
If fstat
 [L]OK = 0
 If [M:APO1]LEG<>""
  Read [APR]APR1 = "";VALEUR
  If !fstat
   [L]OK = 1
 Endif
Endif
Endif
If ![L]OK
 GMESSAGE = mess(30,7837,1)-[M:APO1]LEG : # Code processus incompatible avec cette législation
 [M:APO1]PROCLEG(nolign-1) = ""
 mkstat = 2 : End
Endif
End

# ---------------------------------------------------------#
Subprog S_PROCESSUS(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEX, CHOI,I
Local Integer MAXAPR : MAXAPR=nbrecord([APR]) :#119049
Local Char    TEX(GLONDES)(1..MAXAPR,1..3) , TIT(GLONDES)(0..3)

# X3-60879 03.10.2018
# Process without legislation should not appear in selection when one with legislation is available
For [APR] Where CODLEG=[M:APO1]LEG
 Gosub APPEND_PROC
Next

If [M:APO1]LEG <> ""
  For [APR] Where CODLEG = ""
    If !find([APR]CODPRO, TEX) Then Gosub APPEND_PROC: Endif
  Next
Endif

CHOI = 0
TIT(0)=mess(8,31,1) # Sélection
TIT(1)=func AMK_TOOL.GET_FIELD_LABEL("APR0", "CODPRO") # Code
TIT(2)=func AMK_TOOL.GET_FIELD_LABEL("APR0", "INTIT1") # Libellé
TIT(3)=func AMK_TOOL.GET_FIELD_LABEL("APR0", "CODLEG") # Retour

Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR = TEX(CHOI,1)
 [M:APO1]PROCLEG(nolign-1) = TEX(CHOI,3)
Endif

End

$APPEND_PROC
  NBTEX+= 1
  TEX(NBTEX,1) = [F:APR]CODPRO
  Call LECTEXTRA(TEX(NBTEX,2),"APROCESSUS","INTIT1",[APR]CODPRO,"") From ATEXTRA
  TEX(NBTEX,3) = [APR]CODLEG
Return

######################################################################################
$LIENS
  # X3-60879 03.10.2018
  Local Integer I
  For I = 0 To [M:APO1]NBPROC - 1
    Look [F:APR]APR1 = [M:APO1]LEG;[M:APO1]PROCESSUS(I)
    If !fstat
      [M:APO1]PROCLEG(I) = [M:APO1]LEG
    Else
      [M:APO1]PROCLEG(I) = ""
    Endif
  Next I
Return

