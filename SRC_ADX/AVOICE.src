#<AdxTL>@(#)6.0.0.0 $Revision$
Local Clbfile CLB(2)
Global Integer GVOICETEST
CLB ="1 ceci est un test envoi de message vocal  sur 50"
CLB+="2 ceci est un test envoi de message vocal  sur 50"
CLB+="3 ceci est un test envoi de message vocal  sur 50"
CLB+="4 ceci est un test envoi de message vocal  sur 50"
CLB+="5 ceci est un test envoi de message vocal  sur 50"
CLB+="6 ceci est un test envoi de message vocal  sur 50"
CLB+="7 ceci est un test envoi de message vocal  sur 50"
CLB+="8 ceci est un test envoi de message vocal  sur 50"
CLB+="9 ceci est un test envoi de message vocal  sur 50"
CLB+="0 ceci est un test envoi de message vocal  sur 50"
CLB+="1 ceci est un test envoi de message vocal  sur 50"
CLB+="2 ceci est un test envoi de message vocal  sur 50"
CLB+="3 ceci est un test envoi de message vocal  sur 50"
CLB+="4 ceci est un test envoi de message vocal  sur 50"
CLB+="5 ceci est un test envoi de message vocal  sur 50"
CLB+="6 ceci est un test envoi de message vocal  sur 50"
CLB+="7 ceci est un test envoi de message vocal  sur 50"
CLB+="8 ceci est un test envoi de message vocal  sur 50"
CLB+="9 ceci est un test envoi de message vocal  sur 50"
CLB+="0 ceci est un test envoi de message vocal  sur 50"
Call VOICE(CLB,1)

End

# --------------------------------------------------------------------------------------
Subprog VOICE(TEXT,TYPSEND)
Value Clbfile TEXT
Value Integer TYPSEND

#  Interface d'envoi de message vocal
#  Le message est décomposé en n chaines de 200 caractères
#  Le message n'est envoyé que si on est en connection de type VT
#  Si TYPSEND=0 on envoie le message (éventuellement décomposé) tel quel
#            =n on envoie avec les caractères de contrôle prévus à cet effet (il n'y en a pas actuellement)

If adxtyp<>13 and dim(GVOICETEST)<0 : End : Endif
Local Integer LTE,NBLTE,LTLAST,LT
Local Char DEBSEND(20),FINSEND(20),MESSEND(250)

LTE=len(TEXT)
NBLTE=1+(LTE-1)/200
#  On vérifie que la séquence de controle de fin de vocal n'est pas tronquée (on prend 20 caractères)
If NBLTE>1 and TYPSEND=0
  LTLAST=LTE-200*(NBLTE-1)
  If LTLAST<20 : NBLTE-=1 : Endif
Endif
Case TYPSEND
  When 1 : #DEBSEND="deb1" : #FINSEND="fin1"
  When Default :
Endcase
For I=1 To NBLTE
  LT=200
  If I=NBLTE : LT=LTE-(I-1)*200 : Endif
  MESSEND=mid$(TEXT,1+(I-1)*200,LT)
  If I=1     : MESSEND=DEBSEND+MESSEND : Endif
  If I=NBLTE : MESSEND=MESSEND+FINSEND : Endif
  Infbox("$$VOICOPE"+MESSEND)
Next I
End
