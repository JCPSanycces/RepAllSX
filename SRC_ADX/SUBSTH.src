## Etiquette écran
######################################################################################

Subprog AS_OPT(VALEUR)
Variable Integer VALEUR
Local    Integer K
# FQ82073 - MABON 07/12/12 - Champ Sortie contrat SCTRDAT ne peut pas être saisissable, et est invisible si CTRDAT est invisible
Case [M]FLD(nolign-1)
 When "STRDAT", "ENDDAT", "TIM" : VALEUR=1 : mkstat = 2   : End
 When "SCTRDAT"                            :
    GMENLOC(1)=1
    K = find("CTRDAT", [M]FLD(0..[M]NBRFLD-1))
    If K & [M]OPT(K-1)=3 Then GMENLOC(2)=1 : Endif
    End
 When "FCYT","SRVT"                        : GMENLOC(1)=1 : End
 When "ENDTIM", "BRKTIM"                   : mkstat = 2   : End
 When "BPCNUM", "SOHLIG","SOHNUM","INVFLG" : mkstat = 2   : End
 When "ENDDAY"                             : mkstat = 2   : End
 When "NBRDAY", "NBRHOU"                   : GMENLOC(3)=1 : End                        :#105159
Endcase
End

Subprog AM_OPT(VALEUR)
Variable Integer VALEUR
Local Integer K
# FQ82073 - MABON 07/12/12 - Champ Sortie contrat SCTRDAT doit être invisible si CTRDAT est invisible
If [M]FLD(nolign-1)="STRTIM"
 K = find("ENDTIM", [M]FLD(0..[M]NBRFLD-1))
 If K :[M]OPT(K-1)=VALEUR : Affzo [M]OPT(K-1) : Endif
 K = find("BRKTIM", [M]FLD(0..[M]NBRFLD-1))
 If K :[M]OPT(K-1)=VALEUR : Affzo [M]OPT(K-1) : Endif
Elsif  [M]FLD(nolign-1)="CPY"
 K = find("BPCNUM", [M]FLD(0..[M]NBRFLD-1))
 If K :[M]OPT(K-1)=VALEUR : Affzo [M]OPT(K-1) : Endif
 K=find("SOHNUM", [M]FLD(0..[M]NBRFLD-1))
 If K :[M]OPT(K-1)=VALEUR : Affzo [M]OPT(K-1) : Endif
 K = find("SOHLIG", [M]FLD(0..[M]NBRFLD-1))
 If K :[M]OPT(K-1)=VALEUR : Affzo [M]OPT(K-1) : Endif
 K = find("INVFLG", [M]FLD(0..[M]NBRFLD-1))
 If K :[M]OPT(K-1)=VALEUR : Affzo [M]OPT(K-1) : Endif
Elsif [M]FLD(nolign-1)="CTRDAT"
 K = find("SCTRDAT", [M]FLD(0..[M]NBRFLD-1))
 If K & VALEUR=3 :[M]OPT(K-1)=VALEUR : Affzo [M]OPT(K-1) : Endif
Endif
End

Subprog AS_OBG(VALEUR)
Variable Integer VALEUR
If [M]OPT(nolign-1)<>1 : VALEUR=1 : mkstat=2 : End : Endif
Case [M]FLD(nolign-1)
 When "STRDAT", "ENDDAT", "TIM", "STRDAT", "STRTIM", "ENDTIM","CTRDAT"
  VALEUR=2 : mkstat=2 : End
 When "BRKTIM"
  VALEUR=1 : mkstat=2 : End
Endcase
End

Subprog AM_OBG(VALEUR)
Variable Integer VALEUR
Local    Integer I, K
Local    Char    ZON(10)
Case [M]FLD(nolign-1)
 When "CPY"
  If VALEUR=1
   For ZON="BPCNUM","SOHNUM","SOHLIG"
    K = find(ZON, [M]FLD(0..[M]NBRFLD-1))
    If K & [M]OBG(K-1) = 2
     [M]OBG(K-1) = 1
     Affzo [M]OBG(K-1)
    Endif
   Next
  Endif
 When "BPCNUM"
  If VALEUR=1
   For ZON="SOHNUM","SOHLIG"
    K = find(ZON, [M]FLD(0..[M]NBRFLD-1))
    If K & [M]OBG(K-1) = 2
     [M]OBG(K-1) = 1
     Affzo [M]OBG(K-1)
    Endif
   Next
  Endif
 When "SOHNUM"
  If VALEUR = 2
   For ZON="BPCNUM","CPY"
    K = find(ZON, [M]FLD(0..[M]NBRFLD-1))
    If K
     [M]OBG(K-1) = 2
     Affzo [M]OBG(K-1)
    Endif
   Next
  Else
   K = find("SOHLIG", [M]FLD(0..[M]NBRFLD-1))
   If K & [M]OBG(K-1) = 2
    [M]OBG(K-1) = 1
    Affzo [M]OBG(K-1)
   Endif
  Endif
 When "SOHLIG"
  If VALEUR = 2
   For ZON="SOHNUM","BPCNUM","CPY"
    K = find(ZON, [M]FLD(0..[M]NBRFLD-1))
    If K
     [M]OBG(K-1) = 2
     Affzo [M]OBG(K-1)
    Endif
   Next
  Endif
  ##**92876
  ##**When "DSP"
  ##** If VALEUR=1 : End : Endif
  ##** For I=1 To GOPTCANA
  ##**  K = find("CCE"+num$(I), [M]FLD(0..[M]NBRFLD-1))
  ##**  If K
  ##**   [M]OBG(K-1) = 1
  ##**   Affzo [M]OBG(K-1)
  ##**  Endif
  ##** Next
  ##**When "CCE1","CCE2","CCE3","CCE4","CCE5","CCE6","CCE7","CCE8","CCE9"
  ##**If VALEUR=1 : End : Endif
  ##**K = find("DSP", [M]FLD(0..[M]NBRFLD-1))
  ##**If K
  ##** [M]OBG(K-1) = 1
  ##**  Affzo [M]OBG(K-1)
  ##**Endif
Endcase
End

Subprog C_REGFLG(VALEUR)
Variable Integer VALEUR
If GREP="C" | [M]REGFLG<>VALEUR : [M]REGFLG=VALEUR : Gosub CHARGE_CHAMP : Endif
End


##**92876
Subprog C_CODCDT(VALEUR)
Variable Char    VALEUR()
If [F:CDT]NBRDIE>9 :
 Local Integer OK : OK=2
 #ADNGO - 2016-12-15 - X3-11636- START
 #Call AVERTIR (mess(206,709,1)-mess(207,709,1), OK) From GESECRAN
 Call AVERTIR (mess(206,10709,1)-mess(207,10709,1), OK) From GESECRAN
 #ADNGO - 2016-12-15 - X3-11636- END
 If OK=1 : mkstat = 2 : End : Endif
Endif
End

