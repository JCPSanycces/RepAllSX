#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("STH",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "RAZCRE"    : Gosub RAZCRE
 When "SETBOUT"   : Gosub SETBOUT
 When "EXEBOUT"   : Gosub EXEBOUT
 When "LIENS"     : Gosub LIENS
 When "FERME"     : Gosub FERME
 When "INIMOD"    : Gosub INIMOD
 When "INICRE"    : Gosub INICRE
 When "FILTRE"    : Gosub FILTRE
 When "ANNULE"    : Gosub ANNULE
Endcase
Return

$OUVRE
If clalev([F:AMZ])=0 : Local File AMSKZON  [AMZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE    [ATY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
Local Char    LIBEL(30) , MASKREF(GLONAMK), VFORMAT(30), CODAFF(1)
Local Integer ER , FLGVAL        :#102314 : Add FLGVAL
Local Char    OPTFMT(20) , OPTSAI(20) , CARFMT(10)

#ADNGO - 2016-12-15 - X3-11636- START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#ADNGO - 2016-12-15 - X3-11636- END

Return

$SETBOUT
If !CLECUR | REP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET
Endif
# Transaction de régularisation ou transaction inactive
If [M]REGFLG=2 | [M]ENAFLG<>2
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
Return

#102314 : Assign FLGVAL
$EXEBOUT
Case BOUT
 When "V" :  [L]FLGVAL=1 : Gosub UPDCCE : Call GENECR(nomap,[F:STH]COD) From SUBSTH2    ##**92876
Endcase
Return

$RAZCRE
[M]ENAFLG=2
[M]REGFLG=1
Return

$MASKREF
If [M]REGFLG=2
 MASKREF="TPSSTDR"
Else
 MASKREF="TPSSTD"
Endif
Return

$CHARGE_CHAMP
Local Char    LIBEL(30) , MASKREF(GLONAMK), VFORMAT(30)
Local Integer ER
Gosub MASKREF
Effzo [M]20
Read [F:AMZ]CODE = MASKREF;"NBRLIG"
If fstat=0 : J=[F:AMZ]NUMBLOC : Else J=0 : Endif
##**92876 : On ne charge plus les zones CCE* dans le tableau des champs
##**For [F:AMZ]CODZON Where CODMSK=MASKREF
For [F:AMZ]CODZON Where CODMSK=MASKREF & left$(CODZON,3)<>'CCE'
 OK = 1
 If [F:AMZ]CODTYP="ABS" | [F:AMZ]SAIAFF=3 | (J & [F:AMZ]NUMBLOC<>J)
  OK = 0
 Endif
 If [F:AMZ]CODACT<>""
  Read [F:ACV]CODACT = [F:AMZ]CODACT
  If fstat | [F:ACV]FLACT<>2 : OK = 0 : Endif
 Endif
 If OK & !find([F:AMZ]CODZON,[M]FLD(0..[M]NBRFLD-1))
  NOL = [M]NBRFLD
  [M]FLD(NOL) = [F:AMZ]CODZON
  If [F:AMZ]INTEVAL<>""
    Onerrgo ERRLIB
    ER = 0
    [M]TIT(NOL) = evalue([F:AMZ]INTEVAL)
    If ER
     [M]TIT(NOL) = [F:AMZ]INTEVAL
    Endif
    Onerrgo
   Else
    Call TEXTE([F:AMZ]INTIT,LIBEL) From OBJDIV
    [M]TIT(NOL) = LIBEL
   Endif
   #3 premiers champs saisie obligatoire
   If NOL<3 : [M]OPT(NOL)=1 : [M]OBG(NOL)=2 :  Endif
   # FQ82073 - MABON 07/12/12 - Ajout champs Entrée/sortie contrat, et Site/Service, par défaut Invisibles
   If find([M]FLD(NOL),"CTRDAT","SCTRDAT","FCYT","SRVT")>0 Then [M]OPT(NOL)=3 : Endif
   # Fin MABON
  [M]NBRFLD += 1
 Endif
Next
Affzo [M]
Return

$ERRLIB
ER = errn
Resume

$LIENS
#ADNGO - 2016-12-15 - X3-11636- START
If dim([M:STH1]LEG)>0 : GCURLEG=[M:STH1]LEG : Endif
#ADNGO - 2016-12-15 - X3-11636- END
nolign=1
##**92876 : On ne charge plus les zones CCE* dans le tableau des champs
##**For [F:STD]STD0 Where COD=[F:STH]COD
For [F:STD]STD0 Where COD=[F:STH]COD & left$(FLD,3)<>'CCE'
 [M]=[F:STD]
 nolign+=1
Next
[M]NBRFLD=nolign-1
Return
#ADNGO - 2016-12-15 - X3-11636- START
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
#ADNGO - 2016-12-15 - X3-11636- END
$INIMOD
$INICRE

#102314 : Remove all
#Delete [F:STD] Where COD=[F:STH]COD & left$([F:STD]FLD,3)<>'CCE'
Delete [F:STD] Where COD=[F:STH]COD
If fstat=1
 GOK =-1 : GLOCK = "$SCRTPSD" : Return
Endif

For nolign=1 To [M]NBRFLD
 Raz [F:STD]
 [F:STD]=[M]
 [F:STD]LIG=nolign
 [F:STD]SOH=1
 Gosub FORMAT
 Write [F:STD]
 If fstat<>0
  GOK = 0 : Call FSTA("STD") From GLOCK : Break
 Endif
Next

#102314 : Assign FLGVAL
[L]FLGVAL=0

Gosub UPDCCE    ##**92876
Return

#Mise à jour des zones CCE* définies hors du tableau des champs
$UPDCCE

#102314 : Manage a new flag FLGVAL
If [L]FLGVAL
 Delete [F:STD] Where COD=[F:STH]COD & left$([F:STD]FLD,3)='CCE'
 If fstat=1
  GOK =-1 : GLOCK = "$SCRTPSD" : Return
 Endif
Endif

Local Integer NOL, I, J
NOL=[M]NBRFLD+1
I=1
Read[F:CDT]CDT0=[M]CODCDT
If !fstat
 For I=1 To [F:CDT]NBRDIE    :# max 3 AXES
  Raz [F:STD]
  [F:STD]COD=[M]COD
  [F:STD]LIG=NOL
  [F:STD]FLD="CCE"+num$(I)
  [F:STD]OPT=[F:CDT]OPT(I-1)
  [F:STD]OBG=[F:CDT]OBG(I-1)
  Call LECTEXTRA([F:STD]TIT,"GDIE","COLHEA",[F:CDT]DIE(I-1),"") From ATEXTRA
  [F:STD]SOH=[F:CDT]SOH (I-1)
  Call INICCEFMT([F:CDT]DIE(I-1)) From SETGLBDIE
  Gosub FORMAT
  Write [F:STD]
  If fstat<>0
   GOK = 0 : Call FSTA("STD") From GLOCK : Break
  Endif
  NOL+=1
 Next
Endif
Return

$FORMAT
VFORMAT=""
If [F:STD]OPT=2
 CODAFF = "P"
Else
 CODAFF = ""
Endif
Gosub MASKREF
Read [F:AMZ]CODE = MASKREF;[F:STD]FLD
If fstat : Return : Endif
Read [F:ATY]CODTYP=[F:AMZ]CODTYP
If fstat : Return : Endif
Case [F:ATY]TYPTYP
When 1 : VFORMAT="LA"+CODAFF+num$([F:AMZ]NOLIB)+":"+num$([F:AMZ]LONG)
When 2,3,4,5,6 : VFORMAT="N"+CODAFF+[F:ATY]OPTION+":"
  If [F:ATY]FORTYP<>""
   If left$([F:ATY]FORTYP,1)="="
    VFORMAT+=evalue(seg$([F:ATY]FORTYP,2,len([F:ATY]FORTYP)))
   Else
    VFORMAT+=[F:ATY]FORTYP
   Endif
  Else
   If [F:AMZ]LONG<>0 : VFORMAT+=num$([F:AMZ]LONG)+"#": Else : VFORMAT+=num$([F:ATY]LNGTYP)+"#" :  Endif
  Endif
When 7
  If [F:ATY]FORTYP<>""
   If left$([F:ATY]FORTYP,1)="="
    VFORMAT="K"+CODAFF+":"
    VFORMAT+=evalue(seg$([F:ATY]FORTYP,2,len([F:ATY]FORTYP)))
   Else
    OPTSAI = [F:ATY]OPTION
    Raz OPTFMT, CARFMT
    Gosub OPTCAR From SUBFMT
    VFORMAT="K"+CODAFF+OPTFMT+":"+[F:ATY]FORTYP
   Endif
  Else
   OPTSAI = [F:ATY]OPTION
   Raz OPTFMT, CARFMT
   Gosub OPTCAR From SUBFMT
   If [F:AMZ]LONG<>0
    VFORMAT = "K"+CODAFF+OPTFMT+":"+num$([F:AMZ]LONG)+CARFMT
   Else
    VFORMAT = "K"+CODAFF+OPTFMT+":"+num$([F:ATY]LNGTYP)+CARFMT
   Endif
  Endif
When 8 :VFORMAT="D"+CODAFF+[F:ATY]OPTION+":"
  If [F:ATY]FORTYP<>""
   If left$([F:ATY]FORTYP,1)="="
    VFORMAT+=evalue(seg$([F:ATY]FORTYP,2,len([F:ATY]FORTYP)))
   Else
    VFORMAT+=[F:ATY]FORTYP
   Endif
  Else
   VFORMAT+=GFMDAT4
  Endif
Endcase
If [F:STD]OPT<3 :#saisie ou affiché
 [F:STD]FRMFLD=VFORMAT
Else
 [F:STD]FRMFLD="-"+VFORMAT
Endif
Return

$FILTRE
If GACTION="SELOBJW"
 If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif
 CRITERE = '1=1'
 For [STH]STH0 Where CODACT<>""
  Read [ACV]CODACT=[F:STH]CODACT
  If fstat | [F:ACV]FLACT<>2
   CRITERE -= ' & CODACT<>"'+[F:STH]CODACT+'"'
  Endif
 Next
Endif
Return

$ANNULE
# Annulation de l'écran, de la fenêtre et des traitements associés
Local Char MASQUE(10)
Local Char NOMWIN(10)
MASQUE = "WMJOU"+[M:STH1]COD
Call DELMSK(MASQUE,nomap) From MSKDIV
If GOK<1 : Return : Endif
NOMWIN = "WFJOU"+[M:STH1]COD
Call DELWIN(NOMWIN,nomap) From MSKDIV
If GOK<1 : Return : Endif
Return


########################################
$TRTCOP
If [M]DOSORG=nomap
 Local File SCRTPSH [STH1]
 Local File SCRTPSD [STD1]
Else
 Local File =[M]DOSORG+".SCRTPSH" [STH1]
 Local File =[M]DOSORG+".SCRTPSD" [STD1]
Endif
If [M]DOSDES=nomap
 Local File SCRTPSH [STH2]
 Local File SCRTPSD [STD2]
Else
 Local File =[M]DOSDES+".SCRTPSH" [STH2]
 Local File =[M]DOSDES+".SCRTPSD" [STD2]
Endif

# Vérifie que le contenu de la table SCRTPSD coincide avec GOPTCANA du dossier + libellé de CCE du dossier
# car quand on génère un dossier on prend les données du dossier de référence (PAYREFFRA)
If [M]DOSDES=nomap
 If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
Else
 If clalev([F:ACV])=0 : Local File =[M]DOSDES+".ACTIV" [ACV] : Endif
Endif
Local Integer NBA
Read [ACV]CODACT = "ANA"
NBA = max(0,[F:ACV]DIME)

Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [STH1], [STH2],[STD1],[STD2]
Return


##**92876 : Doit-on copier CADIETPS aussi ?
## Réponse CGROS 05/06/14 : Dans une 1ière version on ne copie pas les infos sur les sections
## Donc on vide le champ CODCDT et on ne recopie pas le contenue de CADIETPS
$TR_COP
GOK = 1
Trbegin [STH2],[STD2]
 Delete [STH2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".SCRTPSH" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("STH2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [STD2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".SCRTPSD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("STHD","") From GLOCK : Goto AB_TR_COP
 Endif
 #Entete
 Read[STH1]STH0=TABLE
 If !fstat
  [F:STH2] = [F:STH1]

  ##**92876
  Raz [F:STH2]CODCDT

  Write [STH2]
  If fstat
   GOK = 0 : Call FSTA("STH2") From GLOCK : Return
  Endif
  #Lignes
  For [STD1]STD0 Where COD=[F:STH1]COD
   ##**92876 : Mise en cmt en attendant...
   ##**If left$([F:STD1]FLD,3)<>"CCE" | (left$([F:STD1]FLD,3)="CCE" & val(right$([F:STD1]FLD,4))<=NBA)
   If left$([F:STD1]FLD,3)<>"CCE"
    [STD2]=[STD1]
    ##**If left$([F:STD1]FLD,3)="CCE" & val(right$([F:STD1]FLD,4))<=NBA
    ##** [F:STD2]TIT = mess(val(right$([F:STD1]FLD,4)),601,1)
    ##**Endif
    Write [STD2]
    If fstat
     GOK = 0 : Call FSTA("STD2") From GLOCK : Break
    Endif
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

########################################

Subprog GENDOS(APPLI)
Value Char APPLI()
If clalev([F:STH])=0  : Local File =APPLI+".SCRTPSH"    [STH]  : Endif
If clalev([F:STD])=0  : Local File =APPLI+".SCRTPSD"    [STD]  : Endif

# Vérifie que le contenu de la table SCRTPSD coincide avec GOPTCANA du dossier + libellé de CCE du dossier
# car quand on génère un dossier on prend les données du dossier de référence (PAYREFFRA)

If clalev([F:ACV])=0  : Local File =APPLI+".ACTIV"      [ACV]  : Endif

Local Integer NBA, IAXE, SAVAXE, SAVLIG

Read [ACV]CODACT = "ANA"
NBA = max(0,[F:ACV]DIME)

Call DEBTRANS From GLOCK
Gosub TR1
If GOK=0 : End : Endif

For [STH]STH0 Where REGFLG<>2 & ENAFLG=2
 If GTRACE<>"" : Call ECR_TRACE([F:STH]COD,0) From GESECRAN : Endif
 Call GENECR(APPLI,[F:STH]COD) From SUBSTH2
 #If GOK=0 : Break : Endif
 If GOK=0 & GTRACE<>""
  # Ecran non généré pour la transaction YYY
  Call ECR_TRACE (mess(90,117,1)-[F:STH]COD,-1) From GESECRAN
 Endif
Next
End

$TR1
GOK = 1
##**92876
##**SAVAXE=0 : SAVLIG=0
##**Trbegin [STD]
##**For [STH]STH0 Where ENAFLG=2
 #On supprime les sections de trop
 ##**Delete [STD] Where COD=[F:STH]COD & left$(FLD,3)="CCE" & val(right$(FLD,4))>NBA
 ##**If fstat=1 : GOK=0 : Goto AB_TR1 : Endif
 ##**For [STD] Where COD=[F:STH]COD & left$(FLD,3)="CCE"
 ##** Readlock [STD] Curr
 ##** If !fstat
 ##**  [F:STD]TIT = mess(val(right$([F:STD]FLD,4)),601,1)
 ##**  Rewrite [STD]
 ##**  If fstat : Call FSTA("STD") From GLOCK : GOK=0 : Break 2 : Endif
 ##** Endif
 ##** SAVAXE=val(right$([F:STD]FLD,4))
 ##** SAVLIG=[F:STD]LIG
 ##**Next
 #On ajoute celles qui manquent
 ##**If SAVAXE<NBA
 ##**  For IAXE=SAVAXE+1 To NBA
 ##**   SAVLIG+=1
 ##**   Raz [F:STD]
 ##**   [F:STD]COD=[F:STH]COD
 ##**   [F:STD]LIG=SAVLIG
 ##**   [F:STD]FLD="CCE"+num$(IAXE)
 ##**   [F:STD]OPT=3
 ##**   [F:STD]OBG=1
 ##**   [F:STD]TIT = mess(IAXE,601,1)
 ##**   [F:STD]FRMFLD = "-K:10c"
 ##**   Write [STD]
 ##**   If fstat : Call FSTA("STD") From GLOCK : GOK=0 : Break 2 : Endif
 ##**  Next
 ##** Endif
 ##**SAVAXE=0 : SAVLIG=0
 ##**Next
 ##**If GOK=0 : Goto AB_TR1 : Endif
 ##**Commit
Return

$AB_TR1
Rollback
Return

