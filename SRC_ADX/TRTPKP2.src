#<AdxTL>@(#)0.0.0.0 $Revision$

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "INIT"        : Gosub INIT
  When "TITRE"       : Gosub TIT_TRT
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "ABA"         : Gosub ABA
 When "ENR"         : Gosub ENR
 When "END"         : Gosub FINEND
 When "FIN"         : Gosub FIN
 When "FINSAI"      : Gosub FINSAI
Endcase
Return
#########################################################################
$INIT
# gouvpac = 1 automatique
# gouvpac = 2 clic droit
#si variable globale GOUVPAC <= 1 on sort
If GOUVPAC < 1
  FIN = 1
  Return
Endif

#recuperation ecran généré de la saisie des regroupements colisage
Local Char        LBOI(GLONFEN) : LBOI  =     "WOPKP2"+GPKPNUM


BCRIT = ""

# ouverture de l ecran géneré
If LBOI = ""
   LBOI = "IPKP2"
Endif

BOITE = LBOI

Return
#########################################################################
$TIT_TRT
    Call LECTEXTRA(TIT,"STKTRS","DESAXX","11",GPKPNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-GPKPNUM-":"-TIT
Return


#########################################################################
$OUVRE_BOITE
#########################################################################
#recuperation numero de ligne
Global Integer   GLIG_PKP1 : GLIG_PKP1 =   val(PARAM(1))
Global Char      GORI_PKP  : GORI_PKP  =  "PKP2"

If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif
If clalev([F:ITM])=0 Local File ITMMASTER  [ITM]  Endif
If clalev([F:STJ])=0 Local File STOJOU     [STJ]  Endif
If clalev([F:STO])=0 Local File STOCK      [STO]  Endif
If clalev([F:STA])=0 Local File STOALL     [STA]  Endif
If clalev([F:SPD])=0 Local File SPACKD     [SPD]  Endif
If clalev([F:SPH])=0 Local File SPACK      [SPH]  Endif


# ouverture et lecture du dictionnaire des fenetres pour recuperer l ecran generé
If clalev([F:AWI])=0 Local File AWINDOW [AWI] : Endif
Local Char WNOMMSK(GLONAMK)
Read [AWI] AWI0=BOITE
If fstat
   WNOMMSK="PKP2"
Else
   WNOMMSK=[F:AWI]NOMMSK(0)
Endif

Gosub CHANGE_AWI From STKINV


If [F:ITM]ITMREF <> [M:PKP1]ITMREF(GLIG_PKP1)
   Read [F:ITM]ITM0=[M:PKP1]ITMREF(GLIG_PKP1)
   If fstat
      Raz [F:ITM]
   Endif
Endif
If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>[M:PKP1]STOFCY
   Read [ITF]ITF0=[F:ITM]ITMREF;[M:PKP1]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

#desactivation des rubriques ecrans suivant le contexte
Gosub FORMAT_PAC_PKP2


Global Integer GMOD_PAC
GMOD_PAC = 1
If clalev([PKP2])    :    Close Mask   [PKP2] : Endif     # hcb 76706
If clalev([M:PKP2])  = 0  Local Mask = WNOMMSK   [PKP2] Endif

Raz [M:PKP2]

Return

#########################################################################
$DEBUT

Gosub CHARGE_PKP2
# pour desactiver ENREGISTRER et ABANDON
REP = ""

Return

#########################################################################
$SETBOUT
Local Integer WI
WI = find(2,[M:PKP2]MODFLG(0..[M:PKP2]NBLIG-1))
Call VIREBOUT(CHBOU,"EA") From GOBJET
# si des modif ont ete faites boutons enregistrer et abandon
If WI >  0 & GCONSULT <> 2
   CHBOU+="E"
   CHBOU+="A"
Endif

Return

#########################################################################
$APRES_MODIF

# pour activer ENREGISTRER et ABANDON
REP = "M"
Return

#########################################################################
$AVANT_ENR
Return

#########################################################################
$ENR
Local Integer  WRET
Local Integer  WPACSEQ
Local Char     WPACNUM
Local Char     WSCCCOD
Local Char     WLBLFMT
Local Char     WSPHTEX(20)
Local Integer  LRET
Local Integer  WSTAT
Local Integer  WI                                                 # hcb 110327-pck
Raz WLBLFMT
Raz WSPHTEX
Raz WPACNUM
Raz WSCCCOD
Raz WPACSEQ

# 101090 - Verify changes if BOL attached to shipment
Local Integer OK : OK = 2
Call VERIF_BOLMOD(OK) From SUBSDHB
If OK<>2 : FOK=0 : Return : Endif

If [M]PECQTY <> 0
#   If GOUVPAC = 1
#---------------------------#
# Si quantité saisie différente de celle dans le document
#---------------------------#
#                                                                                                  # hcb 110327-pck deb
      For WI=0 To [M:PKP2]NBLIG-1
         If [M:PKP2]SERMGTCOD =  4  & [M:PKP2]PCKSERFLG = 2 &
&           [M:PKP2]QTYSTU   (WI) <> 0  & [M:PKP2]SERNUM   (WI) = ""
            GERR=1   : GMESSAGE=mess(3,40,1)-num$(WI+1)-mess(246,199,1)
            GOK=0    : Break
         Endif
      Next
      If GOK = 0
         Return
      Endif
#                                                                                                  # hcb 110327-pck end
      If [M]PECQTY <> [M]QTYSTU1
# si qte <> et details à renseigné alors message bloquant
#        If [M:PKP1]IDETAIL(GLIG_PKP1) = 2                                                         # hcb 110327-pck
#            Call MESSAGE (mess(283,184,1)) From GESECRAN                                          # hcb 110327-pck
#            Return                                                                                # hcb 110327-pck
#         Else                                                                                     # hcb 110327-pck
            Call OUINON(mess(283,184,1)-mess(36,100,1),WRET) From GESECRAN
#  la quantitée traitée est incorrecte ! comfirmation ?
            If WRET<>2
               FOK = 0
               Return
            Endif
#         Endif                                                                                    # hcb 110327-pck
      Endif
#   Endif
Endif

Call DEBTRANS From GLOCK
GOK = 1
Trbegin [SPH]

If [M:PKP2]GROWEI = 0 & [M:PKP2]PCK  <> ""
   Gosub CAL_NETWEI From TRTPKP2
Endif

Local Decimal WNETWEI
WNETWEI    = sigma(0,[M:PKP2]NBLIG-1,[M:PKP2]NETWEI(indcum)*([M:PKP2]QTY(indcum) <> 0))
[M:PKP1]NETWEI  (GLIG_PKP1)       = WNETWEI
WNETWEI    = sigma(0,[M:PKP2]NBLIG-1,[M:PKP2]NETWEIPCK(indcum)*([M:PKP2]QTY(indcum) <> 0))
[M:PKP1]NETWEIPCK  (GLIG_PKP1)       = WNETWEI
[M:PKP1]GROWEI     (GLIG_PKP1)       = [M:PKP2]GROWEI
[M:PKP1]WEU        (GLIG_PKP1)       = [M:PKP2]WEU
# dbgaff
Gosub ECRCOL_PKP2 From FUNPKP
If GOK = 1
   If WPACSEQ <> 0
      Call ENTETE_COLIS([M:PKP1]STOFCY,GVCRTYP,[M:PKP1]VCRNUM,[F:SPD]PACNUM,WPACSEQ,WLBLFMT,WSPHTEX,WSCCCOD,LRET)From FUNPKP
      If GOK = 0 | LRET <> 0
         GOK = 0
      Endif
   Endif
Endif
If GOK = 1
   Gosub MAJDOC_ORIGINE From FUNPKP
Endif
If GOK <> 1
   Gosub ABORT
Else
   Commit
   GMOD_PAC                            = 2
   [M:PKP1]PACQTYSTU (GLIG_PKP1)       = [M:PKP2]PECQTY
   [M:PKP1]PACNUM    (GLIG_PKP1)       = WPACNUM
   [M:PKP1]SCCCOD    (GLIG_PKP1)       = WSCCCOD
   [M:PKP1]LBLFMT    (GLIG_PKP1)       = [M:PKP2]LBLFMT
   [M:PKP1]PACSEQ    (GLIG_PKP1)       = [M:PKP2]PACSEQ
   [M:PKP1]LBLFMT    (GLIG_PKP1)       = [M:PKP2]LBLFMT
   [M:PKP1]PCK       (GLIG_PKP1)       = [M:PKP2]PCK
   [M:PKP1]PCKLEN    (GLIG_PKP1)       = [M:PKP2]PCKLEN
   [M:PKP1]DIU       (GLIG_PKP1)       = [M:PKP2]DIU
   [M:PKP1]VOL       (GLIG_PKP1)       = [M:PKP2]VOL
   [M:PKP1]VOU       (GLIG_PKP1)       = [M:PKP2]VOU
   [M:PKP1]PCKWID    (GLIG_PKP1)       = [M:PKP2]PCKWID
   [M:PKP1]PCKWEI    (GLIG_PKP1)       = [M:PKP2]PCKWEI
   [M:PKP1]WEU       (GLIG_PKP1)       = [M:PKP2]WEU
   [M:PKP1]PCKHEI    (GLIG_PKP1)       = [M:PKP2]PCKHEI
   [M:PKP1]GROWEI    (GLIG_PKP1)       = [M:PKP2]GROWEI
Endif

Gosub DEBUT
Return

#########################################################################
$ABA

Gosub DEBUT

Return

#########################################################################
$FINEND

# GPACSEQ_PKP1 et GPACNUM_PKP1 sont initialisés dans B1_NBLIG de FUNPKP
If dim(GMOD_PAC) > 0
   If GMOD_PAC <> 2
# il ni y pas eu de modifs il faut rafraichir PKP1 avec les valeurs initiales
      [M:PKP1]PACSEQ(GLIG_PKP1) = GPACSEQ_PKP1
      [M:PKP1]PACNUM(GLIG_PKP1) = GPACNUM_PKP1
      [M:PKP1]SCCCOD(GLIG_PKP1) = GSCCCOD_PKP1
      [M:PKP1]MODFLG(GLIG_PKP1) = 0
      Return
   Endif
Endif
# si des details etaient a renseigner sur la ligne alors pas de recalcul
#If [M:PKP1]IDETAIL (GLIG_PKP1) = 2                                                                # hcb 110327-pck
If find([M:PKP1]IDETAIL(GLIG_PKP1),2,3)                                                            # hcb 110327-pck
   [M:PKP1]IDETAIL (GLIG_PKP1) = 0
   [M:PKP1]MODFLG  (GLIG_PKP1) = 0
   [M:PKP1]PACFLG  (GLIG_PKP1) = 2
   [M:PKP1]PACNBR +=1
   Affzo [M:PKP1]PACNBR
   Affzo [M:PKP1]ITMREF    (GLIG_PKP1)   # affzo pour coloration
   Affzo [M:PKP1]PACQTYSTU (GLIG_PKP1)
   Affzo [M:PKP1]PACNUM    (GLIG_PKP1)
   Affzo [M:PKP1]SCCCOD    (GLIG_PKP1)
   Affzo [M:PKP1]LBLFMT    (GLIG_PKP1)
   Affzo [M:PKP1]PCK       (GLIG_PKP1)
   Affzo [M:PKP1]PACSEQ    (GLIG_PKP1)
   Affzo [M:PKP1]LBLFMT    (GLIG_PKP1)
   Affzo [M:PKP1]PCK       (GLIG_PKP1)
   Affzo [M:PKP1]PCKLEN    (GLIG_PKP1)
   Affzo [M:PKP1]DIU       (GLIG_PKP1)
   Affzo [M:PKP1]VOL       (GLIG_PKP1)
   Affzo [M:PKP1]VOU       (GLIG_PKP1)
   Affzo [M:PKP1]PCKWID    (GLIG_PKP1)
   Affzo [M:PKP1]PCKWEI    (GLIG_PKP1)
   Affzo [M:PKP1]WEU       (GLIG_PKP1)
   Affzo [M:PKP1]PCKHEI    (GLIG_PKP1)
   Affzo [M:PKP1]NETWEI    (GLIG_PKP1)

   Return
Endif

If clalev([M:PKPW])  = 0  Local Mask PKP1W   [PKPW] Endif
Raz [M:PKPW]
Transmask [M:PKP1] To [M:PKPW] # Issue 25606 [M:PKPW] = [M:PKP1]
Gosub CHARGE_PKP1 From FUNPKP

Local Integer WZ
Local Integer WI
Local Integer I
WI = find(2,[M:PKP1]MODFLG(0..[M:PKP1]NBLIG-1))
If WI > 0
   If WI > 0
      For WZ = 0 To [M:PKPW]NBLIG-1
          If [M:PKPW]MODFLG(WZ) = 2
             I =sigma(0,[M:PKP1]NBLIG-1,(indcum+1)*(([M:PKP1]VCRLIN(indcum) = [M:PKPW]VCRLIN(WZ))&
&                                                   ([M:PKP1]QTYSAU(indcum) = [M:PKPW]QTYSAU(WZ)) &
&                                                   ([M:PKP1]SAU(indcum)    = [M:PKPW]SAU(WZ)) &
&                                                   ([M:PKP1]QTY(indcum)    = [M:PKPW]QTY(WZ)) &
&                                                   ([M:PKP1]ITMREF(indcum) = [M:PKPW]ITMREF(WZ))))
             If I <> 0
                I -= 1
                [M:PKP1]QTYSTU   (I)      = [M:PKPW]QTYSTU   (WZ)
                [M:PKP1]PCK      (I)      = [M:PKPW]PCK      (WZ)
#               [M:PKP1]PACSEQ   (I)      = [M:PKPW]PACSEQ   (WZ)    # hcb 116008
                [M:PKP1]LBLFMT   (I)      = [M:PKPW]LBLFMT   (WZ)
                [M:PKP1]PCKWEI   (I)      = [M:PKPW]PCKWEI   (WZ)
                [M:PKP1]NETWEI   (I)      = [M:PKPW]NETWEI   (WZ)
                [M:PKP1]NETWEIPCK(I)      = [M:PKPW]NETWEIPCK(WZ)
                [M:PKP1]WEU      (I)      = [M:PKPW]WEU      (WZ)
                [M:PKP1]LIGWEU   (I)      = [M:PKPW]LIGWEU   (WZ)
                [M:PKP1]PCKLEN   (I)      = [M:PKPW]PCKLEN   (WZ)
                [M:PKP1]PCKWID   (I)      = [M:PKPW]PCKWID   (WZ)
                [M:PKP1]PCKHEI   (I)      = [M:PKPW]PCKHEI   (WZ)
                [M:PKP1]DIU      (I)      = [M:PKPW]DIU      (WZ)
                [M:PKP1]VOL      (I)      = [M:PKPW]VOL      (WZ)
                [M:PKP1]VOU      (I)      = [M:PKPW]VOU      (WZ)
                [M:PKP1]SPHTEX   (I)      = [M:PKPW]SPHTEX   (WZ)
                [M:PKP1]MODFLG   (I)      = 2
             Endif
          Endif
      Next WZ
   Endif
Endif


Raz I
# si sur pkp1 meme pacseq et modflg = 2 il faut repercuter le pacnum
I  = sigma(0,[M:PKP1]NBLIG-1,([M:PKP1]PACSEQ(indcum) = [M:PKP2]PACSEQ & [M:PKP1]MODFLG(indcum) = 2))
If I <> 0
     For I = 0 To [M:PKP1]NBLIG-1
         If [M:PKP1]PACSEQ(I) =  [M:PKP2]PACSEQ & [M:PKP1]MODFLG(I) = 2
            [M:PKP1]PACNUM(I) =  [M:PKP2]PACNUM
            [M:PKP1]SCCCOD(I) =  [M:PKP2]SCCCOD
         Endif
     Next
Endif

Affzo [M:PKP1]
Actzo [M:PKP1]
# la saisie du transporteur  n est effective que si une ligne est modifiée   ??????
Diszo [M:PKP1]BPTNUM
Diszo [M:PKP1]PREUSR

mkstat = 4

Return


$FINSAI
GORI_PKP  =  "PKP1"

If dim(GMOD_PAC) > 0
   Kill GMOD_PAC
Endif
If dim(GLIG_PKP1) > 0
   Kill GLIG_PKP1
Endif

Raz GOUVPAC
Return

$FIN
Return


# Rollback suite à erreur
$ABORT

Rollback

Return


#########################################################################
# CHARGE_PKP2                        Chargement ecran pkp2
#########################################################################
$CHARGE_PKP2
Local Char    WFILSTA(20)
Local Char    AGR_RUPTURE(130)
Local Char    AGR_LECTURE(130)
Local Char    WLOT(GLONLOT)
Local Char    WSLO(GLONSLO)
Local Char    WSER(GLONSER)
Local Char    WPAL(GLONPAL)
Local Char    WCTR(GLONCTR)
Local Integer WI
Local Integer WPRECHARGE
Local Integer I
Local Integer WCOLIAUTO_OK       # hcb 55930 2
Local Char    WCOLIAUTO_ORI      # hcb 55930 2
Local Char    WPCU               # hcb 55930 2
Local Decimal WPCUSTUCOE         # hcb 55930 2
Local Integer LRET                                                                                 # hcb 110327-pck
Local Char    WSERIE(GLONSER)                                                                      # hcb 110327-pck
Local Integer WVCRLIN                                                                              # hcb 110327-pck
Local Char    WSERNUM (GLONSER)                                                                    # hcb 110327-pck
Local Char    WSERNUMF(GLONSER)                                                                    # hcb 110327-pck
Local Char     WCRITSPD(250)                                                                       # hcb 110327-pck
Local Integer  WEXISTE                                                                             # hcb 110327-pck
Raz   WSERIE                                                                                       # hcb 110327-pck
Raz   WSERNUM                                                                                      # hcb 110327-pck
Raz   WSERNUMF                                                                                     # hcb 110327-pck

Raz WPRECHARGE
Raz AGR_RUPTURE
Raz AGR_LECTURE
Raz WLOT
Raz WSLO
Raz WSER
Raz WPAL
Raz WCTR
Raz WFILSTA
WSERIE          = [M:PKP2]WSERIE                                                                   # hcb 110327-pck
WVCRLIN         = [M:PKP2]WVCRLIN                                                                  # hcb 110327-pck
Raz [M:PKP2]
GOK = 1
[M:PKP2]WSERIE  = WSERIE                                                                           # hcb 110327-pck
[M:PKP2]WVCRLIN = WVCRLIN                                                                          # hcb 110327-pck

# prechargement à oui (1) si qte saisie = quantité à colisé ou si origine  = PKP1 (enregistrement)
If [M:PKP1]QTYSTU(GLIG_PKP1) = [M:PKP1]QTYSAUSTU(GLIG_PKP1) | GORI_PKP =  "PKP1"
   WPRECHARGE = 1
Else
   WPRECHARGE = 0
Endif
# prechargement à non (1) si suite a colisage automatique detail =2 ou 3                           # hcb 110327-pck
#If [M:PKP1]IDETAIL(GLIG_PKP1) = 2                                                                 # hcb 110327-pck
If find([M:PKP1]IDETAIL(GLIG_PKP1),2,3)                                                            # hcb 110327-pck
   WPRECHARGE = 0
Endif

#                                                                                                  # hcb 110327-pck deb
If [M:PKP1]IDETAIL(GLIG_PKP1) = 3
   If [M:PKP2]WVCRLIN =  0
      [M:PKP2]WVCRLIN =  [M:PKP1]VCRLIN (GLIG_PKP1)
   Endif
   If [M:PKP2]WVCRLIN <> [M:PKP1]VCRLIN (GLIG_PKP1)
      [M:PKP2]WVCRLIN =  [M:PKP1]VCRLIN (GLIG_PKP1)
      Raz [M:PKP2]WSERIE
   Endif
Endif
#                                                                                                  # hcb 110327-pck fin

[M:PKP2]STOFCY     = [M:PKP1]STOFCY
[M:PKP2]ITMREF     = [M:PKP1]ITMREF    (GLIG_PKP1)
[M:PKP2]ITMDES1    = [M:PKP1]ITMDES1   (GLIG_PKP1)
[M:PKP2]SPHTEX     = [M:PKP1]SPHTEX    (GLIG_PKP1)
If [M:PKP1]QTYSTU  (GLIG_PKP1) = 0
   [M:PKP2]QTYSTU1 = [M:PKP1]QTYSAUSTU (GLIG_PKP1)
Else
   [M:PKP2]QTYSTU1 = [M:PKP1]QTYSTU    (GLIG_PKP1)
Endif
[M:PKP2]STU1       = [M:PKP1]STU       (GLIG_PKP1)
[M:PKP2]PACNUM     = [M:PKP1]PACNUM    (GLIG_PKP1)
[M:PKP2]SCCCOD     = [M:PKP1]SCCCOD    (GLIG_PKP1)
[M:PKP2]PACSEQ     = [M:PKP1]PACSEQ    (GLIG_PKP1)
[M:PKP2]PACSEQH    = [M:PKP1]PACSEQH   (GLIG_PKP1)
[M:PKP2]LBLFMT     = [M:PKP1]LBLFMT    (GLIG_PKP1)
[M:PKP2]PCK        = [M:PKP1]PCK       (GLIG_PKP1)
[M:PKP2]PCKLEN     = [M:PKP1]PCKLEN    (GLIG_PKP1)
[M:PKP2]DIU        = [M:PKP1]DIU       (GLIG_PKP1)
[M:PKP2]VOL        = [M:PKP1]VOL       (GLIG_PKP1)
[M:PKP2]VOU        = [M:PKP1]VOU       (GLIG_PKP1)
[M:PKP2]PCKWID     = [M:PKP1]PCKWID    (GLIG_PKP1)
[M:PKP2]PCKWEI     = [M:PKP1]PCKWEI    (GLIG_PKP1)
[M:PKP2]WEU        = [M:PKP1]WEU       (GLIG_PKP1)
[M:PKP2]PCKHEI     = [M:PKP1]PCKHEI    (GLIG_PKP1)
[M:PKP2]STOMGTCOD  = [M:PKP1]STOMGTCOD (GLIG_PKP1)
[M:PKP2]PCKSTKFLG  = [M:PKP1]PCKSTKFLG (GLIG_PKP1)
[M:PKP2]PCKSERFLG  = [M:PKP1]PCKSERFLG (GLIG_PKP1)                                                 # hcb 110327-pck
[M:PKP2]SERMGTCOD  = [M:PKP1]SERMGTCOD (GLIG_PKP1)                                                 # hcb 110327-pck


[M:PKP2]PCKCAP     = [M:PKP1]PCKCAP    (GLIG_PKP1)    # hcb 55930
I  = sigma(0,[M:PKP1]NBLIG-1,([M:PKP1]PACSEQ(indcum) = [M:PKP1]PACSEQ(GLIG_PKP1) & indcum <> nolign-1 & [M:PKP1]PACSEQ(GLIG_PKP1) <>0))
If I <> 0
   Raz [M:PKP2]MODIF
   I  = sigma(0,[M:PKP1]NBLIG-1,([M:PKP1]PACSEQ(indcum) = [M:PKP1]PACSEQ(GLIG_PKP1) & indcum <>  nolign-1)& [M:PKP1]PACSEQH(indcum) = 1)
   If I <> 0
      I -= 1
     [M:PKP2]GROWEI  =  [M:PKP1]GROWEI (I)
     [M:PKP2]GROWEU  =  [M:PKP2]WEU
   Endif
Else
  [M:PKP2]MODIF = 2
  [M:PKP2]GROWEI  =  [M:PKP1]GROWEI (GLIG_PKP1)
  [M:PKP2]GROWEU  =  [M:PKP2]WEU

Endif

If [F:TPA]PCK <> [M:PKP2]PCK
   Read [TPA]TPA0=[M:PKP2]PCK
   If fstat
      Raz [F:TPA]
   Endif
Endif

Local Integer LLIG
Raz LLIG

Local Shortint  WNBLIG
Raz WNBLIG
WNBLIG = [M:PKP2]NBLIG

# lecture si besoin entete document
If GVCRTYP = 4
   If [F:SDH]SDHNUM  <> [M:PKP1]VCRNUM
      Read [SDH]SDH0 =  [M:PKP1]VCRNUM
   Endif
   # Issue X3-69499 - 2018-06-13 by TS
   If [F:SDD]SDHNUM<>[M:PKP1]VCRNUM | [F:SDD]SDDLIN<>[M:PKP1]VCRLIN(GLIG_PKP1)
      Read [SDD]SDD0 = [M:PKP1]VCRNUM;[M:PKP1]VCRLIN(GLIG_PKP1)
   Endif
   # End issue X3-69499
Else
   If [F:PRH]PRHNUM  <> [M:PKP1]VCRNUM
      Read [PRH]PRH0 =  [M:PKP1]VCRNUM
   Endif
Endif
#  PACSEQ   = [M:PKP1]PACSEQ(GLIG_PKP1) enleve ....... remplcé par 1
#If [M:PKP1]PACQTYSTU(GLIG_PKP1) <> 0 &  GORI_PKP = "PKP2"
If [M:PKP1]PACQTYSTU(GLIG_PKP1) <> 0
#lecture des détails du colis pour la ligne de PKP1
    Filter [SPD] Where  VCRTYP   = GVCRTYP                   &
&                       VCRNUM   = [M:PKP1]VCRNUM            &
&                       VCRLIN   = [M:PKP1]VCRLIN(GLIG_PKP1) &
&                       PACNUM   = [M:PKP1]PACNUM(GLIG_PKP1) &
&                       PACSEQ   = 1
&   Order By Key SPD0
    For [SPD]
        LLIG = [M:PKP2]NBLIG
        If LLIG > dim([M:PKP2]MODFLG)
           Call ERREUR(mess(278,184,1)) From GESECRAN
           GOK = 0
           Break
        Endif
        If dim([M:PKP2]LOT)>0
           [M:PKP2]LOT       (LLIG)    = [F:SPD]LOT
        Endif
        If dim([M:PKP2]SLO)>0
           [M:PKP2]SLO       (LLIG)    = [F:SPD]SLO
        Endif
        If dim([M:PKP2]SERNUM)>0
           If [M:PKP2]SERMGTCOD       = 4                                                          # hcb 110327-pck
              [M:PKP2]SERNUM   (LLIG) = [F:SPD]SERDEB     # serie du colis                         # hcb 110327-pck
              [M:PKP2]SERFIN   (LLIG) = [F:SPD]SERFIN     # serie du colis                         # hcb 110327-pck
              [M:PKP2]SERCOLDEB(LLIG) = [F:SPD]SERDEB     # serie du colis                         # hcb 110327-pck
              [M:PKP2]SERCOLFIN(LLIG) = [F:SPD]SERFIN     # serie du colis                         # hcb 110327-pck
              [M:PKP2]QTYINI   (LLIG) = [F:SPD]QTYPCU     # qty ini du colis                       # hcb 110327-pck
              [M:PKP2]SERORIDEB(LLIG) = [F:SPD]SERORIDEB  # serie origine du document              # hcb 110327-pck
              [M:PKP2]SERORIFIN(LLIG) = [F:SPD]SERORIFIN  # serie origine du document              # hcb 110327-pck
           Else                                                                                    # hcb 110327-pck
             [M:PKP2]SERNUM(LLIG)     = [F:SPD]SERNUM
           Endif                                                                                   # hcb 110327-pck
        Endif
        If dim([M:PKP2]PALNUM)>0
           [M:PKP2]PALNUM    (LLIG)    = [F:SPD]PALNUM
        Endif
        If dim([M:PKP2]CTRNUM)>0
           [M:PKP2]CTRNUM    (LLIG)    = [F:SPD]CTRNUM
        Endif
        [M:PKP2]SAU       (LLIG)    = [F:SPD]SAU     # hcb 97419
#        [M:PKP2]QTYPCU    (LLIG)    = [F:SPD]QTYPCU  # hcb X3-108941
#        [M:PKP2]QTY       (LLIG)    = [F:SPD]QTYPCU  # hcb X3-108941
        [M:PKP2]QTYPCU    (LLIG)    = [F:SPD]QTY  # hcb X3-108941
        [M:PKP2]QTY       (LLIG)    = [F:SPD]QTY  # hcb X3-108941
        [M:PKP2]PCU       (LLIG)    = [F:SPD]PCU
        [M:PKP2]NETWEI    (LLIG)    = [F:SPD]NETWEI
        [M:PKP2]LIGWEU    (LLIG)    = [F:SPD]WEU
        [M:PKP2]PCUSTUCOE (LLIG)    = [F:SPD]PCUSTUCOE
        [M:PKP2]WSTOCOU   (LLIG)    = [F:SPD]WSTOCOU
        [M:PKP2]STU       (LLIG)    = [M:PKP1]STU       (GLIG_PKP1)                     # hcb 54897
#        [M:PKP2]QTYSTU    (LLIG)    = [F:SPD]QTYPCU * [F:SPD]PCUSTUCOE            # hcb X3-108941
        [M:PKP2]QTYSTU    (LLIG)    =  [M:PKP2]QTY       (LLIG)  * [F:SPD]PCUSTUCOE            # hcb X3-108941
        Call QTEARR([M:PKP2]QTYSTU(LLIG), [M:PKP1]STU(GLIG_PKP1)) From TRTDIV           # hcb 54897
        [M:PKP2]LIGUNTWEI(LLIG)     = [M:PKP1]LIGUNTWEI(GLIG_PKP1)
        [M:PKP2]NETWEIPCK (LLIG)    = [M:PKP2]NETWEI(LLIG) * [M:PKP2]LIGUNTWEI(LLIG)
        [M:PKP2]MODFLG    (LLIG)    = 0
        [M:PKP2]NBLIG += 1
    Next
    Filter [SPD]
# ceci dans le cas ou l on veux modifier le poids depuis PKP1
    If [M:PKP2]NBLIG = 1  & [M:PKP2]NETWEI (0)  <>  [M:PKP1]NETWEI (GLIG_PKP1)
           [M:PKP2]NETWEI    (0) =  [M:PKP1]NETWEI   (GLIG_PKP1)
    Endif

Else
   WI = [M:PKP2]NBLIG
# si géré en stock et gestion du colisage detail stock on lit STOJOU ou STOALL
   If  [M:PKP2]STOMGTCOD > 1 &   [M:PKP2]PCKSTKFLG = 2

       # Issue X3-69499 - 2018-06-13 by TS
       #If GVCRTYP = 4 & [F:SDH]CFMFLG = 2
       # Ajout test sur LINCFMFLG par sécurité car normalement inutile,
       # les livraisons partiellement validées étant filtrées (non chargées)
       If GVCRTYP=4 & ([F:SDH]CFMFLG=2 | [F:SDD]LINCFMFLG=2)
       # End issue X3-69499
          Filter [STJ] Where STOFCY=[M:PKP2]STOFCY & VCRTYP=GVCRTYP & VCRNUM=[M:PKP1]VCRNUM
&                      & VCRLIN=[M:PKP1]VCRLIN(GLIG_PKP1)
&                      & UPDCOD=2 & REGFLG<>2  & QTYPCU < 0
&         Order By Key CLE = LOT;SLO;SERNUM;PALNUM;CTRNUM;PCU;PCUSTUCOE
          For [STJ]
#                                                                                         # hcb 55930 2 deb
#         si nbcol <> 0 colisage auto en cours avec  plusieurs details
#                       il faut donc verifier que l enregistrement n est pas deja colisé
              If [M:PKP1]NBDETAIL (GLIG_PKP1) > 1 & [M:PKP1]NBCOL  (GLIG_PKP1) <> 0
                 WCOLIAUTO_ORI = "STJ"
                 Gosub VERIF_COLISAUTO
                 If WCOLIAUTO_OK <> 0
                    Goto NEX_PKP2_STJ
                 Endif
              Endif
#                                                                                         # hcb 55930 2 fin
#   rajour test sur SERFIN                                                                         # hcb 110327-pck

              I =sigma(0,[M:PKP2]NBLIG-1,(indcum+1)*((dim([M:PKP2]LOT)<= 0 | [M:PKP2]LOT(indcum) = [F:STJ]LOT) &
&                                      (dim([M:PKP2]SLO)<=0  | [M:PKP2]SLO(indcum) = [F:STO]SLO) &
&                                      (dim([M:PKP2]SERNUM)<= 0 | [M:PKP2]SERNUM(indcum) = [F:STJ]SERNUM) &
&                                      (dim([M:PKP2]SERFIN)<= 0 | [M:PKP2]SERFIN(indcum) = [F:STJ]SERFIN) &
&                                      (dim([M:PKP2]PALNUM)<= 0 | [M:PKP2]PALNUM(indcum) = [F:STJ]PALNUM) &
&                                      (dim([M:PKP2]CTRNUM)<= 0 | [M:PKP2]CTRNUM(indcum) = [F:STJ]CTRNUM) &
&                                      ([M:PKP2]VCRLIN(indcum)    = [M:PKP1]VCRLIN(GLIG_PKP1))        &
&                                      ([M:PKP2]PCU(indcum)       = [F:STJ]PCU) &
&                                      ([M:PKP2]PCUSTUCOE(indcum) = [F:STJ]PCUSTUCOE)))
            If I = 0
               If [M:PKP2]NBLIG  >  dim ([M:PKP2]QTY)   # hcb 71217
                  Call MESSAGE(mess(527,199,1)) From GESECRAN
                  GOK = 0
                  Break
               Endif
               I = [M:PKP2]NBLIG
               If [M:PKP1]MODFLG (GLIG_PKP1) =  2 & [M:PKP1]PACSEQ(GLIG_PKP1) <> 0 &
&                 ([M:PKP1]NBDETAIL (GLIG_PKP1) = 1 | ([M:PKP1]NBDETAIL (GLIG_PKP1) > 1 & [M:PKP1]NBCOL (GLIG_PKP1) <> 0)) # hcb 55930 2
                  [M:PKP2]QTYPCU            (I)       = [M:PKP1]QTY           (GLIG_PKP1)    # hcb 73352
                  [M:PKP2]SAU               (I)       = [M:PKP1]SAU           (GLIG_PKP1)    # hcb 97419
                  [M:PKP2]QTY               (I)       = [M:PKP1]QTY           (GLIG_PKP1)
                  [M:PKP2]PCU               (I)       = [F:STJ]PCU                           # hcb 55930 2
                  [M:PKP2]PCUSTUCOE         (I)       = [F:STJ]PCUSTUCOE                     # hcb 55930 2
                  [M:PKP2]STU               (I)       = [M:PKP1]STU       (GLIG_PKP1)          # hcb 54897
                  [M:PKP2]QTYSTU            (I)       = [M:PKP2]QTY(I) * [M:PKP2]PCUSTUCOE(I)
                  Call QTEARR([M:PKP2]QTYSTU(I), [M:PKP1]STU(GLIG_PKP1)) From TRTDIV           # hcb 54897
                  [M:PKP2]LIGWEU            (I)       = [M:PKP1]WEU(GLIG_PKP1)
                  [M:PKP2]LIGUNTWEI         (I)       = [M:PKP1]LIGUNTWEI(GLIG_PKP1)
                  # Calcul poids de la ligne  en unite de l emballage
                  If [M:PKP1]NETWEI (GLIG_PKP1) <> 0
                     [M:PKP2]NETWEI         (I)       =  [M:PKP1]NETWEI (GLIG_PKP1)
                  Else
                     [M:PKP2]NETWEI         (I)       = [M:PKP2]QTYSTU (I) * [M:PKP1]UNTWEI   (GLIG_PKP1) # hcb 54897
                     [M:PKP2]NETWEIPCK      (I)       = [M:PKP2]NETWEI (I) * [M:PKP2]LIGUNTWEI(I)
                  Endif

               Else
                  [M:PKP2]QTYPCU(I)      += ([F:STJ]QTYPCU * -1)
                  [M:PKP2]SAU   (I)       = [M:PKP1]SAU       (GLIG_PKP1)    # hcb 97419
                  [M:PKP2]QTY(I)          = [M:PKP2]QTYPCU(I) * WPRECHARGE
                  [M:PKP2]PCU(I)          = [F:STJ]PCU
                  [M:PKP2]PCUSTUCOE(I)    = [F:STJ]PCUSTUCOE
                  [M:PKP2]STU (I)         = [M:PKP1]STU       (GLIG_PKP1)                     # hcb 54897
                  [M:PKP2]QTYSTU (I)      = [M:PKP2]QTY(I) * [M:PKP2]PCUSTUCOE(I)
                  Call QTEARR([M:PKP2]QTYSTU(I), [M:PKP1]STU(GLIG_PKP1)) From TRTDIV          # hcb 54897
                  [M:PKP2]LIGWEU(I)       = [M:PKP1]WEU(GLIG_PKP1)
   # Calcul poids de la ligne  en unite de l emballage
                  [M:PKP2]LIGUNTWEI(I)     = [M:PKP1]LIGUNTWEI(GLIG_PKP1)
                  [M:PKP2]NETWEI(I) =  [M:PKP2]QTY(I) * [M:PKP1]UNTWEI   (GLIG_PKP1) # hcb 54897
                  [M:PKP2]NETWEIPCK (I)   = [M:PKP2]NETWEI(I) * [M:PKP2]LIGUNTWEI(I)
               Endif
               If dim([M:PKP2]LOT)>0
                  [M:PKP2]LOT(I)       = [F:STJ]LOT
               Endif
               If dim([M:PKP2]SLO)>0
                  [M:PKP2]SLO(I)       = [F:STJ]SLO
               Endif
               [M:PKP2]QTYINI    (I)    = ([F:STJ]QTYSTU * -1)                                           # hcb 110327-pck
               If  [M:PKP2]QTY    (I)      <> 0                                                   # hcb 110327-pck
                   [M:PKP2]MODFLG (I)      =  2                                                   # hcb 110327-pck
                Endif                                                                              # hcb 110327-pck
               If dim([M:PKP2]SERNUM)>0
                  [M:PKP2]SERORIDEB    (I) = [F:STJ]SERDEB                                      # hcb 110327-pck
                  [M:PKP2]SERORIFIN    (I) = [F:STJ]SERFIN                                      # hcb 110327-pck
                  If [M:PKP1]IDETAIL(GLIG_PKP1) <> 3
                     Raz [M:PKP2]WSERIE                                 # hcb 110327-pck
                  Endif
                  If find([M:PKP1]IDETAIL(GLIG_PKP1),3,4)                                          # hcb 110327-pck
                     Gosub DETAIL_SERIE                                                            # hcb 110327-pck
                  Else                                                                             # hcb 110327-pck
                     [M:PKP2]SERNUM       (I) = [F:STJ]SERNUM
                     [M:PKP2]SERFIN       (I) = [F:STJ]SERNUM                                      # hcb 110327-pck
                  Endif                                                                            # hcb 110327-pck
               Endif
               If dim([M:PKP2]PALNUM)>0
                  [M:PKP2]PALNUM(I)    = [F:STJ]PALNUM
               Endif
               If dim([M:PKP2]CTRNUM)>0
                  [M:PKP2]CTRNUM(I)    = [F:STJ]CTRNUM
               Endif
               [M:PKP2]NBLIG +=1
            Else
               I -= 1
               [M:PKP2]QTYPCU(I)      += ([F:STJ]QTYPCU * -1)
               [M:PKP2]QTY(I)          = [M:PKP2]QTYPCU(I) * WPRECHARGE
               [M:PKP2]QTYSTU (I)      = [M:PKP2]QTY(I) * [M:PKP2]PCUSTUCOE(I)
               Call QTEARR([M:PKD1]QTYSTU(I), [M:PKP1]STU(GLIG_PKP1)) From TRTDIV           # hcb 54897
      # Calcul poids de la ligne  en unite de l emballage
               [M:PKP2]NETWEI(I)       = [M:PKP2]QTYSTU (I) * [M:PKP1]UNTWEI   (GLIG_PKP1)  # hcb 54897
               [M:PKP2]NETWEIPCK (I)   = [M:PKP2]NETWEI(I)  * [M:PKP2]LIGUNTWEI(I)
            Endif
$NEX_PKP2_STJ                                                    # hcb 55930 2
          If  WCOLIAUTO_ORI = "STJ" &  WCOLIAUTO_OK = 0          # hcb 55930 2
              Break                                              # hcb 55930 2
          Endif                                                  # hcb 55930 2
          Next
          Filter [STJ]
       Else
          WI = [M:PKP2]NBLIG
# Si origine = livraison / preparation on recupere les allocation detailées et manquant 2 / 4
          WFILSTA = 'find(ALLTYP,2,4)<>0'
          For [STA]STA1 Where VCRTYP=GVCRTYP & VCRNUM=[M:PKP1]VCRNUM &  VCRLIN=[M:PKP1]VCRLIN(GLIG_PKP1) &
&                             ITMREF=[M:PKP1]ITMREF  (GLIG_PKP1) & evalue(WFILSTA)
# Si allocation détaillée
          If [F:STA]ALLTYP=2
             Read [STO]STO0=[F:STA]STOFCY;[F:STA]STOCOU
             #--- Bug 70617
             #If fstat Return Endif
             If fstat Break Endif
             #---
#                                                                                         # hcb 55930 2 deb
#         si nbcol <> 0 colisage auto en cours avec  plusieurs details
#                       il faut donc verifier que l enregistrement n est pas deja colisé
              If [M:PKP1]NBDETAIL (GLIG_PKP1) > 1 & [M:PKP1]NBCOL  (GLIG_PKP1) <> 0
                 WCOLIAUTO_ORI = "STO"
                 Gosub VERIF_COLISAUTO
                 If WCOLIAUTO_OK <> 0
                    Goto NEX_PKP2_STA
                 Endif
              Endif
#                                                                                         # hcb 55930 2 fin
#         Rajout  [F:ITM]SERMGTCOD = 4                                                             # hcb 110327-pck

             I =sigma(0,[M:PKP2]NBLIG-1,(indcum+1)*((dim([M:PKP2]LOT)<= 0 | [M:PKP2]LOT(indcum) = [F:STO]LOT) &
&                                       (dim([M:PKP2]SLO)   <= 0  | [M:PKP2]SLO(indcum) = [F:STO]SLO) &
&                                       (dim([M:PKP2]SERNUM)<= 0 | [M:PKP2]SERNUM(indcum) = [F:STO]SERNUM) &
&                                       ([M:PKP2]SERMGTCOD = 4 &   [M:PKP2]SERNUM(indcum) = [F:STA]SERNUM | [M:PKP2]SERMGTCOD <> 4) &
&                                       (dim([M:PKP2]PALNUM)<= 0 | [M:PKP2]PALNUM(indcum) = [F:STO]PALNUM) &
&                                       (dim([M:PKP2]CTRNUM)<= 0 | [M:PKP2]CTRNUM(indcum) = [F:STO]CTRNUM) &
&                                       ([M:PKP2]PCU(indcum) = [F:STO]PCU) &
&                                       ([M:PKP2]WSTOCOU(indcum)   = 2) &
&                                       ([M:PKP2]PCUSTUCOE(indcum) = [F:STO]PCUSTUCOE)))
             If I = 0
                I = [M:PKP2]NBLIG
                If [M:PKP1]MODFLG (GLIG_PKP1) =  2 & [M:PKP1]PACSEQ(GLIG_PKP1) <> 0 &
&                  ([M:PKP1]NBDETAIL (GLIG_PKP1) = 1 | ([M:PKP1]NBDETAIL (GLIG_PKP1) > 1 & [M:PKP1]NBCOL (GLIG_PKP1) <> 0)) # hcb 55930 2
                   [M:PKP2]QTYPCU            (I)       = [M:PKP1]QTYSTU(GLIG_PKP1) /[F:STO]PCUSTUCOE
                   [M:PKP2]SAU               (I)       = [M:PKP1]SAU       (GLIG_PKP1)    # hcb 97419
                   [M:PKP2]QTY               (I)       = [M:PKP2]QTYPCU            (I)
                   [M:PKP2]PCU               (I)       = [F:STO]PCU                             # hcb 55930 2
                   [M:PKP2]PCUSTUCOE         (I)       = [F:STO]PCUSTUCOE                       # hcb 55930 2
                   [M:PKP2]STU               (I)       = [M:PKP1]STU       (GLIG_PKP1)          # hcb 54897
                   [M:PKP2]QTYSTU            (I)       = [M:PKP2]QTY(I) * [M:PKP2]PCUSTUCOE(I)
                   Call QTEARR([M:PKP2]QTYSTU(I), [M:PKP1]STU(GLIG_PKP1)) From TRTDIV           # hcb 54897
                   [M:PKP2]LIGWEU            (I)       = [M:PKP1]WEU(GLIG_PKP1)
                   [M:PKP2]LIGUNTWEI         (I)       = [M:PKP1]LIGUNTWEI(GLIG_PKP1)
                   # Calcul poids de la ligne  en unite de l emballage
                   If [M:PKP1]NETWEI (GLIG_PKP1) <> 0
                      [M:PKP2]NETWEI         (I)       =  [M:PKP1]NETWEI (GLIG_PKP1)
                   Else
                      [M:PKP2]NETWEI         (I)       = [M:PKP2]QTYSTU (I) * [M:PKP1]UNTWEI   (GLIG_PKP1) # hcb 54897
                      [M:PKP2]NETWEIPCK      (I)       = [M:PKP2]NETWEI (I) * [M:PKP2]LIGUNTWEI(I)
                   Endif
                Else
                   [M:PKP2]QTYPCU(I)       = [F:STA]QTYSTU/[F:STO]PCUSTUCOE             # hcb X3-108941
#                   [M:PKP2]QTYPCU(I)       = [F:STA]QTYSTU/[M:PKP1]SAUSTUCOE (GLIG_PKP1) # hcb X3-108941
                   [M:PKP2]SAU   (I)       = [M:PKP1]SAU       (GLIG_PKP1)    # hcb 97419
                   [M:PKP2]QTY(I)          = [M:PKP2]QTYPCU(I) * WPRECHARGE                # hcb 105984
#                  [M:PKP2]QTY               (I)       = [M:PKP1]QTY       (GLIG_PKP1)     # hcb 105984
                   [M:PKP2]PCUSTUCOE(I)    = [F:STO]PCUSTUCOE
                   [M:PKP2]STU(I)          = [M:PKP1]STU       (GLIG_PKP1)                   # hcb 54897
                   [M:PKP2]QTYSTU (I)      = [M:PKP2]QTY(I) * [M:PKP2]PCUSTUCOE(I)          # hcb X3-108941
#                  [M:PKP2]QTYSTU (I)      = [M:PKP2]QTY(I) * [M:PKP1]SAUSTUCOE (GLIG_PKP1)   # hcb X3-108941
                   Call QTEARR([M:PKP2]QTYSTU(I), [M:PKP1]STU(GLIG_PKP1)) From TRTDIV          # hcb 54897
                   [M:PKP2]LIGWEU(I)       = [M:PKP1]WEU(GLIG_PKP1)
      # Calcul poids de la ligne  en unite de l emballage
                   [M:PKP2]LIGUNTWEI(I)    = [M:PKP1]LIGUNTWEI(GLIG_PKP1)
                   [M:PKP2]NETWEI(I)       = [M:PKP2]QTYSTU(I) * [M:PKP1]UNTWEI   (GLIG_PKP1) # hcb 54897
                   [M:PKP2]NETWEIPCK (I)   = [M:PKP2]NETWEI(I)  * [M:PKP2]LIGUNTWEI(I)
                   [M:PKP2]PCU(I)          = [F:STO]PCU
                Endif
                [M:PKP2]WSTOCOU(I)      = 2
                If dim([M:PKP2]LOT)>0
                   [M:PKP2]LOT(I)       = [F:STO]LOT
                Endif
                If dim([M:PKP2]SLO)>0
                   [M:PKP2]SLO(I)       = [F:STO]SLO
                Endif
                [M:PKP2]QTYINI     (I)      =  [F:STA]QTYSTU                                       # hcb 110327-pck
                If  [M:PKP2]QTY    (I)      <> 0                                                   # hcb 110327-pck
                    [M:PKP2]MODFLG (I)      =  2                                                   # hcb 110327-pck
                Endif                                                                              # hcb 110327-pck
                If dim([M:PKP2]SERNUM)>0
                   [M:PKP2]SERORIDEB     (I) = [F:STA]SERNUM                                    # hcb 110327-pck
                   If abs([F:STA]QTYSTU)= 1                                                     # hcb 110327-pck
                      [M:PKP2]SERORIFIN  (I) = [F:STA]SERNUM                                    # hcb 110327-pck
                   Else                                                                         # hcb 110327-pck
                      WSERNUM = [F:STA]SERNUM                                                   # hcb 110327-pck
                      Call PLUS_NB(WSERNUM,abs([F:STA]QTYSTU),WSERNUMF,LRET) From STKLIB        # hcb 110327-pck
                      [M:PKP2]SERORIFIN  (I) = WSERNUMF                                         # hcb 110327-pck
                   Endif
                   If find([M:PKP1]IDETAIL(GLIG_PKP1),3,4)                                          # hcb 110327-pck
                      Gosub DETAIL_SERIE                                                           # hcb 110327-pck
                   Else                                                                            # hcb 110327-pck
                      [M:PKP2]SERNUM(I)    = [F:STO]SERNUM
                      [M:PKP2]SERFIN(I)    = [F:STO]SERNUM                                         # hcb 110327-pck
                   Endif                                                                           # hcb 110327-pck
                Endif
                If dim([M:PKP2]PALNUM)>0
                   [M:PKP2]PALNUM(I)    = [F:STO]PALNUM
                Endif
                If dim([M:PKP2]CTRNUM)>0
                   [M:PKP2]CTRNUM(I)    = [F:STO]CTRNUM
                Endif

 #              [M:PKP2]MODFLG    (I)    = 2                                                       # hcb 110327-pck
                [M:PKP2]NBLIG +=1
             Else
                I -= 1
                [M:PKP2]QTYPCU(I)      += [F:STA]QTYSTU/[M:PKP2]PCUSTUCOE(I)
                [M:PKP2]QTY(I)         += ([F:STA]QTYSTU/[M:PKP2]PCUSTUCOE(I)) * WPRECHARGE
                [M:PKP2]QTYSTU (I)      = [M:PKP2]QTY(I) * [M:PKP2]PCUSTUCOE(I)
                Call QTEARR([M:PKP2]QTYSTU(I), [M:PKP1]STU(GLIG_PKP1)) From TRTDIV           # hcb 54897
                [M:PKP2]LIGUNTWEI(I)    = [M:PKP1]LIGUNTWEI(GLIG_PKP1)
                [M:PKP2]LIGWEU(I)       = [M:PKP1]WEU(GLIG_PKP1)
      # Calcul poids de la ligne  en unite de l emballage
                [M:PKP2]NETWEI(I) =  [M:PKP2]QTYSTU(I) * [M:PKP1]UNTWEI   (GLIG_PKP1) # hcb 54897
                [M:PKP2]NETWEIPCK (I)   = [M:PKP2]NETWEI(I)  * [M:PKP2]LIGUNTWEI(I)
             Endif
          Else
#                                                                                         # hcb 55930 2 deb
#         si nbcol <> 0 colisage auto en cours avec  plusieurs details
#                       il faut donc verifier que l enregistrement n est pas deja colisé
              If [M:PKP1]NBDETAIL (GLIG_PKP1) > 1 & [M:PKP1]NBCOL  (GLIG_PKP1) <> 0
                 WCOLIAUTO_ORI = "STA"
                 Gosub VERIF_COLISAUTO
                 If WCOLIAUTO_OK <> 0
                    Goto NEX_PKP2_STA
                 Endif
              Endif
#                                                                                         # hcb 55930 2 fin
             I = [M:PKP2]NBLIG
             If [M:PKP1]MODFLG (GLIG_PKP1) =  2 & [M:PKP1]PACSEQ(GLIG_PKP1) <> 0 &
&              ([M:PKP1]NBDETAIL (GLIG_PKP1) = 1 | ([M:PKP1]NBDETAIL (GLIG_PKP1) > 1 & [M:PKP1]NBCOL (GLIG_PKP1) <> 0)) # hcb 55930 2
                [M:PKP2]QTYPCU            (I)       = [M:PKP1]QTYSAU        (GLIG_PKP1)
                [M:PKP2]SAU               (I)       = [M:PKP1]SAU           (GLIG_PKP1)    # hcb 97419
                [M:PKP2]QTY               (I)       = [M:PKP1]QTY           (GLIG_PKP1)
                [M:PKP2]PCU               (I)       = [M:PKP1]SAU           (GLIG_PKP1)
                [M:PKP2]PCUSTUCOE         (I)       = [M:PKP1]SAUSTUCOE     (GLIG_PKP1)
                [M:PKP2]STU               (I)       = [M:PKP1]STU       (GLIG_PKP1)          # hcb 54897
                [M:PKP2]QTYSTU            (I)       = [M:PKP2]QTY(I) * [M:PKP2]PCUSTUCOE(I)
                Call QTEARR([M:PKP2]QTYSTU(I), [M:PKP1]STU(GLIG_PKP1)) From TRTDIV           # hcb 54897
                [M:PKP2]LIGWEU            (I)       = [M:PKP1]WEU(GLIG_PKP1)
                [M:PKP2]LIGUNTWEI         (I)       = [M:PKP1]LIGUNTWEI(GLIG_PKP1)
                # Calcul poids de la ligne  en unite de l emballage
                If [M:PKP1]NETWEI (GLIG_PKP1) <> 0
                   [M:PKP2]NETWEI         (I)       =  [M:PKP1]NETWEI (GLIG_PKP1)
                Else
                   [M:PKP2]NETWEI         (I)       = [M:PKP2]QTYSTU (I) * [M:PKP1]UNTWEI   (GLIG_PKP1) # hcb 54897
                   [M:PKP2]NETWEIPCK      (I)       = [M:PKP2]NETWEI (I) * [M:PKP2]LIGUNTWEI(I)
                Endif
             Else
                [M:PKP2]QTYPCU    (I)       = [F:STA]QTYSTU
                [M:PKP2]SAU       (I)       = [M:PKP1]SAU       (GLIG_PKP1)    # hcb 97419
                [M:PKP2]QTY       (I)       = [M:PKP2]QTYPCU(I) * WPRECHARGE
                [M:PKP2]STU       (I)       = [M:PKP1]STU       (GLIG_PKP1)                     # hcb 54897
                [M:PKP2]PCUSTUCOE (I)       = [M:PKP1]SAUSTUCOE     (GLIG_PKP1)                 # hcb 55930 2
                [M:PKP2]QTYSTU    (I)       = [M:PKP2]QTY(I)
                [M:PKP2]LIGWEU    (I)       = [M:PKP1]WEU(GLIG_PKP1)
  # Calcul poids de la ligne  en unite de l emballage
                [M:PKP2]LIGUNTWEI(I)        = [M:PKP1]LIGUNTWEI(GLIG_PKP1)
                [M:PKP2]NETWEI    (I)       = [M:PKP2]QTYSTU(I) * [M:PKP1]UNTWEI   (GLIG_PKP1) # hcb 54897
                [M:PKP2]NETWEIPCK (I)       = [M:PKP2]NETWEI(I) * [M:PKP2]LIGUNTWEI(I)
                [M:PKP2]PCU       (I)       = [M:PKP1]SAU           (GLIG_PKP1)                 # hcb 55839
             Endif
             [M:PKP2]WSTOCOU   (I)       = 1
             If dim([M:PKP2]LOT)>0
                [M:PKP2]LOT    (I)       = [F:STA]LOT
             Endif
             If dim([M:PKP2]SLO)>0
                [M:PKP2]SLO    (I)       = [F:STA]SLO
             Endif
             [M:PKP2]QTYINI    (I)      = [F:STA]QTYSTU                                            # hcb 110327-pck
             If  [M:PKP2]QTY(I)    <> 0                                                            # hcb 110327-pck
                 [M:PKP2]MODFLG    (I)    = 2                                                      # hcb 110327-pck
             Endif                                                                                 # hcb 110327-pck
             If dim([M:PKP2]SERNUM)>0
                [M:PKP2]SERORIDEB     (I) = [F:STA]SERNUM                                       # hcb 110327-pck
                If abs([F:STA]QTYSTU)= 1                                                        # hcb 110327-pck
                   [M:PKP2]SERORIFIN  (I) = [F:STA]SERNUM                                       # hcb 110327-pck
                Else                                                                            # hcb 110327-pck
                   WSERNUM = [F:STA]SERNUM                                                      # hcb 110327-pck
                   Call PLUS_NB(WSERNUM,abs([F:STA]QTYSTU),WSERNUMF,LRET) From STKLIB           # hcb 110327-pck
                   [M:PKP2]SERORIFIN  (I) = WSERNUMF                                            # hcb 110327-pck
                Endif                                                                          # hcb 110327-pck
                If find([M:PKP1]IDETAIL(GLIG_PKP1),3,4)                                          # hcb 110327-pck
                   Gosub DETAIL_SERIE                                                             # hcb 110327-pck
                Else                                                                               # hcb 110327-pck
                    [M:PKP2]SERNUM(I)    = [F:STA]SERNUM
                    [M:PKP2]SERFIN(I)    = [F:STA]SERNUM                                           # hcb 110327-pck
                Endif                                                                              # hcb 110327-pck
             Endif
#            [M:PKP2]MODFLG    (I)    = 2                                                          # hcb 110327-pck
             [M:PKP2]NBLIG +=1
          Endif
$NEX_PKP2_STA
          If  (WCOLIAUTO_ORI = "STO" | WCOLIAUTO_ORI = "STA") &  WCOLIAUTO_OK = 0          # hcb 55930 2
              Break                                                                        # hcb 55930 2
          Endif                                                                            # hcb 55930 2
                                                                                           # hcb 55930 2
          Next
          Filter [STA]
       Endif
# recherche si colisage existant
       If WI <> [M:PKP2]NBLIG
          If [M:PKP1]MODFLG (GLIG_PKP1) =  2 & [M:PKP1]PACSEQ(GLIG_PKP1) <> 0 & [M:PKP1]NBDETAIL (GLIG_PKP1) = 1
          Else
          For I=WI To [M:PKP2]NBLIG-1
              WCRITSPD = "1=1"                                                                     # hcb 110327-pck
              Raz      WSER                                                                        # hcb 110327-pck
              If dim([M:PKP2]LOT)>0
                 WLOT = [M:PKP2]LOT(I)
              Endif
              If dim([M:PKP2]SLO)>0
                 WSLO = [M:PKP2]SLO(I)
              Endif
              If dim([M:PKP2]SERNUM)>0
                 If  [M:PKP2]SERMGTCOD <> 4                                                        # hcb 110327-PCK
                     WSER = [M:PKP2]SERNUM(I)                                                      # hcb 110327-PCK
                     WCRITSPD = "1=1"                                                              # hcb 110327-pck
                 Else                                                                              # hcb 110327-PCK
                     WCRITSPD = "SERDEB >= [M:PKP2]SERORIDEB(I)  & SERFIN <= [M:PKP2]SERORIFIN(I)"       # hcb 110327-PCK
                 Endif                                                                             # hcb 110327-PCK
              Endif
              If dim([M:PKP2]PALNUM)>0
                 WPAL = [M:PKP2]PALNUM(I)
              Endif
              If dim([M:PKP2]CTRNUM)>0
                 WCTR = [M:PKP2]CTRNUM(I)
              Endif
              Raz WEXISTE                                                                          # hcb 110327-PCK
#                     rajout evalue(WCRITSPD)                                                      # hcb 110327-PCK

              Filter [SPD] Where STOFCY = [M:PKP1]STOFCY & VCRTYP = GVCRTYP & VCRNUM = [M:PKP1]VCRNUM & VCRLIN = [M:PKP1]VCRLIN(GLIG_PKP1)
&                          & LOT    = WLOT & SLO    = WSLO & SERNUM = WSER & PALNUM = WPAL
&                          & CTRNUM = WCTR & PCU    = [M:PKP2]PCU(I)  & PCUSTUCOE = [M:PKP2]PCUSTUCOE(I)
&                          & evalue(WCRITSPD)
&             Order By Key CLE = LOT;SLO;SERNUM;PALNUM;CTRNUM;PCU;PCUSTUCOE
              For [SPD]
                  [M:PKP2]QTYPCU(I)      -= [F:SPD]QTYPCU
                  If WPRECHARGE = 1
                     [M:PKP2]QTY(I)         -= [F:SPD]QTYPCU
                     [M:PKP2]QTYSTU (I)      = [M:PKP2]QTY(I) * [M:PKP2]PCUSTUCOE(I)
                     Call QTEARR([M:PKP2]QTYSTU(I), [M:PKP1]STU(GLIG_PKP1)) From TRTDIV           # hcb 54897
   # Calcul poids de la ligne  en unite de l emballage
                     [M:PKP2]LIGUNTWEI(I)    = [M:PKP1]LIGUNTWEI(GLIG_PKP1)
                     [M:PKP2]NETWEI(I)       = [M:PKP2]QTYSTU(I) * [M:PKP1]UNTWEI   (GLIG_PKP1) # hcb 54897
                     [M:PKP2]NETWEIPCK (I)   = [M:PKP2]NETWEI(I) * [M:PKP2]LIGUNTWEI(I)
                     WEXISTE = 1                                                    # hcb 110327-pck
                  Endif
              Next
#                                                                                   # hcb 110327-PCK deb
          If [M:PKP2]SERMGTCOD = 4 & WEXISTE = 1
             Raz [M:PKP2]SERNUM(I)
             Raz [M:PKP2]SERFIN(I)
          Endif
#                                                                                                  # hcb 110327-PCK fin
              Filter [SPD]
          Next
          Endif
       Endif
   Else               # si pas gére en sock on charge directement suivant la ligne document
                      # quelquesoit le type de document
       LLIG = [M:PKP2]NBLIG
       [M:PKP2]QTYPCU     (LLIG)       = [M:PKP1]QTY           (GLIG_PKP1)            # hcb 73352
       [M:PKP2]SAU        (LLIG)       = [M:PKP1]SAU           (GLIG_PKP1)    # hcb 97419
       [M:PKP2]QTY        (LLIG)       = [M:PKP1]QTY           (GLIG_PKP1)
       [M:PKP2]PCU        (LLIG)       = [M:PKP1]SAU           (GLIG_PKP1)
       [M:PKP2]PCUSTUCOE  (LLIG)       = [M:PKP1]SAUSTUCOE     (GLIG_PKP1)
       [M:PKP2]STU        (LLIG)       = [M:PKP1]STU           (GLIG_PKP1)                 # hcb 54897
       [M:PKP2]QTYSTU     (LLIG)       = [M:PKP2]QTY(LLIG) * [M:PKP2]PCUSTUCOE(LLIG)
       Call QTEARR([M:PKP2]QTYSTU(LLIG), [M:PKP1]STU(GLIG_PKP1)) From TRTDIV           # hcb 54897
       [M:PKP2]LIGWEU     (LLIG)       = [M:PKP1]WEU(GLIG_PKP1)
       [M:PKP2]LIGUNTWEI  (LLIG)       = [M:PKP1]LIGUNTWEI(GLIG_PKP1)
 # Calcul poids de la ligne  en unite de l emballage
       If [M:PKP1]NETWEI (GLIG_PKP1) <> 0
          [M:PKP2]NETWEI (LLIG)        =  [M:PKP1]NETWEI (GLIG_PKP1)
       Else
          [M:PKP2]NETWEI (LLIG)        = [M:PKP2]QTYSTU  (LLIG)* [M:PKP1]UNTWEI   (GLIG_PKP1) # hcb 54897
          [M:PKP2]NETWEIPCK (LLIG)     = [M:PKP2]NETWEI(LLIG)  * [M:PKP2]LIGUNTWEI(LLIG)
       Endif

       If  [M:PKP2]QTY(I)    <> 0                                                                  # hcb 110327-pck bug
           [M:PKP2]MODFLG    (I)    = 2
       Endif                                                                                       # hcb 110327-pck bug
       [M:PKP2]NBLIG +=1
   Endif

# suppression des lignes qui ont quantité à coliser = 0 dans le cas d un picking de ligne
   Local Integer J
   Raz I,J
   If [M:PKP2]NBLIG <> 0
      For I=0 To [M:PKP2]NBLIG - 1
          If I > [M:PKP2]NBLIG
                 [M:PKP2]NBLIG = I
                 Break
          Else
             If [M:PKP2]QTYPCU(I) = 0
                Dela I,1 [M:PKP2]NBLIG
                I             -= 1
                If [M:PKP2]NBLIG > 0             # hcb 55930
                   [M:PKP2]NBLIG -= 1            # hcb 55930
                Else                             # hcb 55930
                   Break                         # hcb 55930
                Endif                            # hcb 55930
             Endif
          Endif
      Next I
   Endif

# affichage poids total
   If [M:PKP2]NBLIG = WNBLIG & [M:PKP2]QTYPCU(WNBLIG) <> 0
      [M:PKP2]NBLIG +=1
   Endif

Endif
If GORI_PKP =  "PKP2"
   Gosub TOT_GROCAP      # hcb 55930
   Affzo [M:PKP2]
   If dim([M:PKP2]LOT)>0
      Affzo [M:PKP2]LOT
   Endif
# etiquette deja renseigne on ne modifié
   If [M:PKP2]LBLFMT  <> ""
      Diszo [M:PKP2]LBLFMT
   Endif
   If [M:PKP2]PCK     <> ""
      Diszo [M:PKP2]PCK
   Endif

   Gosub GESSELECTION

   If dim([M:PKP2]LOT)>0
      Diszo [M:PKP2]LOT
   Endif
   If dim([M:PKP2]SLO)>0
      Diszo [M:PKP2]SLO
   Endif
   If dim([M:PKP2]SERNUM)>0
      Diszo [M:PKP2]SERNUM
   Endif
Endif

If GCONSULT = 2 | [M:PKP2]MODIF <> 2
#   Grizo [M:PKP2]                        # hcb 110327-pck
   Diszo [M:PKP2]                         # hcb 110327-pck
Endif
Return


#                                                                                         # hcb 55930 2 deb
#########################################################################
# VERIF_COLISAUTO  recherche si enregistrement deja colisé
#                  dans le cadre d un colisage automatique par capacité
#########################################################################
$VERIF_COLISAUTO
Raz WCOLIAUTO_OK
Case  WCOLIAUTO_ORI
      When "STJ" :
           WLOT       = [F:STJ]LOT
           WSLO       = [F:STJ]SLO
           WSER       = [F:STJ]SERNUM
           WPAL       = [F:STJ]PALNUM
           WCTR       = [F:STJ]CTRNUM
           WPCU       = [F:STJ]PCU
           WPCUSTUCOE = [F:STJ]PCUSTUCOE

      When "STO" :
           WLOT       = [F:STO]LOT
           WSLO       = [F:STO]SLO
           WSER       = [F:STO]SERNUM
           WPAL       = [F:STO]PALNUM
           WCTR       = [F:STO]CTRNUM
           WPCU       = [F:STO]PCU
           WPCUSTUCOE = [F:STO]PCUSTUCOE

      When "STA" :
           WLOT       = [F:STA]LOT
           WSLO       = [F:STA]SLO
           WSER       = [F:STA]SERNUM
           WPAL       = ""
           WCTR       = ""
           WPCU       = [M:PKP1]SAU(GLIG_PKP1)
           WPCUSTUCOE = 1

Endcase

Filter [SPD] Where STOFCY = [M:PKP1]STOFCY & VCRTYP = GVCRTYP & VCRNUM = [M:PKP1]VCRNUM & VCRLIN = [M:PKP1]VCRLIN(GLIG_PKP1)
&                & LOT    = WLOT & SLO    = WSLO & SERNUM    = WSER & PALNUM = WPAL
&                & CTRNUM = WCTR & PCU    = WPCU & PCUSTUCOE = WPCUSTUCOE
&            Order By Key CLE = LOT;SLO;SERNUM;PALNUM;CTRNUM;PCU;PCUSTUCOE
        For [SPD]
             WCOLIAUTO_OK = 1
             Break
        Next
Filter [SPD]

Raz WLOT
Raz WSLO
Raz WSER
Raz WPAL
Raz WCTR
Raz WPCU
Raz WPCUSTUCOE

Return
#                                                                                         # hcb 55930 2 fin

#########################################################################
# FORMAT_PAC_PKP2               Desactivation rubrique suivant contexte
#########################################################################
$FORMAT_PAC_PKP2

GWSINVLOT   = GSINVLOT
GWSINTLOT   = GSINTLOT
GWSINVSLO   = GSINVSLO
GWSINTSLO   = GSINTSLO
GWSINVSER   = GSINVSER
GWSINTSER   = GSINTSER

If [F:ITM]LOTMGTCOD = 1
   GWSINVLOT   = "-"+GSINVLOT
   GWSINVSLO   = "-"+GSINVSLO
   GWSINTLOT   = ""
   GWSINTSLO   = ""
Else
   GWSINVLOT   = GSINVLOT
   GWSINTLOT   = GSINTLOT
Endif

If [F:ITM]LOTMGTCOD = 4
   GWSINVSLO   = GSINVSLO
   GWSINTSLO   = GSINTSLO
Else
   GWSINVSLO   = "-"+GSINVSLO
   GWSINTSLO   = ""
Endif
If [F:ITM]SERMGTCOD<3
   GWSINVSER = "-"+GSINVSER
   GWSINTSER = ""
Else
   GWSINVSER = GSINVSER
   GWSINTSER = GSINTSER
Endif
Return


###############################################################################
# GESSELECTION : Met à jour et affichage  champ PECQTY
###############################################################################
$GESSELECTION

[M:PKP2]PECQTY = sum([M]QTYSTU(0..max([M]NBLIG-1,nolign-1)))
Affzo [M:PKP2]PECQTY

Return

#                                                                                                  # hcb 110327-pck deb
###############################################################################
# DETAIL_SERIE  Calcul SERNUM et SERFIN
#               ce composant est appelé à l enregistrement de l écran PKP1
#               la capacité a ete faite il faut initialiser les series
#               uniquement dans le cas ou aucun colis n a déja ete fait (IDETAIL = 3)
###############################################################################
$DETAIL_SERIE

If [M:PKP2]QTY       (I) = 0
   Raz [M:PKP2]SERNUM(I)
   Raz [M:PKP2]SERFIN(I)
   Return
Endif

Case GORI_PKP
     When "PKP1"
           If !find([M:PKP1]IDETAIL(GLIG_PKP1),3,4)
              Return
          Endif
     When "PKP2"
           If [M:PKP1]IDETAIL(GLIG_PKP1) <> 4
              Return
          Endif
     When Default
Endcase
#      si la quantité traitée et differente de la quantité à coliser : recalcul du no serie fin
If  [M:PKP2]QTYINI    (I) <> [M:PKP2]QTY      (I)
    If [M:PKP2]WSERIE    = ""
       [M:PKP2]WSERIE    = [M:PKP2]SERORIDEB  (I)
    Endif
    WSERNUM              = [M:PKP2]WSERIE
    [M:PKP2]SERNUM   (I) = [M:PKP2]WSERIE
    Call PLUS_NB(WSERNUM,abs([M:PKP2]QTY (I)),WSERNUMF,LRET) From STKLIB
    [M:PKP2]SERFIN   (I) = WSERNUMF
    [M:PKP2]WSERIE       = WSERNUMF
    Call PLUS_UN([M:PKP2]WSERIE,[M:PKP2]WSERIE,LRET) From STKLIB
Else
    [M:PKP2]SERNUM   (I) = [M:PKP2]SERORIDEB  (I)
    [M:PKP2]SERFIN   (I) = [M:PKP2]SERORIFIN  (I)
Endif
Raz [M:PKP2]SERCOLDEB(I)
Raz [M:PKP2]SERCOLFIN(I)
If [M:PKP2]SERNUM    (I) = ""
   [M:PKP2]MODFLG    (I) = 0
Endif
Return
#                                                                                                  # hcb 110327-pck fin


###############################################################################
# ACTION Rubriques ecrab PKP2
###############################################################################
Subprog APRES_NBLIG

Gosub GESSELECTION

End


Subprog C_NBLIG
Local Integer I

# annulation d une ligne
If status=65
   [M:PKP2]NETWEI (nolign-1) = 0
   [M:PKP2]QTY    (nolign-1) = 0
   [M:PKP2]QTYSTU (nolign-1) = 0
   [M:PKP2]MODFLG (nolign-1) = 2
   Gosub GESSELECTION
Endif

# annulation d'un groupe de lignes
If find(status,68,83)
   For I=nolign-1 To nolign1-1
      [M:PKP2]NETWEI (nolign-1) = 0
      [M:PKP2]QTY    (nolign-1) = 0
      [M:PKP2]QTYSTU (nolign-1) = 0
      [M:PKP2]MODFLG (nolign-1) = 2
   Next
   Gosub GESSELECTION
Endif

End


Subprog C_QTY(VALEUR)
Variable Decimal VALEUR
If VALEUR  > [M:PKP2]QTYPCU(nolign-1)
   mkstat = 2
   End
Endif

Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
Local Char     WSERNUM (GLONSER)                           # hcb 110327-pck
Local Char     WSERNUMF(GLONSER)                           # hcb 110327-pck
Local Integer  LRET                                        # hcb 110327-pck
[M:PKP2]MODFLG(nolign-1) = 2
[M:PKP2]QTYSTU(nolign-1) = VALEUR * [M:PKP2]PCUSTUCOE(nolign-1)
Call QTEARR([M:PKP2]QTYSTU(nolign-1), [M:PKP1]STU(GLIG_PKP1)) From TRTDIV           # hcb 54897
Affzo [M:PKP2]QTYSTU(nolign-1)
If VALEUR = 0
   Diszo [M:PKP2]NETWEI(nolign-1)
Else
   Actzo [M:PKP2]NETWEI(nolign-1)
Endif

[M:PKP2]NETWEI(nolign-1) = [M:PKP2]QTYSTU(nolign-1)  *  [M:PKP1]UNTWEI   (GLIG_PKP1) # hcb 54897
[M:PKP2]NETWEIPCK (nolign-1) = [M:PKP2]NETWEI   (nolign-1) * [M:PKP2]LIGUNTWEI(nolign-1)
Affzo [M:PKP2]NETWEI(nolign-1)
Gosub CAL_NETWEI From TRTPKP2

                                                                              # hcb 110327-pck deb
#      si géré en serie global et colisage détail serie à oui
#         si la quantité traitée et = à le qte initiale  recperation des n° series
#         si la quantité traitée saisie soit inférieure à la quantité traitée initiale
#            et que le no serie debut = no serie debut de la ligne de document origine : recalcul du no serie fin
 If [M:PKP2]SERMGTCOD = 4 & [M:PKP2]PCKSERFLG  = 2
    If VALEUR <> [M:PKP2]QTY (nolign-1)
       If VALEUR =  [M:PKP2]QTYINI (nolign-1)
          If [M:PKP2]PACNUM <> ""
             [M:PKP2]SERNUM(nolign-1) = [M:PKP2]SERCOLDEB(nolign-1)
             [M:PKP2]SERFIN(nolign-1) = [M:PKP2]SERCOLFIN(nolign-1)
          Else
             [M:PKP2]SERNUM(nolign-1) = [M:PKP2]SERORIDEB(nolign-1)
             [M:PKP2]SERFIN(nolign-1) = [M:PKP2]SERORIFIN(nolign-1)
          Endif
          Affzo [M:PKP2]SERNUM(nolign-1)
          Affzo [M:PKP2]SERFIN(nolign-1)
       Else
          If VALEUR < [M:PKP2]QTY (nolign-1) &  [M:PKP2]SERNUM (nolign-1) = [M:PKP2]SERORIDEB (nolign-1)
             WSERNUM = [M:PKP2]SERNUM (nolign-1)
             Call PLUS_NB(WSERNUM,abs(VALEUR),WSERNUMF,LRET) From STKLIB
             [M:PKP2]SERFIN(nolign-1) = WSERNUMF
             Affzo [M:PKP2]SERFIN(nolign-1)
          Else
             Raz   [M:PKP2]SERNUM(nolign-1)
             Raz   [M:PKP2]SERFIN(nolign-1)
             Affzo [M:PKP2]SERNUM(nolign-1)
             Affzo [M:PKP2]SERFIN(nolign-1)
          Endif
       Endif
    Endif
Endif
#                                                                              # hcb 110327-pck fin

End

Subprog AM_NETWEI(VALEUR)
Variable Decimal VALEUR
[M:PKP2]MODFLG(nolign-1) = 2
[M:PKP2]NETWEIPCK (nolign-1) = VALEUR * [M:PKP2]LIGUNTWEI(nolign-1)
[M:PKP2]NETWEI(nolign-1)     = VALEUR
Gosub CAL_NETWEI From TRTPKP2

End

#---------------------------------------------------
# Avant zone : Colorisation des lignes non colisées
#---------------------------------------------------
$PKP2COLOR

pcolor = GCOUL(0)
If [M:PKP1]PACQTYSTU(GLIG_PKP1) = 0
    pcolor = GCOUL(1)
Endif
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran WT11CH22) 08/09/2006 15:58:11 (HCB)
######################################################################################
Subprog C_PACNUM(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_PACNUM(VALEUR)
Variable Char    VALEUR()
End


Subprog AM_PCK(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""  &  [F:TPA]PCK <> VALEUR
   Read [TPA]TPA0=VALEUR
   If fstat
      Raz [F:TPA]
   Endif
Endif
[M:PKP2]       = [F:TPA]
If GVCRTYP = 4 & [F:TPA]LBLFMT = ""
   [M:PKP2]LBLFMT = GDOCNAM
Endif

[M:PKP2]GROWEU = [M:PKP2]WEU

# recalcul du poids des lignes
If [M:PKP2]NBLIG <> 0
   Gosub CAL_NETWEI From TRTPKP2
Endif


Affzo [M:PKP2]10
Affzo [M:PKP2]LBLFMT
Affzo [M:PKP2]GROWEU

End

Subprog AS_NETWEI(VALEUR)
Variable Decimal VALEUR
# si pas UP pas de saisie
If [M:PKP2]LIGWEU (nolign-1) = ""
   mkstat = 2
   End
Endif

End

###########################################################
# calcul poids d une ligne
###########################################################

$CAL_NETWEI
If [M:PKP2]PCK = ""
   Return
Endif
Raz [M:PKP2]GROWEI
For I = 0 To [M:PKP2]NBLIG-1
    If [M:PKP2]LIGWEU(I) <> [F:TPA]WEU
       # Conversion poids unitaire de unité poids liv en unité poids colis
        [M:PKP2]LIGUNTWEI(I) = 1
        Call SCONV_TCO([M:PKP2]LIGWEU(I),[F:TPA]WEU,[M:PKP2]LIGUNTWEI(I)) From TRTVENQTE
    Endif
    [M:PKP2]NETWEIPCK(I)  = [M:PKP2]NETWEI(I) * [M:PKP2]LIGUNTWEI(I)
    [M:PKP2]GROWEI       += [M:PKP2]NETWEIPCK (I)
Next

[M:PKP2]GROWEI       += [M:PKP2]PCKWEI
Affzo [M:PKP2]GROWEI

Gosub TOT_GROCAP # hcb 55930

Return

#                          # hcb 55930 deb
###########################################################
# calcul capacité emballage du colis
###########################################################

$TOT_GROCAP

Raz [M:PKP2]GROCAP

If [M:PKP2]PCKCAP <> 0
   [M:PKP2]GROCAP  = sum([M:PKP2]QTYSTU(0..max([M:PKP2]NBLIG-1,nolign-1)))
Endif
Affzo [M:PKP2]GROCAP

Return

#                          # hcb 55930 fin



#                                                                     # hcb 110327-pck deb
Subprog IB_NBLIG
# No série à coliser
GBOUT1 = mess(663,199,1)

# l article ne gère pas les séries "globale"  pas de saisie des numéros de séries
If [M:PKP2]PCKSERFLG  <> 2 | [M:PKP2]QTY(nolign-1) = 0
   GBOUT1 = ""
Endif
End
#                                                                     # hcb 110327-pck deb

