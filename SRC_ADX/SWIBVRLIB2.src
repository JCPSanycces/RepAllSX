#*****************************************************************************************************
#                         Sous-Programmes utilisés
#*****************************************************************************************************


#----------------------------------------------------------------------------
# Recherche d'un nouveau numéro de compteur pour constituer le nom du fichier
#----------------------------------------------------------------------------

$CALCUL_COMPTEUR_
    Local Char VALEUR(30)
    Local Integer STAT
    Call NUMERO("SWIDT","",datesyst,"",VALEUR,STAT) From SUBANM
    If STAT <> 0
       Errbox(mess(270,133,1)) # "No sequence number code found"
       COMPTEUR_ = "bank"
    Else
       COMPTEUR_ = VALEUR
    Endif
Return

#--------------------------------------------------------
# Mise à jour de la table des bordereaux de remise PAYFRM
#--------------------------------------------------------

$MAJ_PAYFRM2
    If !clalev([F:XFRM]) : Local File PAYFRM [XFRM]      : Endif
    Read [F:XFRM]FRM0 =[F:FRM]FRMFLG;[F:FRM]FRMNUM
    If fstat = 0
       Trbegin [XFRM]
       [XFRM]TFBDAT = date$
       [XFRM]TFBFIL = TFBFIL_
       # mise à jour du flag permettant de savoir que le fichier DTA a été créé
       [XFRM]STA = max(6,[XFRM]STA)     : # don't reduce STA if already greater than 6
       Rewrite [XFRM]
       If fstat = 0
          Commit
       Else
          Rollback
       Endif
    Endif
    Close File [XFRM]
Return

#------------------------------------------------
# Mise à jour de la table des règlements PAYMENTH
#------------------------------------------------

$MAJ_PAYMENTH
     Filter [ZPYH] Where FRMNUM = [M:FRM0]FRMNUM
     For [ZPYH]
         Trbegin [ZPYH]
         [ZPYH]TFBDAT = date$
         [ZPYH]TFBFIL = TFBFIL_
         [ZPYH]STAFLG(5) = 2            # mise à jour du flag permettant de savoir que le fichier DTA a été créé
                                        # mise à jour prochaine opération : mise en banque
         [ZPYH]STA = max(6,[ZPYH]STA)   # don't reduce STA if already greater than 6
         Rewrite [ZPYH]
         If fstat = 0
            Commit
         Else
            Rollback
         Endif
    Next
    Filter [ZPYH]
Return

#-----------------------------------------------------------------------------------------------------
# Recherche du clearing bancaire
#
# Paramètres: CB: N° de clearing bancaire
#             KO: Gestion des erreurs
#-----------------------------------------------------------------------------------------------------
Subprog RECHCB(CB, KO)
Variable Char CB
Variable Integer KO
Local Integer I

Read [F:XBID]BID0 = 1;[F:ZPYH]BPR;[ZPYH]BID
If fstat = 0
    NUMCLEAR = func SWILIB0.STRIP_ZEROS(left$([F:XBID]BIDNUM,5)) # delete leading zeros from clearing number

    If (NUMCLEAR = "199" or NUMCLEAR = "9000")
        #C'est un paiement postal on met à blanc
        CB = space$(12)
    Else
        CB = format$("K<:12X",NUMCLEAR)
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
    KO = 1
Endif
End
#-----------------------------------------------------------------------------------------------------


$INIT_IBACOD
  IBACOD = ""
  If [XBID]IBAN <> ""                    # IBAN prefix is stored in database?
     IBACOD = [XBID]IBAN + [XBID]BIDNUM  # build IBACOD from IBAN prefix and BIDNUM (including clearing and account)
  Endif
Return
#-----------------------------------------------------------------------------------------------------


