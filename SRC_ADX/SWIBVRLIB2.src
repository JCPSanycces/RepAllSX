#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################################################################
# Project       : Swiss Localization
# File          : SWIBVRLIB2
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 23.04.15
######################################################################################################
# Module        : ACCOUNTING
# Description   : - Suppliers invoices (DTA) bank file generation
######################################################################################################
 # Updates :
 # Date       |Author|Version|Description
 # 2015-06-29 |Bader |U9     |don't use [F:ZPYH]BPANAM instead of [F:XBPA]BPADES in segment 2
 # 2015-08-04 |Bader |U9     |handle AMTCUR with more than 1 digits after decimal point correctly
 # 2016-02-19 |DNE   |U10    |Bugfixing (SAM #114567)
######################################################################################################


#*****************************************************************************************************
#$DTA: action de génération du fichier DTA
#*****************************************************************************************************
Subprog DTA()
    Local Integer REP
    Qstbox mess(22,3648,1)-chr$(13)+chr$(10)+mess(205,100,1) Titled mess(23,3648,1) Using [L]REP
    Case [L]REP
    When 1 :

        TFBFIL_ = [FRM]TFBFIL
        If TFBFIL_ <> ""
            Qstbox mess(260,107,1) + " " + TFBFIL_ + " ?" Using [L]REP  # Data already exists.\Do you want to overwrite it?
            Case [L]REP
                When 1 : Call REGDTA()
            Endcase
        Else
            Call REGDTA()
        Endif
   Endcase
End
#*****************************************************************************************************

#-----------------------------------------------------------------------------------------------------
#$REGDTA: Création du fichier DTA
#-----------------------------------------------------------------------------------------------------
Subprog REGDTA()
Local Char XSLEG(GLONADI)

#---- Déclaration des variables ----#
Gosub DECLARATION_

OK_=0

TFBFIL_ = [FRM]TFBFIL

If TFBFIL_ = "" Gosub CALCUL_COMPTEUR_ Endif

#---- Ouverture des fichiers ----#
Gosub OUVRE_
If OK_=0
    Raz [L]XSLEG
    Call GET_LEG([M:FRM0]CPY,[L]XSLEG) From SWILIB0

    #---- Filtre de la table des paiements correspondant au bordereau de remise ----#
    Filter [ZPYH] Where FRMNUM = [M:FRM0]FRMNUM
    For [ZPYH]
        #---- Test si le fichier est de type DTA ----#
        Call LEC_TPY_LEG([L]XSLEG,[M:FRM0]PAYTYP) From CPTLEC    # read payment entry type
        If fstat=0
          If [F:TPY]SWIPAYTYP = 2                   # DTA payment
            Read [XTAM]TAM0 = [F:ZPYH]PAM;[L]XSLEG
# 2016-02-19 DNE INSERT BEGIN (SAM #114567)
            If fstat
                # Let's give a 2nd try for "All legislations".
                Read [XTAM]TAM0 = [F:ZPYH]PAM;""
            Endif
# 2016-02-19 DNE INSERT END
            If fstat = 0
                TRS_ = [XTAM]TYP
                #---- Création du header -----#
                #---- test du type de pmt ----#
                Case TRS_
                    When 826 :
                        Gosub TRF_HEADER
                        If OK_<>0 : Break : Endif
                        Gosub ECR_GT8271
                        Gosub CREER_GT8262
                        Gosub CREER_GT8263
                    When 827 :
                        Gosub TRF_HEADER
                        If OK_<>0 : Break : Endif
                        Gosub ECR_GT8271
                        Gosub CREER_GT8272
                        Gosub CREER_GT8273
                        Gosub CREER_GT8274
                    When 830 :
                        Gosub TRF_HEADER
                        If OK_<>0 : Break : Endif
                        Gosub ECR_GT8271
                        Gosub CREER_GT8302
                        Gosub CREER_GT8303
                        Gosub CREER_GT8304
                        Gosub CREER_GT8305
                        Gosub CREER_GT8306
                    When 836 :
                        Gosub TRF_HEADER
                        If OK_<>0 : Break : Endif
                        Gosub ECR_GT8271
                        Gosub CREER_GT8362
                        Gosub CREER_GT8363
                        Gosub CREER_GT8364
                        Gosub CREER_GT8365
                    When 837 :
                        Gosub TRF_HEADER
                        If OK_<>0 : Break : Endif
                        Gosub ECR_GT8271
                        Gosub CREER_GT8372
                        Gosub CREER_GT8373
                        Gosub CREER_GT8374
                        Gosub CREER_GT8375
                        Gosub CREER_GT8376
                        Gosub CREER_GT8377
                Endcase
            Endif
          Endif
        Else
           Infbox(func AFNC.MES1( mess(17,3648,1), [M:FRM0]PAYTYP)) # Error reading transaction $1$.
        Endif
    Next
    Filter [ZPYH]
Endif
If OK_=0
      DERNIER_ENREG = 1
      TRS_ = 890
      Gosub TRF_HEADER
      Gosub ECR_GT8901
Endif

If GERRTRACE = 0
    Gosub MAJ_PAYFRM2
    Gosub MAJ_PAYMENTH
    Infbox func AFNC.MES1( mess(55,149,1),FICHIER)  # The $1$ file has been sucessfully created
    #Infbox "Votre fichier " + FICHIER + " a été généré"
Else
    Errbox func AFNC.MES1( mess(46,3648,1),"DTA") Titled mess(324,117,1) # The $1$ file is incorrect. Please correct the error and create the file again!
    #Errbox "Le fichier DTA n'est pas bon. Veuillez corriger les erreurs puis regénérez votre fichier DTA !" Titled "Des erreurs se sont produites.
Endif
Gosub FERME_
End
#-----------------------------------------------------------------------------------------------------

#.....................................................................................................
#$DECLARATION: Déclaration des variables de travail
#.....................................................................................................
$DECLARATION_
# structure enreg 1 pour GT827
    #---- Structure du Header ----#
    Local     Char        GT8271_1(2)                    #Ségment ("01")
    Local     Char        GT8271_2(6)                    #Date de traitement désirée (AAMMJJ) pour GT 826, 827 sinon 0
    Local     Char        GT8271_3(12)                   #No CB de la banque du bénéficiaire. Aligné à gauche compléter avec des blancs
    Local     Char        GT8271_4(5)                    #No de séquence de sortie (interne à la banque) "00000"
    Local     Char        GT8271_5(6)                    #Date de création (AAMMJJ)
    Local     Char        GT8271_6(7)                    #No CB de la banque du donneur d'ordre. Aligné à gauche compléter avec des blancs
    Local     Char        GT8271_7(5)                    #Identificateur de l'expéditeur de fichier de données
    Local     Char        GT8271_8(5)                    #No de séquence d'entrée. De 00001 à XXXXX avec numérotation continue de 1 en 1
    Local     Char        GT8271_9(3)                    #Genre de transaction de l'enregistrement (826, 827, 830, 832, 836)
    Local     Char        GT8271_10(1)                   #Type de paiement. Pour pmt de salaires et rentes mettre 1 dans GT 827, 836 et 837. Sinon 0
    Local     Char        GT8271_11(1)                   #Flag de traitement. (interne à la banque) remplir avec 0
    #---- Total header 51 + 2 ségment=53

    #---- Ségment 1 GT 826, 827, 830 et 836 ----#
    Local     Char        GT8271_12(16)                  #N° de référence 5 premiers= Id donneur d'ordre, 11 suivants=N°trs donneur d'ordre (unique dans le fichier)
    Local     Char        GT8271_13(34)                  #Compte à débiter
    Local     Char        GT8271_14(24)                  #Montant de bonification 6 blanc, 3 code monnaie ISO, 12x montant
    Local     Char        GT8271_15(14)                  #Réserve

    #---- Ségment 3 GT826 ----#
    Local     Char        GT8263_3(12)                   #N° d'adhérent du bénéficiaire
    Local     Char        GT8263_5(27)                   #N° de référence BVR
    Local     Char        GT8263_6(2)                    #Clé de contrôle BVR. Uniquement adh 5 position

    Local     Char        GT8273_3(27)
    Local     Char        GT8273_4(24)
    Local     Char        GT8273_5(24)
    Local     Char        GT8273_6(24)
    Local     Char        GT8273_7(24)
    Local     Char        GT8303_4(21)
    Local     Char        GT8303_5(24)
    Local     Char        GT8303_6(24)
    Local     Char        GT8303_7(24)
    Local     Char        GT8303_8(24)
    Local     Char        GT8305_1(30)
    Local     Char        GT8305_2(30)
    Local     Char        GT8305_3(30)

    Local     Char        GT8363_3(35)
    Local     Char        GT8363_4(35)
    Local     Char        GT8363_5(34)
    Local     Char        GT8365_3(35)
    Local     Char        GT8365_4(35)
    Local     Char        GT8365_5(35)



    # Variable de travail
    Local     Char        BVRREFLINE_(100)
    Local     Integer     COMPTEUR
    Local     Char        COMPTEUR_(10)
    Local     Decimal     MONTANT_
    Local     Decimal     TOTAL_
    Local     Integer     POS
    Local     Integer     DERNIER_ENREG
    Local     Integer     ERREUR
    Local     Char        COD(3)
    Local     Char        FRAIS(10)
    Local     Char        COURS(12)
    Local     Char        NUMCLEAR(30)
    Local     Char        IBACOD(35)

    Local     Integer     TYP
    Local     Integer     OK_
    Local     Integer     TRS_
    COMPTEUR = 0
    TOTAL = 0
    DERNIER_ENREG = 0
    ERREUR = 0
    Local     Char        CHAINE(100), CHAINE1(100), CHAINE2(100), FICHIER(100)
    Local     Char        TFBFIL_(50), TFBFIL2_(50)
    Local     Integer     SPACE_MONTANT
    Local Char    SAVIFS(5) , SAVIRS(5)
    Local Char    SAVSCA(10)

    Local Char    BPANAM_(GLONNAM)

Return
#.....................................................................................................

#.....................................................................................................
#$OUVRE: Ouverture des tables de travail
#.....................................................................................................
$OUVRE_
    Call OUVRE_TRACE(mess(29,160,1)) From LECFIC
    If !clalev([F:XBID]) : Local File BID [XBID]       : Endif
    If !clalev([F:ZPYH]) : Local File PAYMENTH [ZPYH]  : Endif
    If !clalev([F:XPYD]) : Local File PAYMENTD [XPYD]  : Endif
    If !clalev([F:XBAN]) : Local File BANK[XBAN]       : Endif
    If !clalev([F:XFCY]) : Local File FACILITY[XFCY]   : Endif
    If !clalev([F:XPIH]) : Local File PINVOICE[XPIH]   : Endif
    If !clalev([F:XBPR]) : Local File BPARTNER[XBPR]   : Endif
    If !clalev([F:XBPA]) : Local File BPADDRESS[XBPA]  : Endif
    If !clalev([F:ZBPA]) : Local File BPADDRESS[ZBPA]  : Endif
    If !clalev([F:XTAM]) : Local File TABPAM[XTAM]     : Endif
    If !clalev([F:XTCU]) : Local File TABCUR[XTCU]     : Endif
    If !clalev([F:TPY])  : Local File TABPAYTYP [TPY]  : Endif

Local Char XFILEXT(GDIMFIC)
XFILEXT = [M:FRM0]BAN
Read [XBAN]BAN0 = [M:FRM0]BAN
If !fstat and [F:XBAN]FILEXT <> ""
    XFILEXT = [F:XBAN]FILEXT
Endif

    If TFBFIL_ = ""
        If GBVRNUMERIC=2
            TFBFIL_ = left$([M:FRM0]PAYTYP, 2) + format$("N0:8", COMPTEUR_) + "." + XFILEXT
            TFBFIL2_ = left$([M:FRM0]PAYTYP, 2) + format$("N0:8", COMPTEUR_)
        Else
            TFBFIL_ = left$([M:FRM0]PAYTYP, 2) + format$("8X", COMPTEUR_) + "." + XFILEXT
            TFBFIL2_ = left$([M:FRM0]PAYTYP, 2) + format$("8X", COMPTEUR_)
        Endif
    Else
        TFBFIL2_ = left$(TFBFIL_, 10)
    Endif
    FICHIER   = filpath("BQE",TFBFIL2_, XFILEXT)
    SAVIFS = adxifs
    SAVIRS = adxirs
    SAVIUM = adxium
    SAVSCA = adxsca
    adxsca = left$(adxsca,3) + "," + right$(adxsca,5)
    adxifs = ''
    adxium=50
    Openo FICHIER,0 Using [FIC]
    #---- Lecture du site ----#
    Read [F:XFCY]FCY0 = [M:FRM0]FRMFCY
    If fstat = 0
        #---- Lecture de l'adresse du site ----#
        Read [F:XBPA]BPA0(3) = 3;[F:XFCY]FCY;[F:XFCY]BPAADD        # recherche de l'adresse du site
        If fstat <> 0 Then
            Call ECR_TRACE(func AFNC.MES1( mess(24,3648,1), [ZPYH]FCY), 1) From GESECRAN # Address for site $1$ not found!
            OK_=2
        Endif
    Else
        Call ECR_TRACE(mess(4,3648,1)+" "+ [F:ZPYH]FCY , 1) From GESECRAN # Error reading the site, site not found!
        OK_=2
    Endif
Return
#.....................................................................................................

#.....................................................................................................
#$FERME: Fermeture des tables de travail
#.....................................................................................................
$FERME_
    If clalev([F:XBID]) : Close Local File [XBID] : Endif
    If clalev([F:ZPYH]) : Close Local File [ZPYH] : Endif
    If clalev([F:XTAM]) : Close Local File [XTAM] : Endif
    If clalev([F:XPYD]) : Close Local File [XPYD] : Endif
    If clalev([F:XBAN]) : Close Local File [XBAN] : Endif
    If clalev([F:XFCY]) : Close Local File [XFCY] : Endif
    If clalev([F:XPIH]) : Close Local File [XPIH] : Endif
    If clalev([F:XBPR]) : Close Local File [XBPR] : Endif
    If clalev([F:XBPA]) : Close Local File [XBPA] : Endif
    If clalev([F:ZBPA]) : Close Local File [ZBPA] : Endif
    If clalev([F:XTCU]) : Close Local File [XTCU] : Endif
    Openo Using [FIC]
    adxifs = SAVIFS
    adxirs = SAVIRS
    adxsca = SAVSCA
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Return
#.....................................................................................................


#******************************************************************************************************
# Enregistrements de type 1
#******************************************************************************************************

#-----------------------------------------------------------------------------------------------------
# Header: Enregistrement commun à tous les types de paiement
#-----------------------------------------------------------------------------------------------------
$TRF_HEADER

COMPTEUR += 1

#---- Segment ----#
GT8271_1="01"

#---- Date d'exécution ----#
If [M:FRM0]EXEDAT<>[0/0/0]
    If ([M:FRM0]EXEDAT-date$)>= -10 and ([M:FRM0]EXEDAT-date$)<= 60
        #La date est correcte, on stock la date pour la GT826 GT827 ou 0 sinon
        Case TRS_
            When 826, 827
                GT8271_2 = format$("D:YYMMDD",[M:FRM0]EXEDAT)
            When Default
                GT8271_2 = "000000"
        Endcase
    Else
        #La date est incorrecte
        Call ECR_TRACE(mess(25,3648,1)+"\"+mess(26,3648,1),1) From GESECRAN # The execution date may be less than 10 days in the past or 60 days in the future!
        OK_=2
    Endif
Else
    #la date d'exécution est vide
    Call ECR_TRACE(mess(27,3648,1),1) From GESECRAN # The execution date is empty. Please add the date and repeat the file creation!
    OK_=2
Endif

#---- N°CB de la banque du destinataire. Seulement pour paiement de type 827, sinon 0 ----#
GT8271_3 = ""

If TRS_ = 827 Then
    #---- lecture du paiement pour trouver la facture ratachée ----#
    Read [F:XPYD]PYD0 = [ZPYH]NUM
    If fstat = 0 Then
        #---- Vérification si le pmt concerne une facture ----#
        If func SWILIB0.IS_SUPPLIER_INVOICE([F:XPYD]VCRTYP) and [F:XPYD]VCRNUM<>""
            Read [F:XPIH]PIH0 = [XPYD]VCRNUM         # lecture la facture PINVOICE
            If fstat = 0 Then
                BVRREFLINE_ = [F:XPIH]BVRREFLINE              # recherche du champ BVRREFLINE
                CHAINE = BVRREFLINE_
                If CHAINE<>"" Then
                    If mid$(CHAINE, 28, 2) = "+ " and right$(CHAINE,39)=">"   # recherche des bouts de chaînes
                        GT8271_3 = mid$(CHAINE, 30, 9)
                    Elsif len(CHAINE)=10 and right$(CHAINE, 10) = ">"
                        GT8271_3 = space$(12)
                    Else                 # message d'erreur si les bouts de chaînes ne correspondent pas
                        Call ECR_TRACE(func AFNC.MES1( mess(49,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # The structure of the ISR reference line does not correspond to 27 +9> or 9> for invoice $1$.
                        ERREUR = 1
                    Endif
                Else  #La chaîne est vide, on lit le BID pour retrouver le numéro de clearing
                    Call RECHCB(GT8271_3, ERREUR)
                Endif
            Else
                Call ECR_TRACE(func AFNC.MES1( mess(29,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # Error reading the invoice $1$.
                ERREUR = 1
            Endif
        Else
            #---- On est dans un accompte, une note de frais,etc. donc on lit le RIB pour trouver le clearing ----#
            Call RECHCB(GT8271_3,ERREUR)
        Endif
    Else
        Call ECR_TRACE(func AFNC.MES1( mess(30,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the payment details $1$.
        ERREUR = 1
    Endif
Else
    #Autres type de transaction des blancs
    GT8271_3=space$(12)
Endif

#---- N° séquence de sortie ----#
GT8271_4 = "00000"

#---- Date de création du fichier ----#
GT8271_5 = format$("D:YYMMDD",date$)

#---- N° CB et id fichier DTA ----#
GT8271_6 = ""
GT8271_7 = ""
#---- Lecture de la banque ----#
Read [F:XBAN]BAN0 = [ZPYH]BAN
If fstat = 0 Then
    If TRS_ = 890 Then
        GT8271_6 = space$(7)
    Else
        GT8271_6 = format$("K:7X", func SWILIB0.STRIP_ZEROS(left$([XBAN]BIDNUM,5)))
    Endif
    GT8271_7 = format$("K:5X", [XBAN]SENNUM)
Else
    Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [ZPYH]NUM),1) From GESECRAN
    ERREUR = 1
    OK_=2
Endif

#---- N°séquence d'entrée ----#
GT8271_8 = format$("N0:5", COMPTEUR)

#---- Genre de transaction -----#
GT8271_9 = format$("N:3",TRS_)

#---- Type de paiement ----#
If [ZPYH]SWISUP2 = 2 & (TRS_=827 | TRS_=836 | TRS_=837)  Then GT8271_10 = "1" Else GT8271_10 = "0" Endif  # Salary

#---- Flag de traitement ----#
GT8271_11 = "0"

#----- N° de référence 5 premiers= Id donneur d'ordre, 11 suivants=N°trs donneur d'ordre (unique dans le fichier) ----#
GT8271_12=GT8271_7
POS = len([ZPYH]NUM) - 11
If POS>0 Then
    GT8271_12 += right$([ZPYH]NUM, POS+1)
Else
    GT8271_12 += format$("K:11X", [ZPYH]NUM)
Endif

#---- Compte à débiter ----#
If [XBAN]IBACOD <> "" Then          # IBAN exists -> write IBAN
    If TRS_ = 837
       GT8271_13 = format$("K:34X", [XBAN]IBACOD)   # 837: length 34
    Else
       GT8271_13 = format$("K:24X", [XBAN]IBACOD)   # else: length 24
    Endif
Else                           # IBAN doesn't exist -> write account, but only for a Swiss or Liechtenstein bank
    If [XBAN]CRY = "CH" or [XBAN]CRY = "LI"                # Switzerland or Liechtenstein
       If [XBAN]BIDNUM<>""
          If TRS_ = 837
             GT8271_13 = format$("K:34X", func SWILIB0.STRIP_ZEROS(right$([XBAN]BIDNUM,6)))   # 837: length 34
          Else
             GT8271_13 = format$("K:24X", func SWILIB0.STRIP_ZEROS(right$([XBAN]BIDNUM,6)))   # else: length 24
          Endif
       Else
          OK_=2
       Endif
    Else
       OK_=2
    Endif
    If OK_ = 2
       Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [ZPYH]NUM),1) From GESECRAN # Error reading the bank ID for the payment $1$.
       ERREUR=1
    Endif
Endif
#---- Montant à débiter ----#
If DERNIER_ENREG <> 1
    TOTAL_ = TOTAL_ + [ZPYH]AMTCUR        # cumul du montant, sert pour le dernier enregistrement
Endif

Case TRS_

    When 826, 827 :
        #Montant de bonification 6 blanc, 3 code monnaie ISO, 12x montant
        If int([ZPYH]AMTCUR) - [ZPYH]AMTCUR<>0 Then
            If int(10*[ZPYH]AMTCUR) - (10*[ZPYH]AMTCUR) <> 0 Then
                SPACE_MONTANT= 12-len(format$("Nv0:9.2", [ZPYH]AMTCUR)) # more than 1 digit after decimal point -> use formatted string for length calculation
            Else
                SPACE_MONTANT= 11-len(num$([ZPYH]AMTCUR))
            Endif
        Else
            SPACE_MONTANT= 9-len(num$([ZPYH]AMTCUR))
        Endif
        If TRS_=826
            If [F:ZPYH]CUR="CHF" or [F:ZPYH]CUR="EUR"
                GT8271_14=space$(6)+ format$("K:3X",[F:ZPYH]CUR) +format$("Nv0:9.2", [ZPYH]AMTCUR)+space$(SPACE_MONTANT)
            Else
                Call ECR_TRACE(func AFNC.MES1( mess(31,3648,1), [ZPYH]NUM, "CHF/EUR", "826"),1) From GESECRAN # The currency of the payment $1$ is not correct. $2$ required for type $3$.
                ERREUR=1
            Endif
        Else
            If [F:ZPYH]CUR="CHF"
                GT8271_14=space$(6)+ format$("K:3X",[F:ZPYH]CUR) +format$("Nv0:9.2", [ZPYH]AMTCUR)+space$(SPACE_MONTANT)
            Else
                Call ECR_TRACE(func AFNC.MES1( mess(31,3648,1), [ZPYH]NUM, "CHF", "827"),1) From GESECRAN # The currency of the payment $1$ is not correct. $2$ required for type $3$.
                ERREUR=1
            Endif
        Endif
        #Réserve
        GT8271_15=space$(14)
    When 830, 836 , 837:
        #Montant de bonification 6 date AAMMJJ, 3 code monnaie ISO, 12x montant
        Read [F:XTCU]TCU0 = [ZPYH]CUR
        If fstat = 0
            If int([ZPYH]AMTCUR) - [ZPYH]AMTCUR<>0 Then
                If int(10*[ZPYH]AMTCUR) - (10*[ZPYH]AMTCUR) <> 0 Then
                    SPACE_MONTANT= 15-len(format$("Nv0:12.2", [ZPYH]AMTCUR)) # more than 1 digit after decimal point -> use formatted string for length calculation
                Else
                    SPACE_MONTANT= 14-len(num$([ZPYH]AMTCUR))
                Endif
            Else
                SPACE_MONTANT= 12-len(num$([ZPYH]AMTCUR))
            Endif
            GT8271_14 = format$("D:YYMMDD",[M:FRM0]EXEDAT) + format$("K:3X",[XTCU]ISOCOD) +
&                       format$("Nv0:12.2", [ZPYH]AMTCUR)+space$(SPACE_MONTANT)
        Else
            #Erreur de lecture de la table des devises
            Call ECR_TRACE(mess(81,75,1),1) From GESECRAN # record not found
            ERREUR=1
        Endif
        #Réserve
        If TRS_ = 837
            GT8271_15=space$(1)
        Else
            GT8271_15=space$(11)
        Endif
    When 890 :
        If int(TOTAL_) - TOTAL_ <> 0 Then
            If int(10*TOTAL_) - (10*TOTAL_) Then
                SPACE_MONTANT= 16-len(format$("Nv0:13.2", TOTAL_)) # more than 1 digit after decimal point -> use formatted string for length calculation
            Else
                SPACE_MONTANT = 15 -len(num$(TOTAL_))
            Endif
        Else
            SPACE_MONTANT= 13-len(num$(TOTAL_))
        Endif
        GT8271_12=format$("Nv0:13.2", TOTAL_)+space$(SPACE_MONTANT)
Endcase
Return
#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# Ecriture de la première ligne
#-----------------------------------------------------------------------------------------------------
$ECR_GT8271
Wrseq GT8271_1, GT8271_2, format$("K<:12X",GT8271_3), GT8271_4, GT8271_5, format$("K:7X", GT8271_6),
& format$("K:5X", GT8271_7), GT8271_8, GT8271_9, GT8271_10, GT8271_11, GT8271_12, GT8271_13, GT8271_14,
& GT8271_15, Using [FIC]

If fstat<>0 or ERREUR = 1
    Call ECR_TRACE(GT8271_1+ GT8271_2+ format$("K<:12X",GT8271_3)+ GT8271_4+ GT8271_5+
&    format$("K:7X", GT8271_6)+
& format$("K:5X", GT8271_7)+ GT8271_8+ GT8271_9+ GT8271_10+ GT8271_11+ GT8271_12+ GT8271_13+
&    GT8271_14+ GT8271_15, 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
    ERREUR = 0
Endif
Return
#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# 890 de type 1
#-----------------------------------------------------------------------------------------------------
# Ecriture de l'enregistrement
#-----------------------------------------------------------------------------------------------------
$ECR_GT8901
Wrseq GT8271_1, GT8271_2, format$("K<:12X",GT8271_3), GT8271_4, GT8271_5, format$("K<:7X", GT8271_6),
& format$("K:5X", GT8271_7), GT8271_8, GT8271_9, GT8271_10, GT8271_11, GT8271_12, space$(59), Using [FIC]
If fstat<>0 or ERREUR=1
    Call ECR_TRACE(GT8271_1+ GT8271_2+ format$("K<:12X",GT8271_3)+ GT8271_4+
&    GT8271_5+ format$("K<:7X", GT8271_6)+
& format$("K:5X", GT8271_7)+ GT8271_8+ GT8271_9+ GT8271_10+ GT8271_11+GT8271_12+ space$(59), 0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
    ERREUR=0
Endif
Return
