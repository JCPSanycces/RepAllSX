    Call ECR_TRACE("02"+ format$("K:20X", BPANAM_)+format$("K:20X", [XBPA]BPAADDLIG(0))+
&    format$("K:20X", [XBPA]POSCOD)+format$("K:20X", [XBPA]CTY), space$(46), 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
Endif
