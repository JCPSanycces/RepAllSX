#*****************************************************************************************************
# Enregistrements de type 3
#*****************************************************************************************************

#-----------------------------------------------------------------------------------------------------
# 826 de type 3
#-----------------------------------------------------------------------------------------------------
$CREER_GT8263
GT8263_3 = ""
GT8263_5 = ""
Read [F:XPYD]PYD0 = [ZPYH]NUM                  # recherche PAYMENTD
If fstat = 0 Then
    Read [F:XPIH]PIH0 = [XPYD]VCRNUM           # lecture PINVOICE
    If fstat = 0 Then
        CHAINE = [F:XPIH]BVRREFLINE                # recherche BVRREFLINE
        If CHAINE <> "" Then
            If len(CHAINE) = 53 and mid$(CHAINE,14,1) = ">" and mid$(CHAINE,42,2) = "+ " and right$(CHAINE,53) = ">"
                GT8263_3 = seg$(CHAINE, 44, 52)
                GT8263_5 = seg$(CHAINE, 15, 41)
                GT8263_6 = space$(2)
            Endif

            If len(CHAINE) = 43 and mid$(CHAINE,4,1) = ">" and mid$(CHAINE,32,2) = "+ " and right$(CHAINE,43) = ">"
                GT8263_3 = seg$(CHAINE, 34, 42)
                GT8263_5 = seg$(CHAINE, 5, 31)
                GT8263_6 = space$(2)
            Endif

            If len(CHAINE) = 41 and mid$(CHAINE,1,1)="<" and mid$(CHAINE,17,2) = "> " and mid$(CHAINE,34,2) = "+ " and right$(CHAINE,41)=">"
                GT8263_3 = seg$(CHAINE, 36, 40)
                GT8263_5 = seg$(CHAINE, 19, 33)
                GT8263_6 = seg$(CHAINE, 2,3)
            Endif

            If len(CHAINE) = 23 and mid$(CHAINE,16,2) = "+ " and right$(CHAINE,23) = ">"
                GT8263_3 = seg$(CHAINE, 18, 22)
                GT8263_5 = seg$(CHAINE, 1, 15)
                GT8263_6 = space$(2)
            Endif

            If len(CHAINE) = 6 and right$(CHAINE,6) = ">"
                GT8263_3 = seg$(CHAINE, 1, 5)
                GT8263_5 = ""
                GT8263_6 = space$(2)
            Endif

            If len(CHAINE) = 42 and mid$(CHAINE,14,1) = ">" and mid$(CHAINE,31,2) = "+ " and right$(CHAINE,42) = ">"
                GT8263_3 = seg$(CHAINE, 33, 41)
                GT8263_5 = format$("N0:27",seg$(CHAINE, 15, 30))
                GT8263_6 = space$(2)
            Endif

            If len(CHAINE) = 28 and mid$(CHAINE,17,2) = "+ " and right$(CHAINE,28) = ">"
                GT8263_3 = seg$(CHAINE, 19, 27)
                GT8263_5 = format$("N0:27",seg$(CHAINE, 1, 16))
                GT8263_6 = space$(2)
            Endif

            If len(CHAINE) = 32 and mid$(CHAINE,4,1) = ">" and mid$(CHAINE,21,2) = "+ " and right$(CHAINE,32) = ">"
                GT8263_3 = seg$(CHAINE, 23, 31)
                GT8263_5 = format$("N0:27",seg$(CHAINE, 5, 20))
                GT8263_6 = space$(2)
            Endif
        Else
            #La ligne de codage est vide
            Call ECR_TRACE(func AFNC.MES1( mess(32,3648,1), [XPYD]VCRNUM),1) From GESECRAN # The reference line of the invoice $1$ is empty.
        Endif

        TYP=1
        Read [ZBPA]BPA0= TYP;[F:ZPYH]BPR;[F:XPIH]BPAINV    # Lecture de l'adresse
        If fstat=0
          BPANAM_ = [F:ZPYH]BPANAM                             # 29.09.14 Bader
          If BPANAM_ = "" : BPANAM_ = [F:ZBPA]BPADES : Endif   # 29.09.14 Bader
          Wrseq "03", "/C/", format$("N0:9", GT8263_3), format$("K:20X",BPANAM_), format$("K:20X",[F:ZBPA]BPAADDLIG(0)),
&               format$("K:20X",[F:ZBPA]POSCOD), format$("K:20X",[F:ZBPA]CTY), format$("K:27X",GT8263_5),GT8263_6, space$(5), Using [FIC]
          If fstat<>0
              Call ECR_TRACE("03"+ "/C/"+ format$("K:9X", GT8263_3)+ format$("K:20X",BPANAM_)+ format$("K:20X",[F:ZBPA]BPAADDLIG(0))+
&                  format$("K:20X",[F:ZBPA]POSCOD)+ format$("K:20X",[F:ZBPA]CTY)+ format$("K:27X", GT8263_5)+GT8263_6+space$(5),0) From GESECRAN
              Call ECR_TRACE("", 0) From GESECRAN
          Endif
        Else
            Wrseq "03", "/C/", format$("N0:9", GT8263_3),space$(80), format$("K:27X", GT8263_5),GT8263_6, space$(5), Using [FIC]
            If fstat<>0
               Call ECR_TRACE("03"+ "/C/"+ format$("K:9X", GT8263_3)+ space$(80)+
&                   format$("K:27X", GT8263_5)+GT8263_6+ space$(5), 0) From GESECRAN
               Call ECR_TRACE("", 0) From GESECRAN
            Endif
            Call ECR_TRACE(mess(522,199,1)-[F:XPIH]BPR,0) From GESECRAN # The address code of the pay-by BP does not exist
        Endif
    Else
        Call ECR_TRACE(func AFNC.MES1( mess(29,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # Error reading the invoice $1$.
    Endif
Else
   Call ECR_TRACE(func AFNC.MES1( mess(30,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # Error reading the payment details $1$.
Endif
Return
#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# 827 de type 3
#-----------------------------------------------------------------------------------------------------
$CREER_GT8273
Local Char BANKACCOUNT(11)

GT8273_3 = ""
GT8273_4 = ""
GT8273_5 = ""
GT8273_6 = ""
GT8273_7 = ""

TYP = 1
#---- Lecture du RIB ----#
Read [F:XBID]BID0 = 1;[ZPYH]BPR;[ZPYH]BID
If fstat=0
    # test si on as une ligne de codage BVR
    CHAINE = BVRREFLINE_
    If CHAINE<>"" Then
        BVR=1
        If mid$(CHAINE, 28, 1) = "+"
            GT8273_3 = mid$(CHAINE, 1, 27)
        Else
            If mid$(CHAINE, 10, 1) = ">"
                GT8273_3 = mid$(CHAINE, 1, 9)
            Endif
        Endif
    Else   #Pas de BVR, compte normal
        #---- On contrôle si le pays est bien la Suisse ----#
        If [F:XBID]CRY="CH"
            NUMCLEAR = func SWILIB0.STRIP_ZEROS(left$([F:XBID]BIDNUM,5)) # delete leading zeros from clearing number
            If (NUMCLEAR="199" or NUMCLEAR = "9000") Then                # post finance account
#                BANKACCOUNT = [F:XBID]BVRNUM                             # ISR customer number
#                Call CONT_COMPT(BANKACCOUNT) From SWIBVRLIB3
#                If mkstat<>0
#                    Call ECR_TRACE(func AFNC.MES1( mess(39,3648,1), [F:XBID]BVRNUM),1) From GESECRAN # The structure of the ISR customer number $1$ doesn't belong to a post office account!
#                Endif
#               GT8273_3 = BANKACCOUNT
                GT8273_3 = func SWILIB0.STRIP_ZEROS(right$([F:ZPYH]BID,6))  # get account from BIDNUM and strip leading zeros
            Else
                Gosub INIT_IBACOD
                If IBACOD<>""
                    GT8273_3= IBACOD
                Else
                    GT8273_3 = func SWILIB0.STRIP_ZEROS(right$([F:ZPYH]BID,6))  # get account from BIDNUM and strip leading zeros
                Endif
            Endif
        Else
            #---- Banque destinataire hors de Suisse ----#
            Call ECR_TRACE(func AFNC.MES2( mess(33,3648,1), [F:ZPYH]NUM, "827"),1) From GESECRAN # Payment type $2$: recipient must be located inside of Switzerland or Liechtenstein (payment: $1$)
        Endif
    Endif

    #---- Lecture de l'adresse liée au RIB ----#
    Read [F:ZBPA]BPA0(3) = TYP;[F:ZPYH]BPR;[F:XBID]BPAADD
    If fstat=0
        BPANAM_ = [F:ZPYH]BPANAM                             # 29.09.14 Bader
        If BPANAM_ = "" : BPANAM_ = [F:ZBPA]BPADES : Endif   # 29.09.14 Bader
        GT8273_4 = BPANAM_
        GT8273_5 = [F:ZBPA]BPAADDLIG(0)
        GT8273_6 = [F:ZBPA]POSCOD
        GT8273_7 = [F:ZBPA]CTY

        Wrseq "03", "/C/", format$("K:27X", GT8273_3),format$("K:24X", GT8273_4),
&             format$("K:24X",GT8273_5), format$("K:24X",GT8273_6),format$("K:24X", GT8273_7), Using [FIC]
        If fstat<>0
           Call ECR_TRACE(mess(317,107,1), 1) From GESECRAN
           Call ECR_TRACE("03"+ "/C/"+ format$("K:27X", GT8273_3)+format$("K:24X", GT8273_4)+
&               format$("K:24X", GT8273_5)+ format$("K:24X",GT8273_6)+format$("K:24X", GT8273_7)+space$(30), 0) From GESECRAN
           Call ECR_TRACE("", 0) From GESECRAN
        Endif
    Else
        Call ECR_TRACE(func AFNC.MES1( mess(522,199,1), [XPYD]VCRNUM), 1) From GESECRAN # The address code of the pay-by BP does not exist
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [F:ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
Endif
Return
#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# 830 de type 3
#-----------------------------------------------------------------------------------------------------
$CREER_GT8303
GT8303_4 = ""
GT8303_5 = ""
GT8303_6 = ""
GT8303_7 = ""
GT8303_8 = ""

Read [F:XBID]BID0 = 1;[ZPYH]BPR;[ZPYH]BID    # lecture du RIB
If fstat = 0 Then
    If [F:XBID]CRY = "CH"
        GT8303_4 = func SWILIB0.STRIP_ZEROS(left$([F:XBID]BIDNUM,5)) # delete leading zeros from clearing number
    Endif
    If [XBID]BICCOD <> "" Then
        COD = "A"
        GT8303_5 = [XBID]BICCOD
    Else
        COD = "D"
        GT8303_5 = [XBID]PAB1
        GT8303_6 = [XBID]PAB2
        GT8303_7 = [XBID]PAB3
        GT8303_8 = [XBID]PAB4
    Endif
    Wrseq "03", COD, "/C/", format$("K:21X", GT8303_4), format$("K:24X", GT8303_5),
&        format$("K:24X", GT8303_6), format$("K:24X", GT8303_7), format$("K:24X", GT8303_8), space$(5), Using [FIC]
    If fstat<>0
        Call ECR_TRACE("03"+ COD+ "/C/"+ format$("K:21X", GT8303_4)+ format$("K:24X", GT8303_5)+
&            format$("K:24X", GT8303_6)+format$("K:24X", GT8303_7)+ format$("K:24X", GT8303_8)+ space$(5), 0) From GESECRAN
        Call ECR_TRACE("", 0) From GESECRAN
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [F:ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
Endif
Return
#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# 836 de type 3
#-----------------------------------------------------------------------------------------------------
$CREER_GT8363
GT8363_3 = ""
GT8363_4 = ""
GT8363_5 = ""
Read [F:XBID]BID0 = 1;[ZPYH]BPR;[ZPYH]BID
If fstat = 0
    Gosub INIT_IBACOD
    If IBACOD<>""
        GT8363_5=IBACOD
        If [F:XBID]CRY = "CH" or [F:XBID]CRY = "LI"   # for Switzerland / Liechtenstein -> no BIC, no address
           COD = "D"
           GT8363_3 = ""
           GT8363_4 = ""
        Else
           If [XBID]BICCOD <> "" Then                 # if BIC exists -> use it
              COD = "A"
              GT8363_3 = [XBID]BICCOD
           Else                                       # if BIC doesn't exist -> use name/address
              COD = "D"
              GT8363_3 = [XBID]PAB1
              GT8363_4 = [XBID]PAB2
           Endif
        Endif
        Wrseq "03", COD, format$("K:35X", GT8363_3), format$("K:35X", GT8363_4), format$("K:34X", GT8363_5), space$(21), Using [FIC]
        If fstat<>0 Then
            Call ECR_TRACE("03"+ COD + format$("K:35X", GT8363_3)+ format$("K:35X", GT8363_4)+
&               format$("K:34X", GT8363_5)+ space$(21), 0) From GESECRAN
            Call ECR_TRACE("", 0) From GESECRAN
        Endif
    Else
        Call ECR_TRACE(mess(34,3648,1)-[F:ZPYH]BPR-[ZPYH]BID,1) From GESECRAN # The IBAN number is required for the type 836. Please correct.
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [F:ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
Endif
Return
#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# 837 de type 3
#-----------------------------------------------------------------------------------------------------
$CREER_GT8373
GT8303_4 = ""
GT8303_5 = ""
GT8303_6 = ""
GT8303_7 = ""
GT8303_8 = ""

Read [F:XBID]BID0 = 1;[ZPYH]BPR;[ZPYH]BID    # lecture du RIB
If fstat = 0 Then
    If [XBID]CRY = "CH"
       NUMCLEAR = func SWILIB0.STRIP_ZEROS(left$([F:XBID]BIDNUM,5)) # delete leading zeros from clearing number
    Else                                     # for foreign accounts, blanks instead of clearing
       NUMCLEAR = ""
    Endif
    If [XBID]BICCOD <> "" Then
        COD = "A"
        GT8303_4 = NUMCLEAR
        GT8303_5 = [XBID]BICCOD
    Else
        COD = "D"
        GT8303_4 = NUMCLEAR
        GT8303_5 = [XBID]PAB1
        GT8303_6 = [XBID]PAB2
        GT8303_7 = [XBID]PAB3
        GT8303_8 = [XBID]PAB4
    Endif
    Wrseq "03", COD, "/C/", format$("K:21X", GT8303_4), format$("K:24X", GT8303_5),
&             format$("K:24X", GT8303_6), format$("K:24X", GT8303_7), format$("K:24X", GT8303_8), space$(5), Using [FIC]
    If fstat<>0
        Call ECR_TRACE("03"+ COD+ "/C/"+ format$("K:21X", GT8303_4)+ format$("K:24X", GT8303_5)+
&               format$("K:24X", GT8303_6)+format$("K:24X", GT8303_7)+ format$("K:24X", GT8303_8)+ space$(5), 0) From GESECRAN
        Call ECR_TRACE("", 0) From GESECRAN
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [F:ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
Endif
Return
#-----------------------------------------------------------------------------------------------------

#*****************************************************************************************************
# Enregistrements de type 4
#*****************************************************************************************************

#-----------------------------------------------------------------------------------------------------
# 827 de type 4
#-----------------------------------------------------------------------------------------------------
$CREER_GT8274
If func SWILIB0.IS_SUPPLIER_INVOICE([F:XPYD]VCRTYP) and [F:XPYD]VCRNUM<>""
    If [F:XPIH]DES(0) <> "" Then
        Wrseq "04", format$("K:28X", [XPIH]DES(0)), format$("K:28X", [XPIH]DES(1)),
&          format$("K:28X", [XPIH]DES(2)), space$(28), space$(14), Using [FIC]
        If fstat<>0
            Call ECR_TRACE("04"+ format$("K:28X", [XPIH]DES(0))+
&              format$("K:28X", [XPIH]DES(1))+ format$("K:28X", [XPIH]DES(2))+ space$(28)+ space$(14), 0) From GESECRAN
            Call ECR_TRACE("", 0) From GESECRAN
        Endif
    Endif
Endif
Return
#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# 830 de type 4
#-----------------------------------------------------------------------------------------------------
$CREER_GT8304
#---- Lecture du tiers ----#
Read [F:XBPR]BPR0 = [ZPYH]BPR
If fstat=0 Then
    #---- Lecture de l'adresse du tiers ----#
    Read [F:ZBPA]BPA0 = 1;[ZPYH]BPR;[F:XBID]BPAADD
    If fstat = 0
        BPANAM_ = [F:ZPYH]BPANAM                             # 29.09.14 Bader
        If BPANAM_ = "" : BPANAM_ = [F:ZBPA]BPADES : Endif   # 29.09.14 Bader
        Read [F:XBID]BID0 = 1;[ZPYH]BPR;[ZPYH]BID    # lecture du RIB
        If fstat = 0 Then
            Gosub INIT_IBACOD
            If IBACOD=""
                If [XBID]CRY = "CH" or [XBID]CRY = "LI" Then # CH -> take account from BIDNUM from position 6 following
                   Wrseq "04", "/C/", format$("K:21X", func SWILIB0.STRIP_ZEROS(right$([F:ZPYH]BID,6))), format$("K:24X", BPANAM_),
&                        format$("K:24X", [ZBPA]BPAADDLIG(0)), format$("K:24X",[ZBPA]CRY+"-"+[ZBPA]POSCOD),
&                        format$("K:24X", [ZBPA]CTY), space$(6), Using [FIC]
                   If fstat<>0
                      Call ECR_TRACE("04"+ "/C/"+ format$("K:21X", func SWILIB0.STRIP_ZEROS(right$([F:ZPYH]BID,6)))+
&                     format$("K:24X", BPANAM_)+ format$("K:24X", [ZBPA]BPAADDLIG(0))+
&                     format$("K:24X",[ZBPA]CRY+"-"+[ZBPA]POSCOD)+ format$("K:24X", [ZBPA]CTY)+ space$(6), 0) From GESECRAN
                      Call ECR_TRACE("", 0) From GESECRAN
                   Endif
                Else
#                    Wrseq "04", "/C/", space$(21), format$("K:24X", BPANAM_),
                    Wrseq "04", "/C/", format$("K:21X",[F:ZPYH]BID), format$("K:24X", BPANAM_),
&                         format$("K:24X", [ZBPA]BPAADDLIG(0)), format$("K:24X", [ZBPA]CRY+"-"+[ZBPA]POSCOD),
&                         format$("K:24X", [ZBPA]CTY), space$(6), Using [FIC]
                    If fstat<>0
                        Call ECR_TRACE("04"+ "/C/"+ space$(21)+ format$("K:24X", BPANAM_)+
&                         format$("K:24X", [ZBPA]BPAADDLIG(0))+ format$("K:24X",[ZBPA]CRY+"-"+[ZBPA]POSCOD)+
&                         format$("K:24X", [ZBPA]CTY)+ space$(6), 0) From GESECRAN
                        Call ECR_TRACE("", 0) From GESECRAN
                    Endif
                Endif
            Else
               Call ECR_TRACE(func AFNC.MES1( mess(50,3648,1), [ZPYH]NUM), 1) From GESECRAN # An IBAN number is not allowed for the type 830. Please use type 836 or 837 instead.
            Endif
        Else
            Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
        Endif
    Else
        Call ECR_TRACE(mess(522,199,1)-[F:XPIH]BPR,0) From GESECRAN # The address code of the pay-by BP does not exist
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(36,3648,1), [XPYH]BPR), 1) From GESECRAN # Error reading the business partner $1$.
Endif
Return
#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# 836 de type 4
#-----------------------------------------------------------------------------------------------------
$CREER_GT8364
Read [F:ZBPA]BPA0(3) = 1;[F:ZPYH]BPR;[F:XBID]BPAADD        # lecture de l'adresse du tier
If fstat = 0 Then
    BPANAM_ = [F:ZPYH]BPANAM                             # 29.09.14 Bader
    If BPANAM_ = "" : BPANAM_ = [F:ZBPA]BPADES : Endif   # 29.09.14 Bader
        Wrseq "04", format$("K:35X", BPANAM_), format$("K:35X", [ZBPA]BPAADDLIG(0)),
&         format$("K:35X", [ZBPA]CRY+"-"+[ZBPA]POSCOD+" "+[ZBPA]CTY), space$(21), Using [FIC]
        If fstat <> 0
            Call ECR_TRACE("04"+ format$("K:35X", BPANAM_)+ format$("K:35X", [ZBPA]BPAADDLIG(0)) +
&             format$("K:35X", [ZBPA]CRY+"-"+[ZBPA]POSCOD+" "+[ZBPA]CTY) + space$(21), 0) From GESECRAN
            Call ECR_TRACE("", 0) From GESECRAN
        Endif
    #Endif
Else
    Call ECR_TRACE(mess(522,199,1)-[F:XPIH]BPR,0) From GESECRAN # The address code of the pay-by BP does not exist
Endif
Return
#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# 837 de type 4

#-----------------------------------------------------------------------------------------------------
$CREER_GT8374
#---- Lecture du tiers ----#
Read [F:XBPR]BPR0 = [ZPYH]BPR
If fstat=0 Then
    #---- Lecture de l'adresse du tiers ----#
    Read [F:ZBPA]BPA0 = 1;[ZPYH]BPR;[F:XBID]BPAADD
    If fstat = 0
        BPANAM_ = [F:ZPYH]BPANAM                             # 29.09.14 Bader
        If BPANAM_ = "" : BPANAM_ = [F:ZBPA]BPADES : Endif   # 29.09.14 Bader
        #---- Lecture du RIB ----#
        Read [F:XBID]BID0 = 1;[ZPYH]BPR;[ZPYH]BID    # lecture du RIB
        If fstat = 0 Then
            Gosub INIT_IBACOD
            If IBACOD=""
                #---- Pas d'IBAN on met le compte ----#
                If [XBID]CRY = "CH" or [XBID]CRY = "LI" Then # CH -> take account from BIDNUM from position 6 following
                    Wrseq "04", "/C/", format$("K:21X", func SWILIB0.STRIP_ZEROS(right$([F:ZPYH]BID,6))), format$("K:24X", BPANAM_),
&                     format$("K:24X", [ZBPA]BPAADDLIG(0)), format$("K:24X",[ZBPA]CRY+"-"+[ZBPA]POSCOD),
&                     format$("K:24X", [ZBPA]CTY), space$(6), Using [FIC]
                    If fstat<>0
                        Call ECR_TRACE("04"+ "/C/"+ format$("K:21X", func SWILIB0.STRIP_ZEROS(right$([F:ZPYH]BID,6)))+
&                          format$("K:24X", BPANAM_)+ format$("K:24X", [ZBPA]BPAADDLIG(0))+
&                          format$("K:24X",[ZBPA]CRY+"-"+[ZBPA]POSCOD)+ format$("K:24X", [ZBPA]CTY)+ space$(6), 0) From GESECRAN
                        Call ECR_TRACE("", 0) From GESECRAN
                    Endif
                Else                                         # not CH -> take complete BIDNUM
                    Wrseq "04", "/C/", format$("K:21X",[F:ZPYH]BID), format$("K:24X", BPANAM_),
&                     format$("K:24X", [ZBPA]BPAADDLIG(0)), format$("K:24X", [ZBPA]CRY+"-"+[ZBPA]POSCOD),
&                     format$("K:24X", [ZBPA]CTY), space$(6), Using [FIC]
                    If fstat<>0
                        Call ECR_TRACE("04"+ "/C/"+ format$("K:21X",[F:ZPYH]BID) + format$("K:24X", BPANAM_)+
&                         format$("K:24X", [ZBPA]BPAADDLIG(0))+ format$("K:24X",[ZBPA]CRY+"-"+[ZBPA]POSCOD)+
&                         format$("K:24X", [ZBPA]CTY)+ space$(6), 0) From GESECRAN
                        Call ECR_TRACE("", 0) From GESECRAN
                    Endif
                Endif
            Else
                #---- IBAN on ne met pas le compte ----#
                Wrseq "04", "/C/", space$(21), format$("K:24X", BPANAM_), format$("K:24X", [ZBPA]BPAADDLIG(0)),
&                 format$("K:24X", [ZBPA]CRY+"-"+[ZBPA]POSCOD), format$("K:24X", [ZBPA]CTY), space$(6), Using [FIC]
                If fstat<>0
                    Call ECR_TRACE("04"+ "/C/"+ space$(21)+ format$("K:24X", BPANAM_)+
&                      format$("K:24X", [ZBPA]BPAADDLIG(0))+ format$("K:24X",[ZBPA]CRY+"-"+[ZBPA]POSCOD)+
&                      format$("K:24X", [ZBPA]CTY)+ space$(6), 0) From GESECRAN
                    Call ECR_TRACE("", 0) From GESECRAN
                Endif
            Endif
        Else
            Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
        Endif
    Else
        Call ECR_TRACE(mess(522,199,1)-[F:XPIH]BPR,0) From GESECRAN # The address code of the pay-by BP does not exist
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(36,3648,1), [XPYH]BPR), 1) From GESECRAN # Error reading the business partner $1$.
Endif
Return
#-----------------------------------------------------------------------------------------------------

#*****************************************************************************************************
# Enregistrements de type 5
#*****************************************************************************************************

#-----------------------------------------------------------------------------------------------------
# 830 de type 5
#-----------------------------------------------------------------------------------------------------
$CREER_GT8305
GT8305_1= ""
GT8305_2= ""
GT8305_3= ""
Read [F:XPYD]PYD0 = [ZPYH]NUM                # lecture PAYMENTHD pour retrouver la facture rattachée
If fstat = 0 Then
    If func SWILIB0.IS_SUPPLIER_INVOICE([F:XPYD]VCRTYP) and [F:XPYD]VCRNUM<>""
        Read [F:XPIH]PIH0 = [XPYD]VCRNUM         # lecture la facture PINVOICE
        If fstat = 0 Then
            If [F:XPIH]DES(0) <> "" Then
                GT8305_1=[XPIH]DES(0)
                GT8305_2=[XPIH]DES(1)
                GT8305_3=[XPIH]DES(2)
            Endif
        Else
            Call ECR_TRACE(func AFNC.MES1( mess(29,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # Error reading the invoice $1$.
        Endif
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(30,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the payment details $1$.
Endif
Wrseq "05", format$("K:30X", GT8305_1), format$("K:30X", GT8305_2), format$("K:30X", GT8305_3) ,space$(36), Using [FIC]
If fstat <> 0
    Call ECR_TRACE("05"+ format$("K:30X", GT8305_1) + format$("K:30X", GT8305_2) +
&    format$("K:30X", GT8305_3) + space$(36), 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
Endif
Return
#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# 836 de type 5
#-----------------------------------------------------------------------------------------------------
$CREER_GT8365
GT8365_2 = ""
GT8365_3 = ""
GT8365_4 = ""
FRAIS=""
Read [F:XPYD]PYD0 = [ZPYH]NUM                # lecture PAYMENTHD pour retrouver la facture rattachée
If fstat = 0 Then
    If func SWILIB0.IS_SUPPLIER_INVOICE([F:XPYD]VCRTYP) and [F:XPYD]VCRNUM<>""
        Read [F:XPIH]PIH0 = [XPYD]VCRNUM         # lecture la facture PINVOICE
        If fstat = 0 Then
            If [F:XPIH]DES(0) <> "" Then
                GT8365_2=[XPIH]DES(0)
                GT8365_3=[XPIH]DES(1)
                GT8365_4=[XPIH]DES(2)
            Endif
        Else
            Call ECR_TRACE(func AFNC.MES1( mess(29,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # Error reading the invoice $1$.
        Endif
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(30,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the payment details $1$.
Endif
If [ZPYH]SWIIPI <> "" Then
    COD = "I"
    GT8365_2 = [ZPYH]SWIIPI
    GT8365_3 = ""
    GT8365_4 = ""
Else
    COD = "U"
Endif

Case [ZPYH]SWISUP3
    When 3 : FRAIS="0"     # Applicant (OUR)
    When 2 : FRAIS="1"     # Beneficiary (BEN)
    When 1 : FRAIS="2"     # Shared (SHA)
    When Default : FRAIS="0"
Endcase

Wrseq "05", COD, format$("K:35X", GT8365_2), format$("K:35X", GT8365_3),format$("K:35X", GT8365_4), format$("K:1X",FRAIS), space$(19), Using [FIC]
If fstat <> 0
    Call ECR_TRACE("05"+ COD+ format$("K:35X", GT8365_2)+ format$("K:35X", GT8365_3)+ format$("K:35X", GT8365_4)+ format$("K:1X",FRAIS)+ space$(19), 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
Endif
Return
#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# 837 de type 5
#-----------------------------------------------------------------------------------------------------
$CREER_GT8375
#---- Lecture du RIB ----#
Read [F:XBID]BID0 = 1;[ZPYH]BPR;[ZPYH]BID    # lecture du RIB
If fstat = 0 Then
    Gosub INIT_IBACOD
    If IBACOD=""
        #---- Pas d'IBAN on met le compte ----#
        Wrseq "05", space$(34), space$(92), Using [FIC]
        If fstat<>0
            Call ECR_TRACE("05"+ space$(34)+ space$(92), 0) From GESECRAN
            Call ECR_TRACE("", 0) From GESECRAN
        Endif
    Else
        #---- IBAN on ne met pas le compte ----#
        Wrseq "05", format$("K:34X", IBACOD), space$(92), Using [FIC]
        If fstat<>0
            Call ECR_TRACE("05"+ format$("K:34X", IBACOD)+ space$(6), 0) From GESECRAN
            Call ECR_TRACE("", 0) From GESECRAN
        Endif
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
Endif
Return
#-----------------------------------------------------------------------------------------------------

#*****************************************************************************************************
# Enregistrements de type 6
#*****************************************************************************************************

#-----------------------------------------------------------------------------------------------------
# 830 de type 6
#-----------------------------------------------------------------------------------------------------
$CREER_GT8306
FRAIS=""
Case [ZPYH]SWISUP3
    When 3 : FRAIS="CHG/OUR"    # Applicant
    When 2 : FRAIS="CHG/BEN"    # Beneficiary
    When 1 : FRAIS=""           # Shared
    When Default : FRAIS="CHG/OUR"
Endcase
If FRAIS<>""
    Wrseq "06",format$("K:7X", FRAIS), space$(119), Using [FIC]
    If fstat <> 0
        Call ECR_TRACE("06"+ format$("K:7X", FRAIS)+ space$(119), 0) From GESECRAN
        Call ECR_TRACE("", 0) From GESECRAN
    Endif
Endif
Return
#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# 837 de type 6
#-----------------------------------------------------------------------------------------------------
$CREER_GT8376
GT8365_2 = ""
GT8365_3 = ""
GT8365_4 = ""
FRAIS=""
Read [F:XPYD]PYD0 = [ZPYH]NUM                # lecture PAYMENTHD pour retrouver la facture rattachée
If fstat = 0 Then
    If func SWILIB0.IS_SUPPLIER_INVOICE([F:XPYD]VCRTYP) and [F:XPYD]VCRNUM<>""
        Read [F:XPIH]PIH0 = [XPYD]VCRNUM         # lecture la facture PINVOICE
        If fstat = 0 Then
            If [F:XPIH]DES(0) <> "" Then
                GT8365_2=[XPIH]DES(0)
                GT8365_3=[XPIH]DES(1)
                GT8365_4=[XPIH]DES(2)
            Endif
        Else
            Call ECR_TRACE(func AFNC.MES1( mess(29,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # Error reading the invoice $1$.
        Endif
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(30,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the payment details $1$.
Endif
If [ZPYH]SWIIPI <> "" Then
    COD = "I"
    GT8365_2 = [ZPYH]SWIIPI
    GT8365_3 = ""
    GT8365_4 = ""
Else
    COD = "U"
Endif

Case [ZPYH]SWISUP3
    When 3 :  FRAIS="0"    # Applicant (OUR)
    When 2 :  FRAIS="1"    # Beneficiary (BEN)
    When 1 :  FRAIS="2"    # Shared (SHA)
    When Default : FRAIS="0"
Endcase

Wrseq "06", COD, format$("K:35X", GT8365_2), format$("K:35X", GT8365_3),format$("K:35X", GT8365_4), format$("K:1X",FRAIS), space$(19), Using [FIC]
If fstat <> 0
    Call ECR_TRACE("06"+ COD+ format$("K:35X", GT8365_2)+ format$("K:35X", GT8365_3)+ format$("K:35X", GT8365_4)+ format$("K:1X",FRAIS)+ space$(19), 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
Endif
Return
#-----------------------------------------------------------------------------------------------------

#*****************************************************************************************************
# Enregistrements de type 7
#*****************************************************************************************************
#-----------------------------------------------------------------------------------------------------
# 837 de type 7
#-----------------------------------------------------------------------------------------------------
$CREER_GT8377

    Wrseq "07","U",space$(30),space$(30),space$(30),space$(30), space$(5), Using [FIC]
    If fstat <> 0
        Call ECR_TRACE("07"+ space$(30)+space$(30)+space$(30)+space$(30)+ space$(5), 0) From GESECRAN
        Call ECR_TRACE("", 0) From GESECRAN
    Endif
Return
