#<AdxTL>@(#)0.0.0.0 $Revision$ Règlements
#----------------         Changes                  --------------------#
# SAM 108267 angre 16.09.15: Additional Function GETBANKCHARGEAMOUNT   #
# Issue X3-51662 - 2017-08-24 by BEFOU : Wrong amount in payment entry batch after changing a payment
# Issue X3-58926 - 2017-10-17 by BEFOU : For feeding COA field AFTER new entry batch
#----------------------------------------------------------------------#
GFLAG="ZNG"
Raz GBIDC1, GBIDC2
Call OBJET("PAY",GBIDC1,GBIDC2) From GOBJET
End

$CHARG_LOT
If !FLGLOT : Return : Endif
#-----------------------------------------------------------------#
# Chargement du lot VALC1 auquel est associe le reglement courant #
# (uniquement si le lot a charger <> lot deja en ligne)           #
# Rmq: on pourra forcer le chargement en affectant LOTCUR         #
#      a "*" avant l'appel a ce sous-programme                    #
#                                                                      #
# SAM 108267 angre 16.09.15: Additional Function GETBANKCHARGEAMOUNT   #
#                                                                      #
#-----------------------------------------------------------------#
ROK=0
If [L]VALC1=LOTCUR
 Goto RAF_LIGLOT
Endif

LOTCUR=[L]VALC1 : ROK=1

# Si le règlement n'est associe a aucun lot
If [L]VALC1="" : Raz [M:PAY4] : Goto SETBOXLOT : Endif

# Lecture du lot auquel est associe le reglement
Read [PYL]PYL0=[L]VALC1
If fstat : Raz [M:PAY4] : Goto SETBOXLOT : Endif

# Chargement de l'onglet "Lot de saisie"
[M:PAY4]=[F:PYL]
I=find([F:PYL]CPY,GSOC(1..GNBSOC))
If I>0 : [M:PAY4]CPYCUR = GDEVSOC(I)
Else   : [M:PAY4]CPYCUR = ""
Endif
[M:PAY4]CODLOT=[L]VALC1
[M:PAY4]DESLOT=[F:PYL]DES
If [M:PAY0]LOTDES<>[M:PAY4]DESLOT
 [M:PAY0]LOTDES=[F:PYL]DES : Affzo [PAY0]LOTDES
Endif
[M:PAY0]PAYLOT=[L]VALC1
nolign=0
For [PYH]PYH2 Where PAYLOT=[L]VALC1
 If !(GUSRFCY(1)<>"\" & !find([PYH]FCY,GUSRFCY(1..GNBAUZ)))
  nolign+=1
  Gosub CHARG_LIGLOT
 Endif
Next
[M:PAY4]NBPAY=nolign

Gosub INIT_LOT

# On se repositionne sur le bon reglement
Call LECTURE("PAY",[M:PAY0]NUM,"") From CONTOBJ

# Gestion de la coche sur le cote gauche du tableau
Raz [M:PAY4]LIGFLG
LOTLIGCUR=find([F:PYH]NUM,[M:PAY4]PAYNUM(0..[M:PAY4]NBPAY-1))
If LOTLIGCUR
 [M:PAY4]LIGFLG(LOTLIGCUR-1)=2
 Gosub CALCMTLOT
 [M:PAY4]MTLOC=[L]MT
 [M:PAY4]PAYNUMCUR=[F:PYH]NUM
Else
 Raz  [M:PAY4]MTLOC, [M:PAY4]PAYNUMCUR
Endif

$SETBOXLOT
If 1=1 : Return : Endif
[F:PYL]COD=LOTCUR
Case ILISPYL
 When 1 : Setlbox [PAY] GAU_CHE1
 When 2 : Setlbox [PAY] GAU_CHE2
 When 3 : Setlbox [PAY] GAU_CHE3
 When 4 : Setlbox [PAY] GAU_CHE4
 When 5 : Setlbox [PAY] GAU_CHE5
 When 6 : Setlbox [PAY] GAU_CHE6
 When 7 : Setlbox [PAY] GAU_CHE7
 When 8 : Setlbox [PAY] GAU_CHE8
Endcase
Return

$INIT_LOT

Local Integer WNOLINE
If [M:PAY4]NBPAY and GREP = "C"
  WNOLINE = [M:PAY4]NBPAY - 1
  While WNOLINE >= 0
    If [M:PAY4]PAYFCY(WNOLINE) = ""
      WNOLINE -= 1
    Else
      [M:PAY1]FCY = [M:PAY4]PAYFCY(WNOLINE)
      [M:PAY1]ACCDAT = [M:PAY4]PAYDAT(WNOLINE)
      [M:PAY1]BAN = [M:PAY4]PAYBAN(WNOLINE)
      If dim([M:PAY4]PAYREF) >= 0 # Issue 119741
        [M:PAY1]REF = [M:PAY4]PAYREF(WNOLINE)
      Endif # End Issue 119741
      Affzo [M:PAY1]FCY, ACCDAT, BAN, REF
      Break
    Endif
  Wend
  Gosub INISTD From SUBPAY # Issue X3-58926 - 2017-10-17 by BEFOU : For populating COA
Endif

Return

$RAF_LIGLOT
[M:PAY4]DESLOT=[F:PYL]DES
If [M:PAY4]DESLOT<>[M:PAY0]LOTDES
 [M:PAY0]LOTDES = [M:PAY4]DESLOT : Affzo [PAY0]LOTDES
Endif
LOTLIGCUR = find([M:PAY0]NUM,[M:PAY4]PAYNUM(0..[M:PAY4]NBPAY-1))
Raz [M:PAY4]LIGFLG
If LOTLIGCUR<=0
 Affzo [PAY4]LIGFLG
 Raz  [M:PAY4]MTLOC, [M:PAY4]PAYNUMCUR
 Gosub INIT_LOT
 Return
Endif

If [M:PAY4]PAYNUMCUR=[M:PAY0]NUM
 [M:PAY4]TOTLOC-=[M:PAY4]MTLOC
Endif
Gosub CALCMTLOT
[M:PAY4]MTLOC=[L]MT
If [M:PAY4]PAYNUMCUR=[M:PAY0]NUM
 [M:PAY4]TOTLOC+=[M:PAY4]MTLOC
Endif
[M:PAY4]PAYNUMCUR=[M:PAY0]NUM

nolign = LOTLIGCUR
If !(GUSRFCY(1)<>"\" & !find([PYH]FCY,GUSRFCY(1..GNBAUZ)))
  # Issue X3-51662
  If [M:PAY0]NUM <> [F:PYH]NUM # If The PYH Num is not the good one
    Read [PYH]PYH0= [M:PAY0]NUM
  Endif
  # End issue X3-51662
 Gosub CHARG_LIGLOT
Endif
[M:PAY4]LIGFLG(LOTLIGCUR-1)=2
Affzo [PAY4] PAYNUM(NOL),PAYDAT(NOL),PAYFCY(NOL),PAYBAN(NOL),PAYPAM(NOL),PAYBPRSAC(NOL),
&     PAYBPR(NOL),PAYCUR(NOL),PAYAMTCUR(NOL),PAYSTA(NOL),PAYFRMNUM(NOL)
Affzo [PAY4]15-20 : # Nb règlements, Totaux
Affzo [PAY4]LIGFLG
Gosub INIT_LOT

Return

$CHARG_LIGLOT
#---------------------------------------------------#
# Transfert d'un reglement de [F:PYH] vers [M:PAY4] #
# (nolign doit etre affecte avant d'entrer ici)     #
#---------------------------------------------------#
NOL=nolign-1
[M:PAY4]PAYNUM(NOL)   =[F:PYH]NUM
[M:PAY4]PAYDAT(NOL)   =[F:PYH]ACCDAT
[M:PAY4]PAYFCY(NOL)   =[F:PYH]FCY
[M:PAY4]PAYBAN(NOL)   =[F:PYH]BAN
[M:PAY4]PAYPAM(NOL)   =[F:PYH]PAM
[M:PAY4]PAYBPRSAC(NOL)=[F:PYH]BPRSAC
[M:PAY4]PAYBPR(NOL)   =[F:PYH]BPR
[M:PAY4]PAYCUR(NOL)   =[F:PYH]CUR
Gosub SNSLOT
[M:PAY4]PAYAMTCUR(NOL)=[F:PYH]AMTCUR*STAT
[M:PAY4]PAYSTA(NOL)   =[F:PYH]STA
[M:PAY4]PAYFRMNUM(NOL)=[F:PYH]FRMNUM
[M:PAY4]PAYREF(NOL)   =[F:PYH]REF # Issue 119741
Return

$MAJLOT

If !FLGLOT : Return : Endif
#-------------------------------------------------------------#
# Mise a jour du lot en création et modification de reglement #
# VALC1 : ancien lot en modification                          #
#       : vide en création ou duplication                     #
#-------------------------------------------------------------#
If [L]VALC1<>[F:PYH]PAYLOT :  : # Chgt de lot
 If [L]VALC1<>""
  Readlock [PYL]PYL0 = [L]VALC1
  If fstat=1 : GOK=-1 : GLOCK="$PAYLOT"-[L]VALC1 : Return
  Elsif fstat : GOK=0 : Call RSTA("PYL",[L]VALC1) From GLOCK : Return
  Else
   [F:PYL]NBRPAY-=1
   If [F:PYL]NBRPAY=0
    Delete [PYL] Where COD = [L]VALC1
    If fstat=1 : GOK=-1 :  GLOCK="$PAYLOT"-[L]VALC1
    Elsif fstat>5 : GOK=0 :  Call RSTA("PYL",[L]VALC1) From GLOCK
    Endif
   Else
    Gosub CALCMTLOT
    [F:PYL]TOTLOC-=[L]MT
    # SAM: 81743 MAGER Save progressive balance control values
    Gosub SAVEPROBAL

    If dim([F:PYL]STA)>0
     [F:PYL]STA=func SUBPAY5.CALSTAPYL([L]VALC1)
    Endif

    If dim([F:PYL]UPDDAT)>0 : [F:PYL]UPDDAT=date$ : Endif
    If dim([F:PYL]UPDUSR)>0 : [F:PYL]UPDUSR=GUSER : Endif
    If dim([F:PYL]FCY)>0 : [F:PYL]FCY = [M:PAY4]PAYFCY : Endif
    Rewrite [PYL]
    If fstat : GOK=0 : Call FSTA("PYL") From GLOCK : Return : Endif
   Endif
  Endif
 Endif
 Gosub CRELOT

Elsif [L]VALC1<>"" : # On reste sur le même lot
 Readlock [PYL]PYL0 = [L]VALC1
 If fstat=1 : GOK=-1 : GLOCK="$PAYLOT"-[L]VALC1 : Return
 Elsif fstat : GOK=0 : Call RSTA("PYL",[L]VALC1) From GLOCK : Return
 Else
  [F:PYL]TOTLOC-=[M:PAY4]MTLOC
  Gosub CALCMTLOT
  [F:PYL]TOTLOC+=[L]MT
  [F:PYL]DES=[M:PAY0]LOTDES : [M:PAY4]DESLOT=[M:PAY0]LOTDES
  # SAM: 81743 MAGER Save progressive balance control values
  Gosub SAVEPROBAL
  If dim([F:PYL]UPDDAT)>0 : [F:PYL]UPDDAT=date$ : Endif
  If dim([F:PYL]UPDUSR)>0 : [F:PYL]UPDUSR=GUSER : Endif
  If dim([F:PYL]FCY)>0 : [F:PYL]FCY = [M:PAY4]PAYFCY : Endif
  Rewrite [PYL]
  If fstat : GOK=0 : Call FSTA("PYL") From GLOCK : Return : Endif
 Endif
Endif
Return

$CRELOT
#---------------------------------------------------#
# Creation d'un nouveau lot ou                      #
# Ajout d'un règlement sur un lot existant          #
#---------------------------------------------------#
If [F:PYH]PAYLOT="" : Return : Endif

COMPTLOT = ""
Call GETSOC([M]FCY) From DEVSUB
Call LECTCA(3,OKTCA) From SUBTCA
If OKTCA
 COMPTLOT = [F:TCA]CODNUM(6)
Endif

Local Integer NOUVLOT  # Un nouveau lot est cree

If [F:PYH]PAYLOT="*"
 If COMPTLOT="" : # Lots de saisie règlements - Compteur inexistant
  GMESSAGE = mess(7,865,1)+"\"+mess(12,114,1) : GOK=0 : Return
 Endif
 NOUVLOT=1
Else
 Readlock [PYL]PYL0 = [F:PYH]PAYLOT
 If fstat=1 : GOK=-1 : GLOCK="$PAYLOT"-[F:PYH]PAYLOT : Return
 Elsif fstat : GOK=0 : Call RSTA("PYL",[F:PYH]PAYLOT) From GLOCK : Return
 Elsif [F:PYL]NBRPAY<dim([M:PAY4]PAYNUM)
  NOUVLOT=0
 Else : # Lot de saisie plein
  GMESSAGE=[F:PYH]PAYLOT-":"-mess(107,121,1) : GOK=0 : Return
 Endif
Endif

If NOUVLOT
 Raz [F:PYL]
 Call NUMERO(COMPTLOT,[F:PYH]FCY,datesyst,GUSER,[F:PYL]COD,STAT) From SUBANM
 If STAT
  # Problème lors de la récupération du compteur
  Gosub MESSAGE From SUBANM
  GMESSAGE = mess(60,199,1)-"("+COMPTLOT+") : "+MESSA
  Return
 Endif
 [F:PYL]CPY   =[F:PYH]CPY
 [F:PYL]PAYTYP=[F:PYH]PAYTYP
 If dim([F:PYL]CREDAT)>0 : [F:PYL]CREDAT=date$   : Endif
 If dim([F:PYL]CREUSR)>0 : [F:PYL]CREUSR=GUSER   : Endif
 If dim([F:PYL]FCY)>0    : [F:PYL]FCY=[F:PYH]FCY : Endif
Else
 If dim([F:PYL]STA)>0
  [F:PYL]STA=func SUBPAY5.CALSTAPYL([F:PYH]PAYLOT)
 Endif

 If dim([F:PYL]UPDDAT)>0 : [F:PYL]UPDDAT=date$ : Endif
 If dim([F:PYL]UPDUSR)>0 : [F:PYL]UPDUSR=GUSER : Endif
 If dim([F:PYL]FCY)>0 : [F:PYL]FCY = [M:PAY4]PAYFCY : Endif
Endif

# Intitulé, Nombre de règlements dans le lot
[F:PYL]DES    =[M]LOTDES
[F:PYL]NBRPAY+=1

# Montants
Gosub CALCMTLOT
[F:PYL]TOTLOC+=[L]MT

# SAM: 81743 MAGER Save progressive balance control values
Gosub SAVEPROBAL

# Création ou MAJ du lot (resp. en création/duplication)
If NOUVLOT
 Write [PYL]
Else
 Rewrite [PYL]
Endif
If fstat : GOK=0 : Call FSTA("PYL") From GLOCK : Return : Endif

# En création, on associe le règlement courant au lot crée
If NOUVLOT
 [F:PYH]PAYLOT=[F:PYL]COD
Endif
[F:PYH]PAYLOTLIG=[F:PYL]NBRPAY
Rewrite [PYH]
If fstat : GOK=0 : Call FSTA("PYH") From GLOCK : Return : Endif

If [M]PAYLOT<>[F:PYH]PAYLOT | [M:PAY4]NBPAY>=dim([M:PAY4]PAYNUM)
 LOTCUR="*"
Else
 [M:PAY4]PAYNUM([M:PAY4]NBPAY)=[F:PYH]NUM
 [M:PAY4]NBPAY+=1
 [M:PAY4]NBRPAY+=1
 Raz [M:PAY4]MTLOC
 [M:PAY4]PAYNUMCUR=[F:PYH]NUM
Endif
Return

$SUPMAJLOT
If !FLGLOT : Return : Endif
#--------------------------------------------------#
# Mise-a-jour d'un lot en suppression de reglement #
#--------------------------------------------------#

# Si regl. associe a aucun lot, on ne fait rien
If [F:PYH]PAYLOT="" : Return : Endif

If clalev([F:PYL])=0 : Local File PAYLOT [PYL] : Endif

# Lecture du lot associe au reglement
Readlock [PYL]PYL0 = [F:PYH]PAYLOT
If fstat=1 : GOK=-1 : GLOCK="$PAYLOT"-[F:PYH]PAYLOT : Return
Elsif fstat : GOK=0 : Call RSTA("PYL",[F:PYH]PAYLOT) From GLOCK : Return
Endif

# Mise-a-jour du nbre de reglements dans le lot
[F:PYL]NBRPAY-=1

# Suppression du lot si plus de reglements associes
If [F:PYL]NBRPAY=0
 Delete [PYL]PYL0=[F:PYH]PAYLOT
 If fstat=1
  GOK=-1 :  GLOCK="$PAYLOT"-[F:PYH]PAYLOT
 Elsif fstat>5
  GOK=0 :  Call RSTA("PYL",[F:PYH]PAYLOT) From GLOCK
 Endif
 Return
Endif

# Montants
Gosub CALCMTLOT
[F:PYL]TOTLOC-=[L]MT

# SAM: 81743 Save progressive balance control fields
Gosub SAVEPROBAL

# Date et utilisateur de modif.
If dim([F:PYL]UPDDAT)>0 : [F:PYL]UPDDAT=date$ : Endif
If dim([F:PYL]UPDUSR)>0 : [F:PYL]UPDUSR=GUSER : Endif

# Mise-a-jour du lot
Rewrite [PYL]
If fstat : GOK=0 : Call FSTA("PYL") From GLOCK : Return : Endif

# Mise-a-jour des reglements associes a ce lot
Local Char PAYLOT0(GLONVCR)   : PAYLOT0=[F:PYH]PAYLOT
Local Integer PAYLOTLIG0 : PAYLOTLIG0=[F:PYH]PAYLOTLIG
Update [PYH] Where PAYLOT=[L]PAYLOT0 & PAYLOTLIG>[L]PAYLOTLIG0
&            With PAYLOTLIG-=1
If fstat=1
 GOK=-1 : GLOCK="$PAYMENTH"-[L]PAYLOT0-num$([L]PAYLOTLIG0) : Return
Elsif fstat
 GOK=0 : Call RSTA("PYH",[L]PAYLOT0-num$([L]PAYLOTLIG0)) From GLOCK : Return
Endif
Return

$CALCMTLOT
#---------------------------------------------#
# Mise a jour des totaux en devises du lot    #
#---------------------------------------------#
STAT=find([F:PYH]CPY,GSOC(1..GNBSOC))
If STAT<=0
 GMESSAGE=[F:PYH]CPY-":"-mess(16,104,1) : GOK=0 : Return : # Société inexistante
Endif
GLOCALDEV = GDEVSOC(STAT)

If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY [CPY]   : Endif
Call LEC_CPY([F:PYH]CPY) From CPTLEC
Call LEC_TPY_LEG([F:CPY]LEG,[F:PYH]PAYTYP) From CPTLEC

# Montant en devise société
If GLOCALDEV=[F:PYH]CUR
 [L]MT=[F:PYH]AMTCUR
Else
 Call CONVERT([F:PYH]CUR,GLOCALDEV,GLOCALDEV,[F:TPY]RATTYP,
&            [F:PYH]ACCDAT,[F:PYH]AMTCUR,[L]MT,STAT) From TRTDEV
 If STAT : [L]MT=0 : Endif
Endif

Gosub SNSLOT
[L]MT*=STAT
Return

$SNSLOT
If [F:TPY]SNS<3 & [F:PYH]SNS=[F:TPY]SNS : STAT=1
Elsif [F:TPY]SNS<3 & [F:PYH]SNS<>[F:TPY]SNS : STAT=-1

Elsif [F:PYH]SNS=2 : STAT=1
Else STAT=-1
Endif
Return

# SAM: 81743 MAGER - Save progressive balance control values if parameter is active
$SAVEPROBAL
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY] : Endif
If !clalev([F:PYL]) : Local File PAYLOT    [PYL] : Endif
If [F:TPY]LOTPROBALCTL = 2
  Gosub CALCPROBAL
    [F:PYL]BAN    = [M:PAY1]BAN
    [F:PYL]PROBAL = [M:PAY4]PROBAL
    [F:PYL]PRODIF = [M:PAY4]PRODIF
    [F:PYL]STRBAL = [M:PAY4]STRBAL
    [F:PYL]ENDBAL = [M:PAY4]ENDBAL
    [F:PYL]BANCUR = [M:PAY4]BANCUR
Endif
Return

# SAM: 81743 MAGER - calculate progressive balance control fields
$CALCPROBAL
Local Decimal PROBALVAL : PROBALVAL = 0
Gosub CALCPROBALVAL
Local Decimal PROBAL : PROBAL = [M:PAY4]STRBAL + PROBALVAL
Local Decimal PRODIF : PRODIF = [M:PAY4]ENDBAL - PROBAL
[M:PAY4]PROBAL = PROBAL
[M:PAY4]PRODIF = PRODIF
Affzo [PAY4]PROBAL, PRODIF
Return

# SAM: 81743 MAGER - calculate progressive balance control fields
#SAM 108267 angre 16.09.15 add bank charge amount
$CALCPROBALVAL
Local Decimal TEMPAMT : TEMPAMT = 0
Local Decimal TEMPAMT2 : TEMPAMT2 = 0
Local Decimal BNKCHARGEAMOUNT
Local Integer STATI

Filter [F:PYH] Where PAYLOT = [M:PAY0]PAYLOT
For [PYH]
  #get banchargeamount from paymentd (acctyp = 2)
  [L]BNKCHARGEAMOUNT = func GETBANKCHARGEAMOUNT([F:PYH]NUM)

    If [PYH]CUR = [M:PAY4]BANCUR # payment currency = bank currency
      If [PYH]SNS = 2 # Revenue
        PROBALVAL += [PYH]AMTCUR
        #bankcharge
        PROBALVAL += [L]BNKCHARGEAMOUNT
      Else # Expense
        PROBALVAL -= [PYH]AMTCUR
        #bankcharge
        PROBALVAL -= [L]BNKCHARGEAMOUNT
      Endif
    Else # payment currency != bank currency
       Call CONVERT([F:PYH]CUR,[M:PAY4]BANCUR,[M:PAY4]BANCUR,[F:TPY]RATTYP,
&     [F:PYH]ACCDAT,[F:PYH]AMTCUR,TEMPAMT,STATI) From TRTDEV
      #bankcharge
      Call CONVERT([F:PYH]CUR,[M:PAY4]BANCUR,[M:PAY4]BANCUR,[F:TPY]RATTYP,
&     [F:PYH]ACCDAT,BNKCHARGEAMOUNT,TEMPAMT2,STATI) From TRTDEV

      If [PYH]SNS = 2 # Revenue
        PROBALVAL += TEMPAMT
        PROBALVAL += TEMPAMT2
      Else # Expense
        PROBALVAL -= TEMPAMT
        PROBALVAL -= TEMPAMT2
      Endif
    Endif

  Next

Filter [F:PYH]

Return

#SAM 108267 angre 16.09.15
#** #############################################################################################################
#*
#* Function determines the bank charge amount ([F:PYD]ACCTYP = 2) from table PAYMENTD for a given Number
#*
#* @param   Variable Char NUMBER         Payment number

#*
#* @return  Decimal Bankcharge           bank charge amount
#*! #############################################################################################################

Funprog GETBANKCHARGEAMOUNT(NUMBER)
Variable Char NUMBER
Local Decimal BANKCHARGE : BANKCHARGE = 0
  If !clalev([F:PYD]) : Local File PAYMENTD [PYD] : Endif
  Filter [F:PYD] Where [F:PYD]NUM = NUMBER
  For [F:PYD]
    If [F:PYD]ACCTYP = 2
      BANKCHARGE += [F:PYD]AMTLIN
    Endif
  Next
  Filter [F:PYD]
End BANKCHARGE


# YYFIN_88764
Funprog CALSTAPYL(LOT)
Value Char LOT()
If [L]LOT="" : End 0 : Endif
If clalev([F:PYHL1])=0 : Local File PAYMENTH   [PYHL1] : Endif
Local Integer OK

Filter [PYHL1] Where PAYLOT=[L]LOT & STA<5
OK=1
For [PYHL1]
 OK=0 : Break
Next
Filter [PYHL1]
If OK=1
 End 5
Else
 End 0
Endif
End

