#<AdxTL>@(#)12.0.0.0 $Revision$
$ACTION
Case ACTION
    When "IMPORT"        : Gosub IMPORT
    When "IMP_OUVRE"     : Gosub OUVRE
    When "IMP_ZONE"      : Gosub IMP_ZONE
    When "IMP_TAB"       : Gosub IMP_ZONE
    When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD
    When "IMP_FERME"     : Gosub FERME
    When "EXPORT"        : Gosub EXPORT
Endcase
Return

$OUVRE
Global Char INTCOD
Return
# l'action EXPORT est la SEULE appellée à chaque record en export
# il n'y en a pas d'autre
$EXPORT
Local Char TRT  : TRT="3"
Local Char ACT  : ACT="1"
Local Char LANG : LANG=[F:ARX]LAN
If LANG=""
LANG="FRA"
Endif

# cg 5 avril  2004
#If [M:EXP2]NOMEXP <> ""
#    Call MAJTRADX(LANG,TRT,ACT,[M:EXP2]NOMEXP) From MAJTRAD
#    [M:EXP2]NOMEXP=""
#Endif
Return

# Mise à jour suivi des traductions
# TRT=0 traitement de ATEXTE
# TRT=1 traitement de APLSTD
# TRT=2 traitement de AREPORT
# TRT=3 traitement de AREPORTX
# ACT=0 import
# ACT=1 export
$FERME
Local Char TRT  : TRT="3"
Local Char ACT  : ACT="0"
Local Char LANG : LANG=[F:ARX]LAN
If LANG=""
LANG="FRA"
Endif

# cg 5 avril 2004
#Call MAJTRADX(LANG,TRT,ACT,[M:IMP2]NOMIMP) From MAJTRAD
Return

$IMP_ZONE
Case IMPZON
When "INTCOD"
    [M:ARY]INTCOD=[F:ZZZ]INTCOD
    IMPMOD=0
    OK=0
When "EXTCOD"
    [M:ARY]EXTCOD=[F:ZZZ]EXTCOD
    IMPMOD=0
    OK=0
When "LAN"
    [M:ARY]LAN=[F:ZZZ]LAN
    Read [ARX]ARX0=[F:ARX]INTCOD;[F:ARX]EXTCOD;[F:ARX]LAN
    If fstat GREP="C"
    Else     GREP="M"
    Endif 
    IMPMOD=0
    OK=0
Endcase
Return


$IMP_VERIF_MOD
OK=1
Return

$IMPORT
OK=1
Return
