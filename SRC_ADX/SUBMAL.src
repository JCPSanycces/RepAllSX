#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du fichier ATTMALADIE
######################################################################################
# Modifications :
#     V8 SEGAY - FQ81085 - US 1553 02/05/13 - Civility LEG
#     V8 MABON - FQ81085 - US 1554 23/04/13 - Num Sécu / PAYS du contrat
#     V8 MABOS - FQ81085 - US 1554-1553 14/05/13 - Pb de GCURLEG
######################################################################################

Raz GPILOBJ
Call OBJET("MAL",GBIDC1,"") From GOBJET
End

########################################
$ACTION

Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "LIENS"        : Gosub LIENS
 When "SETBOUT"      : Gosub SETBOUT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "FILTRE"       : Gosub FILTRE
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "FERME"        : Gosub FERME
 #86255
 When "AS_REFNUM"    : Gosub AS_REFNUM
 When "BS_REFNUM"    : Gosub BS_REFNUM
 When "RAZCRE"       : Gosub RAZCRE
Endcase

Return

$OUVRE
Gosub OUVRE From WPDEFTABLE
If clalev([F:MAL])=0  : Local File MALADIE    [MAL] : Endif
If clalev([F:MAL2])=0 : Local File MALADIE    [MAL2]: Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If clalev([F:BPA])=0  : Local File BPADDRESS  [BPA] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:CNT])=0  : Local File CONTACT    [CNT] : Endif
If clalev([F:AIN])=0  : Local File CONTACTCRM [AIN] : Endif
If clalev([F:BAN])=0  : Local File BANK       [BAN] : Endif
If clalev([F:EML])=0  : Local File EMPLOID    [EML] : Endif
Local Char VALPAYBAN(GLONBAN)
# FQ81085 - US 1553 02/05/13 - Civility LEG
Local Char    WNUMLIB(30)
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

#86255
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$FILTRE
If GUSRACS<>2
 FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
Else
 FILTSUP = "1=1"
Endif
Return

#86255
$RAZCRE
If GLEGFIL<>""
 GCURLEG=GLEGFIL
Else
 GCURLEG=GDOSLEG
Endif
Return
#

$LIENS
#86255
If GNBLEG = 1         :#=dossier mono-leg
 GCURLEG = GDOSLEG
Else                  :#=dossier multi-leg
 GCURLEG = [F:MAL]LEG
Endif
#
Call AM_FLGRCV ([M:MAL1]FLGRCV)
Call AM_FLGGEN ([M:MAL1]FLGGEN)
Call AM_FLGSPE ([M:MAL1]FLGSPE)
Call GRISE_SBG ([M:MAL2]ENAFLG)
Call AM_FCYRPBFNC([M:MAL2]FCYRPBFNC)
Read [ID]ID0=[M:MAL0]REFNUM
If !fstat
 Call GRISE_CTRNUM([F:ID]FLGMULCTR)
Endif
Diszo [M:MAL3]BUL
# FQ81085 - 23/04/13 - Lecture HRCTR pour les numéros de sécu
Filter [HRCTR] Where REFNUM=[M:MAL0]REFNUM & CTRNUM=[M:MAL0]CTRNUM & CTRDAT<=[M:MAL0]DAT
Read [HRCTR]CTR0 Last
#If fstat Then Raz [F:HRCTR] : Endif
Filter [HRCTR]
# FQ81085 - US 1553 02/05/13 - Civility LEG
If !fstat
  Call PARAM([F:HRCTR]ETRFCY,"CIVIL",WNUMLIB) From ADOVAL
Else
  Raz [F:HRCTR]
  Call PARAM([F:ID]FCYORI,"CIVIL",WNUMLIB) From ADOVAL
Endif
[M:MAL0]NOLIB=val(WNUMLIB)
If [M:MAL0]CIV>0 Then [M:MAL0]CIVA=mess([M:MAL0]CIV,val(WNUMLIB),1) : Endif
# END FQ81085 - US 1553
Return


# DBA le 06/10/04 : possibilité de créer même si le module temps est présent
# afin de gérer les maladies, maternités... des personnes ne gérant pas leur temps.

$APRES_MODIF
If [F:MAL]STAATT=3 & COUZON<>"RCVDAT" & COUZON<>"FLGRCV" & !find(COUZON,CLESEC) & !find(COUZON,CLEPRIM)
 # Modification impossible Attestation validée
 GERR = 1 : GMESSAGE = mess(9,123,1)-"\"-mess(40,10710,1)
 OK=0 : Return
Endif
## NUM = numéro chronologique
If (GREP="C" | GREP="D") & !find(COUZON,CLESEC) & !find(COUZON,CLEPRIM) & [M:MAL0]NUM>1
 Filter [MAL2] Where REFNUM=[M:MAL0]REFNUM & DAT=[M:MAL0]DAT & CTRNUM=[M:MAL0]CTRNUM
 Read [MAL2]MAL0 Last
 Filter [MAL2]
 [M:MAL0]NUM = [F:MAL2]NUM+1
 Affzo [M:MAL0]NUM
Endif
# FQ81085 - US 1553 02/05/13 - Civility LEG
# Le test sur REP et GREP ne sert à rien car n'était fait que sur COUZON="CTRNUM"
# et REP et GREP ne sont pas encore alimentés car la clé n'est pas validée
#If (COUZON="REFNUM" | COUZON="DAT" | COUZON="CTRNUM") & (GREP="C" | GREP="D")
If (COUZON="REFNUM" | COUZON="DAT" | COUZON="CTRNUM")
 Assign "[M:MAL0]"+COUZON With CZ
 GMODIF=1
 Gosub CRE_CHARGE
 Affzo [M:MAL0]
 Affzo [M:MAL1]
 Affzo [M:MAL2]
 Affzo [M:MAL3]
Endif
Return

$VERIF_CRE
Filter [MAL2] Where REFNUM=[M:MAL0]REFNUM & DAT=[M:MAL0]DAT & CTRNUM=[M:MAL0]CTRNUM
Read [MAL2]MAL0 Last
Filter [MAL2]
If [F:MAL2]NUM>=[M:MAL0]NUM
 [M:MAL0]NUM = [F:MAL2]NUM+1
 Affzo [M:MAL0]NUM
Endif
Return

$CRE_CHARGE
#Salarié
Read [F:ID]ID0=[M:MAL0]REFNUM
If !fstat
 [M:MAL0]=[F:ID]
 [M:MAL1]=[F:ID]
Endif
#
#Read [F:HRCTR]CTR0=[M:MAL0]REFNUM;[M:MAL0]CTRNUM
Filter [F:HRCTR] Where REFNUM=[M:MAL0]REFNUM & CTRNUM=[M:MAL0]CTRNUM & CTRDAT<=[M:MAL0]DAT
Read [F:HRCTR]CTR0 Last
Filter [F:HRCTR]
If !fstat
 [M:MAL0]CTRDAT=[F:HRCTR]CTRDAT    :##**82073
 [M:MAL1]JOB=[F:HRCTR]JOB
  # FQ81085 - 23/04/13 - Les numéros de sécu arrivent du contrat, et plus du salarié
 [M:MAL1]NUMSSC  = [F:HRCTR]NUMSSCCTR
 [M:MAL1]NUMSSC2 = [F:HRCTR]NUMSSCCTR2
 # FQ81085 - US 1553 02/05/13 - Civility LEG
 Call PARAM([F:HRCTR]ETRFCY,"CIVIL",WNUMLIB) From ADOVAL
 [M:MAL0]NOLIB=val(WNUMLIB)
 If [F:HRCTR]CIVCTR>0 Then
    [M:MAL0]CIVA=mess([F:HRCTR]CIVCTR,val(WNUMLIB),1)
    [M:MAL0]CIV=[F:HRCTR]CIVCTR
 Endif
 # END FQ81085 - US 1553
 Read [FCY]FCY0=[F:HRCTR]ETRFCY
 If !fstat
  [M:MAL2]FCY=[F:FCY]FCY
  [M:MAL2]FCYCRN=[F:FCY]CRN
  Read [CPY]CPY0=[F:FCY]LEGCPY
  If ! fstat
   [M:MAL3]CURSAL=[F:CPY]ACCCUR
   #86255
   If dim([M:MAL0]LEG)>0 : [M:MAL0]LEG=[F:CPY]LEG : Affzo [MAL0]LEG : Endif
   GCURLEG=[F:CPY]LEG
   #
  Endif
  Read [BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
  If !fstat
   [M:MAL2]FCYADDLIG(0)=[F:BPA]BPAADDLIG(0)
   [M:MAL2]FCYADDLIG(1)=[F:BPA]BPAADDLIG(1)
   [M:MAL2]FCYADDLIG(2)=[F:BPA]BPAADDLIG(2)
   [M:MAL2]FCYPOSCOD=[F:BPA]POSCOD
   [M:MAL2]FCYCTY=[F:BPA]CTY
   [M:MAL2]FCYCRY=[F:BPA]CRY
   [M:MAL2]FCYTEL=[F:BPA]TEL
  Endif
  Read [F:CNT]CNT0=3;[F:FCY]FCY;[F:FCY]CNTNAM
  If ! fstat
   Read [F:AIN]AIN0=[F:FCY]CNTNAM
   If !fstat
    [M:MAL2]FCYRPB=[F:AIN]CNTLNA-[F:AIN]CNTFNA
    [M:MAL2]FCYRPBFNC=[F:CNT]CNTFNC
    Read [BPA]BPA0=3;[F:FCY]FCY;[F:CNT]BPAADD
    If ! fstat : [M:MAL2]PLCREF=[F:BPA]CTY : Endif
   Endif
  Endif
  If [F:FCY]PAYBAN<>""
   Read [F:BAN]BAN0=[F:FCY]PAYBAN
   If !fstat
    [M:MAL2]FCYBID=[F:BAN]BIDNUM
    [M:MAL2]FCYBIDCRY=[F:BAN]CRY
    [M:MAL2]FCYCUR=[F:BAN]CUR
    [M:MAL2]DESBID=[F:BAN]PAB1
   Endif
  Else
   Call PARAM([F:FCY]LEGCPY,"PAYBAN",VALPAYBAN) From ADOVAL
   If VALPAYBAN<>""
    Read [F:BAN]BAN0=VALPAYBAN
    If !fstat
     [F:MAL]FCYBID=[F:BAN]BIDNUM
     [F:MAL]FCYBIDCRY=[F:BAN]CRY
     [F:MAL]FCYCUR=[F:BAN]CUR
     [F:MAL]DESBID=[F:BAN]PAB1
    Endif
   Endif
  Endif
 Endif
Else
 # FQ81085 - US 1553 02/05/13 - Civility LEG
 Call PARAM([F:ID]FCYORI,"CIVIL",WNUMLIB) From ADOVAL
 [M:MAL0]NOLIB=val(WNUMLIB)
 If [F:ID]CIV>0 Then
    [M:MAL0]CIVA=mess([F:ID]CIV,val(WNUMLIB),1)
    [M:MAL0]CIV=[F:ID]CIV
 Endif
Endif
[M:MAL2]ENAFLG=2
[M:MAL2]STRSBG=[M:MAL0]DAT
[M:MAL2]ENDSBG=[M:MAL0]DAT
[M:MAL2]DATREF=date$
Return

# Possibilité de créer même si le module temps est présent
# afin de gérer les maladies, maternités... des personnes ne gérant pas leur temps.

$SETBOUT
# Appelé de SUBDLA
# 39925
If REP="M"| GHISTO=1
 Call VIREBOUT(CHAINE,"BG") From GOBJET :# Désactive le bouton extraction
Endif
# fin 39925
Call VIREBOUT (CHAINE,"H") From GOBJET  #pour désactiver le bouton chgt clé
#Objet à 3 éléments de clé : ajout du btn suppression
If CLECUR  CHAINE+="A"  Endif
If dim([M]STAATT)>0 & [M]STAATT=3
 Call VIREBOUT (CHAINE,"A") From GOBJET
Endif
#86255
If dim([M]STAATT)>0 & ([M]STAATT<>2 | GCURLEG<>"FRA")
 Call VIREBOUT (CHAINE,"G") From GOBJET
Endif

#DEHEN - 2016-08-05 - New Creation to set Check box values an validations
If GFLAG = "MAL"
  Call AM_FLGRCV ([M:MAL1]FLGRCV)
  Call AM_FLGGEN ([M:MAL1]FLGGEN)
  Call AM_FLGSPE ([M:MAL1]FLGSPE)
Endif

Return

#Pour se positionner sur le dernier enreg après extraction
$EXEBOUT
If BOUT="B" & GSTATUT=GSTAOK
 Read [F:MAL]MAL1 Last
 If !fstat
  [M:MAL0]=[F:MAL]
  [M:MAL1]=[F:MAL]
  [M:MAL2]=[F:MAL]
  [M:MAL3]=[F:MAL]
  Affzo [M:MAL0]
  Affzo [M:MAL1]
  Affzo [M:MAL2]
  Affzo [M:MAL3]
 Endif
Endif
If BOUT="G"
 Gosub RELIT From GOBJSUB
Endif
Return

#86255
#Before selection on field REFNUM
#############
$AS_REFNUM
Raz GCURLEG
Return

#After selection on field REFNUM
############
$BS_REFNUM
If mkstat>0
 If dim([M:MAL0]LEG)>=0
  GCURLEG=[M:MAL0]LEG
 Elsif GLEGFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return
#

######################################################################################
## Etiquette (écran MAL0)
######################################################################################
Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Filter [F:MAL] Where REFNUM=VALEUR
Read [F:MAL]MAL0 Last
Filter [MAL]
If fstat<=2
 [M:MAL0]DAT = [F:MAL]DAT
 [M:MAL0]CTRNUM = [F:MAL]CTRNUM
 [M:MAL0]CTRDAT = [F:MAL]CTRDAT
 Affzo [M:MAL0]DAT,CTRNUM
 #86255
 If dim([M:MAL0]LEG)>0 : [M:MAL0]LEG=[F:MAL]LEG : Affzo [M:MAL0]LEG : Endif
 GCURLEG=[F:MAL]LEG
Else
 Raz [M:MAL0]CTRNUM,CTRDAT,DAT
 #86255
 If dim([M:MAL0]LEG)>0 : Raz [M:MAL0]LEG : Endif
 Raz GCURLEG
 mkstat=4
Endif
Call GRISE_CTRNUM([F:ID]FLGMULCTR)
End


Subprog AM_DAT(VALEUR)
Variable Date    VALEUR()
Filter [F:MAL] Where REFNUM=[M:MAL0]REFNUM & DAT=VALEUR
Read [F:MAL]MAL0 Last
Filter [MAL]

If fstat<=2
 [M:MAL0]CTRNUM = [F:MAL]CTRNUM
 [M:MAL0]CTRDAT = [F:MAL]CTRDAT
 Affzo [M:MAL0]CTRNUM
 #86255
 If dim([M:MAL0]LEG)>0 : [M:MAL0]LEG=[F:MAL]LEG : Affzo [M:MAL0]LEG : Endif
 GCURLEG=[F:MAL]LEG
Else
 Raz [M:MAL0]CTRNUM,CTRDAT
 #86255
 If dim([M:MAL0]LEG)>0 : Raz [M:MAL0]LEG : Endif
 Raz GCURLEG
 mkstat=4

 #DEHEN - 2016-08-04 : START
 #Testing to get correct error message when [F:ID]FLGMULCTR = 2. Was not invoked.
 Call CHERCHE_CTR([M:MAL0]REFNUM,VALEUR,[M:MAL0]CTRNUM) From DIVPAYE
   If [M:MAL0]CTRNUM=""
   Call GRISE_CTRNUM([F:ID]FLGMULCTR)
   GMESSAGE=mess(158,10702,1) :#A créer
   mkstat=2 : End
  Endif
 If [F:ID]FLGMULCTR<>2
  [M:MAL0]CTRDAT=[F:HRCTR]CTRDAT
  #86255
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  If dim([M:MAL0]LEG)>0 : [M:MAL0]LEG=[F:CPY]LEG : Affzo [M:MAL0]LEG : Endif
  GCURLEG=[F:CPY]LEG
 Else
  GCURLEG=GLEGFIL
 Endif
 #DEHEN - 2016-08-04 : END
# If [F:ID]FLGMULCTR<>2
#  Call CHERCHE_CTR([M:MAL0]REFNUM,VALEUR,[M:MAL0]CTRNUM) From DIVPAYE
#  If [M:MAL0]CTRNUM=""
#   GMESSAGE=mess(158,10702,1) :#A créer
#   mkstat=2 : End
#  Endif
#  [M:MAL0]CTRDAT=[F:HRCTR]CTRDAT
#  #86255
#  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
#  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#  If dim([M:MAL0]LEG)>0 : [M:MAL0]LEG=[F:CPY]LEG : Affzo [M:MAL0]LEG : Endif
#  GCURLEG=[F:CPY]LEG
# Else
# GCURLEG=GLEGFIL
# Endif
 Affzo [M:MAL0]CTRNUM
Endif

End

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR
If [M:MAL0]CTRNUM=""
 Call SELCTR([M:MAL0]REFNUM,[M:MAL0]DAT,[M:MAL0]DAT,VALEUR) From DIVPAYE
 [M:MAL0]CTRDAT=[F:HRCTR]CTRDAT
 [M:MAL0]CTRNUM=VALEUR
 Affzo [M:MAL0]CTRNUM
 #86255
 If dim([M:MAL0]LEG)>0 : [M:MAL0]LEG=GCURLEG : Affzo [M:MAL0]LEG : Endif
 #
Endif
End

Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:MAL0]CTRNUM
Else
 Diszo [M:MAL0]CTRNUM
Endif
Affzo [M:MAL0]CTRNUM
End

Subprog AM_STAATT(VALEUR)
Variable Integer VALEUR
Local Integer OK
If VALEUR=3
 OK = 2
 # Validation manuelle de l'attestation
 Call AVERTIR(mess(41,10710,1),OK) From GESECRAN
 If OK<>2 : mkstat=2 : Endif
Endif
End

######################################################################################
## Etiquette (écran MAL1)
######################################################################################

Subprog AM_FLGRCV(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Effzo [M:MAL1]RCVDAT,RCVMIDWRK
 Grizo [M:MAL1]RCVDAT,RCVMIDWRK
Else
 Actzo [M:MAL1]RCVDAT,RCVMIDWRK
Endif
End

Subprog AM_FLGGEN(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:MAL1]NBRHRSGEN,AMTGEN
Else
 Effzo [M:MAL1]NBRHRSGEN,AMTGEN
 Grizo [M:MAL1]NBRHRSGEN,AMTGEN
Endif
End

Subprog AM_FLGSPE(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:MAL1]NBRHRSSPE,AMTSPE
Else
 Effzo [M:MAL1]NBRHRSSPE,AMTSPE
 Grizo [M:MAL1]NBRHRSSPE,AMTSPE
Endif
End


######################################################################################
## Etiquette (écran MAL2)
######################################################################################
Subprog C_DATREF(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M:MAL0]DAT
 # La date de signature doit être supérieure au
 GMESSAGE = mess(26,10710,1)-num$([M:MAL0]DAT)
 mkstat = 2 : End
Endif
End

Subprog AM_ENAFLG(VALEUR)
Variable Integer VALEUR
Call GRISE_SBG(VALEUR)
End

Subprog GRISE_SBG(VALEUR)
Value Integer VALEUR
If VALEUR=1
 Effzo [M:MAL2]STRSBG : Grizo [M:MAL2]STRSBG
 Effzo [M:MAL2]ENDSBG : Grizo [M:MAL2]ENDSBG
 Effzo [M:MAL2]FCYBID : Grizo [M:MAL2]FCYBID
 Effzo [M:MAL2]FCYCUR : Grizo [M:MAL2]FCYCUR
 Effzo [M:MAL2]DESBID : Grizo [M:MAL2]DESBID
Else
 Actzo [M:MAL2]STRSBG
 Actzo [M:MAL2]ENDSBG
 Actzo [M:MAL2]FCYBID
 Actzo [M:MAL2]FCYCUR
 Actzo [M:MAL2]DESBID
Endif
Affzo [M:MAL2]10
End

Subprog AM_FCYRPBFNC(VALEUR)
Variable Integer VALEUR
If VALEUR=10
 Actzo [M:MAL2]FCYRPBFNC2
Else
 Effzo [M:MAL2]FCYRPBFNC2
 Grizo [M:MAL2]FCYRPBFNC2
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran MAL0) 21/05/2013 09:38:00 (LANEG)
######################################################################################
#86255
Subprog AS_STAATT(VALEUR)
Variable Integer VALEUR
If GCURLEG<>"FRA"
  GMENLOC(2)=1
Endif
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
#Call CHERCHE_CTR([M:MAL0]REFNUM,[M:MAL0]DAT,VALEUR) From DIVPAYE
#If VALEUR=""
# GMESSAGE=mess(158,10702,1)
# mkstat=2 : End
#Endif
#[M:MAL0]CTRDAT=[F:HRCTR]CTRDAT
##86255
#Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
#Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#If dim([M:MAL0]LEG)>0 : [M:MAL0]LEG=[F:CPY]LEG : Affzo [MAL0]LEG : Endif
#GCURLEG=[F:CPY]LEG

Filter [HRCTR] Where REFNUM=[M:MAL0]REFNUM & CTRDAT<=[M:MAL0]DAT & CTRNUM=VALEUR
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If fstat<=2
 [M:MAL0]CTRNUM=VALEUR
 [M:MAL0]CTRDAT=[F:HRCTR]CTRDAT
 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 If dim([M:MAL0]LEG)>0 : [M:MAL0]LEG=[F:CPY]LEG : Affzo [M:MAL0]LEG : Endif
 GCURLEG=[F:CPY]LEG
Else
 GCURLEG=GLEGFIL
 GMESSAGE=mess(158,10702,1)
 mkstat=2 : End
Endif

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran MAL1) 08/11/2013 18:30:59 (LANEG)
######################################################################################
#92831
Subprog C_ANTDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0]
 If VALEUR<[M:MAL0]DAT
  #La date de reprise anticipée doit être supérieure à la date d'arrêt
  GMESSAGE = mess(45,710,1)
  mkstat = 2 : End
 Endif
 If [M:MAL1]RCVDAT<>[0/0/0] & VALEUR>[M:MAL1]RCVDAT
 #La date de reprise anticipée doit être inférieure à la date de reprise
  GMESSAGE = mess(46,710,1)
  mkstat = 2 : End
 Endif
Endif
End


######################################################################################
######################################################################################
## Section automatically added (screen MAL3) 06/14/2016 16:32:50 (MAPAD)
######################################################################################
Subprog AM_LOSSAL(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0
    Raz [MAL3]SALRES(nolign-1)
    Affzo [MAL3]SALRES(nolign-1)
  Endif
End


######################################################################################

######################################################################################
## Section automatically added (screen MAL3) 06/15/2016 15:06:29 (MAPAD)
######################################################################################
Subprog AM_SALRES(VALEUR)
Variable Decimal VALEUR
 If VALEUR<>0
    Raz [MAL3]LOSSAL(nolign-1)
    Affzo [MAL3]LOSSAL(nolign-1)
  Endif
End


######################################################################################

