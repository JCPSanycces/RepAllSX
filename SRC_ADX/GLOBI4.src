#***********************************************************
#      D O T A T I O N   -   E X E R C I C E
#***********************************************************
#
# Modèle
#If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]AASREF = [F:DEPC]AASREF and [F:DEPC]DPRPLN = [F:DEPC]DPRPLN ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

#########################################################
Subprog  CAL_DOT_EXE
#
# - Objet  : Calcule la dotation de l'exercice
#
# - Entrée : [M:DIV] Structure Cdota
#
  # If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # FQ114113
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    FIYDPC                  E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  If ( G_ETP_GLOBI4 ) Then
    G_SKPSTD = 0
    GPOINT = "FIYDPC" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9100 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  # -1 --------------------------------------------
  If ( not G_SKPSTD ) Then
    # -2 --------------------------------------------
    If ( [M:DPM]DPRMODTYP([M:DIV]INDMOD-1) = GVML_TMSTAND ) Then
      # Mode d'amortissement standard

      Case [M:DIV]MODAMT

        When G_DPMSA
         [M:DIV]LVLLIB = "4FR.CAL_DOT_EXE_SA" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_SA  From =G_GLOB4FR  : # Français - Sans amortissement
        When G_DPMLP
         [M:DIV]LVLLIB = "4FR.CAL_DOT_EXE_LP" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_LP  From =G_GLOB4FR  : # Français - Linéaire
        When G_DPMDF
         [M:DIV]LVLLIB = "4FR.CAL_DOT_EXE_DF" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_DF  From =G_GLOB4FR  : # Français - Dégressif français
        When G_DPMRE
         [M:DIV]LVLLIB = "4FR.CAL_DOT_EXE_RE" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_RE  From =G_GLOB4FR  : # Français - Résiduel
        When G_DPMUO
         [M:DIV]LVLLIB = "4FR.CAL_DOT_EXE_UO" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_UO  From =G_GLOB4FR  : # Français - Unités d'OEUVRE
        When G_DPMSY
         [M:DIV]LVLLIB = "4FR.CAL_DOT_EXE_SY" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_SY  From =G_GLOB4FR  : # Français - SOFTY
        When G_DPMPR
         [M:DIV]LVLLIB = "4FR.CAL_DOT_EXE_PR" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_PR  From =G_GLOB4FR  : # Français - Progressif
        When G_DPMFM
         [M:DIV]LVLLIB = "4FR.CAL_DOT_EXE_FM" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_FM  From =G_GLOB4FR  : # Français - Formes & Moules
        When G_DPMLG
         [M:DIV]LVLLIB = "4FR.CAL_DOT_EXE_LG" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_LG  From =G_GLOB4FR  : # Français - Linge
        When G_DPMLV
         [M:DIV]LVLLIB = "4FR.CAL_DOT_EXE_LV" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_LV  From =G_GLOB4FR  : # Français - Linéaire au dela VR nulle
        When G_DPMCA
         [M:DIV]LVLLIB = "4FR.CAL_DOT_EXE_CA" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_CA  From =G_GLOB4FR  : # Français - Caducité sur valeur brute
        When G_DPMRA
         [M:DIV]LVLLIB = "4FR.CAL_DOT_EXE_RA" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_RA  From =G_GLOB4FR  : # Français - Caducité sur valeur résiduelle
        When G_DPM1P
         [M:DIV]LVLLIB = "4FR.CAL_DOT_EXE_1P" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_1P  From =G_GLOB4FR  : # Français - One period FQ84110

        When G_DPMIT
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_IT" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_IT  From =G_GLOB4  : # Italien - Ordinario - Anticipato

        When G_DPMPC
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_PC" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_PC  From =G_GLOB4  : # Portugais "Constantes"
        When G_DPMPD
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_PD" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_PD  From =G_GLOB4  : # Portugais "Constantes por Duodecimos"
        When G_DPMDP
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_DP" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_DP  From =G_GLOB4  : # Portugais "Degressif Portugais"
        When G_DPMDV
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_DV" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_DV  From =G_GLOB4  : # Portugais "Degressif Portugais Mixte"

        When G_DPMUD
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_UD" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_UD  From =G_GLOB4  : # Anglais "Declining Balance"
        When G_DPMUL
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_UL" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_UL  From =G_GLOB4  : # Anglais "Straight Line"

        When G_DPMDB
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_DB" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_DB  From =G_GLOB4  : # Belge "Dégressif Belge"
        When G_DPMLB
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_LB" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_LB  From =G_GLOB4  : # Belge "Linéaire Belge"

        When G_DPMDA
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_DA" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_DA  From =G_GLOB4  : # Allemand "Dégressif Allemand Constant"
        When G_DPMDX
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_DX" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_DX  From =G_GLOB4  : # Allemand "Dégressif Allemand Mixte"

        When G_DPMSL
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_SL" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_SL  From =G_GLOB4  : # Espagnol "Linéaire espagnol jour" FQ82075
        When G_DPMLE
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_LE" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_LE  From =G_GLOB4  : # Espagnol "Linéaire Espagnol mois"
        When G_DPMDE
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_DE" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_DE  From =G_GLOB4  : # Espagnol "Dégressif Espagnol Pur"
        When G_DPMDI
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_DI" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_DI  From =G_GLOB4  : # Espagnol "Dégressif Espagnol Mixte"

        When G_DPMDM
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_DM" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_DM  From =G_GLOB4  : # Marocain "Dégressif Marocain" FQ55960

        When G_DPMLR
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_LR" : Gosub CAL_ADDLVL  From =G_GLOB0
         Call CAL_DOT_EXE_LR  From =G_GLOB4RU  : # Russe "Linéaire russe" FQ59941
        When G_DPMDR
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_DR" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_DR  From =G_GLOB4RU  : # Russe "Dégressif russe" FQ59941
        When G_DPMCR
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_CR" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_CR  From =G_GLOB4RU  : # Russe "Constant russe" FQ59941
        When G_DPMSR
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_SR" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_SR  From =G_GLOB4RU  : # Russe "SOFTY russe" FQ59941
        When G_DPMUR
         [M:DIV]LVLLIB = "4.CAL_DOT_EXE_UR" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_UR  From =G_GLOB4RU  : # Russe "Unité d'oeuvre russe" FQ59941

        When G_DPMML
          # FQ67577
          [M:DIV]LVLLIB = "4.CAL_DOT_EXE_ML" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_ML  From =G_GLOB4PL  : # Pologne "Linéaire polonais"
        When G_DPMMD
          [M:DIV]LVLLIB = "4.CAL_DOT_EXE_MD" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_MD  From =G_GLOB4PL  : # Pologne "Dégressif polonais" FQ72372

        When G_DPMRL
          [M:DIV]LVLLIB = "4.CAL_DOT_EXE_RL" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_RL  From =G_GLOB4PL  : # Roumanie "Linéaire roumain" FQ77877
        When G_DPMRX
          [M:DIV]LVLLIB = "4.CAL_DOT_EXE_RX" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_RX  From =G_GLOB4PL  : # Roumanie "Accéléré roumain"
        When G_DPMRD
          [M:DIV]LVLLIB = "4.CAL_DOT_EXE_RD" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_RD  From =G_GLOB4PL  : # Roumanie "Dégressif roumain"

        When G_DPMAL
          [M:DIV]LVLLIB = "4.CAL_DOT_EXE_AL" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_AL  From =G_GLOB4PL  : # Australie "Prime Cost" FQ84283
        When G_DPMAD
          [M:DIV]LVLLIB = "4.CAL_DOT_EXE_AD" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_AD  From =G_GLOB4PL  : # Australie "Diminishing value" FQ84283

        When G_DPMHL
          [M:DIV]LVLLIB = "4.CAL_DOT_EXE_HL" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_HL  From =G_GLOB4PL  : # Suisse "Linéaire suisse" FQ84281
        When G_DPMHD
          [M:DIV]LVLLIB = "4.CAL_DOT_EXE_HD" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_HD  From =G_GLOB4PL  : # Suisse "Dégressif suisse" FQ84281


        When G_DPMTL
          [M:DIV]LVLLIB = "4.CAL_DOT_EXE_TL" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_TL  From =G_GLOB4PL  : # Turquie "Linéaire turque" FQ105809
        When G_DPMTD
          [M:DIV]LVLLIB = "4.CAL_DOT_EXE_TD" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_EXE_TD  From =G_GLOB4PL  : # Turquie "Dégressif turque" FQ105809
      Endcase
    Else
    # -2 --------------------------------------------
      # Mode d'amortissement libre
      [M:DIV]LVLLIB = "4.CAL_DOT_EXE_MLB" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CAL_DOT_EXE_MLB  From =G_GLOB4
    Endif
    # -2 --------------------------------------------
  Endif
  # -1 --------------------------------------------

  If ([M:DIV]ERROR) Then : End : Endif

  # Préparation avant calcul d'une dotation exercice
  [M:DIV]LVLLIB = "4.CAL_APRES_CAL_DOT_EXE" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CAL_APRES_CAL_DOT_EXE From  =G_GLOB4

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#########################################################
Subprog  CAL_AVANT_CAL_DOT_EXE
#
# - Objet  : .......
#
# - Entrée :
#
# - Sortie :
#
#   Boite noire gcfc08
#
# ----------------------

Local Integer I_P

  #If ([M:DIV]BDEBUG) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # Intialisations diverses
  [M:DIV]FLGSLDPER = 0

  # Recherche indice du mode d'amortissement
  [M:DIV]LVLLIB = "8.CAL_LOCALISE_MODE" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CAL_LOCALISE_MODE
&      ( [M:DIV]MODAMT,
&        [F:DEPC]STRDPRDAT,
&        [F:DEPC]FIYSTRDAT,
&        [F:DEPC]FIYENDDAT,
&        [M:DIV]INDMOD,
&        [M:DIV]INDANNLB,
&        [M:DIV]TXLB,
&        [M:DIV]TX2LB,
&        [M:DIV2]RGRPPER ) From =G_GLOB8  : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
  If ([M:DIV]ERROR) Then :  End : Endif

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # Type de prorata
  Call CAL_TYPE_PRORATA
&    ( [M:DIV]MODAMT,
&      [F:DEPC]ALWCOD,
&      [F:DEPC]PRATYP,
&      [M:CNX]PROWEK ([F:DEPC]CNX-1)-1,
&      [M:DIV]PROEXEMDB,
&      [M:DIV]PROEXEMLB,
&      [M:DPM]PROTYP([M:DIV]INDMOD-1),
&      [M:DIV]TYPPRO,
&      [M:DIV]TYPPRODAT ) From =G_GLOB8
  If ( [M:DIV]ERROR ) Then : End : Endif

  [F:DEPC]PRATYP = [M:DIV]TYPPRO

  # Ajustement dates d'exercice
  Local Integer WINDEXE
  #  Call CAL_EXERCICE_SELON_DATE
  #&      ( [F:DEPC]STRDPRDAT, [M:DIV]TYPPRO, [M:DIV]DTDBEXI, [M:DIV]DTFNEXI, WINDEXE ) From =G_GLOB8
  [M:DIV]PD(0)= [F:DEPC]STRDPRDAT : [M:DIV]PV(0)= [M:DIV]TYPPRO
  Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
  [M:DIV]DTDBEXI = [M:DIV]RD(1) : [M:DIV]DTFNEXI = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
  If ([M:DIV]ERROR) Then : End : Endif

  #--
  #Call CAL_AJUST_DATE_SELON_PRORATA ( [M:DIV]TYPPRO, [F:DEPC]FIYSTRDAT, "D", [M:DIV]DTDBEXE) From =G_GLOB8
  [M:DIV]PE(0)= [M:DIV]TYPPRO : [M:DIV]PD(0)= [F:DEPC]FIYSTRDAT : [M:DIV]PC(0)= "D"
  Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
  [M:DIV]DTDBEXE = [M:DIV]RD(0)
  #Call CAL_AJUST_DATE_SELON_PRORATA ( [M:DIV]TYPPRO, [F:DEPC]FIYENDDAT, "F", [M:DIV]DTFNEXE) From =G_GLOB8
  [M:DIV]PE(0)= [M:DIV]TYPPRO : [M:DIV]PD(0)= [F:DEPC]FIYENDDAT : [M:DIV]PC(0)= "F"
  Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
  [M:DIV]DTFNEXE = [M:DIV]RD(0)
  # Ajustement dates période (pour affectation éventuelle [M:DIV]EXEDATREF avec [M:DIV]DTDBPER )
  Call ECR_FICH("FS1",9,"Période à partir de laquelle est calculé la dotation exercice" ) From =G_GLOB0
  Call CAL_AJUST_PERIODE ( [M:DIV]TYPPRO,
&      [F:DEPC]PERSTRDAT, [F:DEPC]PERENDDAT, [M:DIV]DTDBPER, [M:DIV]DTFNPER ) From =G_GLOB5

  # Durée exercice de référence selon le type de prorata
  Call CAL_DUR_EXE_REF ([M:DIV]DTDBEXE, [M:DIV]DTFNEXE, [M:DIV]TYPPRO, [M:DIV]DUREXE) From =G_GLOB8

  # Date de début d'amortissement régularisée
  [M:DIV]LVLLIB = "4.CAL_DATE_DEBUT_AMORT_REG" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CAL_DATE_DEBUT_AMORT_REG  From =G_GLOB4
  If ([M:DIV]ERROR) Then : End : Endif

  # Durée d'amortissement régularisée
  [M:DIV]DURAMTREG = [F:DEPC]DPRDUR

  # Date de sortie régularisée
  [M:DIV]LVLLIB = "4.CAL_DATE_SORTIE_REG" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CAL_DATE_SORTIE_REG  From =G_GLOB4
  If ([M:DIV]ERROR) Then : End : Endif

  # Date de fin d'amortissement ( à dégager dès que possible)
  [M:DIV]LVLLIB = "4.CAL_DATE_FIN_AMORT" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CAL_DATE_FIN_AMORT  From =G_GLOB4
  If ([M:DIV]ERROR) Then : End : Endif

  # Evaluation de l'aide fiscale
  [M:DIV]AFI = 0
  If ( [F:DEPC]ALWCOD <> 0 and [F:DEPC]ALWCOD <> GVML_RPAUCUN ) Then
    [M:DIV]LVLLIB = "4.CAL_AIDE_FISCALE" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CAL_AIDE_FISCALE  From =G_GLOB4
    If ([M:DIV]ERROR) Then : End : Endif
  Endif


  # ----------------
  # -- CADUCITE
  # ----------------

  # Durée appliquée à 0 car uniquement pour le mode CA
  [M:DIV]APLDUR = 0

  [M:DIV]SUB = 0.
  #-1 ----------------------------------
  If ( [M:DIV]MODAMT = G_DPMCA or [M:DIV]MODAMT = G_DPMRA ) Then

    # A faire toujours car la subvention est utilisée par la suite pour calculer la dotation Exercice
    #-2 ----------------------------------
    If ( [M:DIV]CCNMOD = GVML_GCFIR ) Then
      #-3 ----------------------------------
      If ( [M:DIV]PLNSUB ) Then
        # Le plan subvention existe
        If ( [M:DIV]DL > [M:PSUB]NB_DEP ) Then
          # Si le plan Subvention n'est pas en phase - Dernier Deprec Subvention considéré
          [M:DIV]SUB = [M:PSUB]DPRBAS([M:PSUB]NB_DEP-1)
        Else
          # Si le plan Subvention est en phase - Deprec courant Subvention considéré
          [M:DIV]SUB = [M:PSUB]DPRBAS([M:DIV]DL-1)
        Endif
      Endif
      #-3 ----------------------------------
    Endif
    #-2 ----------------------------------
    If ( [M:DIV]CCNMOD = GVML_GCRNW ) Then
      #-3 ----------------------------------
      If ( [M:DIV]CCNGRTFLG = G_OUI ) Then
        # Un plan de subvention dédié existe
        Case [M:DIV]CCNGRTPLN
          When G301FIS
            If ( [M:DIV]DL > [M:PFIS]NB_DEP ) Then
              # Si le plan Subvention n'est pas en phase - Dernier Deprec Subvention considéré
              [M:DIV]SUB = [M:PFIS]DPRBAS([M:PFIS]NB_DEP-1)
            Else
              # Si le plan Subvention est en phase - Deprec courant Subvention considéré
             [M:DIV]SUB = [M:PFIS]DPRBAS([M:DIV]DL-1)
            Endif
          When G301ORI
            If ( [M:DIV]DL > [M:PORI]NB_DEP ) Then : [M:DIV]SUB = [M:PORI]DPRBAS([M:PORI]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PORI]DPRBAS([M:DIV]DL-1)       : Endif
          When G301R76
            If ( [M:DIV]DL > [M:PR76]NB_DEP ) Then : [M:DIV]SUB = [M:PR76]DPRBAS([M:PR76]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PR76]DPRBAS([M:DIV]DL-1)       : Endif
          When G301IAS
            If ( [M:DIV]DL > [M:PIAS]NB_DEP ) Then : [M:DIV]SUB = [M:PIAS]DPRBAS([M:PIAS]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PIAS]DPRBAS([M:DIV]DL-1)       : Endif
          When G301TEC
            If ( [M:DIV]DL > [M:PTEC]NB_DEP ) Then : [M:DIV]SUB = [M:PTEC]DPRBAS([M:PTEC]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PTEC]DPRBAS([M:DIV]DL-1)       : Endif
          When G301RET
            If ( [M:DIV]DL > [M:PRET]NB_DEP ) Then : [M:DIV]SUB = [M:PRET]DPRBAS([M:PRET]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PRET]DPRBAS([M:DIV]DL-1)       : Endif
          When G301SUB
            If ( [M:DIV]DL > [M:PSUB]NB_DEP ) Then : [M:DIV]SUB = [M:PSUB]DPRBAS([M:PSUB]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PSUB]DPRBAS([M:DIV]DL-1)       : Endif
          When G301LI1
            If ( [M:DIV]DL > [M:PLI1]NB_DEP ) Then : [M:DIV]SUB = [M:PLI1]DPRBAS([M:PLI1]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PLI1]DPRBAS([M:DIV]DL-1)       : Endif
          When G301LI2
            If ( [M:DIV]DL > [M:PLI2]NB_DEP ) Then : [M:DIV]SUB = [M:PLI2]DPRBAS([M:PLI2]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PLI2]DPRBAS([M:DIV]DL-1)       : Endif
          When G301LI3
            If ( [M:DIV]DL > [M:PLI3]NB_DEP ) Then : [M:DIV]SUB = [M:PLI3]DPRBAS([M:PLI3]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PLI3]DPRBAS([M:DIV]DL-1)       : Endif
          When G301LI4
            If ( [M:DIV]DL > [M:PLI4]NB_DEP ) Then : [M:DIV]SUB = [M:PLI4]DPRBAS([M:PLI4]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PLI4]DPRBAS([M:DIV]DL-1)       : Endif
          When G301LI5
            If ( [M:DIV]DL > [M:PLI5]NB_DEP ) Then : [M:DIV]SUB = [M:PLI5]DPRBAS([M:PLI5]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PLI5]DPRBAS([M:DIV]DL-1)       : Endif
          When G301LI6
            If ( [M:DIV]DL > [M:PLI6]NB_DEP ) Then : [M:DIV]SUB = [M:PLI6]DPRBAS([M:PLI6]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PLI6]DPRBAS([M:DIV]DL-1)       : Endif
          When G301MIN
            If ( [M:DIV]DL > [M:PMIN]NB_DEP ) Then : [M:DIV]SUB = [M:PMIN]DPRBAS([M:PMIN]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PMIN]DPRBAS([M:DIV]DL-1)       : Endif
          When G301CPT
            If ( [M:DIV]DL > [M:PCPT]NB_DEP ) Then : [M:DIV]SUB = [M:PCPT]DPRBAS([M:PCPT]NB_DEP-1)
                                              Else : [M:DIV]SUB = [M:PCPT]DPRBAS([M:DIV]DL-1)       : Endif
        Endcase
      Endif
      #-3 ----------------------------------
    Endif
    #-2 ----------------------------------

    # FQ 54343
    # Caducité passage de CA (sans règle particulière) à RA
    #          passage en résiduel si changement de méthode avec cumul E-1 <> 0
    #                                 changement de base d'amortissement avec cumul E-1 <> 0
    #                                 changement de date de fin d'amortissement avec cumul E-1 <> 0
    #-2 ----------------------------------
    #If ( [M:DIV]MODAMT = G_DPMCA and [F:DEPC]ALWCOD = GVML_RPAUCUN and [F:DEPC]DPRCUM <> 0 ) Then
    #  If ( [F:DEPC]ENDDPRDAT <> [0/0/0] ) Then
    #     # En cas de changement de date de fin d'amortissement
    #     Local Date DTFNAMTNEW   : # Fin d'amortissement recalculé
    #     # Détermination de la date de fin d'amortissement à partir de la durée saisie
    #     Call CAL_DAT_FIN_SELON_DUREE
#&             ( [M:DIV]DTDBAMTREG, [F:DEPC]DPRDUR, [M:DIV]TYPPRO, DTFNAMTNEW) From =G_GLOB9
    #     If ( DTFNAMTNEW > [M:DIV]DTFNCON and [M:DIV]DTFNCON <> [0/0/0] ) Then
    #       # Si la fin d'amortissement calculée est au delà de la fin de consession
    #       # la fin d'amortissement est ramenée à la fin de concession
    #       # la durée d'amortissement pour le calcul se base sur la fin de concession
    #       DTFNAMTNEW   = [M:DIV]DTFNCON
    #     Endif
    #     If ( DTFNAMTNEW <> [F:DEPC]ENDDPRDAT ) Then
    #       # En cas de changement de date de fin d'amortissement
    #       # Passage en résiduel
    #       [F:DEPC]DPM       = G_DPMRA
    #       [F:DEPC]DPMT      = G_DPMRA
    #       [F:DEPC]DPMI      = G_DPMRA
    #       [M:DIV]MODAMT     = G_DPMRA
    #       [F:DEPC]MTCTIATYP = GVML_PEDBEX
    #       [F:DEPC]MTCTIADAT = [F:DEPC]FIYSTRDAT
    #      Endif
    #   Endif
    #Endif
    #-2 ----------------------------------
  Endif
  #-1 ----------------------------------

  # L'application de l"IFRS 5" ( bien détnenu pour la vente ) ne concerne que les plans normés IAS/IFRS
  If ( [F:WFAS]SALCLSDAT <> [0/0/0]  and
&      [M:DIV]PLNSTD(find([F:DEPC]DPRPLN, [M:DIV]PLNCAA)-1) = GVML_NPIAS ) Then

    # Date de classement régularisée FQ87580
    #[M:DIV]DETVTEDAT = [F:WFAS]SALCLSDAT
    [M:DIV]LVLLIB = "4.CAL_DATE_CLASSEMENT_REG" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CAL_DATE_CLASSEMENT_REG  From =G_GLOB4
    If ([M:DIV]ERROR) Then : End : Endif

  Else
    [M:DIV]DETVTEDAT = [0/0/0]
  Endif


  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_APRES_CAL_DOT_EXE
#
# - Objet  : .......
#
# - Entrée :
#
# - Sortie :
#
#   Boite noire
#
# ----------------------


  If ([F:DEPC]ALWCOD = GVML_RPDED40 and [M:DIV]LEGSOC = "FRA" and [F:DEPC]DPRPLN = G301FIS and [M:DIV2]GLODED40 <> 0 ) Then
    # Déduction de l'exercice ( Règle particulière : Déduction 40% [15avr15 - 14avr16] ) FQ107988
    Call CAL_DED40_EXE([F:DEPC]ALWAMT) From =G_GLOB7
  Endif

  #-- 1 ---------------------------------------
  #FQ49345
  #If ( [F:DEPC]ENDDPEFLG = G_OUI ) Then
  If ( [F:DEPC]ENDDPEFLG = G_OUI and not([M:DIV]BCUME_1) ) Then
    #=================
    # Dotation exercice forcée
    #=================
    [M:DIV]DOTEXE = [F:DEPC]ENDDPE
  #-- 1 ---------------------------------------
  Else
    #-- 2 ---------------------------------------
    If ( [F:DEPC]ALWAMTFLG =  G_OUI ) Then
      #=================
      # Aide fiscale saisie / Après
      #=================
      # L'aide fiscale saisie vient majorer la dotation exercice
      [M:DIV]DOTEXE += [F:DEPC]ALWAMT
      # Si la dotation est > à la valeur nette - La dotation est ramenée à la valeur nette
      Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4
    Endif
    #-- 2 ---------------------------------------
  Endif
  #-- 1 ---------------------------------------

  # FQ54343
  # Si code activité concession présent et concession gérée "Transmis par renouvellement" et bien "en concession"
  If ([M:DIV]BACTCCN and [M:DIV]CCNMOD = GVML_GCRNW and [F:WFAS]OWNTYP = GVML_TDCONCE ) Then
    # Si la date renouvellement non forcée alors elle hérite de la fin d'amort. de l'industriel
    If( [F:WFAS]RNWDATFLG <> G_OUI) Then
      If ( [F:DEPC]DPRPLN = [M:DIV]CCNINDPLN ) Then
        [F:WFAS]RNWDAT = [M:DIV]DTFNAMT
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE - Date renouv. hérite de fin amort du plan industriel") From =G_GLOB0
      Endif
    Endif
  Endif


  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#=====================================================================
# ---                                                              ---
#=====================================================================

#########################################################
$PLAFONNEMENT_A_VLNAMT
#
# - Objet  : Plafonnement de la dotation exercice au montant de la valeur nette
#

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 1 and [F:DEPC]FIYENDDAT = [31/12/2006] ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # Sécurité, si la dotation est > à la valeur nette, la dotation ne peut être égale qu'à la valeur nette
  If ( abs([M:DIV]DOTEXE) + abs([M:DIV]AMTEXC ) > abs([M:DIV]VLNAMT)) Then
    If ( abs([M:DIV]DOTEXE) > abs([M:DIV]VLNAMT) ) Then
      [M:DIV]DOTEXE = [M:DIV]VLNAMT
      [M:DIV]AMTEXC = 0
    Else
      [M:DIV]AMTEXC = [M:DIV]VLNAMT - [M:DIV]DOTEXE
    Endif
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE - Dotation exercice     = "+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE)) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE - Amort. Except.        = "+ format$([M:DIV]CURFMT,[M:DIV]AMTEXC)) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE - Valeur nette exe.     = "+ format$([M:DIV]CURFMT,[M:DIV]VLNAMT)) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE - Dotation > Valeur nette => Solde ") From =G_GLOB0
  Endif

Return

#########################################################
$EVALUE_FLGSLDPER
#
# - Objet  : Si la fin d'amortissement est antérieure à l'exercice courant et
#            que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
#            Elle doit l'être aussi sur la période courante
  # FQ65464
  #If ( [M:DIV]DTFNAMT < [M:DIV]DTDBEXE and [M:DIV]DATSORREG = [0/0/0] and [M:DIV]VLNAMT <> 0  ) Then

  #If ( [M:DIV]BDEBUG and [M:DIV]TYPCAL = "R") Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  Local Decimal L_ECACUME_1
  Case [M:DIV]TYPCAL
    When "R"
      L_ECACUME_1 = [M:DIV]ECACUME_1R
    When "T"
      L_ECACUME_1 = [M:DIV]ECACUME_1T
    When "I"
      L_ECACUME_1 = [M:DIV]ECACUME_1I
  Endcase


  # Issue 120693
  # Test initial complété
  # A l'origine si la date de fin d'amortissement est antérieure au début d'exercice que le bien n'est pas sorti et
  # que la valeur nette du bien n'est pas nulle cette dernière est soldée sur la période courante.
  # Quand le bien est sorti il est normal qu'une valeur nette puisse exister car le bien est amorti jusqu'à sa date de sortie.
  # Le test est complété pour prendre en compte le cas particulier où un bien est fini d'amortir dans un exercice antérieure et
  # qu'il possède encore une valeur nette en début d'exercice et qu'il est sorti dans l'exercice courant dans ce cas
  # aucun amortissement n'est calculé (détention à 0) mais la valeur nette doit être tout de même soldée.
  # Les biens en concession sont exclus de ce complément par précaution car il peuvent dans certains cas continuer à s'amortir
  # au delà de la date de sortie
  #If ( [M:DIV]DTFNAMT < [M:DIV]DTDBEXE and [M:DIV]DATSORREG = [0/0/0] and [M:DIV]VLNAMT <> 0 and L_ECACUME_1 = 0  ) Then
  If ( [M:DIV]DTFNAMT < [M:DIV]DTDBEXE and
&   ( [M:DIV]DATSORREG = [0/0/0] or
&     ([F:WFAS]OWNTYP <> GVML_TDCONCE and func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSORREG, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I")) )
&   and [M:DIV]VLNAMT <> 0 and L_ECACUME_1 = 0  ) Then
    [M:DIV]DOTEXE  = [M:DIV]VLNAMT - [M:DIV]AMTEXC
    [M:DIV]FLGSLDPER = 1
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE - Fin amort dépassé > Valeur nette => Solde ") From =G_GLOB0
  Endif
Return

#=====================================================================
# ---   I N F O R M A T I O N S     D E      B A S E               ---
#=====================================================================
#
#########################################################
Subprog  CAL_DATE_DEBUT_AMORT_REG
#
# - Objet  : Détermine la date de début d'amortissement régularisée
#
# - Entrée : [M:DIV] Structure Cdota
#
# - Sortie :
#
#   [M:DIV]DTDBAMTREG Début d'amortissement régularisé

#   Boite noire gcfc6a


Local Date LDTDBEXE, LDTFNEXE

 #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

 #--------------
  If ( [M:DPM]DPRMODTYP([M:DIV]INDMOD -1 ) = GVML_TMSTAND ) Then
    If ( [M:DIV]MODAMT = G_DPMIT ) Then
#     Call CAL_EXERCICE_SELON_DATE ( [F:DEPC]STRDPRDAT,[M:DIV]TYPPRO,
#&         [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT, WINDEXE ) From =G_GLOB8
      [M:DIV]PD(0)= [F:DEPC]STRDPRDAT : [M:DIV]PV(0)= [M:DIV]TYPPRO
      Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
      LDTDBEXE = [M:DIV]RD(1) : LDTFNEXE = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
      If ([M:DIV]ERROR) Then : End : Endif
    Else
      LDTDBEXE = [0/0/0]
    Endif

    # -- Mode standard FQ59941
    Call CAL_DATE_DEB_AMT_SELON_MODE
&        ( [M:DIV]MODAMT,
&          [F:DEPC]ALWCOD,
&          LDTDBEXE,
&          [F:DEPC]STRDPRDAT,
&          [M:DIV]DTDBEXI,
&          [M:DIV]DTFNEXI,
&          [F:WFAS]ITSDAT,
&          [M:DIV]PROEXEMDB,
&          [M:DIV]PROEXEMLB,
&          [M:DIV]RGLSIMPL,
&          [M:DIV]TYPPRO,
&          [M:DIV]TYPPRODAT,
&          [M:DIV]DTDBAMTREG ) From =G_GLOB8
    If ([M:DIV]ERROR) Then : End : Endif
  #--------------
  Else
    # -- Mode libre
    # Détermination exercice d'investissement
    Local Date     WDTDBEXIS
    # Début exercice suivant l'investissement
    WDTDBEXIS  = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNEXI, 1, "D" )

    Call CAL_DATE_DEB_AMT_SELON_REGLE
&        ( [M:DPM]ETRDATTYP([M:DIV]INDMOD -1 ),
&          [F:DEPC]STRDPRDAT,
&          [M:DIV]DTDBEXI,
&          [M:DIV]DTFNEXI,
&          WDTDBEXIS,
&          [M:DIV]TYPPRO,
&          [M:DIV]DTDBAMTREG) From =G_GLOB7
  Endif
  #--------------

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End


#########################################################
Subprog  CAL_DATE_SORTIE_REG
#
# - Objet  : Détermine les dates de sortie régularisées
#
# - Entrée : [M:DIV] Structure Cdota
#
# - Sortie :
#
#   [M:DIV]DATSORREG  Date de sortie régularisée
#   [M:DIV]DATSOREXE  Date de sortie régularisée ( pour le calcul de la dotation exercice )

#   Boite noire gcfc6f

  Local Integer BAPPLICABLE
  Local Integer L_ISSDATRUL

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]DATSORREG = [0/0/0]
  [M:DIV]DATSOREXE = [0/0/0]

  # La date de sortie régularisée est nulle si la date de sortie est nulle
  If ( [F:WFAS]ISSDAT = [0/0/0] ) Then
   [M:DIV]DATSORREG = [F:WFAS]ISSDAT
   [M:DIV]DATSORCCN = [F:WFAS]ISSDAT  : # FQ63145
    Gosub CAL_RMVLVL From =G_GLOB0
   End
   #***
  Endif
  # La date de sortie régularisée est nulle s'il s'agit d'une sortie prévisionnelle non simulée
  If ( [F:WFAS]ISSDAT <> [0/0/0] and [F:WFAS]EXTISSFLG =  G_OUI and [M:DIV]TRTDEM <> "CALSIM") Then
    [M:DIV]DATSORREG = [0/0/0]
    [M:DIV]DATSORCCN = [0/0/0]  : # FQ63145
    Gosub CAL_RMVLVL From =G_GLOB0
    End
   #***
  Endif

  # FQ63145
  # Si code activité concession présent et concession gérée "Transmis par renouvellement" et bien "en concession"
  If ([M:DIV]BACTCCN and [M:DIV]CCNMOD = GVML_GCRNW and [F:WFAS]OWNTYP = GVML_TDCONCE ) Then
    # Pour le plan gérant la caducité
    If ( [F:DEPC]DPRPLN = [M:DIV]CCNCADPLN ) Then
      # La date de sortie utilisée lors du calcul de provisions pour renouvellement est mise à 0.
      [M:DIV]DATSORCCN = [0/0/0]
      # FQ93935 sauvegarde de la règle de sortie
      L_ISSDATRUL = [F:WFAS]ISSDATRUL
      If ( [F:WFAS]ISSDATRUL <> GVML_IRJPREC ) Then
        # FQ93395 Si la règle de sortie est différente de "Pas de dotation le jour de sortie" alors
        #            la règle de sortie est systématiquement "Au jour précisée"
        [F:WFAS]ISSDATRUL =  GVML_IRJOURP
  Endif

    Endif
  Endif

  #-1 -------------------------------------
  If ( [M:DPM]DPRMODTYP([M:DIV]INDMOD -1 ) = GVML_TMSTAND ) Then
    # -- Mode standard
    Call CAL_DATE_SORTIE_SELON_MODE
&        ( [M:DIV]MODAMT,
&          [F:DEPC]ALWCOD,
&          [M:DIV]PROEXESOR,
&          [M:DIV]PROEXEMDB,
&          [M:DIV]PROEXEMLB,
&          [M:DIV]TYPPRO,
&          [M:DIV]TYPPRODAT,
&          [F:WFAS]ISSDAT,
&          [F:DEPC]DPRPLN,
&          [M:DIV]DATSORREG  ) From =G_GLOB8
    If ([M:DIV]ERROR) Then : End : Endif
  #-1 -------------------------------------
  Else
    # -- Mode libre
    Call CAL_DATE_SORTIE_SELON_REGLE
&        ( [M:DPM]ENDDATTYP([M:DIV]INDMOD -1 ),
&          [F:WFAS]ISSDAT,
&          [M:DIV]TYPPRO,
&          [M:DIV]DATSORREG )  From =G_GLOB7
    If ([M:DIV]ERROR) Then : End : Endif
  Endif
  #-1 -------------------------------------

  # Valeur par défaut pour la date de sortie utilisée pour le calcul de la dotation exercice
  [M:DIV]DATSOREXE = [M:DIV]DATSORREG

  #-1 ------------------------
  If ( [M:DIV]DATSORREG <> [0/0/0] ) Then
    If ( [M:DIV]MODAMT = G_DPMPC and [F:DEPC]ALWCOD = GVML_RPEXERC ) Then
      # Dotation complète pour l'exercice de sortie
      Call CAL_DATE_SORTIE_SELON_REGLE(GVML_DSDEREC, [F:WFAS]ISSDAT, [M:DIV]TYPPRO,
&                                      [M:DIV]DATSOREXE) From =G_GLOB7
      If ([M:DIV]ERROR) Then : End : Endif
    Endif
    If ( [M:DIV]MODAMT = G_DPMPD and [F:DEPC]ALWCOD = GVML_RPEXERC ) Then
      # Pas de dotation l'année de sortie
      # AU dernier JOUR DE L'EXERCICE PRECEDANT la sortie
      Call CAL_DATE_SORTIE_SELON_REGLE(GVML_DSDEREP, [F:WFAS]ISSDAT, [M:DIV]TYPPRO,
&                                      [M:DIV]DATSOREXE) From =G_GLOB7
      If ([M:DIV]ERROR) Then : End : Endif
    Endif
    If ([F:WFAS]ISSDATRUL > GVML_IRJOURP and [M:DPM]DPRMODTYP([M:DIV]INDMOD-1) = GVML_TMSTAND ) Then
      # La règle de sortie est-elle applicable au mode du plan ?
      # Ne concerne que le mode d'amortissement standards ( excluant de fait les modes libres)
      # FQ67222
      Call CAL_REGLE_SORTIE_APPLICABLE
&        ( [M:DIV]MODAMT, [F:DEPC]PRATYP, [F:WFAS]ISSDATRUL, [F:DEPC]ALWCOD, [M:DIV]PROEXEMLB, [M:DIV]PROEXEMDB,
&          BAPPLICABLE ) From =G_GLOB8
      If ([M:DIV]ERROR) Then : End : Endif
      If ( BAPPLICABLE ) Then
        # Si la règle de sortie est applicable au mode du plan, elle prime sur le reste.
        # Date de sortie régularisée selon la règle précisée lors de la sortie
        Call CAL_DATE_SORTIE_SELON_REGLE
&            (  [F:WFAS]ISSDATRUL,
&               [F:WFAS]ISSDAT,
&               [M:DIV]TYPPRO,
&               [M:DIV]DATSOREXE ) From =G_GLOB7
        If ([M:DIV]ERROR) Then : End : Endif
        [M:DIV]DATSORREG = [M:DIV]DATSOREXE
      Else
        Call ECR_FICH("FS1", 10,
&       "Règle de sortie"-mess([F:WFAS]ISSDATRUL,GMLREGLSOR,1)-" NON APPLICABLE au mode"-[M:DIV]MODAMT) From =G_GLOB0
      Endif
    Endif
  Endif
  #-1 ------------------------

  # FQ63145
  # Si code activité concession présent et concession gérée "Transmis par renouvellement" et bien "en concession"
  If ([M:DIV]BACTCCN and [M:DIV]CCNMOD = GVML_GCRNW and [F:WFAS]OWNTYP = GVML_TDCONCE ) Then
    # Sauvegarde de la date de sortie régularisée du plan gérant  l'amortissement de caducité
    # pour utilisation ultérieure dans le calcul des provisions
    If ( [F:DEPC]DPRPLN = [M:DIV]CCNCADPLN ) Then
      [M:DIV]DATSORCCN = [M:DIV]DATSORREG
      # FQ93935 restoration de la règle de sortie
      [F:WFAS]ISSDATRUL = L_ISSDATRUL
    Endif
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_DATE_CLASSEMENT_REG
#
# - Objet  : Détermine la date de classement régularisée selon le mode
#            FQ87580
# - Entrée :
#   [F:WFAS]SALCLSDAT  Date de classement non régularisée
#
# - Sortie :
#   [M:DIV]DETVTEDAT  Date de classement régularisée
#

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]DETVTEDAT = [F:WFAS]SALCLSDAT


  #-1 -------------------------------------
  If ( [M:DPM]DPRMODTYP([M:DIV]INDMOD -1 ) = GVML_TMSTAND ) Then
    # -- Mode standard
    Call CAL_DATE_SORTIE_SELON_MODE
&        ( [M:DIV]MODAMT,
&          [F:DEPC]ALWCOD,
&          [M:DIV]PROEXESOR,
&          [M:DIV]PROEXEMDB,
&          [M:DIV]PROEXEMLB,
&          [M:DIV]TYPPRO,
&          [M:DIV]TYPPRODAT,
&          [F:WFAS]SALCLSDAT,
&          [F:DEPC]DPRPLN,
&          [M:DIV]DETVTEDAT  ) From =G_GLOB8
    If ([M:DIV]ERROR) Then : End : Endif
  #-1 -------------------------------------
  Else
    # -- Mode libre
    Call CAL_DATE_SORTIE_SELON_REGLE
&        ( [M:DPM]ENDDATTYP([M:DIV]INDMOD -1 ),
&          [F:WFAS]SALCLSDAT,
&          [M:DIV]TYPPRO,
&          [M:DIV]DETVTEDAT )  From =G_GLOB7
    If ([M:DIV]ERROR) Then : End : Endif
  Endif
  #-1 -------------------------------------

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_DATE_FIN_AMORT
#
# - Objet  : Détermine la date de fin d'amortissement
#
# - Entrée : [M:DIV] Structure Cdota
#
# - Sortie :
#
#   [M:DIV]DTFNAMT  Date fin d'amortissement

#   Boite noire gcfc60


  #--------------------------------------
  If ( [M:DPM]DPRMODTYP([M:DIV]INDMOD -1 ) = GVML_TMSTAND ) Then
    # -- Mode standard
  #--------------------------------------
  Else
    Local Date WDTFNAMT
    # -- Mode libre
    Call CAL_DATE_FIN_AMORT_SELON_REGLE
&      ( [M:DPM]ENDDPRTYP([M:DIV]INDMOD -1 ),
&        [M:DPM]FIRFIYFLG([M:DIV]INDMOD -1 ),
&        [M:DIV]DTDBEXI,
&        [M:DIV]DTDBAMTREG,
&        [M:DIV]DURAMTREG,
&        [M:DIV]TYPPRO,
&        [M:DIV]DTFNAMT )  From =G_GLOB7
    If ([M:DIV]ERROR) Then : End : Endif
  Endif
  #--------------------------------------

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#########################################################
Subprog  CAL_AIDE_FISCALE
#
# - Objet  : Détermine de l'aide fiscale applicable pour l'exercice d'acquisition
#            Ne concerne que le mode "Linéaire français" et "Dégressif français"
#
# - Entrée : [M:DIV] Structure Cdota
#
# - Sortie :
#
#   Boite noire gcfca4


Local Decimal WCOE
Local Integer WINDEXE
Local Date    WDTDBEXI, WDTFNEXI


    Case [F:DEPC]ALWCOD
      When GVML_RPAID25
        # Aide 25 %
        WCOE = 0.25
      When GVML_RPAID50
        # Aide 50 %
        WCOE = 0.50
      When GVML_RPPR39B
        # Aide 39 Bis
#        Call CAL_EXERCICE_SELON_DATE
#&            ( [M:DEP]STRDPRDAT([M:DIV]DPC-1), [M:DIV]TYPPRO, WDTDBEXI, WDTFNEXI, WINDEXE ) From =G_GLOB8
        [M:DIV]PD(0)= [M:DEP]STRDPRDAT([M:DIV]DPC-1) : [M:DIV]PV(0)= [M:DIV]TYPPRO
        Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
        WDTDBEXI = [M:DIV]RD(1) : WDTFNEXI = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
        If ([M:DIV]ERROR) Then : End : Endif
        #--
        If ( WINDEXE <> 0 ) Then :  WCOE = [M:FIY]RAT39BIS(WINDEXE-1) / 100. : Else : WCOE = 0. : Endif
      When Default
        WCOE = 0.
    Endcase

    # Aide fiscale par application d'un taux
    #- 1 -------------------------------
    If ( [F:DEPC]ALWAMTFLG <> G_OUI ) Then
      #- 2 -------------------------------
      If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBAMTREG,[M:DIV]DTDBEXE,[M:DIV]DTFNEXE,"I") ) Then
        # Début d'amortissement du bien dans l'exercice courant
        [F:DEPC]ALWAMT = ([F:DEPC]BSEVAL * WCOE)
        [M:DIV]AFI     = ([F:DEPC]BSEVAL * WCOE)
      #- 2 -------------------------------
      Elsif ( [M:DIV]DTDBAMTREG < [M:DIV]DTDBEXE ) Then
        # L'amortissement du bien a commencé dans un exercice antérieur
        [F:DEPC]ALWAMT = 0.
        [M:DIV]AFI     = ([F:DEPC]BSEVAL * WCOE)
      #- 2 -------------------------------
      Else
        # L'amortissement du bien commence dans un exercice ultérieur
        [F:DEPC]ALWAMT = 0.
        [M:DIV]AFI     = 0.
      Endif
      #- 2 -------------------------------
    Else
    #- 1 -------------------------------
      [M:DIV]AFI    = 0.
    Endif
    #- 1 -------------------------------

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End


#########################################################
Subprog CAL_VALEUR_NETTE ( E01TYP, E01BASAMT, E01VNA, E01BMDR, S01VALNET )
#
# - Objet  : Détermine la valeur nette amortissable en fonction
#            du type début d'exercice ou début de période
#            et de la nature (intiale, theorique, reelle)
#
#            Rem : Le calcul doit tenir compte du solde de différé en période déficitaire
#                  dans la valeur nette début d'exercice ( avant calcul)
#                  Hors calcul, le valeur nette est présentée sans tenir compte de ce différé.
#                  En période bénéficiaire le solde de différé est toujours nul donc neutre.
#                  ( Pour éviter l'ajout d'un nouveau paramètre Hors calcul est repéré
#                    par E01VNA dont les valeurs ont été dupliquées pour avoir
#                    une version Calcul et Hors calcul )
#
#
# - Entrée : [F:DEPC] DEPREC
#            E01TYP
#                E01TYP(1) I initale T théorique R reelle
#                E01TYP(2) D début ( F fin à coder si nécessaire )
#                E01TYP(3) E exercice P période
#            E01VNA
#                0 Valeur nette
#                1 Valeur nette amortissable
#                2 Valeur nette (hors calcul)
#                3 Valeur nette amortissable (hors calcul)
#            E01BMDR
#                0 La modernisation n'est pas à prendre en compte => déduction de l'ecart de modernisation
#                1 La modernisation est à prendre en compte
#
# - Sortie : Valeur nette
#

Value    Char    E01TYP
Value    Decimal E01BASAMT
Value    Integer E01VNA
Value    Integer E01BMDR
Variable Decimal S01VALNET

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
Local Shortint CALL_E01
Goto $DEB_CAL_VALEUR_NETTE
$GSB_CAL_VALEUR_NETTE
  # Déclaration des paramètres en entrée
  Local Char      E01TYP        : E01TYP      = [M:DIV]PC(0)
  Local Decimal   E01BASAMT     : E01BASAMT   = [M:DIV]PV(0)
  Local Integer   E01VNA        : E01VNA      = [M:DIV]PE(0)
  Local Integer   E01BMDR       : E01BMDR     = [M:DIV]PE(1)
  Local Decimal   S01VALNET
$DEB_CAL_VALEUR_NETTE
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

Local Integer L_VNA
Local Decimal L_DFDBLC

  L_VNA = E01VNA
  If ( L_VNA = 2 or L_VNA = 3 ) Then
    # Hors calcul - On ne tient pas compte du solde de différé
    L_DFDBLC = 0
    # Retour à paramétrage de base
    L_VNA = E01VNA - 2
  Else
    # Dans calcul - On tient compte du solde de différé
    L_DFDBLC = [F:DEPC]DFDBLC
  Endif

  #--------------------------------------
  Case E01TYP
    When "IDE"
    #--------------------------------------
    # -- Valeur nette Initiale Début Exercice
      S01VALNET = E01BASAMT
&               - [F:DEPC]EXECLOCUMI
&               - L_DFDBLC
    When "TDE"
    #--------------------------------------
    # -- Valeur nette Théorique Début Exercice
      S01VALNET = E01BASAMT
&               - [F:DEPC]EXECLOCUMT
&               - L_DFDBLC
    When "RDE"
    #--------------------------------------
    # -- Valeur nette Reelle Début Exercice FQ84213
      S01VALNET = E01BASAMT
&               - [F:DEPC]DPRCUM
&               - [F:DEPC]EXEIMLCUM
&               + [F:DEPC]EXERVECUM
&               + [F:DEPC]EXETRFCUM
&               - L_DFDBLC
    When "IDP"
    #--------------------------------------
    # -- Valeur nette Initiale Début Période
      S01VALNET = E01BASAMT
&               - [F:DEPC]EXECLOCUMI
&               - [F:DEPC]PERCLOCUMI
&               - [F:DEPC]PERCLOEXCI
&               - L_DFDBLC
    When "TDP"
    #--------------------------------------
    # -- Valeur nette théorique Début Période
      S01VALNET = E01BASAMT
&               - [F:DEPC]EXECLOCUMT
&               - [F:DEPC]PERCLOCUMT
&               - [F:DEPC]PERCLOEXCT
&               - L_DFDBLC
    When "RDP"
    #--------------------------------------
    # -- Valeur nette Reelle Début Période
      S01VALNET = E01BASAMT
&               - [F:DEPC]DPRCUM
&               - [F:DEPC]PERCLOCUM
&               - [F:DEPC]PERCLOEXC
&               - [F:DEPC]IMLBLC
&               - L_DFDBLC
    When "IFP"
    #--------------------------------------
    # -- Valeur nette Initiale Fin Période
      S01VALNET = E01BASAMT
&               - [F:DEPC]EXECLOCUMI
&               - [F:DEPC]PERCLOCUMI
&               - [F:DEPC]PERCLOEXCI
&               - [F:DEPC]DPEI
&               - [F:DEPC]PEREXCDPRI
    When "TFP"
    #--------------------------------------
    # -- Valeur nette Théorique Fin Période
      S01VALNET = E01BASAMT
&               - [F:DEPC]EXECLOCUMT
&               - [F:DEPC]PERCLOCUMT
&               - [F:DEPC]PERCLOEXCT
&               - [F:DEPC]DPET
&               - [F:DEPC]PEREXCDPRT
    When "RFP"
    #--------------------------------------
    # -- Valeur nette Reelle Fin Période
      S01VALNET = E01BASAMT
&               - [F:DEPC]DPRCUM
&               - [F:DEPC]PERCLOCUM
&               - [F:DEPC]PERCLOEXC
&               - [F:DEPC]PERENDDPE
&               - [F:DEPC]PEREXCDPR
&               - [F:DEPC]IMLBLC
&               - [F:DEPC]IML
&               + [F:DEPC]IMLRVE
&               + [F:DEPC]IMLRVETRF
      If ( [F:WFAS]ISSDAT <> [0/0/0] and [F:DEPC]IMLBLC <> 0 and
&          [F:WFAS]ISSDAT >= [F:DEPC]FIYSTRDAT and [F:WFAS]ISSDAT <= [F:DEPC]FIYENDDAT ) Then
        S01VALNET += [F:WFAS]IMLRVEISS([F:DEPC]DPRPLN-1)
      Endif
    When "IFE"
    #--------------------------------------
    # -- Valeur nette Initiale Fin Exercice
      S01VALNET = E01BASAMT
&               - [F:DEPC]EXECLOCUMI
&               - [F:DEPC]ENDDPEI
&               - [F:DEPC]EXCDPRI
    When "TFE"
    #--------------------------------------
    # -- Valeur nette Théorique Fin Exercice
      S01VALNET = E01BASAMT
&               - [F:DEPC]EXECLOCUMT
&               - [F:DEPC]ENDDPET
&               - [F:DEPC]EXCDPRT
    When "RFE"
    #--------------------------------------
    # -- Valeur nette Reelle Fin Exercice
      S01VALNET = E01BASAMT
&               - [F:DEPC]DPRCUM
&               - [F:DEPC]ENDDPE
&               - [F:DEPC]IMLBLC
&               - [F:DEPC]IML
&               + [F:DEPC]IMLRVE
&               - [F:DEPC]EXCDPR
&               + [F:DEPC]IMLRVETRF
      If ( [F:WFAS]ISSDAT <> [0/0/0] and
&          [F:WFAS]ISSDAT >= [F:DEPC]FIYSTRDAT and [F:WFAS]ISSDAT <= [F:DEPC]FIYENDDAT ) Then
        S01VALNET += [F:WFAS]IMLRVEISS([F:DEPC]DPRPLN-1)
      Endif
  Endcase
  #--------------------------------------

  # FQ67577
  # Pologne : Déduction de l'écart sur modernisation pour application sur mois suivant
  If (dim([F:DEPC]KMDRDEV) >= 0 and [F:DEPC]KMDRDEV <> 0 and not(E01BMDR)) Then
    S01VALNET -= [F:DEPC]KMDRDEV
  Endif

  # Subvention déduite de le cadre de la caducité
  If ( left$(E01TYP,1) = "R" and ( [F:DEPC]DPM  = G_DPMCA or [F:DEPC]DPM  = G_DPMRA ) or
&      left$(E01TYP,1) = "T" and ( [F:DEPC]DPMT = G_DPMCA or [F:DEPC]DPMT = G_DPMRA ) or
&      left$(E01TYP,1) = "I" and ( [F:DEPC]DPMI = G_DPMCA or [F:DEPC]DPMI = G_DPMRA )    ) Then
    S01VALNET = S01VALNET - [M:DIV]SUB
  Endif

  #---------------------
  # Valeur nette amortissable
  If ( L_VNA ) Then
    S01VALNET = S01VALNET - [F:DEPC]RSDVAL
    # Ajustement à 0 de la valeur nette amortissable.
    If ( ( E01BASAMT > 0 and S01VALNET  < 0 ) or
&        ( E01BASAMT < 0 and S01VALNET  > 0 ) or
&        ( E01BASAMT = 0 and S01VALNET <> 0 )   ) Then
      Call ECR_FICH("FS1", 1, "!!!!!!! Rectif val. nette"- E01TYP - "à 0 car ") From =G_GLOB0
      Call ECR_FICH("FS1", 1, "        Base      =" -num$(E01BASAMT)) From =G_GLOB0
      Call ECR_FICH("FS1", 1, "        Val nette =" -num$(S01VALNET)) From =G_GLOB0
      S01VALNET = 0
    Endif
  Else
    # Ajustement à 0 de la valeur nette.
    If ( ( E01BASAMT > 0 and S01VALNET - [F:DEPC]RSDVAL  < 0 ) or
&        ( E01BASAMT < 0 and S01VALNET - [F:DEPC]RSDVAL  > 0 ) or
&        ( E01BASAMT = 0 and S01VALNET - [F:DEPC]RSDVAL <> 0 )   ) Then
      Call ECR_FICH("FS1", 1, "!!!!!!! Rectif val. nette"- E01TYP - "à 0 car ") From =G_GLOB0
      Call ECR_FICH("FS1", 1, "        Base      =" -num$(E01BASAMT)) From =G_GLOB0
      Call ECR_FICH("FS1", 1, "        Val nette =" -num$(S01VALNET)) From =G_GLOB0
      S01VALNET = 0
    Endif
  Endif
  #---------------------

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
If (dim(CALL_E01)<0) Then
 # Récupération des paramètres en sortie
 [M:DIV]RV(1) = S01VALNET
 Return
Endif
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

End


#=====================================================================
# ---  M O D E S    D ' A M O R T I S S E M E N T    L I B R E S   ---
#=====================================================================
#

#########################################################
Subprog  CAL_DOT_EXE_MLB
#
# - Objet  : Calcule la dotation de l'exercice selon un mode Libre
#
# - Entrée : [M:DIV] Structure Cdota
#
# - Sortie : Dotation de l'exercice
#
#   [M:DOT]DOTEXE  Dotation de l'exercice
#
#   Boite noire GCFC52
#
#
  # If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

Local Decimal WVALNET  : WVALNET  = 0.  : # Valeur nette
Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation exercice
Local Decimal WBASAMT  : WBASAMT  = 0.  : # Base d'amortissement
Local Decimal WSURAMT  : WSURAMT  = 0.  : # Suramortissement
Local Decimal WAMTMIN  : WAMTMIN  = 0.  : # Amortissement minimum
Local Decimal WAMTMAX  : WAMTMAX  = 0.  : # Amortissement maximum

Local Date    LDATANI                   : # Date anniversaire
Local Date    LFINA                     : # Borne fin selon taux 2 (année n-1)
Local Date    LFINB                     : # Borne fin selon taux 1 (année n)
Local Decimal LDOTA    : LDOTA    = 0.  : # Sous dotation selon taux 2 (année n-1)
Local Decimal LDOTB    : LDOTB    = 0.  : # Sous dotation selon taux 1 (année n)
Local Decimal LDURA    : LDURA    = 0.  : # Durée détention selon taux 2 (année n-1)
Local Decimal LDURB    : LDURB    = 0.  : # Durée détention selon taux 1 (année n)

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.


  # Durée d'amortissement
  If ( [F:DEPC]DPRDUR < [M:DPM]MINDPRLIF([M:DIV]INDMOD-1) ) Then
    # Contôle durée d'amortissement minimum
    [M:DIV]DURAMTREG = [M:DPM]MINDPRLIF([M:DIV]INDMOD-1)
  Else
    [M:DIV]DURAMTREG = [F:DEPC]DPRDUR
  Endif

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&       [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif

  # Calcul de la durée résiduelle en année à partir de la durée restant à amortir
  Call  CAL_DUR_REST_AMT
&       ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT,
&        WDURRES) From =G_GLOB8

  # Base à appliquer
  Call CAL_BASE_SELON_REGLE
&      ([M:DPM]BASTYP([M:DIV]INDMOD-1), [M:DIV]DUREXE, WDURRES, [M:DIV]DURAMTREG,
&       [M:DIV]BASAMT, [F:DEPC]RSDVAL,  [M:DIV]VLNAMT, WBASAMT ) From =G_GLOB7

  # Valeur nette début d'exercice en cas de solde
  WVALNET =  [M:DIV]VLNAMT + [F:DEPC]RSDVAL

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)   ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)   ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Début d'amort         =" + num$([M:DIV]DTDBAMTREG)) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Date de sortie        =" + num$([M:DIV]DATSORREG )) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Date de sortie Exe.   =" + num$([M:DIV]DATSOREXE )) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Base selon règle      =" + num$( WBASAMT )        ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Base fichier          =" + num$([M:DIV]BASAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)   ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)   ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Fin d'amort.          =" + num$([M:DIV]DTFNAMT)   ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Durée Exercice        =" + num$([M:DIV]DUREXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Durée Détention Exe.  =" + num$( WDURDET )        ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Dur. résid. en années =" + num$( WDURRES )        ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Taux                  =" + num$([M:DIV]TXLB)      ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Taux 2                =" + num$([M:DIV]TX2LB)     ) From =G_GLOB0
  Endif

  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
  # La date de fin d'amortissement n'appartient pas à l'exercice
    #-2 --------------------
    If ( [M:DPM]RATCOETYP([M:DIV]INDMOD-1) = GVML_COBSMTM ) Then
      # Si Application taux correspond BASE X TAUX MENSUEL
      Call CAL_DOT_TX_MENSUEL
&      ( [M:DPM]RAT, ([M:DPM]INDFINRAT([M:DIV]INDMOD-1)-[M:DPM]INDDEBRAT([M:DIV]INDMOD-1)+1),
&        [M:DPM]INDDEBRAT([M:DIV]INDMOD-1), WBASAMT, [M:DPM]RATCOETYP([M:DIV]INDMOD-1),
&        [M:DPM]MINDPRTYP([M:DIV]INDMOD-1), [M:DPM]MINDPRRAT([M:DIV]INDMOD-1),
&        [M:DPM]MAXDPRTYP([M:DIV]INDMOD-1), [M:DPM]MAXDPRRAT([M:DIV]INDMOD-1),
&        [M:DIV]DTDBEXE, [M:DIV]DTFNEXE, [M:DIV]DUREXE, [M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG, [M:DIV]DTFNAMT,
&        [M:DIV]DATSOREXE, [M:DIV]BASAMT, [F:DEPC]RSDVAL, [M:DIV]VLNAMT,
&        WDOTEXE ) From =G_GLOB7
      [M:DIV]TXAMT = 0
    Else
    #-2 --------------------
      #-3 --------------------
      # Calcul à date anniversaire
      If ( [M:DPM]ANIDATFLG([M:DIV]INDMOD-1) =  G_OUI ) Then
        # Construction date anniversaire
        LDATANI = gdat$(day([M:DIV]DTDBAMTREG),month([M:DIV]DTDBAMTREG),year([M:DIV]DTDBEXE))
        # FQ82482 Prise en compte exercices décalés
        If ( (LDATANI < [M:DIV]DTDBAMTREG) or
&            (not func GLOBB9.CAL_DAT_INSIDE(LDATANI, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I")) ) Then
          LDATANI = gdat$(day([M:DIV]DTDBAMTREG),month([M:DIV]DTDBAMTREG),year([M:DIV]DTFNEXE))
        Endif
        #-4 --------------------
        # Calcul sous dotation pour l'intervalle I sur lequel le Taux 2 (année n-1) doit être appliqué
        If (  [M:DIV]DTDBAMTREG >= [M:DIV]DTDBEXE
&         or  LDATANI = [M:DIV]DTDBEXE
&         or ( [M:DIV]DATSOREXE <> [0/0/0] and [M:DIV]DATSOREXE = [M:DIV]DTDBEXE) ) Then
          # Pas de Taux 2 (année n-1 ) pour la première annuité ou
          # La dotation est aussi = 0
          #   si date anniversaire et début d'exercice coincide ou
          #   si date sortie et début d'exercice coincide
          LDOTA = 0
        Else
          # Détermination borne de fin de l'intervalle I
          If ( [M:DIV]DATSOREXE <> [0/0/0] and [M:DIV]DATSOREXE < LDATANI ) Then
            # Date de sortie
            LFINA = [M:DIV]DATSOREXE
          Else
            # Date anniversaire - 1 jour
            # FQ82482
            #LFINA = func GLOBB9.CAL_DAT_PLUS( LDATANI, -1, "Y" )
            LFINA = func GLOBB9.CAL_DAT_PLUS( LDATANI, -1, "D" )
          Endif
          Call CAL_DAT_DIFF( [M:DIV]DTDBEXE, LFINA , [M:DIV]TYPPRODAT, LDURA ) From =G_GLOB9
          # FQ82482
          #LDOTA = WBASAMT * [M:DIV]TX2LB ( LDURA / [M:DIV]DUREXE )
          LDOTA = WBASAMT * ( [M:DIV]TX2LB ) * ( LDURA / [M:DIV]DUREXE )
        Endif
        #-4 --------------------

        #-4 --------------------
        # Calcul sous dotation pour l'intervalle J sur lequel le Taux 1 (année n) doit être appliqué

        # Détermination borne de fin de l'intervalle I
        If ( [M:DIV]DATSOREXE <> [0/0/0] and [M:DIV]DATSOREXE < [M:DIV]DTFNEXE) Then
          # Date de sortie
          LFINB = [M:DIV]DATSOREXE
        Else
          # Date fin d'exercice
          LFINB = [M:DIV]DTFNEXE
        Endif

        # FQ115188
        #If (  LFINB < LDATANI ) Then
        If (  LFINB < LDATANI or LFINB < [M:DIV]DTDBAMTREG) Then
          # La dotation est = 0 si la borne de fin se situe avant la date anniversaire
          LDOTB = 0
        Else
          Call CAL_DAT_DIFF( LDATANI, LFINB , [M:DIV]TYPPRODAT, LDURB ) From =G_GLOB9
          # FQ82482
          #LDOTB = WBASAMT * [M:DIV]TXLB ( LDURB / [M:DIV]DUREXE )
          LDOTB = WBASAMT * ( [M:DIV]TXLB ) * ( LDURB / [M:DIV]DUREXE )
        Endif
        #-4 --------------------
        # calcul de la dotation exercice
        If ( LDOTA = 0 ) Then : [M:DIV]TXAMT = [M:DIV]TXLB : Else : [M:DIV]TXAMT = 0 : Endif
        WDOTEXE = LDOTA + LDOTB
      Else
      #-3 --------------------
      # calcul de la dotation exercice ( Sans calcul à date anniversaire )
        If ( [M:DIV]DUREXE <> 0 ) Then
          WDOTEXE = WBASAMT  * ( [M:DIV]TXLB ) * ( WDURDET / [M:DIV]DUREXE )
        Else
          WDOTEXE = 0
        Endif
        # Solde de la valeur nette lorsque la dotation est > à la valeur nette
        If ( abs(WVALNET) < abs(WDOTEXE) ) Then
          WDOTEXE = WVALNET
          Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Valeur nette soldée   "  ) From =G_GLOB0
        Endif
        [M:DIV]TXAMT = [M:DIV]TXLB
      Endif
      #-3 --------------------
    Endif
    #-2 --------------------
  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
  # La date de fin d'amortissement appartient à l'exercice

    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      WDOTEXE = WVALNET * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif
  Endif
  #-1 --------------------

  # FQ61781
  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  #[M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  #Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  #-1 --------------------
  # Calcul d'un éventuel suramortissement si première annuité
  If  ( [M:DPM]EXCDPRRAT([M:DIV]INDMOD-1) <> 0
&   and func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBAMTREG,[M:DIV]DTDBEXE,[M:DIV]DTFNEXE,"I") ) Then
    WSURAMT = WBASAMT * [M:DPM]EXCDPRRAT([M:DIV]INDMOD-1)
    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WSURAMT, [M:DIV]CUR , WSURAMT) From =G_GLOB8
    [M:DIV]PV(0)= WSURAMT : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WSURAMT = [M:DIV]RV(1)
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Amt Except Exe acquis.=" + num$(WSURAMT)   ) From =G_GLOB0
  Endif
  #-1 --------------------

  # Détermination amortissement minimum selon règle plancher
  Call CAL_AMT_MINIMUM_SELON_REGLE
&     ( [M:DPM]MINDPRTYP([M:DIV]INDMOD-1),
&       [M:DPM]MINDPRRAT([M:DIV]INDMOD-1), WDURDET, [M:DIV]DUREXE, WDURRES,
&       [M:DIV]DTDBEXE, [M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG, [M:DIV]DTFNAMT,
&       WBASAMT, [F:DEPC]RSDVAL, [M:DIV]VLNAMT, WAMTMIN ) From =G_GLOB7

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WAMTMIN, [M:DIV]CUR , WAMTMIN) From =G_GLOB8
  [M:DIV]PV(0)= WAMTMIN : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WAMTMIN = [M:DIV]RV(1)
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Amort minimum         =" + num$(WAMTMIN)    ) From =G_GLOB0

  #-1 --------------------
  #If ( abs(WDOTEXE) < abs(WAMTMIN) ) Then : FQ117795
  If ( abs(WDOTEXE) < abs(WAMTMIN) and not ([M:DIV]DATSOREXE < [M:DIV]DTDBEXE ) ) Then
    # Dotation forcée à l'amortissement minimum si dotation < au plancher
    WDOTEXE = WAMTMIN
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Dotation Exe ajustée à amortissement minimum" ) From =G_GLOB0
  Else
  #-1 --------------------
    # Détermination amortissement maximum selon règle plafond
    Call CAL_AMT_MAXIMUM_SELON_REGLE
&       ( [M:DPM]MAXDPRTYP([M:DIV]INDMOD-1),
&         [M:DPM]MAXDPRRAT([M:DIV]INDMOD-1), WDURDET, [M:DIV]DUREXE,
&         WDOTEXE, WBASAMT, [F:DEPC]RSDVAL, [M:DIV]VLNAMT, WAMTMAX ) From =G_GLOB7

    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WAMTMAX, [M:DIV]CUR , WAMTMAX) From =G_GLOB8
    [M:DIV]PV(0)= WAMTMAX : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WAMTMAX = [M:DIV]RV(1)
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Amort maximum         =" + num$(WAMTMAX)   ) From =G_GLOB0
    #---------------------
    If ( abs(WDOTEXE) > abs(WAMTMAX) ) Then
      # Dotation limitée au plafond si dotation > au plafond
      WDOTEXE = WAMTMAX
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MLB - Dotation Exe ajustée à amortissement maximum" ) From =G_GLOB0
    Endif
    #---------------------
  Endif
  #-1 --------------------

  # Dotation
  [M:DIV]DOTEXE = WDOTEXE
  # Suramortissement
  [M:DIV]AMTEXC = WSURAMT

  # FQ61781
  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  #Call CAL_ARRONDI_MNT (WSURAMT, [M:DIV]CUR , [M:DIV]AMTEXC) From =G_GLOB8
  [M:DIV]PV(0)= WSURAMT : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]AMTEXC = [M:DIV]RV(1)

  # La fin d'amortissement est antérieure à l'exercice courant
  Gosub EVALUE_FLGSLDPER From =G_GLOB4
  # Sécurité, si la dotation est > à la valeur nette, la dotation ne peut être égale qu'à la valeur nette
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4
  Call ECR_FICH("FS1", 7, "- CAL_DOT_EXE_LB > Dotation exercice   =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "- CAL_DOT_EXE_LB > Amort. exceptionnel =" + num$([M:DIV]AMTEXC) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#
#=====================================================================
#  M O D E S    D ' A M O R T I S S E M E N T    S T A N D A R D S
#=====================================================================
#
#***********************************************************
#      D O T A T I O N   -   E X E R C I C E
#***********************************************************
#





#########################################################
Subprog  CAL_DOT_EXE_PC
#
# - Objet  : Calcule la dotation de l'exercice selon le mode "Portugais constant"
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#
#   Boite noire gcfc11
#

Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation de l'exercice

Local Decimal W12EME   : W12EME   = 0.  : # 1/12ème de la dotation exercice

  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Taux / Duree
  #=================
  #-------------------------------
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    # Calcul de la durée à partir du taux forcé
    [M:DIV]DURAMTREG = arr( (1/[M:DIV]TXAMT), 0.01)
  Else
    # Durée en année et centième d'année
    [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
    # Calcul du taux à partir de la durée (4 décimales)
    [M:DIV]TXAMT = arr(1 / [M:DIV]DURAMTREG, 0.000001)
  Endif
  #-------------------------------

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  # FQ116168
  # Gosub CAL_DATE_FIN_AMORT_PC From =G_GLOB8
  If ( [F:DEPC]ENDDPRFLG = G_OUI ) Then
      [M:DIV]DTFNAMT = [F:DEPC]ENDDPRDAT
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PC - Fin d'amortissement FORCEE  "        ) From =G_GLOB0
  Else
    # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
    Gosub CAL_DATE_FIN_AMORT_PC From =G_GLOB8
  Endif
  #---------------------

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PC - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PC - Déb. Exercice         =" + num$([M:DIV]DTDBEXE) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PC - Fin  Exercice         =" + num$([M:DIV]DTFNEXE) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PC - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PC - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PC - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PC - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PC - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PC - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PC - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PC - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT) ) From =G_GLOB0
  Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PC - Valeur amortissable   =" + num$([M:DIV]VALAMT)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PC - Taux                  =" + num$([M:DIV]TXAMT)   ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PC - Règle particulière    =" + mess([F:DEPC]ALWCOD,GML_REGLPART,1)) From =G_GLOB0

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PC - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
  If ([M:DIV]ERROR) Then : End : Endif

  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
    # La date de fin d'amortissement n'appartient pas à l'exercice

    # Calcul de la durée de l'exercice de référence selon le type de prorata
    Call ECR_FICH
&        ("FS1", 7, "CAL_DOT_EXE_PC - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( [M:DIV]DUREXE <> 0 ) Then
      Call ECR_FICH("FS1",7,
&     "Dotation Exercice = Valeur amortissable * Taux * ( Durée Détention Exe. / Durée Exercice)  " ) From =G_GLOB0
      WDOTEXE = [M:DIV]VALAMT * [M:DIV]TXAMT * ( WDURDET / [M:DIV]DUREXE)
    Else
      WDOTEXE = 0
    Endif
    #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , WDOTEXE) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXE = [M:DIV]RV(1)
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

    # Solde de la valeur nette lorsque la dotation est > à la valeur nette
    If ( abs(WDOTEXE)  > abs([M:DIV]VLNAMT) ) Then
      WDOTEXE = [M:DIV]VLNAMT
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PC - Solde du reste à amortir ") From =G_GLOB0
    Endif

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    # La fin d'amortissement a lieu dans l'exercice

    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PC - Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1",7,
&     "Dotation exercice = Val. nette déb. exe. * ( Durée Détention Exe. / Durée Résid. à amort.)  " ) From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  Endif
  #-1 --------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # La fin d'amortissement est antérieure à l'exercice courant
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  # Valeur nette fin exercice soldée si elle est inférieure à 1/12ème de la dotation exercice calculée
  # FQ83918
  If ( [M:DIV]DATSORREG = [0/0/0] ) Then
    W12EME = [M:DIV]DOTEXE / 12
    #Call CAL_TRONCAT_MNT (W12EME, [M:DIV]CUR , W12EME) From =G_GLOB8
    [M:DIV]PV(0)= W12EME : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_TRONCAT_MNT From =G_GLOB8 : W12EME = [M:DIV]RV(1)
    If ( abs([M:DIV]VLNAMT) - abs([M:DIV]DOTEXE + [M:DIV]AMTEXC) < abs(W12EME) ) Then
      [M:DIV]DOTEXE = [M:DIV]VLNAMT - [M:DIV]AMTEXC
    Endif
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PC - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#########################################################
Subprog  CAL_DOT_EXE_PD
#
# - Objet  : Calcule la dotation de l'exercice selon le mode "Portugais duodecimos"
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#
#   Boite noire gcfc11
#

Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation de l'exercice

Local Decimal W12EME   : W12EME   = 0.  : # 1/12ème de la dotation exercice

  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Date Début Amort.
  #=================
  # Pour calcul de la dotation exercice
  Local Date    WDTDBAMTEXE
  # Par défaut début de mois
  WDTDBAMTEXE = [M:DIV]DTDBAMTREG

  If ( [F:DEPC]ALWCOD = GVML_RPEXERC ) Then
    # AU Premier Jour de l'exercice d'investissement
    Call CAL_DATE_DEB_AMT_SELON_REGLE ( GVML_DA1ERE,[F:DEPC]STRDPRDAT,[M:DIV]DTDBEXI,
&        [M:DIV]DATNUL,[M:DIV]DATNUL,[M:DIV]TYPPRO,WDTDBAMTEXE ) From =G_GLOB7
  Endif

  #=================
  # Taux / Duree
  #=================
  #-------------------------------
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    # Calcul de la durée à partir du taux forcé
    [M:DIV]DURAMTREG = arr( (1/[M:DIV]TXAMT), 0.01)
  Else
    # Durée en année et centième d'année
    [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
    # Calcul du taux à partir de la durée
    [M:DIV]TXAMT = arr(1 / [M:DIV]DURAMTREG, 0.000001)
  Endif
  #-------------------------------

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Date de Début d'amort (régularisée pour "dotation exercice" ) + Durée en années - 1 jour
  # FQ116168
  #Gosub CAL_DATE_FIN_AMORT_PD From =G_GLOB8
  If ( [F:DEPC]ENDDPRFLG = G_OUI ) Then
      [M:DIV]DTFNAMT = [F:DEPC]ENDDPRDAT
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PD - Fin d'amortissement FORCEE  "        ) From =G_GLOB0
  Else
    # Date de Début d'amort (régularisée pour "dotation exercice" ) + Durée en années - 1 jour
    Gosub CAL_DATE_FIN_AMORT_PD From =G_GLOB8
  Endif
  #---------------------

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PD - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PD - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PD - Fin  Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PD - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PD - Début d'amort. Exe    =" + num$(WDTDBAMTEXE)       ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PD - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PD - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PD - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PD - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PD - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PD - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_PD - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)  ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PD - Valeur amortissable   =" + num$([M:DIV]VALAMT)   ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PD - Taux                  =" + num$([M:DIV]TXAMT )   ) From =G_GLOB0

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE,    [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMTEXE,
#&      [M:DIV]DTFNAMT,  [M:DIV]DATSOREXE ,   [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMTEXE : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PD - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
    # La date de fin d'amortissement n'appartient pas à l'exercice

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PD - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( [M:DIV]DUREXE <> 0 ) Then
      Call ECR_FICH("FS1",7,
&     "Dotation Exercice = Valeur amortissable * Taux * ( Durée Détention Exe. / Durée Exercice)  " ) From =G_GLOB0
      WDOTEXE = [M:DIV]VALAMT * [M:DIV]TXAMT * ( WDURDET / [M:DIV]DUREXE)
    Else
      WDOTEXE = 0
    Endif
    #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , WDOTEXE) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXE = [M:DIV]RV(1)
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

    # Solde de la valeur nette lorsque la dotation est > à la valeur nette
    If ( abs([M:DIV]VLNAMT) < abs(WDOTEXE) ) Then
      WDOTEXE = [M:DIV]VLNAMT
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PD - Solde du reste à amortir ") From =G_GLOB0
    Endif

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    # La fin d'amortissement a lieu dans l'exercice

    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         (WDTDBAMTEXE, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PD - Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1",7,
&     "Dotation Exercice = Val. nette déb. exe. * ( Durée Détention Exe. / Durée Résid. à amort.)  " ) From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  Endif
  #-1 --------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si valeur nette non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

    # Valeur nette fin exercice soldée si elle est inférieure à 1/12ème de la dotation exercice calculée
  # FQ83918
  If ( [M:DIV]DATSORREG = [0/0/0] ) Then
    W12EME = [M:DIV]DOTEXE / 12
    #Call CAL_TRONCAT_MNT (W12EME, [M:DIV]CUR , W12EME) From =G_GLOB8
    [M:DIV]PV(0)= W12EME : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_TRONCAT_MNT From =G_GLOB8 : W12EME = [M:DIV]RV(1)
    If ( abs([M:DIV]VLNAMT) - abs([M:DIV]DOTEXE + [M:DIV]AMTEXC) < abs(W12EME) ) Then
      [M:DIV]DOTEXE = [M:DIV]VLNAMT - [M:DIV]AMTEXC
    Endif
  Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_PD - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_DOT_EXE_DV
#
# - Objet  : Calcule la dotation de l'exercice selon le mode DV
#            Dégressif Portugais Mixte (avec passage au linéaire)
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire gcfc77, gcfc20
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Decimal WDOTEXEDEG : WDOTEXEDEG  = 0.     : # Dotation exercice en dégressif
Local Decimal WDOTEXELIN : WDOTEXELIN  = 0.     : # Dotation exercice en linéaire sur valeur résiduelle

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DV - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DV - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
   #***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DV - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DV - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DV - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DV - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DV - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DV - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DV - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DV - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DV - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0

  #=================
  # Taux / Duree
  #=================
  #---------------------
  # Durée en année et centième d'année
  [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
  If ( [M:DIV]DURAMTREG < 3. ) Then : [M:DIV]DURAMTREG = 3. : Endif
  # Taux dégressif portugais mixte
  Call CAL_TAUX_MODE_DP
&      ( [M:DIV]DURAMTREG, [M:DIV]TXAMT) From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DV - Taux  d'amortissement =" + num$([M:DIV]TXAMT ) ) From =G_GLOB0

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  Gosub CAL_DATE_FIN_AMORT_DV From =G_GLOB8
  #---------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DV - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DV - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE,  [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DV - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DV - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

  # Cas standard

  #---------------------------------------------
  # Calcul Dotation exercice dégressive
  #---------------------------------------------
  Call ECR_FICH("FS1",7,
& "Dotation Dégressive = Valnet amort déb exe * Taux  d'amortissement * ( Durée Détention Exe. / Durée Exercice)  " ) From =G_GLOB0
  WDOTEXEDEG = [M:DIV]VLNAMT * ( [M:DIV]TXAMT ) * ( WDURDET / [M:DIV]DUREXE )

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXEDEG, [M:DIV]CUR , WDOTEXEDEG) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXEDEG : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXEDEG = [M:DIV]RV(1)
  Call ECR_FICH
&      ("FS1", 7, "CAL_DOT_EXE_DV - Dotation dégressive ................... ="-num$(WDOTEXEDEG) ) From =G_GLOB0

  # Calcul de la durée restant à amortir
  Call  CAL_DUR_REST_AMT
&       ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
& From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DV - Linéaire Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

  #---------------------------------------------
  # Calcul Dotation exercice linéaire sur valeur et durée résiduelles
  #---------------------------------------------
  If ( WDURRES = 0 ) Then
    WDOTEXELIN = 0
  Else
    Call ECR_FICH("FS1",7,
&   "Dotation Linéaire = Valnet amort déb exe * ( Durée Détention Exe. / Durée Résid. à amort.)  " ) From =G_GLOB0
    WDOTEXELIN = [M:DIV]VLNAMT * ( WDURDET / WDURRES )
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXELIN, [M:DIV]CUR, WDOTEXELIN) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXELIN : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXELIN = [M:DIV]RV(1)
  Call ECR_FICH
&      ("FS1", 7, "CAL_DOT_EXE_DV - Linéaire val.rés. / dur. rés. ......... ="-num$(WDOTEXELIN)) From =G_GLOB0

  # Détermination de la dotation exercice
  If ( abs(WDOTEXEDEG) > abs(WDOTEXELIN) ) Then
    [M:DIV]DOTEXE = WDOTEXEDEG
  Else
    [M:DIV]DOTEXE = WDOTEXELIN
  Endif

  # Si valeur nette non nulle et fin d'amortissement antérieur à l'exercice courant elle est soldée
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DV - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_DOT_EXE_DP
#
# - Objet  : Calcule la dotation de l'exercice selon le mode DP
#            Dégressif Portugais Pur (sans passage au linéaire)
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Decimal WDOTEXE    : WDOTEXE     = 0.     : # Dotation exercice


#If ( GUSER = "MWA" and [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DP - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DP - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
   #***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DP - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DP - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DP - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DP - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DP - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DP - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DP - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DP - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DP - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0

  #=================
  # Taux / Duree
  #=================
  #---------------------
  # Durée en année et centième d'année
  [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
  If ( [M:DIV]DURAMTREG < 3. ) Then : [M:DIV]DURAMTREG = 3. : Endif
  # Taux dégressif portugais pur calculé selon les mêmes règles que le dégressif portugais mixte
  Call CAL_TAUX_MODE_DP
&      ( [M:DIV]DURAMTREG, [M:DIV]TXAMT) From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DP - Taux  d'amortissement =" + num$([M:DIV]TXAMT ) ) From =G_GLOB0

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  Gosub CAL_DATE_FIN_AMORT_DP From =G_GLOB8
  #---------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DP - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DP - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
    # ***
  Endif

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE,  [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DP - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DP - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
    # La date de fin d'amortissement n'appartient pas à l'exercice
    Call ECR_FICH("FS1",7,
&   "Dotation Exercice = Valnet amort déb exe * Taux d'amortissement * ( Durée Détention Exe. / Durée exercice)  " ) From =G_GLOB0
    WDOTEXE = [M:DIV]VLNAMT * ( [M:DIV]TXAMT ) * ( WDURDET / [M:DIV]DUREXE )
  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    # La fin d'amortissement a lieu dans l'exercice
    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.
    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH
&        ("FS1", 7, "CAL_DOT_EXE_DP - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

    If ( WDURRES = 0 ) Then
      WDOTEXE = 0
    Else
    Call ECR_FICH("FS1",7,
&   "Dotation Exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée residuelle)  " ) From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES )
    Endif
  Endif
  #-1 --------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DP - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End



#########################################################
Subprog  CAL_DOT_EXE_IT
#
# - Objet  : Calcule la dotation de l'exercice selon le mode IT
#            Ordinario Anticipato
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire GCFC20
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Integer WNUMANN    : WNUMANN     = 0      : # N° Annuité
Local Decimal WDOTORD    : WDOTORD     = 0.     : # Dotation Ordinario
Local Decimal WDOTANT    : WDOTANT     = 0.     : # Dotation Anticipato

Local Integer BSORTIE_A_PRORATER                : # Immo sortie dans l'exercice et à prorater

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.


  #- 1 ---------------------------------------------
  If ( ( [M:DIV]PROEXESOR = G_NON and func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSOREXE,[M:DIV]DTDBEXE,[M:DIV]DTFNEXE,"I"))
&    or
&      ( [M:DIV]DATSOREXE <> [0/0/0] and [M:DIV]DATSOREXE <[M:DIV]DTDBEXE )) Then
    # Pas de dotation pour l'exercice de sortie lorsque pas de prorata lors du désinvestissement
    # FQ68143 Pas de dotation au delà de l'exercice de sortie.
    [M:DIV]DOTEXE = 0.
    [M:DIV]AMTEXC = 0.
    Call ECR_FICH ("FS1", 7, "CAL_DOT_EXE_IT - Pas de prorata lors du désinvestissement") From =G_GLOB0
    Call ECR_FICH ("FS1", 7, "CAL_DOT_EXE_IT - Pas de dotation l'année de sortie " ) From =G_GLOB0
  #- 1 ---------------------------------------------
  Else

    If ( [M:DIV]PROEXESOR = G_OUI and
&        func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSOREXE,[M:DIV]DTDBEXE,[M:DIV]DTFNEXE,"I") ) Then
      # Immo sortie dans l'exercice et à prorater
      BSORTIE_A_PRORATER = 1
    Else
      BSORTIE_A_PRORATER = 0
    Endif

    If ( [M:DIV]NIVDET > 7 ) Then
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_IT - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_IT - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_IT - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_IT - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_IT - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_IT - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_IT - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_IT - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_IT - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
    Endif

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_IT - Bien " + mess([F:WFAS]AASTYP,GML_TYPIMMO,1) -
&                                                      mess([F:WFAS]PURNAT,GML_NATACHAT,1) ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_IT - Valeur amortissable   =" + num$([M:DIV]VALAMT) ) From =G_GLOB0

    #=================
    # Taux / Durée
    #=================
    #---------------------
    # Durée non saisie
    [M:DIV]DURAMTREG = 0.00
    # Taux arrondis à 4 décimales
    [M:DIV]TXAMT    = arr( [F:DEPC]DPRRAT,  0.000001)
    [F:DEPC]DPRRAT2 = arr( [F:DEPC]DPRRAT2, 0.000001)
    #---------------------
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_IT - Taux  Amt Ordinario   =" + num$([M:DIV]TXAMT) ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_IT - Taux  Amt Anticipato  =" + num$([F:DEPC]DPRRAT2) ) From =G_GLOB0

    #=================
    # Date Fin Amort.
    #=================
    # Sans Date de Fin d'Amortissement
    Gosub CAL_DATE_FIN_AMORT_IT From =G_GLOB8

    # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
    If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_IT - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
      [M:DIV]AMTEXC = 0.
      [M:DIV]DOTEXE = 0.
      Gosub CAL_RMVLVL From =G_GLOB0
      End
    # ***
    Endif


    # Numéro d'annuités
    WNUMANN = func GLOBB8.CAL_NUMERO_EXERCICE( [M:DIV]DTDBAMTREG, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE)

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_IT - Annuité n°            =" + num$(WNUMANN)       ) From =G_GLOB0

    #=================
    # Ordinario
    #=================
    #------------------------
    # FQ60562
    If ( WNUMANN = 0 ) Then
      Call ECR_FICH("FS1",7, "Ordinario = 0 Début d'amortissement dans exercice futur  " ) From =G_GLOB0
      WDOTORD = 0
    #FQ67848 Elsif ( WNUMANN = 1 and [F:WFAS]AASTYP = GVML_TICORPO and [M:DIV]PROEXEINV <> G_OUI and [M:DIV]DTDBAMTREG < [01/01/2008] ) Then
    #FQ85563 Elsif ( WNUMANN = 1 and [F:WFAS]AASTYP = GVML_TICORPO and [M:DIV]PROEXEINV <> G_OUI ) Then
    Elsif ( WNUMANN = 1 and [F:WFAS]AASTYP = GVML_TICORPO ) Then
      # 1/2 dotation ordinario la 1ère annuité pour un bien corporel sans prorata
      Call ECR_FICH("FS1",7,
&     "Avant 01/01/2008 - Corporel, sans prorata d'invest, 1ère année => Ordinario= Val. amort. * Taux Amt Ordinario / 2") From =G_GLOB0
      WDOTORD = [M:DIV]VALAMT * [M:DIV]TXAMT / 2
    Else
      Call ECR_FICH("FS1",7,
&     "Ordinario = Valeur amortissable * Taux Amt Ordinario " ) From =G_GLOB0
      WDOTORD = [M:DIV]VALAMT * [M:DIV]TXAMT
    Endif
    #------------------------

    #=================
    # Anticipato
    #=================
    #-2 -----------------------
    If ( [F:WFAS]PURNAT = GVML_NANEUF ) Then
      # Bien Neuf
      #-3 -----------------------
      If ( WNUMANN = 0 ) Then
        Call ECR_FICH("FS1",7, "Anticipato = 0 Début d'amortissement dans exercice futur  " ) From =G_GLOB0
        WDOTANT = 0
      #FQ85563 Elsif ( WNUMANN = 1 and [F:WFAS]AASTYP = GVML_TICORPO and [M:DIV]PROEXEINV <> G_OUI ) Then
      Elsif ( WNUMANN = 1 and [F:WFAS]AASTYP = GVML_TICORPO ) Then
        # 1/2 dotation anticipato la 1ère annuité pour un bien corporel sans prorata
        Call ECR_FICH("FS1",7,
&       "Neuf : Corporel, sans prorata d'invest, 1ère année => Anticipato = Valeur amortissable * ( Taux Amt Anticipato /2 ) " ) From =G_GLOB0
        WDOTANT = [M:DIV]VALAMT * ( [F:DEPC]DPRRAT2 ) / 2
      Else
        #-4 -----------------------
        If ( WNUMANN < 4 ) Then
          # Amortissement anticipato les 3 premières années pour les biens neufs
          Call ECR_FICH("FS1",7,
&         "Neuf : 3 premières années => Anticipato = Valeur amortissable * ( Taux Amt Anticipato ) " ) From =G_GLOB0
          WDOTANT = [M:DIV]VALAMT * ( [F:DEPC]DPRRAT2 )
        Endif
        #-4 -----------------------
      Endif
      #-3 -----------------------
    #-2 -----------------------
    Else
      # Bien d'Occasion
      #-3 -----------------------
      If ( WNUMANN = 0 ) Then
        Call ECR_FICH("FS1",7, "Anticipato = 0 Début d'amortissement dans exercice futur  " ) From =G_GLOB0
        WDOTANT = 0
      Elsif ( WNUMANN = 1 ) Then
        # Amortissement anticipato uniquement la première année pour les biens d'occasion
        #-4 -----------------------
        #FQ85563 If ( [F:WFAS]AASTYP = GVML_TICORPO and [M:DIV]PROEXEINV <> G_OUI ) Then
        If ( [F:WFAS]AASTYP = GVML_TICORPO ) Then
          # 1/2 dotation anticipato la 1ère annuité pour un bien corporel sans prorata
          Call ECR_FICH("FS1",7,
&         "Occasion : Corporel, sans prorata d'invest, 1ère année => Anticipato = Valeur amortissable * ( Taux Amt Anticipato /2 ) " ) From =G_GLOB0
          WDOTANT = [M:DIV]VALAMT * ( [F:DEPC]DPRRAT2 ) / 2
        #-4 -----------------------
        Else
          Call ECR_FICH("FS1",7,
&         "Occasion :  1ère année => Anticipato = Valeur amortissable * ( Taux Amt Anticipato ) " ) From =G_GLOB0
          WDOTANT = [M:DIV]VALAMT * ( [F:DEPC]DPRRAT2 )
        Endif
        #-4 -----------------------
      Endif
      #-3 -----------------------
    Endif
    #-2 -----------------------

    #==========================
    # Application d'un prorata
    #==========================
    #-2 -----------------------
    #FQ85563 If ( ( WNUMANN = 1 and [M:DIV]PROEXEINV = G_OUI ) or BSORTIE_A_PRORATER ) Then
    If ( BSORTIE_A_PRORATER ) Then
    # Application d'un prorata si exercice d'acquisition & prorata exercice d'investissement
    # ou bien sorti dans l'exercice avec un prorata exercice de désinvestissement

#   FQ85563
#      If ( WNUMANN = 1 and [M:DIV]PROEXEINV = G_OUI ) Then
#        Call ECR_FICH
#&            ("FS1", 7, "CAL_DOT_EXE_PR - Dotation Exercice d'investissement à prorater" ) From =G_GLOB0
#      Endif

      If ( BSORTIE_A_PRORATER ) Then
      Call ECR_FICH
&          ("FS1", 7, "CAL_DOT_EXE_PR - Dotation Exercice de désinvestissement à prorater" ) From =G_GLOB0
      Endif

      # Durée de détention dans l'exercice
#     Call  CAL_DUR_DET
#&          ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&          [M:DIV]DTFNAMT, [M:DIV]DATSOREXE,  [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_CAL_DUR_DET From =G_GLOB8
      WDURDET = [M:DIV]RV(1)
      If ([M:DIV]ERROR) Then : End : Endif
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_IT - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_IT - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

      Call ECR_FICH("FS1",7,
&     "Application prorata :  Ordinario & Anticipato = Dotation à prorater * ( Durée Détention Exe. / Durée Exercice ) " ) From =G_GLOB0

      WDOTORD = WDOTORD * ( WDURDET / [M:DIV]DUREXE )
      WDOTANT = WDOTANT * ( WDURDET / [M:DIV]DUREXE )
    Endif
    #-2 -----------------------

    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WDOTORD, [M:DIV]CUR , WDOTORD) From =G_GLOB8
    [M:DIV]PV(0)= WDOTORD : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTORD = [M:DIV]RV(1)
    #Call CAL_ARRONDI_MNT (WDOTANT, [M:DIV]CUR , WDOTANT) From =G_GLOB8
    [M:DIV]PV(0)= WDOTANT : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTANT = [M:DIV]RV(1)

    # Sécurité, les dotations ne peuvent pas être > à la valeur nette - ajustement éventuel
    # Ordinario - Dotation exercice
    If ( abs(WDOTORD) > abs([M:DIV]VLNAMT)) Then
      [M:DIV]DOTEXE = [M:DIV]VLNAMT
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_IT - Dotation > Valeur nette => Solde ") From =G_GLOB0
    Else
      [M:DIV]DOTEXE = WDOTORD
    Endif
    # Anticipato - Dotation exceptionnel
    If ( abs([M:DIV]DOTEXE+WDOTANT) > abs([M:DIV]VLNAMT)) Then
      [M:DIV]AMTEXC = [M:DIV]VLNAMT - [M:DIV]DOTEXE
    Else
      [M:DIV]AMTEXC = WDOTANT
    Endif

  Endif
  #- 1 ---------------------------------------------


  Call ECR_FICH
& ("FS1", 7, "CAL_DOT_EXE_IT > Dotation Ordinario  ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
  Call ECR_FICH
& ("FS1", 7, "CAL_DOT_EXE_IT > Amt Excp Anticipato ="+ format$([M:DIV]CURFMT,[M:DIV]AMTEXC) ) From =G_GLOB0


  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CAL_DOT_EXE_UD
#
# - Objet  : Calcule la dotation de l'exercice selon le mode UD
#            Declining Balance
#
#   Rem. 1°) Lorsque le porata temporis est "1/2 année"
#            Le début d'amt pour la dotation exercice est le milieu du semestre du début d'amt
#            Le début d'amt pour la dotation période  est le début de mois du début d'amt (prorata mois)
#        2°) Lorsque le prorara temporis est "1/2 année" ou "1/2 mois"
#            Calcul de la dotation exercice sans tenir compte de la date de sortie
#            Puis la dotation exercice est proratée par rapport à la date de sortie
#
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire GCFC20
#

Local Decimal WTXAMT     : WTXAMT      = 0.     : # Taux d'amortissement
Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Decimal WDOTEXEDEG : WDOTEXEDEG  = 0.     : # Dotation exercice en dégressif
Local Decimal WDOTEXELIN : WDOTEXELIN  = 0.     : # Dotation exercice en linéaire sur valeur résiduelle
Local Date    WDTDBAMT   :                      : # Date de début d'amort régularisé pour dotation exercice


  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_UD - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0


  #=================
  # Taux / Duree
  #=================
  #---------------------
  # Durée en année et centième d'année
  [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
  # Taux d'amortissement - Utilisation d'une variable locale car pas d'arrondi
  WTXAMT = ( 1 / [M:DIV]DURAMTREG ) * [F:DEPC]ACLCOE
  # Pas de taux d'amortissement en table
  [M:DIV]TXAMT   = 0.00
  #---------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Durée d'amortissement =" + num$([M:DIV]DURAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Coef. d'accélèration  =" + num$([F:DEPC]ACLCOE) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Taux  d'amortissement =" + num$(WTXAMT)             ) From =G_GLOB0

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Selon type de prorata saisi avec Date de début d'amortissement (fichier)
  Gosub CAL_DATE_FIN_AMORT_UD From =G_GLOB8
  #---------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #***********************************************************************
  # FQ88728
#  If ( [M:DIV]TYPPRO = GVML_TPHLFY or [M:DIV]TYPPRO = GVML_TPHLFQ ) Then
#
#    # Si prorata "Half Year"
#    # le début d'amort. pour le calcul de la dot. exe. est le milieu du semestre d'acquistion
#    # le début d'amort. pour le calcul de la dot. per. est le début du mois d'acquistion
#    If ( [M:DIV]TYPPRO = GVML_TPHLFY ) Then
#      # AU début du deuxième Semestre de l'année du début d'amortissement
#      WDTDBAMT = gdat$(01, 07, year([F:DEPC]STRDPRDAT))
#    Else
#      WDTDBAMT = [M:DIV]DTDBAMTREG
#    Endif
#
#    # Durée de détention dans l'exercice ( sans tenir compte de la date de sortie)
##   Call  CAL_DUR_DET
##&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
##&        [M:DIV]DTFNAMT, [M:DIV]DATNUL, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
#    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
#    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
#    [M:DIV]PD(6)= [M:DIV]DATNUL : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
#    Gosub GSB_CAL_DUR_DET From =G_GLOB8
#    WDURDET = [M:DIV]RV(1)
#    If ([M:DIV]ERROR) Then : End : Endif
#    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
#    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0
#
#    #---------------------------------------------
#    # Calcul Dotation exercice dégressive
#    #---------------------------------------------
#    Call ECR_FICH("FS1",7,
#&   "Dotation dégressif = Valnet amort déb exe * Taux  d'amortissement * ( Durée Détention Exe. / Durée Exercice)  " ) From =G_GLOB0
#    WDOTEXEDEG = [M:DIV]VLNAMT * ( WTXAMT ) * ( WDURDET / [M:DIV]DUREXE )
#
#    # Arrondi dans la devise du contexte
#    #Call CAL_ARRONDI_MNT (WDOTEXEDEG, [M:DIV]CUR , WDOTEXEDEG) From =G_GLOB8
#    [M:DIV]PV(0)= WDOTEXEDEG : [M:DIV]PC(0)= [M:DIV]CUR
#    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXEDEG = [M:DIV]RV(1)
#    Call ECR_FICH
#&   ("FS1", 7, "CAL_DOT_EXE_UD - Dotation dégressive ................... ="-num$(WDOTEXEDEG) ) From =G_GLOB0
#
#    # Calcul de la durée restant à amortir
#    Call  CAL_DUR_REST_AMT
#&         (WDTDBAMT, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES) From =G_GLOB8
#    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Linéaire Durée Résid. à amort.  =" + num$(WDURRES)) From =G_GLOB0
#
#    #---------------------------------------------
#    # Calcul Dotation exercice linéaire sur valeur et durée résiduelles
#    #---------------------------------------------
#    # Cas standard
#    If ( WDURRES = 0 ) Then
#      WDOTEXELIN = 0
#    Else
#      Call ECR_FICH("FS1",7,
#&     "Dotation linéaire = Valnet amort déb exe * ( Durée Détention Exe. / Durée résiduelle)  " ) From =G_GLOB0
#      WDOTEXELIN = [M:DIV]VLNAMT * ( WDURDET / WDURRES )
#    Endif
#
#    # Arrondi dans la devise du contexte
#    #Call CAL_ARRONDI_MNT (WDOTEXELIN, [M:DIV]CUR, WDOTEXELIN) From =G_GLOB8
#    [M:DIV]PV(0)= WDOTEXELIN : [M:DIV]PC(0)= [M:DIV]CUR
#    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXELIN = [M:DIV]RV(1)
#    Call ECR_FICH
#&        ("FS1", 7, "CAL_DOT_EXE_UD - Linéaire val.rés./dur rés.............. ="-num$(WDOTEXELIN)) From =G_GLOB0
#
#    # Détermination de la dotation exercice
#    If ( abs(WDOTEXEDEG) > abs(WDOTEXELIN) ) Then
#      [M:DIV]DOTEXE = WDOTEXEDEG
#    Else
#      [M:DIV]DOTEXE = WDOTEXELIN
#    Endif
#
#    # Prise en compte de la date de sortie
#    If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSOREXE, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
#      # Durée de détention dans l'exercice ( sans tenir compte de la date de fin d'amortissement
##     Call  CAL_DUR_DET
##&          ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
##&          [M:DIV]DATNUL, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
#      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
#      [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DATNUL
#      [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
#      Gosub GSB_CAL_DUR_DET From =G_GLOB8
#      WDURDET = [M:DIV]RV(1)
#      If ([M:DIV]ERROR) Then : End : Endif
#      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Prise en compte de la SORTIE" ) From =G_GLOB0
#      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Dot. exe. provisoire  ="-num$([M:DIV]DOTEXE)) From =G_GLOB0
#      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
#      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0
#      Call ECR_FICH("FS1",8,
#&     "Dotation Exercice = Dot. exe. provisoire * ( Durée Détention Exe. / Durée Exercice)  " ) From =G_GLOB0
#      [M:DIV]DOTEXE = [M:DIV]DOTEXE * ( WDURDET / [M:DIV]DUREXE )
#    Endif

  #***********************************************************************
#  Else

    # Durée de détention dans l'exercice
#   Call  CAL_DUR_DET
#&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&        [M:DIV]DTFNAMT, [M:DIV]DATSOREXE,  [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_CAL_DUR_DET From =G_GLOB8
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

    #---------------------------------------------
    # Calcul Dotation exercice dégressive
    #---------------------------------------------
    Call ECR_FICH("FS1",7,
&   "Dotation dégressif = Valnet amort déb exe * Taux  d'amortissement * ( Durée Détention Exe. / Durée Exercice)  " ) From =G_GLOB0
    WDOTEXEDEG = [M:DIV]VLNAMT * ( WTXAMT ) * ( WDURDET / [M:DIV]DUREXE )

    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WDOTEXEDEG, [M:DIV]CUR , WDOTEXEDEG) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXEDEG : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXEDEG = [M:DIV]RV(1)
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_UD - Dotation dégressive ................... ="-num$(WDOTEXEDEG) ) From =G_GLOB0

    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Linéaire Durée Résid. à amort.  =" + num$(WDURRES)) From =G_GLOB0

    #---------------------------------------------
    # Calcul Dotation exercice linéaire sur valeur et durée résiduelles
    #---------------------------------------------
    # Cas standard
    If ( WDURRES = 0 ) Then
      WDOTEXELIN = 0
    Else
      Call ECR_FICH("FS1",7,
&     "Dotation linéaire = Valnet amort déb exe *  ( Durée Détention Exe. / Durée résiduelle)  " ) From =G_GLOB0
      WDOTEXELIN = [M:DIV]VLNAMT * ( WDURDET / WDURRES )
    Endif

    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WDOTEXELIN, [M:DIV]CUR, WDOTEXELIN) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXELIN : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXELIN = [M:DIV]RV(1)
    Call ECR_FICH
&        ("FS1", 7, "CAL_DOT_EXE_UD - Linéaire val.rés./dur rés.............. ="-num$(WDOTEXELIN)) From =G_GLOB0

    # Détermination de la dotation exercice
    If ( abs(WDOTEXEDEG) > abs(WDOTEXELIN) ) Then
      [M:DIV]DOTEXE = WDOTEXEDEG
    Else
      [M:DIV]DOTEXE = WDOTEXELIN
    Endif
  # FQ88728
  #Endif
  #***********************************************************************

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE: [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UD - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CAL_DOT_EXE_UL
#
# - Objet  : Calcule la dotation de l'exercice selon le mode UL
#            Straight Line
#
#   Rem. 1°) Lorsque le porata temporis est "1/2 année"
#            Le début d'amt pour la dotation exercice est le milieu du semestre du début d'amt
#            Le début d'amt pour la dotation période  est le début de mois du début d'amt (prorata mois)
#        2°) Lorsque le prorara temporis est "1/2 année" ou "1/2 mois"
#            Calcul de la dotation exercice sans tenir compte de la date de sortie
#            Puis la dotation exercice est proratée par rapport à la date de sortie
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire GCFC20
#

Local Decimal WTXAMT     : WTXAMT      = 0.     : # Taux d'amortissement
Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Date    WDTDBAMT   :                      : # Date de début d'amort régularisé pour dotation exercice

  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_UL - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UL - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UL - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UL - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UL - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UL - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UL - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UL - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UL - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UL - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0
  Endif

  #=================
  # Taux / Duree
  #=================
  #---------------------
  # Durée en année et centième d'année
  [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
  # Taux d'amortissement - Utilisation d'une variable locale car pas d'arrondi
  WTXAMT = ( 1 / [M:DIV]DURAMTREG )
  # Pas de taux d'amortissement en table
  [M:DIV]TXAMT   = 0.00
  #---------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Taux  d'amortissement =" + num$(WTXAMT) ) From =G_GLOB0

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Selon type de prorata saisi avec Date de début d'amortissement (fichier)
  # Mêmes règles que le mode UD - Declining Balance
  Gosub CAL_DATE_FIN_AMORT_UL From =G_GLOB8
  #---------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Val. amortissable     =" + num$([M:DIV]VALAMT) ) From =G_GLOB0


  #***********************************************************************
# FQ88728
#  If ( [M:DIV]TYPPRO = GVML_TPHLFY or [M:DIV]TYPPRO = GVML_TPHLFQ ) Then
#
#    # Si prorata "Half Year"
#    # le début d'amort. pour le calcul de la dot. exe. est le milieu du semestre d'acquistion
#    # le début d'amort. pour le calcul de la dot. per. est le début du mois d'acquistion
#    If ( [M:DIV]TYPPRO = GVML_TPHLFY ) Then
#      # AU début du deuxième Semestre de l'année du début d'amortissement
#      WDTDBAMT = gdat$(01, 07, year([F:DEPC]STRDPRDAT))
#    Else
#      WDTDBAMT = [M:DIV]DTDBAMTREG
#    Endif
#
#    # Durée de détention dans l'exercice ( sans tenir compte d'une sortie éventuelle)
##   Call  CAL_DUR_DET
##&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
##&        [M:DIV]DTFNAMT, [M:DIV]DATNUL,  [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
#    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
#    [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
#    [M:DIV]PD(6)= [M:DIV]DATNUL    : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
#    Gosub GSB_CAL_DUR_DET From =G_GLOB8
#    WDURDET = [M:DIV]RV(1)
#    If ([M:DIV]ERROR) Then : End : Endif
#    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
#
#
#    #-1 ------------------
#    If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
#    # La date de fin d'amortissement n'appartient pas à l'exercice
#        #---------------------------------------------
#        # Calcul Dotation exercice
#        #---------------------------------------------
#        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0
#        Call ECR_FICH("FS1",7,
#&       "Dotation exercice = Val. amortissable * Taux  d'amortissement * ( Durée Détention Exe. / Durée Exercice)  " ) From =G_GLOB0
#        [M:DIV]DOTEXE = [M:DIV]VALAMT * ( WTXAMT ) * ( WDURDET / [M:DIV]DUREXE )
#    #-1 --------------------
#    Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
#      # La date de fin d'amortissement appartient à l'exercice
#
#      # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
#      # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.
#
#      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
#      # Calcul de la durée restant à amortir
#      Call  CAL_DUR_REST_AMT
#&           (WDTDBAMT, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
#&     From =G_GLOB8
#      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0
#
#      # calcul de la dotation exercice
#      If ( WDURRES <> 0 ) Then
#        Call ECR_FICH("FS1",7,
#&       "Dotation exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée residuelle)  " ) From =G_GLOB0
#        [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
#      Else
#        [M:DIV]DOTEXE = 0
#      Endif
#    Endif
#    #-1 --------------------
#
#    # Arrondi dans la devise du contexte
#    #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
#    [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
#    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
#
#    # Prise en compte de la date de sortie
#    If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSOREXE, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
#      # Durée de détention dans l'exercice ( sans tenir compte de la date de fin d'amortissement
##     Call  CAL_DUR_DET
##&          ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
##&          [M:DIV]DATNUL, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
#      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
#      [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DATNUL
#      [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
#      Gosub GSB_CAL_DUR_DET From =G_GLOB8
#      WDURDET = [M:DIV]RV(1)
#      If ([M:DIV]ERROR) Then : End : Endif
#      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Prise en compte de la SORTIE" ) From =G_GLOB0
#      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Dot. Exe. provisoire  =" + num$(WDURDET) ) From =G_GLOB0
#      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
#      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_UD - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0
#      Call ECR_FICH("FS1",7,
#&     "Dotation exercice = Dot. Exe. provisoire * ( Durée Détention Exe. / Durée Exercice)  " ) From =G_GLOB0
#      [M:DIV]DOTEXE = [M:DIV]DOTEXE * ( WDURDET / [M:DIV]DUREXE )
#      # Arrondi dans la devise du contexte
#      #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
#      [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
#      Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
#    Endif
#
#  #***********************************************************************
#  Else
    # Durée de détention dans l'exercice
#   Call  CAL_DUR_DET
#&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&        [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  #*!
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_CAL_DUR_DET From =G_GLOB8
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Durée exercice de référence =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

    #-1 ------------------
    If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
    # La date de fin d'amortissement n'appartient pas à l'exercice
      #---------------------------------------------
      # Calcul Dotation exercice
      #---------------------------------------------
        Call ECR_FICH("FS1",7,
&       "Dotation exercice = Val. amortissable * Taux  d'amortissement * ( Durée Détention Exe. / Durée Exercice)  " ) From =G_GLOB0
      [M:DIV]DOTEXE = [M:DIV]VALAMT * ( WTXAMT ) * ( WDURDET / [M:DIV]DUREXE )
    #-1 --------------------
    Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
      # La date de fin d'amortissement appartient à l'exercice
      # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
      # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
      # Calcul de la durée restant à amortir
      Call  CAL_DUR_REST_AMT
&           ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&     From =G_GLOB8
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

      # calcul de la dotation exercice
      If ( WDURRES <> 0 ) Then
        Call ECR_FICH("FS1",7,
&       "Dotation exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée residuelle)  " ) From =G_GLOB0
        [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
      Else
        [M:DIV]DOTEXE = 0
      Endif
    Endif
    #-1 --------------------

    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
    [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

#  FQ88728
#  Endif
  #***********************************************************************
  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UL - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#########################################################
Subprog  CAL_DOT_EXE_DB
#
# - Objet  : Calcule la dotation de l'exercice selon le mode DB
#            Dégressif Belge
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Decimal WDOTEXEDEG : WDOTEXEDEG  = 0.     : # Dotation exercice en dégressif
Local Decimal WDOTEXELIN : WDOTEXELIN  = 0.     : # Dotation exercice en linéaire
Local Decimal WTXLIN     : WTXLIN      = 0.     : # Taux linéaire
Local Decimal WTXMAX     : WTXMAX      = 0.     : # Taux maximum
Local Decimal WDOTMAX    : WDOTMAX     = 0.     : # Dotation maximum 40% de Valeur brute

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DB - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DB - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DB - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DB - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DB - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DB - Base                  =" + num$([M:DIV]BASAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DB - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DB - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Endif

  #=================
  # Taux / Duree
  #=================
  #---------------------
  # Durée en année et centième d'année
  [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
  # Taux linéaire
  # FQ78805
  WTXLIN = 1/[M:DIV]DURAMTREG
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    # Le taux est forcé : Contrôle du taux qui doit être > au taux linéaire & < au taux linéaire * 2.
    WTXMAX =  arr((1/[M:DIV]DURAMTREG * 2.), 0.01)
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    If ([M:DIV]TXAMT < WTXLIN ) Then : [M:DIV]TXAMT = WTXLIN  : Endif
    If ([M:DIV]TXAMT > WTXMAX ) Then : [M:DIV]TXAMT = WTXMAX  : Endif
  Else
    # Le taux est calculé
    # Contrôle du coefficient d'accélèration arrondi à 2 décimales. Il doit être >= 1. et <= 2.
    [F:DEPC]ACLCOE = arr( [F:DEPC]ACLCOE, 0.01)
    If ( [F:DEPC]ACLCOE < 1. ) Then : [F:DEPC]ACLCOE = 1. : Endif
    If ( [F:DEPC]ACLCOE > 2. ) Then : [F:DEPC]ACLCOE = 2. : Endif
    [M:DIV]TXAMT = arr( ( (1/[M:DIV]DURAMTREG) * [F:DEPC]ACLCOE ), 0.0001 )
  Endif
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DB - Taux                  =" + num$([M:DIV]TXAMT)  ) From =G_GLOB0

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  Gosub CAL_DATE_FIN_AMORT_DB From =G_GLOB8
  #---------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Val. amortissable     =" + num$([M:DIV]VALAMT) ) From =G_GLOB0

  # Durée de détention dans l'exercice
  #---------------------
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

  #-1 ------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
  # La date de fin d'amortissement n'appartient pas à l'exercice
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)       ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Taux  dégressif       =" + num$([M:DIV]TXAMT ) ) From =G_GLOB0
    #---------------------------------------------
    # Calcul Dotation exercice dégressive
    #---------------------------------------------
    Call ECR_FICH("FS1",7, "Dotation dégressive = Valnet amort déb exe * Taux  dégressif  " ) From =G_GLOB0
    WDOTEXEDEG = [M:DIV]VLNAMT * [M:DIV]TXAMT

    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WDOTEXEDEG, [M:DIV]CUR , WDOTEXEDEG) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXEDEG : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXEDEG = [M:DIV]RV(1)
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_DB - Dotation dégressive ................... ="-num$(WDOTEXEDEG) ) From =G_GLOB0
    #---------------------------------------------
    # Calcul Dotation Linéaire
    #---------------------------------------------
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Val. amortissable     =" + num$([M:DIV]VALAMT) ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Taux linéaire         =" + num$(WTXLIN )       ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "Dotation dégressive = Val. amortissable * Taux  linéaire") From =G_GLOB0
    WDOTEXELIN = [M:DIV]VALAMT * WTXLIN

    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WDOTEXELIN, [M:DIV]CUR, WDOTEXELIN) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXELIN : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXELIN = [M:DIV]RV(1)
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_DB - Dotation linéaire  .................... ="-num$(WDOTEXELIN)) From =G_GLOB0

    # Détermination de la dotation exercice
    If ( abs(WDOTEXEDEG) > abs(WDOTEXELIN) ) Then
      [M:DIV]DOTEXE = WDOTEXEDEG
    Else
      [M:DIV]DOTEXE = WDOTEXELIN
    Endif
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_DB - Dotation à prorater.................... ="-num$([M:DIV]DOTEXE)) From =G_GLOB0

    # Si la dotation est > à la valeur nette
    If ( abs([M:DIV]DOTEXE) > abs([M:DIV]VLNAMT)) Then
      # La dotation est ramenée à la valeur nette
      [M:DIV]DOTEXE = [M:DIV]VLNAMT
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Dotation à prorater ramenée à Valeur nette ") From =G_GLOB0
    Endif

    # La dotation est proratée selon la détention
    Call ECR_FICH("FS1", 7,
&   "Dotation Exercice = Dotation à prorater * (Durée Détention Exe. / Durée exercice)") From =G_GLOB0
    [M:DIV]DOTEXE = [M:DIV]DOTEXE * ( WDURDET / [M:DIV]DUREXE )
  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
  # La date de fin d'amortissement appartient à l'exercice

    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Durée résiduelle      =" +  num$(WDURRES) ) From =G_GLOB0

    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1",7,
&     "Dotation exercice = Valnet amort déb exe * (Durée Détention Exe. / Durée résiduelle)  " ) From =G_GLOB0
      [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      [M:DIV]DOTEXE = 0
    Endif
  #-1 --------------------
  Else
    # La fin d'amortissement est antérieure à l'exercice courant

    # Si valeur nette non nulle elle doit être soldée sur la dotation de l'exercice courant
    # Elle doit l'être aussi soldée dans la période courante
    Gosub EVALUE_FLGSLDPER From =G_GLOB4
  Endif
  #-1 --------------------
  # Si la dotation est > à la valeur nette - La dotation est ramenée à la valeur nette
  If ( abs([M:DIV]DOTEXE) > abs([M:DIV]VLNAMT)) Then
    [M:DIV]DOTEXE = [M:DIV]VLNAMT
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Dotation > Valeur nette => Solde ") From =G_GLOB0
  Else
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Dotation > Au prorata de la détention ") From =G_GLOB0
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la dotation est > à 40% de la valeur "brute"
  WDOTMAX = [M:DIV]BASAMT * 0.4
  #Call CAL_ARRONDI_MNT ( WDOTMAX , [M:DIV]CUR, WDOTMAX ) From =G_GLOB8
  [M:DIV]PV(0)= WDOTMAX : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTMAX  = [M:DIV]RV(1)
  If ( abs([M:DIV]DOTEXE) > abs(WDOTMAX)) Then
    [M:DIV]DOTEXE = WDOTMAX
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Dotation = 40% Valeur Brute      ") From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_DOT_EXE_LB
#
# - Objet  : Calcule la dotation de l'exercice selon le mode LB
#            Linéaire Belge
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Integer WNUMEXE    : WNUMEXE     = 0.     : # N° Exercice

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  # Doublement de la dotation possible les 3 premières exercices
  If ( [F:DEPC]ALWCOD = GVML_RPLBDBL ) Then
    # Numéro d'annuités ( Utilisation des dates Exercice non cadrés et du masque [M:FIY] )
    WNUMEXE = func GLOBB8.CAL_NUMERO_EXERCICE( [F:DEPC]STRDPRDAT, [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT)
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LB - Exercice n°            =" + num$(WNUMEXE)       ) From =G_GLOB0
    If ( WNUMEXE > 3 ) Then : [F:DEPC]ALWCOD = GVML_RPAUCUN : Endif
  Endif

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7,"CAL_DOT_EXE_LB - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LB - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Valeur amortissable
  [M:DIV]VALAMT =  [M:DIV]BASAMT-[F:DEPC]RSDVAL

  #=================
  # Taux / Duree
  #=================
  #---------------------
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    # Calcul de la durée à partir du taux forcé
    Call  CAL_DUREE_SELON_TAUX_LINEAIRE ([M:DIV]TXAMT, [M:DIV]DURAMTREG) From =G_GLOB8
  Else
    # Durée en année et centième d'année
    [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
    # Calcul du taux linéaire à partir de la durée
    # FQ78805
    [M:DIV]TXAMT = 1/[M:DIV]DURAMTREG
  Endif
  #---------------------

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LB - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LB - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LB - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LB - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LB - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LB - Base                  =" + num$([M:DIV]BASAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LB - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LB - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LB - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)           ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LB - Durée                 =" + num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Endif

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  Gosub CAL_DATE_FIN_AMORT_LB From =G_GLOB8
  #---------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LB - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LB - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LB - Val. amortissable     =" + num$([M:DIV]VALAMT) ) From =G_GLOB0

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LB - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

  #-1 ------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
  # La date de fin d'amortissement n'appartient pas à l'exercice
    #-2 --------------------
    If ( [F:DEPC]ALWCOD <> GVML_RPLBABA ) Then

      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LB - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

      #---------------------------------------------
      # Calcul Dotation Linéaire
      #---------------------------------------------
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Val. amortissable     =" + num$([M:DIV]VALAMT)) From =G_GLOB0
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Taux linéaire         =" + num$([M:DIV]TXAMT) ) From =G_GLOB0
      Call ECR_FICH("FS1", 7, "Dotation à prorater = Val. amortissable * Taux linéaire") From =G_GLOB0
      [M:DIV]DOTEXE = [M:DIV]VALAMT * [M:DIV]TXAMT

      # Arrondi dans la devise du contexte
      #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
      [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

      # Si la dotation est > à la valeur nette
      If ( abs([M:DIV]DOTEXE) > abs([M:DIV]VLNAMT)) Then
        # La dotation est ramenée à la valeur nette
        [M:DIV]DOTEXE = [M:DIV]VLNAMT
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DB - Dotation à prorater ramenée à Valeur nette ") From =G_GLOB0
      Endif

      # La dotation est proratée selon la détention
      Call ECR_FICH("FS1", 7,
&     "Dotation Exercice = Dotation à prorater * (Durée Détention Exe. / Durée exercice)") From =G_GLOB0
      [M:DIV]DOTEXE = [M:DIV]DOTEXE * ( WDURDET / [M:DIV]DUREXE )

      If  ( [F:DEPC]ALWCOD = GVML_RPLBDBL ) Then
        [M:DIV]DOTEXE = [M:DIV]DOTEXE * 2
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LB - La dotation doit être doublée"  ) From =G_GLOB0
      Endif
    #-2 --------------------
    Else
       # Calcul de la durée restant à amortir
      Call  CAL_DUR_REST_AMT
&           ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&     From =G_GLOB8
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LB - Durée résiduelle      =" +  num$(WDURRES) ) From =G_GLOB0

      # calcul de la dotation exercice
      If ( WDURRES <> 0 ) Then
       Call ECR_FICH("FS1", 7,
&      "Dotation Exercice = Valnet amort déb exe * (Durée Détention Exe. / Durée résiduelle)") From =G_GLOB0
       [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
      Else
        [M:DIV]DOTEXE = 0
      Endif
    Endif
    #-2 --------------------
  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
  # La date de fin d'amortissement appartient à l'exercice
    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LB - Durée résiduelle      =" +  num$(WDURRES) ) From =G_GLOB0
    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation Exercice = Valnet amort déb exe * (Durée Détention Exe. / Durée résiduelle)") From =G_GLOB0
      [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      [M:DIV]DOTEXE = 0
    Endif
  #-1 --------------------
  Else
    # La fin d'amortissement est antérieure à l'exercice courant

    # Si valeur nette non nulle elle doit être soldée sur la dotation de l'exercice courant
    # Elle doit l'être aussi soldée dans la période courante
    Gosub EVALUE_FLGSLDPER From =G_GLOB4

  Endif
  #-1 --------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la dotation est > à la valeur nette - La dotation est ramenée à la valeur nette
  If ( abs([M:DIV]DOTEXE) > abs([M:DIV]VLNAMT)) Then
    [M:DIV]DOTEXE = [M:DIV]VLNAMT
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LB - Dotation > Valeur nette => Solde ") From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LB - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#########################################################
Subprog  CAL_DOT_EXE_DX
#
# - Objet  : Calcule la dotation de l'exercice selon le mode DX
#            Dégressif Allemand Mixte (avec passage au linéaire)
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Decimal WDOTEXEDEG : WDOTEXEDEG  = 0.     : # Dotation exercice en dégressif
Local Decimal WDOTEXELIN : WDOTEXELIN  = 0.     : # Dotation exercice en linéaire sur valeur résiduelle
Local Decimal WTXLINXN   : WTXLINXN    = 0.     : # Taux lineaire X n fois
# FQ56332
Local Decimal WTXMAX     : WTXMAX      = 0.     : # Taux maximum

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7,"CAL_DOT_EXE_DX - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DX - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #=================
  # Taux / Duree
  #=================
  #---------------------
  # Durée en année et centième d'année
  [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
  #---------------------
  # Taux d'amortissement
  # FQ56332
  # If ( [M:DIV]DTDBAMTREG >= [01/01/2006] and [M:DIV]DTDBAMTREG <= [31/12/2007] ) Then
  #   WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*3, 0.0001)
  #   WTXMAX = 0.3
  # Else
  #   WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*2, 0.0001)
  #   WTXMAX = 0.2
  # Endif
  # [M:DIV]TXAMT = min( WTXLINXN, WTXMAX)
  # ----------------------------------------------
  #  Début       Fin         Coeff.   Taux Max
  # ---------------------------------------------
  #              31/12/2000     3       30%
  #  01/01/2001  31/12/2005     2       20%
  #  01/01/2006  31/12/2007     3       30%
  #  01/01/2008  31/12/2008     1       --
  #  01/01/2009  31/12/2010     2.5     25%
  #  01/01/2011                 1       --
  If ( [F:WFAS]PURDAT < [01/01/2001] ) Then
    WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*3, 0.0001)
    WTXMAX = 0.3
  Elsif ( [F:WFAS]PURDAT < [01/01/2006] ) Then
    WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*2, 0.0001)
    WTXMAX = 0.2
  Elsif ( [F:WFAS]PURDAT < [01/01/2008] ) Then
    WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*3, 0.0001)
    WTXMAX = 0.3
  Elsif ( [F:WFAS]PURDAT >= [01/01/2009] and [F:WFAS]PURDAT <= [31/12/2010] ) Then
    WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*2.5, 0.0001)
    WTXMAX = 0.25
  Else
    WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*1, 0.0001)
    WTXMAX = WTXLINXN
  Endif
  [M:DIV]TXAMT = min( WTXLINXN, WTXMAX)

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  Gosub CAL_DATE_FIN_AMORT_DX From =G_GLOB8
  #---------------------

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DX - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DX - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DX - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DX - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DX - Date de sortie        =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DX - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DX - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DX - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DX - Durée                 =" + num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DX - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DX - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DX - Taux  d'amortissement =" + num$([M:DIV]TXAMT ) ) From =G_GLOB0

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DX - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DX - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

  # Cas standard

  #---------------------------------------------
  # Calcul Dotation exercice dégressive
  #---------------------------------------------
  Call ECR_FICH("FS1", 7,
& "Dotation dégressive = Valnet amort déb exe * Taux d'amortissement * (Durée Détention Exe. / Durée exercice)") From =G_GLOB0
  WDOTEXEDEG = [M:DIV]VLNAMT * ( [M:DIV]TXAMT ) * ( WDURDET / [M:DIV]DUREXE )

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXEDEG, [M:DIV]CUR , WDOTEXEDEG) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXEDEG : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXEDEG = [M:DIV]RV(1)
  Call ECR_FICH
&      ("FS1", 7, "CAL_DOT_EXE_DX - Dotation dégressive ................... ="-num$(WDOTEXEDEG) ) From =G_GLOB0

  # Calcul de la durée restant à amortir
  Call  CAL_DUR_REST_AMT
&       ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
& From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DX - Linéaire Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

  #---------------------------------------------
  # Calcul Dotation exercice linéaire sur valeur et durée résiduelles
  #---------------------------------------------
  If ( WDURRES = 0 ) Then
    WDOTEXELIN = 0
  Else
    Call ECR_FICH("FS1", 7,
&   "Dotation linéaire = Valnet amort déb exe *  (Durée Détention Exe. / Durée résiduelle)") From =G_GLOB0
    WDOTEXELIN = [M:DIV]VLNAMT * ( WDURDET / WDURRES )
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXELIN, [M:DIV]CUR, WDOTEXELIN) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXELIN : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXELIN = [M:DIV]RV(1)
  Call ECR_FICH ("FS1", 7, "CAL_DOT_EXE_DX - Linéaire val.rés. / dur. rés. ......... ="-num$(WDOTEXELIN)) From =G_GLOB0

  # Détermination de la dotation exercice
  If ( abs(WDOTEXEDEG) > abs(WDOTEXELIN) ) Then
    [M:DIV]DOTEXE = WDOTEXEDEG
  Else
    [M:DIV]DOTEXE = WDOTEXELIN
  Endif

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DX - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#########################################################
Subprog  CAL_DOT_EXE_DA
#
# - Objet  : Calcule la dotation de l'exercice selon le mode DA
#            Dégressif Allemand Pur (sans passage au linéaire)
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Decimal WTXLINXN   : WTXLINXN    = 0.     : # Taux lineaire X n fois
# FQ56332
Local Decimal WTXMAX     : WTXMAX      = 0.     : # Taux maximum


  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DA - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DA - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #=================
  # Taux / Duree
  #=================
  #---------------------
  # Durée en année et centième d'année
  [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
  #---------------------
  #---------------------
  # Taux d'amortissement
  # FQ56332
  # If ( [M:DIV]DTDBAMTREG >= [01/01/2006] and [M:DIV]DTDBAMTREG <= [31/12/2007] ) Then
  #   WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*3, 0.0001)
  #   WTXMAX = 0.3
  # Else
  #   WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*2, 0.0001)
  #   WTXMAX = 0.2
  # Endif
  # [M:DIV]TXAMT = min( WTXLINXN, WTXMAX)
  # ----------------------------------------------
  #  Début       Fin         Coeff.   Taux Max
  # ---------------------------------------------
  #              31/12/2000     3       30%
  #  01/01/2001  31/12/2005     2       20%
  #  01/01/2006  31/12/2007     3       30%
  #  01/01/2008  31/12/2008     1       --
  #  01/01/2009  31/12/2010     2.5     25%
  #  01/01/2011                 1       --
  If ( [F:WFAS]PURDAT < [01/01/2001] ) Then
    WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*3, 0.0001)
    WTXMAX = 0.3
  Elsif ( [F:WFAS]PURDAT < [01/01/2006] ) Then
    WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*2, 0.0001)
    WTXMAX = 0.2
  Elsif ( [F:WFAS]PURDAT < [01/01/2008] ) Then
    WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*3, 0.0001)
    WTXMAX = 0.3
  Elsif ( [F:WFAS]PURDAT >= [01/01/2009] and [F:WFAS]PURDAT <= [31/12/2010] ) Then
    WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*2.5, 0.0001)
    WTXMAX = 0.25
  Else
    WTXLINXN = arr( (1/[M:DIV]DURAMTREG)*1, 0.0001)
    WTXMAX = WTXLINXN
  Endif
  [M:DIV]TXAMT = min( WTXLINXN, WTXMAX)

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  Gosub CAL_DATE_FIN_AMORT_DA From =G_GLOB8
  #---------------------

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DA - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DA - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DA - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DA - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DA - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DA - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DA - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DA - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DA - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DA - Durée                 =" + num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DA - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DA - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DA - Taux  d'amortissement =" + num$([M:DIV]TXAMT ) ) From =G_GLOB0

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DX - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DA - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0


  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
    # La date de fin d'amortissement n'appartient pas à l'exercice
    Call ECR_FICH("FS1", 7,
&   "Dotation exercice = Valnet amort déb exe * Taux d'amortissement * (Durée Détention Exe. / Durée exercice)") From =G_GLOB0
    [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( [M:DIV]TXAMT ) * ( WDURDET / [M:DIV]DUREXE )

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    # La fin d'amortissement a lieu dans l'exercice

    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH
&        ("FS1", 7, "CAL_DOT_EXE_DA - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

    If ( WDURRES = 0 ) Then
      [M:DIV]DOTEXE = 0
    Else
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Valnet amort déb exe * Taux d'amortissement * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
      [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES )
    Endif
  Endif
  #-1 --------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DA - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#########################################################
Subprog  CAL_DOT_EXE_LE
#
# - Objet  : Calcule la dotation de l'exercice selon le mode LE
#            Linéaire Espagnol
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire GCFC10
#

#If ( GUSER = "MWA" and [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation exercice

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Taux / Duree
  #=================
  #---------------------
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    # Calcul de la durée à partir du taux forcé ( même traitement que pour le linéaire français )
    Call  CAL_DUREE_SELON_TAUX_LINEAIRE ([M:DIV]TXAMT, [M:DIV]DURAMTREG) From =G_GLOB8
  Else
    # Durée en année et centième d'année
    [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
    # Calcul du taux linéaire à partir de la durée ( même traitement que pour le linéaire français )
    # FQ62812
    Call CAL_TAUX_LINEAIRE ([M:DIV]FLGRNDCHG, [M:DIV]DURAMTREG, [M:DIV]TXAMT) From =G_GLOB8
  Endif
  #---------------------

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Date de fin d'amortissement fonction de l'indicateur 1er exercice décompté pour une année entière
  Gosub CAL_DATE_FIN_AMORT_LE From =G_GLOB8
  #---------------------

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LE - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    # FQ62812 Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 4 décimales pour stockage.
    If( [M:DIV]FLGRNDCHG = G_OUI ) Then : [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LE - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LE - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LE - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LE - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LE - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LE - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LE - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LE - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LE - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LE - Durée                 =" + num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LE - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LE - Val. amortissable     =" + num$([M:DIV]VALAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LE - Taux  Linéaire        =" + num$([M:DIV]TXAMT ) ) From =G_GLOB0

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&       [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LE - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
  # La date de fin d'amortissement n'appartient pas à l'exercice

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LE - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( [M:DIV]DUREXE <> 0 ) Then
      # Valeur amortissable * taux * prorata de détention dans l'exercice
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Val. amortissable * Taux  Linéaire * (Durée Détention Exe. / Durée Exercice)") From =G_GLOB0
      WDOTEXE = [M:DIV]VALAMT * [M:DIV]TXAMT * ( WDURDET / [M:DIV]DUREXE )
    Else
      WDOTEXE = 0
    Endif
    #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , WDOTEXE) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXE = [M:DIV]RV(1)
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LE - Dotation exe.         =" + num$(WDOTEXE) ) From =G_GLOB0
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
  # La date de fin d'amortissement appartient à l'exercice

    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LE - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LE - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Val. nette déb. exe. * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif

  Endif
  #-1 --------------------

  # FQ62812 Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 6 décimales pour stockage.
  If( [M:DIV]FLGRNDCHG = G_OUI ) Then : [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, si la dotation est > à la valeur nette, la dotation ne peut être égale qu'à la valeur nette
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LE - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CAL_DOT_EXE_SL
#
# - Objet  : Calcule la dotation de l'exercice selon le mode SL
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#

Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation exercice

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 1) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Taux / Duree
  #=================
  #---------------------
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    # Calcul de la durée à partir du taux forcé
    Call  CAL_DUREE_SELON_TAUX_SL ([M:DIV]TXAMT, [M:DIV]DURAMTREG) From =G_GLOB8
  Else
    # Durée en année et centième d'année
    [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.001)
    # Calcul du taux linéaire à partir de la durée FQ62812
    Call CAL_TAUX_LINEAIRE ([M:DIV]FLGRNDCHG, [M:DIV]DURAMTREG, [M:DIV]TXAMT) From =G_GLOB8
  Endif
  #---------------------

  If ([M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SL - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SL - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SL - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SL - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SL - Date de sortie Exe.   =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SL - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SL - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SL - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SL - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SL - Durée                 =" + num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Endif
  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  Gosub CAL_DATE_FIN_AMORT_SL From =G_GLOB8

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SL - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    # FQ62812 Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 6 décimales pour stockage.
    If( [M:DIV]FLGRNDCHG = G_OUI ) Then : [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #---------------------
  # FQ82075  Réévaluation 96
  Local Integer B_REEV96 : B_REEV96 = 0
  If( [M:DIV2]FLGR96 = G_OUI and [F:DEPC]DPRPLN = G301CPT and  find([M:DIV]TYPCAL, "R", "T") <> 0 and
&     [F:DEPC]BSEVAL <> [F:DEPC]DPRBAS and [F:WFAS]USRFLDM5 <> 0 and [F:WFAS]USRFLDM6 <> 0 )  Then
    [M:DIV]VALAMT = [F:DEPC]BSEVAL - [F:DEPC]RSDVAL
    B_REEV96 = 1
  Endif

  #---------------------
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SL - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SL - Aide                  =" + num$([M:DIV]AFI)        ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SL - Val. amortissable     =" + num$([M:DIV]VALAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SL - Taux  Linéaire        =" + num$([M:DIV]TXAMT ) ) From =G_GLOB0

  # Gestion de la priorité (Taux/Fin) d'amortissement
  Local Integer B_TXPRI : B_TXPRI = 0
  If ( [M:DIV2]SLTXPRI = G_OUI and [M:DIV]VLNAMT <> 0 and
&      ( [M:DIV]DTFNAMT < [M:DIV]DTDBEXE or func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT,[M:DIV]DTDBEXE,[M:DIV]DTFNEXE,"I") ) ) Then
    B_TXPRI = 1
    # Si le taux d'amortissement est prioritaire et que la valeur nette n'est pas nulle
    # Fin d'amortissement repoussée au delà de la fin d'exercice
    [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNEXE, 1, "D" )
    Local Date WDTFNEXE, WDTDBEXE
    Local Integer WINDEXE
    # Début/Fin exercice
    #Call CAL_EXERCICE_SELON_DATE  ( [M:DIV]DTFNAMT , GVML_TPJOUR, WDTDBEXE, WDTFNEXE, WINDEXE ) From =G_GLOB8
    [M:DIV]PD(0)= [M:DIV]DTFNAMT : [M:DIV]PV(0)= GVML_TPJOUR
    Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
    WDTDBEXE = [M:DIV]RD(1) : WDTFNEXE = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
    If ([M:DIV]ERROR) Then : End : Endif
    [M:DIV]DTFNAMT = WDTFNEXE
  Endif

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&       [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SL - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0


  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
  # La date de fin d'amortissement n'appartient pas à l'exercice

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SL - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( [M:DIV]DUREXE <> 0 ) Then
      # Valeur amortissable * taux * prorata de détention dans l'exercice
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Val. amortissable. * Taux  Linéaire * ( Durée Détention Exe. / Durée Exercice )") From =G_GLOB0
      WDOTEXE = [M:DIV]VALAMT * [M:DIV]TXAMT * ( WDURDET / [M:DIV]DUREXE )
    Else
      WDOTEXE = 0
    Endif
    #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , WDOTEXE) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXE = [M:DIV]RV(1)
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SL - Dotation exe.         =" + num$(WDOTEXE) ) From =G_GLOB0
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
  # La date de fin d'amortissement appartient à l'exercice

    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SL - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SL - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée résiduelle )") From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif

  Endif
  #-1 --------------------

  # FQ62812 Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 6 décimales pour stockage.
  If( [M:DIV]FLGRNDCHG = G_OUI ) Then : [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif

  #---------------------
  # FQ82075  Réévaluation 96
  If (B_REEV96) Then
    WDOTEXE = WDOTEXE * ( 1 + ([F:WFAS]USRFLDM5 / [F:WFAS]USRFLDM6))
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # La fin d'amortissement est antérieure à l'exercice courant
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, si la dotation est > à la valeur nette, la dotation ne peut être égale qu'à la valeur nette
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SL - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Taux prioritaire
  If ( B_TXPRI ) Then
    If ( [M:DIV]DOTEXE = 0 ) Then
      [M:DIV]DTFNAMT = [F:DEPC]ENDDPRDAT
    Else
      WDURRES  = ([M:DIV]VLNAMT / [M:DIV]DOTEXE ) * 365.25
      [M:DIV]DTFNAMT = (func GLOBB9.CAL_DAT_PLUS( max([M:DIV]DTDBAMTREG, [M:DIV]DTDBEXE), WDURRES, "D" )) - 1
    Endif
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_DOT_EXE_DI
#
# - Objet  : Calcule la dotation de l'exercice selon le mode DS
#            Dégressif Espagnol Mixte
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Decimal WDOTEXEDEG : WDOTEXEDEG  = 0.     : # Dotation exercice en dégressif
Local Decimal WDOTEXELIN : WDOTEXELIN  = 0.     : # Dotation exercice en linéaire
Local Decimal WTXLIN     : WTXLIN      = 0.     : # Taux linéaire


  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7,"CAL_DOT_EXE_DI - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DI - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #=================
  # Taux / Duree
  #=================
  #---------------------
  # Durée en année et centième d'année
  [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
  # Taux linéaire
  WTXLIN = arr(1/[M:DIV]DURAMTREG, 0.01)
  # Taux dégressif (le calcul s'effectue de la même manière que pour  le mode DE "Dégressif espagnol pur" )
  Call CAL_TAUX_MODE_DE ( [M:DIV]DURAMTREG, [M:DIV]TXAMT ) From =G_GLOB8

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DI - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DI - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DI - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DI - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DI - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DI - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DI - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DI - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DI - Taux                  =" + num$([M:DIV]TXAMT)      ) From =G_GLOB0
  Endif

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  Gosub CAL_DATE_FIN_AMORT_DI From =G_GLOB8
  #---------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DI - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DI - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DI - Val. amortissable     =" + num$([M:DIV]VALAMT) ) From =G_GLOB0

  # Durée de détention dans l'exercice
  #---------------------
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DI - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

  #-1 ------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
  # La date de fin d'amortissement n'appartient pas à l'exercice

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DI - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DI - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)       ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DI - Taux  dégressif       =" + num$([M:DIV]TXAMT ) ) From =G_GLOB0
    #---------------------------------------------
    # Calcul Dotation exercice dégressive
    #---------------------------------------------
    Call ECR_FICH("FS1", 7, "Dotation dégressive = Valnet amort déb exe. * Taux dégressif") From =G_GLOB0
    WDOTEXEDEG = [M:DIV]VLNAMT * [M:DIV]TXAMT

    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WDOTEXEDEG, [M:DIV]CUR , WDOTEXEDEG) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXEDEG : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXEDEG = [M:DIV]RV(1)
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_DI - Dotation dégressive ................... ="-num$(WDOTEXEDEG) ) From =G_GLOB0
    #---------------------------------------------
    # Calcul Dotation Linéaire
    #---------------------------------------------
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DI - Val. amortissable     =" + num$([M:DIV]VALAMT) ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DI - Taux linéaire         =" + num$(WTXLIN )       ) From =G_GLOB0
    Call ECR_FICH("FS1", 7,
&   "Dotation exercice = Val. amortissable * Taux linéaire") From =G_GLOB0
    WDOTEXELIN = [M:DIV]VALAMT * WTXLIN

    # Arrondi dans la devise du contexte
    #Call CAL_ARRONDI_MNT (WDOTEXELIN, [M:DIV]CUR, WDOTEXELIN) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXELIN : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXELIN = [M:DIV]RV(1)
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_DI - Dotation linéaire  .................... ="-num$(WDOTEXELIN)) From =G_GLOB0

    # Si la dotation linéaire est > à la valeur nette
    If ( abs(WDOTEXELIN) > abs([M:DIV]VLNAMT)) Then
      # La dotation est ramenée à la valeur nette
      [M:DIV]DOTEXE = [M:DIV]VLNAMT
      Call ECR_FICH
&     ("FS1", 7, "CAL_DOT_EXE_DI - Dot. Lin. > Val. Net. Amort. Dotation à prorater ramenée à Valeur nette ")
&     From =G_GLOB0
    Else
      [M:DIV]DOTEXE = WDOTEXEDEG
    Endif

    # La dotation est proratée selon la détention
    Call ECR_FICH("FS1", 7, "Dotation exercice = Dotation à prorater * (Durée Détention Exe. / Durée exercice )") From =G_GLOB0
    [M:DIV]DOTEXE = [M:DIV]DOTEXE * ( WDURDET / [M:DIV]DUREXE )

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
  # La date de fin d'amortissement appartient à l'exercice

    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DI - Durée résiduelle      =" +  num$(WDURRES) ) From =G_GLOB0

    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Valnet amort déb exe. * (Durée Détention Exe. / Durée résiduelle )") From =G_GLOB0
      [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      [M:DIV]DOTEXE = 0
    Endif

  Endif
  #-1 --------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Si la dotation est > à la valeur nette - La dotation est ramenée à la valeur nette
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DI - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End


#########################################################
Subprog  CAL_DOT_EXE_DE
#
# - Objet  : Calcule la dotation de l'exercice selon le mode DS
#            Dégressif Espagnol Pur
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir


  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DE - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DE - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #=================
  # Taux / Duree
  #=================
  #---------------------
  # Durée en année et centième d'année
  [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
  # Taux linéaire
  WTXLIN = arr(1/[M:DIV]DURAMTREG, 0.01)
  # Taux dégressif (le calcul s'effectue de la même manière que pour  le mode DE "Dégressif espagnol pur" )
  Call CAL_TAUX_MODE_DE ( [M:DIV]DURAMTREG, [M:DIV]TXAMT ) From =G_GLOB8

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DE - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DE - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DE - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DE - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DE - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DE - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DE - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DE - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DE - Taux                  =" + num$([M:DIV]TXAMT)      ) From =G_GLOB0
  Endif

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  Gosub CAL_DATE_FIN_AMORT_DE From =G_GLOB8
  #---------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DE - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DE - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DE - Val. amortissable     =" + num$([M:DIV]VALAMT) ) From =G_GLOB0


  # Durée de détention dans l'exercice
  #---------------------
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DE - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

  #-1 ------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
  # La date de fin d'amortissement n'appartient pas à l'exercice

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DE - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DE - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)       ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DE - Taux  dégressif       =" + num$([M:DIV]TXAMT ) ) From =G_GLOB0
    #---------------------------------------------
    Call ECR_FICH("FS1", 7, "Dotation à prorater = Valnet amort déb exe. * Taux dégressif") From =G_GLOB0
    [M:DIV]DOTEXE = [M:DIV]VLNAMT * [M:DIV]TXAMT
    #---------------------------------------------
    # La dotation est proratée selon la détention
    Call ECR_FICH("FS1", 7,
&   "Dotation exercice = Dotation à prorater * ( Durée Détention Exe. / Durée exercice )") From =G_GLOB0
    [M:DIV]DOTEXE = [M:DIV]DOTEXE * ( WDURDET / [M:DIV]DUREXE )

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
  # La date de fin d'amortissement appartient à l'exercice

    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DE - Durée résiduelle      =" +  num$(WDURRES) ) From =G_GLOB0

    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée résiduelle )") From =G_GLOB0
      [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      [M:DIV]DOTEXE = 0
    Endif

  Endif
  #-1 --------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Si la dotation est > à la valeur nette - La dotation est ramenée à la valeur nette
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DE - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End


#########################################################
Subprog  CAL_DOT_EXE_DM
#
# - Objet  : Calcule la dotation de l'exercice selon le mode DM
#            Degressif marocain (avec passage au linéaire)
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   Boite noire
#   FQ 55960
#
Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Decimal WDOTEXEDEG : WDOTEXEDEG  = 0.     : # Dotation exercice en dégressif
Local Decimal WDOTEXELIN : WDOTEXELIN  = 0.     : # Dotation exercice en linéaire sur valeur résiduelle


  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7,"CAL_DOT_EXE_DM - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DM - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #=================
  # Taux / Duree
  #=================
  #---------------------
  # Durée en année entière
  [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 1)
  #---------------------
  # Taux d'amortissement
  Case [M:DIV]DURAMTREG
    When  3. : [M:DIV]TXAMT = 0.5000
    When  4. : [M:DIV]TXAMT = 0.3750
    When  5. : [M:DIV]TXAMT = 0.4000
    When  6. : [M:DIV]TXAMT = 0.3333
    When  7. : [M:DIV]TXAMT = 0.4286
    When  8. : [M:DIV]TXAMT = 0.3750
    When  9. : [M:DIV]TXAMT = 0.3333
    When 10. : [M:DIV]TXAMT = 0.3000
  Endcase

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  Gosub CAL_DATE_FIN_AMORT_DM From =G_GLOB8
  #---------------------

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DM - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DM - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DM - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DM - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DM - Date de sortie        =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DM - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DM - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DM - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DM - Durée                 =" + num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DM - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DM - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DM - Taux  d'amortissement =" + num$([M:DIV]TXAMT )     ) From =G_GLOB0

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DM - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DM - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

  # Cas standard

  #---------------------------------------------
  # Calcul Dotation exercice dégressive
  #---------------------------------------------
  Call ECR_FICH("FS1", 7,
& "Dotation dégressive = Valnet amort déb exe * Taux d'amortissement * (Durée Détention Exe. / Durée exercice)") From =G_GLOB0
  WDOTEXEDEG = [M:DIV]VLNAMT * ( [M:DIV]TXAMT ) * ( WDURDET / [M:DIV]DUREXE )

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXEDEG, [M:DIV]CUR , WDOTEXEDEG) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXEDEG : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXEDEG = [M:DIV]RV(1)
  Call ECR_FICH
&      ("FS1", 7, "CAL_DOT_EXE_DM - Dotation dégressive ................... ="-num$(WDOTEXEDEG) ) From =G_GLOB0

  # Calcul de la durée restant à amortir
  Call  CAL_DUR_REST_AMT
&       ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
& From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DM - Linéaire Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

  #---------------------------------------------
  # Calcul Dotation exercice linéaire sur valeur et durée résiduelles
  #---------------------------------------------
  If ( WDURRES = 0 ) Then
    WDOTEXELIN = 0
  Else
    Call ECR_FICH("FS1", 7,
&   "Dotation linéaire = Valnet amort déb exe *  (Durée Détention Exe. / Durée résiduelle)") From =G_GLOB0
    WDOTEXELIN = [M:DIV]VLNAMT * ( WDURDET / WDURRES )
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXELIN, [M:DIV]CUR, WDOTEXELIN) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXELIN : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXELIN = [M:DIV]RV(1)
  Call ECR_FICH ("FS1", 7, "CAL_DOT_EXE_DM - Linéaire val.rés. / dur. rés. ......... ="-num$(WDOTEXELIN)) From =G_GLOB0

  # Détermination de la dotation exercice
  If ( abs(WDOTEXEDEG) > abs(WDOTEXELIN) ) Then
    [M:DIV]DOTEXE = WDOTEXEDEG
  Else
    [M:DIV]DOTEXE = WDOTEXELIN
  Endif

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DM - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

