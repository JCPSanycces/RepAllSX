#<AdxTL>@(#)0.0.0.0 $Revision$
# MODIFIE PAR : CBO
# LE          : 11 Mai       2015 13:53:26

$OUVRE_TABLE
 If dim(APPLI)<0 : Local Char APPLI(30) : APPLI=nomap : Endif
 If !clalev([F:EVT0]) : Local File =APPLI+".ELOFCNL" [EVT0] : Endif
 If !clalev([F:EVT1]) : Local File =APPLI+".ELOFCNL" [EVT1] : Endif
Return

$CONDITION_EVE
 LCNDREQEVT="CPY=PCPY & REF=PREF & LIN=PLIN & DPRPLN=LPLN &EVTINT=CODEVTINT & SNSEVE=PSNSEVE"
Return

$RAZ_F_EVT0_1
 Raz [F:EVT0]
 Raz [F:EVT1]
Return

$AIGUILLAGE
 Gosub OUVRE_TABLE
 Gosub RAZ_F_EVT0_1
 Gosub LOFCNL1
 [F:EVT0]CPY       = PCPY
 [F:EVT0]FCY       = PFCY
 [F:EVT0]REF       = PREF
 [F:EVT0]CURPERSTR = LCURPERSTR
 [F:EVT0]LIN       = PLIN
 [F:EVT0]CREUSR    = GUSER
 [F:EVT0]CREDAT    = date$
 [F:EVT0]CRETIM    = time
 [F:EVT0]UPDUSR    = ""
 [F:EVT0]UPDDAT    = [0/0/0]
 [F:EVT0]DPRPLN    = LPLN
 [F:EVT0]EVTINT    = CODEVTINT
 [F:EVT0]EVTDAT    = PDAT
 [F:EVT0]CPTFLG    = 1
 [F:EVT0]SNSEVE    = 1
 [F:EVT0]CREUSRO   = ""
 [F:EVT0]TIMSTPO   = ""
 If PACCDAT<>[0/0/0]
  [F:EVT0]CPTDATINT = PACCDAT
 Else
  [F:EVT0]CPTDATINT = PDAT
 Endif
 Gosub CALCUL_TIMSTP
 Gosub ALIM_CUR
Return
 
$CALCUL_TIMSTP
 [F:EVT0]TIMSTP = func GENEVE.BUILD_TIMSTP([F:EVT0]CREDAT, [F:EVT0]CRETIM)
Return

$ALIM_CUR
 [F:EVT0]CUR=Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)
Return

$ANNULE_EVE
 [F:EVT0]SNSEVE = 2
 [F:EVT0]CREUSRO = [F:EVT0]CREUSR
 [F:EVT0]TIMSTPO = [F:EVT0]TIMSTP
 [F:EVT0]CPTDATINTO = [F:EVT0]CPTDATINT
 [F:EVT0]CREUSR = GUSER
 [F:EVT0]CREDAT = date$
 [F:EVT0]CRETIM = time
 [F:EVT0]UPDUSR = ""
 [F:EVT0]UPDDAT = [0/0/0]
 [F:EVT0]CPTFLG = 1
 [F:EVT0]EVTDAT = PDAT
 Gosub CALCUL_TIMSTP
Return

$LOFCNL1
 #--> Désignation
 [F:EVT0]DES        = [F:LOF]DES
 #--> Menus locaux
 #--> Zones numériques
 [F:EVT0]USRFLDM1   = [F:LOF]USRFLDM1
 [F:EVT0]USRFLDM2   = [F:LOF]USRFLDM2
 [F:EVT0]USRFLDM3   = [F:LOF]USRFLDM3
 [F:EVT0]USRFLDM4   = [F:LOF]USRFLDM4
 [F:EVT0]USRFLDM5   = [F:LOF]USRFLDM5
 [F:EVT0]USRFLDM6   = [F:LOF]USRFLDM6
 [F:EVT0]USRFLDC1   = [F:LOF]USRFLDC1
 [F:EVT0]USRFLDC2   = [F:LOF]USRFLDC2
 #--> Zones alphanumériques
 [F:EVT0]CUR        = Func GLOFCYCPY.GET_DEVISE_PLN([F:LOF]CPY,G301CPT)
 [F:EVT0]USRFLDA1   = [F:LOF]USRFLDA1
 [F:EVT0]USRFLDA2   = [F:LOF]USRFLDA2
 [F:EVT0]USRFLDA3   = [F:LOF]USRFLDA3
 [F:EVT0]USRFLDA4   = [F:LOF]USRFLDA4
 [F:EVT0]USRFLDA5   = [F:LOF]USRFLDA5
 [F:EVT0]USRFLDA6   = [F:LOF]USRFLDA6
 [F:EVT0]USRFLDA7   = [F:LOF]USRFLDA7
 [F:EVT0]USRFLDA8   = [F:LOF]USRFLDA8
 [F:EVT0]USRFLDA9   = [F:LOF]USRFLDA9
 [F:EVT0]USRFLDA10  = [F:LOF]USRFLDA10
 #--> Dates
 [F:EVT0]USRFLDD1   = [F:LOF]USRFLDD1
 [F:EVT0]USRFLDD2   = [F:LOF]USRFLDD2
 [F:EVT0]USRFLDD3   = [F:LOF]USRFLDD3
 [F:EVT0]USRFLDD4   = [F:LOF]USRFLDD4
Return

$ECLATE_NBFLD
 LNBFLD=-6
Return

$ECLATE_STATUS
Return

$INFO_EVTINT
 EVT = "LOFCNL"
 LPLN= 1
Return

