Call ECR_TRACE(mess(81,125,1)-"AREPORTV et AREPORTV ("+mess(7,7,1)+") :"-time$,0) From GESECRAN

Trbegin [ARV],[ARX]
 # Codes impressions
 For [ARX]ARX0
  [ARX]TYPCOD = 1
  Rewrite [ARX]
  If fstat : Call ERREUR("AREPORTX",2) From DOSDIC : Endif
 Next
 # Valeurs par defaut
 For [ARV]ARV0
  [ARV]TYPCOD = 1
