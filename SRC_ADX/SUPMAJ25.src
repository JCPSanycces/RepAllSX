######################################################################
# Recuperation des variable globales associées à un parametre
# TRACE pour voir les variables deja crées dans WWAGLOB...subagb
######################################################################
Subprog GLOBPARAM(DOSSIER)
Value Char DOSSIER

Local Integer RANGS,RANGS2,TYPDOS

Local File =DOSSIER+".AGLOBVAR" [AGB] ,  =DOSSIER+".ADOPAR"    [ADP]
&        , =DOSSIER+".ATEXTE"   [ATX1] , =DOSSIER+".ATEXTE"    [ATX2]
&        , =DOSSIER+".ADOVAL"   [ADW]

If dim([F:ADP]GLOBVAR)<=0 : End : Endif

Read [ADW]ADW0="";"";"TYPDOS"
If !fstat & [F:ADW]VALEUR<>""
 TYPDOS = val([F:ADW]VALEUR)-1
Else
 TYPDOS = -1
Endif

Call ECR_TRACE(mess(81,125,1)-"AGLOBVAR ("+mess(86,123,1)+") :"-time$,0) From GESECRAN

Trbegin [AGB]
 For [ADP]ADP0 Where GLOBVAR<>""
  If left$([F:ADP]GLOBVAR,3)<>"[S]" and !instr(1,[F:ADP]GLOBVAR,"(")
   Read [AGB]AGB0 = [F:ADP]GLOBVAR
   If fstat
    Raz [F:AGB]
    Case [F:ADP]TYPVAL
     When 1 : [F:AGB]CODTYP = "A"   : [F:AGB]LNGTYP = "30"
     When 2 : [F:AGB]CODTYP = "DCB"
     When 3 : [F:AGB]CODTYP = "D"
     When 4 : [F:AGB]CODTYP = "M"
    Endcase
    [F:AGB]CODVAR = [F:ADP]GLOBVAR
    [F:AGB]PARAM = [F:ADP]PARAM
    If [F:ADP]NIVDEF<>4
     RANGS += 10
     [F:AGB]TRTSTD = "WWAGLOBVAR"
     [F:AGB]RANG   = [L]RANGS
    Else
     RANGS2 +=10
     [F:AGB]TRTSTD = "WWAGLOBUSR"
     [F:AGB]RANG   = [L]RANGS2
    Endif
    # Issue 86467 - 2012-12-20 by VPO
    #Call COPTEXTE([F:ADP]NAM,[F:AGB]INTIT) From OBJDIV
    [F:AGB]INTIT=[F:ADP]NAM
    Case TYPDOS
     When -1 : # Superviseur
      Case [F:ADP]CHAPITRE
       When "ADX"            : [F:AGB]MODULE = 1    : # Tronc commun
       When "SUP"            : [F:AGB]MODULE = 1    : # Tronc commun
       When "INT"            : [F:AGB]MODULE = 3    : # Interface compta
       When Default          : [F:AGB]MODULE = 11   : # Interne X3
      Endcase
     When 0 : # X3
      Case [F:ADP]CHAPITRE
       When "ADX"            : [F:AGB]MODULE = 1    : # Interne X3
       When "SUP"            : [F:AGB]MODULE = 1    : # Superviseur
       When "ACH"            : [F:AGB]MODULE = 6    : # Achats
       When "CPT"            : [F:AGB]MODULE = 2    : # Comptabilité
       When "STO"            : [F:AGB]MODULE = 7    : # Stocks
       When "VEN"            : [F:AGB]MODULE = 5    : # Ventes
       When "IMM"            : [F:AGB]MODULE = 4    : # Externe
       When "CRM"            : [F:AGB]MODULE = 13   : # Action commerciale
       When "GPA"            : [F:AGB]MODULE = 8    : # GPAO
       When "HDK"            : [F:AGB]MODULE = 12   : # Support client
       When "TC"             : [F:AGB]MODULE = 9    : # Tronc commun
       When "WEB"            : [F:AGB]MODULE = 9    : # Tronc commun
       When "TRS"            : [F:AGB]MODULE = 3    : # Tiers
       When "WEB"            : [F:AGB]MODULE = 9    : # Tronc commun
       When "BUD"            : [F:AGB]MODULE = 2    : # Comptabilité
       When Default          : [F:AGB]MODULE = 9    : # Tronc commun
      Endcase
     When 1 : # Geode
      Case [F:ADP]CHAPITRE
       When "ADX"            : [F:AGB]MODULE = 1    : #
       When "SUP"            : [F:AGB]MODULE = 1    : # Superviseur
       When "DIM"            : [F:AGB]MODULE = 2    : # Geode
       When "IMP"            : [F:AGB]MODULE = 2    : # Geode
       When "INT"            : [F:AGB]MODULE = 2    : # Geode
       When "LA"             : [F:AGB]MODULE = 2    : # Geode
       When "TC"             : [F:AGB]MODULE = 2    : # Geode
       When "UNT"            : [F:AGB]MODULE = 2    : # Geode
       When Default          : [F:AGB]MODULE = 2    : # Geode
      Endcase
     When 2 : # Paye
      Case [F:ADP]CHAPITRE
       When "ADX"            : [F:AGB]MODULE = 1    : #
       When "SUP"            : [F:AGB]MODULE = 1    : # Superviseur
       When "ANA"            : [F:AGB]MODULE = 2    : # Paie
       When "BIL"            : [F:AGB]MODULE = 9    : # Tronc commun
       When "BUL"            : [F:AGB]MODULE = 2    : # Paie
       When "CP"             : [F:AGB]MODULE = 2    : # Paie
       When "CPT"            : [F:AGB]MODULE = 3    : # Interface compta
       When "FRT"            : [F:AGB]MODULE = 5    : # Formation
       When "NOF"            : [F:AGB]MODULE = 6    : # Notes de frais
       When "PAY"            : [F:AGB]MODULE = 2    : # Paie
       When "PLA"            : [F:AGB]MODULE = 2    : # Paie
       When "SEF"            : [F:AGB]MODULE = 7    : # Libre-service
       When "TC"             : [F:AGB]MODULE = 9    : # Tronc commun
       When "TDS"            : [F:AGB]MODULE = 2    : # Paie
       When "TPS"            : [F:AGB]MODULE = 4    : # Gestion temps
       When Default          : [F:AGB]MODULE = 9    : # Tronc commun
      Endcase
     When 3 :  # ABEL
      Case [F:ADP]CHAPITRE
       When "SUP"            : [F:AGB]MODULE = 1    : # Superviseur
       When "ADX"            : [F:AGB]MODULE = 1    : #
       When "FIN"            : [F:AGB]MODULE = 4    : # Financement
       When "AAS"            : [F:AGB]MODULE = 5    : # Immobilisations
       When "IMP"            : [F:AGB]MODULE = 5    : # Immobilisations
       When Default          : [F:AGB]MODULE = 5    : # Immobilisations
      Endcase
    Endcase
    [F:AGB]CODACT = [F:ADP]CODACT
    Write [AGB]
    If fstat : Call ERREUR("AGLOBVAR",1) From DOSDIC : Endif
    #Call ECR_TRACE([F:AGB]CODVAR,0) From GESECRAN
   Endif
  Endif
 Next
Commit
Close Local File [AGB] , [ADP] , [ATX1] , [ATX2] , [ADW]
End

###############################################################
# Mise à jour de la table ASUBPROG                            #
# Mise a jour champ DES dans champ INTIT de type ATX          #
# Mise a jour champ DESPAR dans champ INTITPAR de type ATX    #
###############################################################
Subprog SUBPRG(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","ASUBPROG","fde",DOSSIER),0)<0
 End
Endif

Local File =DOSSIER+".ASUBPROG"  [ASU]
Local File =DOSSIER+".ATEXTE"    [ATX]
Local Integer I

If dim([F:ASU]DESPAR)<=0 : End : Endif

# Mise à jour de la table ASUBPROG (Sous-programmes)
Call ECR_TRACE(mess(81,125,1)-"ASUBPROG ("+mess(207,124,1)+") :"-time$,0) From GESECRAN

Trbegin [ASU]
 For [ASU]ASU0
  For I=0 To [F:ASU]NBRPAR-1
   If [F:ASU]DESPAR(I) <> ""
    Call NUMERO ([F:ASU]DESPAR(I),[F:ASU]INTITPAR(I))
   Endif
  Next
  If [F:ASU]DES <> ""
   Call NUMERO ([F:ASU]DES,[F:ASU]INTIT)
  Endif
  Rewrite [ASU]
  If fstat : Call ERREUR("ASUBPROG",2) From DOSDIC : Endif
 Next ASU
Commit

Close Local File [ASU] , [ATX]
End

#################################################
Subprog NUMERO(VALEUR,NUM)
Value    Char    VALEUR
Variable Integer NUM
Local Integer ASTATUS
Local Char MESSAGE(250)
Local    Integer PREM , DERN
If VALEUR="" : NUM = 0 : End : Endif
Read [ATX]TEXTE = GLANGUE;VALEUR
If fstat=0
 NUM = [F:ATX]NUMERO
Else
 Lock [ATX]
 If fstat
  NUM = 0 : End
 Endif
 If dim([V]GADONIX)>0 & GADONIX<>2
  PREM = GMAXTXTSTD : DERN = GMAXTXTSPE
 Else
  PREM = 0 : DERN = GMAXTXTSTD
 Endif
 #115210/6
 If DERN = GMAXTXTSTD & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
  Gosub INIT_LANGS
  ASTATUS = func ATXTSVC.CREATE_TEXT_CHAR(GPRODUIT,GLANGUE,LANGS,VALEUR, "",NUM,MESSAGE)
  If ASTATUS<>[V]CST_AOK
   Call ECR_TRACE(MESSAGE,1) From GESECRAN
   NUM = 0 : End
  Endif
 Else
  Filter [ATX] Where NUMERO>PREM & NUMERO<DERN Order By Key CLE=NUMERO;LAN
  Read [ATX] Last
  Filter [ATX]
  If fstat : NUM = PREM+1 : Else : NUM = [F:ATX]NUMERO+1 : Endif
 Endif
 Raz [F:ATX]
 [F:ATX]NUMERO = NUM
 [F:ATX]TEXTE  = VALEUR
 [F:ATX]LONG   = 30
 [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
 [F:ATX]LAN = GLANGUE
 If dim([F:ATX]LANORI)>0 & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
  ASTATUS = func ATXTSVC.GET_LANORI(GPRODUIT, NUM, GLANGUE,[F:ATX]LANORI,MESSAGE)
 Endif
 If dim([F:ATX]UPDDAT)>0 : [F:ATX]UPDDAT = date$ : Endif
 Write [ATX]
 If fstat
  Call ERREUR("ATEXTE",1) From DOSDIC
  NUM = 0 : End
 Endif
Endif
End

$INIT_LANGS
Local Char LANGS(3)(0..)
Local Integer NBLANGS
Local File ADOSSIER [ADS]
Local Integer AI
If func DOSSUB.FILL_ADS(nomap)
 For AI=0 To [F:ADS]NBRLAN-1
  LANGS(AI) = [F:ADS]LAN(AI)
  NBLANGS+=1
 Next AI
Endif
Return

