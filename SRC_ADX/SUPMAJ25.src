#########################################################################################
# Mise à jour forcée de l'onglet sélection des objets.
#########################################################################################
Subprog AOBJLST(DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF

Local Char WOBJET(GLONAOB)
Local Integer I
Local File =DOSSIER+".AOBJLST" [AOL] , =DOSREF+".AOBJLST" [AOL2]

Call ECR_TRACE(mess(81,125,1)-": AOBJLST"-time$,0) From GESECRAN : # maj table

Trbegin [AOL]

 For WOBJET = "AOE","ANM","GTC","PS1","PS2","ALH","ALQ","TCY","TCO","TLA","ADP","AD2","AD3"
&            ,"APS","AP2","AWM","APV","ACV","TCU","AEN","AH2"
  Read [AOL]AOL0 = WOBJET
  If !fstat
   Read [AOL2]AOL0 = WOBJET
   If !fstat
    [F:AOL] = [F:AOL2]
    Rewrite [AOL]
    If fstat
     Call ERREUR("AOBJLST"-WOBJET,2) From DOSDIC
    Endif
   Endif
  Endif
 Next WOBJET

Commit
Close Local File [AOL] , [AOL2]
End

