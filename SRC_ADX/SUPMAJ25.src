##############################################################
# Mise a jour champ DES dans champ INTIT de type AXX         #
# Mise a jour champ VARDES dans champ VARINTIT de type AXX   #
##############################################################
Subprog DESPS1(DOSSIER)
Value Char DOSSIER

Local Integer I

Local File =DOSSIER+".PARSTA1"     [PS1]
Local File =DOSSIER+".ATEXTRA"     [AXX]

If dim([F:PS1]DES)<=0 : End : Endif

# Mise à jour de la table PARSTA1 : Déclencheur statistique
Call ECR_TRACE(mess(81,125,1)-"PARSTA1("+mess(62,126,1)+") :"-time$,0) From GESECRAN

Trbegin [AXX]
 For [PS1]PS10
  If [F:PS1]DES <> ""
   Call MAJTEXTRA([F:PS1]DES,"PARSTA1","INTIT",[F:PS1]COD,"")
  Endif
  If [F:PS1]DESSHO <> ""
   Call MAJTEXTRA([F:PS1]DESSHO,"PARSTA1","INTSHO",[F:PS1]COD,"")
  Endif
  For I=0 To [F:PS1]NBRVAR-1
   If [F:PS1]VARDES <> ""
    Call MAJTEXTRA([F:PS1]VARDES(I),"PARSTA1","VARINTIT",[F:PS1]COD,num$(I+1))
   Endif
  Next I
 Next
Commit

Close Local File [PS1],[AXX]
End

##############################################################
# Mise a jour champ DES dans champ INTIT de type AXX         #
# Mise a jour champ FLDDES dans champ FLDINTIT de type AXX   #
##############################################################
Subprog DESPS2(DOSSIER)
Value Char DOSSIER

Local Integer I

Local File =DOSSIER+".PARSTA2"     [PS2]
Local File =DOSSIER+".ATEXTRA"     [AXX]

If dim([F:PS2]DES)<=0 : End : Endif

# Mise à jour de la table PARSTA2 : Codes stats
Call ECR_TRACE(mess(81,125,1)-"PARSTA2("+mess(29,106,1)+") :"-time$,0) From GESECRAN

Trbegin [AXX]
 For [PS2]PS20
  If [F:PS2]DES <> ""
   Call MAJTEXTRA([F:PS2]DES,"PARSTA2","INTIT",[F:PS2]COD,"")
  Endif
  If [F:PS2]DESSHO <> ""
   Call MAJTEXTRA([F:PS2]DESSHO,"PARSTA2","INTSHO",[F:PS2]COD,"")
  Endif
  For I=0 To [F:PS2]NBRFLD-1
   If [F:PS2]FLDDES <> ""
    Call MAJTEXTRA([F:PS2]FLDDES(I),"PARSTA2","FLDINTIT",[F:PS2]COD,num$(I+1))
   Endif
  Next I
  For I=0 To dim([F:PS2]LIBFRM)-1
   If [F:PS2]LIBFRM(I) <> ""
    Call MAJTEXTRA([F:PS2]LIBFRM(I),"PARSTA2","INTITFRM",[F:PS2]COD,num$(I+1))
   Endif
  Next I
 Next
Commit

Close Local File [PS2],[AXX]
End

############################################################
# Rajout des formats NID et EECNUM + Textes traduisibles
############################################################
Subprog TABCOUNTRY(DOSSIER,DOSREF)
Value Char DOSSIER,DOSREF

Local File =DOSSIER+".TABCOUNTRY" [TCY] , =DOSSIER+".ACTIV" [ACV]
&        , =DOSSIER+".ATEXTRA" [AXX] , =DOSSIER+".ATEXTE" [ATX]
&        , =DOSREF+".TABCOUNTRY" [TCY2]

If dim([F:TCY]CRYNAM)<=0 : End : Endif

# Mise à jour de la table TABCOUNTRY
Call ECR_TRACE(mess(81,125,1)-"TABCOUNTRY :"-time$,0) From GESECRAN

Trbegin [TCY]
 For [TCY]
  If [F:TCY]CRNFMTFLG<1
   If [F:TCY]CRNFMT<>""
    [F:TCY]CRNFMTFLG = 2
   Else
    [F:TCY]CRNFMTFLG = 1
   Endif
  Endif
  If [F:TCY]CRTFMTFLG<1
   If [F:TCY]CRNFMT<>""
    [F:TCY]CRTFMTFLG = 2
   Else
    [F:TCY]CRTFMTFLG = 2
   Endif
  Endif
  If [F:TCY]CRNFMT<>""
   If [F:TCY]CRTFMT=""
    [F:TCY]CRTFMT = [F:TCY]CRNFMT
   Endif
  Endif
  If [F:TCY]EECFMTFLG<1
   If [F:TCY]EECFLG=2
    [F:TCY]EECFMTFLG = 2
   Else
    [F:TCY]EECFMTFLG = 1
   Endif
  Endif
  If [F:TCY]NIDFMTFLG<1
   If [F:TCY]EECFLG=2
    [F:TCY]NIDFMTFLG = 2
   Else
    [F:TCY]NIDFMTFLG = 1
   Endif
  Endif
  If [F:TCY]EECFMT=""
   [F:TCY]EECFMT = "20X"
  Endif
  If [F:TCY]NIDFMT=""
   [F:TCY]NIDFMT = "80X"
  Endif
  If [F:TCY]NAFFMTFLG<1
   Read [F:TCY2]TCY0=[F:TCY]CRY
   If !fstat
    [F:TCY]NAFFMTFLG = [F:TCY2]NAFFMTFLG
   Else
    [F:TCY]NAFFMTFLG = 1
   Endif
  Endif
  If [F:TCY]NAFFMT=""
   [F:TCY]NAFFMT = "10X"
  Endif
  Call MAJTEXTRA([F:TCY]CRYNAM,"TABCOUNTRY","CRYDES",[F:TCY]CRY,"")
  If [F:TCY]ETAT=2 or [F:TCY]CRY="US"
   [F:TCY]ETAT = 2
   [F:TCY]ETATFLG = 2
   Read [ATX]TEXTE="FRA";"Etat (province)"
   If !fstat
    K = [F:ATX]NUMERO
    Read [ATX]NUMERO=GLANGUE;K
    If !fstat
     Call MAJTEXTRA([F:ATX]TEXTE,"TABCOUNTRY","ETATNAM",[F:TCY]CRY,"")
    Endif
   Endif
   [F:TCY]ETATFLG2 = 1
  Elsif [F:TCY]ETAT<=1
   [F:TCY]ETAT = 1
   [F:TCY]ETATFLG = 1
   [F:TCY]ETATFLG2 = 1
  Endif
  Rewrite [TCY]
  If fstat : Call ERREUR("TABCOUNTRY",2) From DOSDIC : Endif
 Next
Commit
Close Local File [TCY] , [ACV] , [AXX] , [ATX] , [TCY2]
End

