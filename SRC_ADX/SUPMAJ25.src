###############################################
# Reprise des docs actions et sous-programmes
###############################################
Subprog MAJDOCSUP(DOSSIER)
Value Char DOSSIER

Local Integer NUMERO , K , I , SPEC

Local File =DOSSIER+".ADOCCLB"  [ADH]  , =DOSSIER+".ACTION"    [ACT]
&        , =DOSSIER+".ADOCUMENT" [ADO] , =DOSSIER+".APLSTD"    [AST2]
Local File =DOSSIER+".ATEXTE"   [ATX] Order By Key DERNUM=NUMERO;LAN
Local File =DOSSIER+".ATEXTE"   [AT2] Order By Key DERNUM=NUMERO;LAN

If filinfo(filpath("FIL","ASUBPROG","fde",DOSSIER),0)>0
 Local File =DOSSIER+".ASUBPROG" [ASU]
Endif

Local Char    TEX(100)(1..max(1,dim([F:ACT]INFO)))

# Mise à jour de la table ADOCCLB
Call ECR_TRACE(mess(81,125,1)-"ADOCCLB :"-time$,0) From GESECRAN

Trbegin [ADH] , [ADO]
 For [ACT]
  If dim([F:ACT]INFO)>0 & sum([F:ACT]INFO)>0
   Call SPEC([F:ACT]CODACT,SPEC) From DOSSUB
   If SPEC
    [L]NUMERO = 0
    For I=0 To dim([F:ACT]INFO)-1
     If [F:ACT]INFO(I)<>0
      [L]NUMERO = [F:ACT]INFO(I)
      Break
     Endif
    Next I
    For [ATX]DERNUM Where [F]NUMERO=[L]NUMERO
     K = 0
     If clalev([F:ADS])>0
      If [F:ADS]NBRLAN<=0
       K = 1
      Elsif  find([F:ATX]LAN,[F:ADS]LAN(0..[F:ADS]NBRLAN-1))
       K = 1
      Endif
     Else
      K = 1
     Endif
     If K
      For [ADO] Where LAN=[F:ATX]LAN & TYP="ACT" & COD=[F:ACT]ACTION & PAR="PRE"
       K = 0
      Next ADO
     Endif
     If K
      Raz [L]TEX
      For I=0 To dim([F:ACT]INFO)-1
       If [F:ACT]INFO(I)<>0
        Read [AT2]DERNUM=[F:ACT]INFO(I);[F:ATX]LAN
        If !fstat : [L]TEX(I+1) = [F:AT2]TEXTE+" " : Endif
       Endif
      Next I
      Raz [F:ADO]
      For I=1 To 4
       [F:ADO]LAN    = [F:ATX]LAN
       [F:ADO]TYP    = "ACT"
       [F:ADO]COD    = [F:ACT]ACTION
       Case I
        When 1
         [F:ADO]LEV    = 10
         [F:ADO]SUBLEV = 10
         [F:ADO]PAR    = "TIT"
         Read [AT2]DERNUM=[F:ACT]INTITA;[F:ATX]LAN
         [F:ADO]TIT    = [F:AT2]TEXTE
        When 2
         [F:ADO]LEV    = 10
         [F:ADO]SUBLEV = 20
         [F:ADO]PAR    = "PRE"
         Read [AST2]CLE=142;2;[F:ATX]LAN
         [F:ADO]TIT    = [F:AST2]LANMES : # Présentation
        When 3
         [F:ADO]LEV    = 30
         [F:ADO]SUBLEV = 10
         [F:ADO]PAR    = "PAR"
         Read [AST2]CLE=142;188;[F:ATX]LAN
         [F:ADO]TIT    = [F:AST2]LANMES : # Paramètres de l'action
        When 4
         [F:ADO]LEV    = 40
         [F:ADO]SUBLEV = 10
         [F:ADO]PAR    = "UTI"
         Read [AST2]CLE=142;200;[F:ATX]LAN
         [F:ADO]TIT    = [F:AST2]LANMES : # Utilisation
       Endcase
       [F:ADO]CODACT = [F:ACT]CODACT
       [F:ADO]MODULE = [F:ACT]MODULE
       [F:ADO]CREDAT = date$
       [F:ADO]CREUSR = GUSER
       If dim([F:ADO]CRETIM)>0 : [F:ADO]CRETIM = time : Endif
       Write [ADO]
       If fstat>0 & fstat<>3 : Call ERREUR("ADOCUMENT",1) From DOSDIC : Endif
      Next I
      Raz [F:ADH]
      [F:ADH] = [F:ADO]
      [F:ADH]LEV    = 10
      [F:ADH]SUBLEV = 20
      Setlob [F:ADH]TEXTE With [L]TEX
      [F:ADH]CREDAT = date$
      [F:ADH]CREUSR = GUSER
      If dim([F:ADH]CRETIM)>0 : [F:ADH]CRETIM = time : Endif
      Write [ADH]
      If fstat : Call ERREUR("ADOCCLB",1) From DOSDIC : Endif
     Endif
    Next ATX
   Endif
  Endif
 Next ACT
 If filinfo(filpath("FIL","ASUBPROG","fde",DOSSIER),0)>0 : # Table système : on garde car on ne sait jamais
  For [ASU]
   If dim([F:ASU]TEX)>0
    Setlob [L]TEX With [F:ASU]TEX
    If [L]TEX<>""
     K = 0
     For [ADO] Where LAN=GLANGUE & TYP="ASU" & COD=[F:ASU]PRG+"_"+[F:ASU]SUBPRG & PAR="PRE"
      K = 1
     Next ADO
     If !K
      Raz [F:ADO]
      [F:ADO]LAN    = GLANGUE
      [F:ADO]TYP    = "ASU"
      [F:ADO]COD    = [F:ASU]PRG+"_"+[F:ASU]SUBPRG
      [F:ADO]LEV    = 10
      [F:ADO]SUBLEV = 20
      [F:ADO]PAR    = "PRE"
      [F:ADO]TIT    = mess(2,142,1) : # Présentation
      [F:ADO]CODACT = [F:ASU]CODACT
      [F:ADO]MODULE = [F:ASU]MODULE
      [F:ADO]CREDAT = date$
      [F:ADO]CREUSR = GUSER
      If dim([F:ADO]CRETIM)>0 : [F:ADO]CRETIM = time : Endif
      Write [ADO]
      If fstat : Call ERREUR("ADOCUMENT",1) From DOSDIC : Endif
      Raz [F:ADH]
      [F:ADH] = [F:ADO]
      [F:ADH]TEXTE = [F:ASU]TEX
      [F:ADH]CREDAT = date$
      [F:ADH]CREUSR = GUSER
      If dim([F:ADH]CRETIM)>0 : [F:ADH]CRETIM = time : Endif
      Write [ADH]
      If fstat : Call ERREUR("ADOCCLB",1) From DOSDIC : Endif
     Endif
    Endif
   Endif
  Next ASU
 Endif
Commit

Close Local File [ADH],[ACT],[ADO],[ATX],[AT2]
If clalev([F:ASU])>0 : Close Local File [ASU] : Endif

End

###############################################
# Maj du flag "Public"
###############################################
Subprog MAJPUBFLG(DOSSIER)
Value Char DOSSIER

Local Integer K
Local Char    DOSX3(GLONADS)

Local File =DOSSIER+".ADOCCLB"  [ADH] , =DOSSIER+".ACTION"    [ACT]
&        , =DOSSIER+".AGLOBVAR" [AGB] , =DOSSIER+".ADOCUMENT" [ADO]
&        , =DOSSIER+".ADOVAL"   [ADW]

Read [ADW]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>"" & [F:ADW]VALEUR<>DOSSIER
 DOSX3 = [F:ADW]VALEUR
 If DOSX3<>"" & filinfo(filpath("FIL","ADOCCLB","fde",DOSX3),0)>0
  Local File =DOSX3+".ADOCCLB" [ADHX]
 Endif
Endif

# Mise à jour de la table ACTION
Call ECR_TRACE(mess(81,125,1)-"ACTION :"-time$,0) From GESECRAN

Trbegin [ACT]
 For [ACT]
  K = 1
  For [ADO] Where LAN=GLANGUE & TYP="ACT" & COD=[F:ACT]ACTION & PAR="PRE"
   Read [ADH]ADH0=GLANGUE;"ACT";[F:ACT]ACTION;[F:ADO]LEV;[F:ADO]SUBLEV
   If !fstat
    If !find([F:ADH]TEXTE,"","<P/>") : K = 2 : Endif
   Elsif clalev([F:ADHX])>0
    Read [ADHX]ADH0=GLANGUE;"ACT";[F:ACT]ACTION;[F:ADO]LEV;[F:ADO]SUBLEV
    If !fstat & !find([F:ADHX]TEXTE,"","<P/>") : K = 2 : Endif
   Endif
   Break
  Next ADO
  [F:ACT]PUBFLG = K
  Rewrite [ACT]
  If fstat : Call ERREUR("ACTION",2) From DOSDIC : Endif
 Next ACT
Commit
Trbegin [AGB]
 For [AGB]
  K = 1
  For [ADO] Where LAN=GLANGUE & TYP="AGB" & COD=[F:AGB]CODVAR & PAR="PRE"
   Read [ADH]ADH0=GLANGUE;"AGB";[F:AGB]CODVAR;[F:ADO]LEV;[F:ADO]SUBLEV
   If !fstat
    If !find([F:ADH]TEXTE,"","<P/>") : K = 2 : Endif
   Elsif clalev([F:ADHX])>0
    Read [ADHX]ADH0=GLANGUE;"AGB";[F:AGB]CODVAR;[F:ADO]LEV;[F:ADO]SUBLEV
    If !fstat & !find([F:ADHX]TEXTE,"","<P/>") : K = 2 : Endif
   Endif
   Break
  Next ADO
  [F:AGB]PUBFLG = K
  Rewrite [AGB]
  If fstat : Call ERREUR("AGLOBVAR",2) From DOSDIC : Endif
 Next AGB
Commit

Close Local File [ADH] , [ACT] , [AGB] , [ADO] , [ADW]
If clalev([F:ADHX])>0
 Close Local File [ADHX]
Endif
End

#################################################################
# Concaténation paramètres suite à augmentation champ VALEUR
#################################################################
Subprog CONCATPAR(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".ADOVAL" [ADW] , =DOSSIER+".ADOVAL" [ADW2]
&        , =DOSSIER+".ADOVALAUS" [ADU] , =DOSSIER+".ADOVALAUS" [ADU2]
&        , =DOSSIER+".ADOPAR" [ADP] , =DOSSIER+".AGLOBVAR" [AGB]

# Mise à jour de la table ADOVAL-ADOVALAUS
Call ECR_TRACE(mess(81,125,1)-"ADOVAL-ADOVALAUS :"-time$,0) From GESECRAN

Local Char VAR1(30) , CHAINE(250)
Trbegin [ADW] , [ADU]
 For VAR1="HOMEPAGE1","WRKRMTDIR1","DIRPCE1","REPDOC"
  Case VAR1
   When "HOMEPAGE1"
    For [ADW] Where PARAM="HOMEPAGE1"
     CHAINE = [F:ADW]VALEUR
     Read [ADW2]ADW0=[F:ADW]CMP;[F:ADW]FCY;"HOMEPAGE2"
     If !fstat
      CHAINE += [F:ADW2]VALEUR
      Read [ADW2]ADW0=[F:ADW]CMP;[F:ADW]FCY;"HOMEPAGE3"
      If !fstat
       CHAINE += [F:ADW2]VALEUR
      Endif
     Endif
     Read [ADW2]ADW0=[F:ADW]CMP;[F:ADW]FCY;"HOMEPAGE"
     If !fstat
      [F:ADW2]VALEUR = CHAINE
      Rewrite [ADW2]
      If fstat
       Call ERREUR("ADOVAL"-[F:ADW]CMP-[F:ADW]FCY-"HOMEPAGE",2) From DOSDIC
      Endif
     Else
      [F:ADW2] = [F:ADW]
      [F:ADW2]PARAM = "HOMEPAGE"
      [F:ADW2]VALEUR = CHAINE
      Write [ADW2]
      If fstat
       Call ERREUR("ADOVAL"-[F:ADW]CMP-[F:ADW]FCY-"HOMEPAGE",1) From DOSDIC
      Endif
     Endif
    Next ADW
    Delete [ADW] Where PARAM="HOMEPAGE1"
    Delete [ADW] Where PARAM="HOMEPAGE2"
    Delete [ADW] Where PARAM="HOMEPAGE3"
    For [ADU]ADU0 Where PARAM="HOMEPAGE1"
     CHAINE = [F:ADU]VALEUR
     Read [ADU2]ADU0=[F:ADU]CODUSR;"HOMEPAGE2"
     If !fstat
      CHAINE += [F:ADU2]VALEUR
      Read [ADU2]ADU0=[F:ADU]CODUSR;"HOMEPAGE3"
      If !fstat
       CHAINE += [F:ADU2]VALEUR
      Endif
     Endif
     [F:ADU2] = [F:ADU]
     [F:ADU2]PARAM = "HOMEPAGE"
     [F:ADU2]VALEUR = CHAINE
     Write [ADU2]
     If fstat
      Call ERREUR("ADOVALAUS"-[F:ADU]CODUSR-"HOMEPAGE",1) From DOSDIC
     Endif
    Next ADU
    Delete [ADU] Where PARAM="HOMEPAGE1"
    Delete [ADU] Where PARAM="HOMEPAGE2"
    Delete [ADU] Where PARAM="HOMEPAGE3"
    Delete [ADP] Where PARAM="HOMEPAGE1"
    Delete [ADP] Where PARAM="HOMEPAGE2"
    Delete [ADP] Where PARAM="HOMEPAGE3"
   When "WRKRMTDIR1"
    For [ADW] Where PARAM="WRKRMTDIR1"
     CHAINE = [F:ADW]VALEUR
     Read [ADW2]ADW0=[F:ADW]CMP;[F:ADW]FCY;"WRKRMTDIR2"
     If !fstat
      CHAINE += [F:ADW2]VALEUR
     Endif
     Read [ADW2]ADW0=[F:ADW]CMP;[F:ADW]FCY;"WRKRMTDIR"
     If !fstat
      [F:ADW2]VALEUR = CHAINE
      Rewrite [ADW2]
      If fstat
       Call ERREUR("ADOVAL"-[F:ADW]CMP-[F:ADW]FCY-"WRKRMTDIR",2) From DOSDIC
      Endif
     Else
      [F:ADW2] = [F:ADW]
      [F:ADW2]PARAM = "WRKRMTDIR"
      [F:ADW2]VALEUR = CHAINE
      Write [ADW2]
      If fstat
       Call ERREUR("ADOVAL"-[F:ADW]CMP-[F:ADW]FCY-"WRKRMTDIR",1) From DOSDIC
      Endif
     Endif
    Next ADW
    Delete [ADW] Where PARAM="WRKRMTDIR1"
    Delete [ADW] Where PARAM="WRKRMTDIR2"
    For [ADU]ADU0 Where PARAM="WRKRMTDIR1"
     CHAINE = [F:ADU]VALEUR
     Read [ADU2]ADU0=[F:ADU]CODUSR;"WRKRMTDIR2"
     If !fstat
      CHAINE += [F:ADU2]VALEUR
     Endif
     [F:ADU2] = [F:ADU]
     [F:ADU2]PARAM = "WRKRMTDIR"
     [F:ADU2]VALEUR = CHAINE
     Write [ADU2]
     If fstat
      Call ERREUR("ADOVALAUS"-[F:ADU]CODUSR-"WRKRMTDIR",1) From DOSDIC
     Endif
    Next ADU
    Delete [ADU] Where PARAM="WRKRMTDIR1"
    Delete [ADU] Where PARAM="WRKRMTDIR2"
    Delete [ADP] Where PARAM="WRKRMTDIR1"
    Delete [ADP] Where PARAM="WRKRMTDIR2"
    Delete [AGB] Where CODVAR="GWRKRMTDI1"
    Delete [AGB] Where CODVAR="GWRKRMTDI2"
   When "DIRPCE1"
    For [ADW] Where PARAM="DIRPCE1"
     CHAINE = [F:ADW]VALEUR
     Read [ADW2]ADW0=[F:ADW]CMP;[F:ADW]FCY;"DIRPCE2"
     If !fstat
      CHAINE += [F:ADW2]VALEUR
     Endif
     Read [ADW2]ADW0=[F:ADW]CMP;[F:ADW]FCY;"DIRPCE"
     If !fstat
      [F:ADW2]VALEUR = CHAINE
      Rewrite [ADW2]
      If fstat
       Call ERREUR("ADOVAL"-[F:ADW]CMP-[F:ADW]FCY-"DIRPCE",2) From DOSDIC
      Endif
     Else
      [F:ADW2] = [F:ADW]
      [F:ADW2]PARAM = "DIRPCE"
      [F:ADW2]VALEUR = CHAINE
      Write [ADW2]
      If fstat
       Call ERREUR("ADOVAL"-[F:ADW]CMP-[F:ADW]FCY-"DIRPCE",1) From DOSDIC
      Endif
     Endif
    Next ADW
    Delete [ADW] Where PARAM="DIRPCE1"
    Delete [ADW] Where PARAM="DIRPCE2"
    For [ADU]ADU0 Where PARAM="DIRPCE1"
     CHAINE = [F:ADU]VALEUR
     Read [ADU2]ADU0=[F:ADU]CODUSR;"DIRPCE2"
     If !fstat
      CHAINE += [F:ADU2]VALEUR
     Endif
     [F:ADU2] = [F:ADU]
     [F:ADU2]PARAM = "DIRPCE"
     [F:ADU2]VALEUR = CHAINE
     Write [ADU2]
     If fstat
      Call ERREUR("ADOVALAUS"-[F:ADU]CODUSR-"DIRPCE",1) From DOSDIC
     Endif
    Next ADU
    Delete [ADU] Where PARAM="DIRPCE1"
    Delete [ADU] Where PARAM="DIRPCE2"
    Delete [ADP] Where PARAM="DIRPCE1"
    Delete [ADP] Where PARAM="DIRPCE2"
   When "REPDOC"
    For [ADW] Where PARAM="REPDOC"
     CHAINE = [F:ADW]VALEUR
     Read [ADW2]ADW0=[F:ADW]CMP;[F:ADW]FCY;"REPDOC1"
     If !fstat
      CHAINE += [F:ADW2]VALEUR
     Endif
     Read [ADW2]ADW0=[F:ADW]CMP;[F:ADW]FCY;"DIRDOC"
     If !fstat
      [F:ADW2]VALEUR = CHAINE
      Rewrite [ADW2]
      If fstat
       Call ERREUR("ADOVAL"-[F:ADW]CMP-[F:ADW]FCY-"DIRDOC",2) From DOSDIC
      Endif
     Else
      [F:ADW2] = [F:ADW]
      [F:ADW2]PARAM = "DIRDOC"
      [F:ADW2]VALEUR = CHAINE
      Write [ADW2]
      If fstat
       Call ERREUR("ADOVAL"-[F:ADW]CMP-[F:ADW]FCY-"DIRDOC",1) From DOSDIC
      Endif
     Endif
    Next ADW
    Delete [ADW] Where PARAM="REPDOC"
    Delete [ADW] Where PARAM="REPDOC1"
    For [ADU]ADU0 Where PARAM="REPDOC"
     CHAINE = [F:ADU]VALEUR
     Read [ADU2]ADU0=[F:ADU]CODUSR;"REPDOC1"
     If !fstat
      CHAINE += [F:ADU2]VALEUR
     Endif
     [F:ADU2] = [F:ADU]
     [F:ADU2]PARAM = "DIRDOC"
     [F:ADU2]VALEUR = CHAINE
     Write [ADU2]
     If fstat
      Call ERREUR("ADOVALAUS"-[F:ADU]CODUSR-"DIRDOC",1) From DOSDIC
     Endif
    Next ADU
    Delete [ADU] Where PARAM="REPDOC"
    Delete [ADU] Where PARAM="REPDOC1"
    Delete [ADP] Where PARAM="REPDOC"
    Delete [ADP] Where PARAM="REPDOC1"
    Delete [AGB] Where CODVAR="GREPDOC"
    Delete [AGB] Where CODVAR="GREPDOC1"
  Endcase
 Next VAR1
Commit
Close Local File [ADW] , [ADW2] , [ADU] , [ADU2] , [ADP] , [AGB]
End

#################################################################
# Mise à jour des champs RANG et MENU de la table AFONCTION
#################################################################
Subprog AFONCTION(DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF
Local Integer OK

Local File =DOSSIER+".AFONCTION" [AFC] , =DOSREF+".AFONCTION" [AF2]
&        , =DOSSIER+".AFONCTION" [AF3]

# Mise à jour de la table AFONCTION
Call ECR_TRACE(mess(81,125,1)-"AFONCTION :"-time$,0) From GESECRAN

Trbegin [AFC]
 For [AFC]
  OK =  (find([F:AFC]CODINT,"LECTRACE","MPERS","GESASL","CODCTL","CODACC","APRSMSK")<>0)
  OK += (find([F:AFC]CODINT,"PSADX","ADXD","GESADG")<>0)
  If OK
   Read [AF2]CODINT=[F:AFC]CODINT
   If !fstat
    Look [F:AF3]CODINT=[F:AF2]MENU
    If !fstat
     [F:AFC]MENU = [F:AF2]MENU
     [F:AFC]RANG = [F:AF2]RANG
     Rewrite [AFC]
     If fstat
      Call ERREUR("AFONCTION"-[F:AFC]CODINT,2) From DOSDIC
     Endif
    Endif
   Endif
  Endif
 Next AFC
Commit
Close Local File [AFC] , [AF2] , [AF3]
End

Subprog MAJTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
Value    Char    VALEUR, TABLE, CHAMP, CLE1, CLE2
Local Char OLANGUE(GLONLAN)
OLANGUE = GLANGUE
If clalev([F:ADS])>0
 GLANGUE = [F:ADS]LANDEF
Else
 GLANGUE = "FRA"
Endif
Call MAJTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2) From ATEXTRA
GLANGUE = OLANGUE
End

#########################################################
# Suppression des paramètres X3LAN, X3FCT, X3PRF, X3SIT
#########################################################
Subprog AREPORTD(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AREPORTD" [ARD]

# Mise à jour de la table
Call ECR_TRACE(mess(81,125,1)-"AREPORTD :"-time$,0) From GESECRAN

Trbegin [ARD]
 For [ARD]ARD0
  If find([F:ARD]PARCOD,"X3LAN","X3FCT","X3PRF","X3SIT")
   Delete [ARD] Curr
  Endif
 Next
Commit

Close Local File [ARD]
End

######################################################################
Subprog SUPP_APTLPAR(DOSSIER)
Value Char DOSSIER

If DOSSIER = GDOSX3 : End : Endif

Local Char    MACHINE(50) , APPLI(50) , MESSAGE(250)(1..5) , FICTRA(GDIMFIC)
Local Char    TABLE(30) , ORDSYS(250)(1..2)
Local Integer STAT

TABLE = "APTLPAR"

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If filinfo(filpath("FIL",TABLE,"fde",APPLI),0)<=0 : End : Endif

FICTRA = filpath("tmp",TABLE,"tra",APPLI)
Call EFFACE(FICTRA ,STAT) From ORDSYS
ORDSYS(1) = "valfil -d"-APPLI-TABLE
ORDSYS(2)  = FICTRA
Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
adxifs = ""
adxirs = chr$(10)
Openi FICTRA Using [TR_]
Raz MESSAGE
Rdseq MESSAGE(1) Using [TR_]
Rdseq MESSAGE(2) Using [TR_]
Rdseq MESSAGE(3) Using [TR_]
Openi Using [TR_]
If MESSAGE(1)<>""
 Call ECR_TRACE("Error"-APPLI-TABLE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
Else
 Call EFFACE(filpath("FIL",TABLE,"fde",APPLI),STAT) From ORDSYS
 Call EFFACE(filpath("FIL",TABLE,"srf",APPLI),STAT) From ORDSYS
 Call EFFACE(filpath("FIL",TABLE,"viw",APPLI),STAT) From ORDSYS
 Call EFFACE(FICTRA,STAT) From ORDSYS
 Call ECR_TRACE(APPLI-TABLE-": File deleted",0) From GESECRAN
Endif
End

######################################################################
Subprog MAJGRP(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".COMPANY"  [CPY]
Local File =DOSSIER+".FACILITY" [FCY]
Local File =DOSSIER+".AGRPFCY"  [AGF]
Local File =DOSSIER+".AGRPCPY"  [AGC]
Local File =DOSSIER+".FACGROUP" [FGR]

# Mise à jour de la table
Call ECR_TRACE(mess(81,125,1)-"AGRPFCY :"-time$,0) From GESECRAN
Call ECR_TRACE(mess(81,125,1)-"AGRPCPY :"-time$,0) From GESECRAN

Trbegin [AGF]
 Gosub TR_GRP
Commit
End

$TR_GRP
For [CPY]CPY0
 Read [AGF]AGF0 = [F:CPY]CPY
 If fstat
  Raz [F:AGF]
  [F:AGF]GRP    = [F:CPY]CPY
  [F:AGF]DES    = [F:CPY]CPYNAM
  [F:AGF]SHO    = [F:CPY]CPYSHO
  [F:AGF]FLGLEG = [F:CPY]CPYLEGFLG
  If [F:AGF]FLGLEG=2
   [F:AGF]FLGCPY = 2
  Else
   [F:AGF]FLGCPY = 1
  Endif
  [F:AGF]CREDAT = date$
  If dim([F:AGF]CRETIM)>0 : [F:AGF]CRETIM = time : Endif
  [F:AGF]CREUSR = GUSER
  Write [AGF]
  If fstat
   Call ERREUR("AGRPFCY"-[F:AGF]GRP,1) From DOSDIC
  Endif
 Endif
 If [F:CPY]CPYLEGFLG=2
  Read [AGC]AGC0 = [F:CPY]CPY;[F:CPY]CPY
  If fstat
   [F:AGC]GRP = [F:CPY]CPY
   [F:AGC]CPY = [F:CPY]CPY
   Write [AGC]
   If fstat
    Call ERREUR("AGRPCPY"-[F:AGC]GRP,1) From DOSDIC
   Endif
  Endif
 Endif
Next
Return

###############################################
# Maj champ IMPNOW dans les code impressions
###############################################
Subprog IMPNOW(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AREPORTX" [ARX]

If dim([F:ARX]IMPNOW)<=0 : End : Endif

# Mise à jour de la table AREPORTX (code impression)
Call ECR_TRACE(mess(81,125,1)-"AREPORTX:"-time$,0) From GESECRAN

Trbegin [ARX]
 For [ARX]ARX0
  [F:ARX]IMPNOW = 1
  Rewrite [ARX]
  If fstat : Call ERREUR("AREPORTX",2) From DOSDIC : Endif
 Next
Commit

Close Local File [ARX]
End

##############################################
# Copie d'un style
##############################################
Subprog COPASY(DOSREF,DOSVAL,CODE)
Value Char DOSREF,DOSVAL,CODE

Local File =DOSVAL+".ASTYLE" [ASY] , =DOSREF+".ASTYLE" [ASYR]

Local Integer MAXLIG

# Mise à jour de la table AREPORTX (code impression)
Call ECR_TRACE(mess(81,125,1)-"ASTYLE :"-"("+CODE+")"-time$,0) From GESECRAN

Trbegin [ASY]
 Read [ASYR]ASY0=CODE
 If !fstat
  Read [ASY]ASY0=CODE
  If fstat
   MAXLIG = 0
   For [ASY]ASY0
    If [ASY]LIG > MAXLIG
     MAXLIG = [F:ASY]LIG
    Endif
   Next ASY
   MAXLIG +=1
   Raz [F:ASY]
   [F:ASY] = [F:ASYR]
   [F:ASY]LIG = MAXLIG
   [F:ASY]CREDAT = date$
   [F:ASY]CREUSR = GUSER
   If dim([F:ASY]CRETIM)>0 : [F:ASY]CRETIM = time  : Endif
   Write [ASY]
   If fstat : Call ERREUR("ASTYLE",1) From DOSDIC : Endif
  Else
   MAXLIG = [F:ASY]LIG
   Raz [F:ASY]
   [F:ASY] = [F:ASYR]
   [F:ASY]LIG = MAXLIG
   [F:ASY]UPDDAT = date$
   [F:ASY]UPDUSR = GUSER
   If dim([F:ASY]UPDTIM)>0 : [F:ASY]UPDTIM = time  : Endif
   Rewrite [ASY]
   If fstat : Call ERREUR("ASTYLE",2) From DOSDIC : Endif
  Endif
 Endif
Commit

Close Local File
End

###############################################
# Génération des vues dans le dossier histo
###############################################
Subprog GENVUE(DOSSIER)
Value Char DOSSIER

Local Char     HISTO(GLONADS)
Local Integer  I , COEFF , OK

Local File =DOSSIER+".ADOVAL" [AD__]
HISTO = ""
Read [AD__]ADW0 = "";"";"HISDOS"
If !fstat & [F:AD__]VALEUR<>""
 HISTO = [F:AD__]VALEUR
 If filinfo(filpath("","","",HISTO),0)<=0
  HISTO = ""
 Endif
Endif
Read [AD__]ADW0 = "";"";"HISCOE"
If !fstat
 COEFF = val([F:AD__]VALEUR)
Else
 COEFF = 1
Endif
Close Local File [AD__]
If HISTO="" : End : Endif

Call ECR_TRACE("Update view history folder :"-time$,0) From GESECRAN

Gosub SET_NOVIEW From CREHISTO
## Création des tables sur lesquelles on peut faire des transactions
## Table AOBJSEL pour ne pas avoir de mémos hérités, APLLCK pour ne pas planter sous sql-server, etc.

For I=1 To NBNOVIEW
 If filinfo(filpath("FIL",TABNOVIEW(I),"fde",DOSSIER),0)>0 & filinfo(filpath("FIL",TABNOVIEW(I),"fde",HISTO),0)<0
  Call CRETABLE(DOSSIER,HISTO,[F:ADS]TYPDBA,TABNOVIEW(I),COEFF,0) From CREHISTO
  Call ECR_TRACE(mess(41,125,1)-HISTO+"."+TABNOVIEW(I),0) From GESECRAN
 Endif
Next I

Local File =DOSSIER+".ATABLE" [ATB]
For [ATB]CODFIC Where !find(CODFIC,TABNOVIEW(1..NBNOVIEW)) & TYPFIC<>3
 If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",DOSSIER),0)>0 & filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",HISTO),0)<0
  Call CREVUE(DOSSIER,HISTO,[F:ADS]TYPDBA,[F:ATB]CODFIC,OK) From CREHISTO
  Call ECR_TRACE(mess(121,125,1)-HISTO+"."+[F:ATB]CODFIC,0) From GESECRAN : # Création de la vue
 Endif
Next ATB


Close Local File
End

################################################################
Subprog ADOSSIER(DOSSIER)
Value Char DOSSIER
Call ECR_TRACE("Update new field ADOSSIER"-time$,0) From GESECRAN
Trbegin [ADS]
 Read [ADS]DOSSIER=DOSSIER
 If dim([F:ADS]CREWIN)>0
  [F:ADS]CREWIN=2
 Endif
 If dim([F:ADS]CRECNS)>0
  [F:ADS]CRECNS=2
 Endif
 For I=0 To dim([F:ADS]TRVAL)-1
  If [F:ADS]TRVAL(I)=0
   [F:ADS]TRVAL(I) = 1
  Endif
 Next I
 Rewrite [ADS]
 If fstat
  Call ERREUR("ADOSSIER"-DOSSIER,2) From DOSDIC
 Endif
 Read [ADS]DOSSIER=DOSSIER
Commit
End

################################################################
Subprog ATABDIV(DOSSIER)
Value Char DOSSIER
Call ECR_TRACE("Delete duplicate key ATABDIV"-time$,0) From GESECRAN
Local File =DOSSIER+".ATABDIV" [ADI3] Order By Key CLE = NUMTAB;CODE
Local Char    COD(30)
Local Integer TAB
Raz COD , TAB
Trbegin [ADI3]
 For [ADI3]CLE
  If COD=[F:ADI3]CODE & TAB=[F:ADI3]NUMTAB
   Delete [ADI3] Curr
   Call ECR_TRACE(num$(TAB)-COD,0) From GESECRAN
  Endif
  COD = [F:ADI3]CODE
  TAB = [F:ADI3]NUMTAB
 Next ADI3
Commit
Close Local File
End

################################################################
Subprog VIRETAB(DOSSIER,TABLE)
Value Char DOSSIER,TABLE
Local File =DOSSIER+".ATABIND" [ATI]
Local File =DOSSIER+".ATABZON" [ATZ]
Local File =DOSSIER+".AMSKPAR" [AMP]
Local File =DOSSIER+".ATABLE"  [ATB]
Local File =DOSSIER+".AINDEX"  [ANX]

Look [ATB]CODFIC=TABLE
If !fstat
 Call ECR_TRACE("Delete file"-TABLE-time$,0) From GESECRAN
 If filinfo(filpath("FIL","ATABAUD","fde",DOSSIER),0)>0
  Local File =DOSSIER+".ATABAUD" [ATA]
 Endif
 Trbegin [ATI]
  Call SUPP_TRT("ZZINI"+TABLE) From DOSSUB
  Delete [ATI] Where CODFIC=TABLE
  If fstat=1 : Call ERREUR("ATABIND"-TABLE,3) From DOSDIC : Endif
  Delete [ATZ] Where CODFIC=TABLE
  If fstat=1 : Call ERREUR("ATABZON"-TABLE,3) From DOSDIC : Endif
  Delete [AMP] Where TYPAFF=2 & CODAFF=TABLE
  If fstat=1 : Call ERREUR("AMSKPAR"-TABLE,3) From DOSDIC : Endif
  Delete [ANX] Where [F]TABLE=[L]TABLE
  If fstat=1 : Call ERREUR("AINDEX"-TABLE,3) From DOSDIC : Endif
  If clalev([F:ATA])>0
   Delete [ATA] Where CODFIC=TABLE
   If fstat=1 : Call ERREUR("ATABAUD"-TABLE,3) From DOSDIC : Endif
  Endif
  Delete [ATB] Where CODFIC=TABLE
  If fstat=1 : Call ERREUR("ATABLE"-TABLE,3)  From DOSDIC : Endif
 Commit
Endif

Close Local File
End

################################################################
Subprog USRNOMME(DOSSIER)
Value Char DOSSIER
Local Integer NB
If !(dim(GUSRNOMME)>0 & GUSRNOMME>0) or filinfo(filpath("FIL","AUTILIS","fde",DOSSIER),0)<0
 End
Endif
If func ARECAUO.APPDEM(DOSSIER) or func ARECAUO.APPRAC(DOSSIER)
 End
Endif
Local File AUSRSOL [AUO]
If nbrecord([AUO])<GUSRNOMME
 Call ECR_TRACE("Update AUSRSOL",0) From GESECRAN
 Local File =DOSSIER+".AUTILIS" [AUS]
 Trbegin [AUO]
  For [AUS] Where ENAFLG=2 & USRCONNECT=2
   If NB<GUSRNOMME
    Read [AUO]AUO0 = [F:AUS]USR
    If fstat
     [F:AUO] = [F:AUS]
     Write [AUO]
     NB += 1
    Endif
   Else
    Break
   Endif
  Next AUS
 Commit
Endif
Close Local File
End

################################################################
# Ménage dans les tables liées à AOBJET
################################################################

Subprog AOBJTAB(DOSSIER)
Value Char DOSSIER
Local Integer TEST
TEST = 0
Local File =DOSSIER+".AOBJET"  [AOB], =DOSSIER+".AOBJTAB" [AOT], =DOSSIER+".AOBJLST" [AOL]
Trbegin [AOL]
 For [AOL]
  Look [AOB]ABREV=[F:AOL]ABREV
  If fstat
   If TEST
    Call ECR_TRACE("AOL"-[F:AOL]ABREV,1) From GESECRAN
   Else
    Delete [AOL] Curr
   Endif
  Endif
 Next AOL
 For [AOT]
  Look [AOB]ABREV=[F:AOT]ABREV
  If fstat
   If TEST
    Call ECR_TRACE("AOT"-[F:AOT]ABREV,1) From GESECRAN
   Else
    Delete [AOT] Curr
   Endif
  Endif
 Next AOT
Commit
Close Local File
End

