##################################################
# Mise à jour du flag GENTRA dans ATABLE
##################################################
Subprog ATABLE(DOSSIER,DOSREF)
Value Char DOSSIER, DOSREF

Local File =DOSSIER+".ATABLE" [ATB] , =DOSSIER+".ATABZON" [ATZ]
&        , =DOSSIER+".ADOVAL" [ADW]
&        , =DOSREF+".ATABLE"  [AT2]

Local Char WITEMTRA(10)

# Mise à jour de la table ATABLE
Call ECR_TRACE(mess(81,125,1)-"ATABLE :"-time$,0) From GESECRAN

Read [ADW]ADW0 = "";"";"ITEMTRA"
If !fstat
 WITEMTRA = [F:ADW]VALEUR
Endif

Trbegin [ATB]
 For [ATB]CODFIC Where GENTRA=0
  K = 0
  For [ATZ] Where CODFIC=[F:ATB]CODFIC & find(CODTYP,"AXX","AX1","AX2","AX3")
   K = 1 : Break
  Next
  [F:ATB]GENTRA = K+1
  Rewrite [ATB]
  If fstat : Call ERREUR("ATABLE",2) From DOSDIC : Endif
 Next
 For [AT2]CODFIC
  Read [ATB]CODFIC=[F:AT2]CODFIC
  If !fstat
   [F:ATB]GENTRA = [F:AT2]GENTRA
   Rewrite [ATB]
   If fstat : Call ERREUR("ATABLE",2) From DOSDIC : Endif
  Endif
 Next AT2
 Read [ATB]CODFIC="ITMMASTER"
 If !fstat & WITEMTRA<>"2"
  [F:ATB]GENTRA = 1
  Rewrite [ATB]
  If fstat : Call ERREUR("ATABLE",2) From DOSDIC : Endif
 Endif
Commit

Close Local File [ATB] , [ATZ] , [ADW] , [AT2]
End

##################################################
# Remplacement actions SPX par SPE+STD désactivé
##################################################
Subprog AMSKACT(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AMSKACT" [AMA] , =DOSSIER+".AMSKACT" [AM2]

Local Integer NOSPE , NOSPX

# Mise à jour de la table AMSKACT
Call ECR_TRACE(mess(81,125,1)-"AMSKACT :"-time$,0) From GESECRAN

Trbegin [AMA]
 Filter [AM2] Where TYPAFF=1 & ACTION="SPX"
 For [AM2]TYPAFF(4)
  NOSPX = [F:AM2]NOACT
  NOSPE = 0
  For [AMA] Where TYPAFF=1 & CODAFF=[F:AM2]CODAFF & CODZON=[F:AM2]CODZON
&  & TYPACT=[F:AM2]TYPACT & ACTION="SPE"
   NOSPE = [F:AMA]NOACT : Break
  Next AMA
  If NOSPE
   Read [AMA]TYPAFF=1;[F:AM2]CODAFF;[F:AM2]CODZON;[F:AM2]TYPACT;NOSPE
   If !fstat
    [F:AMA]DISACT = 2
    Rewrite [AMA]
    If fstat : Call ERREUR("AMSKACT",2) From DOSDIC : Endif
    Delete [AMA] Where TYPAFF=1 & CODAFF=[F:AM2]CODAFF & CODZON=[F:AM2]CODZON
&   & TYPACT=[F:AM2]TYPACT & NOACT=NOSPX
    If fstat : Call ERREUR("AMSKACT",3) From DOSDIC : Endif
   Endif
  Else
   Read [AMA]TYPAFF=1;[F:AM2]CODAFF;[F:AM2]CODZON;[F:AM2]TYPACT;NOSPX
   If !fstat
    [F:AMA]ACTION = "SPE"
    [F:AMA]DISACT = 2
    Rewrite [AMA]
    If fstat : Call ERREUR("AMSKACT",2) From DOSDIC : Endif
   Endif
  Endif
 Next AMA
 Filter [AM2]
Commit
End

