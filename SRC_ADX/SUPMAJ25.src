#<AdxTL>@(#)3.0.0.0 $Revision$
#CHECK MIGRATE_SOURCE
Local File ADOSSIER [ADS]
Local Char DOSVAL(20)
DOSVAL = nomap
Read [ADS]DOSSIER = DOSVAL
If fstat : End : Endif
Call OUVRE_TRACE("") From LECFIC
Call AOBJTAB(DOSVAL)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

######################################################################
Subprog MAJDIC
Local Integer I , J , K , OK , OKCOP , DETAIL , OUVFIC , EXISTE
Local Char    X3(20) , OBJET(15), APPLI(15) , MESSA(80)
Local Char    TABSPE(GLONATB)(1..100), TABACTS(GLONACV)(1..300)
Local Integer NBSPE , NBACTS , NBFLD , DIME , VERCUR

VERCUR = 150
DETAIL = 0
APPLI = [F:ADS]DOSSIER

# Les abréviation de ces anciennes tables sont utilisées dans les tables v5/v6
Call VIRETAB(APPLI,"AWRKLOGMES") : # Suppression de la table AWRKLOGMES
Call VIRETAB(APPLI,"APLIMP")     : # Suppression de la table APLIMP

If val(DOSVERS)<14 : End : Endif : # C'est que la mise à jour 14 a déjà été faite

MESSA = "Update Data Types"
If GINFO
 Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
Endif
Call ECR_TRACE(MESSA,0) From GESECRAN
Gosub DOSMAJATY From DOSMAJATY

MESSA = "Update Activity Codes"
If GINFO
 Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
Endif
Call ECR_TRACE(MESSA,0) From GESECRAN
Gosub DOSMAJACV From DOSMAJACV
Call VIRZONAMK(APPLI)

# Le code activité STT ne doit pas être <5 dans un passage 140 en v5
MESSA = "Update Activity Code STT with 5"
Call ECR_TRACE(MESSA,0) From GESECRAN
Call ACTIV(APPLI)

MESSA = "Update tables"
If GINFO
 Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
Endif
Call ECR_TRACE(MESSA,0) From GESECRAN
Gosub DOSMAJATB From DOSMAJATB

End

###################################
Subprog VIRZONAMK(DOSVAL)
Value Char DOSVAL
Call ECR_TRACE("Update Table AMSK",0) From GESECRAN
Local File =DOSVAL+".ATABZON"  [ATZ]
Trbegin [ATZ]
 Delete [ATZ] Where CODFIC="AMSK" & find(CODZONE,"X1","X2","Y1","Y2")<>0
Commit
Close Local File [ATZ]
End

######################################################################
Subprog AMAJ
Local Char DOSVAL(GLONADS) , DOSREF(GLONADS)
DOSVAL = [F:ADS]DOSSIER
DOSREF = [F:ADS]DOSREF
Gosub AMAJSUP
End

$AMAJSUP
If GINFO
 Call AFF_VLC(mess(93,125,1),"Update Supervisor") From GESECRAN
Endif
Call RECTXT50000(DOSVAL)             : # Déplacement des textes spécifiques dans une autre plage
Call ARCHIVEADX(DOSVAL)              : # Création de l'archive
Call RECWRK(DOSVAL)                  : # Récupération des règles workflow 140
Call COPOBJ(DOSREF,DOSVAL,"ANM","WRK","","","") From ACOPIE  : # Création du compteur WRK
Call COPOBJ(DOSREF,DOSVAL,"ANM","WRG","","","") From ACOPIE  : # Création du compteur WRG
Call COPOBJ(DOSREF,DOSVAL,"ANM","AOW","","","") From ACOPIE  : # Création du compteur AOW
If GPRODUIT=3 : # Abel
 Call MAJPAR(DOSVAL,"High resolution","ECRRESOL","2")        : # Paramètre haute résolution
Else
 Call MAJPAR(DOSVAL,"High resolution","ECRRESOL","3")        : # Paramètre haute résolution
Endif
Call MAJPAR(DOSVAL,"History","HISDOS","")                    : # Dossier historisé
Call HRESOL(DOSVAL)                  : # Passage des écrans en haute résolution
Call VIRETRTWIN(DOSVAL)              : # Suppression traitements des fenêtres W*
Call MAJECRCONS(DOSVAL)              : # Code graphique sur écrans consultations
Call ALISTEH(DOSVAL)                 : # MAJ flag graphique dans requêtes + vérif champs disparus
Call MAJWINFIN(DOSVAL)               : # MAJ bouton FIN sur fenêtres consultation
Call GLOBPARAM(DOSVAL)               : # Recuperation des variable globales associées à un parametre
Call SUBPRG(DOSVAL)                  : # MAJ champ DES/DESPAR dans champ INTIT de type ATX table ASUBPRG
Call TYP_IMP(DOSVAL)                 : # Maj table AREPORTV et AREPORTV pour ajout champ type code
Call AOBJLST(DOSVAL,DOSREF)          : # Maj objet suite modif selection gauche
Call DESAOE(DOSVAL)                  : # Maj intitulé en AXX pour l'objet AOE
Call DESAEN(DOSVAL)                  : # Maj intitulé en AXX pour l'objet AEN
Call DESANM(DOSVAL)                  : # Maj intitulé en AXX pour l'objet ANM
Call DESGTC(DOSVAL)                  : # Maj intitulé en AXX pour l'objet GTC
Call DESPS2(DOSVAL)                  : # Maj intitulé en AXX pour l'objet PS2
Call DESPS1(DOSVAL)                  : # Maj intitulé en AXX pour l'objet PS1
Call TABCOUNTRY(DOSVAL,DOSREF)       : # Rajout des formats NID et EECNUM + AXX
Call TABCOEFF(DOSVAL)                : # Maj intitulé en AXX pour l'objet TCO
Call TABCUR(DOSVAL)                  : # Maj intitulé en AXX pour l'objet TCU
Call TABLAN(DOSVAL)                  : # Maj nouveaux champs dans la table TABLAN + Textes traduisibles
Call AMSKZON(DOSVAL)                 : # Raz MOTCLE sur type de donnée ABS
Call ATABLE(DOSVAL,DOSREF)           : # Mise à jour du flag GENTRA
Call AMSKACT(DOSVAL)                 : # Remplacement actions SPX par SPE+STD désactivé
Call DESMEMO(DOSVAL)                 : # Maj intitulé en AXX pour les memos
Call DESALH(DOSVAL)                  : # Maj intitulé en AXX pour les requetes
Call DESALD(DOSVAL)                  : # Maj intitulé en AXX pour les requetes (lignes)
Call TUNALD(DOSVAL)                  : # Maj champ tunnel pour les requetes
Call DESAPS(DOSVAL)                  : # Maj intitulé en AXX pour les pages du portail
Call DESAP2(DOSVAL)                  : # Maj intitulé en AXX pour les pages du Multi-listes
Call DESAPV(DOSVAL)                  : # Maj intitulé en AXX pour les pages des Vues du portail
Call MAJDOCSUP(DOSVAL)               : # Reprise des doc actions et sous-programmes
Call MAJPUBFLG(DOSVAL)               : # Maj flag "Public"
Call RECAIDEFLD(DOSVAL)              : # Récup aide en ligne
Call CONCATPAR(DOSVAL)               : # Concaténation paramètres suite à augmentation champ VALEUR
Call AREPORTD(DOSVAL)                : # Suppression des paramètres X3LAN, X3FCT, X3PRF, X3SIT
Call SUPP_APTLPAR(DOSVAL)            : # Suppression .srf .fde et valfil -d de la table APTLPAR
Call ATABDIV(DOSVAL)                 : # Suppression des homonymes de la table ATABDIV
Call MAJGRP(DOSVAL)                  : # Génération des tables AGRPFCY et AGRPCPY
Call IMPNOW(DOSVAL)                  : # Maj champ IMPNOW dans les code impressions
Call COPASY(DOSREF,DOSVAL,"AMKACT")  : # Copie du style AMKACT
Call COPASY(DOSREF,DOSVAL,"AMKCUR")  : # Copie du style AMKCUR
Call GENVUE(DOSVAL)                  : # Génération des vues dans le dossier histo
Call ADOSSIER(DOSVAL)                : # Mise à jour CREWIN
Call VIRETAB(DOSVAL,"ALISTEI")       : # Suppression de la table ALISTEI
Call VIRETAB(DOSVAL,"AWRKLOGMES")    : # Suppression de la table AWRKLOGMES
Call VIRETAB(DOSVAL,"APLIMP")        : # Suppression de la table APLIMP
Call USRNOMME(DOSVAL)                : # Rajout des utilisateurs nommés
Call AOBJTAB(DOSVAL)                 : # Ménage dans les tables liées à AOBJET
If GINFO
 Call AFF_VLC("","") From GESECRAN
Endif
Return

######################################################################
Subprog MAJ
Local Char DOSVAL(GLONADS)
DOSVAL = [F:ADS]DOSSIER
DOSREF = [F:ADS]DOSREF
Gosub MAJSUP
End

$MAJSUP
If GINFO
 Call AFF_VLC(mess(93,125,1),"Update Supervisor") From GESECRAN
Endif
Call AFONCTION(DOSVAL,DOSREF)    : # Mise à jour des champs RANG et MENU de la table AFONCTION
Call VALFCT(DOSVAL) From AVALAFC : # Génération de la table AFCTFCY
Call ALISTED(DOSVAL)             : # Vérification présence champs requêtes
Call GENSTYLE(DOSVAL,"DEFAULT") From SUBASY : # Génération du fichier style
Call VALPRF(DOSVAL)              : # Génération des menus
If GINFO
 Call AFF_VLC("","") From GESECRAN
Endif
Return

######################################################################
# Génération des menus
######################################################################

Subprog VALPRF(DOSSIER)
Value Char DOSSIER

Local Integer NBPROF , OK , I
Local Char    TBPROF(GLONAFT)(1..500) , PROFCUR(GLONAFT)

Call ECR_TRACE(mess(39,125,1)-time$,0) From GESECRAN : # MAJ des menus utilisateurs

Local File =DOSSIER+".AFONCTION" [AFC] , =DOSSIER+".AMENUSER"  [AMU]

For [AMU]MENFCT(1)
 OK = 1
 PROFCUR = [F:AMU]CODPRF
 For [AMU]MENFCT
  Read [AFC]CODINT = [F:AMU]FONCTION
  If fstat
   OK = 0
  Endif
 Next
 If OK
  NBPROF += 1
  TBPROF(NBPROF) = PROFCUR
 Endif
Next AMU

For I=1 To NBPROF
 Call ECR_TRACE(mess(16,130,1)-TBPROF(I),0) From GESECRAN : # Profil menu
 Call VALPROFAPP(TBPROF(I),DOSSIER) From VALMENU
Next I

Close Local File
End

######################################################################
Subprog ACTIV(DOSSIER)
Value Char DOSSIER

Local Char WCOD(20)

Local File ADOSACT              [ADA]
Local File =[L]DOSSIER+".ACTIV" [ACV]

WCOD = "STT"
Read [ADA]ADA0 = [L]DOSSIER;WCOD
If fstat or [F:ADA]DIME>=5 : End : Endif
Trbegin [ADA] , [ACV]
 Update [ADA] Where DOSSIER=[L]DOSSIER & CODACT=WCOD With DIME=5, FLACT=2
 Update [ACV] Where CODACT=WCOD With DIME=5, FLACT=2
 For WCOD="ST1","ST2","ST3","ST4","ST5"
  Update [ADA] Where DOSSIER=[L]DOSSIER & CODACT=WCOD With FLACT=2
  Update [ACV] Where CODACT=WCOD With FLACT=2
 Next WCOD
 For WCOD="ST6","ST7","ST8"
  Update [ADA] Where DOSSIER=[L]DOSSIER & CODACT=WCOD With FLACT=1
  Update [ACV] Where CODACT=WCOD With FLACT=1
 Next WCOD
Commit
Close Local File
End

######################################################################
Subprog ALISTED(DOSSIER)
Value Char DOSSIER

Local Char ZON(15)

If filinfo(filpath("FIL","ALISTED","fde",DOSSIER),0)<=0 : End : Endif
Local File =DOSSIER+".ALISTED" [ALD] , =DOSSIER+".ATABZON" [ATZ]

Call ECR_TRACE(mess(229,139,1)-": ALISTED"-time$,0) From GESECRAN : # Vérification des requêtes

For [ALD]
 If [F:ALD]TBL<>""
  Read [ATZ]CODZONE(1)=[F:ALD]TBL
  If fstat
   # Requête/Table inexistante
   Call ECR_TRACE(mess(18,134,1)-[F:ALD]COD-":"-[F:ALD]TBL-mess(124,124,1),-1) From GESECRAN
  Elsif [F:ALD]FLD<>""
   ZON = [F:ALD]FLD
   I = instr(1,[F:ALD]FLD,"(")
   If I
    ZON = left$(ZON,I-1)
   Endif
   Read [ATZ]CODZONE=[F:ALD]TBL;ZON
   If fstat
    # Requête/Champ inexistant sur la table
    Call ECR_TRACE(mess(18,134,1)-[F:ALD]COD-":"-ZON-mess(13,133,1)-[F:ALD]TBL,-1) From GESECRAN
   Endif
  Endif
 Endif
Next

Close Local File [ALD] , [ATZ]
End

######################################################################
Subprog RECAIDEFLD(DOSSIER)
Value Char DOSSIER

# Les aides spécifiques à récupérer doivent être dans le répertoire
# HTM du DOSSIER. Les aides qui ne commencent pas par X Y ou Z sont
# renommées (dans les écrans aussi) et intégrées dans la table ADOCFLD

If filinfo(filpath("HTM","","",DOSSIER),0)<0 : End : Endif

Local Integer ERN
Onerrgo ERR
Local File =DOSSIER+".AMSKZON" [AMZ] , =DOSSIER+".ATABZON" [ATZ]
&        , =DOSSIER+".ADOCFLD" [ADZ]
Onerrgo
If ERN : End : Endif

# maj table
Call ECR_TRACE(mess(81,125,1)-": ADOCFLD"-time$,0) From GESECRAN

Local Char    MACHINE(50) , APPLI(50) , COMMANDE(250)
Local Char    TRAIT(15)(30000)
Local Integer I , NBTRAIT , STAT
Local Char    NAM(15) , NEWNAM(15)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

Call SYSTEME2(MACHINE,"lsadx -a "+APPLI+" HTM","",NBTRAIT,TRAIT) From ORDSYS

Trbegin [ATZ] , [ADZ]
 For I=0 To NBTRAIT
  If TRAIT(I)<>""
   NAM = vireblc(TRAIT(I),2)
   J = instr(1,NAM,".")
   If J
    NAM = left$(NAM,J-1)
   Endif
   If NAM>="X"
    NEWNAM = left$(NAM,10)
   Else
    NEWNAM = left$("Z"+NAM,10)
    Read [ADZ]ADZ0=GLANGUE+NEWNAM
    If !fstat
     NEWNAM = left$("Y"+NAM,10)
     Read [ADZ]ADZ0=GLANGUE+NEWNAM
     If !fstat
      NEWNAM = left$("X"+NAM,10)
     Endif
    Endif
   Endif
   If NAM<>NEWNAM
    Update [AMZ] Where MOTCLE=NAM With MOTCLE=NEWNAM
    If fstat
     Call ERREUR("AMSKZON"-NAM,2) From DOSDIC
    Endif
    Update [ATZ] Where MOTCLE=NAM With MOTCLE=NEWNAM
    If fstat
     Call ERREUR("ATABZON"-NAM,2) From DOSDIC
    Endif
   Endif
   Read [ADZ]ADZ0=GLANGUE;NEWNAM
   If fstat
    Raz [F:ADZ]
    [F:ADZ]MOTCLE = NEWNAM
    [F:ADZ]LAN    = GLANGUE
    [F:ADZ]MODULE = 1
    [F:ADZ]GEN    = 1
    [F:ADZ]CREDAT = date$
    If dim([F:ADZ]CRETIM)>0 : [F:ADZ]CRETIM = time : Endif
    [F:ADZ]CREUSR = GUSER
    Openi filpath("HTM",TRAIT(I),"",DOSSIER) Using [XXX]
    Getseq 1,[F:ADZ]TEXTE Using [XXX]
    Openi Using [XXX]
    Write [ADZ]
    If fstat
     Call ERREUR("ADOCFLD"-GLANGUE-NEWNAM,1) From DOSDIC
    Endif
   Else
    [F:ADZ]UPDDAT = date$
    If dim([F:ADZ]UPDTIM)>0 : [F:ADZ]UPDTIM = time : Endif
    [F:ADZ]UPDUSR = GUSER
    Openi filpath("HTM",TRAIT(I),"",DOSSIER) Using [XXX]
    Getseq 1,[F:ADZ]TEXTE Using [XXX]
    Openi Using [XXX]
    Rewrite [ADZ]
    If fstat
     Call ERREUR("ADOCFLD"-GLANGUE-NEWNAM,2) From DOSDIC
    Endif
   Endif
  Endif
 Next I
Commit

End

######################################################################
Subprog RECTXT50000(DOSSIER)
Value Char DOSSIER

Local Char    TABLE(GLONATB)
Local Integer I , J , K , L , NUM , ERN
Local Char    ZONE(GLONAVA)(1..300)
Local Integer DIME(1..300)
Local Integer DEBTXT , MAXTXT

# Ancienne plage des textes standard
DEBTXT = 50000
MAXTXT = GMAXTXTSTD-1

# Si la plage n'a pas changé, on sort
If GMAXTXTSTD=DEBTXT : End : Endif

Onerrgo ERR
Local File =DOSSIER+".ATABZON"  [ATZ] , =DOSSIER+".ATEXTE" [ATX2]
Onerrgo
If ERN : End : Endif

# Incrémente un delta par rapport à GMAXTXTSTD si des textes > 100000 sont déjà utilisés
#115210/6
Filter [ATX2] Where NUMERO<GNEWTXTSTD
Read [ATX2]DERNUM Last
Filter [ATX2]
Local Integer DELTATXT
DELTATXT = max(GMAXTXTSTD,[F:ATX2]NUMERO)-GMAXTXTSTD



# maj table
Call ECR_TRACE(mess(81,125,1)-": ATEXTE ("+num$(DEBTXT)+"->"+num$(GMAXTXTSTD)+")"-time$,0) From GESECRAN
If DELTATXT>0
  Call ECR_TRACE("Delta :"-num$(DELTATXT),0) From GESECRAN
Endif
For [ATZ]CODTYP(2) Where CODTYP="ATX"
 TABLE = [F:ATZ]CODFIC
 If filinfo(filpath("FIL",TABLE,"fde",DOSSIER),0)>0
  L = 0
  Local File =DOSSIER+"."+TABLE [WWW]
  NBZONE = 0
  For [ATZ]CODTYP
   NBZONE += 1
   ZONE(NBZONE) = [F:ATZ]CODZONE
   DIME(NBZONE) = evalue("dim([F:WWW]"+ZONE(NBZONE)+")")
  Next ATZ
  Trbegin ADOVAL
   For [WWW]
    K = 0
    For I=1 To NBZONE
     For J=0 To DIME(I)-1
      NUM = evalue("[F:WWW]"+ZONE(I)+"("+num$(J)+")")
      If NUM>=DEBTXT & NUM<=MAXTXT
       Assign "[F:WWW]"+ZONE(I)+"("+num$(J)+")" With NUM+(GMAXTXTSTD-DEBTXT+DELTATXT)
       K = 1
      Endif
     Next J
    Next I
    If K
     Rewrite [WWW]
     If fstat
      Call ERREUR(TABLE-num$(NUM),2) From DOSDIC
     Endif
     L = 1
    Endif
   Next WWW
  Commit
  Close Local File [WWW]
  If L
   Call ECR_TRACE(TABLE-"Updated",0) From GESECRAN
  Endif
 Endif
Next ATZ
Trbegin [ATX2]
 For [ATX2] Where NUMERO>DEBTXT & NUMERO<MAXTXT
  [F:ATX2]NUMERO += (GMAXTXTSTD-DEBTXT+DELTATXT)
  Rewrite [ATX2]
  If fstat
   Call ERREUR("ATEXTE"-num$([F:ATX2]NUMERO),2) From DOSDIC
  Endif
 Next ATX2
Commit
Call ECR_TRACE("ATEXTE Updated",0) From GESECRAN
End

######################################################################
Subprog ARCHIVEADX(DOSSIER)
Value Char DOSSIER

Local Char    MACHINE(GLONAMC) , APPLI(GLONADS) , COMMAND(250)
Local Char    TRAIT(GLONADC)(30000)
Local Integer I , NBTRAIT , STAT

If val(DOSVERS)<14 : End : Endif : # C'est que la mise à jour 14 a déjà été faite

Call ECR_TRACE("Update process"-time$,0) From GESECRAN

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

# Suppression de l'archive
Call EFFACE(filpath("","archive","atx",APPLI,"",MACHINE),STAT) From ORDSYS
Call EFFACE(filpath("","atx","ind",APPLI,"",MACHINE),STAT) From ORDSYS
Call EFFACE(filpath("","atx","vers",APPLI,"",MACHINE),STAT) From ORDSYS

# Création de l'archive
System COMMAND=MACHINE+'@archive -d'-APPLI-'-t'-'-c "*"'

End

######################################################################
Subprog RECWRK(DOSSIER)
Value Char DOSSIER

Local Char    TEXTE(255)(1..200)
Local Integer I , J , ERN , NBTEX , STAT

Call ECR_TRACE(mess(81,125,1)-": AWRKPAR"-time$,0) From GESECRAN : # maj table

If filinfo(filpath("FIL","AMESSAGE","fde",DOSSIER),0)<=0 : End : Endif

Onerrgo ERR
Local File =DOSSIER+".AWRKPAR"   [AWA] , =DOSSIER+".AWRKPARF" [AWF]
&        , =DOSSIER+".AWRKPARC"  [AWC]
&        , =DOSSIER+".AWRKPARH"  [AWH] , =DOSSIER+".AMESSAGE" [AMS]
&        , =DOSSIER+".AMESSAGED" [AMD] , =DOSSIER+".ATEXTRA"  [AXX]
Onerrgo
If ERN : End : Endif

Trbegin [AWA] , [AWF] , [AWC]
 For [AMS]
  If len([F:AMS]CODE)<10
   Call EFFACE(filpath("TRT","WMK"+[F:AMS]CODE,"src",DOSSIER),STAT) From ORDSYS
  Else
   Call EFFACE(filpath("TRT","WW"+[F:AMS]CODE,"src",DOSSIER),STAT) From ORDSYS
  Endif
  Read [AWA]AWA0 = [F:AMS]CODE
  If fstat
   Call ECR_TRACE(mess(55,75,1)-[F:AMS]CODE,0) From GESECRAN
   Raz [F:AWA]
   [F:AWA] = [F:AMS]
   If dim([F:AMS]TYPEVT)<=0 : # Passage 130->v5
    If left$([F:AMS]EVENEMENT,3)="OBJ"
     [F:AWA]TYPEVT = 2
     [F:AWA]CODEVT = right$([F:AMS]EVENEMENT,4)
    Elsif left$([F:AMS]EVENEMENT,2)="F_"
     [F:AWA]TYPEVT = 3
     [F:AWA]CODEVT = right$([F:AMS]EVENEMENT,3)
    Elsif left$([F:AMS]EVENEMENT,2)="R_"
     [F:AWA]TYPEVT = 4
     [F:AWA]CODEVT = right$([F:AMS]EVENEMENT,3)
    Elsif left$([F:AMS]EVENEMENT,2)="T_"
     [F:AWA]TYPEVT = 7
     [F:AWA]CODEVT = right$([F:AMS]EVENEMENT,3)
    Elsif [F:AMS]EVENEMENT="BATCH"
     [F:AWA]TYPEVT = 5
     [F:AWA]CODEVT = ""
    Elsif [F:AMS]EVENEMENT="ABORT"
     [F:AWA]TYPEVT = 6
     [F:AWA]CODEVT = ""
    Else
     [F:AWA]TYPEVT = 1
     [F:AWA]CODEVT = [F:AMS]EVENEMENT
    Endif
   Endif
   Call MAJTEXTRA([F:AMS]DESIG,"AWRKPAR","INTIT",[F:AMS]CODE,"")
   [F:AWA]CATEG = [F:AMS]CATEGORIE
   [F:AWA]TYPWRK = 2
   [F:AWA]ENAFLG = 1
   I = instr(1,[F:AWA]OPERATION,"B")
   If I
    [F:AWA]OPERATION = left$([F:AWA]OPERATION,I-1)+"W"+right$([F:AWA]OPERATION,I+1)
   Endif
   I = instr(1,[F:AWA]OPERATION,"S")
   If I
    [F:AWA]OPERATION = left$([F:AWA]OPERATION,I-1)+"A"+right$([F:AWA]OPERATION,I+1)
   Endif
   I = instr(1,[F:AWA]OPERATION,"X")
   If I
    [F:AWA]OPERATION = left$([F:AWA]OPERATION,I-1)+"H"+right$([F:AWA]OPERATION,I+1)
   Endif
   If dim([F:AMS]BOUTON)>0
    [F:AWA]OPERATION += [F:AMS]BOUTON
   Endif
   For I=1 To [F:AWA]NBCOND
    [F:AWA]TYPCND(I-1) = 2
   Next I
   Raz [F:AWH]
   [F:AWH] = [F:AMS]
   For I=1 To [F:AWH]NBDEST
    [F:AWH]OPTDEL(I-1) = 1
    [F:AWH]SUIVI(I-1) = 1
    If [F:AMS]COPIE=2
     [F:AWH]ENVOI(I-1) = 3
    Else
     [F:AWH]ENVOI(I-1) = 2
    Endif
   Next I
   Write [AWH]
   If fstat
    Call ERREUR("AWRKPARH"-[F:AWA]CODE,1) From DOSDIC
   Endif
   [F:AWA]OBJET = [F:AMS]SUJET
   Raz TEXTE , NBTEX
   For [AMD] Where CODE=[F:AMS]CODE
    NBTEX += 1
    TEXTE(NBTEX) = "|"+[F:AMD]TEXTE+"|"
    If [F:AMD]SAUTLG=2
     TEXTE(NBTEX) += chr$(10)
    Endif
   Next AMD
   Setlob [F:AWA]TEXTE With [L]TEXTE
   Write [AWA]
   If fstat
    Call ERREUR("AWRKPAR"-[F:AMS]CODE,1) From DOSDIC
   Endif
   Raz [F:AWF]
   [F:AWF]CODE = [F:AWA]CODE
   Write [AWF]
   If fstat
    Call ERREUR("AWRKPARF"-[F:AWA]CODE,1) From DOSDIC
   Endif
   If dim([F:AMS]ACTION)>0 & [F:AMS]ACTION<>""
    Raz [F:AWC]
    [F:AWC] = [F:AMS]
    [F:AWC]CODE = [F:AWA]CODE
    [F:AWC]NUMACT = 1
    [F:AWC]DECACT = 2
    Write [AWC]
    If fstat
     Call ERREUR("AWRKPARC"-[F:AWA]CODE,1) From DOSDIC
    Endif
   Endif
  Endif
 Next AMS
Commit

End

$ERR
ERN = errn
Resume

######################################################################
Subprog MAJPAR(DOSSIER,TIT,PARAM,VALEUR)
Value Char DOSSIER , TIT , PARAM , VALEUR

Local File =DOSSIER+".ADOVAL" [ADW]
Call ECR_TRACE(TIT-time$,0) From GESECRAN
Trbegin [ADW]
 Case PARAM
  When "HISDOS"
   Read [ADW]ADW0 = "";"";PARAM
   If fstat
    Raz [F:ADW]
    [F:ADW]PARAM  = PARAM
    [F:ADW]VALEUR = ""
    Write [ADW]
    If fstat : Call ERREUR("ADOVAL",1) From DOSDIC : Endif
   Endif
  When Default
   Read [ADW]ADW0 = "";"";PARAM
   If fstat
    Raz [F:ADW]
    [F:ADW]PARAM  = PARAM
    [F:ADW]VALEUR = VALEUR
    Write [ADW]
    If fstat : Call ERREUR("ADOVAL",1) From DOSDIC : Endif
   Else
    [F:ADW]VALEUR = VALEUR
    Rewrite [ADW]
    If fstat : Call ERREUR("ADOVAL",2) From DOSDIC : Endif
   Endif
 Endcase
Commit
Close Local File [ADW]
End

###########################################################################
## Moulinette de passage en haute résolution
###########################################################################
Subprog HRESOL(DOSSIER)
Value Char DOSSIER
Local Integer SPEC
Local File =DOSSIER+".AMSK" [AMK]
Call ECR_TRACE(mess(81,125,1)-": AMSK"-time$,0) From GESECRAN : # maj table
Trbegin [AMK]
 For [AMK] Where TYPMSK=1 or TYPMSK=5
  If [F:AMK]CODACT=""
   SPEC = 0
  Else
   Call SPEC([F:AMK]CODACT,SPEC) From DOSSUB
  Endif
  If SPEC
   Case [F:AMK]TYPMSK
    When 1
     If    [F:AMK]NBRCOL=64 : [F:AMK]NBRCOL = 74
     Elsif [F:AMK]NBRCOL=84 : [F:AMK]NBRCOL = 112
     Endif
     If [F:AMK]NBRLIG>=10 & [F:AMK]NBRLIG<=20
      [F:AMK]NBRLIG += 8
     Endif
    When 5
     If    [F:AMK]NBRCOL=64 : [F:AMK]NBRCOL = 74
     Elsif [F:AMK]NBRCOL=84 : [F:AMK]NBRCOL = 112
     Endif
   Endcase
   Rewrite [AMK]
   If fstat : Call ERREUR("AMSK",2) From DOSDIC : Endif
  Endif
 Next
Commit
Close Local File [AMK]
End

######################################################################
Subprog VIRETRTWIN(DOSSIER)
Value Char DOSSIER

Local Integer STAT

Local File =DOSSIER+".AWINDOW" [AWI] , =DOSSIER+".AMSK" [AMK] , =DOSSIER+".AMSKZON" [AMZ]
&        , =DOSSIER+".AMSKACT" [AMA] , =DOSSIER+".AWINBOUT" [AWT] , =DOSSIER+".AWINBRO" [AWB]
&        , =DOSSIER+".AWINPAR" [AWP]

Call ECR_TRACE("Purge process windows W*"-time$,0) From GESECRAN

For [AWI] Where left$(WIN,1)="W"
 Call EFFACE(filpath("TRT","WG"+right$([F:AWI]WIN,2),"src",DOSSIER),STAT) From ORDSYS
 Call EFFACE_ADX("",DOSSIER,"WG"+right$([F:AWI]WIN,2),STAT) From ORDSYS
Next AWI

Call ECR_TRACE("Purge windows W*"-time$,0) From GESECRAN
Trbegin [AWI]
 Delete [AWI] Where left$(WIN,1)="W"
 Delete [AWT] Where left$(WIN,1)="W"
 Delete [AWB] Where left$(WIN,1)="W"
 Delete [AWP] Where left$(WIN,1)="W"
Commit

Call ECR_TRACE("Purge process screen W*"-time$,0) From GESECRAN

For [AMK] Where left$(CODMSK,1)="W"
 Call EFFACE(filpath("TRT","W0"+right$([F:AMK]CODMSK,2),"src",DOSSIER),STAT) From ORDSYS
 Call EFFACE(filpath("TRT","W1"+right$([F:AMK]CODMSK,2),"src",DOSSIER),STAT) From ORDSYS
 Call EFFACE_ADX("",DOSSIER,"W0"+right$([F:AMK]CODMSK,2),STAT) From ORDSYS
 Call EFFACE_ADX("",DOSSIER,"W1"+right$([F:AMK]CODMSK,2),STAT) From ORDSYS
Next AMK

Call ECR_TRACE("Purge screen W*"-time$,0) From GESECRAN
Trbegin [AMK]
 Delete [AMK] Where left$(CODMSK,1)="W"
 Delete [AMA] Where TYPAFF=1 & left$(CODAFF,1)="W"
 Delete [AMZ] Where left$(CODMSK,1)="W"
Commit

Close Local File [AWI] , [AMK] , [AMZ] , [AMA] , [AWT] , [AWB] , [AWP]
End

