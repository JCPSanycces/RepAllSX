#<AdxTL>@(#)3.0.0.0 $Revision$
# Gestion du masque CONSSTCITM1
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Transmask [M:STP1] To [M:CSTP]  # Issue 25606_Transmask [M:CSTP] = [M:STP1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITP]) = 0 : Local File ITMBPS     [ITP] : Endif
If clalev([F:ACV]) = 0 : Local File ACTIV      [ACV] : Endif

#
Local Char    WFIL(250), WFILS(250), WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I

#
Gosub LOAD_SCREEN
#
NAVIG="CONSSTCITP"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:STP1]    = [M:CSTP]
Return
############################################################
$AP_MAGNETO
Return
############################################################
$FERME
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return





############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("STC",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:STP1]STCNUM = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:STP1]ITMREFSTR = [F:ITM]ITMREF
        Endif
      Endif
    When 4 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:STP1]ITMREFEND = [F:ITM]ITMREF
        Endif
      Endif
  Endcase
Next I
If clalev([M:CSTP]) <> 0 & [M:CSTP]MEMO = "STD"
  [M:STP1] = [M:CSTP]
Endif
Return
############################################################
$LECTURE
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    Raz [M:STP2]
    nolign = 1
    WPAGE  = 0
    For [LNK]
      If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    # Bug 38845 - 12/12/2006 - Début
    Effzo [M:STP2]
    # Bug 38845 - 12/12/2006 - fin
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [LNK]
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    += 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :

    Effzo [M:STP2]
    WLIG = 0
    For [LNK]

        WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [LNK]
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    -= 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    Effzo [M:STP2]
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [LNK]
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Filter [F:ITP]
Return
############################################################
$TRT_FILTER
  Raz [M:STP2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif

  Link [ITP] With [ITM]ITM0=[F:ITP]ITMREF
&                As [LNK]
&                Where evalue(WFIL)    &
&                      evalue(WFILSPE)
&                Order By Key ITP0


[M:STP1]NBRITM = rowcount([LNK])

Return

############################################################
$LOAD_FILTER
WFIL="1=1"
# Filtre structure de couts
If [M:STP1]STCNUM <> ""
    WFIL = "[F:ITP]STCNUM=[M:STP1]STCNUM"
Endif

# Filtre article
If [M:STP1]ITMREFSTR <> "" | [M:STP1]ITMREFEND <> ""
  If [M:STP1]ITMREFSTR = [M:STP1]ITMREFEND
    WFIL += "&[F:ITP]ITMREF=[M:STP1]ITMREFSTR"
  Else
    WFIL += "&[F:ITP]ITMREF>=[M:STP1]ITMREFSTR&[F:ITP]ITMREF<=[M:STP1]ITMREFEND"
  Endif
Endif

# filtre catégorie article
If [M:STP1]BPSNUMSTR <> "" | [M:STP1]BPSNUMEND <> ""
  If [M:STP1]BPSNUMSTR = [M:STP1]BPSNUMEND
    WFIL += " & [F:ITP]BPSNUM=[M:STP1]BPSNUMSTR"
  Else
    WFIL += " & [F:ITP]BPSNUM>=[M:STP1]BPSNUMSTR & [F:ITP]BPSNUM<=[M:STP1]BPSNUMEND"
  Endif
Endif

Return
############################################################
$LOA_LIGNE
[M:STP2] = [F:ITM]
[M:STP2] = [F:ITP]
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:STP2]DES1AXX(nolign-1), "[F:ITM]") From TRTX3 # hcb 68703
[M:STP2]PUU(nolign-1)=[F:ITP]PUU

Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
############################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
#[M:STI1]FLG = 0
#[M:STI1]ITMREFEND = VALEUR
If [M]ITMREFEND = "" [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
If [M]ITMREFEND < VALEUR [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
End
############################################################
Subprog AM_ITMREFEND(VALEUR)
Variable Char    VALEUR()
#[M:STI1]FLG = 0
End
############################################################
Subprog AV_ITMREFEND(VALEUR)
Variable Char     VALEUR
If VALEUR = ""
  VALEUR = [M]ITMREFSTR
Endif
End


##########################################################################
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"STP") From SUBGTC

End


######################################################################################
## Etiquette ajoutée par le superviseur (écran CRITSTI) 22/01/2013 09:32:27 (MAE)
######################################################################################
Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]ITMREFSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End

Subprog AM_BPSNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]BPSNUMEND="" [M]BPSNUMEND=VALEUR : Affzo [M]BPSNUMEND : Endif
If [M]BPSNUMEND < VALEUR [M]BPSNUMEND = VALEUR : Affzo [M]BPSNUMEND : Endif
End

Subprog C_BPSNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]BPSNUMSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End


######################################################################################

