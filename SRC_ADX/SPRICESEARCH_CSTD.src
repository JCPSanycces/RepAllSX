###################################################################################################
$CONTROL_SALFCY


Return
#------------------------------------------------------------------------------
$PROPAGATE_SALFCY

  #this.STOFCY = "" #AVOID.ACHAR

Return
#------------------------------------------------------------------------------
$CONTROL_STOFCY

  If this.STOFCY = ""
    #[L]ASTATUS = fmet this.ASETERROR ("STOFCY", mess(10,123,1), [V]CST_AERROR)
    Return
  Endif

  Local File FACILITY [SALFCY]
  Local File FACILITY [STOFCY]

  If this.SALFCY<>""
    Read [F:SALFCY]FCY0=this.SALFCY
    If fstat : Raz [F:SALFCY] : Return : Endif
  Endif

  If this.STOFCY<>""
    Read [F:STOFCY]FCY0=this.STOFCY
    If fstat : Raz [F:STOFCY] : Return : Endif
  Endif

  # --- le site doit être sur la même société juridique que site de vente
  If [F:STOFCY]LEGCPY<>[F:SALFCY]LEGCPY
    [L]ASTATUS = fmet this.ASETERROR ("STOFCY", mess(2,194,1), [V]CST_AERROR)
    Return
  Endif

  LogicClose File [SALFCY]
  LogicClose File [STOFCY]

Return
#------------------------------------------------------------------------------
$PROPAGATE_STOFCY

  If this.STOFCY = ""

    this.CPY    = ""
    this.PLISTC = ""
    this.LEG    = ""
    Return

  Endif

  Local File FACILITY [FCY]
  Local File COMPANY  [CPY]

  Read [F:FCY]FCY0=this.STOFCY
  If fstat : Raz [F:FCY] : Endif
  this.CPY=[F:FCY]LEGCPY

  Read [F:CPY]CPY0=[F:FCY]LEGCPY
  If fstat : Raz [F:CPY] : Endif

  this.PLISTC = [F:CPY]PLISTC
  this.LEG    = [F:CPY]LEG

  LogicClose File [FCY]
  LogicClose File [CPY]

Return
#------------------------------------------------------------------------------
$CONTROL_BPCORD

Return
#------------------------------------------------------------------------------
$PROPAGATE_BPCORD

 Local File BPCUSTOMER [BPC]

	If this.BPCORD="" Return Endif

  # --- Affichage des Informations clients
  Local Char    WANCCUR(GLONCUR) : WANCCUR    = this.CURREF
  Local Integer WRET
  Local Char    WMESSAGE(250)

  Read [F:BPC]BPC0=this.BPCORD
  If fstat : Raz [F:BPC] : Endif

  # --- affichage observations client
  If [F:BPC]BPCREM<>""
    [L]ASTATUS = fmet this.ASETERROR ("", [F:BPC]BPCREM, [V]CST_AINFO)
  Endif

  #--Restricted price list search
  If this.PRICEPARAM(1)=null
    WRET = fmet this.ADDLINE("PRICEPARAM",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("ITMREF", func ASYRFNC.MES2(mess(266,133,1),"PRICEPARAM","SPRICESEARCH"), [V]CST_AERROR)
      Return
    Endif
  Endif

  WRET = fmet this.PRICEPARAM(1).INITPARAM()
  If WRET>=[V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR ("ITMREF", mess(68,123,1)-":"-mess(1,7845,1)-"INITPARAM", [V]CST_AERROR)
    Return
  Endif

  this.PRICEPARAM(1).BPAADD = "" #AVOID.ACHAR

  Call ALICLI (1,"C",this.BPCORD, this.PRICEPARAM(1), WRET) From FINDPRICE_SYRA
  #--Test if errors
  #If WRET<=[V]CST_ASUCCESS : WRET = fmet this.PRICEPARAM(1).AGETMAXERROR("") : Endif
	If WRET>=[V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR ("BPCORD", mess(68,123,1)-":"-mess(3,7845,1)-"ALICLI", [V]CST_AERROR)
    Return
  Endif

  If this.PRICEPARAM(1)<>null and this.PRICEPARAM(1).C_SPKH(1)<>null

    this.BPAADD  = this.PRICEPARAM(1).BPAADD

    #--Because of the Control action of the PTE field, and to avoid blocking situations
    #--This will trigger Propagate of PTE
    this.PTE     = this.PRICEPARAM(1).C_SPKH(1).PTE

    #--This will trigger Propagate of PTE
    this.VACBPR  = this.PRICEPARAM(1).VACBPR

    this.CURREF  = this.PRICEPARAM(1).CUR
    this.PRITYP  = this.PRICEPARAM(1).PRITYP

    this.MDL     = this.PRICEPARAM(1).C_SPKH(1).MDL
    #--CPO 98525
    this.EECICT  = this.PRICEPARAM(1).C_SPKH(1).EECICT
    #--/
  Endif

  If WANCCUR<>this.CURREF and this.PRICEPARAM(1)<>null
    # Alimentation du format des colonnes frais/remise
    WRET = func TRTPRICE_SYRA.ALIFORREM (this, 0, this.CURREF, this.PRICEPARAM(1).FMTCOLREM, WMESSAGE)
  	#--Test if errors
  	#If WRET<=[V]CST_ASUCCESS : WRET = fmet this.AGETMAXERROR("") : Endif
  	If WRET >=[V]CST_AERROR
  	  If WMESSAGE=""
  	    WMESSAGE = mess(68,123,1)-":"-mess(2,7845,1)-"ALIFORREM"
  	  Endif
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("BPCORD", WMESSAGE, WRET)
      Return
    Endif
  Endif

  LogicClose File [BPC]

Return
#------------------------------------------------------------------------------
$CONTROL_ITMREF

  If this.ITMREF = "" : Return : Endif

  Local File ITMSALES  [ITS]
  Local File ITMMASTER [ITM]

  Read [F:ITS]ITS0=this.ITMREF
  If fstat
    [L]ASTATUS = fmet this.ASETERROR("ITMREF", mess(5,192,1), [V]CST_AERROR)
    Return
  Endif

  Read [F:ITM]ITM0=this.ITMREF
  If fstat
    [L]ASTATUS = fmet this.ASETERROR("ITMREF", mess(8,192,1), [V]CST_AERROR)
    Return
  Endif

  LogicClose File [ITS]
  LogicClose File [ITM]

Return
#------------------------------------------------------------------------------
$PROPAGATE_ITMREF

  Local Integer WRET
  Local Char    WMESSAGE(250)

  Local File ITMMASTER [ITM]
  Local File ITMBPC    [ITU]

  If this.ITMREF<>""

    Read [F:ITM]ITM0 = this.ITMREF
    If fstat : Raz [F:ITM] : Endif

    this.SAUREF = [F:ITM]SAU

    If this.BPCORD<>""

      Read [ITU]ITU0=this.ITMREF;this.BPCORD
      If fstat Raz [F:ITU] Endif

      If [F:ITU]SAU<>""
        this.SAUREF = [F:ITU]SAU
      Endif

    Endif
  Endif

  LogicClose File [ITM]
  LogicClose File [ITU]

Return
#------------------------------------------------------------------------------
$PROPAGATE_DATEREF

Return
#------------------------------------------------------------------------------
$PROPAGATE_CURREF

Return
#------------------------------------------------------------------------------
$PROPAGATE_PRITYP

Return
#------------------------------------------------------------------------------
$PROPAGATE_QTYREF

Return
#------------------------------------------------------------------------------
$PROPAGATE_SAUREF

  Local    Decimal QTYDST
  Local    Decimal COEF

  Call SCAL_QUV(this.QTYREF, this.ITMREF, this.BPCORD, this.SAUREF_OLD, this.SAUREF, QTYDST, COEF) From TRTVENQTE_SYRA

  this.QTYREF     = QTYDST
  this.SAUREF_OLD = this.SAUREF

Return
#------------------------------------------------------------------------------
$CONTROL_PTE

  If this.PTE="" : Return : Endif

  Local Integer WRET
  Local Char    VMESSA(250)

  WRET = func FINDVAT_SYRA.CONTTPT(this.ACTX, this.PTE, this.LEG, this.STOFCY, "", this.CPY, VMESSA)
  If WRET>=[V]CST_AERROR | VMESSA<>""
    If VMESSA=""
      VMESSA = mess(68,123,1) #"SPRICESEARCH Class : CONTROL_PTE error returned by func FINDVAT_SYRA.CONTTPT"
    Endif
    [L]ASTATUS = fmet this.ASETERROR("PTE",VMESSA,WRET)
    Return
  Endif

Return
#------------------------------------------------------------------------------
$PROPAGATE_PTE

  Local File TABPAYTERM [TPT]

  If this.PTE=""
    this.PTE_LEG=""
  Else

    Local Integer WRET

    this.PTE_LEG = "" :#AVOID.ACHAR
    Call LEC_TPT_LEG(this.ACTX, this.LEG, this.PTE, 1, WRET) From TRTLECLEG_SYRA
    If WRET<[V]CST_AERROR
        this.PTE_LEG = [F:TPT]LEG
    Endif
  Endif

  If this.PRICEPARAM(1)<>null and this.PRICEPARAM(1).C_SPKH(1)<>null
    this.PRICEPARAM(1).C_SPKH(1).PTE     = this.PTE
    this.PRICEPARAM(1).C_SPKH(1).PTE_LEG = this.PTE_LEG
  Endif

  LogicClose File [TPT]

Return
#------------------------------------------------------------------------------
$CONTROL_VACBPR

  If this.VACBPR="" : Return : Endif

  Local Integer WRET
  Local Char    VMESSA(250)

  WRET = func FINDVAT_SYRA.CONTTVB(this.ACTX, this.VACBPR, this.LEG, this.STOFCY, "", this.CPY, VMESSA)
  If WRET>=[V]CST_AERROR | VMESSA<>""
    If VMESSA=""
      VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"CONTTVB"
    Endif
    [L]ASTATUS = fmet this.ASETERROR("VACBPR",VMESSA,WRET)
    Return
  Endif

Return
#------------------------------------------------------------------------------
$PROPAGATE_VACBPR

  Local File TABVACBPR [TVB]

  If this.VACBPR=""
    this.VACBPR_LEG=""
  Else

    Local Integer WRET

    this.VACBPR_LEG = "" :#AVOID.ACHAR
    Call LEC_TVB_LEG(this.ACTX, this.LEG, this.VACBPR, WRET) From TRTLECLEG_SYRA
    If WRET<[V]CST_AERROR
        this.VACBPR_LEG = [F:TVB]LEG
    Endif
  Endif

  If this.PRICEPARAM(1)<>null

      this.PRICEPARAM(1).VACBPR     = this.VACBPR
      this.PRICEPARAM(1).VACBPR_LEG = this.VACBPR_LEG

    If this.PRICEPARAM(1).C_SPKH(1)<>null

      this.PRICEPARAM(1).C_SPKH(1).VACBPR     = this.VACBPR
      this.PRICEPARAM(1).C_SPKH(1).VACBPR_LEG = this.VACBPR_LEG

    Endif

  Endif

  LogicClose File [TVB]

Return
#------------------------------------------------------------------------------
$CONTROL_PRICEPARAM_VACBPR

  If this.VACBPR="" : Return : Endif

  Local Integer WRET
  Local Char    VMESSA(250)

  WRET = func FINDVAT_SYRA.CONTTVB(this.ACTX, this.VACBPR, this.APARENT.LEG, this.APARENT.STOFCY, "", "", VMESSA)
  If WRET>=[V]CST_AERROR | VMESSA<>""
    If VMESSA=""
      VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"CONTTVB"
    Endif
    [L]ASTATUS = fmet this.ASETERROR("VACBPR",VMESSA,[V]CST_AWARNING)
    Return
  Endif

Return
#------------------------------------------------------------------------------
$PROPAGATE_PRICEPARAM_VACBPR

  If this.VACBPR="" : this.VACBPR_LEG="" : Return : Endif

  Local File TABVACBPR [TVB]

  Local Integer WRET

  this.VACBPR_LEG = "" :#AVOID.ACHAR
  Call LEC_TVB_LEG(this.ACTX, this.APARENT.LEG, this.VACBPR, WRET) From TRTLECLEG_SYRA
  If WRET<[V]CST_AERROR
      this.VACBPR_LEG = [F:TVB]LEG
  Endif

  LogicClose File [TVB]
Return
#------------------------------------------------------------------------------
$CONTROL_PRICEPARAM_C_SPKH_VACBPR

  If this.VACBPR="" : Return : Endif

  Local Integer WRET
  Local Char    VMESSA(250)

  WRET = func FINDVAT_SYRA.CONTTVB(this.ACTX, this.VACBPR, this.APARENT.APARENT.LEG, this.APARENT.APARENT.STOFCY, "", "", VMESSA)
  If WRET>=[V]CST_AERROR | VMESSA<>""
    If VMESSA=""
      VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"CONTTVB"
    Endif
    [L]ASTATUS = fmet this.ASETERROR("VACBPR",VMESSA,WRET)
    Return
  Endif

Return
#------------------------------------------------------------------------------
$PROPAGATE_PRICEPARAM_C_SPKH_VACBPR

  If this.VACBPR="" : this.VACBPR_LEG="" : Return : Endif

  Local File TABVACBPR [TVB]

  Local Integer WRET

  this.VACBPR_LEG = "" :#AVOID.ACHAR
  Call LEC_TVB_LEG(this.ACTX, this.APARENT.APARENT.LEG, this.VACBPR, WRET) From TRTLECLEG_SYRA
  If WRET<[V]CST_AERROR
      this.VACBPR_LEG = [F:TVB]LEG
  Endif

  LogicClose File [TVB]

Return
#------------------------------------------------------------------------------
$CONTROL_PRICEPARAM_C_SPKH_PTE

  If this.PTE="" : Return : Endif

  Local Integer WRET
  Local Char    VMESSA(250)

  WRET = func FINDVAT_SYRA.CONTTPT(this.ACTX, this.PTE, this.APARENT.APARENT.LEG, this.APARENT.APARENT.STOFCY, "", this.APARENT.APARENT.CPY, VMESSA)
  If WRET>=[V]CST_AERROR | VMESSA<>""
    If VMESSA=""
      VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"CONTTPT"
    Endif
    [L]ASTATUS = fmet this.ASETERROR("PTE",VMESSA,WRET)
    Return
  Endif

Return
#------------------------------------------------------------------------------
$PROPAGATE_PRICEPARAM_C_SPKH_PTE

  If this.PTE="" : this.PTE_LEG="" : Return : Endif

  Local File TABPAYTERM [TPT]

  Local Integer WRET

  this.PTE_LEG = "" :#AVOID.ACHAR
  Call LEC_TPT_LEG(this.ACTX, this.APARENT.APARENT.LEG, this.PTE, 1, WRET) From TRTLECLEG_SYRA
  If WRET<=[V]CST_ASUCCESS
      this.PTE_LEG = [F:TPT]LEG
  Endif

  LogicClose File [TPT]

Return
############################################## Methods ############################################
$CONTROL_INSTANCE

  Local Integer VRET
  Local Char    VMESSA(250)

  #--Because we are still on Edit mode, the global _ACONTROL of the class is not executed
  #--It meens that controls such as mandatory fields are not done (tha _aformat and _aothers control actions are executed, but not _amandatory)
  #--All those have to be done manually

  If this.STOFCY=""
    [L]ASTATUS = fmet this.ASETERROR("STOFCY",mess(10,123,1),[V]CST_AERROR)
    Return
  Endif

  If this.SALFCY=""
    [L]ASTATUS = fmet this.ASETERROR("SALFCY",mess(10,123,1),[V]CST_AERROR)
    Return
  Endif

  If this.BPCORD=""
    [L]ASTATUS = fmet this.ASETERROR("BPCORD",mess(10,123,1),[V]CST_AERROR)
    Return
  Endif

  If this.ITMREF=""
    [L]ASTATUS = fmet this.ASETERROR("ITMREF",mess(10,123,1),[V]CST_AERROR)
    Return
  Endif

  If this.DATEREF=AVOID.ADATE
    [L]ASTATUS = fmet this.ASETERROR("DATEREF",mess(10,123,1),[V]CST_AERROR)
    Return
  Endif

  If this.CURREF=""
    [L]ASTATUS = fmet this.ASETERROR("CURREF",mess(10,123,1),[V]CST_AERROR)
    Return
  Endif

  If this.PRITYP=0
    [L]ASTATUS = fmet this.ASETERROR("PRITYP",mess(10,123,1),[V]CST_AERROR)
    Return
  Endif

  If this.QTYREF<=0
    [L]ASTATUS = fmet this.ASETERROR("QTYREF",mess(10,123,1),[V]CST_AERROR)
    Return
  Endif

  If this.SAUREF=""
    [L]ASTATUS = fmet this.ASETERROR("SAUREF",mess(10,123,1),[V]CST_AERROR)
    Return
  Endif

  Gosub CONTROL_STOFCY
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

  Gosub CONTROL_ITMREF
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

  Gosub CONTROL_PTE
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

  Gosub CONTROL_VACBPR
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

  If this.PRICEPARAM(1)<>null and this.PRICEPARAM(1).C_SPKH(1)<>null

    #--Controlling multiple leg type properties
    If this.PRICEPARAM(1).C_SPKH(1).VACBPR<>""
      Local File TABVACBPR [TVB]

      this.PRICEPARAM(1).C_SPKH(1).VACBPR_LEG = "" :#AVOID.ACHAR
      Call LEC_TVB_LEG(this.ACTX, this.LEG, this.PRICEPARAM(1).C_SPKH(1).VACBPR, [L]VRET) From TRTLECLEG_SYRA
      If [L]VRET<[V]CST_AERROR
        this.PRICEPARAM(1).C_SPKH(1).VACBPR_LEG = [F:TVB]LEG
      Endif

      [L]VRET = func FINDVAT_SYRA.CONTTVB(this.ACTX, this.PRICEPARAM(1).C_SPKH(1).VACBPR, this.LEG, this.STOFCY, "", "", VMESSA)
      If [L]VRET>=[V]CST_AERROR | VMESSA<>""
        If VMESSA=""
          VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"CONTTVB"
        Endif
        [L]ASTATUS = fmet this.ASETERROR("VACBPR",VMESSA,[V]CST_AERROR)
        Return
      Endif

      LogicClose File [TVB]

    Endif

    If this.PRICEPARAM(1).C_SPKH(1).PTE<>""
      Local File TABPAYTERM [TPT]

      this.PRICEPARAM(1).C_SPKH(1).PTE_LEG = "" :#AVOID.ACHAR
      Call LEC_TPT_LEG(this.ACTX, this.LEG, this.PRICEPARAM(1).C_SPKH(1).PTE, 1, [L]VRET) From TRTLECLEG_SYRA
      If [L]VRET<[V]CST_AERROR
        this.PRICEPARAM(1).C_SPKH(1).PTE_LEG = [F:TPT]LEG
      Endif

      [L]VRET = func FINDVAT_SYRA.CONTTPT(this.ACTX, this.PRICEPARAM(1).C_SPKH(1).PTE, this.LEG, this.STOFCY, "", "", VMESSA)
      If [L]VRET>=[V]CST_AERROR | VMESSA<>""
        If VMESSA=""
          VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"CONTTPT"
        Endif
        [L]ASTATUS = fmet this.ASETERROR("PTE",VMESSA,[V]CST_AERROR)
        Return
      Endif

      LogicClose File [TPT]

    Endif

  Endif

  #--Restricted price list search
  If this.PRICEPARAM(1)=null
    VRET = fmet this.ADDLINE("PRICEPARAM",1)
    If VRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("ITMREF", func ASYRFNC.MES2(mess(266,133,1),"PRICEPARAM","SPRICESEARCH"), [V]CST_AERROR)
      Return
    Endif
    VRET = fmet this.PRICEPARAM(1).INITPARAM()
    If VRET>=[V]CST_AERROR
      [L]ASTATUS = fmet this.ASETERROR ("ITMREF", mess(68,123,1)-":"-mess(1,7845,1)-"INITPARAM", [V]CST_AERROR)
      Return
    Endif
  Endif

  [L]VRET = fmet this.PRICEPARAM(1).FINDPRICE_RESTRICTED(this, 1)
  If [L]VRET = [V]CST_AWARNING
    [L]ASTATUS = fmet this.ASETERROR("ITMREF", this.PRICEPARAM(1).AERROR.MES, [L]VRET)
    VRET = fmet this.PRICEPARAM(1).ADELETEERROR("")
    [L]ASTATUS = [V]CST_AERROR :#--If item restricted => no price search
    Return
  Elsif [L]VRET>=[V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR("ITMREF", mess(68,123,1)-":"-mess(1,7845,1)-"FINDPRICE_RESTRICTED", [L]VRET)
    Return
  Else
    VRET = fmet this.ADELETEERROR("ITMREF")
  Endif

Return
#------------------------------------------------------------------------------
$DELETE_ERRORS

Return
#------------------------------------------------------------------------------
$LOAD_DEFAULT

  #--Restricted price list search
  If this.PRICEPARAM(1)=null
    WRET = fmet this.ADDLINE("PRICEPARAM",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("ITMREF", func ASYRFNC.MES2(mess(266,133,1),"PRICEPARAM","SPRICESEARCH"), [V]CST_AERROR)
      Return
    Endif

    WRET = fmet this.PRICEPARAM(1).INITPARAM()
    If WRET>=[V]CST_AERROR
      [L]ASTATUS = fmet this.ASETERROR ("ITMREF", mess(68,123,1)-":"-mess(1,7845,1)-"INITPARAM", [V]CST_AERROR)
      Return
    Endif
  Endif

  this.SALFCY = func CPTDIV_SYRA.FINDAFTSITE(this.ACTX.USER,4,AVOID.ACHAR) :#--5 stands for Sales module # Issue X3-36849 - 2017-05-11 by CPO : (SAM 122869) Price search read only pages TRTPRICE_SYRA
  this.STOFCY= this.SALFCY
  # Issue 112865 - 2016-02-02 by CPO : Default values action in price search
  Local File FACILITY [FCY]
  Local File COMPANY  [CPY]

  Read [F:FCY]FCY0=this.STOFCY
  If fstat : Raz [F:FCY] : Endif
  this.CPY=[F:FCY]LEGCPY

  Read [F:CPY]CPY0=[F:FCY]LEGCPY
  If fstat : Raz [F:CPY] : Endif

  this.PLISTC = [F:CPY]PLISTC
  this.LEG    = [F:CPY]LEG

  LogicClose File [FCY]
  LogicClose File [CPY]

  # End issue 112865
  #this.BPCORD=""

  this.DATEREF = date$
  this.PRITYP  = 1
  this.QTYREF  = 1

  #this.SAUREF  = ""
  #this.ITMREF  = ""

Return
#------------------------------------------------------------------------------
$FINDPRICE
Local Decimal H1,H2

    this.setAccessorEnabled = 0

    #--Emptying existing results
    Gosub RAZ_EXISTING

    #--New instance MYPARAM (not anymore => use of pointer from SPRICESEARCH : PARAMPRICE(1))
    #    Local Instance MYPARAM Using C_SFINDPRICE
    #    MYPARAM = NewInstance C_SFINDPRICE AllocGroup null

    If this.PRICEPARAM(1)=null
      WRET = fmet this.ADDLINE("PRICEPARAM",1)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"PRICEPARAM","SPRICESEARCH"), [V]CST_AERROR)
        [L]ARET_VALUE = [L]ASTATUS
        Return
      Endif
      WRET = fmet this.PRICEPARAM(1).INITPARAM()
      If WRET>=[V]CST_AERROR
        [L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(1,7845,1)-"INITPARAM", [V]CST_AERROR)
        [L]ARET_VALUE = [L]ASTATUS
        Return
      Endif
    Endif

    this.PRICEPARAM(1).setAccessorEnabled = 0

    #--Call to FINDPRICE method
    #--We pass a pointer to the local document
    #  WRET = fmet MYPARAM.FINDPRICE(this)
    WRET = fmet this.PRICEPARAM(1).FINDPRICE(this, 1)
    If WRET>=[V]CST_AERROR
      [L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(2,7845,1)-"FINDPRICE", [V]CST_AERROR)
      Goto END_FINDPRICE
    Endif

    $END_FINDPRICE
    #--We must free the instance (not anymore => use of pointer from SPRICESEARCH : PARAMPRICE(1)
    # FreeGroup MYPARAM
    this.setAccessorEnabled = 1
    this.PRICEPARAM(1).setAccessorEnabled = 1
    [L]ARET_VALUE = [L]ASTATUS

Return
#------------------------------------------------------------------------------
$LOADPARAMFROMDOC
#--MYPARAM => pointer to the class parameters
#Variable Instance MYPARAM Using C_SFINDPRICE
#Value    Integer  INDEXLINE

  Local Integer WRET
  Local Integer WLINE : Raz WLINE
  Local Char    WMESSAGE(250)

  #--AVOID.ACHAR doesn't seem to be always null !!! => issue created...
  Local Char WBID(30)
  Local Char WBIDC1(GLONFCY), WBIDC2(GLONBPR), WBIDC3(GLONBPA)

  Local File ITMMASTER  [ITM]
  Local File COMPANY    [CPY]
  Local File BPCUSTOMER [BPC]
  Local File TABVACBPR  [TVB]
  Local File TABPAYTERM [TPT]
  Local File BPADDRESS  [BPA]
  Local File ACTIV      [ACV]

  Read [F:CPY]CPY0=this.CPY
  If fstat : Raz [F:CPY] : Endif

  Read [F:BPC]BPC0=this.BPCORD
  If fstat : Raz [F:BPC] : Endif

  MYPARAM.setAccessorEnabled = 0

  #MYPARAM.PLI()
  If MYPARAM.PLI(1)=null
    WRET = fmet MYPARAM.ADDLINE("PLI",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"PLI","SFINDPRICE"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif

  #MYPARAM.FMTCOLREM()
  If MYPARAM.FMTCOLREM(1)=null
    WRET = fmet MYPARAM.ADDLINE("FMTCOLREM",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"FMTCOLREM","SFINDPRICE"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif

  #MYPARAM.C_SPKH(1)
  If MYPARAM.C_SPKH(1) = null
    WRET = fmet MYPARAM.ADDLINE("C_SPKH",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_SPKH","SFINDPRICE"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif

  #MYPARAM.C_LINE()
  If MYPARAM.C_LINE(1) = null
    WRET = fmet MYPARAM.ADDLINE("C_LINE",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_LINE","SFINDPRICE"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif

  #MYPARAM.C_LINE(1).C_VAT()
  For WLINE=1 To 3
    If MYPARAM.C_LINE(1).C_VAT(WLINE) = null
      WRET = fmet MYPARAM.C_LINE(1).ADDLINE("C_VAT",WLINE)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_VAT","SFINDPRICE.C_LINE(1)"), [V]CST_AERROR)
        [L]ARET_VALUE = [L]ASTATUS
        Return
      Endif
    Endif
  Next WLINE

  #MYPARAM.C_LINE().C_SPKD()
  If MYPARAM.C_LINE(1).C_SPKD(1) = null
    WRET = fmet MYPARAM.C_LINE(1).ADDLINE("C_SPKD",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_SPKD","SFINDPRICE.C_LINE(1)"), [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  Endif

  #--1) Loading the "header" properties

  	MYPARAM.MODULE    = 5            #--Sales
  	If MYPARAM.TYPRECH = 0           #--Doublon avec PLITYP ????
  	  MYPARAM.TYPRECH   = 1          #--Tarif normal
  	Endif
  	MYPARAM.BPCNUM    = this.BPCORD
    MYPARAM.BPAADD    = this.BPAADD

   #MYPARAM.BPAADD      # if "" => done by the ALICLI call
   #MYPARAM.REP         # done by the ALICLI call
   #MYPARAM.CHGTYP      # done by the ALICLI call
   #MYPARAM.VACBPR      # done by the ALICLI call => has to be loaded by this.VACBPR (available property on the representation)

  	Call ALICLI (1,"C",this.BPCORD, MYPARAM, WRET) From FINDPRICE_SYRA
  	#--Test if errors
  	If fmet MYPARAM.AGETMAXERROR("")>=[V]CST_AERROR or WRET>=[V]CST_AERROR
      [L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(3,7845,1)-"ALICLI", [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif

    MYPARAM.VACBPR     = this.VACBPR
    MYPARAM.VACBPR_LEG = "" #AVOID.ACHAR
    Call LEC_TVB_LEG(this.ACTX, this.LEG, MYPARAM.VACBPR, WRET) From TRTLECLEG_SYRA
    If WRET=0
      MYPARAM.VACBPR_LEG = [F:TVB]LEG
    Endif

    #--Overide by additional informations

    MYPARAM.DOCDAT    = this.DATEREF
    If MYPARAM.DOCDAT = [0/0/0] #AVOID.ADATE
      MYPARAM.DOCDAT  = date$
    Endif
    #MYPARAM.CONVDAT             = [0/0/0] #AVOID.ADATE #--only used for invoices   ?????? Doublon VATCLCDAT (remplacant le PARAM_T(3) )?????
  	MYPARAM.FCY                 = this.STOFCY
  	MYPARAM.PURSALFCY           = this.SALFCY
  	MYPARAM.CPY                 = this.CPY
  	MYPARAM.CUR                 = this.CURREF

    MYPARAM.PIO                 = 0  #AVOID.AINT

  #MYPARAM.C_LED().LED               #--Uniquement pour fact.
  #MYPARAM.C_LED().CURLED            #--Uniquement pour fact.
  #MYPARAM.C_LED().RATDIV            #--Uniquement pour fact.
  #MYPARAM.C_LED().RATMLT            #--Uniquement pour fact.

    MYPARAM.PRITYP    = this.PRITYP
    If MYPARAM.PRITYP = 0
       MYPARAM.PRITYP = 1
    Endif
    If MYPARAM.PLITYP = 0
  	  MYPARAM.PLITYP            = 1       #--Tarif normal
  	Endif
    MYPARAM.MLTDIVCOE           = 0       #AVOID.ADEC #--CPO 26/03/2014
    MYPARAM.VATCLCDAT           = [0/0/0] #AVOID.ADATE
    MYPARAM.MOIS                = 0       #AVOID.AINT #--CPO 26/03/2014
  	MYPARAM.FMTCOLREM(1).BPCBPS = 1
  	MYPARAM.FMTCOLREM(1).PLISTC = this.PLISTC

  # Alimentation concernant les colonnes frais/remise en fonction de la structure tarif de la société
  #--Alimentation également des tableau GPLIxxx contenant les tarifs "compatibles" avec la structure tarifaire de la soc

  #MYPARAM.PLI()
  #MYPARAM.PLI().GDISCRG                      #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.PLI().GPLINBR                      #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.PLI().C_PLI().GPLI                 #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.PLI().C_PLI().GPLICRD              #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.PLI().C_PLI().GPLILIN              #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.PLI().C_PLI().GPLISEA              #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.PLI().C_PLI().GPLITYP              #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.PLI().C_PLI().GPIO                 #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM

  #MYPARAM.FMTCOLREM()
  #MYPARAM.FMTCOLREM().C_FMTCOL().GFMTCOL     #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.FMTCOLREM().C_FMTCOL().GCOLREM     #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.FMTCOLREM().C_FMTCOL().GFMTREM     #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.FMTCOLREM().C_FMTCOL().GFORREM     #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.FMTCOLREM().C_FMTCOL().GINCDCR     #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.FMTCOLREM().C_FMTCOL().GDISCRGTYP  #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.FMTCOLREM().C_FMTCOL().GINVDTALIN  #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.FMTCOLREM().C_FMTCOL().GNPRNOTFLG  #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.FMTCOLREM().C_FMTCOL().GNPRVLTFLG  #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM
  #MYPARAM.FMTCOLREM().C_FMTCOL().GCLCRUL     #--Alimenté par TARIFCHGT From TRTPRICE_SYRA suite Call ALICOLREM

  	WRET = func TRTPRICE_SYRA.ALICOLREM (MYPARAM.FMTCOLREM(1).BPCBPS, this.CURREF, 1, this, MYPARAM.PLI(1), MYPARAM.FMTCOLREM(1), this.PLISTC, WMESSAGE) #From TRTPRICE_SYRA
  	#--Test if errors
  	#If WRET=[V]CST_AOK : WRET = fmet MYPARAM.AGETMAXERROR("") : Endif
  	If WRET >=[V]CST_AERROR
  	  If WMESSAGE=""
  	    WMESSAGE = mess(68,123,1)-":"-mess(2,7845,1)-"ALICOLREM"
  	  Endif
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, WRET)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif
  	MYPARAM.GPLINBR = maxtab(MYPARAM.PLI)

  #---"Header" the former Global variables (replaced by properties with same name => to pinpoint their use)

  #MYPARAM.GTYPGEN          #--uniquement pour les fact.
    MYPARAM.GSPLXGRP   = 0  #AVOID.AINT
  	MYPARAM.GDECRCU    = fmet this.ACTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"DECRCU")
  	MYPARAM.GSYSCUR    = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"SYSCUR")
  	MYPARAM.GLOCALDEV  = [F:CPY]ACCCUR
    MYPARAM.GUPDPRISAL = fmet this.ACTX.APARAM.AGETVALNUM ([V]CST_ALEVFCY,this.STOFCY,"UPDPRISAL")
  	MYPARAM.GPNTITMREF = "" #AVOID.ACHAR
  	MYPARAM.GDECPRI    = func SREPLACEGLOB_SYRA.GET_GDECPRI()
    #--- Recherche du nombre de colonnes actives dans le code activite SPR
    Read [ACV]CODACT="SPR"
    If fstat or [F:ACV]FLACT<>[V]CST_AYES  : Raz [F:ACV] : Endif
    MYPARAM.GDISCRG=[F:ACV]DIME

  #--2) Loading the "header" part of the working table SPRICLINK
  #MYPARAM.C_SPKH()

  	MYPARAM.C_SPKH(1).SOHTYP     = "" #AVOID.ACHAR
  	MYPARAM.C_SPKH(1).SOHTYP_LEG = "" #AVOID.ACHAR
  	MYPARAM.C_SPKH(1).CPY        = this.CPY
  	MYPARAM.C_SPKH(1).SALFCY     = this.SALFCY
  	MYPARAM.C_SPKH(1).EECICT     = this.EECICT

  #--------Call ALICLI (1,"C",this.BPCORD, MYPARAM, WRET) From FINDPRICE_SYRA => called earlier
  #MYPARAM.C_SPKH().BPCINV            # given by the ALICLI call
  #MYPARAM.C_SPKH().BPCGRU            # given by the ALICLI call
  #MYPARAM.C_SPKH().BPTNUM            # given by the ALICLI call
  #MYPARAM.C_SPKH().C_TSCCOD().TSCCOD # given by the ALICLI call

  #MYPARAM.C_SPKH().MDL               # given by the ALICLI call
  #MYPARAM.C_SPKH().PTE               # given by the ALICLI call

    MYPARAM.C_SPKH(1).PTE        = this.PTE
    MYPARAM.C_SPKH(1).PTE_LEG    = "" #AVOID.ACHAR
    Call LEC_TPT_LEG(this.ACTX, this.LEG, MYPARAM.C_SPKH(1).PTE, 1, WRET) From TRTLECLEG_SYRA
    If WRET=0
      MYPARAM.C_SPKH(1).PTE_LEG  = [F:TPT]LEG
      this.PTE_LEG               = [F:TPT]LEG
    Endif

    MYPARAM.C_SPKH(1).MDL        = this.MDL

  	MYPARAM.C_SPKH(1).PJT        = this.PJT
  	MYPARAM.C_SPKH(1).PJTNUM     = func TRTPJT.GET_OPPNUM_FROM_PIMNUM(this.PJT)

  	MYPARAM.C_SPKH(1).STOFCY     = this.STOFCY
    MYPARAM.C_SPKH(1).CUSORDREF  = "" #AVOID.ACHAR
  	MYPARAM.C_SPKH(1).VACBPR     = MYPARAM.VACBPR
  	MYPARAM.C_SPKH(1).VACBPR_LEG = MYPARAM.VACBPR_LEG

  #--Initializing flags between BETCPY / BETFCY
  #MYPARAM.C_SPKH().BETFCY
  #MYPARAM.C_SPKH().BETCPY
  #	Call ALIBETCPY(2,this.SALFCY,this.BPCORD,AVOID.ACHAR,AVOID.ACHAR,AVOID.ACHAR,MYPARAM.C_SPKH(1).BETFCY,MYPARAM.C_SPKH(1).BETCPY) From TRTVENISOC_SYRA
  	Call ALIBETCPY(2,this.SALFCY,this.BPCORD,WBIDC1,WBIDC2,WBIDC3,MYPARAM.C_SPKH(1).BETFCY,MYPARAM.C_SPKH(1).BETCPY) From TRTVENISOC_SYRA
  	#--Test if errors
  	WRET = fmet MYPARAM.AGETMAXERROR("")
  	If WRET >=[V]CST_AERROR
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(3,7845,1)-"ALIBETCPY", WRET)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif

    MYPARAM.C_SPKH(1).PLIBPRCNR = 0 #AVOID.AINT => même dans vintage il n'est pas initialsé
  #MYPARAM.C_SPKH().CRY
  #MYPARAM.C_SPKH().SAT
    # 79705 : V7 : SAT in SPRICLINK
    Gosub DECLARE_CRY_SAT
    WBPCORD=MYPARAM.BPCNUM : WBPAADD=MYPARAM.BPAADD : # Step2
    WDBPAADD=MYPARAM.BPAADD                         : # Step2
    Gosub CHARGE_CRY_SAT
    # 79705 : V7 : SAT in SPRICLINK

  #--3) Loading the "line" properties => those that normaly comes from a document line

  	MYPARAM.NBLIG               = maxtab(MYPARAM.C_LINE)

  	MYPARAM.C_LINE(1).ITMREF    = this.ITMREF
  	MYPARAM.C_LINE(1).STOFCY    = this.STOFCY
  	MYPARAM.C_LINE(1).BPAADD    = MYPARAM.BPAADD
  	MYPARAM.C_LINE(1).QTY       = this.QTYREF
  	MYPARAM.C_LINE(1).SAU       = this.SAUREF
    MYPARAM.C_LINE(1).SAUSTUCOE = 0  #AVOID.ADEC #--CPO 26/03/2014
    MYPARAM.C_LINE(1).GROPRI    = 0  #AVOID.ADEC
    MYPARAM.C_LINE(1).NETPRI    = 0  #AVOID.ADEC

    For WLINE = 1 To maxtab(MYPARAM.C_REP)
      If MYPARAM.C_REP(WLINE)<>null
        If MYPARAM.C_LINE(1).C_REP(WLINE) = null
          WRET = fmet MYPARAM.C_LINE(1).ADDLINE("C_REP", WLINE)
          If WRET = [V]CST_ANOTDEFINED
            [L]ASTATUS = fmet this.ASETERROR("", func ASYRFNC.MES2(mess(266,133,1),"C_REP","SFINDPRICE.C_LINE(1)"),[V]CST_AERROR)
            [L]ARET_VALUE = [L]ASTATUS
            Return
          Endif
        Endif

        MYPARAM.C_LINE(1).C_REP(WLINE).REP = MYPARAM.C_REP(WLINE).REP

      Endif
    Next WLINE

  #MYPARAM.C_LINE().C_VAT().VAT
  #MYPARAM.C_LINE().C_VAT().VAT_LEG

    Local Instance MYVATPARAM Using C_FINDVAT
    MYVATPARAM = NewInstance C_FINDVAT AllocGroup null

    MYVATPARAM.setAccessorEnabled = 0
    #--Initializing taxes using the RECHVATCOD subroutine
    MYVATPARAM.TRAIT = 1
	  WRET = fmet MYVATPARAM.FINDVAT(this)
	  If fmet MYVATPARAM.AGETMAXERROR("")>=[V]CST_AERROR or WRET>=[V]CST_AERROR
      [L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(1,7845,1)-"FINDVAT", [V]CST_AERROR)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif

    FreeGroup MYVATPARAM

    MYPARAM.C_LINE(1).CLCAMT1  = 0  #AVOID.ADEC
    MYPARAM.C_LINE(1).CLCAMT2  = 0  #AVOID.ADEC

    For WLINE = 1 To maxtab(MYPARAM.C_LINE(1).C_DISCRG)
      If MYPARAM.C_LINE(1).C_DISCRG(WLINE)<>null

        MYPARAM.C_LINE(1).C_DISCRG(WLINE).DISCRGVAL  = 0  #AVOID.ADEC
        MYPARAM.C_LINE(1).C_DISCRG(WLINE).DISCRGREN  = 0  #AVOID.AINT

      Endif
    Next WLINE

    MYPARAM.C_LINE(1).PRIREN = 0  #AVODI.AINT
    MYPARAM.C_LINE(1).GRPFLG = 0  #AVOID.AINT
  	MYPARAM.C_LINE(1).CUR = this.CURREF

  #--2) Loading the "line" part of the working table SPRICLINK

   MYPARAM.C_LINE(1).C_SPKD(1).STOFCY  = this.STOFCY

   Read [F:ITM]ITM0=this.ITMREF
   If fstat : Raz [F:ITM] : Endif

   For I = 1 To dim([F:ITM]TSICOD)

     If MYPARAM.C_LINE(1).C_SPKD(1).C_TSICOD(I) = null
       WRET = fmet MYPARAM.C_LINE(1).C_SPKD(1).ADDLINE("C_TSICOD",I)
       If WRET = [V]CST_ANOTDEFINED
         #--The insertion was not possible
         [L]ASTATUS = fmet MYPARAM.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_TSICOD","SFINDPRICE.C_LINE(1).C_SPKD(1)"), [V]CST_AERROR)
         Break
       Endif
     Endif
     MYPARAM.C_LINE(1).C_SPKD(1).C_TSICOD(I).TSICOD = [F:ITM]TSICOD(I-1)
   Next I

   MYPARAM.C_LINE(1).C_SPKD(1).PCK        = "" #AVOID.ACHAR => à vide car PCK est alimenté par INIT_ITM (exp SUBSOHB), mais pas fait dans FUNVENSPSI
   MYPARAM.C_LINE(1).C_SPKD(1).USEPLC     = "" #AVOID.ACHAR
   MYPARAM.C_LINE(1).C_SPKD(1).PNTITMREF  = "" #AVOID.ACHAR
   MYPARAM.C_LINE(1).C_SPKD(1).FOCITM     = 1  #If [M:SOH4]FOCFLG(nolign-1)=3 [F:SPK]FOCITM=2 Else [F:SPK]FOCITM=1 Endif
   MYPARAM.C_LINE(1).C_SPKD(1).CLCAMT1    = MYPARAM.C_LINE(1).CLCAMT1 #0  #AVOID.ADEC
   MYPARAM.C_LINE(1).C_SPKD(1).CLCAMT2    = MYPARAM.C_LINE(1).CLCAMT2 #0  #AVOID.ADEC
   MYPARAM.C_LINE(1).C_SPKD(1).LINTYP     = 0  #AVOID.AINT
   MYPARAM.C_LINE(1).C_SPKD(1).LINTYP_A   = 0  #AVOID.AINT
   MYPARAM.C_LINE(1).C_SPKD(1).LINTYP_B   = 0  #AVOID.AINT
   MYPARAM.C_LINE(1).C_SPKD(1).LINTYP_C   = 0  #AVOID.AINT
   MYPARAM.C_LINE(1).C_SPKD(1).CSTTYP     = 1  #Prix standard par defaut
   MYPARAM.C_LINE(1).C_SPKD(1).CUR        = MYPARAM.C_LINE(1).CUR #this.CURREF
   MYPARAM.C_LINE(1).C_SPKD(1).PJT        = this.PJT
   MYPARAM.C_LINE(1).C_SPKD(1).PJTNUM     = func TRTPJT.GET_OPPNUM_FROM_PIMNUM(this.PJT) : # Code affaire seul

  #--------------To do

  #--2) Loading the "line" part of the working table SPRICLINK

  #MYPARAM.C_LINE(1).C_SPKD(1).C_DIE().DIE => not used in the vintage by the FUNVENSPSI
  #MYPARAM.C_LINE(1).C_SPKD(1).C_DIE().CCE => not used in the vintage by the FUNVENSPSI

  #--------------/

  this.setAccessorEnabled = 1
  [L]ARET_VALUE = [L]ASTATUS
#H2 = arr(freeheap/1024,0.0001)
#Callmet this.ASETERROR ("", "Data Class SPRICESEARCH : LOADPARAMFROMDOC BEGIN Heap="+num$(H1)-"** END Heap="+num$(H2), [V]CST_AINFO)
Return
#------------------------------------------------------------------------------
