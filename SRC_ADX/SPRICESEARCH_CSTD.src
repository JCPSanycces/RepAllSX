#<AdxTL>@(#)0.0.0.0 $Revision$
# Data class SPRICESEARCH
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AINIT"            :         Gosub LOAD_DEFAULT
          When "AREAD"            :         Gosub LOAD_DEFAULT
          When "ACONTROL"         :         Gosub CONTROL_INSTANCE
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
        When "PRICESEARCH_MET"  :
                                          #--Nothing done if already existing errors !!!
                                          #--Call to global control method before doing price search
                                          [L]ASTATUS = fmet this.ACONTROL()
                                          If [L]ASTATUS >=[V]CST_AERROR
                                            #--Emptying existing results
                                            Gosub RAZ_EXISTING
                                            [L]ARET_VALUE = [L]ASTATUS
                                            Return
                                          Endif

                                          Gosub FINDPRICE
                                          #Request succeeded – See results
                                          #Callmet this.ASETERROR ("", "Request succeeded – See results", [V]CST_AINFO)

                                          Return
        When "PRICELIST_MET"    :
                                          #--Nothing done if already existing errors !!!
                                          #--Call to global control method before doing price search
                                          [L]ASTATUS = fmet this.ACONTROL()
                                          If [L]ASTATUS >=[V]CST_AERROR
                                            #--Emptying existing results
                                            Gosub RAZ_EXISTING
                                            [L]ARET_VALUE = [L]ASTATUS
                                            Return
                                          Endif

                                          Gosub FINDPRICELIST

                                          #Request succeeded – See results
                                          #Callmet this.ASETERROR ("", "Request succeeded – See results", [V]CST_AINFO)

                                          Return
        When "LOADPARAMFROMDOC" :
                                          #--Nothing done if already existing errors !!!
                                          If fmet this.AGETMAXERROR("")>=[V]CST_AERROR : Return : Endif

                                          Gosub LOADPARAMFROMDOC
                                          Return
        When "LOADDOCFROMRESULT" :
                                          #--Nothing done if already existing errors !!!
                                          If fmet this.AGETMAXERROR("")>=[V]CST_AERROR : Return : Endif

                                          Gosub LOADDOCFROMRESULT
                                          Return
        When "LOADVATPARAMFROMDOC" :
                                          #--Nothing done if already existing errors !!!
                                          If fmet this.AGETMAXERROR("")>=[V]CST_AERROR : Return : Endif

                                          Gosub LOADVATPARAMFROMDOC
                                          Return
        When "LOADVATRESULTFROMFINDVAT" :
                                          #--Nothing done if already existing errors !!!
                                          If fmet this.AGETMAXERROR("")>=[V]CST_AERROR : Return : Endif

                                          Gosub LOADVATRESULTFROMFINDVAT
                                          Return
        When "LOAD_TECPJT"               :
                                          # Issue X3-49098 - 2017-07-25 by CPO : Search price mobile applications don't display the result
                                          #--Nothing done if already existing errors !!!
                                          If fmet this.AGETMAXERROR("")>=[V]CST_AERROR : Return : Endif

                                          Gosub LOAD_TECPJT
                                          Return
                                          # End issue X3-49098
  Endcase
Return
#--------------------------------------
