#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# Traitement STKMAJI - Librairie des composants de màj stock      V140 #
#                      Inventaire                             MBT 2003 #
########################################################################
# Etiquette appelée par Gosub depuis le STKMAJ
#
# INVENTAIRE    Traitement des entrées en stock
#
#-----------------------------------------------------------------------
# Autres étiquettes appelées par Gosub depuis ce traitement :
#
# MAJENT        Traitement d'une ligne détail d'entrée en stock
# MAJSOR        Traitement d'une ligne détail de sortie de stock
#
########################################################################


###################################
# Traitement des entrées en stock #
###################################
$INVENTAIRE


GPOINT="MAJINVSTR" : Gosub ENTREE From EXEFNC

Raz [L]WITMREF, [L]WANA
[L]WFCY=[M:STW]STOFCY : Gosub CHARG_PARAM From STKMAJ
# hcb 41451   inversion ordre traitement (entrée sortie) par (sortie entrée)

Raz WAMTDEV_ITC
#----- Boucle de traitement des lignes pour les inventaires (sorties) -----#
For I=0 To dim([M:STW]ITMREFLIG)-1
  If [M:STW]ITMREFLIG(I)=""  Break : Endif
  If ([M:STW]QTYSTU(I)<>0 | [M:STW]QTYSTUACT(I)<>0) & [M:STW]MAJTYP(I)="S"
    [L]WMAJTYP="S"
    [L]WMAJCODSTO=[L]WMAJCOD
    Gosub MAJSOR  From STKMAJS : If GOK<1  Break : Endif
    Call AMTDEVITC(2, I, WAMTDEV_ITC) From STKVALMAJ2      # 84744
  Endif
Next I
If GOK<1  Return : Endif
#----- Màj cumuls article-site, ... -----#
Raz [L]WRUPTPREC,   [L]WANA
Gosub MAJ_ITMMVT  From STKMAJ : If GOK<1  Return : Endif

Call MAJPMP(2,WAMTDEV_AVC) From STKVALMAJ2
If GOK<1 : Return : Endif
If WMODLOT<>1
    Call MAJFIFO(2,WAMTDEV_STP) From STKVALMAJ2
    If GOK<1 : Return : Endif
    Raz WAMTDEV_TOT
    For I=0 To GACTVLT2
        For J=0 To dim(WAMTDEV_AVC,2)-1
            WAMTDEV_TOT(I,J) += WAMTDEV_AVC(I,J)+WAMTDEV_STP(I,J)
        Next
    Next
    Call MAJITH(2,WAMTDEV_TOT,WAMTDEV_ITC,WMVTSEQSTR, WCTR_MVTSEQ+1) From STKVALMAJ2
    If GOK<1 : Return : Endif
Endif

Raz WAMTDEV_ITC
#----- Boucle de traitement des lignes pour les inventaires (entrées) -----#
For I=0 To dim([M:STW]ITMREFLIG)-1
  If [M:STW]ITMREFLIG(I)=""  Break : Endif
  If ([M:STW]QTYSTU(I)<>0 | [M:STW]QTYSTUACT(I)<>0) & [M:STW]MAJTYP(I)="E"
    [L]WMAJTYP="E"
    [L]WMAJCODSTO=[L]WMAJCOD
    Gosub MAJENT  From STKMAJE : If GOK<1  Break : Endif
    Call AMTDEVITC(1, I, WAMTDEV_ITC) From STKVALMAJ2      # 84744
  Endif
Next I
If GOK<1  Return : Endif


#----- Màj cumuls article-site, ... -----#
Raz [L]WRUPTPREC,   [L]WANA
Gosub MAJ_ITMMVT  From STKMAJ : If GOK<1  Return : Endif
Call MAJPMP(1,WAMTDEV_AVC) From STKVALMAJ2
If GOK<1 : Return : Endif
Call MAJFIFO(1,WAMTDEV_STP) From STKVALMAJ2
If GOK<1 : Return : Endif
Raz WAMTDEV_TOT
For I=0 To GACTVLT2
    For J=0 To dim(WAMTDEV_AVC,2)-1
        WAMTDEV_TOT(I,J) += WAMTDEV_AVC(I,J)+WAMTDEV_STP(I,J)+WAMTDEV_LOT(I,J)
    Next
Next
Call MAJITH(1,WAMTDEV_TOT,WAMTDEV_ITC,WMVTSEQSTR, WCTR_MVTSEQ+1) From STKVALMAJ2
If GOK<1 : Return : Endif

GPOINT="MAJINVEND" : Gosub ENTREE From EXEFNC


Return

