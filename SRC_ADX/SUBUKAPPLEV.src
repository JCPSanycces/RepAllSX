$ACTION
#Infbox ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "LIENS"       : Gosub LIENS
  When "FILGAUCHE"       : Gosub FILGAUCHE
 When Default
Endcase
Return

$LIENS
Local Integer APPLEVALL
Local Decimal APPLEVAMT, PAYTHR
Local Date DTAXSTR
Local Char PERCODE

DTAXSTR =  func GETCOMPANYTAXSTART([M:UAPPLEV0]CPY)

Filter [CPY] Where CPY = [M:UAPPLEV0]CPY
Read [CPY] First
If !fstat
  If [CPY]LEG = 'BRI'
    Filter [CPYUKI] Where CPY = [M:UAPPLEV0]CPY
    Read [CPYUKI] First
    If !fstat
      [M:UAPPLEV0]PAYTHR = [CPYUKI]PAYTHR
      PAYTHR =  [CPYUKI]PAYTHR
      APPLEVALL =  [CPYUKI]APPLEVALL
      APPLEVAMT = [CPYUKI]APPLEVAMT
    Endif
    Gosub GETCOMPDATA
  Endif
Endif
Filter [CPY]

#Trbegin [F:APPLEV]
#Delete [APPLEV] Where CPY <> '!!!!!!!!!!!!'
#Commit
#If fstat
#  GOK=0 : Call FSTA("APPLEV") From GLOCK
#Endif
#If !GOK : Goto AB_TR1 : Return : Endif

Return



$OUVRE
If clalev([FCY])=0      : Local File FACILITY     [FCY]   : Endif
If clalev([HRCTR])=0    : Local File EMPLOCTR     [HRCTR] : Endif
If clalev([VEP])=0      : Local File VALEMP       [VEP]   : Endif
If clalev([HSP])=0      : Local File HISTOPAYE    [HSP]   : Endif
If clalev([CUAL])=0     : Local File HRCPYUKALL   [CUAL]  : Endif
If clalev([CPYUKI])=0   : Local File HRCOMPANYUKI [CPYUKI]: Endif
If clalev([APPLEV])=0   : Local File UKAPPLEV [APPLEV]    : Endif
If clalev([CPY])=0      : Local File COMPANY [CPY]        : Endif
If clalev([HRPEOD])=0   : Local File HRPEODET [HRPEOD]    : Endif
If clalev([HRPEOH])=0 : Local File HRPEOHEA [HRPEOH]  : Endif
Return

$FILGAUCHE
FILGAUCHE ="[F:CPY]LEG='BRI'"
Return

$GETCOMPDATA
Local Date DTAXSTR
Local Decimal ALLOWANCE
Local Integer APPLEVALL
Local Decimal APPLEVAMT, PAYTHR
Local Date DTAXSTR
Local Char PERCODE

Filter [CPY] Where CPY = [M:UAPPLEV0]CPY
Read [CPY] First
If !fstat
  If [CPY]LEG = 'BRI'
    Filter [CPYUKI] Where CPY = [M:UAPPLEV0]CPY
    Read [CPYUKI] First
    If !fstat
      PAYTHR =  [CPYUKI]PAYTHR
      APPLEVALL =  [CPYUKI]APPLEVALL
      APPLEVAMT = [CPYUKI]APPLEVAMT
    Endif
  Endif
Endif
Filter [CPY]
DTAXSTR =  func GETCOMPANYTAXSTART([M:UAPPLEV0]CPY)

Raz [M:APPLEV1]NBRAPPLEV
Raz [M:APPLEV1]NBRCURLEV
nolign = 1
#MASHI - 2017-12-20 X3-68748 START
#For [APPLEV] Where CPY = [M:UAPPLEV0]CPY and eomonth(PERSTR) >= eomonth(DTAXSTR)  and eomonth(PERSTR) <= eomonth(GMOIPAY)
For [APPLEV] Where CPY = [M:UAPPLEV0]CPY and eomonth(PERSTR) >= eomonth(DTAXSTR)  and eomonth(PERSTR) <= eomonth(GMOIPAY) + 5
#MASHI - 2017-12-20 X3-68748 END

If APPLEVALL <> 2
  Filter [CUAL] Where [F:CUAL]CPY = [M:UAPPLEV0]CPY and [F:CUAL]DAT <= [APPLEV]DAT Order By [F:CUAL]DAT Desc
  Read [CUAL] First
  If !fstat
    ALLOWANCE = [F:CUAL]AMT
  Else
    Local Char TMP_APPANNALL
    Local Decimal APPANNALL
    Call PARAM([M:UAPPLEV0]CPY, "APPANNALL", TMP_APPANNALL) From ADOVAL
    If TMP_APPANNALL = "" Then : TMP_APPANNALL = "0" : Endif
    APPANNALL = val(TMP_APPANNALL)
    ALLOWANCE = APPANNALL
  Endif
  Filter [CUAL]
Else
  ALLOWANCE = APPLEVAMT
Endif
ALLOWANCE = ALLOWANCE / 0.005

#MASHI - 2017-12-20 X3-68748 START
#  If eomonth([F:APPLEV]PERSTR) = eomonth(GMOIPAY)
  If [F:APPLEV]PERSTR = GMOIPAY + 6
#MASHI - 2017-12-20 X3-68748 END
    [M:APPLEV1]CURUPT(0) = [APPLEV]DAT
    [M:APPLEV1]CURNIACTR(0) = [APPLEV]NIACTR
    [M:APPLEV1]CURNIAPTD(0) = [APPLEV]NIAPTD
    #ALHAR - 08-05-2018 X3-89689 - Start
    #If PAYTHR = 2
    #  If [APPLEV]NIAPTD > ALLOWANCE
    #    [M:APPLEV1]CURATD(0) = [APPLEV]ATD
    #    [M:APPLEV1]CURLEVDTD(0) = [APPLEV]LEVDTD
    #    [M:APPLEV1]CURLTP(0) = [APPLEV]LTP
    #    [M:APPLEV1]CURLTD(0) = [APPLEV]LTD
    #  Endif
    #Else
    #ALHAR - 08-05-2018 X3-89689 - End
      [M:APPLEV1]CURATD(0) = [APPLEV]ATD
      [M:APPLEV1]CURLEVDTD(0) = [APPLEV]LEVDTD
      [M:APPLEV1]CURLTP(0) = [APPLEV]LTP
      [M:APPLEV1]CURLTD(0) = [APPLEV]LTD
    #ALHAR - 08-05-2018 X3-89689 - Start
    #Endif
    #ALHAR - 08-05-2018 X3-89689 - End
  Else
    [M:APPLEV1]MTH(nolign-1) = [APPLEV]TAXMON
    [M:APPLEV1]UPT(nolign-1) = [APPLEV]DAT
    [M:APPLEV1]NIACTR(nolign-1) = [APPLEV]NIACTR
    [M:APPLEV1]NIAPTD(nolign-1) = [APPLEV]NIAPTD
    #ALHAR - 08-05-2018 X3-89689 - Start
    #If PAYTHR = 2
    #  If [APPLEV]NIAPTD > ALLOWANCE
    #    [M:APPLEV1]ATD(nolign-1) = [APPLEV]ATD
    #    [M:APPLEV1]LEVDTD(nolign-1) = [APPLEV]LEVDTD
    #    [M:APPLEV1]LTP(nolign-1) = [APPLEV]LTP
    #    [M:APPLEV1]LTD(nolign-1) = [APPLEV]LTD
    #  Endif
    #Else
    #ALHAR - 08-05-2018 X3-89689 - End
      [M:APPLEV1]ATD(nolign-1) = [APPLEV]ATD
      [M:APPLEV1]LEVDTD(nolign-1) = [APPLEV]LEVDTD
      [M:APPLEV1]LTP(nolign-1) = [APPLEV]LTP
      [M:APPLEV1]LTD(nolign-1) = [APPLEV]LTD
    #ALHAR - 08-05-2018 X3-89689 - Start
    #Endif
    #ALHAR - 08-05-2018 X3-89689 - End
    nolign+=1
  Endif
Next


Assign "[M:APPLEV1]NBRCURLEV" With 1
Assign "[M:APPLEV1]NBRAPPLEV" With nolign-1
Affzo [M:APPLEV1]
Return




Subprog CALCCOMPANY(COMPANY)
Variable Char COMPANY
Local Date DTAXSTR, PERSTR, PEREND, PAYDAT
Local Char SITES(GLONFCY)(0..), PERCODE
Local Decimal APPLEVAMT, PAYTHR, MTD, YTD,  CURLEV, ALLOWANCE, ATD
Local Integer APPLEVALL, SITECOUNT, TAXMONTH, J, LTPYTD, SUBLTP, TAXYEAR
# Get tax year start
DTAXSTR =  func GETCOMPANYTAXSTART(COMPANY)
#Delete current gmoipay levy
Trbegin [F:APPLEV]
#MASHI - 2017-12-20 X3-68748 START
#Delete [APPLEV] Where CPY = COMPANY and eomonth(PERSTR) = eomonth(GMOIPAY)
Delete [APPLEV] Where CPY = COMPANY and DAT = eomonth(GMOIPAY) + 5
#MASHI - 2017-12-20 X3-68748 START
Commit
If fstat
  GOK=0 : Call FSTA("APPLEV") From GLOCK
Endif
If !GOK : Goto AB_TR1 : Return : Endif

Call GETCOMPVALUES(COMPANY, PAYTHR, APPLEVALL, APPLEVAMT)

#Get sites from company
#Filter [F:FCY] Where LEGCPY = COMPANY
#For [F:FCY]FCY0
#  SITES(SITECOUNT) = [F:FCY]FCY
#  SITECOUNT +=1
#Next
#Filter [FCY]
#Get percod
#MASHI - 2017-12-20 X3-68748 START
#Filter [HRPEOH] Where [F:HRPEOH]LEG = 'BRI' and [F:HRPEOH]CYCSTRDAT =  DTAXSTR and [F:HRPEOH]FLGENA = 2
#Read [F:HRPEOH] First
#If !fstat
#PERCODE = [F:HRPEOH]PERCOD
#Endif
#Filter [HRPEOH]
#Get current tax month and period start, period end date and pay date from percode and gmoipay
#Filter [HRPEOD] Where [F:HRPEOD]PERCOD = PERCODE and eomonth([F:HRPEOD]PERSTR) <= eomonth(GMOIPAY) Order By [F:HRPEOD]PERSTR Desc
#Read [F:HRPEOD] First
#If !fstat
#  TAXMONTH = [F:HRPEOD]TAXMON
#  PERSTR = [F:HRPEOD]PERSTR
#  PEREND = [F:HRPEOD]PEREND
#  PAYDAT = [F:HRPEOD]PYRDAT
#Endif
#Filter [HRPEOD]
#Build the mtd value for gmoipay
#MTD = func UK_FUNCTIONS.GET_PAYSLIP_VALUES(COMPANY,year(DTAXSTR), TAXMONTH,"NAT_IN_MTD")
PERSTR = GMOIPAY + 6
PAYDAT = eomonth(GMOIPAY) + 5
If GMOIPAY < gdat$(01,04,year(GMOIPAY))
TAXMONTH = month(GMOIPAY) + 9
TAXYEAR = year(GMOIPAY) - 1
Else
TAXMONTH = month(GMOIPAY) - 3
TAXYEAR = year(GMOIPAY)
Endif
#MASHI - 2017-12-22 - X3-69492 START
#MTD = func UK_FUNCTIONS.GET_PAYSLIP_VALUES(COMPANY,year(GMOIPAY), month(GMOIPAY),"NAT_IN_MTD")
MTD = func UK_FUNCTIONS.GET_PAYSLIP_VALUES_DATES(COMPANY,PERSTR, PAYDAT,"NAT_IN_MTD")
#MASHI - 2017-12-22 - X3-69492 END
#MASHI - 2017-12-20 X3-68748 END
#For [VEP]VEP0 Where find([F:VEP]FCY,SITES(0..SITECOUNT-1)) > 0
#  For [HSP] Where BUL = [F:VEP]BUL and TYP=6 and RUB = "NAT_IN_MTD" and [F:HSP]DAT >= PERSTR and [F:HSP]DAT <= PEREND
#    MTD += [F:HSP]AMT
#  Next
#Next
#Get all existing levies for the year
#MASHI - 2017-12-20 X3-68748 START
#For [APPLEV] Where CPY = COMPANY and eomonth(PERSTR) >= eomonth(DTAXSTR)  and eomonth(PERSTR) <= eomonth(GMOIPAY) + 5 and TAXMON <> TAXMONTH
For [APPLEV] Where CPY = COMPANY and eomonth(PERSTR) >= eomonth(DTAXSTR)  and PERSTR <= eomonth(GMOIPAY) + 5 and TAXMON <> TAXMONTH
#MASHI - 2017-12-20 X3-68748 END
  YTD += [APPLEV]NIACTR
  #ATD += [APPLEV]ATD
  LTPYTD += [APPLEV]LTP
Next
#Get the latest allowance value
If APPLEVALL <> 2
#MASHI - 2017-12-20 X3-68748 START
#  Filter [CUAL] Where [F:CUAL]CPY = COMPANY and [F:CUAL]DAT < eomonth(GMOIPAY) Order By [F:CUAL]DAT Desc
  Filter [CUAL] Where [F:CUAL]CPY = COMPANY
#MASHI - 2017-12-20 X3-68748 END
  Read [CUAL] First
  If !fstat
    CURLEV = [F:CUAL]AMT / 12
  Else
    Local Char TMP_APPANNALL
    Local Decimal APPANNALL
    Call PARAM(COMPANY, "APPANNALL", TMP_APPANNALL) From ADOVAL
    If TMP_APPANNALL = "" Then : TMP_APPANNALL = "0" : Endif
    APPANNALL = val(TMP_APPANNALL)
    CURLEV = APPANNALL / 12
  Endif
  Filter [CUAL]
Else
  CURLEV = APPLEVAMT / 12
Endif



##BUILD up the allowance to date from previous months
If TAXMONTH > 1
  J = 1
  While J < TAXMONTH
    If APPLEVALL <> 2
#MASHI - 2017-12-20 X3-68748 START
#      Filter [HRPEOD] Where [F:HRPEOD]PERCOD = PERCODE and TAXMON = J #eomonth([F:HRPEOD]PERSTR) <= eomonth(GMOIPAY) Order By [F:HRPEOD]PERSTR Desc
#      Read [F:HRPEOD] First
#      If !fstat
#        Filter [CUAL] Where [F:CUAL]CPY = COMPANY and [F:CUAL]DAT < [F:HRPEOD]PEREND Order By [F:CUAL]DAT Desc
        Filter [CUAL] Where [F:CUAL]CPY = COMPANY
#MASHI - 2017-12-20 X3-68748 END
        Read [CUAL] First
        If !fstat
          ATD += [F:CUAL]AMT / 12
        Else
          Local Char TMP_APPANNALL
          Local Decimal APPANNALL
          Call PARAM(COMPANY, "APPANNALL", TMP_APPANNALL) From ADOVAL
          If TMP_APPANNALL = "" Then : TMP_APPANNALL = "0" : Endif
          APPANNALL = val(TMP_APPANNALL)
          ATD += APPANNALL / 12
        Endif
        Filter [CUAL]
#MASHI - 2017-12-20 X3-68748 START
#      Endif
#      Filter [HRPEOD]
#MASHI - 2017-12-20 X3-68748 END
    Else
      ATD += APPLEVAMT / 12
    Endif
    J+=1
  Wend
Endif
##
YTD += MTD
ATD += CURLEV
  #ALHAR - 08-05-2018 X3-89689 - Start
  If PAYTHR = 2
    ATD=0
  Endif
  #ALHAR - 08-05-2018 X3-89689 - End
#at this point we have the MTD and YTD values the current levy allowance for this month and the allowance YTD
Trbegin [F:APPLEV]
  [APPLEV]CPY = COMPANY
  [APPLEV]TAXMON = TAXMONTH
  [APPLEV]DAT = PAYDAT
  [APPLEV]PERSTR = PERSTR
  [APPLEV]NIACTR = MTD
  [APPLEV]NIAPTD = YTD
  [APPLEV]LTD = YTD*0.005
  [APPLEV]ATD = arr(ATD,0.01)
  If YTD*0.005 < ATD
  [APPLEV]LEVDTD = 0
  [APPLEV]LTP = 0 - LTPYTD
  Else
  [APPLEV]LEVDTD = YTD*0.005 - ATD
  SUBLTP =  (YTD*0.005 - ATD)
  If YTD > (CURLEV*12/0.005)
  [APPLEV]LTP = SUBLTP
  Else
  [APPLEV]LTP = SUBLTP - LTPYTD
  Endif
  Endif
  Write [APPLEV]
Commit
If fstat
  GOK=0 : Call FSTA("APPLEV") From GLOCK
Endif
If !GOK : Goto AB_TR1 : Return : Endif
End

$AB_TR1
  Rollback
  Call ERREUR(mess (17,107,1)) From GESECRAN :#Rollback suite à une erreur dans la transaction
Return

Subprog APPLEV_CALC()
# If [M:UAPPLEV0]ALLCPY = 1 and [M:UAPPLEV0]CURCPY = 1
