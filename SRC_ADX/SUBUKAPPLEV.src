    #If [M:UAPPLEV0]RECALC = 2
    #  Call DELETECOMPDATE([M:UAPPLEV0]CPY)
    #Endif
      Call CALCCOMPANY([M:UAPPLEV0]CPY)
      Gosub GETCOMPDATA
 Endif
End

Subprog C_CURCPY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Grizo [M:UAPPLEV0]ALLCPY
Else
  Actzo [M:UAPPLEV0]ALLCPY
Endif
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Grizo [M:UAPPLEV0]CURCPY
Else
  Actzo [M:UAPPLEV0]CURCPY
Endif
End

Funprog GETCOMPVALUES(COMPANY, PAYTHR, APPLEVALL, APPLEVAMT)
Variable Char COMPANY
Variable Decimal APPLEVAMT, PAYTHR
Variable Integer APPLEVALL

Filter [CPYUKI] Where CPY = COMPANY
Read [CPYUKI] First
If !fstat
  PAYTHR =  [CPYUKI]PAYTHR
  APPLEVALL =  [CPYUKI]APPLEVALL
  APPLEVAMT = [CPYUKI]APPLEVAMT
Endif
Filter [CPYUKI]
End

Funprog GETCOMPANYTAXSTART(COMPANY)
Variable Char COMPANY
Local Date DTAXSTR
Local Char TMP_TAXSTRDAT

Call PARAM(COMPANY, "TAXSTRDAT", TMP_TAXSTRDAT) From ADOVAL
If TMP_TAXSTRDAT = "" Then : TMP_TAXSTRDAT = "00000000" : Endif
DTAXSTR = gdat$(TMP_TAXSTRDAT)
End DTAXSTR

