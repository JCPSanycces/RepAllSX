If VALEUR<=0
   mkstat=2 : End
Endif

End

########################################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR

Gosub AM_QTYPCU_SCS From ENVADC

End

########################################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
# Issue 110327
Local    Char    LSERF(GLONSER)
Local    Decimal LQTYF
Local    Integer J, WRET, WNBSERIE, PNOL
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER), PABR(GLONABR)


If !clalev([F:STO2])  Local File STOCK  [STO2]  Endif
Raz [M]SERNUMF
If VALEUR="" : Return : Endif
# End issue 110327

If [F:ITM]SERMGTCOD <>4 # Issue 110327
  Read [STO]STO5=[M:XAST]ITMREF;VALEUR
  If fstat
    mkstat=2
  Else
    If dim([M:XAST]LOT)>0    : [M:XAST]LOT=[F:STO]LOT       : Endif
    If dim([M:XAST]SLO)>0    : [M:XAST]SLO=[F:STO]SLO       : Endif
    If dim([M:XAST]PALNUM)>0 : [M:XAST]PALNUM=[F:STO]PALNUM : Endif
    If dim([M:XAST]CTRNUM)>0 : [M:XAST]CTRNUM=[F:STO]CTRNUM : Endif
    [M:XAST]STA=[F:STO]STA
    If [M:XAST]STADES=""     : [M:XAST]STADES=[M:XAST]STA   : Endif
    If dim([M:XAST]LOC)>0    : [M:XAST]LOC=[F:STO]LOC       : Endif
    [M:XAST]PCU       = [F:STO]PCU
    [M:XAST]QTYPCU    = 1
    [M:XAST]PCUSTUCOE = 1
    [M:XAST]PCU       = [F:STO]PCU
    [M:XAST]PCUDES    = [M:XAST]PCU
    [M:XAST]COEDES    = [M:XAST]PCUSTUCOE
    [M:XAST]QTYPCUDES = [M:XAST]QTYPCU
    Affzo [M:XAST]1-99
  Endif
# Issue 110327
Else
# Issue 110327 - 2016-09-02 by MAE : Gestion des numéros de série globaux
  Read [STS]STS0=[M]ITMREF;VALEUR
    If !fstat
       Read [STO2]STO0=[M]STOFCY;[F:STS]STOCOU
       If dim([M:XAST]LOT)>0   : [M:XAST]LOT = [F:STO2]LOT  : Endif
       If dim([M:XAST]SLO)>0   : [M:XAST]SLO = [F:STO2]SLO  : Endif
       If dim([M:XAST]PALNUM)>0 : [M:XAST]PALNUM=[F:STO2]PALNUM : Endif
       If dim([M:XAST]CTRNUM)>0 : [M:XAST]CTRNUM=[F:STO2]CTRNUM : Endif
       If dim([M:XAST]LOC)>0   : [M:XAST]LOC = [F:STO2]LOC  : Endif
       [M:XAST]STA = [F:STO2]STA
       If [M:XAST]STADES=""    : [M:XAST]STADES=[M:XAST]STA : Endif
       [M:XAST]PCU       = [F:STO2]PCU
       [M:XAST]PCUSTUCOE = 1
       [M:XAST]PCUDES    = [M:XAST]PCU
       [M:XAST]COEDES    = [M:XAST]PCUSTUCOE
       [M:XAST]QTYPCUDES = [M:XAST]QTYPCU
      Affzo [M:XAST]1-99
     Endif

  #Détermination numéro de série fin
  # Issue 110327
  If [M:XAST]QTYPCU=1
    [M:XAST]SERNUMF = VALEUR
  Else
    # Vérification que les no série existent et sont disponibles
    # et alimentation du no série fin
    WNBSERIE = [M:XAST]QTYPCU
    WNUMDEB  = VALEUR
    For J=2 To WNBSERIE
       Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
       If WRET=0
          #controle sur le numéro de série fin
          Read [STS]STS0=[M:XAST]ITMREF;WNUMFIN
          If fstat
            GMESSAGE=WNUMFIN-":"-mess(43,196,1) # numéro de série inexistant
            mkstat = 2: Break
          Endif
          If [F:STS]ISSDAT<>[0/0/0]
            GMESSAGE=VALEUR-":"-mess(37,184,1)  # numéro de série sorti par une autre piece
            mkstat=2 : Break
          Endif
          If [F:STS]SDHNUM<>""
            GMESSAGE=VALEUR-":"-mess(443,184,1) # numero de série alloué par une autre piece
            mkstat=2 :  Break
          Endif
          WRET = func STKLIB.REC_STOSERW([M:XAST]ITMREF,WNUMFIN)
          If WRET = 1
            GMESSAGE=WNUMFIN-":"-mess(449,184,1)  # numero de série en cours de traitement
            mkstat=2 : Break
          Endif
          WNUMDEB = WNUMFIN
       Else
          GMESSAGE=WNUMDEB-":"-mess(476,197,1) # erreur sur incrementation des numéros de serie
          mkstat=2 : Break
       Endif
    Next J
    If mkstat=2
      End
    Endif
    [M:XAST]SERNUMF = WNUMFIN
  Endif
Endif
# End issue 110327
End

########################################################
Subprog C_STADES(VALEUR)
Variable Char    VALEUR()

If VALEUR=""
   mkstat=2 : End
Endif

Gosub C_STADES_SCS From ENVADC

End

########################################################
Subprog C_LOCDES(VALEUR)
Variable Char    VALEUR()

# New
If VALEUR=""
   GMESSAGE = mess(10,123,1)
   mkstat = 2 : End
Endif

VALEUR = toupper(VALEUR)
If VALEUR<>[M:SCS1]SCOLOC
   Read [F:STC]STC0=[M:SCS1]STOFCY;VALEUR
   If fstat
      GMESSAGE = mess(125,184,1)
      mkstat=2 : End
   Elsif [F:STC]LOCCAT<>4
      GMESSAGE = mess(244,192,1)
      mkstat=2 : End
   Elsif [F:STC]OCPCOD=3
      GMESSAGE = mess(140,184,1)
      mkstat=2 : End
   Endif
   [M:SCS1]SCOLOCTYP = [F:STC]LOCTYP
   [M:XAST]LOCTYPDES = [F:STC]LOCTYP
Endif

End

# Issue 110327
######################################################################################
## Etiquette ajoutée par le superviseur (écran VXAST) 07/03/2017 10:21:45 (MAE)
######################################################################################
Subprog IB_SERNUM
#si l'article est géré en entrée sortie globale, la sélection sur le numéro de série est particulière
If [F:ITM]SERMGTCOD < 4
  Raz GBOUT2
Else
  Raz GBOUT1
Endif
End
# End issue 110327



