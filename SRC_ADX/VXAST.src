#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Program Name: VXAST
# Description : ADC SubContractor Transfer
# Author      : Deutschbauer/Bromley
# Date        : April 18th, 2006
####################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)

Call SAISIE_CHAR(VALEUR,PARAM,"XAST","XAST","XWVXAST") From GSAISIE
End

########################################################
# Subcontractor transfer - Stock Change
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# STOFCY, FCYDES, ITMREF,
# PCU, QTYPCU, STU, QTYSTUDES, PCUSTUCOE
# STA, LOC, LOT, SLO, PALNUM, CTRNUM, SERNUM, SERNUMF
# STADES, LOCDES, LOCTYPDES
# PCUDES, COEDES, QTYPCUDES
# WSTOSEQ, WLOCSEQ

# Necessary value in Entry transaction
# ------------------------------------
# Field 'Movement type'  --> Supplier
# Field 'Form'           --> No print
#
# VXAST is the VT screen
#
########################################################

########################################################
$ACTION

#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "AVANT_OK"      : Gosub AVANT_OK
 When "OK"            : Gosub OK
 When "BOUTON"        : Gosub BOUTON
 When "END"           : Gosub CHECK
 When "FIN"           : Gosub FIN
Endcase

Return

########################################################
# Actions liées à la fenètre de saisie
########################################################

########################################################
$OUVRE

GVTMOD=1

# Initialisation du site de stock
Gosub INIT_STOFCY From ENVADC
Local Integer TUNNEL            #--- Lot V01
Gosub OUVRE_SCS From ENVADC

Return

########################################################
$DEBUT

Local Integer WOK, WCPT

# GFLAG contains the stock change transaction
GFLAG = func ENVADC.SETTRANS(5)

[M:XAST]SRTNUM = GFLAG

Gosub DEBUT_SCS From ENVADC

Gosub INIT_SCREEN

If GXAFCY=""
   Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN=1 : Return
Endif

Return

########################################################
$SETBOUT

If !find("O",CHBOU) CHBOU+="O" Endif
If !find("1",CHMEN) CHMEN+="1" Endif

Return

########################################################
$APRES_MODIF

Gosub APRES_MODIF_SCS From ENVADC

Return

########################################################
$AVANT_OK

If [M:XAST]ITMREF="" | [M:XAST]PCU="" | [M:XAST]QTYPCU<=0
   GMESSAGE=mess(17,7750,1)
Else
   Gosub AVANT_OK_SCS From ENVADC
   If LRET=1
      GMESSAGE=mess(21,7750,1) # "No stock corresponding to the entry"
   Elsif LRET=2
      GMESSAGE=mess(20,7750,1) # "Quantity greater than the available stock"
   Elsif LRET=3
      GMESSAGE=mess(19,7750,1) # "Stock with quality control"
   Elsif LRET=4
      GMESSAGE=mess(18,7750,1) # "No change: location, status and unit are the same"
   Endif
Endif

If GMESSAGE <> ""
   GERR=1 : FIN=0
   zonsui="[M:XAST]ITMREF" : Return
Endif
Return

########################################################
$OK

Gosub OK_SCS From ENVADC

If LRET<>0
   GERR=1 : GMESSAGE=mess(12,7750,1)
   zonsui="[M:XAST]ITMREF" : Return
Endif

[L]WCPT = [M:XAST]WCPT
Effzo [M:XAST]1-99
[M:XAST]WCPT      = [L]WCPT+1
[M:XAST]STOFCY    = [M:SCS1]STOFCY
[M:XAST]FCYDES    = [M:SCS1]FCYDES
[M:XAST]BPSNUM    = [M:SCS1]BPSNUM
[M:XAST]BPSADD    = [M:SCS1]BPSADD
[M:XAST]LOCDES    = [M:SCS1]SCOLOC
[M:XAST]LOCTYPDES = [M:SCS1]SCOLOCTYP
[M:XAST]SRTNUM = GFLAG
Affzo [M:XAST]1-99

zonsui = "[M:XAST]ITMREF"

Return

########################################################
$BOUTON

# Création
If BOUT="1" Gosub CRE Endif
# Abandon
If BOUT="2" Gosub ABA Endif

Return

########################################################
$ABA
# Issue 110327
If [M:SCS1]NBLIG >0
  Call DELSTOCHGW("SCS1",[M:SCS1]STOFCY,-1,-1,1,LRET) From SUBSCSB
Else
  Call RAZSTOCHGW From SUBSCSB
Endif
# End Issue 110327 - 2016-09-13 by MAE
Gosub INIT_SCREEN
GREP = ""
zonsui = "[M:XAST]BPSNUM"

Return

########################################################
$CRE

# Si article renseigné, enregistrement de la saisie (bouton OK)
If [M:XAST]ITMREF<>""
   Gosub AVANT_OK
   If GERR=1 Return Endif
   Gosub OK
   If GERR=1 Return Endif
Endif

If [M:SCS1]NBLIG=0
   Call ERREUR(mess(17,7750,1)) From GESECRAN
   zonsui="[M:XAST]ITMREF" : Return
Endif

Call CRE_SCS From ENVADC
#--- Lot V01
#-----impression des étiquettes ----#
If [F:SRT]PRNCOD1 = 2
   Call PRINT_ETI(GXAFCY  ,[M:SCS1]VCRTYP,[M:SCS1]VCRNUM) From STKADC
Endif

GPROGRAMME = "GSAISIE"
GBOITE     = BOITE
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From= WINPROG
GREP="" : REP=""
GNOLIG = 0

Gosub INIT_SCREEN

GREP = ""
zonsui = "[M:XAST]BPSNUM"

Return

########################################################
$CHECK

If [M:SCS1]NBLIG<>0
   WOK=1
   # Pièce en cours de saisie non enregistrée
   Call OUINON(mess(38,7750,1),WOK) From GESECRAN
   If WOK<>2
      FIN=0 : zonsui="[M:XAST]ITMREF" : Return
   Endif
Endif

Return
########################################################
$FIN

Gosub FIN_SCS From ENVADC

GVTMOD=0

Return

########################################################
$INIT_SCREEN

Raz [M:SCS1]

# [M:SCS1]IPTDAT contains the date
# [M:SCS1]STOFCY contains the site
# [M:SCS1]DESFCY contains the destination site
[M:SCS1]IPTDAT = date$
[M:SCS1]STOFCY = GXAFCY
[M:SCS1]FCYDES = GXAFCY

Raz [M:XAST]

Gosub INIT_SCS From ENVADC

# Chargement du paramétrage lié au site
If GFCY<>[M:SCS1]STOFCY
   GFCY=[M:SCS1]STOFCY
   Gosub CHARG_PARAM From SUBSCSA
Endif

Affzo [M:XAST]1-99

Return

########################################################
# Actions champs
########################################################

########################################################
Subprog AM_SRTNUM(VALEUR)
Variable Char    VALEUR()

GFLAG = VALEUR
#--- Lot V01
GSCSNUM = VALEUR

[M:SCS1]TRSCOD = [F:SRT]TRSCOD
[M:SCS1]TRSFAM = [F:SRT]TRSFAMDEF
[M:SCS1]ENTCOD = [F:SRT]ENTCOD

End

########################################################
Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR=""
   mkstat=2 : End
Endif

End
##########################################################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()

If [F:BPR]BPRNUM<>VALEUR
   Read [BPR] BPR0=VALEUR
Endif
[M:SCS1]BPSNUM = VALEUR
[M:SCS1]BPSADD = [F:BPR]BPAADD
[M:XAST]BPSADD = [F:BPR]BPAADD
If [F:BPR]BPAADD<>""
   Read [F:BPA]BPA0=1;[M:SCS1]BPSNUM;[M:SCS1]BPSADD
   If fstat
      GMESSAGE=mess(16,199,1)
      mkstat=2 : End
   Endif
   Call SCOLOC([M:SCS1]BPSNUM,[M:SCS1]BPSADD) From SUBSCSB
   [M:XAST]LOCDES    = [M:SCS1]SCOLOC
   [M:XAST]LOCTYPDES = [M:SCS1]SCOLOCTYP
   Affzo [M:XAST]LOCDES
Endif
End

##########################################################################
Subprog C_BPSADD(VALEUR)
Variable Char    VALEUR()

If VALEUR=""
   mkstat=2 : End
Endif

If VALEUR<>[M:SCS1]BPSADD
   Read [F:BPA]BPA0=1;[M:SCS1]BPSNUM;VALEUR
   If fstat
      GMESSAGE=mess(16,199,1)
      mkstat=2 : End
   Endif
   Call SCOLOC([M:SCS1]BPSNUM, VALEUR) From SUBSCSB
   [M:XAST]LOCDES    = [M:SCS1]SCOLOC
   [M:XAST]LOCTYPDES = [M:SCS1]SCOLOCTYP
Endif
If [M:SCS1]SCOLOC="" | VALEUR=""
    Actzo [M:XAST]LOCDES
Else
    Diszo [M:XAST]LOCDES
Endif
Affzo [M:XAST]LOCDES

End

########################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()

If VALEUR=""
   mkstat=2 : End
Endif

End

########################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

[M:XAST]WLOCSEQ=1
Gosub AM_ITMREF_SCS From ENVADC

End

########################################################
Subprog C_STA(VALEUR)
Variable Char    VALEUR()

#If VALEUR="" & [F:ITM]SERMGTCOD<3
#   mkstat=2 : End
#Endif
If [M:XAST]STADES=""
   [M:XAST]STADES=VALEUR
Endif

End

########################################################
Subprog C_LOC(VALEUR)
Variable Char    VALEUR()

#--- Old
#Filter [F:STO] Where STOFCY = GXAFCY and ITMREF = [M:XAST]ITMREF and LOC = VALEUR
#Read [F:STO] First
#If fstat
#    mkstat = 2
#    GMESSAGE = mess(4,8016,1)
#Endif
#Filter [F:STO]

#--- New
If [F:ITF]LOCMGTCOD<>2 End Endif

# Emplacement obligatoire si pas de no série
If VALEUR="" & [F:ITM]SERMGTCOD<3
   mkstat=2 : End
Endif

End

########################################################
Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()

[M:XAST]PCUDES = VALEUR

Gosub AM_PCU_SCS From ENVADC

End

########################################################
Subprog AM_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR

Gosub AM_PCUSTUCOE_SCS From ENVADC

End

########################################################
Subprog C_QTYPCU(VALEUR)
Variable Decimal VALEUR
