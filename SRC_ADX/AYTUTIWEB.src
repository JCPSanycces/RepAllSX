######################################################################################
## Xtend - 
#    Utilitaires pour des sites standards Xtend Superviseur
#
#      Subprog-Funprog
#            AUSLOGIN
#            AUSUPDPJ
######################################################################################

# Gestion d'un login en prenant pour exemple: Code profil X3 = Code profil Xtend
#------------------------------------------------------------#
Subprog AUSLOGIN(AXPARCOD,AXPARVAL,AXUSERCODE,AXPWD,AXUSERPROF,AXLOGCOD,AXLOGVAL,USRCONNECT,ENAFLG,LST, CLBLSTIMP, LSTMANAGER)
Variable Char     AXPARCOD()()
Variable Char     AXPARVAL()()
Variable Char     AXUSERCODE()
Value    Char     AXPWD()
Variable Char     AXUSERPROF()
Variable Char     AXLOGCOD()()   
Variable Char     AXLOGVAL()()
Variable Integer  USRCONNECT
Variable Integer  ENAFLG
Variable Char     LST()()
Variable Clbfile  CLBLSTIMP() 
Variable Char    LSTMANAGER()(0..) 
    

Local Integer OK : OK=1
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif

# on ouvre la table des imprimantes
If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif
# L'appel de ADDMESSERR léve une erreur sur le serveur Web
Read [AUS]LOGIN=toupper(vireblc(AXUSERCODE,0))
If fstat or vireblc(AXUSERCODE,0)=""                # Protection car le reaf renvoit fstat=0 sur clé vide
    Call ADDMESSERR(mess(18,7905,1)) From AWEB
Else
  If [AUS]ENAFLG = 2 and [AUS]USRCONNECT = 2
    Call CTLPAS(vireblc(AXPWD,0), OK) From GESUSER
    If OK
        # Call ADDMESSINF(mess(xx,7905,1)-[AUS]NOMUSR) From AWEB   Pas de message car Ctend peut refuser la cnx via les profils Xtend
        AXUSERPROF=[AUS]PRFFCT
        AXLOGCOD(0)="NOMUSR" : AXLOGVAL(0)=[AUS]NOMUSR       # Prévu de charger dans AUSLOGINF
        AXLOGCOD(1)="TELEP"  : AXLOGVAL(1)=[AUS]TELEP        # Idem
        ENAFLG     = [AUS]ENAFLG                             # Idem

        AXLOGCOD(2)="PRFMEN"  : AXLOGVAL(2)=[AUS]PRFMEN      # Prévu de charger dans ASESSION
        USRCONNECT = [AUS]USRCONNECT                         # Idem

        LST(0)=[AUS]NOMUSR        # Prévu de charger dans AUSLOGINF
        LST(1)=[AUS]TELEP         # Idem
        ENAFLG     = [AUS]ENAFLG                             # Idem
         Raz CLBLSTIMP    
    # on récupère les imprimantes actives   
        For [AIM]AIM0 Where ENAFLG=2                
                #on construit les valeurs...
                CLBLSTIMP+='<option value="' + [F:AIM]COD + '">' + [F:AIM]DES +'</OPTION>'
                
        Next
        Local Integer J : J=0
        For [AUS]CODUSR Where ENAFLG=2                 
                #on construit les valeurs...
                LSTMANAGER(J)='<option value="' + [F:AUS]USR + '">' + [F:AUS]NOMUSR +'</OPTION>'
                J+=1
                If J=dim(LSTMANAGER) Then Break Endif    
        Next

    Else
        Call ADDMESSERR(mess(19,7905,1)) From AWEB
    Endif
  Else
        Call ADDMESSERR(mess(20,7905,1)) From AWEB
  Endif
Endif
End

# Gestion de la maj d'une pièce jointe de type clob pour un utilisateur
#-----------------------------------------------------------------------#
Subprog AUSUPDPJ(RET,MSG,ACTION,USERCODE,ACBLINE, ACBDOCTYP, ACBDOCNAM, ACBDOC)
Variable Integer   RET             # 0: Ok     0<: Erreur 1: Banalisée   1<Erreur typée
Variable Char      MSG()()
Value    Char      ACTION()        # READ, UPD
Value    Char      USERCODE()          # Code utilisateur associé à la PJ
Value    Integer   ACBLINE         
Variable Char      ACBDOCTYP()        # RTF, TXT
Variable Char      ACBDOCNAM()
Variable Clbfile   ACBDOC()

# Exemple ACLOB   Clé: CODBLN,IDENT1,IDENT2,IDENT3   =>     "PJ_AUS","JPJ","","003"
#                 Nom: NAMEBLB => XTRTFDET        Type doc:  TYPDOC => "RTF"
# Voir gestion std GOBJTXT
#

If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
If clalev([F:ACB])=0 : Local File ACLOB    [ACB] : Endif

# Ctls
# - - - - - - - - -
USERCODE = vireblc(USERCODE,0)
If(USERCODE = "") : RET=6 : MSG(0)="Code utilisateur incorrect(USERCODE):"-USERCODE : End : Endif
Read [AUS]LOGIN=toupper(vireblc(USERCODE,0))
If fstat                      : RET=6 : MSG(0)="Code utilisateur incorrect(USERCODE):"-USERCODE: End : Endif
# 
ACTION=vireblc(ACTION,0)
If !find(ACTION,"", "Read","UPD") : RET=2 : MSG(0)="Paramètre Action incorrect(ACTION):"-ACTION : End : Endif
If !(0<ACBLINE and ACBLINE < 1000) 
                              : RET=5 : MSG(0)="N° de ligne invalide(ACBLINE)"-num$(ACBLINE): End : Endif
#
If ACTION="UPD"
    If(ACBDOCNAM="")               : RET=10 : MSG(0)="Nom vide(ACBDOCNAM):"-ACBDOCNAM : End : Endif
    If!find(ACBDOCTYP,"RTF","TXT") : RET=11 : MSG(0)="Type non supporté(ACBDOCTYP)"-ACBDOCTYP: End : Endif
Endif

# Traitement demande
# - - - - - - - - - -
If find(ACTION,"", "Read")
    Read [ACB]ACB0 = "PJ_AUS";USERCODE;"";format$("N0:3#",ACBLINE)
    If fstat 
        RET=100
        MSG(0)="La pièce jointe demandée n'existe pas."
        MSG(1)="Clé: PJ_AUS -"-USERCODE-"-"-num$(ACBLINE)
        End
    Endif
    ACBDOCNAM=[ACB]NAMBLB
    ACBDOCTYP=[ACB]TYPDOC
    ACBDOC   =[ACB]CLOB
Elsif ACTION="UPD"
    Gosub UPDPJ
    If RET : End : Endif
Endif
    
End

$ERR_LINE
RET=999
Resume


# Maj table ACB
# - - - - - - - - -
$UPDPJ
Gosub TR1
If GOK=0 
    RET=100
    MSG(0)="Erreur lors de la mise à jour sur le serveur"
    MSG(1)=GMESSAGE+"xxx"
    GMESSAGE=""
Endif
Return

$TR1
Trbegin [ACB]
  Readlock [ACB]ACB0 = "PJ_AUS";USERCODE;"";format$("N0:3#",ACBLINE)
  If fstat=1
   GOK = -1 : GLOCK = "PJ_AUS~"-USERCODE-"~~"-format$("N0:3#",ACBLINE) : Goto ROLL_TR1
  Elsif fstat
   Raz [F:ACB]
   [F:ACB]CLOB   = ACBDOC
   [F:ACB]TYPDOC = ACBDOCTYP
   [F:ACB]NAMBLB = ACBDOCNAM
   [F:ACB]CODBLB = "PJ_AUS"
   [F:ACB]IDENT1 = USERCODE
   [F:ACB]IDENT2 = ""
   [F:ACB]IDENT3 = format$("N0:3#",ACBLINE)
   If dim([F:ACB]CREUSR)>0 : [F:ACB]CREUSR = GUSER : Endif
   If dim([F:ACB]CREDAT)>0 : [F:ACB]CREDAT = date$ : Endif
   If dim([F:ACB]CRETIM)>0 : [F:ACB]CRETIM = time  : Endif
   Write [ACB]
   If fstat
    GOK = 0 : GLOCK = "$ACLOB"-"PJ_AUS~"-USERCODE-"~~"-format$("N0:3#",ACBLINE): Goto AB_TR1
   Endif
  Elsif !fstat
   [F:ACB]CLOB   = ACBDOC
   [F:ACB]TYPDOC = ACBDOCTYP
   If dim([F:ACB]UPDUSR)>0 : [F:ACB]UPDUSR = GUSER : Endif
If dim([F:ACB]UPDDAT)>0 : [F:ACB]UPDDAT = date$ : Endif
   If dim([F:ACB]UPDTIM)>0 : [F:ACB]UPDTIM = time  : Endif
 Rewrite [ACB]
   If fstat
    GOK = 0 : GLOCK = "$ACLOB"-"PJ_AUS~"-USERCODE-"~~"-format$("N0:3#",ACBLINE)  : Goto AB_TR1
   Endif
  Endif
Commit
Return

$AB_TR1
Rollback 
Return 
 
$ROLL_TR1
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR1 : Endif

