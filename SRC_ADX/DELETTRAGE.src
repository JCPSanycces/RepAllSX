#<AdxTL>@(#)9.0.0.0 $Revision$
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
# 2018-08-28 Bader X3-103717 check activity code KIT before reading parameter
Local Char PARAM(10)(1..10) , VALEUR(10)
PARAM(1)="2"
Call TRAITE_CHAR(VALEUR,PARAM,"","DELETTRAGE","DMTCDELET",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

$OUVRE
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:AGC])=0  : Local File AGRPCPY    [AGC]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:BAL])=0  : Local File BALANCE    [BAL]  : Endif
If clalev([F:MTC])=0  : Local File MATCHCODE  [MTC]  : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif
If clalev([F:BPR])=0  : Local File BPARTNER   [BPR]  : Endif
Return

$INIT
Gosub OUVRE
TMP = 1
Return

$INIT_DIA
If val(PARAM(1))<1 : PARAM(1) = "1" : Endif
[M:DIA]LEDTYP = val(PARAM(1))
Return

$CONTROLE
Return

$SORTIE
Return

$EXEC
Call DELETTRAGE([M:DIA]LEDTYP,[M:DIA]NBSOC,[M:DIA]SOC,[M:DIA]SITE
&              ,[M:DIA]DATDEB,[M:DIA]DATFIN,[M:DIA]TYPLET,[M:DIA]LETDEB,[M:DIA]LETFIN
&              ,[M:DIA]CPTDEB,[M:DIA]CPTFIN,[M:DIA]BPRDEB,[M:DIA]BPRFIN,[M:DIA]PERCLO)
TRA = 1
Return

#############################################################################################################
## Délettrage en masse
#############################################################################################################
Subprog DELETTRAGE(REFERENTIEL,NBSOC,SOCIETE,SIT,DATDEB,DATFIN,TYPLET,LETDEB,LETFIN,CPTDEB,CPTFIN,BPRDEB,BPRFIN,PERCLO)
Value Integer REFERENTIEL
Value Integer NBSOC
Value Char    SOCIETE()(1..)
Value Char    SIT
Value Date    DATDEB
Value Date    DATFIN
Value Integer TYPLET
Value Char    LETDEB
Value Char    LETFIN
Value Char    CPTDEB
Value Char    CPTFIN
Value Char    BPRDEB
Value Char    BPRFIN
Value Integer PERCLO

Local Integer ISOC , OK , FLCPT , OKSOC
Local Char    SOC(GLONCPY) , SITE(GLONFCY) , COMPTE(GLONGAC) , TIERS(GLONBPR) , LETTRE(5)
Local Date    DATMIN , DATMAX
Local Char    CRITERE(250), SYMBOLE(50)
Local Char    PLAN(GLONCOA)
Local Integer ECHEANCES
Local Integer OKDELETTRE

Gosub OUVRE

If !GSERVEUR
 # Ouverture de la trace pour le Délettrage
 Call OUVRE_TRACE(mess(10,110,1)) From LECFIC :
 # Permet d'afficher le masque de saisie avec les différents paramétres
 Call TRACE_MASQUE("DELETTRAGE","DIA",nomap) From GTRAITE
Endif

If SIT=""
 For ISOC=1 To NBSOC
  SOC = SOCIETE(ISOC) : Gosub TRTSOC
 Next
Else
 Call LECTURE("FCY",SIT,"") From CONTOBJ
 SOC = [F:FCY]LEGCPY : Gosub TRTSOC
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
End

$TRTSOC
Call LOCKCPY(SOC,OKSOC) From AX3MONO
If !OKSOC : Return : Endif
Call LECTURE("CPY",SOC,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
If [F:GCM]LED(REFERENTIEL-1)=""
 Return
Endif
Call LECTURE("LED",[F:GCM]LED(REFERENTIEL-1),"") From CONTOBJ
PLAN      = [F:LED]COA
ECHEANCES = (REFERENTIEL=[F:GCM]GENLEDTYP)
If clalev([F:BAL2])<>0 : Close Local File [BAL2] : Endif
If [F:LED]GEN=2
 Local File BALANCE [BAL2]
Else
 Local File BALANA  [BAL2]
Endif
Call PREMEX(SOC,REFERENTIEL,DATMIN) From CPTSUB
Call DEREX(SOC,REFERENTIEL,DATMAX) From CPTSUB
If DATMAX<>[0/0/0] & DATMIN<>[0/0/0]
 If SIT=""
  For [FCY]FCY1 Where LEGCPY=SOC & FINFLG=2
   SITE = [F:FCY]FCY : Gosub TRTSITE
  Next
 Else
  SITE = SIT : Gosub TRTSITE
 Endif
Endif
Call UNLOCKCPY From AX3MONO
Return

$TRTSITE
Call LECTURE("FCY",SITE,"") From CONTOBJ
#KC Vinci Call ECR_TRACE(mess(2,116,1)-SOC-mess(5,116,1)-SITE,0) From GESECRAN
#KC Vinci        Société           Site
If CPTFIN="" : CPTFIN = "zzzzzzzzzz" : Endif
If BPRFIN="" : BPRFIN = "zzzzzzzzzz" : Endif
Call LECTURE("GAC",CPTDEB,PLAN) From CONTOBJ
# GH 04/10/99
# [BAL] remplacé par [BAL2] car le filter provoquait des erreurs en maj de balance via DELPCE
If fstat=0 & [F:GAC]SAC=2
 COMPTE = CPTDEB
 Filter [BAL2] Where LEDTYP=REFERENTIEL & CPY=SOC & FCY=SITE & ACC=CPTDEB & BPR>=BPRDEB & BPR<=BPRFIN
&              Order By Key CLE=BPR
 For [BAL2]CLE(1)
  TIERS = [F:BAL2]BPR : Gosub TRTCOMPTE
 Next
Else
 TIERS = ""
 Filter [BAL2] Where LEDTYP=REFERENTIEL & CPY=SOC & FCY=SITE & ACC>=CPTDEB & ACC<=CPTFIN
&              Order By Key CLE=ACC
 For [BAL2]CLE(1)
  COMPTE = [F:BAL2]ACC : Gosub TRTCOMPTE
 Next
Endif
Filter [BAL2]
#KC Vinci Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Return

$TRTCOMPTE
GPE = 0
GPOINT = "BEFUNMATCH" : Gosub ENTREE From EXEFNC
If GPE : GPE = 0 : Return : Endif
SYMBOLE = "MTC"-SITE-COMPTE-TIERS
Lock =SYMBOLE With lockwait=0
If fstat=1 : Return : Endif
OKDELETTRE = 0
FLCPT = 0
CRITERE  = 'LEDTYP='+num$(REFERENTIEL)
CRITERE -= '& CPY="'+SOC+'"'
CRITERE -= '& FCYLIN="'+SITE+'"'
CRITERE -= '& ACC="'+COMPTE+'"'
CRITERE -= '& BPR="'+TIERS+'"'

If DATDEB<>[0/0/0]
 CRITERE -= '& MTCDAT>=['+format$(GFMD,DATDEB)+']'
Endif
If DATFIN<>[0/0/0]
 CRITERE -= '& MTCDAT<=['+format$(GFMD,DATFIN)+']'
Endif
CRITERE -= "& FLGMTC=0"
Case TYPLET
 When 1
  CRITERE -= '& MTC>="A" & MTC<="ZZZZZ"'
 When 2
  CRITERE -= '& MTC>="a" & MTC<="zzzzz"'
 When Default
  CRITERE -= '& MTC<>""'
Endcase
If LETDEB<>""
 CRITERE -= '& MTC>="'+LETDEB+'"'
Endif
If LETFIN<>""
 CRITERE -= '& MTC<="'+LETFIN+'"'
Endif
# KC Vinci: si écriture sur periode close cochée alors on délettre
# sur période fermée et ouverte sinon on délettre sur période ouverte uniquement
 Filter [DAE] Where evalue(CRITERE)
& Order By Key CLE = CPY;FCYLIN;ACC;BPR;MTC
 For [DAE]CLE(5)
  mkstat = 0
  Call CONTDEV([F:DAE]CUR,[F:DAE]ACCDAT) From TRTDEV
  TIERS=[F:DAE]BPR
  If !mkstat
    #regarder la date MTCDATMIN par rapport à datmin et date max si au moins une sur periode fermée
    # alors ne pas délettrer le groupe si ecriture sur periode close non cochée
    LETTRE = [F:DAE]MTC
    If PERCLO=2 | ([F:DAE]MTCDATMIN>DATMIN & [F:DAE]MTCDATMIN<DATMAX & PERCLO =1)
     Gosub TRACE
     Call DELETTRE_PROP(SOC,SITE,REFERENTIEL,COMPTE,TIERS,LETTRE)
    Endif
  Else
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Raz GMESSAGE
   Endif
 Next
 Filter [DAE]

Unlock =SYMBOLE
If FLCPT
 Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Endif
Return

$TRACE
If FLCPT=0
 FLCPT = 1
 #               Compte
 #KC Vinci Call ECR_TRACE(mess(8,104,1)-mess(REFERENTIEL,2644,1)-COMPTE-TIERS,0) From GESECRAN
 #Ajout ds la trace d'info sur les ECT
 Call ECR_TRACE(mess(53,110,1)-SOC+"/"+SITE+"/"+COMPTE+"/"+TIERS,0) From GESECRAN
Endif
#              Lettre
Call ECR_TRACE(mess(11,110,1)-LETTRE,0) From GESECRAN
Return

###############################################################################
## Délettrage d'un groupe avec propagation sur les autres référentiels
###############################################################################
## Règles de propagation
###############################################################################
## On propage le délettrage si
## - Le référentiel origine est le "principal général" (échéances)
## - Le référentiel destination est lettrable et non automatique
## - Le compte destination est toujours le même et est lettrable
## - Il n'y a qu'une seule et même lettre dans le groupe de destination
###############################################################################
Subprog DELETTRE_PROP(SOC,SITE,REFERENTIEL,COMPTE,TIERS,LETTRE)
Value Char    SOC
Value Char    SITE
Value Integer REFERENTIEL
Value Char    COMPTE
Value Char    TIERS
Value Char    LETTRE

Local File GACCENTRYD [DAE] , GACCENTRYD [DAE2]

If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:ADW])=0  : Local File ADOVAL     [ADW]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif

Local Char    TBCPT(GLONGAC)(1..10) , TBTRS(GLONBPR)(1..10) , TBLET(5)(1..10)
Local Char    VALPAR(10)
Local Integer R

Gosub SET_REFPROP
If NBREF
 For [DAE]DAE1 Where LEDTYP=REFERENTIEL & CPY=SOC & FCYLIN=SITE & ACC=COMPTE & BPR=TIERS & MTC=LETTRE
  For R=1 To NBREF
   For [DAE2] Where LEDTYP=TBREF(R) & TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & IDTLIN=[F:DAE]IDTLIN & MTC<>""
   If TBFLG(R)
     If TBCPT(R)=""
      TBCPT(R) = [F:DAE2]ACC
      TBTRS(R) = [F:DAE2]BPR
      TBLET(R) = [F:DAE2]MTC
     Elsif TBCPT(R)<>[F:DAE2]ACC or TBTRS(R)<>[F:DAE2]BPR or TBLET(R)<>[F:DAE2]MTC
      TBFLG(R) = 0
     Endif
    Endif
   Next
  Next R
 Next
Endif
Call DELETTRE(SOC,SITE,REFERENTIEL,COMPTE,TIERS,LETTRE)
For R=1 To NBREF
 If TBFLG(R)
  Call DELETTRE(SOC,SITE,TBREF(R),TBCPT(R),TBTRS(R),TBLET(R))
  If GTRACE<>""
   #KC Vinci Call ECR_TRACE(space$(10)-mess(TBREF(R),2644,1)-TBCPT(R)-mess(11,110,1)-LETTRE,0) From GESECRAN
  Endif
 Endif
Next R
End

$SET_REFPROP
Local Integer NBREF
Local Integer TBREF(1..10) , TBFLG(1..10)
NBREF = 0
Call LECTURE("CPY",SOC,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
If REFERENTIEL=[F:GCM]GENLEDTYP
 For R=1 To len(mess(0,2644,1))
  If R<>REFERENTIEL & [F:GCM]LED(R-1)<>"" & [F:GCM]CFMAUT(R-1)<>2
   Call LECTURE("LED",[F:GCM]LED(R-1),"") From CONTOBJ
   If [F:LED]MTCFLG=2
    NBREF += 1 : TBREF(NBREF) = R : TBFLG(NBREF) = 1
   Endif
  Endif
 Next R
Endif
Return

####################################################################
## Délettrage d'un groupe
####################################################################
Subprog DELETTRE(SOC,SITE,REFERENTIEL,COMPTE,TIERS,LETTRE)
Value Char    SOC
Value Char    SITE
Value Integer REFERENTIEL
Value Char    COMPTE
Value Char    TIERS
Value Char    LETTRE

If LETTRE = "" : End : Endif : ## <PP 30/07/04> Suite au bug 23894

Local Char SYMBOLE(30)
Local File GACCENTRYD [DAE] , GACCENTRYD [DAE3]
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If GFONCTION="LETTRAGE" or GFONCTION="DELETTRAGE"
 Local File GAJOUSTA [JST]
Endif
Gosub SET_REFAUTO
If adxtrans
 Gosub TR11
Else
 Call DEBTRANS From GLOCK
 Gosub TR1
Endif
End

$TR1
GOK = 1
Trbegin [DAE] , [DUD] : # [HAE], [DAA]
 Gosub TR11
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$TR11
Gosub DELETAUTO
If GOK<1 : Return : Endif
For [DAE]DAE1 Where LEDTYP=REFERENTIEL & CPY=SOC & FCYLIN=SITE & ACC=COMPTE & BPR=TIERS & MTC=LETTRE
 Gosub DELETDAE
 If GOK<1 : Break : Endif
Next : # [DAE]
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

######################################################################################################
## Suppression (ou extourne) des pièces automatiques de lettrage
######################################################################################################
$DELETAUTO
If LETTRE="" : Return : Endif
## The masks are already opened if it's a reversal of a netting journal #A voir avec PP
If !clalev([HAE0])
 Local Mask    GACCENT0 [HAE0], GACCENT1 [HAE1], GACCENT2 [HAE2], VENTILE [VTL], VENTILE2 [VT2]
Endif
Local Char    PARAM(10), MESSA(80), SYMBOLE(50)
Call PARAM("","MTCNBR",PARAM) From ADOVAL
MAXECT = max(1000,val(PARAM))
Local Integer NBPCE , STAT
Local Char    TBPCE(25)(1..MAXECT)

Local File GACCENTRYD [DAE2]
Filter [DAE2] Where LEDTYP=REFERENTIEL & CPY=SOC & FCYLIN=SITE & ACC=COMPTE & BPR=TIERS & MTC=LETTRE

NBPCE = 0
For [DAE2]DAE1
 Call CONTDEV([F:DAE2]CUR,[F:DAE2]ACCDAT) From TRTDEV  :# bug 9665
 If mkstat : GOK = 0 : GERR = 1 : Break : Endif
 If !find([F:DAE2]TYP-[F:DAE2]NUM,TBPCE(1..NBPCE))
  If NBPCE >= MAXECT
   # Paramètre MTCNBR (Nb lignes lettrage) trop petit
   Call ECR_TRACE(mess(42,114,1),1) From GESECRAN
   GOK = 0 : Break
  Endif
  NBPCE += 1
  TBPCE(NBPCE) = [F:DAE2]TYP-[F:DAE2]NUM
  Read [HAE]HAE0 = [F:DAE2]TYP;[F:DAE2]NUM
  If fstat=0 & left$([F:HAE]REFINT,3)="MTC" : # pièce de lettrage auto
   If [F:HAE]STA=2  : # pièce définitive, il faut extourner la pièce et non la supprimer
    Call EXTOURNE([F:HAE]TYP,[F:HAE]NUM,REFERENTIEL,STAT,MESSA)
    If GOK<1 : Break : Endif
    If STAT
     Call ECR_TRACE(MESSA,1) From GESECRAN
     GOK = 0 : Break
    Endif
    [F:HAE]RVS = 3
    [F:HAE]RVSDAT = date$
    Rewrite [HAE]
    If fstat
     GOK=0 : Call FSTA("HAE") From GLOCK : Break
    Endif
   Else : # pièce provisoire : on peut la supprimer (la période est forcément ouverte)
    If GFONCTION="LETTRAGE" or GFONCTION="DELETTRAGE"
     Read [JST]JST0 = [F:HAE]CPY;[F:HAE]JOU
     If fstat | [F:JST]OPGSTRDAT>[F:HAE]ACCDAT | ([F:JST]OPGENDDAT<>[0/0/0] and [F:JST]OPGENDDAT<[F:HAE]ACCDAT)
       Call ECR_TRACE([F:HAE]JOU-mess(92,104,1)-"("+format$("D:"+GFMDAT,[F:HAE]ACCDAT)+")",1) From GESECRAN
       GOK = 0 : Break :  # Journal non ouvert
     Endif
    Endif
    Call DELPCE([F:HAE]TYP,[F:HAE]NUM) From CPTBATCH
    If GOK<1 : Break : Endif
   Endif
  Endif
 Endif
Next
Filter [DAE2]
Return

$DELETDAE
If dim(TOLOCK)<=0 | TOLOCK=1
 SYMBOLE = "HAE"+[F:DAE]NUM+"\"+[F:DAE]TYP
 Lock =SYMBOLE
 If fstat=1 : # Pièce en cours de modification
  If GTRACE<>""
   Call ECR_TRACE("("+[F:DAE]MTC+")"-[F:DAE]TYP-[F:DAE]NUM-mess(12,110,1),1) From GESECRAN
  Else
   GOK=1 : Call ERREURT("("+[F:DAE]MTC+")"-[F:DAE]TYP-[F:DAE]NUM-mess(12,110,1),GOK) From GESECRAN
  Endif
  GOK = 0 : Return
 Endif
Endif
# Ajout dans la trace des infos sur les ECT et formatage
If GTRACE<>""
 Call LEC_TCU([F:DAE]CUR) From CPTLEC
 Call ECR_TRACE (mess(REFERENTIEL,2644,1)-mess(10,110,1)-"("+[F:DAE]MTC+")"-[F:DAE]TYP+space$(5-len([F:DAE]TYP))-
&([F:DAE]NUM+space$(20-len([F:DAE]NUM)))-(num$(format$("N3:"+[F:TCU]CURFMT1,[F:DAE]AMTCUR)))-
&num$([F:DAE]SNS)-[F:DAE]CUR,0) From GESECRAN
Endif

## Verrue Italie
# Issue X3-103717
#If func AFNC.PARAM("ITAMTC",[F:DAE]CPY)="2"
If func AFNC.ACTIV("KIT") and func AFNC.PARAM("ITAMTC",[F:DAE]CPY)="2"
 Call DUDUNLNK From CPTLETIT
Endif
##

GPOINT = "DELETTRAGE" : Gosub ENTREE From EXEFNC

[F:DAE]MTC       = ""
[F:DAE]MTCDAT    = date$
[F:DAE]MTCDATMAX = [0/0/0]
[F:DAE]MTCDATMIN = [0/0/0]
Rewrite [DAE]
If fstat
 GOK=0 : Call FSTA("DAE") From GLOCK : Return
Endif

## Propagation référentiels auto

For R=1 To NBREF
 For [DAE3]DAE7 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & IDTLIN=[F:DAE]IDTLIN & LEDTYP=REFAUTO(R)
  Readlock [DAE3]Curr
  If fstat=1
   GOK = 1 : Call ERREURT("("+[F:DAE]MTC+")"-[F:DAE]TYP-[F:DAE]NUM-mess(12,110,1),GOK) From GESECRAN
   GOK = 0 : Break 2
  Endif
  [F:DAE3]MTC       = ""
  [F:DAE3]MTCDAT    = date$
  [F:DAE3]MTCDATMAX = [0/0/0]
  [F:DAE3]MTCDATMIN = [0/0/0]
  Rewrite [DAE3]
  If fstat
   GOK=0 : Call FSTA("DAE3") From GLOCK : Break 2
  Endif
 Next
Next R
If GOK<=0 : Return : Endif

## Mise à jour échéances

If [F:DAE]BPR<>""
 For [DUD]DUD1 Where ACCNUM=[F:DAE]ACCNUM
  Readlock [DUD] Curr
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE"-num$([F:DUD]ACCNUM)-num$([F:DUD]DUDLIG) : Break
  Endif
  [F:DUD]PAYCUR = 0
  [F:DUD]PAYLOC = 0
  Call SLDECH("DUD")From MODECHE
  Rewrite [DUD]
  If fstat
   GOK=0 : Call FSTA("DUD") From GLOCK : Break
  Endif
  If dim(GHDUFLG)<1
   Call HISTOECH("DUD",1,[F:DAE]ACCDAT)From MODECHE
  Endif
 Next
Endif
Return

## Référentiels automatiques

$SET_REFAUTO
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM    [GCM] : Endif
Local Integer NBREF , REFAUTO(1..10)
Local Integer R
Call LEC_CPY(SOC) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
NBREF = 0
For R=1 To len(mess(0,2644,1))
 If [F:GCM]CFMAUT(R-1)=2 & [F:GCM]ORILEDTYP(R-1)=REFERENTIEL
  NBREF += 1
  REFAUTO(NBREF) = R
 Endif
Next R
Return

#######################################################################
## Délettrage d'une écriture avec propagation sur autres référentiels
#######################################################################
Subprog DELETECR_PROP(NUMERO)
Value Integer NUMERO : # ACCNUM

Local File GACCENTRYD [DAE] , GACCENTRYD [DAE2]

If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:ADW])=0  : Local File ADOVAL     [ADW]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif

Local Char    TBCPT(GLONGAC)(1..10) , TBTRS(GLONBPR)(1..10) , TBLET(5)(1..10)
Local Integer TBNBECR(1..10) , TBNUM(1..10,1..100)
Local Char    VALPAR(10)
Local Integer R , REFERENTIEL
Local Char    SOC(GLONCPY)

Read [DAE]DAE2 = NUMERO
REFERENTIEL = [F:DAE]LEDTYP
SOC = [F:DAE]CPY

Gosub SET_REFPROP
If NBREF
 For R=1 To NBREF
  For [DAE2] Where LEDTYP=TBREF(R) & TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & IDTLIN=[F:DAE]IDTLIN & MTC<>""
   If TBFLG(R)
    If TBCPT(R)=""
     TBCPT(R) = [F:DAE2]ACC
     TBTRS(R) = [F:DAE2]BPR
     TBLET(R) = [F:DAE2]MTC
    Elsif TBCPT(R)<>[F:DAE2]ACC or TBTRS(R)<>[F:DAE2]BPR or TBLET(R)<>[F:DAE2]MTC
     TBFLG(R) = 0
    Endif
    TBNBECR(R) += 1
    TBNUM(R,TBNBECR(R)) = [F:DAE2]ACCNUM
   Endif
  Next
 Next R
Endif
Call DELETECR(NUMERO)
For R=1 To NBREF
 If TBFLG(R)
  For I=1 To TBNBECR(R)
   Call DELETECR(TBNUM(R,I))
  Next I
 Endif
Next R
End

####################################################################
## Délettrage d'une écriture
####################################################################
Subprog DELETECR(NUMERO)
Value Integer NUMERO : # ACCNUM

Local Char    SYMBOLE(30)
Local Char    SOC(GLONCPY) , SITE(GLONFCY) , COMPTE(GLONGAC) , TIERS(GLONBPR) , LETTRE(5)
Local Integer REFERENTIEL

Local File GACCENTRYD [DAE] , GACCENTRYD [DAE3]
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If GFONCTION="LETTRAGE" or GFONCTION="DELETTRAGE"
 Local File GAJOUSTA [JST]
Endif
If adxtrans
 Gosub TR22
Else
 Call DEBTRANS From GLOCK
 Gosub TR2
Endif

End

$TR2
GOK = 1
Trbegin [DAE] , [DUD] : # [HAE] , [DAA]
 Gosub TR22
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$TR22
Readlock [DAE]DAE2 = NUMERO
If fstat=1
 GOK=-1 : GLOCK="$GACCENTRYD"-num$(NUMERO) : Return
Elsif fstat
 Return
Endif
LETTRE      = [F:DAE]MTC
SOC         = [F:DAE]CPY
SITE        = [F:DAE]FCYLIN
COMPTE      = [F:DAE]ACC
TIERS       = [F:DAE]BPR
REFERENTIEL = [F:DAE]LEDTYP
Gosub SET_REFAUTO
Gosub DELETDAE
If GOK<1 : Return : Endif
Gosub DELETAUTO
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

##############################################################################################
## Extourne d'une pièce + lettrage
##############################################################################################
Subprog EXTOURNE(OLDTYP,OLDNUM,REFERENTIEL,STAT,MESSA)
Value    Char    OLDTYP
Value    Char    OLDNUM
Value    Integer REFERENTIEL
Variable Integer STAT
Variable Char    MESSA()

Local Char    IDENT(20)(1..2) , INTREF(20) , CODE(GLONGAU)
Local Char    NEWTYP(GLONGTE) , NEWNUM(GLONVCR)
Local Integer NBLET
Local Integer TBECR(1..100) , TBECH(1..100)
Local Decimal TBIPT(1..100)
#*X3-39795 Local Char    ZONE(10)(1..1)
#*X3-39795 Local Char    VALEUR(50)(1..1)
Local Char    ZONE(10)(1..10)     : # Zones imposées   #*X3-39795
Local Char    VALEUR(50)(1..10)   : # Valeurs imposées #*X3-39795

Read [HAE]HAE0 = OLDTYP;OLDNUM
Call PARAM([F:HAE]FCY,"GAUMTE",CODE) From ADOVAL
If CODE="" : CODE = "MTE" : Endif
IDENT(1)  = OLDTYP
IDENT(2)  = OLDNUM
ZONE(1)   = "REFINT"
VALEUR(1) = [F:HAE]REFINT
#*X3-39795  Manage ORIGIN and ORICOD
ZONE(5)   = "ORIGIN"
VALEUR(5) = "2"
ZONE(6)   = "ORICOD"
VALEUR(6) = CODE
#*X3-39795 END
#*
Call VALPCER3(CODE,IDENT,STAT,MESSA,ZONE,VALEUR) From CPTAUTO
If STAT : End : Endif
NEWTYP = [M:HAE0]TYP
NEWNUM = [M:HAE0]NUM

# Existence of entry points
Local Integer TOLOCK : TOLOCK = 1
Global Integer GCALL_PT : Raz GCALL_PT
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("DELETTRAGE",GENTSTD(1..GNBENTREE))
 GCALL_PT=1
Endif

# Délettrage
Local File GACCENTRYD [DAE]
Local Char    SOC(GLONCPY) : SOC=[F:HAE]CPY
Gosub SET_REFAUTO

# Lettrage des 2 pièces
Local File GACCENTRYD [DAE1] , GACCENTRYD [DAE2]
NBLET = 0

Call SETMAINREF([F:HAE]CPY,GTYPGEN,GTYPANA) From CPTDIV
Link [DAE1] With [GAC]GAC0~=[F:DAE1]COA;[F:DAE1]ACC
& As [LDAE1]
& Where [F:GAC]MTC=2 & LEDTYP=REFERENTIEL & TYP=OLDTYP & NUM=OLDNUM
& Order By Key CLE=ACC;BPR

If GCALL_PT=0
 Columns [LDAE1] ([F:DAE1]ACC,[F:DAE1]BPR,[F:DAE1]ACCNUM,[F:DAE1]AMTCUR)
Endif

For [LDAE1]CLE(2)
 Readlock [DAE]DAE2 = [F:DAE1]ACCNUM
 If fstat=1
  GOK=-1 : GLOCK="$GACCENTRYD"-num$(NUMERO) : Break
 Elsif fstat
  Break
 Endif
 Gosub DELETDAE
 If GOK<1 : Break : Endif
 If TOLOCK=1 : TOLOCK = 0 : Endif
 If [F:DAE1]BPR<>""
  For [LDAE1]CLE
   If REFERENTIEL = GTYPGEN
    # The current CPY & FCY are used by LETDIF
    Columns [DUD] (ACCNUM,DUDLIG,AMTCUR,CPY,FCY)
    For [DUD]DUD1 Where ACCNUM=[F:DAE1]ACCNUM
     NBLET += 1
     TBECR(NBLET) = [F:DUD]ACCNUM
     TBECH(NBLET) = [F:DUD]DUDLIG
     TBIPT(NBLET) = [F:DUD]AMTCUR
    Next
    Columns [DUD]
   Else
    NBLET += 1
    TBECR(NBLET) = [F:DAE1]ACCNUM
    TBIPT(NBLET) = [F:DAE1]AMTCUR
   Endif
  Next
  If REFERENTIEL = GTYPGEN
   Link [DAE2] With [DUD]DUD1(1)=[F:DAE2]ACCNUM
&  As [LDAE2]
&  Where LEDTYP=REFERENTIEL & TYP=NEWTYP & NUM=NEWNUM & ACC=[F:DAE1]ACC & BPR=[F:DAE1]BPR
   # The current CPY & FCY are used by LETDIF
   Columns [LDAE2] ([F:DUD]ACCNUM,[F:DUD]DUDLIG,[F:DUD]AMTCUR,[F:DUD]CPY,[F:DUD]FCY)
   For [LDAE2]
    NBLET += 1
    TBECR(NBLET) = [F:DUD]ACCNUM
    TBECH(NBLET) = [F:DUD]DUDLIG
    TBIPT(NBLET) = [F:DUD]AMTCUR
   Next
   Columns [LDAE2]
  Else
   For [DAE2] Where LEDTYP=REFERENTIEL & TYP=NEWTYP & NUM=NEWNUM & ACC=[F:DAE1]ACC & BPR=[F:DAE1]BPR
    NBLET += 1
    TBECR(NBLET) = [F:DAE2]ACCNUM
    TBIPT(NBLET) = [F:DAE2]AMTCUR
   Next
  Endif
 Else
  For [LDAE1]CLE
   NBLET += 1
   TBECR(NBLET) = [F:DAE1]ACCNUM
   TBIPT(NBLET) = [F:DAE1]AMTCUR
  Next
  For [DAE2] Where LEDTYP=REFERENTIEL & TYP=NEWTYP & NUM=NEWNUM & ACC=[F:DAE1]ACC & BPR=[F:DAE1]BPR
   NBLET += 1
   TBECR(NBLET) = [F:DAE2]ACCNUM
   TBIPT(NBLET) = [F:DAE2]AMTCUR
  Next
 Endif
 GPE = 0
 If GCALL_PT = 1
  GPOINT = "BEFRVSMTC" : Gosub ENTREE From EXEFNC
 Endif
 If !GPE
  Call LETDIF(NBLET,TBECR,TBECH,TBIPT,2) From CPTLET
  If GOK<1 : Break : Endif
 Else
  Raz GPE
 Endif
Next

If GCALL_PT=0
 Columns [LDAE1]
Endif
End

