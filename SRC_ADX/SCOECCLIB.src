##################################
# 107513 (06/2015) : version management in Subcontract orders
##################################

##################################
Subprog AM_ITMREF(VALEUR)
Variable Char VALEUR

Local Integer LALT

If dim([M:SCO0]ECCVALMAJ)>0
    # Issue 110904 - 2016-04-12 by JUSYN : default index for call ECCAFF (third parameter = 0)
    Call ECCAFF(VALEUR,"SCO1",0)
    If func ECCLIB.NBRCPN(VALEUR)
        # ECC preload of major and minor version + BOM code
        LALT = [M:SCO0]BOMALT
        Call INIECCBOM(VALEUR, [M:SCO1]PRHFCY, [M:SCO1]ORDDAT, 3, [M:SCO0]ECCVALMAJ,[M:SCO0]ECCVALMIN,LALT) From MFGECCLIB
        [M:SCO0]BOMALT = LALT
        Affzo [M:SCO0]ECCVALMAJ,ECCVALMIN
        Affzo [M:SCO0]BOMALT
    Endif
Endif

End

##################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()

If  VALEUR=""
& | dim([M:SCO0]ECCVALMAJ)<0
& | [M:SCO0]ECCVALMAJ=""
    End
Endif
If clalev([F:STL])=0 : Local File STOLOT [STL] : Endif
Read [STL]STL0(2)=[M:SCO0]ITMREF;VALEUR
Filter [STL]
If !fstat & !( [F:STL]ECCVALMAJ = [M:SCO0]ECCVALMAJ
&            & [F:STL]ECCVALMIN = [M:SCO0]ECCVALMIN)
    mkstat=2
    GMESSAGE = mess(395,184,1)
Endif

End

##################################
Subprog AP_ECCVAL(NOL)
Value Integer NOL
If func ECCLIB.NBRCPN([M:SCO0]ITMREF)
    #Call HIGHLIGHT("SCO1",-1) From ECCLIB
Endif
End

######################################################################################
# Display or hide version fields in subcontract order context
Subprog ECCAFF(ITM, ABR, IND)
Value Char ITM
Value Char ABR
# Issue 110904/114860 - 2016-04-12 by JUSYN : Index for SCO2
Value Integer IND

If dim([M]ECCVALMAJ)<0 | GIMPORT : End : Endif

Local Integer LACTMAJ, LACTMIN, LACTBOM
Local Integer I
I=func ECCLIB.NBRCPNCST(ITM)

If !I
    LACTMAJ = 0
    LACTMIN = 0
    LACTBOM = 1   # if no version management => BOMALT can be entered

Else
    If I=1
        LACTMAJ = 1
        LACTMIN = 0
    Else
        LACTMAJ = 1
        LACTMIN = 1
    Endif
    LACTBOM=0   # if version management => BOMALT can't be entered
Endif

# It's necessary to define the mask (context of tunnel)
Case ABR
    When "SCO0","SCO1"
         Effzo [M:SCO0]ECCVALMAJ, ECCVALMIN
         Effzo [M:SCO0]BOMALT
         If !LACTMAJ
             Diszo [M:SCO0]ECCVALMAJ
         Else
             Actzo [M:SCO0]ECCVALMAJ
         Endif
         If !LACTMIN
             Diszo [M:SCO0]ECCVALMIN
         Else
             Actzo [M:SCO0]ECCVALMIN
         Endif
         If !LACTBOM
             Diszo [M:SCO0]BOMALT
         Else
             Actzo [M:SCO0]BOMALT
         Endif

    When "SCO2":    # SCO2 & SCM0
         If !LACTMAJ
             Diszo [M:SCO2]ECCVALMAJ(IND)
         Else
             Actzo [M:SCO2]ECCVALMAJ(IND)
         Endif
         If !LACTMIN
             Diszo [M:SCO2]ECCVALMIN(IND)
         Else
             Actzo [M:SCO2]ECCVALMIN(IND)
         Endif
    When "SCM0":    # SCO2 & SCM0
         If !LACTMAJ
             Diszo [M:SCM0]ECCVALMAJ
         Else
             Actzo [M:SCM0]ECCVALMAJ
         Endif
         If !LACTMIN
             Diszo [M:SCM0]ECCVALMIN
         Else
             Actzo [M:SCM0]ECCVALMIN
         Endif
Endcase
End

Subprog CTRECCCPN(PIND)
Value Integer PIND

If dim([M:SCO2]CPNITMREF)>0
  Local Integer WRET
  Local Integer SAVNOLIGN : SAVNOLIGN = nolign
  Local Integer LINDSTR, LINDEND

  If PIND<-1 | PIND>=[M:SCO2]NBLIG | dim([M:SCO2]ECCVALMAJ)<0
      End
  Endif
  If PIND=-1
      LINDSTR = 0
      LINDEND = [M:SCO2]NBLIG-1
  Else
      LINDSTR=PIND
      LINDEND=PIND
  Endif

  For nolign=LINDSTR+1 To LINDEND+1
    Call CTRECC([M:SCO2]CPNITMREF(nolign-1),"SCO2","DLVDAT",[M:SCO2]ECCVALMAJ(nolign-1),[M:SCO2]ECCVALMIN(nolign-1),
&               [M:SCO2]DLVDAT(nolign-1),WRET,[M:SCO2]ECCERRMSG(nolign-1)) From ECCLIB
    If WRET<>[M:SCO2]ECCERRCOD(nolign-1)
        [M:SCO2]ECCERRCOD(nolign-1) = WRET
        Call HIGHLIGHT("SCO2",nolign-1) From ECCLIB
    Endif
  Next
  nolign = SAVNOLIGN
Endif
End

#**----------------------------------------------------------------<br/>
#* INIECCDAT : Return start date of the version if PDAT is outside of the validity period of this version
#**<br/>----------------------------------------------------------------<br/>
#* @param PITM = product managed with version
#* @param PFCY = site (optional)
#* @param PECCMAJ = major version
#* @param PECCMIN = minor version
#* @param PECCTYP = flow type of version  (2=manufacturing, 3=sub-contracting, 4=stock)
#* @param PDAT    = start of validity date
#**<br/>----------------------------------------------------------------
#*!
Subprog INIECCDAT(PITM,PFCY,PECCMAJ,PECCMIN,PECCTYP,PDAT)
Value    Char    PITM
Value    Char    PFCY
Value    Char    PECCMAJ
Value    Char    PECCMIN
Value    Integer PECCTYP
Variable Date    PDAT

Local Date WDATE : WDATE=PDAT

If WDATE=[0/0/0] WDATE=date$ Endif

# existence Major/Minor version for current flow type (= '4' Stock in this case)
If !clalev([F:ECS]) : Local File ECCSTA [ECS] : Endif
If !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif

Link [EVL] With [ECS]ECS0=[EVL]ITMREF;[EVL]ECCVALMAJ
&          As [LNK]
&          Where [EVL]ITMREF=PITM
&              & ([EVL]ECCVALMAJ=PECCMAJ | PECCMAJ="")
&              & ([EVL]ECCVALMIN=PECCMIN | PECCMIN="")
&              & [EVL]ECCTYP=PECCTYP
&              & [EVL]USESTA=2
&              & [F:ECS]ECCSTA<>3
&            Order By EXNFLG;ECCSEQ
For [LNK]
# Issue 111235 - 2016-03-08 by JUSYN : Clarified statements
    If WDATE<[F:EVL]STRDAT
&    | [F:EVL]EXNFLG=1 & WDATE>[F:EVL]ENDDAT
&    | [F:EVL]EXNFLG=2 & [F:EVL]EXNDAT<>[0/0/0] & WDATE>[F:EVL]EXNDAT

        PDAT=[F:EVL]STRDAT

    Endif
    Break
Next

End

#####################################################################
$LIENS
# Issue 107513/US10 GA 06/2015 check version number
If dim([M:SCO0]ECCVALMAJ)>0
  Case func ECCLIB.NBRCPN([M:SCO0]ITMREF)
    When 1: # Major version only
        Actzo [M:SCO0]ECCVALMAJ
        Grizo [M:SCO0]ECCVALMIN
        Grizo [M:SCO0]BOMALT         # if version management => BOMALT can't be entered

    When 2: # Major & minor version
        Actzo [M:SCO0]ECCVALMAJ
        Actzo [M:SCO0]ECCVALMIN
        Grizo [M:SCO0]BOMALT        # if version management => BOMALT can't be entered

    When Default :
        Grizo [M:SCO0]ECCVALMAJ
        Grizo [M:SCO0]ECCVALMIN
        # if no version management => BOMALT can be entered
        Actzo [M:SCO0]BOMALT
  Endcase
Endif
Return

