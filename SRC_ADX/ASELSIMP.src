#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char VALEUR(250) , NOEUD(250) , FILTRE(250)
NOEUD = 'component.report.servername~report.service.printport'
FILTRE = 'family="REPORT"'
Call RECH_NOEUD_SOL("",NOEUD,FILTRE,VALEUR)
Infbox VALEUR
End

#------------------------------------------------------------------------------------#
#  Sûˋlection Imprimante et serveur d'impression utilisable en C/S et en Web
#  ContrûÇle imprimante et serveur d'impression
#------------------------------------------------------------------------------------#

$ACTION:
Case ACTION
 When "SEL_LISTE"
     Case LISTE
        When "SELSERV"  : Gosub SELSERV
        When "SELIMPRI" : Gosub SELIMPRI
        When "SELLAND"  : Gosub SELLAND
        When "SELSPG"   : Gosub SELSPG
        When "SELTRN"   : Gosub SELTRN
     Endcase
 When "VERF_LISTE"
     Case LISTE
        When "SELIMPRI" : Gosub VERF_IMP
     Endcase
 When "TRT_DIV"
     If    GACTION="CONTSERV"  or TRAIT="CONTSERV"  : Gosub CONTSERV
     Elsif GACTION="CONTIMPRI" or TRAIT="CONTIMPRI" : Gosub CONTIMPRI
     Elsif GACTION="INISRV"    or TRAIT="INISRV"    : Gosub INISRV
     Endif
 When Default
Endcase
Return

#------------------------------------------------------------------------------------#
## Sûˋlection d'une imprimante et retour des caractûˋristiques
#------------------------------------------------------------------------------------#

$SELIMPRI
Local Char    PARAMETRE(250)(1..200)
Local Integer I , J , K , NBIMP , NBPAR
Local Char    PR_SERVEUR(250)
Local Char    ID_SERVEUR(250)

If PARAM(1)=""
 PR_SERVEUR = "" : # PrinterServer
 ID_SERVEUR = "" : # ID Serveur (avec @)
Else
 If right$(PARAM(1),len(PARAM(1)))<>"@"
  ID_SERVEUR = PARAM(1)+"@"
 Else
  ID_SERVEUR = PARAM(1)
 Endif
 PR_SERVEUR = left$(ID_SERVEUR,len(ID_SERVEUR)-1)
Endif

# Listimp est implûˋmentûˋe pour le WEB et permet de retourner une liste d'imprimantes dûˋclarûˋes sur un compte utilisateur
# Ce compte est soit celui qui demarrûˋ le service d'impression dans le cas d'un serveur ou soit l'utilisateur courant du PC
# Selimp est utilisûˋ en WEB avec novisible=1 pour remonter les caractûˋristiques d'une imprimante
# ou en C/S pour la mûˆme raison, mais si novisible=0, permet de retourner auparavant la liste des imprimantes d'un utilisateur

If GBROWS & GFUSION=0
 Listimp PARAMETRE=ID_SERVEUR
 K = instr(1,PARAMETRE(1),chr$(1))
 NBIMP = val(num$(ascii(mid$(PARAMETRE(1),K+1,1))))
 Raz TEXTE,TEX,NBTEX
 For I=1 To NBIMP
  K = instr(1,PARAMETRE(I+1),chr$(1))
  NBTEX += 1
  TEXTE(NBTEX) = mid$(PARAMETRE(I+1),K+1,len(PARAMETRE(I+1)))
  TEX(NBTEX) = TEXTE(NBTEX)
  If I>=min(dim(PARAMETRE)-1,dim(TEXTE)) : Break : Endif
 Next I
 TIT = mess(86,150,1) : # Liste des imprimantes vues par le serveur d'impression
Else
 Gosub GET_PARIMP
 If PR_SERVEUR<>""
  If adxusr='' : Call SELIMP_TRACE("Call SELIMPRI.1","",PARAMETRE,"_PrinterServer="+PR_SERVEUR) : Endif
  Selimp PARAMETRE="" With PARAMETRE(1..NBPAR) , "_PrinterServer="+chr$(1)+PR_SERVEUR
 Else
  If adxusr='' : Call SELIMP_TRACE("Call SELIMPRI.2","",PARAMETRE,"") : Endif
  Selimp PARAMETRE="" With PARAMETRE(1..NBPAR)
 Endif
 #NBPAR = stat1 : # To control before calling SELIMP_TRACE - RBU - 103289 - 20150526
 #RBU If adxusr='' : Call SELIMP_TRACE("SELIMPRI return","",PARAMETRE,"") : Endif
 Call SELIMP_TRACE("SELIMPRI return","",PARAMETRE,"")
 Gosub SET_PARIMP
Endif
Return

#----------------------------#
$GET_PARIMP
Local Char    DESCRIPT(255)
Local Integer I

PARAM(10) = func SET_MODIFIED(PARAM(1),PARAM)

NBPAR = 0
NBPAR += 1 : PARAMETRE(NBPAR) = "_PrinterName="+chr$(1)+VALEUR
If PARAM(2)<>""
 NBPAR += 1
 PARAMETRE(NBPAR) = "_PrinterPort="+chr$(1)+PARAM(2)
Endif
If PARAM(3)<>""
 NBPAR += 1
 PARAMETRE(NBPAR) = "_PrinterDriver="+chr$(1)+PARAM(3)
Endif
If GFUSION
 NBPAR += 1 : PARAMETRE(NBPAR) = "_PrtDescDiscrete="+chr$(1)+"1"
Endif
Gosub  CLEAN_PARAM_4
If PARAM(4)<>""
 For I=0 To evalue("dim("+PARAM(4)+")")-1
  DESCRIPT = evalue(PARAM(4)+"("+num$(I)+")")
  If DESCRIPT<>""
   NBPAR += 1
   If GFUSION
    PARAMETRE(NBPAR) = "_PrinterDescriptionEx="+chr$(I+1)+DESCRIPT
   Else
    PARAMETRE(NBPAR) = "_PrinterDescription="+chr$(I+1)+DESCRIPT
   Endif
  Endif
 Next I
Endif
If len(PARAM(5)) and val(PARAM(5)) > 0
 NBPAR += 1 : PARAMETRE(NBPAR) = "_PrinterCopies="+chr$(1)+num$(val(PARAM(5)))
Endif

NBPAR += 1 : PARAMETRE(NBPAR) = "_PrinterCollate="+chr$(1)+num$(len(PARAM(6)) and val(PARAM(6)) =2)
If len(PARAM(7)) and val(PARAM(7)) > 0
 NBPAR += 1 : PARAMETRE(NBPAR) = "_PrinterStartPage="+chr$(1)+num$(val(PARAM(7)))
Endif
If len(PARAM(7)) and val(PARAM(8)) > 0
 NBPAR += 1 : PARAMETRE(NBPAR) = "_PrinterStopPage="+chr$(1)+num$(val(PARAM(8)))
Endif
NBPAR += 1 : PARAMETRE(NBPAR) = "_Orientation="+chr$(1)+num$(len(PARAM(9)) and val(PARAM(9)) =2)
Return

#----------------------------#
$SET_PARIMP
Local Integer I , J , K
Local Char PARAM10(250)

Gosub  CLEAN_PARAM_4

For J=1 To evalue("dim("+PARAM(4)+")")
 Assign PARAM(4)+"("+num$(J-1)+")" With ""
Next J
### Cas ou on on a "Etendue de page û  TOUT"
PARAM(7) = ""
PARAM(8) = ""
#SAM 108871 For I=1 To min(NBPAR,dim(PARAMETRE)) NBPAR ?
For I=1 To dim(PARAMETRE)
 K = instr(1,PARAMETRE(I),"=")
 If K
  Case left$(PARAMETRE(I),K-1)
   When "_PrinterName"        :  VALEUR    = right$(PARAMETRE(I),K+2)
   When "_PrinterPort"        :     PARAM(2) = right$(PARAMETRE(I),K+2)
   When "_PrinterDriver"      :    PARAM(3) = right$(PARAMETRE(I),K+2)
   When "_PrinterCopies"      :   PARAM(5) = right$(PARAMETRE(I),K+2)
   When "_PrinterCollate"     :    PARAM(6) = num$(val(right$(PARAMETRE(I),K+2))+1):#boolean
   When "_PrinterStartPage"   :  PARAM(7) = num$(val(right$(PARAMETRE(I),K+2)))
   When "_PrinterStopPage"    : PARAM(8) = num$(val(right$(PARAMETRE(I),K+2)))
   #SAM 108871
   When "_Orientation"    :         PARAM(9) = num$(val(right$(PARAMETRE(I),K+2))+1) :#boolean
   When "_PrinterDescription","_PrinterDescriptionEx"
    J = ascii(mid$(PARAMETRE(I),K+1,1))
    If J<=evalue("dim("+PARAM(4)+")")
     Assign PARAM(4)+"("+num$(J-1)+")" With right$(PARAMETRE(I),K+2)
    Endif
  Endcase
 Endif
Next I

PARAM10  = func SET_MODIFIED(VALEUR,PARAM)
If PARAM10 = PARAM(10)
 PARAM(10) = "1":#oui
Else
 PARAM(10) = "2" :#non
Endif
Return

#----------------------------#
$VERF_IMP
If ID_SERVEUR<>""
 If adxusr='' : Call SELIMP_TRACE("Call VERF_IMP",ID_SERVEUR,PARAMETRE,"_PrinterName="+VALEUR) : Endif
 Selimp PARAMETRE=ID_SERVEUR With PARAMETRE(1..NBPAR),"_PrinterName="+chr$(1)+VALEUR
 # NBPAR = stat1 : # To control before calling SELIMP_TRACE - RBU - 103289 - 20150526
 If adxusr='' : Call SELIMP_TRACE("VERF_IMP return",ID_SERVEUR,PARAMETRE,"") : Endif
 Gosub SET_PARIMP
Endif
Return

#----------------------------#
$DEBUG
Call OUVRE_TRACE(mess(174,100,1)) From LECFIC : # Paramû´tres
For I=1 To NBPAR
 Call ECR_TRACE("|"+PARAMETRE(I),0) From GESECRAN
Next I
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Return

#---------------------------------------------------------------------------------#
## ContrûÇle imprimante et retour des caractûˋristiques
#---------------------------------------------------------------------------------#

$CONTIMPRI
Local Char    PARAMETRE(250)(1..150)
Local Integer NBPAR , ERRS
Local Char    PR_SERVEUR(250)
Local Char    ID_SERVEUR(250)

If PARAM(1)=""
 PR_SERVEUR = "" : # PrinterServer
 ID_SERVEUR = "" : # ID Serveur (avec @)
Else
 If right$(PARAM(1),len(PARAM(1)))<>"@"
  ID_SERVEUR = PARAM(1)+"@"
 Else
  ID_SERVEUR = PARAM(1)
 Endif
 PR_SERVEUR = left$(ID_SERVEUR,len(ID_SERVEUR)-1)
Endif

If VALEUR="" : Return : Endif  : # Pas d'imprimante sûˋlectionnûˋe
If GBROWS<>0 and ID_SERVEUR="" : # En Web le serveur d'impression doit ûˆtre renseignûˋ
 GMESSAGE = mess(90,150,1)     : # Le serveur d'impression doit ûˆtre renseignûˋ
 mkstat = 2 : Return
Endif

Gosub GET_PARIMP

Onerrgo ERRIMPRI
ERRS = 0
If ID_SERVEUR<>""
 If adxusr='' : Call SELIMP_TRACE("call CONTIMPRI.1", ID_SERVEUR,PARAMETRE,"_NoVisible=1") : Endif
 Selimp PARAMETRE=ID_SERVEUR With PARAMETRE(1..NBPAR) , "_NoVisible="+chr$(1)+"1"
Else
 If adxusr='' : Call SELIMP_TRACE("call CONTIMPRI.2","",PARAMETRE,"_NoVisible=1") : Endif
 Selimp PARAMETRE="" With PARAMETRE(1..NBPAR) , "_NoVisible="+chr$(1)+"1"
Endif
Onerrgo
#NBPAR = stat1 : # To control before calling SELIMP_TRACE - RBU - 103289 - 20150526
If adxusr='' : Call SELIMP_TRACE("CONTIMPRI return","",PARAMETRE,"") : Endif
If ERRS                      # | NBPAR=0 - RBU - 103289 - 20150526
 GMESSAGE = mess(91,150,1) : # Imprimante non disponible
 mkstat = 2
Else
 Gosub SET_PARIMP
Endif
Return

$ERRIMPRI
ERRS = 1
Resume

#---------------------------------------------------------------------------------------#
# Recherche les noms des serveurs d'impression associûˋs û  la solution
# en lisant le fichier SOLUTION.xml
#---------------------------------------------------------------------------------------#

$SELSERV
Local Char NOEUD(250) , FILTRE(250) , RETOUR(250)(1..20) , SERVEUR(250)
Local Char TEXTE(80)(1..GNBSEL,1..2) , TEX(80)(1..GNBSEL) , TIT(80)(0..2)
Local Integer NORET , TILDE , NBTEX
TIT = mess(95,150,1) : # Liste des serveurs
TIT(1) = mess(21,151,1) : # Serveur
TIT(2) = mess(238,139,1) : # Port
NOEUD = 'component.report.servername~report.service.printport'
FILTRE = 'family="REPORT"'
Call RECH_NOEUD_SOL("",NOEUD,FILTRE,RETOUR)
Raz TEXTE , NBTEX
For NORET=1 To dim(RETOUR)
 If RETOUR(NORET)=""
  Break
 Endif
 TILDE = instr(1,RETOUR(NORET),"~")
 If TILDE
  SERVEUR = left$(RETOUR(NORET),TILDE-1)+":"+right$(RETOUR(NORET),TILDE+1)+"@"
  Gosub CONTSERI1
  If ERRS=0
   NBTEX += 1
   TEXTE(NBTEX,1) = left$(RETOUR(NORET),TILDE-1)
   TEXTE(NBTEX,2) = right$(RETOUR(NORET),TILDE+1)
   TEX(NBTEX) = left$(RETOUR(NORET),TILDE-1)+":"+right$(RETOUR(NORET),TILDE+1)
  Endif
 Endif
 If dim(SELONESERV)>0 and NBTEX>=1 : Break 1 : Endif
Next I
Return

#---------------------------------------------------------------------------------#
# Recherche du serveur d'impression par dûˋfaut
#---------------------------------------------------------------------------------#

$INISRV
If GBROWS=0 : Return : Endif
Local Integer NBIMPS,IIMPS
If dim(GSERIMP)>0 and GSERIMP<>""
  VALEUR = GSERIMP
  SERVEUR=VALEUR
  Gosub CONTSERI1
  If ERRS=1 : VALEUR="" : Endif
Endif

# Controle de la valeur d'initialisation
If VALEUR = ""
  Local Integer SELONESERV : Gosub SELSERV
  If NBTEX >=1 : VALEUR=TEX(1) : Endif
Endif
Return

$ERRSERVL
ERRS=1
Resume

$CONTSERI1
Local Char CHTEST(250),PARID(250)(1..10)
Local Integer ERRS,K
If SERVEUR="" : ERRS1=1 : Return : Endif
If right$(SERVEUR,len(SERVEUR))<>"@" : SERVEUR=SERVEUR+"@" : Endif
#Onerrgo ERRSERVL
#Listimp PARID=SERVEUR
#Onerrgo
 CHTEST=  "SrvImpVerifyAppli:"+GINSTID+";"+nomap
 Onerrgo ERRSERVL
 Getui PARID=SERVEUR With CHTEST
 Onerrgo
 If ERRS=1 : Return : Endif
 K = instr(1,PARID,"=")
 If right$(PARID,K+2)<>"1"
   Local Char CLISERV(250)
   Call HOSTNAM(CLISERV)
   CHTEST = "X3ImpVerifyAppli:"+nomap+";"+CLISERV+";"+num$(adxtcp)
   Onerrgo ERRSERVL
   Getui PARID=SERVEUR With CHTEST
   Onerrgo
 Endif
 K = instr(1,PARID,"=")
 If right$(PARID,K+2)<>"1" : ERRS = 1 : Endif
Return

#---------------------------------------------------------------------------------#
## ContrûÇle serveur
#---------------------------------------------------------------------------------#

$CONTSERV
Local Char    SERVEUR(250) , CHTEST(250) , PARAMETRE(250)(1..150) , CLISERV(250)
Local Integer ERRS , K , I

#  On n'oblige plus û  saisir un serveur d'impression
#  Le serveur Web appelera le serveur par dûˋfaut

If VALEUR=""
 If GBROWS=0 or (GFONCTION<>"AIMP" & left$(GFONCTION,3)="RPT") : Return : Endif
 GMESSAGE = mess(90,150,1) : # Serveur d'impression doit etre renseignûˋ
 mkstat = 2 : Return
Endif
ERRS = 0
SERVEUR = VALEUR
If right$(VALEUR,len(VALEUR))<>"@" : SERVEUR = VALEUR+"@" : Endif
If len(SERVEUR)<=1 : Return : Endif
Onerrgo ERRSERV
Listimp PARAMETRE=SERVEUR
Onerrgo
If ERRS
 GMESSAGE = mess(89,150,1) : # Serveur d'impression indisponible
 mkstat = 2 : Return
Endif

# Teste si le serveur d'impression connait l'application courante
# Il faut au prûˋalable rûˋcupûˋrer le nom "cluster" du serveur X3
CHTEST=  "SrvImpVerifyAppli:"+GINSTID+";"+nomap
Getui PARAMETRE=SERVEUR With CHTEST
K = instr(1,PARAMETRE,"=")
If right$(PARAMETRE,K+2)<>"1"
  Call HOSTNAM(CLISERV)
  CHTEST = "X3ImpVerifyAppli:"+nomap+";"+CLISERV+";"+num$(adxtcp)
  Getui PARAMETRE=SERVEUR With CHTEST
Endif
K = instr(1,PARAMETRE,"=")
If right$(PARAMETRE,K+2)<>"1"
 GMESSAGE = mess(88,150,1) : # Serveur d'impression non paramûˋtrûˋ pour l'application courante
 mkstat = 2 : Return
Endif
Return

$ERRSERV
ERRS = 1
Resume

#------------------------------------------------------------------#
# Retourne le nom rûˋseau du serveur X3
#------------------------------------------------------------------#

Subprog HOSTNAM(CLISERV)
Variable Char CLISERV
Local Integer AIP,K,K1,K2,J,CONF
Local Char ZTES(250)
Local Char ALPHA(52) , CHIFFRE(10) , ALPNUM(10)
ALPHA   = sigma(0,25,chr$(65+indcum))+sigma(0,25,chr$(97+indcum))
CHIFFRE = sigma(0,9,chr$(48+indcum))
ALPNUM  = ".@\/_:-"

CLISERV = ""

#  CC 31/01/2005     - Bug 26560

Call PARCLI("AppHostName",CLISERV) From GLOBVAR
For J=1 To len(CLISERV)
 If !instr(1,ALPHA+CHIFFRE+ALPNUM,mid$(CLISERV,J,1))
  CLISERV = "" : Break
 Endif
Next J

#  On se protû´ge contre les adresses IP ou les chaûÛnes vides
#  Dans ce cas on prend adxmac

Raz AIP,K,K1,K2
K = instr(1,CLISERV,".")
If K  : K1=instr(K+1,CLISERV,".")  : Endif
If K1 : K2=instr(K1+1,CLISERV,".") : Endif
If K2
  AIP=1
  For J=1 To 4
    If J=1 : ZTES=left$(CLISERV,K-1) : Endif
    If J=2 : ZTES=mid$(CLISERV,K+1,K1-K-1) : Endif
    If J=3 : ZTES=mid$(CLISERV,K1+1,K2-K1-1) : Endif
    If J=4 : ZTES=right$(CLISERV,K2+1) : Endif
    CONF= pat(ZTES,"#")+pat(ZTES,"##")+pat(ZTES,"###")+pat(ZTES,"####")
    If CONF=0 : AIP=0 : Break 1 : Endif
  Next J
Endif

If CLISERV="" or AIP=1
  If adxmac(0)<>""
    CLISERV = adxmac(0)
  Else
    CLISERV = adxmac(-1)
  Endif
Endif
End

#---------------------------------------------------------------------------------#
#  Sûˋlection d'une ou de toutes les langues associûˋes au dossier courant
#---------------------------------------------------------------------------------#

$SELLAND
Raz TEXTE,TEX,NBTEX
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
Read [ADS]DOSSIER=nomap
If fstat=0
  For I=1 To [F:ADS]NBRLAN
    NBTEX+=1
    TEX(NBTEX)=[F:ADS]LAN(I-1)
    Call LECTEXTRA(TEXTE(NBTEX),"TABLAN","INTDES",[F:ADS]LAN(I-1),"") From ATEXTRA
  Next I
Endif
TIT = ""
Return

$SELLANDCCTEST
Local Char TEXTE(30)(1..10,1..2)

Raz TEXTE,TEX,NBTEX
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
Read [ADS]DOSSIER=nomap
If fstat=0
  For I=1 To [F:ADS]NBRLAN
    NBTEX+=1
    TEX(NBTEX)=[F:ADS]LAN(I-1)
    Call LECTEXTRA(TEXTE(NBTEX,1),"TABLAN","INTDES",[F:ADS]LAN(I-1),"") From ATEXTRA
    TEXTE(NBTEX,2)=num$(NBTEX)

  Next I
Endif
TIT(0) = "test"
TIT(1) = "langue"
TIT(2) = "numûˋro"
Return


#---------------------------------------------------------------------------------#
#  Sûˋlection des transactions d'un objet
#---------------------------------------------------------------------------------#


$SELTRN
Raz TEXTE,TEX,NBTEX
If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
Filter [AWI] Where OBJ=PARAM(1)
For [AWI]
  If [F:AWI]TRN<>""
    NBTEX+=1
    TEX(NBTEX)=[F:AWI]TRN
    TEXTE(NBTEX)=[F:AWI]TRN
  Endif
Next
Filter [AWI]
TIT = ""
Return


#----------------------------------------------------------------------------#
#  Sûˋlection des sous-programmes (Subprog , Funprog) d'un traitement
#----------------------------------------------------------------------------#

$SELSPG
Local Char TEXTE(30)(1..200,1..2)
Raz TEXTE,TEX,NBTEX
If PARAM(1)="" : PARAM(1)=nomap : Endif
Call LISTSUB(PARAM(1),PARAM(2),NBTEX,TEX)
If clalev([F:ASU])>0
 For I=1 To NBTEX
  Read [ASU]ASU0=PARAM(2);TEX(I)
  If !fstat
   Call TEXTE([F:ASU]INTIT,TEXTE(I,2)) From OBJDIV
  Endif
 Next I
Endif
TIT(0) = mess(43,115,1)-PARAM(2) : # Traitement (src)
TIT(1) = mess(207,124,1) : # Sous-programmes
TIT(2) = mess(30,109,1)  : # Intitulûˋ
Return


#----------------------------------------------------------------------------#
Subprog LISTSUB(APPLI,TRAIT,NBSPG,LSPG)
Value Char APPLI,TRAIT
Variable Integer NBSPG
Variable Char LSPG()(0..)

Local Char NOMFILE(GDIMFIC),VALL1(GDIMFIC)
Local Integer POS,POS1

Raz NBSPG,LSPG

OK = 1
If APPLI=""
 NOMFILE = filpath("TRT",TRAIT,"src")
 If filinfo(NOMFILE,0)<=0
  If filinfo(filpath("TRT",TRAIT,"adx"),0)>0
   LSPG(1)="NOSOURCE"
   End
  Else
   OK = 0
  Endif
 Endif
Else
 NOMFILE = filpath("TRT",TRAIT,"src")
 If filinfo(NOMFILE,0)<=0
   If filinfo(filpath("TRT",TRAIT,"adx"),0)>0
     LSPG(1)="NOSOURCE"
     End
   Else
     OK = 0
   Endif
 Else
  Openi NOMFILE Using [F_LE]
 Endif
Endif
If !OK
 Call ERREUR(TRAIT-":"-mess(90,123,1)) From GESECRAN : # Traitement inexistant
 End
Endif

Rdseq VALL1 Using [F_LE]
While !fstat
  POS=instr(1,VALL1,"Subprog")
  If POS<>0
    POS1=instr(1,VALL1,"#")
    If POS1=0 or POS1>POS
      NBSPG+=1
      LSPG(NBSPG)=vireblc(mid$(VALL1,POS+8,30),2)
      POS1=instr(1,LSPG(NBSPG),"(")
      If POS1<>0
        LSPG(NBSPG)=vireblc(left$(LSPG(NBSPG),POS1-1),2)
      Endif
    Endif
    Raz VALL1
  Endif
  POS=instr(1,VALL1,"Funprog")
  If POS<>0
    POS1=instr(1,VALL1,"#")
    If POS1=0 or POS1>POS
      NBSPG+=1
      LSPG(NBSPG)=vireblc(mid$(VALL1,POS+8,30),2)
      POS1=instr(1,LSPG(NBSPG),"(")
      If POS1<>0
        LSPG(NBSPG)=vireblc(left$(LSPG(NBSPG),POS1-1),2)
      Endif
    Endif
  Endif
  Rdseq VALL1 Using [F_LE]
Wend

Openi Using [F_LE]
End

#----------------------------------------------------------------------------#

Subprog IMPSERVB(IMPRIMANTE,SERVEUR)
Value    Char    IMPRIMANTE()
Variable Char    SERVEUR()
Local    Char    SERVIMP(250)
Local    Integer OK

SERVEUR=""
If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif

If SERVEUR="" & IMPRIMANTE<>""
 Filter [AIM] Where PRT<>1 & ENAFLG=2 & PRTSRV<>"" & toupper(PRTNAM)=toupper(IMPRIMANTE)
 Read [AIM]AIM0 First
 If fstat<=2 : SERVEUR=[F:AIM]PRTSRV : Endif
Endif

If SERVEUR="" & GSERIMP<>""
 Filter [AIM] Where PRT<>1 & ENAFLG=2 & PRTSRV=GSERIMP
 Read [AIM]AIM0 First
 If fstat<=2 : SERVEUR=GSERIMP : Endif
Endif

If SERVEUR="" & IMPRIMANTE<>""
 Filter [AIM] Where PRT<>1 & PRTSRV<>"" & toupper(PRTNAM)=toupper(IMPRIMANTE)
 Read [AIM]AIM0 First
 If fstat<=2 : SERVEUR=[F:AIM]PRTSRV : Endif
Endif

Filter [AIM]

End

#----------------------------------------------------------------------------#

Subprog IMPSERVD(SERVIMP,OK)
Variable Char SERVIMP
Variable Integer OK

#   OK =1       Serveur trouvûˋ
#   OK =0       Erreur

Local Char SERVEUR(250)
Gosub SELSERV
If NBTEX<>0
  OK=1
  If GSERIMP<>"" and find(GSERIMP,TEX(1..NBTEX))
    SERVIMP=GSERIMP
  Else
    SERVIMP=TEX(1)
  Endif
Elsif GSERIMP<>""
  SERVEUR=GSERIMP
  Gosub CONTSERI1
  If ERRS=0
    SERVIMP=GSERIMP
    OK=1
  Else
    SERVIMP=""
    OK=0
  Endif
Else
  SERVIMP=""
  OK=0
Endif

End


#-------------------------------------------------------------------------------------------------------#
# Recherche de la valeur d'un noeud dans le fichier solution.xml
#-------------------------------------------------------------------------------------------------------#
# NOMFIC -> Nom de la solution ou vide (solution courante)
# NOEUD  -> Nom des noeuds dont on veut retrouver la valeur.
#           2 syntaxes si plusieurs noeuds : sûˋparûˋs par un ~ ou dans un tableau
# FILTRE -> Filtre appliquûˋ sur le noeud "module". Il faut prûˋciser l'attribut et sa valeur
# VALEUR -> Retournûˋe sous la mûˆme forme que celle des noeuds
#-------------------------------------------------------------------------------------------------------#
# S'il y a plusieurs noeuds, il est nûˋcessaire de les rechercher composant par composant (balise module)
#-------------------------------------------------------------------------------------------------------#

Subprog RECH_NOEUD_SOL(NOMFIC,NOEUD,FILTRE,VALEUR)
Value Char NOMFIC , NOEUD , FILTRE
Variable Char VALEUR
Local Char    TBNEU(80)(1..20) , TBVAL(250)(1..20,1..30)
Local Char    CHAINE(255)
Local Clbfile CLOB(9)
Local Integer ER , NBNEU , NBVAL , DEB , FIN , CUR
Local Integer I , J , K , L

# Dûˋcortiquage des paramû´tres
If NOMFIC=""
 NOMFIC = filpath("","","",GDOSX3)
 NOMFIC = left$(NOMFIC,len(NOMFIC)-len(GDOSX3))+"solution.xml"
Endif
If filinfo(NOMFIC,0)<=0
 End
Endif

# Les noeuds sont mis dans un tableau
NBNEU = 0
If dim(NOEUD)>1
 For I=0 To dim(NOEUD)-1
  If NOEUD(I)<>""
   NBNEU += 1
   TBNEU(NBNEU) = NOEUD(I)
  Endif
 Next I
Elsif instr(1,NOEUD,"~")
 CHAINE = NOEUD
 While CHAINE<>""
  K = instr(1,CHAINE,"~")
  If K
   NBNEU += 1
   TBNEU(NBNEU) = left$(CHAINE,K-1)
   CHAINE = right$(CHAINE,K+1)
  Else
   NBNEU += 1
   TBNEU(NBNEU) = CHAINE
   CHAINE = ""
  Endif
 Wend
Else
 TBNEU = NOEUD
 NBNEU = 1
Endif

# Le fichier solution.xml est mis dans un clob pour s'affranchir de la limite des 255 caractû´res
Onerrgo ER
Openi NOMFIC Using [NEU_]
If ER : End : Endif
Raz CLOB
Rdseq CHAINE Using [NEU_]
While !fstat
 CLOB += CHAINE
 Rdseq CHAINE Using [NEU_]
Wend
Openi Using [NEU_]

# C'est parti
CUR = 1
NBVAL = 0
While CUR
 DEB = instr(CUR+1,CLOB,"<module")
 CUR = DEB
 If DEB
  FIN = instr(DEB,CLOB,"</module")
  If FILTRE<>""
   K = instr(DEB,CLOB,FILTRE)
  Else
   K = DEB
  Endif
  If K>=DEB and K<=FIN
   # On est dans le bon module (composant console)
   J = 0
   For I=1 To NBNEU
    K = instr(DEB,CLOB,"<"+TBNEU(I))
    If K>=DEB and K<=FIN
     # On a trouvûˋ un noeud
     K += len(TBNEU(I))+2
     L = instr(K,CLOB,"</"+TBNEU(I))
     If L
      L -= 1
      If J=0
       J = 1
       NBVAL += 1
      Endif
      TBVAL(I,NBVAL) = seg$(CLOB,K,L)
     Endif
    Endif
   Next I
  Endif
 Endif
Wend

# Mis en forme du rûˋsultat
If NBVAL
 If dim(VALEUR)>1
  For J=1 To NBVAL
   VALEUR(J-1) = ""
   For I=1 To NBNEU
    If I>1 : VALEUR(J-1) += "~" : Endif
    VALEUR(J-1) += TBVAL(I,J)
   Next I
  Next J
 Else
  VALEUR = ""
  For J=1 To NBVAL
   For I=1 To NBNEU
    If I>1 or J>1 : VALEUR += "~" : Endif
    VALEUR += TBVAL(I,J)
   Next I
  Next J
 Endif
Endif
End

$ER
ER = errn
Resume

$CLEAN_PARAM_4
Local Integer POS
POS = instr(1,PARAM(4),"/")
If POS
 If GFUSION
  PARAM(4) = right$(PARAM(4),POS+1)
 Else
  PARAM(4) = left$(PARAM(4),POS-1)
 Endif
Endif
Return

#**
#* REPORT_TRACE
#*!
Subprog REPORT_TRACE(MESSAGE,SERVER,PARAMETERS,MISC)
Value Char MESSAGE
Value Char SERVER
Variable Char PARAMETERS()(1..)
Value Char MISC
Local Char FCT(20) : FCT="REPORT - "
Gosub _SELIMP_TRACE
Return

#**
#* SELIMP_TRACE
#*!
Subprog SELIMP_TRACE(MESSAGE,SERVER,PARAMETERS,MISC)
Value Char MESSAGE
Value Char SERVER
Variable Char PARAMETERS()(1..)
Value Char MISC

Local Char FCT(20) : FCT="SELIMP - "
$_SELIMP_TRACE

If !len(GTRACE)
  Call OUVRE_TRACE("conv_"+adxusr) From LECFIC
Endif

Local Char TRACE(250)
Local Integer I:I=1
Local Integer J:J=1
Local Integer NBPARS:NBPARS=1

While NBPARS <= maxtab(PARAMERTERS) and len(PARAMETERS(NBPARS))
 NBPARS += NBPARS
Wend

Call ECR_TRACE(string$(80, "*"),1) From GESECRAN
TRACE = MESSAGE : Gosub _PRINTER_TRACE
TRACE = "SERVER:"+SERVER : Gosub _PRINTER_TRACE
While len(PARAMETERS(I))
TRACE = "PARAMETER:"+PARAMETERS(I) : Gosub _PRINTER_TRACE
 I +=1
Wend
TRACE = "MISC:"+MISC : Gosub _PRINTER_TRACE
End

$_PRINTER_TRACE
For J=1 To min(NBPARS,32)
 TRACE = ctrans(TRACE,chr$(J),"")
Next J
Call ECR_TRACE(FCT+ " - "+TRACE,1) From GESECRAN
Return

#**
#* SET_MODIFIED :
#* Computes a key which makes it possible to identify parameters modidied by selimp
#*
#* @param PARAMS
#*!
Funprog SET_MODIFIED(NAME,PARAMS)
Value Char NAME
Variable Char PARAMS()(1..)

Local Integer I
#Local Char RETVAL(10) : RETVAL=""    # RBU - 103289 - 20150526
Local Char RETVAL(250) : RETVAL=""

RETVAL = NAME
For I=1,2,3,4,5,6,7,8,9
 RETVAL += "~" + PARAMS(I)
Next I

End RETVAL

