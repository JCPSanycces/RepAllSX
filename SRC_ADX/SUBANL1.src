# Gestion du masque ANL1

##########################################################################
## Etiquette ajoutée par le superviseur 01/09/2003 09:57:09 (MM)
##########################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If clalev ([F:FCY]) <= 0 : Local File FACILITY  [FCY] : Endif
Read [FCY]FCY0 = VALEUR
If !fstat : [M:DIA]FCYNAM(nolign-1) = [F:FCY]FCYNAM : Endif
End


##########################################################################
## Etiquette ajoutée par le superviseur 03/09/2003 15:12:25 (MM)
##########################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
End


