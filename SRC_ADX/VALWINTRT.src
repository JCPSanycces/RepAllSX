#<AdxTL>@(#)10.0.0.0 $Revision$
#---------------------------------------------------------------------------------------------------#
# VALWINTRT Ecriture du traitement WGxxx
#---------------------------------------------------------------------------------------------------#

$VALTRT
Gosub TRT_DEB
Gosub ETIQUETTES
Gosub TRT_FIN
Return

$TRT_DEB
FICSRC = filpath("TRT",NOMPROG,"src",APPLI)
Openo FICSRC , 0
adxifs = ""
adxirs = chr$(10)
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq "#"-mess(104,133,1)-FENETRE : # Gestion de la fenêtre
Wrseq
Return

$TRT_FIN
Wrseq
Openo
Call VALID("TRT",NOMPROG,APPLI,OK) From VALMSKSUB
Return

#---------------------------------------------------------------------------------------------------#
$ETIQUETTES
#---------------------------------------------------------------------------------------------------#

Wrseq "$HORODAT"
Wrseq "Local Date    A_DATE"
Wrseq "Local Char    A_HEURE(10) , A_USER(10)"
Wrseq "Local Char    A_STAMP(14)"
Wrseq "Local Integer A_RESULT"
Wrseq "A_DATE  = [";format$(GFMD,JOUR)+"]"
Wrseq 'A_HEURE = "';HEURE;'"'
Wrseq 'A_USER  = "';GUSER;'"'
Wrseq 'Call ISWINVALID(nomap,GLANGUE,"'+FENETRE+'",0,A_STAMP,A_RESULT,1) From INTRUTILB'
Wrseq "Return"
Wrseq

Wrseq "$NAVIGMSK"
Wrseq "Local Char NAVMSK(200)"
Local Char NAVMSK(200)
For I=1 To AWI_NBRMSK
  If AWI_ABRMSK(I)<>"" : NAVMSK+=AWI_ABRMSK(I)+";" : Endif
Next I
Wrseq 'NAVMSK="'+NAVMSK+'"'
Wrseq "Return"
Wrseq

Wrseq "$OUVRE_BOITE"
If AWI_NBRMSK>0
 Wrseq "Gosub INIT_BOITE"
 Wrseq "Gosub DEF_BOITE"
 Wrseq "Gosub AFF_BOITE"
 For L=1 To AWB_NBR
  If AWB_NUM(L)<>"9"
   If AWB_ABR(L)<>""
&   & (AWB_ABB(L)<>"" | AWB_FCY(L)<>"" | AWB_ACC(L)<>"" | FLDTXT(L)<>"" | sum(AWB_OBLLNK(1..AWB_NBFIC(L),L)))
   Elsif AWB_TRE(L)>=2
    If AWB_ABB(L)<>""
     Wrseq "Filter ["+AWB_ABB(L)+"]"
    Elsif AWB_ABR(L)<>""
     Wrseq "Filter ["+AWB_ABR(L)+"]"
    Endif
   Endif
  Endif
 Next L
Endif
Wrseq "Return"
Wrseq

Wrseq "$INIT_BOITE"
If AWI_NBRMSK>0
 NLG = num$(MAXBRO)
 Wrseq "Local Char    OBJLIS(GLONAOB)(0.."+NLG+"), DESLIS(80)(0.."+NLG+"), BOX1(10)"
 Wrseq "Local Integer CHGLIS(0.."+NLG+"), BROLIS(0.."+NLG+"), TRELIS(0.."+NLG+")"
 Wrseq "Local Char    SAIRAP(50)(1.."+num$(MAXSEL)+")"
 Wrseq "Local Integer DERLU , AFOLDEF"
 Wrseq "Local Char    ABRENA(GLONABR)"
 Wrseq "DERLU = "+num$(AWB_DER=2)
 Wrseq "AFOLDEF = 1"
 Wrseq 'ABRENA = "'+AWI_ABRENA+'"'
 Wrseq 'BOX1 = "GAU_CHE'+AWB_NUM(1)+'"'
 For I=1 To AWB_NBR
  If !find(AWB_NUM(I),"9")
   If AWB_NUM(I)=""
    NLG = "0"
   Else
    NLG = AWB_NUM(I)
   Endif
   Wrseq 'OBJLIS('+NLG+') = "'+AWB_OBJ(I)+'"'
   Wrseq 'CHGLIS('+NLG+') = '+num$(AWB_CHG(I))
   Wrseq 'BROLIS('+NLG+') = '+num$(AWB_BRO(I))
   Wrseq 'TRELIS('+NLG+') = '+num$(AWB_TRE(I))
   If find(AWB_TRE(I),1,2,3,5) : # mb 6.6.2 Simple, hiérachisée, picking, picking simple
    Wrseq 'DESLIS('+NLG+') = "'+AWB_IND(I)+'"'
   Endif
  Endif
 Next I
 If AWI_NOMMSK(1)<>""
  Wrseq "If clalev([M:"+AWI_ABRMSK(1)+"])=0 :";
  Case AWI_GLO
   When 0       : Wrseq " Local";
   When Default : Wrseq " Global";
  Endcase
  Wrseq " Mask "+AWI_NOMMSK(1)+" ["+AWI_ABRMSK(1)+"] : Endif"
 Endif
 For I=2 To AWI_NBRMSK
  Wrseq "If clalev([M:"+AWI_ABRMSK(I)+"])=0 :";
  Case AWI_GLO
   When 0       : Wrseq " Local";
   When Default : Wrseq " Global";
  Endcase
  Wrseq " Mask "+AWI_NOMMSK(I)+" ["+AWI_ABRMSK(I)+"] : Endif"
 Next I
 Wrseq "Gosub TIT"
 Wrseq "nolign = 1" : # Sans ça, l'init des formats variables des colonnes ne marche pas en C/S
 Raz OKTXT
 For L=1 To AWB_NBR
  If AWB_NUM(L)<>"9"
   If AWB_ABR(L)<>""
&   & (AWB_ABB(L)<>"" | AWB_FCY(L)<>"" | AWB_ACC(L)<>"" | FLDTXT(L)<>"" | sum(AWB_OBLLNK(1..AWB_NBFIC(L),L)))
    SPA = 0
    Gosub WRLINK From VALWINSUB
   Elsif AWB_TRE(L)>=2
    If AWB_ORD(L)=2
     If AWB_ABB(L)<>""
      Wrseq "Filter ["+AWB_ABB(L)+"] Order by Key "+AWB_CLE(L)+" Desc"
     Elsif AWB_ABR(L)<>""
      Wrseq "Filter ["+AWB_ABR(L)+"] Order by Key "+AWB_CLE(L)+" Desc"
     Endif
    Else
     If AWB_ABB(L)<>""
      If AWB_CLE(L)<>""
       Wrseq "Filter ["+AWB_ABB(L)+"] Order by Key "+AWB_CLE(L)
      Endif
     Elsif AWB_ABR(L)<>""
      Wrseq "[G:"+AWB_ABR(L)+"]currind = "+num$(AWB_NOI(L))
     Endif
    Endif
   Endif
  Endif
 Next L
Endif
Wrseq "Return"
Wrseq

Wrseq "$DEF_BOITE"
If AWI_NBRMSK>0
 Wrseq "Gosub HORODAT From "+NOMPROG
 Wrseq 'If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif'

#  Chargement de A_WINDPREV pour le client convergence  CCORA  - 08/07/2013
#  Pour les transactions d'objet
#  Pour les transactions de consultation
 If AWI_TRN<>"" and AWI_OBJ<>""
  #  Si il y a une fenêtre sans transaction pour ce même objet, c'est la fenêtre modèle
   Filter [AWZ2] Where OBJ=AWI_OBJ and TRN=""
   For [AWZ2]
     Wrseq "If GFUSION=1"
     Wrseq '  A_WINDPREV=";;;'+[F:AWZ2]WIN+'"'
     Wrseq "Endif"
     Break
   Next
   Filter [AWZ2]
 Endif
 If AWI_CNS<>"" and left$(FENETRE,1)="W"
   Read [ACN]ACN0=AWI_CNS
   If fstat=0 and FENETRE<>[F:ACN]WND1
     Wrseq "If GFUSION=1"
     Wrseq '  A_WINDPREV=";;;'+[F:ACN]WND1+'"'
     Wrseq "Endif"
   Endif
 Endif

 If AOB_NBRSCR
  Wrseq 'If GWEBSERV=0'
 Endif
 K = 0
 If AWI_NOMMSK(1)<>""
  CHAINE = AWI_ABRMSK(1)
  Gosub BOX From VALWINSUB
  Gosub ONGLETS From VALWINSUB
 Else
  CHAINE = AWI_ABRMSK(2)
  Gosub BOX From VALWINSUB
 Endif
 For L=1 To AWB_NBR
  Gosub LISTE_GAUCHE From VALWINSUB
 Next L
 Wrseq '& As ['+AWI_BOX+']'
 If AOB_NBRSCR
  Wrseq 'Else'
  K = 0
  If AWI_NOMMSK(1)<>""
   CHAINE = AWI_ABRMSK(1)
   Gosub BOX From VALWINSUB
   Gosub ONGLETS From VALWINSUB
   Gosub ONGLETS_SUP From VALWINSUB
  Else
   CHAINE = AWI_ABRMSK(2)
   Gosub BOX From VALWINSUB
   Gosub ONGLETS_SUP From VALWINSUB
  Endif
  For L=1 To AWB_NBR
   Gosub LISTE_GAUCHE From VALWINSUB
  Next L
  Wrseq '& As ['+AWI_BOX+']'
  Wrseq 'Endif'
 Endif
 Wrseq 'Titled ['+AWI_BOX+'] TIT'
 For I=2 To AWI_NBRMSK
  If AWI_INTFLD(I)<>""
   Wrseq 'Chgtfd ['+AWI_ABRMSK(I)+'] '+format$("KTv2:30X",AWI_INTFLD(I))
  Endif
 Next I
Endif
Wrseq "Return"
Wrseq

Wrseq "$VISU_BOITE"
If AWI_NBRMSK>0
 Wrseq "Gosub INIT_BOITE"
 Wrseq "Gosub HORODAT From "+NOMPROG
 Wrseq 'If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif'
 If AOB_NBRSCR
  Wrseq 'If GWEBSERV=0'
 Endif
 K = 0
 If AWI_NOMMSK(1)<>""
  CHAINE = AWI_ABRMSK(1)
  Gosub BOX From VALWINSUB
  Gosub ONGLETS From VALWINSUB
 Else
  CHAINE = AWI_ABRMSK(2)
  Gosub BOX From VALWINSUB
 Endif
 Wrseq '& As ['+AWI_BOX+']'
 If AOB_NBRSCR
  Wrseq 'Else'
  K = 0
  If AWI_NOMMSK(1)<>""
   CHAINE = AWI_ABRMSK(1)
   Gosub BOX From VALWINSUB
   Gosub ONGLETS From VALWINSUB
   Gosub ONGLETS_SUP From VALWINSUB
  Else
   CHAINE = AWI_ABRMSK(2)
   Gosub BOX From VALWINSUB
   Gosub ONGLETS_SUP From VALWINSUB
  Endif
  Wrseq '& As ['+AWI_BOX+']'
  Wrseq 'Endif'
 Endif
 Wrseq 'Titled ['+AWI_BOX+'] TIT'
 Wrseq "Gosub AFF_BOITE"
Endif
Wrseq "Return"
Wrseq

Wrseq "$AFF_BOITE"
If AWI_NBRMSK>0
 Wrseq "Boxact ["+AWI_BOX+"] ";
 If AWI_NOMMSK(1)<>""
  Wrseq "Folder AFOLDEF"
 Else
  Wrseq
 Endif
Endif
Wrseq "Return"
Wrseq

Wrseq "$SAISIE_BOITE"
If AWI_NBRMSK>0
 Wrseq "Boxinp ["+AWI_BOX+"] Using REPONSE"
Endif
Wrseq "Return"
Wrseq

Wrseq "$FERME_BOITE"
If AWI_NBRMSK>0
 Wrseq "Onerrgo RIEN"
 Wrseq "Close";
 Case AWI_GLO
  When 0       : Wrseq " Local";
  When Default : Wrseq " Global";
 Endcase
 Case AWI_BOU
  When 0       : Wrseq " Inpbox";
  When Default : Wrseq " Inpbox";
 Endcase
 Wrseq " ["+AWI_BOX+"]"
 Wrseq "Onerrgo"
Endif
Wrseq "Return"
Wrseq
Wrseq "$RIEN"
Wrseq "Resume"
Wrseq

Wrseq "$TIT"
For L=1 To AWB_NBR
 Wrseq 'Local Char TITLIS'+AWB_NUM(L)+'(30)'
 If AWB_INT(L)<0
  CHAINE = num$(abs(AWB_INT(L)))
  Wrseq 'TITLIS'+AWB_NUM(L)+' = mess('+right$(CHAINE,4)+','+left$(CHAINE,3)+',1)'
 Else
  Wrseq 'Call TEXTE('+num$(AWB_INT(L))+',TITLIS'+AWB_NUM(L)+') From OBJDIV'
 Endif
Next I
For L=1 To AWB_NBR
 If AWB_NBSEL(L)<>0
  Wrseq 'Local Char TITSEL'+AWB_NUM(L)+'(30)(1..'+num$(AWB_NBSEL(L))+')'
  For I=1 To AWB_NBSEL(L)
   Wrseq 'Call TEXTE('+num$(AWB_SELINT(I,L))+',TITSEL'+AWB_NUM(L)+'('+num$(I)+')) From OBJDIV'
  Next I
 Endif
Next L
Wrseq "Local Char TIT(60) , TITTRN(60)"
If AWI_DES<>0
 Wrseq 'Call TEXTE('+num$(AWI_DES)+',TIT) From OBJDIV'
Endif
If AWI_TRN<>""
 Wrseq 'TIT -= "'+AWI_TRN+'"'
 If AOB_TITTRN<>""
  Wrseq 'If dim(PROGOBJ)>0 & PROGOBJ<>""'
  Wrseq ' Call TITTRN("'+AWI_TRN+'",TITTRN) From =PROGOBJ'
  Wrseq ' TIT -= " : "+TITTRN'
  Wrseq 'Endif'
 Elsif AWI_LIBEL<>""
  Wrseq 'TIT -= " : "+"'+AWI_LIBEL+'"'
 Endif
Endif
If AWI_DES=0 & AWI_TRN="" & OBJET<>""
 If AOB_LIBEL=0
  Wrseq "TIT = titre"
 Else
  Wrseq "Call TEXTE("+num$(AOB_LIBEL)+",TIT) From OBJDIV"
 Endif
Endif
Wrseq 'If GPROGRAMME<>""'
Wrseq ' If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif'
Wrseq ' [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME'
Wrseq 'Endif'
Wrseq "Return"
Wrseq

Wrseq "$REMPLIT_"
L = find("",AWB_NUM(1..AWB_NBR))
If L
 If AWB_NBSEL(L)<>0 & AWB_GES(L)<>2 & AWB_FIC(L)<>""
  Gosub WRREMPLIT From VALWINSUB
 Endif
Endif
Wrseq "Return"
Wrseq
For L=1 To AWB_NBR
 If !find(AWB_NUM(L),"","9") & AWB_NBSEL(L)<>0 & AWB_GES(L)<>2
  Wrseq "$REMPLIT_"+AWB_NUM(L)
  If AWB_FIC(L)<>"" or AWB_ABB(L)<>""
   Gosub WRREMPLIT From VALWINSUB
  Endif
  Wrseq "Return"
  Wrseq
 Endif
Next L

L = find("",AWB_NUM(1..AWB_NBR))
If L
 If AWB_NBSEL(L)<>0 & AWB_GES(L)<>2
  Wrseq "$SETCLE_"
  Gosub WRSETCLE From VALWINSUB
  Wrseq "Return"
  Wrseq
 Endif
Endif
For L=1 To AWB_NBR
 If !find(AWB_NUM(L),"","9") & AWB_NBSEL(L)<>0 & AWB_GES(L)<>2 & AWB_OBJ(L)<>"ALI"
  Wrseq "$SETCLE_"+num$(AWB_NUM(L))
  Gosub WRSETCLE From VALWINSUB
  Wrseq "Return"
  Wrseq
 Endif
Next L

Wrseq "$DEFAUT_BRO"
If AWB_NBR>0
 Wrseq "Case ILIS"
 For L=1 To AWB_NBR
  If !find(AWB_NUM(L),"9") & (AWB_FIC(L)<>"" | AWB_ABB(L)<>"")
   Wrseq " When "+num$(val(AWB_NUM(L)))+" : ";
   If AWB_ABB(L)<>""
    Wrseq "Default file ["+AWB_ABB(L)+"]"
   Elsif AWB_FCY(L)<>"" | AWB_ACC(L)<>"" or FLDTXT(L)<>"" or sum(AWB_OBLLNK(1..AWB_NBFIC(L),L))
    Wrseq "Default file ["+AWB_ABR(L)+"_]"
   Else
    Wrseq "Default file ["+AWB_ABR(L)+"]"
   Endif
  Endif
 Next L
 Wrseq "Endcase"
Endif
Wrseq "Return"
Wrseq

Wrseq "$SETBOX"
If AWB_NBR>0 & find(2,AWB_BRO)
 Wrseq "Case currbox"
 For L=1 To AWB_NBR
  If AWB_BRO(L)=2
   Wrseq ' When "GAU_CHE'+AWB_NUM(L)+'"'
   If !find(AWB_NUM(L),"9") & AWB_FIC(L)<>"" & find(AWB_TRE(L),1,5) & AWB_NBSEL(L)<>0
    Wrseq '  Gosub SETCLE_'+AWB_NUM(L)
    SPA = 2
    Gosub WRORDER From VALWINSUB
   Endif
   Wrseq '  Setlbox ['+AWI_BOX+'] GAU_CHE'+AWB_NUM(L)
   If !find(AWB_NUM(L),"9") & AWB_FIC(L)<>"" & find(AWB_TRE(L),1,5)
    Gosub WRFINFILTRE From VALWINSUB
   Endif
  Elsif AWB_NUM(L)="9"
   Wrseq ' When "GAU_CHE'+AWB_NUM(L)+'"'
   Wrseq '  Gosub CLE_DERLU From =PROGOBJ'
   Wrseq '  Setlbox ['+AWI_BOX+'] GAU_CHE'+AWB_NUM(L)
  Endif
 Next L
 Wrseq "Endcase"
Endif
Wrseq "Return"
Wrseq

Wrseq "$SETORDER"
If AWB_NBR>0
 Wrseq "Case currbox"
 For L=1 To AWB_NBR
  If !find(AWB_NUM(L),"9") & AWB_FIC(L)<>"" & find(AWB_TRE(L),1,5) & AWB_NBSEL(L)<>0 & AWB_ABR(L)<>"ALI"
   Wrseq ' When "GAU_CHE'+AWB_NUM(L)+'"'
   Wrseq '  Gosub SETCLE_'+AWB_NUM(L)
   SPA = 2
   Gosub WRORDER From VALWINSUB
  Endif
 Next L
 Wrseq "Endcase"
Endif
Wrseq "Return"
Wrseq

Wrseq "$ENDORDER"
If AWB_NBR>0
 Wrseq "Case currbox"
 For L=1 To AWB_NBR
  If !find(AWB_NUM(L),"9") & AWB_FIC(L)<>"" & find(AWB_TRE(L),1,5) & AWB_NBSEL(L)<>0 & AWB_ABR(L)<>"ALI"
   Wrseq ' When "GAU_CHE'+AWB_NUM(L)+'"'
   Wrseq '  Gosub SETCLE_'+AWB_NUM(L)
   SPA = 2
   Gosub WRFINFILTRE From VALWINSUB
  Endif
 Next L
 Wrseq "Endcase"
Endif
Wrseq "Return"
Wrseq

Wrseq "$PICKING"
If find(3,AWB_TRE) | find(5,AWB_TRE)
 Wrseq "Gosub SETCUR"
 Wrseq "Case currbox"
 For L=1 To AWB_NBR
  If find(AWB_TRE(L),3,5)
   Wrseq ' When "GAU_CHE'+AWB_NUM(L)+'"'
   If find(5,AWB_TRE(L)) & AWB_NBSEL(L)<>0
    Wrseq '  Gosub SETCLE_'+AWB_NUM(L)
    SPA = 2
    Gosub WRORDER From VALWINSUB
   Endif
   Wrseq '  Pick ['+AWI_BOX+'] GAU_CHE'+AWB_NUM(L)
   If find(5,AWB_TRE(L))
    Gosub WRFINFILTRE From VALWINSUB
   Endif
  Endif
 Next L
 Wrseq "Endcase"
Endif
Wrseq "Return"
Wrseq

Wrseq "$DEPICK"
If find(3,AWB_TRE) | find(5,AWB_TRE)
 Wrseq "Gosub SETCUR"
 Wrseq "Case currbox"
 For L=1 To AWB_NBR
  If find(AWB_TRE(L),3,5)
   Wrseq ' When "GAU_CHE'+AWB_NUM(L)+'"'
   If find(5,AWB_TRE(L)) & AWB_NBSEL(L)<>0
    Wrseq '  Gosub SETCLE_'+AWB_NUM(L)
    SPA = 2
    Gosub WRORDER From VALWINSUB
   Endif
   Wrseq '  Dislbox ['+AWI_BOX+'] GAU_CHE'+AWB_NUM(L)
   If find(5,AWB_TRE(L))
    Gosub WRFINFILTRE From VALWINSUB
   Endif
  Endif
 Next L
 Wrseq "Endcase"
Endif
Wrseq "Return"
Wrseq

Wrseq "$REPICK"
If find(3,AWB_TRE) | find(5,AWB_TRE)
 Wrseq "Gosub SETCUR"
 Wrseq "Case currbox"
 For L=1 To AWB_NBR
  If find(AWB_TRE(L),3,5)
   Wrseq ' When "GAU_CHE'+AWB_NUM(L)+'"'
   If find(5,AWB_TRE(L)) & AWB_NBSEL(L)<>0
    Wrseq '  Gosub SETCLE_'+AWB_NUM(L)
    SPA = 2
    Gosub WRORDER From VALWINSUB
   Endif
   Wrseq '  Setlbox ['+AWI_BOX+'] GAU_CHE'+AWB_NUM(L)
   If find(5,AWB_TRE(L))
    Gosub WRFINFILTRE From VALWINSUB
   Endif
  Endif
 Next L
 Wrseq "Endcase"
Endif
Wrseq "Return"
Wrseq

Wrseq "$SETCUR"
If find(3,AWB_TRE) | find(5,AWB_TRE)
 Wrseq "If !find(currbox";
 CHAINE = ""
 For L=1 To AWB_NBR
  If find(AWB_TRE(L),3,5)
   If CHAINE = "" : CHAINE = "GAU_CHE"+AWB_NUM(L) : Endif
   Wrseq ',"GAU_CHE'+AWB_NUM(L)+'"';
  Endif
 Next L
 Wrseq ")"
 Wrseq ' currbox = "'+CHAINE+'"'
 Wrseq "Endif"
Endif
Wrseq "Return"
Wrseq

Wrseq "$DEFVAR"
NLG = num$(MAXFOL-1)
Wrseq "Local Char    ABMSK(GLONABR)(0.."+NLG+") , NOMMSK(GLONAMK)(0.."+NLG+")"
Wrseq "Local Integer NBMASK , AMA(0.."+NLG+") , NBMSKCMP"
If AWI_NBRMSK>0
 If AWI_NOMMSK(1)<>""
  Wrseq 'NOMMSK(0) = '+format$("K:"+num$(GLONAMK+2)+"X",'"'+AWI_NOMMSK(1)+'"');' : ';
  Wrseq 'ABMSK(0)  = '+format$("K:"+num$(GLONABR+2)+"X",'"'+AWI_ABRMSK(1)+'"');' : ';
  Wrseq 'AMA(0) = 1'
 Endif
 For I=2 To AWI_NBRMSK
  Wrseq 'NOMMSK('+num$(I-1)+') = '+format$("K:"+num$(GLONAMK+2)+"X",'"'+AWI_NOMMSK(I)+'"');' : ';
  Wrseq 'ABMSK('+num$(I-1)+')  = '+format$("K:"+num$(GLONABR+2)+"X",'"'+AWI_ABRMSK(I)+'"');' : ';
  Wrseq 'AMA('+num$(I-1)+') = '+num$(AWI_FLGMSK(I)=2)
 Next I
 Wrseq "NBMASK = "+num$(AWI_NBRMSK-1)
Endif
Wrseq "NBMSKCMP = "+num$(AOB_NBRSCR)
Wrseq "Return"
Wrseq

Wrseq "$SETMASK"
If AWI_NBRMSK>0
 Wrseq "Case MA"
 If AWI_NOMMSK(1)<>""
  Wrseq " When 0 : If clalev([M:"+AWI_ABRMSK(1)+"])>0 : Default Mask ["+AWI_ABRMSK(1)+"] : Endif"
 Endif
 For I=2 To AWI_NBRMSK
  Wrseq " When "+num$(I-1)+" : If clalev([M:"+AWI_ABRMSK(I)+"])>0 : Default Mask ["+AWI_ABRMSK(I)+"] : Endif"
 Next I
 Wrseq "Endcase"
Endif
Wrseq "Return"
Wrseq

Wrseq "$TITMASK"
If AWI_NBRMSK>0
 Wrseq "Case MA"
 If AWI_NOMMSK(1)<>""
  Wrseq " When 0 : If clalev([M:"+AWI_ABRMSK(1)+"])>0 : Gosub TITRES From W1"+AWI_NOMMSK(1)+" : Endif"
 Endif
 For I=2 To AWI_NBRMSK
  Wrseq " When "+num$(I-1)+" : If clalev([M:"+AWI_ABRMSK(I)+"])>0 : Gosub TITRES From W1"+AWI_NOMMSK(I)
&      +" : Endif"
 Next I
 Wrseq "Endcase"
Endif
Wrseq "Return"
Wrseq

Wrseq "$FERME_MASK"
If AWI_NBRMSK>0
 If AWI_NOMMSK(1)<>""
  Wrseq "If clalev([M:"+AWI_ABRMSK(1)+"])>0 : Close";
  Case AWI_GLO
   When 0       : Wrseq " Local";
   When Default : Wrseq " Global";
  Endcase
  Wrseq " Mask ["+AWI_ABRMSK(1)+"] : Endif"
 Endif
 For I=2 To AWI_NBRMSK
  Wrseq "If clalev([M:"+AWI_ABRMSK(I)+"])>0 : Close";
  Case AWI_GLO
   When 0       : Wrseq " Local";
   When Default : Wrseq " Global";
  Endcase
  Wrseq " Mask ["+AWI_ABRMSK(I)+"] : Endif"
 Next I
Endif
Wrseq "Return"
Wrseq

Wrseq "$RAZMASK"
If AWI_NBRMSK>0
 Wrseq "Case MA"
 If AWI_NOMMSK(1)<>""
  Wrseq " When 0 : If clalev([M:"+AWI_ABRMSK(1)+"])>0 : Raz [M:"+AWI_ABRMSK(1)+"] : Endif"
 Endif
 For I=2 To AWI_NBRMSK
  Wrseq " When "+num$(I-1)+" : If clalev([M:"+AWI_ABRMSK(I)+"])>0 : Raz [M:"+AWI_ABRMSK(I)+"] : Endif"
 Next I
 Wrseq "Endcase"
Endif
Wrseq "Return"
Wrseq

Wrseq "$AFFMASK"
If AWI_NBRMSK>0
 Wrseq "Case MA"
 If AWI_NOMMSK(1)<>""
  Wrseq " When 0 : If clalev([M:"+AWI_ABRMSK(1)+"])>0 : Affzo [M:"+AWI_ABRMSK(1)+"] : Endif"
 Endif
 For I=2 To AWI_NBRMSK
  Wrseq " When "+num$(I-1)+" : If clalev([M:"+AWI_ABRMSK(I)+"])>0 : Affzo [M:"+AWI_ABRMSK(I)+"] : Endif"
 Next I
 Wrseq "Endcase"
Endif
Wrseq "Return"
Wrseq

Wrseq "$OUVMSKCMP"
For I=1 To AOB_NBRSCR
 Wrseq "If clalev([M:"+AOB_ABRSCR(I)+"])=0 : Local Mask "+AOB_NAMSCR(I)+" ["+AOB_ABRSCR(I)+"] : Endif"
Next I
Wrseq "Return"
Wrseq

Wrseq "$FERMSKCMP"
For I=1 To AOB_NBRSCR
 Wrseq "If clalev([M:"+AOB_ABRSCR(I)+"])>0 : Close Local Mask ["+AOB_ABRSCR(I)+"] : Endif"
Next I
Wrseq "Return"
Wrseq

Wrseq "$RAZMSKCMP"
For I=1 To AOB_NBRSCR
 Wrseq "If clalev([M:"+AOB_ABRSCR(I)+"])>0 : Raz [M:"+AOB_ABRSCR(I)+"] : Endif"
Next I
Wrseq "Return"
Wrseq

Wrseq "$AFF_ENAFLG"
If AWI_ABRENA<>""
 Wrseq "Affzo [M:"+AWI_ABRENA+"]ENAFLG"
Endif
Wrseq "Return"
Wrseq

Wrseq "$CHARGEFIC"
If AWI_NBRMSK>0 & AWI_OBJ<>""
 Wrseq "Case IMA"
 For I=1 To AWI_NBRMSK
  If AWI_NOMMSK(I)<>""
   Wrseq " When "+num$(I-1)+" : If clalev([M:"+AWI_ABRMSK(I)+"])>0";
   Wrseq " : [F:"+ATB_ABR+"] = [M:"+AWI_ABRMSK(I)+"] : Endif"
  Endif
 Next I
 Wrseq "Endcase"
Endif
Wrseq "Return"
Wrseq

Wrseq "$CHARGEMSK"
If AWI_NBRMSK>0 & AWI_OBJ<>""
 Wrseq "Case IMA"
 For I=1 To AWI_NBRMSK
  If AWI_NOMMSK(I)<>""
   Wrseq " When "+num$(I-1)+" : If clalev([M:"+AWI_ABRMSK(I)+"])>0";
   Wrseq " : [M:"+AWI_ABRMSK(I)+"] = [F:"+ATB_ABR+"] : Endif"
  Endif
 Next I
 Wrseq "Endcase"
Endif
Wrseq "Return"
Wrseq

Wrseq "$GRISE_CLE"
If AWI_OBJ<>"" & AOB_GES<>2 & (AWI_NOMMSK(1)<>"" | AWI_NBRMSK>0)
 If AWI_NOMMSK(1)<>""
  Wrseq "If AMA(0)"
  Wrseq " Grizo [";AWI_ABRMSK(1)+"]";
  Gosub WRGRISE From VALWINSUB
  Wrseq "Else"
  Wrseq " Grizo ["+AWI_ABRMSK(2)+"]";
  Gosub WRGRISE From VALWINSUB
  Wrseq "Endif"
 Elsif AWI_ABRMSK(2)<>""
  Wrseq "Grizo ["+AWI_ABRMSK(2)+"]";
  Gosub WRGRISE From VALWINSUB
 Endif
Endif
Wrseq "Return"
Wrseq

Wrseq "$DEGRISE_CLE"
If AWI_OBJ<>"" & AOB_GES<>2 & (AWI_NOMMSK(1)<>"" | AWI_NBRMSK>0)
 If AWI_NOMMSK(1)<>""
  Wrseq "If AMA(0)"
  Wrseq " Actzo [";AWI_ABRMSK(1)+"]";
  Gosub WRGRISE From VALWINSUB
  Wrseq "Else"
  Wrseq " Actzo ["+AWI_ABRMSK(2)+"]";
  Gosub WRGRISE From VALWINSUB
  Wrseq "Endif"
 Elsif AWI_ABRMSK(2)<>""
  Wrseq "Actzo ["+AWI_ABRMSK(2)+"]";
  Gosub WRGRISE From VALWINSUB
 Endif
Endif
Wrseq "Return"
Wrseq

Wrseq "$BOUTON"
CHAINE = ""
Case AWI_WINTYP
 When 2 : # Objet
  BOUTSTD = "ECSAON09<>RHILJMP"
  If GPRODUIT=1 : ## GEODE
   BOUTSTD += "Q"
  Endif
 When 3 : # Consultation
  BOUTSTD = "RC-+D"
 When 4 : # Critères consultation
  BOUTSTD = "O"
 When Default : # Divers
  BOUTSTD = "ECSAON09<>XHILJMP"
  If GPRODUIT=1 : ## GEODE
   BOUTSTD += "Q"
  Endif
Endcase
For I=1 To len(BOUTSTD)
 If AWI_STA(I)<>0
  CHAINE += mid$(BOUTSTD,I,1)
 Endif
Next I
Wrseq 'STDBOUT = "'+CHAINE+'"'
Wrseq 'NBTEX  = 0'
For I=1 To AWT_NBR
 If AWT_NIV(I)=0
  Wrseq 'NBTEX += 1'
  Wrseq 'CBOUT(NBTEX) = "'+left$(AWT_COD(I),1)+'" : LBOUT(NBTEX) = '+num$(AWT_STA(I));
  Wrseq ' : Call TEXTE('+num$(AWT_TXT(I))+',TEXTE(NBTEX)) From OBJDIV'
  If AWT_ACT(I)>0 & ACT_COD(AWT_ACT(I))="ADIFFERE"
   Wrseq 'CBOUTD = "'+left$(AWT_COD(I),1)+'"'
  Endif
 Endif
Next I
Wrseq 'Raz NBMEN, CMEN, TMEN, NMEN, LMEN'
For I=1 To AWT_NBR
 If AWT_NIV(I)<>0
  Wrseq 'NBMEN += 1'
  Wrseq 'NMEN(NBMEN) = '+num$(AWT_NIV(I));
  If AWT_COD(I)<>""
   Wrseq ' : CMEN(NBMEN) = "'+AWT_COD(I);'"';
  Endif
  If AWT_STA(I)<>0
   Wrseq ' : LMEN(NBMEN) = '+num$(AWT_STA(I));
  Endif
  Wrseq ' : Call TEXTE('+num$(AWT_TXT(I))+',TMEN(NBMEN)) From OBJDIV'
 Endif
Next I
Wrseq "Return"
Wrseq

Wrseq "$EXEBOUT"
Wrseq "Local Char    SAVACT(GLONACT)"
Wrseq "Local Integer FLGEXE"
Wrseq "SAVACT = GACTION"
Wrseq "Case BOUT"
For I=1 To AWT_NBR
 If AWT_ACT(I)>0
  If len(AWT_COD(I))>1
   Wrseq ' When "'+right$(AWT_COD(I),len(AWT_COD(I)))+'"'
  Else
   Wrseq ' When "'+AWT_COD(I)+'"'
  Endif
  SPA = 2
  FLGOK = 0
  A = AWT_ACT(I)
  Gosub EXEBOUT1 From VALWINSUB
  If ACT_SUI(A)>0
   FLGOK = 1
  Endif
  While ACT_SUI(A)>0
   A = ACT_SUI(A)
   Gosub EXEBOUT1 From VALWINSUB
  Wend
 Endif
Next I
Wrseq "Endcase"
Wrseq "GACTION = SAVACT"
Wrseq "Return"
Wrseq

Wrseq "$EXEACT"
Wrseq "Local Char    SAVACT(GLONACT)"
Wrseq "Local Integer FLGEXE"
Wrseq "SAVACT = GACTION"
Wrseq "Case BOUT"
For I=1 To dim(AWI_STA)
 If AWI_ACT(I)>0
  Wrseq ' When "'+mid$(BOUTSTD,I,1)+'"'
  SPA = 2
  A = AWI_ACT(I)
  Gosub EXEACT1 From VALWINSUB
  While ACT_SUI(A)>0
   A = ACT_SUI(A)
   Gosub EXEACT1 From VALWINSUB
  Wend
 Endif
Next I
Wrseq "Endcase"
Wrseq "GACTION = SAVACT"
Wrseq "Return"
Wrseq
Return

