#<AdxTL>@(#)10.0.0.0 $Revision$
Raz GPILCOD, GBIDC1
Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET
End

####################################################################################
## Tableaux de bord : Traitement des fonctions de compta géné
####################################################################################

#
# Ouverture de la bonne balance
#

$OUVRE
Case QTE
 When 0
  If BALGEN<>1
   If clalev([F:BAL])>0 : Close Local File [BAL] : Endif
   Local File BALANCE [BAL]
   BALGEN = 1
  Endif
 When 1
  If BALGEN<>2
   If clalev([F:BAL])>0 : Close Local File [BAL] : Endif
   Local File BLAQTY [BAL]
   BALGEN = 2
  Endif
Endcase
Return

#
# Traitement d'un collectif
#

$TRT_COL
Case FONC
 When "H"  :  # Parcours d'un collectif sans détail des comptes
  DETDEL = 1
  DETAIL = 0
 When "I"  :  # Parcours d'un collectif avec détail des comptes
  DETDEL = 0
  DETAIL = 1
Endcase
If func SUBTXSB.EXISTE(ARG(1))            : # Si le collectif est une variable
 Call REPLACE(ARG(1),ARG(1)) From SUBTXSB
Endif
COLL = ARG(1)
Gosub TRT_CPT
Return

#
# Traitement d'une borne de comptes
#

$TRT_CPT
Gosub OUVRE
Gosub SETREFGEN From CALTBD
Gosub SETEXE From CALTBD
Gosub CRITBAL
If COLL=""
 If CPT_DEB=CPT_FIN
  Call ADDCRIT(CRITERE,ICRIT,'[BAL]ACC="'+CPT_DEB+'"') From CALTBD
 Else
  Call ADDCRIT(CRITERE,ICRIT,'[BAL]ACC>="'+CPT_DEB+'" & [BAL]ACC<="'+CPT_FIN+'"') From CALTBD
 Endif
Else
 Call ADDCRIT(CRITERE,ICRIT,'[GAC]ACCSHO="'+COLL+'"') From CALTBD
Endif
If EXCLUS<>""
 Call ADDCRIT(CRITERE,ICRIT,'left$([BAL]ACC,'+num$(len(EXCLUS))+')<>"'+EXCLUS+'"') From CALTBD
Endif
Link [BAL] With [GAC]GAC0 = [F:BAL]COA;[F:BAL]ACC As [LBAL]
& Where evalue(CRITERE(1..ICRIT))
& Order By Key CLE = [F:BAL]ACC;[F:BAL]BPR;[F:BAL]FCY;[F:BAL]FIY
Gosub TRT_COMPTES
Return

#
# Traitement d'un code bilan ou d'une pyramide
#

$TRT_BIL
Gosub OUVRE
Case FONC
 When "A"  :   # les comptes par code bilan avec détail collectif
  DETDEL = 0
  DETAIL = 1
 When "B"  :   # les comptes par code bilan sans détail collectif
  DETDEL = 1
  DETAIL = 0
Endcase
Gosub SETREFGEN From CALTBD
Gosub SETEXE From CALTBD
If func SUBTXSB.EXISTE(ARG(1))            : # L'argument peut être une variable
 Call REPLACE(ARG(1),ARG(1)) From SUBTXSB
Endif
If NUMBIL=0
 K = instr(1,ARG(1),".")
 If K
  PYRAMIDE(1) = left$(ARG(1),K-1)
  PYRGRP(1)   = right$(ARG(1),K+1)
  Gosub TRT_PYR
 Else
  ER = 17 : ERARG = ARG(1)
 Endif
 Return
Endif

#
# Code bilan
#

COD_BIL = ARG(1)
Gosub CRITBAL
Call ADDCRIT(CRITERE,ICRIT,'(left$([GAC]RPTCODDEB('+num$(NUMBIL-1)+'),'+num$(len(COD_BIL))+')="'+COD_BIL+'"'
& +' | left$([GAC]RPTCODCDT('+num$(NUMBIL-1)+'),'+num$(len(COD_BIL))+')="'+COD_BIL+'")') From CALTBD

Link [BAL] With [GAC]GAC0 = [F:BAL]COA;[F:BAL]ACC As [LBAL]
& Where evalue(CRITERE(1..ICRIT))
& Order By Key CLE = [F:BAL]ACC;[F:BAL]BPR;[F:BAL]FCY;[F:BAL]FIY

Gosub TRT_COMPTES
Return

#
# Traitement d'une pyramide
#

$TRT_PYR
If func SUBTXSB.EXISTE(PYRAMIDE(1))                     : # Pyramide peut être variable
 Call REPLACE(PYRAMIDE(1),PYRAMIDE(1)) From SUBTXSB
Endif
If func SUBTXSB.EXISTE(PYRGRP(1))                       : # Le groupe aussi
 Call REPLACE(PYRGRP(1),PYRGRP(1)) From SUBTXSB
Endif
Read [GYM]GYM0 = PYRAMIDE(1)
If fstat
 ER = 17 : ERARG = PYRAMIDE(1)
 Return
Endif
Read [GRY]GRY0(2) = PYRAMIDE(1);PYRGRP(1)
If fstat
 ER = 17 : ERARG = PYRGRP(1)
 Return
Endif
PYRNIV(1)  = [F:GRY]LEV
Gosub CRITBAL
Call ADDCRIT(CRITERE,ICRIT,'[GYK]GRU="'+PYRGRP(1)+'"') From CALTBD

Link [BAL] With [GAC]GAC0  = [F:BAL]COA;[F:BAL]ACC
&             , [GYK]GYK0 ~= PYRAMIDE(1);PYRNIV(1);[F:BAL]ACC As [LBAL]
& Where evalue(CRITERE(1..ICRIT))
& Order By Key CLE = [F:BAL]ACC;[F:BAL]BPR;[F:BAL]FCY;[F:BAL]FIY
Gosub TRT_COMPTES
Return

########################################################################################
## Filtres communs
########################################################################################
$CRITBAL
Raz CRITERE
ICRIT = 1
Call ADDCRIT(CRITERE,ICRIT,'[BAL]LEDTYP='+num$(NUMREF)) From CALTBD
If NBSOC=1
 Call ADDCRIT(CRITERE,ICRIT,'[BAL]CPY="'+TSOC(1)+'"') From CALTBD
 If TEDEB(1)=TEFIN(1)
  Call ADDCRIT(CRITERE,ICRIT,'[BAL]FIY='+num$(TEDEB(1))) From CALTBD
 Else
  Call ADDCRIT(CRITERE,ICRIT,'[BAL]FIY>='+num$(TEDEB(1))+' & [BAL]FIY<='+num$(TEFIN(1))) From CALTBD
 Endif
Else
 Call ADDCRIT(CRITERE,ICRIT,'find([BAL]CPY,TSOC(1..NBSOC))') From CALTBD
Endif
If NBSITE=1
 Call ADDCRIT(CRITERE,ICRIT,'[BAL]FCY="'+TSITE(1)+'"') From CALTBD
Else
 Call ADDCRIT(CRITERE,ICRIT,'find([BAL]FCY,TSITE(1..NBSITE))') From CALTBD
Endif
If BALGEN=1
 If DEVSEL<>""
  Call ADDCRIT(CRITERE,ICRIT,'[BAL]CUR="'+DEVSEL+'"') From CALTBD
 Endif
Endif
Return

##########################################################################################
## Boucle sur les comptes
##########################################################################################
$TRT_COMPTES
Raz MTDEB, MTCDT, SITINF, CPTINF, TRSINF

For [LBAL]CLE(1) With Nohint : # Compte
 COMPTE = [F:BAL]ACC
 PLAN   = [F:BAL]COA
 If PLAN=""
  Read [CPY]CPY0 = [F:BAL]CPY
  Read [GCM]GCM0 = [F:CPY]ACM
  Read [LED]LED0 = [F:GCM]LED(NUMREF-1)
  PLAN           = [F:LED]COA
 Endif
 OKCPT = 1
 If OKCPT
  Gosub EVAL_INFACC From CALTBD
  COLEC = ([F:GAC]SAC=2)
  Raz CPTDEB, CPTCDT
  Raz SIT_CPTDEB, SIT_CPTCDT

 # Collectif et parcours individuel des comptes

  If COLEC & DETAIL

   For [LBAL]CLE(2) : # Tiers
    Raz I_M, M_DBT, M_CDT, M_FCY, M_ACC, M_BPR
    TIERS = [F:BAL]BPR
    If TIERS<>"" : # On évite le cumul
     Raz BPRDEB, BPRCDT
     For [LBAL]CLE(3)   : # Site
      SITE  = [F:BAL]FCY
      ISITE = find(SITE,TSITE(1..NBSITE))
      If ISITE
       SOC  = TSOCSIT(ISITE)
       ISOC = find(SOC,TSOC(1..NBSITE))
       EDEB = TEDEB(ISOC)
       EFIN = TEFIN(ISOC)
       PDEB = TPDEB(ISOC)
       PFIN = TPFIN(ISOC)
       Raz MTDEB , MTCDT
       For [LBAL]CLE    : # Exercice, devise
        EXE = [F:BAL]FIY
        If EXE>=EDEB & EXE<=EFIN
         Gosub CALC_MT : If GERR : Break 4 : Endif
        Endif
       Next : # Exercice, devise
       # on stocke en mémoire car on teste le solde + tard
       Gosub STO_TXM : If GERR : Break 3 : Endif
       BPRDEB += MTDEB   : # total tiers tous sites
       BPRCDT += MTCDT
      Endif
     Next   : # Site

     # On regarde le solde de ce tiers (tous sites), et on écrit les enregs

     OK = 1
     If NUMBIL<>0
      OK *= (left$([F:GAC]RPTCODDEB(NUMBIL-1),len(COD_BIL))=COD_BIL & SIGN*BPRDEB>SIGN*BPRCDT)
&         | (left$([F:GAC]RPTCODCDT(NUMBIL-1),len(COD_BIL))=COD_BIL & SIGN*BPRCDT>SIGN*BPRDEB)
     Endif
     OK *= ( (DEBIT<>1 & CREDIT<>1)
&         |  (DEBIT=1 & SIGN*BPRDEB>=SIGN*BPRCDT)
&         |  (CREDIT=1 & SIGN*BPRCDT>=SIGN*BPRDEB) )
     If OK
      If CREDIT=2 : Raz BPRDEB,M_DBT : Endif
      If DEBIT=2  : Raz BPRCDT,M_CDT : Endif
      CPTDEB += BPRDEB   : # Total collectif tous sites
      CPTCDT += BPRCDT
      For I=0 To I_M-1
       MTDEB = M_DBT(I)
       MTCDT = M_CDT(I)
       SITE  = M_FCY(I) : Gosub EVAL_INFSIT From CALTBD
       ISITE = find(SITE,TSITE(1..NBSITE))
       SIT_DEB(ISITE)    += MTDEB
       SIT_CDT(ISITE)    += MTCDT
       SIT_CPTDEB(ISITE) += MTDEB
       SIT_CPTCDT(ISITE) += MTCDT
       If DETBPR=2 & (MTDEB<>0 or MTCDT<>0)
        COMPTE = M_ACC(I)
        TIERS  = M_BPR(I) : Gosub EVAL_INFBPR From CALTBD
        INDTXM += 1
        TYPMONT = 3
        Gosub ECR_TXM From CALTBD
        If GOK<1 : Break 3 : Endif
       Endif
      Next I
     Endif
    Endif
   Next   : # Tiers

   # Compte Normal ou Collectif sans parcours individuel des comptes

  Else

   For [LBAL]CLE(2) : # Tiers
    Raz I_M, M_DBT, M_CDT, M_FCY, M_ACC, M_BPR
    TIERS = [F:BAL]BPR
    If TIERS="" : # On ne prend que le cumul
     Raz CPTDEB, CPTCDT
     For [LBAL]CLE(3)   : # Site
      SITE  = [F:BAL]FCY
      ISITE = find(SITE,TSITE(1..NBSITE))
      If ISITE
       SOC  = TSOCSIT(ISITE)
       ISOC = find(SOC,TSOC(1..NBSITE))
       EDEB = TEDEB(ISOC)
       EFIN = TEFIN(ISOC)
       PDEB = TPDEB(ISOC)
       PFIN = TPFIN(ISOC)
       Raz MTDEB , MTCDT
       For [LBAL]CLE : # Exercice, devise
        EXE = [F:BAL]FIY
        If EXE>=EDEB & EXE<=EFIN
         Gosub CALC_MT : If GERR : Break 4 : Endif
        Endif
       Next : # Exercice, devise
       # on stocke en mémoire car on teste le solde + tard
       Gosub STO_TXM : If GERR : Break 3 : Endif
       CPTDEB += MTDEB   : # Total compte tous sites
       CPTCDT += MTCDT
      Endif
     Next   : # Site

   # On regarde le solde du compte (tous sites), et on écrit

     OK = 1
     If NUMBIL<>0
      OK *= (left$([F:GAC]RPTCODDEB(NUMBIL-1),len(COD_BIL))=COD_BIL & SIGN*CPTDEB>SIGN*CPTCDT)
&         | (left$([F:GAC]RPTCODCDT(NUMBIL-1),len(COD_BIL))=COD_BIL & SIGN*CPTCDT>SIGN*CPTDEB)
     Endif
     OK *= ( (DEBIT<>1 & CREDIT<>1)
&         |  (DEBIT=1 & SIGN*CPTDEB>=SIGN*CPTCDT)
&         |  (CREDIT=1 & SIGN*CPTCDT>=SIGN*CPTDEB) )
     If OK
      If CREDIT=2 : Raz CPTDEB,M_DBT : Endif
      If DEBIT=2  : Raz CPTCDT,M_CDT : Endif
      For I=0 To I_M-1
       MTDEB = M_DBT(I)
       MTCDT = M_CDT(I)
       SITE  = M_FCY(I) : Gosub EVAL_INFSIT From CALTBD
       ISITE = find(SITE,TSITE(1..NBSITE))
       SIT_DEB(ISITE)    += MTDEB
       SIT_CDT(ISITE)    += MTCDT
       SIT_CPTDEB(ISITE) += MTDEB
       SIT_CPTCDT(ISITE) += MTCDT
       If DETBPR=2 & (MTDEB<>0 or MTCDT<>0)
        TIERS  = "." : TRSINF = mess(212,111,1) : # Sans tiers
        INDTXM += 1
        TYPMONT = 3
        Gosub ECR_TXM From CALTBD
        If GOK<1 : Break 3 : Endif
       Endif
      Next I
     Endif
    Endif
   Next : # Tiers

  Endif
  Filter [BAL]

 # On écrit le total site/compte et le total compte (tous sites)

  If DETACC=2
   TIERS  = ""          : Gosub EVAL_INFBPR From CALTBD
   For I=1 To NBSITE
    MTDEB  = SIT_CPTDEB(I)
    MTCDT  = SIT_CPTCDT(I)
    If (MTDEB<>0 or MTCDT<>0)
     SITE   = TSITE(I)   : Gosub EVAL_INFSIT From CALTBD
     INDTXM += 1
     TYPMONT = 2
     Gosub ECR_TXM From CALTBD
     If GOK<1 : Break 2 : Endif
    Endif
   Next I
   MTDEB = CPTDEB
   MTCDT = CPTCDT
   If (MTDEB<>0 or MTCDT<>0)
    Raz SITE, TIERS, SITINF, TRSINF
    INDTXM += 1
    TYPMONT = 4
    Gosub ECR_TXM From CALTBD
    If GOK<1 : Break : Endif
   Endif
  Endif
 Endif

 # Cas où valeur saisie en ligne 1 et la formule traitée = 61 62 L1. Il faut mettre à jour SAI_DEB
 For I=1 To NBSITE
  If (SIT_CPTDEB(I)<>0 or SIT_CPTCDT(I)<>0)
   SITE   = TSITE(I)   : Gosub EVAL_INFSIT From CALTBD
   SAI_DEB += SIT_CPTDEB(I)-SIT_CPTCDT(I)
  Endif
 Next I

Next : # Compte
Return


$STO_TXM
M_DBT(I_M) = MTDEB
M_CDT(I_M) = MTCDT
M_FCY(I_M) = SITE
M_ACC(I_M) = COMPTE
M_BPR(I_M) = TIERS
I_M += 1
If I_M>=STOMAX
 GERR = 1
 ER = 99 : GMESSAGE = [F:LBAL]ACC-":"-mess(233,111,1)-num$(STOMAX)
Endif
Return

#########################################################################
## Calcul des montants
#########################################################################
$CALC_MT
If EDEB=EFIN
 PERDEB = PDEB : PERFIN = PFIN
Elsif EXE=EDEB
 PERDEB = PDEB : PERFIN = PMAX
Elsif EXE=EFIN
 PERDEB = 1 : PERFIN = PFIN
 If find([M]TYPMNT(IC),1,2,5) : PERDEB = 0 : Endif
Else
 PERDEB = 1 : PERFIN = PMAX
Endif
Case BALGEN
 When 1
#CHECK FILE_DECLARE BALANCE [BAL]
  Case ENGAGE
   When 0
    If DEVPRN=[F:BAL]CUR
     MTDEB += arr(sum([F:BAL]DEB(PERDEB..PERFIN))*SIGN,AROPRN)
     MTCDT += arr(sum([F:BAL]CDT(PERDEB..PERFIN))*SIGN,AROPRN)
    Elsif DEVPRN=[F:BAL]CURLED & TYPCOURS=0
     MTDEB += arr(sum([F:BAL]DEBLED(PERDEB..PERFIN))*SIGN,AROPRN)
     MTCDT += arr(sum([F:BAL]CDTLED(PERDEB..PERFIN))*SIGN,AROPRN)
    Else
     If TYPCOURS=0 & DEVPRN<>[F:BAL]CURLED
      TYPCOURS = val(func AFNC.PARAM("CNSTYPCUR",[F:BAL]CPY))
     Endif
     Call CONVERT_TAB([F:BAL]CUR,DEVPRN,[F:BAL]CURLED,TYPCOURS,datesyst,[F:BAL]DEB,[F:BAL]DEB,STAT) From TRTDEV
     Call CONVERT_TAB([F:BAL]CUR,DEVPRN,[F:BAL]CURLED,TYPCOURS,datesyst,[F:BAL]CDT,[F:BAL]CDT,STAT) From TRTDEV
     MTDEB += arr(sum([F:BAL]DEB(PERDEB..PERFIN))*SIGN,AROPRN)
     MTCDT += arr(sum([F:BAL]CDT(PERDEB..PERFIN))*SIGN,AROPRN)
    Endif
   When 1
    If DEVPRN=[F:BAL]CURLED & TYPCOURS=0
     MTDEB += arr(sum([F:BAL]CMM(PERDEB..PERFIN))*SIGN,AROPRN) #CHECK IGNORE_LINE
    Else
     If TYPCOURS=0 & DEVPRN<>[F:BAL]CURLED
      TYPCOURS = val(func AFNC.PARAM("CNSTYPCUR",[F:BAL]CPY))
     Endif
     Call CONVERT_TAB([F:BAL]CURLED,DEVPRN,[F:BAL]CURLED,TYPCOURS,datesyst,[F:BAL]CMM,[F:BAL]CMM,STAT) From TRTDEV #CHECK IGNORE_LINE
     MTDEB += arr(sum([F:BAL]CMM(PERDEB..PERFIN))*SIGN,AROPRN)#CHECK IGNORE_LINE
    Endif
   When 2
    If DEVPRN=[F:BAL]CURLED & TYPCOURS=0
     MTDEB += arr(sum([F:BAL]CMMPRP(PERDEB..PERFIN))*SIGN,AROPRN)#CHECK IGNORE_LINE
    Else
     If TYPCOURS=0 & DEVPRN<>[F:BAL]CURLED
      TYPCOURS = val(func AFNC.PARAM("CNSTYPCUR",[F:BAL]CPY))
     Endif
     Call CONVERT_TAB([F:BAL]CURLED,DEVPRN,[F:BAL]CURLED,TYPCOURS,datesyst,[F:BAL]CMMPRP,[F:BAL]CMMPRP,STAT) From TRTDEV #CHECK IGNORE_LINE
     MTDEB += arr(sum([F:BAL]CMMPRP(PERDEB..PERFIN))*SIGN,AROPRN)#CHECK IGNORE_LINE
    Endif
  Endcase
 When 2
  Case ENGAGE
   When 0 : MTDEB += sum([F:BAL]QTY(PERDEB..PERFIN))*SIGN        #CHECK IGNORE_LINE
   When 1 : MTDEB += sum([F:BAL]QTYCMM(PERDEB..PERFIN))*SIGN     #CHECK IGNORE_LINE
   When 2 : MTDEB += sum([F:BAL]QTYCMMPRP(PERDEB..PERFIN))*SIGN  #CHECK IGNORE_LINE
  Endcase
Endcase
Return
