#<AdxTL>@(#)8.0.0.0 $Revision$
#######################################################################################
##                                                                                    #
## Historisation / Epurations pièces comptables  V140    -   Module COMPTABILITE      #
##                                                                                    #
#######################################################################################
#   - GACCENTRY : Historisation / Epuration des pièces comptables                     #
#   - BALANCE   : Historisation / Epuration de la balance générale                    #
#   - BALANA    : Historisation / Epuration de la balance analytique                  #
#   - GCOMMIT   : Historisation / Epuration des engagements                           #
#######################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End


$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "HISTO"    : Gosub HISTO
 When "EPURE"    : Gosub EPURE
 When "FERME"    : Gosub FERME
Endcase
Return

$OUVRE
If clalev([F:FIY]) =0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:HAE]) =0  : Local File GACCENTRY  [HAE]  : Endif
If clalev([F:DAE]) =0  : Local File GACCENTRYD [DAE]  : Endif
If clalev([F:DAE2])=0  : Local File GACCENTRYD [DAE2] : Endif
If clalev([F:GAC]) =0  : Local File GACCOUNT   [GAC]  : Endif
Local Integer OKLET
Return

$HISTO
Case TABLE
 When "GACCENTRY"
  Gosub HISTOHAE
 When "BALANCE" , "BALANA" , "GCOMMIT"
  Gosub VERIF_FIY
Endcase
Return

$VERIF_FIY
Local Integer OKFIY : OKFIY = 0
Filter [FIY] Where CPY=[F:F1]CPY and FIYNUM=[F:F1]FIY
For [FIY]
 OKFIY+=1
 If [F:FIY]FIYSTA<3 : OKFIY=0 : Break : Endif
Next
If OKFIY=0 : OKHIS = 0 : Endif
Return

$VERIF_PER
# Pas d'historisation des écritures ANX
If [F:F1]PER=0 : OKHIS = 0 : Endif
Return

$HISTOHAE
Gosub VERIF_FIY
If !OKHIS  : Return : Endif
Gosub VERIF_PER
If !OKHIS  : Return : Endif

OKLET = 0

Link [DAE] With [GAC]GAC0~=[F:DAE]COA;[F:DAE]ACC
& As [LNK]
& Where [F:DAE]TYP=[F:F1]TYP & [F:DAE]NUM=[F:F1]NUM & [F:GAC]MTC=2

For [LNK]
 # On n'historise pas si la pièce comporte :
 # - une ligne d'écriture non lettrée sur un compte lettrable
 # - ou une ligne d'écriture lettrée en miniscule
 # - ou une écriture lettrée avec une pièce dont la date est supérieure à la date d'historisation

 If [F:DAE]MTC<"A" or [F:DAE]MTC>"ZZZZZ" or [F:DAE]MTCDATMAX>date$-TEMPS
  OKHIS = 0

  # Si on trouve sur la pièce à conserver des lignes lettrées en majuscule et avec une date maximale
  # de lettrage inférieure ou égale à la date jusqu'à laquelle on épure, on met à 1 le champ FLGMTC

  For [DAE2]DAE0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN<>[F:DAE]LIN & MTC<>""
   If [F:DAE2]MTC>"A" & [F:DAE2]MTC<"ZZZZZ" & [F:DAE2]MTCDATMAX<=date$-TEMPS
    [F:DAE2]FLGMTC = 1
    If ![L]SIMUL
     Rewrite [DAE2]
     If fstat
      Call ECR_TRACE(mess(13,100,1)-"GACCENTRYD [DAE2]"-mess(12,107,1)-
&          [F:DAE2]TYP-[F:DAE2]NUM-mess([F:DAE2]LEDTYP,2644,1)-tolower(mess(3,61,1))-num$([F:DAE2]LIN),1) From GESECRAN
     Endif
    Endif
   Endif
  Next
  If OKHIS = 0 : Break : Endif

 Elsif [F:DAE]MTC>"A" and [F:DAE]MTC<"ZZZZZ" and [F:DAE]MTCDATMAX<=date$-TEMPS
  OKLET = 1
 Endif
Next

If OKHIS & OKLET

 # Pièce historisée qui a une écriture lettrée en majuscule avec une pièce X dont la date est inférieure
 # à la date d'historisation. Si cette pièce X est sur un exercie non clôturé, elle ne sera pas
 # historisée. Il faut donc flaguer ses lignes qui resteront dans le dossier d'exploitation
 # pour qu'elles ne soient pas délettrées.Pour savoir si l'écriture est sur un dossier non clôturé
 # il faut faire un Read sur [HAE] + [FIY]=>long. Et si un exercice clos est réouvert, les lignes n'auront
 # pas été flaguées => FLGMTC toujours mis à 1

 For [DAE] Where TYP=[F:F1]TYP & NUM=[F:F1]NUM & MTC>"A" & [F:DAE]MTC<"ZZZZZ" & [F:DAE]MTCDATMAX<=date$-TEMPS

  For [DAE2]DAE6 Where LEDTYP=[F:DAE]LEDTYP & ACC=[F:DAE]ACC & BPR=[F:DAE]BPR & MTC=[F:DAE]MTC & (TYP<>[F:DAE]TYP | NUM<>[F:DAE]NUM)
   [F:DAE2]FLGMTC = 1
   If ![L]SIMUL
    Rewrite [DAE2]
    If fstat
     Call ECR_TRACE(mess(13,100,1)-"GACCENTRYD [DAE2]"-mess(12,107,1)-
&              [F:DAE2]TYP-[F:DAE2]NUM-tolower(mess(3,61,1))-num$([F:DAE2]LIN),1) From GESECRAN
    Endif
   Endif
  Next
 Next
Endif
Return

$EPURE
# Même contrôle que l'historisation
Local Integer SVG_OKHIS
SVG_OKHIS = OKHIS
OKHIS = OKEPU
Gosub HISTO
OKEPU = OKHIS
OKHIS = SVG_OKHIS
Return

$FERME
Case TABLE
 When "GACCENTRY" , "BALANCE" , "BALANA" , "GCOMMIT"
  If clalev([F:FIY])>0 : Close Local File [FIY] : Endif
Endcase
Return
