#<AdxTL>@(#)3.0.0.0 $Revision$
####################################################################################
####################################################################################
### DVPB0 = DCLTYP+RECTYP+DCLNUM+NUM+LIN+DCLFLD+DCLPAG
### DCLTYP, DCLNUM feeded on CALVATPOR
### DCLFLD not feeded (just anual declaration)
### DCLPAG not feeded (just anual declaration)
### RECTYP feeded on CALVATPORA
####################################################################################
####################################################################################
$MAIN
Raz [L]DAELIN
Case [L]RECTYP
  When 2

    If [F:JOU]TYP = 1

      [L]SNS = -1

      Gosub GET_EECNUM From CALVATPOR

      If [L]EECNUM = "" | (len([L]EECNUM)>2 & left$([L]EECNUM, 2) <> "PT") | [F:BPR]LEGETT = 2 : Return : Endif

      #Link [F:DAER] With [F:GACR]GAC0=[L]COA;[F:DAER]ACC As [LDAER] Where [F:GACR]FLGVAT=3
      Link [F:DAER] With [F:GACR]GAC0=[L]COA;[F:DAER]ACC As [LDAER] Where [F:GACR]FLGVAT=2

#      For [LDAER] Where [F:DAER]TYP=[F:HAE]TYP & [F:DAER]NUM=[F:HAE]NUM & [F:DAER]LEDTYP= [F:DVPP]LEDTYP &
#&                 !pat([F:DAER]ACC,[F:DVPP]RCAEXNROT1+string$(len([F:DVPP]RCAEXNROT1)=0,"\")+"*") & !pat([F:DAER]ACC,[F:DVPP]RCAEXNROT2+string$(len([F:DVPP]RCAEXNROT2)=0,"\")+"*") &
#&                 !pat([F:DAER]ACC,[F:DVPP]RCAEXNROT3+string$(len([F:DVPP]RCAEXNROT3)=0,"\")+"*") & !pat([F:DAER]ACC,[F:DVPP]RCAEXNROT4+string$(len([F:DVPP]RCAEXNROT4)=0,"\")+"*")

      For [LDAER] Where [F:DAER]TYP=[F:HAE]TYP & [F:DAER]NUM=[F:HAE]NUM & [F:DAER]LEDTYP= [F:DVPP]LEDTYP & !find([F:DAER]TAX, TAXIGNORE)

        Gosub WRITE_DVPB

        #Gosub WRITE_BASE_FROM_VAT
        Gosub WRITE_VAT_FROM_BASE

      Next

      Close File [LDAER]

    Endif

  When 3

    If [F:JOU]TYP = 2

      [L]SNS = 1
      Raz MULEECNUMFLG

      Gosub GET_EECNUM From CALVATPOR

      If [L]EECNUM = "" | (len([L]EECNUM)>2 & left$([L]EECNUM, 2) <> "PT") : Return : Endif

      If [F:DVPH]MULEECNUMPUR = 2 & ![L]EXCACCFLG : Gosub CHECK_MULEECNUM From CALVATPOR : Endif

      If ![L]MULEECNUMFLG
        #Link [F:DAER] With [F:GACR]GAC0=[L]COA;[F:DAER]ACC As [LDAER] Where [F:GACR]FLGVAT=3
        Link [F:DAER] With [F:GACR]GAC0=[L]COA;[F:DAER]ACC As [LDAER] Where [F:GACR]FLGVAT=2

#        For [LDAER] Where [F:DAER]TYP=[F:HAE]TYP & [F:DAER]NUM=[F:HAE]NUM & [F:DAER]LEDTYP= [F:DVPP]LEDTYP &
#&                 !pat([F:DAER]ACC,[F:DVPP]RCAEXNROT1+string$(len([F:DVPP]RCAEXNROT1)=0,"\")+"*") & !pat([F:DAER]ACC,[F:DVPP]RCAEXNROT2+string$(len([F:DVPP]RCAEXNROT2)=0,"\")+"*") &
#&                 !pat([F:DAER]ACC,[F:DVPP]RCAEXNROT3+string$(len([F:DVPP]RCAEXNROT3)=0,"\")+"*") & !pat([F:DAER]ACC,[F:DVPP]RCAEXNROT4+string$(len([F:DVPP]RCAEXNROT4)=0,"\")+"*")

        For [LDAER] Where [F:DAER]TYP=[F:HAE]TYP & [F:DAER]NUM=[F:HAE]NUM & [F:DAER]LEDTYP= [F:DVPP]LEDTYP & !find([F:DAER]TAX, TAXIGNORE)

          Gosub WRITE_DVPB

          #Gosub WRITE_BASE_FROM_VAT
          Gosub WRITE_VAT_FROM_BASE

        Next

        Close File [LDAER]
      Else

        Gosub WRITE_FROM_PIH From CALVATPOR

      Endif

    Endif
Endcase

Return
#################################################################################################
#################################################################################################
#$WRITE_BASE_FROM_VAT
#
#Link [F:DAE2] With [F:GAC2]GAC0=[L]COA;[F:DAE2]ACC As [LDAE2] Where [F:GAC2]FLGVAT=2
#
#Gosub WRITE_DVPB2
#
#Close File [LDAE2]
#
#Return
#################################################################################################
#################################################################################################
$WRITE_VAT_FROM_BASE

Link [F:DAE2] With [F:GAC2]GAC0=[L]COA;[F:DAE2]ACC As [LDAE2] Where [F:GAC2]FLGVAT=3 &
&                 !pat([F:DAE2]ACC,[F:DVPP]RCAEXNROT1+string$(len([F:DVPP]RCAEXNROT1)=0,"\")+"*") & !pat([F:DAE2]ACC,[F:DVPP]RCAEXNROT2+string$(len([F:DVPP]RCAEXNROT2)=0,"\")+"*") &
&                 !pat([F:DAE2]ACC,[F:DVPP]RCAEXNROT3+string$(len([F:DVPP]RCAEXNROT3)=0,"\")+"*") & !pat([F:DAE2]ACC,[F:DVPP]RCAEXNROT4+string$(len([F:DVPP]RCAEXNROT4)=0,"\")+"*") &
&                 !find([F:DAE2]TAX, TAXIGNORE)

Gosub WRITE_DVPB2

Close File [LDAE2]

Return
##################################################################################################
##################################################################################################
$WRITE_DVPB2

I = dim([L]DAELIN,3)
II = val([L]DCLFLD)

For [LDAE2] Where [F:DAE2]TYP=[F:DAER]TYP & [F:DAE2]NUM=[F:DAER]NUM & [F:DAE2]LIN<>[F:DAER]LIN & [F:DAE2]LEDTYP=[F:DAER]LEDTYP & [F:DAE2]TAX=[F:DAER]TAX &
&                 !find([F:DAE2]LIN, [L]DAELIN([L]DCLPAG,II,1..I))

  Raz [F:DVPB]

  [F:DVPB]DCLTYP    = [L]DCLTYP
  [F:DVPB]DCLPAG    = [L]DCLPAG
  [F:DVPB]DCLNUM    = [L]DCLNUM
  [F:DVPB]NUM       = [F:DAE2]NUM
  [F:DVPB]LIN       = [F:DAE2]LIN
  [F:DVPB]ACC       = [F:DAE2]ACC
  #[F:DVPB]AMTBAS    = [F:DAE2]AMTLED*[F:DAE2]SNS*[L]SNS
  [F:DVPB]AMTVAT    = [F:DAE2]AMTLED*[F:DAE2]SNS*[L]SNS
  [F:DVPB]ACCDAT    = [F:DAE2]ACCDAT
  [F:DVPB]VAT       = [F:DAE2]TAX
  [F:DVPB]DCLFLDTYP = 2
  [F:DVPB]EECNUM    = [L]EECNUM
  [F:DVPB]RECTYP    = [L]RECTYP    #recap type, 2-clients, 3- suppliers

  Write [F:DVPB]
  If fstat : GOK = 0 : Call FSTA("DVPB") From GLOCK : Break : Endif
  I = dim([L]DAELIN,3)
  II = val([L]DCLFLD)
  [L]DAELIN([L]DCLPAG, II,find(0, [L]DAELIN([L]DCLPAG,II,1..I))) = [F:DAE2]LIN

Next

Return
##################################################################################################
##################################################################################################
$WRITE_DVPB

Raz [F:DVPB]

[F:DVPB]DCLTYP    = [L]DCLTYP
[F:DVPB]DCLPAG    = [L]DCLPAG
[F:DVPB]DCLNUM    = [L]DCLNUM
[F:DVPB]NUM       = [F:DAER]NUM
[F:DVPB]LIN       = [F:DAER]LIN
[F:DVPB]ACC       = [F:DAER]ACC
#[F:DVPB]AMTVAT    = [F:DAER]AMTLED*[F:DAER]SNS*[L]SNS
[F:DVPB]AMTBAS    = [F:DAER]AMTLED*[F:DAER]SNS*[L]SNS
[F:DVPB]ACCDAT    = [F:DAER]ACCDAT
[F:DVPB]VAT       = [F:DAER]TAX
[F:DVPB]DCLFLDTYP = 2
[F:DVPB]EECNUM    = [L]EECNUM
[F:DVPB]RECTYP    = [L]RECTYP    #recap type, 2-clients, 3- suppliers

Write [F:DVPB]
If fstat : GOK = 0 : Call FSTA("DVPB") From GLOCK : Return : Endif

Return
#################################################################################################
#################################################################################################
$PROC_LISTS

[L]RECTYP = 2
[L]LINTYP = 21
[L]MINVAL = [F:DVPP]MAXAMTSALA
Gosub PROC_LIST

[L]RECTYP = 3
[L]LINTYP = 22
[L]MINVAL = [F:DVPP]MAXAMTPURA
Gosub PROC_LIST

Return
##################################################################################################
##################################################################################################
$PROC_LIST

Filter [F:DVPB] Where [F:DVPB]RECTYP = [L]RECTYP & [F:DVPB]DCLNUM = [L]DCLNUM Order By Key LKEY = EECNUM

Raz [L]EECNUM, [L]MON, [L]AMTBAS, [L]AMTVAT, [L]RCOUNT, [L]EXPIMPVCR

For [F:DVPB]
  If [F:DVPB]EECNUM <> [L]EECNUM
    If [L]AMTBAS + [L]AMTVAT<> 0
      Gosub  WRITE_DVPL : If GOK = 0 : Break : Endif
      [L]AMTBAS = 0
      [L]AMTVAT = 0
    Endif
  Endif
  [L]AMTBAS += [F:DVPB]AMTBAS
  [L]AMTVAT += [F:DVPB]AMTVAT
  [L]EECNUM  = [F:DVPB]EECNUM
Next

If GOK = 0 : Filter [F:DVPB]: Return : Endif
If [L]AMTBAS + [L]AMTVAT <> 0 : Gosub  WRITE_DVPL : Endif
Filter [F:DVPB]
If GOK = 0 : Return : Endif

Return
##################################################################################################
##################################################################################################
$WRITE_DVPL

If [L]AMTBAS + [L]AMTVAT >=  [L]MINVAL
  Raz [F:DVPL]
  [L]RCOUNT += 1

  [F:DVPL]AMTBAS = int([L]AMTBAS + [L]AMTVAT)
  [F:DVPL]DCLNUM = [L]DCLNUM
  [F:DVPL]EECNUM = [L]EECNUM
  [F:DVPL]LSTLIN = [L]RCOUNT
  [F:DVPL]LINTYP = [L]LINTYP

  Write [DVPL]
  If fstat : GOK=0 : Call FSTA("DVPL") From GLOCK : Endif

Endif

Return
#################################################################################################
#################################################################################################

