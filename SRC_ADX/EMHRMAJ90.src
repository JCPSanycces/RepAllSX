#<AdxTL>@(#)0.0.0.0 $Revision$
# < DEBUG> ###############################################################################################
Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [F:ADS]
Read [F:ADS]DOSSIER = "QAHRMV9ZAF"
If !fstat
    Call AMAJ
    Call MAJ
Endif
Call SUPP_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End
# </DEBUG> ###############################################################################################

#before validation of elements
#Update X3 People version 9 to version 12
Subprog AMAJ

  If GTRACE = ""
    Call OUVRE_TRACE("AMAJ scripts - U9 TO V12") From LECFIC
  Endif
  Call UTI_MOUL([F:ADS]DOSSIER) From EMHRMAJ90_FLD
  Call UTI_MOUL([F:ADS]DOSSIER) From EMHRMAJ90_TXT
  Call UTI_MOUL([F:ADS]DOSSIER) From EMHRMAJ90_TBLABBR
  Call UTI_MOUL([F:ADS]DOSSIER) From EMHRMAJ90_LMRNG
  Call UTI_MOUL([F:ADS]DOSSIER) From EMHRMAJ90_MSCRNG
  Call UTI_MOUL([F:ADS]DOSSIER) From EMHRMAJ90_DT

End

#after validation of elements
Subprog MAJ

  If GTRACE = ""
    Call OUVRE_TRACE("MAJ scripts - U9 TO V12") From LECFIC
  Endif
  Call UTI_MOUL([F:ADS]DOSSIER) From EMHRMAJ90_TBL
  Call UTI_MOUL([F:ADS]DOSSIER) From EMHRMAJ90_MSCOBJ
  Call UTI_MOUL([F:ADS]DOSSIER) From EMHRMAJ90_PARAMS
  Call UTI_MOUL([F:ADS]DOSSIER) From EMHRMAJ90_EMPCTR
  Call UTI_MOUL([F:ADS]DOSSIER) From EMHRMAJ90_HRTABLE
  Call UTI_MOUL([F:ADS]DOSSIER) From EMHRMAJ90_LMNUMBERS
  Call UTI_MOUL([F:ADS]DOSSIER) From EMHRMAJ90_PERIOD

End

