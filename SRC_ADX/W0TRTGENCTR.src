   If vireblc([M]FCY,2)=""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "ACONTFCY"
    Call CONTSITE([M]FCY) From SUBAGF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     Call CONTROLE("FCY","P",[M]FCY,"",mkstat) From CONTOBJ
     If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "CONTFCY"
      Call CONTFCY([M]FCY) From EXEFNC
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
      If !mkstat
       SAVACT = GACTION : GACTION = "CONTFCYCPY"
       Call CONTFCYCPY([M]FCY,[M]CPY) From EXEFNC
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
       If !mkstat
        SAVACT = GACTION : GACTION = "STD"
        Call C_FCY([M]FCY) From TRTGENCTR
        GACTION = SAVACT
        If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
        Gosub AFF From GSAISIE
        If mkstat : End : Endif
        If !mkstat
         If WCHAR<>[M]FCY or IMPMOD
          SAVACT = GACTION : GACTION = "BMFCY"
          Call AM_FCY([M]FCY) From DIVPAYE
          GACTION = SAVACT
          If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
          Gosub AFF From GSAISIE
          If mkstat : End : Endif
          If !mkstat
           SAVACT = GACTION : GACTION = "STD"
           Call AM_FCY([M]FCY) From TRTGENCTR
           GACTION = SAVACT
           If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
           Gosub AFF From GSAISIE
           If mkstat : End : Endif
          Endif
         Endif
        Endif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]LEG,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
