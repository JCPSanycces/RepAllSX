#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TRTGENCTR 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone ALLCPY
mkstat = 0
zoncou = "ALLCPY"
indice = 0
IMPENT = [M]ALLCPY
WNUM = IMPENT
SAVACT = GACTION : GACTION = "STD"
Call AV_ALLCPY(IMPENT) From TRTGENCTR
GACTION = SAVACT
If mkstat=1 : Raz IMPENT : Endif
If !mkstat
 If varinit([M]ALLCPY,indice)=0
  IMPENT = 2
 Endif
Endif
If varmode([M]ALLCPY,indice)=0
 SAVACT = GACTION : GACTION = "BSALLCPY"
 Call AS_ALLCPY(IMPENT) From DIVPAYE
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]ALLCPY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ALLCPY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ALLCPY(indice)
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CALLCPY"
  Call C_ALLCPY(IMPENT) From DIVPAYE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ALLCPY" : GZNUM = 6052 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>IMPENT or IMPMOD
    SAVACT = GACTION : GACTION = "BMALLCPY"
    Call AM_ALLCPY(IMPENT) From DIVPAYE
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "ALLCPY" : GZNUM = 6052 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif
[M]ALLCPY = IMPENT

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
WCHAR = [M]CPY
If varmode([M]CPY,indice)=0
 SAVACT = GACTION : GACTION = "BSCPY"
 Call AS_CPY([M]CPY) From DIVPAYE
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CPY : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "INICPY"
  Call INICPY([M]CPY) From EXEFNC
  GACTION = SAVACT
  If mkstat=1 : Raz [M]CPY : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   If vireblc([M]CPY,2)=""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "ACONTCPY"
    Call CONTSOC([M]CPY) From SUBAGF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     Call CONTROLE("CPY","A",[M]CPY,"",mkstat) From CONTOBJ
     If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "STD"
      Call C_CPY([M]CPY) From TRTGENCTR
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
      If !mkstat
       SAVACT = GACTION : GACTION = "CONTCPY"
       Call CONTCPY([M]CPY) From EXEFNC
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
       If !mkstat
        If WCHAR<>[M]CPY or IMPMOD
         SAVACT = GACTION : GACTION = "BMCPY"
         Call AM_CPY([M]CPY) From DIVPAYE
         GACTION = SAVACT
         If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
         Gosub AFF From GSAISIE
         If mkstat : End : Endif
        Endif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

