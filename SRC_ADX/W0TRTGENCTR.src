 If !mkstat
  SAVACT = GACTION : GACTION = "AFMTCONT"
  Call CONTROLE([M]DOCFINA,"M",[M]NOLIB,20,[M]VALFININT) From FMTVAR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DOCFINA" : GZNUM = 51437 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACONTACL"
   Call CONTACL([M]VALFININT,"M","","") From SUBACL
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DOCFINA" : GZNUM = 51437 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_DOCFINA([M]DOCFINA) From TRTGENCTR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "DOCFINA" : GZNUM = 51437 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]DOCFINA or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_DOCFINA([M]DOCFINA) From TRTGENCTR
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "DOCFINA" : GZNUM = 51437 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone FLGUPD
mkstat = 0
zoncou = "FLGUPD"
indice = 0
IMPENT = [M]FLGUPD
If varinit([M]FLGUPD,indice)=0
 IMPENT = 2
Endif
If varmode([M]FLGUPD,indice)=0
 [M]FLGUPD(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGUPD" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGUPD(indice)
 Endif
Endif
[M]FLGUPD = IMPENT

## Zone FLGPRN
mkstat = 0
zoncou = "FLGPRN"
indice = 0
IMPENT = [M]FLGPRN
If varinit([M]FLGPRN,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGPRN,indice)=0
 [M]FLGPRN(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGPRN" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGPRN(indice)
 Endif
Endif
[M]FLGPRN = IMPENT

## Zone WLEG
mkstat = 0
zoncou = "WLEG"
indice = 0
If varinit([M]WLEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]WLEG,"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone INI
mkstat = 0
zoncou = "INI"
indice = 0
If varinit([M]INI,indice)=0
 SAVACT = GACTION : GACTION = "INICRIDIA"
 GACTION = SAVACT
 Gosub GRISE From DIVPAYE
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "TRTGENCTR"
Return

