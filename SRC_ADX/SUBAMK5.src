#<AdxTL>@(#)2.0.0.0 $Revision$
###############################################################
## SUBAMK5    Saisie des caractéristiques graphiques d'un bloc
###############################################################

$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "DEBUT"       : Gosub DEBUT
  When "SETBOUT"     : Gosub SETBOUT
  When "FIN"         : Gosub FIN
  When "OK"          : Gosub OK
  When "ABANDON"     : Gosub ABANDON
  When "APRES_MODIF" : Gosub APMODIF
Endcase
Return


$APMODIF
  REP="M"
Return

$OUVRE
If zoncou="TYPBLOC" 
  If VALEUR<>8 : FIN=1 : Endif
Else
  If [M:AMK1]TYPBLOC(val(PARAM(1)))<>8 : FIN=1 : Endif
Endif
Return

$DEBUT
[M:AMK5]NOLTBL=val(PARAM(1))
$RECHARG
Raz [M:AMK5]CODURL1,URL1,INTURL1,CODURL2,URL2,INTURL2,CODURL3,URL3,INTURL3
Local Integer NLI : NLI=[M:AMK5]NOLTBL
# Charge les champs stockés dans AMK1
If clalev([F:AUR])=0 : Local File AURL [AUR] : Endif
[M:AMK5]CODURL1=[M:AMK1]BLOCLIEN1(NLI)
If [M:AMK5]CODURL1<>""
  Read [AUR]AUR0=[M:AMK5]CODURL1
  If fstat=0
    Call TEXTE([F:AUR]INTIT,[M]INTURL1) From OBJDIV
    [M]URL1=[F:AUR]URL
  Endif
Endif
[M:AMK5]CODURL2=[M:AMK1]BLOCLIEN2(NLI)
If [M:AMK5]CODURL2<>""
  Read [AUR]AUR0=[M:AMK5]CODURL2
  If fstat=0
    Call TEXTE([F:AUR]INTIT,[M]INTURL2) From OBJDIV
    [M]URL2=[F:AUR]URL
  Endif
Endif
[M:AMK5]CODURL3=[M:AMK1]BLOCLIEN3(NLI)
If [M:AMK5]CODURL3<>""
  Read [AUR]AUR0=[M:AMK5]CODURL3
  If fstat=0
    Call TEXTE([F:AUR]INTIT,[M]INTURL3) From OBJDIV
    [M]URL3=[F:AUR]URL
  Endif
Endif
Affzo [M:AMK5]
Return



$OK
#   On recharge les valeurs dans AMK1
Local Integer NLI : NLI=[M:AMK5]NOLTBL
[M:AMK1]BLOCLIEN1(NLI)=[M:AMK5]CODURL1
[M:AMK1]BLOCLIEN2(NLI)=[M:AMK5]CODURL2
[M:AMK1]BLOCLIEN3(NLI)=[M:AMK5]CODURL3
mkstat=4
Return


$SETBOUT
Return

$ABANDON
REP=""
Gosub RECHARG
Return

$FIN
  REP=""
Return






# Gestion du masque AMK5

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran AMK5) 28/06/2005 15:14:42 (CCORA)
######################################################################################
Subprog AM_CODURL1(VALEUR)
Variable Char    VALEUR()
If clalev([F:AUR])=0 : Local File AURL [AUR] : Endif
Raz [M]URL1,INTURL1
Read [AUR]AUR0=VALEUR
If fstat=0
  Call TEXTE([F:AUR]INTIT,[M]INTURL1) From OBJDIV
  [M]URL1=[F:AUR]URL
Endif
Affzo [M]URL1,INTURL1
End

Subprog AS_CODURL2(VALEUR)
Variable Char    VALEUR()
If [M]CODURL1="" 
  Raz [M]URL2,INTURL2
  Affzo [M]URL2,INTURL2
  mkstat=1 
Endif
End

Subprog AM_CODURL2(VALEUR)
Variable Char    VALEUR()
If clalev([F:AUR])=0 : Local File AURL [AUR] : Endif
Raz [M]URL2,INTURL2
Read [AUR]AUR0=VALEUR
If fstat=0
  Call TEXTE([F:AUR]INTIT,[M]INTURL2) From OBJDIV
  [M]URL2=[F:AUR]URL
Endif
Affzo [M]URL2,INTURL2
End

Subprog AS_CODURL3(VALEUR)
Variable Char    VALEUR()
If [M]CODURL2="" :
 Raz [M]URL3,INTURL3
 Affzo [M]URL3,INTURL3
 mkstat=1 
Endif
End

Subprog AM_CODURL3(VALEUR)
Variable Char    VALEUR()
If clalev([F:AUR])=0 : Local File AURL [AUR] : Endif
Raz [M]URL3,INTURL3
Read [AUR]AUR0=VALEUR
If fstat=0
  Call TEXTE([F:AUR]INTIT,[M]INTURL3) From OBJDIV
  [M]URL3=[F:AUR]URL
Endif
Affzo [M]URL3,INTURL3
End


######################################################################################

