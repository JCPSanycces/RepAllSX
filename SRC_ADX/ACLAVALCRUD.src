#-------------------------------------------------------#
#  Subprog DE VALIDATION DES CLASSES PERSITANTES
#-------------------------------------------------------#
Subprog CRUD_CLASSE(DOSSIER,CODCLA,ACLA,AERR)
Value Char DOSSIER , CODCLA
Variable  Instance  ACLA  Using C_ACLA
Variable  Instance  AERR(1..) Using C_AERROR
Gosub DEFVAR
Local Integer OK,IFSQL
Call STC_VERF(ACLA.ACLAV.TRTCRUD,ACLA.ACLAV.IDENTWML,APPLI,MACHINE,"TRT",OK,AERR) From ACLASUB
If OK

 For MT=1 To maxtab(ACLA.ACLAT)

  Raz CLOB
  Case ACLA.ACLAT(MT).CODMETSTD
   When "C"
    IFSQL = 1
    Gosub TRT_WRITE From ACLAWRITECRUD
    Call STC_DEB(APPLI,MACHINE,ACLA.ACLAV.TRTCRUDCRE,ACLA.ACLAV.IDENTWML,[L]CODCLA,ACLA.INTITCLA,ACLA.ACLAV.MAGIC,ACLA.ACLAV.TITETA,"TRT") From ACLASUB
    Call TRT_FIN(CLOB,ACLA.ACLAV.TRTCRUDCRE,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
    If maxtab(AERR)>0 : Break : Endif

   When "R"

    Gosub TRT_TEST
    Gosub TRT_READ_ETAG From ACLAREADCRUD
    Gosub TRT_READ_SUPER From ACLAREADCRUD
    Gosub TRT_READ From ACLAREADCRUD
    Call STC_DEB(APPLI,MACHINE,ACLA.ACLAV.TRTCRUDREAD,ACLA.ACLAV.IDENTWML,[L]CODCLA,ACLA.INTITCLA,ACLA.ACLAV.MAGIC,ACLA.ACLAV.TITETA,"TRT") From ACLASUB
    Call TRT_FIN(CLOB,ACLA.ACLAV.TRTCRUDREAD,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
    If maxtab(AERR)>0 : Break : Endif

   When "U"
    IFSQL = 1
    Gosub TRT_REWRITE From ACLAREWRITECRUD
    Call STC_DEB(APPLI,MACHINE,ACLA.ACLAV.TRTCRUDUPD,ACLA.ACLAV.IDENTWML,[L]CODCLA,ACLA.INTITCLA,ACLA.ACLAV.MAGIC,ACLA.ACLAV.TITETA,"TRT") From ACLASUB
    Call TRT_FIN(CLOB,ACLA.ACLAV.TRTCRUDUPD,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
    If maxtab(AERR)>0 : Break : Endif

   When "D"
    IFSQL = 1
    Gosub TRT_DELETE From ACLADELETECRUD
    Call STC_DEB(APPLI,MACHINE,ACLA.ACLAV.TRTCRUDDEL,ACLA.ACLAV.IDENTWML,[L]CODCLA,ACLA.INTITCLA,ACLA.ACLAV.MAGIC,ACLA.ACLAV.TITETA,"TRT") From ACLASUB
    Call TRT_FIN(CLOB,ACLA.ACLAV.TRTCRUDDEL,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
    If maxtab(AERR)>0 : Break : Endif

  Endcase
 Next
 If maxtab(AERR)>0 : End : Endif

 Gosub TRT_MASTERCRUD
 If maxtab(AERR)>0 : End : Endif
Endif
Gosub CLOSE_FILE From ACLAVALLEC
End

#-------------------------------------------------------#
$DEFVAR
Local Char    MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Integer OK,NBPRG

Gosub OPEN_FILE From ACLAVALLEC
Gosub DEFVAR From ACLAVALLEC

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

# Crud Gestion only
Local Schar     ATBDES(80) , ATBORI(80)
Local Char      TABPARCOURS(100)(1..50)
Local Integer   NIVPARCOURS,ISFOR,NBFOR
Local Char      WCLE1(250),WCLE2(250),WCHAMP(250),WTABLE(250),WLANGUE(80)
Local Char      WSTRUC(30)(1..50),WSTRABR(20)(1..50),WCLALNK(20)(1..50)
Local Schar     ROOTCLA(GLONASW+1+GLONABR),TYPCRUD,ROOTNAM(GLONACLA+2)
[L]ROOTCLA = ACLA.ACLAK(1).CLALNK
[L]TYPCRUD = "CLA"
[L]ROOTNAM = [L]CODCLA
Return

