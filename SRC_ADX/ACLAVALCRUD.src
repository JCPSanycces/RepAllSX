#-------------------------------------------------------#
$ERFIC
ER = errn
Resume

#-------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$ADDCLB0
Append CLOB,LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$TRT_ACONTROL
LIGNE = "############################################################################################" : Gosub ADDCLB
LIGNE = "# Funprog ACONTROL"
LIGNE = "############################################################################################" : Gosub ADDCLB
LIGNE = "Funprog ACONTROL(WCLA,ASTATUS,ALEVEL)" : Gosub ADDCLB
LIGNE = "Variable Instance WCLA Using OBJECT"  : Gosub ADDCLB
LIGNE = "Value Integer ASTATUS" : Gosub ADDCLB
LIGNE = "Value Integer ALEVEL" : Gosub ADDCLB
LIGNE = "Local Integer ARETURN" : Gosub ADDCLB
LIGNE = 'If ([L]ASTATUS=[V]CST_AERROR) or ([L]ALEVEL>0 & this<>null & fmet this.AGETMAXERROR("")>=[V]CST_AERROR)' : Gosub ADDCLB
DIF += 1
LIGNE = '[L]ARETURN=[V]CST_AERROR ' : Gosub ADDCLB
DIF -= 1
LIGNE = 'Endif' : Gosub ADDCLB
LIGNE = 'End ARETURN' : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Entete avec tous les subprog du trt
#-------------------------------------------------------#
$TRT_MASTERCRUD
If ACLA.TEST : Call ECR_TRACE("- Create TRT CRUD"-ACLA.ACLAV.TRTCRUD,0) From GESECRAN  : Endif
Raz CLOB

Gosub TRT_ENTETE
Gosub TRT_AVARIABLES
If ACLA.TYPCLA=2 : Gosub TRT_LINK : Endif
If ACLA.TYPCLA=2 & IFSQL>0
 Gosub TRT_MAJSQL From ACLASUBMAJCRUD
Endif
Call STC_DEB(APPLI,MACHINE,ACLA.ACLAV.TRTCRUD,ACLA.ACLAV.IDENTWML,[L]CODCLA,ACLA.INTITCLA,ACLA.ACLAV.MAGIC,ACLA.ACLAV.TITETA,"TRT") From ACLASUB
Call TRT_FIN(CLOB,ACLA.ACLAV.TRTCRUD,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
Return

#-------------------------------------------------------#
# Entete avec tous les subprog du trt
#-------------------------------------------------------#
$TRT_ENTETE
Raz CLOB
DIF=0
For MT=1 To maxtab(ACLA.ACLAT)
 If ACLA.ACLAT(MT).CODMETSTD= "R" & ACLA.TYPCLA=2 : LIGNE = "Gosub TEST From "+ACLA.ACLAV.TRTCRUDREAD+" : End" : Gosub ADDCLB : Endif
Next
LIGNE = "" : Gosub ADDCLB
LIGNE = "############################################################################################" : Gosub ADDCLB
For MT=1 To maxtab(ACLA.ACLAT)
 Case ACLA.ACLAT(MT).CODMETSTD
  When "C" : LIGNE = "## C : Subprog "+[V]CST_APRGAINSERT+"(INSTANCE)"  : Gosub ADDCLB
  When "R" : LIGNE = "## R : Subprog "+[V]CST_APRGAREAD+"(INSTANCE"
   For I=1 To ACLA.NBCLEREF : LIGNE += ","+ACLA.ACLAI(I).CLEREF : Next : LIGNE += ")"  : Gosub ADDCLB
  When "U" : LIGNE = "## U : Subprog "+[V]CST_APRGAUPDATE+"(INSTANCE)" : Gosub ADDCLB
  When "D" : LIGNE = "## D : Subprog "+[V]CST_APRGADELETE+"(INSTANCE)" : Gosub ADDCLB
 Endcase
Next
LIGNE = "############################################################################################" : Gosub ADDCLB
For I=1 To maxtab(ACLA.ACLAK)
 LIGNE = "#"-ACLA.ACLAK(I).CLALNK-":  "- ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).TABLNK : Gosub ADDCLB
Next I
LIGNE = "############################################################################################" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Etiquette de test rapide
#-------------------------------------------------------#
$TRT_TEST
DIF=0
If ACLA.TYPCLA<>2 : Return : Endif
LIGNE = "" : Gosub ADDCLB
LIGNE = "Gosub TEST : End" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "############################################################################################" : Gosub ADDCLB
LIGNE = "# Program TEST" : Gosub ADDCLB
LIGNE = "############################################################################################" : Gosub ADDCLB
LIGNE = "$TEST": Gosub ADDCLB
OK =0
 For I=1 To maxtab(ACLA.ACLAT)
  Case ACLA.ACLAT(I).CODMETSTD
   When "R" : OK = 1
  Endcase
 Next
If !OK
 LIGNE = "Return" : Gosub ADDCLB
 Return
Endif
LIGNE = "Local Integer SILENCE"  : Gosub ADDCLB
#LIGNE = "adxmpr = adxmpr"  : Gosub ADDCLB
LIGNE = 'Call OUVRE_TRACE("Test program")From LECFIC' : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
LIGNE = "Gosub ATRT_TEST" : Gosub ADDCLB

LIGNE = '' : Gosub ADDCLB
LIGNE = 'Call LEC_TRACE From LECFIC' : Gosub ADDCLB
LIGNE = 'Call SUPP_TRACE From LECFIC' : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB

LIGNE = "Return" : Gosub ADDCLB
LIGNE = "": Gosub ADDCLB
LIGNE = "#---------------------------------------------------------------#" : Gosub ADDCLB
LIGNE ="$ATRT_TEST" : Gosub ADDCLB
LIGNE = "Local Integer ASTATUS" : Gosub ADDCLB
LIGNE = 'If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif' : Gosub ADDCLB
LIGNE = 'Local File '+ACLA.ACLAK(1).TABLNK-"["+ACLA.ACLAK(1).ABRLNK+"_]" : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
LIGNE = 'If !SILENCE : Call TRACE("2 --> Local Instance '+ACLA.ACLAV.NOMSTC+'") From ASYRCOM : Endif' : Gosub ADDCLB
LIGNE = 'Local Instance '+[L]ROOTNAM+' Using '+ACLA.ACLAV.NOMSTC : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
LIGNE = 'If !SILENCE : Call TRACE("3 --> New Instance '+ACLA.ACLAV.NOMSTC+'") From ASYRCOM : Endif' : Gosub ADDCLB
LIGNE = [L]ROOTNAM+' = NewInstance '+ACLA.ACLAV.NOMSTC-[V]CST_ALLOCGROUP-'null'  : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
LIGNE = 'If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif' : Gosub ADDCLB
LIGNE = 'Read ['+ACLA.ACLAK(1).ABRLNK+'_]'+ACLA.ACLAK(1).CLELNK+' First' : Gosub ADDCLB
LIGNE = 'If !fstat' : Gosub ADDCLB
LIGNE = ' If !SILENCE : Call TRACE("Call program read of '+ACLA.ACLAK(1).CLALNK+'") From ASYRCOM : Endif' : Gosub ADDCLB
LIGNE = ' [L]ASTATUS = max([L]ASTATUS,fmet '
If [L]TYPCRUD = "CLA"
 LIGNE += ACLA.ACLAK(1).CLALNK+'.'+[V]CST_APRGAREAD
Else
 LIGNE += ASHW.CODREP+'.'+[V]CST_APRGAREAD
Endif
LIGNE +='('+"["+ACLA.ACLAK(1).ABRLNK+"_]"+ACLA.ACLAK(1).INDEX(1)
For I=2 To ACLA.ACLAK(1).NBRIND
 LIGNE += ",["+ACLA.ACLAK(1).ABRLNK+"_]"+ACLA.ACLAK(1).INDEX(I)
Next
LIGNE += "))" : Gosub ADDCLB
LIGNE = 'Endif' : Gosub ADDCLB
LIGNE = '' : Gosub ADDCLB
LIGNE = 'If !SILENCE' : Gosub ADDCLB
DIF += 1
LIGNE = 'Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM' : Gosub ADDCLB
For I=1 To ACLA.ACLAK(1).NBRIND
 For J=1 To maxtab(ACLA.ACLAF)
  If ACLA.ACLAF(J).FLDCLA=ACLA.ACLAK(1).INDEX(I) & ACLA.ACLAF(J).FLDGRP=""
   LIGNE = 'Call TRACE("'+[L]ROOTCLA+'.'+ACLA.ACLAK(1).INDEX(I)+' ="-num$('+[L]ROOTCLA+'.'+ACLA.ACLAK(1).INDEX(I)+')) From ASYRCOM' : Gosub ADDCLB
  Endif
 Next
Next
LIGNE = 'Call TRACE("6 --> List of keys :") From ASYRCOM' : Gosub ADDCLB
LIGNE = 'For I=1 To maxtab('+[L]ROOTCLA+'.AKEYS)' : Gosub ADDCLB
LIGNE = ' Call TRACE("-"-num$(I)-":"-'+[L]ROOTCLA+'.AKEYS(I)) From ASYRCOM' : Gosub ADDCLB
LIGNE = 'Next' : Gosub ADDCLB
DIF -= 1
LIGNE = 'Endif' : Gosub ADDCLB
LIGNE = 'Close Local File '+"["+ACLA.ACLAK(1).ABRLNK+"_]" : Gosub ADDCLB
LIGNE = 'FreeGroup '+[L]ROOTNAM : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Declaraiton des tables
#-------------------------------------------------------#
$TRT_AVARIABLES
NIVEAU = 1
Raz J,K
For N=1 To maxtab(ACLA.ACLAK)
 For I=1 To maxtab(ACLA.ACLAK(N).ACLALNK.ACLAF)
  If find(ACLA.ACLAK(N).ACLALNK.ACLAF(I).CODTYP,"AX3","AX2","AX1","AXX")<>0 :   J=1
  Elsif find(ACLA.ACLAK(N).ACLALNK.ACLAF(I).CODTYP,"ATX")<>0 : K=1
  Endif
  If K&J : Break 2 : Endif
 Next
Next
DIF = 0
LIGNE = "############################################################################################"  : Gosub ADDCLB
LIGNE = "### AVARIABLES"  : Gosub ADDCLB
LIGNE = "############################################################################################"  : Gosub ADDCLB
LIGNE = "$AVARIABLES"  : Gosub ADDCLB
LIGNE = '[L]ASTATUS =max([L]ASTATUS,fmet '+[L]ROOTNAM+'._ADELERRORS([V]CST_ALLERRORS))' : Gosub ADDCLB
LIGNE = "$_AVARIABLES"  : Gosub ADDCLB
LIGNE = "Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1"
For I=2 To min(8,maxtab(ACLA.ACLAK))
 LIGNE += ",A_N"+num$(I)+",A_S"+num$(I)
Next
Gosub ADDCLB
Raz LIGNE
For I=9 To maxtab(ACLA.ACLAK)
 If I=9 : LIGNE ="Local    Integer A_N"+num$(I)+",A_S"+num$(I)
 Else LIGNE += ",A_N"+num$(I)+",A_S"+num$(I)
 Endif
Next
If LIGNE<>"" : Gosub ADDCLB : Endif
LIGNE = "Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN" : Gosub ADDCLB
LIGNE = "Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)"  : Gosub ADDCLB
LIGNE = "Local    Uuident    A_UUID" : Gosub ADDCLB
LIGNE = ""  : Gosub ADDCLB
LIGNE = "[L]A_LEVEL    = "+[L]ROOTNAM+".ACTX.LEVWML"   : Gosub ADDCLB
LIGNE = "[L]ASTATUS  = 0"   : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "Onerrgo ERR_OPENTAB"  : Gosub ADDCLB
LIGNE = "If find("+[L]ROOTNAM+'.ACTX.AFOLDER,nomap,"")>0' : Gosub ADDCLB
DIF +=1
For I=1 To maxtab(ACLA.ACLAK)
 If ACLA.ACLAK(I).TABLNK<> "" & ACLA.ACLAK(I).ABRLNK<> ""
  LIGNE = "Local File "+ACLA.ACLAK(I).TABLNK-"["+ACLA.ACLAK(I).ABRLNK+"]"  : Gosub ADDCLB
 Endif
Next
If maxtab(ACLA.ACLAK)=1
 If ACLA.TYPCLA=2
  LIGNE = "Local File"-ACLA.ACLAK(1).TABLNK-"[AAA_]"  : Gosub ADDCLB
 Else
   LIGNE = "Local File ADOVAL [__INT]"  : Gosub ADDCLB
 Endif
Endif
If J : LIGNE = "Local File ATEXTRA [AXX]" : Gosub ADDCLB : Endif
If K : LIGNE = "Local File ATEXTE [ATX]"  : Gosub ADDCLB : Endif
DIF -= 1
LIGNE = "Else" : Gosub ADDCLB
DIF +=1
For I=1 To maxtab(ACLA.ACLAK)
 If ACLA.ACLAK(I).TABLNK<> "" & ACLA.ACLAK(I).ABRLNK<> ""
  If ACLA.ACLAK(I).TYPTAB<>3
   LIGNE = "Local File ="+[L]ROOTNAM+'.ACTX.AFOLDER+".'+ACLA.ACLAK(I).TABLNK+'" ['+ACLA.ACLAK(I).ABRLNK+']'  : Gosub ADDCLB
  Else
   LIGNE = "Local File "+ACLA.ACLAK(I).TABLNK+' ['+ACLA.ACLAK(I).ABRLNK+']'  : Gosub ADDCLB
  Endif
 Endif
Next
If maxtab(ACLA.ACLAK)=1
 If ACLA.TYPCLA=2
  If ACLA.ACLAK(1).TYPTAB<>3
   LIGNE = "Local File ="+[L]ROOTNAM+'.ACTX.AFOLDER+".'+ACLA.ACLAK(1).TABLNK+'" [AAA_]'  : Gosub ADDCLB
  Else
   LIGNE = "Local File "+ACLA.ACLAK(1).TABLNK+' [AAA_]'  : Gosub ADDCLB
  Endif
 Else
   LIGNE = "Local File ="+[L]ROOTNAM+'.ACTX.AFOLDER+".ADOVAL" [__INT]'  : Gosub ADDCLB
 Endif
Endif
If J : LIGNE = "Local File ="+[L]ROOTNAM+'.ACTX.AFOLDER+".ATEXTRA" [AXX]' : Gosub ADDCLB : Endif
If K : LIGNE = "Local File ="+[L]ROOTNAM+'.ACTX.AFOLDER+".ATEXTE" [ATX]' : Gosub ADDCLB : Endif
DIF -= 1
LIGNE = "Endif" : Gosub ADDCLB
LIGNE = "Onerrgo"  : Gosub ADDCLB
LIGNE = "Return"  : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "$ERR_OPENTAB" : Gosub ADDCLB
LIGNE = '[L]ASTATUS = max([L]ASTATUS,fmet '+[L]ROOTNAM+'.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))' : Gosub ADDCLB
LIGNE = "Resume" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Link principale du STRMASTER
#-------------------------------------------------------#
$TRT_LINK
DIF = 0
LIGNE = "############################################################################################"  : Gosub ADDCLB
LIGNE = "### Link"  : Gosub ADDCLB
LIGNE = "############################################################################################"  : Gosub ADDCLB
LIGNE = "$AOPEN_LINK" : Gosub ADDCLB
LIGNE = "Gosub AVARIABLES"  : Gosub ADDCLB
J = 0
LIGNE = "Link ["+ACLA.ACLAK(1).ABRLNK+"] With"  : Gosub ADDCLB
For I=2 To maxtab(ACLA.ACLAK)
 J +=1
 If J>1
  LIGNE += ","  : Gosub ADDCLB
 Endif
 LIGNE = "& ["+ACLA.ACLAK(I).ABRLNK+"]"+ACLA.ACLAK(I).CLELNK
 If find(ACLA.ACLAK(I).TYPLNK,3,4)
  LIGNE += " ~= "
 Else
  LIGNE += " = "
 Endif
 LIGNE += ACLA.ACLAK(I).EXPLNK
Next
If maxtab(ACLA.ACLAK)=1
 LIGNE = "& [AAA_]"+ACLA.ACLAK(1).CLELNK-"="-ACLA.ACLAK(1).EXPLNK : Gosub ADDCLB
Else
 Gosub ADDCLB
Endif
LIGNE = "& As [LNK_]"  : Gosub ADDCLB
LIGNE = "Return"  : Gosub ADDCLB
LIGNE = ""  : Gosub ADDCLB
Return


#-------------------------------------------------------#
# Prg commun a tous les crud
#-------------------------------------------------------#
$PRG_DEB
Local Char      LIGNE(250)
### Ajout au tableau de parcours l'enreg courant : couple TABDES-TABORI
For I=1 To dim(TABPARCOURS)
 If TABPARCOURS(I)=""
  TABPARCOURS(I)= ATBDES-ATBORI
  Break
 Endif
Next
If DIF=0
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
Else
 LIGNE = "#-----------------------#" : Gosub ADDCLB
Endif
Return

#-------------------------------------------------------#
# Prg commun a tous les crud
#-------------------------------------------------------#
$PRG_FIN
If PROGRAM <> "ADELETE"
 If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4)  : #  For
 DIF -= 1 : LIGNE = "Next"-ACLA.ACLAK(NIVEAU).ABRLNK : Gosub ADDCLB
 ISFOR = (find(ACLA.ACLAK(find(ACLA.ACLAK(NIVEAU).TABORI,ACLA.ACLAK(1..maxtab(ACLA.ACLAK)).TABLNK)).TYPLNK,2,4)) :  NBFOR -= 1
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 Elsif find(ACLA.ACLAK(NIVEAU).TYPLNK,1,3) : # read
  DIF -= 1 : LIGNE = "Endif" : Gosub ADDCLB
 Endif
Endif
If ACLA.ACLAK(NIVEAU).CLALNK<>""
 Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM+"_AFTER","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Endif
If DIF=0
 LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
Else
 LIGNE = "#-----------------------#" : Gosub ADDCLB
Endif
Return

#-------------------------------------------------------#
# Prg commun d'appel d'interface
#-------------------------------------------------------#
$PRG_INTERFACE
DIF = 0
NIVEAU = 1
NBFOR = 0
ACLA.ACLAK(NIVEAU).STRCUR =  ACLA.CODCLA
NIVPARCOURS = 0
Gosub ENTETE_SUBPROG From ACLASUBCRUD
Call DECLARE_ACTION([L]ROOTCLA,PROGRAM,"REP","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : End : Endif" :  Gosub ADDCLB
LIGNE = "End":  Gosub ADDCLB
Return

