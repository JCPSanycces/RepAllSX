#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# UTICPT28  KC                                                Module CPT  #
# Update the field COLDESTRA added in the table TBU that is now         #
# the transatable headed instead of COLDES                              #                                                 
#########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Fill in field COLDESTRA with COLDES of TABUDTYP Table") From LECFIC

  Call MAJ_UTICPT28(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT28(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTICPT28 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:TBU])  =0  Local File =DOSSIER+".TABBUDTYP"  [TBU] : Endif
If clalev ([F:AXX]) =0  Local File =DOSSIER+".ATEXTRA"    [AXX] : Endif

If dim([F:TBU]DES)<0
 Close Local File [TBU],[AXX]
 Return 
Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [TBU]
For [TBU]TBU0
   Readlock [TBU] Curr    
   If !fstat & [F:TBU]DES<>""
      #
      Call MAJTEXTRA([F:TBU]COLDES,"TABBUDTYP","COLDESTRA",[F:TBU]BUDTYP,num$([F:TBU]COLNUM)) From ATEXTRA
      If !fstat COMPTEUR += 1 Endif
   Endif
Next
Commit

Close Local File [TBU],[AXX]

Call ECR_TRACE("UTICPT28 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 
If filinfo(filpath("FIL","TABBUDTYP","fde",APPLI),0)<=0 : End : Endif     
Call MAJ_UTICPT28(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 
If filinfo(filpath("FIL","TABBUDTYP","fde",APPLI),0)<=0 : End : Endif   
Call MAJ_UTICPT28(APPLI)
End
