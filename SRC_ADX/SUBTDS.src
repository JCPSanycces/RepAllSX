#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du fichier PRMTDS0
Raz GPILOBJ
GFLAG="2"
Call OBJET("TDS",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVFIC
 When "LIENS"        : Gosub LIENS
 When "RAZCRE"       : [M:TD0]FLGDNA=val(GFLAG)  : [M:TD0]NATREC=val(GFLAG)
 When "INIMOD"       : Gosub SAUVE_ECRAN
 When "INICRE"       : Gosub SAUVE_ECRAN
 When "VERF_ANU"     : Gosub VERF_ANU
 When "SETBOUT"      : Gosub SETBOUT
 When "FILTRE"       : Gosub FILTRE
 When "DEFTRANS"     : Gosub DEFTRANS
 #Voulez-vous appliquer de ce paramétrage de niveau 'Dossier' à toutes les fiches existantes ?
 When "INIT" : TIT = mess(93,10705,1)
 When "EXEC" : Gosub EXEC
 When "FERME"        : Gosub FERME

Endcase
Return

$OUVFIC
If clalev([F:TCY])=0 : Local File TABCOUNTRY  [TCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY     [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY    [FCY] : Endif

If clalev([F:CNT])=0 : Local File CONTACT     [CNT] : Endif
If clalev([F:TD0])=0 : Local File PRMTDS0     [TD0] : Endif
If clalev([F:TD1])=0 : Local File PRMTDS1     [TD1] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE    [RUB] : Endif
If clalev([F:CUM])=0 : Local File CUMUL       [CUM] : Endif
If clalev([F:VRA])=0 : Local File VARIA       [VRA] : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$FILTRE
FILTRE = "FLGDNA=val(GFLAG)"
Return

$LIENS
Call AM_LEV([M:TD0]LEV)
Gosub CHARGE_ECRAN
If [M:TD0]FLGDNA=2 | [M:TD0]LEV=1
 Effzo [M:TD1]NUMAGR
 Grizo [M:TD1]NUMAGR
Else
 Actzo [M:TD1]NUMAGR
Endif
#N4DS
[M:TD0]NATREC=[M:TD0]FLGDNA

Call LECTURE("CPY",[M:TD0]CPY,"") From CONTOBJ
GCURLEG=[F:CPY]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

Return

$VERF_ANU
Delete [F:TD1] Where LEV=[M:TD0]LEV & NATFIL=[M:TD0]NATFIL & CPY=[M:TD0]CPY & FLGDNA=[M:TD0]FLGDNA
Return

$SETBOUT
If CLECUR & VERROU : CHAINE+="A" : Endif
If REP="M" | CLECUR=0 | !VERROU
 Call VIREBOUT(CHAINE,"2O") From GOBJET
Elsif [M:TD0]LEV<>1
 Call VIREBOUT(CHAINE,"O") From GOBJET
Endif

Return

$DEFTRANS
If TUNNEL=1 : GFLAG = SAVGFLAG : Endif
Return

###################################################################################
#                            LECTURE
###################################################################################
$CHARGE_ECRAN
Local Char CHAMP (20)
Local Integer I

nolign = 0
#63907
For [F:TD1]TD10 Where LEV=[M:TD0]LEV & CPY=[M:TD0]CPY & NATFIL=[M:TD0]NATFIL & FLGDNA=[M:TD0]FLGDNA
 nolign += 1
 [M:TD2]=[F:TD1]
  # chargement du Rang
 [M:TD2]ROW(nolign-1)=0
 #Tax band
 If [F:TD1]TYP<6 or [F:TD1]TYP>7
  Read [F:RUB]RUB0=GCURLEG;[F:TD1]COD
  If !fstat :  [M:TD2]ROW(nolign-1)=[F:RUB]ROW : Endif
 Elsif [F:TD1]TYP=6
  Read [F:CUM]CUM0=GCURLEG;[F:TD1]COD
  If !fstat :  [M:TD2]ROW(nolign-1)=[F:CUM]CUMROW : Endif
 Endif

 Raz [M:TD2]TIT(nolign-1)
 If [M:TD2]FLD(nolign-1)<>""
  [M:TD2]FLD(nolign-1)=toupper([M:TD2]FLD(nolign-1))
  I = instr(1,[M:TD2]FLD(nolign-1), "]")
  CHAMP= mid$ ([M:TD2]FLD(nolign-1),I+1,len([M:TD2]FLD(nolign-1))-I)
  Read [F:DDA]DDA0=CHAMP
  If !fstat
   Call TEXTE([F:DDA]DES,[M:TD2]TIT(nolign-1)) From OBJDIV
  Endif
 Endif
Next
[M:TD2]BPAG1 = nolign
Sorta [M]BPAG1 [M]BPAG1 Order By [M]COD(indice)
Return

###################################################################################
#                            ECRITURE
###################################################################################
$SAUVE_ECRAN
#61351
[F:TD0]FLGDNA=val(GFLAG)

#61276 : Remplacement de SYMBOLE par SYMBOLE2
Local Char    SYMBOLE2 (50)
Local Char    ANNEE (4)
If val(GFLAG)=2
 ANNEE=num$(year(GMOIPAY))
 SYMBOLE2 = "DNA"+ANNEE
Else
 Call PARAM("","DADYEA",ANNEE) From ADOVAL
 SYMBOLE2 = "TDS"+ANNEE
Endif
Lock =SYMBOLE2
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif
Call DEBTRANS From GLOCK
Gosub TR1
Unlock =SYMBOLE2
Return

$TR1
If [M:TD2]BPAG1>0
 Delete [TD1] Where LEV=[M:TD0]LEV & NATFIL=[M:TD0]NATFIL & CPY=[M:TD0]CPY & FLGDNA=[M:TD0]FLGDNA
 If fstat=1
  GOK =-1 : GLOCK = "$PRMTDS1" : Return
 Endif
 For nolign=1 To [M:TD2]BPAG1
  [F:TD1]=[M:TD2]
  [F:TD1]LEV=[M:TD0]LEV
  [F:TD1]CPY=[M:TD0]CPY
  [F:TD1]NATFIL=[M:TD0]NATFIL
  [F:TD1]FLGDNA=[M:TD0]FLGDNA
  [F:TD1]NUMFIL=nolign
  Write [TD1]
  If fstat<>0
   GOK = 0 : Call FSTA("TD1") From GLOCK : Break
  Endif
 Next
Endif
Return

$AB_TR
Rollback
GMESSAGE = mess (17,107,1) :#Rollback suite à une erreur dans la transaction
Return

#----------------------------------------------------------------------------------
#                                ETIQUETTES ECRAN
#----------------------------------------------------------------------------------

################################################################################
##################################[M:TD0]#######################################
################################################################################
Subprog AS_LEV(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=1
GMENLOC(4)=1
GMENLOC(5)=1
End

Subprog AM_LEV(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Effzo [M:TD0]CPY : Grizo [M:TD0]CPY
 Effzo [M:TD1] : Grizo [M:TD1]
Else
 Actzo [M:TD0]CPY
 Actzo [M:TD1]
Endif
End

################################################################################
##################################[M:TD1]#######################################
################################################################################

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [FCY]FCY0=VALEUR
 If fstat=0
  [M:TD1]CRNFCY=[F:FCY]CRN
  [M:TD1]CRY=[F:FCY]CRY
 Endif
 Affzo [M:TD1]CRNFCY
Endif
End

Subprog C_FCYDEN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [FCY]FCY0=VALEUR
 If fstat=0
  [M:TD1]CRNFCYDEN=[F:FCY]CRN
  [M:TD1]CRYDEN=[F:FCY]CRY
 Endif
 Affzo [M:TD1]CRNFCYDEN
Endif
End

Subprog AS_DENNUMCOM(VALEUR)
Variable Char    VALEUR()
#recherche du contact TDS du site destinataire des comptes rendus
If [M:TD1]FCYDEN<>""
 Read[F:FCY]FCY0=[M:TD1]FCYDEN
 If !fstat & [F:FCY]CNTDDS<>""
   Read [F:CNT]CNT0=3;[F:FCY]FCY;[F:FCY]CNTDDS
   If fstat=0
    VALEUR=[F:CNT]WEB
    Affzo [M:TD1]DENNUMCOM
   Endif
  Endif
 Endif
End

##############################
Subprog C_NATFIL(VALEUR)
Variable Char    VALEUR()

Local Char TAB(2)(0..10)
Call  NATTYP (TAB,1)

If !find(VALEUR, TAB(0..10))
 #Valeur non autorisée
 GMESSAGE=mess(100,10703,1)
 mkstat=2 : End
Endif
If (val(GFLAG)=2 & VALEUR<>"10" & VALEUR<>"15") | (val(GFLAG)<>2 & (VALEUR="10" | VALEUR="15"))
 #Valeur non autorisée
 GMESSAGE=mess(100,10703,1)
 mkstat=2 : End
Endif
If !func AFNC.ACTIV("BTP") & VALEUR="04"
 #Valeur non autorisée
 GMESSAGE=mess(100,10703,1)
 mkstat=2 : End
Endif
End

##############################
Subprog C_TYPFIL(VALEUR)
Variable Char    VALEUR()

Local Char TAB (2)(0..10)
Call  NATTYP (TAB,2)

If !find(VALEUR, TAB(0..10))
 #Valeur non autorisée
 GMESSAGE=mess(100,10703,1)
 mkstat=2 : End
Endif

Case VALEUR
  When "52"
  If [M]NATFIL="15"
   GMESSAGE=mess(10,10705,1)-[M]NATFIL
   mkstat=2 : End
  Endif
 When "55"
  If [M]NATFIL<>"01" & [M]NATFIL<>"02" & [M]NATFIL<>"07" & [M]NATFIL="08"
   GMESSAGE=mess(10,10705,1)-[M]NATFIL
   mkstat=2 : End
  Endif
 When "59"
  If [M]NATFIL="04" | [M]NATFIL="21"
   GMESSAGE=mess(10,10705,1)-[M]NATFIL
   mkstat=2 : End
  Endif
 When "60"
  If [M]NATFIL<>"10"
   GMESSAGE=mess(10,10705,1)-[M]NATFIL
   mkstat=2 : End
  Endif

Endcase
End

##############################
Subprog NATTYP (TABCOD,TYP)
Variable Char TABCOD ()
Value Integer TYP
Raz TABCOD
Case TYP
 When 1 :
  TABCOD (0)= "01" : TABCOD (1)= "02" : TABCOD (2)= "04" : TABCOD (3)= "07" : TABCOD (4)= "08": TABCOD (5)= "10"
  TABCOD (6)= "12" : TABCOD (7)= "13" : TABCOD (8)= "15" : TABCOD (9)= "21"
 When 2 :
  TABCOD (0)= "51" : TABCOD (1)= "52" : TABCOD (2)= "55" : TABCOD (3)= "59" : TABCOD (4)= "60"
Endcase
End

##############################
Subprog C_OPTFIL(VALEUR)

Variable Char    VALEUR()
If VALEUR<>"A00" &  ([M]NATFIL="01" | [M]NATFIL="02" |  [M]NATFIL="07" | [M]NATFIL="12" | [M]NATFIL="21" )
 #Caractéristique incohérente pour la nature :
 GMESSAGE=mess(11,10705,1)-[M]NATFIL
 mkstat=2 : End
Endif
If (VALEUR="M00" | VALEUR="T00" | left$(VALEUR,2)="S0") & [M]NATFIL="04"
 #Caractéristique incohérente pour la nature :
 GMESSAGE=mess(11,10705,1)-[M]NATFIL
 mkstat=2 : End
Endif
If [M]NATFIL="10"
 If VALEUR<>"M00" & VALEUR<>"EVE"
  #Caractéristique incohérente pour la nature :
  GMESSAGE=mess(11,10705,1)-[M]NATFIL
  mkstat=2 : End
 Elsif VALEUR="EVE"& [M]TYPFIL<>"51"
  #Caractéristique incohérente pour le type :
  GMESSAGE=mess(94,10705,1)-[M]TYPFIL
  mkstat=2 : End
 Endif
Endif
If VALEUR<>"EVE" & [M]NATFIL="15"
 #Caractéristique incohérente pour la nature :
 GMESSAGE=mess(11,10705,1)-[M]NATFIL
 mkstat=2 : End
Endif
If VALEUR<>"A00" & left$(VALEUR,2)<>"T0" & VALEUR<>"EVE" & [M]NATFIL="08"
 #Caractéristique incohérente pour la nature :
 GMESSAGE=mess(11,10705,1)-[M]NATFIL
 mkstat=2 : End
Endif
If left$(VALEUR,2)<>"T0" & [M]NATFIL="13"
 #Caractéristique incohérente pour la nature :
 GMESSAGE=mess(11,10705,1)-[M]NATFIL
 mkstat=2 : End
Endif

End

##########################
Subprog AV_CRNFCY(VALEUR)
Variable Char    VALEUR()
If [M:TD0]LEV=1
 Grizo [M:TD1]CRNFCY
Else
 Actzo [M:TD1]CRNFCY
Endif
End

##########################
Subprog AV_CRNFCYDEN(VALEUR)
Variable Char    VALEUR()
If [M:TD0]LEV=1
 Grizo [M:TD1]CRNFCYDEN
Else
 Actzo [M:TD1]CRNFCYDEN
Endif
End

################################################################################
##################################[M:TD2]#######################################
################################################################################
Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
Local Char CHAMP (20)
Local Integer I
If VALEUR<>""
 VALEUR=toupper(VALEUR)
 I = instr(1,VALEUR, "]")
 CHAMP= mid$ (VALEUR,I+1,len(VALEUR)-I)
 Read [DDA]DDA0 = CHAMP
 If fstat
  GMESSAGE = mess(41,100,1) : # Champ inexistant
  mkstat = 2
  End
 Elsif [F:DDA]ENAFLG=1
  GMESSAGE = mess(106,10702,1) : # Champ inactif
  mkstat = 2
  End
 Endif
Endif
End

##########################
Subprog AM_FLD(VALEUR)
Variable Char    VALEUR()
Local Char CHAMP (20)
Local Integer I
If VALEUR<>""
 VALEUR=toupper(VALEUR)
 I = instr(1,VALEUR, "]")
 CHAMP= mid$ (VALEUR,I+1,len(VALEUR)-I)
 Read [F:DDA]DDA0=CHAMP
 If !fstat
  Call TEXTE([F:DDA]DES,[M:TD2]TIT(nolign-1)) From OBJDIV
  Affzo [M:TD2]TIT(nolign-1)
 Endif
Else
 Raz [M:TD2]TIT(nolign-1)
Endif
End

##########################
Subprog C_COD(VALEUR)
Variable Char    VALEUR()
[M:TD2]ROW(nolign-1)=0
If VALEUR<>""
 #Tax band
 If [M:TD2]TYP(nolign-1)<6 or [M:TD2]TYP(nolign-1)>7
  Read [F:RUB]RUB0=GCURLEG;VALEUR
  If fstat=0
   #Tax Band
   If ([M:TD2]TYP(nolign-1)>=3 & [M:TD2]TYP(nolign-1)<=5) or [M:TD2]TYP(nolign-1)>=8 #Tranche A, B , C...H
    If [F:RUB]TYPRUB<>5 #<>assiette
     GMESSAGE=[F:RUB]COD-mess(7,10705,1) :#cette rubrique n'est pas une assiette de cotisation
     mkstat=2 : End
    Endif
   Else
    If [F:RUB]TYPRUB=5 #=assiette
     GMESSAGE=[F:RUB]COD-mess(8,10705,1) :#cette rubrique ne doit pas être une assiette de cotisation
     mkstat=2 : End
    Endif
   Endif
   [M:TD2]ROW(nolign-1)=[F:RUB]ROW
   Affzo[M:TD2]ROW(nolign-1)
  Else
   GMESSAGE=mess(23,100,1) :#Fiche inexistante
   mkstat=2 : End
  Endif
 Elsif [M:TD2]TYP(nolign-1)=6
  Read [F:CUM]CUM0=GCURLEG;VALEUR
  If fstat=0
   [M:TD2]ROW(nolign-1)=[F:CUM]CUMROW
   Affzo[M:TD2]ROW(nolign-1)
  Else
   GMESSAGE=mess(23,100,1) :#Fiche inexistante
   mkstat=2 : End
  Endif
 Else
  Read [F:VRA]VRA0=GCURLEG;VALEUR
  If fstat<>0
   GMESSAGE=mess(23,100,1) :#Fiche inexistante
   mkstat=2 : End
  Endif
 Endif
 Affzo[M:TD2]ROW(nolign-1)
Endif
End

# A revoir cause ]DES en texte traduisibles !!!
##########################
Subprog S_COD(VALEUR)
Variable Char    VALEUR()
#In expectation of a solution to display DES columns if data type is AX3

#If [M:TD2]TYP(nolign-1)=6
# Choose [CUM] Where CUMCOD>=VALEUR
#& Order By evalue("CUMCOD") Using
#& [CUM]CUMCOD Titled "Code",
#& [CUM]CUMDES Titled "Intitulé"
#& Sized (80,240)
#& Titled "Selection d'un cumul"
# If fstat=0 : VALEUR=[F:CUM]CUMCOD : Endif
#Elsif [M:TD2]TYP(nolign-1)=7
# Choose [VRA] Where COD>=VALEUR
#& Order By evalue("COD") Using
#& [VRA]COD Titled "Code",
#& [VRA]DES Titled "Intitulé"
#& Sized (80,240)
#& Titled "Selection d'une variable"
# If fstat=0 : VALEUR=[F:VRA]COD : Endif
#Else
# Choose [RUB] Where COD>=VALEUR
#& Order By evalue("COD") Using
#& [RUB]COD Titled "Code",
#& [RUB]DES Titled "Intitulé"
#& Sized (80,240)
#& Titled "Selection d'une rubrique"
# If fstat=0 : VALEUR=[F:RUB]COD : Endif
#Endif
If [M:TD2]TYP(nolign-1)=6
 Choose [CUM] Where CUMCOD>=VALEUR
& Order By evalue("CUMCOD") Using
& [CUM]CUMCOD Titled "Code"
& Sized (80,100)
& Titled "Selection d'un cumul"
 If fstat=0 : VALEUR=[F:CUM]CUMCOD : Endif
Elsif [M:TD2]TYP(nolign-1)=7
 Choose [VRA] Where COD>=VALEUR
& Order By evalue("COD") Using
& [VRA]COD Titled "Code"
& Sized (80,100)
& Titled "Selection d'une variable"
 If fstat=0 : VALEUR=[F:VRA]COD : Endif
Else
 Choose [RUB] Where COD>=VALEUR
& Order By evalue("COD") Using
& [RUB]COD Titled "Code"
& Sized (80,100)
& Titled "Selection d'une rubrique"
 If fstat=0 : VALEUR=[F:RUB]COD : Endif
Endif
End

##########################
Subprog AS_AMTTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=0
 #Tax band
 If ([M:TD2]TYP(nolign-1)>=3 & [M:TD2]TYP(nolign-1)<=5) | [M:TD2]TYP(nolign-1)>=8
  VALEUR=7 :#+Tranche
 Else
  VALEUR=3 :#+Montant
 Endif
 Affzo[M:TD2]AMTTYP(nolign-1)
Endif
Case [M:TD2]TYP(nolign-1)
 When 1,2
  GMENLOC(5) = 1 : # Désactive le choix 5
  GMENLOC(6) = 1 : # Désactive le choix 6
  GMENLOC(7) = 1 : # Désactive le choix 7
  GMENLOC(8) = 1 : # Désactive le choix 8
 When 6,7
  GMENLOC(1) = 1 : # Désactive le choix 1
  GMENLOC(2) = 1 : # Désactive le choix 2
  GMENLOC(5) = 1 : # Désactive le choix 5
  GMENLOC(6) = 1 : # Désactive le choix 6
  GMENLOC(7) = 1 : # Désactive le choix 7
  GMENLOC(8) = 1 : # Désactive le choix 8
 #Tax band
 When Default    : #Tranches...
  GMENLOC(3) = 1 : # Désactive le choix 3
  GMENLOC(4) = 1 : # Désactive le choix 4
Endcase
End


########################################
$TRTCOP
If [M]DOSORG=nomap
 Local File PRMTDS0 [TD01]
 Local File PRMTDS1 [TD11]
Else
 Local File =[M]DOSORG+".PRMTDS0" [TD01]
 Local File =[M]DOSORG+".PRMTDS1" [TD11]
Endif
If [M]DOSDES=nomap
 Local File PRMTDS0 [TD02]
 Local File PRMTDS1 [TD12]
Else
 Local File =[M]DOSDES+".PRMTDS0" [TD02]
 Local File =[M]DOSDES+".PRMTDS1" [TD12]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [TD01], [TD02],[TD11], [TD12]
Return

##########################
$TR_COP
GOK = 1
Trbegin [TD02],[TD12]
 Delete [TD02] Where LEV=1 & CPY="" & NATFIL=[M:TD0]NATFIL & FLGDNA=[M:TD0]FLGDNA
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".PRMTDS0" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("TD02","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [TD12] Where LEV=1 & CPY="" & NATFIL=[M:TD0]NATFIL & FLGDNA=[M:TD0]FLGDNA
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".PRMTDS1" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("TD12","") From GLOCK : Goto AB_TR_COP
 Endif
 For [TD01] Where LEV=1 & CPY="" & NATFIL=[M:TD0]NATFIL & FLGDNA=[M:TD0]FLGDNA
  [F:TD02] = [F:TD01]
  If dim([F:TD02]UPDUSR)>0 : [F:TD02]UPDUSR = GUSER : Endif
  If dim([F:TD02]UPDDAT)>0 : [F:TD02]UPDDAT = date$ : Endif
  If dim([F:TD02]UPDTIM)>0 : [F:TD02]UPDTIM = time : Endif
  Write [TD02]
  If fstat
   GOK = 0 : Call FSTA("TD02") From GLOCK : Break
  Endif
 Next
 If GOK
  For [TD11] Where LEV=1 & CPY="" & NATFIL=[M:TD0]NATFIL & FLGDNA=[M:TD0]FLGDNA
   [F:TD12] = [F:TD11]
   If dim([F:TD12]UPDUSR)>0 : [F:TD12]UPDUSR = GUSER : Endif
   If dim([F:TD12]UPDDAT)>0 : [F:TD12]UPDDAT = date$ : Endif
   If dim([F:TD12]UPDTIM)>0 : [F:TD12]UPDTIM = time : Endif
   Write [TD12]
   If fstat
    GOK = 0 : Call FSTA("TD12") From GLOCK : Break
   Endif
  Next
 Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

##########################
$AB_TR_COP
Rollback
Return

##########################
$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

##########################
# Maj auto
##########################
$EXEC
If clalev([F:TD0B])=0 : Local File PRMTDS0     [TD0B] : Endif
If clalev([F:TD1B])=0 : Local File PRMTDS1     [TD1B] : Endif
If clalev([F:TD1C])=0 : Local File PRMTDS1     [TD1C] : Endif

Call DEBTRANS From GLOCK
Trbegin [TD1B]

Delete [TD1B] Where LEV<>1 & CPY<>"" & NATFIL=[M:TD0]NATFIL & FLGDNA=[M:TD0]FLGDNA
If fstat
 GOK = 0 : Call FSTA("TD1B") From GLOCK
Endif
If GOK
 For [TD1C] Where LEV=1 & CPY="" & NATFIL=[M:TD0]NATFIL & FLGDNA=[M:TD0]FLGDNA
  For [TD0B] Where LEV<>1 & CPY<>"" & NATFIL=[M:TD0]NATFIL & FLGDNA=[M:TD0]FLGDNA
   Raz [F:TD1B]
   [F:TD1B] = [F:TD1C]
   [F:TD1B] = [F:TD0B]
   If dim([F:TD1B]CREUSR)>0 : [F:TD1B]CREUSR = GUSER : Endif
   If dim([F:TD1B]CREDAT)>0 : [F:TD1B]CREDAT = date$ : Endif
   If dim([F:TD1B]CRETIM)>0 : [F:TD1B]CRETIM = time : Endif
   Write [TD1B]
   If fstat
    GOK = 0 : Call FSTA("TD1B") From GLOCK : Break
   Endif
  Next
 Next
Endif
If !GOK : Rollback : Else : Commit : Endif
Return

