#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# extract JSON for screens
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("extract JSON for screens") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub EXTRACT
End

#-------------------#
$EXTRACT

If nomap<>DOSSIER | find(nomap,"REPOSX3","X3DEV","FOLDEV")=0 : Return : Endif
Local File =DOSSIER+".AMSK" [AMK__]
Local Char CLE2(250)(0..10)
Local Integer WCOUNTTOT
Local Char ERRMES(250)

Trbegin [AMK__]
For [AMK__]CODMSK Where left$(CODMSK,1)<>"W"
 If func ASYRFNC.IS_UPDATE_MONGO>[V]CST_AFALSE
  # Issue X3-59645 - 2018-01-22 by CCC : display the error
  #Call UPD_META("AMK",[F:AMK__]CODMSK,CLE2,"M") From ASYRMETA
  If func ASYRMETA.UPD_META("AMK",[F:AMK__]CODMSK,CLE2,"M",ERRMES)<>[V]CST_AOK
    Call ECR_TRACE("ASYRMETA.UPD_META"-ERRMES,1) From GESECRAN
  Endif
  WCOUNTTOT+=1
 Endif
Next AM__
Commit

Call ECR_TRACE(func AFNC.MES(mess(220,115,1),num$(WCOUNTTOT)),0) From GESECRAN

Close Local File [AMK__]
Return

