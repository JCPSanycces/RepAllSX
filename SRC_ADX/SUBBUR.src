######################################################################################
# Après_modif de la société
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
  # On grise ou on dégrise le site
  If VALEUR = "" Then
   Actzo [M:BUR1]FCY
   If [M:BUR1]FCY = ""
     Actzo [M:BUR1]LEG
   Endif
  Else
   Diszo [M:BUR1]FCY
   Call LECTURE("CPY",VALEUR,"") From CONTOBJ
   GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
   #25/06/12 - DKA - Set Legislation
   If dim([F:CPY]LEG)>0
     #SBA : US 1840-81085
     If([M:BUR1]LEG<>[F:CPY]LEG)
        Call REINI_FLDSLEG([F:CPY]LEG)
     Endif
      #Fin US 1840-81085
     Diszo [M:BUR1]LEG
     [M:BUR1]LEG = [F:CPY]LEG
     #SBA : US 1840-81085
     Affzo [M:BUR1]LEG,ZLEG
   Endif
  Endif
End

######################################################################################
# Après_modif du site
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
  # On grise ou on dégrise la société
  If VALEUR = "" Then
   Actzo [M:BUR1]CPY
   If [M:BUR1]CPY = ""
     Actzo [M:BUR1]LEG
   Endif
  Else
   Diszo [M:BUR1]CPY
    Call LECTURE("FCY",VALEUR,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
    #25/06/12 - DKA - Set Legislation
    If dim([F:CPY]LEG)>0
      #SBA : US 1840-81085
      If([M:BUR1]LEG<>[F:CPY]LEG)
        Call REINI_FLDSLEG([F:CPY]LEG)
      Endif
      #Fin : US 1840-81085

      [M:BUR1]LEG = [F:CPY]LEG
      #SBA : US 1840-81085
      Affzo [M:BUR1]LEG,ZLEG
    Endif
  Endif
End

######################################################################################
# Contrôle du type de financement
######################################################################################
Subprog C_TYPFIN(VALEUR)
Variable Char    VALEUR()
#Dbgaff
  Call UNICITE(VALEUR,[M]TYPFIN(0..[M]NBLIG-1)) From OBJDIV
End

######################################################################################
######################################################################################
## 25/06/12 - DKA - Set the current context of GCURLEG
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>""
    GCURLEG =VALEUR
     #SBA : US 1840-81085
    Call REINI_FLDSLEG(VALEUR)
  Endif
End

######################################################################################
#SBA : US 1840-81085
Subprog REINI_FLDSLEG(VALEUR)
Value Char VALEUR()
Local Integer WI
Local Integer WOK
Local Char RESULT(10)
If VALEUR="" : End : Endif
For WI=[M:BUR1]NBLIG-1 To 0 Step -1
  WOK=0
  Call GET_LEGADI("10462",[M:BUR1]TYPFIN(WI),WOK,RESULT,WOK) From TOOLSHRLEG
  If(WOK and (RESULT <>"" and VALEUR <>RESULT))
    Supli [M:BUR1]NBLIG(WI+1)
  Endif
Next
Affzo [M:BUR1]NBLIG

End

Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0]
 [M:BUR1]ENDDAT = addmonth(VALEUR,12) - 1
Endif
If [M:BUR1]ENDDAT<>[0/0/0] & VALEUR>[M:BUR1]ENDDAT
 Call ECR_TRACE(mess(1,104,1)-">"-format$("D:"+GFMDAT,[M:BUR1]ENDDAT),1) From GESECRAN
 #### Date incorrecte
 mkstat = 2 : End
Endif
End

Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:BUR1]STRDAT
 Call ECR_TRACE(mess(1,104,1)-"<"-format$("D:"+GFMDAT,[M:BUR1]STRDAT),1) From GESECRAN
 #### Date incorrecte
 mkstat = 2 : End
Endif
End

Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = gdat$(01,01,year(date$))
Endif
End


