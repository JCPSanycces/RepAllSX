######################################################################################
Subprog C_BUDYEA(VALEUR)
Variable Char    VALEUR()
Local Char L_YEAR
#LIPET - 2017-06-26 - X3-29551 - START
# JML 02/09/15 Not needed anymore
#Call PARAM("","DEBAN",L_YEAR) From ADOVAL
