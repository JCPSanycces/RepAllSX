#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet BUR
Raz GPILOBJ
Call OBJET("BUR",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
# Gestion des Budgets de référence (SYMEU - Août 2010 - V6.1)
#     - EXI 66191 LOT 8
# SBA : US 1840-81085 : réinitialisation des champs sur changement de législation
######################################################################################
$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "SETBOUT"     : Gosub SETBOUT
  When "LIENS"       : Gosub LIENS
  When "VERIF_MOD"   : Gosub VERIF_MOD
  When "VERIF_CRE"   : Gosub VERIF_CRE
  When "INIMOD"      : Gosub INIMOD
  When "INICRE"      : Gosub INICRE
  When "MODIF"       : Gosub MODIF
  When "DEGRISE"     : Gosub DEGRISE
  When "RAZCRE"      : Gosub RAZCRE
  When "FERME"       : Gosub FERME
  When Default
Endcase
Return

######################################################################################
$OUVRE
  If clalev([F:BUR2])=0 : Local File BUDREF  [BUR2] : Endif

  If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
  # Fiche 70381 - SYMEU - 04/01/2011 - toujours mettre les décimales
  # en tenant compte du nombre de décimales de GSYSCUR - DEBUT
  Local Char FORMAT_MTT
  Local Integer NB_DECIM
  # Lecture de la table des devises (TABCUR) et récupération du nombre de décimales
  If clalev([F:TCU])=0  : Local File TABCUR  [TCU]  : Endif
  Call LECTURE("TCU",GSYSCUR,"") From CONTOBJ
  NB_DECIM = [F:TCU]DECNBR
  FORMAT_MTT = "N3Z:20"
  If NB_DECIM > 0
    FORMAT_MTT += "."+num$(NB_DECIM)
  Endif
  # Fiche 70381 - SYMEU - 04/01/2011 - toujours mettre les décimales
  # en tenant compte du nombre de décimales de GSYSCUR - FIN
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

######################################################################################
$SETBOUT
# Bouton Supprimer
If REP=""
 CHAINE += "A"
Endif
Return

######################################################################################
$FERME
 If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
######################################################################################
$LIENS
  # (dé)grisage du site et de la société
#  Call AM_CPY([M:BUR1]CPY)
#  Call AM_FCY([M:BUR1]FCY)
#
#  If [M:BUR1]CPY<>""
#    Call LECTURE("CPY",[M:BUR1]CPY,"") From CONTOBJ
#    GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
#  Elsif [M:BUR1]FCY<>""
#    Call LECTURE("FCY",[M:BUR1]FCY,"") From CONTOBJ
#    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#    GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
#  Elsif [M:BUR1]LEG<>""
#    GCURLEG=[M:BUR1]LEG
#  Else
#    GCURLEG=GLEGFIL
#  Endif
  #SBA : US 1840-81085
  If([M:BUR1]LEG ="")
      GCURLEG=GLEGFIL
  Else
     GCURLEG=[M:BUR1]LEG
  Endif
  Local Integer WF
  # on active tous les champs.
  Actzo CPY,FCY
  # on grise selon la sélection.
  If([M:BUR1]CPY<>"" )
    Diszo [M:BUR1]FCY
    WF=1
  Elsif ([M:BUR1]FCY<>"" )
    Diszo [M:BUR1]CPY
    WF=1
  Endif
  # gestion si leg présente
  If dim([M:BUR1]LEG)>0
    GCURLEG=[M:BUR1]LEG
    If(WF)
      Diszo [M:BUR1]LEG
    Else
      Actzo [M:BUR1]LEG
      If [M:BUR1]LEG=""
        GCURLEG=GLEGFIL
      Endif
    Endif
  Else
    GCURLEG=GDOSLEG
  Endif
Return

######################################################################################
$VERIF_MOD
$VERIF_CRE
  # Contrôle de la cohérence des montants saisis

  # Premier contrôle : la saisie du budget en cours (bloquant)
  Local Decimal L_TOT_AMT_IND, L_TOT_AMT
  # indice du type de financement non renseigné (= global)
  L_TOT_AMT_IND = find("",[M:BUR1]TYPFIN(0..[M:BUR1]NBLIG-1))
  # S'il y a plus d'une ligne et s'il y a un montant global, alors on vérifie que la
  # somme des montants par type de financement est <= au montant global
  If [M:BUR1]NBLIG > 1 and L_TOT_AMT_IND > 0 Then
    # Calcul de la somme des types de financement
    L_TOT_AMT = sum([M:BUR1]AMTDET(0..[M:BUR1]NBLIG-1)) - [M:BUR1]AMTDET(L_TOT_AMT_IND-1)
    If L_TOT_AMT > [M:BUR1]AMTDET(L_TOT_AMT_IND-1) Then
      # Le montant global (999,99) est inférieur à la somme des montants des types de financement (999,99)
      # Fiche 70381 - SYMEU - 04/01/2011 - toujours mettre les décimales
      # GMESSAGE = mess(113,10717,1)-"("+num$([M:BUR1]AMTDET(L_TOT_AMT_IND-1))+")"-mess(114,10717,1)-"("+num$(L_TOT_AMT)+")"
      GMESSAGE = mess(113,10717,1)-"("+vireblc(format$([L]FORMAT_MTT, [M:BUR1]AMTDET(L_TOT_AMT_IND-1)),2)+")"-mess(114,10717,1)-"("+vireblc(format$([L]FORMAT_MTT, L_TOT_AMT),2)+")"
      #LIPET - 2017-06-26 - X3-29551 - START
      #OK = 0
      OK = 0 : Return : #JML
      #LIPET - 2017-06-26 - X3-29551 - END
    Endif
  Endif
  #LIPET - 2017-06-26 - X3-29551 - START
  # JML  07/10/15
  Call CTR_BUR([M:BUR1]BUDYEA, [M:BUR1]CPY, [M:BUR1]FCY, [M:BUR1]STRDAT, [M:BUR1]ENDDAT)
  If GMESSAGE<>"" : OK = 0 : Return: Endif
  #LIPET - 2017-06-26 - X3-29551 - END
Return

######################################################################################
$INIMOD
$INICRE
  If [F:BUR]FCY <> "" Then
    [F:BUR]LEV = 3 # niveau site
  Elsif [F:BUR]CPY <> "" Then
    [F:BUR]LEV = 2 # niveau société
  Else
    [F:BUR]LEV = 1 # niveau dossier
  Endif
Return

######################################################################################
$MODIF
  # Deuxième contrôle : la saisie du budget société par rapport au budget global du dossier
  # Quand on est au niveau dossier ou société
  If ([M:BUR1]CPY = "" and [M:BUR1]FCY = "")
& or  [M:BUR1]CPY <> "" Then
    # Fiche 70381 - SYMEU - 04/01/2011 - toujours mettre les décimales : passage du format en paramètre
    Call CTR_DOS([L]FORMAT_MTT)
    If GMESSAGE <> "" Then Return Endif
  Endif

  # Troisième contrôle : la saisie du budget société par rapport au budget global de tous ses sites
  # Quand on est au niveau société
  If  [M:BUR1]CPY <> "" Then
    Call CTR_SOC([M:BUR1]CPY,[L]FORMAT_MTT)
    If GMESSAGE <> "" Then Return Endif
  Endif

  # Quatrième contrôle : la saisie du budget du site par rapport au budget global de sa société
  # Quand on est au niveau site
  If [M:BUR1]FCY <> "" Then
    Call LECTURE("FCY",[M:BUR1]FCY,"") From CONTOBJ
    # Fiche 70381 - SYMEU - 04/01/2011 - toujours mettre les décimales : passage du format en paramètre
    Call CTR_SOC([F:FCY]LEGCPY,[L]FORMAT_MTT)
    If GMESSAGE <> "" Then Return Endif
  Endif

Return

######################################################################################
$DEGRISE
  # (dé)grisage du site et de la société
  Call AM_CPY([M:BUR1]CPY)
  Call AM_FCY([M:BUR1]FCY)
Return

$RAZCRE
  #29/06/12 - DKA - Default LEG value to users LEGFIL when creating a record
  If dim([M:BUR1]LEG)>0 Then
    [M:BUR1]LEG=GLEGFIL
    Affzo [M:BUR1]LEG
  Endif
Return

######################################################################################
#**
#* Contrôle de la cohérence des montants de toutes les sociétés par rapport au dossier
#* Fiche 70381 - SYMEU - 04/01/2011 - toujours mettre les décimales : format en paramètre
#*!
Subprog CTR_DOS(P_FORMAT_MTT)
Value Char P_FORMAT_MTT
  Local Decimal L_AMT_CPY, L_AMT_DOS, L_TOT_AMT, L_FINTYP_AMT
  Local Char L_CRIT_CPY
  L_CRIT_CPY = "CPY<>''"
  # Alimentation du montant global de toutes les sociétés
  L_AMT_CPY = func GET_CPYAMT(L_CRIT_CPY)

  # Lecture des budgets de référence du niveau dossier pour l'année en cours
  Raz L_TOT_AMT, L_FINTYP_AMT
  # Lecture du montant global de l'année en cours
  Filter [F:BUR2] Where BUDYEA = [M:BUR1]BUDYEA
&                   and CPY    = ""
&                   and FCY    = ""
  For [F:BUR2]
    If [F:BUR2]TYPFIN = "" Then
      L_TOT_AMT += [F:BUR2]AMTDET
    Else
      L_FINTYP_AMT += [F:BUR2]AMTDET
    Endif
  Next
  Filter [F:BUR2]
  # Alimentation du montant global du dossier
  If L_TOT_AMT > 0 Then
    L_AMT_DOS += L_TOT_AMT
  Else
    L_AMT_DOS += L_FINTYP_AMT
  Endif

  If L_AMT_CPY > L_AMT_DOS and L_AMT_DOS > 0 Then
    # La somme des montants de toutes les sociétés (999,99) est supérieure au montant du
    # dossier (999,99)
    # Fiche 70381 - SYMEU - 04/01/2011 - toujours mettre les décimales
    # GMESSAGE = mess(115,10717,1)-"("+num$(L_AMT_CPY)+")"-mess(116,10717,1)-"("+num$(L_AMT_DOS)+")"
    GMESSAGE = mess(115,10717,1)-"("+vireblc(format$(P_FORMAT_MTT, L_AMT_CPY),2)+")"-mess(116,10717,1)-"("+vireblc(format$(P_FORMAT_MTT, L_AMT_DOS),2)+")"
  Endif
End

######################################################################################
#**
#* Contrôle de la cohérence des montants de tous les sites de la société du site en cours
#* par rapport aux montants de la société du site en cours
#* Fiche 70381 - SYMEU - 04/01/2011 - toujours mettre les décimales : format en paramètre
#*!
Subprog CTR_SOC(P_SOC,P_FORMAT_MTT)
Value Char P_SOC, P_FORMAT_MTT
  Local Decimal L_AMT_CPY, L_AMT_SIT, L_TOT_AMT, L_FINTYP_AMT
  Local Char L_CRIT_CPY
  Local Char L_FACILITY(GLONFCY)

  # Lecture des budgets de référence de l'année en cours, pour tous les sites dont la société
  # est égale à celle reçue en paramètre
  Raz L_TOT_AMT, L_FINTYP_AMT
  # Lecture du montant global de l'année en cours
  Filter [F:BUR] Where BUDYEA = [M:BUR1]BUDYEA
&                  and CPY    = ""
&                  and FCY    <> ""
  For [F:BUR]
    If L_FACILITY = "" or (L_FACILITY <> "" and L_FACILITY <> [F:BUR]FCY) Then
      Call LECTURE("FCY",[F:BUR]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY = P_SOC Then
        # Le site appartient à la société cherchée
        Raz L_TOT_AMT, L_FINTYP_AMT
        # Lecture du montant global de l'année et de la société en cours
        Filter [F:BUR2] Where BUDYEA = [F:BUR]BUDYEA
&                         and CPY    = [F:BUR]CPY
&                         and FCY    = [F:BUR]FCY
        For [F:BUR2]
          If [F:BUR2]TYPFIN = "" Then
            L_TOT_AMT += [F:BUR2]AMTDET
          Else
            L_FINTYP_AMT += [F:BUR2]AMTDET
          Endif
        Next
        Filter [F:BUR2]
        # Alimentation du montant global de tous les sites de la société
        If L_TOT_AMT > 0 Then
          L_AMT_SIT += L_TOT_AMT
        Else
          L_AMT_SIT += L_FINTYP_AMT
        Endif
      Endif
      L_FACILITY = [F:BUR]FCY
    Endif
  Next
  Filter [F:BUR]

  L_CRIT_CPY = "CPY='"+P_SOC+"'"
  # Alimentation du montant global de la société
  L_AMT_CPY = func GET_CPYAMT(L_CRIT_CPY)

  If L_AMT_SIT > L_AMT_CPY and L_AMT_CPY > 0 Then
    # La somme des montants des sites de la société XXX (999,99) est supérieure au montant de
    # la société XXX (999,99)
    # Fiche 70381 - SYMEU - 04/01/2011 - toujours mettre les décimales
    # GMESSAGE = mess(117,10717,1)-P_SOC-"("+num$(L_AMT_SIT)+")"-mess(118,10717,1)-P_SOC-"("+num$(L_AMT_CPY)+")"
    GMESSAGE = mess(117,10717,1)-P_SOC-"("+vireblc(format$(P_FORMAT_MTT, L_AMT_SIT),2)+")"-mess(118,10717,1)-P_SOC-"("+vireblc(format$(P_FORMAT_MTT, L_AMT_CPY),2)+")"
  Endif
End
#LIPET - 2017-06-26 - X3-29551 - START
Subprog CTR_BUR(COD_BUD, COD_CPY, COD_FCY, DAT_STR, DAT_END)
Value   Char    COD_BUD(), COD_CPY(), COD_FCY()
Value   Date    DAT_STR, DAT_END

If clalev([F:PLF2])=0 : Local File PLNFORM  [PLF2] : Endif

Raz GMESSAGE
For [PLF2]PLF0 Where [PLF2]YEAPLF=COD_BUD & [PLF2]CPYPLF=COD_CPY & [PLF2]FCYPLF=COD_FCY
 If [F:PLF2]STRDAT<>DAT_STR | [F:PLF2]ENDDAT<>DAT_END
  # Il existe un plan de formation prévisionnel avec des dates différentes
  GMESSAGE = mess(309, 10717, 1) - format$(GFMDAT,[F:PLF2]STRDAT)-format$(GFMDAT,[F:PLF2]ENDDAT)
  Break
 Endif
Next : # [PLF2]PLF0
If GMESSAGE<>"" : End : Endif
End
#LIPET - 2017-06-26 - X3-29551 - END
######################################################################################
#**
#* Récupération du montant d'une société ou de toutes les sociétés
#*!
Funprog GET_CPYAMT(P_L_CRIT_CPY)
Value Char P_L_CRIT_CPY

  Local Char L_COMPANY(GLONCPY)
  Local Decimal L_AMT_CPY, L_TOT_AMT, L_FINTYP_AMT

  # Lecture des budgets de référence du niveau société pour l'année en cours
  Filter [F:BUR] Where [F:BUR]BUDYEA = [M:BUR1]BUDYEA and evalue(P_L_CRIT_CPY) and FCY = ""
&         Order By Key BUR0
  For [F:BUR]
    If L_COMPANY = "" or (L_COMPANY <> "" and L_COMPANY <> [F:BUR]CPY) Then
      Raz L_TOT_AMT, L_FINTYP_AMT
      # Lecture du montant global de l'année et de la société en cours
      Filter [F:BUR2] Where BUDYEA = [F:BUR]BUDYEA
&                       and CPY    = [F:BUR]CPY
&                       and FCY    = [F:BUR]FCY
      For [F:BUR2]
        If [F:BUR2]TYPFIN = "" Then
          L_TOT_AMT += [F:BUR2]AMTDET
        Else
          L_FINTYP_AMT += [F:BUR2]AMTDET
        Endif
      Next
      Filter [F:BUR2]
      # Alimentation du montant global de toutes les sociétés
      If L_TOT_AMT > 0 Then
        L_AMT_CPY += L_TOT_AMT
      Else
        L_AMT_CPY += L_FINTYP_AMT
      Endif
      L_COMPANY = [F:BUR]CPY
    Endif
  Next
  Filter [F:BUR]
End L_AMT_CPY

