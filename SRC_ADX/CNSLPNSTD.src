  mkstat = 2
Endif
End

######################################################################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
# Actzo ou Grizo des dépôts selon le site  #
If [M]FCY <>[F:FCY]FCY
  Read [FCY]FCY0=[M]FCY
Endif
If [F:FCY]WRHGES <> 2
  Raz   [M]WRH
  Affzo [M]WRH
  mkstat = 2
Endif

End


######################################################################################
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"LPN") From SUBGTC

End


######################################################################################
$LOAD_TREE

Local Integer NI
Local Integer NE
Local Integer NBLIGLPN
Local Char    SAVLPN(GLONLPN)
Local Char    WLPN(GLONLPN)

Local Char WFILLPN (250)

  Effzo [M:CLPN2]5
  # ------------------------------------
  # La racine c'est le LPN
  NE = 0
  [M:CLPN1]NBLPN = 0
  For [LNK]
    If [F:LPN]LPNNUM <> SAVLPN | SAVLPN = AVOID.ACHAR
      #recherche du nombre de lignes du LPN
      WLPN = [F:LPN]LPNNUM
      Link [LPN] With [STO1]STO6=[LPN]LPNNUM
&          As [LNK2]
#-- Application des Filtres
      Filter [LNK2] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)& evalue(WFIL2)
&                           & [F:STO1]LPNNUM = WLPN Order By STOFCY;LPNNUM;LOC;ITMREF;STOCOU Asc
      NBLIGLPN = rowcount([LNK2])
      #Pour ne pas afficher uniquement l'entête (NE+1) ou ne pas afficher le LPN si pas complet (NE+NBLIGNE)
      If (NE >= dim([M:CLPN2]PARKEY)) | (NE+1 >= dim([M:CLPN2]PARKEY)) | (NE + NBLIGLPN >= dim([M:CLPN2]PARKEY))
        Call MESSAGE(mess(26,100,1)) From GESECRAN
        Break
      Endif
      [M:CLPN2]KEYC(NE) = [F:LPN]LPNNUM
      SAVLPN = [F:LPN]LPNNUM
      [M:CLPN1]NBLPN += 1
      [M:CLPN2]OBJDES(NE) = [F:LPN]LPNNUM+"/"+[F:LPN]LOCTYP+"/"+[F:LPN]LOC
      [M:CLPN2]ICO(NE) = "Folder.gif"
      [M:CLPN2]EXPFLG = CST_ANO
      [M:CLPN2]CUNLOKFLG(NE) = 0
      NE += 1
      nolign = NE+1
      If NE >= dim([M:CLPN2]PARKEY)
        Call MESSAGE(mess(26,100,1)) From GESECRAN
        Break
      Endif
      [M:CLPN2]PARKEY(NE) = [F:LPN]LPNNUM
      [M:CLPN2]KEYC(NE)   = num$([F:STO1]STOCOU)
      [M:CLPN2]OBJDES(NE) = ""
      [M:CLPN2]ICO(NE) = "Produit.gif"
      [M:CLPN2]EXPFLG = CST_ANO
      [M:CLPN2] = [F:STO1]
      #Numéros de série
      If [F:ITM]ITMREF <> [F:STO1]ITMREF
        Read [ITM]ITM0 = [F:STO1]ITMREF
      Endif
      If [F:ITM]SERMGTCOD = 4
        If [F:STO1]QTYPCU = 1
          Filter [STS] Where [STS]ITMREF=[F:STO1]ITMREF & [STS]STOCOU = [F:STO1]STOCOU
          Read [STS] First
          If fstat: Raz [F:STS]: Endif
          [M:CLPN2]SERNUM(nolign-1) = [F:STS]SERNUM
        Else
          [M:CLPN2]SERNUM(nolign-1) = "$"
        Endif
        Filter [F:STS]
      Endif
      [M:CLPN2]STU(nolign-1) = [F:ITM]STU
    Else
      If NE >= dim([M:CLPN2]PARKEY)
        Call MESSAGE(mess(26,100,1)) From GESECRAN
        Break
      Endif
      [M:CLPN2]PARKEY(NE) = [F:LPN]LPNNUM
      [M:CLPN2]KEYC(NE)   = num$([F:STO1]STOCOU)
      [M:CLPN2]OBJDES(NE) = ""
      [M:CLPN2]ICO(NE) = "Produit.gif"
      [M:CLPN2]EXPFLG = CST_ANO
      #
      nolign = NE+1
      [M:CLPN2] = [F:STO1]
        #Numéros de série
      If [F:ITM]ITMREF <> [F:STO1]ITMREF
        Read [ITM]ITM0 = [F:STO1]ITMREF
      Endif
      If [F:ITM]SERMGTCOD = 4
        If [F:STO1]QTYPCU = 1
          Filter [STS] Where [STS]ITMREF=[F:STO1]ITMREF & [STS]STOCOU = [F:STO1]STOCOU
          Read [STS] First
          If fstat: Raz [F:STS]: Endif
          [M:CLPN2]SERNUM(nolign-1) = [F:STS]SERNUM
        Else
          [M:CLPN2]SERNUM(nolign-1) = "$"
        Endif
        Filter [F:STS]
      Endif
      [M:CLPN2]STU(nolign-1) = [F:ITM]STU
    Endif
      # -------------------------
      NE += 1
  Next NI
  [M:CLPN2]NBLIG = NE
  # ------------------------------------
  Affzo [M:CLPN2]5
  Affzo [M:CLPN1]NBLPN
Return

######################################################################################
Subprog AM_SERNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]SERNUMEND = ""     : [M]SERNUMEND = VALEUR : Affzo [M]SERNUMEND : Endif
If [M]SERNUMEND < VALEUR : [M]SERNUMEND = VALEUR : Affzo [M]SERNUMEND : Endif
End
######################################################################################
Subprog C_SERNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]SERNUMSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSLPN2) 18/05/2018 06:41:02 (MAE)
######################################################################################
Subprog IB_NBLIG
If [F:ITM]ITMREF <> [M:CLPN2]ITMREF(nolign-1)
Read [ITM]ITM0 = [M:CLPN2]ITMREF(nolign-1)
Endif
If [F:ITM]SERMGTCOD <> 4 | [M:CLPN2]ITMREF(nolign-1) = AVOID.ACHAR
  Raz GBOUT1
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CRITLPN) 18/05/2018 07:21:00 (MAE)
######################################################################################
Subprog AM_LOCTYPSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> AVOID.ACHAR & [M:CRLPN]LOCTYPEND = AVOID.ACHAR
  [M:CRLPN]LOCTYPEND = VALEUR
  Affzo [M:CRLPN]LOCTYPEND
Endif
End


Subprog AM_LOCSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> AVOID.ACHAR & [M:CRLPN]LOCEND = AVOID.ACHAR
  [M:CRLPN]LOCEND = VALEUR
  Affzo [M:CRLPN]LOCEND
Endif
End

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSLPN1) 18/05/2018 07:59:29 (MAE)
######################################################################################
Subprog AM_LOCSEL(VALEUR)
Variable Char    VALEUR()
[M:CLPN1]LOCSTR = VALEUR
[M:CLPN1]LOCEND = VALEUR
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSLPN1) 13/06/2018 06:58:07 (MAE)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  If dim([M:CLPN1]LOTSEL)>0
    Raz [M:CLPN1]LOTSEL
  Endif
  Raz [M:CLPN1]PALNUM
  Raz [M:CLPN1]CTRNUM
  If dim([M:CLPN1]ECCVALMAJ) > 0
    Raz [M:CLPN1]ECCVALMAJ
    Affzo [M:CLPN1]ECCVALMAJ
  Endif
  If dim([M:CLPN1]SERNUMSTR) > 0
   If !find([F:ITM]SERMGTCOD,2,3)           # hcb X3-70317
      Raz   [M:CLPN1]SERNUMSTR
      Raz   [M:CLPN1]SERNUMEND
   Endif
  Endif
#                                                     # hcb  X3-68850 deb
  If dim([M:CLPN1]LPNNUM) > 0
     If [F:ITF]STOFCY <> [M:CLPN1]FCY | [F:ITF]ITMREF <> [F:ITM]ITMREF
        Read [ITF]ITF0 = [F:ITM]ITMREF;[M:CLPN1]FCY
        If fstat
           Raz [F:ITF]
        Endif
     Endif
     If [F:ITF]LPNMGTCOD<>2
        Raz   [M:CLPN1]LPNNUM
        Affzo [M:CLPN1]LPNNUM
        Diszo [M:CLPN1]LPNNUM
     Else
        Actzo [M:CLPN1]LPNNUM
     Endif
  Endif
#                                                     # hcb  X3-68850 fin
Endif
End


######################################################################################

