            Wrseq SZBUFFTOFILL(0) Using [FXML]
        Endif
        Endif
    Endif
    Endif

    If GHBP1BPRSIH
    If [F:HST]RECTYP = "BIC"
        Read [SIV] SIV0 = [F:HST]RECNUM
        If fstat
            Read [SIH] SIH0 = [F:HST]RECNUM
            If !fstat
            Raz SZBUFFTOFILL
            If ITODO
                SZBUFFTOFILL(0) = A + SZXRECORD
&                              + " T=" + VQ + "BIC" + VQ
&                              + " D=" + VQ + "N" + VQ
&                              + " S=" + VQ + num$([F:HST]CLSNUM) + VQ + D
            Else
                SZBUFFTOFILL(0) = A + SZXRECORD
&                              + " T=" + VQ + "BIC" + VQ
&                              + " D=" + VQ + "Y" + VQ
&                              + " S=" + VQ + num$([F:HST]CLSNUM) + VQ + D
            Endif
            Wrseq SZBUFFTOFILL(0) Using [FXML]

            ITERCOL = 0
            For ITERCOL = 0 To dim(ICOLSORT) - 1
                Case ICOLSORT(ITERCOL)
                            When 1
                                #Colonne Action
                                Raz SZBUFFTOFILL
                                SZBUFFTOFILL(0) = A + SZXFIELD + " F=" + VQ + "TYPCLA" + VQ + D
                                Wrseq SZBUFFTOFILL(0) Using [FXML]

                                SZDATAFORFILL = mess(43, 109, 1)
                                Gosub WRITEXML2 From CRMXML140

                            When 2
                                #Colonne Catégorie
                                Raz SZBUFFTOFILL
                                SZBUFFTOFILL(0) = A + SZXFIELD + " F=" + VQ + "CATCLA" + VQ + D
                                Wrseq SZBUFFTOFILL(0) Using [FXML]

                                If [F:SIH]SIVTYP = ""
                                    SZDATAFORFILL = mess([F:SIH]INVTYP, 645, 2)
                                    Gosub WRITEXML2 From CRMXML140
                                Else
                                    Call GETLEG([F:SIH]CPY,"T",LEGIS) From TRTLECLEG
                                    Call LEC_TSV_LEG(LEGIS,[F:SIH]SIVTYP,RET) From TRTLECLEG
                                    #Read [TSV] TSV0 = [F:SIH]SIVTYP
                                    If RET
                                        SZDATAFORFILL = mess([F:SIH]INVTYP, 645, 2)
                                        Gosub WRITEXML2 From CRMXML140
                                    Else
                                        Local Char AXX_TSVDES (80)
                                        Call GET_ATEXTRA("TABSIVTYP","DESAXX",GLANGUE,AXX_TSVDES) From TRTX3TEX 
                                        If AXX_TSVDES = ""
                                           SZDATAFORFILL = mess([F:SIH]INVTYP, 645, 2)
                                           Gosub WRITEXML2 From CRMXML140
                                        Else
                                           SZDATAFORFILL = AXX_TSVDES
                                           Gosub WRITEXML2 From CRMXML140
                                        Endif
                                    Endif
                                Endif

                            When 3
                                #Colonne Date
                                Raz SZBUFFTOFILL
                                SZBUFFTOFILL(0) = A + SZXFIELD + " F=" + VQ + "DAT" + VQ + D
                                Wrseq SZBUFFTOFILL(0) Using [FXML]

                                If [F:HST]RECDAT <> [00/00/00]
                                    SZDATAFORFILL = format$(GFMD,[F:HST]RECDAT)
                                    Gosub WRITEXML2 From CRMXML140
                                Endif

                            When 4
                                #Colonne Heure
                                Raz SZBUFFTOFILL
                                SZBUFFTOFILL(0) = A + SZXFIELD + " F=" + VQ + "HOU" + VQ + D
                                Wrseq SZBUFFTOFILL(0) Using [FXML]

                            When 5
                                #Colonne Représentant
                                Raz SZBUFFTOFILL
                                SZBUFFTOFILL(0) = A + SZXFIELD + " F=" + VQ + "REP" + VQ + D
                                Wrseq SZBUFFTOFILL(0) Using [FXML]

                            When 6
                                #Colonne Interlocuteur
                                Raz SZBUFFTOFILL
                                SZBUFFTOFILL(0) = A + SZXFIELD + " F=" + VQ + "CCN" + VQ + D
                                Wrseq SZBUFFTOFILL(0) Using [FXML]

                            When 7
                                #Colonne Affaire
                                Raz SZBUFFTOFILL
                                SZBUFFTOFILL(0) = A + SZXFIELD + " F=" + VQ + "OPP" + VQ + D
                                Wrseq SZBUFFTOFILL(0) Using [FXML]

                        Endcase

                        Raz SZBUFFTOFILL
                        SZBUFFTOFILL(0) = B + SZXFIELD + D
                        Wrseq SZBUFFTOFILL(0) Using [FXML]
            Next

            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = B + SZXRECORD + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
        Endif
        Endif
    Endif
    Endif

    I += 1
Next

Filter [HST]

Return


#######################################################
# Description des colonnes affichées
#######################################################
$DOCORECOL

Raz SZBUFFTOFILL
SZBUFFTOFILL(0) = A + SZXCTITLES + D
Wrseq SZBUFFTOFILL(0) Using [FXML]

ITERCOL = 0
For ITERCOL = 0 To dim(ICOLSORT) - 1
            Case ICOLSORT(ITERCOL)
                When 1
                    #Colonne Action
                    Raz SZBUFFTOFILL
                    SZBUFFTOFILL(0) = A + SZXCOLTITLE + " S=" + VQ + "1" + VQ + " F=" + VQ + "TYPCLA" + VQ + D
                    Wrseq SZBUFFTOFILL(0) Using [FXML]

                    Call TEXTE(90, SZDATAFORFILL) From OBJDIV      #Action
                    Gosub WRITEXML2 From CRMXML140

                When 2
                    #Colonne Catégorie
                    Raz SZBUFFTOFILL
                    SZBUFFTOFILL(0) = A + SZXCOLTITLE + " S=" + VQ + "2" + VQ + " F=" + VQ + "CATCLA" + VQ + D
                    Wrseq SZBUFFTOFILL(0) Using [FXML]

                    Call TEXTE(707, SZDATAFORFILL) From OBJDIV      #Catégorie
                    Gosub WRITEXML2 From CRMXML140

                When 3
                    #Colonne Date
                    Raz SZBUFFTOFILL
                    SZBUFFTOFILL(0) = A + SZXCOLTITLE + " S=" + VQ + "3" + VQ + " F=" + VQ + "DAT" + VQ + D
                    Wrseq SZBUFFTOFILL(0) Using [FXML]

                    Call TEXTE(212, SZDATAFORFILL) From OBJDIV      #Date
                    Gosub WRITEXML2 From CRMXML140

                When 4
                    #Colonne Heure
                    Raz SZBUFFTOFILL
                    SZBUFFTOFILL(0) = A + SZXCOLTITLE + " S=" + VQ + "4" + VQ + " F=" + VQ + "HOU" + VQ + D
                    Wrseq SZBUFFTOFILL(0) Using [FXML]

                    Call TEXTE(847, SZDATAFORFILL) From OBJDIV      #Heure
                    Gosub WRITEXML2 From CRMXML140

                When 5
                    #Colonne Représentant
                    Raz SZBUFFTOFILL
                    SZBUFFTOFILL(0) = A + SZXCOLTITLE + " S=" + VQ + "5" + VQ + " F=" + VQ + "REP" + VQ + D
                    Wrseq SZBUFFTOFILL(0) Using [FXML]

                    Call TEXTE(2929, SZDATAFORFILL) From OBJDIV      #Représentant
                    Gosub WRITEXML2 From CRMXML140

                When 6
                    #Colonne Interlocuteur
                    Raz SZBUFFTOFILL
                    SZBUFFTOFILL(0) = A + SZXCOLTITLE + " S=" + VQ + "6" + VQ + " F=" + VQ + "CCN" + VQ + D
                    Wrseq SZBUFFTOFILL(0) Using [FXML]

                    Call TEXTE(10981, SZDATAFORFILL) From OBJDIV      #Interlocuteur
                    Gosub WRITEXML2 From CRMXML140

                When 7
                    #Colonne Affaire
                    Raz SZBUFFTOFILL
                    SZBUFFTOFILL(0) = A + SZXCOLTITLE + " S=" + VQ + "7" + VQ + " F=" + VQ + "OPP" + VQ + D
                    Wrseq SZBUFFTOFILL(0) Using [FXML]

                    Call TEXTE(18260, SZDATAFORFILL) From OBJDIV      #Affaire
                    Gosub WRITEXML2 From CRMXML140


            Endcase

            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = B + SZXCOLTITLE + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
Next

Raz SZBUFFTOFILL
SZBUFFTOFILL(0) = B + SZXCTITLES + D
Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

