#<AdxTL>@(#)2.0.0.0 $Revision$
###############################################################################################################
#
#   Génération XML d'un historique tiers                                                         Version 140
#   Module CRM                             
#
#   HBP1INXML    : Extraction XML de l'historique
#   
###############################################################################################################

Subprog HBP1INXML(SZRECNUM, SZCOLSORT, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Char SZCOLSORT
Value Integer IGENERICFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF
ICHAPTER = 0
IERRINF = 0
SZFULLRETFILE = ""
SZRETFILENAME = ""

If SZRECNUM = "" : End : Endif
If SZCOLSORT = ""
    SZCOLSORT = "1234567"
Endif

Local Char SZBPRNUM
Local Char SZBPRNAM(50)
If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
Read [BPR] BPR0 = SZRECNUM
If fstat
    End
Else
    SZBPRNUM = [F:BPR]BPRNUM
    SZBPRNAM = [F:BPR]BPRNAM
Endif

#Mise en mémoire des colonnes
Local Integer ICOLSORT(7)
ICOLSORT(0) = val(mid$(SZCOLSORT, 1, 1))
ICOLSORT(1) = val(mid$(SZCOLSORT, 2, 1))
ICOLSORT(2) = val(mid$(SZCOLSORT, 3, 1))
ICOLSORT(3) = val(mid$(SZCOLSORT, 4, 1))
ICOLSORT(4) = val(mid$(SZCOLSORT, 5, 1))
ICOLSORT(5) = val(mid$(SZCOLSORT, 6, 1))
ICOLSORT(6) = val(mid$(SZCOLSORT, 7, 1))

Call TEMPON("L") From GESECRAN

##################
#Génération de la feuille de style si SZXSLSHEET = STD
If toupper(SZXSLSHEET) = "STD"
    SZXSLSHEET = "HBP1STD"
    Call GENSTDHBP1XSL(SZXSLSHEET)
Endif

Local Char SZACTIONDONE(100)
Local Char SZACTIONTODO(100)
Local Char SZXACTIONDONE
Local Char SZXACTIONTODO
Local Char SZXCTITLES
Local Char SZXCOLTITLE
Local Integer ITERCOL
Local Integer ITERCOL2
Local Integer ITERCOL3
Local Integer ICLS
Local Integer ITODO
Local Integer ITRB
Local Mask HBP1 [HBP1]
Global Integer GHBP1SQH
Global Integer GHBP1SOH
Global Integer GHBP1SDH
Global Integer GHBP1SIV
Global Integer GHBP1BPRSIH
Global Integer GIFILLDONE
Global Integer GIFILLTODO
Global Char GSZBPRNUM
GSZBPRNUM = SZRECNUM
GIFILLDONE = 0
GIFILLTODO = 0
ICLS = 0
ITODO = 0
ITRB = 0
ITERCOL3 = 0
ITERCOL2 = 0
ITERCOL = 0
SZXCOLTITLE = "XCOLTITLE"
SZXCTITLES = "XCTITLES"
SZXACTIONDONE = "XACTIONDONE"
SZXACTIONTODO = "XACTIONTODO"
#Liste des actions effectuées
SZACTIONDONE = mess(349, 196, 2)
#Liste des actions à effectuer
SZACTIONTODO = mess(350, 196, 2)

If !clalev([F:HST]) : Local File HISTOCRM [HST] : Endif
If !clalev([F:BAP]) : Local File BAPPOINT [BAP] : Endif
If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
If !clalev([F:TSK]) : Local File TASK [TSK] : Endif
If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
If !clalev([F:ITN]) : Local File INTERVEN [ITN] : Endif
If !clalev([F:HIM]) : Local File HISTOOMM [HIM] : Endif
If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
If !clalev([F:SQH]) : Local File SQUOTE [SQH] : Endif
If !clalev([F:SOH]) : Local File SORDER [SOH] : Endif
If !clalev([F:TSO]) : Local File TABSOHTYP [TSO] : Endif
If !clalev([F:SDH]) : Local File SDELIVERY [SDH] : Endif
If !clalev([F:SIH]) : Local File SINVOICE [SIH] : Endif
If !clalev([F:SIV]) : Local File SINVOICEV [SIV] : Endif
If !clalev([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif

#Obtient les paramètres personnels de l'utilisateur
Read [DVA] DVA0 = "HBP";GUSER
If fstat
    #L'utilisateur ne s'est pas défini de paramètres perso
    #On charge donc les valeurs relatives au comportement par défaut
    GHBP1SQH = 1
    GHBP1SOH = 1
    GHBP1SDH = 0
    GHBP1SIV = 0
    GHBP1BPRSIH = 0
Else
    If [F:DVA]INTX(0) = 1
        GHBP1SQH = 0
    Else
        GHBP1SQH = 1
    Endif

    If [F:DVA]INTX(1) = 1
        GHBP1SOH = 0
    Else
        GHBP1SOH = 1
    Endif

    If [F:DVA]INTX(2) = 2
        GHBP1SDH = 1
    Else
        GHBP1SDH = 0
    Endif

    If [F:DVA]INTX(3) = 2
        GHBP1SIV = 1
    Else
        GHBP1SIV = 0
    Endif

    If [F:DVA]INTX(4) = 2
        GHBP1BPRSIH = 1
    Else
        GHBP1BPRSIH = 0
    Endif
Endif

Call FILLHST(0, IERRINF) From TRTHBP1
If IERRINF
    Close Local Mask [HBP1]
    End
Endif

Call FILLHST(1, IERRINF) From TRTHBP1
If IERRINF
    Close Local Mask [HBP1]
    End
Endif

Call TEMPOFF From GESECRAN

#Extraction XML
Gosub XMLPART1 From CRMXML140

#Historique du tiers : (XXXX) + XXXXXXXX
SZHTMLTITLE = mess(158, 177, 2) + " : (" + SZBPRNUM + ") " + SZBPRNAM
SZSUBPROG = "HBP1INXML"
SZAOBABREV = "HBP1"

If SZXCOLTITLE = ""
    SZXCOLTITLE = "XCOLTITLE"
Endif

If SZXCTITLES = ""
    SZXCTITLES = "XCTITLES"
Endif

If SZXACTIONDONE = ""
    SZXACTIONDONE = "XACTIONDONE"
Endif

If SZXACTIONTODO = ""
    SZXACTIONTODO = "XACTIONTODO"
Endif

Gosub XMLPART2HBP1 From CRMXML140
If IERRINF : End : Endif

Gosub DOCORECOL

ITODO = 0
Gosub DOCOREXML
ITODO = 1
Gosub DOCOREXML

Gosub XMLPART3 From CRMXML140

Close Local Mask [HBP1]

#Suppression du fichier de travail 
Call RAZ_HST From TRTHBP1

Kill GHBP1SQH
Kill GHBP1SOH
Kill GHBP1SDH
Kill GHBP1SIV
Kill GHBP1BPRSIH
Kill GIFILLDONE
Kill GIFILLTODO
Kill GSZBPRNUM
End

###############################################################
#Génération de la feuille de style standard
###############################################################
Subprog GENSTDHBP1XSL(SZXSLSHEET)
Value Char SZXSLSHEET

#Caractères XML
Local Char A(2)
Local Char B(4)
Local Char C(4)
Local Char D(2)
Local Char VQ(2)
Local Char SP(2)
SP = '_'
VQ = '"'
A = "<"
B = "</"
C = "/>"
D = ">"

Local Integer IWHERE
Local Char SZHTMLTITLE(250)
Local Char SZLABELFORFILL(250)
Local Char SZDATAFORFILL(250)
Local Char SZBUFFTOFILL(250)(2)      #Buffers d'écriture
Local Char SZADXIFS                  #Séparateurs
Local Char SZADXIRS                  #Séparateurs
Local Char SZXMLFILENAME(250)
Local Char SZWFNAME(250)
Local Char SZSUBPROG
Local Char SZAOBABREV

SZADXIFS = adxifs
SZADXIRS = adxirs
adxifs = ""
adxirs = chr$(10)
Raz SZBUFFTOFILL
Raz SZLABELFORFILL
Raz SZDATAFORFILL
IWHERE = 1

Local Char SZCTAOB
Local Char SZCTAOBTITLE(100)
Local Char SZCTAOBNUM(100)
Local Char SZCTLEVEL
Local Char SZCTPARENTAOB
Local Char SZCTPARENTNUM
SZCTAOB = ""
SZCTAOBTITLE = ""
SZCTAOBNUM = ""
SZCTLEVEL = ""
SZCTPARENTAOB = ""
SZCTPARENTNUM = ""

#Fichier XSL
SZWFNAME = SZXSLSHEET
SZXMLFILENAME = ""

#Ouverture du fichier XSL
Call BUILDFICNAME(IWHERE, SZWFNAME, "xsl", SZXMLFILENAME) From CRMXML140
If SZXMLFILENAME = ""
    #Erreur lors de l'ouverture du fichier XML
    IERRINF = 95
    ICHAPTER = 177
    #On restaure les variables adxifs et adxirs
    adxifs = SZADXIFS
    adxirs = SZADXIRS
    End
Endif

#Définition des couleurs par défaut.
Local Char SZTABLEBORDER
Local Char SZHEADERTEXT
Local Char SZHEADERBACK
Local Char SZHEADERBORDER
Local Char SZLINETEXT
Local Char SZLINEBACK
SZLINEBACK = "#E6F0F5"
SZLINETEXT = "#006699"
SZHEADERBORDER = "#006699"
SZHEADERBACK = "#FF9933"
SZHEADERTEXT = "#006699"
SZTABLEBORDER = "#006699"

#Modification des couleurs standards par point d'entrée
Gosub PE_MGGCOLXSL From TRTCRMPE

Openo SZXMLFILENAME, 0 Using [FXSL]

#<?xml version="1.0" encoding="ISO-8859-1" standalone="yes" ?>
SZBUFFTOFILL(0) = A + "?xml version=" + VQ + "1.0" + VQ + " encoding=" + VQ 
& + "ISO-8859-1" + VQ + " standalone=" + VQ + "yes" + VQ + " ?" + D
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" version="1.0">
SZBUFFTOFILL(0) = A + "xsl:stylesheet xmlns:xsl=" + VQ + "http://www.w3.org/1999/XSL/Transform"
& + VQ + " version=" + VQ + "1.0" + VQ + D
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:output method="html"/><xsl:template match="/">
SZBUFFTOFILL(0) = A + "xsl:output method=" + VQ + "html" + VQ + "/><xsl:template match=" + VQ + "/" + VQ + D
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<HTML><HEAD><TITLE><xsl:value-of select="//XUTILITY/XTITLE"/></TITLE><STYLE>
SZBUFFTOFILL(0) = A + "HTML" + D + A + "HEAD" + D + A + "TITLE" + D + A + "xsl:value-of select="
&  + VQ + "//XUTILITY/XTITLE" + VQ + "/></TITLE><STYLE>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#TABLE.cX3Table {BORDER-STYLE:solid;BORDER-COLOR:#006699;BORDER-WIDTH:1;FONT-SIZE:x-small}
SZBUFFTOFILL(0) = "TABLE.cX3Table {BORDER-STYLE:solid;BORDER-COLOR:" + SZTABLEBORDER + ";BORDER-WIDTH:1;FONT-SIZE:x-small}"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#TD.cX3TDHeader {FONT-STYLE:ITALIC;COLOR:#006699;BACKGROUND-COLOR:#FF9933;BORDER-STYLE:solid;BORDER-COLOR:#006699;BORDER-WIDTH:1}
SZBUFFTOFILL(0) = "TD.cX3TDHeader {FONT-STYLE:ITALIC;COLOR:" + SZHEADERTEXT
& + ";BACKGROUND-COLOR:" + SZHEADERBACK + ";BORDER-STYLE:solid;BORDER-COLOR:" + SZHEADERBORDER + ";BORDER-WIDTH:1}"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#TD.cX3TDLine {FONT-STYLE:NORMAL;COLOR:#006699;BACKGROUND-COLOR:#E6F0F5}
SZBUFFTOFILL(0) = "TD.cX3TDLine {FONT-STYLE:NORMAL;COLOR:" + SZLINETEXT + ";BACKGROUND-COLOR:" + SZLINEBACK + "}"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#TD.cX3TDAction {FONT-STYLE:NORMAL;FONT-WEIGHT:BOLD;COLOR:#006699;BACKGROUND-COLOR:#E6F0F5}
SZBUFFTOFILL(0) = "TD.cX3TDAction {FONT-STYLE:NORMAL;FONT-WEIGHT:BOLD;COLOR:" + SZLINETEXT + ";BACKGROUND-COLOR:" + SZLINEBACK + "}"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#</STYLE></HEAD><BODY><DIV>
SZBUFFTOFILL(0) = "</STYLE></HEAD><BODY><DIV>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:if test="count(//XRECORD[@D = 'Y']) > 0"><xsl:apply-templates select="//XUTILITY/XACTIONDONE"/></xsl:if>
SZBUFFTOFILL(0) = "<xsl:if test=" + VQ + "count(//XRECORD[@D = 'Y']) > 0" + VQ + "><xsl:apply-templates select="
&  + VQ + "//XUTILITY/XACTIONDONE" + VQ + "/></xsl:if>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:if test="count(//XRECORD[@D = 'N']) > 0"><xsl:apply-templates select="//XUTILITY/XACTIONTODO"/></xsl:if>
SZBUFFTOFILL(0) = "<xsl:if test=" + VQ + "count(//XRECORD[@D = 'N']) > 0" + VQ + "><xsl:apply-templates select="
&  + VQ + "//XUTILITY/XACTIONTODO" + VQ + "/></xsl:if>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#</DIV></BODY></HTML></xsl:template>
SZBUFFTOFILL(0) = "</DIV></BODY></HTML></xsl:template>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:template match="//XACTIONDONE">
SZBUFFTOFILL(0) = "<xsl:template match=" + VQ + "//XACTIONDONE" + VQ + D
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<TABLE CELLSPACING="5" CELLPADDING="5" CLASS="cX3Table"><THEAD><TR>
SZBUFFTOFILL(0) = A + "TABLE CELLSPACING=" + VQ + "5" + VQ + " CELLPADDING="
& + VQ + "5" + VQ + " CLASS=" + VQ + "cX3Table" + VQ + "><THEAD><TR" + D
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:if test="count(//XRECORD[@D = 'N']) > 0">
SZBUFFTOFILL(0) = "<xsl:if test=" + VQ + "count(//XRECORD[@D = 'N']) > 0" + VQ + D
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<TD COLSPAN="6" CLASS="cX3TDAction"><xsl:value-of select="//XUTILITY/XACTIONDONE"/></TD>
SZBUFFTOFILL(0) = "<TD COLSPAN=" + VQ + "6" + VQ + " CLASS=" + VQ + "cX3TDAction" + VQ
& + "><xsl:value-of select=" + VQ + "//XUTILITY/XACTIONDONE" + VQ + "/></TD" + D
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<TD CLASS="cX3TDLine"><A HREF="#TODO">+</A></TD></xsl:if>
SZBUFFTOFILL(0) = "<TD CLASS=" + VQ + "cX3TDLine" + VQ
& + "><A HREF=" + VQ + "#TODO" + VQ + ">+</A></TD></xsl:if" + D
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:if test="count(//XRECORD[@D = 'N']) = 0">
SZBUFFTOFILL(0) = "<xsl:if test=" + VQ + "count(//XRECORD[@D = 'N']) = 0" + VQ + D
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<TD COLSPAN="7" CLASS="cX3TDAction"><xsl:value-of select="//XUTILITY/XACTIONDONE"/></TD>
SZBUFFTOFILL(0) = "<TD COLSPAN=" + VQ + "7" + VQ + " CLASS=" + VQ + "cX3TDAction" + VQ
& + "><xsl:value-of select=" + VQ + "//XUTILITY/XACTIONDONE" + VQ + "/></TD" + D
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#</xsl:if></TR><TR><xsl:apply-templates select="//XCOLTITLE"/></TR></THEAD><TBODY>
SZBUFFTOFILL(0) = "</xsl:if></TR><TR><xsl:apply-templates select=" + VQ + "//XCOLTITLE" + VQ + "/></TR></THEAD><TBODY>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:apply-templates select="//XRECORD[@D = 'Y']"/></TBODY></TABLE></xsl:template>
SZBUFFTOFILL(0) = "<xsl:apply-templates select=" + VQ + "//XRECORD[@D = 'Y']" + VQ + "/></TBODY></TABLE></xsl:template>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:template match="//XACTIONTODO">
SZBUFFTOFILL(0) = "<xsl:template match=" + VQ + "//XACTIONTODO" + VQ + D
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<P><A NAME="#TODO"></A></P>
SZBUFFTOFILL(0) = "<P><A NAME=" + VQ + "#TODO" + VQ + "></A></P>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<TABLE CELLSPACING="5" CELLPADDING="5" CLASS="cX3Table"><THEAD><TR>
SZBUFFTOFILL(0) = A + "TABLE CELLSPACING=" + VQ + "5" + VQ + " CELLPADDING="
& + VQ + "5" + VQ + " CLASS=" + VQ + "cX3Table" + VQ + "><THEAD><TR" + D
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<TD COLSPAN="7" CLASS="cX3TDAction">
SZBUFFTOFILL(0) = "<TD COLSPAN=" + VQ + "7" + VQ + " CLASS=" + VQ + "cX3TDAction" + VQ + D
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:value-of select="//XUTILITY/XACTIONTODO"/></TD>
SZBUFFTOFILL(0) = "<xsl:value-of select=" + VQ + "//XUTILITY/XACTIONTODO" + VQ + "/></TD>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#</TR><TR><xsl:apply-templates select="//XCOLTITLE"/></TR></THEAD><TBODY>
SZBUFFTOFILL(0) = "</TR><TR><xsl:apply-templates select=" + VQ + "//XCOLTITLE" + VQ + "/></TR></THEAD><TBODY>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:apply-templates select="//XRECORD[@D = 'N']"/></TBODY></TABLE></xsl:template>
SZBUFFTOFILL(0) = "<xsl:apply-templates select=" + VQ + "//XRECORD[@D = 'N']" + VQ + "/></TBODY></TABLE></xsl:template>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:template match="//XCOLTITLE"><TD CLASS="cX3TDHeader"><xsl:apply-templates/></TD></xsl:template>
SZBUFFTOFILL(0) = "<xsl:template match=" + VQ + "//XCOLTITLE" + VQ + "><TD CLASS="
& + VQ + "cX3TDHeader" + VQ + "><xsl:apply-templates/></TD></xsl:template>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:template match="//XRECORD[@D = 'Y']"><TR><xsl:apply-templates select="./XFIELD"/></TR></xsl:template>
SZBUFFTOFILL(0) = "<xsl:template match=" + VQ + "//XRECORD[@D = 'Y']"
& + VQ + "><TR><xsl:apply-templates select=" + VQ + "./XFIELD" + VQ + "/></TR></xsl:template>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:template match="//XRECORD[@D = 'N']"><TR><xsl:apply-templates select="./XFIELD"/></TR></xsl:template>
SZBUFFTOFILL(0) = "<xsl:template match=" + VQ + "//XRECORD[@D = 'N']"
& + VQ + "><TR><xsl:apply-templates select=" + VQ + "./XFIELD" + VQ + "/></TR></xsl:template>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#<xsl:template match="//XFIELD"><TD CLASS="cX3TDLine"><xsl:apply-templates/></TD></xsl:template></xsl:stylesheet>
SZBUFFTOFILL(0) = "<xsl:template match=" + VQ + "//XFIELD" + VQ + "><TD CLASS=" + VQ + "cX3TDLine"
& + VQ + "><xsl:apply-templates/></TD></xsl:template></xsl:stylesheet>"
Wrseq SZBUFFTOFILL(0)  Using [FXSL]

#On ferme le fichier XML
Openo Using [FXSL]

#On restaure les variables adxifs et adxirs
adxifs = SZADXIFS
adxirs = SZADXIRS

End

###########################################################
$DOCOREXML
Local Integer I
I = 0

If ITODO
    Filter [HST] Where [F:HST]SSS = GIDENT and [F:HST]DON <> 2 and [F:HST]CLSNUM >= ICLS Order By [F:HST]CLSNUM Asc
Else
    Filter [HST] Where [F:HST]SSS = GIDENT and [F:HST]DON = 2 and [F:HST]CLSNUM >= ICLS Order By [F:HST]CLSNUM Asc
Endif

For [HST] Hint Key HST2
    If I >= dim([M:HBP1]TYPCLA) : Break : Endif

    If [F:HST]RECTYP = "OPP"
        Read [OPP] OPP0 = [F:HST]RECNUM
        If !fstat
            Raz SZBUFFTOFILL
            If ITODO
                SZBUFFTOFILL(0) = A + SZXRECORD
&                              + " T=" + VQ + "OPP" + VQ
&                              + " D=" + VQ + "N" + VQ
&                              + " S=" + VQ + num$([F:HST]CLSNUM) + VQ + D
            Else
                SZBUFFTOFILL(0) = A + SZXRECORD
&                              + " T=" + VQ + "OPP" + VQ
&                              + " D=" + VQ + "Y" + VQ
&                              + " S=" + VQ + num$([F:HST]CLSNUM) + VQ + D
            Endif
            Wrseq SZBUFFTOFILL(0) Using [FXML]

            ITERCOL = 0
            For ITERCOL = 0 To dim(ICOLSORT) - 1
                Case ICOLSORT(ITERCOL)

                            When 1
                                #Colonne Action
                                Raz SZBUFFTOFILL
                                SZBUFFTOFILL(0) = A + SZXFIELD + " F=" + VQ + "TYPCLA" + VQ + D
                                Wrseq SZBUFFTOFILL(0) Using [FXML]

                                SZDATAFORFILL = mess(1, 967, 2) #Affaire
                                Gosub WRITEXML2 From CRMXML140

                            When 2
                                #Colonne Catégorie
                                Raz SZBUFFTOFILL
                                SZBUFFTOFILL(0) = A + SZXFIELD + " F=" + VQ + "CATCLA" + VQ + D
                                Wrseq SZBUFFTOFILL(0) Using [FXML]

                                If [F:OPP]OPPTYP <> ""
                                    Call GET_LIB(434, [F:OPP]OPPTYP, SZDATAFORFILL) From CRM_UTIL
                                    Gosub WRITEXML2 From CRMXML140
                                Endif

                            When 3
                                #Colonne Date
                                Raz SZBUFFTOFILL
                                SZBUFFTOFILL(0) = A + SZXFIELD + " F=" + VQ + "DAT" + VQ + D
                                Wrseq SZBUFFTOFILL(0) Using [FXML]

                                If ITODO
                                    If [F:OPP]OPPCDA <> [00/00/00]
                                        SZDATAFORFILL = format$(GFMD,[F:OPP]OPPCDA)
                                        Gosub WRITEXML2 From CRMXML140
                                    Endif
                                Else
                                    If [F:OPP]OPPREACDA <> [00/00/00]
                                        SZDATAFORFILL = format$(GFMD,[F:OPP]OPPREACDA)
                                        Gosub WRITEXML2 From CRMXML140
                                    Endif
                                Endif

                            When 4
                                #Colonne Heure
                                Raz SZBUFFTOFILL
                                SZBUFFTOFILL(0) = A + SZXFIELD + " F=" + VQ + "HOU" + VQ + D
                                Wrseq SZBUFFTOFILL(0) Using [FXML]

                            When 5
                                #Colonne Représentant
                                Raz SZBUFFTOFILL
                                SZBUFFTOFILL(0) = A + SZXFIELD + " F=" + VQ + "REP" + VQ + D
                                Wrseq SZBUFFTOFILL(0) Using [FXML]

                                If [F:OPP]OPPREP <> ""
                                    Read [REP] REP0 = [F:OPP]OPPREP
                                    If !fstat
