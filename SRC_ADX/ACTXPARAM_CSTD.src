# Classe ACONTEXTACACHE

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#  When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "AGETVALCHAR"      : Gosub AGETVALCHAR
    When "AGETVALNUM"       : Gosub AGETVALNUM
    When "AGETVALDATE"      : Gosub AGETVALDATE
    When "AGETUSERVALCHAR"  : Gosub AGETUSERVALCHAR
    When "AGETUSERVALNUM"   : Gosub AGETUSERVALNUM
    When "AGETUSERVALDATE"  : Gosub AGETUSERVALDATE
    When "_AGETADPTYP"      : Gosub _AGETADPTYP
    When "_AGETADPLEV"      : Gosub _AGETADPLEV
    When "_ACLEAN"          : Gosub _ACLEAN
    When "_AINIT_LIST_LEG"  : Gosub _AINIT_LIST_LEG
    When "_AINIT_LIST_FCY"  : Gosub _AINIT_LIST_FCY
    When "_AINIT_LIST_CPY"  : Gosub _AINIT_LIST_CPY
    When "_AEXISTFCY"       : Gosub _AEXISTFCY
    When "_AGETNBFCY"       : Gosub _AGETNBFCY
    When "_AEXISTCPY"       : Gosub _AEXISTCPY
    When "_AGETNBCPY"       : Gosub _AGETNBCPY
    When "_AEXISTLEG"       : Gosub _AEXISTLEG
    When "_AGETNBLEG"       : Gosub _AGETNBLEG
  Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


##########################################################################################
$_AEXISTFCY
Gosub _AINIT_LIST_FCY
Local Integer I
[L]ARET_VALUE =  [V]CST_ANOTDEFINED
For I=1 To maxtab(this.LIST_FCY)
 If this.LIST_FCY(I) = [L]CODEFCY
  [L]ARET_VALUE = I
  Break
 Endif
Next
Return

$_AGETNBFCY
Gosub _AINIT_LIST_FCY
[L]ARET_VALUE =maxtab(this.LIST_FCY)
Return

$_AEXISTLEG
Gosub _AINIT_LIST_LEG
Local Integer I
[L]ARET_VALUE =  [V]CST_ANOTDEFINED
For I=1 To maxtab(this.LIST_LEG)
 If this.LIST_LEG(I) = [L]CODELEG
  [L]ARET_VALUE = I
  Break
 Endif
Next
Return

$_AGETNBLEG
Gosub _AINIT_LIST_LEG
[L]ARET_VALUE =maxtab(this.LIST_LEG)
Return

$_AEXISTCPY
Gosub _AINIT_LIST_CPY
Local Integer I
[L]ARET_VALUE =  [V]CST_ANOTDEFINED
For I=1 To maxtab(this.LIST_CPY)
 If this.LIST_CPY(I) = [L]CODECPY
  [L]ARET_VALUE = I
  Break
 Endif
Next
Return

$_AGETNBCPY
Gosub _AINIT_LIST_CPY
[L]ARET_VALUE =maxtab(this.LIST_CPY)
Return

##########################################################################################

$_AINIT_LIST_LEG
If fmet this.AGETATTRIBUTE("LIST_LEG","STA")<>"1"

 Local Integer J,RES,T_NBLEG,SAV_ISREADONLY
 Local Char T_FOLDLEG(10)(1..40)
 [L]SAV_ISREADONLY = this.isReadonly
 this.isReadonly=0
 Raz this.LIST_LEG
 Call SETLEG(this.APARENT.AFOLDER ,T_FOLDLEG,T_NBLEG) From DOSCONT
 For J = 1 To T_NBLEG
  this.LIST_LEG(J) = T_FOLDLEG(J)
 Next
 RES = fmet this.ASETATTRIBUTE("LIST_LEG","STA","1")
 this.isReadonly = [L]SAV_ISREADONLY
Endif
Return

$_AINIT_LIST_CPY
If fmet this.AGETATTRIBUTE("LIST_CPY","STA")<>"1"
 Local Integer J, RES,SAV_ISREADONLY
 [L]SAV_ISREADONLY = this.isReadonly
 this.isReadonly=0
 Local File =this.APARENT.AFOLDER +".COMPANY" [CPY]
 Raz this.LIST_CPY
 For [CPY]
  J += 1
  this.LIST_CPY(J) = [CPY]CPY
 Next
 RES = fmet this.ASETATTRIBUTE("LIST_CPY","STA","1")
 Close Local File [CPY]
 this.isReadonly = [L]SAV_ISREADONLY
Endif
Return

$_AINIT_LIST_FCY
If maxtab(this.LIST_FCY) = 0
 Local Integer J, RES,SAV_ISREADONLY
 [L]SAV_ISREADONLY = this.isReadonly
 this.isReadonly=0
 Local File =this.APARENT.AFOLDER +".FACILITY" [FCY]
 Raz this.LIST_FCY
 For [FCY]
  J += 1
  this.LIST_FCY(J) = [FCY]FCY
 Next
 #RES = fmet this.ASETATTRIBUTE("LIST_FCY","STA","1")
 Close Local File [FCY]
 this.isReadonly = [L]SAV_ISREADONLY
Endif
Return

############################
##X3-69874
##########################################################################################
$AGETVALCHAR
  Local Char RESULT(250), PARAM_KEY(100)
  Local Integer I, ISOK, LENGTH_RESULT

  If [L]PARAM = ""
   [L]ASTATUS = fmet this.ASETERROR("PARAM", "Code parameter cannot be empty", [V]CST_AERROR)
  Elsif [L]LEVCOD = 0
   [L]ASTATUS = fmet this.ASETERROR("LEVCOD", "Level cannot be empty", [V]CST_AERROR)
  Else
    #Search parameter value in cache
    [L]PARAM_KEY = num$([L]LEVCOD)+"~"+[L]CODE+"~"+[L]PARAM
    I = find([L]PARAM_KEY,this.TAB_CHA1_IND)
    If I>0
      [L]ARET_VALUE = this.TAB_CHA1_VAL(I)
    Else
      I = find([L]PARAM_KEY,this.TAB_CHA2_IND)
      If I>0
        [L]ARET_VALUE = this.TAB_CHA2_VAL(I)
      Else
        I = find([L]PARAM_KEY,this.TAB_CHA3_IND)
        If I>0
          [L]ARET_VALUE = this.TAB_CHA3_VAL(I)
        Else
          #Value not find in cache tables
          #Get the value from disk and add it in cache
          Call _GET_PARAM_SUB(this.APARENT.AFOLDER , [L]LEVCOD, [L]CODE, [L]PARAM, [L]ISOK, [L]RESULT) From ADP_TOOL
          If [L]ISOK=[V]CST_ATRUE
            [L]LENGTH_RESULT=len([L]RESULT)
            [L]ARET_VALUE = [L]RESULT
            this.isReadonly = [V]CST_AFALSE
            If [L]LENGTH_RESULT<=32
              this.TAB_CHA1_IND(maxtab(this.TAB_CHA1_IND)+1) = [L]PARAM_KEY
              this.TAB_CHA1_VAL(maxtab(this.TAB_CHA1_VAL)+1) = [L]ARET_VALUE
            Elsif [L]LENGTH_RESULT<=128
              this.TAB_CHA2_IND(maxtab(this.TAB_CHA2_IND)+1) = [L]PARAM_KEY
              this.TAB_CHA2_VAL(maxtab(this.TAB_CHA2_VAL)+1) = [L]ARET_VALUE
            Else
              this.TAB_CHA3_IND(maxtab(this.TAB_CHA3_IND)+1) = [L]PARAM_KEY
              this.TAB_CHA3_VAL(maxtab(this.TAB_CHA3_VAL)+1) = [L]ARET_VALUE
            Endif
            this.isReadonly = [V]CST_ATRUE
          Else
            Raz [L]ARET_VALUE
            [L]ASTATUS = fmet this.ASETERROR("PARAM", "Code"-[L]PARAM-"does not exist", [V]CST_AERROR)
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################
$AGETVALNUM
  Local Char RESULT(250), PARAM_KEY(100)
  Local Integer I, ISOK

  If [L]PARAM = ""
   [L]ASTATUS = fmet this.ASETERROR("PARAM", "Code parameter cannot be empty", [V]CST_AERROR)
  Elsif [L]LEVCOD = 0
   [L]ASTATUS = fmet this.ASETERROR("LEVCOD", "Level cannot be empty", [V]CST_AERROR)
  Else
    #Search parameter value in cache
    [L]PARAM_KEY = num$([L]LEVCOD)+"~"+[L]CODE+"~"+[L]PARAM
    I = find(PARAM_KEY,this.TAB_NUM_IND)
    If I>0
      [L]ARET_VALUE = this.TAB_NUM_VAL(I)
    Else
      #Value not find in cache tables
      #Get the value from disk and add it in cache
      Call _GET_PARAM_SUB(this.APARENT.AFOLDER , [L]LEVCOD, [L]CODE, [L]PARAM, [L]ISOK, [L]RESULT) From ADP_TOOL
      If [L]ISOK=[V]CST_ATRUE
        [L]ARET_VALUE = val([L]RESULT)
        this.isReadonly = [V]CST_AFALSE
        this.TAB_NUM_IND(maxtab(this.TAB_NUM_IND)+1) = [L]PARAM_KEY
        this.TAB_NUM_VAL(maxtab(this.TAB_NUM_VAL)+1) = [L]ARET_VALUE
        this.isReadonly = [V]CST_ATRUE
      Else
        [L]ASTATUS = fmet this.ASETERROR("PARAM", "Code"-[L]PARAM-"does not exist", [V]CST_AERROR)
      Endif
    Endif
  Endif
Return

##########################################################################################
$AGETVALDATE
  Local Char RESULT(250), PARAM_KEY(100)
  Local Integer I, ISOK, LENGTH_RESULT

  If [L]PARAM = ""
   [L]ASTATUS = fmet this.ASETERROR("PARAM", "Code parameter cannot be empty", [V]CST_AERROR)
  Elsif [L]LEVCOD = 0
   [L]ASTATUS = fmet this.ASETERROR("LEVCOD", "Level cannot be empty", [V]CST_AERROR)
  Else
    #Search parameter value in cache
    [L]PARAM_KEY = num$([L]LEVCOD)+"~"+[L]CODE+"~"+[L]PARAM
    I = find(PARAM_KEY,this.TAB_DAT_IND)
    If I>0
      [L]ARET_VALUE = this.TAB_DAT_VAL(I)
    Else
      #Value not find in cache tables
      #Get the value from disk and add it in cache
      Call _GET_PARAM_SUB(this.APARENT.AFOLDER , [L]LEVCOD, [L]CODE, [L]PARAM, [L]ISOK, [L]RESULT) From ADP_TOOL
      If [L]ISOK=[V]CST_ATRUE
        [L]LENGTH_RESULT=len([L]RESULT)
        If [L]LENGTH_RESULT=6 or [L]LENGTH_RESULT=8
          [L]ARET_VALUE = [L]RESULT
          this.isReadonly = [V]CST_AFALSE
          this.TAB_DAT_IND(maxtab(this.TAB_DAT_IND)+1) = PARAM_KEY
          this.TAB_DAT_VAL(maxtab(this.TAB_DAT_VAL)+1) = [L]ARET_VALUE
          this.isReadonly = [V]CST_ATRUE
        Else
          [L]ASTATUS = fmet this.ASETERROR("PARAM", "Code"-[L]PARAM-"incorrect date format", [V]CST_AERROR)
        Endif
      Else
        [L]ASTATUS = fmet this.ASETERROR("PARAM", "Code"-[L]PARAM-"does not exist", [V]CST_AERROR)
      Endif
    Endif
  Endif
Return

##########################################################################################
$_AGETADPTYP
  Local Integer I

  If [L]PARAM = ""
   [L]ASTATUS = fmet this.ASETERROR("PARAM", "Code parameter cannot be empty", [V]CST_AERROR)
  Else
    #Search parameter type in cache
    I = find([L]PARAM,this.TAB_ADP_IND)
    If I>0
      [L]ARET_VALUE = this.TAB_ADP_TYP(I)
    Else
      Local File =this.APARENT.AFOLDER +".ADOPAR" [ADP]
      Read [ADP]ADP1=[L]PARAM
      If !fstat
        [L]ARET_VALUE = [F:ADP]TYPVAL
        this.isReadonly = [V]CST_AFALSE
        this.TAB_ADP_IND(maxtab(this.TAB_ADP_IND)+1) = [L]PARAM
        this.TAB_ADP_TYP(maxtab(this.TAB_ADP_TYP)+1) = [F:ADP]TYPVAL
        this.TAB_ADP_LEV(maxtab(this.TAB_ADP_LEV)+1) = [F:ADP]NIVDEF
        this.isReadonly = [V]CST_ATRUE
      Else
        [L]ASTATUS = fmet this.ASETERROR("PARAM", "Code"-[L]PARAM-"does not exist", [V]CST_AERROR)
      Endif
      LogicClose File [ADP]
    Endif
  Endif
Return

