Return

##########################################################################################
$AGETUSERVALCHAR
  Local Char RESULT(250)
  Local Integer I, ISOK, LENGTH_RESULT
  Local Char SITE
  SITE = ""

  If [L]PARAM = ""
   [L]ASTATUS = fmet this.ASETERROR("PARAM", "Code parameter cannot be empty", [V]CST_AERROR)
  Else
    #Search parameter value in cache
    I = find([L]PARAM,this.TAB_CH1U_IND)
    If I>0
      [L]ARET_VALUE = this.TAB_CH1U_VAL(I)
    Else
      I = find([L]PARAM,this.TAB_CH2U_IND)
      If I>0
        [L]ARET_VALUE = this.TAB_CH2U_VAL(I)
      Else
        I = find([L]PARAM,this.TAB_CH3U_IND)
        If I>0
          [L]ARET_VALUE = this.TAB_CH3U_VAL(I)
        Else
          #Value not find in cache tables
          #Get the value from disk and add it in cache
          Call _GET_PARAM_USER_SUB(this.APARENT.AFOLDER , this.APARENT.USER,[L]SITE, [L]PARAM, [L]ISOK, [L]RESULT) From ADP_TOOL
          If [L]ISOK=[V]CST_ATRUE
            [L]LENGTH_RESULT=len([L]RESULT)
            [L]ARET_VALUE = [L]RESULT
            this.isReadonly = [V]CST_AFALSE
            If [L]LENGTH_RESULT<=32
              this.TAB_CH1U_IND(maxtab(this.TAB_CH1U_IND)+1) = [L]PARAM
              this.TAB_CH1U_VAL(maxtab(this.TAB_CH1U_VAL)+1) = [L]ARET_VALUE
            Elsif [L]LENGTH_RESULT<=128
              this.TAB_CH2U_IND(maxtab(this.TAB_CH2U_IND)+1) = [L]PARAM
              this.TAB_CH2U_VAL(maxtab(this.TAB_CH2U_VAL)+1) = [L]ARET_VALUE
            Else
              this.TAB_CH3U_IND(maxtab(this.TAB_CH3U_IND)+1) = [L]PARAM
              this.TAB_CH3U_VAL(maxtab(this.TAB_CH3U_VAL)+1) = [L]ARET_VALUE
            Endif
            this.isReadonly = [V]CST_ATRUE
          Else
            [L]ASTATUS = fmet this.ASETERROR("PARAM", "Code"-[L]PARAM-"does not exist", [V]CST_AERROR)
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################
