##########################################################################################
# restore the cache tables
$_ACLEAN
 this.isReadonly = 0
 Local Integer RES

 Raz this.TAB_NUM_IND
 Raz this.TAB_NUM_VAL
 Raz this.TAB_CHA1_IND
 Raz this.TAB_CHA1_VAL
 Raz this.TAB_CHA2_IND
 Raz this.TAB_CHA2_VAL
 Raz this.TAB_CHA3_IND
 Raz this.TAB_CHA3_VAL
 Raz this.TAB_DAT_IND
 Raz this.TAB_DAT_VAL

 Raz this.TAB_NUMU_IND
 Raz this.TAB_NUMU_VAL
 Raz this.TAB_CH1U_IND
 Raz this.TAB_CH1U_VAL
 Raz this.TAB_CH2U_IND
 Raz this.TAB_CH2U_VAL
 Raz this.TAB_CH3U_IND
 Raz this.TAB_CH3U_VAL
 Raz this.TAB_DATU_IND
 Raz this.TAB_DATU_VAL

 Raz this.TAB_ADP_IND
 Raz this.TAB_ADP_LEV
 Raz this.TAB_ADP_TYP

 Raz this.LIST_LEG
 Raz this.LIST_CPY
 Raz this.LIST_FCY

 #Raz this.ERRCOD

 RES = fmet this.ASETATTRIBUTE("LIST_LEG","STA","0")
 RES = fmet this.ASETATTRIBUTE("LIST_CPY","STA","0")
 RES = fmet this.ASETATTRIBUTE("LIST_FCY","STA","0")

 Kill RES
 this.isReadonly = 1
Return

