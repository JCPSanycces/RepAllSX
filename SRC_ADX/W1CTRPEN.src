#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTRPEN 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:49"
A_USER  = "DOC"
A_STAMP = "20181109230349"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRPEN"
  If [M]NBRPEN=0
  Endif
 When "NBRSTA"
  If [M]NBRSTA=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTRPEN [CTRPEN]
Gosub HORODAT
Local Inpbox "CTRPEN" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTRPEN] As [SIM_]
Grizo [CTRPEN]5
Grizo [CTRPEN]10
Grizo [CTRPEN]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTRPEN]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=74 : Y1(1)=3 : Y2(1)=14
X1(2)=1 : X2(2)=74 : Y1(2)=15 : Y2(2)=25
Return

$ON_EXCFRMAUTENR
Onevent INIT_AREA Call D_EXCFRMAUTENR(zc) From W1CTRPEN
Onevent BEFORE_INPUT Call AS_EXCFRMAUTENR(zc) From W1CTRPEN
Return

Subprog D_EXCFRMAUTENR(VALEUR)
Variable Integer VALEUR
If varinit([M]EXCFRMAUTENR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_EXCFRMAUTENR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_ORG
Onevent CONTROL Call C_ORG(zc) From W1CTRPEN
Onevent BEFORE_INPUT Call AS_ORG(zc) From W1CTRPEN
Return

Subprog AS_ORG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(46228,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_ORG(zc) From W1CTRPEN
Onkey   2 Titled GBOUTS Call S_ORG(zc) From W1CTRPEN
Onkey 144 Titled GBOUTP Call P_ORG(zc) From W1CTRPEN
Onkey 146 Titled GBOUTA Call SA_ORG(zc) From W1CTRPEN
Gosub _AFF
End

Subprog C_ORG(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ORG" : GZNUM = 1003169 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ORG" : GZNUM = 1003169 : Endif
 If !mkstat
  ## Action CONTORG
  Call CONTORG(VALEUR) From SUBORG
  If mkstat : GERR = 1 : GZONE = "ORG" : GZNUM = 1003169 : Endif
  If !mkstat
   ## Action STD
   Call C_ORG(VALEUR) From SUBCTR2
   If mkstat : GERR = 1 : GZONE = "ORG" : GZNUM = 1003169 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_ORG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELORGLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELORGLEG"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELORGLEG","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_ORG(VALEUR)
Variable Char    VALEUR()
Call OBJET("ORG",VALEUR,num$(GCURLEG)) From GOBJET
Gosub _AFF
End

Subprog SA_ORG(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ORG"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ORG(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("ORG",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_PENJONDAT
Onevent CONTROL Call C_PENJONDAT(zc) From W1CTRPEN
Onevent BEFORE_AREA Gosub AV_PENJONDAT From W1CTRPEN
Return

$AV_PENJONDAT
Chgfmt [M]PENJONDAT(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog C_PENJONDAT(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PENJONDAT" : GZNUM = 1003170 : Endif
If !mkstat
 ## Action STD
 Call C_PENJONDAT(VALEUR) From SUBCTR2
 If mkstat : GERR = 1 : GZONE = "PENJONDAT" : GZNUM = 1003170 : Endif
Endif
Gosub _AFF
End

