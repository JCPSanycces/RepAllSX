#[M:SHIP1]DISCRGAMT3(NOL) = WSHIPMENT.SHD(WPOS).DISCRGAMT3
#[M:SHIP1]DISCRGAMT4(NOL) = WSHIPMENT.SHD(WPOS).DISCRGAMT4
#[M:SHIP1]DISCRGAMT5(NOL) = WSHIPMENT.SHD(WPOS).DISCRGAMT5
#[M:SHIP1]DISCRGAMT6(NOL) = WSHIPMENT.SHD(WPOS).DISCRGAMT6
#[M:SHIP1]DISCRGAMT7(NOL) = WSHIPMENT.SHD(WPOS).DISCRGAMT7
#[M:SHIP1]DISCRGAMT8(NOL) = WSHIPMENT.SHD(WPOS).DISCRGAMT8
#[M:SHIP1]DISCRGAMT9(NOL) = WSHIPMENT.SHD(WPOS).DISCRGAMT9
#[M:SHIP1]TAXRCP(NOL)   = WSHIPMENT.SHD(WPOS).TAXRCP
#[M:SHIP1]AMTTAXLIN1(NOL) = WSHIPMENT.SHD(WPOS).AMTTAXLIN1
#[M:SHIP1]AMTTAXLIN2(NOL) = WSHIPMENT.SHD(WPOS).AMTTAXLIN2
#[M:SHIP1]AMTTAXLIN3(NOL) = WSHIPMENT.SHD(WPOS).AMTTAXLIN3
#[M:SHIP1]AMTTAXISS(NOL)  = WSHIPMENT.SHD(WPOS).AMTTAXISS
#[M:SHIP1]AMTTAXOTH1(NOL) = WSHIPMENT.SHD(WPOS).AMTTAXOTH1
#[M:SHIP1]AMTTAXOTH2(NOL) = WSHIPMENT.SHD(WPOS).AMTTAXOTH2
#[M:SHIP1]DEDTAXLIN1(NOL) = WSHIPMENT.SHD(WPOS).DEDTAXLIN1
#[M:SHIP1]DEDTAXLIN2(NOL) = WSHIPMENT.SHD(WPOS).DEDTAXLIN2
#[M:SHIP1]DEDTAXLIN3(NOL) = WSHIPMENT.SHD(WPOS).DEDTAXLIN3
#[M:SHIP1]DEDTAXRCP(NOL)  = WSHIPMENT.SHD(WPOS).DEDTAXRCP
#[M:SHIP1]DEDTAXISS(NOL)  = WSHIPMENT.SHD(WPOS).DEDTAXISS
#[M:SHIP1]DEDTAXOTH1(NOL) = WSHIPMENT.SHD(WPOS).DEDTAXOTH1
#[M:SHIP1]DEDTAXOTH2(NOL) = WSHIPMENT.SHD(WPOS).DEDTAXOTH2
#[M:SHIP1]POHFCY(NOL) = WSHIPMENT.SHD(WPOS).POHFCY
## Issue 119360 - 2016-11-02 by MAE : Ajout du site de réception
#[M:SHIP1]PRHFCY(NOL) = WSHIPMENT.SHD(WPOS).PRHFCY
## Issue 111257 US70
#[M:SHIP1]QTYEXPFLG(NOL) = WSHIPMENT.SHD(WPOS).QTYEXPFLG
#[M:SHIP1]PRCPREN(NOL) = WSHIPMENT.SHD(WPOS).PRCPREN
# End issue 49737

End
#-------------------------------------------------------------#
# Chargement dans l'écran des conteneurs                      #
#-------------------------------------------------------------#
$CHARG_CTRH
Local Integer SAVNOLIGN
# Issue 111256 US3
#read TABCONTAINER class
Local Instance WTABCONTAINER Using C_TABCONTAINER
WTABCONTAINER = NewInstance C_TABCONTAINER AllocGroup null
# End issue 111256 US3
#----
# Ouverture de la ligne
SAVNOLIGN = nolign
nolign = [M:SHIP3]NBCONT
Insa nolign,1,[M:SHIP3]NBCONT [M:SHIP3]NBCONT
[M:SHIP3]NBCONT += 1
nolign = [M:SHIP3]NBCONT
status = 0
# Issue 111256 US3
If fmet WTABCONTAINER.AREAD([F:CTRH]TCTRNUM) = [V]CST_AOK
  [M:SHIP3]TCTRVOL(nolign-1) = WTABCONTAINER.TCTRVOL
  # Issue 111256 US3
  If [M:SHIP2]TCTRNUM <> AVOID.ACHAR
    WSHIPMENT.CTRMAXWEI = WTABCONTAINER.MAXWEI
    WSHIPMENT.CTRMAXVOL = WTABCONTAINER.TCTRVOL
    WSHIPMENT.TARWEI = WTABCONTAINER.TARWEI
  Endif
Endif
# End issue 111256 US3
# Issue 111257 US 70
#Par défaut le conteneur est soldé
# Issue 44464 - 2017-06-21 by MAE : Par defaut le conteneur est pré réceptionné
[M:SHIP3]PRCPFLG(nolign-1) = 1
[M:SHIP3]CTRCLEFLG(nolign-1) = 2
Filter [SHD] Where CTRNUM = [F:CTRH]CTRNUM
For [SHD]
  If [F:SHD]CLEFLG <> 2 : [M:SHIP3]CTRCLEFLG(nolign-1) = 1 : Endif
  # Issue 44464
  If [F:SHD]PRCPFLG = 2 :  [M:SHIP3]PRCPFLG(nolign-1) = 2  : Endif
Next
Filter [SHD]
# end Issue 111257 US 70

[M:SHIP3]=[F:CTRH]
nolign = SAVNOLIGN
FreeGroup WTABCONTAINER
Return

# Issue 111257 US 20
#**
#* Gére la création des lignes de l'onglet "Documents"
#*!
$CREATE_DOCUMENTS
#clean the collection
Local Integer I, INDEX
For I=1 To maxtab(WSHIPMENT.SHIPD)
  If (fmet WSHIPMENT.ADELLINE("SHIPD", WSHIPMENT.SHIPD(I).AORDER) <> [V]CST_AOK)
    GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'SHIPD','SHIPMENT')
    GOK = 0 : GERR = 1
    Return
  Endif
Next

#fill the collection with the screen
For I = 0 To [M:SHIPD]NBLIG - 1
  INDEX = fmet WSHIPMENT.ADDLINE("SHIPD", [V]CST_ALASTPOS)
  If (INDEX = [V]CST_ANOTDEFINED)
    #--The insertion was not possible
    GMESSAGE = func ASYRFNC.MES2(mess(266,133,1),'SHIPD','SHIPMENT')
    GOK = 0 : GERR = 1
    Break
  Endif

  nolign = I + 1
  NOL = nolign-1
  # Issue 55127 - 2017-09-07 by MAE
  #mise à jour du numéro de ligne
  Call LINNUM("SDLIN") From TABLEAUX
  # End issue 55127
  Call FILL_CLASS_DOC(WSHIPMENT,INDEX,NOL)

Next
If (GERR = 1) : Return : Endif
Return

#**
#* gere la modification des lignes de l'onglet "documents"
#*!
$MODIF_DOCUMENTS
Local Integer I, INDEX
Local Shortint NOL,WENDL, WBEGL
For I = 0 To [M:SHIPD]NBLIG - 1
  nolign = I + 1
  NOL = nolign-1
  # Retrieve the element using the screen's AUUID
  If [M:SHIPD]AUUID(I)<>""
    INDEX = find(toUuid([M:SHIPD]AUUID(I)), WSHIPMENT.SHIPD(1..maxtab(WSHIPMENT.SHIPD)).AUUID)
  Else
    INDEX=0
  Endif
  If (INDEX = 0)
    # We did not find the element matching with the array line.
    # We add a line.
    INDEX = fmet WSHIPMENT.ADDLINE("SHIPD", [V]CST_ALASTPOS)
    If (INDEX = [V]CST_ANOTDEFINED)
        #--The insertion was not possible
        GMESSAGE = func ASYRFNC.MES2(mess(266,133,1),'SHIPD','SHIPMENT')
        GOK = 0 : GERR = 1
        Break
    Endif
    #GESTION DU NUMÉRO DE LIGNE
    #on ne peut pas utiliser LINNUM de Tableaux, car il modifie tous les nums de ligne
    #insertion en première ligne, debut = 0
    If NOL-1<=0
      WBEGL = 0
    Else
      WBEGL = NOL-1
    Endif
    #insertion en derniére ligne
    If [M:SHIPD]SDLIN(NOL+1) = 0
      [M:SHIPD]SDLIN(NOL) = [M:SHIPD]SDLIN(WBEGL) + 1000
      Goto NEXTL
    Else
      WENDL = NOL+1
    Endif
    [M:SHIPD]SDLIN(NOL) = [M:SHIPD]SDLIN(WBEGL) + int(([M:SHIPD]SDLIN(WENDL) - [M:SHIPD]SDLIN(WBEGL))/2)
  Endif
$NEXTL
  Call FILL_CLASS_DOC(WSHIPMENT,INDEX,NOL)
Next

If (GERR = 1) : Return : Endif

# NOW, ALL ELEMENTS THAT DON't have the status Updated or Created must be deleted, because it means they don'T MATCH With LINES IN THE ARRAY
For I=1 To maxtab(WSHIPMENT.SHIPD)
  If !(find(WSHIPMENT.SHIPD(I).ASTALIN, [V]CST_ANEW, [V]CST_AUPD))
&   and      num$(WSHIPMENT.SHIPD(I).AUUID)<>""
&   and find(num$(WSHIPMENT.SHIPD(I).AUUID),[M:SHIPD]AUUID(0..[M:SHIPD]NBLIG-1))=0
    If (fmet WSHIPMENT.ADELLINE("SHIPD", WSHIPMENT.SHIPD(I).AORDER) <> [V]CST_AOK)
      #--The insertion was not possible
      GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'SHIPD','SHIPMENT')
      GOK = 0 : GERR = 1
      Break
    Endif
  Endif
Next
If (GERR = 1) : Return : Endif
Return

#**
#* Remplit une ligne de la collection SHD par une ligne du tableau écran
#* @param WSHIPMENT : classe des expéditions
#* @param WPOS : Position dans la collection
#* @param NOL : numéro de ligne du tableau
#*!
Subprog FILL_CLASS_DOC(WSHIPMENT, WPOS, NOL)
Variable Instance WSHIPMENT Using C_SHIPMENT
Variable Integer WPOS
Variable Shortint NOL
If WPOS = 0 : End : Endif
# Issue 49737 - 2017-09-04 by MAE : setinstance instead of filling fiel by field
SetInstanceNoSys WSHIPMENT.SHIPD(WPOS) With [M:SHIPD] 5
WSHIPMENT.SHIPD(WPOS).VCRNUM = [M:SHIP0]SHIPNUM
WSHIPMENT.SHIPD(WPOS).VCRTYP = 38
#WSHIPMENT.SHIPD(WPOS).SDTYPE = [M:SHIPD]SDTYPE(NOL)
#WSHIPMENT.SHIPD(WPOS).SDORI = [M:SHIPD]SDORI(NOL)
#WSHIPMENT.SHIPD(WPOS).SDDATE = [M:SHIPD]SDDATE(NOL)
#WSHIPMENT.SHIPD(WPOS).SDREF1 = [M:SHIPD]SDREF1(NOL)
#WSHIPMENT.SHIPD(WPOS).SDREF2 = [M:SHIPD]SDREF2(NOL)
#WSHIPMENT.SHIPD(WPOS).SDBP = [M:SHIPD]SDBP(NOL)
#WSHIPMENT.SHIPD(WPOS).SDNTYP = [M:SHIPD]SDNTYP(NOL)
#WSHIPMENT.SHIPD(WPOS).SDFILNAM = [M:SHIPD]SDFILNAM(NOL)
#WSHIPMENT.SHIPD(WPOS).SDCMT = [M:SHIPD]SDCMT(NOL)
# End issue 49737

End

#**
#* Remplit une ligne du tableau de l'écran SHIPD avec une ligne de la collection SHIPD
#* @param WSHIPMENT : classe des expéditions
#* @param NOL : numéro de ligne du tableau
#* @param WPOS : Position dans la collection
#*!
Subprog FILL_SCREEN_DOC(WSHIPMENT, NOL, WPOS)
Variable Instance WSHIPMENT Using C_SHIPMENT
Variable Shortint NOL
Variable Integer WPOS
If WPOS = 0 : End : Endif
# Issue 49737 - 2017-09-04 by MAE : setinstance instead of filling field by field
SetInstanceNoSys [M:SHIPD] 5 With WSHIPMENT.SHIPD(WPOS)
#[M:SHIPD]SDLIN(NOL) = WSHIPMENT.SHIPD(WPOS).SDLIN
#[M:SHIPD]SDTYPE(NOL) = WSHIPMENT.SHIPD(WPOS).SDTYPE
#[M:SHIPD]SDORI(NOL) = WSHIPMENT.SHIPD(WPOS).SDORI
#[M:SHIPD]SDDATE(NOL) = WSHIPMENT.SHIPD(WPOS).SDDATE
#[M:SHIPD]SDREF1(NOL) =WSHIPMENT.SHIPD(WPOS).SDREF1
#[M:SHIPD]SDREF2(NOL) =WSHIPMENT.SHIPD(WPOS).SDREF2
#[M:SHIPD]SDBP(NOL) = WSHIPMENT.SHIPD(WPOS).SDBP
#[M:SHIPD]SDNTYP(NOL) = WSHIPMENT.SHIPD(WPOS).SDNTYP
#[M:SHIPD]SDFILNAM(NOL) = WSHIPMENT.SHIPD(WPOS).SDFILNAM
#[M:SHIPD]SDCMT(NOL) = WSHIPMENT.SHIPD(WPOS).SDCMT
#[M:SHIPD]AUUID(NOL) = num$(WSHIPMENT.SHIPD(WPOS).AUUID)
# End issue 49737
End

#**
#* Remplit l'onglet "Documents" à partir de la classe avec les documents du transport ou de l'expédition
#* Attention, il faut faire l'affzo de l'écran aprés l'appel
#*!
Subprog LEC_DOC()
Local Integer I
Local Shortint NOL
If [M:SHIP2]TRNNUM <> AVOID.ACHAR
#si transport : l'écran est rempli a partir de la classe F pour ne pas enregistrer
 Filter [SHIPD] Where VCRNUM = [M:SHIP2]TRNNUM and VCRTYP = 39
  For [SHIPD]
    # Ouverture de la ligne
    nolign = [M:SHIPD]NBLIG
    Insa nolign,1,[M:SHIPD]NBLIG [M:SHIPD]NBLIG
    [M:SHIPD]NBLIG += 1
    nolign = [M:SHIPD]NBLIG
    NOL = nolign-1
    status = 0
    [M:SHIPD]=[F:SHIPD]
  Next
 Filter [SHIPD]
 Raz WSHIPMENT.SHIPD
Else
  #sinon, l'écran est rempli de la collection SHIPD pour pouvoir enregistrer les modifs
  For I=1 To maxtab(WSHIPMENT.SHIPD)
    If (WSHIPMENT.SHIPD(I) <> null and find(WSHIPMENT.SHIPD(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0)
       # Ouverture de la ligne
      nolign = [M:SHIPD]NBLIG
      Insa nolign,1,[M:SHIPD]NBLIG [M:SHIPD]NBLIG
      [M:SHIPD]NBLIG += 1
      nolign = [M:SHIPD]NBLIG
      NOL = nolign-1
      status = 0
      Call FILL_SCREEN_DOC(WSHIPMENT,NOL,I)
  Endif
Next
Endif
End
# End issue 111257 US 20
# Issue 111256 US3- 2016-03-30 by MAE : comment
#------------------------------------#
#--- Calcul the header totals        #
#------------------------------------#
$CALCUL_TOTAUX
#------------------------------------#
#--- Using another instance for not modify the principal
Local Instance WSHIPMENT2 Using C_SHIPMENT
Local Integer WPOS, WRET
Local Decimal WLINAMT,WDECIMAL
Local Char SAVCTRNUM (GLONTCTR)
Local Shortint NOL

WSHIPMENT2 = NewInstance C_SHIPMENT AllocGroup null
SetInstance WSHIPMENT2 With [M:SHIP0]
SetInstance WSHIPMENT2 With [M:SHIP2]
WSHIPMENT2.MAXWEI = [M:SHIP2]MAXWEI
WSHIPMENT2.MAXVOL = [M:SHIP2]MAXVOL
WSHIPMENT2.CRRWEI = AVOID.ADEC
WSHIPMENT2.CRRVOL = AVOID.ADEC
WSHIPMENT2.AVAWEI = AVOID.ADEC
WSHIPMENT2.AVAVOL = AVOID.ADEC

For I=0 To [M:SHIP1]NBLIG-1
  NOL = I
  # Issue X3-57542 - 2017-09-27 by MAE : affectation du nolign
  nolign = NOL +1
  WPOS = fmet WSHIPMENT2.ADDLINE("SHD",[V]CST_ALASTPOS)
  If WPOS = [V]CST_ANOTDEFINED
    #--The insertion was not possible
    GMESSAGE = func ASYRFNC.MES2(mess(266,133,1),'SHD','SHIPMENT')
    GOK=0 : GERR=1
    Break
  Endif
  Call FILL_CLASS(WSHIPMENT2,WPOS,NOL)
  If WSHIPMENT2.SHD(WPOS).CTRNUM <> SAVCTRNUM & WSHIPMENT2.SHD(WPOS).CTRNUM<> AVOID.ACHAR
    WRET = fmet WSHIPMENT2.SHD(WPOS)._CALC_TOTAUX(1)
    SAVCTRNUM = WSHIPMENT2.SHD(WPOS).CTRNUM
  Elsif WSHIPMENT2.SHD(WPOS).CTRNUM  = AVOID.ACHAR     #calcul des totaux pour les commandes
    WRET = fmet WSHIPMENT2.SHD(WPOS)._CALC_TOTAUX(2)
  Endif
Next I

#calcul du poids disponible : poids max - poids total des lignes
WSHIPMENT2.AVAWEI = WSHIPMENT2.MAXWEI - WSHIPMENT2.CRRWEI
If WSHIPMENT2.AVAWEI <0 WSHIPMENT2.AVAWEI = 0 Endif
#calcul du volume disponible
WSHIPMENT2.AVAVOL = WSHIPMENT2.MAXVOL - WSHIPMENT2.CRRVOL
If WSHIPMENT2.AVAVOL <0 WSHIPMENT2.AVAVOL = 0 Endif
[M:SHIP2]AVAVOL = WSHIPMENT2.AVAVOL
[M:SHIP2]CRRWEI = WSHIPMENT2.CRRWEI
[M:SHIP2]CRRVOL = WSHIPMENT2.CRRVOL
[M:SHIP2]AVAWEI = WSHIPMENT2.AVAWEI

Affzo [M:SHIP2]AVAVOL,CRRWEI,CRRVOL,AVAWEI
FreeGroup WSHIPMENT2
Return
# End issue 111256 US3

$STATUT
If (BOUT="3" | BOUT="4" | BOUT="5") & mkstat=4 & REP=""
  REP = "M"
Endif
Return
#------------------------------------------------------------------------#
#--- Step tracking screen SHIPT                                          #
#------------------------------------------------------------------------#
# Issue 111257 US 42
#**
#* gere la modification des lignes de l'onglet "Suivi"
#*!
$MODIF_TRACKING
Local Integer I, INDEX
Local Shortint NOL, WENDL, WBEGL

For I = 0 To [M:SHIPT]NBLIGNE - 1
  nolign = I + 1
  NOL = nolign-1
  # Retrieve the element using the screen's AUUID
  If [M:SHIPT]AUUID(I)<>""
    INDEX = find(toUuid([M:SHIPT]AUUID(I)), WSHIPMENT.SHIPT(1..maxtab(WSHIPMENT.SHIPT)).AUUID)
  Else
    INDEX=0
  Endif
  Call FILL_CLASS_TRACK(WSHIPMENT,INDEX,NOL)
Next
# Now, all elements that don't have the status Updated or Created must be deleted, because it means they don't match with lines in the array
For I=1 To maxtab(WSHIPMENT.SHIPT)
  # Issue 53822 - 2017-10-06 by MAE : Suppression du CST_ANEW
  #If WSHIPMENT.SHIPT(I)<>null & !(find(WSHIPMENT.SHIPT(I).ASTALIN, [V]CST_ANEW,[V]CST_ADEL, [V]CST_ANEWDEL ))
  If WSHIPMENT.SHIPT(I)<>null & !(find(WSHIPMENT.SHIPT(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL ))
&   and      num$(WSHIPMENT.SHIPT(I).AUUID)<>""
&   and find(num$(WSHIPMENT.SHIPT(I).AUUID),[M:SHIPT]AUUID(0..[M:SHIPT]NBLIGNE-1))=0
    If (fmet WSHIPMENT.ADELLINE("SHIPT", WSHIPMENT.SHIPT(I).AORDER) <> [V]CST_AOK)
      #--The insertion was not possible
      GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'SHIPT','SHIPMENT')
      GOK = 0 : GERR = 1
      Break
    Endif
  Endif
Next
Return
#-------------------------------------------------------------#
#**
#* Remplit une ligne de la collection SHIPT par une ligne du tableau écran
#* @param WSHIPMENT : classe des transports
#* @param WPOS : Position dans la collection
#* @param NOL : numéro de ligne du tableau
#*!
Subprog FILL_CLASS_TRACK(WSHIPMENT, WPOS, NOL)
Variable Instance WSHIPMENT Using C_SHIPMENT
Variable Integer WPOS
Variable Shortint NOL
Local Integer WTRKDEPLIN  # Issue 49737

If WPOS = 0 : End : Endif
# Issue 49737 - 2017-09-04 by MAE : setinstance instead of filling fiel by field
WTRKDEPLIN = WSHIPMENT.SHIPT(WPOS).TRKDEPLIN
SetInstanceNoSys WSHIPMENT.SHIPT(WPOS) With [M:SHIPT] 10
WSHIPMENT.SHIPT(WPOS).VCRNUM = [M:SHIP0]SHIPNUM
WSHIPMENT.SHIPT(WPOS).VCRTYP = 38
WSHIPMENT.SHIPT(WPOS).TRKDEPLIN = WTRKDEPLIN
#WSHIPMENT.SHIPT(WPOS).TRKNUM = [M:SHIPT]TRKNUM
#WSHIPMENT.SHIPT(WPOS).TRKCOD = [M:SHIPT]TRKCOD(NOL)
#WSHIPMENT.SHIPT(WPOS).TRKPLNDAT = [M:SHIPT]TRKPLNDAT(NOL)
#WSHIPMENT.SHIPT(WPOS).TRKENDDAT = [M:SHIPT]TRKENDDAT(NOL)
#WSHIPMENT.SHIPT(WPOS).TRKMDY = [M:SHIPT]TRKMDY(NOL)
#WSHIPMENT.SHIPT(WPOS).TRKDEPCOD = [M:SHIPT]TRKDEPCOD(NOL)
#WSHIPMENT.SHIPT(WPOS).TRKCMT = [M:SHIPT]TRKCMT(NOL)
#WSHIPMENT.SHIPT(WPOS).TRKUSR = [M:SHIPT]TRKUSR(NOL)
#WSHIPMENT.SHIPT(WPOS).TRKLIGSTAT = [M:SHIPT]TRKLIGSTAT(NOL)
# End issue 49737
End
#-------------------------------------------------------------#
Subprog COPY_SCREEN_TO_CLASS
Local Integer ASTATUS                            # Hybrid part
Local Integer ILINE
Local Integer NI

  Local File SHIPTRACK [SHIPT]
  # ----------------------------------------------------------
  # Hybrid part (begin)
  # Lignes step tracking
  # 1°) On reprend les valeurs des lignes à l'écran dans la classe
  For NI = 0 To [M:SHIPT]NBLIGNE-1
    nolign = NI + 1
    Raz [F:SHIPT]
    [F:SHIPT] = [M:SHIPT]
    [F:SHIPT]VCRNUM = [M:SHIP0]SHIPNUM
    ILINE = 0
    If [M:SHIPT]AUUID(nolign-1) <> ""
      ILINE = find([F:SHIPT]AUUID,WSHIPMENT.SHIPT(1..maxtab(WSHIPMENT.SHIPT)).AUUID)
      If WSHIPMENT.SHIPT(ILINE) <> null and find(WSHIPMENT.SHIPT(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) <> 0
        ILINE = 0
      Endif
    Endif
    If ILINE = 0
      ILINE = fmet WSHIPMENT.ADDLINE("SHIPT", [V]CST_ALASTPOS)
      If ILINE = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WSHIPMENT)
        GOK = 0
        GERR = 1
        Break
      Endif
    Endif
    SetInstance WSHIPMENT.SHIPT(ILINE) With [F:SHIPT]
  Next NI
  If GERR = 1 Then
    End
  Endif
  # ------------------
  # 2°) Celles qui sont nouvelles dans la classe et pas a l'écran : c'est que l'utilisateur à fait ECHAP sur la ligne : on la supprime
  For NI = 1 To maxtab(WSHIPMENT.SHIPT)
    If WSHIPMENT.SHIPT(NI) <> null and find(WSHIPMENT.SHIPT(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(WSHIPMENT.SHIPT(NI).AUUID), [M:SHIPT]AUUID(0..[M:SHIPT]NBLIGNE-1))
      If ILINE = 0
        [L]ASTATUS = fmet WSHIPMENT.ADELLINE("SHIPT", WSHIPMENT.SHIPT(NI).AORDER)
        If [L]ASTATUS >= [V]CST_AERROR Then
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WSHIPMENT)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # ------------------
  # 3°) Celles qui ne sont pas touchées sont détruites
  For NI = 1 To maxtab(WSHIPMENT.SHIPT)
    If WSHIPMENT.SHIPT(NI) <> null and find(WSHIPMENT.SHIPT(NI).ASTALIN,[V]CST_ANEW,[V]CST_AUPD) = 0
&   and      num$(WSHIPMENT.SHIPT(NI).AUUID)<>""
&   and find(num$(WSHIPMENT.SHIPT(NI).AUUID),[M:SHIPT]AUUID(0..[M:SHIPT]NBLIGNE-1))=0
      [L]ASTATUS = fmet WSHIPMENT.ADELLINE("SHIPT", WSHIPMENT.SHIPT.AORDER)
      If [L]ASTATUS >= [V]CST_AERROR Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WSHIPMENT)
        GOK = 0
        GERR = 1
        Break
      Endif
     Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # Hybrid part (end)
  # ----------------------------------------------------------
End
#-------------------------------------------------------------#
Subprog SHOW_TRACK_LINE(VNLINE)
Value Integer VNLINE

Local Integer NI

  Local File SHIPTRACK [SHIPT]
  SetInstance [F:SHIPT] With WSHIPMENT.SHIPT(VNLINE)
  [M:SHIPT] = [F:SHIPT]
  [M:SHIPT]COLLIN(nolign-1) = VNLINE   # Line index in the collection
  #
  For NI = nolign To [M:SHIPT]NBLIGNE-1
    If [M:SHIPT]COLLIN(NI) > 0 Then
      [M:SHIPT]TRKSORT(NI) = WSHIPMENT.SHIPT([M:SHIPT]COLLIN(NI)).TRKSORT
      Affzo [M:SHIPT]TRKSORT(NI)
    Endif
  Next NI
End
# End issue 111257 US 43

