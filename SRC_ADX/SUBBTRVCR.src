#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"    : Gosub OUVRE_BTRV
  When "AV_CHOIX" : Affzo [M:BTRV]
  When "END"      : Gosub END_BTRV
Endcase
Return

$OUVRE_BTRV
  If clalev([M:BTRV])=0   : Local Mask BTRVCR      [BTRV]  : Endif
  Local Integer I, J
  Raz [M:BTRV]

  [M:BTRV]BPR=[M:BTRB]BPR(GNBD)

  If [M:CBTR]CUR<>[M:BTR0]CUR
    [M:BTRV]CUR=[M:CBTR]CUR
  Else
    [M:BTRV]CUR=[M:BTR0]CUR
  Endif

  For I=1 To GNVCR
    If GVCRBP(I) = [M:BTRV]BPR
      [M:BTRV]VCRNUM(J) = GVCRNUM(I)
      [M:BTRV]AMOUNT(J) = GVCRAMT(I)
      [M:BTRV]DUDDAT(J) = GVCRDUD(I)
      [M:BTRV]BAN(J)    = GVCRBAN(I)
      J+=1
    Endif
  Next

  [M:BTRV]NBLIG=J
  Affzo [M:BTRV]

Return


$END_BTRV
Return
