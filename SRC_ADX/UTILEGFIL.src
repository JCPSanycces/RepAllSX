#<AdxTL>@(#)9.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Suppression du paramètre LEGPORT et de la variable globale GLEGPORT
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Delete GLEGPORT variable") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub ANULEG
End

#-------------------#
$ANULEG

Local File =DOSSIER+".AGLOBVAR" [AGB] , =DOSSIER+".ADOPAR"    [ADP]
&        , =DOSSIER+".ADOVAL"   [ADW] , =DOSSIER+".ADOVALAUS" [ADU]

# Mise à jour de la table
Call ECR_TRACE(mess(81,125,1)-"AGLOBVAR-ADOPAR-ADOVAL-ADOVALAUS :"-time$,0) From GESECRAN
Trbegin [AGB]
 Delete [AGB] Where CODVAR="GLEGPORT"
 Delete [ADP] Where PARAM="LEGPORT"
 Delete [ADW] Where PARAM="LEGPORT"
 Delete [ADU] Where PARAM="LEGPORT"
Commit

Close Local File

Return
