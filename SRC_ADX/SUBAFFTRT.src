#<AdxTL>@(#)9.0.0.0 $Revision$

## Exemple de traitement pour l'affectation du no de traite
##
## basé sur l'état RELFAC

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local Char    COMPTEUR(10)
Local Char    CPY(GLONCPY) , FCYDEB(GLONFCY) , FCYFIN(GLONFCY) , BPRDEB(GLONBPR) , BPRFIN(GLONBPR)  # hcb V6
Local Char    RELDEB(15) , RELFIN(15) , PAMDEB(3) , PAMFIN(3) , DATDEB(10) , DATFIN(10)
Local Char    FILTRE(250)
Local Integer STAT

If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif
If clalev([F:SOI])=0 : Local File SOI       [SOI] : Endif
If clalev([F:ANM])=0 : Local File ACODNUM   [ANM] : Endif
If clalev([F:AVN])=0 : Local File AVALNUM   [AVN] : Endif

Read [TCA]TCA0 = 3 : # Module tiers
If fstat
 Call ERREUR("Paramétrage non défini") From GESECRAN
 GOK = 0 : End
Endif
COMPTEUR = [F:TCA]CODNUM(8) : # Numéros de traites
Read [ANM]ANM0 = COMPTEUR
If fstat
 Call ERREUR("Compteur non défini") From GESECRAN
 GOK = 0 : End
Endif

Call GETPARAM("CPY",NBPAR,PARAMETRE,CPY) From ETAT
Call GETPARAM("FCYDEB",NBPAR,PARAMETRE,FCYDEB) From ETAT
Call GETPARAM("FCYFIN",NBPAR,PARAMETRE,FCYFIN) From ETAT
Call GETPARAM("BPRDEB",NBPAR,PARAMETRE,BPRDEB) From ETAT
Call GETPARAM("BPRFIN",NBPAR,PARAMETRE,BPRFIN) From ETAT
Call GETPARAM("RELDEB",NBPAR,PARAMETRE,RELDEB) From ETAT
Call GETPARAM("RELFIN",NBPAR,PARAMETRE,RELFIN) From ETAT
Call GETPARAM("PAMDEB",NBPAR,PARAMETRE,PAMDEB) From ETAT
Call GETPARAM("PAMFIN",NBPAR,PARAMETRE,PAMFIN) From ETAT
Call GETPARAM("SOIDATDEB",NBPAR,PARAMETRE,DATDEB) From ETAT
Call GETPARAM("SOIDATFIN",NBPAR,PARAMETRE,DATFIN) From ETAT

FILTRE = ""
If CPY<>""
 Call ADDCRIT(FILTRE,'CPY="'+CPY+'"')
Endif
If FCYDEB<>""
 Call ADDCRIT(FILTRE,'FCY>="'+FCYDEB+'"')
Endif
If FCYFIN<>""
 Call ADDCRIT(FILTRE,'FCY<="'+FCYFIN+'"')
Endif
If BPRDEB<>""
 Call ADDCRIT(FILTRE,'BPR>="'+BPRDEB+'"')
Endif
If BPRFIN<>""
 Call ADDCRIT(FILTRE,'BPR="'+BPRFIN+'"')
Endif
If RELDEB<>""
 Call ADDCRIT(FILTRE,'SOINUM>="'+RELDEB+'"')
Endif
If RELFIN<>""
 Call ADDCRIT(FILTRE,'SOINUM<="'+RELFIN+'"')
Endif
If PAMDEB<>""
 Call ADDCRIT(FILTRE,'PAM>="'+PAMDEB+'"')
Endif
If PAMFIN
 Call ADDCRIT(FILTRE,'PAM="'+PAMFIN+'"')
Endif
If gdat$(DATDEB)<>[0/0/0]
 Call ADDCRIT(FILTRE,'SOIDAT>=['+format$("D:"+GFMDAT,gdat$(DATDEB))+']')
Endif
If gdat$(DATFIN)<>[0/0/0]
 Call ADDCRIT(FILTRE,'SOIDAT<=['+format$("D:"+GFMDAT,gdat$(DATFIN))+']')
Endif

Call DEBTRANS From GLOCK
Gosub TR1
End

$TR1
GOK = 1
Trbegin [SOI]
 For [SOI] Where evalue(FILTRE) & BILVCR=""
# Il y a débat pour savoir s'il faut prendre la date du relevé ou la date du jour d'impression
  Call NUMERO(COMPTEUR,[F:SOI]FCY,date$,"",[F:SOI]BILVCR,STAT) From SUBANM
  If STAT
   Call ERREUR("Erreur sur compteur"-COMPTEUR) From GESECRAN
   GOK = 0 : Break
  Endif
  Rewrite [SOI]
  If fstat
   GOK = 0 : Call FSTA("SOI") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return
  
$AB_TR1
Rollback
Return

Subprog ADDCRIT(FILTRE,CRITERE)
Variable Char FILTRE
Value    Char CRITERE
If CRITERE<>""
 If FILTRE<>"" : FILTRE -= "&" : Endif
 FILTRE -= CRITERE
Endif
End








