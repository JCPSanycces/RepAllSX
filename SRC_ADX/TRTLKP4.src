#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################################################
#   Traitement de sélection d'un parc concerné sur une intervention        Module CRM        23 juin 2003
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GLKP4MACBRA

Local Integer IBFOUND
Local Char SZTXTNUM

  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  If !clalev([F:SRM]) : Local File SREMAC [SRM] : Endif
  IBFOUND = 0
  If [M:ITN0]SRVDEMNUM = "" Then
    FIN = 1
    #Aucune demande de service n'est associée à l'intervention. Sélection impossible.
    GMESSAGE = mess(243,182,1)
    GERR = 1
  Endif
  Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
  If fstat Then
    FIN = 1
    #Le code de la demande de service associée à l'intervention est incorrect. Sélection impossible.
    GMESSAGE = mess(244,182,1)
    GERR = 1
  Endif
  #PARAM(1) = N° de ligne appelante
  #Obtention du libellé du champ Marque
  Call PARAML("", "MACBRAUSE", SZTXTNUM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  Call TEXTE(val(SZTXTNUM), GLKP4MACBRA) From OBJDIV
  If GLKP4MACBRA = "" Then
    Call TEXTE(14543, GLKP4MACBRA) From OBJDIV
  Endif
  For [SRM] Where [F:SRM]SRENUM = [M:ITN0]SRVDEMNUM and [F:SRM]ITNGRU = [M:ITN0]MACGRU
    IBFOUND = 1
    Break
  Next
  If IBFOUND = 0 Then
    GERR = 2
    FIN = 1
    GMESSAGE = mess(212,177,1)
    Return
  Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If [M:LKP4]NBLIG > 0 Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:LKP4]NOL = val(PARAM(1))
  [M:LKP4]TTR = [F:SRE]SRETTR
  Gosub LOADLKP4
  Affzo [M:LKP4]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Kill GLKP4MACBRA
  #Nettoie l'écran avant de partir.
  If clalev([M:LKP4]) Then
    Raz [M:LKP4]
  Endif
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONOK
  VALEUR = [M:LKP4]MACNUM(nolign-1)
  [M:ITN8]HDTMACSRE([M:LKP4]NOL) = [M:LKP4]MACNUM(nolign-1)
  mkstat = 4
Return

##########################################################################################################
# Chargement du parc concerné
#########################################################
$LOADLKP4
Local Integer ITER

  ITER = 0
  Filter [SRM] Where [F:SRM]SRENUM = [M:ITN0]SRVDEMNUM and [F:SRM]ITNGRU = [M:ITN0]MACGRU
  For [SRM]
    Read [MAC]MAC0=[F:SRM]MACNUM
    If !fstat Then
      [M:LKP4]MACNUM(ITER) = [F:MAC]MACNUM
      [M:LKP4]MACPDTCOD(ITER) = [F:MAC]MACPDTCOD
      #Call LECTEXTRA([M:LKP4]MACPDTDES(ITER), "ITMMASTER", "DES1AXX", [M:LKP4]MACPDTCOD(ITER), "") From ATEXTRA
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:LKP4]MACPDTCOD(ITER),[M:LKP4]MACPDTDES(ITER), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
      [M:LKP4]MACSERNUM(ITER) = [F:MAC]MACSERNUM
      [M:LKP4]MACQTY(ITER) = [F:MAC]MACQTY
      [M:LKP4]MACBRACLA(ITER) = [F:MAC]MACBRACLA
      [M:LKP4]NBLIG += 1
    Endif
    ITER += 1
  Next
  Filter [SRM]
Return

