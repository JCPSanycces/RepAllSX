#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du fichier MEDIA
##########################################################################################################
$ACTION
  Case ACTION
    When "BOITE"       : Gosub BOITE       # FGR 31/07/2014 : X3SUIVI101463
    When "OUVRE"       : Gosub OUVRE
    When "OUVRE_BOITE" : Gosub OUVRE_BOITE
    When "SETBOUT"     : Gosub SETBOUT
    When "RAZCRE"      : Gosub RAZCRE
    When "LIENS"       : Gosub LIENS
    When "FERME"       : Gosub FERME
    When "INICRE"      : Gosub INICRE
    When "VERIF_CRE"   : Gosub VERIF_CRE
    When "VERIF_MOD"   : Gosub VERIF_MOD
    When "CREATION"    : Gosub CREATION
    When "MODIF"       : Gosub MODIF
    When "APRES_CRE"   : Gosub APRES_CRE
    When "APRES_MOD"   : Gosub APRES_MOD
    When "VERF_ANU"    : Gosub VERF_ANU
    When "ANNULE"      : Gosub ANNULE
    When "AV_ANNULE"   : Gosub AV_ANNULE
    When "FILGAUCHE"   : Gosub FILGAUCHE
   When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GCOMNCPT(GLONANM)    # Code compteur pour une opération marketing
Global Char GCOMNNUM(GLONVCR)    # N° d'opération marketing.

Local Char SZBOXOMN(10)
Local Char SZBOXON2(10)
Local Char SZSITE(GLONFCY)

  SZSITE = ""
  Call SITECRMDEF ("ACT", SZSITE) From CRM_UTIL
  GFCY = SZSITE
  Call GETDEV(GFCY) From DEVSUB
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=13
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(2)
  #  GCOMNCPT = [F:TCA]CODNUM(2)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
Return

##########################################################################################################
$BOITE
Local Char STRTSUB(GLONADC)

  # FGR 31/07/2014 : X3SUIVI101463
  STRTSUB = "SUBOMN"
  Gosub BOITE_GOBJET From CRMUTIL150
Return

##########################################################################################################
$REDEFINE_LINK
  If !clalev([F:O_MN]) Then
    # FGR 11/02/2015 : X3SUIVI106120 : Si [O_MN] pas ouvert c'est que les browsers ont été redéfinis en SPE/SPV.
    # On part, c'est à ce niveau qu'on doit faire ce travail.
    Return
  Endif
  #---------------------------------------------------#
  # FGR 30/07/2014 : X3SUIVI101463
  Link [OMN] With [O_MN]OMN0=[F:OMN]OMNNUM,
&                 [AFF]AFF0~=[F:OMN]FCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:OMN]FCY
&              As [ON2]
Return

##########################################################################################################
$OUVRE_BOITE
  #---------------------------------------------------#
  #Chargement des noms des cuurbox de chaque tiroir
  If OBJLIS(0) = "OMN" Then
    SZBOXOMN = "GAU_CHE"
  Else
    SZBOXOMN = "GAU_CHE" + num$(find("OMN",OBJLIS(1..8))) : # Salons professionnels actifs
  Endif
  If OBJLIS(0) = "ON2" Then
    SZBOXON2 = "GAU_CHE"
  Else
    SZBOXON2 = "GAU_CHE" + num$(find("ON2",OBJLIS(1..8))) : # Salons professionnels clôturés
  Endif
Return

##########################################################################################################
$FERME
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESCMG" Then
      Call LOAD_OPG From SUBCMGB
    Endif
  Endif
  # FGR 15/06/2015 : X3SUIVI108846 (début)
  If dim(GCOMNCPT) < 0 Then
    Kill GCOMNCPT            # Code compteur pour une opération marketing.
  Endif
  If dim(GCOMNNUM) < 0 Then
    Kill GCOMNNUM            # N° d'opération marketing.
  Endif
  # FGR 15/06/2015 : X3SUIVI108846 (fin)
Return

##########################################################################################################
$FILGAUCHE
  Default File [OMN]
  If currbox = SZBOXOMN Then
    # Salons professionnels actifs
    Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "CLO <> 2", "&") From GOBJSUB
  Elsif currbox = SZBOXON2 Then
    # Salons professionnels clôturés
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "CLO = 2", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "OMN") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Endif
Return

##########################################################################################################
$SETBOUT
  #Retours marketing
  If REP <> "" Then
    Call VIREBOUT(CHAINE,"P") From GOBJET
  Else
    If [M:OMN0]CMGNUM = "" Then
      Call VIREBOUT(CHAINE,"P") From GOBJET
    Endif
    If [M:OMN0]OMNNUM = "" Then
      Call VIREBOUT(CHAINE,"P") From GOBJET
    Endif
  Endif
  Call VIREBOUT(CHAINE,"HC") From GOBJET
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  Call READ_COUNTER([M:OMN0]FCY, 13, 2, GSOCIETE, GCURLEG, GCOMNCPT, GMANCOU) From CRM_UTIL        # FGR 20/05/2015 : X3SUIVI107775
  # Récupération du compteur
  If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:OMN0]FCY, GCOMNCPT, date$, "", [M:OMN0]OMNNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
        [F:OMN]OMNNUM = [M:OMN0]OMNNUM
        Affzo [M:OMN0]OMNNUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  [F:OMN]TYPFULOBJ = "OMN"
  [F:OMN]NUMFULOBJ = [M:OMN0]OMNNUM
  [M:OMN1]TYPFULOBJ = "OMN"
  [M:OMN1]NUMFULOBJ = [M:OMN0]OMNNUM
Return

##########################################################################################################
$VERIF_CRE
  Gosub CHECKDATA From SUBOMNB
Return

##########################################################################################################
$VERIF_MOD
  Gosub CHECKDATA From SUBOMNB
Return

##########################################################################################################
$CREATION
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBOMNB
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("OMN",1) From SUBPS2
Return

##########################################################################################################
$MODIF
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBOMNB
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("OMN",-1) From SUBPS2
  Call VALSTA("OMN",1) From SUBPS2
Return

##########################################################################################################
$APRES_CRE
  [M:OMN0]OMNPRECLO = [M:OMN1]CLO
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMNB
  Affzo [M:OMN1]1-99
Return

##########################################################################################################
$APRES_MOD
  [M:OMN0]OMNPRECLO = [M:OMN1]CLO
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMNB
  Affzo [M:OMN1]1-99
Return

##########################################################################################################
$VERF_ANU
  Gosub CONFIRM_ANU From SUBOMM
Return

##########################################################################################################
$AV_ANNULE
Local Char GSZOPGNUM
Local Integer IDELTODOCALL

  IDELTODOCALL = 0
  GSZOPGNUM = [M:OMN0]OMNNUM
  Gosub ANNULEOMN
Return


##########################################################################################################
$ANNULEOMN
  Gosub CLEANHISTO From SUBOMMB
  If GOK = 0 Then
    Return
  Endif
  #Suppression des clobs
  Gosub DELCLOB2 From SUBOMNB
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$ANNULE
  # Maj des statistiques
  Call VALSTA("OMN",-1) From SUBPS2
Return

##########################################################################################################
$RAZCRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  #Initialise le site par défaut
  Call SITECRMDEF("ACT", [M:OMN0]FCY) From CRM_UTIL
  GFCY = [M:OMN0]FCY
  Call GETDEV(GFCY) From DEVSUB
  [M:OMN1]CLO = 1
  Raz [M:OMN1]CLODAT
  #Initialise la devise par défaut
  [M:OMN1]CUR = GSYSCUR
  Call CMGINIDATES([M:OMN0]CMGNUM,[M:OMN1]OMNSTR, [M:OMN1]OMNEND,IERRINF,ICHAPTER, IBRETOUR)  From SUBCMGB
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMNB
  [M:OMN0]OMNNUM = ""
  Affzo [M:OMN0]1-99
  Affzo [M:OMN1]1-99
Return

##########################################################################################################
$LIENS
  GFCY = [M:OMN0]FCY
  Call GETDEV(GFCY) From DEVSUB
  #---------------------------------------------------#
  #Lecture des clobs
  #---------------------------------------------------#
  Gosub LOADCLOB From SUBOMNB
  #Affiche le nom de la campagne
  If [M:OMN0]CMGNUM <> "" Then
    Read [CMG]CMG0=[M:OMN0]CMGNUM
    If fstat Then
      [M:OMN0]CMGTTR = [M:OMN0]CMGNUM
    Else
      [M:OMN0]CMGTTR = [F:CMG]TTR
    Endif
  Endif
  [M:OMN0]OMNPRECLO = [M:OMN1]CLO
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMNB
  Affzo [M:OMN1]1-99
Return

##########################################################################################################
Subprog IB_FULOBJ

  Raz GBOUT1
  If [M:OMN1]FULOBJ<> "" Then
    If len([M:OMN1]FULOBJ) > GLONCLE Then
      Call TEXTE(23819, GBOUT1) From OBJDIV      #Synthèse
    Endif
  Endif
End

##########################################################################################################
Subprog AM_FULOBJ (VALEUR)
Variable Clbfile VALEUR

  Call GERE_TEXTE_SYNTHESE([M:OMN1]FULOBJ, VALEUR, [M:OMN1]OBJ) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
  [M:OMN1]FULOBJ = VALEUR
  Gosub DISPICON From SUBOMNB
  Affzo [M:OMN1]1-99
End

##########################################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  GFCY = VALEUR
  Call GETDEV(GFCY) From DEVSUB
End

##########################################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If VALEUR <>"" Then
    Call CMGCTRLFCY (VALEUR,[M:OMN0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AV_FCY(VALEUR)
Variable Char    VALEUR()

  # FGR 21/01/2013 : X3SUIVI71937
  If dim(GCOMNCPT) < 0 Then
    Global Char GCOMNCPT(GLONANM)   # Code compteur pour une opération marketing
  Endif
End

##########################################################################################################
Subprog C_OMNSTR(VALEUR)
Variable Date    VALEUR

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If VALEUR <> [00/00/00] Then
    Call CMGCTRLDATEDEB(VALEUR,[M:OMN0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog C_OMNEND(VALEUR)
Variable Date    VALEUR

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If VALEUR <> [00/00/00] Then
    Call CMGCTRLDATEFIN(VALEUR,[M:OMN0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AM_CLO(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    If [M:OMN0]OMNPRECLO <> 2 Then
      [M:OMN1]CLODAT = date$
    Endif
  Endif
End

