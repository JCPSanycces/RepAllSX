#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM201801001
# Issue X3-55055 - 2017-12-11 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM201801001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM201801001(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer IUPDATE
Local Char SVIEW(30)

  Call ECR_TRACE("UTIPJM201801001: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".PJMBUDTRQ"   [PJQ]
  # --------------------------
  Raz COMPTEUR
  Trbegin [PJQ]
  # --------------------------
  Filter [PJQ] Where [F:PJQ]FREECOL >= 1 and [F:PJQ]FREECOL <= 5 and [F:PJQ]CUMRTCO <> 2
  For [PJQ]
    COMPTEUR += 1
    [F:PJQ]CUMRTCO = 2
    Rewrite [PJQ]
    If fstat Then
      Call ECR_TRACE("File PJMBUDTRQ" - [F:PJQ]PBTGRP -  [F:PJQ]PBTCOD + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
  Next
  Filter [PJQ]
  # --------------------------
  Filter [PJQ] Where [F:PJQ]FREECOL >= 6 and [F:PJQ]FREECOL <= 10 and [F:PJQ]CUMRTCO <> 1
  For [PJQ]
    COMPTEUR += 1
    [F:PJQ]CUMRTCO = 1
    Rewrite [PJQ]
    If fstat Then
      Call ECR_TRACE("File PJMBUDTRQ" - [F:PJQ]PBTGRP -  [F:PJQ]PBTCOD + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
  Next
  Filter [PJQ]
  # --------------------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM201801001 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM201801001 : records processed with error(s).", 0) From GESECRAN
  Endif
  Close Local File [PJQ]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  #If APPLI = GDOSX3 and GADONIX <> 2 Then
  #  End
  #Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMBUDTRQ","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMBUDTRQ") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201801001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  #If APPLI = GDOSX3 and GADONIX <> 2 Then
  #  End
  #Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMBUDTRQ","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMBUDTRQ") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201801001(APPLI)
End

