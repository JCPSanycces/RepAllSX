#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet ICT
########################################################################
# SUBICT : Gestion des incoterms                      MUARN 06/05/2013 #
# Issue 70985 - 2012-02-15 by MUARN : Landed cost                      #
########################################################################
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "RAZCRE"    : Gosub RAZCRE
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "LIENS"     : Gosub LIENS
 When "ANNULE"    : Gosub ANNULE
 When Default
Endcase
Return

$OUVRE
If clalev([F:AML])=0 : Local File AMENLOC [AML] : Endif
If clalev([F:AST])=0 : Local File APLSTD  [AST] : Endif
Return

$RAZCRE
[M:ICT1]DES=""
If [M:ICT1]NBLIG = 0
  nolign = 0
  Filter [AST] Where LANCHP=2276 and LAN=GLANGUE and LANNUM <> 0
  For [AST] CLE
    nolign += 1
    [M:ICT1]CSTNAT(nolign-1) = [F:AST]LANNUM
    [M:ICT1]DESNAT(nolign-1) = [F:AST]LANNUM
  Next
  [M:ICT1]NBLIG = nolign
  Affzo[M:ICT1]1-99
Endif
Return

$CREATION
[F:ICTH] = [M:ICT1]
Call MAJTEXTRA([M:ICT1]DES,"INCOTERM","DES",[M:ICT1]ICTCOD,"") From ATEXTRA
For nolign = 1 To [M:ICT1]NBLIG
  Raz [F:ICTD]
  [F:ICTD] = [M:ICT1]
  Write [ICTD]
  If fstat
    GOK = 0 : Call FSTA("ICTD") From GLOCK : Break
  Endif
Next nolign
Return

$MODIF
Call MAJTEXTRA([M:ICT1]DES,"INCOTERM","DES",[M:ICT1]ICTCOD,"") From ATEXTRA
If dim([M:ICT1]NBLIG) > 0
  For [ICTD]ICTD0 Where ICTCOD = [M:ICT1]ICTCOD
    Delete  [ICTD]
    If fstat = 1
      GOK=-1
      Call RSTA ("ICTD",[M:ICT1]ICTCOD) From GLOCK : Break
    Endif
  Next
  If GOK<>-1
    For nolign = 1 To [M:ICT1]NBLIG
      Raz [F:ICTD]
      [F:ICTD] = [M:ICT1]
      [F:ICTD]ICTCOD = [M:ICT1]ICTCOD
      Write [ICTD]
      If fstat
        GOK = 0 : Call FSTA("ICTD") From GLOCK : Break
      Endif
    Next nolign
  Endif
Endif
Return

$LIENS
Call LECTEXTRA([M:ICT1]DES,"INCOTERM","DES",[M:ICT1]ICTCOD,"") From ATEXTRA
Raz [M:ICT1]CSTNAT, [M:ICT1]DESNAT, [M:ICT1]CSTPYR, [M:ICT1]NBLIG
nolign = 0
For [ICTD] Where ICTCOD=[M:ICT1]ICTCOD
  nolign +=1
  [M:ICT1]=[F:ICTD]
  Read [AST]CLE=2276;[M:ICT1]CSTNAT(nolign-1);GLANGUE
  [M:ICT1]DESNAT(nolign-1)=[F:AST]LANNUM
Next
[M:ICT1]NBLIG = nolign
Affzo[M:ICT1]1-99
Return

$ANNULE
Delete [AXX] Where CODFIC="INCOTERM" & IDENT1=[F:ICTH]ICTCOD
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]SUPP-[L]CODE) From GLOCK : Return
Endif
Delete [F:ICTD] Where ICTCOD = [F:ICTH]ICTCOD
Return

Subprog C_DESNAT(VALEUR)
Variable Integer VALEUR
Call UNICITE(VALEUR,[M]DESNAT) From OBJDIV
End

Subprog AM_DESNAT(VALEUR)
Variable Integer VALEUR
[M:ICT1]CSTNAT(nolign-1) = VALEUR
Affzo [M:ICT1]CSTNAT
End


######################################################################################
