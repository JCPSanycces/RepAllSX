Call ACTIVE
#Call ACTIVE_MAN(filpath("!tmp",ctrans(adxmac(-2),".","")+"_"+adxusr,"tra","","",""),2)
#Call ARRET_MAN
#Call LECTURE("#@C:\temp\ADMIN.tra",2) From TIMING
End

#-------------------------------#
Subprog ACTIVE_MAN(TRACE,SP)
Value Char    TRACE
Value Integer SP
Gosub TRACE
End

#-------------------------------#
Subprog ACTIVE
Gosub TRACE
End

#-------------#
$TRACE
Local Char PARAM(250)(1..4) , VALEUR(10)
Local Integer OGCONSDIA
If dim([L]TRACE)>0
 PARAM(1) = [L]TRACE
 If dim([L]SP)>0
  PARAM(2) = num$([L]SP)
 Endif
Endif
OGCONSDIA = GCONSDIA
GCONSDIA = 0
Call TRAITE_CHAR(VALEUR,PARAM,"","TIMING","TIMING",3,"XYTIMING") From GTRAITE
GCONSDIA = OGCONSDIA
Return

#-------------------------------#
$ACTION
Case ACTION
 When "INIT"      : Gosub INIT
 When "AVANT_PAR" : Gosub AVANT_PAR
 When "INIT_DIA"  : Gosub INIT_DIA
 When "EXEC"     :  Gosub EXEC
Endcase
Return

#-------------------------------#
$INIT
Local Integer OK
Return

#-------------------------------#
$AVANT_PAR
If PARAM(1)<>""
 Call SETCRIT(BCRIT,TRTCRIT,MSKCRIT,ABRCRIT,TITCRIT) From GTRAITE : # Recherche infos écran critère
 If evalue("clalev([M:"+ABRCRIT(1)+"])")=0
  Local Mask =MSKCRIT(1)
  Assign "[M:"+ABRCRIT(1)+"]TRACE" With PARAM(1)
  Assign "[M:"+ABRCRIT(1)+"]SPROG" With val(PARAM(2))
  BCRIT = ""
 Endif
Endif
Return

#-------------------------------#
$INIT_DIA
If [M:TIM]TRACE=""
 [M:TIM]TRACE = filpath("!tmp",GUSER,"tra","","","")
Endif
Return

#-------------------------------#
$EXEC
GTRTIME = [M:TIM]TRACE
GTRSUB  = ([M:TIM]SPROG=2 | [M:TIM]SPROG=0)
Call _ACTIVE(GTRTIME,GTRSUB) From ASYRTIMING
#Openo GTRTIME , 0
#Openo
#I = instr(1,[M:TIM]TRACE,"@")
#If I
# dbgstr(131) = right$([M:TIM]TRACE,I+1)
#Else
# dbgstr(131) = [M:TIM]TRACE
#Endif
#dbglong(20) = 200
Disable GSTATM1
Enable  GSTATM2
Return

#-------------------------------#
Subprog ARRET_MAN
Local Integer NOLEC
Gosub STOP
End

#-------------------------------#
Subprog ARRET
GPOINT = "TIMING" : Gosub ENTREE From EXEFNC
If GPE = 1 : End : Endif
Gosub STOP
End

#-------------#
$STOP
dbgstr(131) = ""
dbglong(20) = 0
If dim([L]NOLEC)>0
 # Pas de lecture
Else
 Call LECTURE(GTRTIME,GTRSUB)
Endif
Disable GSTATM2
Enable  GSTATM1
Return

#-------------------------------#
Subprog LECTURE(FICHIER,SPROG)
Value Char    FICHIER
Value Integer SPROG
If filinfo(FICHIER,0)<=0
 Call ECR_TRACE("|"+FICHIER-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
 End
Endif
Openi FICHIER
adxifs = ""
adxirs = chr$(10)

Onerrgo ERREUR
Gosub CALCUL1 From ASYRTIMING

If !GSERVEUR
 Call OUVRE_TRACE("") From LECFIC
Endif
Gosub CALCUL2 From ASYRTIMING
Call ECR_TRACE(mess(75,126,1)-":"-num$(TOTAL)-"ms"-"->"-format$("N:10#",HH)+":"+format$("N0:2#",MM)+":"+format$("N0:2#",SS)+":"+format$("N0:3#",MS)-"(hh:mm:ss:000)",0) From GESECRAN : # Temps total

For K=1 To NBPROG
# Issue 83075 - 2012-07-09 by VPO : augmenter taille des nombres affichés sur timing
# LIGNE =  format$("K:50X",TBPROG(K))
# LIGNE -= format$("N:6#",NBAPP(K))
# LIGNE += format$("N:8#",TMP(K))-"ms"
# If TOTAL>0
#  LIGNE -= format$("N:2.2#",100*TMP(K)/TOTAL)+" %"
# Endif
# Call ECR_TRACE(LIGNE,0) From GESECRAN
 If TOTAL>0
   Call ECR_TRACE_F(TBPROG(K),format$("N:20#",NBAPP(K)),format$("N:25#",TMP(K))-"ms",format$("N:2.2#",100*TMP(K)/TOTAL)+" %","",50,20,30,10,0,0) From GESECRAN
 Else
   Call ECR_TRACE_F(TBPROG(K),format$("N:20#",NBAPP(K)),format$("N:25#",TMP(K))-"ms","","",50,20,30,0,0,0) From GESECRAN
 Endif
Next K
If !GSERVEUR
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
Onerrgo
End

#-------------------#
$ERREUR
GMESSAGE = "Timing"-num$(errl)-LIGNE-num$(LL)-errmes$(errn)-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Raz GMESSAGE
End
