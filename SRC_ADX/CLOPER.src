#<AdxTL>@(#)10.0.0.0 $Revision$
GBIDC1 = ""
GBIDC2 = ""
GBIDI1 = 0
Call CLOPER(GBIDC1,GBIDC2,GBIDI1)
End

#######################################################
Subprog CLOPER(SOCIETE,INT_SOC,MODIF_AUTOR)
Value   Char    SOCIETE()
Value   Char    INT_SOC()
Value   Integer MODIF_AUTOR
Local   Char    PARAM(10)(1..3) , VALEUR(10)
PARAM(1) = SOCIETE
PARAM(2) = INT_SOC
PARAM(3) = num$(MODIF_AUTOR)
Call TRAITE_CHAR(VALEUR,PARAM,"","CLOPER","CLOPER",3,"") From GTRAITE
End

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
Endcase
Return


##############################################################################
$INIT
Gosub OUVRE

[L]SOCIETE = PARAM(1)
[L]INT_SOC = PARAM(2)
[L]MODIF_AUTOR = val(PARAM(3))

# Recherche période à cloturer
# On essaie de faire + d'un exercice

[M:DIA]CPY    = [L]SOCIETE
[M:DIA]LEDTYP = [M:PER1]LEDTYP
[M:DIA]ZCPY   = [L]INT_SOC
[M:DIA]BATCH  = 0

# Pour tester sans le batch !
If [M:DIA]CPY=""
 [M:DIA]BATCH = 1
Endif

Gosub CHARGE

If !I_J & [M:DIA]CPY<>""
 # Toutes les périodes sont fermées
 GMESSAGE = [L]SOCIETE-mess(62,100,1)-"("-format$(GFMD,datesyst)-")"
 GERR = 1 : FOK = 0 : Return
Endif
[M:DIA]NBLIG = I_J
Return

##############################################################################
$OUVRE
Local Libelle  CLO_PER, DER_PER
Local Libelle  LEDTYPGEN, LEDTYPANA
Local Char     CLO_CRIT(GDIMFIC)
Local Char     CODLED(GLONLED), DEVLED(GLONCUR)
Local Char     TIT(50), MESSA(250)
Local Char     SOCIETE(GLONCPY), INT_SOC(30), PARAM1(10), SOC(GLONCPY)
Local Date     DAT_DEB, DAT_FIN, ENDPERDAT1, ENDPERDAT2, DATFINPER
Local Integer  I_J, OK, NOK, K, N, I_K
Local Integer  EXERCICE , PERIODE , EXESUIV , NBPER
Local Integer  MODIF_AUTOR, OKTRACE
Local Integer  EDEB, EFIN, PMAX, EXE, IMPR, EXER, ISOC, IGCM
Local Decimal  SOLD
Local Integer  OKARCH
Local Integer  MAJSTOSTA
Local Integer  NEXO, NPER
Local Date     NDAT

Gosub OUVFIC

If clalev([M:PER1])=0 : Local Mask PER1 [PER1] : Endif

# mb 28.5.2 Astuce pour utiliser un masque avec un nombre de champs limité
#           pour les paramètres batch
#           En batch, il faut utiliser l'action TRTCLOPERB
Local Mask =BCRIT [DIA]

Raz [M:DIA]
TIT = mess(37,101,1)-mess(12,101,1) : # Clôture période

Local Char WIN (GLONFEN)
WIN="CLOPERB"
Return

$OUVFIC
If clalev([F:CPY])=0    : Local File COMPANY     [CPY]   : Endif
If clalev([F:GCM])=0    : Local File GACM        [GCM]   : Endif
If clalev([F:PER])=0    : Local File PERIOD      [PER]   : Endif
If clalev([F:PER2])=0   : Local File PERIOD      [PER2]  : Endif
If clalev([F:PER3])=0   : Local File PERIOD      [PER3]  : Endif
If clalev([F:FIY])=0    : Local File FISCALYEAR  [FIY]   : Endif
If clalev([F:GAC])=0    : Local File GACCOUNT    [GAC]   : Endif
If clalev([F:TCU])=0    : Local File TABCUR      [TCU]   : Endif
If clalev([F:BAL])=0    : Local File BALANCE     [BAL]   : Endif
If clalev([F:DAE])=0    : Local File GACCENTRYD  [DAE]   : Endif
If func AFNC.ACTIV("REGBC")
 If clalev([F:BCREG])=0 : Local File BANKCASHREG [BCREG] : Endif
Endif
If func AFNC.ACTIV("FIFRC")
 If clalev([F:BAN])   =0  : Local File BANK        [BAN]    : Endif
 If clalev([F:FIFCV]) =0  : Local File FIFOCONVAR  [FIFCV]  : Endif
 If clalev([F:FIFCV2])=0  : Local File FIFOCONVAR  [FIFCV2] : Endif
 If clalev([F:PER4])  =0  : Local File PERIOD      [PER4]   : Endif
Endif

Return

##############################################################################
$CONTROLE
If [M:DIA]CPY="" : FIN = 1 : Return : Endif
OK = 2
For I_J=0 To [M:DIA]NBLIG-1
 If [M:DIA]CLOFLG(I_J)=2 & [M:DIA]DERPER(I_J)=2
  SOC       = [M:DIA]CPY
  EXE       = [M:DIA]FIYNUM(I_J)
  DATFINPER = [M:DIA]PEREND(I_J)
  IMPR      = 0   : # on n'est pas dans le cas de l'impression de l'état CLOPER
  If [M:DIA]BATCH : IMPR= 1 : Endif
  Gosub CTL_EURO   : # Vérifs Euro
  If ![M:DIA]BATCH
   # Ligne xx Clôture de la dernière période de l'exercice
   OK = 1 : Call AVERTIR(mess(3,40,1)-num$(I_J+1)-mess(73,100,1)-num$([M:DIA]FIYNUM(I_J)),OK) From GESECRAN
   If OK<>2 : Break : Endif
  Endif
 Endif
 If [M:DIA]CLOFLG(I_J)<>2 & [M:DIA]PERSTA(I_J)=1
  # Vous devez ouvrir la période suivante Ligne xx
  If ![M:DIA]BATCH
   GMESSAGE = mess(79,100,1)-mess(3,40,1)-num$(I_J+1)
  Else
   Call ECR_TRACE(mess(79,100,1)-mess(3,40,1)-num$(I_J+1),1) From GESECRAN
  Endif
  GERR = 1 : OK = 1 : Break
 Elsif [M:DIA]CLOFLG(I_J)<>2
  OK = 2 : Break
 Endif
 If [M:DIA]PERNUM(I_J)=1 & [M:DIA]CLOFLG(I_J)=2 & func AFNC.PARAM("FRADGI",[M:DIA]CPY)="2"
  Read [F:FIY]FIY0=[M:DIA]CPY;[M:DIA]LEDTYP;[M:DIA]FIYNUM(I_J)-1
  If !fstat & [F:FIY]FIYSTA<>3
   If ![M:DIA]BATCH
    GMESSAGE = mess(73,101,1)
   Else
    Call ECR_TRACE(mess(73,101,1),1) From GESECRAN
   Endif
   GERR = 1 : OK = 1 : Break
  Endif
 Endif
 If func AFNC.ACTIV("REGBC")
  If func AFNC.PARAM("BCREG", [M:DIA]CPY) = "2" & [M:DIA]CLOFLG(I_J)=2
   Gosub CTLCLOPER_BCREG
   If OK = 1 : Break : Endif
  Endif
 Endif
 If func AFNC.ACTIV("FIFRC")
  If func AFNC.PARAM("FIFRC",[M:DIA]CPY) = "2"  & [M:DIA]CLOFLG(I_J)=2
   Gosub CTLCLOPER_FIFRC
   If OK = 1 : Break : Endif
  Endif
 Endif
Next I_J

If OK<>2
 SAI = 1 : Return
Endif

If [M:DIA]CLOFLG([M:DIA]NBLIG-1)=2
 # Il faut vérifier la suivante...
 Read [PER]PER0>[M:DIA]CPY;[M:DIA]LEDTYP;[M:DIA]FIYNUM([M:DIA]NBLIG-1);[M:DIA]PERNUM([M:DIA]NBLIG-1)
 If (fstat<4 & [F:PER]CPY=[M:DIA]CPY & [F:PER]PERSTA<>2) | fstat>=4
  If ![M:DIA]BATCH
   # Vous devez ouvrir la période suivante \ Exercice
   GMESSAGE = mess(79,100,1)-"\"-mess(3,116,1)-num$([F:PER]FIYNUM)-num$([F:PER]PERNUM)
  Else
   # Vous devez ouvrir la période suivante \ Exercice
   Call ECR_TRACE(mess(79,100,1)-"\"-mess(3,116,1)-num$([F:PER]FIYNUM)-num$([F:PER]PERNUM),1) From GESECRAN
  Endif
  SAI = 1 : Return
 Endif
Endif

Call LECTURE("CPY",[M:DIA]CPY,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ

# Clôture d'un référentiel principal sur une société de législation FRA
OKARCH = 0
If find([M:DIA]LEDTYP,[F:GCM]GENLEDTYP,[F:GCM]IASLEDTYP)
 OKARCH = 1
Else
 For I_J=0 To [M:DIA]NBLED-1
  If [M:DIA]LEDFLG(I_J)=2 & find([M:DIA]TYP(I_J),[F:GCM]GENLEDTYP,[F:GCM]IASLEDTYP)
   OKARCH = 1 : Break
  Endif
 Next
Endif
If func AFNC.PARAM("FRADGI",[F:CPY]CPY)="2" & OKARCH=1
 If ![M:DIA]BATCH
  OK = 1
  # Les archives fiscales doivent être générées
  Call AVERTIR(mess(63,101,1),OK) From GESECRAN
  If OK<>2    : # Annuler
   SAI = 1 : Return
  Endif
 Else
  # Les archives fiscales doivent être générées
  Call ECR_TRACE(mess(63,101,1),1) From GESECRAN
 Endif
Endif

TMP = 1 : # Pour afficher le tempon
TRA = 1
Return

$CTL_EURO
# Vérifs Euro : contrôle date de fin dernière période
# Si la date de fin de la dernière période à clôturer est comprise entre les dates paramètres,
# on signale: que certains comptes sont tenus en devise In (avec indication du solde),
#             que des opérations en devise In ne sont pas soldées (lettrage)
#
OKTRACE=0  : # Par défaut, pas de trace à afficher
If IMPR
 If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
 If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
 If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
 If clalev([F:BAL])=0  : Local File BALANCE    [BAL]  : Endif
 If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif
Endif
Call PARAM(SOC,"ENDPERDAT1",PARAM1) From ADOVAL
If PARAM1<>""
 ENDPERDAT1 = PARAM1
Endif
If ENDPERDAT1=[0/0/0] : ENDPERDAT1=[31/12/2001] : Endif
Call PARAM(SOC,"ENDPERDAT2",PARAM1) From ADOVAL
If PARAM1<>""
 ENDPERDAT2 = PARAM1
Endif
If ENDPERDAT2=[0/0/0] : ENDPERDAT2=[31/12/2002] : Endif
If ENDPERDAT1<=DATFINPER & DATFINPER<=ENDPERDAT2
 If !IMPR
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  # Vérification en cours...
  Call TEMPON(mess(2,100,1)) From GESECRAN
 Endif
 Gosub CTLDERPER
 Gosub LST_PIECE
 If !IMPR
  Call TEMPOFF From GESECRAN
  If OKTRACE=1
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
  Endif
 Endif
Endif
Return

$CTLDERPER
Call LECLED([M:DIA]CPY,[M:DIA]LEDTYP,CODLED,DEVLED) From CPTDIV
If IMPR
 Call ECR_TRACE("",0) From GESECRAN
Else
 # Société ...
 Call ECR_TRACE(mess(2,116,1)-SOC,0) From GESECRAN
Endif
# Clôture de la dernière période de l'exercice xx : comptes en devise In
Call ECR_TRACE(mess(73,100,1)-num$(EXE)-":"-mess(56,101,1),0) From GESECRAN
Filter [FIY] Where CPY=SOC & FIYSTA=2 & FIYEND<=DATFINPER
Read [FIY]FIY0 First
EDEB = [F:FIY]FIYNUM
Read [FIY]FIY0 Last
EFIN = [F:FIY]FIYNUM
Filter [FIY]
PMAX = dim([F:BAL]DEB)-1
Filter [GAC] Order By Key CLE = CUR;ACC
For [GAC]CLE(1)
 DEVISE = [F:GAC]CUR
 If DEVISE<>"" & DEVISE<>GEURO
  Call LECTURE("TCU",DEVISE,"") From CONTOBJ
  # On affiche les comptes non soldés tenus en devise In,
  # qq soit la date de fin de validité de la devise en question
  If [F:TCU]EURFLG=2
   For [GAC]CLE
    Gosub CALC_SOLDE
   Next
  Endif
 Endif
Next
Filter [GAC]
Return

$CALC_SOLDE
SOLD = 0
For EXER=EDEB To EFIN
 Filter [BAL] Where LEDTYP=[M:DIA]LEDTYP & CPY=SOC & FCY="" & FIY=EXER & ACC=[F:GAC]ACC
&                 & BPR=""
 For [BAL]BAL0
  If EXER=EDEB
   SOLD += sum([F:BAL]DEBLED(0..PMAX))-sum([F:BAL]CDTLED(0..PMAX))
  Else
   SOLD += sum([F:BAL]DEBLED(1..PMAX))-sum([F:BAL]CDTLED(1..PMAX))
  Endif
 Next
 Filter [BAL]
Next
If SOLD<>0
 If !OKTRACE : OKTRACE=1 : Endif   : # trace à afficher
 # Compte ... Solde: ... Devise
 Local Char INTIT(GLONAX3)
 Call LECTEXTRA(INTIT,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 Call ECR_TRACE(mess(45,102,1)-[F:GAC]ACC-"("+[L]INTIT+")"-mess(1,106,1)+":"-num$(SOLD)-DEVLED,0) From GESECRAN
Endif
Return

$LST_PIECE
Call LECLED([M:DIA]CPY,[M:DIA]LEDTYP,CODLED,DEVLED) From CPTDIV
Call SETMAINREF([M:DIA]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
If LEDTYPGEN<>[M:DIA]LEDTYP : Return : Endif : ### Si ce n'est pas le "Réf. général pricncipal", on s'arrête...
Call ECR_TRACE("",0) From GESECRAN
# Opérations non soldées en devise In (date)
Call ECR_TRACE(mess(55,101,1)-"("+format$(GFMD,DATFINPER)+")",0) From GESECRAN

For [GAC]GAC0 Where MTC=2   : # comptes lettrables
 Filter [DAE] Where ACC=[F:GAC]ACC & CPY=SOC & LEDTYP=[M:DIA]LEDTYP & (MTC<"A" | MTC>"ZZZZZ")
&                 & CUR<>GEURO & ACCDAT<=DATFINPER
& Order By Key CLE = CUR;TYP;NUM
 For [DAE]CLE(1)
   Call LECTURE("TCU",[F:DAE]CUR,"") From CONTOBJ
   If [F:TCU]EURFLG=2
    For [DAE]CLE
     If !OKTRACE : OKTRACE=1 : Endif   :# trace à afficher
     If [F:GAC]SAC<>2     : # compte normal
      Call ECR_TRACE([F:DAE]TYP-[F:DAE]NUM-[F:DAE]CUR-[F:DAE]ACC-":"-[F:DAE]MTC,0) From GESECRAN
     Else  :# compte collectif
      Call ECR_TRACE([F:DAE]TYP-[F:DAE]NUM-[F:DAE]CUR-[F:DAE]ACC-[F:DAE]BPR-":"-[F:DAE]MTC,0) From GESECRAN
     Endif
    Next
   Endif
 Next
Next

Filter [DAE]
If IMPR : Call ECR_TRACE("",0) From GESECRAN : Endif
Return


#######################################################
$FIN
If !GSERVEUR & GTRACE<>""
 TRA = 1
Else
 TRA = 0
Endif
Return

#######################################################
$EXEC
If !GSERVEUR & GTRACE=""
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

NOK = 0

# Si ACCIFA ou OPEIFA à Oui Alors la clôture màj la zone PERSTOSTA dans la table PERIOD
Call PARAM([M:DIA]CPY,"ACCIFA",PARAM1) From ADOVAL
If PARAM1="1"
 Call PARAM([M:DIA]CPY,"OPEIFA",PARAM1) From ADOVAL
Endif
If PARAM1<>"1"
 MAJSTOSTA = 1
Endif

Call SETMAINREF([M:DIA]CPY,GTYPGEN,GTYPANA) From CPTDIV

## Pour chaque période à clôturer, on va effectuer des contrôles sur chaque référentiel concerné par la clôture
## la clôture d'une période ne pourra se faire que si les contrôles sont bons sur chaque référentiel
For I_J=1 To [M:DIA]NBLIG
 SOCIETE  = [M:DIA]CPY
 EXERCICE = [M:DIA]FIYNUM(I_J-1)
 PERIODE  = [M:DIA]PERNUM(I_J-1)
 CLO_PER  = [M:DIA]CLOFLG(I_J-1)
 DER_PER  = [M:DIA]DERPER(I_J-1)
 If (CLO_PER<>2 & [M:DIA]PERSTA(I_J-1)<>3)
  Break
 Endif
 If CLO_PER<>2
  Goto LIG_SUIV
 Endif
 If [M:DIA]LEDTYP<>GTYPGEN
  Filter [PER3] Where CPY=[M:DIA]CPY & LEDTYP=[M]LEDTYP & PERSTA = 2
  Read [PER3]PER0 First
  Filter [PER3]
  If !fstat
   NDAT = [F:PER3]PEREND
   For [PER3]PER0 Where CPY=[M:DIA]CPY & LEDTYP=GTYPGEN & PERSTR<=NDAT & PEREND>=NDAT
    NEXE = [F:PER3]FIYNUM
    NPER = [F:PER3]PERNUM
   Next
   If !NPER | [F:PER3]PERSTA<3
    ## La période du référentiel général principal n'a pas encore été clôturée
    MESSA = mess(148,104,1)-"("+format$(GFMD,[F:PER3]PERSTR)+"->"+format$(GFMD,[F:PER3]PEREND)+")"
    Call ECR_TRACE(MESSA,0) From GESECRAN
    Goto LIG_SUIV
   Endif
  Endif
 Endif
 REFTYP = [M:DIA]LEDTYP
 Read [PER]PER0=SOCIETE;REFTYP;EXERCICE;PERIODE
 DAT_DEB        = [F:PER]PERSTR
 DAT_FIN        = [F:PER]PEREND
 #### Vérifications CPY du 00/00/00 au 00/00/00
 MESSA =  mess(4,115,1)-SOCIETE-mess(40,101,1)-format$("D:"+GFMDAT,DAT_DEB)-mess(41,101,1)
&        -format$("D:"+GFMDAT,DAT_FIN)

 Call ECR_TRACE(MESSA,0) From GESECRAN
 OK = 2

 Gosub CONT_AV_CLOPER
 If OK & !NOK
  ## On regarde les autres référentiels
  For N=0 To [M:DIA]NBLED-1
   If [M:DIA]LEDFLG(N)=2 # Création = Oui
    REFTYP   = [M:DIA]TYP(N)
    Gosub CONT_AV_CLOPER
    If !OK & NOK : Break : Endif
   Endif
  Next N
 Endif

 If !GSERVEUR
  Call TEMPOFF From GESECRAN
 Endif

 # Tout est Ok, on peut clôturer.
 If OK & !NOK
  If !GSERVEUR
   #### Clôture CPY du 00/00/00 au 00/00/00
   Call ECR_TRACE(mess(37,101,1)-SOCIETE-mess(40,101,1)-format$("D:"+GFMDAT,DAT_DEB)-mess(41,101,1)-format$("D:"+GFMDAT,DAT_FIN),0) From GESECRAN
  Endif
  Call DEBTRANS From GLOCK
  Gosub TR2
  If GOK=1
   #### CPY Clôture de la période du 00/00/00 au 00/00/00 Terminée
   Call ECR_TRACE(SOCIETE-mess(39,101,1)-mess(40,101,1)-format$("D:"+GFMDAT,DAT_DEB)-mess(41,101,1)-format$("D:"+GFMDAT,DAT_FIN)-mess(3,21,1),0) From GESECRAN
  Else
   #### CPY Clôture de la période du 00/00/00 au 00/00/00 Opération impossible
   Call ECR_TRACE(SOCIETE-mess(39,101,1)-mess(40,101,1)-format$("D:"+GFMDAT,DAT_DEB)-mess(41,101,1)-format$("D:"+GFMDAT,DAT_FIN)-mess(157,123,1),0) From GESECRAN
  Endif
 Else
  Break
 Endif

$LIG_SUIV
Next I_J

If !GSERVEUR & GTRACE<>""
 Call FERME_TRACE From LECFIC
Endif
Return


$CONT_AV_CLOPER
If GMODU(2)=2  : # Compta
 Call ECR_TRACE(mess(208,111,1)-mess(REFTYP,2644,1),0) From GESECRAN
 OK = 2
 Call VERF(SOCIETE,DAT_DEB,DAT_FIN,EXERCICE,PERIODE,REFTYP,DER_PER,OK) From UTICPTA
 If !OK
  NOK += 1
 Endif
Endif
Return

$TR2
GOK=1
Trbegin [PER]
 REFTYP = [M:DIA]LEDTYP
 GCLE = SOCIETE-num$(REFTYP)-num$(EXERCICE)-num$(PERIODE)
 Readlock [PER]PER0 = SOCIETE;REFTYP;EXERCICE;PERIODE
 If fstat=1
  GOK=-1 : GLOCK="$PERIOD"-GCLE : Goto ROLL_TR2
 Elsif fstat
  GOK=0 : Call RSTA("PER",GCLE) From GLOCK : Goto AB_TR2
 Endif
 If CLO_PER=2
  [F:PER]PERSTA    = 3
  [F:PER]CLODAT    = date$
  If MAJSTOSTA=1
   [F:PER]PERSTOSTA = 4     : # Statut mvt stock = Interdit
  Endif
  GPOINT="BEFCLOPER" : Gosub ENTREE From EXEFNC : # PE : 80351
 Endif
 Rewrite [PER]
 If fstat
  GOK=0 : Call FSTA("PER") From GLOCK : Goto AB_TR2
 Endif
 Call PERAUT(SOCIETE,REFTYP,EXERCICE,PERIODE,GOK) From SUBPER
 If !GOK : Goto AB_TR2 : Endif
 ## et les autres référentiels...
 For N=0 To [M:DIA]NBLED-1
  If [M:DIA]LEDFLG(N)=2 # Création = Oui
   REFTYP   = [M:DIA]TYP(N)
   GCLE = SOCIETE-num$(REFTYP)-num$(EXERCICE)-num$(PERIODE)
   Readlock [PER]PER0 = SOCIETE;REFTYP;EXERCICE;PERIODE
   If fstat=1
    GOK=-1 : GLOCK="$PERIOD"-GCLE : Break
   Elsif fstat
    GOK=0 : Call RSTA("PER",GCLE) From GLOCK : Break
   Endif
   If CLO_PER=2
    [F:PER]PERSTA = 3
    [F:PER]CLODAT = date$
    If MAJSTOSTA=1
     [F:PER]PERSTOSTA = 4     : # Statut mvt stock = Interdit
    Endif
    GPOINT="BEFCLOPER" : Gosub ENTREE From EXEFNC : # PE : 80351
   Endif
   Rewrite [PER]
   If fstat
    GOK=0 : Call FSTA("PER") From GLOCK : Break
   Endif
   Call PERAUT(SOCIETE,REFTYP,EXERCICE,PERIODE,GOK) From SUBPER
   If !GOK : Break : Endif
  Endif
 Next
 If GOK<0    : Goto ROLL_TR2
 Elsif !GOK  : Goto AB_TR2
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$AB_TR2
Rollback
Return

#######################################################
$CHARGE
Raz I_J
Local Integer OK_CHARGE, NOLI
For [PER]PER0 Where CPY=[M:DIA]CPY & LEDTYP=[M:DIA]LEDTYP
 If [F:PER]PERSTA=2 & [F:PER]PEREND<=datesyst  : # Ouvert
  If I_J>=dim([M:DIA]FIYNUM)
   Break
  Endif
  If [F:PER]FIYNUM<>[F:FIY]FIYNUM
   Read [FIY]FIY0=[F:PER]CPY;[F:PER]LEDTYP;[F:PER]FIYNUM
  Endif
  nolign = I_J+1
  [M:DIA]                = [F:PER]
  [M:DIA]FIYSTA(I_J)     = [F:FIY]FIYSTA
  [M:DIA]FIYNUM(I_J)     = [F:PER]FIYNUM
  [M:DIA]PERNUM(I_J)     = [F:PER]PERNUM
  [M:DIA]PERSTR(I_J)     = [F:PER]PERSTR
  [M:DIA]PEREND(I_J)     = [F:PER]PEREND
  [M:DIA]PERSTA(I_J)     = [F:PER]PERSTA
  [M:DIA]CLOFLG(I_J)     = 1                : # Par défaut Non sauf le 1er
  If [M:DIA]FIYSTA(I_J)=2 & I_J=0 & [F:PER]PERSTA=2
   [M:DIA]CLOFLG(I_J) = 2
  Endif
  # Matérialisation de la dernière période de l'exercice / Last Period of a Fiscalyear
  Filter [PER3] Where CPY=[F:PER]CPY & LEDTYP=[F:PER]LEDTYP & FIYNUM=[F:PER]FIYNUM
  Read [PER3]PER0 Last
  If !fstat & [F:PER]PERNUM=[F:PER3]PERNUM
   [M:DIA]DERPER(I_J) = 2
  Endif
  Filter [PER3]
  I_J += 1
 Endif
Next


# La fenêtre de clôture a un tableau des référentiels initialisé à l’ensemble des
# référentiels pour lesquels les mêmes opérations sont possibles : mêmes périodes et mêmes états. On ne pourra
# que supprimer des référentiels.
Read [GCM]GCM0=[F:CPY]ACM
For K=0 To dim([F:GCM]LED)-1
 If [F:GCM]LED(K)<>""
  If K+1<>[M:DIA]LEDTYP
   # Trt batch
   #Filter [PER2] Where CPY=[M:PER1]CPY & FIYNUM=[M:PER1]FIYNUM & LEDTYP=[L]K+1 & LEDTYPAUT<>2
    Filter [PER2] Where CPY=[M]CPY & FIYNUM=[M]FIYNUM & LEDTYP=[L]K+1 & LEDTYPAUT<>2
   OK_CHARGE = 0 : NOLI = 0
   For [PER2]PER0
    If GFONCTION1="GESPER"
     If [F:PER2]PERSTR=[M:PER1]PERSTR(NOLI) & [F:PER2]PEREND=[M:PER1]PEREND(NOLI) & [F:PER2]PERSTA=[M:PER1]PERSTA(NOLI)
      OK_CHARGE = 1
     Else
      OK_CHARGE = 0 : Break
     Endif
     NOLI+=1
    Else
     Read [PER]PER0=[F:PER2]CPY;[M]LEDTYP;[F:PER2]FIYNUM;[F:PER2]PERNUM
     If !fstat & [F:PER]PERSTR=[F:PER2]PERSTR & [F:PER2]PEREND=[F:PER]PEREND & [F:PER2]PERSTA=[F:PER]PERSTA
      OK_CHARGE=1
     Else
      OK_CHARGE = 0 : Break
     Endif
    Endif
   Next
   Filter [PER2]

   # si dates de période et états période identiques, on ajoute le référentiel dans le tableau
   If OK_CHARGE
    [M:DIA]TYP([M:DIA]NBLED)    = K+1
    [M:DIA]LEDFLG([M:DIA]NBLED) = 2
    [M:DIA]NBLED += 1
   Endif
  Endif
 Endif
Next

Return

#######################################################
$CTLCLOPER_BCREG
Filter [F:BCREG] Where [F:BCREG]CPY = [M:DIA]CPY  and [F:BCREG]STA <> 2 and
& (([F:BCREG]STARTDAT >= [M:DIA]PERSTR(I_J) and [F:BCREG]STARTDAT <= [M:DIA]PEREND(I_J)) or
& ([F:BCREG]FINDAT >= [M:DIA]PERSTR(I_J) and [F:BCREG]FINDAT <= [M:DIA]PEREND(I_J)))
Look [F:BCREG] First
If !fstat
 Call ECR_TRACE( func AFNC.MES1(mess(40,7702,1), [M:DIA]CPY) ,1) From GESECRAN : GERR = 1 : OK = 1
Endif
Filter [F:BCREG]
Return
#######################################################
$CTLCLOPER_FIFRC
Local Date FIFRCPERSTR, FIFRCPEREND
Local Integer  LI, LPF
[L]LI = 1 : [L]LPF = 1

Filter [F:PER4] Where [F:PER4]CPY=[M:DIA]CPY and [F:PER4]LEDTYP=[M:DIA]LEDTYP and [F:PER4]FIYNUM=[M:DIA]FIYNUM(I_J)
Read [PER4]PER0 First
[L]FIFRCPERSTR = [PER4]PERSTR

Read [PER4]PER0 Last
[L]LPF         = [PER4]PERNUM
[L]FIFRCPEREND = [PER4]PEREND
Filter [PER4]

If [L]LPF <> [M:DIA]PERNUM(I_J)
 Filter [F:FIFCV] Where [F:FIFCV]CPY = [M:DIA]CPY and [F:FIFCV]FLDPOS <> 2 and
&                       (([F:FIFCV]STARTDAT >= [M:DIA]PERSTR(I_J) and [F:FIFCV]STARTDAT <= [M:DIA]PEREND(I_J)) or
&                       ([F:FIFCV]FINDAT >= [M:DIA]PERSTR(I_J) and [F:FIFCV]FINDAT <= [M:DIA]PEREND(I_J)))
Else
 Filter [F:FIFCV] Where [F:FIFCV]CPY = [M:DIA]CPY and [F:FIFCV]FLDPOS <> 2 and
&                       (([F:FIFCV]STARTDAT >= [L]FIFRCPERSTR and [F:FIFCV]STARTDAT <= [L]FIFRCPEREND) or
&                       ([F:FIFCV]FINDAT >= [L]FIFRCPERSTR and [F:FIFCV]FINDAT <= [L]FIFRCPEREND))
Endif
Read [F:FIFCV] First
#Issue X3-70885 & X3-71035 – 2018-01-18 by MADOR - Additional FIFO conversions - Closing last period
If !fstat
 Call AVERTIR(mess(17,7708,1)-mess(432,7773,1), [L]LI) From GESECRAN
 If [L]LI <> 2 : GERR = 1 : OK = 1 : Endif
Else
 Gosub CHECK_IF_FIFO_EXIST
Endif
#Issue end
Filter [F:FIFCV]
Return
###########################################
## Saisie des paramètres batch
###########################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK)
Value    Char    DOSSIER
Value    Char    USER
Variable Char    P1()(1..)
Variable Char    P2()(1..)
Variable Integer OK
Local    Integer I

Gosub OUVRE
[M:DIA]BATCH = 1       : # C'est du batch
If P1(1)<>""
 [M:DIA]FCY   = left$(P1(1),3)
 Gosub CHARGE
Endif

# Saisie des critères
Call GETPAR(P1,P2)

OK=2 : Call DIALWIN(OK,TIT,WIN) From GESECRAN

If OK=2
 Gosub LEC_PAR
Else
 OK=0
Endif
End

$LEC_PAR
For I=1 To [M:DIA]NBLIG
 P1(I)  = format$("K:3X",[M:DIA]CPY)
 P1(I) += format$("N0:2#",[M:DIA]FIYNUM(I-1))
 P1(I) += format$("N0:2#",[M:DIA]PERNUM(I-1))
 P1(I) += format$("N0:1#",[M:DIA]CLOFLG(I-1))
 P1(I) += num$(([M:DIA]DERPER(I-1)=2))
Next I
Return

Subprog GETPAR(P1,P2)
Variable Char P1()(1..)
Variable Char P2()(1..)
nolign = 0
For I=1 To dim(P1)
 If P1(I)="" : Break : Endif
 nolign += 1
 [M:DIA]CPY                 = left$(P1(I),3)
 [M:DIA]FIYNUM(nolign-1)    = val(mid$(P1(I),4,2))
 [M:DIA]PERNUM(nolign-1)    = val(mid$(P1(I),6,2))
 [M:DIA]CLOFLG(nolign-1)    = val(mid$(P1(I),8,1))
 [M:DIA]DERPER(nolign-1)    = val(mid$(P1(I),10,1))+1
Next I
End


#################################
Subprog IMPRIME(NBPAR,PARAMETRES)
#################################
Variable Integer NBPAR
Variable Char    PARAMETRES()(1..)
If GMODU(2)<>2
 # Fonction non autorisée
 Call ECR_TRACE(mess(1,123,1)+"\GMODU(2)<>2",1) From GESECRAN
 GOK=0 : NBPAR=0 : End
Endif

Onerrgo ERREUR From CONTROLE
If !clalev([F:PER]) : Local File PERIOD [PER] : Endif
Local File PERIOD [PER2]
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
If !clalev([F:GCM]) : Local File GACM    [GCM] : Endif
Onerrgo
If GERREUR : GERREUR=0 : GOK=0 : End : Endif

Local Char    PARAM(50), SOCIETE(GLONCPY)
Local Date    DD, DF, DAT_DEB, DAT_FIN
Local Libelle DER_PER , REF
Local Integer OK
Local Char    OGTRACE(GLONTRA)
Local Integer OGLTRACE, OGERRTRACE

# Pour vérifs Euro
Local Date     ENDPERDAT1, ENDPERDAT2, DATFINPER
Local Char     PARAM1(10), DEVLED(GLONCUR), SOC(GLONCPY), NAMFIC(250)
Local Integer  OKTRACE, EDEB, EFIN, PMAX, EXE, IMPR, EXER
Local Decimal  SOLD

Call GETPARAM("soc",NBPAR,PARAMETRES,SOCIETE) From ETAT
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
If fstat or [F:CPY]CPYLEGFLG=1
 # Société non juridique
 Call ECR_TRACE(SOCIETE-":"-mess(12,199,1),1) From GESECRAN
 GOK=0 : End
Endif
Call GETPARAM("datdeb",NBPAR,PARAMETRES,PARAM) From ETAT
DD = PARAM
Call GETPARAM("datfin",NBPAR,PARAMETRES,PARAM) From ETAT
DF = PARAM
Call GETPARAM("ledtyp",NBPAR,PARAMETRES,PARAM) From ETAT
REF = val(PARAM)

If GTRACE<>""
 OGTRACE=GTRACE
 OGLTRACE=GLTRACE
 OGERRTRACE=GERRTRACE
Endif
Call TEMPON("") From GESECRAN
Call OUVRE_TRACE("") From LECFIC

# Clôture d'un référentiel principal sur une société de législation FRA
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
If func AFNC.PARAM("FRADGI",[F:CPY]CPY)="2" & find(REF,[F:GCM]GENLEDTYP,[F:GCM]IASLEDTYP)
 # Les archives fiscales doivent être générées
 Call ECR_TRACE(mess(63,101,1),1) From GESECRAN
Endif

For [PER]PER0 Where CPY=[L]SOCIETE & PERSTR<=[L]DF & PEREND>=[L]DD & LEDTYP=REF
 If [F:PER]PERSTA=2
  EXERCICE = [F:PER]FIYNUM
  PERIODE  = [F:PER]PERNUM
  REFTYP   = [F:PER]LEDTYP
  DAT_DEB  = [F:PER]PERSTR
  DAT_FIN  = [F:PER]PEREND
  Read [PER2]PER0 > SOCIETE;REFTYP;EXERCICE;PERIODE
  If fstat>2 | [F:PER2]CPY<>SOCIETE | [F:PER2]FIYNUM<>EXERCICE
   DER_PER = 2
  Else
   DER_PER = 1
  Endif
  # SOCIETE Clôture de la période du DAT_DEB au DAT_FIN
  Call ECR_TRACE(SOCIETE-"("+mess(REF,2644,1)+")"-mess(39,101,1)-mess(40,101,1)-format$("D:"+GFMDAT,DAT_DEB)-mess(41,101,1)-format$("D:"+GFMDAT,DAT_FIN),0) From GESECRAN
  OK=2
  Call VERF(SOCIETE,DAT_DEB,DAT_FIN,EXERCICE,PERIODE,REFTYP,DER_PER,OK) From UTICPTA
  # Vérifs Euro : clôture de la dernière période
  If DER_PER=2
   SOC       = SOCIETE
   EXE       = EXERCICE
   DATFINPER = DAT_FIN
   IMPR = 1  :# cas de l'impression de l'état CLOPER
   Gosub CTL_EURO
  Endif
 Endif
Next : # [PER]
Call FERME_TRACE From LECFIC
Call TEMPOFF From GESECRAN
If GTRACE=""
 GOK=0 : NBPAR=0
Else : # Impression de la trace
 If adxmac(0)=""
  Call SETPARAM("nomfic",NBPAR,PARAMETRES,GTRACE) From ETAT
 Else
  NAMFIC = filpath("TRA",GTRACE,"tra",nomap(0),"",adxmac(0))
  Call SETPARAM("nomfic",NBPAR,PARAMETRES,NAMFIC) From ETAT
 Endif
 Call IMPRIME(NBPAR,PARAMETRES) From LECFIC
 Raz GTRACE, GLTRACE, GERRTRACE
Endif
If OGTRACE<>""
 GTRACE=OGTRACE
 GLTRACE=OGLTRACE
 GERRTRACE=OGERRTRACE
 Openo GTRACE, -1
Endif
End
######################################################################################
$CHECK_IF_FIFO_EXIST
#Issue X3-70885 & X3-71035 – 2018-01-18 by MADOR - Additional FIFO conversions - Closing last period
Local Date FIRSTSTARTDAT #Start date of first fifo record for some bank/cash

Filter [F:BAN] Where [F:BAN]CPY = [M:DIA]CPY and [F:BAN]FLDFIFCP = 2 and [F:BAN]FLDSDA <= [M:DIA]PERSTR(I_J)
For [F:BAN]BAN1
    Filter [F:FIFCV2] Where [F:FIFCV2]FIFCOD = [F:BAN]BAN and
&                           (([F:FIFCV2]STARTDAT >= [M:DIA]PERSTR(I_J) and [F:FIFCV2]STARTDAT <= [M:DIA]PEREND(I_J)) or
&                            ([F:FIFCV2]FINDAT >= [M:DIA]PERSTR(I_J) and [F:FIFCV2]FINDAT <= [M:DIA]PEREND(I_J)) or
&                            ([F:FIFCV2]STARTDAT < [M:DIA]PERSTR(I_J) and [F:FIFCV2]FINDAT > [M:DIA]PEREND(I_J)))
    Read [F:FIFCV2] First
    If fstat
        Call AVERTIR(func AFNC.MES1(mess(22,7708,1)-mess(432,7773,1), [F:BAN]BAN), [L]LI) From GESECRAN
        If [L]LI <> 2 : GERR = 1 : OK = 1 : Break : Endif
    Endif
Next

Filter [F:BAN]
Filter [F:FIFCV2]
#Issue end
Return

