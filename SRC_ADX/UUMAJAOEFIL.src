#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise ֳ  jour du champ FIL et fLGEXP
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update field FIL and FLGEXP") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

#-------------------#
$MAJ
Local File =DOSSIER+".AOBJEXT" [AOE]

Local Char AFIL(GLONATB)(0..dim([F:AOE]FIL)-1),AFLGEXP(120)(0..dim([F:AOE]FLGEXP)-1)
Local Integer I,NB

Trbegin [F:AOE]
 For [F:AOE]AOE0
  Raz AFIL,AFLGEXP,NB
  For I=0 To dim([F:AOE]FIL)-1
   If !find([F:AOE]FIL(I),AFIL)
    AFIL(NB)    = [F:AOE]FIL(I)
    AFLGEXP(NB) = [F:AOE]FLGEXP(I)
    NB +=1
   Endif
  Next I
  Raz [F:AOE]FIL,[F:AOE]FLGEXP
  For I=0 To NB-1
   [F:AOE]FIL(I)    = AFIL(I)
   [F:AOE]FLGEXP(I) = AFLGEXP(I)
  Next
  Rewrite [F:AOE]
  If fstat : Call ERREUR("AOBJEXT"-[F:AOE]EXT,2) From DOSDIC  : Endif
 Next I
Commit
Return
