# FQ92896-US2255-Convergence
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
If GFUSION = 1
  Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
  mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP, VALEUR,[M]FICHIER,E_TYPE_FILEWRITE,GMESSAGE)
Else
  Call CTRL_FICHIER(VALEUR)
  If !mkstat : [M]FICHIER=VALEUR : Endif
Endif
End

# FQ92896-US2255-Convergence
Subprog AM_VOLFIL(VALEUR)
Variable Char    VALEUR()
Local Char    FICPATCH(GDIMFIC)
Local Integer OK
If filinfo([M]FICHIER,0)>=0 & ([M]NBOBJ=0)
 Call OUINON(mess(47,115,1),OK) From GESECRAN : # Chargement objets
 If OK=2 : [L]FICPATCH=[M]FICHIER : Gosub CHARGE : Endif
Endif
GFICPATH = VALEUR
End
#end FQ92896-US2255-Convergence

