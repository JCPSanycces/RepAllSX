#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque APATCHP
#** V7 : Waiting time management module **#
#*********************************#
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","HRAPATCHP","HRAPATCHP",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT_DIA"  : Gosub INIT_DIA
 When "EXEC"      : Gosub EXEC

 When "SEL_TABLE" : Gosub SEL_TABLE
 When "SEL_LISTE" : Gosub SEL_LISTE
 When "SORTIE"    : Gosub SORTIE
Endcase
Return

$INIT_DIA
Raz [M:DIA]
# SBA FQ92041 - US1927
[M:DIA]TYPEXP = 2
[M:DIA]DOSSIER = nomap
#JOJAC - 2016-03-22 - REQ114309 US79 - START
#[M:DIA]FICHIER = "/u/by/patch/aa"
Call AM_TYPEXP([M:DIA]TYPEXP):# FQ92896-US2255-Convergence
#JOJAC - 2016-03-22 - REQ114309 US79 - END

If GNBLEG = 1
 GCURLEG = GDOSLEG
Else
 GCURLEG = GLEGFIL
Endif

Return

################################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$EXEC
Local Integer I , J , K , Z
Local Char    FICHIER(10) , ABR(10) , VARIA(10) , IDENT(50) , CHAINE(250) , CHAINE2(250)
Local Integer TYP , IND , NBZONE
Local Integer NUMERO , CHAPITRE
Local Libelle BUFFER(1..30)
Local Integer NB , COMPTE
Local Char    REP(10) , EXT(10) , APPLI(10)
Local Char    CLOB(64)(1..500)
Local Integer NBCLO
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Integer NBLAN
Local Char    LANGUE(GLONLAN)(1..10)

APPLI = [M:DIA]DOSSIER
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

If GNBLEG = 1
 GCURLEG = GDOSLEG
Else
 GCURLEG = [M:DIA]LEG
Endif

Local File =APPLI+".ATABZON"   [ZATZ]
Local File =APPLI+".ATEXTE"    [ZATX]
Local File =APPLI+".ATEXTRA"   [ZAXX]
Local File =APPLI+".RUBRIQUE"  [RUB]
Local File =APPLI+".VARIA"     [VRA]
Local File =APPLI+".CUMUL"     [CUM]
Local File =APPLI+".VALEUR"    [VLA]
Local File =APPLI+".CALRUB"    [CRB]
Local File =APPLI+".PROFIL"    [PRF]
Local File =APPLI+".EXOPAY"    [EXO]
Local File =APPLI+".DECCHARGE" [DCH]
#JOJAC - 2016-03-22 - REQ114309 US79 - START
#Local File =APPLI+".HRFILTDS"    [FTD]
#JOJAC - 2016-03-22 - REQ114309 US79 - END
Local File =APPLI+".ATABTAB"   [ADV]
Local File =APPLI+".ATABDIV"   [ADI]
Local File =APPLI+".ADOPAR"    [ADP]
Local File =APPLI+".ADOVAL"    [ADW]
#**Local File =APPLI+".TIMCOD"    [TIM]

adxifs = ","
adxirs = chr$(10)
NBLAN  = 1
LANGUE(1) = GLANGUE
# SBA FQ92041 - US1927
# ajout de la sélection du fichier
#Openo [M:DIA]FICHIER , 0
Local Char FICPATCH(GDIMFIC),URL(10)
If [M:DIA]TYPEXP=1 : # Client
 Call SET_FICNAM([M:DIA]FICHIER,[L]FICPATCH,URL) From ORDSYS
Else
 [L]FICPATCH = [M:DIA]FICHIER
Endif

Openo [L]FICPATCH , 0
# SBA fin

# En-tête fichier
CHAINE = ""
CHAINE2 = ""
For I=0 To [M:DIA]NBACT-1
 #51893
 #If I>1 : CHAINE += "/" : Endif
 #CHAINE += [M:DIA]ACTIV(I)
 If I>1 : CHAINE2 += "/" : Endif
 CHAINE2 += [M:DIA]ACTIV(I)
 # fin 51893
Next I

Wrseq '1';'"'+[M:DIA]TRAIT+'"';'"'+[M:DIA]LEG+'"';'"'+CHAINE+'"';'"50"';'"'+CHAINE2+'"'

# Commentaires

Setlob CLOB With [M:DIA]CMT
NBCLO = find("",CLOB)-1
Wrseq '2';'"CMT"';num$(NBCLO)
For I=1 To NBCLO
 Putseq len(CLOB(I)),CLOB(I)
Next I
Wrseq
Wrseq '7';'"CMT"'

# Traitement

If [M:DIA]TRAIT<>""
 If filinfo(filpath("TRT",[M:DIA]TRAIT,"src",APPLI),0)>=0
  Wrseq 2;'"TRT"';'"'+[M:DIA]TRAIT+'"'
  Openi filpath("TRT",[M:DIA]TRAIT,"src",APPLI)
  SAVIFS = adxifs
  SAVIRS = adxirs
  SAVIUM = adxium
  adxifs = ""
  adxirs = chr$(10)
  adxium = GUTF8
  Rdseq CHAINE
  While fstat=0
   Wrseq CHAINE
   Rdseq CHAINE
  Wend
  Wrseq string$(10,"*")
  Openi
  adxifs = SAVIFS
  adxirs = SAVIRS
  adxium = SAVIUM
  Wrseq 7;'"TRT"'
 Endif
Endif

# Boucle sur objet

For I=0 To [M:DIA]NBOBJ-1

# En-tête objet

 Wrseq '2';'"'+[M:DIA]TYPOBJ(I)+'"';'"'+[M:DIA]NOMOBJ(I)+'"';'"'+[M:DIA]RUB1(I)+'"';'"'+[M:DIA]RUB2(I)+'"'

 Case [M:DIA]TYPOBJ(I)
  When "RUB"   : Gosub RUBRIQUE
  When "VRA"   : Gosub VARIA
  When "CUM"   : Gosub CUMUL
  When "VLA"   : Gosub VALEUR
  When "EXO"   : Gosub EXO
  When "DCH"   : Gosub CHARGES
  When "FTD"   : Gosub TDS
  When "ADV"   : Gosub TABDIV
  When "ADP"   : Gosub PARAM
  #**When "TIM"   : Gosub TEMPS
 Endcase

# Fin objet

 Wrseq '7';'"'+[M:DIA]TYPOBJ(I)+'"';'"'+[M:DIA]NOMOBJ(I)+'"'

Next I

# Fin fichier

Wrseq '8';'"'+[M:DIA]TRAIT+'"';'"'+[M:DIA]LEG+'"'

Openo

# SBA FQ92041 - US1927
# si poste client, on copie sur le client
If [M:DIA]TYPEXP=1
 Local Integer STAT
 Local Char FICCLI(GDIMFIC)
 [L]FICCLI=[M:DIA]FICHIER+func TOOLSHRLEG.GET_DEFNAMFIL("pay")
 Call COPCLI([L]FICPATCH,[L]FICCLI,STAT) From ORDSYS
Endif
#fin SBA

Return

$RUBRIQUE
Read [RUB]RUB0 = GCURLEG;[M:DIA]NOMOBJ(I)
If fstat : Return : Endif
FICHIER = "RUBRIQUE" : ABR = "RUB" : IDENT = [F:RUB]COD : Gosub FICHIER
For [PRF]PRF0 Where [F:PRF]LEG = GCURLEG
 Read [CRB]CRB0 = [F:RUB]COD;[F:PRF]PRFCOD;GCURLEG
 If fstat
  Wrseq 3;'"CRB"';'"'+[F:PRF]PRFCOD+'"';"0"
 Else
  Wrseq 3;'"CRB"';'"'+[F:PRF]PRFCOD+'"';"1"
 Endif
Next
Return

$VARIA
Read [VRA]VRA0 = GCURLEG;[M:DIA]NOMOBJ(I)
If fstat : Return : Endif
FICHIER = "VARIA" : ABR = "VRA" : IDENT = [F:VRA]COD : Gosub FICHIER
Return

$CUMUL
Read [CUM]CUM0 = GCURLEG;[M:DIA]NOMOBJ(I)
If fstat : Return : Endif
FICHIER = "CUMUL" : ABR = "CUM" : IDENT = [F:CUM]CUMCOD : Gosub FICHIER
Return

$VALEUR
Filter [VLA] Where TYP=1 & LEG=GCURLEG & CPY="" & FCY="" & EMP="" & VARCOD=[M:DIA]NOMOBJ(I)
& Order By Key CLE=TYP;CPY;FCY;EMP;VARCOD;DAT
Read [VLA]CLE Last
If fstat<=2
 FICHIER = "VALEUR" : ABR = "VLA" : IDENT = [F:VLA]VARCOD : Gosub FICHIER
Endif
Filter [VLA]
Return

$EXO
For [EXO]EXO0 Where COD=[M:DIA]NOMOBJ(I) & LEG= GCURLEG
 FICHIER = "EXOPAY" : ABR = "EXO" : IDENT = [F:EXO]COD : Gosub FICHIER
Next
Return

$CHARGES
Read [DCH]DCH0 = [M:DIA]NOMOBJ(I)
If fstat : Return : Endif
FICHIER = "DECCHARGE" : ABR = "DCH" : IDENT = [F:DCH]CODDCC : Gosub FICHIER
Return

$TDS
#JOJAC - 2016-03-22 - REQ114309 US79 - START
#Local Char YEAFTD (4)
#Call PARAM("","DADYEA",YEAFTD) From ADOVAL
#Read [FTD]FTD0 = [L]YEAFLD;[M:DIA]NOMOBJ(I)
#If fstat : Return : Endif
#FICHIER = "HRFILTDS" : ABR = "FTD" : IDENT = [F:FTD]YEA-[F:FTD]NUMREC : Gosub FICHIER
#JOJAC - 2016-03-22 - REQ114309 US79 - END
Return

$TABDIV
Read [ADV]CODE = val([M:DIA]NOMOBJ(I))
If fstat : Return : Endif
FICHIER = "ATABTAB" : ABR = "ADV" : IDENT = num$([F:ADV]NUMTAB) : Gosub FICHIER
For [ADI]CODE Where NUMTAB=val([M:DIA]NOMOBJ(I)) & (LEG="" | LEG=GCURLEG)
 FICHIER = "ATABDIV" : ABR = "ADI" : IDENT = num$([F:ADI]NUMTAB)-[F:ADI]CODE : Gosub FICHIER
Next
Return

$PARAM
Read [ADP]ADP1 = [M:DIA]NOMOBJ(I)
If fstat : Return : Endif
FICHIER = "ADOPAR" : ABR = "ADP" : IDENT = [F:ADP]PARAM : Gosub FICHIER
For [ADW]ADW1 Where PARAM=[M:DIA]NOMOBJ(I) & CMP="" & FCY=""
 FICHIER = "ADOVAL" : ABR = "ADW" : IDENT = [F:ADW]PARAM : Gosub FICHIER
Next
Return

$TEMPS
#**Read [TIM]TIM0 = [M:DIA]NOMOBJ(I)
#**If fstat : Return : Endif
#**FICHIER = "TIMCOD" : ABR = "TIM" : IDENT = [F:TIM]COD : Gosub FICHIER
Return

$FICHIER
Wrseq '3';'"'+ABR+'"';IDENT
NBZONE = evalue("clanbs([F:"+ABR+"],1)")
For Z=1 To NBZONE
 VARIA = evalue("clavar([F:"+ABR+"],"+num$(Z)+")")
 TYP   = evalue("type([F:"+ABR+"]"+VARIA+")")
 IND   = evalue("dim([F:"+ABR+"]"+VARIA+")")
#JOJAC - 2016-03-22 - REQ114309 US79 - START
  #FQ103512
  Case TYP
   When 525 : # AUUID :  Uuident non exporté - FQ103512
   When Default
#JOJAC - 2016-03-22 - REQ114309 US79 - END
    Read [ZATZ]CODZONE = FICHIER;VARIA
    Case [F:ZATZ]CODTYP
      When "ATX"   : Gosub EXPTXT
      When Default : Gosub EXPZON
    Endcase
#JOJAC - 2016-03-22 - REQ114309 US79 - START
  Endcase
#JOJAC - 2016-03-22 - REQ114309 US79 - END
Next Z
Case FICHIER
 When "ATABTAB"
  VARIA = "LNGDES"  : IDENT1 = num$([F:ADV]NUMTAB) : IDENT2 = "" : Gosub EXPTRA
  VARIA = "SHODES"  : IDENT1 = num$([F:ADV]NUMTAB) : IDENT2 = "" : Gosub EXPTRA
  VARIA = "ALPDES1" : IDENT1 = num$([F:ADV]NUMTAB) : IDENT2 = "" : Gosub EXPTRA
  VARIA = "ALPDES2" : IDENT1 = num$([F:ADV]NUMTAB) : IDENT2 = "" : Gosub EXPTRA
  VARIA = "NUMDES1" : IDENT1 = num$([F:ADV]NUMTAB) : IDENT2 = "" : Gosub EXPTRA
  VARIA = "NUMDES2" : IDENT1 = num$([F:ADV]NUMTAB) : IDENT2 = "" : Gosub EXPTRA
 When "ATABDIV"
  VARIA = "LNGDES"  : IDENT1 = num$([F:ADI]NUMTAB) : IDENT2 = [F:ADI]CODE : Gosub EXPTRA
  VARIA = "SHODES"  : IDENT1 = num$([F:ADI]NUMTAB) : IDENT2 = [F:ADI]CODE : Gosub EXPTRA
#JASMI - 2017-02-15 - START
  When "RUBRIQUE"
    VARIA = "DES"     : IDENT1 = GCURLEG : IDENT2 = [F:RUB]COD : Gosub EXPTRA
    VARIA = "DESSHO"  : IDENT1 = GCURLEG : IDENT2 = [F:RUB]COD : Gosub EXPTRA
  When "VARIA"
    VARIA = "DES"     : IDENT1 = GCURLEG : IDENT2 = [F:VRA]COD : Gosub EXPTRA
    VARIA = "DESSHO"  : IDENT1 = GCURLEG : IDENT2 = [F:VRA]COD : Gosub EXPTRA
  When "CUMUL"
    VARIA = "CUMDES"  : IDENT1 = GCURLEG : IDENT2 = [F:CUM]CUMCOD : Gosub EXPTRA
    VARIA = "CUMSHO"  : IDENT1 = GCURLEG : IDENT2 = [F:CUM]CUMCOD : Gosub EXPTRA
  When "PROFIL"
    VARIA = "PRFDES"  : IDENT1 = GCURLEG : IDENT2 = [F:PRF]PRFCOD : Gosub EXPTRA
    VARIA = "PRFSHO"  : IDENT1 = GCURLEG : IDENT2 = [F:PRF]PRFCOD : Gosub EXPTRA
#JASMI - 2017-02-15 - END
Endcase
Wrseq '6';'"'+ABR+'"'
Return

### Export zone normale

$EXPZON
For J=1 To IND
 Wrseq '4';'"'+VARIA+'"';num$(J-1);
 Case TYP
  When 1,2,4,5,6,7,8,9
   Wrseq num$(evalue("[F:"+ABR+"]"+VARIA+"("+num$(J-1)+")"))
  When 3
   Wrseq evalue("[F:"+ABR+"]"+VARIA+"("+num$(J-1)+")")
  When Default
   Wrseq '"'+ctrans(num$(evalue("[F:"+ABR+"]"+VARIA+"("+num$(J-1)+")")),",",chr$(255))+'"'
 Endcase
Next J
Return

### Export zone dico

$EXPTXT
For J=1 To IND
 For K=1 To NBLAN
  NUMERO = evalue("[F:"+ABR+"]"+VARIA+"("+num$(J-1)+")")
  Read [ZATX]NUMERO = LANGUE(K);NUMERO
  If fstat : Raz [F:ZATX] : Endif
  Wrseq '5';'"'+VARIA+'"';num$(J-1);'"'+[F:ZATX]TEXTE+'"';'"'+LANGUE(K)+'"';num$(NUMERO)
 Next K
 Wrseq '5';'"'+VARIA+'"';num$(J-1);'""';'"***"'
Next J
Return

### Export texte traduisible

$EXPTRA
For J=1 To IND
 For K=1 To NBLAN
  Read [ZAXX]AXX0 = FICHIER;VARIA;LANGUE(K);IDENT1;IDENT2
  If !fstat
   Wrseq '9';'"'+VARIA+'"';num$(J-1);'"'+[F:ZAXX]TEXTE+'"';'"'+LANGUE(K)+'"';'"'+IDENT1+'"';'"'+IDENT2+'"'
  Endif
 Next K
 Wrseq '9';'"'+VARIA+'"';num$(J-1);'""';'"***"'
Next J
Return

########################################
Subprog C_FICHIER(NOMFIC)
Variable Char    NOMFIC()
# FQ92896-US2255-Convergence
#Call CTRL_FICHIER(NOMFIC)
End

Subprog CTRL_FICHIER(NOMFIC)
Variable Char    NOMFIC()
#end FQ92896-US2255-Convergence
If NOMFIC="" : mkstat=1 : End : Endif
Local Integer ER
Local Char    REPERT(GDIMFIC) , FICHIER(GDIMFIC)
Local Char    MACHINE(30) , OS(10)
# sba : déplacé pour pour éviter d'avoir /.pay
#If !instr(1,NOMFIC,".")
# NOMFIC += ".pay"
#Endif
Call MACHINE(NOMFIC,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
 mkstat = 2 : End
Elsif OS="unix"
 If pat(left$(REPERT,3),"!:\")
  GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
  mkstat = 2 : End
 Elsif left$(REPERT,1)="\"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  mkstat = 2 : End
 Endif
Else
 If left$(REPERT,1)="/"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  mkstat = 2 : End
 Endif
Endif
Raz ER

Call EXISTE(NOMFIC,ER) From ORDSYS
Case ER
 When 2 : # répertoire
  GMESSAGE = mess(55,141,1) : # Ce fichier est un répertoire
  mkstat = 2 : End
 When 0 : # fichier
  Call REPERT(NOMFIC,REPERT,FICHIER,OS) From SUBEXPOBJ
  Call EXISTE(REPERT,ER) From ORDSYS
  If ER<>2
     #GMESSAGE = "|"+REPERT-"|:"-mess(9,141,1) : # Répertoire inexistant
     #mkstat=2 : End
     Onerrgo ERRACSCLI
     Openi NOMFIC Using [ATST]
     Openi Using [ATST]
     Onerrgo
     If ER=0 or ER=27
      GMESSAGE = mess(147,141,1) : #Répertoire inaccessible
     Else
      GMESSAGE = mess(9,141,1) : # Répertoire inexistant
     Endif
     mkstat = 2 : End
    Endif
 Endcase
 If !instr(1,NOMFIC,".")
 NOMFIC += ".pay"
Endif
End

$ERRACSCLI
ER = errn
Resume

Subprog AM_FICHIER(NOMFIC)
Variable Char NOMFIC()
# FQ92896-US2255-Convergence
#If filinfo(NOMFIC,0)>=0
# Local Integer OK
# Call OUINON(mess(47,115,1),OK) From GESECRAN
# If OK=2 : Gosub CHARGE : Endif
#Endif
#end FQ92896-US2255-Convergence
End

Subprog C_TRAIT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & filinfo(filpath("TRT",VALEUR,"src",[M:DIA]DOSSIER),0)<0
 GMESSAGE = mess(101,100,1) : # Fichier inexistant
 mkstat = 2 : End
Endif
End

$CHARGE
## Préchargement des objets du fichier
Call TEMPON("L") From GESECRAN
Local Integer TYPENR , NB , NOCT , NBLIG , I
Local Libelle BUFFER(1..1000)
Local Char    CHAINE(80)
Local Char    CHAMP(250)(1..50)
Local Char    LIGNE(64)(1..500)
[M]NBOBJ = 0
Raz [M]CMT,TRAIT
Raz CHAMP, TYPENR
adxifs = ","
adxirs = chr$(10)
Openi [L]FICPATCH , 0 : #Openi NOMFIC , 0 :# FQ92896-US2255-Convergence
Rdseq TYPENR,CHAMP
While fstat=0 & TYPENR<>8
 If [M]NBOBJ>=dim([M]NOMOBJ)
  Call ERREUR(mess(26,100,1)) From GESECRAN # Tableau plein
  Break
 Endif
 Call DELIMITE(CHAMP) From PATCH
 If TYPENR=1: [M:DIA]LEG=CHAMP(2): GCURLEG=CHAMP(2) Endif :#84947
 If TYPENR=2
  Case CHAMP(1)
   When "TRT","ADX","ETA"
    Repeat
     Rdseq CHAMP(1)
    Until fstat or CHAMP(1)=string$(10,"*")
    [M:DIA]TRAIT = CHAMP(2)
   When "CMT"
    NBLIG = val(CHAMP(2))
    For I=1 To NBLIG
     Getseq 64,LIGNE(I)
    Next I
    Rdseq CHAINE
    Setlob [M:DIA]CMT With LIGNE(1..NBLIG)
   When Default
    [M]TYPOBJ([M]NBOBJ) = CHAMP(1)
    [M]NOMOBJ([M]NBOBJ) = CHAMP(2)
    #84947
    [M]TYPNOMOBJ([M]NBOBJ)=[M]TYPOBJ([M]NBOBJ)+"|"+ [M]NOMOBJ([M]NBOBJ)
    [M]RUB1([M]NBOBJ)   = CHAMP(3)
    [M]RUB2([M]NBOBJ)   = CHAMP(4)
    [M]NBOBJ += 1
  Endcase
 Endif
 Raz CHAMP, TYPENR
 Rdseq TYPENR,CHAMP
Wend
Affzo
Call TEMPOFF From GESECRAN
Return

Subprog C_TYPOBJ(VALEUR)
Variable Char    VALEUR()
Local Char ZONE (50):#84947
Gosub SET_TYP
If !find(VALEUR,TEX(1..NBTEX))
 Local File = [M]DOSSIER+".ATABLE" [ATB]
 Read [ATB]ABRFIC = VALEUR
 If fstat
  GMESSAGE = mess(42,115,1) : mkstat = 2 : End : # Type d'objet incorrect
 Endif
Endif
#84947
ZONE=VALEUR+"|"+[M]NOMOBJ(nolign-1)
Call UNICITE(ZONE,[M]TYPNOMOBJ(0..[M]NBOBJ-1)) From OBJDIV
If mkstat=2 : End : Endif
#
End

$SET_TYP
Local Integer NBTEX
Local Char    TEX(3)(40) , TEXTE(50)(40)

$REMP_TYP
NBTEX = 0
NBTEX += 1 : TEX(NBTEX) = "RUB" : TEXTE(NBTEX) = TEX(NBTEX)-mess(55,10702,1)  : # Rubrique
NBTEX += 1 : TEX(NBTEX) = "VRA" : TEXTE(NBTEX) = TEX(NBTEX)-mess(118,10702,1) : # Variable
NBTEX += 1 : TEX(NBTEX) = "CUM" : TEXTE(NBTEX) = TEX(NBTEX)-mess(82,10702,1)  : # Cumul
NBTEX += 1 : TEX(NBTEX) = "VLA" : TEXTE(NBTEX) = TEX(NBTEX)-mess(145,10702,1) : # Valeur
NBTEX += 1 : TEX(NBTEX) = "EXO" : TEXTE(NBTEX) = TEX(NBTEX)-mess(88,10702,1)  : # Exonération
NBTEX += 1 : TEX(NBTEX) = "DCH" : TEXTE(NBTEX) = TEX(NBTEX)-mess(124,10702,1) : # Charges
If GCURLEG='FRA'
 NBTEX += 1 : TEX(NBTEX) = "FTD" : TEXTE(NBTEX) = TEX(NBTEX)-mess(125,10702,1) : # DADSU
Endif
NBTEX += 1 : TEX(NBTEX) = "ADV" : TEXTE(NBTEX) = TEX(NBTEX)-mess(126,10702,1) : # Table diverse
NBTEX += 1 : TEX(NBTEX) = "ADP" : TEXTE(NBTEX) = TEX(NBTEX)-mess(127,10702,1) : # Paramètre
#** NBTEX += 1 : TEX(NBTEX) = "TIM" : TEXTE(NBTEX) = TEX(NBTEX)-mess(128,10702,1) : # Evénement
Return

Subprog C_NOMOBJ(VALEUR)
Variable Char    VALEUR()
Local    Char    FIC(20)
#84947
Local Char ZONE (50)
ZONE=[M]TYPOBJ(nolign-1)+"|"+toupper(VALEUR)
Call UNICITE(ZONE,[M]TYPNOMOBJ(0..[M]NBOBJ-1)) From OBJDIV
If mkstat=2 : End : Endif
#

VALEUR = vireblc(format$("K:80g",VALEUR),2)
Case [M]TYPOBJ(nolign-1)
 When "RUB"
  Local File =[M]DOSSIER+".RUBRIQUE" [RUB]
#JOJAC - 2016-03-22 - REQ114309 US79 - START
  Call CONTRUB(VALEUR) From SUBRUB
#JOJAC - 2016-03-22 - REQ114309 US79 - END
  Call CONTROLE("RUB","",VALEUR,GCURLEG,mkstat) From CONTOBJ
 When "VRA","VLA"
  Local File =[M]DOSSIER+".VARIA" [VRA]
  Call CONTROLE("VRA","",VALEUR,GCURLEG,mkstat) From CONTOBJ
 When "CUM"
  Local File =[M]DOSSIER+".CUMUL" [CUM]
  Call CONTROLE("CUM","",VALEUR,GCURLEG,mkstat) From CONTOBJ
 When "EXO"
  Local File =[M]DOSSIER+".EXOPAY" [EXO]
  Call CONTROLE("EXO","",VALEUR,GCURLEG,mkstat) From CONTOBJ
 When "DCH"
  Local File =[M]DOSSIER+".DECCHARGE" [DCH]
  Call CONTROLE("DCH","",VALEUR,"",mkstat) From CONTOBJ
#JOJAC - 2016-03-22 - REQ114309 US79 - START
#  When "FTD"
#  Local File =[M]DOSSIER+".HRFILTDS" [FTD]
#  Call CONTROLE("FTD","",VALEUR,"",mkstat) From CONTOBJ
#JOJAC - 2016-03-22 - REQ114309 US79 - END
 When "ADV"
  Local File =[M]DOSSIER+".ATABTAB" [ADV]
  Call CONTROLE("ADV","",VALEUR,"",mkstat) From CONTOBJ
 When "ADP"
  Local File =[M]DOSSIER+".ADOPAR" [ADP]
  Read [ADP]ADP1 = VALEUR
  If fstat
   GERR = 1 : GMESSAGE = mess(11,133,1) : # Paramètre inexistant
   mkstat = 2
  Endif
#** When "TIM"
#**  Local File =[M]DOSSIER+".TIMCOD" [TIM]
#**  Call CONTROLE("TIM","",VALEUR,"",mkstat) From CONTOBJ
Endcase
End

Subprog AS_RUB1(VALEUR)
Variable Char    VALEUR()
If [M]TYPOBJ(nolign-1)<>"RUB" : mkstat = 2 : End : Endif
End

Subprog AS_RUB2(VALEUR)
Variable Char    VALEUR()
If [M]TYPOBJ(nolign-1)<>"RUB" : mkstat = 2 : End : Endif
End

$SEL_TABLE
#JOJAC - 2016-03-22 - REQ114309 US79 - START
#Local Char SAVACT(20)
#JOJAC - 2016-03-22 - REQ114309 US79 - END
Case GACTION
 When "SELPATCHP"
  Case [M]TYPOBJ(nolign-1)
   When "RUB" : OBJET = "RUB"
   When "VRA", "VLA"  : OBJET = "VRA"
   When "CUM" : OBJET = "CUM"
   When "EXO" : OBJET = "EXO"
   When "DCH" : OBJET = "DCH"
#JOJAC - 2016-03-22 - REQ114309 US79 - START
#   When "FTD" : OBJET = "FTD"
#JOJAC - 2016-03-22 - REQ114309 US79 - END
   When "ADV" : OBJET = "ADV"
   When "ADP" : OBJET = "ADP"
#**   When "TIM" : OBJET = "TIM"
  Endcase
Endcase
Return

$SEL_LISTE
Case GACTION
 When "SELPATCHO"
  Gosub REMP_TYP
Endcase
Return

