#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################################
# Subprograms for use by Salesforce CRM web services
####################################################################################################

$CALLBUNDLE

  Local Clbfile RESHEAD

  # Make call to BPC web service via Syracuse bundle
  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERRMSG)
  If ERRMSG <> ""
    OK = fmet MYLOG.APUTLINE(ERRMSG, OK) : OK = fmet MYLOG.AFLUSHLOG
  Endif

  #-------------------------------------------------------------------------------------------------#
  # Unremark below lines to log contents of response
#  Local Char     CLOBNAME(30)
#  Local Clbfile  CLOBDATA(4)
#  OK = fmet MYLOG.APUTLINE("Debug RESHEAD = "+RESHEAD,OK) : OK=fmet MYLOG.AFLUSHLOG
#  CLOBNAME = "Debug RESBODY" : CLOBDATA = RESBODY : Gosub LOGCLOB
  #-------------------------------------------------------------------------------------------------#

Return

####################################################################################################

Subprog SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERRMSG)
  Value    Char    FUNCTION
  Value    Clbfile ARGUMENTS
  Variable Clbfile RESHEAD
  Variable Clbfile RESBODY
  Variable Char    ERRMSG

  Local Integer  STATUSCODE
  Local Char     MODULE(100)   : MODULE = 'bundles/salesforce-crm'
  Local Char     MODE(10)      : MODE   = 'wait'
  Local Char     ENCODINGS(40)
  Local Integer  CALLBACKINDEX
  Local Char     RETURNS(50)
  Local Char     RETURNS_ENC(3)

  GFUSION = 1

  Onerrgo CONTINUESUB
  STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE,FUNCTION,MODE,ARGUMENTS,ENCODINGS,CALLBACKINDEX,RETURNS,RETURNS_ENC,RESHEAD,RESBODY)
  Onerrgo

  $CONTINUESUB
  If STATUSCODE<>200
    If RESHEAD = ""
      ERRMSG = "X33000107"+":"-FUNCTION+","-func AFNC.TEXTE(141)+":"-num$(STATUSCODE)    # Error message
    Else
      ERRMSG = func BUILDERRORMESSAGE("X33000108", mess(9028,7719,1), RESHEAD, "RESHEAD")
    Endif
  Endif

  RESHEAD=unescJson(RESHEAD)
  RESBODY=unescJson(RESBODY)

End

####################################################################################################

$LOGCLOB

  Local Integer LOOP
  Local Integer CHARPOS
  Local Integer ENDELEMENT
  Local Char ELEMENT(255)
  Local Integer TABCOUNT

  OK=fmet MYLOG.APUTLINE(CLOBNAME - "=",OK)

  # Replace \" with "
  For LOOP = 1 To len(CLOBDATA)
    CHARPOS = instr(1, CLOBDATA, '\"')
    If CHARPOS
      CLOBDATA = left$(CLOBDATA, CHARPOS-1) + '"' + right$(CLOBDATA, CHARPOS + 2)
    Endif
  Next LOOP

  # Log arguments
  CHARPOS = instr(1, CLOBDATA, '<')
  If CHARPOS
    OK=fmet MYLOG.APUTLINE(mid$(CLOBDATA,1,CHARPOS-1), OK)
    CLOBDATA = right$(CLOBDATA, CHARPOS)

    # Add line returns
    For LOOP = 1 To len(CLOBDATA)
      CHARPOS = instr(1, CLOBDATA, '><')
      If CHARPOS
        CLOBDATA = left$(CLOBDATA, CHARPOS-1) + '>' + chr$(10) + '<' + right$(CLOBDATA, CHARPOS + 2)
      Endif
    Next LOOP

    # Log each element
    CHARPOS  = 1
    TABCOUNT = 0
    While CHARPOS
      ENDELEMENT = instr(CHARPOS, CLOBDATA, chr$(10)) : If !ENDELEMENT : Break : Endif
      ELEMENT =  mid$(CLOBDATA,CHARPOS,ENDELEMENT-CHARPOS)
      OK=fmet MYLOG.APUTLINE(string$(TABCOUNT,9)+ELEMENT, OK)
      Case left$(ELEMENT, 5)
        When "<PARA", "<GRP ", "<TAB ", "<LIN ", "<LST " : TABCOUNT += 1
        When "</PAR", "</GRP", "</TAB", "</LIN", "</LST" : TABCOUNT -= 1
      Endcase
      CHARPOS = ENDELEMENT + 1
    Wend
  Else
    For LOOP = 1 To len(CLOBDATA) Step 250
      OK=fmet MYLOG.APUTLINE(mid$(CLOBDATA, LOOP, LOOP+250),OK)
    Next LOOP
  Endif

  OK=fmet MYLOG.AFLUSHLOG

Return

####################################################################################################

$LOADRESPONSES

  Local Integer LOOP
  Local Integer MESSAGECOUNT

  Call GETRESPONSEMESSAGES(RESBODY, RESPONSEMESSAGES)

  For LOOP = 1 To 50
    MESSAGECOUNT += RESPONSEMESSAGES(LOOP)<>""
  Next LOOP

  If MESSAGECOUNT = 2
    RESPONSEMESSAGES(1)  = func IMPROVEMESSAGE(RESPONSEMESSAGES(1), WEBSERVICELANGUAGE)
    RESPONSEMESSAGES(1) += ","-func IMPROVEMESSAGE(RESPONSEMESSAGES(2), WEBSERVICELANGUAGE)
    RESPONSEMESSAGES(2)  = ""
    OK = fmet MYLOG.APUTLINE(RESPONSEMESSAGES(1),OK) : OK = fmet MYLOG.AFLUSHLOG
  Else
    For LOOP = 1 To MESSAGECOUNT
      RESPONSEMESSAGES(LOOP) = func IMPROVEMESSAGE(RESPONSEMESSAGES(LOOP), WEBSERVICELANGUAGE)
      OK = fmet MYLOG.APUTLINE(RESPONSEMESSAGES(LOOP),OK) : OK = fmet MYLOG.AFLUSHLOG
    Next LOOP
  Endif

Return

####################################################################################################

Subprog GETRESPONSEMESSAGES(RESPONSE, MESSAGES)

  Value Clbfile RESPONSE
  Variable Char MESSAGES()(1..)

  Local Integer CURRPOS
  Local Integer LOOP

  CURRPOS   = instr(1, RESPONSE, '"messages"')
  If CURRPOS
    For LOOP = 1 To 50
      CURRPOS  = instr(CURRPOS, RESPONSE, '"message"') : If !CURRPOS : Break : Endif
      CURRPOS += 9 : # length of '"message"'
      CURRPOS  = instr(CURRPOS, RESPONSE, '"')         : If !CURRPOS : Break : Endif
      MESSAGES(LOOP) = mid$(RESPONSE, CURRPOS+1, instr(CURRPOS+1, RESPONSE, '"')-(CURRPOS+1))
    Next LOOP
  Endif

End

####################################################################################################

Funprog GETXMLVALUE(OBJECTXML, BLOCKID, LINENUMBER, FIELDNAME)

  Variable Clbfile OBJECTXML
  Value Char    BLOCKID
  Value Integer LINENUMBER
  Value Char    FIELDNAME

  Local Clbfile DATA
  Local Integer CURPOS
  Local Integer ISLIST

  CURPOS = instr(1, OBJECTXML, 'ID="' + BLOCKID + '"') : If !CURPOS : End "" : Endif
  If FIELDNAME="SIZE"
    CURPOS = instr(CURPOS, OBJECTXML, 'SIZE="')
    DATA = mid$(OBJECTXML, CURPOS + 6, instr(CURPOS + 6, OBJECTXML, '"') - (CURPOS + 6))
  Else
    If LINENUMBER
      CURPOS = instr(CURPOS, OBJECTXML, 'NUM="' + num$(LINENUMBER) + '"') : If !CURPOS : End "" : Endif
    Endif
    CURPOS = instr(CURPOS, OBJECTXML, 'NAME="' + FIELDNAME + '"') : If !CURPOS : End "" : Endif
    ISLIST = mid$(OBJECTXML, CURPOS - 5, 5)="<LST "
    CURPOS = instr(CURPOS, OBJECTXML, '>') : If !CURPOS : End "" : Endif
    If ISLIST
      DATA = mid$(OBJECTXML, CURPOS + 1, instr(CURPOS, OBJECTXML, '</LST>') - (CURPOS+4))
    Else
      If mid$(OBJECTXML, CURPOS-1, 1) = "/"
        DATA = ""
      Else
        DATA = mid$(OBJECTXML, CURPOS + 1, instr(CURPOS, OBJECTXML, '<') - (CURPOS+1))
      Endif
    Endif
  Endif

End DATA

####################################################################################################

Funprog GETRESPONSESTATUS(RESPONSE)

  Value Clbfile RESPONSE

  Local Char XMLSTATUS(2)
  Local Integer CURRPOS

  If RESPONSE = ""
    XMLSTATUS = "0"
  Else
    CURRPOS   = instr(1, RESPONSE, '"status"')       : If !CURRPOS : End 0 : Endif
    CURRPOS   = instr(CURRPOS, RESPONSE, '"$value"') : If !CURRPOS : End 0 : Endif
    CURRPOS  += 8 : # length of '"$value"'
    CURRPOS   = instr(CURRPOS, RESPONSE, '"')        : If !CURRPOS : End 0 : Endif
    XMLSTATUS = mid$(RESPONSE, CURRPOS+1, instr(CURRPOS+1, RESPONSE, '"')-(CURRPOS+1))
  Endif

End int(val(XMLSTATUS))

####################################################################################################

Funprog GETLABEL(SCREENNAME, FIELDNAME)

  Value Char SCREENNAME
  Value Char FIELDNAME

  Local Char    LABEL(80)
  Local Integer TEXTE

  # If no field name then return screen name
  Case SCREENNAME
    When "BPABPC"
      Case FIELDNAME
        When "CODADR"  : TEXTE = 1509
        When "ADDLIG"  : LABEL = func AFNC.TEXTE(1499)
        When "ADDLIG1" : LABEL = func AFNC.TEXTE(1499)-"1"
        When "ADDLIG2" : LABEL = func AFNC.TEXTE(1499)-"2"
        When "ADDLIG3" : LABEL = func AFNC.TEXTE(1499)-"3"
        When "CTY"     : TEXTE = 251
        When "SAT"     : TEXTE = 12700
        When "POSCOD"  : TEXTE = 210
        When "BPACRY"  : TEXTE = 263
        When ""        : TEXTE = 1502
      Endcase
    When "BPC0"
      Case FIELDNAME
        When "BCGCOD" : TEXTE = 707
        When "BPCSTA" : TEXTE = 188
        When "BPCNUM" : TEXTE = 3662
        When ""       : TEXTE = 1503
      Endcase
    When "BPC2"
      Case FIELDNAME
        When "OSTCTL"  : TEXTE = 5234
        When "XOST"    : TEXTE = 5382
        When "WOSTAUZ" : TEXTE = 1680
      Endcase
    When "BPC3"
      Case FIELDNAME
        When "BPCINV" : TEXTE = 1647
        When "BPAINV" : LABEL = mess(9029,7719,1)
        When "BPCRSK" : TEXTE = 26784
        When "BPCPYR" : TEXTE = 1649
        When "BPAPYR" : LABEL = mess(9030,7719,1)
        When "ACCCOD" : TEXTE = 1687
        When "VACBPR" : TEXTE = 3673
        When "PTE"    : TEXTE = 3624
        When "BPCGRU" : TEXTE = 1651
        When ""       : TEXTE = 1503
      Endcase
    When "BPC4"
      Case FIELDNAME
        When "BPDADD" : LABEL = mess(285,183,1)
      Endcase
    When "BPRBPC"
      Case FIELDNAME
        When "BPRNAM" : LABEL = mess(2,871,1)
        When "TEL1"   : TEXTE = 289
        When "TEL2"   : TEXTE = 919
        When "FCYWEB" : TEXTE = 38620
        When "NAF"    : TEXTE = 3791
        When "CRY"    : TEXTE = 263
        When "CRN"    : TEXTE = 1424
        When "LAN"    : TEXTE = 1505
        When "CUR"    : TEXTE = 323
        When ""       : TEXTE = 1503
      Endcase
    When "CNTBPC"
      Case FIELDNAME
        When "CCNCRM" : TEXTE = 15175
        When "CNTFNA" : TEXTE = 1825
        When "CNTLNA" : TEXTE = 55
        When "CNTTEL" : TEXTE = 289
        When "CNTFAX" : TEXTE = 919
        When "CNTWEB" : TEXTE = 1828
        When "CNTADD" : TEXTE = 1509
        When ""       : TEXTE = 3527
      Endcase
    When "SOH0"
      Case FIELDNAME
        When "SOHNUM"    : TEXTE = 2212    # 171
        When "ORDDAT"    : TEXTE = 2566    # 212
        When "SOHTYP"    : TEXTE = 2562    # 680
        When "SALFCY"    : TEXTE = 5060
        When "CUSORDREF" : TEXTE = 36232   # 1371
        When "BPCORD"    : TEXTE = 2951
      Endcase
    When "SOH1"
      Case FIELDNAME
        When "ORDSTA" : TEXTE = 4549
      Endcase
  Endcase

  If TEXTE
    LABEL = func AFNC.TEXTE(TEXTE)
  Endif

End LABEL

####################################################################################################

Funprog BUILDERRORMESSAGE(ERRORCODE, ERRORMSG, FIELDVALUE, FIELDNAME)

  Value Char ERRORCODE
  Value Char ERRORMSG
  Value Char FIELDVALUE
  Value Char FIELDNAME

  Local Char MSG (255)
  Local Char ERRORCODELABEL(30) : ERRORCODELABEL = func AFNC.TEXTE(12861) + ":"   # Error code:
  Local Char ERRORMSGLABEL(30)  : ERRORMSGLABEL  = func AFNC.TEXTE(141)   + ":"   # Error message:
  Local Char VALUELABEL(30)     : VALUELABEL     = func AFNC.TEXTE(122)   + ":"   # Value:
  Local Char FIELDLABEL(30)     : FIELDLABEL     = func AFNC.TEXTE(663)   + ":"   # Field:

  MSG = ERRORCODELABEL - ERRORCODE + "," - ERRORMSGLABEL - ERRORMSG
  If FIELDVALUE <> ""
    MSG += "," - VALUELABEL - FIELDVALUE
  Endif
  If FIELDNAME <> ""
    MSG += "," - FIELDLABEL - FIELDNAME
  Endif

End MSG

####################################################################################################

Funprog GETPROVINCELABEL(COUNTRYCODE, LANGUAGE)

  Value Char COUNTRYCODE
  Value Char LANGUAGE

  Local Char LABEL(80)

  If clalev([F:AXX]) = 0 : Local File ATEXTRA [AXX] : Endif
  Read [F:AXX]AXX0="TABCOUNTRY";"ETATNAM";LANGUAGE;COUNTRYCODE;""
  If fstat
     ERRMSG = func BUILDERRORMESSAGE("X34000102", mess(23,100,1), COUNTRYCODE, func GETLABEL("BPABPC", "SAT"))
  Else
    LABEL = [F:AXX]TEXTE
  Endif

End LABEL

####################################################################################################

Funprog GETLISTVALUE(LIST, ITEMNUMBER)

  Value Clbfile LIST
  Value Integer ITEMNUMBER

  Local Char DATA(255)
  Local Integer CURPOS
  Local Integer CURITM

  CURPOS = 1

  While instr(CURPOS, LIST, "<ITM>")
    CURPOS = instr(CURPOS, LIST, '<ITM>')
    DATA = mid$(LIST, CURPOS + 5, instr(CURPOS, LIST, '</ITM>') - (CURPOS+5))
    CURPOS = instr(CURPOS, LIST, '</ITM>') + 6
    CURITM += 1
    If CURITM = ITEMNUMBER : Break : Endif
    DATA = ""
  Wend

End DATA

####################################################################################################

Funprog IMPROVEMESSAGE(MSGTEXT, LANGUAGE)

  Value Char MSGTEXT
  Value Char LANGUAGE

  Local Char BETTERMESSAGE(255)

  BETTERMESSAGE = MSGTEXT

  # Field error
  If instr(1, toupper(MSGTEXT), toupper(mess(32,126,1)))
    BETTERMESSAGE = right$(MSGTEXT, instr(1, toupper(MSGTEXT), toupper(mess(32,126,1)))+len(mess(32,126,1))+1)
  Endif

  # Customer fields
  If instr(1, MSGTEXT, "[M:BPC0]BCGCOD")  : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPC0]BCGCOD",  "BPC0",   "BCGCOD") : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPC0]BPCSTA")  : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPC0]BPCSTA",  "BPC0",   "BPCSTA") : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPC0]BPCNUM")  : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPC0]BPCNUM",  "BPC0",   "BPCNUM") : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPRC]BPRNAM")  : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPRC]BPRNAM",  "BPRBPC", "BPRNAM") : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPAC]XTEL1")   : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPAC]XTEL1",   "BPRBPC", "TEL1")   : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPAC]XTEL2")   : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPAC]XTEL2",   "BPRBPC", "TEL2")   : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPAC]XFCYWEB") : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPAC]XFCYWEB", "BPRBPC", "FCYWEB") : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPRC]CRY")     : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPRC]CRY",     "BPRBPC", "CRY")    : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPC3]BPAINV")  : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPC3]BPAINV",  "BPC3",   "BPAINV") : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPC3]BPAPYR")  : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPC3]BPAPYR",  "BPC3",   "BPAPYR") : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPC3]VACBPR")  : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPC3]VACBPR",  "BPC3",   "VACBPR") : End BETTERMESSAGE : Endif

  # Contact fields
  If instr(1, MSGTEXT, "[M:CNTC]KCCNCRM") : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:CNTC]KCCNCRM", "CNTBPC", "CCNCRM")  : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:CNTC]KCNTFNA") : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:CNTC]KCNTFNA", "CNTBPC", "CNTFNA")  : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:CNTC]KCNTLNA") : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:CNTC]KCNTLNA", "CNTBPC", "CNTLNA")  : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:CNTC]KCNTTEL") : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:CNTC]KCNTTEL", "CNTBPC", "CNTTEL")  : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:CNTC]KCNTFAX") : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:CNTC]KCNTFAX", "CNTBPC", "CNTFAX")  : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:CNTC]KCNTWEB") : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:CNTC]KCNTWEB", "CNTBPC", "CNTWEB")  : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:CNTC]KCNTADD") : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:CNTC]KCNTADD", "CNTBPC", "CNTADD")  : End BETTERMESSAGE : Endif

  # Address fields
  If instr(1, MSGTEXT, "[M:BPAC]CODADR")   : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPAC]CODADR",   "BPABPC", "CODADR")  : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPAC]XADDLIG1") : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPAC]XADDLIG1", "BPABPC", "ADDLIG1") : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPAC]XADDLIG2") : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPAC]XADDLIG2", "BPABPC", "ADDLIG2") : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPAC]XADDLIG3") : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPAC]XADDLIG3", "BPABPC", "ADDLIG3") : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPAC]XCTY")     : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPAC]XCTY",     "BPABPC", "CTY")     : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPAC]XSAT")     : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPAC]XSAT",     "BPABPC", "SAT")     : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPAC]XPOSCOD")  : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPAC]XPOSCOD",  "BPABPC", "POSCOD")  : End BETTERMESSAGE : Endif
  If instr(1, MSGTEXT, "[M:BPAC]XBPACRY")  : BETTERMESSAGE = func REPLACETEXT(MSGTEXT, "[M:BPAC]XBPACRY",  "BPABPC", "BPACRY")  : End BETTERMESSAGE : Endif

  # Typical errors
  Local Char ERRORCODELABEL(30) : ERRORCODELABEL = func AFNC.TEXTE(12861) + ":"
  Local Char ERRORMSGLABEL(30)  : ERRORMSGLABEL  = func AFNC.TEXTE(141)   + ":"
  Local Char VALUELABEL(30)     : VALUELABEL     = func AFNC.TEXTE(122)   + ":"
  Local Char BADVALUE(255)

  # Invalid length
  If instr(1, toupper(MSGTEXT), toupper(mess(111,123,1)))
    BETTERMESSAGE = ERRORCODELABEL - "X34000101," - ERRORMSGLABEL - MSGTEXT
    End BETTERMESSAGE
  Endif

  # Record does not exist
  If instr(1, toupper(MSGTEXT), toupper(mess(23,100,1)))
    If instr(1, MSGTEXT, ":")
      If instr(1, MSGTEXT, "\")
        BADVALUE = mid$(MSGTEXT, instr(1,MSGTEXT,":")+1, instr(1,MSGTEXT,"\")-instr(1,MSGTEXT,":")-1)
      Else
        BADVALUE = vireblc(left$(MSGTEXT, instr(1, MSGTEXT, ":")-1), 2)
      Endif
    Else
      BADVALUE = MSGTEXT
    Endif
    If toupper(vireblc(MSGTEXT,2)) = toupper(mess(23,100,1))
      BETTERMESSAGE = ERRORCODELABEL - "X34000102," - ERRORMSGLABEL - mess(23,100,1)
    Else
      BETTERMESSAGE = ERRORCODELABEL - "X34000102," - ERRORMSGLABEL - mess(23,100,1) + "," - VALUELABEL - BADVALUE
    Endif
    End BETTERMESSAGE
  Endif

End BETTERMESSAGE

####################################################################################################

Funprog REPLACETEXT(OLDMESSAGE, OLDTEXT, MASKNAME, FIELDNAME)

  Value Char    OLDMESSAGE
  Value Char    OLDTEXT
  Value Char    MASKNAME
  Value Char    FIELDNAME

  Local Char NEWSTRING(255)
  Local Char NEWTEXT(GLONATB+81)

  STARTPOS = instr(1, OLDMESSAGE, OLDTEXT)
  If STARTPOS
    ENDPOS = STARTPOS + len(OLDTEXT)
    NEWSTRING = func AFNC.TEXTE(663) + ":" - func GETLABEL(MASKNAME, "") + "." + func GETLABEL(MASKNAME, FIELDNAME)
  Endif

End NEWSTRING

####################################################################################################

Funprog GETNEXTCONTACTNUMBER(ERRMSG)

  Variable Char ERRMSG

  Local Char CONTACTNUM(GLONCNT)
  Local Integer ERR

  Call NUMERO("SFCCN", "", date$, "", CONTACTNUM, ERR) From SUBANM
  If ERR
    ERRMSG = func BUILDERRORMESSAGE("X34000104", mess(83,134,1), "", "SFCCN")
  Endif

End CONTACTNUM

####################################################################################################

Funprog GETDATEFORMAT(LANGUAGE)

  Value Char LANGUAGE

  Case LANGUAGE
    When "ENG"
      DATEFORMAT = "MM[/]DD[/]YY"
    When "ARB", "BRI", "SPA", "FRA", "ITA"
      DATEFORMAT = "DD[/]MM[/]YY"
    When "POR"
      DATEFORMAT = "DD[-]MM[-]YY"
    When "GER", "RUS"
      DATEFORMAT = "DD[.]MM[.]YY"
    When "CHN"
      DATEFORMAT = "YY[/]MM[/]DD"
    When "POL"
      DATEFORMAT = "YY[-]MM[-]DD"
  Endcase

End DATEFORMAT

####################################################################################################

Subprog FORMATADDRESS(COUNTRYCODE, ADDRESS1, ADDRESS2, ADDRESS3, CITY, PROVINCECODE, PROVINCENAME, POSTALCODE, COUNTRYNAME, ERRMSG)

  Variable Char COUNTRYCODE
  Variable Char ADDRESS1
  Variable Char ADDRESS2
  Variable Char ADDRESS3
  Variable Char CITY
  Variable Char PROVINCECODE
  Variable Char PROVINCENAME
  Variable Char POSTALCODE
  Variable Char COUNTRYNAME
  Variable Char ERRMSG

  # Get formats from country
  If clalev([F:TCY]) = 0 : Local File TABCOUNTRY [TCY] : Endif
  Read [F:TCY]TCY0=COUNTRYCODE
  If fstat
    ERRMSG = func CRMSF.BUILDERRORMESSAGE("X34000102", mess(23,100,1), COUNTRYCODE, func CRMSF.GETLABEL("BPABPC", "BPACRY"))
    End
  Endif

  # Country
  Call LECTEXTRA(COUNTRYNAME, "TABCOUNTRY", "CRYDES", COUNTRYCODE, "") From ATEXTRA

  # Address lines
  If [F:TCY]ADRCODFMT <> ""
    If ADDRESS1 <> "" : ADDRESS1 = format$("Kv2:"+[F:TCY]ADRCODFMT, ADDRESS1) : Endif
    If ADDRESS2 <> "" : ADDRESS2 = format$("Kv2:"+[F:TCY]ADRCODFMT, ADDRESS2) : Endif
    If ADDRESS3 <> "" : ADDRESS3 = format$("Kv2:"+[F:TCY]ADRCODFMT, ADDRESS3) : Endif
  Endif

  # Postal code
  If POSTALCODE <> "" &  [F:TCY]POSCODFMT <> ""
    POSTALCODE = format$("Kv2:"+[F:TCY]POSCODFMT, POSTALCODE)
  Endif

  # City
  If CITY <> "" & [F:TCY]CTYCODFMT<> ""
    CITY = format$("Kv2:"+[F:TCY]CTYCODFMT, CITY)
  Endif

  # Subdivision
  Call LECTEXTRA(PROVINCENAME, "TABSUBDIV", "INTIT", COUNTRYCODE+"~"+num$([F:TCY]ETAT), PROVINCECODE) From ATEXTRA
  If PROVINCENAME <> "" & [F:TCY]ETATFMT <> ""
    Call FMTSATPAY(COUNTRYCODE, "") From TRTDIV
    PROVINCENAME = format$("Kv2:"+GFMT, PROVINCENAME)
  Endif

End

####################################################################################################

Subprog PARSEADDRESS(ADDRESSLINE, ADDRESS1, ADDRESS2, ADDRESS3)

  Value    Char ADDRESSLINE
  Variable Char ADDRESS1
  Variable Char ADDRESS2
  Variable Char ADDRESS3

  Local Integer NEWLINE

  ADDRESS1 = ADDRESSLINE
  NEWLINE = instr(1, ADDRESS1, chr$(13))
  If NEWLINE
    ADDRESS1    = left$(ADDRESS1, NEWLINE-1)
    ADDRESSLINE = right$(ADDRESSLINE, NEWLINE+2)
  Else
    ADDRESSLINE = right$(ADDRESSLINE, len(ADDRESS1)+1)
  Endif

  ADDRESS2 = ADDRESSLINE
  NEWLINE = instr(1, ADDRESS2, chr$(13))
  If NEWLINE
    ADDRESS2    = left$(ADDRESS2, NEWLINE-1)
    ADDRESSLINE = right$(ADDRESSLINE, NEWLINE+2)
  Else
    ADDRESSLINE = right$(ADDRESSLINE, len(ADDRESS2)+1)
  Endif

  ADDRESS3 = ADDRESSLINE
  NEWLINE = instr(1, ADDRESS3, chr$(13))
  If NEWLINE
    ADDRESS3    = left$(ADDRESS3, NEWLINE-1)
    ADDRESSLINE = right$(ADDRESSLINE, NEWLINE+2)
  Else
    ADDRESSLINE = right$(ADDRESSLINE, len(ADDRESS3)+1)
  Endif

End

####################################################################################################

Subprog COMBINEADDRESSES(ADDRESS1, ADDRESS2, ADDRESS3, ADDRESSLINE)

  Value    Char ADDRESS1
  Value    Char ADDRESS2
  Value    Char ADDRESS3
  Variable Char ADDRESSLINE

  ADDRESSLINE = ADDRESS1
  If ADDRESS2 > "" : ADDRESSLINE += chr$(13) +chr$(10) + ADDRESS2 : Endif
  If ADDRESS3 > "" : ADDRESSLINE += chr$(13) +chr$(10) + ADDRESS3 : Endif

End

####################################################################################################

Funprog ESCAPECHARS(INPUTVAL, DIRECTION)

  Value Char INPUTVAL
  Value Char DIRECTION

  Local Char    OUTPUTVAL(255)
  Local Tinyint CHARCOUNT
  Local Integer CHARPOS
  Local Char CHARS(10)(5,2)

  If INPUTVAL <> ""

    If toupper(DIRECTION) = "IN"
      CHARCOUNT = 2
      CHARS(0,0) = '<' : CHARS(0,1) = '&lt;'
      CHARS(1,0) = '"' : CHARS(1,1) = '&quot;'
    Else  # Outbound
      CHARCOUNT = 5
      CHARS(0,0) = '&quot;' : CHARS(0,1) = '"'
      CHARS(1,0) = '&apos;' : CHARS(1,1) = "'"
      CHARS(2,0) = '&lt;'   : CHARS(2,1) = '<'
      CHARS(3,0) = '&gt;'   : CHARS(3,1) = '>'
      CHARS(4,0) = '&amp;'  : CHARS(4,1) = '&'
    Endif

    # Replace problem characters
    OUTPUTVAL = INPUTVAL
    For I = 0 To CHARCOUNT-1
      CHARPOS = instr(1, OUTPUTVAL, CHARS(I,0))
      While CHARPOS
        OUTPUTVAL = left$(OUTPUTVAL, CHARPOS-1) + CHARS(I,1) + right$(OUTPUTVAL, CHARPOS + len(CHARS(I,0)))
        CHARPOS = instr(1, OUTPUTVAL, CHARS(I,0))
      Wend
    Next I

  Endif

End OUTPUTVAL

####################################################################################################

