#<AdxTL>@(#)3.0.0.0 $Revision$ Consultation STL
# Attention ne pas transférer en version 120 (Ecrans modifiés)
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz [M:CSBP] : Transmask [M:SBP1] To [M:CSBP] # Issue 25606 [M:CSBP] = [M:SBP1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:STL1]) = 0 : Local File STOLOT     [STL1] : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:STO1]) = 0 : Local File STOCK      [STO1] : Endif
If clalev([F:ITF])   =0 : Local File ITMFACILIT [ITF]  : Endif

#
Local Char    WFIL(250)
Local Char    WFILS(250)
Local Char    WFILSPE(250)
Local Integer WNOLIGN, WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I, J, K
#
Local Char    WFIRFCY(GLONFCY)
Local Decimal WFIRCHR
#
#WNOLIGN = nolign
Gosub LOAD_SCREEN
#
NAVIG="CONSSBP"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SBP1]FLG = 0
[M:SBP1] = [M:CSBP]
Return
############################################################
$AP_MAGNETO
[M:SBP1]FLG = 0
Return
############################################################
$SETBOUT
#If [M:SBP1]SELFLG = 0
#  Call VIREBOUT(CHAINE,"c") From GOBJET
#Endif
Return
############################################################
$EXEBOUT
#Case BOUT
#  When "c" :
#    If nolign > 0
#      PARAM(7) = [M:SBP2]LOT1(nolign-1)
#      PARAM(8) = [M:SBP2]LOC1(nolign-1)
#      REPONSE = GSTAFIN
#    Endif
#  Endcase
Return
############################################################
$FERME
If clalev([F:STO1]) <> 0 : Filter [STO1] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SBP1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SBP1] = [F:ITM]
        Endif
      Endif
    When 4 :
      If PARAM(I) <> "" & dim([M:SBP1]LOTSEL) > 0
        [M:SBP1]LOTSEL1 = PARAM(I)
      Endif
    When 5 :
      [M:SBP1]SELFLG = val(PARAM(I))
    When 6 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
If clalev([M:CSBP]) <> 0 & [M:CSBP]MEMO = "STD"
  [M:SBP1] = [M:CSBP]
  Return
Endif
If dim([M:SBP1]LOTFLG) < 0
  [M:SBP1]SRTCOD = 4
Else
  [M:SBP1]SRTCOD = 3
Endif
[M:SBP1]AGGFLG = 2
Return
############################################################
$LECTURE
If [M:SBP1]ITMREF = ""
  NBLU = 0
  Return
Endif
# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
# Paramètres pour LOA_PAGE
# WINC      : Increment sur NOL et nolign
# WREAD = 0 : Read first
#         1 : Read next
#         2 : Read last
#         3 : read prev
# WSKIP     : Nombre de relectures avant / arrière
#
If WREAD = 0 | CHGPAG = 1
  nolign = 1
  WREAD  = 0
  WINCR  = 1
  SUITE  = 0
  RETOUR = 0
  Gosub LOA_PAGE
Else
  Case CHGPAG
    When 2  :
      If WINCR = -1
        WSKIP = WLIG
      Else
        WSKIP = 0
      Endif
      nolign = 1
      WREAD  = 1
      WINCR  = 1
      Gosub LOA_PAGE
      RETOUR = 0
    When -1 :
      nolign = MAXLIG
      WREAD  = 2
      WINCR  = -1
      WSKIP  = 0
      Gosub LOA_PAGE
      RETOUR = 0
      SUITE  = 1
    When -2 :
      If WINCR = 1
        WSKIP = WLIG
      Else
        WSKIP = 0
      Endif
      nolign = MAXLIG
      WINCR  = -1
      WREAD  = 3
      Gosub LOA_PAGE
      SUITE  = 0
  Endcase
Endif
Return
############################################################
$TRT_FILTER
If [M:SBP1]FLG = 0
  [M:SBP1]FLG = 1
  Raz [M:SBP2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  Case [M:SBP1]SRTCOD
    When 4 :
      Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE)
&                  Order By ITMREF; STOFCY; LOC; STOCOU
    When 5 :
      Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE)
&                  Order By ITMREF; STA; STOFCY; STOCOU
    When 6 :
      Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE)
&                  Order By ITMREF; PCU; STOFCY; STOCOU
    When Default :
      Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE)
&                  Order By Key STO3
  Endcase
  Raz [F:STO1]
Endif
Return
############################################################
$LOAD_FILTER
WFIL = "[F:STO1]ITMREF=[M:SBP1]ITMREF&LOCCAT=3"
If [M:SBP1]FCY <> ""
  WFIL += "&[F:STO1]STOFCY=[M:SBP1]FCY"
Endif
If dim([M:SBP1]LOTSEL) > 0 & [M:SBP1]LOTSEL1 <> ""
  WFIL += "&pat([F:STO1]LOT,[M:SBP1]LOTSEL1)"
Endif
Return
############################################################
$LOA_PAGE
NBLU = 2
WLIG = 0
If WSKIP <> 0
  If WSKIP < 0
    While WSKIP <> -1
      Read [STO1] Next
      If fstat
        Break
      Endif
      WSKIP += 1
    Wend
  Else
    While WSKIP <> 1
      Read [STO1] Prev
      If fstat
        Break
      Endif
      WSKIP -= 1
    Wend
  Endif
Endif
# Test tableau plein
$LOA_PAGE1
If  nolign > MAXLIG | nolign < 1
  Goto LOA_PAGE_FIN
Endif
# Choix lecture
Case WREAD
  When 0 :
    WREAD = 1
    Read [STO1] First
    If fstat = 0
      WFIRFCY = [F:STO1]STOFCY
      WFIRCHR = [F:STO1]STOCOU
    Else
      WFIRFCY = ""
      WFIRCHR = 0
      SUITE   = 1
      RETOUR  = 1
      Goto LOA_PAGE_FIN
    Endif
  When 1 :
    Read [STO1] Next
    If fstat
      SUITE = 1
      Goto LOA_PAGE_FIN
    Endif
  When 2 :
    WREAD = 3
    Read [STO1] Last
  When 3 :
    Read [STO1] Prev
    If fstat
      RETOUR = 1
      Goto LOA_PAGE_FIN
    Endif
Endcase
# Test fin lecture
Gosub LOA_LIGNE
nolign += WINCR
NOL    += WINCR
WLIG   += WINCR
If [F:STO1]STOFCY = WFIRFCY & [F:STO1]STOCOU = WFIRCHR
  RETOUR = 1
Endif
Goto LOA_PAGE1
#
$LOA_PAGE_FIN
Gosub MAJ_CUMULS
Return
############################################################
$MAJ_CUMULS
If RETOUR = 1 & SUITE = 1 & nolign < MAXLIG-1
  [M:SBP2]STOFCY(nolign-1) = "***"
  If dim([M:SBP2]LOT) > 0
    [M:SBP2]LOT(nolign-1)    = mess(142,124,1)
  Endif
  [M:SBP2]STU(nolign-1)    = [F:ITM]STU
  [M:SBP2]QTYSTU(nolign-1) = sum([M:SBP2]QTYSTU(0..nolign-2))
  If dim([M:SBP2]QTYSTUACT) > 0
    [M:SBP2]QTYSTUACT(nolign-1) = sum([M:SBP2]QTYSTUACT(0..nolign-2))
  Endif
  [M:SBP2]CUNLOKFLG(nolign-1) = 0
  nolign += 1
  NOL    += 1
Endif
Return
############################################################
$LOA_LIGNE
# Si agrégation
If [M:SBP1]AGGFLG = 2 & NOL <> -1
  For I = 0 To NOL
    If [M:SBP2]STOFCY(I)    = "" : Break : Endif
    If dim([M:SBP2]LOT) > 0
         WLOT = [M:SBP2]LOT(I)
    Else WLOT = ""
    Endif
    If dim([M:SBP2]SLO) > 0
         WSLO = [M:SBP2]SLO(I)
    Else WSLO = ""
    Endif
    If dim([M:SBP2]LOC) > 0
         WLOC = [M:SBP2]LOC(I)
    Else WLOC = ""
    Endif
    If dim([M:SBP2]PALNUM) > 0
         WPAL = [M:SBP2]PALNUM(I)
    Else WPAL = ""
    Endif
    If dim([M:SEA2]CTRNUM) > 0
         WCTR = [M:SEA2]CTRNUM(I)
    Else WCTR = ""
    Endif
    If WLOT                 = [F:STO1]LOT       &
&      WSLO                 = [F:STO1]SLO       &
&      WLOC                 = [F:STO1]LOC       &
&      WPAL                 = [F:STO1]PALNUM    &
&      WCTR                 = [F:STO1]CTRNUM    &
&      [M:SBP2]STA(I)       = [F:STO1]STA       &
&      [M:SBP2]PCU(I)       = [F:STO1]PCU       &
&      [M:SBP2]PCUSTUCOE(I) = [F:STO1]PCUSTUCOE &
&      [M:SBP2]QLYCTLDEM(I) = [F:STO1]QLYCTLDEM
      [M:SBP2]STOCOU(I)     = 0
      [M:SBP2]QTYPCU(I)    += [F:STO1]QTYPCU
      [M:SBP2]QTYSTU(I)    += [F:STO1]QTYSTU
      [M:SBP2]CUMALLQTY(I) += [F:STO1]CUMALLQTY
      If dim([M:SBP2]QTYSTUACT) > 0
        [M:SBP2]QTYSTUACT(I) += [F:STO1]QTYSTUACT
      Endif
      If dim([M:SBP2]SERNUM) > 0
        [M:SBP2]SERNUM(I) = "$"
      Endif
      Break
    Endif
  Next I
  If I <= NOL
    nolign -= WINCR
    NOL    -= WINCR
    WLIG   -= WINCR
    Return
  Endif
Endif
#--- Nouvelle ligne écran
[M:SBP2]               = [F:STO1]
[M:SBP2]LOT1(nolign-1) = [F:STO1]LOT
[M:SBP2]LOC1(nolign-1) = [F:STO1]LOC
[M:SBP2]STU(nolign-1)  = [F:ITM]STU

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:STO1]STOFCY | [F:ITF]ITMREF <> [F:STO1]ITMREF
   Read [ITF]ITF0 = [F:STO1]ITMREF;[F:STO1]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif


If find([F:ITF]STOMGTCOD,3,4) & dim([M:SDE2]QTYSTUACT) > 0
  Read [STL1]STL0 = [F:STO1]ITMREF;[F:STO1]LOT;[F:STO1]SLO
  If fstat = 0
    Case [F:ITF]STOMGTCOD
      When 3 :
       [M:SBP2]POT(nolign-1) = [F:STL1]POT
      When 4 :
       [M:SBP2]ACT(nolign-1)= [F:STL1]ACT
    Endcase
  Endif
Endif
Return
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SBP1]FLG = 0
End
############################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SBP1]FLG = 0
End
############################################################
Subprog C_LOTSEL(VALEUR)
Variable Char     VALEUR
VALEUR = toupper(VALEUR)
#Controle si le lot existe sur le site
If !clalev([SLF]) : Local File STOLOTFCY [SLF] : Endif
If !clalev([SLF1]) : Local File STOLOTFCY [SLF1] : Endif

If VALEUR  <> "" & [M:SBP1]ITMREF = ""
  Filter [SLF] Where  LOT  = VALEUR & STOFCY = [M:SBP1]FCY
&            Order By Key SLF0 Desc
  Read [SLF] First
  If fstat = 0 & [F:SLF]ITMREF <>""
    Filter [SLF1] Where  ITMREF <> [F:SLF]ITMREF &
&       LOT  = [F:SLF]LOT & STOFCY = [M:SBP1]FCY
    Read [SLF1] First
    If fstat = 0
      Call MESSAGE (mess(393,184,1)) From GESECRAN
      Raz VALEUR : zonsui = "[M:SBP1]ITMREF"
    Else
      [M:SBP1]ITMREF = [F:SLF]ITMREF : Affzo [M:SBP1]ITMREF
      # Issue 85421 - 2013-01-14 by MAE : lecture de ITM si saisie du lot
      Call LECTURE("ITM",[F:SLF]ITMREF,"") From CONTOBJ
    Endif
  Else
    If fstat
      GMESSAGE=mess(394,184,1)+[M:SBP1]FCY
      mkstat=2
    Endif
  Endif
  Filter [SLF]
  Filter [SLF1]
Endif
[M]LOTSEL1 = VALEUR
End
############################################################
Subprog AM_LOTSEL(VALEUR)
Variable Char    VALEUR()
[M:SBP1]FLG = 0
End
############################################################
Subprog AS_LOTSEL(VALEUR)
Variable Char     VALEUR
End
############################################################
Subprog AS_SRTCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(1) = 1
GMENLOC(2) = 1
If VALEUR = 0
  If dim([M]LOTFLG) < 0
    GMENLOC(3) = 1
    VALEUR = 4
  Else
    VALEUR = 3
  Endif
Endif
GMENLOC(7) = 1
GMENLOC(8) = 1
GMENLOC(9) = 1
GMENLOC(10) = 1
GMENLOC(11) = 1
GMENLOC(12) = 1
End
############################################################
Subprog AP_SRTCOD(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
End
############################################################
Subprog AV_STOFCY(VALEUR)
Variable Char    VALEUR
If nolign <> 0
  If [M]STOFCY(nolign-1) = "***"
    pcolor = GCOUL(3)
  Else
    pcolor = GCOUL(0)
  Endif
Endif
End
############################################################
Subprog IB_NBLIG
If [M]STOCOU(nolign-1) = 0
  GBOUT4 = ""
  GBOUT5 = ""
  GBOUT6 = ""
  GBOUT7 = ""
  GBOUT8 = ""
  GBOUT9 = ""
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If GCONSULT <> 0
  mkstat = 2
Endif
End
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SBP") From SUBGTC

End

