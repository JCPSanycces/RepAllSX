#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Class ESSWRKHISSUI
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"      : Gosub AREAD_AFTER
    Endcase
Endcase
Return

$AREAD_AFTER
#Populate the technical properties for leave and expenses
#These fields will be used as keys to open the detail representations - This can be extended for future approvals
Local Char F_REFNUM(GLONEML)
Local Char F_CTRNUM(GLONHRCTR)
Local Integer F_EXSNUM
Local Integer F_UID

#Leave - DEMCONGE - DCG/DCGMOD
If this.CODEVT = "DCG" or this.CODEVT = "DCGMOD"
  F_REFNUM  = this.VALCTX1
  F_UID     = val(this.VALCTX4)

  #Assign
  this.TCH_REFNUM   = F_REFNUM
  this.TCH_UID      = F_UID
Endif

#Expenses - HREXPENSES - HREXS/EXSMOD
If this.CODEVT = "HREXS" or this.CODEVT = "EXSMOD"
  F_REFNUM  = this.VALCTX1
  F_EXSNUM  = val(this.VALCTX2)
  F_CTRNUM  = this.VALCTX4

  #Assign
  this.TCH_REFNUM = F_REFNUM
  this.TCH_EXSNUM = F_EXSNUM
  this.TCH_CTRNUM = F_CTRNUM
Endif

#Employee ESWD
If this.CODEVT = "ESWD" or this.CODEVT = "ESWDMOD"
  F_REFNUM  = this.VALCTX1
  F_UID     = val(this.VALCTX5)

  #Getting the details of the main record - to be used for detail representation
  Local File ESSWRKFLWDET  [ESWD2]
  Filter [F:ESWD2] Where UID=[L]F_UID and MAIREC = 2
  Read [ESWD2] First
  If fstat = [V]CST_AOK
    #Assign key values
    this.TCH_CLA = [F:ESWD2]CLA
    this.TCH_MAIREC = [F:ESWD2]MAIREC
    this.TCH_FLDNAM = [F:ESWD2]FLDNAM
  Endif

  #Assign
  this.TCH_REFNUM   = F_REFNUM
  this.TCH_UID      = F_UID
Endif

Return





