#**
#* Vérification existence de la variable VAL_VAR dans le code liste fourni dans le paramètre COD_LIST
#*
Subprog CONTROLE_VRACOD(COD_LIST, VAL_VAR)
Value    Char    COD_LIST
Variable Char    VAL_VAR()
Local    Char    CODPVH(GLONPVH)

  # Récupération du code liste à utiliser pour le bordereau de formation
  Call PARAM(GCURLEG, COD_LIST, CODPVH) From ADOVAL
  Filter [F:HRPVD] Where PVHCOD=CODPVH & VRACOD=VAL_VAR & LEG=GCURLEG
  If rowcount([F:HRPVD])=0 Then
    GMESSAGE = mess(182,10717,1)-CODPVH : # Variable non paramétrée dans le code liste
    mkstat=2
  Endif
  Filter [F:HRPVD]
End

#**
#* Recherche du site et de la société relatifs au contrat
#*
#* @param MAT    : matricule
#* @param CTR    : n° de contrat
#* @param STRDAT : date début de session
#*!
Subprog CALC_CFY(MAT, CTR, STRDAT, FCY, CPY)
Value    Char MAT, CTR
Value    Date STRDAT
Variable Char FCY, CPY

  # FQ72318 - MABON 11/03/11 - Prise en compte date d'effet
#  Filter [F:HRCTR] Where REFNUM=MAT and CTRNUM=CTR and CTRDAT<=STRDAT Order By CTRDAT Desc
  Filter [F:HRCTR] Where REFNUM=MAT and CTRNUM=CTR and (CTRDAT<=STRDAT | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=STRDAT)) Order By CTRDAT Desc
  Read [F:HRCTR] First
  If !fstat Then
    FCY = [F:HRCTR]ETRFCY
  Else
    Read [F:ID]ID0=MAT
    If !fstat Then
      FCY = [F:ID]FCY
    Endif
  Endif
  Filter [F:HRCTR]

  Call LECTURE("FCY", FCY, "") From CONTOBJ
  If !fstat Then CPY = [F:FCY]LEGCPY : Endif
  fstat=0
End

#**
#* La date d'application doit être une date d'extraction
#*
#* @param VALEUR
#*!
Subprog C_DAT(VALEUR)
Variable Date    VALEUR
#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#*********************************#
#  If clalev([F:HRPEO])=0 : Local File HRPERIOD [HRPEO] : Endif
#  Filter [F:HRPEO] Where PYRDAT=VALEUR and FCY=''
#  If rowcount([F:HRPEO])=0 Then
#    Filter [F:HRPEO] Where PYRDAT>=VALEUR and FCY='' Order By PYRDAT
#    Read [F:HRPEO] First
#    If !fstat Then
#      VALEUR=[F:HRPEO]PYRDAT
#    Endif
#    Filter [F:HRPEO]
#  Endif
#  Filter [F:HRPEO]
#**
#*!

  If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif
  Filter [F:HRPEOD] Where PERCOD=[HRCTR]PERCOD and PYRDAT=VALEUR
  If rowcount([F:HRPEOD])=0 Then
    Filter [F:HRPEOD] Where PYRDAT>=VALEUR and PERCOD='' Order By PYRDAT
    Read [F:HRPEOD] First
    If !fstat Then
      VALEUR=[F:HRPEOD]PYRDAT
    Endif
    Filter [F:HRPEOD]
  Endif
  Filter [F:HRPEOD]
#LIPET - 2017-05-20 - END
  fstat=0
End

#**
#* Calcul du numéro de ligne suivant dans la table des lignes de bordereau HRPPD
#*
#* @param NUM : numéro de bordereau
#*!
Funprog CALC_NUMLIG(NUM)
Value Char    NUM
Local Integer NUMLIG

  Filter [F:HRPPD] Where REQNUM=NUM Order By NUMLIG Desc
  Read [F:HRPPD] First
  If !fstat Then
    NUMLIG = [F:HRPPD]NUMLIG+1
  Else
    NUMLIG = 1
    fstat  = 0
  Endif
  Filter [F:HRPPD]
End NUMLIG

#**
#* Création du borderau et de ses lignes
#*
#* @param WCHIEF   : manager du bordereau
#* @param CODPVH   : code liste
#* @param DATAPL   : date d'application
#* @param NCRITERE : critère supplémentaire (évalué) pour déterminer si on doit créer un nouveau bordereau ou non
#* @param WFCY     : site
#* @param CRITTPS  : 1=bordereau pour les Autres stages pour le STT ; 2=bordereau pour le HTT
#* @param DESREQ   : désignation bordereau
#* @param WREFNUM  : matricule
#* @param WCTRNUM  : contrat
#* @param TRT      : nom du traitement dans lequel vont se trouver les étiquettes CALC_VRA et CALC_AMT pour calculs spécifiques
#* @param NBD      : nombre de lignes créées ou modifiées
#* @param WREQNUM  : numéro du bordereau créé ou modifié
#*!
Subprog CRE_REQ(WCHIEF, CODPVH, DATAPLSTR, DATAPL, NCRITERE, WFCY, CRITTPS, DESREQ, WREFNUM, WCTRNUM, TRT, NBD, WREQNUM)
Value    Char    WCHIEF, CODPVH, WFCY, DESREQ, WREFNUM, WCTRNUM, TRT
Value    Date    DATAPLSTR, DATAPL
Value    Integer NCRITERE, CRITTPS
Variable Char    WREQNUM()
Variable Integer NBD
Local    Char    WCOMPLEMENT(250), CHIEF, WVRACOD, WCODNUM(GLONANM)
Local    Integer WMANCOU, STAT, NEW_REC_H, NEW_REC_D, ICOT, NBCOT
Local    Decimal ACPAMT
Local    Date    WCTRDAT

  If GPAYE Then
    # Récupération du code du compteur affecté (module paye 2, compteur 7)
#    Call GET_PARCPT(2, 7, WCODNUM, WMANCOU) From DIVPPH
    # Récupération du code du compteur affecté (module paye 20, compteur 7)
# SEGAY 18/01/12 - Spécifique PAIE
    # Récupération du code du compteur affecté (module paye(Gestion des talents 15, compteur 7(HRPPH))
    #Call GET_PARCPT(15, 7, WCODNUM, WMANCOU) From DIVPPH
    If clalev([F:FCY])  = 0    : Local File FACILITY    [FCY]    : Endif
    If clalev([F:CPY])  = 0    : Local File COMPANY     [CPY]    : Endif
    If clalev([F:TCA])  = 0    : Local File TABCOUAFF   [TCA]    : Endif
#DIRAS - 25/05/2017 - JIRA X3-11598 - START
    If clalev([F:HRPPH]) = 0   : Local File PPREQUESTH  [HRPPH]  : Endif #Required for HRCARRNOF
#DIRAS - 25/05/2017 - JIRA X3-11598 - END

    If WFCY<>""
      Call LECTURE("FCY",WFCY,"") From CONTOBJ
      Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
      GSOCIETE=[F:CPY]CPY
      If GNBLEG = 1
        GCURLEG = GDOSLEG
      Else
        If dim([F:CPY]LEG)>0
          GCURLEG =[F:CPY]LEG
        Endif
      Endif
    Endif

    Call LECTCA(15,STAT) From SUBTCA
    If !STAT
      GMESSAGE = mess(12,114,1) : # Compteur inexistant
      GOK = 0 : End
    Else
      [L]WCODNUM= [F:TCA]CODNUM(7)
    Endif

    CHIEF = WCHIEF
    Read [F:ID]ID0=WCHIEF
    If !fstat Then WCOMPLEMENT = [F:ID]NCKNAM : Endif
    fstat=0

    # On cherche si le bordereau existe déjà, et on crée un nouveau bordereau :
    #   - s'il n'existe pas encore
    #   - ou si CRITERE est vérifié
    # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#    Filter [F:HRPPH] Where REQSTA=2 & MGR=CHIEF & PVHCOD=CODPVH & APLDAT=DATAPL
    Filter [F:HRPPH] Where REQSTA=2 & MGR=CHIEF & PVHCOD=CODPVH & APLSTR=DATAPLSTR & APLDAT=DATAPL
    # Fin MABON
    If rowcount([F:HRPPH])=0 | NCRITERE>0 Then
      Call NUMERO(WCODNUM, WFCY, date$, WCOMPLEMENT, WREQNUM, STAT) From SUBANM
      If STAT Then
        GMESSAGE = mess(4,10702,1)-WCODNUM : # Erreur sur compteur
#SEGAY - 23/02/11 bug 71824
#        GOK = 0 : Return
        GOK = 0 : End
      Endif
      NEW_REC_H = 2 : NEW_REC_D = 2
    Else
      Gosub FIND_REQ From =TRT
      NEW_REC_H = 1
    Endif
    Filter [F:HRPPH]

    # Lignes du bordereau
    NBD = 0
    For [F:TBD]
      # FQ77362 - MABON 21/10/11 - Ajout vérification de l'existence de CODFIC dans TBD (qui est variable selon
      # le contexte)
      If dim([F:TBD]CODFIC)>0 & [F:TBD]CODFIC="PARIND" & instr(1,[F:TBD]CODZONE,"COT")>0 Then
        NBCOT=[F:TBD]DIME
      Else
        NBCOT=1
      Endif
      For ICOT=0 To NBCOT-1
        Gosub CALC_VRA From =TRT
        If WVRACOD<>"" Then
          Gosub CALC_AMT From =TRT

          If ACPAMT<>0 Then
            # FQ82073 - MABON 31/01/13 - Initialisation date contrat + La date d'application devient une période d'application
            Gosub CAL_CTRDAT From =TRT
            # On cherche si la ligne existe déjà
                If NEW_REC_H=1 or NEW_REC_D=1 Then
                  NEW_REC_D=1
              # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#                  Filter [F:HRPPD] Where REQNUM=WREQNUM & REFNUM=WREFNUM & CTRNUM=WCTRNUM & VRACOD=WVRACOD
#&                                      & APLDAT=DATAPL & BUL=""
                  Filter [F:HRPPD] Where REQNUM=WREQNUM & REFNUM=WREFNUM & CTRNUM=WCTRNUM & CTRDAT=WCTRDAT & VRACOD=WVRACOD
&                                      & APLSTR=DATAPLSTR & APLDAT=DATAPL & BUL=""
              # Fin MABON
              If rowcount([F:HRPPD])=0 Then
                NEW_REC_D=2
              Else
                Read [F:HRPPD] First
              Endif
              Filter [F:HRPPD]
            Endif
            If NEW_REC_D=2 Then : # On crée la ligne du bordereau si elle n'existe pas encore
              NEW_REC_D=1
              Raz [F:HRPPD]
              [F:HRPPD]REQNUM  = WREQNUM
              [F:HRPPD]NUMLIG  = func CALC_NUMLIG([F:HRPPD]REQNUM)
              [F:HRPPD]IDPPD   = uniqid([HRPPD])
              [F:HRPPD]REFNUM  = WREFNUM
              [F:HRPPD]CTRNUM  = WCTRNUM
              # FQ82073 - MABON 31/01/13 - Initialisation date contrat + La date d'application devient une période d'application
              [F:HRPPD]CTRDAT  = WCTRDAT
              [F:HRPPD]APLSTR  = DATAPLSTR
              # Fin MABON
              [F:HRPPD]APLDAT  = DATAPL
              [F:HRPPD]VRACOD  = WVRACOD
              # FQ66382 - MABON 23/05/11 - C'est le montant accepté qui est récupéré ensuite dans l'arrêté de paie
  #            [F:PPD]DEMAMT  = DEMAMT
              [F:HRPPD]DEMAMT  = ACPAMT
              [F:HRPPD]ACPAMT  = ACPAMT
              # FQ71989 - MABON 01/03/11 - Le statut des lignes doit être directement à Accepté
  #            [F:PPD]STA     = 2 : # Demande
              [F:HRPPD]STA     = 5 : # Accepté
              [F:HRPPD]CREUSR  = GUSER
              [F:HRPPD]CREDAT  = date$
              If [M:DIA]SIMUL=1 Then
                Write [F:HRPPD]
              Endif
            Else : # On met à jour la ligne du bordereau  si elle existe déjà
              # FQ66382 - MABON 23/05/11 - C'est le montant accepté qui est récupéré ensuite dans l'arrêté de paie
  #            [F:PPD]DEMAMT += DEMAMT
              [F:HRPPD]DEMAMT += ACPAMT
              [F:HRPPD]ACPAMT += ACPAMT
              [F:HRPPD]UPDUSR  = GUSER
              [F:HRPPD]UPDDAT  = date$
              If [M:DIA]SIMUL=1 Then
                Rewrite [F:HRPPD]
              Endif
            Endif
  #SEGAY - 23/02/11 bug 71824
  #          If fstat Then GOK=0 : Call FSTA("PPD") From GLOCK : Return : Endif
            If fstat Then GOK=0 : Call FSTA("HRPPD") From GLOCK : Break : Endif
            NBD += 1
          Endif
        Endif
      Next
    Next

    # On ne crée ou met à jour l'en-tête de bordereau que si on a créé ou mis à jour des lignes
    If GOK & NBD>0 Then
      # En-tête du bordereau
      If NEW_REC_H=2 Then
        [F:HRPPH]REQNUM  = WREQNUM
        [F:HRPPH]DES     = DESREQ
        [F:HRPPH]REQSTA  = 2       : # Demande
        [F:HRPPH]MGR     = CHIEF
        [F:HRPPH]PVHCOD  = CODPVH
        # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
        [F:HRPPH]APLSTR  = DATAPLSTR
        # Fin MABON
        [F:HRPPH]APLDAT  = DATAPL
        [F:HRPPH]ALLCPY  = 2
        [F:HRPPH]ALLFCY  = 2
        [F:HRPPH]ALLPRF  = 2
        [F:HRPPH]ALLSRV  = 2
        [F:HRPPH]CRITTPS = CRITTPS
        [F:HRPPH]DEMDAT  = date$
        [F:HRPPH]CREDAT  = date$
        [F:HRPPH]CREUSR  = GUSER
        If [M:DIA]SIMUL=1 Then
          Write [F:HRPPH]
        Endif
      Else
        [F:HRPPH]UPDDAT  = date$
        [F:HRPPH]UPDUSR  = GUSER
        If [M:DIA]SIMUL=1 Then
          Rewrite [F:HRPPH]
        Endif
      Endif
#SEGAY - 23/02/11 bug 71824
#      If fstat Then GOK=0 : Call FSTA("PPH") From GLOCK : Return : Endif
      If fstat Then GOK=0 : Call FSTA("HRPPH") From GLOCK : End : Endif
    Endif
  Endif
End

#**
#* Recherche du numéro de bordereau relatif au salarié en cours
#*
#* @param REFNUMC : salarié en cours
#* @param WREQNUM : numéro de bordereau trouvé
#*!
Subprog FIND_REQNUM(REFNUMC, WREQNUM)
Value    Char    REFNUMC
Variable Char    WREQNUM
Local    Integer FOUND
  If rowcount([F:HRPPH])=1 Then
    Read [F:HRPPH] First
  Else
    # Il faut retrouver le bordereau pour le salarié en cours
    For [F:HRPPH]
      Filter [F:HRPPD] Where REQNUM=[F:HRPPH]REQNUM
      For [F:HRPPD]
        If [F:HRPPD]REFNUM=REFNUMC Then
          FOUND=2 : Break 2
        Endif
      Next
      Filter [F:HRPPD]
    Next
    If FOUND=1 Then : # Si on ne l'a toujours pas trouvé, on prend le 1er
      Read [F:HRPPH] First
    Endif
  Endif
  WREQNUM=[F:HRPPH]REQNUM
End

Subprog CALC_GRPCPY(CPYGRU, LIS_CPY, I)
Value    Char    CPYGRU
Variable Char    LIS_CPY()(0..100)
Variable Integer I
  If clalev([F:AGC])=0 : Local File AGRPCPY  [AGC] : Endif
  For [F:AGC] Where GRP=CPYGRU : # Recherche dans les groupes de sociétés
    If !find(CPYGRU, LIS_CPY) Then
      LIS_CPY(I)=CPYGRU
      I += 1
    Endif
    If !find([F:AGC]CPY, LIS_CPY) Then
      LIS_CPY(I)=[F:AGC]CPY
      I += 1
    Endif
  Next
End


#################
# order to calculate
# first save_ctx
# get_parcpt
# get num  call numero from subanm
# restore_ctx
##################
Subprog GET_PARCPT(MODULE, CPY_SIT, POSITION, CODNUM, MANCOU,STAT)
Value Integer MODULE
Value Char CPY_SIT()
Value Integer POSITION
Variable Char CODNUM()
Variable Integer MANCOU
Variable Integer STAT

Local Integer W_POS, W_OK

GSOCIETE=CPY_SIT
If CPY_SIT <>""
  W_POS = find(CPY_SIT,GSITE(1..GNBSITE))
  If W_POS
    GSOCIETE = GSOCSITE(W_POS)
  Endif
Endif

Call LECTCA(MODULE,STAT) From SUBTCA
If STAT
   [L]CODNUM = [F:TCA]CODNUM([L]POSITION)    : # Récupération du compteur (PPH=7) / Get counter code by row
   [L]MANCOU = [F:TCA]MANCOU([L]POSITION)    : # Compteur manuel (on le récupére par principe,                                              # non géré car bloqué à non en dur dans la paye ) / Get
# affectation type (auto/manual)
Endif


End




$SAVE_CTX

If(dim(S_GSOCIETE)=-1) : Local Char S_GSOCIETE([V]GLONCPY) :Endif
If(dim(S_GCURLEG)=-1) :  Local Char S_GCURLEG(type([V]GCURLEG)-10) :Endif
S_GSOCIETE=GSOCIETE
S_GCURLEG=GCURLEG
Return


$RESTORE_CTX
If(dim(S_GSOCIETE)) : GSOCIETE= S_GSOCIETE : Endif
If(dim(S_GCURLEG))  : GCURLEG= S_GCURLEG : Endif

Return

$SET_VAR_COUNTER
Local Integer TYP_CPT
Local Char W_SITE(GLONFCY), W_VALUECPT(30), W_CPTNAME(30),W_CRITCOMP(250)
Local Date W_DATCPT
Local Integer W_CPTMAN, W_STAT
Local Integer W_MODULE,W_POS
Local Char W_DEFCOUNTER(20)

Return

$SET_VAR_COUNTER_SAL
Gosub SET_VAR_COUNTER
W_MODULE=9

Return



$CONVERT_TO_SAL
# type of counter : 1 type for REFNUM, 2 for type CTRNUM, 0: for Employee arrival
  Case TYP_CPT
    When 0 : W_POS=3
    When 1 : W_POS=2
    When 2 : W_POS=4
  Endcase

Return


$GET_COUNTER_SAL
  Gosub CONVERT_TO_SAL
  Gosub GET_COUNTER

Return


$GET_COUNTER

  Gosub SAVE_CTX
  Call GET_PARCPT(W_MODULE, W_SIT, W_POS, W_CPTNAME, W_CPTMAN,W_STAT) From TOOLSVAR
  If !W_STAT
    GMESSAGE = mess(3,10702,1) : # Compteur matricule non défini
    Gosub RESTORE_CTX
    GOK = 0 : Return
  Endif
 Call NUMERO(W_CPTNAME,W_SIT,W_DATCPT,W_CRITCOMP,W_VALUECPT,OK) From SUBANM
 If OK
   GMESSAGE = mess(4,10702,1)-COMPTEUR : # "Erreur sur compteur"
   Gosub RESTORE_CTX
   GOK = 0 : Return
 Endif
 Gosub RESTORE_CTX
Return

#JASMI - 2017-06-05 - START
Subprog C_LEG_LEV(VALEUR)
Variable Char    VALEUR()

  Call VERIF_FILL_LEVEL(1, VALEUR)

End
