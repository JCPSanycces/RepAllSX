#**
#* Seul le champ relatifs au niveau sélectionné peut être saisissable
#*!
Subprog VERIF_LEVEL(LEVEL)
Value    Integer LEVEL
If [M]LEV(nolign-1)<>(LEVEL - 1) Then mkstat=2 : Endif
End

Subprog AS_ADXDOS(VALEUR)
Variable Char    VALEUR()

