#<AdxTL>@(#)0.0.0.0 $Revision$
#** V7 : Waiting Time Mangement **#
#*********************************#

$ACTION

  Case ACTION
    When "SEL_LISTE"  : Gosub SEL_LISTE
    When Default
  Endcase
Return

#**
#* Sélection des variables relatives au code liste fourni dans le paramètre CODPVH
#*!
$SEL_LISTE
  Case LISTE
    When "SELVPVH" : Gosub SELVPVH
  Endcase
Return

$SELVPVH
Local Char    CODPVH(GLONPVH)
Local Char    TEXTE(80)(1..200,1..2)
  # Récupération du code liste à utiliser pour le bordereau de formation
  # PARAM(1) = nom du paramètre contenant le code liste
  Call PARAM(GCURLEG, PARAM(1), CODPVH) From ADOVAL
  TIT(0)=mess( 7,10344,1) : # Variable
  TIT(1)=mess(37,100,1)   : # Code
  TIT(2)=mess(36,105,1)   : # Libellé
  Filter [F:PVH] Where PVHCOD=CODPVH & LEG=GCURLEG
  Read [F:PVH]PVH0 First
  Filter [F:PVH]
  If fstat : Return : Endif

  For [F:HRPVD] Where PVHCOD=CODPVH & LEG=GCURLEG
    NBTEX += 1
    TEX(NBTEX)     = [F:HRPVD]VRACOD
    TEXTE(NBTEX,1) = [F:HRPVD]VRACOD
    Call LECTEXTRA(TEXTE(NBTEX,2),"VARIA","DES",GCURLEG,[F:HRPVD]VRACOD) From ATEXTRA
  Next
Return

#**
#* Ouverture des tables
#*!
$OUVRE
  If clalev([F:PVH])=0   : Local File PPVRALISH [PVH]   : Endif
  If clalev([F:HRPVD])=0 : Local File PPVRALISD [HRPVD] : Endif
  If clalev([F:VRA])=0   : Local File VARIA     [VRA]   : Endif
Return

