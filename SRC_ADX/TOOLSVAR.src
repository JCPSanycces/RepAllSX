#**#####################################################################################
#* Initialisation de la borne fin par la borne début
#*!
Subprog INIT_ZONE(VALEUR, ZONE)
Variable Char    VALEUR()
Value    Char    ZONE

  If evalue("[M:DIA]"+ZONE)<>"" and VALEUR="" Then
    VALEUR=evalue("[M:DIA]"+ZONE)
  Endif
End

Subprog INIT_ZONE_D(VALEUR, ZONE)
Variable Decimal VALEUR()
Value    Char    ZONE

  If evalue("[M:DIA]"+ZONE)<>0 and VALEUR=0 Then
    VALEUR=evalue("[M:DIA]"+ZONE)
  Endif
End

Subprog INIT_ZONE_I(VALEUR, ZONE)
Variable Integer VALEUR()
Value    Char    ZONE

  If evalue("[M:DIA]"+ZONE)<>0 and VALEUR=0 Then
    VALEUR=evalue("[M:DIA]"+ZONE)
  Endif
End

Subprog INIT_ZONE_DA(VALEUR, ZONE)
Variable Date    VALEUR
Value    Char    ZONE

  If evalue("[M:DIA]"+ZONE)<>[0/0/0] and VALEUR=[0/0/0] Then
    VALEUR=evalue("[M:DIA]"+ZONE)
  Endif
End

