#**
#* Contrôle les habilitations
#*
#* @param VALEUR
#*!
Subprog C_CPY(VALEUR, FROMAFC)
Variable Char    VALEUR()
Value    Char    FROMAFC
Local    Integer AUZCFY

  AUZCFY = func SUBHRSES.GET_AUZ(VALEUR, "", FROMAFC)
  If AUZCFY=1 Then
    mkstat=2
  Endif
End

