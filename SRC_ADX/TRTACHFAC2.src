#<AdxTL>@(#)1.0.0.0 $Revision$
Local Integer WRET
Call GENERE_PIH("FCANY1103VEN00029",2,"TRTACHFAC2",3,WRET) From TRTACHFAC2
End

###########################################################################
# TRTACHFAC2          Traitements liés aux Factures          Module ACHAT #
# ----------------------------------------------------------------------- #
# Sous-programmes                                          MBT 15/09/2003 #
#   - CHARG_FACINTSOC  : Chargement écrans fact achat à partir fact vente #
#   - GENERE_FACINTSOC : Génération facture achat à partir facture vente  #
#   - GENERE_PIH       : Génération d'une facture d'achat                 #
###########################################################################


$ACTION
If GPIH_WRET  mkstat=1 : Return : Endif : # Si déjà une erreur , c'est fini !
Case ACTION
  When "IMP_DEBUT" : Gosub DEB_FACINTSOC
  When "IMP_ZONE"  : Gosub MSK_ENTETE
  When "IMP_TAB"   : Gosub MSK_DETAIL
Endcase
Return


################################################################################
# CHARG_FACINTSOC : S/P chargement écrans facture achat depuis une facture vte #
# ---------------------------------------------------------------------------- #
# Subprog CHARG_FACINTSOC (WNDO,WRET)                                          #
#   WNDO    : Numéro de la facture d'origine vente                             #
#   WRET    : Code retour (0=Ok, 1-99=Erreur avec GMESSAGE)                    #
################################################################################
Subprog CHARG_FACINTSOC (WNDO,WRET)
Value    Char    WNDO
Variable Integer WRET
#-----
Local Integer WCOD          : [L]WCOD=1            : # Chargement [M] (après un picking)
Local Char    WTRT(GLONADC) : [L]WTRT="TRTACHFAC2" : # Traitement pour inter-société
Local Integer WTRA          : [L]WTRA=1            : # Pas de fichier trace
#-----
Gosub GENPIH
#-----
End


################################################################################
# GENERE_FACINTSOC : S/P génération d'une facture achat depuis une facture vte #
# ---------------------------------------------------------------------------- #
# Subprog GENERE_FACINTSOC (WNDO,WTRA,WRET)                                    #
#   WNDO    : Numéro de la facture d'origine vente                             #
#   WTRA    : Fichier trace (0-1=Non,  2=Oui,  3=Oui détaillée)                #
#   WRET    : Code retour (0=Ok,  1-99=Erreur avec GMESSAGE)                   #
################################################################################
Subprog GENERE_FACINTSOC(WNDO,WTRA,WRET)
Value    Char    WNDO
Value    Integer WTRA
Variable Integer WRET
#-----
Local Integer WCOD          : [L]WCOD=2            : # Génération de la facture
Local Char    WTRT(GLONADC) : [L]WTRT="TRTACHFAC2" : # Traitement pour inter-société
#-----
Gosub GENPIH
#-----
End


################################################################################
# GENERE_PIH : S/P de génération de factures d'achat                           #
# ---------------------------------------------------------------------------- #
# Subprog GENERE_PIH (WNDO,WCOD,WTRT,WTRA,WRET)                                #
#   WNDO    : Numéro du document d'origine                                     #
#   WCOD    : Code traitement                                                  #
#             1 = Chargement [M] (après un picking)                            #
#             2 = Actions OUVRE, RAZCRE                                        #
#                 et chargement [M]                                            #
#                 et actions VERIF_CRE, INICRE, CREATION                       #
#                 et écriture enregistrement PINVOICE                          #
#                 et actions APRES_CRE, FERME                                  #
#   WTRT    : Nom du traitement à exécuter pour le chargement des champs       #
#   WTRA    : Fichier trace (0-1=Non,  2=Oui,  3=Oui détaillée)                #
#   WRET    : Code retour (0=Ok,  1-99=Erreur avec GMESSAGE)                   #
################################################################################
Subprog GENERE_PIH(WNDO,WCOD,WTRT,WTRA,WRET)
Value    Char    WNDO
Value    Integer WCOD
Value    Char    WTRT
Value    Integer WTRA
Variable Integer WRET
#-----
Gosub GENPIH
#-----
End


#----------------------------------------------------#
# Chargement [M] et génération d'une facture d'achat #
#----------------------------------------------------#
$GENPIH
Raz WRET
#----- Variables locales -----#
Local  Integer  SAV_GIMPORT : [L]SAV_GIMPORT=GIMPORT
Local  Integer  SAV_NOLIGN  : [L]SAV_NOLIGN =nolign
Local  Integer  OK          : [L]OK=1
Local  Integer  I
Local  Integer  WOUVTRAFLG
Local  Char     WZON(GLONAVA)
Local  Char     ACTION(30)
Local  Char     WPGM(GLONADC)
Local  Char     WMSG2(20)
Local  Char     WMESSAGE(100)
Local  Libelle  WADXLOG
Local Integer   RET
# Issue 99226 - 2014-05-12 by SR
Local  Char     SAV_GGRPFCY(GLONFCY) : SAV_GGRPFCY=GGRPFCY
#-----
Global Integer  GPIH_WCOD   : GPIH_WCOD=WCOD
Global Integer  GPIH_WTRA   : GPIH_WTRA=WTRA
Global Integer  GPIH_WRET   : GPIH_WRET=WRET
Global Decimal  GPIH_WCOE
#-----
Global Char     GSIH_TAX1(GLONVAT)(func AFNC.ACTIV("SVA")+10)
Global Char     GSIH_TAX2(GLONVAT)(func AFNC.ACTIV("SVA")+10)
Global Integer  GSIH_NBTAX
Global Decimal  GSIH_CUMAMTTAX
#-----
If !adxlog  WADXLOG=0  Else  WADXLOG=1 : Endif
#-----
If WTRT="TRTACHFAC2"  WMSG2=mess(491,197,1)  Else  WMSG2="" : Endif
#----- Ouverture de la trace si nécessaire -----#
If WCOD=2 & WTRA<2  WTRA=2 : Endif : # Il faut forcer la trace si traitement complet
If WTRA>1 & GTRACE=""
  Call OUVRE_TRACE (mess(522,197,1)-WMSG2) From LECFIC
  [L]WOUVTRAFLG=1
  If dim(GPURTRACE)>0  GPURTRACE=1 : Endif
Endif
#----- Si traitement inter-sociétés, le module vente doit être présent ! -----#
If WTRT="TRTACHFAC2" & GMODU(5)<>2
  WRET=1 : Gosub TRT_ERR : Goto FIN_GENPIH
Endif
#----- Contrôle des paramètres -----#
If WCOD<1 | WCOD>2
  WRET=4 : [L]WZON="WCOD" : Gosub TRT_ERR : Goto FIN_GENPIH
Endif
If WTRT=""
  WRET=4 : [L]WZON="WTRT" : Gosub TRT_ERR : Goto FIN_GENPIH
Endif
#----- Vérification existence du traitement -----#
Call EXISTE_ADX("","",WTRT,[L]OK) From ORDSYS
If ![L]OK
  WRET=5 : Gosub TRT_ERR : Goto FIN_GENPIH
Endif
#----- Ouverture masques écrans si nécessaire -----#
If !clalev([M:PIH0])    Local Mask PIH0       [PIH0] : Endif
If !clalev([M:PIH1])    Local Mask PIH1       [PIH1] : Endif
If !clalev([M:PIH3])    Local Mask PIH3       [PIH3] : Endif
If !clalev([M:PIH4])    Local Mask PIH4       [PIH4] : Endif
If !clalev([M:PCIW])    Local Mask PCRITINV   [PCIW] : Endif
If !clalev([M:AD66])    Local Mask ADRBPR     [AD66] : Endif
If !clalev([M:AD67])    Local Mask ADRBPR     [AD67] : Endif
If !clalev([M:PCEZ])    Local Mask PCEE       [PCEZ] : Endif
#-----
Raz [M:PIH1], [M:PIH3], [M:PIH4], [M:PCIW], [M:PCEZ], [M:AD66], [M:AD67]
# Issue 99226 - 2014-05-12 by SR
Raz GGRPFCY
#----- Ouverture des tables de l'objet PIH et appel actions OUVRE et RAZCRE -----#
If WCOD=2
  If !clalev([F:PIH])  Local File PINVOICE  [PIH] : Endif
  If !clalev([F:PTR])  Local File PURTRS    [PTR] : Endif
  Raz GPTRNUM
  GIMPORT=1
  Raz [M:PIH0]
  Local Char ABREV(5)
  [L]ABREV="PIH"
  GABREV  ="PIH"
  [L]ACTION="DEFVAR" : [L]WPGM="GOBJET"  : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
  Gosub DEFVAR  From GOBJET
  [L]WINPROG="WGOPIH"
  # sr 02.12 Demande 80297
  # Issue 81372 - 2012-05-04 by SR
  Call ISWINDOWOK (nomap,"OPIH") From INTRUTILB
  [L]ACTION="OUVRE"  : [L]WPGM="WOPIH"   : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
  Gosub OUVRE   From WOPIH
  [L]OK=1
  [L]ACTION="OUVRE"  : [L]WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
  Gosub ACTION From GOBJSUB : If !OK  WRET=1 : Goto TRFIN_GENPIH : Endif
  GREP="C"
  [L]ACTION="RAZCRE" : [L]WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
  Gosub ACTION From GOBJSUB : If !OK  WRET=1 : Goto TRFIN_GENPIH : Endif
  GPIH_PICK=1
Endif
#-----
[L]OK=1
[L]ACTION="IMP_DEBUT" : [L]WPGM=WTRT : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From =WTRT : If !OK  WRET=1 : Goto TRFIN_GENPIH : Endif
#----- Chargement masques écrans -----#
[L]ACTION="IMP_ZONE(SAIMSK)" : [L]WPGM="W0PIH0" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Default Mask [PIH0] : Call SAIMSK("PIH","IMP_ZONE",WTRT) From W0PIH0
If mkstat | GPIH_WRET  WRET=1 : Goto TRFIN_GENPIH : Endif
[L]ACTION="IMP_ZONE(SAIMSK)" : [L]WPGM="W0PIH1" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Default Mask [PIH1] : Call SAIMSK("PIH","IMP_ZONE",WTRT) From W0PIH1
If mkstat | GPIH_WRET  WRET=1 : Goto TRFIN_GENPIH : Endif
#----- Ecran lignes -----#
[L]ACTION="IMP_TAB(SAIMSK)"  : [L]WPGM="W0PIH3" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Default Mask [PIH3] : Call SAIMSK("PIH","IMP_TAB", WTRT) From W0PIH3
If mkstat | GPIH_WRET  WRET=1 : Goto TRFIN_GENPIH : Endif
#----- Ecran contrôle -----#
[L]ACTION="IMP_ZONE(SAIMSK)" : [L]WPGM="W0PIH4" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Default Mask [PIH4] : Call SAIMSK("PIH","IMP_ZONE",WTRT) From W0PIH4
If mkstat | GPIH_WRET  WRET=1 : Goto TRFIN_GENPIH : Endif
#----- Point d'entrée pour gestion champs ou écrans supplémentaires spécifiques -----#
GPOINT="ALIMSKPIH" : Gosub ENTREE From EXEFNC
If mkstat | GPIH_WRET  WRET=1 : Goto TRFIN_GENPIH : Endif
#----- Si chargement [M] uniquement alors c'est fini ! -----#
If WCOD<>2  Goto FIN_GENPIH : Endif
#----- Génération de la facture proprement dite -----#
[L]OK=1
[L]ACTION="VERIF_CRE" : [L]WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB : If !OK  WRET=1 : Goto TRFIN_GENPIH : Endif
If WADXLOG=0  Call DEBTRANS From GLOCK : Endif
#-----
$TR_GENPIH
If WADXLOG=0
  GOK=1
  If WTRA>2
    [L]ACTION="Trbegin [PIH], [PIV], [PID]" : [L]WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Trbegin [PIH], [PIV], [PID]
Endif
  Raz [F:PIH], [F:PIV], [F:PID]
  nolign=1
  [F:PIH]=[M:PIH0]
  [F:PIH]=[M:PIH1]
  [F:PIH]=[M:PIH3]
  [F:PIH]=[M:PIH4]
  If dim([F:PIH]CREDAT)>0  [F:PIH]CREDAT=date$     : Endif
  If dim([F:PIH]CRETIM)>0  [F:PIH]CRETIM=time      : Endif
  If dim([F:PIH]CREUSR)>0  [F:PIH]CREUSR=GUSER     : Endif
  If dim([F:PIH]EXPNUM)>0  [F:PIH]EXPNUM=[C]EXPORT : Endif
  Default File [PIH]
  [L]ACTION="INICRE"   : [L]WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
  Gosub ACTION From GOBJSUB
  If GOK<0  Goto ROLL_GENPIH  Elsif !GOK  Goto AB_GENPIH : Endif
  If WTRA>2
    [L]ACTION="Write [PIH]" : [L]WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Write [PIH]
  If fstat  GOK=0 : Call FSTA("PIH") From GLOCK : Goto AB_GENPIH : Endif
  [L]ACTION="CREATION" : [L]WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
  Gosub ACTION From GOBJSUB
  If GOK<0  Goto ROLL_GENPIH  Elsif !GOK  Goto AB_GENPIH : Endif
  If WTRA>2 & WADXLOG=0
    [L]ACTION="Commit" : [L]WPGM="" : Gosub TRACE_DETAILLEE
  Endif
If WADXLOG=0
  Commit
Endif
[L]ACTION="APRES_CRE" : [L]WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
Gosub ACTION From GOBJSUB
# Issue 101539 - 2014-10-21 by SR : Workflow if Intersoc
If WTRT = "TRTACHFAC2" & [F:PIV]BETCPY = 2
  If !clalev([F:AWA]) : Local File AWRKPAR [AWA] : Endif
  Filter [F:AWA] Where TYPEVT = 1 & CODEVT = "PIH" & ENAFLG = 2
  Read [F:AWA]AWA0 First
  If !fstat
      Call WORKFLOW(1,"PIH","","") From AWRK
  Endif
Endif
# End issue 101539
#-----
$TRFIN_GENPIH
If WCOD=2
  [L]ACTION="FERME"     : [L]WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
  Gosub ACTION From GOBJSUB
Endif
Goto FIN_GENPIH
#-----
$ROLL_GENPIH
If WADXLOG=0
  If WTRA>2
    [L]ACTION="Rollback" : [L]WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Rollback
  Call ROLL From GLOCK
  If GROLL
    [L]ACTION="AB_CREATION" : [L]WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
    Gosub ACTION From GOBJSUB : WRET=1 : Goto TRFIN_GENPIH
  Else
    Goto TR_GENPIH
  Endif
Else
  Goto TRFIN_GENPIH
Endif
#-----
$AB_GENPIH
If WADXLOG=0
  If WTRA>2
    [L]ACTION="Rollback" : [L]WPGM="" : Gosub TRACE_DETAILLEE
  Endif
  Rollback
  [L]ACTION="AB_CREATION" : [L]WPGM="GOBJSUB" : If WTRA>2  Gosub TRACE_DETAILLEE : Endif
  Gosub ACTION From GOBJSUB : WRET=1 : Goto TRFIN_GENPIH
Else
  Goto TRFIN_GENPIH
Endif
#-----
$FIN_GENPIH
If WMSG2<>""  WMSG2-=": " : Endif
If WRET
  If clalev([M:PIH0]) & WCOD<>1  Raz [M:PIH0]SIHNUM : Endif
  If WCOD=2 & WTRA>1 : # Inter-sociétés : Facture d'achat non créée !
    Call ECR_TRACE(WMSG2-mess(383,194,1),1) From GESECRAN
  Endif
  If WADXLOG=1 & GOK=1  GOK=0 : Endif
Else
  If WCOD=2 & WTRA>1 : # Inter-sociétés : Facture achat XXXXXXXXXX créée !
    Call ECR_TRACE(WMSG2-mess(46,109,1)-[F:PIH]NUM-mess(224,197,1),0) From GESECRAN
  Endif
Endif
#----- Lecture de la trace si celle-ci a été ouverte dans le s/p -----#
If [L]WOUVTRAFLG
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
#-----
Kill GPIH_WCOD, GPIH_WTRA, GPIH_WRET,  GPIH_WCOE
Kill GSIH_TAX1, GSIH_TAX2, GSIH_NBTAX, GSIH_CUMAMTTAX
GIMPORT=[L]SAV_GIMPORT
nolign =[L]SAV_NOLIGN
# Issue 99226 - 2014-05-12 by SR
GGRPFCY=SAV_GGRPFCY
Return


#--------------------------------------------------------------------------#
#                         Traitement des erreurs                           #
# ------------------------------------------------------------------------ #
#  1 = Le module vente doit être présent !                                 #
#  2 = Paramètrage inter-sociétés introuvable !                            #
#  3 = Facture vente introuvable !                                         #
#  4 = xxxxxxxx Valeur incorrecte                                          #
#  5 = xxxxxxxx Traitement inexistant                                      #
#  6 = Eléments de facturation Tableau plein                               #
#  7 = xx Elément facturation vente sans correspondance dans les achats !  #
#  8 = xxxxxxxx 9999 9999 Ligne commande introuvable !                     #
#  9 = xxxxxxxx 9999 Ligne facture introuvable !                           #
# 10 = xxxxxxxx 9999 Ligne retour introuvable !                            #
# 11 = xxxxxxxx Facture vente déjà facturée côté achats (xxxxxxxx) !       #
# 12 = xxxxxxxx 9999 La livraison n'a pas encore été réceptionnée !        #
# 13 = xxxxxxxx 9999 9999 Inter-sites : La commande de vente n'existe pas !#
#--------------------------------------------------------------------------#
$TRT_ERR
Case WRET
  When  1 : GMESSAGE=mess(268,197,1)
  When  2 : GMESSAGE=mess(454,199,1)
  When  3 : GMESSAGE=WNDO-mess(455,199,1)
  When  4 : GMESSAGE=[L]WZON-mess(83,123,1)
  When  5 : GMESSAGE=WTRT-mess(90,123,1)
  When  6 : GMESSAGE=mess(523,197,1)-mess(26,100,1)
#  When  7 : GMESSAGE=num$([F:SIV]DTA(I))-mess(292,194,1)
  When  7 : GMESSAGE=num$([F:SVF]DTA)-mess(292,194,1)
  When  8 : GMESSAGE ="[POQ]"-[L]WNUMORI-num$([L]WLINORI)-num$([L]WSEQORI)-mess(360,197,1)
  When  9 : GMESSAGE="[PID]"-[L]WNUMORI-num$([L]WLINORI)-mess(520,197,1)
  When 10 : GMESSAGE="[PND]"-[L]WNUMORI-num$([L]WLINORI)-mess(521,197,1)
  When 11 : GMESSAGE=[F:SIV]NUM-mess(525,197,1)-"("+[F:SIV]PIHNUM+") !"
  When 12 : GMESSAGE=[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)-mess(527,197,1)
  When 13 : GMESSAGE=[F:SDD]SOHNUM-num$([F:SDD]SOPLIN)-num$([F:SDD]SOQSEQ)-mess(274,194,1)
Endcase
GPIH_WRET=WRET : GERR=1
If GPIH_WTRA>1
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  If dim(GPURTRACE)>0   GPURTRACE=2  : Endif
  Raz GMESSAGE, GERR
Elsif GPIH_WCOD=2
  Call ERREUR(GMESSAGE)      From GESECRAN
Endif
Return


#---------------------------------------------------------------------#
#                     Traitement des "warning"                        #
# ------------------------------------------------------------------- #
# 21 = Code taxe facture vente inexistant sur facture achat !         #
# 22 = Bases taxes différentes entre facture vente et facture achat ! #
# 23 = Code taxe facture achat inexistant sur facture vente !         #
# 24 = Elément(s) pour gestion des écarts non renseigné(s) !          #
# 25 = Eléments de facturation Tableau plein                          #
# 26 = xxxxxxx 999 La livraison n'a pas encore été réceptionnée !     #
# 27 = xxxxxxx 999 La livraison n'est que partiellement réceptionnée !#
#---------------------------------------------------------------------#
$TRT_WARNING
Case WRET
  When 21 : GMESSAGE=[F:SVV]VAT-mess(293,194,1)
  When 22 : GMESSAGE =[M:PIH4]TAX(I)-[M:PIH4]LIBTAX(I)-":"-mess(295,194,1)
            GMESSAGE-="("+num$([F:SVV]BASTAX)-"<>"-num$(WBASTAX)+")"
  When 23 : GMESSAGE=[M:PIH4]TAX(I)-[M:PIH4]LIBTAX(I)-":"-mess(294,194,1)
  When 24 : GMESSAGE=mess(524,197,1)
  When 25 : GMESSAGE=mess(523,197,1)-mess(26,100,1)
  When 26 : GMESSAGE=[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)-mess(527,197,1)
  When 27 : GMESSAGE=[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)-mess(341,194,1)
Endcase
If GPIH_WTRA>1
  Call ECR_TRACE(GMESSAGE,0) From GESECRAN
  If dim(GPURTRACE)>0   GPURTRACE=2  : Endif
  Raz GMESSAGE
Else
  Call MESSAGE(GMESSAGE)     From GESECRAN
  Raz GMESSAGE
Endif
Return


#-------------------------------------------------------------------------#
# Création d'un élément pied de facture supplémentaire pour gérer l'écart #
#-------------------------------------------------------------------------#
$CRE_ELESUP
Local Decimal  WECART
Local Char     WTAXE(GLONVAT)
Local Decimal  WPFI
Local Libelle  W_IDEB
Case WRET
  When 21
    [L]WECART=[F:SVV]BASTAX
    [L]WTAXE =GSIH_TAX2(I)
  When 22
    [L]WECART=[F:SVV]BASTAX-WBASTAX
    [L]WTAXE =[M:PIH4]TAX(I)
  When 23
    [L]WECART=-[M:PIH4]BASTAX(I)
    [L]WTAXE =[M:PIH4]TAX(I)
Endcase
If [L]WECART<0  [L]WPFI=[F:BCH]PFIDEFNEG  Else  [L]WPFI=[F:BCH]PFIDEFPOS : Endif
#----- Elément écart non renseigné dans le paramétrage -----#
If [L]WPFI=0              [L]WRET=24 : Gosub TRT_WARNING : Return : Endif
#-----
Raz [L]W_IDEB
While W_IDEB<[M:PIH4]NBFAC
  K=find([L]WPFI,[M:PIH4]INVDTA([L]W_IDEB..[M:PIH4]NBFAC-1))
  If !K
    [L]W_IDEB=[M:PIH4]NBFAC
  Elsif [M:PIH4]INVDTAVAT(K-1)<>[L]WTAXE
    [L]W_IDEB=K : K=0
  Else
    [L]W_IDEB=[M:PIH4]NBFAC
  Endif
Wend
#----- Le tableau des éléments est plein, ajout impossible -----#
If !K & [M:PIH4]NBFAC>14  [L]WRET=25 : Gosub TRT_WARNING : Return : Endif
#-----
If [F:PFI]PFINUM<>[L]WPFI
  Read [PFI] PFI0=[L]WPFI : If fstat  Raz [F:PFI] : Endif
Endif
If K
  nolign=K
  Call AVANT_NBFAC From SUBPIH
  [L]WECART+=[M:PIH4]INVDTAAMT(nolign-1)
  Call AM_INVDTAAMT([L]WECART) From SUBPIH
  [M:PIH4]INVDTAAMT(nolign-1)=[L]WECART
  Call AV_INVDIFAMT([M:PIH4]INVDIFAMT(nolign-1)) From SUBPIH
  Call APRES_NBFAC From SUBPIH
Else
  nolign=[M:PIH4]NBFAC+1
  Call AM_INVDTA([L]WPFI) From SUBPIH
  [M:PIH4]INVDTA(nolign-1)=[L]WPFI
  Call AM_INVDTAAMT([L]WECART) From SUBPIH
  [M:PIH4]INVLINFLG(nolign-1)=1
  [M:PIH4]INVORDFLG(nolign-1)=1
  [M:PIH4]INVDTAVAT(nolign-1)=[L]WTAXE
  [M:PIH4]INVDTAAMT(nolign-1)=[L]WECART
  Call AV_INVDIFAMT([M:PIH4]INVDIFAMT(nolign-1)) From SUBPIH
  Call D_ACC1([M:PIH4]ACC1(nolign-1)) From SUBPIH
  [M:PIH4]NBFAC+=1
  Call APRES_NBFAC From SUBPIH
Endif
Return


#----------------------------------------------------------#
# Génération d'une ligne supplémentaire pour gérer l'écart #
# -------------------------------------------------------- #
#  N'est pas appelé pour l'instant, les codes taxes et     #
#  montants étant récupérés des lignes de la facture vente #
#  ce traitement ne semble pas indispensable !!            #
#  De plus le traitement fait ce qu'il peut et tout        #
#  n'est pas top !!                                        #
#----------------------------------------------------------#
$CRE_LIGSUP
[M:PIH3]TYPORI([M:PIH3]NBLIG)=5
[M:PIH3]NUMORI([M:PIH3]NBLIG)=""
[M:PIH3]LINORI([M:PIH3]NBLIG)=0
[M:PIH3]SEQORI([M:PIH3]NBLIG)=0
[M:PIH3]ITMREF([M:PIH3]NBLIG)=""
nolign=[M:PIH3]NBLIG+1
Call CHARG_LIG ([M:PIH3]NBLIG,[M:PIH3]NBLIG) From SUBPIHB
If [M:PIH3]NBLIG>0
  [M:PIH3]UOM([M:PIH3]NBLIG)=[M:PIH3]UOM([M:PIH3]NBLIG-1)
Else
  If !clalev([TUN])  Local File TABUNIT  [TUN] : Endif
  Read [TUN] TUN0 First : If fstat  Raz [F:TUN] : Endif
  [M:PIH3]UOM([M:PIH3]NBLIG)=[F:TUN]UOM
Endif
Case WRET
  When 21
    [M:PIH3]AMTNOTLIN([M:PIH3]NBLIG)= [F:SVV]BASTAX
    # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
    [M:PIH3]AMTNOTLINCAL([M:PIH3]NBLIG)= [M:PIH3]AMTNOTLIN([M:PIH3]NBLIG)
    [M:PIH3]VAT1([M:PIH3]NBLIG)     = GSIH_TAX2(I)
  When 22
    [M:PIH3]AMTNOTLIN([M:PIH3]NBLIG)= [F:SVV]BASTAX-WBASTAX
    # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
    [M:PIH3]AMTNOTLINCAL([M:PIH3]NBLIG)= [M:PIH3]AMTNOTLIN([M:PIH3]NBLIG)
    [M:PIH3]VAT1([M:PIH3]NBLIG)     = [M:PIH4]TAX(I)
  When 23
    [M:PIH3]AMTNOTLIN([M:PIH3]NBLIG)=-[M:PIH4]BASTAX(I)
    # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
    [M:PIH3]AMTNOTLINCAL([M:PIH3]NBLIG)=[M:PIH3]AMTNOTLIN([M:PIH3]NBLIG)
    [M:PIH3]VAT1([M:PIH3]NBLIG)     = [M:PIH4]TAX(I)
Endcase
[M:PIH3]NBLIG+=1
status=0 : Call LINNUM("PIDLIN") From TABLEAUX
Call APRES_NBLIG From SUBPIH
Gosub TEST_VALID From SUBPIH
Return


#-----------------#
# Trace détaillée #
#-----------------#
$TRACE_DETAILLEE
If [L]WPGM=""
  If [L]ACTION="Write [PIH]"
    [L]WMESSAGE=[L]ACTION
  Else
    [L]WMESSAGE="---"-mess(5,126,1)-[L]ACTION
  Endif
Else
  [L]WMESSAGE=mess(27,115,1)-[L]ACTION+space$(20-len([L]ACTION))+"From "-[L]WPGM
Endif
Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
Return


#--------------------------------------------------------------#
# Traitement à effectuer avant le chargement des champs écrans #
#--------------------------------------------------------------#
$DEB_FACINTSOC
#----- Ouverture fichiers si nécessaire -----#
If !clalev([F:BCH])   Local File BETCPY     [BCH]  : Endif
If !clalev([F:BPR2])  Local File BPARTNER   [BPR2] : Endif
If !clalev([F:SFI])   Local File SFOOTINV   [SFI]  : Endif
If !clalev([F:SVF])   Local File SVCRFOOT   [SVF]  : Endif
If !clalev([F:SVV])   Local File SVCRVAT    [SVV]  : Endif
#----- Lecture des paramètres inter-société
Read [BCH] BCH0="STD"
If fstat  WRET=2 : Gosub TRT_ERR : OK=0 : Return  : Endif
#----- Lecture entêtes facture vente -----#
Read [SIH] SIH0=WNDO
If !fstat
  Read [SIV] SIV0=WNDO
Endif
If fstat
  WRET=3  : Gosub TRT_ERR : OK=0 : Return
Endif
If [F:SIV]PIHNUM<>""
  WRET=11 : Gosub TRT_ERR : OK=0 : Return
Endif
#----- Lecture des taxes de la facture/avoir de vente -----#
Raz GSIH_TAX1, GSIH_TAX2, GSIH_NBTAX, GSIH_CUMAMTTAX
For [SVV] SVV0 Where VCRTYP=4 & VCRNUM=WNDO
  GSIH_TAX1(GSIH_NBTAX)=[F:SVV]VAT
  GSIH_TAX2(GSIH_NBTAX)=[F:SVV]VAT
  GSIH_NBTAX+=1
  GSIH_CUMAMTTAX+=[F:SVV]AMTTAX
Next
#----- Point d'entrée pour modifier provisoirement les classes [F:SIH] et [F:SIV] -----#
GPOINT="ALISIHICO" : Gosub ENTREE From EXEFNC
#----- Ouverture fichiers si nécessaire -----#
Case [F:SIV]SIHORI
  When 2, 3
    If !clalev([F:SOQ])   Local File SORDERQ    [SOQ]   : Endif
    If !clalev([F:SDD])   Local File SDELIVERYD [SDD]   : Endif
  When 4
    If !clalev([F:SIV2])  Local File SINVOICEV  [SIV2]  : Endif
    If !clalev([F:SID2])  Local File SINVOICED  [SID2]  : Endif
  When 6
    If !clalev([F:SRD])   Local File SRETURND   [SRD]   : Endif
      # 107888 : Scheduled invoices : (LD:12/05/16)
  When 10       : # Scheduled invoices
      # For the moment, we manage only scheduled invoices from order
      # This will have to be changed when we'll manage other scheduled invoices
    If [F:SIV]SIHORITYP=10
        If !clalev([F:SOQ])   Local File SORDERQ    [SOQ]   : Endif
    Endif
      # 107888 : Scheduled invoices : (LD:12/05/16)
Endcase
Columns [SID] (NUM, SIDLIN, QTY, SDHNUM, SDDLIN)
For [SID] SID0 Where NUM=[F:SIH]NUM
  If [F:SIV]INVTYP=1 & [F:SIV]SIHORI=3
    Read [SDD] SDD0=[F:SID]SDHNUM;[F:SID]SDDLIN
    If fstat  Raz [F:SDD] : Endif
  Endif
  If [F:SIV]INVTYP=1 & [F:SIV]SIHORI=3 & [F:SDD]SDHNUM<>""
    If [F:SDD]QTYSTU=0  [F:SDD]QTYSTU=1 : Endif : # Par sécurité !
    GBIDD1=[F:SID]QTY
    Columns [PTD] (PTHNUM, PTDLIN, LININVFLG, BPSINV, ITMREF, QTYSTU, SDHNUM, SDDLIN)
    For [PTD] PTD1 Where LININVFLG=1
&                      & ITMREF   =[F:SDD]ITMREF
&                      & SDHNUM   =[F:SDD]SDHNUM
&                      & SDDLIN   =[F:SDD]SDDLIN
      [M:PIH3]NUMORI([M:PIH3]NBLIG)=[F:PTD]PTHNUM
      [M:PIH3]LINORI([M:PIH3]NBLIG)=[F:PTD]PTDLIN
      [M:PIH3]QTYUOM([M:PIH3]NBLIG)=[F:SID]QTY*[F:PTD]QTYSTU/[F:SDD]QTYSTU
      GBIDD1-=[M:PIH3]QTYUOM([M:PIH3]NBLIG)
      [M:PIH3]SIDLIN([M:PIH3]NBLIG)=[F:SID]SIDLIN : [M:PIH3]NBLIG+=1
    Next
    Columns [PTD]
    If [M:PIH3]SIDLIN(max([M:PIH3]NBLIG-1,0))<>[F:SID]SIDLIN
      [M:PIH3]SIDLIN([M:PIH3]NBLIG)=[F:SID]SIDLIN : [M:PIH3]NBLIG+=1
    Else
      If GBIDD1<>0  [M:PIH3]QTYUOM([M:PIH3]NBLIG-1)+=GBIDD1 : Raz GBIDD1 : Endif
    Endif
  Else
    [M:PIH3]SIDLIN([M:PIH3]NBLIG)=[F:SID]SIDLIN : [M:PIH3]NBLIG+=1
  Endif
Next
Columns [SID]
[M:PIH0]SIHNUM=WNDO
Raz [F:SID], [F:PTD]
Return


#--------------------------------------------------------------#
# Chargement des champs écrans PIH0, PIH1, PIH4 entête facture #
#--------------------------------------------------------------#
$MSK_ENTETE
# sr 07.12 MultiLeg
Local Integer RET
Case IMPZON
  When "FCY" :      #----- Ecran PIH0 -----#
    If GPIH_WCOD=2
      Read [BPR2] BPR0=[F:SIH]BPR : If fstat  Raz [F:BPR2] : Endif
      If [F:BPR2]FCY<>""
        If [F:FCY]FCY<>[F:BPR2]FCY
          Read [FCY] FCY0=[F:BPR2]FCY : If fstat  Raz [F:FCY] : Endif
        Endif
        If [F:FCY]FINFLG=2
          [M:PIH0]FCY=[F:FCY]FCY
        Else
          [M:PIH0]FCY=[F:FCY]FINRSPFCY
        Endif
      Endif
      IMPMOD=1
    Endif
  When "PIVTYP"
    #----- Vérification si le type facture saisi convient ------#
    If [M:PIH0]PIVTYP<>""
      If !clalev([F:TSV])  Local File TABSIVTYP [TSV] : Endif
      If [F:TSV]SIVTYP<>[F:SIH]SIVTYP
        #MAE, ajout LEG
        Call LEC_TSV_LEG(GCURLEG,[F:SIH]SIVTYP,RET) From TRTLECLEG
        #Read [TSV] TSV0=[F:SIH]SIVTYP  :
        If RET  Raz [F:TSV] : Endif
      Endif
      If [F:TPV]PIVTYP<>[M:PIH0]PIVTYP
        #MAE, ajout LEG
        Call LEC_TPV_LEG(GCURLEG,[M:PIH0]PIVTYP,RET) From TRTLECLEG
        #Read [TPV] TPV0=[M:PIH0]PIVTYP :
        If fstat  Raz [F:TPV] : Endif
      Endif
      If ([F:TSV]LEG<>"" & [F:TPV]LEG<>"" & [F:TSV]LEG<>[F:TPV]LEG) |
&        ([F:TSV]GFY<>"" & [F:TPV]GFY<>"" & [F:TSV]GFY<>[F:TPV]GFY) |
&         [F:TSV]INVTYP<>[F:TPV]INVTYP
        Raz [M:PIH0]PIVTYP
      Endif
    Endif
    #----- Recherche équivalence type de facture vente --> achat -----#
    If [M:PIH0]PIVTYP=""
      Call IS_PIVTYP([F:SIH]FCY,[M:PIH0]FCY,[F:SIH]SIVTYP,[M:PIH0]PIVTYP) From FUNBCH
      IMPMOD=1
    Endif
    #-----
  When "NUM"
  When "ACCDAT"
  When "BPR"
    If [F:FCY]FCY<>[F:SIH]FCY
      Read [FCY] FCY0=[F:SIH]FCY : If fstat Raz [F:FCY] : Endif
    Endif
    GCPY=[F:FCY]LEGCPY
    If [F:FCY]FINFLG=2
      GBIDC3=[F:FCY]FCY
    Else
      GBIDC3=[F:FCY]FINRSPFCY
    Endif
    Read [BPR] BPR2(2)=2;GBIDC3 : If fstat  Raz [F:BPR] : Endif
    [G:BPR]currind=1 : [G:BPR]currlen=0 : # Réinitialisation clé par défaut
    [M:PIH0]BPR=[F:BPR]BPRNUM          : IMPMOD=1
  When "BPRSAC"
  When "PAZ"
  When "BPRVCR" :   #----- Ecran PIH1 -----#
    If func AFNC.ACTIV("KAG") &
&      func AFNC.PARAM("ARGNUM",[M:PIH0]FCY)="2" & dim([M:PIH1]TYPVCR)>0 & len([F:SIH]NUM)>14
      [M:PIH1]TYPVCR=mid$([F:SIH]NUM,len([F:SIH]NUM)-14,2)
      [M:PIH1]CLSVCR=mid$([F:SIH]NUM,len([F:SIH]NUM)-12,1)
      [M:PIH1]SCUVCR=mid$([F:SIH]NUM,len([F:SIH]NUM)-11,4)
      [M:PIH1]SEQVCR=mid$([F:SIH]NUM,len([F:SIH]NUM)-7,8)
    Endif
    [M:PIH1]BPRVCR=[F:SIH]NUM          : IMPMOD=1
  When "BPRDAT"
    [M:PIH1]BPRDAT=[F:SIH]ACCDAT       : IMPMOD=1
  When "BPRPAY"
  When "CUR"
    [M:PIH1]CUR=[F:SIH]CUR             : IMPMOD=1
  When "CURTYP"
    [M:PIH1]CURTYP=[F:SIH]CURTYP       : IMPMOD=1
  When "RAT1"
    #Local Libelle WTYPGEN, WTYPANA
    #Call SETMAINREF([F:SIH]CPY,WTYPGEN,WTYPANA) From CPTDIV
    #[M:PIH1]RAT1=[F:SIH]RATDIV(WTYPGEN-1) : IMPMOD=1
  When "RAT2"
    #Local Libelle WTYPGEN, WTYPANA
    #Call SETMAINREF([F:SIH]CPY,WTYPGEN,WTYPANA) From CPTDIV
    #[M:PIH1]RAT2=[F:SIH]RATMLT(WTYPGEN-1) : IMPMOD=1
  When "INVREF"
    [M:PIH1]INVREF=[F:SIV]INVREF       : IMPMOD=1
  When "STRDUDDAT"
    [M:PIH1]STRDUDDAT=[F:SIH]STRDUDDAT : IMPMOD=1
  When "PTE"
    Local Char SIT(GLONFCY)   : SIT  =[M:PIH0]FCY
    Local Char TIERS(GLONBPS)
    If GPAYTERM=1
      TIERS=[M:PIH1]BPRPAY
    Else
      TIERS=[M:PIH0]BPR
    Endif
    Gosub INIT_BPEXCEPT From CPTSUB
    If !BPE_TROUVE
      [M:PIH1]PTE=[F:SIH]PTE : IMPMOD=1
    Endif
  When "DEP"
    Local Char SIT(GLONFCY)   : SIT=[M:PIH0]FCY
    Local Char TIERS(GLONBPS) : TIERS=[M:PIH0]BPR
    Gosub INIT_BPEXCEPT From CPTSUB
    If !BPE_TROUVE
      [M:PIH1]DEP=[F:SIH]DEP : IMPMOD=1
    Endif
  When "VAC"
    Local Char SIT(GLONFCY)   : SIT=[M:PIH0]FCY
    Local Char TIERS(GLONBPS) : TIERS=[M:PIH0]BPR
    Gosub INIT_BPEXCEPT From CPTSUB
    If !BPE_TROUVE
      [M:PIH1]VAC=[F:SIH]VAC : IMPMOD=1
    Endif
  When "DAS2"
  When "INVNUM"
    If [M:PIH0]PIHTYP=3 & [F:SIH]INVNUM<>""
      Filter [PIH] Where BPR   =[M:PIH0]BPR
&                      & BPRVCR=[F:SIH]INVNUM
&                      & ORIMOD=6
&                      & STA   =3
&                      & PIHTYP<3
      Read [PIH] PIH1 First : If fstat Raz [F:PIH] : Endif
      Filter [PIH]
      If [F:PIH]NUM<>""
        [M:PIH1]INVNUM=[F:PIH]NUM      : IMPMOD=1
      Endif
    Endif
  When "STRDATSVC"
    [M:PIH1]STRDATSVC=[F:SIH]STRDATSVC : IMPMOD=1
  When "ENDDATSVC"
    [M:PIH1]ENDDATSVC=[F:SIH]ENDDATSVC : IMPMOD=1
  When "NBFAC1"
    For [SVF]SVF2 Where VCRTYP=4 & VCRNUM=[F:SIV]NUM
      If [F:SVF]DTA<>0
        J=find([F:SVF]DTA,[F:BCH]SFINUM)
        If J
          K=find([F:BCH]PFINUM(J-1),[M:PIH1]INVDTA1)
          If !K
            If [M:PIH1]NBFAC1<15
              [M:PIH1]NBFAC1+=1
              [M:PIH1]INVDTA1([M:PIH1]NBFAC1-1)=[F:BCH]PFINUM(J-1)
              nolign=[M:PIH1]NBFAC1
              Read [PFI] PFI0=[M:PIH1]INVDTA1(nolign-1) : If fstat Raz [F:PFI] : Endif
              Call AM_INVDTA1([M:PIH1]INVDTA1(nolign-1)) From SUBPIH
              status=0 : Call APRES_NBFAC1 From SUBPIH
              [M:PIH1]INVDTAAMT1([M:PIH1]NBFAC1-1)=[F:SVF]DTANOT
              If [M:PIH4]INVDTAVAT(nolign-1)<>"" & [F:SVF]DTAVAT(0)<>""
                If [M:PIH4]INVDTAVAT(nolign-1)<>[F:SVF]DTAVAT(0)
                  GBIDI1=find([F:SVF]DTAVAT(0),GSIH_TAX1(0..GSIH_NBTAX-1))
                  If GBIDI1
                    GSIH_TAX2(GBIDI1-1)=[M:PIH4]INVDTAVAT(nolign-1)
                  Endif
                Endif
              Endif
            Else
              #----- Tableau des éléments de facturation plein -----#
              Local Integer WRET
              [L]WRET=6 : Gosub TRT_ERR : mkstat=1 : Break
            Endif
          Else
            [M:PIH1]INVDTAAMT1(K-1)=[F:SVF]DTANOT
          Endif
        Else
          #----- Correspondance non trouvée mais est-ce un élément regroupé ? -----#
          Read [SFI] SFI0=[F:SVF]DTA : If fstat  Raz [F:SFI] : Endif
          If [F:SFI]INVFOOBRD<>0
            J=find([F:SFI]INVFOOBRD,[F:BCH]SFINUM)
            If J
              K=find([F:BCH]PFINUM(J-1),[M:PIH1]INVDTA1)
              If !K
                If [M:PIH1]NBFAC1<15
                  [M:PIH1]NBFAC1+=1
                  [M:PIH1]INVDTA1([M:PIH1]NBFAC1-1)=[F:BCH]PFINUM(J-1)
                  nolign=[M:PIH1]NBFAC1
                  Read [PFI] PFI0=[M:PIH1]INVDTA1(nolign-1) : If fstat Raz [F:PFI] : Endif
                  Call AM_INVDTA1([M:PIH1]INVDTA1(nolign-1)) From SUBPIH
                  status=0 : Call APRES_NBFAC1 From SUBPIH
                  [M:PIH1]INVDTAAMT1([M:PIH1]NBFAC1-1)+=[F:SVF]DTANOT
                  If [M:PIH4]INVDTAVAT(nolign-1)<>"" & [F:SVF]DTAVAT(0)<>""
                    If [M:PIH4]INVDTAVAT(nolign-1)<>[F:SVF]DTAVAT(0)
                      GBIDI1=find([F:SVF]DTAVAT(0),GSIH_TAX1(0..GSIH_NBTAX-1))
                      If GBIDI1
                        GSIH_TAX2(GBIDI1-1)=[M:PIH4]INVDTAVAT(nolign-1)
                      Endif
                    Endif
                  Endif
                Else
                  #----- Tableau des éléments de facturation plein -----#
                  Local Integer WRET
                  [L]WRET=6 : Gosub TRT_ERR : mkstat=1 : Break
                Endif
              Else
                [M:PIH1]INVDTAAMT1(K-1)+=[F:SVF]DTANOT
              Endif
            Else
              #----- Elément de vente sans correspondance dans les achats -----#
              Local Integer WRET
              [L]WRET=7 : Gosub TRT_ERR : mkstat=1 : Break
            Endif
          Else
            #----- Elément de vente sans correspondance dans les achats -----#
            Local Integer WRET
            [L]WRET=7 : Gosub TRT_ERR : mkstat=1 : Break
          Endif
        Endif
      Endif
    Next
    If mkstat  Return : Endif
  When "INVDTA1"
  When "INVDTAAMT1"
    IMPMOD=1
  When "DES"
    [M:PIH1]DES(indice)=[F:SIH]DES(indice) : IMPMOD=1
  When "TOTLINAMT1"
  When "TOTTAXAMT1"
  When "NBFAC"  :   #----- Ecran PIH4 -----#
    Gosub TEST_VALID From SUBPIH
  When "INVDTA"
  When "INVDTAAMT"
  When "INVORDAMT"
    If [M:PIH4]INVORDFLG(indice)=2 & [F:SIV]SIHORI=1
      [M:PIH4]INVORDAMT(indice)=[M:PIH4]INVDTAAMT(indice)
    Endif
  When "INVDTAVAT"
  When "ACC1"
  When "ACC2"
  When "ACC3"
  When "ACC4"
  When "ACC5"
  When "ACC6"
  When "ACC7"
  When "ACC8"
  When "ACC9"
  When "ACC10"
  When "DSP"
  When "PFICCE1"
  When "PFICCE2"
  When "PFICCE3"
  When "PFICCE4"
  When "PFICCE5"
  When "PFICCE6"
  When "PFICCE7"
  When "PFICCE8"
  When "PFICCE9"
  When "PFICCE10"
  When "PFICCE11"
  When "PFICCE12"
  When "PFICCE13"
  When "PFICCE14"
  When "PFICCE15"
  When "PFICCE16"
  When "PFICCE17"
  When "PFICCE18"
  When "PFICCE19"
  When "PFICCE20"
  When "NBTAX"
    For I=0 To GSIH_NBTAX-1
      If !find(GSIH_TAX2(I),[M:PIH4]TAX)
        Read [SVV] SVV0=4;[F:SIH]NUM;GSIH_TAX1(I)
        If !fstat & [F:SVV]BASTAX<>0 | [F:SVV]AMTTAX<>0
          #----- Code taxe facture vente inexistant sur facture achat ! -----#
          Local Integer WRET : [L]WRET=21 : Gosub TRT_WARNING
          Gosub CRE_ELESUP : # On ne sait gérer les écarts que sur les éléments
        Endif
      Endif
    Next I
    #----- Un même code taxe peut être éclaté en 3 (achat, immo, prestation) -----#
    Local Char    WTAB_TAX(GLONVAT)([M:PIH4]NBTAX)
    Local Decimal WBASTAX
    Local Decimal WAMTTAX
    For I=0 To [M:PIH4]NBTAX-1 : WTAB_TAX(I)=[M:PIH4]TAX(I) : Next I
    #-----
    For I=0 To [M:PIH4]NBTAX-1
      If WTAB_TAX(I)<>""
        #J=find([M:PIH4]TAX(I),[F:SIH]TAX)
        J=find([M:PIH4]TAX(I),GSIH_TAX2(0..GSIH_NBTAX-1))
        If J
          WTAB_TAX(I)=""
          WBASTAX    =[M:PIH4]BASTAX(I)
          WAMTTAX    =[M:PIH4]AMTTAX(I)
          K=find([M:PIH4]TAX(I),WTAB_TAX)
          If K
            WTAB_TAX(K-1)=""
            WBASTAX     +=[M:PIH4]BASTAX(K-1)
            WAMTTAX     +=[M:PIH4]AMTTAX(K-1)
          Endif
          K=find([M:PIH4]TAX(I),WTAB_TAX)
          If K
            WTAB_TAX(K-1)=""
            WBASTAX     +=[M:PIH4]BASTAX(K-1)
            WAMTTAX     +=[M:PIH4]AMTTAX(K-1)
          Endif
          #----- Bases taxes différentes entre facture vente et facture achat ! -----#
          Read [SVV] SVV0=4;[F:SIH]NUM;GSIH_TAX1(J-1) : If fstat  Raz [F:SVV] : Endif
          If WBASTAX<>[F:SVV]BASTAX & WAMTTAX<>[F:SVV]AMTTAX
            Local Integer WRET : [L]WRET=22 : Gosub TRT_WARNING
            Gosub CRE_ELESUP : # On ne sait gérer les écarts que sur les éléments
          Endif
        Elsif [M:PIH4]AMTTAX(I)<>0
          #----- Code taxe facture achat inexistant sur facture vente ! -----#
          Local Integer WRET : [L]WRET=23 : Gosub TRT_WARNING
          Gosub CRE_ELESUP : # On ne sait gérer les écarts que sur les éléments
        Endif
      Endif
    Next I
  When "AMTTAX"
    I=find([M:PIH4]TAX(nolign-1),GSIH_TAX2(0..GSIH_NBTAX-1))
    If I
      Read [SVV] SVV0=4;[F:SIH]NUM;GSIH_TAX1(I-1)
      If !fstat & ([F:SVV]AMTTAX<>0 | [M:PIH1]VACTYP<>4)
        # Issue X3-87347 - 2018-04-26 by MUARN : pour le calcul de la taxe non déductible
        If [M:PIH4]DEDTAXCOE(nolign-1)=0
          If [M:PIH4]AMTTAX(nolign-1)<>0
            [M:PIH4]DEDTAXCOE(nolign-1)=[M:PIH4]DEDTAX(nolign-1)/[M:PIH4]AMTTAX(nolign-1)
          Endif
        Endif
        [M:PIH4]AMTTAX(nolign-1)=[F:SVV]AMTTAX*[M:PIH4]BASTAX(nolign-1)/[F:SVV]BASTAX
        Call ARRDEV([M:PIH4]AMTTAX(nolign-1),[M:PIH1]CUR) From TRTDIV
        IMPMOD=1
      Endif
    Endif
  When "TOTTAXAMT"
    [M:PIH4]TOTTAXAMT=GSIH_CUMAMTTAX     : IMPMOD=1
  When "TOTLINAMT"
    [M:PIH4]TOTLINAMT=[M:PIH3]CUMLINAMT1 : IMPMOD=1
Endcase
Return


#----------------------------------------------------#
# Chargement des champs écran PIH3 lignes de facture #
#----------------------------------------------------#
$MSK_DETAIL
NOL=nolign-1 : # La variable NOL est définie par W0PIH3
Case IMPZON
  When "NBLIG"
  When "TYPORI"
    Raz GMENLOC : # Pour autoriser tous les types d'origine !
    Local Integer WTYPORI
    Local Char    WNUMORI(GLONVCR)
    Local Integer WLINORI
    Local Integer WSEQORI
    #-----
    Read [SID] SID0=[F:SIH]NUM;[M:PIH3]SIDLIN(NOL) : If fstat  Raz [F:SID] : Endif
    #-----
    If [F:SIV]INVTYP=1    : #----- Facture
      Case [F:SIV]SIHORI
        When 2       : # Facture d'une ligne de commande
          Read [SOQ] SOQ0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
          If !fstat
            [L]WTYPORI=1
            [L]WNUMORI=[F:SOQ]POHNUM
            [L]WLINORI=[F:SOQ]POPLIN
            [L]WSEQORI=[F:SOQ]POQSEQ
            Look [POQ] POQ0=[L]WNUMORI;[L]WLINORI;[L]WSEQORI
            #----- XXXXXXX 999 999 Ligne commande introuvable ! -----#
            If fstat
              Local Integer WRET
              [L]WRET=8 : Gosub TRT_ERR : mkstat=1
            Endif
          Else
            [L]WTYPORI=5
            Raz [L]WNUMORI, [L]WLINORI, [L]WSEQORI, [F:SOQ]
          Endif
        When 3       : # Facture d'une ligne de livraison
          Read [SDD] SDD0=[F:SID]SDHNUM;[F:SID]SDDLIN
          If !fstat
            If [F:SDD]SOHNUM<>""
              Read [SOQ] SOQ0=[F:SDD]SOHNUM;[F:SDD]SOPLIN;[F:SDD]SOQSEQ
              If !fstat
                If [M:PIH3]NUMORI(NOL)<>"" & [M:PIH3]LINORI(NOL)<>0
                  [L]WTYPORI=2
                  [L]WNUMORI=[M:PIH3]NUMORI(NOL)
                  [L]WLINORI=[M:PIH3]LINORI(NOL)
                  [L]WSEQORI=0
                  [F:SID]QTY=[M:PIH3]QTYUOM(NOL) : Raz [M:PIH3]QTYUOM(NOL)
                Else
                # Issue 95092 - 2014-01-13 by SR : que si pas déjà facturée
                  Filter [PTD] Where POHNUM=[F:SOQ]POHNUM
&                                  & POPLIN=[F:SOQ]POPLIN
&                                  & POQSEQ=[F:SOQ]POQSEQ
&                                  & SDHNUM=[F:SDD]SDHNUM
&                                  & SDDLIN=[F:SDD]SDDLIN
&                                  & LININVFLG=1
                  Read [PTD] PTD2 First
                  Filter [PTD]
                  If !fstat
                    [L]WTYPORI=2
                    [L]WNUMORI=[F:PTD]PTHNUM
                    [L]WLINORI=[F:PTD]PTDLIN
                    [L]WSEQORI=0
                  Endif
                Endif
                If fstat
                  #----- Avertissement, la réception devrait être faite ? -----#
                  If [F:SDD]LINTYP<10
                    Local Integer WRET : [L]WRET=26 : Gosub TRT_WARNING
                  Endif
                  #----- Lecture commande vente, compense l'absence de réception -----#
                  Read [SOQ] SOQ0=[F:SDD]SOHNUM;[F:SDD]SOPLIN;[F:SDD]SOQSEQ
                  If !fstat
                    [L]WTYPORI=1
                    [L]WNUMORI=[F:SOQ]POHNUM
                    [L]WLINORI=[F:SOQ]POPLIN
                    [L]WSEQORI=[F:SOQ]POQSEQ
                    Look [POQ] POQ0=[L]WNUMORI;[L]WLINORI;[L]WSEQORI
                    #----- XXXXXXX 999 999 Ligne commande introuvable ! -----#
                    If fstat
                      Local Integer WRET
                      [L]WRET=8 : Gosub TRT_ERR : mkstat=1
                    Endif
                  Else
                    [L]WTYPORI=5
                    Raz [L]WNUMORI, [L]WLINORI, [L]WSEQORI, [F:SOQ], [F:PTD]
                  Endif
                Endif
              Else
                #----- Erreur bloquante, la commande de vente est introuvable ! -----#
                Local Integer WRET : [L]WRET=13 : Gosub TRT_ERR : mkstat=1
                #[L]WTYPORI=5
                #Raz [L]WNUMORI, [L]WLINORI, [L]WSEQORI, [F:SOQ]
              Endif
            Elsif [F:SDD]RCPFLG>0
              #----- La livraison n'est que partiellement réceptionnée ! -----#
              If [F:SDD]RCPFLG=1
                Local Integer WRET : [L]WRET=27 : Gosub TRT_WARNING
              Endif
              #-----
              If [M:PIH3]NUMORI(NOL)<>"" & [M:PIH3]LINORI(NOL)<>0
                [L]WTYPORI=2
                [L]WNUMORI=[M:PIH3]NUMORI(NOL)
                [L]WLINORI=[M:PIH3]LINORI(NOL)
                [L]WSEQORI=0
                [F:SID]QTY=[M:PIH3]QTYUOM(NOL) : Raz [M:PIH3]QTYUOM(NOL)
              Else
                Filter [PTD] Where LININVFLG=1
&                                & BPSINV   =[M:PIH0]BPR
&                                & ITMREF   =[F:SDD]ITMREF
&                                & SDHNUM   =[F:SDD]SDHNUM
&                                & SDDLIN   =[F:SDD]SDDLIN
                Read [PTD] PTD1 First
                Filter [PTD]
                If !fstat
                  [L]WTYPORI=2
                  [L]WNUMORI=[F:PTD]PTHNUM
                  [L]WLINORI=[F:PTD]PTDLIN
                  [L]WSEQORI=0
                Else
                  [L]WTYPORI=5
                  Raz [L]WNUMORI, [L]WLINORI, [L]WSEQORI, [F:PTD]
                Endif
              Endif
            Else
              #----- Erreur bloquante, la réception devrait être faite ? -----#
              Local Integer WRET : [L]WRET=12 : Gosub TRT_ERR : mkstat=1
              #[L]WTYPORI=5
              #Raz [L]WNUMORI, [L]WLINORI, [L]WSEQORI, [F:SDD]
            Endif
          Else
            [L]WTYPORI=5
            Raz [L]WNUMORI, [L]WLINORI, [L]WSEQORI, [F:SDD]
          Endif
      # 107888 : Scheduled invoices : (LD:12/05/16)
        When 10      : # Scheduled invoice's invoice
          # For the moment, we manage only scheduled invoices from order
          # This will have to be changed when we'll manage other scheduled invoices
          If [F:SIV]SIHORITYP=10
              Read [SOQ] SOQ0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
              If !fstat
                [L]WTYPORI=1
                [L]WNUMORI=[F:SOQ]POHNUM
                [L]WLINORI=[F:SOQ]POPLIN
                [L]WSEQORI=[F:SOQ]POQSEQ
                Look [POQ] POQ0=[L]WNUMORI;[L]WLINORI;[L]WSEQORI
                #----- XXXXXXX 999 999 Ligne commande introuvable ! -----#
                If fstat
                  Local Integer WRET
                  [L]WRET=8 : Gosub TRT_ERR : mkstat=1
                Endif
              Else
                [L]WTYPORI=5
                Raz [L]WNUMORI, [L]WLINORI, [L]WSEQORI, [F:SOQ]
              Endif
          Endif
      # 107888 : Scheduled invoices : (LD:12/05/16)
        When Default : # Facture d'une ligne diverse par défaut
          [L]WTYPORI=5
          Raz [L]WNUMORI, [L]WLINORI, [L]WSEQORI
      Endcase
    Elsif [F:SIV]INVTYP=2 : #----- Avoir
      Case [F:SIV]SIHORI
        When 4       : # Avoir d'une ligne de facture
          Read [SIV2] SIV0=[F:SID]SIHORINUM
          If !fstat
            Read [SID2] SID0=[F:SID]SIHORINUM;[F:SID]SIDORILIN
            If !fstat
              [L]WTYPORI=4
              [L]WNUMORI=[F:SIV2]PIHNUM
              [L]WLINORI=[F:SID2]PIDLIN
              [L]WSEQORI=0
              Look [PID] PID0=[L]WNUMORI;[L]WLINORI
              #----- XXXXXXX 999 Ligne facture introuvable ! -----#
              If fstat
                Local Integer WRET
                [L]WRET=9 : Gosub TRT_ERR : mkstat=1
              Endif
              If [M:PIH0]PIHTYP=4  [M:PIH0]PIHTYP=3 : Endif
            Else
              [L]WTYPORI=5
              Raz [L]WNUMORI, [L]WLINORI, [L]WSEQORI, [F:SID2]
            Endif
          Else
            [L]WTYPORI=5
            Raz [L]WNUMORI, [L]WLINORI, [L]WSEQORI, [F:SIV2]
          Endif
        When 6       : # Avoir d'une ligne de retour
          Read [SRD] SRD0=[F:SID]SRHNUM;[F:SID]SRDLIN
          If !fstat & [F:SRD]PNHNUM<>""
            [L]WTYPORI=3
            [L]WNUMORI=[F:SRD]PNHNUM
            [L]WLINORI=[F:SRD]PNDLIN
            [L]WSEQORI=0
            Look [PND] PND0=[L]WNUMORI;[L]WLINORI
            #----- XXXXXXX 999 Ligne retour introuvable ! -----#
            If fstat
              Local Integer WRET
              [L]WRET=10 : Gosub TRT_ERR : mkstat=1
            Endif
            If [M:PIH0]PIHTYP=3  [M:PIH0]PIHTYP=4 : Endif
          Else
            [L]WTYPORI=5
            Raz [L]WNUMORI, [L]WLINORI, [L]WSEQORI, [F:SRD]
          Endif
        When Default : # Avoir d'une ligne diverse par défaut
          [L]WTYPORI=5
          Raz [L]WNUMORI, [L]WLINORI, [L]WSEQORI
      Endcase
    Else                  : #----- Ni facture ni avoir, ligne diverse
      [L]WTYPORI=5
      Raz [L]WNUMORI, [L]WLINORI, [L]WSEQORI
    Endif
    #-----
    If !mkstat
      [M:PIH3]TYPORI(NOL)=[L]WTYPORI
      [M:PIH3]NUMORI(NOL)=[L]WNUMORI
      [M:PIH3]LINORI(NOL)=[L]WLINORI
      [M:PIH3]SEQORI(NOL)=[L]WSEQORI
      [M:PIH3]ITMREF(NOL)=[F:SID]ITMREF
      Call CHARG_LIG (NOL,NOL) From SUBPIHB
      [M:PIH3]SIDLIN(NOL)=[F:SID]SIDLIN
      IMPENT=[L]WTYPORI : # En attendant la correction définitive de Marc Beinat !!
      IMPMOD=1
    Endif
  When "NUMORI"
  When "LINORI"
  When "ITMREF"
  When "ITMDES"
  When "UOM"
    Call PCOUOM([F:SID]SAU,[M:PIH3]BPSNUM(NOL),[M:PIH3]ITMREF(NOL),3,4) From TRTACHCTL1
    If !mkstat
      #----- L'unité de vente est une unité de conditionnement ou d'achat -----#
      [M:PIH3]UOM(NOL)=[F:SID]SAU
    Else
      #----- L'unité de vente ne convient pas, récupération de l'unité d'achat -----#
      Raz mkstat
      #----- Lecture de l'ITMMASTER si nécessaire -----#
      If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
        Read [ITM] ITM0=[M:PIH3]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
      Endif
      #------ Lecture de l'ITMBPS si nécessaire -------#
      If [F:ITP]ITMREF<>[M:PIH3]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:PIH3]BPSNUM(NOL)
        Read [ITP] ITP0=[M:PIH3]ITMREF(NOL);[M:PIH3]BPSNUM(NOL) : If fstat Raz [F:ITP] : Endif
      Endif
      If [F:ITP]PUU<>""
        [M:PIH3]UOM(NOL)=[F:ITP]PUU
      Else
        [M:PIH3]UOM(NOL)=[F:ITM]PUU
      Endif
    Endif
    IMPMOD=1
  When "QTYUOM"
    If [M:PIH3]UOM(NOL)<>[F:SID]SAU
      #----- Recalcul de la qté facturée si unités différentes -----#
      If [M:PIH3]UOM(NOL)=[F:SID]STU
        [M:PIH3]QTYUOM(NOL)=[F:SID]QTY*[F:SID]SAUSTUCOE
        Call QTEARR([M:PIH3]QTYUOM(NOL),[M:PIH3]UOM(NOL)) From TRTDIV
        GPIH_WCOE=[F:SID]SAUSTUCOE
      Else
        Call PCAL_QTY([F:SID]QTY,[F:SID]SAU,[M:PIH3]QTYUOM(NOL),[M:PIH3]UOM(NOL),
&                 [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GPIH_WCOE) From TRTACHQTE1
      Endif
    Else
      #----- Récupération de la qté facturée si même unité -----#
      [M:PIH3]QTYUOM(NOL)=[F:SID]QTY
      GPIH_WCOE=1
    Endif
    #----- Pour ne pas exécuter l'après modif, le IMPMOD=0 ne suffit plus ! -----#
    WNUM=[M:PIH3]QTYUOM(NOL)
    #----- L'après_modif n'est pas activé, il donc traité ici -----#
    [M:PIH3]QTYPUU(NOL)=[M:PIH3]QTYUOM(NOL)*[M:PIH3]UOMPUUCOE(NOL)
    Call QTEARR([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL)) From TRTDIV
    [M:PIH3]PRTFLG(NOL)=1
    If [M:PIH3]TYPORI(NOL)<>5
      If [M:PIH3]QTYPUU(NOL)<GPIH_QTEMAX & [M:PIH0]PIHTYP=3
        [M:PIH3]PRTFLG(NOL)=2
      Elsif [F:SIV]SIHORI=3 & [M:PIH3]TYPORI(NOL)=1 & [F:SDD]QTYSTU<[F:SOQ]QTYSTU # Issue 114934 - 2016-03-02 by MUARN : ajout NOL
        [M:PIH3]PRTFLG(NOL)=2
      # Issue 120057 - 2016-11-29 by SR : Gérer le partiel/Total sur facture de commande
      Elsif find([F:SIV]SIHORI,2,10) & [M:PIH3]TYPORI(NOL)=1 & [F:SOQ]INVQTYSTU<[F:SOQ]QTYSTU & [F:SOQ]INVFLG<>2
        [M:PIH3]PRTFLG(NOL)=2
      Endif
    Else
      Raz GPIH_QTEMAX
    Endif
    [M:PIH3]AMTNOTLIN(NOL)=[M:PIH3]NETPRI(NOL)*[M:PIH3]QTYUOM(NOL)
    Call ARRDEV([M:PIH3]AMTNOTLIN(NOL),[M:PIH1]CUR) From TRTDIV
    # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
    [M:PIH3]AMTNOTLINCAL(NOL)=[M:PIH3]AMTNOTLIN(NOL)
    If [M:PIH3]LINFLG(NOL)=1  [M:PIH3]LINFLG(NOL)=2 : Endif
    #-----
  When "NETPRI"
    If [M:PIH3]UOM(NOL)<>[F:SID]SAU
      #----- Recalcul prix unitaire si unités différentes -----#
      [M:PIH3]NETPRI(NOL)=arr([F:SID]NETPRINOT/GPIH_WCOE,10^-GDECPRI)
    Else
      #----- Récupération prix unitaire si même unité -----#
      [M:PIH3]NETPRI(NOL)=[F:SID]NETPRINOT
    Endif
    IMPMOD=1
  When "AMTNOTLIN"
    #Fq73759-gbn-Avoir "en valeur" : valorisation du montant H.T. de la ligne.
    If [M:PIH3]QTYUOM(NOL)=0
     [M:PIH3]AMTNOTLIN(NOL)=[F:SID]AMTLIN
     Call ARRDEV([M:PIH3]AMTNOTLIN(NOL),[M:PIH1]CUR) From TRTDIV
     # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
     [M:PIH3]AMTNOTLINCAL(NOL)=[M:PIH3]AMTNOTLIN(NOL)
    Endif
  When "PJT"
  When "LINACC1"
  When "LINACC2"
  When "LINACC3"
  When "LINACC4"
  When "LINACC5"
  When "LINACC6"
  When "LINACC7"
  When "LINACC8"
  When "LINACC9"
  When "LINACC10"
  When "LINPURTYP"
  When "LINDSP"
  When "CCE1"
  When "CCE2"
  When "CCE3"
  When "CCE4"
  When "CCE5"
  When "CCE6"
  When "CCE7"
  When "CCE8"
  When "CCE9"
  When "CCE10"
  When "CCE11"
  When "CCE12"
  When "CCE13"
  When "CCE14"
  When "CCE15"
  When "CCE16"
  When "CCE17"
  When "CCE18"
  When "CCE19"
  When "CCE20"
  When "VAT1"
    #[M:PIH3]VAT1(NOL)=[F:SID]VAT(0) : IMPMOD=1
    If [M:PIH3]VAT1(NOL)<>[F:SID]VAT(0)
      GBIDI1=find([F:SID]VAT(0),GSIH_TAX1(0..GSIH_NBTAX-1))
      If GBIDI1
        GSIH_TAX2(GBIDI1-1)=[M:PIH3]VAT1(NOL)
      Endif
    Endif
  When "VAT2"
    #[M:PIH3]VAT2(NOL)=[F:SID]VAT(1) : IMPMOD=1
    If [M:PIH3]VAT2(NOL)<>[F:SID]VAT(1) & [F:SID]VAT(1)<>""
      GBIDI1=find([F:SID]VAT(1),GSIH_TAX1(0..GSIH_NBTAX-1))
      If GBIDI1
        GSIH_TAX2(GBIDI1-1)=[M:PIH3]VAT2(NOL)
      Endif
    Endif
  When "VAT3"
    #[M:PIH3]VAT3(NOL)=[F:SID]VAT(2) : IMPMOD=1
    If [M:PIH3]VAT3(NOL)<>[F:SID]VAT(2) & [F:SID]VAT(2)<>""
      GBIDI1=find([F:SID]VAT(2),GSIH_TAX1(0..GSIH_NBTAX-1))
      If GBIDI1
        GSIH_TAX2(GBIDI1-1)=[M:PIH3]VAT3(NOL)
      Endif
    Endif
  #VPO 03/03/11 72010 recuperer dates de prestation
  When "STRDAT"
    If [F:SID]STRDAT<>[0/0/0]
      [M:PIH3]STRDAT(NOL)=[F:SID]STRDAT
      IMPMOD=1
    Endif
  When "ENDDAT"
    If [F:SID]ENDDAT<>[0/0/0]
      [M:PIH3]ENDDAT(NOL)=[F:SID]ENDDAT
      IMPMOD=1
    Endif
Endcase
Return

